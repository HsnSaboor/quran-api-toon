quran[26]{c,v,t}:
  37,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ذُرِّیَّتَهُۥ هُمُ ٱلۡبَاقِینَ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٢٠<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span>، قال: «<b>ولد نوح ثلاثة: فسامٌ أبو العرب، وحامٌ أبو الحبش، ويافِث أبو الروم</b>»{1}. (١٢/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢١<span class="dash">-</span></span> عن سمرة بن جندب، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span>، قال: «<b>حام، وسام، ويافِث</b>»{2}. (١٢/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span>، يقول: لم يبق إلا ذرية نوح{3}. (١٢/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر ومقاتل، عن الضحاك بن مزاحم- قال: لَمّا خرج نوحٌ ﵇ مِن السفينة مات مَن معه مِن الرجال والنساء إلَّا ولده ونساءهم، فذلك قوله: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span>، قال: فالناسُ كلهم مِن ذرية نوح{5}. (١٢/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ﴾</span> ولد نوح <span class="qpc-hafs">﴿هُمُ الباقِينَ﴾</span> وذلك أنّ أهل السفينة ماتوا ولم يكن لهم نسلٌ غير ولد نوح، وكان الناس مِن ولد نوح، فلذلك قال: <span class="qpc-hafs">﴿هُمُ الباقِينَ﴾</span>. فقال النبي ﷺ: «<b>سام أبو العرب، ويافث أبو الروم، وحام أبو الحبش</b>»{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٦<span class="dash">-</span></span> عن <span class="name-3">الحارث بن عمير البصري</span> -من طريق سفيان بن عيينة- في قوله: <span class="qpc-hafs">﴿وجعلنا ذريته هم الباقين﴾</span>، قال: ولد نوح وبنوه الثلاثة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span> فالناس كلهم ولد سام، وحام، ويافث{8}<span class=comment-ref>٥٤٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٣</span> أفادت الآثار أن أهل الأرض كلهم من ذرية نوح، وهو ما ذكره <u>ابنُ عطية</u> (٧/٢٩٣-٢٩٤)، ثم <span class="comment-type-4">نقل</span> أنّ فرقة قالت: إن الله تعالى أبقى ذرية نوح، ومد نسله، وبارك فيه، وليس الأمرُ أنّ أهل الأرض انحصروا إلى نسله، بل في الأمم من لا يرجع إليه. ثم قال: «والأول أشهر عند علماء الأمة، وقالوا: نُوحٌ هو آدم الأصغر».</div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ذُرِّیَّتَهُۥ هُمُ ٱلۡبَاقِینَ ۝٧٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٢٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>ولد نوح ثلاثة: سام، وحام، ويافث. فولد سام العربَ وفارسَ والرومَ، والخير فيهم، وولد يافث يأجوجَ ومأجوجَ والتركَ والصقالبةَ، ولا خير فيهم، وولد حام القبطَ والبربرَ والسودان</b>»{9}. (١٢/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٢٩<span class="dash">-</span></span> عن سمرة بن جندب، أن النبي ﷺ قال: «<b>سام أبو العرب، وحام أبو الحبش، ويافث أبو الروم</b>»{10}. (١٢/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق يحيى بن سعيد- قال: كان ولد نوح ثلاثة: سام، وحام، ويافث. فسام أبو العرب وفارس والروم، وحام أبو السودان مِن المشرق إلى المغرب، ويافث أبو الترك ويأجوج ومأجوج وما هنالك{11}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه الترمذي ٥/٤٤٠ (٣٥١٠)، وابن جرير ١٩/٥٦٠، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٢-، والثعلبي ٨/١٤٧، وأخرجه الحاكم ٢/٥٩٥ (٤٠٠٦) دون ذكر الآية.</p><p>قال الترمذي: «حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الشوكاني في فتح القدير ٤/٤٦٦: «من سماع الحسن عن سمرة، وفي سماعه منه مقال معروف، وقد قيل: إنه لم يسمع منه إلا حديث العقيقة فقط، وما عداه فبواسطة».|3:أخرجه ابن جرير ١٩/٥٦١. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه الثعلبي ٨/١٤٧. وينظر: تفسير البغوي ٧/٤٤.|5:أخرجه ابن جرير ١٩/٥٦٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٦١٠.|7:أخرجه إسحاق البستي ص٢٠٦.|8:تفسير يحيى بن سلام ٢/٨٣٥.|9:أخرجه الخطيب في تالي تلخيص المتشابه ١/١١٤، وابن عساكر في تاريخ دمشق ٦٢/٢٧٨، من طريق محمد بن يزيد بن سنان الرهاوي، حدثنا أبي، عن يحيى بن سعيد الأنصاري، عن سعيد بن المسيب، عن أبي هريرة به. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>إسناده ضعيف جدًّا؛ فيه محمد بن يزيد بن سنان الرهاوي، قال عنه ابن حجر في التقريب (٦٣٩٩): «ليس بالقوي». وفيه أبوه يزيد بن سنان بن يزيد أبو فروة، قال عنه ابن حجر في التقريب (٧٧٢٧): «ضعيف».</p><p>قال البزار: «لا نعلم أسنده عن النبي ﷺ إلا أبو هريرة بهذا الإسناد، تفرَّد به يزيد بن سنان، وتفرَّد به ابنه عنه، ورواه غيره مرسلًا، وإنما جعله من قول سعيد». وقال ابن حبان في المجروحين ٣/١٠٦ في ترجمة يزيد بن سنان: «كان ممَّن يخطىء كثيرًا، حتى يروي عن الثقات ما لا يشبه حديث الأثبات، لا يعجبني الاحتجاج بخبره إذا وافق الثقات، فكيف إذا انفرد بالمعضلات». ثم ذكر له هذا الحديث من جملة مروياته.|10:أخرجه أحمد ٣٣/٢٩٢-٢٩٣ (٢٠٠٩٩، ٢٠١٠٠)، ٣٣/٣٠٣ (٢٠١١٤)، والترمذي ٥/٤٤٠-٤٤١ (٣٥١١)، ٦/٤٢٣-٤٢٤ (٤٢٧٣)، والحاكم ٢/٥٩٥ (٤٠٠٦) بنحوه، وابن أبي حاتم ٦/٢٠٣١ (١٠٨٧٦).</p><p>قال الترمذي في الموضع الثاني: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ١/١٩٣ (٩٣٣): «رواه الطبراني في الكبير، ورجاله موثقون». وقال المناوي في التيسير ٢/٥١: «بإسناد حسن». وقال الألباني في الضعيفة ٨/١٥٩ (٣٦٨٣): «ضعيف».|11:أخرجه الثعلبي ٨/١٤٧، وابن عساكر بنحوه في تاريخ دمشق ٦٢/٢٧٨. وينظر: تفسير البغوي ٧/٤٤.
  37,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَرَكۡنَا عَلَیۡهِ فِی ٱلۡـَٔاخِرِینَ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</span>، يقول: يُذكَر بخير{1}. (١٢/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: جعلنا لسان صدقٍ للأنبياء كلهم{2}. (١٢/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الثوري- في قول الله: <span class="qpc-hafs">﴿وآتَيْناهُ أجْرَهُ فِي الدُّنْيا﴾</span> [العنكبوت:٢٧]، قال: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: الثناء الصالح{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: السلام، والثناء الحسن{4}. (١٢/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: هو السلام، كما قال: <span class="qpc-hafs">﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</span> [الصافات:٧٩]{5}. (١٢/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: الثناء الحسن{6}. (١٢/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: أبقى اللهُ عليه الثناءَ الحسنَ في الآخرين{7}. (١٢/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</span>، قال: الثناء الحَسَن{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</span> يقول: ألقينا على نوحٍ بعد موته ثناء حسنًا، يُقال له مِن بعده في الآخرين خيرٌ، فذلك قوله ﷿: <span class="qpc-hafs">﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</span> ألقينا عليه في الآخرين الثناءَ الحسن{10}<span class=comment-ref>٥٤٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٢٩٤) على هذا القول بقوله: «وقوله: <span class="qpc-hafs">﴿سَلامٌ﴾</span> على هذا التأويل: رفع بالابتداء مستأنف، سلَّم الله به عليه ليقتدي بذلك البشر».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦١. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد (٥٦٩)، وأخرجه ابن جرير ١٩/٥٦١. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٩ (٢٠٢).|4:عزاه السيوطي إلى ابن أبي حاتم.|5:عزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.|7:أخرجه ابن جرير ١٩/٥٦٢، وعبد الرزاق ٢/١٥٠ بنحوه من طريق معمر، وابن أبي الدنيا في كتاب مكارم الأخلاق بنحوه من طريق شَيْبان -موسوعة الإمام ابن أبي الدنيا ٣/٤٣٢ (١٧)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٩/٥٦٢.|9:تفسير مقاتل بن سليمان ٣/٦١٠.|10:تفسير يحيى بن سلام ٢/٨٣٥.
  37,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَلَـٰمٌ عَلَىٰ نُوحࣲ فِی ٱلۡعَـٰلَمِینَ ۝٧٩ إِنَّا كَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡمُحۡسِنِینَ ۝٨٠ إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِینَ ۝٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</span>، يعني: ما كان بعد نوح؛ الثناء الحسن يُقال لنوح مِن بعده في الناس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</span> يعني بالسلام: الثناء الحسن الذي ترك عليه مِن بعده في الناس، <span class="qpc-hafs">﴿إنّا كَذلِكَ نَجْزِي المُحْسِنِينَ﴾</span> هكذا نجزي كل محسن؛ فجزاه الله ﷿ بإحسانه الثناء الحسن في العالمين، <span class="qpc-hafs">﴿إنَّهُ مِن عِبادِنا المُؤْمِنِينَ﴾</span> يعني: المصدِّقين بالتوحيد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٨٣٤.|2:تفسير مقاتل بن سليمان ٣/٦١٠-٦١١.
  37,80,""
  37,81,""
  37,82,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ أَغۡرَقۡنَا ٱلۡـَٔاخَرِینَ ۝٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</span>، قال: أنجاه اللهُ ومَن معه في السفينة، وأغرق بَقِيَّة قومه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</span>، يعني: قوم نوح{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</span>، يعني: مَن سِوى الذين كانوا معه في السفينة{3}<span class=comment-ref>٥٤٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٩٥) أن قوله تعالى: <span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</span> يقتضي أنّه أغرق قومَ نوح وأُمَّته ومُكَذِّبيه، وأنه ليس في ذلك نصٌّ على أنّ الغرق عمَّ جميعَ أهل الأرض، ثم قال: «ولكن قد قال به جماعة من العلماء، وأُسندت به أحاديث أنه لم يبق إلا مَن كان معه في السفينة، وعلى هذا يترتب القول بأن الناس اليوم من ذريته، وقالوا: لم يكن الناس حينئذ بهذه الكثرة؛ لأن عهد آدم ﵇ كان قريبًا، وكانت دعوة نوح ﵇ ونبوءته قد بلغت جميعَهم لطول المدة واللّبث فيهم، فكان الجميعُ كفرةً عبَدَة أوثان، لم ينسبهم الحق إلى نفسه، فلذلك أغرق جميعهم».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦٣.|2:تفسير مقاتل بن سليمان ٣/٦١١.|3:تفسير يحيى بن سلام ٢/٨٣٥.
  37,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ مِن شِیعَتِهِۦ لَإِبۡرَ ٰ⁠هِیمَ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وإنَّ مِن شِيعَتِهِ﴾</span>، قال: مِن أهل دينه{1}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</span>، قال: مِن شيعة نوح؛ على مِنهاجه وسُنَّته{2}. (١٢/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</span>، قال: مِن شيعة نوحٍ إبراهيمُ، على منهاجه وسُنَّته{3}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</span>، قال: على دينه{4}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</span>، قال: مِن أهل دينه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</span>، يقول: إبراهيم على مِلَّة نوح ﵉{6}<span class=comment-ref>٥٤٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٦</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٩٥): «قال الطبريُّ وغيرُه عن الفراء: الضمير عائد على محمد ﷺ، والإشارة إليه. وذلك كله محتمل؛ لأن الشيعة معناها: الصنف الشائع الذي يشبه بعضه بعضًا. والشِّيَع: الفرق. وإن كان الأعرف أن المتأخر في الزمن هو شيعة للمتقدم، ولكن قد يجيء من الكلام عكس ذلك».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦٤، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه الحاكم ٢/٤٣٠-٤٣١. وعزاه السيوطي إلى ابن المنذر.|3:تفسير مجاهد (٥٦٩)، وأخرجه ابن جرير ١٩/٥٦٤ دون لفظ: من شيعة نوحٍ إبراهيمُ، ومن طريق القاسم بن أبي بزة بنحوه. وعلَّقه يحيى بن سلام ٢/٨٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:أخرجه عبد الرزاق ٢/١٥٤، وابن جرير من طريق سعيد ١٩/٥٦٤ بلفظ: على دينه وملته. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:أخرجه ابن جرير ١٩/٥٦٤. وعلَّقه يحيى بن سلام ٢/٨٣٥ بنحوه.|6:تفسير مقاتل بن سليمان ٣/٦١١.
  37,84,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ جَاۤءَ رَبَّهُۥ بِقَلۡبࣲ سَلِیمٍ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٥٢<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span> -من طريق هشام- أنّه قال: يا بَنِيَّ، لا تكونوا لعّانين، ألم تروا إلى إبراهيم لم يلعن شيئًا قطُّ، فقال الله: <span class="qpc-hafs">﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span>، قال: ليس فيه شكٌّ{2}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span>: سليم مِن الشرك{3}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span>، قال: سليم من الشرك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span>، يعني: بقلبٍ مُخْلِصٍ مِن الشرك{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦٥.|2:أخرجه ابن جرير ١٩/٥٦٥ بلفظ: لا شك فيه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:أخرجه يحيى بن سلام ٢/٨٣٥، وعبد الرزاق ٢/١٥٤ من طريق معمر، وابن جرير ١٩/٥٦٥ بلفظ: <span class="qpc-hafs">﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span> واللهِ مِن الشرك. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ١٩/٥٦٥.|5:تفسير مقاتل بن سليمان ٣/٦١١.
  37,85,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَ لِأَبِیهِ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذْ قالَ لِأَبِيهِ﴾</span> آزر <span class="qpc-hafs">﴿وقومه ماذا تَعْبُدُونَ﴾</span> مِن الأصنام{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦١١.
  37,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَىِٕفۡكًا ءَالِهَةࣰ دُونَ ٱللَّهِ تُرِیدُونَ ۝٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أئِفْكًا آلِهَةً﴾</span>، قال: أكَذِبًا آلهة دون الله تريدون{1}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أئِفْكًا﴾</span> يعني: أكذبًا <span class="qpc-hafs">﴿آلهة﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أئِفْكًا﴾</span> أي: كذبًا، <span class="qpc-hafs">﴿أئِفْكًا آلِهَةً دُونَ اللَّهِ تُرِيدُونَ﴾</span> على الاستفهام، أي: قد فعلتم فعبدتموهم دونه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٦١١.|3:تفسير يحيى بن سلام ٢/٨٣٥.
  37,87,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا ظَنُّكُم بِرَبِّ ٱلۡعَـٰلَمِینَ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَما ظَنُّكُمْ بِرَبِّ العالَمِينَ﴾</span>: إذا لقيتموه وقد عبدتُم غيرَه{1}. (١٢/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما ظَنُّكُمْ بِرَبِّ العالَمِينَ﴾</span> إذا لقيتموه وقد عبدتم غيره{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَما ظَنُّكُمْ بِرَبِّ العالَمِينَ﴾</span>، أي: أنه معذبكم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٦١١.|3:تفسير يحيى بن سلام ٢/٨٣٦.
  37,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَنَظَرَ نَظۡرَةࣰ فِی ٱلنُّجُومِ ۝٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٦٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كان قومُه يتعاطَوْن عِلْمَ النجوم، فعاملهم مِن حيث كانوا؛ لِئَلّا يُنكِروا عليه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</span>، قال: رأى نجمًا طالعًا{2}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</span>، قال: في السماء{3}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قوله: <span class="qpc-hafs">﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</span>، قال: كلمة مِن كلام العرب، يقول إذا تفكر: نظر في النجوم{4}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</span>، يعني: في الكواكب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَنَظَرَ﴾</span> إبراهيم <span class="qpc-hafs">﴿نَظْرَةً فِي النُّجُومِ﴾</span> يعني: الكواكب، وذلك أنه رأى نجمًا طلع، فقال لقادتهم: إنِّي سقيم. وهم ذاهبون إلى عيدهم{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/٤٤ وعقبه: وذلك أنه أراد أن يكايدهم في أصنامهم ليلزمهم الحجة في أنها غير معبودة، وكان لهم من الغد عيد ومجمع، وكانوا يدخلون على أصنامهم ويقربون لهم القرابين، ويصنعون بين أيديهم الطعام قبل خروجهم إلى عيدهم -زعموا- للتبرك عليه، فإذا انصرفوا من عيدهم أكلوه، فقالوا لإبراهيم: ألا تخرج غدًا معنا إلى عيدنا؟ فنظر إلى النجوم فقال: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>.|2:أخرجه عبد الرزاق ٢/١٥٠، وابن جرير ١٩/٥٦٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن المنذر.|4:عزاه السيوطي إلى ابن أبي حاتم. وينظر: تفسير ابن كثير ٧/٢١.|5:علقه يحيى بن سلام ٢/٨٣٦.|6:تفسير مقاتل بن سليمان ٣/٦١١.
  37,89,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَالَ إِنِّی سَقِیمࣱ ۝٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: لَمّا خرج قومُ إبراهيم إلى عيدهم مرُّوا عليه، فقالوا: يا إبراهيم، ألا تخرج معنا؟ قال: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>{1}. (١٠/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، قال: مريض{2}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، يقول: مطعون{3}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، قال: قالوا له وهو في بيت آلهتهم: اخرج. فقال: إني مطعون. فتركوه مخافة الطاعون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فَقالَ إنِّي سَقِيمٌ﴾</span>، قال: كايَدَ{5} نبيُّ الله عن دينه{6}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فَقالَ إنِّي سَقِيمٌ﴾</span>، قال: قالوا لإبراهيم وهو في بيت آلهتهم: اخرج معنا. فقال لهم: إني مطعون. فتركوه مخافة أن يُعديهم{7}. (١٢/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَقالَ إنِّي سَقِيمٌ﴾</span> مريض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: خرج قومُ إبراهيم إلى عيدٍ لهم، وأرادوا إبراهيمَ على الخروج، فاضطجع على ظهره، وقال: إنِّي سقيم، لا أستطيع الخروج. وجعل ينظر إلى السماء، فلما خرجوا أقبل على آلهتهم، فكسَّرها{9}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابنه عبد الرحمن- في قول الله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، قال: أرسل إليه ملكُهم، فقال: إنّ غدًا عيدنا، فاحضر معنا. قال: فنظر إلى نجم، فقال: إنّ ذلك النجم لم يطلع قط إلا طلع بسقم لي، فقال: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>{10}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٧٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿فَقالَ إنِّي سَقِيمٌ﴾</span> أنّهم كانوا بقرية بين البصرة والكوفة يُقال لها: هُرْمُزْخُرد{11}، وكانوا ينظرون في النجوم، قال: <span class="qpc-hafs">﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ * فَقالَ إنِّي سَقِيمٌ﴾</span>. قال: أي: مطعون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، يعني: وجيع. وذلك أنهم كانوا يعبدون الأصنام، كانت اثنين وسبعين صنمًا، مِن ذهب وفضة وشَبَهٍ{13} ونحاس وحديد وخشب، وكان أكبر الأصنام عيناه مِن ياقوتتين حمراوين، وهو مِن ذهب، وكانوا إذا خرجوا إلى عيدهم دخلوا قبل أن يخرجوا، فيسجدون لها، ويقربون الطعام، ثم يخرجون إلى عيدهم، فإذا رجعوا من عيدهم دخلوا عليها، فسجدوا لها، ثم يتفرقون، فلما خرجوا إلى عيدهم اعتلَّ إبراهيمُ بالطاعون، وذلك أنهم كانوا ينظرون في النجوم، فنظر إبراهيم في النجوم، فقال: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨١<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، قال: طعين، وكانوا يفرّون مِن المطعون، فأراد أن يخلو بآلهتهم{15}. (١٢/٤٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَالَ إِنِّی سَقِیمࣱ ۝٨٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٨٢<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>لم يكذب إبراهيم النبي ﵇ قط إلا ثلاث كذبات، ثِنْتين في ذات الله؛ قوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span></b> [الصافات:٨٩]، <b>وقوله: <span class="qpc-hafs">﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</span></b> [الأنبياء:٦٣]، <b>وواحدة في شأن سارة، فإنّه قدم أرض جبار ومعه سارة، وكانت أحسن الناس، فقال لها: إنّ هذا الجبار إن يعلم أنك امرأتي يغلبني عليك، فإن سألكِ فأخبريه أنك أختي، فإنّكِ أختي في الإسلام، فإني لا أعلم في الأرض مسلمًا غيري وغيرك. فلما دخل أرضَه رآها بعضُ أهل الجبار، أتاه فقال له: لقد قدم أرضُك امرأةً لا ينبغي لها أن تكون إلا لك. فأرسل إليها، فأُتي بها، فقام إبراهيم ﵇ إلى الصلاة، فلمّا دخلتْ عليه لم يتمالك أن بسط يدَه إليها، فقُبضت يده قبضة شديدة، فقال لها: ادعي الله أن يطلق يدي ولا أضُرَّكِ. ففعلت، فعاد، فقُبضتْ أشد من القبضة الأولى، فقال لها مثل ذلك، ففعلت، فعاد، فقُبضتْ أشد من القبضتين الأوليين، فقال: ادعي الله أن يطلق يدي، فلكِ الله أن لا أضركِ. ففعلتْ، وأُطلقت يده، ودعا الذي جاء بها، فقال له: إنّك إنّما أتيتني بشيطان، ولم تأتني بإنسان، فأخرِجها من أرضي، وأعطِها هاجر. قال: فأقبلت تمشي، فلمّا رآها إبراهيم ﵇ انصرف، فقال لها: مهيم؟ قالت: خيرًا، كفَّ اللهُ يدَ الفاجر، وأخْدَمَ خادمًا</b>». قال أبو هريرة: فتلك أمُّكُم، يا بني ماء السماء{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٣<span class="dash">-</span></span> عن أبي سعيد، عن النبي ﷺ، قال: «<b>قول إبراهيم: <span class="qpc-hafs">﴿والذي أطمع أن يغفر لي خطيئتي يوم الدين﴾</span></b> [الشعراء:٨٢] <b>في كذباته الثلاث: <span class="qpc-hafs">﴿إني سقيم﴾</span>، وقوله: <span class="qpc-hafs">﴿بل فعله كبيرهم هذا﴾</span></b> [الأنبياء:٦٣]، <b>وقوله: إن سارة أختي، ما منها كلمة إلا ماحَلَ</b>{17} <b>بها عن دِين الله</b>»{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق المسيب بن رافع- قال: ما كذب إبراهيمُ غيرَ ثلاث كذبات: قوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، وقوله: <span class="qpc-hafs">﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</span> [الأنبياء:٦٣] وإنما قاله موعظة، وقوله حين سأله الملك، فقال: أختي. لسارة، وكانت امرأته{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٥<span class="dash">-</span></span> عن <span class="name-2">محمد [بن سيرين]</span> -من طريق أيوب- قال: إنّ إبراهيم ما كذب إلا ثلاث كذبات، ثنتان في الله، وواحدة في ذات نفسه؛ فأما الثنتان فقوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، وقوله: <span class="qpc-hafs">﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</span>، وقصته في سارة. وذكر قصتها وقصة الملك{3}<span class=comment-ref>٥٤٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٧</span> اختُلِف في قوله: <span class="qpc-hafs">﴿إني سقيم﴾</span> على قولين: <b>الأول</b>: أنها كذبة في ذات الله. وعلى هذا التأويل يأتي حديث النبي ﷺ: «<b>ما كذب إبراهيم غير ثلاث كذبات</b>». و<b>الثاني</b>: أنها مِن المعاريض، ولا يجوز الكذب عليه. وعلى هذا قيل: أراد إني سقيم النفس، أي: من أموركم وكفركم، فظهر لهم من كلامه أنه أراد سقمًا بالجسد حاضرًا، وهكذا هي المعاريض.</p><p>و<span class="comment-type-3">اختار</span> <u>ابنُ جرير</u> (١٩/٥٦٩) القولَ الأول، و<span class="comment-type-2">اسْتَدْرَكَ</span> على الثاني بقوله: «<span class="mustanad">الخبر عن رسول الله</span> ﷺ بخلاف هذا القول، وقول رسول الله ﷺ هو الحق دون غيره».</p><p>و<span class="comment-type-3">اختار</span> <u>ابنُ تيمية</u> (٥/٣٤٨) الثاني، حيث <span class="comment-type-4">علَّقَ</span> على مقالات إبراهيم ﵇ الثلاث الواردة في الحديث بقوله: «وهذه الثلاثة معاريض».</p><p>والظاهر مِن كلام <u>ابن عطية</u> (٧/٢٩٧) أنه <span class="comment-type-4">يميل</span> إلى الثاني، حيث قال <span class="comment-type-4">مُعَلِّقًا</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span>: «وهذا التأويل لا يرده الحديث وذكر الكذبات؛ لأنه قد يقال لها: كذب. على الاتساع بحسب اعتقاد المخبر، والكذب الذي هو قصد قول الباطل، والإخبار بضد ما في النفس بغير منفعة شرعية، هو الذي لا يجوز على الأنبياء».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٢/٣٣-٣٤)، ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق مطولًا ٦/١٨١-١٨٢. وعزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ١٩/٥٦٩.|4:أخرجه ابن جرير ١٩/٥٦٦.|5:من الكيد: الحيلة. التاج (كيد).|6:أخرجه عبد الرزاق ٢/١٥٣، وابن جرير ١٩/٥٦٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:أخرجه ابن جرير ١٩/٥٦٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر مختصرًا.|8:تفسير الثعلبي ١٨/١٤٨، وتفسير البغوي ٧/٤٤.|9:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|10:أخرجه ابن جرير ١٩/٥٦٧. وعزاه السيوطي إلى ابن أبي حاتم.|11:كذا في المطبوع، وقال في معجم البلدان: هُرْمُزْجرد: ناحية كانت بأطراف العراق غزاها المسلمون أيام الفتوح. ٥/٤٠٢.|12:علقه يحيى بن سلام ٢/٨٣٦.|13:الشِّبْه والشَّبَه: النحاس يُصْبَغ بدواء فيَصْفَرّ، وسُمّي كذلك لأنه إذا فُعل ذلك به أشبَه الذهبَ بلونه. اللسان (شبه).|14:تفسير مقاتل بن سليمان ٣/٦١٢.|15:أخرجه إسحاق البستي ص٢٠٧. وعزاه السيوطي إلى ابن أبي حاتم دون آخره.|16:أخرجه البخاري ٤/١٤٠-١٤١ (٣٣٥٨)، ٧/٦ (٥٠٨٤)، ومسلم ٤/١٨٤٠ (٢٣٧١) واللفظ له، وابن جرير ١٩/٥٦٨-٥٦٩ بنحوه مختصرًا.|17:ماحل: دافع وجادل. النهاية (محل).|18:أخرجه أبو يعلى ٢/٣١٠ (١٠٤٠)، وابن عساكر في تاريخه ٦/١٧٩، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٥- بنحوه، من طريق سفيان بن عيينة، عن ابن جدعان، عن أبي نضرة، عن أبي سعيد به.</p><p>إسناده ضعيف؛ فيه علي بن زيد بن جدعان، قال عنه ابن حجر في التقريب (٤٧٣٤): «ضعيف».|19:أخرجه ابن جرير ١٩/٥٦٨-٥٦٩.|20:أخرجه ابن جرير ١٩/٥٦٩.
  37,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّوۡا۟ عَنۡهُ مُدۡبِرِینَ ۝٩٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span> يقول: مطعون، <span class="qpc-hafs">﴿فتولوا عنه مدبرين﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٧<span class="dash">-</span></span> قال <span class="name-2">سعيد</span>: إن كان الفرار مِن الطاعون لَقديمًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</span>، قال: فنكصوا عنه منطلقين{2}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</span> ذاهبين، وقد وضعوا الطعام والشراب بين يدي آلهتهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ فَقالَ إنِّي سَقِيمٌ﴾</span>، يقول الله: <span class="qpc-hafs">﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</span> إلى عيدهم، وذلك أنّهم استتبعوه لعيدهم، فعصَب رأسَه، وقال: إنِّي رأيتُ الليلةَ في النجوم أني سأُطْعَن غدًا. كراهية الذهاب معهم، ولِما أراد أن يفعل بآلهتهم، كادهم بذلك وهي إحدى الخطايا الثلاث؛ قال: <span class="qpc-hafs">﴿والَّذِي أطْمَعُ أنْ يَغْفِرَ لِي خَطِيئَتِي يَوْمَ الدِّينِ﴾</span> [الشعراء:٨٢]، وقوله: <span class="qpc-hafs">﴿إنِّي سَقِيمٌ﴾</span>، وقوله: <span class="qpc-hafs">﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</span> [الأنبياء:٦٣]، وقوله لسارة: إن سألوكِ فقولي: إنك أختي{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦٩.|2:أخرجه ابن جرير ١٩/٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٣/٦١٢.|4:أخرجه ابن جرير ١٩/٥٦٧.|5:تفسير يحيى بن سلام ٢/٨٣٦.
  37,91,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرَاغَ إِلَىٰۤ ءَالِهَتِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَراغَ إلى آلِهَتِهِمْ﴾</span>، قال: فمال. قال: ذهب{1}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فَراغَ إلى آلِهَتِهِمْ﴾</span>، قال: ذهب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَراغَ﴾</span> يعني: فمال <span class=comment-ref>٥٤٩٨</span> <span class="qpc-hafs">﴿إلى آلِهَتِهِمْ﴾</span> إلى الصنم الكبير وهو في بيت{3}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٨</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٩/٥٧٠) في بيان معنى <span class="qpc-hafs">﴿فراغَ﴾</span>: "أرى أن أصل ذلك مِن قولهم: راغ فلان عن فلان: إذا حاد عنه، فيكون معناه إذا كان كذلك: فراغ عن قومه والخروج معهم إلى آلهتهم، كما قال عدي بن زيد:</p><p>حين لا ينفع الرواغ ولا ينـ... فع إلا المصادق النحرير.</p><p>يعني بقوله: «لا ينفع الرواغ»: الحياد. أما أهل التأويل فإنهم فسروه بمعنى: فمال".</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٩/٥٧٠.|3:تفسير مقاتل بن سليمان ٣/٦١٢.
  37,92,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَالَ أَلَا تَأۡكُلُونَ ۝٩١ مَا لَكُمۡ لَا تَنطِقُونَ ۝٩٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَقالَ ألا تَأْكُلُونَ﴾</span>: يستنطقهم{1}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: رجع إبراهيمُ ﵇ إلى آلهتهم، فإذا هي في بَهْوٍ عظيم، مستقبل باب البهو صنمٌ عظيمٌ، إلى جنبه أصغر منه، بعضها إلى جنب بعض، فإذا هم قد جعلوا طعامًا بين يدي الأصنام، وقالوا: إذا رجعنا وجدنا الآلهة برّكت في طعامنا؛ فأكلنا. فلما نظر إليهم إبراهيمُ قال: <span class="qpc-hafs">﴿ألا تَأْكُلُونَ* ما لَكُمْ لا تَنْطِقُونَ﴾</span>. فأخذ حديدةً، فبقر كل صنم في حافتيه، ثم علَّق الفأس في الصنم الأكبر، ثم خرج{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقالَ﴾</span> للآلهة: <span class="qpc-hafs">﴿ألا تَأْكُلُونَ﴾</span> الطعامَ الذي بين أيديكم، <span class="qpc-hafs">﴿ما لَكُمْ لا تَنْطِقُونَ﴾</span> ما لكم لا تكلمون؟ ما لكم لا ترُدُّون جوابًا؟ أتأكلون، أو لا تأكلون؟{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير وابن أبي حاتم -كما في فتح الباري ٦/٣٩٩-.|3:تفسير مقاتل بن سليمان ٣/٦١٢.
  37,93,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرَاغَ عَلَیۡهِمۡ ضَرۡبَۢا بِٱلۡیَمِینِ ۝٩٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٩٨<span class="dash">-</span></span> في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (فَراغَ عَلَيْهِمْ صَفْقًا بِاليَمِينِ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٩٩<span class="dash">-</span></span> عن خالد بن عبيد العتكي، قال: سمعت <span class="name-2">الحسن [البصري]</span> قرأ: (فَراغَ عَلَيْهِمْ صَفْقًا بِاليَمِينِ). أي: ضربًا باليمين{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَرَاغَ عَلَیۡهِمۡ ضَرۡبَۢا بِٱلۡیَمِینِ ۝٩٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</span>، لَمّا خلا جعل يضربُ آلهتَهم باليمين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد-، فذكر مثله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</span>: أي: فأقبل عليهنَّ، فكسرهُنَّ{5}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٣<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</span>، يعني: يده اليمنى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَراغَ عَلَيْهِمْ﴾</span> يعني: فأقبل عليها <span class="qpc-hafs">﴿ضَرْبًا بِاليَمِينِ﴾</span> بيده اليمين، يكسرهم بالفأس{7}<span class=comment-ref>٥٤٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٩</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٩٨): «اخْتُلِف في معنى قوله: <span class="qpc-hafs">﴿باليمين﴾</span>، فقال ابن عباس: أراد: يمنى يديه. <b>وقيل</b>: أراد: بقوته؛ لأنه كان يجمع يديه معًا بالفأس. وقيل: أراد: يمين القسم، في قوله: <span class="qpc-hafs">﴿وتالله لأكيدن أصنامكم﴾</span> [الأنبياء:٥٧]».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ جرير</u> (١٩/٥٧١-٥٧٢).</div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</span>: ثم أقبل عليهم -كما قال الله- ضربًا باليمين، ثم جعل يكسرهن بفأسٍ في يده{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ضَرْبًا بِاليَمِينِ﴾</span> فكسرها إلا كبيرهم{9}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه ابن جرير ١٩/٥٧٢.</p><p>وهي قراءة شاذة، تروى أيضًا عن الحسن. انظر: المحتسب ٢/٢٢١، ومختصر ابن خالويه ص١٢٩.|2:أخرجه ابن جرير ١٩/٥٧٢.|3:أخرجه ابن جرير ١٩/٥٧١.|4:أخرجه ابن جرير ١٩/٥٧١.|5:أخرجه ابن جرير ١٩/٥٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه يحيى بن سلام في تفسيره ٢/٨٣٦ بلفظ: فمال عليهم؛ على آلهتهم.|6:تفسير الثعلبي ١٨/١٤٨.|7:تفسير مقاتل بن سليمان ٣/٦١٢.|8:أخرجه ابن جرير ١٩/٥٧١.|9:تفسير يحيى بن سلام ٢/٨٣٦.
  37,94,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَقۡبَلُوۤا۟ إِلَیۡهِ یَزِفُّونَ ۝٩٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span>، قال: يَجْرون{1}. (١٢/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span>، قال: ينسلون. والوزيف: النسَلان{2}. (١٢/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن مجاهد- <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span>: الخيلاء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span>، قال: يَسْعَوْن{4}. (١٢/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span> يبتدرونه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span>، أي: يزفون زفيف النعام{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span>، قال: يَسْعَوْن{7}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span>، قال: يمشون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابنه عبد الرحمن- <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span>، قال: يستعجلون. قال: يزف: يستعجل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span>، قال: يزفون على أقدامهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا رجعوا من عيدهم <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</span> يمشون إلى إبراهيم يأخذونه بأيديهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَأَقْبَلُوا إلَيْهِ﴾</span> إلى إبراهيم <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span> ... قال بعضهم: <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span> يرعدون غضبًا{12}<span class=comment-ref>٥٥٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٠٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٩٩) أن <b>فرقة</b> ذهبت إلى أن <span class="qpc-hafs">﴿يَزِفُّونَ﴾</span> معناه: يتمهلون في مشيهم كزفاف العروس. و<span class="comment-type-4">علَّق</span> عليه بقوله: «والمعنى: أنهم كانوا على طمأنينة مِن أن ينال أحدٌ آلهتَهم بسوء؛ لعزتهم، فكانوا لذلك متمهلين». ثم قال: «وزفّ بمعنى: أسرع. هو المعروف».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٧٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:تفسير مجاهد (٥٦٩)، وأخرجه عبد بن حميد -كما في تغليق التغليق ٤/٢٩٤، وفتح الباري ٨/٥٤٣-، وابن جرير ١٩/٥٧٣. وعزاه السيوطي إلى ابن المنذر. والنَسَلان: الإسراع. اللسان (نسل).|3:أخرجه يحيى بن سلام ٢/٨٣٦.|4:عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|5:علقه يحيى بن سلام ٢/٨٣٦.|6:تفسير الثعلبي ١٨/١٤٩، وقال عقبه: وهو حال بين المشي والطيران.|7:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٩/٥٧٤.|9:أخرجه ابن جرير ١٩/٥٧٤.|10:أخرجه عبد الرزاق ٢/١٥٠.|11:تفسير مقاتل بن سليمان ٣/٦١٢.|12:تفسير يحيى بن سلام ٢/٨٣٦.
  37,95,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالَ أتَعْبُدُونَ ما تَنْحِتُونَ﴾</span>: مِن الأصنام{1}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال لهم إبراهيم: <span class="qpc-hafs">﴿أتَعْبُدُونَ ما تَنْحِتُونَ﴾</span> مِن الأصنام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالَ﴾</span> لهم إبراهيم: <span class="qpc-hafs">﴿أتَعْبُدُونَ ما تَنْحِتُونَ﴾</span> يعني: أصنامهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/٤٦٩، وابن جرير ١٩/٥٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٦١٢.|3:تفسير يحيى بن سلام ٢/٨٣٦.
  37,96,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ خَلَقَكُمۡ وَمَا تَعۡمَلُونَ ۝٩٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٢٢<span class="dash">-</span></span> عن حذيفة، قال: قال النبيُّ ﷺ: «<b>إنّ اللهَ صانعُ كلِّ صانعٍ وصنْعَتِه</b>». وتلا بعضُهم عند ذلك: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</span>{1}. (١٢/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</span>، قال: خلقكم وخلق ما تعملون بأيديكم{2}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</span> وما تنحتون مِن الأصنام{3}<span class=comment-ref>٥٥٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٠١</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿وما تعملون﴾</span> على قولين: <b>الأول</b>: أنّ «ما» مصدرية، والمعنى: والله خلقكم وعملَكم. و<b>الثاني</b>: أنّ «ما» موصولة، والمعنى: والله خلقكم والذي تعملونه.</p><p>وزاد <u>ابنُ عطية</u> (٧/٢٩٩) قولين آخرين، وهما: <b>الثالث</b>: أنّ «ما» نافية، والمعنى: والله خلقكم وأنتم لا تعملون شيئًا في وقت خلقكم ولا قبله، ولا تقدرون على شيء. و<b>الرابع</b>: أنّ «ما» استفهاميّة.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٧/٢٩٩) على القول الأول -وهو قول جماعة من المفسرين-، فقال: «هذه الآية عندهم قاعدة في خلق أفعال العباد، وذلك موافق لمذهب أهل السنة في ذلك».</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (١٩/٥٧٥) على القول الثاني بقوله: «معنى الكلام عند ذلك: واللهُ خلقكم والذي تعملونه، أي: والذي تعملون منه الأصنام، وهو الخشب، والنحاس، والأشياء التي كانوا ينحتون منها أصنامهم، وهذا المعنى الثاني قصد -إن شاء الله- قتادة بقوله: ... بأيديكم».</p><p>و<span class="comment-type-4">بيَّن</span> <u>ابنُ كثير</u> (١٢/٣٦ بتصرف) أنّ القولين الأول والثاني متلازمان، ولكنه <span class="comment-type-3">مال</span> إلى الأول، فقال: «كلا القولين متلازم، والأول أظهر؛ لما رواه البخاري في كتاب أفعال العباد ... <span class="mustanad">عن حذيفة مرفوعًا</span>، قال: «<b>إن الله تعالى يصنع كل صانع وصنعته</b>»».</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ القيم</u> (٢/٣٧٠-٣٧٣) القولَ الثانيَ <span class="mustanad">استنادًا إلى السياق، ونظائرها</span> <span class="mustanad">في القرآن،</span> <span class="mustanad">والدلالة العقلية</span>، و<span class="comment-type-2">انتَقَدَ</span> القولَ الأولَ، قال <u>ابنُ القيم</u>: «ظن كثير من الناس أن قوله تعالى: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</span> أنها مصدرية، واحتجوا بها على خلق الأعمال، وليست مصدرية، وإنما هي موصولة، والمعنى: والله خلقكم وخلق الذي تعملونه وتنحتونه من الأصنام، فكيف تعبدونه وهو مخلوق لله، ولو كانت مصدرية لكان الكلام إلى أن يكون حجة لهم أقرب من أن يكون حجة عليهم؛ إذ يكون المعنى: أتعبدون ما تنحتون والله خلق عبادتكم لها؟ فأي معنى في هذا، وأي حجة عليهم؟ والمقصود أنه كثيرًا ما تدخل إحداهما على الأخرى ويحتملها الكلام سواء. والصواب أنها موصولة، وأنها لا تدل على صحة مذهب القدرية بل هي حجة عليهم مع كونها موصولة ... فالله سبحانه أنكر عليهم عبادتهم الأصنام، وبين أنها لا تستحق العبادة، ولم يكن سياق الكلام في معرض الإنكار عليهم ترْك عبادته، وأن ما هو في معرض الإنكار عبادةُ من لا يستحق العبادة. فلو أنه قال: لا تعبدون الله وقد خلقكم وما تعملون. لتعينت المصدرية قطعًا، ولم يحسن أن يكون بمعنى: الذي؛ إذ يكون المعنى: كيف لا تعبدونه وهو الذي أوجدكم وأوجد أعمالكم، فهو المنعم عليكم بنوعي الإيجاد والخلق. فهذا وِزان ما قرروه مِن كونها مصدرية. فأما سياق الآية فإنه في معرض إنكاره عليهم عبادةَ مَن لا يستحق العبادة، فلا بُدَّ أن يبين فيه معنًى ينافي كونه معبودًا، فبيَّن هذا المعنى بكونه مخلوقًا له، ومَن كان مخلوقًا مِن بعض مخلوقاته فإنه لا ينبغي أن يُعْبَد ولا تليق به العبادة، وتأمل مطابقة هذا المعنى لقوله: <span class="qpc-hafs">﴿والَّذِينَ يَدْعُونَ مِن دُونِ اللَّهِ لا يَخْلُقُونَ شَيْئًا وهُمْ يُخْلَقُونَ﴾</span> [النحل:٢٠] كيف أنكر عليهم عبادة آلهة مخلوقة له سبحانه وهي غير خالقة، فهذا يبين المراد من قوله: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</span>، ونظيره قوله في سورة الأعراف [١٩٤]: <span class="qpc-hafs">﴿إنَّ الَّذِينَ تَدْعُونَ مِن دُونِ اللَّهِ عِبادٌ أمْثالُكُمْ﴾</span> أي: هم عباد مخلوقون كما أنتم كذلك فكيف تعبدون المخلوق. وتأمل طريقة القرآن لو أراد المعنى الذي ذكروه مِن حسن صفاته وانفراده بالخلق كقول صاحب يس: <span class="qpc-hafs">﴿وما لِيَ لا أعبد الَّذِي فَطَرَنِي﴾</span> [يس:٢٢] فهنا لما كان المقصود إخبارهم بحسن عبادته واستحقاقه لها ذكر الموجب لذلك، وهي كونه خالقًا لعابده فاطرًا له، وهذا إنعام منه عليه؛ فكيف يترك عبادته؟! ولو كان هذا هو المراد من قوله: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</span> كان يقتضي أن يقال: ألا يعبدون الله وهو خالقهم وخالق أعمالهم. فتأمله فإنه واضح».</p><p>ثم بيَّن كيف يستدل بالآية على خلق الله لأعمال العباد، فقال: «ووجه الاستدلال بها على هذا التقدير: أنّ الله سبحانه أخبر أنه خالقهم وخالق الأصنام التي عملوها، وهي إنما صارت أصنامًا بأعمالهم، فلا يقع عليها ذلك الاسم إلا بعد عملهم، فإذا كان سبحانه هو الخالقُ اقتضى صِحَّة هذا الإطلاق أن يكون خالقها بجملتها، أعني: مادتها وصورتها، فإذا كانت صورتها مخلوقة لله كما أنّ مادتها كذلك لزم أن يكون خالقًا لنفس عملهم الذي حصلت به الصورة؛ لأنه متولد عن نفس حركاتهم، فإذا كان الله خالقها كانت أعمالهم التي تولد عنها ما هو مخلوق لله مخلوقة له، وهذا أحسن استدلالًا وألطف من جعل»ما«مصدرية، ونظيره من الاستدلال سواء قوله: <span class="qpc-hafs">﴿وآيَةٌ لَهُمْ أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span> [يس:٤١-٤٢]، والأصح أن المثل المخلوق هنا هو السفن، وقد أخبر أنها مخلوقة، وهي إنما صارت سفنًا بأعمال العباد، ونظير هذا الاستدلال أيضًا قوله تعالى: <span class="qpc-hafs">﴿واللَّهُ جَعَلَ لَكُمْ مِمّا خَلَقَ ظِلالًا وجَعَلَ لَكُمْ مِنَ الجِبالِ أكْنانًا وجَعَلَ لَكُمْ سَرابِيلَ تَقِيكُمُ الحَرَّ وسَرابِيلَ تَقِيكُمْ بَأْسَكُمْ﴾</span> [النحل:٨١] والسرابيل التي يلبسونها وهي مصنوعة لهم، وقد أخبر بأنه سبحانه هو جاعلها، وإنما صارت سرابيل بعملهم، ونظيره: <span class="qpc-hafs">﴿واللَّهُ جَعَلَ لَكُمْ مِن بُيُوتِكُمْ سَكَنًا وجَعَلَ لَكُمْ مِن جُلُودِ الأنْعامِ بُيُوتًا﴾</span> [النحل:٨٠] والبيوت التي من جلود الأنعام هي الخيام، وإنما صارت بيوتًا بعملهم. <b>فإن قلت</b>: المراد من هذا كله المادة لا الصورة. قلت: المادة لا تستحق هذه الأسماء التي أطلق الخلق عليها، وإنما تستحق هذه الأسماء بعد عملها وقيام صورها بها، وقد أخبر أنها مخلوقة له في هذه الحال. والله أعلم. فالأولى أن تكون»ما«موصولة، أي: والله خلقكم وخلق آلهتكم التي عملتموها بأيديكم، فهي مخلوقة له، لا آلهة شركاء معه، فأخبر أنه خلق معمولهم، وقد حله عملهم وصنعهم، ولا يقال:»المراد مادته«فإن مادته غير معمولة لهم، وإنما يصير معمولًا بعد عملهم».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ تيمية</u> (٥/٣٤٨-٣٥١)، و<span class="comment-type-2">ضعَّفَ</span> القول الأول جدًّا، بل <span class="comment-type-2">غلَّطه</span>.</div></p></div>",footnotes:1:أخرجه الحاكم ١/٨٥ (٨٥، ٨٦) بلفظ: «<b>خالق كل صانع</b>»، والبخاري في خلق أفعال العباد ص٤٦ واللفظ له.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الهيثمي في المجمع ٧/١٩٧ (١١٨٣٢): «رواه البزار، ورجاله رجال الصحيح غير أحمد بن عبد الله أبو الحسين ابن الكردي، وهو ثقة». وأورده الألباني في الصحيحة ٤/١٨١ (١٦٣٧).|2:أخرجه يحيى بن سلام ٢/٨٣٦-٨٣٧، وابن جرير ١٩/٥٧٥، وعنده في رواية أخرى: الأصنام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وعقب يحيى بن سلام عليه بقوله: أي: خلقكم وخلق ذلك الذي تنحتون.|3:تفسير مقاتل بن سليمان ٣/٦١٢.
  37,97,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ ٱبۡنُوا۟ لَهُۥ بُنۡیَـٰنࣰا فَأَلۡقُوهُ فِی ٱلۡجَحِیمِ ۝٩٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٢٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿قالُوا ابْنُوا لَهُ بُنْيانًا﴾</span> بنوا حائطًا مِن حجارة، طوله في السماء ثلاثون ذراعًا، وعرضه عشرون ذراعًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: جمعوا الحطبَ زمانًا، حتّى إنَّ الشيخ الكبير الذي لم يخرج مِن بيته قبل ذلك زمانًا كان يجيء بالحطب، فيُلقيه يتقرَّب به إلى آلهتهم فيما يزعم، ثم جاءوا بإبراهيم، فألقوه في تلك النار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قالُوا ابْنُوا لَهُ بُنْيانًا فَأَلْقُوهُ فِي الجَحِيمِ﴾</span>، قال: فحبسوه في بيت، وجمعوا له حَطبًا، حتى إن كانت المرأةُ لَتَمرضُ فتقول: لَئِن عافاني اللهُ لأجمعنَّ حطبًا لإبراهيم. فلمّا جمعوا له وأكثروا من الحطب، حتى إن كانت الطير لَتَمُرُّ بها فتحترق مِن شدة وهجها، فعمدوا إليه، فرفعوه على رأس البنيان، فرفع إبراهيمُ رأسَه إلى السماء، فقالت السماء والأرض والجبال والملائكة: ربَّنا، إبراهيم يُحْرَق فيك. فقال: أنا أعلمُ به، وإن دعاكم فأغيثوه. وقال إبراهيم حين رفع رأسه إلى السماء: اللهم، أنت الواحد في السماء، وأنا الواحد في الأرض، ليس في الأرض أحد يعبدك غيري، حسبي الله ونعم الوكيل. فقذفوه فيها، فناداها: <span class="qpc-hafs">﴿يا نارُ كُونِي بَرْدًا وسَلامًا عَلى إبْراهِيمَ﴾</span> [الأنبياء:٦٩]{3}. (١٢/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَلْقُوهُ فِي الجَحِيمِ﴾</span> في نار عظيمة، قال الله ﷿: <span class="qpc-hafs">﴿يا نارُ كُونِي بَرْدًا وسَلامًا عَلى إبْراهِيمَ﴾</span> [الأنبياء:٦٩]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالُوا ابْنُوا لَهُ بُنْيانًا﴾</span> يقوله بعضهم لبعض <span class="qpc-hafs">﴿فَأَلْقُوهُ فِي الجَحِيمِ﴾</span> أي: في النار. بلغني: أنّهم رموا به في المنجنيق، فكان ذلك أول ما صُنع المنجنيق{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦١٣.|2:علقه يحيى بن سلام ٢/٨٣٧.|3:أخرجه ابن جرير١٦/٣٠٦.|4:تفسير مقاتل بن سليمان ٣/٦١٣.|5:تفسير يحيى بن سلام ٢/٨٣٧.
  37,98,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَرَادُوا۟ بِهِۦ كَیۡدࣰا فَجَعَلۡنَـٰهُمُ ٱلۡأَسۡفَلِینَ ۝٩٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَأَرادُوا بِهِ كَيْدًا فَجَعَلْناهُمُ الأَسْفَلِينَ﴾</span>، قال: فما ناظرهم اللهُ بعد ذلك حتى أهلكهم{1}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَرادُوا بِهِ كَيْدًا﴾</span> سوءًا، الآية [الأنبياء:٧٠]، وعلاهم{2} إبراهيم ﵇، وسلَّمه الله ﷿، وحجزهم عنه، فلم يلبثوا إلا يسيرًا حتى أهلكهم الله ﷿، فما بقيت يومئذ دابةٌ إلا جعلتْ تُطْفِئ النار عن إبراهيم ﵇، غير الوزغ؛ كانت تنفخ النار على إبراهيم، فأمر النبي ﷺ بقتْلها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَأَرادُوا بِهِ كَيْدًا﴾</span> تحريقهم إيّاه، <span class="qpc-hafs">﴿فَجَعَلْناهُمُ الأَسْفَلِينَ﴾</span> في النار{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:كذا، ولعلها مفهوم قول الله تعالى: <span class="qpc-hafs">﴿فَجَعَلْناهُمُ الأَسْفَلِينَ﴾</span>.|3:تفسير مقاتل بن سليمان ٣/٦١٣.|4:تفسير يحيى بن سلام ٢/٨٣٨.
  37,99,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ إِنِّی ذَاهِبٌ إِلَىٰ رَبِّی سَیَهۡدِینِ ۝٩٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٣٣<span class="dash">-</span></span> عن <span class="name-1">سليمان بن صرد</span> -من طريق أبي إسحاق- يقول: لَمّا أرادوا أن يلقوا إبراهيم في النار <span class="qpc-hafs">﴿قالَ إنِّي ذاهِبٌ إلى رَبِّي سَيَهْدِينِ﴾</span>. فجُمِع الحطب، فجاءت عجوز على ظهرها حطب، فقيل لها: أين تريدين؟ قالت: أريد أذهب إلى هذا الرجل الذي يُلقى في النار. فلما ألقي فيها قال: حسبي الله عليه توكلت، أو قال: حسبي الله ونعم الوكيل. قال: فقال الله: <span class="qpc-hafs">﴿يا نارُ كُونِي بَرْدًا وسَلامًا عَلى إبْراهِيمَ﴾</span>. قال: فقال ابن لوط، أو ابن أخي لوط: إنّ النار لم تحرقه مِن أجلي. وكان بينهما قرابة، فأرسل الله عليه عُنُقًا مِن النار، فأحرقته{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وقالَ إنِّي ذاهِبٌ إلى رَبِّي سَيَهْدِينِ﴾</span>، قال: حين هاجر{2}<span class=comment-ref>٥٥٠٢</span>. (١٢/٤٢٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٠٢</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٩/٥٧٦-٥٧٧): «قال آخرون في ذلك: إنما قال إبراهيم: <span class="qpc-hafs">﴿إني ذاهب إلى ربي﴾</span> حين أرادوا أن يلقوه في النار». وذكر أثر سليمان بن صرد السابق، ثم <span class="comment-type-3">اختار</span> القول الأول أنه قال ذلك حين أراد الهجرة <span class="mustanad">مستندًا إلى النظائر</span>، وقال: «إنما اخترت القول الذي قلت في ذلك لأن الله ﷾ ذكر خبره وخبر قومه في موضع آخر، فأخبر أنه لما نجاه مما حاول قومه من إحراقه قال: <span class="qpc-hafs">﴿إني مهاجر إلى ربي﴾</span> [العنكبوت:٢٦] ففسر أهل التأويل ذلك أن معناه: إني مهاجر إلى أرض الشام، فكذلك قوله: <span class="qpc-hafs">﴿إني ذاهب إلى ربي﴾</span>؛ لأنه كقوله: <span class="qpc-hafs">﴿إني مهاجر إلى ربي﴾</span>».</p><p>و<span class="comment-type-4">ذَهَبَ</span> إلى الأول أيضًا <u>ابنُ عطية</u> (٧/٣٠٠) <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «الأول أظهر في نمط الآية عما بعده؛ لأن الهداية معه تترتب، والدعاء في الولد كذلك، ولا يصح مع ذهاب الفناء».</p><p>وإلى ذلك أيضًا <span class="comment-type-4">ذهب</span> <u>ابنُ كثير</u> (١٢/٣٧).</div></p><p><div></p><p><p><span class="item-no">٦٥٦٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقالَ إنِّي ذاهِبٌ إلى رَبِّي﴾</span>، قال: ذاهب بعمله، وقلبه، ونيته{3}. (١٢/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَ﴾</span> وهو ببابل: <span class="qpc-hafs">﴿إنِّي ذاهِبٌ﴾</span> يعني: مهاجر <span class="qpc-hafs">﴿إلى رَبِّي﴾</span> إلى رِضا ربي بالأرض المقدسة، <span class="qpc-hafs">﴿سَيَهْدِينِ﴾</span> لدينه. وهو أول من هاجر من الخلق، ومعه لوط وسارة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقالَ إنِّي ذاهِبٌ إلى رَبِّي سَيَهْدِينِ﴾</span> الطريق، يعني: الهجرة، هاجر من أرض العراق إلى أرض الشام. قال <span class="name-2">قتادة</span>: وكان يُقال: إنّ الشام عماد دار الهجرة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في العقوبات ٤/٤٩٤ (٢٤٠)، وابن جرير ١٩/٥٧٦-٥٧٧.|2:عزاه السيوطي إلى ابن المنذر. وذكر محققو الدر المنثور أنه جاء في بعض نسخه بعد هذا الأثر: وأخرج عبد بن حميد عن مجاهد مثله.|3:أخرجه ابن جرير ١٩/٥٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٦١٣.|5:تفسير يحيى بن سلام ٢/٨٣٨.
  37,100,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿رَبِّ هَبۡ لِی مِنَ ٱلصَّـٰلِحِینَ ۝١٠٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٣٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿رَبِّ هَبْ لِي مِنَ الصّالِحِينَ﴾</span>، قال: ولدًا صالحًا{1}. (١٢/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا قدم الأرض المقدسة، سأل ربَّه الولد: <span class="qpc-hafs">﴿رَبِّ هَبْ لِي مِنَ الصّالِحِينَ﴾</span> ولدًا صالحًا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٧٧. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٦١٤.
  37,101,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَبَشَّرۡنَـٰهُ بِغُلَـٰمٍ حَلِیمࣲ ۝١٠١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٤٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الزهري عن القاسم- <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>: هو إسماعيل. وكان ذلك بمنى{1}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤١<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span> -من طريق الزهري، عن القاسم- <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>: هو إسحاق، وكان ذلك ببيت المقدس{1}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٢<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>، قال: هو إسحاق{3}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>، قال: هو إسحاق{4}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، في قوله: <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>، قال: هو إسماعيل. قال: وبشَّره الله بنبوة إسحاق بعد ذلك{5}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>، قال: بولادة إسحاق{6}. (١٢/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، مثله{7}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>، قال: بُشِّرَ بإسحاق. قال: ولم يُثْنِ اللهُ بالحِلْم على أحد إلا على إبراهيم وإسحاق{8}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>، قال: إسماعيل{9}. (١٢/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فاستجاب له، <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span> يعني: عليم، وهو العالم، وهو إسحاق بن سارة{10}<span class=comment-ref>٥٥٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٠٣</span> اختُلِف في المراد بقوله تعالى: <span class="qpc-hafs">﴿فبشرناه بغلام حليم﴾</span> على قولين: <b>الأول</b>: أنها البشارة المعروفة بإسحاق ﵇، وهو الذبيح على قول. <b>والثاني</b>: أنها البشارة بإسماعيل ﵇، وهو الذبيح. وسيأتي بيان كلام الأئمة، عند قوله تعالى: <span class="qpc-hafs">﴿وفديناه بذبح عظيم﴾</span>.</div></p><p><h3><span class="qpc-hafs">﴿فَبَشَّرۡنَـٰهُ بِغُلَـٰمٍ حَلِیمࣲ ۝١٠١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٥٠<span class="dash">-</span></span> عن يونس، قال: سمعت <span class="name-2">الحسن</span> يقول: ما سمعتُ الله نَحَلَ عباده شيئًا أقل مِن الحلم؛ فإنه قال: <span class="qpc-hafs">﴿إنَّ إبْراهِيمَ لَحَلِيمٌ﴾</span> [هود:٧٥]، وقال: <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span>{11}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد الرزاق، وابن المنذر.|2:عزاه السيوطي إلى عبد الرزاق، وابن المنذر.|3:أخرجه عبد الرزاق ٢/١٥٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|4:أخرجه ابن جرير ١٩/٥٧٨.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|7:عزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ١٩/٥٧٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|9:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|10:تفسير مقاتل بن سليمان ٣/٦١٤.|11:أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ٢/٧٠٧.
  37,102,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعۡیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: العمل{1}. (١٢/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: شبَّ، حتى بلغ سعيُه سعيَ إبراهيم في العمل{2}. (١٢/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٤<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، يعني: المشي معه إلى الجبل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: لما شبَّ حتى أدرك سعيُه سعيَ إبراهيم في العمل{4}. (١٢/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: العمل{5}. (١٢/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: أدرك معه العمل{6}. (١٢/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span> بلغ معه سعي العمل، يعني: قيام الحجة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: لَمّا مَشى مع أبيه{8}<span class=comment-ref>٥٥٠٤</span>. (١٢/٤٢٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٠٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧٨/٣٠١) أن «السَّعْيَ» في هذه الآية: العمل والعبادة والمعونة. ثم قال: «هذا قول ابن عباس، ومجاهد، وابن زيد». وساق القول بأن المراد: السعي على القدم. الذي قال به قتادة، وما في معناه، و<span class="comment-type-4">علَّق</span> عليه بقوله: «يريد: سعيًا متمكنًا. وهذا في المعنى نحو الأول».</div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، يعني: المشي{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق عبد الوهاب- قال: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، يقول: فلمّا عمِل مثلَ عمله{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ﴾</span> مع أبيه <span class="qpc-hafs">﴿السَّعْيَ﴾</span> المشي إلى الجبل{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٣<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، يعني: العمل الذي يقوم به الحجة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</span>، قال: السعي هاهنا: العبادة{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰبُنَیَّ إِنِّیۤ أَرَىٰ فِی ٱلۡمَنَامِ أَنِّیۤ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٦٥<span class="dash">-</span></span> عن الضحاك: (فَأَسَرَّ فِي نَفْسِهِ حُزْنًا) في قراءة <span class="name-1">عبد الله [بن مسعود]</span>، <span class="qpc-hafs">﴿قالَ يا بُنَيَّ إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ﴾</span>{14}. (١٢/٤٢٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰبُنَیَّ إِنِّیۤ أَرَىٰ فِی ٱلۡمَنَامِ أَنِّیۤ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٦٦<span class="dash">-</span></span> عن <span class="name-2">عُبيد بن عُمير</span> -من طريق عمرو بن دينار- قال: رؤيا الأنبياء وحيٌ. ثم تلا هذه الآية: <span class="qpc-hafs">﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</span>{15}. (١٢/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٧<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٨<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿قالَ يا بُنَيَّ إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ﴾</span> أُمِر إبراهيمُ أن يذبح ابنَه ببيت المقدس، فلما تيقّن ذلك أخبر ابنَه، فقال: <span class="qpc-hafs">﴿فانْظُرْ ماذا تَرى﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</span> رؤيا الأنبياء حقٌّ، إذا رأوا شيئًا فعلوه{17}. (١٢/٤٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٧٠<span class="dash">-</span></span> عن <span class="name-2">عثمان بن حاضر</span>، قال: لَمّا أراد إبراهيمُ أن يذبح ابنَه إسحاقَ؛ ترك أُمَّه سارةَ في مسجد الخيف، وذهب بإسحاق معه، فلما بلغ حيث أراد أن يذبحه قال إبراهيمُ لِمَن كان معه: استأخروا مِنِّي. وأخذ بيد ابنه إسحاق، فعزله، فقال: <span class="qpc-hafs">﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</span>. قال له إسحاق: يا أبتِ، ربِّي أمرك؟ قال إبراهيم: نعم، يا إسحاق. قال إسحاق: <span class="qpc-hafs">﴿يا أبَتِ افْعَلْ ما تُؤْمَرُ سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</span>{18}. (١٢/٤٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ يا بُنَيَّ إنِّي أرى فِي المَنامِ﴾</span> لِنَذْرٍ كان عليه فيه، يقول: إني أُمرت في المنام <span class="qpc-hafs">﴿أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</span>{11}<span class=comment-ref>٥٥٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٠٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٣٠١) أن قوله: <span class="qpc-hafs">﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يكون رأى ذلك بعينه، ورؤيا الأنبياء وحي، وعُيّن له وقت الامتثال. <b>الثاني</b>: أن يكون أُمر في نومه بذبحه، فعبر هو عن ذلك، أي: إني رأيت في المنام ما يوجب أن أذبحك.</div></p><p><div></p><p><p><span class="item-no">٦٥٦٧٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: يقول الله تعالى في الخبر عن إبراهيم: <span class="qpc-hafs">﴿قال يا بني إني أرى في المنام أني أذبحك﴾</span> ثم مضى على ذلك، فعرف أنّ الوحي من الله يأتي الأنبياء أيقاظًا ونيامًا، وكان رسول الله ﷺ -فيما بلغني- يقول: «<b>تنام عيناي، وقلبي يقظان</b>». فالله أعلم أنّى ذلك كان قد جاءه وعاين فيه ما عاين مِن أمر الله، على أيِّ حالات كان نائمًا أو يقظانًا، كل ذلك حقٌّ وصِدق{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰبُنَیَّ إِنِّیۤ أَرَىٰ فِی ٱلۡمَنَامِ أَنِّیۤ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٧٣<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>رؤيا الأنبياء وحي</b>»{21}. (١٢/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٧٤<span class="dash">-</span></span> عن <span class="name-2">كعب</span> -من طريق عمرو بن أبي سفيان بن أسيد بن حارثة الثقفي- أنّه قال لأبي هريرة: ألا أخبرك عن إسحاق؟ قال: بلى. قال: أُرِيَ إبراهيمُ أن يذبح إسحاق، قال الشيطان: واللهِ، لئن لم أفْتِن عند هذه آلَ إبراهيم لا أفْتِنُ أحدًا منهم أبدًا. فتمثَّل الشيطانُ رجلًا يعرفونه، فأقبل حتى خرج إبراهيمُ بإسحاق ليذبحه، دخل على سارة، فقال لها: أين أصبح إبراهيمُ غاديًا بإسحاق؟ قالت: لبعض حاجته. قال: لا، واللهِ. قالت: فلِمَ غدا؟ قال: ليذبحه. قالت: لم يكن ليذبح ابنه. قال: بلى، والله. قالت سارة: فلِمَ يذبحه؟ قال: زعم أنّ ربَّه أمره بذلك. قالت: قد أحسن أن يطيع ربَّه إن كان أمره بذلك. فخرج الشيطانُ، فأدرك إسحاقَ وهو يمشي على إثر أبيه، قال: أين أصبح أبوك غاديًا؟ قال: لبعض حاجته. قال: لا، واللهِ، بل غدا بِك ليذبحك. قال: ما كان أبي ليذبحني. قال: بلى. قال: لِمَ؟ قال: زعم أنّ الله أمره بذلك. قال إسحاق: فواللهِ، لَئِن أمره ليطيعنه. فتركه الشيطانُ وأسرع إلى إبراهيم، فقال: أين أصبحتَ غاديًا بابنك؟ قال: لبعض حاجتي. قال: لا، واللهِ، ما غدوتَ به إلا لتذبحه. قال: ولِمَ أذبحه؟ قال: زعمت أنّ الله أمرك بذلك. فقال: واللهِ، لئن كان الله أمرني لأفعلن. قال: فتركه، ويَئِس أن يُطاع، فلما أخذ إبراهيمُ إسحاقَ ليذبحه، وسَلَّم إسحاق، عافاه الله، وفداه بذبح عظيم، فقال: قُم، أيْ بُنَيّ، فإنّ الله قد عافاك. فأوحى الله إلى إسحاق: إني قد أعطيتك دعوةً أستجيب لك فيها. قال: فإني أدعوك أن تستجيب لي أيَّما عبد لقيك مِن الأولين والآخرين لا يشرك بك شيئًا فأدْخِلْه الجنة{22}. (١٢/٤٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٧٥<span class="dash">-</span></span> عن نوح بن حبيب، قال: سمعتُ الشافعيَّ يقول كلامًا ما سمعتُ قطَّ أحسن منه؛ سمعته يقول: قال إبراهيمُ خليلُ اللهِ لولده في وقت ما قصَّ عليه ما رأى: <span class="qpc-hafs">﴿ماذا تَرى﴾</span> أي: ماذا تشير به؟ ليستخرج بهذه اللفظة منه ذِكر التفويض والصبر والتسليم والانقياد لأمر الله، لا لمؤامرته لدفْع أمر الله تعالى، فقال: <span class="qpc-hafs">﴿يا أبَتِ افْعَلْ ما تُؤْمَرُ سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</span>. قال الشافعي: والتفويض هو الصبر، والتسليم هو الصبر، والانقياد هو ملاك الصبر، فجمع له الذبيحُ جميعَ ما ابتغاه بهذه اللفظة اليسيرة{23}. (١٢/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٦٧٦<span class="dash">-</span></span> عن أبي منيب الأحدب، قال: خطب <span class="name-1">معاذ</span> بالشام، فذكر الطاعونَ، فقال: إنها رحمة ربكم، ودعوة نبيكم، وقبْض الصالحين قبلكم، اللهم، أدخِل على آلِ مُعاذٍ نصيبَهم مِن هذه الرحمة. ثم نزل من مقامه ذلك، فدخل على عبد الرحمن بن معاذ، فقال عبد الرحمن: <span class="qpc-hafs">﴿الحَقُّ مِن رَبِّكَ فَلا تَكُونَنَّ مِنَ المُمْتَرِينَ﴾</span> [البقرة:١٤٧]. فقال معاذ: <span class="qpc-hafs">﴿سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</span>{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰۤأَبَتِ ٱفۡعَلۡ مَا تُؤۡمَرُۖ سَتَجِدُنِیۤ إِن شَاۤءَ ٱللَّهُ مِنَ ٱلصَّـٰبِرِینَ ۝١٠٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٦٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدَّ عليه إسحاق: <span class="qpc-hafs">﴿قالَ يا أبَتِ افْعَلْ ما تُؤْمَرُ﴾</span>، وأَطِع ربَّك، فمِن ثمَّ لم يقل إسحاقُ لإبراهيم ﵉: افعل ما رأيت. ورأى إبراهيمُ ذلك ثلاثَ ليالٍ متتابعات، وكان إسحاقُ قد صام وصلى قبل الذبح، <span class="qpc-hafs">﴿سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</span> على الذبح{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٧٩، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه الحاكم ٢/٤٣٠-٤٣١. وعزاه السيوطي إلى ابن المنذر.|3:تفسير الثعلبي ٨/١٥٦، وتفسير البغوي ٧/٤٦.|4:تفسير مجاهد (٥٦٩) بنحوه، وأخرجه ابن جرير ١٩/٥٧٩، ومن طريق الحكم أيضًا. وعلَّقه يحيى بن سلام ٢/٨٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي لفظ عند ابن جرير: لما شب حين أدرك سعيه.|5:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:علقه يحيى بن سلام ٢/٨٣٨. وفي تفسير الثعلبي ٨/١٥٦ بلفظ: يعني: العمل الذي يقوم به الحجة. وفي تفسير البغوي ٧/٤٦: يعني: العمل لله تعالى.|8:أخرجه ابن جرير ١٩/٥٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|9:علقه يحيى بن سلام ٢/٨٣٨.|10:أخرجه البيهقي في شعب الإيمان ٦/٢٢٤-٢٢٥ (٢٧٠٥).|11:تفسير مقاتل بن سليمان ٣/٦١٥.|12:تفسير الثعلبي ٨/١٥٦. وفي تفسير البغوي ٧/٤٦: العمل لله تعالى.|13:أخرجه ابن جرير ١٩/٥٧٩. وهو في تفسير الثعلبي ١٨/١٥٦.|14:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.</p><p>وهي قراءة شاذة.|15:أخرجه البخاري (١٣٨، ٨٥٩)، وابن جرير ١٩/٥٨٢، والبيهقي في الأسماء والصفات (٤٢٠)، والحميدي في مسنده (ت: حسين الداراني) ١/٤٢٩ (٤٨٠). وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، والطبراني.|16:تفسير الثعلبي ٨/١٥٦.|17:أخرجه ابن جرير ١٩/٥٨٢. وعزاه السيوطي إلى عبد بن حميد.|18:عزاه السيوطي إلى عبد بن حميد.|19:تفسير مقاتل بن سليمان ٣/٦١٥.|20:أخرجه ابن أبي حاتم ٤/١١١٧.|21:أخرجه الحاكم ٢/٤٦٨، وابن جرير ١٣/٩، وابن أبي حاتم ٧/٢١٠١، من طريق سفيان، عن سماك بن حرب، عن سعيد بن جبير، عن ابن عباس به، بلفظ: «كانت رؤيا الأنبياء وحيًا».</p><p>قال الحاكم: «حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الألباني في ظلال الجنة (٤٦٣): «إسناده حسن، رجاله كلهم ثقات، رجال مسلم، وفي سماك كلام يسير ...».|22:أخرجه عبد الرزاق ٢/١٥٠-١٥١، وابن جرير ١٩/٥٩٠-٥٩١، وفي تاريخه ١/٢٦٥-٢٦٦، وابن أبي حاتم -كما في الفتح ١٢/٣٧٨-، والحاكم ٢/٥٥٧-٥٥٨، والبيهقي في شعب الإيمان (٧٣٢٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|23:أخرجه ابن عساكر ٢٤/٤٥٤.|24:أخرجه أحمد في مسنده ٣٦/٤٠٤ (٢٢٠٨٥).|25:تفسير مقاتل بن سليمان ٣/٦١٥.