tafsir[26]{c,v,t}:
37,77," <q>﴿وَجَعَلۡنَا ذُرِّیَّتَهُۥ هُمُ ٱلۡبَاقِینَ ۝٧٧﴾</q> - تفسير ٦٥٥٢٠- عن أبي هريرة، عن النبي ﷺ، في قوله: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</q>، قال: «ولد نوح ثلاثة: فسامٌ أبو العرب، وحامٌ أبو الحبش، ويافِث أبو الروم»{1}. (١٢/٤٢٢) ٦٥٥٢١- عن سمرة بن جندب، عن النبي ﷺ، في قوله: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</q>، قال: «حام، وسام، ويافِث»{2}. (١٢/٤٢١) ٦٥٥٢٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</q>، يقول: لم يبق إلا ذرية نوح{3}. (١٢/٤٢١) ٦٥٥٢٣- عن عبد الله بن عباس -من طريق جويبر ومقاتل، عن الضحاك بن مزاحم- قال: لَمّا خرج نوحٌ ﵇ مِن السفينة مات مَن معه مِن الرجال والنساء إلَّا ولده ونساءهم، فذلك قوله: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</q>{4}. (ز) ٦٥٥٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</q>، قال: فالناسُ كلهم مِن ذرية نوح{5}. (١٢/٤٢٠) ٦٥٥٢٥- قال مقاتل بن سليمان: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ﴾</q> ولد نوح <q>﴿هُمُ الباقِينَ﴾</q> وذلك أنّ أهل السفينة ماتوا ولم يكن لهم نسلٌ غير ولد نوح، وكان الناس مِن ولد نوح، فلذلك قال: <q>﴿هُمُ الباقِينَ﴾</q>. فقال النبي ﷺ: «سام أبو العرب، ويافث أبو الروم، وحام أبو الحبش»{6}. (ز) ٦٥٥٢٦- عن الحارث بن عمير البصري -من طريق سفيان بن عيينة- في قوله: <q>﴿وجعلنا ذريته هم الباقين﴾</q>، قال: ولد نوح وبنوه الثلاثة{7}. (ز) ٦٥٥٢٧- قال يحيى بن سلّام: <q>﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</q> فالناس كلهم ولد سام، وحام، ويافث{8}٥٤٩٣. (ز) ٥٤٩٣ أفادت الآثار أن أهل الأرض كلهم من ذرية نوح، وهو ما ذكره ابنُ عطية (٧/٢٩٣-٢٩٤)، ثم نقل أنّ فرقة قالت: إن الله تعالى أبقى ذرية نوح، ومد نسله، وبارك فيه، وليس الأمرُ أنّ أهل الأرض انحصروا إلى نسله، بل في الأمم من لا يرجع إليه. ثم قال: «والأول أشهر عند علماء الأمة، وقالوا: نُوحٌ هو آدم الأصغر». <q>﴿وَجَعَلۡنَا ذُرِّیَّتَهُۥ هُمُ ٱلۡبَاقِینَ ۝٧٧﴾</q> - آثار متعلقة بالآية ٦٥٥٢٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «ولد نوح ثلاثة: سام، وحام، ويافث. فولد سام العربَ وفارسَ والرومَ، والخير فيهم، وولد يافث يأجوجَ ومأجوجَ والتركَ والصقالبةَ، ولا خير فيهم، وولد حام القبطَ والبربرَ والسودان»{9}. (١٢/٤٢١) ٦٥٥٢٩- عن سمرة بن جندب، أن النبي ﷺ قال: «سام أبو العرب، وحام أبو الحبش، ويافث أبو الروم»{10}. (١٢/٤٢١) ٦٥٥٣٠- عن سعيد بن المسيب -من طريق يحيى بن سعيد- قال: كان ولد نوح ثلاثة: سام، وحام، ويافث. فسام أبو العرب وفارس والروم، وحام أبو السودان مِن المشرق إلى المغرب، ويافث أبو الترك ويأجوج ومأجوج وما هنالك{11}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه الترمذي ٥/٤٤٠ (٣٥١٠)، وابن جرير ١٩/٥٦٠، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٢-، والثعلبي ٨/١٤٧، وأخرجه الحاكم ٢/٥٩٥ (٤٠٠٦) دون ذكر الآية. قال الترمذي: «حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الشوكاني في فتح القدير ٤/٤٦٦: «من سماع الحسن عن سمرة، وفي سماعه منه مقال معروف، وقد قيل: إنه لم يسمع منه إلا حديث العقيقة فقط، وما عداه فبواسطة».أخرجه ابن جرير ١٩/٥٦١. وعزاه السيوطي إلى ابن المنذر.أخرجه الثعلبي ٨/١٤٧. وينظر: تفسير البغوي ٧/٤٤.أخرجه ابن جرير ١٩/٥٦٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.أخرجه إسحاق البستي ص٢٠٦.تفسير يحيى بن سلام ٢/٨٣٥.أخرجه الخطيب في تالي تلخيص المتشابه ١/١١٤، وابن عساكر في تاريخ دمشق ٦٢/٢٧٨، من طريق محمد بن يزيد بن سنان الرهاوي، حدثنا أبي، عن يحيى بن سعيد الأنصاري، عن سعيد بن المسيب، عن أبي هريرة به. وعزاه السيوطي إلى ابن أبي حاتم. إسناده ضعيف جدًّا؛ فيه محمد بن يزيد بن سنان الرهاوي، قال عنه ابن حجر في التقريب (٦٣٩٩): «ليس بالقوي». وفيه أبوه يزيد بن سنان بن يزيد أبو فروة، قال عنه ابن حجر في التقريب (٧٧٢٧): «ضعيف». قال البزار: «لا نعلم أسنده عن النبي ﷺ إلا أبو هريرة بهذا الإسناد، تفرَّد به يزيد بن سنان، وتفرَّد به ابنه عنه، ورواه غيره مرسلًا، وإنما جعله من قول سعيد». وقال ابن حبان في المجروحين ٣/١٠٦ في ترجمة يزيد بن سنان: «كان ممَّن يخطىء كثيرًا، حتى يروي عن الثقات ما لا يشبه حديث الأثبات، لا يعجبني الاحتجاج بخبره إذا وافق الثقات، فكيف إذا انفرد بالمعضلات». ثم ذكر له هذا الحديث من جملة مروياته.أخرجه أحمد ٣٣/٢٩٢-٢٩٣ (٢٠٠٩٩، ٢٠١٠٠)، ٣٣/٣٠٣ (٢٠١١٤)، والترمذي ٥/٤٤٠-٤٤١ (٣٥١١)، ٦/٤٢٣-٤٢٤ (٤٢٧٣)، والحاكم ٢/٥٩٥ (٤٠٠٦) بنحوه، وابن أبي حاتم ٦/٢٠٣١ (١٠٨٧٦). قال الترمذي في الموضع الثاني: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ١/١٩٣ (٩٣٣): «رواه الطبراني في الكبير، ورجاله موثقون». وقال المناوي في التيسير ٢/٥١: «بإسناد حسن». وقال الألباني في الضعيفة ٨/١٥٩ (٣٦٨٣): «ضعيف».أخرجه الثعلبي ٨/١٤٧، وابن عساكر بنحوه في تاريخ دمشق ٦٢/٢٧٨. وينظر: تفسير البغوي ٧/٤٤.
37,78," <q>﴿وَتَرَكۡنَا عَلَیۡهِ فِی ٱلۡـَٔاخِرِینَ ۝٧٨﴾</q> - تفسير ٦٥٥٣١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</q>، يقول: يُذكَر بخير{1}. (١٢/٤٢١) ٦٥٥٣٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: جعلنا لسان صدقٍ للأنبياء كلهم{2}. (١٢/٤٢٢) ٦٥٥٣٣- عن مجاهد بن جبر -من طريق الثوري- في قول الله: <q>﴿وآتَيْناهُ أجْرَهُ فِي الدُّنْيا﴾</q> [العنكبوت:٢٧]، قال: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: الثناء الصالح{3}. (ز) ٦٥٥٣٤- عن الضحاك بن مُزاحِم، في قوله: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: السلام، والثناء الحسن{4}. (١٢/٤٢٢) ٦٥٥٣٥- عن عكرمة مولى ابن عباس، <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: هو السلام، كما قال: <q>﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</q> [الصافات:٧٩]{5}. (١٢/٤٢٢) ٦٥٥٣٦- عن الحسن البصري، <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: الثناء الحسن{6}. (١٢/٤٢٢) ٦٥٥٣٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: أبقى اللهُ عليه الثناءَ الحسنَ في الآخرين{7}. (١٢/٤٢٠) ٦٥٥٣٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِين﴾</q>، قال: الثناء الحَسَن{8}. (ز) ٦٥٥٣٩- قال مقاتل بن سليمان: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</q> يقول: ألقينا على نوحٍ بعد موته ثناء حسنًا، يُقال له مِن بعده في الآخرين خيرٌ، فذلك قوله ﷿: <q>﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</q>{9}. (ز) ٦٥٥٤٠- قال يحيى بن سلّام: <q>﴿وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</q> ألقينا عليه في الآخرين الثناءَ الحسن{10}٥٤٩٤. (ز) ٥٤٩٤ علَّق ابنُ عطية (٧/٢٩٤) على هذا القول بقوله: «وقوله: <q>﴿سَلامٌ﴾</q> على هذا التأويل: رفع بالابتداء مستأنف، سلَّم الله به عليه ليقتدي بذلك البشر». ",footnotes:1:أخرجه ابن جرير ١٩/٥٦١. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٦٩)، وأخرجه ابن جرير ١٩/٥٦١. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٩ (٢٠٢).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٩/٥٦٢، وعبد الرزاق ٢/١٥٠ بنحوه من طريق معمر، وابن أبي الدنيا في كتاب مكارم الأخلاق بنحوه من طريق شَيْبان -موسوعة الإمام ابن أبي الدنيا ٣/٤٣٢ (١٧)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٦٢.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٥.
37,79," <q>﴿سَلَـٰمٌ عَلَىٰ نُوحࣲ فِی ٱلۡعَـٰلَمِینَ ۝٧٩ إِنَّا كَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡمُحۡسِنِینَ ۝٨٠ إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِینَ ۝٨١﴾</q> - تفسير ٦٥٥٤١- عن إسماعيل السُّدِّيّ: <q>﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</q>، يعني: ما كان بعد نوح؛ الثناء الحسن يُقال لنوح مِن بعده في الناس{1}. (ز) ٦٥٥٤٢- قال مقاتل بن سليمان: <q>﴿سَلامٌ عَلى نُوحٍ فِي العالَمِينَ﴾</q> يعني بالسلام: الثناء الحسن الذي ترك عليه مِن بعده في الناس، <q>﴿إنّا كَذلِكَ نَجْزِي المُحْسِنِينَ﴾</q> هكذا نجزي كل محسن؛ فجزاه الله ﷿ بإحسانه الثناء الحسن في العالمين، <q>﴿إنَّهُ مِن عِبادِنا المُؤْمِنِينَ﴾</q> يعني: المصدِّقين بالتوحيد{2}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٨٣٤.تفسير مقاتل بن سليمان ٣/٦١٠-٦١١.
  37,80,""
  37,81,""
37,82," <q>﴿ثُمَّ أَغۡرَقۡنَا ٱلۡـَٔاخَرِینَ ۝٨٢﴾</q> - تفسير ٦٥٥٤٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</q>، قال: أنجاه اللهُ ومَن معه في السفينة، وأغرق بَقِيَّة قومه{1}. (ز) ٦٥٥٤٤- قال مقاتل بن سليمان: <q>﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</q>، يعني: قوم نوح{2}. (ز) ٦٥٥٤٥- قال يحيى بن سلّام: قال: <q>﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</q>، يعني: مَن سِوى الذين كانوا معه في السفينة{3}٥٤٩٥. (ز) ٥٤٩٥ ذكر ابنُ عطية (٧/٢٩٥) أن قوله تعالى: <q>﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</q> يقتضي أنّه أغرق قومَ نوح وأُمَّته ومُكَذِّبيه، وأنه ليس في ذلك نصٌّ على أنّ الغرق عمَّ جميعَ أهل الأرض، ثم قال: «ولكن قد قال به جماعة من العلماء، وأُسندت به أحاديث أنه لم يبق إلا مَن كان معه في السفينة، وعلى هذا يترتب القول بأن الناس اليوم من ذريته، وقالوا: لم يكن الناس حينئذ بهذه الكثرة؛ لأن عهد آدم ﵇ كان قريبًا، وكانت دعوة نوح ﵇ ونبوءته قد بلغت جميعَهم لطول المدة واللّبث فيهم، فكان الجميعُ كفرةً عبَدَة أوثان، لم ينسبهم الحق إلى نفسه، فلذلك أغرق جميعهم». ",footnotes:1:أخرجه ابن جرير ١٩/٥٦٣.تفسير مقاتل بن سليمان ٣/٦١١.تفسير يحيى بن سلام ٢/٨٣٥.
37,83," <q>﴿وَإِنَّ مِن شِیعَتِهِۦ لَإِبۡرَ ٰ⁠هِیمَ ۝٨٣﴾</q> - تفسير ٦٥٥٤٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وإنَّ مِن شِيعَتِهِ﴾</q>، قال: مِن أهل دينه{1}. (١٢/٤٢٣) ٦٥٥٤٧- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</q>، قال: مِن شيعة نوح؛ على مِنهاجه وسُنَّته{2}. (١٢/٤٣١) ٦٥٥٤٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</q>، قال: مِن شيعة نوحٍ إبراهيمُ، على منهاجه وسُنَّته{3}. (١٢/٤٢٣) ٦٥٥٤٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</q>، قال: على دينه{4}. (١٢/٤٢٣) ٦٥٥٥٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</q>، قال: مِن أهل دينه{5}. (ز) ٦٥٥٥١- قال مقاتل بن سليمان: <q>﴿وإنَّ مِن شِيعَتِهِ لَإبْراهِيمَ﴾</q>، يقول: إبراهيم على مِلَّة نوح ﵉{6}٥٤٩٦. (ز) ٥٤٩٦ قال ابنُ عطية (٧/٢٩٥): «قال الطبريُّ وغيرُه عن الفراء: الضمير عائد على محمد ﷺ، والإشارة إليه. وذلك كله محتمل؛ لأن الشيعة معناها: الصنف الشائع الذي يشبه بعضه بعضًا. والشِّيَع: الفرق. وإن كان الأعرف أن المتأخر في الزمن هو شيعة للمتقدم، ولكن قد يجيء من الكلام عكس ذلك». ",footnotes:1:أخرجه ابن جرير ١٩/٥٦٤، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه الحاكم ٢/٤٣٠-٤٣١. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٦٩)، وأخرجه ابن جرير ١٩/٥٦٤ دون لفظ: من شيعة نوحٍ إبراهيمُ، ومن طريق القاسم بن أبي بزة بنحوه. وعلَّقه يحيى بن سلام ٢/٨٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٥٤، وابن جرير من طريق سعيد ١٩/٥٦٤ بلفظ: على دينه وملته. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٦٤. وعلَّقه يحيى بن سلام ٢/٨٣٥ بنحوه.تفسير مقاتل بن سليمان ٣/٦١١.
37,84," <q>﴿إِذۡ جَاۤءَ رَبَّهُۥ بِقَلۡبࣲ سَلِیمٍ ۝٨٤﴾</q> - تفسير ٦٥٥٥٢- عن عروة بن الزبير -من طريق هشام- أنّه قال: يا بَنِيَّ، لا تكونوا لعّانين، ألم تروا إلى إبراهيم لم يلعن شيئًا قطُّ، فقال الله: <q>﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</q>{1}. (ز) ٦٥٥٥٣- عن مجاهد بن جبر -من طريق ليث- <q>﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</q>، قال: ليس فيه شكٌّ{2}. (١٢/٤٢٣) ٦٥٥٥٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</q>: سليم مِن الشرك{3}. (١٢/٤٢٣) ٦٥٥٥٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</q>، قال: سليم من الشرك{1}. (ز) ٦٥٥٥٦- قال مقاتل بن سليمان: <q>﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</q>، يعني: بقلبٍ مُخْلِصٍ مِن الشرك{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٦٥.أخرجه ابن جرير ١٩/٥٦٥ بلفظ: لا شك فيه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ٢/٨٣٥، وعبد الرزاق ٢/١٥٤ من طريق معمر، وابن جرير ١٩/٥٦٥ بلفظ: <q>﴿إذْ جاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</q> واللهِ مِن الشرك. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٦٥.تفسير مقاتل بن سليمان ٣/٦١١.
37,85," <q>﴿إِذۡ قَالَ لِأَبِیهِ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ ۝٨٥﴾</q> - تفسير ٦٥٥٥٧- قال مقاتل بن سليمان: <q>﴿إذْ قالَ لِأَبِيهِ﴾</q> آزر <q>﴿وقومه ماذا تَعْبُدُونَ﴾</q> مِن الأصنام{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦١١.
37,86," <q>﴿أَىِٕفۡكًا ءَالِهَةࣰ دُونَ ٱللَّهِ تُرِیدُونَ ۝٨٦﴾</q> - تفسير ٦٥٥٥٨- عن قتادة بن دعامة، في قوله: <q>﴿أئِفْكًا آلِهَةً﴾</q>، قال: أكَذِبًا آلهة دون الله تريدون{1}. (١٢/٤٢٣) ٦٥٥٥٩- قال مقاتل بن سليمان: <q>﴿أئِفْكًا﴾</q> يعني: أكذبًا <q>﴿آلهة﴾</q>{2}. (ز) ٦٥٥٦٠- قال يحيى بن سلّام: <q>﴿أئِفْكًا﴾</q> أي: كذبًا، <q>﴿أئِفْكًا آلِهَةً دُونَ اللَّهِ تُرِيدُونَ﴾</q> على الاستفهام، أي: قد فعلتم فعبدتموهم دونه{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١١.تفسير يحيى بن سلام ٢/٨٣٥.
37,87," <q>﴿فَمَا ظَنُّكُم بِرَبِّ ٱلۡعَـٰلَمِینَ ۝٨٧﴾</q> - تفسير ٦٥٥٦١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَما ظَنُّكُمْ بِرَبِّ العالَمِينَ﴾</q>: إذا لقيتموه وقد عبدتُم غيرَه{1}. (١٢/٤٢٣) ٦٥٥٦٢- قال مقاتل بن سليمان: <q>﴿فَما ظَنُّكُمْ بِرَبِّ العالَمِينَ﴾</q> إذا لقيتموه وقد عبدتم غيره{2}. (ز) ٦٥٥٦٣- قال يحيى بن سلّام: <q>﴿فَما ظَنُّكُمْ بِرَبِّ العالَمِينَ﴾</q>، أي: أنه معذبكم{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١١.تفسير يحيى بن سلام ٢/٨٣٦.
37,88," <q>﴿فَنَظَرَ نَظۡرَةࣰ فِی ٱلنُّجُومِ ۝٨٨﴾</q> - تفسير ٦٥٥٦٤- قال عبد الله بن عباس: كان قومُه يتعاطَوْن عِلْمَ النجوم، فعاملهم مِن حيث كانوا؛ لِئَلّا يُنكِروا عليه{1}. (ز) ٦٥٥٦٥- عن سعيد بن المسيب -من طريق قتادة- في قوله: <q>﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</q>، قال: رأى نجمًا طالعًا{2}. (١٢/٤٢٤) ٦٥٥٦٦- عن الضحاك بن مُزاحِم، في قوله: <q>﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</q>، قال: في السماء{3}. (١٢/٤٢٤) ٦٥٥٦٧- عن قتادة بن دعامة، قوله: <q>﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</q>، قال: كلمة مِن كلام العرب، يقول إذا تفكر: نظر في النجوم{4}. (١٢/٤٢٤) ٦٥٥٦٨- قال إسماعيل السُّدِّيّ: <q>﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ﴾</q>، يعني: في الكواكب{5}. (ز) ٦٥٥٦٩- قال مقاتل بن سليمان: <q>﴿فَنَظَرَ﴾</q> إبراهيم <q>﴿نَظْرَةً فِي النُّجُومِ﴾</q> يعني: الكواكب، وذلك أنه رأى نجمًا طلع، فقال لقادتهم: إنِّي سقيم. وهم ذاهبون إلى عيدهم{6}. (ز) ",footnotes:1:تفسير البغوي ٧/٤٤ وعقبه: وذلك أنه أراد أن يكايدهم في أصنامهم ليلزمهم الحجة في أنها غير معبودة، وكان لهم من الغد عيد ومجمع، وكانوا يدخلون على أصنامهم ويقربون لهم القرابين، ويصنعون بين أيديهم الطعام قبل خروجهم إلى عيدهم -زعموا- للتبرك عليه، فإذا انصرفوا من عيدهم أكلوه، فقالوا لإبراهيم: ألا تخرج غدًا معنا إلى عيدنا؟ فنظر إلى النجوم فقال: <q>﴿إنِّي سَقِيمٌ﴾</q>.أخرجه عبد الرزاق ٢/١٥٠، وابن جرير ١٩/٥٦٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم. وينظر: تفسير ابن كثير ٧/٢١.علقه يحيى بن سلام ٢/٨٣٦.تفسير مقاتل بن سليمان ٣/٦١١.
37,89," <q>﴿فَقَالَ إِنِّی سَقِیمࣱ ۝٨٩﴾</q> - تفسير ٦٥٥٧٠- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: لَمّا خرج قومُ إبراهيم إلى عيدهم مرُّوا عليه، فقالوا: يا إبراهيم، ألا تخرج معنا؟ قال: <q>﴿إنِّي سَقِيمٌ﴾</q>{1}. (١٠/٣٠٣) ٦٥٥٧١- عن عبد الله بن عباس، في قوله: <q>﴿إنِّي سَقِيمٌ﴾</q>، قال: مريض{2}. (١٢/٤٢٤) ٦٥٥٧٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿إنِّي سَقِيمٌ﴾</q>، يقول: مطعون{3}. (١٢/٤٢٤) ٦٥٥٧٣- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿إنِّي سَقِيمٌ﴾</q>، قال: قالوا له وهو في بيت آلهتهم: اخرج. فقال: إني مطعون. فتركوه مخافة الطاعون{4}. (ز) ٦٥٥٧٤- عن سعيد بن المسيب -من طريق قتادة- في قوله: <q>﴿فَقالَ إنِّي سَقِيمٌ﴾</q>، قال: كايَدَ{5} نبيُّ الله عن دينه{6}. (١٢/٤٢٤) ٦٥٥٧٥- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿فَقالَ إنِّي سَقِيمٌ﴾</q>، قال: قالوا لإبراهيم وهو في بيت آلهتهم: اخرج معنا. فقال لهم: إني مطعون. فتركوه مخافة أن يُعديهم{7}. (١٢/٤٢٤) ٦٥٥٧٦- قال الحسن البصري: <q>﴿فَقالَ إنِّي سَقِيمٌ﴾</q> مريض{8}. (ز) ٦٥٥٧٧- عن الحسن البصري، قال: خرج قومُ إبراهيم إلى عيدٍ لهم، وأرادوا إبراهيمَ على الخروج، فاضطجع على ظهره، وقال: إنِّي سقيم، لا أستطيع الخروج. وجعل ينظر إلى السماء، فلما خرجوا أقبل على آلهتهم، فكسَّرها{9}. (١٢/٤٢٥) ٦٥٥٧٨- عن زيد بن أسلم -من طريق ابنه عبد الرحمن- في قول الله: <q>﴿إنِّي سَقِيمٌ﴾</q>، قال: أرسل إليه ملكُهم، فقال: إنّ غدًا عيدنا، فاحضر معنا. قال: فنظر إلى نجم، فقال: إنّ ذلك النجم لم يطلع قط إلا طلع بسقم لي، فقال: <q>﴿إنِّي سَقِيمٌ﴾</q>{10}. (١٢/٤٢٥) ٦٥٥٧٩- قال محمد بن السائب الكلبي: <q>﴿فَقالَ إنِّي سَقِيمٌ﴾</q> أنّهم كانوا بقرية بين البصرة والكوفة يُقال لها: هُرْمُزْخُرد{11}، وكانوا ينظرون في النجوم، قال: <q>﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ * فَقالَ إنِّي سَقِيمٌ﴾</q>. قال: أي: مطعون{12}. (ز) ٦٥٥٨٠- قال مقاتل بن سليمان: <q>﴿إنِّي سَقِيمٌ﴾</q>، يعني: وجيع. وذلك أنهم كانوا يعبدون الأصنام، كانت اثنين وسبعين صنمًا، مِن ذهب وفضة وشَبَهٍ{13} ونحاس وحديد وخشب، وكان أكبر الأصنام عيناه مِن ياقوتتين حمراوين، وهو مِن ذهب، وكانوا إذا خرجوا إلى عيدهم دخلوا قبل أن يخرجوا، فيسجدون لها، ويقربون الطعام، ثم يخرجون إلى عيدهم، فإذا رجعوا من عيدهم دخلوا عليها، فسجدوا لها، ثم يتفرقون، فلما خرجوا إلى عيدهم اعتلَّ إبراهيمُ بالطاعون، وذلك أنهم كانوا ينظرون في النجوم، فنظر إبراهيم في النجوم، فقال: <q>﴿إنِّي سَقِيمٌ﴾</q>{14}. (ز) ٦٥٥٨١- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿إنِّي سَقِيمٌ﴾</q>، قال: طعين، وكانوا يفرّون مِن المطعون، فأراد أن يخلو بآلهتهم{15}. (١٢/٤٢٤) <q>﴿فَقَالَ إِنِّی سَقِیمࣱ ۝٨٩﴾</q> - آثار متعلقة بالآية ٦٥٥٨٢- عن أبي هريرة، أنّ رسول الله ﷺ قال: «لم يكذب إبراهيم النبي ﵇ قط إلا ثلاث كذبات، ثِنْتين في ذات الله؛ قوله: <q>﴿إنِّي سَقِيمٌ﴾</q> [الصافات:٨٩]، وقوله: <q>﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</q> [الأنبياء:٦٣]، وواحدة في شأن سارة، فإنّه قدم أرض جبار ومعه سارة، وكانت أحسن الناس، فقال لها: إنّ هذا الجبار إن يعلم أنك امرأتي يغلبني عليك، فإن سألكِ فأخبريه أنك أختي، فإنّكِ أختي في الإسلام، فإني لا أعلم في الأرض مسلمًا غيري وغيرك. فلما دخل أرضَه رآها بعضُ أهل الجبار، أتاه فقال له: لقد قدم أرضُك امرأةً لا ينبغي لها أن تكون إلا لك. فأرسل إليها، فأُتي بها، فقام إبراهيم ﵇ إلى الصلاة، فلمّا دخلتْ عليه لم يتمالك أن بسط يدَه إليها، فقُبضت يده قبضة شديدة، فقال لها: ادعي الله أن يطلق يدي ولا أضُرَّكِ. ففعلت، فعاد، فقُبضتْ أشد من القبضة الأولى، فقال لها مثل ذلك، ففعلت، فعاد، فقُبضتْ أشد من القبضتين الأوليين، فقال: ادعي الله أن يطلق يدي، فلكِ الله أن لا أضركِ. ففعلتْ، وأُطلقت يده، ودعا الذي جاء بها، فقال له: إنّك إنّما أتيتني بشيطان، ولم تأتني بإنسان، فأخرِجها من أرضي، وأعطِها هاجر. قال: فأقبلت تمشي، فلمّا رآها إبراهيم ﵇ انصرف، فقال لها: مهيم؟ قالت: خيرًا، كفَّ اللهُ يدَ الفاجر، وأخْدَمَ خادمًا». قال أبو هريرة: فتلك أمُّكُم، يا بني ماء السماء{16}. (ز) ٦٥٥٨٣- عن أبي سعيد، عن النبي ﷺ، قال: «قول إبراهيم: <q>﴿والذي أطمع أن يغفر لي خطيئتي يوم الدين﴾</q> [الشعراء:٨٢] في كذباته الثلاث: <q>﴿إني سقيم﴾</q>، وقوله: <q>﴿بل فعله كبيرهم هذا﴾</q> [الأنبياء:٦٣]، وقوله: إن سارة أختي، ما منها كلمة إلا ماحَلَ{17} بها عن دِين الله»{18}. (ز) ٦٥٥٨٤- عن أبي هريرة -من طريق المسيب بن رافع- قال: ما كذب إبراهيمُ غيرَ ثلاث كذبات: قوله: <q>﴿إنِّي سَقِيمٌ﴾</q>، وقوله: <q>﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</q> [الأنبياء:٦٣] وإنما قاله موعظة، وقوله حين سأله الملك، فقال: أختي. لسارة، وكانت امرأته{19}. (ز) ٦٥٥٨٥- عن محمد [بن سيرين] -من طريق أيوب- قال: إنّ إبراهيم ما كذب إلا ثلاث كذبات، ثنتان في الله، وواحدة في ذات نفسه؛ فأما الثنتان فقوله: <q>﴿إنِّي سَقِيمٌ﴾</q>، وقوله: <q>﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</q>، وقصته في سارة. وذكر قصتها وقصة الملك{3}٥٤٩٧. (ز) ٥٤٩٧ اختُلِف في قوله: <q>﴿إني سقيم﴾</q> على قولين: الأول: أنها كذبة في ذات الله. وعلى هذا التأويل يأتي حديث النبي ﷺ: «ما كذب إبراهيم غير ثلاث كذبات». والثاني: أنها مِن المعاريض، ولا يجوز الكذب عليه. وعلى هذا قيل: أراد إني سقيم النفس، أي: من أموركم وكفركم، فظهر لهم من كلامه أنه أراد سقمًا بالجسد حاضرًا، وهكذا هي المعاريض. واختار ابنُ جرير (١٩/٥٦٩) القولَ الأول، واسْتَدْرَكَ على الثاني بقوله: «الخبر عن رسول الله ﷺ بخلاف هذا القول، وقول رسول الله ﷺ هو الحق دون غيره». واختار ابنُ تيمية (٥/٣٤٨) الثاني، حيث علَّقَ على مقالات إبراهيم ﵇ الثلاث الواردة في الحديث بقوله: «وهذه الثلاثة معاريض». والظاهر مِن كلام ابن عطية (٧/٢٩٧) أنه يميل إلى الثاني، حيث قال مُعَلِّقًا مستندًا إلى الدلالة العقلية: «وهذا التأويل لا يرده الحديث وذكر الكذبات؛ لأنه قد يقال لها: كذب. على الاتساع بحسب اعتقاد المخبر، والكذب الذي هو قصد قول الباطل، والإخبار بضد ما في النفس بغير منفعة شرعية، هو الذي لا يجوز على الأنبياء». وبنحوه قال ابنُ كثير (١٢/٣٣-٣٤)، ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق مطولًا ٦/١٨١-١٨٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥٦٩.أخرجه ابن جرير ١٩/٥٦٦.من الكيد: الحيلة. التاج (كيد).أخرجه عبد الرزاق ٢/١٥٣، وابن جرير ١٩/٥٦٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٦٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر مختصرًا.تفسير الثعلبي ١٨/١٤٨، وتفسير البغوي ٧/٤٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٦٧. وعزاه السيوطي إلى ابن أبي حاتم.كذا في المطبوع، وقال في معجم البلدان: هُرْمُزْجرد: ناحية كانت بأطراف العراق غزاها المسلمون أيام الفتوح. ٥/٤٠٢.علقه يحيى بن سلام ٢/٨٣٦.الشِّبْه والشَّبَه: النحاس يُصْبَغ بدواء فيَصْفَرّ، وسُمّي كذلك لأنه إذا فُعل ذلك به أشبَه الذهبَ بلونه. اللسان (شبه).تفسير مقاتل بن سليمان ٣/٦١٢.أخرجه إسحاق البستي ص٢٠٧. وعزاه السيوطي إلى ابن أبي حاتم دون آخره.أخرجه البخاري ٤/١٤٠-١٤١ (٣٣٥٨)، ٧/٦ (٥٠٨٤)، ومسلم ٤/١٨٤٠ (٢٣٧١) واللفظ له، وابن جرير ١٩/٥٦٨-٥٦٩ بنحوه مختصرًا.ماحل: دافع وجادل. النهاية (محل).أخرجه أبو يعلى ٢/٣١٠ (١٠٤٠)، وابن عساكر في تاريخه ٦/١٧٩، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٥- بنحوه، من طريق سفيان بن عيينة، عن ابن جدعان، عن أبي نضرة، عن أبي سعيد به. إسناده ضعيف؛ فيه علي بن زيد بن جدعان، قال عنه ابن حجر في التقريب (٤٧٣٤): «ضعيف».أخرجه ابن جرير ١٩/٥٦٨-٥٦٩.أخرجه ابن جرير ١٩/٥٦٩.
37,90," <q>﴿فَتَوَلَّوۡا۟ عَنۡهُ مُدۡبِرِینَ ۝٩٠﴾</q> - تفسير ٦٥٥٨٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿إنِّي سَقِيمٌ﴾</q> يقول: مطعون، <q>﴿فتولوا عنه مدبرين﴾</q>= (ز) ٦٥٥٨٧- قال سعيد: إن كان الفرار مِن الطاعون لَقديمًا{1}. (ز) ٦٥٥٨٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</q>، قال: فنكصوا عنه منطلقين{2}. (١٢/٤٢٥) ٦٥٥٨٩- قال مقاتل بن سليمان: <q>﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</q> ذاهبين، وقد وضعوا الطعام والشراب بين يدي آلهتهم{3}. (ز) ٦٥٥٩٠- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿فَنَظَرَ نَظْرَةً فِي النُّجُومِ فَقالَ إنِّي سَقِيمٌ﴾</q>، يقول الله: <q>﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</q>{4}. (ز) ٦٥٥٩١- قال يحيى بن سلّام: <q>﴿فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ﴾</q> إلى عيدهم، وذلك أنّهم استتبعوه لعيدهم، فعصَب رأسَه، وقال: إنِّي رأيتُ الليلةَ في النجوم أني سأُطْعَن غدًا. كراهية الذهاب معهم، ولِما أراد أن يفعل بآلهتهم، كادهم بذلك وهي إحدى الخطايا الثلاث؛ قال: <q>﴿والَّذِي أطْمَعُ أنْ يَغْفِرَ لِي خَطِيئَتِي يَوْمَ الدِّينِ﴾</q> [الشعراء:٨٢]، وقوله: <q>﴿إنِّي سَقِيمٌ﴾</q>، وقوله: <q>﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذا﴾</q> [الأنبياء:٦٣]، وقوله لسارة: إن سألوكِ فقولي: إنك أختي{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٦٩.أخرجه ابن جرير ١٩/٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٢.أخرجه ابن جرير ١٩/٥٦٧.تفسير يحيى بن سلام ٢/٨٣٦.
37,91," <q>﴿فَرَاغَ إِلَىٰۤ ءَالِهَتِهِمۡ﴾</q> - تفسير ٦٥٥٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَراغَ إلى آلِهَتِهِمْ﴾</q>، قال: فمال. قال: ذهب{1}. (١٢/٤٢٥) ٦٥٥٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿فَراغَ إلى آلِهَتِهِمْ﴾</q>، قال: ذهب{2}. (ز) ٦٥٥٩٤- قال مقاتل بن سليمان: <q>﴿فَراغَ﴾</q> يعني: فمال ٥٤٩٨ <q>﴿إلى آلِهَتِهِمْ﴾</q> إلى الصنم الكبير وهو في بيت{3}. (ز) ٥٤٩٨ قال ابنُ جرير (١٩/٥٧٠) في بيان معنى <q>﴿فراغَ﴾</q>: "أرى أن أصل ذلك مِن قولهم: راغ فلان عن فلان: إذا حاد عنه، فيكون معناه إذا كان كذلك: فراغ عن قومه والخروج معهم إلى آلهتهم، كما قال عدي بن زيد: حين لا ينفع الرواغ ولا ينـ... فع إلا المصادق النحرير. يعني بقوله: «لا ينفع الرواغ»: الحياد. أما أهل التأويل فإنهم فسروه بمعنى: فمال". ",footnotes:1:أخرجه ابن جرير ١٩/٥٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٧٠.تفسير مقاتل بن سليمان ٣/٦١٢.
37,92," <q>﴿فَقَالَ أَلَا تَأۡكُلُونَ ۝٩١ مَا لَكُمۡ لَا تَنطِقُونَ ۝٩٢﴾</q> - تفسير ٦٥٥٩٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَقالَ ألا تَأْكُلُونَ﴾</q>: يستنطقهم{1}. (١٢/٤٢٥) ٦٥٥٩٦- عن إسماعيل السُّدِّيّ، قال: رجع إبراهيمُ ﵇ إلى آلهتهم، فإذا هي في بَهْوٍ عظيم، مستقبل باب البهو صنمٌ عظيمٌ، إلى جنبه أصغر منه، بعضها إلى جنب بعض، فإذا هم قد جعلوا طعامًا بين يدي الأصنام، وقالوا: إذا رجعنا وجدنا الآلهة برّكت في طعامنا؛ فأكلنا. فلما نظر إليهم إبراهيمُ قال: <q>﴿ألا تَأْكُلُونَ* ما لَكُمْ لا تَنْطِقُونَ﴾</q>. فأخذ حديدةً، فبقر كل صنم في حافتيه، ثم علَّق الفأس في الصنم الأكبر، ثم خرج{2}. (ز) ٦٥٥٩٧- قال مقاتل بن سليمان: <q>﴿فَقالَ﴾</q> للآلهة: <q>﴿ألا تَأْكُلُونَ﴾</q> الطعامَ الذي بين أيديكم، <q>﴿ما لَكُمْ لا تَنْطِقُونَ﴾</q> ما لكم لا تكلمون؟ ما لكم لا ترُدُّون جوابًا؟ أتأكلون، أو لا تأكلون؟{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير وابن أبي حاتم -كما في فتح الباري ٦/٣٩٩-.تفسير مقاتل بن سليمان ٣/٦١٢.
37,93," <q>﴿فَرَاغَ عَلَیۡهِمۡ ضَرۡبَۢا بِٱلۡیَمِینِ ۝٩٣﴾</q> - قراءات ٦٥٥٩٨- في قراءة عبد الله [بن مسعود]: (فَراغَ عَلَيْهِمْ صَفْقًا بِاليَمِينِ){1}. (ز) ٦٥٥٩٩- عن خالد بن عبيد العتكي، قال: سمعت الحسن [البصري] قرأ: (فَراغَ عَلَيْهِمْ صَفْقًا بِاليَمِينِ). أي: ضربًا باليمين{2}. (ز) <q>﴿فَرَاغَ عَلَیۡهِمۡ ضَرۡبَۢا بِٱلۡیَمِینِ ۝٩٣﴾</q> - تفسير الآية ٦٥٦٠٠- عن عبد الله بن عباس -من طريق عطية- قال: <q>﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</q>، لَمّا خلا جعل يضربُ آلهتَهم باليمين{3}. (ز) ٦٥٦٠١- عن الضحاك بن مزاحم -من طريق عبيد-، فذكر مثله{3}. (ز) ٦٥٦٠٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</q>: أي: فأقبل عليهنَّ، فكسرهُنَّ{5}. (١٢/٤٢٥) ٦٥٦٠٣- قال الربيع بن أنس: <q>﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</q>، يعني: يده اليمنى{6}. (ز) ٦٥٦٠٤- قال مقاتل بن سليمان: <q>﴿فَراغَ عَلَيْهِمْ﴾</q> يعني: فأقبل عليها <q>﴿ضَرْبًا بِاليَمِينِ﴾</q> بيده اليمين، يكسرهم بالفأس{7}٥٤٩٩. (ز) ٥٤٩٩ قال ابنُ عطية (٧/٢٩٨): «اخْتُلِف في معنى قوله: <q>﴿باليمين﴾</q>، فقال ابن عباس: أراد: يمنى يديه. وقيل: أراد: بقوته؛ لأنه كان يجمع يديه معًا بالفأس. وقيل: أراد: يمين القسم، في قوله: <q>﴿وتالله لأكيدن أصنامكم﴾</q> [الأنبياء:٥٧]». وبنحوه قال ابنُ جرير (١٩/٥٧١-٥٧٢). ٦٥٦٠٥- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فَراغَ عَلَيْهِمْ ضَرْبًا بِاليَمِينِ﴾</q>: ثم أقبل عليهم -كما قال الله- ضربًا باليمين، ثم جعل يكسرهن بفأسٍ في يده{3}. (ز) ٦٥٦٠٦- قال يحيى بن سلّام: <q>﴿ضَرْبًا بِاليَمِينِ﴾</q> فكسرها إلا كبيرهم{9}. (ز) ",footnotes:1:علقه ابن جرير ١٩/٥٧٢. وهي قراءة شاذة، تروى أيضًا عن الحسن. انظر: المحتسب ٢/٢٢١، ومختصر ابن خالويه ص١٢٩.أخرجه ابن جرير ١٩/٥٧٢.أخرجه ابن جرير ١٩/٥٧١.أخرجه ابن جرير ١٩/٥٧١.أخرجه ابن جرير ١٩/٥٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه يحيى بن سلام في تفسيره ٢/٨٣٦ بلفظ: فمال عليهم؛ على آلهتهم.تفسير الثعلبي ١٨/١٤٨.تفسير مقاتل بن سليمان ٣/٦١٢.أخرجه ابن جرير ١٩/٥٧١.تفسير يحيى بن سلام ٢/٨٣٦.
37,94," <q>﴿فَأَقۡبَلُوۤا۟ إِلَیۡهِ یَزِفُّونَ ۝٩٤﴾</q> - تفسير ٦٥٦٠٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q>، قال: يَجْرون{1}. (١٢/٤٢٦) ٦٥٦٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q>، قال: ينسلون. والوزيف: النسَلان{2}. (١٢/٤٢٦) ٦٥٦٠٩- عن مجاهد بن جبر -من طريق ابن مجاهد- <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q>: الخيلاء{3}. (ز) ٦٥٦١٠- عن الضحاك بن مزاحم، في قوله: <q>﴿يَزِفُّونَ﴾</q>، قال: يَسْعَوْن{4}. (١٢/٤٢٦) ٦٥٦١١- قال الحسن البصري: <q>﴿يَزِفُّونَ﴾</q> يبتدرونه{5}. (ز) ٦٥٦١٢- قال الحسن البصري: <q>﴿يَزِفُّونَ﴾</q>، أي: يزفون زفيف النعام{6}. (ز) ٦٥٦١٣- عن قتادة بن دعامة، في قوله: <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q>، قال: يَسْعَوْن{7}. (١٢/٤٢٥) ٦٥٦١٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q>، قال: يمشون{8}. (ز) ٦٥٦١٥- عن زيد بن أسلم -من طريق ابنه عبد الرحمن- <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q>، قال: يستعجلون. قال: يزف: يستعجل{8}. (ز) ٦٥٦١٦- عن محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿يَزِفُّونَ﴾</q>، قال: يزفون على أقدامهم{10}. (ز) ٦٥٦١٧- قال مقاتل بن سليمان: فلمّا رجعوا من عيدهم <q>﴿فَأَقْبَلُوا إلَيْهِ يَزِفُّونَ﴾</q> يمشون إلى إبراهيم يأخذونه بأيديهم{11}. (ز) ٦٥٦١٨- قال يحيى بن سلّام: <q>﴿فَأَقْبَلُوا إلَيْهِ﴾</q> إلى إبراهيم <q>﴿يَزِفُّونَ﴾</q> ... قال بعضهم: <q>﴿يَزِفُّونَ﴾</q> يرعدون غضبًا{12}٥٥٠٠. (ز) ٥٥٠٠ ذكر ابنُ عطية (٧/٢٩٩) أن فرقة ذهبت إلى أن <q>﴿يَزِفُّونَ﴾</q> معناه: يتمهلون في مشيهم كزفاف العروس. وعلَّق عليه بقوله: «والمعنى: أنهم كانوا على طمأنينة مِن أن ينال أحدٌ آلهتَهم بسوء؛ لعزتهم، فكانوا لذلك متمهلين». ثم قال: «وزفّ بمعنى: أسرع. هو المعروف». ",footnotes:1:أخرجه ابن جرير ١٩/٥٧٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد (٥٦٩)، وأخرجه عبد بن حميد -كما في تغليق التغليق ٤/٢٩٤، وفتح الباري ٨/٥٤٣-، وابن جرير ١٩/٥٧٣. وعزاه السيوطي إلى ابن المنذر. والنَسَلان: الإسراع. اللسان (نسل).أخرجه يحيى بن سلام ٢/٨٣٦.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.علقه يحيى بن سلام ٢/٨٣٦.تفسير الثعلبي ١٨/١٤٩، وقال عقبه: وهو حال بين المشي والطيران.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٧٤.أخرجه ابن جرير ١٩/٥٧٤.أخرجه عبد الرزاق ٢/١٥٠.تفسير مقاتل بن سليمان ٣/٦١٢.تفسير يحيى بن سلام ٢/٨٣٦.
37,95," <q>﴿قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ ۝٩٥﴾</q> - تفسير ٦٥٦١٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قالَ أتَعْبُدُونَ ما تَنْحِتُونَ﴾</q>: مِن الأصنام{1}. (١٢/٤٢٥) ٦٥٦٢٠- قال مقاتل بن سليمان: فقال لهم إبراهيم: <q>﴿أتَعْبُدُونَ ما تَنْحِتُونَ﴾</q> مِن الأصنام{2}. (ز) ٦٥٦٢١- قال يحيى بن سلّام: <q>﴿قالَ﴾</q> لهم إبراهيم: <q>﴿أتَعْبُدُونَ ما تَنْحِتُونَ﴾</q> يعني: أصنامهم{3}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/٤٦٩، وابن جرير ١٩/٥٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٢.تفسير يحيى بن سلام ٢/٨٣٦.
37,96," <q>﴿وَٱللَّهُ خَلَقَكُمۡ وَمَا تَعۡمَلُونَ ۝٩٦﴾</q> - تفسير ٦٥٦٢٢- عن حذيفة، قال: قال النبيُّ ﷺ: «إنّ اللهَ صانعُ كلِّ صانعٍ وصنْعَتِه». وتلا بعضُهم عند ذلك: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q>{1}. (١٢/٤٢٦) ٦٥٦٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q>، قال: خلقكم وخلق ما تعملون بأيديكم{2}. (١٢/٤٢٥) ٦٥٦٢٤- قال مقاتل بن سليمان: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q> وما تنحتون مِن الأصنام{3}٥٥٠١. (ز) ٥٥٠١ اختُلِف في تأويل قوله تعالى: <q>﴿وما تعملون﴾</q> على قولين: الأول: أنّ «ما» مصدرية، والمعنى: والله خلقكم وعملَكم. والثاني: أنّ «ما» موصولة، والمعنى: والله خلقكم والذي تعملونه. وزاد ابنُ عطية (٧/٢٩٩) قولين آخرين، وهما: الثالث: أنّ «ما» نافية، والمعنى: والله خلقكم وأنتم لا تعملون شيئًا في وقت خلقكم ولا قبله، ولا تقدرون على شيء. والرابع: أنّ «ما» استفهاميّة. وعلَّقَ ابنُ عطية (٧/٢٩٩) على القول الأول -وهو قول جماعة من المفسرين-، فقال: «هذه الآية عندهم قاعدة في خلق أفعال العباد، وذلك موافق لمذهب أهل السنة في ذلك». وعلَّقَ ابنُ جرير (١٩/٥٧٥) على القول الثاني بقوله: «معنى الكلام عند ذلك: واللهُ خلقكم والذي تعملونه، أي: والذي تعملون منه الأصنام، وهو الخشب، والنحاس، والأشياء التي كانوا ينحتون منها أصنامهم، وهذا المعنى الثاني قصد -إن شاء الله- قتادة بقوله: ... بأيديكم». وبيَّن ابنُ كثير (١٢/٣٦ بتصرف) أنّ القولين الأول والثاني متلازمان، ولكنه مال إلى الأول، فقال: «كلا القولين متلازم، والأول أظهر؛ لما رواه البخاري في كتاب أفعال العباد ... عن حذيفة مرفوعًا، قال: «إن الله تعالى يصنع كل صانع وصنعته»». ورجَّحَ ابنُ القيم (٢/٣٧٠-٣٧٣) القولَ الثانيَ استنادًا إلى السياق، ونظائرها في القرآن، والدلالة العقلية، وانتَقَدَ القولَ الأولَ، قال ابنُ القيم: «ظن كثير من الناس أن قوله تعالى: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q> أنها مصدرية، واحتجوا بها على خلق الأعمال، وليست مصدرية، وإنما هي موصولة، والمعنى: والله خلقكم وخلق الذي تعملونه وتنحتونه من الأصنام، فكيف تعبدونه وهو مخلوق لله، ولو كانت مصدرية لكان الكلام إلى أن يكون حجة لهم أقرب من أن يكون حجة عليهم؛ إذ يكون المعنى: أتعبدون ما تنحتون والله خلق عبادتكم لها؟ فأي معنى في هذا، وأي حجة عليهم؟ والمقصود أنه كثيرًا ما تدخل إحداهما على الأخرى ويحتملها الكلام سواء. والصواب أنها موصولة، وأنها لا تدل على صحة مذهب القدرية بل هي حجة عليهم مع كونها موصولة ... فالله سبحانه أنكر عليهم عبادتهم الأصنام، وبين أنها لا تستحق العبادة، ولم يكن سياق الكلام في معرض الإنكار عليهم ترْك عبادته، وأن ما هو في معرض الإنكار عبادةُ من لا يستحق العبادة. فلو أنه قال: لا تعبدون الله وقد خلقكم وما تعملون. لتعينت المصدرية قطعًا، ولم يحسن أن يكون بمعنى: الذي؛ إذ يكون المعنى: كيف لا تعبدونه وهو الذي أوجدكم وأوجد أعمالكم، فهو المنعم عليكم بنوعي الإيجاد والخلق. فهذا وِزان ما قرروه مِن كونها مصدرية. فأما سياق الآية فإنه في معرض إنكاره عليهم عبادةَ مَن لا يستحق العبادة، فلا بُدَّ أن يبين فيه معنًى ينافي كونه معبودًا، فبيَّن هذا المعنى بكونه مخلوقًا له، ومَن كان مخلوقًا مِن بعض مخلوقاته فإنه لا ينبغي أن يُعْبَد ولا تليق به العبادة، وتأمل مطابقة هذا المعنى لقوله: <q>﴿والَّذِينَ يَدْعُونَ مِن دُونِ اللَّهِ لا يَخْلُقُونَ شَيْئًا وهُمْ يُخْلَقُونَ﴾</q> [النحل:٢٠] كيف أنكر عليهم عبادة آلهة مخلوقة له سبحانه وهي غير خالقة، فهذا يبين المراد من قوله: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q>، ونظيره قوله في سورة الأعراف [١٩٤]: <q>﴿إنَّ الَّذِينَ تَدْعُونَ مِن دُونِ اللَّهِ عِبادٌ أمْثالُكُمْ﴾</q> أي: هم عباد مخلوقون كما أنتم كذلك فكيف تعبدون المخلوق. وتأمل طريقة القرآن لو أراد المعنى الذي ذكروه مِن حسن صفاته وانفراده بالخلق كقول صاحب يس: <q>﴿وما لِيَ لا أعبد الَّذِي فَطَرَنِي﴾</q> [يس:٢٢] فهنا لما كان المقصود إخبارهم بحسن عبادته واستحقاقه لها ذكر الموجب لذلك، وهي كونه خالقًا لعابده فاطرًا له، وهذا إنعام منه عليه؛ فكيف يترك عبادته؟! ولو كان هذا هو المراد من قوله: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q> كان يقتضي أن يقال: ألا يعبدون الله وهو خالقهم وخالق أعمالهم. فتأمله فإنه واضح». ثم بيَّن كيف يستدل بالآية على خلق الله لأعمال العباد، فقال: «ووجه الاستدلال بها على هذا التقدير: أنّ الله سبحانه أخبر أنه خالقهم وخالق الأصنام التي عملوها، وهي إنما صارت أصنامًا بأعمالهم، فلا يقع عليها ذلك الاسم إلا بعد عملهم، فإذا كان سبحانه هو الخالقُ اقتضى صِحَّة هذا الإطلاق أن يكون خالقها بجملتها، أعني: مادتها وصورتها، فإذا كانت صورتها مخلوقة لله كما أنّ مادتها كذلك لزم أن يكون خالقًا لنفس عملهم الذي حصلت به الصورة؛ لأنه متولد عن نفس حركاتهم، فإذا كان الله خالقها كانت أعمالهم التي تولد عنها ما هو مخلوق لله مخلوقة له، وهذا أحسن استدلالًا وألطف من جعل»ما«مصدرية، ونظيره من الاستدلال سواء قوله: <q>﴿وآيَةٌ لَهُمْ أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q> [يس:٤١-٤٢]، والأصح أن المثل المخلوق هنا هو السفن، وقد أخبر أنها مخلوقة، وهي إنما صارت سفنًا بأعمال العباد، ونظير هذا الاستدلال أيضًا قوله تعالى: <q>﴿واللَّهُ جَعَلَ لَكُمْ مِمّا خَلَقَ ظِلالًا وجَعَلَ لَكُمْ مِنَ الجِبالِ أكْنانًا وجَعَلَ لَكُمْ سَرابِيلَ تَقِيكُمُ الحَرَّ وسَرابِيلَ تَقِيكُمْ بَأْسَكُمْ﴾</q> [النحل:٨١] والسرابيل التي يلبسونها وهي مصنوعة لهم، وقد أخبر بأنه سبحانه هو جاعلها، وإنما صارت سرابيل بعملهم، ونظيره: <q>﴿واللَّهُ جَعَلَ لَكُمْ مِن بُيُوتِكُمْ سَكَنًا وجَعَلَ لَكُمْ مِن جُلُودِ الأنْعامِ بُيُوتًا﴾</q> [النحل:٨٠] والبيوت التي من جلود الأنعام هي الخيام، وإنما صارت بيوتًا بعملهم. فإن قلت: المراد من هذا كله المادة لا الصورة. قلت: المادة لا تستحق هذه الأسماء التي أطلق الخلق عليها، وإنما تستحق هذه الأسماء بعد عملها وقيام صورها بها، وقد أخبر أنها مخلوقة له في هذه الحال. والله أعلم. فالأولى أن تكون»ما«موصولة، أي: والله خلقكم وخلق آلهتكم التي عملتموها بأيديكم، فهي مخلوقة له، لا آلهة شركاء معه، فأخبر أنه خلق معمولهم، وقد حله عملهم وصنعهم، ولا يقال:»المراد مادته«فإن مادته غير معمولة لهم، وإنما يصير معمولًا بعد عملهم». وبنحوه قال ابنُ تيمية (٥/٣٤٨-٣٥١)، وضعَّفَ القول الأول جدًّا، بل غلَّطه. ",footnotes:1:أخرجه الحاكم ١/٨٥ (٨٥، ٨٦) بلفظ: «خالق كل صانع»، والبخاري في خلق أفعال العباد ص٤٦ واللفظ له. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الهيثمي في المجمع ٧/١٩٧ (١١٨٣٢): «رواه البزار، ورجاله رجال الصحيح غير أحمد بن عبد الله أبو الحسين ابن الكردي، وهو ثقة». وأورده الألباني في الصحيحة ٤/١٨١ (١٦٣٧).أخرجه يحيى بن سلام ٢/٨٣٦-٨٣٧، وابن جرير ١٩/٥٧٥، وعنده في رواية أخرى: الأصنام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وعقب يحيى بن سلام عليه بقوله: أي: خلقكم وخلق ذلك الذي تنحتون.تفسير مقاتل بن سليمان ٣/٦١٢.
37,97," <q>﴿قَالُوا۟ ٱبۡنُوا۟ لَهُۥ بُنۡیَـٰنࣰا فَأَلۡقُوهُ فِی ٱلۡجَحِیمِ ۝٩٧﴾</q> - تفسير ٦٥٦٢٥- قال عبد الله بن عباس: <q>﴿قالُوا ابْنُوا لَهُ بُنْيانًا﴾</q> بنوا حائطًا مِن حجارة، طوله في السماء ثلاثون ذراعًا، وعرضه عشرون ذراعًا{1}. (ز) ٦٥٦٢٦- قال الحسن البصري: جمعوا الحطبَ زمانًا، حتّى إنَّ الشيخ الكبير الذي لم يخرج مِن بيته قبل ذلك زمانًا كان يجيء بالحطب، فيُلقيه يتقرَّب به إلى آلهتهم فيما يزعم، ثم جاءوا بإبراهيم، فألقوه في تلك النار{2}. (ز) ٦٥٦٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿قالُوا ابْنُوا لَهُ بُنْيانًا فَأَلْقُوهُ فِي الجَحِيمِ﴾</q>، قال: فحبسوه في بيت، وجمعوا له حَطبًا، حتى إن كانت المرأةُ لَتَمرضُ فتقول: لَئِن عافاني اللهُ لأجمعنَّ حطبًا لإبراهيم. فلمّا جمعوا له وأكثروا من الحطب، حتى إن كانت الطير لَتَمُرُّ بها فتحترق مِن شدة وهجها، فعمدوا إليه، فرفعوه على رأس البنيان، فرفع إبراهيمُ رأسَه إلى السماء، فقالت السماء والأرض والجبال والملائكة: ربَّنا، إبراهيم يُحْرَق فيك. فقال: أنا أعلمُ به، وإن دعاكم فأغيثوه. وقال إبراهيم حين رفع رأسه إلى السماء: اللهم، أنت الواحد في السماء، وأنا الواحد في الأرض، ليس في الأرض أحد يعبدك غيري، حسبي الله ونعم الوكيل. فقذفوه فيها، فناداها: <q>﴿يا نارُ كُونِي بَرْدًا وسَلامًا عَلى إبْراهِيمَ﴾</q> [الأنبياء:٦٩]{3}. (١٢/٤٢٧) ٦٥٦٢٨- قال مقاتل بن سليمان: <q>﴿فَأَلْقُوهُ فِي الجَحِيمِ﴾</q> في نار عظيمة، قال الله ﷿: <q>﴿يا نارُ كُونِي بَرْدًا وسَلامًا عَلى إبْراهِيمَ﴾</q> [الأنبياء:٦٩]{1}. (ز) ٦٥٦٢٩- قال يحيى بن سلّام: <q>﴿قالُوا ابْنُوا لَهُ بُنْيانًا﴾</q> يقوله بعضهم لبعض <q>﴿فَأَلْقُوهُ فِي الجَحِيمِ﴾</q> أي: في النار. بلغني: أنّهم رموا به في المنجنيق، فكان ذلك أول ما صُنع المنجنيق{5}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦١٣.علقه يحيى بن سلام ٢/٨٣٧.أخرجه ابن جرير١٦/٣٠٦.تفسير مقاتل بن سليمان ٣/٦١٣.تفسير يحيى بن سلام ٢/٨٣٧.
37,98," <q>﴿فَأَرَادُوا۟ بِهِۦ كَیۡدࣰا فَجَعَلۡنَـٰهُمُ ٱلۡأَسۡفَلِینَ ۝٩٨﴾</q> - تفسير ٦٥٦٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَأَرادُوا بِهِ كَيْدًا فَجَعَلْناهُمُ الأَسْفَلِينَ﴾</q>، قال: فما ناظرهم اللهُ بعد ذلك حتى أهلكهم{1}. (١٢/٤٢٥) ٦٥٦٣١- قال مقاتل بن سليمان: <q>﴿وأَرادُوا بِهِ كَيْدًا﴾</q> سوءًا، الآية [الأنبياء:٧٠]، وعلاهم{2} إبراهيم ﵇، وسلَّمه الله ﷿، وحجزهم عنه، فلم يلبثوا إلا يسيرًا حتى أهلكهم الله ﷿، فما بقيت يومئذ دابةٌ إلا جعلتْ تُطْفِئ النار عن إبراهيم ﵇، غير الوزغ؛ كانت تنفخ النار على إبراهيم، فأمر النبي ﷺ بقتْلها{3}. (ز) ٦٥٦٣٢- قال يحيى بن سلّام: <q>﴿فَأَرادُوا بِهِ كَيْدًا﴾</q> تحريقهم إيّاه، <q>﴿فَجَعَلْناهُمُ الأَسْفَلِينَ﴾</q> في النار{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.كذا، ولعلها مفهوم قول الله تعالى: <q>﴿فَجَعَلْناهُمُ الأَسْفَلِينَ﴾</q>.تفسير مقاتل بن سليمان ٣/٦١٣.تفسير يحيى بن سلام ٢/٨٣٨.
37,99," <q>﴿وَقَالَ إِنِّی ذَاهِبٌ إِلَىٰ رَبِّی سَیَهۡدِینِ ۝٩٩﴾</q> - تفسير ٦٥٦٣٣- عن سليمان بن صرد -من طريق أبي إسحاق- يقول: لَمّا أرادوا أن يلقوا إبراهيم في النار <q>﴿قالَ إنِّي ذاهِبٌ إلى رَبِّي سَيَهْدِينِ﴾</q>. فجُمِع الحطب، فجاءت عجوز على ظهرها حطب، فقيل لها: أين تريدين؟ قالت: أريد أذهب إلى هذا الرجل الذي يُلقى في النار. فلما ألقي فيها قال: حسبي الله عليه توكلت، أو قال: حسبي الله ونعم الوكيل. قال: فقال الله: <q>﴿يا نارُ كُونِي بَرْدًا وسَلامًا عَلى إبْراهِيمَ﴾</q>. قال: فقال ابن لوط، أو ابن أخي لوط: إنّ النار لم تحرقه مِن أجلي. وكان بينهما قرابة، فأرسل الله عليه عُنُقًا مِن النار، فأحرقته{1}. (ز) ٦٥٦٣٤- عن عبد الله بن عباس، في قوله: <q>﴿وقالَ إنِّي ذاهِبٌ إلى رَبِّي سَيَهْدِينِ﴾</q>، قال: حين هاجر{2}٥٥٠٢. (١٢/٤٢٧) ٥٥٠٢ قال ابنُ جرير (١٩/٥٧٦-٥٧٧): «قال آخرون في ذلك: إنما قال إبراهيم: <q>﴿إني ذاهب إلى ربي﴾</q> حين أرادوا أن يلقوه في النار». وذكر أثر سليمان بن صرد السابق، ثم اختار القول الأول أنه قال ذلك حين أراد الهجرة مستندًا إلى النظائر، وقال: «إنما اخترت القول الذي قلت في ذلك لأن الله ﷾ ذكر خبره وخبر قومه في موضع آخر، فأخبر أنه لما نجاه مما حاول قومه من إحراقه قال: <q>﴿إني مهاجر إلى ربي﴾</q> [العنكبوت:٢٦] ففسر أهل التأويل ذلك أن معناه: إني مهاجر إلى أرض الشام، فكذلك قوله: <q>﴿إني ذاهب إلى ربي﴾</q>؛ لأنه كقوله: <q>﴿إني مهاجر إلى ربي﴾</q>». وذَهَبَ إلى الأول أيضًا ابنُ عطية (٧/٣٠٠) مستندًا إلى الدلالة العقلية، فقال: «الأول أظهر في نمط الآية عما بعده؛ لأن الهداية معه تترتب، والدعاء في الولد كذلك، ولا يصح مع ذهاب الفناء». وإلى ذلك أيضًا ذهب ابنُ كثير (١٢/٣٧). ٦٥٦٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وقالَ إنِّي ذاهِبٌ إلى رَبِّي﴾</q>، قال: ذاهب بعمله، وقلبه، ونيته{3}. (١٢/٤٢٥) ٦٥٦٣٦- قال مقاتل بن سليمان: <q>﴿وقالَ﴾</q> وهو ببابل: <q>﴿إنِّي ذاهِبٌ﴾</q> يعني: مهاجر <q>﴿إلى رَبِّي﴾</q> إلى رِضا ربي بالأرض المقدسة، <q>﴿سَيَهْدِينِ﴾</q> لدينه. وهو أول من هاجر من الخلق، ومعه لوط وسارة{4}. (ز) ٦٥٦٣٧- قال يحيى بن سلّام: <q>﴿وقالَ إنِّي ذاهِبٌ إلى رَبِّي سَيَهْدِينِ﴾</q> الطريق، يعني: الهجرة، هاجر من أرض العراق إلى أرض الشام. قال قتادة: وكان يُقال: إنّ الشام عماد دار الهجرة{5}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في العقوبات ٤/٤٩٤ (٢٤٠)، وابن جرير ١٩/٥٧٦-٥٧٧.عزاه السيوطي إلى ابن المنذر. وذكر محققو الدر المنثور أنه جاء في بعض نسخه بعد هذا الأثر: وأخرج عبد بن حميد عن مجاهد مثله.أخرجه ابن جرير ١٩/٥٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٣.تفسير يحيى بن سلام ٢/٨٣٨.
37,100," <q>﴿رَبِّ هَبۡ لِی مِنَ ٱلصَّـٰلِحِینَ ۝١٠٠﴾</q> - تفسير ٦٥٦٣٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿رَبِّ هَبْ لِي مِنَ الصّالِحِينَ﴾</q>، قال: ولدًا صالحًا{1}. (١٢/٤٢٧) ٦٥٦٣٩- قال مقاتل بن سليمان: فلمّا قدم الأرض المقدسة، سأل ربَّه الولد: <q>﴿رَبِّ هَبْ لِي مِنَ الصّالِحِينَ﴾</q> ولدًا صالحًا{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٧٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٤.
37,101," <q>﴿فَبَشَّرۡنَـٰهُ بِغُلَـٰمٍ حَلِیمࣲ ۝١٠١﴾</q> - تفسير ٦٥٦٤٠- قال عبد الله بن عباس -من طريق الزهري عن القاسم- <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>: هو إسماعيل. وكان ذلك بمنى{1}. (١٢/٤٢٨) ٦٥٦٤١- قال كعب الأحبار -من طريق الزهري، عن القاسم- <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>: هو إسحاق، وكان ذلك ببيت المقدس{1}. (١٢/٤٢٨) ٦٥٦٤٢- عن عبيد بن عمير -من طريق ابن جريج- في قوله: <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>، قال: هو إسحاق{3}. (١٢/٤٢٨) ٦٥٦٤٣- عن عكرمة مولى ابن عباس -من طريق يزيد- <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>، قال: هو إسحاق{4}. (١٢/٤٢٨) ٦٥٦٤٤- عن عامر الشعبي، في قوله: <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>، قال: هو إسماعيل. قال: وبشَّره الله بنبوة إسحاق بعد ذلك{5}. (١٢/٤٢٨) ٦٥٦٤٥- عن الحسن البصري، في قوله: <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>، قال: بولادة إسحاق{6}. (١٢/٤٢٧) ٦٥٦٤٦- عن مجاهد بن جبر، مثله{7}. (١٢/٤٢٨) ٦٥٦٤٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>، قال: بُشِّرَ بإسحاق. قال: ولم يُثْنِ اللهُ بالحِلْم على أحد إلا على إبراهيم وإسحاق{8}. (١٢/٤٢٨) ٦٥٦٤٨- عن محمد بن كعب القرظي، في قوله: <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>، قال: إسماعيل{9}. (١٢/٤٢٨) ٦٥٦٤٩- قال مقاتل بن سليمان: فاستجاب له، <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q> يعني: عليم، وهو العالم، وهو إسحاق بن سارة{10}٥٥٠٣. (ز) ٥٥٠٣ اختُلِف في المراد بقوله تعالى: <q>﴿فبشرناه بغلام حليم﴾</q> على قولين: الأول: أنها البشارة المعروفة بإسحاق ﵇، وهو الذبيح على قول. والثاني: أنها البشارة بإسماعيل ﵇، وهو الذبيح. وسيأتي بيان كلام الأئمة، عند قوله تعالى: <q>﴿وفديناه بذبح عظيم﴾</q>. <q>﴿فَبَشَّرۡنَـٰهُ بِغُلَـٰمٍ حَلِیمࣲ ۝١٠١﴾</q> - آثار متعلقة بالآية ٦٥٦٥٠- عن يونس، قال: سمعت الحسن يقول: ما سمعتُ الله نَحَلَ عباده شيئًا أقل مِن الحلم؛ فإنه قال: <q>﴿إنَّ إبْراهِيمَ لَحَلِيمٌ﴾</q> [هود:٧٥]، وقال: <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q>{11}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد الرزاق، وابن المنذر.عزاه السيوطي إلى عبد الرزاق، وابن المنذر.أخرجه عبد الرزاق ٢/١٥٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٩/٥٧٨.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥٧٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦١٤.أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ٢/٧٠٧.
37,102," <q>﴿فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعۡیَ﴾</q> - تفسير ٦٥٦٥١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: العمل{1}. (١٢/٤٢٩) ٦٥٦٥٢- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: شبَّ، حتى بلغ سعيُه سعيَ إبراهيم في العمل{2}. (١٢/٤٣١) ٦٥٦٥٣- قال عبد الله بن عباس= (ز) ٦٥٦٥٤- وقتادة بن دعامة: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، يعني: المشي معه إلى الجبل{3}. (ز) ٦٥٦٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: لما شبَّ حتى أدرك سعيُه سعيَ إبراهيم في العمل{4}. (١٢/٤٢٩) ٦٥٦٥٦- عن الضحاك بن مزاحم، <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: العمل{5}. (١٢/٤٢٩) ٦٥٦٥٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: أدرك معه العمل{6}. (١٢/٤٢٩) ٦٥٦٥٨- قال الحسن البصري: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q> بلغ معه سعي العمل، يعني: قيام الحجة{7}. (ز) ٦٥٦٥٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: لَمّا مَشى مع أبيه{8}٥٥٠٤. (١٢/٤٢٩) ٥٥٠٤ ذكر ابنُ عطية (٧٨/٣٠١) أن «السَّعْيَ» في هذه الآية: العمل والعبادة والمعونة. ثم قال: «هذا قول ابن عباس، ومجاهد، وابن زيد». وساق القول بأن المراد: السعي على القدم. الذي قال به قتادة، وما في معناه، وعلَّق عليه بقوله: «يريد: سعيًا متمكنًا. وهذا في المعنى نحو الأول». ٦٥٦٦٠- قال إسماعيل السُّدِّيّ: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، يعني: المشي{9}. (ز) ٦٥٦٦١- عن محمد بن السائب الكلبي -من طريق عبد الوهاب- قال: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، يقول: فلمّا عمِل مثلَ عمله{10}. (ز) ٦٥٦٦٢- قال مقاتل بن سليمان: <q>﴿فَلَمّا بَلَغَ مَعَهُ﴾</q> مع أبيه <q>﴿السَّعْيَ﴾</q> المشي إلى الجبل{11}. (ز) ٦٥٦٦٣- عن مقاتل بن حيان: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، يعني: العمل الذي يقوم به الحجة{12}. (ز) ٦٥٦٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَلَمّا بَلَغَ مَعَهُ السَّعْيَ﴾</q>، قال: السعي هاهنا: العبادة{13}. (ز) <q>﴿قَالَ یَـٰبُنَیَّ إِنِّیۤ أَرَىٰ فِی ٱلۡمَنَامِ أَنِّیۤ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ﴾</q> - قراءات ٦٥٦٦٥- عن الضحاك: (فَأَسَرَّ فِي نَفْسِهِ حُزْنًا) في قراءة عبد الله [بن مسعود]، <q>﴿قالَ يا بُنَيَّ إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ﴾</q>{14}. (١٢/٤٢٩) <q>﴿قَالَ یَـٰبُنَیَّ إِنِّیۤ أَرَىٰ فِی ٱلۡمَنَامِ أَنِّیۤ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ﴾</q> - تفسير الآية ٦٥٦٦٦- عن عُبيد بن عُمير -من طريق عمرو بن دينار- قال: رؤيا الأنبياء وحيٌ. ثم تلا هذه الآية: <q>﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</q>{15}. (١٢/٤٣١) ٦٥٦٦٧- قال عطاء= (ز) ٦٥٦٦٨- ومقاتل: <q>﴿قالَ يا بُنَيَّ إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ﴾</q> أُمِر إبراهيمُ أن يذبح ابنَه ببيت المقدس، فلما تيقّن ذلك أخبر ابنَه، فقال: <q>﴿فانْظُرْ ماذا تَرى﴾</q>{16}. (ز) ٦٥٦٦٩- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</q> رؤيا الأنبياء حقٌّ، إذا رأوا شيئًا فعلوه{17}. (١٢/٤٣٢) ٦٥٦٧٠- عن عثمان بن حاضر، قال: لَمّا أراد إبراهيمُ أن يذبح ابنَه إسحاقَ؛ ترك أُمَّه سارةَ في مسجد الخيف، وذهب بإسحاق معه، فلما بلغ حيث أراد أن يذبحه قال إبراهيمُ لِمَن كان معه: استأخروا مِنِّي. وأخذ بيد ابنه إسحاق، فعزله، فقال: <q>﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</q>. قال له إسحاق: يا أبتِ، ربِّي أمرك؟ قال إبراهيم: نعم، يا إسحاق. قال إسحاق: <q>﴿يا أبَتِ افْعَلْ ما تُؤْمَرُ سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</q>{18}. (١٢/٤٤٦) ٦٥٦٧١- قال مقاتل بن سليمان: <q>﴿قالَ يا بُنَيَّ إنِّي أرى فِي المَنامِ﴾</q> لِنَذْرٍ كان عليه فيه، يقول: إني أُمرت في المنام <q>﴿أنِّي أذْبَحُكَ فانْظُرْ ماذا تَرى﴾</q>{11}٥٥٠٥. (ز) ٥٥٠٥ ذكر ابنُ عطية (٧/٣٠١) أن قوله: <q>﴿إنِّي أرى فِي المَنامِ أنِّي أذْبَحُكَ﴾</q> يحتمل احتمالين: الأول: أن يكون رأى ذلك بعينه، ورؤيا الأنبياء وحي، وعُيّن له وقت الامتثال. الثاني: أن يكون أُمر في نومه بذبحه، فعبر هو عن ذلك، أي: إني رأيت في المنام ما يوجب أن أذبحك. ٦٥٦٧٢- قال محمد بن إسحاق -من طريق سلمة-: يقول الله تعالى في الخبر عن إبراهيم: <q>﴿قال يا بني إني أرى في المنام أني أذبحك﴾</q> ثم مضى على ذلك، فعرف أنّ الوحي من الله يأتي الأنبياء أيقاظًا ونيامًا، وكان رسول الله ﷺ -فيما بلغني- يقول: «تنام عيناي، وقلبي يقظان». فالله أعلم أنّى ذلك كان قد جاءه وعاين فيه ما عاين مِن أمر الله، على أيِّ حالات كان نائمًا أو يقظانًا، كل ذلك حقٌّ وصِدق{20}. (ز) <q>﴿قَالَ یَـٰبُنَیَّ إِنِّیۤ أَرَىٰ فِی ٱلۡمَنَامِ أَنِّیۤ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ﴾</q> - آثار متعلقة بالآية ٦٥٦٧٣- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «رؤيا الأنبياء وحي»{21}. (١٢/٤٣١) ٦٥٦٧٤- عن كعب -من طريق عمرو بن أبي سفيان بن أسيد بن حارثة الثقفي- أنّه قال لأبي هريرة: ألا أخبرك عن إسحاق؟ قال: بلى. قال: أُرِيَ إبراهيمُ أن يذبح إسحاق، قال الشيطان: واللهِ، لئن لم أفْتِن عند هذه آلَ إبراهيم لا أفْتِنُ أحدًا منهم أبدًا. فتمثَّل الشيطانُ رجلًا يعرفونه، فأقبل حتى خرج إبراهيمُ بإسحاق ليذبحه، دخل على سارة، فقال لها: أين أصبح إبراهيمُ غاديًا بإسحاق؟ قالت: لبعض حاجته. قال: لا، واللهِ. قالت: فلِمَ غدا؟ قال: ليذبحه. قالت: لم يكن ليذبح ابنه. قال: بلى، والله. قالت سارة: فلِمَ يذبحه؟ قال: زعم أنّ ربَّه أمره بذلك. قالت: قد أحسن أن يطيع ربَّه إن كان أمره بذلك. فخرج الشيطانُ، فأدرك إسحاقَ وهو يمشي على إثر أبيه، قال: أين أصبح أبوك غاديًا؟ قال: لبعض حاجته. قال: لا، واللهِ، بل غدا بِك ليذبحك. قال: ما كان أبي ليذبحني. قال: بلى. قال: لِمَ؟ قال: زعم أنّ الله أمره بذلك. قال إسحاق: فواللهِ، لَئِن أمره ليطيعنه. فتركه الشيطانُ وأسرع إلى إبراهيم، فقال: أين أصبحتَ غاديًا بابنك؟ قال: لبعض حاجتي. قال: لا، واللهِ، ما غدوتَ به إلا لتذبحه. قال: ولِمَ أذبحه؟ قال: زعمت أنّ الله أمرك بذلك. فقال: واللهِ، لئن كان الله أمرني لأفعلن. قال: فتركه، ويَئِس أن يُطاع، فلما أخذ إبراهيمُ إسحاقَ ليذبحه، وسَلَّم إسحاق، عافاه الله، وفداه بذبح عظيم، فقال: قُم، أيْ بُنَيّ، فإنّ الله قد عافاك. فأوحى الله إلى إسحاق: إني قد أعطيتك دعوةً أستجيب لك فيها. قال: فإني أدعوك أن تستجيب لي أيَّما عبد لقيك مِن الأولين والآخرين لا يشرك بك شيئًا فأدْخِلْه الجنة{22}. (١٢/٤٣٩) ٦٥٦٧٥- عن نوح بن حبيب، قال: سمعتُ الشافعيَّ يقول كلامًا ما سمعتُ قطَّ أحسن منه؛ سمعته يقول: قال إبراهيمُ خليلُ اللهِ لولده في وقت ما قصَّ عليه ما رأى: <q>﴿ماذا تَرى﴾</q> أي: ماذا تشير به؟ ليستخرج بهذه اللفظة منه ذِكر التفويض والصبر والتسليم والانقياد لأمر الله، لا لمؤامرته لدفْع أمر الله تعالى، فقال: <q>﴿يا أبَتِ افْعَلْ ما تُؤْمَرُ سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</q>. قال الشافعي: والتفويض هو الصبر، والتسليم هو الصبر، والانقياد هو ملاك الصبر، فجمع له الذبيحُ جميعَ ما ابتغاه بهذه اللفظة اليسيرة{23}. (١٢/٤٤١) ٦٥٦٧٦- عن أبي منيب الأحدب، قال: خطب معاذ بالشام، فذكر الطاعونَ، فقال: إنها رحمة ربكم، ودعوة نبيكم، وقبْض الصالحين قبلكم، اللهم، أدخِل على آلِ مُعاذٍ نصيبَهم مِن هذه الرحمة. ثم نزل من مقامه ذلك، فدخل على عبد الرحمن بن معاذ، فقال عبد الرحمن: <q>﴿الحَقُّ مِن رَبِّكَ فَلا تَكُونَنَّ مِنَ المُمْتَرِينَ﴾</q> [البقرة:١٤٧]. فقال معاذ: <q>﴿سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</q>{24}. (ز) <q>﴿قَالَ یَـٰۤأَبَتِ ٱفۡعَلۡ مَا تُؤۡمَرُۖ سَتَجِدُنِیۤ إِن شَاۤءَ ٱللَّهُ مِنَ ٱلصَّـٰبِرِینَ ۝١٠٢﴾</q> - تفسير ٦٥٦٧٧- قال مقاتل بن سليمان: فرَدَّ عليه إسحاق: <q>﴿قالَ يا أبَتِ افْعَلْ ما تُؤْمَرُ﴾</q>، وأَطِع ربَّك، فمِن ثمَّ لم يقل إسحاقُ لإبراهيم ﵉: افعل ما رأيت. ورأى إبراهيمُ ذلك ثلاثَ ليالٍ متتابعات، وكان إسحاقُ قد صام وصلى قبل الذبح، <q>﴿سَتَجِدُنِي إنْ شاءَ اللَّهُ مِنَ الصّابِرِينَ﴾</q> على الذبح{11}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٧٩، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه الحاكم ٢/٤٣٠-٤٣١. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٨/١٥٦، وتفسير البغوي ٧/٤٦.تفسير مجاهد (٥٦٩) بنحوه، وأخرجه ابن جرير ١٩/٥٧٩، ومن طريق الحكم أيضًا. وعلَّقه يحيى بن سلام ٢/٨٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي لفظ عند ابن جرير: لما شب حين أدرك سعيه.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٨٣٨. وفي تفسير الثعلبي ٨/١٥٦ بلفظ: يعني: العمل الذي يقوم به الحجة. وفي تفسير البغوي ٧/٤٦: يعني: العمل لله تعالى.أخرجه ابن جرير ١٩/٥٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٣٨.أخرجه البيهقي في شعب الإيمان ٦/٢٢٤-٢٢٥ (٢٧٠٥).تفسير مقاتل بن سليمان ٣/٦١٥.تفسير الثعلبي ٨/١٥٦. وفي تفسير البغوي ٧/٤٦: العمل لله تعالى.أخرجه ابن جرير ١٩/٥٧٩. وهو في تفسير الثعلبي ١٨/١٥٦.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر. وهي قراءة شاذة.أخرجه البخاري (١٣٨، ٨٥٩)، وابن جرير ١٩/٥٨٢، والبيهقي في الأسماء والصفات (٤٢٠)، والحميدي في مسنده (ت: حسين الداراني) ١/٤٢٩ (٤٨٠). وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، والطبراني.تفسير الثعلبي ٨/١٥٦.أخرجه ابن جرير ١٩/٥٨٢. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦١٥.أخرجه ابن أبي حاتم ٤/١١١٧.أخرجه الحاكم ٢/٤٦٨، وابن جرير ١٣/٩، وابن أبي حاتم ٧/٢١٠١، من طريق سفيان، عن سماك بن حرب، عن سعيد بن جبير، عن ابن عباس به، بلفظ: «كانت رؤيا الأنبياء وحيًا». قال الحاكم: «حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الألباني في ظلال الجنة (٤٦٣): «إسناده حسن، رجاله كلهم ثقات، رجال مسلم، وفي سماك كلام يسير ...».أخرجه عبد الرزاق ٢/١٥٠-١٥١، وابن جرير ١٩/٥٩٠-٥٩١، وفي تاريخه ١/٢٦٥-٢٦٦، وابن أبي حاتم -كما في الفتح ١٢/٣٧٨-، والحاكم ٢/٥٥٧-٥٥٨، والبيهقي في شعب الإيمان (٧٣٢٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن عساكر ٢٤/٤٥٤.أخرجه أحمد في مسنده ٣٦/٤٠٤ (٢٢٠٨٥).تفسير مقاتل بن سليمان ٣/٦١٥.
