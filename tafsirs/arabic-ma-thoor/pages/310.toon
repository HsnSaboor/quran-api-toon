tafsir[12]{c,v,t}:
19,65," <q>﴿رَّبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا﴾</q> - تفسير ٤٦٩٤٠- قال مقاتل بن سليمان: <q>﴿رب السماوات والأرض﴾</q> يعني: والأرضين، <q>﴿وما بينهما﴾</q> مِن الخلق{1}. (ز) <q>﴿فَٱعۡبُدۡهُ وَٱصۡطَبِرۡ لِعِبَـٰدَتِهِۦۚ﴾</q> - تفسير ٤٦٩٤١- قال الحسن البصري: قوله: <q>﴿واصطبر لعبادته﴾</q> لِما فَرَضَ عليك{2}. (ز) ٤٦٩٤٢- قال مقاتل بن سليمان: <q>﴿فاعبده﴾</q> يعني: فوَحِّده، <q>﴿واصطبر لعبادته﴾</q> يقول: واصبِر على توحيد الله ﷿، ولا تعجل حتى يأتيَك أمري{1}. (ز) <q>﴿هَلۡ تَعۡلَمُ لَهُۥ سَمِیࣰّا ۝٦٥﴾</q> - تفسير ٤٦٩٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿هل تعلم له سميا﴾</q>، قال: هل تعلم للربِّ مثلًا أو شبهًا؟!{4}٤٢٠٦. (١٠/١٠٨) ٤٢٠٦ علَّق ابنُ عطية (٦/٥٢) على قول ابن عباس من طريق علي، ومجاهد، وقتادة، وابن جريج، بقوله: «وهذا قول حسن، وكأن السَّمِيِّ بمعنى: المُسامِي والمُضاهِي؛ فهو مِن السّمو، وهذا القول يحسن في هذه الآية، ولا يحسن فيما تقدم في ذكر يحيى ﵇». ٤٦٩٤٤- عن عبد الله بن عباس، <q>﴿هل تعلم له سميا﴾</q>، قال: ليس أحدٌ يُسَمّى «الرحمن» غيره{5}. (١٠/١٠٨) ٤٦٩٤٥- عن عبد الله بن عباس، في قوله: <q>﴿هل تعلم له سميا﴾</q>: هل تعلم -يا محمدُ- لإلهك مِن ولَد؟!{6}. (١٠/١٠٨) ٤٦٩٤٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿هل تعلم له سميا﴾</q>. قال: هل تعلم له ولدًا. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت الشاعرَ وهو يقول: أما السَّمِيُّ فأنت منه مُكَثَّرٌ والمالُ مالٌ يَغتدي ويَروح؟{7}. (١٠/١٠٨) ٤٦٩٤٧- عن مجاهد بن جبر -من طريق الأعمش- في هذه الآية: <q>﴿هل تعلم له سميا﴾</q>، قال: هل تعلم له شبهًا؟! هل تعلم له مثلًا؟!{8}. (ز) ٤٦٩٤٨- عن قتادة بن دعامة -من طريق سعيد- قال: هل تعلم له عِدْلًا؟!= (ز) ٤٦٩٤٩- قال يحيى بن سلام: أي: من قِبَل المساماة{9}. (ز) ٤٦٩٥٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿هل تعلم له سميا﴾</q>: لا سَمِيَّ لله، ولا عِدْل له، كلُّ خَلْقِه يُقِرُّ له ويعترف أنّه خالقُه، ويعرف ذلك. ثم يقرأ هذه الآية: <q>﴿ولئن سألتهم من خلقهم ليقولن الله﴾</q> [الزخرف:٨٧]{10}. (ز) ٤٦٩٥١- قال محمد بن السائب الكلبي: هل تعلم أحدًا يُسَمّى «الله» غيره؟!{11}٤٢٠٧. (ز) ٤٢٠٧ ذكر ابنُ عطية (٦/٥٢) أنّ هذا القول هو ظاهر اللفظ، ثم علَّق بقوله: «وهذا يحسن فيه أن يريد بالاسم ما تقدم من قوله: <q>﴿رَبُّ السَّماواتِ والأَرْضِ وما بَيْنَهُما﴾</q>، أي: هل تعلم مَن يُسَمّى بهذا ويُوصَف بهذه الصفة؟ وذلك أنّ الأُمَم لا يُسَمُّون بهذا الاسم وثنًا ولا شيئًا سوى الله تعالى، وأمّا الألوهية والقدرة وغير ذلك فقد يوجه السمي فيها، وذلك باشتراكٍ، لا بمعنًى واحد». ٤٦٩٥٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿هل تعلم له سميا﴾</q>، قال: يقول: لا شريك له، ولا مثل{8}. (ز) ٤٦٩٥٣- قال مقاتل بن سليمان: ثم قال للنبيِّ ﷺ: <q>﴿هل تعلم له سميا﴾</q>، يقول جل جلاله: هل تعلمُ مِن الآلهة مِن شيء اسمه: الله ﷿؟! لأن الله -تعالى ذِكْرُه- يمنعهم مِن ذلك{1}. (ز) ٤٦٩٥٤- قال يحيى بن سلّام: قوله: <q>﴿هل تعلم له سميا﴾</q> على الاستفهام؛ أي: إنّك لا تعلمه{9}. (ز) <q>﴿هَلۡ تَعۡلَمُ لَهُۥ سَمِیࣰّا ۝٦٥﴾</q> - آثار متعلقة بالآية ٤٦٩٥٥- عن الحسن البصري -من طريق أبي الأشهب- قال: «اللهُ» و«الرحمنُ» اسمان ممنوعان، لم يستطع أحدٌ مِن الخلق أن يَنتَحِلَهما{15}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٣٣.علَّقه يحيى بن سلام ١/٢٣٤.تفسير مقاتل بن سليمان ٢/٦٣٣.أخرجه ابن جرير ١٥/٥٨٥، وابن أبي حاتم -كما في فتح الباري ٦/٤٦٨-، وابن مردويه -كما في التغليق ٤/٣٤-، والبيهقي في شعب الإيمان (١٢٢). وعزاه السيوطي إلى ابن المنذر.أخرجه الحاكم ٢/٣٧٥، والبيهقي في شعب الإيمان (١٢٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.أخرجه الطستي -كما في الإتقان ٢/١٠١-.أخرجه ابن جرير ١٥/٥٨٦.تفسير يحيى بن سلام ١/٢٣٤.أخرجه يحيى بن سلام ١/٢٣٤ مختصرًا، وابن جرير ١٥/٥٨٦.تفسير الثعلبي ٦/٢٢٣، وتفسير البغوي ٥/٢٤٤.أخرجه ابن جرير ١٥/٥٨٦.تفسير مقاتل بن سليمان ٢/٦٣٣.تفسير يحيى بن سلام ١/٢٣٤.أخرجه يحيى بن سلام ١/٢٣٤.
19,66," <q>﴿وَیَقُولُ ٱلۡإِنسَـٰنُ أَءِذَا مَا مِتُّ لَسَوۡفَ أُخۡرَجُ حَیًّا ۝٦٦﴾</q> - قراءات ٤٦٩٥٦- عن الأعمش: في قراءة عبد الله بن مسعود: (سَأَخْرُجُ حَيًّا){1}. (ز) ٤٦٩٥٧- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿لَسَوْفَ أُخْرَجُ﴾</q> برفع الألف{2}. (١٠/١٠٩) <q>﴿وَیَقُولُ ٱلۡإِنسَـٰنُ أَءِذَا مَا مِتُّ لَسَوۡفَ أُخۡرَجُ حَیًّا ۝٦٦﴾</q> - تفسير الآية، ونزولها ٤٦٩٥٨- عن زيد بن أسلم -من طريق حفص- في قول الله: <q>﴿ويقول الإنسان أإذا ما مت لسوف أخرج حيا﴾</q>: وذلك في الذين يُنكِرون البعث{3}. (ز) ٤٦٩٥٩- قال مقاتل بن سليمان: <q>﴿ويقول الإنسان﴾</q>، وهو أُبَيُّ بن خلف الجمحي: <q>﴿أإذا ما مت لسوف أخرج حيا﴾</q> مِن الأرض بعد الموت، يقول ذلك تكذيبًا بالبعث{4}. (ز) ٤٦٩٦٠- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ويقول الإنسان﴾</q> الآية، قال: قالها العاصي بن وائل{5}. (١٠/١٠٨) ٤٦٩٦١- قال يحيى بن سلّام: قوله: <q>﴿ويقول الإنسان أإذا ما مت لسوف أخرج حيا﴾</q> هذا المشرك يكذب بالبعث، وقد ذكروا أنه قولُ أُبَيِّ بن خَلَفٍ للنبي ﵇، حيث جاء بعَظْمٍ نَخِرٍ، فَفَتَّه بيده، ثم قال: يا محمد، أيُحْيِي اللهُ هذا؟ وتفسيره في سورة يس{6}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٣. (سَأَخْرُجُ حَيًّا) بالسين قراءة شاذة، تروى أيضًا عن طلحة بن مصرف. انظر: مختصر ابن خالويه ص٨٨.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٣٧ (٧٦).تفسير مقاتل بن سليمان ٢/٦٣٣.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٢٣٤.
19,67," <q>﴿أَوَلَا یَذۡكُرُ ٱلۡإِنسَـٰنُ أَنَّا خَلَقۡنَـٰهُ مِن قَبۡلُ وَلَمۡ یَكُ شَیۡـࣰٔا ۝٦٧﴾</q> - قراءات ٤٦٩٦٢- عن عاصم بن أبي النجود أنّه قرأ: ... <q>﴿أوَلا يَذْكُرُ الإنسانُ﴾</q> خفيفة؛ بنصب الياء ورفع الكاف{1}. (١٠/١٠٩) <q>﴿أَوَلَا یَذۡكُرُ ٱلۡإِنسَـٰنُ أَنَّا خَلَقۡنَـٰهُ مِن قَبۡلُ وَلَمۡ یَكُ شَیۡـࣰٔا ۝٦٧﴾</q> - تفسير الآية ٤٦٩٦٣- قال مقاتل بن سليمان: يقول الله ﷿ يَعِظُه ليعتبر: <q>﴿أولا يذكر الإنسان﴾</q> يقول: أوَلا يتذكر الإنسان في خلق نفسه <q>﴿أنا خلقناه﴾</q> أول مرة، يعني: أول خلق خلقناه <q>﴿من قبل ولم يك شيئا﴾</q>{2}. (ز) ٤٦٩٦٤- قال يحيى بن سلّام: قال الله -تبارك وتعالى-: <q>﴿أولا يذكر الإنسان أنا خلقناه من قبل ولم يك شيئا﴾</q>، فالذي خلقه ولم يكُ شيئًا قادرٌ على أن يبعثه يوم القيامة{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة نافع، وابن عامر، وعاصم، وقرأ بقية العشرة: ‹أوَ لا يَذَّكَّرُ› بتشديدهما مع فتح الكاف. انظر: النشر ٢/٣١٨، والإتحاف ص٣٨٠.تفسير مقاتل بن سليمان ٢/٦٣٤.تفسير يحيى بن سلام ١/٢٣٤.
19,68," <q>﴿فَوَرَبِّكَ لَنَحۡشُرَنَّهُمۡ وَٱلشَّیَـٰطِینَ ثُمَّ لَنُحۡضِرَنَّهُمۡ حَوۡلَ جَهَنَّمَ جِثِیࣰّا ۝٦٨﴾</q> - قراءات ٤٦٩٦٥- عن عبد الله بن عباس، قال: لا أدري كيف قرأ النبيُّ ﷺ ‹عُتِيًّا› أو ‹جُثِيًّا›؛ فإنهما جميعًا بالضم{1}. (١٠/١٠٩) ٤٦٩٦٦- عن عاصم بن أبي النجود أنّه قرأ: ‹جُثِيًّا›برفع الجيم، و‹عُتِيًّا› برفع العين، و‹صُلِيًّا› برفع الصاد{2}. (١٠/١٠٩) <q>﴿فَوَرَبِّكَ لَنَحۡشُرَنَّهُمۡ وَٱلشَّیَـٰطِینَ﴾</q> - تفسير ٤٦٩٦٧- عن عبد الله بن مسعود، قال: يَحْشُرُ الأولَ على الآخر، حتى إذا تكاملت العِدَّةُ أثارهم جميعًا{3}. (١٠/١١٠) ٤٦٩٦٨- عن زيد بن أسلم -من طريق حفص- يقول الله: <q>﴿أولا يذكر الإنسان أنا خلقناه من قبل ولم يك شيئا فوربك﴾</q> يا محمد، <q>﴿لنحشرنهم﴾</q> أهل هذا القول، المُكَذِّبين بالبعث، <q>﴿والشياطين ثم لنحضرنهم حول جهنم جثيا﴾</q>{4}. (ز) ٤٦٩٦٩- قال مقاتل بن سليمان: فأقسم الربُّ ﷿ لَيبعثهم في الآخرة، فقال: <q>﴿فوربك﴾</q> يا محمد، <q>﴿لنحشرنهم﴾</q> يعني: لنجمعنهم، <q>﴿والشياطين﴾</q> معهم الذين أضلُّوهم، في الآخرة{5}. (ز) ٤٦٩٧٠- قال يحيى بن سلّام: ثم أقسم بنفسه، فقال: <q>﴿فوربك لنحشرنهم﴾</q> يعني: المشركين، <q>﴿والشياطين﴾</q> الذين دَعَتْهُم إلى عبادة الأوثان{6}. (ز) <q>﴿ثُمَّ لَنُحۡضِرَنَّهُمۡ حَوۡلَ جَهَنَّمَ جِثِیࣰّا ۝٦٨﴾</q> - تفسير ٤٦٩٧١- عن عبد الله بن عباس، في قوله: ‹جُثِيًّا›، قال: قُعودًا{7}. (١٠/١٠٩) ٤٦٩٧٢- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿ثم لنحضرنهم حول جهنم جثيا﴾</q>، يعني: القعود. وهو مثل قوله: <q>﴿وترى كل أمة جاثية﴾</q> [الجاثية:٢٨]{8}. (ز) ٤٦٩٧٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ثم لنحضرنهم حول جهنم جثيا﴾</q>، قال: على رُكَبهم{9}. (ز) ٤٦٩٧٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿حول جهنم جثيا﴾</q>، قال: قيامًا{7}. (١٠/١١٠) ٤٦٩٧٥- قال محمد بن السائب الكلبي: جماعة، كلُّ أُمَّةٍ على حِدَتِها{11}. (ز) ٤٦٩٧٦- قال مقاتل بن سليمان: <q>﴿ثم لنحضرنهم حول جهنم﴾</q> يعني: في جهنم، <q>﴿جثيا﴾</q>، يعني: جميعًا على الرُّكَب{5}. (ز) ٤٦٩٧٧- قال يحيى بن سلّام: <q>﴿ثم لنحضرنهم حول جهنم جثيا﴾</q>، وهذا قبل دخولهم النار ... وقال بعضهم: <q>﴿جثيا﴾</q> جماعة جماعة{6}. (ز) <q>﴿ثُمَّ لَنُحۡضِرَنَّهُمۡ حَوۡلَ جَهَنَّمَ جِثِیࣰّا ۝٦٨﴾</q> - آثار متعلقة بالآية ٤٦٩٧٨- عن عبد الله بن باباه، قال: قال رسول الله ﷺ: «كأني أراكم بالكوم دون جهنم جاثين»{14}. (١٠/١٠٩) ",footnotes:1:أخرجه الحاكم ٢/٢٤٤. و‹عُتِيًّا›، و‹صُلِيًّا›، و‹جُثِيّا› بضم العين، والصاد، والجيم قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، وحفصًا؛ فإنهم قرؤوا بكسر العين والصاد والجيم فيها. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم، والبيهقي في البعث.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٣٧ (٧٦).تفسير مقاتل بن سليمان ٢/٦٣٤.تفسير يحيى بن سلام ١/٢٣٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٨٧.أخرجه يحيى بن سلام ١/٢٣٥.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢٣٥.تفسير مقاتل بن سليمان ٢/٦٣٤.تفسير يحيى بن سلام ١/٢٣٥.أخرجه ابن المبارك في الزهد ٢/١٠٥، وأبو نعيم في الحلية ٧/٢٩٩، وعبد الرزاق ٣/١٩٣ (٢٨٣٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٧١-. قال ابن حجر في الفتح ١١/٤٠٥: «وقد أخرج البيهقي في البعث من مرسل عبد الله بن باباه بسند رجاله ثقات، رفعه».
19,69," <q>﴿ثُمَّ لَنَنزِعَنَّ﴾</q> - تفسير ٤٦٩٧٩- قال مقاتل بن سليمان: <q>﴿ثم لننزعن من كل شيعة﴾</q>، يقول: لنُخْرِجَنَّ، ثم نبدأ بهم{1}. (ز) ٤٦٩٨٠- عن عبد الملك ابن جُرَيْج، <q>﴿ثم لننزعن﴾</q>، قال: لَنَبْدَأَنَّ{2}. (١٠/١١٠) <q>﴿مِن كُلِّ شِیعَةٍ﴾</q> - تفسير ٤٦٩٨١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿لننزعن من كل شيعة﴾</q>، قال: مِن كل أُمَّة{3}. (١٠/١١٠) ٤٦٩٨٢- قال الحسن البصري: من كل أُمَّة. يعني: كُفّارها{4}. (ز) ٤٦٩٨٣- عن قتادة بن دعامة، في قوله: <q>﴿ثم لننزعن﴾</q> الآية، قال: لننزعن مِن كُل أهل دِين قادتَهم ورؤوسَهم في الشر{5}. (١٠/١١٠) ٤٦٩٨٤- تفسير السُّدِّيّ: قوله: <q>﴿ثم لننزعن من كل شيعة﴾</q>، يعني: مِن كل أهل مِلِّة{4}. (ز) ٤٦٩٨٥- قال مقاتل بن سليمان: <q>﴿ثم لننزعن من كل شيعة﴾</q>، يقول: لنُخْرِجَنَّ، ثم نبدأ بهم، من كل مِلَّة{1}. (ز) <q>﴿أَیُّهُمۡ أَشَدُّ عَلَى ٱلرَّحۡمَـٰنِ عِتِیࣰّا ۝٦٩﴾</q> - تفسير ٤٦٩٨٦- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: يحشر الأول على الآخر، حتى إذا تكاملت العِدَّة أثارهم جميعًا، ثم بدأ بالأكابر فالأكابر جُرْمًا. ثم قرأ: <q>﴿فوربك لنحشرنهم﴾</q> إلى قوله: <q>﴿عتيا﴾</q>{8}. (١٠/١١٠) ٤٦٩٨٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿عتيا﴾</q>، قال: عصِيًّا{9}. (١٠/١٠٩) ٤٦٩٨٨- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿أيُّهُمْ أشَدُّ عَلى الرَّحْمَنِ عِتِيًّا﴾</q>، يقول: أيهم أشد للرحمن معصية، وهي معصيته في الشِّرك{10}. (١٠/١٠٩) ٤٦٩٨٩- عن أبي الأحوص [عوف بن مالك بن نَضْلَة الأشجعي الكوفي] -من طريق علي بن الأقمر- <q>﴿ثم لننزعن من كل شيعة﴾</q> الآية، قال: يبدأ بالأكابرِ فالأكابرِ جُرْمًا{11}. (١٠/١١٠) ٤٦٩٩٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿أشد على الرحمن عتيا﴾</q>، قال: كُفْرًا{12}. (١٠/١١٠) ٤٦٩٩١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿أيهم أشد على الرحمن عتيا﴾</q>، قال: في الدنيا{5}. (١٠/١١٠) ٤٦٩٩٢- قال الحسن البصري: شِدَّة في القَسْوة{14}. (ز) ٤٦٩٩٣- عن زيد بن أسلم -من طريق حفص-: يقول الله: <q>﴿ثم لننزعن من كل شيعة أيهم أشد على الرحمن عتيا﴾</q>، المُكَذِّبين بالبعث{15}. (ز) ٤٦٩٩٤- قال محمد بن السائب الكلبي: أشد معصية{14}. (ز) ٤٦٩٩٥- قال محمد بن السائب الكلبي: قائدهم ورأسهم في الشَّرِّ{17}. (ز) ٤٦٩٩٦- قال مقاتل بن سليمان: <q>﴿أيهم أشد على الرحمن عتيا﴾</q>، يعني: عُتُوًّا في الكفر، يعني: القادة، فيعذبهم في النار{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٣٤.عزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ١/٢٣٥. وعزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، والبيهقي.علقه يحيى بن سلام ١/٢٣٥.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢٣٥.تفسير مقاتل بن سليمان ٢/٦٣٤.أخرجه إسحاق البستي في تفسيره ص٢٠٢. وعزاه السيوطي إلى ابن أبي حاتم، والبيهقي في البعث. كما أخرجه عبد الرزاق ٢/١٠ موقوفًا على أبي الأحوص.أخرجه ابن جرير ١٥/٥٨٨.أخرجه ابن جرير ١٥/٥٨٨. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.أخرجه عبد الرزاق ٢/١٠، وهناد (٢٥٨)، وابن جرير ١٥/٥٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٨٨-٥٨٩. وعلَّقه يحيى بن سلام ١/٢٣٥. وعزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، والبيهقي.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٢٣٥.أخرجه عبد الله بن وهب في الجامع ١/٣٧ (٧٦).علَّقه يحيى بن سلام ١/٢٣٥.تفسير الثعلبي ٦/٢٢٤، وتفسير البغوي ٥/٢٤٥.تفسير مقاتل بن سليمان ٢/٦٣٤.
19,70," <q>﴿ثُمَّ لَنَحۡنُ أَعۡلَمُ بِٱلَّذِینَ هُمۡ أَوۡلَىٰ بِهَا صِلِیࣰّا ۝٧٠﴾</q> - تفسير ٤٦٩٩٧- قال مقاتل بن سليمان: <q>﴿ثم لنحن أعلم بالذين هم أولى بها صليا﴾</q>، يعني: مَن هو أولى بها، يعني: القادة في الكفر{1}. (ز) ٤٦٩٩٨- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿ثم لنحن أعلم بالذين هم أولى بها صليا﴾</q>، يقول: أيُّهم أوْلى بالخلود في جهنم{2}٤٢٠٨. (١٠/١١٠) ٤٢٠٨ انتقد ابنُ جرير (١٥/٥٩٠) قول ابن جريج مستندًا لظاهر الآية، فقال: «وهذا الذي قاله ابن جريج قولٌ لا معنى له، لأن الله -تعالى ذِكْرُه- أخبر أن الذين ينزعهم من كل شيعة مِن الكفرة أشدهم كفرًا، ولا شك أنه لا كافر بالله إلا مخلد في النار، فلا وجه -وجميعهم مُخَلَّدون في جهنم- لأن يقال: ثم لَنحن أعلمُ بالذين هم أحقُّ بالخلود مِن هؤلاء المخلدين». ٤٦٩٩٩- قال يحيى بن سلّام: قوله: <q>﴿ثم لنحن أعلم بالذين هم أولى بها صليا﴾</q>، يعني: الذين يَصِلُونها. وقال بعضهم: أشدُّ عذابًا{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٣٤.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٢٣٧.
19,71," <q>﴿وَإِن مِّنكُمۡ إِلَّا وَارِدُهَاۚ﴾</q> - قراءات ٤٧٠٠٠- عن عبد الله بن عباس -من طريق عبد الله بن السائب، عن رجل- أنّه قرأ: (وإن مِّنْهُمْ إلّا وارِدُها). يعني: الكفار. قال: لا يَرِدُها مُؤْمِنٌ. كذا قرأها{1}. (١٠/١٢٠) ٤٧٠٠١- عن عكرمة مولى ابن عباس -من طريق عمر بن الوليد الشَّنِّيِّ- أنه قرأ: (وإن مِّنْهُمْ إلّا وارِدُها). قال: وهم الظَّلَمة. كذلك كُنّا نقرؤها{2}. (١٠/١٢٠) <q>﴿وَإِن مِّنكُمۡ إِلَّا وَارِدُهَاۚ﴾</q> - تفسير الآية ٤٧٠٠٢- عن أبي هريرة، قال: قال رسول الله ﷺ: <q>﴿وإن منكم إلا واردها﴾</q>. يقول: «مُجْتازٌ فيها»{3}. (١٠/١١٥) ٤٧٠٠٣- عن أبي أيوب، قال: قال رسول الله ﷺ: «أول مَن يختصم يوم القيامة الرجلُ وامرأتُه، وما ينطِق لسانُها ولا لسانُه، ولكن يداها ورجلاها، يشهدان عليها بما كانت تُغَيِّبُ له، ويداه ورجلاه يشهدان عليه بما كان يُولِيها، ثم يُدْعى الرجلُ وخَوَلُه وخَدَمُه كمِثل ذلك، ثم يُؤتى بأهل الأسواق، فما هي بقراريط تؤخذ منهم ولا دَوانِق، إلا حسناتُ ذا تُدْفَع إلى ذا، وسيئاتُ ذا تُدْفَع إلى ذا، ثم يُؤتى بالجبابرة في مَقامِع مِن حديد، فيُوقَفُون عند رب العالمين، فيقول: سُوقوهم إلى النار. فما أدري أيدخلونها، أو كما قال الله: <q>﴿وإن منكم إلا واردها كان على ربك حتما مقضيا﴾</q>؟»{4}. (١٠/١١٨) ٤٧٠٠٤- عن أُمِّ مُبَشِّر، قالت: قال رسول الله ﷺ: «لا يدخل النارَ أحدٌ شَهِد بدرًا والحديبية». قالت حفصة: أليس الله يقول: <q>﴿وإن منكم إلا واردها﴾</q>؟ قال: «ألم تسمعيه يقول: <q>﴿ثم ننجي الذين اتقوا﴾</q>؟»{5}. (١٠/١١٩) ٤٧٠٠٥- عن أبي هريرة، أنّ النبي ﷺ قال: «مَن مات له ثلاثةٌ مِن الوَلَد لم يَبْلُغُوا الحِنثَ لم تَمَسُّه النارُ إلا تَحِلَّة القَسَم». يعني: الورود{6}. (ز) ٤٧٠٠٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «لا يموت لمسلم ثلاثةٌ مِن الولد فيَلِجُ النارَ إلا تَحِلَّة القسم». ثم قرأ سفيان: <q>﴿وإن منكم إلا واردها﴾</q>{7}. (١٠/١١٩) ٤٧٠٠٧- عن معاذ بن أنس، عن رسول الله ﷺ، قال: «مَن حَرَسَ مِن وراء المسلمين في سبيل الله مُتَطَوِّعًا لا يأخذه سلطان؛ لم يرَ النّار بعينه إلا تَحِلَّة القَسَم، فإن الله يقول: <q>﴿وإن منكم إلا واردها﴾</q>»{8}. (١٠/١٢٠) ٤٧٠٠٨- عن أبي سُمَيَّة، قال: اختلفنا في الورود؛ فقال بعضُنا: لا يدخلها مؤمن. وقال بعضهم: يدخلونها جميعًا، ثم ينجي الله الذين اتقوا. فلقيت جابر بن عبد الله، فذكرتُ له، فقال -وأهوى بأصبعيه إلى أذنيه-: صُمَّتا إن لم أكن سمعتُ رسولَ الله ﷺ يقول: «لا يبقى برٌّ ولا فاجرٌ إلا دخلها، فتكون على المؤمن بردًا وسلامًا كما كانت على إبراهيم، حتى إنّ للنار ضجيجًا مِن بردهم، ثم يُنَجِّي الله الذين اتقوا ويذر الظالمين فيها جثيًا»{9}. (١٠/١١٣) ٤٧٠٠٩- عن أبي الزبير، قال: سألتُ جابر بن عبد الله عن الورود. فقال: سمعتُ رسول الله ﷺ يقول: «هو الدُّخُول، يَرِدُون النارَ حتى يخرجوا منها، فآخر مَن يبقى رجلٌ على الصراط يزحف، فيرفع الله -تبارك وتعالى- له شجرة، قال: فيقول: أيْ ربِّ، أدْنِني منها. قال: فيُدنيه الله -تبارك وتعالى- منها. قال: ثم يقول: أي ربِّ، أدخِلني الجنة. قال: فيدخله الجنة. قال: فيقول: سَلْ. قال: فيسأل. قال: فيقول: ذلك لك وعشرة أضعافه أو نحوها ...» الحديث{10}. (ز) ٤٧٠١٠- عن عبد الرحمن بن بشير الأنصاري، قال: قال رسول الله ﷺ: «مَن مات له ثلاثةٌ من الولد لم يبلغوا الحِنث؛ لم يَرِدِ النارَ إلا عابرَ سبيل». يعني: الجواز على الصراط{11}. (١٠/١٢٠) ٤٧٠١١- عن قيس بن أبي حازم، قال: بكى عبدُ الله بن رواحة، فقالت امرأته: ما يُبكيك؟ قال: إني أُنبِئت أنِّي واردٌ النارَ، ولم أُنبَّأ أنِّي صادِرٌ{12}. (١٠/١٢٢) ٤٧٠١٢- عن عروة بن الزبير، قال: لما أراد ابنُ رواحة الخروجَ إلى أرض مؤتة من الشام؛ أتاه المسلمون يُوَدِّعونه، فبكى، فقال: أما -واللهِ- ما بي حُبُّ الدنيا، ولا صَبابَةٌ لكم، ولكني سمعت رسول الله ﷺ قرأ هذه الآية: <q>﴿وإن منكم إلا واردها كان على ربك حتما مقضيا﴾</q>، فقد علمتُ أنِّي واردٌ النارَ، ولا أدري كيف الصدور بعد الورود؟{13}. (١٠/١٢١) ٤٧٠١٣- عن بكر بن عبد الله المزني، قال: لَمّا نزلت هذه الآية: <q>﴿وإن منكم إلا واردها﴾</q> ذهب عبدُ الله بن رواحة إلى بيته، فبكى، فجاءت المرأةُ، فبَكَت، وجاءت الخادم، فبَكَت، وجاء أهل البيت، فجعلوا يبكون، فلمّا انقطعت عبرتهم قال: يا أهلاه، ما الذي أبكاكم؟ قالوا: لا ندري، ولكن رأيناك بكيت فبكينا. قال: إنّه أُنزِلت على رسول الله ﷺ آيةٌ يُنَبِّئني فيها ربِّي -تبارك وتعالى- أنِّي واردٌ النار، ولم يُنَبِّئني أنِّي صادرٌ عنها، فذاك الذي أبكاني{14}. (١٠/١٢١) ٤٧٠١٤- عن عبد الله بن مسعود، في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: قال رسول الله ﷺ: «يَرِدُ الناسُ كلُّهم النارَ، ثم يصدرون عنها بأعمالهم، فأولهم كلمح البرق، ثم كالريح، ثم كَحُضْرِ الفرس{15}، ثم كالرّاكب في رَحْلِهِ، ثم كشَدِّ الرَّجُل، ثم كمَشْيِهِ»{16}. (١٠/١١٤) ٤٧٠١٥- عن عبد الله بن مسعود -من طريق مُرَّة- قال: يَرِد الناسُ الصراطَ جميعًا، ووُرُودُهم قيامُهم حول النار، ثم يصدرون عن الصراط بأعمالهم؛ فمِنهم مَن يَمُرُّ مثل البرق، ومنهم مَن يَمُرُّ مثل الريح، ومنهم مَن يَمُرُّ مثل الطير، ومنهم مَن يَمُرُّ كأجود الخيل، ومنهم مَن يَمُرُّ كأجود الإبل، ومنهم مَن يَمُرُّ كعَدْوِ الرجل، حتى إنّ آخرهم مرًّا رَجُلٌ نُورُه على موضع إبهام قدميه، يمر مُتَكَفِّئًا{17} به الصراط{18}. (١٠/١١٤) ٤٧٠١٦- عن عبد الله بن مسعود، - من طريق أبي الأحوص-،في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: ورودُها الصراطَ{19}. (١٠/١١٤) ٤٧٠١٧- عن عبد الله بن مسعود -من طريق مُرَّة الهمداني-: أنّه سُئِل عن قوله: <q>﴿وإن منكم إلا واردها﴾</q>. قال: وإن منكم إلا داخلُها{20}. (١٠/١١٤) ٤٧٠١٨- عن عبد الله بن مسعود -من طريق عبد الله بن السائب- في قوله: <q>﴿وإن منكم إلا واردها كان على ربك حتما مقضيا﴾</q>، قال: الكفار{21}. (ز) ٤٧٠١٩- عن عبد الله بن مسعود -من طريق أبي الأحوص- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: الصراط على جهنم مثلُ حَدِّ السيف، فتمرُّ الطبقة الأولى كالبرق، والثانية كالريح، والثالثة كأجود الخيل، والرابعة كأجود الإبل والبهائم، ثم يَمُرُّون على منازلهم، والملائكة يقولون: ربِّ، سلِّم سلِّم{22}٤٢٠٩. (١٠/١١٥) ٤٢٠٩ علَّق ابنُ كثير (٩/٢٨٢) على هذا الحديث بقوله: «ولهذا شواهد في الصحيحين وغيرهما، من رواية أنس، وأبي سعيد، وأبي هريرة، وجابر، وغيرهم من الصحابة ﵃». ٤٧٠٢٠- عن عمرو بن الحارث، أنّ بُكيرًا حدثه أنّه قال لِبُسْرِ بن سعيد: إنّ فلانًا يقول: إنّ ورود النار القيامُ عليها. قال بُسْرٌ: أما أبو هريرة فسمعته يقول: إذا كان يوم القيامة فيجتمع الناسُ نادى مُنادٍ: لِيَلْحَقَ كُلُّ أناسٍ بما كانوا يعبدون. فيقوم هذا إلى الحجر، وهذا إلى القوس، وهذا إلى الخشبة، حتى يبقى الذين يعبدون الله، فيأتيهم الله -تبارك وتعالى-، فإذا رَأَوْه قاموا إليه، فيذهب بهم، فيسلك بهم على الصراط، وفيه عُلَّيْقُ{23}، فعند ذلك يُؤذَن بالشفاعة، فيَمُرُّ الناس، والنبيون يقولون: اللهم، سَلِّم سَلِّم. قال بكير: فكان ابن عميرة يقول: فناج مُسَلَّم، ومُكَدَّسٌ{24} في جهنم، ومخدوش ثم ناجٍ{25}. (ز) ٤٧٠٢١- عن عبد الله بن عباس -من طريق عكرمة- في الآية، قال: لا يبقى أحدٌ إلا دَخَلَها{26}. (١٠/١١٤) ٤٧٠٢٢- عن عمرو بن دينار، قال: أخبرني مَن سمع عبد الله بن عباس يُخاصِم نافعَ بن الأزرق، فقال ابن عباس: الورود: الدخول. وقال نافع: لا. فقرأ ابنُ عباس: <q>﴿إنكم وما تعبدون من دون الله حصب جهنم أنتم لها واردون﴾</q> [الأنبياء:٩٨]، وقال: وردوا أم لا؟ وقرأ: <q>﴿يقدم قومه يوم القيامة فأوردهم النار﴾</q> [هود:٩٨]، أوَردوا أم لا؟ أما أنا وأنت فسندخلها، فانظر هل نخرج منها أم لا؟ وما أرى اللهَ مُخْرِجَك منها لتكذيبك. قال: فضحك نافع، فقال ابن عباس: ففيم الضَّحِكُ إذًا؟!{27}. (١٠/١١٣) ٤٧٠٢٣- عن مرزوق بن أبي سلامة، قال: قال نافع بن الأزرق لعبد الله بن عباس: ما الورود؟ قال: الدخول. قال: لا، الوُرود: الوُقوف على شَفِيرِها. فقال: ويحك! أما تقرأ كتاب الله: <q>﴿وما أمر فرعون برشيد. يقدم قومه يوم القيامة فأوردهم النار﴾</q> [هود:٩٧-٩٨]؟ أفَتَراه -ويحك- إنّما أوقفهم على شفيرها، والله تعالى يقول: <q>﴿ويوم تقوم الساعة أدخلوا آل فرعون أشد العذاب﴾</q> [غافر:٤٦]؟!{28}. (١٠/١١٧) ٤٧٠٢٤- عن عبد الله بن عباس -من طريق الضحاك- قال: الورود في القرآن أربعة؛ في هود [٩٨]: <q>﴿وبئس الوِرد المَورُود﴾</q>، وفي مريم [٧١]: <q>﴿وإن منكم إلا واردها﴾</q>، وفيها [٨٦] أيضًا: <q>﴿ونسُوقُ المجرمين إلى جهنم وِردًا﴾</q>، وفي الأنبياء [٩٨]: <q>﴿حصب جهنم أنتم لها وارِدُون﴾</q>. قال: كل هذا الدخول. كان ابن عباس يقول: كل هذا الدخول، واللهِ، لَيَرِدَنَّ جهنمَ كلُّ برٍّ وفاجر، <q>﴿ثم ننجي الذين اتقوا ونذر الظالمين فيها جثيا﴾</q>{29}. (٨/١٣٥) ٤٧٠٢٥- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: يَرِدُها البَرُّ والفاجر، ألم تسمع قوله: <q>﴿فأوردهم النار وبئس الورد المورود﴾</q> [هود:٩٨]، وقوله: <q>﴿ونسوق المجرمين إلى جهنم وردا﴾</q>؟ [مريم:٨٦]{30}. (١٠/١١٣) ٤٧٠٢٦- عن عبد الله بن عباس -من طريق أبي عبيد مولى ابن عباس- أنّ عمر لَمّا طُعِن قال: واللهِ، لو أنّ لي ما على الأرض مِن شيء لافتديتُ به مِن هول المَطْلَع. فقال ابن عباس: فقلت له: واللهِ، إنِّي لأرجو ألا تراها إلا مقدار ما قال الله: <q>﴿وإن منكم إلا واردها﴾</q>{31}. (١٠/١١٨) ٤٧٠٢٧- عن أبي الزبير، أنّه سمع جابر بن عبد الله يُسْأَل عن الورود. فقال: نحن يوم القيامة على كوى أو كدى فوق الناس{32}، فتُدْعى الأمم بأوثانها وما كانت تَعْبُدُ الأولَ فالأولَ، فينطلق بهم، ويتبعونه. قال: ويُعْطى كلُّ إنسانٍ منافقٌ ومؤمنٌ نورًا، وتَغْشى ظلمةٌ، ثم يتبعونه، وعلى جسر جهنم حَسَك{33} وكلاليب تأخذ مَن شاء الله، فيطفأ نور المنافق، وينجو المؤمنون، فتنجو أولُ زمرةٍ كالقمر ليلة البدر، وسبعون ألفًا لا حساب عليهم، ثم الذين يلونهم كأَضْوَإ نجم في السماء، ثم كذلك، ثم تحل الشفاعة فيشفعون، ويخرج من النار مَن قال: «لا إله إلا الله» مِمَّن في قلبه وزنُ شعيرة مِن خير، ثُمَّ يلقون تلقاء الجنة، ويُهَرِيقُ عليهم أهلُ الجنة الماء، فينبتون نبات الشيء في السيل، ثم يسألون فيجعل لهم الدنيا وعشرة أمثالها{34}. (ز) ٤٧٠٢٨- عن الحسن البصري، قال: كان أصحابُ رسول الله ﷺ إذا التَقَوْا يقول الرجل لصاحبه: هل أتاك أنّك وارد؟ فيقول: نعم. فيقول: هل أتاك أنّك خارج؟ فيقول: لا. فيقول: ففيم الضحك إذن؟!{35}. (١٠/١٢٢) ٤٧٠٢٩- عن أبي العوام، قال: قال كعب الأحبار: هل تدرون ما قوله: <q>﴿وإن منكم إلا واردها﴾</q>؟ قالوا: ما كنا نرى ورودَها إلا دخولَها. قال: لا، ولكن ورودُها أن يُجاء بجهنم كأنها مَتْنُ إهالَةٍ{36}، حتى إذا استوت عليها أقدام الخلائق برِّهم وفاجرِهم ناداها منادٍ: خذي أصحابك، وذَرِي أصحابي. فيخسف بكل ولِيِّ لها، لَهِيَ أعلمُ بهم مِن الوالد بولده، وينجو المؤمنون نَدِيَّةً ثيابُهم. قال: وإنّ الخازِن مِن خَزَنَةِ جهنم ما بين منكبيه مسيرةُ سنة، معه عمودٌ مِن حديد له شُعْبَتان، يدفع الدفعة فيَكُبُّ في النار تسعمائة ألف. أو كما قال{37}. (١٠/١١٧) ٤٧٠٣٠- عن أبي الجَلْد [جيلان بن أبي فروة] -من طريق أبي عمران الجوني- قال: تكون الأرض يومًا نارًا، فماذا أعددتم لها؟ قال: فذلك قول الله: <q>﴿وإن منكم إلا واردها كان على ربك حتما مقضيا ثم ننجي الذين اتقوا ونذر الظالمين فيها جثيا﴾</q>{38}. (ز) ٤٧٠٣١- عن أبي ميسرة [عمرو بن شرحبيل الهمداني] -من طريق أبي إسحاق- أنّه أوى إلى فراشه، فقال: يا ليت أُمِّي لم تلِدْني. فقالت امرأته: يا أبا ميسرة، إنّ الله قد أحسن إليك؛ هداك إلى الإسلام. فقال: أجل، ولكن الله قد بيَّن لنا أنّا واردو النارِ، ولم يُبَيِّن لنا أنّا صادِرون عنها{39}. (١٠/١٢٢) ٤٧٠٣٢- عن عبيد بن عمير، قال: حضورها: ورودها{40}٤٢١٠. (١٠/١١٧) ٤٢١٠ علَّق ابنُ عطية (٦/٥٧) على قول عبيد بقوله: «ومنه قوله تعالى: <q>﴿ولَمّا ورَدَ ماءَ مَدْيَنَ﴾</q> [القصص:٢٣]». ٤٧٠٣٣- عن خالد بن معدان -من طريق بكار بن أبي مروان- قال: إذا دخل أهلُ الجنةِ الجنةَ قالوا: ربَّنا، ألم تَعِدْنا أنّا نَرِدُ النارَ؟ قال: بلى، ولكنكم مررتم عليها وهي خامدة{41}. (١٠/١١٦) ٤٧٠٣٤- عن مجاهد بن جبر -من طريق مسلم الأعور- قال: يعني: داخلها{42}. (ز) ٤٧٠٣٥- عن مجاهد بن جبر قال: الحُمّى في الدنيا حَظُّ المؤمن مِن الورود في الآخرة{43}٤٢١١. (١٠/١٢٢) ٤٢١١ علَّق ابنُ عطية (٦/٥٨-٥٩) على هذا القول بقوله: «وفي الحديث: «الحُمّى حظُّ كلِّ مؤمن من النار»». ٤٧٠٣٦- عن مجاهد بن جبر -من طريق عثمان بن الأسود- قال: الحُمّى حظُّ كُلِّ مؤمن من النار، ثم قرأ: <q>﴿وإن منكم إلا واردها كان على ربك حتما مقضيا﴾</q>. والورود في الدنيا هو الورود في الآخرة{44}. (١٠/١٢٢) ٤٧٠٣٧- عن عكرمة مولى ابن عباس -من طريق السدي- في الآية، قال: الصراط على جهنم يَرِدُون عليه{45}. (١٠/١١٦) ٤٧٠٣٨- عن عكرمة مولى ابن عباس -من طريق يزيد النَّحْوِيّ- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: الدخول{46}. (١٠/١٢٣) ٤٧٠٣٩- قال عكرمة مولى ابن عباس -من طريق عمر بن الوليد-: يعني: الكفار، لا يَرِدُها مؤمن{47}. (ز) ٤٧٠٤٠- عن أبي نَضْرَة [المنذر بن مالك العبدي]، في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: يحملون على الصراط إلى جهنم، وهي كأنها مَتْنُ إهالَة، فتميل بهم، فيقول الله لجهنم: خذي أصحابك، ودعي أصحابي. فيخسف بهم الصراط، وينجو المؤمنون، وهو قول الله: <q>﴿فاستبقوا الصراط فأنى يبصرون﴾</q> [يس:٦٦]{48}. (١٠/١١٦) ٤٧٠٤١- عن الحسن البصري -من طريق المُبارَكِ بن فَضالَة- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: الورود: المَمَرُّ عليها مِن غير أن يدخلها{49}. (١٠/١١٦) ٤٧٠٤٢- عن الحسن البصري -من طريق عمرو- قال: <q>﴿وإن منكم إلا واردها﴾</q> إلا داخلها، فيجعلها الله على المؤمن بردًا وسلامًا، كما جعلها على إبراهيم{50}. (ز) ٤٧٠٤٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، قال: هو المَمَرُّ عليها{51}. (١٠/١١٦) ٤٧٠٤٤- عن زيد بن أسلم -من طريق حفص-: يقول الله: <q>﴿ثم لننزعن من كل شيعة أيهم أشد على الرحمن عتيا﴾</q> المكذبين بالبعث، <q>﴿وإن منكم﴾</q> يا أهل هذا القول <q>﴿إلا واردها كان على ربك حتما مقضيا﴾</q>{52}. (ز) ٤٧٠٤٥- عن ابن أبي ليلى، أنه كان يقول: الورود: الدخول{48}. (١٠/١٢٤) ٤٧٠٤٦- قال مقاتل بن سليمان: <q>﴿وإن منكم إلا واردها﴾</q>، يعني: وما منكم أحدٌ إلا داخلها، يعني: جهنم، البر والفاجر، ... يجعل الله النار على المؤمنين يومئذ بردًا وسلامًا، كما جعلها على إبراهيم ﵇، فذلك قوله ﷿: <q>﴿كان على ربك حتما مقضيا﴾</q>{54}. (ز) ٤٧٠٤٧- قال عبد الملك ابن جُرَيْج -من طريق حجاج-: يقول: الوُرود الذي ذكره الله في القرآن: الدخول. لَيَرِدَنَّها كلُّ برٍّ وفاجر، في القرآن أربعة أوراد: <q>﴿فأوردهم النار﴾</q> [هود:٩٨]، <q>﴿حصب جهنم أنتم لها واردون﴾</q> [الأنبياء:٩٨]، <q>﴿ونسوق المجرمين إلى جهنم وردا﴾</q> [مريم:٨٦]، <q>﴿وإن منكم إلا واردها﴾</q>{55}. (ز) ٤٧٠٤٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>: ورود المسلمين: المرور على الجسر بين ظهريها. وورود المشركين: أن يدخلوها. قال: وقال النبي ﷺ: «الزالُّون والزالّات يومئذ كثير، وقد أحاط بالجسر سِماطان{56} مِن الملائكة، دعواهم يومئذ: يا الله، سلِّم سلِّم»{57}٤٢١٢. (١٠/ ١١٧) ٤٢١٢ اختُلِف في المعنيّ بالخطاب في قوله: <q>﴿وإن منكم إلا واردها﴾</q> على قولين: الأول: عامٌّ للمؤمنين والكافرين. الثاني: خاصٌّ بالكافرين. واختُلِف في الورود على أقوال: الأول: الدخول. الثاني: الحضور. الثالث: ورود المسلمين: المرور على الجسر، وورود المشركين: دخولها. الرابع: ورود المؤمن إليها: ما يصيبه من الحمّى في الدنيا. الخامس: الممر عليها، ثم يصدر الناس بأعمالهم. ورجَّح ابنُ جرير (١٥/٦٠١) مستندًا إلى السنة القولَ الأخير الذي قاله ابن مسعود من طريق مُرَّة، وابن عباس من طريق مجاهد، وجابر بن عبدالله، والحسن من طريق المبارك، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: يَرِدُها الجميعُ ثم يصدر عنها المؤمنون، فينجيهم الله، ويهوي فيها الكفار. وورودُهموها: هو ما تظاهرت به الأخبار عن رسول الله ﷺ من مرورهم على الصراط المنصوب على متن جهنم، فناجٍ مُسَلَّم، ومُكَدَّس فيها». ٤٧٠٤٩- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿وإن منكم إلا واردها﴾</q>، فقال: يرِدُونها وهي خامدة، فينجي الله <q>﴿الذين اتقوا ونذر الظالمين فيها جثيا﴾</q>{58}. (ز) ٤٧٠٥٠- قال يحيى بن سلّام: قوله: <q>﴿وإن منكم إلا واردها كان على ربك حتما مقضيا﴾</q>، يعني: قَسَمًا كائنًا{59}٤٢١٣. (ز) ٤٢١٣ ذكر ابنُ عطية (٦/٥٧) قولًا أنّ الورود نُسِخ بقوله: <q>﴿إنَّ الَّذِينَ سَبَقَتْ لَهُمْ مِنّا الحُسْنى أُولئِكَ عَنْها مُبْعَدُونَ﴾</q> [الأنبياء:١٠١]، وانتقده، فقال: «وهذا ضعيف، وليس هذا موضع نسخ». <q>﴿وَإِن مِّنكُمۡ إِلَّا وَارِدُهَاۚ﴾</q> - آثار متعلقة بالآية ٤٧٠٥١- عن أبي هريرة، قال: خرج رسول الله صلى الله علية وسلم يعود رجلًا مِن أصحابه وعِكًا، وأنا معه، فقال: «إنّ الله يقول: هي ناري، أُسَلِّطها على عبدي المؤمن؛ لتكون حظَّه مِن النار في الآخرة»{60}. (١٠/١٢٣) ٤٧٠٥٢- عن يعلى ابن مُنْيَة، عن النبي ﷺ، قال: «تقول النار للمؤمن يوم القيامة: جُزْ، يا مؤمن، فقد أطفأ نورُك لهبي»{61}. (١٠/١١٩) ٤٧٠٥٣- عن أبي سعيد الخدري، أنّ رسول الله ﷺ قال: «يُؤتى بالجسر، فيجعل بين ظهري جهنم». قلنا: يا رسول الله، وما الجسر؟ قال: «مَدْحَضَةٌ مَزِلَّةٌ، عليه خطاطيف وكلاليب، وحسكة مفلطحة لها شوكة عُقَيْفاءُ، تكون بنجد، يقال لها: السَّعدان، المؤمن عليها كالطرف، وكالبرق، وكالريح، وكأجاويد الخيل، والركاب، فناجٍ مُسَلَّم، وناجٍ مَخْدُوش، ومَكْدُوس في نار جهنم، حتى يَمُرَّ آخرُهم يسحب سَحْبًا، فما أنتم بأشدَّ لي مناشدة في الحق، قد تبين لكم مَن المؤمن يومئذ للجبار، وإذا رأوا أنّهم قد نجوا في إخوانهم يقولون: ربَّنا، إخواننا، كانوا يُصَلُّون معنا، ويصومون معنا، ويعملون معنا. فيقول الله تعالى: اذهبوا، فمَن وجدتم في قلبه مثقالَ دينار من إيمان فأخرجوه. ويُحَرِّم اللهُ صُورَهم على النار، فيأتونهم وبعضُهم قد غاب في النار إلى قدمه، وإلى أنصاف ساقيه، فيُخْرِجون مَن عرفوا، ثم يعودون، فيقول: اذهبوا، فمَن وجدتم في قلبه مثقالَ نصف دينار فأخرِجوه. فيُخْرِجون مَن عرفوا، ثم يعودون، فيقول: اذهبوا، فمَن وجدتم في قلبه مثقالَ ذرَّةٍ مِن إيمان فأخرِجوه. فيُخْرِجون مَن عرفوا -قال أبو سعيد: فإن لم تُصَدِّقوني فاقرءوا: <q>﴿إن الله لا يظلم مثقال ذرة وإن تك حسنة يضاعفها﴾</q> [النساء:٤٠]-، فيَشْفَعُ النبيون والملائكة والمؤمنون، فيقول الجبار: بقيت شفاعتي. فيقبض قبضة من النار، فيخرج أقوامًا قد امتُحِشوا{62}، فيُلْقَون في نهرٍ بأفواه الجنة يُقال له: ماء الحياة، فينبتون في حافتيه كما تنبت الحبَّة في حَمِيل السَّيْل، قد رأيتموها إلى جانب الصخرة، وإلى جانب الشجرة، فما كان إلى الشمس منها كان أخضر، وما كان منها إلى الظِّلِّ كان أبيض، فيخرجون كأنهم اللؤلؤ، فيجعل في رقابهم الخواتيم، فيدخلون الجنة، فيقول أهل الجنة: هؤلاء عتقاء الرحمن، أدخلهم الجنةَ بغير عمل عملوه، ولا خيرٍ قدَّموه. فيُقال لهم: لكم ما رأيتم ومثلُه معه»{63}. (ز) ٤٧٠٥٤- عن المغيرة، قال: قال رسول الله ﷺ: «شعارُ المسلمين على الصراط يوم القيامة: اللهم، سلِّم سلِّم»{64}. (١٠/١١٥) ٤٧٠٥٥- عن الحسن البصري، قال: قال رجل لأخيه: يا أخي، هل أتاك أنّك واردٌ النارَ؟ قال: نعم. قال: فهل أتاك أنّك خارجٌ منها؟ قال: لا. قال: ففيم الضحك؟! فما رُئِي ضاحكًا حتى مات{65}. (١٠/١٢٢) <q>﴿كَانَ عَلَىٰ رَبِّكَ حَتۡمࣰا مَّقۡضِیࣰّا ۝٧١﴾</q> - تفسير ٤٧٠٥٦- عن عبد الله بن مسعود -من طريق مرة الهمداني- <q>﴿كان على ربك حتما مقضيا﴾</q>، قال: قَسَمًا واجِبًا{66}. (ز) ٤٧٠٥٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿حتما مقضيا﴾</q>. قال: الحَتْمُ: الواجب. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أُمَيَّة بن أبي الصلت وهو يقول: عبادك يخطئون وأنت ربٌّ بكفيك المنايا والحُتُوم؟{67}. (١٠/١٢٤) ٤٧٠٥٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿حتما مقضيا﴾</q>، قال: قضاء مِن الله{68}. (١٠/١٢٣) ٤٧٠٥٩- عن عكرمة مولى ابن عباس -من طريق يزيد النَّحْويِّ- في قوله: <q>﴿كان على ربك حتما مقضيا﴾</q>، قال: قَسَمًا واجبًا{69}. (١٠/١٢٣) ٤٧٠٦٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿كان على ربك حتما مقضيا﴾</q>، يقول: قَسَمًا واجبًا{66}. (ز) ٤٧٠٦١- عن مقاتل بن سليمان: <q>﴿كان على ربك حتما مقضيا﴾</q>، قال: قضاءً واجبًا قد قضاه في اللوح المحفوظ أنّه كائن لا بُدَّ، غير الأنبياء ﵈، فتكون على المؤمنين بردًا وسلامًا{71}. (ز) ٤٧٠٦٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿حتما مقضيا﴾</q>، قال: قضاء{72}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٥٩٦. وعزاه السيوطي إلى ابن أبي حاتم، وابن الأنباري، والبيهقي في البعث. وهي قراءة شاذة، تروى أيضًا عن عكرمة. انظر: مختصر ابن خالويه ص٨٩.أخرجه ابن جرير ١٥/٥٩٦، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٤٨- واللفظ له. وعند ابن جرير: يعني الكفار، لا يَرِدُها مؤمن.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي الدنيا في كتاب الأهوال ص١٦٥ (١٩٧)، والطبراني في الكبير ٤/١٤٨ (٣٩٦٩)، وفيه عبد الله بن عبد العزيز. قال العقيلي في الضعفاء ٢/٢٧٦ بعد سياقه لهذه الرواية مع رواية أخرى مرسلة للزهري: «قال لي عبد الله بن علي، قال محمد بن يحيى: الحديثان منكران جميعًا، والحمل فيهما على عبد الله بن عبد العزيز، وهو ضعيف الحديث». وقال ابن الجوزي في العلل المتناهية ٢/١٦٠-١٦١ (١٠٧٦): «قال النيسابوري: حديث منكر، والحمل فيه على عبد الله بن عبد العزيز». وقال الذهبي في ميزان الاعتدال ٢/٤٥٥ (٤٤٢٥) عن الحديث: «باطل». وقال الهيثمي في المجمع ١٠/٣٤٩ (١٨٣٨٨): «وفيه عبد الله بن عبد العزيز الليثي، وهو ضعيف، وقد وثَّقه سعيد بن منصور، وقال: كان مالك يرضاه، وبقية رجاله رجال الصحيح». وقال السيوطي في الدر ١٢/٦٥٩: «بسند لا بأس به».أخرجه أحمد ٤٤/٥٩٠ (٢٧٠٤٢)، وابن حبان ١١/١٢٥ (٤٨٠٠)، وابن جرير ١٥/٦٠١. وأخرجه مسلم ٤/١٩٤٢ (٢٤٩٦) بنحوه.أخرجه أحمد ١٣/١٥٥ (٧٧٢١)، وعبد الرزاق ٢/٣٦٠ (١٧٧٨)، وابن جرير ١٥/٦٠٥، من طريق معمر، أخبرني الزهري، عن ابن المسيب، عن أبي هريرة به. إسناده صحيح.أخرجه البخاري ٢/٧٣ (١٢٥١)، ومسلم ٤/٢٠٢٨ (٢٦٣٢)، والثعلبي ٦/٢٢٦. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه أحمد ٢٤/٣٧٩ (١٥٦١٢)، وابن جرير ١٥/٦٠٤-٦٠٥. قال ابن القيسراني في ذخيرة الحفاظ ٤/٢٢٦٤ (٥٢٥٧): «رواه رشدين بن سعد، عن زبان بن فائد، عن سهل بن معاذ، عن أبيه. ورشدين ليس بشيء». وقال المنذري في الترغيب والترهيب ٢/١٥٩ (١٩١٩): «رواه أحمد، وأبو يعلى، والطبراني، ولا بأس بإسناده في المتابعات». وقال الهيثمي في المجمع ٥/٢٨٧ (٩٤٨٧): «رواه أحمد، وأبو يعلى، والطبراني، وفي أحد إسنادي أحمد ابن لهيعة، وهو أحسن حالًا من رشدين».أخرجه أحمد ٢٢/٣٩٦-٣٩٧ (١٤٥٢٠)، والثعلبي ٦/٢٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. قال المنذري في الترغيب والترغيب ٤/٢٣١ (٥٤٩١): «ورواته ثقات». وقال ابن كثير في تفسيره ٥/٢٥٢: «غريب، ولم يخرجوه». وقال في البداية والنهاية ٢٠/٩٦: «لم يخرجوه في كتبهم، وهو حسن». وقال الهيثمي في المجمع ٧/٥٥ (١١١٥٩): «ورجاله ثقات». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢٠٧ (٧٧٩٦): «مدار أسانيدهم على أبي سمية، وهو مجهول». وقال القسطلاني في المواهب اللدنية ٣/٦٦٧: «رواه أحمد، والبيهقي، بإسناد حسن». وقال الألباني في الضعيفة ١٠/٣٠٤ (٤٧٦١): «ضعيف».أخرجه ابن منده في الإيمان ٢/٨٢٥، وابن جرير ١٥/٦٠٤، من طريق روح بن عبادة، عن ابن جريج، قال: أخبرني أبو الزبير، قال: سمعت جابرًا يقول ... وذكره. إسناده صحيح.أخرجه أبو نعيم في معرفة الصحابة ٤/١٨٤٢ (٤٦٤٧). قال المنذري في الترغيب والترهيب ٣/٥٥ (٣٠٥٥): «رواه الطبراني بإسناد لا بأس به، وله شواهد كثيرة». وقال الهيثمي في المجمع ٣/٦ (٣٩٧٦) بعد عزوه للطبراني: «ورجاله موثقون، خلا شيخ الطبراني أحمد بن مسعود المقدسي، ولم أجد مَن تَرْجَمَهُ».أخرجه ابن المبارك (٣١٠)،، وابن أبي شيبة ١٣/٣٥٧، وأحمد في الزهد ص٢٠٠، وهناد ابن السري في الزهد (٢٢٧)، والحاكم ٤/٥٨٨. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، والبيهقي في البعث.أخرجه أبو نعيم في الحلية ١/١١٨، والبيهقي في الدلائل ٤/٣٥٨-٣٥٩، وابن عساكر في تاريخ دمشق ٢٨/١٢٣. وهو عند الطبري بسياق آخر.أخرجه ابن المبارك (٣٠٩)، وابن عساكر ٢٨/١٠٦. وعزاه السيوطي إلى أحمد في الزهد. كما أخرج عبد الرزاق ٢/١٠-١١ نحوه مختصرًا من طريق إسماعيل عن قيس.حُضْر الفرس: عَدْوُ الفرس. لسان العرب (حضر).أخرجه الترمذي ٥/٣٨٠ (٣٤٢٨)، والحاكم ٢/٤٠٧ (٣٤٢١)، ٤/٦٢٩ (٨٧٤١)، وأخرجه أحمد ٧/٢٠٦-٢٠٧ (٤١٤١) مختصرًا. قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وأورده الألباني في الصحيحة ١/٦٢٠ (٣١١).مُتَكَفِّئًا: متمايلًا. تاج العروس (كفأ).أخرجه يحيى بن سلام ١/٢٣٧ بنحوه، وابن جرير ١٥/٥٩٨ مختصرًا، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٤٩-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.أخرجه هناد (٢٣٢)، والطبراني (٩٠٨٤، ٩١٢١).أخرجه ابن جرير ١٥/٥٩٤، والحاكم ٤/٥٨٧، وأخرجه إسحاق البستي في تفسيره ص٢٠٦ بلفظ: يردونها ثم يصدرون عنها بأعمالهم.أخرجه إسحاق البستي في تفسيره ص٢٠٧.أخرجه يحيى بن سلام ١/٢٣٧، وابن جرير ١٥/٥٩٥، والحاكم ٢/٣٧٥-٣٧٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.العُلَّيْقُ: نبات يتعلَّق بالشجر ويَلْتَوي عليه. وقال أبو حنيفة: العُلَّيق: شجر من شجر الشوك لا يَعْظُم، وإذا نَشِب فيه شيء لم يكد يتخلَّص من كثرة شوكه، وشَوكُه حُجَز شداد. قال: ولذلك سمِّي عُلَّيْقًا. لسان العرب (علق).تَكَدَّسَ الإنسان: إذا دُفِعَ مِن ورائه فسَقَط. تاج العروس (كدس).أخرجه ابن جرير ١٥/٦٠٠.أخرجه ابن جرير ١٥/٥٩٤ من طريق مجاهد. وعزاه السيوطي إلى البيهقي في البعث.أخرجه يحيى بن سلام ١/٢٣٧ بنحوه، وعبد الرزاق ٢/١١، وهناد (٢٢٩) من طريق مجاهد مختصرًا، وابن جرير ١٥/٥٩٠-٥٩١ كذلك من طريق عمرو بن دينار، قال: أخبرني مَن سمع ابنَ عباس يُخاصم نافع بن الأزرق، وإسحاق البستي في تفسيره ص٢٠٤-٢٠٥، وابن أبي حاتم ٦/٢٠٨٠ مختصرًا. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، والبيهقي في البعث. كما أخرج آخره ابن جرير ١٥/٥٩٨ من طريق مجاهد. وأورده مقاتل بن سليمان في تفسيره ٢/٦٣٥.عزاه السيوطي إلى ابن الأنبارى في المصاحف.أخرجه ابن جرير ١٢/٥٦٣، وابن أبي حاتم ٦/٢٠٨١ مختصرًا. كما أخرجه مقاتل بن سليمان في تفسيره ٢/٦٣٥، وذكر فيه قوله تعالى: <q>﴿لو كان هؤلاء آلهة ما وردوها﴾</q> بدل <q>﴿ونسُوقُ المجرمين إلى جهنم وِردًا﴾</q>.أخرجه ابن جرير ١٥/٥٩٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن سعد ٣/٣٥٢.قال القاضي عياض في تعليقه على نحو هذه الجملة في شرحه لصحيح مسلم إكمال المعلم ١/٣٧٠: «هذه صورة الحديث في جميع النسخ، وفيه تغيير كثير، وتصحيف». قال: «وصوابه: نجيء يوم القيامة على كوم. هكذا رواه بعض أهل الحديث، وفي كتاب ابن أبي خيثمة من طريق كعب بن مالك: يحشر الناس يوم القيامة على تَلٍّ، وأمتي على تل. وذكر الطبري في التفسير من حديث ابن عمر: فيرقى هو -يعني: محمدًا ﷺ- وأمته على كوم فوق الناس. وذكر من حديث كعب بن مالك: يحشر الناس يوم القيامة فأكون أنا وأمتي على تل. قال القاضي: فهذا كله يبين ما تغير من الحديث، وأنه كان أظلم هذا الحرف على الراوي أو امَّحى فعبَّر عنه بكذا وكذا، وفسره بقوله: أي: فوق الناس. وكتب عليه: انظر تنبيهًا. فجمع النقلة الكل، ونسقوه على أنه من متن الحديث، كما تراه». نقله النووي في شرحه لصحيح مسلم ٣/٤٧، ثم قال: «هذا كلام القاضي، وقد تابعه عليه جماعة من المتأخرين».الحَسَكُ: نبات له ثمرة خشنة تَعْلَقُ بأَصواف الغنم. لسان العرب (حسك).أخرجه ابن جرير ١٥/٥٩٩.أخرجه ابن أبي شيبة ١٣/٥٠٠.مَتْنُ إهالة: أي: ظَهْرُها. والإهالَة: ما أذَبْتَ من الشحم. لسان العرب (أهل).أخرجه ابن أبي شيبة ١٣/١٦٩، وابن جرير ١٥/٥٩٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٩٣، وأبو نعيم في حلية الأولياء ٦/٥٥.أخرجه ابن المبارك (٣١٢)، وهناد (٢٢٨)، وابن جرير ١٥/٥٩٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ١٣/٥٦١، وهناد (٢٣١)، وابن جرير ١٥/٥٩٢، والحكيم الترمذي -كما في تخريج أحاديث الكشاف ٢/٣٣٢-، وإسحاق البستي في تفسيره من طريق ثور ص٢٠٢. وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري في المصاحف.تفسير مجاهد ص٤٥٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي الدنيا في كتاب المرض والكفارات -موسوعة ابن أبي الدنيا ٤/٢٢٩ (٢٠)-، وابن جرير ١٥/٥٩٧. وعزاه السيوطي إلى ابن المنذر. وأخرجه البيهقي في شعب الإيمان (٣٧٤) بلفظ: مَن حُمَّ من المسلمين فقد وردها.أخرجه هناد في الزهد (٢٣٣). وعزاه السيوطي إلى عبد بن حميد.أخرجه الخطيب في تالي التلخيص (١٤٤).أخرجه ابن جرير ١٥/٥٩٦.عزاه السيوطي إلى ابن الأنباري.عزاه السيوطي إلى عبد بن حميد، وابن الأنبارى، والبيهقي في البعث.أخرجه يحيى بن سلام ١/٢٣٨.أخرجه عبد الرزاق ٢/١٠، وابن جرير ١٥/٥٩ من طريق سعيد أيضًا. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٣٧ (٧٦).عزاه السيوطي إلى ابن الأنباري.تفسير مقاتل بن سليمان ٢/٦٣٥-٦٣٦.أخرجه ابن جرير ١٥/٥٩١.سماطان: صفّان. لسان العرب (سمط).أخرجه ابن جرير ١٥/٥٩٦-٥٩٧.أخرجه إسحاق البستي في تفسيره ص٢١٠.تفسير يحيى بن سلام ١/٢٣٧.أخرجه أحمد ١٥/٤٢٢ (٩٦٧٦)، وابن ماجه ٤/٥٢١ (٣٤٧٠)، والحاكم ١/٤٩٦ (١٢٧٧)، وابن جرير ١٥/٥٩٧. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال النووي في خلاصة الأحكام ٢/٩١٣-٩١٤ (٣٢٣٨): «رواه البيهقي بإسناد حسن». وقال ابن كثير في تفسيره ٥/٢٥٥ تعليقًا على رواية ابن جرير: «غريب، ولم يخرجوه من هذا الوجه». وقال في البداية والنهاية ٢٠/٩٤: «وهذا إسناد حسن». وقال البوصيري في مصباح الزجاجة ٤/٦١ (٩٠٢١): «هذا إسناد صحيح، رجاله موثقون». وأورده الألباني الصحيحة ٢/٩٨ (٥٥٧).أخرجه الطبراني في الكبير ٢٢/٢٥٨-٢٥٩ (٦٦٨)، والبيهقي في الشعب ١/٥٧٧-٥٧٨ (٣٦٩). وأورده الثعلبي ٦/٢٢٧. قال البيهقي: «تفرَّد به سليم بن منصور، وهو منكر». وقال ابن كثير في البداية والنهاية ٢٠/٩٧: «هذا حديث غريب جدًّا». وقال ابن رجب في التخويف من النار ص٢٥٣: «غريب، وفيه نكارة». وقال الهيثمي في المجمع ١٠/٣٦٠ (١٨٤٤٦): «فيه سليم بن منصور بن عمار، وهو ضعيف». وقال السخاوي في المقاصد الحسنة ص٢٦٢ (٣٤٤): «في سنده منصور بن عمار الواعظ الشهير، قال أبوحاتم: إنه ليس بالقوي. وقال ابن عدي: منكر الحديث. وأورد له هذا الحديث في كامله، وهو مع ذلك منقطع بين خالد ويعلى، وأرجو أن يكون صحيحًا». وقال المناوي في التيسير ١/٤٥٥: «فيه ضعف وانقطاع». وقال الألباني في الضعيفة ٧/٤٢١ (٣٤١٣): «ضعيف».امتحشوا -بضم المثناة وكسر الحاء على ما لم يسم فاعله، وضبطه الأصيلي بفتحهما-: يقال: محشته النار: أي أحرقته، والمحش: احتراق الجلد، وظهور العظم. وقال الداودي معناه: انقبضوا واسودوا. فتح الباري ١/١٨٦.أخرجه البخاري ٩/١٢٩-١٣١ (٧٤٣٩)، ومسلم ١/١٦٧ (٣٠٢)، وابن جرير ١٥/٦٠٣-٦٠٤.أخرجه الترمذي ٤/٤٢٩ (٢٦٠١)، والحاكم ٢/٤٠٧ (٣٤٢٢)، وفيه عبد الرحمن بن إسحاق. قال الترمذي: «هذا حديث غريب من حديث المغيرة بن شعبة، لا نعرفه إلا من حديث عبد الرحمن بن إسحاق». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن حبان في كتاب المجروحين ٢/٥٤-٥٥ (٥٩٢) في ترجمة عبد الرحمن بن إسحاق: «كان مِمَّن يقلب الأخبار والأسانيد، وينفرد بالمناكير عن المشاهير، لا يَحِلُّ الاحتجاج بخبره». وقال ابن القيسراني في تذكرة الحفاظ ص٢١٢ (٥٠٨): «رواه عبد الرحمن بن إسحاق الواسطي، وهو الذي يُقال له: عباد بن إسحاق، عن النعمان بن سعد، عن المغيرة بن شعبة، وعبد الرحمن هذا مُنكَر الحديث عن الثقات، وقال أحمد بن حنبل: ليِّن الحديث. ورضي القول فيه يحيى بن معين». وقال ابن الجوزي في العلل المتناهية ٢/٤٣٤ (١٥٣١): «هذا حديث لا يصح». وقال الألباني في الضعيفة ٤/٤٤١ (١٩٧٣): «ضعيف».أخرجه ابن المبارك في الزهد (٣١١).أخرجه ابن جرير ١٥/٦٠٦.أخرجه ابن الأنباري في الوقف والابتداء ١/٩٧ (١١٦)، والطستي -كما في الإتقان ٢/٩٦-.أخرجه ابن جرير ١٥/٦٠٥، وإسحاق البستي في تفسيره ص٢٠٨ من طريق ابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الخطيب في تالي التلخيص ١/٢٥٦ (١٤٤).أخرجه ابن جرير ١٥/٦٠٦.تفسير مقاتل بن سليمان ٢/٦٣٦.أخرجه ابن جرير ١٥/٦٠٥.
19,72," <q>﴿ثُمَّ نُنَجِّی ٱلَّذِینَ ٱتَّقَوا۟ وَّنَذَرُ ٱلظَّـٰلِمِینَ فِیهَا جِثِیࣰّا ۝٧٢﴾</q> - قراءات ٤٧٠٦٣- عن عبد الله بن عباس -من طريق أبي سلامة- أنّه قرأ: <q>﴿ثُمَّ نُنَجِّي الَّذِينَ اتَّقَوْا﴾</q> بضم الثاء{1}. (١٠/١٢٤) ٤٧٠٦٤- عن عبد الله بن عباس -من طُرُق- أنه كان يقرأ: (ثَمَّ نُنَجِّي الَّذِينَ اتَّقَوْاْ) بفتح الثاء{2}. (١٠/١٢٤) ٤٧٠٦٥- عن ابن أبي ليلى أنّه كان يقرأ: (ثَمَّ نُنَجِّي الَّذِينَ اتَّقَوْاْ) بفتح الثاء{2}. (١٠/١٢٤) <q>﴿ثُمَّ نُنَجِّی ٱلَّذِینَ ٱتَّقَوا۟ وَّنَذَرُ ٱلظَّـٰلِمِینَ فِیهَا جِثِیࣰّا ۝٧٢﴾</q> - تفسير الآية ٤٧٠٦٦- عن عبد الله بن عباس، في قوله: <q>﴿ونذر الظلمين فيها جثيا﴾</q>، وكذلك كان يقرؤها، يعني: باقين فيها{4}. (١٠/١٢٤) ٤٧٠٦٧- عن مجاهد بن جبر، في قوله: <q>﴿ونذر الظلمين فيها جثيا﴾</q>، قال: جِثِيًّا على رُكَبهم{4}. (١٠/١٢٤) ٤٧٠٦٨- عن الضحاك بن مزاحم= (ز) ٤٧٠٦٩- والحسن البصري: جمعُ جاثٍ، أي: جاثين على الرُّكَب{6}. (ز) ٤٧٠٧٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ثم ننجي الذين اتقوا ونذر الظالمين فيها جثيا﴾</q>: إنّ الناس وردوا جهنم وهي سوداء مُظْلِمة، فأما المؤمنون فأضاءت لهم حسناتُهم، فأُنجوا منها، وأمّا الكُفّار فأوبقتهم أعمالُهم، واحْتُبِسُوا بذنوبهم{7}. (ز) ٤٧٠٧١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿جثيا﴾</q>، قال: على رُكَبِهم{8}. (١٠/١٢٥) ٤٧٠٧٢- عن زيد بن أسلم -من طريق حفص- يقول الله: <q>﴿ثم ننجي الذين اتقوا﴾</q> فلا يَرِدونها، <q>﴿ونذر الظالمين فيها جثيا﴾</q>{9}. (ز) ٤٧٠٧٣- قال مقاتل بن سليمان: <q>﴿ثم ننجي الذين اتقوا﴾</q> الشِّرْك منها، يعني: أهل التوحيد، فنخرجهم منها، <q>﴿ونذر الظالمين﴾</q> يعني: المشركين <q>﴿فيها﴾</q> يعني: في جهنم <q>﴿جثيا﴾</q> على الرُّكَب{10}. (ز) ٤٧٠٧٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في الآية، قال: الجِثِيُّ شر الجلوس، ولا يجلس الرجل جاثيًا إلا عند كَرْبٍ نزل{11}. (١٠/١٢٤) ٤٧٠٧٥- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿ونذر الظالمين فيها جثيا﴾</q>، قال: قد جَثَوْا{12}. (ز) ٤٧٠٧٦- قال يحيى بن سلّام، في قوله: <q>﴿ونذر الظلمين فيها جثيا﴾</q>: وقال بعضهم: جماعة جماعة{13}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن الأنباري. <q>﴿ثُمَّ نُنَجِّي﴾</q> بضم الثاء قراءة العشرة، وبفتحها قراءة شاذة. انظر: مختصر ابن خالويه ص٨٩.عزاه السيوطي إلى ابن الأنباري.عزاه السيوطي إلى ابن الأنباري.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٢٤٥.أخرجه ابن جرير ١٥/٦٠٧.أخرجه يحيى بن سلام ١/٢٣٩، وعبد الرزاق ٢/١٠ من طريق معمر، وابن جرير ١٥/٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع – تفسير القرآن ١/٣٧ (٧٦).تفسير مقاتل بن سليمان ٢/٦٣٦.أخرجه ابن جرير ١٥/٦٠٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢١٠.تفسير يحيى بن سلام ١/٢٣٩.
19,73," <q>﴿وَإِذَا تُتۡلَىٰ عَلَیۡهِمۡ ءَایَـٰتُنَا بَیِّنَـٰتࣲ قَالَ ٱلَّذِینَ كَفَرُوا۟ لِلَّذِینَ ءَامَنُوۤا۟ أَیُّ ٱلۡفَرِیقَیۡنِ خَیۡرࣱ مَّقَامࣰا وَأَحۡسَنُ نَدِیࣰّا ۝٧٣﴾</q> - قراءات ٤٧٠٧٧- قال سفيان الثوري: مَن قرأها: ‹خَيْرٌ مُّقامًا› فإنما يعني: مقامه الذي يُقِيم فيه الدهر. والذي يقرأها: <q>﴿خَيْرٌ مَّقامًا﴾</q> فإنما يعني: المقامة التي يقيم فيها{1}. (ز) <q>﴿وَإِذَا تُتۡلَىٰ عَلَیۡهِمۡ ءَایَـٰتُنَا بَیِّنَـٰتࣲ قَالَ ٱلَّذِینَ كَفَرُوا۟ لِلَّذِینَ ءَامَنُوۤا۟ أَیُّ ٱلۡفَرِیقَیۡنِ خَیۡرࣱ مَّقَامࣰا وَأَحۡسَنُ نَدِیࣰّا ۝٧٣﴾</q> - تفسير الآية ٤٧٠٧٨- عن عبد الله بن عباس -من طريقي علي، وأبي ظَبْيانَ- في قوله: <q>﴿خيرا مقاما﴾</q> قال: المنازل، <q>﴿وأحسن نديا﴾</q> قال: المجالس{2}. (١٠/١٢٥) ٤٧٠٧٩- عن عبد الله بن عباس -من طريق العوفي- <q>﴿وإذا تتلى عليهم آياتنا بينات قال الذين كفروا للذين آمنوا أي الفريقين خير مقاما وأحسن نديا﴾</q>، قال: المقام: المسكن. والندي: المجلس والنعمة والبهجة التي كانوا فيها. وهو كما قال الله لقوم فرعون حين أهلكهم وقصَّ شأنهم في القرآن، فقال: <q>﴿كم تركوا من جنات وعيون وزروع ومقام كريم ونعمة كانوا فيها فاكهين﴾</q> [الدخان:٢٥-٢٦] فالمقام: المسكن والنعيم. والندي: المجلس والمَجْمَعُ الذي كانوا يجتمعون فيه، وقال الله فيما قصَّ على رسوله في أمرِ لوطٍ إذ قال: <q>﴿وتأتون في ناديكم المنكر﴾</q> [العنكبوت:٢٩]. والعرب تسمي المجلس: النادي{3}. (ز) ٤٧٠٨٠- عن عبد الله بن عباس: أن نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿وأحسن نديا﴾</q>. قال: النادي: المجلس والتكأة. قال: فهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: يومان يومُ مقاماتٍ وأنديةٍ ويومُ سيرٍ إلى الأعداءِ تَأْوِيبِ؟{4}. (١٠/١٢٥) ٤٧٠٨١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قول الله: <q>﴿أي الفريقين﴾</q> قال: قريش تقولها لأصحاب محمد ﷺ، <q>﴿وأحسن نديا﴾</q> قال: مجالسهم، يقولونه أيضًا{5}. (١٠/١٢٥) ٤٧٠٨٢- قال مجاهد بن جبر: يقوله مشركو قريش لهؤلاء أصحاب محمد{6}. (ز) ٤٧٠٨٣- عن الحسن البصري، في قوله: <q>﴿خير مقاما وأحسن نديا﴾</q>، قال: أكرم مجلسًا{7}. (١٠/١٢٥) ٤٧٠٨٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿خير مقاما وأحسن نديا﴾</q>، قال: خيرٌ مكانًا، وأحسنُ مجلسًا{8}. (١٠/١٢٦) ٤٧٠٨٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإذا تتلى عليهم آياتنا بينات قال الذين كفروا للذين آمنوا أي الفريقين خير مقاما وأحسن نديا﴾</q>: رَأَوْا أصحابَ محمد ﷺ في عيشهم خشونةٌ، وفيهم قَشافَةٌ، فعرَّض أهلُ الشرك بما تسمعون قوله: <q>﴿وأحسن نديا﴾</q>، يقول: مجلسًا{9}. (ز) ٤٧٠٨٦- قال مقاتل بن سليمان: <q>﴿وإذا تتلى عليهم آياتنا﴾</q> يعني: القرآن <q>﴿بينات﴾</q> يعني: واضحات؛ <q>﴿قال الذين كفروا﴾</q> وهم النضر بن الحارث بن علقمة وغيره، <q>﴿للذين آمنوا أي الفريقين خير مقاما﴾</q> وذلك أنّهم لبِسوا أحسن الثياب، ودهنوا الرؤوس، ثم قالوا للمؤمنين: أي الفريقين نحن أو أنتم خير؟ يعني: أفضل مقامًا للمساكن من مساكن مكة. ومثله في «حم» الدخان [٢٦]: <q>﴿ومقام كريم﴾</q> يعني: ومساكن طيبة. <q>﴿وأحسن نديا﴾</q> يعني: مجلسًا. كقوله سبحانه: <q>﴿وتأتون في ناديكم المنكر﴾</q> [العنكبوت:٩]، يعني: في مجالسكم{10}. (ز) ٤٧٠٨٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأحسن نديا﴾</q> قال: الندي: المجلس. وقرأ قول الله: <q>﴿فليدع ناديه﴾</q> [العلق:١٧]، قال: مجلسًا{11}. (ز) ٤٧٠٨٨- قال يحيى بن سلّام: قوله: <q>﴿وإذا تتلى عليهم آياتنا بينات قال الذين كفروا للذين آمنوا أي الفريقين﴾</q> نحن وأنتم، <q>﴿خير مقاما وأحسن نديا﴾</q> المقام: المسكن. والندي: المجمع{12}. (ز) ",footnotes:1:تفسير الثوري ص١٨٨. ‹خَيْرٌ مُّقامًا› بضم الميم قراءة متواترة، قرأ بها ابن كثير، وقرأ بقية العشرة: <q>﴿خَيْرٌ مَّقامًا﴾</q> بفتح الميم. انظر: النشر ٢/٣١٨-٣١٩، والإتحاف ص٣٧٩.أخرجه ابن جرير ١٥/٦٠٨، ٦٠٩، ٦١١، وإسحاق البستي في تفسيره ص٢١٠ من طريق أبي ظبيان، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-٢٤٩، وفتح الباري ٨/٤٢٧، والإتقان ٢/٢٧-. وعزاه السيوطي إلى الفريايي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٦٠٨.أخرجه الطستي -كما في الإتقان ٢/٧١-.أخرجه ابن جرير ١٥/٦٠٩ واللفظ له. وعلق أوَّله يحيى بن سلام ١/٢٣٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ١/٢٣٩.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١١، وابن جرير ١٥/٦١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٢٣٩ بنحوه، وابن جرير ١٥/٦١٠.تفسير مقاتل بن سليمان ٢/٦٣٦.أخرجه ابن جرير ١٥/٦١٠.تفسير يحيى بن سلام ١/٢٣٩.
19,74," <q>﴿وَكَمۡ أَهۡلَكۡنَا قَبۡلَهُم مِّن قَرۡنٍ هُمۡ أَحۡسَنُ أَثَـٰثࣰا وَرِءۡیࣰا ۝٧٤﴾</q> - قراءات ٤٧٠٨٩- عن سعيد بن جبير -من طريق أبي الصهباء- قرأ: (أثاثًا وزِيًّا) بالزاي{1}. (ز) ٤٧٠٩٠- عن سلمة، عن الفراء: قرأ بعضُهم: (وزِيًّا) بالزاي، وهو الهيئة والمنظر، تقول العرب: زييتُ الجارية: أي: زَيَّنتُها وهَيَّأتُها{2}. (ز) <q>﴿وَكَمۡ أَهۡلَكۡنَا قَبۡلَهُم مِّن قَرۡنٍ هُمۡ أَحۡسَنُ أَثَـٰثࣰا وَرِءۡیࣰا ۝٧٤﴾</q> - تفسير الآية ٤٧٠٩١- عن عبد الله بن عباس -من طريق علي، وأبي ظبيان- في قوله: <q>﴿أحسن أثاثا﴾</q> قال: المتاع والمال، <q>﴿ورئيا﴾</q> قال: المَنظَر{3}. (١٠/١٢٥) ٤٧٠٩٢- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿ورئيا﴾</q>: منظرًا في اللون والحسن{4}. (ز) ٤٧٠٩٣- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: ‹أثاثًا ورِيًّا›{5}. قال: الأثاث: المتاع، والرِيُّ من الشراب. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: كأن على الحُمولِ غداةَ ولَّوا مِن الريِّ الكريم من الأثاثِ؟{6}. (١٠/١٢٥) ٤٧٠٩٤- عن أبي رَزِين [مسعود بن مالك الأسدي]، قال: الثياب{7}. (ز) ٤٧٠٩٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿خير مقاما وأحسن نديا﴾</q> قال: مجالسهم، وفي قوله: <q>﴿أحسن أثاثا﴾</q> قال: زينة، <q>﴿ورئيا﴾</q> قال: فيما يرى الناسُ{8}. (١٠/١٢٦) ٤٧٠٩٦- عن الضحاك بن مزاحم -من طريق عُبيد- قال في قوله: <q>﴿أحسن أثاثا﴾</q>: يعني: المال، <q>﴿ورئيا﴾</q> يعني: المنظر الحسن{9}. (ز) ٤٧٠٩٧- عن الحسن البصري، في قوله: <q>﴿أحسن أثاثا ورئيا﴾</q>، قال: أحسن متاعًا، وأحسن صورًا{10}. (١٠/١٢٦) ٤٧٠٩٨- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿أثاثا ورئيا﴾</q>، قال: الأثاث: أحسن المتاع. والرئي، قال: المال{11}. (ز) ٤٧٠٩٩- عن قتادة بن دعامة -من طريق سعيد-: يقول الله -تبارك وتعالى-: <q>﴿وكم أهلكنا قبلهم من قرن هم أحسن أثاثا ورئيا﴾</q>، أي: أكثر متاعًا، وأحسن مرآة ومنظرًا، فأهلك اللهُ أموالَهم، وأفسد صورهم عليهم -تبارك وتعالى-{12}. (ز) ٤٧١٠٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أحسن أثثا ورئيا﴾</q>، قال: أكثر أموالًا، وأحسن صُوَرًا{13}. (١٠/١٢٦) ٤٧١٠١- قال مقاتل، في قوله: <q>﴿هم أحسن أثاثا﴾</q>: لباسًا وثيابًا{14}. (ز) ٤٧١٠٢- قال مقاتل بن سليمان: يقول الله ﷿ يُخَوِّفهم: <q>﴿وكم أهلكنا﴾</q> بالعذاب في الدنيا <q>﴿قبلهم﴾</q> قبل أهل مكة <q>﴿من قرن﴾</q> يعني: أمة. كقوله ﷿: <q>﴿أهلكنا القرون﴾</q> [يونس:١٣]، يعني: الأمم الخالية، <q>﴿هم أحسن أثاثا﴾</q> يعني: ألين متاعًا، <q>﴿ورئيا﴾</q> وأحسن منظرًا من أهل مكة، فأهلك الله ﷿ أموالَهم وصورهم{15}. (ز) ٤٧١٠٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أحسن أثاثا ورئيا﴾</q>، قال: الرئي: المنظر. والأثاث: المتاع. أحسن متاعًا، وأحسن منظرًا{4}. (ز) ٤٧١٠٤- قال يحيى بن سلّام: قال الله: <q>﴿وكم أهلكنا قبلهم من قرن هم أحسن أثاثا ورئيا﴾</q> منهم، والأثاث: المال. وقال بعضهم: المتاع ... <q>﴿ورئيا﴾</q> مَن قرأها مهموزة فيقول: منظرًا، ومَن قرأها بغير همزة فيقول: ورِيًّا مِن قِبَل الرِواء، وإنّما عَيْشُ الناس بالمطر، به تَنبت زرعهم، وتعيش ماشِيَتُهم{17}٤٢١٤. (ز) ٤٢١٤ ساق ابنُ كثير (٩/٢٨٩) الأقوال الواردة، ثم علَّق بقوله: «والكلُّ متقارب صحيح». ",footnotes:1:أخرجه الحربي في غريب الحديث ٣/٩٨٦. وهي قراءة شاذة، تروى أيضًا عن يزيد البربري وغيرهما. انظر: مختصر ابن خالويه ص٨٩، والمحتسب ٢/٤٤.أخرجه الحربي في غريب الحديث ٣/٩٨٦.أخرجه ابن جرير ١٥/٦٠٨، ٦٠٩، ٦١١، وإسحاق البستي في تفسيره ص٢١٠ من طريق أبي ظبيان، وزاد: وليس في الدنيا مما في الجنة إلا الأسماء، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-٢٤٩، وفتح الباري ٨/٤٢٧، والإتقان ٢/٢٧-. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٦١٢.قال محققوه: كذا في النسخ، وفي مصدر التخريج: <q>﴿ورئيا﴾</q>. وهي قراءة قالون وابن ذكوان وأبي جعفر. انظر: التيسير ص١٤٩، والنشر ١/٣٩٣.أخرجه الطستي -كما في الإتقان ٢/٧١-.أخرجه ابن أبي حاتم -كما في الفتح ٨/٤٢٧-.أخرجه ابن جرير١٥/٦١٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٦١٢، وإسحاق البستي في تفسيره ص٢١١.عزاه السيوطي إلى عبد بن حميد. وعلَّق يحيى بن سلام ١/٢٣٩ آخره.أخرجه ابن جرير ١٥/٦١١.أخرجه يحيى بن سلام ١/٢٣٩ بنحوه، وابن جرير ١٥/٦١١.أخرجه عبد الرزاق ٢/١١، وابن جرير ١٥/٦١٢. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٦/٢٢٨، وتفسير البغوي ٥/٢٥٢، واللفظ له.تفسير مقاتل بن سليمان ٢/٦٣٦.أخرجه ابن جرير ١٥/٦١٢.تفسير يحيى بن سلام ١/٢٣٩.
19,75," <q>﴿قُلۡ مَن كَانَ فِی ٱلضَّلَـٰلَةِ فَلۡیَمۡدُدۡ لَهُ ٱلرَّحۡمَـٰنُ مَدًّاۚ﴾</q> - قراءات ٤٧١٠٥- عن حبيب بن أبي ثابت، قال: في حرف أُبَيِّ بن كعب: (قُلْ مَن كانَ فِي الضَّلالَةِ فَإنَّهُ يَزِيدُهُ اللهُ ضَلالَةً){1}. (١٠/١٢٧) <q>﴿قُلۡ مَن كَانَ فِی ٱلضَّلَـٰلَةِ فَلۡیَمۡدُدۡ لَهُ ٱلرَّحۡمَـٰنُ مَدًّاۚ﴾</q> - تفسير الآية ٤٧١٠٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿قل من كان في الضلالة فليمدد له الرحمن مدا﴾</q>: فلْيَدَعْهُ اللهُ في طُغْيانِه{2}. (١٠/١٢٦) ٤٧١٠٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿قل من كان في الضلالة﴾</q> يعني: في الكفر؛ <q>﴿فليمدد له الرحمن مدا﴾</q> يقول: وهو العاص بن وائل{3}. (ز) ٤٧١٠٨- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لهم: <q>﴿من كان في الضلالة﴾</q> يعني: مَن هو في الشرك؛ <q>﴿فليمدد له الرحمن مدا﴾</q> في الخير؛ لقولهم للمؤمنين: <q>﴿أي الفريقين خير مقاما﴾</q>{4}. (ز) ٤٧١٠٩- قال يحيى بن سلّام: قوله: <q>﴿قل من كان في الضلالة﴾</q> هذا الذي يموت على ضلالته؛ <q>﴿فليمدد له الرحمن مدا﴾</q> هذا دعاءٌ، فأمَدَّ له الرحمن مدًّا. أمر الله النبيَّ أن يدعو بهذا{5}٤٢١٥. (ز) ٤٢١٥ ذكر ابنُ عطية (٦/٦٢) أن قوله: <q>﴿قُلْ مَن كانَ فِي الضَّلالَةِ ...﴾</q> يحتمل معنيين: أحدهما: أن يكون بمعنى الدعاء والابتهال، كأنه يقول: الأضلُّ منا ومنكم مدّ الله له حتى يؤول ذلك إلى عذابه. والآخر: أن يكون بمعنى الخبر، كأنه يقول: مَن كان ضالًّا مِن الأُمَم فعادة الله فيه أنه يمد له ولا يُعاجله حتى يفضي ذلك إلى عذابه في الآخرة. ثم قال: «فاللام في قوله:<q>﴿فَلْيَمْدُدْ﴾</q> على المعنى الأول لام رغبة في صيغة أمر، وعلى المعنى الثاني لام أمر دخلت على معنى الخبر ليكون أوكد وأقوى، وهذا موجود في كلام العرب وفصاحتها». <q>﴿حَتَّىٰۤ إِذَا رَأَوۡا۟ مَا یُوعَدُونَ إِمَّا ٱلۡعَذَابَ وَإِمَّا ٱلسَّاعَةَ فَسَیَعۡلَمُونَ مَنۡ هُوَ شَرࣱّ مَّكَانࣰا وَأَضۡعَفُ جُندࣰا ۝٧٥﴾</q> - تفسير ٤٧١١٠- قال مقاتل بن سليمان: <q>﴿حتى إذا رأوا ما يوعدون إما العذاب﴾</q> في الدنيا، يعني: القتل ببدر، <q>﴿وإما الساعة﴾</q> يعني: القيامة، <q>﴿فسيعلمون من هو شر مكانا﴾</q> يعني: شر منزلًا، <q>﴿وأضعف جندا﴾</q> يعني: وأقلُّ فئة هم أمِ المؤمنون{4}. (ز) ٤٧١١١- قال يحيى بن سلّام: قال: <q>﴿حتى إذا رأوا ما يوعدون إما العذاب﴾</q> في الدنيا قبل عذاب الآخرة، <q>﴿وإما الساعة﴾</q> أي: وإما عذاب الآخرة، فهو العذاب الأكبر. لم يبعث الله نبيًّا إلا وهو يُحَذِّر أمته عذاب الله في الدنيا، وعذابه في الآخرة إن لم يؤمنوا، <q>﴿فسيعلمون﴾</q> عند ذلك <q>﴿من هو شر مكانا﴾</q> أهم أم المؤمنون، <q>﴿وأضعف جندا﴾</q> في النصرة والمَنَعَة، أي: إنهم ليس لهم أحد يمنعهم من عذاب الله{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم. وعزاه الحافظ في فتح الباري ٨/٤٢٨ إلى ابن أبي حاتم بلفظ: (مَن كانَ فِي الضَّلالَةِ فَإنَّ اللهَ يَزِيدُهُ ضَلالَةً). وهي قراءة شاذة. انظر: فتح القدير ٣/٤٨٠.أخرجه يحيى بن سلام ١/٢٤٠ من طريق ابن مجاهد، وابن جرير ١٥/٦١٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٤٥٨.تفسير مقاتل بن سليمان ٢/٦٣٧.تفسير يحيى بن سلام ١/٢٤٠.تفسير مقاتل بن سليمان ٢/٦٣٧.تفسير يحيى بن سلام ١/٢٤٠.
19,76," <q>﴿وَیَزِیدُ ٱللَّهُ ٱلَّذِینَ ٱهۡتَدَوۡا۟ هُدࣰىۗ﴾</q> - تفسير ٤٧١١٢- تفسير السُّدِّيّ: قال: <q>﴿ويزيد الله الذين اهتدوا هدى﴾</q>، يعني: يزيدهم إيمانًا{1}. (ز) ٤٧١١٣- عن الربيع [بن أنس]، <q>﴿ويزيد الله الذين اهتدوا هدى﴾</q>، قال: يزيدهم إخلاصًا{2}. (١٠/١١٥) ٤٧١١٤- قال مقاتل بن سليمان: <q>﴿ويزيد الله الذين اهتدوا هدى﴾</q> مِن الضلالة، يعني: يزيدهم إيمانًا{3}٤٢١٦. (ز) ٤٢١٦ نقل ابنُ جرير (١٥/٦١٦) قولًا ولم يسنده بأنّ المعنى: ويزيد الله الذين اهتدوا هُدًى بناسخ القرآن ومنسوخه، فيؤمن بالناسخ، كما آمَن مِن قبل بالمنسوخ، فذلك زيادة هُدًى مِن الله له على هداه من قبل. وعلَّق عليه ابنُ عطية (٦/٦٣) بقوله: «وهذا مثال». <q>﴿وَٱلۡبَـٰقِیَـٰتُ ٱلصَّـٰلِحَـٰتُ﴾</q> - تفسير ٤٧١١٥- قال مقاتل بن سليمان: <q>﴿والباقيات الصالحات﴾</q> وهي أربعة كلمات: سبحان الله، والحمد لله، ولا إله إلا الله، والله أكبر، من قالها فهو <q>﴿خير عند ربك ثوابا وخير مردا﴾</q>{4}. (ز) <q>﴿خَیۡرٌ عِندَ رَبِّكَ ثَوَابࣰا وَخَیۡرࣱ مَّرَدًّا ۝٧٦﴾</q> - تفسير ٤٧١١٦- عن سعيد بن جبير، في قوله: <q>﴿خير عند ربك ثوابا﴾</q> يعني: خير جزاء مِن جزاء المشركين، <q>﴿وخير مردا﴾</q> يعني: مرجعًا مِن مرجعهم إلى النار{2}. (١٠/١٢٧) ٤٧١١٧- قال مقاتل بن سليمان: <q>﴿خير﴾</q> يعني: أفضل <q>﴿عند ربك ثوابا و﴾</q>الآخرة <q>﴿خير مردا﴾</q> يعني: أفضل مرجعًا مِن ثواب الكافر النار، ومرجعهم إليها{3}. (ز) ٤٧١١٨- قال يحيى بن سلّام: قوله: <q>﴿خير عند ربك ثوابا﴾</q> جزاء في الآخرة، <q>﴿وخير مردا﴾</q> خير عاقبة من أعمال الكفار{7}. (ز) ",footnotes:1:علقه يحيى بن سلام ١/٢٤٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٣٧.تفسير مقاتل بن سليمان ٢/٦٣٧. وقد تقدمت الآثار مفصلة في تفسير الباقيات الصالحات، وذلك عند قوله تعالى: <q>﴿والباقِياتُ الصّالِحاتُ خَيْرٌ عِنْدَ رَبِّكَ ثَوابًا وخَيْرٌ أمَلًا﴾</q> [الكهف:٤٦].عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٣٧.تفسير يحيى بن سلام ١/٢٤١.
