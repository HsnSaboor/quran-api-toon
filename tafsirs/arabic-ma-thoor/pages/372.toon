quran[25]{c,v,t}:
26,112," <q>﴿قَالَ وَمَا عِلۡمِی بِمَا كَانُوا۟ یَعۡمَلُونَ ۝١١٢﴾</q> - تفسير ٥٦١٤٩- قال مقاتل بن سليمان: <q>﴿قال﴾</q> نوح ﵇: <q>﴿وما علمي بما كانوا يعملون﴾</q> يقول: لم أكن أعلم أنّ الله يهديهم للإيمان مِن بينكم، ويَدَعُكُم!{1}. (ز) ٥٦١٥٠- عن أصبغ، قال: سمعتُ عبد الرحمن بن زيد بن أسلم في قول الله: <q>﴿يعملون﴾</q>، قال: يعملون ويصنعون واحد{2}. (ز) ٥٦١٥١- قال يحيى بن سلّام: <q>﴿وما علمي بما كانوا يعملون﴾</q>، أي: بما يعملون، إنّما أقبل منهم الظاهر، وليس لي بباطن أمرهم عِلْمٌ{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن أبي حاتم ٨/٢٧٨٨.تفسير يحيى بن سلّام ٢/٥١٢.
26,113," <q>﴿إِنۡ حِسَابُهُمۡ إِلَّا عَلَىٰ رَبِّیۖ لَوۡ تَشۡعُرُونَ ۝١١٣﴾</q> - تفسير ٥٦١٥٢- تفسير إسماعيل السُّدِّيّ: <q>﴿إن حسابهم﴾</q>، يعني: ما جزاؤهم{1}. (ز) ٥٦١٥٣- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿إن حسابهم إلا على ربي﴾</q>، قال: هو أعلم بما في أنفسهم{2}. (١١/٢٧٨) ٥٦١٥٤- قال مقاتل بن سليمان: ثم قال نوح ﵇: <q>﴿إن حسابهم﴾</q> يعني: ما جزا[ؤهم] <q>﴿إلا على ربي لو تشعرون﴾</q>{3}. (ز) <q>﴿إِنۡ حِسَابُهُمۡ إِلَّا عَلَىٰ رَبِّیۖ لَوۡ تَشۡعُرُونَ ۝١١٣﴾</q> - آثار متعلقة بالآية ٥٦١٥٥- عن زِرّ بن حُبَيْشٍ، قال: شهدتُ صاحبَنا وابصةَ بن معبد، وسمع رجلين يتنازعان في أهل العراق وأهل الشام، يعيب أحدُهما هؤلاء، ويعيب الآخرُ هؤلاء. قال وابصة: فهلّا يقولون غير ذلك! قال: وما نقول؟ قال: يقولان: <q>﴿إن حسابهم إلا على ربي لو تشعرون﴾</q>{4}. (ز) ",footnotes:1:تفسير يحيى بن سلّام ٢/٥١٢.أخرجه ابن جرير ١٧/٦٠٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن أبي حاتم ٨/٢٧٨٩.
26,114," <q>﴿وَمَاۤ أَنَا۠ بِطَارِدِ ٱلۡمُؤۡمِنِینَ ۝١١٤ إِنۡ أَنَا۠ إِلَّا نَذِیرࣱ مُّبِینࣱ ۝١١٥﴾</q> - تفسير ٥٦١٥٦- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿نذير﴾</q>، قال: نذير مِن النار{1}. (ز) ٥٦١٥٧- قال مقاتل بن سليمان: <q>﴿وما أنا بطارد المؤمنين﴾</q> يقول: وما أنا بالذي لا يقبل الإيمان مِن الذين تزعمون أنهم الأرذلون عندكم، <q>﴿إن أنا﴾</q> يعني: ما أنا <q>﴿إلا نذير مبين﴾</q> يعني: رسول بَيِّن{2}. (ز) ٥٦١٥٨- قال يحيى بن سلّام: <q>﴿وما أنا بطارد المؤمنين (١١٤)﴾</q> يعنيهم{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٨٩.تفسير مقاتل بن سليمان ٣/٢٧٢.تفسير يحيى بن سلّام ٢/٥١٢.
  26,115,""
26,116," <q>﴿قَالُوا۟ لَىِٕن لَّمۡ تَنتَهِ یَـٰنُوحُ لَتَكُونَنَّ مِنَ ٱلۡمَرۡجُومِینَ ۝١١٦﴾</q> - تفسير ٥٦١٥٩- عن عبد الله بن عباس، في قوله: <q>﴿لتكونن من المرجومين﴾</q>، قال: مِن المقتولين{1}. (ز) ٥٦١٦٠- عن الضحاك بن مُزاحِم، في قوله: <q>﴿لتكونن من المرجومين﴾</q>، قال: مِن المشتومين{2}. (ز) ٥٦١٦١- عن الحسن البصري -من طريق النضر أبي محمد- <q>﴿لتكونن من المرجومين﴾</q>، قال: تواعدوه بالقتل{3}. (١١/٢٧٨) ٥٦١٦٢- عن زيد بن أسلم، نحو ذلك{4}. (ز) ٥٦١٦٣- عن قتادة بن دعامة، في قوله: <q>﴿لتكونن من المرجومين﴾</q>، قال: بالحجارة{5}. (١١/٢٧٨) ٥٦١٦٤- عن إسماعيل السُّدِّيّ، <q>﴿لتكونن من المرجومين﴾</q>، قال: بالشتيمة{3}. (١١/٢٧٨) ٥٦١٦٥- قال [أبو حمزة] الثمالي: كل شيء في القرآن مِن ذكر المرجومين فإنّه يعني بذلك: القتل؛ إلا التي في سورة مريم [٤٦]: <q>﴿لئن لم تنته لأرجمنك﴾</q>، فإنّه يعني: لأشتمنَّك{1}. (ز) ٥٦١٦٦- قال محمد بن السائب الكلبي: مِن المقتولين بالحجارة{8}. (ز) ٥٦١٦٧- قال مقاتل بن سليمان: <q>﴿قالوا لئن لم تنته﴾</q> يعني: لئن لم تسكت <q>﴿يا نوح﴾</q> عنّا؛ <q>﴿لتكونن من المرجومين﴾</q> يعني: مِن المقتولين{9}. (ز) ٥٦١٦٨- قال يحيى بن سلّام: <q>﴿قالوا لئن لم تنته يا نوح﴾</q> عما تدعونا إليه، وعن ذمِّ آلهتنا وشتمها. <q>﴿لتكونن من المرجومين﴾</q> قال قتادة: بالحجارة، فلنقتلنَّك بها{10}٤٨١١. (ز) ٤٨١١ ذكر ابنُ عطية (٦/٤٩٦) أن قولهم: <q>﴿مِنَ المَرْجُومِينَ﴾</q> يحتمل أن يريدوا: بالحجارة، ويحتمل أن يريدوا: بالقول والشتم ونحوه، ثم علَّق على الاحتمال الثاني بقوله: «وهو شبيه برجم الحجارة، وهو من الرجم بالغيب والظن ونحو ذلك». ",footnotes:1:تفسير الثعلبي ٧/١٧٣.تفسير البغوي ٦/١٢١. وتصحَّفت في تفسير الثعلبي ٧/١٧٣ إلى: المشؤومين.أخرجه ابن أبي حاتم ٨/٢٧٨٩.علَّقه ابن أبي حاتم ٨/٢٧٨٩.أخرجه ابن أبي حاتم ٨/٢٧٨٩. وعلَّقه يحيى بن سلّام ٢/٥١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٨٩.تفسير الثعلبي ٧/١٧٣.تفسير البغوي ٦/١٢١.تفسير مقاتل بن سليمان ٣/٢٧٢. وآخره في تفسير الثعلبي ٧/١٧٣، وتفسير البغوي ٦/١٢١ منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلّام ٢/٥١٢.
26,117," <q>﴿قَالَ رَبِّ إِنَّ قَوۡمِی كَذَّبُونِ ۝١١٧﴾</q> - تفسير ٥٦١٦٩- قال مقاتل بن سليمان: <q>﴿قال﴾</q> نوح: <q>﴿رب إن قومي كذبون﴾</q> البعث{1}. (ز) ",footnotes:1:هكذا في تفسير مقاتل بن سليمان ٣/٢٧٢.
26,118," <q>﴿فَٱفۡتَحۡ بَیۡنِی وَبَیۡنَهُمۡ فَتۡحࣰا وَنَجِّنِی وَمَن مَّعِیَ مِنَ ٱلۡمُؤۡمِنِینَ ۝١١٨﴾</q> - تفسير ٥٦١٧٠- عن عبد الله بن عباس -من طريق قتادة- قال: ما كنتُ أدري ما قوله: <q>﴿افتح بيننا وبين قومنا بالحق﴾</q> [الأعراف:٨٩]، حتى سمعت ابن ذي يزن يقول: تعالي أُفاتحك. يعني: تعال أُخاصمك{1}. (ز) ٥٦١٧١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فافتح بيني وبينهم فتحا﴾</q>، قال: اقضِ بيني وبينهم قضاءً{2}. (١١/ ٢٧٨) ٥٦١٧٢- عن أبي صالح [باذام]، مثله{3}. (١١/ ٢٧٨) ٥٦١٧٣- عن إسماعيل السُّدِّيّ، نحوه{4}. (ز) ٥٦١٧٤- قال مقاتل بن سليمان: <q>﴿فافتح بيني وبينهم فتحا﴾</q> يقول: اقض بيني وبينهم قضاءً، يعني: العذاب، <q>﴿ونجني ومن معي من المؤمنين﴾</q> مِن الغرق، فنجّاه الله ﷿{5}. (ز) ٥٦١٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فافتح بيني وبينهم فتحا﴾</q>، قال: اقضِ بيني وبينهم{6}. (ز) ٥٦١٧٦- قال يحيى بن سلّام: <q>﴿ونجني ومن معي من المؤمنين﴾</q>، والفتح: القضاء. وإذا قضى الله بين النبيِّ وقومه هلكوا، وهذا حيثُ أمر بالدعاء عليهم، فاستجيب له، فأهلكهم الله، ونجّاه ومَن معه من المؤمنين{7}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٩٠.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦٠٤، وابن أبي حاتم ٨/٢٧٩٠ من طريق سعيد. وعلَّقه يحيى بن سلّام ٢/٥١٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٨/٢٧٩٠.تفسير مقاتل بن سليمان ٣/٢٧٢.أخرجه ابن جرير ١٧/٦٠٤. وعلَّقه ابن أبي حاتم ٨/٢٧٩٠.تفسير يحيى بن سلّام ٢/٥١٣.
26,119," <q>﴿فَأَنجَیۡنَـٰهُ وَمَن مَّعَهُۥ فِی ٱلۡفُلۡكِ﴾</q> - تفسير ٥٦١٧٧- عن أبي مالك غزوان الغفاري -من طريق السُّدِّيّ- <q>﴿في الفلك المشحون﴾</q>، قال: سفينة حمل فيها مِن كل زوجين اثنين{1}. (ز) ٥٦١٧٨- عن أبي صالح [باذام]، <q>﴿في الفلك المشحون﴾</q>، قال: سفينة نوح{2}. (١١/٢٨٠) ٥٦١٧٩- عن الضحاك بن مزاحم= (ز) ٥٦١٨٠- وقتادة بن دعامة، نحو ذلك{3}. (ز) <q>﴿ٱلۡمَشۡحُونِ ۝١١٩﴾</q> - تفسير ٥٦١٨١- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿الفلك المشحون﴾</q>. قال: السفينة المُوقَرة{4} الممتلئة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عبيد بن الأبرص: شَحَنّا أرضهم بالخيل حتى تركناهم أذلَّ من الصِّراطِ؟{5}. (١١/٢٧٨) ٥٦١٨٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿الفلك المشحون﴾</q>، قال: المُمْتَلِئ{6}. (١١/٢٧٩) ٥٦١٨٣- عن عبد الله بن عباس -من طريق العوفي- أنّه قال: تدرون ما المشحون؟ قلنا: لا. قال: هو المُوقَر{7}. (١١/٢٧٩) ٥٦١٨٤- عن عبد الله بن عباس -من طريق العوفي- قال: المُثْقَل{8}. (١١/٢٨٠) ٥٦١٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <q>﴿الفلك المشحون﴾</q>، قال: المملوء المفروغ منه تحميلًا{9}. (١١/٢٧٩) ٥٦١٨٦- عن عامر الشعبي، <q>﴿في الفلك المشحون﴾</q>، قال: المُثْقَل{10}. (١١/٢٨٠) ٥٦١٨٧- عن الحسن البصري -من طريق أبي مودود- في قوله: <q>﴿الفلك المشحون﴾</q>، قال: المستدير{11}. (ز) ٥٦١٨٨- عن عطاء، في قوله: <q>﴿المشحون﴾</q>، قال: المثقل{12}. (ز) ٥٦١٨٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿في الفلك المشحون﴾</q>، قال: المحمَّل{13}. (١١/٢٧٩) ٥٦١٩٠- عن قتادة بن دعامة: <q>﴿في الفلك المشحون﴾</q>، كُنّا نُحَدَّث: أنّه الموقر{2}. (١١/٢٧٩) ٥٦١٩١- قال مقاتل بن سليمان: <q>﴿فأنجيناه ومن معه في الفلك المشحون﴾</q>، يعني: الموقر مِن الناس والطير والحيوان كلها، من كل صنف ذكر وأنثى{15}. (ز) ٥٦١٩٢- قال يحيى بن سلّام: <q>﴿فأنجيناه ومن معه في الفلك المشحون﴾</q>، والمشحون: الموقر بحمله مما حمل نوح في السفينة من كل زوجين اثنين، ومَن معه من المؤمنين، كان معه امرأته وثلاثة بنين له: سام، وحام، ويافث، ونساؤهم، فجميعهم ثمانية{16}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٩١.علَّقه ابن أبي حاتم ٨/٢٧٩١. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٨/٢٧٩١.المُوقَرة: المثْقَلة، من الوِقر -بكسر الواو-: الحِمْل. النهاية (وقر).أخرجه الطستي -كما في الإتقان ٢/٨٠-.أخرجه ابن جرير ١٩/٤٤٢، وابن أبي حاتم -كما في الإتقان ٢/٣٩-.أخرجه ابن جرير ١٧/٦٠٤-٦٠٥، وابن أبي حاتم ٨/٢٧٩١ من طريق سعيد بن جبير. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٩/٤٤٢.أخرجه ابن جرير ١٧/٦٠٥، وابن أبي حاتم ٨/٢٧٩٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الثوري في تفسيره ص٢٢٩.تفسير الثعلبي ٧/١٧٣.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦٠٥. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٨/٢٧٩١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٧٣.تفسير يحيى بن سلّام ٢/٥١٣.
26,120," <q>﴿ثُمَّ أَغۡرَقۡنَا بَعۡدُ ٱلۡبَاقِینَ ۝١٢٠ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٢١ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٢٢﴾</q> - تفسير ٥٦١٩٣- قال مقاتل بن سليمان: <q>﴿ثم أغرقنا بعد﴾</q> أهل السفينة <q>﴿الباقين﴾</q> يعني: مَن بقي منهم مِمَّن لم يركب السفينة، <q>﴿إن في ذلك لآية﴾</q> يقول: إنّ في هلاك قوم نوح لعبرة لِمَن بعدهم مِن هذه الأمة، ليحذروا مثل عقوبتهم. ثم قال تعالى: <q>﴿وما كان أكثرهم مؤمنين﴾</q> يعني: مُصَدِّقين بتوحيد الله ﷿. يقول: كان أكثرهم كافرين بالتوحيد، ولو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا. ثم قال سبحانه: <q>﴿وإن ربك لهو العزيز﴾</q> في نِقْمَته منهم بالغرق، <q>﴿الرحيم﴾</q> بالمؤمنين إذ نَجّاهم من الغرق، إنّما ذكر الله تعالى تكذيب الأمم الخالية رسلهم لَمّا كذَّب كُفّار قريش النبيَّ ﷺ بالرسالة، أخبر الله ﷿ النبيَّ ﷺ أنه أرسله كما أرسل نوحًا وهودًا وصالحًا ولوطًا وشعيبًا، فكذبهم قومهم، فكذلك أنت، يا محمد. وذكر عقوبة الذين كذبوا رسلهم لئلا يُكَذِّب كفار قريش محمدًا ﷺ، فحذَّرهم مثلَ عذاب الأمم الخالية{1}. (ز) ٥٦١٩٤- قال يحيى بن سلّام: <q>﴿ثم أغرقنا بعد﴾</q> من أنجينا في السفينة <q>﴿الباقين﴾</q> وهم قوم نوح، وفيها تقديم، ثم أغرقنا الباقين بعد{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٣.تفسير يحيى بن سلّام ٢/٥١٣.
  26,121,""
  26,122,""
26,123," <q>﴿كَذَّبَتۡ عَادٌ ٱلۡمُرۡسَلِینَ ۝١٢٣﴾</q> - تفسير ٥٦١٩٥- عن الربيع بن خُثيم -من طريق أبي وائل- قال: كانت عادٌ ما بينَ اليمن إلى الشام مثل الذَّرِّ{1}. (٦/٤٤٧) ٥٦١٩٦- عن إسماعيل السُّدِّيّ، قال: إنّ عادًا كانوا قومًا باليمن بالأحقاف، والأحقاف: هي الرمال، فأتاهم، فوعظهم، وذكَّرهم بما قصَّ اللهُ في القرآن، فكذَّبوه، وسألوا أن يأتيهم بالعذاب{2}. (ز) ٥٦١٩٧- قال يحيى بن سلّام: قوله ﷿: <q>﴿كذبت عاد المرسلين﴾</q>، يعني: هودًا أخاهم{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٩٢.أخرجه ابن أبي حاتم ٨/٢٧٩٢. وقد تقدم بسط قصة عاد مع نبيهم هود في سورة الأعراف.تفسير يحيى بن سلّام ٢/٥١٣.
26,124," <q>﴿إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ هُودٌ أَلَا تَتَّقُونَ ۝١٢٤ إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٢٥ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٢٦ وَمَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٢٧﴾</q> - تفسير ٥٦١٩٨- تفسير إسماعيل السُّدِّيّ: <q>﴿ألا تتقون﴾</q> اللهَ، يقول: ألا تخشون الله{1}. (ز) ٥٦١٩٩- قال محمد بن السائب الكلبي: أمين فيكم قبل الرسالة، فكيف تتهموني اليوم؟!{2}. (ز) ٥٦٢٠٠- قال مقاتل بن سليمان: <q>﴿إذ قال لهم أخوهم هود﴾</q> ليس بأخيهم في الدين، ولكن أخوهم في النسب، <q>﴿ألا تتقون﴾</q> يعني: ألا تخشون الله ﷿، <q>﴿إني لكم رسول أمين﴾</q> فيما بينكم وبين ربكم، <q>﴿فاتقوا الله﴾</q> يعني: فاعبدوا الله، <q>﴿وأطيعون﴾</q> فيما آمركم به مِن النصيحة، <q>﴿وما أسألكم عليه من أجر﴾</q> يقول: لا أسالكم على الإيمان جُعْلًا، <q>﴿إن أجري﴾</q> يقول: ما أجري <q>﴿إلا على رب العالمين﴾</q>{3}. (ز) ٥٦٢٠١- قال يحيى بن سلّام: قوله ﷿: <q>﴿إذ قال لهم أخوهم هود﴾</q> أخوهم في النسب، وليس بأخيهم في الدين ...، <q>﴿ألا تتقون﴾</q> يأمرهم أن يتقوا الله، <q>﴿إني لكم رسول أمين﴾</q> على ما جئتُكم به، <q>﴿فاتقوا الله وأطيعون (١٠٨) وما أسألكم عليه﴾</q> أي: على ما جئتكم به <q>﴿من أجر إن أجري﴾</q> وثوابي <q>﴿إلا على رب العالمين﴾</q>{4}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ٢/٥١٣.تفسير الثعلبي ٧/١٧٤، وتفسير البغوي ٦/١٢٢.تفسير مقاتل بن سليمان ٣/٢٧٣.تفسير يحيى بن سلّام ٢/٥١٣.
  26,125,""
  26,126,""
  26,127,""
26,128," <q>﴿أَتَبۡنُونَ بِكُلِّ رِیعٍ﴾</q> - تفسير ٥٦٢٠٢- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿أتبنون بكل ريع﴾</q>، قال: طريق{1}. (١١/٢٨٠) ٥٦٢٠٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أتبنون بكل ريع﴾</q>، قال: شَرَفٌ{2}. (١١/٢٨٠) ٥٦٢٠٤- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- قوله: <q>﴿أتبنون بكل ريع﴾</q>، قال: بكل فجٍّ بين جبلين{3}. (١١/٢٨١) ٥٦٢٠٥- عن مجاهد بن جبر -من طريق مسلم بن خالد، عن ابن أبي نجيح- في قوله: <q>﴿أتبنون بكل ريع﴾</q>، قال: الرِّيع: الثنية الصغيرة{4}. (ز) ٥٦٢٠٦- عن مجاهد بن جبر -من طريق ابن جريج- قوله: <q>﴿أتبنون بكل ريع﴾</q>، قال: شَرَف، ومنظر{5}. (ز) ٥٦٢٠٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿بكل ريع﴾</q>: بكل طريق{6}. (ز) ٥٦٢٠٨- عن عكرمة مولى ابن عباس -من طريق ابن جريج- <q>﴿بكل ريع﴾</q>، قال: فجٍّ، وواد{1}. (ز) ٥٦٢٠٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿أتبنون بكل ريع﴾</q>، قال: بكل طريق{8}. (١١/٢٨٠) ٥٦٢١٠- عن إسماعيل السُّدِّيّ، قال: الرِّيع: ما استقبل الطريق بين الجبال والظِّراب{9}{10}. (١١/٢٧٠) ٥٦٢١١- عن عطاء الخراساني -من طريق ابنه عثمان- قال: وأمّا <q>﴿بكل ريع آية تعبثون﴾</q> فيُقال: بكل شَرَف ومنظر تبنون عبثًا{11}. (ز) ٥٦٢١٢- قال محمد بن السائب الكلبي، في قوله: <q>﴿بكل ريع﴾</q>: بكل طريق{12}. (ز) ٥٦٢١٣- قال مقاتل بن سليمان: <q>﴿أتبنون بكل ريع﴾</q>، يعني: طريق{13}. (ز) ٥٦٢١٤- عن أبي صخر [حميد بن زياد الخرّاط] -من طريق مفضل- قال: الرِّيع: الجبال، والأمكنة المرتفعة مِن الأرض{10}٤٨١٢. (١١/٢٨٠) ٤٨١٢ أفادت الآثار اختلاف عبارات المفسرين في الرِّيع، وهو ما علَّق عليه ابنُ عطية (٦/٤٩٧) بقوله: «وجملة ذلك: أنّه المكان المُشْرِف، وهو الذي يتنافس البشر في هيآته». وذكر ابنُ كثير (١٠/٣٥٩) أنّ حاصل أقول المفسرين في الريع: أنّه المكان المرتفع عند جواد الطرق المشهورة. ٥٦٢١٥- عن محمد بن إسحاق -من طريق سلمة- قال: فلمّا عَتَوْا على الله، وكَذَّبوا نبيهم، وأكثروا في الأرض؛ تَجَبَّروا، وبنوا بكل ريع آية عبثًا لغير نفع؛ كلَّمهم هود، فقال: <q>﴿أتبنون بكل ريع آية تعبثون* وتتخذون مصانع لعلكم تخلدون﴾</q>{15}. (ز) ٥٦٢١٦- قال يحيى بن سلّام: <q>﴿أتبنون﴾</q> على الاستفهام، أي: قد فعلتم{16}. (ز) <q>﴿ءَایَةࣰ﴾</q> - تفسير ٥٦٢١٧- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿آية﴾</q>، قال: عَلَمًا{5}. (١١/٢٨٠) ٥٦٢١٨- قال سعيد بن جبير: هذا في بُرُوج الحمام، أنكر عليهم هود ﵇ اتِّخاذها{18}. (ز) ٥٦٢١٩- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- في قوله: <q>﴿آية﴾</q>، قال: بُنيانًا{19}. (١١/٢٨١) ٥٦٢٢٠- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿بكل ريع آية﴾</q>، قال: بُنيان الحمام{20}. (ز) ٥٦٢٢١- قال مقاتل بن سليمان: <q>﴿آية﴾</q>، يعني: [طريقًا]{21}. (ز) ٥٦٢٢٢- قال يحيى بن سلّام: <q>﴿آية﴾</q>، أي: عَلَمًا{22}٤٨١٣. (ز) ٤٨١٣ ذكر ابنُ جرير (١٧/٦٠٩) أنّ الآية: هي الدلالة والعلامة مستندًا لأقوال أهل التأويل، حيث قال: «وبنحو الذي قلنا في ذلك قال أهل التأويل على اختلافٍ منهم في ألفاظهم في تأويله». <q>﴿تَعۡبَثُونَ ۝١٢٨﴾</q> - تفسير ٥٦٢٢٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿تعبثون﴾</q>، قال: تلعبون{23}. (١١/٢٨٠) ٥٦٢٢٤- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿تعبثون﴾</q>، قال: تلعبون{24}. (١١/٢٨١) ٥٦٢٢٥- عن قتادة بن دعامة، مثل ذلك{25}. (ز) ٥٦٢٢٦- قال مقاتل بن سليمان: <q>﴿تعبثون﴾</q>، يعني: تلعبون، وذلك أنّهم كانوا إذا سافروا لا يهتدون إلّا بالنجوم، فبنوا القصور الطِّوال عبثًا. يقول: عَلَمًا بكل طريق يهتدون بها في طريقهم{26}. (ز) ٥٦٢٢٧- قال يحيى بن سلّام: <q>﴿تعبثون﴾</q> تلعبون{22}. (ز) <q>﴿تَعۡبَثُونَ ۝١٢٨﴾</q> - آثار متعلقة بالآية ٥٦٢٢٨- عن مجاهد بن جبر -من طريق العلاء بن عبد الكريم- قال: ليس أحدٌ أشبهَ فعالًا بعادٍ مِن أُمَّة محمد ﷺ، قال: <q>﴿أتبنون بكل ريع آية تعبثون﴾</q>، فقد -واللهِ- فعلوا{11}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٦٠٨.أخرجه ابن جرير ١٧/٦٠٧، وابن أبي حاتم ٩/٢٧٩٣. وعزاه السيوطي إلى ابن المنذر.أخرجه الفريابي -كما في التغليق ٤/٢٧٢-، وابن جرير ١٧/٦٠٨، ٦١٠، ٦١١، وابن أبي حاتم ٩/٢٧٩٣-٢٧٩٤، وأخرجه يحيى بن سلّام ٢/٥١٤ من طريق ابن مجاهد. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٦٠٨، وابن أبي حاتم ٩/٢٧٩٣.أخرجه ابن جرير ١٧/٦٠٩.أخرجه ابن جرير ١٧/٦٠٩، وإسحاق البستي في تفسيره ص٥٣٥.أخرجه ابن جرير ١٧/٦٠٨.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦٠٩، وابن أبي حاتم ٩/٢٧٩٣ من طريق همام. وعلَّقه يحيى بن سلّام ٢/٥١٤. وعزاه السيوطي إلى عبد بن حميد.الظِراب: جمع الظَرِب، وهو الجبل الصغير. النهاية (ظرب).أخرجه ابن أبي حاتم ٩/٢٧٩٣.أخرجه ابن أبي حاتم ٩/٢٧٩٤.تفسير الثعلبي ٧/١٧٤، وتفسير البغوي ٦/١٢٢.تفسير مقاتل بن سليمان ٣/٢٧٣. وفي تفسير الثعلبي ٧/١٧٤، وفي تفسير البغوي ٦/١٢٢ مثله منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن أبي حاتم ٩/٢٧٩٣.أخرجه ابن أبي حاتم ٩/٢٧٩٥.تفسير يحيى بن سلّام ٢/٥١٣.أخرجه ابن جرير ١٧/٦٠٩.تفسير البغوي ٦/١٢٢.تفسير مجاهد ص٥١٢، وأخرجه الفريابي -كما في التغليق ٤/٢٧٢-، وابن جرير ١٧/٦١٠، وابن أبي حاتم ٩/٢٧٩٣-٢٧٩٤، وأخرجه يحيى بن سلّام ٢/٥١٤ من طريق ابن مجاهد. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٦١٠، وابن أبي حاتم ٩/٢٧٩٤ من طريق مسلم بن خالد عن ابن أبي نجيح بلفظ: اتخاذ أبرجة الحمام. وعلَّقه ابن أبي الدنيا في كتاب ذم الملاهي -موسوعة الإمام ابن أبي الدنيا ٥/٢٩٤- بلفظ: بروج الحمام.تفسير مقاتل بن سليمان ٣/٢٧٤.تفسير يحيى بن سلّام ٢/٥١٤.أخرجه ابن جرير ١٧/٦١٠.أخرجه ابن جرير ١٧/٦١٠، وإسحاق البستي في تفسيره ص٥٣٥. وعلَّقه ابن أبي حاتم ٩/٢٧٩٤.علَّقه ابن أبي حاتم ٩/٢٧٩٤.تفسير مقاتل بن سليمان ٣/٢٧٤. ونحوه في تفسير الثعلبي ٧/١٧٤.تفسير يحيى بن سلّام ٢/٥١٤.أخرجه ابن أبي حاتم ٩/٢٧٩٤.
26,129," <q>﴿وَتَتَّخِذُونَ مَصَانِعَ﴾</q> - تفسير ٥٦٢٢٩- قال عبد الله بن عباس: أبنية{1}. (ز) ٥٦٢٣٠- قال عبد الله بن عباس: قصور مَشِيدَة{2}. (ز) ٥٦٢٣١- عن مجاهد بن جبر -من طُرُقٍ- في قوله: <q>﴿وتتخذون مصانع﴾</q>، قال: بروج الحمام{3}. (١١/٢٨١) ٥٦٢٣٢- عن مجاهد بن جبر -من طريق ورْقاء، عن ابن أبي نجيح- قوله: <q>﴿وتتخذون مصانع﴾</q>، قال: قصورًا مَشِيدة، وبنيانًا مخلدًا{4}. (١١/٢٨١) ٥٦٢٣٣- قال الحسن البصري: <q>﴿وتتخذون مصانع﴾</q> البناء{5}. (ز) ٥٦٢٣٤- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿وتتخذون مصانع﴾</q>، قال: مآخِذ للماء{6}. (١١/٢٨١) ٥٦٢٣٥- قال محمد بن السائب الكلبي: القصور{5}. (ز) ٥٦٢٣٦- قال محمد بن السائب الكلبي: منازل{2}. (ز) ٥٦٢٣٧- قال محمد بن السائب الكلبي: الحصون{1}. (ز) ٥٦٢٣٨- قال مقاتل بن سليمان: <q>﴿وتتخذون مصانع﴾</q>، يعني: القصور؛ ليُذْكَروا بها: هذا منزل بني فلان، وبني فلان{10}. (ز) ٥٦٢٣٩- قال يحيى بن سلّام: ويُقال: مصانع للماء{11}٤٨١٤. (ز) ٤٨١٤ اختُلِف في معنى المصانع؛ فقال قوم: قصور مشيدة. وقال آخرون: مآخذ الماء. ورجَّح ابنُ جرير (١٧/٦١٢) جميعها للعموم، فقال: «والصواب من القول في ذلك أن يُقال: إنّ المصانع جمع مصنعة، والعرب تسمي كل بناء: مصنعة. وجائز أن يكون ذلك البناء كان قصورًا وحصونًا مشيدة، وجائز أن يكون كان مآخذ للماء، ولا خبر يقطع العذر بأي ذلك كان، ولا هو مِمّا يُدرَك مِن جهة العقل؛ فالصواب أن يُقال فيه ما قال الله: إنهم كانوا يتخذون مصانع». <q>﴿لَعَلَّكُمۡ تَخۡلُدُونَ ۝١٢٩﴾</q> - قراءات ٥٦٢٤٠- عن قتادة بن دعامة -من طريق مَعْمَر- قال: وكان في بعض القراءة: (وتَتَّخِذُونَ مَصانِعَ كَأَنَّكُمْ خالِدُونَ){12}. (١١/٢٨١) ٥٦٢٤١- عن قتادة بن دعامة -من طريق إسرائيل بن يونس، والخليل بن مرة- قال: كانت في الحرف الأول: (وتَتَّخِذُونَ مَصانِعَ كَأَنَّكُمْ تَخْلُدُونَ فِيها){13}. (ز) ٥٦٢٤٢- عن قتادة بن دعامة -من طريق سعيد- قال: في بعض القراءة: (كَأَنَّكُمْ خالِدُونَ فِي الدُّنْيا){14}. (ز) <q>﴿لَعَلَّكُمۡ تَخۡلُدُونَ ۝١٢٩﴾</q> - تفسير الآية ٥٦٢٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لعلكم تخلدون﴾</q>، قال:كأنّكم تخلدون{15}. (١١/٢٨٢) ٥٦٢٤٤- قال قتادة بن دعامة: يعني: كأنّكم تبقون فيها خالدين{16}. (ز) ٥٦٢٤٥- قال مقاتل بن سليمان: <q>﴿لعلكم﴾</q> يعني: كأنّكم <q>﴿تخلدون﴾</q> في الدنيا، فلا تموتون{10}. (ز) ٥٦٢٤٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وتتخذون مصانع لعلكم تخلدون﴾</q>، قال: هذا استفهام. يقول: لعلكم تخلدون حين تبنون هذه الأشياء؟!{18}. (ز) ٥٦٢٤٧- قال يحيى بن سلّام: <q>﴿لعلكم تخلدون﴾</q> في الدنيا، أي: لا تخلدون فيها{11}. (ز) <q>﴿لَعَلَّكُمۡ تَخۡلُدُونَ ۝١٢٩﴾</q> - آثار متعلقة بالآية ٥٦٢٤٨- عن عون بن عبد الله بن عتبة: أنّ أبا الدرداء لَمّا رأى ما أحدث المسلمون في الغُوطة مِن البنيان ونَصْبِ الشجر؛ قام في مسجدهم، فنادى: يا أهلَ دمشق. فاجتمعوا إليه، فحمِد الله، وأثنى عليه، ثم قال: ألا تستحيون! ألا تستحيون! تجمعون ما لا تأكلون، وتبنون ما لا تسكنون، وتأملون ما لا تُدْرِكون، قد كانت قبلكم قرون، يجمعون فيُوعون، ويبنون فيوثقون، ويأملون فيُطِيلون، فأصبح أملُهم غرورًا، وأصبح جمعُهم بُورًا، وأصبحت مساكنهم قبورًا، ألا إنّ عادًا ملكت ما بين عدنٍ وعمان خيلًا ورِكابًا، فمن يشتري مِنِّي ميراثَ عاد بدرهمين؟{20}. (ز) ",footnotes:1:تفسير البغوي ٦/١٢٣.تفسير الثعلبي ٧/١٧٤.أخرجه الفريابي -كما في التغليق ٤/٢٧٢-، وابن جرير ١٧/٦٠٨، ٦١٠ من طريق مسلم عن رجل، وابن أبي حاتم ٩/٢٧٩٤ من طريق مسلم الزنجي عن ابن أبي نجيح. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦١١ من طريق معمر بلفظ: حصون وقصور، وابن أبي حاتم ٩/٢٧٩٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلّام ٢/٥١٤.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦١١، وابن أبي حاتم ٩/٢٧٩٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلّام ٢/٥١٤.تفسير الثعلبي ٧/١٧٤.تفسير البغوي ٦/١٢٣.تفسير مقاتل بن سليمان ٣/٢٧٤.تفسير يحيى بن سلّام ٢/٥١٤.أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٦١١، وابن أبي حاتم ٩/٢٧٩٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. والقراءة شاذة. انظر: الجامع لأحكام القرآن ١٦/٥٧.أخرجه يحيى بن سلّام ٢/٥١٤. وهي قراءة شاذة، تروى أيضًا عن أُبَيّ. انظر: البحر المحيط ٦/٣١.أخرجه يحيى بن سلّام ٢/٥١٤. وهي قراءة شاذة.أخرجه ابن جرير ١٧/٦١٢، وابن أبي حاتم ٩/٢٧٩٥. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٧/١٧٥.تفسير مقاتل بن سليمان ٣/٢٧٤.أخرجه ابن جرير ١٧/٦١٢، وابن أبي حاتم ٩/٢٧٩٥ من طريق أصبغ، وفيه بلفظ: هذا استثناء.تفسير يحيى بن سلّام ٢/٥١٤.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/١٥٣-.
26,130," <q>﴿وَإِذَا بَطَشۡتُم بَطَشۡتُمۡ جَبَّارِینَ ۝١٣٠﴾</q> - تفسير ٥٦٢٤٩- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿بطشتم جبارين﴾</q>، قال: أقوياء{1}. (١١/٢٨٢) ٥٦٢٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإذا بطشتم بطشتم جبارين﴾</q>، قال: بالسَّوْط، والسيف{2}. (١١/٢٨٢) ٥٦٢٥١- قال إسماعيل السُّدِّيّ: <q>﴿بطشتم جبارين﴾</q>، يعني: قتّالين. يقول: إذا عاقبتم أسرفتم في العقوبة، جعلتم مكان الضرب قَتْلًا. يقول: إذا أخذتم أخذتم؛ فقتلتم في غير حقٍّ{3}. (ز) ٥٦٢٥٢- قال عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿وإذا بطشتم بطشتم جبارين﴾</q>، قال: القتل بالسيف، والسِّياط{4}. (ز) ٥٦٢٥٣- قال مقاتل بن سليمان: <q>﴿وإذا بطشتم بطشتم جبارين﴾</q>، يقول: إذا أخذتم أخذتم فقتلتم في غير حقٍّ، كفعل الجبارين، والجبّار مَن يقتل بغير حق{5}. (ز) ٥٦٢٥٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإذا بطشتم﴾</q> بالمؤمنين <q>﴿بطشتم جبارين﴾</q> يعني: قتّالين، تَعْدُون عليهم. هودٌ يقوله لهم، أي: أسرفتم في العقوبة{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٧٩٥.أخرجه ابن أبي الدنيا في كتاب التواضع -موسوعة الإمام ابن أبي الدنيا ٣/٥٧٤ (٢٠٢)- دون ذكر السوط، وإسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٧٩٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلّام ٢/٥١٥.أخرجه ابن جرير ١٧/٦١٣.تفسير مقاتل بن سليمان ٣/٢٧٤.تفسير يحيى بن سلّام ٢/٥١٤.
26,131," <q>﴿فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٣١ وَٱتَّقُوا۟ ٱلَّذِیۤ أَمَدَّكُم بِمَا تَعۡلَمُونَ ۝١٣٢ أَمَدَّكُم بِأَنۡعَـٰمࣲ وَبَنِینَ ۝١٣٣ وَجَنَّـٰتࣲ وَعُیُونٍ ۝١٣٤﴾</q> - تفسير ٥٦٢٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح - قوله: <q>﴿جنات﴾</q>، قال: حَوائِط{1}. (ز) ٥٦٢٥٦- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿أنعام﴾</q> قال: الراعية، <q>﴿وجنات﴾</q> قال: البساتين{1}. (ز) ٥٦٢٥٧- قال مقاتل بن سليمان: <q>﴿واتقوا الذي أمدكم﴾</q> يقول: اتقوا الله الذى أعطاكم <q>﴿بما تعلمون﴾</q> مِن الخير. ثم أخبر بالذي أعطاهم، فقال سبحانه: <q>﴿أمدكم بأنعام وبنين * وجنات﴾</q> يقول: البساتين، <q>﴿وعيون﴾</q> يعني: وأنهار جارية، أعطاهم هذا الخيرَ كله{3}. (ز) ٥٦٢٥٨- قال يحيى بن سلّام: <q>﴿واتقوا الذي أمدكم بما تعلمون﴾</q> ثم أخبر بالذي أمدَّهم به، فقال: <q>﴿أمدكم بأنعام وبنين (١٣٣) وجنات وعيون (١٣٤)﴾</q>{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٧٩٦.أخرجه ابن أبي حاتم ٩/٢٧٩٦.تفسير مقاتل بن سليمان ٣/٢٧٤.تفسير يحيى بن سلّام ٢/٥١٥.
