tafsir[10]{c,v,t}:
20,126," <q>﴿قَالَ كَذَ ٰ⁠لِكَ أَتَتۡكَ ءَایَـٰتُنَا فَنَسِیتَهَاۖ وَكَذَ ٰ⁠لِكَ ٱلۡیَوۡمَ تُنسَىٰ ۝١٢٦﴾</q> - تفسير ٤٨٥٥٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿قالَ كَذَلِكَ أتَتْكَ آياتُنا فَنَسِيتَها﴾</q> قال: فتَرَكْتُها، <q>﴿وكَذَلِكَ اليَوْمَ تُنْسى﴾</q> وكذلك اليوم تُتْرَك في النار{1}. (١٠/٢٥٩) ٤٨٥٦٠- عن عكرمة مولى ابن عباس -من طريق جابر- في قوله: <q>﴿وكذلك اليوم تنسى﴾</q>، قال: في النار{2}. (١٠/٢٦٠) ٤٨٥٦١- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿وكذلك اليوم تنسى﴾</q>، قال: في النار{3}. (ز) ٤٨٥٦٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قال كذلك أتتك آياتنا فنسيتها وكذلك اليوم تنسى﴾</q>، قال: نُسِي مِن الخير، ولم يُنسَ مِن الشَّرِّ{4}٤٣١٩. (ز) ٤٣١٩ ذكر ابنُ جرير (١٦/٢٠٣) اختلافًا في معنى: <q>﴿وكَذَلِكَ اليَوْمَ تُنْسى﴾</q> على قولين: الأول: وكذلك اليوم تُنسى في النار. وهو قول أبي صالح، ومجاهد. والثاني: وكذلك اليوم تُنسى من الخير، ولم تُنسَ مِن الشر. وهو قول قتادة. ووجَّه قول قتادة قائلًا: «وهذا القول الذي قاله قتادة قريب المعنى مما قاله أبو صالح ومجاهد؛ لأن تَرْكَه إياهم في النار من أعظم الشر لهم». ٤٨٥٦٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿أتتك آياتنا فنسيتها﴾</q>: يقول: تركتَها أن تعمل بها، <q>﴿وكذلك اليوم تنسى﴾</q> قال: تُتْرك مِن الخير{5}. (١٠/٢٦٠) ٤٨٥٦٤- قال مقاتل بن سليمان: <q>﴿قال﴾</q> الله تعالى: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿أتتك آياتنا﴾</q> يعني: آيات القرآن <q>﴿فنسيتها﴾</q> يعني: فتركت إيمانًا بآيات القرآن، <q>﴿وكذلك اليوم تنسى﴾</q> في الآخرة تترك في النار، ولا تخرج منها، ولا نذكرك{6}. (ز) ٤٨٥٦٥- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿وكذلك أتتك آياتنا فنسيتها﴾</q> قال: فتركتها، <q>﴿وكذلك اليوم تنسى﴾</q> تُتْرَك{7}. (ز) ٤٨٥٦٦- قال يحيى بن سلّام: قال الله -تبارك وتعالى-: <q>﴿قال كذلك أتتك آياتنا فنسيتها وكذلك اليوم تنسى﴾</q> أي: لأنّه أتَتْك آياتنا في الدنيا <q>﴿فنسيتها﴾</q> فتركتها، لم تؤمن بها، <q>﴿وكذلك اليوم تنسى﴾</q> تُتْركُ في النار{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٠٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٩٠، وهناد في الزهد (٢٢٢).أخرجه ابن جرير ١٦/٢٠٣.أخرجه ابن جرير ١٦/٢٠٣. وعلَّقه يحيى بن سلّام ١/٢٩٠، وعقَّب عليه بقوله: أي: تُرك مِن الخير، ولم يُترك من الشر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٥.أخرجه إسحاق البستي في تفسيره ص٢٨٤.تفسير يحيى بن سلّام ١/٢٩٠.
20,127," <q>﴿وَكَذَ ٰ⁠لِكَ نَجۡزِی مَنۡ أَسۡرَفَ وَلَمۡ یُؤۡمِنۢ بِـَٔایَـٰتِ رَبِّهِۦۚ وَلَعَذَابُ ٱلۡـَٔاخِرَةِ أَشَدُّ وَأَبۡقَىٰۤ ۝١٢٧﴾</q> - تفسير ٤٨٥٦٧- قال مقاتل بن سليمان: <q>﴿وكذلك نجزي من أسرف﴾</q> يعني: وهكذا نجزي مَن أشرك في الدنيا بالنار في الآخرة، <q>﴿ولم يؤمن بآيات ربه﴾</q> يقول: ولم يؤمن بالقرآن، <q>﴿ولعذاب الآخرة أشد﴾</q> مِمّا أصابه في الدنيا مِن القتل ببدر، <q>﴿وأبقى﴾</q> يعني: وأدوم من عذاب الدنيا{1}. (ز) ٤٨٥٦٨- عن سفيان، في قوله: <q>﴿وكذلك نجزي من أسرف﴾</q>، قال: مَن أشرك{2}. (١٠/٢٦٠) ٤٨٥٦٩- قال يحيى بن سلّام: قوله: <q>﴿وكذلك نجزي من أسرف﴾</q> مَن أشرك؛ أسرف على نفسه بالشرك، <q>﴿ولم يؤمن بآيات ربه ولعذاب الآخرة أشد﴾</q> مِن عذاب الدنيا، <q>﴿وأبقى﴾</q> أي: لا ينقطع أبدًا{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٩٠.
20,128," <q>﴿أَفَلَمۡ یَهۡدِ لَهُمۡ﴾</q> - قراءات الآية، وتفسيرها ٤٨٥٧٠- عن عبد الله بن عباس، في قوله: <q>﴿أفَلَمْ يَهْدِ لَهُمْ﴾</q>، قال: ألم نُبَيِّن لهم؟{1}. (١٠/٢٦٠) ٤٨٥٧١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أفَلَمْ يَهْدِ لَهُمْ﴾</q>، قال: أفلم نبيِّن لهم؟{2}. (١٠/٢٦٠) ٤٨٥٧٢- قال الحسن البصري: ([أفَلَمْ نَهْدِ لَهُمْ] كَمْ أهْلَكْنا قَبْلَهُم مِّنَ القُرُونِ)، أي: بيَّنا لهم، فقرأه على النون، كيف أهلكنا القرون الأولى، نُحَذِّرهم ونُخَوِّفهم العذاب إن لم يؤمنوا{3}. (ز) ٤٨٥٧٣- قال يحيى بن سلّام: ومَن قرأها بالياء يقول: <q>﴿أفَلَمْ يَهْدِ لَهُمْ﴾</q>: أفلم يُبَيِّن الله لهم. ولا أعرف أيَّ المقرأتين قرأ قتادة{4}. (ز) ٤٨٥٧٤- تفسير إسماعيل السُّدِّيّ قوله: <q>﴿أفَلَمْ يَهْدِ لَهُمْ﴾</q>، قال: أفلم نبين لهم{5}. (ز) <q>﴿كَمۡ أَهۡلَكۡنَا قَبۡلَهُم مِّنَ ٱلۡقُرُونِ یَمۡشُونَ فِی مَسَـٰكِنِهِمۡۚ﴾</q> - تفسير ٤٨٥٧٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كم أهلكنا قبلهم من القرون يمشون في مساكنهم﴾</q>: نحو عاد، وثمود، ومَن أُهلِك من الأمم{6}. (١٠/٢٦٠) ٤٨٥٧٦- قال إسماعيل السُّدِّيّ: <q>﴿يمشون في مساكنهم﴾</q>، يعني: يَمُرُّون، يعني: ممرُّ أهل مكة على مساكنهم، يعني: على قراهم{5}. (ز) ٤٨٥٧٧- قال مقاتل بن سليمان: ثم خَوَّف كُفّار مكة، فقال سبحانه: <q>﴿أفلم يهد لهم﴾</q> يقول: أوَلَم نُبَيِّن لهم <q>﴿كم أهلكنا﴾</q> بالعذاب <q>﴿قبلهم من القرون يمشون في مساكنهم﴾</q> يقول: يمرون في قراهم فيرون هلاكَهم، يعني: عادًا، وثمودًا، وقوم لوط، وقوم شعيب{8}. (ز) ٤٨٥٧٨- قال يحيى بن سلّام: قوله: <q>﴿يمشون في مساكنهم﴾</q> تمشي هذه الأمة في مساكن مَن مضى، أي: يمرون عليها، وإن لم تكن الديار قائمة، ولكن المواضع. كقوله: <q>﴿ذلك من أنباء القرى نقصه عليك﴾</q> ثم قال: <q>﴿منها قائم﴾</q> تراه، <q>﴿وحصيد﴾</q> [هود:١٠٠] لا تراه{4}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّأُو۟لِی ٱلنُّهَىٰ ۝١٢٨﴾</q> - تفسير ٤٨٥٧٩- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿لأولي النهى﴾</q>، يقول: التُّقى{10}. (ز) ٤٨٥٨٠- قال الحسن البصري: لأولي العقول، وهم المؤمنون{5}. (ز) ٤٨٥٨١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إن في ذلك لآيات لأولي النهى﴾</q>: أهل الوَرَع{12}. (ز) ٤٨٥٨٢- قال مقاتل بن سليمان: <q>﴿إن في ذلك﴾</q> يعني: إنّ في هلاكهم بالعذاب في الدنيا <q>﴿لآيات﴾</q> لعبرة <q>﴿لأولي النهى﴾</q> يعني: لِذوي العقول، فيَحْذَرُون مثلَ عقوبتهم{8}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٩١. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلّام ١/٢٩١. و<q>﴿أفَلَمْ يَهْدِ لَهُمْ كَمْ أهْلَكْنا قَبْلَهُم مِّنَ القُرُونِ﴾</q> قراءة العشرة، والقراءة بالنون شاذة.تفسير يحيى بن سلّام ١/٢٩١.علقه يحيى بن سلّام ١/٢٩١.أخرجه ابن جرير ١٦/٢٠٤. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلّام ١/٢٩١.تفسير مقاتل بن سليمان ٣/٤٥.تفسير يحيى بن سلّام ١/٢٩١.أخرجه ابن جرير ١٦/٢٠٦.علقه يحيى بن سلّام ١/٢٩١.أخرجه ابن جرير ١٦/٢٠٦. وعلقه يحيى بن سلّام ١/٢٩١.تفسير مقاتل بن سليمان ٣/٤٥.
20,129," <q>﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ لَكَانَ لِزَامࣰا وَأَجَلࣱ مُّسَمࣰّى ۝١٢٩﴾</q> - تفسير ٤٨٥٨٣- عن عبد الله بن مسعود -من طريق ابن سيرين-: كان اللزام يوم بدر{1}. (ز) ٤٨٥٨٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لكان لزاما﴾</q>، قال: مَوْتًا{2}. (١٠/٢٦١) ٤٨٥٨٥- عن أبي هريرة أنّه قال لكعب: سمعتَ رسول الله ﷺ يقول: «خيرُ يوم طلعت فيه الشمس وغابت يومُ الجمعة»؟. فقال كعب: نعم، إنّ الله خلق الخلق يوم الأحد حتى انتهى إلى الجمعة، فخلق آدم آخرَ ساعات النهار يوم الجمعة، فلمّا استوى عطس، فقال: الحمد لله. فقال الله له: يرحمك الله. فهي الآية: <q>﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</q>{1}. (ز) ٤٨٥٨٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</q>، قال: الأجل المسمى: الموت. وفيه تقديم وتأخير، يقول: لولا كلمة سبقت من ربك وأجل مسمى لكان لِزامًا{4}. (ز) ٤٨٥٨٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</q>، قال: أجل مسمى: الدنيا{5}. (١٠/٢٦١) ٤٨٥٨٨- عن مجاهد بن جبر، في الآية، قال: الأجل المسمى: الكَلِمةُ التي سَبَقَتْ مِن ربك{6}. (١٠/٢٦١) ٤٨٥٨٩- تفسير الحسن البصري: قوله: <q>﴿ولولا كلمة سبقت من ربك﴾</q> ألّا تُعَذَّب هذه الأمة بعذاب الاستئصال إلا بالساعة، يعني: النفخة الأولى؛ <q>﴿لكان لزاما وأجل مسمى﴾</q>{7}. (ز) ٤٨٥٩٠- عن الحسن البصري -في تفسير عمرو [بن عبيد]- قال: وهو هلاكُ آخِرِ كُفّار هذه الأمة بالنفخة الأولى؛ الدائِنين بدين أبي جهل وأصحابه{1}. (ز) ٤٨٥٩١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</q>: وهذه مِن مقاديم الكلام. يقول: لولا كلمةٌ سبقت من ربك إلى أجل مسمى كان لزامًا، والأجل المسمى: الساعة؛ لأن الله يقول: <q>﴿بل الساعة موعدهم والساعة أدهى وأمر﴾</q> [القمر:٤٦]{9}. (١٠/٢٦٠) ٤٨٥٩٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولولا كلمة سبقت من ربك لكان لزاما﴾</q>، قال: لكان أخذًا، ولَكِنّا أخَّرناهم إلى يوم بدر، وهو اللزام، وتفسيرها: ولولا كلمة سبقت من ربك وأجل مسمى لكان لزامًا. ولكنه تقديم وتأخير في الكلام{10}. (١٠/٢٦١) ٤٨٥٩٣- قال مقاتل بن سليمان: <q>﴿ولولا كلمة سبقت من ربك﴾</q> في تأخير العذاب عنهم إلى تلك المدة؛ <q>﴿لكان لزاما وأجل مسمى﴾</q> يعني: يوم القيامة، <q>﴿لكان لزاما﴾</q> لَلَزِمهم العذاب في الدنيا كلزوم الغريمِ الغريمَ {11}. (ز) ٤٨٥٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</q>، قال: هذا مقدم ومؤخر، ولولا كلمة سبقت من ربك وأجل مسمى لكان لزامًا. واللزام: القتل{12}. (ز) ٤٨٥٩٥- قال يحيى بن سلّام: <q>﴿لكان لزاما﴾</q> يعني: أخذًا بالعذاب، يلزمون عقوبة كفرهم ... وفي الآخرة النار ... يقول: ولولا كلمة سبقت من ربك وأجل مسمى لكان لزامًا، ولذلك ارتفع الأجل والكلمة، أي: إذًا لأهلكناهم بجحودهم جميعًا ما جاء به النبي ﷺ. وقد كان اللزام خاصة فيمن أهلك الله يوم بدر في قول عبد الله بن مسعود{13}٤٣٢٠. (ز) ٤٣٢٠ أفادت الآثار اختلاف المفسرين في المراد بـ«الأجل المسمى» على أقوال: الأول: أنه يوم القيامة. الثاني: أنه موت كل واحد منهم، وانقضاء آجالهم. الثالث: أنه يوم بدر. ووجَّه ابنُ عطية (٦/١٤٤) القول الأول بقوله: «والعذاب المتوعَّد به -على هذا- هو عذاب جهنم». ووجَّه القول الثاني بقوله: «فالعذاب -على هذا- ما يَلْقى في قبره وما بعده». ووجَّه القول الثالث بقوله: «فالعذاب -على هذا- هو قتلهم بالسيف». ",footnotes:1:أخرجه يحيى بن سلّام ١/٢٩٢.أخرجه ابن جرير ١٦/٢٠٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٩٢.تفسير مجاهد ص٤٦٨.أخرجه ابن جرير ١٦/٢٠٧. وعزاه السيوطي إلى أبي نصر السجزي في الإبانة.عزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلّام ١/٢٩١.أخرجه يحيى بن سلّام ١/٢٩٢.أخرجه ابن جرير ١٦/٢٠٧. وعلَّقه يحيى بن سلّام ١/٢٩٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٦.أخرجه ابن جرير ١٦/٢٠٨.علَّقه يحيى بن سلّام ١/٢٩٢.
20,130," <q>﴿فَٱصۡبِرۡ عَلَىٰ مَا یَقُولُونَ وَسَبِّحۡ بِحَمۡدِ رَبِّكَ﴾</q> - تفسير ٤٨٥٩٦- قال مقاتل بن سليمان: <q>﴿فاصبر على ما يقولون﴾</q> مِن تكذيبِهم إيّاك بالعذابِ، <q>﴿وسبح بحمد ربك﴾</q> يعني: صلِّ بأمر ربك{1}٤٣٢١. (ز) ٤٣٢١ وجَّه ابنُ تيمية (٤/٣٤٦) قول من قال بأن معنى: <q>﴿وسَبِّحْ بِحَمْدِ رَبِّكَ﴾</q>: فصل بأمر ربك، فقال: «وتوجيه هذا أن قوله:»بحمده«أي: بكونه محمودًا، كما قد قيل في قول القائل: سبحان الله وبحمده؛ قيل: سبحان الله ومع حمده أسبِّحه، أو أسبِّحه بحمدي له، وقيل: سبحان الله وبحمده سبَّحناه، أي: هو المحمود على ذلك، كما تقول: فعلتُ هذا بحمد الله، وصلينا بحمد الله، أي: بفضله وإحسانه الذي يَستحقُّ الحمدَ عليه، وهو يرجع إلى الأول، كأنه قال: بحمدِنا لله فإنه المستحق لأن نحمده على ذلك. وإذا كان ذلك بكونه المحمود على ذلك فهو المحمود على ذلك، حيث كان هو الذي أمَر بذلك وشَرَعَه، فإذا سبَّحنا سبَّحنا بحمده، كما قال تعالى: <q>﴿لَقَدْ مَنَّ اللَّهُ عَلى المُؤْمِنِينَ إذْ بَعَثَ فِيهِمْ رَسُولًا مِن أنْفُسِهِمْ﴾</q> الآية [آل عمران:١٦٤]. وقد يكون القائل الذي قال:»فسبح بحمد ربك«أي: بأمره؛ أراد: المأمور به، أي: سبّحه بما أمرك أن تُسبِّحه به، فيكون المعنى: سَبِّح التسبيحَ الذي أمركَ ربُّك به، كالصلاة التي أمرك بها. وقولنا: صليتُ بأمر الله، وسبَّحتُ بأمر الله. يتناول هذا وهذا، يتناول أنه أمرَ بذلك ففَعَلْتُه بأمْرِه لم أبتدعْه، وأني فعلتُ بما أمرني به لم أبتدعْ». ٤٨٥٩٧- قال يحيى بن سلّام: قوله: <q>﴿فاصبر على ما يقولون﴾</q> مِن قولهم لك: إنّك ساحرٌ، وإنك شاعرٌ، وإنك مجنونٌ، وإنك كاذبٌ، وإنك كاهنٌ{2}. (ز) <q>﴿قَبۡلَ طُلُوعِ ٱلشَّمۡسِ وَقَبۡلَ غُرُوبِهَاۖ﴾</q> - تفسير ٤٨٥٩٨- عن جرير بن عبد الله، عن النبي ﷺ، في قوله: <q>﴿وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</q>، قال: «<q>﴿قبل طلوع الشمس﴾</q> صلاة الصبح، <q>﴿وقبل غروبها﴾</q> صلاة العصر»{3}. (١٠/٢٦٢) ٤٨٥٩٩- عن جرير بن عبد الله، قال: قال رسول الله ﷺ: «إنّكم سترون ربكم كما ترون هذا القمر، لا تُضامُونَ{4} في رؤيته، فإن استطعتم أن لا تُغْلَبوا على صلاة قبل طلوع الشمس وقبل غروبها؛ فافعلوا». ثم قرأ: <q>﴿وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</q>{5}. (١٠/٢٦٢) ٤٨٦٠٠- عن عبد الله بن عباس -من طريق أبي رَزِين- في قوله: <q>﴿وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</q>، قال: هي الصلاة المكتوبة{6}. (١٠/٢٦١) ٤٨٦٠١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وسبح بحمد ربك قبل طلوع الشمس﴾</q> قال: هي صلاة الفجر، <q>﴿وقبل غروبها﴾</q> قال: صلاة العصر{7}. (١٠/٢٦١) ٤٨٦٠٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وسبح بحمد ربك قبل طلوع الشمس﴾</q> قال: صلاة الصبح. <q>﴿وقبل غروبها﴾</q> الظهر والعصر{8}. (ز) ٤٨٦٠٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</q>، قال: كان هذا قبل أن تُفرَض الصلاة{9}. (١٠/٢٦٢) ٤٨٦٠٤- قال مقاتل بن سليمان: <q>﴿قبل طلوع الشمس﴾</q> يعني: الفجر، <q>﴿وقبل غروبها﴾</q> يعني: الظهر والعصر{1}. (ز) ٤٨٦٠٥- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</q>، قال: العصر{11}. (ز) <q>﴿وَمِنۡ ءَانَاۤىِٕ ٱلَّیۡلِ فَسَبِّحۡ وَأَطۡرَافَ ٱلنَّهَارِ﴾</q> - تفسير ٤٨٦٠٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ومن آناء الليل فسبح﴾</q>، قال: آناء الليل: جَوْف الليل{12}. (ز) ٤٨٦٠٧- قال عبد الله بن عباس -من طريق ابن جريج- <q>﴿ومن آناء الليل﴾</q>، قال: المصلّى من الليل كله{11}. (ز) ٤٨٦٠٨- قال عبد الله بن عباس: يريد: أول الليل{14}. (ز) ٤٨٦٠٩- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿ومن آناء الليل﴾</q>: يعني: الليل كله{15}. (ز) ٤٨٦١٠- عن عكرمة مولى ابن عباس، في قوله: <q>﴿ومن آناء الليل فسبح وأطراف النهار﴾</q>، قال: بعد الصبح، وعند غروب الشمس{16}. (١٠/٢٦٣) ٤٨٦١١- عن أبي رجاء، قال: سمعتُ الحسن البصري قرأ: <q>﴿ومن آناء الليل﴾</q>، قال: مِن أوله، وأوسطه، وآخره{12}. (ز) ٤٨٦١٢- عن الحسن البصري: <q>﴿فسبح وأطراف النهار﴾</q>، يعني: التطوع{18}. (ز) ٤٨٦١٣- عن الحسن البصري -من طريق قرة بن خالد- في قوله: <q>﴿وأقم الصلاة طرفي النهار﴾</q> قال: ما بين صلاة الصبح وصلاة العصر، <q>﴿وزلفا من الليل﴾</q> [هود:١١٤] المغرب والعشاء{8}. (ز) ٤٨٦١٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ومن آناء الليل﴾</q> قال: صلاة المغرب والعشاء، <q>﴿وأطراف النهار﴾</q> قال: صلاة الظهر{7}٤٣٢٢. (١٠/٢٦١) ٤٣٢٢ وجَّه ابنُ عطية (٦/١٤٥) قول قتادة قائلًا: «وأمّا من قال: <q>﴿وأَطْرافَ النَّهارِ﴾</q> لصلاة الظهر وحدها فلا بدَّ له مِن أنْ يتمسك بأن يكون النهار للجنس كما قلنا، أو يقول: إنّ النهار ينقسم قسمين؛ فصَلَهُما الزوال، ولكل قسم طرفان، فعند الزوال طرفان، الآخِر من القسم الأول، والأول من القسم الآخر، فقال عن الطرفين: أطرافًا، على نحو: <q>﴿فَقَدْ صَغَتْ قُلُوبُكُما﴾</q> [التحريم:٤]». ٤٨٦١٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومن آناء الليل﴾</q>: يعني: المغرب والعشاء{8}. (ز) ٤٨٦١٦- قال قتادة بن دعامة= (ز) ٤٨٦١٧- وإسماعيل السُّدِّيّ: <q>﴿ومن آناء الليل﴾</q>، يعني: ومِن ساعات الليل{22}. (ز) ٤٨٦١٨- قال مقاتل بن سليمان: <q>﴿ومن آناء الليل﴾</q> يعني: المغرب والعشاء <q>﴿فسبح وأطراف النهار﴾</q> ... قال مقاتل: كانت الصلاة ركعتين بالغَداةِ، وركعتين بالعَشِي، فلمّا عُرِج بالنبي ﷺ فُرِضَت عليه خمس صلوات؛ ركعتين ركعتين غير المغرب، فلما هاجر إلى المدينة أُمِر بتمام الصلوات، ولها ثلاثة أحوال{1}. (ز) ٤٨٦١٩- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿وأطراف النهار﴾</q>، قال: المكتوبة{11}. (ز) ٤٨٦٢٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومن آناء الليل فسبح وأطراف النهار﴾</q>، قال: <q>﴿من آناء الليل﴾</q>: العتمة، <q>﴿وأطراف النهار﴾</q>: المغرب والصبح{11}. (ز) <q>﴿لَعَلَّكَ تَرۡضَىٰ ۝١٣٠﴾</q> - قراءات ٤٨٦٢١- عن أبي عبد الرحمن [السلمي] -من طريق عاصم- أنّه قرأ: ‹لَعَلَّكَ تُرْضى› برفع التاء{26}. (١٠/٢٦٣) <q>﴿لَعَلَّكَ تَرۡضَىٰ ۝١٣٠﴾</q> - تفسير الآية ٤٨٦٢٢- قال الحسن البصري: أي: فإنّك سترضى ثوابَ عملِك في الآخرةِ{27}. (ز) ٤٨٦٢٣- قال مقاتل بن سليمان: <q>﴿لعلك ترضى﴾</q> يا محمدُ في الآخرةِ بثوابِ اللهِ ﷿{1}. (ز) ٤٨٦٢٤- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿لعلك ترضى﴾</q>، قال: بما تُعْطى{29}. (ز) ٤٨٦٢٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لعلك ترضى﴾</q>، قال: الثوابَ؛ ترضى فيما يزيدُك اللهُ على ذلك{30}. (١٠/٢٦٣) ٤٨٦٢٦- قال يحيى بن سلّام: قوله: <q>﴿لعلك ترضى﴾</q> لكي ترضى في الآخرة ثوابَ عملِك{31}. (ز) <q>﴿لَعَلَّكَ تَرۡضَىٰ ۝١٣٠﴾</q> - آثار متعلقة بالآية ٤٨٦٢٧- عن عُمارة بن رُوَيْبَة، قال: سمعتُ رسول الله ﷺ يقول: «لن يَلِجَ النارَ أحدٌ صَلّى قبل طلوع الشمس، وقبل غروبها»{32}. (١٠/٢٦٣) ٤٨٦٢٨- عن فضالة بن وهب الليثي، أنّ النبي ﷺ قال له: «حافِظْ على العَصْرَيْن». قلت: وما العصران؟ قال: «صلاة قبل طلوع الشمس وقبل غروبها»{33}. (١٠/٢٦٣) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٦.تفسير يحيى بن سلّام ١/٢٩٢.أخرجه الطبراني في الكبير ٢/٣٠٨ (٢٢٨٣)، وابن عساكر في تاريخه ٤١/٢٤٨. قال الهيثمي في المجمع ٧/٦٧ (١١١٧٢): «وفيه يحيى بن سعيد العطار، وهو ضعيف».تُضامون -بتشديد الميم وتخفيفها-: فالتشديد معناه: لا يَنضَمُّ بَعضُكم إلى بَعْض وتَزْدَحِمون وقتَ النَّظَر إليه. ومعنى التخفيف: لا يَنالُكم ضَيمٌ في رُؤْيتِه، فَيراه بعضُكم دُونَ بعضٍ. النهاية (ضمم).أخرجه البخاري ١/١١٥ (٥٥٤)، ١/١١٩ (٥٧٣)، ٦/١٣٩ (٤٨٥١)، ٩/١٢٧ (٧٤٣٤، ٧٤٣٥، ٧٤٣٦)، ومسلم ١/٤٣٩ (٦٣٣)، ويحيى بن سلّام ١/٢٩٣، وابن جرير ١٦/٢١٠.أخرجه يحيى بن سلّام ١/٢٩٣، وعبد الرزاق ٢/٢١، وابن المنذر في الأوسط ٢/٣٢٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٢١، وابن جرير ١٦/٢١١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٩٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٦.أخرجه ابن جرير ١٦/٢١١.أخرجه ابن جرير ١٦/٢١٢.أخرجه ابن جرير ١٦/٢١١.تفسير البغوي ٥/٣٠٢.أخرجه إسحاق البستي في تفسيره ص٢٨٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٢١٢.علَّقه يحيى بن سلّام ١/٢٩٣.أخرجه يحيى بن سلّام ١/٢٩٣.أخرجه عبد الرزاق ٢/٢١، وابن جرير ١٦/٢١١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٩٣.علقه يحيى بن سلّام ١/٢٩٣.تفسير مقاتل بن سليمان ٣/٤٦.أخرجه ابن جرير ١٦/٢١١.أخرجه ابن جرير ١٦/٢١١.أخرجه الفراء في معاني القرآن ٢/١٩٦. وعزاه السيوطي إلى عبد بن حميد. و‹لَعَلَّكَ تُرْضى› بضم التاء قراءة متواترة، قرأ بها الكسائي، وأبو بكر عن عاصم، وقرأ بقية العشرة: <q>﴿تَرْضى﴾</q> بفتح التاء. انظر: النشر ٢/٣٢٢، والإتحاف ص٣٩٠.علَّقه يحيى بن سلّام ١/٢٩٤.تفسير مقاتل بن سليمان ٣/٤٦.أخرجه ابن جرير ١٦/٢١٣.أخرجه ابن جرير ١٦/٢١٢ ولفظه: بما يثيبك الله. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٩٤.أخرجه مسلم ١/٤٤٠ (٦٣٤).أخرجه أبو داود ١/٣١٩ (٤٢٨)، والحاكم ١/٦٩ (٥١)، ١/٣١٥ (٧١٧)، ٣/٧٢٨ (٦٦٣٧). قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه، وعبد الله هو ابن فضالة بن عبيد، وقد خرج له في الصحيح حديثان». ووافقه الذهبي. قال إبراهيم الحسيني الحنفي في البيان والتعريف ٢/١٩ (٩٣٥): «قال الحافظ ابن حجر في الأربعين المتباينة: هذا حديث صحيح». وقال الألباني في صحيح أبي داود ٢/٣٠٦ (٤٥٤): «إسناده صحيح، وصححه ابن حبان، والسيوطي».
20,131," <q>﴿وَلَا تَمُدَّنَّ عَیۡنَیۡكَ إِلَىٰ مَا مَتَّعۡنَا بِهِۦۤ أَزۡوَ ٰ⁠جࣰا مِّنۡهُمۡ﴾</q> الآية - نزول الآية ٤٨٦٢٩- عن أبي رافع، قال: أضاف النبيُّ ﷺ ضيفًا، ولم يكن عند النبي ﷺ ما يُصْلِحه، فأرسلني إلى رجل مِن اليهود أنْ: «بِعْنا أو أسْلِفْنا دقيقًا إلى هلالِ رجبٍ». فقال: لا، إلا بِرَهْنٍ. فأتيتُ النبيَّ ﷺ، فأخبرته، فقال: «أما -واللهِ- إنِّي لَأمينٌ في السماء، أمينٌ في الأرض، ولَئِن أسلفني أو باعني لَأَدَّيْتُ إليه، اذهب بدرعي الحديد». فلم أخرج من عنده حتى نزلت هذه الآية: <q>﴿ولا تمدن عينيك إلى ما متعنا به أزواجا منهم﴾</q>. كأنه يعزيه عن الدنيا{1}٤٣٢٣. (١٠/٢٦٤) ٤٣٢٣ انتقد ابنُ عطية (٦/١٤٦) مستندًا إلى دلالة التاريخ أن يكون هذا الحديث سبب نزول الآية، فقال: «وهذا مُعتَرَضٌ أن يكون سببًا؛ لأن السورة مكية، والقصة المذكورة مدنية في آخر عمر النبي ﷺ؛ لأنّه مات ودرعه مرهونة بهذه القصة التي ذكرت». ثم رجَّح مستندًا إلى السياق تناسق الآية مع ما قبلها: «وإنما الظاهر أن الآية متناسقة مع ما قبلها، وذلك أنّ الله تعالى وبَّخهم على ترك الاعتبار بالأمم السابقة، ثم تَوَعَّدهم بالعذاب المُؤَجَّل، ثم أمَرَ نبيَّه ﷺ بالاحتقار لشأنهم، والصبر على أقوالهم، والإعراض عن أموالهم وما في أيديهم مِن الدنيا، إذ ذلك مُنصَرِمٌ عنهم، صائرٌ بهم إلى خِزْيٍ». <q>﴿وَلَا تَمُدَّنَّ عَیۡنَیۡكَ إِلَىٰ مَا مَتَّعۡنَا بِهِۦۤ أَزۡوَ ٰ⁠جࣰا مِّنۡهُمۡ﴾</q> - تفسير ٤٨٦٣٠- تفسير مجاهد بن جبر: قوله: <q>﴿ولا تمدن عينيك إلى ما متعنا به أزواجا منهم﴾</q>، يعني: الأغنياء{2}. (ز) ٤٨٦٣١- قال مقاتل بن سليمان: <q>﴿ولا تمدن عينيك إلى ما متعنا به أزواجا منهم﴾</q> يعني: كفار مكة، مِن الرزق أصنافًا <q>﴿منهم﴾</q> مِن الأموال{3}. (ز) ٤٨٦٣٢- عن سفيان، في قوله: <q>﴿ولا تمدن عينيك﴾</q> الآية، قال: تَعْزِيَةً لرسول الله ﷺ{4}. (١٠/٢٦٤) <q>﴿زَهۡرَةَ ٱلۡحَیَوٰةِ ٱلدُّنۡیَا﴾</q> - تفسير ٤٨٦٣٣- عن أبي سعيد، أنّ رسول الله ﷺ قال: «أخْوَفُ ما أخاف عليكم ما يُخْرِجُ اللهُ لكم مِن زهرة الدنيا». قالوا: وما زهرة الدنيا، يا رسول الله؟ قال: «بركات الأرض»{5}. (١٠/٢٦٤) ٤٨٦٣٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿زهرة الحياة الدنيا﴾</q>، قال: زينة الحياة الدنيا{6}. (١٠/٢٦٤) ٤٨٦٣٥- قال مقاتل بن سليمان: فإنها <q>﴿زهرة﴾</q> يعني: زينة <q>﴿الحياة الدنيا﴾</q>{3}. (ز) <q>﴿لِنَفۡتِنَهُمۡ فِیهِۚ﴾</q> - تفسير ٤٨٦٣٦- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿لنفتنهم فيه﴾</q>، قال: لِنَبْتَلِيَهُم فيه{8}. (ز) ٤٨٦٣٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لنفتنهم فيه﴾</q>، قال: لنبتليهم فيه{9}. (١٠/٢٦٤) ٤٨٦٣٨- قال مقاتل بن سليمان: <q>﴿لنفتنهم فيه﴾</q>، يقول: أعطيناهم ذلك لكى نبتليهم{3}. (ز) ٤٨٦٣٩- قال يحيى بن سلّام: لنختبرهم فيه{11}. (ز) <q>﴿وَرِزۡقُ رَبِّكَ خَیۡرࣱ وَأَبۡقَىٰ ۝١٣١﴾</q> - تفسير ٤٨٦٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ورزق ربك خير وأبقى﴾</q>، قال: مِمّا مُتِّع به هؤلاء مِن زهرة الدنيا{12}. (١٠/٢٦٥) ٤٨٦٤١- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ورزق ربك﴾</q>، يقول: رِزْق الجنة{4}. (١٠/٢٦٥) ٤٨٦٤٢- قال مقاتل بن سليمان: <q>﴿ورزق ربك﴾</q> في الآخرة، يعني: الجنة <q>﴿خير وأبقى﴾</q> يعني: أفضل وأَدْوَمُ وأبقى مِمّا أعطى كفار مكة{3}. (ز) ٤٨٦٤٣- قال يحيى بن سلّام: قوله: <q>﴿ورزق ربك﴾</q> في الجنة <q>﴿خير﴾</q> مِن الدنيا، <q>﴿وأبقى﴾</q> لا نَفادَ لذلك الرِّزْقِ{15}. (ز) <q>﴿وَرِزۡقُ رَبِّكَ خَیۡرࣱ وَأَبۡقَىٰ ۝١٣١﴾</q> - آثار متعلقة بالآية ٤٨٦٤٤- عن عمرو بن شعيب، عن جده عبد الله بن عمرو، قال: سمعتُ رسول الله ﷺ يقول: «خصلتان مَن كانتا فيه كَتَبَه الله شاكِرًا صابِرًا، ومَن لم تكونا فيه لم يكتبه الله شاكِرًا ولا صابِرًا: مَن نظر في دينه إلى مَن هو فوقه فاقتدى به، ونظر في دُنياه إلى مَن هو دونه فحمد الله على ما فَضَلَّه به عليه؛ كتبه الله شاكِرًا وصابِرًا، ومَن نظر في دينه إلى مَن هو دونه، ونظر في دنياه إلى مَن هو فوقه فأسف على ما فاته منه؛ لم يكتبه الله شاكِرًا ولا صابِرًا»{16}. (ز) ٤٨٦٤٥- عن الحسن البصري، قال: قال رسول الله ﷺ: «خير الرِّزق الكَفافُ، اللَّهُمَّ، اجعل رِزقَ آلِ محمدٍ كفافًا»{17}. (ز) ٤٨٦٤٦- قال أُبَيّ بن كعب: مَن لم يَتَعَزَّ بعِزَّة الله تَقَطَّعَتْ نفسُه حسرات، ومَن يُتْبِع بصرَه فيما في أيدي الناس يَطُلْ حُزنُه، ومَن ظَنَّ أنّ نعمةَ الله في مطعمِه ومشربِه وملبسِه فقد قلَّ عملُه، وحضرَ عذابُه{18}. (ز) ",footnotes:1:أخرجه الروياني في مسنده ١/٤٧٢ (٧١٥)، والطبراني في الكبير ١/٣٣١ (٩٨٩). وأورده البغوي ٥/٣٠٣. وأخرجه إسحاق البستي في تفسيره ص٢٨٧، عن ابن أبي عمر، عن سفيان بن عيينة، قال: بلغني أن النبي ﷺ؛ فذكر نحوه. قال العراقي في تخريج أحاديث الإحياء ص١٥٤٧: «أخرجه الطبراني بسند ضعيف». وقال الهيثمي في المجمع ٤/١٢٦ (٦٦١٩): «رواه الطبراني في الكبير، والبزار، وفيه موسى بن عبيدة الربذي، وهو ضعيف».علَّقه يحيى بن سلّام ١/٢٩٤.تفسير مقاتل بن سليمان ٣/٤٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البخاري ٤/٢٦ (٢٨٤٢)، ٨/٩١ (٦٤٢٧)، ومسلم ٢/٧٢٨ (١٠٥٢)، وابن أبي حاتم ٧/٢٤٤٢ (١٣٥٨٩).أخرجه ابن جرير ١٦/٢١٥. وعلَّقه يحيى بن سلّام ١/٢٩٤. وعزاه السيوطي إلى ابن أبي حاتم. وعقَّب عليه يحيى بن سلّام بقوله -وقد يكون القول لقتادة-: أمره أن يزهد في الدنيا.تفسير مقاتل بن سليمان ٣/٤٦.أخرجه إسحاق البستي في تفسيره ص٢٨٧.أخرجه ابن جرير ١٦/٢١٦. وعلَّقه يحيى بن سلّام ١/٢٩٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٦.تفسير يحيى بن سلّام ١/٢٩٤.أخرجه يحيى بن سلّام ١/٢٩٥، وابن جرير ١٦/٢١٦. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٦.تفسير يحيى بن سلّام ١/٢٩٥.أخرجه الترمذي ٤/٤٨٦ (٢٦٨٠)، من طريق المثنى بن الصباح، عن عمرو بن شعيب، عن جده عبد الله بن عمرو به. قال الترمذي: «هذا حديث غريب». وقال المناوي في التيسير بشرح الجامع الصغير ١/٥١٦: «إسناد ضعيف». وقال في فيض القدير ٣/٤٤٢: «فيه المثنى بن صباح؛ ضعَّفه ابن معين، وقال النسائي: متروك». وقال الألباني في الضعيفة ٤/٣٩٧ (١٩٢٤): «ضعيف».أخرجه وكيع في الزهد ص٣٤٠ (١١٥)، والمعافى بن عمران في الزهد ص٢٧٥ (١٦٥) بزيادة: «يومًا بيوم» بعد قوله: «كفافًا»، وأخرجه يحيى بن سلّام ١/٢٩٥. قال الألباني في الصحيحة ٤/٤٥٠ (١٨٣٤): «وهذا مرسل ضعيف».تفسير البغوي ٥/٣٠٣.
20,132," <q>﴿وَأۡمُرۡ أَهۡلَكَ بِٱلصَّلَوٰةِ وَٱصۡطَبِرۡ عَلَیۡهَاۖ لَا نَسۡـَٔلُكَ رِزۡقࣰاۖ نَّحۡنُ نَرۡزُقُكَۗ وَٱلۡعَـٰقِبَةُ لِلتَّقۡوَىٰ ۝١٣٢﴾</q> - نزول الآية ٤٨٦٤٧- عن أبي سعيد الخدري، قال: لما نزلت <q>﴿وأمر أهلك بالصلاة﴾</q> كان النبيُّ ﷺ يجيء إلى باب عليٍّ صلاة الغداة -ثمانية أشهر- يقول: «الصلاة رحمكم الله، <q>﴿إنما يريد الله ليذهب عنكم الرجس أهل البيت ويطهركم تطهيرا﴾</q>» [الأحزاب:٣٣]{1}. (١٠/٢٦٦) ٤٨٦٤٨- عن أبي الحمراء، قال: نزلت هذه الآية: <q>﴿وأْمُرْ أهْلَكَ بِالصَّلاةِ﴾</q>. قال: كان يأتي النبيُّ ﷺ بابَ عليٍّ، فيقول: «الصلاة رحمكم الله، <q>﴿إنما يريد الله ليذهب عنكم الرجس أهل البيت ويطهركم تطهيرا﴾</q>» [الأحزاب: ٣٣]{2}. (١٠/٢٦٦) <q>﴿وَأۡمُرۡ أَهۡلَكَ بِٱلصَّلَوٰةِ وَٱصۡطَبِرۡ عَلَیۡهَاۖ﴾</q> - تفسير ٤٨٦٤٩- عن سعيد بن جبير، في قوله: <q>﴿وأمر أهلك﴾</q>، قال: قومك{3}. (١٠/٢٦٥) ٤٨٦٥٠- قال مقاتل بن سليمان: <q>﴿وأمر أهلك﴾</q> يعني: قومك <q>﴿بالصلاة﴾</q> كقوله: سبحانه: <q>﴿وكان يأمر أهله بالصلاة والزكاة﴾</q> [مريم:٥٥] يعني: [قومه]، <q>﴿واصطبر عليها﴾</q> يعني: الصلاة{4}. (ز) ٤٨٦٥١- قال يحيى بن سلّام: قوله: <q>﴿وأمر أهلك بالصلاة﴾</q>، وأهله في هذا الموضع: أُمَّته{5}. (ز) <q>﴿لَا نَسۡـَٔلُكَ رِزۡقࣰاۖ نَّحۡنُ نَرۡزُقُكَۗ﴾</q> - تفسير ٤٨٦٥٢- قال مقاتل بن سليمان: فإنا <q>﴿لا نسألك رزقا﴾</q> إنّما نسألك العبادة، <q>﴿نحن نرزقك﴾</q>{4}. (ز) ٤٨٦٥٣- عن سفيان الثوري، في قوله: <q>﴿لا نسألك رزقا﴾</q>، قال: لا نُكَلِّفك بالطلب{7}. (١٠/٢٦٥) ٤٨٦٥٤- قال يحيى بن سلّام: قوله: <q>﴿لا نسألك رزقا﴾</q>، قال بعضهم: لا نسألك على ما أعطيناك من النبوة رِزْقًا، وتفسير الحسن في التي في الذاريات: <q>﴿ما أريد منهم من رزق﴾</q> [الذاريات:٥٧]: أن يرزقوا أنفسَهم. قال يحيى: فإن كانت هذه عند الحسن مثلها فهو: <q>﴿لا نسألك رزقا﴾</q> أن ترزق نفسَك، وهو أعْجَبُ إلَيَّ{5}. (ز) <q>﴿وَٱلۡعَـٰقِبَةُ لِلتَّقۡوَىٰ ۝١٣٢﴾</q> - تفسير ٤٨٦٥٥- عن إسماعيل السُّدِّيّ، <q>﴿والعاقبة للتقوى﴾</q>، قال: هي الجنة{7}. (١٠/٢٦٨) ٤٨٦٥٦- قال مقاتل بن سليمان: <q>﴿والعاقبة للتقوى﴾</q> يعني: عاقبة التقوى دار الجنة، لقوله ﷿: <q>﴿وما خلقت الجن والإنس إلا ليعبدون ما أريد منهم من رزق ومآ أريد أن يطعمون﴾</q> [الذاريات:٥٦-٥٧]، إنما أريد منهم العبادة{4}. (ز) ٤٨٦٥٧- قال يحيى بن سلّام: <q>﴿نحن نرزقك والعاقبة للتقوى﴾</q>، أي: لأهل التقوى، والعاقبة: الجنة. كقوله: <q>﴿والآخرة عند ربك للمتقين﴾</q> [الزخرف:٣٥]{5}. (ز) <q>﴿وَٱلۡعَـٰقِبَةُ لِلتَّقۡوَىٰ ۝١٣٢﴾</q> - آثار متعلقة بالآية ٤٨٦٥٨- عن مَعْمَر، عن رجل من قريش، قال: كان النبيُّ ﷺ إذا دخل على أهله بعضُ الضيقِ في الرِّزق أمرَ أهلَه بالصلاةِ، ثم قرأ هذه الآية: <q>﴿وأمر أهلك بالصلاة﴾</q> الآية{12}. (١٠/٢٦٧) ٤٨٦٥٩- عن عبد الله بن سلام، قال: كان النبيُّ ﷺ إذا نزلتْ بأهلِه شِدَّةٌ أو ضيقٌ أمرَهم بالصلاةِ، وتلا: <q>﴿وأمر أهلك بالصلاة﴾</q> الآية{13}. (١٠/٢٦٧) ٤٨٦٦٠- عن ثابت، قال: كان النبيُّ ﷺ إذا أصابت أهلَه خَصاصَةٌ نادى أهلَه: «يا أهلاه، صلُّوا صلُّوا».= (ز) ٤٨٦٦١- قال ثابت: وكانت الأنبياء إذا نزلَ بهم أمرٌ فَزِعوا إلى الصلاةِ{14}. (١٠/٢٦٦) ٤٨٦٦٢- عن أسلم، قال: كان عمرُ بن الخطاب يُصَلِّي مِن الليل ما شاء الله أن يُصَلِّي، حتى إذا كان آخرَ الليل أيقظ أهله للصلاة، ويقول لهم: الصلاةَ الصلاةَ. ويتلو هذه الآية: <q>﴿وأمر أهلك بالصلاة﴾</q>{15}. (١٠/٢٦٧) ٤٨٦٦٣- عن هشام بن عروة بن الزبير، قال: قال لنا أبي [عروةُ بنُ الزبيرِ]: إذا رأى أحدكم شيئًا مِن زينةِ الدنيا وزهرتِها فليأت أهلَه، وليأمر أهله بالصلاة، وليصطبر عليها؛ فإنّ الله قال لنبيه: <q>﴿ولا تمدن عينيك إلى ما متعنا به أزواجا منهم﴾</q> وقرأ إلى آخر الآية{16}. (١٠/٢٦٧) ٤٨٦٦٤- عن عروة [بن الزبير]: أنّه كان إذا دخل على أهل الدنيا فرأى مِن دنياهم طَرَفًا، فإذا رجع إلى أهله، فدخل الدار، قرأ: <q>﴿ولا تمدن عينيك﴾</q> إلى قوله: <q>﴿نحن نرزقك﴾</q>، ثم يقول: الصلاةَ الصلاةَ، رَحِمَكم اللهُ{17}. (١٠/٢٦٦) ٤٨٦٦٥- قال مالك بن دينار: كان بكرُ بن عبد الله المزني إذا أصاب أهلَه خَصاصَةٌ يقول: قوموا فصَلُّوا. ثم يقول: بهذا أمرَ اللهُ رسولَه. ويتلو هذه الآية{18}. (ز) ",footnotes:1:أخرجه الأصبهاني في طبقات المحدثين بأصبهان ٤/١٤٨، وابن عساكر في تاريخه ٤٢/١٣٦، من طريق عطية العوفي، عن أبي سعيد به. إسناده ضعيف؛ لضعف عطية.أخرجه عبد بن حميد كما في المنتخب من مسنده ص١٧٣ (٤٧٥)، وابن عساكر في تاريخه ٤٢/١٣٦-١٣٧ بنحوه، من طريق أبي داود السبيعي، عن أبي الحمراء به. إسناده ضعيف جدًّا؛ أبو داود هو نفيع بن الحارث الهمداني الأعمى، قال عنه ابن حجر في التقريب (٧١٨١): «متروك، وقد كّذبه ابن معين».عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٦.تفسير يحيى بن سلّام ١/٢٩٥.تفسير مقاتل بن سليمان ٣/٤٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٩٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٦.تفسير يحيى بن سلّام ١/٢٩٥.أخرجه عبد الرزاق في مصنفه ٣/٤٩ (٤٧٤٤).أخرجه الطبراني في الأوسط ١/٢٧٢ (٨٨٦)، والبيهقي في الشعب ٤/٥١٥-٥١٦ (٢٩١١)، والواحدي في الوسيط ٣/٢٢٨ (٦١٢). قال الطبراني: «لا يُروى هذا الحديثُ عن عبد الله بن سلام إلا بهذا الإسناد، تفرَّد به معمر». وقال الهيثمي في المجمع ٧/٦٧ (١١١٧٣): «رواه الطبرانيُّ في الأوسط، ورجاله ثقات». وقال السيوطي: «وأبو نعيم في الحلية، بسند صحيح».أخرجه أحمد في الزهد ص١٢ (٤٩)، والبيهقي في الشعب ٤/٥١٨ (٢٩١٥)، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٢٨-. قال الألباني في الضعيفة ٦/٢٨٠ (٢٧٦٠): «ضعيف».أخرجه مالك ١/١١٩، وعبد الرزاق في مصنفه ٣/٤٩ (٤٧٤٣)، والبيهقي (٣٠٨٦).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٠٣ (٣٦٤٨٣).أخرجه ابن جرير ١٦/٢١٧، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٢١- ولفظه: كان عروة إذا رأى ما عند السلاطين دخل داره ... إلخ. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٦/٢٦٧.
20,133," <q>﴿وَقَالُوا۟ لَوۡلَا یَأۡتِینَا بِـَٔایَةࣲ مِّن رَّبِّهِۦۤۚ أَوَلَمۡ تَأۡتِهِم بَیِّنَةُ مَا فِی ٱلصُّحُفِ ٱلۡأُولَىٰ ۝١٣٣﴾</q> - تفسير ٤٨٦٦٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿تأتهم﴾</q>، قال: التوراة والإنجيل{1}. (١٠/٢٦٨) ٤٨٦٦٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿أولم تأتهم بينة ما في الصحف الأولى﴾</q>: الكتب التي خَلَتْ مِن الأُمَم التي يمشون في مساكنهم{2}. (ز) ٤٨٦٦٨- قال مقاتل بن سليمان: <q>﴿وقالوا﴾</q> أي: كفار مكة: <q>﴿لولا﴾</q> يعني: هلّا <q>﴿يأتينا بآية من ربه﴾</q> فَتُعْلِمَ أنّه نبيٌ رسولٌ، كما كانت الأنبياء تجيء بها إلى قومِهم. يقول الله ﷿: <q>﴿أولم تأتهم بينة ما في الصحف الأولى﴾</q> يعني: بيان كتب إبراهيم وموسى الذي كان قبل كتاب محمد -صلى الله عليهم أجمعين-{3}. (ز) ٤٨٦٦٩- قال يحيى بن سلّام: قوله: <q>﴿وقالوا لولا﴾</q> هلّا <q>﴿يأتينا بآية من ربه﴾</q>. قال الله: <q>﴿أولم تأتهم بينة ما في الصحف الأولى﴾</q> التوراة والإنجيل. كقوله: <q>﴿النبي الأمي الذي يجدونه مكتوبا عندهم في التوراة والإنجيل﴾</q> [الأعراف:١٥٧]{4}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ١٤/١٢٠، وإسحاق البستي في تفسيره ص٢٨٨ من طريق ابن جُرَيْج، وابن جرير ١٦/٢١٨. وعلَّقه يحيى بن سلّام ١/٢٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢١٨. وعلَّقه يحيى بن سلّام ١/٢٩٦ وقال عَقِبه: وهو واحد. يعني: تفسير مجاهد وقتادة.تفسير مقاتل بن سليمان ٣/٤٧.تفسير يحيى بن سلّام ١/٢٩٥.
20,134," <q>﴿وَلَوۡ أَنَّاۤ أَهۡلَكۡنَـٰهُم بِعَذَابࣲ مِّن قَبۡلِهِۦ لَقَالُوا۟ رَبَّنَا لَوۡلَاۤ أَرۡسَلۡتَ إِلَیۡنَا رَسُولࣰا فَنَتَّبِعَ ءَایَـٰتِكَ مِن قَبۡلِ أَن نَّذِلَّ وَنَخۡزَىٰ ۝١٣٤﴾</q> - تفسير ٤٨٦٧٠- عن أبي سعيد الخدري، عن النبي ﷺ، قال: «يَحْتَجُّ على الله يوم القيامة ثلاثةٌ: الهالِكُ في الفَتْرَةِ، والمغلوبُ على عقله، والصبيُّ الصغيرُ. فيقول المغلوب على عقله: لم تجعل لي عقلًا أنتفعُ به. ويقول الهالِك في الفترة: لم يأتني رسولٌ ولا نبيٌّ، ولو أتاني لك رسولٌ أو نبيٌّ لكنتُ أطوعَ خلقِك لَك. وقرأ: <q>﴿لولا أرسلت إلينا رسولا﴾</q>. ويقول الصبيُّ الصغير: كنتُ صغيرًا لا أعقل. قال: فتُرفعُ لهم نارٌ، ويقال لهم: رِدُوها. قال: فيَرِدُها مَن كان في علم الله أنّه سعيدٌ، ويَتَلَكَّأ عنها مَن كان في علم الله أنّه شَقِيٌّ. فيقول: إيّاي عصيتم، فكيف برسُلي لو أتَتْكم؟!»{1}٤٣٢٤. (ز) ٤٣٢٤ علَّق ابنُ عطية (٤/٧٢ ط: دار الكتب العلمية) على هذا الحديث بقوله: «فأما الصبي والمغلوب على عقله فبَيِّنٌ أمرهما، وأما صاحب الفترة فليس ككافر قريش قبل النبي ﷺ؛ لأنّ كُفّار قريش وغيرهم مِمَّن عَلِم وسَمِع عن نبوَّة ورسالة في أقطار الأرض فليس بصاحب فترة، والنبيُّ ﷺ قد قال للرجل الذي سأله عن أبيه: «أبي وأبوك في النار». ورأى عمروَ بن لحي في النار، إلى غير هذا مما يطول ذكره، وإنما صاحب الفترة يُفْرَضُ أنه آدمي لم يصل إليه أن الله تعالى بعث رسولًا، ولا دعا إلى دين، وهذا قليلُ الوجود، اللهم إلا أن يشذ في أطراف الأرض المنقطعة عن العمران». ٤٨٦٧١- عن عطية العوفي، قال: الهالِك في الفترة، والمعتوه، والمولود يقول: ربِّ، لم يأتني كتابٌ ولا رسولٌ. وقرأ هذه الآية: <q>﴿ولو أنا أهلكناهم بعذاب من قبله لقالوا ربنا لولا أرسلت إلينا رسولا﴾</q> الآية{2}. (١٠/٢٦٨) ٤٨٦٧٢- قال مقاتل بن سليمان: <q>﴿ولو أنا أهلكناهم بعذاب﴾</q> في الدنيا <q>﴿من قبله﴾</q> يعني: مِن قبل هذا القرآن في الآخرة؛ <q>﴿لقالوا ربنا لولا﴾</q> يعني: هلّا <q>﴿أرسلت إلينا رسولا﴾</q> معه كتابٌ؛ <q>﴿فنتبع آياتك﴾</q> يعني: آياتِ القرآنِ، <q>﴿من قبل أن نذل﴾</q> يعني: نستذلَّ، <q>﴿ونخزى﴾</q> يعني: ونُعَذَّب في الدنيا. نظيرُها في القصص{3}. (ز) ٤٨٦٧٣- قال يحيى بن سلّام: قوله: <q>﴿ولو أنا أهلكناهم بعذاب من قبله﴾</q> مِن قبلِ القرآن؛ <q>﴿لقالوا ربنا لولا﴾</q> هلّا <q>﴿أرسلت إلينا رسولا فنتبع آياتك من قبل أن نذل ونخزى﴾</q> في العذاب{4}. (ز) ",footnotes:1:أخرجه البزار -كما في كشف الأستار ٣/٣٤ (٢١٧٦)-، واللالكائي في شرح أصول أهل السنة ٤/٦٦٦ (١٠٧٦)، وابن جرير ١٦/٢١٩، وابن أبي حاتم ٩/٢٩٨٤ (١٦٩٥٠) مختصرًا. قال البزار: «لا نعلمه يُرْوى عن أبي سعيد إلا من حديث فضيل». وقال -كما في تفسير ابن كثير ٥/٥٦-: «لا يعرف من حديث أبي سعيد إلا من طريقه، عن عطية عنه». وقال ابن عبد البر في التمهيد ١٨/١٢٨: «مِن الناس مِن يُوقِف هذا الحديث على أبي سعيد، ولا يرفعه، منهم أبو نعيم الملائي». وقال الهيثمي في المجمع ٧/٢١٦ (١١٩٣٨): «رواه البزار، وفيه عطية وهو ضعيف». وقال الصالحي في سبل الهدى والرشاد ١/٢٥٢: «رواه البزار من طريق عطية العوفي، وفيه ضعف. والترمذي يحسّن حديثه، خصوصًا إذا كان له شاهد، وحديثه هذا له عدة شواهد تقتضي الحكم بحسنه وثبوته».عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٧-٤٨. يشير إلى قوله تعالى: <q>﴿ولَوْلا أنْ تُصِيبَهُمْ مُصِيبَةٌ بِما قَدَّمَتْ أيْدِيهِمْ فَيَقُولُوا رَبَّنا لَوْلا أرْسَلْتَ إلَيْنا رَسُولًا فَنَتَّبِعَ آياتِكَ ونَكُونَ مِنَ المُؤْمِنِينَ﴾</q> [القصص:٤٧].تفسير يحيى بن سلّام ١/٢٩٦.
20,135," <q>﴿قُلۡ كُلࣱّ مُّتَرَبِّصࣱ فَتَرَبَّصُوا۟ۖ فَسَتَعۡلَمُونَ مَنۡ أَصۡحَـٰبُ ٱلصِّرَ ٰ⁠طِ ٱلسَّوِیِّ وَمَنِ ٱهۡتَدَىٰ ۝١٣٥﴾</q> - نزول الآية ٤٨٦٧٤- قال مقاتل بن سليمان: وذلك أنّ كفار مكة قالوا: نتربَّص بمحمد ﷺ الموتَ. لأنّ النبي ﷺ أوعدهم العذاب في الدنيا؛ فأنزل الله ﷿: <q>﴿قل كل متربص فتربصوا فستعلمون من أصحاب الصراط السوي ومن اهتدى﴾</q>{1}. (ز) <q>﴿قُلۡ كُلࣱّ مُّتَرَبِّصࣱ فَتَرَبَّصُوا۟ۖ﴾</q> - تفسير ٤٨٦٧٥- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لكفار مكة: <q>﴿كل متربص﴾</q> أنتم بمحمد الموت، ومحمدٌ يتربص بكم العذابَ في الدنيا، <q>﴿فتربصوا﴾</q>{1}. (ز) ٤٨٦٧٦- قال يحيى بن سلّام: قال الله -تبارك وتعالى- للنبيِّ ﷺ: <q>﴿قل كل متربص﴾</q> نحن وأنتم. وكان المشركون يَتَرَبَّصون بالنبيِّ ﷺ أن يموتَ، وكان النبيُّ ﵇ يتربَّص بهم أن يجيئهم العذابُ{3}. (ز) <q>﴿فَسَتَعۡلَمُونَ مَنۡ أَصۡحَـٰبُ ٱلصِّرَ ٰ⁠طِ ٱلسَّوِیِّ وَمَنِ ٱهۡتَدَىٰ ۝١٣٥﴾</q> - تفسير ٤٨٦٧٧- عن إسماعيل السدي، في قوله: <q>﴿أصحاب الصراط السوي﴾</q>، قال: العَدْل{4}. (١٠/٢٦٨) ٤٨٦٧٨- قال مقاتل بن سليمان: <q>﴿فستعلمون﴾</q> إذا نزل بكم العذابُ في الدنيا <q>﴿من أصحاب الصراط السوي﴾</q> يعني: العَدْل؛ أنحن أم أنتم، <q>﴿ومن اهتدى﴾</q> مِنّا ومنكم{1}. (ز) ٤٨٦٧٩- قال يحيى بن سلّام: قال الله: <q>﴿فستعلمون من أصحاب الصراط السوي﴾</q> الطريق العَدْل المستقيم إلى الجنة، وهو الإسلام، <q>﴿ومن اهتدى﴾</q> أي: فستعلمون أنّ النبيَّ ﷺ والمؤمنين كانوا على الصراط السوي، وهو طريق الجنة، وأنّهم ماتوا على الهُدى{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٧-٤٨.تفسير مقاتل بن سليمان ٣/٤٧-٤٨.تفسير يحيى بن سلّام ١/٢٩٦.علَّقه يحيى بن سلّام ١/٢٩٦ بلفظ: الدين: العدل. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٧-٤٨.تفسير يحيى بن سلّام ١/٢٩٦.
