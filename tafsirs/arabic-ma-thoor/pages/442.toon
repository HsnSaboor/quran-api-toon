quran[13]{c,v,t}:
  36,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنزَلۡنَا عَلَىٰ قَوۡمِهِۦ مِنۢ بَعۡدِهِۦ مِن جُندࣲ مِّنَ ٱلسَّمَاۤءِ وَمَا كُنَّا مُنزِلِینَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق بعض أصحاب ابن إسحاق- قال: غضب الله له -يعني: لهذا المؤمن- لاستضعافهم إيّاه غضبةً لم يُبق مِن القوم شيئًا، فعجّل لهم النقمة بما استحلُّوا منه، وقال: <span class="qpc-hafs">﴿وما أنْزَلْنا عَلى قَوْمِهِ مِن بَعْدِهِ مِن جُنْدٍ مِنَ السَّماءِ وما كُنّا مُنْزِلِينَ﴾</span>، يقول: ما كابدناهم بالجموع، أي: الأمر أيسر علينا مِن ذلك{1}. (١٢/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال الله: <span class="qpc-hafs">﴿وما أنْزَلْنا عَلى قَوْمِهِ مِن بَعْدِهِ مِن جُنْدٍ مِنَ السَّماءِ﴾</span>: رسالة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿وما أنْزَلْنا عَلى قَوْمِهِ﴾</span> الآية، قال: ما استعنتُ عليهم جندًا مِن السماء ولا مِن الأرض{3}. (١٢/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٤٦<span class="dash">-</span></span> عن <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿وما كُنّا مُنْزِلِينَ﴾</span>، والجند: الملائكة الذين يجيئون بالوحي إلى الأنبياء، فانقطع عنهم الوحي، واستوجبوا العذاب، فجاءهم العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما أنْزَلْنا عَلى قَوْمِهِ مِن بَعْدِهِ مِن جُنْدٍ مِنَ السَّماءِ وما كُنّا مُنْزِلِينَ﴾</span> قال: فلا، واللهِ، ما عاتب اللهُ قومَه بعد قتله، <span class="qpc-hafs">﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً فَإذا هُمْ خامِدُونَ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿وما أنْزَلْنا عَلى قَوْمِهِ مِن بَعْدِهِ﴾</span> يعني: مِن بعد قتْل حبيب النجار <span class="qpc-hafs">﴿مِن جُنْدٍ مِنَ السَّماءِ وما كُنّا مُنْزِلِينَ﴾</span> الملائكة{6}<span class=comment-ref>٥٤٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٠</span> اختلف السلف فيما عنى الله بالجند على قولين: <b>الأول</b>: أنها الرسالة. وهو قول مجاهد. <b>الثاني</b>: أن معنى ذلك: أن الله لم يبعث لهم جنودًا يقاتلهم بها، ولكنه أهلكهم بصيحة واحدة.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٩/٤٢٨) <span class="mustanad">مستندًا إلى اللغة والدلالة العقلية</span> القول الثاني، و<span class="comment-type-2">انتقد</span> القول الأول، فقال: «وهذا القول الثاني أولى القولين بتأويل الآية، وذلك أن الرسالة لا يقال لها: جند، إلا أن يكون أراد مجاهد بذلك: الرسل، فيكون وجهًا، وإن كان أيضًا مِن المفهوم بظاهر الآية بعيدًا، وذلك أنّ الرسل من بني آدم لا ينزلون من السماء، والخبر في ظاهر هذه الآية عن أنه لم ينزل من السماء بعد مهلك هذا المؤمن على قومه جندًا، وذلك بالملائكة أشبه منه ببني آدم».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٤٤) في «ما» من قوله: <span class="qpc-hafs">﴿وما كنا منزلين﴾</span> قولين: <b>الأول</b>: أنها نافية، و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا يجري مع التأويل الثاني في قوله: <span class="qpc-hafs">﴿ما أنْزَلْنا مِن جُنْدٍ﴾</span>». و<b>الثاني</b>: أنها عطف على <span class="qpc-hafs">﴿جند﴾</span>، والمعنى: «من جند ومن الذي كنا منزلين على الأمم مثلهم قبل ذلك».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٢٧-٤٢٨. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٢٦. وعلَّقه يحيى بن سلّام ٢/٨٠٦.|3:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|4:علقه يحيى بن سلّام ٢/٨٠٦.|5:أخرجه ابن جرير ١٩/٤٢٧.|6:تفسير مقاتل بن سليمان ٣/٥٧٧.
  36,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن كَانَتۡ إِلَّا صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ فَإِذَا هُمۡ خَـٰمِدُونَ ۝٢٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٤٩<span class="dash">-</span></span> عن محمد بن سيرين، قال: في قراءة <span class="name-1">ابن مسعود</span>: (إن كانَتْ إلّا زَقْيَةً واحِدَةً). وفي قراءتنا: <span class="qpc-hafs">﴿إن كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span>{1}<span class=comment-ref>٥٤٢١</span>. (١٢/٣٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢١</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٧/٢٤٥) على قراءة ابن مسعود، فقال: «وقرأ ابن مسعود، وعبد الرحمن بن الأسود: (إلّا زَقْيَةً)، وهي: الصيحة من الديك ونحوه مِن الطير».</div></p><p><h3><span class="qpc-hafs">﴿إِن كَانَتۡ إِلَّا صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span>، الصيحة: العذاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span> صيحة إسرافيل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span> مِن جبريل ﵇، ليس لها مَثْنوِيَّة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هُمۡ خَـٰمِدُونَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق بعض أصحاب ابن إسحاق- قال: <span class="qpc-hafs">﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً فَإذا هُمْ خامِدُونَ﴾</span>، فأهلك الله ذلك الملِك وأهلَ أنطاكية، فبادُوا عن وجه الأرض، فلم تبقَ منهم باقية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥٤<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جبير]</span> -من طريق الخفاف- <span class="qpc-hafs">﴿فإذا هم خامدون﴾</span>، قال: أُخمِدوا، واللهِ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span>، في قوله: <span class="qpc-hafs">﴿فَإذا هُمْ خامِدُونَ﴾</span>، قال: ميِّتون{7}. (١٢/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا هُمْ خامِدُونَ﴾</span> مَوْتى، مثل النار إذا طُفِئَت لا يُسمَع لها صوت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَإذا هُمْ خامِدُونَ﴾</span> قد هلكوا{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هُمۡ خَـٰمِدُونَ ۝٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٥٨<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ، قال: «<b>السُّبَّقُ ثلاثة: فالسابق إلى موسى يوشع بن نون، والسابق إلى عيسى صاحب يس، والسابق إلى محمد ﷺ عليُّ بن أبي طالب</b>»{10}. (١٢/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٥٩<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>الصديقون ثلاثة: حزقيل مؤمن آل فرعون، وحبيب النجار صاحب آل ياسين، وعلي بن أبي طالب</b>»{11}. (١٢/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٠<span class="dash">-</span></span> عن جابر مرفوعًا: «<b>ثلاثة ما كفروا بالله قط: مؤمن آل ياسين، وعلي بن أبي طالب، وآسية امرأة فرعون</b>»{12}. (١٢/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦١<span class="dash">-</span></span> عن أبي ليلى، قال: قال رسول الله ﷺ: «<b>الصديقون ثلاثة: حبيب النجار مؤمن آل ياسين الذي قال: <span class="qpc-hafs">﴿يا قَوْمِ اتَّبِعُوا المُرْسَلِين﴾</span>، وحزقيل مؤمن آل فرعون الذي قال: <span class="qpc-hafs">﴿أتَقْتُلُونَ رَجُلًا أنْ يَقُولَ رَبِّيَ اللَّه﴾</span></b> [غافر:٢٨]، <b>وعلي بن أبي طالب، وهو أفضلهم</b>»{13}. (١٢/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٢<span class="dash">-</span></span> عن ابن عباس: أنّ النبيَّ ﷺ بعث عُروة بن مسعود إلى الطائف إلى قومه ثقيف، فدعاهم إلى الإسلام، فرماه رجل بسهم، فقتله، فقال: «<b>ما أشبهَه بصاحب يس!</b>»{14}. (١٢/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٣<span class="dash">-</span></span> عن عروة، قال: قدِم عروة بن مسعود الثقفي على رسول الله ﷺ، ثم استأذن ليرجع إلى قومه، فقال له رسول الله ﷺ: «<b>إنّهم قاتِلوك</b>». قال: لو وجدوني نائمًا ما أيقظوني. فرجع إليهم، فدعاهم إلى الإسلام، فعصوه، وأسمعوه مِن الأذى، فلما طلع الفجر قام على غرفةٍ، فأذّن بالصلاة وتشهَّد، فرماه رجلٌ مِن ثقيف بسهم، فقتله، فقال رسول الله ﷺ حين بلغه قتْله: «<b>مَثَلُ عروة مَثَلُ صاحب يس؛ دعا قومَه إلى الله فقتلوه</b>»{15}. (١٢/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٤<span class="dash">-</span></span> عن رجل، قال: قال رسول الله ﷺ: «<b>أبو بكر الصديق خيرُ أهل الأرض، إلا أن يكون نبيٌّ، إلا مؤمن آل ياسين، وإلا مؤمن آل فرعون</b>»{16}. (١٢/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٥<span class="dash">-</span></span> قال النبي ﷺ: «<b>إنّ صاحب يس اليوم في الجنة، ومؤمن آل فرعون، ومريم بنت عمران، وآسية امرأة فرعون</b>»{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائل القرآن (١٨٢).</p><p>و(إن كانَتْ إلّا زَقْيَةً واحِدَةً) قراءة شاذة، تروى أيضًا عن عبد الرحمن بن الأسود، وقراءة العشرة: <span class="qpc-hafs">﴿إن كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span>. انظر: المحتسب ٢/٢٠٥.|2:علقه يحيى بن سلّام ٢/٨٠٦.|3:علقه يحيى بن سلّام ٢/٨٠٦.|4:تفسير مقاتل بن سليمان ٣/٥٧٧-٥٧٨.|5:أخرجه ابن جرير ١٩/٤٢٧.|6:أخرجه الحربي في غريب الحديث ٢/٦٧١.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٣/٥٧٧-٥٧٨.|9:تفسير يحيى بن سلّام ٢/٨٠٦.|10:أخرجه الطبراني في الكبير ١١/٩٣ (١١١٥٢).</p><p>قال ابن كثير في تفسيره ٦/٥٧٤: «حديث منكر، لا يعرف إلا من طريق حسين الأشقر، وهو شيعي متروك». وقال الهيثمي في المجمع ٩/١٠٢ (١٤٥٩٨): «فيه حسين بن حسن الأشقر، وثّقه ابن حبان، وضعّفه الجمهور، وبقيّة رجاله حديثهم حسن أو صحيح». وقال ابن حجر في الفتح ٦/٤٦٧: «وفي إسناده حسين بن حسين الأشقر، وهو ضعيف». وقال السيوطي: «بسند ضعيف». وقال المناوي في فيض القدير ٤/١٣٥ (٤٧٩٥): «ورواه من هذا الوجه العقيلي في الضعفاء، وقال: حسن المذكور شيعي متروك، والحديث لا يعرف إلا من جهته، وهو حديث منكر». وقال الألباني في الضعيفة ١/٥٣٢ (٣٥٨): «ضعيف جدًّا».|11:عزاه السيوطي إلى ابن النجار.</p><p>قال الألباني في الضعيفة ١/٥٣٠ (٣٥٥): «موضوع».|12:أخرجه ابن عدي في الكامل في الضعفاء ٧/٥٤٢، وابن عساكر في تاريخه ٤٢/٣١٣.</p><p>قال ابن عدي: «وهذا باطل».|13:أخرجه أبو نعيم في المعرفة ١/١٠٤ (٣٤٠)، والثعلبي ٨/١٢٦، وابن عساكر ٤٢/٣١٣، والديلمي (٣٨٦٦).</p><p>وقال الألباني في السلسلة الضعيفة (٣٥٥): «موضوع».|14:أخرجه الطبراني في الكبير ١١/٤٠٧ (١٢١٥٦).</p><p>قال الهيثمي في المجمع ٩/٣٨٦ (١٦٠٥٣): «فيه أبو عبيدة بن الفضل، وهو ضعيف».|15:أخرجه الحاكم ٣/٧١٣ (٦٥٧٩).</p><p>قال الهيثمي في المجمع ٩/٣٨٦ (١٦٠٥٢): «رواه الطبراني، وروى عن الزهري نحوه، وكلاهما مرسل، وإسنادهما حسن».|16:أخرجه خيثمة بن سليمان في حديثه ص١٣٢، ومن طريقه ابن عساكر في تاريخه ٣٠/٢١٢-٢١٣، من طريق رجاء بن عيسى المقبري، قال: أخبرنا مهدي بن ميمون، عن صدقة القرشي، عن رجل، قال: قال رسول الله ﷺ به.</p><p>إسناده ضعيف؛ لانقطاعه، وجهالة شيخ صدقة بن خالد القرشي، وهو من طبقة أتباع التابعين، وشيخه المبهم ليس صحابيًّا يقينًا، فقد أرسله إلى النبي ﷺ.|17:أورده مقاتل بن سليمان ٣/٥٧٨.
  36,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰحَسۡرَةً عَلَى ٱلۡعِبَادِۚ مَا یَأۡتِیهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٣٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنه قرأ: (يا حَسْرَةَ العِبادِ){1}<span class=comment-ref>٥٤٢٢</span>. (١٢/٣٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٢</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٧/٢٤٦ بتصرف) على قراءة ابن عباس، فقال: «وقرأ ابن عباس (يا حَسْرَةَ العِبادِ) بإضافتها، وقول ابن عباس حسنٌ مع قراءته». يريد تفسيره الآتي: يا ويلًا للعباد.</div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: في بعض القراءة: (يا حَسْرَةَ العِبادِ عَلى أنفُسِها ما يَأْتِيهِم مِّن رَّسُولٍ){2}<span class=comment-ref>٥٤٢٣</span>. (١٢/٣٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٣</span> ذكر <u>ابنُ كثير</u> (١١/٣٥٩) هذه القراءة، ثم قال <span class="comment-type-4">معلّقًا</span>: «ومعنى هذا: يا حسرتهم وندامتهم يوم القيامة إذا عاينوا العذاب، كيف كذبوا رسل الله، وخالفوا أمر الله، فإنهم كانوا في الدار الدنيا المكذبون منهم».</div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-: إنّ في بعض الحروف: (عَلى العِبادِ الحَسْرَةُ){3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٦٩<span class="dash">-</span></span> عن هارون، قال: في حرف <span class="name-1">أُبَيّ بن كعب</span>: (يا حَسْرَةَ العِبادِ ما يَأْتِيهِم مِّن رَّسُولٍ إلّا كانُوا بِهِ يَسْتَهْزِءُونَ){4}. (١٢/٣٤٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰحَسۡرَةً عَلَى ٱلۡعِبَادِۚ مَا یَأۡتِیهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span>، يقول: يا ويلًا للعباد{5}. (١٢/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span> قال: الندامة على العباد الذين <span class="qpc-hafs">﴿ما يَأْتِيهِمْ مِن رَسُولٍ إلّا كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span> يقول: الندامة عليهم يوم القيامة{6}. (١٢/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٢<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرياحي</span>: لَمّا عاينوا العذاب قالوا: <span class="qpc-hafs">﴿يا حَسْرَةً﴾</span> أي: ندامةً على العباد، يعني: على الرسل الثلاثة حيث لم يؤمنوا بهم، فتَمَنَّوا الإيمان حين لم ينفعهم{7}<span class=comment-ref>٥٤٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٤</span> <span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٧/٢٤٦) قول أبي العالية، فقال: «وقال أبو العالية: المراد بـ<span class="qpc-hafs">﴿العِبادِ﴾</span>: الرسل الثلاثة. فكأن هذا التحسر من الكفار حين رأوا عذاب الله تلهفوا على ما فاتهم». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى السياق</span> بقوله: «وقوله تعالى: <span class="qpc-hafs">﴿ما يَأْتِيهِمْ﴾</span> الآية، يدافع هذا التأويل».</div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span>، قال: كان حسرةً عليهم استهزاؤهم بالرسل{8}. (١٢/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خصيف- في قوله: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span>، قال: يا حسرة لهم{9}. (١٢/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٥<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span>، يعني: على أنفسهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span>، أي: يا حسرةَ العباد على أنفسها على ما ضيَّعت مِن أمر الله، وفرّطت في جنب الله{11}<span class=comment-ref>٥٤٢٥</span>. (١٢/٣٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٥</span> لم يذكر <u>ابنُ جرير</u> (١٩/٤٢٩-٤٣٠) غير قول قتادة، وقول مجاهد، وقول ابن عباس من طريق علي.</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٧/٢٤٦ بتصرف) على ما ذهب إليه <u>ابنُ جرير</u>، فقال: «قال الطبري: المعنى: يا حسرة العباد على أنفسهم. وذكر أنها في بعض القراءات كذلك. وتأويل الطبري في ذلك القراءة الأولى ليس بالبين، وإنما يتجه أن يكون المعنى: تلهفًا على العباد، كأن الحال يقتضيه وطباع كل بشر توجب عند سماعه حالهم وعذابهم على الكفر وتضييعهم أمر الله تعالى أن يشفق ويتحسر على العباد».</div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span> في أنفسهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا حَسْرَةً عَلى العِبادِ﴾</span> يا ندامة للعباد في الآخرة باستهزائهم بالرسل في الدنيا، ثم قال ﷿: <span class="qpc-hafs">﴿ما يَأْتِيهِمْ مِن رَسُولٍ إلّا كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ما يَأْتِيهِمْ مِن رَسُولٍ إلّا كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span> فيا لك حسرة عليهم، مثل قوله: <span class="qpc-hafs">﴿أنْ تَقُولَ نَفْسٌ يا حَسْرَتا عَلى ما فَرَّطْتُ فِي جَنْبِ اللَّهِ﴾</span> [الزمر:٥٦]، إذا كان القول من العباد قال العبد: يا حسرتا، وقال القوم: يا حسرتنا. إنّما أخبر الله أنّ تكذيبهم الرسل حسرة عليهم، وهذا من الصراخ بالنكرة الموصوفة{14}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وابن الأنباري في المصاحف.</p><p>وهي قراءة شاذة، تروى أيضًا عن أبي بن كعب، والحسن، ومجاهد، وغيرهم. انظر: المحتسب ٢/٢٠٧، ومختصر ابن خالويه ص١٢٥.|2:أخرجه ابن جرير ١٩/٤٢٩. وعزاه السيوطي إلى عبد بن حميد، ابن المنذر، وابن أبي حاتم.</p><p>وهي قراءة شاذة. انظر: النكت والعيون ٥/١٥، وروح المعاني ٢٣/٣.|3:أخرجه عبد الرزاق ٢/١٤١.</p><p>وهي قراءة شاذة.|4:أخرجه أبو عبيد في فضائل القرآن (١٨١). وعزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٩/٤٢٩-٤٣٠، وابن أبي حاتم -كما في الإتقان ٢/٣٨-. وعزاه السيوطي إلى ابن المنذر.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:تفسير الثعلبي ٨/١٢٧، وتفسير البغوي ٧/١٦.|8:تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٢٩، والفريابي -كما في التغليق ٤/٢٩١-. وعزاه السيوطي إلى عبيد بن حميد، وابن المنذر، وابن أبي حاتم.|9:أخرجه سفيان الثوري (٢٤٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:تفسير الثعلبي ٨/١٢٧، وتفسير البغوي ٧/١٦.|11:أخرجه ابن جرير ١٩/٤٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|12:أخرجه يحيى بن سلّام ٢/٨٠٦.|13:تفسير مقاتل بن سليمان ٣/٥٧٨.|14:تفسير يحيى بن سلّام ٢/٨٠٦.
  36,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ یَرَوۡا۟ كَمۡ أَهۡلَكۡنَا قَبۡلَهُم مِّنَ ٱلۡقُرُونِ أَنَّهُمۡ إِلَیۡهِمۡ لَا یَرۡجِعُونَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٨٠<span class="dash">-</span></span> عن أبي إسحاق، قال: قيل <span class="name-1">لابن عباس</span>: إنّ ناسًا يزعمون أن عليًّا مبعوثٌ قبل يوم القيامة! فسكت ساعة، ثم قال: بئس القوم نحن إن كُنّا أنكحنا نساءَه، واقتسمنا ميراثه، أما تقرءون: <span class="qpc-hafs">﴿ألَمْ يَرَوْا كَمْ أهْلَكْنا قَبْلَهُمْ مِنَ القُرُونِ أنَّهُمْ إلَيْهِمْ لا يَرْجِعُونَ﴾</span>؟!{1}. (١٢/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ألَمْ يَرَوْا كَمْ أهْلَكْنا قَبْلَهُمْ مِنَ القُرُونِ أنَّهُمْ إلَيْهِمْ لا يَرْجِعُونَ﴾</span>، قال: عادًا، وثمودًا، وقرونًا بين ذلك كثيرًا{2}. (١٢/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨٢<span class="dash">-</span></span> عن <span class="name-2">حميد الأعرج</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨٣<span class="dash">-</span></span> و<span class="name-2">أبي عمرو [البصري]</span> -من طريق هارون- في قوله: <span class="qpc-hafs">﴿أنَّهُمْ إلَيْهِمْ لا يَرْجِعُونَ﴾</span>، قالا: ليس في هذه اختلاف، هذا مِن رجوع الدنيا{3}. (١٢/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّف كفار مكة، فقال: <span class="qpc-hafs">﴿ألَمْ يَرَوْا﴾</span> ألم يعلموا <span class="qpc-hafs">﴿كَمْ أهْلَكْنا﴾</span> بالعذاب <span class="qpc-hafs">﴿قبلَهم﴾</span>؛ قبل كفار مكة <span class="qpc-hafs">﴿مِن القرون﴾</span> الأمم: عاد، وثمود، وقوم لوط، فيرى أهل مكة من هلاكهم <span class="qpc-hafs">﴿أنَّهُمْ إلَيْهِمْ لا يَرْجِعُونَ﴾</span> إلى الحياة الدنيا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ألَمْ يَرَوْا كَمْ أهْلَكْنا قَبْلَهُمْ مِنَ القُرُونِ أنَّهُمْ إلَيْهِمْ لا يَرْجِعُونَ﴾</span> أي: لا يرجعون إلى الدنيا، يعني: مَن أُهلِك مِن الأمم السالفة حين كذَّبوا رسلهم، يقول هذا لمشركي العرب، يقول: <span class="qpc-hafs">﴿ألَمْ يَرَوْا كَمْ أهْلَكْنا قَبْلَهُمْ مِنَ القُرُونِ﴾</span> يحذرهم أن ينزل بهم ما نزل بهم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ١٩/٤٣٠.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٥٧٨.|5:تفسير يحيى بن سلّام ٢/٨٠٧.
  36,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن كُلࣱّ لَّمَّا جَمِیعࣱ لَّدَیۡنَا مُحۡضَرُونَ ۝٣٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٨٦<span class="dash">-</span></span> عن هارون، عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إن كُلٌّ لَّمّا﴾</span> مثقلة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨٧<span class="dash">-</span></span> وفي قراءة <span class="name-1">أُبَيّ بن كعب</span>: (إلّا جَمِيعٌ لَّدَيْنا مُحْضَرُونَ){1}<span class=comment-ref>٥٤٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٦</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٩/٤٣١) على هذه القراءة، فقال: "وقرأ ذلك عامة قراء أهل الكوفة: <span class="qpc-hafs">﴿لما﴾</span> بتشديد الميم. ولتشديدهم ذلك عندنا وجهان: <b>أحدهما</b>: أن يكون الكلام عندهم كان مرادًا به: وإن كل لمما جميع. ثم حذفت إحدى الميمات لما كثرت، كما قال الشاعر:</p><p>غَداةَ طَفَتْ عَلْماءِ بكر بن وائل وعُجْنا صدور الخيلِ نحوَ تَمِيمِ</p><p><b>والآخر</b>: أن يكونوا أرادوا أن تكون <span class="qpc-hafs">﴿لما﴾</span> بمعنى: إلا مع إن خاصة، فتكون نظيرة إنما إذا وضعت موضع إلا«. ثم <span class="comment-type-4">علّق</span> عليها وعلى قراءة التخفيف، فقال:»والصواب من القول في ذلك عندي أنهما قراءتان <span class="mustanad">مشهورتان متقاربتا المعنى</span>، فبأيتهما قرأ القارئ فمصيب".</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٧/٢٤٧) قراءة التخفيف، فقال: «وقرأ الجمهور ‹لَما› بتخفيف الميم، وذلك على زيادة»ما«للتأكيد، والمعنى: لَجميع».</p><p>و<span class="comment-type-4">علّق</span> <u>ابن كثير</u> (١١/٣٥٩) على القراءتين بقوله: «ومعنى القراءتين واحد».</div></p><p><h3><span class="qpc-hafs">﴿وَإِن كُلࣱّ لَّمَّا جَمِیعࣱ لَّدَیۡنَا مُحۡضَرُونَ ۝٣٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإنْ كُلٌّ لَمّا جَمِيعٌ لَدَيْنا مُحْضَرُونَ﴾</span>، قال: أي: هم يوم القيامة{2}. (١٢/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٨٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿وإنْ كُلٌّ لَمّا جَمِيعٌ﴾</span> يعني: إلا جميع <span class="qpc-hafs">﴿لَدَيْنا مُحْضَرُونَ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>:<span class="qpc-hafs">﴿وإنْ كُلٌّ لَمّا جَمِيعٌ لَدَيْنا مُحْضَرُونَ﴾</span> عندنا في الآخرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإنْ كُلٌّ لَمّا جَمِيعٌ لَدَيْنا﴾</span> عندنا <span class="qpc-hafs">﴿مُحْضَرُونَ﴾</span> يوم القيامة، يعني: الماضين والباقين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص١٨٣.</p><p>و<span class="qpc-hafs">﴿إن كُلٌّ لَّمّا﴾</span> مثقلة الميم قراءة متواترة، قرأ بها ابن عامر، وعاصم، وحمزة، وابن جماز، وقرأ بقية العشرة: ‹إن كُلٌّ لَّما› مخففة الميم. انظر: النشر ٢/٣٥٣، والإتحاف ص٤٦٧.</p><p>وأما (إلّا جَمِيعٌ) فهي قراءة شاذة. انظر: تفسير الرازي ٢٦/٦٤.|2:أخرجه ابن جرير ١٩/٤٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:علقه يحيى بن سلّام ٢/٨٠٧.|4:تفسير مقاتل بن سليمان ٣/٥٧٨.|5:تفسير يحيى بن سلّام ٢/٨٠٧.
  36,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَءَایَةࣱ لَّهُمُ ٱلۡأَرۡضُ ٱلۡمَیۡتَةُ أَحۡیَیۡنَـٰهَا وَأَخۡرَجۡنَا مِنۡهَا حَبࣰّا فَمِنۡهُ یَأۡكُلُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ الأَرْضُ المَيْتَةُ﴾</span>، يعني: المُجْدِبة، أي: الذي أحياها بعد موتها قادِر على أن يُحيي الموتى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم وعظ كفارَ مكة، فقال ﷿: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ﴾</span> وعلامة لهم <span class="qpc-hafs">﴿الأَرْضُ المَيْتَةُ أحييناها﴾</span> بالمطر فتنبت، <span class="qpc-hafs">﴿وأَخْرَجْنا مِنها حَبًّا﴾</span> البر والشعير؛ الحبوب كلها، <span class="qpc-hafs">﴿فَمِنهُ يَأْكُلُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أحْيَيْناها﴾</span> بالنبات، يعني بـ<span class="qpc-hafs">﴿المَيْتَةُ﴾</span>: الأرض التي ليس فيها نبات{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلّام ٢/٨٠٧.|2:تفسير مقاتل بن سليمان ٣/٥٧٨.|3:تفسير يحيى بن سلّام ٢/٨٠٧.
  36,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا فِیهَا جَنَّـٰتࣲ مِّن نَّخِیلࣲ وَأَعۡنَـٰبࣲ وَفَجَّرۡنَا فِیهَا مِنَ ٱلۡعُیُونِ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلْنا فِيها﴾</span> في الأرض <span class="qpc-hafs">﴿جَنّاتٍ﴾</span> بساتين <span class="qpc-hafs">﴿مِن نخيل وأعناب وفَجَّرْنا فِيها مِنَ العُيُونِ﴾</span> الجارية{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٧٨.
  36,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِیَأۡكُلُوا۟ مِن ثَمَرِهِۦ وَمَا عَمِلَتۡهُ أَیۡدِیهِمۡۚ أَفَلَا یَشۡكُرُونَ ۝٣٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّه قرأ: <span class="qpc-hafs">﴿وما عَمِلَتْهُ أيْدِيهِمْ﴾</span>{1}. (١٢/٣٤٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِیَأۡكُلُوا۟ مِن ثَمَرِهِۦ وَمَا عَمِلَتۡهُ أَیۡدِیهِمۡۚ أَفَلَا یَشۡكُرُونَ ۝٣٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٥٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وما عَمِلَتْهُ أيْدِيهِمْ﴾</span>، قال: وجدوه معمولًا، لم تَعْمَلْه أيديهم. يعني: الفرات، ودجلة، ونهر بلخ، وأشباهها، <span class="qpc-hafs">﴿أفَلا يَشْكُرُون﴾</span> لهذا؟!{2}. (١٢/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٩٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿وما عَمِلَتْهُ أيْدِيهِمْ﴾</span> لم يكن ذلك مِن فعلهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٥٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِيَأْكُلُوا مِن ثَمَرِهِ وما عَمِلَتْهُ أيْدِيهِمْ﴾</span> يقول: لم يكن ذلك مِن صنع أيديهم، ولكنه مِن فعلنا، <span class="qpc-hafs">﴿أفَلا يَشْكُرُون﴾</span> ربَّ هذه النِّعَم؛ فيُوَحِّدوه!{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لِيَأْكُلُوا مِن ثَمَرِهِ وما عَمِلَتْهُ أيْدِيهِمْ﴾</span> أي: لم تكن تعمله أيديهم، ونحن أنبتنا ما فيها، <span class="qpc-hafs">﴿أفَلا يَشْكُرُونَ﴾</span> أي: فليشكروا{5}<span class=comment-ref>٥٤٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٩/٤٣٣) في «ما» من قوله: <span class="qpc-hafs">﴿وما عملته أيديهم﴾</span> ثلاثة أوجه، فقال: «و»ما«التي في قوله: ‹وما عَمِلَتْ أيْدِيهِمْ› [كذا، وهي قراءة حمزة والكسائي وأبي بكر عن عاصم] في موضع خفض عطفًا على الثمر، <b>بمعنى</b>: ومن الذي عملت أيديهم، وهي في قراءة عبد الله فيما ذكر: (ومِمّا عَمِلَتْهُ) بالهاء على هذا المعنى؛ فالهاء في قراءتنا مضمرة، لأن العرب تضمرها أحيانًا، وتظهرها في صلات: من، وما، والذي. <b>ولو قيل</b>:»ما«بمعنى المصدر كان مذهبًا، فيكون معنى الكلام: ومن عمل أيديهم. <b>ولو قيل</b>: إنها بمعنى الجحد، ولا موضع لها؛ كان أيضًا مذهبًا، فيكون معنى الكلام: ليأكلوا من ثمره، ولم تعمله أيديهم».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٧/٢٤٨).</div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا حمزة، والكسائي، وخلفًا، وشعبة؛ فإنهم قرؤوا: ‹وما عَمِلَتْ› بدون هاء. انظر: النشر ٢/٣٥٣، والإتحاف ص٤٦٧.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:علقه يحيى بن سلّام ٢/٨٠٧.|4:تفسير مقاتل بن سليمان ٣/٥٧٨.|5:تفسير يحيى بن سلّام ٢/٨٠٧.
  36,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَ ٱلَّذِی خَلَقَ ٱلۡأَزۡوَ ٰ⁠جَ كُلَّهَا مِمَّا تُنۢبِتُ ٱلۡأَرۡضُ وَمِنۡ أَنفُسِهِمۡ وَمِمَّا لَا یَعۡلَمُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٠١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</span> الأصناف كلها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</span> الأصناف كلها <span class="qpc-hafs">﴿مِمّا تُنْبِتُ الأَرْضُ﴾</span> مِمّا تخرج الأرض مِن ألوان النبات والشجر، <span class="qpc-hafs">﴿ومِن أنْفُسِهِمْ﴾</span> الذكر والأنثى، <span class="qpc-hafs">﴿ومِمّا لا يَعْلَمُونَ﴾</span> مِن الخلق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</span> قال: الأصناف كلها؛ الملائكة زوج، والإنس زوج، والجن زوج، وما تنبت الأرض زوج، وكل صنف من الطير زوج. ثم فسَّره فقال: <span class="qpc-hafs">﴿مِمّا تُنْبِتُ الأَرْضُ ومِن أنْفُسِهِمْ ومِمّا لا يَعْلَمُونَ﴾</span> الروح؛ لا يعلمه إلا الله، لا الملائكة، ولا خلق الله، ولم يطَّلع على الروح أحد. وقوله: <span class="qpc-hafs">﴿ومِمّا لا يَعْلَمُونَ﴾</span> لا يعلم الملائكة، ولا غيرها الروح{3}. (١٢/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</span> أي: الألوان كلها <span class="qpc-hafs">﴿مِمّا تُنْبِتُ الأَرْضُ ومِن أنْفُسِهِمْ﴾</span> الذكر والأنثى، ومما خلق في البر والبحر، من صغير وكبير، <span class="qpc-hafs">﴿ومِمّا لا يَعْلَمُونَ﴾</span> وهو كقوله: <span class="qpc-hafs">﴿ويَخْلُقُ ما لا تَعْلَمُونَ﴾</span> [النحل:٨]{4}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلّام ٢/٨٠٨.|2:تفسير مقاتل بن سليمان ٣/٥٧٨.|3:عزاه السيوطي إلى ابن المنذر.|4:تفسير يحيى بن سلّام ٢/٨٠٧.
  36,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَءَایَةࣱ لَّهُمُ ٱلَّیۡلُ نَسۡلَخُ مِنۡهُ ٱلنَّهَارَ فَإِذَا هُم مُّظۡلِمُونَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ اللَّيْلُ نَسْلَخُ مِنهُ النَّهارَ﴾</span>، قال: نُخرِجُ أحدَهما من الآخر، ويجري كلٌّ منهما في فَلَك{1}. (١٢/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ اللَّيْلُ نَسْلَخُ مِنهُ النَّهارَ﴾</span>، قال: كقوله: <span class="qpc-hafs">﴿يُولِجُ اللَّيْلَ فِي النَّهارِ ويُولِجُ النَّهارَ فِي اللَّيْلِ﴾</span> [الحج:٦١، والحديد:٦]{2}<span class=comment-ref>٥٤٢٨</span>. (١٢/٣٤٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٨</span> ذكر <u>ابنُ جرير</u> (١٩/٤٣٤) أن معنى: <span class="qpc-hafs">﴿وآية لهم الليل نسلخ منه النهار﴾</span> أي: ننزِع عنه النهار. ثم ذكر قول قتادة، <span class="comment-type-2">وانتقده</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> قائلًا: «وهذا الذي قاله قتادة في ذلك عندي مِن معنى سلخ النهار من الليل بعيد؛ وذلك أن إيلاج الليل في النهار إنما هو زيادة ما نقص من ساعات هذا في ساعات الآخر، وليس السلخ من ذلك في شيء؛ لأن النهار يسلخ من الليل كله، وكذلك الليل من النهار كله، وليس يولج كل الليل في كل النهار، ولا كل النهار في كل الليل».</p><p>ووافقه <u>ابنُ كثير</u> (١١/٣٦٠). و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> <span class="mustanad">مستندًا إلى ظاهر الآية</span> أن المعنى: «<span class="qpc-hafs">﴿وآية لهم الليل نسلخ منه النهار﴾</span> أي: نصرمه منه فيذهب، فيقبل الليل؛ ولهذا قال: <span class="qpc-hafs">﴿فإذا هم مظلمون﴾</span> كما جاء في الحديث: «<b>إذا أقبل الليل من هاهنا، وأدبر النهار من هاهنا، وغربت الشمس، فقد أفطر الصائم</b>». هذا هو الظاهر من الآية».</div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ اللَّيْلُ نَسْلَخُ مِنهُ النَّهارَ﴾</span> نذهب به؛ <span class="qpc-hafs">﴿فَإذا هُمْ مُظْلِمُونَ﴾</span> داخلون في الظلام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ﴾</span> يقول: مِن علامة الرب لأهل مكة إذ لم يروه <span class="qpc-hafs">﴿اللَّيْلُ نَسْلَخُ مِنهُ النَّهارَ﴾</span> نَنزِع منه النهار؛ <span class="qpc-hafs">﴿فَإذا هُمْ مُظْلِمُونَ﴾</span> بالليل، مثل قوله ﷿: <span class="qpc-hafs">﴿واتْلُ عَلَيْهِمْ نَبَأَ الَّذِي آتَيْناهُ آياتِنا فانْسَلَخَ مِنها فَأَتْبَعَهُ الشَّيْطانُ فَكانَ مِنَ الغاوِينَ﴾</span> [الأعراف:١٧٥]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ اللَّيْلُ نَسْلَخُ مِنهُ النَّهارَ﴾</span> نُذهِب منه النهار{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الفريابي -كما في التغليق ٣/٤٩١-. وعزا أوله السيوطي إلى ابن جرير، وورد عند ابن جرير ٥/٣٠٥ في تفسير قوله تعالى: <span class="qpc-hafs">﴿تولج الليل في النهار وتولج النهار في الليل﴾</span> [آل عمران:٢٧] بلفظ: ما ينقص من أحدهما يدخل في الآخر، متعاقبان ذلك من الساعات.|2:أخرجه ابن جرير ١٩/٤٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|3:تفسير الثعلبي ٨/١٢٨.|4:تفسير مقاتل بن سليمان ٣/٥٧٨-٥٧٩.|5:تفسير يحيى بن سلّام ٢/٨٠٨.
  36,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلشَّمۡسُ تَجۡرِی لِمُسۡتَقَرࣲّ لَّهَاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٣٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٦١٠<span class="dash">-</span></span> عن أبي ذرٍّ، قال: دخلتُ المسجدَ ورسولُ الله ﷺ جالس، فلما غربت الشمس قال: <b>«يا أبا ذر، هل تدري أين تذهب هذه؟».</b> قال: قلت: الله ورسوله أعلم. قال: <b>«فإنها تذهب تستأذن في السجود، فيؤذن لها، وكأنها قد قيل لها: ارجعي من حيث جئت، فتطلع من مغربها</b>». ثم قرأ: (وذَلِكَ مُسْتَقَرٌّ لَّها). في قراءة <span class="name-1">عبد الله [بن مسعود]</span>{1}. (١٢/٣٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، أنه كان يقرأ: (والشَّمْسُ تَجْرِي لا مُسْتَقَرَّ لَها){2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنّه كان يقرأ: (والشَّمْسُ تَجْرِي لا مُسْتَقَرَّ لَها){3}<span class=comment-ref>٥٤٢٩</span>. (١٢/٣٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٢٩</span> ذكر <u>ابنُ كثير</u> (١١/٣٦٢) قراءة ابن عباس وابن مسعود، ثم <span class="comment-type-1">وجّهها</span>، فقال: «وقرأ ابن مسعود، وابن عباس: (والشَّمْسُ تَجْرِي لا مُسْتَقَرَّ لَها» أي: لا قرار لها ولا سكون، بل هي سائرة ليلًا ونهارًا، لا تفتر ولا تقف. <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿وسخر لكم الشمس والقمر دائبين﴾</span> [إبراهيم:٣٣]، أي: لا يفتران ولا يقفان إلى يوم القيامة".</div></p><p><div></p><p><p><span class="item-no">٦٤٦١٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سفيان، عن شيخ له- أنه قرأ: (والشَّمْسُ تَجْرِي لا مُسْتَقَرَّ لَها){4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلشَّمۡسُ تَجۡرِی لِمُسۡتَقَرࣲّ لَّهَاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٣٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٦١٤<span class="dash">-</span></span> عن أبي ذرٍّ، قال: سألتُ رسول الله ﷺ عن قوله: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span>. قال:«<b>مستقرُّها تحت العرش</b>»{5}. (١٢/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١٥<span class="dash">-</span></span> عن أبي ذرٍّ، قال: كنت مع النبي ﷺ في المسجد عند غروب الشمس، فقال: «<b>يا أبا ذرٍّ، أتدري أين تغرب الشمس</b>؟». قلت: الله ورسوله أعلم. قال: «<b>فإنها تذهب حتى تسجد تحت العرش، فذلك قوله</b>: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span>»{6}. (١٢/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١٦<span class="dash">-</span></span> عن أبي ذرٍّ، قال: قال النبي ﷺ لأبي ذرٍّ حين غربت الشمس: «<b>أتدري أين تذهب؟</b>». قلت: الله ورسوله أعلم. قال: «<b>فإنها تذهب حتى تسجد تحت العرش، فتستأذن، فيؤذن لها، ويوشك أن تسجد، فلا يقبل منها، وتستأذن، فلا يؤذن لها، يقال لها: ارجعي من حيث جئت، فتطلع من مغربها، فذلك قوله تعالى</b>: <span class="qpc-hafs">﴿والشمس تجري لمستقر لها ذلك تقدير العزيز العليم﴾</span>«{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١٧<span class="dash">-</span></span> عن أبى ذرٍّ الغفاري، قال: كنت آخذ بيد رسول الله ﷺ، ونحن نتماشى جميعًا نحو المغرب، وقد طَفَلَت الشمس{8}، فما زلنا ننظر إليها حتى غابت، قال: قلت: يا رسول الله، أين تغرب؟ قال: «<b>تغرب في السماء ثم ترفع مِن سماء إلى سماء، حتى ترفع إلى السماء السابعة العليا، حتى تكون تحت العرش، فتخر ساجدة، فتسجد معها الملائكة الموكلون بها، ثم تقول: يا رب، مِن أين تأمرني أن أطلع؛ أمِن مغربي أم مِن مطلعي</b>؟». قال: فذلك قوله ﷿: <span class="qpc-hafs">﴿والشمس تجرى لمستقر لها﴾</span> حيث تحبس تحت العرش <span class="qpc-hafs">﴿ذلك تقدير العزيز العليم﴾</span>. قال: يعني: ذلك صنع الرب العزيز في ملكه العليم بخلقه. قال: فيأتيها جبرائيل ﵇ بحلة ضوء مِن نور العرش، على مقادير ساعات النهار في طوله في الصيف أو قصره في الشتاء أو ما بين ذلك في الخريف والربيع. قال: فتلبس تلك الحُلَّة كما يلبس أحدكم ثيابه، ثم ينطلق بها في جو السماء حتى تطلع من مطالعها. قال النبي ﷺ: «<b>فكأنها قد حُبست مقدار ثلاث ليال، ثم لا تُكسى ضوءًا، وتُؤمر أن تطلع من مغربها</b>». فذلك قوله ﷿: <span class="qpc-hafs">﴿إذ الشمس كورت﴾</span> [التكوير:١]. قال: والقمر كذلك في مطلعه ومجراه في أفق السماء ومغربه وارتفاعه إلى السماء السابعة العليا، ومحبسه تحت العرش وسجوده واستئذانه، ولكن جبرائيل ﵇ يأتيه بالحلة من نور الكرسي. قال: فذلك قوله ﷿: <span class="qpc-hafs">﴿جعل الشمس ضياء والقمر نورا﴾</span> [يونس:٥]. قال أبو ذر: ثم عدلت مع رسول الله ﷺ، فصلَّيْنا المغرب{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق وهب بن جابر الخيواني- قال: مستقرها: أن تطلع، فتردَّها ذنوب بني آدم، فإذا غربت سلَّمت، وسجدت، واستأذنت، فيؤذن لها، حتى إذا غربت سلَّمت وسجدت فلا يؤذن لها، فتقول: إنّ السير بعيد، وإنِّي إن لم يُؤذَن لي لا أبلغ. فتحبس ما شاء الله أن تحبس، ثم يقال: اطلُعي مِن حيث غربت. قال: فمِن يومئذٍ إلى يوم القيامة لا ينفع نفسًا إيمانُها{10}. (١٢/٣٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦١٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span> لا تبلغ مستقرها حتى ترجع إلى منازلها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق أبي الصهباء-: بقدر يجريان، يعني: الشمس والقمر، يجريان بإذن الله{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span>، ثم ترجع إلى أدنى منازلها إلى يوم القيامة، حيث تُكوَّر فيذهب ضوؤها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span>، قال: لوقتها، ولأجَلٍ لا تَعْدُوه{14}. (١٢/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span>، يعني: لمنتهاها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span> لوقتٍ لها إلى يوم القيامة، <span class="qpc-hafs">﴿ذلك﴾</span> الذي ذُكِر من الليل والنهار، والشمس والقمر يجري في ملكه بما قدر من أمرهما وخلْقهما <span class="qpc-hafs">﴿تقدير العزيز العليم﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span> لا تُجاوِزُه، وهذا أبعد مسيرها، هذا مثل قوله: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمُ الشَّمْسَ والقَمَرَ دائبين﴾</span> [إبراهيم:٣٣]{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٦<span class="dash">-</span></span> عن أبي راشد -من طريق الأعمش- في قوله: <span class="qpc-hafs">﴿والشَّمْسُ تَجْرِي لِمُسْتَقَرٍّ لَها﴾</span>، قال: موضع سجودها{18}. (١٢/٣٤٨)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٩/١٢٥ (٧٤٢٤)، ومسلم ١/١٣٩ (١٥٩)، وابن جرير ١٩/٤٣٥.</p><p>وهي قراءة شاذة.|2:تفسير الثعلبي ٨/١٢٨، وأخرجه البغوي ٧/١٨.</p><p>وهي قراءة شاذة، تروى أيضًا عن عكرمة. انظر: الجامع لأحكام القرآن ١٧/٤٤٥.|3:أخرجه يحيى بن سلّام ٢/٨٠٨، وأبو عبيد في فضائله ص١٨١، والثعلبي ٨/١٢٨. وعزاه السيوطي إلى أحمد، وابن الأنباري في المصاحف.|4:أخرجه إسحاق البستي ص١٨٥.|5:أخرجه البخاري ٦/١٢٣ (٤٨٠٣)، ٩/١٢٧ (٧٤٣٣)، ومسلم ١/١٣٨ (١٥٩).|6:أخرجه البخاري ٦/١٢٣ (٤٨٠٢).|7:أخرجه البخاري ٤/١٠٧ (٣١٩٩).|8:طفلت الشمس: دَنَتْ من الغُرُوب. النهاية (طفل).|9:أخرجه ابن جرير في تاريخه ١/٦٣-٦٥، من طريق عمر بن صبح أبي نعيم البلخي، عن مقاتل بن حيان، عن عبد الرحمن بن أبزى، عن أبي ذر الغفاري به.</p><p>إسناده ضعيف جدًّا؛ فيه عمر بن صبح التميمي أبو نعيم الخراساني، قال عنه ابن حجر في التقريب (٤٩٢٢): «متروك، كذّبه ابن راهويه».|10:أخرجه عبد الرزاق ٢/١٤٢، وأبو الشيخ في العظمة (٦٣١). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|11:تفسير الثعلبي ٨/١٢٨.|12:أخرجه إسحاق البستي ص١٨٦.|13:علقه يحيى بن سلّام ٢/٨٠٨.|14:أخرجه ابن جرير ١٩/٤٣٥ بنحوه، وأبو الشيخ (٦٦٤). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن الأنباري في المصاحف.|15:علقه يحيى بن سلّام ٢/٨٠٨.|16:تفسير مقاتل بن سليمان ٣/٥٧٩.|17:تفسير يحيى بن سلّام ٢/٨٠٨.|18:أخرجه إسحاق البستي ص١٨٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.
  36,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡقَمَرَ قَدَّرۡنَـٰهُ مَنَازِلَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿والقَمَرَ قَدَّرْناهُ مَنازِلَ حَتّى عادَ كالعُرْجُونِ القَدِيمِ﴾</span>، قال: في ثمانية وعشرين منزلًا، ينزلها القمر في شهر؛ أربعة عشر منها شامية، وأربعة عشر منها يمانية: فأولها الشَّرْطِين، والبُطَين، والثريا، والدبران، والهقْعَة، والهنْعة، والذِّراع، والنَّثْرة، والطَّرْف، والجَبهة، والزُّبْرة، والصَّرْفة، والعَوّاء، والسِّماك وهو آخر الشامية، والغَفْر، والزُّبانيين، والإكليل، والقلب، والشَّوْلة، والنعائم، والبَلدة، وسعد الذابح، وسعد بُلَع، وسعد السُّعود، وسعد الأخبية، ومُقدَّم الدلو، ومُؤخَّر الدلو، والحوت وهو آخر اليمانية، فإذا سار هذه الثمانية والعشرين منزلًا عاد كالعرجون القديم كما كان في أول الشهر{1}. (١٢/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والقَمَرَ قَدَّرْناهُ مَنازِلَ﴾</span> لا يطلع ولا يغيب إلا في زيادة أو نقصان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والقَمَرَ قَدَّرْناهُ مَنازِلَ﴾</span>، قال: قدَّره اللهُ منازل، فجعل ينقص حتى كان مثل عِذق النخلة، فشبَّهه بذلك{3}. (١٢/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿والقَمَرَ قَدَّرْناهُ مَنازِلَ﴾</span> يجري على منازله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿والقَمَرَ قَدَّرْناهُ مَنازِلَ﴾</span> في السماء يزيد، ثم يستوي، ثم ينقص في آخر الشهر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والقَمَرَ قَدَّرْناهُ مَنازِلَ﴾</span> يزيد وينقص{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ عَادَ كَٱلۡعُرۡجُونِ ٱلۡقَدِیمِ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كالعُرْجُونِ القَدِيمِ﴾</span>: يعني: أصل العِذْق{7} العتيق{8}<span class=comment-ref>٥٤٣٠</span>. (١٢/٣٥٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٠</span> <span class="comment-type-1">وجّه</span> <u>ابنُ كثير</u> (١١/٣٦٣) قول ابن عباس، فقال: «يعني ابن عباس: أصل العنقود مِن الرطب إذا عَتُق ويبس وانحنى».</div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿كالعُرْجُونِ القَدِيمِ﴾</span>: يعني بالعرجون: العِذق اليابس{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٥<span class="dash">-</span></span> عن <span class="name-2">يزيد بن الأصم</span> -من طريق جعفر بن برقان- في قوله: <span class="qpc-hafs">﴿حَتّى عادَ كالعُرْجُونِ القَدِيمِ﴾</span>، قال: عِذق النخلة إذا قدُم انحنى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- في قوله: <span class="qpc-hafs">﴿كالعُرْجُونِ القَدِيمِ﴾</span>، قال: عرجون النخل اليابس{11}. (١٢/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عيسى بن عبيد- في قوله: <span class="qpc-hafs">﴿كالعُرْجُونِ القَدِيمِ﴾</span>، قال: النخلة القديمة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿كالعُرْجُونِ القَدِيمِ﴾</span>، قال: كعِذق النخلة إذا قَدُمَ فانحنى{13}<span class=comment-ref>٥٤٣١</span>. (١٢/٣٥٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣١</span> ذكر <u>ابنُ عطية</u> (٧/٢٥٠) قول الحسن، ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «العرجون: وهو الغصن من النخلة الذي فيه شماريخ التمر، فإنه ينحني ويصفر إذا قدم، ويجيء أشبه شيء بالهلال. قاله الحسن بن أبي الحسن، والوجود يشهد به».</div></p><p><div></p><p><p><span class="item-no">٦٤٦٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كالعُرْجُونِ القَدِيمِ﴾</span>، قال: هو عِذق النخلة اليابس المنحني{14}. (١٢/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٠<span class="dash">-</span></span> عن <span class="name-2">سليمان التيمي</span> -من طريق أبي عاصم- في قوله: <span class="qpc-hafs">﴿حَتّى عادَ كالعُرْجُونِ القَدِيمِ﴾</span>، قال: العِذْق{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى عادَ كالعُرْجُونِ﴾</span> حتى عاد مثل الخيط، كما يكون أول ما استهل فيه، <span class="qpc-hafs">﴿كالعُرْجُونِ﴾</span> يعني: العِذق اليابس المنحني <span class="qpc-hafs">﴿القديم﴾</span> الذي أتى عليه الحول{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ عَادَ كَٱلۡعُرۡجُونِ ٱلۡقَدِیمِ ۝٣٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٤٢<span class="dash">-</span></span> عن الحسين بن الوليد، قال: أعتق رجلٌ كُلَّ غلام له قديم، فسُئِل يعقوب، فقال: مَن كان لِسَنَةٍ فهو حرٌّ؛ قال الله: <span class="qpc-hafs">﴿حَتّى عادَ كالعُرْجُونِ القَدِيمِ﴾</span> فهو لِسنة{17}. (١٢/٣٥٠)</p></p><p></div></p></div>",footnotes:1:أخرجه الخطيب في كتاب النجوم ص١٣٣-١٤٠.|2:علقه يحيى بن سلّام ٢/٨٠٨.|3:أخرجه ابن جرير ١٩/٤٣٨. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.|4:علقه يحيى بن سلّام ٢/٨٠٨.|5:تفسير مقاتل بن سليمان ٣/٥٧٩.|6:تفسير يحيى بن سلّام ٢/٨٠٨.|7:العِذْق -بالكسر-: عرجون النخلة، بما فيه من شماريخ. والشُّمْروخ: العِثْكال الذي عليه البُسْر. النهاية (عذق، عرج)، واللسان (شمرخ).|8:أخرجه ابن جرير ١٩/٤٣٧، وابن أبي حاتم -كما في الإتقان ٢/٣٨-. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن جرير ١٩/٤٣٧.|10:أخرجه ابن جرير ١٩/٤٣٧.|11:أخرجه يحيى بن سلّام ٢/٨٠٦ بنحوه، وابن جرير ١٩/٤٣٧-٣٤٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|12:أخرجه ابن جرير ١٩/٤٣٧.|13:أخرجه ابن جرير ١٩/٤٣٧، وإسحاق البستي ص١٨٥ بلفظ: إذا قام فانحنى. وعزاه السيوطي إلى ابن أبي حاتم.|14:أخرجه عبد الرزاق ٢/١٤١ من طريق معمر، وابن جرير ١٩/٤٣٨ بنحوه مطولًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|15:أخرجه ابن جرير ١٩/٤٤٧.|16:تفسير مقاتل بن سليمان ٣/٥٧٩.|17:عزاه السيوطي إلى ابن المنذر.
  36,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا ٱلشَّمۡسُ یَنۢبَغِی لَهَاۤ أَن تُدۡرِكَ ٱلۡقَمَرَ وَلَا ٱلَّیۡلُ سَابِقُ ٱلنَّهَارِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span>، يقول: إذا اجتمعا في السماء كان أحدُهما بين يدي الآخر، فإذا غابا غاب أحدهما بين يدي الآخر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span> قال: لا يُشْبِهُ ضوءُ أحدهما ضوءَ الآخر، ولا ينبغي لهما ذلك، <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> قال: يتطالبان حثيثين، يسلخ أحدهما من الآخر{2}. (١٢/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span>، قال: في قضاء الله وعِلمه أن لا يفوت الليلُ النهارَ حتى يُدركَه فيُذهب ظلمته، وفي قضاء الله وعلمه أن لا يفوت النهارُ الليل حتى يدركه فيذهب بضوئه{3}. (١٢/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَر﴾</span>: ليلة الهلال خاصَّة لا يجتمعان في السماء، وقد يُرَيان جميعًا، ويجتمعان في غير ليلة الهلال{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span>، قال: لا يعلو هذا ضوءَ هذا، ولا هذا على هذا{5}. (١٢/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span>، قال: لا يذهب الليلُ مِن هاهنا حتى يجيء النهارُ مِن هاهنا. وأومأ بيده إلى المشرق{6}. (١٢/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٤٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span>: هذا في ضوء القمر وضوء الشمس، إذا طلعت الشمس لم يكن للقمر ضوء، وإذا طلع القمر بضوئه لم يكن للشمس ضوء، <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> قال: في قضاء الله وعلمه أن لا يفوت الليل النهار حتى يدركه، فيذهب ظلمته، وفي قضاء الله أن لا يفوت النهار الليل حتى يدركه، فيذهب بضوئه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span>، قال: لا يسبق هذا ضوءَ هذا، ولا هذا ضوءَ هذا{5}. (١٢/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span>، قال: لكل واحد منهما سلطان؛ للقمر سلطان بالليل، وللشمس سلطان بالنهار، فلا ينبغي للشمس أن تطلع بالليل. وقوله: <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> يقول: لا ينبغي إذا كان ليلٌ أن يكون ليلٌ آخر، حتى يكون النهار{9}. (١٢/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span>، قال: ذاك ليلة الهلال{9}. (١٢/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span> قال: لا ينبغي للشمس أن تدرك القمر، يعني: أنّ الليل والنهار لا يجتمعان، <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> قال: لا ينبغي لليل أن يُدرِك ضوء النهار{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span>، قال: لا يدرك هذا ضوءَ هذا، ولا هذا ضوءَ هذا{12}. (١٢/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span>، قال: لكلٍ حَدٌّ وعِلْمٌ لا يَعْدُوه، ولا يقصر دونه، إذا جاء سلطانُ هذا ذهبَ سلطانُ هذا، وإذا جاء سلطانُ هذا ذهب سلطانُ هذا{13}. (١٢/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> لا ينبغي للشمس أن تطلع بالليل فتكون مع القمر في سلطانه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَرَ﴾</span> فتضيء مع ضوء القمر؛ لأنّ الشمس سلطان النهار، والقمر سلطان الليل، ثم قال ﷿: <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> يقول: ولا يُدرك سوادُ الليل ضوءَ النهار، فيغلبه على ضوئه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَر﴾</span> لا يجتمع ضوؤهما؛ ضوء الشمس بالنهار، وضوء القمر بالليل، لا ينبغي لهما أن يجتمع ضوؤهما. وبعضهم يقول: <span class="qpc-hafs">﴿لا الشَّمْسُ يَنْبَغِي لَها أنْ تُدْرِكَ القَمَر﴾</span> صبيحة ليلة البدر، يبادر فيغيب قبل طلوعها، <span class="qpc-hafs">﴿ولا اللَّيْلُ سابِقُ النَّهارِ﴾</span> يأتي عليه النهار فيذهبه، كقوله: <span class="qpc-hafs">﴿يُغْشِي اللَّيْلَ النَّهارَ يَطْلُبُهُ حَثِيثًا﴾</span> [الأعراف:٥٤]{16}<span class=comment-ref>٥٤٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٢</span> <span class="comment-type-4">قال</span> <u>ابن جرير</u> (١٩/٤٣٨): «وقوله: <span class="qpc-hafs">﴿لا الشمس ينبغي لها أن تدرك القمر﴾</span> يقول -تعالى ذِكْرُه-: لا الشمس يصلح لها إدراك القمر، فيذهب ضوءها بضوئه، فتكون الأوقات كلها نهارًا لا ليل فيها، <span class="qpc-hafs">﴿ولا الليل سابق النهار﴾</span> يقول -تعالى ذكره-: ولا الليل بفائت النهار حتى تذهب ظلمته بضيائه، فتكون الأوقات كلها ليلًا. وبنحو الذي قلنا في ذلك قال أهل التأويل على اختلاف منهم في ألفاظهم في تأويل ذلك، إلا أن معاني عامتهم الذي قلناه». ثم ذكر قول ابن عباس من طريق عطية العوفي، ومجاهد بن جبر من طريق ابن أبي نجيح، وقتادة، وأبي صالح باذام، والضحاك بن مزاحم من طريق عبيد.</p><p>وذكر <u>ابنُ كثير</u> (١١/٢٦٤) عبارات السلف في تفسير الآية، ثم <span class="comment-type-4">علّق</span> قائلًا: «والمعنى في هذا: أنّه لا فترة بين الليل والنهار، بل كل منهما يعقب الآخر بلا مهلة ولا تراخٍ؛ لأنهما مسخَّران دائبين يتطالبان طلبًا حثيثًا».</div></p><p><h3><span class="qpc-hafs">﴿وَكُلࣱّ فِی فَلَكࣲ یَسۡبَحُونَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span>، قال: في فلك كفَلَكِ المِغْزَل{17}{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق على- قوله: <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span> دوران، يقول: دورانًا <span class="qpc-hafs">﴿يَسْبَحُونَ﴾</span> يقول: يجرون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span>، يعني: كل في فلك في السموات{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: مجرى كل واحد منهما -يعني: الليل والنهار- <span class="qpc-hafs">﴿في فلك يسبحون﴾</span> يجرون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span> والشمس والقمر بالليل والنهار <span class="qpc-hafs">﴿يسبحون﴾</span> يدورون كما يدور فلك المغزل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد- قال: مثل فلكة المغزل يدور{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span>، الفلك: طاحونة مستديرة كفلكة المغزل بين السماء والأرض، وتجري فيها الشمس والقمر والنجوم، وليست بملتصقة بالسماء، ولو كانت ملتصقة ما جرت{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span>: أي: في فلك السماء يسبحون{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿يَسْبَحُونَ﴾</span> يجرون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span>، قال: كل شيء يدور فهو فلك{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكُلٌّ﴾</span> الليل والنهار <span class="qpc-hafs">﴿فِي فَلَكٍ يَسْبَحُونَ﴾</span> في دوران يجرون، يعني: الشمس والقمر يدخلان تحت الأرض مِن قِبَل المغرب، فيخرجان مِن تحت الأرض، حتى يخرجا من قبل المشرق، ثم يجريان في السماء حتى يغربا قِبل المغرب، فهذا دورانهما، فذلك قوله ﷿: <span class="qpc-hafs">﴿وكُلٌّ فِي فَلَكٍ يَسْبَحُونَ﴾</span> يقول: وكلاهما في دورانٍ يجريان إلى يوم القيامة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٠<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿في فلك يسبحون﴾</span>، قال: مثل قُطب الرَّحى{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكُلࣱّ فِی فَلَكࣲ یَسۡبَحُونَ ۝٤٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٧١<span class="dash">-</span></span> عن مجاهد بن جبر: أنّ أُناسًا من اليهود قالوا <span class="name-1">لعمر بن الخطاب</span>: تقولون: جنة عرضها السموات والأرض، فأين تكون النار؟ قال: أرأيتَ إذا جاء النهار أين يكون الليل؟ وإذا جاء الليل أين يكون النهار؟ يفعل الله ما يشاء{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٢<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالي</span> -من طريق أبي صالح- قال: إنّ السماء خُلقت مثل القُبَّة، وإن الشمس والقمر والنجوم ليس منها شيءٌ لاصِق بالسماء، وإنها تجري في فَلَك دون السماء{31}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٤٠.|2:تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٣٨-٤٣٩، وأخرج شطره الأول من طريق القاسم بن أبي بزة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:علَّقه يحيى بن سلّام ٢/٨٠٩، وعقَّب عليه بقوله: وهو كقوله: <span class="qpc-hafs">﴿والقَمَرِ إذا تَلاها﴾</span> [الشمس:٢] إذا تبعها ليلة الهلال. سعيد عن قتادة قالَ: <span class="qpc-hafs">﴿والقَمَرِ إذا تَلاها﴾</span> يتلوها صبيحة الهلال.|5:عزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:أخرجه ابن جرير ١٩/٤٤٠.|8:عزاه السيوطي إلى عبد بن حميد.|9:أخرجه عبد الرزاق ٢/١٤٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:أخرجه عبد الرزاق ٢/١٤٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|11:أخرجه سفيان الثوري (٢٤٩-٢٥٠).|12:أخرجه ابن جرير ١٩/٤٣٩. وعزاه السيوطي إلى أبي الشيخ في العظمة، وابن أبي حاتم.|13:أخرجه ابن جرير ١٩/٤٤٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|14:علقه يحيى بن سلّام ٢/٨٠٩.|15:تفسير مقاتل بن سليمان ٣/٥٧٩.|16:تفسير يحيى بن سلّام ٢/٨٠٩-٨١٠.|17:فَلْكَة المِغزَل: قطعة مستديرة من الخشب، تُجعل في أعلى المغزل، وتثبَّت الصِّنّارةُ من فوقها، وعودُ المِغْزَل من تحتها. معجم اللغة العربية المعاصرة (فلك).|18:أخرجه ابن جرير ١٩/٤٤٠.|19:أخرجه ابن جرير ١٩/٤٤١.|20:أخرجه ابن جرير ١٩/٤٤١.|21:أخرجه ابن جرير ١٩/٤٤١.|22:علقه يحيى بن سلّام ٢/٨٠٩.|23:أخرجه إسحاق البستي ص١٨٦.|24:علقه يحيى بن سلّام ٢/٨٠٩.|25:أخرجه عبد الرزاق ٢/١٤٤ بنحوه، وابن جرير ١٩/٤٤١.|26:علقه يحيى بن سلّام ٢/٨٠٩.|27:أخرجه عبد الرزاق ٢/١٤٣-١٤٤.|28:تفسير مقاتل بن سليمان ٣/٥٧٩-٥٨٠.|29:أخرجه إسحاق البستي ص١٨٦.|30:أخرجه يحيى بن سلّام ٢/٨١٠.|31:أخرجه يحيى بن سلّام ٢/٨٠-٨١٠.