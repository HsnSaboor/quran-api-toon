tafsir[11]{c,v,t}:
19,1," مقدمة السورة ٤٥٩٩٦- عن عائشة، قالت: نزلت سورة مريم بمكة{1}. (١٠/٥) ٤٥٩٩٧- عن عبد الله بن عباس، قال: أنزل بمكة سورة «كهيعص»{2}. (١٠/٥) ٤٥٩٩٨- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مكية{3}. (١٠/٥) ٤٥٩٩٩- عن عبد الله بن عباس -من طريق عطاء الخراساني-: «كهيعص» مكية، نزلت بعد الملائكة؛ فاطر{4}. (ز) ٤٦٠٠٠- عن عبد الله بن الزبير، قال: نزلت سورة مريم بمكة{1}. (١٠/٥) ٤٦٠٠١- عن قتادة بن دعامة -من طرق-: مكية{6}. (ز) ٤٦٠٠٢- عن محمد ابن شهاب الزهري: مكية، وسماها «كهيعص»، ونزلت بعد فاطر{7}. (ز) ٤٦٠٠٣- عن علي بن أبي طلحة: مكية{8}. (ز) ٤٦٠٠٤- قال مقاتل بن سليمان: مكية كلها، إلا آية سجدتها [٥٨] فإنها مدنية، وهي ثمان وتسعون آية كوفي{9}٤١٢٢. (ز) ٤١٢٢ ذكر ابنُ عطية (٦/٥) أنّ هذه السورة مكية بإجماع، إلا السجدة منها. ٤٦٠٠٥- قال يحيى بن سلّام: وهي مكية كلها، وهي تسعون وثمان آيات{10}. (ز) ٤٦٠٠٦- عن أم سلمة: أنّ النجاشيَّ قال لجعفر بن أبي طالب: هل معك مما جاء به -يعني: رسول الله ﷺ- عن الله شيء؟ قال: نعم. فقرأ عليه صدرًا مِن«كهيعص»، فبكى النجاشيُّ حتى أخْضَل لحيته، وبكت أساقِفَتَهُ حتى أخْضَلوا مصاحفهم حين سمعوا ما تلا عليهم، ثم قال النجاشيُّ: إنّ هذا والذي جاء به موسى لَيخرج مِن مِشْكاة واحدة{11}. (١٠/٥) ٤٦٠٠٧- عن أبي بكر بن عبد الله بن أبي مريم الغساني، عن أبيه، عن جده، قال: أتيتُ رسولَ الله ﷺ، فقلتُ: وُلِدَت لي الليلة جارية. فقال: «والليلةُ أُنزِلَتْ عليَّ سورة مريم، سمِّها: مريم»{12}. (١٠/٥) <q>﴿كۤهیعۤصۤ ۝١﴾</q> - تفسير ٤٦٠٠٨- عن محمد بن السائب الكلبي: أنّه سُئِل عن <q>﴿كهيعص﴾</q>. فحدَّث عن أبي صالح، عن أمِّ هانئ، عن رسول الله ﷺ، قال: «كاف، هاد، عالم، صادق»{13}. (١٠/٨) ٤٦٠٠٩- عن عبد الله بن مسعود وناس من الصحابة: <q>﴿كهيعص﴾</q> هو الهجاء المقطَّع؛ الكاف مِن الملك، والهاء مِن الله، والياء والعين مِن العزيز، والصاد من المُصَوِّر{14}. (١٠/٧) ٤٦٠١٠- عن فاطمة ابنة عَلِيٍّ، قالت: كان عَلِيُّ [بن أبي طالب] يقول: يا كهيعص، اغفِر لي{15}٤١٢٣. (١٠/٨) ٤١٢٣ ذكر ابنُ عطية (٦/٦) قول علي بن أبي طالب، ووجَّهه بقوله: «فهذا يحتمل أن تكون الجملة من أسماء الله تعالى، ويحتمل أن يريد علي بن أبي طالب ﵁ أن ينادي الله تعالى بجميع الأسماء التي تضمنها <q>﴿كهيعص﴾</q>، كأنه أراد أن يقول: يا كريم، يا هادي، يا عليّ، يا عزيز، يا صادق، اغفر. فجَمَع هذا كلَّه باختصار في قوله: يا كهيعص». ونقل أنّ ابن المستنير وغيره قالوا بأن <q>﴿كهيعص﴾</q> عبارة عن حروف المعجم، ونَسَبَه الزجّاج إلى أكثر أهل اللغة، أي: هذه الحروف منها ذكر رحمت ربك عبده زكريا، ثم علَّق بقوله: «وعلى هذا يتركب قول من يقول: ارتفع <q>﴿ذكر﴾</q> بأنه خبر عن <q>﴿كهيعص﴾</q>». ثم قال: «وهي حروف تَهَجٍّ يُوقَف عليها بالسكون». ٤٦٠١١- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿كهيعص﴾</q>، قال: كبير، هاد، أمين، عزيز، صادق. وفي لفظ: كاف. بدل: كبير{16}. (١٠/٧) ٤٦٠١٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿كهيعص﴾</q>، قال: كاف من كريم، وهاء من هادٍ، وياء من حكيم، وعين من عليم، وصاد من صادق{17}. (١٠/٧) ٤٦٠١٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كهيعص﴾</q>: قَسَم أقسم الله به، وهو مِن أسماء الله{18}. (١٠/٨) ٤٦٠١٤- عن عبد الله بن عباس -من طريق السدي- أنه كان يقول في <q>﴿كهيعص﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿يس﴾</q>، وأشباه هذا: هو اسم الله الأعظم{19}. (١٠/٨) ٤٦٠١٥- قال يحيى بن سلّام: كان الحسن يقول: لا أدري ما تفسيره، غير أنّ قومًا من أصحاب النبي ﵇ كانوا يقولون: أسماء السور ومفاتيحها{20}. (ز) ٤٦٠١٦- عن أبي العالية الرياحي -من طريق الربيع بن أنس- قال: <q>﴿كهيعص﴾</q> ليس منها حرفٌ إلا وهو اسم{21}. (ز) ٤٦٠١٧- عن سعيد بن جبير -من طريق إسماعيل بن راشد- في <q>﴿كهيعص﴾</q>، قال: كاف: كبير، ها: هاد، ياء: يمين، عين: عالم، صاد: صادق{22}. (ز) ٤٦٠١٨- عن سعيد بن جبير -من طريق سالم- في قوله <q>﴿كهيعص﴾</q>، قال: كاف: كاف، ها: هاد، عين: عزيز، صاد: صادق{23}. (ز) ٤٦٠١٩- عن سعيد بن جبير -من طريق عطاء- <q>﴿كهيعص﴾</q>، قال: كاف من كريم، يا من حكيم، عين من عالم، صاد: صادق{24}٤١٢٤. (ز) ٤١٢٤ علَّق ابنُ عطية (٦/٥) على أقوال سعيد بن جبير بقوله: «مقتضى أقواله أنّها دالَّة على كلِّ اسم فيه كاف من أسمائه تعالى». ٤٦٠٢٠- عن الضحاك بن مزاحم، في قوله: <q>﴿كهيعص﴾</q>، قال: كاف: كاف، ها: هاد، عين: عدل، صاد: صادق{25}. (ز) ٤٦٠٢١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿كهيعص﴾</q>، قال: يقول: أنا الكبير، الهادي، عَلِيٌّ، أمين، صادق{14}. (١٠/٩) ٤٦٠٢٢- عن المسيب بن رافع -من طريق ابنه العلاء- في قوله: <q>﴿كهيعص﴾</q>، قال: اسم مِن أسماء الله، كاف: كبير، ها: هاد، ياء: يمين، عين: من عالم، صادق{27}. (ز) ٤٦٠٢٣- عن الحسن البصري -من طريق أبي بكر الهذلي- قال: فواتح يفتح الله بهذا{28} الكتاب{29}. (ز) ٤٦٠٢٤- عن أبي صالح باذام -من طريق الكلبي- في قوله: <q>﴿كهيعص﴾</q>، قال: الكاف: الكافي، والهاء: الهادي، والعين: العالم، والصاد: الصادق. قال: كافٍ لهم، هادٍ لهم، عالِمٌ بهم، صادق في قوله. وفي لفظ: في وعده{30}. (١٠/٨) ٤٦٠٢٥- عن محمد بن كعب القرظي، في قوله: <q>﴿كهيعص﴾</q>، قال: الكاف من الملك، والهاء من الله، والعين من العزيز، والصاد من الصمد{14}. (١٠/٩) ٤٦٠٢٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿كهيعص﴾</q>، قال: اسم مِن أسماء القرآن{32}. (١٠/٩) ٤٦٠٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿كهيعص﴾</q>، قال: مِن الهِجاء المُتَقَطِّع{33}. (ز) ٤٦٠٢٨- عن الربيع بن أنس، في قوله: <q>﴿كهيعص﴾</q>، قال: الكاف مفتاح اسمه كافي، والهاء مفتاح اسمه هادي، والعين مفتاح اسمه عالم، والصاد مفتاح اسمه صادق{34}. (١٠/٩) ٤٦٠٢٩- عن الربيع بن أنس -من طريق إبراهيم بن أبي الضُّرَيس- في قوله: <q>﴿كهيعص﴾</q>، قال: يا مَن يُجِير ولا يُجار عليه{35}. (١٠/٩) ٤٦٠٣٠- عن محمد بن السائب الكلبي -من طريق عَنبَسَةَ- أنّه كان يقول: كاف، هاد، عالم، صادق. ويقول: كاف لخلقه، هادٍ لعباده، عالم بأمره، صادق في قوله{36}. (ز) ٤٦٠٣١- قال محمد بن السائب الكلبي: هو ثناء أثنى الله ﷿ به على نفسه{37}. (ز) ٤٦٠٣٢- قال مقاتل بن سليمان: <q>﴿كهيعص﴾</q>: كافٍ، هادٍ، عالم، صادق، هذا ثناءُ الرَّبِّ -تبارك وتعالى- على نفسه، يقول: كافيًا لخلقه، هادِيًا لعباده، الياء مِن الهادي، عالم ببريته، صادق في قوله ﷿{38}٤١٢٥. (ز) ٤١٢٥ علّق ابنُ جرير (١٥/٤٥٢) على ما أوْرَد من أقوال في معنى <q>﴿كهيعص﴾</q> بقوله: «والقول في ذلك عندنا نظيرُ القول في <q>﴿الم﴾</q>، وسائر فواتح سور القرآن التي افتتحت أوائلها بحروف المعجم، وقد ذكرنا ذلك فيما مضى قبل، فأغنى عن إعادته في هذا الموضع». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه النحاس ص٥٥٥. وعزاه السيوطي إلى ابن مردويه.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٥٠١، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خصيف عن مجاهد. قال السيوطي في الإتقان ١/٥٠: «إسناده جيد، رجاله كلهم ثقات مِن علماء العربية المشهورين».أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٢/٦١٩.تفسير يحيى بن سلام ١/٢١٣.أخرجه أحمد ٣/٢٦٣، ٣٧/١٧٠ (١٧٤٠، ٢٢٤٩٨)، والبيهقي في الدلائل ٢/٣٠١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الطبراني في الكبير ٢٢/٣٣٢ (٨٣٤)، وأبو نعيم في معرفة الصحابة ٦/٣٠١١ (٦٩٨٨). قال ابن القيسراني في ذخيرة الحفاظ ٥/٢٥٦٣ (٥٩٥٨): «رواه أبو بكر بن أبي مريم، عن أبيه، عن جده. وأبو بكر هذا اسمه: بكير، وثَّقه قومٌ، وضعَّفه آخرون». وقال الهيثمي في المجمع ٨/٥٥ (١٢٨٨٩): «رواه الطبراني، وفيه سليمان بن سلمة الخبائري، وهو متروك».عزاه السيوطي إلى ابن مردويه. إسناده ضعيف جدًّا؛ لضعف محمد بن السائب الكلبي وأبي صالح، كما تقدم مرارًا.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عثمان بن سعيد الدارمي في الرد على بشر المريسي ص١١، وابن ماجه -كما في تهذيب الكمال ٢٩/٢٨٤-، وابن جرير ١٥/٤٥١.أخرجه ابن جرير ١٥/٤٤٣-٤٤٧، ٤٤٩، ٤٥٠ مفرقًا، وإسحاق البستي في تفسيره ص١٧١، والحاكم ٢/٣٧٢، والبيهقي في الأسماء والصفات (١٦٥، ١٦٦)، والضياء في المختارة ١٠/٥٦ (٤٨). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه عبد الرزاق ٢/٣، وآدم بن أبي إياس -كما في تفسير مجاهد ص٤٥٣-، وعثمان بن سعيد الدارمي في الرد على المريسي ص١١، وابن جرير ١٥/٤٤٤-٤٥٠ مفرقًا، وإسحاق البستي في تفسيره ص١٧٠، بلفظ: كاف من كافي...، والحاكم ٢/٣٧١-٣٧٢، والبيهقي في الأسماء والصفات (١٦٤). وعزاه السيوطي إلى عثمان بن سعيد الدارمي في التوحيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٥/٤٥١. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى أبي عبيد، وابن المنذر.علقه يحيى بن سلام ٢/٢١٣.أخرجه ابن جرير ١٥/٤٥٢.أخرجه ابن جرير مفرقًا ١٥/٤٤٣، ٤٤٥، ٤٤٦، ٤٤٨، ٤٥٠.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٩، ٤٥١.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٧، ٤٤٨، ٤٥١.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٧، ٤٤٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٧، ٤٤٨، ٤٥١.ذكر محقق المصدر أنه كذا في الأصل، وجاء في أول سورة الشورى: بهن.أخرجه إسحاق البستي في تفسيره ص١٧١.أخرجه أبو الشيخ في العظمة (١٨٨). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣، وابن جرير ١٥/٤٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه الحربي في غريب الحديث ٣/١٠٩٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٤٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرج أوَّله ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٨، ٤٥١. وعلَّقه يحيى بن سلام ١/٢١٣. وفي تفسير الثعلبي ٦/٢٠٦، وتفسير البغوي ٥/٢١٨ بلفظ: كافٍ لخلقه، هادٍ لعباده، يده فوق أيديهم، عالم ببريته، صادق في وعده.تفسير الثعلبي ٦/٢٠٥.تفسير مقاتل بن سليمان ٢/٦٢٠.
19,2," <q>﴿ذِكۡرُ رَحۡمَتِ رَبِّكَ عَبۡدَهُۥ زَكَرِیَّاۤ ۝٢﴾</q> - قراءات ٤٦٠٣٣- عن يحيى بن يَعْمَر أنه كان يقرأ: (ذَكَّرَ رَحْمَةَ رَبِّكَ عَبْدُهُ زَكَرِيّا) يُثَقِّلُ{1}، يقول: لما دخل عليها زكريا المحراب وجد عندها فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، فقال: (ذَكَّرَ رَحْمَةَ رَبِّكَ){2}٤١٢٦. (١٠/٩) ٤١٢٦ ذكر ابنُ عطية (٦/٧) أنّ هذه القراءة على معنى: هذا المتلوّ ذكَّر رحمة ربك عبده. <q>﴿ذِكۡرُ رَحۡمَتِ رَبِّكَ عَبۡدَهُۥ زَكَرِیَّاۤ ۝٢﴾</q> - تفسير الآية ٤٦٠٣٤- عن عبد الله بن عباس -من طريق مقاتل، وجويبر عن الضَّحّاك- في قوله: <q>﴿ذكر رحمت ربك عبده زكريا﴾</q>، قال: ذكره اللهُ برحمةٍ منه حيث دعاه{3}. (١٠/٢٥) ٤٦٠٣٥- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿ذكر رحمت ربك﴾</q> يعني: نعمة ربك، يا محمد، <q>﴿عبده زكريا﴾</q> ابن بَرْخِيا، وذلك أنّ الله تعالى ذكر عبده زكريا بالرحمة{4}. (ز) ٤٦٠٣٦- قال: يحيى بن سلّام، في قوله: <q>﴿ذِكْرُ رَحْمَتِ رَبِّكَ عَبْدَهُ زَكَرِيّا﴾</q>، يقول: ذِكْرُه لزكريا رحمة من الله له{5}. (ز) <q>﴿ذِكۡرُ رَحۡمَتِ رَبِّكَ عَبۡدَهُۥ زَكَرِیَّاۤ ۝٢﴾</q> - آثار متعلقة بالآية ٤٦٠٣٧- عن أبي هريرة، عن النبي ﷺ، قال: «كان زكريّا نجّارًا»{6}. (١٠/١٠) ٤٦٠٣٨- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- قال: إنّ زكريا بن دان أبا يحيى كان مِن أبناء الأنبياء الذين كانوا يكتبون الوحي ببيت المقدس{7}. (١٠/١٠) ",footnotes:1:يعني: يشدّد الكاف من (ذَكَّرَ). ينظر: مختصر ابن خالويه ص٨٦.عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة شاذة، تُروى عن الحسن أيضًا. ينظر: مختصر ابن خالويه ص٨٦، والمحتسب ٢/٣٧.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٣.أخرجه مسلم ٤/١٨٤٧ (٢٣٧٩).أخرجه ابن عساكر ١٩/٤٨-٤٩. وعزاه السيوطي إلى إسحاق بن بشر.
19,3," <q>﴿إِذۡ نَادَىٰ رَبَّهُۥ نِدَاۤءً خَفِیࣰّا ۝٣﴾</q> - تفسير ٤٦٠٣٩- عن عبد الله بن مسعود -من طريق السدي، عن مرة الهمداني-= (ز) ٤٦٠٤٠- وعن عبد الله بن عباس -من طريق السدي، عن أبي مالك وأبي صالح- قال: كان آخر أنبياء بني إسرائيل زكريا بن أدن بن مسلم، مِن ذُرِّيَّة يعقوب، دعا ربَّه سِرًّا؛ <q>﴿قال رب إني وهن العظم مني﴾</q> إلى قوله: <q>﴿خفت الموالي﴾</q> هم العصبة، <q>﴿يرثني﴾</q> ويَرِثُ نُبُوَّتي؛ نُبُوَّة آل يعقوب، <q>﴿فنادته الملائكة﴾</q> [آل عمران:٣٩] وهو جبريل: إنّ الله يبشرك بغلام اسمه يحيى. فلما سمع النداء جاءه الشيطان، فقال: يا زكريا، إنّ الصوت الذي سمعت ليس مِن الله، إنما هو مِن الشيطان يَسْخَرُ بك. فشكَّ، وقال: <q>﴿أنى يكون لي غلام﴾</q> يقول: مِن أين يكون <q>﴿وقد بلغني الكبر وامرأتي عاقر﴾</q>؟! [آل عمران:٤٠]. قال الله: <q>﴿قد خلقتك من قبل ولم تك شيئا﴾</q>{1}. (١٠/١١) ٤٦٠٤١- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿إذ نادى ربه نداء خفيا﴾</q>، يعني: دعا ربَّه دُعاءً خَفِيًّا في الليل، لا يُسْمِعُ أحدًا، أو يُسْمِع أذنيه{2}. (١٠/٢٥) ٤٦٠٤٢- عن الحسن البصري، في قوله: <q>﴿إذ نادى ربه نداء خفيا﴾</q>، قال: دعاء لا رياء فيه{3}. (ز) ٤٦٠٤٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إذ نادى ربه نداء خفيا﴾</q>، أي: بقلبه سِرًّا، وإنّ الله يُحِبُّ الصوت الخَفِيّ، والقلب النَّقِيَّ{4}. (١٠/١٠) ٤٦٠٤٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: رغِب زكريا في الولد، فقام فصلّى، ثم دعا ربَّه سِرًّا، فقال: <q>﴿رب إني وهن العظم مني﴾</q> إلى <q>﴿واجعله رب رضيا﴾</q>{5}. (ز) ٤٦٠٤٥- قال مقاتل بن سليمان: <q>﴿إذ نادى ربه نداء خفيا﴾</q>، يقول: إذ دعا ربَّه دعاء سِرًّا، وإنّما دعا ربَّه ﷿ سِرًّا لِئَلّا يقول الناس: انظروا إلى هذا الشيخ الكبير، يسأل الولد على كِبَرِه!{6}. (ز) ٤٦٠٤٦- عن عبد الملك ابن جُرَيج -من طريق حجاج- في قوله: <q>﴿إذ نادى ربه نداء خفيا﴾</q>، قال: لا يريد رياء{7}٤١٢٧. (١٠/١٠) ٤١٢٧ علَّق ابنُ عطية (٦/٧) على قول ابن جريج بقوله: «ومنه قول النبي ﵇: «خير الذِّكْرِ الخَفِيُّ»». <q>﴿إِذۡ نَادَىٰ رَبَّهُۥ نِدَاۤءً خَفِیࣰّا ۝٣﴾</q> - آثار متعلقة بالآية ٤٦٠٤٧- عن عقبة بن عبد الغافر -من طريق ثابت البُنانِيِّ- قال: دعوة السِّرِّ أفضلُ مِن سبعين في العلانية{8}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٥٩٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٣.أخرجه يحيى بن سلام ١/٢١٣ مختصرًا، وابن جرير ١٥/٤٥٣ بلفظ: أي: سِرًّا، وإن الله يعلم القلب النقي، ويسمع الصوت الخفي. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٥٤.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه ابن جرير ١٥/٤٥٣. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ٢/٢١٣.
19,4," <q>﴿قَالَ رَبِّ إِنِّی وَهَنَ ٱلۡعَظۡمُ مِنِّی﴾</q> - تفسير ٤٦٠٤٨- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: فقال: <q>﴿رب إني وهن﴾</q>، يعني: ضَعُفَ العظم مِنِّي{1}. (١٠/٢٥) ٤٦٠٤٩- عن سعيد بن جبير، في قوله: <q>﴿وهن العظم مني﴾</q>، يقول: ضَعُف{2}. (١٠/١١) ٤٦٠٥٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿وهن العظم مني﴾</q>، قال: نُحُولُ العظم{3}. (١٠/١١) ٤٦٠٥١- عن مجاهد بن جبر -من طريق منصور- في قوله تعالى: <q>﴿وهن العظم مني﴾</q>، قال: شَكا ذهابَ أضراسِه{4}. (ز) ٤٦٠٥٢- قال الحسن البصري: ضَعُفَ{5}. (ز) ٤٦٠٥٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قال رب إني وهن العظم مني﴾</q>، أي: ضَعُفَ العظم مِنِّي{6}. (ز) ٤٦٠٥٤- قال قتادة بن دعامة: اشتكى سقوطَ الأضراس{7}. (ز) ٤٦٠٥٥- قال مقاتل بن سليمان: <q>﴿قال رب إني وهن العظم مني﴾</q>، يعني: ضَعُف العظم مِنِّي{8}. (ز) ٤٦٠٥٦- قال يحيى بن سلّام: <q>﴿وهن العظم مني﴾</q>: رَقَّ{9}. (ز) <q>﴿وَٱشۡتَعَلَ ٱلرَّأۡسُ شَیۡبࣰا﴾</q> - تفسير ٤٦٠٥٧- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿واشتعل الرأس شيبا﴾</q>، يعني: غَلَبَ البياضُ السوادَ{1}. (١٠/٢٥) ٤٦٠٥٨- قال مقاتل بن سليمان: <q>﴿واشتعل الرأس شيبا﴾</q>، يعني: بياضًا{8}. (ز) <q>﴿وَلَمۡ أَكُنۢ بِدُعَاۤىِٕكَ رَبِّ شَقِیࣰّا ۝٤﴾</q> - تفسير ٤٦٠٥٩- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿ولم أكن بدعائك رب شقيا﴾</q>، أي: لم أدْعُك قطُّ فخيَّبتني فيما مضى، فتخيِّبَني فيما بقي، فكما لم أشْقَ بدعائي فيما مضى؛ فكذلك لا أشقى فيما بقي، عوَّدتني الإجابة من نفسك{1}. (١٠/٢٥) ٤٦٠٦٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولم أكن بدعائك رب شقيا﴾</q>، قال: قد كنت تُعَوِّدُني الإجابة فيما مضى{13}. (١٠/١٠) ٤٦٠٦١- قال محمد بن السائب الكلبي: لم يكن دعائي مِمّا يَخِيب عندك{14}. (ز) ٤٦٠٦٢- قال مقاتل بن سليمان: <q>﴿ولم أكن بدعائك رب شقيا﴾</q>، يعني: خائِبًا فيما خلا، كُنتَ تستجيب لي، فلا تُخَيِّبْنِي في دعائي إيّاك بالولد{8}. (ز) ٤٦٠٦٣- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿ولم أكن بدعائك رب شقيا﴾</q>، يقول: قد كنت تُعَرِّفني الإجابة فيما مضى{16}. (ز) ٤٦٠٦٤- عن سفيان بن عيينة، في قوله: <q>﴿ولم أكن بدعائك رب شقيا﴾</q>، يقول: بل سَعِدت بدعائك، وإن لم تُعْطني{2}. (١٠/١١) ٤٦٠٦٥- قال يحيى بن سلّام: <q>﴿ولم أكن بدعائك﴾</q> أي: بدعائي إيّاك <q>﴿رب شقيا﴾</q> يقول: لم أزل بدعائك سعيدًا، لم تَرْدُدْهُ عَلَيَّ{9}٤١٢٨. (ز) ٤١٢٨ ذكر ابنُ القيم (٢/١٦٩) أن هذا القول ظاهر، وأنّه يدل عليه أنه قدم ذلك أمام طلبه الولد، وجعله وسيلة إلى ربه، فطلب منه أن يجاريه على عادته التي عوّده من قضاء حوائجه وإجابته إلى ما سأله. وبنحوه ابنُ تيمية (٤/٢٧٢). ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٥٤. وعزاه السيوطي إلى عبد الرزاق، وابن أبي حاتم.أخرجه أبو نعيم في حلية الأولياء ٣/٢٩١.علَّقه يحيى بن سلام ١/٢١٤.أخرجه ابن جرير ١٥/٤٥٤. وعلقه يحيى بن سلام ٢/٢١٤.تفسير البغوي ٥/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٤.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه عبد الرزاق ٢/٤، وابن عساكر في تاريخ دمشق ١٩/٥٢ من طريق معمر بلفظ: كنت تعرِّفني الإجابة. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علَّقه يحيى بن سلام ٢/٢١٤.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه ابن جرير ١٥/٤٥٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٢١٤.
19,5," <q>﴿وَإِنِّی خِفۡتُ ٱلۡمَوَ ٰ⁠لِیَ مِن وَرَاۤءِی وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا فَهَبۡ لِی مِن لَّدُنكَ وَلِیࣰّا ۝٥ یَرِثُنِی وَیَرِثُ مِنۡ ءَالِ یَعۡقُوبَۖ وَٱجۡعَلۡهُ رَبِّ رَضِیࣰّا ۝٦﴾</q> - قراءات ٤٦٠٦٦- عن سعيد بن العاص، قال: أملى عَلَيَّ عثمان بن عفان مِن فِيهِ: (وإنِّي خَفَّتِ المَوالِي) يُثَقِّلها، يعني: بنصب الخاء والفاء وكسر التاء. يقول: قَلَّتِ الموالي{1}٤١٢٩. (١٠/١٢) ٤١٢٩ وجَّهَ ابنُ جرير (١٥/٤٥٧) قراءة عثمان بقوله: «كأنّه وجه تأويل الكلام: وإني ذَهَبَتْ عَصَبَتي ومَن يرثني مِن بني أعمامي». وبنحوه ابنُ عطية (٦/٨)، وكذا ابن كثير (٩/٢١٥). ثم قال ابنُ جرير: «وإذا قرئ ذلك كذلك كانت الياء من <q>﴿الموالي﴾</q> مسكّنة غير متحركة؛ لأنها تكون في موضع رفع بـ(خَفَّتِ)». وذكر ابنُ عطية (٦/٨) أنه على هذه القراءة يكون زكريا طلب وليًّا يقوم بالدِّين. ٤٦٠٦٧- عن يحيى بن يَعْمَر أنه قرأها: (وإنِّي خَفَّتِ المَوالِي مِن ورَآئِي) مشددة؛ بنصب الخاء وكسر التاء{2}. (١٠/١٤) <q>﴿وَإِنِّی خِفۡتُ ٱلۡمَوَ ٰ⁠لِیَ مِن وَرَاۤءِی﴾</q> - تفسير ٤٦٠٦٨- عن عبد الله بن مسعود -من طريق السدي، عن مرة الهمداني-= (ز) ٤٦٠٦٩- وعن عبد الله بن عباس -من طريق السدي، عن أبي مالك وأبي صالح- <q>﴿خفت الموالي﴾</q>: هم العَصَبَة{3}. (١٠/١١) ٤٦٠٧٠- عن عبد الله بن عباس، في قوله: <q>﴿وإني خفت الموالي﴾</q>، يعني: الكلالَة{4}. (١٠/١٢) ٤٦٠٧١- عن عبد الله بن عباس، في قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، قال: الوَرَثة، وهم عَصَبَة الرجل{5}. (١٠/١٢) ٤٦٠٧٢- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، يعني بالموالي: الكلالة الأولياء أن يرثوه، فوهب الله له يحيى{6}. (ز) ٤٦٠٧٣- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>: فلم يبق لي وارِث، وخِفْتُ العَصَبَة أن تَرِثَني{7}. (١٠/٢٥) ٤٦٠٧٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، قال: العَصَبَة مِن آل يعقوب، وكان مِن ورائه غلام، وكان زكريا مِن ذُرِّيَّة يعقوب. وفي لفظ: أيوب{8}. (١٠/١٢) ٤٦٠٧٥- عن أبي صالح باذام -من طريق جابر بن نوح، عن إسماعيل- في قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، قال: خاف موالي الكلالة{9}. (١٠/١٣) ٤٦٠٧٦- عن أبي صالح باذام -من طريق أبي أسامة، عن إسماعيل- في قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، قال: العَصَبَة{10}. (ز) ٤٦٠٧٧- عن قتادة بن دعامة -من طريق معمر- قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، قال: العَصَبَة{11}. (ز) ٤٦٠٧٨- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿وإني خفت الموالي من ورائي﴾</q>: والموالي: هُنَّ العَصَبَة{12}. (ز) ٤٦٠٧٩- قال محمد بن السائب الكلبي: الورثة{13}. (ز) ٤٦٠٨٠- قال مقاتل بن سليمان: <q>﴿وإني خفت الموالي من ورآئي وكانت امرأتي عاقرا﴾</q>، يقول: خِفْتُ الكلالة، وهم العَصَبَة مِن بعد موتي أن يرثوا مالي{14}. (ز) ٤٦٠٨١- عن يحيى بن سلّام، في قوله: <q>﴿وإني خفت الموالي من ورائي﴾</q>، أي: الوَرَثة مِن بعدي، يعني: العَصَبَة الذين يرِثون ماله، فأراد أن يكون مِن صُلْبِه مَن يرِث ماله{15}٤١٣٠. (ز) ٤١٣٠ ذكر ابنُ عطية (٦/٨-٩) أن قوله: <q>﴿من ورائي﴾</q> أي: من بعدي في الزمن، وبيَّن أنّ أبا عبيدة قال في هذه الآية: أي: مِن بين يدي ومن أمامي، وانتقده بقوله: «وهذا قِلَّة تحرير». <q>﴿وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا فَهَبۡ لِی مِن لَّدُنكَ وَلِیࣰّا ۝٥﴾</q> - تفسير ٤٦٠٨٢- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك - في قوله: <q>﴿فهب لي من لدنك وليا﴾</q>، يعني: مِن عندك ولدًا{7}. (١٠/٢٥) ٤٦٠٨٣- عن إسماعيل السُّدِّيّ: <q>﴿وليا﴾</q>، يعني: الولد{17}. (ز) ٤٦٠٨٤- قال مقاتل بن سليمان: <q>﴿فهب لي من لدنك وليا﴾</q>، يعني: من عِندِك ولدًا{14}. (ز) ٤٦٠٨٥- عن يحيى بن سلّام، في قوله: <q>﴿وكانت امرأتي عاقرا﴾</q> أي: لا تلد، <q>﴿فهب لي من لدنك﴾</q> من عندك <q>﴿وليا﴾</q> يعني: الولد{15}. (ز) <q>﴿یَرِثُنِی وَیَرِثُ مِنۡ ءَالِ یَعۡقُوبَۖ﴾</q> - قراءات ٤٦٠٨٦- عن عبد الله بن عباس أنّه كان يقرأ: <q>﴿يَرِثُنِي ويَرِثُ مِن آلِ يَعْقُوبَ﴾</q>{20}. (١٠/١٤) ٤٦٠٨٧- عن يحيى بن يَعْمَر أنّه قرأها: (يَرِثُنِي وارِثٌ مِّنْ آلِ يَعْقُوبَ){21}. (١٠/١٤) ٤٦٠٨٨- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿يَرِثُنِي﴾</q> مثقل مرفوع{22}٤١٣١. (١٠/١٤) ٤١٣١ اختُلِف في قراءة قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>؛ فقرأ قوم: <q>﴿يرثُني ويرثُ﴾</q> برفع الحرفين كليهما، وقرأ آخرون: ‹يَرِثْنِي ويَرِثْ› بجزم الحرفين على الجزاء والشرط. وذكر ابنُ جرير (١٥/٤٦٠) أن قراءة الضم بمعنى: فهب الذي يرثني ويرث من آل يعقوب، وعلى أنّ <q>﴿يرثني ويرث من آل يعقوب﴾</q> من صلة الولي. وذكر أن قراءة الجزم بمعنى: فهب لي من لدنك وليًا فإنه يرثني إذا وهبْته لي. وبنحوه ابنُ عطية (٦/٩). ونقل ابنُ جرير عمَّن قرءوا بالجزم أنهم قالوا: إنما حسُن ذلك في هذا الموضع؛ لأن <q>﴿يرثني﴾</q> من آية غير التي قبلها. وإنما يحسُن أن يكون مثل هذا صلة، إذا كان غير منقطع عما هو له صلة، كقوله: <q>﴿ردءا يصدقني﴾</q> [القصص:٣٤]. ورجَّح قراءةَ الرفع، وانتقد الأخرى مستندًا إلى اللغة، ودلالة العقل، فقال: «لأنّ الولي نكرة، وأنّ زكريا إنما سأل ربه أن يهب له وليًّا يكون بهذه الصفة، كما روي عن رسول الله ﷺ، لا أنّه سأله ولِيًّا، ثم أخبر أنّه إذا وهب له ذلك كانت هذه صفته؛ لأن ذلك لو كان كذلك كان ذلك من زكريا دخولًا في علْم الغيب الذي قد حجبه الله عن خلقه». وبنحوه ابنُ عطية (٦/٩). <q>﴿یَرِثُنِی وَیَرِثُ مِنۡ ءَالِ یَعۡقُوبَۖ﴾</q> - تفسير الآية ٤٦٠٨٩- عن عبد الله بن مسعود -من طريق السدي، عن مرة الهمداني-= (ز) ٤٦٠٩٠- وعن عبد الله بن عباس -من طريق السدي، عن أبي مالك وأبي صالح- قالوا: كان آخر أنبياء بني إسرائيل زكريا بن أدن بن مسلم، وكان من ذُرِّيَّة يعقوب، قال: يرثني مُلْكِي، ويرث مِن آل يعقوب النبوة{23}. (ز) ٤٦٠٩١- عن عبد الله بن عباس، قال: كان زكريا لا يُولَد له، فسأل ربَّه، فقال: ربِّ، <q>﴿هب لي من لدنك وليا يرثني ويرث من آل يعقوب﴾</q>. قال: يرث مالي، ويرث مِن آل يعقوب النبوة{24}. (١٠/١٢) ٤٦٠٩٢- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿يرثني﴾</q> يعني: يرث محرابي، وعصاي، وبُرْنُس{25} القربان، وقلمي الذي أكتب به الوحي، <q>﴿ويرث من آل يعقوب﴾</q> النبوة{7}. (١٠/٢٥) ٤٦٠٩٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿يرثني ويرث من آل يعقوب﴾</q>، قال: وكان وِراثته عِلْمًا، وكان زكريا مِن ذُرِّيَّة يعقوب{27}. (ز) ٤٦٠٩٤- عن مجاهد بن جبر= (ز) ٤٦٠٩٥- وعكرمة مولى ابن عباس، في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>، قال: يرثني مالي، ويرث من آل يعقوب النبوة{28}. (١٠/١٣) ٤٦٠٩٦- عن الضحاك بن مزاحم، في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>، قال: السُّنَّة، والعِلْم{4}. (١٠/١٤) ٤٦٠٩٧- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>، قال: يرث مِن مالي، ويرث مِن آل يعقوب السُّنَّة والعِلم{30}. (ز) (١٠/١٤) ٤٦٠٩٨- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>، قال: نبوته، وعلمه{31}. (١٠/١٣) ٤٦٠٩٩- قال الحسن البصري: معناه: يرثني مالي، ويرث مِن آل يعقوب النبوة والحبورة{32}. (ز) ٤٦١٠٠- عن أبي صالح باذام -من طريق إسماعيل- في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>، قال: يرثني مالي، ويرث من آل يعقوب النبوة{33}. (١٠/١٣) ٤٦١٠١- عن أبي صالح باذام -من طريق إسماعيل- في قوله: <q>﴿ويرث من آل يعقوب﴾</q>، قال: النبوة؛ يكون نبيًّا كما كان أبوه{34}. (١٠/١٣) ٤٦١٠٢- في تفسير قتادة: يرث مالَه{35}. (ز) ٤٦١٠٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>: فيقول: يرث نبوتي، ونبوة آل يعقوب{4}. (١٠/١٣) ٤٦١٠٤- قال محمد بن السائب الكلبي، في قوله: <q>﴿آل يعقوب﴾</q>: هو يعقوب بن ماتان، أخو زكريا، وليس يعقوب أبا يوسف{37}. (ز) ٤٦١٠٥- قال مقاتل بن سليمان: <q>﴿يرثني﴾</q> يرِث مالي، <q>﴿ويرث من آل يعقوب﴾</q> ابن ماثان عِلْمَهم، ورياستَهم في الأحبار، وكان يعقوب وعمران أبو مريم أخوين ابنا ماثان، ومريم ابنة عمران بن ماثان{14}. (ز) ٤٦١٠٦- عن سفيان الثوري، في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>: يرثني المالَ، ويرث من آل يعقوب النبوةَ{39}. (ز) ٤٦١٠٧- عن يحيى بن سلّام، في قوله: <q>﴿يرثني ويرث من آل يعقوب﴾</q>: ملكَهم، وسلطانَهم، كانت امرأة زكرياء مِن ولد يعقوب، ليس يعني يعقوب الأكبر، يعقوب دونه{15}٤١٣٢. (ز) ٤١٣٢ أفادت الآثارُ الاختلاف في المراد بهذا الميراث. ورجَّح ابنُ كثير (٩/٢١٥-٢١٧) أنها وراثة النبوة مستندًا إلى السنة، والدلالات العقلية بما مفاده الآتي: ١- أنّ النبي أعظم منزلة مِن أن يشفق على ماله بأن يأنف مِن وراثة عصباته له، ويسأل أن يكون له ولد، فيحوز ميراثه دونه. ٢- أنه لم يُذكر أنه كان ذا مال، بل كان نجّارًا يأكل مِن كسب يديه، ومثل هذا لا يجمع مالًا، ولا سيما الأنبياء ﵈، فإنهم كانوا أزهد شيء في الدنيا. ٣- قول النبي ﷺ: «نحن معشر الأنبياء لا نورث». وهذا يوجب حمل قوله: <q>﴿فهب لي من لدنك وليا * يرثني﴾</q> على ميراث النبوة؛ ولهذا قال: <q>﴿ويرث من آل يعقوب﴾</q>، كما قال تعالى: <q>﴿وورث سليمان داود﴾</q> [النمل:١٦] أي: في النبوة؛ إذ لو كان في المال لما خصَّه مِن بين إخوته بذلك، ولما كان في الإخبار بذلك كبير فائدة، إذ مِن المعلوم المستقر في جميع الشرائع والملل أنّ الولد يرِث أباه، فلولا أنها وراثة خاصة لما أخبر بها. وذكر ابنُ كثير أنّ ما رُوِي عن النبي ﷺ أنه قال: «رحم الله أخي زكريا، ما كان عليه من ورثة ماله ...». بأن هذه مرسلات، لا تُعارِض الصحاح. وذكر ابنُ عطية (٦/٨) أنّ أكثر المفسرين على القول بأن زكريا أراد وراثة المال، وبيَّن أن قول النبي ﷺ: «إنا معشر الأنبياء لا نورث» يحتمل أن لا يريد به العموم، ثم رجَّح القول بأنها وراثة النبوة مستندًا إلى دلالة العقل، والنظائر، فقال: «والأظهر الأليق بزكريا ﵇ أن يريد: وراثة العلم والدين؛ فتكون الوراثة مستعارة، ألا ترى أنه إنما طلب ولِيًّا، ولم يخصص ولدًا، فبلّغه الله أمله على أكمل الوجوه». ونقل حكاية عن الزجاج أنّ فرقة قالت: إنما كان مواليه مهملين للدّين، فخاف بموته أن يضيع الدين، فطلب وليًّا يقوم بالدين بعده. وعلَّق عليه بقوله: «وفيه أنه لا يجوز أن يسأل زكريا مَن يرث ماله؛ إذ الأنبياء لا تورث، وهذا يؤيده قول النبي ﷺ: «إنا معشر الأنبياء لا نورث، ما تركنا فهو صدقة». ويوهنه ذكر العاقر». أي: في الآية. ونقل (٦/٩) عن فرقة أنها قالت: بل طلب الولد ثم شرط أن تكون الإجابة في أن يعيش حتى يرثه، تحفظًا مِن أن تقع الإجابة في الولد ثم يخترم فلا يتحصل منه الغرض المقصود. <q>﴿وَٱجۡعَلۡهُ رَبِّ رَضِیࣰّا ۝٦﴾</q> - تفسير ٤٦١٠٨- عن عبد الله بن عباس، في قوله: <q>﴿واجعله رب رضيا﴾</q>: يعني: مَرْضِيًّا عندك، زاكيًا بالعمل{7}. (١٠/٢٥) ٤٦١٠٩- قال مقاتل بن سليمان: <q>﴿واجعله رب رضيا﴾</q>، يعني: صالِحًا{14}. (ز) ٤٦١١٠- قال يحيى بن سلّام، في قوله: <q>﴿واجعله رب رضيا﴾</q>: فأوحى الله إليه{43}. (ز) <q>﴿وَٱجۡعَلۡهُ رَبِّ رَضِیࣰّا ۝٦﴾</q> - آثار متعلقة بالآيتين ٤٦١١١- عن الحسن البصري، قال: قال رسول الله ﷺ: «رحِم الله أخي زكريا، ماكان عليه مِن ورثة ماله حين يقول: <q>﴿فهب لي من لدنك وليا، يرثني ويرث من آل يعقوب﴾</q>!»{44}. (١١/١٣) ٤٦١١٢- قال قتادة: ذُكِر لنا: أنّ نبي الله ﷺ كان إذا قرأ هذه الآية، وأتى على <q>﴿يرثني ويرث من آل يعقوب﴾</q> قال: «رحم الله زكريا، ما كان عليه مِن ورَثَته!»{45}. (ز) ٤٦١١٣- عن محمد بن كعب القرظي، قال: قال داود ﵇: يا ربِّ، هب لي ابنًا. فوُلِد له ابنٌ خرج عليه، فبعث إليه داود جيشًا، فقال: إن أخذتموه سليمًا فابعثوا إلَيَّ رجلًا أعرف السرور -أو قال: البِشْرَ- في وجهه، وإن قتلتموه فابعثوا إلَيَّ رجلًا أعرف الشَّرَّ في وجهه. فقتلوه، فبعثوا إليه رجلًا أسود، فلمّا رآه علِم أنّه قُتِل، فقال: ربِّ، سألتُ أن تَهَب لي ابنًا، فخرج عَلَيَّ. فقال: إنك لم تستثن. قال محمد بن كعب:لم يقل كما قال زكريا: <q>﴿واجعله رب رضيا﴾</q>{4}. (١٠/١٤) ",footnotes:1:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٦٢-٦٣ (١٤٥)، وإسحاق البستي في تفسيره ص١٧٣ (رسالة جامعية ت: عوض العمري). وعزاه السيوطي إلى أبي عبيد، وابن المنذر، وابن أبي حاتم. وهي قراءة شاذة، تروى أيضًا عن محمد بن علي، وعلي بن الحسن، ويحيى بن يعمر، وغيرهم. انظر: مختصر ابن خالويه ص٨٦، والمحتسب ٢/٣٧.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.أخرجه الحاكم ٢/٥٩٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٥٥.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٥/٤٥٦ بلفظ: العَصَبَة. دون الكلام الذي بعدها. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٥٦، وإسحاق البستي في تفسيره ص١٧٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٥٦.أخرجه عبد الرزاق ٢/٣، وابن جرير ١٥/٤٥٦.أخرجه ابن جرير ١٥/٤٥٧. وعلقه يحيى بن سلام ١/٢١٤.تفسير الثعلبي ٦/٢٠٦، وتفسير البغوي ٥/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٤.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٤.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٤.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة، ما عدا أبا عمرو، والكسائي، فإنّهما قرآ: ‹يَرِثْنِي ويَرِثْ› بجزم الثاء فيهما. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد. و(يَرِثُنِي وارِثٌ) قراءة شاذة، تروى عن الحسن، والجحدري، وقتادة، وغيرهم. انظر: مختصر ابن خالويه ص٨٦، والمحتسب ٢/٣٨.عزاه السيوطي إلى عبد بن حميد.أخرجه الحاكم ٢/٥٨٧.عزاه السيوطي إلى الفريابي.البُرْنُس: كل ثوب رأْسه منه مُلْتَزِقٌ به. لسان العرب (برنس).أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٥/٤٥٨.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص١٧٤ (رسالة جامعية ت: عوض العمري). وعزا السيوطي إلى ابن أبي حاتم آخره.أخرجه عبد الرزاق ٢/٣، وابن جرير ١٥/٤٥٩. وعلَّقه يحيى بن سلام ٢/٢١٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ٦/٢٠٦، وتفسير البغوي ٥/٢١٨. والحبورة: هي رئاسة المذبح وبيت القربان. كما في تفسير الثعلبي ٧/٢٦٤.أخرجه ابن جرير ١٥/٤٥٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٥٨ بلفظ: يكون نبيًّا كما كانت آباؤه أنبياء. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٠٦.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه الثوري في تفسيره ص١٨١.تفسير يحيى بن سلام ١/٢١٤.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٥.أخرجه يحيى بن سلام ١/٢١٤، وابن جرير ١٥/٤٥٩ واللفظ له. وهو مرسل كما ذكر ابن كثير في التعليق السابق.أخرجه ابن جرير ١٥/٤٥٩-٤٦٠ مرسلًا.عزاه السيوطي إلى ابن أبي حاتم.
