19,7," <q>﴿یَـٰزَكَرِیَّاۤ إِنَّا نُبَشِّرُكَ بِغُلَـٰمٍ ٱسۡمُهُۥ یَحۡیَىٰ﴾</q> - تفسير ٤٦١١٤- قال عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك-: فاستجاب الله له، كان قد دخل في السِّنِّ هو وامرأتُه، فبينا هو قائم يصلي في المحراب حيث يذبح القربان إذا هو برجل عليه البياض حياله، وهو جبريل، فقال: يا زكريّا، إنّ الله يبشرك بغلام اسمه يحيى. هو اسم مِن اسماء الله، اشتق مِن: يا حيُّ، سمّاه الله فوق عرشه{1}. (١٠/٢٥) ٤٦١١٥- عن مجاهد بن جبر، قال: لَمّا دعا زكريا ربَّه أن يهب له غلامًا هبط جبريل ﵇، فبشَّره بيحيى{2}. (١٠/١٥) ٤٦١١٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يا زكريا إنا نبشرك بغلام اسمه يحيى﴾</q> عبدًا أحياه الله بالإيمان{3}. (ز) ٤٦١١٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: نادى جبرائيل زكريا: إنّ الله يبشرك بغلام اسمه يحيى لم نجعل له مِن قبل سميًّا{4}. (ز) ٤٦١١٨- قال مقاتل بن سليمان: فاستجاب الله ﷿ لزكريا في الولد، فأتاه جبريل وهو يُصَلِّي، فقال: <q>﴿يازكريا إنا نبشرك بغلام اسمه يحيى﴾</q>{5}. (ز) <q>﴿لَمۡ نَجۡعَل لَّهُۥ مِن قَبۡلُ سَمِیࣰّا ۝٧﴾</q> - تفسير ٤٦١١٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال:لم يُسَمَّ أحَدٌ يحيى قبله{6}. (١٠/١٥) ٤٦١٢٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال:لم تلِدِ العواقِرُ مثلَه ولدًا{7}. (١٠/١٥) ٤٦١٢١- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>: لم يجعل لزكريا من قبل يحيى ولدًا. نظيرها: <q>﴿هل تعلم له سميا﴾</q> [مريم:٦٥]، يعني: هل تعلم له ولدًا. ولم يكن لزكريا قبله ولد، ولم يكن قبل يحيى أحد يُسَمّى: يحيى. قال: وكان اسمه: حي، فلما وهب الله لسارة إسحق، فكان اسمها: يسارة -ويسارة مِن النساء التي لا تلد، وسارة من النساء: الطالقة الرَّحِم التي تلد-، فسماها الله: سارة، وحوَّل الياء مِن سارة إلى حي، فسماه: يحيى{1}. (١٠/٢٥) ٤٦١٢٢- عن سعيد بن جبير، في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال: شِبْهًا{9}. (١٠/١٦) ٤٦١٢٣- عن عطاء، مثله{10}. (١٠/١٦) ٤٦١٢٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال: مثلًا{11}. (١٠/١٦) ٤٦١٢٥- عن مجاهد بن جبر -من طريق الحَكَم- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال: شِبْهًا{12}. (١٠/١٦) ٤٦١٢٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال: لم يُسَمَّ أحدٌ يحيى قبله{13}. (١٠/١٥) ٤٦١٢٧- عن عكرمة مولى ابن عباس، مثله{14}. (١٠/١٥) ٤٦١٢٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- إن الله يبشرك بغلام اسمه يحيى <q>﴿لم نجعل له من قبل سميا﴾</q>: لم يُسَمَّ أحد قبله: يحيى{15}. (ز) ٤٦١٢٩- عن محمد بن السائب الكلبي، مثله{16}. (ز) ٤٦١٣٠- عن عبد الملك ابن جريج -من طريق حَجّاج-، مثله{15}. (ز) ٤٦١٣١- قال مقاتل بن سليمان: <q>﴿لم نجعل له من قبل سميا﴾</q> لم يكن أحدٌ مِن الناس فيما خلا يُسَمّى: يحيى، وإنما سمّاه: يحيى؛ لأنه أحياه مِن بين شيخ كبير وعجوز عاقر{5}. (ز) ٤٦١٣٢- عن عبدالرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال: لم يُسَمَّ أحدٌ قبلَه بهذا الاسم{15}. (ز) ٤٦١٣٣- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>، قال: ليس ليحيى مِثْلٌ في ولد آدم{20}. (ز) ٤٦١٣٤- عن يحيى بن سلّام: <q>﴿سميا﴾</q>، قال: يُسامِيه، نَظِيرٌ له في ذلك{21}٤١٣٣. (ز) ٤١٣٣ اختُلِف في قوله: <q>﴿لم نجعل له من قبل سميا﴾</q>؛ فقال قوم: معناه:لم تلد مثله عاقر قط. وقال آخرون: لم نجعل له من قبله مِثْلًا. وقال غيرهم: معنى ذلك: أنّه لم يسم باسمه أحد قبله. ورجَّح ابنُ جرير (١٥/٤٦٣) مستندًا إلى اللغة القولَ الأخير الذي قاله ابن عباس، وقتادة، وابن جريج، والسدي، وعبد الرحمن بن زيد بن أسلم، فقال: «والسّمي: فعيل، صُرِف من»مفعول«إليه». ووجَّهَ ابنُ عطية (٦/١٠) القول الثاني الذي قاله مجاهد، فقال: «وهذا كأنه من المساماة، والسمو». ثم انتقده مستندًا للواقع، فقال: «وفي هذا بُعْد؛ لأنه لا يُفضل على إبراهيم وموسى ﵉، إلاّ أن يفضل في السؤود والحصر». <q>﴿لَمۡ نَجۡعَل لَّهُۥ مِن قَبۡلُ سَمِیࣰّا ۝٧﴾</q> - آثار متعلقة بالآية ٤٦١٣٥- عن يحيى بن خلاد الزرقي: أنّه لَمّا وُلِد أُتِي به النبي ﷺ، فحنَّكه، وقال: «لأسمينه اسمًا لم يُسَمَّ بعد يحيى بن زكريا». فسماه: يحيى{22}. (١٠/١٦) ٤٦١٣٦- عن يحيى بن عبدالرحمن بن حاطب، قال: قال عمر لصهيب: ما وجدت عليك في الإسلام إلا ثلاثًا: تكنيت: أبا يحيى، وقال الله تعالى: <q>﴿لم نجعل له من قبل سميا﴾</q>، وإنّك لم تمسك شيئًا إلا أنفقته، وتُدعى إلى النمر بن قاسط، وأنت من المهاجرين الأولين، وممن أنعم الله عليه. قال: أما قولك إني تكنيت: أبا يحيى؛ فإنّ رسول الله ﷺ كنّاني: أبا يحيى. وأما قولك: إني لا أمسك شيئًا إلا أنفقته؛ فإن الله تعالى قال: <q>﴿وما أنفقتم من شيء فهو يخلفه﴾</q> [سبأ:٣٩]. وأما قولك: إني أدعى إلى النمر؛ فإن العرب كانت يسبي بعضهم بعضًا، فسَبَتْنِي طائفة من العرب، فباعوني بسواد الكوفة، فأخذت بلسانهم، ولو كنت مِن روثة ما ادَّعَيْتُ إلا إليها{23}. (ز) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٢١٥، وابن جرير ١٥/٤٦٠.أخرجه ابن جرير ١٥/٤٦٤.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه الفريابي -كما في التغليق ٤/٣٣-، وابن أبي شيبة ١١/٥٦٠، وابن أبي حاتم -كما في فتح الباري ٦/٤٦٨-، والحاكم ٢/٣٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٦١. وعلَّقه يحيى بن سلام ٢/٢١٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٦٢، وإسحاق البستي في تفسيره ص١٧٥-١٧٦من طريق سفيان بن عيينة عن رجل. وعزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٦٢، وإسحاق البستي في تفسيره ص١٧٥-١٧٦.أخرجه يحيى بن سلام ٢/٢١٥، وعبد الرزاق ٢/٤، وابن جرير ١٥/٤٦٢ من طريق سعيد. وعزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد.عزاه السيوطي إلى أحمد في الزهد.أخرجه ابن جرير ١٥/٤٦٣.تفسير الثعلبي ٦/٢٠٧، وتفسير البغوي ٥/٢١٩.أخرجه ابن جرير ١٥/٤٦٣.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٦٣.أخرجه إسحاق البستي في تفسيره ص١٧٥.تفسير يحيى بن سلام ١/٢١٥.أخرجه البخاري في تاريخه ٨/٢٦٩-٢٧٠ في ترجمة يحيى بن خلاد (٢٩٦٣).أخرجه أبو نعيم في حلية الأولياء ١/١٥٣-١٥٤.
19,8," <q>﴿قَالَ رَبِّ أَنَّىٰ یَكُونُ لِی غُلَـٰمࣱ وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا﴾</q> - تفسير ٤٦١٣٧- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿قال رب أنى يكون لي غلام وكانت امرأتي عاقرا﴾</q>: خاف أنها لا تلِد{1}. (١٠/٢٥) ٤٦١٣٨- عن مجاهد بن جبر، قال: لَمّا دعا زكريّا ربَّه أن يهب له غلامًا؛ هبط جبريل ﵇، فبشره بيحيى، فقال زكريا عندها: <q>﴿أنى يكون لي غلام﴾</q>. وأخبر بكِبَر سنِّه، وعِلَّةِ زوجته، فأخذ جبريلُ عودًا يابسًا، فجعله بين كفي زكريا، فقال: أدرِجْهُ بين كفَّيْك. ففعل، فإذا في رأسه ورقتين يقطُرُ منهما الماء، فقال جبريل: إنّ الذي أخرج هذا الورق من هذا العود قادر أن يُخرج مِن صلبك ومن امرأتك العاقر غلامًا{2}. (١٠/١٥) ٤٦١٣٩- قال الحسن البصري: أراد زكريا أن يَعْلَمَ كيف ذلك{3}. (ز) ٤٦١٤٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: نادى جبرائيل زكريا: إنّ الله يبشرك بغلام اسمه يحيى لم نجعل له من قبل سميًا. فلمّا سمع النداء جاءه الشيطان، فقال: يا زكريا، إنّ الصوت الذي سمعت ليس مِن الله، إنما هو من الشيطان يَسْخَرُ بك، ولو كان مِن الله أوحاه إليك كما يوحي إليك غيره من الأمر. فشكَّ مكانه، وقال: <q>﴿أنى يكون لي غلام﴾</q> يقول: مِن أين يكون <q>﴿وقد بلغني الكبر وامرأتي عاقر﴾</q>؟! [آل عمران:٤٠]{4}. (ز) ٤٦١٤١- قال مقاتل بن سليمان: فلما بَشَّر مَيِّتَيْنِ بالولد <q>﴿قال رب أنى يكون لي غلام﴾</q> يعني: من أين يكون لي غلام <q>﴿وكانت امرأتي عاقرا﴾</q>؟! أيليشفع{5} لا تلد{6}. (ز) ٤٦١٤٢- قال يحيى بن سلّام: قوله: <q>﴿قال رب أنى يكون لي غلام﴾</q> يقول: مِن أين يكون لي غلام <q>﴿وكانت امرأتي عاقرا﴾</q> لا تلد؟!{7}. (ز) <q>﴿وَقَدۡ بَلَغۡتُ مِنَ ٱلۡكِبَرِ عِتِیࣰّا ۝٨﴾</q> - قراءات ٤٦١٤٣- في قراءة عبد الله بن مسعود: (وقَدْ بَلَغْتُ مِنَ الكِبَرِ عُسِيًّا){8}. (ز) ٤٦١٤٤- عن ابن كثير، قال: سمعت مجاهدًا يقول: في قراءة أُبَيّ بن كعب: (مِنَ الكِبَرِ عُسِيًّا){9}. (ز) ٤٦١٤٥- عن عبد الله بن عباس -من طريق عكرمة- قال: لا أدري كيف كان رسول الله ﷺ يقرأ هذا الحرف‹عُتِيًّا›{10} أو (عُسِيًّا)؟{11}. (١٠/١٦) ٤٦١٤٦- عن يحيى بن وثاب أنه قرأها: <q>﴿عِتِيًّا﴾</q>، و<q>﴿صِلِيًّا﴾</q> بكسر العين والصاد{12}. (١٠/١٨) ٤٦١٤٧- عن عاصم بن أبي النجود أنه قرأ: (عُتِيًّا) برفع العين{12}. (١٠/١٨) ٤٦١٤٨- عن عبد الله بن عقيل أنّه قرأ: (وقَدْ بَلَغْتُ مِنَ الكِبَرِ عُسِيًّا) بالسين ورفع العين{2}. (١٠/١٨) <q>﴿وَقَدۡ بَلَغۡتُ مِنَ ٱلۡكِبَرِ عِتِیࣰّا ۝٨﴾</q> - تفسير الآية ٤٦١٤٩- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وقد بلغت من الكبر عتيا﴾</q>، قال: يعني بالعِتيِّ: الكِبَر{15}. (ز) ٤٦١٥٠- عن ميمون بن مهران، أن نافع بن الأزرق سأل عبد الله بن عباس، فقال: أخبِرني عن قول الله: <q>﴿وقد بلغت من الكبر عتيا﴾</q>، ما العِتِيُّ؟ قال: البؤس مِن الكِبَر. قال الشاعر: إنما يعذر الوليد ولا يُـ ـعذر مَن كان في الزمان عِتِيّا{16}. (١٠/١٦) ٤٦١٥١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿وقد بلغت من الكبر عتيا﴾</q>، قال: نُحُول العظم{17}. (١٠/١٧) ٤٦١٥٢- قال سفيان بن عيينة: فسَّر مجاهد <q>﴿من الكبر عتيا﴾</q>، قال: عُسيًّا{9}. (ز) ٤٦١٥٣- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وقد بلغت من الكبر عتيا﴾</q>، قال: هو الكِبَر{19}. (ز) ٤٦١٥٤- عن عطاء: <q>﴿وقَدْ بَلَغْتُ مِنَ الكِبَرِ عِتِيًّا﴾</q>، قال: لبثت زمانًا في الكبر{2}. (١٠/١٧) ٤٦١٥٥- عن وهب بن مُنَبِّه -من طريق أبي عثمان الصنعاني- <q>﴿وقد بلغت من الكبر عتيا﴾</q>: قال هذه المقالة، وهو ابن ستين، أو خمس وستين{21}. (١٠/١٨) ٤٦١٥٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وقَدْ بَلَغْتُ مِنَ الكِبَرِ عِتِيًّا﴾</q>، قال: سِنًّا. قال: وبلغني: أنّه كان ابن بضع وسبعين سنة{22}. (١٠/١٧) ٤٦١٥٧- قال قتادة بن دعامة: يريد: نُحُول العظم{23}. (ز) ٤٦١٥٨- عن إسماعيل السُّدِّيّ: <q>﴿وقَدْ بَلَغْتُ مِنَ الكِبَرِ عِتِيًّا﴾</q>، يقول: هرمًا{2}. (١٠/١٧) ٤٦١٥٩- قال محمد بن السائب الكلبي: العتي: اليبس{3}. (ز) ٤٦١٦٠- قال مقاتل بن سليمان: <q>﴿وقد بلغت﴾</q> أنا <q>﴿من الكبر عتيا﴾</q>، يعني: بؤسًا، وكان زكريا يومئذ ابن خمس وسبعين سنة{6}. (ز) ٤٦١٦١- عن سفيان الثوري -من طريق عبد الرزاق- قال: بلغني: أنّ زكريا كان ابن سبعين سنة{27}. (١٠/١٨) ٤٦١٦٢- عن عبد الله بن المبارك، <q>﴿وقد بلغت من الكبر عتيا﴾</q>، قال: سِتِّين سنة{2}. (١٠/١٨) ٤٦١٦٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وقد بلغت من الكبر عتيا﴾</q>، قال: العِتِيُّ: الذي عَتا عن الولد فيما يرى في نفسه، لا ولادة فيه{29}. (١٠/١٨) ٤٦١٦٤- قال يحيى بن سلّام: وقال بعضهم: يُبْسُ جلدي على عظمي{7}٤١٣٤. (ز) ٤١٣٤ أفادت الآثارُ الاختلافَ في معنى قوله: <q>﴿عتيا﴾</q> على قولين: أحدهما: نُحُول العظم. والآخر: الكبَر. وعلَّق ابنُ كثير (٩/٢١٨) بعد ذكرهما بقوله: «والظاهر أنه أخص من الكِبَر». ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٥.أخرجه ابن جرير ١٥/٤٦٤.أيليشفع: اسم امرأة زكريا، كما ذكر مقاتل بن سليمان في تفسير سورة آل عمران.تفسير مقاتل بن سليمان ٢/٦٢١.تفسير يحيى بن سلام ١/٢١٥.علقه يحيى بن سلام ١/٢١٥. (عُسِيًّا) بالسين قراءة شاذة، تروى أيضًا عن ابن عباس، ومجاهد. انظر: مختصر ابن خالويه ص٨٦.أخرجه إسحاق البستي في تفسيره ص١٧٦.كذا ضبطت في مطبوعة تفسير ابن جرير، وقد نسب محققوها هذا الضبط إلى إحدى النسخ الخطية، وإلى أصول مسند أحمد.أخرجه أحمد ٤/١١٢، ١٧٢ (٢٢٤٦، ٢٣٣٢)، وأبو داود (٨٠٩) -وليس فيه محل الشاهد-، وابن جرير ١٥/٤٦٥، والحاكم ٢/٢٤٤. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن مردويه. صححه الحاكم، قال محققو المسند: «إسناده صحيح على شرط البخاري». و‹عُتِيًّا›، و‹صُلِيًّا› بضم العين، والصاد قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، وحفصًا؛ فإنهم قرؤوا بكسر العين والصاد فيهما. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٦٥.أخرجه الحاكم ٢/٣٧٣. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء بلفظ «اليؤس» بدل«البؤس».أخرجه ابن جرير ١٥/٤٦٥. وعلَّقه يحيى بن سلام ١/ ٢١٥ بلفظ: قحول، وكذا أخرجه ابن عساكر في تاريخ دمشق ١٩/٥١، وينظر: مختصره لابن منظور ٩/٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص١٧٦.أخرجه ابن جرير ١٥/٤٦٦، وإسحاق البستي في تفسيره ص١٧٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الرامَهُرْمُزِيُّ في الأمثال ص٦٤.أخرجه عبد الرزاق ٢/٤، وابن جرير ١٥/٤٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٢٠٧، وتفسير البغوي ٥/٢٢٠.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٥.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٥٤. وعزاه السيوطي إلى عبد الرزاق، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٦٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٢١٥.
19,9," <q>﴿قَالَ كَذَ ٰ⁠لِكَ قَالَ رَبُّكَ هُوَ عَلَیَّ هَیِّنࣱ وَقَدۡ خَلَقۡتُكَ مِن قَبۡلُ وَلَمۡ تَكُ شَیۡـࣰٔا ۝٩﴾</q> - تفسير ٤٦١٦٥- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿قال كذلك قال ربك﴾</q> يا زكريا: <q>﴿هو علي هين وقد خلقتك من قبل﴾</q> أن أهبَ لكَ يحيى <q>﴿ولم تك شيئا﴾</q>، وكذلك أقدر على أن أخلق مِن الكبير والعاقِر{1}. (١٠/٢٥) ٤٦١٦٦- قال مقاتل بن سليمان: <q>﴿قال﴾</q> له جبريل ﵇: <q>﴿كذلك﴾</q> يعني: هكذا، <q>﴿قال ربك﴾</q> إنه ليكون لك غلام، <q>﴿هو علي هين وقد خلقتك من قبل﴾</q> أن تسألني الولد، <q>﴿ولم تك شيئا﴾</q>{2}. (ز) ٤٦١٦٧- قال يحيى بن سلّام: قال له الملك: <q>﴿قال كذلك قال ربك هو علي هين﴾</q> الله يقوله، وهو كلام موصول أخبَرَ به الملَك عن الله: أعطيك هذا الولد، <q>﴿وقد خلقتك من قبل ولم تك شيئا﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢١.تفسير يحيى بن سلام ١/٢١٥.
19,10," <q>﴿قَالَ رَبِّ ٱجۡعَل لِّیۤ ءَایَةࣰۖ﴾</q> - تفسير ٤٦١٦٨- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- قال: وذلك أنّ إبليس أتاه، فقال: يا زكريا، دعاؤك كان خفِيًّا، فأُجِبت بصوت رفيع، وبُشِّرت بصوت عالٍ، ذلك صوتٌ مِن الشيطان، ليس مِن جبريل، ولا من ربك. <q>﴿قال رب اجعل لي آية﴾</q> حتى أعرف أنّ هذه البُشرى مِنكَ{1}. (١٠/٢٥) ٤٦١٦٩- عن نوف البِكالِيِّ في قوله: <q>﴿رب اجعل لي آية﴾</q>، قال: أعطِنِي آيةً أنّك قد استجبت لي. فقال: <q>﴿آيتك أن لا تكلم الناس ثلاث ليال سويا﴾</q>{2}. (١٠/١٨) ٤٦١٧٠- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿قال رب﴾</q> فإن كان هذا الصوت منك فـ<q>﴿اجعل لي آية قال﴾</q> اللهُ: <q>﴿آيتك﴾</q> لذلك <q>﴿ألا تكلم الناس ثلاث ليال سويا﴾</q>{3}. (ز) ٤٦١٧١- قال مقاتل بن سليمان: <q>﴿قال﴾</q> زكريا: <q>﴿رب اجعل لي آية﴾</q>، يعني: علَمًا للحَبَل، فسأل الآية بعد مشافهة جبريل{4}. (ز) ٤٦١٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قال رب اجعل لي آية﴾</q>، قال: <q>﴿قال رب اجعل لي آيةً﴾</q> أن هذا منك{3}. (ز) ٤٦١٧٣- قال يحيى بن سلّام: <q>﴿قال﴾</q> زكريا <q>﴿رب اجعل لي آية﴾</q>{6}. (ز) <q>﴿قَالَ ءَایَتُكَ أَلَّا تُكَلِّمَ ٱلنَّاسَ ثَلَـٰثَ لَیَالࣲ سَوِیࣰّا ۝١٠﴾</q> - تفسير ٤٦١٧٤- عن عبد الله بن عباس -من طريق سعيد- في قوله: <q>﴿أن لا تكلم الناس ثلاث ليال سويا﴾</q>، قال: اعتقل لسانُه مِن غير مرض{7}. (١٠/١٩) ٤٦١٧٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ثلاث ليال سويا﴾</q>، قال: من غير خرس{8}. (١٠/١٩) ٤٦١٧٦- عن الضحاك بن مزاحم، مثله{9}. (١٠/١٩) ٤٦١٧٧- عن عكرمة مولى ابن عباس -من طريق قتادة-، مثله{10}. (١٠/١٩) ٤٦١٧٨- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿قال آيتك ألا تكلم الناس ثلاث ليال سويا﴾</q>، قال: ثلاث ليال مُتتابِعات{11}٤١٣٥. (ز) ٤١٣٥ اختلف في معنى <q>﴿سويا﴾</q>؛ فقال قوم: صحيح مِن غير عِلَّة. وقال آخرون: ذاك عائد على الليالي، أي: متتابعات. ورجَّح ابنُ كثير (٩/٢١٩ بتصرف) مستندًا إلى القرآن القولَ الأول دون الثاني الذي قاله ابن عباس من طريق العوفي، فقال: «والقول الأول أصح، كما قال تعالى في آل عمران [٤١]: <q>﴿قال رب اجعل لي آية قال آيتك ألا تكلم الناس ثلاثة أيام إلا رمزا واذكر ربك كثيرا وسبح بالعشي والإبكار﴾</q>». ٤٦١٧٩- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿قال آيتك أن لا تكلم الناس ثلاث ليال سويًا﴾</q>، يعني: صحيحًا مِن غير خرس. فحاضت زوجتُه، فلمّا طهُرَت طاف عليها، فاستحملت، فأصبح لا يتكلم، فكان إذا أراد التسبيحَ والصلاةَ أطلق اللهُ لسانه، فإذا أراد أن يكلم الناس اعْتُقِل لسانُه فلا يستطيع أن يتكلم، وكانت عقوبة له؛ لأنّه بُشِّر بالولد، فقال: أنى يكون لي ولد؟! فخاف أن يكون الصوت مِن غير الله{1}. (١٠/٢٥) ٤٦١٨٠- عن أبي عبد الرحمن السلمي، قال: اعتُقِل لسانه مِن غير مرض{13}. (ز) ٤٦١٨١- عن نوف البِكالِيِّ، في قوله: <q>﴿آيتك أن لا تكلم الناس ثلاث ليال سويا﴾</q>، قال: ختم على لسانه وهو صحيح سويٌّ ليس به من مرض، فلم يتكلم ثلاثة أيام{2}. (١٠/١٨) ٤٦١٨٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جريج- في قوله: <q>﴿ثلاث ليال سويا﴾</q>، قال: صحيحًا، لا يمنعك الكلامَ مرضٌ{15}. (١٠/١٩) ٤٦١٨٣- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتَّهم- قال: أخذ الله بلسانه مِن غير سوء، فجعل لا يطيق الكلام، وإنما كلامه لقومه بالإشارة، حتى مضت الثلاثة الأيام التي جعلها الله آية لِمِصْداقِ ما وعده مِن هِبَتِه له{16}. (ز) ٤٦١٨٤- عن قتادة بن دعامة -من طريق سعيد- قال: إنما عُوقِب لأنّه سأل الآية بعدما شافهته الملائكة مشافهة، وبشَّرته بيحيى، فأخذ عليه بلسانه، فجعل لا يُفِيض الكلام، أي: لا يُبِينُ الكلامَ إلا ما أوْمَأَ إيماء، وهو قوله: <q>﴿ثلاثة أيام إلا رمزا﴾</q> [آل عمران:٤١]: إيماء{17}. (ز) ٤٦١٨٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿قال آيتك ألا تكلم الناس ثلاث ليال سويا﴾</q>، يقول: مِن غير خرس، إلا رمزًا، فاعْتُقِل لسانُه ثلاثة أيام وثلاث ليال{18}. (ز) ٤٦١٨٦- قال مقاتل بن سليمان: <q>﴿قال﴾</q> جبريل ﵇: <q>﴿آيتك﴾</q> إذا جامعتَها على طُهْرٍ فحَبلت فإنّك تصبح تلك الليلة لا تستنكر مِن نفسك خرسًا، ولا مرضًا، ولكن لا تستطيع الكلام، <q>﴿ألا تكلم الناس ثلاث ليال سويا﴾</q> أنت فيهن سَوِيٌّ صحيح. فأخذ بلسانه عقوبة حين سأل الآية بعد مشافهة جبريل ﵇، ولم يحبس الله ﷿ لسانه عن ذِكره، ولا عن الصلاة{4}. (ز) ٤٦١٨٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في الآية، قال: حبس لسانه، فكان لا يستطيع أن يُكَلِّم أحدًا، وهو في ذلك يُسَبِّح، ويقرأ التوراة، فإذا أراد كلام الناس لم يستطع أن يكلمهم{20}. (١٠/١٩) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه الحاكم ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٦٧.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٦٧.تفسير يحيى بن سلام ١/٢١٦.أخرجه ابن جرير ١٥/٤٦٨.أخرجه ابن جرير ١٥/٤٦٨، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٤، وابن جرير ١٥/٤٦٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٧٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم -كما في الفتح ٦/٤٦٨-.أخرجه الحاكم ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٦٨، كما أخرجه يحيى بن سلام ١/٢١٦ من طريق عاصم بن حكيم، وإسحاق البستي في تفسيره ص١٧٧ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٦٩.أخرجه يحيى بن سلام ١/٢١٦ واللفظ له، وعبد الرزاق ٢/٤ مختصرًا، وابن جرير ١٥/٤٦٨ وآخره بلفظ: ما كان يطيق الكلام، إلا ما أومأ إيماء. دون ذكر آية آل عمران.أخرجه ابن جرير ١٥/٤٦٩. وعلَّقه يحيى بن سلام ١/٢١٦ بلفظ: يعني: صحيحًا من غير خرس ولا داء.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٦٩ وفيه زيادة: ويقرأ الإنجيل!. وعزاه السيوطي إلى ابن أبي حاتم.
19,11," <q>﴿فَخَرَجَ عَلَىٰ قَوۡمِهِۦ مِنَ ٱلۡمِحۡرَابِ﴾</q> - تفسير ٤٦١٨٨- عن عبد الله بن عباس، في قوله: <q>﴿فخرج على قومه من المحراب﴾</q>: يعني: مِن مُصَلّاه الذي كان يُصَلِّي فيه{1}. (١٠/٢٥) ٤٦١٨٩- قال الحسن البصري، في قوله: <q>﴿فخرج على قومه من المحراب﴾</q>: مِن المسجد{2}. (ز) ٤٦١٩٠- عن عبد الملك ابن جُرَيج -من طريق حجاج- <q>﴿فخرج على قومه من المحراب﴾</q>، قال: أشْرَفَ على قومه من المحراب{3}. (ز) ٤٦١٩١- قال مقاتل بن سليمان: <q>﴿فخرج﴾</q> زكريا <q>﴿على قومه﴾</q> بني إسرائيل <q>﴿من المحراب﴾</q> يعني: مِن المسجد{4}. (ز) ٤٦١٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فخرج على قومه من المحراب﴾</q>، قال: المحراب: مُصَلّاه{5}. (١٠/١٩) <q>﴿فَأَوۡحَىٰۤ إِلَیۡهِمۡ﴾</q> - تفسير ٤٦١٩٣- عن عبد الله بن عباس، في قوله: <q>﴿فأوحى إليهم﴾</q>، قال: كَتَب لهم كتابًا{6}. (١٠/١٩) ٤٦١٩٤- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿فأوحى إليهم﴾</q>: بكتاب كتبه بيده{1}. (١٠/٢٥) ٤٦١٩٥- عن نوف البِكالِيِّ، <q>﴿فأوحى إليهم﴾</q>، قال: كتب لهم{8}. (١٠/٢٠) ٤٦١٩٦- عن سعيد بن جبير، <q>﴿فأوحى إليهم﴾</q>، قال: أوْمَأ إليهم{9}. (١٠/٢٠) ٤٦١٩٧- عن مجاهد بن جبر، في قوله: <q>﴿فَأَوْحى إلَيْهِمْ أنْ سَبِّحُوا﴾</q>، قال: كتب لهم في الأرض{10}. (١٠/٢٠) ٤٦١٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فأوحى إليهم﴾</q>، قال: فأشار زكريا{11}. (١٠/٢٠) ٤٦١٩٩- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- <q>﴿فأوحى إليهم﴾</q>، قال: الوحي: الإشارة{12}. (ز) ٤٦٢٠٠- عن الحكم [بن عتيبة] -من طريق ابن أبي ليلى- <q>﴿فأوحى إليهم﴾</q>، قال: كتب لهم{13}. (١٠/٢٠) ٤٦٢٠١- عن محمد بن كعب القرظي -من طريق أبي معشر- <q>﴿فأوحى إليهم أن سبحوا﴾</q>، قال: أشار إليهم إشارة{14}. (١٠/٢٠) ٤٦٢٠٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿فأوحى إليهم﴾</q>، قال: أوْمى إليهم{15}. (ز) ٤٦٢٠٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فكتب لهم في كتاب: <q>﴿أن سبحوا بكرة وعشيا﴾</q>. وذلك قوله: <q>﴿فأوحى إليهم﴾</q>{16}. (١٠/٢٠) ٤٦٢٠٤- قال مقاتل بن سليمان: <q>﴿فأوحى إليهم﴾</q>، يقول: كتب كتابًا بيده، وهو الوحي إليهم{4}. (ز) ٤٦٢٠٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأوحى إليهم أن سبحوا بكرة وعشيا﴾</q>، قال: ما ندري كتابًا كتبه لهم، أو إشارة أشارها! -والله أعلم-. قال: أمرهم أن سبِّحوا بكرة وعشيًّا، وهو لا يكلمهم{15}. (ز) ٤٦٢٠٦- قال يحيى بن سلّام: <q>﴿فأوحى إليهم﴾</q>، أي: أوْمَأَ إليهم{19}٤١٣٦. (ز) ٤١٣٦ اختُلِف في معنى: <q>﴿فأوحى إليهم﴾</q>؛ فقال قوم: أمرهم. وقال آخرون: معنى أوحى: كتب. وقال غيرهم: أشار إليهم بيده. وذكر ابنُ جرير (١٥/٤٧١) أن المعنى: أشار إليهم، وأن هذه الإشارة قد تكون باليد، أو بالكتابة، وبغير ذلك مما يُفهم به مراده. وعلَّق ابنُ عطية (٦/١٢) على القول الثاني والثالث بقوله: «وكِلا القولين وحْيٌ». <q>﴿أَن سَبِّحُوا۟ بُكۡرَةࣰ وَعَشِیࣰّا ۝١١﴾</q> - تفسير ٤٦٢٠٧- عن عبد الله بن عباس، في قوله: <q>﴿فأوحى إليهم أن سبحوا﴾</q>، قال: أمَرَهم بالصلاة بكرة وعشيًّا{20}. (١٠/٢٠) ٤٦٢٠٨- عن عبد الله بن عباس، في قوله: <q>﴿أن سبحوا بكرة عشيا﴾</q>: يعني: صَلُّوا صلاةَ الغداة والعصر{1}. (١٠/٢٥) ٤٦٢٠٩- عن أبي العالية الرِّياحِي في قوله: <q>﴿أن سبحوا بكرة وعشيا﴾</q>. قال: البكرة صلاة الفجر، وعشيًا صلاة العصر{6}. (١٠/٢١) ٤٦٢١٠- قال الحسن البصري: <q>﴿أن سبحوا بكرة وعشيا﴾</q>، أي: أن صلُّوا لله بالغداة والعَشِيِّ{2}. (ز) ٤٦٢١١- عن محمد بن كعب القرظي -من طريق أبي مَعْشَرٍ- في قول الله: <q>﴿فأوحى إليهم أن سبحوا بكرة وعشيا﴾</q>، قال: أشار إليهم أن صلُّوا بكرة وعشيًّا{24}. (ز) ٤٦٢١٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿فأوحى إليهم أن سبحوا﴾</q>، قال: صلُّوا{25}. (١٠/٢١) ٤٦٢١٣- قال مقاتل بن سليمان: <q>﴿أن سبحوا بكرة وعشيا﴾</q>: أن صلوا بالغداة والعَشِيِّ{4}. (ز) ٤٦٢١٤- قال يحيى بن سلّام، في قوله: <q>﴿أن سبحوا بكرة وعشيا﴾</q>: يعني به: الصلاة؛ صلاة الغداة، وصلاة العصر{19}. (ز) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٦.أخرجه ابن جرير ١٥/٤٧٠.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٠. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٧١. وعلَّقه يحيى بن سلام ١/٢١٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٧١.أخرجه عبد الرزاق في تفسيره ٢/٥، وفي مصنفه ٦/٤١٣ (١١٤٣٥)، وابن جرير ١٥/٤٧٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١١٨ (٢٣٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٧٢.أخرجه ابن جرير ١٥/٤٧٢. وعلق يحيى بن سلام ١/٢١٦ نحوه. وعزا السيوطي إلى ابن أبي حاتم نحوه.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٢.تفسير يحيى بن سلام ١/٢١٦.أخرجه الحاكم ٢/٣٧٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٢١٦.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١١٨ (٢٣٣).أخرجه عبد الرزاق ٢/٤، وابن جرير ١٥/٤٧٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٦٢٢.تفسير يحيى بن سلام ١/٢١٦.
