quran[11]{c,v,t}:
  19,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٤٥٩٩٦<span class="dash">-</span></span> عن عائشة، قالت: نزلت سورة مريم بمكة{1}. (١٠/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٩٩٧<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أنزل بمكة سورة «كهيعص»{2}. (١٠/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٩٩٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مكية{3}. (١٠/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٩٩٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: «كهيعص» مكية، نزلت بعد الملائكة؛ فاطر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٠<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: نزلت سورة مريم بمكة{1}. (١٠/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠١<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٢<span class="dash">-</span></span> عن محمد ابن شهاب الزهري: مكية، وسماها «كهيعص»، ونزلت بعد فاطر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٤<span class="dash">-</span></span> قال مقاتل بن سليمان: مكية كلها، إلا آية سجدتها [٥٨] فإنها مدنية، وهي ثمان وتسعون آية كوفي{9}<span class=comment-ref>٤١٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥) أنّ هذه السورة مكية <span class="mustanad">بإجماع</span>، إلا السجدة منها.</div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٥<span class="dash">-</span></span> قال يحيى بن سلّام: وهي مكية كلها، وهي تسعون وثمان آيات{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٦<span class="dash">-</span></span> عن أم سلمة: أنّ النجاشيَّ قال لجعفر بن أبي طالب: هل معك مما جاء به -يعني: رسول الله ﷺ- عن الله شيء؟ قال: نعم. فقرأ عليه صدرًا مِن«كهيعص»، فبكى النجاشيُّ حتى أخْضَل لحيته، وبكت أساقِفَتَهُ حتى أخْضَلوا مصاحفهم حين سمعوا ما تلا عليهم، ثم قال النجاشيُّ: إنّ هذا والذي جاء به موسى لَيخرج مِن مِشْكاة واحدة{11}. (١٠/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٧<span class="dash">-</span></span> عن أبي بكر بن عبد الله بن أبي مريم الغساني، عن أبيه، عن جده، قال: أتيتُ رسولَ الله ﷺ، فقلتُ: وُلِدَت لي الليلة جارية. فقال: «<b>والليلةُ أُنزِلَتْ عليَّ سورة مريم، سمِّها: مريم</b>»{12}. (١٠/٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كۤهیعۤصۤ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٠٨<span class="dash">-</span></span> عن محمد بن السائب الكلبي: أنّه سُئِل عن <span class="qpc-hafs">﴿كهيعص﴾</span>. فحدَّث عن أبي صالح، عن أمِّ هانئ، عن رسول الله ﷺ، قال: «<b>كاف، هاد، عالم، صادق</b>»{13}. (١٠/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من الصحابة</span>: <span class="qpc-hafs">﴿كهيعص﴾</span> هو الهجاء المقطَّع؛ الكاف مِن الملك، والهاء مِن الله، والياء والعين مِن العزيز، والصاد من المُصَوِّر{14}. (١٠/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٠<span class="dash">-</span></span> عن فاطمة ابنة عَلِيٍّ، قالت: كان <span class="name-1">عَلِيُّ [بن أبي طالب]</span> يقول: يا كهيعص، اغفِر لي{15}<span class=comment-ref>٤١٢٣</span>. (١٠/٨)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٦) قول علي بن أبي طالب، و<span class="comment-type-1">وجَّهه</span> بقوله: «فهذا <b>يحتمل</b> أن تكون الجملة من أسماء الله تعالى، و<b>يحتمل</b> أن يريد علي بن أبي طالب ﵁ أن ينادي الله تعالى بجميع الأسماء التي تضمنها <span class="qpc-hafs">﴿كهيعص﴾</span>، كأنه أراد أن يقول: يا كريم، يا هادي، يا عليّ، يا عزيز، يا صادق، اغفر. فجَمَع هذا كلَّه باختصار في قوله: يا كهيعص». ونقل أنّ ابن المستنير وغيره قالوا بأن <span class="qpc-hafs">﴿كهيعص﴾</span> عبارة عن حروف المعجم، ونَسَبَه الزجّاج إلى أكثر أهل اللغة، أي: هذه الحروف منها ذكر رحمت ربك عبده زكريا، ثم <span class="comment-type-4">علَّق</span> بقوله: «وعلى هذا يتركب قول من يقول: ارتفع <span class="qpc-hafs">﴿ذكر﴾</span> بأنه خبر عن <span class="qpc-hafs">﴿كهيعص﴾</span>». ثم قال: «وهي حروف تَهَجٍّ يُوقَف عليها بالسكون».</div></p><p><div></p><p><p><span class="item-no">٤٦٠١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: كبير، هاد، أمين، عزيز، صادق. وفي لفظ: كاف. بدل: كبير{16}. (١٠/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: كاف من كريم، وهاء من هادٍ، وياء من حكيم، وعين من عليم، وصاد من صادق{17}. (١٠/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>: قَسَم أقسم الله به، وهو مِن أسماء الله{18}. (١٠/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- أنه كان يقول في <span class="qpc-hafs">﴿كهيعص﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿يس﴾</span>، وأشباه هذا: هو اسم الله الأعظم{19}. (١٠/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٥<span class="dash">-</span></span> قال يحيى بن سلّام: كان الحسن يقول: لا أدري ما تفسيره، غير أنّ <span class="name-1">قومًا من أصحاب النبي ﵇</span> كانوا يقولون: أسماء السور ومفاتيحها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع بن أنس- قال: <span class="qpc-hafs">﴿كهيعص﴾</span> ليس منها حرفٌ إلا وهو اسم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق إسماعيل بن راشد- في <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: كاف: كبير، ها: هاد، ياء: يمين، عين: عالم، صاد: صادق{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- في قوله <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: كاف: كاف، ها: هاد، عين: عزيز، صاد: صادق{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠١٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: كاف من كريم، يا من حكيم، عين من عالم، صاد: صادق{24}<span class=comment-ref>٤١٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥) على أقوال سعيد بن جبير بقوله: «مقتضى أقواله أنّها دالَّة على كلِّ اسم فيه كاف من أسمائه تعالى».</div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: كاف: كاف، ها: هاد، عين: عدل، صاد: صادق{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: يقول: أنا الكبير، الهادي، عَلِيٌّ، أمين، صادق{14}. (١٠/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٢<span class="dash">-</span></span> عن <span class="name-2">المسيب بن رافع</span> -من طريق ابنه العلاء- في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: اسم مِن أسماء الله، كاف: كبير، ها: هاد، ياء: يمين، عين: من عالم، صادق{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- قال: فواتح يفتح الله بهذا{28} الكتاب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق الكلبي- في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: الكاف: الكافي، والهاء: الهادي، والعين: العالم، والصاد: الصادق. قال: كافٍ لهم، هادٍ لهم، عالِمٌ بهم، صادق في قوله. وفي لفظ: في وعده{30}. (١٠/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: الكاف من الملك، والهاء من الله، والعين من العزيز، والصاد من الصمد{14}. (١٠/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: اسم مِن أسماء القرآن{32}. (١٠/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: مِن الهِجاء المُتَقَطِّع{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: الكاف مفتاح اسمه كافي، والهاء مفتاح اسمه هادي، والعين مفتاح اسمه عالم، والصاد مفتاح اسمه صادق{34}. (١٠/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٢٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق إبراهيم بن أبي الضُّرَيس- في قوله: <span class="qpc-hafs">﴿كهيعص﴾</span>، قال: يا مَن يُجِير ولا يُجار عليه{35}. (١٠/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٣٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق عَنبَسَةَ- أنّه كان يقول: كاف، هاد، عالم، صادق. ويقول: كاف لخلقه، هادٍ لعباده، عالم بأمره، صادق في قوله{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٣١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: هو ثناء أثنى الله ﷿ به على نفسه{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كهيعص﴾</span>: كافٍ، هادٍ، عالم، صادق، هذا ثناءُ الرَّبِّ -تبارك وتعالى- على نفسه، يقول: كافيًا لخلقه، هادِيًا لعباده، الياء مِن الهادي، عالم ببريته، صادق في قوله ﷿{38}<span class=comment-ref>٤١٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٥</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٥/٤٥٢) على ما أوْرَد من أقوال في معنى <span class="qpc-hafs">﴿كهيعص﴾</span> بقوله: «والقول في ذلك عندنا نظيرُ القول في <span class="qpc-hafs">﴿الم﴾</span>، وسائر فواتح سور القرآن التي افتتحت أوائلها بحروف المعجم، وقد ذكرنا ذلك فيما مضى قبل، فأغنى عن إعادته في هذا الموضع».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه النحاس ص٥٥٥. وعزاه السيوطي إلى ابن مردويه.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٥٠١، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خصيف عن مجاهد.</p><p>قال السيوطي في الإتقان ١/٥٠: «إسناده جيد، رجاله كلهم ثقات مِن علماء العربية المشهورين».أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٢/٦١٩.تفسير يحيى بن سلام ١/٢١٣.أخرجه أحمد ٣/٢٦٣، ٣٧/١٧٠ (١٧٤٠، ٢٢٤٩٨)، والبيهقي في الدلائل ٢/٣٠١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الطبراني في الكبير ٢٢/٣٣٢ (٨٣٤)، وأبو نعيم في معرفة الصحابة ٦/٣٠١١ (٦٩٨٨).</p><p>قال ابن القيسراني في ذخيرة الحفاظ ٥/٢٥٦٣ (٥٩٥٨): «رواه أبو بكر بن أبي مريم، عن أبيه، عن جده. وأبو بكر هذا اسمه: بكير، وثَّقه قومٌ، وضعَّفه آخرون». وقال الهيثمي في المجمع ٨/٥٥ (١٢٨٨٩): «رواه الطبراني، وفيه سليمان بن سلمة الخبائري، وهو متروك».عزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف جدًّا؛ لضعف محمد بن السائب الكلبي وأبي صالح، كما تقدم مرارًا.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عثمان بن سعيد الدارمي في الرد على بشر المريسي ص١١، وابن ماجه -كما في تهذيب الكمال ٢٩/٢٨٤-، وابن جرير ١٥/٤٥١.أخرجه ابن جرير ١٥/٤٤٣-٤٤٧، ٤٤٩، ٤٥٠ مفرقًا، وإسحاق البستي في تفسيره ص١٧١، والحاكم ٢/٣٧٢، والبيهقي في الأسماء والصفات (١٦٥، ١٦٦)، والضياء في المختارة ١٠/٥٦ (٤٨). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه عبد الرزاق ٢/٣، وآدم بن أبي إياس -كما في تفسير مجاهد ص٤٥٣-، وعثمان بن سعيد الدارمي في الرد على المريسي ص١١، وابن جرير ١٥/٤٤٤-٤٥٠ مفرقًا، وإسحاق البستي في تفسيره ص١٧٠، بلفظ: كاف من كافي...، والحاكم ٢/٣٧١-٣٧٢، والبيهقي في الأسماء والصفات (١٦٤). وعزاه السيوطي إلى عثمان بن سعيد الدارمي في التوحيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٥/٤٥١. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى أبي عبيد، وابن المنذر.علقه يحيى بن سلام ٢/٢١٣.أخرجه ابن جرير ١٥/٤٥٢.أخرجه ابن جرير مفرقًا ١٥/٤٤٣، ٤٤٥، ٤٤٦، ٤٤٨، ٤٥٠.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٩، ٤٥١.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٧، ٤٤٨، ٤٥١.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٧، ٤٤٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٧، ٤٤٨، ٤٥١.ذكر محقق المصدر أنه كذا في الأصل، وجاء في أول سورة الشورى: بهن.أخرجه إسحاق البستي في تفسيره ص١٧١.أخرجه أبو الشيخ في العظمة (١٨٨). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣، وابن جرير ١٥/٤٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه الحربي في غريب الحديث ٣/١٠٩٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٤٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرج أوَّله ابن جرير مفرقًا ١٥/٤٤٤، ٤٤٦، ٤٤٨، ٤٥١. وعلَّقه يحيى بن سلام ١/٢١٣. وفي تفسير الثعلبي ٦/٢٠٦، وتفسير البغوي ٥/٢١٨ بلفظ: كافٍ لخلقه، هادٍ لعباده، يده فوق أيديهم، عالم ببريته، صادق في وعده.تفسير الثعلبي ٦/٢٠٥.تفسير مقاتل بن سليمان ٢/٦٢٠.
  19,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذِكۡرُ رَحۡمَتِ رَبِّكَ عَبۡدَهُۥ زَكَرِیَّاۤ ۝٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٣٣<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمَر</span> أنه كان يقرأ: (ذَكَّرَ رَحْمَةَ رَبِّكَ عَبْدُهُ زَكَرِيّا) يُثَقِّلُ{1}، يقول: لما دخل عليها زكريا المحراب وجد عندها فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، فقال: (ذَكَّرَ رَحْمَةَ رَبِّكَ){2}<span class=comment-ref>٤١٢٦</span>. (١٠/٩)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٧) أنّ هذه القراءة على معنى: هذا المتلوّ ذكَّر رحمة ربك عبده.</div></p><p><h3><span class="qpc-hafs">﴿ذِكۡرُ رَحۡمَتِ رَبِّكَ عَبۡدَهُۥ زَكَرِیَّاۤ ۝٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل، وجويبر عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿ذكر رحمت ربك عبده زكريا﴾</span>، قال: ذكره اللهُ برحمةٍ منه حيث دعاه{3}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿ذكر رحمت ربك﴾</span> يعني: نعمة ربك، يا محمد، <span class="qpc-hafs">﴿عبده زكريا﴾</span> ابن بَرْخِيا، وذلك أنّ الله تعالى ذكر عبده زكريا بالرحمة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٣٦<span class="dash">-</span></span> قال: <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿ذِكْرُ رَحْمَتِ رَبِّكَ عَبْدَهُ زَكَرِيّا﴾</span>، يقول: ذِكْرُه لزكريا رحمة من الله له{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذِكۡرُ رَحۡمَتِ رَبِّكَ عَبۡدَهُۥ زَكَرِیَّاۤ ۝٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٣٧<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>كان زكريّا نجّارًا</b>»{6}. (١٠/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- قال: إنّ زكريا بن دان أبا يحيى كان مِن أبناء الأنبياء الذين كانوا يكتبون الوحي ببيت المقدس{7}. (١٠/١٠)</p></p><p></div></p></div>",footnotes:1:يعني: يشدّد الكاف من (ذَكَّرَ). ينظر: مختصر ابن خالويه ص٨٦.عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة، تُروى عن الحسن أيضًا. ينظر: مختصر ابن خالويه ص٨٦، والمحتسب ٢/٣٧.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٣.أخرجه مسلم ٤/١٨٤٧ (٢٣٧٩).أخرجه ابن عساكر ١٩/٤٨-٤٩. وعزاه السيوطي إلى إسحاق بن بشر.
  19,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ نَادَىٰ رَبَّهُۥ نِدَاۤءً خَفِیࣰّا ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مرة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٠<span class="dash">-</span></span> وعن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك وأبي صالح- قال: كان آخر أنبياء بني إسرائيل زكريا بن أدن بن مسلم، مِن ذُرِّيَّة يعقوب، دعا ربَّه سِرًّا؛ <span class="qpc-hafs">﴿قال رب إني وهن العظم مني﴾</span> إلى قوله: <span class="qpc-hafs">﴿خفت الموالي﴾</span> هم العصبة، <span class="qpc-hafs">﴿يرثني﴾</span> ويَرِثُ نُبُوَّتي؛ نُبُوَّة آل يعقوب، <span class="qpc-hafs">﴿فنادته الملائكة﴾</span> [آل عمران:٣٩] وهو جبريل: إنّ الله يبشرك بغلام اسمه يحيى. فلما سمع النداء جاءه الشيطان، فقال: يا زكريا، إنّ الصوت الذي سمعت ليس مِن الله، إنما هو مِن الشيطان يَسْخَرُ بك. فشكَّ، وقال: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span> يقول: مِن أين يكون <span class="qpc-hafs">﴿وقد بلغني الكبر وامرأتي عاقر﴾</span>؟! [آل عمران:٤٠]. قال الله: <span class="qpc-hafs">﴿قد خلقتك من قبل ولم تك شيئا﴾</span>{1}. (١٠/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿إذ نادى ربه نداء خفيا﴾</span>، يعني: دعا ربَّه دُعاءً خَفِيًّا في الليل، لا يُسْمِعُ أحدًا، أو يُسْمِع أذنيه{2}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إذ نادى ربه نداء خفيا﴾</span>، قال: دعاء لا رياء فيه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إذ نادى ربه نداء خفيا﴾</span>، أي: بقلبه سِرًّا، وإنّ الله يُحِبُّ الصوت الخَفِيّ، والقلب النَّقِيَّ{4}. (١٠/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: رغِب زكريا في الولد، فقام فصلّى، ثم دعا ربَّه سِرًّا، فقال: <span class="qpc-hafs">﴿رب إني وهن العظم مني﴾</span> إلى <span class="qpc-hafs">﴿واجعله رب رضيا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ نادى ربه نداء خفيا﴾</span>، يقول: إذ دعا ربَّه دعاء سِرًّا، وإنّما دعا ربَّه ﷿ سِرًّا لِئَلّا يقول الناس: انظروا إلى هذا الشيخ الكبير، يسأل الولد على كِبَرِه!{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿إذ نادى ربه نداء خفيا﴾</span>، قال: لا يريد رياء{7}<span class=comment-ref>٤١٢٧</span>. (١٠/١٠)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٧) على قول ابن جريج بقوله: «<span class="mustanad">ومنه قول النبي</span> ﵇: «<b>خير الذِّكْرِ الخَفِيُّ</b>»».</div></p><p><h3><span class="qpc-hafs">﴿إِذۡ نَادَىٰ رَبَّهُۥ نِدَاۤءً خَفِیࣰّا ۝٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٤٧<span class="dash">-</span></span> عن <span class="name-2">عقبة بن عبد الغافر</span> -من طريق ثابت البُنانِيِّ- قال: دعوة السِّرِّ أفضلُ مِن سبعين في العلانية{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٥٩٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٣.أخرجه يحيى بن سلام ١/٢١٣ مختصرًا، وابن جرير ١٥/٤٥٣ بلفظ: أي: سِرًّا، وإن الله يعلم القلب النقي، ويسمع الصوت الخفي. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٥٤.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه ابن جرير ١٥/٤٥٣. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ٢/٢١٣.
  19,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ إِنِّی وَهَنَ ٱلۡعَظۡمُ مِنِّی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: فقال: <span class="qpc-hafs">﴿رب إني وهن﴾</span>، يعني: ضَعُفَ العظم مِنِّي{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٤٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وهن العظم مني﴾</span>، يقول: ضَعُف{2}. (١٠/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿وهن العظم مني﴾</span>، قال: نُحُولُ العظم{3}. (١٠/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله تعالى: <span class="qpc-hafs">﴿وهن العظم مني﴾</span>، قال: شَكا ذهابَ أضراسِه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ضَعُفَ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قال رب إني وهن العظم مني﴾</span>، أي: ضَعُفَ العظم مِنِّي{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: اشتكى سقوطَ الأضراس{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال رب إني وهن العظم مني﴾</span>، يعني: ضَعُف العظم مِنِّي{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهن العظم مني﴾</span>: رَقَّ{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱشۡتَعَلَ ٱلرَّأۡسُ شَیۡبࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿واشتعل الرأس شيبا﴾</span>، يعني: غَلَبَ البياضُ السوادَ{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واشتعل الرأس شيبا﴾</span>، يعني: بياضًا{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ أَكُنۢ بِدُعَاۤىِٕكَ رَبِّ شَقِیࣰّا ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿ولم أكن بدعائك رب شقيا﴾</span>، أي: لم أدْعُك قطُّ فخيَّبتني فيما مضى، فتخيِّبَني فيما بقي، فكما لم أشْقَ بدعائي فيما مضى؛ فكذلك لا أشقى فيما بقي، عوَّدتني الإجابة من نفسك{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولم أكن بدعائك رب شقيا﴾</span>، قال: قد كنت تُعَوِّدُني الإجابة فيما مضى{13}. (١٠/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: لم يكن دعائي مِمّا يَخِيب عندك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولم أكن بدعائك رب شقيا﴾</span>، يعني: خائِبًا فيما خلا، كُنتَ تستجيب لي، فلا تُخَيِّبْنِي في دعائي إيّاك بالولد{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿ولم أكن بدعائك رب شقيا﴾</span>، يقول: قد كنت تُعَرِّفني الإجابة فيما مضى{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٤<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span>، في قوله: <span class="qpc-hafs">﴿ولم أكن بدعائك رب شقيا﴾</span>، يقول: بل سَعِدت بدعائك، وإن لم تُعْطني{2}. (١٠/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولم أكن بدعائك﴾</span> أي: بدعائي إيّاك <span class="qpc-hafs">﴿رب شقيا﴾</span> يقول: لم أزل بدعائك سعيدًا، لم تَرْدُدْهُ عَلَيَّ{9}<span class=comment-ref>٤١٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٢/١٦٩) أن هذا القول ظاهر، وأنّه يدل عليه أنه قدم ذلك أمام طلبه الولد، وجعله وسيلة إلى ربه، فطلب منه أن يجاريه على عادته التي عوّده من قضاء حوائجه وإجابته إلى ما سأله.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ تيمية</u> (٤/٢٧٢).</div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٥٤. وعزاه السيوطي إلى عبد الرزاق، وابن أبي حاتم.أخرجه أبو نعيم في حلية الأولياء ٣/٢٩١.علَّقه يحيى بن سلام ١/٢١٤.أخرجه ابن جرير ١٥/٤٥٤. وعلقه يحيى بن سلام ٢/٢١٤.تفسير البغوي ٥/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٤.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه عبد الرزاق ٢/٤، وابن عساكر في تاريخ دمشق ١٩/٥٢ من طريق معمر بلفظ: كنت تعرِّفني الإجابة. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علَّقه يحيى بن سلام ٢/٢١٤.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه ابن جرير ١٥/٤٥٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٢١٤.
  19,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنِّی خِفۡتُ ٱلۡمَوَ ٰ⁠لِیَ مِن وَرَاۤءِی وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا فَهَبۡ لِی مِن لَّدُنكَ وَلِیࣰّا ۝٥ یَرِثُنِی وَیَرِثُ مِنۡ ءَالِ یَعۡقُوبَۖ وَٱجۡعَلۡهُ رَبِّ رَضِیࣰّا ۝٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٦٦<span class="dash">-</span></span> عن سعيد بن العاص، قال: أملى عَلَيَّ <span class="name-1">عثمان بن عفان</span> مِن فِيهِ: (وإنِّي خَفَّتِ المَوالِي) يُثَقِّلها، يعني: بنصب الخاء والفاء وكسر التاء. يقول: قَلَّتِ الموالي{1}<span class=comment-ref>٤١٢٩</span>. (١٠/١٢)</p></p><p></div></p><p><div><span class=comment-ref>٤١٢٩</span> <span class="comment-type-1">وجَّهَ</span> <u>ابنُ جرير</u> (١٥/٤٥٧) قراءة عثمان بقوله: «كأنّه وجه تأويل الكلام: وإني ذَهَبَتْ عَصَبَتي ومَن يرثني مِن بني أعمامي».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/٨)، و<span class="comment-type-4">كذا</span> <u>ابن كثير</u> (٩/٢١٥).</p><p>ثم قال <u>ابنُ جرير</u>: «وإذا قرئ ذلك كذلك كانت الياء من <span class="qpc-hafs">﴿الموالي﴾</span> مسكّنة غير متحركة؛ لأنها تكون في موضع رفع بـ(خَفَّتِ)».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٨) أنه على هذه القراءة يكون زكريا طلب وليًّا يقوم بالدِّين.</div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٧<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمَر</span> أنه قرأها: (وإنِّي خَفَّتِ المَوالِي مِن ورَآئِي) مشددة؛ بنصب الخاء وكسر التاء{2}. (١٠/١٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنِّی خِفۡتُ ٱلۡمَوَ ٰ⁠لِیَ مِن وَرَاۤءِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مرة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٦٩<span class="dash">-</span></span> وعن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿خفت الموالي﴾</span>: هم العَصَبَة{3}. (١٠/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي﴾</span>، يعني: الكلالَة{4}. (١٠/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، قال: الوَرَثة، وهم عَصَبَة الرجل{5}. (١٠/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، يعني بالموالي: الكلالة الأولياء أن يرثوه، فوهب الله له يحيى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>: فلم يبق لي وارِث، وخِفْتُ العَصَبَة أن تَرِثَني{7}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، قال: العَصَبَة مِن آل يعقوب، وكان مِن ورائه غلام، وكان زكريا مِن ذُرِّيَّة يعقوب. وفي لفظ: أيوب{8}. (١٠/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق جابر بن نوح، عن إسماعيل- في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، قال: خاف موالي الكلالة{9}. (١٠/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق أبي أسامة، عن إسماعيل- في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، قال: العَصَبَة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، قال: العَصَبَة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>: والموالي: هُنَّ العَصَبَة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٧٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: الورثة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإني خفت الموالي من ورآئي وكانت امرأتي عاقرا﴾</span>، يقول: خِفْتُ الكلالة، وهم العَصَبَة مِن بعد موتي أن يرثوا مالي{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨١<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي﴾</span>، أي: الوَرَثة مِن بعدي، يعني: العَصَبَة الذين يرِثون ماله، فأراد أن يكون مِن صُلْبِه مَن يرِث ماله{15}<span class=comment-ref>٤١٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٨-٩) أن قوله: <span class="qpc-hafs">﴿من ورائي﴾</span> أي: من بعدي في الزمن، و<span class="comment-type-4">بيَّن</span> أنّ أبا عبيدة قال في هذه الآية: أي: مِن بين يدي ومن أمامي، و<span class="comment-type-2">انتقده</span> بقوله: «وهذا قِلَّة تحرير».</div></p><p><h3><span class="qpc-hafs">﴿وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا فَهَبۡ لِی مِن لَّدُنكَ وَلِیࣰّا ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك - في قوله: <span class="qpc-hafs">﴿فهب لي من لدنك وليا﴾</span>، يعني: مِن عندك ولدًا{7}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وليا﴾</span>، يعني: الولد{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فهب لي من لدنك وليا﴾</span>، يعني: من عِندِك ولدًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨٥<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وكانت امرأتي عاقرا﴾</span> أي: لا تلد، <span class="qpc-hafs">﴿فهب لي من لدنك﴾</span> من عندك <span class="qpc-hafs">﴿وليا﴾</span> يعني: الولد{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَرِثُنِی وَیَرِثُ مِنۡ ءَالِ یَعۡقُوبَۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه كان يقرأ: <span class="qpc-hafs">﴿يَرِثُنِي ويَرِثُ مِن آلِ يَعْقُوبَ﴾</span>{20}. (١٠/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨٧<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمَر</span> أنّه قرأها: (يَرِثُنِي وارِثٌ مِّنْ آلِ يَعْقُوبَ){21}. (١٠/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٨٨<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿يَرِثُنِي﴾</span> مثقل مرفوع{22}<span class=comment-ref>٤١٣١</span>. (١٠/١٤)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣١</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿يرثُني ويرثُ﴾</span> برفع الحرفين كليهما، <b>وقرأ آخرون</b>: ‹يَرِثْنِي ويَرِثْ› بجزم الحرفين على الجزاء والشرط.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٥/٤٦٠) أن قراءة الضم بمعنى: فهب الذي يرثني ويرث من آل يعقوب، وعلى أنّ <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span> من صلة الولي. وذكر أن قراءة الجزم بمعنى: فهب لي من لدنك وليًا فإنه يرثني إذا وهبْته لي.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/٩).</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ جرير</u> عمَّن قرءوا بالجزم أنهم قالوا: إنما حسُن ذلك في هذا الموضع؛ لأن <span class="qpc-hafs">﴿يرثني﴾</span> من آية غير التي قبلها. وإنما يحسُن أن يكون مثل هذا صلة، إذا كان غير منقطع عما هو له صلة، كقوله: <span class="qpc-hafs">﴿ردءا يصدقني﴾</span> [القصص:٣٤].</p><p>و<span class="comment-type-3">رجَّح</span> قراءةَ الرفع، و<span class="comment-type-2">انتقد</span> الأخرى <span class="mustanad">مستندًا إلى اللغة، ودلالة العقل</span>، فقال: «لأنّ الولي نكرة، وأنّ زكريا إنما سأل ربه أن يهب له وليًّا يكون بهذه الصفة، كما روي عن رسول الله ﷺ، لا أنّه سأله ولِيًّا، ثم أخبر أنّه إذا وهب له ذلك كانت هذه صفته؛ لأن ذلك لو كان كذلك كان ذلك من زكريا دخولًا في علْم الغيب الذي قد حجبه الله عن خلقه».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/٩).</div></p><p><h3><span class="qpc-hafs">﴿یَرِثُنِی وَیَرِثُ مِنۡ ءَالِ یَعۡقُوبَۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٠٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مرة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٠<span class="dash">-</span></span> وعن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك وأبي صالح- قالوا: كان آخر أنبياء بني إسرائيل زكريا بن أدن بن مسلم، وكان من ذُرِّيَّة يعقوب، قال: يرثني مُلْكِي، ويرث مِن آل يعقوب النبوة{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كان زكريا لا يُولَد له، فسأل ربَّه، فقال: ربِّ، <span class="qpc-hafs">﴿هب لي من لدنك وليا يرثني ويرث من آل يعقوب﴾</span>. قال: يرث مالي، ويرث مِن آل يعقوب النبوة{24}. (١٠/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿يرثني﴾</span> يعني: يرث محرابي، وعصاي، وبُرْنُس{25} القربان، وقلمي الذي أكتب به الوحي، <span class="qpc-hafs">﴿ويرث من آل يعقوب﴾</span> النبوة{7}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>، قال: وكان وِراثته عِلْمًا، وكان زكريا مِن ذُرِّيَّة يعقوب{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٥<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>، قال: يرثني مالي، ويرث من آل يعقوب النبوة{28}. (١٠/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>، قال: السُّنَّة، والعِلْم{4}. (١٠/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>، قال: يرث مِن مالي، ويرث مِن آل يعقوب السُّنَّة والعِلم{30}. (ز) (١٠/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>، قال: نبوته، وعلمه{31}. (١٠/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٠٩٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: معناه: يرثني مالي، ويرث مِن آل يعقوب النبوة والحبورة{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>، قال: يرثني مالي، ويرث من آل يعقوب النبوة{33}. (١٠/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿ويرث من آل يعقوب﴾</span>، قال: النبوة؛ يكون نبيًّا كما كان أبوه{34}. (١٠/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٢<span class="dash">-</span></span> في تفسير <span class="name-2">قتادة</span>: يرث مالَه{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>: فيقول: يرث نبوتي، ونبوة آل يعقوب{4}. (١٠/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿آل يعقوب﴾</span>: هو يعقوب بن ماتان، أخو زكريا، وليس يعقوب أبا يوسف{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يرثني﴾</span> يرِث مالي، <span class="qpc-hafs">﴿ويرث من آل يعقوب﴾</span> ابن ماثان عِلْمَهم، ورياستَهم في الأحبار، وكان يعقوب وعمران أبو مريم أخوين ابنا ماثان، ومريم ابنة عمران بن ماثان{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٦<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>: يرثني المالَ، ويرث من آل يعقوب النبوةَ{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٧<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span>: ملكَهم، وسلطانَهم، كانت امرأة زكرياء مِن ولد يعقوب، ليس يعني يعقوب الأكبر، يعقوب دونه{15}<span class=comment-ref>٤١٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٢</span> أفادت الآثارُ الاختلاف في المراد بهذا الميراث. و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٩/٢١٥-٢١٧) أنها وراثة النبوة <span class="mustanad">مستندًا إلى السنة، والدلالات العقلية</span> بما مفاده الآتي: ١- أنّ النبي أعظم منزلة مِن أن يشفق على ماله بأن يأنف مِن وراثة عصباته له، ويسأل أن يكون له ولد، فيحوز ميراثه دونه. ٢- أنه لم يُذكر أنه كان ذا مال، بل كان نجّارًا يأكل مِن كسب يديه، ومثل هذا لا يجمع مالًا، ولا سيما الأنبياء ﵈، فإنهم كانوا أزهد شيء في الدنيا. ٣- قول النبي ﷺ: «<b>نحن معشر الأنبياء لا نورث</b>». وهذا يوجب حمل قوله: <span class="qpc-hafs">﴿فهب لي من لدنك وليا * يرثني﴾</span> على ميراث النبوة؛ ولهذا قال: <span class="qpc-hafs">﴿ويرث من آل يعقوب﴾</span>، كما قال تعالى: <span class="qpc-hafs">﴿وورث سليمان داود﴾</span> [النمل:١٦] أي: في النبوة؛ إذ لو كان في المال لما خصَّه مِن بين إخوته بذلك، ولما كان في الإخبار بذلك كبير فائدة، إذ مِن المعلوم المستقر في جميع الشرائع والملل أنّ الولد يرِث أباه، فلولا أنها وراثة خاصة لما أخبر بها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> أنّ ما رُوِي عن النبي ﷺ أنه قال: «<b>رحم الله أخي زكريا، ما كان عليه من ورثة ماله ...</b>». بأن هذه مرسلات، لا تُعارِض الصحاح.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٨) أنّ أكثر المفسرين على القول بأن زكريا أراد وراثة المال، و<span class="comment-type-4">بيَّن</span> أن قول النبي ﷺ: «<b>إنا معشر الأنبياء لا نورث</b>» يحتمل أن لا يريد به العموم، ثم <span class="comment-type-3">رجَّح</span> القول بأنها وراثة النبوة <span class="mustanad">مستندًا إلى دلالة العقل، والنظائر</span>، فقال: «والأظهر الأليق بزكريا ﵇ أن يريد: وراثة العلم والدين؛ فتكون الوراثة مستعارة، ألا ترى أنه إنما طلب ولِيًّا، ولم يخصص ولدًا، فبلّغه الله أمله على أكمل الوجوه».</p><p>ونقل حكاية عن الزجاج أنّ فرقة قالت: إنما كان مواليه مهملين للدّين، فخاف بموته أن يضيع الدين، فطلب وليًّا يقوم بالدين بعده. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وفيه أنه لا يجوز أن يسأل زكريا مَن يرث ماله؛ إذ الأنبياء لا تورث، <span class="mustanad">وهذا يؤيده قول النبي</span> ﷺ: «<b>إنا معشر الأنبياء لا نورث، ما تركنا فهو صدقة</b>». ويوهنه ذكر العاقر». أي: في الآية. و<span class="comment-type-4">نقل</span> (٦/٩) عن فرقة أنها قالت: بل طلب الولد ثم شرط أن تكون الإجابة في أن يعيش حتى يرثه، تحفظًا مِن أن تقع الإجابة في الولد ثم يخترم فلا يتحصل منه الغرض المقصود.</div></p><p><h3><span class="qpc-hafs">﴿وَٱجۡعَلۡهُ رَبِّ رَضِیࣰّا ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿واجعله رب رضيا﴾</span>: يعني: مَرْضِيًّا عندك، زاكيًا بالعمل{7}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واجعله رب رضيا﴾</span>، يعني: صالِحًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿واجعله رب رضيا﴾</span>: فأوحى الله إليه{43}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱجۡعَلۡهُ رَبِّ رَضِیࣰّا ۝٦﴾</span> - آثار متعلقة بالآيتين</h3></p><p><div></p><p><p><span class="item-no">٤٦١١١<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>رحِم الله أخي زكريا، ماكان عليه مِن ورثة ماله حين يقول</b>: <span class="qpc-hafs">﴿فهب لي من لدنك وليا، يرثني ويرث من آل يعقوب﴾</span>!»{44}. (١١/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٢<span class="dash">-</span></span> قال قتادة: ذُكِر لنا: أنّ نبي الله ﷺ كان إذا قرأ هذه الآية، وأتى على <span class="qpc-hafs">﴿يرثني ويرث من آل يعقوب﴾</span> قال: «<b>رحم الله زكريا، ما كان عليه مِن ورَثَته!</b>»{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٣<span class="dash">-</span></span> عن محمد بن كعب القرظي، قال: قال داود ﵇: يا ربِّ، هب لي ابنًا. فوُلِد له ابنٌ خرج عليه، فبعث إليه داود جيشًا، فقال: إن أخذتموه سليمًا فابعثوا إلَيَّ رجلًا أعرف السرور -أو قال: البِشْرَ- في وجهه، وإن قتلتموه فابعثوا إلَيَّ رجلًا أعرف الشَّرَّ في وجهه. فقتلوه، فبعثوا إليه رجلًا أسود، فلمّا رآه علِم أنّه قُتِل، فقال: ربِّ، سألتُ أن تَهَب لي ابنًا، فخرج عَلَيَّ. فقال: إنك لم تستثن. قال محمد بن كعب:لم يقل كما قال زكريا: <span class="qpc-hafs">﴿واجعله رب رضيا﴾</span>{4}. (١٠/١٤)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٦٢-٦٣ (١٤٥)، وإسحاق البستي في تفسيره ص١٧٣ (رسالة جامعية ت: عوض العمري). وعزاه السيوطي إلى أبي عبيد، وابن المنذر، وابن أبي حاتم.</p><p>وهي قراءة شاذة، تروى أيضًا عن محمد بن علي، وعلي بن الحسن، ويحيى بن يعمر، وغيرهم. انظر: مختصر ابن خالويه ص٨٦، والمحتسب ٢/٣٧.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.أخرجه الحاكم ٢/٥٩٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٥٥.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٥/٤٥٦ بلفظ: العَصَبَة. دون الكلام الذي بعدها. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٥٦، وإسحاق البستي في تفسيره ص١٧٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٥٦.أخرجه عبد الرزاق ٢/٣، وابن جرير ١٥/٤٥٦.أخرجه ابن جرير ١٥/٤٥٧. وعلقه يحيى بن سلام ١/٢١٤.تفسير الثعلبي ٦/٢٠٦، وتفسير البغوي ٥/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٤.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٤.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٤.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة، ما عدا أبا عمرو، والكسائي، فإنّهما قرآ: ‹يَرِثْنِي ويَرِثْ› بجزم الثاء فيهما. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.</p><p>و(يَرِثُنِي وارِثٌ) قراءة شاذة، تروى عن الحسن، والجحدري، وقتادة، وغيرهم. انظر: مختصر ابن خالويه ص٨٦، والمحتسب ٢/٣٨.عزاه السيوطي إلى عبد بن حميد.أخرجه الحاكم ٢/٥٨٧.عزاه السيوطي إلى الفريابي.البُرْنُس: كل ثوب رأْسه منه مُلْتَزِقٌ به. لسان العرب (برنس).أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٥/٤٥٨.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص١٧٤ (رسالة جامعية ت: عوض العمري). وعزا السيوطي إلى ابن أبي حاتم آخره.أخرجه عبد الرزاق ٢/٣، وابن جرير ١٥/٤٥٩. وعلَّقه يحيى بن سلام ٢/٢١٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ٦/٢٠٦، وتفسير البغوي ٥/٢١٨.</p><p>والحبورة: هي رئاسة المذبح وبيت القربان. كما في تفسير الثعلبي ٧/٢٦٤.أخرجه ابن جرير ١٥/٤٥٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٥٨ بلفظ: يكون نبيًّا كما كانت آباؤه أنبياء. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٠٦.تفسير مقاتل بن سليمان ٢/٦٢٠.أخرجه الثوري في تفسيره ص١٨١.تفسير يحيى بن سلام ١/٢١٤.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٠.تفسير يحيى بن سلام ١/٢١٥.أخرجه يحيى بن سلام ١/٢١٤، وابن جرير ١٥/٤٥٩ واللفظ له.</p><p>وهو مرسل كما ذكر ابن كثير في التعليق السابق.أخرجه ابن جرير ١٥/٤٥٩-٤٦٠ مرسلًا.عزاه السيوطي إلى ابن أبي حاتم.
  19,6,""
  19,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰزَكَرِیَّاۤ إِنَّا نُبَشِّرُكَ بِغُلَـٰمٍ ٱسۡمُهُۥ یَحۡیَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١١٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك-: فاستجاب الله له، كان قد دخل في السِّنِّ هو وامرأتُه، فبينا هو قائم يصلي في المحراب حيث يذبح القربان إذا هو برجل عليه البياض حياله، وهو جبريل، فقال: يا زكريّا، إنّ الله يبشرك بغلام اسمه يحيى. هو اسم مِن اسماء الله، اشتق مِن: يا حيُّ، سمّاه الله فوق عرشه{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: لَمّا دعا زكريا ربَّه أن يهب له غلامًا هبط جبريل ﵇، فبشَّره بيحيى{2}. (١٠/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يا زكريا إنا نبشرك بغلام اسمه يحيى﴾</span> عبدًا أحياه الله بالإيمان{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: نادى جبرائيل زكريا: إنّ الله يبشرك بغلام اسمه يحيى لم نجعل له مِن قبل سميًّا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فاستجاب الله ﷿ لزكريا في الولد، فأتاه جبريل وهو يُصَلِّي، فقال: <span class="qpc-hafs">﴿يازكريا إنا نبشرك بغلام اسمه يحيى﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَمۡ نَجۡعَل لَّهُۥ مِن قَبۡلُ سَمِیࣰّا ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال:لم يُسَمَّ أحَدٌ يحيى قبله{6}. (١٠/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال:لم تلِدِ العواقِرُ مثلَه ولدًا{7}. (١٠/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>: لم يجعل لزكريا من قبل يحيى ولدًا. نظيرها: <span class="qpc-hafs">﴿هل تعلم له سميا﴾</span> [مريم:٦٥]، يعني: هل تعلم له ولدًا. ولم يكن لزكريا قبله ولد، ولم يكن قبل يحيى أحد يُسَمّى: يحيى. قال: وكان اسمه: حي، فلما وهب الله لسارة إسحق، فكان اسمها: يسارة -ويسارة مِن النساء التي لا تلد، وسارة من النساء: الطالقة الرَّحِم التي تلد-، فسماها الله: سارة، وحوَّل الياء مِن سارة إلى حي، فسماه: يحيى{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال: شِبْهًا{9}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٣<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، مثله{10}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال: مثلًا{11}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحَكَم- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال: شِبْهًا{12}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال: لم يُسَمَّ أحدٌ يحيى قبله{13}. (١٠/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثله{14}. (١٠/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- إن الله يبشرك بغلام اسمه يحيى <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>: لم يُسَمَّ أحد قبله: يحيى{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٢٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، مثله{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حَجّاج-، مثله{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span> لم يكن أحدٌ مِن الناس فيما خلا يُسَمّى: يحيى، وإنما سمّاه: يحيى؛ لأنه أحياه مِن بين شيخ كبير وعجوز عاقر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٢<span class="dash">-</span></span> عن <span class="name-3">عبدالرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال: لم يُسَمَّ أحدٌ قبلَه بهذا الاسم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، قال: ليس ليحيى مِثْلٌ في ولد آدم{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٤<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿سميا﴾</span>، قال: يُسامِيه، نَظِيرٌ له في ذلك{21}<span class=comment-ref>٤١٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٣</span> اختُلِف في قوله: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>؛ <b>فقال قوم</b>: معناه:لم تلد مثله عاقر قط. <b>وقال آخرون</b>: لم نجعل له من قبله مِثْلًا. <b>وقال غيرهم</b>: معنى ذلك: أنّه لم يسم باسمه أحد قبله.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٤٦٣) <span class="mustanad">مستندًا إلى اللغة</span> القولَ الأخير الذي قاله ابن عباس، وقتادة، وابن جريج، والسدي، وعبد الرحمن بن زيد بن أسلم، فقال: «والسّمي: فعيل، صُرِف من»مفعول«إليه».</p><p>و<span class="comment-type-1">وجَّهَ</span> <u>ابنُ عطية</u> (٦/١٠) القول الثاني الذي قاله مجاهد، فقال: «وهذا كأنه من المساماة، والسمو». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للواقع</span>، فقال: «وفي هذا بُعْد؛ لأنه لا يُفضل على إبراهيم وموسى ﵉، إلاّ أن يفضل في السؤود والحصر».</div></p><p><h3><span class="qpc-hafs">﴿لَمۡ نَجۡعَل لَّهُۥ مِن قَبۡلُ سَمِیࣰّا ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦١٣٥<span class="dash">-</span></span> عن يحيى بن خلاد الزرقي: أنّه لَمّا وُلِد أُتِي به النبي ﷺ، فحنَّكه، وقال: «<b>لأسمينه اسمًا لم يُسَمَّ بعد يحيى بن زكريا»</b>. فسماه: يحيى{22}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٦<span class="dash">-</span></span> عن يحيى بن عبدالرحمن بن حاطب، قال: قال عمر لصهيب: ما وجدت عليك في الإسلام إلا ثلاثًا: تكنيت: أبا يحيى، وقال الله تعالى: <span class="qpc-hafs">﴿لم نجعل له من قبل سميا﴾</span>، وإنّك لم تمسك شيئًا إلا أنفقته، وتُدعى إلى النمر بن قاسط، وأنت من المهاجرين الأولين، وممن أنعم الله عليه. قال: أما قولك إني تكنيت: أبا يحيى؛ فإنّ رسول الله ﷺ كنّاني: أبا يحيى. وأما قولك: إني لا أمسك شيئًا إلا أنفقته؛ فإن الله تعالى قال: <span class="qpc-hafs">﴿وما أنفقتم من شيء فهو يخلفه﴾</span> [سبأ:٣٩]. وأما قولك: إني أدعى إلى النمر؛ فإن العرب كانت يسبي بعضهم بعضًا، فسَبَتْنِي طائفة من العرب، فباعوني بسواد الكوفة، فأخذت بلسانهم، ولو كنت مِن روثة ما ادَّعَيْتُ إلا إليها{23}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٢١٥، وابن جرير ١٥/٤٦٠.أخرجه ابن جرير ١٥/٤٦٤.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه الفريابي -كما في التغليق ٤/٣٣-، وابن أبي شيبة ١١/٥٦٠، وابن أبي حاتم -كما في فتح الباري ٦/٤٦٨-، والحاكم ٢/٣٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٦١. وعلَّقه يحيى بن سلام ٢/٢١٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٦٢، وإسحاق البستي في تفسيره ص١٧٥-١٧٦من طريق سفيان بن عيينة عن رجل. وعزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٦٢، وإسحاق البستي في تفسيره ص١٧٥-١٧٦.أخرجه يحيى بن سلام ٢/٢١٥، وعبد الرزاق ٢/٤، وابن جرير ١٥/٤٦٢ من طريق سعيد. وعزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد.عزاه السيوطي إلى أحمد في الزهد.أخرجه ابن جرير ١٥/٤٦٣.تفسير الثعلبي ٦/٢٠٧، وتفسير البغوي ٥/٢١٩.أخرجه ابن جرير ١٥/٤٦٣.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٦٣.أخرجه إسحاق البستي في تفسيره ص١٧٥.تفسير يحيى بن سلام ١/٢١٥.أخرجه البخاري في تاريخه ٨/٢٦٩-٢٧٠ في ترجمة يحيى بن خلاد (٢٩٦٣).أخرجه أبو نعيم في حلية الأولياء ١/١٥٣-١٥٤.
  19,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ أَنَّىٰ یَكُونُ لِی غُلَـٰمࣱ وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿قال رب أنى يكون لي غلام وكانت امرأتي عاقرا﴾</span>: خاف أنها لا تلِد{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: لَمّا دعا زكريّا ربَّه أن يهب له غلامًا؛ هبط جبريل ﵇، فبشره بيحيى، فقال زكريا عندها: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span>. وأخبر بكِبَر سنِّه، وعِلَّةِ زوجته، فأخذ جبريلُ عودًا يابسًا، فجعله بين كفي زكريا، فقال: أدرِجْهُ بين كفَّيْك. ففعل، فإذا في رأسه ورقتين يقطُرُ منهما الماء، فقال جبريل: إنّ الذي أخرج هذا الورق من هذا العود قادر أن يُخرج مِن صلبك ومن امرأتك العاقر غلامًا{2}. (١٠/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٣٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: أراد زكريا أن يَعْلَمَ كيف ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: نادى جبرائيل زكريا: إنّ الله يبشرك بغلام اسمه يحيى لم نجعل له من قبل سميًا. فلمّا سمع النداء جاءه الشيطان، فقال: يا زكريا، إنّ الصوت الذي سمعت ليس مِن الله، إنما هو من الشيطان يَسْخَرُ بك، ولو كان مِن الله أوحاه إليك كما يوحي إليك غيره من الأمر. فشكَّ مكانه، وقال: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span> يقول: مِن أين يكون <span class="qpc-hafs">﴿وقد بلغني الكبر وامرأتي عاقر﴾</span>؟! [آل عمران:٤٠]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلما بَشَّر مَيِّتَيْنِ بالولد <span class="qpc-hafs">﴿قال رب أنى يكون لي غلام﴾</span> يعني: من أين يكون لي غلام <span class="qpc-hafs">﴿وكانت امرأتي عاقرا﴾</span>؟! أيليشفع{5} لا تلد{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿قال رب أنى يكون لي غلام﴾</span> يقول: مِن أين يكون لي غلام <span class="qpc-hafs">﴿وكانت امرأتي عاقرا﴾</span> لا تلد؟!{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَدۡ بَلَغۡتُ مِنَ ٱلۡكِبَرِ عِتِیࣰّا ۝٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦١٤٣<span class="dash">-</span></span> في قراءة <span class="name-1">عبد الله بن مسعود</span>: (وقَدْ بَلَغْتُ مِنَ الكِبَرِ عُسِيًّا){8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٤<span class="dash">-</span></span> عن ابن كثير، قال: سمعت مجاهدًا يقول: في قراءة <span class="name-1">أُبَيّ بن كعب</span>: (مِنَ الكِبَرِ عُسِيًّا){9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: لا أدري كيف كان رسول الله ﷺ يقرأ هذا الحرف‹عُتِيًّا›{10} أو (عُسِيًّا)؟{11}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٦<span class="dash">-</span></span> عن <span class="name-2">يحيى بن وثاب</span> أنه قرأها: <span class="qpc-hafs">﴿عِتِيًّا﴾</span>، و<span class="qpc-hafs">﴿صِلِيًّا﴾</span> بكسر العين والصاد{12}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٧<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: (عُتِيًّا) برفع العين{12}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٤٨<span class="dash">-</span></span> عن عبد الله بن عقيل أنّه قرأ: (وقَدْ بَلَغْتُ مِنَ الكِبَرِ عُسِيًّا) بالسين ورفع العين{2}. (١٠/١٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَدۡ بَلَغۡتُ مِنَ ٱلۡكِبَرِ عِتِیࣰّا ۝٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦١٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>، قال: يعني بالعِتيِّ: الكِبَر{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٠<span class="dash">-</span></span> عن ميمون بن مهران، أن نافع بن الأزرق سأل <span class="name-1">عبد الله بن عباس</span>، فقال: أخبِرني عن قول الله: <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>، ما العِتِيُّ؟ قال: البؤس مِن الكِبَر. قال الشاعر:</p><p>إنما يعذر الوليد ولا يُـ ـعذر مَن كان في الزمان عِتِيّا{16}. (١٠/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>، قال: نُحُول العظم{17}. (١٠/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٢<span class="dash">-</span></span> قال سفيان بن عيينة: فسَّر <span class="name-2">مجاهد</span> <span class="qpc-hafs">﴿من الكبر عتيا﴾</span>، قال: عُسيًّا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>، قال: هو الكِبَر{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٤<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وقَدْ بَلَغْتُ مِنَ الكِبَرِ عِتِيًّا﴾</span>، قال: لبثت زمانًا في الكبر{2}. (١٠/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق أبي عثمان الصنعاني- <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>: قال هذه المقالة، وهو ابن ستين، أو خمس وستين{21}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وقَدْ بَلَغْتُ مِنَ الكِبَرِ عِتِيًّا﴾</span>، قال: سِنًّا. قال: وبلغني: أنّه كان ابن بضع وسبعين سنة{22}. (١٠/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: يريد: نُحُول العظم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وقَدْ بَلَغْتُ مِنَ الكِبَرِ عِتِيًّا﴾</span>، يقول: هرمًا{2}. (١٠/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٥٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: العتي: اليبس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقد بلغت﴾</span> أنا <span class="qpc-hafs">﴿من الكبر عتيا﴾</span>، يعني: بؤسًا، وكان زكريا يومئذ ابن خمس وسبعين سنة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦١<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عبد الرزاق- قال: بلغني: أنّ زكريا كان ابن سبعين سنة{27}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الله بن المبارك</span>، <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>، قال: سِتِّين سنة{2}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وقد بلغت من الكبر عتيا﴾</span>، قال: العِتِيُّ: الذي عَتا عن الولد فيما يرى في نفسه، لا ولادة فيه{29}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٤<span class="dash">-</span></span> قال يحيى بن سلّام: وقال بعضهم: يُبْسُ جلدي على عظمي{7}<span class=comment-ref>٤١٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٤</span> أفادت الآثارُ الاختلافَ في معنى قوله: <span class="qpc-hafs">﴿عتيا﴾</span> على قولين: <b>أحدهما</b>: نُحُول العظم. <b>والآخر</b>: الكبَر.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٩/٢١٨) بعد ذكرهما بقوله: «والظاهر أنه أخص من الكِبَر».</div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٥.أخرجه ابن جرير ١٥/٤٦٤.أيليشفع: اسم امرأة زكريا، كما ذكر مقاتل بن سليمان في تفسير سورة آل عمران.تفسير مقاتل بن سليمان ٢/٦٢١.تفسير يحيى بن سلام ١/٢١٥.علقه يحيى بن سلام ١/٢١٥.</p><p>(عُسِيًّا) بالسين قراءة شاذة، تروى أيضًا عن ابن عباس، ومجاهد. انظر: مختصر ابن خالويه ص٨٦.أخرجه إسحاق البستي في تفسيره ص١٧٦.كذا ضبطت في مطبوعة تفسير ابن جرير، وقد نسب محققوها هذا الضبط إلى إحدى النسخ الخطية، وإلى أصول مسند أحمد.أخرجه أحمد ٤/١١٢، ١٧٢ (٢٢٤٦، ٢٣٣٢)، وأبو داود (٨٠٩) -وليس فيه محل الشاهد-، وابن جرير ١٥/٤٦٥، والحاكم ٢/٢٤٤. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن مردويه.</p><p>صححه الحاكم، قال محققو المسند: «إسناده صحيح على شرط البخاري».</p><p>و‹عُتِيًّا›، و‹صُلِيًّا› بضم العين، والصاد قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، وحفصًا؛ فإنهم قرؤوا بكسر العين والصاد فيهما. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٦٥.أخرجه الحاكم ٢/٣٧٣. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء بلفظ «اليؤس» بدل«البؤس».أخرجه ابن جرير ١٥/٤٦٥. وعلَّقه يحيى بن سلام ١/ ٢١٥ بلفظ: قحول، وكذا أخرجه ابن عساكر في تاريخ دمشق ١٩/٥١، وينظر: مختصره لابن منظور ٩/٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص١٧٦.أخرجه ابن جرير ١٥/٤٦٦، وإسحاق البستي في تفسيره ص١٧٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الرامَهُرْمُزِيُّ في الأمثال ص٦٤.أخرجه عبد الرزاق ٢/٤، وابن جرير ١٥/٤٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٢٠٧، وتفسير البغوي ٥/٢٢٠.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٥.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٥٤. وعزاه السيوطي إلى عبد الرزاق، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٦٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٢١٥.
  19,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ كَذَ ٰ⁠لِكَ قَالَ رَبُّكَ هُوَ عَلَیَّ هَیِّنࣱ وَقَدۡ خَلَقۡتُكَ مِن قَبۡلُ وَلَمۡ تَكُ شَیۡـࣰٔا ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿قال كذلك قال ربك﴾</span> يا زكريا: <span class="qpc-hafs">﴿هو علي هين وقد خلقتك من قبل﴾</span> أن أهبَ لكَ يحيى <span class="qpc-hafs">﴿ولم تك شيئا﴾</span>، وكذلك أقدر على أن أخلق مِن الكبير والعاقِر{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> له جبريل ﵇: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا، <span class="qpc-hafs">﴿قال ربك﴾</span> إنه ليكون لك غلام، <span class="qpc-hafs">﴿هو علي هين وقد خلقتك من قبل﴾</span> أن تسألني الولد، <span class="qpc-hafs">﴿ولم تك شيئا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال له الملك: <span class="qpc-hafs">﴿قال كذلك قال ربك هو علي هين﴾</span> الله يقوله، وهو كلام موصول أخبَرَ به الملَك عن الله: أعطيك هذا الولد، <span class="qpc-hafs">﴿وقد خلقتك من قبل ولم تك شيئا﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢١.تفسير يحيى بن سلام ١/٢١٥.
  19,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ ٱجۡعَل لِّیۤ ءَایَةࣰۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- قال: وذلك أنّ إبليس أتاه، فقال: يا زكريا، دعاؤك كان خفِيًّا، فأُجِبت بصوت رفيع، وبُشِّرت بصوت عالٍ، ذلك صوتٌ مِن الشيطان، ليس مِن جبريل، ولا من ربك. <span class="qpc-hafs">﴿قال رب اجعل لي آية﴾</span> حتى أعرف أنّ هذه البُشرى مِنكَ{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٦٩<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالِيِّ</span> في قوله: <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>، قال: أعطِنِي آيةً أنّك قد استجبت لي. فقال: <span class="qpc-hafs">﴿آيتك أن لا تكلم الناس ثلاث ليال سويا﴾</span>{2}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿قال رب﴾</span> فإن كان هذا الصوت منك فـ<span class="qpc-hafs">﴿اجعل لي آية قال﴾</span> اللهُ: <span class="qpc-hafs">﴿آيتك﴾</span> لذلك <span class="qpc-hafs">﴿ألا تكلم الناس ثلاث ليال سويا﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> زكريا: <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>، يعني: علَمًا للحَبَل، فسأل الآية بعد مشافهة جبريل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قال رب اجعل لي آية﴾</span>، قال: <span class="qpc-hafs">﴿قال رب اجعل لي آيةً﴾</span> أن هذا منك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> زكريا <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ ءَایَتُكَ أَلَّا تُكَلِّمَ ٱلنَّاسَ ثَلَـٰثَ لَیَالࣲ سَوِیࣰّا ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أن لا تكلم الناس ثلاث ليال سويا﴾</span>، قال: اعتقل لسانُه مِن غير مرض{7}. (١٠/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ثلاث ليال سويا﴾</span>، قال: من غير خرس{8}. (١٠/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، مثله{9}. (١٠/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق قتادة-، مثله{10}. (١٠/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿قال آيتك ألا تكلم الناس ثلاث ليال سويا﴾</span>، قال: ثلاث ليال مُتتابِعات{11}<span class=comment-ref>٤١٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٥</span> اختلف في معنى <span class="qpc-hafs">﴿سويا﴾</span>؛ <b>فقال قوم</b>: صحيح مِن غير عِلَّة. <b>وقال آخرون</b>: ذاك عائد على الليالي، أي: متتابعات.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٩/٢١٩ بتصرف) <span class="mustanad">مستندًا إلى القرآن</span> القولَ الأول دون الثاني الذي قاله ابن عباس من طريق العوفي، فقال: «والقول الأول أصح، كما قال تعالى في آل عمران [٤١]: <span class="qpc-hafs">﴿قال رب اجعل لي آية قال آيتك ألا تكلم الناس ثلاثة أيام إلا رمزا واذكر ربك كثيرا وسبح بالعشي والإبكار﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٤٦١٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿قال آيتك أن لا تكلم الناس ثلاث ليال سويًا﴾</span>، يعني: صحيحًا مِن غير خرس. فحاضت زوجتُه، فلمّا طهُرَت طاف عليها، فاستحملت، فأصبح لا يتكلم، فكان إذا أراد التسبيحَ والصلاةَ أطلق اللهُ لسانه، فإذا أراد أن يكلم الناس اعْتُقِل لسانُه فلا يستطيع أن يتكلم، وكانت عقوبة له؛ لأنّه بُشِّر بالولد، فقال: أنى يكون لي ولد؟! فخاف أن يكون الصوت مِن غير الله{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٠<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السلمي</span>، قال: اعتُقِل لسانه مِن غير مرض{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨١<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالِيِّ</span>، في قوله: <span class="qpc-hafs">﴿آيتك أن لا تكلم الناس ثلاث ليال سويا﴾</span>، قال: ختم على لسانه وهو صحيح سويٌّ ليس به من مرض، فلم يتكلم ثلاثة أيام{2}. (١٠/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جريج- في قوله: <span class="qpc-hafs">﴿ثلاث ليال سويا﴾</span>، قال: صحيحًا، لا يمنعك الكلامَ مرضٌ{15}. (١٠/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتَّهم- قال: أخذ الله بلسانه مِن غير سوء، فجعل لا يطيق الكلام، وإنما كلامه لقومه بالإشارة، حتى مضت الثلاثة الأيام التي جعلها الله آية لِمِصْداقِ ما وعده مِن هِبَتِه له{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: إنما عُوقِب لأنّه سأل الآية بعدما شافهته الملائكة مشافهة، وبشَّرته بيحيى، فأخذ عليه بلسانه، فجعل لا يُفِيض الكلام، أي: لا يُبِينُ الكلامَ إلا ما أوْمَأَ إيماء، وهو قوله: <span class="qpc-hafs">﴿ثلاثة أيام إلا رمزا﴾</span> [آل عمران:٤١]: إيماء{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قال آيتك ألا تكلم الناس ثلاث ليال سويا﴾</span>، يقول: مِن غير خرس، إلا رمزًا، فاعْتُقِل لسانُه ثلاثة أيام وثلاث ليال{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> جبريل ﵇: <span class="qpc-hafs">﴿آيتك﴾</span> إذا جامعتَها على طُهْرٍ فحَبلت فإنّك تصبح تلك الليلة لا تستنكر مِن نفسك خرسًا، ولا مرضًا، ولكن لا تستطيع الكلام، <span class="qpc-hafs">﴿ألا تكلم الناس ثلاث ليال سويا﴾</span> أنت فيهن سَوِيٌّ صحيح. فأخذ بلسانه عقوبة حين سأل الآية بعد مشافهة جبريل ﵇، ولم يحبس الله ﷿ لسانه عن ذِكره، ولا عن الصلاة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في الآية، قال: حبس لسانه، فكان لا يستطيع أن يُكَلِّم أحدًا، وهو في ذلك يُسَبِّح، ويقرأ التوراة، فإذا أراد كلام الناس لم يستطع أن يكلمهم{20}. (١٠/١٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه الحاكم ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٦٧.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٦٧.تفسير يحيى بن سلام ١/٢١٦.أخرجه ابن جرير ١٥/٤٦٨.أخرجه ابن جرير ١٥/٤٦٨، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٤، وابن جرير ١٥/٤٦٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٧٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم -كما في الفتح ٦/٤٦٨-.أخرجه الحاكم ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٦٨، كما أخرجه يحيى بن سلام ١/٢١٦ من طريق عاصم بن حكيم، وإسحاق البستي في تفسيره ص١٧٧ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٦٩.أخرجه يحيى بن سلام ١/٢١٦ واللفظ له، وعبد الرزاق ٢/٤ مختصرًا، وابن جرير ١٥/٤٦٨ وآخره بلفظ: ما كان يطيق الكلام، إلا ما أومأ إيماء. دون ذكر آية آل عمران.أخرجه ابن جرير ١٥/٤٦٩. وعلَّقه يحيى بن سلام ١/٢١٦ بلفظ: يعني: صحيحًا من غير خرس ولا داء.تفسير مقاتل بن سليمان ٢/٦٢١.أخرجه ابن جرير ١٥/٤٦٩ وفيه زيادة: ويقرأ الإنجيل!. وعزاه السيوطي إلى ابن أبي حاتم.
  19,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَخَرَجَ عَلَىٰ قَوۡمِهِۦ مِنَ ٱلۡمِحۡرَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فخرج على قومه من المحراب﴾</span>: يعني: مِن مُصَلّاه الذي كان يُصَلِّي فيه{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٨٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فخرج على قومه من المحراب﴾</span>: مِن المسجد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- <span class="qpc-hafs">﴿فخرج على قومه من المحراب﴾</span>، قال: أشْرَفَ على قومه من المحراب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فخرج﴾</span> زكريا <span class="qpc-hafs">﴿على قومه﴾</span> بني إسرائيل <span class="qpc-hafs">﴿من المحراب﴾</span> يعني: مِن المسجد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فخرج على قومه من المحراب﴾</span>، قال: المحراب: مُصَلّاه{5}. (١٠/١٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡحَىٰۤ إِلَیۡهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦١٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: كَتَب لهم كتابًا{6}. (١٠/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>: بكتاب كتبه بيده{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٥<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالِيِّ</span>، <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: كتب لهم{8}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: أوْمَأ إليهم{9}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فَأَوْحى إلَيْهِمْ أنْ سَبِّحُوا﴾</span>، قال: كتب لهم في الأرض{10}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: فأشار زكريا{11}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦١٩٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: الوحي: الإشارة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٠<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span> -من طريق ابن أبي ليلى- <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: كتب لهم{13}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر- <span class="qpc-hafs">﴿فأوحى إليهم أن سبحوا﴾</span>، قال: أشار إليهم إشارة{14}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، قال: أوْمى إليهم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فكتب لهم في كتاب: <span class="qpc-hafs">﴿أن سبحوا بكرة وعشيا﴾</span>. وذلك قوله: <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>{16}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، يقول: كتب كتابًا بيده، وهو الوحي إليهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأوحى إليهم أن سبحوا بكرة وعشيا﴾</span>، قال: ما ندري كتابًا كتبه لهم، أو إشارة أشارها! -والله أعلم-. قال: أمرهم أن سبِّحوا بكرة وعشيًّا، وهو لا يكلمهم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>، أي: أوْمَأَ إليهم{19}<span class=comment-ref>٤١٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٦</span> اختُلِف في معنى: <span class="qpc-hafs">﴿فأوحى إليهم﴾</span>؛ <b>فقال قوم</b>: أمرهم. <b>وقال آخرون</b>: معنى أوحى: كتب. <b>وقال غيرهم</b>: أشار إليهم بيده.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٥/٤٧١) أن المعنى: أشار إليهم، وأن هذه الإشارة قد تكون باليد، أو بالكتابة، وبغير ذلك مما يُفهم به مراده.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/١٢) على القول الثاني والثالث بقوله: «وكِلا القولين وحْيٌ».</div></p><p><h3><span class="qpc-hafs">﴿أَن سَبِّحُوا۟ بُكۡرَةࣰ وَعَشِیࣰّا ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فأوحى إليهم أن سبحوا﴾</span>، قال: أمَرَهم بالصلاة بكرة وعشيًّا{20}. (١٠/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أن سبحوا بكرة عشيا﴾</span>: يعني: صَلُّوا صلاةَ الغداة والعصر{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٠٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِي</span> في قوله: <span class="qpc-hafs">﴿أن سبحوا بكرة وعشيا﴾</span>. قال: البكرة صلاة الفجر، وعشيًا صلاة العصر{6}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أن سبحوا بكرة وعشيا﴾</span>، أي: أن صلُّوا لله بالغداة والعَشِيِّ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي مَعْشَرٍ- في قول الله: <span class="qpc-hafs">﴿فأوحى إليهم أن سبحوا بكرة وعشيا﴾</span>، قال: أشار إليهم أن صلُّوا بكرة وعشيًّا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فأوحى إليهم أن سبحوا﴾</span>، قال: صلُّوا{25}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن سبحوا بكرة وعشيا﴾</span>: أن صلوا بالغداة والعَشِيِّ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿أن سبحوا بكرة وعشيا﴾</span>: يعني به: الصلاة؛ صلاة الغداة، وصلاة العصر{19}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٦.أخرجه ابن جرير ١٥/٤٧٠.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٠. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٧١. وعلَّقه يحيى بن سلام ١/٢١٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٧١.أخرجه عبد الرزاق في تفسيره ٢/٥، وفي مصنفه ٦/٤١٣ (١١٤٣٥)، وابن جرير ١٥/٤٧٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١١٨ (٢٣٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٧٢.أخرجه ابن جرير ١٥/٤٧٢. وعلق يحيى بن سلام ١/٢١٦ نحوه. وعزا السيوطي إلى ابن أبي حاتم نحوه.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٢.تفسير يحيى بن سلام ١/٢١٦.أخرجه الحاكم ٢/٣٧٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٢١٦.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١١٨ (٢٣٣).أخرجه عبد الرزاق ٢/٤، وابن جرير ١٥/٤٧٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٦٢٢.تفسير يحيى بن سلام ١/٢١٦.