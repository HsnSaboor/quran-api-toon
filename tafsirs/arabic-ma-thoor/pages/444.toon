quran[16]{c,v,t}:
  36,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ أَصۡحَـٰبَ ٱلۡجَنَّةِ ٱلۡیَوۡمَ فِی شُغُلࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق شقيق بن سلمة- في قوله: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</span>، قال: شَغَلهم افتضاضُ العذارى{1}. (١٢/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿فِي شُغُلٍ فاكِهُونَ﴾</span>، قال: في افتضاض الأبكار{2}. (١٢/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{3}. (١٢/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فِي شُغُلٍ فاكِهُونَ﴾</span>، قال: ضَرْب الأوتار{4}. (١٢/٣٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق وائل بن داود- في قوله: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</span>، قال: في افتضاض العذارى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٣<span class="dash">-</span></span> عن إياس بن عامر، قال: سمعتُ رجلًا بإيلياء قديمًا يقول: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</span>، إنّ الرجل مِن أهل الجنة في الخيمة مع نسائه، حتى تأتيه نساءٌ فيَقُلْنَ له: اخرج إلى أهلك. فيقول: ما أنتُنَّ لي بأهل. فيقُلْن: بلى، نحن مِمّا أخفى الله لك، فقد زُوِّجتنا. فيشتغل بِهِنَّ عن أهله الأولين، فذلك قول الله: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</span>. قال: فذكرت ذلك <span class="name-2">لتُبَيْع</span> برُودِس{6}، فقال: ذلك أبو فلان، فعرفه، صَدَق كما قال{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ﴾</span>، قال: مِن النِّعمة{8}. (١٢/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي سهل- في قوله: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</span>، قال: شَغلهم النعيمُ عمّا فيه أهل النار مِن العذاب{9}. (١٢/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل بن أبي خالد</span> -من طريق أبان بن تغلب- <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ﴾</span> الآية، قال: في شُغل عمّا يلقى أهلُ النار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٨<span class="dash">-</span></span> و<span class="name-2">الثُّمالِي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٠٩<span class="dash">-</span></span> و<span class="name-3">المسيب [بن شريك]</span>: <span class="qpc-hafs">﴿فِي شُغُلٍ فاكِهُونَ﴾</span>، يعني: في شُغل عن أهل النار وعمّا هم فيه، لا يهمهم أمرُهم، ولا يذكرونهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ﴾</span> في الآخرة <span class="qpc-hafs">﴿فِي شُغُلٍ﴾</span> يعني: شُغِلوا بالنعيم؛ بافتضاض العذارى عن ذِكر أهل النار، فلا يذكرونهم، ولا يهتمون بهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١١<span class="dash">-</span></span> قال <span class="name-3">وكيع بن الجراح</span>: <span class="qpc-hafs">﴿فِي شُغُلٍ فاكِهُونَ﴾</span>، يعني: في السماع{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: فأخبر بمصير أهل الإيمان وأهل الكفر، فقال: <span class="qpc-hafs">﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ﴾</span> يعني: في الآخرة <span class="qpc-hafs">﴿فِي شُغُلٍ فاكِهُونَ﴾</span>{14}<span class=comment-ref>٥٤٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤١</span> اختلف السلف في معنى الشغل الذي وصف الله -جلَّ ثناؤه- أصحاب الجنة أنهم فيه يوم القيامة على أقوال: <b>الأول</b>: أنّه افتضاض العذارى. <b>الثاني</b>: أنّه النعمة. <b>الثالث</b>: أنهم في شغل عما فيه أهل النار. <b>الرابع</b>: أنه السماع.</p><p>ولم يذكر <u>ابنُ جرير</u> (١٩/٤٦١-٤٦٢) غير الأقوال الثلاثة الأولى، ثم <span class="comment-type-3">رجّح</span> جميعها <span class="mustanad">للعموم</span>، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال كما قال الله -جل ثناؤه-: <span class="qpc-hafs">﴿إن أصحاب الجنة﴾</span> وهم أهلها <span class="qpc-hafs">﴿في شغل فاكهون﴾</span> بنِعَم بأنهم في شغل، وذلك الشغل الذي هم فيه نعمة، وافتضاض أبكار، ولهو، ولذة، وشغل عما يلقى أهل النار».</p><p>وكذا <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٧/٢٥٧) <span class="mustanad">العموم</span>، فقال: «وقال مجاهد: معناه: نعيم قد شغلهم. وهذا هو القول الصحيح، وتعيين شيء دون شيء لا قياس له».</div></p><p><h3><span class="qpc-hafs">﴿فَـٰكِهُونَ ۝٥٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٨١٣<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (فِي شُغُلٍ فَكِهِينَ){15}<span class=comment-ref>٥٤٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٢</span> <span class="comment-type-3">رجح</span> <u>ابنُ جرير</u> (١٩/٤٦٣) <span class="mustanad">مستندًا إلى شهرة القراءة</span> في قوله: <span class="qpc-hafs">﴿فاكهون﴾</span> قراءة من قرأ ذلك بالألف، فقال: «والصواب من القراءة في ذلك عندي قراءة من قرأه بالألف؛ لأن ذلك هو القراءة المعروفة».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٧/٢٥٨) عليها، فقال: «وقرأ جمهور الناس: <span class="qpc-hafs">﴿فاكهون﴾</span>، معناه: أصحاب فاكهة، كما يقال: تامر، ولابِن، وشاحم، ولاحِم».</div></p><p><h3><span class="qpc-hafs">﴿فَـٰكِهُونَ ۝٥٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فاكِهُونَ﴾</span>، قال: فرِحون{16}. (١٢/٣٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فاكِهُونَ﴾</span>، قال: مُعجبون{17}. (١٢/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٦<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿فاكِهُونَ﴾</span> مُعجبون بما هم فيه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿فاكِهُونَ﴾</span> مسرورون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨١٩<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فِي شُغُلٍ فاكِهُونَ﴾</span>، قالا: أي: مُعجبون{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿فاكِهُونَ﴾</span> ناعمون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿فاكِهُونَ﴾</span>: ‹فَكِهُونَ› يعني: معجبين بما هم فيه شغل النعيم والكرامة ... ومن قرأ <span class="qpc-hafs">﴿فاكهون﴾</span> يعني: ناعمين في ظلالِ كبار القصور ...{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٦٠، وابن أبي الدنيا (٢٧٦)، وعبد الله بن أحمد في زوائد الزهد -كما في حادي الأرواح ص١٨٢-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن أبي الدنيا في صفة الجنة (٢٧٧)، وابن جرير ١٩/٤٦٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم، وابن مردويه. كما أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٢٢ (٣٣) من طريق الأوزاعي.|3:أخرجه يحيى بن سلّام ٢/٨١٤ عن قتادة، وإسحاق البستي ص١٩٢ عن عكرمة من طريق أبي عمرو الكوفي. وعزاه السيوطي إلى عبد بن حميد.|4:عزاه السيوطي إلى ابن أبي حاتم، وذكر عن أبي حاتم أنه قال: «هذا خطأٌ مِن السمع، إنما هو: افتضاض الأبكار». وقال ابن كثير في تفسيره ٦/٥٦٩: «وقال أبو حاتم: لعله غلط من المستمع، وإنما هو: افتضاض الأبكار».|5:أخرجه سفيان الثوري (٢٥٠)، وابن جرير ١٩/٤٦٠.|6:رُودِس: جزيرة ببلاد الروم مقابل الإسكندرية على ليلة منها في البحر. معجم البلدان ٣/٧٨.|7:أخرجه عبد الله بن وهب في الجامع في تفسير القرآن ٢/١٤٤ (٢٩٣).|8:تفسير مجاهد (٥٦١)، وأخرجه الفريابي -كما في التغليق ٤/٢٩١-، وابن جرير ١٩/٤٦١ بلفظ: في نعمة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:أخرجه ابن جرير ١٩/٤٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:أخرجه ابن جرير ١٩/٤٦١.|11:تفسير الثعلبي ٨/١٣١، وفي تفسير البغوي ٧/٢٢ عن الكلبي فقط.|12:تفسير مقاتل بن سليمان ٣/٥٨٢.|13:تفسير الثعلبي ٨/١٣١.|14:تفسير يحيى بن سلّام ٢/٨١٤.|15:أخرجه ابن أبي داود في المصاحف (/٣٣١.</p><p>و(فَكِهِينَ) قراءة شاذة، تروى أيضًا عن طلحة، والأعمش، وجماعة. انظر: مختصر ابن خالويه ص١٢٧، والمحرر الوجيز ٤/٤٥٩.|16:أخرجه ابن جرير ١٩/٤٦٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|17:تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٦٣ بلفظ: عجبون، والفريابي -كما في التغليق ٤/٢٩١-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|18:تفسير الثعلبي ٨/١٣١، وتفسير البغوي ٧/٢٢.|19:علقه يحيى بن سلّام ٢/٨١٤.|20:أخرجه عبد الرزاق ٢/١٤٥.|21:تفسير الثعلبي ٨/١٣١.|22:تفسير مقاتل بن سليمان ٣/٥٨٢.
  36,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُمۡ وَأَزۡوَ ٰ⁠جُهُمۡ فِی ظِلَـٰلٍ عَلَى ٱلۡأَرَاۤىِٕكِ مُتَّكِـُٔونَ ۝٥٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٢٢<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (فِي ظُلَٰلٍ عَلى الأَرَآئِكِ مُتَّكِئِينَ){1}<span class=comment-ref>٥٤٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٣</span> ذكر <u>ابنُ جرير</u> (١٩/٤٦٤) هذه القراءة، و<span class="comment-type-4">علّق</span> عليها، فقال: «قرأه بعضهم: ‹فِي ظُلَلٍ› بمعنى: جمع ظلة، كما تجمع الحلة: حُلَلًا».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u> (٧/٢٥٨)، فقال: «وقرأ حمزة والكسائي ‹فِي ظُلَلٍ› وهي جمع ظلة، وهي قراءة طلحة، وعبد الله، وأبي عبد الرحمن، وهذه عبارة عن الملابس والمراتب من الحجال والستور ونحوها مِن الأشياء التي تظل، وهي زينة».</p><p>وذكر <u>ابن جرير</u> قراءة من قرأ ذلك <span class="qpc-hafs">﴿ظلال﴾</span>، ثم <span class="comment-type-4">علّق</span> عليها، فقال: «وقرأه آخرون: <span class="qpc-hafs">﴿في ظلال﴾</span>؛ وإذا قرئ ذلك كذلك كان له وجهان: <b>أحدهما</b>: أن يكون مرادًا به جمع الظل الذي هو بمعنى الكن، فيكون معنى الكلمة حينئذ: هم وأزواجهم في كن لا يضحون لشمس كما يضحي لها أهل الدنيا؛ لأنه لا شمس فيها. و<b>الآخر</b>: أن يكون مرادًا به: جمع ظلة، فيكون وجه جمعها كذلك نظير جمعهم الخلة في الكثرة: الخلال، والقلة: القلال».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u>، فقال: «وقرأ جمهور القراء <span class="qpc-hafs">﴿في ظلال﴾</span>، وهو جمع: ظل؛ إذ الجنة لا شمس فيها، وإنما هواؤها سجسج، كوقت الإسفار قبل طلوع الشمس، ويحتمل أن يكون جمع: ظلة، قال أبو علي: كبرمة وبرام، وغير ذلك، وقال منذر بن سعيد: <span class="qpc-hafs">﴿ظِلالٍ﴾</span> جمع ظلة بكسر الظاء. وهي لغة في ظلة».</div></p><p><h3><span class="qpc-hafs">﴿هُمۡ وَأَزۡوَ ٰ⁠جُهُمۡ فِی ظِلَـٰلٍ عَلَى ٱلۡأَرَاۤىِٕكِ مُتَّكِـُٔونَ ۝٥٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</span>، قال: هي السُّرر في الحِجال{2}{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الأوزاعي- قال: والأرائك: السرر في جوْف الحجال، عليها الفرش منضودة في السماء فرسخًا{4}<span class=comment-ref>٥٤٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٤</span> ذكر <u>ابنُ كثير</u> (١١/٣٦٩) قول ابن عباس وغيره، ثم <span class="comment-type-4">علّق</span>، فقال: «قال ابن عباس، ومجاهد وعكرمة، ومحمد بن كعب، والحسن، وقتادة، والسُدِّيّ، وخصيف: <span class="qpc-hafs">﴿الأرائك﴾</span> هي السرر تحت الحجال. قلت: نظيره في الدنيا هذه التخوت تحت البشاخين».</div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَزْواجُهُم﴾</span>، قال: حلائلهم{5}. (١٢/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حصين- في قول الله: <span class="qpc-hafs">﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</span>، قال: الأرائك: السرر عليها الحِجال{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق محمد- قال: <span class="qpc-hafs">﴿عَلى الأَرائِكِ﴾</span> السُّرر في الحجال{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- وسأله رجل عن الأرائك. فقال: هي الحِجال. وأهل اليمن يقولون: أريكة فلان= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٢٩<span class="dash">-</span></span> وسمعت <span class="name-2">عكرمة</span> وسُئِل عنها، فقال: هي الحجال على السُّرر{7}<span class=comment-ref>٥٤٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٥</span> قال <u>ابنُ عطية</u> (٧/٢٥٨): «و<span class="qpc-hafs">﴿الأَرائِكِ﴾</span>: السرر المفروشة، قال <b>بعض الناس</b>: من شروطها أن تكون عليها، حجلة وإلا فليست بأريكة، وبذلك قيدها ابن عباس ومجاهد والحسن وعكرمة. وقال <b>بعضهم</b>: الأريكة: السرير؛ كان عليه حجلة أو لم يكن».</div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</span>، قال: هي الحجال فيها السُّرر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٣١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</span>، قال: على السُّرر في الحِجال{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُمْ وأَزْواجُهُمْ﴾</span> يعني: الحور العين حلائلهم <span class="qpc-hafs">﴿فِي ظِلالٍ﴾</span> ومَن قرأ <span class="qpc-hafs">﴿فاكهون﴾</span> يعني: ناعمين في ظلالِ كبار القصور، <span class="qpc-hafs">﴿عَلى الأَرائِكِ﴾</span> على السُّرر عليها الحجال <span class="qpc-hafs">﴿مُتَّكِؤُنَ﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿على الأرائك متكئون﴾</span>، قال: هُنَّ سُرُر في الحِجال{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿هُمْ وأَزْواجُهُمْ فِي ظِلالٍ﴾</span> في حِجال، <span class="qpc-hafs">﴿عَلى الأَرائِكِ﴾</span> على السرر في الحِجال <span class="qpc-hafs">﴿مُتَّكِئُونَ﴾</span>{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣١.</p><p>و(مُتَّكِئِينَ) بالياء قراءة شاذة. انظر: مختصر ابن خالويه ص١٢٧.|2:الحِجال: جمع الحَجَلَةُ -بالتَّحْريك-: بَيْت كالقُبَّة يُسْتَر بالثِّياب وتكون له أزرارٌ كبارٌ. النهاية (حجل).|3:أخرجه ابن جرير ١٩/٤٦٥.|4:أخرجه عبد الله بن وهب في الجامع- تفسير القرآن ٢/٢٢ (٣٣).|5:تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٦٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:أخرجه سفيان الثوري (٢٥١) بنحوه، وابن جرير ١٩/٤٦٥.|7:أخرجه ابن جرير ١٩/٤٦٦.|8:أخرجه ابن جرير ١٩/٤٦٦.|9:أخرجه عبد الرزاق ٢/١٤٥، وابن جرير ١٩/٤٦٦.|10:أخرجه عبد الرزاق ٢/١٤٥.|11:تفسير مقاتل بن سليمان ٣/٥٨٢.|12:أخرجه إسحاق البستي ص١٩٣.|13:تفسير يحيى بن سلّام ٢/٨١٤.
  36,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَهُمۡ فِیهَا فَـٰكِهَةࣱ وَلَهُم مَّا یَدَّعُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٣٥<span class="dash">-</span></span> عن <span class="name-1">أبي أمامة</span>، قال: إنّ الرجل مِن أهل الجنة لَيشتهي الشراب من شراب الجنة، فيجيء إليه الإبريقُ، فيقع في يده، فيشرب، فيعود إلى مكانه{1}. (١٢/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَهُمْ فِيها﴾</span> في الجنة <span class="qpc-hafs">﴿فاكِهَةٌ ولَهُمْ ما يَدَّعُونَ﴾</span> يتمنّون ما شاءوا من الخير{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿لَهُمْ فِيها فاكِهَةٌ ولَهُمْ ما يَدَّعُونَ﴾</span> ما يشتهون، يكون في فِي أحدهم الطعامُ، فيخطر على باله طعامٌ آخر، فيتحول ذلك الطعام في فِيهِ، ويأكل مِن ناحيةٍ مِن البُسْرة بُسرًا، ثم يأكل مِن ناحية أخرى عنبًا، إلى عشرة ألوان أو ما شاء الله مِن ذلك، ويَصُفُّ الطيرُ بين يديه، فإذا اشتهى الطيرَ منها اضطرب، ثم صار بين يديه نَضيجًا؛ نصفه شواء، ونصفه قديرًا{3}، وكل ما اشتهت أنفسهم وجدوه، كقوله: <span class="qpc-hafs">﴿وفِيها ما تَشْتَهِيهِ الأَنْفُسُ﴾</span> [الزخرف:٧١]{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في صفة الجنة (١٣٥).|2:تفسير مقاتل بن سليمان ٣/٥٨٢.|3:كذا في المطبوع، ولعله: قديدًا، بالدال.|4:تفسير يحيى بن سلّام ٢/٨١٥.
  36,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَلَـٰمࣱ قَوۡلࣰا مِّن رَّبࣲّ رَّحِیمࣲ ۝٥٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٣٨<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (سَلامًا قَوْلًا){1}<span class=comment-ref>٥٤٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٦</span> ذكر <u>ابنُ جرير</u> (١٩/٤٦٦-٤٦٧) هذه القراءة، و<span class="comment-type-4">علّق</span> عليها، فقال: «وقد ذكر أنها في قراءة عبد الله: (سلامًا قولًا) على أن الخبر متناهٍ عند قوله: <span class="qpc-hafs">﴿ولهم ما يدعون﴾</span>، ثم نصب (سلامًا) على التوكيد، بمعنى: مسلمًا قولًا».</p><p>و<span class="comment-type-4">أورد</span> في رفع <span class="qpc-hafs">﴿سلام﴾</span> في قراءة من قرأها كذلك وجهين، فقال: «في رفع <span class="qpc-hafs">﴿سلام﴾</span> وجهان في قول بعض نحويي الكوفة: <b>أحدهما</b>: أن يكون خبرًا لـ<span class="qpc-hafs">﴿ما يدعون﴾</span>، فيكون معنى الكلام: ولهم ما يدعون مسلم لهم خالص. وإذا وجه معنى الكلام إلى ذلك كان القول حينئذ منصوبًا توكيدًا خارجًا مِن السلام، كأنه قيل: ولهم فيها ما يدعون مسلم خالص حقًّا، كأنه قيل: قاله قولًا. و<b>الوجه الثاني</b>: أن يكون قوله: <span class="qpc-hafs">﴿سلام﴾</span> مرفوعًا على المدح، بمعنى: هو سلامٌ لهم قولًا مِن الله». ثم قال: «والذي هو أولى بالصواب على ما جاء به الخبر عن محمد بن كعب القرظي أن يكون <span class="qpc-hafs">﴿سلام﴾</span> خبرًا لقوله: <span class="qpc-hafs">﴿ولهم ما يدعون﴾</span>؛ فيكون معنى ذلك: ولهم فيها ما يدعون، وذلك هو سلام من الله عليهم، بمعنى: تسليم من الله، ويكون <span class="qpc-hafs">﴿سلام﴾</span> ترجمة <span class="qpc-hafs">﴿ما يدعون﴾</span>، ويكون القول خارجًا من قوله: سلام». واستدل <u>ابنُ جرير</u> على هذا <span class="mustanad">بقول عمر بن عبد العزيز</span> وقول محمد بن كعب الآتيين، ثم قال (١٩/٤٦٩) <span class="comment-type-4">معلّقًا</span> عليه: «فهذا القول الذي قاله محمد بن كعب ينبئ عن أن <span class="qpc-hafs">﴿سلام﴾</span> بيان عن قوله: <span class="qpc-hafs">﴿ما يدعون﴾</span>، وأن القول خارج من السلام».</div></p><p><div></p><p><p><span class="item-no">٦٤٨٣٩<span class="dash">-</span></span> عن هارون، قال: في قراءة <span class="name-1">أُبَيّ [بن كعب]</span>: (سَلامًا قَوْلًا){2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سَلَـٰمࣱ قَوۡلࣰا مِّن رَّبࣲّ رَّحِیمࣲ ۝٥٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٤٠<span class="dash">-</span></span> عن جابر، قال: قال رسول الله ﷺ: «<b>بينا أهل الجنة في نعيمهم إذ سطع لهم نورٌ، فرفعوا رؤوسهم، فإذا الربُّ قد أشرف عليهم مِن فوقهم، فقال: السلام عليكم، يا أهل الجنة. وذلك قول الله:</b> <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span>. <b>قال: فينظر إليهم، وينظرون إليه، فلا يلتفتوا إلى شيءٍ مِن النعيم ما داموا ينظرون إليه حتى يحتجب عنهم، ويبقى نورُه وبركتُه عليهم في ديارهم»</b>{3}. (١٢/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span>، قال: فإنّ الله هو يُسَلِّم عليهم{4}<span class=comment-ref>٥٤٤٧</span>. (١٢/٣٦٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٧</span> ذكر <u>ابنُ كثير</u> (١١/٣٧٠) قول ابن عباس، و<span class="comment-type-4">علّق</span> عليه، فقال: «وهذا الذي قاله ابن عباس <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿تحيتهم يوم يلقونه سلام﴾</span> [الأحزاب:٤٤]».</div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٢<span class="dash">-</span></span> عن <span class="name-1">البراء [بن عازب]</span> -من طريق محمد بن مالك- في قوله: <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span>، قال: يسلِّم عليهم عند الموت{5}. (١٢/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٣<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> -من طريق محمد بن كعب القرظي- قال: إذا فرغ اللهُ مِن أهل الجنة والنارِ أقبل اللهُ في ظُلَلٍ مِن الغمام والملائكة، قال: فيُسَلِّم على أهل الجنة في أول درجة، فيردون ﵇.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٤<span class="dash">-</span></span> قال <span class="name-2">القرظي</span>: وهذا في القرآن: <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span>. فيقول: سلوني. فيقولون: ماذا نسألك، أيْ ربِّ. قال: بلى، سلوني. قالوا: نسألك -أي رب- رضاك. قال: رضائي أُدخلكم دار كرامتي. قالوا: يا رب، وما الذي نسألك؟! فوَعِزَّتك وجلالِك وارتفاعِ مكانك، لو قسَّمت علينا رِزْقَ الثقلين لأطعمناهم ولأسقيناهم ولألبسناهم ولأخْدَمْناهُم{6}، لا ينقصنا من ذلك شيئًا. قال: إنّ لدي مزيدًا. قال: فيفعل الله ذلك بهم في درجتهم، حتى يستوي في مجلسه. قال: ثم تأتيهم التُّحَفُ مِن الله، تحمله إليهم الملائكة. قال: وليس في الآخرة ليل ولا نصف نهار، إنما هو بكرة وعشيًّا، وذلك في القرآن، في آل فرعون: <span class="qpc-hafs">﴿النّارُ يُعْرَضُونَ عَلَيْها غُدُوًّا وعَشِيًّا﴾</span> [غافر:٤٦]، وكذلك قال لأهل الجنة: <span class="qpc-hafs">﴿ولَهُمْ رِزْقُهُمْ فِيها بُكْرَةً وعَشِيًّا﴾</span> [مريم:٦٢]، قال: وقال: واللهِ الذي لا إله إلا هو، لو أنّ امرأة من حور العين أطلعت سِوارها لأطفأ نورُ سوارِها الشمسَ والقمر، فكيف المُسوَّرة؟! وإنْ خلق الله شيئًا يلبسه إلا عليه مثلما عليها مِن ثياب أو حلي{7}. (١٢/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span>، وذلك أنّ الملائكة تدخل على أهل الجنة مِن كل باب، يقولون: سلام عليكم -يا أهل الجنة- من ربكم الرحيم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span> يأتي الملَك مِن عند الله إلى أحدهم، فلا يدخل عليه حتى يستأذن عليه؛ يطلب الإذن مِن البوّاب الأول، فيذكره للبوّاب الثاني، ثم كذلك حتى ينتهي إلى البوّاب الذي يليه، فيقول البوّاب له: مَلَك على الباب يستأذن. فيقول: ائذن له. فيدخل بثلاثة أشياء: بالسلام مِن الله، والتحفة، والهدية، وبأنّ الله عنه راض، وهو قوله: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span> [الإنسان:٢٠]{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣١، وابن جرير ١٤/٢١٤.</p><p>وهي قراءة شاذة، تروى أيضا عن أُبي، وعيسى الثقفي. انظر: المحتسب ٢/٢١٤.|2:أخرجه إسحاق البستي ص١٩٣.|3:أخرجه ابن ماجه ١/١٢٧ (١٨٤)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٨٣-.|4:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|5:أخرجه ابن جرير ١٤/٢١٤.|6:أي: لَجَعَلْنا لهم من يَخْدُمُهم. اللسان (خدم).|7:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٣-٨٤ (١٨٧)، وابن جرير ١٩/٤٦٧-٤٦٩. وأورد السيوطي قول القرظي بنحوه، وعزاه إلى ابن جرير، وأبي نصر السجزي في الإبانة، وآخره: فيفعل ذلك بأهل كل درجة حتى ينتهي، ثم يأتيهم التحف من الله تحمله إليهم الملائكة.|8:تفسير مقاتل بن سليمان ٣/٥٨٢.|9:تفسير يحيى بن سلّام ٢/٨١٥-٨١٦.
  36,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱمۡتَـٰزُوا۟ ٱلۡیَوۡمَ أَیُّهَا ٱلۡمُجۡرِمُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٤٧<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>إذا كان يوم القيامة أمر الله جهنم، فيخرج منها عُنُق ساطِع مُظلِم، ثم يقول</b>: <span class="qpc-hafs">﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ أنْ لا تَعْبُدُوا الشَّيْطانَ إنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ * وأَنِ اعْبُدُونِي هَذا صِراطٌ مُسْتَقِيمٌ * ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا أفَلَمْ تَكُونُوا تَعْقِلُونَ * هَذِهِ جَهَنَّمُ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</span>، <b>وامتازوا اليوم أيُّها المجرمون</b>. <b>فيتميز الناس ويجثون</b>، <b>وهي قوله:</b> <span class="qpc-hafs">﴿وتَرى كُلَّ أُمَّةٍ جاثِيَةً كُلُّ أُمَّةٍ تُدْعى إلى كِتابِها اليَوْمَ تُجْزَوْنَ ما كُنْتُمْ تَعْمَلُونَ﴾</span> [الجاثية:٢٨]»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span> تفرَّقوا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٤٩<span class="dash">-</span></span> قال <span class="name-2">أبو العالية</span>: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span> تَمَيَّزوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: إذا كان يومُ القيامة جمعَ اللهُ الناسَ على تلٍّ رفيع، ثم نادى منادٍ: امتازوا اليوم، أيها المجرمون{4}. (١٢/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span>، قال: عُزِلوا عن كل خير{5}. (١٢/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥٢<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span> كونوا على حِدَة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وامْتازُوا﴾</span> واعتزلوا <span class="qpc-hafs">﴿اليَوْمَ﴾</span> في الآخرة <span class="qpc-hafs">﴿أيُّها المُجْرِمُونَ﴾</span> وذلك حين اختلط الإنسُ والجنُّ والدوابُّ؛ دوابُّ البرِ والبحرِ والطيرِ، فاقتصَّ بعضُهم مِن بعض، ثم قيل لهم: كونوا ترابًا. فكانوا ترابًا، فبقي الإنس والجن خليطين، إذ بعث الله ﷿ إليهم مناديًا: أن امتازوا اليوم. يقول: اعتزلوا اليوم -أيها المجرمون- مِن الصالحين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span> المشركون، أي: ليمتازوا عن الجنة إلى النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥٥<span class="dash">-</span></span> عن <span class="name-3">رَوّاد بن الجراح</span>: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span>، قال: إذا كان يوم القيامة نادى منادٍ: أن ميِّزوا المسلمين مِن المجرمين، إلا صاحب الأهواء. يعني: يُترك صاحب الهوى مع المجرمين{4}. (١٢/٣٦٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱمۡتَـٰزُوا۟ ٱلۡیَوۡمَ أَیُّهَا ٱلۡمُجۡرِمُونَ ۝٥٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٥٦<span class="dash">-</span></span> عن <span class="name-2">ميمون</span> أنه قرأ هذه الآية: <span class="qpc-hafs">﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</span> فَرَقَّ وبكى، وقال: ما سمع الناس قط. بنعتٍ أشد منه{4}. (١٢/٣٦٥)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق بن راهويه في مسنده ١/٨٤ (١٠)، والبيهقي في البعث والنشور ١/٣٣٦-٣٤٤ (٦٠٩) كلاهما مطولًا، وابن جرير ١٩/٤٧٠ واللفظ له، من طريق محمد بن يزيد بن أبي زياد، عن رجل من الأنصار، عن محمد بن كعب القرظي، عن رجل من الأنصار، عن أبي هريرة به.</p><p>إسناده ضعيف؛ لجهالة محمد بن يزيد بن أبي زياد، والرجلين الأنصاريين.|2:تفسير الثعلبي ٨/١٣٣.|3:تفسير الثعلبي ٨/١٣٣، وتفسير البغوي ٧/٢٣.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه يحيى بن سلّام ٢/٨١٥، وابن جرير ١٩/٤٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|6:تفسير الثعلبي ٨/١٣٣، وتفسير البغوي ٧/٢٣.|7:تفسير مقاتل بن سليمان ٣/٥٨٢-٥٨٣.|8:تفسير يحيى بن سلّام ٢/٨١٦.|9:عزاه السيوطي إلى ابن أبي حاتم.|10:عزاه السيوطي إلى ابن أبي حاتم.
  36,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ أَعۡهَدۡ إِلَیۡكُمۡ یَـٰبَنِیۤ ءَادَمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ألَمْ أعْهَدْ إلَيْكُمْ﴾</span>، يقول: ألم أنهكم؟!{1}. (١٢/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَمْ أعْهَدْ إلَيْكُمْ﴾</span> الذين أُمروا بالاعتزال <span class="qpc-hafs">﴿يا بَنِي آدَمَ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن لَّا تَعۡبُدُوا۟ ٱلشَّیۡطَـٰنَۖ إِنَّهُۥ لَكُمۡ عَدُوࣱّ مُّبِینࣱ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٥٩<span class="dash">-</span></span> عن عطاء بن دينار الهذلي: أنّ عبد الملك بن مروان كتب إلى <span class="name-2">سعيد بن جبير</span> يسأله عن هذه المسائل، فأجابه فيها: ... قال: وتسأل عن العبادة: والعبادة هي الطاعة، وذلك أنّه مَن أطاع الله فيما أمره به وفيما نهاه عنه فقد أتمَّ عبادة الله، ومَن أطاع الشيطان في دينه وعمله فقد عبد الشيطان، ألم تر أنّ الله قال للذين فرَّطوا: <span class="qpc-hafs">﴿ألم أعهد إليكم يا بني آدم أن لا تعبدوا الشيطان﴾</span>. وإنما كانت عبادتُهم الشيطانَ أنهم أطاعوه في دينهم، فمِنهم مَن أمرهم فاتخذوا أوثانًا أو شمسًا أو قمرًا أو بشرًا أو ملكًا يسجدون له مِن دون الله، ولم يظهر الشيطانُ لأحد منهم فيتعبد له، أو يسجد له، ولكنهم أطاعوه فاتخذوها آلهة مِن دون الله، فلمّا جُمعوا جميعًا يوم القيامة في النار قال لهم الشيطان: <span class="qpc-hafs">﴿إني كفرت بما أشركتمون من قبل﴾</span> [إبراهيم:٢٢]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٠<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span>، في قوله: <span class="qpc-hafs">﴿أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</span>، قال: إنّما عبادتُه طاعتُه{4}. (١٢/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، قال: <span class="qpc-hafs">﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</span>: يعني: ألا تطيعوا الشيطان في الشرك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ﴾</span> في الدنيا <span class="qpc-hafs">﴿أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</span> يعني: إبليس وحده، ولا تطيعوه في الشرك؛ <span class="qpc-hafs">﴿إنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ﴾</span> بيِّن العداوة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ﴾</span> أنّهم عبدوا الأوثان بما وسوس إليهم الشيطان، فأمرهم بعبادتهم، فإنما عبدوا الشيطان{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٥٨٣.|3:أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/٣٤٦-٣٤٧.|4:عزاه السيوطي إلى ابن المنذر.|5:علقه يحيى بن سلام ٢/٨١٦.|6:تفسير مقاتل بن سليمان ٣/٥٨٣.|7:تفسير يحيى بن سلام ٢/٨١٦.
  36,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنِ ٱعۡبُدُونِیۚ هَـٰذَا صِرَ ٰ⁠طࣱ مُّسۡتَقِیمࣱ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنِ اعْبُدُونِي﴾</span> يقول: وحِّدوني، <span class="qpc-hafs">﴿هَذا﴾</span> التوحيد <span class="qpc-hafs">﴿هَذا صِراطٌ مُسْتَقِيمٌ﴾</span> دين الإسلام؛ لأنّ غير دين الإسلام ليس بمستقيم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وأَنِ اعْبُدُونِي﴾</span> لا تشركوا بي شيئًا، <span class="qpc-hafs">﴿هَذا صِراطٌ مُسْتَقِيمٌ﴾</span> دين مستقيم، والصراط: الطريق، مستقيم على الجنة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٣.|2:تفسير يحيى بن سلام ٢/٨١٦.
  36,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَضَلَّ مِنكُمۡ جِبِلࣰّا كَثِیرًاۖ أَفَلَمۡ تَكُونُوا۟ تَعۡقِلُونَ ۝٦٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٦٦<span class="dash">-</span></span> عن أبي هريرة: أنّ النبي ﷺ قرأ: (ولَقَدْ أضَلَّ مِنكُمْ جِبِلًا) مخففة{1}. (١٢/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٧<span class="dash">-</span></span> عن هارون، عن <span class="name-2">الحسن</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٨<span class="dash">-</span></span> و<span class="name-3">ابن أبي اسحاق</span>: <span class="qpc-hafs">﴿ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا﴾</span> مثقلة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٦٩<span class="dash">-</span></span> و<span class="name-2">الأعرج</span>: (جِبْلًا) وهكذا أبلغني أهل الكوفة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧٠<span class="dash">-</span></span> و<span class="name-2">أبي عمرو</span> ‹جُبْلًا› خفيفة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧١<span class="dash">-</span></span> عن هذيل، أنه قرأ: ‹جُبُلًا› مخففة{3}<span class=comment-ref>٥٤٤٨</span>. (١٢/٣٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٨</span> ذكر <u>ابنُ جرير</u> (١٩/٤٧١) في قوله: <span class="qpc-hafs">﴿جبلا﴾</span> ثلاث قراءات، فقال: «واختلف القراء في قراءة ذلك، فقرأته عامة قراء المدينة وبعض الكوفيين: <span class="qpc-hafs">﴿جِبلًّا﴾</span> بكسر الجيم وتشديد اللام، وكان بعض المكيين وعامة قراء الكوفة يقرؤونه: (جُبُلًا) بضم الجيم والباء وتخفيف اللام. وكان بعض قراء البصرة يقرؤه: ‹جُبْلًا› بضم الجيم وتسكين الباء». ثم <span class="comment-type-4">علّق</span> بقوله: «وكل هذه لغات معروفات». ثم <span class="comment-type-3">رجّح</span> قراءة من قرأ ذلك بكسر الجيم وتشديد اللام، وقراءة مَن قرأ ذلك بضم الجيم وتخفيف اللام <span class="mustanad">مستندًا للإجماع</span>، فقال: «غير أني لا أحب القراءة في ذلك إلا بإحدى القراءتين اللتين إحداهما بكسر الجيم وتشديد اللام، والأخرى بضم الجيم والباء وتخفيف اللام؛ لأن ذلك هو القراءة التي عليها عامة قرّاء الأمصار».</div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَضَلَّ مِنكُمۡ جِبِلࣰّا كَثِیرًاۖ أَفَلَمۡ تَكُونُوا۟ تَعۡقِلُونَ ۝٦٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿جِبِلًّا كَثِيرًا﴾</span>، قال: خَلْقًا كثيرًا{4}. (١٢/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا﴾</span> يعني: قد أغوى إبليسُ منكم <span class="qpc-hafs">﴿جِبِلًّا﴾</span> يعني: خلقًا كثيرًا، فكفروا فلم يكونوا يعقلون، وأخبر عنهم، فقال: <span class="qpc-hafs">﴿وقالُوا لَوْ كُنّا نَسْمَعُ أوْ نَعْقِلُ ما كُنّا فِي أصْحابِ السَّعِيرِ﴾</span> أي: لو كنا نسمع أو نعقل لآمَنّا في الدنيا، فلم نكن من أصحاب السعير. قال اللَّه: <span class="qpc-hafs">﴿فاعْتَرَفُوا بِذَنْبِهِمْ فَسُحْقًا﴾</span> فبُعْدًا <span class="qpc-hafs">﴿لأَصْحابِ السَّعِيرِ﴾</span> [الملك:١٠-١١]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ أضَلَّ مِنكُمْ﴾</span> ولقد أضل إبليسُ منكم عن الهدى <span class="qpc-hafs">﴿جِبِلًّا﴾</span> خَلْقًا <span class="qpc-hafs">﴿كَثِيرًا﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧٥<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿ولقد أضل منكم جبلا كثيرا﴾</span>، قال: خَلْقًا كثيرًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا﴾</span> خَلْقًا كثيرًا؛ أضلَّ مِن كل ألف تسعمائة وتسعة وتسعين{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٢٧٢ (٢٩٨٠).</p><p>قال الحاكم: «رواته كلهم ثقات، غير إسماعيل بن رافع، فإنهما لم يحتجا به». وقال الذهبي في التلخيص: «في إسناده إسماعيل بن رافع، هالك».</p><p>وهي قراءة شاذة، تروى أيضًا عن الأعمش. انظر: مختصر ابن خالويه ص١٢٦.|2:أخرجه إسحاق البستي في تفسيره ص١٩٤.</p><p>و<span class="qpc-hafs">﴿جِبِلًّا﴾</span> قراءة متواترة، قرأ بها نافع، وأبو جعفر، وعاصم، وقرأ أبو عمرو، وابن عامر: ‹جُبْلًا› بضم الجيم وإسكان الباء وتخفيف اللام، وقرأ روح: ‹جُبُلًّا› بضم الجيم والباء وتشديد اللام، وقرأ بقية العشرة كذلك إلا أنهم خففوا اللام. انظر: النشر ٢/٣٥٥، والإتحاف ص٤٦٩.</p><p>وأما (جِبْلًا) بكسر الجيم، وإسكان الباء، فهي قراءة شاذة، تروى أيضًا عن حماد بن سلمة عن عاصم، وأشهب، والعقيلي. انظر: المحتسب ٢/٢١٦.|3:عزاه السيوطي إلى عبد بن حميد.|4:تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:علقه يحيى بن سلام ٢/٨١٦.|6:تفسير مقاتل بن سليمان ٣/٥٨٣.|7:أخرجه إسحاق البستي ص١٩٤.|8:تفسير يحيى بن سلام ٢/٨١٦.
  36,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِی كُنتُمۡ تُوعَدُونَ ۝٦٣ ٱصۡلَوۡهَا ٱلۡیَوۡمَ بِمَا كُنتُمۡ تَكۡفُرُونَ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذِهِ جَهَنَّمُ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</span> في الدنيا، <span class="qpc-hafs">﴿اصْلَوْها اليَوْمَ﴾</span> في الآخرة <span class="qpc-hafs">﴿بِما كُنْتُمْ تَكْفُرُونَ﴾</span> في الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿هَذِهِ جَهَنَّمُ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</span> في الدنيا إن لم تؤمنوا، <span class="qpc-hafs">﴿اصْلَوْها اليَوْمَ بِما كُنْتُمْ تَكْفُرُونَ﴾</span> في الدنيا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٣.|2:تفسير يحيى بن سلام ٢/٨١٧.
  36,64,"36:63"
  36,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلۡیَوۡمَ نَخۡتِمُ عَلَىٰۤ أَفۡوَ ٰ⁠هِهِمۡ وَتُكَلِّمُنَاۤ أَیۡدِیهِمۡ وَتَشۡهَدُ أَرۡجُلُهُم بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٧٩<span class="dash">-</span></span> عن أنس، في قوله: <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</span>، قال: كُنّا عند النبيِّ ﷺ، فضحِك حتى بَدَتْ نَواجِذُه، قال: «<b>هل تدرون مِمَّ ضَحِكْتُ</b>؟». قلنا: لا، يا رسول الله. قال: «<b>مِن مخاطبة العبد ربَّه، يقول: يا ربِّ، ألم تُجِرْني مِن الظلم؟ فيقول: بلى. فيقول: إنِّي لا أُجِيزُ عَلَيَّ إلا شاهدًا مِنِّي. فيقول: كفى بنفسك اليومَ عليك شهيدًا، وبالكرام الكاتبين شهودًا. فيُختم على فيه، ويُقال لأركانه: انطقي. فتنطق بأعماله، ثم يُخَلّى بينه وبين الكلام، فيقول: بُعدًا لكُنَّ وسُحقًا، فعنكُنَّ كنت أُناضِل</b>»{1}. (١٢/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٠<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span> -من طريق أبي بردة- قال: يُدْعى المؤمنُ للحساب يوم القيامة، فيَعرض عليه ربُّه عملَه فيما بينه وبينه، فيعترف، فيقول: أيْ ربِّ، عملتُ، عملتُ، عملتُ. فيغفر الله له ذنوبَه، ويستره منها، قال: فما على الأرض خليقة يَرى من تلك الذنوب شيئًا، وتبدو حسناته فودَّ أنّ الناس كلهم يرونها. ويُدعى الكافر والمنافق للحساب، فيعرض ربُّه عليه عمله، فيجحد، ويقول: أي ربِّ، وعِزَّتِك، لقد كتب عَلَيَّ هذا الملَكُ ما لم أعمل. فيقول له الملَكُ: أما عملتَ كذا، في يوم كذا، في مكان كذا؟ فيقول: لا، وعزتك، أي ربِّ، ما عملتُه. فإذا فعل ذلك خُتم على فيه، فإني أحسب أول ما ينطق مِنه لَفَخِذُه اليمنى. ثم تلا: <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</span> الآية{2}. (١٢/٣٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨١<span class="dash">-</span></span> عن ابن جدعان، قال: سُئِل <span class="name-1">ابنُ عباس</span> عن قوله: <span class="qpc-hafs">﴿يوم لا ينطقون ولا يؤذن لهم فيعتذرون﴾</span> [المرسلات:٣٥-٣٦]، <span class="qpc-hafs">﴿قالوا والله ربنا ما كنا مشركين﴾</span> [الأنعام:٢٣]، وقال: <span class="qpc-hafs">﴿اليوم نختم على أفواههم وتكلمنا أيديهم وتشهد أرجلهم بما كانوا يكسبون﴾</span>. قال: فقال ابن عباس: إنّه يومٌ ذو ألوان{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق الأعمش- قال: يُقال للرجل يوم القيامة: عملتَ كذا وكذا. فيقول: ما عملتُ. فيُختم على فِيه، وتنطق جوارحُه، فيقول لجوارحه: أبْعَدَكُنَّ اللهُ، ما خاصمت إلا فيكُنَّ{4}. (١٢/٣٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</span>، قال: أول ما ينطق مِن الإنسان فخذه اليمنى{5}. (١٢/٣٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</span> هذا آخر مواطن يوم القيامة، فإذا خُتمت أفواههم لم يكن بعد ذلك إلا دخول النار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</span>، قال: كانت خصوماتٌ وكلام، وكان هذا آخره، أن خُتم على أفواههم{7}. (١٢/٣٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿اليَوْمَ﴾</span>: يعني: في الآخرة <span class="qpc-hafs">﴿نَخْتِمُ عَلى أفْواهِهِمْ﴾</span> قال: فلا يتكلمون{8}. (١٢/٣٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٧<span class="dash">-</span></span> عن <span class="name-3">أسماء بن عبيد</span>، قال: يُؤتى بابنِ آدم يوم القيامة ومعه جبلٌ مِن صُحُف، لكل ساعة صحيفة، فيقول الفاجر: وعِزَّتِك، لقد كتبوا عَلَيَّ ما لم أعمل. فعند ذلك يُختم على أفواههم، ويؤذن لجوارحهم في الكلام، فيكون أول ما يتكلم مِن جوارح ابن آدم فخذه اليسرى{9}. (١٢/٣٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ﴾</span> وذلك أنهم سُئِلوا: <span class="qpc-hafs">﴿أين شركاؤكم الذين كنتم تزعمون﴾</span>؟ [الأنعام:٢٢] فقالوا: <span class="qpc-hafs">﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</span> [الأنعام: ٢٣]. فيختم الله -جلَّ وعزَّ- على أفواههم، وتتكلم أيديهم وأرجلهم بشركهم، فذلك قوله تعالى: <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ وتُكَلِّمُنا أيْدِيهِمْ وتَشْهَدُ أرْجُلُهُمْ بِما كانُوا يَكْسِبُونَ﴾</span> بما كانوا يقولون مِن الشِّرك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بِما كانُوا يَكْسِبُونَ﴾</span> أي: يعملون{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡیَوۡمَ نَخۡتِمُ عَلَىٰۤ أَفۡوَ ٰ⁠هِهِمۡ وَتُكَلِّمُنَاۤ أَیۡدِیهِمۡ وَتَشۡهَدُ أَرۡجُلُهُم بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٦٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٩٠<span class="dash">-</span></span> عن أبي سعيد وأبي هريرة، قالا: قال رسول الله ﷺ: «<b>يلقى العبدُ ربَّه، فيقول اللهُ: أي فُل</b>{12}، <b>ألم أُكرمك، وأسوِّدك، وأزوِّجك، وأسخِّر لك الخيل والإبل، وأذرك ترأسُ وترْبَعُ</b>{13}؟ <b>فيقول: بلى، أي رب. فيقول: أفَطِنتَ أنّك مُلاقِيَّ؟ فيقول: لا. فيقول: فإنِّي أنساك كما نسيتني. ثم يلقى الثاني، فيقول مثل ذلك، ثم يلقى الثالث، فيقول له مثل ذلك، فيقول: آمنتُ بك، وبكتابك، وبرسولك، وصليتُ، وصمتُ، وتصدقتُ. ويثني بخير ما استطاع، فيقول: ألا نبعث شاهدنا عليك؟ فيفكِّر في نفسه: مَن الذي يشهد عليَّ؟ فيُختم على فيه، ويقال لفخذه: انطقي. فتنطق فخذه ولحمه وعظامه بعمله، ما كان ذلك يُعذر من نفسه، وذلك المنافق، وذلك الذي يسخط الله عليه</b>»{14}. (١٢/٣٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩١<span class="dash">-</span></span> عن عقبة بن عامر، أنّه سمع رسول الله ﷺ يقول: «<b>إنّ أول عَظْم مِن الإنسان يتكلم يوم يُختم على الأفواه: فخِذه مِن الرِّجل الشمال</b>»{15}. (١٢/٣٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩٢<span class="dash">-</span></span> عن بهز بن حكيم بن معاوية، عن أبيه، عن جدِّه، عن النبي ﷺ، قال: «<b>إنّكم تُدعون، فيُفْدَم على أفواهكم بالفِدام</b>{16}، <b>فأول ما يُسأل عن أحدكم فخِذه وكفُّه</b>»{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩٣<span class="dash">-</span></span> عن بسرة -وكانت من المهاجرات- قالت: قال رسول الله ﷺ: «<b>عليكنَّ بالتسبيح، والتهليل، والتقديس، ولا تغفلن، واعقدن بالأنامل؛ فإنهنَّ مسئولات ومستنطقات</b>»{18}. (١٢/٣٦٨)</p></p><p></div></p></div>",footnotes:1:أخرجه مسلم ٤/٢٢٨٠ (٢٩٦٩)، وابن أبي حاتم ٨/٢٥٥٩ (١٤٣٠١).|2:أخرجه ابن جرير ١٩/٤٧٢-٤٧٣. وعزاه السيوطي إلى ابن أبي حاتم. وأخرج نحوه يحيى بن سلام ٢/٨١٧ مختصرًا.|3:أخرجه إسحاق البستي ص١٩٤.|4:أخرجه ابن جرير ١٩/٤٧٣.|5:عزاه السيوطي إلى عبد بن حميد.|6:علقه يحيى بن سلام ٢/٨١٧.|7:أخرجه ابن جرير ١٩/٤٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|8:عزاه السيوطي إلى ابن أبي حاتم.|9:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:تفسير مقاتل بن سليمان ٣/٥٨٣-٥٨٤.|11:تفسير يحيى بن سلام ٢/٨١٧.|12:فُل: يا فلان. شرح النووي على صحيح مسلم ١٨/١٠٣.|13:تربع: تأخذ المرباع الذي كانت ملوك الجاهلية تأخذه، وهو ربع الغنيمة. شرح النووي على صحيح مسلم ١٨/١٠٣.|14:أخرجه الترمذي ٤/٤٢٥-٤٢٦ (٢٥٩٧).</p><p>قال الترمذي: «هذا حديث صحيح غريب».|15:أخرجه أحمد ٢٨/٦٠٢ (١٧٣٧٤)، وابن جرير ١٩/٤٧٣-٤٧٤، ٢٠/٤٠٩، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٨٦-، والثعلبي ٨/١٣٤.</p><p>وأصله عند مسلم ٤/٢٢٧٩ (٢٩٦٨)، وابن أبي حاتم ٤/١٢٨٠ (٧٢٢٢) مختصرًا، من حديث أبي هريرة.</p><p>قال ابن كثير: «وقد جوّد إسنادَه الإمامُ أحمد». وقال الهيثمي في المجمع ١٠/٣٥١ (١٨٣٩٩): «رواه أحمد، والطبراني، وإسنادهما جيد». وقال المظهري في تفسيره ٦/٤٨٣: «وأخرج أحمد بسند جيد».|16:الفِدام: ما يشد على فم الإبريق والكوز مِن خرقة لتصفية الشراب الذي فيه، أي: أنهم يمنعون الكلام بأفواههم حتى تتكلم جوارحهم، فشبه ذلك بالفِدام. النهاية (فدم).|17:أخرجه أحمد ٣٣/٢٣٦-٢٣٧ (٢٠٠٣٧)، ٣٣/٢٤٢ (٢٠٠٤٣) مطولًا، وعبد الرازق ٣/١٥١ (٢٦٩٩)، وابن جرير ٢٠/٤٠٨-٤٠٩.</p><p>صحّحه الألباني في الصحيحة ٦/٤٧٩ (٢٧١٣).|18:أخرجه الترمذي ٦/١٧٩-١٨٠ (٣٩٠٠)، وأبو داود ٢/٦١٦ (١٥٠١)، وابن حبان ٣/١٢٢ (٨٤٢)، والحاكم ١/٧٣٢ (٢٠٠٧).</p><p>قال الترمذي: «هذا حديث إنما نعرفه من حديث هانئ بن عثمان، وقد رواه محمد بن ربيعة عن هانئ بن عثمان». وقال العراقي في تخريج أحاديث الإحياء ص٣٥٦: «بإسناد جيد». وقال الألباني في صحيح أبي داود ٥/٢٣٦ (١٣٤٥): «حديث حسن».
  36,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَشَاۤءُ لَطَمَسۡنَا عَلَىٰۤ أَعۡیُنِهِمۡ فَٱسۡتَبَقُوا۟ ٱلصِّرَ ٰ⁠طَ فَأَنَّىٰ یُبۡصِرُونَ ۝٦٦﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</span> نزلت في كفار مكة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَشَاۤءُ لَطَمَسۡنَا عَلَىٰۤ أَعۡیُنِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٨٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</span>، قال: أعميناهم، وأضللناهم عن الهدى{2}. (١٢/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩٨<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٨٩٩<span class="dash">-</span></span> و<span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</span>، معناه: لو نشاء لفقأنا أعين ضلالتهم، فأعميناهم عن غيِّهم، وحوّلنا أبصارهم مِن الضلالة إلى الهدى، فأبصروا رشدهم، فأنّى يبصرون ولم أفعل ذلك بهم؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا﴾</span>، قال: لو شاء الله لتركهم عُمْيًا يَتَرَدَّدون{4}. (١٢/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ فاسْتَبَقُوا الصِّراطَ فَأَنّى يُبْصِرُونَ﴾</span>، يقول: لو شئنا لتركناهم عُميًا يَتَرَدَّدون{5}<span class=comment-ref>٥٤٤٩</span>. (١٢/٣٧١)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٩</span> ذكر <u>ابنُ عطية</u> (٧/٢٦٢ ط: دار الكتب العلمية) قول قتادة وقول الحسن، ثم <span class="comment-type-4">علّق</span> عليهما، فقال: «وقال الحسن بن أبي الحسن، وقتادة: أراد الأعين حقيقة، والمعنى: لأعميناهم فلا يرون كيف يمشون. ويؤيد هذا مجانسة المسخ للعمى الحقيقي».</div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</span> نزلت في كفار مكة، يقول: لو نشاء لحوّلنا أبصارهم مِن الضلالة إلى الهدى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</span>، يعني: المشركين{7}<span class=comment-ref>٥٤٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٠</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿ولو نشاء لطمسنا أعينهم...﴾</span> الآيةَ على قولين: <b>الأول</b>: أن معنى ذلك: ولو نشاء لأعميناهم عن الهدى، وأضللناهم عن قصد المحجة. وهو مروي عن ابن عباس، وعطاء، ومقاتل. <b>الثاني</b>: أنّ معنى ذلك: ولو نشاء لتركناهم عميًا. وهو مروي عن الحسن، وقتادة.</p><p>وقد ذكر <u>ابنُ جرير</u> (١٩/٤٧٥) القولين، ثم قال <span class="comment-type-3">مرجّحًا</span> القول الثاني، <span class="comment-type-2">ومنتقدًا</span> القول الأول <span class="mustanad">مستندًا إلى الدلالة العقلية</span>: «وهذا القول الذي ذكرناه عن الحسن وقتادة أشبه بتأويل الكلام؛ لأنّ الله إنما تهدد به قومًا كُفارًا، فلا وجه لأن يُقال وهم كفار: لو نشاء لأضللناهم. وقد أضلهم، ولكنه قال: لو نشاء لعاقبناهم على كفرهم، فطمسنا على أعينهم، فصيرناهم عميًا لا يبصرون طريقًا، ولا يهتدون له. والطمس على العين: هو أن لا يكون بين جفني العين غر، وذلك هو الشق الذي بين الجفنين، كما تطمس الريح الأثر، يقال: أعمى مطموس وطميس».</div></p><p><h3><span class="qpc-hafs">﴿فَٱسۡتَبَقُوا۟ ٱلصِّرَ ٰ⁠طَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فاسْتَبَقُوا الصِّراطَ﴾</span>، قال: الطريق{8}. (١٢/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿فاسْتَبَقُوا الصِّراطَ﴾</span>، أي: الطريق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاسْتَبَقُوا الصِّراطَ﴾</span> ولو طمستُ الكفار لاستبقوا الصراط، يقول: لأبصروا طريق الهدى، <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُونَ﴾</span> فمِن أين يبصرون الهُدى إن لم أُعم عليهم طريق الضلالة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فاسْتَبَقُوا الصِّراطَ﴾</span>، قال: الصراط: الطريق{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَنَّىٰ یُبۡصِرُونَ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُونَ﴾</span>، قال: فكيف يهتدون؟!{12}. (١٢/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُونَ﴾</span>، يقول: لا يبصرون الحقَّ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُون﴾</span>: وقد طمسنا على أعينهم{14}<span class=comment-ref>٥٤٥١</span>. (١٢/٣٧٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥١</span> ذكر <u>ابنُ جرير</u> (١٩/٤٧٦) قول مجاهد، و<span class="comment-type-4">قدّم</span> له بقوله: «وقوله: <span class="qpc-hafs">﴿فأنى يبصرون﴾</span> يقول: فأي وجه يبصرون أن يسلكوه من الطرق، وقد طمسنا على أعينهم؟!». ثم <span class="comment-type-4">قال</span>: «وقال الذين وجهوا تأويل قوله: <span class="qpc-hafs">﴿ولو نشاء لطمسنا على أعينهم﴾</span> إلى أنه معني به: العمى عن الهدى؛ تأويل قوله: <span class="qpc-hafs">﴿فأنى يبصرون﴾</span>: فأنى يهتدون للحق». وذكر قولي ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٦٤٩١١<span class="dash">-</span></span> عن <span class="name-2">الحسن</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٢<span class="dash">-</span></span> و<span class="name-2">السُدِّيّ</span>: <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُونَ﴾</span> فكيف يبصرون وقد أعمينا أعينهم؟!{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُونَ﴾</span> فكيف يُبِصرون إذا أغشيناهم؟!{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَنّى يُبْصِرُونَ﴾</span> فمِن أين يبصرون الهدى إن لم أُعَمِّ عليهم طريق الضلالة؟!{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٤.|2:أخرجه ابن جرير ١٩/٤٧٤، والبيهقي في الأسماء والصفات (٣٠٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:تفسير الثعلبي ٨/١٣٥، وتفسير البغوي ٦/٢٥.|4:أخرجه ابن جرير ١٩/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|5:أخرجه عبد الرزاق ٢/١٤٥ من طريق معمر بلفظ:«لو نشاء لجعلناهم عميًا لا يترددون» وابن جرير ١٩/٤٧٥ واللفظ له، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٣/٥٨٤|7:تفسير يحيى بن سلام ٢/٨١٧.|8:تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:أخرجه يحيى بن سلام ٢/٨١٧، وابن جرير ١٩/٤٧٦.|10:تفسير مقاتل بن سليمان ٣/٥٨٤.|11:أخرجه ابن جرير ١٩/٤٧٦.|12:أخرجه ابن جرير ١٩/٤٧٦، والبيهقي في الأسماء والصفات (٣٠٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|13:أخرجه ابن جرير ١٩/٤٧٧.|14:تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|15:تفسير البغوي ٦/٢٥.|16:أخرجه يحيى بن سلام ٢/٨١٧.|17:تفسير مقاتل بن سليمان ٣/٥٨٤.
  36,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَشَاۤءُ لَمَسَخۡنَـٰهُمۡ عَلَىٰ مَكَانَتِهِمۡ فَمَا ٱسۡتَطَـٰعُوا۟ مُضِیࣰّا وَلَا یَرۡجِعُونَ ۝٦٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٩١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن</span> -من طريق إسماعيل-: <span class="qpc-hafs">﴿لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</span>، وقد اختلف فيها عنه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَشَاۤءُ لَمَسَخۡنَـٰهُمۡ عَلَىٰ مَكَانَتِهِمۡ فَمَا ٱسۡتَطَـٰعُوا۟ مُضِیࣰّا وَلَا یَرۡجِعُونَ ۝٦٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٩١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ﴾</span> قال: أهلكناهم، <span class="qpc-hafs">﴿عَلى مَكانَتِهِمْ﴾</span> قال: في مساكنهم{2}. (١٢/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</span>، قال: لو نشاء لأقعدناهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ﴾</span>، يقول: لَجعلناهم حجارة{4}. (١٢/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</span> قال: لو نشاء لجعلناهم كُسحًا لا يقومون، <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مُضِيًّا ولا يَرْجِعُونَ﴾</span> قال: فلم يستطيعوا أن يتقدموا ولا يتأخروا{5}. (١٢/٣٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم، فقال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</span> يقول تعالى: لو شئتُ لمسختهم حجارةً في منازلهم ليس فيها أرواح، <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مُضِيًّا ولا يَرْجِعُونَ﴾</span> يقول: لا يتقدمون ولا يتأخرون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</span> قال: ولو نشاء لأقعدناهم على أرجلهم، <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مُضِيًّا ولا يَرْجِعُونَ﴾</span> فما استطاعوا إذا فعلنا ذلك بهم أن يتقدَّموا أو يتأخروا{7}<span class=comment-ref>٥٤٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٢</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿ولو نشاء لمسخناهم على مكانتهم﴾</span> على أقوال: <b>الأول</b>: أن معناه: ولو نشاء لأقعدناهم في منازلهم؛ فلا يستطيعون أن يمضوا أمامهم، ولا أن يرجعوا وراءهم. <b>الثاني</b>: أن معناه: ولو نشاء لأهلكناهم في منازلهم. <b>الثالث</b>: أن معناه: ولو نشاء لجعلناهم حجارة.</p><p>وقد <span class="comment-type-3">اختار</span> <u>ابنُ جرير</u> (١٩/٤٧٧) القول الأول <span class="mustanad">مستندًا لأقوال السلف</span>.</div></p></div>",footnotes:1:أخرجه إسحاق البستي ص١٩٥. وقد ذكر أبو حيان في البحر المحيط ٧/٣٤٤ عن الحسن أنه قرأ: <span class="qpc-hafs">﴿على مكانتهم﴾</span> بالإفراد. وقال القرطبي في الجامع لأحكام القرآن ١٥/٥٠: قرأ الحسن والسلمي وزر بن حبيش وعاصم في رواية أبي بكر: ‹مَكاناتِهِمْ› على الجمع، الباقون بالتوحيد.</p><p>وهما متواترتان، فقرأ شعبة عن عاصم ‹عَلى مَكاناتِهِمْ› بالجمع، وقرأ بقية العشرة <span class="qpc-hafs">﴿عَلى مَكانَتِهِمْ﴾</span> بالإفراد. ينظر: النشر ٢/٢٦٣، والإتحاف ص٤٦٩.|2:أخرجه ابن جرير ١٩/٤٧٧-٤٧٨. وعزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن جرير ١٩/٤٧٧.|4:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|5:أخرجه عبد الرزاق ٢/١٤٥ من طريق معمر مقتصرًا على شطره الأول، وابن جرير ١٩/٤٧٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر شطره الأول. وعزا إلى ابن أبي حاتم شطره الثاني.|6:تفسير مقاتل بن سليمان ٣/٥٨٤.|7:تفسير يحيى بن سلام ٢/٨١٧.
  36,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن نُّعَمِّرۡهُ نُنَكِّسۡهُ فِی ٱلۡخَلۡقِۚ أَفَلَا یَعۡقِلُونَ ۝٦٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٢٢<span class="dash">-</span></span> عن هارون، عن <span class="name-2">الأعمش</span>: <span class="qpc-hafs">﴿نُنَكِّسْهُ﴾</span> مِن النكس.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٣<span class="dash">-</span></span> قال <span class="name-2">الأعرج</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٤<span class="dash">-</span></span> و<span class="name-2">الحسن</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٥<span class="dash">-</span></span> و<span class="name-2">أبو عمرو</span>: ‹نَنكُسْهُ فِي الخَلْقِ أفَلا يَعْقِلُونَ›{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٦<span class="dash">-</span></span> عن هارون، عن نوح، عن <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿أفَلا يَعْقِلُونَ﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٧<span class="dash">-</span></span> وكذلك قراءة <span class="name-2">الأعرج</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن نُّعَمِّرۡهُ نُنَكِّسۡهُ فِی ٱلۡخَلۡقِۚ أَفَلَا یَعۡقِلُونَ ۝٦٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومَن نُعَمِّرْهُ﴾</span> يقول: مَن نُمِدُّ له في العمر <span class="qpc-hafs">﴿نُنَكِّسْهُ فِي الخَلْقِ﴾</span> لكيلا يعلم بعد عِلْمٍ شَيئًا، يعني: الهرم{3}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ومَن نُعَمِّرْهُ نُنَكِّسْهُ فِي الخَلْقِ﴾</span>، قال: هو الهرِم، يتغيّر سمعُه وبصرُه وقوتُه، كما رأيت{4}. (١٢/٣٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله:<span class="qpc-hafs">﴿ومَن نُعَمِّرْهُ نُنَكِّسْهُ فِي الخَلْقِ﴾</span>، قال: نَرُدُّه إلى أرذل العمر{5}. (١٢/٣٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَن نُعَمِّرْهُ﴾</span> فنطول عمره <span class="qpc-hafs">﴿نُنَكِّسْهُ فِي الخَلْقِ أفَلا يَعْقِلُونَ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٢<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، في قوله: <span class="qpc-hafs">﴿ومَن نُعَمِّرْهُ نُنَكِّسْهُ﴾</span>، قال: ثمانين سنة{7}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ومَن نُعَمِّرْهُ﴾</span> أي: إلى أرذل العمر <span class="qpc-hafs">﴿نُنَكِّسْهُ فِي الخَلْقِ﴾</span> فيكون بمنزلة الصبيِّ الذي لا يعقل، كقوله: <span class="qpc-hafs">﴿ومِنكُمْ مَن يُرَدُّ إلى أرْذَلِ العُمُرِ لِكَيْلا يَعْلَمَ مِن بَعْدِ عِلْمٍ شَيْئًا﴾</span> [الحج:٥]، قال: <span class="qpc-hafs">﴿أفَلا يَعْقِلُونَ﴾</span> يعني به: المشركين، أي: فالذي خلقكم، ثم جعلكم شبابًا، ثم جعلكم شيوخًا، ثم نكَّسكم في الخلق، فردَّكم بمنزلة الطفل الذي لا يعقل شيئًا قادِر على أن يبعثكم يوم القيامة{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص١٩٥.</p><p>و<span class="qpc-hafs">﴿نُنَكِّسْهُ﴾</span> قراءة متواترة، قرأ بها عاصم، وحمزة، وقرأ بقية العشرة: ‹نَنْكُسْهُ› بفتح النون الأولى، وإسكان الثانية، وضم الكاف. انظر: النشر ٢/٣٥٥، والإتحاف ص٤٦٩.|2:أخرجه إسحاق البستي في تفسيره ص١٩٥.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، وعاصم، وحمزة، والكسائي، وخلف، وهشام، وقرأ نافع، وأبو جعفر، ويعقوب، وابن ذكوان: ‹أفَلا تَعْقِلُونَ› بالتاء. انظر: النشر ٢/٢٥٧، والإتحاف ص٤٦٩.|3:أخرجه ابن جرير ١٩/٤٧٨. وعزاه السيوطي إلى ابن أبي حاتم.|4:أخرجه عبد الرزاق ٢/١٤٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:عزاه السيوطي إلى ابن المنذر.|6:تفسير مقاتل بن سليمان ٣/٥٨٤.|7:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|8:تفسير يحيى بن سلام ٢/٨١٧-٨١٨.
  36,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا عَلَّمۡنَـٰهُ ٱلشِّعۡرَ وَمَا یَنۢبَغِی لَهُۥۤۚ إِنۡ هُوَ إِلَّا ذِكۡرࣱ وَقُرۡءَانࣱ مُّبِینࣱ ۝٦٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٣٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: إنّ كُفّار مكة قالوا: إنّ محمدًا شاعر، وما يقوله شعر. فأنزل الله تكذيبًا لهم: <span class="qpc-hafs">﴿وما عَلَّمْناهُ الشِّعْرَ وما يَنْبَغِي لَهُ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما عَلَّمْناهُ الشِّعْرَ﴾</span> نزلت في عقبة بن أبي مُعَيط وأصحابه، قالوا: إنّ القرآن شِعر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا عَلَّمۡنَـٰهُ ٱلشِّعۡرَ وَمَا یَنۢبَغِی لَهُۥۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وما عَلَّمْناهُ الشِّعْرَ وما يَنْبَغِي لَهُ﴾</span>، قال: محمد ﷺ عصمه الله مِن ذلك{3}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وما عَلَّمْناهُ الشِّعْرَ﴾</span>، قال: محمد ﷺ{4}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يَنْبَغِي لَهُ﴾</span> أن يَعلَمَه{2}<span class=comment-ref>٥٤٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٦٤) في عود الضمير من قوله: <span class="qpc-hafs">﴿وما ينبغي له﴾</span> احتمالين، فقال: «والضمير في <span class="qpc-hafs">﴿لَهُ﴾</span> <b>يحتمل</b> أن يعود على محمد، <b>ويحتمل</b> أن يعود على القرآن، وإن كان لم يذكر لدلالة المجاورة عليه، ويبين ذلك قوله تعالى: <span class="qpc-hafs">﴿إنْ هُوَ﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٦٤٩٣٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وما عَلَّمْناهُ الشِّعْرَ﴾</span> يعني: النبي ﵇، <span class="qpc-hafs">﴿وما يَنْبَغِي لَهُ﴾</span> أن يكون شاعرًا ولا يروي الشعر{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا ذِكۡرࣱ وَقُرۡءَانࣱ مُّبِینࣱ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٤٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ذِكْرٌ وقُرْآنٌ مُبِينٌ﴾</span> يذكرون به الجنة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنْ هُوَ إلّا ذِكْر﴾</span>، قال: هذا القرآن{8}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنْ هُوَ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿إلّا ذِكْرٌ﴾</span> تفكُّر، <span class="qpc-hafs">﴿وقُرْآنٌ مُبِينٌ﴾</span> بيِّن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنْ هُوَ﴾</span> يعني: ما هو <span class="qpc-hafs">﴿إلّا ذِكْرٌ﴾</span> يعني: ما هو إلا تَفَكُّر للعالمين لِمَن آمن مِن الجن والإنس. وقال بعضهم: <span class="qpc-hafs">﴿إنْ هُوَ إلّا ذِكْرٌ﴾</span> تذكُّر في ذات الله، <span class="qpc-hafs">﴿وقُرْآنٌ مُبِينٌ﴾</span> بيِّن{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا ذِكۡرࣱ وَقُرۡءَانࣱ مُّبِینࣱ ۝٦٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٤٤<span class="dash">-</span></span> عن قتادة، قال: بلغني: أنّه قيل لعائشة: هل كان رسول الله ﷺ يَتَمَثَّل بشيء من الشعر؟ قالت: كان أبغضَ الحديث إليه، غير أنّه كان يتمثل ببيت أخي بني قيس، يجعل أوله آخره، وآخره أوله ويقول: «<b>ويأتيك من لم تزود بالأخبار</b>». فقال له أبو بكر: ليس هكذا. فقال رسول الله ﷺ: «<b>إني -واللهِ- ما أنا بشاعر، ولا ينبغي لي</b>»{11}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٥<span class="dash">-</span></span> عن عائشة، قالت: كان رسول الله ﷺ إذا استراث{12} الخبرَ تمثّل ببيت طرفة:</p><p>ويأتيك بالأخبار من لم تُزَوِّد{13}. (١٢/٣٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٦<span class="dash">-</span></span> عن عائشة، قالت: ما جمع رسولُ الله ﷺ بيت شعر قطُّ إلا بيتًا واحدًا:</p><p>«<b>تفاءل بما تهوى يكن فلقلَّما يقال لشيء كان إلا تحقق</b>»</p><p>قالت عائشة: ولم يقل تحقَّقا. لئلا يعربه فيصير شعرًا{14}. (١٢/٣٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٧<span class="dash">-</span></span> عن المقدام بن شريح، عن أبيه، قال: قلت لعائشة: أكان رسول الله ﷺ يتمثَّل بشيء من الشعر؟ قالت: كان يتمثل مِن شعر عبد الله بن رواحة، قالت: وربما قال:</p><p>ويأتيك بالأخبار من لم تزود{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٨<span class="dash">-</span></span> عن ابن عباس، قال: كان رسول الله ﷺ يتمثل من الأشعار:</p><p>ويأتيك بالأخبار من لم تزود{16}<span class=comment-ref>٥٤٥٤</span>. (١٢/٣٧٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٤</span> ذكر <u>ابنُ كثير</u> (١١/٣٧٩-٣٨٠) بعض الآثار التي أفادت قول النبي ﷺ بعض الأشعار، ثم <span class="comment-type-4">علّق</span> قائلًا: «وكل هذا لا ينافي كونه ﷺ ما علم شعرًا ولا ينبغي له؛ فإن الله تعالى إنما علمه القرآن العظيم، الذي لا يأتيه الباطل من بين يديه ولا من خلفه تنزيل من حكيم حميد، وليس هو بشعرٍ كما زعمه طائفة مِن جهلة كفار قريش، ولا كهانة، ولا مفتعل، ولا سحر يؤثر، كما تنوعت فيه أقوال الضلال وآراء الجهال. وقد كانت سجيته ﷺ تأبى صناعة الشعر طبعًا وشرعًا».</div></p><p><div></p><p><p><span class="item-no">٦٤٩٤٩<span class="dash">-</span></span> عن الحسن: أنّ النبي ﷺ كان يتمثل بهذا البيت: «<b>كفى بالإسلام والشيب للمرء ناهيا</b>». فقال أبو بكر: يا رسول الله، إنما قال الشاعر:</p><p>كفى بالشيب والإسلام للمرء ناهيا</p><p>فأعاده كالأول، فقال أبو بكر: أشهد أنك رسول الله، ما علّمك الشعر وما ينبغي لك{17}. (١٢/٣٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٠<span class="dash">-</span></span> عن عبد الرحمن بن أبي الزناد، أن النبي ﷺ قال للعباس بن مرداس: «<b>أرأيت قولك: أصبح نَهِبي ونهبُ العبيد بين الأقرع وعُيينة</b>». فقال أبو بكر: بأبي أنت وأمي، يا رسول الله، ما أنت بشاعر ولا راويه، ولا ينبغي لك، إنما قال: بين عُيينة والأقرع{18}. (١٢/٣٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥١<span class="dash">-</span></span> عن عبد الله بن عمرو، سمعتُ رسول الله ﷺ يقول: «<b>ما أبالي ما أتيتُ إن أنا شربتُ تِرياقًا، أو تعلّقتُ تميمة، أو قلتُ الشِّعر من قِبل نفسي</b>»{19}. (١٢/٣٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٢<span class="dash">-</span></span> عن نوفل بن عقرب، قال: سألتُ عائشة: هل كان رسول الله ﷺ يتسامع عنده الشعر؟ قالت: كان أبغضَ الحديث إليه{20}. (١٢/٣٧٥)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/٢٦.|2:تفسير مقاتل بن سليمان ٣/٥٨٤.|3:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٣/٥٨٤.|6:تفسير يحيى بن سلام ٢/٨١٨.|7:علقه يحيى بن سلام ٢/٨١٨.|8:أخرجه ابن جرير ١٩/٤٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|9:تفسير مقاتل بن سليمان ٣/٥٨٤.|10:تفسير يحيى بن سلام ٢/٨١٨.|11:أخرجه عبد الرزاق ٣/٨٦ (٢٤٩٦)، وابن جرير ١٩/٤٨٠، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٩٠-، والثعلبي ٨/١٣٦.</p><p>إسناده ضعيف؛ لانقطاعه، فقد بلغ به قتادةُ عائشة، وأبهم الواسطة بينهما.|12:استراث: أبطأ. النهاية (ريث).|13:أخرجه أحمد ٤٠/٢٤ (٢٤٠٢٣)، ٤٢/٦٥ (٢٥١٣٤).</p><p>قال الهيثمي في المجمع ٨/١٢٨ (١٣٣٤٧): «رجاله رجال الصحيح». وقال المناوي في التيسير ٢/٢٣٨: «بإسناد صحيح». وصحّحه الألباني في الصحيحة ٥/٨٩ (٢٠٥٧).|14:أخرجه البيهقي في الكبرى ٧/٦٨-٦٩ (١٣٢٩١)، والخطيب في تاريخه ١١/٤٢٦ (٣٣٧١).</p><p>قال البيهقي: «ولم أكتبه إلا بهذا الإسناد، وفيهم مَن يجهل حاله». وقال الخطيب: «غريب جدًّا، لم أكتبه إلا بهذا الإسناد». وقال ابن كثير في تفسيره ٦/٥٩٠: «سألت شيخنا الحافظ أبا الحجاج المزي عن هذا الحديث، فقال: هو منكر. ولم يعرف شيخ الحاكم، ولا الضرير».|15:أخرجه أحمد ٤١/٥١٦ (٢٥٠٧١)، ٤٢/١٣١ (٢٥٢٣١)، ٤٣/٥١ (٢٥٨٦٢)، والترمذي ٥/١٢١-١٢٢ (٣٠٦٢).</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال أبو نعيم في الحلية ٧/٢٦٤: «غريب، لم أكتبه إلا من هذا الوجه». وعلّق الألباني في الصحيحة على كلام الترمذي بقوله ٥/٨٩: «كذا قال، ولعله بالنظر إلى طريقيه، وإلا فشريك -وهو ابن عبد الله القاضي- سيئ الحفظ».|16:أخرجه ابن أبي شيبة ٥/٢٧٢ (٢٦٠١٤)، والطبراني في الكبير ١١/٢٨٨ (١١٧٦٣).</p><p>قال الهيثمي في المجمع ٨/١٢٨ (١٣٣٤٦): «رواه البزار، والطبراني في أثناء حديث، ورجالهما رجال الصحيح». وقال الألباني في الصحيحة ٥/٩٠: «وإسناده صحيح».|17:أخرجه ابن سعد ١/٣٨٢-٣٨٣، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٧٤-، والمرزباني في معجم الشعراء -كما في الإصابة ٣/٢٥٠-.|18:أخرجه ابن سعد٤/٢٧٣-٢٧٤.|19:أخرجه أحمد ١١/١٢٥ (٦٥٦٥)، ١١/٦٥١-٦٥٢ (٧٠٨١)، وأبو داود ٦/١٧-١٨ (٣٨٦٩).</p><p>قال الهيثمي في المجمع ٥/١٠٣ (٨٤٠١): «رواه الطبراني في الأوسط عن شيخه موسى بن عيسى بن المنذر الحمصي، ولم أعرفه، وبقية رجاله ثقات». وقال المناوي في التيسير ٢/٣٣٧: «قال الذهبي: هذا حديث منكر». وقال الرباعي في فتح الغفار ٤/١٩٩٦ (٥٨٠٤): «وفي إسناده عبد الرحمن بن رافع التنوخي قاضي أفريقية، قال البخاري: في حديثه مناكير».|20:أخرجه أحمد ٤١/٤٧٥-٤٧٦ (٢٥٠٢٠)، ٤٢/٧٦ (٢٥١٥٠)، ٤٢/٣٥٨ (٢٥٥٥٤) عن أبي نوفل.</p><p>قال الهيثمي في المجمع ٨/١١٩ (١٣٢٩٧): «ورجاله رجال الصحيح». وأورده البوصيري في إتحاف الخيرة ٦/١٤٤ (٥٥٢٣/٢) من مسند مسدّد بسنده، ثم قال: «هذا إسناد صحيح، على شرط مسلم». وأورده الألباني في الصحيحة ٧/٢٥٣ (٣٠٩٥).
  36,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّیُنذِرَ مَن كَانَ حَیࣰّا وَیَحِقَّ ٱلۡقَوۡلُ عَلَى ٱلۡكَـٰفِرِینَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٥٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي روق- في قوله: <span class="qpc-hafs">﴿لِيُنْذِرَ مَن كانَ حَيًّا﴾</span>، قال: عاقلًا{1}. (١٢/٣٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لِيُنْذِرَ مَن كانَ حَيًّا﴾</span>، قال: حي القلب، حي البصر{2}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿لِيُنْذِرَ مَن كانَ حَيًّا﴾</span>، يعني: مهتديًا، مؤمنًا في علم الله، هو الذي يقبل نذارتك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِيُنْذِرَ﴾</span> يعني: لتنذر -يا محمد- بما في القرآن مِن الوعيد <span class="qpc-hafs">﴿مَن كانَ حَيًّا﴾</span> مَن كان مهديًّا في علم الله ﷿{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لِيُنْذِرَ﴾</span> مِن النار، من قرأها بالياء يقول: لينذر القرآن. ومن قرأها بالتاء يقول: لتنذر يا محمد{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَحِقَّ ٱلۡقَوۡلُ عَلَى ٱلۡكَـٰفِرِینَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويحق القول على الكافرين﴾</span>: بأعمالهم؛ أعمال السوء{6}. (١٢/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَحِقَّ القَوْلُ﴾</span> ويجب العذاب <span class="qpc-hafs">﴿عَلى الكافِرِينَ﴾</span> بتوحيد الله ﷿{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويَحِقَّ القَوْلُ﴾</span> الغضب <span class="qpc-hafs">﴿عَلى الكافِرِينَ﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٨١، والبزار في البحر الزخار المعروف بمسند البزار ٨/١٧٩ (٣٢١١)، والبيهقي في شعب الإيمان (٤٦٥٣).|2:أخرجه ابن جرير ١٩/٤٨١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|3:علقه يحيى بن سلام ٢/٨١٩.|4:تفسير مقاتل بن سليمان ٣/٥٨٤.|5:تفسير يحيى بن سلام ٢/٨١٩.</p><p>قرأ المدنيان وابن عامر ويعقوب بالتاء، وقرأ الباقون بالياء. انظر: النشر ٢/٣٥٥.|6:أخرجه ابن جرير ١٩/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|7:تفسير مقاتل بن سليمان ٣/٥٨٤.|8:تفسير يحيى بن سلام ٢/٨١٩.