tafsir[16]{c,v,t}:
36,55," <q>﴿إِنَّ أَصۡحَـٰبَ ٱلۡجَنَّةِ ٱلۡیَوۡمَ فِی شُغُلࣲ﴾</q> - تفسير ٦٤٧٩٧- عن عبد الله بن مسعود -من طريق شقيق بن سلمة- في قوله: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</q>، قال: شَغَلهم افتضاضُ العذارى{1}. (١٢/٣٦١) ٦٤٧٩٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿فِي شُغُلٍ فاكِهُونَ﴾</q>، قال: في افتضاض الأبكار{2}. (١٢/٣٦١) ٦٤٧٩٩- عن عكرمة مولى ابن عباس= (ز) ٦٤٨٠٠- وقتادة بن دعامة -من طريق سعيد-، مثله{3}. (١٢/٣٦١) ٦٤٨٠١- عن عبد الله بن عباس، في قوله: <q>﴿فِي شُغُلٍ فاكِهُونَ﴾</q>، قال: ضَرْب الأوتار{4}. (١٢/٣٦٢) ٦٤٨٠٢- عن سعيد بن المسيب -من طريق وائل بن داود- في قوله: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</q>، قال: في افتضاض العذارى{5}. (ز) ٦٤٨٠٣- عن إياس بن عامر، قال: سمعتُ رجلًا بإيلياء قديمًا يقول: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</q>، إنّ الرجل مِن أهل الجنة في الخيمة مع نسائه، حتى تأتيه نساءٌ فيَقُلْنَ له: اخرج إلى أهلك. فيقول: ما أنتُنَّ لي بأهل. فيقُلْن: بلى، نحن مِمّا أخفى الله لك، فقد زُوِّجتنا. فيشتغل بِهِنَّ عن أهله الأولين، فذلك قول الله: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</q>. قال: فذكرت ذلك لتُبَيْع برُودِس{6}، فقال: ذلك أبو فلان، فعرفه، صَدَق كما قال{7}. (ز) ٦٤٨٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ﴾</q>، قال: مِن النِّعمة{8}. (١٢/٣٦٠) ٦٤٨٠٥- عن الحسن البصري -من طريق أبي سهل- في قوله: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ فِي شُغُلٍ فاكِهُونَ﴾</q>، قال: شَغلهم النعيمُ عمّا فيه أهل النار مِن العذاب{9}. (١٢/٣٦١) ٦٤٨٠٦- عن إسماعيل بن أبي خالد -من طريق أبان بن تغلب- <q>﴿إنَّ أصْحابَ الجَنَّةِ﴾</q> الآية، قال: في شُغل عمّا يلقى أهلُ النار{10}. (ز) ٦٤٨٠٧- قال محمد بن السائب الكلبي= (ز) ٦٤٨٠٨- والثُّمالِي= (ز) ٦٤٨٠٩- والمسيب [بن شريك]: <q>﴿فِي شُغُلٍ فاكِهُونَ﴾</q>، يعني: في شُغل عن أهل النار وعمّا هم فيه، لا يهمهم أمرُهم، ولا يذكرونهم{11}. (ز) ٦٤٨١٠- قال مقاتل بن سليمان: ثم قال -جلَّ وعزَّ-: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ﴾</q> في الآخرة <q>﴿فِي شُغُلٍ﴾</q> يعني: شُغِلوا بالنعيم؛ بافتضاض العذارى عن ذِكر أهل النار، فلا يذكرونهم، ولا يهتمون بهم{12}. (ز) ٦٤٨١١- قال وكيع بن الجراح: <q>﴿فِي شُغُلٍ فاكِهُونَ﴾</q>، يعني: في السماع{13}. (ز) ٦٤٨١٢- قال يحيى بن سلّام: فأخبر بمصير أهل الإيمان وأهل الكفر، فقال: <q>﴿إنَّ أصْحابَ الجَنَّةِ اليَوْمَ﴾</q> يعني: في الآخرة <q>﴿فِي شُغُلٍ فاكِهُونَ﴾</q>{14}٥٤٤١. (ز) ٥٤٤١ اختلف السلف في معنى الشغل الذي وصف الله -جلَّ ثناؤه- أصحاب الجنة أنهم فيه يوم القيامة على أقوال: الأول: أنّه افتضاض العذارى. الثاني: أنّه النعمة. الثالث: أنهم في شغل عما فيه أهل النار. الرابع: أنه السماع. ولم يذكر ابنُ جرير (١٩/٤٦١-٤٦٢) غير الأقوال الثلاثة الأولى، ثم رجّح جميعها للعموم، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال كما قال الله -جل ثناؤه-: <q>﴿إن أصحاب الجنة﴾</q> وهم أهلها <q>﴿في شغل فاكهون﴾</q> بنِعَم بأنهم في شغل، وذلك الشغل الذي هم فيه نعمة، وافتضاض أبكار، ولهو، ولذة، وشغل عما يلقى أهل النار». وكذا رجّح ابنُ عطية (٧/٢٥٧) العموم، فقال: «وقال مجاهد: معناه: نعيم قد شغلهم. وهذا هو القول الصحيح، وتعيين شيء دون شيء لا قياس له». <q>﴿فَـٰكِهُونَ ۝٥٥﴾</q> - قراءات ٦٤٨١٣- عن الأعمش: في قراءة عبد الله [بن مسعود]: (فِي شُغُلٍ فَكِهِينَ){15}٥٤٤٢. (ز) ٥٤٤٢ رجح ابنُ جرير (١٩/٤٦٣) مستندًا إلى شهرة القراءة في قوله: <q>﴿فاكهون﴾</q> قراءة من قرأ ذلك بالألف، فقال: «والصواب من القراءة في ذلك عندي قراءة من قرأه بالألف؛ لأن ذلك هو القراءة المعروفة». وعلّق ابنُ عطية (٧/٢٥٨) عليها، فقال: «وقرأ جمهور الناس: <q>﴿فاكهون﴾</q>، معناه: أصحاب فاكهة، كما يقال: تامر، ولابِن، وشاحم، ولاحِم». <q>﴿فَـٰكِهُونَ ۝٥٥﴾</q> - تفسير الآية ٦٤٨١٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فاكِهُونَ﴾</q>، قال: فرِحون{16}. (١٢/٣٦٢) ٦٤٨١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فاكِهُونَ﴾</q>، قال: مُعجبون{17}. (١٢/٣٦٠) ٦٤٨١٦- قال الضحاك بن مزاحم: <q>﴿فاكِهُونَ﴾</q> مُعجبون بما هم فيه{18}. (ز) ٦٤٨١٧- عن الحسن البصري: قوله: <q>﴿فاكِهُونَ﴾</q> مسرورون{19}. (ز) ٦٤٨١٨- عن الحسن البصري= (ز) ٦٤٨١٩- وقتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿فِي شُغُلٍ فاكِهُونَ﴾</q>، قالا: أي: مُعجبون{20}. (ز) ٦٤٨٢٠- قال إسماعيل السُدِّيّ: <q>﴿فاكِهُونَ﴾</q> ناعمون{13}. (ز) ٦٤٨٢١- قال مقاتل بن سليمان: ثم قال -جلَّ وعزَّ-: <q>﴿فاكِهُونَ﴾</q>: ‹فَكِهُونَ› يعني: معجبين بما هم فيه شغل النعيم والكرامة ... ومن قرأ <q>﴿فاكهون﴾</q> يعني: ناعمين في ظلالِ كبار القصور ...{12}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٦٠، وابن أبي الدنيا (٢٧٦)، وعبد الله بن أحمد في زوائد الزهد -كما في حادي الأرواح ص١٨٢-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي الدنيا في صفة الجنة (٢٧٧)، وابن جرير ١٩/٤٦٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم، وابن مردويه. كما أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٢٢ (٣٣) من طريق الأوزاعي.أخرجه يحيى بن سلّام ٢/٨١٤ عن قتادة، وإسحاق البستي ص١٩٢ عن عكرمة من طريق أبي عمرو الكوفي. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم، وذكر عن أبي حاتم أنه قال: «هذا خطأٌ مِن السمع، إنما هو: افتضاض الأبكار». وقال ابن كثير في تفسيره ٦/٥٦٩: «وقال أبو حاتم: لعله غلط من المستمع، وإنما هو: افتضاض الأبكار».أخرجه سفيان الثوري (٢٥٠)، وابن جرير ١٩/٤٦٠.رُودِس: جزيرة ببلاد الروم مقابل الإسكندرية على ليلة منها في البحر. معجم البلدان ٣/٧٨.أخرجه عبد الله بن وهب في الجامع في تفسير القرآن ٢/١٤٤ (٢٩٣).تفسير مجاهد (٥٦١)، وأخرجه الفريابي -كما في التغليق ٤/٢٩١-، وابن جرير ١٩/٤٦١ بلفظ: في نعمة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٤٦١.تفسير الثعلبي ٨/١٣١، وفي تفسير البغوي ٧/٢٢ عن الكلبي فقط.تفسير مقاتل بن سليمان ٣/٥٨٢.تفسير الثعلبي ٨/١٣١.تفسير يحيى بن سلّام ٢/٨١٤.أخرجه ابن أبي داود في المصاحف (/٣٣١. و(فَكِهِينَ) قراءة شاذة، تروى أيضًا عن طلحة، والأعمش، وجماعة. انظر: مختصر ابن خالويه ص١٢٧، والمحرر الوجيز ٤/٤٥٩.أخرجه ابن جرير ١٩/٤٦٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٦٣ بلفظ: عجبون، والفريابي -كما في التغليق ٤/٢٩١-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٨/١٣١، وتفسير البغوي ٧/٢٢.علقه يحيى بن سلّام ٢/٨١٤.أخرجه عبد الرزاق ٢/١٤٥.تفسير الثعلبي ٨/١٣١.تفسير مقاتل بن سليمان ٣/٥٨٢.
36,56," <q>﴿هُمۡ وَأَزۡوَ ٰ⁠جُهُمۡ فِی ظِلَـٰلٍ عَلَى ٱلۡأَرَاۤىِٕكِ مُتَّكِـُٔونَ ۝٥٦﴾</q> - قراءات ٦٤٨٢٢- عن الأعمش: في قراءة عبد الله [بن مسعود]: (فِي ظُلَٰلٍ عَلى الأَرَآئِكِ مُتَّكِئِينَ){1}٥٤٤٣. (ز) ٥٤٤٣ ذكر ابنُ جرير (١٩/٤٦٤) هذه القراءة، وعلّق عليها، فقال: «قرأه بعضهم: ‹فِي ظُلَلٍ› بمعنى: جمع ظلة، كما تجمع الحلة: حُلَلًا». وعلّق عليها ابنُ عطية (٧/٢٥٨)، فقال: «وقرأ حمزة والكسائي ‹فِي ظُلَلٍ› وهي جمع ظلة، وهي قراءة طلحة، وعبد الله، وأبي عبد الرحمن، وهذه عبارة عن الملابس والمراتب من الحجال والستور ونحوها مِن الأشياء التي تظل، وهي زينة». وذكر ابن جرير قراءة من قرأ ذلك <q>﴿ظلال﴾</q>، ثم علّق عليها، فقال: «وقرأه آخرون: <q>﴿في ظلال﴾</q>؛ وإذا قرئ ذلك كذلك كان له وجهان: أحدهما: أن يكون مرادًا به جمع الظل الذي هو بمعنى الكن، فيكون معنى الكلمة حينئذ: هم وأزواجهم في كن لا يضحون لشمس كما يضحي لها أهل الدنيا؛ لأنه لا شمس فيها. والآخر: أن يكون مرادًا به: جمع ظلة، فيكون وجه جمعها كذلك نظير جمعهم الخلة في الكثرة: الخلال، والقلة: القلال». وعلّق عليها ابنُ عطية، فقال: «وقرأ جمهور القراء <q>﴿في ظلال﴾</q>، وهو جمع: ظل؛ إذ الجنة لا شمس فيها، وإنما هواؤها سجسج، كوقت الإسفار قبل طلوع الشمس، ويحتمل أن يكون جمع: ظلة، قال أبو علي: كبرمة وبرام، وغير ذلك، وقال منذر بن سعيد: <q>﴿ظِلالٍ﴾</q> جمع ظلة بكسر الظاء. وهي لغة في ظلة». <q>﴿هُمۡ وَأَزۡوَ ٰ⁠جُهُمۡ فِی ظِلَـٰلٍ عَلَى ٱلۡأَرَاۤىِٕكِ مُتَّكِـُٔونَ ۝٥٦﴾</q> - تفسير الآية ٦٤٨٢٣- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</q>، قال: هي السُّرر في الحِجال{2}{3}. (ز) ٦٤٨٢٤- عن عبد الله بن عباس -من طريق الأوزاعي- قال: والأرائك: السرر في جوْف الحجال، عليها الفرش منضودة في السماء فرسخًا{4}٥٤٤٤. (ز) ٥٤٤٤ ذكر ابنُ كثير (١١/٣٦٩) قول ابن عباس وغيره، ثم علّق، فقال: «قال ابن عباس، ومجاهد وعكرمة، ومحمد بن كعب، والحسن، وقتادة، والسُدِّيّ، وخصيف: <q>﴿الأرائك﴾</q> هي السرر تحت الحجال. قلت: نظيره في الدنيا هذه التخوت تحت البشاخين». ٦٤٨٢٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَزْواجُهُم﴾</q>، قال: حلائلهم{5}. (١٢/٣٦٣) ٦٤٨٢٦- عن مجاهد بن جبر -من طريق حصين- في قول الله: <q>﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</q>، قال: الأرائك: السرر عليها الحِجال{6}. (ز) ٦٤٨٢٧- عن عكرمة مولى ابن عباس -من طريق محمد- قال: <q>﴿عَلى الأَرائِكِ﴾</q> السُّرر في الحجال{7}. (ز) ٦٤٨٢٨- عن الحسن البصري -من طريق أبي رجاء- وسأله رجل عن الأرائك. فقال: هي الحِجال. وأهل اليمن يقولون: أريكة فلان= (ز) ٦٤٨٢٩- وسمعت عكرمة وسُئِل عنها، فقال: هي الحجال على السُّرر{7}٥٤٤٥. (ز) ٥٤٤٥ قال ابنُ عطية (٧/٢٥٨): «و<q>﴿الأَرائِكِ﴾</q>: السرر المفروشة، قال بعض الناس: من شروطها أن تكون عليها، حجلة وإلا فليست بأريكة، وبذلك قيدها ابن عباس ومجاهد والحسن وعكرمة. وقال بعضهم: الأريكة: السرير؛ كان عليه حجلة أو لم يكن». ٦٤٨٣٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</q>، قال: هي الحجال فيها السُّرر{9}. (ز) ٦٤٨٣١- قال محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿عَلى الأَرائِكِ مُتَّكِئُونَ﴾</q>، قال: على السُّرر في الحِجال{10}. (ز) ٦٤٨٣٢- قال مقاتل بن سليمان: <q>﴿هُمْ وأَزْواجُهُمْ﴾</q> يعني: الحور العين حلائلهم <q>﴿فِي ظِلالٍ﴾</q> ومَن قرأ <q>﴿فاكهون﴾</q> يعني: ناعمين في ظلالِ كبار القصور، <q>﴿عَلى الأَرائِكِ﴾</q> على السُّرر عليها الحجال <q>﴿مُتَّكِؤُنَ﴾</q>{11}. (ز) ٦٤٨٣٣- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿على الأرائك متكئون﴾</q>، قال: هُنَّ سُرُر في الحِجال{12}. (ز) ٦٤٨٣٤- قال يحيى بن سلّام: قال: <q>﴿هُمْ وأَزْواجُهُمْ فِي ظِلالٍ﴾</q> في حِجال، <q>﴿عَلى الأَرائِكِ﴾</q> على السرر في الحِجال <q>﴿مُتَّكِئُونَ﴾</q>{13}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣١. و(مُتَّكِئِينَ) بالياء قراءة شاذة. انظر: مختصر ابن خالويه ص١٢٧.الحِجال: جمع الحَجَلَةُ -بالتَّحْريك-: بَيْت كالقُبَّة يُسْتَر بالثِّياب وتكون له أزرارٌ كبارٌ. النهاية (حجل).أخرجه ابن جرير ١٩/٤٦٥.أخرجه عبد الله بن وهب في الجامع- تفسير القرآن ٢/٢٢ (٣٣).تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٦٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سفيان الثوري (٢٥١) بنحوه، وابن جرير ١٩/٤٦٥.أخرجه ابن جرير ١٩/٤٦٦.أخرجه ابن جرير ١٩/٤٦٦.أخرجه عبد الرزاق ٢/١٤٥، وابن جرير ١٩/٤٦٦.أخرجه عبد الرزاق ٢/١٤٥.تفسير مقاتل بن سليمان ٣/٥٨٢.أخرجه إسحاق البستي ص١٩٣.تفسير يحيى بن سلّام ٢/٨١٤.
36,57," <q>﴿لَهُمۡ فِیهَا فَـٰكِهَةࣱ وَلَهُم مَّا یَدَّعُونَ ۝٥٧﴾</q> - تفسير ٦٤٨٣٥- عن أبي أمامة، قال: إنّ الرجل مِن أهل الجنة لَيشتهي الشراب من شراب الجنة، فيجيء إليه الإبريقُ، فيقع في يده، فيشرب، فيعود إلى مكانه{1}. (١٢/٣٦٣) ٦٤٨٣٦- قال مقاتل بن سليمان: <q>﴿لَهُمْ فِيها﴾</q> في الجنة <q>﴿فاكِهَةٌ ولَهُمْ ما يَدَّعُونَ﴾</q> يتمنّون ما شاءوا من الخير{2}. (ز) ٦٤٨٣٧- قال يحيى بن سلّام: قال: <q>﴿لَهُمْ فِيها فاكِهَةٌ ولَهُمْ ما يَدَّعُونَ﴾</q> ما يشتهون، يكون في فِي أحدهم الطعامُ، فيخطر على باله طعامٌ آخر، فيتحول ذلك الطعام في فِيهِ، ويأكل مِن ناحيةٍ مِن البُسْرة بُسرًا، ثم يأكل مِن ناحية أخرى عنبًا، إلى عشرة ألوان أو ما شاء الله مِن ذلك، ويَصُفُّ الطيرُ بين يديه، فإذا اشتهى الطيرَ منها اضطرب، ثم صار بين يديه نَضيجًا؛ نصفه شواء، ونصفه قديرًا{3}، وكل ما اشتهت أنفسهم وجدوه، كقوله: <q>﴿وفِيها ما تَشْتَهِيهِ الأَنْفُسُ﴾</q> [الزخرف:٧١]{4}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في صفة الجنة (١٣٥).تفسير مقاتل بن سليمان ٣/٥٨٢.كذا في المطبوع، ولعله: قديدًا، بالدال.تفسير يحيى بن سلّام ٢/٨١٥.
36,58," <q>﴿سَلَـٰمࣱ قَوۡلࣰا مِّن رَّبࣲّ رَّحِیمࣲ ۝٥٨﴾</q> - قراءات ٦٤٨٣٨- عن الأعمش: في قراءة عبد الله [بن مسعود]: (سَلامًا قَوْلًا){1}٥٤٤٦. (ز) ٥٤٤٦ ذكر ابنُ جرير (١٩/٤٦٦-٤٦٧) هذه القراءة، وعلّق عليها، فقال: «وقد ذكر أنها في قراءة عبد الله: (سلامًا قولًا) على أن الخبر متناهٍ عند قوله: <q>﴿ولهم ما يدعون﴾</q>، ثم نصب (سلامًا) على التوكيد، بمعنى: مسلمًا قولًا». وأورد في رفع <q>﴿سلام﴾</q> في قراءة من قرأها كذلك وجهين، فقال: «في رفع <q>﴿سلام﴾</q> وجهان في قول بعض نحويي الكوفة: أحدهما: أن يكون خبرًا لـ<q>﴿ما يدعون﴾</q>، فيكون معنى الكلام: ولهم ما يدعون مسلم لهم خالص. وإذا وجه معنى الكلام إلى ذلك كان القول حينئذ منصوبًا توكيدًا خارجًا مِن السلام، كأنه قيل: ولهم فيها ما يدعون مسلم خالص حقًّا، كأنه قيل: قاله قولًا. والوجه الثاني: أن يكون قوله: <q>﴿سلام﴾</q> مرفوعًا على المدح، بمعنى: هو سلامٌ لهم قولًا مِن الله». ثم قال: «والذي هو أولى بالصواب على ما جاء به الخبر عن محمد بن كعب القرظي أن يكون <q>﴿سلام﴾</q> خبرًا لقوله: <q>﴿ولهم ما يدعون﴾</q>؛ فيكون معنى ذلك: ولهم فيها ما يدعون، وذلك هو سلام من الله عليهم، بمعنى: تسليم من الله، ويكون <q>﴿سلام﴾</q> ترجمة <q>﴿ما يدعون﴾</q>، ويكون القول خارجًا من قوله: سلام». واستدل ابنُ جرير على هذا بقول عمر بن عبد العزيز وقول محمد بن كعب الآتيين، ثم قال (١٩/٤٦٩) معلّقًا عليه: «فهذا القول الذي قاله محمد بن كعب ينبئ عن أن <q>﴿سلام﴾</q> بيان عن قوله: <q>﴿ما يدعون﴾</q>، وأن القول خارج من السلام». ٦٤٨٣٩- عن هارون، قال: في قراءة أُبَيّ [بن كعب]: (سَلامًا قَوْلًا){2}. (ز) <q>﴿سَلَـٰمࣱ قَوۡلࣰا مِّن رَّبࣲّ رَّحِیمࣲ ۝٥٨﴾</q> - تفسير الآية ٦٤٨٤٠- عن جابر، قال: قال رسول الله ﷺ: «بينا أهل الجنة في نعيمهم إذ سطع لهم نورٌ، فرفعوا رؤوسهم، فإذا الربُّ قد أشرف عليهم مِن فوقهم، فقال: السلام عليكم، يا أهل الجنة. وذلك قول الله: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q>. قال: فينظر إليهم، وينظرون إليه، فلا يلتفتوا إلى شيءٍ مِن النعيم ما داموا ينظرون إليه حتى يحتجب عنهم، ويبقى نورُه وبركتُه عليهم في ديارهم»{3}. (١٢/٣٦٣) ٦٤٨٤١- عن عبد الله بن عباس، في قوله: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q>، قال: فإنّ الله هو يُسَلِّم عليهم{4}٥٤٤٧. (١٢/٣٦٣) ٥٤٤٧ ذكر ابنُ كثير (١١/٣٧٠) قول ابن عباس، وعلّق عليه، فقال: «وهذا الذي قاله ابن عباس كقوله تعالى: <q>﴿تحيتهم يوم يلقونه سلام﴾</q> [الأحزاب:٤٤]». ٦٤٨٤٢- عن البراء [بن عازب] -من طريق محمد بن مالك- في قوله: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q>، قال: يسلِّم عليهم عند الموت{5}. (١٢/٣٦٤) ٦٤٨٤٣- عن عمر بن عبد العزيز -من طريق محمد بن كعب القرظي- قال: إذا فرغ اللهُ مِن أهل الجنة والنارِ أقبل اللهُ في ظُلَلٍ مِن الغمام والملائكة، قال: فيُسَلِّم على أهل الجنة في أول درجة، فيردون ﵇.= (ز) ٦٤٨٤٤- قال القرظي: وهذا في القرآن: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q>. فيقول: سلوني. فيقولون: ماذا نسألك، أيْ ربِّ. قال: بلى، سلوني. قالوا: نسألك -أي رب- رضاك. قال: رضائي أُدخلكم دار كرامتي. قالوا: يا رب، وما الذي نسألك؟! فوَعِزَّتك وجلالِك وارتفاعِ مكانك، لو قسَّمت علينا رِزْقَ الثقلين لأطعمناهم ولأسقيناهم ولألبسناهم ولأخْدَمْناهُم{6}، لا ينقصنا من ذلك شيئًا. قال: إنّ لدي مزيدًا. قال: فيفعل الله ذلك بهم في درجتهم، حتى يستوي في مجلسه. قال: ثم تأتيهم التُّحَفُ مِن الله، تحمله إليهم الملائكة. قال: وليس في الآخرة ليل ولا نصف نهار، إنما هو بكرة وعشيًّا، وذلك في القرآن، في آل فرعون: <q>﴿النّارُ يُعْرَضُونَ عَلَيْها غُدُوًّا وعَشِيًّا﴾</q> [غافر:٤٦]، وكذلك قال لأهل الجنة: <q>﴿ولَهُمْ رِزْقُهُمْ فِيها بُكْرَةً وعَشِيًّا﴾</q> [مريم:٦٢]، قال: وقال: واللهِ الذي لا إله إلا هو، لو أنّ امرأة من حور العين أطلعت سِوارها لأطفأ نورُ سوارِها الشمسَ والقمر، فكيف المُسوَّرة؟! وإنْ خلق الله شيئًا يلبسه إلا عليه مثلما عليها مِن ثياب أو حلي{7}. (١٢/٣٦٤) ٦٤٨٤٥- قال مقاتل بن سليمان: قوله ﷿: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q>، وذلك أنّ الملائكة تدخل على أهل الجنة مِن كل باب، يقولون: سلام عليكم -يا أهل الجنة- من ربكم الرحيم{8}. (ز) ٦٤٨٤٦- قال يحيى بن سلّام: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q> يأتي الملَك مِن عند الله إلى أحدهم، فلا يدخل عليه حتى يستأذن عليه؛ يطلب الإذن مِن البوّاب الأول، فيذكره للبوّاب الثاني، ثم كذلك حتى ينتهي إلى البوّاب الذي يليه، فيقول البوّاب له: مَلَك على الباب يستأذن. فيقول: ائذن له. فيدخل بثلاثة أشياء: بالسلام مِن الله، والتحفة، والهدية، وبأنّ الله عنه راض، وهو قوله: <q>﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</q> [الإنسان:٢٠]{9}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣١، وابن جرير ١٤/٢١٤. وهي قراءة شاذة، تروى أيضا عن أُبي، وعيسى الثقفي. انظر: المحتسب ٢/٢١٤.أخرجه إسحاق البستي ص١٩٣.أخرجه ابن ماجه ١/١٢٧ (١٨٤)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٨٣-.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢١٤.أي: لَجَعَلْنا لهم من يَخْدُمُهم. اللسان (خدم).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٣-٨٤ (١٨٧)، وابن جرير ١٩/٤٦٧-٤٦٩. وأورد السيوطي قول القرظي بنحوه، وعزاه إلى ابن جرير، وأبي نصر السجزي في الإبانة، وآخره: فيفعل ذلك بأهل كل درجة حتى ينتهي، ثم يأتيهم التحف من الله تحمله إليهم الملائكة.تفسير مقاتل بن سليمان ٣/٥٨٢.تفسير يحيى بن سلّام ٢/٨١٥-٨١٦.
36,59," <q>﴿وَٱمۡتَـٰزُوا۟ ٱلۡیَوۡمَ أَیُّهَا ٱلۡمُجۡرِمُونَ ۝٥٩﴾</q> - تفسير ٦٤٨٤٧- عن أبي هريرة، أنّ رسول الله ﷺ قال: «إذا كان يوم القيامة أمر الله جهنم، فيخرج منها عُنُق ساطِع مُظلِم، ثم يقول: <q>﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ أنْ لا تَعْبُدُوا الشَّيْطانَ إنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ * وأَنِ اعْبُدُونِي هَذا صِراطٌ مُسْتَقِيمٌ * ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا أفَلَمْ تَكُونُوا تَعْقِلُونَ * هَذِهِ جَهَنَّمُ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</q>، وامتازوا اليوم أيُّها المجرمون. فيتميز الناس ويجثون، وهي قوله: <q>﴿وتَرى كُلَّ أُمَّةٍ جاثِيَةً كُلُّ أُمَّةٍ تُدْعى إلى كِتابِها اليَوْمَ تُجْزَوْنَ ما كُنْتُمْ تَعْمَلُونَ﴾</q> [الجاثية:٢٨]»{1}. (ز) ٦٤٨٤٨- قال عبد الله بن عباس: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q> تفرَّقوا{2}. (ز) ٦٤٨٤٩- قال أبو العالية: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q> تَمَيَّزوا{3}. (ز) ٦٤٨٥٠- عن الحسن البصري، قال: إذا كان يومُ القيامة جمعَ اللهُ الناسَ على تلٍّ رفيع، ثم نادى منادٍ: امتازوا اليوم، أيها المجرمون{4}. (١٢/٣٦٤) ٦٤٨٥١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q>، قال: عُزِلوا عن كل خير{5}. (١٢/٣٦٥) ٦٤٨٥٢- قال إسماعيل السُدِّيّ: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q> كونوا على حِدَة{3}. (ز) ٦٤٨٥٣- قال مقاتل بن سليمان: <q>﴿وامْتازُوا﴾</q> واعتزلوا <q>﴿اليَوْمَ﴾</q> في الآخرة <q>﴿أيُّها المُجْرِمُونَ﴾</q> وذلك حين اختلط الإنسُ والجنُّ والدوابُّ؛ دوابُّ البرِ والبحرِ والطيرِ، فاقتصَّ بعضُهم مِن بعض، ثم قيل لهم: كونوا ترابًا. فكانوا ترابًا، فبقي الإنس والجن خليطين، إذ بعث الله ﷿ إليهم مناديًا: أن امتازوا اليوم. يقول: اعتزلوا اليوم -أيها المجرمون- مِن الصالحين{7}. (ز) ٦٤٨٥٤- قال يحيى بن سلّام: قال: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q> المشركون، أي: ليمتازوا عن الجنة إلى النار{8}. (ز) ٦٤٨٥٥- عن رَوّاد بن الجراح: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q>، قال: إذا كان يوم القيامة نادى منادٍ: أن ميِّزوا المسلمين مِن المجرمين، إلا صاحب الأهواء. يعني: يُترك صاحب الهوى مع المجرمين{4}. (١٢/٣٦٤) <q>﴿وَٱمۡتَـٰزُوا۟ ٱلۡیَوۡمَ أَیُّهَا ٱلۡمُجۡرِمُونَ ۝٥٩﴾</q> - آثار متعلقة بالآية ٦٤٨٥٦- عن ميمون أنه قرأ هذه الآية: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q> فَرَقَّ وبكى، وقال: ما سمع الناس قط. بنعتٍ أشد منه{4}. (١٢/٣٦٥) ",footnotes:1:أخرجه إسحاق بن راهويه في مسنده ١/٨٤ (١٠)، والبيهقي في البعث والنشور ١/٣٣٦-٣٤٤ (٦٠٩) كلاهما مطولًا، وابن جرير ١٩/٤٧٠ واللفظ له، من طريق محمد بن يزيد بن أبي زياد، عن رجل من الأنصار، عن محمد بن كعب القرظي، عن رجل من الأنصار، عن أبي هريرة به. إسناده ضعيف؛ لجهالة محمد بن يزيد بن أبي زياد، والرجلين الأنصاريين.تفسير الثعلبي ٨/١٣٣.تفسير الثعلبي ٨/١٣٣، وتفسير البغوي ٧/٢٣.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٨١٥، وابن جرير ١٩/٤٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ٨/١٣٣، وتفسير البغوي ٧/٢٣.تفسير مقاتل بن سليمان ٣/٥٨٢-٥٨٣.تفسير يحيى بن سلّام ٢/٨١٦.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.
36,60," <q>﴿أَلَمۡ أَعۡهَدۡ إِلَیۡكُمۡ یَـٰبَنِیۤ ءَادَمَ﴾</q> - تفسير ٦٤٨٥٧- عن إسماعيل السُدِّيّ، في قوله: <q>﴿ألَمْ أعْهَدْ إلَيْكُمْ﴾</q>، يقول: ألم أنهكم؟!{1}. (١٢/٣٦٥) ٦٤٨٥٨- قال مقاتل بن سليمان: <q>﴿ألَمْ أعْهَدْ إلَيْكُمْ﴾</q> الذين أُمروا بالاعتزال <q>﴿يا بَنِي آدَمَ﴾</q>{2}. (ز) <q>﴿أَن لَّا تَعۡبُدُوا۟ ٱلشَّیۡطَـٰنَۖ إِنَّهُۥ لَكُمۡ عَدُوࣱّ مُّبِینࣱ ۝٦٠﴾</q> - تفسير ٦٤٨٥٩- عن عطاء بن دينار الهذلي: أنّ عبد الملك بن مروان كتب إلى سعيد بن جبير يسأله عن هذه المسائل، فأجابه فيها: ... قال: وتسأل عن العبادة: والعبادة هي الطاعة، وذلك أنّه مَن أطاع الله فيما أمره به وفيما نهاه عنه فقد أتمَّ عبادة الله، ومَن أطاع الشيطان في دينه وعمله فقد عبد الشيطان، ألم تر أنّ الله قال للذين فرَّطوا: <q>﴿ألم أعهد إليكم يا بني آدم أن لا تعبدوا الشيطان﴾</q>. وإنما كانت عبادتُهم الشيطانَ أنهم أطاعوه في دينهم، فمِنهم مَن أمرهم فاتخذوا أوثانًا أو شمسًا أو قمرًا أو بشرًا أو ملكًا يسجدون له مِن دون الله، ولم يظهر الشيطانُ لأحد منهم فيتعبد له، أو يسجد له، ولكنهم أطاعوه فاتخذوها آلهة مِن دون الله، فلمّا جُمعوا جميعًا يوم القيامة في النار قال لهم الشيطان: <q>﴿إني كفرت بما أشركتمون من قبل﴾</q> [إبراهيم:٢٢]{3}. (ز) ٦٤٨٦٠- عن مكحول الشامي، في قوله: <q>﴿أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</q>، قال: إنّما عبادتُه طاعتُه{4}. (١٢/٣٦٥) ٦٤٨٦١- عن إسماعيل السُدِّيّ، قال: <q>﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</q>: يعني: ألا تطيعوا الشيطان في الشرك{5}. (ز) ٦٤٨٦٢- قال مقاتل بن سليمان: <q>﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ﴾</q> في الدنيا <q>﴿أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</q> يعني: إبليس وحده، ولا تطيعوه في الشرك؛ <q>﴿إنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ﴾</q> بيِّن العداوة{2}. (ز) ٦٤٨٦٣- قال يحيى بن سلّام: <q>﴿إنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ﴾</q> أنّهم عبدوا الأوثان بما وسوس إليهم الشيطان، فأمرهم بعبادتهم، فإنما عبدوا الشيطان{7}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٣.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/٣٤٦-٣٤٧.عزاه السيوطي إلى ابن المنذر.علقه يحيى بن سلام ٢/٨١٦.تفسير مقاتل بن سليمان ٣/٥٨٣.تفسير يحيى بن سلام ٢/٨١٦.
36,61," <q>﴿وَأَنِ ٱعۡبُدُونِیۚ هَـٰذَا صِرَ ٰ⁠طࣱ مُّسۡتَقِیمࣱ ۝٦١﴾</q> - تفسير ٦٤٨٦٤- قال مقاتل بن سليمان: <q>﴿وأَنِ اعْبُدُونِي﴾</q> يقول: وحِّدوني، <q>﴿هَذا﴾</q> التوحيد <q>﴿هَذا صِراطٌ مُسْتَقِيمٌ﴾</q> دين الإسلام؛ لأنّ غير دين الإسلام ليس بمستقيم{1}. (ز) ٦٤٨٦٥- قال يحيى بن سلّام: قال: <q>﴿وأَنِ اعْبُدُونِي﴾</q> لا تشركوا بي شيئًا، <q>﴿هَذا صِراطٌ مُسْتَقِيمٌ﴾</q> دين مستقيم، والصراط: الطريق، مستقيم على الجنة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٣.تفسير يحيى بن سلام ٢/٨١٦.
36,62," <q>﴿وَلَقَدۡ أَضَلَّ مِنكُمۡ جِبِلࣰّا كَثِیرًاۖ أَفَلَمۡ تَكُونُوا۟ تَعۡقِلُونَ ۝٦٢﴾</q> - قراءات ٦٤٨٦٦- عن أبي هريرة: أنّ النبي ﷺ قرأ: (ولَقَدْ أضَلَّ مِنكُمْ جِبِلًا) مخففة{1}. (١٢/٣٦٦) ٦٤٨٦٧- عن هارون، عن الحسن= (ز) ٦٤٨٦٨- وابن أبي اسحاق: <q>﴿ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا﴾</q> مثقلة.= (ز) ٦٤٨٦٩- والأعرج: (جِبْلًا) وهكذا أبلغني أهل الكوفة= (ز) ٦٤٨٧٠- وأبي عمرو ‹جُبْلًا› خفيفة{2}. (ز) ٦٤٨٧١- عن هذيل، أنه قرأ: ‹جُبُلًا› مخففة{3}٥٤٤٨. (١٢/٣٦٦) ٥٤٤٨ ذكر ابنُ جرير (١٩/٤٧١) في قوله: <q>﴿جبلا﴾</q> ثلاث قراءات، فقال: «واختلف القراء في قراءة ذلك، فقرأته عامة قراء المدينة وبعض الكوفيين: <q>﴿جِبلًّا﴾</q> بكسر الجيم وتشديد اللام، وكان بعض المكيين وعامة قراء الكوفة يقرؤونه: (جُبُلًا) بضم الجيم والباء وتخفيف اللام. وكان بعض قراء البصرة يقرؤه: ‹جُبْلًا› بضم الجيم وتسكين الباء». ثم علّق بقوله: «وكل هذه لغات معروفات». ثم رجّح قراءة من قرأ ذلك بكسر الجيم وتشديد اللام، وقراءة مَن قرأ ذلك بضم الجيم وتخفيف اللام مستندًا للإجماع، فقال: «غير أني لا أحب القراءة في ذلك إلا بإحدى القراءتين اللتين إحداهما بكسر الجيم وتشديد اللام، والأخرى بضم الجيم والباء وتخفيف اللام؛ لأن ذلك هو القراءة التي عليها عامة قرّاء الأمصار». <q>﴿وَلَقَدۡ أَضَلَّ مِنكُمۡ جِبِلࣰّا كَثِیرًاۖ أَفَلَمۡ تَكُونُوا۟ تَعۡقِلُونَ ۝٦٢﴾</q> - تفسير الآية ٦٤٨٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿جِبِلًّا كَثِيرًا﴾</q>، قال: خَلْقًا كثيرًا{4}. (١٢/٣٦٥) ٦٤٨٧٣- عن إسماعيل السُدِّيّ: <q>﴿ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا﴾</q> يعني: قد أغوى إبليسُ منكم <q>﴿جِبِلًّا﴾</q> يعني: خلقًا كثيرًا، فكفروا فلم يكونوا يعقلون، وأخبر عنهم، فقال: <q>﴿وقالُوا لَوْ كُنّا نَسْمَعُ أوْ نَعْقِلُ ما كُنّا فِي أصْحابِ السَّعِيرِ﴾</q> أي: لو كنا نسمع أو نعقل لآمَنّا في الدنيا، فلم نكن من أصحاب السعير. قال اللَّه: <q>﴿فاعْتَرَفُوا بِذَنْبِهِمْ فَسُحْقًا﴾</q> فبُعْدًا <q>﴿لأَصْحابِ السَّعِيرِ﴾</q> [الملك:١٠-١١]{5}. (ز) ٦٤٨٧٤- قال مقاتل بن سليمان: <q>﴿ولَقَدْ أضَلَّ مِنكُمْ﴾</q> ولقد أضل إبليسُ منكم عن الهدى <q>﴿جِبِلًّا﴾</q> خَلْقًا <q>﴿كَثِيرًا﴾</q>{6}. (ز) ٦٤٨٧٥- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿ولقد أضل منكم جبلا كثيرا﴾</q>، قال: خَلْقًا كثيرًا{7}. (ز) ٦٤٨٧٦- قال يحيى بن سلّام: قال: <q>﴿ولَقَدْ أضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا﴾</q> خَلْقًا كثيرًا؛ أضلَّ مِن كل ألف تسعمائة وتسعة وتسعين{8}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٢٧٢ (٢٩٨٠). قال الحاكم: «رواته كلهم ثقات، غير إسماعيل بن رافع، فإنهما لم يحتجا به». وقال الذهبي في التلخيص: «في إسناده إسماعيل بن رافع، هالك». وهي قراءة شاذة، تروى أيضًا عن الأعمش. انظر: مختصر ابن خالويه ص١٢٦.أخرجه إسحاق البستي في تفسيره ص١٩٤. و<q>﴿جِبِلًّا﴾</q> قراءة متواترة، قرأ بها نافع، وأبو جعفر، وعاصم، وقرأ أبو عمرو، وابن عامر: ‹جُبْلًا› بضم الجيم وإسكان الباء وتخفيف اللام، وقرأ روح: ‹جُبُلًّا› بضم الجيم والباء وتشديد اللام، وقرأ بقية العشرة كذلك إلا أنهم خففوا اللام. انظر: النشر ٢/٣٥٥، والإتحاف ص٤٦٩. وأما (جِبْلًا) بكسر الجيم، وإسكان الباء، فهي قراءة شاذة، تروى أيضًا عن حماد بن سلمة عن عاصم، وأشهب، والعقيلي. انظر: المحتسب ٢/٢١٦.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨١٦.تفسير مقاتل بن سليمان ٣/٥٨٣.أخرجه إسحاق البستي ص١٩٤.تفسير يحيى بن سلام ٢/٨١٦.
36,63," <q>﴿هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِی كُنتُمۡ تُوعَدُونَ ۝٦٣ ٱصۡلَوۡهَا ٱلۡیَوۡمَ بِمَا كُنتُمۡ تَكۡفُرُونَ ۝٦٤﴾</q> - تفسير ٦٤٨٧٧- قال مقاتل بن سليمان: <q>﴿هَذِهِ جَهَنَّمُ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</q> في الدنيا، <q>﴿اصْلَوْها اليَوْمَ﴾</q> في الآخرة <q>﴿بِما كُنْتُمْ تَكْفُرُونَ﴾</q> في الدنيا{1}. (ز) ٦٤٨٧٨- قال يحيى بن سلّام: قوله ﷿: <q>﴿هَذِهِ جَهَنَّمُ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</q> في الدنيا إن لم تؤمنوا، <q>﴿اصْلَوْها اليَوْمَ بِما كُنْتُمْ تَكْفُرُونَ﴾</q> في الدنيا{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٣.تفسير يحيى بن سلام ٢/٨١٧.
  36,64,""
36,65," <q>﴿ٱلۡیَوۡمَ نَخۡتِمُ عَلَىٰۤ أَفۡوَ ٰ⁠هِهِمۡ وَتُكَلِّمُنَاۤ أَیۡدِیهِمۡ وَتَشۡهَدُ أَرۡجُلُهُم بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٦٥﴾</q> - تفسير ٦٤٨٧٩- عن أنس، في قوله: <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</q>، قال: كُنّا عند النبيِّ ﷺ، فضحِك حتى بَدَتْ نَواجِذُه، قال: «هل تدرون مِمَّ ضَحِكْتُ؟». قلنا: لا، يا رسول الله. قال: «مِن مخاطبة العبد ربَّه، يقول: يا ربِّ، ألم تُجِرْني مِن الظلم؟ فيقول: بلى. فيقول: إنِّي لا أُجِيزُ عَلَيَّ إلا شاهدًا مِنِّي. فيقول: كفى بنفسك اليومَ عليك شهيدًا، وبالكرام الكاتبين شهودًا. فيُختم على فيه، ويُقال لأركانه: انطقي. فتنطق بأعماله، ثم يُخَلّى بينه وبين الكلام، فيقول: بُعدًا لكُنَّ وسُحقًا، فعنكُنَّ كنت أُناضِل»{1}. (١٢/٣٦٦) ٦٤٨٨٠- عن أبي موسى الأشعري -من طريق أبي بردة- قال: يُدْعى المؤمنُ للحساب يوم القيامة، فيَعرض عليه ربُّه عملَه فيما بينه وبينه، فيعترف، فيقول: أيْ ربِّ، عملتُ، عملتُ، عملتُ. فيغفر الله له ذنوبَه، ويستره منها، قال: فما على الأرض خليقة يَرى من تلك الذنوب شيئًا، وتبدو حسناته فودَّ أنّ الناس كلهم يرونها. ويُدعى الكافر والمنافق للحساب، فيعرض ربُّه عليه عمله، فيجحد، ويقول: أي ربِّ، وعِزَّتِك، لقد كتب عَلَيَّ هذا الملَكُ ما لم أعمل. فيقول له الملَكُ: أما عملتَ كذا، في يوم كذا، في مكان كذا؟ فيقول: لا، وعزتك، أي ربِّ، ما عملتُه. فإذا فعل ذلك خُتم على فيه، فإني أحسب أول ما ينطق مِنه لَفَخِذُه اليمنى. ثم تلا: <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</q> الآية{2}. (١٢/٣٦٨) ٦٤٨٨١- عن ابن جدعان، قال: سُئِل ابنُ عباس عن قوله: <q>﴿يوم لا ينطقون ولا يؤذن لهم فيعتذرون﴾</q> [المرسلات:٣٥-٣٦]، <q>﴿قالوا والله ربنا ما كنا مشركين﴾</q> [الأنعام:٢٣]، وقال: <q>﴿اليوم نختم على أفواههم وتكلمنا أيديهم وتشهد أرجلهم بما كانوا يكسبون﴾</q>. قال: فقال ابن عباس: إنّه يومٌ ذو ألوان{3}. (ز) ٦٤٨٨٢- عن عامر الشعبي -من طريق الأعمش- قال: يُقال للرجل يوم القيامة: عملتَ كذا وكذا. فيقول: ما عملتُ. فيُختم على فِيه، وتنطق جوارحُه، فيقول لجوارحه: أبْعَدَكُنَّ اللهُ، ما خاصمت إلا فيكُنَّ{4}. (١٢/٣٦٩) ٦٤٨٨٣- عن الحسن البصري، <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</q>، قال: أول ما ينطق مِن الإنسان فخذه اليمنى{5}. (١٢/٣٦٩) ٦٤٨٨٤- عن الحسن البصري: <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</q> هذا آخر مواطن يوم القيامة، فإذا خُتمت أفواههم لم يكن بعد ذلك إلا دخول النار{6}. (ز) ٦٤٨٨٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</q>، قال: كانت خصوماتٌ وكلام، وكان هذا آخره، أن خُتم على أفواههم{7}. (١٢/٣٦٩) ٦٤٨٨٦- عن إسماعيل السُدِّيّ، في قوله: <q>﴿اليَوْمَ﴾</q>: يعني: في الآخرة <q>﴿نَخْتِمُ عَلى أفْواهِهِمْ﴾</q> قال: فلا يتكلمون{8}. (١٢/٣٦٩) ٦٤٨٨٧- عن أسماء بن عبيد، قال: يُؤتى بابنِ آدم يوم القيامة ومعه جبلٌ مِن صُحُف، لكل ساعة صحيفة، فيقول الفاجر: وعِزَّتِك، لقد كتبوا عَلَيَّ ما لم أعمل. فعند ذلك يُختم على أفواههم، ويؤذن لجوارحهم في الكلام، فيكون أول ما يتكلم مِن جوارح ابن آدم فخذه اليسرى{9}. (١٢/٣٦٩) ٦٤٨٨٨- قال مقاتل بن سليمان: <q>﴿اليَوْمَ نَخْتِمُ﴾</q> وذلك أنهم سُئِلوا: <q>﴿أين شركاؤكم الذين كنتم تزعمون﴾</q>؟ [الأنعام:٢٢] فقالوا: <q>﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</q> [الأنعام: ٢٣]. فيختم الله -جلَّ وعزَّ- على أفواههم، وتتكلم أيديهم وأرجلهم بشركهم، فذلك قوله تعالى: <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ وتُكَلِّمُنا أيْدِيهِمْ وتَشْهَدُ أرْجُلُهُمْ بِما كانُوا يَكْسِبُونَ﴾</q> بما كانوا يقولون مِن الشِّرك{10}. (ز) ٦٤٨٨٩- قال يحيى بن سلّام: <q>﴿بِما كانُوا يَكْسِبُونَ﴾</q> أي: يعملون{11}. (ز) <q>﴿ٱلۡیَوۡمَ نَخۡتِمُ عَلَىٰۤ أَفۡوَ ٰ⁠هِهِمۡ وَتُكَلِّمُنَاۤ أَیۡدِیهِمۡ وَتَشۡهَدُ أَرۡجُلُهُم بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٦٥﴾</q> - آثار متعلقة بالآية ٦٤٨٩٠- عن أبي سعيد وأبي هريرة، قالا: قال رسول الله ﷺ: «يلقى العبدُ ربَّه، فيقول اللهُ: أي فُل{12}، ألم أُكرمك، وأسوِّدك، وأزوِّجك، وأسخِّر لك الخيل والإبل، وأذرك ترأسُ وترْبَعُ{13}؟ فيقول: بلى، أي رب. فيقول: أفَطِنتَ أنّك مُلاقِيَّ؟ فيقول: لا. فيقول: فإنِّي أنساك كما نسيتني. ثم يلقى الثاني، فيقول مثل ذلك، ثم يلقى الثالث، فيقول له مثل ذلك، فيقول: آمنتُ بك، وبكتابك، وبرسولك، وصليتُ، وصمتُ، وتصدقتُ. ويثني بخير ما استطاع، فيقول: ألا نبعث شاهدنا عليك؟ فيفكِّر في نفسه: مَن الذي يشهد عليَّ؟ فيُختم على فيه، ويقال لفخذه: انطقي. فتنطق فخذه ولحمه وعظامه بعمله، ما كان ذلك يُعذر من نفسه، وذلك المنافق، وذلك الذي يسخط الله عليه»{14}. (١٢/٣٦٧) ٦٤٨٩١- عن عقبة بن عامر، أنّه سمع رسول الله ﷺ يقول: «إنّ أول عَظْم مِن الإنسان يتكلم يوم يُختم على الأفواه: فخِذه مِن الرِّجل الشمال»{15}. (١٢/٣٦٧) ٦٤٨٩٢- عن بهز بن حكيم بن معاوية، عن أبيه، عن جدِّه، عن النبي ﷺ، قال: «إنّكم تُدعون، فيُفْدَم على أفواهكم بالفِدام{16}، فأول ما يُسأل عن أحدكم فخِذه وكفُّه»{17}. (ز) ٦٤٨٩٣- عن بسرة -وكانت من المهاجرات- قالت: قال رسول الله ﷺ: «عليكنَّ بالتسبيح، والتهليل، والتقديس، ولا تغفلن، واعقدن بالأنامل؛ فإنهنَّ مسئولات ومستنطقات»{18}. (١٢/٣٦٨) ",footnotes:1:أخرجه مسلم ٤/٢٢٨٠ (٢٩٦٩)، وابن أبي حاتم ٨/٢٥٥٩ (١٤٣٠١).أخرجه ابن جرير ١٩/٤٧٢-٤٧٣. وعزاه السيوطي إلى ابن أبي حاتم. وأخرج نحوه يحيى بن سلام ٢/٨١٧ مختصرًا.أخرجه إسحاق البستي ص١٩٤.أخرجه ابن جرير ١٩/٤٧٣.عزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلام ٢/٨١٧.أخرجه ابن جرير ١٩/٤٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٥٨٣-٥٨٤.تفسير يحيى بن سلام ٢/٨١٧.فُل: يا فلان. شرح النووي على صحيح مسلم ١٨/١٠٣.تربع: تأخذ المرباع الذي كانت ملوك الجاهلية تأخذه، وهو ربع الغنيمة. شرح النووي على صحيح مسلم ١٨/١٠٣.أخرجه الترمذي ٤/٤٢٥-٤٢٦ (٢٥٩٧). قال الترمذي: «هذا حديث صحيح غريب».أخرجه أحمد ٢٨/٦٠٢ (١٧٣٧٤)، وابن جرير ١٩/٤٧٣-٤٧٤، ٢٠/٤٠٩، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٨٦-، والثعلبي ٨/١٣٤. وأصله عند مسلم ٤/٢٢٧٩ (٢٩٦٨)، وابن أبي حاتم ٤/١٢٨٠ (٧٢٢٢) مختصرًا، من حديث أبي هريرة. قال ابن كثير: «وقد جوّد إسنادَه الإمامُ أحمد». وقال الهيثمي في المجمع ١٠/٣٥١ (١٨٣٩٩): «رواه أحمد، والطبراني، وإسنادهما جيد». وقال المظهري في تفسيره ٦/٤٨٣: «وأخرج أحمد بسند جيد».الفِدام: ما يشد على فم الإبريق والكوز مِن خرقة لتصفية الشراب الذي فيه، أي: أنهم يمنعون الكلام بأفواههم حتى تتكلم جوارحهم، فشبه ذلك بالفِدام. النهاية (فدم).أخرجه أحمد ٣٣/٢٣٦-٢٣٧ (٢٠٠٣٧)، ٣٣/٢٤٢ (٢٠٠٤٣) مطولًا، وعبد الرازق ٣/١٥١ (٢٦٩٩)، وابن جرير ٢٠/٤٠٨-٤٠٩. صحّحه الألباني في الصحيحة ٦/٤٧٩ (٢٧١٣).أخرجه الترمذي ٦/١٧٩-١٨٠ (٣٩٠٠)، وأبو داود ٢/٦١٦ (١٥٠١)، وابن حبان ٣/١٢٢ (٨٤٢)، والحاكم ١/٧٣٢ (٢٠٠٧). قال الترمذي: «هذا حديث إنما نعرفه من حديث هانئ بن عثمان، وقد رواه محمد بن ربيعة عن هانئ بن عثمان». وقال العراقي في تخريج أحاديث الإحياء ص٣٥٦: «بإسناد جيد». وقال الألباني في صحيح أبي داود ٥/٢٣٦ (١٣٤٥): «حديث حسن».
36,66," <q>﴿وَلَوۡ نَشَاۤءُ لَطَمَسۡنَا عَلَىٰۤ أَعۡیُنِهِمۡ فَٱسۡتَبَقُوا۟ ٱلصِّرَ ٰ⁠طَ فَأَنَّىٰ یُبۡصِرُونَ ۝٦٦﴾</q> - نزول الآية ٦٤٨٩٤- قال مقاتل بن سليمان: <q>﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</q> نزلت في كفار مكة{1}. (ز) <q>﴿وَلَوۡ نَشَاۤءُ لَطَمَسۡنَا عَلَىٰۤ أَعۡیُنِهِمۡ﴾</q> - تفسير ٦٤٨٩٥- عن عبد الله بن عباس -من طريق علي- <q>﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</q>، قال: أعميناهم، وأضللناهم عن الهدى{2}. (١٢/٣٧٠) ٦٤٨٩٦- قال عبد الله بن عباس= (ز) ٦٤٨٩٧- وقتادة بن دعامة= (ز) ٦٤٨٩٨- ومقاتل= (ز) ٦٤٨٩٩- وعطاء: <q>﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</q>، معناه: لو نشاء لفقأنا أعين ضلالتهم، فأعميناهم عن غيِّهم، وحوّلنا أبصارهم مِن الضلالة إلى الهدى، فأبصروا رشدهم، فأنّى يبصرون ولم أفعل ذلك بهم؟!{3}. (ز) ٦٤٩٠٠- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿ولَوْ نَشاءُ لَطَمَسْنا﴾</q>، قال: لو شاء الله لتركهم عُمْيًا يَتَرَدَّدون{4}. (١٢/٣٧٠) ٦٤٩٠١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ فاسْتَبَقُوا الصِّراطَ فَأَنّى يُبْصِرُونَ﴾</q>، يقول: لو شئنا لتركناهم عُميًا يَتَرَدَّدون{5}٥٤٤٩. (١٢/٣٧١) ٥٤٤٩ ذكر ابنُ عطية (٧/٢٦٢ ط: دار الكتب العلمية) قول قتادة وقول الحسن، ثم علّق عليهما، فقال: «وقال الحسن بن أبي الحسن، وقتادة: أراد الأعين حقيقة، والمعنى: لأعميناهم فلا يرون كيف يمشون. ويؤيد هذا مجانسة المسخ للعمى الحقيقي». ٦٤٩٠٢- قال مقاتل بن سليمان: <q>﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</q> نزلت في كفار مكة، يقول: لو نشاء لحوّلنا أبصارهم مِن الضلالة إلى الهدى{6}. (ز) ٦٤٩٠٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولَوْ نَشاءُ لَطَمَسْنا عَلى أعْيُنِهِمْ﴾</q>، يعني: المشركين{7}٥٤٥٠. (ز) ٥٤٥٠ اختلف السلف في تفسير قوله: <q>﴿ولو نشاء لطمسنا أعينهم...﴾</q> الآيةَ على قولين: الأول: أن معنى ذلك: ولو نشاء لأعميناهم عن الهدى، وأضللناهم عن قصد المحجة. وهو مروي عن ابن عباس، وعطاء، ومقاتل. الثاني: أنّ معنى ذلك: ولو نشاء لتركناهم عميًا. وهو مروي عن الحسن، وقتادة. وقد ذكر ابنُ جرير (١٩/٤٧٥) القولين، ثم قال مرجّحًا القول الثاني، ومنتقدًا القول الأول مستندًا إلى الدلالة العقلية: «وهذا القول الذي ذكرناه عن الحسن وقتادة أشبه بتأويل الكلام؛ لأنّ الله إنما تهدد به قومًا كُفارًا، فلا وجه لأن يُقال وهم كفار: لو نشاء لأضللناهم. وقد أضلهم، ولكنه قال: لو نشاء لعاقبناهم على كفرهم، فطمسنا على أعينهم، فصيرناهم عميًا لا يبصرون طريقًا، ولا يهتدون له. والطمس على العين: هو أن لا يكون بين جفني العين غر، وذلك هو الشق الذي بين الجفنين، كما تطمس الريح الأثر، يقال: أعمى مطموس وطميس». <q>﴿فَٱسۡتَبَقُوا۟ ٱلصِّرَ ٰ⁠طَ﴾</q> - تفسير ٦٤٩٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فاسْتَبَقُوا الصِّراطَ﴾</q>، قال: الطريق{8}. (١٢/٣٧٠) ٦٤٩٠٥- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿فاسْتَبَقُوا الصِّراطَ﴾</q>، أي: الطريق{9}. (ز) ٦٤٩٠٦- قال مقاتل بن سليمان: <q>﴿فاسْتَبَقُوا الصِّراطَ﴾</q> ولو طمستُ الكفار لاستبقوا الصراط، يقول: لأبصروا طريق الهدى، <q>﴿فَأَنّى يُبْصِرُونَ﴾</q> فمِن أين يبصرون الهُدى إن لم أُعم عليهم طريق الضلالة{1}. (ز) ٦٤٩٠٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فاسْتَبَقُوا الصِّراطَ﴾</q>، قال: الصراط: الطريق{11}. (ز) <q>﴿فَأَنَّىٰ یُبۡصِرُونَ ۝٦٦﴾</q> - تفسير ٦٤٩٠٨- عن عبد الله بن عباس -من طريق علي- <q>﴿فَأَنّى يُبْصِرُونَ﴾</q>، قال: فكيف يهتدون؟!{12}. (١٢/٣٧٠) ٦٤٩٠٩- عن عبد الله بن عباس -من طريق عطية- <q>﴿فَأَنّى يُبْصِرُونَ﴾</q>، يقول: لا يبصرون الحقَّ{13}. (ز) ٦٤٩١٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَأَنّى يُبْصِرُون﴾</q>: وقد طمسنا على أعينهم{14}٥٤٥١. (١٢/٣٧٠) ٥٤٥١ ذكر ابنُ جرير (١٩/٤٧٦) قول مجاهد، وقدّم له بقوله: «وقوله: <q>﴿فأنى يبصرون﴾</q> يقول: فأي وجه يبصرون أن يسلكوه من الطرق، وقد طمسنا على أعينهم؟!». ثم قال: «وقال الذين وجهوا تأويل قوله: <q>﴿ولو نشاء لطمسنا على أعينهم﴾</q> إلى أنه معني به: العمى عن الهدى؛ تأويل قوله: <q>﴿فأنى يبصرون﴾</q>: فأنى يهتدون للحق». وذكر قولي ابن عباس. ٦٤٩١١- عن الحسن= (ز) ٦٤٩١٢- والسُدِّيّ: <q>﴿فَأَنّى يُبْصِرُونَ﴾</q> فكيف يبصرون وقد أعمينا أعينهم؟!{15}. (ز) ٦٤٩١٣- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿فَأَنّى يُبْصِرُونَ﴾</q> فكيف يُبِصرون إذا أغشيناهم؟!{16}. (ز) ٦٤٩١٤- قال مقاتل بن سليمان: <q>﴿فَأَنّى يُبْصِرُونَ﴾</q> فمِن أين يبصرون الهدى إن لم أُعَمِّ عليهم طريق الضلالة؟!{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٤.أخرجه ابن جرير ١٩/٤٧٤، والبيهقي في الأسماء والصفات (٣٠٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٨/١٣٥، وتفسير البغوي ٦/٢٥.أخرجه ابن جرير ١٩/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٥ من طريق معمر بلفظ:«لو نشاء لجعلناهم عميًا لا يترددون» وابن جرير ١٩/٤٧٥ واللفظ له، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٥٨٤تفسير يحيى بن سلام ٢/٨١٧.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ٢/٨١٧، وابن جرير ١٩/٤٧٦.تفسير مقاتل بن سليمان ٣/٥٨٤.أخرجه ابن جرير ١٩/٤٧٦.أخرجه ابن جرير ١٩/٤٧٦، والبيهقي في الأسماء والصفات (٣٠٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٧٧.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٦/٢٥.أخرجه يحيى بن سلام ٢/٨١٧.تفسير مقاتل بن سليمان ٣/٥٨٤.
36,67," <q>﴿وَلَوۡ نَشَاۤءُ لَمَسَخۡنَـٰهُمۡ عَلَىٰ مَكَانَتِهِمۡ فَمَا ٱسۡتَطَـٰعُوا۟ مُضِیࣰّا وَلَا یَرۡجِعُونَ ۝٦٧﴾</q> - قراءات ٦٤٩١٥- عن الحسن -من طريق إسماعيل-: <q>﴿لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</q>، وقد اختلف فيها عنه{1}. (ز) <q>﴿وَلَوۡ نَشَاۤءُ لَمَسَخۡنَـٰهُمۡ عَلَىٰ مَكَانَتِهِمۡ فَمَا ٱسۡتَطَـٰعُوا۟ مُضِیࣰّا وَلَا یَرۡجِعُونَ ۝٦٧﴾</q> - تفسير الآية ٦٤٩١٦- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ﴾</q> قال: أهلكناهم، <q>﴿عَلى مَكانَتِهِمْ﴾</q> قال: في مساكنهم{2}. (١٢/٣٧٠) ٦٤٩١٧- عن الحسن البصري -من طريق أبي رجاء- <q>﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</q>، قال: لو نشاء لأقعدناهم{3}. (ز) ٦٤٩١٨- عن أبي صالح باذام، في قوله: <q>﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ﴾</q>، يقول: لَجعلناهم حجارة{4}. (١٢/٣٧٠) ٦٤٩١٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</q> قال: لو نشاء لجعلناهم كُسحًا لا يقومون، <q>﴿فَما اسْتَطاعُوا مُضِيًّا ولا يَرْجِعُونَ﴾</q> قال: فلم يستطيعوا أن يتقدموا ولا يتأخروا{5}. (١٢/٣٧١) ٦٤٩٢٠- قال مقاتل بن سليمان: ثم خوّفهم، فقال -جلَّ وعزَّ-: <q>﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</q> يقول تعالى: لو شئتُ لمسختهم حجارةً في منازلهم ليس فيها أرواح، <q>﴿فَما اسْتَطاعُوا مُضِيًّا ولا يَرْجِعُونَ﴾</q> يقول: لا يتقدمون ولا يتأخرون{6}. (ز) ٦٤٩٢١- قال يحيى بن سلّام: <q>﴿ولَوْ نَشاءُ لَمَسَخْناهُمْ عَلى مَكانَتِهِمْ﴾</q> قال: ولو نشاء لأقعدناهم على أرجلهم، <q>﴿فَما اسْتَطاعُوا مُضِيًّا ولا يَرْجِعُونَ﴾</q> فما استطاعوا إذا فعلنا ذلك بهم أن يتقدَّموا أو يتأخروا{7}٥٤٥٢. (ز) ٥٤٥٢ اختلف السلف في تفسير قوله: <q>﴿ولو نشاء لمسخناهم على مكانتهم﴾</q> على أقوال: الأول: أن معناه: ولو نشاء لأقعدناهم في منازلهم؛ فلا يستطيعون أن يمضوا أمامهم، ولا أن يرجعوا وراءهم. الثاني: أن معناه: ولو نشاء لأهلكناهم في منازلهم. الثالث: أن معناه: ولو نشاء لجعلناهم حجارة. وقد اختار ابنُ جرير (١٩/٤٧٧) القول الأول مستندًا لأقوال السلف. ",footnotes:1:أخرجه إسحاق البستي ص١٩٥. وقد ذكر أبو حيان في البحر المحيط ٧/٣٤٤ عن الحسن أنه قرأ: <q>﴿على مكانتهم﴾</q> بالإفراد. وقال القرطبي في الجامع لأحكام القرآن ١٥/٥٠: قرأ الحسن والسلمي وزر بن حبيش وعاصم في رواية أبي بكر: ‹مَكاناتِهِمْ› على الجمع، الباقون بالتوحيد. وهما متواترتان، فقرأ شعبة عن عاصم ‹عَلى مَكاناتِهِمْ› بالجمع، وقرأ بقية العشرة <q>﴿عَلى مَكانَتِهِمْ﴾</q> بالإفراد. ينظر: النشر ٢/٢٦٣، والإتحاف ص٤٦٩.أخرجه ابن جرير ١٩/٤٧٧-٤٧٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٤٧٧.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٥ من طريق معمر مقتصرًا على شطره الأول، وابن جرير ١٩/٤٧٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر شطره الأول. وعزا إلى ابن أبي حاتم شطره الثاني.تفسير مقاتل بن سليمان ٣/٥٨٤.تفسير يحيى بن سلام ٢/٨١٧.
36,68," <q>﴿وَمَن نُّعَمِّرۡهُ نُنَكِّسۡهُ فِی ٱلۡخَلۡقِۚ أَفَلَا یَعۡقِلُونَ ۝٦٨﴾</q> - قراءات ٦٤٩٢٢- عن هارون، عن الأعمش: <q>﴿نُنَكِّسْهُ﴾</q> مِن النكس.= (ز) ٦٤٩٢٣- قال الأعرج= (ز) ٦٤٩٢٤- والحسن= (ز) ٦٤٩٢٥- وأبو عمرو: ‹نَنكُسْهُ فِي الخَلْقِ أفَلا يَعْقِلُونَ›{1}. (ز) ٦٤٩٢٦- عن هارون، عن نوح، عن الحسن: <q>﴿أفَلا يَعْقِلُونَ﴾</q>= (ز) ٦٤٩٢٧- وكذلك قراءة الأعرج{2}. (ز) <q>﴿وَمَن نُّعَمِّرۡهُ نُنَكِّسۡهُ فِی ٱلۡخَلۡقِۚ أَفَلَا یَعۡقِلُونَ ۝٦٨﴾</q> - تفسير الآية ٦٤٩٢٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ومَن نُعَمِّرْهُ﴾</q> يقول: مَن نُمِدُّ له في العمر <q>﴿نُنَكِّسْهُ فِي الخَلْقِ﴾</q> لكيلا يعلم بعد عِلْمٍ شَيئًا، يعني: الهرم{3}. (١٢/٣٧٢) ٦٤٩٢٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ومَن نُعَمِّرْهُ نُنَكِّسْهُ فِي الخَلْقِ﴾</q>، قال: هو الهرِم، يتغيّر سمعُه وبصرُه وقوتُه، كما رأيت{4}. (١٢/٣٧١) ٦٤٩٣٠- عن عبد الملك ابن جريج، في قوله:<q>﴿ومَن نُعَمِّرْهُ نُنَكِّسْهُ فِي الخَلْقِ﴾</q>، قال: نَرُدُّه إلى أرذل العمر{5}. (١٢/٣٧١) ٦٤٩٣١- قال مقاتل بن سليمان: <q>﴿ومَن نُعَمِّرْهُ﴾</q> فنطول عمره <q>﴿نُنَكِّسْهُ فِي الخَلْقِ أفَلا يَعْقِلُونَ﴾</q>{6}. (ز) ٦٤٩٣٢- عن سفيان، في قوله: <q>﴿ومَن نُعَمِّرْهُ نُنَكِّسْهُ﴾</q>، قال: ثمانين سنة{7}. (١٢/٣٧٢) ٦٤٩٣٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿ومَن نُعَمِّرْهُ﴾</q> أي: إلى أرذل العمر <q>﴿نُنَكِّسْهُ فِي الخَلْقِ﴾</q> فيكون بمنزلة الصبيِّ الذي لا يعقل، كقوله: <q>﴿ومِنكُمْ مَن يُرَدُّ إلى أرْذَلِ العُمُرِ لِكَيْلا يَعْلَمَ مِن بَعْدِ عِلْمٍ شَيْئًا﴾</q> [الحج:٥]، قال: <q>﴿أفَلا يَعْقِلُونَ﴾</q> يعني به: المشركين، أي: فالذي خلقكم، ثم جعلكم شبابًا، ثم جعلكم شيوخًا، ثم نكَّسكم في الخلق، فردَّكم بمنزلة الطفل الذي لا يعقل شيئًا قادِر على أن يبعثكم يوم القيامة{8}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص١٩٥. و<q>﴿نُنَكِّسْهُ﴾</q> قراءة متواترة، قرأ بها عاصم، وحمزة، وقرأ بقية العشرة: ‹نَنْكُسْهُ› بفتح النون الأولى، وإسكان الثانية، وضم الكاف. انظر: النشر ٢/٣٥٥، والإتحاف ص٤٦٩.أخرجه إسحاق البستي في تفسيره ص١٩٥. وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، وعاصم، وحمزة، والكسائي، وخلف، وهشام، وقرأ نافع، وأبو جعفر، ويعقوب، وابن ذكوان: ‹أفَلا تَعْقِلُونَ› بالتاء. انظر: النشر ٢/٢٥٧، والإتحاف ص٤٦٩.أخرجه ابن جرير ١٩/٤٧٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٨٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ٢/٨١٧-٨١٨.
36,69," <q>﴿وَمَا عَلَّمۡنَـٰهُ ٱلشِّعۡرَ وَمَا یَنۢبَغِی لَهُۥۤۚ إِنۡ هُوَ إِلَّا ذِكۡرࣱ وَقُرۡءَانࣱ مُّبِینࣱ ۝٦٩﴾</q> - نزول الآية ٦٤٩٣٤- قال محمد بن السائب الكلبي: إنّ كُفّار مكة قالوا: إنّ محمدًا شاعر، وما يقوله شعر. فأنزل الله تكذيبًا لهم: <q>﴿وما عَلَّمْناهُ الشِّعْرَ وما يَنْبَغِي لَهُ﴾</q>{1}. (ز) ٦٤٩٣٥- قال مقاتل بن سليمان: <q>﴿وما عَلَّمْناهُ الشِّعْرَ﴾</q> نزلت في عقبة بن أبي مُعَيط وأصحابه، قالوا: إنّ القرآن شِعر{2}. (ز) <q>﴿وَمَا عَلَّمۡنَـٰهُ ٱلشِّعۡرَ وَمَا یَنۢبَغِی لَهُۥۤۚ﴾</q> - تفسير ٦٤٩٣٦- عن قتادة بن دعامة، في قوله: <q>﴿وما عَلَّمْناهُ الشِّعْرَ وما يَنْبَغِي لَهُ﴾</q>، قال: محمد ﷺ عصمه الله مِن ذلك{3}. (١٢/٣٧٢) ٦٤٩٣٧- عن إسماعيل السُدِّيّ، في قوله: <q>﴿وما عَلَّمْناهُ الشِّعْرَ﴾</q>، قال: محمد ﷺ{4}. (١٢/٣٧٢) ٦٤٩٣٨- قال مقاتل بن سليمان: <q>﴿وما يَنْبَغِي لَهُ﴾</q> أن يَعلَمَه{2}٥٤٥٣. (ز) ٥٤٥٣ ذكر ابنُ عطية (٧/٢٦٤) في عود الضمير من قوله: <q>﴿وما ينبغي له﴾</q> احتمالين، فقال: «والضمير في <q>﴿لَهُ﴾</q> يحتمل أن يعود على محمد، ويحتمل أن يعود على القرآن، وإن كان لم يذكر لدلالة المجاورة عليه، ويبين ذلك قوله تعالى: <q>﴿إنْ هُوَ﴾</q>». ٦٤٩٣٩- قال يحيى بن سلّام: قوله ﷿: <q>﴿وما عَلَّمْناهُ الشِّعْرَ﴾</q> يعني: النبي ﵇، <q>﴿وما يَنْبَغِي لَهُ﴾</q> أن يكون شاعرًا ولا يروي الشعر{6}. (ز) <q>﴿إِنۡ هُوَ إِلَّا ذِكۡرࣱ وَقُرۡءَانࣱ مُّبِینࣱ ۝٦٩﴾</q> - تفسير ٦٤٩٤٠- قال الحسن البصري: <q>﴿ذِكْرٌ وقُرْآنٌ مُبِينٌ﴾</q> يذكرون به الجنة{7}. (ز) ٦٤٩٤١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنْ هُوَ إلّا ذِكْر﴾</q>، قال: هذا القرآن{8}. (١٢/٣٧٢) ٦٤٩٤٢- قال مقاتل بن سليمان: <q>﴿إنْ هُوَ﴾</q> يعني: القرآن <q>﴿إلّا ذِكْرٌ﴾</q> تفكُّر، <q>﴿وقُرْآنٌ مُبِينٌ﴾</q> بيِّن{2}. (ز) ٦٤٩٤٣- قال يحيى بن سلّام: <q>﴿إنْ هُوَ﴾</q> يعني: ما هو <q>﴿إلّا ذِكْرٌ﴾</q> يعني: ما هو إلا تَفَكُّر للعالمين لِمَن آمن مِن الجن والإنس. وقال بعضهم: <q>﴿إنْ هُوَ إلّا ذِكْرٌ﴾</q> تذكُّر في ذات الله، <q>﴿وقُرْآنٌ مُبِينٌ﴾</q> بيِّن{6}. (ز) <q>﴿إِنۡ هُوَ إِلَّا ذِكۡرࣱ وَقُرۡءَانࣱ مُّبِینࣱ ۝٦٩﴾</q> - آثار متعلقة بالآية ٦٤٩٤٤- عن قتادة، قال: بلغني: أنّه قيل لعائشة: هل كان رسول الله ﷺ يَتَمَثَّل بشيء من الشعر؟ قالت: كان أبغضَ الحديث إليه، غير أنّه كان يتمثل ببيت أخي بني قيس، يجعل أوله آخره، وآخره أوله ويقول: «ويأتيك من لم تزود بالأخبار». فقال له أبو بكر: ليس هكذا. فقال رسول الله ﷺ: «إني -واللهِ- ما أنا بشاعر، ولا ينبغي لي»{11}. (١٢/٣٧٢) ٦٤٩٤٥- عن عائشة، قالت: كان رسول الله ﷺ إذا استراث{12} الخبرَ تمثّل ببيت طرفة: ويأتيك بالأخبار من لم تُزَوِّد{13}. (١٢/٣٧٣) ٦٤٩٤٦- عن عائشة، قالت: ما جمع رسولُ الله ﷺ بيت شعر قطُّ إلا بيتًا واحدًا: «تفاءل بما تهوى يكن فلقلَّما يقال لشيء كان إلا تحقق» قالت عائشة: ولم يقل تحقَّقا. لئلا يعربه فيصير شعرًا{14}. (١٢/٣٧٤) ٦٤٩٤٧- عن المقدام بن شريح، عن أبيه، قال: قلت لعائشة: أكان رسول الله ﷺ يتمثَّل بشيء من الشعر؟ قالت: كان يتمثل مِن شعر عبد الله بن رواحة، قالت: وربما قال: ويأتيك بالأخبار من لم تزود{15}. (ز) ٦٤٩٤٨- عن ابن عباس، قال: كان رسول الله ﷺ يتمثل من الأشعار: ويأتيك بالأخبار من لم تزود{16}٥٤٥٤. (١٢/٣٧٣) ٥٤٥٤ ذكر ابنُ كثير (١١/٣٧٩-٣٨٠) بعض الآثار التي أفادت قول النبي ﷺ بعض الأشعار، ثم علّق قائلًا: «وكل هذا لا ينافي كونه ﷺ ما علم شعرًا ولا ينبغي له؛ فإن الله تعالى إنما علمه القرآن العظيم، الذي لا يأتيه الباطل من بين يديه ولا من خلفه تنزيل من حكيم حميد، وليس هو بشعرٍ كما زعمه طائفة مِن جهلة كفار قريش، ولا كهانة، ولا مفتعل، ولا سحر يؤثر، كما تنوعت فيه أقوال الضلال وآراء الجهال. وقد كانت سجيته ﷺ تأبى صناعة الشعر طبعًا وشرعًا». ٦٤٩٤٩- عن الحسن: أنّ النبي ﷺ كان يتمثل بهذا البيت: «كفى بالإسلام والشيب للمرء ناهيا». فقال أبو بكر: يا رسول الله، إنما قال الشاعر: كفى بالشيب والإسلام للمرء ناهيا فأعاده كالأول، فقال أبو بكر: أشهد أنك رسول الله، ما علّمك الشعر وما ينبغي لك{17}. (١٢/٣٧٣) ٦٤٩٥٠- عن عبد الرحمن بن أبي الزناد، أن النبي ﷺ قال للعباس بن مرداس: «أرأيت قولك: أصبح نَهِبي ونهبُ العبيد بين الأقرع وعُيينة». فقال أبو بكر: بأبي أنت وأمي، يا رسول الله، ما أنت بشاعر ولا راويه، ولا ينبغي لك، إنما قال: بين عُيينة والأقرع{18}. (١٢/٣٧٤) ٦٤٩٥١- عن عبد الله بن عمرو، سمعتُ رسول الله ﷺ يقول: «ما أبالي ما أتيتُ إن أنا شربتُ تِرياقًا، أو تعلّقتُ تميمة، أو قلتُ الشِّعر من قِبل نفسي»{19}. (١٢/٣٧٥) ٦٤٩٥٢- عن نوفل بن عقرب، قال: سألتُ عائشة: هل كان رسول الله ﷺ يتسامع عنده الشعر؟ قالت: كان أبغضَ الحديث إليه{20}. (١٢/٣٧٥) ",footnotes:1:تفسير البغوي ٧/٢٦.تفسير مقاتل بن سليمان ٣/٥٨٤.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٤.تفسير يحيى بن سلام ٢/٨١٨.علقه يحيى بن سلام ٢/٨١٨.أخرجه ابن جرير ١٩/٤٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٤.تفسير يحيى بن سلام ٢/٨١٨.أخرجه عبد الرزاق ٣/٨٦ (٢٤٩٦)، وابن جرير ١٩/٤٨٠، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٩٠-، والثعلبي ٨/١٣٦. إسناده ضعيف؛ لانقطاعه، فقد بلغ به قتادةُ عائشة، وأبهم الواسطة بينهما.استراث: أبطأ. النهاية (ريث).أخرجه أحمد ٤٠/٢٤ (٢٤٠٢٣)، ٤٢/٦٥ (٢٥١٣٤). قال الهيثمي في المجمع ٨/١٢٨ (١٣٣٤٧): «رجاله رجال الصحيح». وقال المناوي في التيسير ٢/٢٣٨: «بإسناد صحيح». وصحّحه الألباني في الصحيحة ٥/٨٩ (٢٠٥٧).أخرجه البيهقي في الكبرى ٧/٦٨-٦٩ (١٣٢٩١)، والخطيب في تاريخه ١١/٤٢٦ (٣٣٧١). قال البيهقي: «ولم أكتبه إلا بهذا الإسناد، وفيهم مَن يجهل حاله». وقال الخطيب: «غريب جدًّا، لم أكتبه إلا بهذا الإسناد». وقال ابن كثير في تفسيره ٦/٥٩٠: «سألت شيخنا الحافظ أبا الحجاج المزي عن هذا الحديث، فقال: هو منكر. ولم يعرف شيخ الحاكم، ولا الضرير».أخرجه أحمد ٤١/٥١٦ (٢٥٠٧١)، ٤٢/١٣١ (٢٥٢٣١)، ٤٣/٥١ (٢٥٨٦٢)، والترمذي ٥/١٢١-١٢٢ (٣٠٦٢). قال الترمذي: «هذا حديث حسن صحيح». وقال أبو نعيم في الحلية ٧/٢٦٤: «غريب، لم أكتبه إلا من هذا الوجه». وعلّق الألباني في الصحيحة على كلام الترمذي بقوله ٥/٨٩: «كذا قال، ولعله بالنظر إلى طريقيه، وإلا فشريك -وهو ابن عبد الله القاضي- سيئ الحفظ».أخرجه ابن أبي شيبة ٥/٢٧٢ (٢٦٠١٤)، والطبراني في الكبير ١١/٢٨٨ (١١٧٦٣). قال الهيثمي في المجمع ٨/١٢٨ (١٣٣٤٦): «رواه البزار، والطبراني في أثناء حديث، ورجالهما رجال الصحيح». وقال الألباني في الصحيحة ٥/٩٠: «وإسناده صحيح».أخرجه ابن سعد ١/٣٨٢-٣٨٣، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٧٤-، والمرزباني في معجم الشعراء -كما في الإصابة ٣/٢٥٠-.أخرجه ابن سعد٤/٢٧٣-٢٧٤.أخرجه أحمد ١١/١٢٥ (٦٥٦٥)، ١١/٦٥١-٦٥٢ (٧٠٨١)، وأبو داود ٦/١٧-١٨ (٣٨٦٩). قال الهيثمي في المجمع ٥/١٠٣ (٨٤٠١): «رواه الطبراني في الأوسط عن شيخه موسى بن عيسى بن المنذر الحمصي، ولم أعرفه، وبقية رجاله ثقات». وقال المناوي في التيسير ٢/٣٣٧: «قال الذهبي: هذا حديث منكر». وقال الرباعي في فتح الغفار ٤/١٩٩٦ (٥٨٠٤): «وفي إسناده عبد الرحمن بن رافع التنوخي قاضي أفريقية، قال البخاري: في حديثه مناكير».أخرجه أحمد ٤١/٤٧٥-٤٧٦ (٢٥٠٢٠)، ٤٢/٧٦ (٢٥١٥٠)، ٤٢/٣٥٨ (٢٥٥٥٤) عن أبي نوفل. قال الهيثمي في المجمع ٨/١١٩ (١٣٢٩٧): «ورجاله رجال الصحيح». وأورده البوصيري في إتحاف الخيرة ٦/١٤٤ (٥٥٢٣/٢) من مسند مسدّد بسنده، ثم قال: «هذا إسناد صحيح، على شرط مسلم». وأورده الألباني في الصحيحة ٧/٢٥٣ (٣٠٩٥).
36,70," <q>﴿لِّیُنذِرَ مَن كَانَ حَیࣰّا وَیَحِقَّ ٱلۡقَوۡلُ عَلَى ٱلۡكَـٰفِرِینَ ۝٧٠﴾</q> - تفسير ٦٤٩٥٣- عن الضحاك بن مزاحم -من طريق أبي روق- في قوله: <q>﴿لِيُنْذِرَ مَن كانَ حَيًّا﴾</q>، قال: عاقلًا{1}. (١٢/٣٧٥) ٦٤٩٥٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لِيُنْذِرَ مَن كانَ حَيًّا﴾</q>، قال: حي القلب، حي البصر{2}. (١٢/٣٧٢) ٦٤٩٥٥- قال إسماعيل السُدِّيّ: <q>﴿لِيُنْذِرَ مَن كانَ حَيًّا﴾</q>، يعني: مهتديًا، مؤمنًا في علم الله، هو الذي يقبل نذارتك{3}. (ز) ٦٤٩٥٦- قال مقاتل بن سليمان: <q>﴿لِيُنْذِرَ﴾</q> يعني: لتنذر -يا محمد- بما في القرآن مِن الوعيد <q>﴿مَن كانَ حَيًّا﴾</q> مَن كان مهديًّا في علم الله ﷿{4}. (ز) ٦٤٩٥٧- قال يحيى بن سلّام: <q>﴿لِيُنْذِرَ﴾</q> مِن النار، من قرأها بالياء يقول: لينذر القرآن. ومن قرأها بالتاء يقول: لتنذر يا محمد{5}. (ز) <q>﴿وَیَحِقَّ ٱلۡقَوۡلُ عَلَى ٱلۡكَـٰفِرِینَ ۝٧٠﴾</q> - تفسير ٦٤٩٥٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويحق القول على الكافرين﴾</q>: بأعمالهم؛ أعمال السوء{6}. (١٢/٣٧٢) ٦٤٩٥٩- قال مقاتل بن سليمان: <q>﴿ويَحِقَّ القَوْلُ﴾</q> ويجب العذاب <q>﴿عَلى الكافِرِينَ﴾</q> بتوحيد الله ﷿{4}. (ز) ٦٤٩٦٠- قال يحيى بن سلّام: <q>﴿ويَحِقَّ القَوْلُ﴾</q> الغضب <q>﴿عَلى الكافِرِينَ﴾</q>{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٨١، والبزار في البحر الزخار المعروف بمسند البزار ٨/١٧٩ (٣٢١١)، والبيهقي في شعب الإيمان (٤٦٥٣).أخرجه ابن جرير ١٩/٤٨١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨١٩.تفسير مقاتل بن سليمان ٣/٥٨٤.تفسير يحيى بن سلام ٢/٨١٩. قرأ المدنيان وابن عامر ويعقوب بالتاء، وقرأ الباقون بالياء. انظر: النشر ٢/٣٥٥.أخرجه ابن جرير ١٩/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٤.تفسير يحيى بن سلام ٢/٨١٩.
