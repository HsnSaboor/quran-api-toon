quran[19]{c,v,t}:
38,43," <q>﴿وَوَهَبۡنَا لَهُۥۤ أَهۡلَهُۥ وَمِثۡلَهُم مَّعَهُمۡ رَحۡمَةࣰ مِّنَّا وَذِكۡرَىٰ لِأُو۟لِی ٱلۡأَلۡبَـٰبِ ۝٤٣﴾</q> - تفسير ٦٦٨٥٠- قال الحسن البصري: وردّ عليه أهلَه وولدَه وأموالَه من البقر والغنم والحيوان وكل شيء هلك بعينه، ثم أبقاه الله فيها حتى وهب له مِن نسولها أمثالها، فهو قوله: <q>﴿ووَهَبْنا لَهُ أهْلَهُ ومِثْلَهُمْ مَعَهُمْ رَحْمَةً مِنّا﴾</q>، وكانوا ماتوا غيرَ الموت الذي أتى على آجالهم تسليطًا مِن الله للشيطان؛ فأحياهم الله، فوفّاهم آجالهم{1}. (ز) ٦٦٨٥١- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿ووَهَبْنا لَهُ أهْلَهُ ومِثْلَهُمْ مَعَهُمْ﴾</q>، قال: فأحياهم الله بأعيانهم، وزاده مثلهم معهم{2}. (ز) ٦٦٨٥٢- قال مقاتل بن سليمان: <q>﴿ووَهَبْنا لَهُ أهْلَهُ ومِثْلَهُمْ مَعَهُمْ﴾</q> فأضعف الله ﷿ له، وكان له سبعَ بنين وثلاثَ بنات قبل البلاء، وولدت له امرأتُه بعد البلاء سبعَ بنين وثلاثَ بنات، فأضعف الله له <q>﴿رَحْمَةً﴾</q> يعني: نعمة <q>﴿مِنّا﴾</q>، ثم قال: <q>﴿وذِكْرى﴾</q> يعني: تَفَكُّر <q>﴿لِأُولِي الأَلْبابِ﴾</q> يعني: أهل اللُّبِّ والعقل{3}. (ز) ٦٦٨٥٣- قال سفيان الثوري في قوله: <q>﴿ووَهَبْنا لَهُ أهْلَهُ﴾</q> قال: أحيينا له أهله، <q>﴿ومِثْلَهُمْ مَعَهُمْ﴾</q>{4}٥٥٧٨. (ز) ٥٥٧٨ أفادت الآثارُ أنّ الله تعالى ردَّ على أيوب أهلَه ومَن هلك مِن حاشيته ورعيته في الدنيا. وقد ذكر ابنُ عطية (٧/٣٥٣) هذا القول، وقولًا آخر: أنّ ذلك كله وعد في الآخرة. ثم علّق بقوله: «والأول أكثر في قول المفسرين». ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٤-.أخرجه ابن جرير ٢٠/١١٠.تفسير مقاتل بن سليمان ٣/٦٤٨.تفسير سفيان الثوري (٢٥٩).
38,44," <q>﴿وَخُذۡ بِیَدِكَ ضِغۡثࣰا فَٱضۡرِب بِّهِۦ وَلَا تَحۡنَثۡۗ﴾</q> - تفسير ٦٦٨٥٤- عن عبد الله بن عباس -من طريق يوسف بن مهران- قال: إنّ إبليس قعد على الطريق، واتَّخذ تابوتًا يداوي الناس، فقالت امرأةُ أيوب: يا عبد الله، إنّ ههنا مُبتلىً مِن أمره كذا وكذا، فهل لك أن تداويه؟ قال: نعم، بشرط إن أنا شفيته أن يقول: أنت شفيتَني. لا أريد منه أجرًا غيره، فأتت أيوبَ، فذكرت ذلك له، فقال: ويحكِ، ذاك الشيطانُ، لله عَلَيَّ إن شفاني اللهُ أن أجلدك مائة جلدة. فلمّا شفاه الله أمره أن يأخذ ضِغثًا، فيضربها به، فأخذ عِذقًا فيه مائة شِمْراخ{1}، فضربها به ضربة واحدة{2}. (١٢/٥٩٩) ٦٦٨٥٥- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: هو الأَثْل{3}. (١٢/٦٠٣) ٦٦٨٥٦- عن عبد الله بن عباس، <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: الضِّغث: القبضة من الرِّيحان الرَّطْب{4}. (١٢/٦٠٣) ٦٦٨٥٧- عن عبد الله بن عباس -من طريق علي- <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: حُزمة{5}. (١٢/٦٠٣) ٦٦٨٥٨- عن عبد الله بن عباس -من طريق عطية- <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: أُمر أن يأخذ ضِغثًا من رطبة بقدر ما حلف عليه، فيضرب به{6}. (ز) ٦٦٨٥٩- عن عبد الله بن عباس، في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>: وذلك أنّه أمره أن يأخذ ضِغثًا فيه مائة طاق{7} من عيدان القتِّ{8}، فيضرب به امرأتَه لليمين التي كان يحلف عليها. قال: ولا يجوز ذلك لأحد بعد أيوب إلا الأنبياء{9}. (١٢/٦٠٥) ٦٦٨٦٠- عن سعيد بن المسيب، أنه بلغه: أنّ أيوب حلف لَيضربن امرأتَه مائةً في أن جاءته بزيادة على ما كانت تأتي به مِن الخبز الذي كانت تعمل عليه، وخشي أن تكون قارفت شيئًا من الخيانة، فلمّا ﵀ وكشف عنه الضر عَلِم براءةَ امرأته مما اتهمها به، فقال الله ﷿: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</q>. فأخذ ضِغثًا من ثُمام{10}، وهو مائة عود، فضرب به كما أمره الله تعالى{4}. (١٢/٦٠٤) ٦٦٨٦١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: هي لأيوب خاصة= (ز) ٦٦٨٦٢- وقال عطاء: هي للناس عامَّة{12}. (١٢/٦٠٤) ٦٦٨٦٣- عن الضحاك بن مزاحم، <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: جماعة من الشجر، وكانت لأيوب خاصة، وهي لنا عامة{13}. (١٢/٦٠٤) ٦٦٨٦٤- عن الضحاك بن مزاحم -من طريق عبيد- قال في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>: يعني: ضِغثًا من الشجر الرَّطب، كان حلف على يمين، فأخذ مِن الشجر عددَ ما حلف عليه، فضرب به ضربة واحدة، فبرّت يمينه، وهو اليوم في الناس يمين أيوب، مَن أخذ بها فهو حسن{14}. (ز) ٦٦٨٦٥- عن الحسن: أنّ إبليس أتى امرأتَه، فقال لها: إن أكل أيوب ولم يُسَمِّ عوفي. فعرضت ذلك على أيوب، فحلف ليضربنها مائة، فلما عُوفي أمره الله أن يأخذ عرجونًا فيه مائة شِمراخ، فضربها ضربةً واحدةً{15}. (ز) ٦٦٨٦٦- قال يحيى بن سلّام: قال الحسن: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</q>، إنّ امرأة أيوب كانت قاربت الشيطان في بعض الأمر، ودعت أيوبَ إلى مقاربته؛ فحلف بالله لئن الله عافاه أن يجلدها مائة جلدة، ولم تكن له نِيَّةٌ بأيِّ شيء يجلدها، فمكث في ذلك البلاءِ حتى أذن الله له في الدعاء، وتمَّت له النعمة مِن الله والأجر، فأتاه الوحي مِن الله، وكانت امرأتُه مسلمةً قد أحسنت القيام عليه، وكانت لها عند الله منزلة، فأوحى الله إليه: أن يأخذ بيده ضغثًا -والضِّغث: أن يأخذ قبضة. قال بعضهم: مِن السنبل، وكانت مائة سنبلة. وقال بعضهم: من الأسَل، والأسَل: السمار{16}-، فيضربها به ضربة واحدة ففعل {17}. (ز) ٦٦٨٦٧- عن معاوية بن قرة، قال: ... الضِغث: أن يأخذ الحزمة مِن السياط، فيضرب بها الضربة الواحدة{18}. (١٢/٦٠١) ٦٦٨٦٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: عودًا فيه تسعة وتسعون عودًا، والأصل تمام المائة. وذلك أنّ امرأته قال لها الشيطان: قولي لزوجك يقول: كذا وكذا. فقالت له، فحلف أن يضربها مائةً، فضربها تلك الضربة، فكانت تحِلَّةً ليمينه، وتخفيفًا عن امرأته{19}. (١٢/٦٠٤) ٦٦٨٦٩- عن عبد الرحمن بن جبير -من طريق صفوان- قال: ابتُلِي أيوبُ بماله وولده وجسده، حتى طُرِح في المزبلة، جعلت امرأته تخرج تكسب عليه ما تطعمه، فحسده الشيطان على ذلك، فكان يأتي أصحابَ الخبز والشاء الذين كانوا يتصدقون عليها، فيقول: اطردوا هذه المرأة التي تغشاكم؛ فإنها تعالج صاحبَها، وتلمسه بيدها، فالناس يتقذَّرون طعامَكم مِن أجلها، إنها تأتيكم وتغشاكم. فجعلوا لا يدنونها منهم، ويقولون: تباعدي عَنّا، ونحن نطعمك ولا تقربينا. فأخبرت بذلك أيوب، فحمد الله على ذلك، وكان يلقاها إذا خرجت كالمتحزِّن بما لقي أيوب، فيقول: لَجَّ صاحبُك، وأبى إلا ما أتى، واللهِ، لو تكلم بكلمة واحدة لكُشف عنه كل ضر، ولرجع إليه ماله وولده. فتجيء فتخبر أيوب، فيقول لها: لقيك عدوُّ الله فلقّاك هذا الكلام! لئن أقامني اللهُ مِن مرضي لأجلدنك مائة. فلذلك قال الله تعالى: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</q>. يعني بالضِّغث: القبضة مِن المكانس{20}. (١٢/٦٠٢) ٦٦٨٧٠- عن عطاء [بن أبي رباح] -من طريق ابن جريج- في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: عيدانًا رطبة{14}. (ز) ٦٦٨٧١- قال مقاتل بن سليمان: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q> يعني بالضغث: القبضة الواحدة، فأخذ عيدانًا رطبة -وهي الأسل- مائة عود، عدد ما حلف عليه، وكان حلف ليجلدن امرأته مائة جلدة، <q>﴿فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</q> يعني: ولا تأثم في يمينك التي حلفت عليها، فعَمَدَ إليها، فضربها بمائة عود ضربة واحدة، فأوجعها، فبرئت يمينه، وكان اسمها: دنيا{22}. (ز) ٦٦٨٧٢- عن سفيان الثوري، في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</q>، قال: لم يُجعَل لأحدٍ بعده{23}. (ز) ٦٦٨٧٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</q>، قال: ضِغثًا واحدًا مِن الكلأ فيه أكثر من مائة عود، فضرب به ضربةً واحدةً، فذلك مائة ضربة{14}. (ز) <q>﴿وَخُذۡ بِیَدِكَ ضِغۡثࣰا فَٱضۡرِب بِّهِۦ وَلَا تَحۡنَثۡۗ﴾</q> - آثار متعلقة بالآية ٦٦٨٧٤- عن سهل بن سعد: أنّ النبي ﷺ أُتي بشيخ أحبن{25} مُصْفَرٍّ قد ظهرت عروقه، قد زنى بامرأة، فضربه بضغث فيه مائة شمراخ ضربة واحدة{26}. (١٢/٦٠٦) ٦٦٨٧٥- عن أبي أمامة بن سهل بن حنيف، قال: حملت وليدةٌ في بني ساعدة مِن زنًا، فقيل لها: مِمَّن حَمْلُكِ؟ قالت: مِن فلان المُقعَد. فسُئل المُقعَد، فقال: صدَقَتْ. فرفُع ذلك إلى رسول الله ﷺ، فقال: «خذوا له عُثكولًا{27} فيه مائة شِمراخ، فاضربوه به ضربةً واحدةً». ففعلوا{28}. (١٢/٦٠٥) ٦٦٨٧٦- عن سعيد بن سعد بن عبادة، قال: كان في أبياتنا إنسانٌ ضعيف مُخدَج{29}، فلم يُرَعْ أهلُ الدار إلا وهو على أمَة مِن إماء أهل الدار يخبث بها، وكان مسلمًا، فرفع سعدٌ شأنه إلى رسول الله ﷺ، فقال: «اضربوه حدَّه». فقالوا يا رسول الله، إنّه أضعف مِن ذلك، إن ضربناه مائة قتلناه. قال: «فخذوا له عِثكالًا فيه مائة شمراخ، فاضربوه ضربة واحدة، وخلّوا سبيله»{30}. (١٢/٦٠٥) ٦٦٨٧٧- عن عبد الله بن عبيد بن عمير، عن أبيه، قال: إذا حلف الرجلُ يضرب غلامه؛ حلَّل يمينَه بها، وضرب. وتأول هذه الآية: <q>﴿وخذ بيدك ضغثًا فاضرب به ولا تحنث﴾</q>{31}. (ز) ٦٦٨٧٨- عن عبد الواحد بن أيمن، عن عطاء، قال: أتاه رجل، فقال: إنِّي حلفت ألا أكسو امرأتي درعًا حتى تقف بعرفة. فقال: احملها على حمار، ثم اذهب، فقفْ بها عرفة. فقال: إنما عنيتُ يوم عرفة. فقال له عطاء: وأيوب حين حلف ليجلدن امرأته مئة جلدة؛ أنَوى أن يضربها بالضغث؟ إنما أمره الله أن يأخذ ضغثًا فيضربها به. قال عطاء: إنما القرآن عِبَر، إنما القرآن عِبَر{32}. (ز) ٦٦٨٧٩- عن وهب بن مُنَبِّه، قال: زوجة أيوب رحمة بنت منشأ بن يوسف بن يعقوب بن إسحاق بن إبراهيم ﵈{33}. (١٢/٦٠٧) <q>﴿إِنَّا وَجَدۡنَـٰهُ صَابِرࣰاۚ نِّعۡمَ ٱلۡعَبۡدُ إِنَّهُۥۤ أَوَّابࣱ ۝٤٤﴾</q> - تفسير ٦٦٨٨٠- قال مقاتل بن سليمان: ثم أثنى الله ﷿ على أيوب، فقال: <q>﴿إنّا وجَدْناهُ صابِرًا﴾</q> على البلاء، إضمار، <q>﴿نِعْمَ العَبْدُ إنَّهُ أوّابٌ﴾</q> يعني: مطيعًا لله تعالى. لما برأ أيوب فاغتسل كساه جبريل ﵇ حُلَّة{22}. (ز) <q>﴿إِنَّا وَجَدۡنَـٰهُ صَابِرࣰاۚ نِّعۡمَ ٱلۡعَبۡدُ إِنَّهُۥۤ أَوَّابࣱ ۝٤٤﴾</q> - آثار متعلقة بالآية ٦٦٨٨١- عن عبد الله بن مسعود -من طريق ابن سخبرة- قال: أيوب رأس الصابرين يوم القيامة{35}. (١٢/٦٠٦) ٦٦٨٨٢- عن عبد الله بن عباس: أنّ امرأة أيوب قالت: يا أيوب، إنّك رجل مباح{36} الدعوة، فادعُ الله أن يشفيك. فقال: ويحكِ، كُنّا في النعماء سبعين سنة، فدعِينا نكون في البلاء سبعين سنة. فكان في البلاء سبع سنين{13}. (١٢/٦٠٧) ٦٦٨٨٣- عن سعيد بن العاص، قال: نودي أيوب: يا أيوب، لولا أنِّي أفرغتُ مكان كل شعرة منك صبرًا ما صبرتَ{38}. (١٢/٦٠٧) ٦٦٨٨٤- عن الحسن البصري -من طريق مبارك- قال: كان أيوبُ كُلَّما أصابه مصيبةٌ؛ قال: اللهم، أنت أخذتَ، وأنت أعطيتَ، مهما تُبقي نفسي أحمدك على حُسن بلائك{39}. (١٢/٦٠٧) ٦٦٨٨٥- عن وهب بن مُنَبِّه -من طريق عمران بن الهذيل- أنه سمعه يقول: أصاب أيوبَ البلاءُ سبعَ سنين{40}. (ز) ٦٦٨٨٦- عن ليث بن أبي سليم، قال: قيل لأيوب: يا أيوب، لا يُعجبنَّك صبرك، فلولا أني أعطيتُ موضع كل شعرة منك صبرًا ما صبرتَ{41}. (١٢/٦٠٧) ٦٦٨٨٧- عن عمرو بن السكن، قال: كنت عند سفيان بن عيينة، فقام إليه رجل مِن أهل بغداد، فقال: يا أبا محمد، أخبِرني عن قول مُطرِّف: لأن أُعافى فأشكُر أحب إليَّ مِن أن أُبتلى فأصبر. أهو أحبُّ إليك أم قول أخيه أبي العلاء: اللهم، رضيتُ لنفسي ما رضيتَ لي؟ قال: فسكت سكتة، ثم قال: قول مطرف أحبُّ إلَيَّ. فقال الرجل: كيف وقد رضي هذا لنفسه ما رضيه الله له. قال سفيان: إني قرأت القرآن فوجدت صفة سليمان مع العافية التي كان فيها: <q>﴿نعم العبد إنه أواب﴾</q> [ص:٣٠]. ووجدت صفة أيوب مع البلاء الذي كان فيه: <q>﴿نعم العبد إنه أواب﴾</q>، فاستوت الصفتان؛ وهذا معافًى، وهذا مبتلًى، فوجدتُ الشكر قد قام مقام الصبر، فلمّا اعتدلا كانت العافية مع الشكر أحبُّ إلَيَّ مِن البلاء مع الصبر{42}. (ز) ",footnotes:1:الشِّمْراخ: العِثْكال الذي عليه البُسْر، وأَصله في العِذْق، وقد يكون في العنب. اللسان (شمرخ).أخرجه ابن عساكر ١٠/٧٦. وعزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٠/١١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١١، وابن أبي حاتم -كما في الإتقان ٢/٤٠-.أخرجه ابن جرير ٢٠/١١١-١١٢.الطّاقَة: شُعْبَة من ريحان أو شعر وقوة من الخيط أو نحو ذلك. ويقال: طاق نعل وطاقة رَيْحان. اللسان (طوق).القَتُّ: الفِصْفِصَة، وهي الرَّطبة من علف الدَّواب. النهاية (قتت).أخرجه ابن عساكر ٦٩/١٢٤.الثُّمام: نبْت ضعيف قصير لا يطول. النهاية (ثمم).عزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه - التفسير ٧/١٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه سفيان الثوري (٢٦٠) عن مجاهد بلفظ: كانت له رخصة. وكذا ابن عساكر في تاريخ دمشق ٩/٦٨. وعلقه النحاس في الناسخ والمنسوخ (٦٤٨).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٢.أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٤٢١-.كذا في مطبوعة المصدر، ولعله «السَّمُر». والأَسَل: نبات له أغصان كثيرة دقاق لا ورق لها. النهاية (أسل).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٥-.عزاه السيوطي إلى عبد بن حميد. وتقدم قريبًا بتمامه.أخرجه عبد الرزاق ٢/١٦٧-١٦٨ من طريق معمر واللفظ له، وابن جرير ٢٠/١١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أحمد في الزهد ص٨٩، وابن جرير ٢٠/١١١، ١١٣.أخرجه ابن جرير ٢٠/١١٢.تفسير مقاتل بن سليمان ٣/٦٤٨.تفسير سفيان الثوري (٢٥٩).أخرجه ابن جرير ٢٠/١١٢.الأحبن: المستسقى، من الحبَن –بالتحريك- وهو عِظَم البطْن. النهاية (حبن).أخرجه الطبراني في الكبير ٦/١٥٢ (٥٨٢٠) من طريق أبي بكر بن أبي سبرة، قال: حدثني أبو حازم، عن سهل بن سعد به. قال الهيثمي في المجمع ٦/٢٥٢ (١٠٥١٨): «فيه أبو بكر بن سبرة، وهو متروك».العُثْكول: العِذْق، وكلّ غُصْنٍ من أغصانِهِ شِمْراخ. النهاية (شمرخ) و(عثكل).أخرجه النسائي ٨/٢٤٢، وأبو داود ٤/١٢١ من طرق وألفاظ مختلفة، فرُوِيَ موصولًا ومرسلًا من حديث أبي الزناد عن أبي أمامة، ومن طريق أبي أمامة بن سهل عن أبيه، ومن طريق أبي أمامة عن النبي ﷺ مرسلًا. قال الدارقطني في سننه ٤/٩٢: «والصواب عن أبي حازم عن أبي أمامة بن سهل عن النبي ﷺ». وكذا رجَّح إرساله في علله -كما في البدر المنير لابن الملقّن ٨/٦٢٦-، وقال البيهقي بعد ذكر بعض طرقه ٨/٢٣٠: «هذا هو المحفوظ عن سفيان مرسلًا، وروي عنه موصولًا بذكر أبي سعيد فيه .. وقيل: عن أبى الزناد عن أبى أمامة عن أبيه...».مخدج: ناقص الخلقة. النهاية (خدج).أخرجه أحمد ٣٦/٢٦٣ (٢١٩٣٥)، وابن ماجه ٣/٦٠٤-٦٠٥ (٢٥٧٤). قال البوصيري في مصباح الزجاجة ٣/١١٠ (٢١٩): «هذا إسناد ضعيف ... لأن مدار الإسناد على محمد بن إسحاق، وهو مدلّس، وقد رواه بالعنعنة». وقال ابن حجر في بلوغ المرام ٢/١٤٢ (١٢١٥): «وإسناده حسن، لكن اختلف في وصله وإرساله». وأورده الألباني في الصحيحة ٦/١٢١٥ (٢٩٨٦).أخرجه إسحاق البستي ص٢٥١.أخرجه سعيد بن منصور في سننه- التفسير ٧/١٨٦-١٨٧ (١٨٤٧).أخرجه ابن عساكر ١٠/٥٨.تفسير مقاتل بن سليمان ٣/٦٤٨.أخرجه ابن عساكر ١٠/٦٦.مباح الدعوة: حلال لك أن تدعو. التاج (بوح).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن عساكر ١٠/٦٩.أخرجه ابن أبي شيبة ١٣/٢٠٩. وعزاه السيوطي إلى أحمد في الزهد.أخرجه عبد الرزاق ٢/١٦٧.أخرجه ابن عساكر ١٠/٦٨.أخرجه أبو نعيم في حلية الأولياء ٢/٢١٢-٢١٣.
38,45," <q>﴿وَٱذۡكُرۡ عِبَـٰدَنَاۤ إِبۡرَ ٰ⁠هِیمَ وَإِسۡحَـٰقَ وَیَعۡقُوبَ﴾</q> - قراءات ٦٦٨٨٨- عن عبد الله بن عباس -من طريق عطاء- أنه كان يقرأ: ‹واذْكُرْ عَبْدَنَآ إبْراهِيمَ›، ويقول: إنما ذكر إبراهيم، ثم ذكر بعده ولده{1}. (١٢/٦٠٨) ٦٦٨٨٩- عن عاصم أنه قرأ: <q>﴿واذْكُرْ عِبادَنا﴾</q> على الجماع <q>﴿إبْراهِيمَ وإسْحاقَ ويَعْقُوبَ﴾</q>{2}٥٥٧٩. (١٢/٦٠٨) ٥٥٧٩ رجّح ابنُ جرير (٢٠/١١٤) مستندًا إلى إجماع الحجة من القراء قراءة الجمع، فقال: «والصواب عندنا من القراءة في ذلك: قراءة من قرأه على الجماع، على أن إبراهيم وإسحاق ويعقوب بيان عن العباد، وترجمة عنه؛ لإجماع الحجة من القراء عليه». وعلَّق عليها ابنُ عطية (٧/٣٥٥) بقوله: «فأما على هذه القراءة فدخل الثلاثة في الذكر، وفي العبودية». وعلَّق على قراءة من قرأ ذلك ‹عَبْدَنا› فقال: «وأما على قراءة من قرأ ‹عَبْدَنا›؛ فقال مكي وغيره: دخلوا في الذكر، ولم يدخلوا في العبودية إلا من غير هذه الآية». وانتقد قول مكي بقوله: «وفي هذا نظر». <q>﴿أُو۟لِی ٱلۡأَیۡدِی وَٱلۡأَبۡصَـٰرِ ۝٤٥﴾</q> - قراءات ٦٦٨٩٠- عن عبد الله بن مسعود أنّه كان يقرؤه: (أُولِي الأَيْدِ) بغير ياء{3}٥٥٨٠. (ز) ٥٥٨٠ علَّق ابنُ جرير (٢٠/١١٦) على هذه القراءة، فقال: «وقد ذكر عن عبد الله أنه كان يقرؤه: (أُولِي الأَيْدِ) بغير ياء، وقد يحتمل أن يكون ذلك من التأييد، وأن يكون بمعنى: الأيدي، ولكنه أسقط منه الياء، كما قيل: <q>﴿يوم يناد المناد﴾</q> [ق:٤١] بحذف الياء». وذكر ابنُ عطية (٧/٣٥٥) قراءة إثبات الياء ونسبها إلى جمهور القراء، وذكر القراءة بحذفها، ثم رتب عليهما عدة أوجه في تفسير الآية، فقال: «وأما القراءة الأولى فـ<q>﴿الأيدي﴾</q> فيها عبارة عن القوة في طاعة الله، قاله ابن عباس ومجاهد، وقالت فرقة: بل معناه: أولي الأيدي والنعم التي أسداها الله تعالى إليهم؛ من النبوة والمكانة. وقالت فرقة: بل هي عبارة عن إحسانهم في الدين وتقديمهم عند الله تعالى أعمال صدق، فهي كالأيادي. وقال قوم: المعنى: أيدي الجوارح، والمراد الأيدي المتصرفة في الخير والأبصار الثاقبة فيه، لا كالتي هي مهملة في جل الناس». ثم ذكر قراءة من قرأ ذلك بغير ياء، وعلَّق عليها، فقال: «وأما من قرأ (الأَيْدِ) دون ياء فيحتمل أن يكون معناها معنى القراءة بالياء وحذفت تخفيفًا، ومن حيث كانت الألف واللام تعاقب التنوين وجب أن تحذف معها كما تحذف مع التنوين». ٦٦٨٩١- عن هارون، قال: كان أبو عمرو [بن العلاء] يقول: (أُولِي الأَيْدِ والأَبْصارِ)، يعني: البصر في الدين{4}. (ز) <q>﴿أُو۟لِی ٱلۡأَیۡدِی وَٱلۡأَبۡصَـٰرِ ۝٤٥﴾</q> - تفسير الآية ٦٦٨٩٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أُولِي الأَيْدِي﴾</q> قال: أولي القوة في العبادة، <q>﴿والأَبْصارِ﴾</q> قال: الفقه في الدين{5}. (١٢/٦٠٨) ٦٦٨٩٣- عن عبد الله بن عباس، في قوله: <q>﴿أُولِي الأَيْدِي﴾</q> قال: القوة في العبادة، <q>﴿والأَبْصارِ﴾</q> قال: القوة في الدين{6}. (١٢/٦٠٨) ٦٦٨٩٤- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q>، قال: فُضِّلوا بالقُوَّة والعبادة{7}. (ز) ٦٦٨٩٥- عن عبد الله بن عباس، في قوله: <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q> قال: القوة في العبادة، <q>﴿والأَبْصارِ﴾</q> قال: البصر في أمر الله{6}. (١٢/٦٠٨) ٦٦٨٩٦- عن عبد الله بن عباس، في قوله: <q>﴿أُولِي الأَيْدِي﴾</q>، قال: النِّعمة{9}. (١٢/٦٠٩) ٦٦٨٩٧- عن سعيد بن جبير، <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q>، قال: أما الأيد: فهو القوة في العمل. وأما الأبصار: فالبصر بما هم فيه من أمر دينهم{2}. (١٢/٦٠٩) ٦٦٨٩٨- عن مجاهد بن جبر -من طريق منصور- <q>﴿أُولِي الأَيْدِي﴾</q> قال: القوة في أمر الله، <q>﴿والأَبْصارِ﴾</q> قال: العقول{11}. (١٢/٦٠٩) ٦٦٨٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أُولِي الأَيْدِي﴾</q> قال: القوة في طاعة الله، <q>﴿والأبصار﴾</q> قال: البصر في الحق{12}. (ز) ٦٦٩٠٠- عن الحسن البصري، <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q>، قال: أولي الأيدي على الناس بالمعروف{2}. (١٢/٦٠٩) ٦٦٩٠١- عن هارون، عن عمرو، عن الحسن البصري: <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q> يعني: أولو القوة= (ز) ٦٦٩٠٢- قال: وكان أبو عمرو [بن العلاء] يقول: (أُولِي الأَيْدِ والأَبْصارِ)، يعني: البصر في الدين{4}. (ز) ٦٦٩٠٣- عن قتادة بن دعامة -من طريق معمر، وسعيد- <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q>، قال: أولي القوة في العبادة. وفي لفظ: قال: أُعطوا قوة في العبادة، وبصرًا في الدين{15}. (١٢/٦٠٩) ٦٦٩٠٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿أُولِي الأَيْدِي والأَبْصارِ﴾</q>، قال: الأيدي: القوة في طاعة الله. والأبصار: البصر بعقولهم في دينهم{12}. (ز) ٦٦٩٠٥- عن منصور [بن المعتمر] -من طريق شعبة- أنه قال في هذه الآية: <q>﴿أُولِي الأَيْدِي﴾</q>، قال: القُوَّة{12}. (ز) ٦٦٩٠٦- عن عطاء الخراساني -من طريق يونس بن يزيد- <q>﴿أولي الأيدي والأبصار﴾</q>، قال: القوة في العبادة، والبصر في أمر الله ﷿{18}. (ز) ٦٦٩٠٧- قال مقاتل بن سليمان: <q>﴿واذْكُرْ﴾</q> يا محمد صَبْرَ <q>﴿عِبادَنا إبْراهِيمَ﴾</q> حين أُلْقِي في النار، <q>﴿و﴾</q>صبر <q>﴿إسْحاقَ﴾</q> للذبح، <q>﴿و﴾</q>صبر <q>﴿يَعْقُوبَ﴾</q> فى ذهاب بصره، ولم يذكر إسماعيل بن إبراهيم؛ لأنه لم يُبتلَ، واسم أم يعقوب: رفقا، <q>﴿أُولِي الأَيْدِي﴾</q> يعني: أولي القوة في العبادة، <q>﴿والأَبْصارِ﴾</q> يعني: البصيرة في أمر الله ودينه{19}٥٥٨١. (ز) ٥٥٨١ اختلف السلف في تفسير قوله: <q>﴿أولي الأيدي والأبصار﴾</q> على أقوال: الأول: أن الأيدي القوة في الطاعة، والأبصار: أنهم أهل بصائر في الدين والعلم. الثاني: أن الأيدي: النعمة. وقد بيّن ابنُ جرير (٢٠/١١٤) أن المعنى: أنهم أهل قوة في الطاعة وأهل بصائر القلوب، فقال: «وقوله: <q>﴿أولي الأيدي والأبصار﴾</q> ويعني بالأيدي: القوة، يقول: أهل القوة على عبادة الله وطاعته، ويعني بالأبصار: أنهم أهل إبصار القلوب، يعني به: أولي العقول للحق. وقد اختلف أهلُ التأويل في تأويل ذلك، فقال بعضُهم في ذلك نحوًا مما قلنا فيه». ثم ذكر آثار السلف على هذا. وقال ابنُ عطية (٧/٣٥٥): «وقوله تعالى: <q>﴿والأَبْصارِ﴾</q> عبارة عن البصائر، أي: يبصرون الحقائق وينظرون بنور الله تعالى، وبنحو هذا فسَّر الجميعُ». ",footnotes:1:أخرجه ابن جرير ٢٠/١١٤، وابن أبي حاتم -كما في التغليق ٤/٢٩٦، والإتقان ٢/٤٠-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد. وهي قراءة متواترة، قرأ بها ابن كثير، وقرأ بقية العشرة: <q>﴿عِبادَنا﴾</q> على الجمع. انظر: النشر ٢/٣٦١، والإتحاف ص٤٧٧.عزاه السيوطي إلى عبد بن حميد.ذكره ابن جرير ٢٠/١١٦. وهي قراءة شاذة، تروى أيضا عن الحسن والأعمش، والثقفي بخلاف عنهم، وقراءة العشرة: <q>﴿أُولِي الأَيْدِي﴾</q>. انظر: المحتسب ٢/٢٣٣، ومختصر ابن خالويه ص١٣١.أخرجه إسحاق البستي ص٢٥٢.أخرجه ابن جرير ٢٠/١١٤. وعزا السيوطي شطره الثاني إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٥-١١٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٥.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص٢٥٢.أخرج اللفظ الأول عبد الرزاق ٢/١٦٨ من طريق معمر، وأخرج اللفظ الثاني ابن جرير ٢٠/١١٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٥.أخرجه ابن جرير ٢٠/١١٥.أخرجه أبو جعفر الرملي في جزئه ص١١٠ (تفسير عطاء الخراساني). وهو في تفسير مقاتل بن سليمان ٣/٦٤٩ من طريق ابن جابر بلفظ: القوة في العبادة والبصر بالدين.تفسير مقاتل بن سليمان ٣/٦٤٨-٦٤٩.
38,46," <q>﴿إِنَّاۤ أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ ذِكۡرَى ٱلدَّارِ ۝٤٦ وَإِنَّهُمۡ عِندَنَا لَمِنَ ٱلۡمُصۡطَفَیۡنَ ٱلۡأَخۡیَارِ ۝٤٧﴾</q> - قراءات ٦٦٩٠٨- عن الأعرج -من طريق هارون- قال: (مُخالِصِينَ ذِكْرى الدّارِ){1}. (ز) <q>﴿إِنَّاۤ أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ ذِكۡرَى ٱلدَّارِ ۝٤٦ وَإِنَّهُمۡ عِندَنَا لَمِنَ ٱلۡمُصۡطَفَیۡنَ ٱلۡأَخۡیَارِ ۝٤٧﴾</q> - تفسير الآية ٦٦٩٠٩- عن عبد الله بن عباس، في قوله: <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: أخلصوا بذكر دار الآخرة أن يعملوا لها{2}. (١٢/٦٠٩) ٦٦٩١٠- عن عبد الله بن عباس، في قوله: <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: أخلصوا بذلك وبذكرهم دار يوم القيامة{3}. (١٢/٦١٠) ٦٦٩١١- عن سعيد بن جبير -من طريق سالم الأفطس- <q>﴿ذِكْرى الدّارِ﴾</q>، قال: عقبى الدار{4}. (١٢/٦١٠) ٦٦٩١٢- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: بذكر الآخرة، وليس لهم هَمٌّ ولا ذِكْرٌ غيرها{5}. (١٢/٦١٠) ٦٦٩١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿بِخالِصَةٍ ذِكْرى الدّارِ﴾</q> هم أهل الدار، وذو الدار، كقولك: ذو الكلاع، وذو يزن{6}. (ز) ٦٦٩١٤- عن الضحاك بن مزاحم، <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: بخوف الآخرة{3}. (١٢/٦١٠) ٦٦٩١٥- عن الحسن البصري، <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: بفضل أهل الجنة{8}. (١٢/٦١٠) ٦٦٩١٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: بهذه أخلصهم الله، كانوا يدعون إلى الآخرة وإلى الله{9}. (١٢/٦١٠) ٦٦٩١٧- عن قتادة بن دعامة -من طريق فضيل بن عياض، عن رجل- في قوله: <q>﴿إنّا أخْلَصْناهُمْ﴾</q>، قال: بِهَمِّ الآخرة{10}. (ز) ٦٦٩١٨- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: يدعون إلى الآخرة، وإلى طاعة الله{11}. (ز) ٦٦٩١٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، قال: بذكرهم الدار الآخرة، وعملهم للآخرة{12}. (ز) ٦٦٩٢٠- قال مالك بن دينار: <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q> نزعنا مِن قلوبهم حُبَّ الدنيا وذِكْرَها، وأخلصناهم بحب الآخرة وذكرِها{13}. (ز) ٦٦٩٢١- عن عطاء الخراساني -من طريق ابن جابر- قال في قوله: <q>﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</q>، يقول: وجعلناهم أذكر الناس لدار الآخرة، يعني: الجنة{14}. (ز) ٦٦٩٢٢- عن عطاء الخراساني -من طريق يونس بن يزيد- <q>﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</q>، قال: أخلصوا بذلك، وتفكَّروا{15} بدار يوم القيامة{16}. (ز) ٦٦٩٢٣- قال مقاتل بن سليمان: ثم ذكر الله تعالى هؤلاء الثلاثة: إبراهيم، وابنيه؛ إسحاق، ويعقوب بن إسحاق، فقال: <q>﴿إنّا أخْلَصْناهُمْ﴾</q> للنبوة والرسالة <q>﴿بِخالِصَةٍ ذِكْرى الدّارِ وإنَّهُمْ عِنْدَنا لَمِنَ المُصْطَفَيْنَ الأَخْيارِ﴾</q> اختارهم الله على عِلْمٍ للرسالة{14}. (ز) ٦٦٩٢٤- عن العلاء العطار، قال: سمعت فضيل [بن عياض] يقول في قوله: <q>﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</q>، قال: أخلصوا بهمِّ الآخرة{18}. (ز) ٦٦٩٢٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ‹إنَّآ أخْلَصْناهُمْ بِخالِصَةِ ذِكْرى الدّارِ›، قال: بأفضل ما في الآخرة، أخلصناهم به، وأعطيناهم إياه. قال: والدار: الجنة. وقرأ: <q>﴿تِلْكَ الدّارُ الآخِرَةُ نَجْعَلُها لِلَّذِينَ لا يُرِيدُونَ عُلُوًّا فِي الأَرْضِ﴾</q> [القصص:٨٣]، قال: الجنة. وقرأ: <q>﴿ولَنِعْمَ دارُ المُتَّقِينَ﴾</q> [النحل:٣٠]، قال: هذا كله الجنة. وقال: أخلصناهم بخير الآخرة{12}٥٥٨٢. (ز) ٥٥٨٢ اختلف السلف في قوله: <q>﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</q> على أقوال: الأول: أنهم كانوا يُذَكِّرون الناسَ بالدار الآخرة، ويدعونهم إلى طاعة الله. الثاني: أنه أخلصهم بعملهم للآخرة، وذكرهم لها. الثالث: إنا أخلصناهم بأفضل ما في الآخرة. الرابع: خالصة عقبى الدار. الخامس: بخالصة أهل الدار. السادس: أخلصناهم بالنبوة وذكر الدار الآخرة. وقد رجح ابنُ جرير (٢٠/١١٩) أن المعنى على قراءة <q>﴿بخالصة﴾</q> بالتنوين: «إنا أخلصناهم بخالصة هي ذكرى الدار الآخرة، فعملوا لها في الدنيا، فأطاعوا الله وراقبوه». ولم يذكر مستندًا، ثم بيّن احتمال الآية للقول الأول على هذه القراءة، فقال: «وقد يدخل في وصفهم بذلك أن يكون من صفتهم أيضًا الدعاء إلى الله وإلى الدار الآخرة؛ لأن ذلك من طاعة الله والعمل للدار الآخرة، غير أن معنى الكلمة ما ذكرت». ثم وضَّح أن المعنى على قراءة الإضافة: «إنا أخلصناهم بخالصة ما ذكر في الدار الآخرة؛ فلما لم تذكر في أضيفت الذكرى إلى الدار كما قد بينا قبل في معنى قوله: <q>﴿لا يسأم الإنسان من دعاء الخير﴾</q> [فصلت:٤٩]، وقوله: <q>﴿بِسُؤالِ نَعْجَتِكَ إلى نِعاجِهِ﴾</q> [ص:٢٤]». وزاد ابنُ عطية (٧/٣٥٦) في معنى الآية قولًا، فقال: «ويحتمل أن يريد بـ<q>﴿الدار﴾</q> دار الدنيا على معنى: ذكر الثناء والتعظيم من الناس، والحمد الباقي الذي هو الخلد المجازي، فتجيء الآية في معنى قوله: <q>﴿لسان صدق﴾</q> [الشعراء:٨٤]، وفي معنى قوله: <q>﴿وتركنا عليه في الآخرين﴾</q> [الصافات:٧٨، ١٠٨، ١٢٩]». <q>﴿إِنَّاۤ أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ ذِكۡرَى ٱلدَّارِ ۝٤٦ وَإِنَّهُمۡ عِندَنَا لَمِنَ ٱلۡمُصۡطَفَیۡنَ ٱلۡأَخۡیَارِ ۝٤٧﴾</q> - آثار متعلقة بالآية ٦٦٩٢٦- عن عبيد بن عمير -من طريق ابنه عبد الله- قال: قال موسى ﷺ: يا ربِّ، بما أثنيت على إبراهيم وإسحاق ويعقوب بأيِّ شيء أعطيتَهم ذلك؟ قال: إنّ إبراهيم لم يعدل فِيَّ شيئًا إلا اختارني عليه، وإنّ إسحاق جاد لي بنفسه فهو بغيرها أجود، وأمّا يعقوب فلم أبتله ببلاء إلا زاد فِيَّ حُسن ظن{20}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٢٥٢. وهي قراءة شاذة.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٨ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١٩.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب الهم والحزن -موسوعة الإمام ابن أبي الدنيا ٣/٢٦٩ (٣٩)-.أخرجه عبد الرزاق ٢/١٦٨.أخرجه ابن جرير ٢٠/١١٨.تفسير البغوي ٧/٩٧.تفسير مقاتل بن سليمان ٣/٦٤٩.في المصدر: وتكفروا.أخرجه أبو جعفر الرملي في جزئه ص١١٠ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٦٤٩.أخرجه أبو نعيم في حلية الأولياء ٨/١٠٤.أخرجه ابن جرير ٢٠/١١٨.أخرجه سفيان الثوري في تفسيره (٢٦٠).
  38,47,""
38,48," <q>﴿وَٱذۡكُرۡ إِسۡمَـٰعِیلَ وَٱلۡیَسَعَ وَذَا ٱلۡكِفۡلِۖ وَكُلࣱّ مِّنَ ٱلۡأَخۡیَارِ ۝٤٨﴾</q> - قراءات ٦٦٩٢٧- عن عاصم أنه قرأ: <q>﴿واليَسَعَ﴾</q> مخففة{1}. (١٢/٦١٠) ٦٦٩٢٨- عن سليمان الأعمش أنه قرأ: ‹اللّيْسَعَ› مشددة{2}. (١٢/٦١٠) <q>﴿وَٱذۡكُرۡ إِسۡمَـٰعِیلَ وَٱلۡیَسَعَ وَذَا ٱلۡكِفۡلِۖ وَكُلࣱّ مِّنَ ٱلۡأَخۡیَارِ ۝٤٨﴾</q> - تفسير الآية ٦٦٩٢٩- قال مجاهد بن جبر: <q>﴿واذْكُرْ إسْماعِيلَ واليَسَعَ وذا الكِفْلِ﴾</q>، إنّ ذا الكفل كان رجلًا صالحًا، وليس بنبي، تكفَّل لنبيٍّ بأن يكفل له أمر قومه، ويقضي بينهم بالعدل{3}. (ز) ٦٦٩٣٠- قال مقاتل بن سليمان: <q>﴿واذْكُرْ﴾</q> صبر <q>﴿إسْماعِيلَ﴾</q> هو أشويل بن هلقانا، <q>﴿و﴾</q>صبر <q>﴿اليَسَعَ و﴾</q>صبر <q>﴿ذا الكِفْلِ وكُلٌّ مِنَ الأَخْيارِ﴾</q> اختارهم الله ﷿ للنبوة، فاصبر -يا محمد- على الأذى كما صبر هؤلاء الستة على البلاء{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا حمزة، والكسائي، وخلفًا؛ فإنهم قرؤوا: ‹واللّيْسَعَ› بتشديد اللام مفتوحة، بعدها ياء ساكنة. انظر: النشر ٢/٢٦٠، والإتحاف ص٤٧٨.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٦-.تفسير مقاتل بن سليمان ٣/٦٤٩-٦٥٠.
38,49," <q>﴿هَـٰذَا ذِكۡرࣱۚ﴾</q> - تفسير ٦٦٩٣١- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿هَذا ذِكْرٌ﴾</q>، قال: القرآن{1}٥٥٨٣. (ز) ٥٥٨٣ لم يذكر ابن جرير (٢٠/١٢٠) غير قول السدي. وقال ابنُ عطية (٧/٣٥٧): «<q>﴿هذا ذِكْرٌ﴾</q> يحتمل معنيين: أحدهما: أن يشير إلى مدح من ذكر وإبقاء الشرف له، فيتأيد بهذا التأويل قول مَن قال آنفًا: إن الدّارِ يراد بها: الدار الدنيا. والثاني: أن يشير بهذا إلى القرآن، إذ هو ذكر للعالم». ٦٦٩٣٢- قال مقاتل بن سليمان: <q>﴿هَذا ذِكْرٌ﴾</q>، يعني: هذا بيان الذي ذكر الله مِن أمر الأنبياء في هذه السورة{2}. (ز) <q>﴿وَإِنَّ لِلۡمُتَّقِینَ لَحُسۡنَ مَـَٔابࣲ ۝٤٩﴾</q> - تفسير ٦٦٩٣٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وإنَّ لِلْمُتَّقِينَ لَحُسْنَ مَآبٍ﴾</q>، قال: لحُسنَ مُنقلَبٍ{3}. (ز) ٦٦٩٣٤- قال مقاتل بن سليمان: <q>﴿وإنَّ لِلْمُتَّقِينَ﴾</q> مِن هذه الأمة في الآخرة <q>﴿لَحُسْنَ مَآبٍ﴾</q> يعني: مَرجِع{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/١٢٠.تفسير مقاتل بن سليمان ٣/٦٥٠.أخرجه ابن جرير ٢٠/١٢١.تفسير مقاتل بن سليمان ٣/٦٥٠.
38,50," <q>﴿جَنَّـٰتِ عَدۡنࣲ مُّفَتَّحَةࣰ لَّهُمُ ٱلۡأَبۡوَ ٰ⁠بُ ۝٥٠﴾</q> - تفسير ٦٦٩٣٥- عن قتادة، في قوله: <q>﴿جَنّاتِ عَدْنٍ﴾</q>، قال: سأل عمرُ كعبًا: ما عَدْن؟ قال: يا أمير المؤمنين، قصور في الجنة من ذهب، يسكنها النبيُّون والصديقون والشهداء وأئمة العدل{1}. (ز) ٦٦٩٣٦- عن الحسن البصري -من طريق ابن دعلج- في قوله: <q>﴿جَنّاتِ عَدْنٍ مُفَتَّحَةً لَهُمُ الأَبْوابُ﴾</q>، قال: يرى ظاهرها من باطنها، وباطنها من ظاهرها، يُقال لها: انفتحي، انغلقي، تكلمي. فتفهم، وتتكلَّم{2}. (١٢/٦١١) ",footnotes:1:أخرجه ابن جرير ٢٠/١٢١.تفسير مقاتل بن سليمان ٣/٦٥٠، وأخرجه ابن جرير ٢٠/١٢٢، ٥٧٧. وعزاه السيوطي إلى ابن المنذر.
38,51," <q>﴿مُتَّكِـِٔینَ فِیهَا یَدۡعُونَ فِیهَا بِفَـٰكِهَةࣲ كَثِیرَةࣲ وَشَرَابࣲ ۝٥١﴾</q> - تفسير ٦٦٩٣٧- قال مقاتل بن سليمان: <q>﴿مُتَّكِئِينَ فِيها﴾</q> في الجنة على السُّرر، <q>﴿يَدْعُونَ فِيها بِفاكِهَةٍ كَثِيرَةٍ وشَرابٍ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥٠.
38,52," <q>﴿وَعِندَهُمۡ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</q> - تفسير ٦٦٩٣٨- عن محمد بن كعب القرظي، في قوله: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ أتْرابٌ﴾</q>، قال: قاصرات الطرف على أزواجهن، لا يبغين غيرهم{1}. (١٢/٦١١) ٦٦٩٣٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q>، قال: قَصَرْنَ طرفهنَّ على أزواجهنَّ، فلا يُرِدْن غيرَهم{2}. (١٢/٦١١) ٦٦٩٤٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿قاصِراتُ الطَّرْفِ﴾</q>، قال: قصرن أبصارهن وقلوبهن وأسماعهن على أزواجهن، فلا يُرِدْن غيرهم{3}. (ز) ٦٦٩٤١- قال مقاتل بن سليمان: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q> النظر عن الرجال؛ لا ينظرن إلى غير أزواجهن؛ لأنهنَّ عاشقات لأزواجهن{4}. (ز) <q>﴿أَتۡرَابٌ ۝٥٢﴾</q> - تفسير ٦٦٩٤٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أتْرابٌ﴾</q>، قال: مستويات{5}. (١٢/٦١١) ٦٦٩٤٣- عن مجاهد بن جبر -من طريق سفيان- قال: <q>﴿أتْرابٌ﴾</q>، الأتراب: المستويات{6}. (ز) ٦٦٩٤٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أتْرابٌ﴾</q>، قال: أمثال{7}. (١٢/٦١١) ٦٦٩٤٥- عن محمد بن كعب القرظي، في قوله: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ أتْرابٌ﴾</q>: والأتراب: المستويات{1}. (١٢/٦١١) ٦٦٩٤٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أتْرابٌ﴾</q>، قال: سِنّ واحدة{9}. (١٢/٦١١) ٦٦٩٤٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أتْرابٌ﴾</q>، قال: مستويات. قال: وقال بعضهم: مُتواخِيات؛ لا يتباغضن، ولا يتعادين، ولا يتغايرن، ولا يتحاسدن{10}. (ز) ٦٦٩٤٨- قال مقاتل بن سليمان: <q>﴿أتْرابٌ﴾</q>، يعني: مستويات على ميلادٍ واحد؛ بنات ثلاثة وثلاثين سنة{4}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٢٣.تفسير مقاتل بن سليمان ٣/٦٥٠.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤١-، والبيهقي في البعث (٣٧٧).أخرجه سفيان الثوري ١/٢٦٠.تفسير مجاهد (٥٧٦)، وأخرجه ابن جرير ٢٠/١٢٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٢٤. وقوله: «وقال بعضهم» يظهر أنه من قول السدي لذكر «قال» قبله. ويحتمل أن يكون من كلام ابن جرير.تفسير مقاتل بن سليمان ٣/٦٥٠.
38,53," <q>﴿هَـٰذَا مَا تُوعَدُونَ لِیَوۡمِ ٱلۡحِسَابِ ۝٥٣﴾</q> - تفسير ٦٦٩٤٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿هَذا ما تُوعَدُونَ لِيَوْمِ الحِسابِ﴾</q>، قال: هو في الدنيا ليوم القيامة{1}. (ز) ٦٦٩٥٠- قال مقاتل بن سليمان: ثم قال: <q>﴿هَذا﴾</q> الذي ذُكِر في هذه الآية، ذكر يعني: بيان من الخير في الجنة <q>﴿ما تُوعَدُونَ لِيَوْمِ الحِسابِ﴾</q> يعني: ليوم الجزاء{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/١٢٤.تفسير مقاتل بن سليمان ٣/٦٥٠.
38,54," <q>﴿إِنَّ هَـٰذَا لَرِزۡقُنَا مَا لَهُۥ مِن نَّفَادٍ ۝٥٤﴾</q> - تفسير ٦٦٩٥١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ هَذا لَرِزْقُنا ما لَهُ مِن نَفادٍ﴾</q>: أي: مِن انقطاع{1}. (١٢/٦١٢) ٦٦٩٥٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿إنَّ هَذا لَرِزْقُنا ما لَهُ مِن نَفادٍ﴾</q>، قال: رزق الجنة، كلمّا أُخِذ منه شيءٌ عاد مثله مكانه، ورزق الدنيا له نفاد{2}. (ز) ٦٦٩٥٣- قال مقاتل بن سليمان: <q>﴿إن هَذا﴾</q> الخير في الجنة <q>﴿لَرِزْقُنا ما لَهُ مِن نَفادٍ﴾</q> يقول: هذا الرزق للمتقين{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/١٢٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٥.تفسير مقاتل بن سليمان ٣/٦٥٠.
38,55," <q>﴿هَـٰذَاۚ وَإِنَّ لِلطَّـٰغِینَ لَشَرَّ مَـَٔابࣲ ۝٥٥﴾</q> - تفسير ٦٦٩٥٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وإنَّ لِلطّاغِينَ لَشَرَّ مَآبٍ﴾</q>، قال: لَشَرّ مُنقلَب{1}. (ز) ٦٦٩٥٥- قال مقاتل بن سليمان: ثم ذكر الكفار، فقال سبحانه: <q>﴿هَذا وإنَّ لِلطّاغِينَ لَشَرَّ مَآبٍ﴾</q>، يعني: بئس المرجع{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/١٢٦.تفسير مقاتل بن سليمان ٣/٦٥٠-٦٥١.
38,56," <q>﴿جَهَنَّمَ یَصۡلَوۡنَهَا فَبِئۡسَ ٱلۡمِهَادُ ۝٥٦﴾</q> - تفسير ٦٦٩٥٦- قال مقاتل بن سليمان: ثم أخبر بالمرجع، فقال: <q>﴿جَهَنَّمَ يَصْلَوْنَها فَبِئْسَ المِهادُ﴾</q> ما مهدوا لأنفسهم مِن العذاب{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥١.
38,57," <q>﴿هَـٰذَا فَلۡیَذُوقُوهُ حَمِیمࣱ﴾</q> - تفسير ٦٦٩٥٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ وغَسّاقٌ﴾</q>، قال: الحميم: الذي قد انتهى حرُّه{1}. (ز) ٦٦٩٥٨- قال مقاتل بن سليمان: <q>﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ﴾</q>، يعني: الحارّ الذي انتهى حرُّه وطبخه{2}. (ز) ٦٦٩٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ﴾</q>: الحميم: دموع أعينهم، يجتمع في حياض النار، فيُسقَوْنَه{3}. (ز) <q>﴿وَغَسَّاقࣱ ۝٥٧﴾</q> - تفسير ٦٦٩٦٠- عن أبي سعيد، قال: قال رسول الله ﷺ: «لو أنّ دَلْوًا مِن غسّاق يُهراق في الدنيا لأنتن أهل الدنيا»{4}. (١٢/٦١٣) ٦٦٩٦١- عن عبد الله بن مسعود -من طريق مرة الهمداني- في قوله: <q>﴿وغَسّاقٌ﴾</q>، قال: الزَّمْهَرِير{5}. (١٢/٦١٢) ٦٦٩٦٢- عن عبد الله بن عمرو -من طريق أبي هبيرة الزيادي- أنه سمعه يقول: <q>﴿وغَسّاقٌ﴾</q> أيُّ شيء الغساق؟ قالوا: الله أعلم. فقال عبد الله بن عمرو: هو القَيح الغليظ، لو أنّ قطرة منه تُهراق في المغرب لأنتنت أهل المشرق، ولو تهراق في المشرق لأنتنت أهل المغرب{6}. (ز) ٦٦٩٦٣- قال عبد الله بن عباس: <q>﴿غَسّاقٌ﴾</q> هو الزمهرير، يحرقهم ببرده، كما تحرقهم النارُ بِحَرِّها{7}. (ز) ٦٦٩٦٤- عن كعب الأحبار -من طريق عطية الكلاعي- قال: <q>﴿غَسّاقٌ﴾</q> عينٌ في جهنم، يسيل إليها حُمَة{8} كلِّ ذات حُمَة؛ مِن حيَّة أو عقرب أو غيرها، فيستنقع، فيؤتى بالآدمي، فيغمس فيها غمسة واحدة، فيخرج وقد سقط جلدُه ولحمُه عن العظام حتى يتعلَّق جلدُه في كعبيه وعقبيه، وينجرُّ لحمه كَجَرِّ الرجل ثوبه{9}. (١٢/٦١٣) ٦٦٩٦٥- عن أبي رَزين [مسعود بن مالك الأسدي] -من طريق منصور- قال: <q>﴿وغَسّاقٌ﴾</q>، الغساق: ما يسيل مِن صديدهم{10}. (١٢/٦١٢) ٦٦٩٦٦- عن إبراهيم النخعي -من طريق منصور- قال: <q>﴿غَسّاقٌ﴾</q>، الغسّاق: ما يسيل من سُرْمهم{11}، وما ينقطع من جلودهم{12}. (ز) ٦٦٩٦٧- عن عبد الله بن بريدة -من طريق حيان- قال: <q>﴿وغَسّاقٌ﴾</q>، الغساق: المنتن، وهو بالطخارية{13}. (١٢/٦١٣) ٦٦٩٦٨- عن مجاهد بن جبر -من طريق ليث- قال: الغسّاق: الذي لا يستطيعون أن يذوقوه مِن شِدَّة بَرْدِه{14}. (١٢/٦١٢) ٦٦٩٦٩- عن مجاهد بن جبر -من طريق منصور- <q>﴿وغَسّاق﴾</q>، قال: ما يقطع مِن جلودهم{15}. (ز) ٦٦٩٧٠- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ وغَسّاقٌ﴾</q>، قال: يُقال الغساق: أبرد البرد. ويقول آخرون: لا، بل هو أنتن النتن{16}. (ز) ٦٦٩٧١- عن عطية العوفي -من طريق إدريس- في قوله: <q>﴿وغَسّاقٌ﴾</q>، قال: الذي يسيل من جلودهم{17}. (١٢/٦١٢) ٦٦٩٧٢- قال محمد بن كعب القرظي: <q>﴿وغَسّاقٌ﴾</q> هو عُصارة أهل النار{18}. (ز) ٦٦٩٧٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ وغَسّاقٌ﴾</q>، قال: كنا نحدَّث: أنّ الغساق: ما يسيل من بين جلده ولحمه{19}. (١٢/٦١٢) ٦٦٩٧٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وغَسّاقٌ﴾</q>: الغساق: الذي يسيل من أعينهم من دموعهم، يسقونه مع الحميم{20}. (ز) ٦٦٩٧٥- قال مقاتل بن سليمان: <q>﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ﴾</q> يعني: الحارّ الذي انتهى حرُّه وطبخه، <q>﴿وغَسّاقٌ﴾</q> البارد الذي قد انتهى برده، نظيرها في «عَمَّ يتساءلون»: <q>﴿إلّا حَمِيمًا وغَسّاقًا﴾</q> [النبأ:٢٥]، فينطلق من الحار إلى البارد فتقطع جلودهم، وتتصدع عظامهم، وتحرق كما يحرق حرُّ النارِ{2}. (ز) ٦٦٩٧٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وغَسّاقٌ﴾</q>: الغساق: الصديد يخرج من جلودهم مما تصهره النار في حياض يجتمع فيها فيُسقونه{3}٥٥٨٤. (ز) ٥٥٨٤ اختلف السلف في الغساق على أقوال: الأول: أنه ما يسيل من جلودهم من الصديد والدم. الثاني: أنه البارد الذي لا يستطاع من برده. الثالث: أنه المنتن. وقد رجّح ابنُ جرير (٢٠/١٣٠) مستندًا إلى الأغلب لغةً القول الأول، فقال: «وأولى الأقوال في ذلك عندي بالصواب: قولُ مَن قال: هو ما يسيل من صديدهم. لأن ذلك هو الأغلب من معنى الغسوق، وإن كان للآخر وجه صحيح». ",footnotes:1:أخرجه ابن جرير ٢٠/١٢٧.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٢٧-١٢٨.أخرجه أحمد ١٧/٣٣١ (٢/١١٢٣٠)، ١٨/٣١٠ (١١٧٨٦)، والترمذي ٤/٥٤٠-٥٤١ (٢٧٦٦)، والحاكم ٤/٦٤٤ (٨٧٧٩)، وابن جرير ٢٠/١٣٠، ٢٤/٣١-٣٢. قال الترمذي: «هذا حديث إنما نعرفه من حديث رشدين بن سعد، وفي رشدين مقال، وقد تُكلّم فيه من قبل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه ابن جرير ٢٠/١٣٢، وابن أبي حاتم -كما في الإتقان ٢/٤١-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/١١٥ (٢٦٣)، وابن جرير ٢٠/١٢٩، وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٧-.تفسير الثعلبي ٨/٢١٣، وتفسير البغوي ٧/٩٩.الحُمَة -بِالتَّخْفيف-: السَّمُّ. النهاية (حمه).أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٩ (٩١)-، وابن جرير ٢٠/١٢٩.أخرجه ابن المبارك في الزهد ١/٤٩٦، وابن أبي شيبة ١٣/٤١٩، وهناد (٢٩١). وعزاه السيوطي إلى عبد بن حميد.سُرمهم: مخرج الثُّفل. مختار الصحاح (سرم).أخرجه ابن جرير ٢٠/١٢٨، وأخرجه ابن المبارك في الزهد ١/٤٩٦ بلفظ: ما يسيل من صديدهم.أخرجه ابن جرير ٢٠/١٣٠. والطخارية: لغة أهل طخارستان. التاج (طخر).أخرجه هناد بن السري في الزهد (٢٩٠)، وابن جرير ٢٤/١٣٠ بنحوه من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٩ (٩٠)-.أخرجه ابن جرير ٢٠/١٣٠.أخرجه هناد (٢٨٩).تفسير الثعلبي ٨/٢١٣.أخرجه عبد الرزاق ٢/١٦٨ من طريق معمر، وابن جرير ٢٠/١٢٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٨.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٢٧-١٢٨.
38,58," <q>﴿وَءَاخَرُ مِن شَكۡلِهِۦۤ﴾</q> - قراءات ٦٦٩٧٧- عن مجاهد بن جبر أنه قرأ: ‹وأُخَرُ مِن شَكْلِهِ أزْواجٌ› برفع الألف ونصب الخاء{1}٥٥٨٥. (١٢/٦١٤) ٥٥٨٥ ذكر ابنُ جرير (٢٠/١٣٠-١٣١) هذه القراءة، ثم علَّق عليها، فقال: «وقرأ ذلك بعضُ المكيين وبعض البصريين: ‹وأُخَرُ› على الجماع، وكأنّ مَن قرأ ذلك كذلك كان عنده لا يصلح أن يكون الأزواج -وهي جمع- نعتًا لواحد، فلذلك جمع أُخَر لتكون الأزواج نعتًا لها؛ والعرب لا تمنع أن ينعت الاسم إذا كان فعلًا بالكثير والقليل والاثنين كما بينا، فتقول: عذاب فلان أنواع، ونوعان مختلفان». وذكر ابنُ جرير قراءة من قرأ ذلك بالتوحيد، وعلَّق عليها، فقال: «عامة قراء المدينة والكوفة: <q>﴿وآخر من شكله أزواج﴾</q> على التوحيد، بمعنى: هذا حميم وغساق فليذوقوه، وعذاب آخر من نحو الحميم ألوان وأنواع، كما يقال: لك عذاب من فلان ضروب وأنواع، وقد يحتمل أن يكون مرادًا بالأزواج: الخبر عن الحميم والغساق، وآخر من شكله، وذلك ثلاثة، فقيل: أزواج، يراد أن ينعت بالأزواج تلك الأشياء الثلاثة». ثم رجَّحها مستندًا إلى الأصحّ لغة وأقوال أهل التأويل بقوله: «وأعجب القراءتين إلَيَّ أن أقرأ بها: <q>﴿وآخر﴾</q> على التوحيد، وإن كانت الأخرى صحيحة لاستفاضة القراءة بها في قراء الأمصار، وإنما اخترنا التوحيد لأنه أصح مخرجًا في العربية، وأنه في التفسير بمعنى التوحيد. وقيل: إنه الزمهرير». ٦٦٩٧٨- عن الحسن [البصري] -من طريق عمرو [بن عبيد]-: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>{2}. (ز) <q>﴿وَءَاخَرُ مِن شَكۡلِهِۦۤ﴾</q> - تفسير الآية ٦٦٩٧٩- عن عبد الله بن مسعود -من طريق مرة الهمداني- في قوله: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>، قال: الزَّمْهَرِير{3}. (١٢/٦١٣) ٦٦٩٨٠- عن مرة، قال: ذكروا الزمهرير، فقال عبد الله [بن مسعود]: ذلك قول الله: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>. فقالوا لعبد الله: إنّ للزَّمْهَرِير بردًا. قال: فقرأ هذه الآية: <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا* إلّا حَمِيمًا وغَسّاقًا﴾</q> [النبأ:٢٤]{4}. (١٢/٦١٣) ٦٦٩٨١- عن عبد الله بن عباس -من طريق علي- <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>، قال: مِن نحوه{5}٥٥٨٦. (١٢/٦١٢) ٥٥٨٦ علّق ابنُ عطية (٧/٣٥٨) على ما جاء في هذا القول، فقال: «<q>﴿مِن شَكْلِهِ﴾</q> في موضع الصفة. ومعنى <q>﴿مِن شَكْلِهِ﴾</q>: من مثله وضربه. وجاز على هذا القول أن يخبر الجمع الذي هو أزواج عن الواحد من حيث ذلك الواحد درجات ورُتَب من العذاب، وقوي وأقل منه. وأيضًا فمن جهة أخرى على أن يسمى كل جزء من ذلك الآخر باسم الكل، قالوا: عرفات لعرفة، وشابت مفارقه، فجعلوا كل جزء من المفرق مفرقًا، وكما قالوا: جمل ذو عثانين ونحو هذا، ألا ترى أن جماعة من المفسرين قالوا: إنّ هذا الآخر هو الزمهرير، فكأنهم جعلوا كل جزء منه زمهريرًا». ٦٦٩٨٢- عن الحسن البصري -من طريق مبارك بن فضالة- قال: ذكر الله العذابَ، فذكر السلاسلَ والأغلالَ وما يكون في الدنيا، ثم قال: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>، قال: وآخر لم يُرَ في الدنيا{6}. (١٢/٦١٤) ٦٦٩٨٣- عن قتادة بن دعامة -من طريق سعيد <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>: من نحوه{6}. (ز) ٦٦٩٨٤- قال مقاتل بن سليمان: ثم قال: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>، يقول: وآخر من شكله، يعني: من نحو الحميم والغساق{8}. (ز) ٦٦٩٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>، قال: مِن كل شكل ذلك العذاب الذي سمى الله أزواجٌ لم يُسَمِّها الله. قال: والشكل: الشبيه{9}. (ز) <q>﴿أَزۡوَ ٰ⁠جٌ ۝٥٨﴾</q> - تفسير ٦٦٩٨٦- عن عبد الله بن عباس -من طريق علي- <q>﴿أزْواجٌ﴾</q>، قال: ألوان مِن العذاب{5}. (١٢/٦١٢) ٦٦٩٨٧- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</q>، قال: ألوان من العذاب{11}. (١٢/٦١٤) ٦٦٩٨٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أزْواجٌ﴾</q>، قال: زوجٌ زوجٌ من العذاب{9}. (ز) ٦٦٩٨٩- قال مقاتل بن سليمان: <q>﴿أزْواجٌ﴾</q>: أصناف، يعني: ألوان من العذاب في الحميم، يشبه بعضه بعضًا في شبه العذاب{8}. (ز) ٦٦٩٩٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أزْواجٌ﴾</q>، قال: أزواج من العذاب في النار{9}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وأخرجه إسحاق البستي ص٢٥٣ من طريق هارون. وهي قراءة متواترة، قرا بها أبو عمرو، ويعقوب، وقرأ بقية العشرة: <q>﴿وآخَرُ﴾</q> بفتح الهمزة وألف بعدها. انظر: النشر ٢/٣٦١، والإتحاف ص٤٧٨.أخرجه إسحاق البستي ص٢٥٣.أخرجه سفيان الثوري ص٢٦٠-٢٦١، وعبد الرزاق ٢/١٦٦-١٦٧، وابن جرير ٢٠/١٣٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٣٢، وابن أبي حاتم -كما في الإتقان ٢/٤١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٢.أخرجه ابن جرير ٢٠/١٣٢.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٣٣.أخرجه ابن جرير ٢٠/١٣٢، وابن أبي حاتم -كما في الإتقان ٢/٤١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٣، وابن أبي شيبة ١٣/١٦٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٣.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٣٣.
38,59," <q>﴿هَـٰذَا فَوۡجࣱ مُّقۡتَحِمࣱ مَّعَكُمۡ لَا مَرۡحَبَۢا بِهِمۡۚ إِنَّهُمۡ صَالُوا۟ ٱلنَّارِ ۝٥٩﴾</q> - تفسير ٦٦٩٩١- عن عبد الله بن عباس، <q>﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ﴾</q>: هو أنّ القادة إذا دخلوا النار، ثم دخل بعدهم الأتباعُ؛ قالت الخزنةُ للقادة: <q>﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ لا مَرْحَبًا بِهِمْ إنَّهُمْ صالُو النّارِ﴾</q>{1}. (ز) ٦٦٩٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ﴾</q> إلى قوله: <q>﴿فَبِئْسَ القَرارُ﴾</q>، قال: هؤلاء الأتباع يقولونه للرؤوس{2}. (١٢/٦١٤) ٦٦٩٩٣- قال مقاتل بن سليمان: <q>﴿هَذا فَوْجٌ﴾</q> يعني: زُمْرَة <q>﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ﴾</q> وذلك أنّ القادة فى الكفر، المُطعمين في غزاة بدر، والمستهزئين مِن رؤساء قريش؛ دخلوا النار قبل الأتباع، فقالت الخزنة للقادة وهم في النار: <q>﴿مُقْتَحِمٌ مَعَكُمْ﴾</q> النار. إضمار، يعنون: الأتباع. قالت القادة: لا مرحبًا بهم. قال الخزنة: <q>﴿إنَّهُمْ صالُو النّارِ﴾</q> معكم{3}٥٥٨٧. (ز) ٥٥٨٧ قال ابنُ عطية (٧/٣٥٩): «والأظهر أن قائل ذلك لهم: ملائكة العذاب، وهو الذي حكاه الثعلبي وغيره، ويحتمل أن يكون ذلك من قول بعضهم لبعض». ٦٦٩٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ لا مَرْحَبًا بِهِمْ﴾</q>، قال: الفوج: القوم الذين يدخلون فوجًا بعد فوج. وقرأ: <q>﴿كُلَّما دَخَلَتْ أُمَّةٌ لَعَنَتْ أُخْتَها﴾</q> [الأعراف:٣٨] التي كانت قبلها{4}. (ز) ٦٦٩٩٥- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿هذا فوج مقتحم معكم﴾</q>، قال: داخل معكم{5}. (ز) ",footnotes:1:تفسير البغوي ٧/٩٩.أخرجه ابن جرير ٢٠/١٣٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٣٤.أخرجه إسحاق البستي ص٢٥٢.
38,60," <q>﴿قَالُوا۟ بَلۡ أَنتُمۡ لَا مَرۡحَبَۢا بِكُمۡۖ أَنتُمۡ قَدَّمۡتُمُوهُ لَنَاۖ فَبِئۡسَ ٱلۡقَرَارُ ۝٦٠﴾</q> - تفسير ٦٦٩٩٦- قال مقاتل بن سليمان: فردَّت الأتباعُ مِن كُفّار مكة على القادة <q>﴿قالُوا بَلْ أنْتُمْ لا مَرْحَبًا بِكُمْ أنْتُمْ قَدَّمْتُمُوهُ لَنا﴾</q> زينتموه لنا هذا الكفر، <q>﴿إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ ونَجْعَلَ لَهُ أنْدادًا﴾</q> [سبأ:٣٣]، <q>﴿فَبِئْسَ القَرارُ﴾</q> يعني: فبئس المستقر{1}٥٥٨٨. (ز) ٥٥٨٨ ذكر ابنُ القيم (٢/٣٨٣-٣٨٤) في عود الضمير من قوله: <q>﴿قدمتموه﴾</q> قولين، وعلّق عليهما، فقال: «وفي الضمير قولان: أحدهما: أنّه ضمير الكفر والتكذيب ورد قول الرسول ﷺ واستبدال غيره به، والمعنى: أنتم زينتم لنا الكفر ودعوتمونا إليه وحسنتموه لنا، وقيل على هذا القول: أنه قول الأمم المتأخرين للمتقدمين، والمعنى على هذا: أنتم شرعتم لنا تكذيب الرسل ورد ما جاءوا به والشرك بالله ﷾، وبدأتم به وتقدمتمونا إليه فدخلتم النار قبلنا فبئس القرار، أي: بئس المستقر والمنزل. والقول الثاني: أن الضمير في قوله: <q>﴿أنتم قدمتموه لنا﴾</q> ضمير العذاب وصُلِيّ النار، والقولان متلازمان، وهما حقٌّ». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥١.
38,61," <q>﴿قَالُوا۟ رَبَّنَا مَن قَدَّمَ لَنَا هَـٰذَا﴾</q> - تفسير ٦٦٩٩٧- قال مقاتل بن سليمان: قالت الأتباع: <q>﴿قالُوا رَبَّنا مَن قَدَّمَ لَنا هَذا﴾</q> يعني: مَن زيَّن لنا هذا، يعني: مَن سبَّب لنا هذا الكفر <q>﴿فَزِدْهُ عَذابًا ضِعْفًا فِي النّارِ﴾</q>{1}. (ز) <q>﴿فَزِدۡهُ عَذَابࣰا ضِعۡفࣰا فِی ٱلنَّارِ ۝٦١﴾</q> - تفسير ٦٦٩٩٨- عن عبد الله بن مسعود -من طريق مرة- في قوله: <q>﴿فَزِدْهُ عَذابًا ضِعْفًا فِي النّارِ﴾</q>، قال: أفاعي، وحيّات{2}. (١٢/٦١٥) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥١-٦٥٢.أخرجه الطبراني في المعجم الكبير ٩/٢٢٦ (٩١٠٢). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.
