quran[19]{c,v,t}:
  38,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَهَبۡنَا لَهُۥۤ أَهۡلَهُۥ وَمِثۡلَهُم مَّعَهُمۡ رَحۡمَةࣰ مِّنَّا وَذِكۡرَىٰ لِأُو۟لِی ٱلۡأَلۡبَـٰبِ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٥٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: وردّ عليه أهلَه وولدَه وأموالَه من البقر والغنم والحيوان وكل شيء هلك بعينه، ثم أبقاه الله فيها حتى وهب له مِن نسولها أمثالها، فهو قوله: <span class="qpc-hafs">﴿ووَهَبْنا لَهُ أهْلَهُ ومِثْلَهُمْ مَعَهُمْ رَحْمَةً مِنّا﴾</span>، وكانوا ماتوا غيرَ الموت الذي أتى على آجالهم تسليطًا مِن الله للشيطان؛ فأحياهم الله، فوفّاهم آجالهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿ووَهَبْنا لَهُ أهْلَهُ ومِثْلَهُمْ مَعَهُمْ﴾</span>، قال: فأحياهم الله بأعيانهم، وزاده مثلهم معهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ووَهَبْنا لَهُ أهْلَهُ ومِثْلَهُمْ مَعَهُمْ﴾</span> فأضعف الله ﷿ له، وكان له سبعَ بنين وثلاثَ بنات قبل البلاء، وولدت له امرأتُه بعد البلاء سبعَ بنين وثلاثَ بنات، فأضعف الله له <span class="qpc-hafs">﴿رَحْمَةً﴾</span> يعني: نعمة <span class="qpc-hafs">﴿مِنّا﴾</span>، ثم قال: <span class="qpc-hafs">﴿وذِكْرى﴾</span> يعني: تَفَكُّر <span class="qpc-hafs">﴿لِأُولِي الأَلْبابِ﴾</span> يعني: أهل اللُّبِّ والعقل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٣<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span> في قوله: <span class="qpc-hafs">﴿ووَهَبْنا لَهُ أهْلَهُ﴾</span> قال: أحيينا له أهله، <span class="qpc-hafs">﴿ومِثْلَهُمْ مَعَهُمْ﴾</span>{4}<span class=comment-ref>٥٥٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٧٨</span> أفادت الآثارُ أنّ الله تعالى ردَّ على أيوب أهلَه ومَن هلك مِن حاشيته ورعيته في الدنيا. وقد ذكر <u>ابنُ عطية</u> (٧/٣٥٣) هذا القول، و<b>قولًا آخر</b>: أنّ ذلك كله وعد في الآخرة. ثم <span class="comment-type-4">علّق</span> بقوله: «والأول أكثر في قول المفسرين».</div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٤-.أخرجه ابن جرير ٢٠/١١٠.تفسير مقاتل بن سليمان ٣/٦٤٨.تفسير سفيان الثوري (٢٥٩).
  38,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَخُذۡ بِیَدِكَ ضِغۡثࣰا فَٱضۡرِب بِّهِۦ وَلَا تَحۡنَثۡۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يوسف بن مهران- قال: إنّ إبليس قعد على الطريق، واتَّخذ تابوتًا يداوي الناس، فقالت امرأةُ أيوب: يا عبد الله، إنّ ههنا مُبتلىً مِن أمره كذا وكذا، فهل لك أن تداويه؟ قال: نعم، بشرط إن أنا شفيته أن يقول: أنت شفيتَني. لا أريد منه أجرًا غيره، فأتت أيوبَ، فذكرت ذلك له، فقال: ويحكِ، ذاك الشيطانُ، لله عَلَيَّ إن شفاني اللهُ أن أجلدك مائة جلدة. فلمّا شفاه الله أمره أن يأخذ ضِغثًا، فيضربها به، فأخذ عِذقًا فيه مائة شِمْراخ{1}، فضربها به ضربة واحدة{2}. (١٢/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: هو الأَثْل{3}. (١٢/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: الضِّغث: القبضة من الرِّيحان الرَّطْب{4}. (١٢/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: حُزمة{5}. (١٢/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: أُمر أن يأخذ ضِغثًا من رطبة بقدر ما حلف عليه، فيضرب به{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>: وذلك أنّه أمره أن يأخذ ضِغثًا فيه مائة طاق{7} من عيدان القتِّ{8}، فيضرب به امرأتَه لليمين التي كان يحلف عليها. قال: ولا يجوز ذلك لأحد بعد أيوب إلا الأنبياء{9}. (١٢/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>، أنه بلغه: أنّ أيوب حلف لَيضربن امرأتَه مائةً في أن جاءته بزيادة على ما كانت تأتي به مِن الخبز الذي كانت تعمل عليه، وخشي أن تكون قارفت شيئًا من الخيانة، فلمّا ﵀ وكشف عنه الضر عَلِم براءةَ امرأته مما اتهمها به، فقال الله ﷿: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</span>. فأخذ ضِغثًا من ثُمام{10}، وهو مائة عود، فضرب به كما أمره الله تعالى{4}. (١٢/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: هي لأيوب خاصة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٢<span class="dash">-</span></span> وقال <span class="name-2">عطاء</span>: هي للناس عامَّة{12}. (١٢/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: جماعة من الشجر، وكانت لأيوب خاصة، وهي لنا عامة{13}. (١٢/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- قال في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>: يعني: ضِغثًا من الشجر الرَّطب، كان حلف على يمين، فأخذ مِن الشجر عددَ ما حلف عليه، فضرب به ضربة واحدة، فبرّت يمينه، وهو اليوم في الناس يمين أيوب، مَن أخذ بها فهو حسن{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن</span>: أنّ إبليس أتى امرأتَه، فقال لها: إن أكل أيوب ولم يُسَمِّ عوفي. فعرضت ذلك على أيوب، فحلف ليضربنها مائة، فلما عُوفي أمره الله أن يأخذ عرجونًا فيه مائة شِمراخ، فضربها ضربةً واحدةً{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٦<span class="dash">-</span></span> قال يحيى بن سلّام: قال <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</span>، إنّ امرأة أيوب كانت قاربت الشيطان في بعض الأمر، ودعت أيوبَ إلى مقاربته؛ فحلف بالله لئن الله عافاه أن يجلدها مائة جلدة، ولم تكن له نِيَّةٌ بأيِّ شيء يجلدها، فمكث في ذلك البلاءِ حتى أذن الله له في الدعاء، وتمَّت له النعمة مِن الله والأجر، فأتاه الوحي مِن الله، وكانت امرأتُه مسلمةً قد أحسنت القيام عليه، وكانت لها عند الله منزلة، فأوحى الله إليه: أن يأخذ بيده ضغثًا -والضِّغث: أن يأخذ قبضة. قال بعضهم: مِن السنبل، وكانت مائة سنبلة. وقال بعضهم: من الأسَل، والأسَل: السمار{16}-، فيضربها به ضربة واحدة ففعل {17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٧<span class="dash">-</span></span> عن <span class="name-2">معاوية بن قرة</span>، قال: ... الضِغث: أن يأخذ الحزمة مِن السياط، فيضرب بها الضربة الواحدة{18}. (١٢/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: عودًا فيه تسعة وتسعون عودًا، والأصل تمام المائة. وذلك أنّ امرأته قال لها الشيطان: قولي لزوجك يقول: كذا وكذا. فقالت له، فحلف أن يضربها مائةً، فضربها تلك الضربة، فكانت تحِلَّةً ليمينه، وتخفيفًا عن امرأته{19}. (١٢/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٦٩<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن جبير</span> -من طريق صفوان- قال: ابتُلِي أيوبُ بماله وولده وجسده، حتى طُرِح في المزبلة، جعلت امرأته تخرج تكسب عليه ما تطعمه، فحسده الشيطان على ذلك، فكان يأتي أصحابَ الخبز والشاء الذين كانوا يتصدقون عليها، فيقول: اطردوا هذه المرأة التي تغشاكم؛ فإنها تعالج صاحبَها، وتلمسه بيدها، فالناس يتقذَّرون طعامَكم مِن أجلها، إنها تأتيكم وتغشاكم. فجعلوا لا يدنونها منهم، ويقولون: تباعدي عَنّا، ونحن نطعمك ولا تقربينا. فأخبرت بذلك أيوب، فحمد الله على ذلك، وكان يلقاها إذا خرجت كالمتحزِّن بما لقي أيوب، فيقول: لَجَّ صاحبُك، وأبى إلا ما أتى، واللهِ، لو تكلم بكلمة واحدة لكُشف عنه كل ضر، ولرجع إليه ماله وولده. فتجيء فتخبر أيوب، فيقول لها: لقيك عدوُّ الله فلقّاك هذا الكلام! لئن أقامني اللهُ مِن مرضي لأجلدنك مائة. فلذلك قال الله تعالى: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</span>. يعني بالضِّغث: القبضة مِن المكانس{20}. (١٢/٦٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٠<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: عيدانًا رطبة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span> يعني بالضغث: القبضة الواحدة، فأخذ عيدانًا رطبة -وهي الأسل- مائة عود، عدد ما حلف عليه، وكان حلف ليجلدن امرأته مائة جلدة، <span class="qpc-hafs">﴿فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</span> يعني: ولا تأثم في يمينك التي حلفت عليها، فعَمَدَ إليها، فضربها بمائة عود ضربة واحدة، فأوجعها، فبرئت يمينه، وكان اسمها: دنيا{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٢<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا﴾</span>، قال: لم يُجعَل لأحدٍ بعده{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وخُذْ بِيَدِكَ ضِغْثًا فاضْرِبْ بِهِ ولا تَحْنَثْ﴾</span>، قال: ضِغثًا واحدًا مِن الكلأ فيه أكثر من مائة عود، فضرب به ضربةً واحدةً، فذلك مائة ضربة{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَخُذۡ بِیَدِكَ ضِغۡثࣰا فَٱضۡرِب بِّهِۦ وَلَا تَحۡنَثۡۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٧٤<span class="dash">-</span></span> عن سهل بن سعد: أنّ النبي ﷺ أُتي بشيخ أحبن{25} مُصْفَرٍّ قد ظهرت عروقه، قد زنى بامرأة، فضربه بضغث فيه مائة شمراخ ضربة واحدة{26}. (١٢/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٥<span class="dash">-</span></span> عن أبي أمامة بن سهل بن حنيف، قال: حملت وليدةٌ في بني ساعدة مِن زنًا، فقيل لها: مِمَّن حَمْلُكِ؟ قالت: مِن فلان المُقعَد. فسُئل المُقعَد، فقال: صدَقَتْ. فرفُع ذلك إلى رسول الله ﷺ، فقال: «<b>خذوا له عُثكولًا</b>{27} <b>فيه مائة شِمراخ، فاضربوه به ضربةً واحدةً</b>». ففعلوا{28}. (١٢/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٦<span class="dash">-</span></span> عن سعيد بن سعد بن عبادة، قال: كان في أبياتنا إنسانٌ ضعيف مُخدَج{29}، فلم يُرَعْ أهلُ الدار إلا وهو على أمَة مِن إماء أهل الدار يخبث بها، وكان مسلمًا، فرفع سعدٌ شأنه إلى رسول الله ﷺ، فقال: «<b>اضربوه حدَّه</b>». فقالوا يا رسول الله، إنّه أضعف مِن ذلك، إن ضربناه مائة قتلناه. قال: «<b>فخذوا له عِثكالًا فيه مائة شمراخ، فاضربوه ضربة واحدة، وخلّوا سبيله</b>»{30}. (١٢/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٧<span class="dash">-</span></span> عن عبد الله بن <span class="name-2">عبيد بن عمير</span>، عن أبيه، قال: إذا حلف الرجلُ يضرب غلامه؛ حلَّل يمينَه بها، وضرب. وتأول هذه الآية: <span class="qpc-hafs">﴿وخذ بيدك ضغثًا فاضرب به ولا تحنث﴾</span>{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٨<span class="dash">-</span></span> عن عبد الواحد بن أيمن، عن <span class="name-2">عطاء</span>، قال: أتاه رجل، فقال: إنِّي حلفت ألا أكسو امرأتي درعًا حتى تقف بعرفة. فقال: احملها على حمار، ثم اذهب، فقفْ بها عرفة. فقال: إنما عنيتُ يوم عرفة. فقال له عطاء: وأيوب حين حلف ليجلدن امرأته مئة جلدة؛ أنَوى أن يضربها بالضغث؟ إنما أمره الله أن يأخذ ضغثًا فيضربها به. قال <span class="name-2">عطاء</span>: إنما القرآن عِبَر، إنما القرآن عِبَر{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٧٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: زوجة أيوب رحمة بنت منشأ بن يوسف بن يعقوب بن إسحاق بن إبراهيم ﵈{33}. (١٢/٦٠٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّا وَجَدۡنَـٰهُ صَابِرࣰاۚ نِّعۡمَ ٱلۡعَبۡدُ إِنَّهُۥۤ أَوَّابࣱ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أثنى الله ﷿ على أيوب، فقال: <span class="qpc-hafs">﴿إنّا وجَدْناهُ صابِرًا﴾</span> على البلاء، إضمار، <span class="qpc-hafs">﴿نِعْمَ العَبْدُ إنَّهُ أوّابٌ﴾</span> يعني: مطيعًا لله تعالى. لما برأ أيوب فاغتسل كساه جبريل ﵇ حُلَّة{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّا وَجَدۡنَـٰهُ صَابِرࣰاۚ نِّعۡمَ ٱلۡعَبۡدُ إِنَّهُۥۤ أَوَّابࣱ ۝٤٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق ابن سخبرة- قال: أيوب رأس الصابرين يوم القيامة{35}. (١٢/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ امرأة أيوب قالت: يا أيوب، إنّك رجل مباح{36} الدعوة، فادعُ الله أن يشفيك. فقال: ويحكِ، كُنّا في النعماء سبعين سنة، فدعِينا نكون في البلاء سبعين سنة. فكان في البلاء سبع سنين{13}. (١٢/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٣<span class="dash">-</span></span> عن سعيد بن العاص، قال: نودي أيوب: يا أيوب، لولا أنِّي أفرغتُ مكان كل شعرة منك صبرًا ما صبرتَ{38}. (١٢/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- قال: كان أيوبُ كُلَّما أصابه مصيبةٌ؛ قال: اللهم، أنت أخذتَ، وأنت أعطيتَ، مهما تُبقي نفسي أحمدك على حُسن بلائك{39}. (١٢/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عمران بن الهذيل- أنه سمعه يقول: أصاب أيوبَ البلاءُ سبعَ سنين{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٦<span class="dash">-</span></span> عن <span class="name-3">ليث بن أبي سليم</span>، قال: قيل لأيوب: يا أيوب، لا يُعجبنَّك صبرك، فلولا أني أعطيتُ موضع كل شعرة منك صبرًا ما صبرتَ{41}. (١٢/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٧<span class="dash">-</span></span> عن عمرو بن السكن، قال: كنت عند <span class="name-3">سفيان بن عيينة</span>، فقام إليه رجل مِن أهل بغداد، فقال: يا أبا محمد، أخبِرني عن قول مُطرِّف: لأن أُعافى فأشكُر أحب إليَّ مِن أن أُبتلى فأصبر. أهو أحبُّ إليك أم قول أخيه أبي العلاء: اللهم، رضيتُ لنفسي ما رضيتَ لي؟ قال: فسكت سكتة، ثم قال: قول مطرف أحبُّ إلَيَّ. فقال الرجل: كيف وقد رضي هذا لنفسه ما رضيه الله له. قال سفيان: إني قرأت القرآن فوجدت صفة سليمان مع العافية التي كان فيها: <span class="qpc-hafs">﴿نعم العبد إنه أواب﴾</span> [ص:٣٠]. ووجدت صفة أيوب مع البلاء الذي كان فيه: <span class="qpc-hafs">﴿نعم العبد إنه أواب﴾</span>، فاستوت الصفتان؛ وهذا معافًى، وهذا مبتلًى، فوجدتُ الشكر قد قام مقام الصبر، فلمّا اعتدلا كانت العافية مع الشكر أحبُّ إلَيَّ مِن البلاء مع الصبر{42}. (ز)</p></p><p></div></p></div>",footnotes:1:الشِّمْراخ: العِثْكال الذي عليه البُسْر، وأَصله في العِذْق، وقد يكون في العنب. اللسان (شمرخ).أخرجه ابن عساكر ١٠/٧٦. وعزاه السيوطي إلى أحمد في الزهد، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٠/١١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١١، وابن أبي حاتم -كما في الإتقان ٢/٤٠-.أخرجه ابن جرير ٢٠/١١١-١١٢.الطّاقَة: شُعْبَة من ريحان أو شعر وقوة من الخيط أو نحو ذلك. ويقال: طاق نعل وطاقة رَيْحان. اللسان (طوق).القَتُّ: الفِصْفِصَة، وهي الرَّطبة من علف الدَّواب. النهاية (قتت).أخرجه ابن عساكر ٦٩/١٢٤.الثُّمام: نبْت ضعيف قصير لا يطول. النهاية (ثمم).عزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه - التفسير ٧/١٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه سفيان الثوري (٢٦٠) عن مجاهد بلفظ: كانت له رخصة. وكذا ابن عساكر في تاريخ دمشق ٩/٦٨. وعلقه النحاس في الناسخ والمنسوخ (٦٤٨).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٢.أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٤٢١-.كذا في مطبوعة المصدر، ولعله «السَّمُر». والأَسَل: نبات له أغصان كثيرة دقاق لا ورق لها. النهاية (أسل).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٥-.عزاه السيوطي إلى عبد بن حميد. وتقدم قريبًا بتمامه.أخرجه عبد الرزاق ٢/١٦٧-١٦٨ من طريق معمر واللفظ له، وابن جرير ٢٠/١١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أحمد في الزهد ص٨٩، وابن جرير ٢٠/١١١، ١١٣.أخرجه ابن جرير ٢٠/١١٢.تفسير مقاتل بن سليمان ٣/٦٤٨.تفسير سفيان الثوري (٢٥٩).أخرجه ابن جرير ٢٠/١١٢.الأحبن: المستسقى، من الحبَن –بالتحريك- وهو عِظَم البطْن. النهاية (حبن).أخرجه الطبراني في الكبير ٦/١٥٢ (٥٨٢٠) من طريق أبي بكر بن أبي سبرة، قال: حدثني أبو حازم، عن سهل بن سعد به.</p><p>قال الهيثمي في المجمع ٦/٢٥٢ (١٠٥١٨): «فيه أبو بكر بن سبرة، وهو متروك».العُثْكول: العِذْق، وكلّ غُصْنٍ من أغصانِهِ شِمْراخ. النهاية (شمرخ) و(عثكل).أخرجه النسائي ٨/٢٤٢، وأبو داود ٤/١٢١ من طرق وألفاظ مختلفة، فرُوِيَ موصولًا ومرسلًا من حديث أبي الزناد عن أبي أمامة، ومن طريق أبي أمامة بن سهل عن أبيه، ومن طريق أبي أمامة عن النبي ﷺ مرسلًا.</p><p>قال الدارقطني في سننه ٤/٩٢: «والصواب عن أبي حازم عن أبي أمامة بن سهل عن النبي ﷺ». وكذا رجَّح إرساله في علله -كما في البدر المنير لابن الملقّن ٨/٦٢٦-، وقال البيهقي بعد ذكر بعض طرقه ٨/٢٣٠: «هذا هو المحفوظ عن سفيان مرسلًا، وروي عنه موصولًا بذكر أبي سعيد فيه .. وقيل: عن أبى الزناد عن أبى أمامة عن أبيه...».مخدج: ناقص الخلقة. النهاية (خدج).أخرجه أحمد ٣٦/٢٦٣ (٢١٩٣٥)، وابن ماجه ٣/٦٠٤-٦٠٥ (٢٥٧٤).</p><p>قال البوصيري في مصباح الزجاجة ٣/١١٠ (٢١٩): «هذا إسناد ضعيف ... لأن مدار الإسناد على محمد بن إسحاق، وهو مدلّس، وقد رواه بالعنعنة». وقال ابن حجر في بلوغ المرام ٢/١٤٢ (١٢١٥): «وإسناده حسن، لكن اختلف في وصله وإرساله». وأورده الألباني في الصحيحة ٦/١٢١٥ (٢٩٨٦).أخرجه إسحاق البستي ص٢٥١.أخرجه سعيد بن منصور في سننه- التفسير ٧/١٨٦-١٨٧ (١٨٤٧).أخرجه ابن عساكر ١٠/٥٨.تفسير مقاتل بن سليمان ٣/٦٤٨.أخرجه ابن عساكر ١٠/٦٦.مباح الدعوة: حلال لك أن تدعو. التاج (بوح).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن عساكر ١٠/٦٩.أخرجه ابن أبي شيبة ١٣/٢٠٩. وعزاه السيوطي إلى أحمد في الزهد.أخرجه عبد الرزاق ٢/١٦٧.أخرجه ابن عساكر ١٠/٦٨.أخرجه أبو نعيم في حلية الأولياء ٢/٢١٢-٢١٣.
  38,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱذۡكُرۡ عِبَـٰدَنَاۤ إِبۡرَ ٰ⁠هِیمَ وَإِسۡحَـٰقَ وَیَعۡقُوبَ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- أنه كان يقرأ: ‹واذْكُرْ عَبْدَنَآ إبْراهِيمَ›، ويقول: إنما ذكر إبراهيم، ثم ذكر بعده ولده{1}. (١٢/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٨٩<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿واذْكُرْ عِبادَنا﴾</span> على الجماع <span class="qpc-hafs">﴿إبْراهِيمَ وإسْحاقَ ويَعْقُوبَ﴾</span>{2}<span class=comment-ref>٥٥٧٩</span>. (١٢/٦٠٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٧٩</span> <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٠/١١٤) <span class="mustanad">مستندًا إلى إجماع الحجة من القراء</span> قراءة الجمع، فقال: «والصواب عندنا من القراءة في ذلك: قراءة من قرأه على الجماع، على أن إبراهيم وإسحاق ويعقوب بيان عن العباد، وترجمة عنه؛ لإجماع الحجة من القراء عليه».</p><p>و<span class="comment-type-4">علَّق</span> عليها <u>ابنُ عطية</u> (٧/٣٥٥) بقوله: «فأما على هذه القراءة فدخل الثلاثة في الذكر، وفي العبودية». و<span class="comment-type-4">علَّق</span> على قراءة من قرأ ذلك ‹عَبْدَنا› فقال: «وأما على قراءة من قرأ ‹عَبْدَنا›؛ فقال مكي وغيره: دخلوا في الذكر، ولم يدخلوا في العبودية إلا من غير هذه الآية». و<span class="comment-type-2">انتقد</span> قول مكي بقوله: «وفي هذا نظر».</div></p><p><h3><span class="qpc-hafs">﴿أُو۟لِی ٱلۡأَیۡدِی وَٱلۡأَبۡصَـٰرِ ۝٤٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنّه كان يقرؤه: (أُولِي الأَيْدِ) بغير ياء{3}<span class=comment-ref>٥٥٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٢٠/١١٦) على هذه القراءة، فقال: «وقد ذكر عن عبد الله أنه كان يقرؤه: (أُولِي الأَيْدِ) بغير ياء، وقد يحتمل أن يكون ذلك من التأييد، وأن يكون بمعنى: الأيدي، ولكنه أسقط منه الياء، <span class="mustanad">كما قيل</span>: <span class="qpc-hafs">﴿يوم يناد المناد﴾</span> [ق:٤١] بحذف الياء».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٣٥٥) قراءة إثبات الياء ونسبها إلى جمهور القراء، وذكر القراءة بحذفها، ثم رتب عليهما عدة أوجه في تفسير الآية، فقال: «وأما القراءة الأولى فـ<span class="qpc-hafs">﴿الأيدي﴾</span> فيها عبارة عن القوة في طاعة الله، قاله ابن عباس ومجاهد، <b>وقالت فرقة</b>: بل معناه: أولي الأيدي والنعم التي أسداها الله تعالى إليهم؛ من النبوة والمكانة. <b>وقالت فرقة</b>: بل هي عبارة عن إحسانهم في الدين وتقديمهم عند الله تعالى أعمال صدق، فهي كالأيادي. <b>وقال قوم</b>: المعنى: أيدي الجوارح، والمراد الأيدي المتصرفة في الخير والأبصار الثاقبة فيه، لا كالتي هي مهملة في جل الناس». ثم ذكر قراءة من قرأ ذلك بغير ياء، و<span class="comment-type-4">علَّق</span> عليها، فقال: «وأما من قرأ (الأَيْدِ) دون ياء <b>فيحتمل</b> أن يكون معناها معنى القراءة بالياء وحذفت تخفيفًا، ومن حيث كانت الألف واللام تعاقب التنوين وجب أن تحذف معها كما تحذف مع التنوين».</div></p><p><div></p><p><p><span class="item-no">٦٦٨٩١<span class="dash">-</span></span> عن هارون، قال: كان <span class="name-2">أبو عمرو [بن العلاء]</span> يقول: (أُولِي الأَيْدِ والأَبْصارِ)، يعني: البصر في الدين{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لِی ٱلۡأَیۡدِی وَٱلۡأَبۡصَـٰرِ ۝٤٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٨٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span> قال: أولي القوة في العبادة، <span class="qpc-hafs">﴿والأَبْصارِ﴾</span> قال: الفقه في الدين{5}. (١٢/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span> قال: القوة في العبادة، <span class="qpc-hafs">﴿والأَبْصارِ﴾</span> قال: القوة في الدين{6}. (١٢/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span>، قال: فُضِّلوا بالقُوَّة والعبادة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span> قال: القوة في العبادة، <span class="qpc-hafs">﴿والأَبْصارِ﴾</span> قال: البصر في أمر الله{6}. (١٢/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span>، قال: النِّعمة{9}. (١٢/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span>، قال: أما الأيد: فهو القوة في العمل. وأما الأبصار: فالبصر بما هم فيه من أمر دينهم{2}. (١٢/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span> قال: القوة في أمر الله، <span class="qpc-hafs">﴿والأَبْصارِ﴾</span> قال: العقول{11}. (١٢/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٨٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span> قال: القوة في طاعة الله، <span class="qpc-hafs">﴿والأبصار﴾</span> قال: البصر في الحق{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span>، قال: أولي الأيدي على الناس بالمعروف{2}. (١٢/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠١<span class="dash">-</span></span> عن هارون، عن عمرو، عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span> يعني: أولو القوة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٢<span class="dash">-</span></span> قال: وكان <span class="name-2">أبو عمرو [بن العلاء]</span> يقول: (أُولِي الأَيْدِ والأَبْصارِ)، يعني: البصر في الدين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر، وسعيد- <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span>، قال: أولي القوة في العبادة. وفي لفظ: قال: أُعطوا قوة في العبادة، وبصرًا في الدين{15}. (١٢/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿أُولِي الأَيْدِي والأَبْصارِ﴾</span>، قال: الأيدي: القوة في طاعة الله. والأبصار: البصر بعقولهم في دينهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٥<span class="dash">-</span></span> عن <span class="name-2">منصور [بن المعتمر]</span> -من طريق شعبة- أنه قال في هذه الآية: <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span>، قال: القُوَّة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿أولي الأيدي والأبصار﴾</span>، قال: القوة في العبادة، والبصر في أمر الله ﷿{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واذْكُرْ﴾</span> يا محمد صَبْرَ <span class="qpc-hafs">﴿عِبادَنا إبْراهِيمَ﴾</span> حين أُلْقِي في النار، <span class="qpc-hafs">﴿و﴾</span>صبر <span class="qpc-hafs">﴿إسْحاقَ﴾</span> للذبح، <span class="qpc-hafs">﴿و﴾</span>صبر <span class="qpc-hafs">﴿يَعْقُوبَ﴾</span> فى ذهاب بصره، ولم يذكر إسماعيل بن إبراهيم؛ لأنه لم يُبتلَ، واسم أم يعقوب: رفقا، <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span> يعني: أولي القوة في العبادة، <span class="qpc-hafs">﴿والأَبْصارِ﴾</span> يعني: البصيرة في أمر الله ودينه{19}<span class=comment-ref>٥٥٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨١</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿أولي الأيدي والأبصار﴾</span> على أقوال: <b>الأول</b>: أن الأيدي القوة في الطاعة، والأبصار: أنهم أهل بصائر في الدين والعلم. <b>الثاني</b>: أن الأيدي: النعمة.</p><p>وقد <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٠/١١٤) أن المعنى: أنهم أهل قوة في الطاعة وأهل بصائر القلوب، فقال: «وقوله: <span class="qpc-hafs">﴿أولي الأيدي والأبصار﴾</span> ويعني بالأيدي: القوة، يقول: أهل القوة على عبادة الله وطاعته، ويعني بالأبصار: أنهم أهل إبصار القلوب، يعني به: أولي العقول للحق. وقد اختلف أهلُ التأويل في تأويل ذلك، <span class="mustanad">فقال بعضُهم في ذلك نحوًا مما قلنا فيه</span>». ثم ذكر آثار السلف على هذا.</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٣٥٥): «وقوله تعالى: <span class="qpc-hafs">﴿والأَبْصارِ﴾</span> عبارة عن البصائر، أي: يبصرون الحقائق وينظرون بنور الله تعالى، وبنحو هذا <span class="mustanad">فسَّر الجميعُ</span>».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١١٤، وابن أبي حاتم -كما في التغليق ٤/٢٩٦، والإتقان ٢/٤٠-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وقرأ بقية العشرة: <span class="qpc-hafs">﴿عِبادَنا﴾</span> على الجمع. انظر: النشر ٢/٣٦١، والإتحاف ص٤٧٧.عزاه السيوطي إلى عبد بن حميد.ذكره ابن جرير ٢٠/١١٦.</p><p>وهي قراءة شاذة، تروى أيضا عن الحسن والأعمش، والثقفي بخلاف عنهم، وقراءة العشرة: <span class="qpc-hafs">﴿أُولِي الأَيْدِي﴾</span>. انظر: المحتسب ٢/٢٣٣، ومختصر ابن خالويه ص١٣١.أخرجه إسحاق البستي ص٢٥٢.أخرجه ابن جرير ٢٠/١١٤. وعزا السيوطي شطره الثاني إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٥-١١٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٥.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص٢٥٢.أخرج اللفظ الأول عبد الرزاق ٢/١٦٨ من طريق معمر، وأخرج اللفظ الثاني ابن جرير ٢٠/١١٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٥.أخرجه ابن جرير ٢٠/١١٥.أخرجه أبو جعفر الرملي في جزئه ص١١٠ (تفسير عطاء الخراساني). وهو في تفسير مقاتل بن سليمان ٣/٦٤٩ من طريق ابن جابر بلفظ: القوة في العبادة والبصر بالدين.تفسير مقاتل بن سليمان ٣/٦٤٨-٦٤٩.
  38,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّاۤ أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ ذِكۡرَى ٱلدَّارِ ۝٤٦ وَإِنَّهُمۡ عِندَنَا لَمِنَ ٱلۡمُصۡطَفَیۡنَ ٱلۡأَخۡیَارِ ۝٤٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٠٨<span class="dash">-</span></span> عن <span class="name-2">الأعرج</span> -من طريق هارون- قال: (مُخالِصِينَ ذِكْرى الدّارِ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّاۤ أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ ذِكۡرَى ٱلدَّارِ ۝٤٦ وَإِنَّهُمۡ عِندَنَا لَمِنَ ٱلۡمُصۡطَفَیۡنَ ٱلۡأَخۡیَارِ ۝٤٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: أخلصوا بذكر دار الآخرة أن يعملوا لها{2}. (١٢/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: أخلصوا بذلك وبذكرهم دار يوم القيامة{3}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- <span class="qpc-hafs">﴿ذِكْرى الدّارِ﴾</span>، قال: عقبى الدار{4}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: بذكر الآخرة، وليس لهم هَمٌّ ولا ذِكْرٌ غيرها{5}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿بِخالِصَةٍ ذِكْرى الدّارِ﴾</span> هم أهل الدار، وذو الدار، كقولك: ذو الكلاع، وذو يزن{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: بخوف الآخرة{3}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: بفضل أهل الجنة{8}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: بهذه أخلصهم الله، كانوا يدعون إلى الآخرة وإلى الله{9}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق فضيل بن عياض، عن رجل- في قوله: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ﴾</span>، قال: بِهَمِّ الآخرة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: يدعون إلى الآخرة، وإلى طاعة الله{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩١٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، قال: بذكرهم الدار الآخرة، وعملهم للآخرة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢٠<span class="dash">-</span></span> قال <span class="name-2">مالك بن دينار</span>: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span> نزعنا مِن قلوبهم حُبَّ الدنيا وذِكْرَها، وأخلصناهم بحب الآخرة وذكرِها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابن جابر- قال في قوله: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ بِخالِصَةٍ ذِكْرى الدّارِ﴾</span>، يقول: وجعلناهم أذكر الناس لدار الآخرة، يعني: الجنة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</span>، قال: أخلصوا بذلك، وتفكَّروا{15} بدار يوم القيامة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر الله تعالى هؤلاء الثلاثة: إبراهيم، وابنيه؛ إسحاق، ويعقوب بن إسحاق، فقال: <span class="qpc-hafs">﴿إنّا أخْلَصْناهُمْ﴾</span> للنبوة والرسالة <span class="qpc-hafs">﴿بِخالِصَةٍ ذِكْرى الدّارِ وإنَّهُمْ عِنْدَنا لَمِنَ المُصْطَفَيْنَ الأَخْيارِ﴾</span> اختارهم الله على عِلْمٍ للرسالة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢٤<span class="dash">-</span></span> عن العلاء العطار، قال: سمعت <span class="name-3">فضيل [بن عياض]</span> يقول في قوله: <span class="qpc-hafs">﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</span>، قال: أخلصوا بهمِّ الآخرة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: ‹إنَّآ أخْلَصْناهُمْ بِخالِصَةِ ذِكْرى الدّارِ›، قال: بأفضل ما في الآخرة، أخلصناهم به، وأعطيناهم إياه. قال: والدار: الجنة. وقرأ: <span class="qpc-hafs">﴿تِلْكَ الدّارُ الآخِرَةُ نَجْعَلُها لِلَّذِينَ لا يُرِيدُونَ عُلُوًّا فِي الأَرْضِ﴾</span> [القصص:٨٣]، قال: الجنة. وقرأ: <span class="qpc-hafs">﴿ولَنِعْمَ دارُ المُتَّقِينَ﴾</span> [النحل:٣٠]، قال: هذا كله الجنة. وقال: أخلصناهم بخير الآخرة{12}<span class=comment-ref>٥٥٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٢</span> اختلف السلف في قوله: <span class="qpc-hafs">﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</span> على أقوال: <b>الأول</b>: أنهم كانوا يُذَكِّرون الناسَ بالدار الآخرة، ويدعونهم إلى طاعة الله. <b>الثاني</b>: أنه أخلصهم بعملهم للآخرة، وذكرهم لها. <b>الثالث</b>: إنا أخلصناهم بأفضل ما في الآخرة. <b>الرابع</b>: خالصة عقبى الدار. <b>الخامس</b>: بخالصة أهل الدار. <b>السادس</b>: أخلصناهم بالنبوة وذكر الدار الآخرة.</p><p>وقد <span class="comment-type-3">رجح</span> <u>ابنُ جرير</u> (٢٠/١١٩) أن المعنى على قراءة <span class="qpc-hafs">﴿بخالصة﴾</span> بالتنوين: «إنا أخلصناهم بخالصة هي ذكرى الدار الآخرة، فعملوا لها في الدنيا، فأطاعوا الله وراقبوه». ولم يذكر مستندًا، ثم <span class="comment-type-4">بيّن</span> احتمال الآية للقول الأول على هذه القراءة، فقال: «وقد يدخل في وصفهم بذلك أن يكون من صفتهم أيضًا الدعاء إلى الله وإلى الدار الآخرة؛ لأن ذلك من طاعة الله والعمل للدار الآخرة، غير أن معنى الكلمة ما ذكرت». ثم <span class="comment-type-4">وضَّح</span> أن المعنى على قراءة الإضافة: «إنا أخلصناهم بخالصة ما ذكر في الدار الآخرة؛ فلما لم تذكر في أضيفت الذكرى إلى الدار <span class="mustanad">كما قد بينا قبل في معنى قوله</span>: <span class="qpc-hafs">﴿لا يسأم الإنسان من دعاء الخير﴾</span> [فصلت:٤٩]، <span class="mustanad">وقوله</span>: <span class="qpc-hafs">﴿بِسُؤالِ نَعْجَتِكَ إلى نِعاجِهِ﴾</span> [ص:٢٤]».</p><p>وزاد <u>ابنُ عطية</u> (٧/٣٥٦) في معنى الآية <b>قولًا</b>، فقال: «ويحتمل أن يريد بـ<span class="qpc-hafs">﴿الدار﴾</span> دار الدنيا على معنى: ذكر الثناء والتعظيم من الناس، والحمد الباقي الذي هو الخلد المجازي، فتجيء الآية في معنى قوله: <span class="qpc-hafs">﴿لسان صدق﴾</span> [الشعراء:٨٤]، وفي معنى قوله: <span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span> [الصافات:٧٨، ١٠٨، ١٢٩]».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّاۤ أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ ذِكۡرَى ٱلدَّارِ ۝٤٦ وَإِنَّهُمۡ عِندَنَا لَمِنَ ٱلۡمُصۡطَفَیۡنَ ٱلۡأَخۡیَارِ ۝٤٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٢٦<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير</span> -من طريق ابنه عبد الله- قال: قال موسى ﷺ: يا ربِّ، بما أثنيت على إبراهيم وإسحاق ويعقوب بأيِّ شيء أعطيتَهم ذلك؟ قال: إنّ إبراهيم لم يعدل فِيَّ شيئًا إلا اختارني عليه، وإنّ إسحاق جاد لي بنفسه فهو بغيرها أجود، وأمّا يعقوب فلم أبتله ببلاء إلا زاد فِيَّ حُسن ظن{20}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٢٥٢.</p><p>وهي قراءة شاذة.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٨ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١١٩.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب الهم والحزن -موسوعة الإمام ابن أبي الدنيا ٣/٢٦٩ (٣٩)-.أخرجه عبد الرزاق ٢/١٦٨.أخرجه ابن جرير ٢٠/١١٨.تفسير البغوي ٧/٩٧.تفسير مقاتل بن سليمان ٣/٦٤٩.في المصدر: وتكفروا.أخرجه أبو جعفر الرملي في جزئه ص١١٠ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٦٤٩.أخرجه أبو نعيم في حلية الأولياء ٨/١٠٤.أخرجه ابن جرير ٢٠/١١٨.أخرجه سفيان الثوري في تفسيره (٢٦٠).
  38,47,""
  38,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱذۡكُرۡ إِسۡمَـٰعِیلَ وَٱلۡیَسَعَ وَذَا ٱلۡكِفۡلِۖ وَكُلࣱّ مِّنَ ٱلۡأَخۡیَارِ ۝٤٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٢٧<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿واليَسَعَ﴾</span> مخففة{1}. (١٢/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٢٨<span class="dash">-</span></span> عن <span class="name-2">سليمان الأعمش</span> أنه قرأ: ‹اللّيْسَعَ› مشددة{2}. (١٢/٦١٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱذۡكُرۡ إِسۡمَـٰعِیلَ وَٱلۡیَسَعَ وَذَا ٱلۡكِفۡلِۖ وَكُلࣱّ مِّنَ ٱلۡأَخۡیَارِ ۝٤٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٢٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿واذْكُرْ إسْماعِيلَ واليَسَعَ وذا الكِفْلِ﴾</span>، إنّ ذا الكفل كان رجلًا صالحًا، وليس بنبي، تكفَّل لنبيٍّ بأن يكفل له أمر قومه، ويقضي بينهم بالعدل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واذْكُرْ﴾</span> صبر <span class="qpc-hafs">﴿إسْماعِيلَ﴾</span> هو أشويل بن هلقانا، <span class="qpc-hafs">﴿و﴾</span>صبر <span class="qpc-hafs">﴿اليَسَعَ و﴾</span>صبر <span class="qpc-hafs">﴿ذا الكِفْلِ وكُلٌّ مِنَ الأَخْيارِ﴾</span> اختارهم الله ﷿ للنبوة، فاصبر -يا محمد- على الأذى كما صبر هؤلاء الستة على البلاء{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة ما عدا حمزة، والكسائي، وخلفًا؛ فإنهم قرؤوا: ‹واللّيْسَعَ› بتشديد اللام مفتوحة، بعدها ياء ساكنة. انظر: النشر ٢/٢٦٠، والإتحاف ص٤٧٨.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٦-.تفسير مقاتل بن سليمان ٣/٦٤٩-٦٥٠.
  38,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا ذِكۡرࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٣١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿هَذا ذِكْرٌ﴾</span>، قال: القرآن{1}<span class=comment-ref>٥٥٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٣</span> لم يذكر <u>ابن جرير</u> (٢٠/١٢٠) غير قول السدي.</p><p><span class="comment-type-4">وقال</span> <u>ابنُ عطية</u> (٧/٣٥٧): «<span class="qpc-hafs">﴿هذا ذِكْرٌ﴾</span> يحتمل معنيين: <b>أحدهما</b>: أن يشير إلى مدح من ذكر وإبقاء الشرف له، فيتأيد بهذا التأويل قول مَن قال آنفًا: إن الدّارِ يراد بها: الدار الدنيا. <b>والثاني</b>: أن يشير بهذا إلى القرآن، إذ هو ذكر للعالم».</div></p><p><div></p><p><p><span class="item-no">٦٦٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا ذِكْرٌ﴾</span>، يعني: هذا بيان الذي ذكر الله مِن أمر الأنبياء في هذه السورة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّ لِلۡمُتَّقِینَ لَحُسۡنَ مَـَٔابࣲ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٣٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإنَّ لِلْمُتَّقِينَ لَحُسْنَ مَآبٍ﴾</span>، قال: لحُسنَ مُنقلَبٍ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّ لِلْمُتَّقِينَ﴾</span> مِن هذه الأمة في الآخرة <span class="qpc-hafs">﴿لَحُسْنَ مَآبٍ﴾</span> يعني: مَرجِع{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٢٠.تفسير مقاتل بن سليمان ٣/٦٥٠.أخرجه ابن جرير ٢٠/١٢١.تفسير مقاتل بن سليمان ٣/٦٥٠.
  38,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿جَنَّـٰتِ عَدۡنࣲ مُّفَتَّحَةࣰ لَّهُمُ ٱلۡأَبۡوَ ٰ⁠بُ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٣٥<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿جَنّاتِ عَدْنٍ﴾</span>، قال: سأل عمرُ <span class="name-2">كعبًا</span>: ما عَدْن؟ قال: يا أمير المؤمنين، قصور في الجنة من ذهب، يسكنها النبيُّون والصديقون والشهداء وأئمة العدل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ابن دعلج- في قوله: <span class="qpc-hafs">﴿جَنّاتِ عَدْنٍ مُفَتَّحَةً لَهُمُ الأَبْوابُ﴾</span>، قال: يرى ظاهرها من باطنها، وباطنها من ظاهرها، يُقال لها: انفتحي، انغلقي، تكلمي. فتفهم، وتتكلَّم{2}. (١٢/٦١١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٢١.تفسير مقاتل بن سليمان ٣/٦٥٠، وأخرجه ابن جرير ٢٠/١٢٢، ٥٧٧. وعزاه السيوطي إلى ابن المنذر.
  38,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ فِیهَا یَدۡعُونَ فِیهَا بِفَـٰكِهَةࣲ كَثِیرَةࣲ وَشَرَابࣲ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ فِيها﴾</span> في الجنة على السُّرر، <span class="qpc-hafs">﴿يَدْعُونَ فِيها بِفاكِهَةٍ كَثِيرَةٍ وشَرابٍ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥٠.
  38,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعِندَهُمۡ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٣٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ أتْرابٌ﴾</span>، قال: قاصرات الطرف على أزواجهن، لا يبغين غيرهم{1}. (١٢/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span>، قال: قَصَرْنَ طرفهنَّ على أزواجهنَّ، فلا يُرِدْن غيرَهم{2}. (١٢/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قاصِراتُ الطَّرْفِ﴾</span>، قال: قصرن أبصارهن وقلوبهن وأسماعهن على أزواجهن، فلا يُرِدْن غيرهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span> النظر عن الرجال؛ لا ينظرن إلى غير أزواجهن؛ لأنهنَّ عاشقات لأزواجهن{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَتۡرَابٌ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أتْرابٌ﴾</span>، قال: مستويات{5}. (١٢/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- قال: <span class="qpc-hafs">﴿أتْرابٌ﴾</span>، الأتراب: المستويات{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أتْرابٌ﴾</span>، قال: أمثال{7}. (١٢/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ أتْرابٌ﴾</span>: والأتراب: المستويات{1}. (١٢/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أتْرابٌ﴾</span>، قال: سِنّ واحدة{9}. (١٢/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أتْرابٌ﴾</span>، قال: مستويات. قال: وقال بعضهم: مُتواخِيات؛ لا يتباغضن، ولا يتعادين، ولا يتغايرن، ولا يتحاسدن{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أتْرابٌ﴾</span>، يعني: مستويات على ميلادٍ واحد؛ بنات ثلاثة وثلاثين سنة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٢٣.تفسير مقاتل بن سليمان ٣/٦٥٠.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤١-، والبيهقي في البعث (٣٧٧).أخرجه سفيان الثوري ١/٢٦٠.تفسير مجاهد (٥٧٦)، وأخرجه ابن جرير ٢٠/١٢٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٢٤. وقوله: «وقال بعضهم» يظهر أنه من قول السدي لذكر «قال» قبله. ويحتمل أن يكون من كلام ابن جرير.تفسير مقاتل بن سليمان ٣/٦٥٠.
  38,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا مَا تُوعَدُونَ لِیَوۡمِ ٱلۡحِسَابِ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿هَذا ما تُوعَدُونَ لِيَوْمِ الحِسابِ﴾</span>، قال: هو في الدنيا ليوم القيامة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿هَذا﴾</span> الذي ذُكِر في هذه الآية، ذكر يعني: بيان من الخير في الجنة <span class="qpc-hafs">﴿ما تُوعَدُونَ لِيَوْمِ الحِسابِ﴾</span> يعني: ليوم الجزاء{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٢٤.تفسير مقاتل بن سليمان ٣/٦٥٠.
  38,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ هَـٰذَا لَرِزۡقُنَا مَا لَهُۥ مِن نَّفَادٍ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ هَذا لَرِزْقُنا ما لَهُ مِن نَفادٍ﴾</span>: أي: مِن انقطاع{1}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٥٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إنَّ هَذا لَرِزْقُنا ما لَهُ مِن نَفادٍ﴾</span>، قال: رزق الجنة، كلمّا أُخِذ منه شيءٌ عاد مثله مكانه، ورزق الدنيا له نفاد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن هَذا﴾</span> الخير في الجنة <span class="qpc-hafs">﴿لَرِزْقُنا ما لَهُ مِن نَفادٍ﴾</span> يقول: هذا الرزق للمتقين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٢٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٥.تفسير مقاتل بن سليمان ٣/٦٥٠.
  38,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَاۚ وَإِنَّ لِلطَّـٰغِینَ لَشَرَّ مَـَٔابࣲ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٥٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإنَّ لِلطّاغِينَ لَشَرَّ مَآبٍ﴾</span>، قال: لَشَرّ مُنقلَب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر الكفار، فقال سبحانه: <span class="qpc-hafs">﴿هَذا وإنَّ لِلطّاغِينَ لَشَرَّ مَآبٍ﴾</span>، يعني: بئس المرجع{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٢٦.تفسير مقاتل بن سليمان ٣/٦٥٠-٦٥١.
  38,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿جَهَنَّمَ یَصۡلَوۡنَهَا فَبِئۡسَ ٱلۡمِهَادُ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر بالمرجع، فقال: <span class="qpc-hafs">﴿جَهَنَّمَ يَصْلَوْنَها فَبِئْسَ المِهادُ﴾</span> ما مهدوا لأنفسهم مِن العذاب{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥١.
  38,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا فَلۡیَذُوقُوهُ حَمِیمࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ وغَسّاقٌ﴾</span>، قال: الحميم: الذي قد انتهى حرُّه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ﴾</span>، يعني: الحارّ الذي انتهى حرُّه وطبخه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٥٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ﴾</span>: الحميم: دموع أعينهم، يجتمع في حياض النار، فيُسقَوْنَه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَغَسَّاقࣱ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٦٠<span class="dash">-</span></span> عن أبي سعيد، قال: قال رسول الله ﷺ: «<b>لو أنّ دَلْوًا مِن غسّاق يُهراق في الدنيا لأنتن أهل الدنيا</b>»{4}. (١٢/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مرة الهمداني- في قوله: <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span>، قال: الزَّمْهَرِير{5}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق أبي هبيرة الزيادي- أنه سمعه يقول: <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span> أيُّ شيء الغساق؟ قالوا: الله أعلم. فقال <span class="name-1">عبد الله بن عمرو</span>: هو القَيح الغليظ، لو أنّ قطرة منه تُهراق في المغرب لأنتنت أهل المشرق، ولو تهراق في المشرق لأنتنت أهل المغرب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿غَسّاقٌ﴾</span> هو الزمهرير، يحرقهم ببرده، كما تحرقهم النارُ بِحَرِّها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٤<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عطية الكلاعي- قال: <span class="qpc-hafs">﴿غَسّاقٌ﴾</span> عينٌ في جهنم، يسيل إليها حُمَة{8} كلِّ ذات حُمَة؛ مِن حيَّة أو عقرب أو غيرها، فيستنقع، فيؤتى بالآدمي، فيغمس فيها غمسة واحدة، فيخرج وقد سقط جلدُه ولحمُه عن العظام حتى يتعلَّق جلدُه في كعبيه وعقبيه، وينجرُّ لحمه كَجَرِّ الرجل ثوبه{9}. (١٢/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٥<span class="dash">-</span></span> عن <span class="name-2">أبي رَزين [مسعود بن مالك الأسدي]</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span>، الغساق: ما يسيل مِن صديدهم{10}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿غَسّاقٌ﴾</span>، الغسّاق: ما يسيل من سُرْمهم{11}، وما ينقطع من جلودهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٧<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن بريدة</span> -من طريق حيان- قال: <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span>، الغساق: المنتن، وهو بالطخارية{13}. (١٢/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: الغسّاق: الذي لا يستطيعون أن يذوقوه مِن شِدَّة بَرْدِه{14}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿وغَسّاق﴾</span>، قال: ما يقطع مِن جلودهم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ وغَسّاقٌ﴾</span>، قال: يُقال الغساق: أبرد البرد. ويقول آخرون: لا، بل هو أنتن النتن{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧١<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق إدريس- في قوله: <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span>، قال: الذي يسيل من جلودهم{17}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>: <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span> هو عُصارة أهل النار{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ وغَسّاقٌ﴾</span>، قال: كنا نحدَّث: أنّ الغساق: ما يسيل من بين جلده ولحمه{19}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span>: الغساق: الذي يسيل من أعينهم من دموعهم، يسقونه مع الحميم{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا فَلْيَذُوقُوهُ حَمِيمٌ﴾</span> يعني: الحارّ الذي انتهى حرُّه وطبخه، <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span> البارد الذي قد انتهى برده، نظيرها في «عَمَّ يتساءلون»: <span class="qpc-hafs">﴿إلّا حَمِيمًا وغَسّاقًا﴾</span> [النبأ:٢٥]، فينطلق من الحار إلى البارد فتقطع جلودهم، وتتصدع عظامهم، وتحرق كما يحرق حرُّ النارِ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وغَسّاقٌ﴾</span>: الغساق: الصديد يخرج من جلودهم مما تصهره النار في حياض يجتمع فيها فيُسقونه{3}<span class=comment-ref>٥٥٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٤</span> اختلف السلف في الغساق على أقوال: <b>الأول</b>: أنه ما يسيل من جلودهم من الصديد والدم. <b>الثاني</b>: أنه البارد الذي لا يستطاع من برده. <b>الثالث</b>: أنه المنتن.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٠/١٣٠) <span class="mustanad">مستندًا إلى الأغلب لغةً</span> القول الأول، فقال: «وأولى الأقوال في ذلك عندي بالصواب: قولُ مَن قال: هو ما يسيل من صديدهم. لأن ذلك هو الأغلب من معنى الغسوق، وإن كان للآخر وجه صحيح».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/١٢٧.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٢٧-١٢٨.أخرجه أحمد ١٧/٣٣١ (٢/١١٢٣٠)، ١٨/٣١٠ (١١٧٨٦)، والترمذي ٤/٥٤٠-٥٤١ (٢٧٦٦)، والحاكم ٤/٦٤٤ (٨٧٧٩)، وابن جرير ٢٠/١٣٠، ٢٤/٣١-٣٢.</p><p>قال الترمذي: «هذا حديث إنما نعرفه من حديث رشدين بن سعد، وفي رشدين مقال، وقد تُكلّم فيه من قبل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه ابن جرير ٢٠/١٣٢، وابن أبي حاتم -كما في الإتقان ٢/٤١-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/١١٥ (٢٦٣)، وابن جرير ٢٠/١٢٩، وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٩٧-.تفسير الثعلبي ٨/٢١٣، وتفسير البغوي ٧/٩٩.الحُمَة -بِالتَّخْفيف-: السَّمُّ. النهاية (حمه).أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٩ (٩١)-، وابن جرير ٢٠/١٢٩.أخرجه ابن المبارك في الزهد ١/٤٩٦، وابن أبي شيبة ١٣/٤١٩، وهناد (٢٩١). وعزاه السيوطي إلى عبد بن حميد.سُرمهم: مخرج الثُّفل. مختار الصحاح (سرم).أخرجه ابن جرير ٢٠/١٢٨، وأخرجه ابن المبارك في الزهد ١/٤٩٦ بلفظ: ما يسيل من صديدهم.أخرجه ابن جرير ٢٠/١٣٠. والطخارية: لغة أهل طخارستان. التاج (طخر).أخرجه هناد بن السري في الزهد (٢٩٠)، وابن جرير ٢٤/١٣٠ بنحوه من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٩ (٩٠)-.أخرجه ابن جرير ٢٠/١٣٠.أخرجه هناد (٢٨٩).تفسير الثعلبي ٨/٢١٣.أخرجه عبد الرزاق ٢/١٦٨ من طريق معمر، وابن جرير ٢٠/١٢٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/١٢٨.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٢٧-١٢٨.
  38,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَءَاخَرُ مِن شَكۡلِهِۦۤ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> أنه قرأ: ‹وأُخَرُ مِن شَكْلِهِ أزْواجٌ› برفع الألف ونصب الخاء{1}<span class=comment-ref>٥٥٨٥</span>. (١٢/٦١٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٥</span> ذكر <u>ابنُ جرير</u> (٢٠/١٣٠-١٣١) هذه القراءة، ثم <span class="comment-type-4">علَّق</span> عليها، فقال: «وقرأ ذلك بعضُ المكيين وبعض البصريين: ‹وأُخَرُ› على الجماع، وكأنّ مَن قرأ ذلك كذلك كان عنده لا يصلح أن يكون الأزواج -وهي جمع- نعتًا لواحد، فلذلك جمع أُخَر لتكون الأزواج نعتًا لها؛ والعرب لا تمنع أن ينعت الاسم إذا كان فعلًا بالكثير والقليل والاثنين كما بينا، فتقول: عذاب فلان أنواع، ونوعان مختلفان».</p><p>وذكر <u>ابنُ جرير</u> قراءة من قرأ ذلك بالتوحيد، و<span class="comment-type-4">علَّق</span> عليها، فقال: «عامة قراء المدينة والكوفة: <span class="qpc-hafs">﴿وآخر من شكله أزواج﴾</span> على التوحيد، بمعنى: هذا حميم وغساق فليذوقوه، وعذاب آخر من نحو الحميم ألوان وأنواع، كما يقال: لك عذاب من فلان ضروب وأنواع، وقد يحتمل أن يكون مرادًا بالأزواج: الخبر عن الحميم والغساق، وآخر من شكله، وذلك ثلاثة، فقيل: أزواج، يراد أن ينعت بالأزواج تلك الأشياء الثلاثة».</p><p>ثم <span class="comment-type-3">رجَّحها</span> <span class="mustanad">مستندًا إلى الأصحّ لغة وأقوال أهل التأويل</span> بقوله: «وأعجب القراءتين إلَيَّ أن أقرأ بها: <span class="qpc-hafs">﴿وآخر﴾</span> على التوحيد، وإن كانت الأخرى صحيحة لاستفاضة القراءة بها في قراء الأمصار، وإنما اخترنا التوحيد لأنه أصح مخرجًا في العربية، وأنه في التفسير بمعنى التوحيد. وقيل: إنه الزمهرير».</div></p><p><div></p><p><p><span class="item-no">٦٦٩٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن [البصري]</span> -من طريق عمرو [بن عبيد]-: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاخَرُ مِن شَكۡلِهِۦۤ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مرة الهمداني- في قوله: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>، قال: الزَّمْهَرِير{3}. (١٢/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٠<span class="dash">-</span></span> عن مرة، قال: ذكروا الزمهرير، فقال <span class="name-1">عبد الله [بن مسعود]</span>: ذلك قول الله: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>. فقالوا لعبد الله: إنّ للزَّمْهَرِير بردًا. قال: فقرأ هذه الآية: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا* إلّا حَمِيمًا وغَسّاقًا﴾</span> [النبأ:٢٤]{4}. (١٢/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>، قال: مِن نحوه{5}<span class=comment-ref>٥٥٨٦</span>. (١٢/٦١٢)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٦</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٧/٣٥٨) على ما جاء في هذا القول، فقال: «<span class="qpc-hafs">﴿مِن شَكْلِهِ﴾</span> في موضع الصفة. <b>ومعنى</b> <span class="qpc-hafs">﴿مِن شَكْلِهِ﴾</span>: من مثله وضربه. وجاز على هذا القول أن يخبر الجمع الذي هو أزواج عن الواحد من حيث ذلك الواحد درجات ورُتَب من العذاب، وقوي وأقل منه. وأيضًا فمن جهة أخرى على أن يسمى كل جزء من ذلك الآخر باسم الكل، قالوا: عرفات لعرفة، وشابت مفارقه، فجعلوا كل جزء من المفرق مفرقًا، وكما قالوا: جمل ذو عثانين ونحو هذا، ألا ترى أن جماعة من المفسرين قالوا: إنّ هذا الآخر هو الزمهرير، فكأنهم جعلوا كل جزء منه زمهريرًا».</div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك بن فضالة- قال: ذكر الله العذابَ، فذكر السلاسلَ والأغلالَ وما يكون في الدنيا، ثم قال: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>، قال: وآخر لم يُرَ في الدنيا{6}. (١٢/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>: من نحوه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>، يقول: وآخر من شكله، يعني: من نحو الحميم والغساق{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>، قال: مِن كل شكل ذلك العذاب الذي سمى الله أزواجٌ لم يُسَمِّها الله. قال: والشكل: الشبيه{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جٌ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿أزْواجٌ﴾</span>، قال: ألوان مِن العذاب{5}. (١٢/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿وآخَرُ مِن شَكْلِهِ أزْواجٌ﴾</span>، قال: ألوان من العذاب{11}. (١٢/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أزْواجٌ﴾</span>، قال: زوجٌ زوجٌ من العذاب{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أزْواجٌ﴾</span>: أصناف، يعني: ألوان من العذاب في الحميم، يشبه بعضه بعضًا في شبه العذاب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أزْواجٌ﴾</span>، قال: أزواج من العذاب في النار{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وأخرجه إسحاق البستي ص٢٥٣ من طريق هارون.</p><p>وهي قراءة متواترة، قرا بها أبو عمرو، ويعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿وآخَرُ﴾</span> بفتح الهمزة وألف بعدها. انظر: النشر ٢/٣٦١، والإتحاف ص٤٧٨.أخرجه إسحاق البستي ص٢٥٣.أخرجه سفيان الثوري ص٢٦٠-٢٦١، وعبد الرزاق ٢/١٦٦-١٦٧، وابن جرير ٢٠/١٣٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٣٢، وابن أبي حاتم -كما في الإتقان ٢/٤١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٢.أخرجه ابن جرير ٢٠/١٣٢.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٣٣.أخرجه ابن جرير ٢٠/١٣٢، وابن أبي حاتم -كما في الإتقان ٢/٤١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٣، وابن أبي شيبة ١٣/١٦٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/١٣٣.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٣٣.
  38,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا فَوۡجࣱ مُّقۡتَحِمࣱ مَّعَكُمۡ لَا مَرۡحَبَۢا بِهِمۡۚ إِنَّهُمۡ صَالُوا۟ ٱلنَّارِ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ﴾</span>: هو أنّ القادة إذا دخلوا النار، ثم دخل بعدهم الأتباعُ؛ قالت الخزنةُ للقادة: <span class="qpc-hafs">﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ لا مَرْحَبًا بِهِمْ إنَّهُمْ صالُو النّارِ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فَبِئْسَ القَرارُ﴾</span>، قال: هؤلاء الأتباع يقولونه للرؤوس{2}. (١٢/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا فَوْجٌ﴾</span> يعني: زُمْرَة <span class="qpc-hafs">﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ﴾</span> وذلك أنّ القادة فى الكفر، المُطعمين في غزاة بدر، والمستهزئين مِن رؤساء قريش؛ دخلوا النار قبل الأتباع، فقالت الخزنة للقادة وهم في النار: <span class="qpc-hafs">﴿مُقْتَحِمٌ مَعَكُمْ﴾</span> النار. إضمار، يعنون: الأتباع. قالت القادة: لا مرحبًا بهم. قال الخزنة: <span class="qpc-hafs">﴿إنَّهُمْ صالُو النّارِ﴾</span> معكم{3}<span class=comment-ref>٥٥٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٣٥٩): «والأظهر أن قائل ذلك لهم: ملائكة العذاب، وهو الذي حكاه الثعلبي وغيره، و<b>يحتمل</b> أن يكون ذلك من قول بعضهم لبعض».</div></p><p><div></p><p><p><span class="item-no">٦٦٩٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هَذا فَوْجٌ مُقْتَحِمٌ مَعَكُمْ لا مَرْحَبًا بِهِمْ﴾</span>، قال: الفوج: القوم الذين يدخلون فوجًا بعد فوج. وقرأ: <span class="qpc-hafs">﴿كُلَّما دَخَلَتْ أُمَّةٌ لَعَنَتْ أُخْتَها﴾</span> [الأعراف:٣٨] التي كانت قبلها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٦٩٩٥<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿هذا فوج مقتحم معكم﴾</span>، قال: داخل معكم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/٩٩.أخرجه ابن جرير ٢٠/١٣٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٥١.أخرجه ابن جرير ٢٠/١٣٤.أخرجه إسحاق البستي ص٢٥٢.
  38,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَلۡ أَنتُمۡ لَا مَرۡحَبَۢا بِكُمۡۖ أَنتُمۡ قَدَّمۡتُمُوهُ لَنَاۖ فَبِئۡسَ ٱلۡقَرَارُ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فردَّت الأتباعُ مِن كُفّار مكة على القادة <span class="qpc-hafs">﴿قالُوا بَلْ أنْتُمْ لا مَرْحَبًا بِكُمْ أنْتُمْ قَدَّمْتُمُوهُ لَنا﴾</span> زينتموه لنا هذا الكفر، <span class="qpc-hafs">﴿إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ ونَجْعَلَ لَهُ أنْدادًا﴾</span> [سبأ:٣٣]، <span class="qpc-hafs">﴿فَبِئْسَ القَرارُ﴾</span> يعني: فبئس المستقر{1}<span class=comment-ref>٥٥٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٥٨٨</span> ذكر <u>ابنُ القيم</u> (٢/٣٨٣-٣٨٤) في عود الضمير من قوله: <span class="qpc-hafs">﴿قدمتموه﴾</span> قولين، و<span class="comment-type-4">علّق</span> عليهما، فقال: «وفي الضمير قولان: <b>أحدهما</b>: أنّه ضمير الكفر والتكذيب ورد قول الرسول ﷺ واستبدال غيره به، والمعنى: أنتم زينتم لنا الكفر ودعوتمونا إليه وحسنتموه لنا، وقيل على هذا القول: أنه قول الأمم المتأخرين للمتقدمين، والمعنى على هذا: أنتم شرعتم لنا تكذيب الرسل ورد ما جاءوا به والشرك بالله ﷾، وبدأتم به وتقدمتمونا إليه فدخلتم النار قبلنا فبئس القرار، أي: بئس المستقر والمنزل. <b>والقول الثاني</b>: أن الضمير في قوله: <span class="qpc-hafs">﴿أنتم قدمتموه لنا﴾</span> ضمير العذاب وصُلِيّ النار، والقولان متلازمان، وهما حقٌّ».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥١.
  38,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ رَبَّنَا مَن قَدَّمَ لَنَا هَـٰذَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالت الأتباع: <span class="qpc-hafs">﴿قالُوا رَبَّنا مَن قَدَّمَ لَنا هَذا﴾</span> يعني: مَن زيَّن لنا هذا، يعني: مَن سبَّب لنا هذا الكفر <span class="qpc-hafs">﴿فَزِدْهُ عَذابًا ضِعْفًا فِي النّارِ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَزِدۡهُ عَذَابࣰا ضِعۡفࣰا فِی ٱلنَّارِ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٦٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مرة- في قوله: <span class="qpc-hafs">﴿فَزِدْهُ عَذابًا ضِعْفًا فِي النّارِ﴾</span>، قال: أفاعي، وحيّات{2}. (١٢/٦١٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٥١-٦٥٢.أخرجه الطبراني في المعجم الكبير ٩/٢٢٦ (٩١٠٢). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.