quran[8]{c,v,t}:
  48,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل لِّلۡمُخَلَّفِینَ مِنَ ٱلۡأَعۡرَابِ سَتُدۡعَوۡنَ إِلَىٰ قَوۡمٍ أُو۟لِی بَأۡسࣲ شَدِیدࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٠٣<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق الزُّهريّ- <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: لم يأتِ أولئك بعد{1}. (١٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٠٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق ابن أبي خالد، عن أبيه- في قوله: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: هم البارِز. يعني: الأكراد{2}. (١٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء بن أبي رباح- في قوله <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: فارس{3}. (١٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: فارس، والروم{4}. (١٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: هَوازن، وبني حنيفة{5}. (١٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ستدعون إلى قوم أولى بأس شديد﴾</span>، قال: هَوازن، وثقيف{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٠٩<span class="dash">-</span></span> قال <span class="name-1">رافع بن خَدِيج</span>: كُنّا نقرأ هذه الآية، ولا نعلم مَن هم، حتى دعا أبو بكر إلى قتال بني حنيفة، فعلمنا أنهم هم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٠<span class="dash">-</span></span> عن <span class="name-2">كعب [الأحبار]</span> -من طريق الفرج بن محمد الكلاعي- قال: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: الروم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١١<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق ثابت البُناني- في قوله: <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: فارس، والروم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٣<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: هَوازن يوم حنين{10}. (١٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى وورقاء، عن ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: هم فارس{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: هم فارس، والروم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: أعراب فارس، وأكْراد العَجم{13}. (١٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: أهل الأوثان{14}. (١٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طرق- قال: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>: هم فارس، والروم{15}. (١٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢١٩<span class="dash">-</span></span> عن <span class="name-2">عطاء ابن أبي رباح</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿أولي بأس شديد﴾</span>، قال: هم فارس{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>: هم هَوازن، وغَطَفان يوم حُنين{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: فدُعوا يوم حُنين إلى هَوازن وثقيف، فمنهم مَن أحسن الإجابة ورغب في الجهاد{18}. (١٣/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق ابن إسحاق- قال: <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span> هم بنو حَنيفة مع مُسَيلمة الكذّاب{19}. (١٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿أُولِي بَأْسٍ شَدِيدٍ﴾</span>، أنه قال: هم بنو حَنيفة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ﴾</span> عن الحُدَيبية مخافة القتل <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span> يعني: أهل اليمامة، يعني: بني حَنيفة: مُسَيلمة بن حبيب الكذّاب الحنفي وقومه، دعاهم أبو بكر ﵁ إلى قتال أهل اليمامة، يعني: هؤلاء الأحياء الخمسة؛ جُهينة، ومُزينة، وأشْجَع، وغِفار، وأسْلَم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: ... إلى قتال فارس{22}. (١٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span>، قال: فارس، والروم{23}<span class=comment-ref>٦٠٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٥٧</span> اختُلف في قوله تعالى: <span class="qpc-hafs">﴿قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span> مَن هؤلاء القوم على أقوال: <b>الأول:</b> هَوازن بحنين. <b>الثاني:</b> الروم. <b>الثالث:</b> أهل الرّدة وبنو حنيفة باليمامة. <b>الرابع:</b> فارس والروم. <b>الخامس:</b> هم أهل فارس. <b>السادس:</b> لم تأت هذه الآية بعد.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢١/٢٦٩) <span class="mustanad">مستندًا إلى دلالة الإطلاق في ظاهر الآية</span> «أن يُقال: إنّ الله -تعالى ذِكْره- أخبر عن هؤلاء المخلَّفين من الأعراب أنهم سيُدعَون إلى قتال قومٍ أولي بأسٍ في القتال، ونجدةٍ في الحروب، ولم يوضَع لنا الدليل من خبرٍ ولا عقلٍ على أن المعنيَّ بذلك هوازن، ولا بنو حنيفة، ولا فارس، ولا الروم، ولا أعيانٌ بأعيانهم، وجائزٌ أن يكون عُنِيَ بذلك بعض هذه الأجناس، وجائزٌ أن يكون عُنِيَ بهم غيرهم، ولا قول فيه أصح مِن أن يُقال كما قال الله -جلَّ ثناؤه-: إنهم سيُدعَون إلى قومٍ أولي بأسٍ شديد».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٦٧٦) على القول الأول بقوله: «ويندرج في هذا القول عندي مَن حورب وغلب في فتح مكة». ثم <span class="comment-type-3">رجَّح</span> القول الأول والثاني <span class="mustanad">مستندًا إلى دلالة الواقع</span>، و<span class="comment-type-2">انتقد</span> باقي الأقوال قائلًا: «والقولان الأوَّلان حسنان؛ لأنهما الذي كشف الغيب، وباقيهما ضعيف».</p><p>ثم نقل <u>ابنُ عطية</u> تعليق منذر بن سعيد على القول الثالث بقوله: «وقال منذر بن سعيد: يتركَّب على هذا القول أن الآية مُؤذنة بخلافة أبي بكر الصِّديق وعمر بن الخطاب». و<span class="comment-type-1">وجَّهه</span> بقوله: «يريد: لما كشف الغيب أنهما دَعَوا إلى قتال أهل الردة». ونقل عن منذر بن سعيد أيضًا قوله: «رفع الله في هذه الجزية، وليس إلا القتال أو الإسلام، وهذا لا يوجد إلا في أهل الردة». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وكذا مَن حورب في فتح مكة».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٦/٢١-٢٢) القول الرابع <span class="mustanad">مستندًا إلى دلالة الواقع</span>، فذكر: أن أظهر الأقوال في الآية هو أن المراد «تُدعون إلى قتال أولي بأس شديد أعظم من العرب، لا بُدَّ فيهم مِن أحد أمرين: إما أن يُسلموا، وإما أن يُقاتَلوا؛ بخلاف مَن دُعوا إليه عام الحُدَيبية، فإنّ بأسهم لم يكن شديدًا مثل هؤلاء ودُعوا إليهم، ففي ذلك لم يُسلموا ولم يقاتلوا. وكذلك عام الفتح في أول الأمر لم يُسلموا ولم يقاتلوا، لكن بعد ذلك أسلموا. وهؤلاء هم الروم والفرس ونحوهم، فإنه لابد من قتالهم إذا لم يُسلموا، وأول الدعوة إلى قتال هؤلاء عام مؤتة وتبوك».</p><p>و<span class="comment-type-2">انتقد</span> (٦/١٩) القول الأول بأنه لا «يجوز أن يكون دعاهم إلى قتال أهل مكة وهَوازن عقيب عام الفتح؛ لأن هؤلاء هم الذين دعوا إليهم عام الحُدَيبية، ومن لم يكن منهم فهو من جنسهم ليس هو أشدَّ بأسًا منهم، كلّهم عرب من أهل الحجاز، وقتالهم من جنس واحد، وأهل مكة ومَن حولها كانوا أشد بأسًا وقتالًا للنبي ﷺ وأصحابه يوم بدر وأحد والخندق مِن أولئك، وكذلك في غير ذلك من السرايا».</div></p><p><h3><span class="qpc-hafs">﴿تُقَـٰتِلُونَهُمۡ أَوۡ یُسۡلِمُونَۖ فَإِن تُطِیعُوا۟ یُؤۡتِكُمُ ٱللَّهُ أَجۡرًا حَسَنࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</span> يعني: أهل اليمامة، يعني: بني حنيفة: مُسَيلمة بن حبيب الكذّاب الحنفي وقومه، دعاهم أبو بكر ﵁ إلى قتال أهل اليمامة، يعني: هؤلاء الأحياء الخمسة؛ جُهينة، ومُزينة، وأشْجَع، وغِفار، وأسْلَم <span class="qpc-hafs">﴿تُقاتِلُونَهُمْ أوْ يُسْلِمُونَ فَإنْ تُطِيعُوا﴾</span> أبا بكر إذا دعاكم إلى قتالهم <span class="qpc-hafs">﴿يُؤْتِكُمُ اللَّهُ أجْرًا حَسَنًا﴾</span> في الآخرة، يعني: جزاء كريمًا في الجنّة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ سَتُدْعَوْنَ إلى قَوْمٍ﴾</span> قال: عمر بن الخطاب دعا أعراب المدينة؛ جُهينة ومُزينة الذين كان النَّبِيّ ﷺ دعاهم إلى خروجه إلى مكة، دعاهم عمر بن الخطاب إلى قتال فارس <span class="qpc-hafs">﴿فَإنْ تُطِيعُوا﴾</span> إذا دعاكم عمر تكن توبة لتخلُّفكم عن النبيِّ ﷺ <span class="qpc-hafs">﴿يؤتكم الله أجرًا حسنًا﴾</span>{22}. (١٣/٤٧٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن تَتَوَلَّوۡا۟ كَمَا تَوَلَّیۡتُم مِّن قَبۡلُ یُعَذِّبۡكُمۡ عَذَابًا أَلِیمࣰا ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٢٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وإنْ تَتَوَلَّوْا كَما تَوَلَّيْتُمْ مِن قَبْلُ﴾</span> يوم الحُدَيبية{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ تَتَوَلَّوْا﴾</span> يعني: تُعرِضوا عن قتال أهل اليمامة <span class="qpc-hafs">﴿كَما تَوَلَّيْتُمْ﴾</span> يعني: كما أعرضتم <span class="qpc-hafs">﴿مِن قَبْلُ﴾</span> عن قتال الكفار يوم الحُدَيبية؛ <span class="qpc-hafs">﴿يُعَذِّبْكُمْ﴾</span> الله في الآخرة <span class="qpc-hafs">﴿عَذابًا ألِيمًا﴾</span> يعني: وجيعًا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وإنْ تَتَوَلَّوْا﴾</span> إذا دعاكم عمر <span class="qpc-hafs">﴿كَما تَوَلَّيْتُمْ مِن قَبْلُ﴾</span> إذ دعاكم النبيُّ ﷺ <span class="qpc-hafs">﴿يُعَذِّبْكُمْ عَذابًا ألِيمًا﴾</span>{22}. (١٣/٤٧٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن تَتَوَلَّوۡا۟ كَمَا تَوَلَّیۡتُم مِّن قَبۡلُ یُعَذِّبۡكُمۡ عَذَابًا أَلِیمࣰا ۝١٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧١٢٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: خلافة أبي بكر ﵁ في هذه الآية مؤكّدة{29}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ٢١/٢٦٨.|2:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٢١-، وأخرج أوله إسحاق البستي ص٣٦٩.|3:أخرجه ابن جرير ٢١/٢٦٦، والبيهقي ٤/١٦٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:عزاه السيوطي إلى ابن مردويه.|5:عزاه السيوطي إلى الفريابي، وابن مردويه.|6:أخرجه ابن عساكر في تاريخ دمشق ٥/٤٧٣.|7:تفسير البغوي ٧/٣٠٣.|8:أخرجه ابن جرير ٢١/٢٦٨.|9:أخرجه ابن جرير ٢١/٢٦٦.|10:أخرجه ابن جرير ٢١/٢٦٧ وفيه: هوازن وثقيف، وفي رواية أخرى ١٢/٢٦٨: هوازن وبني حنيفة، والبيهقي ٤/١٦٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|11:أخرجه ابن جرير ٢١/٢٦٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٢-.|12:تفسير مجاهد ص٦٠٨.|13:عزاه السيوطي إلى ابن المنذر، والطبراني في الكبير.|14:عزاه السيوطي إلى عبد بن حميد.|15:أخرجه عبد الرزاق ٢/٢٢٦ من طريق معمر، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٠٨- من طريق المبارك بن فضالة، وابن جرير ٢١/٢٦٦-٢٦٧ من طريق قتادة، والبيهقي ٤/١٦٥. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|16:أخرجه إسحاق البستي ص٣٧٠.|17:أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ٢١/٢٦٧.|18:أخرجه ابن جرير ٢١/٢٦٧-٢٦٨. وعزاه السيوطي إلى عبد بن حميد.|19:أخرجه ابن جرير ٢١/٢٦٨. وعزاه السيوطي إلى ابن المنذر، والطبراني.|20:أخرجه عبد الرزاق ٢/٢٢٦.|21:تفسير مقاتل بن سليمان ٤/٧٢-٧٣.|22:عزاه السيوطي إلى ابن المنذر.|23:أخرجه ابن جرير ٢١/٢٦٧.|24:تفسير مقاتل بن سليمان ٤/٧٣.|25:عزاه السيوطي إلى ابن المنذر.|26:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٢-.|27:تفسير مقاتل بن سليمان ٤/٧٣.|28:عزاه السيوطي إلى ابن المنذر.|29:أخرجه الهذيل بن حبيب -كما في تفسير مقاتل بن سليمان ٤/٧٣-.
  48,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّیۡسَ عَلَى ٱلۡأَعۡمَىٰ حَرَجࣱ وَلَا عَلَى ٱلۡأَعۡرَجِ حَرَجࣱ وَلَا عَلَى ٱلۡمَرِیضِ حَرَجࣱۗ وَمَن یُطِعِ ٱللَّهَ وَرَسُولَهُۥ یُدۡخِلۡهُ جَنَّـٰتࣲ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ وَمَن یَتَوَلَّ یُعَذِّبۡهُ عَذَابًا أَلِیمࣰا ۝١٧﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧١٢٣٣<span class="dash">-</span></span> عن زيد بن ثابت، قال: كنت أكتب لرسول الله ﷺ، وإنِّي لَواضِعٌ القَلمَ على أذني إذ أُمِر بالقتال، إذ جاء أعمى فقال: كيف بي وأنا ذاهبُ البصر؟ فنزلت: <span class="qpc-hafs">﴿لَيْسَ عَلى الأَعْمى حَرَجٌ﴾</span> الآية. قال: «<b>هذا في الجهاد، ليس عليهم مِن جهاد إذا لم يُطِيقوا</b>»{1}. (١٣/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿لَيْسَ عَلى الأَعْمى حَرَجٌ﴾</span> الآية: يعني: في القتال{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: ثم عذَر الله أهلَ العُذر مِن الناس، فقال: <span class="qpc-hafs">﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</span>{3}. (١٣/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</span>، قال: هذا كلّه في الجهاد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل بن أبي خالد</span> -من طريق سفيان بن عيينة- قال: <span class="qpc-hafs">﴿ليس على الأعمى حرج﴾</span>، قال: هو المُقْعَد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عذر أهل الزَّمانَةِ، فقال: <span class="qpc-hafs">﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</span> في تخلُّفهم عن الحُدَيبية. يقول: مَن تخلَّف عن الحُدَيبية مِن هؤلاء المعذورين فمَن شاء منهم أن يسير معكم فليَسِر، <span class="qpc-hafs">﴿ومَن يُطِعِ اللَّهَ ورَسُولَهُ في الغزو يُدْخِلْهُ جَنّاتٍ تَجْرِي مِن تَحْتِها الأَنْهارُ ومَن يَتَوَلَّ﴾</span> يعني: يُعرِض عن طاعتهما في التخلّف مِن غير عُذر <span class="qpc-hafs">﴿يُعَذِّبْهُ عَذابًا ألِيمًا﴾</span> يعني: وجيعًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</span>، قال: في الجهاد في سبيل الله{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ٥/١٥٥ (٤٩٢٦).</p><p>قال الهيثمي في المجمع ٧/١٠٧ (١١٣٤٥): «وفيه محمد بن جابر السحيمي، وهو ضعيف يُكتب حديثه، وبقية رجاله رجال الصحيح». وقال السيوطي: «بسند حسن».|2:أخرجه ابن جرير ٢١/٢٧١.|3:عزاه السيوطي إلى ابن جرير، وعبد بن حميد.|4:أخرجه ابن جرير ٢١/٢٧٠.|5:أخرجه إسحاق البستي ص٣٧٠.|6:تفسير مقاتل بن سليمان ٤/٧٣.|7:أخرجه ابن جرير ٢١/٢٧١.
  48,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّقَدۡ رَضِیَ ٱللَّهُ عَنِ ٱلۡمُؤۡمِنِینَ إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧١٢٤٠<span class="dash">-</span></span> عن <span class="name-1">سَلَمة بن الأكْوع</span>، قال: بينا نحن قائِلون إذ نادى مُنادي رسول الله ﷺ: أيها الناس، البيعةَ البيعةَ، نزل روح القُدس. فثُرْنا إلى رسول الله ﷺ وهو تحت شجرة سَمُرَة، فبايعناه، فذلك قول الله تعالى: <span class="qpc-hafs">﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ﴾</span>، فبايع لعثمان؛ إحدى يديه على الأخرى، فقال الناس: هنيئًا لابن عفان، يطوف بالبيت ونحن ههنا. فقال رسول الله ﷺ: «<b>لو مكث كذا وكذا سنةً ما طاف حتى أطوف</b>»{1}. (١٣/٤٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّقَدۡ رَضِیَ ٱللَّهُ عَنِ ٱلۡمُؤۡمِنِینَ إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</span> - قصة بيعة الرضوان، وسببها</h3></p><p><div></p><p><p><span class="item-no">٧١٢٤١<span class="dash">-</span></span> عن أنس بن مالك، قال: لَمّا أمَر رسولُ الله ﷺ ببيعة الرضوان كان عثمانُ بن عفان رسولَ رسولِ الله ﷺ إلى أهل مكة، فبايع الناس، فقال رسول الله ﷺ: «<b>اللهم، إنّ عثمان في حاجة الله وحاجة رسوله</b>». فضرب بإحدى يديه على الأخرى، فكانت يد رسول الله ﷺ لعثمان خيرًا مِن أيديهم لأنفسهم{2}. (١٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٢<span class="dash">-</span></span> عن عروة بن الزبير، قال: لَمّا نزل النبيُّ ﷺ الحُدَيبية فَزِعت قريش لنزوله عليهم، فأحبّ رسولُ الله ﷺ أن يبعث إليهم رجلًا مِن أصحابه، فدعا عمرَ بن الخطاب ليبعثه إليهم، فقال: يا رسول الله، إني لا آمَن، وليس بمكة أحد مِن بني كعب يغضب لي إنْ أُوذيت، فأرسِل عثمان بن عفان، فإنّ عشيرته بها، وإنه مبلّغٌ لك ما أردت. فدعا رسولُ الله ﷺ عثمانَ، فأرسله إلى قريش، وقال: «<b>أخبِرهم أنّا لم نأتِ لقتال، وإنّما جِئنا عُمّارًا، وادعهم إلى الإسلام</b>». وأمَره أن يأتي رجالًا بمكة مؤمنين ونساء مؤمنات، فيدخل عليهم، ويبشّرهم بالفتح، ويخبرهم أنّ الله وشيكٌ أن يُظهِر دينه بمكة حتى لا يُستخفى فيها بالإيمان. فانطلَق عثمان إلى قريش، فأخبَرهم، فارتهنه المشركون، ودعا رسولُ الله ﷺ إلى البيعة، ونادى منادي رسول الله ﷺ: ألا إنّ روح القدس قد نزل على رسول الله ﷺ، فأمره بالبيعة، فاخرجوا على اسم الله، فبايِعوه. فثار المسلمون إلى رسول الله ﷺ وهو تحت الشجرة، فبايَعوه على ألّا يَفِرّوا أبدًا، فرَعَبهم الله، فأرسَلوا مَن كانوا ارتهَنوا مِن المسلمين، ودَعَوا إلى المُوادعة والصُّلح{3}. (١٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٣<span class="dash">-</span></span> عن عكرمة مولى ابن عباس –من طريق ابن إسحاق، عن رجل-، نحوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٤<span class="dash">-</span></span> عن محمد بن إسحاق، قال: فحدثني عبد الله بن أبي بكر: أنّ رسول الله ﷺ حين بلغه أن عثمان قد قُتِل، قال: «<b>لا نبرح حتى نناجز القوم</b>». ودعا الناس إلى البيعة، فكانت بيعة الرضوان تحت الشجرة، فكان الناس يقولون: بايعهم رسول الله ﷺ على الموت. فكان جابر بن عبد الله يقول: إنّ رسول الله ﷺ لم يبايعنا على الموت، ولكنه بايعنا على أن لا نَفِرّ. فبايع رسولُ الله ﷺ الناسَ، ولم يتخلف عنه أحدٌ مِن المسلمين حضرها إلا الجدُّ بنُ قيس أخو بني سلمة، كان جابر بن عبد الله يقول: لَكأنِّي أنظر إليه لاصقًا بإبط ناقته، قد اختبأ إليها، يستتر بها مِن الناس. ثم أتى رسولَ الله ﷺ أنّ الذي ذُكِر مِن أمر عثمان باطلٌ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٥<span class="dash">-</span></span> عن محمد بن إسحاق، عن بعض أهل العلم، قال: إنّ رسول الله ﷺ دعا خِراش بن أُميّة الخزاعي، فبعثه إلى قريش بمكة، وحمله على جمل له يُقال له: الثعلب، ليُبَلّغ أشرافهم عنه ما جاء له، وذلك حين نزل الحُدَيبية، فعقروا به جمل رسول الله ﷺ، وأرادوا قتْله، فمنعته الأحابيش، فخلَّوا سبيله، حتى أتى رسولَ الله ﷺ{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّقَدۡ رَضِیَ ٱللَّهُ عَنِ ٱلۡمُؤۡمِنِینَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٤٦<span class="dash">-</span></span> عن سعيد بن المسيّب، عن <span class="name-1">أبيه</span>، قال: كُنّا مع النبيِّ ﷺ تحت الشجرة ألفًا وأربعمائة{7}. (١٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ﴾</span>، قال: كان أهل البيعة تحت الشجرة ألفًا وخمسمائة وخمسًا وعشرين{8}. (١٣/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٨<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span>، قال: كُنّا يوم الحُدَيبية ألفًا وأربعمائة، فقال لنا رسول الله ﷺ: «<b>أنتم خيرُ أهل الأرض</b>»{9}. (١٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٤٩<span class="dash">-</span></span> عن قتادة، قال: قلت ل<span class="name-2">سعيد بن المسيّب</span>: كم كان الذين شهِدوا بيعة الرضوان؟ قال: خمس عشرة مائة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٠<span class="dash">-</span></span> قلت: فإنّ <span class="name-1">جابر بن عبد الله</span> قال: كانوا أربع عشرة مائة. قال: يرحمه الله، وهِم، هو حدّثني أنّهم كانوا خمس عشرة مائة{10}. (١٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن أبي أوْفى</span>، قال: كان أصحابُ الشجرة ألفًا وثلاثمائة{11}<span class=comment-ref>٦٠٥٨</span>. (١٣/٤٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٥٨</span> نقل <u>ابن كثير</u> (١٣/٩٢) في عدد الصحابة الذين بايعوا رسول الله ﷺ في بيعة الرضوان ثلاثة أقوال: <b>الأول:</b> ألف وثلاثمائة. <b>الثاني:</b> وأربعمائة. <b>الثالث:</b> وخمسمائة. ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأوسط أصحّ». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٥٢<span class="dash">-</span></span> عن <span class="name-1">مَعْقِل بن يَسار</span>، قال: لقد رأيتُني يومَ الشجرة والنبيُّ ﷺ يبايع الناس، وأنا رافع غصنًا مِن أغصانها عن رأسه، ونحن أربع عشرة مائة، ولم نبايعه على الموت، ولكن بايعناه على ألا نَفرّ{12}. (١٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٣<span class="dash">-</span></span> عن <span class="name-1">سَلَمة بن الأكْوع</span>، قال: بايعتُ رسول الله ﷺ تحت الشجرة. قيل: على أيِّ شيء كنتم تَبايَعون يومئذ؟ قال: على الموت{13}. (١٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٤<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span> -من طريق محمد بن المنكدر- قال: كُنّا يوم الحُدَيبية ألفًا وأربعمائة، فبايعناه وعمرُ آخِذٌ بيده تحت الشجرة، وهي سَمُرَة. وقال: بايعناه على ألا نَفِرَّ، ولم نبايعه على الموت{14}. (١٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ فَعَلِمَ ما فِي قُلُوبِهِمْ فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</span>، قال: ... وهم الذين بايعوا زمان الحُدَيبية، وكانت الشجرة -فيما ذُكِر لنا- سَمُرة، بايع النبيُّ ﷺ أصحابَه تحتها، وكانوا يومئذ خمس عشرة مائة، فبايعوه على ألّا يَفِرُّوا، ولم يبايعوه على الموت{15}. (١٣/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٦<span class="dash">-</span></span> عن <span class="name-2">بُكَير بن الأشجّ</span>، أنّه بلغه: أنّ الناس بايعوا رسول الله ﷺ على الموت، فقال رسول الله ﷺ: «<b>على ما استطعتم</b>». والشجرة التي بُويِع تحتها بفجٍّ نحو مكة. وزعموا: أنّ عمر بن الخطاب ﵁ مرّ بذلك المكان بعد أن ذهبت الشجرة، فقال: أين كانت؟ فجعل بعضهم يقول: هنا. وبعضهم يقول: ههنا. فلما كثر اختلافهم قال: سيروا، هذا التكلّف. فذهبت الشجرة، وكانت سَمُرَة؛ إما ذهب بها سيل، وإما شيء سوى ذلك{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ﴾</span> بالحُدَيبية، يقول: رضي ببيعتهم إياك{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق ابن ثور- في قوله تعالى: <span class="qpc-hafs">﴿يبايعونك تحت الشجرة﴾</span>، قال: سَمُرة كانت بالحُدَيبية، فكانت هذه الشجرة يُعرَف موضعها، ويؤتى هذا المسجد، حتى كان عمر بن الخطاب ﵁، فبلغه أنّ الناس يأتونها ويُصلّون عندها فيما هُنالِك ويُعَظِّمونها، فرأى أنّ ذلك مِن فعلهم حَدَثٌ{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٥٩<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- قال:.... هي بيعة الرضوان. ثم قرأ: <span class="qpc-hafs">﴿لقد رضي الله عن المؤمنين إذ يبايعونك تحت الشجرة﴾</span> الآية{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧١٢٦٠<span class="dash">-</span></span> عن أُمّ مُبَشِّر، عن النبيّ ﷺ، قال: «<b>لا يدخل النارَ أحدٌ مِمَّن بايع تحت الشجرة</b>»{20}. (١٣/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٦١<span class="dash">-</span></span> عن أبي أُمامة الباهلي، قال: لَمّا نزلت: <span class="qpc-hafs">﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ﴾</span> قلتُ: يا رسول الله، أنا مِمَّن بايعك تحت الشجرة. قال: «<b>يا أبا أُمامة، أنت مِنِّي، وأنا منك</b>»{21}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٦٢<span class="dash">-</span></span> عن عامر الشعبي، قال: لَمّا دعا النبيُّ ﷺ الناسَ إلى البيعة، كان أول مَن انتهى إليه أبو سنان الأسدي، فقال: ابسطْ يدَك أبايعْك. فقال النبيُّ ﷺ: «<b>علامَ تبايعني؟</b>». قال: على ما في نفسك{22}. (١٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٦٣<span class="dash">-</span></span> عن نافع، قال: بلغ <span class="name-1">عمرَ بن الخطاب</span> أنّ ناسًا يأتون الشجرة التي بُويع تحتها، فأمر بها، فقُطِعَت{23}. (١٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٦٤<span class="dash">-</span></span> عن طارق بن عبد الرحمن، قال: انطلقتُ حاجًّا، فمررتُ بقومٍ يُصَلُّون، فقلت: ما هذا المسجد؟ قالوا: هذه الشجرة، حيث بايع رسولُ الله ﷺ بيعة الرضوان. فأتيتُ سعيد بن المسيّب، فأخبرته، فقال سعيد: حدّثني أبي: أنه كان فيمن بايع رسول الله ﷺ تحت الشجرة، فلما خرجنا من العام المقبل نسيناها، فلم نقدر عليها. فقال <span class="name-2">سعيد</span>: إنّ أصحاب محمد ﷺ لم يعلموها وعلمتموها أنتم، فأنتم أعلم؟!{24}. (١٣/٤٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَعَلِمَ مَا فِی قُلُوبِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَعَلِمَ ما فِي قُلُوبِهِمْ﴾</span> مِن الكراهية للبيعة على أن يُقاتلوا ولا يَفرّوا في أمر البيعة{17}<span class=comment-ref>٦٠٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٥٩</span> أفاد أثر مقاتل أن معنى: <span class="qpc-hafs">﴿فَعَلِمَ ما فِي قُلُوبِهِمْ﴾</span>: من كراهية البيعة على القتال وعدم الفرار. و<span class="comment-type-2">انتقده</span> <u>ابنُ عطية</u> (٧/٦٧٩) فقال: «وهذا ضعيف؛ فيه مذمَّة للصحابة ﵃».</p><p>وزاد <u>ابنُ عطية</u> قولين آخرين: <b>الأول:</b> «معناه: مِن الإيمان، وصحَّته، والحبِّ في الدين، والحرص عليه». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا قول حسن، لكنه مَن كانت هذه حاله فلا يحتاج إلى نزول ما يسكنه». غير أنّه ذكر له <span class="comment-type-1">وجْهًا</span> يمكن أن يُحمَل عليه، فقال: «أما إنه يحتمل أن يجازى بالسَّكِينة والفتح القريب والمغانم». <b>الثاني:</b> «معناه: مِن الهمِّ بالانصراف عن المشركين، والأنفة في ذلك على نحو ما خاطب فيه عمر ﵄ وغيره». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا تأويل حسن، يترتب معه نزول السَّكينة والتعويض بالفتح القريب».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٢/٤٥٨) أن <b>المعنى</b>: «علم الله ﷿ ما في قلوبهم من القلق والاضطراب لَمّا منعهم كفارُ قريش من دخول بيت الله، وحبسوا الهَدي عن محلِّه، واشترطوا عليهم تلك الشروط الجائرة الظالمة، فاضطربت قلوبهم، وقلقت، ولم تُطق الصبر، فعلم تعالى ما فيها، فثبّتها بالسكينة رحمة منه ورأفة ولطفًا، وهو اللطيف الخبير». ثم ذكر أن الآية <b>تحتمل</b> «أنه سبحانه علم ما في قلوبهم من الإيمان والخير ومحبته ومحبة رسوله، فثبّتها بالسكينة وقت قلقها واضطرابها». ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى العموم</span>- قائلًا: «والظاهر أن الآية تعُمُّ الأمرين، وهو أنه علم ما في قلوبهم مما يحتاجون معه إلى إنزال السكينة وما في قلوبهم مِن الخير الذي هو سبب إنزالها».</div></p><p><h3><span class="qpc-hafs">﴿فَأَنزَلَ ٱلسَّكِینَةَ عَلَیۡهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَعَلِمَ ما فِي قُلُوبِهِمْ فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</span>، قال: إنما أُنزِلَت السَّكينة على مَن عُلِم منه الوفاء{26}. (١٣/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٦٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</span>، السَّكينة: الوقار{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</span>، قال: الوقار، والصبر{28}. (١٣/٤٨٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَثَـٰبَهُمۡ فَتۡحࣰا قَرِیبࣰا ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: ... ثم ذكر البيعة، فقال: <span class="qpc-hafs">﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</span> لفتح الحُدَيبية{29}. (١٣/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٠<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق الحكم- في قوله: <span class="qpc-hafs">﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</span>، قال: خَيْبَر{30}. (١٣/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧١<span class="dash">-</span></span> قال معمر، في قوله: <span class="qpc-hafs">﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</span>: إنّ <span class="name-2">مِقْسَمًا</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٢<span class="dash">-</span></span> أو <span class="name-2">قتادة</span>، أو كلاهما قالا: هو خَيْبَر{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</span>، قال: خَيْبَر، حيث رجعوا من صُلح الحُدَيبية{32}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، <span class="qpc-hafs">﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</span>، قال: فتْح خَيْبَر{33}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأثابهم فتحا قريبا﴾</span>: وهي خيبر{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَثابَهُمْ﴾</span> يعني: وأعطاهم <span class="qpc-hafs">﴿فَتْحًا قَرِيبًا﴾</span> يعني: مغانم خَيْبَر{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة في مصنفه ٦/٣٦٢ (٣٢٠٤٦)، ٧/٣٨٦ (٣٦٨٥٢)، والطبراني في الكبير ١/٩٠ (١٤٤)، وابن جرير ٢١/٢٧٣-٢٧٤ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٤٠-.</p><p>قال الهيثمي في المجمع ٩/٨٤ (١٤٥١٧): «رواه الطبراني، وفيه موسى بن عبيدة، وهو ضعيف».|2:أخرجه الترمذي ٦/٢٧٦ (٤٠٣٥).</p><p>قال الترمذي: «هذا حديث حسن صحيح غريب».|3:أخرجه البيهقي ٤/١٣٢.|4:أخرجه ابن جرير ٢١/٢٧٢.|5:أخرجه ابن جرير ٢١/٢٧٣.|6:أخرجه ابن جرير ٢١/٢٧٢.|7:أخرجه البيهقي ٤/٩٨.|8:أخرجه ابن جرير ٢١/٢٧٧. وعزاه السيوطي إلى ابن مردويه.|9:أخرجه البخاري ٥/١٢٣ (٤١٥٤)، ومسلم ٣/١٤٨٤ (١٨٥٦).|10:أخرجه البخاري ٥/١٢٣ (٤١٥٣). وعزاه السيوطي إلى ابن مردويه.|11:أخرجه مسلم (١٨٥٧)، وابن جرير ٢١/٢٧٧، وإسحاق البستي ص٣٧١، وابن مردويه -كما في فتح الباري ٧/٤٤٤-. وعلقه البخاري (٤١٥٥).|12:أخرجه مسلم (١٨٥٨). وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.|13:أخرجه البخاري (٤١٦٩).|14:أخرجه ابن جرير ٢١/٢٧٥-٢٧٦، ومسلم (١٨٥٦). وعزاه السيوطي إلى ابن مردويه.|15:عزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٢١٣ مختصرًا من طريق معمر، وكذا ابن جرير ٢١/٢٧٧ من طريق سعيد.|16:أخرجه ابن جرير ٢١/٢٧٥. وينظر: تفسير الثعلبي ٩/٤٧، وتفسير البغوي ٦/٣٠٤.|17:تفسير مقاتل بن سليمان ٤/٧٣.|18:أخرجه الفاكهي في أخبار مكة ٥/٧٧ (٢٨٧٥).|19:أخرجه الفاكهي في أخبار مكة ٥/٧٦ (٢٨٧١)، وإسحاق البستي ص٣٧١.|20:أخرجه مسلم ٤/١٩٤٢ (٢٤٦٩)، وابن جرير ١٥/٦٠١ بنحوه.|21:أخرجه ابن عساكر في تاريخه ٢٤/٦١، من طريق خيثمة بن سليمان، نا علي بن الحسن بن معروف السلمي بحمص، نا وهب بن صدقة، عن يوسف بن حزن الباهلي، قال: سمعت أبا أمامة به.</p><p>وهب بن صدقة، ويوسف بن حزن الباهلي، لم أجد من ترجم لهما، فضلًا عن توثيقهما.|22:أخرجه إسحاق البستي ص٣٧١، والبيهقي ٤/١٣٧.|23:أخرجه ابن أبي شيبة ٢/٣٧٥.|24:أخرجه البخاري (٤١٦٣). وعزاه السيوطي إلى ابن مردويه.|25:تفسير مقاتل بن سليمان ٤/٧٣.|26:عزاه السيوطي إلى ابن أبي حاتم.|27:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٤-.|28:أخرجه ابن جرير ٢١/٢٧٨. وعزاه السيوطي إلى عبد بن حميد.|29:عزاه السيوطي إلى ابن مردويه. وتقدم بتمامه في إجمال تفسير السورة.|30:أخرجه ابن جرير ٢١/٢٧٨، والبيهقي ٤/١٦٣. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|31:أخرجه عبد الرزاق ٢/٢٢٦.|32:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|33:عزاه السيوطي إلى عبد بن حميد.|34:أخرجه ابن جرير ٢١/٢٧٨.|35:تفسير مقاتل بن سليمان ٤/٧٣.
  48,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَغَانِمَ كَثِیرَةࣰ یَأۡخُذُونَهَاۗ وَكَانَ ٱللَّهُ عَزِیزًا حَكِیمࣰا ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَثابَهُمْ فَتْحًا قَرِيبًا ومَغانِمَ كَثِيرَةً﴾</span>، قال: هي مغانم خَيْبَر، وكانت عقارًا ومالًا، فقَسمها نبيُّ الله صلي الله عليه وسلم بين أصحابه{1}. (١٣/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَغانِمَ كَثِيرَةً يَأْخُذُونَها وكانَ اللَّهُ عَزِيزًا﴾</span> يعني: منيعًا، <span class="qpc-hafs">﴿حَكِيمًا﴾</span> في أمْره، فحكم على أهل خَيْبَر القتْل والسبي{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ٢١/٢٧٧-٢٧٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|2:تفسير مقاتل بن سليمان ٤/٧٣.
  48,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَدَكُمُ ٱللَّهُ مَغَانِمَ كَثِیرَةࣰ تَأۡخُذُونَهَا فَعَجَّلَ لَكُمۡ هَـٰذِهِۦ وَكَفَّ أَیۡدِیَ ٱلنَّاسِ عَنكُمۡ وَلِتَكُونَ ءَایَةࣰ لِّلۡمُؤۡمِنِینَ وَیَهۡدِیَكُمۡ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝٢٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧١٢٧٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق معمر- قال: لَمّا انصرف رسولُ الله ﷺ حتى أتى المدينة فغزا خيبر مِن الحُدَيبية؛ فأنزل الله عليه: <span class="qpc-hafs">﴿وعدكم الله مغانم كثيرة تأخذونها فعجل لكم هذه﴾</span> إلى <span class="qpc-hafs">﴿ويهديكم صراطا مستقيما﴾</span>. فلما فتحت خيبر جعلها لِمَن غزا معه الحُدَيبية وبايع تحت الشجرة مِمَّن كان غائبًا وشاهدًا، مِن أجل أنّ الله كان وعدهم إيّاها، وخمَّس رسول الله ﷺ خيبر، ثم قسم سائرها مغانم بين مَن شهدها من المسلمين، ومَن غاب عنها مِن أهل الحُدَيبية{1}. (١٣/٤٨٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَدَكُمُ ٱللَّهُ مَغَانِمَ كَثِیرَةࣰ تَأۡخُذُونَهَا فَعَجَّلَ لَكُمۡ هَـٰذِهِۦ وَكَفَّ أَیۡدِیَ ٱلنَّاسِ عَنكُمۡ وَلِتَكُونَ ءَایَةࣰ لِّلۡمُؤۡمِنِینَ وَیَهۡدِیَكُمۡ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝٢٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧١٢٨٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عطية، عن أصحاب علي-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨١<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قالا في قوله تعالى: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً﴾</span>: فتوحٌ من لَدُنْ خَيْبَر <span class="qpc-hafs">﴿تَأْخُذُونَها﴾</span> تَلُونها، وتَغْنمون ما فيها{2}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</span>، قال: المغانم الكثيرة التي وُعِدوا: ما يأخذون حتى اليوم{3}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</span>، قال: يوم خَيْبَر= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٤<span class="dash">-</span></span> كان أبي [<span class="name-2">زيد بن أسلم</span>] يقول ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</span> مع النبي ﷺ، ومِن بعده إلى يوم القيامة{5}<span class=comment-ref>٦٠٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٦٠</span> اختُلف في معنى: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</span> أيُّ المغانم هي؟ على قولين: <b>الأول:</b> هو كلّ مَغْنَم غَنِمه المسلمون. <b>الثاني:</b> هي مغانم خَيْبَر.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٢١/٢٨٠) على القول الأول بقوله: «وعلى هذا التأويل <b>يَحْتَمِل</b> الكلام أن يكون مرادًا بالمغانم الثانية: المغانمُ الأولى، ويكون معناه عند ذلك: فأثابهم فتحًا قريبًا ومغانمَ كثيرةً يأخذونها، وعدكم الله -أيُّها القوم- هذه المغانم التي تأخذونها، وأنتم إليها واصلون عِدَةً، فجعل لكم الفتح القريب من فتح خَيْبَر. و<b>يَحْتَمِل</b> أن تكون الثانية غير الأولى، وتكون الأولى من غنائم خَيْبَر، والغنائم الثانية التي وعَدَهموها من غنائم سائر أهل الشرك سواهم».</p><p>و<span class="comment-type-3">رجَّح</span> (٢١/٢٨١) -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- أنها سائر المغانم التي غنموها بعد خَيْبَر، وعلَّل ذلك بقوله: «لأن الله أخبر أنه عجَّل لهم هذه التي أثابهم من مسيرهم الذي ساروه مع رسول الله ﷺ إلى مكة، ولِما عُلِم مِن صحة نيَّتهم في قتال أهلها؛ إذ بايعوا رسول الله ﷺ على أن لا يفرُّوا عنه، ولا شكّ أن التي عُجِّلَت لهم غير التي لم تُعَجَّل لهم».</div></p><p><h3><span class="qpc-hafs">﴿فَعَجَّلَ لَكُمۡ هَـٰذِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٨٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عطية، عن أصحاب علي-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٧<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قالا في قوله تعالى: <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ﴾</span>: من ذلك خَيْبَر{2}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</span>، يعني: الفتح{7}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</span>: يعني: الصلح{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</span>، يعني: خَيْبَر{9}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩١<span class="dash">-</span></span> عن <span class="name-2">مروان</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٢<span class="dash">-</span></span> و<span class="name-1">المِسْوَر بن مَخْرَمَة</span>، قالا: انصرف رسول الله ﷺ عام الحُدَيبية، فنزلت عليه سورة الفتح فيما بين مكة والمدينة، فأعطاه الله فيها خَيْبَر، <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</span> خَيْبَر، فقدم النبِيُّ ﷺ المدينةَ في ذي الحجة، فأقام بها حتى سار إلى خَيْبَر في المُحرّم، فنزل رسول الله ﷺ بالرّجيع -وادٍ بين غَطَفان وخَيْبَر-، فتخوّف أن تمدهم غَطَفان، فبات به حتى أصبح فغدا عليهم{10}. (١٣/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</span>، قال: عُجِّلت لهم خَيْبَر{4}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٤<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span>، <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</span>، قال: فتْح خَيْبَر{12}. (١٣/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</span>، قال: خَيْبَر{13}. (١٣/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿فعجل لكم هذه﴾</span>، قال: يُقال: خَيْبَر. ويُقال أيضًا: فَدك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</span> يعني: غنيمة خَيْبَر{5}<span class=comment-ref>٦٠٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٦١</span> اختُلف في معنى: <span class="qpc-hafs">﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</span> على قولين: <b>الأول:</b> أنها غنيمة خَيْبَر، والمؤخَّرَةُ سائرُ فتوح المسلمين بعد ذلك الوقت إلى قيام الساعة. <b>الثاني:</b> أنه الصلح الذي كان بيْن رسول الله ﷺ وبيْن قريش.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢١/٢٨١) -<span class="mustanad">مستندًا إلى دلالة الواقع</span>- القول الأول، وهو قول مجاهد، وقتادة وما في معناه، وعلَّل ذلك بقوله: «وذلك أن المسلمين لم يَغْنَموا بعد الحُدَيبية غنيمة، ولم يفتحوا فتحًا أقربَ من بيعتهم رسول الله ﷺ بالحُدَيبية إليها، من فتح خَيْبَر وغنائمها».</div></p><p><h3><span class="qpc-hafs">﴿وَكَفَّ أَیۡدِیَ ٱلنَّاسِ عَنكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٢٩٨<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عطية، عن أصحاب علي-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٢٩٩<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قالا في قوله تعالى: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ﴾</span>: قريش <span class="qpc-hafs">﴿عَنْكُمْ﴾</span> بالصلح يوم الحُدَيبية{2}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span>، يعني: أهل مكة، أن يستحلّوا حرَم الله، أو يُستحل بكم وأنتم حُرم{9}. (١٣/٤٨٥-٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span>، قال: عن بيْضتهم وعن عيالهم بالمدينة، حين ساروا عن المدينة إلى خَيْبَر، وكانت خيبر في ذلك الوجه{18}. (١٣/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: ألقى الله في قلوبهم الرّعب، فهربوا من تحت ليلتهم؛ فهو قوله: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span> إلى آخر الآية{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span> يعني: حلفاء أهل خَيْبَر أسد وغَطَفان جاءوا لينصروا أهل خَيْبَر، وذلك أنّ مالك بن عوف النصري، وعُيينة بن حِصن الفزاري، ومَن معهما من أسد وغَطَفان؛ جاءوا لينصروا أهل خَيْبَر، فقذف الله في قلوبهم الرُّعب، فانصرفوا عنهم، فذلك قوله: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span> يعني: أسد، وغَطَفان{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span>، قال: الحليفان أسد وغَطَفان، عليهم عُيينة بن حِصن، معه مالك بن عوف النّصري أبو النضر، وأهل خَيْبَر على بئر معونة، فألقى الله في قلوبهم الرُّعب، فانهزموا، ولم يلقَوا النبيَّ ﷺ{21}<span class=comment-ref>٦٠٦٢</span>. (١٣/٤٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٦٢</span> اختُلف في قوله تعالى: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span> مَن هم الذين كُفَّت أيديهم عن المسلمين؟ على قولين: <b>الأول:</b> هم اليهود، كفَّ الله أيديهم عن عيال الذين ساروا من المدينة مع رسول الله ﷺ إلى مكة. <b>الثاني:</b> أنهم أسد وغَطَفان جاءوا لينصروا أهل خَيْبَر، فقذف الله في قلوبهم الرُّعب، فانصرفوا عنهم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢١/٢٨٢) -<span class="mustanad">مستندًا إلى دلالة العقل</span>- القول الأول، فقال معلِّلًا ترجيحه: «والذي قاله قتادة في ذلك عندي أشبه بتأويل الآية، وذلك أنّ كفَّ اللهِ أيديَ المشركين من أهل مكة عن أهل الحُدَيبية قد ذكره الله بعد هذه الآية في قوله: <span class="qpc-hafs">﴿وهُوَ الَّذِي كَفَّ أيْدِيَهُمْ عَنْكُمْ وأَيْدِيَكُمْ عَنْهُمْ بِبَطْنِ مَكَّةَ﴾</span>، فعُلِم بذلك أن الكفَّ الذي ذكره الله تعالى في قوله: <span class="qpc-hafs">﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</span> غير الكفّ الذي ذكر الله بعد هذه الآية في قوله: <span class="qpc-hafs">﴿وهُوَ الَّذِي كَفَّ أيْدِيَهُمْ عَنْكُمْ وأَيْدِيَكُمْ عَنْهُمْ بِبَطْنِ مَكَّةَ﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿وَلِتَكُونَ ءَایَةࣰ لِّلۡمُؤۡمِنِینَ وَیَهۡدِیَكُمۡ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٣٠٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عطية، عن أصحاب علي-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٦<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قالا في قوله تعالى: <span class="qpc-hafs">﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</span>: شاهدًا على ما بعدها، ودليلًا على إنجازها{2}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</span>، قال: سُنّةً لِمَن بعدكم{9}. (١٣/٤٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</span>، يقول: وذلك آية للمؤمنين، كفّ أيدي الناس عن عيالهم{24}<span class=comment-ref>٦٠٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٦٣</span> لم يذكر <u>ابنُ جرير</u> (٢١/٢٨٣) في معنى: <span class="qpc-hafs">﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</span> سوى قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٧١٣٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِتَكُونَ﴾</span> يعني: ولكي تكون هزيمتهم مِن غير قتال <span class="qpc-hafs">﴿آيَةً لِلْمُؤْمِنِينَ ويَهْدِيَكُمْ صِراطًا مُسْتَقِيمًا﴾</span> يعني: تزدادون بالإسلام تصديقًا؛ مِمّا ترون مِن عِدَة الله في القرآن من الفتح والغنيمة. كما قال نظيرها في المدثر [٣١]: <span class="qpc-hafs">﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</span>، يعني: تصديقًا بمحمد ﷺ، وبما جاء به في خَزنة جهنم{20}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في مصنفه (٩٧٣٨)، وأبو داود في مراسيله ص١٦٥.|2:أخرجه ابن عساكر ١/٣٩٧.|3:أخرجه ابن جرير ٢١/٢٧٩.|4:أخرجه ابن جرير ٢١/٢٨٠.|5:تفسير مقاتل بن سليمان ٤/٧٣.|6:أخرجه ابن عساكر ١/٣٩٧.|7:عزاه السيوطي إلى ابن جرير، وابن مردويه.|8:أخرجه ابن جرير ٢١/٢٨١.|9:عزاه السيوطي إلى ابن مردويه.|10:أخرجه البيهقي ٤/١٩٧. وعزاه السيوطي إلى ابن مردويه.|11:أخرجه ابن جرير ٢١/٢٨٠.|12:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|13:أخرجه ابن جرير ٢١/٢٨١. وعزاه السيوطي إلى عبد بن حميد.|14:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٠.|15:تفسير مقاتل بن سليمان ٤/٧٣.|16:أخرجه ابن عساكر ١/٣٩٧.|17:عزاه السيوطي إلى ابن مردويه.|18:أخرجه ابن جرير ٢١/٢٨٢، وأخرجه عبد الرزاق ٢/٢٢٧ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.|19:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٥-.|20:تفسير مقاتل بن سليمان ٤/٧٤.|21:عزاه السيوطي إلى ابن المنذر.|22:أخرجه ابن عساكر ١/٣٩٧.|23:عزاه السيوطي إلى ابن مردويه.|24:أخرجه عبد الرزاق ٢/٢٢٧، وابن جرير ٢١/٢٨٤.|25:تفسير مقاتل بن سليمان ٤/٧٤.
  48,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُخۡرَىٰ لَمۡ تَقۡدِرُوا۟ عَلَیۡهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٣١٠<span class="dash">-</span></span> عن أبي الأسود الدُّؤلي: أنّ <span class="name-1">الزبير بن العوام</span> لَمّا قدِم البصرة دخل بيت المال، فإذا هو بصفراء وبيضاء، فقال: يقول الله: <span class="qpc-hafs">﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</span> ... <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها قَدْ أحاطَ اللَّهُ بِها﴾</span>، فقال: هذا لنا{1}. (١٣/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عطية، عن أصحاب علي-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٢<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قالا في قوله تعالى: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>: على عِلْمِ وقتها، أُفيئها عليكم؛ فارس والروم{2}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شعبة، عن سِماك الحنفي- في قوله: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: هذه الفتوح التي تُفتَح إلى اليوم{3}. (١٣/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سِماك- <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>: فارس، والروم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: هي خَيْبَر{5}. (١٣/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٦<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق الحكم- <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: فارس، والروم{6}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>: ما فتحوا حتى اليوم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>: يعني: خَيْبَر، بعثهم رسول الله ﷺ يومئذ، فقال: «<b>لا تُمَثِّلُوا، ولا تَغُلُّوا، ولا تَقْتلوا وليدًا</b>»{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: يوم حُنين{9}. (١٣/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٠<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span> هي خَيْبَر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span> هي فارس، والروم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٢<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span>، <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: فتْح فارس{9}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: بلَغَنا: أنّها مكة{13}. (١٣/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٤<span class="dash">-</span></span> عن <span class="name-2">جويبر</span>، <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>، قال: يزعمون: أنها قرى عربية. ويزعم آخرون: أنها فارس، والروم{9}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span> يعني: [قرى] فارس والروم وغيرها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>: يعني: أهل خَيْبَر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها قَدْ أحاطَ اللَّهُ بِها﴾</span>، قال: خَيْبَر. قال: لم يكونوا يذكرونها، ولا يَرْجُونها، حتى أخبرهم الله بها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٢٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن عمر الواقدي</span>، في قوله: <span class="qpc-hafs">﴿وأخرى لم تقدروا عليها﴾</span>، قال: فارس والروم. ويُقال: مكة{18}<span class=comment-ref>٦٠٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٦٤</span> اختُلِف في البلدة التي وعدهم الله تعالى فَتْحَها في قوله: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span> على أقوال: <b>الأول:</b> أنها أرض فارس والروم، وما يفتحه المسلمون من البلاد إلى قيام الساعة. <b>الثاني:</b> أنها خَيْبَر. <b>الثالث:</b> أنها مكة. <b>الرابع:</b> يوم حُنين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢١/٢٨٦) -<span class="mustanad">مستندًا إلى دلالة العقل</span>- القول الثالث، وهو قول قتادة، وعلَّل ذلك بـ«أن الله أخبر هؤلاء الذين بايعوا رسول الله ﷺ تحت الشجرة أنه محيطٌ بقريةٍ لم يَقْدِروا عليها، ومعقولٌ أنه لا يُقال لقومٍ: لم يقدروا على هذه المدينة. إلا أن يكونوا قد رامُوها، فتَعَذَّرت عليهم، فأمّا وهم لم يروموها فتَتَعَذَّر عليهم فلا يُقال: إنهم لم يقدروا عليها. فإذ كان ذلك كذلك، وكان معلومًا أنّ رسول الله ﷺ لم يَقْصِد قبل نزول هذه الآية عليه خَيْبَر لحربٍ، ولا وجَّه إليها لقتال أهلها جيشًا ولا سريةً؛ عُلِم أن المعنيَّ بقوله: <span class="qpc-hafs">﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</span>: غيرها، وأنها هي التي قد عالجها ورامَها فتعذَّرت، فكانت مكة وأهلها كذلك».</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٧/٦٨١) قائلًا: «وهذا هو القول الذي يتَّسق معه المعنى ويتأيَّد».</div></p><p><h3><span class="qpc-hafs">﴿قَدۡ أَحَاطَ ٱللَّهُ بِهَاۚ وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣰا ۝٢١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧١٣٢٩<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عطية، عن أصحاب علي-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٣٠<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قالا في قوله تعالى: <span class="qpc-hafs">﴿قَدْ أحاطَ اللَّهُ بِها﴾</span>: قضى الله بها أنها لكم{2}. (١٣/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- في قوله: <span class="qpc-hafs">﴿قَدْ أحاطَ اللَّهُ بِها﴾</span>: أنها ستكون لكم، بمنزلة قوله: أحاط الله بها علمًا أنها لكم{20}. (١٣/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قَدْ أحاطَ اللَّهُ﴾</span> علمه <span class="qpc-hafs">﴿بِها﴾</span> أن يفتحها على يدي المؤمنين، <span class="qpc-hafs">﴿وكانَ اللَّهُ عَلى كُلِّ شَيْءٍ﴾</span> مِن القرى <span class="qpc-hafs">﴿قَدِيرًا﴾</span> على فتْحها{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٥/٢٨٠.|2:أخرجه ابن عساكر ١/٣٩٧.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه. وأخرجه إسحاق البستي ص٣٧٣ بلفظ: ما أصبتم من هذه الفتوح، والبيهقي في الدلائل ٤/١٦٣ بلفظ: هو ما أصبتم بعده.|4:أخرجه ابن جرير ٢١/٢٨٤.|5:أخرجه ابن جرير ٢١/٢٨٥. وعزاه السيوطي إلى ابن مردويه.|6:أخرجه ابن جرير ٢١/٢٨٤، والبيهقي ٤/١٦. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ٢١/٢٨٤.|8:أخرجه ابن جرير ٢١/٢٨٥.|9:عزاه السيوطي إلى عبد بن حميد.|10:تفسير الثعلبي ٩/٥٣. وذُكر في طبعة دار التفسير ٢٤/٢٧٤ أنها في نسخة: حنين. وقد أثبتوا ذلك في المتن.|11:أخرجه ابن جرير ٢١/٢٨٤.|12:عزاه السيوطي إلى عبد بن حميد.|13:أخرجه عبد الرزاق ٢/٢٢٧، وابن جرير ٢١/٢٨٦، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.|14:عزاه السيوطي إلى عبد بن حميد.|15:تفسير مقاتل بن سليمان ٤/٧٤.|16:أخرجه ابن جرير ٢١/٢٨٥.|17:أخرجه ابن جرير ٢١/٢٨٥.|18:أخرجه ابن عساكر في تاريخ دمشق ١/٣٩٨.|19:أخرجه ابن عساكر ١/٣٩٧.|20:أخرجه البيهقي ٤/١٦٣.|21:تفسير مقاتل بن سليمان ٤/٧٤.
  48,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ قَـٰتَلَكُمُ ٱلَّذِینَ كَفَرُوا۟ لَوَلَّوُا۟ ٱلۡأَدۡبَـٰرَ ثُمَّ لَا یَجِدُونَ وَلِیࣰّا وَلَا نَصِیرࣰا ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٣٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولَوْ قاتَلَكُمُ الَّذِينَ كَفَرُوا لَوَلَّوُا الأَدْبارَ﴾</span>: يعني: أهل مكة{1}<span class=comment-ref>٦٠٦٥</span>. (١٣/٤٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٦٥</span> ذكر <u>ابنُ عطية</u> (٧/٦٨١) قول قتادة، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وفي هذا تقويةٌ لنفوس المؤمنين». ثم نقل عن بعض المفسّرين أن المراد بهم: الروم وفارس، ثم <span class="comment-type-2">انتقدهم</span> قائلًا: «وهذا ضعيف، وإنما الإشارة إلى العدوِّ الأحضر».</div></p><p><div></p><p><p><span class="item-no">٧١٣٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿ولَوْ قاتَلَكُمُ الَّذِينَ كَفَرُوا لَوَلَّوُا الأَدْبارَ﴾</span> منهزمين، <span class="qpc-hafs">﴿ثُمَّ لا يَجِدُونَ ولِيًّا ولا نَصِيرًا﴾</span> يعني: ولا مانِعًا يمنعهم من الهزيمة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ولَوْ قاتَلَكُمُ الَّذِينَ كَفَرُوا﴾</span> هم أسد وغَطَفان، <span class="qpc-hafs">﴿لَوَلَّوُا الأَدْبارَ﴾</span> حتى <span class="qpc-hafs">﴿ولَنْ{3} تَجِدَ لِسُنَّةِ اللَّهِ تَبْدِيلًا﴾</span>{4}. (١٣/٤٨٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٢٨٧ بلفظ: كفار قريش. وعزاه السيوطي إلى عبد بن حميد.|2:تفسير مقاتل بن سليمان ٤/٧٤-٧٥.|3:ذكر محققو الدر أنه في نسخه: لا.|4:عزاه السيوطي إلى ابن المنذر.
  48,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سُنَّةَ ٱللَّهِ ٱلَّتِی قَدۡ خَلَتۡ مِن قَبۡلُۖ وَلَن تَجِدَ لِسُنَّةِ ٱللَّهِ تَبۡدِیلࣰا ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧١٣٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: كذلك كان <span class="qpc-hafs">﴿سُنَّةَ اللَّهِ الَّتِي قَدْ خَلَتْ مِن قَبْلُ﴾</span> كفار مكة حين هُزموا ببدر، فهؤلاء بمنزلتهم، <span class="qpc-hafs">﴿ولَنْ تَجِدَ لِسُنَّةِ اللَّهِ تَبْدِيلًا﴾</span> يعني: تحويلًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ولَنْ تَجِدَ لِسُنَّةِ اللَّهِ تَبْدِيلًا﴾</span>، يقول: سُنَّة الله في الذين خَلَوا من قبل أن لن يُقاتِل أحدٌ نبيَّه إلا خذله الله؛ فقتله أو رَعَّبه فانهزم، ولن يسمع به عدوٌّ إلا انهزموا واستسلموا{2}. (١٣/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧١٣٣٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق وهب عن أبيه- قوله: <span class="qpc-hafs">﴿سنه الله التي قد خلت من قبل﴾</span> يعني: قريشًا في المواطن التي كانت قبل ذلك، <span class="qpc-hafs">﴿ولن تجد لسنة الله تبديلا﴾</span> يقول: الذي وعد من النصر{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٧٤-٧٥.|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه إسحاق البستي ص٣٧٣.