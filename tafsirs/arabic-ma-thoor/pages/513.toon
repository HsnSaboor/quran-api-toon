quran[8]{c,v,t}:
48,16," <q>﴿قُل لِّلۡمُخَلَّفِینَ مِنَ ٱلۡأَعۡرَابِ سَتُدۡعَوۡنَ إِلَىٰ قَوۡمٍ أُو۟لِی بَأۡسࣲ شَدِیدࣲ﴾</q> - تفسير ٧١٢٠٣- عن أبي هريرة -من طريق الزُّهريّ- <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: لم يأتِ أولئك بعد{1}. (١٣/٤٧٧) ٧١٢٠٤- عن أبي هريرة -من طريق ابن أبي خالد، عن أبيه- في قوله: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: هم البارِز. يعني: الأكراد{2}. (١٣/٤٧٧) ٧١٢٠٥- عن عبد الله بن عباس -من طريق عطاء بن أبي رباح- في قوله <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: فارس{3}. (١٣/٤٧٧) ٧١٢٠٦- عن عبد الله بن عباس، <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: فارس، والروم{4}. (١٣/٤٧٨) ٧١٢٠٧- عن عبد الله بن عباس، <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: هَوازن، وبني حنيفة{5}. (١٣/٤٧٨) ٧١٢٠٨- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿ستدعون إلى قوم أولى بأس شديد﴾</q>، قال: هَوازن، وثقيف{6}. (ز) ٧١٢٠٩- قال رافع بن خَدِيج: كُنّا نقرأ هذه الآية، ولا نعلم مَن هم، حتى دعا أبو بكر إلى قتال بني حنيفة، فعلمنا أنهم هم{7}. (ز) ٧١٢١٠- عن كعب [الأحبار] -من طريق الفرج بن محمد الكلاعي- قال: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: الروم{8}. (ز) ٧١٢١١- عن عبد الرحمن بن أبي ليلى -من طريق ثابت البُناني- في قوله: <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: فارس، والروم{9}. (ز) ٧١٢١٢- عن سعيد بن جُبير= (ز) ٧١٢١٣- وعكرمة مولى ابن عباس -من طريق أبي بشر- في قوله: <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: هَوازن يوم حنين{10}. (١٣/٤٧٨) ٧١٢١٤- عن مجاهد بن جبر -من طريق عيسى وورقاء، عن ابن أبي نجيح- قوله: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: هم فارس{11}. (ز) ٧١٢١٥- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- قوله: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: هم فارس، والروم{12}. (ز) ٧١٢١٦- عن مجاهد بن جبر، <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: أعراب فارس، وأكْراد العَجم{13}. (١٣/٤٧٧) ٧١٢١٧- عن مجاهد بن جبر، <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: أهل الأوثان{14}. (١٣/٤٧٨) ٧١٢١٨- عن الحسن البصري -من طرق- قال: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>: هم فارس، والروم{15}. (١٣/٤٧٧) ٧١٢١٩- عن عطاء ابن أبي رباح -من طريق عمرو- في قوله: <q>﴿أولي بأس شديد﴾</q>، قال: هم فارس{16}. (ز) ٧١٢٢٠- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>: هم هَوازن، وغَطَفان يوم حُنين{17}. (ز) ٧١٢٢١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: فدُعوا يوم حُنين إلى هَوازن وثقيف، فمنهم مَن أحسن الإجابة ورغب في الجهاد{18}. (١٣/٤٧٦) ٧١٢٢٢- عن محمد بن شهاب الزُّهريّ -من طريق ابن إسحاق- قال: <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q> هم بنو حَنيفة مع مُسَيلمة الكذّاب{19}. (١٣/٤٧٧) ٧١٢٢٣- عن محمد بن السّائِب الكلبي -من طريق معمر- <q>﴿أُولِي بَأْسٍ شَدِيدٍ﴾</q>، أنه قال: هم بنو حَنيفة{20}. (ز) ٧١٢٢٤- قال مقاتل بن سليمان: ثم قال: <q>﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ﴾</q> عن الحُدَيبية مخافة القتل <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q> يعني: أهل اليمامة، يعني: بني حَنيفة: مُسَيلمة بن حبيب الكذّاب الحنفي وقومه، دعاهم أبو بكر ﵁ إلى قتال أهل اليمامة، يعني: هؤلاء الأحياء الخمسة؛ جُهينة، ومُزينة، وأشْجَع، وغِفار، وأسْلَم{21}. (ز) ٧١٢٢٥- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: ... إلى قتال فارس{22}. (١٣/٤٧٨) ٧١٢٢٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q>، قال: فارس، والروم{23}٦٠٥٧. (ز) ٦٠٥٧ اختُلف في قوله تعالى: <q>﴿قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q> مَن هؤلاء القوم على أقوال: الأول: هَوازن بحنين. الثاني: الروم. الثالث: أهل الرّدة وبنو حنيفة باليمامة. الرابع: فارس والروم. الخامس: هم أهل فارس. السادس: لم تأت هذه الآية بعد. ورجَّح ابنُ جرير (٢١/٢٦٩) مستندًا إلى دلالة الإطلاق في ظاهر الآية «أن يُقال: إنّ الله -تعالى ذِكْره- أخبر عن هؤلاء المخلَّفين من الأعراب أنهم سيُدعَون إلى قتال قومٍ أولي بأسٍ في القتال، ونجدةٍ في الحروب، ولم يوضَع لنا الدليل من خبرٍ ولا عقلٍ على أن المعنيَّ بذلك هوازن، ولا بنو حنيفة، ولا فارس، ولا الروم، ولا أعيانٌ بأعيانهم، وجائزٌ أن يكون عُنِيَ بذلك بعض هذه الأجناس، وجائزٌ أن يكون عُنِيَ بهم غيرهم، ولا قول فيه أصح مِن أن يُقال كما قال الله -جلَّ ثناؤه-: إنهم سيُدعَون إلى قومٍ أولي بأسٍ شديد». وعلَّق ابنُ عطية (٧/٦٧٦) على القول الأول بقوله: «ويندرج في هذا القول عندي مَن حورب وغلب في فتح مكة». ثم رجَّح القول الأول والثاني مستندًا إلى دلالة الواقع، وانتقد باقي الأقوال قائلًا: «والقولان الأوَّلان حسنان؛ لأنهما الذي كشف الغيب، وباقيهما ضعيف». ثم نقل ابنُ عطية تعليق منذر بن سعيد على القول الثالث بقوله: «وقال منذر بن سعيد: يتركَّب على هذا القول أن الآية مُؤذنة بخلافة أبي بكر الصِّديق وعمر بن الخطاب». ووجَّهه بقوله: «يريد: لما كشف الغيب أنهما دَعَوا إلى قتال أهل الردة». ونقل عن منذر بن سعيد أيضًا قوله: «رفع الله في هذه الجزية، وليس إلا القتال أو الإسلام، وهذا لا يوجد إلا في أهل الردة». ثم علَّق عليه بقوله: «وكذا مَن حورب في فتح مكة». ورجَّح ابنُ تيمية (٦/٢١-٢٢) القول الرابع مستندًا إلى دلالة الواقع، فذكر: أن أظهر الأقوال في الآية هو أن المراد «تُدعون إلى قتال أولي بأس شديد أعظم من العرب، لا بُدَّ فيهم مِن أحد أمرين: إما أن يُسلموا، وإما أن يُقاتَلوا؛ بخلاف مَن دُعوا إليه عام الحُدَيبية، فإنّ بأسهم لم يكن شديدًا مثل هؤلاء ودُعوا إليهم، ففي ذلك لم يُسلموا ولم يقاتلوا. وكذلك عام الفتح في أول الأمر لم يُسلموا ولم يقاتلوا، لكن بعد ذلك أسلموا. وهؤلاء هم الروم والفرس ونحوهم، فإنه لابد من قتالهم إذا لم يُسلموا، وأول الدعوة إلى قتال هؤلاء عام مؤتة وتبوك». وانتقد (٦/١٩) القول الأول بأنه لا «يجوز أن يكون دعاهم إلى قتال أهل مكة وهَوازن عقيب عام الفتح؛ لأن هؤلاء هم الذين دعوا إليهم عام الحُدَيبية، ومن لم يكن منهم فهو من جنسهم ليس هو أشدَّ بأسًا منهم، كلّهم عرب من أهل الحجاز، وقتالهم من جنس واحد، وأهل مكة ومَن حولها كانوا أشد بأسًا وقتالًا للنبي ﷺ وأصحابه يوم بدر وأحد والخندق مِن أولئك، وكذلك في غير ذلك من السرايا». <q>﴿تُقَـٰتِلُونَهُمۡ أَوۡ یُسۡلِمُونَۖ فَإِن تُطِیعُوا۟ یُؤۡتِكُمُ ٱللَّهُ أَجۡرًا حَسَنࣰاۖ﴾</q> - تفسير ٧١٢٢٧- قال مقاتل بن سليمان: <q>﴿سَتُدْعَوْنَ إلى قَوْمٍ أُولِي بَأْسٍ شَدِيدٍ﴾</q> يعني: أهل اليمامة، يعني: بني حنيفة: مُسَيلمة بن حبيب الكذّاب الحنفي وقومه، دعاهم أبو بكر ﵁ إلى قتال أهل اليمامة، يعني: هؤلاء الأحياء الخمسة؛ جُهينة، ومُزينة، وأشْجَع، وغِفار، وأسْلَم <q>﴿تُقاتِلُونَهُمْ أوْ يُسْلِمُونَ فَإنْ تُطِيعُوا﴾</q> أبا بكر إذا دعاكم إلى قتالهم <q>﴿يُؤْتِكُمُ اللَّهُ أجْرًا حَسَنًا﴾</q> في الآخرة، يعني: جزاء كريمًا في الجنّة{24}. (ز) ٧١٢٢٨- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿قُلْ لِلْمُخَلَّفِينَ مِنَ الأَعْرابِ سَتُدْعَوْنَ إلى قَوْمٍ﴾</q> قال: عمر بن الخطاب دعا أعراب المدينة؛ جُهينة ومُزينة الذين كان النَّبِيّ ﷺ دعاهم إلى خروجه إلى مكة، دعاهم عمر بن الخطاب إلى قتال فارس <q>﴿فَإنْ تُطِيعُوا﴾</q> إذا دعاكم عمر تكن توبة لتخلُّفكم عن النبيِّ ﷺ <q>﴿يؤتكم الله أجرًا حسنًا﴾</q>{22}. (١٣/٤٧٨) <q>﴿وَإِن تَتَوَلَّوۡا۟ كَمَا تَوَلَّیۡتُم مِّن قَبۡلُ یُعَذِّبۡكُمۡ عَذَابًا أَلِیمࣰا ۝١٦﴾</q> - تفسير ٧١٢٢٩- قال محمد بن السّائِب الكلبي: <q>﴿وإنْ تَتَوَلَّوْا كَما تَوَلَّيْتُمْ مِن قَبْلُ﴾</q> يوم الحُدَيبية{26}. (ز) ٧١٢٣٠- قال مقاتل بن سليمان: <q>﴿وإنْ تَتَوَلَّوْا﴾</q> يعني: تُعرِضوا عن قتال أهل اليمامة <q>﴿كَما تَوَلَّيْتُمْ﴾</q> يعني: كما أعرضتم <q>﴿مِن قَبْلُ﴾</q> عن قتال الكفار يوم الحُدَيبية؛ <q>﴿يُعَذِّبْكُمْ﴾</q> الله في الآخرة <q>﴿عَذابًا ألِيمًا﴾</q> يعني: وجيعًا{24}. (ز) ٧١٢٣١- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وإنْ تَتَوَلَّوْا﴾</q> إذا دعاكم عمر <q>﴿كَما تَوَلَّيْتُمْ مِن قَبْلُ﴾</q> إذ دعاكم النبيُّ ﷺ <q>﴿يُعَذِّبْكُمْ عَذابًا ألِيمًا﴾</q>{22}. (١٣/٤٧٨) <q>﴿وَإِن تَتَوَلَّوۡا۟ كَمَا تَوَلَّیۡتُم مِّن قَبۡلُ یُعَذِّبۡكُمۡ عَذَابًا أَلِیمࣰا ۝١٦﴾</q> - آثار متعلقة بالآية ٧١٢٣٢- قال مقاتل بن سليمان: خلافة أبي بكر ﵁ في هذه الآية مؤكّدة{29}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ٢١/٢٦٨.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٢١-، وأخرج أوله إسحاق البستي ص٣٦٩.أخرجه ابن جرير ٢١/٢٦٦، والبيهقي ٤/١٦٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى الفريابي، وابن مردويه.أخرجه ابن عساكر في تاريخ دمشق ٥/٤٧٣.تفسير البغوي ٧/٣٠٣.أخرجه ابن جرير ٢١/٢٦٨.أخرجه ابن جرير ٢١/٢٦٦.أخرجه ابن جرير ٢١/٢٦٧ وفيه: هوازن وثقيف، وفي رواية أخرى ١٢/٢٦٨: هوازن وبني حنيفة، والبيهقي ٤/١٦٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢١/٢٦٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٢-.تفسير مجاهد ص٦٠٨.عزاه السيوطي إلى ابن المنذر، والطبراني في الكبير.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٢٦ من طريق معمر، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٠٨- من طريق المبارك بن فضالة، وابن جرير ٢١/٢٦٦-٢٦٧ من طريق قتادة، والبيهقي ٤/١٦٥. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه إسحاق البستي ص٣٧٠.أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ٢١/٢٦٧.أخرجه ابن جرير ٢١/٢٦٧-٢٦٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢١/٢٦٨. وعزاه السيوطي إلى ابن المنذر، والطبراني.أخرجه عبد الرزاق ٢/٢٢٦.تفسير مقاتل بن سليمان ٤/٧٢-٧٣.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢٦٧.تفسير مقاتل بن سليمان ٤/٧٣.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٢-.تفسير مقاتل بن سليمان ٤/٧٣.عزاه السيوطي إلى ابن المنذر.أخرجه الهذيل بن حبيب -كما في تفسير مقاتل بن سليمان ٤/٧٣-.
48,17," <q>﴿لَّیۡسَ عَلَى ٱلۡأَعۡمَىٰ حَرَجࣱ وَلَا عَلَى ٱلۡأَعۡرَجِ حَرَجࣱ وَلَا عَلَى ٱلۡمَرِیضِ حَرَجࣱۗ وَمَن یُطِعِ ٱللَّهَ وَرَسُولَهُۥ یُدۡخِلۡهُ جَنَّـٰتࣲ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ وَمَن یَتَوَلَّ یُعَذِّبۡهُ عَذَابًا أَلِیمࣰا ۝١٧﴾</q> - نزول الآية، وتفسيرها ٧١٢٣٣- عن زيد بن ثابت، قال: كنت أكتب لرسول الله ﷺ، وإنِّي لَواضِعٌ القَلمَ على أذني إذ أُمِر بالقتال، إذ جاء أعمى فقال: كيف بي وأنا ذاهبُ البصر؟ فنزلت: <q>﴿لَيْسَ عَلى الأَعْمى حَرَجٌ﴾</q> الآية. قال: «هذا في الجهاد، ليس عليهم مِن جهاد إذا لم يُطِيقوا»{1}. (١٣/٤٧٩) ٧١٢٣٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿لَيْسَ عَلى الأَعْمى حَرَجٌ﴾</q> الآية: يعني: في القتال{2}. (ز) ٧١٢٣٥- عن قتادة بن دعامة -من طريق سعيد-: ثم عذَر الله أهلَ العُذر مِن الناس، فقال: <q>﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</q>{3}. (١٣/٤٧٦) ٧١٢٣٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</q>، قال: هذا كلّه في الجهاد{4}. (ز) ٧١٢٣٧- عن إسماعيل بن أبي خالد -من طريق سفيان بن عيينة- قال: <q>﴿ليس على الأعمى حرج﴾</q>، قال: هو المُقْعَد{5}. (ز) ٧١٢٣٨- قال مقاتل بن سليمان: ثم عذر أهل الزَّمانَةِ، فقال: <q>﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</q> في تخلُّفهم عن الحُدَيبية. يقول: مَن تخلَّف عن الحُدَيبية مِن هؤلاء المعذورين فمَن شاء منهم أن يسير معكم فليَسِر، <q>﴿ومَن يُطِعِ اللَّهَ ورَسُولَهُ في الغزو يُدْخِلْهُ جَنّاتٍ تَجْرِي مِن تَحْتِها الأَنْهارُ ومَن يَتَوَلَّ﴾</q> يعني: يُعرِض عن طاعتهما في التخلّف مِن غير عُذر <q>﴿يُعَذِّبْهُ عَذابًا ألِيمًا﴾</q> يعني: وجيعًا{6}. (ز) ٧١٢٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لَيْسَ عَلى الأَعْمى حَرَجٌ ولا عَلى الأَعْرَجِ حَرَجٌ ولا عَلى المَرِيضِ حَرَجٌ﴾</q>، قال: في الجهاد في سبيل الله{2}. (ز) ",footnotes:1:أخرجه الطبراني في الكبير ٥/١٥٥ (٤٩٢٦). قال الهيثمي في المجمع ٧/١٠٧ (١١٣٤٥): «وفيه محمد بن جابر السحيمي، وهو ضعيف يُكتب حديثه، وبقية رجاله رجال الصحيح». وقال السيوطي: «بسند حسن».أخرجه ابن جرير ٢١/٢٧١.عزاه السيوطي إلى ابن جرير، وعبد بن حميد.أخرجه ابن جرير ٢١/٢٧٠.أخرجه إسحاق البستي ص٣٧٠.تفسير مقاتل بن سليمان ٤/٧٣.أخرجه ابن جرير ٢١/٢٧١.
48,18," <q>﴿لَّقَدۡ رَضِیَ ٱللَّهُ عَنِ ٱلۡمُؤۡمِنِینَ إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</q> - نزول الآية ٧١٢٤٠- عن سَلَمة بن الأكْوع، قال: بينا نحن قائِلون إذ نادى مُنادي رسول الله ﷺ: أيها الناس، البيعةَ البيعةَ، نزل روح القُدس. فثُرْنا إلى رسول الله ﷺ وهو تحت شجرة سَمُرَة، فبايعناه، فذلك قول الله تعالى: <q>﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ﴾</q>، فبايع لعثمان؛ إحدى يديه على الأخرى، فقال الناس: هنيئًا لابن عفان، يطوف بالبيت ونحن ههنا. فقال رسول الله ﷺ: «لو مكث كذا وكذا سنةً ما طاف حتى أطوف»{1}. (١٣/٤٧٩) <q>﴿لَّقَدۡ رَضِیَ ٱللَّهُ عَنِ ٱلۡمُؤۡمِنِینَ إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</q> - قصة بيعة الرضوان، وسببها ٧١٢٤١- عن أنس بن مالك، قال: لَمّا أمَر رسولُ الله ﷺ ببيعة الرضوان كان عثمانُ بن عفان رسولَ رسولِ الله ﷺ إلى أهل مكة، فبايع الناس، فقال رسول الله ﷺ: «اللهم، إنّ عثمان في حاجة الله وحاجة رسوله». فضرب بإحدى يديه على الأخرى، فكانت يد رسول الله ﷺ لعثمان خيرًا مِن أيديهم لأنفسهم{2}. (١٣/٤٨٢) ٧١٢٤٢- عن عروة بن الزبير، قال: لَمّا نزل النبيُّ ﷺ الحُدَيبية فَزِعت قريش لنزوله عليهم، فأحبّ رسولُ الله ﷺ أن يبعث إليهم رجلًا مِن أصحابه، فدعا عمرَ بن الخطاب ليبعثه إليهم، فقال: يا رسول الله، إني لا آمَن، وليس بمكة أحد مِن بني كعب يغضب لي إنْ أُوذيت، فأرسِل عثمان بن عفان، فإنّ عشيرته بها، وإنه مبلّغٌ لك ما أردت. فدعا رسولُ الله ﷺ عثمانَ، فأرسله إلى قريش، وقال: «أخبِرهم أنّا لم نأتِ لقتال، وإنّما جِئنا عُمّارًا، وادعهم إلى الإسلام». وأمَره أن يأتي رجالًا بمكة مؤمنين ونساء مؤمنات، فيدخل عليهم، ويبشّرهم بالفتح، ويخبرهم أنّ الله وشيكٌ أن يُظهِر دينه بمكة حتى لا يُستخفى فيها بالإيمان. فانطلَق عثمان إلى قريش، فأخبَرهم، فارتهنه المشركون، ودعا رسولُ الله ﷺ إلى البيعة، ونادى منادي رسول الله ﷺ: ألا إنّ روح القدس قد نزل على رسول الله ﷺ، فأمره بالبيعة، فاخرجوا على اسم الله، فبايِعوه. فثار المسلمون إلى رسول الله ﷺ وهو تحت الشجرة، فبايَعوه على ألّا يَفِرّوا أبدًا، فرَعَبهم الله، فأرسَلوا مَن كانوا ارتهَنوا مِن المسلمين، ودَعَوا إلى المُوادعة والصُّلح{3}. (١٣/٤٨١) ٧١٢٤٣- عن عكرمة مولى ابن عباس –من طريق ابن إسحاق، عن رجل-، نحوه{4}. (ز) ٧١٢٤٤- عن محمد بن إسحاق، قال: فحدثني عبد الله بن أبي بكر: أنّ رسول الله ﷺ حين بلغه أن عثمان قد قُتِل، قال: «لا نبرح حتى نناجز القوم». ودعا الناس إلى البيعة، فكانت بيعة الرضوان تحت الشجرة، فكان الناس يقولون: بايعهم رسول الله ﷺ على الموت. فكان جابر بن عبد الله يقول: إنّ رسول الله ﷺ لم يبايعنا على الموت، ولكنه بايعنا على أن لا نَفِرّ. فبايع رسولُ الله ﷺ الناسَ، ولم يتخلف عنه أحدٌ مِن المسلمين حضرها إلا الجدُّ بنُ قيس أخو بني سلمة، كان جابر بن عبد الله يقول: لَكأنِّي أنظر إليه لاصقًا بإبط ناقته، قد اختبأ إليها، يستتر بها مِن الناس. ثم أتى رسولَ الله ﷺ أنّ الذي ذُكِر مِن أمر عثمان باطلٌ{5}. (ز) ٧١٢٤٥- عن محمد بن إسحاق، عن بعض أهل العلم، قال: إنّ رسول الله ﷺ دعا خِراش بن أُميّة الخزاعي، فبعثه إلى قريش بمكة، وحمله على جمل له يُقال له: الثعلب، ليُبَلّغ أشرافهم عنه ما جاء له، وذلك حين نزل الحُدَيبية، فعقروا به جمل رسول الله ﷺ، وأرادوا قتْله، فمنعته الأحابيش، فخلَّوا سبيله، حتى أتى رسولَ الله ﷺ{4}. (ز) <q>﴿لَّقَدۡ رَضِیَ ٱللَّهُ عَنِ ٱلۡمُؤۡمِنِینَ﴾</q> - تفسير ٧١٢٤٦- عن سعيد بن المسيّب، عن أبيه، قال: كُنّا مع النبيِّ ﷺ تحت الشجرة ألفًا وأربعمائة{7}. (١٣/٤٨١) ٧١٢٤٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ﴾</q>، قال: كان أهل البيعة تحت الشجرة ألفًا وخمسمائة وخمسًا وعشرين{8}. (١٣/٤٨٤) ٧١٢٤٨- عن جابر بن عبد الله، قال: كُنّا يوم الحُدَيبية ألفًا وأربعمائة، فقال لنا رسول الله ﷺ: «أنتم خيرُ أهل الأرض»{9}. (١٣/٤٨٠) ٧١٢٤٩- عن قتادة، قال: قلت لسعيد بن المسيّب: كم كان الذين شهِدوا بيعة الرضوان؟ قال: خمس عشرة مائة.= (ز) ٧١٢٥٠- قلت: فإنّ جابر بن عبد الله قال: كانوا أربع عشرة مائة. قال: يرحمه الله، وهِم، هو حدّثني أنّهم كانوا خمس عشرة مائة{10}. (١٣/٤٨٠) ٧١٢٥١- عن عبد الله بن أبي أوْفى، قال: كان أصحابُ الشجرة ألفًا وثلاثمائة{11}٦٠٥٨. (١٣/٤٨٠) ٦٠٥٨ نقل ابن كثير (١٣/٩٢) في عدد الصحابة الذين بايعوا رسول الله ﷺ في بيعة الرضوان ثلاثة أقوال: الأول: ألف وثلاثمائة. الثاني: وأربعمائة. الثالث: وخمسمائة. ثم رجَّح قائلًا: «والأوسط أصحّ». ولم يذكر مستندًا. <q>﴿إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</q> - تفسير ٧١٢٥٢- عن مَعْقِل بن يَسار، قال: لقد رأيتُني يومَ الشجرة والنبيُّ ﷺ يبايع الناس، وأنا رافع غصنًا مِن أغصانها عن رأسه، ونحن أربع عشرة مائة، ولم نبايعه على الموت، ولكن بايعناه على ألا نَفرّ{12}. (١٣/٤٨٢) ٧١٢٥٣- عن سَلَمة بن الأكْوع، قال: بايعتُ رسول الله ﷺ تحت الشجرة. قيل: على أيِّ شيء كنتم تَبايَعون يومئذ؟ قال: على الموت{13}. (١٣/٤٨١) ٧١٢٥٤- عن جابر بن عبد الله -من طريق محمد بن المنكدر- قال: كُنّا يوم الحُدَيبية ألفًا وأربعمائة، فبايعناه وعمرُ آخِذٌ بيده تحت الشجرة، وهي سَمُرَة. وقال: بايعناه على ألا نَفِرَّ، ولم نبايعه على الموت{14}. (١٣/٤٨٢) ٧١٢٥٥- عن قتادة بن دعامة، قال: <q>﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ فَعَلِمَ ما فِي قُلُوبِهِمْ فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</q>، قال: ... وهم الذين بايعوا زمان الحُدَيبية، وكانت الشجرة -فيما ذُكِر لنا- سَمُرة، بايع النبيُّ ﷺ أصحابَه تحتها، وكانوا يومئذ خمس عشرة مائة، فبايعوه على ألّا يَفِرُّوا، ولم يبايعوه على الموت{15}. (١٣/٤٨٤) ٧١٢٥٦- عن بُكَير بن الأشجّ، أنّه بلغه: أنّ الناس بايعوا رسول الله ﷺ على الموت، فقال رسول الله ﷺ: «على ما استطعتم». والشجرة التي بُويِع تحتها بفجٍّ نحو مكة. وزعموا: أنّ عمر بن الخطاب ﵁ مرّ بذلك المكان بعد أن ذهبت الشجرة، فقال: أين كانت؟ فجعل بعضهم يقول: هنا. وبعضهم يقول: ههنا. فلما كثر اختلافهم قال: سيروا، هذا التكلّف. فذهبت الشجرة، وكانت سَمُرَة؛ إما ذهب بها سيل، وإما شيء سوى ذلك{16}. (ز) ٧١٢٥٧- قال مقاتل بن سليمان: <q>﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ﴾</q> بالحُدَيبية، يقول: رضي ببيعتهم إياك{17}. (ز) ٧١٢٥٨- عن عبد الملك ابن جُرَيْج -من طريق ابن ثور- في قوله تعالى: <q>﴿يبايعونك تحت الشجرة﴾</q>، قال: سَمُرة كانت بالحُدَيبية، فكانت هذه الشجرة يُعرَف موضعها، ويؤتى هذا المسجد، حتى كان عمر بن الخطاب ﵁، فبلغه أنّ الناس يأتونها ويُصلّون عندها فيما هُنالِك ويُعَظِّمونها، فرأى أنّ ذلك مِن فعلهم حَدَثٌ{18}. (ز) ٧١٢٥٩- قال سفيان بن عيينة -من طريق ابن أبي عمر- قال:.... هي بيعة الرضوان. ثم قرأ: <q>﴿لقد رضي الله عن المؤمنين إذ يبايعونك تحت الشجرة﴾</q> الآية{19}. (ز) <q>﴿إِذۡ یُبَایِعُونَكَ تَحۡتَ ٱلشَّجَرَةِ﴾</q> - آثار متعلقة بالآية ٧١٢٦٠- عن أُمّ مُبَشِّر، عن النبيّ ﷺ، قال: «لا يدخل النارَ أحدٌ مِمَّن بايع تحت الشجرة»{20}. (١٣/٤٨٣) ٧١٢٦١- عن أبي أُمامة الباهلي، قال: لَمّا نزلت: <q>﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ إذْ يُبايِعُونَكَ تَحْتَ الشَّجَرَةِ﴾</q> قلتُ: يا رسول الله، أنا مِمَّن بايعك تحت الشجرة. قال: «يا أبا أُمامة، أنت مِنِّي، وأنا منك»{21}. (١٣/٤٨٥) ٧١٢٦٢- عن عامر الشعبي، قال: لَمّا دعا النبيُّ ﷺ الناسَ إلى البيعة، كان أول مَن انتهى إليه أبو سنان الأسدي، فقال: ابسطْ يدَك أبايعْك. فقال النبيُّ ﷺ: «علامَ تبايعني؟». قال: على ما في نفسك{22}. (١٣/٤٨٢) ٧١٢٦٣- عن نافع، قال: بلغ عمرَ بن الخطاب أنّ ناسًا يأتون الشجرة التي بُويع تحتها، فأمر بها، فقُطِعَت{23}. (١٣/٤٨٠) ٧١٢٦٤- عن طارق بن عبد الرحمن، قال: انطلقتُ حاجًّا، فمررتُ بقومٍ يُصَلُّون، فقلت: ما هذا المسجد؟ قالوا: هذه الشجرة، حيث بايع رسولُ الله ﷺ بيعة الرضوان. فأتيتُ سعيد بن المسيّب، فأخبرته، فقال سعيد: حدّثني أبي: أنه كان فيمن بايع رسول الله ﷺ تحت الشجرة، فلما خرجنا من العام المقبل نسيناها، فلم نقدر عليها. فقال سعيد: إنّ أصحاب محمد ﷺ لم يعلموها وعلمتموها أنتم، فأنتم أعلم؟!{24}. (١٣/٤٧٩) <q>﴿فَعَلِمَ مَا فِی قُلُوبِهِمۡ﴾</q> - تفسير ٧١٢٦٥- قال مقاتل بن سليمان: <q>﴿فَعَلِمَ ما فِي قُلُوبِهِمْ﴾</q> مِن الكراهية للبيعة على أن يُقاتلوا ولا يَفرّوا في أمر البيعة{17}٦٠٥٩. (ز) ٦٠٥٩ أفاد أثر مقاتل أن معنى: <q>﴿فَعَلِمَ ما فِي قُلُوبِهِمْ﴾</q>: من كراهية البيعة على القتال وعدم الفرار. وانتقده ابنُ عطية (٧/٦٧٩) فقال: «وهذا ضعيف؛ فيه مذمَّة للصحابة ﵃». وزاد ابنُ عطية قولين آخرين: الأول: «معناه: مِن الإيمان، وصحَّته، والحبِّ في الدين، والحرص عليه». ثم علَّق عليه بقوله: «وهذا قول حسن، لكنه مَن كانت هذه حاله فلا يحتاج إلى نزول ما يسكنه». غير أنّه ذكر له وجْهًا يمكن أن يُحمَل عليه، فقال: «أما إنه يحتمل أن يجازى بالسَّكِينة والفتح القريب والمغانم». الثاني: «معناه: مِن الهمِّ بالانصراف عن المشركين، والأنفة في ذلك على نحو ما خاطب فيه عمر ﵄ وغيره». ثم علَّق عليه بقوله: «وهذا تأويل حسن، يترتب معه نزول السَّكينة والتعويض بالفتح القريب». وذكر ابنُ القيم (٢/٤٥٨) أن المعنى: «علم الله ﷿ ما في قلوبهم من القلق والاضطراب لَمّا منعهم كفارُ قريش من دخول بيت الله، وحبسوا الهَدي عن محلِّه، واشترطوا عليهم تلك الشروط الجائرة الظالمة، فاضطربت قلوبهم، وقلقت، ولم تُطق الصبر، فعلم تعالى ما فيها، فثبّتها بالسكينة رحمة منه ورأفة ولطفًا، وهو اللطيف الخبير». ثم ذكر أن الآية تحتمل «أنه سبحانه علم ما في قلوبهم من الإيمان والخير ومحبته ومحبة رسوله، فثبّتها بالسكينة وقت قلقها واضطرابها». ثم رجَّح -مستندًا إلى العموم- قائلًا: «والظاهر أن الآية تعُمُّ الأمرين، وهو أنه علم ما في قلوبهم مما يحتاجون معه إلى إنزال السكينة وما في قلوبهم مِن الخير الذي هو سبب إنزالها». <q>﴿فَأَنزَلَ ٱلسَّكِینَةَ عَلَیۡهِمۡ﴾</q> - تفسير ٧١٢٦٦- عن عبد الله بن عباس، في قوله: <q>﴿فَعَلِمَ ما فِي قُلُوبِهِمْ فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</q>، قال: إنما أُنزِلَت السَّكينة على مَن عُلِم منه الوفاء{26}. (١٣/٤٨٣) ٧١٢٦٧- قال الحسن البصري: <q>﴿فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</q>، السَّكينة: الوقار{27}. (ز) ٧١٢٦٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَأَنْزَلَ السَّكِينَةَ عَلَيْهِمْ﴾</q>، قال: الوقار، والصبر{28}. (١٣/٤٨٤) <q>﴿وَأَثَـٰبَهُمۡ فَتۡحࣰا قَرِیبࣰا ۝١٨﴾</q> - تفسير ٧١٢٦٩- عن عبد الله بن عباس، قال: ... ثم ذكر البيعة، فقال: <q>﴿لَقَدْ رَضِيَ اللَّهُ عَنِ المُؤْمِنِينَ﴾</q> إلى قوله: <q>﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</q> لفتح الحُدَيبية{29}. (١٣/٤٨٤) ٧١٢٧٠- عن عبد الرحمن بن أبي ليلى -من طريق الحكم- في قوله: <q>﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</q>، قال: خَيْبَر{30}. (١٣/٤٨٣) ٧١٢٧١- قال معمر، في قوله: <q>﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</q>: إنّ مِقْسَمًا= (ز) ٧١٢٧٢- أو قتادة، أو كلاهما قالا: هو خَيْبَر{31}. (ز) ٧١٢٧٣- عن عكرمة مولى ابن عباس، <q>﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</q>، قال: خَيْبَر، حيث رجعوا من صُلح الحُدَيبية{32}. (١٣/٤٨٥) ٧١٢٧٤- عن عامر الشعبي، <q>﴿وأَثابَهُمْ فَتْحًا قَرِيبًا﴾</q>، قال: فتْح خَيْبَر{33}. (١٣/٤٨٥) ٧١٢٧٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأثابهم فتحا قريبا﴾</q>: وهي خيبر{34}. (ز) ٧١٢٧٦- قال مقاتل بن سليمان: <q>﴿وأَثابَهُمْ﴾</q> يعني: وأعطاهم <q>﴿فَتْحًا قَرِيبًا﴾</q> يعني: مغانم خَيْبَر{17}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة في مصنفه ٦/٣٦٢ (٣٢٠٤٦)، ٧/٣٨٦ (٣٦٨٥٢)، والطبراني في الكبير ١/٩٠ (١٤٤)، وابن جرير ٢١/٢٧٣-٢٧٤ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٤٠-. قال الهيثمي في المجمع ٩/٨٤ (١٤٥١٧): «رواه الطبراني، وفيه موسى بن عبيدة، وهو ضعيف».أخرجه الترمذي ٦/٢٧٦ (٤٠٣٥). قال الترمذي: «هذا حديث حسن صحيح غريب».أخرجه البيهقي ٤/١٣٢.أخرجه ابن جرير ٢١/٢٧٢.أخرجه ابن جرير ٢١/٢٧٣.أخرجه ابن جرير ٢١/٢٧٢.أخرجه البيهقي ٤/٩٨.أخرجه ابن جرير ٢١/٢٧٧. وعزاه السيوطي إلى ابن مردويه.أخرجه البخاري ٥/١٢٣ (٤١٥٤)، ومسلم ٣/١٤٨٤ (١٨٥٦).أخرجه البخاري ٥/١٢٣ (٤١٥٣). وعزاه السيوطي إلى ابن مردويه.أخرجه مسلم (١٨٥٧)، وابن جرير ٢١/٢٧٧، وإسحاق البستي ص٣٧١، وابن مردويه -كما في فتح الباري ٧/٤٤٤-. وعلقه البخاري (٤١٥٥).أخرجه مسلم (١٨٥٨). وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.أخرجه البخاري (٤١٦٩).أخرجه ابن جرير ٢١/٢٧٥-٢٧٦، ومسلم (١٨٥٦). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٢١٣ مختصرًا من طريق معمر، وكذا ابن جرير ٢١/٢٧٧ من طريق سعيد.أخرجه ابن جرير ٢١/٢٧٥. وينظر: تفسير الثعلبي ٩/٤٧، وتفسير البغوي ٦/٣٠٤.تفسير مقاتل بن سليمان ٤/٧٣.أخرجه الفاكهي في أخبار مكة ٥/٧٧ (٢٨٧٥).أخرجه الفاكهي في أخبار مكة ٥/٧٦ (٢٨٧١)، وإسحاق البستي ص٣٧١.أخرجه مسلم ٤/١٩٤٢ (٢٤٦٩)، وابن جرير ١٥/٦٠١ بنحوه.أخرجه ابن عساكر في تاريخه ٢٤/٦١، من طريق خيثمة بن سليمان، نا علي بن الحسن بن معروف السلمي بحمص، نا وهب بن صدقة، عن يوسف بن حزن الباهلي، قال: سمعت أبا أمامة به. وهب بن صدقة، ويوسف بن حزن الباهلي، لم أجد من ترجم لهما، فضلًا عن توثيقهما.أخرجه إسحاق البستي ص٣٧١، والبيهقي ٤/١٣٧.أخرجه ابن أبي شيبة ٢/٣٧٥.أخرجه البخاري (٤١٦٣). وعزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٧٣.عزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٤-.أخرجه ابن جرير ٢١/٢٧٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن مردويه. وتقدم بتمامه في إجمال تفسير السورة.أخرجه ابن جرير ٢١/٢٧٨، والبيهقي ٤/١٦٣. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٢٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢١/٢٧٨.تفسير مقاتل بن سليمان ٤/٧٣.
48,19," <q>﴿وَمَغَانِمَ كَثِیرَةࣰ یَأۡخُذُونَهَاۗ وَكَانَ ٱللَّهُ عَزِیزًا حَكِیمࣰا ۝١٩﴾</q> - تفسير ٧١٢٧٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأَثابَهُمْ فَتْحًا قَرِيبًا ومَغانِمَ كَثِيرَةً﴾</q>، قال: هي مغانم خَيْبَر، وكانت عقارًا ومالًا، فقَسمها نبيُّ الله صلي الله عليه وسلم بين أصحابه{1}. (١٣/٤٨٤) ٧١٢٧٨- قال مقاتل بن سليمان: <q>﴿ومَغانِمَ كَثِيرَةً يَأْخُذُونَها وكانَ اللَّهُ عَزِيزًا﴾</q> يعني: منيعًا، <q>﴿حَكِيمًا﴾</q> في أمْره، فحكم على أهل خَيْبَر القتْل والسبي{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ٢١/٢٧٧-٢٧٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٧٣.
48,20," <q>﴿وَعَدَكُمُ ٱللَّهُ مَغَانِمَ كَثِیرَةࣰ تَأۡخُذُونَهَا فَعَجَّلَ لَكُمۡ هَـٰذِهِۦ وَكَفَّ أَیۡدِیَ ٱلنَّاسِ عَنكُمۡ وَلِتَكُونَ ءَایَةࣰ لِّلۡمُؤۡمِنِینَ وَیَهۡدِیَكُمۡ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝٢٠﴾</q> - نزول الآية ٧١٢٧٩- عن محمد بن شهاب الزُّهريّ -من طريق معمر- قال: لَمّا انصرف رسولُ الله ﷺ حتى أتى المدينة فغزا خيبر مِن الحُدَيبية؛ فأنزل الله عليه: <q>﴿وعدكم الله مغانم كثيرة تأخذونها فعجل لكم هذه﴾</q> إلى <q>﴿ويهديكم صراطا مستقيما﴾</q>. فلما فتحت خيبر جعلها لِمَن غزا معه الحُدَيبية وبايع تحت الشجرة مِمَّن كان غائبًا وشاهدًا، مِن أجل أنّ الله كان وعدهم إيّاها، وخمَّس رسول الله ﷺ خيبر، ثم قسم سائرها مغانم بين مَن شهدها من المسلمين، ومَن غاب عنها مِن أهل الحُدَيبية{1}. (١٣/٤٨٣) <q>﴿وَعَدَكُمُ ٱللَّهُ مَغَانِمَ كَثِیرَةࣰ تَأۡخُذُونَهَا فَعَجَّلَ لَكُمۡ هَـٰذِهِۦ وَكَفَّ أَیۡدِیَ ٱلنَّاسِ عَنكُمۡ وَلِتَكُونَ ءَایَةࣰ لِّلۡمُؤۡمِنِینَ وَیَهۡدِیَكُمۡ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝٢٠﴾</q> - تفسير الآية ٧١٢٨٠- عن علي بن أبي طالب -من طريق عطية، عن أصحاب علي-= (ز) ٧١٢٨١- وعبد الله بن عباس -من طريق الضَّحّاك- قالا في قوله تعالى: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً﴾</q>: فتوحٌ من لَدُنْ خَيْبَر <q>﴿تَأْخُذُونَها﴾</q> تَلُونها، وتَغْنمون ما فيها{2}. (١٣/٤٨٨) ٧١٢٨٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</q>، قال: المغانم الكثيرة التي وُعِدوا: ما يأخذون حتى اليوم{3}. (١٣/٤٨٥) ٧١٢٨٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</q>، قال: يوم خَيْبَر= (ز) ٧١٢٨٤- كان أبي [زيد بن أسلم] يقول ذلك{4}. (ز) ٧١٢٨٥- قال مقاتل بن سليمان: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</q> مع النبي ﷺ، ومِن بعده إلى يوم القيامة{5}٦٠٦٠. (ز) ٦٠٦٠ اختُلف في معنى: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها﴾</q> أيُّ المغانم هي؟ على قولين: الأول: هو كلّ مَغْنَم غَنِمه المسلمون. الثاني: هي مغانم خَيْبَر. وعلَّق ابنُ جرير (٢١/٢٨٠) على القول الأول بقوله: «وعلى هذا التأويل يَحْتَمِل الكلام أن يكون مرادًا بالمغانم الثانية: المغانمُ الأولى، ويكون معناه عند ذلك: فأثابهم فتحًا قريبًا ومغانمَ كثيرةً يأخذونها، وعدكم الله -أيُّها القوم- هذه المغانم التي تأخذونها، وأنتم إليها واصلون عِدَةً، فجعل لكم الفتح القريب من فتح خَيْبَر. ويَحْتَمِل أن تكون الثانية غير الأولى، وتكون الأولى من غنائم خَيْبَر، والغنائم الثانية التي وعَدَهموها من غنائم سائر أهل الشرك سواهم». ورجَّح (٢١/٢٨١) -مستندًا إلى الدلالة العقلية- أنها سائر المغانم التي غنموها بعد خَيْبَر، وعلَّل ذلك بقوله: «لأن الله أخبر أنه عجَّل لهم هذه التي أثابهم من مسيرهم الذي ساروه مع رسول الله ﷺ إلى مكة، ولِما عُلِم مِن صحة نيَّتهم في قتال أهلها؛ إذ بايعوا رسول الله ﷺ على أن لا يفرُّوا عنه، ولا شكّ أن التي عُجِّلَت لهم غير التي لم تُعَجَّل لهم». <q>﴿فَعَجَّلَ لَكُمۡ هَـٰذِهِۦ﴾</q> - تفسير ٧١٢٨٦- عن علي بن أبي طالب -من طريق عطية، عن أصحاب علي-= (ز) ٧١٢٨٧- وعبد الله بن عباس -من طريق الضَّحّاك- قالا في قوله تعالى: <q>﴿فَعَجَّلَ لَكُمْ﴾</q>: من ذلك خَيْبَر{2}. (١٣/٤٨٨) ٧١٢٨٨- عن عبد الله بن عباس: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</q>، يعني: الفتح{7}. (١٣/٤٨٥) ٧١٢٨٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</q>: يعني: الصلح{8}. (ز) ٧١٢٩٠- عن عبد الله بن عباس: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</q>، يعني: خَيْبَر{9}. (١٣/٤٨٥) ٧١٢٩١- عن مروان= (ز) ٧١٢٩٢- والمِسْوَر بن مَخْرَمَة، قالا: انصرف رسول الله ﷺ عام الحُدَيبية، فنزلت عليه سورة الفتح فيما بين مكة والمدينة، فأعطاه الله فيها خَيْبَر، <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</q> خَيْبَر، فقدم النبِيُّ ﷺ المدينةَ في ذي الحجة، فأقام بها حتى سار إلى خَيْبَر في المُحرّم، فنزل رسول الله ﷺ بالرّجيع -وادٍ بين غَطَفان وخَيْبَر-، فتخوّف أن تمدهم غَطَفان، فبات به حتى أصبح فغدا عليهم{10}. (١٣/٤٨٦) ٧١٢٩٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</q>، قال: عُجِّلت لهم خَيْبَر{4}. (١٣/٤٨٥) ٧١٢٩٤- عن عطية بن سعد العَوفيّ، <q>﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</q>، قال: فتْح خَيْبَر{12}. (١٣/٤٨٦) ٧١٢٩٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</q>، قال: خَيْبَر{13}. (١٣/٤٨٦) ٧١٢٩٦- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿فعجل لكم هذه﴾</q>، قال: يُقال: خَيْبَر. ويُقال أيضًا: فَدك{14}. (ز) ٧١٢٩٧- قال مقاتل بن سليمان: <q>﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</q> يعني: غنيمة خَيْبَر{5}٦٠٦١. (ز) ٦٠٦١ اختُلف في معنى: <q>﴿فَعَجَّلَ لَكُمْ هَذِهِ﴾</q> على قولين: الأول: أنها غنيمة خَيْبَر، والمؤخَّرَةُ سائرُ فتوح المسلمين بعد ذلك الوقت إلى قيام الساعة. الثاني: أنه الصلح الذي كان بيْن رسول الله ﷺ وبيْن قريش. ورجَّح ابنُ جرير (٢١/٢٨١) -مستندًا إلى دلالة الواقع- القول الأول، وهو قول مجاهد، وقتادة وما في معناه، وعلَّل ذلك بقوله: «وذلك أن المسلمين لم يَغْنَموا بعد الحُدَيبية غنيمة، ولم يفتحوا فتحًا أقربَ من بيعتهم رسول الله ﷺ بالحُدَيبية إليها، من فتح خَيْبَر وغنائمها». <q>﴿وَكَفَّ أَیۡدِیَ ٱلنَّاسِ عَنكُمۡ﴾</q> - تفسير ٧١٢٩٨- عن علي بن أبي طالب -من طريق عطية، عن أصحاب علي-= (ز) ٧١٢٩٩- وعبد الله بن عباس -من طريق الضَّحّاك- قالا في قوله تعالى: <q>﴿وكَفَّ أيْدِيَ النّاسِ﴾</q>: قريش <q>﴿عَنْكُمْ﴾</q> بالصلح يوم الحُدَيبية{2}. (١٣/٤٨٨) ٧١٣٠٠- عن عبد الله بن عباس: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q>، يعني: أهل مكة، أن يستحلّوا حرَم الله، أو يُستحل بكم وأنتم حُرم{9}. (١٣/٤٨٥-٤٨٦) ٧١٣٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q>، قال: عن بيْضتهم وعن عيالهم بالمدينة، حين ساروا عن المدينة إلى خَيْبَر، وكانت خيبر في ذلك الوجه{18}. (١٣/٤٨٦) ٧١٣٠٢- عن محمد بن السّائِب الكلبي: ألقى الله في قلوبهم الرّعب، فهربوا من تحت ليلتهم؛ فهو قوله: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q> إلى آخر الآية{19}. (ز) ٧١٣٠٣- قال مقاتل بن سليمان: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q> يعني: حلفاء أهل خَيْبَر أسد وغَطَفان جاءوا لينصروا أهل خَيْبَر، وذلك أنّ مالك بن عوف النصري، وعُيينة بن حِصن الفزاري، ومَن معهما من أسد وغَطَفان؛ جاءوا لينصروا أهل خَيْبَر، فقذف الله في قلوبهم الرُّعب، فانصرفوا عنهم، فذلك قوله: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q> يعني: أسد، وغَطَفان{20}. (ز) ٧١٣٠٤- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q>، قال: الحليفان أسد وغَطَفان، عليهم عُيينة بن حِصن، معه مالك بن عوف النّصري أبو النضر، وأهل خَيْبَر على بئر معونة، فألقى الله في قلوبهم الرُّعب، فانهزموا، ولم يلقَوا النبيَّ ﷺ{21}٦٠٦٢. (١٣/٤٨٦) ٦٠٦٢ اختُلف في قوله تعالى: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q> مَن هم الذين كُفَّت أيديهم عن المسلمين؟ على قولين: الأول: هم اليهود، كفَّ الله أيديهم عن عيال الذين ساروا من المدينة مع رسول الله ﷺ إلى مكة. الثاني: أنهم أسد وغَطَفان جاءوا لينصروا أهل خَيْبَر، فقذف الله في قلوبهم الرُّعب، فانصرفوا عنهم. ورجَّح ابنُ جرير (٢١/٢٨٢) -مستندًا إلى دلالة العقل- القول الأول، فقال معلِّلًا ترجيحه: «والذي قاله قتادة في ذلك عندي أشبه بتأويل الآية، وذلك أنّ كفَّ اللهِ أيديَ المشركين من أهل مكة عن أهل الحُدَيبية قد ذكره الله بعد هذه الآية في قوله: <q>﴿وهُوَ الَّذِي كَفَّ أيْدِيَهُمْ عَنْكُمْ وأَيْدِيَكُمْ عَنْهُمْ بِبَطْنِ مَكَّةَ﴾</q>، فعُلِم بذلك أن الكفَّ الذي ذكره الله تعالى في قوله: <q>﴿وكَفَّ أيْدِيَ النّاسِ عَنْكُمْ﴾</q> غير الكفّ الذي ذكر الله بعد هذه الآية في قوله: <q>﴿وهُوَ الَّذِي كَفَّ أيْدِيَهُمْ عَنْكُمْ وأَيْدِيَكُمْ عَنْهُمْ بِبَطْنِ مَكَّةَ﴾</q>». <q>﴿وَلِتَكُونَ ءَایَةࣰ لِّلۡمُؤۡمِنِینَ وَیَهۡدِیَكُمۡ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝٢٠﴾</q> - تفسير ٧١٣٠٥- عن علي بن أبي طالب -من طريق عطية، عن أصحاب علي-= (ز) ٧١٣٠٦- وعبد الله بن عباس -من طريق الضَّحّاك- قالا في قوله تعالى: <q>﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</q>: شاهدًا على ما بعدها، ودليلًا على إنجازها{2}. (١٣/٤٨٨) ٧١٣٠٧- عن عبد الله بن عباس، <q>﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</q>، قال: سُنّةً لِمَن بعدكم{9}. (١٣/٤٨٥) ٧١٣٠٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</q>، يقول: وذلك آية للمؤمنين، كفّ أيدي الناس عن عيالهم{24}٦٠٦٣. (ز) ٦٠٦٣ لم يذكر ابنُ جرير (٢١/٢٨٣) في معنى: <q>﴿ولِتَكُونَ آيَةً لِلْمُؤْمِنِينَ﴾</q> سوى قول قتادة. ٧١٣٠٩- قال مقاتل بن سليمان: <q>﴿ولِتَكُونَ﴾</q> يعني: ولكي تكون هزيمتهم مِن غير قتال <q>﴿آيَةً لِلْمُؤْمِنِينَ ويَهْدِيَكُمْ صِراطًا مُسْتَقِيمًا﴾</q> يعني: تزدادون بالإسلام تصديقًا؛ مِمّا ترون مِن عِدَة الله في القرآن من الفتح والغنيمة. كما قال نظيرها في المدثر [٣١]: <q>﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</q>، يعني: تصديقًا بمحمد ﷺ، وبما جاء به في خَزنة جهنم{20}. (ز) ",footnotes:1:أخرجه عبد الرزاق في مصنفه (٩٧٣٨)، وأبو داود في مراسيله ص١٦٥.أخرجه ابن عساكر ١/٣٩٧.أخرجه ابن جرير ٢١/٢٧٩.أخرجه ابن جرير ٢١/٢٨٠.تفسير مقاتل بن سليمان ٤/٧٣.أخرجه ابن عساكر ١/٣٩٧.عزاه السيوطي إلى ابن جرير، وابن مردويه.أخرجه ابن جرير ٢١/٢٨١.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي ٤/١٩٧. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢١/٢٨٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢١/٢٨١. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٠.تفسير مقاتل بن سليمان ٤/٧٣.أخرجه ابن عساكر ١/٣٩٧.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢١/٢٨٢، وأخرجه عبد الرزاق ٢/٢٢٧ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٥٥-.تفسير مقاتل بن سليمان ٤/٧٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ١/٣٩٧.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٢٢٧، وابن جرير ٢١/٢٨٤.تفسير مقاتل بن سليمان ٤/٧٤.
48,21," <q>﴿وَأُخۡرَىٰ لَمۡ تَقۡدِرُوا۟ عَلَیۡهَا﴾</q> - تفسير ٧١٣١٠- عن أبي الأسود الدُّؤلي: أنّ الزبير بن العوام لَمّا قدِم البصرة دخل بيت المال، فإذا هو بصفراء وبيضاء، فقال: يقول الله: <q>﴿وعَدَكُمُ اللَّهُ مَغانِمَ كَثِيرَةً تَأْخُذُونَها فَعَجَّلَ لَكُمْ هَذِهِ﴾</q> ... <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها قَدْ أحاطَ اللَّهُ بِها﴾</q>، فقال: هذا لنا{1}. (١٣/٤٨٧) ٧١٣١١- عن علي بن أبي طالب -من طريق عطية، عن أصحاب علي-= (ز) ٧١٣١٢- وعبد الله بن عباس -من طريق الضَّحّاك- قالا في قوله تعالى: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>: على عِلْمِ وقتها، أُفيئها عليكم؛ فارس والروم{2}. (١٣/٤٨٨) ٧١٣١٣- عن عبد الله بن عباس -من طريق شعبة، عن سِماك الحنفي- في قوله: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: هذه الفتوح التي تُفتَح إلى اليوم{3}. (١٣/٤٨٧) ٧١٣١٤- عن عبد الله بن عباس -من طريق سِماك- <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>: فارس، والروم{4}. (ز) ٧١٣١٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: هي خَيْبَر{5}. (١٣/٤٨٩) ٧١٣١٦- عن عبد الرحمن بن أبي ليلى -من طريق الحكم- <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: فارس، والروم{6}. (١٣/٤٨٨) ٧١٣١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>: ما فتحوا حتى اليوم{4}. (ز) ٧١٣١٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>: يعني: خَيْبَر، بعثهم رسول الله ﷺ يومئذ، فقال: «لا تُمَثِّلُوا، ولا تَغُلُّوا، ولا تَقْتلوا وليدًا»{8}. (ز) ٧١٣١٩- عن عكرمة مولى ابن عباس، <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: يوم حُنين{9}. (١٣/٤٨٩) ٧١٣٢٠- قال عكرمة مولى ابن عباس: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q> هي خَيْبَر{10}. (ز) ٧١٣٢١- عن الحسن البصري -من طريق قتادة- قال: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q> هي فارس، والروم{4}. (ز) ٧١٣٢٢- عن عطية بن سعد العَوفيّ، <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: فتْح فارس{9}. (١٣/٤٨٨) ٧١٣٢٣- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: بلَغَنا: أنّها مكة{13}. (١٣/٤٨٩) ٧١٣٢٤- عن جويبر، <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>، قال: يزعمون: أنها قرى عربية. ويزعم آخرون: أنها فارس، والروم{9}. (١٣/٤٨٨) ٧١٣٢٥- قال مقاتل بن سليمان: قوله: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q> يعني: [قرى] فارس والروم وغيرها{15}. (ز) ٧١٣٢٦- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>: يعني: أهل خَيْبَر{8}. (ز) ٧١٣٢٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها قَدْ أحاطَ اللَّهُ بِها﴾</q>، قال: خَيْبَر. قال: لم يكونوا يذكرونها، ولا يَرْجُونها، حتى أخبرهم الله بها{8}. (ز) ٧١٣٢٨- عن محمد بن عمر الواقدي، في قوله: <q>﴿وأخرى لم تقدروا عليها﴾</q>، قال: فارس والروم. ويُقال: مكة{18}٦٠٦٤. (ز) ٦٠٦٤ اختُلِف في البلدة التي وعدهم الله تعالى فَتْحَها في قوله: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q> على أقوال: الأول: أنها أرض فارس والروم، وما يفتحه المسلمون من البلاد إلى قيام الساعة. الثاني: أنها خَيْبَر. الثالث: أنها مكة. الرابع: يوم حُنين. ورجَّح ابنُ جرير (٢١/٢٨٦) -مستندًا إلى دلالة العقل- القول الثالث، وهو قول قتادة، وعلَّل ذلك بـ«أن الله أخبر هؤلاء الذين بايعوا رسول الله ﷺ تحت الشجرة أنه محيطٌ بقريةٍ لم يَقْدِروا عليها، ومعقولٌ أنه لا يُقال لقومٍ: لم يقدروا على هذه المدينة. إلا أن يكونوا قد رامُوها، فتَعَذَّرت عليهم، فأمّا وهم لم يروموها فتَتَعَذَّر عليهم فلا يُقال: إنهم لم يقدروا عليها. فإذ كان ذلك كذلك، وكان معلومًا أنّ رسول الله ﷺ لم يَقْصِد قبل نزول هذه الآية عليه خَيْبَر لحربٍ، ولا وجَّه إليها لقتال أهلها جيشًا ولا سريةً؛ عُلِم أن المعنيَّ بقوله: <q>﴿وأُخْرى لَمْ تَقْدِرُوا عَلَيْها﴾</q>: غيرها، وأنها هي التي قد عالجها ورامَها فتعذَّرت، فكانت مكة وأهلها كذلك». ورجَّحه ابنُ عطية (٧/٦٨١) قائلًا: «وهذا هو القول الذي يتَّسق معه المعنى ويتأيَّد». <q>﴿قَدۡ أَحَاطَ ٱللَّهُ بِهَاۚ وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣰا ۝٢١﴾</q> - تفسير الآية ٧١٣٢٩- عن علي بن أبي طالب -من طريق عطية، عن أصحاب علي-= (ز) ٧١٣٣٠- وعبد الله بن عباس -من طريق الضَّحّاك- قالا في قوله تعالى: <q>﴿قَدْ أحاطَ اللَّهُ بِها﴾</q>: قضى الله بها أنها لكم{2}. (١٣/٤٨٨) ٧١٣٣١- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- في قوله: <q>﴿قَدْ أحاطَ اللَّهُ بِها﴾</q>: أنها ستكون لكم، بمنزلة قوله: أحاط الله بها علمًا أنها لكم{20}. (١٣/٤٨٧) ٧١٣٣٢- قال مقاتل بن سليمان: <q>﴿قَدْ أحاطَ اللَّهُ﴾</q> علمه <q>﴿بِها﴾</q> أن يفتحها على يدي المؤمنين، <q>﴿وكانَ اللَّهُ عَلى كُلِّ شَيْءٍ﴾</q> مِن القرى <q>﴿قَدِيرًا﴾</q> على فتْحها{15}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ١٥/٢٨٠.أخرجه ابن عساكر ١/٣٩٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه. وأخرجه إسحاق البستي ص٣٧٣ بلفظ: ما أصبتم من هذه الفتوح، والبيهقي في الدلائل ٤/١٦٣ بلفظ: هو ما أصبتم بعده.أخرجه ابن جرير ٢١/٢٨٤.أخرجه ابن جرير ٢١/٢٨٥. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢١/٢٨٤، والبيهقي ٤/١٦. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢١/٢٨٤.أخرجه ابن جرير ٢١/٢٨٥.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٥٣. وذُكر في طبعة دار التفسير ٢٤/٢٧٤ أنها في نسخة: حنين. وقد أثبتوا ذلك في المتن.أخرجه ابن جرير ٢١/٢٨٤.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٢٧، وابن جرير ٢١/٢٨٦، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٧٤.أخرجه ابن جرير ٢١/٢٨٥.أخرجه ابن جرير ٢١/٢٨٥.أخرجه ابن عساكر في تاريخ دمشق ١/٣٩٨.أخرجه ابن عساكر ١/٣٩٧.أخرجه البيهقي ٤/١٦٣.تفسير مقاتل بن سليمان ٤/٧٤.
48,22," <q>﴿وَلَوۡ قَـٰتَلَكُمُ ٱلَّذِینَ كَفَرُوا۟ لَوَلَّوُا۟ ٱلۡأَدۡبَـٰرَ ثُمَّ لَا یَجِدُونَ وَلِیࣰّا وَلَا نَصِیرࣰا ۝٢٢﴾</q> - تفسير ٧١٣٣٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولَوْ قاتَلَكُمُ الَّذِينَ كَفَرُوا لَوَلَّوُا الأَدْبارَ﴾</q>: يعني: أهل مكة{1}٦٠٦٥. (١٣/٤٨٩) ٦٠٦٥ ذكر ابنُ عطية (٧/٦٨١) قول قتادة، ثم علَّق عليه بقوله: «وفي هذا تقويةٌ لنفوس المؤمنين». ثم نقل عن بعض المفسّرين أن المراد بهم: الروم وفارس، ثم انتقدهم قائلًا: «وهذا ضعيف، وإنما الإشارة إلى العدوِّ الأحضر». ٧١٣٣٤- قال مقاتل بن سليمان: قال: <q>﴿ولَوْ قاتَلَكُمُ الَّذِينَ كَفَرُوا لَوَلَّوُا الأَدْبارَ﴾</q> منهزمين، <q>﴿ثُمَّ لا يَجِدُونَ ولِيًّا ولا نَصِيرًا﴾</q> يعني: ولا مانِعًا يمنعهم من الهزيمة{2}. (ز) ٧١٣٣٥- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ولَوْ قاتَلَكُمُ الَّذِينَ كَفَرُوا﴾</q> هم أسد وغَطَفان، <q>﴿لَوَلَّوُا الأَدْبارَ﴾</q> حتى <q>﴿ولَنْ{3} تَجِدَ لِسُنَّةِ اللَّهِ تَبْدِيلًا﴾</q>{4}. (١٣/٤٨٦) ",footnotes:1:أخرجه ابن جرير ٢١/٢٨٧ بلفظ: كفار قريش. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٧٤-٧٥.ذكر محققو الدر أنه في نسخه: لا.عزاه السيوطي إلى ابن المنذر.
48,23," <q>﴿سُنَّةَ ٱللَّهِ ٱلَّتِی قَدۡ خَلَتۡ مِن قَبۡلُۖ وَلَن تَجِدَ لِسُنَّةِ ٱللَّهِ تَبۡدِیلࣰا ۝٢٣﴾</q> - تفسير ٧١٣٣٦- قال مقاتل بن سليمان: يقول: كذلك كان <q>﴿سُنَّةَ اللَّهِ الَّتِي قَدْ خَلَتْ مِن قَبْلُ﴾</q> كفار مكة حين هُزموا ببدر، فهؤلاء بمنزلتهم، <q>﴿ولَنْ تَجِدَ لِسُنَّةِ اللَّهِ تَبْدِيلًا﴾</q> يعني: تحويلًا{1}. (ز) ٧١٣٣٧- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ولَنْ تَجِدَ لِسُنَّةِ اللَّهِ تَبْدِيلًا﴾</q>، يقول: سُنَّة الله في الذين خَلَوا من قبل أن لن يُقاتِل أحدٌ نبيَّه إلا خذله الله؛ فقتله أو رَعَّبه فانهزم، ولن يسمع به عدوٌّ إلا انهزموا واستسلموا{2}. (١٣/٤٨٦) ٧١٣٣٨- عن محمد بن إسحاق -من طريق وهب عن أبيه- قوله: <q>﴿سنه الله التي قد خلت من قبل﴾</q> يعني: قريشًا في المواطن التي كانت قبل ذلك، <q>﴿ولن تجد لسنة الله تبديلا﴾</q> يقول: الذي وعد من النصر{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٧٤-٧٥.عزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي ص٣٧٣.
