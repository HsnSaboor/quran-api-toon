17,94," <q>﴿وَمَا مَنَعَ ٱلنَّاسَ أَن یُؤۡمِنُوۤا۟ إِذۡ جَاۤءَهُمُ ٱلۡهُدَىٰۤ إِلَّاۤ أَن قَالُوۤا۟ أَبَعَثَ ٱللَّهُ بَشَرࣰا رَّسُولࣰا ۝٩٤ قُل لَّوۡ كَانَ فِی ٱلۡأَرۡضِ مَلَـٰۤىِٕكَةࣱ یَمۡشُونَ مُطۡمَىِٕنِّینَ لَنَزَّلۡنَا عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ مَلَكࣰا رَّسُولࣰا ۝٩٥﴾</q> - نزول الآية ٤٤٠١٢- قال مقاتل بن سليمان: نزلت في المستهزئين، والمطعمين ببدر{1}. (ز) <q>﴿وَمَا مَنَعَ ٱلنَّاسَ﴾</q> - تفسير ٤٤٠١٣- قال مقاتل بن سليمان: <q>﴿وما منع الناس﴾</q>، يعني: رؤوس كفار مكة{1}. (ز) ٤٤٠١٤- قال يحيى بن سلّام: قوله: <q>﴿وما منع الناس﴾</q>، يعني: المشركين{3}. (ز) <q>﴿أَن یُؤۡمِنُوۤا۟ إِذۡ جَاۤءَهُمُ ٱلۡهُدَىٰۤ إِلَّاۤ أَن قَالُوۤا۟ أَبَعَثَ ٱللَّهُ بَشَرࣰا رَّسُولࣰا ۝٩٤﴾</q> - تفسير ٤٤٠١٥- قال مقاتل بن سليمان: <q>﴿أن يؤمنوا﴾</q> يعني: أن يُصَدِّقوا بالقرآن <q>﴿إذ جاءهم الهدى﴾</q> يعني: البيان، وهو القرآن؛ لأنّ القرآن هُدًى مِن الضلالة، <q>﴿إلا أن قالوا أبعث الله بشرا رسولا﴾</q>{1}. (ز) ٤٤٠١٦- قال يحيى بن سلّام: قوله: <q>﴿أن يؤمنوا إذ جاءهم الهدى إلا أن قالوا أبعث الله بشرا رسولا﴾</q>، على الاستفهام، وهذا الاستفهام على إنكار منهم، أي: لم يبعث الله بشرًا رسولًا؛ فلو كان من الملائكة لآمنّا به{3}. (ز) <q>﴿قُل لَّوۡ كَانَ فِی ٱلۡأَرۡضِ مَلَـٰۤىِٕكَةࣱ یَمۡشُونَ مُطۡمَىِٕنِّینَ لَنَزَّلۡنَا عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ مَلَكࣰا رَّسُولࣰا ۝٩٥﴾</q> - تفسير ٤٤٠١٧- قال مقاتل بن سليمان: <q>﴿قل لو كان في الأرض ملائكة يمشون مطمئنين﴾</q> يعني: مقيمين بها، مثل قوله سبحانه في النساء [١٠٣]: <q>﴿فإذا اطمأننتم﴾</q> يقول: فإذا أقمتم <q>﴿فأقيموا الصلاة﴾</q>، <q>﴿لنزلنا عليهم من السماء ملكا رسولا﴾</q>{1}. (ز) ٤٤٠١٨- قال يحيى بن سلّام: قال الله لنبيه: <q>﴿قل لو كان﴾</q> معه <q>﴿في الأرض ملائكة يمشون مطمئنين﴾</q> قد اطمأنت بهم الدار، أي: هي مسكنهم؛ <q>﴿لنزلنا عليهم من السماء ملكا رسولا﴾</q> ولكن فيها بشر، فأرسلنا إليهم بشرًا مثلهم{7}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير يحيى بن سلام ١/١٦٣.تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير يحيى بن سلام ١/١٦٣.تفسير مقاتل بن سليمان ٢/٥٥٠-٥٥١.تفسير يحيى بن سلام ١/١٦٤.
  17,95,""
17,96," <q>﴿قُلۡ كَفَىٰ بِٱللَّهِ شَهِیدَۢا بَیۡنِی وَبَیۡنَكُمۡۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِیرَۢا بَصِیرࣰا ۝٩٦﴾</q> - تفسير ٤٤٠١٩- قال مقاتل بن سليمان: <q>﴿قُل كفى بِالله شهيدًا بيني وبينكم﴾</q> يقول: فلا أحد أفضل من الله شاهدًا بأنِّي رسول الله إليكم، <q>﴿إنه كان بعباده خبيرا بصيرا﴾</q> حين اختصَّ محمدًا ﷺ بالرسالة{1}. (ز) ٤٤٠٢٠- قال يحيى بن سلّام: <q>﴿قل كفى بالله شهيدا بيني وبينكم﴾</q> أني رسوله، <q>﴿إنه كان بعباده خبيرا بصيرا﴾</q>{2}٣٩٢٨. (ز) ٣٩٢٨ قال ابنُ عطية (٥/٥٤٦): «معنى أقوالهم: إنما هو طلب شهادة دون أن يذكروها، ففي ذلك نزلت الآية، أي: الله يشهد بيني وبينكم، الذي له الخبر والبصر بجميعنا، صادقنا وكاذبنا». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٥١.تفسير يحيى بن سلام ١/١٦٤.
