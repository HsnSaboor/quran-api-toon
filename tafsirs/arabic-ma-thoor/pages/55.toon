quran[8]{c,v,t}:
  3,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُنَالِكَ دَعَا زَكَرِیَّا رَبَّهُۥۖ قَالَ رَبِّ هَبۡ لِی مِن لَّدُنكَ ذُرِّیَّةࣰ طَیِّبَةًۖ إِنَّكَ سَمِیعُ ٱلدُّعَاۤءِ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٦٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: كفلها زكريا، فدخل عليها المحرابَ، فوجد عندها عنبًا في مِكْتلٍ في غير حينه، <span class="qpc-hafs">﴿أنى لك هذا قالت هو من عند الله إن الله يرزق من يشاء بغير حساب﴾</span>. قال: إنّ الذي يرزقك العنب في غير حينه لَقادِرٌ أن يرزقني مِن العاقر الكبير العقيمِ ولدًا. <span class="qpc-hafs">﴿هنالك دعا زكريا ربه﴾</span>، فلما بُشِّرَ بيحيى قال: <span class="qpc-hafs">﴿رب اجعل لي آية قال آيتك ألا تكلم الناس﴾</span>. قال: يُعْتَقَلُ لسانُك مِن غير مرضٍ وأنت سَوِيٌّ{1}. (٣/٥٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا رأى ذلك زكريا -يعني: فاكهة الصيف في الشتاء، وفاكهة الشتاء في الصيف عند مريم- قال: إنّ الذي يأتي بهذا مريمَ في غير زمانه قادرٌ أن يرزقني ولدًا. فذلك حين دعا ربَّه{2}. (٣/٥٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩١<span class="dash">-</span></span> عن <span class="name-2">نَوف البِكالِي</span> -من طريق أبي عمران- في قول الله ﷿: <span class="qpc-hafs">﴿وكفلها زكريا﴾</span>، قال: كان يزورها، وكانت فتاة تنزل في بيت قومها، فكانت تُقَدَّم إليها فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، فقال: <span class="qpc-hafs">﴿أنى لك هذا قالت هو من عند الله إن الله يرزق من يشاء بغير حساب﴾</span>. فهنالك دعا زكريّا ربّه أن يهب له غلامًا، فوهب له يحيى، ولم يُسمَّ يحيى قبله، قال: <span class="qpc-hafs">﴿أنى يكون لي غلام وكانت امرأتي عاقرًا وقد بلغت من الكبر عتيًّا﴾</span> ...{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: لَمّا وجد زكريّا عند مريم ثَمَرَ الشتاء في الصيف، وثمر الصيف في الشتاء، يأتيها به جبريل؛ قال لها: أنّى لك هذا في غير حينه؟ فقالت: هذا رزق من عند الله يأتيني، إن الله يرزق من يشاء بغير حساب. فطمع زكريّا في الولد، فقال: إنّ الذي أتى مريمَ بهذه الفاكهة في غير حينها لَقادِرٌ أن يُصْلِح لي زوجتي، ويَهَبَ لي منها ولدًا. فعند ذلك <span class="qpc-hafs">﴿دعا زكريا ربه﴾</span>، وذلك لثلاث ليال بَقِين من الـمُحَرَّم، قام زكريا فاغتسل، ثم ابتهل في الدعاء إلى الله، قال: يا رازقَ مريمَ ثمار الصيف في الشتاء، وثمار الشتاء في الصيف، <span class="qpc-hafs">﴿هب لي من لدنك﴾</span> يعني: من عندك <span class="qpc-hafs">﴿ذرية طيبة﴾</span> يعني: تَقِيًّا{4}. (٣/٥٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجد عندها رزقا﴾</span> الآية، قال: فعجِب من ذلك زكريا، قال الله ﷿: <span class="qpc-hafs">﴿هنالك دعا زكريّا ربّه قال ربّ هب لي من لدنك ذرّيّة طيّبة﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: فلمّا رأى زكريا من حالها ذلك -يعني: فاكهة الصيف في الشتاء، وفاكهة الشتاء في الصيف- قال: إنّ ربًّا أعطاها هذا في غير حينه لَقادِرٌ على أن يرزقني ذُرِّيَّةً طيِّبةً. ورَغِب في الولد، فقام فصلّى، ثم دعا ربَّه سِرًّا فقال: <span class="qpc-hafs">﴿رب إني وهن العظم مني واشتعل الرأس شيبًا ولم أكن بدعائك رب شقيًّا وإني خفت الموالي من ورائي وكانت امرأتي عاقرًا فهب لي من لدنك وليًّا يرثني ويرث من آل يعقوب واجعله رب رضيًّا﴾</span> [مريم:٤-٦]. وقال: <span class="qpc-hafs">﴿رب هب لي من لدنك ذرية طيبة إنك سميع الدعاء﴾</span>. وقال: <span class="qpc-hafs">﴿رب لا تذرني فردًا وأنت خير الوارثين﴾</span> [الأنبياء:٨٩]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ذرية طيبة﴾</span>، يقول: مُبارَكة{7}. (٣/٥٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكَلْبِيِّ</span>: وكانت امرأةُ زكريا عاقِرًا قد دَخَلَتْ في السِّنِّ، وزكريا شيخٌ كبير، فاستجاب الله له{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٦٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فطمع عند ذلك زكريا في الولد، فقال: إن الذي يأتي مريم بهذه الفاكهة في غير حينها لَقادِرٌ أن يُصْلِح لي زوجتي، ويهب لي منها ولدًا. فذلك قوله: <span class="qpc-hafs">﴿هنالك﴾</span> يعني: عند ذلك <span class="qpc-hafs">﴿دعا زكريّا ربه قال رب هب لي من لدنك﴾</span> يعني: مِن عندك <span class="qpc-hafs">﴿ذرية طيبة﴾</span> تقيًّا زكيًّا، كقوله: <span class="qpc-hafs">﴿واجعله ربّ رضيّا﴾</span> [مريم:٦]، <span class="qpc-hafs">﴿إنك سميع الدعاء﴾</span>. فاستجاب الله ﷿، وكانا قد دَخَلا في السِّنِّ{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٣٥١، ٣٥٣، وابن المنذر ١/١٨١-١٨٢، وابن أبي حاتم ٢/٦٤٠، والحاكم ٢/٢٩١ واللفظ له.أخرجه ابن جرير ٥/٣٦١.أخرجه ابن عساكر في تاريخ دمشق ٧٠/٨٥.أخرجه ابن عساكر في تاريخ دمشق ٧٠/٨٤.أخرجه ابن المنذر ١/١٨٤.أخرجه ابن جرير ٥/٣٦٠، وابن المنذر ١/١٨٤ بنحوه، وابن أبي حاتم ٢/٦٤١ مختصرًا.أخرجه ابن جرير ٥/٣٦٢، وابن أبي حاتم ٢/٦٤١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٧-.تفسير مقاتل بن سليمان ١/٢٧٣.
  3,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَنَادَتۡهُ ٱلۡمَلَـٰۤىِٕكَةُ وَهُوَ قَاۤىِٕمࣱ یُصَلِّی فِی ٱلۡمِحۡرَابِ أَنَّ ٱللَّهَ یُبَشِّرُكَ بِیَحۡیَىٰ مُصَدِّقَۢا بِكَلِمَةࣲ مِّنَ ٱللَّهِ وَسَیِّدࣰا وَحَصُورࣰا وَنَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝٣٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٢٦٩٨<span class="dash">-</span></span> عن عبد الله بن مسعود، أنّ النبي ﷺ قرأ: <span class="qpc-hafs">﴿فَناداهُ الملائكة﴾</span> بالياء{1}<span class=comment-ref>١١٧٥</span>. (٣/٥٢٧)</p></p><p></div></p><p><div><span class=comment-ref>١١٧٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٥/٣٦٤ بتصرف) هذه القراءة بقوله: «وقد قرأ ذلك جماعةٌ مِن أهل الكوفة بالياء، بمعنى: فناداه جبريل، فذكَّرُوه للتأويل؛ لأنّهم يُؤَنِّثُون فعل الذَّكَرِ لِلَّفْظِ، فكذلك يُذَكِّرون فعل المؤنث أيضًا لِلَّفظ. واعتبروا ذلك فيما أرى <span class="mustanad">بقراءة يُذْكَرُ أنّها قراءة عبد الله بن مسعود</span>».</div></p><p><div></p><p><p><span class="item-no">١٢٦٩٩<span class="dash">-</span></span> عن عبد الرحمن بن أبي حمّاد، قال: في قراءة <span class="name-1">عبد الله بن مسعود</span>: (فَناداهُ جِبْرِيلُ وهُوَ قَآئِمٌ يُصَلِّي فِي المِحْرابِ){2}. (٣/٥٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- قال: ذَكِّرُوا الملائكةَ. ثُمَّ تلا: <span class="qpc-hafs">﴿إن الذين لا يؤمنون بالآخرة ليسمون الملائكة تسمية الأنثى﴾</span> [النجم:٢٧]. وكان يَقْرَأُها: ›فَناداهُ المَلَآئِكَةُ‹{3}. (٣/٥٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم-: أنّه كان يُذَكِّرُ الملائكةَ في القرآن{4}. (٣/٥٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٠٢<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span>، أنّه قرأ: <span class="qpc-hafs">﴿فنادته الملائكة﴾</span> بالتاء، <span class="qpc-hafs">﴿أن الله﴾</span> بنصب الألف، <span class="qpc-hafs">﴿يبشرك﴾</span> مُثَقَّلة{5}<span class=comment-ref>١١٧٦</span><span class=comment-ref>١١٧٧</span>. (٣/٥٢٧)</p></p><p></div></p><p><div><span class=comment-ref>١١٧٦</span> ذكر <u>ابنُ جرير</u> (٥/٣٦٣) أنّ المراد بهذه القراءة جمع الملائكة، ثُمَّ <span class="comment-type-1">وجَّهها</span> بقوله: «وكذلك تفعل العربُ في جماعة الذكور إذا تقدّمت أفعالها أُنِّثَت أفعالها، ولا سيّما الأسماء التي في ألفاظها التأنيث، كقولهم: جاءت الطلحات».</div></p><p><div><span class=comment-ref>١١٧٧</span> اختُلِف في قراءة <span class="qpc-hafs">﴿فناداه﴾</span> بين من قرأها بالتاء، وبين من قرأها بالياء.</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/٣٦٥ بتصرف) صوابَ كِلْتا القراءتين <span class="mustanad">مستنِدًا إلى اللغة،</span> فقال: «وإنّما الصوابُ مِن القول عندي في قراءة ذلك أنّهما قراءتان معروفتان، فبأيَّتهما قرأ القارئ فمصيب، وذلك أنّه لا اختلاف في معنى ذلك باختلاف القرائن، وهما جميعًا فصيحتان عند العرب، وذلك أنّ الملائكة إن كان مرادًا بها جبريل -كما رُوِي عن عبد الله- فإنّ التأنيث في فعلها فصيحٌ في كلام العرب للفظها إن تقدّمها الفعل، وجائز فيه التذكير لمعناها، وإن كان مرادًا بها جمع الملائكة فجائزٌ في فعلها التأنيث، وهو من قبلها للفظها، وذلك أنّ العرب إذا قدّمت على الكثير مِن الجماعة فِعلَها أنَّثته، فقالت: قالت النساء، وجائز التذكير في فعلها بناء على الواحد إذا تقدّم فعله، فيقال: قال الرجال».</div></p><p><h3><span class="qpc-hafs">﴿فَنَادَتۡهُ ٱلۡمَلَـٰۤىِٕكَةُ وَهُوَ قَاۤىِٕمࣱ یُصَلِّی فِی ٱلۡمِحۡرَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧٠٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي بكر- قال: فدخل المحراب، وغلَّق الأبواب، وناجى ربَّه، فقال: <span class="qpc-hafs">﴿ربّ إني وهن العظم مني واشتعل الرأس شيبًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿رب رضيًّا﴾</span> [مريم:٤-٦]. <span class="qpc-hafs">﴿فنادته الملائكة وهو قائم يصلي في المحراب أن الله يبشرك بيحيى مصدّقًا بكلمة من الله﴾</span>{6}<span class=comment-ref>١١٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٧٨</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/٣٦٥) هذا القول الذي قال به قتادة، والربيع، وعكرمة، ومجاهد <span class="mustanad">مستنِدًا إلى اللغة</span>، فقال: «وأمّا الصواب من القول في تأويله فأن يقال: إنّ الله -جل ثناؤه- أخبر أنّ الملائكة نادته، والظاهر من ذلك أنها جماعة من الملائكة دون الواحد، وجبريل واحد، فلن يجوز أن يحمل تأويل القرآن إلا على الأظهر الأكثر من الكلام المستعمل في ألسن العرب دون الأقلِّ ما وجد إلى ذلك سبيل، ولم يَضْطرنا حاجة إلى صرف ذلك إلى أنّه بمعنى واحد، فيُحْتاج له إلى طلب المخرج بالخفيِّ من الكلام والمعاني».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/٢٠٧) على هذا القول ذاكرًا ما <span class="mustanad">يستند إليه من النّظائر</span>، فقال: «وقال قوم: بل نادت ملائكةٌ كثيرةٌ حسبما تقتضيه ألفاظ الآية. وقد وجدنا الله تعالى بعث ملائكة إلى لوط، وإلى إبراهيم ﵇، وفي غير ما قصة».</div></p><p><div></p><p><p><span class="item-no">١٢٧٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فنادته الملائكة﴾</span>، قال: جبريل{7}<span class=comment-ref>١١٧٩</span>. (٣/٥٢٦)</p></p><p></div></p><p><div><span class=comment-ref>١١٧٩</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٥/٣٦٤ بتصرف) هذا القول الذي قال به السدي، ومقاتل، فقال: «فإن قال قائلٌ: وكيف جاز أن يُقال على هذا التأويل: <span class="qpc-hafs">﴿فنادته الملائكة﴾</span> والملائكة جمع لا واحد؟ قيل: ذلك جائز في كلام العرب بأن تُخْبِر عن الواحد بمَذْهب الجمع، كما يُقال في الكلام: خرج فلان على بِغال البُرُد، وإنّما ركب بَغْلًا واحدًا، ورَكِب السُّفُن، وإنّما ركب سفينة واحدة. وقد قيل: إنّ منه قوله: <span class="qpc-hafs">﴿الذين قال لهم الناس إن الناس قد جمعوا لكم﴾</span> [آل عمران:١٧٣]، والقائلُ كان -فيما ذُكِر- واحدًا، وذلك جائز عندهم فيما لم يُقْصَد فيه قَصْد واحد».</p><p>وبنحوه قال <u>ابنُ عطية</u> (٥/٢٠٧-٢٠٨).</div></p><p><div></p><p><p><span class="item-no">١٢٧٠٥<span class="dash">-</span></span> عن محمد بن إسحاق -من طريق سلمة- عن بعض أهل العلم، قال: فدعا زكريا عند ذلك بعد ما أسَنَّ، ولا ولد له، وقد انقرض أهلُ بيته؛ فقال: <span class="qpc-hafs">﴿رب هب لي من لدنك ذرية طيبة إنك سميع الدعاء﴾</span>. ثُمَّ شكا إلى ربِّه، فقال: <span class="qpc-hafs">﴿ربّ إني وهن العظم منّي واشتعل الرأس شيْبًا﴾</span> إلى <span class="qpc-hafs">﴿واجعله رب رضيًّا﴾</span> [مريم:٤-٦]. <span class="qpc-hafs">﴿فنادته الملائكة وهو قائم يُصَلّي في المحراب﴾</span> الآية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فنادته الملائكة وهو قائم يصلي في المحراب﴾</span>، فبينما هو يُصَلِّي في المحراب، حيث يذْبَح القربان، إذا برجل عليه بياض حِيالَه، وهو جبريل ﵇، فقال: <span class="qpc-hafs">﴿إن الله يُبَشّرك بيحيى﴾</span>{9}<span class=comment-ref>١١٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/٢٠٧) على مَن ذكر أنّ المنادي هو جبريل <span class="mustanad">مستنِدًا إلى العادة في مثل ذلك</span> بقوله: «وهذا هو العُرْف في الوحي إلى الأنبياء».</div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ قَاۤىِٕمࣱ یُصَلِّی فِی ٱلۡمِحۡرَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: المحراب: المُصَلّى{10}. (٣/٥٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٠٨<span class="dash">-</span></span> عن <span class="name-2">ثابت [البُنانِيّ]</span> -من طريق جعفر بن سليمان- قال: الصلاة خدمة الله في الأرض، ولو علم الله شيئًا أفضلَ من الصلاة ما قال: <span class="qpc-hafs">﴿فنادته الملائكة وهو قائم يصلي﴾</span>{11}. (٣/٥٢٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنَّ ٱللَّهَ یُبَشِّرُكَ بِیَحۡیَىٰ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٢٧٠٩<span class="dash">-</span></span> عن معاذ الكوفيِّ -من طريق عبد الرحمن بن أبي حَمّاد- قال: مَن قرأ: <span class="qpc-hafs">﴿يُبَشِّرُهُم﴾</span> [التوبة:٢١] مُثَقَّلَة فإنّه مِن البِشارة، ومَن قرأ (يَبْشُرُهم) مخففة بنصب الياء فإنّه مِن السرور: يَسُرُّهم{12}<span class=comment-ref>١١٨١</span>. (٣/٥٢٩)</p></p><p></div></p><p><div><span class=comment-ref>١١٨١</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٥/٣٦٩) قولَ معاذ الكوفي <span class="mustanad">مستنِدًا إلى اللغة</span>، فقال: "وأما ما رُوي عن معاذ الكوفيِّ مِن الفرق بين معنى التّخفيف والتّشديد في ذلك؛ فلم نجد أهلَ العلم بكلام العرب يعرفونه مِن وجه صحيح، فلا معنى لِما حُكِي من ذلك عنه، وقد قال جرير بن عطيّة:</p><p>يا بِشْرُ حُقَّ لوجهك التبشير ... هلا غضبت لنا وأنت أمير</p><p>فقد علم أنّه أراد بقوله: التبشير: الجمال والنضارة والسرور، فقال: التبشير. ولم يقل: البِشْر. فقد بَيَّن ذلك أنّ معنى التخفيف والتثقيل في ذلك واحد".</div></p><p><h3><span class="qpc-hafs">﴿أَنَّ ٱللَّهَ یُبَشِّرُكَ بِیَحۡیَىٰ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٢٧١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة- قال: صاحبكم ﷺ خامسُ خمسة مُبَشَّرٌ بهم قبل أن يكونوا: إسحاق ويعقوب، قول الله تعالى: <span class="qpc-hafs">﴿فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</span> [هود:٧١]، ويحيى، قوله تعالى: <span class="qpc-hafs">﴿إن الله يبشرك بيحيى مصدقا﴾</span>، وعيسى ابن مريم: <span class="qpc-hafs">﴿إن الله يبشرك بكلمة منه﴾</span>، ومحمد ﷺ، قول عيسى ﵇: <span class="qpc-hafs">﴿يأتي من بعدي اسمه أحمد﴾</span> [الصف:٦]، فهؤلاء أُخْبِر بهم مِن قبل أن يكونوا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: سُمِّي: يحيى؛ لأنّ الله أحْيا به عُقْرَ{14} أُمِّه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- قال: إنّ الملائكة شافهته بذلك مُشافهة، فبشَّرَتْه بيحيى{16}. (٣/٥٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿أن الله يبشرك بيحيى﴾</span>، قال: إنّما سُمِّي: يحيى؛ لأنّ الله أحياه بالإيمان{17}. (٣/٥٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق شيبان- <span class="qpc-hafs">﴿أن الله يبشرك بيحيى﴾</span>، قال: عبد أحياه الله بالإيمان{18}<span class=comment-ref>١١٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٢</span> لم يذكر <u>ابنُ جرير</u> (٥/٣٧٠) غير هذا القول وما في معناه.</div></p><p><div></p><p><p><span class="item-no">١٢٧١٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿أن الله يبشرك بيحيى﴾</span>، قال: سَمّى اللهُ يحيى{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق ابن ثور-: فنادته الملائكةُ: <span class="qpc-hafs">﴿أنّ الله يبشرك بيحيى﴾</span> بالحَمْل به{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن الله يبشرك بيحيى﴾</span>، اشتُقَّ يحيى مِن أسماء الله ﷿{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُصَدِّقَۢا بِكَلِمَةࣲ مِّنَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧١٨<span class="dash">-</span></span> عن عبد الله بن مسعود، مرفوعًا: <b>«خلق الله فرعون في بطن أُمِّه كافرًا، وخلق يحيى بن زكريا في بطن أُمِّه مؤمنًا»</b>{22}. (٣/٥٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿مصدقًا بكلمة من الله﴾</span>، قال: عيسى ابن مريم، والكلمةُ يعني: تَكَوَّن بكلمة من الله{23}. (٣/٥٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿مصدقًا بكلمة من الله﴾</span>، قال: كان عيسى ويحيى ابْنَيْ خالة، وكانت أُمُّ يحيى تقول لمريم: إنِّي أجد الذي في بطني يَسْجُدُ لِلَّذِي في بطنك. فذلك تصديقه بعيسى؛ سجودُه في بطن أمّه، وهو أوَّلُ من صدَّق بعيسى، وكلمة عيسى، ويحيى أكبرُ مِن عيسى{24}. (٣/٥٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قوله: <span class="qpc-hafs">﴿مصدقًا بكلمة من الله﴾</span>، قال: عيسى ابن مريم هو الكلمة من الله، اسمه المسيح{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٢<span class="dash">-</span></span> وعن <span class="name-2">أبي الشَّعْثاء جابر بن زيد</span>، نحو ذلك{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق النَّضْر بن عَرَبِيٍّ- قال: قالت امرأة زكريّا لمريم: إنِّي أجد الذي في بطني يتحرّك لِلَّذِي في بطنك. فوضعتِ امرأةُ زكريّا يحيى ﵇، ومريمُ عيسى ﵇، وذلك قوله: <span class="qpc-hafs">﴿مصدّقًا بكلمة من الله﴾</span>، قال: يحيى مُصَدِّقٌ بعيسى{27}. (٣/٥٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق علي بن الحكم- في قوله: <span class="qpc-hafs">﴿مصدقًا بكلمة من الله﴾</span>، قال: كان يحيى أوَّل مَن صَدَّق بعيسى، وشهد أنّه كلمةٌ مِن الله، وكان يحيى ابنَ خالة عيسى، وكان أكبرَ من عيسى{28}. (٣/٥٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- في قول الله: <span class="qpc-hafs">﴿أن الله يبشرك بيحيى مصدّقًا بكلمة من الله﴾</span>، قال: مُصَدِّقًا بعيسى ابن مريم{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿مصدّقًا بكلمة من الله﴾</span>، يقول: مُصَدِّقٌ بعيسى، وعلى سُنَّتِه، ومنهاجه{30}. (٣/٥٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿مصدِّقًا بكلمة من الله﴾</span>، قال: يُصدِّق بعيسى{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لقِيَتْ أُمُّ يحيى أُمَّ عيسى، وهذه حامل بيحيى، وهذه حامل بعيسى، فقالت امرأةُ زكريا: إنِّي وجدت ما في بطني يسجد لِما في بطنك. فذلك قوله تعالى: <span class="qpc-hafs">﴿مُصدِّقًا بكلمة من الله﴾</span>{32}. (٣/٥٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٢٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿مصدِّقًا بكلمة من الله﴾</span>، قال: كان أوَّلَ رجل صدَّق عيسى، وهو كلمة من الله ورُوحٌ{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٠<span class="dash">-</span></span> عن <span class="name-2">الرِّقاشِيِّ</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿يبشرك بيحيى مصدقا بكلمة من الله﴾</span>، قال: مُصَدِّقًا بعيسى ابن مريم{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُصدِّقًا بكلمة من الله﴾</span>، يعني: مِن الله ﷿، وكان يحيى أوَّلَ مَن صدَّق بعيسى ﵉، وهو ابن ثلاث سنين، قوله الأوَّل وهو ابن سِتَّة أشهر، فلَمّا شهِد يحيى أنّ عيسى مِن الله ﷿ عجِبت بنو إسرائيل لصغره، فلَمّا سَمِع زكريا شهادته قام إلى عيسى، فضَمَّه إليه، وهو في خِرْقَةٍ، وكان يحيى أكبر من عيسى بثلاث سنين، يحيى وعيسى ابنا خالة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَیِّدࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿وسيّدًا﴾</span>، قال: حليمًا تقِيًّا{36}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطيّة- في قوله: <span class="qpc-hafs">﴿وسيِّدًا﴾</span>، قال: السيِّد: الحليم{37}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق يحيى بن سعيد- قال: السيِّد: الفقيهُ العالِم{38}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٥<span class="dash">-</span></span> عن <span class="name-2">أبي الشَّعْثاء جابر بن زيد</span>، قال: السيِّد: الذي يغلِبُ غضبَه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٧<span class="dash">-</span></span> و<span class="name-2">مطر الوَرّاق</span>، أنّهما قالا: حليمًا{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- قال: السيِّد: الحليم{41}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٣٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- <span class="qpc-hafs">﴿وسيّدًا﴾</span>، قال: السَّيِّدُ: التَّقِيُّ{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: السيِّدُ: الذي يغلِب غضبَه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿وسيّدًا﴾</span>، قال: ليس له شرك{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: السيِّد: الكريم على الله{45}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قول الله ﷿: <span class="qpc-hafs">﴿وسيِّدًا﴾</span>، قال: السيِّد: الحليمُ التَّقِيُّ{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قال: السيِّد: الحسنُ الخُلُق{47}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي بكر الهُذَلِيِّ- قال: السيِّدُ: الذي لا يغلِبُه الغضبُ{48}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، قال: السيِّد: التَّقِيُّ{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: السيِّد: الذي يغلب غضبَه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٤٨<span class="dash">-</span></span> عن <span class="name-2">عطيّة العوفي</span> -من طريق إدريس- في قوله: <span class="qpc-hafs">﴿وسيّدًا﴾</span>، قال: السيِّدُ في خُلُقِه ودينه{19}<span class=comment-ref>١١٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٣</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ تيمية</u> (٣/٦٤بتصرف) على مَن فَسَّر السيِّد بأنّه سيِّدٌ لقومه في الدِّين، فقال: «ولا يسود الرجلُ الناسَ حتى يكون في نفسه مُجْتَمِع الخلقِ ثابتًا. ولهذا فسَّر طائفةٌ مِن السلف السيِّد بأنّه: سيِّدُ قومه في الدين».</div></p><p><div></p><p><p><span class="item-no">١٢٧٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، قال: السيِّد: الذي يغلِب غضبَه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وسيِّدًا﴾</span>، قال: إي واللهِ، لَسَيِّدٌ في العبادة، والحِلْم، والعلم، والوَرَع{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: والسيِّد: الحسن الخُلُق{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>: السيِّدُ: الحليمُ{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٣<span class="dash">-</span></span> عن شِبْل، قال: زَعَم <span class="name-2">الرِّقاشِيُّ</span> أنّ السَّيِّد: الكريمُ على الله{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال الله سبحانه: <span class="qpc-hafs">﴿وسيِّدًا﴾</span>، يعني: حليمًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٥<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: الذي لا يحسِد{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٦<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق عبد الرحمن بن مهديّ- في قوله: <span class="qpc-hafs">﴿وسيّدًا﴾</span>، قال: حليمًا تَقِيًّا{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وسيّدًا﴾</span>، قال: السيِّدُ: الشَّريفُ{38}<span class=comment-ref>١١٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٤</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ عَطِيَّة</u> (٢/٢١٠) على الأقوال الواردة في تأويل السيِّد بقوله: «كُلُّ مَن فَسَّر مِن هؤلاء العلماء المذكورين السُّؤْدَد بالحِلْم فقد أحرز أكثر معنى السُّؤْدَد، ومَن جرَّد تفسيره بالعِلم والتُّقى ونحوه فلم يُفَسِّر بحسب كلام العرب، وقد تحصَّلَ العلمُ ليحيى ﵇ بقوله ﷿: <span class="qpc-hafs">﴿مُصَدِّقًا بِكَلِمَةٍ مِنَ اللَّهِ﴾</span>، وتحصَّلَ التُّقى بباقي الآية». ثُمَّ ذكر (١/٤٢٩) عمومَ اللفظة لِكُلِّ ما ذُكِر، فقال: «وخصَّه الله بذكر السُّؤْدَد الذي هو الاحتمال في رِضى الناس على أشرف الوجوه دون أن يوقع في باطل، هذا لفظ يَعُمُّ السُّؤْدَد، وتفصيله أن يقال: بذل النَّدى -وهذا هو الكرم-، وكفُّ الأذى -وهنا هي العِفَّة بالفرج واليد واللسان-، واحتمال العظائم -وهنا هو الحلم وغيره؛ مِن تَحَمُّلِ الغرامات، وجبر الكسير، والإفضال على المُسْتَرْفِد، والإنقاذ من الهلكات-».</div></p><p><h3><span class="qpc-hafs">﴿وَحَصُورࣰا وَنَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧٥٨<span class="dash">-</span></span> عن أبي هريرة، أنّ النبي ﷺ قال: <b>«كُلُّ ابنِ آدم يَلْقى الله بذنب قد أذنبه، يُعَذّبه عليه إن شاء أو يَرْحَمه، إلّا يحيى بن زكريّا؛ فإنّه كان <span class="qpc-hafs">﴿سيّدًا وحصورًا ونبيًّا من الصالحين﴾</span>».</b> ثُمَّ أهْوى النبيُّ ﷺ إلى قَذاةٍ مِن الأرض، فأخذها، وقال: <b>«كان ذَكَرُه مِثلَ هذه القَذاة»</b>{61}. (٣/٥٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٥٩<span class="dash">-</span></span> عن عبد الله بن عمرو بن العاص، عن النبي ﷺ، قال: <b>«ما مِن عبد يَلْقى الله إلا ذا ذنب، إلا يحيى بن زكريّا؛ فإنّ الله يقول: <span class="qpc-hafs">﴿وسيِّدًا وحصورًا﴾</span>». قال: «وإنّما كان ذَكَرُه مثلَ هُدْبَةِ الثَّوْب»</b>. وأشار بأَنْمَلِهِ{62}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، مثله موقوفًا{63}. (٣/٥٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦١<span class="dash">-</span></span> عن معاوية بن صالح، عن بعضهم رَفَعَ الحديث: <b>«لعن اللهُ والملائكةُ رجلًا تَحَصَّر بعد يحيى بن زكريا»</b>{64}. (٣/٥٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زِرٍّ- قال: الحَصُور: الذي لا يَقْرَبُ النِّساء. ولفظُ ابنِ المنذر: العِنِّين{65}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿وحصورا﴾</span>، قال: والحصورُ: الذي لا يأتي النساءَ{37}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- قال: الحَصُور: الذي لا يُنزِلُ الماءَ{67}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق نافع بن الأزرق- أنّه سأله عن قوله: <span class="qpc-hafs">﴿وحصورًا﴾</span>. قال: الذي لا يأتي النِّساءَ. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>وحصور عن الخَنا يأمر النا سَ بِفَعل الخيرات والتَّشْمِير؟{68}. (٣/٥٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٦<span class="dash">-</span></span> عن <span class="name-2">أبي الشعثاء جابر بن زيد</span>، قال: الحصور: الذي لا يَغْشى النِّساء{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span>، قال: الذي لا يُولَد له{70}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق يحيى بن سعيد- في قوله: <span class="qpc-hafs">﴿وحصورًا﴾</span>، قال: لا يشتهي النساءَ. ثم ضرب بيده إلى الأرض، فأخذ نَواةً، فقال: ما كان معه إلا مِثْلُ هذه{71}. (٣/٥٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٦٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المُسَيِّب</span> -من طريق يحيى بن سعيد- يقول: ليس أحدٌ إلا يلقى اللهَ يومَ القيامة ذا ذَنب، إلا يحيى بن زكريا، كان حصورًا، مَعَهُ مِثلُ الهُدْبَة{71}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- قال: الحصورُ: الذي لا يأتي النساءَ{73}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- قال: الحصور: الذي لا يأتي النساءَ{74}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قال: الحصورُ: الذي حُصِر عن النساء{75}. (٣/٥٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر-: الحَصُور: الذي لا يُولَد له، وليس له ماء{76}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: هو الذي لا يأتي النساءَ{77}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصريِّ</span> -من طريق عبّاد بن منصور- <span class="qpc-hafs">﴿وحصُورًا﴾</span>، قال: لا يقرَب النساءَ{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>: الحَصُور: الذي ليس له شهوة{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٧<span class="dash">-</span></span> عن <span class="name-2">عَطِيَّة العوفيِّ</span>، قال: هو الذي لا يأتي النساءَ{77}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٨<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، قال: الحصور: الذي لا يَغْشى النساءَ{81}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وحصورًا﴾</span>، قال: كُنّا نُحدَّث: أنّ الحصورَ: الذي لا يَقْرَب النساءَ{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وحصُورًا﴾</span>، قال: الحَصُور: الذي لا يريد النساءَ{83}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق عثمان بن عطاء- في قوله: <span class="qpc-hafs">﴿وحصورا﴾</span>، قال: مُنثَنِي الذَّكَر{84}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: الحصورُ: الذي لا يُولَد له{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٣<span class="dash">-</span></span> عن شِبْلٍ، قال: زَعَمَ <span class="name-2">الرَّقاشِيُّ</span>: الحصور: الذي لا يَقْرَب النساء{86}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحصورًا﴾</span>: لا ماء له، والحصورُ: الَّذي لا حاجةَ له في النساء{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- <span class="qpc-hafs">﴿وحصُورًا﴾</span>، قال: الحَصُورُ: الذي لا يأتي النساءَ{83}<span class=comment-ref>١١٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٥</span> قال <u>ابنُ عطية</u> (٢/٢١٢) بعد ذِكْرِه لِمَن جعل حَصْرَ يحيى ﵇ لأنّه لم يكن له إلا مِثْلُ الهُدْبَة، ومَن علَّله بكونه عِنِّينًا لا يأتي النساء، ونقله لقول ثالث يقول بأنّ حصر يحيى كان بمجاهدته نفسَه، وأنّه كانت به القدرة على إتيان النساء: «قالوا: وهذا أمدحُ له، وليس له في التأويلين الأوَّلَيْن مدحٌ، إلا بأنّ الله يسَّر له شيئًا لا تَكَسُّب له فيه».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٣/٥٧) أنّ مدح يحيى ﵇ بأنّه حصور ليس معناه: أنّه لا يأتي النساء، بل معناه: أنّه معصومٌ عن الفواحش والقاذورات؛ <span class="mustanad">مستنِدًا إلى دلالة عقْلِيَّة</span>، وذلك أنّ عدم القدرة على النِّكاح نَقْصٌ، ثُمَّ قال بعد ذلك: «ولا يمنع ذلك من تزويجه بالنساء الحلال، وغشيانِهِنَّ، وإيلادِهِنَّ، بل قد يُفْهم وجود النسل له من دُعاء زكريا المتقدم؛ حيث قال: <span class="qpc-hafs">﴿هب لي من لدنك ذرية طيبة﴾</span>. كأنه قال: ولدًا له ذُرِّيَّةٌ ونَسْلٌ وعَقِب».</div></p><p><h3><span class="qpc-hafs">﴿وَحَصُورࣰا وَنَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝٣٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٧٨٦<span class="dash">-</span></span> عن أبي سعيد، قال: قال رسول الله ﷺ: <b>«الحسن والحسين سيِّدا شباب أهل الجنة، إلّا ابْنَيِ الخالة؛ عيسى ابن مريم، ويحيى بن زكريا»</b>{89}. (١٠/٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٧<span class="dash">-</span></span> عن أبي أُمامَة، قال: قال رسول الله ﷺ: <b>«أربعةٌ لُعِنوا في الدنيا والآخرة وأَمَّنَت الملائكةُ: رجلٌ جعله الله ذَكَرًا فأنّث نفسَه وتَشَبَّه بالنساء، وامرأة جعلها الله أنثى فتَذَكَّرَتْ وتَشَبَّهَتْ بالرِّجال، والذي يُضِلّ الأعمى، ورجلٌ حَصُور، ولم يجعل اللهُ حصُورًا إلا يحيى بن زكريّا»</b>{90}. (٣/٥٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٨<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span>، قال: نادى مُنادٍ من السماء: إنّ يحيى بن زكريا سيِّدُ مَن ولدت النساء، وإنّ جورجيس سَيِّدُ الشهداء{91}. (٣/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٨٩<span class="dash">-</span></span> عن <span class="name-2">ثابت البُنانِيِّ</span>، قال: بَلَغَنا: أنّ إبليس ظهر ليحيى بن زكريا، فرأى عليه مَعالِيق مِن كُلِّ شيء، فقال له يحيى: ما هذه؟ قال: هذه الشَّهَوات التي أُصِيبُ بها بني آدم. قال له يحيى: هل لي فيها شيء؟ قال: لا. قال: فهل تُصِيب مِنِّي شيئًا؟ قال: رُبَّما شَبِعْتَ؛ فثقَّلْناك عن الصلاة والذِّكْر. قال: هل غيرُه؟ قال: لا. قال: لا جَرَم، لا أشبعُ أبدًا{92}. (١٠/٣٤)</p></p><p></div></p></div>",footnotes:1:أخرجه الخطيب في تاريخه ٥/٢١٥ (١٣٦٥) من طريق أحمد بن الحسن المقرئ، عن أحمد بن الخليل اليماني، عن أبي بكر ابن عياش، عن الأعمش، عن خيثمة، عن عبد الله بن مسعود به.</p><p>قال الخطيب ٥/٢١٥ (١٣٦٥): «غريب لم أكتبه إلا من هذا الوجه». قلنا: في سنده: أحمد بن الحسن بن علي المقري دبيس، قال عنه الدارقطني: «ليس بثقة». ينظر: ميزان الاعتدال ١/٩١. وفيه أيضًا أحمد بن الخليل بن مالك المعروف بحور، قال الدارقطني: «ضعيف لا يُحْتَجُّ به». انظر: تاريخ بغداد ٥/٢١٥. وانظر: لسان الميزان ١/٤٥٣.</p><p>والمراد من قراءته بالياء أنه قرأ بألف بعد الدال ممالة، وهي قراءة متواترة قرأ بها حمزة والكسائي وخلف. انظر: النشر ٢/١٨٠.أخرجه ابن جرير ٥/٣٦٤.</p><p>وهي قراءة شاذة. ينظر: البحر المحيط ٢/٤٦٤.أخرجه ابن المنذر ١/١٨٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن المنذر ١/١٨٤-١٨٥.عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>قرأ جمهور القراء: <span class="qpc-hafs">﴿أن الله﴾</span> بفتح الهمزة، وقرأ ابن عامر وحمزة بكسرها. انظر: النشر ٢/٢٣٩.</p><p>وقرأ جمهور القراء: <span class="qpc-hafs">﴿يبشرك﴾</span> مثقلة بضم الياء وتشديد الشين مكسورة، وقرأ حمزة والكسائي بالتخفيف بفتح الياء والشين مخففة. انظر: النشر ٢/٢٣٩.أخرجه ابن جرير ٥/٣٦١.أخرجه ابن جرير ٥/٣٦٤، وابن أبي حاتم ٢/٦٤١.أخرجه ابن جرير ٥/٣٦١.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه ابن المنذر ١/١٨١.أخرجه ابن المنذر ١/١٨٥، وابن أبي حاتم ٢/٦٤١، وابن أبي الدنيا في كتاب التهجد وقيام الليل -موسوعة الإمام ابن أبي الدنيا ١/٣٢٩ (٤٠٥)- من طريق إبراهيم بن أبي عبلة.أخرجه ابن جرير ٥/٣٦٩.</p><p>وهما قراءتان عشريتان، قرأ بالتخفيف حمزة الكوفي، وقرأ الباقون بالتشديد. ينظر: النشر ٢/٢٣٩.أخرجه ابن عساكر في تاريخ دمشق ٣/٣٩٣.عُقْرُ المرأة –بالضمّ-: فَرْجُها. تاج العروس (عقر).تفسير الثعلبي ٣/٦٢، وتفسير البغوي ٢/٣٤.أخرجه عبد الرزاق ١/١٢٠، وابن جرير ٥/٣٦٩، وابن المنذر ١/١٨٦ من طريق سعيد، وابن أبي حاتم ٢/٦٤١.أخرجه ابن جرير ٥/٣٧٠، وابن المنذر ١/١٨٦، وابن أبي حاتم ٢/٦٤٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زَمنين ١/٢٨٧-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/٣٧٠ من طريق سعيد، وابن أبي حاتم ٢/٦٤١.أخرجه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن المنذر ١/١٨٧.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه الطبراني في الكبير ١٠/٢٢٤ (١٠٥٤٣)، والبيهقي في القضاء والقدر ١/١٥٣ (٩٦)، ١/١٥٤ (٩٨)، ١/١٥٥ (١٠٣) من طريق قتادة، عن أبي حسان الأعرج، عن ناجية بن كعب، عن عبد الله بن مسعود به.</p><p>قال الهيثمي في المجمع ٧/١٩٣ (١١٨١١): «إسناده جيّد». وقال الألباني في الصحيحة ٤/٤٤٧ (١٨٣١): «له طريق حسنة».أخرجه ابن جرير ٥/٣٧٢، وابن المنذر ١/١٨٧، وابن أبي حاتم ٢/٦٤٢. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد.أخرجه ابن جرير ٥/٣٧٢-٣٧٣.أخرجه ابن جرير ٥/٣٧٢.علَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧١. وعزاه السيوطي إلى أحمد في الزهد. كما أخرج ابن جرير ٥/٣٧١ آخره مختصرًا من طريق ابن أبي نجيح.أخرجه ابن جرير ٥/٣٧٢ من طريق عبيد بن سليمان، وابن المنذر ١/١٨٧.أخرجه ابن جرير ٥/٣٧٣. وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧١.أخرجه ابن جرير ٥/٣٧٢.أخرجه ابن جرير ٥/٣٧٣.أخرجه ابن جرير ٥/٣٧٢. وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧١. وعلَّقه ابن أبي حاتم ٢/٦٤٢.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه ابن جرير ٥/٣٧٦، وابن أبي حاتم ٢/٦٤٢.أخرجه عبد الرزاق ١/١٢٠، وابن المنذر ١/١٩٠، وابن أبي حاتم ٢/٦٤٣، وابن عساكر ٦٤/١٧٦. وعند عبد الرزاق من قول قتادة.أخرجه ابن جرير ٥/٣٧٦.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.علَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن أبي شيبة ٨/٣٣٧، ١١/٥٦٢، وأحمد في الزهد ص٧٦، وابن جرير ٥/٣٧٤ من طريق سالم. وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن المنذر ١/١٨٨، وابن جرير ٥/٣٧٥.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن أبي حاتم ٢/٦٤٣.أخرجه ابن جرير ٥/٣٧٥، وابن المنذر ١/١٨٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه الثوري في تفسيره ص٧٦، وابن جرير ٥/٣٧٥، وابن عساكر في تاريخ دمشق ٦٤/١٧٨. وعلَّقه ابن أبي حاتم ٢/٦٤٢. وذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩ بلفظ: الحليم.أخرجه أحمد في الزهد ص٩٠، والخرائطيُّ في مكارم الأخلاق (١٧، ٢٦٨-منتقى). وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧٦، وابن أبي حاتم ٢/٦٤٢. وعزاه السيوطي إلى ابن أبي الدنيا في ذمِّ الغضب.ذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن أبي حاتم ٢/٦٤٢ بلفظ: تقيًّا.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن أبي حاتم ٢/٦٤٢.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن جرير ٥/٣٧٣. وعلَّقه ابن أبي حاتم ٢/٦٤٢ بلفظ: «حليمًا» فقط.ذكره يحيى بن سلام -كما في تفسير ابن أبي زَمنين ١/٢٨٧-.ذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن المنذر ١/١٨٩، وابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧٥، وابن أبي حاتم ٢/٦٤٣.تفسير مقاتل بن سليمان ١/٢٧٤.تفسير الثعلبي ٣/٦٣، وتفسير البغوي ٢/٣٤.أخرجه ابن جرير ٥/٣٧٥.أخرجه ابن جرير ٥/٣٧٦.أخرجه الطبراني في الأوسط ٦/٣٣٣ (٦٥٥٦)، وابن عساكر ٦٤/١٩٤ (١٣١١٦)، وابن أبي حاتم ٢/٦٤٤ (٣٤٧٠) من طريق محمد بن سلمة المرادي، عن حجاج بن سليمان، عن الليث بن سعد، عن محمد بن عجلان، عن القعقاع بن حكيم، عن أبي صالح، عن أبي هريرة به.</p><p>قال أبو حاتم الرازي: «لم يكن هذا الحديثُ عند أحد غير الحجاج، ولم يكن في كتاب الليث، وحجاج شيخ معروف». انظر: علل الحديث لابن أبي حاتم ٥/١٠١. وقال الطبراني: «لم يروِ هذا الحديثَ عن محمد بن عجلان إلا الليث، ولا عن الليث إلا حجاج بن سليمان، تفرَّد به محمد بن سلمة المرادي». وقال ابن عدي في الكامل في ضعفاء الرجال ٢/٥٣٦ عن حجاج بن سليمان: «يحدث عن الليث وابن لهيعة أحاديث منكرة» ثم أورد هذا الحديث في ترجمته. وقال الهيثمي في المجمع ٨/٢٠٩ (١٣٨٠٤): «وفيه حجاج بن سليمان الرّعيني، وثَّقه ابن حبان وغيره، وضعّفه أبو زرعة وغيره، وبقية رجاله ثقات».أخرجه الحاكم في المستدرك ٢/٤٠٤ (٣٤١١)، ٤/٢٧٣ (٧٦١٨)، وابن جرير ٥/٣٧٨، وابن المنذر ١/١٩١ (٤٣٠) من طريق محمد بن إسحاق، عن يحيى بن سعيد الأنصاري، عن سعيد بن المسيب، عن عمرو بن العاص به مرفوعًا.</p><p>قال الحاكم: «حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٢/٣٨: «في صحة المرفوع نظر».</p><p>وأخرجه ابن أبي شيبة في المصنف ٧/١٢٨، وابن جرير ٥/٣٧٨ -على الشك: إمّا عبد الله، وإمّا أبوه- من طريق يحيى بن سعيد، عن سعيد بن المسيب، عن عبد الله بن عمرو به موقوفًا عليه.أخرجه ابن أبي شيبة ١١/٥٦١-٥٦٢، وأحمد في الزهد ص٩٠، وابن أبي حاتم ٢/٦٤٣ من وجه آخر. وينظر: العلل لابن أبي حاتم (١٩١٣).</p><p>قال ابن كثير في تفسيره ٢/٣٨: «فهذا موقوف، وهو أقوى إسنادًا من المرفوع [يعني: الأثر الذي قبله]، بل وفي صحة المرفوع نظر». وقال السيوطي: «هو أقوى إسنادًا من المرفوع».أخرجه ابن عساكر ٦٤/١٩٦.أخرجه ابن جرير ٥/٣٧٧، وابن المنذر ١/١٩٠، والبيهقي في سُنَنِه ٧/٨٣. وعلَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه عبد الرزاق ١/١٢٠، وابن المنذر ١/١٩٠، وابن أبي حاتم ٢/٦٤٣، وابن عساكر ٦٤/١٧٦. وعند عبد الرزاق من قول قتادة.أخرجه ابن جرير ٥/٣٨٠، وابن المنذر ١/١٩٠، وابن أبي حاتم ٢/٦٤٣. وعزاه السيوطي إلى أحمد في الزهد.أخرجه الطستي -كما في الإتقان ٢/٩٠-.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن أبي حاتم ٢/٦٤٣.علَّقه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن جرير ٥/٣٧٨.أخرجه ابن جرير ٥/٣٧٨.أخرجه الثوري في تفسيره ص٧٦، وابن أبي شيبة ٨/٣٣٧، ١١/٥٦٢، وأحمد في الزهد ص٧٦، وعبد بن حميد كما في قطعة من تفسيره ص٢٩، وابن جرير ٥/٣٧٩. وعلَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه ابن جرير ٥/٣٧٩ من طريق النَّضْر بن عَرَبِيٍّ، والبيهقي في سُنَنِه ٧/٨٣. وعلَّقه ابن أبي حاتم ٢/٦٤٣. وعزاه السيوطي إلى أحمد.أخرجه أحمد في الزهد ص٩٠، والخرائطيُّ في مكارم الأخلاق (١٧، ٢٦٨-منتقى) بدون ذكر الحصور فيه. وعلَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه ابن جرير ٥/٣٧٩، وابن أبي حاتم ٢/٦٤٤. وعلَّقه ابن المنذر ١/١٩٠.علَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩، وابن جرير ٥/٣٨١.ذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن أبي حاتم ٢/٦٤٣ بلفظ: هو الذي لا يأتي النساء.علَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعزاه الحافظ ابن حجر في الفتح ٤/٤ إلى ابن جرير.أخرجه ابن جرير ٥/٣٨٠. وعلَّقه ابن المنذر ١/١٩٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زَمنين ١/٢٨٧-.أخرجه ابن جرير ٥/٣٨٠.أخرجه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن المنذر ١/١٩١. وعلَّقه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن جرير ٥/٣٧٩.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه ابن جرير ٥/٣٨٠.أخرجه النسائي في الكبرى ٧/٣١٨ (٨١١٣)، ٧/٤٦٠ (٨٤٧٥)، وابن حبان ١٥/٤١١-٤١٢ (٦٩٥٩)، والحاكم ٣/١٨٢ (٤٧٧٨) وفي إسناده الحكم بن عبد الرحمن بن أبي نعم.</p><p>وأخرجه أحمد مختصرًا ١٧/٣١ (١٠٩٩٩)، ١٨/١٣٨ (١١٥٩٤)، ١٨/١٦١ (١١٦١٨)، ١٨/٣٠١ (١١٧٧٧)، والترمذي ٦/٣٢٤-٣٢٥ (٤١٠١، ٤١٠٢).</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث قد صح من أوجه كثيرة، وأنا أتعجب أنهما لم يخرجاه». وقال الذهبي في التلخيص: «الحكم بن عبد الرحمن بن أبي نعم فيه لين». وقال السخاوي في المقاصد الحسنة ص٣٠٦ (٤٠٧): «وقد روى هذا الحديث سويد بن سعيد عن أبي معاوية عن الأعمش عن عطية عن أبي سعيد، فقال ابن معين: إنه باطل عن أبي معاوية، قال الدارقطني: فلم نزل نظن أن هذا كما قال ابن معين حتى دخلت مصر في سنة سبع وخمسين فوجدت الحديث في مسند إسحاق بن إبراهيم المنجنيقي - وكان ثقة - رواه عن أبي كريب عن أبي معاوية كما قال سويد سواء، وتخلص سويد». وصحّحه الألباني في الصحيحة ٢/٤٢٣-٤٣١ (٧٩٦).أخرجه الطبراني في الكبير ٨/٢٠٤ (٧٨٢٧) من طريق علي بن يزيد، عن القاسم، عن أبي أمامة به.</p><p>قال الهيثمي في المجمع ٨/١٠٣ (١٣٢٠٢): «فيه علي بن يزيد الألهاني، وهو متروك». وقال الألباني في الصحيحة ٦/١٢١٢: «حديث منكر ضعيف الإسناد جِدًّا».أخرجه أحمد في الزهد ص٧٦.أخرجه أحمد في الزهد ص٧٦، والبيهقي في الشعب (٥٧٠٠)، وابن عساكر ٦٤/٢٠٣.
  3,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ أَنَّىٰ یَكُونُ لِی غُلَـٰمࣱ وَقَدۡ بَلَغَنِیَ ٱلۡكِبَرُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك-: كان ابنَ عشرين ومائة سنة، وكانت امرأتُه بنتَ ثمانٍ وتسعين سنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي بكر- قال: أتاه الشيطانُ، فأراد أن يُكَدِّر عليه نعمةَ ربِّه، قال: هل تدري مَن ناداك؟ قال: نعم، ناداني ملائكةُ ربي. قال: بل ذلك الشيطان، لو كان هذا مِن ربِّك لأخفاهُ إليك كما أخفيتَ نداءك. فقال: <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>{2}. (٣/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا سمع زكريا النّداءَ جاءه الشيطان، فقال له: يا زكريا، إنّ الصَّوْت الذي سمعت ليس هو من الله، إنّما هو مِن الشيطان لِيَسْخَر بك، ولو كان من الله أوحى إليك كما يُوحي إليك في غيره من الأمر. فشكّ مكانه، وقال: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span>{3}<span class=comment-ref>١١٨٦</span>. (٣/٥٣٤)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٦</span> لم يذكر <u>ابنُ جرير</u> (٥/٣٨٣) غير هذا القول، وأورد قول عكرمة، والسدي، ثم قال <span class="mustanad">مستنِدًا إلى دلالة الإسرائيليات</span>: «فكان قوله ما قال من ذلك، ومراجعته ربّه فيما راجع فيه بقوله: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span>؛ للوسوسة التي خالطت قلبَه من الشّيطان، حتى خَيَّلَتْ إليه أنّ النداء الذي سمعه كان نِداءً من غير الملائكة، فقال: <span class="qpc-hafs">﴿رب أنى يكون لي غلام﴾</span> مُستَثْبتًا في أمره ليتقرّر عنده بآيةٍ يريه الله في ذلك أنّه بشارة من الله على ألسن ملائكته، ولذلك قال: <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>». ثم ذكر (٥/٣٨٣) بعد ذلك وجهًا آخر لتأويل الآية، فقال: «وقد يجوز أن يكون قيلُه ذلك مسألةً منه ربَّه: مِن أيِّ وجهٍ يكون الولد الذي بُشّر به؟ أمِن زوجته فهي عاقر، أم من غيرها من النساء؟ فيكون ذلك على غير الوجه الذي قاله عكرمة، والسدي، ومَن قال مثل قولهما».</p><p><span class="comment-type-4">وعلّق</span> <u>ابنُ عطية</u> (٢/٢١٣) على الوجه الآخر الذي ذكره <u>ابن جرير</u> بقوله: «وهذا تأويل حسنٌ لائِقٌ بزكرياء ﵇».</div></p><p><div></p><p><p><span class="item-no">١٢٧٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> –من طريق أسباط- قال: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span>، يقول: مِن أين؟{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿أنّى يكون لي﴾</span>، قال: كيف يكون لي؟{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿قال ربّ﴾</span>، أي: يا سيِّدي. قاله لجبريل ﵇{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: كان زكريا يوم بُشِّر بالولد ابن ثنتين وتسعين سنة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلَمّا بُشِّر زكريا بالولد قال لجبريل ﵇ في المخاطبة: <span class="qpc-hafs">﴿قال رب أنى﴾</span>، يعني: مِن أين <span class="qpc-hafs">﴿يكون لي غلام وقد بلغني الكبر وامرأتي عاقر﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱمۡرَأَتِی عَاقِرࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٧٩٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: أراد أن يَعْلَم كيف وُهِبَ ذلك له وهو كبيرٌ وامرأتُه عاقِرٌ؛ ليزداد علمًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٧٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقد بلغني الكبر وامرأتي عاقر﴾</span>، يقولُ ذلك تَعَجُّبًا؛ لأنّه كان قد يَبِس جِلْدُه على عظمه مِن الكِبَر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٠<span class="dash">-</span></span> عن شعيب الجَبَئِيِّ -من طريق وهب بن سليمان-: أنّ اسمَ أُمِّ يحيى: أشْيَع{11}. (٣/٥٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ كَذَ ٰ⁠لِكَ ٱللَّهُ یَفۡعَلُ مَا یَشَاۤءُ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٠١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span> -من طريق السدي- قوله: <span class="qpc-hafs">﴿كذلك﴾</span>، قال: يعني: هكذا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿كذلك﴾</span>، يعني: هكذا{13}. (٣/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> جبريل ﵇: <span class="qpc-hafs">﴿كذلك﴾</span>، يعني: هكذا قال ربك إنّه يكون لك ولد، <span class="qpc-hafs">﴿الله يفعل ما يشاء﴾</span> أن يجعل ولدًا من الكبير والعاقر؛ لقوله: <span class="qpc-hafs">﴿وقد بلغني الكبر وامرأتي عاقر﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٢/٣٥.أخرجه ابن جرير ٥/٣٨٢-٣٨٣.أخرجه ابن جرير ٥/٣٨٢، وابن أبي حاتم ٢/٦٤٤.أخرجه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن أبي حاتم ٢/٦٤٤.تفسير الثعلبي ٣/٦٥، وتفسير البغوي ٢/٣٥.تفسير الثعلبي ٣/٦٥، وتفسير البغوي ٢/٣٥.تفسير مقاتل بن سليمان ١/٢٧٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٨-.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه ابن جرير ٥/٣٥٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٢/٦٤٥.عزاه السيوطي إلى ابن أبي حاتم، وعند ابن أبي حاتم ٢/٦٤٥ عن السدي عن أبي مالك.تفسير مقاتل بن سليمان ١/٢٧٥.
  3,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ ٱجۡعَل لِّیۤ ءَایَةࣰۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>، قال: قال زكريا: يا ربِّ، فإن كان هذا الصَّوْتُ مِنكَ فاجعل لي آية{1}. (٣/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق ابن ثور- <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>، قال: بالحمل به{2}. (٣/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال رب اجعل لي آية﴾</span>، يعني: عَلَمًا للحَبَل{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ ءَایَتُكَ أَلَّا تُكَلِّمَ ٱلنَّاسَ ثَلَـٰثَةَ أَیَّامٍ إِلَّا رَمۡزࣰاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا بُشِّرَ بيحيى قال: <span class="qpc-hafs">﴿رب اجعل لي آية قال آيتك ألا تكلم النّاس﴾</span>، قال: يُعْتَقَلُ لسانُك مِن غير مرضٍ، وأنت سَوِيٌّ{4}. (٣/٥٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: الرَّمْز بالشَّفَتين{5}. (٣/٥٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفيِّ- قال: الرَّمْز أن أُخِذ بلسانه، فجعل يُكَلِّمُ الناسَ بيده{6}. (٣/٥٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿إلا رمزًا﴾</span>. قال: الإشارةُ باليد، والوَحْيُ بالرأس. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر:</p><p>ما في السماء من الرحمن مُرْتَمزٌ إلا إليه، وما في الأرض مِن وزَرِ؟{7}. (٣/٥٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١١<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السلمي</span> -من طريق عطاء بن السائب- قال: اعْتُقِل لسانُه مِن غير مرضٍ{5}. (٣/٥٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٢<span class="dash">-</span></span> عن <span class="name-2">جُبَير بن نُفَير</span> -من طريق صفوان بن عمرو- قال: ربا لسانُه في فيه حتّى مَلَأَهُ، فمنعه الكلامَ، ثم أطلقه اللهُ بعد ثلاث{9}. (٣/٥٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، يقول: يُومِئُ إيماءً{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: الإشارة{11}. (٣/٥٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٥<span class="dash">-</span></span> وعن <span class="name-2">أبي عبد الرحمن السلمي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٦<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القرظي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٧<span class="dash">-</span></span> و<span class="name-2">زيد بن أسلم</span>، نحو ذلك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: إيماؤُه بشفتيه{13}. (٣/٥٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق النَّضْر بن عَرَبِيٍّ- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: تحريك الشفتين{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سلمة بن نُبَيْط- قال: الرَّمْزُ: أن يشير بيده أو رأسه ولا يتكلَّم{15}. (٣/٥٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النَّضْر بن عَرَبِيٍّ- في قوله ﷿: <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: حَرَّكَ شَفَتَه{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- في قوله: <span class="qpc-hafs">﴿قال آيتك ألا تكلم الناس ثلاثة أيام إلا رمزًا﴾</span>، قال: أُمْسِكَ بلسانه، فجعل يُومِئُ بيده إلى قومه: أن سَبِّحُوا بُكْرَةً وعَشِيًّا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٣<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، أراد به صوم ثلاثة أيّامٍ؛ لأنّهم إذا صاموا لم يتكلَّموا إلا رمزًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿آيتك ألا تكلم الناس ثلاثة أيّام﴾</span>، قال: إنّما عُوقِب بذلك لأنّ الملائكة شافهتْهُ بذلك مُشافَهَةً، فبَشَّرَتْه بيحيى، فسأل الآيةَ بعد كلام الملائكة إيّاه، فأخذ عليه بلسانه{19}. (٣/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: إلا إيماءً{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٦<span class="dash">-</span></span> عن <span class="name-2">ابن كثير المكي</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: إلا إشارة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، يقول: إشارة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: اعْتُقِلَ لسانهُ ثلاثةَ أيّامٍ وثلاثَ ليالٍ{5}. (٣/٥٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٢٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فنادته الملائكة﴾</span> الآية، قال: فجاء الشَّيطانُ إلى زكريّا، فقال: هذا النداءُ الذي نُودِيتَ ليس مِن الله، إنّما هو من الشيطان، سَخِرَ بِك، لو كان من الله أوحاه إليك كما كان يُوحي إليك. فقال عند ذلك: <span class="qpc-hafs">﴿رب اجعل لي آية﴾</span>؛ حتى أعلم أنّ هذا النّداء منك. فقال له: <span class="qpc-hafs">﴿آيتك ألا تكلم الناس ثلاثة أيام إلا رمزا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٠<span class="dash">-</span></span> عن <span class="name-2">عطاء بن السائب</span> -من طريق ورقاء- في قوله: <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: اعْتُقِلَ لسانه من غير مرض{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣١<span class="dash">-</span></span> عن <span class="name-2">خُصَيْف بن عبد الرحمن</span> -من طريق محمد بن سلمة- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: إشارة بالشَّفَتَيْن والحاجِبَيْن{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: ذُكِر لنا -والله أعلم-: أنّه عوقب؛ لأنّ الملائكة شافهته، فبَشَّرَتْه بيحيى، قالت: <span class="qpc-hafs">﴿أن الله يبشرك بيحيى﴾</span>. فسأل بعد كلام الملائكة إيّاه الآيةَ، فأُخِذ عليه لسانُه، فجعل لا يقدر على الكلام إلا رمزًا، يقول: يُومِئُ إيماءً{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال آيتك﴾</span> إذا جامعتَها على طهر فحَبَلَتْ؛ فإنّك تصبح لا تَسْتَنكِرُ مِن نفسك خَرَسًا ولا سَقَمًا، ولكن تُصْبِح لا تُطِيق الكلامَ، <span class="qpc-hafs">﴿ألا تكلم الناس ثلاثة أيام إلا رمزًا﴾</span>، يعني: إلّا إشارة يومئ بيده، أو برأسه من غير مرض، ... فأتى امرأته على طهرها فحَمَلت، وكان آيةُ الحَبَل أنّه وضع يده على صدرها، فحَمَلَتْ، فاستقرّ الحَمْلُ في رَحِمِها، فحبلت بيحيى، فأصبح لا يستطيع الكلام، فعرف أنّ امرأته قد حَبَلَتْ، فولدت يحيى ﵇، فلم يعصِ اللهَ قطُّ{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿آيتك أن لا تكلم الناس ثلاثة أيّام﴾</span>، قال: تمسك على فيك{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿إلا رمزًا﴾</span>، قال: والرَّمْزُ: الإشارة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿رب اجعل لي آية قال آيتك ألا تكلم الناس ثلاثة أيام إلا رمزًا﴾</span> الآية، قال: جعل آيتَه أن لا يُكَلِّمَ الناسَ ثلاثة أيّام إلا رمزًا، إلا أنّه يذكر الله. والرمزُ: الإشارةُ، يشير إليهم{6}<span class=comment-ref>١١٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٧</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (٢/٢١٥) إلى العموم، وعدم تخصيص الرَّمز بمعنى دون غيره، حيث إنّه قال: «والرَّمز في اللغة: حركةٌ تُعْلِمُ بما في نَفْسِ الرّامِز، بأيِّ شيء كانت الحركة؛ من عين، أو حاجب، أو شفة، أو يد، أو عود، أو غير ذلك. وقد قيل للكلام المُحَرَّف عن ظاهره: رموز؛ لأنّها علاماتٌ بغير اللفظ الموضوع للمعنى المقصود الإعلامِ به. وقد يُقالُ للتصويت الدالِّ على معنًى: رمز». ثم قال: «وأمّا المفسرون فخصَّص كُلُّ واحدٍ منهم نوعًا من الرَّمز في تفسيره هذه الآية».</div></p><p><h3><span class="qpc-hafs">﴿وَٱذۡكُر رَّبَّكَ كَثِیرࣰا وَسَبِّحۡ بِٱلۡعَشِیِّ وَٱلۡإِبۡكَـٰرِ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وسبح بالعشي والإبكار﴾</span>، قال: العشيُّ: ميل الشمس إلى أن تغيب. والإبكار: أوَّلُ الفجر{32}. (٣/٥٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الله بن كثير- في قوله: <span class="qpc-hafs">﴿وسبّح بالعشي والإبكار﴾</span>، قال: صلاة المكتوبة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ولم يُحْبَس لسانُه عن ذكر الله ﷿، ولا عن الصلاة، فكذلك قوله سبحانه: <span class="qpc-hafs">﴿واذكر ربك كثيرًا وسبّح بالعشيّ والإبكار﴾</span>، يقول: صَلِّ بالغداة والعَشِيِّ{3}<span class=comment-ref>١١٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٨</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ عطية</u> (٢/٢١٦) أنّ الأمر بالتسبيح معناه هنا: قُل: سبحان الله. <span class="mustanad">مستنِدًا إلى السّياق، ودلالة عقليّة</span>، فقال: «<span class="qpc-hafs">﴿وسَبِّحْ﴾</span> معناه: قُل: سبحان الله. وقال قومٌ: معناه: صَلِّ. والقولُ الأوَّلُ أصوب؛ لأنّه يناسب الذِّكْر، ويُستغرب مع امتناع الكلام مع الناس».</div></p><p><h3><span class="qpc-hafs">﴿وَٱذۡكُر رَّبَّكَ كَثِیرࣰا وَسَبِّحۡ بِٱلۡعَشِیِّ وَٱلۡإِبۡكَـٰرِ ۝٤١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٨٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: لا يكون العبدُ مِن الذاكرين الله كثيرًا حتى يذكر اللهَ قائِمًا ومُضْطَجِعًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٤١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظِيِّ</span> -من طريق أبي معشر- قال: لو رَخَّص الله لأحد في ترك الذِّكْرِ لَرَخَّص لزكريا ﵇، حيث قال: <span class="qpc-hafs">﴿آيتك ألا تكلم الناس ثلاثة أيّام إلا رمزًا واذكر ربّك كثيرًا﴾</span>، ولو رَخَّص لأحد في ترك الذِّكر لرَخَّص لِلَّذِين يُقاتِلون في سبيل الله، قال الله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا لقيتم فئة فاثبتوا واذكروا الله كثيرًا﴾</span> [الأنفال:٤٥]{36}. (٣/٥٣٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٣٨٤، وابن أبي حاتم ٢/٦٤٥.أخرجه ابن المنذر ١/١٩٣.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه الحاكم ٢/٢٩١.أخرجه ابن أبي حاتم ٢/٦٤٥.أخرجه ابن جرير ٥/٣٨٩.أخرجه الطستيُّ -كما في الإتقان ٢/٨٠-. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن أبي حاتم ٢/٦٤٥.أخرجه ابن جرير ٥/٣٨٧. وعلَّقه ابن أبي حاتم ٢/٦٤٦ عن عبد الرحمن بن جبير بن نفير.تفسير مجاهد ص٢٥٢.أخرجه ابن أبي حاتم ٢/٦٤٦.علَّقه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن جرير ٥/٣٨٨، وابن المنذر ١/١٩٤. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/٣٨٨، وابن أبي حاتم ٢/٦٤٦ بلفظ: كلام بالشفتين.أخرجه الثوري في تفسيره ص٧٧، وابن جرير ٥/٣٨٩. وعلَّقه ابن أبي حاتم ٢/٦٤٦ مختصرًا. وذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن المنذر ١/١٩٤. وعلَّقه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن جرير ٥/٣٩٠. وعلَّقه ابن أبي حاتم ٢/٦٤٦ مختصرًا.تفسير الثعلبي ٣/٦٦، وتفسير البغوي ٢/٣٦.أخرجه عبد الرزاق ١/١٢٠، وابن جرير ٥/٣٨٦، وابن المنذر ١/١٩٣ من طريق سعيد، وابن أبي حاتم ٢/٦٤٥. ولفظ عبد الرزاق وابن أبي حاتم هو: إيماء، وكانت عقوبةً عُوقِب بها، إذ سأل الآيةَ بعد مشافهة الملائكة إيّاه بما بشّرته. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ١/١٢٠، وابن جرير ٥/٣٩٠، وابن المنذر ١/١٩٥ من طريق سلّام بن أبي مُطيع. وعلَّقه ابن أبي حاتم ٢/٦٤٦ بلفظ: الإشارة.أخرجه ابن جرير ٥/٣٩٠.أخرجه ابن جرير ٥/٣٩٠. وعلَّقه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن أبي حاتم ٢/٦٤٥.أخرجه ابن المنذر ١/١٩٣.تفسير مجاهد ص٢٥٢.أخرجه ابن المنذر ١/١٩٤. وعلَّق ابن أبي حاتم ٢/٦٤٦ نحوه.أخرجه ابن جرير ٥/٣٨٦. وعلَّقه ابن أبي حاتم ٢/٦٤٦ بلفظ: الإشارة.تفسير مقاتل ١/٢٧٥.علَّقه ابن المنذر ١/١٩٣.أخرجه ابن جرير ٥/٣٨٩.أخرجه ابن جرير ٥/٣٨٩.أخرجه ابن جرير ٥/٣٩٢، وابن المنذر ١/١٩٥، وابن أبي حاتم ٢/٦٤٦-٦٤٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٦٤٦.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن جرير ٥/٣٩١، وابن المنذر (٤٤٥)، وابن أبي حاتم ٢/٦٤٦، وأبو نعيم ٣/٢١٥.
  3,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَتِ ٱلۡمَلَـٰۤىِٕكَةُ یَـٰمَرۡیَمُ إِنَّ ٱللَّهَ ٱصۡطَفَىٰكِ وَطَهَّرَكِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر ومقاتل، عن الضَّحّاك- قال: لَمّا وهَب اللهُ لزكريا يحيى، وبلغ ثلاث سنين؛ بشَّر اللهُ مريم بعيسى، فبينما هي في المحراب إذ قالت الملائكة -وهو جبريل وحده-: <span class="qpc-hafs">﴿يا مريم إن الله اصطفاك وطهرك﴾</span> مِن الفاحشة{1}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿إن الله اصطفاك وطهرك﴾</span>، قال: جعلك طيِّبَةً إيمانًا{2}<span class=comment-ref>١١٨٩</span>. (٣/٥٤١)</p></p><p></div></p><p><div><span class=comment-ref>١١٨٩</span> لم يذكر <u>ابنُ جرير</u> (٥/٣٩٦) غيرَ هذا القول.</div></p><p><div></p><p><p><span class="item-no">١٢٨٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق الحكم- <span class="qpc-hafs">﴿وطهرك﴾</span>، قال: مِن الحيض{3}<span class=comment-ref>١١٩٠</span>. (٣/٥٤١)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٠</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ عطية</u> (٢/٢١٧) على هذا القول بقوله: «وهذا يحتاج إلى سند قويٍّ، وما أحفظه».</div></p><p><div></p><p><p><span class="item-no">١٢٨٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذ قالت الملائكة﴾</span> وهو جبريل ﵇ وحده: <span class="qpc-hafs">﴿يامريم﴾</span> وهي في المحراب، <span class="qpc-hafs">﴿إن الله اصطفاك﴾</span> يعني: اختارك، <span class="qpc-hafs">﴿وطهرك﴾</span> مِن الفاحشة، والألم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱصۡطَفَىٰكِ عَلَىٰ نِسَاۤءِ ٱلۡعَـٰلَمِینَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٤٧<span class="dash">-</span></span> عن أبي هريرة -من طريق سعيد بن المُسَيِّب- في قوله: <span class="qpc-hafs">﴿إن الله اصطفاك وطهّرك واصطفاك على نساء العالمين﴾</span> أنّه كان يُحَدِّثُ عن رسول الله ﷺ أنّه قال: <b>«خيرُ نساءٍ رَكِبْن الإبِلَ نساءُ قريش؛ أحْناهُ على ولد في صِغَرِه، وأَرْعاهُ على زوجٍ في ذاتِ يدٍ»</b>. قال أبو هريرة: ولم تركب مريمُ بنتُ عمران بعيرًا قط{6}<span class=comment-ref>١١٩١</span>. (٣/٥٣٨)</p></p><p></div></p><p><div><span class=comment-ref>١١٩١</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ عطية</u> (٢/٢١٨) على زيادة أبي هريرة بقوله: «وهذه الزيادة فيها غَيْبٌ، فلا يُتَأَوّل أنّ أبا هريرة ﵄ قالها إلا عن سماع من النبي ﷺ».</div></p><p><div></p><p><p><span class="item-no">١٢٨٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر ومقاتل، عن الضحاك- قال: <span class="qpc-hafs">﴿واصطفاك﴾</span> يعني: اختارَكِ <span class="qpc-hafs">﴿على نساء العالمين﴾</span> عالَمِ أُمَّتِها{7}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحكم- <span class="qpc-hafs">﴿واصطفاك على نساء العالمين﴾</span>، قال: على نساء ذلك الزمان الذي هم فيه{3}. (٣/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واصطفاك﴾</span> يعني: واختاركِ <span class="qpc-hafs">﴿على نساء العالمين﴾</span> بالوَلَدِ مِن غير بَشَرٍ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿واصطفاك على نساء العالمين﴾</span>، قال: ذلك للعالمين يومئذ{10}<span class=comment-ref>١١٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٢</span> اختلف المفسرون في الاصطفاء هنا؛ أهُوَ على العموم أم على الخصوص؟ وذكر <u>ابنُ عطيّة</u> (٢/٢١٧) أنّ الآية تحتمل الوجهين، فقال: «إن جعلنا <span class="qpc-hafs">﴿العالَمِينَ﴾</span> عامًّا فيمن تقدَّم وتأخَّر جعلنا الاصطفاء مخصُوصًا في أمر عيسى ﵇، وأنًّها اصطُفِيَت لتَلِد مِن غير فَحْل، وإن جعلنا الاصطفاء عامًّا جعلنا قولَه تعالى: <span class="qpc-hafs">﴿العالَمِينَ﴾</span> مخصوصًا في عالَمِ ذلك الزمان».</div></p><p><div></p><p><p><span class="item-no">١٢٨٥٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: كانت مريمُ حَبيسًا في الكنيسة، ومعها في الكنيسة غلامٌ اسمُه يوسف، وقد كان أمُّه وأبوه جعلاه نَذيرًا حبيسًا، فكانا في الكنيسة جميعًا، وكانتْ مريم إذا نفِدَ ماؤُها وماءُ يوسف أخذا قُلَّتَيْهما فانطلقا إلى المَغارَة التي فيها الماء، فيملَآنِ ثُمَّ يرجعان، والملائكة في ذلك مُقْبِلة على مريم: <span class="qpc-hafs">﴿يا مريم إن الله اصطفاك وطهرك واصطفاك على نساء العالمين﴾</span>. فإذا سمع ذلك زكريا قال: إنّ لابنةِ عمران لَشَأْنًا{11}<span class=comment-ref>١١٩٣</span>. (٣/٥٤١)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٣</span> اختُلِف في نبوّة السّيّدة مريم، قال <u>ابنُ عطية</u> (٢/٢١٨): «وقد قال بعضُ الناس: إنّ مريم نبيّة. قال ابن إسحاق: فمِن مخاطبة الملائكة لها جعلها هذا القائلُ نَبِيَّة». ثم قال بعد ذلك: «و<span class="mustanad">جمهور الناس</span> على أنّه لم تُنَبَّإ امرأةٌ».</div></p><p><h3><span class="qpc-hafs">﴿وَٱصۡطَفَىٰكِ عَلَىٰ نِسَاۤءِ ٱلۡعَـٰلَمِینَ ۝٤٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٨٥٣<span class="dash">-</span></span> عن فاطمة، قالت: قال لي رسول الله ﷺ: <b>«أنتِ سيِّدةُ نساء أهل الجنة، إلا مريم البَتُول»</b>{12}. (٣/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥٤<span class="dash">-</span></span> عن علي بن أبي طالب، قال: سمعتُ رسول الله يقول: <b>«خيرُ نسائها مريمُ بنت عمران، وخيرُ نسائها خديجةُ بنت خويلد»</b>{13}<span class=comment-ref>١١٩٤</span>. (٣/٥٣٨)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٥/٣٩٣) على هذا الحديث بقوله: «يعني بقوله: «خير نسائها»: خير نساء أهل الجنة».</p><p>وقال <u>ابنُ عطية</u> (٢/٢١٨) بعد ذكره لهذه الأحاديث: «وإذا تأمّلت هذه الأحاديث وغيرَها مِمّا هو في معناها: وجَدتَ مريم فيها متقدِّمة، فسائغٌ أن يُتَأَوَّل عمومُ الاصطفاء على العالَمِينَ عمومًا أيضًا».</div></p><p><div></p><p><p><span class="item-no">١٢٨٥٥<span class="dash">-</span></span> عن عبد الله بن عبّاس، قال: قال رسول الله ﷺ: <b>«أفضلُ نساء العالمين خديجةُ بنت خويلد، وفاطمةُ، ومريمُ، وآسيةُ امرأة فرعون»</b>{14}. (٣/٥٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: <b>«سيِّدةُ نساء أهل الجنة مريمُ بنت عمران، ثم فاطمةُ، ثم خديجةُ، ثم آسيةُ امرأة فرعون»</b>{15}. (٣/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥٧<span class="dash">-</span></span> عن ابن عباس -من طريق الضحاك- عن النبي ﷺ، قال: <b>«أربعُ نسوة سيّداتُ عالَمِهِنَّ: مريم بنت عمران، وآسية بنت مزاحم، وخديجة بنت خويلد، وفاطمة بنت محمّد، وأفضلُهنَّ عالَمًا فاطمة»</b>{16}. (٣/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥٨<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: <b>«إنّ الله اصطفى على نساء العالمين أربعًا: آسية بنت مزاحم، ومريم بنت عمران، وخديجة بنت خويلد، وفاطمة بنت محمد»</b>{17}. (٣/٥٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٥٩<span class="dash">-</span></span> عن أبي موسى، قال: قال رسول الله ﷺ: <b>«كَمُل من الرِّجال كثير، ولم يكمُل من النساء إلا مريم بنت عمران، وآسية امرأة فرعون. وفَضْلُ عائشةَ على النساء كفَضْل الثَّرِيدِ على الطعام»</b>{18}. (٣/٥٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٠<span class="dash">-</span></span> عن أنس بن مالك، أنّ رسول الله ﷺ قال: <b>«حسبُك مِن نساء العالمين مريم بنت عمران، وخديجة بنت خويلد، وفاطمة بنت محمد، وآسية امرأة فرعون»</b>{19}. (٣/٥٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦١<span class="dash">-</span></span> وعن الحسن البصري، نحوه{20}. (٣/٥٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٢<span class="dash">-</span></span> عن عمّار بن سعد، قال: قال رسول الله ﷺ: <b>«فُضِّلَتْ خديجةُ على نساء أُمَّتِي، كما فُضِّلَتْ مريمُ على نساء العالمين»</b>{21}. (٣/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٣<span class="dash">-</span></span> عن عبد الرحمن بن أبي ليلى، قال: قال رسول الله ﷺ: <b>«فاطمةُ سيِّدةُ نساء العالمين بعد مريم ابنة عمران، وآسية امرأة فرعون، وخديجة ابنة خويلد»</b>{22}. (٣/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٤<span class="dash">-</span></span> عن مكحول، قال: قال رسول الله ﷺ: «<b>خيرُ نساء رَكِبْن الإبل نساء قريش؛ أحْناه على ولدٍ في صِغَرِه، وأَرْعاه على بَعْلٍ في ذات يده، ولو عَلِمْتُ أنّ مريم ابنة عمران ركِبَتْ بعيرًا ما فَضَّلتُ عليها أحَدًا»</b>{23}. (٣/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٥<span class="dash">-</span></span> عن قتادة بن دِعامة -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإذ قالت الملائكة يا مريم إن الله اصطفاك وطهّرك واصطفاك على نساء العالمين﴾</span>، قال: ذُكِر لنا: أنّ نبي الله ﷺ كان يقول: <b>«حسبُك بمريم بنت عمران، وامرأة فرعون، وخديجة بنت خويلد، وفاطمة بنت محمد مِن نساء العالمين»</b>{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٤٧/٣٤٧-٣٤٨ من طريق إسحاق بن بشر. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ٥/٣٩٦، وابن المنذر ١/١٩٦ من طريق ابن جريج، وابن أبي حاتم ٢/٦٤٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٢/٦٤٧.علَّقه ابن أبي حاتم ٢/٦٤٧.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه عبد الرزاق في تفسيره ١/٣٩٣ (٤٠٠)، وابن المنذر ١/١٩٧ (٤٥١)، وابن أبي حاتم ٢/٦٤٧ (٣٤٨٨). وأخرجه البخاري ٤/١٦٤ (٣٤٣٤)، ٧/٦ (٥٠٨٢)، ٧/٦٦ (٥٣٦٥)، ومسلم ٤/١٩٥٨ (٢٥٢٧)، ٤/١٩٥٩ (٢٥٢٧) دون ذكر الآية.أخرجه ابن عساكر ٤٧/٣٤٧- ٣٤٨ من طريق إسحاق بن بشر. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم ٢/٦٤٧.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه ابن جرير ٥/٣٩٦.أخرجه ابن جرير ٥/٣٩٧.أخرجه ابن أبي شيبة ٦/٣٨٨ (٣٢٢٧٠)، وابن جرير ٥/٣٩٥. وأصله في البخاري ٤/٢٠٣ (٣٦٢٤) دون ذكر مريم.أخرجه البخاري ٤/١٦٤ (٣٤٣٢)، ٥/٣٨ (٣٨١٥)، ومسلم ٤/١٨٨٦ (٢٤٣٠).أخرجه أحمد في مسنده ٤/٤٠٩ (٢٦٦٨)، والحاكم ٢/٦٥٠ (٤١٦٠)، واللفظ للحاكم من طريق داود بن أبي الفرات، عن علباء بن أحمر، عن عكرمة، عن ابن عباس به.</p><p>قال الحاكم: «صحيح الإسناد، ولم يخرجاه بهذا اللفظ». وصحّحه ابن حبان ١٥/٤٧٠ (٧٠١٠)، واختاره الضياء المقدسي في المختارة ١٢/١٦٧ (١٨٧)، وقال ابن حجر في فتح الباري ٦/٤٧١: «إسناده صحيح». وصحّحه الألباني في الصحيحة ٤/١٣.أخرجه الطبراني في الكبير ١١/٤١٥ (١٢١٧٩)، ٢٣/٧ (٢)، والأوسط ٢/٢٣ (١١٠٧) من طريق عبد العزيز بن محمد، عن إبراهيم بن عقبة، عن كريب، عن ابن عباس به.</p><p>قال الطبراني في الأوسط: «لم يروِ هذا الحديثَ عن إبراهيم إلا الدَّراورْدِيُّ، ولا يُرْوى عن ابن عباس إلا بهذا الإسناد». وقال الهيثمي في المجمع ٩/٢٠١ (١٥١٩٠): «رواه الطبراني في الأوسط والكبير بنحوه، إلا أنه قال: وآسية. ورجال الكبير رجال الصحيح». وسبق تخريجه قبل قليل من طريق آخر عن ابن عباس، وقد صحَّحه جمعٌ من الأئمة.أخرجه ابن عساكر في تاريخه ٧٠/١٠٧-١٠٨ (١٣٨٠٥) من طريق إسحاق بن إبراهيم شاذان، عن سعد بن الصلت، عن مقاتل، عن الضحاك، عن ابن عباس به.</p><p>وفي سنده إسحاق بن إبراهيم شاذان، قال عنه ابن حجر في لسان الميزان ٢/٣٣: «له مناكير وغرائب».عزاه السيوطي إلى ابن مردويه.أخرجه البخاري ٤/١٥٨ (٣٤١١)، ٤/١٦٤ (٣٤٣٣)، ٥/٢٩ (٣٧٦٩)، ٧/٧٥ (٥٤١٨)، ومسلم ٤/١٨٨٦ (٢٤٣١).أخرجه الترمذي ٦/٣٩٢ (٤٢١٦)، وأحمد ١٩/٣٨٣ (١٢٣٩١).</p><p>قال الترمذي: «حديث صحيح». وصحَّحه ابنُ حبان ١٥/٤٦٤ (٧٠٠٣)، وقال الحاكم ٣/١٧٢ (٤٧٤٦): «حديث صحيح، على شرط الشيخين، ولم يخرجاه بهذا اللفظ؛ فإنّ قوله ﷺ: «حسبك من نساء العالمين» يسوي بين نساء الدنيا». واختاره الضياء المقدسي في المختارة ٧/٢١ (٢٤٠١)، وقال ابن حجر في الفتح ٦/٤٧١: «بإسناد صحيح». وأورده الألباني في الصحيحة ٤/١٣ (١٥٠٨).أخرجه ابن أبي شيبة ٦/٣٩١ (٣٢٢٩١)، وأحمد في فضائل الصحابة ٢/٨٥٠ (١٥٧٥) عن الحسن مرسلًا.أخرجه ابن جرير ٥/٣٩٦ من طريق ابن لهيعة، عن عمرو بن الحارث، عن أبي زياد الحميري، عن عمار بن سعد به. وأخرجه البزار ٤/٢٥٥ (١٤٢٧) بالإسناد نفسه، إلا أنّه قال: عن أبي يزيد الحميري عن عمار بن ياسر به.</p><p>قال ابن حجر في الفتح ٧/١٣٥: «حسن الإسناد». و قال الهيثمي في المجمع ٩/٢٢٣ (١٥٢٧٠): «وفيه أبو يزيد الحميري ولم أعرفه، وبقيّة رجاله وثّقوا». وقال الشيخ أحمد شاكر في تحقيقه لتفسير الطبري ٦/٤٠٠: «هذا إسناد ضعيف بكل حال. أما أبو زياد الحميري فلم نعرف مَن هو؟ ولم نجد له ترجمة ولا ذِكرًا، والغالب أنه مُحَرَّف عن شيء لا ندريه. وأما عمار بن سعد بن عابد المؤذن فإنّه المعروف أبوه بلقب: سعد القرظ المؤذن. وعمّار هذا تابعيٌّ، نصَّ في التهذيب على أنّ روايته عن النّبي ﷺ مُرْسَلة. وقد ترجمه الحافظ في الإصابة ٥/٨٣، في القسم الثاني، الذين ولدوا في حياة رسول الله ﷺ».أخرجه ابن أبي شيبة ٦/٣٨٨ (٣٢٢٧٣) مرسلًا.أخرجه ابن أبي شيبة ٦/٤٠٣ (٣٢٤٠٢) مرسلًا.أخرجه ابن جرير ٥/٣٩٣.</p><p>قال الشيخ أحمد شاكر: «حديث مرسل».
  3,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰمَرۡیَمُ ٱقۡنُتِی لِرَبِّكِ وَٱسۡجُدِی وَٱرۡكَعِی مَعَ ٱلرَّ ٰ⁠كِعِینَ ۝٤٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٢٨٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق النزال- أنّه كان يقرأ: (وارْكَعِي واسْجُدِي فِي السّاجِدِينَ){1}. (٣/٥٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰمَرۡیَمُ ٱقۡنُتِی لِرَبِّكِ وَٱسۡجُدِی وَٱرۡكَعِی مَعَ ٱلرَّ ٰ⁠كِعِینَ ۝٤٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٢٨٦٧<span class="dash">-</span></span> عن أبي سعيد الخُدْرِيِّ -من طريق درّاجٍ- عن النبي ﷺ، قال: <b>«كُلُّ حرف يُذْكر فيه القنوتُ مِن القرآن فهو طاعةٌ لله»</b>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قال في قوله: <span class="qpc-hafs">﴿يا مريم اقنتي لربّك﴾</span>: يعني: صلّي لربّك، يقول: اركُدِي لربّك في الصلاة بطول القيام. فكانت تقوم حتى ورِمت قدماها، <span class="qpc-hafs">﴿واسجدي واركعي مع الراكعين﴾</span> يعني: مع المصلين، مع قُرّاء بيت المقدس{3}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٦٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿يا مريم اقنتي لربك﴾</span>: أي: اركُدِي لربك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- <span class="qpc-hafs">﴿اقنتي لربّك﴾</span>، قال: أخْلِصي{5}. (٣/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يا مريم اقنتي لربّك﴾</span>، قال: أطِيلي الرُّكود في الصلاة. يعني: القيام{6}. (٣/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحَكَم بن عتيبة- في قوله: <span class="qpc-hafs">﴿يا مريم اقنتي لربك واسجدي﴾</span>، قال: طول الركوع في الصلاة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- في قوله: <span class="qpc-hafs">﴿يا مريم اقنتي لربك﴾</span>، قال: يقول: اعبدي ربّك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿اقنتي لربّك﴾</span>، قال: أطيعي ربّك{9}. (٣/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿اقنتي لربك﴾</span>، قال: أطيعي ربّك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿يا مريم اقنتي لربك﴾</span> قال: القنوت: الرُّكود. يقول: قومي لربِّك في الصَّلاة. يقول: اركُدِي لربِّك، أي: انتصبي له في الصّلاة، <span class="qpc-hafs">﴿واسجدي واركعي مع الراكعين﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يامريم اقنتي لربك﴾</span> يعني: لربك، <span class="qpc-hafs">﴿واسجدي واركعي مع الراكعين﴾</span> يعني مع المصلِّين في بيت المقدس{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٧٨<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق أبي عبيد الله المخزومي- في قوله تعالى: <span class="qpc-hafs">﴿يا مريم اقنتي لربك﴾</span>، قال: القنوتُ: طاعةُ الله تعالى{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰمَرۡیَمُ ٱقۡنُتِی لِرَبِّكِ وَٱسۡجُدِی وَٱرۡكَعِی مَعَ ٱلرَّ ٰ⁠كِعِینَ ۝٤٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٨٧٩<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد</span> -من طريق عطيَّة- قال: كانت مريم تُصلِّي حتى تَرِمَ قدماها{14}. (٣/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: لَمّا قيل لها: <span class="qpc-hafs">﴿اقنتي لربّك﴾</span> قامَت حتى ورِمَت قدماها{15}<span class=comment-ref>١١٩٥</span>. (٣/٥٤٢)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٥</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ كثير</u> (٣/٦١ بتصرف) على قول مجاهد بقوله: «وقال مجاهد: يعني: امتثالًا لقوله تعالى: <span class="qpc-hafs">﴿يا مريم اقنتي لربك﴾</span>».</div></p><p><div></p><p><p><span class="item-no">١٢٨٨١<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي كَثِير</span> -من طريق الأوزاعي- في قوله تعالى: <span class="qpc-hafs">﴿يا مريم اقنتي لربك﴾</span>، قال: سجدتْ حتى نزل الماءُ الأصفرُ في عينيها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن عمرو الأوزاعي</span> -من طريق عمرو- قال: كانت مريمُ تقوم حتى يسيل القَيْحُ مِن قدميها{17}. (٣/٥٤٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ص٥٤.</p><p>وهي قراءة شاذة. انظر: روح المعاني ٣/١٥٨.أخرجه أحمد ١٨/٢٣٩ (١١٧١١)، وابن حبان ٢/٧ (٣٠٩)، وابن جرير ٥/٤٠٠ من طريق درّاج، عن أبي الهيثم، عن أبي سعيد به.</p><p>صحّحه ابن حبان. وقال ابن كثير في تفسيره ١/٣٩٨: «هذا الإسناد ضعيف لا يعتمد عليه، ورَفْعُ هذا الحديث منكر، وقد يكون من كلام الصحابيِّ أو مَن دونه، والله أعلم. وكثيرًا ما يأتي بهذا الإسناد تفاسيرُ فيها نكارة، فلا يُغْتَرُّ بها؛ فإنّ السند ضعيف». وقال الهيثمي في المجمع ٦/٣٢٠ (١٠٨٦٨): «في إسناد أحمد وأبي يعلى ابن لهيعة، وهو ضعيف، وقد يحسن حديثه». وقال المناوي في فيض القدير ٥/١٨ (٦٢٩٧) بعد نقله كلام الهيثمي: «وفيه أيضًا درّاج عن أبي الهيثم، وقد سبق أنّ أبا حاتم وغيره ضعّفوه، وأنّ أحمد قال: أحاديثه مناكير». وقال الألباني في الضعيفة ٩/١٠٦ (٤١٠٥): «ضعيف».أخرجه ابن عساكر ٧٠/٨٨.أخرجه ابن أبي حاتم ٢/٦٤٨.أخرجه ابن جرير ٥/٣٩٩.أخرجه ابن جرير ٥/٣٩٨ بلفظ: «يعني: القنوت» في آخره. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٨- نحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه الثوري في تفسيره ص٧٧، وابن المنذر ١/١٩٧، وأبو جعفر الرملي في جزئه ص٧٥ -تفسير مسلم الزنجي (جزء فيه تفسير يحيى بن يمان، ونافع بن أبي نعيم، ومسلم الزنجي، وعطاء الخراساني)-. وأبو نعيم في حلية الأولياء ٣/٢٩٨ من طريق أبي ليلى. وفي الطبري والدُّرِّ عنه: أطيلي الركود. وفسّرها الأوّل بالقنوت، والثاني بالقيام. وأشار محقق الطبري إلى أنّه في إحدى النسخ: الركوع.أخرجه ابن جرير ٥/٤٠٠، وابن أبي حاتم ٢/٦٤٨.أخرجه عبد الرزاق ١/١٢١، وابن جرير ٥/٤٠٠، وابن المنذر ١/١٩٨.أخرجه ابن جرير ٥/٤٠٠.أخرجه ابن جرير ٥/٣٩٨.تفسير مقاتل بن سليمان ١/٢٧٦.أخرجه ابن عساكر في تاريخ دمشق ٧٠/١٠١.أخرجه ابن عساكر ٧٠/١٠٠.أخرجه عَبد بن حُمَيد كما في قطعة من تفسيره ص٣٠، وابن المنذر ١/١٩٧، وابن أبي حاتم ٢/٦٤٨ من طريق ليث. وعزاه السيوطي إلى ابن جرير.أخرجه ابن عساكر في تاريخ دمشق ٧٠/١٠١.أخرجه ابن جرير ٥/٣٩٩، وابن أبي حاتم ٢/٦٤٨ من طريق الوليد بلفظ: رَكَدتْ في محرابها قائمةً وراكعةً وساجدةً، حتى نزل الماء الأصفر من قدميها.
  3,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مِنۡ أَنۢبَاۤءِ ٱلۡغَیۡبِ نُوحِیهِ إِلَیۡكَۚ وَمَا كُنتَ لَدَیۡهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قال: يقول الله لنبيه ﷺ: <span class="qpc-hafs">﴿ذلك من أنباء الغيب نوحيه إليك﴾</span> يعني: بالخَبَر الغَيْب في قِصَّة زكريا ويحيى ومريم، <span class="qpc-hafs">﴿وما كنت لديهم﴾</span> يعني: عندهم <span class="qpc-hafs">﴿إذ يلقون أقلامهم﴾</span> في كفالة مريم{1}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span> -من طريق السدي- قوله: <span class="qpc-hafs">﴿أنباء﴾</span> يعني: أحاديث، <span class="qpc-hafs">﴿لديهم﴾</span> يعني: عندهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- في قوله: <span class="qpc-hafs">﴿وما كنت لديهم إذ يلقون أقلامهم﴾</span>، قال: حيث اقترعوا على مريم، وكان غيبًا عن محمد ﷺ حين أُخْبِرَه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما كنت لديهم﴾</span>: يعني: محمدًا ﷺ{4}. (٣/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> أنّ الذي ذُكِر في هؤلاء الآيات <span class="qpc-hafs">﴿من أنباء الغيب﴾</span> يعني: حديثًا من الغيب لَمْ تشهدْه، يا محمد، فذلك قوله: <span class="qpc-hafs">﴿نوحيه إليك وما كنت لديهم إذ يلقون أقلامهم﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٨٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبد الله بن إدريس- قوله: <span class="qpc-hafs">﴿ذلك من أنباء الغيب نوحيه إليك﴾</span>، ثُمَّ قد جئتَهم به دليلًا على نُبُوَّتِك، والحُجَّةُ لك عليهم، <span class="qpc-hafs">﴿وما كنت لديهم﴾</span> يقول: ما حضرتَ، ولا عينت{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ یُلۡقُونَ أَقۡلَـٰمَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: <span class="qpc-hafs">﴿أقلامهم﴾</span>، قال: التي يكتبون بها التَّوْراة{6}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، مثله{8}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أقلامهم﴾</span>: سهامهم، يعني: قِداحهم التي اسْتَهَمُوا بها عليها، فخرج قِدْحُ زكريا فضمّها، فيما قال{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: <span class="qpc-hafs">﴿أقلامهم﴾</span>، يقول: عِصِيَّهم{10}. (٣/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿أقلامهم﴾</span>، يعني: قِداحَهم{11}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٤<span class="dash">-</span></span> عن سعيد بن إسحاق الدمشقي -من طريق عبّاس الحذاء- في قول الله ﷿: <span class="qpc-hafs">﴿إذ يلقون أقلامهم أيّهم يكفل مريم﴾</span>، قال: على نهرٍ بحَلَب، يُقال له: قُوَيْق{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَیُّهُمۡ یَكۡفُلُ مَرۡیَمَ وَمَا كُنتَ لَدَیۡهِمۡ إِذۡ یَخۡتَصِمُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٨٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وما كنت لديهم إذ يلقون أقلامهم أيهم يكفل مريم﴾</span>، قال: إنّ مريم ﵍ لَمّا وُضِعَتْ في المسجد اقْتَرَع عليها أهلُ الـمُصَلّى وهم يكتبون الوحي، فاقْتَرَعوا بأقلامهم أيُّهم يكفلُها، فقال الله لمحمد ﷺ: <span class="qpc-hafs">﴿وما كنت لديهم إذ يلقون أقلامهم أيهم يكفل مريم وما كنت لديهم إذ يختصمون﴾</span>{13}. (٣/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿إذ يلقون أقلامهم﴾</span>، قال: زكريا وأصحابه، اسْتَهَمُوا بأقلامهم على مريم حين دخلت عليهم، فَسَهَمَهُم بقلمه زكريا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عُبَيْد- يقول في قوله: <span class="qpc-hafs">﴿إذ يلقون أقلامهم أيهم يكفل مريم﴾</span>: اقْتَرَعُوا بأقلامهم أيُّهم يكفل مريم، فَقَرَعهم زكريا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النَّضْر بن عَرَبِيٍّ- في قوله: <span class="qpc-hafs">﴿إذ يلقون أقلامهم أيّهم يكفل مريم﴾</span>، قال: ألْقَوْا أقلامَهم في الماءِ، فذَهَبَتْ مع الجِرْيَة، وصعِد قلمُ زكريا، فكفلها زكريا{16}. (٣/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٨٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إذ يلقون أقلامهم﴾</span>، قال: تَساهَمُوا على مريم أيُّهم يكفُلها، فقَرَعَهُم زكريّا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما كنت لديهم إذ يلقون أقلامهم أيّهم يكفُل مريم وما كنت لديهم إذ يختصمون﴾</span>، قال: كانت مريمُ ابنةَ إمامهم وسيِّدهم، فتشاجر بنو إسرائيل، فاقترعوا فيها بسهامهم أيُّهم يكفُلها، فقرعهم زكريّا، فكفلها زكريا، يقول: ضمّها إليه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: ألْقَوْا أقلامَهم -يقول: عِصيَّهم- تِلْقاء جِرْيَةِ الماء، فاستقبلت عصا زكريا جِرْيَةِ الماء، فقرَعهم{10}. (٣/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿وما كنت لديهم إذ يختصمون﴾</span>: أي: ما كنت معهم إذ يختصمون فيها، يخبره بخفيِّ ما كتموا منه من العلم عندهم؛ لتحقيق نُبُوَّتِه والحجّة عليهم لِما يأتيهم به مِمّا أخْفَوْا منه{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-، مثله{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ يلقون أقلامهم﴾</span> في القُرْعة <span class="qpc-hafs">﴿أيُّهم يكفل مريم﴾</span> يعني: يضمُّ مريم إلى نفسه، <span class="qpc-hafs">﴿وما كنت لديهم﴾</span> يا محمّد <span class="qpc-hafs">﴿إذ يختصمون﴾</span> في مريم، يعني: القرّاء أيُّهم يكفلها{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٧٠/٨٩.أخرجه ابن أبي حاتم ٢/٦٤٨، ٦٥٠.أخرجه ابن جرير ٥/٤٠٥.أخرجه ابن جرير ٥/٤٠٣.تفسير مقاتل بن سليمان ١/٢٧٦.أخرجه ابن أبي حاتم ٢/٦٤٩.أخرجه ابن أبي حاتم ٢/٦٤٩.عزاه السيوطي إلى عَبد بن حُمَيد.ذكره ابن هشام في السيرة ١/٥١٥.أخرجه ابن جرير ٥/٣٤٨، وابن أبي حاتم ٢/٦٥٠.أخرجه ابن أبي حاتم ٢/٦٤٩، وابن المنذر ١/١٩٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن عساكر في تاريخ دمشق ١١/٢١.أخرجه ابن جرير ٥/٤٠٤، وابن أبي حاتم ٢/٦٤٩.أخرجه ابن المنذر ١/١٩٨، وأخرج ابن جرير ٥/٤٠٣ نحوه من طريق ابن أبي نجيح. وعلَّقه ابن أبي حاتم ٢/٦٤٩.أخرجه ابن جرير ٥/٤٠٥. وعلَّقه ابن أبي حاتم ٢/٦٤٩.أخرجه ابن جرير ٥/٣٤٨، وابن أبي حاتم ٢/٦٤٩.أخرجه عبد الرزاق ١/١٢١، وابن جرير ٥/٤٠٤، وابن أبي حاتم ٢/٦٤٩.أخرجه ابن جرير ٥/٤٠٤، ومن طريق معمر أيضًا مختصرًا، وابن المنذر ١/١٩٩، وابن أبي حاتم ٢/٦٥٠ من طريق شيبان.أخرجه ابن جرير ٥/٣٤٨، وابن أبي حاتم ٢/٦٥٠.أخرجه ابن جرير ٥/٤٠٦.أخرجه ابن أبي حاتم ٢/٦٥٠.تفسير مقاتل بن سليمان ١/٢٧٦.
  3,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَتِ ٱلۡمَلَـٰۤىِٕكَةُ یَـٰمَرۡیَمُ إِنَّ ٱللَّهَ یُبَشِّرُكِ بِكَلِمَةࣲ مِّنۡهُ ٱسۡمُهُ ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ وَجِیهࣰا فِی ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِ وَمِنَ ٱلۡمُقَرَّبِینَ ۝٤٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٢٩٠٥<span class="dash">-</span></span> عن الأعمش، في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وقالَتِ المَلَآئِكَةُ يا مَرْيَمُ إنَّ اللهَ لَيُبَشِّرُكِ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَتِ ٱلۡمَلَـٰۤىِٕكَةُ یَـٰمَرۡیَمُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٩٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إذ قالت الملائكة يا مريم إن الله يبشرك﴾</span>، قال: شافَهَتْها الملائكةُ بذلك{2}. (٣/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ قالت الملائكة يا مريم﴾</span>، وهو جبريلُ وحده ﵇{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٠٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبد الله بن إدريس- قال: ثُمَّ أخبره خبرَ مريم وعيسى حين ابتدأها مِن كرامة الله بِما آتاها: <span class="qpc-hafs">﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه اسمه المسيح عيسى ابن مريم﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یُبَشِّرُكِ بِكَلِمَةࣲ مِّنۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عبّاس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿يبشرك بكلمة منه﴾</span>، قال: عيسى هو الكلمة مِن الله{5}<span class=comment-ref>١١٩٦</span>. (٣/٥٤٧)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٦</span> ذكر <u>ابنُ جرير</u> (٥/٤٠٧) أنّ هناك مَن ذهبوا إلى أنّ الكلمة هي اسمٌ سمّاه الله لعيسى، كما سَمّى سائرَ خلقه بما شاء من الأسماء، وأدخل قولَ ابن عباس في هذا القول.</p><p>و<span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٢/٢٢١) صنيعَ <u>ابن جرير</u>، فقال: «وقولُ ابن عباس يَحْتَمِل أن يُفَسَّر بما قال قتادة [من أنّ المراد بالكلمة قوله: <span class="qpc-hafs">﴿كن﴾</span>] وبغير ذلك مما سنذكره الآن، وليس فيه شيءٌ مما ادَّعى الطبريُّ ﵀. وقال قومٌ من أهل العلم: سماه الله (كلمة) من حيث كان تقدَّم ذكره في توراة موسى وغيرها مِن كتب الله، وأنّه سيكون، فهذه كلمةٌ سَبَقَتْ فيه من الله، فمعنى الآية: أنتِ -يا مريمُ- مُبَشَّرَة بأنّك المخصوصةُ بولادة الإنسان الذي قد تكلَّم الله بأمره، وأخبر به في ماضي كتبه المنزلة على أنبيائه. و<span class="qpc-hafs">﴿اسْمُهُ﴾</span> في هذا الموضع معناه: تسميته، وجاء الضمير مُذَكَّرًا من أجل المعنى؛ إذ (الكلمة) عبارة عن ولد».</div></p><p><div></p><p><p><span class="item-no">١٢٩١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- قوله: <span class="qpc-hafs">﴿بكلمة منه﴾</span>، قال: قوله: كُن{6}<span class=comment-ref>١١٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٧</span> قال <u>ابنُ جرير</u> <span class="comment-type-4">مُعَلِّقًا</span> (٥/٤٠٧): «فسمّاهُ الله ﷿ كلمتَه [يعني: على هذا القول]؛ لأنّه كان عن كلمته، كما يُقال لِما قدَّر اللهُ مِن شيء: هذا قدرُ الله وقضاؤه. يعني به: هذا عن قدر الله وقضائه حدَثَ، وكما قال -جلَّ ثناؤه-: <span class="qpc-hafs">﴿وكان أمر الله مفعولًا﴾</span> [النساء:٤٧]، يعني به: ما أمر اللهُ به، وهو المأمور الذي كان عن أمر الله ﷿».</p><p>وبنحوه قال <u>ابنُ عطية</u> (٢/٢٢١).</div></p><p><div></p><p><p><span class="item-no">١٢٩١١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبد الله بن إدريس-: <span class="qpc-hafs">﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه﴾</span>، أي: بولدٍ لا أبَ له{4}<span class=comment-ref>١١٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٨</span> ذكر <u>ابنُ جرير</u> (٥/٤٠٧) في تفسير الكلمة ثلاثة أقوال، أحدها: أنّ المراد بها: رسالةٌ من الله، وخَبَرٌ مِن عنده. ولم ينسبه لأحد. وثانيها: أنّ الكلمة التي قالها الله هي:كن. وثالثها: أنّ الكلمة هي اسم لعيسى سمّاه الله به كما سمّى سائرَ الخلائق بما شاء من الأسماء.</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> القولَ الأول <span class="mustanad">مُسْتنِدًا إلى اللغة</span>، فقال: «ولذلك قال ﷿: <span class="qpc-hafs">﴿اسمه المسيح﴾</span>. فذكَّر، ولم يقل: اسمها. فيؤنث، والكلمة مؤنثة؛ لأنّ الكلمة غير مقصود بها قصد الاسم الذي هو بمعنى فلان، وإنما هي بمعنى: البشارة، فذُكّرت كنايتُها كما تُذَكّر كناية الذُّرِّيَّة، والدابَّة، والألقاب».</div></p><p><h3><span class="qpc-hafs">﴿ٱسۡمُهُ ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٩١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: لم يكن مِن الأنبياء مَن له اسمان إلّا عيسى، ومحمد ﵉{4}. (٣/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: سُمِّي مَسيحًا لأنّه ما مَسَحَ ذا عاهَةٍ إلا بَرِئَ{9}<span class=comment-ref>١١٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٩٩</span> ذكر <u>ابنُ عطيّة</u> (٢/٢٢١) أنّ اشتقاق لفظة <span class="qpc-hafs">﴿المسيح﴾</span> على هذا القول (فعيل) بمعنى: (فاعل).</div></p><p><div></p><p><p><span class="item-no">١٢٩١٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعِيِّ</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿المسيح﴾</span>: الصِّدِّيقُ{10}<span class=comment-ref>١٢٠٠</span>. (٣/٥٤٧)</p></p><p></div></p><p><div><span class=comment-ref>١٢٠٠</span> ذَكَرَ <u>ابنُ جرير</u> (٥/٤٠٩) أنّ المسيح: فعيل، صُرِف مِن (مفعول) إلى (فعيل)، وإنّه ممسوح، يعني: مسحه الله فطهَّره مِن الذُّنوب، ثُمَّ قال: «ولذلك قال إبراهيم: ...».</div></p><p><div></p><p><p><span class="item-no">١٢٩١٥<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعِيِّ</span> -من طريق منصور- مثله، أي: مُسِحَ بالبركة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿اسمه المسيح﴾</span>: أي: مُسِحَ بالبركة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩١٧<span class="dash">-</span></span> عن <span class="name-2">أبي عمرو بن العلاء</span>، أنّه قال: <span class="qpc-hafs">﴿المسيحُ﴾</span>: الـمَلِكُ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩١٨<span class="dash">-</span></span> عن <span class="name-3">يحيى بن عبد الرحمن الثقفي</span> -من طريق سعيد ابن أبي هلال-: أنّ عيسى كان سائِحًا، ولذلك سُمِّي المسيح؛ كان يُمسي بأرضٍ ويُصْبِح بأخرى، وأنّه لم يَتَزَوَّج حتى رُفِع{4}. (٣/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩١٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكَلْبِيُّ</span>: سُمِّيَ بذلك لأنّه كان يمسحُ عينَ الأعمى، فيُبْصِر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٠<span class="dash">-</span></span> عن <span class="name-3">سعيد</span> -من طريق عمرو بن أبي سلمة- قال: إنّما سُمِّي المسيح لأنّه مُسِحَ بالبَرَكَة{16}<span class=comment-ref>١٢٠١</span>. (٣/٥٤٧)</p></p><p></div></p><p><div><span class=comment-ref>١٢٠١</span> ذكر <u>ابنُ عطية</u> (٢/٢٢١) أنّ اشتقاق لفظة <span class="qpc-hafs">﴿المسيح﴾</span> على هذا القول (فعيل) بمعنى: (مفعول).</div></p><p><h3><span class="qpc-hafs">﴿وَجِیهࣰا فِی ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِ وَمِنَ ٱلۡمُقَرَّبِینَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٩٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر ومقاتل، عن الضحاك- قال: ثُمَّ قال: يا محمد. يُخبِر بقِصَّة عيسى: <span class="qpc-hafs">﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه اسمه المسيح عيسى ابن مريم وجيهًا في الدنيا﴾</span> يعني: مَكِينًا عند الله في الدنيا، <span class="qpc-hafs">﴿ومن المقرّبين﴾</span> في الآخرة{17}. (٣/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومن المقرّبين﴾</span>، يقول: ومِن المقرَّبين عند الله يوم القيامة{18}. (٣/٥٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿ومن المقرّبين﴾</span>، يقول: مِن المقرَّبين عند الله يوم القيامة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿وجيهًا﴾</span>، قال: وجيهًا في الدُّنيا والآخرة عند الله{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه اسمه المسيح عيسى ابن مريم وجيهًا في الدنيا والآخرة ومن المقربين﴾</span>: أي: هكذا كان أمرُه، لا ما يقولون فيه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق زياد-، مثله{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجيهًا﴾</span> يعني: مَكِينًا عند الله ﷿ <span class="qpc-hafs">﴿في الدنيا والآخرة﴾</span> فيها تقديم، <span class="qpc-hafs">﴿ومن المقرّبين﴾</span> عند الله في الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٩٢٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span>: قوله: <span class="qpc-hafs">﴿وجيها في الدنيا والآخرة﴾</span> أي: عند الله، <span class="qpc-hafs">﴿ومن المقربين﴾</span> عند الله{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣١١.</p><p>وهي قراءة شاذة.أخرجه ابن أبي حاتم ٢/٦٥٠.تفسير مقاتل بن سليمان ١/٢٧٦.أخرجه ابن أبي حاتم ٢/٦٥١.أخرجه ابن جرير ٥/٤٠٧، وابن المنذر ١/٢٠٠، وابن أبي حاتم ٢/٦٥١.أخرجه ابن جرير ٥/٤٠٧.أخرجه ابن أبي حاتم ٢/٦٥١.أخرجه ابن أبي حاتم ٢/٦٥١.تفسير البغوي ٢/٣٨.أخرجه ابن جرير ٥/٤٠٩-٤١٠، وابن المنذر ١/٢٠٠، وابن أبي حاتم ٢/٦٥١.أخرجه ابن جرير ٥/٤٠٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٩-.تفسير الثعلبي ٣/٦٨.أخرجه ابن أبي حاتم ٢/٦٥١.تفسير الثعلبي ٣/٦٨.أخرجه ابن جرير ٥/٤١٠. وسعيد هنا لعلَّه سعيد بن عبد العزيز الدِّمشقي من كبار أتباع التابعين ت١٦٧ﻫ.أخرجه ابن عساكر ٤٧/٣٤٧-٣٤٨ من طريق إسحاق بن بشر. وعزاه السيوطي إلى إسحاق بن بشرأخرجه ابن جرير ٥/٤١٢، وابن المنذر ١/٢٠١. وعلَّقه ابن أبي حاتم ٢/٦٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٤١١، وابن أبي حاتم ٢/٦٥٢.أخرجه ابن جرير ٥/٤١٠.أخرجه ابن جرير ٥/٤٠٨.أخرجه ابن المنذر ١/٢٠١.تفسير مقاتل بن سليمان ١/٢٧٦.أخرج شطره الأول ابن أبي حاتم ٢/٦٥١ من طريق سلمة، وأخرج شطرَه الثاني ابنُ المنذر ١/٢٠١ من طريق زياد.