quran[8]{c,v,t}:
3,38," <q>﴿هُنَالِكَ دَعَا زَكَرِیَّا رَبَّهُۥۖ قَالَ رَبِّ هَبۡ لِی مِن لَّدُنكَ ذُرِّیَّةࣰ طَیِّبَةًۖ إِنَّكَ سَمِیعُ ٱلدُّعَاۤءِ ۝٣٨﴾</q> - تفسير ١٢٦٨٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: كفلها زكريا، فدخل عليها المحرابَ، فوجد عندها عنبًا في مِكْتلٍ في غير حينه، <q>﴿أنى لك هذا قالت هو من عند الله إن الله يرزق من يشاء بغير حساب﴾</q>. قال: إنّ الذي يرزقك العنب في غير حينه لَقادِرٌ أن يرزقني مِن العاقر الكبير العقيمِ ولدًا. <q>﴿هنالك دعا زكريا ربه﴾</q>، فلما بُشِّرَ بيحيى قال: <q>﴿رب اجعل لي آية قال آيتك ألا تكلم الناس﴾</q>. قال: يُعْتَقَلُ لسانُك مِن غير مرضٍ وأنت سَوِيٌّ{1}. (٣/٥٢١) ١٢٦٩٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لَمّا رأى ذلك زكريا -يعني: فاكهة الصيف في الشتاء، وفاكهة الشتاء في الصيف عند مريم- قال: إنّ الذي يأتي بهذا مريمَ في غير زمانه قادرٌ أن يرزقني ولدًا. فذلك حين دعا ربَّه{2}. (٣/٥٢٥) ١٢٦٩١- عن نَوف البِكالِي -من طريق أبي عمران- في قول الله ﷿: <q>﴿وكفلها زكريا﴾</q>، قال: كان يزورها، وكانت فتاة تنزل في بيت قومها، فكانت تُقَدَّم إليها فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، فقال: <q>﴿أنى لك هذا قالت هو من عند الله إن الله يرزق من يشاء بغير حساب﴾</q>. فهنالك دعا زكريّا ربّه أن يهب له غلامًا، فوهب له يحيى، ولم يُسمَّ يحيى قبله، قال: <q>﴿أنى يكون لي غلام وكانت امرأتي عاقرًا وقد بلغت من الكبر عتيًّا﴾</q> ...{3}. (ز) ١٢٦٩٢- عن الحسن البصري -من طريق قتادة- قال: لَمّا وجد زكريّا عند مريم ثَمَرَ الشتاء في الصيف، وثمر الصيف في الشتاء، يأتيها به جبريل؛ قال لها: أنّى لك هذا في غير حينه؟ فقالت: هذا رزق من عند الله يأتيني، إن الله يرزق من يشاء بغير حساب. فطمع زكريّا في الولد، فقال: إنّ الذي أتى مريمَ بهذه الفاكهة في غير حينها لَقادِرٌ أن يُصْلِح لي زوجتي، ويَهَبَ لي منها ولدًا. فعند ذلك <q>﴿دعا زكريا ربه﴾</q>، وذلك لثلاث ليال بَقِين من الـمُحَرَّم، قام زكريا فاغتسل، ثم ابتهل في الدعاء إلى الله، قال: يا رازقَ مريمَ ثمار الصيف في الشتاء، وثمار الشتاء في الصيف، <q>﴿هب لي من لدنك﴾</q> يعني: من عندك <q>﴿ذرية طيبة﴾</q> يعني: تَقِيًّا{4}. (٣/٥٢٥) ١٢٦٩٣- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿وجد عندها رزقا﴾</q> الآية، قال: فعجِب من ذلك زكريا، قال الله ﷿: <q>﴿هنالك دعا زكريّا ربّه قال ربّ هب لي من لدنك ذرّيّة طيّبة﴾</q>{5}. (ز) ١٢٦٩٤- عن إسماعيل السُّدِّيّ -من طريق أسباط-: فلمّا رأى زكريا من حالها ذلك -يعني: فاكهة الصيف في الشتاء، وفاكهة الشتاء في الصيف- قال: إنّ ربًّا أعطاها هذا في غير حينه لَقادِرٌ على أن يرزقني ذُرِّيَّةً طيِّبةً. ورَغِب في الولد، فقام فصلّى، ثم دعا ربَّه سِرًّا فقال: <q>﴿رب إني وهن العظم مني واشتعل الرأس شيبًا ولم أكن بدعائك رب شقيًّا وإني خفت الموالي من ورائي وكانت امرأتي عاقرًا فهب لي من لدنك وليًّا يرثني ويرث من آل يعقوب واجعله رب رضيًّا﴾</q> [مريم:٤-٦]. وقال: <q>﴿رب هب لي من لدنك ذرية طيبة إنك سميع الدعاء﴾</q>. وقال: <q>﴿رب لا تذرني فردًا وأنت خير الوارثين﴾</q> [الأنبياء:٨٩]{6}. (ز) ١٢٦٩٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ذرية طيبة﴾</q>، يقول: مُبارَكة{7}. (٣/٥٢٦) ١٢٦٩٦- عن محمد بن السّائِب الكَلْبِيِّ: وكانت امرأةُ زكريا عاقِرًا قد دَخَلَتْ في السِّنِّ، وزكريا شيخٌ كبير، فاستجاب الله له{8}. (ز) ١٢٦٩٧- قال مقاتل بن سليمان: فطمع عند ذلك زكريا في الولد، فقال: إن الذي يأتي مريم بهذه الفاكهة في غير حينها لَقادِرٌ أن يُصْلِح لي زوجتي، ويهب لي منها ولدًا. فذلك قوله: <q>﴿هنالك﴾</q> يعني: عند ذلك <q>﴿دعا زكريّا ربه قال رب هب لي من لدنك﴾</q> يعني: مِن عندك <q>﴿ذرية طيبة﴾</q> تقيًّا زكيًّا، كقوله: <q>﴿واجعله ربّ رضيّا﴾</q> [مريم:٦]، <q>﴿إنك سميع الدعاء﴾</q>. فاستجاب الله ﷿، وكانا قد دَخَلا في السِّنِّ{9}. (ز) ",footnotes:1:أخرجه ابن جرير ٥/٣٥١، ٣٥٣، وابن المنذر ١/١٨١-١٨٢، وابن أبي حاتم ٢/٦٤٠، والحاكم ٢/٢٩١ واللفظ له.أخرجه ابن جرير ٥/٣٦١.أخرجه ابن عساكر في تاريخ دمشق ٧٠/٨٥.أخرجه ابن عساكر في تاريخ دمشق ٧٠/٨٤.أخرجه ابن المنذر ١/١٨٤.أخرجه ابن جرير ٥/٣٦٠، وابن المنذر ١/١٨٤ بنحوه، وابن أبي حاتم ٢/٦٤١ مختصرًا.أخرجه ابن جرير ٥/٣٦٢، وابن أبي حاتم ٢/٦٤١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٧-.تفسير مقاتل بن سليمان ١/٢٧٣.
3,39," <q>﴿فَنَادَتۡهُ ٱلۡمَلَـٰۤىِٕكَةُ وَهُوَ قَاۤىِٕمࣱ یُصَلِّی فِی ٱلۡمِحۡرَابِ أَنَّ ٱللَّهَ یُبَشِّرُكَ بِیَحۡیَىٰ مُصَدِّقَۢا بِكَلِمَةࣲ مِّنَ ٱللَّهِ وَسَیِّدࣰا وَحَصُورࣰا وَنَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝٣٩﴾</q> - قراءات ١٢٦٩٨- عن عبد الله بن مسعود، أنّ النبي ﷺ قرأ: <q>﴿فَناداهُ الملائكة﴾</q> بالياء{1}١١٧٥. (٣/٥٢٧) ١١٧٥ وجَّه ابنُ جرير (٥/٣٦٤ بتصرف) هذه القراءة بقوله: «وقد قرأ ذلك جماعةٌ مِن أهل الكوفة بالياء، بمعنى: فناداه جبريل، فذكَّرُوه للتأويل؛ لأنّهم يُؤَنِّثُون فعل الذَّكَرِ لِلَّفْظِ، فكذلك يُذَكِّرون فعل المؤنث أيضًا لِلَّفظ. واعتبروا ذلك فيما أرى بقراءة يُذْكَرُ أنّها قراءة عبد الله بن مسعود». ١٢٦٩٩- عن عبد الرحمن بن أبي حمّاد، قال: في قراءة عبد الله بن مسعود: (فَناداهُ جِبْرِيلُ وهُوَ قَآئِمٌ يُصَلِّي فِي المِحْرابِ){2}. (٣/٥٢٦) ١٢٧٠٠- عن عبد الله بن مسعود -من طريق إبراهيم- قال: ذَكِّرُوا الملائكةَ. ثُمَّ تلا: <q>﴿إن الذين لا يؤمنون بالآخرة ليسمون الملائكة تسمية الأنثى﴾</q> [النجم:٢٧]. وكان يَقْرَأُها: ›فَناداهُ المَلَآئِكَةُ‹{3}. (٣/٥٢٦) ١٢٧٠١- عن عبد الله بن مسعود -من طريق إبراهيم-: أنّه كان يُذَكِّرُ الملائكةَ في القرآن{4}. (٣/٥٢٧) ١٢٧٠٢- عن عاصم بن أبي النجود، أنّه قرأ: <q>﴿فنادته الملائكة﴾</q> بالتاء، <q>﴿أن الله﴾</q> بنصب الألف، <q>﴿يبشرك﴾</q> مُثَقَّلة{5}١١٧٦١١٧٧. (٣/٥٢٧) ١١٧٦ ذكر ابنُ جرير (٥/٣٦٣) أنّ المراد بهذه القراءة جمع الملائكة، ثُمَّ وجَّهها بقوله: «وكذلك تفعل العربُ في جماعة الذكور إذا تقدّمت أفعالها أُنِّثَت أفعالها، ولا سيّما الأسماء التي في ألفاظها التأنيث، كقولهم: جاءت الطلحات». ١١٧٧ اختُلِف في قراءة <q>﴿فناداه﴾</q> بين من قرأها بالتاء، وبين من قرأها بالياء. ورَجَّح ابنُ جرير (٥/٣٦٥ بتصرف) صوابَ كِلْتا القراءتين مستنِدًا إلى اللغة، فقال: «وإنّما الصوابُ مِن القول عندي في قراءة ذلك أنّهما قراءتان معروفتان، فبأيَّتهما قرأ القارئ فمصيب، وذلك أنّه لا اختلاف في معنى ذلك باختلاف القرائن، وهما جميعًا فصيحتان عند العرب، وذلك أنّ الملائكة إن كان مرادًا بها جبريل -كما رُوِي عن عبد الله- فإنّ التأنيث في فعلها فصيحٌ في كلام العرب للفظها إن تقدّمها الفعل، وجائز فيه التذكير لمعناها، وإن كان مرادًا بها جمع الملائكة فجائزٌ في فعلها التأنيث، وهو من قبلها للفظها، وذلك أنّ العرب إذا قدّمت على الكثير مِن الجماعة فِعلَها أنَّثته، فقالت: قالت النساء، وجائز التذكير في فعلها بناء على الواحد إذا تقدّم فعله، فيقال: قال الرجال». <q>﴿فَنَادَتۡهُ ٱلۡمَلَـٰۤىِٕكَةُ وَهُوَ قَاۤىِٕمࣱ یُصَلِّی فِی ٱلۡمِحۡرَابِ﴾</q> - تفسير ١٢٧٠٣- عن عكرمة مولى ابن عباس -من طريق أبي بكر- قال: فدخل المحراب، وغلَّق الأبواب، وناجى ربَّه، فقال: <q>﴿ربّ إني وهن العظم مني واشتعل الرأس شيبًا﴾</q> إلى قوله: <q>﴿رب رضيًّا﴾</q> [مريم:٤-٦]. <q>﴿فنادته الملائكة وهو قائم يصلي في المحراب أن الله يبشرك بيحيى مصدّقًا بكلمة من الله﴾</q>{6}١١٧٨. (ز) ١١٧٨ رَجَّح ابنُ جرير (٥/٣٦٥) هذا القول الذي قال به قتادة، والربيع، وعكرمة، ومجاهد مستنِدًا إلى اللغة، فقال: «وأمّا الصواب من القول في تأويله فأن يقال: إنّ الله -جل ثناؤه- أخبر أنّ الملائكة نادته، والظاهر من ذلك أنها جماعة من الملائكة دون الواحد، وجبريل واحد، فلن يجوز أن يحمل تأويل القرآن إلا على الأظهر الأكثر من الكلام المستعمل في ألسن العرب دون الأقلِّ ما وجد إلى ذلك سبيل، ولم يَضْطرنا حاجة إلى صرف ذلك إلى أنّه بمعنى واحد، فيُحْتاج له إلى طلب المخرج بالخفيِّ من الكلام والمعاني». وعلَّق ابنُ عطية (٢/٢٠٧) على هذا القول ذاكرًا ما يستند إليه من النّظائر، فقال: «وقال قوم: بل نادت ملائكةٌ كثيرةٌ حسبما تقتضيه ألفاظ الآية. وقد وجدنا الله تعالى بعث ملائكة إلى لوط، وإلى إبراهيم ﵇، وفي غير ما قصة». ١٢٧٠٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فنادته الملائكة﴾</q>، قال: جبريل{7}١١٧٩. (٣/٥٢٦) ١١٧٩ وجَّه ابنُ جرير (٥/٣٦٤ بتصرف) هذا القول الذي قال به السدي، ومقاتل، فقال: «فإن قال قائلٌ: وكيف جاز أن يُقال على هذا التأويل: <q>﴿فنادته الملائكة﴾</q> والملائكة جمع لا واحد؟ قيل: ذلك جائز في كلام العرب بأن تُخْبِر عن الواحد بمَذْهب الجمع، كما يُقال في الكلام: خرج فلان على بِغال البُرُد، وإنّما ركب بَغْلًا واحدًا، ورَكِب السُّفُن، وإنّما ركب سفينة واحدة. وقد قيل: إنّ منه قوله: <q>﴿الذين قال لهم الناس إن الناس قد جمعوا لكم﴾</q> [آل عمران:١٧٣]، والقائلُ كان -فيما ذُكِر- واحدًا، وذلك جائز عندهم فيما لم يُقْصَد فيه قَصْد واحد». وبنحوه قال ابنُ عطية (٥/٢٠٧-٢٠٨). ١٢٧٠٥- عن محمد بن إسحاق -من طريق سلمة- عن بعض أهل العلم، قال: فدعا زكريا عند ذلك بعد ما أسَنَّ، ولا ولد له، وقد انقرض أهلُ بيته؛ فقال: <q>﴿رب هب لي من لدنك ذرية طيبة إنك سميع الدعاء﴾</q>. ثُمَّ شكا إلى ربِّه، فقال: <q>﴿ربّ إني وهن العظم منّي واشتعل الرأس شيْبًا﴾</q> إلى <q>﴿واجعله رب رضيًّا﴾</q> [مريم:٤-٦]. <q>﴿فنادته الملائكة وهو قائم يُصَلّي في المحراب﴾</q> الآية{6}. (ز) ١٢٧٠٦- قال مقاتل بن سليمان: <q>﴿فنادته الملائكة وهو قائم يصلي في المحراب﴾</q>، فبينما هو يُصَلِّي في المحراب، حيث يذْبَح القربان، إذا برجل عليه بياض حِيالَه، وهو جبريل ﵇، فقال: <q>﴿إن الله يُبَشّرك بيحيى﴾</q>{9}١١٨٠. (ز) ١١٨٠ علَّق ابنُ عطية (٢/٢٠٧) على مَن ذكر أنّ المنادي هو جبريل مستنِدًا إلى العادة في مثل ذلك بقوله: «وهذا هو العُرْف في الوحي إلى الأنبياء». <q>﴿وَهُوَ قَاۤىِٕمࣱ یُصَلِّی فِی ٱلۡمِحۡرَابِ﴾</q> - تفسير ١٢٧٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: المحراب: المُصَلّى{10}. (٣/٥٢٧) ١٢٧٠٨- عن ثابت [البُنانِيّ] -من طريق جعفر بن سليمان- قال: الصلاة خدمة الله في الأرض، ولو علم الله شيئًا أفضلَ من الصلاة ما قال: <q>﴿فنادته الملائكة وهو قائم يصلي﴾</q>{11}. (٣/٥٢٧) <q>﴿أَنَّ ٱللَّهَ یُبَشِّرُكَ بِیَحۡیَىٰ﴾</q> - قراءات ١٢٧٠٩- عن معاذ الكوفيِّ -من طريق عبد الرحمن بن أبي حَمّاد- قال: مَن قرأ: <q>﴿يُبَشِّرُهُم﴾</q> [التوبة:٢١] مُثَقَّلَة فإنّه مِن البِشارة، ومَن قرأ (يَبْشُرُهم) مخففة بنصب الياء فإنّه مِن السرور: يَسُرُّهم{12}١١٨١. (٣/٥٢٩) ١١٨١ انتَقَدَ ابنُ جرير (٥/٣٦٩) قولَ معاذ الكوفي مستنِدًا إلى اللغة، فقال: "وأما ما رُوي عن معاذ الكوفيِّ مِن الفرق بين معنى التّخفيف والتّشديد في ذلك؛ فلم نجد أهلَ العلم بكلام العرب يعرفونه مِن وجه صحيح، فلا معنى لِما حُكِي من ذلك عنه، وقد قال جرير بن عطيّة: يا بِشْرُ حُقَّ لوجهك التبشير ... هلا غضبت لنا وأنت أمير فقد علم أنّه أراد بقوله: التبشير: الجمال والنضارة والسرور، فقال: التبشير. ولم يقل: البِشْر. فقد بَيَّن ذلك أنّ معنى التخفيف والتثقيل في ذلك واحد". <q>﴿أَنَّ ٱللَّهَ یُبَشِّرُكَ بِیَحۡیَىٰ﴾</q> - تفسير الآية ١٢٧١٠- عن عبد الله بن مسعود -من طريق مُرَّة- قال: صاحبكم ﷺ خامسُ خمسة مُبَشَّرٌ بهم قبل أن يكونوا: إسحاق ويعقوب، قول الله تعالى: <q>﴿فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</q> [هود:٧١]، ويحيى، قوله تعالى: <q>﴿إن الله يبشرك بيحيى مصدقا﴾</q>، وعيسى ابن مريم: <q>﴿إن الله يبشرك بكلمة منه﴾</q>، ومحمد ﷺ، قول عيسى ﵇: <q>﴿يأتي من بعدي اسمه أحمد﴾</q> [الصف:٦]، فهؤلاء أُخْبِر بهم مِن قبل أن يكونوا{13}. (ز) ١٢٧١١- عن عبد الله بن عباس، قال: سُمِّي: يحيى؛ لأنّ الله أحْيا به عُقْرَ{14} أُمِّه{15}. (ز) ١٢٧١٢- عن قتادة بن دِعامة -من طريق مَعْمَر- قال: إنّ الملائكة شافهته بذلك مُشافهة، فبشَّرَتْه بيحيى{16}. (٣/٥٢٩) ١٢٧١٣- عن قتادة بن دِعامة -من طريق أبي جعفر- <q>﴿أن الله يبشرك بيحيى﴾</q>، قال: إنّما سُمِّي: يحيى؛ لأنّ الله أحياه بالإيمان{17}. (٣/٥٢٩) ١٢٧١٤- عن قتادة بن دِعامة -من طريق شيبان- <q>﴿أن الله يبشرك بيحيى﴾</q>، قال: عبد أحياه الله بالإيمان{18}١١٨٢. (ز) ١١٨٢ لم يذكر ابنُ جرير (٥/٣٧٠) غير هذا القول وما في معناه. ١٢٧١٥- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿أن الله يبشرك بيحيى﴾</q>، قال: سَمّى اللهُ يحيى{19}. (ز) ١٢٧١٦- عن عبد الملك ابن جُرَيْج -من طريق ابن ثور-: فنادته الملائكةُ: <q>﴿أنّ الله يبشرك بيحيى﴾</q> بالحَمْل به{20}. (ز) ١٢٧١٧- قال مقاتل بن سليمان: <q>﴿أن الله يبشرك بيحيى﴾</q>، اشتُقَّ يحيى مِن أسماء الله ﷿{9}. (ز) <q>﴿مُصَدِّقَۢا بِكَلِمَةࣲ مِّنَ ٱللَّهِ﴾</q> - تفسير ١٢٧١٨- عن عبد الله بن مسعود، مرفوعًا: «خلق الله فرعون في بطن أُمِّه كافرًا، وخلق يحيى بن زكريا في بطن أُمِّه مؤمنًا»{22}. (٣/٥٢٩) ١٢٧١٩- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿مصدقًا بكلمة من الله﴾</q>، قال: عيسى ابن مريم، والكلمةُ يعني: تَكَوَّن بكلمة من الله{23}. (٣/٥٢٩) ١٢٧٢٠- عن عبد الله بن عباس -من طريق ابن جُرَيْج- <q>﴿مصدقًا بكلمة من الله﴾</q>، قال: كان عيسى ويحيى ابْنَيْ خالة، وكانت أُمُّ يحيى تقول لمريم: إنِّي أجد الذي في بطني يَسْجُدُ لِلَّذِي في بطنك. فذلك تصديقه بعيسى؛ سجودُه في بطن أمّه، وهو أوَّلُ من صدَّق بعيسى، وكلمة عيسى، ويحيى أكبرُ مِن عيسى{24}. (٣/٥٣٠) ١٢٧٢١- عن عبد الله بن عباس -من طريق عكرمة- قوله: <q>﴿مصدقًا بكلمة من الله﴾</q>، قال: عيسى ابن مريم هو الكلمة من الله، اسمه المسيح{25}. (ز) ١٢٧٢٢- وعن أبي الشَّعْثاء جابر بن زيد، نحو ذلك{26}. (ز) ١٢٧٢٣- عن مجاهد بن جبر -من طريق النَّضْر بن عَرَبِيٍّ- قال: قالت امرأة زكريّا لمريم: إنِّي أجد الذي في بطني يتحرّك لِلَّذِي في بطنك. فوضعتِ امرأةُ زكريّا يحيى ﵇، ومريمُ عيسى ﵇، وذلك قوله: <q>﴿مصدّقًا بكلمة من الله﴾</q>، قال: يحيى مُصَدِّقٌ بعيسى{27}. (٣/٥٣٠) ١٢٧٢٤- عن الضحاك بن مُزاحِم -من طريق علي بن الحكم- في قوله: <q>﴿مصدقًا بكلمة من الله﴾</q>، قال: كان يحيى أوَّل مَن صَدَّق بعيسى، وشهد أنّه كلمةٌ مِن الله، وكان يحيى ابنَ خالة عيسى، وكان أكبرَ من عيسى{28}. (٣/٥٣٠) ١٢٧٢٥- عن الحسن البصري -من طريق عبّاد بن منصور- في قول الله: <q>﴿أن الله يبشرك بيحيى مصدّقًا بكلمة من الله﴾</q>، قال: مُصَدِّقًا بعيسى ابن مريم{29}. (ز) ١٢٧٢٦- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿مصدّقًا بكلمة من الله﴾</q>، يقول: مُصَدِّقٌ بعيسى، وعلى سُنَّتِه، ومنهاجه{30}. (٣/٥٣٠) ١٢٧٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿مصدِّقًا بكلمة من الله﴾</q>، قال: يُصدِّق بعيسى{25}. (ز) ١٢٧٢٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لقِيَتْ أُمُّ يحيى أُمَّ عيسى، وهذه حامل بيحيى، وهذه حامل بعيسى، فقالت امرأةُ زكريا: إنِّي وجدت ما في بطني يسجد لِما في بطنك. فذلك قوله تعالى: <q>﴿مُصدِّقًا بكلمة من الله﴾</q>{32}. (٣/٥٣٠) ١٢٧٢٩- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿مصدِّقًا بكلمة من الله﴾</q>، قال: كان أوَّلَ رجل صدَّق عيسى، وهو كلمة من الله ورُوحٌ{33}. (ز) ١٢٧٣٠- عن الرِّقاشِيِّ -من طريق ابن أبي نجيح- في قول الله: <q>﴿يبشرك بيحيى مصدقا بكلمة من الله﴾</q>، قال: مُصَدِّقًا بعيسى ابن مريم{34}. (ز) ١٢٧٣١- قال مقاتل بن سليمان: <q>﴿مُصدِّقًا بكلمة من الله﴾</q>، يعني: مِن الله ﷿، وكان يحيى أوَّلَ مَن صدَّق بعيسى ﵉، وهو ابن ثلاث سنين، قوله الأوَّل وهو ابن سِتَّة أشهر، فلَمّا شهِد يحيى أنّ عيسى مِن الله ﷿ عجِبت بنو إسرائيل لصغره، فلَمّا سَمِع زكريا شهادته قام إلى عيسى، فضَمَّه إليه، وهو في خِرْقَةٍ، وكان يحيى أكبر من عيسى بثلاث سنين، يحيى وعيسى ابنا خالة{9}. (ز) <q>﴿وَسَیِّدࣰا﴾</q> - تفسير ١٢٧٣٢- عن عبد الله بن عباس -من طريق العوفي- <q>﴿وسيّدًا﴾</q>، قال: حليمًا تقِيًّا{36}. (٣/٥٣١) ١٢٧٣٣- عن عبد الله بن عباس -من طريق عطيّة- في قوله: <q>﴿وسيِّدًا﴾</q>، قال: السيِّد: الحليم{37}. (٣/٥٣٢) ١٢٧٣٤- عن سعيد بن المسيب -من طريق يحيى بن سعيد- قال: السيِّد: الفقيهُ العالِم{38}. (٣/٥٣١) ١٢٧٣٥- عن أبي الشَّعْثاء جابر بن زيد، قال: السيِّد: الذي يغلِبُ غضبَه{39}. (ز) ١٢٧٣٦- عن أبي العالية الرِّياحِيِّ= (ز) ١٢٧٣٧- ومطر الوَرّاق، أنّهما قالا: حليمًا{26}. (ز) ١٢٧٣٨- عن سعيد بن جبير -من طريق عطاء- قال: السيِّد: الحليم{41}. (٣/٥٣٢) ١٢٧٣٩- عن سعيد بن جبير -من طريق سالم- <q>﴿وسيّدًا﴾</q>، قال: السَّيِّدُ: التَّقِيُّ{42}. (ز) ١٢٧٤٠- عن سعيد بن جبير، قال: السيِّدُ: الذي يغلِب غضبَه{39}. (ز) ١٢٧٤١- عن مجاهد بن جبر -من طريق ليث- <q>﴿وسيّدًا﴾</q>، قال: ليس له شرك{44}. (ز) ١٢٧٤٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قال: السيِّد: الكريم على الله{45}. (٣/٥٣١) ١٢٧٤٣- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قول الله ﷿: <q>﴿وسيِّدًا﴾</q>، قال: السيِّد: الحليمُ التَّقِيُّ{46}. (ز) ١٢٧٤٤- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- قال: السيِّد: الحسنُ الخُلُق{47}. (٣/٥٣١) ١٢٧٤٥- عن عكرمة مولى ابن عباس -من طريق أبي بكر الهُذَلِيِّ- قال: السيِّدُ: الذي لا يغلِبُه الغضبُ{48}. (٣/٥٣١) ١٢٧٤٦- عن أبي صالح باذام، قال: السيِّد: التَّقِيُّ{49}. (ز) ١٢٧٤٧- عن الحسن البصري، قال: السيِّد: الذي يغلب غضبَه{39}. (ز) ١٢٧٤٨- عن عطيّة العوفي -من طريق إدريس- في قوله: <q>﴿وسيّدًا﴾</q>، قال: السيِّدُ في خُلُقِه ودينه{19}١١٨٣. (ز) ١١٨٣ عَلَّق ابنُ تيمية (٣/٦٤بتصرف) على مَن فَسَّر السيِّد بأنّه سيِّدٌ لقومه في الدِّين، فقال: «ولا يسود الرجلُ الناسَ حتى يكون في نفسه مُجْتَمِع الخلقِ ثابتًا. ولهذا فسَّر طائفةٌ مِن السلف السيِّد بأنّه: سيِّدُ قومه في الدين». ١٢٧٤٩- عن عطاء، قال: السيِّد: الذي يغلِب غضبَه{39}. (ز) ١٢٧٥٠- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿وسيِّدًا﴾</q>، قال: إي واللهِ، لَسَيِّدٌ في العبادة، والحِلْم، والعلم، والوَرَع{53}. (ز) ١٢٧٥١- عن قتادة بن دعامة: والسيِّد: الحسن الخُلُق{54}. (ز) ١٢٧٥٢- عن الربيع بن أنس: السيِّدُ: الحليمُ{55}. (ز) ١٢٧٥٣- عن شِبْل، قال: زَعَم الرِّقاشِيُّ أنّ السَّيِّد: الكريمُ على الله{56}. (ز) ١٢٧٥٤- قال مقاتل بن سليمان: ثُمَّ قال الله سبحانه: <q>﴿وسيِّدًا﴾</q>، يعني: حليمًا{9}. (ز) ١٢٧٥٥- قال سفيان الثوري: الذي لا يحسِد{58}. (ز) ١٢٧٥٦- عن سفيان -من طريق عبد الرحمن بن مهديّ- في قوله: <q>﴿وسيّدًا﴾</q>، قال: حليمًا تَقِيًّا{59}. (ز) ١٢٧٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وسيّدًا﴾</q>، قال: السيِّدُ: الشَّريفُ{38}١١٨٤. (ز) ١١٨٤ عَلَّق ابنُ عَطِيَّة (٢/٢١٠) على الأقوال الواردة في تأويل السيِّد بقوله: «كُلُّ مَن فَسَّر مِن هؤلاء العلماء المذكورين السُّؤْدَد بالحِلْم فقد أحرز أكثر معنى السُّؤْدَد، ومَن جرَّد تفسيره بالعِلم والتُّقى ونحوه فلم يُفَسِّر بحسب كلام العرب، وقد تحصَّلَ العلمُ ليحيى ﵇ بقوله ﷿: <q>﴿مُصَدِّقًا بِكَلِمَةٍ مِنَ اللَّهِ﴾</q>، وتحصَّلَ التُّقى بباقي الآية». ثُمَّ ذكر (١/٤٢٩) عمومَ اللفظة لِكُلِّ ما ذُكِر، فقال: «وخصَّه الله بذكر السُّؤْدَد الذي هو الاحتمال في رِضى الناس على أشرف الوجوه دون أن يوقع في باطل، هذا لفظ يَعُمُّ السُّؤْدَد، وتفصيله أن يقال: بذل النَّدى -وهذا هو الكرم-، وكفُّ الأذى -وهنا هي العِفَّة بالفرج واليد واللسان-، واحتمال العظائم -وهنا هو الحلم وغيره؛ مِن تَحَمُّلِ الغرامات، وجبر الكسير، والإفضال على المُسْتَرْفِد، والإنقاذ من الهلكات-». <q>﴿وَحَصُورࣰا وَنَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝٣٩﴾</q> - تفسير ١٢٧٥٨- عن أبي هريرة، أنّ النبي ﷺ قال: «كُلُّ ابنِ آدم يَلْقى الله بذنب قد أذنبه، يُعَذّبه عليه إن شاء أو يَرْحَمه، إلّا يحيى بن زكريّا؛ فإنّه كان <q>﴿سيّدًا وحصورًا ونبيًّا من الصالحين﴾</q>». ثُمَّ أهْوى النبيُّ ﷺ إلى قَذاةٍ مِن الأرض، فأخذها، وقال: «كان ذَكَرُه مِثلَ هذه القَذاة»{61}. (٣/٥٣٣) ١٢٧٥٩- عن عبد الله بن عمرو بن العاص، عن النبي ﷺ، قال: «ما مِن عبد يَلْقى الله إلا ذا ذنب، إلا يحيى بن زكريّا؛ فإنّ الله يقول: <q>﴿وسيِّدًا وحصورًا﴾</q>». قال: «وإنّما كان ذَكَرُه مثلَ هُدْبَةِ الثَّوْب». وأشار بأَنْمَلِهِ{62}. (٣/٥٣٢) ١٢٧٦٠- عن عبد الله بن عمرو، مثله موقوفًا{63}. (٣/٥٣٣) ١٢٧٦١- عن معاوية بن صالح، عن بعضهم رَفَعَ الحديث: «لعن اللهُ والملائكةُ رجلًا تَحَصَّر بعد يحيى بن زكريا»{64}. (٣/٥٣٣) ١٢٧٦٢- عن عبد الله بن مسعود -من طريق زِرٍّ- قال: الحَصُور: الذي لا يَقْرَبُ النِّساء. ولفظُ ابنِ المنذر: العِنِّين{65}. (٣/٥٣٢) ١٢٧٦٣- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿وحصورا﴾</q>، قال: والحصورُ: الذي لا يأتي النساءَ{37}. (٣/٥٣٢) ١٢٧٦٤- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- قال: الحَصُور: الذي لا يُنزِلُ الماءَ{67}. (٣/٥٣٢) ١٢٧٦٥- عن عبد الله بن عباس -من طريق نافع بن الأزرق- أنّه سأله عن قوله: <q>﴿وحصورًا﴾</q>. قال: الذي لا يأتي النِّساءَ. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت قول الشاعر: وحصور عن الخَنا يأمر النا سَ بِفَعل الخيرات والتَّشْمِير؟{68}. (٣/٥٣٤) ١٢٧٦٦- عن أبي الشعثاء جابر بن زيد، قال: الحصور: الذي لا يَغْشى النِّساء{69}. (ز) ١٢٧٦٧- عن أبي العالية الرِّياحِيِّ، قال: الذي لا يُولَد له{70}. (ز) ١٢٧٦٨- عن سعيد بن المسيب -من طريق يحيى بن سعيد- في قوله: <q>﴿وحصورًا﴾</q>، قال: لا يشتهي النساءَ. ثم ضرب بيده إلى الأرض، فأخذ نَواةً، فقال: ما كان معه إلا مِثْلُ هذه{71}. (٣/٥٣٤) ١٢٧٦٩- عن سعيد بن المُسَيِّب -من طريق يحيى بن سعيد- يقول: ليس أحدٌ إلا يلقى اللهَ يومَ القيامة ذا ذَنب، إلا يحيى بن زكريا، كان حصورًا، مَعَهُ مِثلُ الهُدْبَة{71}. (ز) ١٢٧٧٠- عن سعيد بن جبير -من طريق عطاء بن السائب- قال: الحصورُ: الذي لا يأتي النساءَ{73}. (٣/٥٣٢) ١٢٧٧١- عن مجاهد بن جبر -من طريق ابن أبي نَجيح- قال: الحصور: الذي لا يأتي النساءَ{74}. (٣/٥٣١) ١٢٧٧٢- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- قال: الحصورُ: الذي حُصِر عن النساء{75}. (٣/٥٣١) ١٢٧٧٣- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر-: الحَصُور: الذي لا يُولَد له، وليس له ماء{76}. (ز) ١٢٧٧٤- عن عكرمة مولى ابن عباس، قال: هو الذي لا يأتي النساءَ{77}. (ز) ١٢٧٧٥- عن الحسن البصريِّ -من طريق عبّاد بن منصور- <q>﴿وحصُورًا﴾</q>، قال: لا يقرَب النساءَ{78}. (ز) ١٢٧٧٦- عن أبي صالح باذام: الحَصُور: الذي ليس له شهوة{79}. (ز) ١٢٧٧٧- عن عَطِيَّة العوفيِّ، قال: هو الذي لا يأتي النساءَ{77}. (ز) ١٢٧٧٨- عن عطاء، قال: الحصور: الذي لا يَغْشى النساءَ{81}. (ز) ١٢٧٧٩- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿وحصورًا﴾</q>، قال: كُنّا نُحدَّث: أنّ الحصورَ: الذي لا يَقْرَب النساءَ{82}. (ز) ١٢٧٨٠- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿وحصُورًا﴾</q>، قال: الحَصُور: الذي لا يريد النساءَ{83}. (ز) ١٢٧٨١- عن عطاء الخراساني -من طريق عثمان بن عطاء- في قوله: <q>﴿وحصورا﴾</q>، قال: مُنثَنِي الذَّكَر{84}. (ز) ١٢٧٨٢- عن الربيع بن أنس -من طريق أبي جعفر- قال: الحصورُ: الذي لا يُولَد له{85}. (ز) ١٢٧٨٣- عن شِبْلٍ، قال: زَعَمَ الرَّقاشِيُّ: الحصور: الذي لا يَقْرَب النساء{86}. (ز) ١٢٧٨٤- قال مقاتل بن سليمان: <q>﴿وحصورًا﴾</q>: لا ماء له، والحصورُ: الَّذي لا حاجةَ له في النساء{9}. (ز) ١٢٧٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- <q>﴿وحصُورًا﴾</q>، قال: الحَصُورُ: الذي لا يأتي النساءَ{83}١١٨٥. (ز) ١١٨٥ قال ابنُ عطية (٢/٢١٢) بعد ذِكْرِه لِمَن جعل حَصْرَ يحيى ﵇ لأنّه لم يكن له إلا مِثْلُ الهُدْبَة، ومَن علَّله بكونه عِنِّينًا لا يأتي النساء، ونقله لقول ثالث يقول بأنّ حصر يحيى كان بمجاهدته نفسَه، وأنّه كانت به القدرة على إتيان النساء: «قالوا: وهذا أمدحُ له، وليس له في التأويلين الأوَّلَيْن مدحٌ، إلا بأنّ الله يسَّر له شيئًا لا تَكَسُّب له فيه». ورجَّح ابنُ كثير (٣/٥٧) أنّ مدح يحيى ﵇ بأنّه حصور ليس معناه: أنّه لا يأتي النساء، بل معناه: أنّه معصومٌ عن الفواحش والقاذورات؛ مستنِدًا إلى دلالة عقْلِيَّة، وذلك أنّ عدم القدرة على النِّكاح نَقْصٌ، ثُمَّ قال بعد ذلك: «ولا يمنع ذلك من تزويجه بالنساء الحلال، وغشيانِهِنَّ، وإيلادِهِنَّ، بل قد يُفْهم وجود النسل له من دُعاء زكريا المتقدم؛ حيث قال: <q>﴿هب لي من لدنك ذرية طيبة﴾</q>. كأنه قال: ولدًا له ذُرِّيَّةٌ ونَسْلٌ وعَقِب». <q>﴿وَحَصُورࣰا وَنَبِیࣰّا مِّنَ ٱلصَّـٰلِحِینَ ۝٣٩﴾</q> - آثار متعلقة بالآية ١٢٧٨٦- عن أبي سعيد، قال: قال رسول الله ﷺ: «الحسن والحسين سيِّدا شباب أهل الجنة، إلّا ابْنَيِ الخالة؛ عيسى ابن مريم، ويحيى بن زكريا»{89}. (١٠/٣٠) ١٢٧٨٧- عن أبي أُمامَة، قال: قال رسول الله ﷺ: «أربعةٌ لُعِنوا في الدنيا والآخرة وأَمَّنَت الملائكةُ: رجلٌ جعله الله ذَكَرًا فأنّث نفسَه وتَشَبَّه بالنساء، وامرأة جعلها الله أنثى فتَذَكَّرَتْ وتَشَبَّهَتْ بالرِّجال، والذي يُضِلّ الأعمى، ورجلٌ حَصُور، ولم يجعل اللهُ حصُورًا إلا يحيى بن زكريّا»{90}. (٣/٥٣٣) ١٢٧٨٨- عن وهْب بن مُنَبِّه، قال: نادى مُنادٍ من السماء: إنّ يحيى بن زكريا سيِّدُ مَن ولدت النساء، وإنّ جورجيس سَيِّدُ الشهداء{91}. (٣/٥٣٢) ١٢٧٨٩- عن ثابت البُنانِيِّ، قال: بَلَغَنا: أنّ إبليس ظهر ليحيى بن زكريا، فرأى عليه مَعالِيق مِن كُلِّ شيء، فقال له يحيى: ما هذه؟ قال: هذه الشَّهَوات التي أُصِيبُ بها بني آدم. قال له يحيى: هل لي فيها شيء؟ قال: لا. قال: فهل تُصِيب مِنِّي شيئًا؟ قال: رُبَّما شَبِعْتَ؛ فثقَّلْناك عن الصلاة والذِّكْر. قال: هل غيرُه؟ قال: لا. قال: لا جَرَم، لا أشبعُ أبدًا{92}. (١٠/٣٤) ",footnotes:1:أخرجه الخطيب في تاريخه ٥/٢١٥ (١٣٦٥) من طريق أحمد بن الحسن المقرئ، عن أحمد بن الخليل اليماني، عن أبي بكر ابن عياش، عن الأعمش، عن خيثمة، عن عبد الله بن مسعود به. قال الخطيب ٥/٢١٥ (١٣٦٥): «غريب لم أكتبه إلا من هذا الوجه». قلنا: في سنده: أحمد بن الحسن بن علي المقري دبيس، قال عنه الدارقطني: «ليس بثقة». ينظر: ميزان الاعتدال ١/٩١. وفيه أيضًا أحمد بن الخليل بن مالك المعروف بحور، قال الدارقطني: «ضعيف لا يُحْتَجُّ به». انظر: تاريخ بغداد ٥/٢١٥. وانظر: لسان الميزان ١/٤٥٣. والمراد من قراءته بالياء أنه قرأ بألف بعد الدال ممالة، وهي قراءة متواترة قرأ بها حمزة والكسائي وخلف. انظر: النشر ٢/١٨٠.أخرجه ابن جرير ٥/٣٦٤. وهي قراءة شاذة. ينظر: البحر المحيط ٢/٤٦٤.أخرجه ابن المنذر ١/١٨٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن المنذر ١/١٨٤-١٨٥.عزاه السيوطي إلى عَبد بن حُمَيد. قرأ جمهور القراء: <q>﴿أن الله﴾</q> بفتح الهمزة، وقرأ ابن عامر وحمزة بكسرها. انظر: النشر ٢/٢٣٩. وقرأ جمهور القراء: <q>﴿يبشرك﴾</q> مثقلة بضم الياء وتشديد الشين مكسورة، وقرأ حمزة والكسائي بالتخفيف بفتح الياء والشين مخففة. انظر: النشر ٢/٢٣٩.أخرجه ابن جرير ٥/٣٦١.أخرجه ابن جرير ٥/٣٦٤، وابن أبي حاتم ٢/٦٤١.أخرجه ابن جرير ٥/٣٦١.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه ابن المنذر ١/١٨١.أخرجه ابن المنذر ١/١٨٥، وابن أبي حاتم ٢/٦٤١، وابن أبي الدنيا في كتاب التهجد وقيام الليل -موسوعة الإمام ابن أبي الدنيا ١/٣٢٩ (٤٠٥)- من طريق إبراهيم بن أبي عبلة.أخرجه ابن جرير ٥/٣٦٩. وهما قراءتان عشريتان، قرأ بالتخفيف حمزة الكوفي، وقرأ الباقون بالتشديد. ينظر: النشر ٢/٢٣٩.أخرجه ابن عساكر في تاريخ دمشق ٣/٣٩٣.عُقْرُ المرأة –بالضمّ-: فَرْجُها. تاج العروس (عقر).تفسير الثعلبي ٣/٦٢، وتفسير البغوي ٢/٣٤.أخرجه عبد الرزاق ١/١٢٠، وابن جرير ٥/٣٦٩، وابن المنذر ١/١٨٦ من طريق سعيد، وابن أبي حاتم ٢/٦٤١.أخرجه ابن جرير ٥/٣٧٠، وابن المنذر ١/١٨٦، وابن أبي حاتم ٢/٦٤٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زَمنين ١/٢٨٧-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/٣٧٠ من طريق سعيد، وابن أبي حاتم ٢/٦٤١.أخرجه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن المنذر ١/١٨٧.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه الطبراني في الكبير ١٠/٢٢٤ (١٠٥٤٣)، والبيهقي في القضاء والقدر ١/١٥٣ (٩٦)، ١/١٥٤ (٩٨)، ١/١٥٥ (١٠٣) من طريق قتادة، عن أبي حسان الأعرج، عن ناجية بن كعب، عن عبد الله بن مسعود به. قال الهيثمي في المجمع ٧/١٩٣ (١١٨١١): «إسناده جيّد». وقال الألباني في الصحيحة ٤/٤٤٧ (١٨٣١): «له طريق حسنة».أخرجه ابن جرير ٥/٣٧٢، وابن المنذر ١/١٨٧، وابن أبي حاتم ٢/٦٤٢. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد.أخرجه ابن جرير ٥/٣٧٢-٣٧٣.أخرجه ابن جرير ٥/٣٧٢.علَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧١. وعزاه السيوطي إلى أحمد في الزهد. كما أخرج ابن جرير ٥/٣٧١ آخره مختصرًا من طريق ابن أبي نجيح.أخرجه ابن جرير ٥/٣٧٢ من طريق عبيد بن سليمان، وابن المنذر ١/١٨٧.أخرجه ابن جرير ٥/٣٧٣. وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧١.أخرجه ابن جرير ٥/٣٧٢.أخرجه ابن جرير ٥/٣٧٣.أخرجه ابن جرير ٥/٣٧٢. وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧١. وعلَّقه ابن أبي حاتم ٢/٦٤٢.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه ابن جرير ٥/٣٧٦، وابن أبي حاتم ٢/٦٤٢.أخرجه عبد الرزاق ١/١٢٠، وابن المنذر ١/١٩٠، وابن أبي حاتم ٢/٦٤٣، وابن عساكر ٦٤/١٧٦. وعند عبد الرزاق من قول قتادة.أخرجه ابن جرير ٥/٣٧٦.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.علَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن أبي شيبة ٨/٣٣٧، ١١/٥٦٢، وأحمد في الزهد ص٧٦، وابن جرير ٥/٣٧٤ من طريق سالم. وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن المنذر ١/١٨٨، وابن جرير ٥/٣٧٥.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن أبي حاتم ٢/٦٤٣.أخرجه ابن جرير ٥/٣٧٥، وابن المنذر ١/١٨٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه الثوري في تفسيره ص٧٦، وابن جرير ٥/٣٧٥، وابن عساكر في تاريخ دمشق ٦٤/١٧٨. وعلَّقه ابن أبي حاتم ٢/٦٤٢. وذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩ بلفظ: الحليم.أخرجه أحمد في الزهد ص٩٠، والخرائطيُّ في مكارم الأخلاق (١٧، ٢٦٨-منتقى). وعلَّقه ابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧٦، وابن أبي حاتم ٢/٦٤٢. وعزاه السيوطي إلى ابن أبي الدنيا في ذمِّ الغضب.ذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن أبي حاتم ٢/٦٤٢ بلفظ: تقيًّا.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن أبي حاتم ٢/٦٤٢.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن جرير ٥/٣٧٣. وعلَّقه ابن أبي حاتم ٢/٦٤٢ بلفظ: «حليمًا» فقط.ذكره يحيى بن سلام -كما في تفسير ابن أبي زَمنين ١/٢٨٧-.ذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن المنذر ١/١٨٩، وابن أبي حاتم ٢/٦٤٢.أخرجه ابن جرير ٥/٣٧٥، وابن أبي حاتم ٢/٦٤٣.تفسير مقاتل بن سليمان ١/٢٧٤.تفسير الثعلبي ٣/٦٣، وتفسير البغوي ٢/٣٤.أخرجه ابن جرير ٥/٣٧٥.أخرجه ابن جرير ٥/٣٧٦.أخرجه الطبراني في الأوسط ٦/٣٣٣ (٦٥٥٦)، وابن عساكر ٦٤/١٩٤ (١٣١١٦)، وابن أبي حاتم ٢/٦٤٤ (٣٤٧٠) من طريق محمد بن سلمة المرادي، عن حجاج بن سليمان، عن الليث بن سعد، عن محمد بن عجلان، عن القعقاع بن حكيم، عن أبي صالح، عن أبي هريرة به. قال أبو حاتم الرازي: «لم يكن هذا الحديثُ عند أحد غير الحجاج، ولم يكن في كتاب الليث، وحجاج شيخ معروف». انظر: علل الحديث لابن أبي حاتم ٥/١٠١. وقال الطبراني: «لم يروِ هذا الحديثَ عن محمد بن عجلان إلا الليث، ولا عن الليث إلا حجاج بن سليمان، تفرَّد به محمد بن سلمة المرادي». وقال ابن عدي في الكامل في ضعفاء الرجال ٢/٥٣٦ عن حجاج بن سليمان: «يحدث عن الليث وابن لهيعة أحاديث منكرة» ثم أورد هذا الحديث في ترجمته. وقال الهيثمي في المجمع ٨/٢٠٩ (١٣٨٠٤): «وفيه حجاج بن سليمان الرّعيني، وثَّقه ابن حبان وغيره، وضعّفه أبو زرعة وغيره، وبقية رجاله ثقات».أخرجه الحاكم في المستدرك ٢/٤٠٤ (٣٤١١)، ٤/٢٧٣ (٧٦١٨)، وابن جرير ٥/٣٧٨، وابن المنذر ١/١٩١ (٤٣٠) من طريق محمد بن إسحاق، عن يحيى بن سعيد الأنصاري، عن سعيد بن المسيب، عن عمرو بن العاص به مرفوعًا. قال الحاكم: «حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٢/٣٨: «في صحة المرفوع نظر». وأخرجه ابن أبي شيبة في المصنف ٧/١٢٨، وابن جرير ٥/٣٧٨ -على الشك: إمّا عبد الله، وإمّا أبوه- من طريق يحيى بن سعيد، عن سعيد بن المسيب، عن عبد الله بن عمرو به موقوفًا عليه.أخرجه ابن أبي شيبة ١١/٥٦١-٥٦٢، وأحمد في الزهد ص٩٠، وابن أبي حاتم ٢/٦٤٣ من وجه آخر. وينظر: العلل لابن أبي حاتم (١٩١٣). قال ابن كثير في تفسيره ٢/٣٨: «فهذا موقوف، وهو أقوى إسنادًا من المرفوع [يعني: الأثر الذي قبله]، بل وفي صحة المرفوع نظر». وقال السيوطي: «هو أقوى إسنادًا من المرفوع».أخرجه ابن عساكر ٦٤/١٩٦.أخرجه ابن جرير ٥/٣٧٧، وابن المنذر ١/١٩٠، والبيهقي في سُنَنِه ٧/٨٣. وعلَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه عبد الرزاق ١/١٢٠، وابن المنذر ١/١٩٠، وابن أبي حاتم ٢/٦٤٣، وابن عساكر ٦٤/١٧٦. وعند عبد الرزاق من قول قتادة.أخرجه ابن جرير ٥/٣٨٠، وابن المنذر ١/١٩٠، وابن أبي حاتم ٢/٦٤٣. وعزاه السيوطي إلى أحمد في الزهد.أخرجه الطستي -كما في الإتقان ٢/٩٠-.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن أبي حاتم ٢/٦٤٣.علَّقه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن جرير ٥/٣٧٨.أخرجه ابن جرير ٥/٣٧٨.أخرجه الثوري في تفسيره ص٧٦، وابن أبي شيبة ٨/٣٣٧، ١١/٥٦٢، وأحمد في الزهد ص٧٦، وعبد بن حميد كما في قطعة من تفسيره ص٢٩، وابن جرير ٥/٣٧٩. وعلَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه ابن جرير ٥/٣٧٩ من طريق النَّضْر بن عَرَبِيٍّ، والبيهقي في سُنَنِه ٧/٨٣. وعلَّقه ابن أبي حاتم ٢/٦٤٣. وعزاه السيوطي إلى أحمد.أخرجه أحمد في الزهد ص٩٠، والخرائطيُّ في مكارم الأخلاق (١٧، ٢٦٨-منتقى) بدون ذكر الحصور فيه. وعلَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه ابن جرير ٥/٣٧٩، وابن أبي حاتم ٢/٦٤٤. وعلَّقه ابن المنذر ١/١٩٠.علَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩، وابن جرير ٥/٣٨١.ذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعلَّقه ابن أبي حاتم ٢/٦٤٣ بلفظ: هو الذي لا يأتي النساء.علَّقه ابن أبي حاتم ٢/٦٤٣.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٩. وعزاه الحافظ ابن حجر في الفتح ٤/٤ إلى ابن جرير.أخرجه ابن جرير ٥/٣٨٠. وعلَّقه ابن المنذر ١/١٩٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زَمنين ١/٢٨٧-.أخرجه ابن جرير ٥/٣٨٠.أخرجه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن المنذر ١/١٩١. وعلَّقه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن جرير ٥/٣٧٩.تفسير مقاتل بن سليمان ١/٢٧٤.أخرجه ابن جرير ٥/٣٨٠.أخرجه النسائي في الكبرى ٧/٣١٨ (٨١١٣)، ٧/٤٦٠ (٨٤٧٥)، وابن حبان ١٥/٤١١-٤١٢ (٦٩٥٩)، والحاكم ٣/١٨٢ (٤٧٧٨) وفي إسناده الحكم بن عبد الرحمن بن أبي نعم. وأخرجه أحمد مختصرًا ١٧/٣١ (١٠٩٩٩)، ١٨/١٣٨ (١١٥٩٤)، ١٨/١٦١ (١١٦١٨)، ١٨/٣٠١ (١١٧٧٧)، والترمذي ٦/٣٢٤-٣٢٥ (٤١٠١، ٤١٠٢). قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث قد صح من أوجه كثيرة، وأنا أتعجب أنهما لم يخرجاه». وقال الذهبي في التلخيص: «الحكم بن عبد الرحمن بن أبي نعم فيه لين». وقال السخاوي في المقاصد الحسنة ص٣٠٦ (٤٠٧): «وقد روى هذا الحديث سويد بن سعيد عن أبي معاوية عن الأعمش عن عطية عن أبي سعيد، فقال ابن معين: إنه باطل عن أبي معاوية، قال الدارقطني: فلم نزل نظن أن هذا كما قال ابن معين حتى دخلت مصر في سنة سبع وخمسين فوجدت الحديث في مسند إسحاق بن إبراهيم المنجنيقي - وكان ثقة - رواه عن أبي كريب عن أبي معاوية كما قال سويد سواء، وتخلص سويد». وصحّحه الألباني في الصحيحة ٢/٤٢٣-٤٣١ (٧٩٦).أخرجه الطبراني في الكبير ٨/٢٠٤ (٧٨٢٧) من طريق علي بن يزيد، عن القاسم، عن أبي أمامة به. قال الهيثمي في المجمع ٨/١٠٣ (١٣٢٠٢): «فيه علي بن يزيد الألهاني، وهو متروك». وقال الألباني في الصحيحة ٦/١٢١٢: «حديث منكر ضعيف الإسناد جِدًّا».أخرجه أحمد في الزهد ص٧٦.أخرجه أحمد في الزهد ص٧٦، والبيهقي في الشعب (٥٧٠٠)، وابن عساكر ٦٤/٢٠٣.
3,40," <q>﴿قَالَ رَبِّ أَنَّىٰ یَكُونُ لِی غُلَـٰمࣱ وَقَدۡ بَلَغَنِیَ ٱلۡكِبَرُ﴾</q> - تفسير ١٢٧٩٠- عن عبد الله بن عباس -من طريق الضَّحّاك-: كان ابنَ عشرين ومائة سنة، وكانت امرأتُه بنتَ ثمانٍ وتسعين سنة{1}. (ز) ١٢٧٩١- عن عكرمة مولى ابن عباس -من طريق أبي بكر- قال: أتاه الشيطانُ، فأراد أن يُكَدِّر عليه نعمةَ ربِّه، قال: هل تدري مَن ناداك؟ قال: نعم، ناداني ملائكةُ ربي. قال: بل ذلك الشيطان، لو كان هذا مِن ربِّك لأخفاهُ إليك كما أخفيتَ نداءك. فقال: <q>﴿رب اجعل لي آية﴾</q>{2}. (٣/٥٣٥) ١٢٧٩٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا سمع زكريا النّداءَ جاءه الشيطان، فقال له: يا زكريا، إنّ الصَّوْت الذي سمعت ليس هو من الله، إنّما هو مِن الشيطان لِيَسْخَر بك، ولو كان من الله أوحى إليك كما يُوحي إليك في غيره من الأمر. فشكّ مكانه، وقال: <q>﴿أنى يكون لي غلام﴾</q>{3}١١٨٦. (٣/٥٣٤) ١١٨٦ لم يذكر ابنُ جرير (٥/٣٨٣) غير هذا القول، وأورد قول عكرمة، والسدي، ثم قال مستنِدًا إلى دلالة الإسرائيليات: «فكان قوله ما قال من ذلك، ومراجعته ربّه فيما راجع فيه بقوله: <q>﴿أنى يكون لي غلام﴾</q>؛ للوسوسة التي خالطت قلبَه من الشّيطان، حتى خَيَّلَتْ إليه أنّ النداء الذي سمعه كان نِداءً من غير الملائكة، فقال: <q>﴿رب أنى يكون لي غلام﴾</q> مُستَثْبتًا في أمره ليتقرّر عنده بآيةٍ يريه الله في ذلك أنّه بشارة من الله على ألسن ملائكته، ولذلك قال: <q>﴿رب اجعل لي آية﴾</q>». ثم ذكر (٥/٣٨٣) بعد ذلك وجهًا آخر لتأويل الآية، فقال: «وقد يجوز أن يكون قيلُه ذلك مسألةً منه ربَّه: مِن أيِّ وجهٍ يكون الولد الذي بُشّر به؟ أمِن زوجته فهي عاقر، أم من غيرها من النساء؟ فيكون ذلك على غير الوجه الذي قاله عكرمة، والسدي، ومَن قال مثل قولهما». وعلّق ابنُ عطية (٢/٢١٣) على الوجه الآخر الذي ذكره ابن جرير بقوله: «وهذا تأويل حسنٌ لائِقٌ بزكرياء ﵇». ١٢٧٩٣- عن إسماعيل السُّدِّيّ –من طريق أسباط- قال: <q>﴿أنى يكون لي غلام﴾</q>، يقول: مِن أين؟{4}. (ز) ١٢٧٩٤- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿أنّى يكون لي﴾</q>، قال: كيف يكون لي؟{4}. (ز) ١٢٧٩٥- عن محمد بن السّائِب الكلبي: <q>﴿قال ربّ﴾</q>، أي: يا سيِّدي. قاله لجبريل ﵇{6}. (ز) ١٢٧٩٦- عن محمد بن السّائِب الكلبي: كان زكريا يوم بُشِّر بالولد ابن ثنتين وتسعين سنة{6}. (ز) ١٢٧٩٧- قال مقاتل بن سليمان: فلَمّا بُشِّر زكريا بالولد قال لجبريل ﵇ في المخاطبة: <q>﴿قال رب أنى﴾</q>، يعني: مِن أين <q>﴿يكون لي غلام وقد بلغني الكبر وامرأتي عاقر﴾</q>{8}. (ز) <q>﴿وَٱمۡرَأَتِی عَاقِرࣱۖ﴾</q> - تفسير ١٢٧٩٨- عن الحسن البصري: أراد أن يَعْلَم كيف وُهِبَ ذلك له وهو كبيرٌ وامرأتُه عاقِرٌ؛ ليزداد علمًا{9}. (ز) ١٢٧٩٩- قال مقاتل بن سليمان: <q>﴿وقد بلغني الكبر وامرأتي عاقر﴾</q>، يقولُ ذلك تَعَجُّبًا؛ لأنّه كان قد يَبِس جِلْدُه على عظمه مِن الكِبَر{8}. (ز) ١٢٨٠٠- عن شعيب الجَبَئِيِّ -من طريق وهب بن سليمان-: أنّ اسمَ أُمِّ يحيى: أشْيَع{11}. (٣/٥٣٥) <q>﴿قَالَ كَذَ ٰ⁠لِكَ ٱللَّهُ یَفۡعَلُ مَا یَشَاۤءُ ۝٤٠﴾</q> - تفسير ١٢٨٠١- عن أبي مالك غَزْوان الغِفارِيِّ -من طريق السدي- قوله: <q>﴿كذلك﴾</q>، قال: يعني: هكذا{12}. (ز) ١٢٨٠٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿كذلك﴾</q>، يعني: هكذا{13}. (٣/٥٣٥) ١٢٨٠٣- قال مقاتل بن سليمان: <q>﴿قال﴾</q> جبريل ﵇: <q>﴿كذلك﴾</q>، يعني: هكذا قال ربك إنّه يكون لك ولد، <q>﴿الله يفعل ما يشاء﴾</q> أن يجعل ولدًا من الكبير والعاقر؛ لقوله: <q>﴿وقد بلغني الكبر وامرأتي عاقر﴾</q>{8}. (ز) ",footnotes:1:تفسير البغوي ٢/٣٥.أخرجه ابن جرير ٥/٣٨٢-٣٨٣.أخرجه ابن جرير ٥/٣٨٢، وابن أبي حاتم ٢/٦٤٤.أخرجه ابن أبي حاتم ٢/٦٤٤.أخرجه ابن أبي حاتم ٢/٦٤٤.تفسير الثعلبي ٣/٦٥، وتفسير البغوي ٢/٣٥.تفسير الثعلبي ٣/٦٥، وتفسير البغوي ٢/٣٥.تفسير مقاتل بن سليمان ١/٢٧٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٨-.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه ابن جرير ٥/٣٥٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٢/٦٤٥.عزاه السيوطي إلى ابن أبي حاتم، وعند ابن أبي حاتم ٢/٦٤٥ عن السدي عن أبي مالك.تفسير مقاتل بن سليمان ١/٢٧٥.
3,41," <q>﴿قَالَ رَبِّ ٱجۡعَل لِّیۤ ءَایَةࣰۖ﴾</q> - تفسير ١٢٨٠٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿رب اجعل لي آية﴾</q>، قال: قال زكريا: يا ربِّ، فإن كان هذا الصَّوْتُ مِنكَ فاجعل لي آية{1}. (٣/٥٣٥) ١٢٨٠٥- عن عبد الملك ابن جُرَيْج -من طريق ابن ثور- <q>﴿رب اجعل لي آية﴾</q>، قال: بالحمل به{2}. (٣/٥٣٥) ١٢٨٠٦- قال مقاتل بن سليمان: <q>﴿قال رب اجعل لي آية﴾</q>، يعني: عَلَمًا للحَبَل{3}. (ز) <q>﴿قَالَ ءَایَتُكَ أَلَّا تُكَلِّمَ ٱلنَّاسَ ثَلَـٰثَةَ أَیَّامٍ إِلَّا رَمۡزࣰاۗ﴾</q> - تفسير ١٢٨٠٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لَمّا بُشِّرَ بيحيى قال: <q>﴿رب اجعل لي آية قال آيتك ألا تكلم النّاس﴾</q>، قال: يُعْتَقَلُ لسانُك مِن غير مرضٍ، وأنت سَوِيٌّ{4}. (٣/٥٢١) ١٢٨٠٨- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿إلا رمزًا﴾</q>، قال: الرَّمْز بالشَّفَتين{5}. (٣/٥٣٦) ١٢٨٠٩- عن عبد الله بن عباس -من طريق العوفيِّ- قال: الرَّمْز أن أُخِذ بلسانه، فجعل يُكَلِّمُ الناسَ بيده{6}. (٣/٥٣٧) ١٢٨١٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿إلا رمزًا﴾</q>. قال: الإشارةُ باليد، والوَحْيُ بالرأس. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر: ما في السماء من الرحمن مُرْتَمزٌ إلا إليه، وما في الأرض مِن وزَرِ؟{7}. (٣/٥٣٧) ١٢٨١١- عن أبي عبد الرحمن السلمي -من طريق عطاء بن السائب- قال: اعْتُقِل لسانُه مِن غير مرضٍ{5}. (٣/٥٣٦) ١٢٨١٢- عن جُبَير بن نُفَير -من طريق صفوان بن عمرو- قال: ربا لسانُه في فيه حتّى مَلَأَهُ، فمنعه الكلامَ، ثم أطلقه اللهُ بعد ثلاث{9}. (٣/٥٣٦) ١٢٨١٣- عن سعيد بن جبير -من طريق عطاء- <q>﴿إلا رمزًا﴾</q>، يقول: يُومِئُ إيماءً{10}. (ز) ١٢٨١٤- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿إلا رمزًا﴾</q>، قال: الإشارة{11}. (٣/٥٣٦) ١٢٨١٥- وعن أبي عبد الرحمن السلمي= (ز) ١٢٨١٦- ومحمد بن كعب القرظي= (ز) ١٢٨١٧- وزيد بن أسلم، نحو ذلك{12}. (ز) ١٢٨١٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿إلا رمزًا﴾</q>، قال: إيماؤُه بشفتيه{13}. (٣/٥٣٦) ١٢٨١٩- عن مجاهد بن جبر -من طريق النَّضْر بن عَرَبِيٍّ- <q>﴿إلا رمزًا﴾</q>، قال: تحريك الشفتين{14}. (ز) ١٢٨٢٠- عن الضَّحّاك بن مُزاحِم -من طريق سلمة بن نُبَيْط- قال: الرَّمْزُ: أن يشير بيده أو رأسه ولا يتكلَّم{15}. (٣/٥٣٧) ١٢٨٢١- عن عكرمة مولى ابن عباس -من طريق النَّضْر بن عَرَبِيٍّ- في قوله ﷿: <q>﴿إلا رمزًا﴾</q>، قال: حَرَّكَ شَفَتَه{16}. (ز) ١٢٨٢٢- عن الحسن البصري -من طريق عبّاد بن منصور- في قوله: <q>﴿قال آيتك ألا تكلم الناس ثلاثة أيام إلا رمزًا﴾</q>، قال: أُمْسِكَ بلسانه، فجعل يُومِئُ بيده إلى قومه: أن سَبِّحُوا بُكْرَةً وعَشِيًّا{17}. (ز) ١٢٨٢٣- قال عطاء: <q>﴿إلا رمزًا﴾</q>، أراد به صوم ثلاثة أيّامٍ؛ لأنّهم إذا صاموا لم يتكلَّموا إلا رمزًا{18}. (ز) ١٢٨٢٤- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿آيتك ألا تكلم الناس ثلاثة أيّام﴾</q>، قال: إنّما عُوقِب بذلك لأنّ الملائكة شافهتْهُ بذلك مُشافَهَةً، فبَشَّرَتْه بيحيى، فسأل الآيةَ بعد كلام الملائكة إيّاه، فأخذ عليه بلسانه{19}. (٣/٥٣٥) ١٢٨٢٥- عن قتادة بن دِعامة -من طريق مَعْمَر- <q>﴿إلا رمزًا﴾</q>، قال: إلا إيماءً{20}. (ز) ١٢٨٢٦- عن ابن كثير المكي -من طريق ابن جُرَيْج- <q>﴿إلا رمزًا﴾</q>، قال: إلا إشارة{21}. (ز) ١٢٨٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿إلا رمزًا﴾</q>، يقول: إشارة{22}. (ز) ١٢٨٢٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: اعْتُقِلَ لسانهُ ثلاثةَ أيّامٍ وثلاثَ ليالٍ{5}. (٣/٥٣٦) ١٢٨٢٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فنادته الملائكة﴾</q> الآية، قال: فجاء الشَّيطانُ إلى زكريّا، فقال: هذا النداءُ الذي نُودِيتَ ليس مِن الله، إنّما هو من الشيطان، سَخِرَ بِك، لو كان من الله أوحاه إليك كما كان يُوحي إليك. فقال عند ذلك: <q>﴿رب اجعل لي آية﴾</q>؛ حتى أعلم أنّ هذا النّداء منك. فقال له: <q>﴿آيتك ألا تكلم الناس ثلاثة أيام إلا رمزا﴾</q>{2}. (ز) ١٢٨٣٠- عن عطاء بن السائب -من طريق ورقاء- في قوله: <q>﴿إلا رمزًا﴾</q>، قال: اعْتُقِلَ لسانه من غير مرض{10}. (ز) ١٢٨٣١- عن خُصَيْف بن عبد الرحمن -من طريق محمد بن سلمة- <q>﴿إلا رمزًا﴾</q>، قال: إشارة بالشَّفَتَيْن والحاجِبَيْن{26}. (ز) ١٢٨٣٢- عن الربيع بن أنس -من طريق أبي جعفر- قال: ذُكِر لنا -والله أعلم-: أنّه عوقب؛ لأنّ الملائكة شافهته، فبَشَّرَتْه بيحيى، قالت: <q>﴿أن الله يبشرك بيحيى﴾</q>. فسأل بعد كلام الملائكة إيّاه الآيةَ، فأُخِذ عليه لسانُه، فجعل لا يقدر على الكلام إلا رمزًا، يقول: يُومِئُ إيماءً{27}. (ز) ١٢٨٣٣- قال مقاتل بن سليمان: <q>﴿قال آيتك﴾</q> إذا جامعتَها على طهر فحَبَلَتْ؛ فإنّك تصبح لا تَسْتَنكِرُ مِن نفسك خَرَسًا ولا سَقَمًا، ولكن تُصْبِح لا تُطِيق الكلامَ، <q>﴿ألا تكلم الناس ثلاثة أيام إلا رمزًا﴾</q>، يعني: إلّا إشارة يومئ بيده، أو برأسه من غير مرض، ... فأتى امرأته على طهرها فحَمَلت، وكان آيةُ الحَبَل أنّه وضع يده على صدرها، فحَمَلَتْ، فاستقرّ الحَمْلُ في رَحِمِها، فحبلت بيحيى، فأصبح لا يستطيع الكلام، فعرف أنّ امرأته قد حَبَلَتْ، فولدت يحيى ﵇، فلم يعصِ اللهَ قطُّ{28}. (ز) ١٢٨٣٤- عن عبد الملك ابن جُرَيْج: <q>﴿آيتك أن لا تكلم الناس ثلاثة أيّام﴾</q>، قال: تمسك على فيك{29}. (ز) ١٢٨٣٥- عن محمد بن إسحاق -من طريق سلمة- <q>﴿إلا رمزًا﴾</q>، قال: والرَّمْزُ: الإشارة{6}. (ز) ١٢٨٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿رب اجعل لي آية قال آيتك ألا تكلم الناس ثلاثة أيام إلا رمزًا﴾</q> الآية، قال: جعل آيتَه أن لا يُكَلِّمَ الناسَ ثلاثة أيّام إلا رمزًا، إلا أنّه يذكر الله. والرمزُ: الإشارةُ، يشير إليهم{6}١١٨٧. (ز) ١١٨٧ ذَهَبَ ابنُ عطية (٢/٢١٥) إلى العموم، وعدم تخصيص الرَّمز بمعنى دون غيره، حيث إنّه قال: «والرَّمز في اللغة: حركةٌ تُعْلِمُ بما في نَفْسِ الرّامِز، بأيِّ شيء كانت الحركة؛ من عين، أو حاجب، أو شفة، أو يد، أو عود، أو غير ذلك. وقد قيل للكلام المُحَرَّف عن ظاهره: رموز؛ لأنّها علاماتٌ بغير اللفظ الموضوع للمعنى المقصود الإعلامِ به. وقد يُقالُ للتصويت الدالِّ على معنًى: رمز». ثم قال: «وأمّا المفسرون فخصَّص كُلُّ واحدٍ منهم نوعًا من الرَّمز في تفسيره هذه الآية». <q>﴿وَٱذۡكُر رَّبَّكَ كَثِیرࣰا وَسَبِّحۡ بِٱلۡعَشِیِّ وَٱلۡإِبۡكَـٰرِ ۝٤١﴾</q> - تفسير ١٢٨٣٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وسبح بالعشي والإبكار﴾</q>، قال: العشيُّ: ميل الشمس إلى أن تغيب. والإبكار: أوَّلُ الفجر{32}. (٣/٥٣٨) ١٢٨٣٨- عن مجاهد بن جبر -من طريق عبد الله بن كثير- في قوله: <q>﴿وسبّح بالعشي والإبكار﴾</q>، قال: صلاة المكتوبة{11}. (ز) ١٢٨٣٩- قال مقاتل بن سليمان: ولم يُحْبَس لسانُه عن ذكر الله ﷿، ولا عن الصلاة، فكذلك قوله سبحانه: <q>﴿واذكر ربك كثيرًا وسبّح بالعشيّ والإبكار﴾</q>، يقول: صَلِّ بالغداة والعَشِيِّ{3}١١٨٨. (ز) ١١٨٨ رَجَّح ابنُ عطية (٢/٢١٦) أنّ الأمر بالتسبيح معناه هنا: قُل: سبحان الله. مستنِدًا إلى السّياق، ودلالة عقليّة، فقال: «<q>﴿وسَبِّحْ﴾</q> معناه: قُل: سبحان الله. وقال قومٌ: معناه: صَلِّ. والقولُ الأوَّلُ أصوب؛ لأنّه يناسب الذِّكْر، ويُستغرب مع امتناع الكلام مع الناس». <q>﴿وَٱذۡكُر رَّبَّكَ كَثِیرࣰا وَسَبِّحۡ بِٱلۡعَشِیِّ وَٱلۡإِبۡكَـٰرِ ۝٤١﴾</q> - آثار متعلقة بالآية ١٢٨٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: لا يكون العبدُ مِن الذاكرين الله كثيرًا حتى يذكر اللهَ قائِمًا ومُضْطَجِعًا{11}. (ز) ١٢٨٤١- عن محمد بن كعب القُرَظِيِّ -من طريق أبي معشر- قال: لو رَخَّص الله لأحد في ترك الذِّكْرِ لَرَخَّص لزكريا ﵇، حيث قال: <q>﴿آيتك ألا تكلم الناس ثلاثة أيّام إلا رمزًا واذكر ربّك كثيرًا﴾</q>، ولو رَخَّص لأحد في ترك الذِّكر لرَخَّص لِلَّذِين يُقاتِلون في سبيل الله، قال الله: <q>﴿يا أيها الذين آمنوا إذا لقيتم فئة فاثبتوا واذكروا الله كثيرًا﴾</q> [الأنفال:٤٥]{36}. (٣/٥٣٧) ",footnotes:1:أخرجه ابن جرير ٥/٣٨٤، وابن أبي حاتم ٢/٦٤٥.أخرجه ابن المنذر ١/١٩٣.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه الحاكم ٢/٢٩١.أخرجه ابن أبي حاتم ٢/٦٤٥.أخرجه ابن جرير ٥/٣٨٩.أخرجه الطستيُّ -كما في الإتقان ٢/٨٠-. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن أبي حاتم ٢/٦٤٥.أخرجه ابن جرير ٥/٣٨٧. وعلَّقه ابن أبي حاتم ٢/٦٤٦ عن عبد الرحمن بن جبير بن نفير.تفسير مجاهد ص٢٥٢.أخرجه ابن أبي حاتم ٢/٦٤٦.علَّقه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن جرير ٥/٣٨٨، وابن المنذر ١/١٩٤. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/٣٨٨، وابن أبي حاتم ٢/٦٤٦ بلفظ: كلام بالشفتين.أخرجه الثوري في تفسيره ص٧٧، وابن جرير ٥/٣٨٩. وعلَّقه ابن أبي حاتم ٢/٦٤٦ مختصرًا. وذكره عبد بن حميد كما في قطعة من تفسيره ص٢٩.أخرجه ابن المنذر ١/١٩٤. وعلَّقه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن جرير ٥/٣٩٠. وعلَّقه ابن أبي حاتم ٢/٦٤٦ مختصرًا.تفسير الثعلبي ٣/٦٦، وتفسير البغوي ٢/٣٦.أخرجه عبد الرزاق ١/١٢٠، وابن جرير ٥/٣٨٦، وابن المنذر ١/١٩٣ من طريق سعيد، وابن أبي حاتم ٢/٦٤٥. ولفظ عبد الرزاق وابن أبي حاتم هو: إيماء، وكانت عقوبةً عُوقِب بها، إذ سأل الآيةَ بعد مشافهة الملائكة إيّاه بما بشّرته. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ١/١٢٠، وابن جرير ٥/٣٩٠، وابن المنذر ١/١٩٥ من طريق سلّام بن أبي مُطيع. وعلَّقه ابن أبي حاتم ٢/٦٤٦ بلفظ: الإشارة.أخرجه ابن جرير ٥/٣٩٠.أخرجه ابن جرير ٥/٣٩٠. وعلَّقه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن أبي حاتم ٢/٦٤٥.أخرجه ابن المنذر ١/١٩٣.تفسير مجاهد ص٢٥٢.أخرجه ابن المنذر ١/١٩٤. وعلَّق ابن أبي حاتم ٢/٦٤٦ نحوه.أخرجه ابن جرير ٥/٣٨٦. وعلَّقه ابن أبي حاتم ٢/٦٤٦ بلفظ: الإشارة.تفسير مقاتل ١/٢٧٥.علَّقه ابن المنذر ١/١٩٣.أخرجه ابن جرير ٥/٣٨٩.أخرجه ابن جرير ٥/٣٨٩.أخرجه ابن جرير ٥/٣٩٢، وابن المنذر ١/١٩٥، وابن أبي حاتم ٢/٦٤٦-٦٤٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٦٤٦.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه ابن أبي حاتم ٢/٦٤٦.أخرجه ابن جرير ٥/٣٩١، وابن المنذر (٤٤٥)، وابن أبي حاتم ٢/٦٤٦، وأبو نعيم ٣/٢١٥.
3,42," <q>﴿وَإِذۡ قَالَتِ ٱلۡمَلَـٰۤىِٕكَةُ یَـٰمَرۡیَمُ إِنَّ ٱللَّهَ ٱصۡطَفَىٰكِ وَطَهَّرَكِ﴾</q> - تفسير ١٢٨٤٢- عن عبد الله بن عباس -من طريق جُوَيْبِر ومقاتل، عن الضَّحّاك- قال: لَمّا وهَب اللهُ لزكريا يحيى، وبلغ ثلاث سنين؛ بشَّر اللهُ مريم بعيسى، فبينما هي في المحراب إذ قالت الملائكة -وهو جبريل وحده-: <q>﴿يا مريم إن الله اصطفاك وطهرك﴾</q> مِن الفاحشة{1}. (٣/٥٤٤) ١٢٨٤٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿إن الله اصطفاك وطهرك﴾</q>، قال: جعلك طيِّبَةً إيمانًا{2}١١٨٩. (٣/٥٤١) ١١٨٩ لم يذكر ابنُ جرير (٥/٣٩٦) غيرَ هذا القول. ١٢٨٤٤- عن إسماعيل السُّدِّيِّ -من طريق الحكم- <q>﴿وطهرك﴾</q>، قال: مِن الحيض{3}١١٩٠. (٣/٥٤١) ١١٩٠ عَلَّق ابنُ عطية (٢/٢١٧) على هذا القول بقوله: «وهذا يحتاج إلى سند قويٍّ، وما أحفظه». ١٢٨٤٥- عن عكرمة مولى ابن عباس، نحو ذلك{4}. (ز) ١٢٨٤٦- قال مقاتل بن سليمان: <q>﴿وإذ قالت الملائكة﴾</q> وهو جبريل ﵇ وحده: <q>﴿يامريم﴾</q> وهي في المحراب، <q>﴿إن الله اصطفاك﴾</q> يعني: اختارك، <q>﴿وطهرك﴾</q> مِن الفاحشة، والألم{5}. (ز) <q>﴿وَٱصۡطَفَىٰكِ عَلَىٰ نِسَاۤءِ ٱلۡعَـٰلَمِینَ ۝٤٢﴾</q> - تفسير ١٢٨٤٧- عن أبي هريرة -من طريق سعيد بن المُسَيِّب- في قوله: <q>﴿إن الله اصطفاك وطهّرك واصطفاك على نساء العالمين﴾</q> أنّه كان يُحَدِّثُ عن رسول الله ﷺ أنّه قال: «خيرُ نساءٍ رَكِبْن الإبِلَ نساءُ قريش؛ أحْناهُ على ولد في صِغَرِه، وأَرْعاهُ على زوجٍ في ذاتِ يدٍ». قال أبو هريرة: ولم تركب مريمُ بنتُ عمران بعيرًا قط{6}١١٩١. (٣/٥٣٨) ١١٩١ عَلَّق ابنُ عطية (٢/٢١٨) على زيادة أبي هريرة بقوله: «وهذه الزيادة فيها غَيْبٌ، فلا يُتَأَوّل أنّ أبا هريرة ﵄ قالها إلا عن سماع من النبي ﷺ». ١٢٨٤٨- عن عبد الله بن عباس -من طريق جُوَيْبِر ومقاتل، عن الضحاك- قال: <q>﴿واصطفاك﴾</q> يعني: اختارَكِ <q>﴿على نساء العالمين﴾</q> عالَمِ أُمَّتِها{7}. (٣/٥٤٤) ١٢٨٤٩- عن إسماعيل السُّدِّيّ -من طريق الحكم- <q>﴿واصطفاك على نساء العالمين﴾</q>، قال: على نساء ذلك الزمان الذي هم فيه{3}. (٣/٥٤١) ١٢٨٥٠- قال مقاتل بن سليمان: <q>﴿واصطفاك﴾</q> يعني: واختاركِ <q>﴿على نساء العالمين﴾</q> بالوَلَدِ مِن غير بَشَرٍ{5}. (ز) ١٢٨٥١- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿واصطفاك على نساء العالمين﴾</q>، قال: ذلك للعالمين يومئذ{10}١١٩٢. (ز) ١١٩٢ اختلف المفسرون في الاصطفاء هنا؛ أهُوَ على العموم أم على الخصوص؟ وذكر ابنُ عطيّة (٢/٢١٧) أنّ الآية تحتمل الوجهين، فقال: «إن جعلنا <q>﴿العالَمِينَ﴾</q> عامًّا فيمن تقدَّم وتأخَّر جعلنا الاصطفاء مخصُوصًا في أمر عيسى ﵇، وأنًّها اصطُفِيَت لتَلِد مِن غير فَحْل، وإن جعلنا الاصطفاء عامًّا جعلنا قولَه تعالى: <q>﴿العالَمِينَ﴾</q> مخصوصًا في عالَمِ ذلك الزمان». ١٢٨٥٢- عن محمد بن إسحاق -من طريق سلمة- قال: كانت مريمُ حَبيسًا في الكنيسة، ومعها في الكنيسة غلامٌ اسمُه يوسف، وقد كان أمُّه وأبوه جعلاه نَذيرًا حبيسًا، فكانا في الكنيسة جميعًا، وكانتْ مريم إذا نفِدَ ماؤُها وماءُ يوسف أخذا قُلَّتَيْهما فانطلقا إلى المَغارَة التي فيها الماء، فيملَآنِ ثُمَّ يرجعان، والملائكة في ذلك مُقْبِلة على مريم: <q>﴿يا مريم إن الله اصطفاك وطهرك واصطفاك على نساء العالمين﴾</q>. فإذا سمع ذلك زكريا قال: إنّ لابنةِ عمران لَشَأْنًا{11}١١٩٣. (٣/٥٤١) ١١٩٣ اختُلِف في نبوّة السّيّدة مريم، قال ابنُ عطية (٢/٢١٨): «وقد قال بعضُ الناس: إنّ مريم نبيّة. قال ابن إسحاق: فمِن مخاطبة الملائكة لها جعلها هذا القائلُ نَبِيَّة». ثم قال بعد ذلك: «وجمهور الناس على أنّه لم تُنَبَّإ امرأةٌ». <q>﴿وَٱصۡطَفَىٰكِ عَلَىٰ نِسَاۤءِ ٱلۡعَـٰلَمِینَ ۝٤٢﴾</q> - آثار متعلقة بالآية ١٢٨٥٣- عن فاطمة، قالت: قال لي رسول الله ﷺ: «أنتِ سيِّدةُ نساء أهل الجنة، إلا مريم البَتُول»{12}. (٣/٥٤٠) ١٢٨٥٤- عن علي بن أبي طالب، قال: سمعتُ رسول الله يقول: «خيرُ نسائها مريمُ بنت عمران، وخيرُ نسائها خديجةُ بنت خويلد»{13}١١٩٤. (٣/٥٣٨) ١١٩٤ علَّق ابنُ جرير (٥/٣٩٣) على هذا الحديث بقوله: «يعني بقوله: «خير نسائها»: خير نساء أهل الجنة». وقال ابنُ عطية (٢/٢١٨) بعد ذكره لهذه الأحاديث: «وإذا تأمّلت هذه الأحاديث وغيرَها مِمّا هو في معناها: وجَدتَ مريم فيها متقدِّمة، فسائغٌ أن يُتَأَوَّل عمومُ الاصطفاء على العالَمِينَ عمومًا أيضًا». ١٢٨٥٥- عن عبد الله بن عبّاس، قال: قال رسول الله ﷺ: «أفضلُ نساء العالمين خديجةُ بنت خويلد، وفاطمةُ، ومريمُ، وآسيةُ امرأة فرعون»{14}. (٣/٥٣٩) ١٢٨٥٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «سيِّدةُ نساء أهل الجنة مريمُ بنت عمران، ثم فاطمةُ، ثم خديجةُ، ثم آسيةُ امرأة فرعون»{15}. (٣/٥٤٠) ١٢٨٥٧- عن ابن عباس -من طريق الضحاك- عن النبي ﷺ، قال: «أربعُ نسوة سيّداتُ عالَمِهِنَّ: مريم بنت عمران، وآسية بنت مزاحم، وخديجة بنت خويلد، وفاطمة بنت محمّد، وأفضلُهنَّ عالَمًا فاطمة»{16}. (٣/٥٤٠) ١٢٨٥٨- عن أنس بن مالك، قال: قال رسول الله ﷺ: «إنّ الله اصطفى على نساء العالمين أربعًا: آسية بنت مزاحم، ومريم بنت عمران، وخديجة بنت خويلد، وفاطمة بنت محمد»{17}. (٣/٥٣٩) ١٢٨٥٩- عن أبي موسى، قال: قال رسول الله ﷺ: «كَمُل من الرِّجال كثير، ولم يكمُل من النساء إلا مريم بنت عمران، وآسية امرأة فرعون. وفَضْلُ عائشةَ على النساء كفَضْل الثَّرِيدِ على الطعام»{18}. (٣/٥٣٩) ١٢٨٦٠- عن أنس بن مالك، أنّ رسول الله ﷺ قال: «حسبُك مِن نساء العالمين مريم بنت عمران، وخديجة بنت خويلد، وفاطمة بنت محمد، وآسية امرأة فرعون»{19}. (٣/٥٣٩) ١٢٨٦١- وعن الحسن البصري، نحوه{20}. (٣/٥٣٩) ١٢٨٦٢- عن عمّار بن سعد، قال: قال رسول الله ﷺ: «فُضِّلَتْ خديجةُ على نساء أُمَّتِي، كما فُضِّلَتْ مريمُ على نساء العالمين»{21}. (٣/٥٤٠) ١٢٨٦٣- عن عبد الرحمن بن أبي ليلى، قال: قال رسول الله ﷺ: «فاطمةُ سيِّدةُ نساء العالمين بعد مريم ابنة عمران، وآسية امرأة فرعون، وخديجة ابنة خويلد»{22}. (٣/٥٤٠) ١٢٨٦٤- عن مكحول، قال: قال رسول الله ﷺ: «خيرُ نساء رَكِبْن الإبل نساء قريش؛ أحْناه على ولدٍ في صِغَرِه، وأَرْعاه على بَعْلٍ في ذات يده، ولو عَلِمْتُ أنّ مريم ابنة عمران ركِبَتْ بعيرًا ما فَضَّلتُ عليها أحَدًا»{23}. (٣/٥٤٠) ١٢٨٦٥- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿وإذ قالت الملائكة يا مريم إن الله اصطفاك وطهّرك واصطفاك على نساء العالمين﴾</q>، قال: ذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «حسبُك بمريم بنت عمران، وامرأة فرعون، وخديجة بنت خويلد، وفاطمة بنت محمد مِن نساء العالمين»{24}. (ز) ",footnotes:1:أخرجه ابن عساكر ٤٧/٣٤٧-٣٤٨ من طريق إسحاق بن بشر. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ٥/٣٩٦، وابن المنذر ١/١٩٦ من طريق ابن جريج، وابن أبي حاتم ٢/٦٤٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٢/٦٤٧.علَّقه ابن أبي حاتم ٢/٦٤٧.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه عبد الرزاق في تفسيره ١/٣٩٣ (٤٠٠)، وابن المنذر ١/١٩٧ (٤٥١)، وابن أبي حاتم ٢/٦٤٧ (٣٤٨٨). وأخرجه البخاري ٤/١٦٤ (٣٤٣٤)، ٧/٦ (٥٠٨٢)، ٧/٦٦ (٥٣٦٥)، ومسلم ٤/١٩٥٨ (٢٥٢٧)، ٤/١٩٥٩ (٢٥٢٧) دون ذكر الآية.أخرجه ابن عساكر ٤٧/٣٤٧- ٣٤٨ من طريق إسحاق بن بشر. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم ٢/٦٤٧.تفسير مقاتل بن سليمان ١/٢٧٥.أخرجه ابن جرير ٥/٣٩٦.أخرجه ابن جرير ٥/٣٩٧.أخرجه ابن أبي شيبة ٦/٣٨٨ (٣٢٢٧٠)، وابن جرير ٥/٣٩٥. وأصله في البخاري ٤/٢٠٣ (٣٦٢٤) دون ذكر مريم.أخرجه البخاري ٤/١٦٤ (٣٤٣٢)، ٥/٣٨ (٣٨١٥)، ومسلم ٤/١٨٨٦ (٢٤٣٠).أخرجه أحمد في مسنده ٤/٤٠٩ (٢٦٦٨)، والحاكم ٢/٦٥٠ (٤١٦٠)، واللفظ للحاكم من طريق داود بن أبي الفرات، عن علباء بن أحمر، عن عكرمة، عن ابن عباس به. قال الحاكم: «صحيح الإسناد، ولم يخرجاه بهذا اللفظ». وصحّحه ابن حبان ١٥/٤٧٠ (٧٠١٠)، واختاره الضياء المقدسي في المختارة ١٢/١٦٧ (١٨٧)، وقال ابن حجر في فتح الباري ٦/٤٧١: «إسناده صحيح». وصحّحه الألباني في الصحيحة ٤/١٣.أخرجه الطبراني في الكبير ١١/٤١٥ (١٢١٧٩)، ٢٣/٧ (٢)، والأوسط ٢/٢٣ (١١٠٧) من طريق عبد العزيز بن محمد، عن إبراهيم بن عقبة، عن كريب، عن ابن عباس به. قال الطبراني في الأوسط: «لم يروِ هذا الحديثَ عن إبراهيم إلا الدَّراورْدِيُّ، ولا يُرْوى عن ابن عباس إلا بهذا الإسناد». وقال الهيثمي في المجمع ٩/٢٠١ (١٥١٩٠): «رواه الطبراني في الأوسط والكبير بنحوه، إلا أنه قال: وآسية. ورجال الكبير رجال الصحيح». وسبق تخريجه قبل قليل من طريق آخر عن ابن عباس، وقد صحَّحه جمعٌ من الأئمة.أخرجه ابن عساكر في تاريخه ٧٠/١٠٧-١٠٨ (١٣٨٠٥) من طريق إسحاق بن إبراهيم شاذان، عن سعد بن الصلت، عن مقاتل، عن الضحاك، عن ابن عباس به. وفي سنده إسحاق بن إبراهيم شاذان، قال عنه ابن حجر في لسان الميزان ٢/٣٣: «له مناكير وغرائب».عزاه السيوطي إلى ابن مردويه.أخرجه البخاري ٤/١٥٨ (٣٤١١)، ٤/١٦٤ (٣٤٣٣)، ٥/٢٩ (٣٧٦٩)، ٧/٧٥ (٥٤١٨)، ومسلم ٤/١٨٨٦ (٢٤٣١).أخرجه الترمذي ٦/٣٩٢ (٤٢١٦)، وأحمد ١٩/٣٨٣ (١٢٣٩١). قال الترمذي: «حديث صحيح». وصحَّحه ابنُ حبان ١٥/٤٦٤ (٧٠٠٣)، وقال الحاكم ٣/١٧٢ (٤٧٤٦): «حديث صحيح، على شرط الشيخين، ولم يخرجاه بهذا اللفظ؛ فإنّ قوله ﷺ: «حسبك من نساء العالمين» يسوي بين نساء الدنيا». واختاره الضياء المقدسي في المختارة ٧/٢١ (٢٤٠١)، وقال ابن حجر في الفتح ٦/٤٧١: «بإسناد صحيح». وأورده الألباني في الصحيحة ٤/١٣ (١٥٠٨).أخرجه ابن أبي شيبة ٦/٣٩١ (٣٢٢٩١)، وأحمد في فضائل الصحابة ٢/٨٥٠ (١٥٧٥) عن الحسن مرسلًا.أخرجه ابن جرير ٥/٣٩٦ من طريق ابن لهيعة، عن عمرو بن الحارث، عن أبي زياد الحميري، عن عمار بن سعد به. وأخرجه البزار ٤/٢٥٥ (١٤٢٧) بالإسناد نفسه، إلا أنّه قال: عن أبي يزيد الحميري عن عمار بن ياسر به. قال ابن حجر في الفتح ٧/١٣٥: «حسن الإسناد». و قال الهيثمي في المجمع ٩/٢٢٣ (١٥٢٧٠): «وفيه أبو يزيد الحميري ولم أعرفه، وبقيّة رجاله وثّقوا». وقال الشيخ أحمد شاكر في تحقيقه لتفسير الطبري ٦/٤٠٠: «هذا إسناد ضعيف بكل حال. أما أبو زياد الحميري فلم نعرف مَن هو؟ ولم نجد له ترجمة ولا ذِكرًا، والغالب أنه مُحَرَّف عن شيء لا ندريه. وأما عمار بن سعد بن عابد المؤذن فإنّه المعروف أبوه بلقب: سعد القرظ المؤذن. وعمّار هذا تابعيٌّ، نصَّ في التهذيب على أنّ روايته عن النّبي ﷺ مُرْسَلة. وقد ترجمه الحافظ في الإصابة ٥/٨٣، في القسم الثاني، الذين ولدوا في حياة رسول الله ﷺ».أخرجه ابن أبي شيبة ٦/٣٨٨ (٣٢٢٧٣) مرسلًا.أخرجه ابن أبي شيبة ٦/٤٠٣ (٣٢٤٠٢) مرسلًا.أخرجه ابن جرير ٥/٣٩٣. قال الشيخ أحمد شاكر: «حديث مرسل».
3,43," <q>﴿یَـٰمَرۡیَمُ ٱقۡنُتِی لِرَبِّكِ وَٱسۡجُدِی وَٱرۡكَعِی مَعَ ٱلرَّ ٰ⁠كِعِینَ ۝٤٣﴾</q> - قراءات ١٢٨٦٦- عن عبد الله بن مسعود -من طريق النزال- أنّه كان يقرأ: (وارْكَعِي واسْجُدِي فِي السّاجِدِينَ){1}. (٣/٥٤٢) <q>﴿یَـٰمَرۡیَمُ ٱقۡنُتِی لِرَبِّكِ وَٱسۡجُدِی وَٱرۡكَعِی مَعَ ٱلرَّ ٰ⁠كِعِینَ ۝٤٣﴾</q> - تفسير الآية ١٢٨٦٧- عن أبي سعيد الخُدْرِيِّ -من طريق درّاجٍ- عن النبي ﷺ، قال: «كُلُّ حرف يُذْكر فيه القنوتُ مِن القرآن فهو طاعةٌ لله»{2}. (ز) ١٢٨٦٨- عن عبد الله بن عباس -من طريق الضَّحّاك- قال في قوله: <q>﴿يا مريم اقنتي لربّك﴾</q>: يعني: صلّي لربّك، يقول: اركُدِي لربّك في الصلاة بطول القيام. فكانت تقوم حتى ورِمت قدماها، <q>﴿واسجدي واركعي مع الراكعين﴾</q> يعني: مع المصلين، مع قُرّاء بيت المقدس{3}. (٣/٥٤٤) ١٢٨٦٩- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- <q>﴿يا مريم اقنتي لربك﴾</q>: أي: اركُدِي لربك{4}. (ز) ١٢٨٧٠- عن سعيد بن جبير -من طريق سالم- <q>﴿اقنتي لربّك﴾</q>، قال: أخْلِصي{5}. (٣/٥٤٢) ١٢٨٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿يا مريم اقنتي لربّك﴾</q>، قال: أطِيلي الرُّكود في الصلاة. يعني: القيام{6}. (٣/٥٤٢) ١٢٨٧٢- عن مجاهد بن جبر -من طريق الحَكَم بن عتيبة- في قوله: <q>﴿يا مريم اقنتي لربك واسجدي﴾</q>، قال: طول الركوع في الصلاة{7}. (ز) ١٢٨٧٣- عن الحسن البصري -من طريق عبّاد بن منصور- في قوله: <q>﴿يا مريم اقنتي لربك﴾</q>، قال: يقول: اعبدي ربّك{8}. (ز) ١٢٨٧٤- عن قتادة بن دِعامة -من طريق معمر- <q>﴿اقنتي لربّك﴾</q>، قال: أطيعي ربّك{9}. (٣/٥٤٢) ١٢٨٧٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿اقنتي لربك﴾</q>، قال: أطيعي ربّك{10}. (ز) ١٢٨٧٦- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿يا مريم اقنتي لربك﴾</q> قال: القنوت: الرُّكود. يقول: قومي لربِّك في الصَّلاة. يقول: اركُدِي لربِّك، أي: انتصبي له في الصّلاة، <q>﴿واسجدي واركعي مع الراكعين﴾</q>{11}. (ز) ١٢٨٧٧- قال مقاتل بن سليمان: <q>﴿يامريم اقنتي لربك﴾</q> يعني: لربك، <q>﴿واسجدي واركعي مع الراكعين﴾</q> يعني مع المصلِّين في بيت المقدس{12}. (ز) ١٢٨٧٨- عن سفيان -من طريق أبي عبيد الله المخزومي- في قوله تعالى: <q>﴿يا مريم اقنتي لربك﴾</q>، قال: القنوتُ: طاعةُ الله تعالى{13}. (ز) <q>﴿یَـٰمَرۡیَمُ ٱقۡنُتِی لِرَبِّكِ وَٱسۡجُدِی وَٱرۡكَعِی مَعَ ٱلرَّ ٰ⁠كِعِینَ ۝٤٣﴾</q> - آثار متعلقة بالآية ١٢٨٧٩- عن أبي سعيد -من طريق عطيَّة- قال: كانت مريم تُصلِّي حتى تَرِمَ قدماها{14}. (٣/٥٤٢) ١٢٨٨٠- عن مجاهد بن جبر -من طريق ليث- قال: لَمّا قيل لها: <q>﴿اقنتي لربّك﴾</q> قامَت حتى ورِمَت قدماها{15}١١٩٥. (٣/٥٤٢) ١١٩٥ عَلَّق ابنُ كثير (٣/٦١ بتصرف) على قول مجاهد بقوله: «وقال مجاهد: يعني: امتثالًا لقوله تعالى: <q>﴿يا مريم اقنتي لربك﴾</q>». ١٢٨٨١- عن يحيى بن أبي كَثِير -من طريق الأوزاعي- في قوله تعالى: <q>﴿يا مريم اقنتي لربك﴾</q>، قال: سجدتْ حتى نزل الماءُ الأصفرُ في عينيها{13}. (ز) ١٢٨٨٢- عن عبد الرحمن بن عمرو الأوزاعي -من طريق عمرو- قال: كانت مريمُ تقوم حتى يسيل القَيْحُ مِن قدميها{17}. (٣/٥٤٢) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ص٥٤. وهي قراءة شاذة. انظر: روح المعاني ٣/١٥٨.أخرجه أحمد ١٨/٢٣٩ (١١٧١١)، وابن حبان ٢/٧ (٣٠٩)، وابن جرير ٥/٤٠٠ من طريق درّاج، عن أبي الهيثم، عن أبي سعيد به. صحّحه ابن حبان. وقال ابن كثير في تفسيره ١/٣٩٨: «هذا الإسناد ضعيف لا يعتمد عليه، ورَفْعُ هذا الحديث منكر، وقد يكون من كلام الصحابيِّ أو مَن دونه، والله أعلم. وكثيرًا ما يأتي بهذا الإسناد تفاسيرُ فيها نكارة، فلا يُغْتَرُّ بها؛ فإنّ السند ضعيف». وقال الهيثمي في المجمع ٦/٣٢٠ (١٠٨٦٨): «في إسناد أحمد وأبي يعلى ابن لهيعة، وهو ضعيف، وقد يحسن حديثه». وقال المناوي في فيض القدير ٥/١٨ (٦٢٩٧) بعد نقله كلام الهيثمي: «وفيه أيضًا درّاج عن أبي الهيثم، وقد سبق أنّ أبا حاتم وغيره ضعّفوه، وأنّ أحمد قال: أحاديثه مناكير». وقال الألباني في الضعيفة ٩/١٠٦ (٤١٠٥): «ضعيف».أخرجه ابن عساكر ٧٠/٨٨.أخرجه ابن أبي حاتم ٢/٦٤٨.أخرجه ابن جرير ٥/٣٩٩.أخرجه ابن جرير ٥/٣٩٨ بلفظ: «يعني: القنوت» في آخره. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٨- نحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه الثوري في تفسيره ص٧٧، وابن المنذر ١/١٩٧، وأبو جعفر الرملي في جزئه ص٧٥ -تفسير مسلم الزنجي (جزء فيه تفسير يحيى بن يمان، ونافع بن أبي نعيم، ومسلم الزنجي، وعطاء الخراساني)-. وأبو نعيم في حلية الأولياء ٣/٢٩٨ من طريق أبي ليلى. وفي الطبري والدُّرِّ عنه: أطيلي الركود. وفسّرها الأوّل بالقنوت، والثاني بالقيام. وأشار محقق الطبري إلى أنّه في إحدى النسخ: الركوع.أخرجه ابن جرير ٥/٤٠٠، وابن أبي حاتم ٢/٦٤٨.أخرجه عبد الرزاق ١/١٢١، وابن جرير ٥/٤٠٠، وابن المنذر ١/١٩٨.أخرجه ابن جرير ٥/٤٠٠.أخرجه ابن جرير ٥/٣٩٨.تفسير مقاتل بن سليمان ١/٢٧٦.أخرجه ابن عساكر في تاريخ دمشق ٧٠/١٠١.أخرجه ابن عساكر ٧٠/١٠٠.أخرجه عَبد بن حُمَيد كما في قطعة من تفسيره ص٣٠، وابن المنذر ١/١٩٧، وابن أبي حاتم ٢/٦٤٨ من طريق ليث. وعزاه السيوطي إلى ابن جرير.أخرجه ابن عساكر في تاريخ دمشق ٧٠/١٠١.أخرجه ابن جرير ٥/٣٩٩، وابن أبي حاتم ٢/٦٤٨ من طريق الوليد بلفظ: رَكَدتْ في محرابها قائمةً وراكعةً وساجدةً، حتى نزل الماء الأصفر من قدميها.
3,44," <q>﴿ذَ ٰ⁠لِكَ مِنۡ أَنۢبَاۤءِ ٱلۡغَیۡبِ نُوحِیهِ إِلَیۡكَۚ وَمَا كُنتَ لَدَیۡهِمۡ﴾</q> - تفسير ١٢٨٨٣- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: يقول الله لنبيه ﷺ: <q>﴿ذلك من أنباء الغيب نوحيه إليك﴾</q> يعني: بالخَبَر الغَيْب في قِصَّة زكريا ويحيى ومريم، <q>﴿وما كنت لديهم﴾</q> يعني: عندهم <q>﴿إذ يلقون أقلامهم﴾</q> في كفالة مريم{1}. (٣/٥٤٤) ١٢٨٨٤- عن أبي مالك غَزْوان الغِفارِيِّ -من طريق السدي- قوله: <q>﴿أنباء﴾</q> يعني: أحاديث، <q>﴿لديهم﴾</q> يعني: عندهم{2}. (ز) ١٢٨٨٥- عن الحسن البصري -من طريق عبّاد بن منصور- في قوله: <q>﴿وما كنت لديهم إذ يلقون أقلامهم﴾</q>، قال: حيث اقترعوا على مريم، وكان غيبًا عن محمد ﷺ حين أُخْبِرَه{3}. (ز) ١٢٨٨٦- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿وما كنت لديهم﴾</q>: يعني: محمدًا ﷺ{4}. (٣/٥٤٣) ١٢٨٨٧- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> أنّ الذي ذُكِر في هؤلاء الآيات <q>﴿من أنباء الغيب﴾</q> يعني: حديثًا من الغيب لَمْ تشهدْه، يا محمد، فذلك قوله: <q>﴿نوحيه إليك وما كنت لديهم إذ يلقون أقلامهم﴾</q>{5}. (ز) ١٢٨٨٨- عن محمد بن إسحاق -من طريق عبد الله بن إدريس- قوله: <q>﴿ذلك من أنباء الغيب نوحيه إليك﴾</q>، ثُمَّ قد جئتَهم به دليلًا على نُبُوَّتِك، والحُجَّةُ لك عليهم، <q>﴿وما كنت لديهم﴾</q> يقول: ما حضرتَ، ولا عينت{6}. (ز) <q>﴿إِذۡ یُلۡقُونَ أَقۡلَـٰمَهُمۡ﴾</q> - تفسير ١٢٨٨٩- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: <q>﴿أقلامهم﴾</q>، قال: التي يكتبون بها التَّوْراة{6}. (٣/٥٤٤) ١٢٨٩٠- عن مجاهد بن جبر، مثله{8}. (٣/٥٤٤) ١٢٨٩١- عن الحسن البصري: <q>﴿أقلامهم﴾</q>: سهامهم، يعني: قِداحهم التي اسْتَهَمُوا بها عليها، فخرج قِدْحُ زكريا فضمّها، فيما قال{9}. (ز) ١٢٨٩٢- عن الربيع بن أنس -من طريق أبي جعفر- قال: <q>﴿أقلامهم﴾</q>، يقول: عِصِيَّهم{10}. (٣/٥٤٣) ١٢٨٩٣- عن عطاء الخراساني -من طريق ابن جريج- <q>﴿أقلامهم﴾</q>، يعني: قِداحَهم{11}. (٣/٥٤٤) ١٢٨٩٤- عن سعيد بن إسحاق الدمشقي -من طريق عبّاس الحذاء- في قول الله ﷿: <q>﴿إذ يلقون أقلامهم أيّهم يكفل مريم﴾</q>، قال: على نهرٍ بحَلَب، يُقال له: قُوَيْق{12}. (ز) <q>﴿أَیُّهُمۡ یَكۡفُلُ مَرۡیَمَ وَمَا كُنتَ لَدَیۡهِمۡ إِذۡ یَخۡتَصِمُونَ ۝٤٤﴾</q> - تفسير ١٢٨٩٥- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وما كنت لديهم إذ يلقون أقلامهم أيهم يكفل مريم﴾</q>، قال: إنّ مريم ﵍ لَمّا وُضِعَتْ في المسجد اقْتَرَع عليها أهلُ الـمُصَلّى وهم يكتبون الوحي، فاقْتَرَعوا بأقلامهم أيُّهم يكفلُها، فقال الله لمحمد ﷺ: <q>﴿وما كنت لديهم إذ يلقون أقلامهم أيهم يكفل مريم وما كنت لديهم إذ يختصمون﴾</q>{13}. (٣/٥٤٣) ١٢٨٩٦- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿إذ يلقون أقلامهم﴾</q>، قال: زكريا وأصحابه، اسْتَهَمُوا بأقلامهم على مريم حين دخلت عليهم، فَسَهَمَهُم بقلمه زكريا{14}. (ز) ١٢٨٩٧- عن الضَّحّاك بن مُزاحِم -من طريق عُبَيْد- يقول في قوله: <q>﴿إذ يلقون أقلامهم أيهم يكفل مريم﴾</q>: اقْتَرَعُوا بأقلامهم أيُّهم يكفل مريم، فَقَرَعهم زكريا{15}. (ز) ١٢٨٩٨- عن عكرمة مولى ابن عباس -من طريق النَّضْر بن عَرَبِيٍّ- في قوله: <q>﴿إذ يلقون أقلامهم أيّهم يكفل مريم﴾</q>، قال: ألْقَوْا أقلامَهم في الماءِ، فذَهَبَتْ مع الجِرْيَة، وصعِد قلمُ زكريا، فكفلها زكريا{16}. (٣/٥٤٣) ١٢٨٩٩- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿إذ يلقون أقلامهم﴾</q>، قال: تَساهَمُوا على مريم أيُّهم يكفُلها، فقَرَعَهُم زكريّا{17}. (ز) ١٢٩٠٠- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿وما كنت لديهم إذ يلقون أقلامهم أيّهم يكفُل مريم وما كنت لديهم إذ يختصمون﴾</q>، قال: كانت مريمُ ابنةَ إمامهم وسيِّدهم، فتشاجر بنو إسرائيل، فاقترعوا فيها بسهامهم أيُّهم يكفُلها، فقرعهم زكريّا، فكفلها زكريا، يقول: ضمّها إليه{18}. (ز) ١٢٩٠١- عن الربيع بن أنس -من طريق أبي جعفر- قال: ألْقَوْا أقلامَهم -يقول: عِصيَّهم- تِلْقاء جِرْيَةِ الماء، فاستقبلت عصا زكريا جِرْيَةِ الماء، فقرَعهم{10}. (٣/٥٤٣) ١٢٩٠٢- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿وما كنت لديهم إذ يختصمون﴾</q>: أي: ما كنت معهم إذ يختصمون فيها، يخبره بخفيِّ ما كتموا منه من العلم عندهم؛ لتحقيق نُبُوَّتِه والحجّة عليهم لِما يأتيهم به مِمّا أخْفَوْا منه{20}. (ز) ١٢٩٠٣- عن محمد بن إسحاق -من طريق سلمة-، مثله{21}. (ز) ١٢٩٠٤- قال مقاتل بن سليمان: <q>﴿إذ يلقون أقلامهم﴾</q> في القُرْعة <q>﴿أيُّهم يكفل مريم﴾</q> يعني: يضمُّ مريم إلى نفسه، <q>﴿وما كنت لديهم﴾</q> يا محمّد <q>﴿إذ يختصمون﴾</q> في مريم، يعني: القرّاء أيُّهم يكفلها{5}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٧٠/٨٩.أخرجه ابن أبي حاتم ٢/٦٤٨، ٦٥٠.أخرجه ابن جرير ٥/٤٠٥.أخرجه ابن جرير ٥/٤٠٣.تفسير مقاتل بن سليمان ١/٢٧٦.أخرجه ابن أبي حاتم ٢/٦٤٩.أخرجه ابن أبي حاتم ٢/٦٤٩.عزاه السيوطي إلى عَبد بن حُمَيد.ذكره ابن هشام في السيرة ١/٥١٥.أخرجه ابن جرير ٥/٣٤٨، وابن أبي حاتم ٢/٦٥٠.أخرجه ابن أبي حاتم ٢/٦٤٩، وابن المنذر ١/١٩٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن عساكر في تاريخ دمشق ١١/٢١.أخرجه ابن جرير ٥/٤٠٤، وابن أبي حاتم ٢/٦٤٩.أخرجه ابن المنذر ١/١٩٨، وأخرج ابن جرير ٥/٤٠٣ نحوه من طريق ابن أبي نجيح. وعلَّقه ابن أبي حاتم ٢/٦٤٩.أخرجه ابن جرير ٥/٤٠٥. وعلَّقه ابن أبي حاتم ٢/٦٤٩.أخرجه ابن جرير ٥/٣٤٨، وابن أبي حاتم ٢/٦٤٩.أخرجه عبد الرزاق ١/١٢١، وابن جرير ٥/٤٠٤، وابن أبي حاتم ٢/٦٤٩.أخرجه ابن جرير ٥/٤٠٤، ومن طريق معمر أيضًا مختصرًا، وابن المنذر ١/١٩٩، وابن أبي حاتم ٢/٦٥٠ من طريق شيبان.أخرجه ابن جرير ٥/٣٤٨، وابن أبي حاتم ٢/٦٥٠.أخرجه ابن جرير ٥/٤٠٦.أخرجه ابن أبي حاتم ٢/٦٥٠.تفسير مقاتل بن سليمان ١/٢٧٦.
3,45," <q>﴿إِذۡ قَالَتِ ٱلۡمَلَـٰۤىِٕكَةُ یَـٰمَرۡیَمُ إِنَّ ٱللَّهَ یُبَشِّرُكِ بِكَلِمَةࣲ مِّنۡهُ ٱسۡمُهُ ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ وَجِیهࣰا فِی ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِ وَمِنَ ٱلۡمُقَرَّبِینَ ۝٤٥﴾</q> - قراءات ١٢٩٠٥- عن الأعمش، في قراءة عبد الله [بن مسعود]: (وقالَتِ المَلَآئِكَةُ يا مَرْيَمُ إنَّ اللهَ لَيُبَشِّرُكِ){1}. (ز) <q>﴿إِذۡ قَالَتِ ٱلۡمَلَـٰۤىِٕكَةُ یَـٰمَرۡیَمُ﴾</q> - تفسير ١٢٩٠٦- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿إذ قالت الملائكة يا مريم إن الله يبشرك﴾</q>، قال: شافَهَتْها الملائكةُ بذلك{2}. (٣/٥٤٧) ١٢٩٠٧- قال مقاتل بن سليمان: <q>﴿إذ قالت الملائكة يا مريم﴾</q>، وهو جبريلُ وحده ﵇{3}. (ز) ١٢٩٠٨- عن محمد بن إسحاق -من طريق عبد الله بن إدريس- قال: ثُمَّ أخبره خبرَ مريم وعيسى حين ابتدأها مِن كرامة الله بِما آتاها: <q>﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه اسمه المسيح عيسى ابن مريم﴾</q>{4}. (ز) <q>﴿إِنَّ ٱللَّهَ یُبَشِّرُكِ بِكَلِمَةࣲ مِّنۡهُ﴾</q> - تفسير ١٢٩٠٩- عن عبد الله بن عبّاس -من طريق عكرمة- في قوله: <q>﴿يبشرك بكلمة منه﴾</q>، قال: عيسى هو الكلمة مِن الله{5}١١٩٦. (٣/٥٤٧) ١١٩٦ ذكر ابنُ جرير (٥/٤٠٧) أنّ هناك مَن ذهبوا إلى أنّ الكلمة هي اسمٌ سمّاه الله لعيسى، كما سَمّى سائرَ خلقه بما شاء من الأسماء، وأدخل قولَ ابن عباس في هذا القول. وانتَقَدَ ابنُ عطية (٢/٢٢١) صنيعَ ابن جرير، فقال: «وقولُ ابن عباس يَحْتَمِل أن يُفَسَّر بما قال قتادة [من أنّ المراد بالكلمة قوله: <q>﴿كن﴾</q>] وبغير ذلك مما سنذكره الآن، وليس فيه شيءٌ مما ادَّعى الطبريُّ ﵀. وقال قومٌ من أهل العلم: سماه الله (كلمة) من حيث كان تقدَّم ذكره في توراة موسى وغيرها مِن كتب الله، وأنّه سيكون، فهذه كلمةٌ سَبَقَتْ فيه من الله، فمعنى الآية: أنتِ -يا مريمُ- مُبَشَّرَة بأنّك المخصوصةُ بولادة الإنسان الذي قد تكلَّم الله بأمره، وأخبر به في ماضي كتبه المنزلة على أنبيائه. و<q>﴿اسْمُهُ﴾</q> في هذا الموضع معناه: تسميته، وجاء الضمير مُذَكَّرًا من أجل المعنى؛ إذ (الكلمة) عبارة عن ولد». ١٢٩١٠- عن قتادة بن دِعامة -من طريق مَعْمَر- قوله: <q>﴿بكلمة منه﴾</q>، قال: قوله: كُن{6}١١٩٧. (ز) ١١٩٧ قال ابنُ جرير مُعَلِّقًا (٥/٤٠٧): «فسمّاهُ الله ﷿ كلمتَه [يعني: على هذا القول]؛ لأنّه كان عن كلمته، كما يُقال لِما قدَّر اللهُ مِن شيء: هذا قدرُ الله وقضاؤه. يعني به: هذا عن قدر الله وقضائه حدَثَ، وكما قال -جلَّ ثناؤه-: <q>﴿وكان أمر الله مفعولًا﴾</q> [النساء:٤٧]، يعني به: ما أمر اللهُ به، وهو المأمور الذي كان عن أمر الله ﷿». وبنحوه قال ابنُ عطية (٢/٢٢١). ١٢٩١١- عن محمد بن إسحاق -من طريق عبد الله بن إدريس-: <q>﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه﴾</q>، أي: بولدٍ لا أبَ له{4}١١٩٨. (ز) ١١٩٨ ذكر ابنُ جرير (٥/٤٠٧) في تفسير الكلمة ثلاثة أقوال، أحدها: أنّ المراد بها: رسالةٌ من الله، وخَبَرٌ مِن عنده. ولم ينسبه لأحد. وثانيها: أنّ الكلمة التي قالها الله هي:كن. وثالثها: أنّ الكلمة هي اسم لعيسى سمّاه الله به كما سمّى سائرَ الخلائق بما شاء من الأسماء. ورَجَّح ابنُ جرير القولَ الأول مُسْتنِدًا إلى اللغة، فقال: «ولذلك قال ﷿: <q>﴿اسمه المسيح﴾</q>. فذكَّر، ولم يقل: اسمها. فيؤنث، والكلمة مؤنثة؛ لأنّ الكلمة غير مقصود بها قصد الاسم الذي هو بمعنى فلان، وإنما هي بمعنى: البشارة، فذُكّرت كنايتُها كما تُذَكّر كناية الذُّرِّيَّة، والدابَّة، والألقاب». <q>﴿ٱسۡمُهُ ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ﴾</q> - تفسير ١٢٩١٢- عن عبد الله بن عباس -من طريق عكرمة- قال: لم يكن مِن الأنبياء مَن له اسمان إلّا عيسى، ومحمد ﵉{4}. (٣/٥٤٧) ١٢٩١٣- عن عبد الله بن عباس، قال: سُمِّي مَسيحًا لأنّه ما مَسَحَ ذا عاهَةٍ إلا بَرِئَ{9}١١٩٩. (ز) ١١٩٩ ذكر ابنُ عطيّة (٢/٢٢١) أنّ اشتقاق لفظة <q>﴿المسيح﴾</q> على هذا القول (فعيل) بمعنى: (فاعل). ١٢٩١٤- عن إبراهيم النَّخَعِيِّ -من طريق منصور- قال: <q>﴿المسيح﴾</q>: الصِّدِّيقُ{10}١٢٠٠. (٣/٥٤٧) ١٢٠٠ ذَكَرَ ابنُ جرير (٥/٤٠٩) أنّ المسيح: فعيل، صُرِف مِن (مفعول) إلى (فعيل)، وإنّه ممسوح، يعني: مسحه الله فطهَّره مِن الذُّنوب، ثُمَّ قال: «ولذلك قال إبراهيم: ...». ١٢٩١٥- عن إبراهيم النَّخَعِيِّ -من طريق منصور- مثله، أي: مُسِحَ بالبركة{11}. (ز) ١٢٩١٦- عن الحسن البصري، في قوله: <q>﴿اسمه المسيح﴾</q>: أي: مُسِحَ بالبركة{12}. (ز) ١٢٩١٧- عن أبي عمرو بن العلاء، أنّه قال: <q>﴿المسيحُ﴾</q>: الـمَلِكُ{13}. (ز) ١٢٩١٨- عن يحيى بن عبد الرحمن الثقفي -من طريق سعيد ابن أبي هلال-: أنّ عيسى كان سائِحًا، ولذلك سُمِّي المسيح؛ كان يُمسي بأرضٍ ويُصْبِح بأخرى، وأنّه لم يَتَزَوَّج حتى رُفِع{4}. (٣/٥٤٧) ١٢٩١٩- قال محمد بن السّائِب الكَلْبِيُّ: سُمِّيَ بذلك لأنّه كان يمسحُ عينَ الأعمى، فيُبْصِر{13}. (ز) ١٢٩٢٠- عن سعيد -من طريق عمرو بن أبي سلمة- قال: إنّما سُمِّي المسيح لأنّه مُسِحَ بالبَرَكَة{16}١٢٠١. (٣/٥٤٧) ١٢٠١ ذكر ابنُ عطية (٢/٢٢١) أنّ اشتقاق لفظة <q>﴿المسيح﴾</q> على هذا القول (فعيل) بمعنى: (مفعول). <q>﴿وَجِیهࣰا فِی ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِ وَمِنَ ٱلۡمُقَرَّبِینَ ۝٤٥﴾</q> - تفسير ١٢٩٢١- عن عبد الله بن عباس -من طريق جُوَيْبِر ومقاتل، عن الضحاك- قال: ثُمَّ قال: يا محمد. يُخبِر بقِصَّة عيسى: <q>﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه اسمه المسيح عيسى ابن مريم وجيهًا في الدنيا﴾</q> يعني: مَكِينًا عند الله في الدنيا، <q>﴿ومن المقرّبين﴾</q> في الآخرة{17}. (٣/٥٤٤) ١٢٩٢٢- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿ومن المقرّبين﴾</q>، يقول: ومِن المقرَّبين عند الله يوم القيامة{18}. (٣/٥٤٨) ١٢٩٢٣- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿ومن المقرّبين﴾</q>، يقول: مِن المقرَّبين عند الله يوم القيامة{19}. (ز) ١٢٩٢٤- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿وجيهًا﴾</q>، قال: وجيهًا في الدُّنيا والآخرة عند الله{20}. (ز) ١٢٩٢٥- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿إذ قالت الملائكة يا مريم إن الله يبشرك بكلمة منه اسمه المسيح عيسى ابن مريم وجيهًا في الدنيا والآخرة ومن المقربين﴾</q>: أي: هكذا كان أمرُه، لا ما يقولون فيه{21}. (ز) ١٢٩٢٦- عن محمد بن إسحاق -من طريق زياد-، مثله{22}. (ز) ١٢٩٢٧- قال مقاتل بن سليمان: <q>﴿وجيهًا﴾</q> يعني: مَكِينًا عند الله ﷿ <q>﴿في الدنيا والآخرة﴾</q> فيها تقديم، <q>﴿ومن المقرّبين﴾</q> عند الله في الآخرة{3}. (ز) ١٢٩٢٨- عن محمد بن إسحاق: قوله: <q>﴿وجيها في الدنيا والآخرة﴾</q> أي: عند الله، <q>﴿ومن المقربين﴾</q> عند الله{24}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣١١. وهي قراءة شاذة.أخرجه ابن أبي حاتم ٢/٦٥٠.تفسير مقاتل بن سليمان ١/٢٧٦.أخرجه ابن أبي حاتم ٢/٦٥١.أخرجه ابن جرير ٥/٤٠٧، وابن المنذر ١/٢٠٠، وابن أبي حاتم ٢/٦٥١.أخرجه ابن جرير ٥/٤٠٧.أخرجه ابن أبي حاتم ٢/٦٥١.أخرجه ابن أبي حاتم ٢/٦٥١.تفسير البغوي ٢/٣٨.أخرجه ابن جرير ٥/٤٠٩-٤١٠، وابن المنذر ١/٢٠٠، وابن أبي حاتم ٢/٦٥١.أخرجه ابن جرير ٥/٤٠٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٨٩-.تفسير الثعلبي ٣/٦٨.أخرجه ابن أبي حاتم ٢/٦٥١.تفسير الثعلبي ٣/٦٨.أخرجه ابن جرير ٥/٤١٠. وسعيد هنا لعلَّه سعيد بن عبد العزيز الدِّمشقي من كبار أتباع التابعين ت١٦٧ﻫ.أخرجه ابن عساكر ٤٧/٣٤٧-٣٤٨ من طريق إسحاق بن بشر. وعزاه السيوطي إلى إسحاق بن بشرأخرجه ابن جرير ٥/٤١٢، وابن المنذر ١/٢٠١. وعلَّقه ابن أبي حاتم ٢/٦٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٤١١، وابن أبي حاتم ٢/٦٥٢.أخرجه ابن جرير ٥/٤١٠.أخرجه ابن جرير ٥/٤٠٨.أخرجه ابن المنذر ١/٢٠١.تفسير مقاتل بن سليمان ١/٢٧٦.أخرج شطره الأول ابن أبي حاتم ٢/٦٥١ من طريق سلمة، وأخرج شطرَه الثاني ابنُ المنذر ١/٢٠١ من طريق زياد.
