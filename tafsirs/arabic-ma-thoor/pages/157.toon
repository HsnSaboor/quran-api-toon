quran[6]{c,v,t}:
7,52," <q>﴿وَلَقَدۡ جِئۡنَـٰهُم بِكِتَـٰبࣲ فَصَّلۡنَـٰهُ عَلَىٰ عِلۡمٍ هُدࣰى وَرَحۡمَةࣰ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٥٢﴾</q> - تفسير ٢٧٨٥٨- عن عبد الله بن عباس -من طريق علي- <q>﴿فَصَّلْناهُ﴾</q>، يقول: بَيَّنّاه{1}. (ز) ٢٧٨٥٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ورحمة﴾</q>، قال: القرآن{1}. (ز) ٢٧٨٦٠- عن أبي العالية الرِّياحِيِّ، مثل ذلك{3}. (ز) ٢٧٨٦١- قال مقاتل بن سليمان: <q>﴿ولقد جئناهم بكتاب فصلناه﴾</q> يعني: بيَّنّاه <q>﴿على علم﴾</q> وهو القرآن، <q>﴿هدى﴾</q> من الضلالة، <q>﴿ورحمة﴾</q> من العذاب <q>﴿لقوم يؤمنون﴾</q> يعني: يُصَدِّقون بالقرآن بأنّه من الله{4}٢٥٣٢. (ز) ٢٥٣٢ ذكر ابنُ عطية (٣/٥٧٦) قولَ مَن قال: المراد بالكتاب: القرآن. كما في قول مقاتل، ثم قال مُعَلِّقًا: «ويحتمل أن يكون اسم جنس في جميع الكتب المنزلة على تأويل مَن يرى الضمير في <q>﴿جِئْناهُمْ﴾</q> لِمَن تقدَّم ذكره». ٢٧٨٦٢- عن محمد بن إسحاق -من طريق سلمة- <q>﴿هدى ورحمة لقوم يؤمنون﴾</q>، أي: مغفرة لِما رَكِبوا{1}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٩٣.أخرجه ابن أبي حاتم ٥/١٤٩٣.علَّقه ابن أبي حاتم ٥/١٤٩٣.تفسير مقاتل بن سليمان ٢/٤٠.أخرجه ابن أبي حاتم ٥/١٤٩٣.
7,53," <q>﴿هَلۡ یَنظُرُونَ إِلَّا تَأۡوِیلَهُۥۚ یَوۡمَ یَأۡتِی تَأۡوِیلُهُۥ﴾</q> - تفسير ٢٧٨٦٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿يومَ يأتِي تأويلُهُ﴾</q>، قال: يومَ القيامة{1}. (٦/٤١٦) ٢٧٨٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿هل ينظرون إلا تأويله﴾</q> يعني: جزاءَه، وثوابه، <q>﴿يوم يأتي تأويلُهُ﴾</q> قال: جزاؤُه{2}. (٦/٤١٦) ٢٧٨٦٥- عن معاوية بن قُرَّة -من طريق الفُرات- <q>﴿هل ينظرون إلا تأويله﴾</q>، قال: الجزاء به في الآخرة{3}. (ز) ٢٧٨٦٦- قال قتادة بن دعامة: <q>﴿هل ينظرونَ إلا تأويله﴾</q>، يعني: الجزاء به في الآخرة{4}. (ز) ٢٧٨٦٧- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿هل ينظرونَ إلا تأويله﴾</q>، قال: عاقبته{5}. (٦/٤١٥) ٢٧٨٦٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿هل ينظرونَ إلا تأويله﴾</q> أي: ثوابه، <q>﴿يوم يأتي تأويله﴾</q> أي: ثوابه{6}. (ز) ٢٧٨٦٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿يومَ يأتي تأويلُهُ﴾</q>، قال: عواقبُه؛ مثلُ وقعة بدرٍ، والقيامة، وما وُعِد فيه من مَوْعدٍ{7}٢٥٣٣. (٦/٤١٦) ٢٥٣٣ ذكر ابنُ عطية (٣/٥٧٦) قول السدي، ثم وجَّه معنى الآية عليه قائلًا: «والمراد: هل ينتظر هؤلاء الكفارُ إلا مآل الحالِ في هذا الدين، وما دعوا إليه، وما صدُّوهم عنه، وهم يعتقدون مآله جميلًا لهم؟ فأخبر الله ﷿ أنّ مآله يوم يأتي يقع معه ندمهم، ويقولون تأسفًا على ما فاتهم من الإيمان: لقد صَدَقَت الرسلُ، وجاءوا بالحق. فالتأويل على هذا مأخوذٌ من آل يَؤُولُ». وزاد ابنُ عطية في معنى التأويل قولين آخرين، فقال: «وقال الخطابيُّ: أوَّلْتُ الشيء: رددته إلى أوله، فاللفظة مأخوذة من الأول، حكاه النقاش. وقد قيل: أوَّلْتُ، معناه: طَلَبْتُ أوَّلَ الوجوه والمعاني». ٢٧٨٧٠- عن الربيع بن أنس -من طريق أبي جعفر- في الآية، قال: لا يزالُ يقعُ من تأويله أمرٌ، حتى يَتِمَّ تأويلُه يوم القيامة، حتى يدخُل أهلُ الجنةِ الجنةَ، وأهلُ النارِ النارَ، فيَتِمَّ تأويلُه يومئذٍ، ففي ذلك أُنزِلت: <q>﴿يومَ يأْتي تأويلُهُ﴾</q> حيثُ أثاب الله أولياءَه وأعداءَه ثوابَ أعمالهم، <q>﴿يقول﴾</q> يومئذٍ <q>﴿الَّذين نسوهُ من قبلُ قدْ جاءتْ رُسُلُ ربنا بالحقِّ﴾</q> إلى آخر الآية{8}. (٦/٤١٦) ٢٧٨٧١- عن محمد بن السائب الكلبي -من طريق مَعْمَر- في قوله تعالى: <q>﴿هل ينظرون إلا تأويله يوم يأتي تأويله﴾</q>، قال: تأويله: عاقِبَته{9}. (ز) ٢٧٨٧٢- قال مقاتل بن سليمان: رجع في التقديم إلى الذين جحدوا بالقرآن، فقال: <q>﴿هل ينظرون﴾</q> يُخَوِّفهم <q>﴿إلا تأويله يوم يأتي تأويله﴾</q> يعني: العاقبة؛ ما وعَد اللهُ في القرآن من الوعد والوعيد، والخير والشر، على ألسنة الرُّسُل{10}. (ز) ٢٧٨٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله:<q>﴿يوم يأْتي تأويلُهُ﴾</q>، قال: تَحْقِيقه. وقرأ: <q>﴿هذا تأويل رُءيايَ من قبلُ﴾</q> [يوسف:١٠٠]، قال: هذا تحقيقُها. وقرأ: <q>﴿وما يعلمُ تأويلهُ إلّا اللهُ﴾</q> [آل عمران:٧]، قال: ما يعلمُ تحقيقَه إلا اللهُ{11}. (٦/٤١٦) <q>﴿یَقُولُ ٱلَّذِینَ نَسُوهُ مِن قَبۡلُ قَدۡ جَاۤءَتۡ رُسُلُ رَبِّنَا بِٱلۡحَقِّ فَهَل لَّنَا مِن شُفَعَاۤءَ فَیَشۡفَعُوا۟ لَنَاۤ أَوۡ نُرَدُّ فَنَعۡمَلَ غَیۡرَ ٱلَّذِی كُنَّا نَعۡمَلُۚ﴾</q> - تفسير ٢٧٨٧٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿يقول الذين نسوه من قبل﴾</q>، قال: أعْرَضوا عنه{12}. (٦/٤١٦) ٢٧٨٧٥- عن الحسن البصري -من طريق عبد الواحد بن زيد- في قوله: <q>﴿وأَنْذِرْهُمْ يَوْمَ الآزِفَةِ إذِ القُلُوبُ لَدى الحَناجِرِ كاظِمِينَ﴾</q> [غافر:١٨]، قال: أزِفَت –واللهِ- عقولُهم، وطارت قلوبُهم، فتردَّدَتْ في أجوافهم بالغُصص إلى حناجرهم لَمّا أُمِر بهم مَلَكٌ يسوقهم إلى النار، فيقول بعضهم لبعض: <q>﴿فَهَلْ لَنا مِن شُفَعاءَ فَيَشْفَعُوا لَنا﴾</q>. فيُنادَوْن: <q>﴿ما لِلظّالِمِينَ مِن حَمِيمٍ ولا شَفِيعٍ يُطاعُ﴾</q> [غافر:١٨]{13}. (ز) ٢٧٨٧٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿يقول الذين نسوه من قبل قد جاءت رسل ربنا بالحق﴾</q>: أما <q>﴿الذين نسوه﴾</q> فتركوه، فلمّا رأوا ما وعدهم أنبياؤُهم استيقنوا، فقالوا: <q>﴿قد جاءت رسل ربنا بالحق﴾</q>{14}. (ز) ٢٧٨٧٧- قال مقاتل بن سليمان: <q>﴿يقول الذين نسوه من قبل﴾</q> يعني: يقول في الآخرة الذين تركوا الإيمان في الدنيا بالبعث، فإذا ذكروه وعاينوا قول الرسل، قالوا: <q>﴿قد جاءت رسل ربنا بالحق﴾</q> بأنّ هذا اليوم كائن، وهو حق، <q>﴿فهل لنا من شفعاء﴾</q> من الملائكة والنبيين وغيرها؛ <q>﴿فيشفعوا لنا أو نرد﴾</q> إلى الدنيا؛ <q>﴿فنعمل﴾</q> من الخير <q>﴿غير الذي كنا نعمل﴾</q> من الشر، يعني: الشرك، والتكذيب{15}. (ز) <q>﴿قَدۡ خَسِرُوۤا۟ أَنفُسَهُمۡ﴾</q> - تفسير ٢٧٨٧٨- عن أبي رَزين [مسعود بن مالك الأسدي]-من طريق الأعمش- في قوله: <q>﴿قد د خسروا أنفسهم﴾</q>، قال: قد ضَلُّوا{16}. (ز) ٢٧٨٧٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿قد خسروا أنفسهم﴾</q>، يقول: بشَّروها بخسران{17}٢٥٣٤. (ز) ٢٥٣٤ لم يذكر ابنُ جرير (١٠/٢٤٥) غير هذا القول. ٢٧٨٨٠- قال مقاتل بن سليمان: يقول الله: <q>﴿قد خسروا أنفسهم﴾</q>، يقول: قد غَبَنُوا أنفسَهم، فساروا إلى النار{18}. (ز) <q>﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٥٣﴾</q> - تفسير ٢٧٨٨١- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿وضلَّ عنهُم ما كانُوا يفترُون﴾</q>، قال: ما كانوا يَكذِبون في الدُّنيا{19}. (٦/٤١٧) ٢٧٨٨٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ما كانُوا يفترونَ﴾</q>، أي: يُشرِكون{19}. (٦/٤١٧) ٢٧٨٨٣- قال مقاتل بن سليمان: <q>﴿وضل عنهم﴾</q> في الآخرة <q>﴿ما كانوا يفترون﴾</q> في الدنيا من التكذيب{18}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٢٤٢، وابن أبي حاتم ٥/١٤٩٤.تفسير مجاهد ص٣٣٨، وأخرجه ابن جرير ١٠/٢٤١، وابن أبي حاتم ٥/١٤٩٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤٩٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٢٦-.أخرجه عبد الرزاق ١/٢٣٠، وابن جرير ١٠/٢٤١، وابن أبي حاتم ٥/١٤٩٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٢٤١.أخرجه ابن جرير ١٠/٢٤٢، وابن أبي حاتم ٥/١٤٩٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٢٤٢، وابن أبي حاتم ٥/١٤٩٤-١٤٩٥. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ٢/٢٣٠.تفسير مقاتل بن سليمان ٢/٤٠.أخرجه ابن جرير ١٠/٢٤٢-٢٤٣، وابن أبي حاتم ٥/١٤٩٤.تفسير مجاهد ص٣٣٨، وأخرجه ابن جرير ١٠/٢٤٤، وابن أبي حاتم ٥/١٤٩٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٥٣-٤٥٤ (٢٥٠)-.أخرجه ابن جرير ١٠/٢٤٣، وابن أبي حاتم ٥/١٤٩٥.تفسير مقاتل بن سليمان ٢/٤٠-٤١.أخرجه ابن أبي حاتم ٥/١٤٩٥.أخرجه ابن جرير ١٠/٢٤٥، وابن أبي حاتم ٥/١٤٩٥.تفسير مقاتل بن سليمان ٢/٤١.أخرجه ابن أبي حاتم ٥/١٤٩٦.أخرجه ابن أبي حاتم ٥/١٤٩٦.تفسير مقاتل بن سليمان ٢/٤١.
7,54," <q>﴿إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ فِی سِتَّةِ أَیَّامࣲ﴾</q> الآية - نزول الآية ٢٧٨٨٤- عن سعد بن إسحاق بن كعب بن عُجْرَةَ، قال: نزلت هذه الآية: <q>﴿إن ربَّكُمُ الله الذي خلق السماوات والأرض﴾</q>، لُقِيَ ركبٌ عظيمٌ لا يُرَوْنَ إلا أنّهم من العرب، فقالوا لهم: مَن أنتم؟ قالوا: مِن الجنِّ، خرَجنا من المدينة، أخرَجَتْنا هذه الآيةُ{1}. (٦/٤١٧) <q>﴿إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ فِی سِتَّةِ أَیَّامࣲ﴾</q> - تفسير ٢٧٨٨٥- عن أبي هريرة، قال: أخذَ رسولُ الله ﷺ بيدي، فقال: «يا أبا هريرةَ، إنّ الله خلق السماوات والأرض وما بينهما في ستَّة أيامٍ، ثُمَّ استوى على العرش، فخلق التُّربة يوم السبت، والجبال يوم الأحد، والشجر يوم الاثنين، وكذا يوم الثلاثاء، والنور يوم الأربعاء، والدوابَّ يوم الخميس، وآدم يومَ الجُمعة في آخر ساعةٍ من النَّهار»{2}٢٥٣٥. (٦/٤٢٠) ٢٥٣٥ ذكر ابنُ كثير (٦/٣١٩ بتصرف) هذا الحديث مُخَرَّجًا في مسند الإمام أحمد، ثم قال مُعَلِّقًا: «وقد رواه مسلم بن الحجاج في صحيحه، والنسائي من غير وجه، عن حجاج -وهو ابن محمد الأعور-، عن عبد الملك ابن جريج به. وفيه استيعاب الأيام السبعة، والله تعالى قد قال في ستة أيام؛ ولهذا تكلم البخاريُّ وغيرُ واحد من الحفاظ في هذا الحديث، وجعلوه من رواية أبي هريرة، عن كعب الأحبار، ليس مرفوعًا». ٢٧٨٨٦- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿خلق السماواتِ والأرضَ﴾</q>، قال: كلُّ يومٍ مقدارُه ألفُ سنةٍ{3}. (٦/٤١٩) ٢٧٨٨٧- عن زيد بن أرقم، قال: إنّ الله ﷿ خلق السماوات والأرض في سِتَّة أيام، لكلِّ يومٍ منها اسمٌ: أبو جادٍ، هوّازٌ، حُطِّي، كَلَمُونَ، سَعْفَصُ، قَرْشاتُ{4}. (٦/٤١٩) ٢٧٨٨٨- عن كعب الأحبار -من طريق أبي صالح- قال: بدأ الله بخلق السماوات والأرض يوم الأحد والاثنين والثلاثاء والأربعاء والخميس والجُمعة، وجعلَ كُلَّ يومٍ ألفَ سنةٍ{5}. (٦/٤٢٠) ٢٧٨٨٩- قال سعيد بن جبير: قَدِر اللهُ ﷿ على خلق السماوات والأرض في لَمْحَة ولَحْظَة، وإنّما خَلَقَهُنَّ في ستة أيام تعليمًا لخلقه الرِّفق والتثبت في الأمور{6}٢٥٣٦. (ز) ٢٥٣٦ أبان قولُ سعيد بن جبير عن الحكمة من خلق السموات والأرض في ستة أيام على ما ذكر، وقد جعل ابنُ عطية (٣/٥٧٧) حكمة هذا مما انفرد الله بعلمه، وبيّن أنّ كل ما قيل في هذا إنما هو من باب التَّخَرُّص. ٢٧٨٩٠- عن مجاهد بن جبر -من طريق أبي بشر- قال: بَدْءُ الخلقِ العرشُ والماء والهواءُ، وخُلقتِ الأرضُ من الماء، وكان بَدْءُ الخلق يوم الأحد ويوم الاثنين والثلاثاء والأربعاء والخميس، وجمَع الخلق في يوم الجُمعة، وتهوَّدتِ اليهودُ يوم السبت، ويومٌ من الستَّة أيامٍ كألف سنة مما تعُدُّون{7}٢٥٣٧. (٦/٤١٩) ٢٥٣٧ لم يذكر ابنُ جرير (١٠/٢٤٥) غير قول مجاهد بن جبر. وعلّق عليه ابنُ عطية (٣/٥٧٧) قائلًا: «وهذا كلُّه والساعةُ اليسيرةُ سواءٌ في قُدْرَةِ الله تعالى». ٢٧٨٩١- عن عكرمة مولى ابن عباس -من طريق الحكم- قال: إنّ اللهَ بَدَأَ خلق السماوات والأرض وما بينهما يوم الأحد، ثم استوى على العرش يوم الجُمعة في ثلاث ساعات، فخلق في ساعةٍ منها الشُّموس كي يَرغَبَ الناسُ إلى ربهم في الدعاء والمسألة، وخلق في ساعة النَّتَن الذي يقعُ على ابن آدم إذا ماتَ؛ لكي يُقبرَ{8}. (٦/٤١٩) ٢٧٨٩٢- قال مقاتل بن سليمان: <q>﴿إن ربكم الله الذي خلق السماوات والأرض في ستة أيام ثم استوى على العرش﴾</q> قبل ذلك{9}. (ز) ٢٧٨٩٣- عن محمد بن إسحاق -من طريق سلمة- قال: ابتَدَع السمواتِ والأرضَ، ولم يكونا إلا بقدرته، ولم يَسْتَعِن على ذلك بأحدٍ مِن خلقه، ولم يُشْرِكه في شيءٍ مِن أمر سلطانه القاهر وقولِه النافذ، الذي يقول له لِما أراد أن يكون: كن. فيكون، ففرغ من خلق السماوات والأرض في ستة أيام{10}. (ز) <q>﴿ثُمَّ ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِۖ﴾</q> - تفسير ٢٧٨٩٤- عن أُمِّ سلمة أمِّ المؤمنين -من طريق الحسن، عن أُمِّه- في قوله تعالى: <q>﴿ثمُّ استوى على العرشِ﴾</q>، قالت: الكَيْفُ غيرُ معقولٍ، والاستواءُ غير مجهولٍ، والإقرار به إيمانٌ، والجحود به كفرٌ{11}. (٦/٤٢١) ٢٧٨٩٥- عن أبي العالية الرياحي-من طريق الربيع بن أنس- في قوله: <q>﴿ثم استوى﴾</q> يقول: ارتفع{12}. (ز) ٢٧٨٩٦- عن الحسن البصري= (ز) ٢٧٨٩٧- والربيع بن أنس مثله{13}. (ز) ٢٧٨٩٨- مجاهد بن جبر، في قوله: <q>﴿استوى﴾</q>، قال: عَلا على العرش{14}. (٦/٤٢١) ٢٧٨٩٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ثمَّ استوى على العرشِ﴾</q>، قال: يومَ السابعِ{8}. (٦/٤٢١) ٢٧٩٠٠- عن ابن عُيَيْنَة، قال: سُئِل ربيعةُ [بن أبي عبد الرحمن] عن قوله: <q>﴿استوى على العرشِ﴾</q>، كيف استوى؟ قال: الاستواءُ غيرُ مجهولٍ، والكَيْفُ غيرُ معقولٍ، ومِن الله الرسالةُ، وعلى الرسول البلاغُ، وعلينا التصديقُ{16}. (٦/٤٢١) ٢٧٩٠١- عن عبد الله بن صالح بن مسلم، قال: سُئِل ربيعةُ [بن أبي عبد الرحمن]. فذَكَرَه{17}. (٦/٤٢٢) ٢٧٩٠٢- قال محمد بن السائب الكلبي= (ز) ٢٧٩٠٣- ومقاتل: <q>﴿ثم استوى على العرش﴾</q>: اسْتَقَرَّ{18}. (ز) ٢٧٩٠٤- قال مقاتل بن سليمان: <q>﴿إن ربكم الله الذي خلق السماوات والأرض في ستة أيام ثم استوى على العرش﴾</q> قبل ذلك{9}. (ز) ٢٧٩٠٥- عن محمد بن شعيب بن شابور، عن أبيه: أنّ رجلًا سأل الأوزاعي في قوله تعالى: <q>﴿الرحمن على العرش استوى﴾</q>. فقال: هو على العرش كما وصَف نفسَه، وإنِّي لَأراك رجلًا ضالًّا{20}. (ز) ٢٧٩٠٦- عن جعفر بن عبد الله، قال: جاء رجلٌ إلى مالك بن أنس، فقال له: يا أبا عبد الله، <q>﴿استوى على العرش﴾</q>، كيف استوى؟ قال: فما رأيتُ مالِكًا وجِدَ من شيءٍ كمَوجِدَتِه مِن مقالتِه، وعلاه الرُّحَضاءُ -يعني: العرق-، وأطْرَقَ القومُ، قال: فَسُرِّيَ عن مالك، فقال: الكيفُ غيرُ معقولٍ، والاستواءُ منه غيرُ مجهولٍ، والإيمان به واجبٌ، والسؤالُ عنه بدعةٌ، وإنِّي أخافُ أن تكونَ ضالًّا. وأمَر به فأُخرِجَ{21}. (٦/٤٢٢) ٢٧٩٠٧- عن عبد الله بن وهبٍ، قال: كُنّا عند مالك بن أنس، فدخل رجلٌ، فقال: يا أبا عبد الله، <q>﴿الرحمنُ على العرش استوى﴾</q>، كيف استواؤُه؟ فأطرَقَ مالِكٌ، وأخَذَته الرُّحَضاءُ، ثم رفَعَ رأسه، فقال: الرحمنُ على العرش استوى كما وصَف نفسَه، ولا يقالُ له: كيف، وكيف عنه مرفوعٌ، وأنت رجلُ سَوءٍ صاحبُ بدعةٍ، أخرِجُوه. قال: فأُخرِجَ الرجلُ{22}. (٦/٤٢٢) ٢٧٩٠٨- عن أحمدَ بن أبي الحواريِّ، قال: سمعتُ سفيانَ بنَ عُيَيْنةَ، يقول: كُلَّ ما وصفَ اللهُ مِن نفسِه في كتابه فتفسيرُه: تلاوتُه، والسكوتُ عليه{23}. (٦/٤٢٣) ٢٧٩٠٩- عن إسحاقَ بن موسى، قال: سمعتُ ابنَ عُيَيْنةَ يقولُ: ما وصفَ اللهُ به نفسَه فتفسيرُه قراءتُه، ليس لأحدٍ أن يُفَسِّرَه إلا اللهُ تعالى، ورسلُه -صلواتُ الله عليهم-{24}. (٦/٤٢٣) <q>﴿ٱلۡعَرۡشِۖ﴾</q> - تفسير ٢٧٩١٠- عن عبد الله بن عباس -من طريق الضحاك بن مزاحم- قال: إنّما سُمِّي العرشُ: عرشًا؛ لارتفاعه{25}. (٧/٦١٦) ٢٧٩١١- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: ما يَقْدُرُ قدرَ العرش إلا الذي خَلَقه، وإنّ السماوات في خَلْق الرحمن مِثْلُ قُبَّةٍ في صحراء{26}. (٧/٦١٨) ٢٧٩١٢- عن مجاهد بن جبر -من طريق ليث- قال: ما أخَذَتِ السماواتُ والأرضُ مِن العرشِ إلا كما تَأْخُذُ الحَلقةُ مِن أرضِ الفَلاةِ{27}. (٧/٦١٨) ٢٧٩١٣- عن وهب بن مُنَبِّه -من طريق ابن إلياس ابن ابنة وهب بن منبه- قال: إنّ الله خلق العرش من نوره{28}٢٥٣٨. (ز) ٢٥٣٨ علَّق ابن كثير (٧/٣٣٣) على قول وهب بقوله: «وهذا غريب». <q>﴿یُغۡشِی ٱلَّیۡلَ ٱلنَّهَارَ﴾</q> - تفسير ٢٧٩١٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يُغْشي الَّليل النَّهار﴾</q>، قال: يُلْبِسُ الليلَ النهار{29}. (٦/٤٢٤) ٢٧٩١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿يُغشي الَّليل﴾</q>، قال: يُغشي الليلَ النهارَ، فيَذهبُ بضوئِه، ويطلبُه سرِيعًا حتى يُدركَه{30}. (٦/٤٢٤) <q>﴿یَطۡلُبُهُۥ حَثِیثࣰا﴾</q> - تفسير ٢٧٩١٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿حثيثًا﴾</q>، قال: سريعًا{31}. (٦/٤٢٤) ٢٧٩١٧- عن إسماعيل السُّدِّيّ -من طريق أسباط-، نحو ذلك{32}. (٦/٤٢٤) ٢٧٩١٨- قال مقاتل بن سليمان: <q>﴿يطلبه حثيثا﴾</q>، يعني: سريعًا{9}. (ز) <q>﴿وَٱلشَّمۡسَ وَٱلۡقَمَرَ وَٱلنُّجُومَ مُسَخَّرَ ٰ⁠تِۭ بِأَمۡرِهِۦۤۗ﴾</q> - تفسير ٢٧٩١٩- عن أنسٍ، عن رسول الله ﷺ، قال: «إنّ الشمسَ والقمرَ والنجومَ خُلِقْنَ مِن نور العرشِ»{34}. (٦/٤٢٤) ٢٧٩٢٠- عن حسّان بن عطية -من طريق الأوزاعي- قال: الشمس والقمر والنجوم مسخرات في فَلَكٍ من السماء والأرض{35}. (ز) ٢٧٩٢١- قال مقاتل بن سليمان: <q>﴿والشَّمْسَ والقَمَرَ والنُّجُومَ مُسَخَّراتٍ بِأَمْرِهِ﴾</q> لبني آدم{9}. (ز) <q>﴿أَلَا لَهُ ٱلۡخَلۡقُ وَٱلۡأَمۡرُۗ تَبَارَكَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٥٤﴾</q> - تفسير ٢٧٩٢٢- عن عبد العزيز الشّامي، عن أبيه -وكانت له صحبةٌ-، قال: قال رسول الله ﷺ: «مَن لَمْ يحمَدِ اللهَ على ما عمِلَ مِن عملٍ صالحٍ، وحمِدَ نفسَه؛ فقد كفَرَ وحبِطَ عملُه، ومَن زعم أنّ الله جعل للعباد من الأمر شيئًا فقد كَفر بما أنزَلَ الله على أنبيائه؛ لقوله: <q>﴿ألا لهُ الخلقُ والأمرُ تباركَ اللهُ ربُّ العالمينَ﴾</q>»{37}٢٥٣٩. (٦/٤٢٥) ٢٥٣٩ لم يذكر ابنُ جرير (١٠/٢٤٧) غير هذا القول. ٢٧٩٢٣- قال أبو هريرة -من طريق عبد الله بن موهب-: الخلقُ خلقُ الله، والأمرُ أمرُه{35}. (ز) ٢٧٩٢٤- عن عبد الله بن عباس -من طريق الضحاك بن مزاحم- قال: يوم القيامة يُدِينُهم بأعمالهم، إلّا مَن عفا عنه، فالأمرُ أمرُه، ثم قال: <q>﴿ألا له الخلق والأمر﴾</q>{35}. (ز) ٢٧٩٢٥- قال مقاتل بن سليمان: <q>﴿ألا له الخلق﴾</q> يعني: كُل شيء خلق، <q>﴿والأمر﴾</q> يعني: قضاءه في الخلق الذي في اللوح المحفوظ، فله المشيئة في الخلق والأمر{9}. (ز) ٢٧٩٢٦- عن سفيان بن عُيَيْنة -من طريق أبي زرعة الخراساني- في قوله: <q>﴿ألا لهُ الخلقُ والأمرُ﴾</q>، قال:الخلْقُ ما دون العرشِ، والأمرُ ما فوقَ ذلك{35}. (٦/٤٢٥) ٢٧٩٢٧- عن سفيان بن عُيَيْنة -من طريق بشّار بن موسى- قال: الخلقُ هو الخلقُ، والأمرُ هو الكلامُ{42}. (٦/٤٢٥) ٢٧٩٢٨- قال سفيان بن عُيَيْنة: بيَّن اللهُ الخلقَ من الأمر؛ لقوله تعالى: <q>﴿ألا له الخلق والأمر﴾</q>{43}. (ز) ٢٧٩٢٩- عن عبد الجبار بن العلاء العطّار، قال: سألتُ سفيان بن عُيَيْنة عن قوله: <q>﴿ألا لَهُ الخَلْقُ والأَمْرُ﴾</q>. فقال: فرَّق اللهُ بين الخلق والأمر، ومَن جمع بينهما فقد كَفَر{44}٢٥٤٠. (ز) ٢٥٤٠ قال ابنُ عطية (٣/٥٧٩-٥٨٠): «وأخذ المفسرون الخَلْق بمعنى: المخلوقات، أي: هي له كلها وملكه واختراعه، وأخذوا الأَمْرُ مصدرًا من أمر يأمر، وعلى هذا قال النقّاش وغيرُه: إنّ الآية ترُدُّ على القائلين بخلق القرآن؛ لأنّه فرق فيها بين المخلوقات وبين الكلام؛ إذ الأمر كلامه ﷿. ويحتمل أن تؤخذ لفظة الخَلْق على المصدر مِن خلق يخلق خلقًا، أي: له هذه الصفة؛ إذ هو الموجد للأشياء بعد العدم، ويؤخذ الأَمْرُ على أنّه واحد الأمور، إلا أنّه يدل على الجنس فيكون بمنزلة قوله: <q>﴿وإلَيْهِ يُرْجَعُ الأَمْرُ كُلُّهُ﴾</q> [هود:١٢٣]، وبمنزلة قوله: <q>﴿وإلى اللَّهِ تُرْجَعُ الأُمُورُ﴾</q> [البقرة:٢١٠]، فإذا أُخِذَت اللفظتان هكذا خرجتا عن مسألة الكلام». <q>﴿تَبَارَكَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٥٤﴾</q> - تفسير ٢٧٩٣٠- عن عبد الله بن عباس -من طريق الضحاك بن مزاحم-: <q>﴿تبارك﴾</q> تَفاعُلٌ مِن البَرَكة{35}. (ز) ٢٧٩٣١- قال الضحاك بن مزاحم: <q>﴿تبارك﴾</q>: تَعَظَّم{46}. (ز) ٢٧٩٣٢- وقال الحسن البصري: تجيء البركة مِن قِبَلِه{47}. (ز) ٢٧٩٣٣- قال مقاتل بن سليمان: <q>﴿تبارك الله رب العالمين﴾</q>، فيُخْبِرُ بعَظَمَته، وقُدْرَته{9}. (ز) <q>﴿تَبَارَكَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٥٤﴾</q> - آثار متعلقة بالآية ٢٧٩٣٤- عن كعب الأحبار -من طريق السلولي- قال: إنّ اللهَ حين خلق الخلْقَ استوى على العرش، فسبَّحَه العرشُ{49}. (٦/٤٢١) ٢٧٩٣٥- عن حيّان الأعرج، قال: كَتَبَ يزيدُ بن أبي مسلمٍ إلى جابر بن زيدٍ، يسأله عن بدء الخلق. قال: العرشُ والماءُ والقلمُ، والله أعلمُ أيّ ذلك بَدَأ قبلُ{50}. (٦/٤٢٠) ٢٧٩٣٦- قال وهب بن مُنَبِّه -من طريق عبد الصمد-: قال عُزَيْرٌ: يا ربِّ، أمَرْتَ الماءَ فجمد على وسط الهوا، فجعلت منه سبعًا، وسَمَّيْتَها: السموات، ثم أمرت الماءَ ينفتق من التراب، ثم أمرت التراب أن يَتَمَيَّز من الماء، فكان كذلك، فسَمَّيْتَ جميع ذلك: الأرضين، وجميع الماء: البحار{10}. (ز) ٢٧٩٣٧- عن سُمَيطٍ، قال: دلَّنا ربُّنا -تبارك وتعالى- على نفسِه في هذه الآية: <q>﴿إنّ ربَّكمُ الله الَّذي خلق السماواتِ والأرضَ﴾</q> الآية{52}. (٦/٤١٧) ",footnotes:1:أخرجه المستغفري في فضائل القرآن ٢/٧٥٨ (١١٤٩)، وابن أبي حاتم ٥/١٤٩٦ (٨٥٧٢)، ٦/١٩٢٤ (١٠٢٠٧) مرسلًا.أخرجه مسلم ٤/٢١٤٩ (٢٧٨٩)، وابن جرير ٢٠/٣٨٣-٣٨٤ كلاهما بنحوه. وعزاه السيوطي إلى ابن مردُويه.أخرجه ابن أبي حاتم ٥/١٤٩٦. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.عزاه السيوطي إلى سمُّويه في فوائده.أخرجه ابن أبي شيبة ١٤/١٢٦.تفسير الثعلبي ٤/٢٣٨.أخرجه سعيد بن منصور -كما في الفتح ٦/٢٩٠-، وابن أبي شيبة ١٤/١٠٦، وابن جرير ١٠/٢٤٥-٢٤٦، والبيهقي في الأسماء والصفات (٨٠٦). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن أبي حاتم ٥/١٤٩٧.تفسير مقاتل بن سليمان ٢/٤١.أخرجه ابن أبي حاتم ٥/١٤٩٦.أخرجه اللالكائي في السنة (٦٦٣). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٦/١٩٢٥.علّقه ابن أبي حاتم ٦/١٩٢٥. وقد أورد هذين الأثرين قبلُ في تفسير قوله تعالى: <q>﴿ثُمَّ اسْتَوى إلى السَّماءِ﴾</q> [البقرة: ٢٩].عزاه السيوطي إلى الفريابي.أخرجه ابن أبي حاتم ٥/١٤٩٧.أخرجه اللالكائي (٦٦٥).أخرجه البيهقي في الأسماء والصفات (٨٦٨).تفسير الثعلبي ٤/٢٣٨، وتفسير البغوي ٣/٢٣٥.تفسير مقاتل بن سليمان ٢/٤١.تفسير الثعلبي ٤/٢٣٩.أخرجه اللالكائي (٦٦٤).أخرجه البيهقي (٨٦٦).أخرجه البيهقي (٨٦٩).أخرجه البيهقي (٩٠٦).أخرجه ابن أبي حاتم ٦/١٩١٩.أخرج أبو الشيخ في العظمة (١٩٨). كما أخرج أوَّله يحيى بن سلام ٢/٥٤٠، وابن أبي حاتم ٦/١٩٢٠، والحاكم ٢/٢٨٢.أخرجه ابن أبى حاتم ٦/١٩٢٠، وأبو الشيخ (٢٢٠، ٢٥١). وعزاه السيوطي إلى سعيد بن منصور.أخرجه ابن أبي حاتم ٥/١٤٩٧، ٦/١٩٢٥.أخرجه ابن أبي حاتم ٧/٢٢١٩.أخرجه ابن جرير ١٠/٢٤٦، وابن أبي حاتم ٥/١٤٩٧-١٤٩٨. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٢٤٦، وابن أبي حاتم ٥/١٤٩٨.أخرجه ابن جرير ١٠/٢٤٦. وعلَّقه ابن أبي حاتم ٥/١٤٩٨.تفسير مقاتل بن سليمان ٢/٤١.أخرجه الطبراني في الأوسط ٦/١٥٣ (٦٠٦٢)، وأبو الشيخ الأصبهاني في العظمة ٤/١١٣٩-١١٤٠. قال الهيثمي في المجمع ٨/١٣٢ (١٣٣٦٦): «رواه الطبراني في الأوسط، وفيه معقل بن مالك، وثَّقه ابنُ حِبّان، وقال الأزدي: متروك. وفيه مَن لم أعرفه».أخرجه ابن أبي حاتم ٥/١٤٩٨.تفسير مقاتل بن سليمان ٢/٤١.أخرجه ابن جرير ١٠/٢٤٧. قال الألباني في الضعيفة ١٣/١٦٤ (٦٠٦٤): «موضوع».أخرجه ابن أبي حاتم ٥/١٤٩٨.أخرجه ابن أبي حاتم ٥/١٤٩٨.تفسير مقاتل بن سليمان ٢/٤١.أخرجه ابن أبي حاتم ٥/١٤٩٨.أخرجه ابن أبي حاتم ٥/١٤٩٨، والبيهقي في الأسماء والصفات (٥٤٨) مُطَوَّلًا.علَّقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التوحيد - باب قول الله تعالى: <q>﴿والله خلقكم وما تعملون﴾</q> ٦/٢٧٤٦.أخرجه الثعلبي في تفسيره ٤/٢٣٩، وتفسير البغوي ٣/٢٣٦.أخرجه ابن أبي حاتم ٥/١٤٩٨.تفسير الثعلبي ٤/٢٤٠.تفسير الثعلبي ٣/١٢٣.تفسير مقاتل بن سليمان ٢/٤١.أخرجه ابن أبي حاتم ٧/٢٢١٧.أخرجه البيهقي في الأسماء والصفات (٨٠٥).أخرجه ابن أبي حاتم ٥/١٤٩٦.عزاه السيوطي إلى أبي الشيخ.
7,55," <q>﴿ٱدۡعُوا۟ رَبَّكُمۡ تَضَرُّعࣰا وَخُفۡیَةًۚ﴾</q> - تفسير ٢٧٩٣٨- عن النعمان بن بشير، قال: قال رسول الله ﷺ: «الدُّعاء هو العبادة»{1}٢٥٤١. (ز) ٢٥٤١ للدعاء نوعان: دعاء العبادة، ودعاء المسألة. وقد أشار هذا الحديثُ إلى النوع الأول من أنواع الدعاء، وهو دعاء العبادة. وقد بيّن ابنُ تيمية (٣/١٦٣-١٦٥) أنّ النوعين متلازمان، فكلُّ دعاء عبادة مستلزم لدعاء المسألة، وكل دعاء متضمن مستلزم لدعاء العبادة، وذكر العديدَ من الآيات التي تبين هذا وتوضحه. وليس قوله تعالى: <q>﴿ادعوا ربكم تضرعا وخفية﴾</q> فيما يرى ابنُ تيمية مقصورًا على أحد نوعي الدعاء، بل هو شاملٌ لكليهما، وإن كان أظهرَ في دعاء المسألة، مُعَلِّلًا ذلك بقوله: «ولهذا أمر بإخفائه وإسراره». ٢٧٩٣٩- عن أبي موسى، قال: كان النبيُّ ﷺ في غَزاة، فأشرفوا على وادٍ، فجعل الناسُ يُكَبِّرون، ويُهَلِّلون، ويرفعون أصواتهم، فقال: «أيها الناس، ارْبَعُوا على أنفسكم، إنّكم لا تدعون أصمَّ ولا غائبًا، إنّكم تدعون سميعًا قريبًا، إنّه معكم»{2}٢٥٤٢. (ز) ٢٥٤٢ لم يذكر ابنُ جرير (١٠/٢٤٨) غير هذا الأثر، وقول ابن عباس، والحسن البصري من طريق المبارك بن فضالة. ٢٧٩٤٠- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿ادعُوا ربَّكم تضرُّعا وخُفية﴾</q>، قال: السِّرّ{3}. (٦/٤٢٥) ٢٧٩٤١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿ادعُوا ربَّكم تضرُّعا﴾</q> يعني: مُسْتَكِينًا، <q>﴿وخفيةً﴾</q> يعني: في خفضٍ وسكونٍ في حاجاتِكم مِن أمر الدنيا والآخرة{4}. (٦/٤٢٦) ٢٧٩٤٢- عن الحسن البصري -من طريق المبارك- قال: لقد كان المسلمون يجتهدُون في الدعاء، وما سُمِعَ لهم صوتٌ، إن كان إلّا همسًا بينَهم وبينَ ربِّهم، وذلك أنّ الله يقولُ: <q>﴿ادعُوا ربكُم تضرعًا وخُفية﴾</q>. وذلك أنّ الله ذَكَر عبدًا صالحًا، فرضِي له قولَه، فقال: <q>﴿إذْ نادى ربهُ نداءً خفيا﴾</q> [مريم:٣]{5}٢٥٤٣. (٦/٤٢٨) ٢٥٤٣ ذهب بعضُ السلف إلى أنّ التضرع علانيةً، والخفية سِرًّا، كما في قول قتادة. وقد أفاد قولُ الحسن هذا أنّ التضرع والخفية في معنى السرِّ جميعًا. وقد ذكر ابنُ عطية (٣/٥٨١ بتصرف) هذا عن الحسن، ثم قال مُعَلِّقًا عليه: «فكأنّ التضرع على قول الحسن فِعْلٌ للقلب». ثم زاد قولًا آخر عن الزجاج: أنّ قوله: <q>﴿تضرعا وخفية﴾</q> معناه: باستكانة واعتقاد ذلك في القلوب". ٢٧٩٤٣- عن قتادة بن دعامة، قال: التضرُّع علانيةٌ، والخفيةُ سِرٌّ{6}. (٦/٤٢٥) ٢٧٩٤٤- عن زيد بن أسلم -من طريق ابن أبي الرجال- في قول الله: <q>﴿ادعُوا ربكُم تضرعًا وخُفية﴾</q>، قال: عنى بذلك: القراءة{4}. (ز) ٢٧٩٤٥- قال مقاتل بن سليمان: ثم بَيَّن كيف يدعونه، فقال: <q>﴿ادعُوا ربكُم تضرعًا﴾</q> يعني: مستكينين، <q>﴿وخفية﴾</q> يعني: في خفض وسكون، كقوله: <q>﴿ولا تُخافت بها﴾</q> [الإسراء:١١٠]، يعني: تُسِرّ بها{8}. (ز) <q>﴿إِنَّهُۥ لَا یُحِبُّ ٱلۡمُعۡتَدِینَ ۝٥٥﴾</q> - تفسير ٢٧٩٤٦- عن عبد الله بن مُغَفَّل، أنّه سمِعَ ابنه يقول: اللهمَّ، إنِّي أسألُك القصر الأبيض عن يمين الجنة إذا دخَلْتُها. فقال: أيْ بُنيَّ، سلِ اللهَ الجنَّة، وتعوَّذْ به من النار، فإنِّي سمعتُ النبيَّ ﷺ يقول: «سيكونُ في هذه الأُمَّةِ قومٌ يعتدُون في الدُّعاء والطَّهُور»{9}٢٥٤٤. (٦/٤٢٧) ٢٥٤٤ ذكر ابنُ كثير (٦/٤٢٣-٤٢٤) هذا الأثر من رواية الإمام أحمد، ثم قال مُعَلِّقًا: «وهكذا رواه ابنُ ماجه، عن أبي بكر بن أبي شيبة، عن عفان به. وأخرجه أبو داود، عن موسى ابن إسماعيل، عن حماد بن سلمة، عن سعيد بن إياس الجريري، عن أبي نعامة -واسمه: قيس ابن عباية الحنفي البصري-، وهو إسناد حسن لا بأس به». ٢٧٩٤٧- عن سعد بن أبي وقاص، أنّه سمِعَ ابنًا له يدعُو، ويقول: اللَّهُمَّ، إنِّي أسألُك الجنَّة، ونعيمَها، وإستبرَقَها، ونحو هذا، وأعوذ بك من النار، وسلاسِلِها، وأغلالِها. فقال: لقد سألتَ الله خيرًا، وتعوَّذتَ به من شرٍّ كثيرٍ، وإنِّي سمعتُ رسول الله ﷺ يقول: «إنّه سيكونُ قومٌ يعتدُون في الدعاءِ». وقرأ هذه الآية: <q>﴿ادعُوا ربَّكم تضرعًا وخفية إنّه لا يحبُّ المعتدينَ﴾</q>. وإنّ بحسبك أن تقول: اللهمَّ، إنِّي أسألُك الجنَّة، وما قَرَّبَ إليها مِن قولٍ أو عملٍ، وأعوذُ بك من النار وما قرَّبَ إليها من قولٍ أو عملٍ{10}. (٦/٤٢٧) ٢٧٩٤٨- عن عبد الله بن عباس -من طريق عطاء-: <q>﴿إنّه لا يحبُّ المعتدينَ﴾</q> في الدعاء، ولا في غيره{11}. (٦/٤٢٥) ٢٧٩٤٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿إنّه لا يحبُّ المعتدينَ﴾</q>، يقول: لا تدعُوا على المؤمنِ والمؤمنةِ بالشرِّ؛ اللهمَّ، اخْزِه، والعَنْه، ونحو ذلك؛ فإن ذلك عُدوانٌ{12}. (٦/٤٢٦) ٢٧٩٥٠- عن أبي مجلز لاحق بن حميد -من طريق علقمة- في قوله: <q>﴿إنّه لا يحبُّ المعتدينَ﴾</q>، قال: لا تسألُوا منازلَ الأنبياء{13}. (٦/٤٢٦) ٢٧٩٥١- قال عطية بن سعد العوفي: هم الذين يدعون على المؤمنين فيما لا يَحِلُّ، فيقولون: اللَّهُمَّ، اخْزِهِم، اللَّهُمَّ، العنهم{14}. (ز) ٢٧٩٥٢- عن قتادة بن دعامة: <q>﴿إن ربكُمُ اللهُ الذي خلق السماوات والأرض﴾</q> إلى قوله: <q>﴿تباركَ اللهُ ربُّ العالمينَ﴾</q> قال: لَمّا أنبَأكم الله بقُدرتِه وعظمتِه وجلاله بيَّن لكم كيف تدعُونَه على تفِئةِ{15} ذلك، فقال: <q>﴿ادعوا ربكُم تضرُّعا وخُفية إنّه لا يُحبُ المعتدينَ﴾</q>. قال: تعلَّموا أن في بعض الدعاءِ اعتداءً، فاجتنبوا العدوانَ والاعتداء إن استطعتم، ولا قُوة إلا بالله. قال: وذُكِرَ لنا: أنّ مجالدَ بن مسعودٍ أخا بني سُليم سمِعَ قومًا يَعِجُّون{16} في دعائهم، فمشى إليهم، فقال: أيُّها القومُ، لقد أصبتُم فضلًا على مَن كان قبلكم، أو لقد هلَكتُم. فجعلوا يتسلَّلون رجلًا رجلًا، حتى ترَكُوا بُقْعَتَهم التي كانوا فيها. قال: وذُكِر لنا: أنّ ابن عمر أتى على قومٍ يرفعُون أيديَهم، فقال: ما يتناولُ هؤلاءِ القومُ؟! فواللهِ، لو كانوا على أطولِ جبل في الأرض ما ازدادُوا من الله قُربًا. قال قتادة: وإنّ اللهَ إنما يُتقرَّبُ إليه بطاعته، فما كان من دعائكم اللهَ فلْيَكُن في سكينةٍ، ووقارٍ، وحُسْنِ سَمتٍ، وزيٍّ{17}، وهَدْيٍ، وحُسنِ دَعَةٍ{18}. (٦/٤٢٦) ٢٧٩٥٣- عن عطاء الخراساني -من طريق ابنه عثمان- <q>﴿إنه لا يحب المعتدين﴾</q>، قال: لا يُحِبُّ الاعتداء في الدعاء، ولا في غيره{12}٢٥٤٥. (ز) ٢٥٤٥ رجّح ابنُ تيمية (٣/١٦٩) مستندًا إلى النظائر، ودلالة العقل أنّ قوله تعالى: <q>﴿إنه لا يحب المعتدين﴾</q> يشمل الدعاء وغيره، كما في قول عطاء، فقد ذكر قولَ مَن جعلها في الدعاء خاصة، ثم قال: «وبعد، فالآية أعمُّ من ذلك كُلِّه، وإن كان الاعتداء في الدعاء مرادًا بها فهو من جملة المراد، والله لا يحب المعتدين في كل شيء، دعاء كان أو غيره، كما قال: <q>﴿ولا تعتدوا إن الله لا يحب المعتدين﴾</q> [البقرة:١٩٠، المائدة:٨٧]. وعلى هذا فيكون قد أمَر بدعائه وعبادته، وأخبر أنّه لا يحب أهل العدوان، وهم الذين يدعون معه غيره، فهؤلاء أعظم المعتدين عدوانًا؛ فإنّ أعظم العدوان هو الشرك، وهو داخل ولا بُدَّ في قوله: <q>﴿إنه لا يحب المعتدين﴾</q>». وبمثله قال ابنُ القيم (١/٤٠٣-٤٠٤). ٢٧٩٥٤- عن زيد بن أسلم -من طريق ابن أبي الرجال-: كان يُرى أنّ الجهر بالدعاء الاعتداء{12}. (٦/٤٢٦) ٢٧٩٥٥- عن الربيع بن أنس، في الآية، قال: إيّاك أن تسألَ ربَّك أمرًا قد نُهيتَ عنه، أو ما لا ينبغي لك{6}. (٦/٤٢٨) ٢٧٩٥٦- قال مقاتل بن سليمان: ... فادعوه في حاجتكم، ولا تدعوه فيما لا يَحِلُّ لكم على مؤمن أو مؤمنة، تقول: اللَّهُمَّ، اخزه، والعنه، اللَّهُمَّ، أهلكه، أو افعل به كذا وكذا، فذلك عدوان؛ <q>﴿إنه﴾</q> الله <q>﴿لا يحب المعتدين﴾</q>{8}. (ز) ٢٧٩٥٧- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في الآية، قال: إنّ من الدعاء اعْتداء؛ يُكرَهُ رفعُ الصوتِ، والنداءُ، والصياحُ بالدعاء، ويُؤمرُ بالتضرُّع، والاستكانة{23}٢٥٤٦. (٦/٤٢٩) ٢٥٤٦ لم يذكر ابنُ جرير (١٠/٢٤٩) غير قول ا بن جريج، وقول أبي مجلز، وقول ابن عباس. ",footnotes:1:أخرجه أحمد ٣٠/٢٩٧-٢٩٨ (١٨٣٥٢)، ٣٠/٣٣٦ (١٨٣٨٦)، ٣٠/٣٤٠ (١٨٣٩١)، ٣٠/٣٨٠ (١٨٤٣٢)، ٣٠/٣٨٢-٣٨٣ (١٨٤٣٦، ١٨٤٣٧)، وأبو داود ٤/٦٠٣ (١٤٧٩)، والترمذي ٥/٢٢٧-٢٢٨ (٣٢٠٧)، ٥/٤٥٢ (٣٥٢٨)، ٦/٦ (٣٦٦٨)، وابن ماجه ٥/٥ (٣٨٢٨)، وابن حبان ٣/١٧٢ (٨٩٠)، والحاكم ١/٦٦٧ (١٨٠٢، ١٨٠٣، ١٨٠٤)، وعبد الرزاق في تفسيره ٣/١٤٧ (٢٦٨٥)، وابن جرير ٣/٢٢٨، ٢٠/٣٥٢، ٣٥٣، ٣٥٤، وابن أبي حاتم ٥/١٤٩٩ (٨٥٩٠)، ١٠/٣٢٦٩ (١٨٤٤٤)، والثعلبي ٨/٢٨٠. قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال النووي في الأذكار ص٦١٢ (١٩٧٢): «روينا بالأسانيد الصحيحة...». وقال ابن حجر في الفتح ١/٤٩: «أخرجه أصحاب السنن بسند جيد». وقال المناوي في التيسير ٢/١١: «أسانيد صحيحة». وقال الألباني في صحيح أبي داود ٥/٢١٩ (١٣٢٩): «إسناده صحيح».أخرجه البخاري ٤/٥٧ (٢٩٩٢)، ٥/١٣٣ (٤٢٠٥)، ٨/٨٢ (٦٣٨٤)، ٨/٨٧ (٦٤٠٩)، ٨/١٢٥ (٦٦١٠)، ٩/١١٧-١١٨ (٧٣٨٦)، ومسلم ٤/٢٠٧٦ (٢٧٠٤)، وابن جرير ١٠/٢٤٨. وأورده الثعلبي ٤/٢٤٠.أخرجه ابن جرير ١٠/٢٤٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤٩٩.أخرجه ابن المبارك (١٤٠)، وابن جرير ١٠/٢٤٧-٢٤٨. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤٩٩.تفسير مقاتل بن سليمان ٢/٤١.أخرجه أحمد ٢٧/٣٥٦ (١٦٨٠١)، ٣٤/١٧٢ (٢٠٥٥٤)، وأبو داود ١/٧١ (٩٦)، وابن ماجه ٥/٣٢ (٣٨٦٤)، وابن حبان ١٥/١٦٦ (٦٧٦٣)، ١٥/١٦٦-١٦٧ (٦٧٦٤)، والحاكم ١/٢٦٧ (٥٧٩)، ١/٧٢٤ (١٩٧٩). قال الحاكم في الموضع الثاني: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في الموضع الأول: «فيه إرسال». وقال ابن كثير في تفسيره ٣/٤٢٩: «إسناد حسن، لا بأس به». وقال الألباني في صحيح أبي داود ١/١٦٣ (٨٦): «إسناده صحيح».أخرجه أحمد ٣/٧٩-٨٠ (١٤٨٣)، ٣/١٤٦-١٤٧ (١٥٨٤)، وأبو داود ٢/٦٠٤ (١٤٨٠)، وابن أبي حاتم ٥/١٥٠٠ (٨٥٩٥). قال الألباني في صحيح أبي داود ٥/٢٢٠ (١٣٣٠): «حديث حسن».أخرجه ابن جرير ١٠/٢٤٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٥٠٠.أخرجه ابن جرير ١٠/٢٤٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٤/٢٤٠، وتفسير البغوي ٣/٢٣٧.على تفئة ذلك: أي على إثر ذلك. النهاية (تفأ).العَجُّ: رفع الصوت. النهاية (عجج).الزِّيّ: الهيئة والمنظر. لسان العرب (زوي).عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٥٠٠.أخرجه ابن أبي حاتم ٥/١٥٠٠.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٤١.أخرجه ابن جرير ١٠/٢٤٩. وعزاه السيوطي إلى أبي الشيخ.
7,56," <q>﴿وَلَا تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ بَعۡدَ إِصۡلَـٰحِهَا﴾</q> - تفسير ٢٧٩٥٨- قال الضحاك بن مزاحم= (ز) ٢٧٩٥٩- والحسن البصري= (ز) ٢٧٩٦٠- وإسماعيل السُّدِّيّ= (ز) ٢٧٩٦١- ومحمد بن السائب الكلبي:<q>﴿ولا تفسدوا في الأرض بعد إصلاحها﴾</q>، أي: لا تُفْسِدوا فيها بالمعاصي، والدعاء إلى غير طاعة الله، بعد إصلاح الله إيّاها ببَعْثِ الرسل، وبيان الشريعة، والدعاء إلى طاعة الله{1}٢٥٤٧. (ز) ٢٥٤٧ علّق ابنُ عطية (٣/٥٨٢) على قول الضحاك، والحسن، والسدي، والكلبي، فقال: «وقال بعضُ الناس: المراد: ولا تشركوا في الأرض بعد أن أصلحها الله ببعثة الرسل، وتقرير الشرائع، ووضوح ملة محمد ﷺ. وقائل هذه المقالة قصد إلى أكبر فساد بعد أعظم صلاحٍ، فخصَّه بالذِّكْر». وذكر ابنُ عطية عن الضحاك قولًا آخر؛ أنّ ذلك معناه: «لا تغوروا الماء المعين، ولا تقطعوا الشجر المثمر ضرارًا». وقد رجّح ابنُ عطية أنّ اللفظَ عامٌّ يتضمَّنُ كُلَّ إفساد بعد إصلاح قلَّ أو كثر، وبيَّن أنّ تخصيص شيء دون شيء في هذا تَحَكُّمٌ، إلا أن يُقال على سبيل المثال. ٢٧٩٦٢- قال عطية بن سعد العوفي: لا تعصوا في الأرض؛ فيُمْسِك اللهُ المطرَ، ويُهْلِكُ الحرثَ بمعاصيكم{2}. (ز) ٢٧٩٦٣- عن أبي صالح باذام -من طريق السدي- في قوله: <q>﴿ولا تُفسدوا في الأرض بعدَ إصلاحها﴾</q>، قال: بعدَ ما أصلَحَتْها الأنبياءُ وأصحابُهم{3}. (٦/٤٢٩) ٢٧٩٦٤- عن أبي سنان [سعيد بن سنان البُرْجُمِيّ]، في قوله: <q>﴿ولا تُفسدوا في الأرضِ بعدَ إصلاحها﴾</q>، قال: قد أحلَلتُ حلالي، وحرَّمتُ حرامي، وحدَدتُ حدُودي، فلا تُفْسِدُوها{4}. (٦/٤٣٠) ٢٧٩٦٥- قال مقاتل بن سليمان: <q>﴿ولا تُفسدوا في الأرضِ بعدَ إصلاحها﴾</q>، وذلك أنّ الله إذا بعث نبيًّا إلى الناس فأطاعوه صلحت الأرض، وصلح أهلها، وأنّ المعاصي فساد المعيشة، وهلاك أهلها. يقول: لا تعملوا في الأرض بالمعاصي بعد الطاعة{5}. (ز) ٢٧٩٦٦- عن أبي بكر بن عياش -من طريق سُنَيد- أنّه سُئل عن قوله: <q>﴿ولا تُفسدُوا في الأرض بعد إصلاحها﴾</q>. فقال: إنّ الله بعث محمدًا ﷺ إلى أهل الأرض وهم في فسادٍ، فأصلَحَهم الله بمحمدٍ ﷺ، فمَن دعا إلى خلافِ ما جاءَ به محمدٌ ﷺ فهو من المفسدين في الأرض{6}. (٦/٤٢٩) <q>﴿وَٱدۡعُوهُ خَوۡفࣰا وَطَمَعًاۚ﴾</q> - تفسير ٢٧٩٦٧- عن عبد الله بن عباس، <q>﴿وادعوُهُ خوفًا وطمعًا﴾</q>، قال: خوفًا منه، وطمعًا لِما عنده{4}. (٦/٤٣٠) ٢٧٩٦٨- قال عطاء: <q>﴿خوفًا﴾</q> مِن النيران، <q>﴿وطمعًا﴾</q> في الجنان{8}. (ز) ٢٧٩٦٩- قال الربيع بن أنس: <q>﴿خوفا وطمعا﴾</q> كقوله: <q>﴿رغبا ورهبا﴾</q> [الأنبياء:٩٠]{8}. (ز) ٢٧٩٧٠- قال محمد بن السائب الكلبي: <q>﴿وادعوه خوفا وطمعا﴾</q>: خوفًا منه ومن عذابه، وطمعًا فيما عنده من مغفرته وثوابه{10}. (ز) ٢٧٩٧١- قال مقاتل بن سليمان: <q>﴿وادعوه خوفا﴾</q> من عذابه، <q>﴿وطمعا﴾</q> في رحمته، فمَن فعل ذلك وهو مُحْسِن، فذلك قوله: <q>﴿إن رحمت الله قريب من المحسنين﴾</q>{5}. (ز) ٢٧٩٧٢- قال عبد الملك ابن جُرَيْج: خوف العدل، وطمع الفضل{8}. (ز) <q>﴿إِنَّ رَحۡمَتَ ٱللَّهِ قَرِیبࣱ مِّنَ ٱلۡمُحۡسِنِینَ ۝٥٦﴾</q> - تفسير ٢٧٩٧٣- عن عبد الله بن عباس: <q>﴿إنّ رحمت الله قريبٌ من المحسنينَ﴾</q>، يعني: من المؤمنين، ومَن لم يؤمن بالله فهو من المفسدين{4}. (٦/٤٣٠) ٢٧٩٧٤- قال سعيد بن جبير: الرحمة هاهنا: الثواب{14}. (ز) ٢٧٩٧٥- عن مطر الورّاق -من طريق جعفر- قال: تَنَجَّزُوا موعودَ الله بطاعة الله؛ فإنّه قضى أنّ رحمتَه قريبٌ من المحسنين{6}. (٦/٤٣٠) ٢٧٩٧٦- قال أبو عمرو بن العلاء: القريبُ في اللغة يكون بمعنى القُرْب، وبمعنى المسافة، تقول العرب: هذه امرأة قريبة منك إذا كانت بمعنى القرابة، وقريب منك إذا كانت بمعنى المسافة{16}. (ز) ٢٧٩٧٧- قال مقاتل بن سليمان: <q>﴿إن رحمت الله قريب من المحسنين﴾</q>، يعني بالرحمة: المَطَر. يقول: الرحمة لهم{5}. (ز) ٢٧٩٧٨- قال الكسائي: <q>﴿إن رحمت الله قريب﴾</q>: مكانها قريب، كقوله: <q>﴿وما يُدْرِيكَ لَعَلَّ السّاعَةَ قَرِيبٌ﴾</q> [الشورى: ١٧]، أي: إتيانها قريب{8}٢٥٤٨. (ز) ٢٥٤٨ رجّح ابنُ القيم (١/٤٠٨-٤٠٩) مستندًا إلى اللغة في سبب الإخبار عن الرحمة -وهي مؤنثة- بقوله: <q>﴿قريب﴾</q> -وهو مذكر-: أنّ الأصل في الآية: إنّ الله قريب من المحسنين، وإنّ رحمة الله قريبة من المحسنين. فاستغنى بذكر أحدهما عن الآخر لظهور المعنى؛ فإنّ قربَ اللهِ من المحسنين مُسْتَلْزِمٌ لقرب رحمته منهم. وذكر ابنُ عطية (٣/٥٨٣-٥٨٤) فيها أقوالًا، فقال: «واختلف الناسُ في وجه حذف التاء مِن <q>﴿قريب﴾</q> في صفة الرحمة على أقوال؛ منها: أنه على جهة النسَب، أي: ذات قرب. ومنها: أنّه لما كان تأنيثها غير حقيقي جرت مجرى: كفٍّ خَضيب، ولحيةٍ دَهين. ومنها: أنها بمعنى مُذكَّر، فذُكِّر الوصف لذلك. وقال أبو عبيدة: قريب في الآية ليس بصفةٍ للرحمة، وإنما هو ظرفٌ لها وموضع، فيجيء هكذا في المؤنث والاثنين والجميع وكذلك بعيد، فإذا جعلوها صفة بمعنى: مقربة قالوا: قريبة وقريبتان وقريبات. وذكر الطبريُّ أن قوله: <q>﴿قريب﴾</q> إنما يُراد به مقاربة الأرواح للأجساد، أي: عند ذلك تنالهم الرحمة». ",footnotes:1:تفسير البغوي ٣/٢٣٨.تفسير الثعلبي ٤/٢٤٠، وتفسير البغوي ٣/٢٣٨.أخرجه ابن أبي حاتم ٥/١٥٠١.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٤٢.أخرجه ابن أبي حاتم ٥/١٥٠١. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٤/٢٤١.تفسير الثعلبي ٤/٢٤١.تفسير الثعلبي ٤/٢٤٠.تفسير مقاتل بن سليمان ٢/٤٢.تفسير الثعلبي ٤/٢٤١.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٤/٢٤١، وتفسير البغوي ٣/٢٣٨.أخرجه ابن أبي حاتم ٥/١٥٠١. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٤/٢٤٢، وتفسير البغوي ٣/٢٣٨.تفسير مقاتل بن سليمان ٢/٤٢.تفسير الثعلبي ٤/٢٤١.
7,57," <q>﴿وَهُوَ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ بُشۡرَۢا بَیۡنَ یَدَیۡ رَحۡمَتِهِۦۖ حَتَّىٰۤ إِذَاۤ أَقَلَّتۡ سَحَابࣰا ثِقَالࣰا سُقۡنَـٰهُ لِبَلَدࣲ مَّیِّتࣲ فَأَنزَلۡنَا بِهِ ٱلۡمَاۤءَ فَأَخۡرَجۡنَا بِهِۦ مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِۚ كَذَ ٰ⁠لِكَ نُخۡرِجُ ٱلۡمَوۡتَىٰ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٥٧﴾</q> - قراءات ٢٧٩٧٩- عن عاصمٍ أنّه قرأ: <q>﴿وهُوَ الَّذِي يُرْسِلُ الرِّياحَ﴾</q> على الجِماع{1}٢٥٤٩، <q>﴿بُشْرًا﴾</q> خفيفةً، بالباءِ{2}٢٥٥٠. (٦/٤٣٠) ٢٥٤٩ قال ابنُ عطية (٣/٥٨٥) مُعَلِّقًا: «ومن جمع الريح في هذه الآية فهو أسعد، وذلك أن الرياح حيث وقعت في القرآن فهي مقترنة بالرحمة، كقوله: <q>﴿ومن آياته أن يرسل الرياح مبشرات﴾</q> [الروم:٤٥]، وقوله: <q>﴿وأرسلنا الرياح لواقح﴾</q> [الحجر:٢٢] وغيرهما، وأكثر ذكر الريح مفردة إنما هو بقرينة عذاب، كقوله: <q>﴿وفي عاد إذ أرسلنا عليهم الريح العقيم﴾</q> [الذاريات:٤١]، وقوله: <q>﴿وأما عاد فأهلكوا بريح صرصر عاتية﴾</q> [الحاقة:٦] وغيرهما. وفي الحديث: أنّ رسول الله ﷺ كان إذا هبَّت الريح يقول: «اللَّهُمَّ، اجعلها رياحًا، ولا تجعلها ريحًا»». ٢٥٥٠ ذكر ابنُ جرير (١٠/٢٥٣) اختلاف القرّاء في قراءة قوله: <q>﴿بشرا﴾</q>، ثم قال: «والصواب من القول في ذلك أن يُقال: إنّ قراءة من قرأ ذلك ‹نَشْرًا› و‹نُشُرًا› بفتح النون وسكون الشين، وبضم النون والشين، قراءتان مشهورتان في قراءة الأمصار، وأما قراءة الباء فلا أُحِبُّ القراءة بها، وإن كان لها معنًى صحيح ووجه مفهوم في المعنى والإعراب كما ذكرنا من العلة». ٢٧٩٨٠- عن عبد الله بن اليمانيِّ أنّه كان يقرؤها: (بُشْرى) مِن قبلِ مُبَشِّرات{3}. (٦/٤٣١) <q>﴿وَهُوَ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ بُشۡرَۢا بَیۡنَ یَدَیۡ رَحۡمَتِهِۦۖ حَتَّىٰۤ إِذَاۤ أَقَلَّتۡ سَحَابࣰا ثِقَالࣰا سُقۡنَـٰهُ لِبَلَدࣲ مَّیِّتࣲ فَأَنزَلۡنَا بِهِ ٱلۡمَاۤءَ فَأَخۡرَجۡنَا بِهِۦ مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِۚ﴾</q> - تفسير ٢٧٩٨١- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿بُشرا بين يدي رحمتِه﴾</q>، قال: يَستبشِرُ بها الناسُ{4}. (٦/٤٣١) ٢٧٩٨٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في الآية، قال: إنّ الله يُرسِلُ الريحَ، فتأتي بالسَّحاب من بين الخافقين؛ طرَفِ السماء والأرض، من حيثُ يلتقيانِ، فيُخرجُه مِن ثَمَّ، ثُم ينشُرُه، فيبسُطُه في السماء كيف يشاءُ، ثم يفتحُ أبواب السماء، فيَسيلُ الماءُ على السَّحاب، ثم يُمطِرُ السَّحابُ بعدَ ذلك. وأمّا <q>﴿رحمته﴾</q> فهو المطرُ{5}٢٥٥١. (٦/٤٣٠) ٢٥٥١ لم يذكر ابنُ جرير غير هذا القول (١٠/٢٥٤). وعلّق عليه ابنُ عطية (٣/٥٨٨) قائلًا: «وهذا التفصيل لم يثبت عن النبي ﷺ». ٢٧٩٨٣- قال مقاتل بن سليمان: <q>﴿وهو الذي يرسل الرياح بشرا بين يدي رحمته﴾</q> يقول: الرياح نشرًا للسحاب، كقوله: <q>﴿يرسل الرياح فتثير سحابا﴾</q> [الروم:٤٨]، يسير السحاب قدّام الرياح، <q>﴿حتى إذا أقلت﴾</q> يعني: إذا حملت الريحُ <q>﴿سحابا ثقالا﴾</q> من الماء <q>﴿سقناه لبلد ميت﴾</q> ليس فيه نبات، <q>﴿فأنزلنا به الماء فأخرجنا به﴾</q> بالماء من الأرض <q>﴿من كل الثمرات﴾</q>{6}. (ز) <q>﴿كَذَ ٰ⁠لِكَ نُخۡرِجُ ٱلۡمَوۡتَىٰ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٥٧﴾</q> - تفسير ٢٧٩٨٤- قال أبو هريرة= (ز) ٢٧٩٨٥- وعبد الله بن عباس: إذا مات الناسُ كلُّهم في النفخة الأولى أُمْطِر عليهم أربعين عامًا، يُسْقى الرجالُ من ماء تحت العرش يُدْعى: ماء الحيوان، فينبتون في قبورهم بذلك المطر كما ينبتون في بطون أمهاتهم، وكما ينبت الزرعُ من الماء، حتى إذا استكملت أجسادهم نُفِخ فيهم الروح، ثم يُلْقى عليهم نومة، فينامون في قبورهم، فإذا نُفِخ في الصور الثانية عاشوا وهم يجدون طعم النوم في رؤوسهم وأعينهم، كما يجد النائمُ إذا استيقظَ من نومه، فعند ذلك يقولون: <q>﴿يا ويلنا من بعثنا من مرقدنا﴾</q>، فيناديهم المنادي: <q>﴿هذا ما وعد الرحمن وصدق المرسلون﴾</q> [يس:٥٢]{7}٢٥٥٢. (ز) ٢٥٥٢ قال ابنُ عطية (٣/٥٨٨): «وقوله -تبارك وتعالى-: <q>﴿كذلك نخرج الموتى﴾</q> يحتمل مقصدين: أحدهما: أن يُراد: كهذه القدرة العظيمة في إنزال الماء وإخراج الثمرات به من الأرض المجدبة هي القدرة على إحياء الموتى من الأجداث، وهذه مثال لها، ويحتمل أن يراد: أنّ هكذا يُصْنَع بالأموات من نزول المطر عليهم حتى يحيوا به، فيكون الكلام خبرًا لا مَثَلًا، وهذا التأويل إنما يستند إلى الحديث الذي ذكره الطبري عن أبي هريرة أنّ الناس إذا ماتوا ...». وذكر هذا الأثر. ٢٧٩٨٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كذلك نخرج الموتى﴾</q>، قال: إذا أراد اللهُ أن يُخْرِج الموتى أمْطَر السماءَ حتى تشقَّقَ الأرضُ، ثم يُرسل الأرواح، فيهوِي كلُّ رُوحٍ إلى جسده، فكذلك يُحيي اللهُ الموتى بالمطر كإحيائِه الأرضَ{8}. (٦/٤٣١) ٢٧٩٨٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿كذلك نُخرجُ الموتى﴾</q>، قال: وكذلك تُخرجُون، وكذلك النشورُ، كما يخرُجُ الزرعُ بالماءِ{9}. (٦/٤٣١) ٢٧٩٨٨- قال مقاتل بن سليمان: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿نخرج﴾</q> يُخْرِج اللهُ <q>﴿الموتى﴾</q> من الأرض بالماء، كما أخرج النبات من الأرض بالماء؛ <q>﴿لعلكم﴾</q> يعني: لكي <q>﴿تذكرون﴾</q>، فتعتبروا في البعث أنّه كائن. نظيرها في الروم، والملائكة{10}. (ز) <q>﴿كَذَ ٰ⁠لِكَ نُخۡرِجُ ٱلۡمَوۡتَىٰ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٥٧﴾</q> - آثار متعلقة بالآية ٢٧٩٨٩- عن خالد بن يزيد [بن معاوية] -من طريق سيار- أنه كان عند عبد الملك بن مروان، فذكروا الماء، فقال خالد بن يزيد: منه مِن السماء، ومنه مِمّا يسقيه الغيم من البحر فيعذبه الرعد والبرق، وأمّا ما كان من البحر فلا يكون له نبات، وأمّا النَّبات فمِمّا كان من السماء{11}. (ز) ٢٧٩٩٠- قال أبو بكر بن عياش: لا تَقْطُر من السماء قطرةٌ حتى يُعْمِل فيها أربعٌ: رياح الصَّبا تُهَيِّجُهُ، والشمال تَجمعه، والجنوب تُدِرُّهُ، والدَّبُور تُفَرِّقُهُ{12}. (ز) ",footnotes:1:قرأ نافع، وأبو جعفر، وأبو عمرو، ويعقوب، وابن عامر، وعاصم بالجمع، وقرأ بقية العشرة: ‹الرِّيحَ› بالإفراد. النشر ٢/٢٢٣، والإتحاف ص١٩٦.علَّقه ابن جرير ١٠/٢٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٥/١٥٠٢. وهي قراءة شاذة، تروى أيضًا عن محمد بن السَّميفع، وابن قطيب. انظر: المحتسب ١/١٥٥.أخرجه ابن أبي حاتم ٥/١٥٠٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٢٥٤، وابن أبي حاتم ٥/١٥٠١. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٤٢.تفسير الثعلبي ٤/٢٤٣. وعلَّق ابنُ جرير ١٠/٢٥٥-٢٥٦ نحوه.تفسير مجاهد ص٣٣٨ مختصرًا، وأخرجه ابن جرير ١٠/٢٥٦، وابن أبي حاتم ٥/١٥٠٣ مختصرًا. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، أبي الشيخ.أخرجه ابن جرير ١٠/٢٥٥، وابن أبي حاتم ٥/١٥٠٣.تفسير مقاتل بن سليمان ٢/٤٢. يشير إلى قوله تعالى: <q>﴿ويُنَزِّلُ مِنَ السَّماءِ ماءً فَيُحْيِي بِهِ الأَرْضَ بَعْدَ مَوْتِها إنَّ فِي ذَلِكَ لَآياتٍ لِقَوْمٍ يَعْقِلُونَ (٢٤)﴾</q>، وقوله تعالى: <q>﴿واللَّهُ الَّذِي أرْسَلَ الرِّياحَ فَتُثِيرُ سَحابًا فَسُقْناهُ إلى بَلَدٍ مَيِّتٍ فَأَحْيَيْنا بِهِ الأَرْضَ بَعْدَ مَوْتِها كَذَلِكَ النُّشُورُ﴾</q> [فاطر:٩].أخرجه ابن أبي حاتم ٥/١٥٠٢.تفسير الثعلبي ٤/٢٤٢-٢٤٣.
