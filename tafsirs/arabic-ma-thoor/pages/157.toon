quran[6]{c,v,t}:
  7,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ جِئۡنَـٰهُم بِكِتَـٰبࣲ فَصَّلۡنَـٰهُ عَلَىٰ عِلۡمٍ هُدࣰى وَرَحۡمَةࣰ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فَصَّلْناهُ﴾</span>، يقول: بَيَّنّاه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ورحمة﴾</span>، قال: القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span>، مثل ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد جئناهم بكتاب فصلناه﴾</span> يعني: بيَّنّاه <span class="qpc-hafs">﴿على علم﴾</span> وهو القرآن، <span class="qpc-hafs">﴿هدى﴾</span> من الضلالة، <span class="qpc-hafs">﴿ورحمة﴾</span> من العذاب <span class="qpc-hafs">﴿لقوم يؤمنون﴾</span> يعني: يُصَدِّقون بالقرآن بأنّه من الله{4}<span class=comment-ref>٢٥٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٢</span> ذكر <u>ابنُ عطية</u> (٣/٥٧٦) قولَ مَن قال: المراد بالكتاب: القرآن. كما في قول مقاتل، ثم قال <span class="comment-type-4">مُعَلِّقًا</span>: «ويحتمل أن يكون اسم جنس في جميع الكتب المنزلة على تأويل مَن يرى الضمير في <span class="qpc-hafs">﴿جِئْناهُمْ﴾</span> لِمَن تقدَّم ذكره».</div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿هدى ورحمة لقوم يؤمنون﴾</span>، أي: مغفرة لِما رَكِبوا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٩٣.|2:أخرجه ابن أبي حاتم ٥/١٤٩٣.|3:علَّقه ابن أبي حاتم ٥/١٤٩٣.|4:تفسير مقاتل بن سليمان ٢/٤٠.|5:أخرجه ابن أبي حاتم ٥/١٤٩٣.
  7,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ یَنظُرُونَ إِلَّا تَأۡوِیلَهُۥۚ یَوۡمَ یَأۡتِی تَأۡوِیلُهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿يومَ يأتِي تأويلُهُ﴾</span>، قال: يومَ القيامة{1}. (٦/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿هل ينظرون إلا تأويله﴾</span> يعني: جزاءَه، وثوابه، <span class="qpc-hafs">﴿يوم يأتي تأويلُهُ﴾</span> قال: جزاؤُه{2}. (٦/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٥<span class="dash">-</span></span> عن <span class="name-2">معاوية بن قُرَّة</span> -من طريق الفُرات- <span class="qpc-hafs">﴿هل ينظرون إلا تأويله﴾</span>، قال: الجزاء به في الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿هل ينظرونَ إلا تأويله﴾</span>، يعني: الجزاء به في الآخرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿هل ينظرونَ إلا تأويله﴾</span>، قال: عاقبته{5}. (٦/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿هل ينظرونَ إلا تأويله﴾</span> أي: ثوابه، <span class="qpc-hafs">﴿يوم يأتي تأويله﴾</span> أي: ثوابه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٦٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿يومَ يأتي تأويلُهُ﴾</span>، قال: عواقبُه؛ مثلُ وقعة بدرٍ، والقيامة، وما وُعِد فيه من مَوْعدٍ{7}<span class=comment-ref>٢٥٣٣</span>. (٦/٤١٦)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٣</span> ذكر <u>ابنُ عطية</u> (٣/٥٧٦) قول السدي، ثم <span class="comment-type-1">وجَّه</span> معنى الآية عليه قائلًا: «والمراد: هل ينتظر هؤلاء الكفارُ إلا مآل الحالِ في هذا الدين، وما دعوا إليه، وما صدُّوهم عنه، وهم يعتقدون مآله جميلًا لهم؟ فأخبر الله ﷿ أنّ مآله يوم يأتي يقع معه ندمهم، ويقولون تأسفًا على ما فاتهم من الإيمان: لقد صَدَقَت الرسلُ، وجاءوا بالحق. فالتأويل على هذا مأخوذٌ من آل يَؤُولُ».</p><p>وزاد <u>ابنُ عطية</u> في معنى التأويل <b>قولين آخرين</b>، فقال: «وقال الخطابيُّ: أوَّلْتُ الشيء: رددته إلى أوله، فاللفظة مأخوذة من الأول، حكاه النقاش. وقد قيل: أوَّلْتُ، معناه: طَلَبْتُ أوَّلَ الوجوه والمعاني».</div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في الآية، قال: لا يزالُ يقعُ من تأويله أمرٌ، حتى يَتِمَّ تأويلُه يوم القيامة، حتى يدخُل أهلُ الجنةِ الجنةَ، وأهلُ النارِ النارَ، فيَتِمَّ تأويلُه يومئذٍ، ففي ذلك أُنزِلت: <span class="qpc-hafs">﴿يومَ يأْتي تأويلُهُ﴾</span> حيثُ أثاب الله أولياءَه وأعداءَه ثوابَ أعمالهم، <span class="qpc-hafs">﴿يقول﴾</span> يومئذٍ <span class="qpc-hafs">﴿الَّذين نسوهُ من قبلُ قدْ جاءتْ رُسُلُ ربنا بالحقِّ﴾</span> إلى آخر الآية{8}. (٦/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿هل ينظرون إلا تأويله يوم يأتي تأويله﴾</span>، قال: تأويله: عاقِبَته{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: رجع في التقديم إلى الذين جحدوا بالقرآن، فقال: <span class="qpc-hafs">﴿هل ينظرون﴾</span> يُخَوِّفهم <span class="qpc-hafs">﴿إلا تأويله يوم يأتي تأويله﴾</span> يعني: العاقبة؛ ما وعَد اللهُ في القرآن من الوعد والوعيد، والخير والشر، على ألسنة الرُّسُل{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله:<span class="qpc-hafs">﴿يوم يأْتي تأويلُهُ﴾</span>، قال: تَحْقِيقه. وقرأ: <span class="qpc-hafs">﴿هذا تأويل رُءيايَ من قبلُ﴾</span> [يوسف:١٠٠]، قال: هذا تحقيقُها. وقرأ: <span class="qpc-hafs">﴿وما يعلمُ تأويلهُ إلّا اللهُ﴾</span> [آل عمران:٧]، قال: ما يعلمُ تحقيقَه إلا اللهُ{11}. (٦/٤١٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَقُولُ ٱلَّذِینَ نَسُوهُ مِن قَبۡلُ قَدۡ جَاۤءَتۡ رُسُلُ رَبِّنَا بِٱلۡحَقِّ فَهَل لَّنَا مِن شُفَعَاۤءَ فَیَشۡفَعُوا۟ لَنَاۤ أَوۡ نُرَدُّ فَنَعۡمَلَ غَیۡرَ ٱلَّذِی كُنَّا نَعۡمَلُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿يقول الذين نسوه من قبل﴾</span>، قال: أعْرَضوا عنه{12}. (٦/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبد الواحد بن زيد- في قوله: <span class="qpc-hafs">﴿وأَنْذِرْهُمْ يَوْمَ الآزِفَةِ إذِ القُلُوبُ لَدى الحَناجِرِ كاظِمِينَ﴾</span> [غافر:١٨]، قال: أزِفَت –واللهِ- عقولُهم، وطارت قلوبُهم، فتردَّدَتْ في أجوافهم بالغُصص إلى حناجرهم لَمّا أُمِر بهم مَلَكٌ يسوقهم إلى النار، فيقول بعضهم لبعض: <span class="qpc-hafs">﴿فَهَلْ لَنا مِن شُفَعاءَ فَيَشْفَعُوا لَنا﴾</span>. فيُنادَوْن: <span class="qpc-hafs">﴿ما لِلظّالِمِينَ مِن حَمِيمٍ ولا شَفِيعٍ يُطاعُ﴾</span> [غافر:١٨]{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿يقول الذين نسوه من قبل قد جاءت رسل ربنا بالحق﴾</span>: أما <span class="qpc-hafs">﴿الذين نسوه﴾</span> فتركوه، فلمّا رأوا ما وعدهم أنبياؤُهم استيقنوا، فقالوا: <span class="qpc-hafs">﴿قد جاءت رسل ربنا بالحق﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يقول الذين نسوه من قبل﴾</span> يعني: يقول في الآخرة الذين تركوا الإيمان في الدنيا بالبعث، فإذا ذكروه وعاينوا قول الرسل، قالوا: <span class="qpc-hafs">﴿قد جاءت رسل ربنا بالحق﴾</span> بأنّ هذا اليوم كائن، وهو حق، <span class="qpc-hafs">﴿فهل لنا من شفعاء﴾</span> من الملائكة والنبيين وغيرها؛ <span class="qpc-hafs">﴿فيشفعوا لنا أو نرد﴾</span> إلى الدنيا؛ <span class="qpc-hafs">﴿فنعمل﴾</span> من الخير <span class="qpc-hafs">﴿غير الذي كنا نعمل﴾</span> من الشر، يعني: الشرك، والتكذيب{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَدۡ خَسِرُوۤا۟ أَنفُسَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٧٨<span class="dash">-</span></span> عن <span class="name-2">أبي رَزين [مسعود بن مالك الأسدي]</span>-من طريق الأعمش- في قوله: <span class="qpc-hafs">﴿قد د خسروا أنفسهم﴾</span>، قال: قد ضَلُّوا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿قد خسروا أنفسهم﴾</span>، يقول: بشَّروها بخسران{17}<span class=comment-ref>٢٥٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٤</span> لم يذكر <u>ابنُ جرير</u> (١٠/٢٤٥) غير هذا القول.</div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله: <span class="qpc-hafs">﴿قد خسروا أنفسهم﴾</span>، يقول: قد غَبَنُوا أنفسَهم، فساروا إلى النار{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿وضلَّ عنهُم ما كانُوا يفترُون﴾</span>، قال: ما كانوا يَكذِبون في الدُّنيا{19}. (٦/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ما كانُوا يفترونَ﴾</span>، أي: يُشرِكون{19}. (٦/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضل عنهم﴾</span> في الآخرة <span class="qpc-hafs">﴿ما كانوا يفترون﴾</span> في الدنيا من التكذيب{18}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٢٤٢، وابن أبي حاتم ٥/١٤٩٤.|2:تفسير مجاهد ص٣٣٨، وأخرجه ابن جرير ١٠/٢٤١، وابن أبي حاتم ٥/١٤٩٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|3:أخرجه ابن أبي حاتم ٥/١٤٩٤.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٢٦-.|5:أخرجه عبد الرزاق ١/٢٣٠، وابن جرير ١٠/٢٤١، وابن أبي حاتم ٥/١٤٩٤. وعزاه السيوطي إلى أبي الشيخ.|6:أخرجه ابن جرير ١٠/٢٤١.|7:أخرجه ابن جرير ١٠/٢٤٢، وابن أبي حاتم ٥/١٤٩٤. وعزاه السيوطي إلى أبي الشيخ.|8:أخرجه ابن جرير ١٠/٢٤٢، وابن أبي حاتم ٥/١٤٩٤-١٤٩٥. وعزاه السيوطي إلى أبي الشيخ.|9:أخرجه عبد الرزاق ٢/٢٣٠.|10:تفسير مقاتل بن سليمان ٢/٤٠.|11:أخرجه ابن جرير ١٠/٢٤٢-٢٤٣، وابن أبي حاتم ٥/١٤٩٤.|12:تفسير مجاهد ص٣٣٨، وأخرجه ابن جرير ١٠/٢٤٤، وابن أبي حاتم ٥/١٤٩٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|13:أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٥٣-٤٥٤ (٢٥٠)-.|14:أخرجه ابن جرير ١٠/٢٤٣، وابن أبي حاتم ٥/١٤٩٥.|15:تفسير مقاتل بن سليمان ٢/٤٠-٤١.|16:أخرجه ابن أبي حاتم ٥/١٤٩٥.|17:أخرجه ابن جرير ١٠/٢٤٥، وابن أبي حاتم ٥/١٤٩٥.|18:تفسير مقاتل بن سليمان ٢/٤١.|19:أخرجه ابن أبي حاتم ٥/١٤٩٦.|20:أخرجه ابن أبي حاتم ٥/١٤٩٦.|21:تفسير مقاتل بن سليمان ٢/٤١.
  7,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ فِی سِتَّةِ أَیَّامࣲ﴾</span> الآية - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٨٤<span class="dash">-</span></span> عن <span class="name-2">سعد بن إسحاق بن كعب بن عُجْرَةَ</span>، قال: نزلت هذه الآية: <span class="qpc-hafs">﴿إن ربَّكُمُ الله الذي خلق السماوات والأرض﴾</span>، لُقِيَ ركبٌ عظيمٌ لا يُرَوْنَ إلا أنّهم من العرب، فقالوا لهم: مَن أنتم؟ قالوا: مِن الجنِّ، خرَجنا من المدينة، أخرَجَتْنا هذه الآيةُ{1}. (٦/٤١٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ فِی سِتَّةِ أَیَّامࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٨٥<span class="dash">-</span></span> عن أبي هريرة، قال: أخذَ رسولُ الله ﷺ بيدي، فقال: «<b>يا أبا هريرةَ، إنّ الله خلق السماوات والأرض وما بينهما في ستَّة أيامٍ، ثُمَّ استوى على العرش، فخلق التُّربة يوم السبت، والجبال يوم الأحد، والشجر يوم الاثنين، وكذا يوم الثلاثاء، والنور يوم الأربعاء، والدوابَّ يوم الخميس، وآدم يومَ الجُمعة في آخر ساعةٍ من النَّهار</b>»{2}<span class=comment-ref>٢٥٣٥</span>. (٦/٤٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٥</span> ذكر <u>ابنُ كثير</u> (٦/٣١٩ بتصرف) هذا الحديث مُخَرَّجًا في مسند الإمام أحمد، ثم قال <span class="comment-type-4">مُعَلِّقًا</span>: «وقد رواه مسلم بن الحجاج في صحيحه، والنسائي من غير وجه، عن حجاج -وهو ابن محمد الأعور-، عن عبد الملك ابن جريج به. وفيه استيعاب الأيام السبعة، والله تعالى قد قال في ستة أيام؛ ولهذا تكلم البخاريُّ وغيرُ واحد من الحفاظ في هذا الحديث، وجعلوه من رواية أبي هريرة، عن كعب الأحبار، ليس مرفوعًا».</div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿خلق السماواتِ والأرضَ﴾</span>، قال: كلُّ يومٍ مقدارُه ألفُ سنةٍ{3}. (٦/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٧<span class="dash">-</span></span> عن <span class="name-1">زيد بن أرقم</span>، قال: إنّ الله ﷿ خلق السماوات والأرض في سِتَّة أيام، لكلِّ يومٍ منها اسمٌ: أبو جادٍ، هوّازٌ، حُطِّي، كَلَمُونَ، سَعْفَصُ، قَرْشاتُ{4}. (٦/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٨<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق أبي صالح- قال: بدأ الله بخلق السماوات والأرض يوم الأحد والاثنين والثلاثاء والأربعاء والخميس والجُمعة، وجعلَ كُلَّ يومٍ ألفَ سنةٍ{5}. (٦/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٨٩<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: قَدِر اللهُ ﷿ على خلق السماوات والأرض في لَمْحَة ولَحْظَة، وإنّما خَلَقَهُنَّ في ستة أيام تعليمًا لخلقه الرِّفق والتثبت في الأمور{6}<span class=comment-ref>٢٥٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٦</span> أبان قولُ سعيد بن جبير عن الحكمة من خلق السموات والأرض في ستة أيام على ما ذكر، وقد <span class="comment-type-4">جعل</span> <u>ابنُ عطية</u> (٣/٥٧٧) حكمة هذا مما انفرد الله بعلمه، وبيّن أنّ كل ما قيل في هذا إنما هو من باب التَّخَرُّص.</div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي بشر- قال: بَدْءُ الخلقِ العرشُ والماء والهواءُ، وخُلقتِ الأرضُ من الماء، وكان بَدْءُ الخلق يوم الأحد ويوم الاثنين والثلاثاء والأربعاء والخميس، وجمَع الخلق في يوم الجُمعة، وتهوَّدتِ اليهودُ يوم السبت، ويومٌ من الستَّة أيامٍ كألف سنة مما تعُدُّون{7}<span class=comment-ref>٢٥٣٧</span>. (٦/٤١٩)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٧</span> لم يذكر <u>ابنُ جرير</u> (١٠/٢٤٥) غير قول مجاهد بن جبر.</p><p>و<span class="comment-type-4">علّق</span> عليه <u>ابنُ عطية</u> (٣/٥٧٧) قائلًا: «وهذا كلُّه والساعةُ اليسيرةُ سواءٌ في قُدْرَةِ الله تعالى».</div></p><p><div></p><p><p><span class="item-no">٢٧٨٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم- قال: إنّ اللهَ بَدَأَ خلق السماوات والأرض وما بينهما يوم الأحد، ثم استوى على العرش يوم الجُمعة في ثلاث ساعات، فخلق في ساعةٍ منها الشُّموس كي يَرغَبَ الناسُ إلى ربهم في الدعاء والمسألة، وخلق في ساعة النَّتَن الذي يقعُ على ابن آدم إذا ماتَ؛ لكي يُقبرَ{8}. (٦/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن ربكم الله الذي خلق السماوات والأرض في ستة أيام ثم استوى على العرش﴾</span> قبل ذلك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ابتَدَع السمواتِ والأرضَ، ولم يكونا إلا بقدرته، ولم يَسْتَعِن على ذلك بأحدٍ مِن خلقه، ولم يُشْرِكه في شيءٍ مِن أمر سلطانه القاهر وقولِه النافذ، الذي يقول له لِما أراد أن يكون: كن. فيكون، ففرغ من خلق السماوات والأرض في ستة أيام{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٨٩٤<span class="dash">-</span></span> عن <span class="name-1">أُمِّ سلمة أمِّ المؤمنين</span> -من طريق الحسن، عن أُمِّه- في قوله تعالى: <span class="qpc-hafs">﴿ثمُّ استوى على العرشِ﴾</span>، قالت: الكَيْفُ غيرُ معقولٍ، والاستواءُ غير مجهولٍ، والإقرار به إيمانٌ، والجحود به كفرٌ{11}. (٦/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي-</span>من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿ثم استوى﴾</span> يقول: ارتفع{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٧<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span> مثله{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٨<span class="dash">-</span></span> <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿استوى﴾</span>، قال: عَلا على العرش{14}. (٦/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٨٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ثمَّ استوى على العرشِ﴾</span>، قال: يومَ السابعِ{8}. (٦/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٠<span class="dash">-</span></span> عن ابن عُيَيْنَة، قال: سُئِل <span class="name-2">ربيعةُ [بن أبي عبد الرحمن]</span> عن قوله: <span class="qpc-hafs">﴿استوى على العرشِ﴾</span>، كيف استوى؟ قال: الاستواءُ غيرُ مجهولٍ، والكَيْفُ غيرُ معقولٍ، ومِن الله الرسالةُ، وعلى الرسول البلاغُ، وعلينا التصديقُ{16}. (٦/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠١<span class="dash">-</span></span> عن عبد الله بن صالح بن مسلم، قال: سُئِل <span class="name-2">ربيعةُ [بن أبي عبد الرحمن]</span>. فذَكَرَه{17}. (٦/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٣<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿ثم استوى على العرش﴾</span>: اسْتَقَرَّ{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن ربكم الله الذي خلق السماوات والأرض في ستة أيام ثم استوى على العرش﴾</span> قبل ذلك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٥<span class="dash">-</span></span> عن محمد بن شعيب بن شابور، عن أبيه: أنّ رجلًا سأل <span class="name-3">الأوزاعي</span> في قوله تعالى: <span class="qpc-hafs">﴿الرحمن على العرش استوى﴾</span>. فقال: هو على العرش كما وصَف نفسَه، وإنِّي لَأراك رجلًا ضالًّا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٦<span class="dash">-</span></span> عن جعفر بن عبد الله، قال: جاء رجلٌ إلى <span class="name-3">مالك بن أنس</span>، فقال له: يا أبا عبد الله، <span class="qpc-hafs">﴿استوى على العرش﴾</span>، كيف استوى؟ قال: فما رأيتُ مالِكًا وجِدَ من شيءٍ كمَوجِدَتِه مِن مقالتِه، وعلاه الرُّحَضاءُ -يعني: العرق-، وأطْرَقَ القومُ، قال: فَسُرِّيَ عن مالك، فقال: الكيفُ غيرُ معقولٍ، والاستواءُ منه غيرُ مجهولٍ، والإيمان به واجبٌ، والسؤالُ عنه بدعةٌ، وإنِّي أخافُ أن تكونَ ضالًّا. وأمَر به فأُخرِجَ{21}. (٦/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٧<span class="dash">-</span></span> عن عبد الله بن وهبٍ، قال: كُنّا عند <span class="name-3">مالك بن أنس</span>، فدخل رجلٌ، فقال: يا أبا عبد الله، <span class="qpc-hafs">﴿الرحمنُ على العرش استوى﴾</span>، كيف استواؤُه؟ فأطرَقَ مالِكٌ، وأخَذَته الرُّحَضاءُ، ثم رفَعَ رأسه، فقال: الرحمنُ على العرش استوى كما وصَف نفسَه، ولا يقالُ له: كيف، وكيف عنه مرفوعٌ، وأنت رجلُ سَوءٍ صاحبُ بدعةٍ، أخرِجُوه. قال: فأُخرِجَ الرجلُ{22}. (٦/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٨<span class="dash">-</span></span> عن أحمدَ بن أبي الحواريِّ، قال: سمعتُ <span class="name-3">سفيانَ بنَ عُيَيْنةَ</span>، يقول: كُلَّ ما وصفَ اللهُ مِن نفسِه في كتابه فتفسيرُه: تلاوتُه، والسكوتُ عليه{23}. (٦/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٠٩<span class="dash">-</span></span> عن إسحاقَ بن موسى، قال: سمعتُ <span class="name-3">ابنَ عُيَيْنةَ</span> يقولُ: ما وصفَ اللهُ به نفسَه فتفسيرُه قراءتُه، ليس لأحدٍ أن يُفَسِّرَه إلا اللهُ تعالى، ورسلُه -صلواتُ الله عليهم-{24}. (٦/٤٢٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡعَرۡشِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك بن مزاحم- قال: إنّما سُمِّي العرشُ: عرشًا؛ لارتفاعه{25}. (٧/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: ما يَقْدُرُ قدرَ العرش إلا الذي خَلَقه، وإنّ السماوات في خَلْق الرحمن مِثْلُ قُبَّةٍ في صحراء{26}. (٧/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: ما أخَذَتِ السماواتُ والأرضُ مِن العرشِ إلا كما تَأْخُذُ الحَلقةُ مِن أرضِ الفَلاةِ{27}. (٧/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩١٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إلياس ابن ابنة وهب بن منبه- قال: إنّ الله خلق العرش من نوره{28}<span class=comment-ref>٢٥٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٨</span> <span class="comment-type-4">علَّق</span> <u>ابن كثير</u> (٧/٣٣٣) على قول وهب بقوله: «وهذا غريب».</div></p><p><h3><span class="qpc-hafs">﴿یُغۡشِی ٱلَّیۡلَ ٱلنَّهَارَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يُغْشي الَّليل النَّهار﴾</span>، قال: يُلْبِسُ الليلَ النهار{29}. (٦/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿يُغشي الَّليل﴾</span>، قال: يُغشي الليلَ النهارَ، فيَذهبُ بضوئِه، ويطلبُه سرِيعًا حتى يُدركَه{30}. (٦/٤٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَطۡلُبُهُۥ حَثِیثࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿حثيثًا﴾</span>، قال: سريعًا{31}. (٦/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-، نحو ذلك{32}. (٦/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يطلبه حثيثا﴾</span>، يعني: سريعًا{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلشَّمۡسَ وَٱلۡقَمَرَ وَٱلنُّجُومَ مُسَخَّرَ ٰ⁠تِۭ بِأَمۡرِهِۦۤۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩١٩<span class="dash">-</span></span> عن أنسٍ، عن رسول الله ﷺ، قال: «<b>إنّ الشمسَ والقمرَ والنجومَ خُلِقْنَ مِن نور العرشِ</b>»{34}. (٦/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٠<span class="dash">-</span></span> عن <span class="name-2">حسّان بن عطية</span> -من طريق الأوزاعي- قال: الشمس والقمر والنجوم مسخرات في فَلَكٍ من السماء والأرض{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والشَّمْسَ والقَمَرَ والنُّجُومَ مُسَخَّراتٍ بِأَمْرِهِ﴾</span> لبني آدم{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَا لَهُ ٱلۡخَلۡقُ وَٱلۡأَمۡرُۗ تَبَارَكَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٢٢<span class="dash">-</span></span> عن عبد العزيز الشّامي، عن أبيه -وكانت له صحبةٌ-، قال: قال رسول الله ﷺ: «<b>مَن لَمْ يحمَدِ اللهَ على ما عمِلَ مِن عملٍ صالحٍ، وحمِدَ نفسَه؛ فقد كفَرَ وحبِطَ عملُه، ومَن زعم أنّ الله جعل للعباد من الأمر شيئًا فقد كَفر بما أنزَلَ الله على أنبيائه؛ لقوله: <span class="qpc-hafs">﴿ألا لهُ الخلقُ والأمرُ تباركَ اللهُ ربُّ العالمينَ﴾</span></b>»{37}<span class=comment-ref>٢٥٣٩</span>. (٦/٤٢٥)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣٩</span> لم يذكر <u>ابنُ جرير</u> (١٠/٢٤٧) غير هذا القول.</div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٣<span class="dash">-</span></span> قال <span class="name-1">أبو هريرة</span> -من طريق عبد الله بن موهب-: الخلقُ خلقُ الله، والأمرُ أمرُه{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك بن مزاحم- قال: يوم القيامة يُدِينُهم بأعمالهم، إلّا مَن عفا عنه، فالأمرُ أمرُه، ثم قال: <span class="qpc-hafs">﴿ألا له الخلق والأمر﴾</span>{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا له الخلق﴾</span> يعني: كُل شيء خلق، <span class="qpc-hafs">﴿والأمر﴾</span> يعني: قضاءه في الخلق الذي في اللوح المحفوظ، فله المشيئة في الخلق والأمر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَيْنة</span> -من طريق أبي زرعة الخراساني- في قوله: <span class="qpc-hafs">﴿ألا لهُ الخلقُ والأمرُ﴾</span>، قال:الخلْقُ ما دون العرشِ، والأمرُ ما فوقَ ذلك{35}. (٦/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَيْنة</span> -من طريق بشّار بن موسى- قال: الخلقُ هو الخلقُ، والأمرُ هو الكلامُ{42}. (٦/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٨<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عُيَيْنة</span>: بيَّن اللهُ الخلقَ من الأمر؛ لقوله تعالى: <span class="qpc-hafs">﴿ألا له الخلق والأمر﴾</span>{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٢٩<span class="dash">-</span></span> عن عبد الجبار بن العلاء العطّار، قال: سألتُ <span class="name-3">سفيان بن عُيَيْنة</span> عن قوله: <span class="qpc-hafs">﴿ألا لَهُ الخَلْقُ والأَمْرُ﴾</span>. فقال: فرَّق اللهُ بين الخلق والأمر، ومَن جمع بينهما فقد كَفَر{44}<span class=comment-ref>٢٥٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٠</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٣/٥٧٩-٥٨٠): «وأخذ المفسرون الخَلْق بمعنى: المخلوقات، أي: هي له كلها وملكه واختراعه، وأخذوا الأَمْرُ مصدرًا من أمر يأمر، وعلى هذا قال النقّاش وغيرُه: إنّ الآية ترُدُّ على القائلين بخلق القرآن؛ لأنّه فرق فيها بين المخلوقات وبين الكلام؛ إذ الأمر كلامه ﷿. ويحتمل أن تؤخذ لفظة الخَلْق على المصدر مِن خلق يخلق خلقًا، أي: له هذه الصفة؛ إذ هو الموجد للأشياء بعد العدم، ويؤخذ الأَمْرُ على أنّه واحد الأمور، إلا أنّه يدل على الجنس فيكون <span class="mustanad">بمنزلة قوله</span>: <span class="qpc-hafs">﴿وإلَيْهِ يُرْجَعُ الأَمْرُ كُلُّهُ﴾</span> [هود:١٢٣]، <span class="mustanad">وبمنزلة قوله</span>: <span class="qpc-hafs">﴿وإلى اللَّهِ تُرْجَعُ الأُمُورُ﴾</span> [البقرة:٢١٠]، فإذا أُخِذَت اللفظتان هكذا خرجتا عن مسألة الكلام».</div></p><p><h3><span class="qpc-hafs">﴿تَبَارَكَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك بن مزاحم-: <span class="qpc-hafs">﴿تبارك﴾</span> تَفاعُلٌ مِن البَرَكة{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٣١<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿تبارك﴾</span>: تَعَظَّم{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٣٢<span class="dash">-</span></span> وقال <span class="name-2">الحسن البصري</span>: تجيء البركة مِن قِبَلِه{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تبارك الله رب العالمين﴾</span>، فيُخْبِرُ بعَظَمَته، وقُدْرَته{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَبَارَكَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٥٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٣٤<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق السلولي- قال: إنّ اللهَ حين خلق الخلْقَ استوى على العرش، فسبَّحَه العرشُ{49}. (٦/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٣٥<span class="dash">-</span></span> عن حيّان الأعرج، قال: كَتَبَ يزيدُ بن أبي مسلمٍ إلى <span class="name-2">جابر بن زيدٍ</span>، يسأله عن بدء الخلق. قال: العرشُ والماءُ والقلمُ، والله أعلمُ أيّ ذلك بَدَأ قبلُ{50}. (٦/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٣٦<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد-: قال عُزَيْرٌ: يا ربِّ، أمَرْتَ الماءَ فجمد على وسط الهوا، فجعلت منه سبعًا، وسَمَّيْتَها: السموات، ثم أمرت الماءَ ينفتق من التراب، ثم أمرت التراب أن يَتَمَيَّز من الماء، فكان كذلك، فسَمَّيْتَ جميع ذلك: الأرضين، وجميع الماء: البحار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٣٧<span class="dash">-</span></span> عن سُمَيطٍ، قال: دلَّنا ربُّنا -تبارك وتعالى- على نفسِه في هذه الآية: <span class="qpc-hafs">﴿إنّ ربَّكمُ الله الَّذي خلق السماواتِ والأرضَ﴾</span> الآية{52}. (٦/٤١٧)</p></p><p></div></p></div>",footnotes:1:أخرجه المستغفري في فضائل القرآن ٢/٧٥٨ (١١٤٩)، وابن أبي حاتم ٥/١٤٩٦ (٨٥٧٢)، ٦/١٩٢٤ (١٠٢٠٧) مرسلًا.|2:أخرجه مسلم ٤/٢١٤٩ (٢٧٨٩)، وابن جرير ٢٠/٣٨٣-٣٨٤ كلاهما بنحوه. وعزاه السيوطي إلى ابن مردُويه.|3:أخرجه ابن أبي حاتم ٥/١٤٩٦. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.|4:عزاه السيوطي إلى سمُّويه في فوائده.|5:أخرجه ابن أبي شيبة ١٤/١٢٦.|6:تفسير الثعلبي ٤/٢٣٨.|7:أخرجه سعيد بن منصور -كما في الفتح ٦/٢٩٠-، وابن أبي شيبة ١٤/١٠٦، وابن جرير ١٠/٢٤٥-٢٤٦، والبيهقي في الأسماء والصفات (٨٠٦). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|8:أخرجه ابن أبي حاتم ٥/١٤٩٧.|9:تفسير مقاتل بن سليمان ٢/٤١.|10:أخرجه ابن أبي حاتم ٥/١٤٩٦.|11:أخرجه اللالكائي في السنة (٦٦٣). وعزاه السيوطي إلى ابن مردويه.|12:أخرجه ابن أبي حاتم ٦/١٩٢٥.|13:علّقه ابن أبي حاتم ٦/١٩٢٥. وقد أورد هذين الأثرين قبلُ في تفسير قوله تعالى: <span class="qpc-hafs">﴿ثُمَّ اسْتَوى إلى السَّماءِ﴾</span> [البقرة: ٢٩].|14:عزاه السيوطي إلى الفريابي.|15:أخرجه ابن أبي حاتم ٥/١٤٩٧.|16:أخرجه اللالكائي (٦٦٥).|17:أخرجه البيهقي في الأسماء والصفات (٨٦٨).|18:تفسير الثعلبي ٤/٢٣٨، وتفسير البغوي ٣/٢٣٥.|19:تفسير مقاتل بن سليمان ٢/٤١.|20:تفسير الثعلبي ٤/٢٣٩.|21:أخرجه اللالكائي (٦٦٤).|22:أخرجه البيهقي (٨٦٦).|23:أخرجه البيهقي (٨٦٩).|24:أخرجه البيهقي (٩٠٦).|25:أخرجه ابن أبي حاتم ٦/١٩١٩.|26:أخرج أبو الشيخ في العظمة (١٩٨). كما أخرج أوَّله يحيى بن سلام ٢/٥٤٠، وابن أبي حاتم ٦/١٩٢٠، والحاكم ٢/٢٨٢.|27:أخرجه ابن أبى حاتم ٦/١٩٢٠، وأبو الشيخ (٢٢٠، ٢٥١). وعزاه السيوطي إلى سعيد بن منصور.|28:أخرجه ابن أبي حاتم ٥/١٤٩٧، ٦/١٩٢٥.|29:أخرجه ابن أبي حاتم ٧/٢٢١٩.|30:أخرجه ابن جرير ١٠/٢٤٦، وابن أبي حاتم ٥/١٤٩٧-١٤٩٨. وعزاه السيوطي إلى أبي الشيخ.|31:أخرجه ابن جرير ١٠/٢٤٦، وابن أبي حاتم ٥/١٤٩٨.|32:أخرجه ابن جرير ١٠/٢٤٦. وعلَّقه ابن أبي حاتم ٥/١٤٩٨.|33:تفسير مقاتل بن سليمان ٢/٤١.|34:أخرجه الطبراني في الأوسط ٦/١٥٣ (٦٠٦٢)، وأبو الشيخ الأصبهاني في العظمة ٤/١١٣٩-١١٤٠.</p><p>قال الهيثمي في المجمع ٨/١٣٢ (١٣٣٦٦): «رواه الطبراني في الأوسط، وفيه معقل بن مالك، وثَّقه ابنُ حِبّان، وقال الأزدي: متروك. وفيه مَن لم أعرفه».|35:أخرجه ابن أبي حاتم ٥/١٤٩٨.|36:تفسير مقاتل بن سليمان ٢/٤١.|37:أخرجه ابن جرير ١٠/٢٤٧.</p><p>قال الألباني في الضعيفة ١٣/١٦٤ (٦٠٦٤): «موضوع».|38:أخرجه ابن أبي حاتم ٥/١٤٩٨.|39:أخرجه ابن أبي حاتم ٥/١٤٩٨.|40:تفسير مقاتل بن سليمان ٢/٤١.|41:أخرجه ابن أبي حاتم ٥/١٤٩٨.|42:أخرجه ابن أبي حاتم ٥/١٤٩٨، والبيهقي في الأسماء والصفات (٥٤٨) مُطَوَّلًا.|43:علَّقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التوحيد - باب قول الله تعالى: <span class="qpc-hafs">﴿والله خلقكم وما تعملون﴾</span> ٦/٢٧٤٦.|44:أخرجه الثعلبي في تفسيره ٤/٢٣٩، وتفسير البغوي ٣/٢٣٦.|45:أخرجه ابن أبي حاتم ٥/١٤٩٨.|46:تفسير الثعلبي ٤/٢٤٠.|47:تفسير الثعلبي ٣/١٢٣.|48:تفسير مقاتل بن سليمان ٢/٤١.|49:أخرجه ابن أبي حاتم ٧/٢٢١٧.|50:أخرجه البيهقي في الأسماء والصفات (٨٠٥).|51:أخرجه ابن أبي حاتم ٥/١٤٩٦.|52:عزاه السيوطي إلى أبي الشيخ.
  7,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱدۡعُوا۟ رَبَّكُمۡ تَضَرُّعࣰا وَخُفۡیَةًۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٣٨<span class="dash">-</span></span> عن النعمان بن بشير، قال: قال رسول الله ﷺ: «<b>الدُّعاء هو العبادة</b>»{1}<span class=comment-ref>٢٥٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤١</span> للدعاء نوعان: دعاء العبادة، ودعاء المسألة. وقد أشار هذا الحديثُ إلى النوع الأول من أنواع الدعاء، وهو دعاء العبادة. وقد بيّن <u>ابنُ تيمية</u> (٣/١٦٣-١٦٥) أنّ النوعين متلازمان، فكلُّ دعاء عبادة مستلزم لدعاء المسألة، وكل دعاء متضمن مستلزم لدعاء العبادة، وذكر العديدَ من الآيات التي تبين هذا وتوضحه. وليس قوله تعالى: <span class="qpc-hafs">﴿ادعوا ربكم تضرعا وخفية﴾</span> فيما يرى <u>ابنُ تيمية</u> مقصورًا على أحد نوعي الدعاء، بل هو شاملٌ لكليهما، وإن كان أظهرَ في دعاء المسألة، مُعَلِّلًا ذلك بقوله: «ولهذا أمر بإخفائه وإسراره».</div></p><p><div></p><p><p><span class="item-no">٢٧٩٣٩<span class="dash">-</span></span> عن أبي موسى، قال: كان النبيُّ ﷺ في غَزاة، فأشرفوا على وادٍ، فجعل الناسُ يُكَبِّرون، ويُهَلِّلون، ويرفعون أصواتهم، فقال: «<b>أيها الناس، ارْبَعُوا على أنفسكم، إنّكم لا تدعون أصمَّ ولا غائبًا، إنّكم تدعون سميعًا قريبًا، إنّه معكم</b>»{2}<span class=comment-ref>٢٥٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٢</span> لم يذكر <u>ابنُ جرير</u> (١٠/٢٤٨) غير هذا الأثر، وقول ابن عباس، والحسن البصري من طريق المبارك بن فضالة.</div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿ادعُوا ربَّكم تضرُّعا وخُفية﴾</span>، قال: السِّرّ{3}. (٦/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ادعُوا ربَّكم تضرُّعا﴾</span> يعني: مُسْتَكِينًا، <span class="qpc-hafs">﴿وخفيةً﴾</span> يعني: في خفضٍ وسكونٍ في حاجاتِكم مِن أمر الدنيا والآخرة{4}. (٦/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- قال: لقد كان المسلمون يجتهدُون في الدعاء، وما سُمِعَ لهم صوتٌ، إن كان إلّا همسًا بينَهم وبينَ ربِّهم، وذلك أنّ الله يقولُ: <span class="qpc-hafs">﴿ادعُوا ربكُم تضرعًا وخُفية﴾</span>. وذلك أنّ الله ذَكَر عبدًا صالحًا، فرضِي له قولَه، فقال: <span class="qpc-hafs">﴿إذْ نادى ربهُ نداءً خفيا﴾</span> [مريم:٣]{5}<span class=comment-ref>٢٥٤٣</span>. (٦/٤٢٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٣</span> ذهب <b>بعضُ السلف</b> إلى أنّ التضرع علانيةً، والخفية سِرًّا، كما في قول قتادة. وقد أفاد <b>قولُ الحسن</b> هذا أنّ التضرع والخفية في معنى السرِّ جميعًا. وقد ذكر <u>ابنُ عطية</u> (٣/٥٨١ بتصرف) هذا عن الحسن، ثم قال <span class="comment-type-4">مُعَلِّقًا</span> عليه: «فكأنّ التضرع على قول الحسن فِعْلٌ للقلب». ثم زاد <b>قولًا</b> آخر عن الزجاج: أنّ قوله: <span class="qpc-hafs">﴿تضرعا وخفية﴾</span> معناه: باستكانة واعتقاد ذلك في القلوب".</div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: التضرُّع علانيةٌ، والخفيةُ سِرٌّ{6}. (٦/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابن أبي الرجال- في قول الله: <span class="qpc-hafs">﴿ادعُوا ربكُم تضرعًا وخُفية﴾</span>، قال: عنى بذلك: القراءة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم بَيَّن كيف يدعونه، فقال: <span class="qpc-hafs">﴿ادعُوا ربكُم تضرعًا﴾</span> يعني: مستكينين، <span class="qpc-hafs">﴿وخفية﴾</span> يعني: في خفض وسكون، كقوله: <span class="qpc-hafs">﴿ولا تُخافت بها﴾</span> [الإسراء:١١٠]، يعني: تُسِرّ بها{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَا یُحِبُّ ٱلۡمُعۡتَدِینَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٤٦<span class="dash">-</span></span> عن عبد الله بن مُغَفَّل، أنّه سمِعَ ابنه يقول: اللهمَّ، إنِّي أسألُك القصر الأبيض عن يمين الجنة إذا دخَلْتُها. فقال: أيْ بُنيَّ، سلِ اللهَ الجنَّة، وتعوَّذْ به من النار، فإنِّي سمعتُ النبيَّ ﷺ يقول: «<b>سيكونُ في هذه الأُمَّةِ قومٌ يعتدُون في الدُّعاء والطَّهُور</b>»{9}<span class=comment-ref>٢٥٤٤</span>. (٦/٤٢٧)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٤</span> ذكر <u>ابنُ كثير</u> (٦/٤٢٣-٤٢٤) هذا الأثر من رواية الإمام أحمد، ثم قال <span class="comment-type-4">مُعَلِّقًا</span>: «وهكذا رواه ابنُ ماجه، عن أبي بكر بن أبي شيبة، عن عفان به. وأخرجه أبو داود، عن موسى ابن إسماعيل، عن حماد بن سلمة، عن سعيد بن إياس الجريري، عن أبي نعامة -واسمه: قيس ابن عباية الحنفي البصري-، وهو إسناد حسن لا بأس به».</div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٧<span class="dash">-</span></span> عن سعد بن أبي وقاص، أنّه سمِعَ ابنًا له يدعُو، ويقول: اللَّهُمَّ، إنِّي أسألُك الجنَّة، ونعيمَها، وإستبرَقَها، ونحو هذا، وأعوذ بك من النار، وسلاسِلِها، وأغلالِها. فقال: لقد سألتَ الله خيرًا، وتعوَّذتَ به من شرٍّ كثيرٍ، وإنِّي سمعتُ رسول الله ﷺ يقول: «<b>إنّه سيكونُ قومٌ يعتدُون في الدعاءِ</b>». وقرأ هذه الآية: <span class="qpc-hafs">﴿ادعُوا ربَّكم تضرعًا وخفية إنّه لا يحبُّ المعتدينَ﴾</span>. وإنّ بحسبك أن تقول: اللهمَّ، إنِّي أسألُك الجنَّة، وما قَرَّبَ إليها مِن قولٍ أو عملٍ، وأعوذُ بك من النار وما قرَّبَ إليها من قولٍ أو عملٍ{10}. (٦/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء-: <span class="qpc-hafs">﴿إنّه لا يحبُّ المعتدينَ﴾</span> في الدعاء، ولا في غيره{11}. (٦/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٤٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿إنّه لا يحبُّ المعتدينَ﴾</span>، يقول: لا تدعُوا على المؤمنِ والمؤمنةِ بالشرِّ؛ اللهمَّ، اخْزِه، والعَنْه، ونحو ذلك؛ فإن ذلك عُدوانٌ{12}. (٦/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي مجلز لاحق بن حميد</span> -من طريق علقمة- في قوله: <span class="qpc-hafs">﴿إنّه لا يحبُّ المعتدينَ﴾</span>، قال: لا تسألُوا منازلَ الأنبياء{13}. (٦/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥١<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العوفي</span>: هم الذين يدعون على المؤمنين فيما لا يَحِلُّ، فيقولون: اللَّهُمَّ، اخْزِهِم، اللَّهُمَّ، العنهم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿إن ربكُمُ اللهُ الذي خلق السماوات والأرض﴾</span> إلى قوله: <span class="qpc-hafs">﴿تباركَ اللهُ ربُّ العالمينَ﴾</span> قال: لَمّا أنبَأكم الله بقُدرتِه وعظمتِه وجلاله بيَّن لكم كيف تدعُونَه على تفِئةِ{15} ذلك، فقال: <span class="qpc-hafs">﴿ادعوا ربكُم تضرُّعا وخُفية إنّه لا يُحبُ المعتدينَ﴾</span>. قال: تعلَّموا أن في بعض الدعاءِ اعتداءً، فاجتنبوا العدوانَ والاعتداء إن استطعتم، ولا قُوة إلا بالله. قال: وذُكِرَ لنا: أنّ مجالدَ بن مسعودٍ أخا بني سُليم سمِعَ قومًا يَعِجُّون{16} في دعائهم، فمشى إليهم، فقال: أيُّها القومُ، لقد أصبتُم فضلًا على مَن كان قبلكم، أو لقد هلَكتُم. فجعلوا يتسلَّلون رجلًا رجلًا، حتى ترَكُوا بُقْعَتَهم التي كانوا فيها. قال: وذُكِر لنا: أنّ ابن عمر أتى على قومٍ يرفعُون أيديَهم، فقال: ما يتناولُ هؤلاءِ القومُ؟! فواللهِ، لو كانوا على أطولِ جبل في الأرض ما ازدادُوا من الله قُربًا. قال قتادة: وإنّ اللهَ إنما يُتقرَّبُ إليه بطاعته، فما كان من دعائكم اللهَ فلْيَكُن في سكينةٍ، ووقارٍ، وحُسْنِ سَمتٍ، وزيٍّ{17}، وهَدْيٍ، وحُسنِ دَعَةٍ{18}. (٦/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- <span class="qpc-hafs">﴿إنه لا يحب المعتدين﴾</span>، قال: لا يُحِبُّ الاعتداء في الدعاء، ولا في غيره{12}<span class=comment-ref>٢٥٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٥</span> <span class="comment-type-3">رجّح</span> <u>ابنُ تيمية</u> (٣/١٦٩) <span class="mustanad">مستندًا إلى النظائر، ودلالة العقل</span> أنّ قوله تعالى: <span class="qpc-hafs">﴿إنه لا يحب المعتدين﴾</span> يشمل الدعاء وغيره، كما في قول عطاء، فقد ذكر قولَ مَن جعلها في الدعاء خاصة، ثم قال: «وبعد، فالآية أعمُّ من ذلك كُلِّه، وإن كان الاعتداء في الدعاء مرادًا بها فهو من جملة المراد، والله لا يحب المعتدين في كل شيء، دعاء كان أو غيره، كما قال: <span class="qpc-hafs">﴿ولا تعتدوا إن الله لا يحب المعتدين﴾</span> [البقرة:١٩٠، المائدة:٨٧]. وعلى هذا فيكون قد أمَر بدعائه وعبادته، وأخبر أنّه لا يحب أهل العدوان، وهم الذين يدعون معه غيره، فهؤلاء أعظم المعتدين عدوانًا؛ فإنّ أعظم العدوان هو الشرك، وهو داخل ولا بُدَّ في قوله: <span class="qpc-hafs">﴿إنه لا يحب المعتدين﴾</span>».</p><p>و<span class="comment-type-4">بمثله</span> قال <u>ابنُ القيم</u> (١/٤٠٣-٤٠٤).</div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابن أبي الرجال-: كان يُرى أنّ الجهر بالدعاء الاعتداء{12}. (٦/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في الآية، قال: إيّاك أن تسألَ ربَّك أمرًا قد نُهيتَ عنه، أو ما لا ينبغي لك{6}. (٦/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فادعوه في حاجتكم، ولا تدعوه فيما لا يَحِلُّ لكم على مؤمن أو مؤمنة، تقول: اللَّهُمَّ، اخزه، والعنه، اللَّهُمَّ، أهلكه، أو افعل به كذا وكذا، فذلك عدوان؛ <span class="qpc-hafs">﴿إنه﴾</span> الله <span class="qpc-hafs">﴿لا يحب المعتدين﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في الآية، قال: إنّ من الدعاء اعْتداء؛ يُكرَهُ رفعُ الصوتِ، والنداءُ، والصياحُ بالدعاء، ويُؤمرُ بالتضرُّع، والاستكانة{23}<span class=comment-ref>٢٥٤٦</span>. (٦/٤٢٩)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٦</span> لم يذكر <u>ابنُ جرير</u> (١٠/٢٤٩) غير قول ا بن جريج، وقول أبي مجلز، وقول ابن عباس.</div></p></div>",footnotes:1:أخرجه أحمد ٣٠/٢٩٧-٢٩٨ (١٨٣٥٢)، ٣٠/٣٣٦ (١٨٣٨٦)، ٣٠/٣٤٠ (١٨٣٩١)، ٣٠/٣٨٠ (١٨٤٣٢)، ٣٠/٣٨٢-٣٨٣ (١٨٤٣٦، ١٨٤٣٧)، وأبو داود ٤/٦٠٣ (١٤٧٩)، والترمذي ٥/٢٢٧-٢٢٨ (٣٢٠٧)، ٥/٤٥٢ (٣٥٢٨)، ٦/٦ (٣٦٦٨)، وابن ماجه ٥/٥ (٣٨٢٨)، وابن حبان ٣/١٧٢ (٨٩٠)، والحاكم ١/٦٦٧ (١٨٠٢، ١٨٠٣، ١٨٠٤)، وعبد الرزاق في تفسيره ٣/١٤٧ (٢٦٨٥)، وابن جرير ٣/٢٢٨، ٢٠/٣٥٢، ٣٥٣، ٣٥٤، وابن أبي حاتم ٥/١٤٩٩ (٨٥٩٠)، ١٠/٣٢٦٩ (١٨٤٤٤)، والثعلبي ٨/٢٨٠.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال النووي في الأذكار ص٦١٢ (١٩٧٢): «روينا بالأسانيد الصحيحة...». وقال ابن حجر في الفتح ١/٤٩: «أخرجه أصحاب السنن بسند جيد». وقال المناوي في التيسير ٢/١١: «أسانيد صحيحة». وقال الألباني في صحيح أبي داود ٥/٢١٩ (١٣٢٩): «إسناده صحيح».|2:أخرجه البخاري ٤/٥٧ (٢٩٩٢)، ٥/١٣٣ (٤٢٠٥)، ٨/٨٢ (٦٣٨٤)، ٨/٨٧ (٦٤٠٩)، ٨/١٢٥ (٦٦١٠)، ٩/١١٧-١١٨ (٧٣٨٦)، ومسلم ٤/٢٠٧٦ (٢٧٠٤)، وابن جرير ١٠/٢٤٨. وأورده الثعلبي ٤/٢٤٠.|3:أخرجه ابن جرير ١٠/٢٤٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|4:أخرجه ابن أبي حاتم ٥/١٤٩٩.|5:أخرجه ابن المبارك (١٤٠)، وابن جرير ١٠/٢٤٧-٢٤٨. وعزاه السيوطي إلى أبي الشيخ.|6:عزاه السيوطي إلى أبي الشيخ.|7:أخرجه ابن أبي حاتم ٥/١٤٩٩.|8:تفسير مقاتل بن سليمان ٢/٤١.|9:أخرجه أحمد ٢٧/٣٥٦ (١٦٨٠١)، ٣٤/١٧٢ (٢٠٥٥٤)، وأبو داود ١/٧١ (٩٦)، وابن ماجه ٥/٣٢ (٣٨٦٤)، وابن حبان ١٥/١٦٦ (٦٧٦٣)، ١٥/١٦٦-١٦٧ (٦٧٦٤)، والحاكم ١/٢٦٧ (٥٧٩)، ١/٧٢٤ (١٩٧٩).</p><p>قال الحاكم في الموضع الثاني: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في الموضع الأول: «فيه إرسال». وقال ابن كثير في تفسيره ٣/٤٢٩: «إسناد حسن، لا بأس به». وقال الألباني في صحيح أبي داود ١/١٦٣ (٨٦): «إسناده صحيح».|10:أخرجه أحمد ٣/٧٩-٨٠ (١٤٨٣)، ٣/١٤٦-١٤٧ (١٥٨٤)، وأبو داود ٢/٦٠٤ (١٤٨٠)، وابن أبي حاتم ٥/١٥٠٠ (٨٥٩٥).</p><p>قال الألباني في صحيح أبي داود ٥/٢٢٠ (١٣٣٠): «حديث حسن».|11:أخرجه ابن جرير ١٠/٢٤٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|12:أخرجه ابن أبي حاتم ٥/١٥٠٠.|13:أخرجه ابن جرير ١٠/٢٤٩. وعزاه السيوطي إلى ابن أبي حاتم.|14:تفسير الثعلبي ٤/٢٤٠، وتفسير البغوي ٣/٢٣٧.|15:على تفئة ذلك: أي على إثر ذلك. النهاية (تفأ).|16:العَجُّ: رفع الصوت. النهاية (عجج).|17:الزِّيّ: الهيئة والمنظر. لسان العرب (زوي).|18:عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.|19:أخرجه ابن أبي حاتم ٥/١٥٠٠.|20:أخرجه ابن أبي حاتم ٥/١٥٠٠.|21:عزاه السيوطي إلى أبي الشيخ.|22:تفسير مقاتل بن سليمان ٢/٤١.|23:أخرجه ابن جرير ١٠/٢٤٩. وعزاه السيوطي إلى أبي الشيخ.
  7,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ بَعۡدَ إِصۡلَـٰحِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٥٨<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٥٩<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٠<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦١<span class="dash">-</span></span> و<span class="name-3">محمد بن السائب الكلبي</span>:<span class="qpc-hafs">﴿ولا تفسدوا في الأرض بعد إصلاحها﴾</span>، أي: لا تُفْسِدوا فيها بالمعاصي، والدعاء إلى غير طاعة الله، بعد إصلاح الله إيّاها ببَعْثِ الرسل، وبيان الشريعة، والدعاء إلى طاعة الله{1}<span class=comment-ref>٢٥٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٧</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٣/٥٨٢) على قول الضحاك، والحسن، والسدي، والكلبي، فقال: «وقال بعضُ الناس: المراد: ولا تشركوا في الأرض بعد أن أصلحها الله ببعثة الرسل، وتقرير الشرائع، ووضوح ملة محمد ﷺ. وقائل هذه المقالة قصد إلى أكبر فساد بعد أعظم صلاحٍ، فخصَّه بالذِّكْر». وذكر <u>ابنُ عطية</u> عن الضحاك <b>قولًا</b> آخر؛ أنّ ذلك معناه: «لا تغوروا الماء المعين، ولا تقطعوا الشجر المثمر ضرارًا».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> أنّ اللفظَ <span class="mustanad">عامٌّ</span> يتضمَّنُ كُلَّ إفساد بعد إصلاح قلَّ أو كثر، وبيَّن أنّ تخصيص شيء دون شيء في هذا تَحَكُّمٌ، إلا أن يُقال على سبيل المثال.</div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٢<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العوفي</span>: لا تعصوا في الأرض؛ فيُمْسِك اللهُ المطرَ، ويُهْلِكُ الحرثَ بمعاصيكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿ولا تُفسدوا في الأرض بعدَ إصلاحها﴾</span>، قال: بعدَ ما أصلَحَتْها الأنبياءُ وأصحابُهم{3}. (٦/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٤<span class="dash">-</span></span> عن <span class="name-3">أبي سنان [سعيد بن سنان البُرْجُمِيّ]،</span> في قوله: <span class="qpc-hafs">﴿ولا تُفسدوا في الأرضِ بعدَ إصلاحها﴾</span>، قال: قد أحلَلتُ حلالي، وحرَّمتُ حرامي، وحدَدتُ حدُودي، فلا تُفْسِدُوها{4}. (٦/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تُفسدوا في الأرضِ بعدَ إصلاحها﴾</span>، وذلك أنّ الله إذا بعث نبيًّا إلى الناس فأطاعوه صلحت الأرض، وصلح أهلها، وأنّ المعاصي فساد المعيشة، وهلاك أهلها. يقول: لا تعملوا في الأرض بالمعاصي بعد الطاعة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٦<span class="dash">-</span></span> عن <span class="name-3">أبي بكر بن عياش</span> -من طريق سُنَيد- أنّه سُئل عن قوله: <span class="qpc-hafs">﴿ولا تُفسدُوا في الأرض بعد إصلاحها﴾</span>. فقال: إنّ الله بعث محمدًا ﷺ إلى أهل الأرض وهم في فسادٍ، فأصلَحَهم الله بمحمدٍ ﷺ، فمَن دعا إلى خلافِ ما جاءَ به محمدٌ ﷺ فهو من المفسدين في الأرض{6}. (٦/٤٢٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱدۡعُوهُ خَوۡفࣰا وَطَمَعًاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وادعوُهُ خوفًا وطمعًا﴾</span>، قال: خوفًا منه، وطمعًا لِما عنده{4}. (٦/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٨<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿خوفًا﴾</span> مِن النيران، <span class="qpc-hafs">﴿وطمعًا﴾</span> في الجنان{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٦٩<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿خوفا وطمعا﴾</span> كقوله: <span class="qpc-hafs">﴿رغبا ورهبا﴾</span> [الأنبياء:٩٠]{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿وادعوه خوفا وطمعا﴾</span>: خوفًا منه ومن عذابه، وطمعًا فيما عنده من مغفرته وثوابه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وادعوه خوفا﴾</span> من عذابه، <span class="qpc-hafs">﴿وطمعا﴾</span> في رحمته، فمَن فعل ذلك وهو مُحْسِن، فذلك قوله: <span class="qpc-hafs">﴿إن رحمت الله قريب من المحسنين﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٢<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span>: خوف العدل، وطمع الفضل{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَحۡمَتَ ٱللَّهِ قَرِیبࣱ مِّنَ ٱلۡمُحۡسِنِینَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّ رحمت الله قريبٌ من المحسنينَ﴾</span>، يعني: من المؤمنين، ومَن لم يؤمن بالله فهو من المفسدين{4}. (٦/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٤<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: الرحمة هاهنا: الثواب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٥<span class="dash">-</span></span> عن <span class="name-2">مطر الورّاق</span> -من طريق جعفر- قال: تَنَجَّزُوا موعودَ الله بطاعة الله؛ فإنّه قضى أنّ رحمتَه قريبٌ من المحسنين{6}. (٦/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٦<span class="dash">-</span></span> قال <span class="name-2">أبو عمرو بن العلاء</span>: القريبُ في اللغة يكون بمعنى القُرْب، وبمعنى المسافة، تقول العرب: هذه امرأة قريبة منك إذا كانت بمعنى القرابة، وقريب منك إذا كانت بمعنى المسافة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن رحمت الله قريب من المحسنين﴾</span>، يعني بالرحمة: المَطَر. يقول: الرحمة لهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٧٨<span class="dash">-</span></span> قال <span class="name-3">الكسائي</span>: <span class="qpc-hafs">﴿إن رحمت الله قريب﴾</span>: مكانها قريب، كقوله: <span class="qpc-hafs">﴿وما يُدْرِيكَ لَعَلَّ السّاعَةَ قَرِيبٌ﴾</span> [الشورى: ١٧]، أي: إتيانها قريب{8}<span class=comment-ref>٢٥٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٨</span> <span class="comment-type-3">رجّح</span> <u>ابنُ القيم</u> (١/٤٠٨-٤٠٩) <span class="mustanad">مستندًا إلى اللغة</span> في سبب الإخبار عن الرحمة -وهي مؤنثة- بقوله: <span class="qpc-hafs">﴿قريب﴾</span> -وهو مذكر-: أنّ الأصل في الآية: إنّ الله قريب من المحسنين، وإنّ رحمة الله قريبة من المحسنين. فاستغنى بذكر أحدهما عن الآخر لظهور المعنى؛ فإنّ قربَ اللهِ من المحسنين مُسْتَلْزِمٌ لقرب رحمته منهم.</p><p><span class="comment-type-4">وذكر</span> <u>ابنُ عطية</u> (٣/٥٨٣-٥٨٤) فيها <b>أقوالًا</b>، فقال: «واختلف الناسُ في وجه حذف التاء مِن <span class="qpc-hafs">﴿قريب﴾</span> في صفة الرحمة على أقوال؛ منها: أنه على جهة النسَب، أي: ذات قرب. ومنها: أنّه لما كان تأنيثها غير حقيقي جرت مجرى: كفٍّ خَضيب، ولحيةٍ دَهين. ومنها: أنها بمعنى مُذكَّر، فذُكِّر الوصف لذلك. وقال أبو عبيدة: قريب في الآية ليس بصفةٍ للرحمة، وإنما هو ظرفٌ لها وموضع، فيجيء هكذا في المؤنث والاثنين والجميع وكذلك بعيد، فإذا جعلوها صفة بمعنى: مقربة قالوا: قريبة وقريبتان وقريبات. وذكر <u>الطبريُّ</u> أن قوله: <span class="qpc-hafs">﴿قريب﴾</span> إنما يُراد به مقاربة الأرواح للأجساد، أي: عند ذلك تنالهم الرحمة».</div></p></div>",footnotes:1:تفسير البغوي ٣/٢٣٨.|2:تفسير الثعلبي ٤/٢٤٠، وتفسير البغوي ٣/٢٣٨.|3:أخرجه ابن أبي حاتم ٥/١٥٠١.|4:عزاه السيوطي إلى أبي الشيخ.|5:تفسير مقاتل بن سليمان ٢/٤٢.|6:أخرجه ابن أبي حاتم ٥/١٥٠١. وعزاه السيوطي إلى أبي الشيخ.|7:عزاه السيوطي إلى أبي الشيخ.|8:تفسير الثعلبي ٤/٢٤١.|9:تفسير الثعلبي ٤/٢٤١.|10:تفسير الثعلبي ٤/٢٤٠.|11:تفسير مقاتل بن سليمان ٢/٤٢.|12:تفسير الثعلبي ٤/٢٤١.|13:عزاه السيوطي إلى أبي الشيخ.|14:تفسير الثعلبي ٤/٢٤١، وتفسير البغوي ٣/٢٣٨.|15:أخرجه ابن أبي حاتم ٥/١٥٠١. وعزاه السيوطي إلى أبي الشيخ.|16:تفسير الثعلبي ٤/٢٤٢، وتفسير البغوي ٣/٢٣٨.|17:تفسير مقاتل بن سليمان ٢/٤٢.|18:تفسير الثعلبي ٤/٢٤١.
  7,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ بُشۡرَۢا بَیۡنَ یَدَیۡ رَحۡمَتِهِۦۖ حَتَّىٰۤ إِذَاۤ أَقَلَّتۡ سَحَابࣰا ثِقَالࣰا سُقۡنَـٰهُ لِبَلَدࣲ مَّیِّتࣲ فَأَنزَلۡنَا بِهِ ٱلۡمَاۤءَ فَأَخۡرَجۡنَا بِهِۦ مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِۚ كَذَ ٰ⁠لِكَ نُخۡرِجُ ٱلۡمَوۡتَىٰ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٥٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٧٩<span class="dash">-</span></span> عن <span class="name-2">عاصمٍ</span> أنّه قرأ: <span class="qpc-hafs">﴿وهُوَ الَّذِي يُرْسِلُ الرِّياحَ﴾</span> على الجِماع{1}<span class=comment-ref>٢٥٤٩</span>، <span class="qpc-hafs">﴿بُشْرًا﴾</span> خفيفةً، بالباءِ{2}<span class=comment-ref>٢٥٥٠</span>. (٦/٤٣٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤٩</span> قال <u>ابنُ عطية</u> (٣/٥٨٥) <span class="comment-type-4">مُعَلِّقًا</span>: «ومن جمع الريح في هذه الآية فهو أسعد، وذلك أن الرياح حيث وقعت في القرآن فهي مقترنة بالرحمة، <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿ومن آياته أن يرسل الرياح مبشرات﴾</span> [الروم:٤٥]، وقوله: <span class="qpc-hafs">﴿وأرسلنا الرياح لواقح﴾</span> [الحجر:٢٢] وغيرهما، وأكثر ذكر الريح مفردة إنما هو بقرينة عذاب، <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿وفي عاد إذ أرسلنا عليهم الريح العقيم﴾</span> [الذاريات:٤١]، وقوله: <span class="qpc-hafs">﴿وأما عاد فأهلكوا بريح صرصر عاتية﴾</span> [الحاقة:٦] وغيرهما. وفي الحديث: أنّ رسول الله ﷺ كان إذا هبَّت الريح يقول: «اللَّهُمَّ، اجعلها رياحًا، ولا تجعلها ريحًا»».</div></p><p><div><span class=comment-ref>٢٥٥٠</span> ذكر <u>ابنُ جرير</u> (١٠/٢٥٣) اختلاف القرّاء في قراءة قوله: <span class="qpc-hafs">﴿بشرا﴾</span>، ثم قال: «والصواب من القول في ذلك أن يُقال: إنّ قراءة من قرأ ذلك ‹نَشْرًا› و‹نُشُرًا› بفتح النون وسكون الشين، وبضم النون والشين، قراءتان مشهورتان في قراءة الأمصار، وأما قراءة الباء فلا أُحِبُّ القراءة بها، وإن كان لها معنًى صحيح ووجه مفهوم في المعنى والإعراب كما ذكرنا من العلة».</div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٠<span class="dash">-</span></span> عن عبد الله بن اليمانيِّ أنّه كان يقرؤها: (بُشْرى) مِن قبلِ مُبَشِّرات{3}. (٦/٤٣١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ بُشۡرَۢا بَیۡنَ یَدَیۡ رَحۡمَتِهِۦۖ حَتَّىٰۤ إِذَاۤ أَقَلَّتۡ سَحَابࣰا ثِقَالࣰا سُقۡنَـٰهُ لِبَلَدࣲ مَّیِّتࣲ فَأَنزَلۡنَا بِهِ ٱلۡمَاۤءَ فَأَخۡرَجۡنَا بِهِۦ مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿بُشرا بين يدي رحمتِه﴾</span>، قال: يَستبشِرُ بها الناسُ{4}. (٦/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في الآية، قال: إنّ الله يُرسِلُ الريحَ، فتأتي بالسَّحاب من بين الخافقين؛ طرَفِ السماء والأرض، من حيثُ يلتقيانِ، فيُخرجُه مِن ثَمَّ، ثُم ينشُرُه، فيبسُطُه في السماء كيف يشاءُ، ثم يفتحُ أبواب السماء، فيَسيلُ الماءُ على السَّحاب، ثم يُمطِرُ السَّحابُ بعدَ ذلك. وأمّا <span class="qpc-hafs">﴿رحمته﴾</span> فهو المطرُ{5}<span class=comment-ref>٢٥٥١</span>. (٦/٤٣٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٥١</span> لم يذكر <u>ابنُ جرير</u> غير هذا القول (١٠/٢٥٤).</p><p>و<span class="comment-type-4">علّق</span> عليه <u>ابنُ عطية</u> (٣/٥٨٨) قائلًا: «وهذا التفصيل لم يثبت عن النبي ﷺ».</div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهو الذي يرسل الرياح بشرا بين يدي رحمته﴾</span> يقول: الرياح نشرًا للسحاب، كقوله: <span class="qpc-hafs">﴿يرسل الرياح فتثير سحابا﴾</span> [الروم:٤٨]، يسير السحاب قدّام الرياح، <span class="qpc-hafs">﴿حتى إذا أقلت﴾</span> يعني: إذا حملت الريحُ <span class="qpc-hafs">﴿سحابا ثقالا﴾</span> من الماء <span class="qpc-hafs">﴿سقناه لبلد ميت﴾</span> ليس فيه نبات، <span class="qpc-hafs">﴿فأنزلنا به الماء فأخرجنا به﴾</span> بالماء من الأرض <span class="qpc-hafs">﴿من كل الثمرات﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نُخۡرِجُ ٱلۡمَوۡتَىٰ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٨٤<span class="dash">-</span></span> قال <span class="name-1">أبو هريرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٥<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span>: إذا مات الناسُ كلُّهم في النفخة الأولى أُمْطِر عليهم أربعين عامًا، يُسْقى الرجالُ من ماء تحت العرش يُدْعى: ماء الحيوان، فينبتون في قبورهم بذلك المطر كما ينبتون في بطون أمهاتهم، وكما ينبت الزرعُ من الماء، حتى إذا استكملت أجسادهم نُفِخ فيهم الروح، ثم يُلْقى عليهم نومة، فينامون في قبورهم، فإذا نُفِخ في الصور الثانية عاشوا وهم يجدون طعم النوم في رؤوسهم وأعينهم، كما يجد النائمُ إذا استيقظَ من نومه، فعند ذلك يقولون: <span class="qpc-hafs">﴿يا ويلنا من بعثنا من مرقدنا﴾</span>، فيناديهم المنادي: <span class="qpc-hafs">﴿هذا ما وعد الرحمن وصدق المرسلون﴾</span> [يس:٥٢]{7}<span class=comment-ref>٢٥٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٥٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٣/٥٨٨): «وقوله -تبارك وتعالى-: <span class="qpc-hafs">﴿كذلك نخرج الموتى﴾</span> يحتمل مقصدين: <b>أحدهما</b>: أن يُراد: كهذه القدرة العظيمة في إنزال الماء وإخراج الثمرات به من الأرض المجدبة هي القدرة على إحياء الموتى من الأجداث، وهذه مثال لها، <b>ويحتمل</b> أن يراد: أنّ هكذا يُصْنَع بالأموات من نزول المطر عليهم حتى يحيوا به، فيكون الكلام خبرًا لا مَثَلًا، وهذا التأويل إنما <span class="mustanad">يستند إلى الحديث</span> الذي ذكره الطبري عن أبي هريرة أنّ الناس إذا ماتوا ...». وذكر هذا الأثر.</div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كذلك نخرج الموتى﴾</span>، قال: إذا أراد اللهُ أن يُخْرِج الموتى أمْطَر السماءَ حتى تشقَّقَ الأرضُ، ثم يُرسل الأرواح، فيهوِي كلُّ رُوحٍ إلى جسده، فكذلك يُحيي اللهُ الموتى بالمطر كإحيائِه الأرضَ{8}. (٦/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿كذلك نُخرجُ الموتى﴾</span>، قال: وكذلك تُخرجُون، وكذلك النشورُ، كما يخرُجُ الزرعُ بالماءِ{9}. (٦/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿نخرج﴾</span> يُخْرِج اللهُ <span class="qpc-hafs">﴿الموتى﴾</span> من الأرض بالماء، كما أخرج النبات من الأرض بالماء؛ <span class="qpc-hafs">﴿لعلكم﴾</span> يعني: لكي <span class="qpc-hafs">﴿تذكرون﴾</span>، فتعتبروا في البعث أنّه كائن. نظيرها في الروم، والملائكة{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نُخۡرِجُ ٱلۡمَوۡتَىٰ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٥٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٩٨٩<span class="dash">-</span></span> عن خالد بن يزيد [بن معاوية] -من طريق سيار- أنه كان عند عبد الملك بن مروان، فذكروا الماء، فقال <span class="name-2">خالد بن يزيد</span>: منه مِن السماء، ومنه مِمّا يسقيه الغيم من البحر فيعذبه الرعد والبرق، وأمّا ما كان من البحر فلا يكون له نبات، وأمّا النَّبات فمِمّا كان من السماء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٩٩٠<span class="dash">-</span></span> قال <span class="name-3">أبو بكر بن عياش</span>: لا تَقْطُر من السماء قطرةٌ حتى يُعْمِل فيها أربعٌ: رياح الصَّبا تُهَيِّجُهُ، والشمال تَجمعه، والجنوب تُدِرُّهُ، والدَّبُور تُفَرِّقُهُ{12}. (ز)</p></p><p></div></p></div>",footnotes:1:قرأ نافع، وأبو جعفر، وأبو عمرو، ويعقوب، وابن عامر، وعاصم بالجمع، وقرأ بقية العشرة: ‹الرِّيحَ› بالإفراد. النشر ٢/٢٢٣، والإتحاف ص١٩٦.|2:علَّقه ابن جرير ١٠/٢٥٢. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن أبي حاتم ٥/١٥٠٢.</p><p>وهي قراءة شاذة، تروى أيضًا عن محمد بن السَّميفع، وابن قطيب. انظر: المحتسب ١/١٥٥.|4:أخرجه ابن أبي حاتم ٥/١٥٠٢. وعزاه السيوطي إلى أبي الشيخ.|5:أخرجه ابن جرير ١٠/٢٥٤، وابن أبي حاتم ٥/١٥٠١. وعزاه السيوطي إلى أبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٤٢.|7:تفسير الثعلبي ٤/٢٤٣. وعلَّق ابنُ جرير ١٠/٢٥٥-٢٥٦ نحوه.|8:تفسير مجاهد ص٣٣٨ مختصرًا، وأخرجه ابن جرير ١٠/٢٥٦، وابن أبي حاتم ٥/١٥٠٣ مختصرًا. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، أبي الشيخ.|9:أخرجه ابن جرير ١٠/٢٥٥، وابن أبي حاتم ٥/١٥٠٣.|10:تفسير مقاتل بن سليمان ٢/٤٢. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿ويُنَزِّلُ مِنَ السَّماءِ ماءً فَيُحْيِي بِهِ الأَرْضَ بَعْدَ مَوْتِها إنَّ فِي ذَلِكَ لَآياتٍ لِقَوْمٍ يَعْقِلُونَ (٢٤)﴾</span>، وقوله تعالى: <span class="qpc-hafs">﴿واللَّهُ الَّذِي أرْسَلَ الرِّياحَ فَتُثِيرُ سَحابًا فَسُقْناهُ إلى بَلَدٍ مَيِّتٍ فَأَحْيَيْنا بِهِ الأَرْضَ بَعْدَ مَوْتِها كَذَلِكَ النُّشُورُ﴾</span> [فاطر:٩].|11:أخرجه ابن أبي حاتم ٥/١٥٠٢.|12:تفسير الثعلبي ٤/٢٤٢-٢٤٣.