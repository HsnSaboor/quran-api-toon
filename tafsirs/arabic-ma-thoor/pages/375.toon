quran[23]{c,v,t}:
  26,184,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱتَّقُوا۟ ٱلَّذِی خَلَقَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿الذي خلقكم﴾</span> وخلق الذين مِن قبلكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتقوا﴾</span> يقول: واخْشَوْا أن يُعَذِّبكم في الدنيا <span class="qpc-hafs">﴿الذي خلقكم و﴾</span>خلق <span class="qpc-hafs">﴿الجبلة الأولين﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِینَ ۝١٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والجبلة الأولين﴾</span>، قال: خَلْقَ الأولين{3}. (١١/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿واتقوا الذي خلقكم والجبلة﴾</span>: يعني: وخلق الجبلة <span class="qpc-hafs">﴿الأولين﴾</span> يعني: القرون الأولين الذين أُهْلِكوا بالمعاصي، ولا تهلكوا مثلهم{4}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والجبلة الأولين﴾</span>، قال: الخَلِيقَة{5}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>خلق <span class="qpc-hafs">﴿الجِبِلَّة﴾</span> يعني: الخليقة <span class="qpc-hafs">﴿الأولين﴾</span> يعني: الأمم الخالية الذين عُذِّبوا في الدنيا؛ قوم نوح، وصالح، وقوم لوط{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والجبلة الأولين﴾</span>، قال: الخَلْق الأولين. الجِبِلَّة: الخَلْقُ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿واتقوا الذي خلقكم والجبلة الأولين﴾</span>، قال: خَلْق الأولين. ثم قرأ: <span class="qpc-hafs">﴿ولقد أضل منكم جبلا كثيرا﴾</span> [يس:٦٢]{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨١٣.|2:تفسير مقاتل بن سليمان ٣/٢٧٨.|3:أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٣. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.|5:أخرجه ابن جرير ١٧/٦٣٥، وإسحاق البستي في تفسيره ص٥٤٠ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٣. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٣/٢٧٨.|7:أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٣ من طريق أصبغ.|8:أخرجه إسحاق البستي في تفسيره ص٥٤١، وابن أبي حاتم ٩/٢٨١٣.
  26,185,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span>: يعني: مِن المخلوقين{1}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span> يعني: أنت بشر مثلنا، لست بملك، ولا رسول، فذلك قوله سبحانه: <span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.|2:تفسير مقاتل بن سليمان ٣/٢٧٩. وتقدمت آثار السلف في تفسيرها عند قوله تعالى: <span class="qpc-hafs">﴿قالُوا إنَّما أنْتَ مِنَ المُسَحَّرِينَ (١٥٣)﴾</span> [الشعراء:١٥٣].
  26,186,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنتَ إِلَّا بَشَرࣱ مِّثۡلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلۡكَـٰذِبِینَ ۝١٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا﴾</span> لا تفضلنا في شيء فنتبعك، <span class="qpc-hafs">﴿وإن نظنك﴾</span> يقول: وقد نحسبك -يا شعيب- <span class="qpc-hafs">﴿لمن الكاذبين﴾</span> يعني: حين تزعم أنّك نبيٌّ رسول{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا وإن نظنك لمن الكاذبين﴾</span> فيما تَدَّعي مِن الرسالة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.|2:تفسير يحيى بن سلّام ٢/٥٢٢.
  26,187,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَسۡقِطۡ عَلَیۡنَا كِسَفࣰا مِّنَ ٱلسَّمَاۤءِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿كسفا﴾</span>، يقول: قِطَعًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء﴾</span>: يعني: قِطَعًا من السماء{2}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٦٩<span class="dash">-</span></span> عن عبيد، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿كسفا من السماء﴾</span>: جانبًا من السماء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء﴾</span>، قال: قِطَعًا من السماء{4}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿كسفا من السماء﴾</span>، يقول: عذابًا مِن السماء{5}<span class=comment-ref>٤٨٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٠/٣٦٨) على قول الضحاك، وقتادة، والسدي بقوله: «وهذا شبيه بما قالت قريش فيما أخبر الله عنهم في قوله تعالى: <span class="qpc-hafs">﴿وقالُوا لَنْ نُؤْمِنَ لَكَ حَتّى تَفْجُرَ لَنا مِنَ الأرْضِ يَنْبُوعًا﴾</span> إلى أن قالوا: <span class="qpc-hafs">﴿أوْ تُسْقِطَ السَّماءَ كَما زَعَمْتَ عَلَيْنا كِسَفًا أوْ تَأْتِيَ بِاللَّهِ والمَلائِكَةِ قَبِيلا﴾</span> [الإسراء:٩٠-٩٢]، وقوله: <span class="qpc-hafs">﴿وإذْ قالُوا اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</span> [الأنفال:٣٢]، وهكذا قال هؤلاء الكفرة الجهلة: <span class="qpc-hafs">﴿فَأَسْقِطْ عَلَيْنا كِسَفًا مِنَ السَّماءِ إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأسقط علينا كسفا﴾</span> يعني: جانبًا <span class="qpc-hafs">﴿من السماء إن كنت من الصادقين﴾</span> بأنّ العذاب نازل بنا؛ لقوله في هود [٨٤]: <span class="qpc-hafs">﴿وإني أخاف عليكم عذاب يوم محيط﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء﴾</span>، قال: ناحية من السماء، عذابٌ، ذلك الكِسَفُ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن كنت من الصادقين﴾</span> بما جئت به{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦٣٦.|2:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.|3:أخرجه ابن جرير ١٧/٦٣٦، وإسحاق البستي في تفسيره ص٥٤١، وابن أبي حاتم ٩/٢٨١٤.|4:أخرجه ابن أبي حاتم ٩/٢٨١٤. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن أبي حاتم ٩/٢٨١٤.|6:تفسير مقاتل بن سليمان ٣/٢٧٩.|7:أخرجه ابن جرير ١٧/٦٣٦.|8:تفسير يحيى بن سلّام ٢/٥٢٢.
  26,188,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّیۤ أَعۡلَمُ بِمَا تَعۡمَلُونَ ۝١٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> شعيب: <span class="qpc-hafs">﴿ربي أعلم﴾</span> مِن غيره <span class="qpc-hafs">﴿بما تعملون﴾</span> مِن نقصان الكيل والميزان{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.
  26,189,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَذَّبُوهُ فَأَخَذَهُمۡ عَذَابُ یَوۡمِ ٱلظُّلَّةِۚ إِنَّهُۥ كَانَ عَذَابَ یَوۡمٍ عَظِیمٍ ۝١٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٧٦<span class="dash">-</span></span> عن قتادة، قال: قال <span class="name-1">عبد الله بن عمرو بن العاص</span>: تدرون كيف كان أمرُ أصحاب الأيكة؟ قالوا: الله أعلم. قال: كان أمرهم أنّ الله سلَّط عليهم الحرَّ سبعة أيام، حتى ما يُظِلُّهم منه شيء، ثم إنّ الله أنشا لهم سحابةً، فانطلق إليها أحدُهم، فاسْتَظَلَّ بها، فأصاب تحتها بردًا وراحة، فأعلم بذلك قومه، فأتوا جميعًا، فاسْتَظَلُّوا تحتها، فأجَّجَتْ عليهم نارًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٧<span class="dash">-</span></span> قال قتادة: فحدثنا <span class="name-2">شهر بن حوشب</span>: أنّه رأى مكانهم، وأنه لا يذكر منهم إلا كموضع المِسَلَّة{1}، صاروا رمادًا، قال الله ﷿: <span class="qpc-hafs">﴿إنه كان عذاب يوم عظيم﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الشعبي- قال: مَن حدَّثك مِن العلماء ما عذابُ يوم الظلة فكذِّبه{3}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٧٩<span class="dash">-</span></span> عن يزيد الباهلي، قال: سألتُ <span class="name-1">عبد الله بن عباس</span> عن قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>. فقال: بعث الله عليهم ومَدَة{4}، وحرًّا شديدًا، فأخذ بأنفاسهم، فدخلوا أجواف البيوت، فدخل عليهم أجواف البيوت، فأخذ بأنفاسهم، فخرجوا مِن البيوت هرابًا إلى البرية، فبعث الله عليهم سحابة، فأظلَّتهم مِن الشمس، فوجدوا لها بردًا ولَذَّة، فنادى بعضُهم بعضًا، حتى إذا اجتمعوا تحتها أسقطها اللهُ عليهم نارًا، فذلك عذاب يوم الظلة{5}. (١١/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>: أرسل الله عليهم سَمُومًا مِن جهنم، فأطاف بهم سبعة أيام، حتى أنضجهم الحرُّ، فحميت بيوتهم، وغَلَتْ مياهُهم في الآبار والعيون، فخرجوا مِن منازلهم ومحلتهم هاربين، والسموم معهم، فسلط الله عليهم الشمسَ مِن فوق رؤوسهم، فتغشتهم حتى تفَلَّقت فيها جماجمهم، وسلَّط الله عليهم الرَّمضاء مِن تحت أرجلهم، حتى تساقطت لحومُ أرجلهم، ثم أنشئت لهم ظلة كالسحابة السوداء، فلمّا رأوها ابتدروها يستغيثون بظِلِّها، حتى إذا كانوا تحتها جميعًا أطبقت عليهم، فهلكوا، ونَجّى الله شعيبًا والذين آمنوا معه{6}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨١<span class="dash">-</span></span> عن <span class="name-2">علقمة</span> -من طريق زيد بن معاوية- <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: أصابهم الحرُّ، حتى أقلعهم من بيوتهم، فخرجوا، ورُفِعَت لهم سحابةٌ، فانطلقوا إليها، فلمّا استظلوا بها أرسلت إليهم، فلم ينفلِت منهم أحدٌ{7}. (١١/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن معاوية</span> -من طريق أبي إسحاق السبيعي- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: أصابهم حرٌّ أقلقهم مِن بيوتهم، فنشأت لهم سحابةٌ كهيئة الظُّلَّة، فابتدروها، فلما تَتامُّوا تحتها أخذتهم الرجفة{8}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قول الله: <span class="qpc-hafs">﴿عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</span>، قال: كانت الظلة سحابةً، وكانوا يحفرون الأسراب{9}، يدخلونها، فيَتَبَرَّدون بها، فإذا دخلوها وجدوها أشدَّ حرًّا مِن ظَهْرِها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: ظلل العذاب إيّاهم{11}. (١١/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: قوم شعيب، حبس الله عنهم الظل والريح، فأصابهم حرٌّ شديد، ثم بعث الله لهم سحابةً فيها العذاب، فلمّا رأوا السحابة انطلقوا يَؤُمُّونها -زعموا- يستظلون، فاضطرمت عليهم نارًا، فأهلكتهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جويبر- في قوله ﷿: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: الأيكة: الغيضة، أهلكهم ﷿ فيها، لَمّا أراد الله تعالى هلاكهم أرسل عليهم حرًّا شديدًا، حتى امتنع منهم طلاع البيوت والشراب{13}، وبعث الله سحابةً، فعامت على الغَيْضَة، فلمّا رأوها حسُّوا أنّ لها ظِلًّا، فدخلوا، فلما تتامُّوا تحتها أرسل الله عليهم نارًا، فأحرقهم، فذلك قوله ﷿: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ميسرة- في قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>، قال: الظلة فيها نار نزلت من السماء، فلمّا رأت الأرضُ ذلك أشفقت، وظنَّت أن إيّاها يُراد، فائتَفَكَتْ{15}، فكانت الأفكة{16} بقوم شعيب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الوليد بن حسان- قال: سلَّط اللهُ الحرَّ على قوم شعيب سبعة أيام ولياليهن، حتى كانوا لا ينتفعون بظلِّ بيت، ولا ببرد ماء، ثم رُفِعَت لهم سحابةٌ في البَرِّيَّة، فوجدوا تحتها الرَّوح، فجعل يدْعُو بعضُهم بعضًا، حتى إذا اجتمعوا تحتها أشعلها الله عليهم نارًا، فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>{18}. (١١/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٨٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر- قال: إنّ أهل مدين عُذِّبوا بثلاثة أصناف من العذاب: أخذتهم الرجفة في دارهم حتى خرجوا منها، فلما خرجوا منها أصابهم فزع شديد، ففرقوا أن يدخلوا البيوت أن تسقط عليهم، فأرسل الله عليهم الظلة، فدخل تحتها رجل، قال: ما رأيت كاليوم ظِلًّا أطيب، ولا أبرد، هلمُّوا، أيها الناس. فدخلوا جميعًا تحت الظلة، فصاح فيهم صيحة واحدة، فماتوا جميعًا{19}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: ذُكِر لنا: أنّه سلط الله عليهم الحرَّ سبعة أيام، لا يُظِلُّهم ظل، ولا ينفعهم منه شيء، فبعث الله عليهم سحابة، فلجُّوا إليها يلتمسون الرَّوح في ظلها، فجعلها الله عليهم عذابًا، فأحرقتهم، بعثت عليهم نارًا، فاضطرمت، فأكلتهم، فذلك عذاب يوم الظلة{20}. (١١/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق جرير بن حازم- قال: بعث شعيب إلى أمتين: إلى قومه أهل مدين، وإلى أصحاب الأيكة. وكانت الأيكة مِن شجر ملتف، فلما أراد الله أن يُعَذِّبهم بعث الله عليهم حرًّا شديدًا، ورفع لهم العذابَ كأنه سحابة، فلما دنت منهم خرجوا إليها رجاءَ بردها، فلما كانوا تحتها مطرت عليهم نارًا. قال: فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: بعث الله شعيبًا إلى أصحاب الأيكة، والأيكة: غيضة، فكذبوه، فأخذهم عذاب يوم الظلة. قال: فتح الله عليهم بابًا مِن أبواب جهنم، فغشيهم مِن حرِّه ما لم يُطيقوه، فتَغَوَّثوا بالماء وبما قدروا عليه، فبينما هم كذلك إذا رُفِعت لهم سحابةٌ فيها ريح باردة طيبة، فلمّا وجدوا بردها –الظلة- تنادوا: عليكم الظلة. فأتوها يتغوثون بها، فخرجوا من كل شيء كانوا فيه، فلما تكاملوا تحتها طبقت عليهم بالعذاب، فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>{22}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٣<span class="dash">-</span></span> عن <span class="name-2">منصور [بن المعتمر]</span> -من طريق محمد بن جابر- <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>، قال: بعث الله عليهم سحابة تنضح عليهم بالنار{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق مالك- قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>، قال: صارت الغمام عليهم نارًا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق داود بن قيس الفراء- قال: كان ينهاهم عن قطع الدراهم، فأخذهم عذاب يوم الظلة، حتى إذا اجتمعوا كلهم كشف الله عنهم الظلة، وأحمى عليهم الشمس، فاحترقوا كما يحترق الجراد في المقلى{25}. (١١/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٦<span class="dash">-</span></span> عن <span class="name-3">جعفر [بن محمد بن علي]</span> -من طريق يعقوب- في قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>، قال: كانوا يحفرون الأسراب لِيَتَبَرَّدوا فيها، فإذا دخلوها وجدوها أشدَّ حرًا مِن الظاهر، وكانت الظلة سحابة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكذبوه﴾</span> بالعذاب، <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span> وذلك أنّ الله ﷿ كان حبس عنهم الريح والظل، فأصابهم حر شديد، فخرجوا من منازلهم، فرفع الله ﷿ سحابةً فيها عذاب بعد ما أصابهم الحر سبعة أيام، فانقلبوا ليستظلوا تحتها، فأهلكهم الله ﷿ حرًّا وغمًّا تحت السحابة، فذلك قوله ﷿: <span class="qpc-hafs">﴿إنه كان عذاب يوم عظيم﴾</span> لشدته{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٨<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج-: لما أنزل الله عليهم أول العذاب أخذهم منه حر شديد، فرفع الله لهم غمامة، فخرج إليها طائفة منهم ليستظلُّوا بها، فأصابهم منها رَوح وبرد وريح طيبة، فصبَّ الله عليهم من فوقهم من تلك الغمامة عذابًا، فذلك قوله: <span class="qpc-hafs">﴿عذاب يوم الظلة﴾</span>{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٩٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة، إنه كان عذاب يوم عظيم﴾</span>، قال: بعث الله إليهم ظُلَّة مِن سحاب، وبعث إلى الشمس، فأحرقت ما على وجه الأرض، فخرجوا كلهم إلى تلك الظُّلَّة، حتى إذا اجتمعوا كلُّهم كشف الله عنهم الظلة، وأحمى عليهم الشمس، فاحترقوا كما يحترق الجراد في المقلى{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٠<span class="dash">-</span></span> عن أبي نضرة العبدي، قال: حدَّثنا رجلٌ من الصدر الأول، قال: كان قوم شعيب يقتلون على الكِذْبَة فما فوقها، فكانوا إذ يصنعون ذلك عيشُهم فيه شِدَّة. قال: حتى أصاب بعضُ ملوكهم ذنبًا، فعُطِّل الحد. قال: حتى أباحوا [الخمر] نهارًا جهارًا في المجالس. قال: فبسط الله لهم الرزق عند ذلك، حتى قال قائل: لو سعرناه كنا قد عطلناها منذ زمان. قال: فلما أراد الله عقوبتهم بعث عليهم حرًّا شديدًا. قال: فلم ينفعهم بيتٌ، ولا ظِلٌّ، ولا شيء. قال: فانطلقوا يرتادون الرَّوْح والبَرْد. قال: فدخل داخل منهم الظُّلَّة، فوجدها باردة، فأذَّن في الناس: البردَ البردَ. فلما تَتامُّوا تحتها قذفها الله عليهم، فذلك قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</span>{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فأخذهم عذاب يوم الظلة﴾</span>: يعني: تلك السحابة{31}. (ز)</p></p><p></div></p></div>",footnotes:1:المِسَلَّة: الإبرة العظيمة. مختار الصحاح (سلل).|2:أخرجه ابن أبي حاتم ٩/٢٨١٥.|3:أخرجه ابن جرير ١٧/٦٣٩، وابن أبي حاتم ٩/٢٨١٥، والحاكم ٢/٥٦٩.|4:الوَمَد والوَمَدَة: ندًى يجيء في صميم الحر مِن قِبَل البحر مع سكون ريح، وهو ما يُعَبَّر عنه اليوم بالرطوبة. اللسان والمعجم الوسيط (ومد).|5:أخرجه ابن جرير ١٧/٦٣٨، وابن أبي حاتم ٩/٢٨١٤-٢٨١٥، والحاكم ٢/٥٦٨-٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.|7:أخرجه ابن أبي الدنيا في العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧ (١٨٧)-. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ١٧/٦٣٧، وإسحاق البستي في تفسيره ص٥٤١. وعزاه السيوطي إلى الفريابي بلفظ: فأنشئت لهم سحابة، فأتوها، فصيح بهم فيها.|9:الأسراب: جمع سَرَب، وهو حفير تحت الأرض، وقيل: بيت تحت الأرض. لسان العرب (سرب).|10:أخرجه ابن أبي حاتم ٩/٢٨١٦.|11:أخرج الفريابي -كما في فتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦٣٨-٦٣٩، وابن أبي حاتم ٩/٢٨١٦، والحاكم ٢/٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وفي تفسير مجاهد ص٥١٣ بلفظ: يعني: ظل العذاب الذي أتاهم.|12:أخرجه ابن جرير ١٧/٦٤٠، وإسحاق البستي في تفسيره ص٥٤٢.|13:يوضح هذه العبارةَ قولُ ابن عباس من طريق الضحاك: فحميت بيوتهم، وغلت مياههم.|14:أخرجه ابن عساكر ٢٣/٧٤.|15:ائتفكت: انقلبت. النهاية (أفك).|16:الأفكة: العذاب. النهاية (أفك).|17:أخرجه ابن أبي حاتم ٩/٢٨١٦.|18:أخرجه ابن أبي حاتم ٩/٢٨١٦، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧-٤٧٨ (١٨٨)-. وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن أبي حاتم ٩/٢٨١٥. وعزاه السيوطي إلى ابن المنذر.|20:أخرجه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد. وتقدم أنّ ابن أبي حاتم ٩/٢٨١٥ أخرجه من قول عبد الله بن عمرو.|21:أخرجه ابن جرير ١٧/٦٣٧ واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|22:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٣)-. وعزاه السيوطي إلى ابن المنذر.|23:أخرجه ابن أبي حاتم ٩/٢٨١٥، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٤)-.|24:أخرجه ابن عساكر في تاريخ دمشق ٢٣/٧٨.|25:أخرجه الحاكم ٢/٥٦٩.|26:أخرجه ابن جرير ١٧/٦٣٧.|27:تفسير مقاتل بن سليمان ٣/٢٧٩.|28:أخرجه ابن جرير ١٧/٦٣٩.|29:أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٧ مختصرًا من طريق أصبغ.|30:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧ (١٨٦)-، وابن أبي حاتم ٩/٢٨١٦، وأخرج نحوه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦٣٩، وابن أبي حاتم ٩/٢٨١٧ عن معمر بن راشد، عن رجل من أصحابه، عن بعض العلماء.|31:تفسير يحيى بن سلّام ٢/٥٢٣.
  26,190,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٩٠ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> إنّ في هلاكهم بالحر والغم لعبرة لمن بعدهم، يُحَذِّر كُفّار مكة أمة محمد ﷺ، ثم قال ﷿: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> يعني: لو كان أكثرهم مؤمنين ما عذبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته من أعدائه، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إن في ذلك لآية وما كان أكثرهم مؤمنين (١٩٠) وإن ربك لهو العزيز الرحيم (١٩١)﴾</span> وهي مثل الأولى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.|2:تفسير يحيى بن سلّام ٢/٥٢٣.
  26,191,""
  26,192,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَتَنزِیلُ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٩٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن سلام</span>، قال: كان نفر مِن قريش مِن أهل مكة قدموا على قوم مِن يهود مِن بني قريظة لبعض حوائجهم، فسمعوهم يقرأون التوراة، فقال القُرَشِيُّون: ماذا نلقى مِمَّن يقرأ توراتكم هذه؟ لَهؤلاء أشدُّ علينا من محمد وأصحابه. فقال اليهود: نحن مِن أولئك برآء، وأولئك يكذبون على التوراة، وما أنزل الله في الكتب، إنما أرادوا عَرَض الدنيا. فقال القرشيون: فإذا لقيتموهم فسَوِّدوا وجوههم. وقال المنافقون: لا يُعلِّمه إلا بشرٌ مثله. وأنزل الله: <span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span> إلى قوله: <span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span>، يعني: النبي ﷺ، وصفته، ونعته، وأمره{1}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span>، وذلك أنّه لَمّا قال كفار مكة: إنّ محمدًا ﷺ يتعلم القرآن مِن أبي فكيهة، ويجيء به الري -وهو شيطان-، فيلقيه على لسان محمد ﷺ. فأكذبهم الله تعالى، فقال ﷿: <span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَتَنزِیلُ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٩٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span>، قال: هذا القرآن{3}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span>، يعني: القرآن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل</span>، في قوله: <span class="qpc-hafs">﴿وإنه﴾</span>، قال: ذِكْر محمد ﷺ، ونعته{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span>، يعني: القرآن{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:تفسير مقاتل بن سليمان ٣/٢٧٩.|3:أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤١-٦٤٢، وابن أبي حاتم ٩/٢٨١٧. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٣/٢٧٩.|5:تفسير الثعلبي ٧/١٨٠، وتفسير البغوي ٦/١٢٩.|6:تفسير يحيى بن سلّام ٢/٥٢٣.
  26,193,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِینُ ۝١٩٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥١٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد، وإسماعيل- أنّه قرأ: ‹نَزَّل بِهِ› يثقلها، ‹الرُّوحَ الأَمِينَ›{1}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١١<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: ‹نَزَّل بِهِ› مثقلة، ‹الرُّوحَ الأَمِينَ› منصوبتان{2}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٢<span class="dash">-</span></span> عن <span class="name-2">الأعرج</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٣<span class="dash">-</span></span> و<span class="name-2">أبي عمرو</span> -من طريق هارون-: <span class="qpc-hafs">﴿نَزَلَ بِهِ الرُّوحُ الأَمِينُ﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٤<span class="dash">-</span></span> وتفسير <span class="name-2">قتادة</span>: <span class="qpc-hafs">﴿نَزَلَ بِهِ الرُّوحُ الأَمِينُ﴾</span> مخففة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِینُ ۝١٩٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥١٥<span class="dash">-</span></span> عن ابن عباس، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿نزل به الروح الأمين﴾</span>، قال: «<b>الروح الأمين جبريل، رأيت له ستمائة جناح مِن لؤلؤ، قد نشرها فيها مثل ريش الطَّواويس</b>»{4}. (١١/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿نزل به الروح الأمين﴾</span>، قال: الروح الأمين: جبريل{5}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٧<span class="dash">-</span></span> عن عبيد، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿الروح الأمين﴾</span>، قال: جبريل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد، وإسماعيل- أنّه قرأ: ‹نزَّل بِهِ› يثقلها، ‹الرُّوحَ الأمينَ› يقول: نزَّل اللهُ جبريل{7}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥١٩<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق إدريس- <span class="qpc-hafs">﴿الروح الأمين﴾</span>، قال: جبريل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، قال: <span class="qpc-hafs">﴿الروح الأمين﴾</span> جبريل{9}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿نزل به الروح الأمين﴾</span>، قال: جبريل{10}. (١١/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٢<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق عقيل، وبنحوه من طريق يونس بن يزيد- قال: قد بيَّن اللهُ لنا في كتابه أنه يرسل جبريلَ إلى محمد نبينا ﷺ، فقال الله ﷿: <span class="qpc-hafs">﴿قُلْ مَن كانَ عَدُوًّا لِجِبْرِيلَ فَإنَّهُ نَزَّلَهُ عَلى قَلْبِكَ بِإذْنِ اللَّهِ﴾</span> [البقرة:٩٧]، وذكر الله الروح الأمين، فقال: <span class="qpc-hafs">﴿وانه لتنزيل رب العالمين نزل به الروح الامين على قلبك لتكون من المنذرين﴾</span> يعني: جبريل ﵇{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿الروح الأمين﴾</span>: هو جبريل{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نزل به الروح الأمين﴾</span>، يعني: جبريل ﵇، أمين فيما استودعه الله ﷿ مِن الرسالة إلى الأنبياء ﵈{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- قال: <span class="qpc-hafs">﴿الروح الأمين﴾</span> جبريل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿نزل به﴾</span> يعني: القرآن ... وهي تُقرأ على وجهين، بالرفع والنصب، فمن قرأها بالرفع قال: <span class="qpc-hafs">﴿نَزَلَ به﴾</span> خفيفة <span class="qpc-hafs">﴿الروح الأمين﴾</span> جبريل نزل به. ومَن قرأها بالنصب قال: ‹نَزَّلَ بِهِ› مثقلة، الله نزَّل به <span class="qpc-hafs">﴿الرُّوحَ الأمينَ﴾</span>، الله نزَّل جبريل بالقرآن{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِینُ ۝١٩٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٢٧<span class="dash">-</span></span> عن الحسن، أظنُّه عن سعد، قال: قال النبي ﷺ: «<b>ألا وإنّ الروح الأمين نفث في رُوعي أنه لن تموت نفس حتى تستكمل رزقها، وإن أبطأ عنها</b>»{16}. (١١/٢٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٨<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>أيُّها الناس، إنّه ليس مِن شيء يُقَرِّبكم مِن الجنة ويبعدكم من النار إلا قد أمرتكم به، وليس شيء يقربكم من النار ويبعدكم من الجنة إلا قد نهيتكم عنه، وإنّ الروح الأمين نفث في روعي أنّه ليس مِن نفس تموت حتى تستوفي رزقها، فاتقوا الله، وأَجْمِلُوا في الطَّلَب، ولا يَحْمِلَنَّكم استبطاءُ الرزق على أن تطلبوه بمعاصي الله، فإنه لا ينال ما عند الله إلا بطاعته</b>»{17}. (١١/٢٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: مَن كلَّمه الروحُ الأمينُ لم تأكله الأرض{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨١٧.</p><p>وهي قراءة متواترة، قرأ بها يعقوب، وابن عامر، وحمزة، والكسائي، وخلف العاشر، وأبو بكر. وقرأ بقية العشرة: <span class="qpc-hafs">﴿نَزَلَ بِهِ الرُّوحُ الأَمِينُ﴾</span> بتخفيف الزاي، ورفعهما. انظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٤.|2:عزاه السيوطي إلى عبد بن حُمَيد.|3:أخرجه إسحاق البستي في تفسيره ص٥٤٢.|4:أخرجه أبو الشيخ في كتاب العظمة ٢/٨٠١. وعزاه السيوطي إلى ابن مردويه.</p><p>رجال إسناده ثقات، سوى محمد بن سليمان البصري، قال عنه أبو حاتم كما في الجرح والتعديل ٧/٢٦٨: «شيخ».|5:أخرجه ابن جرير ١٧/٦٤٢.|6:أخرجه ابن جرير ١٧/٦٤٢، وإسحاق البستي في تفسيره ص٥٤٢. وعلَّقه ابن أبي حاتم ٩/٢٨١٧.|7:أخرجه ابن أبي حاتم ٩/٢٨١٧.|8:أخرجه ابن أبي حاتم ٩/٢٨١٧.|9:علَّقه ابن أبي حاتم ٩/٢٨١٧. وعزاه السيوطي إلى عبد بن حميد.|10:أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤١-٦٤٢، وابن أبي حاتم ٩/٢٨١٧. وعلَّقه يحيى بن سلّام ٢/٥٢٣. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن أبي حاتم ٩/٢٨١٨.|12:علَّقه يحيى بن سلّام ٢/٥٢٣.|13:تفسير مقاتل بن سليمان ٣/٢٧٩.|14:أخرجه ابن جرير ١٧/٦٤٢، وابن أبي حاتم ٩/٢٨١٧.|15:تفسير يحيى بن سلّام ٢/٥٢٣.|16:أخرجه ابن بشران في أماليه ٢/٢٣٢ (١٤١١) مطولًا. وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ثقات، لكن فيه سليمان الأعمش يُدَلِّس كما في التقريب (٢٦١٥)، وقد عنعن.|17:أخرجه ابن أبي شيبة ٧/٧٩ (٣٤٣٣٢) واللفظ له، والحاكم ٢/٥ (٢١٣٦)، والبغوي في تفسيره ٦/٢٥٤.</p><p>قال الدارقطني في العلل ٥/٢٧٣ (٨٧٥): «يرويه إسماعيل بن أبي خالد، واختُلِف عنه؛ فقال هبيرة التمار أبو عمر المقري: عن هشيم، عن إسماعيل، عن زبيد، عن مرة، عن عبد الله. وغيره يرويه عن إسماعيل، عن زبيد مرسلًا، عن ابن مسعود. وهذا أصح». وقال البوصيري في إتحاف الخيرة ٣/٢٧٠ (٢٧٢٢/١) في رواية ابن راهويه: «فيه انقطاع». وقال فيه ٣/٢٧١ (٢٧٢٢/٣): «ورواه الحاكم في المستدرك، وله شاهد من حديث حذيفة، رواه البزار في مسنده. ورواه الطبراني في الكبير من حديث الحسن بن علي. ورواه ابن ماجه والحاكم والبيهقي في سننه الكبرى من حديث جابر بن عبد الله». وقال الألباني في الصحيحة ٦/٨٦٥-٨٦٧ (٢٨٦٦): «وبالجملة فحديث حسن على أقل الأحوال».|18:أخرجه ابن أبي حاتم ٩/٢٨١٨.
  26,194,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَىٰ قَلۡبِكَ لِتَكُونَ مِنَ ٱلۡمُنذِرِینَ ۝١٩٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزله <span class="qpc-hafs">﴿على قلبك﴾</span> ليثبت به قلبك، يا محمد؛ <span class="qpc-hafs">﴿لتكون من المنذرين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿على قلبك﴾</span> يا محمد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.|2:تفسير يحيى بن سلّام ٢/٥٢٤.
  26,195,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بِلِسَانٍ عَرَبِیࣲّ مُّبِینࣲ ۝١٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٣٢<span class="dash">-</span></span> عن <span class="name-1">بريدة [بن الحصيب]</span>، في قوله: <span class="qpc-hafs">﴿بلسان عربي مبين﴾</span>، قال: بلسان جُرْهُم{1}. (١١/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن بريدة</span> -من طريق حسين بن واقد-، مثله{2}. (١١/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قول الله تعالى: <span class="qpc-hafs">﴿بلسان عربي مبين﴾</span>، قال: بلسان قريش، ولو كان غير عربيٍّ ما فهِموه، وما أنزل الله مِن السماء كتابًا إلا بالعبرانية{3}. (١١/٢٩٨) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- قال: نزل القرآن بلسان قريش، ولسان خزاعة، وذلك أنّ الدار واحدة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سيف المالكي- في قوله: <span class="qpc-hafs">﴿بلسان عربي مبين﴾</span>، قال: بلسان قريش{5}. (١١/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أنزله <span class="qpc-hafs">﴿بلسان عربي مبين﴾</span>؛ ليفقهوا ما فيه، [لقولهم]: إنما يعلمه أبو فَكِيهَة. وكان أبو فكيهة أعجميًّا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٣٨<span class="dash">-</span></span> عن الهذيل، عن رجل، عن الفضيل بن عيسى الرقاشي، قال: <span class="qpc-hafs">﴿بلسان عربي مبين﴾</span>، قال: فضله على الألْسُن{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِلِسَانٍ عَرَبِیࣲّ مُّبِینࣲ ۝١٩٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٣٩<span class="dash">-</span></span> عن موسى بن محمد بن إبراهيم التميمي، عن أبيه، قال: بينما رسولُ الله ﷺ مع أصحابه في يوم دَجَنٍ{8}، إذ قال لهم رسول الله ﷺ: «<b>كيف ترون بَواسِقَها</b>{9}؟». قالوا: ما أحسنَها وأشدَّ تراكمها. قال: <b>«فكيف ترون قواعدها؟</b>». قالوا: ما أحسنَها وأشدَّ تَمَكُّنِها. قال: <b>«كيف ترون جَوْنَها؟</b>». قالوا: ما أحسنَه وأشدَّ سواده. قال: <b>«فكيف ترون رَحاها استدارت؟</b>». قالوا: نعم، ما أحسنها وأشد استدارتها. قال: <b>«كيف ترون برقها خفوًا، أو وميضًا، أم يشقُّ شقًّا؟</b>». قالوا: بل يشقُّ شقًّا. قال: <b>«الحياء الحياء، إن شاء الله</b>». فقال له رجل: يا رسول الله، ما أفصحك! ما رأينا الذي هو أعرب منك. قال: فقال: <b>«حُقَّ لي، وإنما نزل القرآن بلساني، والله يقول:</b> <span class="qpc-hafs">﴿بلسان عربي مبين﴾</span>»{10}{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٠<span class="dash">-</span></span> عن يحيى ابن الضريس، يقول: سمعت <span class="name-3">سفيان الثوري</span> يقول: لم ينزل وحيٌ إلا بالعربية، ثم ترجم كلُّ نبي لقومه، واللسان يوم القيامة بالسريانية، فمَن تكلم بالعربية دخل الجنة{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٤٣٩، والبيهقي في شعب الإيمان (١٦٢٢).|2:أخرجه إسحاق البستي في تفسيره ص٥٤٢، وابن أبي حاتم ٩/٢٨١٨. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه الرافعي في تاريخ قزوين ٢/٤٨. وعزاه السيوطي إلى ابن النجار في تاريخه دون آخره.|4:أخرجه ابن جرير ١/٦١.|5:أخرجه ابن أبي حاتم ٩/٢٨١٨.|6:تفسير مقاتل بن سليمان ٣/٢٨٠.|7:تفسير مقاتل بن سليمان ٣/٢٨٣.|8:الدَّجن: ظلُّ الغيم في اليوم المطير. لسان العرب (دجن).|9:الباسِق: المرتفع فِي عُلُوّه. النهاية (بسق).|10:أخرجه ابن أبي الدنيا في كتاب المطر والرعد ص٥٦-٥٧ (١٢)، والبيهقي في الشعب ٣/٣٣ (١٣٦٣)، وابن أبي حاتم ٩/٢٨١٨-٢٨١٩ (١٥٩٤٩).</p><p>قال ابن الملقن في البدر المنير ٨/٢٨٢: «مرسلًا».|11:أورد البيهقي عقب هذا الحديث: قول أبي عبيد: قوله: «قواعدها» يعني: قواعد السحاب وهي أصولها المعترضة، وفي آفاق السماء وإلى الأفق الآخر، و«الجون» الأسود، وقوله: «رحاها» فرحاها استدارة السحاب في السماء، و«الخفو» هو الاعتراض من البرق في نواحي بجسم، و«الوميض» أن يلمع قليلًا ثم يسكن، وليس له اعتراض، وأما الذي يشق شقًّا فاستطارته في الجو إلى وسط السماء من غير أن يأخذ يمينًا وشمالًا، والحياء هو المطر الواسع الغزير.|12:أخرجه ابن أبي حاتم ٩/٢٨١٩.
  26,196,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَفِی زُبُرِ ٱلۡأَوَّلِینَ ۝١٩٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span>: أي: في كُتُب الأولين{1}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، مثل ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span>، قال: أي: وإنّ القرآن لفي كُتُب الأولين؛ التوراة والإنجيل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span>، يقول: نعت محمد وأُمَّتُه في زبر الأولين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span>، يقول: أمر محمد ﷺ ونعته في كتب الأولين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ- <span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span>، يقول: في الكتب التي أنزلها على الأولين{6}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يعني: في كتاب الأولين{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.|2:علَّقه ابن أبي حاتم ٩/٢٨٢٠.|3:علَّقه يحيى بن سلّام ٢/٥٢٤.|4:علَّقه يحيى بن سلّام ٢/٥٢٤.|5:تفسير مقاتل بن سليمان ٣/٢٨٠.|6:أخرجه ابن أبي حاتم ٩/٢٨١٩.|7:تفسير يحيى بن سلّام ٢/٥٢٤.
  26,197,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَكُن لَّهُمۡ ءَایَةً أَن یَعۡلَمَهُۥ عُلَمَـٰۤؤُا۟ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٩٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٤٨<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿أوَ لَمْ يَكُن لَّهُمْ آيَةً﴾</span> بالياء{1}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أوَ لَمْ يَكُن لَّهُمْ آيَةً﴾</span> وهي تقرأ على وجهين، بالتاء والياء{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَكُن لَّهُمۡ ءَایَةً﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٥٠<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: أي: فقد كان لهم في إيمانهم به آية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿أو لم يكن﴾</span> محمدٌ ﷺ <span class="qpc-hafs">﴿لهم آية﴾</span> يعني: لكفار مكة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿أولم يكن لهم آية﴾</span> قال: محمد <span class="qpc-hafs">﴿أن يعلمه﴾</span> قال: يعرفه <span class="qpc-hafs">﴿علماء بني إسرائيل﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٣<span class="dash">-</span></span> عن <span class="name-3">مبشر بن عبيد القرشي</span> -من طريق عبد الواحد بن ميسرة- في قوله: <span class="qpc-hafs">﴿أو لم يكن لهم آية﴾</span>، يقول: أولم يكن لهم القرآن آية{6}. (١١/٣٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أولم يكن لهم آية﴾</span>، فمَن قرأها بالتاء يقول: قد كانت لهم آية، ومَن قرأها بالياء فيجعلها عملًا في باب كان، يقول: قد كان لهم آية{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن یَعۡلَمَهُۥ عُلَمَـٰۤؤُا۟ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٩٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: كان عبدُ الله بنُ سلام من علماء بني إسرائيل، وكان من خيارهم، فآمن بكتاب محمد ﷺ، فقال لهم الله: <span class="qpc-hafs">﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span>{8}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: بعث أهل مكة إلى اليهود وهم بالمدينة، فسألوهم عن محمد ﷺ، فقالوا: إنّ هذا لَزمانُه، وإنّا نجد في التوراة نعتَه وصفتَه. فكان ذلك آيةً لهم على صِدقه{9}<span class=comment-ref>٤٨٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٣</span> ذكر <u>ابنُ عطية</u> (٦/٥٠٥) أثر ابن عباس، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «ويؤيد هذا كون الآية مكية». ثم <span class="comment-type-1">وجَّه</span> معنى الآية على القول بمكيتها قائلًا: «فمن قال: إنها مكية. ذهب إلى أن علماء بني إسرائيل ذكروا أنّ في التوراة صفة النبي ﷺ، وهذه الإشارة إلى ذلك».</div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أولم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span>، قال: عبد الله بن سلام وغيره مِن علمائهم{10}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٨<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق عمرو بن قيس- في قوله: <span class="qpc-hafs">﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span>، قال: كانوا خمسة: أسد، وأَسِيد، وابن يامين، وثعلبة، وعبد الله بن سلام{11}. (١١/٣٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span>، قال: أولم يكن النبي آية -علامة- أنّ علماء بني إسرائيل كانوا يعلمون أنّهم كانوا يجدونه مكتوبًا عندهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span>، قال: يعني بذلك: اليهود والنصارى، كانوا يعلمون أنّهم يجدون محمدًا ﷺ مكتوبًا عندهم في التوراة والإنجيل أنّه رسول الله{13}. (١١/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن يعلمه علماء بني إسرائيل﴾</span>، يعني: ابن سلام وأصحابه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أن يعلمه علماء بني إسرائيل﴾</span>، يعني: مَن آمن منهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة ما عدا ابن عامر، فإنه قرأ: ‹أوَ لَمْ تَكُن لَّهُمْ آيَةٌ› بالتاء، ورفع ‹آيَةٌ›. ينظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٤.|2:تفسير يحيى بن سلّام ٢/٥٢٤.|3:علَّقه يحيى بن سلّام ٢/٥٢٤.|4:تفسير مقاتل بن سليمان ٣/٢٨٠.|5:أخرجه ابن جرير ١٧/٦٤٥.|6:أخرجه ابن أبي حاتم ٩/٢٨١٩.|7:تفسير يحيى بن سلّام ٢/٥٢٤.|8:أخرجه ابن جرير ١٧/٦٤٤، وابن أبي حاتم ٩/٢٨٢٠. وعزاه السيوطي إلى ابن مردويه.|9:تفسير الثعلبي ٧/١٨٠، وتفسير البغوي ٦/١٢٩.|10:تفسير مجاهد ص٥١٤ وزاد: من أسلم منهم، وأخرجه ابن جرير ١٧/٦٤٤-٦٤٥، وابن أبي حاتم ٩/٢٨١٩، وأخرجه يحيى بن سلّام ٢/٥٢٤ من طريق ابن مجاهد، وإسحاق البستي في تفسيره ص٥٤٣ من طريق ابن جريج. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|11:أخرجه ابن سعد ٢/٣٥٣، وابن أبي حاتم ٩/٢٨٢٠. وعزاه السيوطي إلى ابن المنذر.|12:أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤٥، وابن أبي حاتم ٩/٢٨١٩-٢٨٢٠.|13:أخرجه ابن أبي حاتم ٩/٢٨١٩-٢٨٢٠. وعلَّقه يحيى بن سلّام ٢/٥٢٤. وعزاه السيوطي بهذا اللفظ إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وهو عند عبد الرزاق وابن جرير بالطريق واللفظ السابق.|14:تفسير مقاتل بن سليمان ٣/٢٨٠.|15:تفسير يحيى بن سلّام ٢/٥٢٤.
  26,198,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَزَّلۡنَـٰهُ عَلَىٰ بَعۡضِ ٱلۡأَعۡجَمِینَ ۝١٩٨ فَقَرَأَهُۥ عَلَیۡهِم مَّا كَانُوا۟ بِهِۦ مُؤۡمِنِینَ ۝١٩٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٦٣<span class="dash">-</span></span> عن محمد بن أبي موسى، قال: كنت واقفًا إلى جنب <span class="name-1">عبد الله بن مطيع</span> بعَرَفة، فتلا هذه الآية: <span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين (١٩٨) فقرأه عليهم ما كانوا به مؤمنين﴾</span>. قال: جملي هذا أعجم، فلو أُنزِل على هذا ما كانوا به مؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿فقرأه عليهم﴾</span>: محمد ﷺ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٥<span class="dash">-</span></span> عن سفيان: أخبرني مَن سمع <span class="name-2">مجاهدًا</span> يقول: <span class="qpc-hafs">﴿ولو نزلناه على بعض الاعجمين﴾</span> قال: دواب العجم، <span class="qpc-hafs">﴿فقرأه عليهم ما كانوا به مؤمنين﴾</span> لا يؤمنون كما لا يؤمن دوابُّ العجم، لو قُرِئ عليهم ما كانوا به مؤمنين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين﴾</span>، قال: يقول: لو نزلنا هذا القرآن على بعض الأعجمين لكانت العرب أشرَّ الناس فيه، لا يفهمونه ولا يدرون ما هو{4}. (١١/٣٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين﴾</span>، قال: لو أنزله الله أعجميًّا لكانوا أخسَّ الناس به؛ لأنهم لا يعرفون العجمية{5}<span class=comment-ref>٤٨٢٤</span>. (١١/٣٠٠)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٤</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (١٧/٦٤٧) قول قتادة <span class="mustanad">مستندًا إلى لفظ الآية</span> قائلًا: «وهذا الذي ذكرناه عن قتادة قولٌ لا وجْه له؛ لأنه وجَّه الكلام إلى أن معناه: ولو نزَّلناه أعجميًّا، وإنما التنزيل: <span class="qpc-hafs">﴿ولَوْ نَزَّلْناهُ عَلى بَعْضِ الأَعْجَمِينَ﴾</span>، يعني: ولو نزَّلنا هذا القرآن العربيّ على بهيمة ٍمن العَجَم أو بعض ما لا يُفْصِح، ولم يَقُلْ: ولو نزَّلناه أعجميًّا. فيكون تأويل الكلام ما قاله».</div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين﴾</span>، قال: الفُرْس{6}. (١١/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ولو نزلناه﴾</span> يعني: القرآن <span class="qpc-hafs">﴿على بعض الأعجمين﴾</span> يعني: أبا فكيهة، يقول: لو أنزلناه على رجل ليس بعربي اللسان، <span class="qpc-hafs">﴿فقرأه عليهم﴾</span> على كفار مكة، لقالوا: ما نفقه قوله؛ و<span class="qpc-hafs">﴿ما كانوا به مؤمنين﴾</span> يعني: بالقرآن مُصَدِّقين بأنّه مِن الله ﷿{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن الأوزاعي</span>، قال: سمعت في قول الله: <span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين فقرأه عليهم ما كانوا به مؤمنين﴾</span>، لأنّه لو أنزله على بعض الأعجمين ما كانوا ليؤمنوا به، وهم يجدونه في زبر الأولين: أنه يبعث بلسان عربي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولو نزلناه﴾</span> يعني: القرآن ... <span class="qpc-hafs">﴿ما كانوا به مؤمنين﴾</span> يقول: لو أنزلناه بلسان عجمي لم تؤمن به العرب. كقوله: <span class="qpc-hafs">﴿وما أرسلنا من رسول إلا بلسان قومه﴾</span> [إبراهيم:٤]{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦٤٧، وابن أبي حاتم ٩/٢٨٢٠.|2:أخرجه إسحاق البستي في تفسيره ص٥٤٣، وابن أبي حاتم ٩/٢٨٢١، وأخرجه يحيى بن سلّام ٢/٥٢٤ من طريق ابن مجاهد.|3:أخرجه ابن أبي حاتم ٩/٢٨٢١.|4:أخرجه ابن أبي حاتم ٩/٢٨٢٠. وعلَّقه يحيى بن سلّام ٢/٥٢٥. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤٧. وعزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى ابن أبي حاتم، وقد وقع في مطبوعة تفسير ابن أبي حاتم ٩/٢٨٢١: حدثنا علي بن الحسين، قال: حدثنا الهيثم بن يمان، قال: حدثنا الحكم، عن السدي: في قوله: <span class="qpc-hafs">﴿ولَوْ نَزَّلْناهُ عَلى بَعْضِ الأَعْجَمِينَ﴾</span> ... ووقع بعد الآية إسناد أثر آخر دون أن يُذكر تفسير السدي.|7:تفسير مقاتل بن سليمان ٣/٢٨٠.|8:أخرجه ابن أبي حاتم ٩/٢٨٢١.|9:تفسير يحيى بن سلّام ٢/٥٢٤.
  26,199,""
  26,200,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ سَلَكۡنَـٰهُ فِی قُلُوبِ ٱلۡمُجۡرِمِینَ ۝٢٠٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> قال: أدخلنا الشرك والتكذيب <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿المجرمين﴾</span>: الكُفّار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٤<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق حميد الطويل- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span>، قال: الشِّرْك، سلكه في قلوب المشركين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> قال: أدخلنا الشرك والتكذيب <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span>، قال: القَسْوَة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق حماد بن سلمة، عن حُمَيد- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span>، قال: الشرك، جعلناه في قلوب المجرمين{6}. (١١/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان، عن حُمَيد- في هذه الآية: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span>، قال: خَلَقْناه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق همام- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span>، قال: جعلناه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> قال: الكفر <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> يعني: هكذا جعلنا الكفر بالقرآن <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span> [قال: الشرك]{11}<span class=comment-ref>٤٨٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٥</span> لم يذكر <u>ابنُ جرير</u> (١٧/٦٤٨-٦٤٩) في معنى: <span class="qpc-hafs">﴿كَذَلِكَ سَلَكْناهُ فِي قُلُوبِ المُجْرِمِينَ﴾</span> سوى قول الحسن، وابن جريج، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿كذلك سلكناه﴾</span> جعلناه <span class="qpc-hafs">﴿في قلوب المجرمين﴾</span> المشركين، التكذيب{12}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/١٢٩.|2:أخرجه ابن أبي حاتم ٩/٢٨٢٢.|3:أخرجه ابن أبي حاتم ٩/٢٨٢١-٢٨٢٢.|4:تفسير البغوي ٦/١٢٩.|5:أخرجه ابن أبي حاتم ٩/٢٨٢٩.|6:أخرجه ابن جرير ١٧/٦٤٩ بلفظ: الشرك سلكه في قلوبهم. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ١٧/٦٤٩.|8:أخرجه ابن أبي حاتم ٩/٢٨٢١.|9:أخرجه ابن جرير ١٧/٦٤٩.|10:تفسير مقاتل بن سليمان ٣/٢٨٠.|11:أخرجه ابن جرير ١٧/٦٤٩. وعلَّقه ابن أبي حاتم ٩/٢٨٢١. وما بين المعقوفين ساقط من نسخة ابن جرير، ويدل عليه ما علَّقه ابن أبي حاتم.|12:تفسير يحيى بن سلّام ٢/٥٢٥.
  26,201,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یُؤۡمِنُونَ بِهِۦ حَتَّىٰ یَرَوُا۟ ٱلۡعَذَابَ ٱلۡأَلِیمَ ۝٢٠١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿لا يؤمنون به﴾</span>، قال: إذا كذَّبوا سَلَك الله في قلوبهم ألّا يؤمنوا به{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿لا يؤمنون به﴾</span>، يقول: لا يؤمنون بما جاء به محمدٌ ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يؤمنون به﴾</span> يعني: بالقرآن <span class="qpc-hafs">﴿حتى يروا العذاب الأليم﴾</span> يعني: الوجيع{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٧<span class="dash">-</span></span> عن أصبغ، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قول الله تعالى: <span class="qpc-hafs">﴿سلكناه في قلوب المجرمين لا يؤمنون به﴾</span>، قال: هي كما قال: هو أضلَّهم، ومنعهم الإيمان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿لا يؤمنون به﴾</span> بالقرآن <span class="qpc-hafs">﴿حتى يروا العذاب الأليم﴾</span> المُوجِع، يعني: قيام الساعة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٢.|2:أخرجه ابن أبي حاتم ٩/٢٨٢٢.|3:تفسير مقاتل بن سليمان ٣/٢٨٠.|4:أخرجه ابن أبي حاتم ٩/٢٨٢٢.|5:تفسير يحيى بن سلّام ٢/٥٢٥.
  26,202,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَأۡتِیَهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٢٠٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسام- أنّه قرأ: (فَتَأْتِيهِم بَغْتَةً) بالتاء. فقال له رجل: يا أبا سعيد، إنما يأتيهم العذاب بغتة. فانتهره الحسن، وقال: إنما هي الساعة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَأۡتِیَهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٢٠٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فيأتيهم﴾</span> العذاب <span class="qpc-hafs">﴿بغتة﴾</span> يعني: فجأة، <span class="qpc-hafs">﴿وهم لا يشعرون﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فيأتيهم بغتة﴾</span> فجأة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي ٧/١٨١.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/١٣٧.|2:تفسير مقاتل بن سليمان ٣/٢٨٠.|3:تفسير يحيى بن سلّام ٢/٥٢٥.
  26,203,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَقُولُوا۟ هَلۡ نَحۡنُ مُنظَرُونَ ۝٢٠٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فيتَمَنَّوْن الرجعة والنظرة، فذلك قوله سبحانه: <span class="qpc-hafs">﴿فيقولوا﴾</span> يعني: كفار مكة: <span class="qpc-hafs">﴿هل نحن منظرون﴾</span> فنعتب ونراجع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فيقولوا﴾</span> يومئذ عند ذلك: <span class="qpc-hafs">﴿هل نحن منظرون﴾</span> مُؤَخَّرون، مردودون إلى الدنيا؛ فنُؤْمِن{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٨٠.|2:تفسير يحيى بن سلّام ٢/٥٢٥.
  26,204,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا أوعدهم النبيُّ ﷺ العذابَ قالوا: فمتى هذا العذاب؟ تكذيبًا به. يقول الله ﷿: <span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span> على الاستفهام، أي: قد استعجلوا به لقولهم: <span class="qpc-hafs">﴿ائتنا بعذاب الله﴾</span> [العنكبوت:٢٩]، وذلك منهم استهزاء وتكذيب بأنّه لا يأتيهم العذاب{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٦<span class="dash">-</span></span> عن أنس بن مالك: أنّ رسول الله ﷺ عادَ رجلًا مِن المسلمين قد خفت فصارَ مِثل الفَرْخ، فقال له رسول الله ﷺ: «<b>هل كنت تدعو بشيء، أو تسأله إيّاه</b>؟». قال: نعم، كنت أقول: اللهم، ما كنت معاقبي به في الآخرة فعجِّله لي في الدنيا. فقال رسول الله ﷺ: «<b>سبحان الله! لا تُطِيقه</b> –أو: <b>لا تستطيعه</b>-، <b>أفلا قلتَ: اللهم، آتِنا في الدنيا حسنة، وفي الآخرة حسنة، وقنا عذاب النار؟!</b>». قال: فدعا اللهَ له، فشفاه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٨٠. وفي تفسير الثعلبي ٧/١٨١، وتفسير البغوي ٦/١٣٠ مثله منسوبًا إلى مقاتل دون تعيينه.|2:تفسير يحيى بن سلّام ٢/٥٢٥.|3:أخرجه مسلم ٤/٢٠٦٨ (٢٦٨٨)، وابن جرير ٣/٥٤٥، وابن أبي حاتم ٩/٢٨٢٢ (١٥٩٩٦)، والبغوي في تفسيره ١/٢٣٣. وأورده الثعلبي ٢/١١٦.
  26,205,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٧<span class="dash">-</span></span> عن <span class="name-2">أبي جَهْضَمٍ</span>، قال: رُئي النبيُّ ﷺ كأنّه مُتَحَيِّر، فسألوه عن ذلك، فقال: «<b>ولِمَ؟! ورأيت عَدُوِّي يَلُونَ أمر أمتي من بعدي</b>». فنزلت: <span class="qpc-hafs">﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</span> فطابت نفسُه{1}. (١١/٣٠١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</span> - تفسير الآيات</h3></p><p><div></p><p><p><span class="item-no">٥٦٥٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span>، قال: مثل عمر الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٥٩٩<span class="dash">-</span></span> عن أبي زيد فيض بن إسحاق، قال: سألتُ <span class="name-3">الفُضَيل بن عياض</span> عن قول الله ﷿: <span class="qpc-hafs">﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</span>، قال: قراءتها تفسيرُها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span> في الدنيا، <span class="qpc-hafs">﴿ثم جآءهم﴾</span> بعد ذلك العذاب <span class="qpc-hafs">﴿ما كانوا يوعدون * مآ أغنى عنهم﴾</span> مِن العذاب <span class="qpc-hafs">﴿ما كانوا يمتعون﴾</span> في الدنيا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span> إلى قوله: <span class="qpc-hafs">﴿ما أغنى عنهم ما كانوا يمتعون﴾</span>، قال: هؤلاء أهل الكفر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ثم جاءهم ما كانوا يوعدون﴾</span> العذاب{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٦٠٣<span class="dash">-</span></span> عن <span class="name-3">سليمان بن عبد الملك</span> -من طريق يزيد بن حازم- أنّه كان لا يَدَعُ أن يقول في خطبته كل جمعة: إنما أهل الدنيا فيها على وجَل، لم تمضِ بهم نِيَّة، ولم تَطْمَئِنَّ لهم دارٌ، حتى يأتي أمرُ الله وهم على ذلك، لا يدوم نعيمها، ولا تؤمن فجعاتها، ولا يبقى فيها شيء. ثم يتلو: <span class="qpc-hafs">﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</span>{7}. (١١/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٦٠٤<span class="dash">-</span></span> عن عبيد الله بن موسى، قال: سمعت <span class="name-3">الحسن بن صالح</span> يقول: لقد دخل الترابَ مِن هذا المِصْرَ قومٌ قطعوا عنهم الدنيا بالصبر على طاعة الله، وبيَّن لهم هذا القرآنُ غِيَر{8} الدنيا، قال: <span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين ثم جاءهم ما كانوا يوعدون ما أغنى عنهم ما كانوا يمتعون﴾</span>. ثم بكى حسن، ثم قال: إذا جاء الموتُ وسَكَراتُه لم يُغْنِ عن الفتى ما كان فيه مِن النعيم واللذة. ثم مال مَغْشِيًّا عليه{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٣ (١٥٩٩٧) مرسلًا.|2:أخرجه يحيى بن سلّام ٢/٥٢٥.|3:أخرجه ابن أبي حاتم ٩/٢٨٢٣.|4:تفسير مقاتل بن سليمان ٣/٢٨٠.|5:أخرجه ابن جرير ١٧/٦٥١، وابن أبي حاتم ٩/٢٨٢٣ مختصرًا من طريق أصبغ.|6:تفسير يحيى بن سلّام ٢/٥٢٥.|7:أخرجه ابن أبي الدنيا في كتاب ذم الدنيا -موسوعة الإمام ابن أبي الدنيا ٥/١٣٠-١٣١ (٢٧١)-، وابن أبي حاتم ٩/٢٨٢٢ (١٥٩٩٦). وعزاه السيوطي إلى عبد بن حميد.|8:غِيَر الدنيا: تغيُّر حالها، وانتقالها عن الصلاح إلى الفساد. النهاية (غير).|9:أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢٣٣ (٦١)-.
  26,206,""