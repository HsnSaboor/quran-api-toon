quran[23]{c,v,t}:
26,184," <q>﴿وَٱتَّقُوا۟ ٱلَّذِی خَلَقَكُمۡ﴾</q> - تفسير ٥٦٤٥٥- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿الذي خلقكم﴾</q> وخلق الذين مِن قبلكم{1}. (ز) ٥٦٤٥٦- قال مقاتل بن سليمان: <q>﴿واتقوا﴾</q> يقول: واخْشَوْا أن يُعَذِّبكم في الدنيا <q>﴿الذي خلقكم و﴾</q>خلق <q>﴿الجبلة الأولين﴾</q>{2}. (ز) <q>﴿وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِینَ ۝١٨٤﴾</q> - تفسير ٥٦٤٥٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿والجبلة الأولين﴾</q>، قال: خَلْقَ الأولين{3}. (١١/٢٩١) ٥٦٤٥٨- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿واتقوا الذي خلقكم والجبلة﴾</q>: يعني: وخلق الجبلة <q>﴿الأولين﴾</q> يعني: القرون الأولين الذين أُهْلِكوا بالمعاصي، ولا تهلكوا مثلهم{4}. (١١/٢٩٠) ٥٦٤٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والجبلة الأولين﴾</q>، قال: الخَلِيقَة{5}. (١١/٢٩٢) ٥٦٤٦٠- قال مقاتل بن سليمان: <q>﴿و﴾</q>خلق <q>﴿الجِبِلَّة﴾</q> يعني: الخليقة <q>﴿الأولين﴾</q> يعني: الأمم الخالية الذين عُذِّبوا في الدنيا؛ قوم نوح، وصالح، وقوم لوط{2}. (ز) ٥٦٤٦١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والجبلة الأولين﴾</q>، قال: الخَلْق الأولين. الجِبِلَّة: الخَلْقُ{7}. (ز) ٥٦٤٦٢- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿واتقوا الذي خلقكم والجبلة الأولين﴾</q>، قال: خَلْق الأولين. ثم قرأ: <q>﴿ولقد أضل منكم جبلا كثيرا﴾</q> [يس:٦٢]{8}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨١٣.تفسير مقاتل بن سليمان ٣/٢٧٨.أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٧/٦٣٥، وإسحاق البستي في تفسيره ص٥٤٠ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٣. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٨.أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٣ من طريق أصبغ.أخرجه إسحاق البستي في تفسيره ص٥٤١، وابن أبي حاتم ٩/٢٨١٣.
26,185," <q>﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٨٥﴾</q> - تفسير ٥٦٤٦٣- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿قالوا إنما أنت من المسحرين﴾</q>: يعني: مِن المخلوقين{1}. (١١/٢٩٠) ٥٦٤٦٤- قال مقاتل بن سليمان: <q>﴿قالوا إنما أنت من المسحرين﴾</q> يعني: أنت بشر مثلنا، لست بملك، ولا رسول، فذلك قوله سبحانه: <q>﴿وما أنت إلا بشر مثلنا﴾</q>{2}. (ز) ",footnotes:1:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٣/٢٧٩. وتقدمت آثار السلف في تفسيرها عند قوله تعالى: <q>﴿قالُوا إنَّما أنْتَ مِنَ المُسَحَّرِينَ (١٥٣)﴾</q> [الشعراء:١٥٣].
26,186," <q>﴿وَمَاۤ أَنتَ إِلَّا بَشَرࣱ مِّثۡلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلۡكَـٰذِبِینَ ۝١٨٦﴾</q> - تفسير ٥٦٤٦٥- قال مقاتل بن سليمان: <q>﴿وما أنت إلا بشر مثلنا﴾</q> لا تفضلنا في شيء فنتبعك، <q>﴿وإن نظنك﴾</q> يقول: وقد نحسبك -يا شعيب- <q>﴿لمن الكاذبين﴾</q> يعني: حين تزعم أنّك نبيٌّ رسول{1}. (ز) ٥٦٤٦٦- قال يحيى بن سلّام: <q>﴿وما أنت إلا بشر مثلنا وإن نظنك لمن الكاذبين﴾</q> فيما تَدَّعي مِن الرسالة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.تفسير يحيى بن سلّام ٢/٥٢٢.
26,187," <q>﴿فَأَسۡقِطۡ عَلَیۡنَا كِسَفࣰا مِّنَ ٱلسَّمَاۤءِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٨٧﴾</q> - تفسير ٥٦٤٦٧- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿كسفا﴾</q>، يقول: قِطَعًا{1}. (ز) ٥٦٤٦٨- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿فأسقط علينا كسفا من السماء﴾</q>: يعني: قِطَعًا من السماء{2}. (١١/٢٩٠) ٥٦٤٦٩- عن عبيد، قال: سمعت الضحاك بن مزاحم يقول في قوله: <q>﴿كسفا من السماء﴾</q>: جانبًا من السماء{3}. (ز) ٥٦٤٧٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فأسقط علينا كسفا من السماء﴾</q>، قال: قِطَعًا من السماء{4}. (١١/٢٩٢) ٥٦٤٧١- عن إسماعيل السُّدِّيّ، <q>﴿كسفا من السماء﴾</q>، يقول: عذابًا مِن السماء{5}٤٨٢٢. (ز) ٤٨٢٢ علَّق ابنُ كثير (١٠/٣٦٨) على قول الضحاك، وقتادة، والسدي بقوله: «وهذا شبيه بما قالت قريش فيما أخبر الله عنهم في قوله تعالى: <q>﴿وقالُوا لَنْ نُؤْمِنَ لَكَ حَتّى تَفْجُرَ لَنا مِنَ الأرْضِ يَنْبُوعًا﴾</q> إلى أن قالوا: <q>﴿أوْ تُسْقِطَ السَّماءَ كَما زَعَمْتَ عَلَيْنا كِسَفًا أوْ تَأْتِيَ بِاللَّهِ والمَلائِكَةِ قَبِيلا﴾</q> [الإسراء:٩٠-٩٢]، وقوله: <q>﴿وإذْ قالُوا اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</q> [الأنفال:٣٢]، وهكذا قال هؤلاء الكفرة الجهلة: <q>﴿فَأَسْقِطْ عَلَيْنا كِسَفًا مِنَ السَّماءِ إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</q>». ٥٦٤٧٢- قال مقاتل بن سليمان: <q>﴿فأسقط علينا كسفا﴾</q> يعني: جانبًا <q>﴿من السماء إن كنت من الصادقين﴾</q> بأنّ العذاب نازل بنا؛ لقوله في هود [٨٤]: <q>﴿وإني أخاف عليكم عذاب يوم محيط﴾</q>{6}. (ز) ٥٦٤٧٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأسقط علينا كسفا من السماء﴾</q>، قال: ناحية من السماء، عذابٌ، ذلك الكِسَفُ{1}. (ز) ٥٦٤٧٤- قال يحيى بن سلّام: <q>﴿إن كنت من الصادقين﴾</q> بما جئت به{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٦٣٦.أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٧/٦٣٦، وإسحاق البستي في تفسيره ص٥٤١، وابن أبي حاتم ٩/٢٨١٤.أخرجه ابن أبي حاتم ٩/٢٨١٤. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨١٤.تفسير مقاتل بن سليمان ٣/٢٧٩.أخرجه ابن جرير ١٧/٦٣٦.تفسير يحيى بن سلّام ٢/٥٢٢.
26,188," <q>﴿قَالَ رَبِّیۤ أَعۡلَمُ بِمَا تَعۡمَلُونَ ۝١٨٨﴾</q> - تفسير ٥٦٤٧٥- قال مقاتل بن سليمان: <q>﴿قال﴾</q> شعيب: <q>﴿ربي أعلم﴾</q> مِن غيره <q>﴿بما تعملون﴾</q> مِن نقصان الكيل والميزان{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.
26,189," <q>﴿فَكَذَّبُوهُ فَأَخَذَهُمۡ عَذَابُ یَوۡمِ ٱلظُّلَّةِۚ إِنَّهُۥ كَانَ عَذَابَ یَوۡمٍ عَظِیمٍ ۝١٨٩﴾</q> - تفسير ٥٦٤٧٦- عن قتادة، قال: قال عبد الله بن عمرو بن العاص: تدرون كيف كان أمرُ أصحاب الأيكة؟ قالوا: الله أعلم. قال: كان أمرهم أنّ الله سلَّط عليهم الحرَّ سبعة أيام، حتى ما يُظِلُّهم منه شيء، ثم إنّ الله أنشا لهم سحابةً، فانطلق إليها أحدُهم، فاسْتَظَلَّ بها، فأصاب تحتها بردًا وراحة، فأعلم بذلك قومه، فأتوا جميعًا، فاسْتَظَلُّوا تحتها، فأجَّجَتْ عليهم نارًا.= (ز) ٥٦٤٧٧- قال قتادة: فحدثنا شهر بن حوشب: أنّه رأى مكانهم، وأنه لا يذكر منهم إلا كموضع المِسَلَّة{1}، صاروا رمادًا، قال الله ﷿: <q>﴿إنه كان عذاب يوم عظيم﴾</q>{2}. (ز) ٥٦٤٧٨- عن عبد الله بن عباس -من طريق الشعبي- قال: مَن حدَّثك مِن العلماء ما عذابُ يوم الظلة فكذِّبه{3}. (١١/٢٨٤) ٥٦٤٧٩- عن يزيد الباهلي، قال: سألتُ عبد الله بن عباس عن قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>. فقال: بعث الله عليهم ومَدَة{4}، وحرًّا شديدًا، فأخذ بأنفاسهم، فدخلوا أجواف البيوت، فدخل عليهم أجواف البيوت، فأخذ بأنفاسهم، فخرجوا مِن البيوت هرابًا إلى البرية، فبعث الله عليهم سحابة، فأظلَّتهم مِن الشمس، فوجدوا لها بردًا ولَذَّة، فنادى بعضُهم بعضًا، حتى إذا اجتمعوا تحتها أسقطها اللهُ عليهم نارًا، فذلك عذاب يوم الظلة{5}. (١١/٢٩٣) ٥٦٤٨٠- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>: أرسل الله عليهم سَمُومًا مِن جهنم، فأطاف بهم سبعة أيام، حتى أنضجهم الحرُّ، فحميت بيوتهم، وغَلَتْ مياهُهم في الآبار والعيون، فخرجوا مِن منازلهم ومحلتهم هاربين، والسموم معهم، فسلط الله عليهم الشمسَ مِن فوق رؤوسهم، فتغشتهم حتى تفَلَّقت فيها جماجمهم، وسلَّط الله عليهم الرَّمضاء مِن تحت أرجلهم، حتى تساقطت لحومُ أرجلهم، ثم أنشئت لهم ظلة كالسحابة السوداء، فلمّا رأوها ابتدروها يستغيثون بظِلِّها، حتى إذا كانوا تحتها جميعًا أطبقت عليهم، فهلكوا، ونَجّى الله شعيبًا والذين آمنوا معه{6}. (١١/٢٩٠) ٥٦٤٨١- عن علقمة -من طريق زيد بن معاوية- <q>﴿فأخذهم عذاب يوم الظلة﴾</q>، قال: أصابهم الحرُّ، حتى أقلعهم من بيوتهم، فخرجوا، ورُفِعَت لهم سحابةٌ، فانطلقوا إليها، فلمّا استظلوا بها أرسلت إليهم، فلم ينفلِت منهم أحدٌ{7}. (١١/٢٩٤) ٥٦٤٨٢- عن زيد بن معاوية -من طريق أبي إسحاق السبيعي- في قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>، قال: أصابهم حرٌّ أقلقهم مِن بيوتهم، فنشأت لهم سحابةٌ كهيئة الظُّلَّة، فابتدروها، فلما تَتامُّوا تحتها أخذتهم الرجفة{8}. (١١/٢٩٦) ٥٦٤٨٣- عن سعيد بن جبير -من طريق جعفر- في قول الله: <q>﴿عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</q>، قال: كانت الظلة سحابةً، وكانوا يحفرون الأسراب{9}، يدخلونها، فيَتَبَرَّدون بها، فإذا دخلوها وجدوها أشدَّ حرًّا مِن ظَهْرِها{10}. (ز) ٥٦٤٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>، قال: ظلل العذاب إيّاهم{11}. (١١/٢٩٥) ٥٦٤٨٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>، قال: قوم شعيب، حبس الله عنهم الظل والريح، فأصابهم حرٌّ شديد، ثم بعث الله لهم سحابةً فيها العذاب، فلمّا رأوا السحابة انطلقوا يَؤُمُّونها -زعموا- يستظلون، فاضطرمت عليهم نارًا، فأهلكتهم{12}. (ز) ٥٦٤٨٦- عن الضحاك بن مُزاحِم -من طريق جويبر- في قوله ﷿: <q>﴿كذب أصحاب الأيكة المرسلين﴾</q>، قال: الأيكة: الغيضة، أهلكهم ﷿ فيها، لَمّا أراد الله تعالى هلاكهم أرسل عليهم حرًّا شديدًا، حتى امتنع منهم طلاع البيوت والشراب{13}، وبعث الله سحابةً، فعامت على الغَيْضَة، فلمّا رأوها حسُّوا أنّ لها ظِلًّا، فدخلوا، فلما تتامُّوا تحتها أرسل الله عليهم نارًا، فأحرقهم، فذلك قوله ﷿: <q>﴿فأخذهم عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</q>{14}. (ز) ٥٦٤٨٧- عن عكرمة مولى ابن عباس -من طريق ميسرة- في قوله: <q>﴿عذاب يوم الظلة﴾</q>، قال: الظلة فيها نار نزلت من السماء، فلمّا رأت الأرضُ ذلك أشفقت، وظنَّت أن إيّاها يُراد، فائتَفَكَتْ{15}، فكانت الأفكة{16} بقوم شعيب{10}. (ز) ٥٦٤٨٨- عن الحسن البصري -من طريق الوليد بن حسان- قال: سلَّط اللهُ الحرَّ على قوم شعيب سبعة أيام ولياليهن، حتى كانوا لا ينتفعون بظلِّ بيت، ولا ببرد ماء، ثم رُفِعَت لهم سحابةٌ في البَرِّيَّة، فوجدوا تحتها الرَّوح، فجعل يدْعُو بعضُهم بعضًا، حتى إذا اجتمعوا تحتها أشعلها الله عليهم نارًا، فذلك قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>{18}. (١١/٢٩٣) ٥٦٤٨٩- عن محمد بن كعب القرظي -من طريق أبي معشر- قال: إنّ أهل مدين عُذِّبوا بثلاثة أصناف من العذاب: أخذتهم الرجفة في دارهم حتى خرجوا منها، فلما خرجوا منها أصابهم فزع شديد، ففرقوا أن يدخلوا البيوت أن تسقط عليهم، فأرسل الله عليهم الظلة، فدخل تحتها رجل، قال: ما رأيت كاليوم ظِلًّا أطيب، ولا أبرد، هلمُّوا، أيها الناس. فدخلوا جميعًا تحت الظلة، فصاح فيهم صيحة واحدة، فماتوا جميعًا{19}. (١١/٢٩٢) ٥٦٤٩٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فأخذهم عذاب يوم الظلة﴾</q>، قال: ذُكِر لنا: أنّه سلط الله عليهم الحرَّ سبعة أيام، لا يُظِلُّهم ظل، ولا ينفعهم منه شيء، فبعث الله عليهم سحابة، فلجُّوا إليها يلتمسون الرَّوح في ظلها، فجعلها الله عليهم عذابًا، فأحرقتهم، بعثت عليهم نارًا، فاضطرمت، فأكلتهم، فذلك عذاب يوم الظلة{20}. (١١/٢٩٤) ٥٦٤٩١- عن قتادة بن دعامة -من طريق جرير بن حازم- قال: بعث شعيب إلى أمتين: إلى قومه أهل مدين، وإلى أصحاب الأيكة. وكانت الأيكة مِن شجر ملتف، فلما أراد الله أن يُعَذِّبهم بعث الله عليهم حرًّا شديدًا، ورفع لهم العذابَ كأنه سحابة، فلما دنت منهم خرجوا إليها رجاءَ بردها، فلما كانوا تحتها مطرت عليهم نارًا. قال: فذلك قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>{21}. (ز) ٥٦٤٩٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: بعث الله شعيبًا إلى أصحاب الأيكة، والأيكة: غيضة، فكذبوه، فأخذهم عذاب يوم الظلة. قال: فتح الله عليهم بابًا مِن أبواب جهنم، فغشيهم مِن حرِّه ما لم يُطيقوه، فتَغَوَّثوا بالماء وبما قدروا عليه، فبينما هم كذلك إذا رُفِعت لهم سحابةٌ فيها ريح باردة طيبة، فلمّا وجدوا بردها –الظلة- تنادوا: عليكم الظلة. فأتوها يتغوثون بها، فخرجوا من كل شيء كانوا فيه، فلما تكاملوا تحتها طبقت عليهم بالعذاب، فذلك قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>{22}. (١١/٢٩٢) ٥٦٤٩٣- عن منصور [بن المعتمر] -من طريق محمد بن جابر- <q>﴿فأخذهم عذاب يوم الظلة﴾</q>، قال: بعث الله عليهم سحابة تنضح عليهم بالنار{23}. (ز) ٥٦٤٩٤- عن زيد بن أسلم -من طريق مالك- قوله: <q>﴿عذاب يوم الظلة﴾</q>، قال: صارت الغمام عليهم نارًا{24}. (ز) ٥٦٤٩٥- عن زيد بن أسلم -من طريق داود بن قيس الفراء- قال: كان ينهاهم عن قطع الدراهم، فأخذهم عذاب يوم الظلة، حتى إذا اجتمعوا كلهم كشف الله عنهم الظلة، وأحمى عليهم الشمس، فاحترقوا كما يحترق الجراد في المقلى{25}. (١١/٢٩٥) ٥٦٤٩٦- عن جعفر [بن محمد بن علي] -من طريق يعقوب- في قوله: <q>﴿عذاب يوم الظلة﴾</q>، قال: كانوا يحفرون الأسراب لِيَتَبَرَّدوا فيها، فإذا دخلوها وجدوها أشدَّ حرًا مِن الظاهر، وكانت الظلة سحابة{26}. (ز) ٥٦٤٩٧- قال مقاتل بن سليمان: <q>﴿فكذبوه﴾</q> بالعذاب، <q>﴿فأخذهم عذاب يوم الظلة﴾</q> وذلك أنّ الله ﷿ كان حبس عنهم الريح والظل، فأصابهم حر شديد، فخرجوا من منازلهم، فرفع الله ﷿ سحابةً فيها عذاب بعد ما أصابهم الحر سبعة أيام، فانقلبوا ليستظلوا تحتها، فأهلكهم الله ﷿ حرًّا وغمًّا تحت السحابة، فذلك قوله ﷿: <q>﴿إنه كان عذاب يوم عظيم﴾</q> لشدته{27}. (ز) ٥٦٤٩٨- قال عبد الملك ابن جريج -من طريق حجاج-: لما أنزل الله عليهم أول العذاب أخذهم منه حر شديد، فرفع الله لهم غمامة، فخرج إليها طائفة منهم ليستظلُّوا بها، فأصابهم منها رَوح وبرد وريح طيبة، فصبَّ الله عليهم من فوقهم من تلك الغمامة عذابًا، فذلك قوله: <q>﴿عذاب يوم الظلة﴾</q>{28}. (ز) ٥٦٤٩٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأخذهم عذاب يوم الظلة، إنه كان عذاب يوم عظيم﴾</q>، قال: بعث الله إليهم ظُلَّة مِن سحاب، وبعث إلى الشمس، فأحرقت ما على وجه الأرض، فخرجوا كلهم إلى تلك الظُّلَّة، حتى إذا اجتمعوا كلُّهم كشف الله عنهم الظلة، وأحمى عليهم الشمس، فاحترقوا كما يحترق الجراد في المقلى{29}. (ز) ٥٦٥٠٠- عن أبي نضرة العبدي، قال: حدَّثنا رجلٌ من الصدر الأول، قال: كان قوم شعيب يقتلون على الكِذْبَة فما فوقها، فكانوا إذ يصنعون ذلك عيشُهم فيه شِدَّة. قال: حتى أصاب بعضُ ملوكهم ذنبًا، فعُطِّل الحد. قال: حتى أباحوا [الخمر] نهارًا جهارًا في المجالس. قال: فبسط الله لهم الرزق عند ذلك، حتى قال قائل: لو سعرناه كنا قد عطلناها منذ زمان. قال: فلما أراد الله عقوبتهم بعث عليهم حرًّا شديدًا. قال: فلم ينفعهم بيتٌ، ولا ظِلٌّ، ولا شيء. قال: فانطلقوا يرتادون الرَّوْح والبَرْد. قال: فدخل داخل منهم الظُّلَّة، فوجدها باردة، فأذَّن في الناس: البردَ البردَ. فلما تَتامُّوا تحتها قذفها الله عليهم، فذلك قوله: <q>﴿فأخذهم عذاب يوم الظلة إنه كان عذاب يوم عظيم﴾</q>{30}. (ز) ٥٦٥٠١- قال يحيى بن سلّام، في قوله: <q>﴿فأخذهم عذاب يوم الظلة﴾</q>: يعني: تلك السحابة{31}. (ز) ",footnotes:1:المِسَلَّة: الإبرة العظيمة. مختار الصحاح (سلل).أخرجه ابن أبي حاتم ٩/٢٨١٥.أخرجه ابن جرير ١٧/٦٣٩، وابن أبي حاتم ٩/٢٨١٥، والحاكم ٢/٥٦٩.الوَمَد والوَمَدَة: ندًى يجيء في صميم الحر مِن قِبَل البحر مع سكون ريح، وهو ما يُعَبَّر عنه اليوم بالرطوبة. اللسان والمعجم الوسيط (ومد).أخرجه ابن جرير ١٧/٦٣٨، وابن أبي حاتم ٩/٢٨١٤-٢٨١٥، والحاكم ٢/٥٦٨-٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧ (١٨٧)-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٦٣٧، وإسحاق البستي في تفسيره ص٥٤١. وعزاه السيوطي إلى الفريابي بلفظ: فأنشئت لهم سحابة، فأتوها، فصيح بهم فيها.الأسراب: جمع سَرَب، وهو حفير تحت الأرض، وقيل: بيت تحت الأرض. لسان العرب (سرب).أخرجه ابن أبي حاتم ٩/٢٨١٦.أخرج الفريابي -كما في فتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦٣٨-٦٣٩، وابن أبي حاتم ٩/٢٨١٦، والحاكم ٢/٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وفي تفسير مجاهد ص٥١٣ بلفظ: يعني: ظل العذاب الذي أتاهم.أخرجه ابن جرير ١٧/٦٤٠، وإسحاق البستي في تفسيره ص٥٤٢.يوضح هذه العبارةَ قولُ ابن عباس من طريق الضحاك: فحميت بيوتهم، وغلت مياههم.أخرجه ابن عساكر ٢٣/٧٤.ائتفكت: انقلبت. النهاية (أفك).الأفكة: العذاب. النهاية (أفك).أخرجه ابن أبي حاتم ٩/٢٨١٦.أخرجه ابن أبي حاتم ٩/٢٨١٦، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧-٤٧٨ (١٨٨)-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨١٥. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد. وتقدم أنّ ابن أبي حاتم ٩/٢٨١٥ أخرجه من قول عبد الله بن عمرو.أخرجه ابن جرير ١٧/٦٣٧ واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٣)-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨١٥، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٤)-.أخرجه ابن عساكر في تاريخ دمشق ٢٣/٧٨.أخرجه الحاكم ٢/٥٦٩.أخرجه ابن جرير ١٧/٦٣٧.تفسير مقاتل بن سليمان ٣/٢٧٩.أخرجه ابن جرير ١٧/٦٣٩.أخرجه ابن جرير ١٧/٦٣٥، وابن أبي حاتم ٩/٢٨١٧ مختصرًا من طريق أصبغ.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٧ (١٨٦)-، وابن أبي حاتم ٩/٢٨١٦، وأخرج نحوه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦٣٩، وابن أبي حاتم ٩/٢٨١٧ عن معمر بن راشد، عن رجل من أصحابه، عن بعض العلماء.تفسير يحيى بن سلّام ٢/٥٢٣.
26,190," <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٩٠ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٩١﴾</q> - تفسير ٥٦٥٠٢- قال مقاتل بن سليمان: <q>﴿إن في ذلك لآية﴾</q> إنّ في هلاكهم بالحر والغم لعبرة لمن بعدهم، يُحَذِّر كُفّار مكة أمة محمد ﷺ، ثم قال ﷿: <q>﴿وما كان أكثرهم مؤمنين﴾</q> يعني: لو كان أكثرهم مؤمنين ما عذبوا في الدنيا، <q>﴿وإن ربك لهو العزيز﴾</q> في نقمته من أعدائه، <q>﴿الرحيم﴾</q> بالمؤمنين{1}. (ز) ٥٦٥٠٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿إن في ذلك لآية وما كان أكثرهم مؤمنين (١٩٠) وإن ربك لهو العزيز الرحيم (١٩١)﴾</q> وهي مثل الأولى{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.تفسير يحيى بن سلّام ٢/٥٢٣.
  26,191,""
26,192," <q>﴿وَإِنَّهُۥ لَتَنزِیلُ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٩٢﴾</q> - نزول الآية ٥٦٥٠٤- عن عبد الله بن سلام، قال: كان نفر مِن قريش مِن أهل مكة قدموا على قوم مِن يهود مِن بني قريظة لبعض حوائجهم، فسمعوهم يقرأون التوراة، فقال القُرَشِيُّون: ماذا نلقى مِمَّن يقرأ توراتكم هذه؟ لَهؤلاء أشدُّ علينا من محمد وأصحابه. فقال اليهود: نحن مِن أولئك برآء، وأولئك يكذبون على التوراة، وما أنزل الله في الكتب، إنما أرادوا عَرَض الدنيا. فقال القرشيون: فإذا لقيتموهم فسَوِّدوا وجوههم. وقال المنافقون: لا يُعلِّمه إلا بشرٌ مثله. وأنزل الله: <q>﴿وإنه لتنزيل رب العالمين﴾</q> إلى قوله: <q>﴿وإنه لفي زبر الأولين﴾</q>، يعني: النبي ﷺ، وصفته، ونعته، وأمره{1}. (١١/٢٩٩) ٥٦٥٠٥- قال مقاتل بن سليمان: <q>﴿وإنه لتنزيل رب العالمين﴾</q>، وذلك أنّه لَمّا قال كفار مكة: إنّ محمدًا ﷺ يتعلم القرآن مِن أبي فكيهة، ويجيء به الري -وهو شيطان-، فيلقيه على لسان محمد ﷺ. فأكذبهم الله تعالى، فقال ﷿: <q>﴿وإنه لتنزيل رب العالمين﴾</q>{2}. (ز) <q>﴿وَإِنَّهُۥ لَتَنزِیلُ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٩٢﴾</q> - تفسير الآية ٥٦٥٠٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿وإنه لتنزيل رب العالمين﴾</q>، قال: هذا القرآن{3}. (١١/٢٩٦) ٥٦٥٠٧- قال مقاتل بن سليمان: <q>﴿وإنه لتنزيل رب العالمين﴾</q>، يعني: القرآن{2}. (ز) ٥٦٥٠٨- عن مقاتل، في قوله: <q>﴿وإنه﴾</q>، قال: ذِكْر محمد ﷺ، ونعته{5}. (ز) ٥٦٥٠٩- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإنه لتنزيل رب العالمين﴾</q>، يعني: القرآن{6}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٧٩.أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤١-٦٤٢، وابن أبي حاتم ٩/٢٨١٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٧٩.تفسير الثعلبي ٧/١٨٠، وتفسير البغوي ٦/١٢٩.تفسير يحيى بن سلّام ٢/٥٢٣.
26,193," <q>﴿نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِینُ ۝١٩٣﴾</q> - قراءات ٥٦٥١٠- عن الحسن البصري -من طريق عمرو بن عبيد، وإسماعيل- أنّه قرأ: ‹نَزَّل بِهِ› يثقلها، ‹الرُّوحَ الأَمِينَ›{1}. (١١/٢٩٦) ٥٦٥١١- عن عاصم بن أبي النجود أنه قرأ: ‹نَزَّل بِهِ› مثقلة، ‹الرُّوحَ الأَمِينَ› منصوبتان{2}. (١١/٢٩٦) ٥٦٥١٢- عن الأعرج= (ز) ٥٦٥١٣- وأبي عمرو -من طريق هارون-: <q>﴿نَزَلَ بِهِ الرُّوحُ الأَمِينُ﴾</q>= (ز) ٥٦٥١٤- وتفسير قتادة: <q>﴿نَزَلَ بِهِ الرُّوحُ الأَمِينُ﴾</q> مخففة{3}. (ز) <q>﴿نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِینُ ۝١٩٣﴾</q> - تفسير الآية ٥٦٥١٥- عن ابن عباس، عن النبي ﷺ، في قوله: <q>﴿نزل به الروح الأمين﴾</q>، قال: «الروح الأمين جبريل، رأيت له ستمائة جناح مِن لؤلؤ، قد نشرها فيها مثل ريش الطَّواويس»{4}. (١١/٢٩٨) ٥٦٥١٦- عن عبد الله بن عباس -من طريق العوفي- <q>﴿نزل به الروح الأمين﴾</q>، قال: الروح الأمين: جبريل{5}. (١١/٢٩٦) ٥٦٥١٧- عن عبيد، قال: سمعت الضحاك بن مزاحم يقول في قوله: <q>﴿الروح الأمين﴾</q>، قال: جبريل{6}. (ز) ٥٦٥١٨- عن الحسن البصري -من طريق عمرو بن عبيد، وإسماعيل- أنّه قرأ: ‹نزَّل بِهِ› يثقلها، ‹الرُّوحَ الأمينَ› يقول: نزَّل اللهُ جبريل{7}. (١١/٢٩٦) ٥٦٥١٩- عن عطية العوفي -من طريق إدريس- <q>﴿الروح الأمين﴾</q>، قال: جبريل{7}. (ز) ٥٦٥٢٠- عن محمد بن كعب القرظي، قال: <q>﴿الروح الأمين﴾</q> جبريل{9}. (١١/٢٩٦) ٥٦٥٢١- عن قتادة بن دعامة -من طريق معمر- <q>﴿نزل به الروح الأمين﴾</q>، قال: جبريل{10}. (١١/٢٩٦) ٥٦٥٢٢- عن محمد ابن شهاب الزهري -من طريق عقيل، وبنحوه من طريق يونس بن يزيد- قال: قد بيَّن اللهُ لنا في كتابه أنه يرسل جبريلَ إلى محمد نبينا ﷺ، فقال الله ﷿: <q>﴿قُلْ مَن كانَ عَدُوًّا لِجِبْرِيلَ فَإنَّهُ نَزَّلَهُ عَلى قَلْبِكَ بِإذْنِ اللَّهِ﴾</q> [البقرة:٩٧]، وذكر الله الروح الأمين، فقال: <q>﴿وانه لتنزيل رب العالمين نزل به الروح الامين على قلبك لتكون من المنذرين﴾</q> يعني: جبريل ﵇{11}. (ز) ٥٦٥٢٣- تفسير إسماعيل السُّدِّيّ، في قوله: <q>﴿الروح الأمين﴾</q>: هو جبريل{12}. (ز) ٥٦٥٢٤- قال مقاتل بن سليمان: <q>﴿نزل به الروح الأمين﴾</q>، يعني: جبريل ﵇، أمين فيما استودعه الله ﷿ مِن الرسالة إلى الأنبياء ﵈{13}. (ز) ٥٦٥٢٥- عن عبد الملك ابن جُرَيج -من طريق حجاج- قال: <q>﴿الروح الأمين﴾</q> جبريل{14}. (ز) ٥٦٥٢٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿نزل به﴾</q> يعني: القرآن ... وهي تُقرأ على وجهين، بالرفع والنصب، فمن قرأها بالرفع قال: <q>﴿نَزَلَ به﴾</q> خفيفة <q>﴿الروح الأمين﴾</q> جبريل نزل به. ومَن قرأها بالنصب قال: ‹نَزَّلَ بِهِ› مثقلة، الله نزَّل به <q>﴿الرُّوحَ الأمينَ﴾</q>، الله نزَّل جبريل بالقرآن{15}. (ز) <q>﴿نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِینُ ۝١٩٣﴾</q> - آثار متعلقة بالآية ٥٦٥٢٧- عن الحسن، أظنُّه عن سعد، قال: قال النبي ﷺ: «ألا وإنّ الروح الأمين نفث في رُوعي أنه لن تموت نفس حتى تستكمل رزقها، وإن أبطأ عنها»{16}. (١١/٢٩٧) ٥٦٥٢٨- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «أيُّها الناس، إنّه ليس مِن شيء يُقَرِّبكم مِن الجنة ويبعدكم من النار إلا قد أمرتكم به، وليس شيء يقربكم من النار ويبعدكم من الجنة إلا قد نهيتكم عنه، وإنّ الروح الأمين نفث في روعي أنّه ليس مِن نفس تموت حتى تستوفي رزقها، فاتقوا الله، وأَجْمِلُوا في الطَّلَب، ولا يَحْمِلَنَّكم استبطاءُ الرزق على أن تطلبوه بمعاصي الله، فإنه لا ينال ما عند الله إلا بطاعته»{17}. (١١/٢٩٧) ٥٦٥٢٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: مَن كلَّمه الروحُ الأمينُ لم تأكله الأرض{11}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨١٧. وهي قراءة متواترة، قرأ بها يعقوب، وابن عامر، وحمزة، والكسائي، وخلف العاشر، وأبو بكر. وقرأ بقية العشرة: <q>﴿نَزَلَ بِهِ الرُّوحُ الأَمِينُ﴾</q> بتخفيف الزاي، ورفعهما. انظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٤.عزاه السيوطي إلى عبد بن حُمَيد.أخرجه إسحاق البستي في تفسيره ص٥٤٢.أخرجه أبو الشيخ في كتاب العظمة ٢/٨٠١. وعزاه السيوطي إلى ابن مردويه. رجال إسناده ثقات، سوى محمد بن سليمان البصري، قال عنه أبو حاتم كما في الجرح والتعديل ٧/٢٦٨: «شيخ».أخرجه ابن جرير ١٧/٦٤٢.أخرجه ابن جرير ١٧/٦٤٢، وإسحاق البستي في تفسيره ص٥٤٢. وعلَّقه ابن أبي حاتم ٩/٢٨١٧.أخرجه ابن أبي حاتم ٩/٢٨١٧.أخرجه ابن أبي حاتم ٩/٢٨١٧.علَّقه ابن أبي حاتم ٩/٢٨١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤١-٦٤٢، وابن أبي حاتم ٩/٢٨١٧. وعلَّقه يحيى بن سلّام ٢/٥٢٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨١٨.علَّقه يحيى بن سلّام ٢/٥٢٣.تفسير مقاتل بن سليمان ٣/٢٧٩.أخرجه ابن جرير ١٧/٦٤٢، وابن أبي حاتم ٩/٢٨١٧.تفسير يحيى بن سلّام ٢/٥٢٣.أخرجه ابن بشران في أماليه ٢/٢٣٢ (١٤١١) مطولًا. وعزاه السيوطي إلى ابن مردويه. إسناده ثقات، لكن فيه سليمان الأعمش يُدَلِّس كما في التقريب (٢٦١٥)، وقد عنعن.أخرجه ابن أبي شيبة ٧/٧٩ (٣٤٣٣٢) واللفظ له، والحاكم ٢/٥ (٢١٣٦)، والبغوي في تفسيره ٦/٢٥٤. قال الدارقطني في العلل ٥/٢٧٣ (٨٧٥): «يرويه إسماعيل بن أبي خالد، واختُلِف عنه؛ فقال هبيرة التمار أبو عمر المقري: عن هشيم، عن إسماعيل، عن زبيد، عن مرة، عن عبد الله. وغيره يرويه عن إسماعيل، عن زبيد مرسلًا، عن ابن مسعود. وهذا أصح». وقال البوصيري في إتحاف الخيرة ٣/٢٧٠ (٢٧٢٢/١) في رواية ابن راهويه: «فيه انقطاع». وقال فيه ٣/٢٧١ (٢٧٢٢/٣): «ورواه الحاكم في المستدرك، وله شاهد من حديث حذيفة، رواه البزار في مسنده. ورواه الطبراني في الكبير من حديث الحسن بن علي. ورواه ابن ماجه والحاكم والبيهقي في سننه الكبرى من حديث جابر بن عبد الله». وقال الألباني في الصحيحة ٦/٨٦٥-٨٦٧ (٢٨٦٦): «وبالجملة فحديث حسن على أقل الأحوال».أخرجه ابن أبي حاتم ٩/٢٨١٨.
26,194," <q>﴿عَلَىٰ قَلۡبِكَ لِتَكُونَ مِنَ ٱلۡمُنذِرِینَ ۝١٩٤﴾</q> - تفسير ٥٦٥٣٠- قال مقاتل بن سليمان: نزله <q>﴿على قلبك﴾</q> ليثبت به قلبك، يا محمد؛ <q>﴿لتكون من المنذرين﴾</q>{1}. (ز) ٥٦٥٣١- قال يحيى بن سلّام: <q>﴿على قلبك﴾</q> يا محمد{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٩.تفسير يحيى بن سلّام ٢/٥٢٤.
26,195," <q>﴿بِلِسَانٍ عَرَبِیࣲّ مُّبِینࣲ ۝١٩٥﴾</q> - تفسير ٥٦٥٣٢- عن بريدة [بن الحصيب]، في قوله: <q>﴿بلسان عربي مبين﴾</q>، قال: بلسان جُرْهُم{1}. (١١/٢٩٨) ٥٦٥٣٣- عن عبد الله بن بريدة -من طريق حسين بن واقد-، مثله{2}. (١١/٢٩٨) ٥٦٥٣٤- عن عبد الله بن عباس -من طريق عطاء- في قول الله تعالى: <q>﴿بلسان عربي مبين﴾</q>، قال: بلسان قريش، ولو كان غير عربيٍّ ما فهِموه، وما أنزل الله مِن السماء كتابًا إلا بالعبرانية{3}. (١١/٢٩٨) (ز) ٥٦٥٣٥- عن عبد الله بن عباس -من طريق قتادة- قال: نزل القرآن بلسان قريش، ولسان خزاعة، وذلك أنّ الدار واحدة{4}. (ز) ٥٦٥٣٦- عن مجاهد بن جبر -من طريق سيف المالكي- في قوله: <q>﴿بلسان عربي مبين﴾</q>، قال: بلسان قريش{5}. (١١/٢٩٨) ٥٦٥٣٧- قال مقاتل بن سليمان: أنزله <q>﴿بلسان عربي مبين﴾</q>؛ ليفقهوا ما فيه، [لقولهم]: إنما يعلمه أبو فَكِيهَة. وكان أبو فكيهة أعجميًّا{6}. (ز) ٥٦٥٣٨- عن الهذيل، عن رجل، عن الفضيل بن عيسى الرقاشي، قال: <q>﴿بلسان عربي مبين﴾</q>، قال: فضله على الألْسُن{7}. (ز) <q>﴿بِلِسَانٍ عَرَبِیࣲّ مُّبِینࣲ ۝١٩٥﴾</q> - آثار متعلقة بالآية ٥٦٥٣٩- عن موسى بن محمد بن إبراهيم التميمي، عن أبيه، قال: بينما رسولُ الله ﷺ مع أصحابه في يوم دَجَنٍ{8}، إذ قال لهم رسول الله ﷺ: «كيف ترون بَواسِقَها{9}؟». قالوا: ما أحسنَها وأشدَّ تراكمها. قال: «فكيف ترون قواعدها؟». قالوا: ما أحسنَها وأشدَّ تَمَكُّنِها. قال: «كيف ترون جَوْنَها؟». قالوا: ما أحسنَه وأشدَّ سواده. قال: «فكيف ترون رَحاها استدارت؟». قالوا: نعم، ما أحسنها وأشد استدارتها. قال: «كيف ترون برقها خفوًا، أو وميضًا، أم يشقُّ شقًّا؟». قالوا: بل يشقُّ شقًّا. قال: «الحياء الحياء، إن شاء الله». فقال له رجل: يا رسول الله، ما أفصحك! ما رأينا الذي هو أعرب منك. قال: فقال: «حُقَّ لي، وإنما نزل القرآن بلساني، والله يقول: <q>﴿بلسان عربي مبين﴾</q>»{10}{11}. (ز) ٥٦٥٤٠- عن يحيى ابن الضريس، يقول: سمعت سفيان الثوري يقول: لم ينزل وحيٌ إلا بالعربية، ثم ترجم كلُّ نبي لقومه، واللسان يوم القيامة بالسريانية، فمَن تكلم بالعربية دخل الجنة{12}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٤٣٩، والبيهقي في شعب الإيمان (١٦٢٢).أخرجه إسحاق البستي في تفسيره ص٥٤٢، وابن أبي حاتم ٩/٢٨١٨. وعزاه السيوطي إلى ابن المنذر.أخرجه الرافعي في تاريخ قزوين ٢/٤٨. وعزاه السيوطي إلى ابن النجار في تاريخه دون آخره.أخرجه ابن جرير ١/٦١.أخرجه ابن أبي حاتم ٩/٢٨١٨.تفسير مقاتل بن سليمان ٣/٢٨٠.تفسير مقاتل بن سليمان ٣/٢٨٣.الدَّجن: ظلُّ الغيم في اليوم المطير. لسان العرب (دجن).الباسِق: المرتفع فِي عُلُوّه. النهاية (بسق).أخرجه ابن أبي الدنيا في كتاب المطر والرعد ص٥٦-٥٧ (١٢)، والبيهقي في الشعب ٣/٣٣ (١٣٦٣)، وابن أبي حاتم ٩/٢٨١٨-٢٨١٩ (١٥٩٤٩). قال ابن الملقن في البدر المنير ٨/٢٨٢: «مرسلًا».أورد البيهقي عقب هذا الحديث: قول أبي عبيد: قوله: «قواعدها» يعني: قواعد السحاب وهي أصولها المعترضة، وفي آفاق السماء وإلى الأفق الآخر، و«الجون» الأسود، وقوله: «رحاها» فرحاها استدارة السحاب في السماء، و«الخفو» هو الاعتراض من البرق في نواحي بجسم، و«الوميض» أن يلمع قليلًا ثم يسكن، وليس له اعتراض، وأما الذي يشق شقًّا فاستطارته في الجو إلى وسط السماء من غير أن يأخذ يمينًا وشمالًا، والحياء هو المطر الواسع الغزير.أخرجه ابن أبي حاتم ٩/٢٨١٩.
26,196," <q>﴿وَإِنَّهُۥ لَفِی زُبُرِ ٱلۡأَوَّلِینَ ۝١٩٦﴾</q> - تفسير ٥٦٥٤١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإنه لفي زبر الأولين﴾</q>: أي: في كُتُب الأولين{1}. (١١/٢٩٩) ٥٦٥٤٢- عن إسماعيل السُّدِّيّ، مثل ذلك{2}. (ز) ٥٦٥٤٣- عن قتادة بن دعامة، في قوله: <q>﴿وإنه لفي زبر الأولين﴾</q>، قال: أي: وإنّ القرآن لفي كُتُب الأولين؛ التوراة والإنجيل{3}. (ز) ٥٦٥٤٤- قال إسماعيل السُّدِّيّ: <q>﴿وإنه لفي زبر الأولين﴾</q>، يقول: نعت محمد وأُمَّتُه في زبر الأولين{3}. (ز) ٥٦٥٤٥- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿وإنه لفي زبر الأولين﴾</q>، يقول: أمر محمد ﷺ ونعته في كتب الأولين{5}. (ز) ٥٦٥٤٦- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ- <q>﴿وإنه لفي زبر الأولين﴾</q>، يقول: في الكتب التي أنزلها على الأولين{6}. (١١/٢٩٩) ٥٦٥٤٧- قال يحيى بن سلّام: يعني: في كتاب الأولين{7}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.علَّقه ابن أبي حاتم ٩/٢٨٢٠.علَّقه يحيى بن سلّام ٢/٥٢٤.علَّقه يحيى بن سلّام ٢/٥٢٤.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن أبي حاتم ٩/٢٨١٩.تفسير يحيى بن سلّام ٢/٥٢٤.
26,197," <q>﴿أَوَلَمۡ یَكُن لَّهُمۡ ءَایَةً أَن یَعۡلَمَهُۥ عُلَمَـٰۤؤُا۟ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٩٧﴾</q> - قراءات ٥٦٥٤٨- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿أوَ لَمْ يَكُن لَّهُمْ آيَةً﴾</q> بالياء{1}. (١١/٢٩٩) ٥٦٥٤٩- قال يحيى بن سلّام: <q>﴿أوَ لَمْ يَكُن لَّهُمْ آيَةً﴾</q> وهي تقرأ على وجهين، بالتاء والياء{2}. (ز) <q>﴿أَوَلَمۡ یَكُن لَّهُمۡ ءَایَةً﴾</q> - تفسير ٥٦٥٥٠- تفسير الحسن البصري: أي: فقد كان لهم في إيمانهم به آية{3}. (ز) ٥٦٥٥١- قال مقاتل بن سليمان: ثم قال: <q>﴿أو لم يكن﴾</q> محمدٌ ﷺ <q>﴿لهم آية﴾</q> يعني: لكفار مكة{4}. (ز) ٥٦٥٥٢- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿أولم يكن لهم آية﴾</q> قال: محمد <q>﴿أن يعلمه﴾</q> قال: يعرفه <q>﴿علماء بني إسرائيل﴾</q>{5}. (ز) ٥٦٥٥٣- عن مبشر بن عبيد القرشي -من طريق عبد الواحد بن ميسرة- في قوله: <q>﴿أو لم يكن لهم آية﴾</q>، يقول: أولم يكن لهم القرآن آية{6}. (١١/٣٠٠) ٥٦٥٥٤- قال يحيى بن سلّام: <q>﴿أولم يكن لهم آية﴾</q>، فمَن قرأها بالتاء يقول: قد كانت لهم آية، ومَن قرأها بالياء فيجعلها عملًا في باب كان، يقول: قد كان لهم آية{2}. (ز) <q>﴿أَن یَعۡلَمَهُۥ عُلَمَـٰۤؤُا۟ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٩٧﴾</q> - تفسير ٥٦٥٥٥- عن عبد الله بن عباس -من طريق العوفي- قال: كان عبدُ الله بنُ سلام من علماء بني إسرائيل، وكان من خيارهم، فآمن بكتاب محمد ﷺ، فقال لهم الله: <q>﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</q>{8}. (١١/٢٩٩) ٥٦٥٥٦- قال عبد الله بن عباس: بعث أهل مكة إلى اليهود وهم بالمدينة، فسألوهم عن محمد ﷺ، فقالوا: إنّ هذا لَزمانُه، وإنّا نجد في التوراة نعتَه وصفتَه. فكان ذلك آيةً لهم على صِدقه{9}٤٨٢٣. (ز) ٤٨٢٣ ذكر ابنُ عطية (٦/٥٠٥) أثر ابن عباس، ثم علَّق عليه بقوله: «ويؤيد هذا كون الآية مكية». ثم وجَّه معنى الآية على القول بمكيتها قائلًا: «فمن قال: إنها مكية. ذهب إلى أن علماء بني إسرائيل ذكروا أنّ في التوراة صفة النبي ﷺ، وهذه الإشارة إلى ذلك». ٥٦٥٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أولم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</q>، قال: عبد الله بن سلام وغيره مِن علمائهم{10}. (١١/٢٩٩) ٥٦٥٥٨- عن عطية العوفي -من طريق عمرو بن قيس- في قوله: <q>﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</q>، قال: كانوا خمسة: أسد، وأَسِيد، وابن يامين، وثعلبة، وعبد الله بن سلام{11}. (١١/٣٠٠) ٥٦٥٥٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</q>، قال: أولم يكن النبي آية -علامة- أنّ علماء بني إسرائيل كانوا يعلمون أنّهم كانوا يجدونه مكتوبًا عندهم{12}. (ز) ٥٦٥٦٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أو لم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</q>، قال: يعني بذلك: اليهود والنصارى، كانوا يعلمون أنّهم يجدون محمدًا ﷺ مكتوبًا عندهم في التوراة والإنجيل أنّه رسول الله{13}. (١١/٢٩٩) ٥٦٥٦١- قال مقاتل بن سليمان: <q>﴿أن يعلمه علماء بني إسرائيل﴾</q>، يعني: ابن سلام وأصحابه{4}. (ز) ٥٦٥٦٢- قال يحيى بن سلّام: <q>﴿أن يعلمه علماء بني إسرائيل﴾</q>، يعني: مَن آمن منهم{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا ابن عامر، فإنه قرأ: ‹أوَ لَمْ تَكُن لَّهُمْ آيَةٌ› بالتاء، ورفع ‹آيَةٌ›. ينظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٤.تفسير يحيى بن سلّام ٢/٥٢٤.علَّقه يحيى بن سلّام ٢/٥٢٤.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن جرير ١٧/٦٤٥.أخرجه ابن أبي حاتم ٩/٢٨١٩.تفسير يحيى بن سلّام ٢/٥٢٤.أخرجه ابن جرير ١٧/٦٤٤، وابن أبي حاتم ٩/٢٨٢٠. وعزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٧/١٨٠، وتفسير البغوي ٦/١٢٩.تفسير مجاهد ص٥١٤ وزاد: من أسلم منهم، وأخرجه ابن جرير ١٧/٦٤٤-٦٤٥، وابن أبي حاتم ٩/٢٨١٩، وأخرجه يحيى بن سلّام ٢/٥٢٤ من طريق ابن مجاهد، وإسحاق البستي في تفسيره ص٥٤٣ من طريق ابن جريج. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن سعد ٢/٣٥٣، وابن أبي حاتم ٩/٢٨٢٠. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤٥، وابن أبي حاتم ٩/٢٨١٩-٢٨٢٠.أخرجه ابن أبي حاتم ٩/٢٨١٩-٢٨٢٠. وعلَّقه يحيى بن سلّام ٢/٥٢٤. وعزاه السيوطي بهذا اللفظ إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وهو عند عبد الرزاق وابن جرير بالطريق واللفظ السابق.تفسير مقاتل بن سليمان ٣/٢٨٠.تفسير يحيى بن سلّام ٢/٥٢٤.
26,198," <q>﴿وَلَوۡ نَزَّلۡنَـٰهُ عَلَىٰ بَعۡضِ ٱلۡأَعۡجَمِینَ ۝١٩٨ فَقَرَأَهُۥ عَلَیۡهِم مَّا كَانُوا۟ بِهِۦ مُؤۡمِنِینَ ۝١٩٩﴾</q> - تفسير ٥٦٥٦٣- عن محمد بن أبي موسى، قال: كنت واقفًا إلى جنب عبد الله بن مطيع بعَرَفة، فتلا هذه الآية: <q>﴿ولو نزلناه على بعض الأعجمين (١٩٨) فقرأه عليهم ما كانوا به مؤمنين﴾</q>. قال: جملي هذا أعجم، فلو أُنزِل على هذا ما كانوا به مؤمنين{1}. (ز) ٥٦٥٦٤- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿فقرأه عليهم﴾</q>: محمد ﷺ{2}. (ز) ٥٦٥٦٥- عن سفيان: أخبرني مَن سمع مجاهدًا يقول: <q>﴿ولو نزلناه على بعض الاعجمين﴾</q> قال: دواب العجم، <q>﴿فقرأه عليهم ما كانوا به مؤمنين﴾</q> لا يؤمنون كما لا يؤمن دوابُّ العجم، لو قُرِئ عليهم ما كانوا به مؤمنين{3}. (ز) ٥٦٥٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولو نزلناه على بعض الأعجمين﴾</q>، قال: يقول: لو نزلنا هذا القرآن على بعض الأعجمين لكانت العرب أشرَّ الناس فيه، لا يفهمونه ولا يدرون ما هو{4}. (١١/٣٠٠) ٥٦٥٦٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولو نزلناه على بعض الأعجمين﴾</q>، قال: لو أنزله الله أعجميًّا لكانوا أخسَّ الناس به؛ لأنهم لا يعرفون العجمية{5}٤٨٢٤. (١١/٣٠٠) ٤٨٢٤ انتقد ابنُ جرير (١٧/٦٤٧) قول قتادة مستندًا إلى لفظ الآية قائلًا: «وهذا الذي ذكرناه عن قتادة قولٌ لا وجْه له؛ لأنه وجَّه الكلام إلى أن معناه: ولو نزَّلناه أعجميًّا، وإنما التنزيل: <q>﴿ولَوْ نَزَّلْناهُ عَلى بَعْضِ الأَعْجَمِينَ﴾</q>، يعني: ولو نزَّلنا هذا القرآن العربيّ على بهيمة ٍمن العَجَم أو بعض ما لا يُفْصِح، ولم يَقُلْ: ولو نزَّلناه أعجميًّا. فيكون تأويل الكلام ما قاله». ٥٦٥٦٨- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولو نزلناه على بعض الأعجمين﴾</q>، قال: الفُرْس{6}. (١١/٣٠١) ٥٦٥٦٩- قال مقاتل بن سليمان: ثم قال: <q>﴿ولو نزلناه﴾</q> يعني: القرآن <q>﴿على بعض الأعجمين﴾</q> يعني: أبا فكيهة، يقول: لو أنزلناه على رجل ليس بعربي اللسان، <q>﴿فقرأه عليهم﴾</q> على كفار مكة، لقالوا: ما نفقه قوله؛ و<q>﴿ما كانوا به مؤمنين﴾</q> يعني: بالقرآن مُصَدِّقين بأنّه مِن الله ﷿{7}. (ز) ٥٦٥٧٠- عن عبد الرحمن الأوزاعي، قال: سمعت في قول الله: <q>﴿ولو نزلناه على بعض الأعجمين فقرأه عليهم ما كانوا به مؤمنين﴾</q>، لأنّه لو أنزله على بعض الأعجمين ما كانوا ليؤمنوا به، وهم يجدونه في زبر الأولين: أنه يبعث بلسان عربي{3}. (ز) ٥٦٥٧١- قال يحيى بن سلّام: <q>﴿ولو نزلناه﴾</q> يعني: القرآن ... <q>﴿ما كانوا به مؤمنين﴾</q> يقول: لو أنزلناه بلسان عجمي لم تؤمن به العرب. كقوله: <q>﴿وما أرسلنا من رسول إلا بلسان قومه﴾</q> [إبراهيم:٤]{9}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٦٤٧، وابن أبي حاتم ٩/٢٨٢٠.أخرجه إسحاق البستي في تفسيره ص٥٤٣، وابن أبي حاتم ٩/٢٨٢١، وأخرجه يحيى بن سلّام ٢/٥٢٤ من طريق ابن مجاهد.أخرجه ابن أبي حاتم ٩/٢٨٢١.أخرجه ابن أبي حاتم ٩/٢٨٢٠. وعلَّقه يحيى بن سلّام ٢/٥٢٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٧٦، وابن جرير ١٧/٦٤٧. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم، وقد وقع في مطبوعة تفسير ابن أبي حاتم ٩/٢٨٢١: حدثنا علي بن الحسين، قال: حدثنا الهيثم بن يمان، قال: حدثنا الحكم، عن السدي: في قوله: <q>﴿ولَوْ نَزَّلْناهُ عَلى بَعْضِ الأَعْجَمِينَ﴾</q> ... ووقع بعد الآية إسناد أثر آخر دون أن يُذكر تفسير السدي.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن أبي حاتم ٩/٢٨٢١.تفسير يحيى بن سلّام ٢/٥٢٤.
  26,199,""
26,200," <q>﴿كَذَ ٰ⁠لِكَ سَلَكۡنَـٰهُ فِی قُلُوبِ ٱلۡمُجۡرِمِینَ ۝٢٠٠﴾</q> - تفسير ٥٦٥٧٢- عن عبد الله بن عباس، في قوله: <q>﴿كذلك سلكناه﴾</q> قال: أدخلنا الشرك والتكذيب <q>﴿في قلوب المجرمين﴾</q>{1}. (ز) ٥٦٥٧٣- عن عبد الله بن عباس -من طريق الضحاك- <q>﴿المجرمين﴾</q>: الكُفّار{2}. (ز) ٥٦٥٧٤- عن أنس بن مالك -من طريق حميد الطويل- في قوله: <q>﴿كذلك سلكناه في قلوب المجرمين﴾</q>، قال: الشِّرْك، سلكه في قلوب المشركين{3}. (ز) ٥٦٥٧٥- عن مجاهد بن جبر، في قوله: <q>﴿كذلك سلكناه﴾</q> قال: أدخلنا الشرك والتكذيب <q>﴿في قلوب المجرمين﴾</q>{1}. (ز) ٥٦٥٧٦- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- في قوله: <q>﴿كذلك سلكناه في قلوب المجرمين﴾</q>، قال: القَسْوَة{5}. (ز) ٥٦٥٧٧- عن الحسن البصري -من طريق حماد بن سلمة، عن حُمَيد- في قوله: <q>﴿كذلك سلكناه﴾</q>، قال: الشرك، جعلناه في قلوب المجرمين{6}. (١١/٣٠١) ٥٦٥٧٨- عن الحسن البصري -من طريق سفيان، عن حُمَيد- في هذه الآية: <q>﴿كذلك سلكناه في قلوب المجرمين﴾</q>، قال: خَلَقْناه{7}. (ز) ٥٦٥٧٩- عن قتادة بن دعامة -من طريق همام- في قوله: <q>﴿كذلك سلكناه﴾</q>، قال: جعلناه{8}. (ز) ٥٦٥٨٠- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿كذلك سلكناه﴾</q> قال: الكفر <q>﴿في قلوب المجرمين﴾</q>{7}. (ز) ٥٦٥٨١- قال مقاتل بن سليمان: <q>﴿كذلك سلكناه﴾</q> يعني: هكذا جعلنا الكفر بالقرآن <q>﴿في قلوب المجرمين﴾</q>{10}. (ز) ٥٦٥٨٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كذلك سلكناه في قلوب المجرمين﴾</q> [قال: الشرك]{11}٤٨٢٥. (ز) ٤٨٢٥ لم يذكر ابنُ جرير (١٧/٦٤٨-٦٤٩) في معنى: <q>﴿كَذَلِكَ سَلَكْناهُ فِي قُلُوبِ المُجْرِمِينَ﴾</q> سوى قول الحسن، وابن جريج، وابن زيد. ٥٦٥٨٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿كذلك سلكناه﴾</q> جعلناه <q>﴿في قلوب المجرمين﴾</q> المشركين، التكذيب{12}. (ز) ",footnotes:1:تفسير البغوي ٦/١٢٩.أخرجه ابن أبي حاتم ٩/٢٨٢٢.أخرجه ابن أبي حاتم ٩/٢٨٢١-٢٨٢٢.تفسير البغوي ٦/١٢٩.أخرجه ابن أبي حاتم ٩/٢٨٢٩.أخرجه ابن جرير ١٧/٦٤٩ بلفظ: الشرك سلكه في قلوبهم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٦٤٩.أخرجه ابن أبي حاتم ٩/٢٨٢١.أخرجه ابن جرير ١٧/٦٤٩.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن جرير ١٧/٦٤٩. وعلَّقه ابن أبي حاتم ٩/٢٨٢١. وما بين المعقوفين ساقط من نسخة ابن جرير، ويدل عليه ما علَّقه ابن أبي حاتم.تفسير يحيى بن سلّام ٢/٥٢٥.
26,201," <q>﴿لَا یُؤۡمِنُونَ بِهِۦ حَتَّىٰ یَرَوُا۟ ٱلۡعَذَابَ ٱلۡأَلِیمَ ۝٢٠١﴾</q> - تفسير ٥٦٥٨٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿لا يؤمنون به﴾</q>، قال: إذا كذَّبوا سَلَك الله في قلوبهم ألّا يؤمنوا به{1}. (ز) ٥٦٥٨٥- عن إسماعيل السُّدِّيّ، <q>﴿لا يؤمنون به﴾</q>، يقول: لا يؤمنون بما جاء به محمدٌ ﷺ{1}. (ز) ٥٦٥٨٦- قال مقاتل بن سليمان: <q>﴿لا يؤمنون به﴾</q> يعني: بالقرآن <q>﴿حتى يروا العذاب الأليم﴾</q> يعني: الوجيع{3}. (ز) ٥٦٥٨٧- عن أصبغ، قال: سمعت عبد الرحمن بن زيد بن أسلم، في قول الله تعالى: <q>﴿سلكناه في قلوب المجرمين لا يؤمنون به﴾</q>، قال: هي كما قال: هو أضلَّهم، ومنعهم الإيمان{1}. (ز) ٥٦٥٨٨- قال يحيى بن سلّام: قوله ﷿: <q>﴿لا يؤمنون به﴾</q> بالقرآن <q>﴿حتى يروا العذاب الأليم﴾</q> المُوجِع، يعني: قيام الساعة{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٢.أخرجه ابن أبي حاتم ٩/٢٨٢٢.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن أبي حاتم ٩/٢٨٢٢.تفسير يحيى بن سلّام ٢/٥٢٥.
26,202," <q>﴿فَیَأۡتِیَهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٢٠٢﴾</q> - قراءات ٥٦٥٨٩- عن الحسن البصري -من طريق الحسام- أنّه قرأ: (فَتَأْتِيهِم بَغْتَةً) بالتاء. فقال له رجل: يا أبا سعيد، إنما يأتيهم العذاب بغتة. فانتهره الحسن، وقال: إنما هي الساعة{1}. (ز) <q>﴿فَیَأۡتِیَهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٢٠٢﴾</q> - تفسير الآية ٥٦٥٩٠- قال مقاتل بن سليمان: <q>﴿فيأتيهم﴾</q> العذاب <q>﴿بغتة﴾</q> يعني: فجأة، <q>﴿وهم لا يشعرون﴾</q>{2}. (ز) ٥٦٥٩١- قال يحيى بن سلّام: قوله ﷿: <q>﴿فيأتيهم بغتة﴾</q> فجأة{3}. (ز) ",footnotes:1:أخرجه الثعلبي ٧/١٨١. وهي قراءة شاذة. انظر: المحتسب ٢/١٣٧.تفسير مقاتل بن سليمان ٣/٢٨٠.تفسير يحيى بن سلّام ٢/٥٢٥.
26,203," <q>﴿فَیَقُولُوا۟ هَلۡ نَحۡنُ مُنظَرُونَ ۝٢٠٣﴾</q> - تفسير ٥٦٥٩٢- قال مقاتل بن سليمان: فيتَمَنَّوْن الرجعة والنظرة، فذلك قوله سبحانه: <q>﴿فيقولوا﴾</q> يعني: كفار مكة: <q>﴿هل نحن منظرون﴾</q> فنعتب ونراجع{1}. (ز) ٥٦٥٩٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿فيقولوا﴾</q> يومئذ عند ذلك: <q>﴿هل نحن منظرون﴾</q> مُؤَخَّرون، مردودون إلى الدنيا؛ فنُؤْمِن{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٨٠.تفسير يحيى بن سلّام ٢/٥٢٥.
26,204," <q>﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</q> - نزول الآية ٥٦٥٩٤- قال مقاتل بن سليمان: فلمّا أوعدهم النبيُّ ﷺ العذابَ قالوا: فمتى هذا العذاب؟ تكذيبًا به. يقول الله ﷿: <q>﴿أفبعذابنا يستعجلون﴾</q>{1}. (ز) <q>﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</q> - تفسير الآية ٥٦٥٩٥- قال يحيى بن سلّام: قال الله: <q>﴿أفبعذابنا يستعجلون﴾</q> على الاستفهام، أي: قد استعجلوا به لقولهم: <q>﴿ائتنا بعذاب الله﴾</q> [العنكبوت:٢٩]، وذلك منهم استهزاء وتكذيب بأنّه لا يأتيهم العذاب{2}. (ز) <q>﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝٢٠٤﴾</q> - آثار متعلقة بالآية ٥٦٥٩٦- عن أنس بن مالك: أنّ رسول الله ﷺ عادَ رجلًا مِن المسلمين قد خفت فصارَ مِثل الفَرْخ، فقال له رسول الله ﷺ: «هل كنت تدعو بشيء، أو تسأله إيّاه؟». قال: نعم، كنت أقول: اللهم، ما كنت معاقبي به في الآخرة فعجِّله لي في الدنيا. فقال رسول الله ﷺ: «سبحان الله! لا تُطِيقه –أو: لا تستطيعه-، أفلا قلتَ: اللهم، آتِنا في الدنيا حسنة، وفي الآخرة حسنة، وقنا عذاب النار؟!». قال: فدعا اللهَ له، فشفاه{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٨٠. وفي تفسير الثعلبي ٧/١٨١، وتفسير البغوي ٦/١٣٠ مثله منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلّام ٢/٥٢٥.أخرجه مسلم ٤/٢٠٦٨ (٢٦٨٨)، وابن جرير ٣/٥٤٥، وابن أبي حاتم ٩/٢٨٢٢ (١٥٩٩٦)، والبغوي في تفسيره ١/٢٣٣. وأورده الثعلبي ٢/١١٦.
26,205," <q>﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</q> - نزول الآيات ٥٦٥٩٧- عن أبي جَهْضَمٍ، قال: رُئي النبيُّ ﷺ كأنّه مُتَحَيِّر، فسألوه عن ذلك، فقال: «ولِمَ؟! ورأيت عَدُوِّي يَلُونَ أمر أمتي من بعدي». فنزلت: <q>﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</q> فطابت نفسُه{1}. (١١/٣٠١) <q>﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</q> - تفسير الآيات ٥٦٥٩٨- عن عكرمة مولى ابن عباس، <q>﴿أفرأيت إن متعناهم سنين﴾</q>، قال: مثل عمر الدنيا{2}. (ز) ٥٦٥٩٩- عن أبي زيد فيض بن إسحاق، قال: سألتُ الفُضَيل بن عياض عن قول الله ﷿: <q>﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</q>، قال: قراءتها تفسيرُها{3}. (ز) ٥٦٦٠٠- قال مقاتل بن سليمان: <q>﴿أفرأيت إن متعناهم سنين﴾</q> في الدنيا، <q>﴿ثم جآءهم﴾</q> بعد ذلك العذاب <q>﴿ما كانوا يوعدون * مآ أغنى عنهم﴾</q> مِن العذاب <q>﴿ما كانوا يمتعون﴾</q> في الدنيا{4}. (ز) ٥٦٦٠١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أفرأيت إن متعناهم سنين﴾</q> إلى قوله: <q>﴿ما أغنى عنهم ما كانوا يمتعون﴾</q>، قال: هؤلاء أهل الكفر{5}. (ز) ٥٦٦٠٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿ثم جاءهم ما كانوا يوعدون﴾</q> العذاب{6}. (ز) <q>﴿أَفَرَءَیۡتَ إِن مَّتَّعۡنَـٰهُمۡ سِنِینَ ۝٢٠٥ ثُمَّ جَاۤءَهُم مَّا كَانُوا۟ یُوعَدُونَ ۝٢٠٦ مَاۤ أَغۡنَىٰ عَنۡهُم مَّا كَانُوا۟ یُمَتَّعُونَ ۝٢٠٧﴾</q> - آثار متعلقة بالآية ٥٦٦٠٣- عن سليمان بن عبد الملك -من طريق يزيد بن حازم- أنّه كان لا يَدَعُ أن يقول في خطبته كل جمعة: إنما أهل الدنيا فيها على وجَل، لم تمضِ بهم نِيَّة، ولم تَطْمَئِنَّ لهم دارٌ، حتى يأتي أمرُ الله وهم على ذلك، لا يدوم نعيمها، ولا تؤمن فجعاتها، ولا يبقى فيها شيء. ثم يتلو: <q>﴿أفَرَأَيْتَ إنْ مَتَّعْناهُمْ سِنِينَ (٢٠٥) ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ (٢٠٦) ما أغْنى عَنْهُمْ ما كانُوا يُمَتَّعُونَ (٢٠٧)﴾</q>{7}. (١١/٣٠١) ٥٦٦٠٤- عن عبيد الله بن موسى، قال: سمعت الحسن بن صالح يقول: لقد دخل الترابَ مِن هذا المِصْرَ قومٌ قطعوا عنهم الدنيا بالصبر على طاعة الله، وبيَّن لهم هذا القرآنُ غِيَر{8} الدنيا، قال: <q>﴿أفرأيت إن متعناهم سنين ثم جاءهم ما كانوا يوعدون ما أغنى عنهم ما كانوا يمتعون﴾</q>. ثم بكى حسن، ثم قال: إذا جاء الموتُ وسَكَراتُه لم يُغْنِ عن الفتى ما كان فيه مِن النعيم واللذة. ثم مال مَغْشِيًّا عليه{9}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٢٣ (١٥٩٩٧) مرسلًا.أخرجه يحيى بن سلّام ٢/٥٢٥.أخرجه ابن أبي حاتم ٩/٢٨٢٣.تفسير مقاتل بن سليمان ٣/٢٨٠.أخرجه ابن جرير ١٧/٦٥١، وابن أبي حاتم ٩/٢٨٢٣ مختصرًا من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٢٥.أخرجه ابن أبي الدنيا في كتاب ذم الدنيا -موسوعة الإمام ابن أبي الدنيا ٥/١٣٠-١٣١ (٢٧١)-، وابن أبي حاتم ٩/٢٨٢٢ (١٥٩٩٦). وعزاه السيوطي إلى عبد بن حميد.غِيَر الدنيا: تغيُّر حالها، وانتقالها عن الصلاح إلى الفساد. النهاية (غير).أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢٣٣ (٦١)-.
  26,206,""
