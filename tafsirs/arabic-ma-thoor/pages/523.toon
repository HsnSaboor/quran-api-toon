quran[23]{c,v,t}:
  51,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ مَاۤ أَتَى ٱلَّذِینَ مِن قَبۡلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوۡ مَجۡنُونٌ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿ما أتى الَّذِينَ مِن قَبْلِهِمْ﴾</span> يعني: الأمم الخالية <span class="qpc-hafs">﴿مِن رَسُولٍ إلّا قالُوا﴾</span> لرسولهم: هو <span class="qpc-hafs">﴿ساحِرٌ أوْ مَجْنُونٌ﴾</span> كقول كُفّار مكة لمحمد ﷺ{1}<span class=comment-ref>٦٢١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٩</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٨١): «وقوله تعالى: <span class="qpc-hafs">﴿كذلك﴾</span> تقديره: سيرة الأمم كذلك، أو الأمر في القديم كذلك. وقوله: <span class="qpc-hafs">﴿إلا قالوا ساحر أو مجنون﴾</span> معناه: إلا قال بعض هذا، وبعض الجميع، ألا ترى أنّ قوم نوح لم يقولوا قط: ساحر. وإنما قالوا: <span class="qpc-hafs">﴿به جنة﴾</span> [سبأ:٨]! فلما اختلف الفرق جعل الخبر عن ذلك بإدخال <span class="qpc-hafs">﴿أو﴾</span> بين الصفتين، وليس المعنى أنّ كلّ أمة قالت عن نبيها: إنه ساحر أو هو مجنون، فليست هذه كالمتقدمة في فرعون، بل هذه كأنه قال: إلا قالوا: هو ساحر، وهو مجنون».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣٣.
  51,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَتَوَاصَوۡا۟ بِهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أتَواصَوْا بِهِ﴾</span>، قال: هل أوصى الأوّلُ الآخرَ منهم بالتكذيب؟!{1}. (١٣/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أتَواصَوْا بِهِ﴾</span> يقول: أوصى الأولُ الآخرَ أن يقولوا ذلك لرسلهم؟! ثم قال: <span class="qpc-hafs">﴿بَلْ هُمْ قَوْمٌ طاغُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلۡ هُمۡ قَوۡمࣱ طَاغُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٥١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿بَلْ هُمْ قَوْمٌ طاغُونَ﴾</span> حمَلهم الطغيانُ فيما أعطَيتهم ووسّعتُ عليهم على تكذيبك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ هُمْ قَوْمٌ طاغُونَ﴾</span>، يعني: عاصين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٥٠، ومن طريق سعيد بنحوه. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٣٣.|3:تفسير البغوي ٧/٣٨٠.|4:تفسير مقاتل بن سليمان ٤/١٣٣.
  51,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤ وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾</span> - نزول الآيتين</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٥٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، قال: لَمّا نَزَلَتْ: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> لم يَبقَ مِنّا أحدٌ إلا أيقن بالهَلكة؛ إذ أُمر النبيُّ ﷺ أن يتولّى عنّا؛ فنَزَلَتْ: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فطابتْ أنفسُنا{1}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: ما نَزَلَتْ علينا آيةٌ كانت أشدّ علينا منها، ولا أعظم علينا منها، فقلنا: ما هذا إلا مِن سَخْطةٍ أو مقْتٍ. حتى نَزَلَتْ: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{2}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٥<span class="dash">-</span></span> عن <span class="name-3">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: ذُكِر لنا: أنها لما نَزَلَتْ اشتدَّ على أصحاب رسول الله ﷺ، ورأوا أنّ الوحي قد انقطع، وأنّ العذاب قد حضر، فأنزل الله بعد ذلك: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{3}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> يعني: فأعْرِض عنهم، فقد بلَّغتَ وأعذَرتَ، <span class="qpc-hafs">﴿فَما أنْتَ﴾</span> يا محمد <span class="qpc-hafs">﴿بِمَلُومٍ﴾</span> يقول: فلا تُلام، فحزن النبيُّ ﷺ مخافة أن ينزل بهم العذاب؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤ وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾</span> - تفسير الآيتين، والنسخ فيهما</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٥٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>، قال: ذَكِّر بالقرآن{5}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: أمره الله أن يتولّى عنهم ليعذّبهم، وعذر محمدًا ﷺ، ثم قال: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فنَسَختْها{6}. (١٣/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: محمد ﷺ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> قال: فأَعرَض عنهم، فقيل له: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فوَعَظهم{8}. (١٣/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> أنّ التولي عنهم منسوخ؛ بأنّه قد أُمِر بالإقبال عليهم بالموعظة، قال تعالى: <span class="qpc-hafs">﴿يا أيُّها الرَّسُولُ بَلِّغْ ما أُنْزِلَ إلَيْكَ مِن رَبِّكَ وإنْ لَمْ تَفْعَلْ فَما بَلَّغْتَ رِسالَتَهُ﴾</span> [المائدة:٦٧]{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن شهاب الزُّهريّ</span>: وقال تعالى في سورة الذّاريات: <span class="qpc-hafs">﴿فتول عنهم فما أنت بملوم﴾</span>، نُسِختْ بقوله: <span class="qpc-hafs">﴿وذكر فإن الذكرى تنفع المؤمنين﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق القاسم بن عبد الله- أنه قال: ويقول في الذّاريات: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span> أمره أن يتولى عنهم ليعذّبهم، وعذر محمدًا النبي محمد ﷺ، ثم قال: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> عِظ بالقرآن مَن آمن مِن قومك؛ فإنّ الذكرى تنفعهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> يعني: فأعْرِض عنهم، فقد بلَّغتَ وأعذَرتَ، <span class="qpc-hafs">﴿فَما أنْتَ﴾</span> يا محمد <span class="qpc-hafs">﴿بِمَلُومٍ﴾</span> يقول: فلا تلام، فحزن النبيُّ ﷺ مخافةَ أن ينزل بهم العذاب؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> فوعظ كفارَ مكة بوعيد القرآن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span> معناه: عِظ بالقرآن كفار مكة؛ فإنّ الذكرى تنفع مَن سبق في عِلم الله أن يؤمن منهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٦٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ فَما أنْتَ بِمَلُومٍ﴾</span>، قال: قد بلَّغتَ ما أرسلناك به، فلستَ بملوم. قال: وكيف يلومه، وقد أدّى ما أُمر به؟!{3}<span class=comment-ref>٦٢٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨١) في معنى الآية <b>احتمالين</b>، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فتول عنهم﴾</span> أي: عن الحرص المُفرط عليهم، وذهاب النفس حسرات. و<b>يحتمل</b> أن يراد: فتولّ عن التعب المفرط في دعائهم وضمهم إلى الإسلام، فلست بمصيطر عليهم، ولست بملوم إذ قد بلغت، فنحّ نفسك عن الحزن عليهم، وذكِّر فقط، فإن الذكرى نافعة للمؤمنين، ولمن قضي له أن يكون منهم في ثاني حال». ثم <span class="comment-type-4">علّق</span> على الاحتمال الثاني، فقال: «وعلى هذا التأويل فلا نسخ في الآية، إلا في معنى الموادعة التي فيها، فإن آية السيف نسخَتْ جميع الموادعات».</div></p><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡ فَمَاۤ أَنتَ بِمَلُومࣲ ۝٥٤ وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٦٨<span class="dash">-</span></span> عن سليمان بن حبيب المحاربي، قال: مَن وجد للذكرى في قلبه موقعًا فليعلم أنّه مؤمن؛ قال الله: <span class="qpc-hafs">﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</span>{16}. (١٣/٦٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق بن راهويه -كما في المطالب (٤١١٦)-، وأحمد بن منيع -كما في المطالب (٤١١٧)-، والهيثم بن كليب -كما في المطالب ٩/٤٣-، والبيهقي في شعب الإيمان (١٧٥٠)، والضياء في المختارة (٧١٤). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|2:أخرجه إسحاق بن راهويه -كما في المطالب (٤١١٥)-، وابن جرير ٢١/٥٥٢. وعزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ٢١/٥٥٢.|4:تفسير مقاتل بن سليمان ٤/١٣٣.|5:أخرجه إسحاق بن راهويه -كما في المطالب (٤١١٥)-. وعزاه السيوطي إلى ابن مردويه.|6:عزاه السيوطي إلى أبي داود في ناسخه، وابن المنذر.|7:تفسير مجاهد ص٦٢١، وأخرجه ابن جرير ٢١/٥٥٢.|8:أخرجه ابن جرير ٢١/٥٥١، ٥٥٣. وعزاه السيوطي إلى ابن المنذر.|9:علقه النحاس في الناسخ والمنسوخ (ت: اللاحم) ٣/٢٨.|10:الناسخ والمنسوخ للزهري ص٣٥.|11:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٨٣ (١٨٠).|12:تفسير البغوي ٧/٣٨٠.|13:تفسير مقاتل بن سليمان ٤/١٣٣.|14:تفسير البغوي ٧/٣٨٠.|15:أخرجه ابن جرير ٢١/٥٥٢.|16:عزاه السيوطي إلى ابن المنذر.
  51,55,""
  51,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا خَلَقۡتُ ٱلۡجِنَّ وَٱلۡإِنسَ إِلَّا لِیَعۡبُدُونِ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٦٩<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: <span class="qpc-hafs">﴿إلا لِيَعْبُدُونِ﴾</span>، أي: إلا لِآمرهم أن يعبدوني، وأدعوهم إلى عبادتي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلّا لِيَعْبُدُونِ﴾</span>، قال: ليُقِرّوا بالعبودية طوعًا أو كرهًا{2}<span class=comment-ref>٦٢٢١</span>. (١٣/٦٨٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢١</span> ذكر <u>ابنُ عطية</u> (٨/٨٢) قولًا آخر لابن عباس، و<span class="comment-type-4">علّق</span> عليه فقال: «وقال ابن عباس أيضًا: معنى: <span class="qpc-hafs">﴿ليعبدونِ﴾</span> أي: ليتذللوا لي ولقدرتي، وإن لم يكن ذلك على قوانين الشرع. وعلى هذا التأويل فجميع الجن والإنس عابد متذلّل، والكفار كذلك، ألا تراهم عند القَحْط والأمراض وغير ذلك!».</div></p><p><div></p><p><p><span class="item-no">٧٢٧٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلّا لِيَعْبُدُونِ﴾</span>، قال: على ما خلقتُهم عليه مِن طاعتي ومعصيتي، وشِقوتي وسعادتي{3}. (١٣/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله ﷿: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلّا لِيَعْبُدُونِ﴾</span>، قال: إلّا ليعرفوني{4}<span class=comment-ref>٦٢٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/١١٩) نحو قول مجاهد عن ابن عباس، ثم <span class="comment-type-2">انتقده</span>، فقال: «وأما التفسير المذكور عن ابن عباس فالذين ذكروه عنه جعلوا هذه المعرفة هي المعرفة الفطرية التي يُقرّ بها المؤمن والكافر، ومقصودهم بذلك: أن جميع الإنس والجن قد وُجد منهم ما خُلقوا له من العبادة التي هي مجرد الإقرار الفطري، وجعلوا ذلك فِرارًا من احتجاج القدرية بهذه الآية، ولا ريب أنّ هذا ضعيف، ليس المراد أنّ الله خَلقهم لمجرد الإقرار الفطري».</div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٣<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿إلّا لِيَعْبُدُونِ﴾</span> هذا خاصٌّ لأهل عبادته وطاعته{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٤<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿إلا ليعبدون﴾</span> ويطيعون؛ فأُثيب العابد، وأُعاقب الجاحد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب</span> -من طريق أبي معشر- في قوله ﷿: <span class="qpc-hafs">﴿وما خلقت الجن والإنس إلا ليعبدون﴾</span>، قال: إلا ليقولوا: لا إله إلا الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلّا لِيَعْبُدُونِ﴾</span>، قال: ما جُبِلوا عليه مِن الشّقاء والسعادة{8}. (١٣/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق حيان- <span class="qpc-hafs">﴿إلّا لِيَعْبُدُونِ﴾</span>: إلا ليُوحِّدون، فأما المؤمن فيوحّده في الشّدة والرخاء، وأما الكافر فيوحّده في الشّدة والبلاء دون النعمة والرخاء{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلا لِيَعْبُدُونِ﴾</span> هذا خاصٌّ لأهل طاعته من الفريقين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلّا لِيَعْبُدُونِ﴾</span>، يعني: إلا ليُوحّدون، وقالوا: إلا ليعرفونِ، يعني: ما أمرتُهم إلا بالعبادة، ولو أنهم خُلقوا للعبادة ما عَصَوا طرْفة عين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلا لِيَعْبُدُونِ﴾</span>، قال: مَن خُلق للعبادة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨١<span class="dash">-</span></span> عن إبراهيم بن بشّار، عن <span class="name-3">إبراهيم بن أدهم</span> أنه قال: صدق الله -عزّ اسمه- فيما يقول: <span class="qpc-hafs">﴿وما خلقت الجن والأنس إلا ليعبدون﴾</span>، ولم يقُل: وما خلقتُ الجن والإنس إلا ليعمروا الدنيا ويجمعوا الأموال، ويبنوا الدُّور ويُشيّدوا القصور ويتلذَّذوا ويتفكّهوا. ويجعل يومه أجمع يُرَدِّد ذلك، ويقول: <span class="qpc-hafs">﴿فبهداهم اقتده﴾</span> [الأنعام:٩٠]، <span class="qpc-hafs">﴿وما أمروا إلا ليعبدوا الله مخلصين له الدين حنفاء ويقيموا الصلاة ويؤتوا الزّكاة وذلك دين القيمة﴾</span> [البينة:٥]{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٢<span class="dash">-</span></span> عن محمد بن شعيب، عن محمد بن صهيب أنّه سأل بعضَ علماء أهل الجزيرة بأرمينية عن قول الله ﷿: <span class="qpc-hafs">﴿وما خلقتُ الجن والإنس إلا ليعبدون﴾</span>. فأخبره عن بعض علماء الجزيرة أنّه كان يقول: هذه خاصّة، ولم يُعَمِّم كقوله: <span class="qpc-hafs">﴿ويوم يحشرهم جميعًا يا معشر الجن قد استكثرتم من الإنس﴾</span> [الأنعام:١٢٨]، <span class="qpc-hafs">﴿ألم يأتكم رسل منكم﴾</span> [الأنعام:١٣٠]، قال: فهذه خاصة، وقد قال جميعًا. قال ابن شعيب: فلقيتُ <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، فسألتُه عن قول الله: <span class="qpc-hafs">﴿وما خلقت الجن والإنس إلا ليعبدون﴾</span>، وأخبرتُه بقول ابن صهيب عن الجزري، فقال: هو كذلك، إنّ الله رُبَّما ذكر الواحد وهو لجميع الناس، وربما ذكر الناس وهو واحد، يقول الله ﷿: <span class="qpc-hafs">﴿الذين قال لهم الناس إن الناس قد جمعوا لكم﴾</span> [آل عمران:١٧٣]، وإنما قال لهم ذلك رجل واحد، وقال: <span class="qpc-hafs">﴿يا أيها الإنسان ما غرّك بربك الكريم﴾</span> [الانفطار:٦]، فهذا لجميع الناس، وإنما قال: يا أيها الإنسان{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٣<span class="dash">-</span></span> عن <span class="name-3">الهُذيل بن حبيب</span>، قال: إلا ليوحِّدونِ، وقال: الأمر يُعصى، والخَلْق لا يعصى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما خَلَقْتُ الجِنَّ والإنْسَ إلّا لِيَعْبُدُونِ﴾</span>، كقوله: <span class="qpc-hafs">﴿ولَئِنْ سَأَلْتَهُمْ مَن خَلَقَهُمْ لَيَقُولُنَّ اللَّهُ﴾</span> [الزخرف:٨٧]{16}<span class=comment-ref>٦٢٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٣</span> اختُلف في قوله: <span class="qpc-hafs">﴿وما خلقت الإنس والجن إلا ليعبدون﴾</span> على أقوال: <b>الأول</b>: إلا ليُقِرّوا ويُذعنوا بالعبودية طوعًا أو كرهًا. <b>الثاني</b>: وما خلقت السعداء من الجن والإنس إلا لعبادتي، والأشقياء منهم لمعصيتي. <b>الثالث</b>: إلا ليعرفوني. <b>الرابع</b>: الآية خاصة في أهل الإيمان، والمعنى: وما خلقت الطائعين من الجن والإنس إلا لعبادتي.</p><p>وقد ذكر <u>ابنُ عطية</u> (٨/٨٢) القول الأول، و<span class="comment-type-4">علّق</span> عليه، فقال: «قال ابن عباس وعلي بن أبي طالب ﵄: المعنى: ما خلقت الجن والإنس إلا لآمرهم بعبادتي، وليُقِرّوا لي بالعبودية، فعبّر عن ذلك بقوله: <span class="qpc-hafs">﴿ليعبدون﴾</span> إذ العبادة هي مضمون الأمر».</p><p>و<span class="comment-type-4">علّق</span> على القول الرابع بقوله: «ويؤيد هذا التأويل أن ابن عباس روى عن النبي ﷺ أنه قرأ: (وما خَلَقْتُ الجِنَّ والإنسَ مِنَ المُؤْمِنِينَ إلّا لِيَعْبُدُونِي)».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ تيمية</u> (٦/١١٦) على القولين الأول والثالث، فقال: «فعلى هذه الأقوال أن جميع الإنس والجن عبدوه وعرفوه ووحّدوه وأقرُّوا له بالعبودية طوعًا وكرهًا».</p><p>ولم يذكر <u>ابنُ جرير</u> غير القولين الأولين، ثم <span class="comment-type-3">رجّح</span> (٢١/٥٥٥) القول الأول <span class="mustanad">مستندًا إلى الدلالة العقلية،</span> فقال: «وأولى القولين في ذلك بالصواب القول الذي ذكرنا عن ابن عباس، وهو: ما خلقت الجن والإنس إلا لعبادتنا، والتذلل لأمرنا. فإن قال قائل: فكيف كفروا وقد خلقهم للتذلل لأمره؟ قيل: إنهم قد تذللوا لقضائه الذي قضاه عليهم؛ لأن قضاءه جارٍ عليهم، لا يقدرون من الامتناع منه إذا نزل بهم، وإنما خالفه مَن كفر به في العمل بما أمره به، فأما التذلل لقضائه فإنه غير ممتنع منه».</p><p>و<span class="comment-type-4">أورد</span> <u>ابنُ تيمية</u> (٦/١١٧) <span class="comment-type-1">توجيه</span> <u>ابن جرير</u> لترجيحه، ونسَبه للثعلبي، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الدلالة العقلية، وظاهر القرآن، والسياق</span>، فقال: «وهذا المعنى -وإن كان في نفسه صحيحًا، وقد نازعت القدرية في بعضه- فليس هو المراد بالآية، فإن جميع المخلوقات -حتى البهائم والجمادات- بهذه المنزلة. وأيضًا فالعبادة المذكورة في عامة المواضع في القرآن لا يراد بها هذا المعنى. وأيضًا فإن قوله: <span class="qpc-hafs">﴿ما أريد منهم من رزق وما أريد أن يطعمون إن الله هو الرزاق ذو القوة المتين﴾</span> دليل على أنه خلقهم ليعبدوه، لا ليرزقوا ويُطعموا، بل هو المُطعم الرازق، وإطعامه لهم ورزقه إياهم هو من جملة تدبيرهم وتصريفهم، الذي قد جعله أهل هذا القول عبادةً له، فتكون العبادة التي خُلقوا لها كونهم مرزوقين مُدبَّرين، وهذا باطل. وأيضًا فقوله: <span class="qpc-hafs">﴿ليعبدون﴾</span> يقتضي فعلًا يفعلونه هم، وكونه يربّيهم ويخلقهم ليس فيه إلا فِعله فقط، ليس في ذلك فعل لهم». وانتقد كذلك القول الرابع، فقال: «ويلي هذا القول في الضعف قول مَن يقول: إن الآية خاصة فإنه هذه أقوال ضعيفة».</p><p><span class="comment-type-4">وذكر</span> <u>ابنُ عطية</u> في الآية <b>احتمالًا آخر</b>، فقال: «وتحتمل الآية أن يكون المعنى: ما خلقت الجن والإنس إلا مُعدّين ليعبدون». و<span class="comment-type-4">علّق</span> عليه بقوله: «وكأن الآية تعديد نعمة، أي: خلقت لهم حواس وعقولًا وأجسامًا منقادة نحو العبادة، وهذا كما تقول: البقر مخلوقة للحرْث، والخيل للحرب، وقد يكون منها ما لا يُحارب به أصلًا، فالمعنى: أن الإعداد في خلْق هؤلاء إنما هو للعبادة، لكن بعضهم تكسب صرف نفسه عن ذلك، ويؤيد هذا المنزع قول النبي ﷺ: «<b>اعملوا فكلٌّ مُيسَّرٌ لما خُلق له</b>». وقوله: «<b>كلّ مولود يولد على الفطرة</b>»».</div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٢٠، وتفسير البغوي ٧/٣٨٠.|2:أخرجه ابن جرير ٢١/٥٥٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩١-. وعزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن المنذر.|4:أخرجه إسحاق البستي ص٤٣٦، وابن عبد البر في جامع بيان العلم وفضله ٢/٨١٠.|5:تفسير الثعلبي ٩/١٢٠.|6:تفسير الثعلبي ٩/١٢٠.|7:أخرجه الطبراني في الدعاء ٣/١٥٣٧.|8:أخرجه سفيان الثوري ص٢٨٢، وعبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٥٣. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه الثعلبي ٩/١٢٠.|10:تفسير البغوي ٧/٣٨٠.|11:تفسير مقاتل بن سليمان ٤/١٣٣.|12:أخرجه ابن جرير ٢١/٥٥٤. وجاء في تفسير الثعلبي ٩/١٢٠ منسوبًا إلى سفيان مهملًا بلفظ: هذا خاصّ لأهل عبادته وطاعته.|13:أخرجه أبو نعيم في حلية الأولياء ٨/٤٠.|14:أخرجه ابن عساكر في تاريخ دمشق ٥٣/٢٧٧.|15:تفسير مقاتل بن سليمان ٤/١٣٣.|16:تفسير ابن أبي زمنين ٤/٢٩١.
  51,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَاۤ أُرِیدُ مِنۡهُم مِّن رِّزۡقࣲ وَمَاۤ أُرِیدُ أَن یُطۡعِمُونِ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن مالك، عن أبي الجَوْزاء- <span class="qpc-hafs">﴿ما أُرِيدُ مِنهُمْ مِن رِزْقٍ وما أُرِيدُ أنْ يُطْعِمُونِ﴾</span>، قال: يُطعمون أنفسهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٦<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق عمرو بن مالك- <span class="qpc-hafs">﴿ما أُرِيدُ مِنهُمْ مِن رِزْقٍ وما أُرِيدُ أنْ يُطْعِمُونِ﴾</span>، قال: يُطعمون أنفسهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق عمرو بن مالك- في الآية، قال: أنا أرزقهم، وأنا أطعمهم، ما خلقتُهم إلا ليعبدون{3}. (١٣/٦٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٨<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، في التي في الذاريات: <span class="qpc-hafs">﴿ما أريد منهم من رزق﴾</span>: أن يرزقوا أنفسهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما أُرِيدُ مِنهُمْ مِن رِزْقٍ﴾</span> يقول: لم أسألهم أن يرزقوا أحدًا، <span class="qpc-hafs">﴿وما أُرِيدُ أنْ يُطْعِمُونِ﴾</span> يعني: أن يرزقون{5}<span class=comment-ref>٦٢٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٤</span> ذكر <u>ابنُ عطية</u> (٨/٨٢) في الآية احتمالين: <b>الأول</b>: «أن يكون المعنى: أن يُطعموا خلقي». و<span class="comment-type-1">وجّهه</span> بقوله: «فأضيف ذلك إلى الضمير على جهة التجوز. وهذا قول ابن عباس». <b>الثاني</b>: «أن يكون الإطعام هنا بمعنى النفع على العموم». و<span class="comment-type-1">وجّهه</span> بقوله: «كما تقول: أعطيتُ فلانًا كذا وكذا طعمة، وأنت قد أعطيتَه عرضًا أو بلدًا يحييه، ونحو هذا، فكأنه قال: ولا أريد أن ينفعوني، فذكر جزءًا مِن المنافع وجعله دالًّا على الجميع».</div></p><p><h3><span class="qpc-hafs">﴿مَاۤ أُرِیدُ مِنۡهُم مِّن رِّزۡقࣲ وَمَاۤ أُرِیدُ أَن یُطۡعِمُونِ ۝٥٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٩٠<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>قال الله: ابنَ آدم، تفرَّغ لعبادتي أملأ صدرك غنًى، وأسُدّ فقرك، وإلا تفعل ملأتُ صدرك شُغلًا، ولم أسُدّ فقرك</b>»{6}. (١٣/٦٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٩١<span class="dash">-</span></span> عن أبي الدّرداء، قال: قال رسول الله ﷺ: «<b>قال الله: إني والجنّ والإنس في نبأٍ عظيم، أخلقُ ويُعبَد غيري، وأرزقُ ويُشكَر غيري</b>»{7}. (١٣/٦٨٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٥٥.|2:أخرجه إسحاق البستي ص٤٣٧.|3:أخرجه ابن أبي شيبة ١٤/٤٤.|4:علقه يحيى بن سلام ١/٢٩٥.|5:تفسير مقاتل بن سليمان ٤/١٣٣.|6:أخرجه أحمد ١٤/٣٢١ (٨٦٩٦)، والترمذي ٤/٤٥٦ (٢٦٣٤)، وابن ماجه ٥/٢٢٨ (٤١٠٧)، وابن حبان ٢/١١٩ (٣٩٣)، والحاكم ٢/٤٨١ (٣٦٥٧).</p><p>قال الترمذي: «هذا حديث حسن غريب، وأبو خالد الوالبي اسمه: هرمز». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وذكر الدارقطني في العلل ٨/٣٢٥ (١٥٩٦) الاختلاف في رفعه ووقفه، وقال ابن القطان في بيان الوهم والإيهام ٤/٦٤٢: «أبو خالد هرمز فلا بأس به، وزائدة بن نشيط لا تُعرف حاله». وقال ابن مفلح في الآداب الشرعية ٣/٢٧٠: «حديث جيد». وقال الألباني في الصحيحة ٣/٣٤٦ (١٣٥٩): «قلت: قد روى عنه جمْعٌ من الثقات، وأورده فيهم ابن حبان، وقال أبو حاتم: صالح الحديث. فهو جيد الحديث، لكن العلة من زائدة بن نشيط، فإنه لم يروِ عنه مع ابنه غير فطر بن خليفة، ولم يوثّقه غير ابن حبان، وبيّض له ابن أبي حاتم، فهو مجهول الحال، وقد أشار إلى ذلك الحافظ بقوله في التقريب: مقبول».|7:أخرجه الطبراني في مسند الشاميين ٢/٩٣ (٩٧٤، ٩٧٥)، والبيهقي في الشعب ٦/٣١٠-٣١١ (٤٢٤٣).</p><p>وقال المناوي في فيض القدير ٤/٤٦٩ (٦٠٠٨): «فيه عند مخرّجه البيهقي كالحاكم؛ مهنى بن يحيى مجهول، وبقية بن الوليد أورده الذهبي في الضعفاء، وقال: يروي عن الكذّابين ويدلّسهم، وشريح بن عبيد ثقة، لكنه مرسل». وقال الألباني في الضعيفة ٥/٣٩٣ (٢٣٧١): «ضعيف».
  51,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلۡقُوَّةِ ٱلۡمَتِینُ ۝٥٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: أقرأني رسول الله ﷺ: (إنِّي أنا الرَّزّاقُ ذُو القُوَّةِ المَتِينُ){1}. (١٣/٦٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلۡقُوَّةِ ٱلۡمَتِینُ ۝٥٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿المَتِينُ﴾</span>، يقول: الشديد{2}. (١٣/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ اللَّهَ هُوَ الرَّزّاقُ ذُو القُوَّةِ﴾</span> يعني: البطش في هلاكهم ببدر، <span class="qpc-hafs">﴿المَتِينُ﴾</span> يعني: الشديد{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٦/٢٨٥-٢٨٦ (٣٧٤١)، ٦/٣١٣ (٣٧٧١)، ٧/٨٠-٨١ (٣٩٧٠)، وأبو داود ٦/١١٧ (٣٩٩٣)، والترمذي ٥/٢٠٠ (٣١٦٩)، وابن حبان ١٤/٢٣٦ (٦٣٢٩)، والحاكم ٢/٢٥٥ (٢٩١٩)، ٢/٢٧٣ (٢٩٨٣)، والثعلبي ٩/١٢١.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم في الموضع الثاني: «هذا حديث صحيح، على شرط الشيخين».</p><p>والقراءة شاذة. انظر: مختصر ابن خالويه ص١٤٦.|2:أخرجه ابن جرير ٢١/٥٥٧، والبيهقي في الأسماء والصفات (٦، ١١٤، ٢٥١). وعزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٤/١٣٤.
  51,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنَّ لِلَّذِینَ ظَلَمُوا۟ ذَنُوبࣰا مِّثۡلَ ذَنُوبِ أَصۡحَـٰبِهِمۡ فَلَا یَسۡتَعۡجِلُونِ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ذَنُوبًا﴾</span>، قال: دَلْوًا{1}. (١٣/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿فَإنَّ لِلَّذِينَ ظَلَمُوا ذَنُوبًا مِثْلَ ذُنُوبِ أصْحابِهِمْ﴾</span>، قال: يقول: للذين ظلموا عذابًا مثل عذاب أصحابهم فلا يستعجلون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٩٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: طرَفًا من العذاب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٩٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي بشر- <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: سَجْلًا مِن العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: سَجْلًا من العذاب مثل عذاب أصحابهم{5}. (١٣/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿ذَنُوبًا﴾</span> سبيلًا <span class="qpc-hafs">﴿مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span> مثل سبيل أصحابهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق شهاب بن شُرْنُفة- في قوله: <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: دَلْوًا مثل دَلْو أصحابهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٢<span class="dash">-</span></span> قال <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج-: سَجْلًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٣<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ذَنُوبًا﴾</span> عذابًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَإنَّ لِلَّذِينَ ظَلَمُوا ذَنُوبًا﴾</span>: أي: سَجْلًا من عذاب الله{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: عذابًا مثل عذاب أصحابهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله تعالى: <span class="qpc-hafs">﴿ذنوبا مثل ذنوب أصحابهم﴾</span>، قال: الذَّنوب: العقوبة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنَّ لِلَّذِينَ ظَلَمُوا﴾</span> يعني: مشركي مكة <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span> يعني: نصيبًا من العذاب في الدنيا، مثل نصيب أصحابهم في الشرك، يعني: الأمم الخالية الذين عُذِّبوا في الدنيا؛ <span class="qpc-hafs">﴿فَلا يَسْتَعْجِلُونِ﴾</span> العذاب تكذيبًا به{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٨<span class="dash">-</span></span> عن <span class="name-3">طلحة بن عمرو</span>، في قوله: <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: عذابًا مثل عذاب أصحابهم{14}. (١٣/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٠٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَإنَّ لِلَّذِينَ ظَلَمُوا ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span>، قال: يقول: ذَنوبًا من العذاب. قال: يقول: لهم سَجْلٌ مِن عذاب الله، وقد فُعِل هذا بأصحابهم من قبلهم، فلهم عذابٌ مثل عذاب أصحابهم فلا يستعجلون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٥٨، وابن أبي حاتم -كما في الإتقان ٢/٤٤-، وأخرجه ابن المنذر -كما في الفتح ٨/٦٠٠- بلفظ: سَجْلًا.|2:أخرجه ابن جرير ٢١/٥٥٨|3:أخرجه ابن جرير ٢١/٥٥٩.|4:أخرجه ابن جرير ٢١/٥٥٨. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩١-، وقال عقبه: والسَّجْل: الدَّلْو.|5:أخرجه ابن جرير ٢١/٥٥٨ بنحوه، و الفريابي -كما في تغليق التعليق ٤/٣١٩-.|6:تفسير مجاهد ٢/٦٢١، وأخرج أوله إسحاق البستي ص٤٣٧ من طريق ابن جُرَيْج، وكذلك ابن المنذر-كما في الفتح ٨/٦٠٠-. وعلقه البخاري في صحيحه ٤/١٨٣٧.|7:أخرجه ابن جرير ٢١/٥٥٨، وأخرج إسحاق البستي ص٤٣٨ من طريق نبهان عن الحسن في قوله: <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أصْحابِهِمْ﴾</span> قال: دولة مثل دولة أصحابهم. ولعل في النص تصحيفًا، وكذلك في طريقه.|8:أخرجه ابن المنذر -كما في الفتح ٨/٦٠٠-.|9:تفسير الثعلبي ٩/١٢٢.|10:أخرجه ابن جرير ٢١/٥٥٨.|11:أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٥٩.|12:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤. وجاء في تفسير الثعلبي (ط: دار التفسير) عن عطاء الخراساني في الآية قال: حظًّا. بينما أثبتت في طبعة دار إحياء التراث ٩/١٢٢ عن الكسائي.|13:تفسير مقاتل بن سليمان ٤/١٣٤.|14:أخرجه الخرائطي في مساوئ الأخلاق (٦٥١).|15:أخرجه ابن جرير ٢١/٥٥٩.
  51,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَیۡلࣱ لِّلَّذِینَ كَفَرُوا۟ مِن یَوۡمِهِمُ ٱلَّذِی یُوعَدُونَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَوَيْلٌ لِلَّذِينَ كَفَرُوا﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿مِن يَوْمِهِمُ﴾</span> في الآخرة <span class="qpc-hafs">﴿الَّذِي﴾</span> فيه <span class="qpc-hafs">﴿يُوعَدُونَ﴾</span> العذاب{1}<span class=comment-ref>٦٢٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٥</span> نقل <u>ابنُ عطية</u> (٨/٨٤) في وقت الوعيد قولين، فقال: «و<b>قال جمهور المفسّرين</b>: هذا التوعّد هو بيوم القيامة. و<b>قال آخرون</b> -ذكره الثعلبي-: هو بيوم بدر».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣٤.
  52,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٢٨١١<span class="dash">-</span></span> عن عبد الله بن عباس -من طرق- قال: نزلت سورة الطور بمكة{1}. (١٣/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٢<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{2}. (١٣/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ- مكّيّة، ونزلت بعد «تنزيل السجدة»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٤<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٥<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٦<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٧<span class="dash">-</span></span> عن محمد بن شهاب الزُّهريّ: مكّيّة، ونزلت بعد «تنزيل السجدة»{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٨<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨١٩<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الطور مكّيّة، وعددها تسع وأربعون آية كوفي{8}<span class=comment-ref>٦٢٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٦</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/٨٥) أن هذ السورة مكية <span class="mustanad">بإجماع من المفسرين والرواة</span>.</div></p><p><h3><span class="qpc-hafs">﴿وَٱلطُّورِ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿والطُّورِ﴾</span>، قال: جبل{9}. (١٣/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والطُّورِ﴾</span>، قال: هو الجبل، بالسُّريانية{10}<span class=comment-ref>٦٢٢٧</span>. (١٣/٦٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٧</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٨/٨٥) قول مجاهد <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وهذا ضعيف؛ لأن من حكاه في العربية يقضي على هذا».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كل جبل يُدعى: طورًا{11}<span class=comment-ref>٦٢٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨٥) هذا القول منسوبًا لبعض أهل العربية، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «فكأنه أقسم بالجبال؛ إذ هو اسم جنس».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٤<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق معمر، عمن سمع عكرمة- يقول في: <span class="qpc-hafs">﴿والطُّورِ﴾</span>، قالا: جبل يقال له: الطور{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والطُّورِ﴾</span> يعني: الجبل، بلغة النَّبَط، الذي كلّم الله عليه موسى ﵇ بالأرض المُقدّسة{13}<span class=comment-ref>٦٢٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٥١) أن هذا القول هو قول جمهور من السلف والخلف.</div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٦<span class="dash">-</span></span> قال <b>⟨مقاتل بن حيّان</b>:⟩{تت} <span class="qpc-hafs">﴿والطُّورِ﴾</span> هما طوران؛ يُقال لأحدهما: طور تينا، وللآخر: طور زيتا؛ لأنهما يُنبِتان التين والزّيتون{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلطُّورِ ۝١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٢٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>الطُّور من جبال الجنة</b>»{15}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٨<span class="dash">-</span></span> عن عمرو بن عوف، قال: قال رسول الله ﷺ: «<b>الطُّور جبل من جبال الجنة</b>»{16}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٢٩<span class="dash">-</span></span> عن <span class="name-2">نَوْف البكالي</span> -من طريق أبي عمران الجوني- قال: أوحى الله إلى الجبال: أني نازل على جبلٍ منكنّ. قال: فشَمخت الجبالُ كلّها رجاء أن يكون الأمر عليها. قال: وتواضع طور سيناء، وقال: أرضى بما قسم الله لي. فكان الأمرُ عليه{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٣/٢٠ من طريق أبي عمرو بن العلاء، عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف، عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|5:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.|6:تنزيل القرآن ص٣٧-٤٢.|7:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|8:تفسير مقاتل بن سليمان ٤/١٤١.|9:أخرجه الحاكم ٢/٤٦٧-٤٦٨. وعزاه السيوطي إلى ابن أبي حاتم.|10:تفسير مجاهد ص٦٢٢، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٠-، وابن جرير ٢١/٥٦٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر|11:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٣-.|12:أخرجه عبد الرزاق ٢/٢٤٦.|13:تفسير مقاتل بن سليمان ٤/١٤٣.|14:تفسير الثعلبي ٩/١٢٣.|15:أخرجه الطبراني في الأوسط ٧/٣٤٢ (٧٦٧٣)، من طريق الحسن بن كثير، عن يحيى بن سعيد اليمامي، عن نصر بن يحيى بن أبي كثير، عن أبيه، عن سعيد بن أبي سعيد، عن أبي هريرة بنحوه.</p><p>قال الطبراني: «لم يرو هذا الحديث عن يحيى بن أبي كثير إلا ابنه نصر، ولا رواه عن نصر إلا يحيى بن أبي سعيد اليمامي، تفرد به الحسن بن كثير». وقال الهيثمي في المجمع ١٠/٧١: «فيه مَن لم أعرفهم». وقال الألباني في الضعيفة ١٤/٩٣٠: «منكر جدًّا».|16:أخرجه ابن شبة في تاريخ المدينة ١/٨٠-٨١، والطبراني في الكبير ١٧/١٨ (١٩) كلاهما مطولًا، من طريق كثير بن عبد الله المزني، عن أبيه، عن جده به.</p><p>قال ابن الجوزي في الموضوعات ١/١٤٨: «هذا حديث لا يصحّ عن رسول الله ﷺ». وقال ابن القيسراني في ذخيرة الحفاظ ١/٣٨٣ (٤٦٢): «رواه كثير بن عبد الله بن عمرو بن عوف، عن أبيه، عن جده. وكثير ضعيف». وقال الهيثمي في المجمع ٤/١٤ (٥٩١٤): «فيه كثير بن عبد الله، وهو ضعيف». وقال السيوطي في اللآلئ المصنوعة ١/٨٦: «لا يصح؛ كثير كذاب». وقال الألباني في الضعيفة ١١/٨٤٨ (٥٤٩٠): «موضوع بهذا التمام».|17:أخرجه عبد الرزاق ٢/٢٤٦-٢٤٧.
  52,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكِتَـٰبࣲ مَّسۡطُورࣲ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وكِتابٍ مَسْطُورٍ﴾</span>، قال: صُحفٌ مكتوبة{1}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿مَسْطُورٍ﴾</span>، قال: مكتوب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وكِتابٍ مَسْطُورٍ﴾</span>، قال: مكتوب{3}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكِتابٍ مَسْطُورٍ﴾</span>، يعني: أعمال بني آدم مكتوبة، يقول: أعمالهم تخرج إليهم يومئذ، يعني: يوم القيامة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وكِتابٍ﴾</span> قال: الذِّكر، <span class="qpc-hafs">﴿مَسْطُورٍ﴾</span> قال: مكتوب{5}<span class=comment-ref>٦٢٣٠</span>. (١٣/٦٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨٥-٨٦) أن الكتاب المسطور معناه <span class="mustanad">بإجماع</span>: المكتوب أسطارًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٥١) قولًا بأن الكتاب هو اللوح المحفوظ، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لظاهر الآيات</span>، فقال: «وهذا غلط؛ لأنه ليس برَقٍّ». و<span class="comment-type-4">بيّن</span> أن قول مقاتل أصح منه، ثم <span class="comment-type-3">رجَّح</span> القول بأنه الكتاب المنزل من عند الله، فقال: «الظاهر أن المراد به: الكتاب المنزل من عند الله، وأقسم الله به لعظمته وجلالته، وما تضمّنه من آيات ربوبيته، وأدلة توحيده، وهداية خلْقه».</div></p></div>",footnotes:1:تفسير مجاهد ص٦٢٢، وأخرجه البخاري في خلْق أفعال العباد (٩٩)، وابن جرير ٢١/٥٦١ بنحوه، والبيهقي (٥٧٠-٥٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر بلفظ: صحف.|2:أخرجه ابن جرير ٢١/٥٦١.|3:أخرجه عبد الرزاق ٢/٢٤٦، والبخاري في خلْق أفعال العباد (٩٨) من طريق سعيد، وابن جرير ٢١/٥٦١ من طريقي معمر وسعيد، والبيهقي في الأسماء والصفات (٥٧٠). وعزاه السيوطي إلى ابن المنذر.|4:تفسير مقاتل بن سليمان ٤/١٤٣.|5:عزاه السيوطي إلى ابن المنذر.
  52,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِی رَقࣲّ مَّنشُورࣲ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِي رَقٍّ مَنشُورٍ﴾</span>، قال: في الكتاب{1}. (١٣/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فِي رَقٍّ مَنشُورٍ﴾</span>، قال: الصحيفة{2}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فِي رَقٍّ مَنشُورٍ﴾</span>، قال: في صُحف{3}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِي رَقٍّ مَنشُورٍ﴾</span> القرآن في أيدي السَّفرة{4}<span class=comment-ref>٦٢٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣١</span> <span class="comment-type-3">رجَّح</span> <u>ابن القيم</u> (٣/٥٢) هذا القول <span class="mustanad">مستندًا إلى ظاهر الآيات</span>، فقال: «هذا أرجح الأقوال؛ لأنه سبحانه وصف القرآن بأنه في صُحفٍ مطهّرة، بأيدي سَفرة كرامٍ بررة. فالصحف هي الرّقّ، وكونه بأيدي سفرة هو كونه منشورًا».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فِي رَقٍّ مَنشُورٍ﴾</span>، قال: هو الكتاب{5}. (١٣/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿فِي رَقٍّ مَنشُورٍ﴾</span> هو ما كتب الله بيده لموسى من التوراة، وموسى يسمع صرير القلم{6}<span class=comment-ref>٦٢٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٢</span> <span class="comment-type-1">وجّه</span> <u>ابنُ القيم</u> (٣/٥٢) هذا القول بقوله: «وكأنّ صاحب هذا القول رأى اقتران الكتاب بالطور؛ فقال: هو التوراة»، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لدلالة القرآن</span>، فقال: «ولكن التوراة إنما أُنزلت في ألواح لا في رَقٍّ، إلا أن يقال: هي في رَقٍّ في السماء وأُنزلت في ألواح».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي رَقٍّ﴾</span> يعني أديم الصُّحف <span class="qpc-hafs">﴿مَنشُورٍ﴾</span>{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٠-، وابن جرير ٢١/٥٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مجاهد ص٦٢٢، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٠- بلفظ: صحف ورق، والبخاري في خلْق أفعال العباد (٩٩)، وابن جرير ٢١/٥٦٢ بنحوه، والبيهقي (٥٧٠-٥٧٣).|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٣-.|5:أخرجه البخاري في خلْق أفعال العباد (٩٨)، وابن جرير ٢١/٥٦٢، والبيهقي في الأسماء والصفات (٥٧٠). وعزاه السيوطي إلى عبد الرزاق،وابن المنذر.|6:تفسير البغوي ٧/٣٨٢.|7:تفسير مقاتل بن سليمان ٤/١٤٣.
  52,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡبَیۡتِ ٱلۡمَعۡمُورِ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٤٢<span class="dash">-</span></span> عن أنس، عن النَّبِيّ ﷺ قال: «<b>البيت المعمور في السماء السابعة، يدخله كلّ يوم سبعون ألف مَلَك، لا يعودون إليه حتى تقوم الساعة</b>»{1}. (١٣/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٣<span class="dash">-</span></span> عن أبي هريرة، عن النبيِّ ﷺ، قال: «<b>في السماء بيت يُقال له: المعمور، بِحِيال الكعبة، وفي السماء الرابعة نهر يقال له: الحيوان، يدخله جبريل كلّ يوم، فينغمس انغماسة ثم يخرج، فيَنتَفض انتفاضة يَخِرّ عنه سبعون ألف قطرة، يخلق الله مِن كلّ قطْرة مَلكًا، يؤمرون أن يأتوا البيت المعمور فيُصَلُّون، فيفعلون ثم يخرجون فلا يعودون إليه أبدًا، ويُولّى عليهم أحدهم، يؤمر أن يقف بهم في السماء موقفًا يسبِّحون الله فيه إلى أن تقوم الساعة</b>»{2}. (١٣/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٤<span class="dash">-</span></span> عن عبد الله بن عمرو، رفعه قال: «<b>إنّ البيت المعمور بِحِيال الكعبة، لو سقط شيء منه لسقط عليها، يُصلّي فيه كلّ يوم سبعون ألفًا لا يعودون فيه</b>»{3}. (١٣/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٥<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>البيت المعمور في السماء، يُقال له: الضُّراح، على مثل البيت الحرام؛ بِحِياله، لو سقط لَسقط عليه، يدخله كلُّ يوم سبعون ألف مَلَك، لم يَرَوه قطّ، وإنّ له في السماء حُرمةً على قدْر حُرمة مكة</b>»{4}. (١٣/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٦<span class="dash">-</span></span> عن كُرَيْب مولى ابن عباس، مثله مرسلًا{5}. (١٣/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٧<span class="dash">-</span></span> عن عائشة: أنّ النبيَّ ﷺ قدِم مكة، فأرادت عائشة أن تدخل البيت، فقال لها بنو شيبة: إنّ أحدًا لا يدخله ليلًا، ولكن نُخَلّيه لك نهارًا. فدخل عليها النبيُّ ﷺ، فشَكَتْ إليه أنهم منعوها أن تدخل البيت، فقال: «<b>إنّه ليس لأحد أن يدخل البيت ليلًا، إنّ هذه الكعبة بِحِيال البيت المعمور الذي في السماء، يدخل ذلك المعمور سبعون ألف مَلَك لا يعودون إليه إلى يوم القيامة، لو وقع حجَرٌ منه لوقع على ظهر الكعبة</b>»{6}. (١٣/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٨<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: ذُكِر لنا أنّ رسول الله ﷺ قال يومًا لأصحابه: «<b>هل تدرون ما البيت المعمور؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>فإنه مسجد في السماء بِحِيال الكعبة، لو خرَّ خرّ عليها، يُصلّي فيه كلّ يوم سبعون ألف مَلَك، إذا خرجوا منه لم يعودوا آخر ما عليهم</b>»{7}. (١٣/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٤٩<span class="dash">-</span></span> عن خالد بن عَرعرة، أنّ رجلًا قال ل<span class="name-1">علي</span>: ما البيت المعمور؟ قال: بيت في السماء يُقال له: الضُّراح، وهو بِحِيال الكعبة مِن فوقها، حُرمته في السماء كحُرمة البيت في الأرض، يُصلّي فيه كلّ يوم سبعون ألفًا من الملائكة، لا يعودون إليه أبدًا{8}. (١٣/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٠<span class="dash">-</span></span> عن أبي الطُّفيل: أنّ ابن الكَوّاء سأل <span class="name-1">عليًّا</span> عن البيت المعمور: ما هو؟ قال: ذلك الضُّراح، بيت فوق سبع سموات، تحت العرش، يدخله كلّ يوم سبعون ألف مَلَك، ثم لا يعودون إليه إلى يوم القيامة{9}. (١٣/٦٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاصي</span> -من طريق معدان- قال في البيت المعمور: بيتٌ في السماء بِحِيال الكعبة، لو سقط سقط عليها، يُصلّي فيه كلّ يوم سبعون ألف مَلَك، والحَرَم حَرَمٌ بِحِياله إلى العرش، وما من السماء موضع إهابٍ إلا وعليه مَلَك ساجد أو قائم{10}. (١٣/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: هو بيت حذاء العرش، يعمره الملائكة، يُصلّي فيه كلّ ليلة سبعون ألفًا مِن الملائكة، ثم لا يعودون إليه{11}. (١٣/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رجاء العُطارديّ- في قوله: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: هو بيت في السماء بِحِيال الكعبة، يُقال له: الضُّراح، يزوره كلّ يوم سبعون ألف مَلَك، لا يعودون فيه إلى يوم القيامة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: إنّ في السماء بيتًا يُقال له: الضُّراح، وهو فوق البيت العتيق من حياله، حُرمته في السماء كحُرمة هذا في الأرض، يَلِجُه كلُّ ليلةٍ سبعون ألف مَلَك يُصَلُّون فيه، لا يعودون إليه أبدًا غير تلك الليلة{13}. (١٣/٦٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: بيت في السماء يُقال له: الضُّراح{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: أُنزل من الجنة، فكان يُعمَرُ بمكة، فلمّا كان الغرق رفعه الله، فهو في السماء السادسة، يدخله كلُّ يوم سبعون ألف مَلَك مِن قبيلة إبليس، ثم لا يرجع إليه أحدٌ يومًا واحدًا أبدًا{15}. (١٣/٦٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٧<span class="dash">-</span></span> عن حسين، قال: سُئِل <span class="name-2">عكرمة</span> وأنا جالس عنده عن البيت المعمور، قال: بيت في السماء بِحِيال الكعبة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله سبحانه: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: هو الكعبة البيت الحرام الذي هو معمور مِن الناس، يعمره الله تعالى كل سنة بستمائة ألف، فإن عجز الناس عن ذلك أتمَّه الله سبحانه وتقدس بالملائكة، وهو أول بيت وُضع للعبادة في الأرض{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام بن حسان- قال: البيت المعمور بِحِيال الكعبة، ما بينهما حرامٌ كلّه، وما تحته إلى الأرض السابعة حرامٌ كلّه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٠<span class="dash">-</span></span> عن محمد بن عباد بن جعفر، قال: رأيتُ <span class="name-2">ابنَ عامر</span> قائمًا على باب البصريّين بمكة، فنظر إلى البيت، فقال: حبّذا بيت ربي ما أحسنه وأجمله، هذا -واللهِ- البيت المعمور{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: قال الله ﷿ لآدم: أُهبِطُ معك بيتي، يُطاف حوله كما يُطاف حول عرشي. فحجّه آدم وما بعده من المؤمنين، فلما كان زمان الطوفان رفعه الله وطهّره مِن أن تصيبه عقوبة أهل الأرض؛ فصار معمور السماء، فتتبّع إبراهيمُ الأساس، فبناه على أساسٍ قديم كان قبله{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span> واسمه: الضُّراح، وهو في السماء الخامسة، ويقال: في سماء الدنيا، حِيال الكعبة في العَرض والموضع، غير أنّ طوله كما بين السماء والأرض، وعمارته أنه يدخله كلّ يوم سبعون ألف مَلَك يُصلُّون فيه -يقال لهم: الجن، ومنهم كان إبليس، وهم حيٌّ من الملائكة- لم يدخلوه قطّ، ولا يعودون فيه إلى يوم القيامة، ثم ينزلون إلى البيت الحرام، فيطوفون به، ويُصلُّون فيه، ثم يصعدون إلى السماء، فلا يهبطون إليه أبدًا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والبَيْتِ المَعْمُورِ﴾</span>، قال: بيت الله الذي في السماء. وقال: قال رسول الله ﷺ: «<b>إنّ بيت الله في السماء لَيدخله كلُّ يومٍ طلعت شمسُه سبعون ألف مَلَك، ثم لا يعودون فيه أبدًا بعد ذلك</b>»{14}<span class=comment-ref>٦٢٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٣</span> اختُلف في البيت المعمور على قولين: <b>الأول</b>: أنه البيت في السماء. <b>الثاني</b>: أنه البيت الحرام.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٥٢) أن المشهور هو القول الأول، ثم <span class="comment-type-4">علَّق</span> بقوله: «ولا ريب أنّ كلًّا منهما معمور، فهذا معمور بالملائكة وعبادتهم، وهذا معمور بالطائفين والقائمين والرُّكع والسجود، وعلى كلا القولين فكل منهما سيّد البيوت».</div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٢-، وأحمد ٢٠/٢٧-٢٨ (١٢٥٥٨)، والحاكم ٢/٥٠٨ (٣٧٤٢) واللفظ له، وابن جرير ٢١/٥٦٥، من طريق حماد بن سلمة، عن ثابت البُناني، عن أنس بن مالك به.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي.|2:أخرجه الحسن بن رشيق العسكري في جزئه ص٦٥-٦٦ (٥٢)، والعقيلي في الضعفاء الكبير ٢/٥٩، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢٨-، والواحدي ٤/١٨٤، من طريق هشام بن عمار، عن الوليد بن مسلم، عن روح بن جناح، عن الزُّهريّ، عن سعيد بن المسيب، عن أبي هريرة به.</p><p>قال ابن الجوزي في الموضوعات ١/١٤٧: «هذا حديث لا يُتهم به إلا روح بن جناح؛ فإنه يُعرف به، ولم يتابعه عليه أحد. قال ابن حبان: يروي عن الثقة ما إذا سمعه مَن ليس بمتبحر في هذه الصناعة شهد بالوضع. وقال عبد الغنى الحافظ: هذا حديث منكر بهذا الإسناد، ليس له أصل عن الزُّهريّ، ولا عن سعيد، ولا عن أبي هريرة، ولا يصحّ عن رسول الله ﷺ من هذه الطريق ولا من غيرها». وقال ابن كثير في تفسيره ١٣/٢٢٧: «هذا حديث غريب جدًّا، تفرَّد به روح بن جناح هذا، وهو القرشي الأموي مولاهم أبو سعد الدمشقي، وقد أنكر هذا الحديث عليه جماعة من الحفاظ منهم: الجوزجاني، والعقيلي، والحاكم أبو عبد الله النيسابوري، وغيرهم. قال الحاكم: لا أصل له من حديث أبي هريرة، ولا سعيد، ولا الزُّهريّ». وقال ابن حجر في الفتح ٦/٣٠٩: «إسناده ضعيف». وقال السيوطي: «سند ضعيف». وقال في اللآلئ المصنوعة ١/٨٤ معقِّبًا على كلام ابن الجوزي: «ما هو بموضوع». وقال المناوي في فيض القدير ٢/٤٧٠: «سند ضعيف».|3:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٢-٦٢٣- بنحوه، من طريق عبد الرحمن، عن إبراهيم، عن آدم، عن شيبان، عن قتادة، عن سالم بن أبي الجعد، عن معدان بن طلحة، عن عبد الله بن عمرو بن العاص به.</p><p>قال ابن حجر في الفتح ٦/٣٠٨: «إسناد ضعيف».|4:أخرجه الطبراني في الكبير ١١/٤١٧ (١٢١٨٥)، من طريق إسحاق بن بشر أبي حذيفة، عن ابن جُرَيْج، عن صفوان بن سليم، عن كريب، عن ابن عباس به.</p><p>وأخرجه الواحدي ٤/١٨٤، من طريق سعيد بن سالم، عن ابن جُرَيْج، عن صفوان بن سليم، عن كريب، عن ابن عباس به.</p><p>قال العقيلي في الضعفاء الكبير ١/١٠٠: «ليس له أصل عن ابن جُرَيْج». وقال الهيثمي في المجمع ٧/١١٣-١١٤ (١١٣٦٨): «فيه إسحاق بن بشر أبو حذيفة، وهو متروك». وقال السيوطي: «سند ضعيف».|5:أخرجه عبد الرزاق في المصنف (٧٤، ٨٨).|6:أخرجه الثعلبي ٩/١٢٤، من طريق الحسين بن محمد، عن هارون بن محمد بن هارون، عن إبراهيم بن الحسين بن ديزيل، عن موسى بن إسماعيل، عن سفيان بن نشيط، عن أبي محمد، عن الزبير، عن عائشة به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال ابن حجر في الفتح ٦/٣٠٨: «إسناد صالح».|7:أخرجه عبد الرزاق ٢/٢٤٦ من طريق معمر، وابن جرير ٢١/٥٦٥ من طريق سعيد.|8:أخرجه إسحاق بن راهويه -كما في المطالب (٤١٢٢)-، وابن جرير ٢١/٥٦٣-٥٦٤، والبيهقي في شعب الإيمان (٣٩٩١). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وفي رواية عند ابن جرير ٢١/٥٦٣، وإسحاق البستي ص٤٣٩ بلفظ: في السماء السادسة.|9:أخرجه عبد الرزاق (٨٨٧٥)، وابن جرير ٢١/٥٦٣-٥٦٤. وعزاه السيوطي إلى ابن المنذر، وابن الأنباري في المصاحف.|10:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٢-، والبيهقي في شعب الإيمان (٣٩٩٤).|11:أخرجه ابن جرير ٢١/٥٦٤.|12:أخرجه إسحاق البستي ص٤٤١.|13:أخرجه البيهقي (٣٩٩٧). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٣- بنحوه.|14:أخرجه ابن جرير ٢١/٥٦٥.|15:أخرجه ابن جرير ٢١/٥٦٥ بنحوه. وعزاه السيوطي إلى ابن المنذر. كما أخرجه إسحاق البستي مختصرًا ص٤٤٢، وفيه: من قبيلة إبليس يقال لهم: الجن.|16:أخرجه ابن جرير ٢١/٥٦٤.|17:أخرجه الثعلبي ٩/١٢٤.|18:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٣-٢٩٤-.|19:أخرجه إسحاق البستي ص٤٤١.|20:أخرجه إسحاق البستي ص٤٣٩.|21:تفسير مقاتل بن سليمان ٤/١٤٣.|22:أخرجه ابن جرير ٢١/٥٦٥.
  52,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٦٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق خالد بن عَرعرة- في قوله: <span class="qpc-hafs">﴿والسَّقْفِ المَرْفُوعِ﴾</span>، قال: السماء{1}. (١٣/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والسَّقْفِ﴾</span>، قال: السماء{2}. (١٣/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿والسَّقْفِ المَرْفُوعِ﴾</span>، قال: هو السماء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿والسَّقْفِ المَرْفُوعِ﴾</span>، قال: العرش{4}<span class=comment-ref>٦٢٣٤</span>. (١٣/٦٩٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٢٨) على قول الربيع بقوله: «يعني: أنه سقف لجميع المخلوقات، وله اتجاه، وهو يراد مع غيره. كما قاله الجمهور».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسَّقْفِ المَرْفُوعِ﴾</span> يعني: السماء، رُفِع مِن الأرض مسيرة خمسمائة عام، يعني: السموات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والسَّقْفِ المَرْفُوعِ﴾</span> سقف السماء{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٣-، وابن راهويه -كما في المطالب (٤١٢٢)-، وابن جرير ٢١/٥٦٦، وأبو الشيخ في العظمة (٥٥٠)، والحاكم ٢/٤٦٨، والبيهقي في شعب الإيمان (٣٩٩١). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. كما أخرجه إسحاق البستي ص٤٤٢ وزاد فيه استدلاله بقوله تعالى: <span class="qpc-hafs">﴿وجعلنا السماء سقفا محفوظا﴾</span> [الأنبياء:٣٢].|2:أخرجه ابن جرير ٢١/٥٦٧، وأبو الشيخ (٥٤٩)، وعبد بن حميد، وابن أبي حاتم -كما في الفتح ٦/٢٩٣-.|3:أخرجه عبد الرزاق ٢/٢٤٦، وابن جرير ٢١/٥٦٧ من طريق سعيد.|4:أخرجه ابن أبي حاتم -كما في الفتح ٦/٢٩٣-٢٩٤-، وأبو الشيخ (٢٥٣).|5:تفسير مقاتل بن سليمان ٤/١٤٣.|6:أخرجه ابن جرير ٢١/٥٦٧.
  52,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡبَحۡرِ ٱلۡمَسۡجُورِ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٧٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق أبي صالح- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: بحرٌ في السماء تحت العرش{1}. (١٣/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق مجاهد-، مثله{2}. (١٣/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق النِّزال بن سَبرة- أنه قال في البحر المسجور: هو بحرٌ تحت العرش، عمقه كما بين السماء السابعة إلى الأرض السابعة، وهو ماء غليظ، يُقال له: بحر الحيوان، يُمطر العباد بعد النفخة الأولى منه أربعين صباحًا، فيَنبُتون في قبورهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي مكين- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: بحر دون العرش{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: بحرٌ تحت العرش{5}<span class=comment-ref>٦٢٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨٨)، <span class="comment-type-4">وكذا</span> <u>ابنُ كثير</u> (١٣/٢٢٨) أن الجمهور على أنه بحر الدنيا، ثم <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> بقوله: «<span class="mustanad">ويؤيد ذلك قوله تعالى</span>: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span> [التكوير:٦]».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: هو الماء الأعلى الذي تحت العرش{6}. (١٣/٦٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span> تحت العرش الممتلئ مِن الماء، يُسمّى: بحر الحيوان، يُحيي الله به الموتى فيما بين النفختين{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡمَسۡجُورِ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٨٧٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق سعيد بن المسيّب- أنّه قال لرجل مِن اليهود: أين جهنم؟ قال: هي البحر. فقال عليٌّ: ما أراه إلا صادقًا: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، ‹وإذا البِحارُ سُجِرَتْ› مخففة [التكوير:٦]{8}<span class=comment-ref>٦٢٣٦</span>. (١٣/٦٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٦</span> ساق <u>ابنُ عطية</u> (٨/٨٧) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «<span class="mustanad">ومنه ما روي عن النبي</span> ﷺ: «<b>إن البحر هو جهنم</b>»».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٨<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق سعيد بن المسيّب- قال: ما رأيتُ يهوديًّا أصدق مِن فلان، زعم أنّ نار الله الكُبرى هي البحر، فإذا كان يوم القيامة جمع الله فيه الشمس والقمر والنجوم، ثم بعث عليه الدَّبور فسعّرته{9}. (١٣/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المحبوس{10}<span class=comment-ref>٦٢٣٧</span>. (١٣/٦٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٨) على هذا القول بقوله: «ومنه: ساجور الكلب: وهو القلادة من عُود أو حديد التي تمسكه، وكذلك لولا أن البحر يُمسَك لفاض على الأرض».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٢٩ بتصرف) على هذا القول بقوله: «وعليه يدل الحديث الذي رواه الإمام أحمد، فقال: ... حدّثنا عمر بن الخطاب <span class="mustanad">عن رسول الله</span> ﷺ قال: «<b>ليس من ليلة إلا والبحر يُشرف فيها ثلاث مرات، يستأذن الله أن ينفضخ عليهم، فيكفه الله ﷿</b>»».</p><p>و<span class="comment-type-4">بنحوهما</span> قال <u>ابنُ القيم</u> (٣/٥٤).</div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المُرسَل{11}. (١٣/٦٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ذي الرّمة- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: الفارغ، خرجت أمَة تستقي، فرأت الحوض فارغًا، فقالت: الحوض مسجور{12}. (١٣/٦٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: سَجْره حين يذهب ماؤه ويُفجَر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق ابن عباس- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: البحر يُسجر، فيصير جهنم{14}. (١٣/٦٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٤<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٥<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿المَسْجُورِ﴾</span> هو اليابس الذي قد ذهب ماؤه ونَضب{15}<span class=comment-ref>٦٢٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٨) على هذا القول الذي قاله ابن عباس من طريق العَوفيّ، وأبو العالية، وقتادة، والحسن من طريق المبارك، بقوله: «ويروى أن البحار يذهب ماؤها يوم القيامة، وهذا معروف في اللغة، فهو من الأضداد».</div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المُوقَد{16}. (١٣/٦٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿المَسْجُورِ﴾</span>: المملوء{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٨<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٨٩<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span> يعني: المُوقَد المحمى، بمنزلة التنّور المسجور{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فَضالة- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المملوء، مثل قوله: <span class="qpc-hafs">﴿... ثُمَّ فِي النّارِ يُسْجَرُونَ﴾</span> [غافر:٧٢]{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فَضالة-: تُسجر حتى يذهب ماؤها، فلا يبقى فيها قطرة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٢<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span> -من طريق حفص بن حُمَيد- في قوله تعالى: <span class="qpc-hafs">﴿والبحر المسجور﴾</span>، قال: بمنزلة التنّور{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبيد بن عمير</span> -من طريق طلحة بن عمرو- في قوله تعالى: <span class="qpc-hafs">﴿والبحر المسجور﴾</span>، قال: المُوقَد{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المملوء{23}. (١٣/٦٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٥<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿المَسْجُورِ﴾</span> المُختلط العذب بالمالح{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٦<span class="dash">-</span></span> عن <span class="name-3">شِمْر بن عطية</span> -من طريق حفص بن حُميد- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: بمنزلة التنّور المسجور{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: الممتلئ{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المُوقَد. وقرأ قول الله تعالى: <span class="qpc-hafs">﴿وإذا البِحارُ سُجِّرَتْ﴾</span> [التكوير:٦]، قال: أُوقِدَت{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٨٩٩<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿والبَحْرِ المَسْجُورِ﴾</span>، قال: المملوء، إذا سُجر مثل النور{28}<span class=comment-ref>٦٢٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣٩</span> اختُلف في المراد بالمسجور على أقوال: <b>الأول</b>: أنه المملوء. <b>الثاني</b>: الموقد. <b>الثالث</b>: الذي ذهب ماؤه. <b>الرابع</b>: المحبوس.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٧) على القول الأول الذي قاله قتادة، وسفيان، والكلبي، والحسن، ومجاهد، بقوله: «وهذا <span class="mustanad">معروف من اللغة</span>».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٥٣) أنه قول <span class="mustanad">جميع أهل اللغة</span>.</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (١٥/٥٦٩-٥٧٠ بتصرف) أن «السجر» في اللغة مستعمل في معنيي الامتلاء والإيقاد، ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى دلالة اللغة، والعقل</span>- أنه المملوء، فقال: «فإذا كان ذلك الأغلب من معاني السَّجر، وكان البحر غير موقد اليوم، وكان الله -تعالى ذكره- قد وصفه بأنه مسجور، فبطل عنه إحدى الصفتين، وهو الإيقاد صحت الصفة الأخرى التي هي له اليوم، وهو الامتلاء؛ لأنه كل وقت ممتلئ».</p><p>و<span class="comment-type-4">رأى</span> <u>ابنُ عطية</u> (٨/٧٨) أنه لا تعارض بين القول بأنه المملوء أو القول بأنه المُوقَد، فقال: «لأنّ قولهم: سجرتُ التنّور، معناه: ملأتها بما يحترق ويتّقد».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٣/٥٤) القول الثاني <span class="mustanad">مستندًا إلى دلالة اللغة، والقرآن</span>، فقال: «وأقوى الأقوال في المسجور: أنه المُوقَد. وهذا هو المعروف في اللغة من المسجور، ويدل عليه قوله تعالى: <span class="qpc-hafs">﴿وإذا البحار سجرت﴾</span> [التكوير:٦]». و<span class="comment-type-4">بيّن</span> أنه لا يعارض القول الأول ولا الثالث. ثم <span class="comment-type-4">جمع</span> بين الأقوال كلها بقوله: «وإذا اعتبرتَ أسلوب القرآن ونظْمه ومفرداته رأيتَ اللفظة تدل على ذلك كلّه، فإن البحر محبوس بقدرة الله، ومملوء ماء، ويذهب ماؤه يوم القيامة ويصير نارًا، فكلٌّ من المفسرين أخذ معنى من هذه المعاني».</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡمَسۡجُورِ ۝٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٠٠<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «<b>لا يركبنّ رجلٌ بحرًا إلا غازيًا أو معتمرًا أو حاجًا؛ فإنّ تحت البحر نارًا، وتحت النار بحرًا</b>»{29}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٧٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٤-. وعزاه السيوطي إلى عبد الرزاق، وسعيد بن منصور، وابن أبي حاتم.|2:أخرجه ابن جرير ٢١/٥٧٠.|3:أخرجه الثعلبي ٩/١٢٥-١٢٦، والبغوي ٧/٣٨٦.|4:أخرجه إسحاق ص٤٤٦.|5:أخرجه عبد الرزاق ٢/٢٤٦، وابن جرير ٢١/٥٧٠.|6:أخرجه أبو الشيخ (٢٥٣).|7:تفسير مقاتل بن سليمان ٤/١٤٣.|8:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٣-، وابن جرير ٢١/٥٦٧-٥٦٨، ٢٤/١٣٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وأبي الشيخ في العظمة، وجاء بعده عن ابن جرير: مخففة.|9:أخرجه أبو الشيخ في العظمة (٩٣٠). وعزاه السيوطي إلى البيهقي في البعث والنشور.|10:أخرجه ابن جرير ٢١/٥٦٩، وابن أبي حاتم -كما في الإتقان ٢/٤٥-.|11:أخرجه إسحاق البستي ص٤٤٥. وعزاه السيوطي إلى ابن المنذر.|12:أخرجه الثعلبي ٩/١٢٥. وعزاه السيوطي إلى الشيرازي في الألقاب.|13:أخرجه ابن جرير ٢١/٥٦٩.|14:أخرجه أبو الشيخ (٩٣١).|15:تفسير البغوي ٧/٣٨٦.|16:تفسير مجاهد ص٦٢٣، وأخرجه ابن جرير ٢١/٥٦٨.|17:علقه البخاري في صحيحه ٤/١٨٨٣.|18:تفسير الثعلبي ٩/١٢٤، وتفسير البغوي ٧/٣٨٦.|19:تفسير مقاتل بن سليمان ٤/١٤٤.|20:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٤-، وبنحوه ابن جرير ١٢/٤٦٠. وعلقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التفسير، عقب باب: سورة والطور ٤/١٨٣٨.|21:أخرجه أبو نعيم في حلية الأولياء ٦/٦١، وهو في الطبري عن شمر بن عطية.|22:أخرجه أبو نعيم في حلية الأولياء ٣/٣٥٦.|23:أخرجه ابن جرير ٢١/٥٦٨ بلفظ: الممتلئ.|24:تفسير الثعلبي ٩/١٢٥، وتفسير البغوي ٧/٣٨٦.|25:أخرجه ابن جرير ٢١/٥٦٨.|26:أخرجه عبد الرزاق ٢/٢٤٧.|27:أخرجه ابن جرير ٢١/٥٦٨.|28:أخرجه إسحاق البستي ص٤٤٦.|29:أخرجه أبو داود ٤/١٤٥ (٢٤٨٩)، من طريق إسماعيل بن زكريا، عن مطرف، عن بشر أبي عبد الله، عن بشير بن مسلم، عن عبد الله بن عمرو به.</p><p>قال ابن عبد البر في التمهيد ١/٢٤٠: «وهو حديث ضعيفٌ، مُظلم الإسناد، لا يصحّحه أهل العلم بالحديث؛ لأن رواته مجهولون لا يُعرفون». وقال العيني في عمدة القاري ١٤/٨٧: «هذا حديث ضعيف». وضعّفه النووي في خلاصة الأحكام ١/٦٩ (٢٥). وقال ابن الملقّن في خلاصة البدر المنير ١/٣٤٤ (١١٨٧): «ضعيف باتفاق الأئمة. قال البخاري: ليس بصحيح. وقال أحمد: غريب. وقال أبو داود: رواته مجهولون. وقال الخطابي: ضعّفوا إسناده. وقال صاحب الإلمام [الإمام]: اختُلف في إسناده». وقال الألباني في الضعيفة ١/٦٩١ (٤٧٨): «منكر». وقال في ضعيف أبي داود ٢/٢٩٩ (٤٢٩): «إسناده ضعيف».
  52,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ عَذَابَ رَبِّكَ لَوَ ٰ⁠قِعࣱ ۝٧ مَّا لَهُۥ مِن دَافِعࣲ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ﴾</span>، قال: وقع القَسم ههنا، وذاك يوم القيامة{1}<span class=comment-ref>٦٢٤٠</span>. (١٣/٧٠٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨٨) أنه على قول قتادة فالعامل في <span class="qpc-hafs">﴿يَوْم﴾</span> هو <span class="qpc-hafs">﴿واقع﴾</span>، ثم ساق <b>احتمالًا آخر</b>، فقال: «ويجوز أن يكون العامل فيه <span class="qpc-hafs">﴿دافِعٍ﴾</span>». ثم <span class="comment-type-3">رجَّح</span> الأول بقوله: «والأول أبين». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٧٢٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ﴾</span> بالكفار، <span class="qpc-hafs">﴿ما لَهُ﴾</span> يعني: العذاب <span class="qpc-hafs">﴿مِن دافِعٍ﴾</span> في الآخرة يدفع عنهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ عَذَابَ رَبِّكَ لَوَ ٰ⁠قِعࣱ ۝٧ مَّا لَهُۥ مِن دَافِعࣲ ۝٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٠٣<span class="dash">-</span></span> عن جبير بن مُطعِم، قال: قدمتُ المدينة على رسول الله ﷺ لأكلّمه في أسارى بدر، فدُفعت إليه وهو يُصلّي بأصحابه صلاة المغرب، فسمعتُه يقرأ: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ﴾</span>، فكأنّما صُدِع قلبي{3}. (١٣/٦٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٠٤<span class="dash">-</span></span> عن عامر الشعبي، قال: سمع <span class="name-1">عمر بن الخطاب</span> رجلًا يقرأ: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ ما لَهُ مِن دافِعٍ﴾</span>، فجعل يبكي حتى اشتدَّ بكاؤه، ثم خرَّ يضطرب، فقيل له في ذلك، فقال: دَعُوني، فإني سمعت قَسَمَ حقٍّ مِن ربي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٠٥<span class="dash">-</span></span> عن الحسن البصري: أن <span class="name-1">عمر بن الخطاب</span> قرأ: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ﴾</span>، فربا لها رَبْوةً{5} عِيدَ لها عشرين يومًا{6}. (١٣/٧٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٠٦<span class="dash">-</span></span> عن مالك بن مغول، قال: قرأ <span class="name-1">عمر</span>: <span class="qpc-hafs">﴿والطُّورِ وكِتابٍ مَسْطُورٍ فِي رَقٍّ مَنشُورٍ﴾</span> قال: قَسمٌ، إلى قوله: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ﴾</span> فبكى ثم بكى، حتى عِيد من وجعه ذلك{7}. (١٣/٧٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٠٧<span class="dash">-</span></span> عن هشام بن حسان، قال: انطلقتُ أنا و<span class="name-2">مالك بن دينار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٠٨<span class="dash">-</span></span> إلى <span class="name-2">الحسن [البصري]</span>، فانتهينا إليه وعنده رجل يقرأ، فلما بلغ هذه الآية: <span class="qpc-hafs">﴿إنَّ عَذابَ رَبِّكَ لَواقِعٌ ما لَهُ مِن دافِعٍ﴾</span> بكى <span class="name-2">الحسنُ</span>، وبكى أصحابُه، وجعل <span class="name-2">مالك</span> يضطرب حتى غُشي عليه{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٤٤.|3:أخرجه أحمد ٢٧/٣٢٦ (١٦٧٦٢)، ٢٧/٣٤٠ (١٦٧٨٥)، والطبراني في المعجم الكبير ٢/١١٧ (١٥٠٢). وعزاه السيوطي إلى سعيد بن منصور، وابن سعد.</p><p>وقال محققو المسند: «صحيح دون قوله: فكأنما صُدع قلبي حين سمع القرآن».|4:أخرجه ابن أبي الدنيا في الرقة والبكاء ٣/١٨٩-١٩٠ (١٠٠).|5:الرّبو والرَّبْوة: البُهْر وانتفاخ الجوف والنَّفَس العالي بسبب الخوف وغيره. لسان العرب (ربا).|6:أخرجه أبو عبيد في فضائله ص٦٤.|7:عزاه السيوطي إلى أحمد في الزهد.|8:أخرجه الثعلبي ٩/١٢٦.
  52,8,""
  52,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ تَمُورُ ٱلسَّمَاۤءُ مَوۡرࣰا ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: تحرَّك{1}. (١٣/٧٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: يوم تشقّق السماء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: تدور دورًا{3}. (١٣/٧٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>: يعني: استدارتها وتحريكها لأمر الله، ومَوْج بعضها في بعض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٣<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: <span class="qpc-hafs">﴿تَمُورُ﴾</span> تختلف{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: مَوْرها: تحرُّكها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٥<span class="dash">-</span></span> قال <span class="name-2">عطاء الخُراسانيّ</span>: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span> تختلف أجزاؤها بعضها في بعض{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أخبر متى يقع بهم العذاب، فقال: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span> يعني: استدارتها وتحريكها بعضها في بعضٍ من الخوف{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّماءُ مَوْرًا﴾</span>، قال: هذا يوم القيامة، وأما المَوْرُ فلا عِلْمَ لنا به{2}<span class=comment-ref>٦٢٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤١</span> <span class="comment-type-1">فُسّر</span> «المور» بالحركة، <b>وفُسّر</b> بالدوران، <b>وفُسّر</b> بالتموج والاضطراب والتشقق.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٩) على تلك المعاني بقوله: «وهذه كلها تفاسير بالمعنى؛ لأن السماء العالية يعتريها هذا كله».</p><p>و<span class="comment-type-4">ساق</span> <u>ابنُ القيم</u> (٣/٥٥) ما جاء في تفسير المور، ثم قال: «والتحقيق أنه حركة في تموّج وتكفؤ وذهاب ومجيء؛ ولهذا فرق بين حركة السماء وحركة الجبال، فقال: <span class="qpc-hafs">﴿وتَسِيرُ الجِبالُ سَيْرًا﴾</span>، وقال: <span class="qpc-hafs">﴿وإذا الجِبالُ سُيِّرَتْ﴾</span> [التكوير:٣] من مكان إلى مكان، وأما السماء فإنها تتكفّأ، وتموج، وتذهب، وتجيء».</div></p><p><div></p><p><p><span class="item-no">٧٢٩١٨<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿يوم تمور السماء مورًا﴾</span> قال: فيها تقديم <span class="qpc-hafs">﴿إن عذاب ربك لواقع﴾</span> بهم <span class="qpc-hafs">﴿يوم تمور السماء مورًا﴾</span>{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٧٢، وابن أبي حاتم -كما في الإتقان ٢/٤٥-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢١/٥٧٣.|3:أخرجه ابن جرير ٢١/٥٧٢-٥٧٣. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢١/٥٧٣.|5:تفسير الثعلبي ٩/١٢٦.|6:أخرجه عبد الرزاق ٢/٢٤٧، وابن جرير ٢١/٥٧٣ من طريق سعيد أيضًا.|7:تفسير الثعلبي ٩/١٢٦، وتفسير البغوي ٧/٣٨٧ بنحوه.|8:تفسير مقاتل بن سليمان ٤/١٤٤.|9:أخرجه ابن جرير ٢١/٥٧٣.|10:أخرجه أبو عمرو الداني في المكتفى ص٢٠٥ (٣٦).
  52,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَسِیرُ ٱلۡجِبَالُ سَیۡرࣰا ۝١٠ فَوَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١١ ٱلَّذِینَ هُمۡ فِی خَوۡضࣲ یَلۡعَبُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَسِيرُ الجِبالُ سَيْرًا﴾</span> مِن أمكنتها حتى تستوي بالأرض كالأديم الممدود، <span class="qpc-hafs">﴿فَوَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span> بالعذاب <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي خَوْضٍ يَلْعَبُونَ﴾</span> يعني: في باطلٍ لاهون{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَسِیرُ ٱلۡجِبَالُ سَیۡرࣰا ۝١٠ فَوَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١١ ٱلَّذِینَ هُمۡ فِی خَوۡضࣲ یَلۡعَبُونَ ۝١٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق حُصين بن عقبة- قال: أكثرُ الناس خطايا أكثرُهم خوْضًا في الباطل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٤٤.|2:أخرجه إسحاق البستي عند تفسير هذه الآية ص٤٤٨.
  52,11,""
  52,12,""
  52,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ یُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا ۝١٣ هَـٰذِهِ ٱلنَّارُ ٱلَّتِی كُنتُم بِهَا تُكَذِّبُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٩٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ﴾</span>، قال: يُدفَعون{1}. (١٣/٧٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ﴾</span>، قال: يُدفعون فيها دفعًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُدفع في أعناقهم حتى يَرِدوا النار{3}<span class=comment-ref>٦٢٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٨٩) على هذا القول بقوله: «<span class="mustanad">ومنه قوله تعالى</span>: <span class="qpc-hafs">﴿فذلك الذي يدع اليتيم﴾</span> [الماعون:٢]».</div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ﴾</span>، قال: يُدفعون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>: الدَّعّ: الدَّفع والإرهاق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، يقول: يُدفعون إلى نار جهنم دفعًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، في قوله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُدفعون إليها دفعًا{7}. (١٣/٧٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُزعَجون إليها إزعاجًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: والويل لهم <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span> وذلك أنّ خزنة جهنم بعد الحساب يغلّون بأيدي الكفار إلى أعناقهم، ثم يجمعون نواصيهم إلى أقدامهم وراء ظهورهم، ثم يدفعونهم في جهنم دفعًا على وجوههم، إذا دَنَوا منها قالت لهم خزنتُها: <span class="qpc-hafs">﴿هذِهِ النّارُ الَّتِي كُنْتُمْ بِها تُكَذِّبُونَ﴾</span> في الدنيا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٩٣٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿يَوْمَ يُدَعُّونَ إلى نارِ جَهَنَّمَ دَعًّا﴾</span>، قال: يُدفَعون دفعًا. وقرأ قول الله تبارك وتعالى: <span class="qpc-hafs">﴿فَذَلِكَ الَّذِي يَدُعُّ اليَتِيمَ﴾</span> [الماعون:٢]، قال: يدفعه ويُغْلِظ عليه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٧٥، وبنحوه من طريق عطية، وابن أبي حاتم -كما في الإتقان ٢/٤٥-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢١/٥٧٥، كما أخرجه إسحاق البستي ص٤٤٨ من طريق عطاء الخُراسانيّ.|3:أخرجه ابن جرير ٢١/٥٧٥.|4:تفسير مجاهد ص٦٢٣، وأخرجه ابن جرير ٢١/٥٧٦.|5:أخرجه ابن جرير ٢١/٥٧٦.|6:أخرجه ابن جرير ٢١/٥٧٥.|7:عزاه السيوطي إلى سعيد بن منصور.|8:أخرجه عبد الرزاق ٢/٢٤٧، وابن جرير ٢١/٥٧٦، ومن طريق سعيد أيضًا.|9:تفسير مقاتل بن سليمان ٤/١٤٤.|10:أخرجه ابن جرير ٢١/٥٧٦.
  52,14,""