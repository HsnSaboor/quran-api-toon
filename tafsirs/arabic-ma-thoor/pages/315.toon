quran[13]{c,v,t}:
  20,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ عِلۡمُهَا عِندَ رَبِّی فِی كِتَـٰبࣲۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿علمها عند ربي﴾</span> الآية، يقول: أي: أعمارها وآجالها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... لَمّا سمع ذلك فرعونُ مِن المؤمن قال لموسى: <span class="qpc-hafs">﴿فما بال القرون الأولى﴾</span>، فلم يعلم موسى ما أمْرُهم؛ لأنّ التوراة إنما أُنزِلت على موسى ﵇ بعد هلاك فرعون وقومه. فمِن ثَمَّ رد عليه موسى، فـ<span class="qpc-hafs">﴿قال علمها عند ربي في كتاب﴾</span> يعني: اللوح المحفوظ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ عِلۡمُهَا عِندَ رَبِّی فِی كِتَـٰبࣲۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٣١<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي المُهَزِّم- قال: قال فرعون: يا هامان، إنّ موسى يعرض عليَّ أن لي مُلْكِي حياتي ما بقيت، وأنّ لي الجنة إذا مِتُّ. وقال له هامان: بينما أنت إله تُعبد إذ صرت عبدًا تَعبُد! فردَّه عن رأيه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٢<span class="dash">-</span></span> عن أبي هلال، قال: كنا عند <span class="name-2">قتادة</span>، فذكروا الكتاب، وسألوه عن ذلك. فقال: وما بأس بذلك، أليس الله الخبير يُخْبِر: <span class="qpc-hafs">﴿قال فما بال القرون الأولى قال علمها عند ربي في كتاب﴾</span>{4}. (١٠/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٣<span class="dash">-</span></span> عن <span class="name-3">أبي المَلِيح</span>، قال: الناسُ يَعِيبُون علينا الكتابَ، وقال الله تعالى: <span class="qpc-hafs">﴿علمها عند ربي في كتاب﴾</span>{5}. (١٠/٢١٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّا یَضِلُّ رَبِّی وَلَا یَنسَى ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا يضل ربي﴾</span>، قال: لا يُخْطِئ{6}. (١٠/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لا يضل ربي ولا ينسى﴾</span>، قال: هما شيء واحد{7}<span class=comment-ref>٤٢٧٦</span>. (١٠/٢١٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٧٦</span> ذكر <u>ابنُ جرير</u> (١٦/٨٤) قولَ مَن فسر الضلال بالخطأ، كما في قول ابن عباس وغيره، وقول مَن جعله والنسيان بمعنى واحد، ثم <span class="comment-type-4">علّق</span> قائلًا: «والعرب تقول: ضَلَّ فلان منزله: إذا أخطأه، يَضِلُّه، بغير ألف، وكذلك ذلك في كل ما كان من شيء ثابت لا يبرح فأخطأه مريده، فإنها تقول: ضلَّه، ولا تقول: أضلَّه. فأمّا إذا ضاع منه ما يزول بنفسه من دابة وناقة وما أشبه ذلك من الحيوان الذي ينفلت منه فيذهب، فإنها تقول: أضلَّ فلان بعيره أو شاته أو ناقته، يُضِلُّه، بالألف».</div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٦<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿قال علمها عند ربي في كتاب لا يضل ربي ولا ينسى﴾</span> لا يَضِلُّه فيذهب، ولا ينسى ما فيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿لا يضل ربي ولا ينسى﴾</span>، قال: لا يضل ربي الكتاب، ولا ينسى ما فيه{9}. (١٠/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿قال علمها عند ربي في كتاب لا يضل ربي ولا ينسى﴾</span> يعني: ذلك الكتاب، <span class="qpc-hafs">﴿ولا ينسى﴾</span> عِلْمَ أعمالِها وآجالِها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يضل ربي﴾</span> يعني: لا يُخْطِئُ ذلك الكتابَ ربي، <span class="qpc-hafs">﴿ولا ينسى﴾</span> ما فيه. فلما أنزل الله ﷿ عليه التوراة أعْلَمَه، وبَيَّن له فيها القرون الأولى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٨٠.|2:تفسير مقاتل بن سليمان ٣/٢٩.|3:أخرجه يحيى بن سلّام ١/٢٦٣.|4:أخرجه ابن سعد ٧/٢٣٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|5:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:أخرجه ابن جرير ١٦/٨٣، وابن أبي حاتم -كما في الإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ١٦/٨٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|8:علقه يحيى بن سلّام ١/٢٦٢.|9:عزاه السيوطي إلى ابن أبي حاتم.|10:علقه يحيى بن سلّام ١/٢٦٢.|11:تفسير مقاتل بن سليمان ٣/٢٩.
  20,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ مَهۡدࣰا وَسَلَكَ لَكُمۡ فِیهَا سُبُلࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٤٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: سَهَّل لكم فيها طرقًا تسلكونها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وسلك لكم فيها سبلا﴾</span>: أي: طُرُقًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر موسى ﵇ صُنْعَ الله ﷿؛ لِيَعْتَبِر به فرعون، فقال: <span class="qpc-hafs">﴿الذي جعل لكم الأرض مهدا﴾</span> يعني: فراشًا، <span class="qpc-hafs">﴿وسلك لكم﴾</span> يعني: وجعل لكم <span class="qpc-hafs">﴿فيها سبلا﴾</span> يعني: طُرُقًا في الأرض{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿الذي جعل لكم الأرض مهدا﴾</span> مثل قوله: <span class="qpc-hafs">﴿جعل لكم الأرض بساطا﴾</span> [نوح:١٩]، <span class="qpc-hafs">﴿فراشا﴾</span> [البقرة:٢٢]، قوله: <span class="qpc-hafs">﴿وسلك لكم فيها سبلا﴾</span> أي: وجعل لكم فيها طُرُقًا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَخۡرَجۡنَا بِهِۦۤ أَزۡوَ ٰ⁠جࣰا مِّن نَّبَاتࣲ شَتَّىٰ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿من نبات شتى﴾</span>، قال: مختلف{5}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فأخرجنا به أزواجا﴾</span>: يقول: أصنافًا، لكل صنف من نبات الأرض أزواج؛ النخل زوجٌ صنفٌ، والأعناب زوجٌ صنفٌ، وكل شيء تنبته الأرض أزواج{6}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنزل من السماء ماء فأخرجنا به﴾</span> يعني: بالمطر <span class="qpc-hafs">﴿أزواجا من نبات شتى﴾</span> مِن الأرض، يعني: مختلفًا مِن كل لون مِن النبت؛ منها للدوابِّ، ومنها للناس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأنزل﴾</span> لكم <span class="qpc-hafs">﴿من السماء ماء فأخرجنا به أزواجا من نبات شتى﴾</span> مختلف في لونه وطعمه، وكل ما ينبت في الأرض فالواحد منه زوج. قال: فالذي ينبت هذه الأزواج الشتّى قادِرٌ على أن يبعثكم بعد الموت{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٥/٢٧٨.|2:أخرجه ابن جرير ١٦/٨٥.|3:تفسير مقاتل بن سليمان ٣/٢٩.|4:تفسير يحيى بن سلّام ١/٢٦٣.|5:أخرجه ابن جرير ١٦/٨٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:عزاه السيوطي إلى ابن المنذر.|7:تفسير مقاتل بن سليمان ٣/٢٩.|8:تفسير يحيى بن سلّام ١/٢٦٣.
  20,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُوا۟ وَٱرۡعَوۡا۟ أَنۡعَـٰمَكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿كلوا وارعوا أنعامكم﴾</span> مِن ذلك النبات{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّأُو۟لِی ٱلنُّهَىٰ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لأولي النهى﴾</span>، قال: لأولي التُّقى{2}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لأولي النهى﴾</span>، قال: لِذَوِي الحِجا والعقل{3}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥١<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿لأولي النهى﴾</span> الذين ينتهون عما حرَّم الله عليهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لِأُولِي العقول{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لأولي النهى﴾</span>، قال: لأولي الوَرَع{6}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٤<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، في قوله: <span class="qpc-hafs">﴿لأولي النهى﴾</span>، قال: الذين ينتهون عما نهوا عنه{3}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك﴾</span> يعني: فيما ذُكِر مِن هذه الآية <span class="qpc-hafs">﴿لآيات﴾</span> يعني: لَعِبْرَة <span class="qpc-hafs">﴿لأولي النهى﴾</span> يعني: لِذَوي العقولِ في توحيد الله ﷿، هذا قول موسى ﵇ لفرعون{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ١/٢٦٣.|2:أخرجه ابن جرير ١٦/٨٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن المنذر.|4:تفسير الثعلبي ٦/٢٤٨، وتفسير البغوي ٥/٢٧٨.|5:علَّقه يحيى بن سلّام ١/٢٦٣.|6:أخرجه يحيى بن سلّام ١/٢٦٣. وعزاه السيوطي إلى ابن أبي حاتم.|7:عزاه السيوطي إلى ابن المنذر.|8:تفسير مقاتل بن سليمان ٣/٣٠.
  20,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مِنۡهَا خَلَقۡنَـٰكُمۡ وَفِیهَا نُعِیدُكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٥٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعني: خَلَق آدم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>، قال: إنّ الملَك ينطلِق، فيأخذ مِن تراب المكان الذي يُدْفَن فيه، فيَذُرُّهُ على النُّطفة، فيخلق مِن التراب ومِن النطفة، وذلك قوله: <span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم﴾</span>{2}. (١٠/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال الله ﷿: <span class="qpc-hafs">﴿منها خلقناكم﴾</span> يعني: أول مرة خلقكم مِن الأرض مِن التراب الذي ذَكَر في هذه الآية التي قبلها، <span class="qpc-hafs">﴿وفيها نعيدكم﴾</span> إذا مِتُّم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿منها خلقناكم﴾</span>، يعني: من الأرض خلقناكم ... وبلغني: أنّه يُؤْخَذ من تربة الأرض التي يموت فيها، فيخلط بخلقه، أو فتُذَرّى على خلقه، وهو قوله: <span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم ومنها نخرجكم تارة أخرى﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡهَا نُخۡرِجُكُمۡ تَارَةً أُخۡرَىٰ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومنها نخرجكم تارة أخرى﴾</span>، يقول: مرَّة أخرى{5}. (١٠/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومنها نخرجكم﴾</span> يوم القيامة أحياءَ بعد الموت <span class="qpc-hafs">﴿تارة أخرى﴾</span> يعني: مرة أخرى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿تارة أخرى﴾</span>، قال: مرة أخرى الخَلْق الآخَر{7}<span class=comment-ref>٤٢٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٧٧</span> ذكر <u>ابنُ جرير</u> (١٦/٨٧) قول ابن زيد، وقول قتادة قبله، ثم <span class="comment-type-1">وجّه</span> معنى الآية عليهما، فقال: «فتأويل الكلام إذن: مِن الأرض أخرجناكم -ولم تكونوا شيئًا- خلقًا سَوِيًّا، وسنخرجكم منها بعد مماتكم مرة أخرى، كما أخرجناكم منها أول مرة».</div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡهَا نُخۡرِجُكُمۡ تَارَةً أُخۡرَىٰ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٦٣<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، قال: لَمّا وُضِعَت أمُّ كلثوم بنت رسول الله ﷺ في القبرِ قال رسول الله ﷺ: «<span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم ومنها نخرجكم تارة أخرى﴾</span>. <b>باسم الله، وفي سبيل الله، وعلى مِلَّةِ رسول الله</b>»{8}. (١٠/٢١٥)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلّام ١/٢٦٣.|2:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٣٠.|4:تفسير يحيى بن سلّام ١/٢٦٣-٢٦٤.|5:أخرجه يحيى بن سلّام ١/٢٦٣، وابن جرير ١٦/٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٣٠.|7:أخرجه ابن جرير ١٦/٨٧.|8:أخرجه أحمد ٣٦/٥٢٤ (٢٢١٨٧)، والحاكم ٢/٤١١ (٣٤٣٣) واللفظ له.</p><p>قال الذهبي في التلخيص: «لم يتكلم عليه -أي: الحاكم-، وهو خبر واهٍ؛ لأن علي بن يزيد متروك».
  20,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَرَیۡنَـٰهُ ءَایَـٰتِنَا كُلَّهَا فَكَذَّبَ وَأَبَىٰ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد أريناه آياتنا كلها﴾</span> يعني: فرعون، الآيات التسع: الطوفان، والجراد، والقمل، والضفادع، والدم، والطمس{1}، والسنين، والعصا، واليد، <span class="qpc-hafs">﴿فكذب﴾</span> بها بأنّها ليست مِن الله ﷿، <span class="qpc-hafs">﴿وأبى﴾</span> أن يُصَدِّق بها، وزعم أنها سحر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولقد أريناه آياتنا كلها﴾</span> التسع: يده، وعصاه، والطوفان، والجراد، والقمل، والضفادع، والدم، <span class="qpc-hafs">﴿ولقد أخذنا آل فرعون بالسنين ونقص من الثمرات﴾</span> [الأعراف:١٣٠]. قال: <span class="qpc-hafs">﴿فكذب وأبى﴾</span> أن يؤمن{3}. (ز)</p></p><p></div></p></div>",footnotes:1:هو قول الله تعالى: <span class="qpc-hafs">﴿وقال موسى ربنا إنك آتيت فرعون وملأه زينة وأموالا في الحياة الدنيا ربنا ليضلوا عن سبيلك ربنا اطمس على أموالهم واشدد على قلوبهم فلا يؤمنوا حتى يروا العذاب الأليم. قال قد أجيبت دعوتكما﴾</span> [يونس:٨٨-٨٩].|2:تفسير مقاتل بن سليمان ٣/٣٠.|3:تفسير يحيى بن سلّام ١/٢٦٤.
  20,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَجِئۡتَنَا لِتُخۡرِجَنَا مِنۡ أَرۡضِنَا بِسِحۡرِكَ یَـٰمُوسَىٰ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون لموسى: <span class="qpc-hafs">﴿أجئتنا لتخرجنا من أرضنا بسحرك ياموسى﴾</span> اليد والعصا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٠.
  20,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَنَأۡتِیَنَّكَ بِسِحۡرࣲ مِّثۡلِهِۦ فَٱجۡعَلۡ بَیۡنَنَا وَبَیۡنَكَ مَوۡعِدࣰا لَّا نُخۡلِفُهُۥ نَحۡنُ وَلَاۤ أَنتَ مَكَانࣰا سُوࣰى ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿مكانا سوى﴾</span>، قال: مَنصَفًا بينهم{1}. (١٠/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿مكانا سوى﴾</span>، قال: نصفًا بيني وبينك{2}. (١٠/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٦٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: مكانًا عَدْلًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿مكانا سوى﴾</span>، قال: عدلًا{4}. (١٠/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: يعني: سوى هذا المكان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلنأتينك بسحر مثله﴾</span> يعني: بمثل سحرك، <span class="qpc-hafs">﴿فاجعل بيننا وبينك موعدا﴾</span> يعني: وقتًا <span class="qpc-hafs">﴿لا نخلفه نحن ولا أنت مكانا سوى﴾</span> يعني: ميقاتًا، يعني: عدلًا، كقوله سبحانه: <span class="qpc-hafs">﴿أصحاب الصراط السوي﴾</span> [طه:١٣٥]، يعني: العدل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿مكانا سوى﴾</span>، قال: مكانًا مستويًا، يَتَبَيَّنُ الناسُ ما فيه، لا يكون صُوَبٌ{7} ولا شيء؛ فيغيب بعضُ ذلك عن بعض، مستَوٍ حين يُرى{4}. (١٠/٢١٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٨٩. وعلَّقه يحيى بن سلّام ١/٢٦٤. وعزاه السيوطي إلى عبد بن حميد، ابن المنذر، وابن أبي حاتم.|2:أخرجه عبد الرزاق ٢/١٧، وابن جرير ١٦/٩٠. وعزاه السيوطي إلى عبد بن حميد.|3:علقه يحيى بن سلّام ١/٢٦٤.|4:أخرجه ابن جرير ١٦/٩٠. وعزاه السيوطي إلى ابن أبي حاتم.|5:تفسير البغوي ٥/٢٧٩.|6:تفسير مقاتل بن سليمان ٣/٣٠. وفي تفسير البغوي ٥/٢٧٩ بنحوه منسوبًا إلى مقاتل دون تعيينه.|7:صُوَبٌ: جمع صُوبة، وهي الكُثْبة من تُرابٍ أو غيره. اللسان (صوب).|8:أخرجه ابن جرير ١٦/٩٠. وعزاه السيوطي إلى ابن أبي حاتم.
  20,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ مَوۡعِدُكُمۡ یَوۡمُ ٱلزِّینَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿موعدكم يوم الزينة﴾</span>، قال: يوم عاشوراء{1}. (١٠/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿قال موعدكم يوم الزينة وأن يحشر الناس ضحى﴾</span>: فإنّه يوم زينة يجتمع الناس إليه، ويحشر الناس له{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قال: <span class="qpc-hafs">﴿موعدكم يوم الزينة﴾</span>، قال: يوم السوق{3}. (١٠/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: يوم عاشوراء{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿قال موعدكم يوم الزينة﴾</span>، قال: هو يومُ عِيدٍ لهم{5}. (١٠/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح، وابن جُرَيْج- <span class="qpc-hafs">﴿يوم الزينة﴾</span>: موعدهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿قال موعدكم يوم الزينة﴾</span>، قال: هو يوم عيدٍ كان لهم{7}. (١٠/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قال موعدكم يوم الزينة﴾</span>، قال: يوم زينة واعدوه فيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿موعدكم يوم الزينة وأن يحشر الناس ضحى﴾</span> وذلك يوم عيد لهم{9}<span class=comment-ref>٤٢٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٧٨</span> ذكر <u>ابنُ كثير</u> (٩/٣٤٦) قول السدي ومَن وافقه، وقول ابن عباس أنّ يوم الزينة: هو يوم عاشوراء، وقول سعيد بن جبير: أنه يوم سوقهم، وبيّن أنه لا منافاة بين هذه الأقوال.</div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: يوم عيد لهم، كلِّ سنة يتزيّنون ويجتمعون فيه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى لفرعون: <span class="qpc-hafs">﴿موعدكم يوم الزينة﴾</span> يعني: يوم عيد لهم في كل سنة واحد، وهو يوم النيروز{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿قال موعدكم يوم الزينة﴾</span> قال: يوم زينة لهم، ويوم عيد لهم، <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span> إلى عيد لهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span>، <span class="qpc-hafs">﴿قال موعدكم يوم الزينة﴾</span>: يوم عيد كان فرعون يخرج له{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿موعدكم يوم الزينة﴾</span>، قال: يوم العيد؛ يوم يَتَفَرَّغ الناسُ مِن الأعمال، ويشهدون، ويحضرون، ويَرَوْن{14}. (١٠/٢١٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ مَوۡعِدُكُمۡ یَوۡمُ ٱلزِّینَةِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، قال: قال رسول الله ﷺ: «<b>مَن صام يوم الزِّينة أدرك ما فاته مِن صيام تلك السنة، ومَن تصدق يومئذٍ بصدقة أدرك ما فاته مِن صدقة تلك السنة</b>». يعني: يوم عاشوراء{15}. (١٠/٢١٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَن یُحۡشَرَ ٱلنَّاسُ ضُحࣰى ۝٥٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي نَهِيك</span> أنّه قرأ: (وأَن تَحْشُرَ النّاسَ ضُحًى) بالتاء؛ وأن تحشر أنت، قال: فرعون يحشرُ قومَه{16}. (١٠/٢١٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَن یُحۡشَرَ ٱلنَّاسُ ضُحࣰى ۝٥٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٩٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يوم عيد كان لهم، يجتمعون فيه ضحًى{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span>، قال: يجتمعون لذلك الميعاد الذي واعدوه{18}. (١٠/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٢<span class="dash">-</span></span> عن عبد المؤمن، قال: سمعت <span class="name-2">أبا نَهِيك</span> يقول: (وأن يَحْشُر الناس ضحى)، يعني: فرعون يحشر قومه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span>، يعني: أهل مصر{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span>، يعني: نهارًا في اليوم الذي فيه العيد. مثل قوله: <span class="qpc-hafs">﴿بأسنا ضحى﴾</span> [الأعراف:٩٨]، يعني: نهارًا. وبَعَث فرعون شُرْطَةً، فحشرهم للميعاد{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span>: حتى يحضروا أمري وأمرك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٦<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> في قوله: <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span>، قال: ليس هو بيوم القيامة، وإنما هو يوم فرعون وموسى، <span class="qpc-hafs">﴿ضحى﴾</span> قال: الشمس{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وقال بعضهم: <span class="qpc-hafs">﴿وأن يحشر الناس ضحى﴾</span>، يعني: نهارًا{24}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ١٦/٩١.|3:أخرجه ابن جرير ١٦/٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير الثعلبي ٦/٢٤٩، وتفسير البغوي ٥/٢٧٩.|5:تفسير مجاهد ص٤٦٣. وعزاه السيوطي إلى عبد بن حميد بلفظ: يوم عيدهم.|6:أخرجه إسحاق البستي في تفسيره ص٢٦١ من طريق ابن جريج، وابن جرير ١٦/٩١، ٩٢.|7:أخرجه عبد الرزاق ٢/١٧، وابن جرير ١٦/٩٠ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه يحيى بن سلّام ١/٢٦٥.|9:أخرجه ابن جرير ١٦/٩٢.|10:تفسير الثعلبي ٦/٢٤٩.|11:تفسير مقاتل بن سليمان ٣/٣٠. وفي تفسير الثعلبي ٦/٢٤٩، وتفسير البغوي ٥/٢٧٩ بنحوه منسوبًا إلى مقاتل دون تعيينه.|12:أخرجه ابن جرير ١٦/٩١.|13:أخرجه ابن جرير ١٦/٩٢.|14:أخرجه ابن جرير ١٦/٩٢. وعزاه السيوطي إلى ابن أبي حاتم.|15:أخرجه الأصبهاني في الترغيب والترهيب ٢/٤٠٢ (١٨٧٣)، من طريق عيسى بن إبراهيم الهاشمي، ثنا ابن لهيعة، عن يزيد بن حبيب، عن الوليد بن عمرو، عن عبد الله بن عمرو به. وعزاه السيوطي إلى ابن المنذر.</p><p>إسناده ضعيف؛ فيه ابن لهيعة، وهو ضعيف.|16:عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة، تروى أيضًا عن أبي عمران النحوي، والجحدري. انظر: مختصر ابن خالويه ص٩١.|17:علقه يحيى بن سلّام ١/٢٦٥.|18:أخرجه يحيى بن سلّام ١/٢٦٥، وابن جرير ١٦/٩٣. وعزاه السيوطي إلى ابن أبي حاتم.|19:أخرجه ابن جرير ١٦/٩٣.|20:علَّقه يحيى بن سلّام ١/٢٦٥.|21:تفسير مقاتل بن سليمان ٣/٣٠.|22:أخرجه ابن جرير ١٦/٩٢.|23:تفسير الثوري ص١٩٤.|24:تفسير يحيى بن سلّام ١/٢٦٥.
  20,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّىٰ فِرۡعَوۡنُ فَجَمَعَ كَیۡدَهُۥ ثُمَّ أَتَىٰ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٨٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتولى فرعون﴾</span> يقول: أعْرَضَ فرعونُ عن الحقِّ الذي دُعِيَ إليه، <span class="qpc-hafs">﴿فجمع كيده﴾</span> يعني: سَحَرَتَه، <span class="qpc-hafs">﴿ثم أتى﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٨٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فتولى فرعون فجمع كيده﴾</span> يعني: ما جمع من سحرة، <span class="qpc-hafs">﴿ثم أتى﴾</span> قال: ثم جاء{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١.|2:تفسير يحيى بن سلّام ١/٢٦٥.
  20,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَهُم مُّوسَىٰ وَیۡلَكُمۡ لَا تَفۡتَرُوا۟ عَلَى ٱللَّهِ كَذِبࣰا فَیُسۡحِتَكُم بِعَذَابࣲۖ وَقَدۡ خَابَ مَنِ ٱفۡتَرَىٰ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٩٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فيسحتكم﴾</span>، قال: يُهْلِككم{1}. (١٠/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق- قال: جمع كلُّ ساحر حبالَه وعِصِيَّه، وخرج موسى معه أخوه يتكئ على عصاه، حتى أتى الجَمْعَ، وفرعونُ في مجلسه، معه أشرافُ أهل مملكته، قد استكفَّ له الناس{2}، فقال موسى للسحرة حين جاءهم: <span class="qpc-hafs">﴿ويلكم لا تفتروا على الله كذبا فيسحتكم بعذاب وقد خاب من افترى﴾</span>. فتَرادَّ السحرةُ بينهم، وقال بعضُهم لبعض: ما هذا بقول ساحر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قوله: <span class="qpc-hafs">﴿قال لهم موسى ويلكم لا تفتروا على الله كذبا فيسحتكم بعذاب﴾</span>، قال: فيستأصلكم بعذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿فيسحتكم﴾</span>، قال: يذبحكم{5}. (١٠/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فيسحتكم﴾</span>، قال: يستأصلكم بعذاب، فيهلككم{6}. (١٠/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فيسحتكم بعذاب﴾</span>، قال: يهلككم بعذاب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿فيسحتكم﴾</span>، قال: فيهلككم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال لهم موسى ويلكم لا تفتروا على الله كذبا﴾</span> لقولهم: إنّ اليد والعصا ليستا مِن الله ﷿، وإنها سحر؛ <span class="qpc-hafs">﴿فيسحتكم﴾</span> يعني: فيهلككم جميعًا <span class="qpc-hafs">﴿بعذاب وقد خاب﴾</span> يعني: وقد خَسِر <span class="qpc-hafs">﴿من افترى﴾</span> وقال الكَذِب على الله ﷿{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فيسحتكم﴾</span>، قال: فيُهْلِككم هلاكًا ليس له بَقِيَّة، والذي يُسحَتُ ليس فيه بقية{10}<span class=comment-ref>٤٢٧٩</span>. (١٠/٢١٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٧٩</span> لم يذكر <u>ابنُ جرير</u> (١٦/٩٤) غير قول ابن زيد وما في معناه.</div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٩٤، وابن أبي حاتم -كما في الإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.|2:استكفَّ له الناس: أحدقوا به. النهاية (كفف).|3:أخرجه ابن جرير ١٦/٩٦.|4:أخرجه يحيى بن سلّام ١/٢٦٥.|5:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|6:أخرجه عبد الرزاق ٢/١٨، وابن جرير ١٦/٩٤. وعزاه السيوطي إلى عبد بن حميد بلفظ: يستأصلكم. وكذا أخرجه ابن جرير ١٦/٩٤ من طريق سعيد.|7:أخرجه ابن جرير ١٦/٩٣.|8:تفسير الثعلبي ٦/٢٤٩، وتفسير البغوي ٥/٢٨٠.|9:تفسير مقاتل بن سليمان ٣/٣١.|10:أخرجه ابن جرير ١٦/٩٤. وعزاه السيوطي إلى ابن أبي حاتم.
  20,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَنَـٰزَعُوۤا۟ أَمۡرَهُم بَیۡنَهُمۡ وَأَسَرُّوا۟ ٱلنَّجۡوَىٰ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٩٠٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق- قال: أشار بعضهم إلى بعض بتناجٍ: <span class="qpc-hafs">﴿إن هذان لساحران يريدان أن يخرجاكم من أرضكم بسحرهما﴾</span>{1}<span class=comment-ref>٤٢٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٨٠</span> <span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٦/١٠٥-١٠٦) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> ما جاء في قول وهب، فقال: «وقالت فرقة: إنما كان تناجيهم بالآية التي بعد هذا: <span class="qpc-hafs">﴿إن هذانِ لَساحِرانِ﴾</span>. والأظهر أنّ تلك قيلت علانية، ولو كان تناجيهم ذلك لم يكن ثَمَّ تنازع، والنَّجْوى: السرُّ والمسارة. أي: كان كل رجل يناجي مَن يليه، ثم جعلوا ذلك سِرًّا مخافة فرعون أن يتبين فيهم ضعفًا؛ لأنهم لم يكونوا حينئذ مُصَمِّمين على غلبة موسى، بل كان ظنًّا مِن بعضهم».</div></p><p><div></p><p><p><span class="item-no">٤٧٩١٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿فَتَنازَعُوا أمْرَهُمْ بَيْنَهُمْ وأَسَرُّوا النَّجْوى﴾</span>، قال: قالوا فيما بينهم: لو كان هذا بسحر لَعَلِمناه كما يَعْرِفُ الكاتبُ الذي بين يديه، ولكنَّه ليس بسحر. وجادلوا فرعون مجادلة الأنبياء{2}. (١٠/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَسَرُّوا النَّجْوى﴾</span>، قال: قالت السَّحَرة بينهم: إن كان هذا سحرٌ فإنّا سَنَغْلِبُه، وإن كان مِن السماء فله أمر{3}. (١٠/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩١٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فَتَنازَعُوا أمْرَهُمْ بَيْنَهُمْ وأَسَرُّوا النَّجْوى﴾</span>، قال: مِن دون موسى وهارون{4}. (١٠/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩١٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: قالوا سِرًّا: إن غَلَبَنا موسى اتبعناه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتنازعوا أمرهم بينهم﴾</span> يعني: اختلفوا في قولهم بينهم. نظيرها في الكهف [٢١]: <span class="qpc-hafs">﴿إذ يتنازعون بينهم أمرهم﴾</span>. <span class="qpc-hafs">﴿وأسروا النجوى﴾</span> مِن موسى وهارون ﵉{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩١٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: لَمّا قال لهم موسى: لا تفتروا على الله كَذِبًا. قال بعضُهم لبعض: ما هذا بقول ساحر{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٩٦.|2:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:أخرجه يحيى بن سلّام ١/٢٦٥. وعزاه السيوطي إلى ابن أبي حاتم.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:تفسير البغوي ٥/٢٨٠.|6:تفسير مقاتل بن سليمان ٣/٣١.|7:تفسير البغوي ٥/٢٨٠.
  20,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنۡ هَـٰذَ ٰ⁠نِ لَسَـٰحِرَ ٰ⁠نِ یُرِیدَانِ أَن یُخۡرِجَاكُم مِّنۡ أَرۡضِكُم بِسِحۡرِهِمَا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٧٩١٦<span class="dash">-</span></span> عن الأعمش، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (إنْ هَذانِ إلّا ساحِرانِ){1}<span class=comment-ref>٤٢٨١</span>. (١٠/٢١٨)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٨١</span> ذكر <u>ابنُ جرير</u> (١٦/٩٧-١٠١) اختلاف القرّاء في الآية، ثم قال (١٦/١٠١): «والصوابُ من القراءة في ذلك عندنا: ›إنْ‹ بتشديد نونها، و<span class="qpc-hafs">﴿هذان﴾</span> بالألف؛ <span class="mustanad">لإجماع الحُجَّة مِن القرأة عليه</span>، <span class="mustanad">وأنه كذلك هو في خط المصحف</span>. و<span class="comment-type-1">وجهه</span> إذا قرئ كذلك: مُشابهته»الذين«؛ إذ زادوا على»الذي«النون، وأُقِرَّ في جميع الأحوال الإعراب على حالة واحدة، فكذلك <span class="qpc-hafs">﴿إن هذان﴾</span> زيدت على»هذا«نون، وأُقِرَّ في جميع أحوال الإعراب على حال واحدة، وهي لغة الحارث بن كعب، وخثعم، وزبيد، ومن ولِيَهُم مِن قبائل اليمن».</div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنۡ هَـٰذَ ٰ⁠نِ لَسَـٰحِرَ ٰ⁠نِ یُرِیدَانِ أَن یُخۡرِجَاكُم مِّنۡ أَرۡضِكُم بِسِحۡرِهِمَا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٩١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿قالوا إن هذان لساحران﴾</span>، قال: يعنون: موسى وهارون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فنجواهم أن <span class="qpc-hafs">﴿قالوا إن هذان لساحران يريدان أن يخرجاكم من أرضكم﴾</span> يعني: أرض مصر <span class="qpc-hafs">﴿بسحرهما﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنۡ هَـٰذَ ٰ⁠نِ لَسَـٰحِرَ ٰ⁠نِ یُرِیدَانِ أَن یُخۡرِجَاكُم مِّنۡ أَرۡضِكُم بِسِحۡرِهِمَا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٩١٩<span class="dash">-</span></span> قال أبان: قُرِئَت هذه الآية عند <span class="name-1">عثمان بن عفان</span>، فقال: لحن وخطأ. فقيل له: ألا تُغَيِّره؟ فقال: دَعُوه؛ فإنّه لا يُحِلُّ حرامًا، ولا يُحَرِّم حلالًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٠<span class="dash">-</span></span> عن عروة، قال: سألتُ <span class="name-1">عائشة</span> عن لحن القرآن: <span class="qpc-hafs">﴿إن الذين ءامنوا والذين هادوا والصائبون﴾</span> [المائدة:٦٩]، و<span class="qpc-hafs">﴿المقيمين الصلاة والمؤتون الزكاة﴾</span> [النساء:١٦٢]، و‹إنَّ هَذانِ لَساحِرانِ›. فقالت: يا ابن أختي، هذا عَمَلُ الكُتّاب، أخْطَئوا في الكتاب{5}<span class=comment-ref>٤٢٨٢</span>. (٥/١٢٨)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٨٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٧/٦٨٣) <span class="mustanad">مستندًا إلى خط المصحف</span> <span class="mustanad">وقراءة المسلمين</span> ما ذكر عن عائشة، بأنه لو كان ذلك «خطأً من جهة الخطِّ لم يكن الذين أُخِذ عنهم القرآن مِن أصحاب رسول الله ﷺ يُعلِّمون مَن علَّموا ذلك مِن المسلمين على وجْه اللحن، ولأصلحوه بألسنتهم، ولقَّنوه الأمة تعليمًا على وجه الصواب. وفي نقل المسلمين جميعًا ذلك قراءةً على ما هو به في الخطِّ مرسومًا أدلُّ الدليل على صحة ذلك وصوابه، وأن لا صُنْعَ في ذلك للكاتب».</div></p><p><h3><span class="qpc-hafs">﴿وَیَذۡهَبَا بِطَرِیقَتِكُمُ ٱلۡمُثۡلَىٰ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٩٢١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الشعبي- في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، قال: يَصْرِفا وجوهَ الناس إليهما. وهي بالسُّرْيانِيَّة{6}. (١٠/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، يقول: أمثلكم. وهم بنو إسرائيل{7}. (١٠/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح، وابن جريج- في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، قال: أُولُو العقلِ والشرفِ والأسنانِ{7}. (١٠/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، يعني: يذهبا بخِياركم{9}. (١٠/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، قال: رأس الكفر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، قال: بأشرافكم{11}. (١٠/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور بن زادان-، نحو ذلك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ويذهبا بعيشكم الأمثل، يعني: بني إسرائيل. وكان بنو إسرائيل في القِبط بمنزلة أهلِ الجِزْية فينا؛ يأخذون منهم الخَراج، ويستعبدونهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>: وطريقتهم المثلى يومئذ كانت بني إسرائيل، وكانوا أكثر القوم عددًا وأموالًا وأولادًا. قال عدوُّ الله: إنما يريدان أن يذهبا بهم لأنفسهما{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، يقول: يذهبا بأشراف قومكم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: يعني: الأمثل فالأمثل مِن ذَوِي الرَّأْي والعقول{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، يقول: يَغْلِبانِكُم على الرجال -والأمثال: جمع أمثل، وهو الممتاز مِن الرجال مِن أهل العقول والشرف-، فيتبعون موسى وهارون، ويتركون فرعون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>، قال: يذهبا بالذي أنتم عليه؛ يغير ما أنتم عليه. وقرأ: <span class="qpc-hafs">﴿ذروني أقتل موسى﴾</span> [غافر:٢٦]. قال: هذا قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span>. وقال: يقول: طريقتكم اليوم طريقة حسنة، فإذا غُيِّرت ذهبت هذه الطريقة{18}<span class=comment-ref>٤٢٨٣</span>. (١٠/٢١٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٨٣</span> اختلف المفسرون في المراد من الطريقة على قولين: <b>الأول</b>: السادة، ويراد بها أهل العقل والشرف. <b>والثاني</b>: السيرة والحال التي هم عليها. وهو قول ابن زيد.</p><p>وقد حكى <u>ابنُ جرير</u> (١٦/١٠١-١٠٤) القولين، ثم <span class="comment-type-2">استدرك</span> <span class="mustanad">مستندًا للإجماع</span> قولَ ابن زيد بقوله: «وهذا القول الذي قاله ابن زيد في قوله: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span> وإن كان قولًا له وجه يحتمله الكلام؛ فإنّ تأويل أهل التأويل بخلافه؛ فلا أستجيز لذلك القول به».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٦/١٠٨) ما أفاده قولُ ابن زيد، فقال: «والأظهر في الطريقة هنا أنها: السيرة والمملكة والحال التي هم عليها». ولم يذكر مستندًا.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٩١.|2:أخرجه يحيى بن سلّام ١/٢٦٥.|3:تفسير مقاتل بن سليمان ٣/٣١.|4:تفسير الثعلبي ٦/٢٥٠. قال ابن أبي داود في المصاحف ص٣٢ عن مثل هذا القول: «لو كان فيه لحن لا يجوز في كلام العرب جميعًا لما استجاز أن يبعث إلى قوم يقرؤونه».|5:أخرجه أبو عبيد في فضائله ص١٦٠-١٦١، وسعيد بن منصور (٧٦٩- تفسير)، وابن جرير ٧/٦٨٠-٦٨١، وابن أبي داود ص٣٤، والثعلبي في تفسيره ٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.|6:أخرجه ابن جرير ١٦/١٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:أخرجه ابن جرير ١٦/١٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٦/١٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|9:عزاه السيوطي إلى عبد بن حميد.|10:أخرجه إسحاق البستي في تفسيره ص٢٦٣.|11:أخرجه إسحاق البستي في تفسيره ص٢٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، ووكيع في الغرور. وأخرجه سفيان الثوري ص١٩٤، وابن جرير ١٦/١٠٣ بلفظ: بسراة الناس.|12:أخرجه إسحاق البستي في تفسيره ص٢٦٢.|13:علَّقه يحيى بن سلّام ١/٢٦٦.|14:أخرجه يحيى بن سلّام ١/٢٦٥، وابن جرير ١٦/١٠٣.|15:أخرجه ابن جرير ١٦/١٠٣.|16:تفسير الثعلبي ٦/٢٥١.|17:تفسير مقاتل بن سليمان ٣/٣١. وفي تفسير الثعلبي ٦/٢٥١ بنحوه منسوبًا إلى مقاتل دون تعيينه.|18:أخرجه ابن جرير ١٦/١٠٤، وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.
  20,64,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَجۡمِعُوا۟ كَیۡدَكُمۡ ثُمَّ ٱئۡتُوا۟ صَفࣰّاۚ وَقَدۡ أَفۡلَحَ ٱلۡیَوۡمَ مَنِ ٱسۡتَعۡلَىٰ ۝٦٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٧٩٣٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد-: ‹فاجْمَعُواْ كَيْدَكُمْ›. وقال <span class="name-2">أبو عمرو</span>: ‹فاجْمَعُواْ› مِن: جمَعَ كيْدَه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَجۡمِعُوا۟ كَیۡدَكُمۡ ثُمَّ ٱئۡتُوا۟ صَفࣰّاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٩٣٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿ثم ائتوا صفا﴾</span>، أي: جميعًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأجمعوا كيدكم﴾</span> يعني: سحركم، هذا قول فرعون لوجوه سحرة قومه، <span class="qpc-hafs">﴿ثم ائتوا صفا﴾</span> يعني: جميعًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فأجمعوا كيدكم﴾</span> يعني: سحركم، يقوله بعضهم لبعض، <span class="qpc-hafs">﴿ثم ائتوا صفا﴾</span> أي: تعالوا جميعًا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَدۡ أَفۡلَحَ ٱلۡیَوۡمَ مَنِ ٱسۡتَعۡلَىٰ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٩٣٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق- قال: جَمَع فرعونُ الناس لذلك الجمعَ، ثم أمَرَ السَّحَرَة، فقال: <span class="qpc-hafs">﴿ائتوا صفا وقد أفلح اليوم من استعلى﴾</span>، أي: قد أفلح مَن فَلَجَ{5} اليوم على صاحبه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وقد أفلح اليوم من استعلى﴾</span>، قال: مَن غَلَب{7}. (١٠/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٤٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: من غَلَب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٩٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقد أفلح﴾</span> يعني: وقد سَعِد <span class="qpc-hafs">﴿اليوم من استعلى﴾</span> يعني: مَن غَلَب{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٢٦٣.</p><p>وهي قراءة متواترة، قرأ بها أبو عمرو البصري، وقرأ بقية العشرة: <span class="qpc-hafs">﴿فَأَجْمِعُواْ كَيْدَكُمْ﴾</span> بهمزة قطع، وكسر الميم. انظر: النشر ٢/٣٢١، والإتحاف ص٣٨٥.|2:تفسير الثعلبي ٦/٢٥٢، وتفسير البغوي ٥/٢٨٣.|3:تفسير مقاتل بن سليمان ٣/٣١. وفي تفسير الثعلبي ٦/٢٥٢، وتفسير البغوي ٥/٢٨٣ بنحو قوله في معنى: <span class="qpc-hafs">﴿صفًّا﴾</span> منسوبًا إلى مقاتل دون تعيينه.|4:تفسير يحيى بن سلّام ١/٢٦٦.|5:فَلَجَ: غَلَبَ. النهاية (فلج).|6:أخرجه ابن جرير ١٦/١٠٦.|7:علَّقه يحيى ين سلام ١/٢٦٦ بلفظ: مَن ظَهَر. وعزاه السيوطي إلى ابن أبي حاتم.|8:علقه يحيى بن سلّام ١/٢٦٦.|9:تفسير مقاتل بن سليمان ٣/٣١.