quran[9]{c,v,t}:
  11,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ لَمۡ یَكُونُوا۟ مُعۡجِزِینَ فِی ٱلۡأَرۡضِ وَمَا كَانَ لَهُم مِّن دُونِ ٱللَّهِ مِنۡ أَوۡلِیَاۤءَۘ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿معجزين﴾</span>، قال: مُسابِقِين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٢٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: هارِبين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ نَعَتَهم، فقال: <span class="qpc-hafs">﴿أُولَئِكَ لَمْ يَكُونُوا مُعْجِزِينَ﴾</span> يعني: بسابقي الله <span class="qpc-hafs">﴿فِي الأَرْضِ﴾</span> هربًا حتى يجزيهم بأعمالهم الخبيثة، <span class="qpc-hafs">﴿وما كانَ لَهُمْ مِن دُونِ اللَّهِ مِن أوْلِياءَ﴾</span> يعني: أقرباء يمنعونهم مِن الله{3}<span class=comment-ref>٣١٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٩٩</span> ذكر <u>ابنُ عطية</u> (٤/٥٥٧) أنّ قوله تعالى: <span class="qpc-hafs">﴿وما كانَ لَهُمْ مِن دُونِ اللَّهِ مِن أوْلِياءَ﴾</span> يحتمل معنيين: <b>أحدهما:</b> أنّه نفى أن يكون لهم وليٌّ أو ناصر كائنًا مَن كان. و<b>الثاني</b>: أن يقصد وصف الأصنام والآلهة بأنهم لم يكونوا أولياء حقيقة، وإن كانوا هم يعتقدون أنهم أولياء.</div></p><p><div></p><p><p><span class="item-no">٣٥٣٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: فائتين{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُضَـٰعَفُ لَهُمُ ٱلۡعَذَابُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يضاعف لهم العذاب﴾</span>، أي: عذاب الدنيا، والآخرة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا كَانُوا۟ یَسۡتَطِیعُونَ ٱلسَّمۡعَ وَمَا كَانُوا۟ یُبۡصِرُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: أخبر الله سبحانه أنّه حال بين أهل الشرك وبين طاعته في الدنيا والآخرة؛ أمّا في الدنيا فإنه قال: <span class="qpc-hafs">﴿ما كانوا يستطيعون السمع﴾</span> وهي طاعته، <span class="qpc-hafs">﴿وما كانوا يبصرون﴾</span>. وأما في الآخرة فإنه قال: <span class="qpc-hafs">﴿لا يستطيعون* خاشعة﴾</span> [القلم:٤٢-٤٣]{6}. (٨/٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ما كانوا يستطيعون السمع وما كانوا يبصرون﴾</span>، قال: ما كانوا يستطيعون أن يسمعوا خيرًا فينتفعوا به، ولا يُبْصِروا خيرًا فيأخذوا به{7}. (٨/٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما كانُوا يَسْتَطِيعُونَ السَّمْعَ﴾</span> يعني: ما كانوا على سمع إيمان بالقرآن، <span class="qpc-hafs">﴿وما كانُوا يُبْصِرُونَ﴾</span> الإيمان بالقرآن؛ لأنّ الله جَعَل في آذانهم وقرًا، وعلى أبصارهم غشاوة{3}<span class=comment-ref>٣٢٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٥٧-٥٥٨) أنّ قوله تعالى: <span class="qpc-hafs">﴿ما كانُوا يَسْتَطِيعُونَ السَّمْعَ وما كانُوا يُبْصِرُونَ﴾</span> يحتمل عدة احتمالات، فقال: «وقوله: <span class="qpc-hafs">﴿ما كانوا يستطيعون السمع وما كانوا يبصرون﴾</span> يحتمل خمسة أوجه: <b>أحدها</b>: أن يصف هؤلاء الكفار بهذه الصفة، على معنى: أنّ الله ختم عليهم بذلك، فهم لا يسمعون سماعًا ينتفعون به، ولا يبصرون كذلك. و<b>الثاني</b>: أن يكون وصَفَهُم بذلك مِن أجل بغضتهم في النبي ﷺ، فهم لا يستطيعون أن يحملوا أنفسهم على السمع منه والنظر إليه. و<b>الثالث</b>: أن يكون وصَفَ بذلك الأصنام والآلهة التي نفى عنها أن تكون أولياء. و<b>الرابع</b>: أن يكون التقدير: يضاعف لهم العذاب بما كانوا، بحذف الجارِّ. و<b>الخامس</b>: يضاعف لهم مدة استطاعتهم السمع والبصر، وقد أعْلَمَتِ الشريعةُ أنّهم لا يموتون فيها أبدًا؛ فالعذاب إذن متمادٍ أبدًا». و<span class="comment-type-4">بيَّن</span> <u>ابنُ عطية</u> أنّ <span class="qpc-hafs">﴿ما﴾</span> على الأقوال الثلاثة الأولى نافية، وعلى القول الرابع مصدرية، وعلى القول الخامس ظرفية.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٣٧٢) <span class="mustanad">مستندًا لدلالة العقل</span> القول الأول، وهو قول ابن عباس، وقتادة، ومقاتل بقوله: «والصواب من القول في ذلك عندنا ما قاله ابنُ عباس وقتادة، مِن أنّ الله وصفهم -تعالى ذِكْرُه- بأنّهم لا يستطيعون أن يسمعوا الحق سماع منتفعٍ، ولا يبصرونه إبصار مهتدٍ؛ لاشتغالهم بالكفر الذي كانوا عليه مقيمين عن استعمال جوارحهم في طاعة الله، وقد كانت لهم أسماع وأبصار». و<span class="comment-type-4">علَّق</span> على القول الثالث بقوله: «وهذا قول روي عن ابن عباس من وجه كرهت ذِكْرَه لضعف سنده».</p><p>ونسب <u>ابنُ عطية</u> القول الرابع للفرّاء، و<span class="comment-type-2">انتقده</span> بقوله: «وهذا قول فيه تحامُل».</p><p>وذكر <u>ابنُ تيمية</u> (٣/٥٣٨) أنّ الاستطاعة على نوعين: <b>الأولى</b>: استطاعة هي مناط الأمر والنهي، وهي المصححة للفعل، ولا يجب أن تُقارِن الفعل. و<b>الثانية</b>: استطاعة تُقارِن الفعل، ويجب معها وجود الفعل. وبيَّن أن بعض العلماء يفسر الاستطاعة في هذه الآية بالمعنى الثاني، وأمّا على تفسير السلف والجمهور فالمراد بعدم الاستطاعة: مشقة ذلك عليهم، وصعوبته على نفوسهم، فنفوسهم لا تستطيع إرادته وإن كانوا قادرين على فعله لو أرادوه، وهذه حال مَن صَدَّه هواهُ أو رأيُه الفاسد عن استماع كتب الله المنزلة واتباعها، وقد أخبر أنه لا يستطيع ذلك، وهذه الاستطاعة هي المقارنة للفعل الموجبة له، وأما الأولى فلولا وجودها لم يثبت التكليف".</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠١٨.|2:تفسير الثعلبي ٥/١٦٣، وتفسير البغوي ٤/١٦٩.|3:تفسير مقاتل بن سليمان ٢/٢٧٧.|4:تفسير الثعلبي ٥/١٦٣، وتفسير البغوي ٤/١٦٩ دون تعيينه بأنه ابن حيان.|5:أخرجه ابن أبي حاتم ٦/٢٠١٨.|6:أخرجه ابن جرير ١٢/٣٧١. وعزاه السيوطي إلى أبي الشيخ.|7:أخرجه عبد الرزاق ١/٣٠٤، وابن جرير ١٢/٣٧١. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير مقاتل بن سليمان ٢/٢٧٧.
  11,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ خَسِرُوۤا۟ أَنفُسَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أولئك الذين خسروا أنفسهم﴾</span>، قال: غَبَنُوا أنفسَهم{1}. (٨/٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتهم، فقال: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ خَسِرُوا أنْفُسَهُمْ﴾</span>، يعني: غَبَنوا أنفسَهم، <span class="qpc-hafs">﴿وضل عنهم ما كانوا يفترون﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- <span class="qpc-hafs">﴿ما كانوا يفترون﴾</span>: ما كانوا يكذبون في الدُّنْيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ما كانوا يفترون﴾</span>، أي: يُشْرِكون{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠١٩.|2:تفسير مقاتل بن سليمان ٢/٢٧٧-٢٧٨.|3:أخرجه ابن أبي حاتم ٦/٢٠١٩.|4:أخرجه ابن أبي حاتم ٦/٢٠١٩.
  11,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا جَرَمَ أَنَّهُمۡ فِی ٱلۡـَٔاخِرَةِ هُمُ ٱلۡأَخۡسَرُونَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿لا جرم﴾</span>، يقول: بلى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا جَرَمَ﴾</span> حقًّا <span class="qpc-hafs">﴿أنَّهُمْ فِي الآخِرَةِ هُمُ الأَخْسَرُونَ﴾</span>{2}<span class=comment-ref>٣٢٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠١</span> ذكر <u>ابنُ عطية</u> (٤/٥٥٩) في قوله: <span class="qpc-hafs">﴿لا جرم﴾</span> أربعة أقوال: <b>الأول</b>: أنها بمعنى: حقَّ. <b>الثاني</b>: أن تكون بمعنى: لا بُدَّ، أو: لا شك. <b>الثالث</b>: أن تكون <span class="qpc-hafs">﴿لا﴾</span> ردٌّ عليهم ولما تقدم مِن كُلِّ ما قبلها، وتكون <span class="qpc-hafs">﴿جَرَم﴾</span> بمعنى: كسَبَ، والمعنى: كسب فعلُهم <span class="qpc-hafs">﴿أنهم في الآخرة هم الأخسرون﴾</span>. <b>الرابع</b>: أن تكون بمعنى: لا صَدَّ ولا منْع. و<span class="comment-type-4">علّق</span> عليه قائلًا: «فكأنّ <span class="qpc-hafs">﴿جرم﴾</span> على هذا مِن معنى القطع، تقول: جرمت، أي: قطعت».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠١٩.|2:تفسير مقاتل بن سليمان ٢/٢٧٨.
  11,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَأَخۡبَتُوۤا۟ إِلَىٰ رَبِّهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأخبَتُوا﴾</span>، قال: خافوا{1}. (٨/٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: الإخبات: الإنابة{2}. (٨/٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿وأخبتوا إلى ربهم﴾</span>، قال: اطْمَأَنُّوا{3}. (٨/٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: الإخبات: الخُشُوع والتَّواضع{4}. (٨/٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وأخبتوا إلى ربهم﴾</span>، يقول: وأنابوا إلى ربهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ أخبر عن المؤمنين، وما أعَدَّ لهم، فقال: <span class="qpc-hafs">﴿إنَّ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ وأَخْبَتُوا إلى رَبِّهِمْ﴾</span>، يعني: وأخلصوا إلى ربهم{6}<span class=comment-ref>٣٢٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (١٢/٣٧٥) على الأقوال الواردة في معنى الإخبات بقوله: «وهذه الأقوال متقاربة المعاني، وإن اختلفت ألفاظُها؛ لأنّ الإنابة إلى الله مِن خوف الله، ومِن الخشوع والتواضع لله بالطاعة، والطمأنينة إليه من الخشوع له، غير أنّ نفس الإخبات عند العرب: الخشوع والتواضع».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٤/٥٦٠)، فقال: «وهذه الأقوال بعضُها قريبٌ مِن بعض، وأصل اللفظ مِن الخبْت، وهو: البراح القفْر المستوي من الأرض، فكأنّ المخبت في القفر قد انكشف واستسلم وبقي دون منَعَة، فشبه المتذلل الخاشع بذلك، وقيل: إنما اشْتُقَّ منه لاستوائه وطمأنينته».</p><p>وذكر <u>ابنُ القيم</u> (٢/٥٣) أنّ الخبْت أصله في اللغة: المكان المنخفض من الأرض، و<span class="comment-type-1">وجَّه</span> قول مَن فسر المخبتين بالمتواضعين بأنّه متخرج على هذا المعنى اللغوي، ثم أورد بقية الأقوال، و<span class="comment-type-4">علَّق</span> عليها بقوله: «وهذه الأقوال تدور على معنيين: التواضع، والسكون إلى الله ﷿، ولذلك عُدِّيَ بإلى تضمينًا لمعنى الطمأنينة والإنابة والسكون إلى الله تعالى».</div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلۡجَنَّةِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- قوله: <span class="qpc-hafs">﴿أولئك أصحاب الجنة﴾</span> أي: مَن آمَنَ بما كفرتم، وعَمِل بما تركتم مِن دينه فلهم الجنة خالدين فيها، <span class="qpc-hafs">﴿هم فيها خالدون﴾</span> فلهم الجنة خالدين فيها، يخبرهم أنّ الثواب بالخير [والشَّرِّ] مُقِيمٌ على أهله أبدًا لا انقطاع له{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أُولَئِكَ أصْحابُ الجَنَّةِ هُمْ فِيها خالِدُونَ﴾</span> لا يموتون{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٣٧٤، وابن أبي حاتم ٦/٢٠١٩. وعزاه السيوطي إلى أبي الشيخ.|2:أخرجه ابن جرير ١٢/٣٧٤.|3:تفسير مجاهد ص٣٨٦، وأخرجه ابن جرير ١٢/٣٧٥. وعزاه السيوطي إلى أبي الشيخ.|4:أخرجه عبد الرزاق ١/٣٠٤، وابن جرير ١٢/٣٧٥. وعزاه السيوطي إلى أبي الشيخ.|5:أخرجه ابن جرير ١٢/٣٧٤، وابن أبي حاتم ٦/٢٠٢٠.|6:تفسير مقاتل بن سليمان ٢/٢٧٨.|7:أخرجه ابن أبي حاتم ٦/٢٠٢٠.|8:تفسير مقاتل بن سليمان ٢/٢٧٨.
  11,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَثَلُ ٱلۡفَرِیقَیۡنِ كَٱلۡأَعۡمَىٰ وَٱلۡأَصَمِّ وَٱلۡبَصِیرِ وَٱلسَّمِیعِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿مثل الفريقين كالأعمى والأصم﴾</span> قال: الكافر، <span class="qpc-hafs">﴿والبصير والسميع﴾</span> قال: المُؤمِن{1}. (٨/٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مثل الفريقين كالأعمى والأصم والبصير والسميع﴾</span>: الفريقان الكافران، والمؤمنان، فأمّا الأعمى والأصم فالكافران، وأمّا البصير والسميع فهما المؤمنان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿مثل الفريقين كالأعمى والأصم والبصير والسميع﴾</span> الآية: هذا مَثَلٌ ضَرَبَه اللهُ للكافر والمؤمن، فأمّا الكافر فصُمَّ عن الحق فلا يسمعه، وعَمِي عنه فلا يُبْصِره، وأمّا المؤمن فسمع الحق فانتفع به، وأبصره فوعاه وحفِظَه وعَمِل به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ ضرب مثلًا للمؤمنين والكافرين، فقال: <span class="qpc-hafs">﴿مثل الفريقين﴾</span> المؤمن والكافر، <span class="qpc-hafs">﴿كالأعمى﴾</span> عن الإيمان لا يُبْصِر، <span class="qpc-hafs">﴿والأصم﴾</span> عن الإيمان فلا يسمعه، يعني: الكافر، ثم ذكر المؤمن فقال: <span class="qpc-hafs">﴿والبصير والسميع﴾</span> للإيمان{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- قال: ثُمَّ ذَكَر محمدًا ﷺ، فقرأ فيما بينه وبين مَن خالفه، فقرأ: <span class="qpc-hafs">﴿مثل الفريقين﴾</span> الآية كلها{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هَلۡ یَسۡتَوِیَانِ مَثَلًاۚ أَفَلَا تَذَكَّرُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٥٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قال: لا يَسْتَوِي في الفَضْل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هل يستويان مثلا﴾</span> يقول: هل يستويان في الشَّبَه؟ فقالوا: لا. فقال: <span class="qpc-hafs">﴿أفلا تذكرون﴾</span> أنّهما لا يستويان؛ فتَعْتَبِرُوا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٣٧٦. وعزاه السيوطي إلى أبي الشيخ.|2:أخرجه ابن جرير ١٢/٣٧٧.|3:أخرجه ابن جرير ١٢/٣٦٨، وابن أبي حاتم ٦/٢٠٢٠ بنحوه.|4:تفسير مقاتل بن سليمان ٢/٢٧٨.|5:أخرجه ابن أبي حاتم ٦/١٩٩٥، ٢٠٢٠.|6:أخرجه ابن أبي حاتم ٦/٢٠٢١. وأورده قبل ذلك في تفسير قوله تعالى: <span class="qpc-hafs">﴿لا يَسْتَوِي القاعِدُونَ مِنَ المُؤْمِنِينَ غَيْرُ أُولِي الضَّرَرِ والمُجاهِدُونَ فِي سَبِيلِ اللَّهِ بِأَمْوالِهِمْ وأَنْفُسِهِمْ﴾</span> [النساء:٩٥] وهو ألصق بسياقها.|7:تفسير مقاتل بن سليمان ٢/٢٧٨.
  11,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَرۡسَلۡنَا نُوحًا إِلَىٰ قَوۡمِهِۦۤ إِنِّی لَكُمۡ نَذِیرࣱ مُّبِینٌ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: بُعِث نوح بعد مائة سنة، وأمره ربُّه ببناء السفينة وهو ابنُ ستمائة سنة، وكان عمرُه ألفًا وخمسين عامًا، ولَبِث يدعو قومَه تسعمائة وخمسين سنة، قال الله تعالى: <span class="qpc-hafs">﴿فَلَبِثَ فِيهِمْ ألْفَ سَنَةٍ إلّا خَمْسِينَ عامًا﴾</span> [العنكبوت:١٤]، أي: فلبِث فيهم داعيًا، <span class="qpc-hafs">﴿فقال الملأ الذين كفروا من قومه ما نراك﴾</span> يا نوح <span class="qpc-hafs">﴿إلا بشرا مثلنا﴾</span> آدميًّا مثلنا <span class="qpc-hafs">﴿وما نراك اتبعك إلا الذين هم أراذلنا﴾</span> سَفِلتنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ولَمّا كذَّب كُفّار مكة محمدًا بالرسالة أخبر اللهُ محمدًا ﵇ أنّه أرسله رسولًا كما أرسل نوحًا، وهودًا، وصالحًا، ولوطًا، وشعيبًا في هذه السورة، فقال: <span class="qpc-hafs">﴿ولقد أرسلنا نوحا إلى قومه﴾</span> فقال لهم: <span class="qpc-hafs">﴿إني لكم نذير﴾</span> مِن العذاب في الدنيا <span class="qpc-hafs">﴿مبين﴾</span> يعني: بيِّن. نظيرها فى سورة نوح{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٥٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة بن الفضل- قال: كان مِن حديث نوحٍ وحديث قومه -فيما يَذْكُر أهلُ العلم-: أنّه كان حليمًا صبورًا، لم يلق نبيٌّ مِن قومه مِن البلاء أكثرَ مِمّا لقي، إلا نبي قُتِل. وكان يدعوهم كما قال الله تعالى: ليلًا ونهارًا، وسِرًّا وجِهارًا بالنصيحة لهم، فلم يَزِدهم ذلك منه إلا فرارًا، حتى إنّه لَيُكَلِّم الرجل منهم فيلف رأسَه بثوبه، ويجعل أصابعه في أُذُنَيْه؛ لكيلا يسمع شيئًا مِن قوله{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٦٥. وتفسير البغوي ٤/١٧٠.|2:تفسير مقاتل بن سليمان ٢/٢٧٨. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿قالَ يا قَوْمِ إنِّي لَكُمْ نَذِيرٌ مُبِينٌ﴾</span> [نوح:٢].|3:أخرجه ابن أبي حاتم ٦/٢٠٢١-٢٠٢٢.
  11,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَن لَّا تَعۡبُدُوۤا۟ إِلَّا ٱللَّهَۖ إِنِّیۤ أَخَافُ عَلَیۡكُمۡ عَذَابَ یَوۡمٍ أَلِیمࣲ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنِّي أخافُ عَلَيْكُمْ﴾</span> فى الدنيا <span class="qpc-hafs">﴿عذاب يوم أليم﴾</span> يعني: وجِيع{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٧٨.
  11,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَالَ ٱلۡمَلَأُ ٱلَّذِینَ كَفَرُوا۟ مِن قَوۡمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرࣰا مِّثۡلَنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٦١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السُّدِّي- قوله: <span class="qpc-hafs">﴿فقال الملأ﴾</span>، يعني: الأشراف مِن قومه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقال الملأ﴾</span> الأشراف <span class="qpc-hafs">﴿الذين كفروا مِن قومه ما نراك إلا بشرا مثلنا﴾</span> يعني: إلا آدَمِيًّا مثلنا، لا تَفْضُلُنا بشيء{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِینَ هُمۡ أَرَاذِلُنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٦٣<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله <span class="qpc-hafs">﴿أراذلنا﴾</span>: الحاكَةُ{3}، والأَساكِفَةُ{4}{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما نَراكَ اتَّبَعَكَ إلّا الَّذِينَ هُمْ أراذِلُنا﴾</span>، يعني: الرذالة من الناس، السَّفِلَة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَادِیَ ٱلرَّأۡیِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿وما نراك اتبعك إلا الذين هم أراذِلُنا بادي الرأي﴾</span>، قال: فيما ظَهَرَ لنا{7}. (٨/٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٦٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان-، مثله{8}. (٨/٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span>: <span class="qpc-hafs">﴿بادي الرأي﴾</span> مِن غير رَوِيَّةٍ، ولا فِكْرَة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٦٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: رأي العين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بادِيَ الرَّأْيِ﴾</span>، يعني: بدا لنا أنّهم سَفِلَتُنا{2}<span class=comment-ref>٣٢٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٣</span> <span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٢/٥٤): «قال الزجاج: المعنى: إن كنتم تزعمون أنّهم إنما اتبعوني في بادي الرأي وظاهره فليس عَلَيَّ أن أطَّلع على ما في أنفسهم، فإذا رأيت مَن يُوَحِّد الله عملت على ظاهره، ورددت عِلْمَ ما في نفوسهم إلى الله. وهذا معنًى حسن. والذي يظهر من الآية: أنّ الله يعلم ما في أنفسهم، إذ أهَّلهم لقبول دينه وتوحيده، وتصديق رسله، والله ﷾ عليم حكيم، يضع العطاء في مواضعه، وتكون هذه الآية <span class="mustanad">مثل قوله تعالى</span>: <span class="qpc-hafs">﴿وكذلك فتنا بعضهم ببعض ليقولوا أهؤلاء من الله عليهم من بيننا أليس الله بأعلم بالشاكرين﴾</span> [الأنعام:٥٣]، فإنهم أنكروا أن يكون الله سبحانه أهلهم للهدى والحق، وحرمه رؤساء الكفار وأهل العزة والثروة منهم، كأنهم استدلوا بعطاء الدنيا على عطاء الآخرة، فأخبر الله سبحانه أنّه أعلم بمن يؤهله لذلك لِسِرٍّ عنده من معرفة قدر النعمة، ورؤيتها من مجرد فضل المنعم، ومحبته، وشكره عليها، وليس كل أحد عنده هذا السر؛ فلا يؤهل كل أحد لهذا العطاء».</div></p><p><h3><span class="qpc-hafs">﴿وَمَا نَرَىٰ لَكُمۡ عَلَیۡنَا مِن فَضۡلِۭ بَلۡ نَظُنُّكُمۡ كَـٰذِبِینَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿من فضل﴾</span>، يعني: فَضِيلة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما نَرى لَكُمْ عَلَيْنا مِن فَضْلٍ﴾</span> في مُلْكٍ، ولا مالٍ، ولا شيء فنتبعك. يعنون: نوحًا، <span class="qpc-hafs">﴿بَلْ نَظُنُّكُمْ﴾</span> يعني: نحسبك مِن الـ<span class="qpc-hafs">﴿كاذِبِينَ﴾</span> حين تزعم أنّك رسول نبي{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٢٢.|2:تفسير مقاتل بن سليمان ٢/٢٧٨.|3:الحاكة: جمع حائك، وهو الذي حِرفته الحِياكةُ، وحاك الثوب: نسجه. لسان العرب (حوك)، (حيك).|4:الأَساكِفَة: جمع إسْكاف، وهو الخفّاف، وقيل: الصانع أيًّا كان، وخصَّ بعضهم به النجار. لسان العرب (سكف).|5:تفسير البغوي ٤/١٧١.|6:تفسير مقاتل بن سليمان ٢/٢٧٨.|7:أخرجه ابن جرير ١٢/٣٨١. وعزاه السيوطي إلى ابن المنذر.|8:أخرجه ابن أبي حاتم ٦/٢٠٢٢. وعزاه السيوطي إلى أبي الشيخ.|9:تفسير الثعلبي ٥/١٦٥، وعَقِبه: يعني: آمنوا من غير روية.|10:تفسير البغوي ٤/١٧١.|11:تفسير مقاتل بن سليمان ٢/٢٧٨.|12:أخرجه ابن أبي حاتم ٦/٢٠٢٣.|13:تفسير مقاتل بن سليمان ٢/٢٧٨-٢٧٩.
  11,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَرَءَیۡتُمۡ إِن كُنتُ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّی وَءَاتَىٰنِی رَحۡمَةࣰ مِّنۡ عِندِهِۦ فَعُمِّیَتۡ عَلَیۡكُمۡ أَنُلۡزِمُكُمُوهَا وَأَنتُمۡ لَهَا كَـٰرِهُونَ ۝٢٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٧٢<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق أبي العالية- أنّه قرأ: (أنُلْزِمُكُمُوها مِن شَطْرِ قُلُوبِنا){1}<span class=comment-ref>٣٢٠٤</span>. (٨/٣٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٤</span> <span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٤/٥٦٥) قراءة أُبَيٍّ، فقال: «وفي قراءة أبي بن كعب: (أنُلْزِمُكُمُوها مِن شَطْرِ أنفُسِنا)، ومعناه: من تلقاء أنفسنا».</div></p><p><div></p><p><p><span class="item-no">٣٥٣٧٣<span class="dash">-</span></span> عن أبي العالية، قال: في قراءة <span class="name-1">أُبَيّ</span>: (أنُلْزِمُكُمُوها مِن شَطْرِ أنفُسِنا وأَنتُمْ لَها كارِهُونَ){2}. (٨/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> - من طريق عمرو بن دينار- أنّه كان يقرأ: (أنُلْزِمُكُمُوها مِن شَطْرِ أنفُسِنا وأَنتُمْ لَها كارِهُونَ){3}. (٨/٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَرَءَیۡتُمۡ إِن كُنتُ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٧٥<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجوني</span> -من طريق جعفر بن سليمان- قرأ هذه الآية: <span class="qpc-hafs">﴿إن كنت على بينة من ربي﴾</span>، قال: على ثِقَة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ يا قَوْمِ أرَأَيْتُمْ إنْ كُنْتُ عَلى بَيِّنَةٍ مِن رَبِّي﴾</span>، يعني: بيان من ربي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿إن كنت على بينة من ربي﴾</span>، قال: قد عرَفتُها، وعرَفْتُ بها أمرَه، وأنّه لا إله إلا هو{6}. (٨/٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَىٰنِی رَحۡمَةࣰ مِّنۡ عِندِهِۦ فَعُمِّیَتۡ عَلَیۡكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتانِي﴾</span> يعني: وأعطاني <span class="qpc-hafs">﴿رَحْمَةً مِن عِنْدِهِ﴾</span> نِعْمَةً من عنده، وهو الهُدى، <span class="qpc-hafs">﴿فَعُمِّيَتْ عَلَيْكُمْ﴾</span> يعني: فخَفِيَت عليكم الرحمةُ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿وآتاني رحمة من عنده﴾</span>، قال: الإسلام، والهُدى، والإيمان، والحكم، والنبوة{8}. (٨/٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنُلۡزِمُكُمُوهَا وَأَنتُمۡ لَهَا كَـٰرِهُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن دينار-: (أنُلْزِمُكُمُوها مِن شَطْرِ أنفُسِنا)، قال عبد الله: (مِن شَطْرِ أنفُسِنا): مِن تلقاء أنفسنا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أنلزِمُكُمُوها﴾</span>، قال: أما –واللهِ- لو استطاع نبيُّ الله لَأَلْزَمَها قومَه، ولكنه لم يستطع ذلك، ولم يملكه{6}. (٨/٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنلزِمُكُمُوها وأَنْتُمْ لَها﴾</span> يعني: الرحمة، وهي النِّعمةُ والهدى <span class="qpc-hafs">﴿كارِهُونَ﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٣٨٤. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عباس. انظر: البحر المحيط ٥/٢١٨.|2:أخرجه ابن جرير ١٢/٣٨٣، ٣٨٤. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عباس. انظر: البحر المحيط ٥/٢١٨.|3:أخرجه سعيد بن منصور (١٠٨٥- تفسير)، وابن جرير ١٢/٣٨٤، وابن أبي حاتم ٦/٢٠٢٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|4:أخرجه ابن أبي حاتم ٦/٢٠٢٣.|5:تفسير مقاتل بن سليمان ٢/٢٧٩.|6:أخرجه ابن جرير ١٢/٣٨٣، وابن أبي حاتم ٦/٢٠٢٣. وعزاه السيوطي إلى أبي الشيخ.|7:تفسير مقاتل بن سليمان ٢/٢٧٩.|8:أخرجه ابن جرير ١٢/٣٨٣. وعزاه السيوطي إلى أبي الشيخ.|9:أخرجه ابن جرير ١٢/٣٨٤.|10:أخرجه ابن جرير ١٢/٣٨٣، وابن أبي حاتم ٦/٢٠٢٣. وعزاه السيوطي إلى أبي الشيخ.|11:تفسير مقاتل بن سليمان ٢/٢٧٩.