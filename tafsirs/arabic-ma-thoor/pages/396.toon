quran[10]{c,v,t}:
28,85," <q>﴿إِنَّ ٱلَّذِی فَرَضَ عَلَیۡكَ ٱلۡقُرۡءَانَ لَرَاۤدُّكَ إِلَىٰ مَعَادࣲۚ قُل رَّبِّیۤ أَعۡلَمُ مَن جَاۤءَ بِٱلۡهُدَىٰ وَمَنۡ هُوَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٨٥﴾</q> - نزول الآية ٥٩٤١٣- عن عبد الله بن عباس -من طريق مقاتل، عن الضحاك- في قوله: <q>﴿لرادك إلى معاد﴾</q>، قال: إنّما نزلت بالجُحْفة، ليس بمكة ولا المدينة{1}. (ز) ٥٩٤١٤- عن الضحاك بن مُزاحم -من طريق سفيان بن عيينة، عن مقاتل بن سليمان- قال: لَمّا خرج النبيُّ ﷺ من مكة فبلغ الجحفة اشتاق إلى مكة؛ فأنزل الله: <q>﴿إن الذي فرض عليك القرآن لرادك إلى معاد﴾</q> إلى مكة{2}. (١١/٥٢١) ٥٩٤١٥- تفسير إسماعيل السُّدِّيّ: <q>﴿لرادك إلى معاد﴾</q>، يعني: إلى مكة. وقال: ليس في القرآن آية إلا وهي مكية أو مدنية، إلا هذه الآية؛ فإنها ليست بمكية ولا مدنية، وذلك أنها نزلت على النبي ﷺ بالجُحفة، في هجرته إلى المدينة، قبل بلوغه{3}. (ز) ٥٩٤١٦- قال مقاتل بن سليمان: <q>﴿إن الذي فرض عليك القران﴾</q>، وذلك أنّ النبي ﷺ خرج مِن الغار ليلًا، ثم هاجر مِن وجهه ذلك إلى المدينة، فسار في غير الطريق مخافةَ الطلب، فلمّا أمِن رجع إلى الطريق، فنزل بالجحفة بين مكة والمدينة، وعرف الطريق إلى مكة، فاشتاق إليها، وذكر مولدَه ومولد أبيه، فأتاه جبريل ﵇، فقال: أتشتاق إلى بلدك ومولدك؟ فقال النبي ﷺ: «نعم». فقال جبريل: إنّ الله ﷿ يقول: <q>﴿إن الذي فرض عليك القران لرادك إلى معاد﴾</q> يعني: إلى مكة ظاهِرًا عليهم. فنزلت هذه الآية بالجُحفة؛ ليست بمكية، ولا مدنية{4}. (ز) ٥٩٤١٧- قال يحيى بن سلّام: بلغني: أنّ النبي ﷺ وهو موجه من مكة إلى المدينة حين هاجر نزل عليه جبريل وهو بالجُحفة، فقال: أتشتاق -يا محمد- إلى بلادك التي وُلِدت بها؟ فقال: «نعم». فقال: <q>﴿إن الذي فرض عليك القرءان لرادك إلى معاد﴾</q> إلى مولدك الذي خرجت منه ظاهرًا على أهله{5}. (ز) ٥٩٤١٨- عن علي بن الحسين بن واقد، قال: كل القرآن مكيٌّ أو مدنيٌّ، غير قوله: <q>﴿إن الذي فرض عليك القرآن لرادك إلى معاد﴾</q>؛ فإنها أُنزِلت على رسول الله ﷺ بالجُحْفة حين خرج مهاجرًا إلى المدينة؛ فلا هي مكية ولا مدنية، وكل آية نزلت على رسول الله ﷺ قبل الهجرة فهي مكية، فنزلت بمكة أو بغيرها من البلدان، وكل آية نزلت بالمدينة بعد الهجرة فإنها مدنية، نزلت بالمدينة أو بغيرها من البلدان{6}. (١١/٥٢١) <q>﴿إِنَّ ٱلَّذِی فَرَضَ عَلَیۡكَ﴾</q> - تفسير ٥٩٤١٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إن الذي فرض عليك القرآن﴾</q>، قال: الذي أعطاك القرآن{7}٥٠٠٨. (ز) ٥٠٠٨ ذكر ابنُ عطية (٦/٦١٩) هذا القول، ثم قال: «وقالت فرقة: في هذا القول حذف مضاف، والمعنى: فرض عليك أحكام القرآن». ٥٩٤٢٠- عن عطاء بن أبي رباح، في قوله: <q>﴿إن الذي فرض عليك القرآن﴾</q>، قال: أوجب عليك العمل بالقرآن{8}. (ز) ٥٩٤٢١- قال يحيى بن سلّام: <q>﴿إن الذي فرض عليك﴾</q> يعني: أنزل عليك <q>﴿القرءان﴾</q>{9}. (ز) <q>﴿لَرَاۤدُّكَ إِلَىٰ مَعَادࣲۚ﴾</q> - تفسير ٥٩٤٢٢- عن قتادة، في قوله: <q>﴿لرادك إلى معاد﴾</q>، قال: هذه مِمّا كان يكتم ابنُ عباس{10}. (١١/٥٢٤) ٥٩٤٢٣- عن عبد الله بن عباس -من طريق عدي بن ثابت، عن سعيد بن جبير- قال: إلى الموت، أو إلى مكة{11}. (ز) ٥٩٤٢٤- عن عبد الله بن عباس -من طريق الأعمش، عن سعيد بن جبير- <q>﴿لرادك إلى معاد﴾</q>، قال: الموت{12}. (١١/٥٢٢) ٥٩٤٢٥- عن عبد الله بن عباس -من طريق الأعمش، عن رجل، عن سعيد بن جبير- <q>﴿إن الذي فرض عليك القرآن لرادك إلى معاد﴾</q>، قال: لرادُّك إلى الجنة{13}. (ز) ٥٩٤٢٦- عن عبد الله بن عباس -من طريق سفيان العصفري، عن عكرمة- في قوله: <q>﴿لرادك إلى معاد﴾</q>، قال: إلى مكة{14}. (١١/٥٢٢) ٥٩٤٢٧- عن عبد الله بن عباس -من طريق خُصَيف، عن عكرمة- <q>﴿لرادك إلى معاد﴾</q>، قال: إلى معدنك مِن الجنة{15}. (١١/٥٢٣) ٥٩٤٢٨- عن عبد الله بن عباس -من طريق الحكم بن أبان، عن عكرمة- <q>﴿لرادك إلى معاد﴾</q>، قال: إلى يوم القيامة{16}. (١١/٥٢٣) ٥٩٤٢٩- عن عكرمة مولى ابن عباس، مثله{17}. (١١/٥٢٣) ٥٩٤٣٠- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن رجل- في قوله: <q>﴿لرادك إلى معاد﴾</q>، قال: إلى الموت{18}. (ز) ٥٩٤٣١- عن عبد الله بن عباس -من طريق العوفي - في قوله: <q>﴿لرادك إلى معاد﴾</q>، قال: إلى مكة كما أخرجك منها{19}. (ز) ٥٩٤٣٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي صالح- <q>﴿إن الذي فرض عليك القرآن لرادك إلى معاد﴾</q>، قال: لَرادُّك إلى الجنة، ثم سائِلُك عن القرآن{20}. (١١/٥٢٤) ٥٩٤٣٣- قال السُّدِّيّ: قال أبو سعيد الخدري، مثلها{21}. (ز) ٥٩٤٣٤- عن أبي سعيد الخدري -من طريق إبراهيم بن حيان، عن أبي جعفر- <q>﴿لرادك إلى معاد﴾</q>، قال: معادُه آخرتُه؛ الجنة{22}. (١١/٥٢٢) ٥٩٤٣٥- عن أبي سعيد الخدري -من طريق جابر، عن أبي جعفر- <q>﴿لرادك إلى معاد﴾</q>، قال: الموت{23}. (١١/٥٢٢) ٥٩٤٣٦- عن سعيد بن جبير -من طريق الأعمش- قال: إلى الموت{24}٥٠٠٩. (ز) ٥٠٠٩ علَّق ابنُ عطية (٦/٦١٩) على هذا القول الذي قاله ابن عباس من طريقي الأعمش عن سعيد بن جبير، والسدي عن رجل، وأبو سعيد الخدري، وسعيد بن جبير، ومجاهد، وعكرمة، فقال: «فكأن الآية -على هذا- واعظة ومُذَكِّرة». ٥٩٤٣٧- عن مجاهد بن جبر= (ز) ٥٩٤٣٨- وعكرمة مولى ابن عباس، نحو ذلك{21}. (ز) ٥٩٤٣٩- عن سعيد بن جبير -من طريق جعفر- <q>﴿لرادك إلى معاد﴾</q>: إلى مولدك بمكة{26}. (ز) ٥٩٤٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إن الذي فرض عليك القرآن لرادك إلى معاد﴾</q>، قال: يُحْيِيك يوم القيامة{27}٥٠١٠. (١١/٥٢٣) ٥٠١٠ علَّق ابنُ عطية (٦/٦١٩) على هذا القول الذي قاله ابن عباس من طريق الحكم عن عكرمة، وعطاء، ومجاهد، وعكرمة، والحسن، بقوله: «فالآية -على هذا- مقصدها إثبات الحشر، والإعلام بوقوعه». ٥٩٤٤١- عن مجاهد بن جبر -من طريق يونس بن أبي إسحاق- <q>﴿لرادك إلى معاد﴾</q>، قال: إلى مولدك؛ إلى مكة{28}. (١١/٥٢٢) ٥٩٤٤٢- عن الضحاك بن مزاحم، مثله{29}٥٠١١. (١١/٥٢١، ٥٢٢) ٥٠١١ علَّق ابنُ عطية (٦/٦٢٠) على هذا القول الذي قاله ابن عباس من طريق سفيان العصفري عن عكرمة، والعوفي، ومجاهد، والضحاك، وسعيد بن جبير، ويحيى الجزار، وعطية العوفي، والسدي، ومقاتل، وابن سلام، بقوله: «فالآية -على هذا- مُعْلِمة بغيب قد ظهر للأمة، ومؤْنسة بفتح». وعلَّق ابنُ كثير (١٠/٤٩٠) على هذا القول بقوله: «وهذا مِن كلام الضحاك يقتضي أن هذه الآية مدنية، وإن كان مجموع السورة مكيًّا». ٥٩٤٤٣- عن يحيى الجزار= (ز) ٥٩٤٤٤- وعطية العوفي، نحو ذلك{30}. (ز) ٥٩٤٤٥- عن مجاهد بن جبر= (ز) ٥٩٤٤٦- وعكرمة مولى ابن عباس -من طريق جابر- قالا: إلى الجنة{31}٥٠١٢. (ز) ٥٠١٢ وجَّه ابنُ جرير (١٨/٣٥١-٣٥٢ بتصرف) هذا القول الذي قاله ابن عباس من طرق خصيف عن عكرمة، والأعمش عن رجل عن سعيد بن جبير، والسدي عن أبي صالح، وقاله أبو سعيد الخدري، وأبو مالك، وأبو صالح، وعكرمة، ومجاهد، وعطاء، فقال: «فإن قال قائل: أوَكان أُخرِج من الجنة؛ فيُقال له: نحن نعيدك إليها؟ قيل: لذلك وجهان: أحدهما: أنه إن كان أبوه آدم -صلى الله عليهما- أُخرج منها فكأن ولده بإخراج الله إيّاه منها قد أخرجوا منها، فمن دخلها فكأنما يرد إليها بعد الخروج. والثاني أن يقال: إنه كان ﷺ دخلها ليلة أسري به، كما روي عنه أنه قال: «دخلت الجنة، فرأيت فيها قصرًا، فقلت: لمن هذا؟ فقالوا: لعمر بن الخطاب». ونحو ذلك مِن الأخبار التي رُوِيت عنه بذلك، ثم رد إلى الأرض، فيقال له: <q>﴿إن الذي فرض عليك القرآن لرادك﴾</q> لَمُصَيِّرُك إلى الموضع الذي خرجتَ منه مِن الجنة إلى أن تعود إليه». وعلَّق ابنُ عطية (٦/٦٢٠) على توجيه ابن جرير بقوله: «وإنما قال هذا من حيث تعطي لفظة»المعاد«أنّ المخاطب قد كان في حال يعود إليها، وهذا وإن كان مما يظهر في اللفظة فيتوجه أن يُسَمّى»معادًا«ما لم يكن المرء فيه مجوزًا؛ ولأنها أحوال تابعة للمعاد الذي هو النشور من القبور». ٥٩٤٤٧- عن مجاهد بن جبر= (ز) ٥٩٤٤٨- وعكرمة مولى ابن عباس= (ز) ٥٩٤٤٩- وعطاء [بن أبي رباح] -من طريق جابر-= (ز) ٥٩٤٥٠- والحسن البصري -من طريق أبي قزعة- قالوا: يوم القيامة{32}. (ز) ٥٩٤٥١- عن مجاهد بن جبر -من طريق يونس بن أبي إسحاق- قال: لَرادُّك إلى مولدك؛ إلى مكة{5}. (ز) ٥٩٤٥٢- عن أبي داود [الطيالسي]، قال: حدثنا عبد الواحد بن زياد، قال: سمعت أبا مريم يروي عن الحكم، عن مجاهد، في قول الله ﷿: <q>﴿لرادك إلى معاد﴾</q>، قال: يَرُدُّ محمدًا ﷺ إلى الدنيا حتى يرى عمل أمته. قال عبد الواحد: فقلت له: كذبتَ، ما حدَّثك بهذا الحكم، فقال: اتَّقِ الله، تُكَذِّبني؟!{34}. (ز) ٥٩٤٥٣- عن أبي مالك غزوان الغفاري -من طريق السُّدِّيّ- قال: يردك إلى الجنة، ثم يسألك عن القرآن{35}. (ز) ٥٩٤٥٤- عن الحسن البصري -من طريق قتادة- <q>﴿لرادك إلى معاد﴾</q>، قال: إي، واللهِ، إنّ له لَمعادًا يبعثه الله يوم القيامة، ثم يدخله الجنة{36}. (١١/٥٢٣) ٥٩٤٥٥- عن الحسن البصري= (ز) ٥٩٤٥٦- ومحمد ابن شهاب الزهري -من طريق معمر- قالا: معاده يوم القيامة{37}. (ز) ٥٩٤٥٧- عن أبي صالح [باذام] -من طريق السُّدِّيّ- في قوله: <q>﴿لرادك إلى معاد﴾</q>، قال: إلى الجنة{38}. (١١/٥٢٤) ٥٩٤٥٨- تفسير إسماعيل السُّدِّيّ: <q>﴿لرادك إلى معاد﴾</q>، يعني: إلى مكة{3}. (ز) ٥٩٤٥٩- عن نُعَيْم القارِئ -من طريق حريز- <q>﴿لرادك إلى معاد﴾</q>، قال: إلى بيت المقدس{16}٥٠١٣. (١١/٥٢٤) ٥٠١٣ وجَّه ابنُ كثير (١٠/٤٩١) هذا القول الذي قاله نعيم بقوله: «وهذا -والله أعلم -يرجع إلى قول مَن فسر ذلك بيوم القيامة؛ لأن بيت المقدس هو أرض المحشر والمنشر». ٥٩٤٦٠- قال مقاتل بن سليمان: يعني: إلى مكة ظاهِرًا عليهم{41}. (ز) ٥٩٤٦١- قال يحيى بن سلّام: <q>﴿لرادك إلى معاد﴾</q> إلى مولدك الذي خرجت منه، ظاهِرًا على أهله{5}٥٠١٤. (ز) ٥٠١٤ اختلف في معنى قوله: <q>﴿لرادك إلى معاد﴾</q> على أقوال: الأول: لرادك إلى الموت. الثاني: لرادك إلى مكة موضع ولادتك. الثالث: لرادك إلى مكة بالفتح. الرابع: لرادك إلى القيامة بالبعث. الخامس: لمصيرك إلى الجنة. السادس: بيت المقدس. ورجَّح ابنُ جرير (١٨/٣٥١) القول الأول والثاني مستندًا إلى اللغة، فقال: «والصواب من القول في ذلك عندي قول من قال: لرادك إلى عادتك من الموت، أو إلى عادتك حيث ولدت. وذلك أن المعاد في هذا الموضع»المفعل«من العادة، ليس من العود». ثم ذكر بأن القول الثاني يصح إن وجه «موجه تأويل قوله: <q>﴿لرادك﴾</q>: لمصيرك، فيتوجه حينئذ قوله: <q>﴿إلى معاد﴾</q> إلى معنى العود، ويكون تأويله: إن الذي فرض عليك القرآن لمصيرك إلى أن تعود إلى مكة مفتوحة لك». وساق ابنُ عطية (٦/٦١٩) الأقوال، ثم قال: «والمعاد: الموضع الذي يعاد إليه. وقد اشتهر به يوم القيامة؛ لأنّه معاد الكل». وجمع ابنُ كثير (١٠/٤٩١) بين الروايات الواردة عن ابن عباس بقوله: «ووجه الجمع بين هذه الأقوال أنّ ابن عباس فسر ذلك تارة برجوعه إلى مكة، وهو الفتح الذي هو عند ابن عباس أمارة على اقتراب أجله ﷺ، كما فسره ابن عباس بسورة <q>﴿إذا جاء نصر الله والفتح﴾</q> أنه أجل رسول الله ﷺ نعي إليه، وكان ذلك بحضرة عمر بن الخطاب، ووافقه عمر على ذلك، وقال: لا أعلم منها غير الذي تعلم. ولهذا فسر ابن عباس تارة أخرى قوله: <q>﴿لرادك إلى معاد﴾</q> بالموت، وتارة بيوم القيامة الذي هو بعد الموت، وتارة بالجنة التي هي جزاؤه ومصيره على أداء رسالة الله وإبلاغها إلى الثقلين: الجن والإنس، ولأنه أكمل خلق الله، وأفصح خلق الله، وأشرف خلق الله على الإطلاق». <q>﴿قُل رَّبِّیۤ أَعۡلَمُ مَن جَاۤءَ بِٱلۡهُدَىٰ وَمَنۡ هُوَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٨٥﴾</q> - نزول الآية، وتفسيرها ٥٩٤٦٢- عن عبد الله بن عباس -من طريق الضحاك- قال: نزل جبريل ﵇ على محمد ﷺ، فقال له: يا محمد، قل{43}. (ز) ٥٩٤٦٣- قال مقاتل بن سليمان: <q>﴿قل ربي أعلم من جاء بالهدى﴾</q> وذلك أنّ كفار مكة كذَّبوا محمدًا ﷺ، وقالوا: إنّك في ضلال. فأنزل الله -تبارك وتعالى- في قولهم: <q>﴿قل ربي أعلم من جاء بالهدى﴾</q> فأنا الذي جئت بالهدى من عند الله ﷿، <q>﴿و﴾</q>هو أعلم <q>﴿من هو في ضلال مبين﴾</q> يقول: أنحن أم أنتم{4}. (ز) ٥٩٤٦٤- قال يحيى بن سلّام: <q>﴿قل ربي أعلم﴾</q> قال الله للنبي ﷺ: <q>﴿قل ربي أعلم من جاء بالهدى﴾</q> أي: أنّ محمدًا جاء بالهدى، فآمن به المؤمنون، فعلِموا أنّ محمدًا هو الذي جاء بالهدى، وأنه على الهدى، <q>﴿ومن هو﴾</q> أي: وأعلم من هو <q>﴿في ضلال مبين﴾</q> المشركون{9}. (ز) ",footnotes:1:أورده الثعلبي ٧/٢٦٧.أخرجه إسحاق البستي في تفسيره ص٦٤، وابن أبي حاتم ٩/٣٠٢٦، وعندهما: قال سفيان بن عيينة: سمعناه من مقاتل منذ سبعين سنة.علَّقه يحيى بن سلّام ٢/٦١٣.تفسير مقاتل بن سليمان ٣/٣٥٩.أخرجه يحيى بن سلّام ٢/٦١٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٨/٣٤٥-٣٤٦، وابن أبي حاتم ٩/٣٠٢٥. وعلقه يحيى بن سلّام ٢/٦١٣.تفسير الثعلبي ٧/٢٦٦، وتفسير البغوي ٦/٢٢٦.تفسير يحيى بن سلّام ٢/٦١٣.أخرجه عبد الرزاق ٢/٩٤، وابن أبي حاتم ٩/٣٠٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٣٤٩، والطبراني (١٢٢٦٨).أخرجه ابن جرير ١٨/٣٤٨، وابن أبي حاتم ٩/٣٠٢٥، والطبراني (١٢٢٦٨). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.أخرجه ابن جرير ١٨/٣٤٦، وأخرجه يحيى بن سلّام ٢/٦١٣ من طريق عبد الوهاب بن مجاهد عن أبيه.أخرجه البخاري (٤٧٧٣)، والنسائي في الكبرى (١١٣٨٦)، وابن جرير ١٨/٣٥٠، والبيهقي في الدلائل ٢/٥٢٠-٥٢١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ١٨/٣٤٦، وابن أبي حاتم ٩/٣٠٢٦، والطبراني (١٢٠٣٢) بلفظ: معادك من الجنة. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٩/٣٠٢٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٥٤٩.أخرجه ابن جرير ١٨/٣٥٠.أخرجه ابن أبي حاتم ٩/٣٠٢٥. وعزاه السيوطي إلى ابن جرير، وابن المنذر، والطبراني، وابن مردويه. وهو عند ابن جرير ١٨/٣٤٦ عن السدي عن أبي مالك من قوله كما سيأتي.علقه ابن أبي حاتم ٩/٣٠٢٥.أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٩/٢٦٥ (٣٥٩٨٤)، وأبو يعلى (١١٣١)، وابن جرير ١٨/٣٤٦. وعلَّقه ابن أبي حاتم ٩/٣٠٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.أخرجه ابن جرير ١٨/٣٤٩. وعلَّقه ابن أبي حاتم ٩/٣٠٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.أخرجه ابن جرير ١٨/٣٤٩. وعلَّقه ابن أبي حاتم ٩/٣٠٢٥.علقه ابن أبي حاتم ٩/٣٠٢٥.أخرجه إسحاق البستي في تفسيره ص٦٤. وعلقه ابن أبي حاتم ٩/٣٠٢٦.أخرجه ابن جرير ١٨/٣٤٨، وابن أبي حاتم ٩/٣٠٢٦. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٣٤٧، وابن أبي حاتم ٩/٣٠٢٦. وعزاه السيوطي إلى عبد بن حميد، والفريابي.عزاه السيوطي إلى عبد بن حميد. وأخرجه إسحاق البستي في تفسيره ص٦٤، وابن أبي حاتم ٩/٣٠٢٦ من طريق مقاتل بن سليمان عن سفيان بن عيينة، كما تقدم في نزول الآية.علقه ابن أبي حاتم ٩/٣٠٢٦.أخرجه ابن جرير ١٨/٣٤٧. وعلقه ابن أبي حاتم ٩/٣٠٢٦ عن مجاهد.أخرجه ابن جرير ١٨/٣٤٧، كما أخرجه إسحاق البستي في تفسيره ص٦٣-٦٤ عن مجاهد من طريق ابن جريج بلفظ: يجيء بك يوم القيامة، ومن طريق سفيان بن عيينة بلفظ: إلى الآخرة.أخرجه يحيى بن سلّام ٢/٦١٣.أخرجه العقيلي في كتاب الضعفاء ٤/٣٣ (٣٦٦٥، ٣٦٦٦) وأورد عقبه: قال أبو داود: وأنا أشهد أن أبا مريم كذاب؛ لأني قد لقيته وسمعت منه، واسمه: عبد الغفار بن القاسم.أخرجه ابن جرير ١٨/٣٤٧. وعلَّقه ابن أبي حاتم ٩/٣٠٢٦.أخرجه ابن جرير ١٨/٣٤٨، وابن أبي حاتم ٩/٣٠٢٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٩٤، وابن جرير ١٨/٣٤٨.أخرجه ابن جرير ١٨/٣٤٧. وعزاه السيوطي إلى الفريابي.علَّقه يحيى بن سلّام ٢/٦١٣.أخرجه ابن أبي حاتم ٩/٣٠٢٦.تفسير مقاتل بن سليمان ٣/٣٥٩، وتقدم بتمامه في نزول الآية. وهو في تفسير الثعلبي ٧/٢٦٧ منسوبًا إلى مقاتل دون تعيينه.أخرجه يحيى بن سلّام ٢/٦١٣.أخرجه ابن أبي حاتم ٩/٣٠٢٧.تفسير مقاتل بن سليمان ٣/٣٥٩.تفسير يحيى بن سلّام ٢/٦١٣.
28,86," <q>﴿وَمَا كُنتَ تَرۡجُوۤا۟ أَن یُلۡقَىٰۤ إِلَیۡكَ ٱلۡكِتَـٰبُ إِلَّا رَحۡمَةࣰ مِّن رَّبِّكَۖ فَلَا تَكُونَنَّ ظَهِیرࣰا لِّلۡكَـٰفِرِینَ ۝٨٦﴾</q> - نزول الآية، وتفسيرها ٥٩٤٦٥- قال مقاتل بن سليمان: <q>﴿وما كنت ترجوا﴾</q> يا محمد <q>﴿أن يلقى إليك الكتاب﴾</q> يعني: أن ينزل عليك القرآن، يُذَكِّره النعم. وقال: ما كان الكتاب <q>﴿إلا رحمة﴾</q> يعني ﷿: نعمةً <q>﴿من ربك﴾</q> اختصصت بها، يا محمد، وذلك حين دُعيَ إلى دين آبائه، فأوحى الله ﷿ إلى النبي ﷺ في ذلك، فقال: <q>﴿فلا تكونن ظهيرا﴾</q> يعني: مُعِينًا <q>﴿للكافرين﴾</q>على دينهم{1}. (ز) ٥٩٤٦٦- قال يحيى بن سلّام: <q>﴿وما كنت ترجو﴾</q> يقوله للنبي ﷺ <q>﴿أن يلقى إليك﴾</q> أن ينزل إليك <q>﴿الكتاب﴾</q> القرآن <q>﴿إلا رحمة من ربك﴾</q> أي: ولكن أنزل عليك الكتاب رحمة من ربك؛ <q>﴿فلا تكونن ظهيرا﴾</q> أي: عَوِينًا <q>﴿للكافرين﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٥٩. وفي تفسير البغوي ٦/٢٢٧: قال مقاتل في قوله: <q>﴿فلا تكونن ظهيرا للكافرين﴾</q>: وذلك حين دعي إلى دين آبائه، فذكر الله نعمه، ونهاه عن مظاهرتهم على ما هم عليه.تفسير يحيى بن سلّام ٢/٦١٤.
28,87," <q>﴿وَلَا یَصُدُّنَّكَ عَنۡ ءَایَـٰتِ ٱللَّهِ بَعۡدَ إِذۡ أُنزِلَتۡ إِلَیۡكَۖ وَٱدۡعُ إِلَىٰ رَبِّكَۖ﴾</q> - تفسير ٥٩٤٦٧- قال مقاتل بن سليمان: <q>﴿ولا يصدنك﴾</q> كفار مكة <q>﴿عن آيات الله﴾</q> يعني: عن إيمان بالقرآن <q>﴿بعد إذ أنزلت إليك وادع﴾</q> الناسَ <q>﴿إلى﴾</q> معرفة <q>﴿ربك﴾</q> ﷿، وهو التوحيد{1}. (ز) ٥٩٤٦٨- قال يحيى بن سلّام: <q>﴿ولا يصدنك عن آيات الله بعد إذ أنزلت إليك وادع إلى ربك﴾</q> إلى عبادة ربك{2}٥٠١٥. (ز) ٥٠١٥ قال ابنُ عطية (٦/٦٢١): «وجميع الآية يتضمن المهادنة والموادعة، وهذا كله منسوخ بآية السيف». <q>﴿وَلَا تَكُونَنَّ مِنَ ٱلۡمُشۡرِكِینَ ۝٨٧﴾</q> - تفسير ٥٩٤٦٩- قال عبد الله بن عباس، في قوله: <q>﴿ولا تكونن من المشركين﴾</q>: الخطاب في الظاهر للنبي ﷺ، والمراد به أهل دينه{3}. (ز) ٥٩٤٧٠- قال مقاتل بن سليمان: ثم أوْعَزَ إلى النبي ﷺ وحذَّره، فقال سبحانه: <q>﴿ولا تكونن من المشركين﴾</q>، وذلك حين دُعِي إلى دين آبائه{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٦٠.تفسير يحيى بن سلّام ٢/٦١٤.تفسير البغوي ٦/٢٢٨.تفسير مقاتل بن سليمان ٣/٣٦٠.
28,88," <q>﴿وَلَا تَدۡعُ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَۘ لَاۤ إِلَـٰهَ إِلَّا هُوَۚ﴾</q> - تفسير ٥٩٤٧١- قال مقاتل بن سليمان: فحذَّره الله ﷿ أن يَتَّبع دينهم، فقال سبحانه: <q>﴿ولا تدع﴾</q> يقول: ولا تعبد <q>﴿مع الله﴾</q> تعالى <q>﴿إلها آخر﴾</q> فإنّه واحد ليس معه شريك. ثم وحَّد نفسه جل جلاله فقال: <q>﴿لا إله إلا هو﴾</q>{1}. (ز) <q>﴿كُلُّ شَیۡءٍ هَالِكٌ إِلَّا وَجۡهَهُۥۚ﴾</q> - نزول الآية ٥٩٤٧٢- عن عبد الله بن عباس، قال: لَمّا نزلت: <q>﴿كل نفس ذائقة الموت﴾</q> قيل: يا رسول الله، فما بال الملائكة؟ فنزلت: <q>﴿كل شيء هالك إلا وجهه﴾</q> ...{2}. (١١/٥٢٥) ٥٩٤٧٣- عن عبد الملك ابن جريج، قال: لما نزلت: <q>﴿كل من عليها فان﴾</q> [الرحمن:٢٦] قالت الملائكة: هلك أهل الأرض. فلما نزلت: <q>﴿كل نفس ذائقة الموت﴾</q> [آل عمران:١٨٥، العنكبوت:٥٧] قالت الملائكة: هلك كل نفس. فلما نزلت: <q>﴿كل شيء هالك إلا وجهه﴾</q> قالت الملائكة: هلك أهل السماء، وأهل الأرض{3}. (١١/٥٢٤) <q>﴿كُلُّ شَیۡءٍ هَالِكٌ إِلَّا وَجۡهَهُۥۚ﴾</q> - تفسير الآية ٥٩٤٧٤- عن علي بن أبي طالب -من طريق الحسن، وسعيد بن جبير- أنّ رجلًا سأله شيئًا فلم يعطه، فقال: أسألك لوجه الله. فقال له عليٌّ: كذبتَ، ليس لوجه الله سألتني، إنّما وجه الله الحق، ألا ترى قوله ﷾: <q>﴿كُلُّ شَيْءٍ هالِكٌ إلّا وجْهَهُ﴾</q> يعني: الحق؟ ولكن سألتني بوجهك الخلق {4}. (ز) ٥٩٤٧٥- عن عبد الله بن عباس، قال: لما نزلت: <q>﴿كل نفس ذائقة الموت﴾</q> قيل: يا رسول الله، فما بال الملائكة؟ فنزلت: <q>﴿كل شيء هالك إلا وجهه﴾</q>. فبين في هذه الآية فناء الملائكة، والثقلين من الجن والإنس، وسائر عالم الله وبريته؛ من الطير، والوحش، والسباع، والأنعام، وكل ذي روح؛ أنه هالك ميت{2}. (١١/٥٢٥) ٥٩٤٧٦- عن عبد الله بن عباس: <q>﴿كل شيء هالك إلا وجهه﴾</q> إلا ما يريد به وجهه{6}. (١١/٥٢٥) ٥٩٤٧٧- عن عيسى المديني، قال: سمعت علي بن الحسين سأل كعب الأحبار عن قوله: <q>﴿فصعق من في السموات ومن في الأرض إلا من شاء الله﴾</q> [الزمر:٦٨]، مَن الذين استثنى؟ قال: هم ثلاثة عشر: جبريل، وميكائيل، وإسرافيل، وحملة العرش الثمانية، وملَك الموت، ورب العزة. فيأمر ملك الموت فيقبض فلانًا وفلانًا وحملة العرش حتى لا يبقى غيره، فيقول ربُّ العزة: مُت، يا ملك الموت. فيموت، فذلك قوله: <q>﴿كل من عليها فان ويبقى وجه ربك ذو الجلال والإكرام﴾</q> [الرحمن:٢٦-٢٧]. وذلك قوله: <q>﴿كل شيء هالك إلا وجهه له الحكم وإليه ترجعون﴾</q>{7}. (ز) ٥٩٤٧٨- عن أبي العالية الرياحي، في قوله: <q>﴿كل شيء هالك إلا وجهه﴾</q>، قال: إلا ما أُرِيدَ به وجهه{8}. (ز) ٥٩٤٧٩- عن مجاهد بن جبر -من طريق خُصيف- <q>﴿كل شيء هالك إلا وجهه﴾</q>، قال: إلّا ما أُرِيدَ به وجهه{9}. (١١/٥٢٥) ٥٩٤٨٠- عن مجاهد بن جبر، <q>﴿كل شيء هالك إلا وجهه﴾</q>، قال: إلا هو{10}. (ز) ٥٩٤٨١- عن الضحاك بن مزاحم: كلّ شيء هالك إلّا الله، والجنة، والنار، والعرش{11}. (ز) ٥٩٤٨٢- قال إسماعيل السُّدِّيّ: <q>﴿كل شيء هالك﴾</q> يعني: كل شيء من الحيوان ميت، <q>﴿إلا وجهه﴾</q> إلا الله؛ فإنّه لا يموت -تبارك وتعالى-{12}. (ز) ٥٩٤٨٣- عن [جعفر بن محمد] الصادق، قال: إلا دينه{10}. (ز) ٥٩٤٨٤- عن يحيى بن شبل، قال: كنت جالسًا عند مقاتل بن سليمان، فجاء شابٌّ، فسأله: ما تقول في قول الله تعالى: <q>﴿كل شيء هالك إلا وجهه﴾</q>؟ قال: فقال مقاتل: هذا جهمي. قال: ما أدري ما جهم، إن كان عندك عِلم فيما أقول وإلا فقُل: لا أدري. فقال: ويحك، إنّ جهمًا -واللهِ- ما حجَّ هذا البيت، ولا جالس العلماء، إنما كان رجلًا أُعطي لسانًا. وقوله تعالى: <q>﴿كل شيء هالك إلا وجهه﴾</q> إنما هو شيء في الروح{14}، كما قال ههنا لملكة سبأ: <q>﴿وأوتيت من كل شيء﴾</q> [النمل:٢٣] لم تؤت إلا ملك بلادها، وكما قال: <q>﴿وآتيناه من كل شيء سببًا﴾</q> [الكهف:٨٤] لم يؤت إلا ما في يده من الملك. ولم يَدَعْ في القرآن «كل شيء، وكل شيء» إلا سَرَدَ علينا{15}. (ز) ٥٩٤٨٥- قال مقاتل بن سليمان: <q>﴿كل شيء هالك إلا وجهه﴾</q> يقول سبحانه: كل شيء من الحيوان ميت، ثم استثنى نفسَه جل جلاله بأنّه تعالى حيٌّ دائم لا يموت، فقال جل جلاله: <q>﴿إلا وجهه﴾</q> يعني: إلا هو{1}. (ز) ٥٩٤٨٦- عن مقاتل [بن حيان] -من طريق منصور بن الحميد- <q>﴿كل شيء هالك إلا وجهه﴾</q>: يعني: الحيوان خاصة مِن أهل السموات والملائكة، ومَن في الأرض، وجميع الحيوان، ثم تهلك السماء والأرض بعد ذلك، ولا تهلك الجنة والنار وما فيها، ولا العرش، ولا الكرسي{17}. (١١/٥٢٥) ٥٩٤٨٧- عن سفيان الثوري، في قوله: <q>﴿كل شيء هالك إلا وجهه﴾</q>، قال: إلا ما أريد به وجهه من الأعمال الصالحة{18}٥٠١٦. (١١/٥٢٥) ٥٠١٦ علَّق ابنُ عطية (٦/٦٢١) على هذا القول بقوله: "أي: ما عُمل لذاته من طاعة، وتُوجّه به نحوه، ومن هذا قول الشاعر: رب العباد إليه الوجه والعمل ومنه قول القائل: أردت بفعلي وجه الله تعالى. ومنه قوله ﷿: <q>﴿ولا تَطْرُدِ الَّذِينَ يَدْعُونَ رَبَّهُمْ بِالغَداةِ والعَشِيِّ يُرِيدُونَ وجْهَهُ﴾</q> [الأنعام:٥٢]". ٥٩٤٨٨- قال يحيى بن سلّام: <q>﴿ولا تدع مع الله إلها آخر لا إله إلا هو كل شيء هالك إلا وجهه﴾</q> هو كقوله: <q>﴿ويبقى وجه ربك ذو الجلال والإكرام﴾</q> [الرحمن:٢٧]{19}٥٠١٧. (ز) ٥٠١٧ اختلف في قوله تعالى: <q>﴿كُلُّ شَيْءٍ هالِكٌ إلّا وجْهَهُ﴾</q> على قولين: الأول: إلاَّ الله. الثاني: إلا ما أُرِيدَ به وجهُه. الثالث: دينه. وذكر ابنُ كثير (١٠/٤٩٢) أن القول الثاني لا ينافي الأول، فقال: «وهذا القول لا ينافي القول الأول، فإن هذا إخبار عن كل الأعمال بأنها باطلة إلا ما أريد بها وجه الله ﷿ من الأعمال الصالحة المطابقة للشريعة. والقول الأول مقتضاه أن كل الذوات فانية وهالكة وزائلة إلا ذاته تعالى، فإنه الأول الآخر الذي هو قبل كل شيء وبعد كل شيء». ورجَّح ابنُ تيمية (٥/٩٣) القول الثاني الذي قاله ابن عباس من طريق عطاء، والثوري، وأبو العالية، ومجاهد، مستندًا إلى السياق، فقال: «وتفسير الآية بما هو مأثور ومنقول عن ما قاله من السلف والمفسرين من أن المعنى:كل شيء هالك إلا ما أريد به وجهه. فإنه ذكر ذلك بعد نهيه عن الإشراك، وأن يدعو معه إلهًا آخر، وقوله: <q>﴿لا إله إلا هو﴾</q> يقتضي أظهر الوجهين: وهو أن كل شيء هالك إلا ما كان لوجهه من الإيمان والأعمال وغيرهما». وذكر ابنُ تيمية أن القول الثاني والأخير -الذي قاله جعفر الصادق- معناهما واحد. <q>﴿لَهُ ٱلۡحُكۡمُ وَإِلَیۡهِ تُرۡجَعُونَ ۝٨٨﴾</q> - تفسير ٥٩٤٨٩- قال مقاتل بن سليمان: قوله <q>﴿له الحكم﴾</q> يعني: القضاء، <q>﴿وإليه ترجعون﴾</q> أحياء في الآخرة، فيجزيكم ﷿ بأعمالكم{1}. (ز) ٥٩٤٩٠- قال يحيى بن سلّام: <q>﴿له الحكم﴾</q> القضاء، <q>﴿وإليه ترجعون﴾</q> يوم القيامة{19}. (ز) <q>﴿لَهُ ٱلۡحُكۡمُ وَإِلَیۡهِ تُرۡجَعُونَ ۝٨٨﴾</q> - آثار متعلقة بالآية ٥٩٤٩١- عن عبادة بن الصامت -من طريق شهر بن حوشب- قال: يُجاء بالدنيا يوم القيامة، فيُقال: ميِّزوا ما كان لله منها. قال: فيماز ما كان لله منها، ثم يُؤمَر بسائرها فيُلقى في النار{4}. (ز) ٥٩٤٩٢- عن عبد الله بن عمر: أنّه كان إذا أراد أن يتعاهد قلبَه يأتي الخرِبة، يقف على بابها، فينادي بصوت حزين: أين أهلُكِ؟ ثم يرجع إلى نفسه، فيقول: <q>﴿كل شيء هالك إلا وجهه﴾</q>{23}. (١١/٥٢٦) ٥٩٤٩٣- عن ثابت، قال: لَمّا مات موسى بن عمران ﵇ جالَتِ الملائكةُ في السموات، يقولون: مات موسى، فأيُّ نفس لا تموت!{24}. (١١/٥٢٦) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٦٠.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه الثعلبي ٧/٢٦٧.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة في العرش ص٤٠٢-٤٠٣ (٤٢)، وابن أبي حاتم ٩/٣٠٢٨.تفسير الثعلبي ٧/٢٦٧، وتفسير البغوي ٦/٢٢٨.أخرجه ابن أبي حاتم ٩/٣٠٢٨.تفسير الثعلبي ٧/٢٦٧.تفسير الثعلبي (ط دار التفسير) ٢٠/٥٢٤.علَّقه يحيى بن سلّام ٢/٦١٤.تفسير الثعلبي ٧/٢٦٧.كذا في المصدر، ويظهر أنها: فيه الروح، كما في تفسير مقاتل في قوله: كل شيء من الحيوان.أخرجه ابن عساكر في تاريخ دمشق ٦٠/١١٩.تفسير مقاتل بن سليمان ٣/٣٦٠.أخرجه ابن أبي حاتم ٩/٣٠٢٨، والبيهقي (٦٨٩٤).تفسير سفيان الثوري ص٢٣٤، ومن طريق راويه أبي حذيفة النهدي أخرجه البيهقي في شعب الإيمان (٦٨٩٤)، كما أخرجه ابن أبي حاتم ٩/٣٠٢٨ من طريق عطاء بن مسلم الحلبي.تفسير يحيى بن سلّام ٢/٦١٤.تفسير مقاتل بن سليمان ٣/٣٦٠.تفسير يحيى بن سلّام ٢/٦١٤.أخرجه الثعلبي ٧/٢٦٧.أخرجه ابن أبي الدنيا في كتاب التفكر -كما في تفسير ابن كثير ٦/٢٧٢-.أخرجه أحمد في الزهد ص٧٤.
29,1," مقدمة السورة ٥٩٤٩٤- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة العنكبوت بمكة{1}. (١١/٥٢٧) ٥٩٤٩٥- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد الروم{2}. (ز) ٥٩٤٩٦- عن عبد الله بن الزبير، قال: نزلت سورة العنكبوت بمكة{3}. (١١/٥٢٧) ٥٩٤٩٧- عن علي بن الحسين -من طريق الحسين بن واقد- قال: آخر سورة نزلت على رسول الله ﷺ بمكة: المؤمنون، ويقال: العنكبوت{4}. (ز) ٥٩٤٩٨- قال عامر الشعبي: هذه الآيات العشر من أول السورة إلى هاهنا مدنية{5}، وباقي السورة مكية{6}. (ز) ٥٩٤٩٩- عن عكرمة مولى ابن عباس= (ز) ٥٩٥٠٠- والحسن البصري -من طريق يزيد النحوي-: مكية{7}. (ز) ٥٩٥٠١- عن قتادة بن دعامة -من طريق همام-: مكية{8}. (ز) ٥٩٥٠٢- عن قتادة بن دعامة -من طريق سعيد- قال: أُنزِلت هذه الآيات في القوم الذين رَدَّهم المشركون إلى مكة، وهؤلاء الآيات العشر مدنيات، وسائرها مكي{9}. (١١/٥٢٨) ٥٩٥٠٣- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الروم{10}. (ز) ٥٩٥٠٤- عن علي بن أبي طلحة: مكية{11}. (ز) ٥٩٥٠٥- قال مقاتل بن سليمان: مكية، ويقال: نزلت بين مكة والمدينة، في طريقه حين هاجر ﷺ، وهي تسع وستون آية كوفية{12}. (ز) ٥٩٥٠٦- قال يحيى بن سلّام: وهي مكية كلها، إلا عشر آيات مدنية من أولها إلى قوله: <q>﴿وليعلمن المنافقين﴾</q>{13}. (ز) ٥٩٥٠٧- قال يحيى بن سلّام: ... وما بعد هذه العشر آيات مكي، وهذه العشر مدنية نزلت بعدها من هذه السورة، وهي قبل ما بعدها في التأليف{14}٥٠١٨. (ز) ٥٠١٨ قال ابن عطية (ط. دار الكتب العلمية ٤/٣٠٥): «هذه السورة مكية، إلا الصدر منها، العشر الآيات، فإنها مدنية، نزلت في شأن من كان من المسلمين بمكة، وفي هذا اختلاف، وهذا أصح ما قيل فيه». ",footnotes:1:أخرجه النحاس ص٦١١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في الدلائل ٧/١٤٣-١٤٤ من طريق خصيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه الواحدي في أسباب النزول ١/١٠٦.يعني قوله تعالى: <q>﴿وليعلمن الله الذين آمنوا وليعلمن المنافقين﴾</q> [العنكبوت:١١].تفسير البغوي ٦/٢٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه أبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧-.أخرجه ابن جرير ١٨/٣٦٦-٣٦٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ بلفظ: مكية، إلا عشر آيات منها.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٣٧١.تفسير يحيى بن سلّام ٢/٦١٥.تفسير يحيى بن سلّام ٢/٦١٩.
29,2," <q>﴿الۤمۤ ۝١ أَحَسِبَ ٱلنَّاسُ أَن یُتۡرَكُوۤا۟ أَن یَقُولُوۤا۟ ءَامَنَّا وَهُمۡ لَا یُفۡتَنُونَ ۝٢﴾</q> - نزول الآية ٥٩٥٠٨- عن عامر الشعبي -من طريق مطر الوراق- في قوله: <q>﴿الم (١) أحَسِبَ النّاسُ أنْ يُتْرَكُوا﴾</q> الآية، قال: نزلت في أناس كانوا بمكة قد أقرُّوا بالإسلام، فكتب اليهم أصحابُ رسول الله ﷺ من المدينة لما نزلت آية الهجرة: إنه لا يُقْبَلُ منكم إقرار ولا إسلام حتى تهاجروا. قال: فخرجوا عامِدين إلى المدينة، فاتَّبَعهم المشركون، فرَدُّوهم، فنزلت فيهم هذه الآية، فكتبوا إليهم: إنه قد أُنزِلَت فيكم آية كذا وكذا. فقالوا: نخرُجُ، فإن اتَّبَعَنا أحدٌ قاتلناه. فخرجوا، فاتَّبَعهم المشركون، فقاتَلوهم؛ فمنهم مَن قُتل، ومنهم مَن نجا؛ فأنزل اللهُ فيهم: <q>﴿ثم إن ربك للذين هاجروا من بعد ما فتنوا ثم جاهدوا وصبروا إن ربك من بعدها لغفور رحيم﴾</q> [النحل: ١١٠]{1}. (١١/٥٢٧) ٥٩٥٠٩- عن عبد الله بن عبيد بن عمير -من طريق ابن جريج- قال: نزلت في عمار بن ياسر، إذ كان يُعَذَّبُ في الله: <q>﴿الم (١)أحَسِبَ النّاسُ أنْ يُتْرَكُوا﴾</q> الآية{2}. (١١/٥٢٨) ٥٩٥١٠- قال ابن جريج: سمعت ابن عمير وغيرَه يقولون: كان أبو جهل يُعذِّبُ عمارَ بن ياسر وأمَّه، ويجعل على عمار دِرْعًا من حديد في اليوم الصائف، وطعن في حَياء{3} أمه برمح؛ ففي ذلك نزلت: <q>﴿الم (١) أحَسِبَ النّاسُ أنْ يُتْرَكُوا أنْ يَقُولُوا آمَنّا وهُمْ لا يُفْتَنُونَ (٢)﴾</q>{4}. (١١/٥٢٩) ٥٩٥١١- عن قتادة بن دعامة -من طريق سعيد بن بشير- في قوله: <q>﴿الم (١) أحَسِبَ النّاسُ﴾</q> الآية، قال: نزلت في أُناسٍ من أهل مكة، خرجوا يريدون النبيَّ ﷺ، فعرَض لهم المشركون، فرجَعوا، فكتب إليهم إخوانُهم بما نزل فيهم من القرآن، فخرَجوا، فقُتل مَن قُتل، وخلَص مَن خلَص، فنزل القرآن: <q>﴿والذين جاهدوا فينا لنهدينهم سبلنا﴾</q> [العنكبوت:٦٩]{5}٥٠١٩. (١١/٥٢٨) ٥٠١٩ أشار ابنُ عطية (٦/٦٢٣) إلى نحو ما جاء في قول قتادة، ثم علّق قائلًا: «وهذه الآية وإن كانت نزلت بهذا السبب، وفي هذه الجماعة، فهي بمعناها باقية في أمة محمد ﷺ، موجود حكمها بقية الدهر، وذلك أن الفتنة من الله تعالى باقية في ثغور المسلمين بالأسر ونكاية العدو وغير ذلك، وإذا اعتبر أيضًا كل موضع ففيه ذلك بالأمراض وأنواع المحن، ولكن التي تشبه نازلة المؤمنين مع قريش هي ما ذكرناه من أمر العدو في كل ثغر». ٥٩٥١٢- قال مقاتل بن سليمان: <q>﴿الم (١) أحَسِبَ النّاسُ أنْ يُتْرَكُوا﴾</q> نزلت في مهجع بن عبد الله مولى عمر بن الخطاب، كان أول قتيل من المسلمين يوم بدر، وهو أول من يدعى إلى الجنة من شهداء أمة محمد ﷺ، فجزع عليه أبواه، وكان الله -تبارك وتعالى- بيَّن للمسلمين أنه لا بُدَّ لهم من البلاء والمشقة في ذات الله ﷿، وقال النبي ﷺ يومئذ: «سيد الشهداء مهجع». وكان رماه عامر بن الحضرمي بسهم، فقتله، فأنزل الله ﷿ في أبويه عبد الله وامرأته: <q>﴿الم (١) أحَسِبَ النّاسُ أنْ يُتْرَكُوا أنْ يَقُولُوا آمَنّا وهُمْ لا يُفْتَنُونَ﴾</q>{6}. (ز) ٥٩٥١٣- قال يحيى بن سلّام: أي: وهم لا يُبْتَلُون بالجهاد في سبيل الله، وذلك أن قومًا كانوا بمكة ممن أسلم كان قد وُضع عنهم الجهاد والنبي ﵇ بالمدينة بعد ما افْتُرِضَ الجهاد، وقُبِلَ منهم أن يقيموا الصلاة ويؤتوا الزكاة ولا يجاهدوا، ثم أُذن لهم في القتال حين أخرجهم أهل مكة، فقال: <q>﴿أُذِنَ لِلَّذِينَ يُقاتَلُونَ بِأَنَّهُمْ ظُلِمُوا﴾</q> [الحج: ٣٩]، فلما أُمِرُوا بالجهاد كره قوم القتال، فقال الله تبارك وتعالى: <q>﴿ألَمْ تَرَ إلى الَّذِينَ قِيلَ لَهُمْ كُفُّوا أيْدِيَكُمْ وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ فَلَمّا كُتِبَ عَلَيْهِمُ القِتالُ إذا فَرِيقٌ مِنهُمْ يَخْشَوْنَ النّاسَ كَخَشْيَةِ اللَّهِ أوْ أشَدَّ خَشْيَةً وقالُوا رَبَّنا لِمَ كَتَبْتَ عَلَيْنا القِتالَ لَوْلا أخَّرْتَنا إلى أجَلٍ قَرِيبٍ﴾</q> [النساء: ٧٧]، وأنزل في هذه السورة: <q>﴿أحَسِبَ النّاسُ أنْ يُتْرَكُوا أنْ يَقُولُوا آمَنّا وهُمْ لا يُفْتَنُونَ﴾</q>{7}. (ز) <q>﴿الۤمۤ ۝١ أَحَسِبَ ٱلنَّاسُ أَن یُتۡرَكُوۤا۟ أَن یَقُولُوۤا۟ ءَامَنَّا وَهُمۡ لَا یُفۡتَنُونَ ۝٢﴾</q> - تفسير الآية ٥٩٥١٤- عن سعيد بن جبير= (ز) ٥٩٥١٥- ومعاوية بن قرة= (ز) ٥٩٥١٦- وخصيف بن عبد الرحمن= (ز) ٥٩٥١٧- والربيع بن أنس، <q>﴿وهم لا يفتنون﴾</q> أنهم قالوا: يُبتَلَوْن{8}. (ز) ٥٩٥١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهم لا يفتنون﴾</q>، قال: لا يبتلون في أموالهم وأنفسهم{9}. (١١/٥٢٩) ٥٩٥١٩- عن عكرمة مولى ابن عباس -من طريق عثمان بن غياث- <q>﴿وهم لا يفتنون﴾</q>: يُبتلون{10}. (ز) ٥٩٥٢٠- عن الحسن البصري -من طريق حوشب- في قوله: <q>﴿الم (١) أحسب الناس أن يتركوا أن يقولوا آمنا﴾</q>، قال: أحسب الناس أن يتركوا أن يقولوا: لا إله إلا الله حتى أبتليهم، فأعرف الصادق من الكاذب{11}. (ز) ٥٩٥٢١- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿أحسب الناس أن يتركوا أن يقولوا آمنا وهم لا يفتنون﴾</q>، قال: لا يبتلون{12}. (١١/٥٢٩) ٥٩٥٢٢- تفسير إسماعيل السُّدِّيّ: <q>﴿أحسب الناس أن يتركوا أن يقولوا آمنا وهم لا يفتنون﴾</q>، يعني: وهم لا يبتلون في إيمانهم{13}. (ز) ٥٩٥٢٣- عن الربيع بن أنس -من طريق عبد الله بن أبي جعفر- في قوله: <q>﴿الم (١) أحسب الناس أن يتركوا﴾</q>، قال: كان أمر النبيُّ ﷺ رجالًا، وحسبوا أن الأمر يخفوا{14}، فلما أوذوا في الله ارتدَّ منهم أقوامٌ، وقال في آية أخرى: <q>﴿أم حسبتم أن تدخلوا الجنة ولما يأتكم مثل الذين خلوا من قبلكم مستهم البأساء والضراء وزلزلوا﴾</q> [البقرة:٢١٤]. قال: فكان أصحاب النبي ﷺ يقولون: أتتنا -يعني: السنن- على ما أوذوا في الله وصبروا عند البأساء والضراء، وشكروا في السراء، وقضى الله عليهم أنه سيبتليهم بالسراء والضراء، والخير والشر، والأمن والخوف، والطمأنينة والشخوص، واستخرج الله عند ذلك أخبارهم ...{15} من الدهر، حتى وضعت الحرب أوزارها، وجلسوا في المجالس آمنين، ثم قال النبي ﷺ في آخر عمره، وخشي عليهم الدنيا، وعرف أنهم سيؤتون من قبلها: أنها تفتح عليهم خزائنها، فتقدم إليهم في ذلك أن تَغُرَّهم الحياة الدنيا، وأخبرهم أن الفتنة واقعة، وأنها مصيبة الذين ظلموا منهم خاصة، فإذا فعلوا ذلك كانوا في انتقاص وتغيير{16}. (ز) ٥٩٥٢٤- عن أسباط [بن نصر]-من طريق عامر بن الفرات- قال: فابتلوا عند الفرقة؛ حين اقتتل عليٌّ وطلحةُ والزبيرُ{17}. (ز) ٥٩٥٢٥- قال مقاتل بن سليمان: <q>﴿أحسب الناس أن يتركوا أن يقولوا آمنا وهم لا يفتنون﴾</q>، يقول: أحسبوا أن يتركوا عن التصديق بتوحيد الله ﷿، ولا يبتلون في إيمانهم!{6}. (ز) ٥٩٥٢٦- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قوله: <q>﴿الم (١) أحسب الناس أن يتركوا أن يقولوا آمنا وهم لا يفتنون﴾</q>، قال: لا يختبرون{19}. (ز) ٥٩٥٢٧- قال يحيى بن سلّام: <q>﴿أحَسِبَ النّاسُ أنْ يُتْرَكُوا أنْ يَقُولُوا آمَنّا وهُمْ لا يُفْتَنُونَ﴾</q> لا يُبْتَلَون بالجهاد في سبيل الله{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٥٨-٣٥٩، وابن أبي حاتم ٩/٣٠٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن سعد ٣/٢٥٠، وابن جرير ١٨/٣٥٨، وابن أبي حاتم ٩/٣٠٣٢، وابن عساكر ٤٣/٣٧٥-٣٧٦.الحياء -ممدود-: الفَرْج. النهاية ١/٤٧٢.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٣١.تفسير مقاتل بن سليمان ٣/٣٧٢.تفسير يحيى بن سلّام ٢/٦١٥.علقه ابن أبي حاتم ٩/٣٠٣٢.أخرجه ابن جرير ١٨/٣٥٩، وابن أبي حاتم ٩/٣٠٣٢. وأخرجه إسحاق البستي في تفسيره ص٦٦ من طريق ابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، والفريابي.أخرجه الحربي في غريب الحديث ٣/٩٣٢.أخرجه ابن أبي حاتم ٩/٣٠٣١. وأخرجه يحيى بن سلّام ٢/٦١٥ مختصرًا من طريق المبارك بلفظ: «<q>﴿وهم لا يفتنون﴾</q>: لا يبتلون».أخرجه ابن جرير ١٨/٣٥٦، ٣٥٩، وابن أبي حاتم ٩/٣٠٣٣. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ٢/٦١٥.في مطبوعة المصدر: (يخفوا).علق محقق المصدر على هذا الموضع بقوله: «طمس بالأصل، ولعلها بالأصل: ومكثوا فترة».أخرجه ابن أبي حاتم ٩/٣٠٣٠.أخرجه ابن أبي حاتم ٩/٣٠٣٢. ويحتمل أن يكون الأثر عن السدي من طريق أسباط، سقط اسم السدي من النسخة.تفسير مقاتل بن سليمان ٣/٣٧٢.أخرجه ابن أبي حاتم ٩/٣٠٣٢.تفسير يحيى بن سلّام ٢/٦١٥.
29,3," <q>﴿وَلَقَدۡ فَتَنَّا ٱلَّذِینَ مِن قَبۡلِهِمۡۖ﴾</q> - تفسير ٥٩٥٢٨- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله ﷿: <q>﴿ولقد فتنا الذين من قبلهم﴾</q>، يقول: ولقد اختبرناهم{1}. (ز) ٥٩٥٢٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولقد فتنا الذين من قبلهم﴾</q>، قال: ابتلينا{2}. (١١/٥٢٩) ٥٩٥٣٠- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿ولقد فتنا الذين من قبلهم﴾</q>، يقول: ابتلينا الذين من قبلهم{1}. (ز) ٥٩٥٣١- عن سعيد بن جبير= (ز) ٥٩٥٣٢- ومعاوية بن قرة{4}= (ز) ٥٩٥٣٣- وخصيفٍ بن عبد الرحمن، مثل ذلك{5}. (ز) ٥٩٥٣٤- عن الحسن البصري -من طريق يونس- <q>﴿ولقد فتنا﴾</q>: ابتلينا{6}. (ز) ٥٩٥٣٥- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿ولقد فتنا الذين من قبلهم﴾</q>، قال: ابتلينا الذين من قبلهم{7}. (١١/٥٢٩) ٥٩٥٣٦- تفسير إسماعيل السُّدِّيّ، في قوله: <q>﴿ولقد فتنا﴾</q>، قال: يعني: ولقد ابتلينا{8}. (ز) ٥٩٥٣٧- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿ولقد فتنا الذين من قبلهم﴾</q>، قال: بلونا الذين من قبلهم{9}. (ز) ٥٩٥٣٨- قال مقاتل بن سليمان: <q>﴿ولقد فتنا﴾</q> يقول: ولقد ابتلينا <q>﴿الذين من قبلهم﴾</q> يعني: من قبل هذه الأمة من المؤمنين{10}. (ز) ٥٩٥٣٩- قال يحيى بن سلّام: قوله: <q>﴿ولقد فتنا الذين من قبلهم﴾</q>، يعني: ابتلينا الذين من قبلهم{11}. (ز) <q>﴿فَلَیَعۡلَمَنَّ ٱللَّهُ ٱلَّذِینَ صَدَقُوا۟ وَلَیَعۡلَمَنَّ ٱلۡكَـٰذِبِینَ ۝٣﴾</q> - قراءات ٥٩٥٤٠- عن علي بن أبي طالب -من طريق يونس بن بكير- أنه كان يقرأ: (فَلَيُعْلِمَنَّ اللهُ الَّذِينَ صَدَقُواْ ولَيُعْلِمَنَّ الكاذِبِينَ) قال: يُعْلِمُهم الناسَ{12}٥٠٢٠. (١١/٥٢٩) ٥٠٢٠ علّق ابنُ عطية (٦/٦٢٤) على هذه القراءة، فقال: «وهذه القراءة تحتمل ثلاثة معان: أحدها: أن يُعلِم في الآخرة هؤلاء الصادقين والكاذبين بمنازلهم من ثوابه وعقابه، وبأعمالهم في الدنيا، بمعنى: يُوقِفهم على ما كان منهم. والثاني: أن يُعلِم الناس والعالم هؤلاء الصادقين والكاذبين، أي: يفضحهم ويشهرهم؛ هؤلاء في الخير، وهؤلاء في الشر، وذلك في الدنيا والآخرة. والثالث: أن يكون ذلك من العلامة، أي: يضع لكل طائفة عَلَمًا تشهر به، فالآية على هذا ينظر إليها قول النبي ﷺ: «من أسر سريرة ألبسه الله رداءها». وعلى كل معنى منها ففيها وعد للمؤمنين الصادقين، ووعيد للكافرين». <q>﴿فَلَیَعۡلَمَنَّ ٱللَّهُ ٱلَّذِینَ صَدَقُوا۟ وَلَیَعۡلَمَنَّ ٱلۡكَـٰذِبِینَ ۝٣﴾</q> - تفسير الآية ٥٩٥٤١- عن عبد الله بن عباس -من طريق عكرمة- في الآية، قال: كان الله يبعث النبي إلى أمته، فيلبث فيهم إلى انقضاء أجله في الدنيا، ثم يقبضه الله إليه، فتقول الأمةُ مِن بعده أو مَن شاء الله منهم: إنا على منهاج النبي وسبيله. فينزل الله بهم البلاء؛ فمن ثبت منهم على ما كان عليه فهو الصادق، ومَن خالف إلى غير ذلك فهو الكاذب{13}. (١١/٥٣٠) ٥٩٥٤٢- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿فليعلمن الله الذين صدقوا﴾</q>، قال: ليعلم الصادقَ من الكاذب، والطائعَ من العاصي، وقد كان يُقال: إنّ المؤمن ليُضرَب بالبلاء كما يُفتَن الذهب بالنار. وكان يُقال: إن مثل الفتنة كمثل الدرهم الزيف، يأخذه الأعمى، ويراه البصير{14}. (١١/٥٢٩) ٥٩٥٤٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فليعلمن الله الذين صدقوا وليعلمن الكاذبين﴾</q>، قال: الذين صدقوا: علي بن أبي طالب وأصحابه{15}. (ز) ٥٩٥٤٤- قال مقاتل بن سليمان: <q>﴿فليعلمن الله الذين﴾</q> يقول: فليرين الله الذين <q>﴿صدقوا﴾</q> في إيمانهم من هذه الأمة عند البلاء، فيصبروا لقضاء الله ﷿، <q>﴿وليعلمن﴾</q> يقول: وليرين <q>﴿الكاذبين﴾</q> في إيمانهم، فيَشْكُوا عند البلاء{10}. (ز) ٥٩٥٤٥- قال يحيى بن سلّام: <q>﴿فليعلمن الله الذين صدقوا﴾</q>: بما أظهروا من الإيمان، <q>﴿وليعلمن الكاذبين﴾</q> الذين أظهروا الإيمان وقلوبهم على الكفر، وهم المنافقون، وهذا عِلْمُ الفِعال{11}. (ز) <q>﴿فَلَیَعۡلَمَنَّ ٱللَّهُ ٱلَّذِینَ صَدَقُوا۟ وَلَیَعۡلَمَنَّ ٱلۡكَـٰذِبِینَ ۝٣﴾</q> - آثار متعلقة بالآية ٥٩٥٤٦- عن الحسن البصري -من طريق الحسن بن دينار- قال: واللهِ، ما قال عبدٌ في هذا الدِّين مِن قولٍ إلا وعلى قولِه دليلٌ مِن عمله، يُصَدِّقه أو يُكَذِّبه{11}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٣٢.أخرجه ابن جرير ١٨/٣٥٩، وابن أبي حاتم ٩/٣٠٣٢. وأخرجه إسحاق البستي في تفسيره ص٦٦ من طريق أبي هاشم وابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، والفريابي.أخرجه ابن أبي حاتم ٩/٣٠٣٢.تصحفت في الأصل المطبوع إلى «مرة».علقه ابن أبي حاتم ٩/٣٠٣٢.أخرجه الحربي في غريب الحديث ٣/٩٣٢.أخرجه ابن جرير ١٨/٣٥٦، ٣٥٧، وابن أبي حاتم ٩/٣٠٣٣. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ٢/٦١٥.أخرجه أبو جعفر الرملي في جزئه ص١٠٠ (تفسير عطاء الخراساني). وعلقه ابن أبي حاتم ٩/٣٠٣٢ بنحوه.تفسير مقاتل بن سليمان ٣/٣٧٢.تفسير يحيى بن سلّام ٢/٦١٦.أخرجه ابن أبي حاتم ٩/٣٠٣٢. وهي قراءة شاذة، تروى أيضًا عن الكلبي. انظر: المحتسب ٢/١٥٩، ومختصر ابن خالويه ص١١٥.أخرجه أبو نعيم في الحلية ١/٣٢٦. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٩/٣٠٣٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٣٠٣٣.تفسير مقاتل بن سليمان ٣/٣٧٢.تفسير يحيى بن سلّام ٢/٦١٦.تفسير يحيى بن سلّام ٢/٦١٦.
29,4," <q>﴿أَمۡ حَسِبَ ٱلَّذِینَ یَعۡمَلُونَ ٱلسَّیِّـَٔاتِ أَن یَسۡبِقُونَاۚ سَاۤءَ مَا یَحۡكُمُونَ ۝٤﴾</q> - نزول الآية ٥٩٥٤٧- عن قتادة بن دعامة -من طريق شيبان- في قوله: <q>﴿أم حسب الذين يعملون﴾</q>، قال: اليهود{1}. (ز) ٥٩٥٤٨- قال مقاتل بن سليمان: في قوله سبحانه: <q>﴿أم حسب الذين يعملون السيئات﴾</q> ... نزلت في بني عبد شمس، <q>﴿أن يسبقونا﴾</q> يعني: أن يفوتونا بأعمالهم السيئة حتى يجزيهم بها في الدنيا، فقتلهم الله ﷿ ببدر، منهم شيبة وعتبة ابنا ربيعة، والوليد بن عتبة بن ربيعة، وحنظلة بن أبى سفيان بن حرب، وعبيدة بن سعد بن العاص بن أمية، وعقبة بن أبى معيط، والعاص بن وائل{2}. (ز) <q>﴿أَمۡ حَسِبَ ٱلَّذِینَ یَعۡمَلُونَ ٱلسَّیِّـَٔاتِ﴾</q> - تفسير ٥٩٥٤٩- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿أم حسب الذين يعملون السيئات﴾</q>، قال: الشِّرك{3}. (١١/٥٣٠) ٥٩٥٥٠- قال مقاتل بن سليمان: ثم وعظ كُفّار العرب، فقال سبحانه: <q>﴿أم حسب الذين يعملون السيئات﴾</q>، يعني: الشرك{2}. (ز) ٥٩٥٥١- قال يحيى بن سلّام: <q>﴿أم حسب الذين يعملون السيئات﴾</q>، والسيئات هاهنا: الشرك{5}٥٠٢١. (ز) ٥٠٢١ قال ابنُ عطية (٦/٦٢٥): «وقوله تعالى: <q>﴿الَّذِينَ يَعْمَلُونَ السَّيِّئاتِ﴾</q>، وإن كان الكفار المراد الأول بحسب النازلة التي الكلام فيها، فإن لفظ الآية يعمُّ كل عاص وعامل سيئة من المسلمين وغيرهم». <q>﴿أَن یَسۡبِقُونَاۚ﴾</q> - تفسير ٥٩٥٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله <q>﴿أن يسبقونا﴾</q>، قال: أن يُعجِزونا{6}. (١١/٥٣٠) ٥٩٥٥٣- قال مقاتل بن سليمان: <q>﴿أن يسبقونا﴾</q>، يعني: أن يفوتونا بأعمالهم السيئة حتى يجزيهم بها في الدنيا، فقتلهم الله ﷿ ببدر{2}. (ز) ٥٩٥٥٤- قال يحيى بن سلّام: <q>﴿أن يسبقونا﴾</q> حتى لا نقدر عليهم فنعذبهم، أي: قد حسبوا ذلك، وليس كما ظنوا{5}. (ز) <q>﴿سَاۤءَ مَا یَحۡكُمُونَ ۝٤﴾</q> - تفسير ٥٩٥٥٥- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿ساء ما يحكمون﴾</q>، يعني: ما يقضون، يعني: بني عبد شمس بن عبد مناف{2}. (ز) ٥٩٥٥٦- قال يحيى بن سلّام: <q>﴿ساء ما﴾</q> بئس ما <q>﴿يحكمون﴾</q> أن يظنُّوا أن الله خلقهم ثم لا يبعثهم فيجزيهم بأعمالهم{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٣٣.تفسير مقاتل بن سليمان ٣/٣٧٢.أخرجه ابن جرير ١٨/٣٦٠، وابن أبي حاتم ٩/٣٠٣٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٧٢.تفسير يحيى بن سلّام ٢/٦١٦.أخرجه ابن جرير ١٨/٣٦٠، وابن أبي حاتم ٩/٣٠٣٣، وإسحاق البستي في تفسيره ص٦٧ من طريق ابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، والفريابي.تفسير مقاتل بن سليمان ٣/٣٧٢.تفسير يحيى بن سلّام ٢/٦١٦.تفسير مقاتل بن سليمان ٣/٣٧٢.تفسير يحيى بن سلّام ٢/٦١٦.
29,5," <q>﴿مَن كَانَ یَرۡجُوا۟ لِقَاۤءَ ٱللَّهِ﴾</q> - نزول الآية ٥٩٥٥٧- قال مقاتل بن سليمان: نزلت <q>﴿من كان يرجو لقاء الله﴾</q> في بني هاشم وبني عبد المطلب ابني عبد مناف، منهم علي بن أبي طالب، وحمزة، وجعفر، وعبيدة بن الحارث، والحصين والطفيل ابنا الحارث بن المطلب، ومسطح بن أثاثة بن عباد بن المطلب، وزيد بن حارثة، وأبو هند، وأبو ليلى مولى النبي ﷺ، وأيمن ابن أم أيمن قتيل يوم حنين{1}. (ز) <q>﴿مَن كَانَ یَرۡجُوا۟ لِقَاۤءَ ٱللَّهِ﴾</q> - تفسير الآية ٥٩٥٥٨- عن سعيد بن جبير -من طريق عطاء بن دينار- <q>﴿من كان يرجو لقاء الله﴾</q>، قال: مَن كان يخشى البعث في الآخرة{2}. (١١/٥٣١) ٥٩٥٥٩- عن سعيد بن جبير -من طريق ربيع بن أبي راشد- في قوله: <q>﴿من كان يرجو لقاء الله﴾</q>، قال: ثوابَ ربِّه{2}. (ز) ٥٩٥٦٠- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿من كان يرجو لقاء الله﴾</q>، يقول: مَن كان يخشى{4}. (ز) ٥٩٥٦١- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿من كان يرجو لقاء الله﴾</q>، يقول: مَن خشي البعث في الآخرة فليعمل لذلك اليوم{1}. (ز) ٥٩٥٦٢- قال يحيى بن سلّام: <q>﴿من كان يرجو لقاء الله فإن أجل الله لآت﴾</q>، يقول: من كان يخشى البعث، وهو المؤمن{6}٥٠٢٢. (ز) ٥٠٢٢ ذكر ابنُ عطية (٦/٦٢٥) نحو قول يحيى عن أبي عبيدة، ثم علّق قائلًا: «وقال أبو عبيدة <q>﴿يَرْجُو﴾</q> هاهنا بمعنى: يخاف، والصحيح أن الرجاء هاهنا على بابه متمكنًا». <q>﴿فَإِنَّ أَجَلَ ٱللَّهِ لَـَٔاتࣲۚ﴾</q> - تفسير ٥٩٥٦٣- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿فإن أجل الله لآتٍ﴾</q>، يعني: يوم القيامة{1}. (ز) ٥٩٥٦٤- قال يحيى بن سلّام: <q>﴿فإن أجل الله لآت﴾</q> فإن القيامة آتية، يعني: البعث{6}. (ز) <q>﴿وَهُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٥﴾</q> - تفسير ٥٩٥٦٥- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿وهو السميع﴾</q> لقول بني عبد شمس بن عبد مناف حين قالوا: إنا نُعطى في الآخرة ما يُعطى المؤمنون. يعني بالمؤمنين: بني هاشم، وبني عبد المطلب بن عبد مناف، <q>﴿العليم﴾</q> به{1}. (ز) ٥٩٥٦٦- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿السميع﴾</q> أي: سميعٌ لما يقولون، <q>﴿العليم﴾</q> بما يخفون{2}. (ز) ٥٩٥٦٧- قال يحيى بن سلّام: <q>﴿وهو السميع العليم﴾</q> لا أسمع منه، ولا أعلم{6}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٧٣.أخرجه ابن أبي حاتم ٩/٣٠٣٤.أخرجه ابن أبي حاتم ٩/٣٠٣٤.علقه ابن أبي حاتم ٩/٣٠٣٣.تفسير مقاتل بن سليمان ٣/٣٧٣.تفسير يحيى بن سلّام ٢/٦١٧.تفسير مقاتل بن سليمان ٣/٣٧٣.تفسير يحيى بن سلّام ٢/٦١٧.تفسير مقاتل بن سليمان ٣/٣٧٣.أخرجه ابن أبي حاتم ٩/٣٠٣٤.تفسير يحيى بن سلّام ٢/٦١٧.
29,6," <q>﴿وَمَن جَـٰهَدَ فَإِنَّمَا یُجَـٰهِدُ لِنَفۡسِهِۦۤۚ﴾</q> - تفسير ٥٩٥٦٨- عن إسماعيل السُّدِّيّ: <q>﴿ومن جاهد﴾</q> يعني: ومَن عمل الخير <q>﴿فإنما يجاهد لنفسه﴾</q> فإنما يعمل لنفسه، إنما نفعُ ذلك له{1}. (ز) ٥٩٥٦٩- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿ومن جاهد فإنما يجاهد لنفسه﴾</q>، يقول: مَن يعمل الخير فإنما يعمل لنفسه، يقول: إنما أعمالهم لأنفسهم{2}. (ز) ٥٩٥٧٠- قال يحيى بن سلّام: يعطيه الله ثواب ذلك في الجنة{3}٥٠٢٣. (ز) ٥٠٢٣ قال ابنُ عطية (٦/٦٢٥-٦٢٦ بتصرف): «وقوله تعالى: <q>﴿ومَن جاهَدَ فَإنَّما يُجاهِدُ لِنَفْسِهِ﴾</q> إعلامٌ بأن كل واحد مجازًى بفعله فهو إذًا له، وهو حظُّه الذي ينبغي أن لا يفرط فيه، فإن الله غني عن جهاده، وغني عن العالمين بأَسْرِهم. وقيل: معنى الآية: ومن جاهد المؤمنين ودفع في صدر الدين فإنما جهاده لنفسه، لا لله، فالله غني. وهذا قول ذكره المفسرون، وهو ضعيف». <q>﴿إِنَّ ٱللَّهَ لَغَنِیٌّ عَنِ ٱلۡعَـٰلَمِینَ ۝٦﴾</q> - تفسير ٥٩٥٧١- عن مقاتل بن حيان -من طريق بُكَير- في قوله: <q>﴿إن الله لغنيٌ﴾</q> في سلطانه عما عندكم{4}. (ز) ٥٩٥٧٢- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿إن الله لغنيٌ عن العالمين﴾</q>، يعني: عن أعمال القبيلتين؛ بني هاشم، وبني عبد المطلب، ابْنَيْ عبد مناف{2}. (ز) ٥٩٥٧٣- عن يحيى بن سلّام، في قوله: <q>﴿إن الله لغنيٌ عن العالمين﴾</q>، قال: عن عبادتهم{3}. (ز) <q>﴿إِنَّ ٱللَّهَ لَغَنِیٌّ عَنِ ٱلۡعَـٰلَمِینَ ۝٦﴾</q> - آثار متعلقة بالآية ٥٩٥٧٤- عن الحسن البصري -من طريق أبي بشير- قال: إنّ العبد لَيُجاهِدُ في الله حق جهاده، وما ضرب بسيف{7}. (ز) ",footnotes:1:علقه يحيى بن سلّام ٢/٦١٧.تفسير مقاتل بن سليمان ٣/٣٧٣.تفسير يحيى بن سلّام ٢/٦١٧.أخرجه ابن أبي حاتم ٩/٣٠٣٥.تفسير مقاتل بن سليمان ٣/٣٧٣.تفسير يحيى بن سلّام ٢/٦١٧.أخرجه ابن أبي حاتم ٩/٣٠٣٤.
