tafsir[30]{c,v,t}:
87,16," <q>﴿بَلۡ تُؤۡثِرُونَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝١٦ وَٱلۡـَٔاخِرَةُ خَیۡرࣱ وَأَبۡقَىٰۤ ۝١٧﴾</q> - قراءات ٨٢٧٤١- عن عبد الله بن مسعود أنه كان يقرأ: (بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا عَلى الآخِرَةِ){1}. (١٥/٣٧٣) ٨٢٧٤٢- عن عرفجة الثقفي، قال: استقرأتُ عبد الله بن مسعود: <q>﴿سَبِّحِ اسْمَ رَبِّكَ الأَعْلى﴾</q> فلما بلغ: <q>﴿بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا﴾</q> ترك القراءة، وأقبل على أصحابه، فقال: آثرنا الدنيا على الآخرة. فسكتَ القوم، فقال: آثرنا الدنيا؛ لأنّا رأينا زينتها ونساءها، وطعامها وشرابها، وزُويتْ عنا الآخرة؛ فاخترنا هذا العاجل، وتركنا الآجل. وقال: ‹بَلْ يُؤْثِرُونَ الحَياةَ الدُّنْيا› بالياء{2}٧١٣٧. (١٥/٣٧٣) ٧١٣٧ اختلفت القرأة في قراءة قوله تعالى: <q>﴿بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا﴾</q> على قراءتين: الأولى: <q>﴿تُؤْثِرُونَ﴾</q> بالتاء وهي قراءة العشرة ما عدا أبا عمرو. الثانية: ‹بَلْ يُؤْثِرُونَ› بالياء، وهي قراءة أبي عمرو. انظر: النشر ٣/٤٠٠، والإتحاف ص٥٨٠. ورجَّح ابنُ جرير (٢٤/٣٢٣) القراءة الأولى مستندًا إلى إجماع الحجّة من القرأة عليها، ثم قال: «وذُكِر أنّ ذلك في قراءة أُبيٍّ: (بَلْ أنتُمْ تُؤْثِرُونَ)، فذلك أيضًا شاهدٌ لصحة القراءة بالتاء». ووجَّه ابنُ كثير (١٤/٣٢٧) قول ابن مسعود: «آثرنا الدنيا على الآخرة ...» بقوله: «وهذا منه على وجه التواضع والهضم، أو هو إخبار عن الجنس مِن حيث هو». <q>﴿بَلۡ تُؤۡثِرُونَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝١٦ وَٱلۡـَٔاخِرَةُ خَیۡرࣱ وَأَبۡقَىٰۤ ۝١٧﴾</q> - تفسير الآية ٨٢٧٤٣- عن عكرمة مولى ابن عباس، <q>﴿بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا﴾</q>، قال: يعني: هذه الأُمّة، وإنكم ستؤثرون الحياة الدنيا{3}. (١٥/٣٧٤) ٨٢٧٤٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا﴾</q> قال: اختار الناس العاجلة إلا مَن عصم الله، <q>﴿والآخِرَةُ خَيْرٌ﴾</q> في الخير، <q>﴿وأَبْقى﴾</q> في البقاء{4}. (١٥/٣٧٤) ٨٢٧٤٥- قال مقاتل بن سليمان: <q>﴿بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا﴾</q> يقول: بل تختارون الحياة الدنيا، <q>﴿والآخِرَةُ خَيْرٌ وأَبْقى﴾</q>{5}. (ز) <q>﴿بَلۡ تُؤۡثِرُونَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝١٦ وَٱلۡـَٔاخِرَةُ خَیۡرࣱ وَأَبۡقَىٰۤ ۝١٧﴾</q> - آثار متعلقة بالآية ٨٢٧٤٦- عن أنس، قال: قال رسول الله ﷺ: «لا إله إلا الله تمنع العباد مِن سخط الله، ما لم يُؤثروا صفقة دنياهم على دينهم، فإذا آثروا صفقة دنياهم على دينهم ثم قالوا: لا إله إلا الله. رُدّت عليهم، وقال الله: كذبتم»{6}. (١٥/٣٧٤) ٨٢٧٤٧- عن ابن عمر، أنّ رسول الله ﷺ قال: «لا يلقى اللهَ أحدٌ بشهادة أن لا إله إلا الله، وحده لا شريك له، إلا دخل الجنة، ما لم يخلط معها غيرها». ردَّدها ثلاثًا، قال قائل من قاصية الناس: بأبي أنت وأمي يا رسول الله، وما يخلط معها غيرها؟ قال: «حُبّ الدنيا، وأَثرة لها، وجمعًا لها، ورِضًا بها، وعمل الجبّارين»{7}. (١٥/٣٧٤-٣٧٥) ٨٢٧٤٨- عن أبي موسى الأشعري، أنّ رسول الله ﷺ قال: «مَن أحبَّ دنياه أضرّ بآخرته، ومَن أحبَّ آخرته أضرّ بدنياه، فآثِروا ما يبقى على ما يفنى»{8}. (١٥/٣٧٥) ٨٢٧٤٩- عن عائشة، قالت: قال رسول الله ﷺ: «الدنيا دار مَن لا دار له، ومال مَن لا مال له، ولها يجمع مَن لا عقل له»{9}. (١٥/٣٧٥) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة.أخرجه ابن جرير ٢٤/٣٢٢، والطبراني (٩١٤٧)، والبيهقي في شعب الإيمان (١٠٦٤٥). وعزاه السيوطي إلى ابن المنذر. قال الهيثمي في مجمع الزوائد ١٠/٢٣٦: «فيه عطاء بن السّائِب، وقد اختلط، وبقية رجاله ثقات».عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٢٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٠.أخرجه أبو يعلى في مسنده ٧/٩٥ (٤٠٣٤)، والبيهقي في الشعب ١٣/١٠٠-١٠١ (١٠٠١٥، ١٠٠١٦) واللفظ له. قال ابن القيسراني في ذخيرة الحفاظ ٥/٢٥٩٠-٢٥٩١ (٦٠١٧): «رواه عمر بن حمزة بن عبد الله بن عمر، عن نافع بن مالك أبي سهيل عن أنس، وعمر هذا ضعيف». وقال الهيثمي في المجمع ٧/٢٧٧ (١٢١٨٨): «رواه البزار، وإسناده حسن». وقال البوصيري في إتحاف الخيرة المهرة ٧/٤٣٣ (٧٢٦٢): «رواه أبو يعلى الموصلي بسند ضعيف؛ لضعف عمر بن حمزة».أخرجه البيهقي في الشعب ١٣/١٠١ (١٠٠١٧)، من طريق علي بن عياش، ثنا سعيد بن سنان، حدثني أبو الزّاهرية، عن أبي شجرة، عن عبد الله بن عمر به. إسناده ضعيف جدًّا؛ فيه سعيد بن سنان الحنفي أو الكندي أبو مهدي الحمصي، قال عنه ابن حجر في التقريب (٢٣٣٣): «متروك، ورماه الدارقطني وغيره بالوضع».أخرجه أحمد ٣٢/٤٧٠، ٤٧٢ (١٩٦٩٧، ١٩٦٩٨)، وابن حبان ٢/٤٨٦ (٧٠٩)، والحاكم ٤/٣٤٣ (٧٨٥٣)، ٤/٣٥٤ (٧٨٩٧). قال الحاكم في الموضع الأول: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «فيه انقطاع». وقال الحاكم في الموضع الثاني: «هذا حديث صحيح». وقال المنذري في الترغيب والترهيب ٤/٨٤-٨٥ (٤٩٠٣): «رواه أحمد، ورواته ثقات، والبزار، وابن حبان في صحيحه، والحاكم، والبيهقي في الزهد، وغيره كلهم من رواية المطلب بن عبد الله بن حنطب، عن أبي موسى ... المطلب لم يسمع من أبي موسى». وقال الهيثمي في المجمع ١٠/٢٤٩ (١٧٨٢٥): «رواه أحمد، والبزار، والطبراني، ورجالهم ثقات». وقال الألباني في الضعيفة ١٢/٣٣٧ (٥٦٥٠): «ضعيف».أخرجه أحمد ٤٠/٤٨٠ (٢٤٤١٩). قال السخاوي في المقاصد الحسنة ص٣٥٠ (٤٩٤)، والعجلوني في كشف الخفاء ١/٤٦٩ (١٣١٥): «رجاله ثقات». وقال المناوي في التيسير ٢/١٣: «أسانيد صحيحة». وقال في فيض القدير ٣/٥٤٦ (٤٢٧٤): «قال المنذري في الترغيب والترهيب ٤/٨٦ (٤٩١٢)، والحافظ العراقي في تخريج أحاديث الإحياء ص١١٠٣: إسناده جيد». وقال الهيثمي مجمع الزوائد ١٠/٢٨٨ (١٨٠٧٨): «رجال أحمد رجال الصحيح، غير دويد وهو ثقة». وقال الألباني في الضعيفة ٤/٤٠٥ (١٩٣٣): «ضعيف».
  87,17,""
87,18," <q>﴿إِنَّ هَـٰذَا لَفِی ٱلصُّحُفِ ٱلۡأُولَىٰ ۝١٨ صُحُفِ إِبۡرَ ٰ⁠هِیمَ وَمُوسَىٰ ۝١٩﴾</q> - تفسير ٨٢٧٥٠- عن عبد الله بن عباس، قال: لما نزلت: <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى صُحُفِ إبْراهِيمَ ومُوسى﴾</q>، قال: رسول الله ﷺ: «هي كلّها في صحف إبراهيم وموسى»{1}. (١٥/٣٧٦) ٨٢٧٥١- عن أبي ذرّ، قال: قلتُ: يا رسول الله، كم أنزل الله من كتاب؟ قال: «مائة كتاب وأربعة كتب، أنزل على شِيث خمسين صحيفة، وعلى إدريس ثلاثين صحيفة، وعلى إبراهيم عشر صحائف، وعلى موسى قبل التوراة عشر صحائف، وأنزل التوراة، والإنجيل، والزّبور، والفرقان». قلتُ: يا رسول الله، فما كانت صحف إبراهيم؟ قال: «أمثال كلّها؛ أيّها الملك المُتسلّط المُبْتلى المغرور، لم أبعثك لتجمع الدنيا بعضها على بعض، ولكن بعثتُك لتردّ عني دعوة المظلوم، فإني لا أردّها ولو كانت مِن كافر، وعلى العاقل ما لم يكن مغلوبًا على عقله أن يكون له ثلاث ساعات: ساعة يناجي فيها ربّه، وساعة يحاسب فيها نفسه ويتفكّر فيما صنع، وساعة يخلو فيها لحاجته من الحلال؛ فإنّ في هذه الساعة عونًا لتلك الساعات، واستجمامًا{2} للقلوب وتفريغًا لها، وعلى العاقل أنْ يكون بصيرًا بزمانه، مُقبلًا على شأنه، حافظًا للسانه، فإنّ مَن حسب كلامه من عمله أقلَّ الكلام إلا فيما يعنيه، وعلى العاقل أنْ يكون طالبًا لثلاث؛ مَرَمَّة{3} لمعاش، أو تزوُّدٌ لمعاد، أو تلذُّذٌ في غير مُحرّم». قلتُ: يا رسول الله، فما كانت صحف موسى؟ قال: «كانت عِبرًا كلها؛ عجبتُ لمن أيقن بالموت ثم يفرح، ولمن أيقن بالنار ثم يضحك، ولمن يرى الدنيا وتقلبها بأهلها ثم يطمئن إليها، ولمن أيقن بالقَدَر ثم يَنصَب، ولمن أيقن بالحساب ثم لا يعمل». قلت: يا رسول الله، هل أنزل الله عليك شيئًا مما كان في صحف إبراهيم وموسى؟ قال: «يا أبا ذرّ، نعم: <q>﴿قَدْ أفْلَحَ مَن تَزَكّى وذَكَرَ اسْمَ رَبِّهِ فَصَلّى بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا والآخِرَةُ خَيْرٌ وأَبْقى إنَّ هَذا لَفِي الصُّحُفِ الأُولى صُحُفِ إبْراهِيمَ ومُوسى﴾</q>»{4}. (١٥/٣٧٨) ٨٢٧٥٢- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q> الآية، قال: نُسخت هذه السورة مِن صحف إبراهيم وموسى. ولفظ سعيد: هذه السورة في صحف إبراهيم وموسى. ولفظ ابن مردويه: وهذه السورة وقوله: <q>﴿وإبْراهِيمَ الَّذِي وفّى﴾</q> [النجم:٣٧] إلى آخر السورة من صحف إبراهيم وموسى{5}. (١٥/٣٧٦) ٨٢٧٥٣- عن أبي العالية الرِّياحيّ -من طريق الربيع- <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q>، يقول: قصة هذه السورة في الصحف الأولى{6}. (١٥/٣٧٧) ٨٢٧٥٤- عن عكرمة مولى ابن عباس -من طريق سفيان، عن أبيه- <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q> قال: هؤلاء الآيات{7}. (١٥/٣٧٧) ٨٢٧٥٥- عن الحسن البصري، <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q>، قال: في كتب الله كلّها{8}. (١٥/٣٧٧) ٨٢٧٥٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q>، قال: ما قصَّ الله في هذه السورة{9}. (١٥/٣٧٧) ٨٢٧٥٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q>، قال: تتابعتْ كتبُ الله -كما تسمعون- أنّ الآخرة خير وأبقى{10}. (١٥/٣٧٧) ٨٢٧٥٨- عن إسماعيل السُّدِّيّ، قال: إنّ هذه السورة في صحف إبراهيم وموسى مثل ما أُنزِلَتْ على النبي ﷺ{8}. (١٥/٣٧٦) ٨٢٧٥٩- قال مقاتل بن سليمان: <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q> الكتب الأولى؛ <q>﴿صُحُفِ إبْراهِيمَ﴾</q> كتب إبراهيم، <q>﴿و﴾</q>كتاب <q>﴿مُوسى﴾</q> وهي التوراة، فأمّا صحف إبراهيم فقد رُفعتْ{12}. (ز) ٨٢٧٦٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿إنَّ هَذا لَفِي الصُّحُفِ الأُولى﴾</q> الآية، قال: في الصحف الأولى أنّ الآخرة خير من الدنيا{13}٧١٣٨. (١٥/٣٧٧) ٧١٣٨ اختُلف في المشار إليه بـ<q>﴿هذا﴾</q> في هذه الآية على أقوال: الأول: أُشير به إلى الآيات التي في <q>﴿سَبِّحِ اسْمَ رَبِّكَ الأَعْلى﴾</q>. الثاني: إلى قصة هذه السورة. الثالث: إنّ هذا الذي قضى الله في هذه السورة لفي الصُّحف الأولى. الرابع: أن قوله: <q>﴿والآخِرَةُ خَيْرٌ وأَبْقى﴾</q> في الصُّحف الأولى. ورجَّح ابنُ جرير (٢٤/٣٢٥) -مستندًا إلى الأظهر لغة- أنّ «قوله: <q>﴿قَدْ أفْلَحَ مَن تَزَكّى وذَكَرَ اسْمَ رَبِّهِ فَصَلّى بَلْ تُؤْثِرُونَ الحَياةَ الدُّنْيا والآخِرَةُ خَيْرٌ وأَبْقى﴾</q>، لفي الصحف الأولى، صحف إبراهيم خليل الرحمن، وصحف موسى بن عمران». وعلَّل ذلك بقوله: «لأنّ <q>﴿هذا﴾</q> إشارةٌ إلى حاضرٍ، فلأَن يكون إشارة إلى ما قَرُب منها أولى من أن يكون إشارة إلى غيره». ونحوه قال ابنُ عطية (٨/٥٩٤). وكذا ابنُ كثير (١٤/٣٢٨) فقال: «وهذا اختيار حسن قوي». ",footnotes:1:أخرجه الحاكم ٢/٢٥٨ (٢٩٣٠) مطولًا. وقال البزار -كما في كشف الأستار ٣/٨٠ (٢٢٨٥)-: «لا نعلم الثقات عن عطاء، عن عكرمة، عن ابن عباس، إلا هذا الحديث وحديثًا آخر». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ٧/١٣٧ (١١٤٨٩): «رواه البزار، وفيه عطاء بن السّائِب وقد اختلط، وبقية رجاله رجال الصحيح».الجمام: الراحة، وتجم الفؤاد: أي تريحه، وقيل: تجمعه وتكمل صلاحه ونشاطه. اللسان (جمم).المرمة: متاع البيت. اللسان (رمم).أخرجه الشجري في ترتيب الأمالي الخميسية ١/٢٦٨-٢٧٠ (٩١٥)، وابن عساكر في تاريخ دمشق ٢٣/٢٧٦-٢٧٩ مطولًا، وأخرجه ابن حبان ٢/٧٦-٧٩ (٣٦١) دون ذكر الآية. قال الزيلعي في تخريج أحاديث الكشاف ٢/٣٩١: «معان وعلي بن يزيد والقاسم؛ ثلاثتهم ضعفاء، وقد خالف ابن حبان في هذا الحديث أبو الفرج بن الجوزي، فأورده في كتابه الموضوعات، واتهم به إبراهيم بن هشام، ولا شكّ أنه تَكلّم فيه أئمة الجرح والتعديل مِن أجل هذا الحديث».أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٧٢٣-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٤/٣٢٣-٣٢٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٢٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٧، وابن جرير ٢٤/٣٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٣٢٤. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٠.أخرجه ابن جرير ٢٤/٣٢٤-٣٢٥ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.
  87,19,""
88,1," مقدمة السورة ٨٢٧٦١- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الغاشية بمكة{1}. (١٥/٣٨٠) ٨٢٧٦٢- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٣٨٠) ٨٢٧٦٣- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمُسمّى: <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q>، وأنها نزلت بعد سورة الذاريات{3}. (ز) ٨٢٧٦٤- عن عكرمة مولى ابن عباس= (ز) ٨٢٧٦٥- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز) ٨٢٧٦٦- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٨٢٧٦٧- عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد <q>﴿والذّارِيات﴾</q>{6}. (ز) ٨٢٧٦٨- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٨٢٧٦٩- قال مقاتل بن سليمان: سورة الغاشية مكّيّة، عددها ست وعشرون آية{8}. (ز) <q>﴿هَلۡ أَتَىٰكَ حَدِیثُ ٱلۡغَـٰشِیَةِ ۝١﴾</q> - تفسير ٨٢٧٧٠- عن عمرو بن ميمون، قال: مَرَّ النبيُّ ﷺ على امرأة تقرأ: <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q>، فقام يستمع، ويقول: «نعم، قد جاءني»{9}. (١٥/٣٨٠) ٨٢٧٧١- عن عبد الله بن عباس -من طريق علي- قال: الغاشية مِن أسماء يوم القيامة، عظّمه الله، وحذّره عباده{10}. (١٥/٣٨٠) ٨٢٧٧٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q>، قال: الساعة{11}. (١٥/٣٨١) ٨٢٧٧٣- عن سعيد بن جُبَير -من طريق أشعث- قال: الغاشية: غاشية النار{12}. (١٥/٣٨١) ٨٢٧٧٤- عن الضَّحّاك بن مُزاحِم، قال: الغاشية: القيامة{13}. (١٥/٣٨١) ٨٢٧٧٥- قال الحسن البصري: <q>﴿الغاشِيَةِ﴾</q> يعني: القيامة، تغشى الناسَ بعذابها وعقابها{14}. (ز) ٨٢٧٧٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q>، قال: حديث الساعة{15}. (١٥/٣٨١) ٨٢٧٧٧- قال مقاتل بن سليمان: <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q> يعني: قد أتاك حديث أهل النار، وكلّ شيء في القرآن <q>﴿هَلْ أتاكَ﴾</q>: قد أتاك{16}٧١٣٩. (ز) ٧١٣٩ اختُلف في معنى: <q>﴿الغاشية﴾</q> في هذه الآية على قولين: الأول: أنها القيامة تغشى الناس بالأهوال. الثاني: أنها النار تغشى وجوه الكفرة. وعلَّق ابنُ عطية (٨/٥٩٦) على القول الأول بقوله: «يؤيده قوله تعالى: <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</q>، والوجوه الخاشعة هي وجوه الكفار، وخشوعها: ذُلُّها وتغيُّرُها بالعذاب». وعلَّق على القول الثاني بقوله: «وقد قال تعالى: <q>﴿وتَغْشى وُجُوهَهُمُ النّارُ﴾</q> [إبراهيم:٥٠]، وقال: <q>﴿ومِن فَوْقِهِمْ غَواشٍ﴾</q> [الأعراف:٤١]، فهي تغشى سكانها». ورجَّح ابنُ جرير (٢٤/٣٢٧) العموم، فقال: «إن الله قال لنبيّه: <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q>، ولم يُخْبِرنا أنه عَنى غاشية القيامة، ولا أنه عَنى غاشية النار، وكلتاهما غاشيةٌ، هذه تغشى الناس بالبلابل والأهوال والكروب، وهذه تغشى الكفار باللفْح في الوجوه والشُّواظ والنُّحاس، فلا قول أصحُّ في ذلك مِن أن يقال كما قال -جلَّ ثناؤه-، ويُعَمَّ الخبرُ بذلك كما عمَّه». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٦٧٥.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٠٦- مرسلًا.أخرجه ابن جرير ٢٤/٣٢٦، وابن أبي حاتم مختصرًا -كما في الإتقان ٢/٥٥، وفتح الباري ٨/٧٠٠-.أخرجه ابن جرير ٢٤/٣٢٦.أخرجه ابن جرير ٢٤/٣٢٧. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٣-.أخرجه ابن جرير ٢٤/٣٢٦. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٧.
88,2," <q>﴿وُجُوهࣱ یَوۡمَىِٕذٍ خَـٰشِعَةٌ ۝٢﴾</q> - تفسير ٨٢٧٧٨- عن سعيد بن جُبَير، <q>﴿وُجُوهٌ يَوْمَئِذٍ﴾</q>، قال: يعني: في الآخرة{1}. (١٥/٣٨٢) ٨٢٧٧٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</q>، قال: خاشعة في النار{2}. (ز) ٨٢٧٨٠- عن قتادة بن دعامة، <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</q>، قال: ذليلة في النار{3}. (١٥/٣٨١) ٨٢٧٨١- قال مقاتل بن سليمان: <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾</q>، يعني: ذليلة{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨، وابن جرير ٢٤/٣٢٨.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم. وعند ابن جرير ٢٤/٣٢٨ من طريق سعيد بلفظ: ذليلة.تفسير مقاتل بن سليمان ٤/٦٧٧.
88,3," <q>﴿عَامِلَةࣱ نَّاصِبَةࣱ ۝٣﴾</q> - تفسير ٨٢٧٨٢- عن أبي عمران الجَونيّ، قال: مَرَّ عمر بن الخطاب براهبٍ، فوقف، ونودي الراهب، فقيل له: هذا أمير المؤمنين. فاطّلع، فإذا إنسان به مِن الضر والاجتهاد وتَرْك الدنيا، فلمّا رآه عمر بكى، فقيل له: إنه نصراني! فقال عمر: قد علمتُ، ولكني رحِمتُه؛ ذكرتُ قول الله: <q>﴿عامِلَةٌ ناصِبَةٌ تَصْلى نارًا حامِيَةً﴾</q>، فرحمتُ نَصَبه واجتهاده، وهو في النار{1}. (١٥/٣٨٢) ٨٢٧٨٣- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</q>، قال: يعني: اليهود والنصارى، تخشع ولا ينفعها عملُها{2}. (١٥/٣٨٢) ٨٢٧٨٤- عن عبد الله بن عباس -من طريق علي- <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: النصارى{3}. (ز) ٨٢٧٨٥- عن عبد الله بن عباس -من طريق أبي الضحى- <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: الرُّهبان{4}. (ز) ٨٢٧٨٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</q>، قال: تعمل وتَنصَب في النار{5}٧١٤٠. (١٥/٣٨١) ٧١٤٠ لم يذكر ابنُ جرير (٢٤/٣٢٨) في معنى: <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q> سوى قول ابن عباس من طريق العَوفيّ، وقول الحسن، وقتادة، وابن زيد. ٨٢٧٨٧- قال سعيد بن جُبَير= (ز) ٨٢٧٨٨- وزيد بن أسلم: <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</q> هم الرُّهبان، وأصحاب الصوامع{6}. (ز) ٨٢٧٨٩- قال الضَّحّاك بن مُزاحِم: <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</q> يُكلّفون ارتقاء جبل مِن حديد في النار{7}. (ز) ٨٢٧٩٠- عن عكرمة مولى ابن عباس، في قوله: <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: عاملة في الدنيا بالمعاصي، تَنصَب في النار يوم القيامة{8}٧١٤١. (١٥/٣٨٢) ٧١٤١ اختُلف في معنى: <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q> على أقوال: الأول: عاملة في النار ناصبة فيها. الثاني: عاملة في الدنيا ناصبة فيها، والآية في القِسِّيسين، وعباد الأوثان، وكلّ مَن اجتهد في كُفر. الثالث: عاملة في الدنيا ناصبة يوم القيامة. ووجَّه ابنُ عطية (٨/٥٩٦) القول الثالث بقوله: «فالعمل -على هذا- هو مساعي الدنيا». ورجَّح ابنُ تيمية (٧/٥) -مستندًا إلى اللغة، والدلالة العقلية، والنظائر- القول الأول، فقال: «هذا هو الحق لوجوه: أحدها: أنه على هذا التقدير يتعلق الظرف بما يليه، أي: وجوه يوم الغاشية خاشعة عاملة ناصبة صالية، وعلى الأولى لا يتعلق إلا بقوله: <q>﴿تصلى﴾</q>، ويكون قوله: <q>﴿خاشعة﴾</q> صفة للوجوه، قد فصل بين الصفة والموصوف بأجنبي متعلّق بصفة أخرى متأخرة، والتقدير: وجوه خاشعة عاملة ناصبة يومئذٍ تصلى نارًا حامية، والتقديم والتأخير على خلاف الأصل؛ فالأصل إقرار الكلام على نظْمه وترتيبه لا تغيير ترتيبه، ثم إنما يجوز فيه التقديم والتأخير مع القرينة، أما مع اللبس فلا يجوز؛ لأنه يلتبس على المخاطب، ومعلوم أنه ليس هنا قرينة تدل على التقديم والتأخير، بل القرينة تدل على خلاف ذلك، فإرادة التقديم والتأخير بمثل هذا الخطاب خلاف البيان، وأمْر المخاطب بفهمه تكليف لما لا يطاق. الوجه الثاني: أنّ الله قد ذكر وجوه الأشقياء ووجوه السعداء في السورة، فقال بعد ذلك: <q>﴿وُجُوهٌ يَوْمَئِذٍ ناعِمَةٌ لِسَعْيِها راضِيَةٌ فِي جَنَّةٍ عالِيَةٍ﴾</q>، ومعلوم أنه إنما وصفها بالنعمة يوم القيامة لا في الدنيا؛ إذ هذا ليس بمدح، فالواجب تشابه الكلام وتناظر القسمين، لا اختلافهما، وحينئذ فيكون الأشقياء وُصفتْ وجوههم بحالها في الآخرة. الثالث: أنّ نظير هذا التقسيم قوله: <q>﴿وُجُوهٌ يَوْمَئِذٍ ناضِرَةٌ إلى رَبِّها ناظِرَةٌ ووُجُوهٌ يَوْمَئِذٍ باسِرَةٌ تَظُنُّ أنْ يُفْعَلَ بِها فاقِرَةٌ﴾</q> [القيامة:٢٢-٢٥]، وقوله: <q>﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ ضاحِكَةٌ مُسْتَبْشِرَةٌ ووُجُوهٌ يَوْمَئِذٍ عَلَيْها غَبَرَةٌ تَرْهَقُها قَتَرَةٌ أُولَئِكَ هُمُ الكَفَرَةُ الفَجَرَةُ﴾</q> [عبس:٣٨-٤٢]، وهذا كله وصفٌ للوجوه لحالها في الآخرة لا في الدنيا. الرابع: أنّ وصف الوجوه بالأعمال ليس في القرآن، وإنما في القرآن ذِكْر العلامة، كقوله: <q>﴿سِيمِاهُمْ فِي وُجُوهِهِمْ﴾</q> [الفتح:٢٩]، وقوله: <q>﴿ولَوْ نَشاءُ لأَرَيْناكَهُمْ فَلَعَرَفْتَهُمْ بِسِيماهُمْ﴾</q> [محمد:٣٠]، وقوله: <q>﴿وإذا تُتْلى عَلَيْهِمْ آياتُنا بَيِّناتٍ تَعْرِفُ فِي وُجُوهِ الَّذِينَ كَفَرُوا المُنْكَرَ يَكادُونَ يَسْطُونَ بِالَّذِينَ يَتْلُونَ عَلَيْهِمْ آياتِنا﴾</q> [الحج:٧٢]، وذلك لأنّ العمل والنَّصَب ليس قائمًا بالوجوه فقط؛ بخلاف السيما والعلامة. الخامس: أنّ قوله: <q>﴿خاشِعَةً عامِلَةٌ ناصِبَةٌ﴾</q> لو جُعل صفة لهم في الدنيا لم يكن في هذا اللفظ ذم، فإنّ هذا إلى المدح أقرب، وغايته أنه وصفٌ مشترك بين عُبّاد المؤمنين وعُبّاد الكفار، والذم لا يكون بالوصف المشترك، ولو أُريد المختص لقيل: خاشعة للأوثان -مثلًا-، عاملة لغير الله، ناصبة في طاعة الشيطان. وليس في الكلام ما يقتضي كون هذا الوصف مختصًّا بالكفار، ولا كونه مذمومًا، وليس في القرآن ذمٌّ لهذا الوصف مطلقًا، ولا وعيد عليه، فحمْله على هذا المعنى خروج عن الخطاب المعروف في القرآن. السادس: أنّ هذا الوصف مختص ببعض الكفار، ولا موجب للتخصيص، فإنّ الذين لا يتعبّدون من الكفار أكثر، وعقوبة فُسّاقهم في دينهم أشد في الدنيا والآخرة، فإنّ مَن كفَّ منهم عن المحرمات المتفق عليها، وأدّى الواجبات المتفق عليها لم تكن عقوبته كعقوبة الذين يدعون مع الله إلهًا آخر، ويقتلون النفس التي حرّم الله إلا بالحق ويَزْنُون. فإذا كان الكفر والعذاب على هذا التقدير في القسم المتروك أكثر وأكبر؛ كان هذا التخصيص عكس الواجب. السابع: أنّ هذا الخطاب فيه تنفير عن العبادة والنُّسك ابتداء، ثم إذا قُيِّد ذلك بعبادة الكفار والمبتدعة -وليس في الخطاب تقييد- كان هذا سعيًا في إصلاح الخطاب بما لم يُذكر فيه». ٨٢٧٩١- عن الحسن البصري -من طريق أبي رجاء- أنه قرأ: <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: لم تعمل لله في الدنيا، فأعْملها في النار{9}. (ز) ٨٢٧٩٢- عن الحسن البصري -من طريق يونس- في قوله تعالى: <q>﴿وجوه يومئذ خاشعة عاملة ناصبة﴾</q>، قال: لم تخشع لله في الدنيا فأخْشعها وأنصبها في النار، فذلك عمَلها{10}. (ز) ٨٢٧٩٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: تكبّرتْ في الدنيا عن طاعة الله، فأعْملها وأنصبها في النار{11}. (١٥/٣٨١) ٨٢٧٩٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: عاملة ناصبة في النار{12}. (ز) ٨٢٧٩٥- قال محمد بن السّائِب الكلبي: <q>﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾</q> يُجَرُّون على وجوههم في النار{13}. (ز) ٨٢٧٩٦- قال مقاتل بن سليمان: <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q> يعني: عاملة في النار، النار تأكله ويأكل مِن النار، يعني: ناصبة للعذاب صاغِرة{14}. (ز) ٨٢٧٩٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿عامِلَةٌ ناصِبَةٌ﴾</q>، قال: لا أحد أنصب ولا أشدّ مِن أهل النار{15}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٦٨، والحاكم ٢/٥٢١-٥٢٢. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم. وعزاه الحافظ في الفتح ٨/٧٠٠ إليه من طريق عكرمة دون ذكر آخره.علقه البخاري في صحيحه ٦/١٦٨. وذكر الحافظ ابن حجر في الفتح ٨/٧٠٠ أنّ ابن أبي حاتم وصله من طريق علي بن أبي طلحة.أخرجه الثعلبي -كما في الفتح ٨/٧٠٠-.أخرجه ابن جرير ٢٤/٣٢٨.تفسير الثعلبي ١٠/١٨٨.تفسير الثعلبي ١٠/١٨٧، وتفسير البغوي ٨/٤٠٨.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٢٨، وابن أبي الدنيا في صفة النار ٦/٤٢٧-٤٢٨ (١٢٩) من طريق يونس.أخرجه أبو الشيخ في طبقات المحدثين بأصبهان ٢/٢٠٤.أخرجه ابن جرير ٢٤/٣٢٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٩، وابن جرير ٢٤/٣٢٨.تفسير الثعلبي ١٠/١٨٧، وتفسير البغوي ٨/٤٠٤.تفسير مقاتل بن سليمان ٤/٦٧٧.أخرجه ابن جرير ٢٤/٣٢٩.
88,4," <q>﴿تَصۡلَىٰ نَارًا حَامِیَةࣰ ۝٤﴾</q> - تفسير ٨٢٧٩٨- قال عبد الله بن مسعود: <q>﴿تَصْلى نارًا حامِيَةً﴾</q> تخوض في النار كما تخوض الإبل في الوَحْل{1}. (ز) ٨٢٧٩٩- عن عبد الله بن عباس، في قوله: <q>﴿تَصْلى نارًا حامِيَةً﴾</q>، قال: حارّة{2}. (١٥/٣٨٢) ",footnotes:1:تفسير الثعلبي ١٠/١٨٨، وتفسير البغوي ٨/٤٠٤.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.
88,5," <q>﴿تُسۡقَىٰ مِنۡ عَیۡنٍ ءَانِیَةࣲ ۝٥﴾</q> - تفسير ٨٢٨٠٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: هي التي قد طال أنْيُها{1}. (١٥/٣٨١) ٨٢٨٠١- عن عبد الله بن عباس، <q>﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: قد أنى غليانها{2}. (١٥/٣٨٢) ٨٢٨٠٢- عن عبد الله بن عباس، <q>﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: انتهى حرُّها{3}. (١٥/٣٨٢) ٨٢٨٠٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: قد بلغتْ إناها، وحان شُربها{4}. (١٥/٣٨٣) ٨٢٨٠٤- عن الحسن البصري -من طريق معمر- <q>﴿مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: قد أنى حرّها{5}. (١٥/٣٨٣) ٨٢٨٠٥- عن الحسن البصري -من طريق أبي رجاء- <q>﴿مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: قد آن طبخُها منذ خلق الله السماوات والأرض{6}. (١٥/٣٨٣) ٨٢٨٠٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: أنى طبخها منذ خلق الله السماوات والأرض{7}. (١٥/٣٨١) ٨٢٨٠٧- عن إسماعيل السُّدِّيّ، <q>﴿مِن عَيْنٍ آنِيَةٍ﴾</q>، قال: انتهى حرُّها، فليس فوقه حرّ{2}. (١٥/٣٨٣) ٨٢٨٠٨- قال مقاتل بن سليمان: <q>﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾</q> مِن عينٍ قد انتهى حرُّها، وذلك أنّ جهنم تُسَعَّر عليهم منذ يوم خُلقتْ إلى يوم يدخلونها، وهي عينٌ تخرج مِن أصل جبل طولها مسيرة سبعين عامًا، ماؤها أسود كدرديّ الزيت، كدرٌ غليظ، كثير الدعاميص{9}، تسقيه الملائكة بإناء مِن حديد مِن نار، فيشربه، فإذا قرّب الإناء مِن فِيه أحرق شدقيه، وتناثرتْ أنيابُه وأضراسُه، فإذا بلغ صدره نضج قلبه، فإذا بلغ بطنه غلى كما يغلي الحميم مِن شدة الحرّ حتى يذوب كما يذوب الرصاص إذا أصابه النار، فيدعو الشقيُّ بالويل{10}. (ز) ٨٢٨٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿آنِيَةٍ﴾</q>، قال: حاضرة{11}٧١٤٢. (١٥/٣٨٣) ٧١٤٢ علَّق ابنُ عطية (٨/٥٩٧) على قول ابن زيد بقوله: «من قولهم: أنى الشيءُ: إذا حضر». ",footnotes:1:أخرجه ابن جرير ٢٤/٣٢٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٥٠٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٥، وفتح الباري ٨/٧٠٠-، وهناد (٢٦٥)، وابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨، وابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٢٤- من طريق المبارك، وابن جرير ٢٤/٣٢٩-٣٣٠، وابن أبي الدنيا في صفة النار ٦/٤٢٧-٤٢٨ (١٢٩) من طريق يونس. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.الدعاميص: جمع دعموص، وهي دويبة تكون في مستنقع الماء. النهاية (دعمص).تفسير مقاتل بن سليمان ٤/٦٧٧-٦٧٨.أخرجه ابن جرير ٢٤/٣٣٠. وعزاه السيوطي إلى ابن أبي حاتم.
88,6," <q>﴿لَّیۡسَ لَهُمۡ طَعَامٌ إِلَّا مِن ضَرِیعࣲ ۝٦ لَّا یُسۡمِنُ وَلَا یُغۡنِی مِن جُوعࣲ ۝٧﴾</q> - تفسير ٨٢٨١٠- عن أبي الدّرداء، قال: قال رسول الله ﷺ: «يُلقى على أهل النار الجوعُ، حتى يعدل ما هم فيه مِن العذاب، فيستغيثون بالطعام، فيُغاثون بطعام مِن ضريع، لا يُسمن ولا يُغني مِن جوع»{1}. (١٥/٣٨٤) ٨٢٨١١- عن عبد الله بن عباس، <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: قال رسول الله ﷺ: «شيء يكون في النار شبه الشوك، أمرّ مِن الصبر، وأنتن مِن الجِيفة، وأشدّ حرًّا مِن النار، سمّاه الله: الضريع، إذا طعمه صاحبه لا يدخل البطن، ولا يرتفع إلى الفم، فيبقى بين ذلك، ولا يُغني من جوع»{2}. (١٥/٣٨٥) ٨٢٨١٢- قال أبو الدّرداء= (ز) ٨٢٨١٣- والحسن البصري: إنّ الله تعالى يُرسل على أهل النار الجوع، حتى يعدل عندهم ما هم فيه من العذاب، فيستغيثون، فيُغاثون مِن الضّريع، ثم يستغيثون، فيُغاثون بطعام ذا غُصّة، فيذكرون أنهم كانوا يجيزون الغصص في الدنيا بالماء، فيستسقون، فيُعطشهم ألف سنة، ثم يُسقون من عين آنية، شَربةً لا هنيئة ولا مريئة، فإذا أدنوه من وجوههم سلخ جلود وجوههم وشواها، فإذا وصل إلى بطونهم قطعها، فذلك قوله عز جل: <q>﴿وسُقُوا ماءً حَمِيمًا فَقَطَّعَ أمْعاءَهُمْ﴾</q> [محمد:١٥]{3}. (ز) ٨٢٨١٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: الشِّبرِق{4}. (١٥/٣٨١) ٨٢٨١٥- عن عبد الله بن عباس -من طريق علي- <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، يقول: مِن شجر مِن نار{5}. (١٥/٣٨٢) ٨٢٨١٦- عن عبد الله بن عباس، <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: الشِّبرِق اليابس{6}. (١٥/٣٨٣) ٨٢٨١٧- عن عبد الله بن عباس -من طريق عطاء- <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>: هو شيء يطرحه البحر المالح، يُسمِّيه أهل اليمن: الضريع{7}. (ز) ٨٢٨١٨- عن أبي الجَوْزاء -من طريق عمرو بن مالك- قال: الضريع: السُّلّاء، وهو الشوك، وكيف يَسمَن مَن كان طعامه الشوك؟!{8}. (١٥/٣٨٤) ٨٢٨١٩- عن سعيد بن جُبَير -من طريق جعفر- <q>﴿إلّا مِن ضَرِيعٍ﴾</q>، قال: مِن حجارة{9}. (١٥/٣٨٤) ٨٢٨٢٠- عن سعيد بن جُبَير، <q>﴿إلّا مِن ضَرِيعٍ﴾</q>، قال: الزّقوم{10}٧١٤٣. (١٥/٣٨٤) ٧١٤٣ وجَّه ابنُ عطية (٨/٥٩٧) قول سعيد بن جُبَير بقوله: «لأنّ الله تعالى قد أخبر في هذه الآية أنّ الكفار لا طعام لهم إلا مِن ضَرِيعٍ، وقد أخبر أنّ الزّقوم طعام الأثيم، فذلك يقتضي أنّ الضّريع: الزّقوم». ٨٢٨٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلّا مِن ضَرِيعٍ﴾</q>، قال: الشِّبرِق اليابس{11}. (١٥/٣٨٣) ٨٢٨٢٢- عن عكرمة مولى ابن عباس -من طريق عبد الرحمن الأصبهاني- في قوله: <q>﴿إلّا مِن ضَرِيعٍ﴾</q>، قال: الشِّبرِق{12}. (١٥/٣٨٢) ٨٢٨٢٣- عن عكرمة مولى ابن عباس -من طريق رجل من عبد القيس- قال: الضّريع: الشِّبرِق؛ شجرة ذات شوك لاطئة بالأرض، فإذا كان الربيع سمّتها قريش: الشِّبرِق، فإذا هاج العود سمّتها: الضّريع{13}. (١٥/٣٨٤) ٨٢٨٢٤- عن قتادة بن دعامة، قال: الضّريع بلغة قريش في الربيع: الشِّبرِق، وفي الصيف: الضّريع{14}. (١٥/٣٨٤) ٨٢٨٢٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: هو الشِّبرِق، إذا يبس يُسمّى: الضّريع{15}. (١٥/٣٨١) ٨٢٨٢٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: مِن شرّ الطعام، وأبشعه، وأخبثه{16}. (١٥/٣٨١) ٨٢٨٢٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿طعام إلا من ضريع﴾</q>، قال: شجرة يقال لها: الشِّبرِق{17}. (ز) ٨٢٨٢٨- قال محمد بن السّائِب الكلبي: <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q> نبْتٌ يَنبت في الربيع، فإذا كان في الصيف يبس؛ فاسمه إذا كان عليه ورقه: شِبرِق، وإذا تساقط ورقه فهو: الضّريع، فالإبل تأكله أخضر، فإذا يبس لم تذقه{18}. (ز) ٨٢٨٢٩- قال مقاتل بن سليمان: <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q> وهي شجرة تكون بمكة كثيرة الشوك، لا تَقربها دابة في الأرض مِن شوكها، ولا يستطيع أحد أن يمسّها مِن كثرة شوكها، وتُسمّيها قريش وهي رطبة في الربيع: الشِّبرِق، وتصيب الإبل من ورقها في الربيع ما دامت رطبة، فإذا يبستْ لم تَقربها الإبل، وما من دابة في الأرض من الهوام والسباع وما يؤذي بني آدم إلا مثلها في النار، سلّطها الله ﷿ على أهلها، لكنها مِن نار، وما خلق الله شيئًا في النار إلا من النار، <q>﴿لا يُسْمِنُ ولا يُغْنِي مِن جُوعٍ﴾</q> فإنهم لا يطعمون مِن أجل الجوع، وإنما من أجل العذاب{19}. (ز) ٨٢٨٣٠- عن شريك بن عبد الله -من طريق محمد بن عبيد- في قوله: <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: الشِّبرِق{20}. (ز) ٨٢٨٣١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾</q>، قال: الضّريع: الشوك من النار. قال: وأما في الدنيا فإنّ الضّريع: الشوك اليابس الذي ليس له ورق، تدعوه العرب: الضّريع، وهو في الآخرة شوك من نار{21}٧١٤٤. (ز) ٧١٤٤ زاد ابنُ عطية (٨/٥٩٨-٥٩٩) في معنى الآية أقوالًا أخرى، وعلَّق على بعضها، فقال: «وقيل: الضريع: العِشْرِقُ. وقال النبي ﷺ: «الضريع شوك في النار». وقال بعض اللغويين: الضريع يَبِسُ العَرْفَج إذا تحطّم. وقال آخرون: هو رَطْبُ العَرْفج. وقال الزَّجّاج: هو نَبْتٌ كالعَوْسج. وقال بعض المفسرين: الضّريع نبتٌ في البحر أخضر منتن مُجَوَّف مستطيل له نَوْر فيه كبير ... وكلّ مَن ذَكر شيئًا مما قدمناه فإنما يعني أنّ ذلك من نار ولا بُدّ، وكلّ ما في النار فهو نار. وقال قوم: ضَرِيع وادٍ في جهنم. وقال جماعة من المتأولين: الضّريعُ طعام أهل النار. ولم يُرِد أن يخصص شيئًا مما ذُكِر، قال بعض اللغويين: وهذا مما لا تعرفه العرب. وقيل: الضّريع: الجلدة التي على العظم تحت اللحم». ثم علَّق بقوله: «ولا أعرف مَن تأوَّل الآية بهذا، وأهل هذه الأقاويل يقولون: الزّقوم لطائفة، والضّريع لطائفة، والغِسْلين لطائفة». ",footnotes:1:أخرجه الترمذي ٤/٥٤١-٥٤٣ (٢٧٦٨) مطولًا، وابن جرير ١٧/١٢٣-١٢٤، والثعلبي ٨/٣٤٥. قال الترمذي: «قال عبد الله بن عبد الرحمن -يعني الدارمي-: والناس لا يرفعون هذا الحديث، إنما روي هذا الحديث عن الأعمش، عن شِمْر بن عطية، عن شَهْر بن حَوْشَب، عن أُمّ الدّرداء، عن أبي الدّرداء قولَه، وليس بمرفوع، وقطبة بن عبد العزيز هو ثقة عند أهل الحديث». وذكر الدارقطني في العلل ٦/٢٢٠ (١٠٨٦) الاختلاف في أسانيده، بين إرساله وإسناده، وبين رفعه ووقفه، وأنّ وقفه مسندًا موقوفًا أصح من غيره.أخرجه الواحدي في التفسير الوسيط ٤/٤٧٤ (١٣٣٧) مختصرًا. وأورده الديلمي في الفردوس ٢/٤٣٤ (٣٩٠٥) واللفظ له، والثعلبي ١٠/١٨٨. وعزاه السيوطي إلى ابن مردويه. قال ابن كثير في البداية والنهاية ٢٠/١٥٧: «وهذا حديث غريب جدًّا». وقال السيوطي: «بسند واهٍ».تفسير الثعلبي ١٠/١٨٨، وتفسير البغوي ٨/٤٠٨.أخرجه ابن جرير ٢٤/٣٣١. والشِّبرِق: نبت حجازي يؤكل وله شوك، وإذا يبس سُمّي الضريع. النهاية (شبرق).أخرجه ابن جرير ٢٤/٣٣٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٨٨.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي مصنف ابن أبي شيبة في (ت: محمد عوامة) ١٩/٤٨٨-٤٨٩ (٣٦٨٠٧) بلفظ: «السلم»، وهو كذلك في بعض نسخ الدر المنثور. والسَّلَم نوع من العضاه وهو كلّ شجر له شوك. أما السُّلّاء: فشوك النخل، واحدتها سلاءة. اللسان (سلأ، سلم، عضه).أخرجه ابن جرير ٢٤/٣٣٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مجاهد ص٥٠٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٥، وفتح الباري ٨/٧٠٠-، وهناد (٢٦٥)، وابن جرير ٢٤/٣٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨ مختصرًا، وابن جرير ٢٤/٣٣٢.أخرجه ابن جرير ٢٤/٣٣٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم بلفظ: الشّبرِق، شر الطعام وأبشعه وأخبثه.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٣-.تفسير مقاتل بن سليمان ٤/٦٧٨.أخرجه ابن جرير ٢٤/٣٣٢.أخرجه ابن جرير ٢٤/٣٣٣.
  88,7,""
88,8," <q>﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾</q> - قراءات ٨٢٨٣٢- عن سعيد بن جُبَير أنه قرأ في سورة الغاشية: (مُتَّكِئِينَ فِيها ناعِمِينَ فِيها){1}. (١٥/٣٨٥) <q>﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾</q> - تفسير الآية ٨٢٨٣٣- قال مقاتل بن سليمان: <q>﴿وُجُوهٌ يَوْمَئِذٍ ناعِمَةٌ﴾</q> يعني: فَرِحة، شبّه الله ﷿ وجوههم بوجوه قوم فَرِحين؛ إذا أصابوا الشراب طابتْ أنفسهم، فاجتمع الدم في وجوههم، فاجتمع فرح القلوب وفرح الشراب، فهو ضاحك الوجه، مبتسم طيّب النفس{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة.تفسير مقاتل بن سليمان ٤/٦٧٨.
88,9," <q>﴿لِّسَعۡیِهَا رَاضِیَةࣱ ۝٩﴾</q> - تفسير ٨٢٨٣٤- قال مقاتل بن سليمان: <q>﴿لِسَعْيِها راضِيَةٌ﴾</q>، يعني: قد رضي الله عمله، فأثابه الله ﷿ ذلك بعمله{1}. (ز) ٨٢٨٣٥- عن سفيان، في قوله: <q>﴿لِسَعْيِها راضِيَةٌ﴾</q>، قال: رَضِيَتْ عملها{2}. (١٥/٣٨٥) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٧٨.عزاه السيوطي إلى ابن أبي حاتم.
88,10," <q>﴿فِی جَنَّةٍ عَالِیَةࣲ ۝١٠﴾</q> - تفسير ٨٢٨٣٦- قال مقاتل بن سليمان: <q>﴿فِي جَنَّةٍ عالِيَةٍ﴾</q> وإنما سمّاها عالية لأن جهنم أسفل منها، وهي دركات، والجنة درجات{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٧٨.
88,11," <q>﴿لَّا تَسۡمَعُ فِیهَا لَـٰغِیَةࣰ ۝١١﴾</q> - قراءات ٨٢٨٣٧- عن عاصم أنه قرأ: <q>﴿لا تَسْمَعُ فِيها﴾</q> بالتاء ونصب التاء، <q>﴿لاغِيَةً﴾</q> منصوبة منونة{1}٧١٤٥. (١٥/٣٨٥) ٧١٤٥ اختلفت القرأة في قراءة قوله تعالى: <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q> على ثلاث قراءات: الأولى: <q>﴿لا تَسْمَعُ﴾</q> بفتح التاء، بمعنى: لا تسمع الوجوه. الثانية: ‹لا تُسْمَعُ› بضم التاء، بمعنى: ما لم يُسمّ فاعله. الثالثة: ‹لا يُسْمَعُ› بالضم أيضًا غير أنها بالياء. ورجَّح ابنُ جرير (٢٤/٣٣٦) «أن كل ذلك قراءاتٌ معروفاتٌ صحيحات المعاني، فبأيِّ ذلك قرأ القارئ فمصيبٌ». <q>﴿لَّا تَسۡمَعُ فِیهَا لَـٰغِیَةࣰ ۝١١﴾</q> - تفسير الآية ٨٢٨٣٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q>، يقول: لا تَسمع أذًى ولا باطلًا{2}. (١٥/٣٨٥) ٨٢٨٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q>، قال: شتمًا{3}. (١٥/٣٨٦) ٨٢٨٤٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q>، قال: لا تَسمع فيها باطلًا، ولا مَأْثَمًا{4}. (١٥/٣٨٦) ٨٢٨٤١- عن سليمان بن مهران الأعمش، <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q>، قال: مُؤْذِيَة{5}. (١٥/٣٨٦) ٨٢٨٤٢- قال مقاتل بن سليمان: <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q>، يقول: لا يسمع بعضهم من بعض غيبة، ولا كذب، ولا شتم{6}٧١٤٦. (ز) ٧١٤٦ ذكر ابنُ جرير (٢٤/٣٣٤) عن بعض نحويي الكوفة أنّ معنى الآية: «لا تسمع فيها حالفةٌ على الكذب، ولذلك قيل: لاغية». ثم انتقده -مستندًا إلى أقوال السلف- قائلًا: «ولهذا الذي قاله مذهبٌ ووجْهٌ، لولا أنّ أهل التأويل من الصحابة والتابعين على خلافه، وغير جائزٍ لأحدٍ خلافهم فيما كانوا عليه مُجْمِعين». ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها العشرة، ما عدا ابن كثير، وأبا عمرو، ورويسًا؛ فإنهم قرؤوا: ‹لا يُسْمَعُ فِيها لاغِيَةٌ› بالياء، ورفع <q>﴿لاغِيَةٌ﴾</q>، وما عدا نافعًا فإنه قرأ: ‹لا تُسْمَعُ فِيها لاغِيَةٌ› بالتاء ورفع <q>﴿لاغِيَةٌ﴾</q>. انظر: النشر ٢/٤٠٠، والإتحاف ص٥٨١.أخرجه ابن جرير ٢٤/٣٣٤.تفسير مجاهد ص٥٠١، وأخرجه ابن جرير ٢٤/٣٣٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٦٨، وابن جرير ٢٤/٣٣٥، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٧٨-٦٧٩.
88,12," <q>﴿فِیهَا عَیۡنࣱ جَارِیَةࣱ ۝١٢﴾</q> - تفسير ٨٢٨٤٣- قال مقاتل بن سليمان: <q>﴿فِيها عَيْنٌ جارِيَةٌ﴾</q> يعني: في الجنة؛ لأنها فيها تجري الأنهار{1}٧١٤٧. (ز) ٧١٤٧ ذكر ابنُ عطية (٨/٦٠٠) في معنى: <q>﴿عَيْنٌ﴾</q> قوله: «<q>﴿عَيْنٌ﴾</q> في هذه الآية اسم جنس، ويحتمل أن تكون عينًا مخصوصة ذُكرت على جهة التشريف لها». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٧٩.
88,13," <q>﴿فِیهَا سُرُرࣱ مَّرۡفُوعَةࣱ ۝١٣﴾</q> - تفسير ٨٢٨٤٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</q>، قال: بعضها فوق بعض{1}. (١٥/٣٨٦) ٨٢٨٤٥- قال عبد الله بن عباس: <q>﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</q> ألواحها مِن ذهب، مُكلّلة بالزَّبَرْجد والدُّرّ والياقوت، مرتفعة ما لم يجئ أهلها، فإذا أراد أن يجلس عليها تواضعتْ له حتى يجلس عليها، ثم ترتفع إلى مواضعها{2}. (ز) ٨٢٨٤٦- قال مقاتل بن سليمان: <q>﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</q> منسوجة بقضبان الدُّرّ والذَّهب، عليها سبعون فراشًا، كلّ فراش قدر غرفة مِن غرف الدنيا{3}. (ز) ٨٢٨٤٧- عن عبد الملك ابن جُرَيْج، <q>﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾</q>، قال: مرتفعة{4}. (١٥/٣٨٦) ",footnotes:1:أخرجه ابن جرير ٢٤/٣٣٦.تفسير البغوي ٨/٤٠٩.تفسير مقاتل بن سليمان ٤/٦٧٩.عزاه السيوطي إلى ابن المنذر.
88,14," <q>﴿وَأَكۡوَابࣱ مَّوۡضُوعَةࣱ ۝١٤﴾</q> - تفسير ٨٢٨٤٨- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿وأكواب﴾</q>، قال: الأكواب: الأقساط{1}. (ز) ٨٢٨٤٩- قال مقاتل بن سليمان: <q>﴿وأَكْوابٌ مَوْضُوعَةٌ﴾</q>، يعني: مصفوفة، وهي أكواب من فِضّة، وهي في الصفاء مثل القوارير، مُدَوَّرة الرؤوس، ليس لها عُرًى ولا خراطيم{2}. (ز) ",footnotes:1:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤.تفسير مقاتل بن سليمان ٤/٦٧٩.
88,15," <q>﴿وَنَمَارِقُ مَصۡفُوفَةࣱ ۝١٥﴾</q> - تفسير ٨٢٨٥٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿ونَمارِقُ﴾</q>، قال: مجالس{1}. (١٥/٣٨٦) ٨٢٨٥١- عن عبد الله بن عباس، في قوله: <q>﴿ونَمارِقُ﴾</q>، قال: الوسائد{2}. (١٥/٣٨٦) ٨٢٨٥٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ونَمارِقُ﴾</q>، قال: المرافق{3}. (١٥/٣٨٦) ٨٢٨٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ونَمارِقُ﴾</q>، قال: الوسائد{4}. (١٥/٣٨٦) ٨٢٨٥٤- قال مقاتل بن سليمان: <q>﴿ونَمارِقُ مَصْفُوفَةٌ﴾</q>، يعني: الوسائد الكبار العظام، مصفوفة على الطنافس، وهي بلغة قريش خاصة{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٣٣٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٣٧، وابن أبي حاتم -كما في الإتقان ٢/٥٥-.أخرجه ابن جرير ٢٤/٣٣٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.
88,16," <q>﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾</q> - قراءات ٨٢٨٥٥- عن عمار بن محمد، قال: صَلّيتُ خلف منصور بن المعتمر، فقرأ: <q>﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾</q>، فقرأ فيها: (وزَرابِيُّ مَبْثُوثَةٌ مُّتَّكِئِينَ فِيها ناعِمِينَ){1}. (١٥/٣٨٧) <q>﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾</q> - تفسير الآية ٨٢٨٥٦- عن عبد الله بن عباس، في قوله: <q>﴿وزَرابِيُّ﴾</q>، قال: البُسط{2}. (١٥/٣٨٦) ٨٢٨٥٧- قال عبد الله بن عباس: <q>﴿وزَرابِيُّ﴾</q> هي الطنافس التي لها خمل رقيق{3}. (ز) ٨٢٨٥٨- عن عكرمة مولى ابن عباس، <q>﴿وزَرابِيُّ مَبْثُوثَةٌ﴾</q>، قال: بعضها على بعض{4}. (١٥/٣٨٧) ٨٢٨٥٩- عن الحسن البصري، <q>﴿وزَرابِيُّ﴾</q>، قال: البُسُط{5}. (١٥/٣٨٦) ٨٢٨٦٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿مَبْثُوثَةٌ﴾</q>، قال: مبسوطة{6}. (١٥/٣٨٦) ٨٢٨٦١- قال مقاتل بن سليمان: <q>﴿وزَرابِيُّ مَبْثُوثَةٌ﴾</q>، يعني: طنافس مبسوطة بعضها على بعض، يذكّرهم الله ﷿ صُنعه؛ ليعتبر عباده، فيحرصوا عليها، ويرغبوا فيها، ويحذروا النار، فإنّ عقوبته على قدر سلطانه، وكرامته قدر سلطانه{7}. (ز) <q>﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾</q> - آثار متعلقة بالآية ٨٢٨٦٢- عن عبد الله بن أبي الهذيل: أنّ موسى أو غيره من الأنبياء قال: يا ربّ، كيف يكون هذا منك؟! أولياؤك في الأرض خائفون يُقتلون، ويطلبون فلا يُعطون، وأعداؤك يأكلون ما شاؤوا، ويشربون ما شاؤوا! ونحو هذا، فقال: انطلِقوا بعبدي إلى الجنة. فينظر ما لم يَر مثله قطّ؛ إلى أكواب موضوعة، ونمارق مصفوفة، وزرابيّ مبثوثة، وإلى الحُور العين، وإلى الثمار، وإلى الخدم كأنهم لؤلؤ مكنون، فقال: ما ضرّ أوليائي ما أصابهم في الدنيا إذا كان مصيرهم إلى هذا؟! ثم قال: انطلِقوا بعبدي. فانطُلق به إلى النار، فخرج منها عُنق، فصَعِق العبد، ثم أفاق، فقال: ما نفع أعدائي ما أعطيتُهم في الدنيا إذا كان مصيرهم إلى هذا؟ قال: لا شيء{8}. (١٥/٣٨٧) ٨٢٨٦٣- عن عبد الله بن عمار -من طريق عكرمة بن خالد- قال: رأيتُ عمر بن الخطاب يُصلِّي على عبقريّ، وهو الزرابيّ{9}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف. وهي قراءة شاذة.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤٠٩.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٣٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.أخرجه ابن أبي شيبة ١٣/١١٥.أخرجه ابن جرير ٢٤/٣٣٧.
88,17," <q>﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</q> - نزول الآية ٨٢٨٦٤- عن قتادة بن دعامة -من طريق سعيد- قال: لما نعت الله ما في الجنة عجِب من ذلك أهلُ الضلالة؛ فأنزل الله: <q>﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾</q>، وكانت الإبل عيشًا من عيش العرب، وخَوَلًا مِن خَوَلهم{1}. (١٥/٣٨٨) ٨٢٨٦٥- عن قتادة بن دعامة، قال: ذكر الله تعالى ارتفاع سُرُرِ الجنة، وفُرُشِها، فقالوا: كيف نصعدها؟ فأنزل الله تعالى هذه الآية{2}. (ز) <q>﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</q> - تفسير الآية ٨٢٨٦٦- سُئِل الحسن البصري عن هذه الآية: <q>﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾</q>، وقيل له: الفيل أعظم في الأعجوبة؟ فقال: أمّا الفيل فالعرب بعيدة العهد بها، ثم هو لا خير فيه، لا يُركب ظهرها، ولا يؤكل لحمها، ولا يُحلب درّها، والإبل أعزّ مالٍ للعرب وأنفَسها، تأكل النوى والقتّ وتُخرج اللبن{2}. (ز) ٨٢٨٦٧- قال محمد بن السّائِب الكلبي: <q>﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾</q> لأنّها تنهض بحمْلها وهي باركة، ولأنه ليس شيء مِن الحيوانات سابقها غيرها{2}. (ز) ٨٢٨٦٨- قال مقاتل بن سليمان: <q>﴿أفَلا يَنْظُرُونَ إلى الإبِلِ﴾</q> لأنّ العرب لم يكونوا رأوا الفيل، وإنما ذكر لهم ما أبصروا، ولو أنه قال: أفلا ينظرون إلى الفِيَلة <q>﴿كَيْفَ خُلِقَتْ﴾</q> لم يتعجّبوا لها؛ لأنهم لم يَروها{5}٧١٤٨. (ز) ٧١٤٨ نقل ابنُ عطية (٨/٦٠١) عن المبرد قوله: «الإبل هنا: السحاب؛ لأنّ العرب قد تسميها بذلك إذ تأتي أرسالًا كالإبل، وتُزْجى كما تُزْجى الإبل، وهي في هيئتها أحيانًا تشبه الإبل والنعام». واستشهد ببيت من الشعر: كأن السحاب دوين السما ء نعام تعلق بالأرجل. <q>﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</q> - آثار متعلقة بالآية ٨٢٨٦٩- عن شريح [القاضي] -من طريق أبي إسحاق، عمَّن سمعه- أنه كان يقول لأصحابه: اخرجوا بنا إلى السوق فننظر إلى الإبل كيف خُلقتْ؟{6}. (١٥/٣٨٩) ",footnotes:1:أخرجه ابن جرير ٢٤/٣٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤١٠.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤١٠.تفسير الثعلبي ١٠/١٨٩، وتفسير البغوي ٨/٤١٠.تفسير مقاتل بن سليمان ٤/٦٧٩.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٠١-، وابن جرير ٢٤/٣٣٩. وعزاه السيوطي إلى عبد بن حميد.
88,18," <q>﴿وَإِلَى ٱلسَّمَاۤءِ كَیۡفَ رُفِعَتۡ ۝١٨ وَإِلَى ٱلۡجِبَالِ كَیۡفَ نُصِبَتۡ ۝١٩﴾</q> - تفسير ٨٢٨٧٠- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿وإلى السَّماءِ كَيْفَ رُفِعَتْ وإلى الجِبالِ كَيْفَ نُصِبَتْ﴾</q>، قال: تصعد إلى الجبل الصَّيْخُود{1} عامة يومك، فإذا أفضيتَ إلى أعلاه أفضيتَ إلى عيون مُتفجِّرة، وأثمار متهدّلة، لم تغرسه الأيدي، ولم تعمله الناس، نعمة من الله، وبُلْغَة إلى أجل{2}. (١٥/٣٨٨) ٨٢٨٧١- قال مقاتل بن سليمان: <q>﴿وإلى السَّماءِ كَيْفَ رُفِعَتْ﴾</q> من فوقهم خمسمائة عام، <q>﴿وإلى الجِبالِ كَيْفَ نُصِبَتْ﴾</q> على الأرض أوتادًا لِئلّا تزول بأهلها{3}. (ز) ",footnotes:1:يقال صخرة صيخود: شديدة لا تعمل فيها المعاول. التاج (صخد).أخرجه ابن جرير ٢٤/٣٣٩-٣٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.
  88,19,""
88,20," <q>﴿وَإِلَى ٱلۡأَرۡضِ كَیۡفَ سُطِحَتۡ ۝٢٠﴾</q> - تفسير ٨٢٨٧٢- عن عبد الله بن عباس -من طريق عطاء- <q>﴿وإلى الأرْضِ كَيْفَ سُطِحَتْ﴾</q>: هل يقدر أحد أن يَخلُق مثل الإبل، أو يرفع مثل السماء، أو ينصب مثل الجبال، أو يسطح مثل الأرض غيري؟!{1}. (ز) ٨٢٨٧٣- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿وإلى الأَرْضِ كَيْفَ سُطِحَتْ﴾</q> أي: بُسطتْ. يقول: الذي خَلَق هذا قادر على أن يَخلُق في الجنة ما أراد{2}. (١٥/٣٨٨) ٨٢٨٧٤- قال مقاتل بن سليمان: <q>﴿وإلى الأَرْضِ كَيْفَ سُطِحَتْ﴾</q>، يعني: كيف بُسطتْ مِن تحت الكعبة مسيرة خمسمائة عام{3}. (ز) ",footnotes:1:أخرجه البغوي ٨/٤١٠.أخرجه ابن جرير ٢٤/٣٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٧٩.
88,21," <q>﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾</q> - قراءات ٨٢٨٧٥- عن جابر، قال: قرأ رسول الله ﷺ: <q>﴿لَسْتَ عَلَيْهِم بِمُصَيْطِرٍ﴾</q> بالصاد{1}. (١٥/٣٨٩) <q>﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾</q> - تفسير الآية ٨٢٨٧٦- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «أُمرتُ أنْ أقاتل الناس حتى يقولوا: لا إله إلا الله. فإذا قالوها عصموا مِنِّي دماءهم وأموالهم إلا بحقِّها، وحسابهم على الله». ثم قرأ: <q>﴿فَذَكِّرْ إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>{2}. (١٥/٣٨٩) ٨٢٨٧٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، يقول: بجبّار، فاعفُ عنهم واصفح{3}. (١٥/٣٨٩) ٨٢٨٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، قال: جبّار{4}. (١٥/٣٩٠) ٨٢٨٧٩- عن الضَّحّاك بن مُزاحِم، <q>﴿بِمُصَيْطِرٍ﴾</q>، قال: بمُسلَّط{5}. (١٥/٣٩٠) ٨٢٨٨٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، قال: بقاهر{6}. (١٥/٣٩٠) ٨٢٨٨١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، قال: كِلْ عبادي إلَيَّ{7}. (١٥/٣٩٠) ٨٢٨٨٢- قال مقاتل بن سليمان: <q>﴿فَذَكِّرْ﴾</q> أهل مكة، يا محمد <q>﴿إنَّما أنْتَ مُذَكِّرٌ﴾</q> كالذين من قبلك، <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q> يقول: لستَ عليهم بملِك{8}. (ز) ٨٢٨٨٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، قال: لستَ عليهم بمُسلَّط أن تُكرههم على الإيمان{9}. (ز) <q>﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾</q> - النسخ في الآية ٨٢٨٨٤- عن عبد الله بن عباس، <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، قال: نسَخ ذلك، فقال: <q>﴿اقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾</q> [التوبة:٥]{10}. (١٥/٣٩٠) ٨٢٨٨٥- قال مقاتل بن سليمان: <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، يقول: لستَ عليهم بملِك، ثم نَسَخَتْها آيةُ السيف في براءة{8}. (ز) ٨٢٨٨٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، قال: لستَ عليهم بمُسلَّط أن تُكرههم على الإيمان. قال: ثم جاء بعد هذا: <q>﴿جاهِدِ الكُفّارَ والمُنافِقِينَ واغْلُظْ عَلَيْهِمْ﴾</q> [التوبة:٧٣، والتحريم:٩]، وقال: <q>﴿واقْعُدُوا لَهُمْ كُلَّ مَرْصَدٍ﴾</q> وارصدوهم لا يخرجوا في البلاد، <q>﴿فَإنْ تابُوا وأَقامُوا الصَّلاةَ وآتَوُا الزَّكاةَ فَخَلُّوا سَبِيلَهُمْ إنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾</q> [التوبة:٥]. قال: فنَسَخَتْ <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>. قال: جاء اقتله أو يُسلِم. قال: والتذكرة كما هي لم تُنسخ. وقرأ: <q>﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾</q> [الذاريات:٥٥]{9}٧١٤٩. (ز) ٧١٤٩ ذكر ابنُ عطية (٨/٦٠٢) اختلاف المفسرين في قوله تعالى: <q>﴿إلا مَن تَوَلّى وكَفَرَ﴾</q> على قولين: الأول: «أنّ الاستثناء متصل، والمعنى: إلا مَن تولى وكفر فأنت مُسيطِرٌ عليه». ثم وجَّهه بقوله: «فالآية -على هذا- لا نسخ فيها». الثاني: «أن الاستثناء منفصل، والمعنى: <q>﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾</q>، وتمَّ الكلام، وهي آية موادعة منسوخة بالسيف، ثم قال تعالى: <q>﴿إلّا مَن تَوَلّى وكَفَرَ * فَيُعَذِّبُهُ﴾</q>». ثم رجَّحه مستندًا إلى أحوال النزول، فقال: «وهذا هو القول الصحيح؛ لأن السورة مكّيّة، والقتال إنما نزل بالمدينة». ",footnotes:1:أخرجه الحاكم ٢/٢٧٩ (٣٠٠٧). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم». وهي قراءة متواترة، قرأ بها العشرة، ما عدا هشامًا فإنه قرأ: ‹بِمُسَيْطِرٍ› بالسين، وما عدا قنبلًا وابن ذكوان وحفصًا وخلادًا الأربعة كلهم في رواية. انظر: النشر ٢/٣٧٨، والإتحاف ص٥٨٢.أخرجه مسلم ١/٥٢ (٢١)، وابن جرير ٢٤/٣٤٢.أخرجه ابن جرير ٢٤/٣٤١، وابن أبي حاتم -كما في الإتقان ٢/٥٥-. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.تفسير مجاهد ص٥٠١، وأخرجه ابن جرير ٢٤/٣٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٦٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٣٤١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٧٩-٦٨٠.أخرجه ابن جرير ٢٤/٣٤١.عزاه السيوطي إلى أبي داود في ناسخه. وينظر: نواسخ القرآن لابن الجوزي ص٥٠٧.تفسير مقاتل بن سليمان ٤/٦٧٩-٦٨٠.أخرجه ابن جرير ٢٤/٣٤١.
  88,22,""
88,23," <q>﴿إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ۝٢٣ فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾</q> - قراءات ٨٢٨٨٧- في قراءة عبد الله بن مسعود: (فَإنَّهُ يُعَذِّبُهُ اللهُ العَذابَ الأَكْبَرَ){1}. (ز) <q>﴿إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ۝٢٣ فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾</q> - تفسير الآية ٨٢٨٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إلّا مَن تَوَلّى وكَفَرَ﴾</q>، قال: حسابه على الله{2}. (١٥/٣٩٠) ٨٢٨٨٩- قال مقاتل بن سليمان: <q>﴿إلّا مَن تَوَلّى﴾</q> يعني: أعرَض، <q>﴿وكَفَرَ﴾</q> بالإيمان، <q>﴿فَيُعَذِّبُهُ اللَّهُ﴾</q> في الآخرة <q>﴿العَذابَ الأَكْبَرَ﴾</q> وإنما سمّاه الله الأكبر لأنّ الله كان أوعدهم القتل والجوع في الدنيا، فقال الأكبر؛ لأنه أكبر من الجوع والقتل، وهو عذاب جهنم{3}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٨. وهي قراءة شاذة. انظر: المحرر الوجيز ٥/٤٧٥، والجامع لأحكام القرآن ٢٢/٢٥٤.تفسير مجاهد ص٥٠١، وأخرجه ابن جرير ٢٤/٣٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٨٠.
  88,24,""
88,25," <q>﴿إِنَّ إِلَیۡنَاۤ إِیَابَهُمۡ ۝٢٥ ثُمَّ إِنَّ عَلَیۡنَا حِسَابَهُم ۝٢٦﴾</q> - تفسير ٨٢٨٩٠- عن عبد الله بن عباس -من طريق ابن جُرَيْج، عن عطاء الخُراسانيّ- في قوله: <q>﴿إنَّ إلَيْنا إيابَهُمْ﴾</q>، قال: مرجعهم{1}. (١٥/٣٩٠) ٨٢٨٩١- عن عطاء، مثله{2}. (١٥/٣٩١) ٨٢٨٩٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿إنَّ إلَيْنا إيابَهُمْ﴾</q>. قال: الإياب: المرجع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت عَبيد بن الأَبْرص يقول: وكلّ ذي غَيْبة يؤوب وغائب الموت لا يؤوب وقال الآخر: فأَلقتْ عصاها واستقرّ بها النَّوى كما قرّ عَينًا بالإياب المسافر{3}. (١٥/٣٩١) ٨٢٨٩٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّ إلَيْنا إيابَهُمْ ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾</q>، قال: إلى الله الإياب، وعلى الله الحساب{4}. (١٥/٣٩١) ٨٢٨٩٤- عن إسماعيل السُّدِّيّ، <q>﴿إنَّ إلَيْنا إيابَهُمْ﴾</q>، قال: مُنقَلَبهم{5}. (١٥/٣٩١) ٨٢٨٩٥- قال إسماعيل السُّدِّيّ: <q>﴿ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾</q>، يعني: جزاءهم{6}. (ز) ٨٢٨٩٦- قال مقاتل بن سليمان: <q>﴿إنَّ إلَيْنا إيابَهُمْ﴾</q> يعني: مصيرهم، <q>﴿ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾</q> يعني: جزاءهم على الله هَيِّن{7}. (ز) ",footnotes:1:أخرجه ابن المنذر -كما في فتح الباري ٨/٧٠١-.عزاه السيوطي إلى ابن أبي حاتم. وينظر: فتح الباري ٨/٧٠١.أخرجه الطستي -كما في الإتقان ٢/٩٠-.أخرجه ابن جرير ٢٤/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٢٥-.تفسير مقاتل بن سليمان ٤/٦٨٠.
  88,26,""
