quran[20]{c,v,t}:
  26,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فَعَلۡتُهَاۤ إِذࣰا وَأَنَا۠ مِنَ ٱلضَّاۤلِّینَ ۝٢٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٩٤<span class="dash">-</span></span> عن الضحاك بن مُزاحِم، قال: في حرف <span class="name-1">ابن مسعود</span>: (قالَ فَعَلْتُهَآ إذًا وأَنا مِنَ الجاهِلِينَ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٥<span class="dash">-</span></span> عن ابن جُرَيْج، قال: في قراءة <span class="name-1">ابن مسعود</span>: (فَعَلْتُهَآ إذَن وأَناْ مِنَ الجاهِلِينَ){2}. (١١/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٦<span class="dash">-</span></span> قال مقاتل بن سليمان: وهي قراءة <span class="name-1">ابن مسعود</span>: (فَعَلْتُهَآ إذًا وأَنا مِنَ الجاهِلِينَ){3}<span class=comment-ref>٤٧٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٧</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٦/٤٧٥) على قراءة ابن مسعود الواردة في قول مقاتل، فقال: «ويشبه أن تكون هذه القراءة على جهة التفسير».</div></p><p><h3><span class="qpc-hafs">﴿قَالَ فَعَلۡتُهَاۤ إِذࣰا وَأَنَا۠ مِنَ ٱلضَّاۤلِّینَ ۝٢٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿قال فعلتها إذا وأنا من الضالين﴾</span>، قال: من الجاهلين{4}. (١١/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٩<span class="dash">-</span></span> و<span class="name-3">سفيان الثوري</span>، مثل ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فعلتها إذا وأنا من الضالين﴾</span>، قال: من الجاهلين{6}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠١<span class="dash">-</span></span> عن عبيد، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿وأنت من الكافرين﴾</span>: فقال موسى: لم أكفر، ولكن فعلتها، وأنا من الضالين. وفي حرف ابن مسعود: (فَعَلْتُهَآ إذًا وأَناْ مِنَ الجاهِلِينَ){7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: فتَبَرَّأ مِن ذلك نبيُّ الله، قال: <span class="qpc-hafs">﴿فعلتها إذا وأنا من الضالين﴾</span>. قال: مِن الجاهلين. قال: وهي في بعض القراءة: (وأَناْ مِنَ الجاهِلِينَ)، فإنّما هو شيء جَهِلَه، ولم يَتَعَمَّدْه{8}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: أي: من الجاهلين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال فعلتها إذا وأنا من الضالين﴾</span>، يعني: مِن الجاهلين، وهي في قراءة ابن مسعود: (فَعَلْتُهَآ إذًا وأَنا مِنَ الجاهِلِينَ){3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿فعلتها إذا وأنا من الضالين﴾</span>، أي: خطأ، لا أُريد ذلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قال فعلتها إذا وأنا من الضالين﴾</span>: قبل أن يأتيني مِن الله شيء، كان قتلي إيّاه ضلالة خطأ. قال: والضلالة ههنا: الخطأ، لم يقل: ضلالة فيما بينه وبين الله{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال موسى: <span class="qpc-hafs">﴿فعلتها إذا وأنا من الضالين﴾</span>، أي: لم يتعمد قتله{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٥٥٨، وإسحاق البستي في تفسيره ص٥٣١.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عباس. انظر: مختصر ابن خالويه ص١٠٧.|2:أخرجه أبو عبيد ص١٨٠، وابن جرير ١٧/٥٥٨. وعزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٢٦٠.|4:علَّقه ابن أبي حاتم ٨/٢٧٥٤.|5:أخرجه ابن جرير ١٧/٥٥٨. وعلَّقه ابن أبي حاتم ٨/٢٧٥٤.|6:أخرجه ابن جرير ١٧/٥٥٨، كذلك من طريق ابن جريج أيضًا، وإسحاق البستي في تفسيره ص٥٣١ من طريق ابن جريج، وابن أبي حاتم ٨/٢٧٥٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ١٧/٥٥٨، وإسحاق البستي في تفسيره ص٥٣١.|8:أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٥٨، وابن أبي حاتم ٨/٢٧٥٥ من طريق سعيد. وعلَّقه يحيى بن سلام ٢/٤٩٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:علَّقه يحيى بن سلام ٢/٤٩٩.|10:تفسير مقاتل بن سليمان ٣/٢٦٠.|11:أخرجه ابن أبي حاتم ٨/٢٧٥٥-٢٧٥٦.|12:أخرجه ابن جرير ١٧/٥٥٨، وابن أبي حاتم ٨/٢٧٥٥ من طريق أصبغ.|13:تفسير يحيى بن سلام ٢/٤٩٩.
  26,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَفَرَرۡتُ مِنكُمۡ لَمَّا خِفۡتُكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٠٨<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ففررت منكم﴾</span>، يعني: فهربت منكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ففررت منكم﴾</span> إلى مَدْين؛ <span class="qpc-hafs">﴿لما خفتكم﴾</span> أن تقتلون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ففررت منكم لما خفتكم﴾</span>، يعني: حيث تَوَجَّه تلقاء مَدين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَوَهَبَ لِی رَبِّی حُكۡمࣰا وَجَعَلَنِی مِنَ ٱلۡمُرۡسَلِینَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فوهب لي ربي حكما﴾</span>، قال:النُّبُوَّة{4}<span class=comment-ref>٤٧٨٨</span>. (١١/٢٤١)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٨</span> لم يذكر <u>ابنُ جرير</u> (١٧/٥٥٩) في معنى «الحكم» غير قول السدي.</div></p><p><div></p><p><p><span class="item-no">٥٥٧١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فوهب لي ربي حكما﴾</span> يعني: العلم والفهم، <span class="qpc-hafs">﴿وجعلني من المرسلين﴾</span> إليكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فوهب لي ربي حكما﴾</span> النبوة، <span class="qpc-hafs">﴿وجعلني من المرسلين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ٢/٤٩٩.|2:تفسير مقاتل بن سليمان ٣/٢٦٠.|3:تفسير يحيى بن سلام ٢/٤٩٩.|4:أخرجه ابن جرير ١٧/٥٥٩، وابن أبي حاتم ٨/٢٧٥٥.|5:تفسير مقاتل بن سليمان ٣/٢٦٠. وفي تفسير البغوي ٦/١١٠ مثل قوله في معنى <span class="qpc-hafs">﴿حكمًا﴾</span> منسوبًا إلى مقاتل دون تعيينه.|6:تفسير يحيى بن سلام ٢/٤٩٩.
  26,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتِلۡكَ نِعۡمَةࣱ تَمُنُّهَا عَلَیَّ أَنۡ عَبَّدتَّ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني إسرائيل﴾</span>، قال: قَهَرتهم، واستعملتهم{1}. (١١/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧١٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: أخذتَ أموالَ بني إسرائيل، وأنفقتَ منها عَلَيَّ، واتخذتَهم عبيدًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وتلك نعمة تمنها علي﴾</span>، قال: يقول موسى لفرعون: أتَمُنُّ عليَّ -يا فرعون- بأنِ اتَّخَذْت بني إسرائيل عبيدًا، وكانوا أحرارًا، فقهرتهم واتخذتَهم عبيدًا؟!{3}. (١١/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني إسرائيل﴾</span>: وربَّيْتَنِي قبلُ وليدًا{4}<span class=comment-ref>٤٧٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٩</span> للسلف في تفسير قوله: <span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني إسرائيل﴾</span> قولان: <b>الأول</b>: أن ذلك خبر معناه: اعتراف من موسى ﵇ بما لفرعون عليه مِن يد؛ إذ استعبد بني إسرائيل، وربّاه في بيته. <b>الثاني</b>: أنّ ذلك استفهام غرضه الإنكار أن تكون هذه نعمة، كما في قول قتادة.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٧/٥٥٩-٥٦٠) القول الأول <span class="mustanad">مستندًا للغة، والسياق</span>، فقال: «يعني بقوله: <span class="qpc-hafs">﴿وتلك نعمة تمنها علي﴾</span>: وتلك تربية فرعون إيّاه، يقول: وتربيتك إيّاي، وتركك استعبادي كما استعبدت بني إسرائيل نعمةٌ منك تَمُنُّها عَلَيَّ بحق. وفي الكلام محذوف استغنى بدلالة ما ذكر عليه عنه، وهو: وتلك نعمة تمنها عَلَيَّ أن عبدت بني إسرائيل وتركتني، فلم تستعبدني، فترك ذكر: وتركتني؛ لدلالة قوله: <span class="qpc-hafs">﴿أن عبدت بني إسرائيل﴾</span> عليه، والعرب تفعل ذلك اختصارًا للكلام».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٦/٤٧٧) على القولين، فقال: «ولكل وجه ناحيةٌ مِن الاحتجاج؛ فالأول ماضٍ في طريق المخالفة لفرعون ونقض كلامه كله، والثاني مُبْدٍ مِن موسى ﵇ أنّه مُنصِف مِن نفسه، مُعْتَرِف بالحق، ومتى حصل أحد المجادلين في هذه الرتبة، وكان خصمه في ضدها؛ غلب المتصف بذلك، وصار قوله أوقع في النفوس».</div></p><p><div></p><p><p><span class="item-no">٥٥٧١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال لفرعون: <span class="qpc-hafs">﴿وتلك نعمة تمنها علي﴾</span> يا فرعون، تمنُّ عليَّ بإحسانك إلَيَّ خاصة فيما زعمتَ، وتنسى إساءتك <span class="qpc-hafs">﴿أن عبدت﴾</span> يقول: استعبدت <span class="qpc-hafs">﴿بني إسرائيل﴾</span> فاتخذتهم عبيدًا لقومك القِبط؟! وكان فرعونُ قد قهرهم أربعمائة وثلاثين سنة، ويقال: وأربعين سنة، وإنما كانت بنو إسرائيل بمصر حين أتاها يعقوب وبنوه وحشمه حين أتوا يوسف{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧١٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثم أقبل عليه موسى يُنكِر عليه ما ذَكَر مِن يده عنده، فقال: <span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني اسرائيل﴾</span>، أي: أنِ اتخذتَهم عبيدًا، تنزِع أبناءَهم مِن أيديهم، فتَسْتَرِقَّ مَن شئت، وتقتل مَن شئت، وإنِّي إنّما صيَّرني إليك لِأُبَيِّن لك ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ثم قال: <span class="qpc-hafs">﴿وتلك نعمة تمنها علي﴾</span> لقول فرعون له: <span class="qpc-hafs">﴿وأنت من الكافرين﴾</span> لنعمتنا <span class="qpc-hafs">﴿أن عبدت بني إسرائيل﴾</span> موسى يقوله لفرعون، أراد ألّا يسوغ عدو الله ما امْتَنَّ به عليه، فقال: <span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني إسرائيل﴾</span> فاتخذتَ قومي عبيدًا، وكانوا أحرارًا، وأخذت أموالهم، فأنفقت عَلَيَّ مِن أموالهم، وربَّيْتَني بها، فأنا أحقُّ بأموال قومي منك{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ٢/٥٠٠ موصولًا ومعلقًا، والموصول من طريق ابن مجاهد، وابن جرير ١٧/٥٦٠-٥٦١، وابن أبي حاتم ٨/٢٧٥٦. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وعبد بن حميد.|2:تفسير الثعلبي ٧/١٦٢.|3:أخرجه عبد الرزاق ٢/٧٤، وابن جرير ١٧/٥٦١، وابن أبي حاتم ٨/٢٧٥٥ من طريق سعيد. وعلَّقه يحيى بن سلام ٢/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه ابن جرير ١٧/٥٦١.|5:تفسير مقاتل بن سليمان ٣/٢٦٠.|6:أخرجه ابن أبي حاتم ٨/٢٧٥٥.|7:تفسير يحيى بن سلام ٢/٤٩٩.
  26,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فِرۡعَوۡنُ وَمَا رَبُّ ٱلۡعَـٰلَمِینَ ۝٢٣ قَالَ رَبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَاۤۖ إِن كُنتُم مُّوقِنِینَ ۝٢٤ قَالَ لِمَنۡ حَوۡلَهُۥۤ أَلَا تَسۡتَمِعُونَ ۝٢٥ قَالَ رَبُّكُمۡ وَرَبُّ ءَابَاۤىِٕكُمُ ٱلۡأَوَّلِینَ ۝٢٦ قَالَ إِنَّ رَسُولَكُمُ ٱلَّذِیۤ أُرۡسِلَ إِلَیۡكُمۡ لَمَجۡنُونࣱ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قال فرعون وما رب العالمين﴾</span> إلى قوله: <span class="qpc-hafs">﴿إن كنتم تعقلون﴾</span>، قال: فلم يَزِدْهُ إلا رَغَمًا{1}{2}. (١١/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قال لمن حوله﴾</span>: كانوا خمسمائة رجل، عليهم الأسورة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي سعد- في قوله: <span class="qpc-hafs">﴿وتلك نعمة تمنها عليَّ أن عبدت بني إسرائيل*قال فرعون وما رب العالمين*قال رب السموات والأرض وما بينهما إن كنتم موقنين*قال لمن حوله ألا تستمعون﴾</span>: فلم يزده إلا رَغَمًا، <span class="qpc-hafs">﴿قال ربكم ورب آبائكم الأولين﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿قال فرعون وما رب العالمين﴾</span>، قال: مَن ربُّكما، يا موسى؟ <span class="qpc-hafs">﴿قال ربنا الذي اعطى كل شيء خلقه ثم هدى﴾</span> [طه:٥٠]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال فرعون﴾</span> لموسى: <span class="qpc-hafs">﴿وما رب العالمين﴾</span>؟ مُنكِرًا له، <span class="qpc-hafs">﴿قال﴾</span> موسى: هو <span class="qpc-hafs">﴿رب السماوات والأرض وما بينهما﴾</span> مِن العجائب؛ <span class="qpc-hafs">﴿إن كنتم موقنين﴾</span> بتوحيد الله ﷿. <span class="qpc-hafs">﴿قال﴾</span> فرعون <span class="qpc-hafs">﴿لمن حوله﴾</span> يعني: الأشراف، وكان حوله خمسون ومائة مِن أشرافهم، أصحاب الأثرة: <span class="qpc-hafs">﴿ألا تستمعون﴾</span> إلى قول هذا. يعني: موسى، <span class="qpc-hafs">﴿قال﴾</span> موسى: هو <span class="qpc-hafs">﴿ربكم ورب آبآئكم الأولين﴾</span>. <span class="qpc-hafs">﴿قال﴾</span> فرعون لهم: <span class="qpc-hafs">﴿إن رسولكم﴾</span> يعني: موسى <span class="qpc-hafs">﴿الذي أرسل إليكم لمجنون﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿قال فرعون وما رب العالمين﴾</span> قال: يَسْتَوْصِفُه اللهُ الذي أرسله إليه، أي: ما إلهك هذا؟ <span class="qpc-hafs">﴿قال لمن حوله﴾</span> مِن مَلَئِه: <span class="qpc-hafs">﴿ألا تستمعون﴾</span> أي: إنكارًا لِما قال أن ليس إلهًا غيري. <span class="qpc-hafs">﴿قال ربكم ورب آبائكم الاولين﴾</span> أي: وخلق آباءكم الأولين، وخلقكم مِن آبائكم، <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿إن رسولكم الذي أرسل اليكم لمجنون﴾</span> أي: ما هذا الكلام صحيح أن يزعم أنّ لكم إلهًا غيري{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال فرعون وما رب العالمين (٢٣) قال﴾</span> موسى: <span class="qpc-hafs">﴿رب السموات والأرض وما بينهما إن كنتم موقنين (٢٤) قال﴾</span> فرعون <span class="qpc-hafs">﴿لمن حوله ألا تستمعون﴾</span> أي: إلى ما يقول. قال موسى: <span class="qpc-hafs">﴿ربكم ورب آبائكم الأولين﴾</span> جوابًا لقوله في أول الكلام: <span class="qpc-hafs">﴿وما رب العالمين﴾</span>؟ قال فرعون: <span class="qpc-hafs">﴿إن رسولكم الذي أرسل إليكم﴾</span> في ما يَدَّعي <span class="qpc-hafs">﴿لمجنون﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:رَغَمًا: ذلًا. اللسان (رغم).|2:أخرجه ابن أبي حاتم ٨/٢٧٥٦.|3:تفسير الثعلبي ٧/١٦٢، وتفسير البغوي ٦/١١١.|4:أخرجه إسحاق البستي في تفسيره ص٥٣٢.|5:أخرجه ابن أبي حاتم ٨/٢٧٥٦.|6:تفسير مقاتل بن سليمان ٣/٢٦١.|7:أخرجه ابن أبي حاتم ٨/٢٧٥٦-٢٧٥٧.|8:تفسير يحيى بن سلام ٢/٥٠٠.
  26,24,""
  26,25,""
  26,26,""
  26,27,""
  26,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبُّ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ وَمَا بَیۡنَهُمَاۤۖ إِن كُنتُمۡ تَعۡقِلُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿رب المشرق والمغرب﴾</span>، قال: عدد أيام السنة لها كل يوم مطلع ومغرب، لا ترجع إلى مطلعها ذلك إلى يوم القيامة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٢٩<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق أبي إسرائيل- في قوله: <span class="qpc-hafs">﴿رب المشرقين ورب المغربين﴾</span> [الرحمن:١٧]، قال: الشمس تطلع في الشتاء وتغرب، لها مغرب في الصيف ومطلع. وفي قوله: <span class="qpc-hafs">﴿رب المشرق والمغرب﴾</span>، قال: لها كل يوم مطلع ومغرب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: هو <span class="qpc-hafs">﴿رب المشرق والمغرب﴾</span> يعني: مشرق ومغرب يومٍ، يستوي الليل والنهار في السنة يومين، ويسمى البرج: الميزان. ثم قال: <span class="qpc-hafs">﴿وما بينهما﴾</span> يعني: ما بين المشرق والمغرب من جبل، أو بناء، أو شجر، أو شيء؛ <span class="qpc-hafs">﴿إن كنتم تعقلون﴾</span> توحيد الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿قال رب المشرق والمغرب﴾</span> أي: خالق المشرق والمغرب، <span class="qpc-hafs">﴿وما بينهما﴾</span> أي: خالق ما بينهما مِن الخَلْق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٢<span class="dash">-</span></span> عن أصبغ بن الفرج، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> في قوله: <span class="qpc-hafs">﴿تعقلون﴾</span>: يتفكرون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿رب المشرق والمغرب وما بينهما إن كنتم تعقلون﴾</span>. وهذا تبع للكلام الأول: <span class="qpc-hafs">﴿وما رب العالمين﴾</span>{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو الشيخ في العظمة ٤/١١٩٩ (٦٧٠).|2:أخرجه أبو الشيخ في العظمة ٤/١١٩٨ (٦٦٧).|3:تفسير مقاتل بن سليمان ٣/٢٦١.|4:أخرجه ابن أبي حاتم ٨/٢٧٥٦-٢٧٥٧.|5:أخرجه ابن أبي حاتم ٨/٢٧٥٧.|6:تفسير يحيى بن سلام ٢/٥٠٠.
  26,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَىِٕنِ ٱتَّخَذۡتَ إِلَـٰهًا غَیۡرِی لَأَجۡعَلَنَّكَ مِنَ ٱلۡمَسۡجُونِینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٣٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان سجنُه أشدَّ مِن القتل؛ لأنّه كان يأخذ الرجل فيطرحه في مكان وحده فردًا، لا يسمع ولا يُبْصِر فيه شيئًا، يهوي به في الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿لئن اتخذت إلها غيري﴾</span> يعني: ربًّا <span class="qpc-hafs">﴿لأجعلنك من المسجونين﴾</span> يعني: مِن المحبوسين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿قال لئن اتخذت الها غيري لأجعلنك من المسجونين﴾</span>: أي: إن أقمت على هذا أن تعبد غيري، وتترك عبادتي؛ لأجعلنك من المسجونين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿لئن اتخذت إلها غيري لأجعلنك من المسجونين﴾</span> لأخلدنك في السجن{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/١٦٢، وتفسير البغوي ٦/١١١.|2:تفسير مقاتل بن سليمان ٣/٢٦١.|3:أخرجه ابن أبي حاتم ٨/٢٧٥٧.|4:تفسير يحيى بن سلام ٢/٥٠٠.
  26,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَوَلَوۡ جِئۡتُكَ بِشَیۡءࣲ مُّبِینࣲ ۝٣٠ قَالَ فَأۡتِ بِهِۦۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- قال: لقد دخل موسى على فرعون وعليه زُرْمانِقةٌ{1} مِن صوفٍ، ما تجاوِزُ مِرْفَقَه، فاستُؤْذِن على فرعون، فقال: أدْخِلوه. فدخل، فقال: إنّ إلهي أرسلني إليك. فقال للقوم حوله: ما علمتُ لكم من إله غيري، خذوه. قال: إنِّي قد جئتُك بآية. قال: <span class="qpc-hafs">﴿فائت به إن كنتَ من الصادقين﴾</span>{2}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين قال﴾</span> فرعون: <span class="qpc-hafs">﴿فأت به إن كنت من الصادقين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثم قال له فرعون: <span class="qpc-hafs">﴿إنْ كُنْتَ جِئْتَ بِآيَةٍ فَأْتِ بِها إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span> [الأعراف:١٠٦]. وذلك بعدما قال الله مِن الكلام ما ذكر الله، قال له موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين﴾</span> يعني: بأمر بيِّن، يعني: اليد والعصا، يستبين لك أمري فتصدقني. <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿فأت به إن كنت من الصادقين﴾</span> بأنّك رسول رب العالمين إلينا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿قال أولو جئتك بشيء مبين﴾</span>: أي: بأمر تعرف به صِدْقي وكَذِبك، وحَقِّي وباطلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال له موسى: <span class="qpc-hafs">﴿أولو جئتك بشيء مبين﴾</span> بيِّن، <span class="qpc-hafs">﴿قال فأت به إن كنت من الصادقين﴾</span>{7}. (ز)</p></p><p></div></p></div>",footnotes:1:الزُّرْمانقة: جُبَّة من صوف، أعجمي معرب. المعرب ص٢١٩، واللسان (زرمق).|2:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٥٣، ٢٧٥٧.|3:أخرجه ابن أبي حاتم ٨/٢٧٥٧.|4:أخرجه ابن أبي حاتم ٨/٢٧٥٧.|5:تفسير مقاتل بن سليمان ٣/٢٦١.|6:أخرجه ابن أبي حاتم ٨/٢٧٥٧.|7:تفسير يحيى بن سلام ٢/٥٠٠.
  26,31,""
  26,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَلۡقَىٰ عَصَاهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فألقى عصاه﴾</span>، وفى يد موسى ﵇ عصاه، وكانت من الآس{1}.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: إنّ جبريل دفع العصا إلى موسى ﵉ بالليل حين تَوَجَّه إلى مدين، وكان آدم ﵇ أُخْرِج بالعصا من الجنة، فلمّا مات آدمُ قبضها جبريل ﵇، فقال موسى لفرعون: ما هذه بيدي؟ قال فرعون: هذه عصا. فألقاها موسى مِن يده{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هِیَ ثُعۡبَانࣱ مُّبِینࣱ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، قال: الحيَّة الذَّكَر{3}. (٦/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- يعني: قوله: <span class="qpc-hafs">﴿فالقى عصاه فاذا هي ثعبان مبين﴾</span>، قال: فألقى عصاه فصارت ثعبانًا، ما بين لحييه ما بين الشفق إلى الأرض{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شهر بن حوشب- في قوله: <span class="qpc-hafs">﴿فألقى عصاه فإذا هي ثعبان مبين﴾</span> يقول: مبين له خَلْقُ حيةٍ{5}، <span class="qpc-hafs">﴿ونزع يده﴾</span> يقول: وأخرج موسى يده من جيبه، <span class="qpc-hafs">﴿فإذا هي بيضاء﴾</span> تلمع <span class="qpc-hafs">﴿للناظرين﴾</span> لِمَن ينظر إليها ويراها{6}. (١١/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: <span class="qpc-hafs">﴿فألقى عصاه﴾</span>، فتحوَّلَت حية عظيمة، فاغرة فاها، مسرعةً إلى فرعون، فلما رأى فرعونُ أنّها قاصِدةً إليه خافها؛ فاقتحم عن سريره، واستغاث بموسى أن يَكُفَّها عنه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق عبد الصمد بن معقل- قال: لَمّا دخل موسى على فرعون قال له موسى: أُعَرِّفُك؟ قال: نعم. قال: <span class="qpc-hafs">﴿ألم نربك فينا وليدا﴾</span>. قال: فردَّ إليه موسى الذي ردَّ، فقال فرعون: خذوه. فبادره موسى فألقى عصاه، فإذا هي ثعبان مبين، فحملت على الناسِ، فانهزموا منها، فمات منهم خمسة وعشرون ألفًا، قتل بعضُهم بعضًا، وقام فرعون مُنهزمًا حتى دخل البيت{8}<span class=comment-ref>٤٧٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٠</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (٦/٣٦٠) على رواية وهب فقال: «رواه ابن جرير، والإمام أحمد في كتابه الزهد، وابن أبي حاتم. وفيه غرابة في سياقه».</div></p><p><div></p><p><p><span class="item-no">٥٥٧٥١<span class="dash">-</span></span> عن <span class="name-2">المنهال [بن عمرو]</span> -من طريق الأعمش- قال: ارتفعت الحيَّةُ في السماء قدر مِيل، ثم سفلت حتى صار رأسُ فرعون بين نابَيْها، فجعلت تقول: يا موسى، مُرْنِي بما شئتَ. فجعل فرعون يقول: يا موسى، أسألك بالذي أرسلك. قال: فأخذه بطنُه{9}{10}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: أقبل موسى إلى أهله، فسار بهم نحو مصر حتى أتاها ليلًا، فتَضَيَّف على أُمِّه، وهو لا يعرفهم، في ليلةٍ كانوا يأكلون منها الطَفَيْشَلَ{11}، فنزل في جانب الدار، فجاء هارون، فلمّا أبصر ضيفه سأل عنه أُمَّه، فأخبرته أنّه ضيفٌ، فدعاه، فأكل معه، فلمّا قعدا فتحدَّثا، فسأله هارون: مَن أنت؟ قال: أنا موسى. فقام كلُّ واحدٍ منهما إلى صاحبه، فاعتنقه، فلمّا أن تعارفا قال له موسى: يا هارون، انطلق معي إلى فرعون؛ فإن الله قد أرسلنا إليه. قال هارون: سمعًا وطاعةً. فقامت أمُّهما، فصاحت، وقالت: أنشدكما بالله ألا تذهبا إلى فرعون فيقتلكما. فأبَيا، فانطلقا إليه ليلًا، فأتيا الباب، فضرباه، ففزع فرعون، وفزع البوّاب، فقال فرعون: مَن هذا الذي يضرب بابي هذه الساعة؟ فأشرف عليهما البوابُ، فكلمهما، فقال له موسى: <span class="qpc-hafs">﴿إنا رسول رب العالمين﴾</span>. ففزع البواب، فأتى فرعونَ، فأخبره، فقال: إنّ ههنا إنسانًا مجنونًا يزعم أنّه رسول رب العالمين. فقال: أدخِله. فدخل، فقال: إني رسول رب العالمين. قال فرعون: <span class="qpc-hafs">﴿وما رب العالمين﴾</span>. قال: <span class="qpc-hafs">﴿ربنا الذي أعطى كل شيء خلقه ثم هدى﴾</span> [طه:٥٠]. قال: <span class="qpc-hafs">﴿إن كنت جئت بآية فأت بها إن كنت من الصادقين فألقى عصاه فإذا هي ثعبان مبين﴾</span> [الأعراف:١٠٦-١٠٧]. والثعبان: الذَّكَر مِن الحيّات، فاتحةً فمَها، واضِعةً لحيها الأسفل في الأرض، والأعلى على سور القصر، ثم توجهت نحو فرعون لتأخذه، فلما رآها ذعر منها، ووثب، فأحدث، ولم يكن يُحْدِث قبل ذلك، وصاح: يا موسى، خذها، وأنا أومن بك، وأُرسِلُ معك بني إسرائيل. فأخذها موسى، فصارت عصًا، فقالت السَّحَرة في نجواهم: <span class="qpc-hafs">﴿إن هذان لساحران يريدان أن يخرجاكم من أرضكم بسحرهما﴾</span> [طه:٦٣]. فالتقى موسى وأميرُ السحرة، فقال له موسى: أرأيت إن غلبتُك غدًا أتُؤْمِنُ بي، وتشهد أنّ ما جئتُ به حقٌّ؟ قال الساحر: لآتين غدًا بسحرٍ لا يغلبه سِحرٌ، فواللهِ، لئن غلبتني لأؤمِنَنَّ لك، ولأشهدن أنّك حقٌّ. وفرعون ينظر إليهما{12}. (١١/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، يعني: حيَّة ذكر، أصفر، أشعر العنق، عظيم، ملأ الدار عَظْمًا، قائِمٌ على ذَنَبه، يَتَلَمَّظُ{13} على فرعون وقومه يتوعدهم، قال فرعون: خُذها، يا موسى. مخافة أن تبتلعه، فأخذ بذَنَبها، فصارت عصًا مثل ما كانت{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فالقى عصاه فاذا هي ثعبان مبين﴾</span>: فمكث ما بين سِماطَي{15} فرعون، فاتحةً فاها، قد كان محجنها عُرْفًا{16} على ظهرها، فَرَفَضَ{17} عنها الناس، وحال فرعون عن سريره، وجعلت تَلَظّى{18}، وتعلو على جنب قصر فرعون، ثم ترجع إلى موسى فَتُبَصْبِصُ{19} حوله، وتستدير به{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فألقى عصاه فإذا هي ثعبان مبين﴾</span> حية، أشعر، ذكر، يكاد يَسْرِطُ{21} فرعون، غرزت ذنبها في الأرض، ورفعت صدرها ورأسها، وأَهْوَت إلى عدوِّ الله لتأخذه، فجعل يميل، ويقول: يا موسى، خذها، يا موسى، خذها. فأخذها موسى. قال: <span class="qpc-hafs">﴿ونزع يده﴾</span> أدخل يدَه في جيب قميصه ثم أخرجها، فهو قوله: <span class="qpc-hafs">﴿ونزع يده﴾</span> أي: أخرج يده، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span> يغشى البصر مِن بياضها{22}. (ز)</p></p><p></div></p></div>",footnotes:1:الآس: نوع من الشجر. اللسان (أسس).|2:تفسير مقاتل بن سليمان ٣/٢٦٢.</p><p>وتقدمت الآثار مفصلة عن عصا موسى وخبرها عند تفسير قوله تعالى: <span class="qpc-hafs">﴿فَأَلْقى عَصاهُ فَإذا هِيَ ثُعْبانٌ مُبِينٌ﴾</span> [الأعراف:١٠٧]، وقوله تعالى: <span class="qpc-hafs">﴿قالَ هِيَ عَصايَ أتَوَكَّأُ عَلَيْها وأَهُشُّ بِها عَلى غَنَمِي ولِيَ فِيها مَآرِبُ أُخْرى﴾</span> [طه:١٨].|3:أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨ من طريق الضحاك. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|4:أخرجه ابن أبي حاتم ٨/٢٧٥٩.|5:يبدو أن ما بعد هذا من كلام ابن جرير، حيث يفصل بينهما لفظ «وقوله: <span class="qpc-hafs">﴿ونزع يده﴾</span>» كما جاء في الأصل، وتصرف محققيه يشعر بذلك.|6:أخرجه ابن جرير ١٧/٥٦٥-٥٦٦.|7:أخرجه ابن جرير ١٠/٣٤٤، وابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|8:أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢.|9:فأخذه بطنه: أحدث. كما في أثر السدي الذي يلي هذا الأثر.|10:أخرجه ابن جرير ١٧/٥٦٦. وعزاه السيوطي إلى أبي الشيخ.|11:الطفيشل -بالمعجمة كسميدع-، قال ابن عباد: نوع من المرق معروف. تاج العروس (طفشل).|12:أخرجه ابن أبي حاتم ٨/٢٧٥٦، ٢٧٥٩ مختصرًا من طريق أسباط.|13:يَتَلَمَّظ: يُدِير لِسانه في فيه ويُحَرِّكُه. النهاية (لمظ).|14:تفسير مقاتل بن سليمان ٣/٢٦٢.|15:سِماطَي: السٍّماط: الجماعة من الناس والنخل. والمعنى: الجماعة الذين كانوا جلوسًا على الجانبين. النهاية واللسان (سمط).|16:عُرْف الدِّيك والفَرَس والدّابّة وغيرها: مَنبِت الشعرِ والرِّيش من العُنق. اللسان (عرف).|17:أي: تفرّقوا. النهاية واللسان (رفض).|18:يُقال: فلان يتلظّى على فلان تَلظِّيًا: إذا تَوَقَّد عَلَيْه مِن شدَّة الغضب. اللسان (لظي).|19:أي: تحرّك ذَنَبها. النهاية (بصبص)، واللسان (بصص).|20:أخرجه ابن أبي حاتم ٨/٢٧٥٩.|21:يَسْرِط: يبتلع. اللسان (سرط).|22:تفسير يحيى بن سلام ٢/٥٠١.
  26,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَزَعَ یَدَهُۥ فَإِذَا هِیَ بَیۡضَاۤءُ لِلنَّـٰظِرِینَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿بَيْضاءُ لِلنّاظِرِينَ﴾</span>: مِن غير برص{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿ونزع يده﴾</span> قال: فأخرج يدَه مِن جيبه، <span class="qpc-hafs">﴿فاذا هي بيضاء للناظرين﴾</span> قال: أخرج يده مِن جيبه فرآها بيضاء مِن غير سوء، يعني به: البرص، ثم أعادها في كُمِّه، فصارت إلى لونها الأول{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- قوله: <span class="qpc-hafs">﴿ونزع يده فاذا هي بيضاء للناظرين﴾</span>، قال: فأدخل يده في جيبه، فأخرجها مثلَ البرق تلتمع الأبصار، فخَرُّوا على وجوههم، وأخذ موسى عصاه ثم خرج ليس أحد من الناس إلا يَفِرُّ منه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٥٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ونَزَعَ يَدَهُ﴾</span>: أخرجها من جيبه <span class="qpc-hafs">﴿فَإذا هِيَ بَيْضاءُ لِلنّاظِرِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي سعد- في قوله: <span class="qpc-hafs">﴿ونزع يده﴾</span> قال: نزع يده من جيبه، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span> وكان موسى رجلًا آدَمَ، فأخرج يده، فإذا هي بيضاء أشد بياضًا من اللبن، <span class="qpc-hafs">﴿من غير سوء﴾</span> [طه:٢٢]، قال: من غير برص، آية لفرعون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة بن خالد- قال: أخرجها -واللهِ- كأنّها مِصباح{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال فرعون: هل مِن آية أخرى غيرها؟ قال موسى: نعم. فأبرز يده، قال لفرعون: ما هذه؟ قال فرعون: هذه يدُك. فأدخلها في جيبه، وهي مِدْرعة{7} مصرية مِن صوف، <span class="qpc-hafs">﴿ونزع يده﴾</span> يعني: أخرج يده مِن المدرعة، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span> لها شعاع مثلُ شعاع الشمس مِن شِدَّة بياضها، يَغْشى البَصَر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثم أدخل يده في جيبه، فأخرجها بيضاء مثل الثلج، ثم ردَّها، فرجعت كهيئتها، وأدخل موسى يدَه في جيبه، فصارت عصًا بيده، يده بين شعبتيها ومحجنها في أسفلها كما كان، وأخذ فرعون بطنه، فكان -فيما يزعمون- يمكث الخميس والسبت ما يلتمس المذهب كما كان يلتمسه الناس، وكان ذلك مما زَيَّن له أن يقول: إنه ليس له في الناس شبيه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ونزع يده﴾</span> أدخل يده في جيب قميصه ثم أخرجها، فهو قوله: <span class="qpc-hafs">﴿ونزع يده﴾</span> أي: أخرج يده، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span> يغشى البصر من بياضها{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٤٦.|2:أخرجه ابن جرير ١٠/٣٤٦، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٥٩.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٠.|4:أخرجه ابن جرير ١٠/٣٤٧.|5:تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٤٧.|6:أخرجه يحيى بن سلام ٢/٥٠١.|7:المِدْرَعة: ضَرْبٌ مِن الثّياب لا يكون إلا من الصُّوفِ خاصَّة. اللسان (درع).|8:تفسير مقاتل بن سليمان ٣/٢٦٢.|9:أخرجه ابن أبي حاتم ٨/٢٧٦٠.|10:تفسير يحيى بن سلام ٢/٥٠١.
  26,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لِلۡمَلَإِ حَوۡلَهُۥۤ إِنَّ هَـٰذَا لَسَـٰحِرٌ عَلِیمࣱ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم-: فلمّا أفاق، وذهب عن فرعون الرَّوْعُ؛ <span class="qpc-hafs">﴿قال للملإ حوله﴾</span>: ماذا تأمرون؟{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون <span class="qpc-hafs">﴿للملإ﴾</span> يعني: الأشراف <span class="qpc-hafs">﴿حوله إن هذا﴾</span> يعني: موسى <span class="qpc-hafs">﴿لساحر عليم﴾</span> بالسِّحْر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فقال للملإ حوله﴾</span>: قال لملئه: <span class="qpc-hafs">﴿إن هذا لساحر عليم﴾</span> أي: ما ساحر أسحرَ منه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال للملإ حوله﴾</span> فرعون يقوله: <span class="qpc-hafs">﴿إن هذا لساحر عليم﴾</span> بالسحر{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٠.|2:تفسير مقاتل بن سليمان ٣/٢٦٢.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٠.|4:تفسير يحيى بن سلام ٢/٥٠١.
  26,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُرِیدُ أَن یُخۡرِجَكُم مِّنۡ أَرۡضِكُم بِسِحۡرِهِۦ فَمَاذَا تَأۡمُرُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٦٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿يريد ان يخرجكم من أرضكم بسحره﴾</span>، قال: يستخرجكم مِن أرضكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يريد أن يخرجكم من أرضكم﴾</span> يعني: مصر <span class="qpc-hafs">﴿بسحره فماذا تأمرون﴾</span> يقول: فماذا تُشِيرون عليَّ؟{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿فماذا تأمرون﴾</span> أأقتله؟{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يريد أن يخرجكم من أرضكم بسحره فماذا تأمرون﴾</span> فأراد قتله، فقال له صاحبُه: لا تقتله؛ فإنما هو ساحر، ومتى ما تقتله أدخلت على الناس في أمره شبهة، ولكن <span class="qpc-hafs">﴿أرجه وأخاه﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٠.|2:تفسير مقاتل بن سليمان ٣/٢٦٢.|3:أخرجه ابن أبي حاتم ٨/٢٧٦١.|4:تفسير يحيى بن سلام ٢/٥٠١.
  26,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَرۡجِهۡ وَأَخَاهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- <span class="qpc-hafs">﴿قالوا أرجه وأخاه﴾</span>: لا تَأْتِنا به، ولا يقربنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿قالوا أرجه وأخاه﴾</span>، يقول: أخِّره وأخاه{2}. (٦/ ٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قالوا أرجه وأخاه﴾</span>، قال: احْبِسْه وأخاه{3}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٦<span class="dash">-</span></span> قال يحيى بن سلّام: <span class="qpc-hafs">﴿أرجه وأخاه﴾</span> أخِّره وأخاه، فإنما هو ساحر، ومتى ما تقتله [أدخلت على الناس في أمره شبهة]، في تفسير <span class="name-2">الحسن البصري</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فردَّ عليه الملأُ مِن قومه، يعني: الأشراف، <span class="qpc-hafs">﴿قالوا أرجه وأخاه﴾</span> يقول: احبسهما جميعًا، ولا تقتلهما، حتى ننظر ما أمرهما{5}<span class=comment-ref>٤٧٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩١</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٠/٣٤٩): «يقول -تعالى ذِكْرُه-: قال الملأ من قوم فرعون لفرعون: أرجئه: أي: أخره. وقال بعضهم: معناه: احبس. والإرجاء <span class="mustanad">في كلام العرب</span>: التأخير، يُقال منه: أرجيت هذا الأمر وأرجأته إذا أخرته، <span class="mustanad">ومنه قول الله تعالى</span>: <span class="qpc-hafs">﴿ترجي من تشاء منهن﴾</span> [الأحزاب:٥١]: تُؤَخِّر».</div></p><p><h3><span class="qpc-hafs">﴿وَٱبۡعَثۡ فِی ٱلۡمَدَاۤىِٕنِ حَـٰشِرِینَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي مالك - في قوله: <span class="qpc-hafs">﴿وأرسل في المدائن حاشرين﴾</span> [الأعراف:١١١]، قال: الشُّرَط{6}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: قالوا لفرعون: اجمع لهم السحرة، فإنهم بأرضك كثير، حتى تغلب بسحرهم سحرَهما{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن مهاجر، عن أبيه- <span class="qpc-hafs">﴿وابعث في المدائن حاشرين﴾</span>، قال: الشُّرَط{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم بن المهاجر</span> -من طريق قيس بن ربيع- في قوله تعالى: <span class="qpc-hafs">﴿في المدائن حاشرين﴾</span>، قال: الشُّرَط{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق قيس- <span class="qpc-hafs">﴿وابعث في المدائن حاشرين﴾</span>، قال: الشُّرَط{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وابعث في المدآئن﴾</span> يعني: في القُرى <span class="qpc-hafs">﴿حاشرين﴾</span> يحشرون عليك السَّحَرة. فذلك قوله سبحانه: <span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وابعث في المدائن حاشرين﴾</span>، يحشرون عليك السحرة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦١.|2:أخرجه ابن جرير ١٠/٣٥٠، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٦١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|3:أخرجه ابن جرير ١٠/٣٥١، وابن أبي حاتم ٥/١٥٣٣ من طريق همام. وعلَّقه يحيى بن سلام ٢/٥٠١. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير يحيى بن سلام ٢/٥٠١.|5:تفسير مقاتل بن سليمان ٣/٢٦٢.|6:أخرجه ابن جرير ١٠/٣٥١-٣٥٢، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦١ من طريق مجاهد. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|7:أخرجه ابن أبي حاتم ٨/٢٧٦١.|8:أخرجه ابن جرير ١٠/٣٥١. وعلَّقه ابن أبي حاتم ٨/٢٧٦١.|9:ذكره الحافظ في المطالب العالية (إشراف: د. سعد الشثري) ١٥/٧٧ (٣٦٧٤).|10:أخرجه ابن جرير ١٠/٣٥١.|11:تفسير مقاتل بن سليمان ٣/٢٦٢.|12:تفسير يحيى بن سلام ٢/٥٠١.
  26,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَأۡتُوكَ بِكُلِّ سَحَّارٍ عَلِیمࣲ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قوله: <span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span>، قال: فحشر له كل سحّار مُتعالِم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- قوله: <span class="qpc-hafs">﴿وابعث في المدائن حاشرين﴾</span>: فإنّما هذا ساحر. فأرسل فرعون في المدائن حاشرين، وكانت السحرةُ يَخشَون مِن فرعون، فلمّا أرسَل إليهم قالوا: قد احتاج إليكم إلهُكم{2}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span>، قال: فحشروا السَّحَرة، وحشر الناس ينظرون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span>، يعني: عالم بالسحر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٨٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿أرجه وأخاه وأرسل في المدائن حاشرين يأتوك بكل سحار عليم﴾</span>: أي: كاثِرْه بالسَّحَرة، لعلك أن تجد في السَّحرة مَن يأتي بمثل ما جاء به، وقد كان موسى وهارون خرجا مِن عنده حين أراهم مِن سلطان الله ما أراهم، وبعث فرعونُ في مملكته مكانَه، فلم يترك في سلطانه ساحِرٌ إلا أتى به{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span> بالسحر{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٢.|2:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦١.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٢.|4:تفسير مقاتل بن سليمان ٣/٢٦٢.|5:أخرجه ابن جرير ١٠/٣٥٤.|6:تفسير يحيى بن سلام ٢/٥٠١.
  26,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَجُمِعَ ٱلسَّحَرَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ- قال: كان السحرة سبعين رجلًا{1}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٢<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق أبي سودة - قال: كان سَحرةُ فرعون اثني عشر ألفًا{2}. (٦/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فجمع السحرة لميقات يوم معلوم﴾</span>، وهم اثنان وسبعون ساحرًا مِن أهل فارس، وبقيتهم مِن بني إسرائيل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة - قال: جُمِع له خمسة عشر ألف ساحرٍ{4}. (٦/٤٩٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِمِیقَـٰتِ یَوۡمࣲ مَّعۡلُومࣲ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: وافق ذلك اليوم يومَ السبت، في أول يوم من السنة، وهو يوم النيروز{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فجمع السحرة لميقات يوم معلوم﴾</span>، يعني: مُوَقَّت، وهو يوم عيدهم، وهو يوم الزينة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: وكان اجتماعهم للميقات بالإسكندرية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٧٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿فجمع السحرة لميقات يوم معلوم﴾</span>، وهو قوله: <span class="qpc-hafs">﴿موعدكم يوم الزينة﴾</span> [طه:٥٩]، يوم عيد لهم، كان يجتمع فيه أهل القرى والناس، فأراد موسى أن يفضحه على رؤوس الناس{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٦٤، وابن أبي حاتم ٥/١٥٣٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|2:أخرجه ابن جرير ١٠/٣٥٥، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وأبي الشيخ.|3:تفسير مقاتل بن سليمان ٣/٢٦٣.|4:أخرجه ابن جرير ١٠/٣٥٤، وابن أبي حاتم ٨/٢٧٦٢. وتقدمت الآثار مفصلة في عدد سحرة فرعون وذلك عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وجاءَ السَّحَرَةُ فِرْعَوْنَ قالُوا إنَّ لَنا لَأَجْرًا إنْ كُنّا نَحْنُ الغالِبِينَ﴾</span> [الأعراف:١١٣].|5:تفسير الثعلبي ٧/١٦٣، وتفسير البغوي ٦/١١٢.|6:تفسير مقاتل بن سليمان ٣/٢٦٣.|7:تفسير الثعلبي ٧/١٦٣.|8:تفسير يحيى بن سلام ٢/٥٠١.
  26,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقِیلَ لِلنَّاسِ هَلۡ أَنتُم مُّجۡتَمِعُونَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٧٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وقيل للناس هل أنتم مجتمعون﴾</span>، يقول: حُشِر الناس ينظرون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقيل للناس﴾</span> يعني: لأهل مصر: <span class="qpc-hafs">﴿هل أنتم مجتمعون﴾</span> إلى السَّحَرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقيل للناس﴾</span> قاله بعضهم لبعض: <span class="qpc-hafs">﴿هل أنتم مجتمعون﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٢.|2:تفسير مقاتل بن سليمان ٣/٢٦٣.|3:تفسير يحيى بن سلام ٢/٥٠٢.