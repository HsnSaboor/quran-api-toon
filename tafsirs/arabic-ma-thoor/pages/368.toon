26,28," <q>﴿قَالَ رَبُّ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ وَمَا بَیۡنَهُمَاۤۖ إِن كُنتُمۡ تَعۡقِلُونَ ۝٢٨﴾</q> - تفسير ٥٥٧٢٨- عن مجاهد بن جبر -من طريق ليث- <q>﴿رب المشرق والمغرب﴾</q>، قال: عدد أيام السنة لها كل يوم مطلع ومغرب، لا ترجع إلى مطلعها ذلك إلى يوم القيامة{1}. (ز) ٥٥٧٢٩- عن عطية العوفي -من طريق أبي إسرائيل- في قوله: <q>﴿رب المشرقين ورب المغربين﴾</q> [الرحمن:١٧]، قال: الشمس تطلع في الشتاء وتغرب، لها مغرب في الصيف ومطلع. وفي قوله: <q>﴿رب المشرق والمغرب﴾</q>، قال: لها كل يوم مطلع ومغرب{2}. (ز) ٥٥٧٣٠- قال مقاتل بن سليمان: <q>﴿قال﴾</q> موسى: هو <q>﴿رب المشرق والمغرب﴾</q> يعني: مشرق ومغرب يومٍ، يستوي الليل والنهار في السنة يومين، ويسمى البرج: الميزان. ثم قال: <q>﴿وما بينهما﴾</q> يعني: ما بين المشرق والمغرب من جبل، أو بناء، أو شجر، أو شيء؛ <q>﴿إن كنتم تعقلون﴾</q> توحيد الله ﷿{3}. (ز) ٥٥٧٣١- عن محمد بن إسحاق -من طريق سلمة- في قوله: <q>﴿قال رب المشرق والمغرب﴾</q> أي: خالق المشرق والمغرب، <q>﴿وما بينهما﴾</q> أي: خالق ما بينهما مِن الخَلْق{4}. (ز) ٥٥٧٣٢- عن أصبغ بن الفرج، قال: سمعت عبد الرحمن بن زيد بن أسلم في قوله: <q>﴿تعقلون﴾</q>: يتفكرون{5}. (ز) ٥٥٧٣٣- قال يحيى بن سلّام: <q>﴿قال﴾</q> موسى: <q>﴿رب المشرق والمغرب وما بينهما إن كنتم تعقلون﴾</q>. وهذا تبع للكلام الأول: <q>﴿وما رب العالمين﴾</q>{6}. (ز) ",footnotes:1:أخرجه أبو الشيخ في العظمة ٤/١١٩٩ (٦٧٠).أخرجه أبو الشيخ في العظمة ٤/١١٩٨ (٦٦٧).تفسير مقاتل بن سليمان ٣/٢٦١.أخرجه ابن أبي حاتم ٨/٢٧٥٦-٢٧٥٧.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير يحيى بن سلام ٢/٥٠٠.
26,29," <q>﴿قَالَ لَىِٕنِ ٱتَّخَذۡتَ إِلَـٰهًا غَیۡرِی لَأَجۡعَلَنَّكَ مِنَ ٱلۡمَسۡجُونِینَ ۝٢٩﴾</q> - تفسير ٥٥٧٣٤- قال محمد بن السائب الكلبي: كان سجنُه أشدَّ مِن القتل؛ لأنّه كان يأخذ الرجل فيطرحه في مكان وحده فردًا، لا يسمع ولا يُبْصِر فيه شيئًا، يهوي به في الأرض{1}. (ز) ٥٥٧٣٥- قال مقاتل بن سليمان: <q>﴿قال﴾</q> فرعون: <q>﴿لئن اتخذت إلها غيري﴾</q> يعني: ربًّا <q>﴿لأجعلنك من المسجونين﴾</q> يعني: مِن المحبوسين{2}. (ز) ٥٥٧٣٦- عن محمد بن إسحاق -من طريق سلمة- في قوله: <q>﴿قال لئن اتخذت الها غيري لأجعلنك من المسجونين﴾</q>: أي: إن أقمت على هذا أن تعبد غيري، وتترك عبادتي؛ لأجعلنك من المسجونين{3}. (ز) ٥٥٧٣٧- قال يحيى بن سلّام: <q>﴿قال﴾</q> فرعون: <q>﴿لئن اتخذت إلها غيري لأجعلنك من المسجونين﴾</q> لأخلدنك في السجن{4}. (ز) ",footnotes:1:تفسير الثعلبي ٧/١٦٢، وتفسير البغوي ٦/١١١.تفسير مقاتل بن سليمان ٣/٢٦١.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير يحيى بن سلام ٢/٥٠٠.
26,30," <q>﴿قَالَ أَوَلَوۡ جِئۡتُكَ بِشَیۡءࣲ مُّبِینࣲ ۝٣٠ قَالَ فَأۡتِ بِهِۦۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٣١﴾</q> - تفسير ٥٥٧٣٨- عن عبد الله بن عباس -من طريق مِقْسَم- قال: لقد دخل موسى على فرعون وعليه زُرْمانِقةٌ{1} مِن صوفٍ، ما تجاوِزُ مِرْفَقَه، فاستُؤْذِن على فرعون، فقال: أدْخِلوه. فدخل، فقال: إنّ إلهي أرسلني إليك. فقال للقوم حوله: ما علمتُ لكم من إله غيري، خذوه. قال: إنِّي قد جئتُك بآية. قال: <q>﴿فائت به إن كنتَ من الصادقين﴾</q>{2}. (٦/٤٩٣) ٥٥٧٣٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قال﴾</q> موسى: <q>﴿أولو جئتك بشيء مبين قال﴾</q> فرعون: <q>﴿فأت به إن كنت من الصادقين﴾</q>{3}. (ز) ٥٥٧٤٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثم قال له فرعون: <q>﴿إنْ كُنْتَ جِئْتَ بِآيَةٍ فَأْتِ بِها إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</q> [الأعراف:١٠٦]. وذلك بعدما قال الله مِن الكلام ما ذكر الله، قال له موسى: <q>﴿أولو جئتك بشيء مبين﴾</q>{3}. (ز) ٥٥٧٤١- قال مقاتل بن سليمان: <q>﴿قال﴾</q> موسى: <q>﴿أولو جئتك بشيء مبين﴾</q> يعني: بأمر بيِّن، يعني: اليد والعصا، يستبين لك أمري فتصدقني. <q>﴿قال﴾</q> فرعون: <q>﴿فأت به إن كنت من الصادقين﴾</q> بأنّك رسول رب العالمين إلينا{5}. (ز) ٥٥٧٤٢- عن محمد بن إسحاق -من طريق سلمة- <q>﴿قال أولو جئتك بشيء مبين﴾</q>: أي: بأمر تعرف به صِدْقي وكَذِبك، وحَقِّي وباطلك{3}. (ز) ٥٥٧٤٣- قال يحيى بن سلّام: قال له موسى: <q>﴿أولو جئتك بشيء مبين﴾</q> بيِّن، <q>﴿قال فأت به إن كنت من الصادقين﴾</q>{7}. (ز) ",footnotes:1:الزُّرْمانقة: جُبَّة من صوف، أعجمي معرب. المعرب ص٢١٩، واللسان (زرمق).أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٥٣، ٢٧٥٧.أخرجه ابن أبي حاتم ٨/٢٧٥٧.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير مقاتل بن سليمان ٣/٢٦١.أخرجه ابن أبي حاتم ٨/٢٧٥٧.تفسير يحيى بن سلام ٢/٥٠٠.
  26,31,""
26,32," <q>﴿فَأَلۡقَىٰ عَصَاهُ﴾</q> - تفسير ٥٥٧٤٤- قال مقاتل بن سليمان: <q>﴿فألقى عصاه﴾</q>، وفى يد موسى ﵇ عصاه، وكانت من الآس{1}.= (ز) ٥٥٧٤٥- قال عبد الله بن عباس: إنّ جبريل دفع العصا إلى موسى ﵉ بالليل حين تَوَجَّه إلى مدين، وكان آدم ﵇ أُخْرِج بالعصا من الجنة، فلمّا مات آدمُ قبضها جبريل ﵇، فقال موسى لفرعون: ما هذه بيدي؟ قال فرعون: هذه عصا. فألقاها موسى مِن يده{2}. (ز) <q>﴿فَإِذَا هِیَ ثُعۡبَانࣱ مُّبِینࣱ ۝٣٢﴾</q> - تفسير ٥٥٧٤٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فإذا هي ثعبان مبين﴾</q>، قال: الحيَّة الذَّكَر{3}. (٦/٤٩٤) ٥٥٧٤٧- عن عبد الله بن عباس -من طريق مقسم- يعني: قوله: <q>﴿فالقى عصاه فاذا هي ثعبان مبين﴾</q>، قال: فألقى عصاه فصارت ثعبانًا، ما بين لحييه ما بين الشفق إلى الأرض{4}. (ز) ٥٥٧٤٨- عن عبد الله بن عباس -من طريق شهر بن حوشب- في قوله: <q>﴿فألقى عصاه فإذا هي ثعبان مبين﴾</q> يقول: مبين له خَلْقُ حيةٍ{5}، <q>﴿ونزع يده﴾</q> يقول: وأخرج موسى يده من جيبه، <q>﴿فإذا هي بيضاء﴾</q> تلمع <q>﴿للناظرين﴾</q> لِمَن ينظر إليها ويراها{6}. (١١/٢٤٢) ٥٥٧٤٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: <q>﴿فألقى عصاه﴾</q>، فتحوَّلَت حية عظيمة، فاغرة فاها، مسرعةً إلى فرعون، فلما رأى فرعونُ أنّها قاصِدةً إليه خافها؛ فاقتحم عن سريره، واستغاث بموسى أن يَكُفَّها عنه{7}. (ز) ٥٥٧٥٠- عن وهب بن منبه -من طريق عبد الصمد بن معقل- قال: لَمّا دخل موسى على فرعون قال له موسى: أُعَرِّفُك؟ قال: نعم. قال: <q>﴿ألم نربك فينا وليدا﴾</q>. قال: فردَّ إليه موسى الذي ردَّ، فقال فرعون: خذوه. فبادره موسى فألقى عصاه، فإذا هي ثعبان مبين، فحملت على الناسِ، فانهزموا منها، فمات منهم خمسة وعشرون ألفًا، قتل بعضُهم بعضًا، وقام فرعون مُنهزمًا حتى دخل البيت{8}٤٧٩٠. (ز) ٤٧٩٠ علّق ابنُ كثير (٦/٣٦٠) على رواية وهب فقال: «رواه ابن جرير، والإمام أحمد في كتابه الزهد، وابن أبي حاتم. وفيه غرابة في سياقه». ٥٥٧٥١- عن المنهال [بن عمرو] -من طريق الأعمش- قال: ارتفعت الحيَّةُ في السماء قدر مِيل، ثم سفلت حتى صار رأسُ فرعون بين نابَيْها، فجعلت تقول: يا موسى، مُرْنِي بما شئتَ. فجعل فرعون يقول: يا موسى، أسألك بالذي أرسلك. قال: فأخذه بطنُه{9}{10}. (٦/٤٩٣) ٥٥٧٥٢- عن إسماعيل السُّدِّيّ، قال: أقبل موسى إلى أهله، فسار بهم نحو مصر حتى أتاها ليلًا، فتَضَيَّف على أُمِّه، وهو لا يعرفهم، في ليلةٍ كانوا يأكلون منها الطَفَيْشَلَ{11}، فنزل في جانب الدار، فجاء هارون، فلمّا أبصر ضيفه سأل عنه أُمَّه، فأخبرته أنّه ضيفٌ، فدعاه، فأكل معه، فلمّا قعدا فتحدَّثا، فسأله هارون: مَن أنت؟ قال: أنا موسى. فقام كلُّ واحدٍ منهما إلى صاحبه، فاعتنقه، فلمّا أن تعارفا قال له موسى: يا هارون، انطلق معي إلى فرعون؛ فإن الله قد أرسلنا إليه. قال هارون: سمعًا وطاعةً. فقامت أمُّهما، فصاحت، وقالت: أنشدكما بالله ألا تذهبا إلى فرعون فيقتلكما. فأبَيا، فانطلقا إليه ليلًا، فأتيا الباب، فضرباه، ففزع فرعون، وفزع البوّاب، فقال فرعون: مَن هذا الذي يضرب بابي هذه الساعة؟ فأشرف عليهما البوابُ، فكلمهما، فقال له موسى: <q>﴿إنا رسول رب العالمين﴾</q>. ففزع البواب، فأتى فرعونَ، فأخبره، فقال: إنّ ههنا إنسانًا مجنونًا يزعم أنّه رسول رب العالمين. فقال: أدخِله. فدخل، فقال: إني رسول رب العالمين. قال فرعون: <q>﴿وما رب العالمين﴾</q>. قال: <q>﴿ربنا الذي أعطى كل شيء خلقه ثم هدى﴾</q> [طه:٥٠]. قال: <q>﴿إن كنت جئت بآية فأت بها إن كنت من الصادقين فألقى عصاه فإذا هي ثعبان مبين﴾</q> [الأعراف:١٠٦-١٠٧]. والثعبان: الذَّكَر مِن الحيّات، فاتحةً فمَها، واضِعةً لحيها الأسفل في الأرض، والأعلى على سور القصر، ثم توجهت نحو فرعون لتأخذه، فلما رآها ذعر منها، ووثب، فأحدث، ولم يكن يُحْدِث قبل ذلك، وصاح: يا موسى، خذها، وأنا أومن بك، وأُرسِلُ معك بني إسرائيل. فأخذها موسى، فصارت عصًا، فقالت السَّحَرة في نجواهم: <q>﴿إن هذان لساحران يريدان أن يخرجاكم من أرضكم بسحرهما﴾</q> [طه:٦٣]. فالتقى موسى وأميرُ السحرة، فقال له موسى: أرأيت إن غلبتُك غدًا أتُؤْمِنُ بي، وتشهد أنّ ما جئتُ به حقٌّ؟ قال الساحر: لآتين غدًا بسحرٍ لا يغلبه سِحرٌ، فواللهِ، لئن غلبتني لأؤمِنَنَّ لك، ولأشهدن أنّك حقٌّ. وفرعون ينظر إليهما{12}. (١١/٢٤٢) ٥٥٧٥٣- قال مقاتل بن سليمان: <q>﴿فإذا هي ثعبان مبين﴾</q>، يعني: حيَّة ذكر، أصفر، أشعر العنق، عظيم، ملأ الدار عَظْمًا، قائِمٌ على ذَنَبه، يَتَلَمَّظُ{13} على فرعون وقومه يتوعدهم، قال فرعون: خُذها، يا موسى. مخافة أن تبتلعه، فأخذ بذَنَبها، فصارت عصًا مثل ما كانت{14}. (ز) ٥٥٧٥٤- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فالقى عصاه فاذا هي ثعبان مبين﴾</q>: فمكث ما بين سِماطَي{15} فرعون، فاتحةً فاها، قد كان محجنها عُرْفًا{16} على ظهرها، فَرَفَضَ{17} عنها الناس، وحال فرعون عن سريره، وجعلت تَلَظّى{18}، وتعلو على جنب قصر فرعون، ثم ترجع إلى موسى فَتُبَصْبِصُ{19} حوله، وتستدير به{4}. (ز) ٥٥٧٥٥- قال يحيى بن سلّام: <q>﴿فألقى عصاه فإذا هي ثعبان مبين﴾</q> حية، أشعر، ذكر، يكاد يَسْرِطُ{21} فرعون، غرزت ذنبها في الأرض، ورفعت صدرها ورأسها، وأَهْوَت إلى عدوِّ الله لتأخذه، فجعل يميل، ويقول: يا موسى، خذها، يا موسى، خذها. فأخذها موسى. قال: <q>﴿ونزع يده﴾</q> أدخل يدَه في جيب قميصه ثم أخرجها، فهو قوله: <q>﴿ونزع يده﴾</q> أي: أخرج يده، <q>﴿فإذا هي بيضاء للناظرين﴾</q> يغشى البصر مِن بياضها{22}. (ز) ",footnotes:1:الآس: نوع من الشجر. اللسان (أسس).تفسير مقاتل بن سليمان ٣/٢٦٢. وتقدمت الآثار مفصلة عن عصا موسى وخبرها عند تفسير قوله تعالى: <q>﴿فَأَلْقى عَصاهُ فَإذا هِيَ ثُعْبانٌ مُبِينٌ﴾</q> [الأعراف:١٠٧]، وقوله تعالى: <q>﴿قالَ هِيَ عَصايَ أتَوَكَّأُ عَلَيْها وأَهُشُّ بِها عَلى غَنَمِي ولِيَ فِيها مَآرِبُ أُخْرى﴾</q> [طه:١٨].أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨ من طريق الضحاك. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٨/٢٧٥٩.يبدو أن ما بعد هذا من كلام ابن جرير، حيث يفصل بينهما لفظ «وقوله: <q>﴿ونزع يده﴾</q>» كما جاء في الأصل، وتصرف محققيه يشعر بذلك.أخرجه ابن جرير ١٧/٥٦٥-٥٦٦.أخرجه ابن جرير ١٠/٣٤٤، وابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢.فأخذه بطنه: أحدث. كما في أثر السدي الذي يلي هذا الأثر.أخرجه ابن جرير ١٧/٥٦٦. وعزاه السيوطي إلى أبي الشيخ.الطفيشل -بالمعجمة كسميدع-، قال ابن عباد: نوع من المرق معروف. تاج العروس (طفشل).أخرجه ابن أبي حاتم ٨/٢٧٥٦، ٢٧٥٩ مختصرًا من طريق أسباط.يَتَلَمَّظ: يُدِير لِسانه في فيه ويُحَرِّكُه. النهاية (لمظ).تفسير مقاتل بن سليمان ٣/٢٦٢.سِماطَي: السٍّماط: الجماعة من الناس والنخل. والمعنى: الجماعة الذين كانوا جلوسًا على الجانبين. النهاية واللسان (سمط).عُرْف الدِّيك والفَرَس والدّابّة وغيرها: مَنبِت الشعرِ والرِّيش من العُنق. اللسان (عرف).أي: تفرّقوا. النهاية واللسان (رفض).يُقال: فلان يتلظّى على فلان تَلظِّيًا: إذا تَوَقَّد عَلَيْه مِن شدَّة الغضب. اللسان (لظي).أي: تحرّك ذَنَبها. النهاية (بصبص)، واللسان (بصص).أخرجه ابن أبي حاتم ٨/٢٧٥٩.يَسْرِط: يبتلع. اللسان (سرط).تفسير يحيى بن سلام ٢/٥٠١.
26,33," <q>﴿وَنَزَعَ یَدَهُۥ فَإِذَا هِیَ بَیۡضَاۤءُ لِلنَّـٰظِرِینَ ۝٣٣﴾</q> - تفسير ٥٥٧٥٦- عن عبد الله بن عباس -من طريق علي- <q>﴿بَيْضاءُ لِلنّاظِرِينَ﴾</q>: مِن غير برص{1}. (ز) ٥٥٧٥٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿ونزع يده﴾</q> قال: فأخرج يدَه مِن جيبه، <q>﴿فاذا هي بيضاء للناظرين﴾</q> قال: أخرج يده مِن جيبه فرآها بيضاء مِن غير سوء، يعني به: البرص، ثم أعادها في كُمِّه، فصارت إلى لونها الأول{2}. (ز) ٥٥٧٥٨- عن عبد الله بن عباس -من طريق مقسم- قوله: <q>﴿ونزع يده فاذا هي بيضاء للناظرين﴾</q>، قال: فأدخل يده في جيبه، فأخرجها مثلَ البرق تلتمع الأبصار، فخَرُّوا على وجوههم، وأخذ موسى عصاه ثم خرج ليس أحد من الناس إلا يَفِرُّ منه{3}. (ز) ٥٥٧٥٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ونَزَعَ يَدَهُ﴾</q>: أخرجها من جيبه <q>﴿فَإذا هِيَ بَيْضاءُ لِلنّاظِرِينَ﴾</q>{4}. (ز) ٥٥٧٦٠- عن مجاهد بن جبر -من طريق أبي سعد- في قوله: <q>﴿ونزع يده﴾</q> قال: نزع يده من جيبه، <q>﴿فإذا هي بيضاء للناظرين﴾</q> وكان موسى رجلًا آدَمَ، فأخرج يده، فإذا هي بيضاء أشد بياضًا من اللبن، <q>﴿من غير سوء﴾</q> [طه:٢٢]، قال: من غير برص، آية لفرعون{5}. (ز) ٥٥٧٦١- عن الحسن البصري -من طريق قُرَّة بن خالد- قال: أخرجها -واللهِ- كأنّها مِصباح{6}. (ز) ٥٥٧٦٢- قال مقاتل بن سليمان: قال فرعون: هل مِن آية أخرى غيرها؟ قال موسى: نعم. فأبرز يده، قال لفرعون: ما هذه؟ قال فرعون: هذه يدُك. فأدخلها في جيبه، وهي مِدْرعة{7} مصرية مِن صوف، <q>﴿ونزع يده﴾</q> يعني: أخرج يده مِن المدرعة، <q>﴿فإذا هي بيضاء للناظرين﴾</q> لها شعاع مثلُ شعاع الشمس مِن شِدَّة بياضها، يَغْشى البَصَر{8}. (ز) ٥٥٧٦٣- عن محمد بن إسحاق -من طريق سلمة- قال: ثم أدخل يده في جيبه، فأخرجها بيضاء مثل الثلج، ثم ردَّها، فرجعت كهيئتها، وأدخل موسى يدَه في جيبه، فصارت عصًا بيده، يده بين شعبتيها ومحجنها في أسفلها كما كان، وأخذ فرعون بطنه، فكان -فيما يزعمون- يمكث الخميس والسبت ما يلتمس المذهب كما كان يلتمسه الناس، وكان ذلك مما زَيَّن له أن يقول: إنه ليس له في الناس شبيه{3}. (ز) ٥٥٧٦٤- قال يحيى بن سلّام: <q>﴿ونزع يده﴾</q> أدخل يده في جيب قميصه ثم أخرجها، فهو قوله: <q>﴿ونزع يده﴾</q> أي: أخرج يده، <q>﴿فإذا هي بيضاء للناظرين﴾</q> يغشى البصر من بياضها{10}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٤٦.أخرجه ابن جرير ١٠/٣٤٦، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٥٩.أخرجه ابن أبي حاتم ٨/٢٧٦٠.أخرجه ابن جرير ١٠/٣٤٧.تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٤٧.أخرجه يحيى بن سلام ٢/٥٠١.المِدْرَعة: ضَرْبٌ مِن الثّياب لا يكون إلا من الصُّوفِ خاصَّة. اللسان (درع).تفسير مقاتل بن سليمان ٣/٢٦٢.أخرجه ابن أبي حاتم ٨/٢٧٦٠.تفسير يحيى بن سلام ٢/٥٠١.
26,34," <q>﴿قَالَ لِلۡمَلَإِ حَوۡلَهُۥۤ إِنَّ هَـٰذَا لَسَـٰحِرٌ عَلِیمࣱ ۝٣٤﴾</q> - تفسير ٥٥٧٦٥- عن عبد الله بن عباس -من طريق مقسم-: فلمّا أفاق، وذهب عن فرعون الرَّوْعُ؛ <q>﴿قال للملإ حوله﴾</q>: ماذا تأمرون؟{1}. (ز) ٥٥٧٦٦- قال مقاتل بن سليمان: <q>﴿قال﴾</q> فرعون <q>﴿للملإ﴾</q> يعني: الأشراف <q>﴿حوله إن هذا﴾</q> يعني: موسى <q>﴿لساحر عليم﴾</q> بالسِّحْر{2}. (ز) ٥٥٧٦٧- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فقال للملإ حوله﴾</q>: قال لملئه: <q>﴿إن هذا لساحر عليم﴾</q> أي: ما ساحر أسحرَ منه{1}. (ز) ٥٥٧٦٨- قال يحيى بن سلّام: <q>﴿قال للملإ حوله﴾</q> فرعون يقوله: <q>﴿إن هذا لساحر عليم﴾</q> بالسحر{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٠.تفسير مقاتل بن سليمان ٣/٢٦٢.أخرجه ابن أبي حاتم ٨/٢٧٦٠.تفسير يحيى بن سلام ٢/٥٠١.
26,35," <q>﴿یُرِیدُ أَن یُخۡرِجَكُم مِّنۡ أَرۡضِكُم بِسِحۡرِهِۦ فَمَاذَا تَأۡمُرُونَ ۝٣٥﴾</q> - تفسير ٥٥٧٦٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿يريد ان يخرجكم من أرضكم بسحره﴾</q>، قال: يستخرجكم مِن أرضكم{1}. (ز) ٥٥٧٧٠- قال مقاتل بن سليمان: <q>﴿يريد أن يخرجكم من أرضكم﴾</q> يعني: مصر <q>﴿بسحره فماذا تأمرون﴾</q> يقول: فماذا تُشِيرون عليَّ؟{2}. (ز) ٥٥٧٧١- عن محمد بن إسحاق -من طريق سلمة- قوله: <q>﴿فماذا تأمرون﴾</q> أأقتله؟{3}. (ز) ٥٥٧٧٢- قال يحيى بن سلّام: <q>﴿يريد أن يخرجكم من أرضكم بسحره فماذا تأمرون﴾</q> فأراد قتله، فقال له صاحبُه: لا تقتله؛ فإنما هو ساحر، ومتى ما تقتله أدخلت على الناس في أمره شبهة، ولكن <q>﴿أرجه وأخاه﴾</q>{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٠.تفسير مقاتل بن سليمان ٣/٢٦٢.أخرجه ابن أبي حاتم ٨/٢٧٦١.تفسير يحيى بن سلام ٢/٥٠١.
26,36," <q>﴿قَالُوۤا۟ أَرۡجِهۡ وَأَخَاهُ﴾</q> - تفسير ٥٥٧٧٣- عن عبد الله بن عباس -من طريق مقسم- <q>﴿قالوا أرجه وأخاه﴾</q>: لا تَأْتِنا به، ولا يقربنا{1}. (ز) ٥٥٧٧٤- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿قالوا أرجه وأخاه﴾</q>، يقول: أخِّره وأخاه{2}. (٦/ ٤٩٦) ٥٥٧٧٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قالوا أرجه وأخاه﴾</q>، قال: احْبِسْه وأخاه{3}. (٦/٤٩٦) ٥٥٧٧٦- قال يحيى بن سلّام: <q>﴿أرجه وأخاه﴾</q> أخِّره وأخاه، فإنما هو ساحر، ومتى ما تقتله [أدخلت على الناس في أمره شبهة]، في تفسير الحسن البصري{4}. (ز) ٥٥٧٧٧- قال مقاتل بن سليمان: فردَّ عليه الملأُ مِن قومه، يعني: الأشراف، <q>﴿قالوا أرجه وأخاه﴾</q> يقول: احبسهما جميعًا، ولا تقتلهما، حتى ننظر ما أمرهما{5}٤٧٩١. (ز) ٤٧٩١ قال ابنُ جرير (١٠/٣٤٩): «يقول -تعالى ذِكْرُه-: قال الملأ من قوم فرعون لفرعون: أرجئه: أي: أخره. وقال بعضهم: معناه: احبس. والإرجاء في كلام العرب: التأخير، يُقال منه: أرجيت هذا الأمر وأرجأته إذا أخرته، ومنه قول الله تعالى: <q>﴿ترجي من تشاء منهن﴾</q> [الأحزاب:٥١]: تُؤَخِّر». <q>﴿وَٱبۡعَثۡ فِی ٱلۡمَدَاۤىِٕنِ حَـٰشِرِینَ ۝٣٦﴾</q> - تفسير ٥٥٧٧٨- عن عبد الله بن عباس -من طريق أبي مالك - في قوله: <q>﴿وأرسل في المدائن حاشرين﴾</q> [الأعراف:١١١]، قال: الشُّرَط{6}. (٦/٤٩٦) ٥٥٧٧٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: قالوا لفرعون: اجمع لهم السحرة، فإنهم بأرضك كثير، حتى تغلب بسحرهم سحرَهما{1}. (ز) ٥٥٧٨٠- عن مجاهد بن جبر -من طريق إبراهيم بن مهاجر، عن أبيه- <q>﴿وابعث في المدائن حاشرين﴾</q>، قال: الشُّرَط{8}. (ز) ٥٥٧٨١- عن إبراهيم بن المهاجر -من طريق قيس بن ربيع- في قوله تعالى: <q>﴿في المدائن حاشرين﴾</q>، قال: الشُّرَط{9}. (ز) ٥٥٧٨٢- عن إسماعيل السُّدِّيّ -من طريق قيس- <q>﴿وابعث في المدائن حاشرين﴾</q>، قال: الشُّرَط{10}. (ز) ٥٥٧٨٣- قال مقاتل بن سليمان: <q>﴿وابعث في المدآئن﴾</q> يعني: في القُرى <q>﴿حاشرين﴾</q> يحشرون عليك السَّحَرة. فذلك قوله سبحانه: <q>﴿يأتوك بكل سحار عليم﴾</q>{5}. (ز) ٥٥٧٨٤- قال يحيى بن سلّام: <q>﴿وابعث في المدائن حاشرين﴾</q>، يحشرون عليك السحرة{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦١.أخرجه ابن جرير ١٠/٣٥٠، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٦١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٥١، وابن أبي حاتم ٥/١٥٣٣ من طريق همام. وعلَّقه يحيى بن سلام ٢/٥٠١. وعزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ٢/٥٠١.تفسير مقاتل بن سليمان ٣/٢٦٢.أخرجه ابن جرير ١٠/٣٥١-٣٥٢، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦١ من طريق مجاهد. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٨/٢٧٦١.أخرجه ابن جرير ١٠/٣٥١. وعلَّقه ابن أبي حاتم ٨/٢٧٦١.ذكره الحافظ في المطالب العالية (إشراف: د. سعد الشثري) ١٥/٧٧ (٣٦٧٤).أخرجه ابن جرير ١٠/٣٥١.تفسير مقاتل بن سليمان ٣/٢٦٢.تفسير يحيى بن سلام ٢/٥٠١.
26,37," <q>﴿یَأۡتُوكَ بِكُلِّ سَحَّارٍ عَلِیمࣲ ۝٣٧﴾</q> - تفسير ٥٥٧٨٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قوله: <q>﴿يأتوك بكل سحار عليم﴾</q>، قال: فحشر له كل سحّار مُتعالِم{1}. (ز) ٥٥٧٨٦- عن عبد الله بن عباس -من طريق مقسم- قوله: <q>﴿وابعث في المدائن حاشرين﴾</q>: فإنّما هذا ساحر. فأرسل فرعون في المدائن حاشرين، وكانت السحرةُ يَخشَون مِن فرعون، فلمّا أرسَل إليهم قالوا: قد احتاج إليكم إلهُكم{2}. (٦/٤٩٣) ٥٥٧٨٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿يأتوك بكل سحار عليم﴾</q>، قال: فحشروا السَّحَرة، وحشر الناس ينظرون{3}. (ز) ٥٥٧٨٨- قال مقاتل بن سليمان: <q>﴿يأتوك بكل سحار عليم﴾</q>، يعني: عالم بالسحر{4}. (ز) ٥٥٧٨٩- عن محمد بن إسحاق -من طريق سلمة- <q>﴿أرجه وأخاه وأرسل في المدائن حاشرين يأتوك بكل سحار عليم﴾</q>: أي: كاثِرْه بالسَّحَرة، لعلك أن تجد في السَّحرة مَن يأتي بمثل ما جاء به، وقد كان موسى وهارون خرجا مِن عنده حين أراهم مِن سلطان الله ما أراهم، وبعث فرعونُ في مملكته مكانَه، فلم يترك في سلطانه ساحِرٌ إلا أتى به{5}. (ز) ٥٥٧٩٠- قال يحيى بن سلّام: <q>﴿يأتوك بكل سحار عليم﴾</q> بالسحر{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٢.أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦١.أخرجه ابن أبي حاتم ٨/٢٧٦٢.تفسير مقاتل بن سليمان ٣/٢٦٢.أخرجه ابن جرير ١٠/٣٥٤.تفسير يحيى بن سلام ٢/٥٠١.
26,38," <q>﴿فَجُمِعَ ٱلسَّحَرَةُ﴾</q> - تفسير ٥٥٧٩١- عن عبد الله بن عباس -من طريق السُّدِّيّ- قال: كان السحرة سبعين رجلًا{1}. (٦/٤٩٦) ٥٥٧٩٢- عن كعب الأحبار -من طريق أبي سودة - قال: كان سَحرةُ فرعون اثني عشر ألفًا{2}. (٦/٤٩٧) ٥٥٧٩٣- قال مقاتل بن سليمان: <q>﴿فجمع السحرة لميقات يوم معلوم﴾</q>، وهم اثنان وسبعون ساحرًا مِن أهل فارس، وبقيتهم مِن بني إسرائيل{3}. (ز) ٥٥٧٩٤- عن محمد بن إسحاق -من طريق سلمة - قال: جُمِع له خمسة عشر ألف ساحرٍ{4}. (٦/٤٩٧) <q>﴿لِمِیقَـٰتِ یَوۡمࣲ مَّعۡلُومࣲ ۝٣٨﴾</q> - تفسير ٥٥٧٩٥- عن عبد الله بن عباس، قال: وافق ذلك اليوم يومَ السبت، في أول يوم من السنة، وهو يوم النيروز{5}. (ز) ٥٥٧٩٦- قال مقاتل بن سليمان: <q>﴿فجمع السحرة لميقات يوم معلوم﴾</q>، يعني: مُوَقَّت، وهو يوم عيدهم، وهو يوم الزينة{3}. (ز) ٥٥٧٩٧- قال عبد الرحمن بن زيد بن أسلم: وكان اجتماعهم للميقات بالإسكندرية{7}. (ز) ٥٥٧٩٨- قال يحيى بن سلّام: قال الله: <q>﴿فجمع السحرة لميقات يوم معلوم﴾</q>، وهو قوله: <q>﴿موعدكم يوم الزينة﴾</q> [طه:٥٩]، يوم عيد لهم، كان يجتمع فيه أهل القرى والناس، فأراد موسى أن يفضحه على رؤوس الناس{8}. (ز) ",footnotes:1:أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٦٤، وابن أبي حاتم ٥/١٥٣٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٥٥، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وأبي الشيخ.تفسير مقاتل بن سليمان ٣/٢٦٣.أخرجه ابن جرير ١٠/٣٥٤، وابن أبي حاتم ٨/٢٧٦٢. وتقدمت الآثار مفصلة في عدد سحرة فرعون وذلك عند تفسير قوله تعالى: <q>﴿وجاءَ السَّحَرَةُ فِرْعَوْنَ قالُوا إنَّ لَنا لَأَجْرًا إنْ كُنّا نَحْنُ الغالِبِينَ﴾</q> [الأعراف:١١٣].تفسير الثعلبي ٧/١٦٣، وتفسير البغوي ٦/١١٢.تفسير مقاتل بن سليمان ٣/٢٦٣.تفسير الثعلبي ٧/١٦٣.تفسير يحيى بن سلام ٢/٥٠١.
26,39," <q>﴿وَقِیلَ لِلنَّاسِ هَلۡ أَنتُم مُّجۡتَمِعُونَ ۝٣٩﴾</q> - تفسير ٥٥٧٩٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وقيل للناس هل أنتم مجتمعون﴾</q>، يقول: حُشِر الناس ينظرون{1}. (ز) ٥٥٨٠٠- قال مقاتل بن سليمان: <q>﴿وقيل للناس﴾</q> يعني: لأهل مصر: <q>﴿هل أنتم مجتمعون﴾</q> إلى السَّحَرة{2}. (ز) ٥٥٨٠١- قال يحيى بن سلّام: <q>﴿وقيل للناس﴾</q> قاله بعضهم لبعض: <q>﴿هل أنتم مجتمعون﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٢.تفسير مقاتل بن سليمان ٣/٢٦٣.تفسير يحيى بن سلام ٢/٥٠٢.
