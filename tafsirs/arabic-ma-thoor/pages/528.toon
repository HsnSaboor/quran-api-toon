quran[24]{c,v,t}:
  53,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّهُۥ خَلَقَ ٱلزَّوۡجَیۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰ ۝٤٥ مِن نُّطۡفَةٍ إِذَا تُمۡنَىٰ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٥٧٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٧٨<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span>: <span class="qpc-hafs">﴿مِن نُطْفَةٍ إذا تُمْنى﴾</span> أي: تُصبّ في الرَّحِم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنَّهُ خَلَقَ الزَّوْجَيْنِ﴾</span> الرجل والمرأة؛ كلّ واحد منهما زَوْجُ الآخر <span class="qpc-hafs">﴿الذَّكَرَ والأُنْثى﴾</span> خلَقهما <span class="qpc-hafs">﴿مِن نُطْفَةٍ إذا تُمْنى﴾</span> يعني: إذا تدفّق المني{2}<span class=comment-ref>٦٢٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩٨</span> ذكر <u>ابنُ عطية</u> (٨/١٢٨) في معنى: <span class="qpc-hafs">﴿تُمنى﴾</span> احتمالين: <b>الأول:</b> «أن يكون من قولك: أمنى الرجل: إذا خرج منه المنيّ»؟ <b>والثاني:</b> «أن يكون مِن قولك: منى الله الشيء: إذا خلقه». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فكأنه قال: إذا تُخلَق وتُقَدَّر».</div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٥٦، وتفسير البغوي ٧/٤١٨.|2:تفسير مقاتل بن سليمان ٤/١٦٦.
  53,46,""
  53,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّ عَلَیۡهِ ٱلنَّشۡأَةَ ٱلۡأُخۡرَىٰ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٥٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنَّ عَلَيْهِ النَّشْأَةَ الأُخْرى﴾</span> يعني: الخَلْق الآخر، يعني: البعث في الآخرة بعد الموت{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٦.
  53,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنَىٰ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٥٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ أغْنى وأَقْنى﴾</span>، قال: أعطاه وأرضاه {1}. (١٤/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أغْنى﴾</span> قال: أكثر، <span class="qpc-hafs">﴿وأَقْنى﴾</span> قال: قنّع{2}. (١٤/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿أغْنى وأَقْنى﴾</span>. قال: أغنى من الفقر، وأقنى من الغنى فقنع به. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عَنترة العَبسيّ:</p><p>فاقْنَي حياءك لا أبا لك واعلمي أني امرؤ سأموت إنْ لم أُقْتلِ؟{3}. (١٤/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿أغْنى﴾</span> رضّى، <span class="qpc-hafs">﴿أقْنى﴾</span> موَّن{4}. (١٤/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿أغْنى﴾</span> قال: موّل، <span class="qpc-hafs">﴿وأَقْنى﴾</span> قال: رضّى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ أغْنى وأَقْنى﴾</span>، قال: <span class="qpc-hafs">﴿أغْنى﴾</span> موَّل، <span class="qpc-hafs">﴿وأَقْنى﴾</span> أخدم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿أغْنى﴾</span> بالذّهب والفِضّة وصنوف الأموال، <span class="qpc-hafs">﴿وأقنى﴾</span> بالإبل والبقر والغنم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿أغْنى﴾</span> في المال، <span class="qpc-hafs">﴿وأَقْنى﴾</span> قال: أخدم{8}. (١٤/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٨٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، مثله{9}. (١٤/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- في قوله: <span class="qpc-hafs">﴿أغنى﴾</span> قال: أغنى بالمال، <span class="qpc-hafs">﴿وأَقْنى﴾</span> قال: القُنيَة{10}. (١٤/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>- من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أغنى وأقنى﴾</span> قال: أعطى وأرضى وأخدم{11}. (١٤/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٢<span class="dash">-</span></span> عن سليمان التيمي، في قول الله ﷿: <span class="qpc-hafs">﴿أغنى وأقنى﴾</span>، قال: زعم <span class="name-3">حضرمي [بن لاحق التميمي السعدي]</span> أنه: أغنى نفسه، وأفقر الخلائق إليه{12}<span class=comment-ref>٦٢٩٩</span>. (١٤/٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩٩</span> نقل <u>ابن عطية</u> (٨/١٢٩) عن بعضهم: أن «أقنى معناه: أكسب ما يُقتنى». ثم نقل قول مجاهد، وحضرمي، ثم نقل عن الأخفش: «أقنى: أفقر». ثم <span class="comment-type-4">علَّق</span> عليها بقوله: «وهذه عبارات لا تقتضيها اللفظة، والوجْه فيها <span class="mustanad">بحسب اللغة</span>: أكْسَبَ ما يُقْتَنى». ثم نقل قول ابن عباس أن أقْنى معناه: أقنع، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «والقناعة خير قَنْيَة، والغِنى عَرَضٌ زائل، فلله دَرُّ ابنِ عباس ﵄».</p><p>ونقل <u>ابنُ كثير</u> (١٣/٢٨٢) قول حضرمي، وابن زيد، ثم <span class="comment-type-2">انتقدهما</span> بقوله: «وهما بعيدان <span class="mustanad">مِن حيث اللفظ</span>».</div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَقْنى﴾</span>، يقول: موَّل وأرضى هذا الإنسان بما أعطى{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٤<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق الحسن- قال: سمعتُ المفسّرين مِن كل جانبٍ يقولون في قوله: <span class="qpc-hafs">﴿أغْنى﴾</span> قال: أرضى. قال سفيان: لا يكون غنيًّا أبدًا حتى يَرضى بما قَسم الله له، فذلك الغني{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>- من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ أغْنى وأَقْنى﴾</span>، قال: <span class="qpc-hafs">﴿أغنى﴾</span> فأكثر، و<span class="qpc-hafs">﴿أقنى﴾</span> أقلَّ. وقرأ: <span class="qpc-hafs">﴿يبسط الرزق لمن يشاء من عباده ويقدر له﴾</span> [العنكبوت:٦٢]{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٨٤، ومن طريق عطية بلفظ: أغنى وأرضى، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٤، والإتقان ٢/٤٥-.|2:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٤-.|3:أخرجه الطستي -كما في الإتقان ٢/١٠٠-.|4:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر. وعند ابن جرير بلفظ مختلف كما في الأثرين التاليين.|5:تفسير مجاهد ص٦٢٨، وأخرجه ابن جرير ٢٢/٨٤.|6:أخرجه ابن جرير ٢٢/٨٣.|7:تفسير الثعلبي ٩/١٥٦، وتفسير البغوي ٧/٤١٩.|8:أخرجه ابن جرير ٢٢/٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.|10:أخرجه ابن جرير ٢٢/٨٢. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن جرير ٢٢/٨٣، كما أخرجه من طريق معمر بلفظ: أغنى وأخدم. وعزا السيوطي نحوه إلى عبد بن حميد، وابن المنذر.|12:أخرجه ابن جرير ٢٢/٨٤، وأبو الشيخ في العظمة (١٧٦) واللفظ له، ولفظ ابن جرير: زعم حضرمي أنه ذُكر له.|13:تفسير مقاتل بن سليمان ٤/١٦٦.|14:أخرجه ابن أبي الدنيا في الرضا عن الله ١/٤٥٦ (٩٥).|15:أخرجه ابن جرير ٢٢/٨٦.
  53,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ۝٤٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٥٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: نَزَلَتْ هذه الآية في خُزاعة، وكانوا يعبدون الشِّعرى، وهو الكوكب الذي يتبع الجَوزاء{1}. (١٤/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: كان ناس في الجاهلية يعبدون هذا النّجم الذي يُقال له: الشِّعْرى؛ فنَزَلَتْ: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</span>{2}. (١٤/٥٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ۝٤٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٥٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</span>، قال: هو الكوكب الذي يُدعى: الشِّعرى{3}. (١٤/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٥٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- قال: <span class="qpc-hafs">﴿الشِّعْرى﴾</span> الكوكب الذي خَلف الجَوزاء، كانوا يعبدونه{4}. (١٤/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</span>، قال: نجم كان يُعبد في الجاهلية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</span>، قال: مِرْزم الجوزاء{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿رَبُّ الشِّعْرى﴾</span>، قال: كان ناس في الجاهلية يعبدون هذا النّجم الذي يقال له: الشِّعرى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: الشِّعرى اليمانية النّيّرة الجنوبية، كوكب مضيء، وهي التي تتبع الجوزاء، ويُقال لها: المُزْنُ والعَبُور، كان أناس من الأعراب مِن خُزاعة وغسّان وغَطَفان يعبدونها، وهي الكوكب الذي يطلع بعد الجَوزاء، قال الله تعالى: أنا ربّها؛ فاعبدوني{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</span>، قال: كانت تُعبد في الجاهلية، فقال: تعبدون هذه وتتركون ربّها؟! اعبدوا ربّها. قال: والشِّعرى: النّجم الوقّاد الذي يتبع الجَوزاء، يقال له: المِرْزم{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الفاكهي ٥/١٦٥، من طريق الكلبي، عن أبي صالح، عن ابن عباس به.</p><p>ضعيف. وينظر: مقدمة الموسوعة.|2:أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٨٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه ابن جرير ٢٢/٨٥.|4:أخرجه ابن جرير ٢٢/٨٥، وأبو الشيخ (٦٩٥). وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٢/٨٥.|6:تفسير مجاهد ص٦٢٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، والفاكهي ٥/١٦٥، وابن جرير ٢٢/٨٦.|7:أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٨٦ من طريقي معمر وسعيد.|8:تفسير مقاتل بن سليمان ٤/١٦٦-١٦٧.|9:أخرجه ابن جرير ٢٢/٨٦، ٨٨.
  53,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّهُۥۤ أَهۡلَكَ عَادًا ٱلۡأُولَىٰ ۝٥٠ وَثَمُودَا۟ فَمَاۤ أَبۡقَىٰ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</span> بالعذاب، وذلك أنّ أهل عاد وثمود، وأهل السواد، وأهل المُوصل، وأهل العال كلّها مِن ولد إرَم بن سام بن نوح ﵇، فمِن ثَمّ قال: <span class="qpc-hafs">﴿أهْلَكَ عادًا الأُولى﴾</span> يعني: قوم هود بالعذاب، <span class="qpc-hafs">﴿و﴾</span>أهلك <span class="qpc-hafs">﴿ثَمُودَ﴾</span> بالعذاب <span class="qpc-hafs">﴿فَما أبْقى﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</span>، قال: كانت الآخرة بحضْرموت{2}. (١٤/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: وكان هلاك عاد الآخرة ببغي بعضهم على بعض، فتفانَوا بالقتل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</span>، قال: يُقال: هي مِن أول الأمم{3}<span class=comment-ref>٦٣٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٠</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٢٩) قول ابن زيد بقوله: «فهي أُولى بالإضافة إلى الأمم المتأخرة». ثم ذكر قول <u>ابن جرير</u>: «سُميت أولى؛ لأن ثَمَّ عادًا أخيرة -وهي قبيلة- كانت بمكة مع العماليق، وهم بنو لُقَيم بن هزّال». ثم <span class="comment-type-3">رجَّح</span> قول ابن زيد.</p><p>و<span class="comment-type-2">انتقد</span> قول <u>ابن جرير</u> قائلًا: «والقول الأول أبْيَن؛ لأن هذا الأخير لم يصح». ثم <b>ذكر</b> عن المبرد -نقلًا عن الزهراوي-: «عاد الأخيرة هي ثمود». <span class="mustanad">واستشهد ببيتٍ من الشعر</span>، ثم نقل <b>قولًا</b> أن «الأخيرة: الجبّارون».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٧.|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ٢٢/٨٨.|4:أخرجه ابن جرير ٢٢/٨٨.
  53,51,""
  53,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَوۡمَ نُوحࣲ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُوا۟ هُمۡ أَظۡلَمَ وَأَطۡغَىٰ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقَوْمَ نُوحٍ مِن قَبْلُ إنَّهُمْ كانُوا هُمْ أظْلَمَ وأَطْغى﴾</span>، قال: لم يكن قبيلٌ مِن الناس هم أظلم وأطغى مِن قوم نوح، دعاهم نوحٌ ألفَ سنة إلا خمسين عامًا، كلّما هلك قرنٌ ونشأ قرنٌ دعاهم، حتى لقد ذُكِر لنا: أنّ الرجل كان يأخذ بيد أخيه أو ابنه فيمشي به إليه، فيقول: يا بُني، إنّ أبي قد مشى بي إلى هذا، وأنا مثلك يومئذ. تَتابُعًا في الضلالة، وتكذيبًا بأمر الله{1}. (١٤/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقَوْمَ نُوحٍ﴾</span> بالغرق <span class="qpc-hafs">﴿مِن قَبْلُ﴾</span> هلاك عاد وثمود؛ <span class="qpc-hafs">﴿إنَّهُمْ كانُوا هُمْ أظْلَمَ وأَطْغى﴾</span> من عاد وثمود، وذلك أنّ نوحًا دعا قومَه ألف سنة إلا خمسين عامًا، فلم يُجيبوه، حتى إنّ الرجل منهم كان يأخذ بيد ابنِه، فينطلِق به إلى نوحٍ ﵇، فيقول له: احذر هذا؛ فإنه كذّاب، فإنّ أبي قد مشى بي إلى هذا وأنا مثلك، فحذّرني منه؛ فاحذره. فيموت الكبير على الكفر، وينشأ الصغير على وصيّة أبيه، فنشأ قرنٌ بعد قرنٍ على الكفر <span class="qpc-hafs">﴿هُمْ أظْلَمَ وأَطْغى﴾</span>، فبقي مِن نسلهم بعد عاد أهل السواد، وأهل الجزيرة، وأهل العال، فمِن ثَمَّ قال: <span class="qpc-hafs">﴿عادًا الأُولى﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٨٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. كما أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٩٠ من طريق معمر مختصرًا.|2:تفسير مقاتل بن سليمان ٤/١٦٧.
  53,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡمُؤۡتَفِكَةَ أَهۡوَىٰ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span>، قال: المكذِّبين أهلكهم الله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span>، قال: أهوى بها جبريل بعد أن رفعها إلى السماء{2}. (١٤/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span>، قال: قوم لوط ائتفكتْ بهم الأرض بعد أن رفعها الله إلى السماء، فالأرض تَجَلجَل بهم إلى يوم القيامة{3}. (١٤/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span>، قال: قرى قوم لوط{4}. (١٤/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٥<span class="dash">-</span></span> عن <span class="name-2">أبي عيسى يحيى بن رافع</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span>، قال: قرية لوط أهوى بها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span> -من طريق أسباط- قال: لَمّا أصبحوا -يعني: قوم لوط- نزل جبرئيل، فاقتلع الأرض من سبع أرضين، فحملها حتى بلغ السماء الدنيا، حتى سمع أهلُ السماء نباحَ كلابهم وأصوات ديوكهم، ثم قلبها، فقتلهم، فذلك حين يقول: <span class="qpc-hafs">﴿والمؤتفكة أهوى﴾</span> المنقلبة حين أهوى بها جبرئيل الأرض، فاقتلعها بجناحه...{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span> أهلك <span class="qpc-hafs">﴿المُؤْتَفِكَةَ﴾</span> يعني: الكذبة{7} أهوى، يعني: قُرى قوم لوط، وذلك أنّ جبريل ﵇ أدخل جناحه تحتَها، فرفعها إلى السماء، حتى سمعت ملائكةُ سماء الدنيا أصوات الدِّيكة، ونباح الكلاب، ثم قلَبها، فهوتْ مِن السماء إلى الأرض مقلوبة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span>، قال: قرية لوط أهواها مِن السماء، ثم أتبعها ذاك الصخر؛ اقتُِلَعت من الأرض، ثم هوى بها في السماء، ثم قُلِبَت{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٩٢.|2:تفسير مجاهد ص٦٢٩، وأخرجه ابن جرير ٢٢/٩٠، وأبو الشيخ في العظمة (٣٧١).|3:عزاه السيوطي إلى عبد بن حميد.|4:أخرجه عبد الرزاق ٢/٢٥٤-٢٥٥، وابن جرير ٢٢/٩١، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:أخرجه ابن جرير ٢٢/٩٠.|6:أخرجه ابن جرير ١٢/٥٣٦.|7:كذا، ولعلها: المكذبة.|8:تفسير مقاتل بن سليمان ٤/١٦٧.|9:أخرجه ابن جرير ٢٢/٩١.
  53,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَغَشَّىٰهَا مَا غَشَّىٰ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَغَشّاها ما غَشّى﴾</span>، قال: الحجارة{1}. (١٤/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فَغَشّاها ما غَشّى﴾</span>: غشّاها صخرًا منضودًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَغَشّاها ما غَشّى﴾</span> يعني: الحجارة التي غشّاها مَن كان خارجًا من القرية، أو كان في زرعه، أو في ضَرْعه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَغَشّاها ما غَشّى﴾</span>، قال: الحجارة التي رماهم بها مِن السماء{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٥٤-٢٥٥، وابن جرير ٢٢/٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٢/٩١.|3:تفسير مقاتل بن سليمان ٤/١٦٧.|4:أخرجه ابن جرير ٢٢/٩٢.
  53,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكَ تَتَمَارَىٰ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٢٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿تَتَمارى﴾</span> تُكَذِّب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكَ﴾</span>، قال: بأيِّ نِعَم الله تتمارى، يا ابن آدم{2}<span class=comment-ref>٦٣٠١</span>. (١٤/٥٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٣/٢٨٣) في معنى: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكَ تَتَمارى﴾</span> قول قتادة: «ففي أيِّ نعم الله عليك -أيها الإنسان- تمتري؟!». و<span class="comment-type-4">نقل</span> عن ابن جُرَيْج قوله: «<span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكَ تَتَمارى﴾</span> يا محمد». ثم <span class="comment-type-3">رجَّح</span> قول قتادة قائلًا: «والأول أوْلى، وهو اختيار ابن جرير». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّك﴾</span> يعني: بأي نعمة ربك <span class="qpc-hafs">﴿تَتَمارى﴾</span> يعني: يشكّ فيها ابن آدم{3}<span class=comment-ref>٦٣٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/١٤٩) في معنى: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكَ تَتَمارى﴾</span> قول من قال: تشكّ وتجادل. وقول ابن عباس، ثم <span class="comment-type-4">علَّق</span> بقوله: «ضمّن <span class="qpc-hafs">﴿تتمارى﴾</span> معنى: تكذب، ولهذا عدّاه بالتاء؛ فإنه تفاعل من المرآء، يقال: تمارينا في الهلال، ومراءٌ في القرآن كفر، وهو يكون لتكذيب وتشكيك».</div></p></div>",footnotes:1:تفسير البغوي ٧/٤٢٠.|2:أخرجه ابن جرير ٢٢/٩٢، كما أخرجه عبد الرزاق ٢/٢٥٤-٢٥٥، وابن جرير ٢٢/٩٢، بنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/١٦٨.
  53,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا نَذِیرࣱ مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰۤ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span>، قال: محمد ﷺ{1}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [الغفاري]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span>، قال: مِمّا أنذروا به قومهم في صُحف إبراهيم وموسى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر [الباقر]</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span>، قال: هو محمد ﷺ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٢٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي معشر- في قوله: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span>، قال: محمد ﷺ أنذرَ ما أنذر الأولون{4}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span>، قال: إنّما بُعِث محمد بما بُعِث به الرسلُ قبله{3}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span>، قال: أنذر محمدٌ ﷺ كما أنذرَت الرسلُ من قبله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span> فيها تقديم، يقول: هذا الذي أخبر عن هلاك الأمم الخالية -يعني: قوم نوح، وعاد، وثمود، وقوم لوط- يخوِّف كفار مكة ليحذروا معصيته{7}<span class=comment-ref>٦٣٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٣</span> اختُلف في معنى: <span class="qpc-hafs">﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</span> على قولين: <b>الأول:</b> أنّ النبي ﷺ نذيرٌ لقومه كما كانت النُّذُر الذين قبله نُذُرًا لقومهم. <b>الثاني:</b> هذا الذي أنذرتكم به -أيُّها القوم- مِن الوقائع التي ذكرتُ لكم أني أوْقَعْتُها بالأمم قبلكم، من النُّذُر التي أنذرتها الأمم قبلكم في صحف إبراهيم وموسى.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٩٤) <span class="mustanad">-مستندًا إلى السياق-</span> القول الثاني، وهو قول أبي مالك، فقال: «وهذا القول الذي ذُكِر عن أبي مالك أشْبَه بتأويل الآية». ثم علَّل ذلك بقوله: «وذلك أنّ الله -جلَّ ثناؤه- ذكر ذلك في سياق الآيات التي أخبر عنها أنها في صحف إبراهيم وموسى نذيرٌ من النُّذُر الأولى، التي جاءت الأمم قبلكم كما جاءتكم، فقوله: <span class="qpc-hafs">﴿هَذا﴾</span> بأن يكون إشارة إلى ما تقدَّمه من الكلام، أوْلى وأَشْبه منه بغير ذلك».</p><p>ونقل <u>ابنُ عطية</u> (ينظر: ٨/١٣٢) عن قوم: أن الإشارة إلى القرآن. ثم <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/١٣٣) القول الأول، فقال: «والأشبه أن تكون الإشارة إلى محمد ﷺ». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/١٥٠) أن القول الأول، وكذا قول مَن قال: إن الإشارة إلى القرآن متلازمان.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن جرير ٢٢/٩٤.|3:أخرجه ابن جرير ٢٢/٩٣.|4:أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٨١ (٢١٠٦).|5:أخرجه ابن جرير ٢٢/٩٣.|6:أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٣.|7:تفسير مقاتل بن سليمان ٤/١٦٨.
  53,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَزِفَتِ ٱلۡـَٔازِفَةُ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الآزفة مِن أسماء يوم القيامة{1}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أزِفَتِ الآزِفَةُ﴾</span>، قال: اقتربت الساعة{2}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أزفت الآزفة﴾</span>، قال: الساعة{3}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أزِفَتِ الآزِفَةُ﴾</span> يعني: اقتربت الساعة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿أزِفَتِ الآزِفَةُ﴾</span>، قال: اقتربت الساعة{5}. (١٤/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٣٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أزِفَتِ الآزِفَةُ﴾</span>، قال: الساعة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٩٥ بزيادة: عظّمه الله، وحذّره عباده.|2:تفسير مجاهد ص٦٢٩، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٩٥.|3:عزاه السيوطي إلى عبد بن حميد، وابن جرير.|4:تفسير مقاتل بن سليمان ٤/١٦٨.|5:عزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ٢٢/٩٥.
  53,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَیۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في الآية، قال: ليس لها من دون الله من آلهتهم كاشفة{1}. (١٤/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤٠<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿لَيْسَ لَها مِن دُونِ اللَّهِ كاشِفَةٌ﴾</span> ليس لها رادٌّ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ليس لها من دون الله كاشفة﴾</span>: أي: رادّة{3}. (١٤/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَيْسَ لَها مِن دُونِ اللَّهِ كاشِفَةٌ﴾</span>، يقول: لا يكشفها أحد إلا الله، يعني: الساعة لا يكشفها أحد مِن الآلهة إلا الله تعالى الذي يكشفها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿لَيْسَ لَها مِن دُونِ اللَّهِ كاشِفَةٌ﴾</span>، قال: لا يكشف عنها إلا هو{1}<span class=comment-ref>٦٣٠٤</span>. (١٤/٥٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٤</span> نقل <u>ابنُ عطية</u> (٨/١٣٣) عن ابن جرير والزّجاج أن معنى: <span class="qpc-hafs">﴿كاشفة﴾</span>: «هو من كشف السِّرِّ». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «أي: ليس من دون الله من يكشف وقتها ويعلمه». ثم ذكر عن منذر بن سعيد -نقلًا عن الزهراوي-: «هو من كشف الضُّرِّ ودَفْعِه». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «أي: ليس من يكشف هولها وخطبها».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:تفسير البغوي ٧/٤٢٠، وجاء عقبه: يعني: إذا غشيت الخلق أهوالها وشدائدها لم يكشفها ولم يردّها عنهم أحد.|3:عزاه السيوطي إلى ابن جرير.|4:تفسير مقاتل بن سليمان ٤/١٦٨.|5:عزاه السيوطي إلى ابن المنذر.
  53,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَمِنۡ هَـٰذَا ٱلۡحَدِیثِ تَعۡجَبُونَ ۝٥٩ وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ۝٦٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٤٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: لَمّا نَزَلَتْ: <span class="qpc-hafs">﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</span> بكى أصحابُ الصُّفَّة{1} حتى جَرتْ دموعُهم على خدودهم، فلمّا سمِع رسولُ الله ﷺ حنينَهم بكى معهم، فبكينا ببكائه، فقال رسول الله ﷺ: «<b>لا يلِجُ النارَ مَن بكى مِن خشية الله، ولا يدخل الجنة مُصِرٌّ على معصية، ولو لم تُذنبوا لَجاء الله بقومٍ يُذنبون فيغفر لهم</b>»{2}. (١٤/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا نَزَلَتْ هذه الآيةُ على النبيِّ ﷺ: <span class="qpc-hafs">﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</span>، فما رُؤي النبيُّ ﷺ بعدها ضاحِكًا حتى ذهب مِن الدنيا{3}. (١٤/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤٦<span class="dash">-</span></span> عن <span class="name-2">صالح أبي الخليل</span>، قال: لَمّا نَزَلَتْ هذه الآية: <span class="qpc-hafs">﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</span>، فما ضحك النبيُّ ﷺ بعد ذلك إلا أن يبتسم. ولفظ عَبد بن حُمَيد: فما رُؤي النبي ﷺ ضاحكًا ولا متبسّمًا حتى ذهب من الدنيا{4}. (١٤/٥٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَمِنۡ هَـٰذَا ٱلۡحَدِیثِ تَعۡجَبُونَ ۝٥٩ وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ۝٦٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أفَمِن هَذا الحَدِيثِ﴾</span>، قال: القرآن{5}. (١٤/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَمِن هَذا الحَدِيثِ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿تَعْجَبُونَ﴾</span> تكذيبًا به، <span class="qpc-hafs">﴿وتَضْحَكُونَ﴾</span> استهزاء، <span class="qpc-hafs">﴿ولا تَبْكُونَ﴾</span> يعني: كفار مكة؛ مِمّا فيه من الوعيد{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَمِنۡ هَـٰذَا ٱلۡحَدِیثِ تَعۡجَبُونَ ۝٥٩ وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ۝٦٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك بن فَضالة- أنّه قرأ هذه الآية: <span class="qpc-hafs">﴿أفمن هذا الحديث تعجبون وتضحكون ولا تبكون﴾</span>. قال: واللهِ، إن كان أكيس القوم في هذا الأمر لَمَن بكى، فأبكوا هذه القلوب، وابكوا هذه الأعمال، فإنّ الرجل لَتبكي عيناه وإنّه لَقاسي القلب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٠<span class="dash">-</span></span> عن <span class="name-3">الفُضَيل بن عِياض</span> -من طريق إبراهيم بن نصر-: مَن أُوتِي عِلمًا لا يزداد فيه خوفًا وحزنًا وبكاء خليقٌ بأن لا يكون أُوتي علمًا ينفعه. ثم قرأ: <span class="qpc-hafs">﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أصحاب الصفة: هم فقراء المهاجرين، ومن لم يكن له منهم منزل يسكنه، فكانوا يأوون إلى موضع مظلل في مسجد المدينة يسكنونه. النهاية (صفف).|2:أخرجه ابن شاهين في الترغيب في فضائل الأعمال ص٧٧ (٢٢٨)، والبيهقي في الشعب ٢/٢٣٣ (٧٧٧)، والثعلبي ٩/١٥٨، من طريق محمد بن يونس الكديمي، عن عبد الله بن الربيع الباهلي، عن محمد بن عمرو، عن أبي سلمة، عن أبي هريرة به.</p><p>وقال الألباني في الضعيفة ١٤/٤٣١ (٦٦٩٥): «موضوع».|3:أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٣٨٥-.|4:أخرجه ابن أبي شيبة ١٣/٢٣٤، وأحمد -كما في تخريج أحاديث الكشاف ٣/٣٨٦-، وهناد (٤٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:تفسير مجاهد ص٦٢٩، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-.|6:تفسير مقاتل بن سليمان ٤/١٦٨.|7:أخرجه ابن المبارك في كتاب الزهد ١/٧٩، ووكيع في كتاب الزهد ١/٢٤٨ مختصرًا.|8:أخرجه البيهقي في شعب الإيمان ٤/٤٢٧-٤٢٨ (١٦٧٢).
  53,60,""
  53,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنتُمۡ سَـٰمِدُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٥١<span class="dash">-</span></span> عن أبي خالد الوالبي، قال: خرج <span class="name-1">عليُّ بنُ أبي طالب</span> علينا وقد أُقيمت الصلاة، ونحن قيام ننتظره ليتقدم، فقال: ما لكم سامدون؛ لا أنتم في صلاة، ولا أنتم جلوس تنتظرون؟!{1}<span class=comment-ref>٦٣٠٥</span>. (١٤/٦١)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٣٥) قول علي بن أبي طالب بقوله: «يشبه أنه رآهم في أحاديث ونحوها مما يُظن أنه غفلة مّا».</div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿سامِدُونَ﴾</span>، قال: لاهُون؛ مُعرِضون عنه{2}. (١٤/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي نجيح، عن عكرمة- قال: السامدون: المغنُّون، بالحِميرية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق إسماعيل بن شروس، عن عكرمة- في قوله <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، قال: الغناء باليمانية، كانوا إذا سمعوا القرآن تغنّوا ولعبوا{4}. (١٤/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿سامِدُونَ﴾</span>، قال: كانوا يمرُّون على رسول الله ﷺ شامخين، ألم تر إلى البعير كيف يَخطِرُ{5} شامخًا!{6}. (١٤/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿سامِدُونَ﴾</span>. قال: السّمود: اللهو، والباطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول هُزَيْلة بنت بكر وهي تبكي قوم عاد:</p><p>ليت عادًا قبلوا الحق ولم يُبدوا جحودًا</p><p>قيل قُم فانظر إليهم ثم دع عنك السّمودا؟{7}<span class=comment-ref>٦٣٠٦</span>. (١٤/٦٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٦</span> ذكر <u>ابنُ عطية</u> (٨/١٣٤) أنّ «السامد: اللاعب اللاهي. وبهذا فسّر ابن عباس وغيره من المفسّرين، ... وسَمَدَ بلغة حِمْيَر: غَنّى». و<span class="comment-type-4">علَّق</span> عليهما بقوله: «وهذا كلّه معنًى قريبٌ بعضُه مِن بعض».</div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- قال: كانوا يكرهون أن يقوم القومُ ينتظرون الإمام، وكان يُقال: ذلك من السّمود. أو هو: السّمود. قال منصور: حين يقوم المؤذن فيقومون ينتظرون{8}. (١٤/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق أبي معشر-: أنّه كان يكره أن يقوم إذا أُقِيمت الصلاة حتى يجيء الإمام، ويقرأ هذه الآية: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>{9}. (١٤/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، قال: البَرْطَمة{10}{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سامِدُونَ﴾</span>، قال: غِضابٌ مُبرطِمون{12}. (١٤/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>: السّمود: اللهو واللعب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span> أشِرون بطِرون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، قال: هو الغناء، بالحِميرية{15}. (١٤/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سعيد بن مسروق-: هو اللعب واللهو{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، قال: غافلون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، قال: غافلون{18}. (١٤/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٧<span class="dash">-</span></span> عن <span class="name-3">مَيسرة بن عمّار الأشجعي</span>، قال: هو الغناء، بلسان كذا وكذا، يقول: اسمُد لنا؛ أي: غنِّ لنا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿سامِدُونَ﴾</span> السامد: الحزين، بلسان طيئ، وبلسان أهل اليمن: الملاهي{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، يعني: لاهُون عن القرآن، بلغة اليمن{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَنْتُمْ سامِدُونَ﴾</span>، قال: السامد: الغافل{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في المصنف (١٩٣٣)، وابن جرير ٢٢/١٠٠، وورد عنده عن أبي خالد الراسبي. وعزاه السيوطي إلى عبد بن حميد.|2:أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٧، ٩٨، ١٠١، وبنحوه من طريق عطية، وابن أبي حاتم -كما في الإتقان ٢/٤٥-، والطبراني (١١٧٢). وأخرجه ابن مردويه -كما في الفتح ٨/٦٠٥- من طريق سعيد بن جبير بلفظ: معرضون.|3:أخرجه ابن جرير ٢٢/٩٩.|4:أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٧ من طريق قتادة عن عكرمة. وأخرجه مختصرًا أبو عبيد في فضائله (٢٠٥) من طريق سفيان عن أبيه عن عكرمة، وعبد بن حميد -كما في تغليق التعليق ٤/٣٢٣-، وابن أبى الدنيا في ذم الملاهي (٣٣)، والبزار (٢٢٦٤-كشف) وابن جرير ٢٢/٩٧، وأخرجه البيهقي ١٠/٢٢٣.|5:يقال: خَطَرَ البعير بذنبه يَخْطِر: إذا رفعه وحطّه، وإنما يفعل ذلك عند الشَّبَع والسَّمَن. النهاية (خطر).|6:أخرجه أبو يعلى (٢٦٨٥)، وابن جرير ٢٢/٩٨.</p><p>قال محقق مسند أبى يعلى: «إسناده ضعيف».|7:أخرجه نافع في مسائله (٧)، وأخرجه الطبراني ١٠/٣١٠.|8:أخرجه ابن جرير ٢٢/١٠١-١٠٢، وبنحوه من طريق عمران. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن جرير ٢٢/١٠١ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.|10:البَرْطَمَة: الانتِفاخ مِن الغضب، ورجل مُبَرْطِم: مُتكبِّر. وقيل: مُقَطّب مُتَغَضِّبٌ. النهاية (برطم).|11:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٩٨، ٩٩، ١٠١، وبنحوه من طريق ليث.|12:تفسير مجاهد ص٦٢٩ بنحوه. وأخرجه ابن جرير ٢٢/٩٨. وعزاه السيوطي إلى عبد بن حميد.|13:أخرجه ابن جرير ٢٢/٩٩.|14:تفسير الثعلبي ٩/١٥٨، وتفسير البغوي ٧/٤٢١.|15:أخرجه ابن عيينة في تفسيره -كما في تغليق التعليق ٤/٣٢٢-، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٩-، وعبد بن حميد -كما في تغليق التعليق ٤/٣٢٣-، والفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٩٩.|16:أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٨٣ (٢١١٠).|17:أخرجه ابن جرير ٢٢/٩٨.|18:أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٩، كذلك من طريق سعيد.|19:أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٨٢ (٢١٠٩).|20:تفسير الثعلبي ٩/١٥٨.|21:تفسير مقاتل بن سليمان ٤/١٦٨.|22:أخرجه ابن جرير ٢٢/١٠١.
  53,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱسۡجُدُوا۟ لِلَّهِ وَٱعۡبُدُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فاسْجُدُوا لِلَّهِ واعْبُدُوا﴾</span>، قال: اعنِتوا هذه الوجوه لله، وعفِّروها في طاعة الله{1}. (١٤/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاسْجُدُوا لِلَّهِ﴾</span> يعني: صَلُّوا الصلوات الخمس، <span class="qpc-hafs">﴿واعْبُدُوا﴾</span> يعني: وحِّدوا الرّبَّ تعالى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٦٨.</p><p><b>وقد تقدم ما يتعلق بأحكام سجدة هذه السورة في الآثار المتعلقة بها، وذلك في أولها.</b>
  54,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٧٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طرق- قال: نَزَلَتْ سورة القمر بمكة{1}. (١٤/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٤<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{2}. (١٤/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: نَزَلَتْ بمكة سورة <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ﴾</span>، بعد <span class="qpc-hafs">﴿والسماء والطارق﴾</span>{3}. (١٤/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٦<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٧<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّية، وسمّياها: <span class="qpc-hafs">﴿اقتربت الساعة﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٨<span class="dash">-</span></span> عن قتادة بن دعامة: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٧٩<span class="dash">-</span></span> عن محمد بن شهاب الزُّهريّ: مكّيّة، وسمّاها: <span class="qpc-hafs">﴿اقتربت الساعة﴾</span>، نَزَلَتْ بعد سورة الهُمَزة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٠<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٨١<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة القمر مكّيّة، عددها خمس وخمسون آية{8}<span class=comment-ref>٦٣٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٣٦) أن هذه السورة مكية <span class="mustanad">بإجماع</span>، إلا آية واحدة اختُلف فيها، وهي قوله: <span class="qpc-hafs">﴿سيهزم الجمع﴾</span> [القمر:٤٥]، <b>فقال جمهور الناس</b>: هي مكية. و<b>قال قوم</b>: هي مما نزل ببدر. و<b>قيل</b>: بالمدينة.</p><p>و<span class="comment-type-3">رجّح</span> (٨/١٥٣) عند تفسيره لها أنها مكية، ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٢<span class="dash">-</span></span> عن بُرَيْدة بن الحُصَيب: أنّ معاذ بن جبل صلّى بأصحابه صلاة العشاء، فقرأ فيها: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ﴾</span>، فقام رجلٌ مِن قبل أن يفرغ، فصلّى وذهب، فقال له معاذ قولًا شديدًا، فأتى الرجلُ النبيَّ ﷺ، فاعتذر إليه، فقال: إني كنتُ أعمل في نخلٍ، وخِفتُ على الماء. فقال رسول الله ﷺ: «<b>صلِّ بـ«الشمس وضحاها»، ونحوها من السور</b>»{9}. (١٤/٦٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ۝١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٨٣<span class="dash">-</span></span> عن <span class="name-1">حُذيفة بن اليمان</span> أنه قرأ: (اقْتَرَبَتِ السّاعَةُ وقَدِ انشَقَّ القَمَرُ){10}. (١٤/٧٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ۝١﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- قال: انشقّ القمرُ على عهد رسول الله ﷺ، فقالت قريش: هذا سِحرُ ابنِ أبي كَبْشة. فقالوا: انتظِروا ما يأتيكم به السُّفّار؛ فإنّ محمدًا لا يستطيع أن يَسْحَر الناس كلّهم. فجاء السُّفار، فسألوهم، فقالوا: نعم، قد رأيناه. فأنزل الله: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>{11}. (١٤/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مجاهد، عن أبي معمر- قال: رأيتُ القمر مُنشقًّا شِقّتين مرّتين بمكة قبل مخرج النبيِّ ﷺ؛ شِقّة على أبي قبيس، وشِقّة على السويداء، فقالوا: سَحَر القمر. فنَزَلَت: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>. قال مجاهد: يقول: كما رأيتم القمر مُنشقًّا، فإنّ الذي أخبركم عن اقتراب الساعة حقّ{12}. (١٤/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٦<span class="dash">-</span></span> عن <span class="name-1">جُبير بن مُطعم</span> -من طريق محمد بن جبير- في قوله: <span class="qpc-hafs">﴿وانْشَقَّ القَمَرُ﴾</span>، قال: انشقّ القمر ونحن بمكة على عهد رسول الله ﷺ، حتى صار فِرْقتين؛ فِرْقة على هذا الجبل، وفِرْقة على هذا الجبل، فقال الناس: سَحَرَنا محمد. فقال رجل: إن كان سَحركم فإنه لا يستطيع أن يَسْحَر الناسَ كلّهم{13}<span class=comment-ref>٦٣٠٨</span>. (١٤/٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٨</span> <span class="comment-type-4">علَّق</span> <u>ابن كثير</u> (١٣/٢٩٠) على هذا الحديث بقوله: «تفرد به الإمام أحمد من هذا الوجه، وأسنده البيهقي في الدلائل من طريق محمد بن كثير، عن أخيه سليمان بن كثير، عن حُصين بن عبد الرحمن، به. وهكذا رواه ابن جرير من حديث محمد بن فضيل وغيره، عن حصين، به. ورواه البيهقي أيضًا من طريق إبراهيم بن طهمان وهشيم، كلاهما عن حصين، عن جبير بن محمد بن جبير بن مطعم، عن أبيه، عن جدّه فذكره».</div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كُسف القمر على عهد رسول الله ﷺ، فقالوا: سَحَر القمر. فنَزَلَت: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span> إلى قوله: <span class="qpc-hafs">﴿مُسْتَمِرٌّ﴾</span>{14}. (١٤/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: انتهى أهلُ مكة إلى النبيِّ ﷺ، فقالوا: هل مِن آية نعرف بها أنك رسول الله؟ فهبط جبريل، فقال: يا محمد، قُل لأهل مكة: إن تختلفوا هذه الليلة فسَتَرون آية. فأخبرهم رسول الله ﷺ بمقالة جبريل، فخرجوا ليلة أربع عشرة، فانشقّ القمرُ نصفين؛ نِصفًا على الصفا، ونِصفًا على المروة، فنظروا، ثم قالوا بأبصارهم، فمسحوها، ثم أعادوا النظر، فنظروا، ثم مسحوا أعينهم، ثم نظروا، فقالوا: يا محمد، ما هذا إلا سحرٌ ذاهِب. فأنزل الله: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>{15}. (١٤/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء، والضَّحّاك- في قوله: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، قال: اجتمع المشركون على عهد رسول الله ﷺ؛ منهم: الوليد بن المُغيرة، وأبو جهل بن هشام، والعاصي بن وائل، والعاصي بن هشام، والأسود بن عبد يغوث، والأسود بن المطلب، وزمعة بن الأسود، والنَّضر بن الحارث، فقالوا للنبي ﷺ: إن كنتَ صادقًا فشُقَّ لنا القمر فِرْقَتين؛ نِصفًا على أبي قبيس، ونِصفًا على قُعَيْقِعان. فقال لهم النبيُّ ﷺ: «<b>إن فعلتُ تؤمنوا؟</b>». قالوا: نعم. قال: وكانت ليلة بدر. فسأل رسول الله ﷺ ربّه أن يُعطيَه ما سألوا، فأمسى القمرُ قد مُثِّل نِصفًا على أبي قبيس، ونِصفًا على قُعَيْقِعان، ورسول الله ﷺ يُنادي: «<b>يا أبا سلمة بن عبد الأسد، والأرقم بن أبي الأرقم، اشهدوا</b>»{16}. (١٤/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قال: جاءت أحبار اليهود إلى رسول الله ﷺ، فقالوا: أرِنا آيةً حتى نؤمن. فسأل النبيُّ ﷺ ربّه أن يريهم آية، فأراهم القمر قد انشقّ، فصار قمرين؛ أحدهما على الصفا، والآخر على المروة، قدْر ما بين العصر إلى الليل ينظرون إليه، ثم غاب القمر، فقالوا: هذا سحرٌ مستمرٌّ{17}. (١٤/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩١<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق قتادة-: أنّ أهل مكة سألوا رسول الله ﷺ أن يريهم آية، فأراهم القمرَ شِقَّتين، حتى رَأوا حِراء بينهما{18}. (١٤/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٢<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق قتادة- قال: سأل أهلُ مكة النبيَّ ﷺ آيةً، فانشقّ القمر بمكة فِرْقتين؛ فنَزَلَتْ: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span> إلى قوله: <span class="qpc-hafs">﴿سِحْرٌ مُسْتَمِرٌّ﴾</span> يقول: ذاهب{19}. (١٤/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمرو- قال: انشقّ القمرُ على عهد رسول الله شِقّتين. فقال المشركون: سحرٌ. فنَزَلَتْ: <span class="qpc-hafs">﴿اقتربت الساعة وانشق القمر وإن يروا آية يعرضوا ويقولوا سحر مستمر﴾</span>{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٦٩٤<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق أبي معمر- قال: انشقّ القمر على عهد رسول الله ﷺ فِرْقتين؛ فِرْقة فوق الجبل، وفِرْقة دونه، فقال رسول الله ﷺ: «<b>اشهدوا</b>»{21}. (١٤/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٥<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق الأسود- قال: رأيتُ القمر وقد انشقّ، فأبصرتُ الجبل مِن بين فُرْجَتي القمر{22}. (١٤/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- قال: خمس قد مَضين: الدُّخان، واللِّزام، والبَطْشة، والقمر، والرُّوم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٧<span class="dash">-</span></span> عن أبي عبد الرحمن السلمي، قال: خطبنا <span class="name-1">حُذيفة بن اليمان</span> بالمدائن، فحمد الله، وأثنى عليه، ثم قال: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، ألا وإنّ الساعة قد اقتربَتْ، ألا وإنّ القمر قد انشقّ على عهد رسول الله ﷺ، ألا وإنّ الدنيا قد آذنت بفراقٍ، ألا وإنّ اليوم المِضمار وغدًا السّباق{24}. (١٤/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الله بن عُتبة- قال: انشقّ القمر في زمان النبيِّ ﷺ{25}. (١٤/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٦٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، قال: قد مضى ذلك؛ كان قبل الهجرة، انشقّ القمر حتى رأوا شِقَّيه{26}. (١٤/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: ثلاث ذكرهنّ الله في القرآن قد مَضين: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span> قال: قد انشقّ القمر على عهد رسول الله ﷺ شِقَّتين حتى رآه الناس، و<span class="qpc-hafs">﴿سَيُهْزَمُ الجَمْعُ ويُوَلُّونَ الدُّبُرَ﴾</span> [القمر:٤٥] كان يوم بدر، <span class="qpc-hafs">﴿حَتّى إذا فَتَحْنا عَلَيْهِمْ بابًا ذا عَذابٍ شَدِيدٍ﴾</span> [المؤمنون:٧٧]{27}. (١٤/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، قال: كان ذلك على عهد رسول الله ﷺ، انشقّ فِرْقتين؛ فِرْقة من دون الجبل، وفِرْقة خلفه، فقال النبيُّ ﷺ: «<b>اللهم اشهد</b>»{28}<span class=comment-ref>٦٣٠٩</span>. (١٤/٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٩٢) على هذا الحديث بقوله: «هكذا رواه مسلم، والترمذي، من طرق عن شعبة، عن الأعمش، عن مجاهد، به. قال مسلم كرواية مجاهد عن أبي معمر، عن ابن مسعود. وقال الترمذي: حسن صحيح».</div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٢<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخُدري</span> -من طريق رجل- قال: يسمعون صوتًا من السماء: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ﴾</span>، فمن بين مصدِّق ومكذِّب، وعارف ومنكر، فبينما هم كذلك إذ يسمعون مناديًا ينادي من السماء: يا أيها الناس، اقتربت الساعة. قال: فمن بين مصدِّق ومكذِّب، وعارف ومنكر، فلا يلبثون إلا يسيرًا حتى يسمعون الصيحة، فذاك حين تُلْهى كلّ واحدة عن ولدها{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعيّ</span> -من طريق مُغيرة- قال: مضى، انشقّ القمر بمكة{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، قال: انفلق القمر فِلْقتين، فثبتت فِلْقة، وذهبت فِلْقة من وراء الجبل، فقال النبي ﷺ: «<b>اشهدوا</b>»{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، قال: رَأوه مُنشقًّا{32}. (١٤/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>، قال: كما رأيتم القمر مُنشقًا فإنّ الذي أخبركم عن اقتراب الساعة حقّ{33}. (١٤/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</span>: يُحدث الله في خلْقه ما يشاء{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق ابنه عثمان- <span class="qpc-hafs">﴿وانْشَقَّ القَمَرُ﴾</span> أنّ معناه: وسينشقّ القمر{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ﴾</span> يعني: القيامة، ومن علامة ذلك: خروج النبي ﷺ، والدُّخان، وانشقاق القمر. وذلك أنّ كفار مكة سألوا النبي ﷺ أن يريهم آية، فانشقّ القمر نِصفين، فقالوا: هذا عمل السّحرة{36}<span class=comment-ref>٦٣١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٠</span> <span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٨/١٣٧) عن الثعلبي أنه <b>قيل</b>: إنّ المعنى: ينشق القمر يوم القيامة. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للسنة، والإجماع</span>، فقال: «وهذا ضعيف، والأمّة على خلافه». وساق الآثار في ثبوت ذلك ووقوعه.</p><p><span class="comment-type-4">وذكر</span> <u>ابنُ كثير</u> (١٣/٢٨٩) أن وقوع انشقاق القمر في زمان النبي ﷺ أمر <span class="mustanad">متفق عليه بين العلماء،</span> وأنه كان إحدى المعجزات الباهرات.</div></p></div>",footnotes:1:أخرجه النحاس ص٦٨٠ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في الدلائل ٧/١٤٤ من طريق خُصَيف عن مجاهد.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|5:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|6:تنزيل القرآن ص٣٧-٤٢.|7:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|8:تفسير مقاتل بن سليمان ٤/١٧٥.|9:أخرجه أحمد ٣٨/١١٥-١١٦ (٢٣٠٠٨)، من طريق حسين بن واقد، عن عبد الله بن بريدة، عن بريدة به.</p><p>قال مغلطاي في شرح ابن ماجه ٥/١٤٠٩: «سند صحيح». وقال الهيثمي في المجمع ٢/١١٨-١١٩ (٢٧٠٨): «رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٢/٨٦ (١٠٨٨): «هذا إسناد صحيح، بل قيل فيه: إنه مِن أصح الإسناد». وقال ابن حجر في الفتح ٢/١٩٣: «ووقع عند أحمد من حديث بريدة بإسناد قوي، فقرأ: <span class="qpc-hafs">﴿اقتربت الساعة﴾</span>، وهي شاذة، إلا إن حُمل على التعدد». وقال العيني في عمدة القاري ٥/٢٣٦: «إسناد قوي». وقال الألباني في الإرواء ١/٣٣١: «سند صحيح، غير أن قوله: فقرأ فيها: <span class="qpc-hafs">﴿اقتربت الساعة﴾</span> شاذ، والمحفوظ أنه قرأ البقرة في سائر الروايات المتقدمة».|10:عزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٢٩٧، ومختصر ابن خالويه ص١٤٨.|11:أخرجه البيهقي في دلائل النبوة ٢/٢٦٦-٢٦٧، والواحدي في أسباب النزول ص٤٠٠، وابن جرير ٢٢/١٠٦-١٠٧، والثعلبي ٩/١٦٢، من طريق أبي عوانة، عن المُغيرة، عن أبي الضحى، عن مسروق، عن عبد الله به.</p><p>وسنده صحيح.|12:أخرجه الحاكم ٢/٥١٢ (٣٧٥٧)، وعبد الرزاق ٣/٢٥٩ (٣٠٥٩).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه بهذه السياقة». ووافقه الذهبي في التلخيص.|13:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٣٣-، وأحمد ٢٧/٣١٤ (١٦٧٥٠)، والترمذي (٣٢٨٩)، وابن جرير ٢٢/١٠٩، والحاكم ٢/٤٧٢، والبيهقي ٢/٢٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه، وأبي نعيم.</p><p>صححه الحاكم. وقال الألباني في صحيح سنن الترمذي (٢٦٢٢): «صحيح الإسناد».|14:أخرجه الطبراني في الكبير ١١/٢٥٠ (١١٦٤٢-١١٦٤٣)، من طريق أحمد بن عمرو البزار، عن محمد بن يحيى القطعي، عن محمد بن بكر، عن ابن جُرَيْج، عن عمرو بن دينار، عن عكرمة، عن ابن عباس به.</p><p>قال ابن كثير في البداية والنهاية عن إسناد الطبراني ٤/٢٩٩: «إسناد جيد».|15:أخرجه أبو نعيم -كما في البداية والنهاية لابن كثير ٤/٢٩٧-، من طريق إسماعيل بن زياد، عن ابن جُرَيْج، عن عطاء، عن ابن عباس به.</p><p>وسنده ضعيف جدًّا، فيه إسماعيل بن زياد، قال عنه ابن حجر في تقريب التهذيب (٤٤٦): «متروك، كذّبوه».|16:أخرجه أبو نعيم في دلائل النبوة ص٢٧٩-٢٨٠ (٢٠٩)، من طريق بكر بن سهل، عن عبد الغني بن سعيد، عن موسى بن عبد الرحمن، عن ابن جُرَيْج، عن عطاء، عن ابن عباس. وعن مقاتل، عن الضَّحّاك، عن ابن عباس به.</p><p>قال ابن حجر في الفتح ٧/١٨٢: «ضعيف».|17:أخرجه أبو نعيم في الدلائل (٢١٠).|18:أخرجه عبد الرزاق ٢/٢٥٧، والبخاري (٣٦٣٧، ٣٨٦٨، ٤٨٦٧، ٤٨٦٨)، ومسلم (٢٨٠٢/٤٦)، وابن جرير ٢٢/١٠٣-١٠٤، ١٠٥.|19:أخرجه البخاري ٤/٢٠٦-٢٠٧ (٣٦٣٧)، ٥/٤٩ (٣٨٦٨)، ٦/١٤٢-١٤٣ (٤٨٦٧، ٤٨٦٨)، ومسلم ٤/٢١٥٩ (٢٨٠٢) دون ذكر الآية، وعبد الرزاق ٣/٢٥٧ (٣٠٥٧)، وابن جرير ٢٢/١١١، والثعلبي ٩/١٦١ دون ذكر الآية أيضًا.|20:أخرجه نعيم بن حماد في كتاب الفتن ٢/٦٠٣. وذكره في الإيماء ٧/٤٧٢ (٧١٦٤)، وعزاه إلى جزء سعدان (٥٥) وقال: «وصله الطبراني (١١٦٤٢) عن عكرمة، عن ابن عباس».|21:أخرجه البخاري ٤/٢٠٦ (٣٦٣٦)، ٥/٤٩ (٣٨٦٩، ٣٨٧١)، ٦/١٤٢ (٤٨٦٤، ٤٨٦٥) واللفظ له، ومسلم ٤/٢١٥٨ (٢٨٠٠)، وابن جرير ٢٢/١٠٥، والثعلبي ٩/١٦٠-١٦١.|22:أخرجه عبد الرزاق ٢/٢٥٧، وبنحوه من طريق الكلبي، وأحمد ٧/٣٩ (٣٩٢٤)، وابن جرير ٢٢/١٠٦، والحاكم ٢/٤٧١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٥-. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه، وأبي نعيم في الدلائل.</p><p>صححه الحاكم. وقال محققو المسند: «حديث صحيح».|23:أخرجه ابن جرير ٢٢/١٠٧. وعلقه يحيى بن سلام ١/٤٩٤ مطولًا.|24:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٧٥-٧٦ (١٧٠) من طريق مسلم بن أبي عمران، وابن أبي شيبة ٢/١١٥، ١٣/٣٧٨، وابن جرير ٢٢/١٠٧، ١٠٨، ١١٢، ومن طريق أبي سنان أيضًا، وابن مردويه -كما في تخريج الكشاف ٣/٣٩١-، وأبو نعيم في الحلية ١/٢٨٠-٢٨١. وعزاه السيوطي إلى عبد بن حميد، وعبد الله بن أحمد في زوائد الزهد.|25:أخرجه البخاري (٣٦٣٨، ٣٨٧٠، ٤٨٦٦)، ومسلم (٢٨٠٣)، وابن جرير ٢٢/١١٠ بنحوه من طريق عطية، والبيهقي في الدلائل ٢/٢٦٧. وعزاه السيوطي إلى ابن مردويه.|26:أخرجه ابن جرير ٢٢/١١٠. وعزاه السيوطي إلى ابن مردويه، وأبي نعيم في الدلائل.|27:عزاه السيوطي إلى ابن مردويه. وأخرج نحوه يحيى بن سلام ١/٤٩٤ من طريقي علي بن أبي طلحة والأعمش، ولفظه: ثلاث آيات قد مضين؛ اثنتان منهم يوم بدر، يوم ذو عذاب شديد، <span class="qpc-hafs">﴿سيهزم الجمع﴾</span>، <span class="qpc-hafs">﴿وانشق القمر﴾</span>.|28:أخرجه مسلم ٤/٢١٥٩ (٢٨٠١)، والحاكم ٢/٥١٣ (٣٧٥٩) واللفظ له، وابن جرير ٢٢/١٠٥-١٠٦.|29:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٥٠ (٤١)-.|30:أخرجه ابن جرير ٢٢/١١٣.|31:أخرجه ابن جرير ٢٢/١١٠-١١١، ومن طريق ليث أيضًا وفيه: فقال النبي ﷺ لأبي بكر: «<b>اشهد، يا أبا بكر</b>».|32:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١١٠. وعزاه السيوطي إلى عبد بن حميد.|33:أخرجه عبد الرزاق ٣/٢٥٩، وأخرج نحوه ابن مردويه -كما في الفتح ٧/١٨٤- من طريق ابن جريج.|34:أخرجه ابن جرير ٢٢/١١١.|35:أخرجه الثعلبي ٩/١٦٠.|36:تفسير مقاتل بن سليمان ٤/١٧٧.
  54,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یَرَوۡا۟ ءَایَةࣰ یُعۡرِضُوا۟ وَیَقُولُوا۟ سِحۡرࣱ مُّسۡتَمِرࣱّ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧١٠<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١١<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿سِحْرٌ مُسْتَمِرٌّ﴾</span>، أي: مُحكمٌ شديد قوي، وهو مِن المرّة، وهي القوّة{1}<span class=comment-ref>٦٣١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١١</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٨/١٣٨) على قول الضَّحّاك وأبي العالية، بقوله: "وقال أبو العالية والضَّحّاك: معناه: مشدود، من مراير الحبل، كأنه سحر قد استمرّ، أي: أُحْكم، <span class="mustanad">ومنه قول الشاعر</span>:</p><p>حتى استمرّت على شزر مريرته صدق العزيمة لا رتًّا ولا ضرعا".</div></p><p><div></p><p><p><span class="item-no">٧٣٧١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سِحْرٌ مُسْتَمِرٌّ﴾</span>، قال: ذاهب{2}. (١٤/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</span> كما يقول أهل الشرك إذا كُسف القمر؛ يقولون: هذا عمل السّحرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: كان القمر قد انشقّ ورسول الله ﷺ بمكة قبل أن يُهاجِر، فقالوا: هذا سحرُ أسْحَرِ السَّحرة، فافعلوا كما فعل المشركون؛ إذا كُسِف القمر ضربوا بِطِساسِهم{4}، واصفرّ أحبارهم، وقالوا: هذا فِعلُ السّحر. فذلك قوله: <span class="qpc-hafs">﴿وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</span>{5}. (١٤/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</span>، قال: إذا رأى أهلُ الضّلالة آيةً مِن آيات الله قالوا: إنّما هذا عمل السّحر، يوشك هذا أن يستمرّ ويذهب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١٦<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span>: <span class="qpc-hafs">﴿ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</span>، أي: نافذ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ يَرَوْا آيَةً﴾</span> يعني: انشقاق القمر <span class="qpc-hafs">﴿يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</span> يعني: سحرٌ ذاهب، فاستمر، ثم التأم القمر بعد ذلك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧١٨<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- في قوله: <span class="qpc-hafs">﴿يُعْرِضُوا﴾</span> قال: حين انشقّ القمر بفِلْقتين؛ فِلْقة من وراء الجبل، وبَقِيتْ فِلْقة أخرى، فقال المشركون حين رأوا ذلك: <span class="qpc-hafs">﴿سِحْرٌ مُسْتَمِرٌّ﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَرَوۡا۟ ءَایَةࣰ یُعۡرِضُوا۟ وَیَقُولُوا۟ سِحۡرࣱ مُّسۡتَمِرࣱّ ۝٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٧١٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عكرمة- قال: كُسِفت الشمس على عهد رسول الله ﷺ، فقالوا: سَحَر الشمسَ. فتلا رسولُ الله ﷺ: <span class="qpc-hafs">﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</span>{10}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٦٢ واللفظ له، وجاء عقبه: وهو من المرّة وهي القوة، وتفسير البغوي ٧/٤٢٦.|2:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١١٣. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ٢٢/١١٣.|4:بِطِساسِهم: جمع الطَّسَّة، وهو الطَّسْت من الآنية ويكون من النحاس أو غيره. التاج والمعجم الوسيط (طسس).|5:عزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ٢٢/١١٣، ومن طريق معمر أيضًا بلفظ: ذاهب.|7:تفسير الثعلبي ٩/١٦٢.|8:تفسير مقاتل بن سليمان ٤/١٧٧.|9:أخرجه ابن جرير ٢٢/١١٣.|10:أخرجه الطبراني في الأوسط ٨/١٧٥ (٨٣١٥)، عن موسى بن زكريا، عن محمد بن يحيى القطيعي، عن محمد بن بكر البرساني، عن ابن جريج، عن عمرو بن دينار، عن عكرمة.</p><p>قال الهيثمي في مجمع الزوائد ٢/ ٢٠٩: «رواه الطبراني في الأوسط، وفيه موسى بن زكريا شيخ الطبراني؛ فإن كان هو التستري فقد تكلم فيه الدارقطني، وإن كان غيره فلا أعرفه، وبقية رجاله رجال الصحيح».
  54,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَّبُوا۟ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُمۡۚ وَكُلُّ أَمۡرࣲ مُّسۡتَقِرࣱّ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</span>، قال: يوم القيامة{1}. (١٤/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</span>، قال: مستقرٌّ بأهل الخيرِ الخيرُ، وبأهل الشرِّ الشرُّ{2}. (١٤/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</span> لكلّ أمر حقيقة، ما كان منه في الدنيا فسيظهر، وما كان منه في الآخرة فسيُعرف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعال: <span class="qpc-hafs">﴿وكَذَّبُوا﴾</span> بالآية، يعني: بالقمر أنه ليس من الله تعالى، <span class="qpc-hafs">﴿واتَّبَعُوا أهْواءَهُمْ وكُلُّ أمْرٍ﴾</span> هذا وعيد <span class="qpc-hafs">﴿مُسْتَقِرٌّ﴾</span> يعني: لكل حديث منتهًى وحقيقة، يعني: العذاب في الدنيا؛ القتْل ببدر، ومنه في الآخرة: عذاب النار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</span>، قال: بأهله{5}. (١٤/٧١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦١٦-.|2:أخرجه ابن جرير ٢٢/١١٤-١١٥. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.|3:تفسير البغوي ٧/٤٢٦.|4:تفسير مقاتل بن سليمان ٤/١٧٧.|5:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦١٦-. وعزاه السيوطي إلى ابن المنذر.
  54,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ جَاۤءَهُم مِّنَ ٱلۡأَنۢبَاۤءِ مَا فِیهِ مُزۡدَجَرٌ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٢٥<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> أنه خطب بالمدينة، فتلا هذه الآية: <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</span>، قال: أحلّ فيه الحلال، وحرَّم فيه الحرام، وأنبأكم فيه ما تأتون، لم يَدعْكم في لَبْسٍ مِن دينكم، كرامة أكرمكم بها، ونعمة أتمّ بها عليكم{1}. (١٤/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</span>، قال: هذا القرآن مُزدَجر. قال: مُنْتَهى. وفى لفظ: مُتَناهِي{2}. (١٤/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</span>، أي: هذا القرآن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ﴾</span> يعني: جاء أهل مكة <span class="qpc-hafs">﴿مِنَ الأَنْباءِ﴾</span> مِن حديث القرآن <span class="qpc-hafs">﴿ما فِيهِ مُزْدَجَرٌ﴾</span> يعني: موعظة لهم، وهو النهي عن المعاصي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٧٢٩<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</span>، قال: المُزدجر: المنتهى{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.|2:تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١١٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|3:أخرجه ابن جرير ٢٢/١١٥.|4:تفسير مقاتل بن سليمان ٤/١٧٧.|5:أخرجه ابن جرير ٢٢/١١٥.
  54,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حِكۡمَةُۢ بَـٰلِغَةࣱۖ فَمَا تُغۡنِ ٱلنُّذُرُ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: جاءهم <span class="qpc-hafs">﴿حِكْمَةٌ بالِغَةٌ﴾</span>، يعني: القرآن، نظيرها في يونس [١٠١]: <span class="qpc-hafs">﴿وما تُغْنِي الآياتُ والنُّذُرُ عَنْ قَوْمٍ لا يُؤْمِنُونَ﴾</span> يقول: أرسلتُ إليهم وأنذرتُهم فكفروا بما جاءهم من البيان، <span class="qpc-hafs">﴿فَما تُغْنِ النُّذُرُ﴾</span>{1}<span class=comment-ref>٦٣١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٣٩) أن «ما» في قوله: <span class="qpc-hafs">﴿فما تغن النذر﴾</span> تحتمل احتمالين: <b>الأول</b>: أن تكون نافية، أي: ليس تغني مع عتوّ هؤلاء الناس. <b>الثاني</b>: أن تكون استفهامًا بمعنى التقرير، أي: فما غناء النذر مع هؤلاء الكفرة؟!.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٧.
  54,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّ عَنۡهُمۡۘ یَوۡمَ یَدۡعُ ٱلدَّاعِ إِلَىٰ شَیۡءࣲ نُّكُرٍ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٧٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> يعني: فأَعرِض عن كفار مكة <span class="qpc-hafs">﴿يَوْمَ يَدْعُ الدّاعِ﴾</span> وهو إسرافيل، ينفخ الثانية قائمًا على صخرة بيت المقدس <span class="qpc-hafs">﴿إلى شَيْءٍ نُكُرٍ﴾</span> يعني: إلى أمر فظيع{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٧-١٧٨.