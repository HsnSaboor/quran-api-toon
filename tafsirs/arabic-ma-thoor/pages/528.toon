tafsir[24]{c,v,t}:
53,45," <q>﴿وَأَنَّهُۥ خَلَقَ ٱلزَّوۡجَیۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰ ۝٤٥ مِن نُّطۡفَةٍ إِذَا تُمۡنَىٰ ۝٤٦﴾</q> - تفسير ٧٣٥٧٧- قال الضَّحّاك بن مُزاحِم= (ز) ٧٣٥٧٨- وعطاء بن أبي رباح: <q>﴿مِن نُطْفَةٍ إذا تُمْنى﴾</q> أي: تُصبّ في الرَّحِم{1}. (ز) ٧٣٥٧٩- قال مقاتل بن سليمان: <q>﴿وأَنَّهُ خَلَقَ الزَّوْجَيْنِ﴾</q> الرجل والمرأة؛ كلّ واحد منهما زَوْجُ الآخر <q>﴿الذَّكَرَ والأُنْثى﴾</q> خلَقهما <q>﴿مِن نُطْفَةٍ إذا تُمْنى﴾</q> يعني: إذا تدفّق المني{2}٦٢٩٨. (ز) ٦٢٩٨ ذكر ابنُ عطية (٨/١٢٨) في معنى: <q>﴿تُمنى﴾</q> احتمالين: الأول: «أن يكون من قولك: أمنى الرجل: إذا خرج منه المنيّ»؟ والثاني: «أن يكون مِن قولك: منى الله الشيء: إذا خلقه». ثم وجَّهه بقوله: «فكأنه قال: إذا تُخلَق وتُقَدَّر». ",footnotes:1:تفسير الثعلبي ٩/١٥٦، وتفسير البغوي ٧/٤١٨.تفسير مقاتل بن سليمان ٤/١٦٦.
  53,46,""
53,47," <q>﴿وَأَنَّ عَلَیۡهِ ٱلنَّشۡأَةَ ٱلۡأُخۡرَىٰ ۝٤٧﴾</q> - تفسير ٧٣٥٨٠- قال مقاتل بن سليمان: <q>﴿وأَنَّ عَلَيْهِ النَّشْأَةَ الأُخْرى﴾</q> يعني: الخَلْق الآخر، يعني: البعث في الآخرة بعد الموت{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٦.
53,48," <q>﴿وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنَىٰ ۝٤٨﴾</q> - تفسير ٧٣٥٨١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأَنَّهُ هُوَ أغْنى وأَقْنى﴾</q>، قال: أعطاه وأرضاه {1}. (١٤/٥٣) ٧٣٥٨٢- عن عبد الله بن عباس، في قوله: <q>﴿أغْنى﴾</q> قال: أكثر، <q>﴿وأَقْنى﴾</q> قال: قنّع{2}. (١٤/٥٣) ٧٣٥٨٣- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿أغْنى وأَقْنى﴾</q>. قال: أغنى من الفقر، وأقنى من الغنى فقنع به. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عَنترة العَبسيّ: فاقْنَي حياءك لا أبا لك واعلمي أني امرؤ سأموت إنْ لم أُقْتلِ؟{3}. (١٤/٥٣) ٧٣٥٨٤- عن مجاهد بن جبر، قال: <q>﴿أغْنى﴾</q> رضّى، <q>﴿أقْنى﴾</q> موَّن{4}. (١٤/٥٣) ٧٣٥٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿أغْنى﴾</q> قال: موّل، <q>﴿وأَقْنى﴾</q> قال: رضّى{5}. (ز) ٧٣٥٨٦- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿وأَنَّهُ هُوَ أغْنى وأَقْنى﴾</q>، قال: <q>﴿أغْنى﴾</q> موَّل، <q>﴿وأَقْنى﴾</q> أخدم{6}. (ز) ٧٣٥٨٧- قال الضَّحّاك بن مُزاحِم: <q>﴿أغْنى﴾</q> بالذّهب والفِضّة وصنوف الأموال، <q>﴿وأقنى﴾</q> بالإبل والبقر والغنم{7}. (ز) ٧٣٥٨٨- عن الحسن البصري -من طريق أبي رجاء- قال: <q>﴿أغْنى﴾</q> في المال، <q>﴿وأَقْنى﴾</q> قال: أخدم{8}. (١٤/٥٤) ٧٣٥٨٩- عن الضَّحّاك بن مُزاحِم، مثله{9}. (١٤/٥٤) ٧٣٥٩٠- عن أبي صالح باذام -من طريق السُّدِّيّ- في قوله: <q>﴿أغنى﴾</q> قال: أغنى بالمال، <q>﴿وأَقْنى﴾</q> قال: القُنيَة{10}. (١٤/٥٤) ٧٣٥٩١- عن قتادة بن دعامة- من طريق سعيد- في قوله: <q>﴿أغنى وأقنى﴾</q> قال: أعطى وأرضى وأخدم{11}. (١٤/٥٤) ٧٣٥٩٢- عن سليمان التيمي، في قول الله ﷿: <q>﴿أغنى وأقنى﴾</q>، قال: زعم حضرمي [بن لاحق التميمي السعدي] أنه: أغنى نفسه، وأفقر الخلائق إليه{12}٦٢٩٩. (١٤/٥٤) ٦٢٩٩ نقل ابن عطية (٨/١٢٩) عن بعضهم: أن «أقنى معناه: أكسب ما يُقتنى». ثم نقل قول مجاهد، وحضرمي، ثم نقل عن الأخفش: «أقنى: أفقر». ثم علَّق عليها بقوله: «وهذه عبارات لا تقتضيها اللفظة، والوجْه فيها بحسب اللغة: أكْسَبَ ما يُقْتَنى». ثم نقل قول ابن عباس أن أقْنى معناه: أقنع، ثم علَّق عليه بقوله: «والقناعة خير قَنْيَة، والغِنى عَرَضٌ زائل، فلله دَرُّ ابنِ عباس ﵄». ونقل ابنُ كثير (١٣/٢٨٢) قول حضرمي، وابن زيد، ثم انتقدهما بقوله: «وهما بعيدان مِن حيث اللفظ». ٧٣٥٩٣- قال مقاتل بن سليمان: <q>﴿وأَقْنى﴾</q>، يقول: موَّل وأرضى هذا الإنسان بما أعطى{13}. (ز) ٧٣٥٩٤- عن سفيان -من طريق الحسن- قال: سمعتُ المفسّرين مِن كل جانبٍ يقولون في قوله: <q>﴿أغْنى﴾</q> قال: أرضى. قال سفيان: لا يكون غنيًّا أبدًا حتى يَرضى بما قَسم الله له، فذلك الغني{14}. (ز) ٧٣٥٩٥- عن عبد الرحمن بن زيد بن أسلم- من طريق ابن وهب- في قوله: <q>﴿وأَنَّهُ هُوَ أغْنى وأَقْنى﴾</q>، قال: <q>﴿أغنى﴾</q> فأكثر، و<q>﴿أقنى﴾</q> أقلَّ. وقرأ: <q>﴿يبسط الرزق لمن يشاء من عباده ويقدر له﴾</q> [العنكبوت:٦٢]{15}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٨٤، ومن طريق عطية بلفظ: أغنى وأرضى، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٤، والإتقان ٢/٤٥-.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٤-.أخرجه الطستي -كما في الإتقان ٢/١٠٠-.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر. وعند ابن جرير بلفظ مختلف كما في الأثرين التاليين.تفسير مجاهد ص٦٢٨، وأخرجه ابن جرير ٢٢/٨٤.أخرجه ابن جرير ٢٢/٨٣.تفسير الثعلبي ٩/١٥٦، وتفسير البغوي ٧/٤١٩.أخرجه ابن جرير ٢٢/٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٢/٨٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٨٣، كما أخرجه من طريق معمر بلفظ: أغنى وأخدم. وعزا السيوطي نحوه إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٨٤، وأبو الشيخ في العظمة (١٧٦) واللفظ له، ولفظ ابن جرير: زعم حضرمي أنه ذُكر له.تفسير مقاتل بن سليمان ٤/١٦٦.أخرجه ابن أبي الدنيا في الرضا عن الله ١/٤٥٦ (٩٥).أخرجه ابن جرير ٢٢/٨٦.
53,49," <q>﴿وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ۝٤٩﴾</q> - نزول الآية ٧٣٥٩٦- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: نَزَلَتْ هذه الآية في خُزاعة، وكانوا يعبدون الشِّعرى، وهو الكوكب الذي يتبع الجَوزاء{1}. (١٤/٥٥) ٧٣٥٩٧- عن قتادة بن دعامة -من طريق معمر- قال: كان ناس في الجاهلية يعبدون هذا النّجم الذي يُقال له: الشِّعْرى؛ فنَزَلَتْ: <q>﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</q>{2}. (١٤/٥٥) <q>﴿وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ۝٤٩﴾</q> - تفسير الآية ٧٣٥٩٨- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</q>، قال: هو الكوكب الذي يُدعى: الشِّعرى{3}. (١٤/٥٤) ٧٣٥٩٩- عن مجاهد بن جبر -من طريق خُصَيف- قال: <q>﴿الشِّعْرى﴾</q> الكوكب الذي خَلف الجَوزاء، كانوا يعبدونه{4}. (١٤/٥٥) ٧٣٦٠٠- عن مجاهد بن جبر -من طريق منصور- <q>﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</q>، قال: نجم كان يُعبد في الجاهلية{3}. (ز) ٧٣٦٠١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</q>، قال: مِرْزم الجوزاء{6}. (ز) ٧٣٦٠٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿رَبُّ الشِّعْرى﴾</q>، قال: كان ناس في الجاهلية يعبدون هذا النّجم الذي يقال له: الشِّعرى{7}. (ز) ٧٣٦٠٣- قال مقاتل بن سليمان: الشِّعرى اليمانية النّيّرة الجنوبية، كوكب مضيء، وهي التي تتبع الجوزاء، ويُقال لها: المُزْنُ والعَبُور، كان أناس من الأعراب مِن خُزاعة وغسّان وغَطَفان يعبدونها، وهي الكوكب الذي يطلع بعد الجَوزاء، قال الله تعالى: أنا ربّها؛ فاعبدوني{8}. (ز) ٧٣٦٠٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَنَّهُ هُوَ رَبُّ الشِّعْرى﴾</q>، قال: كانت تُعبد في الجاهلية، فقال: تعبدون هذه وتتركون ربّها؟! اعبدوا ربّها. قال: والشِّعرى: النّجم الوقّاد الذي يتبع الجَوزاء، يقال له: المِرْزم{9}. (ز) ",footnotes:1:أخرجه الفاكهي ٥/١٦٥، من طريق الكلبي، عن أبي صالح، عن ابن عباس به. ضعيف. وينظر: مقدمة الموسوعة.أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٨٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٨٥.أخرجه ابن جرير ٢٢/٨٥، وأبو الشيخ (٦٩٥). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٨٥.تفسير مجاهد ص٦٢٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، والفاكهي ٥/١٦٥، وابن جرير ٢٢/٨٦.أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٨٦ من طريقي معمر وسعيد.تفسير مقاتل بن سليمان ٤/١٦٦-١٦٧.أخرجه ابن جرير ٢٢/٨٦، ٨٨.
53,50," <q>﴿وَأَنَّهُۥۤ أَهۡلَكَ عَادًا ٱلۡأُولَىٰ ۝٥٠ وَثَمُودَا۟ فَمَاۤ أَبۡقَىٰ ۝٥١﴾</q> - تفسير ٧٣٦٠٥- قال مقاتل بن سليمان: <q>﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</q> بالعذاب، وذلك أنّ أهل عاد وثمود، وأهل السواد، وأهل المُوصل، وأهل العال كلّها مِن ولد إرَم بن سام بن نوح ﵇، فمِن ثَمّ قال: <q>﴿أهْلَكَ عادًا الأُولى﴾</q> يعني: قوم هود بالعذاب، <q>﴿و﴾</q>أهلك <q>﴿ثَمُودَ﴾</q> بالعذاب <q>﴿فَما أبْقى﴾</q>{1}. (ز) ٧٣٦٠٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</q>، قال: كانت الآخرة بحضْرموت{2}. (١٤/٥٥) ٧٣٦٠٧- عن محمد بن إسحاق -من طريق سلمة-: وكان هلاك عاد الآخرة ببغي بعضهم على بعض، فتفانَوا بالقتل{3}. (ز) ٧٣٦٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</q>، قال: يُقال: هي مِن أول الأمم{3}٦٣٠٠. (ز) ٦٣٠٠ وجَّه ابنُ عطية (٨/١٢٩) قول ابن زيد بقوله: «فهي أُولى بالإضافة إلى الأمم المتأخرة». ثم ذكر قول ابن جرير: «سُميت أولى؛ لأن ثَمَّ عادًا أخيرة -وهي قبيلة- كانت بمكة مع العماليق، وهم بنو لُقَيم بن هزّال». ثم رجَّح قول ابن زيد. وانتقد قول ابن جرير قائلًا: «والقول الأول أبْيَن؛ لأن هذا الأخير لم يصح». ثم ذكر عن المبرد -نقلًا عن الزهراوي-: «عاد الأخيرة هي ثمود». واستشهد ببيتٍ من الشعر، ثم نقل قولًا أن «الأخيرة: الجبّارون». ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٧.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٨٨.أخرجه ابن جرير ٢٢/٨٨.
  53,51,""
53,52," <q>﴿وَقَوۡمَ نُوحࣲ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُوا۟ هُمۡ أَظۡلَمَ وَأَطۡغَىٰ ۝٥٢﴾</q> - تفسير ٧٣٦٠٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وقَوْمَ نُوحٍ مِن قَبْلُ إنَّهُمْ كانُوا هُمْ أظْلَمَ وأَطْغى﴾</q>، قال: لم يكن قبيلٌ مِن الناس هم أظلم وأطغى مِن قوم نوح، دعاهم نوحٌ ألفَ سنة إلا خمسين عامًا، كلّما هلك قرنٌ ونشأ قرنٌ دعاهم، حتى لقد ذُكِر لنا: أنّ الرجل كان يأخذ بيد أخيه أو ابنه فيمشي به إليه، فيقول: يا بُني، إنّ أبي قد مشى بي إلى هذا، وأنا مثلك يومئذ. تَتابُعًا في الضلالة، وتكذيبًا بأمر الله{1}. (١٤/٥٥) ٧٣٦١٠- قال مقاتل بن سليمان: <q>﴿وقَوْمَ نُوحٍ﴾</q> بالغرق <q>﴿مِن قَبْلُ﴾</q> هلاك عاد وثمود؛ <q>﴿إنَّهُمْ كانُوا هُمْ أظْلَمَ وأَطْغى﴾</q> من عاد وثمود، وذلك أنّ نوحًا دعا قومَه ألف سنة إلا خمسين عامًا، فلم يُجيبوه، حتى إنّ الرجل منهم كان يأخذ بيد ابنِه، فينطلِق به إلى نوحٍ ﵇، فيقول له: احذر هذا؛ فإنه كذّاب، فإنّ أبي قد مشى بي إلى هذا وأنا مثلك، فحذّرني منه؛ فاحذره. فيموت الكبير على الكفر، وينشأ الصغير على وصيّة أبيه، فنشأ قرنٌ بعد قرنٍ على الكفر <q>﴿هُمْ أظْلَمَ وأَطْغى﴾</q>، فبقي مِن نسلهم بعد عاد أهل السواد، وأهل الجزيرة، وأهل العال، فمِن ثَمَّ قال: <q>﴿عادًا الأُولى﴾</q>{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٨٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. كما أخرجه عبد الرزاق ٢/٢٥٤، وابن جرير ٢٢/٩٠ من طريق معمر مختصرًا.تفسير مقاتل بن سليمان ٤/١٦٧.
53,53," <q>﴿وَٱلۡمُؤۡتَفِكَةَ أَهۡوَىٰ ۝٥٣﴾</q> - تفسير ٧٣٦١١- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿والمُؤْتَفِكَةَ أهْوى﴾</q>، قال: المكذِّبين أهلكهم الله{1}. (ز) ٧٣٦١٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿والمُؤْتَفِكَةَ أهْوى﴾</q>، قال: أهوى بها جبريل بعد أن رفعها إلى السماء{2}. (١٤/٥٦) ٧٣٦١٣- عن عكرمة مولى ابن عباس، في قوله: <q>﴿والمُؤْتَفِكَةَ أهْوى﴾</q>، قال: قوم لوط ائتفكتْ بهم الأرض بعد أن رفعها الله إلى السماء، فالأرض تَجَلجَل بهم إلى يوم القيامة{3}. (١٤/٥٦) ٧٣٦١٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿والمُؤْتَفِكَةَ أهْوى﴾</q>، قال: قرى قوم لوط{4}. (١٤/٥٦) ٧٣٦١٥- عن أبي عيسى يحيى بن رافع -من طريق إسماعيل- <q>﴿والمُؤْتَفِكَةَ أهْوى﴾</q>، قال: قرية لوط أهوى بها{5}. (ز) ٧٣٦١٦- عن إسماعيل السُدِّيّ -من طريق أسباط- قال: لَمّا أصبحوا -يعني: قوم لوط- نزل جبرئيل، فاقتلع الأرض من سبع أرضين، فحملها حتى بلغ السماء الدنيا، حتى سمع أهلُ السماء نباحَ كلابهم وأصوات ديوكهم، ثم قلبها، فقتلهم، فذلك حين يقول: <q>﴿والمؤتفكة أهوى﴾</q> المنقلبة حين أهوى بها جبرئيل الأرض، فاقتلعها بجناحه...{6}. (ز) ٧٣٦١٧- قال مقاتل بن سليمان: <q>﴿و﴾</q> أهلك <q>﴿المُؤْتَفِكَةَ﴾</q> يعني: الكذبة{7} أهوى، يعني: قُرى قوم لوط، وذلك أنّ جبريل ﵇ أدخل جناحه تحتَها، فرفعها إلى السماء، حتى سمعت ملائكةُ سماء الدنيا أصوات الدِّيكة، ونباح الكلاب، ثم قلَبها، فهوتْ مِن السماء إلى الأرض مقلوبة{8}. (ز) ٧٣٦١٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والمُؤْتَفِكَةَ أهْوى﴾</q>، قال: قرية لوط أهواها مِن السماء، ثم أتبعها ذاك الصخر؛ اقتُِلَعت من الأرض، ثم هوى بها في السماء، ثم قُلِبَت{9}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٩٢.تفسير مجاهد ص٦٢٩، وأخرجه ابن جرير ٢٢/٩٠، وأبو الشيخ في العظمة (٣٧١).عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٥٤-٢٥٥، وابن جرير ٢٢/٩١، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٩٠.أخرجه ابن جرير ١٢/٥٣٦.كذا، ولعلها: المكذبة.تفسير مقاتل بن سليمان ٤/١٦٧.أخرجه ابن جرير ٢٢/٩١.
53,54," <q>﴿فَغَشَّىٰهَا مَا غَشَّىٰ ۝٥٤﴾</q> - تفسير ٧٣٦١٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَغَشّاها ما غَشّى﴾</q>، قال: الحجارة{1}. (١٤/٥٦) ٧٣٦٢٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فَغَشّاها ما غَشّى﴾</q>: غشّاها صخرًا منضودًا{2}. (ز) ٧٣٦٢١- قال مقاتل بن سليمان: <q>﴿فَغَشّاها ما غَشّى﴾</q> يعني: الحجارة التي غشّاها مَن كان خارجًا من القرية، أو كان في زرعه، أو في ضَرْعه{3}. (ز) ٧٣٦٢٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَغَشّاها ما غَشّى﴾</q>، قال: الحجارة التي رماهم بها مِن السماء{4}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٢٥٤-٢٥٥، وابن جرير ٢٢/٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٩١.تفسير مقاتل بن سليمان ٤/١٦٧.أخرجه ابن جرير ٢٢/٩٢.
53,55," <q>﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكَ تَتَمَارَىٰ ۝٥٥﴾</q> - تفسير ٧٣٦٢٣- قال عبد الله بن عباس: <q>﴿تَتَمارى﴾</q> تُكَذِّب{1}. (ز) ٧٣٦٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَبِأَيِّ آلاءِ رَبِّكَ﴾</q>، قال: بأيِّ نِعَم الله تتمارى، يا ابن آدم{2}٦٣٠١. (١٤/٥٦) ٦٣٠١ ذكر ابنُ كثير (١٣/٢٨٣) في معنى: <q>﴿فَبِأَيِّ آلاءِ رَبِّكَ تَتَمارى﴾</q> قول قتادة: «ففي أيِّ نعم الله عليك -أيها الإنسان- تمتري؟!». ونقل عن ابن جُرَيْج قوله: «<q>﴿فَبِأَيِّ آلاءِ رَبِّكَ تَتَمارى﴾</q> يا محمد». ثم رجَّح قول قتادة قائلًا: «والأول أوْلى، وهو اختيار ابن جرير». ولم يذكر مستندًا. ٧٣٦٢٥- قال مقاتل بن سليمان: <q>﴿فَبِأَيِّ آلاءِ رَبِّك﴾</q> يعني: بأي نعمة ربك <q>﴿تَتَمارى﴾</q> يعني: يشكّ فيها ابن آدم{3}٦٣٠٢. (ز) ٦٣٠٢ ذكر ابنُ تيمية (٦/١٤٩) في معنى: <q>﴿فَبِأَيِّ آلاءِ رَبِّكَ تَتَمارى﴾</q> قول من قال: تشكّ وتجادل. وقول ابن عباس، ثم علَّق بقوله: «ضمّن <q>﴿تتمارى﴾</q> معنى: تكذب، ولهذا عدّاه بالتاء؛ فإنه تفاعل من المرآء، يقال: تمارينا في الهلال، ومراءٌ في القرآن كفر، وهو يكون لتكذيب وتشكيك». ",footnotes:1:تفسير البغوي ٧/٤٢٠.أخرجه ابن جرير ٢٢/٩٢، كما أخرجه عبد الرزاق ٢/٢٥٤-٢٥٥، وابن جرير ٢٢/٩٢، بنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٦٨.
53,56," <q>﴿هَـٰذَا نَذِیرࣱ مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰۤ ۝٥٦﴾</q> - تفسير ٧٣٦٢٦- عن عبد الله بن عباس، في قوله: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q>، قال: محمد ﷺ{1}. (١٤/٥٧) ٧٣٦٢٧- عن أبي مالك [الغفاري] -من طريق إسماعيل- <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q>، قال: مِمّا أنذروا به قومهم في صُحف إبراهيم وموسى{2}. (ز) ٧٣٦٢٨- عن أبي جعفر [الباقر] -من طريق جابر- في قوله: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q>، قال: هو محمد ﷺ{3}. (ز) ٧٣٦٢٩- عن محمد بن كعب القُرَظيّ -من طريق أبي معشر- في قوله: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q>، قال: محمد ﷺ أنذرَ ما أنذر الأولون{4}. (١٤/٥٧) ٧٣٦٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q>، قال: إنّما بُعِث محمد بما بُعِث به الرسلُ قبله{3}. (١٤/٥٧) ٧٣٦٣١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q>، قال: أنذر محمدٌ ﷺ كما أنذرَت الرسلُ من قبله{6}. (ز) ٧٣٦٣٢- قال مقاتل بن سليمان: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q> فيها تقديم، يقول: هذا الذي أخبر عن هلاك الأمم الخالية -يعني: قوم نوح، وعاد، وثمود، وقوم لوط- يخوِّف كفار مكة ليحذروا معصيته{7}٦٣٠٣. (ز) ٦٣٠٣ اختُلف في معنى: <q>﴿هَذا نَذِيرٌ مِنَ النُّذُرِ الأُولى﴾</q> على قولين: الأول: أنّ النبي ﷺ نذيرٌ لقومه كما كانت النُّذُر الذين قبله نُذُرًا لقومهم. الثاني: هذا الذي أنذرتكم به -أيُّها القوم- مِن الوقائع التي ذكرتُ لكم أني أوْقَعْتُها بالأمم قبلكم، من النُّذُر التي أنذرتها الأمم قبلكم في صحف إبراهيم وموسى. ورجَّح ابنُ جرير (٢٢/٩٤) -مستندًا إلى السياق- القول الثاني، وهو قول أبي مالك، فقال: «وهذا القول الذي ذُكِر عن أبي مالك أشْبَه بتأويل الآية». ثم علَّل ذلك بقوله: «وذلك أنّ الله -جلَّ ثناؤه- ذكر ذلك في سياق الآيات التي أخبر عنها أنها في صحف إبراهيم وموسى نذيرٌ من النُّذُر الأولى، التي جاءت الأمم قبلكم كما جاءتكم، فقوله: <q>﴿هَذا﴾</q> بأن يكون إشارة إلى ما تقدَّمه من الكلام، أوْلى وأَشْبه منه بغير ذلك». ونقل ابنُ عطية (ينظر: ٨/١٣٢) عن قوم: أن الإشارة إلى القرآن. ثم رجَّح ابنُ عطية (٨/١٣٣) القول الأول، فقال: «والأشبه أن تكون الإشارة إلى محمد ﷺ». ولم يذكر مستندًا. وذكر ابنُ تيمية (٦/١٥٠) أن القول الأول، وكذا قول مَن قال: إن الإشارة إلى القرآن متلازمان. ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٩٤.أخرجه ابن جرير ٢٢/٩٣.أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٨١ (٢١٠٦).أخرجه ابن جرير ٢٢/٩٣.أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٣.تفسير مقاتل بن سليمان ٤/١٦٨.
53,57," <q>﴿أَزِفَتِ ٱلۡـَٔازِفَةُ ۝٥٧﴾</q> - تفسير ٧٣٦٣٣- عن عبد الله بن عباس -من طريق علي- قال: الآزفة مِن أسماء يوم القيامة{1}. (١٤/٥٧) ٧٣٦٣٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أزِفَتِ الآزِفَةُ﴾</q>، قال: اقتربت الساعة{2}. (١٤/٥٧) ٧٣٦٣٥- عن قتادة بن دعامة، في قوله: <q>﴿أزفت الآزفة﴾</q>، قال: الساعة{3}. (١٤/٥٧) ٧٣٦٣٦- قال مقاتل بن سليمان: <q>﴿أزِفَتِ الآزِفَةُ﴾</q> يعني: اقتربت الساعة{4}. (ز) ٧٣٦٣٧- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿أزِفَتِ الآزِفَةُ﴾</q>، قال: اقتربت الساعة{5}. (١٤/٥٨) ٧٣٦٣٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أزِفَتِ الآزِفَةُ﴾</q>، قال: الساعة{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٩٥ بزيادة: عظّمه الله، وحذّره عباده.تفسير مجاهد ص٦٢٩، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٩٥.عزاه السيوطي إلى عبد بن حميد، وابن جرير.تفسير مقاتل بن سليمان ٤/١٦٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٩٥.
53,58," <q>﴿لَیۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ ۝٥٨﴾</q> - تفسير ٧٣٦٣٩- عن الضَّحّاك بن مُزاحِم، في الآية، قال: ليس لها من دون الله من آلهتهم كاشفة{1}. (١٤/٥٨) ٧٣٦٤٠- قال عطاء: <q>﴿لَيْسَ لَها مِن دُونِ اللَّهِ كاشِفَةٌ﴾</q> ليس لها رادٌّ{2}. (ز) ٧٣٦٤١- عن قتادة بن دعامة، في قوله: <q>﴿ليس لها من دون الله كاشفة﴾</q>: أي: رادّة{3}. (١٤/٥٧) ٧٣٦٤٢- قال مقاتل بن سليمان: <q>﴿لَيْسَ لَها مِن دُونِ اللَّهِ كاشِفَةٌ﴾</q>، يقول: لا يكشفها أحد إلا الله، يعني: الساعة لا يكشفها أحد مِن الآلهة إلا الله تعالى الذي يكشفها{4}. (ز) ٧٣٦٤٣- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿لَيْسَ لَها مِن دُونِ اللَّهِ كاشِفَةٌ﴾</q>، قال: لا يكشف عنها إلا هو{1}٦٣٠٤. (١٤/٥٨) ٦٣٠٤ نقل ابنُ عطية (٨/١٣٣) عن ابن جرير والزّجاج أن معنى: <q>﴿كاشفة﴾</q>: «هو من كشف السِّرِّ». ثم وجَّهه بقوله: «أي: ليس من دون الله من يكشف وقتها ويعلمه». ثم ذكر عن منذر بن سعيد -نقلًا عن الزهراوي-: «هو من كشف الضُّرِّ ودَفْعِه». ثم وجَّهه بقوله: «أي: ليس من يكشف هولها وخطبها». ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٧/٤٢٠، وجاء عقبه: يعني: إذا غشيت الخلق أهوالها وشدائدها لم يكشفها ولم يردّها عنهم أحد.عزاه السيوطي إلى ابن جرير.تفسير مقاتل بن سليمان ٤/١٦٨.عزاه السيوطي إلى ابن المنذر.
53,59," <q>﴿أَفَمِنۡ هَـٰذَا ٱلۡحَدِیثِ تَعۡجَبُونَ ۝٥٩ وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ۝٦٠﴾</q> - نزول الآية ٧٣٦٤٤- عن أبي هريرة، قال: لَمّا نَزَلَتْ: <q>﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</q> بكى أصحابُ الصُّفَّة{1} حتى جَرتْ دموعُهم على خدودهم، فلمّا سمِع رسولُ الله ﷺ حنينَهم بكى معهم، فبكينا ببكائه، فقال رسول الله ﷺ: «لا يلِجُ النارَ مَن بكى مِن خشية الله، ولا يدخل الجنة مُصِرٌّ على معصية، ولو لم تُذنبوا لَجاء الله بقومٍ يُذنبون فيغفر لهم»{2}. (١٤/٥٩) ٧٣٦٤٥- عن عبد الله بن عباس، قال: لَمّا نَزَلَتْ هذه الآيةُ على النبيِّ ﷺ: <q>﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</q>، فما رُؤي النبيُّ ﷺ بعدها ضاحِكًا حتى ذهب مِن الدنيا{3}. (١٤/٥٨) ٧٣٦٤٦- عن صالح أبي الخليل، قال: لَمّا نَزَلَتْ هذه الآية: <q>﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</q>، فما ضحك النبيُّ ﷺ بعد ذلك إلا أن يبتسم. ولفظ عَبد بن حُمَيد: فما رُؤي النبي ﷺ ضاحكًا ولا متبسّمًا حتى ذهب من الدنيا{4}. (١٤/٥٨) <q>﴿أَفَمِنۡ هَـٰذَا ٱلۡحَدِیثِ تَعۡجَبُونَ ۝٥٩ وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ۝٦٠﴾</q> - تفسير الآية ٧٣٦٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أفَمِن هَذا الحَدِيثِ﴾</q>، قال: القرآن{5}. (١٤/٥٨) ٧٣٦٤٨- قال مقاتل بن سليمان: <q>﴿أفَمِن هَذا الحَدِيثِ﴾</q> يعني: القرآن <q>﴿تَعْجَبُونَ﴾</q> تكذيبًا به، <q>﴿وتَضْحَكُونَ﴾</q> استهزاء، <q>﴿ولا تَبْكُونَ﴾</q> يعني: كفار مكة؛ مِمّا فيه من الوعيد{6}. (ز) <q>﴿أَفَمِنۡ هَـٰذَا ٱلۡحَدِیثِ تَعۡجَبُونَ ۝٥٩ وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ۝٦٠﴾</q> - آثار متعلقة بالآية ٧٣٦٤٩- عن الحسن البصري -من طريق مبارك بن فَضالة- أنّه قرأ هذه الآية: <q>﴿أفمن هذا الحديث تعجبون وتضحكون ولا تبكون﴾</q>. قال: واللهِ، إن كان أكيس القوم في هذا الأمر لَمَن بكى، فأبكوا هذه القلوب، وابكوا هذه الأعمال، فإنّ الرجل لَتبكي عيناه وإنّه لَقاسي القلب{7}. (ز) ٧٣٦٥٠- عن الفُضَيل بن عِياض -من طريق إبراهيم بن نصر-: مَن أُوتِي عِلمًا لا يزداد فيه خوفًا وحزنًا وبكاء خليقٌ بأن لا يكون أُوتي علمًا ينفعه. ثم قرأ: <q>﴿أفَمِن هَذا الحَدِيثِ تَعْجَبُونَ وتَضْحَكُونَ ولا تَبْكُونَ﴾</q>{8}. (ز) ",footnotes:1:أصحاب الصفة: هم فقراء المهاجرين، ومن لم يكن له منهم منزل يسكنه، فكانوا يأوون إلى موضع مظلل في مسجد المدينة يسكنونه. النهاية (صفف).أخرجه ابن شاهين في الترغيب في فضائل الأعمال ص٧٧ (٢٢٨)، والبيهقي في الشعب ٢/٢٣٣ (٧٧٧)، والثعلبي ٩/١٥٨، من طريق محمد بن يونس الكديمي، عن عبد الله بن الربيع الباهلي، عن محمد بن عمرو، عن أبي سلمة، عن أبي هريرة به. وقال الألباني في الضعيفة ١٤/٤٣١ (٦٦٩٥): «موضوع».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٣٨٥-.أخرجه ابن أبي شيبة ١٣/٢٣٤، وأحمد -كما في تخريج أحاديث الكشاف ٣/٣٨٦-، وهناد (٤٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٦٢٩، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-.تفسير مقاتل بن سليمان ٤/١٦٨.أخرجه ابن المبارك في كتاب الزهد ١/٧٩، ووكيع في كتاب الزهد ١/٢٤٨ مختصرًا.أخرجه البيهقي في شعب الإيمان ٤/٤٢٧-٤٢٨ (١٦٧٢).
  53,60,""
53,61," <q>﴿وَأَنتُمۡ سَـٰمِدُونَ ۝٦١﴾</q> - تفسير ٧٣٦٥١- عن أبي خالد الوالبي، قال: خرج عليُّ بنُ أبي طالب علينا وقد أُقيمت الصلاة، ونحن قيام ننتظره ليتقدم، فقال: ما لكم سامدون؛ لا أنتم في صلاة، ولا أنتم جلوس تنتظرون؟!{1}٦٣٠٥. (١٤/٦١) ٦٣٠٥ وجَّه ابنُ عطية (٨/١٣٥) قول علي بن أبي طالب بقوله: «يشبه أنه رآهم في أحاديث ونحوها مما يُظن أنه غفلة مّا». ٧٣٦٥٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿سامِدُونَ﴾</q>، قال: لاهُون؛ مُعرِضون عنه{2}. (١٤/٥٩) ٧٣٦٥٣- عن عبد الله بن عباس -من طريق ابن أبي نجيح، عن عكرمة- قال: السامدون: المغنُّون، بالحِميرية{3}. (ز) ٧٣٦٥٤- عن عبد الله بن عباس -من طريق إسماعيل بن شروس، عن عكرمة- في قوله <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، قال: الغناء باليمانية، كانوا إذا سمعوا القرآن تغنّوا ولعبوا{4}. (١٤/٥٩) ٧٣٦٥٥- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿سامِدُونَ﴾</q>، قال: كانوا يمرُّون على رسول الله ﷺ شامخين، ألم تر إلى البعير كيف يَخطِرُ{5} شامخًا!{6}. (١٤/٦٠) ٧٣٦٥٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿سامِدُونَ﴾</q>. قال: السّمود: اللهو، والباطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول هُزَيْلة بنت بكر وهي تبكي قوم عاد: ليت عادًا قبلوا الحق ولم يُبدوا جحودًا قيل قُم فانظر إليهم ثم دع عنك السّمودا؟{7}٦٣٠٦. (١٤/٦٠) ٦٣٠٦ ذكر ابنُ عطية (٨/١٣٤) أنّ «السامد: اللاعب اللاهي. وبهذا فسّر ابن عباس وغيره من المفسّرين، ... وسَمَدَ بلغة حِمْيَر: غَنّى». وعلَّق عليهما بقوله: «وهذا كلّه معنًى قريبٌ بعضُه مِن بعض». ٧٣٦٥٧- عن إبراهيم النَّخْعي -من طريق منصور- قال: كانوا يكرهون أن يقوم القومُ ينتظرون الإمام، وكان يُقال: ذلك من السّمود. أو هو: السّمود. قال منصور: حين يقوم المؤذن فيقومون ينتظرون{8}. (١٤/٦١) ٧٣٦٥٨- عن إبراهيم النَّخْعي -من طريق أبي معشر-: أنّه كان يكره أن يقوم إذا أُقِيمت الصلاة حتى يجيء الإمام، ويقرأ هذه الآية: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>{9}. (١٤/٦١) ٧٣٦٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، قال: البَرْطَمة{10}{11}. (ز) ٧٣٦٦٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سامِدُونَ﴾</q>، قال: غِضابٌ مُبرطِمون{12}. (١٤/٦١) ٧٣٦٦١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>: السّمود: اللهو واللعب{3}. (ز) ٧٣٦٦٢- قال الضَّحّاك بن مُزاحِم: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q> أشِرون بطِرون{14}. (ز) ٧٣٦٦٣- عن عكرمة مولى ابن عباس -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، قال: هو الغناء، بالحِميرية{15}. (١٤/٦٠) ٧٣٦٦٤- عن عكرمة مولى ابن عباس -من طريق سعيد بن مسروق-: هو اللعب واللهو{16}. (ز) ٧٣٦٦٥- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، قال: غافلون{17}. (ز) ٧٣٦٦٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، قال: غافلون{18}. (١٤/٥٩) ٧٣٦٦٧- عن مَيسرة بن عمّار الأشجعي، قال: هو الغناء، بلسان كذا وكذا، يقول: اسمُد لنا؛ أي: غنِّ لنا{19}. (ز) ٧٣٦٦٨- قال محمد بن السّائِب الكلبي: <q>﴿سامِدُونَ﴾</q> السامد: الحزين، بلسان طيئ، وبلسان أهل اليمن: الملاهي{20}. (ز) ٧٣٦٦٩- قال مقاتل بن سليمان: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، يعني: لاهُون عن القرآن، بلغة اليمن{21}. (ز) ٧٣٦٧٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَنْتُمْ سامِدُونَ﴾</q>، قال: السامد: الغافل{22}. (ز) ",footnotes:1:أخرجه عبد الرزاق في المصنف (١٩٣٣)، وابن جرير ٢٢/١٠٠، وورد عنده عن أبي خالد الراسبي. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٧، ٩٨، ١٠١، وبنحوه من طريق عطية، وابن أبي حاتم -كما في الإتقان ٢/٤٥-، والطبراني (١١٧٢). وأخرجه ابن مردويه -كما في الفتح ٨/٦٠٥- من طريق سعيد بن جبير بلفظ: معرضون.أخرجه ابن جرير ٢٢/٩٩.أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٧ من طريق قتادة عن عكرمة. وأخرجه مختصرًا أبو عبيد في فضائله (٢٠٥) من طريق سفيان عن أبيه عن عكرمة، وعبد بن حميد -كما في تغليق التعليق ٤/٣٢٣-، وابن أبى الدنيا في ذم الملاهي (٣٣)، والبزار (٢٢٦٤-كشف) وابن جرير ٢٢/٩٧، وأخرجه البيهقي ١٠/٢٢٣.يقال: خَطَرَ البعير بذنبه يَخْطِر: إذا رفعه وحطّه، وإنما يفعل ذلك عند الشَّبَع والسَّمَن. النهاية (خطر).أخرجه أبو يعلى (٢٦٨٥)، وابن جرير ٢٢/٩٨. قال محقق مسند أبى يعلى: «إسناده ضعيف».أخرجه نافع في مسائله (٧)، وأخرجه الطبراني ١٠/٣١٠.أخرجه ابن جرير ٢٢/١٠١-١٠٢، وبنحوه من طريق عمران. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٠١ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.البَرْطَمَة: الانتِفاخ مِن الغضب، ورجل مُبَرْطِم: مُتكبِّر. وقيل: مُقَطّب مُتَغَضِّبٌ. النهاية (برطم).أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٩٨، ٩٩، ١٠١، وبنحوه من طريق ليث.تفسير مجاهد ص٦٢٩ بنحوه. وأخرجه ابن جرير ٢٢/٩٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٩٩.تفسير الثعلبي ٩/١٥٨، وتفسير البغوي ٧/٤٢١.أخرجه ابن عيينة في تفسيره -كما في تغليق التعليق ٤/٣٢٢-، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٩-، وعبد بن حميد -كما في تغليق التعليق ٤/٣٢٣-، والفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٩٩.أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٨٣ (٢١١٠).أخرجه ابن جرير ٢٢/٩٨.أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٩٩، كذلك من طريق سعيد.أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٨٢ (٢١٠٩).تفسير الثعلبي ٩/١٥٨.تفسير مقاتل بن سليمان ٤/١٦٨.أخرجه ابن جرير ٢٢/١٠١.
53,62," <q>﴿فَٱسۡجُدُوا۟ لِلَّهِ وَٱعۡبُدُوا۟﴾</q> - تفسير ٧٣٦٧١- عن قتادة بن دعامة، في قوله: <q>﴿فاسْجُدُوا لِلَّهِ واعْبُدُوا﴾</q>، قال: اعنِتوا هذه الوجوه لله، وعفِّروها في طاعة الله{1}. (١٤/٦٢) ٧٣٦٧٢- قال مقاتل بن سليمان: <q>﴿فاسْجُدُوا لِلَّهِ﴾</q> يعني: صَلُّوا الصلوات الخمس، <q>﴿واعْبُدُوا﴾</q> يعني: وحِّدوا الرّبَّ تعالى{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٦٨. وقد تقدم ما يتعلق بأحكام سجدة هذه السورة في الآثار المتعلقة بها، وذلك في أولها.
54,1," مقدمة السورة ٧٣٦٧٣- عن عبد الله بن عباس -من طرق- قال: نَزَلَتْ سورة القمر بمكة{1}. (١٤/٦٣) ٧٣٦٧٤- عن عبد الله بن الزبير، مثله{2}. (١٤/٦٣) ٧٣٦٧٥- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: نَزَلَتْ بمكة سورة <q>﴿اقْتَرَبَتِ السّاعَةُ﴾</q>، بعد <q>﴿والسماء والطارق﴾</q>{3}. (١٤/٦٣) ٧٣٦٧٦- عن عكرمة مولى ابن عباس= (ز) ٧٣٦٧٧- والحسن البصري -من طريق يزيد النحوي-: مكّية، وسمّياها: <q>﴿اقتربت الساعة﴾</q>{4}. (ز) ٧٣٦٧٨- عن قتادة بن دعامة: مكّيّة{5}. (ز) ٧٣٦٧٩- عن محمد بن شهاب الزُّهريّ: مكّيّة، وسمّاها: <q>﴿اقتربت الساعة﴾</q>، نَزَلَتْ بعد سورة الهُمَزة{6}. (ز) ٧٣٦٨٠- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٧٣٦٨١- قال مقاتل بن سليمان: سورة القمر مكّيّة، عددها خمس وخمسون آية{8}٦٣٠٧. (ز) ٦٣٠٧ ذكر ابنُ عطية (٨/١٣٦) أن هذه السورة مكية بإجماع، إلا آية واحدة اختُلف فيها، وهي قوله: <q>﴿سيهزم الجمع﴾</q> [القمر:٤٥]، فقال جمهور الناس: هي مكية. وقال قوم: هي مما نزل ببدر. وقيل: بالمدينة. ورجّح (٨/١٥٣) عند تفسيره لها أنها مكية، ولم يذكر مستندًا. ٧٣٦٨٢- عن بُرَيْدة بن الحُصَيب: أنّ معاذ بن جبل صلّى بأصحابه صلاة العشاء، فقرأ فيها: <q>﴿اقْتَرَبَتِ السّاعَةُ﴾</q>، فقام رجلٌ مِن قبل أن يفرغ، فصلّى وذهب، فقال له معاذ قولًا شديدًا، فأتى الرجلُ النبيَّ ﷺ، فاعتذر إليه، فقال: إني كنتُ أعمل في نخلٍ، وخِفتُ على الماء. فقال رسول الله ﷺ: «صلِّ بـ«الشمس وضحاها»، ونحوها من السور»{9}. (١٤/٦٤) <q>﴿ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ۝١﴾</q> - قراءات ٧٣٦٨٣- عن حُذيفة بن اليمان أنه قرأ: (اقْتَرَبَتِ السّاعَةُ وقَدِ انشَقَّ القَمَرُ){10}. (١٤/٧٠) <q>﴿ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ۝١﴾</q> - نزول الآيات ٧٣٦٨٤- عن عبد الله بن مسعود -من طريق مسروق- قال: انشقّ القمرُ على عهد رسول الله ﷺ، فقالت قريش: هذا سِحرُ ابنِ أبي كَبْشة. فقالوا: انتظِروا ما يأتيكم به السُّفّار؛ فإنّ محمدًا لا يستطيع أن يَسْحَر الناس كلّهم. فجاء السُّفار، فسألوهم، فقالوا: نعم، قد رأيناه. فأنزل الله: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>{11}. (١٤/٦٦) ٧٣٦٨٥- عن عبد الله بن مسعود -من طريق مجاهد، عن أبي معمر- قال: رأيتُ القمر مُنشقًّا شِقّتين مرّتين بمكة قبل مخرج النبيِّ ﷺ؛ شِقّة على أبي قبيس، وشِقّة على السويداء، فقالوا: سَحَر القمر. فنَزَلَت: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>. قال مجاهد: يقول: كما رأيتم القمر مُنشقًّا، فإنّ الذي أخبركم عن اقتراب الساعة حقّ{12}. (١٤/٦٥) ٧٣٦٨٦- عن جُبير بن مُطعم -من طريق محمد بن جبير- في قوله: <q>﴿وانْشَقَّ القَمَرُ﴾</q>، قال: انشقّ القمر ونحن بمكة على عهد رسول الله ﷺ، حتى صار فِرْقتين؛ فِرْقة على هذا الجبل، وفِرْقة على هذا الجبل، فقال الناس: سَحَرَنا محمد. فقال رجل: إن كان سَحركم فإنه لا يستطيع أن يَسْحَر الناسَ كلّهم{13}٦٣٠٨. (١٤/٦٧) ٦٣٠٨ علَّق ابن كثير (١٣/٢٩٠) على هذا الحديث بقوله: «تفرد به الإمام أحمد من هذا الوجه، وأسنده البيهقي في الدلائل من طريق محمد بن كثير، عن أخيه سليمان بن كثير، عن حُصين بن عبد الرحمن، به. وهكذا رواه ابن جرير من حديث محمد بن فضيل وغيره، عن حصين، به. ورواه البيهقي أيضًا من طريق إبراهيم بن طهمان وهشيم، كلاهما عن حصين، عن جبير بن محمد بن جبير بن مطعم، عن أبيه، عن جدّه فذكره». ٧٣٦٨٧- عن عبد الله بن عباس -من طريق عكرمة- قال: كُسف القمر على عهد رسول الله ﷺ، فقالوا: سَحَر القمر. فنَزَلَت: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q> إلى قوله: <q>﴿مُسْتَمِرٌّ﴾</q>{14}. (١٤/٦٨) ٧٣٦٨٨- عن عبد الله بن عباس، قال: انتهى أهلُ مكة إلى النبيِّ ﷺ، فقالوا: هل مِن آية نعرف بها أنك رسول الله؟ فهبط جبريل، فقال: يا محمد، قُل لأهل مكة: إن تختلفوا هذه الليلة فسَتَرون آية. فأخبرهم رسول الله ﷺ بمقالة جبريل، فخرجوا ليلة أربع عشرة، فانشقّ القمرُ نصفين؛ نِصفًا على الصفا، ونِصفًا على المروة، فنظروا، ثم قالوا بأبصارهم، فمسحوها، ثم أعادوا النظر، فنظروا، ثم مسحوا أعينهم، ثم نظروا، فقالوا: يا محمد، ما هذا إلا سحرٌ ذاهِب. فأنزل الله: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>{15}. (١٤/٦٩) ٧٣٦٨٩- عن عبد الله بن عباس -من طريق عطاء، والضَّحّاك- في قوله: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، قال: اجتمع المشركون على عهد رسول الله ﷺ؛ منهم: الوليد بن المُغيرة، وأبو جهل بن هشام، والعاصي بن وائل، والعاصي بن هشام، والأسود بن عبد يغوث، والأسود بن المطلب، وزمعة بن الأسود، والنَّضر بن الحارث، فقالوا للنبي ﷺ: إن كنتَ صادقًا فشُقَّ لنا القمر فِرْقَتين؛ نِصفًا على أبي قبيس، ونِصفًا على قُعَيْقِعان. فقال لهم النبيُّ ﷺ: «إن فعلتُ تؤمنوا؟». قالوا: نعم. قال: وكانت ليلة بدر. فسأل رسول الله ﷺ ربّه أن يُعطيَه ما سألوا، فأمسى القمرُ قد مُثِّل نِصفًا على أبي قبيس، ونِصفًا على قُعَيْقِعان، ورسول الله ﷺ يُنادي: «يا أبا سلمة بن عبد الأسد، والأرقم بن أبي الأرقم، اشهدوا»{16}. (١٤/٦٨) ٧٣٦٩٠- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: جاءت أحبار اليهود إلى رسول الله ﷺ، فقالوا: أرِنا آيةً حتى نؤمن. فسأل النبيُّ ﷺ ربّه أن يريهم آية، فأراهم القمر قد انشقّ، فصار قمرين؛ أحدهما على الصفا، والآخر على المروة، قدْر ما بين العصر إلى الليل ينظرون إليه، ثم غاب القمر، فقالوا: هذا سحرٌ مستمرٌّ{17}. (١٤/٦٩) ٧٣٦٩١- عن أنس بن مالك -من طريق قتادة-: أنّ أهل مكة سألوا رسول الله ﷺ أن يريهم آية، فأراهم القمرَ شِقَّتين، حتى رَأوا حِراء بينهما{18}. (١٤/٦٥) ٧٣٦٩٢- عن أنس بن مالك -من طريق قتادة- قال: سأل أهلُ مكة النبيَّ ﷺ آيةً، فانشقّ القمر بمكة فِرْقتين؛ فنَزَلَتْ: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q> إلى قوله: <q>﴿سِحْرٌ مُسْتَمِرٌّ﴾</q> يقول: ذاهب{19}. (١٤/٦٤) ٧٣٦٩٣- عن عكرمة مولى ابن عباس -من طريق عمرو- قال: انشقّ القمرُ على عهد رسول الله شِقّتين. فقال المشركون: سحرٌ. فنَزَلَتْ: <q>﴿اقتربت الساعة وانشق القمر وإن يروا آية يعرضوا ويقولوا سحر مستمر﴾</q>{20}. (ز) <q>﴿ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ۝١﴾</q> - تفسير ٧٣٦٩٤- عن عبد الله بن مسعود -من طريق أبي معمر- قال: انشقّ القمر على عهد رسول الله ﷺ فِرْقتين؛ فِرْقة فوق الجبل، وفِرْقة دونه، فقال رسول الله ﷺ: «اشهدوا»{21}. (١٤/٦٥) ٧٣٦٩٥- عن عبد الله بن مسعود -من طريق الأسود- قال: رأيتُ القمر وقد انشقّ، فأبصرتُ الجبل مِن بين فُرْجَتي القمر{22}. (١٤/٦٦) ٧٣٦٩٦- عن عبد الله بن مسعود -من طريق مسروق- قال: خمس قد مَضين: الدُّخان، واللِّزام، والبَطْشة، والقمر، والرُّوم{23}. (ز) ٧٣٦٩٧- عن أبي عبد الرحمن السلمي، قال: خطبنا حُذيفة بن اليمان بالمدائن، فحمد الله، وأثنى عليه، ثم قال: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، ألا وإنّ الساعة قد اقتربَتْ، ألا وإنّ القمر قد انشقّ على عهد رسول الله ﷺ، ألا وإنّ الدنيا قد آذنت بفراقٍ، ألا وإنّ اليوم المِضمار وغدًا السّباق{24}. (١٤/٧٠) ٧٣٦٩٨- عن عبد الله بن عباس -من طريق عبد الله بن عُتبة- قال: انشقّ القمر في زمان النبيِّ ﷺ{25}. (١٤/٦٦) ٧٣٦٩٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، قال: قد مضى ذلك؛ كان قبل الهجرة، انشقّ القمر حتى رأوا شِقَّيه{26}. (١٤/٦٨) ٧٣٧٠٠- عن عبد الله بن عباس، قال: ثلاث ذكرهنّ الله في القرآن قد مَضين: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q> قال: قد انشقّ القمر على عهد رسول الله ﷺ شِقَّتين حتى رآه الناس، و<q>﴿سَيُهْزَمُ الجَمْعُ ويُوَلُّونَ الدُّبُرَ﴾</q> [القمر:٤٥] كان يوم بدر، <q>﴿حَتّى إذا فَتَحْنا عَلَيْهِمْ بابًا ذا عَذابٍ شَدِيدٍ﴾</q> [المؤمنون:٧٧]{27}. (١٤/٧٠) ٧٣٧٠١- عن عبد الله بن عمر -من طريق مجاهد- في قوله: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، قال: كان ذلك على عهد رسول الله ﷺ، انشقّ فِرْقتين؛ فِرْقة من دون الجبل، وفِرْقة خلفه، فقال النبيُّ ﷺ: «اللهم اشهد»{28}٦٣٠٩. (١٤/٦٧) ٦٣٠٩ علَّق ابنُ كثير (١٣/٢٩٢) على هذا الحديث بقوله: «هكذا رواه مسلم، والترمذي، من طرق عن شعبة، عن الأعمش، عن مجاهد، به. قال مسلم كرواية مجاهد عن أبي معمر، عن ابن مسعود. وقال الترمذي: حسن صحيح». ٧٣٧٠٢- عن أبي سعيد الخُدري -من طريق رجل- قال: يسمعون صوتًا من السماء: <q>﴿اقْتَرَبَتِ السّاعَةُ﴾</q>، فمن بين مصدِّق ومكذِّب، وعارف ومنكر، فبينما هم كذلك إذ يسمعون مناديًا ينادي من السماء: يا أيها الناس، اقتربت الساعة. قال: فمن بين مصدِّق ومكذِّب، وعارف ومنكر، فلا يلبثون إلا يسيرًا حتى يسمعون الصيحة، فذاك حين تُلْهى كلّ واحدة عن ولدها{29}. (ز) ٧٣٧٠٣- عن إبراهيم النَّخْعيّ -من طريق مُغيرة- قال: مضى، انشقّ القمر بمكة{30}. (ز) ٧٣٧٠٤- عن مجاهد بن جبر -من طريق منصور- <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، قال: انفلق القمر فِلْقتين، فثبتت فِلْقة، وذهبت فِلْقة من وراء الجبل، فقال النبي ﷺ: «اشهدوا»{31}. (ز) ٧٣٧٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، قال: رَأوه مُنشقًّا{32}. (١٤/٧١) ٧٣٧٠٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>، قال: كما رأيتم القمر مُنشقًا فإنّ الذي أخبركم عن اقتراب الساعة حقّ{33}. (١٤/٦٥) ٧٣٧٠٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ﴾</q>: يُحدث الله في خلْقه ما يشاء{34}. (ز) ٧٣٧٠٨- عن عطاء الخُراسانيّ -من طريق ابنه عثمان- <q>﴿وانْشَقَّ القَمَرُ﴾</q> أنّ معناه: وسينشقّ القمر{35}. (ز) ٧٣٧٠٩- قال مقاتل بن سليمان: <q>﴿اقْتَرَبَتِ السّاعَةُ﴾</q> يعني: القيامة، ومن علامة ذلك: خروج النبي ﷺ، والدُّخان، وانشقاق القمر. وذلك أنّ كفار مكة سألوا النبي ﷺ أن يريهم آية، فانشقّ القمر نِصفين، فقالوا: هذا عمل السّحرة{36}٦٣١٠. (ز) ٦٣١٠ نقل ابنُ عطية (٨/١٣٧) عن الثعلبي أنه قيل: إنّ المعنى: ينشق القمر يوم القيامة. وانتقده مستندًا للسنة، والإجماع، فقال: «وهذا ضعيف، والأمّة على خلافه». وساق الآثار في ثبوت ذلك ووقوعه. وذكر ابنُ كثير (١٣/٢٨٩) أن وقوع انشقاق القمر في زمان النبي ﷺ أمر متفق عليه بين العلماء، وأنه كان إحدى المعجزات الباهرات. ",footnotes:1:أخرجه النحاس ص٦٨٠ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في الدلائل ٧/١٤٤ من طريق خُصَيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/١٧٥.أخرجه أحمد ٣٨/١١٥-١١٦ (٢٣٠٠٨)، من طريق حسين بن واقد، عن عبد الله بن بريدة، عن بريدة به. قال مغلطاي في شرح ابن ماجه ٥/١٤٠٩: «سند صحيح». وقال الهيثمي في المجمع ٢/١١٨-١١٩ (٢٧٠٨): «رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٢/٨٦ (١٠٨٨): «هذا إسناد صحيح، بل قيل فيه: إنه مِن أصح الإسناد». وقال ابن حجر في الفتح ٢/١٩٣: «ووقع عند أحمد من حديث بريدة بإسناد قوي، فقرأ: <q>﴿اقتربت الساعة﴾</q>، وهي شاذة، إلا إن حُمل على التعدد». وقال العيني في عمدة القاري ٥/٢٣٦: «إسناد قوي». وقال الألباني في الإرواء ١/٣٣١: «سند صحيح، غير أن قوله: فقرأ فيها: <q>﴿اقتربت الساعة﴾</q> شاذ، والمحفوظ أنه قرأ البقرة في سائر الروايات المتقدمة».عزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة. انظر: المحتسب ٢/٢٩٧، ومختصر ابن خالويه ص١٤٨.أخرجه البيهقي في دلائل النبوة ٢/٢٦٦-٢٦٧، والواحدي في أسباب النزول ص٤٠٠، وابن جرير ٢٢/١٠٦-١٠٧، والثعلبي ٩/١٦٢، من طريق أبي عوانة، عن المُغيرة، عن أبي الضحى، عن مسروق، عن عبد الله به. وسنده صحيح.أخرجه الحاكم ٢/٥١٢ (٣٧٥٧)، وعبد الرزاق ٣/٢٥٩ (٣٠٥٩). قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه بهذه السياقة». ووافقه الذهبي في التلخيص.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٣٣-، وأحمد ٢٧/٣١٤ (١٦٧٥٠)، والترمذي (٣٢٨٩)، وابن جرير ٢٢/١٠٩، والحاكم ٢/٤٧٢، والبيهقي ٢/٢٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه، وأبي نعيم. صححه الحاكم. وقال الألباني في صحيح سنن الترمذي (٢٦٢٢): «صحيح الإسناد».أخرجه الطبراني في الكبير ١١/٢٥٠ (١١٦٤٢-١١٦٤٣)، من طريق أحمد بن عمرو البزار، عن محمد بن يحيى القطعي، عن محمد بن بكر، عن ابن جُرَيْج، عن عمرو بن دينار، عن عكرمة، عن ابن عباس به. قال ابن كثير في البداية والنهاية عن إسناد الطبراني ٤/٢٩٩: «إسناد جيد».أخرجه أبو نعيم -كما في البداية والنهاية لابن كثير ٤/٢٩٧-، من طريق إسماعيل بن زياد، عن ابن جُرَيْج، عن عطاء، عن ابن عباس به. وسنده ضعيف جدًّا، فيه إسماعيل بن زياد، قال عنه ابن حجر في تقريب التهذيب (٤٤٦): «متروك، كذّبوه».أخرجه أبو نعيم في دلائل النبوة ص٢٧٩-٢٨٠ (٢٠٩)، من طريق بكر بن سهل، عن عبد الغني بن سعيد، عن موسى بن عبد الرحمن، عن ابن جُرَيْج، عن عطاء، عن ابن عباس. وعن مقاتل، عن الضَّحّاك، عن ابن عباس به. قال ابن حجر في الفتح ٧/١٨٢: «ضعيف».أخرجه أبو نعيم في الدلائل (٢١٠).أخرجه عبد الرزاق ٢/٢٥٧، والبخاري (٣٦٣٧، ٣٨٦٨، ٤٨٦٧، ٤٨٦٨)، ومسلم (٢٨٠٢/٤٦)، وابن جرير ٢٢/١٠٣-١٠٤، ١٠٥.أخرجه البخاري ٤/٢٠٦-٢٠٧ (٣٦٣٧)، ٥/٤٩ (٣٨٦٨)، ٦/١٤٢-١٤٣ (٤٨٦٧، ٤٨٦٨)، ومسلم ٤/٢١٥٩ (٢٨٠٢) دون ذكر الآية، وعبد الرزاق ٣/٢٥٧ (٣٠٥٧)، وابن جرير ٢٢/١١١، والثعلبي ٩/١٦١ دون ذكر الآية أيضًا.أخرجه نعيم بن حماد في كتاب الفتن ٢/٦٠٣. وذكره في الإيماء ٧/٤٧٢ (٧١٦٤)، وعزاه إلى جزء سعدان (٥٥) وقال: «وصله الطبراني (١١٦٤٢) عن عكرمة، عن ابن عباس».أخرجه البخاري ٤/٢٠٦ (٣٦٣٦)، ٥/٤٩ (٣٨٦٩، ٣٨٧١)، ٦/١٤٢ (٤٨٦٤، ٤٨٦٥) واللفظ له، ومسلم ٤/٢١٥٨ (٢٨٠٠)، وابن جرير ٢٢/١٠٥، والثعلبي ٩/١٦٠-١٦١.أخرجه عبد الرزاق ٢/٢٥٧، وبنحوه من طريق الكلبي، وأحمد ٧/٣٩ (٣٩٢٤)، وابن جرير ٢٢/١٠٦، والحاكم ٢/٤٧١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٥-. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه، وأبي نعيم في الدلائل. صححه الحاكم. وقال محققو المسند: «حديث صحيح».أخرجه ابن جرير ٢٢/١٠٧. وعلقه يحيى بن سلام ١/٤٩٤ مطولًا.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٧٥-٧٦ (١٧٠) من طريق مسلم بن أبي عمران، وابن أبي شيبة ٢/١١٥، ١٣/٣٧٨، وابن جرير ٢٢/١٠٧، ١٠٨، ١١٢، ومن طريق أبي سنان أيضًا، وابن مردويه -كما في تخريج الكشاف ٣/٣٩١-، وأبو نعيم في الحلية ١/٢٨٠-٢٨١. وعزاه السيوطي إلى عبد بن حميد، وعبد الله بن أحمد في زوائد الزهد.أخرجه البخاري (٣٦٣٨، ٣٨٧٠، ٤٨٦٦)، ومسلم (٢٨٠٣)، وابن جرير ٢٢/١١٠ بنحوه من طريق عطية، والبيهقي في الدلائل ٢/٢٦٧. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/١١٠. وعزاه السيوطي إلى ابن مردويه، وأبي نعيم في الدلائل.عزاه السيوطي إلى ابن مردويه. وأخرج نحوه يحيى بن سلام ١/٤٩٤ من طريقي علي بن أبي طلحة والأعمش، ولفظه: ثلاث آيات قد مضين؛ اثنتان منهم يوم بدر، يوم ذو عذاب شديد، <q>﴿سيهزم الجمع﴾</q>، <q>﴿وانشق القمر﴾</q>.أخرجه مسلم ٤/٢١٥٩ (٢٨٠١)، والحاكم ٢/٥١٣ (٣٧٥٩) واللفظ له، وابن جرير ٢٢/١٠٥-١٠٦.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٥٠ (٤١)-.أخرجه ابن جرير ٢٢/١١٣.أخرجه ابن جرير ٢٢/١١٠-١١١، ومن طريق ليث أيضًا وفيه: فقال النبي ﷺ لأبي بكر: «اشهد، يا أبا بكر».أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٣/٢٥٩، وأخرج نحوه ابن مردويه -كما في الفتح ٧/١٨٤- من طريق ابن جريج.أخرجه ابن جرير ٢٢/١١١.أخرجه الثعلبي ٩/١٦٠.تفسير مقاتل بن سليمان ٤/١٧٧.
54,2," <q>﴿وَإِن یَرَوۡا۟ ءَایَةࣰ یُعۡرِضُوا۟ وَیَقُولُوا۟ سِحۡرࣱ مُّسۡتَمِرࣱّ ۝٢﴾</q> - تفسير ٧٣٧١٠- قال أبو العالية الرِّياحيّ= (ز) ٧٣٧١١- والضَّحّاك بن مُزاحِم: <q>﴿سِحْرٌ مُسْتَمِرٌّ﴾</q>، أي: مُحكمٌ شديد قوي، وهو مِن المرّة، وهي القوّة{1}٦٣١١. (ز) ٦٣١١ علَّق ابن عطية (٨/١٣٨) على قول الضَّحّاك وأبي العالية، بقوله: "وقال أبو العالية والضَّحّاك: معناه: مشدود، من مراير الحبل، كأنه سحر قد استمرّ، أي: أُحْكم، ومنه قول الشاعر: حتى استمرّت على شزر مريرته صدق العزيمة لا رتًّا ولا ضرعا". ٧٣٧١٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سِحْرٌ مُسْتَمِرٌّ﴾</q>، قال: ذاهب{2}. (١٤/٧١) ٧٣٧١٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q> كما يقول أهل الشرك إذا كُسف القمر؛ يقولون: هذا عمل السّحرة{3}. (ز) ٧٣٧١٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: كان القمر قد انشقّ ورسول الله ﷺ بمكة قبل أن يُهاجِر، فقالوا: هذا سحرُ أسْحَرِ السَّحرة، فافعلوا كما فعل المشركون؛ إذا كُسِف القمر ضربوا بِطِساسِهم{4}، واصفرّ أحبارهم، وقالوا: هذا فِعلُ السّحر. فذلك قوله: <q>﴿وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q>{5}. (١٤/٧٠) ٧٣٧١٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q>، قال: إذا رأى أهلُ الضّلالة آيةً مِن آيات الله قالوا: إنّما هذا عمل السّحر، يوشك هذا أن يستمرّ ويذهب{6}. (ز) ٧٣٧١٦- عن الربيع [بن أنس]: <q>﴿ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q>، أي: نافذ{7}. (ز) ٧٣٧١٧- قال مقاتل بن سليمان: <q>﴿وإنْ يَرَوْا آيَةً﴾</q> يعني: انشقاق القمر <q>﴿يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q> يعني: سحرٌ ذاهب، فاستمر، ثم التأم القمر بعد ذلك{8}. (ز) ٧٣٧١٨- عن سفيان [الثوري] -من طريق مهران- في قوله: <q>﴿يُعْرِضُوا﴾</q> قال: حين انشقّ القمر بفِلْقتين؛ فِلْقة من وراء الجبل، وبَقِيتْ فِلْقة أخرى، فقال المشركون حين رأوا ذلك: <q>﴿سِحْرٌ مُسْتَمِرٌّ﴾</q>{3}. (ز) <q>﴿وَإِن یَرَوۡا۟ ءَایَةࣰ یُعۡرِضُوا۟ وَیَقُولُوا۟ سِحۡرࣱ مُّسۡتَمِرࣱّ ۝٢﴾</q> - آثار متعلقة بالآية ٧٣٧١٩- عن عبد الله بن عباس -من طريق عكرمة- قال: كُسِفت الشمس على عهد رسول الله ﷺ، فقالوا: سَحَر الشمسَ. فتلا رسولُ الله ﷺ: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q>{10}. (ز) ",footnotes:1:تفسير الثعلبي ٩/١٦٢ واللفظ له، وجاء عقبه: وهو من المرّة وهي القوة، وتفسير البغوي ٧/٤٢٦.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١١٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١١٣.بِطِساسِهم: جمع الطَّسَّة، وهو الطَّسْت من الآنية ويكون من النحاس أو غيره. التاج والمعجم الوسيط (طسس).عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١١٣، ومن طريق معمر أيضًا بلفظ: ذاهب.تفسير الثعلبي ٩/١٦٢.تفسير مقاتل بن سليمان ٤/١٧٧.أخرجه ابن جرير ٢٢/١١٣.أخرجه الطبراني في الأوسط ٨/١٧٥ (٨٣١٥)، عن موسى بن زكريا، عن محمد بن يحيى القطيعي، عن محمد بن بكر البرساني، عن ابن جريج، عن عمرو بن دينار، عن عكرمة. قال الهيثمي في مجمع الزوائد ٢/ ٢٠٩: «رواه الطبراني في الأوسط، وفيه موسى بن زكريا شيخ الطبراني؛ فإن كان هو التستري فقد تكلم فيه الدارقطني، وإن كان غيره فلا أعرفه، وبقية رجاله رجال الصحيح».
54,3," <q>﴿وَكَذَّبُوا۟ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُمۡۚ وَكُلُّ أَمۡرࣲ مُّسۡتَقِرࣱّ ۝٣﴾</q> - تفسير ٧٣٧٢٠- عن مجاهد بن جبر، <q>﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</q>، قال: يوم القيامة{1}. (١٤/٧١) ٧٣٧٢١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</q>، قال: مستقرٌّ بأهل الخيرِ الخيرُ، وبأهل الشرِّ الشرُّ{2}. (١٤/٧١) ٧٣٧٢٢- قال محمد بن السّائِب الكلبي: <q>﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</q> لكلّ أمر حقيقة، ما كان منه في الدنيا فسيظهر، وما كان منه في الآخرة فسيُعرف{3}. (ز) ٧٣٧٢٣- قال مقاتل بن سليمان: يقول الله تعال: <q>﴿وكَذَّبُوا﴾</q> بالآية، يعني: بالقمر أنه ليس من الله تعالى، <q>﴿واتَّبَعُوا أهْواءَهُمْ وكُلُّ أمْرٍ﴾</q> هذا وعيد <q>﴿مُسْتَقِرٌّ﴾</q> يعني: لكل حديث منتهًى وحقيقة، يعني: العذاب في الدنيا؛ القتْل ببدر، ومنه في الآخرة: عذاب النار{4}. (ز) ٧٣٧٢٤- عن عبد الملك ابن جُرَيْج، <q>﴿وكُلُّ أمْرٍ مُسْتَقِرٌّ﴾</q>، قال: بأهله{5}. (١٤/٧١) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦١٦-.أخرجه ابن جرير ٢٢/١١٤-١١٥. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.تفسير البغوي ٧/٤٢٦.تفسير مقاتل بن سليمان ٤/١٧٧.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦١٦-. وعزاه السيوطي إلى ابن المنذر.
54,4," <q>﴿وَلَقَدۡ جَاۤءَهُم مِّنَ ٱلۡأَنۢبَاۤءِ مَا فِیهِ مُزۡدَجَرٌ ۝٤﴾</q> - تفسير ٧٣٧٢٥- عن عمر بن عبد العزيز أنه خطب بالمدينة، فتلا هذه الآية: <q>﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</q>، قال: أحلّ فيه الحلال، وحرَّم فيه الحرام، وأنبأكم فيه ما تأتون، لم يَدعْكم في لَبْسٍ مِن دينكم، كرامة أكرمكم بها، ونعمة أتمّ بها عليكم{1}. (١٤/٧٢) ٧٣٧٢٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</q>، قال: هذا القرآن مُزدَجر. قال: مُنْتَهى. وفى لفظ: مُتَناهِي{2}. (١٤/٧١) ٧٣٧٢٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</q>، أي: هذا القرآن{3}. (ز) ٧٣٧٢٨- قال مقاتل بن سليمان: <q>﴿ولَقَدْ جاءَهُمْ﴾</q> يعني: جاء أهل مكة <q>﴿مِنَ الأَنْباءِ﴾</q> مِن حديث القرآن <q>﴿ما فِيهِ مُزْدَجَرٌ﴾</q> يعني: موعظة لهم، وهو النهي عن المعاصي{4}. (ز) ٧٣٧٢٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿ولَقَدْ جاءَهُمْ مِنَ الأَنْباءِ ما فِيهِ مُزْدَجَرٌ﴾</q>، قال: المُزدجر: المنتهى{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١١٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/١١٥.تفسير مقاتل بن سليمان ٤/١٧٧.أخرجه ابن جرير ٢٢/١١٥.
54,5," <q>﴿حِكۡمَةُۢ بَـٰلِغَةࣱۖ فَمَا تُغۡنِ ٱلنُّذُرُ ۝٥﴾</q> - تفسير ٧٣٧٣٠- قال مقاتل بن سليمان: جاءهم <q>﴿حِكْمَةٌ بالِغَةٌ﴾</q>، يعني: القرآن، نظيرها في يونس [١٠١]: <q>﴿وما تُغْنِي الآياتُ والنُّذُرُ عَنْ قَوْمٍ لا يُؤْمِنُونَ﴾</q> يقول: أرسلتُ إليهم وأنذرتُهم فكفروا بما جاءهم من البيان، <q>﴿فَما تُغْنِ النُّذُرُ﴾</q>{1}٦٣١٢. (ز) ٦٣١٢ ذكر ابنُ عطية (٨/١٣٩) أن «ما» في قوله: <q>﴿فما تغن النذر﴾</q> تحتمل احتمالين: الأول: أن تكون نافية، أي: ليس تغني مع عتوّ هؤلاء الناس. الثاني: أن تكون استفهامًا بمعنى التقرير، أي: فما غناء النذر مع هؤلاء الكفرة؟!. ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٧.
54,6," <q>﴿فَتَوَلَّ عَنۡهُمۡۘ یَوۡمَ یَدۡعُ ٱلدَّاعِ إِلَىٰ شَیۡءࣲ نُّكُرٍ ۝٦﴾</q> - تفسير ٧٣٧٣١- قال مقاتل بن سليمان: <q>﴿فَتَوَلَّ عَنْهُمْ﴾</q> يعني: فأَعرِض عن كفار مكة <q>﴿يَوْمَ يَدْعُ الدّاعِ﴾</q> وهو إسرافيل، ينفخ الثانية قائمًا على صخرة بيت المقدس <q>﴿إلى شَيْءٍ نُكُرٍ﴾</q> يعني: إلى أمر فظيع{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٧-١٧٨.
