quran[19]{c,v,t}:
67,27," <q>﴿فَلَمَّا رَأَوۡهُ﴾</q> - تفسير ٧٧٩٢٦- قال مجاهد بن جبر: <q>﴿فَلَمّا رَأَوْهُ﴾</q> يعني: العذاب ببدر{1}. (ز) ٧٧٩٢٧- عن الحسن البصري -من طريق أبي رجاء- <q>﴿فَلَمّا رَأَوْهُ﴾</q>، قال: لَمّا عايَنوه{2}. (ز) ٧٧٩٢٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَلَمّا رَأَوْهُ﴾</q>، قال: لَمّا رَأوا عذاب الله{3}. (١٤/٦١٥) ٧٧٩٢٩- قال مقاتل بن سليمان: <q>﴿فَلَمّا رَأَوْهُ﴾</q> يعني: العذاب والنار في الآخرة{4}٦٧٠٩. (ز) ٦٧٠٩ رجّح ابنُ تيمية (٦/٣٦٧ بتصرف) في عوْد الضمير في قوله: <q>﴿فلما رأوه﴾</q> ما جاء في قول مقاتل وغيره مِن أنه عائد على ما وُعدوا من العذاب يوم القيامة، وذكر قولًا لم يَنسبه لأحد مِن السلف أنّ الضمير عائد على الله تعالى، وانتقده مستندًا إلى السياق، فقال: «ومَن قال: إنّ الضمير عائد هنا إلى الله. فقوله ضعيف؛ فإنّ الله قال: <q>﴿ويقولون متى هذا الوعد إن كنتم صادقين قل إنما العلم عند الله وإنما أنا نذير مبين فلما رأوه زلفة سيئت وجوه الذين كفروا وقيل هذا الذي كنتم به تدعون﴾</q>، فهذا يُبيّن أنّ الذي رَأوه هو الوعد، أي: الموعود به من العذاب، ألا تراه يقول: <q>﴿وقيل هذا الذي كنتم به تدعون﴾</q>». <q>﴿زُلۡفَةࣰ﴾</q> - تفسير ٧٧٩٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿زُلْفَةً﴾</q>، قال: قد اقترب{5}. (١٤/٦١٥) ٧٧٩٣١- قال مقاتل بن سليمان: <q>﴿زُلْفَةً﴾</q> قريبًا{4}. (ز) ٧٧٩٣٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: <q>﴿زُلْفَةً﴾</q> الزُّلفة: حاضرٌ، قد حضرهم عذاب الله ﷿{2}. (ز) <q>﴿سِیۤـَٔتۡ وُجُوهُ ٱلَّذِینَ كَفَرُوا۟﴾</q> - تفسير ٧٧٩٣٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾</q>، قال: سِيئت بما رأتْ من عذاب الله وهَوانه{8}. (١٤/٦١٥) ٧٧٩٣٤- قال مقاتل بن سليمان: <q>﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾</q>، يعني: سِيئ لذلك وجوههم{4}. (ز) <q>﴿وَقِیلَ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَدَّعُونَ ۝٢٧﴾</q> - قراءات ٧٧٩٣٥- عن الحسن البصري أنه قرأ: ‹وقِيلَ هَذا الَّذِي كُنتُم بِهِ تَدْعُونَ› مُخفّفة{10}. (١٤/٦١٥) ٧٧٩٣٦- عن قتادة بن دعامة -من طريق أبان العطار، وسعيد بن أبي عَروبة- أنه قرأها: ‹الَّذِي كُنتُم بِهِ تَدْعُونَ› خفيفة{11}. (ز) ٧٧٩٣٧- عن أبي بكر بن عيّاش، أنّ عاصمًا قرأ: <q>﴿تَدَّعُونَ﴾</q> مُثقّلة{12}٦٧١٠. (١٤/٦١٥) ٦٧١٠ ذكر ابنُ جرير (٢٣/١٣٧) القراءتين، ووجّههما، فقال: «واختلفت القرّاء في قراءة ذلك، فقرأته عامة قراء الأمصار: <q>﴿هذا الذي كنتم به تدعون﴾</q> بتشديد الدال، بمعنى: تفتعلون من الدعاء. وذكر عن قتادة، والضَّحّاك أنهما قرآ ذلك: ‹تَدْعُونَ› بمعنى: تفعلون في الدنيا». ووجّههما ابنُ عطية (٨/٣٦٢-٣٦٣)، فقال: «وقرأ جمهور الناس ونافع بخلاف عنه: <q>﴿تدعون﴾</q> بفتح الدال وشدّها، على وزن: تفتعلون، أي: تتداعون أمره بينكم، وقال الحسن: يدّعون أنه لا جنة ولا نار. وقرأ أبو رجاء، والحسن، والضَّحّاك، وقتادة، وابن يَسار، وسلام: (يَدْعُونَ) بسكون الدال على معنى: يستعجلون، كقولهم: <q>﴿عَجِّلْ لَنا قِطَّنا﴾</q> [ص:١٦]، و<q>﴿فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ﴾</q> [الأنفال:٣٢]، وغير ذلك». ورجّح ابن جرير -مستندًا لإجماع الحجة من القراء- قراءة التشديد، فقال: «والصواب من القراءة في ذلك ما عليه قراء الأمصار؛ لإجماع الحُجّة من القراء عليه». <q>﴿وَقِیلَ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَدَّعُونَ ۝٢٧﴾</q> - تفسير الآية ٧٧٩٣٨- قال الحسن البصري: <q>﴿الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾</q> تدّعون أن لا جنة ولا نار{13}. (ز) ٧٧٩٣٩- عن قتادة بن دعامة -من طريق أبان العطار، وسعيد بن أبي عَروبة- أنه قرأها: (الَّذِي كُنتُم بِهِ تَدْعُونَ) خفيفة، ويقول: كانوا يَدْعُون بالعذاب. ثم قرأ: <q>﴿وإذ قالوا اللهم إن كان هذا هو الحق من عندك فأمطر علينا حجارة من السماء أو ائتنا بعذاب أليم﴾</q> [الأنفال:٣٢]{11}. (ز) ٧٧٩٤٠- قال مقاتل بن سليمان: <q>﴿وقِيلَ﴾</q> لهم، يعني: قالتْ لهم الخَزنة: <q>﴿هَذا﴾</q> العذاب <q>﴿الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾</q> يعني: تَمتَرون في الدنيا{4}. (ز) ٧٧٩٤١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وقِيلَ هَذا الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾</q>، قال: استعجالهم بالعذاب{11}. (ز) ٧٧٩٤٢- قال أبو بكر بن عياش: تفسير <q>﴿تَدَّعُونَ﴾</q>: تَستعجلون{12}. (١٤/٦١٥) ",footnotes:1:تفسير الثعلبي ٩/٣٦١، وتفسير البغوي ٨/١٨٠.أخرجه ابن جرير ٢٣/١٣٦.أخرجه عبد الرزاق ٢/٣٠٦، وابن جرير ٢٣/١٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٤.تفسير مجاهد ص٦٦٧، وأخرجه ابن جرير ٢٣/١٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٤.أخرجه ابن جرير ٢٣/١٣٦.أخرجه عبد الرزاق ٢/٣٠٦، وابن جرير ٢٣/١٣٥-١٣٦، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٤.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <q>﴿تَدَّعُونَ﴾</q> بفتحها مشددة. انظر: النشر ٢/٣٨٩، والإتحاف ص٥٥١.أخرجه ابن جرير ٢٣/١٣٧.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٣٦١.أخرجه ابن جرير ٢٣/١٣٧.تفسير مقاتل بن سليمان ٤/٣٩٤.أخرجه ابن جرير ٢٣/١٣٧.عزاه السيوطي إلى عبد بن حميد.
67,28," <q>﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَهۡلَكَنِیَ ٱللَّهُ وَمَن مَّعِیَ أَوۡ رَحِمَنَا فَمَن یُجِیرُ ٱلۡكَـٰفِرِینَ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٨﴾</q> - تفسير ٧٧٩٤٣- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> لكفار مكة، يا محمد: <q>﴿أرَأَيْتُمْ إنْ أهْلَكَنِيَ اللَّهُ﴾</q> إنْ عذَّبني الله، <q>﴿ومَن مَعِيَ﴾</q> من المؤمنين <q>﴿أوْ رَحِمَنا﴾</q> فلم يُعذّبنا، وأَنعَم علينا؛ <q>﴿فَمَن يُجِيرُ الكافِرِينَ﴾</q> فمَن يُؤمّنكم أنتم <q>﴿مِن عَذابٍ ألِيمٍ﴾</q> وجيع{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٤.
67,29," <q>﴿قُلۡ هُوَ ٱلرَّحۡمَـٰنُ ءَامَنَّا بِهِۦ وَعَلَیۡهِ تَوَكَّلۡنَاۖ فَسَتَعۡلَمُونَ مَنۡ هُوَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٢٩﴾</q> - تفسير ٧٧٩٤٤- قال مقاتل بن سليمان: <q>﴿قُلْ هُوَ الرَّحْمنُ﴾</q> الذي يفعل ذلك <q>﴿آمَنّا بِهِ﴾</q> يقول: صدَّقنا بتوحيده؛ إن شاء أهلكنا أو عذَّبنا، <q>﴿وعَلَيْهِ تَوَكَّلْنا﴾</q> يعني: بالله وثقنا، <q>﴿فَسَتَعْلَمُونَ﴾</q> عند نزول العذاب <q>﴿مَن هُوَ فِي ضَلالٍ مُبِينٍ﴾</q> يعني: باطل ليس بشيء، أنحن أم أنتم؟{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٤.
67,30," <q>﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا﴾</q> - نزول الآية ٧٧٩٤٥- عن محمد بن السّائِب الكلبي -من طريق سفيان - قال: نزلت هذه الآية: <q>﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ غَوْرًا﴾</q> في بئر زمزم، وبئر ميمون بن الحَضرميّ{1}، وكانت جاهليةً{2}٦٧١١. (١٤/٦١٦) ٦٧١١ ذكر ابنُ عطية (٨/٣٦٣) ما جاء في هذا الأثر، ثم قال معلِّقًا: «ويشبه أن تكون هاتان عُظْم ماءِ مكة، وإلا فكانت فيها آبار كثيرة كخُم والجَفر وغيرهما». <q>﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا﴾</q> - تفسير الآية ٧٧٩٤٦- عن عبد الله بن عباس، في قوله: <q>﴿غَوْرًا﴾</q>، قال: داخِلًا في الأرض{3}. (١٤/٦١٦) ٧٧٩٤٧- عن عبد الله بن عباس، <q>﴿غَوْرًا﴾</q>، قال: يَرجع في الأرض{3}. (١٤/٦١٦) ٧٧٩٤٨- عن سعيد بن جُبَير -من طريق سالم- <q>﴿غَوْرًا﴾</q>: لا تَناله الدِّلاء{5}. (ز) ٧٧٩٤٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿غَوْرًا﴾</q>: ذاهِبًا{5}. (ز) ٧٧٩٥٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿غَوْرًا﴾</q>، قال: ذاهبًا{7}. (١٤/٦١٦) ٧٧٩٥١- قال محمد بن السّائِب الكلبي= (ز) ٧٧٩٥٢- ومقاتل: <q>﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ غَوْرًا﴾</q>، يعني: ماء زمزم، وبئر ميمون الحضرمي، وهي بئر عادية قديمة{8}. (ز) ٧٧٩٥٣- قال مقاتل بن سليمان: <q>﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ﴾</q> يعني: ماء زمزم وغيره <q>﴿غَوْرًا﴾</q> يعني: غارَ في الأرض، فذَهب؛ فلم تَقدِروا عليه{9}. (ز) <q>﴿فَمَن یَأۡتِیكُم بِمَاۤءࣲ مَّعِینِۭ ۝٣٠﴾</q> - تفسير ٧٧٩٥٤- عن عبد الله بن عباس، في قوله: <q>﴿ماءٍ مَعِينٍ﴾</q>، قال: الجاري{3}. (١٤/٦١٦) ٧٧٩٥٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿ماءٍ مَعِينٍ﴾</q>، قال: عَذْب{11}. (١٤/٦١٦) ٧٧٩٥٦- عن عبد الله بن عباس، <q>﴿ماءٍ مَعِينٍ﴾</q>، قال: ظاهِر{12}. (١٤/٦١٦) ٧٧٩٥٧- عن مجاهد بن جبر= (ز) ٧٧٩٥٨- وعكرمة مولى ابن عباس -من طريق جابر-، مثله{13}. (١٤/٦١٦) ٧٧٩٥٩- عن سعيد بن جُبَير -من طريق سالم- <q>﴿ماءٍ مَعِينٍ﴾</q>، قال: الظّاهر{5}. (ز) ٧٧٩٦٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿ماءٍ مَعِينٍ﴾</q>: جارٍ{5}. (ز) ٧٧٩٦١- قال الحسن البصري: <q>﴿ماءٍ مَعِينٍ﴾</q>، المعين: الذي أصله من العيون{16}. (ز) ٧٧٩٦٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ماءٍ مَعِينٍ﴾</q>، قال: الجاري{7}. (١٤/٦١٦) ٧٧٩٦٣- قال مقاتل بن سليمان: <q>﴿فَمَن يَأْتِيكُمْ بِماءٍ مَعِينٍ﴾</q> ظاهر تَناله الدِّلاء{9}. (ز) ",footnotes:1:قال الفاكهي عن بئر ميمون ٤/١٠٤: «وكانت آخر بئر حفرت [في مكة] من هذه البئار في الجاهلية، ولم يكن بمكة يومئذ ماء يشرب إلا زمزم، وبئر ميمون».أخرجه الفاكهي في أخبار مكة ٤/١٠٥. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٣٩.أخرجه ابن جرير ٢٣/١٣٩.أخرجه ابن جرير ٢٣/١٣٩. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٣٦٢، وتفسير البغوي ٨/١٨١.تفسير مقاتل بن سليمان ٤/٣٩٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٣٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد. وأخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٧- عن عكرمة. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٦- عن عكرمة.أخرجه ابن جرير ٢٣/١٣٩.أخرجه ابن جرير ٢٣/١٣٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٦-.أخرجه ابن جرير ٢٣/١٣٩. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٣٩٤.
68,1," مقدمة السورة ٧٧٩٦٤- عن عائشة، قالت: نزلت سورة <q>﴿ن والقلم﴾</q> بمكة{1}. (١٤/٦١٧) ٧٧٩٦٥- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ- قال: كانتْ إذا نزلت فاتحةُ سورةٍ بمكة كُتِبتْ بمكة، ثم يزيد الله فيها ما شاء، وكان أول ما نزل من القرآن: <q>﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</q>، ثم <q>﴿ن والقلم﴾</q>، ثم المُزَّمِّل، ثم المُدَّثِّر{2}. (١٤/٦١٧) ٧٧٩٦٦- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة <q>﴿ن والقلم﴾</q> بمكة{3}. (١٤/٦١٧) ٧٧٩٦٧- عن عكرمة مولى ابن عباس= (ز) ٧٧٩٦٨- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وذكراها بمسمّى: <q>﴿ن والقلم﴾</q>{4}. (ز) ٧٧٩٦٩- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٧٧٩٧٠- عن محمد بن شهاب الزُّهريّ: مكّيّة، وذكرها بمسمّى: سورة <q>﴿ن﴾</q>، وأنها نَزَلَتْ بعد: <q>﴿اقرأ باسم ربك الذي خلق﴾</q>{6}. (ز) ٧٧٩٧١- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٧٧٩٧٢- قال مقاتل بن سليمان: سورة <q>﴿ن﴾</q> مكّيّة، عددها اثنتان وخمسون آية كوفي{8}٦٧١٢. (ز) ٦٧١٢ ذكر ابنُ عطية (٨/٣٦٤) أنّ السورة مكّيّة بلا خلاف بين أهل التأويل. <q>﴿نۤۚ وَٱلۡقَلَمِ﴾</q> - تفسير ٧٧٩٧٣- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «إنّ أول ما خَلَق الله القلم والحوت، قال: اكتب. قال: ما أكتب؟ قال: كلّ شيء كائن إلى يوم القيامة». ثم قرأ: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>. فالنُّون: الحوت، والقلم: القلم{9}. (١٤/٦١٨) ٧٧٩٧٤- عن عبد الله بن عباس، في قوله: <q>﴿ن والقَلَمِ﴾</q>، قال: قال رسول الله ﷺ: «النُّون: السمكة التي عليها قَرار الأرضين، والقلم الذي خَطّ به ربّنا ﷿ القدَر؛ خيره وشَرّه، ضُرّه ونفْعه، <q>﴿وما يَسْطُرُونَ﴾</q> قال: الكِرام الكاتبون»{1}. (١٤/٦٢١) ٧٧٩٧٥- عن قُرّة، قال: قال رسول الله ﷺ: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>، قال: «لَوحٌ من نور، وقلم من نور يجري بما هو كائن إلى يوم القيامة»{11}. (١٤/٦١٩) ٧٧٩٧٦- عن ابن عباس، قال: قال رسول الله ﷺ: «النُّون: اللوح المحفوظ، والقلم من نور ساطع»{12}. (١٤/٦١٩) ٧٧٩٧٧- عن أبي هريرة، قال: سمعتُ رسولَ الله ﷺ يقول: «إنّ أول شيء خَلَق الله القلم، ثم خَلَق النُّون، وهي الدَّواة، ثم قال له: اكتب. قال: وما أكتب؟ قال: ما كان وما هو كائن إلى يوم القيامة؛ من عملٍ، أو أثر، أو رِزق، أو أجَل. فكَتب ما يكون وما هو كائن إلى يوم القيامة، وذلك قوله: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>، ثم خَتَم على فِي القلم، فلم يَنطق ولا يَنطق إلى يوم القيامة، ثم خَلَق الله العقل، فقال: وعزّتي، لأُكمِّلنّك فيمن أحببتُ، ولأُنقِصنّك فيمَن أبغضتُ»{13}. (١٤/٦١٩) ٧٧٩٧٨- عن عبد الله بن عباس -من طريق عكرمة-: <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ن﴾</q> حروف الرحمن مُقطّعة{14}. (ز) ٧٧٩٧٩- عن عبد الله بن عباس، قوله: <q>﴿ن﴾</q>: أشباه هذا قَسمٌ أقسم الله به، وهي من أسماء الله{15}. (١٤/٦٢٠) ٧٧٩٨٠- عن عبد الله بن عباس -من طريق أبي ظَبْيان- قال: إنّ أول شيء خَلَقه الله القلم، فقال له: اكتب. قال: يا ربّ، وما أكتب؟ قال: اكتب القَدَر. فجرى مِن ذلك اليوم بما هو كائن إلى أن تقوم الساعة، ثم طُوِي الكتاب، ورُفِع القلم، وكان عرشُه على الماء، فارتفع بخارُ الماء، ففُتِقتْ منه السماوات، ثم خَلَق النُّون، فبُسطتْ الأرض عليه، والأرض على ظهر النُّون، فاضطرب النُّون، فمادت الأرض، فأُثبتت بالجبال، فإنّ الجبال لَتَفْخَر على الأرض إلى يوم القيامة. ثم قرأ ابن عباس: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>{16}. (١٤/٦١٧) ٧٧٩٨١- عن عبد الله بن عباس -من طريق ثابت الثُّماليّ- قال: إنّ الله خَلَق النُّون، وهي الدَّواة، وخَلَق القلم، فقال: اكتب. قال: ما أكتب؟ قال: اكتب ما هو كائن إلى يوم القيامة{17}. (١٤/٦١٩) ٧٧٩٨٢- عن عبد الله بن عباس -من طريق ثابت الثُّمالي- قال: أول ما خَلَق الله القلم، فأخذه بيمينه، وكِلتا يديه يمين، وخَلَق النُّون، وهي الدَّواة، وخَلَق اللوح، فكَتب فيه، ثم خَلَق السماوات، فكتب ما يكون مِن حينئذ في الدنيا إلى أن تكون الساعة؛ مِن خَلْق مخلوق، أو عَملٍ معمول؛ برٍّ أو فجور، وكلّ رِزق؛ حلال أو حرام، رَطْبٍ أو يابس{18}. (١٤/٦٢٠) ٧٧٩٨٣- عن عبد الله بن عباس -من طريق يحيى بن الجزار- <q>﴿ن والقَلَمِ﴾</q>، قال: <q>﴿ن﴾</q>: الدَّواة، <q>﴿والقلم﴾</q>: القلم{19}. (١٤/٦٢٠) ٧٧٩٨٤- عن عبد الله بن عباس -من طريق مُسلم بن صُبَيْح- في قوله: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>، قال: خَلَق الله القلم، فقال: اجْرِهْ. فجَرى بما هو كائن إلى يوم القيامة، ثم خَلَق الحوت، وهي النُّون، فكَبس عليها الأرض. ثم قال: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>{20}. (١٤/٦٢١) ٧٧٩٨٥- قال كعب الأحبار: <q>﴿ن﴾</q> الحوت الذي يَحمل الأرض، واسمه: لويثا{21}. (ز) ٧٧٩٨٦- عن مجاهد بن جبر -من طريق إبراهيم بن أبي بَكرة- قال: <q>﴿ن﴾</q>: الحوت الذي تحت الأرض السابعة، <q>﴿والقَلَمِ﴾</q>: الذي كُتب به الذِّكر{22}. (١٤/٦٢٠) ٧٧٩٨٧- قال الضَّحّاك بن مُزاحِم: <q>﴿ن﴾</q> الدَّواة{23}. (ز) ٧٧٩٨٨- عن الحسن البصري= (ز) ٧٧٩٨٩- وقتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ن﴾</q>، قالا: الدَّواة{24}. (١٤/٦٢٠) ٧٧٩٩٠- قال الحسن البصري: <q>﴿ن والقَلَمِ﴾</q>، يعني: الدَّواة، والقلم: هذا القلم الذي يُكتب به{25}٦٧١٣. (ز) ٦٧١٣ علَّق ابنُ عطية (٨/٣٦٤) على القول بأنّ <q>﴿ن﴾</q> هي الدَّواة الذي قاله ابن عباس من طريق ثابت الثُّمالي، وقاله الحسن، وقتادة، والضَّحّاك، فقال: «فهذا إما أن يكون لغة لبعض العرب، أو تكون لفظة أعجمية». ٧٧٩٩١- عن عطاء: <q>﴿ن﴾</q> افتتاح اسمه: نور، وناصر، ونصير{26}. (ز) ٧٧٩٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q> يُقسم الله بما شاء{27}. (ز) ٧٧٩٩٣- قال محمد بن كعب القُرَظيّ: أقسم الله تعالى بنُصرته المؤمنين{26}. (ز) ٧٧٩٩٤- قال مُرّة الهَمداني= (ز) ٧٧٩٩٥- وإسماعيل السُّدِّيّ= (ز) ٧٧٩٩٦- وعطاء الخُراسانيّ= (ز) ٧٧٩٩٧- ومقاتل= (ز) ٧٧٩٩٨- ومحمد بن السّائِب الكلبي: هو الحوت الذي على ظهره الأرض. وعن الكلبي، ومقاتل: أنّ اسمه: يهموت{29}. (ز) ٧٧٩٩٩- قال جعفر الصادق: هو نهر في الجنة{30}. (ز) ٧٨٠٠٠- قال مقاتل بن سليمان: <q>﴿ن والقَلَمِ﴾</q> يعني بنون: الحوت، وهو في بحرٍ تحت الأرض السُّفلى، والقلم قلم من نور يُكتب به، طوله كما بين السماء والأرض، كُتب به اللوح المحفوظ{31}. (ز) ٧٨٠٠١- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ن﴾</q>، قال: هو الحوت الذي عليه الأرض{32}. (١٤/٦٢٠) ٧٨٠٠٢- قال الواقديّ: <q>﴿ن﴾</q> هو الحوت الذي عليه الأرض، واسمه: ليوثا{33}٦٧١٤. (ز) ٦٧١٤ ساق ابنُ كثير (١٤/٨٢ بتصرف) هذا القول، ثم علَّق بقوله: «ومن العجيب أنّ بعضهم حمل على هذا المعنى الحديث الذي رواه الإمام أحمد ... عن أنس: أنّ عبد الله بن سلام بلغه مَقدم رسول الله ﷺ المدينة، فأتاه، فسأله عن أشياء، قال: إني سائلك عن أشياء لا يعلمها إلا نبي. قال: ما أول أشراط الساعة؟ وما أول طعام يأكله أهل الجنة؟ وما بال الولد يَنزع إلى أبيه، والولد يَنزع إلى أمه؟ قال: «أخبَرني بهن جبريل آنفًا». قال ابن سلام: فذاك عدو اليهود من الملائكة. قال: «أمّا أول أشراط الساعة فنار تَحشرهم من المشرق إلى المغرب، وأول طعام يأكله أهل الجنة زيادة كبد حوت، وأما الولد فإذا سَبق ماء الرجل ماء المرأة نَزع الولد، وإذا سَبق ماء المرأة ماء الرجل نَزعتْ»». ٧٨٠٠٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿ن والقَلَمِ وما يَسْطُرُونَ﴾</q>، قال: هذا قَسمٌ أقسم الله به{27}٦٧١٥. (ز) ٦٧١٥ اختُلف في المراد بقوله: <q>﴿ن﴾</q> على أقوال: الأول: أنّ النُّون: الحوت الذي عليه الأرض. الثاني: أنّ النُّون: الدَّواة. الثالث: حرف من حروف الرحمن. الرابع: لَوح من نور. الخامس: اسم من أسماء السورة. السادس: قَسمٌ أقسم الله به. السابع: حرف من حروف المعجم. ورجَّح ابنُ القيم (٣/١٧٦) القول الأخير، فقال: «الصحيح أنّ <q>﴿ن﴾</q> و<q>﴿ق﴾</q> و<q>﴿ص﴾</q> من حروف الهجاء التي يَفتتح بها الرّبّ سبحانه بعض السور». ولم يذكر مستندًا. ووجّه ابنُ عطية (٨/٣٦٤-٣٦٥) المراد بالقلم على القول بأنّ <q>﴿ن﴾</q> اسم الحوت بأنه القلم الذي خَلَقه الله تعالى وأمره فكَتب الكائنات، وأنّ الضمير في <q>﴿يسطرون﴾</q> للملائكة، وعلى القول بأنّ <q>﴿ن﴾</q> اسم للدَّواة، فـ<q>﴿القلم﴾</q> هو المتعارف بأيدي الناس، وأنّ الضمير في <q>﴿يسطرون﴾</q> للناس. ثم علَّق على هذا القول بقوله: «فجاء القَسم -على هذا- بمجموع أمر الكتاب الذي هو قوام للعلوم والمعارف، وأمور الدنيا والآخرة، فإنّ القلم أخو اللسان، ومَطية الفِطنة، ونعمة من الله عامة». ورجَّح ابنُ جرير (٢٣/١٤٥) -مستندًا إلى السنة- أنّ القلم المُقسَم به هو ما كُتب به القدَر، فقال: «وأما القلم: فهو القلم المعروف، غير أنّ الذي أقسم به ربنا من الأقلام: القلم الذي خَلَقه الله -تعالى ذِكْره-، فأمره فجَرى بكتابة جميع ما هو كائن إلى يوم القيامة». ثم ساق الأحاديث في ذلك. ورجَّح ابنُ كثير (١٤/٨٣) -مستندًا إلى النظائر- أنّ المراد بالقلم: جنس القلم، فقال: «وقوله: <q>﴿والقلم﴾</q> الظاهر أنه جنس القلم الذي يُكتب به، كقوله: <q>﴿اقرأ وربك الأكرم الذي علم بالقلم علم الإنسان ما لم يعلم﴾</q> [العلق:٣-٥]، فهو قَسمٌ منه تعالى، وتنبيه لخَلْقه على ما أنعم به عليهم من تعليم الكتابة التي بها تُنال العلوم؛ ولهذا قال: <q>﴿وما يسطرون﴾</q>». <q>﴿نۤۚ وَٱلۡقَلَمِ﴾</q> - آثار متعلقة بالآية ٧٨٠٠٤- عن عُبادة بن الصّامت، سمعتُ رسول الله ﷺ يقول: «إنّ أول ما خَلَق الله القلم، فقال له: اكتب. فجَرى بما هو كائن إلى الأبد»{35}. (١٤/٦١٨) ٧٨٠٠٥- عن علي بن أبي طالب: أن اسم الحوت: بلهوت{36}. (ز) ٧٨٠٠٦- عن مجاهد، قال: قلتُ لابن عباس: إنّ ناسًا يُكَذِّبون بالقدَر. فقال: إنهم يُكذِّبون بكتاب الله، لآخذنّ بشعر أحدهم، فلأَنفُضنّ به، إنّ الله كان على عرشه قبل أن يَخلق شيئًا، فكان أول ما خَلَق الله القلم، فجَرى بما هو كائن إلى يوم القيامة، فإنما يجري الناس على أمر قد فُرغ منه{37}. (ز) ٧٨٠٠٧- عن أبي هاشم، أنه سمع مجاهدًا قال: سمعتُ عبد الله -لا يدري ابن عمر أو ابن عباس- قال: إنّ أول ما خَلَق الله القلم، فجَرى القلم بما هو كائن، وإنما يَعمل الناس اليوم فيما قد فُرغ منه{38}. (ز) ٧٨٠٠٨- عن قتادة بن دعامة، قال: القلم نعمة من الله عظيمة؛ لولا القلم ما قام دِين، ولم يَصلح عَيشٌ، والله أعلم بما يُصلِح خَلْقَه{32}. (١٤/٦٢١) <q>﴿وَمَا یَسۡطُرُونَ ۝١﴾</q> - تفسير ٧٨٠٠٩- عن عبد الله بن عباس، في قوله: <q>﴿وما يَسْطُرُونَ﴾</q>، قال: وما يَعملون{40}. (١٤/٦٢١) ٧٨٠١٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وما يَسْطُرُونَ﴾</q>، قال: وما يَكتبون{41}. (١٤/٦٢١) ٧٨٠١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح-= (ز) ٧٨٠١٢- وقتادة بن دعامة -من طريق معمر-، مثله{42}. (١٤/٦٢١) ٧٨٠١٣- عن الحسن البصري -من طريق معمر- <q>﴿وما يَسْطُرُونَ﴾</q>: وما يَكتبون{43}٦٧١٦. (ز) ٦٧١٦ علَّق ابنُ جرير (٢٣/١٤٥) على هذا القول بقوله: «وإذا وُجّه التأويل إلى هذا الوجه كان القَسم بالخَلْق وأفعالهم». ثم أورد احتمالًا آخر وهو أن يكون معناه: وسَطرهم ما يَسطرون. فتكون «ما» بمعنى المصدر. وعلَّق عليه بقوله: «وإذا وُجِّه التأويل إلى هذا الوجه كان القَسَم بالكتاب، كأنه قيل: ن والقلم والكتاب». ٧٨٠١٤- قال مقاتل بن سليمان: <q>﴿وما يَسْطُرُونَ﴾</q>، يقول: وما تَكتب الملائكة مِن أعمال بني آدم{31}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس (١٧).أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٤٩) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٠١.أخرجه الطبراني في الكبير ١١/٤٣٣ (١٢٢٢٧)، من طريق مؤمل بن إسماعيل، عن حماد بن زيد، عن عطاء بن السّائِب، عن مسلم بن صبيح، عن ابن عباس به. قال الطبراني: «لم يرفعه عن حماد بن زيد إلا مؤمل بن إسماعيل». وقال الهيثمي في المجمع ٧/١٢٨ (١١٤٣٤): «ومؤمل ثقة كثير الخطأ، وقد وثّقه ابن معين وغيره، وضعّفه البخاري وغيره، وبقية رجاله ثقات».عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/١٤٤. قال ابن كثير في تفسيره ٨/٢١٢: «وهذا مرسل غريب».أخرجه الرافعي في التدوين في أخبار قزوين ٢/٤١٤، من طريق عبد الغفار بن عبد الحكم القرشي، عن جعفر بن محمد الحنظلي، عن جرير، عن الضَّحّاك بن مُزاحِم، عن عبد الله بن عباس به. إسناده ضعيف جدًّا. وينظر: مقدمة الموسوعة. وفي سنده عبد الغفار بن عبد الحكم القرشي، عن جعفر بن محمد الحنظلي، ولم أقف لهما على ترجمة.أخرجه الفريابي في القدر ص٢٩-٣٠ (١٨)، وابن عساكر في تاريخ دمشق ٦١/٣٨٥، من طريق هشام بن خالد الأزرق الدمشقي، عن الحسن بن يحيى الخشني، عن أبي عبد الله مولى بني أُميّة، عن أبي صالح، عن أبي هريرة به. وأخرجه ابن عدي في الكامل ٧/٥٢٢، وابن عساكر في تاريخ دمشق ٥٦/٢٠٨، من طريق محمد بن وهب الدمشقي، عن الوليد بن مسلم، عن مالك بن أنس، عن سمي، عن أبي صالح، عن أبي هريرة به. قال ابن عدي: «وهذا بهذا الإسناد باطل مُنكر». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١٠٢٤ (٢١٥٥): «رواه محمد بن وهب الدمشقي، عن الوليد بن مسلم، عن مالك بن أنس، عن سمي، عن أبي صالح، عن أبي هريرة. وهذا بهذا الإسناد باطل مُنكر، والحمل فيه على ابن وهب هذا». وذكر ابن كثير في تفسيره ١٤/٨٣ أنّ هذا الحديث غريب جدًّا. وأورده السيوطي في اللآلئ المصنوعة ١/١٢١. وقال الألباني في الضعيفة ٣/٤٠٨ (١٢٥٣): «باطل». وقال في موضع آخر منه ١٣/٦٧٦ (٦٣٠٩): «مُنكر».أخرجه ابن جرير ٢٣/١٤٢.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٧، وابن جرير ٢٣/١٤٠-١٤١، وفي تاريخه ١/٣٣، ٥١، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢١٠-، وأبو الشيخ في العظمة (٩٠٠)، والحاكم ٢/٤٩٨، والبيهقي في الأسماء والصفات (٨٠٤)، والخطيب في تاريخه ٩/٥٩، والضياء في المختارة ١٠/١٨ (٨). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٣/١٤٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٤/١٠١ مختصرًا، وابن جرير ٢٣/١٤٣ مطولًا. وعزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٨-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٨-، وابن جرير ٢٣/١٤٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٨٢.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرج شطره الأول ابن جرير ٢٣/١٤١.تفسير الثعلبي ١٠/٦، وتفسير البغوي ٨/١٨٦.أخرجه عبد الرزاق ٢/٣٠٧، وابن جرير ٢٣/١٤٣. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٨-.تفسير الثعلبي ١٠/٦، وتفسير البغوي ٨/١٨٧.أخرجه ابن جرير ٢٣/١٤٤.تفسير الثعلبي ١٠/٦، وتفسير البغوي ٨/١٨٧.تفسير الثعلبي ١٠/٥، وتفسير البغوي ٨/١٨٦ دون عطاء الخُراسانيّ، ومُرّة الهَمداني.تفسير الثعلبي ١٠/٧.تفسير مقاتل بن سليمان ٤/٤٠٣.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/١٨٢، وتفسير الثعلبي ١٠/٥ بلفظ: لوسا.أخرجه ابن جرير ٢٣/١٤٤.أخرجه أحمد ٣٧/٣٧٨-٣٧٩، ٣٨١ (٢٢٧٠٥، ٢٢٧٠٧)، وأبو داود ٧/٨٦ (٤٧٠٠)، والترمذي ٤/٢٣٠-٢٣١ (٢٢٩٤)، ٥/٥١٤ (٣٦٠٧)، وابن جرير ٢٣/١٤٥، ١٤٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/١٨٧-، من طريق الوليد بن عبادة، عن عبادة به. قال الترمذي في الموضع الأول: «هذا حديث غريب». وقال في الموضع الثاني: «هذا حديث حسن صحيح غريب». وقال البوصيري في إتحاف الخيرة المهرة ١/١٧٣ (٢٠٤): «هذا إسناد صحيح، رجاله ثقات».تفسير الثعلبي ١٠/٥، وفي تفسير البغوي ٨/١٨٢: بلهوث -بالثاء-.أخرجه ابن جرير ٢٣/١٤٦.أخرجه ابن جرير ٢٣/١٤٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/١٤٨، والحاكم ٢/٤٩٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٠٧، وابن جرير ٢٣/١٤٨ عن مجاهد، وقتادة، ومن طريق سعيد بلفظ: وما يَخُطُّون. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٧.تفسير مقاتل بن سليمان ٤/٤٠٣.
68,2," <q>﴿مَاۤ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونࣲ ۝٢﴾</q> - نزول الآية ٧٨٠١٥- قال مقاتل بن سليمان: ... وذلك حين قال كفار مكة؛ أبو جهل بن هشام، وعُتبة بن ربيعة، وشيبة بن ربيعة، وغيرهم: إنّ محمدًا مجنون. فأقسم الله تعالى بالحوت، والقلم، وما يَسطرون -الملائكة- من أعمال بني آدم{1}. (ز) ٧٨٠١٦- عن عبد الملك ابن جُرَيْج، قال: كانوا يقولون للنبي ﷺ: إنه لمجنون، به شيطان. فنَزلت: <q>﴿ما أنْتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ﴾</q>{2}. (١٤/٦٢٢) <q>﴿مَاۤ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونࣲ ۝٢﴾</q> - تفسير الآية ٧٨٠١٧- قال مقاتل بن سليمان: فقال: <q>﴿ما أنْتَ﴾</q> يا محمد <q>﴿بِنِعْمَةِ رَبِّكَ﴾</q> يعني: برحمة ربك <q>﴿بِمَجْنُونٍ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٣.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٣.
68,3," <q>﴿وَإِنَّ لَكَ لَأَجۡرًا غَیۡرَ مَمۡنُونࣲ ۝٣﴾</q> - تفسير ٧٨٠١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ﴾</q>، قال: غير محسوب{1}٦٧١٧. (١٤/٦٢٢) ٦٧١٧ علَّق ابنُ عطية (٨/٣٦٦) على قول مجاهد بقوله: «أي: بغير حساب». وذكر ابنُ كثير (١٤/٨٥) أنّ قوله: <q>﴿غير ممنون﴾</q> هو الأجر الذي لا يَنقطع ولا يَبيد، وساق قول مجاهد، ثم علَّق بقوله: «وهو راجع إلى ما قلناه». ٧٨٠١٩- قال الحسن البصري: <q>﴿غَيْرَ مَمْنُونٍ﴾</q>، أي: لا يَمُنّ عليك به مِن أذًى{2}. (ز) ٧٨٠٢٠- قال مقاتل بن سليمان: <q>﴿وإنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ﴾</q>، يقول: غير منقوص لا يَمُنّ به عليك{3}٦٧١٨. (ز) ٦٧١٨ علَّق ابنُ عطية (٨/٣٦٦) على هذا القول بقوله: «أي: لا يُكَدِّره مَنٌّ به». وذكر أنّ أكثر المفسرين قالوا بأنّ معنى <q>﴿ممنون﴾</q>: الواهن المُنقطع. وعلَّق عليه بقوله: «يقال: حبل منين، أي: ضعيف». ",footnotes:1:أخرجه ابن جرير ٢٣/١٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٩-.تفسير مقاتل بن سليمان ٤/٤٠٣.
68,4," <q>﴿وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِیمࣲ ۝٤﴾</q> - تفسير ٧٨٠٢١- عن عائشة -من طريق عُروة- قالت: ما كان أحد أحسن خُلُقًا مِن رسول الله ﷺ؛ ما دعاه أحد مِن أصحابه ولا مِن أهل بيته إلا قال: لبّيك. فلذلك أنزل الله: <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>{1}. (١٤/٦٢٢) ٧٨٠٢٢- عن سعد بن هشام، قال: أتيتُ عائشة، فقلتُ: يا أُمّ المؤمنين، أخبِريني بخُلُق رسول الله ﷺ. قالت: كان خُلُقه القرآن، أما تقرأ القرآن: <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>؟{2}٦٧١٩. (١٤/٦٢٢) ٦٧١٩ علَّق ابنُ كثير (١٤/٨٥) على هذا الحديث بقوله: «هذا حديث طويل. وقد رواه الإمام مسلم في صحيحه، من حديث قتادة بطوله». ٧٨٠٢٣- عن عبد الله بن عباس، <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، قال: القرآن{3}. (١٤/٦٢٣) ٧٨٠٢٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، قال: دين عظيم، وهو الإسلام{4}٦٧٢٠. (١٤/٦٢٤) ٦٧٢٠ علَّق ابنُ عطية (٨/٣٦٦) على تفسير الخُلُق بالدّين، بقوله: «وذلك لا محالة رأس الخُلُق، ووَكِيدُه». ثم رجَّح -مستندًا إلى السياق- أنّ المراد به في الآية: ما يُضاد الجنون، فقال: «أما إنّ الظاهر من الآية أنّ الخُلُق هو الذي يُضاد مقصد الكفار في قولهم: مجنون. أي: غير محصّل لما يقول». وعلَّق ابنُ تيمية (٦/٣٦٩) على تفسير الخُلُق بالدّين، بقوله: «الدِّين والعادة والخُلُق ألفاظ متقاربة المعنى في الذات، وإن تَنوّعتْ في الصفات كما قيل في لفظة الدّين». ٧٨٠٢٥- عن أنس بن مالك -من طريق ثابت- قال: خدمتُ رسولَ الله ﷺ إحدى عشرة سنة، ما قال لي قطّ: ألا فعلتَ هذا، أو لِمَ فعلتَ هذا؟ قال ثابت: فقلتُ: يا أبا حمزة، إنه كما قال الله تعالى: <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>{5}. (١٤/٦٢٤) ٧٨٠٢٦- عن ابن أبْزى= (ز) ٧٨٠٢٧- وسعيد بن جُبَير، قالا: على دِين عظيم{6}. (١٤/٦٢٤) ٧٨٠٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، قال: الدّين{7}. (١٤/٦٢٤) ٧٨٠٢٩- عن أبي مالك [غَزْوان الغفاري]، <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، قال: الإسلام{6}. (١٤/٦٢٤) ٧٨٠٣٠- قال الحسن البصري: كان خلقه آداب القرآن{9}. (ز) ٧٨٠٣١- عن عطية بن سعد العَوفيّ -من طريق فُضيل بن مرزوق- في قوله: <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، قال: على أدَب القرآن{10}. (١٤/٦٢٣) ٧٨٠٣٢- قال قتادة بن دعامة: هو ما كان يَأتمر به من أمر الله، ويَنتهي عنه من نهى الله سبحانه{11}. (ز) ٧٨٠٣٣- عن زيد بن أسلم، <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، قال: الدِّين{6}. (١٤/٦٢٤) ٧٨٠٣٤- قال مقاتل بن سليمان: <q>﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾</q>، يعني: دين الإسلام{13}. (ز) <q>﴿وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِیمࣲ ۝٤﴾</q> - آثار متعلقة بالآية ٧٨٠٣٥- عن جابر، أنّ النبيَّ ﷺ قال: «إنّ الله بعثني لِتمام مكارم الأخلاق، وتَمام محاسن الأفعال»{14}. (ز) ٧٨٠٣٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «بُعِثتُ لِأُتمّمَ مكارم الأخلاق»{15}. (ز)= (ز) ٧٨٠٣٧- وقال: «أدّبني ربي فأَحسن تَأديبي»{16}. (ز) ٧٨٠٣٨- عن ميمونة، قالت: خرج رسول الله ﷺ ذات ليلة مِن عندي، فأَغلقتُ دونه الباب، فجاء يَستفتح الباب، فأَبيتُ أنْ أفتح له، فقال: «أقسمتُ عليكِ إلا فَتحتِ لي». فقلتُ له: تذهب إلى أزواجك في ليلتي! قال: «ما فعلتُ، ولكن وجدتُ حَقْنًا مِن بَولي»{17}. (١٤/٦٢٥) ٧٨٠٣٩- عن أنس: أنّ امرأة كان في عقلها شيء، فقالت: يا رسول الله، إنّ لي إليكَ حاجة. فقال: «يا أم فلان، انظري أيَّ السِّكَك شئت، حتى أقضي لك حاجتك». فخلا معها في بعض الطرق، حتى فرغت من حاجتها{18}. (ز) ٧٨٠٤٠- عن أنس بن مالك، قال: كنتُ أمشي مع رسول الله ﷺ وعليه بُرد نجراني غليظ الحاشية، فأَدركه أعرابيٌّ، فجَبذه بردائه جَبذة شديدة، حتى نظرتُ إلى صفْحة عاتق رسول الله ﷺ قد أثّرت بها حاشية البُرد مِن شدة جَبْذته، ثم قال: يا محمد، مُرْ لي مِن مال الله الذي عندك. فالتفتَ إليه رسول الله ﷺ، ثم ضحك، ثم أمَر له بعطاء{19}. (ز) ٧٨٠٤١- عن عبد الله بن عمر، قال: إنّ رسول الله ﷺ لم يكن فاحِشًا ولا مُتَفَحِّشًا، وكان يقول: «خياركم أحسنكم أخلاقًا»{20}. (ز) ٧٨٠٤٢- عن أبي الدّرداء، قال: سُئِلَتْ عائشةُ عن خُلُق رسول الله ﷺ. فقالت: كان خُلُقه القرآن؛ يَرضى لرضاه، ويَسخط لسَخطه{21}. (١٤/٦٢٢) ٧٨٠٤٣- عن أبي عبد الله الجَدَليّ، قال: قلتُ لعائشة: كيف كان خُلُق رسول الله ﷺ؟ قالت: لم يكن فاحشًا، ولا مُتفاحِشًا، ولا سَخّابًا{22} في الأسواق، ولا يَجزي بالسيئة السيئة، ولكن يعفو ويصفح{23}. (١٤/٦٢٣) ٧٨٠٤٤- عن عائشة، قالت: ما ضَرب رسول الله ﷺ بيده شيئًا قطّ إلا أن يُجاهد في سبيل الله، ولا ضَرب خادمًا ولا امرأة{24}. (ز) ٧٨٠٤٥- عن أنس بن مالك، أنّ رسول الله ﷺ كان إذا صافح الرجل لم يَنزع يده من يده حتى يكون هو الذي يَنزع يده، ولا يَصرف وجهه عن وجهه حتى يكون هو الذي يَصرف وجهه عن وجهه، ولم يُر مقدِّمًا رُكْبتيه بين يدي جليس له{25}. (ز) ",footnotes:1:أخرجه أبو نعيم في الدلائل (١١٩)، والواحدي (٣٢٨). وعزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٣٠٧، وعبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٦ (٣٢٢) بنحوه، وابن أبي شيبة ١٤/٢١٤ عن رجل من بني سواءة، عن عائشة، ومسلم (٧٤٦) مطولًا، والحاكم ٢/٤٩٩، وابن جرير ٢٣/١٥٠-١٥١، وبنحوه من طريق قتادة. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٥٠، وبنحوه من طريق علي. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى الخرائطي في مكارم الأخلاق.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٠. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٩، وتفسير البغوي ٨/١٨٧.أخرجه ابن المبارك في الزهد (٦٧٨) واللفظ له، والبيهقي في الدلائل ١/٣١٠، وابن جرير ٢٣/١٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٩، وتفسير البغوي ٨/١٨٨.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٠٣.أخرجه الطبراني في الأوسط ٧/٧٤ (٦٨٩٥)، والبغوي في شرح السنة ١٣/٢٠٢ (٣٦٢٢، ٣٦٢٣) واللفظ له، من طريق عمر بن إبراهيم القرشي، عن يوسف بن محمد بن المنكدر، عن أبيه، عن جابر به. قال البيهقي في الشعب ١٠/٣٥٣ (٧٦١٠): «إسناده ضعيف». وقال الهيثمي في المجمع ٨/١٨٨ (١٣٦٨٤): «فيه عمر بن إبراهيم القرشي، وهو ضعيف». وقال السخاوي في المقاصد الحسنة ص١٨٠ (٢٠٤): «سنده فيه عمر بن إبراهيم القرشي، وهو ضعيف عن جابر». وقال الألباني في الضعيفة ٥/١٠٤ (٢٠٨٧): «ضعيف».أخرجه الثعلبي ١٠/١٠، والبزار -كما في كشف الأستار ٣/١٥٧ (٢٤٧٠)-. قال الهيثمي في المجمع ٩/١٥ (١٤١٨٨) عن رواية البزار: «ورجاله رجال الصحيح ...، غير محمد بن رزق الله الكلوذاني، وهو ثقة».أورده الثعلبي ١٠/١٠ عقب الحديث السابق. قال ابن الجوزي: «لا يصحّ، وصحّحه أبو الفضل بن ناصر». وقال ابن تيمية في مجموع الفتاوى ١٨/٣٧٥: «معناه صحيح، لكن لا يُعرف له إسناد ثابت». وقال الفتني في تذكرة الموضوعات ص٨٧: «سنده ضعيف، ولا يُعرف له إسناد ضعيف ثابت». وقال الشوكاني في الفوائد المجموعة ص٣٢٧ (٢٥): «لا يُعرف له إسناد ثابت». وقال الألباني في الضعيفة ١/١٧٣ (٧٢): «ضعيف».أخرجه الحاكم ٤/٣٤ (٦٨٠٠) مع اختلاف يسير، من طريق الحُسين بن الفرج، عن محمد بن عمر، عن إبراهيم بن محمد مولى خزاعة، عن صالح بن محمد، عن أم درة، عن ميمونة به. وسنده شديد الضعف؛ فيه الحُسين بن الفرج الخياط، وهو متروك. الميزان ١/٥٤٥. وفيه محمد بن عمر الواقديّ، قال عنه ابن حجر في التقريب (٦١٧٥): «متروك مع سعة علمه».أخرجه مسلم ٤/١٨١٢ (٢٣٢٦)، والبغوي ٨/١٨٩ واللفظ له.أخرجه البخاري ٤/٩٤-٩٥ (٣١٤٩)، ٧/١٤٦ (٥٨٠٩)، ٨/٢٤ (٦٠٨٨) واللفظ له، ومسلم ٢/٧٣٠ (١٠٥٧).أخرجه أبو الشيخ في أخلاق النبي ١/١٩٨ (٥٤)، والبغوي ٨/١٨٩، من طريق سفيان الثوري، عن الأعمش، عن شقيق، عن مسروق، عن ابن عمر به. وسنده صحيح.أخرجه البيهقي في الدلائل ١/٣٠٩-٣١٠. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.السَّخَب والصَّخَب: الصياح. لسان العرب (سخب)، (صخب).أخرجه ابن أبي شيبة ٨/٣٣٠، والترمذي وصححه (٢٠١٦). وعزاه السيوطي إلى ابن مردويه.أخرجه البغوي ٨/١٩٠.أخرجه البغوي ٨/١٨٩.
68,5," <q>﴿فَسَتُبۡصِرُ وَیُبۡصِرُونَ ۝٥﴾</q> - تفسير ٧٨٠٤٦- عن عبد الله بن عباس، في قوله: <q>﴿فَسَتُبْصِرُ ويُبْصِرُونَ﴾</q>، قال: تَعلم ويَعلمون يوم القيامة{1}. (١٤/٦٢٥) ٧٨٠٤٧- عن مجاهد بن جبر، في قوله: <q>﴿فَسَتُبْصِرُ ويُبْصِرُونَ * بِأَيِّكُمُ المَفْتُونُ﴾</q>، يقول: يَتبيّن لكم المَفتون{1}. (١٤/٦٢٥) ٧٨٠٤٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فَسَتُبْصِرُ ويُبْصِرُونَ﴾</q>، يقول: تَرى ويَرون{3}. (ز) ٧٨٠٤٩- قال مقاتل بن سليمان: <q>﴿فَسَتُبْصِرُ ويُبْصِرُونَ بِأَيِّكُمُ المَفْتُونُ﴾</q>، يعني: سَترى -يا محمد- ويَرى أهل مكة إذا نَزل بهم العذاب ببدر{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٥٢.تفسير مقاتل بن سليمان ٤/٤٠٣.
68,6," <q>﴿بِأَییِّكُمُ ٱلۡمَفۡتُونُ ۝٦﴾</q> - تفسير ٧٨٠٥٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فَسَتُبْصِرُ ويُبْصِرُونَ بِأَيِّكُمُ المَفْتُونُ﴾</q>، يقول: بأيّكم الجنون{1}. (١٤/٦٢٥) ٧٨٠٥١- عن عبد الله بن عباس، في قوله: <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: الشيطان، كانوا يقولون: إنه شيطان، إنه مجنون{2}. (١٤/٦٢٥) ٧٨٠٥٢- عن ابن أبْزى= (ز) ٧٨٠٥٣- وسعيد بن جُبَير: <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قالا: المجنون{3}. (١٤/٦٢٥) ٧٨٠٥٤- عن أبي الجَوْزاء، <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: المجنون{4}. (١٤/٦٢٦) ٧٨٠٥٥- عن مجاهد بن جبر -من طريق خُصَيف- <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: بأيّكم المجنون{5}. (١٤/٦٢٦) ٧٨٠٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: الشيطان{6}. (١٤/٦٢٦) ٧٨٠٥٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>: يعني: الجنون{7}. (ز) ٧٨٠٥٨- عن الحسن البصري، <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: المجنون{4}٦٧٢١. (١٤/٦٢٦) ٦٧٢١ وجّه ابنُ جرير (٢٣/١٥٣) هذا القول الذي قاله سعيد بن جُبَير، وأبي الجَوْزاء، ومجاهد، والحسن، ومقاتل بأنه وُجّه فيه معنى الباء في قوله: <q>﴿بأيكم﴾</q> إلى معنى: في، ثم قال مُعلّقًا: «وإذا وُجّهت الباء إلى معنى»في«كان تأويل الكلام: ويُبْصِرون في أي الفريقين المجنون؛ في فريقك -يا محمد- أو فريقهم، ويكون»المجنون«اسمًا مرفوعًا بالباء». وعلَّق عليه ابنُ عطية (٨/٣٦٧) بقوله: «وهذا قول حسن قليل التَّكلّف، ولا نقول: إنّ حرفًا بمعنى حرف، بل نقول: إن هذا المعنى يُتوصّل إليه بـ»في«وبالباء أيضًا، وقرأ ابن عبلة: (فِي أيِّكُمُ المَفْتُونُ)». ٧٨٠٥٩- عن الحسن البصري، <q>﴿فَسَتُبْصِرُ ويُبْصِرُونَ بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: أيّكم أولى بالشيطان. فكانوا أولى بالشيطان منه{2}. (١٤/٦٢٦) ٧٨٠٦٠- قال الحسن البصري: <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، يعني: أيّكم الضُّلّال{10}. (ز) ٧٨٠٦١- عن يحيى بن سلّام: تفسير الحسن [البصري]: <q>﴿بأيكم المفتون﴾</q> يعني: بأيّكم الضّال، والباء صلة{11}. (ز) ٧٨٠٦٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q>، قال: أيّكم أولى بالشيطان{12}٦٧٢٢. (١٤/٦٢٦) ٦٧٢٢ ذكر ابنُ جرير (٢٣/١٤٥) أنه على هذا القول الذي قاله قتادة، والحسن، فالباء في قوله: <q>﴿بأيكم﴾</q> زائدة. وبنحوه قال ابنُ عطية (٨/٣٦٧). ٧٨٠٦٣- قال مقاتل بن سليمان: <q>﴿بِأَيِّكُمُ المَفْتُونُ﴾</q> يعني: المجنون، فهذا وعيد، العذاب ببدر، القتْل، وضرْب الملائكة الوجوه والأدبار{13}٦٧٢٣. (ز) ٦٧٢٣ اختُلف في المراد بـ<q>﴿المفتون﴾</q> على أقوال: الأول: أنه المجنون. الثاني: الضّال. الثالث: أولى بالشيطان. الرابع: الجنون. ووجَّه ابنُ جرير (٢٣/١٥٣) القول الأخير الذي قاله ابن عباس من طريق العَوفيّ، والضَّحّاك، بأنه وُجّه فيه المفتون إلى معنى الفتنة أو الفتون، كما قيل: ليس له معقول ولا معقود، أي: بمعنى: ليس له عقل ولا عقد رأي. وبنحوه قال ابنُ عطية (٨/٣٦٧). ورجَّحه ابنُ جرير (٢٣/١٥٥) مستندًا إلى اللغة، فقال: «لأنّ ذلك أظهر معاني الكلام، إذا لم ينو إسقاط الباء، وجَعلنا لدخولها وجهًا مفهومًا. وقد بَيّنا أنه غير جائز أن يكون في القرآن شيءٌ لا معنى له». وانتقده ابنُ تيمية (٦/٣٧٧) مستندًا للغة، فقال: «وكون المفتون بمعنى الفتنة لا أصل له في اللغة ألبتة، وجَعْل المصدر على زنة»مفعول«لو صحّ لم يكن قياسًا. بل مقصورًا على السماع». وانتقد ابنُ القيم (٣/١٨٥) هذه الأقوال، ورجَّح أنّ الباء إنما دَخَلتْ لتدلّ على تضمين الفعل «تبصر» معنى «تَشعر وتَعلم»- مستندًا إلى النظائر-، فقال: «وهذه الأقوال كلّها تَكلُّف ظاهر لا حاجة إلى شيء منه، و»سَتُبصِر«مُضمّن معنى»تَشعر وتَعلم«، فعدي بالباء كما تقول: سَتشعر بكذا وتَعلم به، قال تعالى: <q>﴿ألَمْ يَعْلَمْ بِأَنَّ اللَّهَ يَرى﴾</q> [العلق:١٤]. وإذا دعاك اللفظ إلى المعنى من مكان قريب فلا تُجب مَن دعاك إليه من مكان بعيد». ورجَّح ابنُ كثير (١٤/٨٨) القول الثاني الذي قاله الحسن مستندًا إلى اللغة، فقال: «ومعنى <q>﴿المفتون﴾</q> ظاهر، أي: الذي قد افتُتن عن الحق وضَلّ عنه، وإنما دَخَلت الباء في قوله: <q>﴿بأييكم المفتون﴾</q> لتدلّ على تَضمين الفعل في قوله: <q>﴿فستبصر ويبصرون﴾</q>، وتقديره: فسَتعلم ويَعلمون، أو: فسَتُخبر ويُخبرون بأيكم المفتون». ورجَّح ابنُ تيمية (٦/٣٧٥) -مستندًا إلى القراءات، وأقوال السلف- القول الثالث الذي قاله مجاهد، والحسن، وقتادة، فقال: «قوله تعالى: <q>﴿بأيكم المفتون﴾</q> حار فيها كثير من الناس، والصواب فيها التفسير المأثور عن السلف». ثم عَلّق على قول الحسن بقوله: «فبَيّن الحسن المعنى المراد وإن لم يَتكلّم على اللفظ، كعادة السلف في اختصار الكلام مع البلاغة وفهم المعنى». ثم قال: «ويدلّ أيضًا على هذا المعنى في الآية أنّ في قراءة أُبيّ بن كعب، والجَوْنيّ، وابن عبلة: (فِي أيِّيكُمُ المَفْتُونُ) والشيطان مفتون بلا ريب». وذكر (٦/٣٧٥-٣٧٦) أنّ القول الثاني الوارد عن الحسن أيضًا موافق لما ذُكر؛ فإنّ الضّال به المفتون الذي هو شيطان، ثم قال: «وإنما ذَكر الحسن لفظ الضّال؛ لأنهم لم يريدوا بالمجنون الذي يَخرق ثيابه، ويَقذف بالحجارة، ويَتكلّم بالهذَيان». ",footnotes:1:أخرجه ابن جرير ٢٣/١٥٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٣، ومن طريق ليث أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٥٣-١٥٤.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٩-.أخرجه أبو عمرو الداني في المكتفى ص٢٢٠ (٤١).أخرجه عبد الرزاق ٢/٣٠٨، وابن جرير ٢٣/١٥٤، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٠٣.
68,7," <q>﴿إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِیلِهِۦ وَهُوَ أَعۡلَمُ بِٱلۡمُهۡتَدِینَ ۝٧﴾</q> - تفسير ٧٨٠٦٤- قال مقاتل بن سليمان: ثم قال: <q>﴿إنَّ رَبَّكَ هُوَ أعْلَمُ بِمَن ضَلَّ عَنْ سَبِيلِهِ﴾</q> الهُدى، <q>﴿وهُوَ أعْلَمُ بِالمُهْتَدِينَ﴾</q> مِن غيره{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٣.
68,8," <q>﴿فَلَا تُطِعِ ٱلۡمُكَذِّبِینَ ۝٨﴾</q> - نزول الآية ٧٨٠٦٥- قال مقاتل بن سليمان: قوله: <q>﴿فَلا تُطِعِ المُكَذِّبِينَ﴾</q> حين دعا إلى دين آبائه ومِلّتهم، نزلت هذه الآية في بني المُغيرة بن عبد الله بن عمر بن مخزوم؛ منهم الوليد بن المُغيرة، وأبو قيس بن الفاكه بن المُغيرة، وعبد الله بن أبي أُمَيّة، وعبد الله بن مخزوم، وعثمان ونوفل ابني عبد الله بن المُغيرة، والعاص، وقيس، وعبد شمس، وبني الوليد سبعة؛ الوليد، وخالد، وعمارة، وهشام، والعاص، وقيس، وعبد شمس، بنو الوليد بن المُغيرة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٣-٤٠٤. كذا جاءت الأسماء، ويظهر وجود تصحيف وسقط وتكرار.
68,9," <q>﴿وَدُّوا۟ لَوۡ تُدۡهِنُ فَیُدۡهِنُونَ ۝٩﴾</q> - تفسير ٧٨٠٦٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، قال: لو تُرُخِّص لهم فيُرخِّصون{1}. (١٤/٦٢٦) ٧٨٠٦٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، يقول: ودُّوا لو تَكفر فيَكفُرون{2}. (ز) ٧٨٠٦٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، يقول: لو تَرْكن إليهم، وتَترك ما أنتَ عليه مِن الحق؛ فيُمالِئونك{3}. (١٤/٦٢٦) ٧٨٠٦٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، قال: تَكفر فيكفرون{2}. (ز) ٧٨٠٧٠- عن عكرمة مولى ابن عباس، <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، قال: لو تَكفر فيكفرون{5}. (١٤/٦٢٧) ٧٨٠٧١- قال الحسن البصري: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q> لو تُصانعهم في دينك؛ فيُصانعونك في دينهم{6}. (ز) ٧٨٠٧٢- عن الحسن البصري -من طريق عَوْف- <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>: لو تَرفض بعض أمْرك؛ فيَرفضون بعض أمْرهم{7}. (ز) ٧٨٠٧٣- قال عطية بن سعد العَوفيّ: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q> لو تَكْذِبُ فيَكْذِبُون{7}. (ز) ٧٨٠٧٤- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، قال: ودُّوا لو يُدهِن رسولُ الله فيُدهِنون{9}. (ز) ٧٨٠٧٥- عن قتادة بن دعامة، <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، قال: ودُّوا لو وهِن نبيُّ الله ﷺ عن هذا الأمر؛ فوَهِنوا عنه{5}. (١٤/٦٢٦) ٧٨٠٧٦- قال زيد بن أسلم: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q> لو تَنافق وتُرائي؛ فيُنافِقون ويُراؤون{6}. (ز) ٧٨٠٧٧- قال محمد بن السّائِب الكلبي: <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q> لو تَلين لهم فيَلينون لك{12}. (ز) ٧٨٠٧٨- قال مقاتل بن سليمان: <q>﴿ودُّوا﴾</q> حين دعا إلى دين آبائه <q>﴿لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q> يقول: ودُّوا لو تَكفر -يا محمد- فيَكفرون فلا يُؤمنون{13}. (ز) ٧٨٠٧٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿ودُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ﴾</q>، قال: تَكفر فيكفرون{2}٦٧٢٤. (ز) ٦٧٢٤ اختُلف في معنى قوله: <q>﴿ودوا لو تدهن فيدهنون﴾</q> على قولين: الأول: أنّ المعنى ذلك: ودّ المُكذِّبون بآيات الله لو تَكفر بالله -يا محمد- فيكفرون. الثاني: ودُّوا لو تُرخِّص لهم فيُرخِّصون، أو تَلين في دينك فيَلينون في دينهم. ورجَّح ابنُ جرير (٢٣/١٥٧) -مستندًا إلى النظائر، واللغة- القول الثاني الذي قاله ابن عباس من طريق العَوفيّ، ومجاهد، وقتادة، فقال: «وأولى القولين في ذلك بالصواب: قولُ مَن قال: معنى ذلك: ودّ هؤلاء المشركون -يا محمد- لو تَلين لهم في دينك بإجابتك إياهم إلى الرُّكون إلى آلهتهم، فيَلينون لك في عبادتك إلهك، كما قال -جلّ ثناؤه-: <q>﴿ولولا أن ثبتناك لقد كدت تركن إليهم شيئًا قليلا إذا لأذقناك ضعف الحياة وضعف الممات﴾</q> [الإسراء:٧٤-٧٥]. وإنما هو مأخوذ من الدُّهن، شبّه التّليين في القول بَتليين الدُّهن». ",footnotes:1:أخرجه ابن جرير ٢٣/١٥٦. وعزاه السيوطي إلى ابن المنذر، وأبي حاتم.أخرجه ابن جرير ٢٣/١٥٦.أخرجه ابن جرير ٢٣/١٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٥٦.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.تفسير الثعلبي ١٠/١٢.تفسير الثعلبي ١٠/١٢.أخرجه عبد الرزاق ٢/٣٠٨، وابن جرير ٢٣/١٥٧، وبنحوه من طريق سعيد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.تفسير الثعلبي ١٠/١٢، تفسير البغوي ٨/١٩٢.تفسير مقاتل بن سليمان ٤/٤٠٤.أخرجه ابن جرير ٢٣/١٥٦.
68,10," <q>﴿وَلَا تُطِعۡ كُلَّ حَلَّافࣲ مَّهِینٍ ۝١٠﴾</q> - نزول الآية ٧٨٠٨٠- عن أبي عثمان النَّهدي، قال: قال مروان بن الحكم لَمّا بايع الناسُ ليزيد: سُنّة أبي بكر وعمر. فقال عبد الرحمن بن أبي بكر: إنّها ليست بسُنّة أبي بكر وعمر، ولكنها سُنّة هِرَقْل. فقال مروان: هذا الذي أُنزِل فيه: <q>﴿والَّذِي قالَ لِوالِدَيْهِ أُفٍّ لَكُما﴾</q> الآية [الأحقاف:١٧]. قال: فسمِعَتْ ذلك عائشةُ، فقالتْ: إنّها لم تنزِل في عبد الرحمن، ولكن نزلت في أبيك: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ هَمّازٍ مَشّاءٍ بِنَمِيمٍ﴾</q>{1}. (١٤/٦٢٧) ٧٨٠٨١- عن عبد الله بن عباس، <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ﴾</q> الآية، قال: يعني: الأسود بن عبد يَغوث{2}. (١٤/٦٢٧) ٧٨٠٨٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q>، قال: نزلت في الأَخْنس بن شَرِيق{3}. (١٤/٦٣١) ٧٨٠٨٣- عن محمد بن السّائِب الكلبي -من طريق معمر-، مثله{4}. (١٤/٦٣١) ٧٨٠٨٤- عن مجاهد بن جبر، في قوله: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q>، قال: هو الأسود بن عبد يَغوث{3}. (١٤/٦٣١) ٧٨٠٨٥- عن عامر الشعبي، <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ﴾</q> الآية، قال: هو رجل من ثَقيف، يُقال له: الأَخْنس بن شَرِيق{6}. (١٤/٦٢٧) ٧٨٠٨٦- قال عطاء: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q> الأَخْنس بن شَرِيق{7}٦٧٢٥. (ز) ٦٧٢٥ علَّق ابنُ عطية (٨/٣٦٨) على هذا القول الذي قاله السُّدِّيّ، والكلبي، والشعبي، وعطاء، مستندًا إلى التاريخ، فقال: «ويؤيّد ذلك أنه كانت له هَنة في حلقه كزنَمة الشاة، وأيضًا فكان من ثقيف مُلصقًا في قريش». وذكر (٨/٣٧٠) أنّ أكثر المفسرين على هذا القول. ٧٨٠٨٧- عن الربيع بن أنس -من طريق عيسى بن عبد الله التميمي- قال: نزلت في الوليد بن المغيرة: <q>﴿عتل بعد ذلك زنيم﴾</q>، قال: فاحش مع ذلك لئيم{8}٦٧٢٦. (ز) ٦٧٢٦ علَّق ابنُ عطية (٨/٣٦٨) على هذا القول الذي قاله الربيع، ومقاتل، مستندًا إلى التاريخ، فقال: «ويؤيد ذلك غناه، وأنه أشهرهم بالمال والبنين». ٧٨٠٨٨- قال مقاتل بن سليمان: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q>، يعني: الوليد بن المُغيرة المخزوميّ{9}٦٧٢٧. (ز) ٦٧٢٧ ذكر ابنُ عطية (٨/٣٦٨) أنّ كثيرًا من المفسرين ذهب إلى أنّ هذه الأوصاف هي أجناس لم يُرد بها رجل بعينه، ورجَّحه مستندًا إلى العموم، فقال: «وظاهر اللفظ عمومُ مَن هذه صفته». ثم قال: «والمخاطبة بهذا المعنى مُستمرّة باقي الزمن، لا سيما لولاة الأمور». <q>﴿وَلَا تُطِعۡ كُلَّ حَلَّافࣲ مَّهِینٍ ۝١٠﴾</q> - تفسير الآية ٧٨٠٨٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿مَهِينٍ﴾</q>، قال: الكذّاب{10}٦٧٢٨. (١٤/٦٣٥) ٦٧٢٨ وجَّه ابنُ جرير (٢٣/١٥٨) تفسير ابن عباس للمَهين بالكذّاب، بقوله: «وأحسبه فعل ذلك؛ لأنه رأى أنه إذا وُصف بالمهانة، فإنما وُصف بها لمهانة نفسه وكانت عليه، وكذلك صفة الكذوب، إنما يَكذب لمهانة نفسه عليه». ٧٨٠٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿حَلّافٍ مَهِينٍ﴾</q>: ضعيف{11}. (ز) ٧٨٠٩١- عن الحسن البصري -من طريق معمر- في قوله: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q> يقول: مِكثار في الحَلِف، <q>﴿مَهِينٍ﴾</q> يقول: ضعيف{12}٦٧٢٩. (١٤/٦٢٧) ٦٧٢٩ ساق ابنُ عطية (٨/٣٦٨) هذا القول، ثم علَّق بقوله: «وهو مِن: مهُن إذا ضعف، والميم فاء الفعل». ٧٨٠٩٢- عن الحسن البصري -من طريق سعيد- <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q>: وهو المِكثار في الشّرِّ{13}. (ز) ٧٨٠٩٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q>، قال: المَهين: المِكثار في الشّرّ{14}. (١٤/٦٢٨) ٧٨٠٩٤- قال مقاتل بن سليمان: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ﴾</q>، يعني: الوليد بن المُغيرة المخزوميّ. يقول: كان تاجرًا ضعيف القلب، وذلك أنه كان عَرض على النبي ﷺ المالَ على أن يَرجع عن دينه، وذلك قوله تعالى: <q>﴿ولا تُطِعْ مِنهُمْ آثِمًا أوْ كَفُورًا﴾</q> [الإنسان:٢٤]، يعني: الوليد، وعُتبة{15}. (ز) ",footnotes:1:أخرجه النسائي في الكبرى ١٠/٢٥٧ (١١٤٢٧)، والحاكم في المستدرك ٤/٥٢٨ (٨٤٨٣)، من طريق محمد بن زياد، عن عائشة بنحوه. قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وتعقّبه الذهبي، فقال: «فيه انقطاع».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٠٨. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٩٢.أخرجه ابن إسحاق في سيرته ص١٤٠.تفسير مقاتل بن سليمان ٤/٤٠٤. وهو في تفسير البغوي ٨/١٩٢ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢٣/١٥٨. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٣/١٥٨.أخرجه عبد الرزاق ٢/٣٠٨، وابن جرير ٢٣/١٥٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٥٩.أخرجه ابن جرير ٢٣/١٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٤.
68,11," <q>﴿هَمَّازࣲ﴾</q> - تفسير ٧٨٠٩٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿هَمّازٍ﴾</q>: يعني: الاغتياب{1}. (١٤/٦٣٥) ٧٨٠٩٦- قال الحسن البصري: <q>﴿هَمّازٍ﴾</q> هو الذي يَغمز بأخيه في المجلس{2}. (ز) ٧٨٠٩٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿هَمّازٍ﴾</q>، قال: يأكل لحوم الناس{3}. (١٤/٦٢٨) ٧٨٠٩٨- قال مقاتل بن سليمان: <q>﴿هَمّازٍ﴾</q>، يعني: مُغتاب{4}. (ز) ٧٨٠٩٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿هَمّازٍ﴾</q>، قال: الهمّاز: الذي يَهمز الناس بيده، ويَضربهم، وليس باللسان. وقرأ: <q>﴿ويْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾</q> [الهمزة:١]، الذي يَلمز الناس بلسانه، والهَمْز أصله الغَمْز، فقيل للمُغتاب: هَمّاز؛ لأنه يَطعن في أعراض الناس بما يَكرهون، وذلك غمْزٌ عليهم{5}. (ز) <q>﴿مَّشَّاۤءِۭ بِنَمِیمࣲ ۝١١﴾</q> - تفسير ٧٨١٠٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿مَشّاءٍ بِنَمِيمٍ﴾</q>: يمشي بالكذب{6}. (ز) ٧٨١٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿مَشّاءٍ بِنَمِيمٍ﴾</q>: يَنقل الأحاديث مِن بعض الناس إلى بعض{6}. (ز) ٧٨١٠٢- عن محمد بن السّائِب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿مَشّاءٍ بِنَمِيمٍ﴾</q>، قال: هو الأَخْنس بن شَريق، أصله من ثَقيف، وعِداده في بني زهرة{6}. (ز) ٧٨١٠٣- قال مقاتل بن سليمان: <q>﴿هَمّازٍ﴾</q> يعني: مغتاب، <q>﴿مَشّاءٍ بِنَمِيمٍ﴾</q> كان يَمشي بالنَّميمة{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/١٥٩. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.أخرجه ابن جرير ٢٣/١٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٤.أخرجه ابن جرير ٢٣/١٥٩.أخرجه ابن جرير ٢٣/١٦٠.أخرجه ابن جرير ٢٣/١٦٠.أخرجه ابن جرير ٢٣/١٦٠.تفسير مقاتل بن سليمان ٤/٤٠٤.
68,12," <q>﴿مَّنَّاعࣲ لِّلۡخَیۡرِ مُعۡتَدٍ أَثِیمٍ ۝١٢﴾</q> - تفسير ٧٨١٠٤- قال عبد الله بن عباس: <q>﴿مَنّاعٍ لِلْخَيْرِ﴾</q> أي: للإسلام، يَمنع ولده وعشيرته عن الإسلام، يقول: لئن دَخل واحدٌ منكم في دين محمد لا أنفعه بشيء أبدًا{1}. (ز) ٧٨١٠٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿مَنّاعٍ لِلْخَيْرِ﴾</q> قال: فلا يُعطي خيرًا، <q>﴿مُعْتَدٍ﴾</q> قال: مُعتدٍ في قوله، مُعتدٍ في عمله، <q>﴿أثِيمٍ﴾</q> بربّه{2}. (١٤/٦٢٨) ٧٨١٠٦- قال مقاتل بن سليمان: <q>﴿مَنّاعٍ لِلْخَيْرِ﴾</q> يعني: الإسلام، منع ابن أخيه وأهله الإسلام، <q>﴿مُعْتَدٍ﴾</q> يعني: في الغَشْم والظُّلم، <q>﴿أثِيمٍ﴾</q> يعني: أثيم بربّه لغَشْمه وظُلمه، نظيرها في <q>﴿ويْلٌ لِلْمُطَفِّفِينَ﴾</q>{3}٦٧٣٠. (ز) ٦٧٣٠ ذكر ابنُ عطية (٨/٣٦٩) أنّ كثيرًا من المفسرين قالوا: الخير هنا المال، فوصَفه بالشحّ. ونَقل عن آخرين أنه على عمومه في المال والأفعال الصالحة، وعلَّق عليه بقوله: «ومَن يَمنع إيمانه وطاعته لله تعالى فقد مَنع الخير». ",footnotes:1:تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.أخرجه ابن جرير ٢٣/١٦٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٤. والمراد بنظيرها هنا هو قوله تعالى: <q>﴿وما يُكَذِّبُ بِهِ إلّا كُلُّ مُعْتَدٍ أثِيمٍ﴾</q> [المطففين:١٢].
68,13," <q>﴿عُتُلِّۭ﴾</q> - تفسير ٧٨١٠٧- عن أبي الدّرداء، عن رسول الله ﷺ، في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: «العُتلّ: كلّ رَحيب الجوف، وثيق الخَلْق{1}، أكولٌ، شَروبٌ، جَموعٌ للمال، مَنوعٌ للخير»{2}. (١٤/٦٣٢) ٧٨١٠٨- عن شَدادّ بن أوْس، قال: قال رسول الله ﷺ: «لا يَدخل الجنة جَوّاظ، ولا جَعْظَريّ، ولا عُتُلّ، ولا زَنيم». قال: قلت: فما الجوّاظ؟ قال: «كلُّ جمّاع منّاع». قلت: فما الجَعْظَريّ؟ قال: «الفَظّ الغَليظ». قلت: فما العُتُلّ الزَّنيم؟ قال: «كلّ رَحب الجوف، وثيق الخَلْق، أكولٌ، شَروبٌ، غَشومٌ، ظَلومٌ»{3}. (ز) ٧٨١٠٩- عن عبد الرحمن بن غَنْم، أنّ رسول الله ﷺ قال: «لا يَدخل الجنة جَوّاظ، ولا جَعْظَريّ، ولا العُتُلّ الزَّنيم». فقال له رجل من المسلمين: ما الجَوّاظ، والجَعْظَريّ، والعُتُل الزَّنيم؟ فقال رسول الله ﷺ: «أما الجَوّاظ فالذي جَمع ومَنع، تدعوه لَظى، نَزّاعة للشَّوى، وأما الجَعْظَريّ فالفَظّ الغليظ، قال الله: <q>﴿فَبِما رَحْمَةٍ مِنَ اللَّهِ لِنْتَ لَهُمْ ولَوْ كُنْتَ فَظًّا غَلِيظَ القَلْبِ لانْفَضُّوا مِن حَوْلِكَ﴾</q> [آل عمران:١٥٩]، وأما العُتُلّ الزَّنيم فشديد الخَلْق، رَحيب الجوف، مُصحّح، أكولٌ، شَروبٌ، واجدٌ للطعام والشراب، ظَلومٌ للناس»{4}. (١٤/٦٣٠) ٧٨١١٠- عن زيد بن أسلم، قال: قال رسول الله ﷺ: «تبكي السماء مِن عبدٍ أصحّ اللهُ جسمَه، وأَرحب جوفه، وأعطاه من الدنيا مَقْضمًا{5}، فكان للناس ظَلومًا، فذلك العُتُلّ الزَّنيم»{6}. (١٤/٦٣٢) ٧٨١١١- عن القاسم مولى معاوية، وموسى بن عُقبة، قالا: سُئِل رسول الله ﷺ عن العُتلّ الزنيم. قال: «هو الفاحش اللئيم»{7}. (١٤/٦٣٢) ٧٨١١٢- قال علي بن أبي طالب: <q>﴿عُتُلٍّ﴾</q>، العُتُلّ: الفاحش الخُلُق، السيئ الخُلُق{8}. (ز) ٧٨١١٣- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: العُتُلّ: هو الدَّعِيُّ{9}. (١٤/٦٣٣) ٧٨١١٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿عُتُلٍّ﴾</q>، قال: الشّديد الفاتك{10}. (١٤/٦٣٥) ٧٨١١٥- عن شَهْر بن حَوْشَب، عن عبد الله بن عباس، قال: ستة لا يدخلون الجنة أبدًا: العاقُّ، والمُدمن، والجَعْثَلُ{11}، والجَوّاظ، والقَتّات، والعُتُلّ الزَّنيم. فقلتُ: يا ابن عباس، أما اثنتان فقد عَلمتُ، فأَخبِرني ما الأربع. قال: أما الجَعْثَل فالفَظّ الغليظ، وأما الجَوّاظ فمَن يَجمع المال ويَمنع، وأما القَتّات فمَن يأكل لحوم الناس، وأما العُتُلّ الزَّنيم فمَن يمشي بين الناس بالنَّميمة{12}. (١٤/٦٣٠) ٧٨١١٦- عن عبد الله بن عمر، أنه تلا: <q>﴿مَنّاعٍ لِلْخَيْرِ﴾</q> إلى <q>﴿زَنِيمٍ﴾</q>. فقال: سمعتُ رسول الله ﷺ يقول: «أهل النار كلّ جَعْظَريّ، جَوّاظ، مُستكبر، جمّاع، منّاع، وأهل الجنة الضّعفاء المَغلوبون»{13}. (١٤/٦٣٣) ٧٨١١٧- عن أبي أُمامة، في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: هو الفاحش اللئيم{12}. (١٤/٦٢٨) ٧٨١١٨- عن الحسن البصري= (ز) ٧٨١١٩- وأبي العالية الرِّياحيّ، مثله{15}. (١٤/٦٢٨) ٧٨١٢٠- عن عُبيد بن عُمير -من طريق أبي الزّبير- قال: العُتُلّ: الأَكُول الشَّروب، القوي الشديد، يُوضع في الميزان فلا يَزن شعيرة، يَدفع الملَك مِن أولئك سبعين ألفًا دفعةً في جهنم{16}. (ز) ٧٨١٢١- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق سفيان، عن منصور- في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: العُتُلّ: الشديد{17}. (ز) ٧٨١٢٢- عن أبي رَزِين -من طريق جرير، عن منصور- قال: العُتُلّ: الصحيح{18}. (١٤/٦٢٨) ٧٨١٢٣- عن أبي رَزِين -من طريق جرير، عن منصور- <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: هو الفاجر الصحيح{19}. (ز) ٧٨١٢٤- عن إبراهيم النَّخْعي -من طريق منصور- في قوله تعالى: <q>﴿عتل بعد ذلك زنيم﴾</q>، قال: العُتُلّ: الفاجر{20}. (ز) ٧٨١٢٥- عن مجاهد بن جبر –من طريق ابن أبي نجيح- <q>﴿عُتُلٍّ﴾</q>، قال: شَديد الأَسْر{21}. (١٤/٦٢٨) ٧٨١٢٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿عُتُلٍّ﴾</q>، قال: العُتلّ: الشديد{22}. (ز) ٧٨١٢٧- عن عكرمة مولى ابن عباس -من طريق عمر بن نافع- أنه سُئل عن: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>. فقال: ذلك الكافر اللئيم{23}. (ز) ٧٨١٢٨- عن الحسن البصري -من طريق معمر- قال: هو الفاحش اللئيم الضَرِيبة{24}. (١٤/٦٢٨) ٧٨١٢٩- عن شَهْر بن حَوْشَب، قال: العُتُلّ: الصحيح، الأَكُول، الشَّرُوب{12}. (١٤/٦٢٩) ٧٨١٣٠- عن وهْب الذِّماري -من طريق عطاء بن يَسار- قال: تبكي السماء والأرض مِن رجل أتمّ الله خَلْقه، وأَرحبَ جوفه، وأعطاه مَقْضَمًا من الدنيا، ثم يكون ظَلومًا للناس، فذلك العُتُلّ الزَّنيم{26}. (ز) ٧٨١٣١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عُتُلٍّ﴾</q>: هو الفاحش اللئيم الضَّرِيبة. وذُكر لنا: أنّ النبي ﷺ قال: «لا تقوم الساعة حتى يَظهر الفُحْش، والتَّفحُّش، وسُوء الجوار، وقَطيعة الرَّحِم»{27}. (١٤/٦٢٨) ٧٨١٣٢- عن الربيع بن أنس -من طريق عيسى بن عبد الله التميمي- <q>﴿عتل بعد ذلك زنيم﴾</q>، قال: فاحش مع ذلك لئيم{28}. (ز) ٧٨١٣٣- قال محمد بن السّائِب الكلبي: <q>﴿عُتُلٍّ﴾</q> هو الشديد في كُفره{29}. (ز) ٧٨١٣٤- قال مقاتل: <q>﴿عُتُلٍّ﴾</q> الضَّخم{8}. (ز) ٧٨١٣٥- قال مقاتل بن سليمان: <q>﴿عُتُلٍّ بَعْدَ ذلِكَ﴾</q> يقول: مع ذلك النَّعت <q>﴿زَنِيمٍ﴾</q>، يعني بالعُتُلّ: رَحيب الجوف، مُوثق الحلق{31}، أكولٌ، شَروبٌ، غَشومٌ، ظَلوم{32}٦٧٣١. (ز) ٦٧٣١ ذكر ابنُ عطية (٨/٣٦٩) أنّ العُتُلّ: القويّ البنية، الغليظ الأعضاء، المُصحَّح، القاسي القلب، البعيد الفهم، الأَكُول الشَّروب، الذي هو بالليل جيفة وبالنهار حمار. ثم علَّق بقوله: «فكلّ ما عبّر به المفسرون عنه من خلال النقص فعن هذه التي ذكرتُ تصْدر». ثم بيّن أنّ هذه الصفات كثيرة التلازم. <q>﴿عُتُلِّۭ﴾</q> - آثار متعلقة بالآية ٧٨١٣٦- عن حارثة بن وهب، قال: سمعتُ رسول الله ﷺ يقول: «ألا أُخبِركم بأهل الجنة! كلّ ضعيف مُتضعّف، لو أقسم على الله لأَبرّه، ألا أُخبِركم بأهل النار! كلّ عُتلِّ جَوّاظٍ مُستكبر»{33}. (١٤/٦٣٢) <q>﴿بَعۡدَ ذَ ٰ⁠لِكَ زَنِیمٍ ۝١٣﴾</q> - تفسير ٧٨١٣٧- عن علي بن أبي طالب -من طريق قتادة- قال: الزَّنيم: هو الهَجِين الكافر{34}. (١٤/٦٣٥) ٧٨١٣٨- قال علي بن أبي طالب: الزَّنيم: الذي لا أصل له{35}. (ز) ٧٨١٣٩- عن عبد الله بن عباس، قال: الزَّنيم: هو الرجل يَمُرّ على القوم، فيقولون: رجل سُوء{36}. (١٤/٦٣٣) ٧٨١٤٠- عن عبد الله بن عباس، في قوله: <q>﴿زَنِيمٍ﴾</q>، قال: الدَّعِيّ، الفاحش، اللئيم{36}. (١٤/٦٣٤) ٧٨١٤١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿زَنِيمٍ﴾</q>، قال: ظَلوم{38}. (١٤/٦٣٤) ٧٨١٤٢- عن عبد الله بن عباس -من طريق شعبة، عن أبي إسحاق، عن سعيد بن جُبَير- أنه قال في الزَّنيم: الذي يُعرف بأُبْنة{39}{40}. (ز) ٧٨١٤٣- عن عبد الله بن عباس -من طريق شريك، عن أبي إسحاق، عن سعيد بن جُبَير- قال: الزَّنيم: هو المُريب الذي يُعرف بالشّرّ{41}. (١٤/٦٣٣) ٧٨١٤٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: هو الرجل يُعرف بالشّرّ؛ كما تُعرف الشاة بزَنَمتها{42}. (١٤/٦٣٣) ٧٨١٤٥- عن عبد الله بن عباس -من طريق أبي حصين، عن مجاهد- في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: هو رجل من قريش، كانت له زَنَمة زائدة مثل زَنَمة الشاة، يُعرف بها{43}. (١٤/٦٣٤) ٧٨١٤٦- عن عبد الله بن عباس -من طريق ابن أبي نجيح، عن مجاهد- قال: الزَّنيم: المُلحق النَّسب{44}. (١٤/٦٢٨، ٦٣٤) ٧٨١٤٧- عن عبد الله بن عباس –من طريق علي بن عاصم، عن داود بن أبي هند، عن عكرمة- قال: نَزل على النبي ﷺ: <q>﴿ولا تُطِعْ كُلَّ حَلّافٍ مَهِينٍ هَمّازٍ مَشّاءٍ بِنَمِيمٍ﴾</q> فلم يُعرف، حتى نَزل عليه بعد ذلك: <q>﴿زَنِيمٍ﴾</q> فعرفناه، له زَنَمَةٌ{45} كزَنَمَةِ الشاة{46}. (١٤/٦٣١) ٧٨١٤٨- عن عبد الله بن عباس - من طريق عبد الأعلى، عن داود، عن عكرمة - في الآية، قال: نُعِتَ فلم يُعرف، حتى قيل: <q>﴿زَنِيمٍ﴾</q>، وكانت له زَنَمة في عُنُقه يُعرف بها{47}. (١٤/٦٣٤) ٧٨١٤٩- عن عبد الله بن عباس -من طريق هشام، عن عكرمة- في قوله: <q>﴿زَنِيمٍ﴾</q>، قال: هو الدَّعِيُّ، أما سمعتَ قول الشاعر: زَنيمٌ تداعتْه الرجال زِيادة كما زِيد في عَرْضِ الأديمِ الأَكارِع؟{48}. (١٤/٦٢٨) ٧٨١٥٠- عن عبد الله بن عباس -من طريق أبي صفية، عن شيخ يكنى أبا عبد الرحمن- قال: الزَّنيم: الدَّعِيُّ الفاحش، اللئيم المُلزَق. ثم أنشد هذ البيت: زنيمٌ تَداعاه الرجال زِيادة كما زِيد في عَرْضِ الأديم الأَكارعِ{49}. (١٤/٦٣١) ٧٨١٥١- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿زَنِيمٍ﴾</q>. قال: ولد الزِّنا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر: زنيمٌ تداعتْه الرجال زِيادة كما زِيد في عَرْضِ الأديم الأَكارِع؟{50}. (١٤/٦٣٤) ٧٨١٥٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿زَنِيمٍ﴾</q>، قال: والزَّنيم: الدَّعِيُّ. ويقال: الزَّنيم رجل كانت به زَنَمة يُعرف بها. ويقال: هو الأَخْنس بن شَريق الثَّقَفي حَليف بني زهرة. وزعم ناس من بني زهرة: أنّ الزَّنيم هو الأسود بن عبد يَغوث الزُّهريّ، وليس به{22}. (ز) ٧٨١٥٣- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق منصور- قال: الزَّنيم: الفاجر. وفي لفظ: الكافر{52}. (١٤/٦٢٨) ٧٨١٥٤- عن سعيد بن المسيّب -من طريق عبد الرحمن بن حَرْملة- في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: هو المُلزَق في القوم ليس منهم{53}. (١٤/٦٣٠) ٧٨١٥٥- عن سعيد بن جُبَير -من طريق الحسن- قال: الزَّنيم: الذي يُعرف بالشّرّ، كما تُعرف الشاة بزَنَمتها، المُلصق{54}. (ز) ٧٨١٥٦- قال سعيد بن جُبَير: <q>﴿زَنِيمٍ﴾</q> هو الكافر، الهَجِين، المعروف بالشّرّ، المُريب{35}. (ز) ٧٨١٥٧- عن إبراهيم النَّخْعي -من طريق منصور- في قوله تعالى: <q>﴿عتل بعد ذلك زنيم﴾</q>، قال: الزَّنيم: اللئيم في أخلاق الناس{20}. (ز) ٧٨١٥٨- قال مُرّة الهَمداني: إنما ادّعاه أبوه بعد ثماني عشرة سنة{57}. (ز) ٧٨١٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: الزَّنيم يُعرف بهذا الوصف، كما تُعرف الشاة الزَّنماء من التي لا زَنَمة لها{58}. (١٤/٦٢٩) ٧٨١٦٠- عن مجاهد بن جبر، قال: العُتُلّ الزَّنيم: رجل ضخم شديد، كانت له زَنَمة زائدة في يده، وكانت علامته{12}. (١٤/٦٢٩) ٧٨١٦١- عن مجاهد بن جبر -من طريق الثُّمالي- في الزَّنيم، قال: كانت له سِتّ أصابع في يده، في كلّ إبهام له إصبع{60}. (ز) ٧٨١٦٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: الزَّنيم، يقول: كانت له زَنَمة في أصل أُذُنه. يقال: هو اللئيم، المُلصَق في النَّسب{61}. (ز) ٧٨١٦٣- قال عكرمة مولى ابن عباس -من طريق هشام- الزَّنيم: هو الدَّعِيُّ{54}. (ز) ٧٨١٦٤- عن عكرمة مولى ابن عباس، في قوله: <q>﴿عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ﴾</q>، قال: يُعرف الكافر من المؤمن مثل الشاة الزَّنماء، والزَّنماء التي في حلقها كالمُتَعلِّقتين في حَلْق الشاة{12}. (١٤/٦٢٩) ٧٨١٦٥- عن عكرمة مولى ابن عباس أنه سُئل عن الزَّنيم. قال: هو ولد الزِّنا. وتمثّل بقول الشاعر: زَنيمٌ ليس يُعرف مَن أبوه بَغيُّ الأُمِّ ذو حسبٍ لئيم{64}. (١٤/٦٢٩) ٧٨١٦٦- قال عكرمة مولى ابن عباس -من طريق خُصَيف- الزَّنيم: الذي يُعرف باللؤم كما تُعرف الشاة بزَنَمتها{65}. (ز) ٧٨١٦٧- عن عامر الشعبي، أنه سُئل عن الزَّنيم. قال: هو الرجل تكون له الزَّنمة من الشّرّ يُعرف بها، وهو رجل من ثقيف يُقال له: الأَخْنس بن شَريق{66}. (١٤/٦٣١) ٧٨١٦٨- عن شَهْر بن حَوْشَب -من طريق داود بن أبي هند- قال: هو الجِلف الجافي، الأَكُول الشَّروب مِن الحرام{67}. (ز) ٧٨١٦٩- عن شَهْر بن حَوْشَب، قال: الزَّنيم: الفاجر{12}. (١٤/٦٢٩) ٧٨١٧٠- قال محمد بن كعب القُرَظيّ: <q>﴿زَنِيمٍ﴾</q> هو الكافر، الهَجِين، المعروف بالشّرّ، المُريب{35}. (ز) ٧٨١٧١- عن الربيع بن أنس -من طريق عيسى بن عبد الله التميمي- <q>﴿عتل بعد ذلك زنيم﴾</q>، قال: فاحش مع ذلك لئيم{28}. (ز) ٧٨١٧٢- قال مقاتل بن سليمان: ومعنى <q>﴿زَنِيمٍ﴾</q>: أنه كان في أصل أُذُنه مثل زَنَمة الشاة، مثل الزَّنَمة التي تكون مُعلَّقة في لحى الشاة، زيادة في خَلْقه{32}. (ز) ٧٨١٧٣- قال معمر بن راشد: <q>﴿زَنِيمٍ﴾</q> هو ولد الزنا في بعض اللغة{72}. (ز) ٧٨١٧٤- عن ابن إدريس، عن أصحاب التفسير، قالوا: هو الذي يكون له زَنَمة كزَنَمة الشاة{73}٦٧٣٢. (ز) ٦٧٣٢ ساق ابنُ كثير (١٤/٩٢) هذا القول، ثم علَّق بقوله: «ومعنى هذا: أنه كان مشهورًا بالشّرّ كشُهرة الشاة ذات الزَّنمة من بين أخواتها». ثم قال (١٤/٩٣): «والأقوال في هذا كثيرة، وتَرجع إلى ما قلناه، وهو أنّ الزَّنيم هو: المشهور بالشر، الذي يُعرف به من بين الناس، وغالبًا يكون دعيًّا ولد زنا، فإنه في الغالب يَتسلّط الشيطان عليه ما لا يَتسلّط على غيره، كما جاء في الحديث: «لا يدخل الجنة ولد زنا»». ",footnotes:1:وثيق: عظيم الخلقة. فيض القدير ٤/٣٧٥.عزاه السيوطي إلى أبي الشيخ، وابن مردويه، والديلمي.أخرجه الجصاص في أحكام القرآن ٣/٦٢٥، والثعلبي ١٠/١٣-١٤ واللفظ له، من طريق الوليد بن مسلم، عن أبي شيبة إبراهيم بن عثمان، عن عثمان بن عمير البجلي، عن شَهْر بن حَوْشَب، عن شَدّاد بن أوْس به. وسنده شديد الضعف؛ فيه إبراهيم بن عثمان أبو شيبة، قال عنه ابن حجر في التقريب (٢١٥): «متروك الحديث».أخرجه أحمد ٢٩/٥١٦، ٥١٧ (١٧٩٩١، ١٧٩٩٣) مختصرًا، من طريق شَهْر بن حَوْشَب، عن عبد الرحمن بن غَنْم به. قال الهيثمي في المجمع ٧/١٢٨ (١١٤٣٥): «فيه شَهْر، وثّقه جماعة، وفيه ضعف، وعبد الرحمن بن غَنْم ليس له صحبة على الصحيح». وقال أيضًا ١٠/٣٩٣ (١٨٦١٨): «إسناده حسن، إلا أن ابن غَنْم لم يسمع من النبي ﷺ». وقال ابن حجر في الفتح ٨/٦٦٣: «مختلف في صحته».المقضم: ما يقضم عليه، ويعني به هنا: المأكل والميرة. اللسان (قضم).أخرجه عبد الرزاق ٢/٣٠٨، وبنحوه عن عطاء بن يَسار مرفوعًا في تفسير <q>﴿زنيم﴾</q>، وابن جرير ٢٣/١٦٣. وعزاه السيوطي إلى ابن المنذر مرسلًا. قال ابن كثير ١٤/٩٢: «هكذا رواه ابن أبي حاتم من طريقين مُرسلين».أخرجه ابن جرير ٢٣/١٦٢. وعزاه السيوطي إلى ابن أبي حاتم مرسلًا.تفسير الثعلبي ١٠/١٢.أخرجه ابن جرير ٢٣/١٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/١٦١. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.الجعثل قيل: هو مقلوب الجثعل، وهو العظيم البطن. قال الخطابي: إنما هو العثجل وهو العظيم البطن. وكذا قال الجوهري. اللسان (جثعل، جعثل، عثجل).عزاه السيوطي إلى عبد بن حميد.أخرجه أحمد ١١/١٤٥ (٦٥٨٠)، ١١/٥٨٥ (٧٠١٠)، والحاكم ٢/٥٤١ (٣٨٤٤)، كلاهما عن عبد الله بن عمرو، وهو الراوي للحديث كما في الدُّر ١٤/٦٣٣. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه بهذه السياقة». ووافقه الذهبي في التلخيص. وقال الهيثمي في المجمع ١٠/٣٩٣ (١٨٦١٧): «رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢١٤ (٧٨٠٩): «رواته تقات». وقال الألباني في الصحيحة ٤/٣٢١ (١٧٤١) بعد نقله لقول الحاكم والذهبي: «وهو كما قالا».عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٠٩-٣١٠ (٣٦١٤٤)، وابن جرير ٢٣/١٦١.أخرجه ابن جرير ٢٣/١٦٢.أخرجه ابن جرير ٢٣/١٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٤ (٢٢٦٩).أخرجه أبو نعيم في حلية الأولياء ٤/٢٣٢.أخرجه ابن جرير ٢٣/١٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٦٤.أخرجه ابن جرير ٢٣/١٦٣.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٦٢، كذا من طريق سعيد، وأبي الأشهب، وأبي رجاء أيضًا. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٩- بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٦١.أخرجه ابن جرير ٢٣/١٦٢ دون الحديث، ومن طريق هشام أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن إسحاق في سيرته ص١٤٠.تفسير الثعلبي ١٠/١٢، وتفسير البغوي ٨/١٩٢.تفسير الثعلبي ١٠/١٢.كذا في المطبوع، ولعلها: الخلق.تفسير مقاتل بن سليمان ٤/٤٠٤-٤٠٥.أخرجه البخاري ٦/١٥٩ (٤٩١٨)، ٨/٢٠ (٦٠٧١)، ٨/١٣٤ (٦٦٥٧)، ومسلم ٤/٢١٩٠ (٢٨٥٣).أخرجه عبد الرزاق ٢/٣٠٩. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٣.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٣/١٦٧، وابن أبي حاتم -كما في الإتقان ٢/٤٨-. وعزاه السيوطي إلى ابن المنذر.الأُبنة: العيب. لسان العرب (أبن).أخرجه ابن جرير ٢٣/١٦٧، وقال عقبه: قال أبو إسحاق: وسمعتُ الناس في إمرة زياد يقولون: العُتُلّ: الدّعيّ.أخرجه ابن جرير ٢٣/١٦٧، وعبد الله بن وهب في الجامع -تفسير القرآن ١/١٤٧-١٤٨ (٣٤٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٦٩-، والخرائطي في مساوئ الأخلاق (٢٢٩)، والحاكم ٢/٤٩٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه البخاري (٤٩١٧)، والنسائي في الكبرى (١١٦١٦)، وأبو نعيم في مستخرجه -كما في فتح الباري ٨/٦٣٣- واللفظ له.أخرجه ابن جرير ٢٣/١٦٥. وعزا السيوطي إلى عبد بن حميد، وابن المنذر نحوه.الزنمة: أصلها هنة معلقة في أذن الشاة، فإذا كانت في الحلق فهي زلمة. لسان العرب (زلم، زنم).أخرجه ابن جرير ٢٣/١٦٦. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/١٦٥-١٦٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٢٣/٣٨٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٨/٥٢٩، ١٠/٤٧٥-٤٧٦. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه الطستي -كما في الإتقان ٢/٨١-.أخرجه ابن جرير ٢٣/١٦٤.أخرجه ابن جرير ٢٣/١٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٦٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٦٥.تفسير الثعلبي ١٠/١٣.أخرجه أبو نعيم في حلية الأولياء ٤/٢٣٢.تفسير الثعلبي ١٠/١٣، وتفسير البغوي ٨/١٩٣.أخرجه ابن جرير ٢٣/١٦٨. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٤.أخرجه ابن جرير ٢٣/١٦٦.أخرجه ابن جرير ٢٣/١٦٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٣ (٢٢٦٨)، وابن جرير ٢٣/١٦٨.عزاه السيوطي إلى ابن سعد، وعبد بن حميد.أخرجه ابن جرير ٢٣/١٦٧-١٦٨.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٣.أخرجه ابن إسحاق في سيرته ص١٤٠.تفسير مقاتل بن سليمان ٤/٤٠٤-٤٠٥.أخرجه عبد الرزاق ٢/٣٠٩.أخرجه ابن جرير ٢٣/١٦٦. وعزاه ابن كثير إلى ابن جرير وفيه: «ابن إدريس عن أبيه».
68,14," <q>﴿أَن كَانَ ذَا مَالࣲ وَبَنِینَ ۝١٤ إِذَا تُتۡلَىٰ عَلَیۡهِ ءَایَـٰتُنَا قَالَ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝١٥﴾</q> - قراءات ٧٨١٧٥- عن عاصم أنه قرأ: ‹ءَأَن كانَ ذا مالٍ وبَنِينَ› يَستفهم بهمزتين{1}٦٧٣٣. (١٤/٦٣٥) ٦٧٣٣ ذكر ابنُ جرير (٢٣/١٦٩) أنّ هذه القراءة تتخرّج على وجهين: الأول: «أن يكون مرادًا به: ألأن كان ذا مال وبنين تُطيعه؟ على وجه التوبيخ لمن أطاعه». الثاني: «أن يكون مرادًا به تقريع هذا الحلّاف المَهين، فقيل: ألأن كان هذا الحلّاف المَهين ذا مال وبنين إذا تُتلى عليه آياتنا قال: أساطير الأولين». وعلَّق عليه بقوله: «وهذا أظهر وجهيه». <q>﴿أَن كَانَ ذَا مَالࣲ وَبَنِینَ ۝١٤ إِذَا تُتۡلَىٰ عَلَیۡهِ ءَایَـٰتُنَا قَالَ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝١٥﴾</q> - تفسير الآية ٧٨١٧٦- قال مقاتل بن سليمان: <q>﴿أنْ كانَ﴾</q> يعني: إذا كان <q>﴿ذا مالٍ وبَنِينَ * إذا تُتْلى عَلَيْهِ﴾</q> يعني: الوليد <q>﴿آياتُنا﴾</q> يعني: القرآن <q>﴿قالَ أساطِيرُ الأَوَّلِينَ﴾</q> يقول: أحاديث الأوّلين وكذبهم، وهو حديث رُستم وإسفنديار{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها ابن عامر، وشعبة، وحمزة، وأبو جعفر، ويعقوب، وهم على أصولهم في تحقيق الهمزة وتسهيلها، والإدخال وعدمه. وقرأ بقية العشرة: <q>﴿أن كانَ﴾</q> بهمزة واحدة. انظر: الإتحاف ص٥٥٢.تفسير مقاتل بن سليمان ٤/٤٠٥.
  68,15,""
