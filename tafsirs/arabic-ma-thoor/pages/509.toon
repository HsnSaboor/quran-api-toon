quran[10]{c,v,t}:
47,20," <q>﴿وَیَقُولُ ٱلَّذِینَ ءَامَنُوا۟ لَوۡلَا نُزِّلَتۡ سُورَةࣱۖ فَإِذَاۤ أُنزِلَتۡ سُورَةࣱ مُّحۡكَمَةࣱ وَذُكِرَ فِیهَا ٱلۡقِتَالُ رَأَیۡتَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ یَنظُرُونَ إِلَیۡكَ نَظَرَ ٱلۡمَغۡشِیِّ عَلَیۡهِ مِنَ ٱلۡمَوۡتِۖ﴾</q> - تفسير ٧٠٩٠٥- قال مقاتل بن سليمان: <q>﴿ويَقُولُ الَّذِينَ آمَنُوا﴾</q> يعني: صدّقوا بالقرآن: <q>﴿لَوْلا نُزِّلَتْ سُورَةٌ﴾</q> وذلك أنّ المؤمنين اشتاقوا إلى الوحي، فقالوا: هلّا نزلتْ سورة! <q>﴿فَإذا أُنْزِلَتْ سُورَةٌ مُحْكَمَةٌ﴾</q> يعني بالمُحكمة: ما فيها من الحلال والحرام، <q>﴿وذُكِرَ فِيها القِتالُ﴾</q> وطاعة الله، والنبي ﷺ، وقول معروف حَسن؛ فرح بها المؤمنون، فيها تقديم، ثم ذكر المنافقين، فذلك قوله: <q>﴿رَأَيْتَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</q> يعني: الشكّ في القرآن، منهم عبد الله بن أُبَيّ، ورفاعة بن زيد، والحارث بن عمرو <q>﴿يَنْظُرُونَ إلَيْكَ نَظَرَ المَغْشِيِّ عَلَيْهِ مِنَ المَوْتِ﴾</q> غمًّا وكراهية لنزول القرآن{1}. (ز) ٧٠٩٠٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ويَقُولُ الَّذِينَ آمَنُوا﴾</q> الآية، قال: كان المؤمنون يشتاقون إلى كتاب الله تعالى، وإلى بيان ما ينزل عليهم فيه، فإذا أُنزلت السورة يُذكر فيها القتال رأيتَ -يا محمد- المنافقين <q>﴿يَنْظُرُونَ إلَيْكَ نَظَرَ المَغْشِيِّ عَلَيْهِ مِنَ المَوْتِ﴾</q>{2}. (١٣/٤٣٤) ٧٠٩٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يَنْظُرُونَ إلَيْكَ نَظَرَ المَغْشِيِّ عَلَيْهِ مِنَ المَوْتِ﴾</q>، قال: هؤلاء المنافقون طبع الله على قلوبهم، فلا يفقهون ما يقول النبي ﷺ{3}٦٠٢١. (ز) ٦٠٢١ لم يذكر ابنُ جرير (٢١/٢١٠) غير قول ابن زيد. <q>﴿فَأَوۡلَىٰ لَهُمۡ ۝٢٠﴾</q> - تفسير ٧٠٩٠٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَأَوْلى لَهُمْ﴾</q> قال: هذه وعيد، ثم انقطع الكلام، فقال: <q>﴿طاعَةٌ وقَوْلٌ مَعْرُوفٌ﴾</q>{4}. (١٣/٤٣٤) ٧٠٩٠٩- قال مقاتل بن سليمان: <q>﴿فَأَوْلى لَهُمْ﴾</q> فهذا وعيد{1}. (ز) ٧٠٩١٠- عن عبد الملك ابن جُرَيْج، <q>﴿فَأَوْلى لَهُمْ﴾</q>، قال: وعيد مِن الله لهم{2}. (١٣/٤٣٤) <q>﴿فَأَوۡلَىٰ لَهُمۡ ۝٢٠﴾</q> - آثار متعلقة بالآية ٧٠٩١١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ويَقُولُ الَّذِينَ آمَنُوا لَوْلا نُزِّلَتْ سُورَةٌ فَإذا أُنْزِلَتْ سُورَةٌ مُحْكَمَةٌ﴾</q> الآية، قال: كلّ سورة ذُكر فيها الجهاد فهي محكمة، وهي أشدّ القرآن على المنافقين{7}٦٠٢٢. (١٣/٤٣٤) ٦٠٢٢ قال ابنُ جرير (٢١/٢١٠): «وقوله: <q>﴿وذكر فيها القتال﴾</q> يقول: وذُكر فيها الأمر بقتال المشركين». ثم ذكر قول قتادة، ولم يعلق عليه. وعلّق ابنُ عطية (٧/٦٥١) على قول قتادة، فقال: «وهذا أمر استقرأه قتادة مِن القرآن، وليس من تفسير هذه الآية في شيء». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢١٠.أخرجه عبد الرزاق ٢/٢٢٣-٢٢٤، وابن جرير ٢١/٢١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢١٠، وعبد الرزاق ٢/٢٢٣ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.
47,21," <q>﴿طَاعَةࣱ وَقَوۡلࣱ مَّعۡرُوفࣱۚ﴾</q> - تفسير ٧٠٩١٢- عن عبد الله بن عباس أنّه قال: قال الله تعالى: <q>﴿فَأَوْلى لَهُمْ﴾</q>، ثم قال للذين آمنوا منهم: <q>﴿طاعَةٌ وقَوْلٌ مَعْرُوفٌ﴾</q>{1}٦٠٢٣. (ز) ٦٠٢٣ علّق ابنُ جرير (٢١/٢١٢) على قول ابن عباس، فقال: «فعلى هذا القول تمام الوعيد فأولى، ثم يستأنف بعد، فيقال: <q>﴿لهم طاعة وقول معروف﴾</q> فتكون الطاعة مرفوعة بقوله: <q>﴿لهم﴾</q>». وبيّن أن إسناده «غير مرتضى». ٧٠٩١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿طاعَةٌ وقَوْلٌ مَعْرُوفٌ﴾</q>، قال: أمر الله بذلك المنافقين{2}. (١٣/٤٣٥) <q>﴿فَإِذَا عَزَمَ ٱلۡأَمۡرُ﴾</q> - تفسير ٧٠٩١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَإذا عَزَمَ الأَمْرُ﴾</q>، قال: جدَّ الأمر{3}. (١٣/٤٣٥) ٧٠٩١٥- قال مقاتل بن سليمان: <q>﴿فَإذا عَزَمَ الأَمْرُ﴾</q>، يعني: جدَّ الأمر عند دقائق الأمور{4}. (ز) <q>﴿فَلَوۡ صَدَقُوا۟ ٱللَّهَ لَكَانَ خَیۡرࣰا لَّهُمۡ ۝٢١﴾</q> - تفسير ٧٠٩١٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَإذا عَزَمَ الأَمْرُ فَلَوْ صَدَقُوا اللَّهَ لَكانَ خَيْرًا لَهُمْ﴾</q>، يقول: طاعة الله ورسوله وقول بالمعروف عند حقائق الأمور خير لهم{5}٦٠٢٤. (١٣/٤٣٤) ٦٠٢٤ ذكر ابنُ عطية (٧/٦٥٢) قول قتادة، ثم علّق عليه قائلًا: «فـ<q>﴿طاعة﴾</q> على هذا القول: ابتداء، وخبره: لهم. والمعنى: أن ذلك منهم على جهة الخديعة، فإذا عزم الأمر ناقضوا وتعاصوا». ٧٠٩١٧- قال مقاتل بن سليمان: <q>﴿فَلَوْ صَدَقُوا اللَّهَ﴾</q> في النبي ﷺ وما جاء به <q>﴿لَكانَ خَيْرًا لَهُمْ﴾</q> مِن الشرك{4}٦٠٢٥. (ز) ٦٠٢٥ ذكر ابنُ عطية (٧/٦٥٢) في قوله: <q>﴿صدقوا﴾</q> احتمالين، فقال: «وقوله: <q>﴿صدقوا الله﴾</q> يحتمل أن يكون من الصدق الذي هو ضد الكذب. ويحتمل أن يكون من قولك: عود صدق». ثم علّق بقوله: «والمعنى متقارب». ",footnotes:1:أخرجه ابن جرير ٢١/٢١١.تفسير مجاهد ص٦٠٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٢-، وابن جرير ٢١/٢١٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٠٥، وأخرجه ابن جرير ٢١/٢١٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٨.أخرجه عبد الرزاق ٢/٢٢٣-٢٢٤، وابن جرير ٢١/٢١١، كما أخرجه من طريق سعيد ٢١/٢١١، ٢١٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨.
47,22," <q>﴿فَهَلۡ عَسَیۡتُمۡ إِن تَوَلَّیۡتُمۡ أَن تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ وَتُقَطِّعُوۤا۟ أَرۡحَامَكُمۡ ۝٢٢﴾</q> - قراءات ٧٠٩١٨- عن عبد الله بن مُغَفّل، قال: سمعتُ النبيَّ يقرأ: ‹فَهَلْ عَسَيْتُمْ إن تُوُلِّيتُمْ›{1}٦٠٢٦. (١٣/٤٣٥) ٦٠٢٦ وجّه ابنُ عطية (٧/٦٥٣) هذه القراءة، فقال: «قرأ علي بن أبي طالب: ‹إن تُوُلِّيتُمْ› بضم التاء والواو وكسر اللام المشددة على معنى: إن وليتكم ولاية الجَوْر فمِلتم إلى دنياهم دون إمام العدل. أو على معنى: إن توليتم بالتعذيب والتنكيل وأفعال العرب في جاهليتها وسيرتها من الغارات والسباء، فإنما كانت ثمرتها الإفساد في الأرض وقطيعة الرحم. وقيل معناها: إنْ تولاكم الناس ووكلكم الله إليهم». وذكر ابنُ عطية أن جمهور القراء قرؤوا ذلك: <q>﴿إن تَولَيتم﴾</q>، ثم علّق عليها، فقال: «والمعنى: إن أعرضتم عن الإسلام. وقال كعب الأحبار ومحمد بن كعب القرظي: المعنى: إن توليتم أمور الناس من الولاية. وعلى هذا قيل: إنها نزلت في بني هاشم وبني أمية. ذكره الثعلبي». <q>﴿فَهَلۡ عَسَیۡتُمۡ إِن تَوَلَّیۡتُمۡ أَن تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ وَتُقَطِّعُوۤا۟ أَرۡحَامَكُمۡ ۝٢٢﴾</q> - تفسير الآية، ونزولها ٧٠٩١٩- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ الله خلَق الخلْق، حتى إذا فرغ منهم قامت الرّحِم فأخذت بِحَقْوِ الرحمن، فقال: مَه. فقالت: هذا مقام العائذ بك مِن القطيعة. قال: نعم، أما ترضي أنْ أصِلَ مَن وصلك، وأقطع مَن قطعك؟ قالت: بلى. قال: فذاك لك». ثم قال رسول الله ﷺ: «اقرؤا إنْ شئتم: <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ أُولَئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ وأَعْمى أبْصارَهُمْ أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</q>»{2}. (١٣/٤٣٦) ٧٠٩٢٠- عن عبد الله بن مُغَفّل، قال: سمعتُ النبي ﷺ يقرأ: ‹فَهَلْ عَسَيْتُمْ إن تُوُلِّيتُمْ أن تُفْسِدُوا فِي الأَرْضِ›. ثم قال: «هم هذا الحي مِن قريش، أخذ الله عليهم إن ولوا الناس ألا يُفسدوا في الأرض، ولا يُقطّعوا أرحامهم»{3}. (ز) ٧٠٩٢١- عن بُريدة، قال: كنت جالسًا عند عمر إذ سمع صائحًا، فقال: يا يَرْفَأُ، انظر ما هذا الصوت. فنظر، ثم جاء فقال: جارية مِن قريش تُباع أُمُّها. فقال عمر: ادعُ لي المهاجرين والأنصار. فلم يمكث إلا ساعة حتى امتلأت الدار والحجرة، فحمد الله، وأثنى عليه، ثم قال: أما بعد، فهل تعلمونه كان فيما جاء به محمد ﷺ القطيعة؟ قالوا: لا. قال: فإنها قد أصبحت فيكم فاشية. ثم قرأ: <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ﴾</q>. ثم قال: وأي قطيعة أقطع من أن تُباع أمّ امرئ فيكم، وقد أوسع الله لكم؟ قالوا: فاصنع ما بدا لك. فكتب في الآفاق ألا تُباع أمّ حر؛ فإنها قطيعة رحم، وأنه لا يحل{4}. (١٣/٤٣٦) ٧٠٩٢٢- عن عبد الله بن عباس، عن النبيّ ﷺ، قال: «لا يدخل الجنة مُدْمن الخمر، ولا العاقّ، ولا المنّان». قال ابن عباس: شقّ ذلك عَلَيَّ؛ لأن المؤمنين يُصيبون ذنوبًا، حتى وجدتُ ذلك في كتاب الله في العاقّ: <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ﴾</q>، وقال: <q>﴿لا تُبْطِلُوا صَدَقاتِكُمْ بِالمَنِّ والأَذى﴾</q> [البقرة:٢٦٤]، وقال: <q>﴿إنَّما الخَمْرُ والمَيْسِرُ﴾</q> الآية [المائدة:٩٠]{5}. (١٣/٤٤٥) ٧٠٩٢٣- عن بكر بن عبد الله المُزَني، في قوله: <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ﴾</q> الآية، قال: ما أُراها نزلت إلا في الحَرُورِيَّةِ{6}. (١٣/٤٣٥) ٧٠٩٢٤- عن محمد بن كعب القُرَظيّ، <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ﴾</q>، قال: إن توليتم أمر الناس{7}. (١٣/٤٣٥) ٧٠٩٢٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ﴾</q>، قال: فعلوا{8}. (ز) ٧٠٩٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ﴾</q> الآية، قال: كيف رأيتم القوم حين توَلّوا عن كتاب الله؟ ألم يسفكوا الدم الحرام، وقطَّعوا الأرحام، وعصوا الرحمن؟{9}. (١٣/٤٣٥) ٧٠٩٢٧- قال مقاتل بن سليمان: <q>﴿فَهَلْ عَسَيْتُمْ﴾</q> يعني: منافقي اليهود <q>﴿إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ﴾</q> بالمعاصي، <q>﴿وتُقَطِّعُوا أرْحامَكُمْ﴾</q> قال: وكان بينهم وبين الأنصار قرابة{10}. (ز) ٧٠٩٢٨- قال المسيب بن شريك: يقول: فهل عسيتم إن توليتم إن وُلِّيتم أمر الناس أن تفسدوا في الأرض بالظلم، نزلت في بني أمية، وفي بني هاشم{11}. (ز) <q>﴿فَهَلۡ عَسَیۡتُمۡ إِن تَوَلَّیۡتُمۡ أَن تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ وَتُقَطِّعُوۤا۟ أَرۡحَامَكُمۡ ۝٢٢﴾</q> - آثار متعلقة بالآية{12} ٧٠٩٢٩- عن عائشة، أنّ رسول الله ﷺ قال: «الرَّحم شُجْنَةٌ مِن الله؛ فمَن وصَلها وصَله الله، ومن قَطَعها قطعه الله»{13}. (١٣/٤٤٠) ٧٠٩٣٠- عن عبد الله بن سلام، قال: قال رسول الله ﷺ: «أفشوا السلام، وأطعِموا الطعام، وصِلُوا الأرحام، وصلُّوا بالليل والناس نيام؛ تدخلوا الجنة بسلام»{14}. (١٣/٤٤٢) ٧٠٩٣١- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ أعمال بني آدم تُعْرَضُ عشِيَّةَ كل خميس ليلة الجمعة، فلا يُقْبَلُ عمل قاطع رحم»{15}. (١٣/٤٣٩) ",footnotes:1:أخرجه الحاكم ٢/٢٧٩ (٣٠٠٦)، بسنده من طريق نفيع أبي داود، عن عبد الله بن مغفل به. إسناده تالف؛ فيه نفيع بن الحارث، هو أبو داود الأعمى، قال ابن حجر في التقريب (٧١٨١): «متروك، وقد كذّبه ابن معين». والقراءة متواترة، قرأ بها رُويس، وقرأ بقية العشرة: <q>﴿إن تَوَلَّيْتُمْ﴾</q> بفتح التاء والواو واللام. انظر: النشر ٢/٣٧٤، والإتحاف ص٥٠٧.أخرجه البخاري ٦/١٣٤(٤٨٣٠-٤٨٣٢)، ٨/٥ (٥٩٨٧)، ٩/١٤٥ (٧٥٠٢)، ومسلم ٤/١٩٨٠ (٢٥٥٤)، وابن جرير ٢١/٢١٤.أخرجه الثعلبي ٩/٣٥، من طريق القاسم بن يونس الهلالي، عن سعيد بن الحكم الورّاق، عن أبي داود، عن عبد الله بن مغفل به. وعزاه ابن حجر في الفتح ٨/٥٨١ إلى الطبري في تهذيبه. إسناده تالف؛ فيه أبو داود الأعمى وهو نفيع بن الحارث، قال عنه ابن حجر في التقريب (٧١٨١): «متروك، وقد كذّبه ابن معين».أخرجه الحاكم ٢/٤٥٨. وعزاه السيوطي إلى ابن المنذر.أخرجه الطبراني في الكبير ١١/٩٩ (١١١٧٠)، والخرائطي في مساوئ الأخلاق ص١١٦-١١٧ (٢٣٤)، ص٣١٩ (٦٧١). قال الهيثمي في المجمع ٥/٧٤ (٨٢١١): «رواه الطبراني، ورجاله ثقات، إلا أن عتاب بن بشير لم أعرف له مِن مجاهد سماعًا».عزاه السيوطي إلى عبد بن حميد. وينظر: تقسير القرطبي ١٦/٢٤٥.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٢٤، وابن جرير ٢١/٢١٤.أخرجه ابن جرير ٢١/٢١٣-٢١٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٨-٤٩.تفسير الثعلبي ٩/٣٥، وتفسير البغوي ٧/٢٨٧.⟨أورد السيوطي عند تفسير هذه الآية ١٣/٤٣٨– ٤٤٤ آثارًا كثيرة عن وجوب صلة الرحم، والوعيد الشديد لقاطعها.⟩{ع}أخرجه البخاري ٨/٦ (٥٩٨٩) واللفظ له، ومسلم ٤/١٩٨١ (٢٥٥٥).أخرجه أحمد ٣٩/٢٠١ (٢٣٧٨٤)، والترمذي ٤/٤٦٩ (٢٦٥٣)، وابن ماجه ٢/٣٦٠ (١٣٣٤)، ٤/٣٩٧ (٣٢٥١)، والحاكم ٣/١٤ (٤٢٨٣)، ٤/١٧٦ (٧٢٧٧). قال الترمذي: «هذا حديث صحيح». وقال الطبراني في الأوسط ٥/٣١٣ (٥٤١٠): «لم يروِ هذا الحديث عن عاصم إلا عمرو بن عبد الغفار، ولا رواه عن أبي العالية إلا عاصم، والمشهور من حديث عوف الأعرابي، عن زرارة بن أوفى، عن عبد الله بن سلام». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال البغوي في شرح السنة ٤/٤٠ (٩٢٦): «هذا حديث صحيح». وقال ابن عساكر في معجمه ٢/١٠٤٠ (١٣٣٩): «حديث حسن». وقال الألباني في الإرواء ٣/٢٣٧ (٧٧٧): «صحيح متواتر».أخرجه أحمد ١٦/١٩١ (١٠٢٧٢). قال المنذري في الترغيب ٣/٢٣٣ (٣٨٢٤): «رواته ثقات». وقال الهيثمي في المجمع ٨/١٥١ (١٣٤٥٠): «رجاله ثقات». وقال الهيتمي في الزواجر ٢/١٢٤: «رواته ثقات». وقال المناوي في التيسير ١/٣١٢: «رجاله ثقات». وقال السيوطي في نور اللمعة ص١١٠ (١٩٧): «بسند جيد». وقال الألباني في الإرواء ٤/١٠٥: «وإسناده ضعيف».
47,23," <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ لَعَنَهُمُ ٱللَّهُ فَأَصَمَّهُمۡ وَأَعۡمَىٰۤ أَبۡصَـٰرَهُمۡ ۝٢٣﴾</q> - تفسير ٧٠٩٣٢- قال مقاتل بن سليمان: <q>﴿أُولئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ﴾</q> فلم يسمعوا الهدى، <q>﴿وأَعْمى أبْصارَهُمْ﴾</q> فلم يُبصِرُوا الهُدى{1}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ لَعَنَهُمُ ٱللَّهُ فَأَصَمَّهُمۡ وَأَعۡمَىٰۤ أَبۡصَـٰرَهُمۡ ۝٢٣﴾</q> - آثار متعلقة بالآية ٧٠٩٣٣- عن سلمان، قال: قال رسول الله ﷺ: «إذا ظهر القولُ، وخُزن العملُ، وأَتْلفَت الألسنُ، واختلفت القلوب، وقَطع كلّ ذي رَحِم رَحِمه؛ فعند ذلك لعنهم الله فأصمّهم وأعمى أبصارهم»{2}. (١٣/٤٤٥) ٧٠٩٣٤- عن الحسن، قال: قال رسول الله ﷺ: «إذا الناس أظهروا العلم، وضيّعوا العمل، وتحابّوا بالألسن، وتباغضوا بالقلوب، وتقاطعوا في الأرحام؛ لعنهم الله عند ذلك فأصمّهم وأعمى أبصارهم»{3}. (١٣/٤٤٦) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩.أخرجه أحمد في الزهد ص١٢٧ (٨٣٦)، والطبراني في الكبير ٦/٢٦٣ (٦١٧٠). قال الطبراني في الأوسط ٢/١٦١(١٥٧٨): «لا يُروى هذان الحديثان عن سلمان إلا بهذا الإسناد، تفرّد بهما محمد بن عمار». وقال الهيثمي في المجمع ٧/٢٨٧ (١٢٢٤١): «وفيه جماعة لم أعرفهم». وقال الألباني في الضعيفة ١٢/١١٤ (٥٥٥٩): «ضعيف».عزاه السيوطي إلى ابن أبي الدنيا في العلم مرسلًا.
47,24," <q>﴿أَفَلَا یَتَدَبَّرُونَ ٱلۡقُرۡءَانَ أَمۡ عَلَىٰ قُلُوبٍ أَقۡفَالُهَاۤ ۝٢٤﴾</q> - تفسير ٧٠٩٣٥- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «يأتي على الناس زمانٌ يَخلَقُ القرآن في قلوبهم، يتهافتون تهافتًا». قيل: يا رسول الله، وما تهافتُهم؟ قال: «يقرأ أحدهم فلا يجد حلاوةً ولا لذةً؛ يبدأ أحدهم بالسورة، وإنما بُغْيَتُه آخرها، فإنْ عملوا قالوا: ربنا، اغفِر لنا. وإن تركوا الفرائض قالوا: لا يُعَذِّبُنا الله، ونحن لا نشرك به شيئًا. أمْرهم رجاء، ولا خوف فيهم، <q>﴿أُولَئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ وأَعْمى أبْصارَهُمْ أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</q>»{1}. (١٣/٤٤٧) ٧٠٩٣٦- عن سهل بن سعد، قال: قرأ رسول الله ﷺ: <q>﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</q>. فقال شابٌّ عند النبي ﷺ: بل -واللهِ- عليها أقفالُها، حتى يكون الله هو الذي يَفُكُّها. فلما وُلِّيَ عمر سأل عن ذلك الشابّ ليستعمله، فقيل: قد مات{2}. (١٣/٤٤٦) ٧٠٩٣٧- عن هشام بن عروة، عن أبيه، قال: تلا رسول الله ﷺ يومًا: <q>﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</q>. فقال شابٌّ مِن أهل اليمن: بل عليها أقفالها، حتى يكون الله يفتحها أو يَفْرِجها. فقال النبيُّ ﷺ: «صدقت». فما زال الشابُّ في نفس عمر حتى وُلِّيَ فاستعان به{3}. (١٣/٤٤٦) ٧٠٩٣٨- عن خالد بن معدان -من طريق ثور بن يزيد- قال: ما مِن آدميٍّ إلا وله أربع أعين: عينان في رأسه لدنياه وما يصلحه مِن معيشته، وعينان في قلبه لدينه وما وعد الله من الغيب، فإذا أراد الله بعبد خيرًا أبصرت عيناه اللتان في قلبه، وإذا أراد الله به غير ذلك طمس عليهما، فذلك قوله: <q>﴿أم على قلوب أقفالها﴾</q>{4}. (١٣/٤٤٧) ٧٠٩٣٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ﴾</q>، قال: إذن -واللهِ- في القرآن زاجرٌ عن معصية الله. قال: لم يتدبّره القوم ويعقلوه، ولكنهم أخذوا بمُتَشابِهِه فهلَكوا عند ذلك{5}. (١٣/٤٤٧) ٧٠٩٤٠- قال مقاتل بن سليمان: <q>﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ﴾</q> يقول: أفلا يسمعون القرآن، <q>﴿أمْ عَلى قُلُوبٍ أقْفالُها﴾</q> يعني: الطّبع على القلوب{6}٦٠٢٧. (ز) ٦٠٢٧ ذكر ابنُ القيم (٢/٤٥٤) قول مقاتل أنه فسر قوله: <q>﴿أم على قلوب أقفالها﴾</q> بالطبع. ثم وجّهه بقوله: «وكأنّ القلب بمنزلة الباب المرتج الذي قد ضُرب عليه قفل، فإنه ما لم يُفتح القفل لا يمكن فتح الباب والوصول إلى ما وراءه، وكذلك ما لم يُرفع الختم والقفل عن القلب لم يدخل الإيمان والقرآن». <q>﴿أَفَلَا یَتَدَبَّرُونَ ٱلۡقُرۡءَانَ أَمۡ عَلَىٰ قُلُوبٍ أَقۡفَالُهَاۤ ۝٢٤﴾</q> - آثار متعلقة بالآية ٧٠٩٤١- عن خالد بن معدان، قال: ما مِن عبدٍ إلا له أربع أعين: عينان في وجهه يُبصر بهما دنياه وما يُصلحه من معيشته، وعينان في قلبه يُبصِر بهما دينه وما وعد الله بالغيب، وإذا أراد الله بعبد خيرًا فتح عينيه اللَّذين في قلبه فأبصر بهما ما وُعِد بالغيب، وإذا أراد الله به سوءًا ترك القلب على ما فيه. وقرأ: <q>﴿أمْ عَلى قُلُوبٍ أقْفالُها﴾</q>، وما من عبد إلا وله شيطان مُتبطّنٌ فَقار ظهره، لاوٍ عنقه على عنقه، فاغرٌ فاه على قلبه{7}. (١٣/٤٤٧) ٧٠٩٤٢- عن خالد بن معدان، عن معاذ بن جبل مثله مرفوعًا إلى قوله: وقرأ <q>﴿أمْ عَلى قُلُوبٍ أقْفالُها﴾</q>{8}. (١٣/٤٤٧) ",footnotes:1:أورده الديلمي في مسند الفردوس ٥/٤٤٨-٤٤٩ (٨٧٠١).عزاه السيوطي إلى الدارقطني في الأفراد، وابن مردويه.أخرجه إسحاق بن راهويه -كما في المطالب العالية (٤١٠٤)-، وابن جرير ٢١/٢١٧. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٢١/٢١٦ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢١٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر. وأخرجه ابن جرير ٢١/٢١٦ بنحوه من طريق ثور بن يزيد.أخرجه الديلمي في مسند الفردوس ٤/١٤ (٦٠٤٠). قال العراقي في تخريج الإحياء ص٩٢٣: «وفيه الحسين بن أحمد بن محمد الهروي السماخي الحافظ، كذّبه الحاكم، والآفة منه».
47,25," <q>﴿إِنَّ ٱلَّذِینَ ٱرۡتَدُّوا۟ عَلَىٰۤ أَدۡبَـٰرِهِم مِّنۢ بَعۡدِ مَا تَبَیَّنَ لَهُمُ ٱلۡهُدَى﴾</q> - نزول الآية، وتفسيرها ٧٠٩٤٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ﴾</q> إلى: <q>﴿إسْرارَهُمْ﴾</q>: هم أهل النِّفاق{1}. (١٣/٤٤٩) ٧٠٩٤٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ﴾</q> إلى قوله: <q>﴿فَأَحْبَطَ أعْمالَهُمْ﴾</q>، قال: هم أهل النِّفاق{1}. (ز) ٧٠٩٤٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ مِن بَعْدِ ما تَبَيَّنَ لَهُمُ الهُدى﴾</q>، قال: هم أعداء الله أهل الكتاب يعرفون نَعْت محمد ﷺ وأصحابه عندهم، ويجدونه مكتوبًا في التوراة والإنجيل، ثم يكفرون به{3}. (١٣/٤٤٨) ٧٠٩٤٦- قال إسماعيل السُّدّيّ: هم المنافقون{4}. (ز) ٧٠٩٤٧- قال مقاتل بن سليمان: ثم ذكر اليهود، فقال: <q>﴿إنَّ الَّذِينَ ارْتَدُّوا﴾</q> عن إيمانٍ بمحمد ﷺ بعد المعرفة <q>﴿عَلى أدْبارِهِمْ﴾</q> يعني: أعقابهم كفارًا، <q>﴿مِن بَعْدِ ما تَبَيَّنَ لَهُمُ الهُدى﴾</q> يعني: أمر النبي ﷺ يبيّن لهم في التوراة أنّه نبيٌّ رسول{5}. (ز) ٧٠٩٤٨- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ مِن بَعْدِ ما تَبَيَّنَ لَهُمُ الهُدى﴾</q>، قال: اليهود ارتدّوا عن الهُدى بعد أن عَرفوا أنّ محمدًا ﷺ نبي{6}٦٠٢٨. (١٣/٤٤٨) ٦٠٢٨ ذكر ابنُ عطية (٧/٦٥٤) قول من قال: إن هذه الآية نزلت في جماعة من اليهود. وقول من قال: نزلت في جماعة من المنافقين. ثم علّق بقوله: «والآية تعم كل مَن دخل في ضمن لفظها غابر الدهر». <q>﴿ٱلشَّیۡطَـٰنُ سَوَّلَ لَهُمۡ وَأَمۡلَىٰ لَهُمۡ ۝٢٥﴾</q> - قراءات ٧٠٩٤٩- عن هارون، عن الأعرج: ‹وأُمْلِي لَهُمْ› مثل: أُملي لهم، يقول الله: <q>﴿وأملي لهم إن كيدي متين﴾</q> [الأعراف:١٨٣، والقلم:٤٥]{7}. (ز) <q>﴿ٱلشَّیۡطَـٰنُ سَوَّلَ لَهُمۡ وَأَمۡلَىٰ لَهُمۡ ۝٢٥﴾</q> - تفسير الآية ٧٠٩٥٠- قال الحسن البصري: <q>﴿وأَمْلى لَهُمْ﴾</q>، يعني: وسْوَس{8}. (ز) ٧٠٩٥١- عن الحسن البصري -من طريق الربيع بن عبد الله بن خُطّاف- <q>﴿الشَّيْطانُ سَوَّلَ لَهُمْ وأَمْلى لَهُمْ﴾</q>، قال: زيّن لهم الخطايا، ومدَّ لهم في الأمل{9}. (ز) ٧٠٩٥٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿الشَّيْطانُ سَوَّلَ لَهُمْ﴾</q>، قال: زيّن لهم{10}٦٠٢٩. (١٣/٤٤٨) ٦٠٢٩ لم يذكر ابنُ جرير (٢١/٢١٨) غير قول قتادة. ٧٠٩٥٣- قال مقاتل بن سليمان: <q>﴿الشَّيْطانُ سَوَّلَ لَهُمْ﴾</q> يعني: زيّن لهم ترْك الهدى، يعني: إيمانًا بمحمد ﷺ، <q>﴿وأَمْلى﴾</q> الله <q>﴿لَهُمُ﴾</q> فيها تقديم، وأمهل الله لهم حين قالوا: ليس محمدٌ بنبي! فلم يعجل عليهم، ثم انتقم منهم حين قتل أهل قُريظة، وأجلى أهل النضير{5}. (ز) ٧٠٩٥٤- عن عبد الملك ابن جريج، في قوله: <q>﴿الشَّيْطانُ سَوَّلَ لَهُمْ وأَمْلى لَهُمْ﴾</q>، قال: أملى الله لهم{6}٦٠٣٠. (١٣/٤٤٨) ٦٠٣٠ في فاعل <q>﴿أملى﴾</q> قولان: الأول: أنه الشيطان. الثاني: أنه الله. وقد ذكر ابنُ عطية (٧/٦٥٤) القولين، وعلّق على الأول قائلًا: «وذلك أنّ الإملاء: هو الإبقاء ملاوة من الدهر، يقال: ملاوة وملاوة وملاوة بضم الميم وفتحها وكسرها، وهي القطعة من الزمن، ومنه: الملوان الليل والنهار، فإذا أملى الشيطان إملاء ما فلا صحة له إلا بطمعهم الكاذب». وعلّق على الثاني، فقال: «ويحتمل أن يكون الفاعل في»أملى«الله ﷿، كأنه قال: الشيطان سول لهم وأملى الله لهم». ثم رجّح -مستندًا إلى حقيقة اللفظ- الثاني بقوله: «وحقيقة الإملاء إنما هو بيد الله ﷿، وهذا هو الأرجح». ",footnotes:1:أخرجه ابن جرير ٢١/٢١٨.أخرجه ابن جرير ٢١/٢١٨.أخرجه عبد الرزاق في تفسيره ٢/٢٢٤، وفي المصنف (١٠٢١٢)، وابن جرير ٢١/٢١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٣٧، وتفسير البغوي ٧/٢٨٨.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي ص٣٦٢. وهي قراءة متواترة قرأ بها يعقوب، وقرأ أبو عمرو: ‹وأُمْلِيَ› بضم الهمز وفتح الياء، وقرأ الباقون: <q>﴿وأَمْلى لَهُمْ﴾</q>. ينظر: النشر: ٢/٢٨٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٤٣-.أخرجه ابن أبي الدنيا في قصر الأمل ٣/٣٤١ (١٦٣).أخرجه عبد الرزاق في تفسيره ٢/٢٢٤، وفي المصنف (١٠٢١٢)، وابن جرير ٢١/٢١٨ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.
47,26," <q>﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ قَالُوا۟ لِلَّذِینَ كَرِهُوا۟ مَا نَزَّلَ ٱللَّهُ سَنُطِیعُكُمۡ فِی بَعۡضِ ٱلۡأَمۡرِۖ وَٱللَّهُ یَعۡلَمُ إِسۡرَارَهُمۡ ۝٢٦﴾</q> - تفسير ٧٠٩٥٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ذَلِكَ بِأَنَّهُمْ قالُوا لِلَّذِينَ كَرِهُوا ما نَزَّلَ اللَّهُ﴾</q>، قال: هم المنافقون{1}. (١٣/٤٤٨) ٧٠٩٥٦- قال مقاتل بن سليمان: يقول: <q>﴿ذلك﴾</q> الذي أصابهم مِن القتْل والجلاء <q>﴿بِأَنَّهُمْ قالُوا لِلَّذِينَ كَرِهُوا﴾</q> يعني: تركوا الإيمان، يعني: المنافقين <q>﴿ما نَزَّلَ اللَّهُ﴾</q> مِن القرآن <q>﴿سَنُطِيعُكُمْ فِي بَعْضِ الأَمْرِ﴾</q> قالت اليهود للمنافقين في تكذيب بمحمد ﷺ، وهو بعض الأمر، قالوا ذلك سِرًّا فيما بينهم، فذلك قوله: <q>﴿واللَّهُ يَعْلَمُ إسْرارَهُمْ﴾</q> يعني: اليهود والمنافقين{2}. (ز) ٧٠٩٥٧- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ذَلِكَ بِأَنَّهُمْ قالُوا لِلَّذِينَ كَرِهُوا ما نَزَّلَ اللَّهُ﴾</q> قال: يهود تقول للمنافقين مِن أصحاب النبيّ ﷺ، وكانوا يُسِرُّون إليهم: إنّا <q>﴿سَنُطِيعُكُمْ فِي بَعْضِ الأَمْرِ﴾</q>. وكان بعض الأمر أنهم يعلمون أنّ محمدًا نبي، وقالوا: اليهودية الدّين. فكان المنافقون يُطيعون اليهود بما أمرتهم، <q>﴿واللَّهُ يَعْلَمُ إسْرارَهُمْ﴾</q> قال: ذلك سِرّ القول{3}. (١٣/٤٤٨) ",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٢٢٤، وفي المصنف (١٠٢١٢)، وابن جرير ٢١/٢٢٠ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.
47,27," <q>﴿فَكَیۡفَ إِذَا تَوَفَّتۡهُمُ ٱلۡمَلَـٰۤىِٕكَةُ یَضۡرِبُونَ وُجُوهَهُمۡ وَأَدۡبَـٰرَهُمۡ ۝٢٧﴾</q> - تفسير ٧٠٩٥٨- عن مجاهد بن جبر، في قوله: <q>﴿يَضْرِبُونَ وُجُوهَهُمْ وأَدْبارَهُمْ﴾</q>، قال: يضربون وجوههم وأستاههم، ولكنّ الله كريم يَكْنِي{1}. (١٣/٤٤٩) ٧٠٩٥٩- قال الحسن البصري: <q>﴿توفتهم الملائكة﴾</q> حشَرَتهم إلى النار <q>﴿يضربون وجوههم وأدبارهم﴾</q> في النار{2}. (ز) ٧٠٩٦٠- قال مقاتل بن سليمان: ثم خوّفهم، فقال: <q>﴿فَكَيْفَ إذا تَوَفَّتْهُمُ المَلائِكَةُ﴾</q> يعني: مَلك الموت وحده <q>﴿يَضْرِبُونَ وُجُوهَهُمْ وأَدْبارَهُمْ﴾</q> عند الموت{3}. (ز) ٧٠٩٦١- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿فَكَيْفَ إذا تَوَفَّتْهُمُ المَلائِكَةُ يَضْرِبُونَ وُجُوهَهُمْ وأَدْبارَهُمْ﴾</q>، قال: عند الموت{1}٦٠٣١. (١٣/٤٤٨) ٦٠٣١ ذكر ابنُ عطية (٧/٦٥٥) في الآية احتمالين، فقال: «وقوله تعالى: <q>﴿فكيف إذا توفتهم﴾</q> الآية، يحتمل أن يُتوعّدوا به على معنيين: أحدهما: هذا هلعهم وجزعهم لفرض القتال وقراع الأعداء، فكيف فزعهم وجزعهم إذا توفتهم الملائكة؟! والثاني أن يريد: هذه معاصيهم وعنادهم وكفرهم، فكيف تكون حالهم مع الله إذا توفتهم الملائكة؟! وقال الطبري: المعنى: والله يعلم إسرارهم فكيف علمه بها إذا توفتهم الملائكة». وبيّن ابنُ عطية أنّ الضمير في قوله: <q>﴿يضربون﴾</q> عائد على الملائكة، ثم ذكر قولًا آخر أنّه عائد على الكفار، وانتقده، فقال: «ومن قال: إن الضمير في: <q>﴿يضربون﴾</q> للكفار الذين يُتوفّون، فذلك ضعيف». ",footnotes:1:عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٤٤-.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.
47,28," <q>﴿ذَ ٰ⁠لِكَ بِأَنَّهُمُ ٱتَّبَعُوا۟ مَاۤ أَسۡخَطَ ٱللَّهَ وَكَرِهُوا۟ رِضۡوَ ٰ⁠نَهُۥ فَأَحۡبَطَ أَعۡمَـٰلَهُمۡ ۝٢٨﴾</q> - تفسير ٧٠٩٦٢- قال عبد الله بن عباس: <q>﴿بِأَنَّهُمُ اتَّبَعُوا ما أسْخَطَ اللَّهَ﴾</q> بما كتموا مِن التوراة، وكفروا بمحمد ﷺ{1}. (ز) ٧٠٩٦٣- قال مقاتل بن سليمان: <q>﴿ذلِكَ﴾</q> الضرب الذي أصابهم عند الموت <q>﴿بِأَنَّهُمُ اتَّبَعُوا ما أسْخَطَ اللَّهَ﴾</q> من الكفر بالنبي محمد ﷺ، <q>﴿وكَرِهُوا رِضْوانَهُ﴾</q> يقول: وتركوا رضوان الله في إيمانٍ بمحمد ﷺ؛ <q>﴿فَأَحْبَطَ أعْمالَهُمْ﴾</q> التي عملوها في غير إيمان{2}. (ز) ",footnotes:1:تفسير البغوي ٧/٢٨٨.تفسير مقاتل بن سليمان ٤/٤٩.
47,29," <q>﴿أَمۡ حَسِبَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضٌ أَن لَّن یُخۡرِجَ ٱللَّهُ أَضۡغَـٰنَهُمۡ ۝٢٩﴾</q> - تفسير ٧٠٩٦٤- عن عبد الله بن عباس، في قوله: <q>﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</q>، قال: أعمالهم؛ خُبْثَهم، والحسد الذي في قلوبهم. قال: فَدَلَّ اللهُ النبيَّ ﷺ بَعْدُ على المنافقين، فكان يدعو باسم الرجل مِن أهل النِّفاق{1}. (١٣/٤٤٩) ٧٠٩٦٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</q> إلى آخر الآية، قال: هم أهل النِّفاق، وقد عرَّفه إياهم في براءة، فقال: <q>﴿ولا تُصَلِّ عَلى أحَدٍ مِنهُمْ ماتَ أبَدًا ولا تَقُمْ عَلى قَبْرِهِ﴾</q> [التوبة:٨٤]، وقال: <q>﴿قُلْ لَنْ تَخْرُجُوا مَعِيَ أبَدًا ولَنْ تُقاتِلُوا مَعِي عَدُوًّا﴾</q> [التوبة:٨٣]{2}٦٠٣٢. (ز) ٦٠٣٢ ذكر ابنُ عطية (٧/٦٥٦) قول ابن عباس، وعلّق عليه بقوله: «وهذا في الحقيقة ليس بتعريف تام، بل هو لفظ يشير إليهم على الإجمال، لا أنه سمّى أحدًا». ٧٠٩٦٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</q> الآية: هم أهل النِّفاق <q>﴿فَلَعَرَفْتَهُمْ بِسِيماهُمْ ولَتَعْرِفَنَّهُمْ فِي لَحْنِ القَوْلِ﴾</q>، فعرّفه الله إياهم في سورة براءة، فقال: <q>﴿ولا تُصَلِّ عَلى أحَدٍ مِنهُمْ ماتَ أبَدًا﴾</q> [التوبة:٨٤]، وقال: قل لهم: لن تنفروا معي أبدًا، ولن تقاتلوا معي عدوًا{2}. (ز) ٧٠٩٦٧- قال مقاتل بن سليمان: ثم رجع إلى عبد الله بن أُبَيّ، ورفاعة بن زيد، والحارث بن عمرو، فقال: <q>﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</q> يعني: الشكّ بالقرآن، وهم المنافقون <q>﴿أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</q> يعني: أن لن يُظهر الله الغشّ الذي في قلوبهم للمؤمنين{4}. (ز) ٧٠٩٦٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</q>، قال: هؤلاء المنافقون. قال: والذي أسَرُّوا من النّفاق هو الكفر{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٣١٢- من طريق عطاء مختصرًا. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢٢٢.أخرجه ابن جرير ٢١/٢٢٢.تفسير مقاتل بن سليمان ٤/٤٩-٥٠.أخرجه ابن جرير ٢١/٢٢٢.
