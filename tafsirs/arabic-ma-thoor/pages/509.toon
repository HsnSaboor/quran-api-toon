quran[10]{c,v,t}:
  47,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُ ٱلَّذِینَ ءَامَنُوا۟ لَوۡلَا نُزِّلَتۡ سُورَةࣱۖ فَإِذَاۤ أُنزِلَتۡ سُورَةࣱ مُّحۡكَمَةࣱ وَذُكِرَ فِیهَا ٱلۡقِتَالُ رَأَیۡتَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ یَنظُرُونَ إِلَیۡكَ نَظَرَ ٱلۡمَغۡشِیِّ عَلَیۡهِ مِنَ ٱلۡمَوۡتِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُ الَّذِينَ آمَنُوا﴾</span> يعني: صدّقوا بالقرآن: <span class="qpc-hafs">﴿لَوْلا نُزِّلَتْ سُورَةٌ﴾</span> وذلك أنّ المؤمنين اشتاقوا إلى الوحي، فقالوا: هلّا نزلتْ سورة! <span class="qpc-hafs">﴿فَإذا أُنْزِلَتْ سُورَةٌ مُحْكَمَةٌ﴾</span> يعني بالمُحكمة: ما فيها من الحلال والحرام، <span class="qpc-hafs">﴿وذُكِرَ فِيها القِتالُ﴾</span> وطاعة الله، والنبي ﷺ، وقول معروف حَسن؛ فرح بها المؤمنون، فيها تقديم، ثم ذكر المنافقين، فذلك قوله: <span class="qpc-hafs">﴿رَأَيْتَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</span> يعني: الشكّ في القرآن، منهم عبد الله بن أُبَيّ، ورفاعة بن زيد، والحارث بن عمرو <span class="qpc-hafs">﴿يَنْظُرُونَ إلَيْكَ نَظَرَ المَغْشِيِّ عَلَيْهِ مِنَ المَوْتِ﴾</span> غمًّا وكراهية لنزول القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ويَقُولُ الَّذِينَ آمَنُوا﴾</span> الآية، قال: كان المؤمنون يشتاقون إلى كتاب الله تعالى، وإلى بيان ما ينزل عليهم فيه، فإذا أُنزلت السورة يُذكر فيها القتال رأيتَ -يا محمد- المنافقين <span class="qpc-hafs">﴿يَنْظُرُونَ إلَيْكَ نَظَرَ المَغْشِيِّ عَلَيْهِ مِنَ المَوْتِ﴾</span>{2}. (١٣/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَنْظُرُونَ إلَيْكَ نَظَرَ المَغْشِيِّ عَلَيْهِ مِنَ المَوْتِ﴾</span>، قال: هؤلاء المنافقون طبع الله على قلوبهم، فلا يفقهون ما يقول النبي ﷺ{3}<span class=comment-ref>٦٠٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢١</span> لم يذكر <u>ابنُ جرير</u> (٢١/٢١٠) غير قول ابن زيد.</div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡلَىٰ لَهُمۡ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَأَوْلى لَهُمْ﴾</span> قال: هذه وعيد، ثم انقطع الكلام، فقال: <span class="qpc-hafs">﴿طاعَةٌ وقَوْلٌ مَعْرُوفٌ﴾</span>{4}. (١٣/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَوْلى لَهُمْ﴾</span> فهذا وعيد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩١٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿فَأَوْلى لَهُمْ﴾</span>، قال: وعيد مِن الله لهم{2}. (١٣/٤٣٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡلَىٰ لَهُمۡ ۝٢٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٩١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ويَقُولُ الَّذِينَ آمَنُوا لَوْلا نُزِّلَتْ سُورَةٌ فَإذا أُنْزِلَتْ سُورَةٌ مُحْكَمَةٌ﴾</span> الآية، قال: كلّ سورة ذُكر فيها الجهاد فهي محكمة، وهي أشدّ القرآن على المنافقين{7}<span class=comment-ref>٦٠٢٢</span>. (١٣/٤٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٢</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/٢١٠): «وقوله: <span class="qpc-hafs">﴿وذكر فيها القتال﴾</span> يقول: وذُكر فيها الأمر بقتال المشركين». ثم ذكر قول قتادة، ولم يعلق عليه.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٧/٦٥١) على قول قتادة، فقال: «وهذا أمر استقرأه قتادة مِن القرآن، وليس من تفسير هذه الآية في شيء».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢١٠.أخرجه عبد الرزاق ٢/٢٢٣-٢٢٤، وابن جرير ٢١/٢١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢١٠، وعبد الرزاق ٢/٢٢٣ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.
  47,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿طَاعَةࣱ وَقَوۡلࣱ مَّعۡرُوفࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه قال: قال الله تعالى: <span class="qpc-hafs">﴿فَأَوْلى لَهُمْ﴾</span>، ثم قال للذين آمنوا منهم: <span class="qpc-hafs">﴿طاعَةٌ وقَوْلٌ مَعْرُوفٌ﴾</span>{1}<span class=comment-ref>٦٠٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٣</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (٢١/٢١٢) على قول ابن عباس، فقال: «فعلى هذا القول تمام الوعيد فأولى، ثم يستأنف بعد، فيقال: <span class="qpc-hafs">﴿لهم طاعة وقول معروف﴾</span> فتكون الطاعة مرفوعة بقوله: <span class="qpc-hafs">﴿لهم﴾</span>». وبيّن أن إسناده «غير مرتضى».</div></p><p><div></p><p><p><span class="item-no">٧٠٩١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿طاعَةٌ وقَوْلٌ مَعْرُوفٌ﴾</span>، قال: أمر الله بذلك المنافقين{2}. (١٣/٤٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا عَزَمَ ٱلۡأَمۡرُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَإذا عَزَمَ الأَمْرُ﴾</span>، قال: جدَّ الأمر{3}. (١٣/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا عَزَمَ الأَمْرُ﴾</span>، يعني: جدَّ الأمر عند دقائق الأمور{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَوۡ صَدَقُوا۟ ٱللَّهَ لَكَانَ خَیۡرࣰا لَّهُمۡ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَإذا عَزَمَ الأَمْرُ فَلَوْ صَدَقُوا اللَّهَ لَكانَ خَيْرًا لَهُمْ﴾</span>، يقول: طاعة الله ورسوله وقول بالمعروف عند حقائق الأمور خير لهم{5}<span class=comment-ref>٦٠٢٤</span>. (١٣/٤٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٤</span> ذكر <u>ابنُ عطية</u> (٧/٦٥٢) قول قتادة، ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «فـ<span class="qpc-hafs">﴿طاعة﴾</span> على هذا القول: ابتداء، وخبره: لهم. والمعنى: أن ذلك منهم على جهة الخديعة، فإذا عزم الأمر ناقضوا وتعاصوا».</div></p><p><div></p><p><p><span class="item-no">٧٠٩١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَوْ صَدَقُوا اللَّهَ﴾</span> في النبي ﷺ وما جاء به <span class="qpc-hafs">﴿لَكانَ خَيْرًا لَهُمْ﴾</span> مِن الشرك{4}<span class=comment-ref>٦٠٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٥</span> ذكر <u>ابنُ عطية</u> (٧/٦٥٢) في قوله: <span class="qpc-hafs">﴿صدقوا﴾</span> احتمالين، فقال: «وقوله: <span class="qpc-hafs">﴿صدقوا الله﴾</span> <b>يحتمل</b> أن يكون من الصدق الذي هو ضد الكذب. <b>ويحتمل</b> أن يكون من قولك: عود صدق». ثم <span class="comment-type-4">علّق</span> بقوله: «والمعنى متقارب».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٢١١.تفسير مجاهد ص٦٠٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٢-، وابن جرير ٢١/٢١٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٠٥، وأخرجه ابن جرير ٢١/٢١٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٨.أخرجه عبد الرزاق ٢/٢٢٣-٢٢٤، وابن جرير ٢١/٢١١، كما أخرجه من طريق سعيد ٢١/٢١١، ٢١٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨.
  47,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَهَلۡ عَسَیۡتُمۡ إِن تَوَلَّیۡتُمۡ أَن تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ وَتُقَطِّعُوۤا۟ أَرۡحَامَكُمۡ ۝٢٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠٩١٨<span class="dash">-</span></span> عن عبد الله بن مُغَفّل، قال: سمعتُ النبيَّ يقرأ: ‹فَهَلْ عَسَيْتُمْ إن تُوُلِّيتُمْ›{1}<span class=comment-ref>٦٠٢٦</span>. (١٣/٤٣٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٦</span> <span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٧/٦٥٣) هذه القراءة، فقال: «قرأ علي بن أبي طالب: ‹إن تُوُلِّيتُمْ› بضم التاء والواو وكسر اللام المشددة على معنى: إن وليتكم ولاية الجَوْر فمِلتم إلى دنياهم دون إمام العدل. أو على معنى: إن توليتم بالتعذيب والتنكيل وأفعال العرب في جاهليتها وسيرتها من الغارات والسباء، فإنما كانت ثمرتها الإفساد في الأرض وقطيعة الرحم. وقيل معناها: إنْ تولاكم الناس ووكلكم الله إليهم».</p><p>وذكر <u>ابنُ عطية</u> أن جمهور القراء قرؤوا ذلك: <span class="qpc-hafs">﴿إن تَولَيتم﴾</span>، ثم <span class="comment-type-4">علّق</span> عليها، فقال: «والمعنى: إن أعرضتم عن الإسلام. وقال كعب الأحبار ومحمد بن كعب القرظي: المعنى: إن توليتم أمور الناس من الولاية. وعلى هذا قيل: إنها نزلت في بني هاشم وبني أمية. ذكره الثعلبي».</div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ عَسَیۡتُمۡ إِن تَوَلَّیۡتُمۡ أَن تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ وَتُقَطِّعُوۤا۟ أَرۡحَامَكُمۡ ۝٢٢﴾</span> - تفسير الآية، ونزولها</h3></p><p><div></p><p><p><span class="item-no">٧٠٩١٩<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ الله خلَق الخلْق، حتى إذا فرغ منهم قامت الرّحِم فأخذت بِحَقْوِ الرحمن، فقال: مَه. فقالت: هذا مقام العائذ بك مِن القطيعة. قال: نعم، أما ترضي أنْ أصِلَ مَن وصلك، وأقطع مَن قطعك؟ قالت: بلى. قال: فذاك لك</b>». ثم قال رسول الله ﷺ: «<b>اقرؤا إنْ شئتم: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ أُولَئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ وأَعْمى أبْصارَهُمْ أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</span></b>»{2}. (١٣/٤٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٠<span class="dash">-</span></span> عن عبد الله بن مُغَفّل، قال: سمعتُ النبي ﷺ يقرأ: ‹فَهَلْ عَسَيْتُمْ إن تُوُلِّيتُمْ أن تُفْسِدُوا فِي الأَرْضِ›. ثم قال: «<b>هم هذا الحي مِن قريش، أخذ الله عليهم إن ولوا الناس ألا يُفسدوا في الأرض، ولا يُقطّعوا أرحامهم</b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢١<span class="dash">-</span></span> عن بُريدة، قال: كنت جالسًا عند عمر إذ سمع صائحًا، فقال: يا يَرْفَأُ، انظر ما هذا الصوت. فنظر، ثم جاء فقال: جارية مِن قريش تُباع أُمُّها. فقال عمر: ادعُ لي المهاجرين والأنصار. فلم يمكث إلا ساعة حتى امتلأت الدار والحجرة، فحمد الله، وأثنى عليه، ثم قال: أما بعد، فهل تعلمونه كان فيما جاء به محمد ﷺ القطيعة؟ قالوا: لا. قال: فإنها قد أصبحت فيكم فاشية. ثم قرأ: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ﴾</span>. ثم قال: وأي قطيعة أقطع من أن تُباع أمّ امرئ فيكم، وقد أوسع الله لكم؟ قالوا: فاصنع ما بدا لك. فكتب في الآفاق ألا تُباع أمّ حر؛ فإنها قطيعة رحم، وأنه لا يحل{4}. (١٣/٤٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٢<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبيّ ﷺ، قال: «<b>لا يدخل الجنة مُدْمن الخمر، ولا العاقّ، ولا المنّان</b>». قال <span class="name-1">ابن عباس</span>: شقّ ذلك عَلَيَّ؛ لأن المؤمنين يُصيبون ذنوبًا، حتى وجدتُ ذلك في كتاب الله في العاقّ: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ﴾</span>، وقال: <span class="qpc-hafs">﴿لا تُبْطِلُوا صَدَقاتِكُمْ بِالمَنِّ والأَذى﴾</span> [البقرة:٢٦٤]، وقال: <span class="qpc-hafs">﴿إنَّما الخَمْرُ والمَيْسِرُ﴾</span> الآية [المائدة:٩٠]{5}. (١٣/٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٣<span class="dash">-</span></span> عن <span class="name-2">بكر بن عبد الله المُزَني</span>، في قوله: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ﴾</span> الآية، قال: ما أُراها نزلت إلا في الحَرُورِيَّةِ{6}. (١٣/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ﴾</span>، قال: إن توليتم أمر الناس{7}. (١٣/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ وتُقَطِّعُوا أرْحامَكُمْ﴾</span>، قال: فعلوا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إنْ تَوَلَّيْتُمْ﴾</span> الآية، قال: كيف رأيتم القوم حين توَلّوا عن كتاب الله؟ ألم يسفكوا الدم الحرام، وقطَّعوا الأرحام، وعصوا الرحمن؟{9}. (١٣/٤٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ﴾</span> يعني: منافقي اليهود <span class="qpc-hafs">﴿إنْ تَوَلَّيْتُمْ أنْ تُفْسِدُوا فِي الأَرْضِ﴾</span> بالمعاصي، <span class="qpc-hafs">﴿وتُقَطِّعُوا أرْحامَكُمْ﴾</span> قال: وكان بينهم وبين الأنصار قرابة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٢٨<span class="dash">-</span></span> قال <span class="name-3">المسيب بن شريك</span>: يقول: فهل عسيتم إن توليتم إن وُلِّيتم أمر الناس أن تفسدوا في الأرض بالظلم، نزلت في بني أمية، وفي بني هاشم{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ عَسَیۡتُمۡ إِن تَوَلَّیۡتُمۡ أَن تُفۡسِدُوا۟ فِی ٱلۡأَرۡضِ وَتُقَطِّعُوۤا۟ أَرۡحَامَكُمۡ ۝٢٢﴾</span> - آثار متعلقة بالآية{12}</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٢٩<span class="dash">-</span></span> عن عائشة، أنّ رسول الله ﷺ قال: «<b>الرَّحم شُجْنَةٌ مِن الله؛ فمَن وصَلها وصَله الله، ومن قَطَعها قطعه الله</b>»{13}. (١٣/٤٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣٠<span class="dash">-</span></span> عن عبد الله بن سلام، قال: قال رسول الله ﷺ: «<b>أفشوا السلام، وأطعِموا الطعام، وصِلُوا الأرحام، وصلُّوا بالليل والناس نيام؛ تدخلوا الجنة بسلام</b>»{14}. (١٣/٤٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣١<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ أعمال بني آدم تُعْرَضُ عشِيَّةَ كل خميس ليلة الجمعة، فلا يُقْبَلُ عمل قاطع رحم</b>»{15}. (١٣/٤٣٩)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٢٧٩ (٣٠٠٦)، بسنده من طريق نفيع أبي داود، عن عبد الله بن مغفل به.</p><p>إسناده تالف؛ فيه نفيع بن الحارث، هو أبو داود الأعمى، قال ابن حجر في التقريب (٧١٨١): «متروك، وقد كذّبه ابن معين».</p><p>والقراءة متواترة، قرأ بها رُويس، وقرأ بقية العشرة: <span class="qpc-hafs">﴿إن تَوَلَّيْتُمْ﴾</span> بفتح التاء والواو واللام. انظر: النشر ٢/٣٧٤، والإتحاف ص٥٠٧.أخرجه البخاري ٦/١٣٤(٤٨٣٠-٤٨٣٢)، ٨/٥ (٥٩٨٧)، ٩/١٤٥ (٧٥٠٢)، ومسلم ٤/١٩٨٠ (٢٥٥٤)، وابن جرير ٢١/٢١٤.أخرجه الثعلبي ٩/٣٥، من طريق القاسم بن يونس الهلالي، عن سعيد بن الحكم الورّاق، عن أبي داود، عن عبد الله بن مغفل به. وعزاه ابن حجر في الفتح ٨/٥٨١ إلى الطبري في تهذيبه.</p><p>إسناده تالف؛ فيه أبو داود الأعمى وهو نفيع بن الحارث، قال عنه ابن حجر في التقريب (٧١٨١): «متروك، وقد كذّبه ابن معين».أخرجه الحاكم ٢/٤٥٨. وعزاه السيوطي إلى ابن المنذر.أخرجه الطبراني في الكبير ١١/٩٩ (١١١٧٠)، والخرائطي في مساوئ الأخلاق ص١١٦-١١٧ (٢٣٤)، ص٣١٩ (٦٧١).</p><p>قال الهيثمي في المجمع ٥/٧٤ (٨٢١١): «رواه الطبراني، ورجاله ثقات، إلا أن عتاب بن بشير لم أعرف له مِن مجاهد سماعًا».عزاه السيوطي إلى عبد بن حميد. وينظر: تقسير القرطبي ١٦/٢٤٥.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٢٤، وابن جرير ٢١/٢١٤.أخرجه ابن جرير ٢١/٢١٣-٢١٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٨-٤٩.تفسير الثعلبي ٩/٣٥، وتفسير البغوي ٧/٢٨٧.⟨أورد السيوطي عند تفسير هذه الآية ١٣/٤٣٨– ٤٤٤ آثارًا كثيرة عن وجوب صلة الرحم، والوعيد الشديد لقاطعها.⟩{ع}أخرجه البخاري ٨/٦ (٥٩٨٩) واللفظ له، ومسلم ٤/١٩٨١ (٢٥٥٥).أخرجه أحمد ٣٩/٢٠١ (٢٣٧٨٤)، والترمذي ٤/٤٦٩ (٢٦٥٣)، وابن ماجه ٢/٣٦٠ (١٣٣٤)، ٤/٣٩٧ (٣٢٥١)، والحاكم ٣/١٤ (٤٢٨٣)، ٤/١٧٦ (٧٢٧٧).</p><p>قال الترمذي: «هذا حديث صحيح». وقال الطبراني في الأوسط ٥/٣١٣ (٥٤١٠): «لم يروِ هذا الحديث عن عاصم إلا عمرو بن عبد الغفار، ولا رواه عن أبي العالية إلا عاصم، والمشهور من حديث عوف الأعرابي، عن زرارة بن أوفى، عن عبد الله بن سلام». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال البغوي في شرح السنة ٤/٤٠ (٩٢٦): «هذا حديث صحيح». وقال ابن عساكر في معجمه ٢/١٠٤٠ (١٣٣٩): «حديث حسن». وقال الألباني في الإرواء ٣/٢٣٧ (٧٧٧): «صحيح متواتر».أخرجه أحمد ١٦/١٩١ (١٠٢٧٢).</p><p>قال المنذري في الترغيب ٣/٢٣٣ (٣٨٢٤): «رواته ثقات». وقال الهيثمي في المجمع ٨/١٥١ (١٣٤٥٠): «رجاله ثقات». وقال الهيتمي في الزواجر ٢/١٢٤: «رواته ثقات». وقال المناوي في التيسير ١/٣١٢: «رجاله ثقات». وقال السيوطي في نور اللمعة ص١١٠ (١٩٧): «بسند جيد». وقال الألباني في الإرواء ٤/١٠٥: «وإسناده ضعيف».
  47,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ لَعَنَهُمُ ٱللَّهُ فَأَصَمَّهُمۡ وَأَعۡمَىٰۤ أَبۡصَـٰرَهُمۡ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أُولئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ﴾</span> فلم يسمعوا الهدى، <span class="qpc-hafs">﴿وأَعْمى أبْصارَهُمْ﴾</span> فلم يُبصِرُوا الهُدى{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ لَعَنَهُمُ ٱللَّهُ فَأَصَمَّهُمۡ وَأَعۡمَىٰۤ أَبۡصَـٰرَهُمۡ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٣٣<span class="dash">-</span></span> عن سلمان، قال: قال رسول الله ﷺ: «<b>إذا ظهر القولُ، وخُزن العملُ، وأَتْلفَت الألسنُ، واختلفت القلوب، وقَطع كلّ ذي رَحِم رَحِمه؛ فعند ذلك لعنهم الله فأصمّهم وأعمى أبصارهم</b>»{2}. (١٣/٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣٤<span class="dash">-</span></span> عن الحسن، قال: قال رسول الله ﷺ: «<b>إذا الناس أظهروا العلم، وضيّعوا العمل، وتحابّوا بالألسن، وتباغضوا بالقلوب، وتقاطعوا في الأرحام؛ لعنهم الله عند ذلك فأصمّهم وأعمى أبصارهم</b>»{3}. (١٣/٤٤٦)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩.أخرجه أحمد في الزهد ص١٢٧ (٨٣٦)، والطبراني في الكبير ٦/٢٦٣ (٦١٧٠).</p><p>قال الطبراني في الأوسط ٢/١٦١(١٥٧٨): «لا يُروى هذان الحديثان عن سلمان إلا بهذا الإسناد، تفرّد بهما محمد بن عمار». وقال الهيثمي في المجمع ٧/٢٨٧ (١٢٢٤١): «وفيه جماعة لم أعرفهم». وقال الألباني في الضعيفة ١٢/١١٤ (٥٥٥٩): «ضعيف».عزاه السيوطي إلى ابن أبي الدنيا في العلم مرسلًا.
  47,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَا یَتَدَبَّرُونَ ٱلۡقُرۡءَانَ أَمۡ عَلَىٰ قُلُوبٍ أَقۡفَالُهَاۤ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٣٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>يأتي على الناس زمانٌ يَخلَقُ القرآن في قلوبهم، يتهافتون تهافتًا</b>». قيل: يا رسول الله، وما تهافتُهم؟ قال: «<b>يقرأ أحدهم فلا يجد حلاوةً ولا لذةً؛ يبدأ أحدهم بالسورة، وإنما بُغْيَتُه آخرها، فإنْ عملوا قالوا: ربنا، اغفِر لنا. وإن تركوا الفرائض قالوا: لا يُعَذِّبُنا الله، ونحن لا نشرك به شيئًا. أمْرهم رجاء، ولا خوف فيهم، <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ وأَعْمى أبْصارَهُمْ أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</span></b>»{1}. (١٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣٦<span class="dash">-</span></span> عن سهل بن سعد، قال: قرأ رسول الله ﷺ: <span class="qpc-hafs">﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</span>. فقال شابٌّ عند النبي ﷺ: بل -واللهِ- عليها أقفالُها، حتى يكون الله هو الذي يَفُكُّها. فلما وُلِّيَ عمر سأل عن ذلك الشابّ ليستعمله، فقيل: قد مات{2}. (١٣/٤٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣٧<span class="dash">-</span></span> عن هشام بن عروة، عن أبيه، قال: تلا رسول الله ﷺ يومًا: <span class="qpc-hafs">﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ أمْ عَلى قُلُوبٍ أقْفالُها﴾</span>. فقال شابٌّ مِن أهل اليمن: بل عليها أقفالها، حتى يكون الله يفتحها أو يَفْرِجها. فقال النبيُّ ﷺ: «<b>صدقت</b>». فما زال الشابُّ في نفس عمر حتى وُلِّيَ فاستعان به{3}. (١٣/٤٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣٨<span class="dash">-</span></span> عن <span class="name-2">خالد بن معدان</span> -من طريق ثور بن يزيد- قال: ما مِن آدميٍّ إلا وله أربع أعين: عينان في رأسه لدنياه وما يصلحه مِن معيشته، وعينان في قلبه لدينه وما وعد الله من الغيب، فإذا أراد الله بعبد خيرًا أبصرت عيناه اللتان في قلبه، وإذا أراد الله به غير ذلك طمس عليهما، فذلك قوله: <span class="qpc-hafs">﴿أم على قلوب أقفالها﴾</span>{4}. (١٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ﴾</span>، قال: إذن -واللهِ- في القرآن زاجرٌ عن معصية الله. قال: لم يتدبّره القوم ويعقلوه، ولكنهم أخذوا بمُتَشابِهِه فهلَكوا عند ذلك{5}. (١٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَلا يَتَدَبَّرُونَ القُرْآنَ﴾</span> يقول: أفلا يسمعون القرآن، <span class="qpc-hafs">﴿أمْ عَلى قُلُوبٍ أقْفالُها﴾</span> يعني: الطّبع على القلوب{6}<span class=comment-ref>٦٠٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٧</span> ذكر <u>ابنُ القيم</u> (٢/٤٥٤) قول مقاتل أنه فسر قوله: <span class="qpc-hafs">﴿أم على قلوب أقفالها﴾</span> بالطبع. ثم <span class="comment-type-1">وجّهه</span> بقوله: «وكأنّ القلب بمنزلة الباب المرتج الذي قد ضُرب عليه قفل، فإنه ما لم يُفتح القفل لا يمكن فتح الباب والوصول إلى ما وراءه، وكذلك ما لم يُرفع الختم والقفل عن القلب لم يدخل الإيمان والقرآن».</div></p><p><h3><span class="qpc-hafs">﴿أَفَلَا یَتَدَبَّرُونَ ٱلۡقُرۡءَانَ أَمۡ عَلَىٰ قُلُوبٍ أَقۡفَالُهَاۤ ۝٢٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٤١<span class="dash">-</span></span> عن <span class="name-2">خالد بن معدان</span>، قال: ما مِن عبدٍ إلا له أربع أعين: عينان في وجهه يُبصر بهما دنياه وما يُصلحه من معيشته، وعينان في قلبه يُبصِر بهما دينه وما وعد الله بالغيب، وإذا أراد الله بعبد خيرًا فتح عينيه اللَّذين في قلبه فأبصر بهما ما وُعِد بالغيب، وإذا أراد الله به سوءًا ترك القلب على ما فيه. وقرأ: <span class="qpc-hafs">﴿أمْ عَلى قُلُوبٍ أقْفالُها﴾</span>، وما من عبد إلا وله شيطان مُتبطّنٌ فَقار ظهره، لاوٍ عنقه على عنقه، فاغرٌ فاه على قلبه{7}. (١٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٢<span class="dash">-</span></span> عن خالد بن معدان، عن معاذ بن جبل مثله مرفوعًا إلى قوله: وقرأ <span class="qpc-hafs">﴿أمْ عَلى قُلُوبٍ أقْفالُها﴾</span>{8}. (١٣/٤٤٧)</p></p><p></div></p></div>",footnotes:1:أورده الديلمي في مسند الفردوس ٥/٤٤٨-٤٤٩ (٨٧٠١).عزاه السيوطي إلى الدارقطني في الأفراد، وابن مردويه.أخرجه إسحاق بن راهويه -كما في المطالب العالية (٤١٠٤)-، وابن جرير ٢١/٢١٧. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٢١/٢١٦ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢١٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر. وأخرجه ابن جرير ٢١/٢١٦ بنحوه من طريق ثور بن يزيد.أخرجه الديلمي في مسند الفردوس ٤/١٤ (٦٠٤٠).</p><p>قال العراقي في تخريج الإحياء ص٩٢٣: «وفيه الحسين بن أحمد بن محمد الهروي السماخي الحافظ، كذّبه الحاكم، والآفة منه».
  47,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ ٱرۡتَدُّوا۟ عَلَىٰۤ أَدۡبَـٰرِهِم مِّنۢ بَعۡدِ مَا تَبَیَّنَ لَهُمُ ٱلۡهُدَى﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ﴾</span> إلى: <span class="qpc-hafs">﴿إسْرارَهُمْ﴾</span>: هم أهل النِّفاق{1}. (١٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فَأَحْبَطَ أعْمالَهُمْ﴾</span>، قال: هم أهل النِّفاق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ مِن بَعْدِ ما تَبَيَّنَ لَهُمُ الهُدى﴾</span>، قال: هم أعداء الله أهل الكتاب يعرفون نَعْت محمد ﷺ وأصحابه عندهم، ويجدونه مكتوبًا في التوراة والإنجيل، ثم يكفرون به{3}. (١٣/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدّيّ</span>: هم المنافقون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر اليهود، فقال: <span class="qpc-hafs">﴿إنَّ الَّذِينَ ارْتَدُّوا﴾</span> عن إيمانٍ بمحمد ﷺ بعد المعرفة <span class="qpc-hafs">﴿عَلى أدْبارِهِمْ﴾</span> يعني: أعقابهم كفارًا، <span class="qpc-hafs">﴿مِن بَعْدِ ما تَبَيَّنَ لَهُمُ الهُدى﴾</span> يعني: أمر النبي ﷺ يبيّن لهم في التوراة أنّه نبيٌّ رسول{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ ارْتَدُّوا عَلى أدْبارِهِمْ مِن بَعْدِ ما تَبَيَّنَ لَهُمُ الهُدى﴾</span>، قال: اليهود ارتدّوا عن الهُدى بعد أن عَرفوا أنّ محمدًا ﷺ نبي{6}<span class=comment-ref>٦٠٢٨</span>. (١٣/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٨</span> ذكر <u>ابنُ عطية</u> (٧/٦٥٤) قول من قال: إن هذه الآية نزلت في جماعة من اليهود. وقول من قال: نزلت في جماعة من المنافقين. ثم <span class="comment-type-4">علّق</span> بقوله: «والآية تعم كل مَن دخل في ضمن لفظها غابر الدهر».</div></p><p><h3><span class="qpc-hafs">﴿ٱلشَّیۡطَـٰنُ سَوَّلَ لَهُمۡ وَأَمۡلَىٰ لَهُمۡ ۝٢٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٤٩<span class="dash">-</span></span> عن هارون، عن <span class="name-2">الأعرج</span>: ‹وأُمْلِي لَهُمْ› مثل: أُملي لهم، يقول الله: <span class="qpc-hafs">﴿وأملي لهم إن كيدي متين﴾</span> [الأعراف:١٨٣، والقلم:٤٥]{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلشَّیۡطَـٰنُ سَوَّلَ لَهُمۡ وَأَمۡلَىٰ لَهُمۡ ۝٢٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٥٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وأَمْلى لَهُمْ﴾</span>، يعني: وسْوَس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الربيع بن عبد الله بن خُطّاف- <span class="qpc-hafs">﴿الشَّيْطانُ سَوَّلَ لَهُمْ وأَمْلى لَهُمْ﴾</span>، قال: زيّن لهم الخطايا، ومدَّ لهم في الأمل{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿الشَّيْطانُ سَوَّلَ لَهُمْ﴾</span>، قال: زيّن لهم{10}<span class=comment-ref>٦٠٢٩</span>. (١٣/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٩</span> لم يذكر <u>ابنُ جرير</u> (٢١/٢١٨) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٧٠٩٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الشَّيْطانُ سَوَّلَ لَهُمْ﴾</span> يعني: زيّن لهم ترْك الهدى، يعني: إيمانًا بمحمد ﷺ، <span class="qpc-hafs">﴿وأَمْلى﴾</span> الله <span class="qpc-hafs">﴿لَهُمُ﴾</span> فيها تقديم، وأمهل الله لهم حين قالوا: ليس محمدٌ بنبي! فلم يعجل عليهم، ثم انتقم منهم حين قتل أهل قُريظة، وأجلى أهل النضير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿الشَّيْطانُ سَوَّلَ لَهُمْ وأَمْلى لَهُمْ﴾</span>، قال: أملى الله لهم{6}<span class=comment-ref>٦٠٣٠</span>. (١٣/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٣٠</span> في فاعل <span class="qpc-hafs">﴿أملى﴾</span> قولان: <b>الأول</b>: أنه الشيطان. <b>الثاني</b>: أنه الله.</p><p>وقد ذكر <u>ابنُ عطية</u> (٧/٦٥٤) القولين، و<span class="comment-type-4">علّق</span> على الأول قائلًا: «وذلك أنّ الإملاء: هو الإبقاء ملاوة من الدهر، يقال: ملاوة وملاوة وملاوة بضم الميم وفتحها وكسرها، وهي القطعة من الزمن، ومنه: الملوان الليل والنهار، فإذا أملى الشيطان إملاء ما فلا صحة له إلا بطمعهم الكاذب». و<span class="comment-type-4">علّق</span> على الثاني، فقال: «ويحتمل أن يكون الفاعل في»أملى«الله ﷿، كأنه قال: الشيطان سول لهم وأملى الله لهم». ثم <span class="comment-type-3">رجّح</span> -<span class="mustanad">مستندًا إلى حقيقة اللفظ-</span> الثاني بقوله: «وحقيقة الإملاء إنما هو بيد الله ﷿، وهذا هو الأرجح».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٢١٨.أخرجه ابن جرير ٢١/٢١٨.أخرجه عبد الرزاق في تفسيره ٢/٢٢٤، وفي المصنف (١٠٢١٢)، وابن جرير ٢١/٢١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٣٧، وتفسير البغوي ٧/٢٨٨.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي ص٣٦٢.</p><p>وهي قراءة متواترة قرأ بها يعقوب، وقرأ أبو عمرو: ‹وأُمْلِيَ› بضم الهمز وفتح الياء، وقرأ الباقون: <span class="qpc-hafs">﴿وأَمْلى لَهُمْ﴾</span>. ينظر: النشر: ٢/٢٨٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٤٣-.أخرجه ابن أبي الدنيا في قصر الأمل ٣/٣٤١ (١٦٣).أخرجه عبد الرزاق في تفسيره ٢/٢٢٤، وفي المصنف (١٠٢١٢)، وابن جرير ٢١/٢١٨ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.
  47,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ قَالُوا۟ لِلَّذِینَ كَرِهُوا۟ مَا نَزَّلَ ٱللَّهُ سَنُطِیعُكُمۡ فِی بَعۡضِ ٱلۡأَمۡرِۖ وَٱللَّهُ یَعۡلَمُ إِسۡرَارَهُمۡ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ذَلِكَ بِأَنَّهُمْ قالُوا لِلَّذِينَ كَرِهُوا ما نَزَّلَ اللَّهُ﴾</span>، قال: هم المنافقون{1}. (١٣/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿ذلك﴾</span> الذي أصابهم مِن القتْل والجلاء <span class="qpc-hafs">﴿بِأَنَّهُمْ قالُوا لِلَّذِينَ كَرِهُوا﴾</span> يعني: تركوا الإيمان، يعني: المنافقين <span class="qpc-hafs">﴿ما نَزَّلَ اللَّهُ﴾</span> مِن القرآن <span class="qpc-hafs">﴿سَنُطِيعُكُمْ فِي بَعْضِ الأَمْرِ﴾</span> قالت اليهود للمنافقين في تكذيب بمحمد ﷺ، وهو بعض الأمر، قالوا ذلك سِرًّا فيما بينهم، فذلك قوله: <span class="qpc-hafs">﴿واللَّهُ يَعْلَمُ إسْرارَهُمْ﴾</span> يعني: اليهود والمنافقين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ذَلِكَ بِأَنَّهُمْ قالُوا لِلَّذِينَ كَرِهُوا ما نَزَّلَ اللَّهُ﴾</span> قال: يهود تقول للمنافقين مِن أصحاب النبيّ ﷺ، وكانوا يُسِرُّون إليهم: إنّا <span class="qpc-hafs">﴿سَنُطِيعُكُمْ فِي بَعْضِ الأَمْرِ﴾</span>. وكان بعض الأمر أنهم يعلمون أنّ محمدًا نبي، وقالوا: اليهودية الدّين. فكان المنافقون يُطيعون اليهود بما أمرتهم، <span class="qpc-hafs">﴿واللَّهُ يَعْلَمُ إسْرارَهُمْ﴾</span> قال: ذلك سِرّ القول{3}. (١٣/٤٤٨)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٢٢٤، وفي المصنف (١٠٢١٢)، وابن جرير ٢١/٢٢٠ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.
  47,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَیۡفَ إِذَا تَوَفَّتۡهُمُ ٱلۡمَلَـٰۤىِٕكَةُ یَضۡرِبُونَ وُجُوهَهُمۡ وَأَدۡبَـٰرَهُمۡ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿يَضْرِبُونَ وُجُوهَهُمْ وأَدْبارَهُمْ﴾</span>، قال: يضربون وجوههم وأستاههم، ولكنّ الله كريم يَكْنِي{1}. (١٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٥٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿توفتهم الملائكة﴾</span> حشَرَتهم إلى النار <span class="qpc-hafs">﴿يضربون وجوههم وأدبارهم﴾</span> في النار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم، فقال: <span class="qpc-hafs">﴿فَكَيْفَ إذا تَوَفَّتْهُمُ المَلائِكَةُ﴾</span> يعني: مَلك الموت وحده <span class="qpc-hafs">﴿يَضْرِبُونَ وُجُوهَهُمْ وأَدْبارَهُمْ﴾</span> عند الموت{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿فَكَيْفَ إذا تَوَفَّتْهُمُ المَلائِكَةُ يَضْرِبُونَ وُجُوهَهُمْ وأَدْبارَهُمْ﴾</span>، قال: عند الموت{1}<span class=comment-ref>٦٠٣١</span>. (١٣/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٣١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٦٥٥) في الآية احتمالين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فكيف إذا توفتهم﴾</span> الآية، يحتمل أن يُتوعّدوا به على معنيين: <b>أحدهما</b>: هذا هلعهم وجزعهم لفرض القتال وقراع الأعداء، فكيف فزعهم وجزعهم إذا توفتهم الملائكة؟! <b>والثاني</b> أن يريد: هذه معاصيهم وعنادهم وكفرهم، فكيف تكون حالهم مع الله إذا توفتهم الملائكة؟! وقال الطبري: المعنى: والله يعلم إسرارهم فكيف علمه بها إذا توفتهم الملائكة».</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> أنّ الضمير في قوله: <span class="qpc-hafs">﴿يضربون﴾</span> عائد على الملائكة، ثم ذكر <b>قولًا آخر</b> أنّه عائد على الكفار، و<span class="comment-type-2">انتقده</span>، فقال: «ومن قال: إن الضمير في: <span class="qpc-hafs">﴿يضربون﴾</span> للكفار الذين يُتوفّون، فذلك ضعيف».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٤٤-.تفسير مقاتل بن سليمان ٤/٤٩.عزاه السيوطي إلى ابن المنذر.
  47,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّهُمُ ٱتَّبَعُوا۟ مَاۤ أَسۡخَطَ ٱللَّهَ وَكَرِهُوا۟ رِضۡوَ ٰ⁠نَهُۥ فَأَحۡبَطَ أَعۡمَـٰلَهُمۡ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٦٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿بِأَنَّهُمُ اتَّبَعُوا ما أسْخَطَ اللَّهَ﴾</span> بما كتموا مِن التوراة، وكفروا بمحمد ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلِكَ﴾</span> الضرب الذي أصابهم عند الموت <span class="qpc-hafs">﴿بِأَنَّهُمُ اتَّبَعُوا ما أسْخَطَ اللَّهَ﴾</span> من الكفر بالنبي محمد ﷺ، <span class="qpc-hafs">﴿وكَرِهُوا رِضْوانَهُ﴾</span> يقول: وتركوا رضوان الله في إيمانٍ بمحمد ﷺ؛ <span class="qpc-hafs">﴿فَأَحْبَطَ أعْمالَهُمْ﴾</span> التي عملوها في غير إيمان{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/٢٨٨.تفسير مقاتل بن سليمان ٤/٤٩.
  47,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ حَسِبَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضٌ أَن لَّن یُخۡرِجَ ٱللَّهُ أَضۡغَـٰنَهُمۡ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٩٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</span>، قال: أعمالهم؛ خُبْثَهم، والحسد الذي في قلوبهم. قال: فَدَلَّ اللهُ النبيَّ ﷺ بَعْدُ على المنافقين، فكان يدعو باسم الرجل مِن أهل النِّفاق{1}. (١٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</span> إلى آخر الآية، قال: هم أهل النِّفاق، وقد عرَّفه إياهم في براءة، فقال: <span class="qpc-hafs">﴿ولا تُصَلِّ عَلى أحَدٍ مِنهُمْ ماتَ أبَدًا ولا تَقُمْ عَلى قَبْرِهِ﴾</span> [التوبة:٨٤]، وقال: <span class="qpc-hafs">﴿قُلْ لَنْ تَخْرُجُوا مَعِيَ أبَدًا ولَنْ تُقاتِلُوا مَعِي عَدُوًّا﴾</span> [التوبة:٨٣]{2}<span class=comment-ref>٦٠٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٣٢</span> ذكر <u>ابنُ عطية</u> (٧/٦٥٦) قول ابن عباس، و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا في الحقيقة ليس بتعريف تام، بل هو لفظ يشير إليهم على الإجمال، لا أنه سمّى أحدًا».</div></p><p><div></p><p><p><span class="item-no">٧٠٩٦٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</span> الآية: هم أهل النِّفاق <span class="qpc-hafs">﴿فَلَعَرَفْتَهُمْ بِسِيماهُمْ ولَتَعْرِفَنَّهُمْ فِي لَحْنِ القَوْلِ﴾</span>، فعرّفه الله إياهم في سورة براءة، فقال: <span class="qpc-hafs">﴿ولا تُصَلِّ عَلى أحَدٍ مِنهُمْ ماتَ أبَدًا﴾</span> [التوبة:٨٤]، وقال: قل لهم: لن تنفروا معي أبدًا، ولن تقاتلوا معي عدوًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى عبد الله بن أُبَيّ، ورفاعة بن زيد، والحارث بن عمرو، فقال: <span class="qpc-hafs">﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</span> يعني: الشكّ بالقرآن، وهم المنافقون <span class="qpc-hafs">﴿أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</span> يعني: أن لن يُظهر الله الغشّ الذي في قلوبهم للمؤمنين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٦٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ أنْ لَنْ يُخْرِجَ اللَّهُ أضْغانَهُمْ﴾</span>، قال: هؤلاء المنافقون. قال: والذي أسَرُّوا من النّفاق هو الكفر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٣١٢- من طريق عطاء مختصرًا. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢٢٢.أخرجه ابن جرير ٢١/٢٢٢.تفسير مقاتل بن سليمان ٤/٤٩-٥٠.أخرجه ابن جرير ٢١/٢٢٢.