quran[24]{c,v,t}:
  51,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّمَاۤءِ ذَاتِ ٱلۡحُبُكِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٣٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عمرو البَكالي- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: هي السماء السابعة{1}<span class=comment-ref>٦١٧٧</span>. (١٣/٦٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧٧</span> <span class="comment-type-1">وجّه</span> <u>ابنُ كثير</u> (١٣/٢٠٩) قول عبد الله، فقال: «وكأنه -والله أعلم- أراد بذلك: السماء التي فيها الكواكب الثابتة، وهي عند كثير من علماء الهيئة في الفلك الثامن الذي فوق السابع».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٦٢): «ظاهر لفظة السماء أنها لجميع السماوات».</div></p><p><h3><span class="qpc-hafs">﴿ذَاتِ ٱلۡحُبُكِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٣٩٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> أنه سُئل عن قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>. قال: ذات الخَلْق الحَسن{2}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: حُسنها، واستواؤها{3}. (١٣/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات البهاء والجمال، وإنّ بنيانها كالبُرْد المُسلسل{4}. (١٣/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات الخَلْق الحَسن{5}<span class=comment-ref>٦١٧٨</span>. (١٣/٦٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧٨</span> نقل <u>ابنُ عطية</u> (٨/٦٣) عن منذر بن سعيد قوله: «إنّ السماء في تألّف جِرمها هي هكذا لها حُبُك، وذلك لجودة خِلْقتها وإتقان صَنعتها». و<span class="comment-type-4">علَّق</span> عليه بقوله: «ولذلك عبّر ابن عباس ﵄ في تفسير قوله تعالى: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span> بأن قال: حُبُكها: حُسْن خِلقَتها ...».</div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>. قال: ذات الطرائق، والخَلْق الحَسن. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعتَ زهير بن أبي سُلْمى يقول:</p><p>هم يضربون حَبِيك البَيْض إذ لَحِقوا لا ينكُصُون إذا ما استُلحموا وحَمُوا؟{6}. (١٣/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿ <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، ما الحُبك؟ قال: ذات الطرائق. قال: فهل كانت العرب تعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: نعم، أما سمعت قول زهير بن أبي سُلْمى:</p><p>مُكلّل بأصول النجم تنسجه ريح الشمال لضاحي مائح حُبُك؟{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: حُبُكها: حُسْنها، واستواؤها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٣٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: ذات الزينة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: المُتقن البُنيان{10}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، يقول: ذات الزينة، ويُقال أيضًا: حُبُكها مثل حُبُك الرّمل، ومثل حُبُك الدّرع، ومثل حُبُك الماء إذا ضربتْه الريح، فنسجته طرائق{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿الحُبُكِ﴾</span>: الطريق التي تُرى في السماء من آثار الغيم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران بن حدير- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات الخَلْق الحَسن، ألم تر إلى النساج إذا نسج الثوب قيل: ما أحسن ما حبَكه{13}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿ذاتِ الحُبُك﴾</span>، قال: حُبكت بالخَلْق الحَسن؛ حُبكت بالنجوم{14}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span>، قال: ذات الخَلْق الشديد{15}. (١٣/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ذاتِ الحُبُكِ﴾</span>، قال: ذات الخَلْق الحَسن{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: حُبُكها: نجومها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق علي بن جعفر- <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: ذات الخَلْق الحَسن{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٠٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُك﴾</span> ذات الطرائق، كحُبُك الماء إذا ضربتْه الريح، وحُبُك الرمل والشَّعر الجَعد، ولكنها لا تُرى لبُعدها من الناس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، يعني: مثل الطرائق التي تكون في الرّمل من الريح، ومثل الماء تصيبه الريح فيركب بعضه بعضًا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١١<span class="dash">-</span></span> عن <span class="name-3">سفيان بن حسين</span> -من طريق الحصين بن نمير- في قوله: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span>، قال: طرائق كطرائق الرمل والماء. وأنشد:</p><p>مكلّل بأصول النجم تنسجه ريح خَريْق لضاحي مائه حبُك{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذاتِ الحُبُكِ﴾</span>، قال: الشدة، حُبِكت: شُدّت. وقرأ قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وبَنَيْنا فَوْقَكُمْ سَبْعًا شِدادًا﴾</span> [النبأ:١٢]{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٣<span class="dash">-</span></span> عن <span class="name-3">الهُذيل بن حبيب</span>: <span class="qpc-hafs">﴿والسَّماءِ ذاتِ الحُبُكِ﴾</span> الخَلْق الحَسن{23}<span class=comment-ref>٦١٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧٩</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/٤٨٦ بتصرف): «قوله تعالى: <span class="qpc-hafs">﴿والسماء ذات الحبك﴾</span> يقول -تعالى ذِكْرُه-: والسماء ذات الخَلْق الحَسن، وعنى بقوله: <span class="qpc-hafs">﴿ذات الحبك﴾</span>: ذات الطرائق ... <span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span>، وإن اختلفت ألفاظ قائليه فيه».</p><p>وذكر <u>ابنُ كثير</u> (١٣/٢٠٩) عبارات السلف في معنى الحُبك، ثم <span class="comment-type-4">علّق</span> قائلًا: «وكل هذه الأقوال ترجع إلى شيء واحد، وهو الحُسْن والبهاء، <span class="mustanad">كما قال ابن عباس</span> ﵄، فإنها مِن حُسنها مرتفعة شفّافة صفيقة، شديدة البناء، متسعة الأرجاء، أنيقة البهاء، مكلّلة بالنجوم الثوابت والسيارات، موشحة بالشمس والقمر والكواكب الزاهرات».</p><p>ونقل <u>ابنُ عطية</u> (٨/٦٣) عن ابن جني قوله: «الحُبُك: طرائق الغَيْم ونحو هذا».</div></p><p><h3><span class="qpc-hafs">﴿ذَاتِ ٱلۡحُبُكِ ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٤١٤<span class="dash">-</span></span> عن أبي قِلابة، عن رجل مِن أصحاب النبي ﷺ، عن النبي ﷺ، قال: «<b>إنّ مِن بعدكم الكذّاب المُضِل، وإنّ رأسه مِن بعده حُبُك حُبُك حُبُك</b>» ثلاث مرات{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٨٩ من طريقي عمرو والقاسم، وأبو الشيخ (٥٦٥). وعزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه أحمد بن منيع -كما في المطالب العالية (٤١٢٠)-.|3:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦١٧-، والفريابي -كما في تغليق التعليق ٤/٣١٩-، وابن جرير ٢١/٤٨٧، وابن أبي حاتم -كما في تغليق التعليق ٤/٣١٩-، وأبو الشيخ في العظمة (٥٥٦). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٣- بنحوه. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|4:أخرجه ابن أبي حاتم -كما في الفتح ٦/٢٩٤-، وأبو الشيخ في العظمة (٥٥٦).|5:أخرجه ابن جرير ٢١/٤٨٦، ٤٨٨، ٤٨٩ من طريق عكرمة وقتادة، ومن طريق علي أيضًا بزيادة: ويقال: ذات الزينة. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:أخرجه الطستي في مسائله -كما في الإتقان ٢/٩٤-.|7:أخرجه الطبراني مطولًا في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).|8:أخرجه ابن جرير ٢١/٤٨٧.|9:أخرجه ابن جرير ٢١/٤٨٧.|10:تفسير مجاهد ص٦١٧، وأخرجه ابن جرير ٢١/٤٨٩.|11:أخرجه ابن جرير ٢١/٤٨٩، وإسحاق البستي ص٢٢٠.|12:أخرجه ابن جرير -كما في الفتح ٦/٢٩٤-.|13:أخرجه ابن جرير ٢١/٤٨٧، وأبو الشيخ (٥٥٥).|14:أخرجه ابن جرير ٢١/٤٨٧-٤٨٨، وبنحوه من طريق قتادة، وأبو الشيخ (٥٤٨).|15:أخرجه إسحاق البستي ص٢٢٠، وأبو الشيخ (٥٤٦).|16:أخرجه عبد الرزاق ٢/٢٤٢، وابن جرير ٢١/٤٨٨، وبنحوه من طريق سعيد.|17:أخرجه ابن جرير ٢١/٤٨٨.|18:أخرجه ابن جرير ٢١/٤٨٨.|19:تفسير البغوي ٧/٣٧١.|20:تفسير مقاتل بن سليمان ٤/١٢٧. وفي تفسير البغوي ٧/٣٧١ عن مقاتل دون تعيينه.|21:أخرجه إسحاق البستي ص٤٢١.|22:أخرجه ابن جرير ٢١/٤٨٩.|23:تفسير مقاتل بن سليمان ٤/١٢٧.|24:أخرجه أحمد ٣٨/٢٢٩ (٢٣١٥٩)، ٣٨/٤٧٢ (٢٣٤٨٧)، وابن جرير ٢١/٤٨٨ وقال عقبه: يعني بالحبُك الجُعُودة.</p><p>قال الهيثمي في المجمع ٧/٣٤٣ (١٢٥٢٢): «رواه أحمد، ورجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٨/١٢١ (٧٦٢٨): «رواه أحمد بن منيع، ورواته ثقات». وقال ابن حجر في الإصابة ٣/٣٧١: «وقال الدارقطني في الأفراد: ... غريب تفرد به ابن أبي سبرة. قلت: وهو ضعيف، والراوي عنه أضعف منه». وقال الألباني في الصحيحة ٦/٧٢٧ (٢٨٠٨): «وهذا إسناد صحيح، غاية رجاله ثقات رجال الشيخين، وجهالة الصحابي لا تضر».
  51,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّكُمۡ لَفِی قَوۡلࣲ مُّخۡتَلِفࣲ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إنَّكُمْ لَفِي قَوْلٍ مُخْتَلِف﴾</span>، قال: مصدِّق بهذا القرآن ومُكَذِّب{1}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّكُمْ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿لَفِي قَوْلٍ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿مُخْتَلِفٍ﴾</span> شكّ، يؤمن به بعضكم ويكفر به بعضكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿إنَّكُمْ لَفِي قَوْلٍ مُخْتَلِف﴾</span>، قال: أهل الشرك يختلف عليهم الباطل{3}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّكُمْ لَفِي قَوْلٍ مُخْتَلِفٍ﴾</span>، قال: يتخرّصون؛ يقولون: هذا سحر، ويقولون: هذا أساطير، فبأي قولهم يؤخذ؟! قُتل الخرّاصون، هذا الرجل لا بدّ له من أن يكون فيه أحد هؤلاء، فما لكم لا تأخذون أحد هؤلاء، وقد رميتموه بأقاويل شتى، فبأي هذا القول تأخذون هذا الرجل الآن؟! فهو قول مختلف. قال: فذكر أنه تَخرّصٌ منهم، ليس لهم بذلك علم. قالوا: فما منع هذا القرآن أن ينزل باللسان الذي نَزَلَتْ به الكتب من قبلك، فقال الله: <span class="qpc-hafs">﴿أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</span> [فصلت:٤٤]؟ لو جعلنا هذا القرآن أعجميًّا لقلتم نحن عَرَبٌ وهذا القرآن أعجمي، فكيف يجتمعان؟!{4}<span class=comment-ref>٦١٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٠</span> ذكر <u>ابنُ عطية</u> (٨/٦٤) في المخاطب بقوله: <span class="qpc-hafs">﴿إنكم﴾</span> احتمالين، و<span class="comment-type-1">وجّههما</span>، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿إنكم لفي قول مختلف﴾</span> <b>يحتمل</b> أن يكون خطابًا لجميع الناس مؤمن وكافر، أي: اختلفتم بأن قال فريق منكم: آمنّا بمحمد وكتابه، وقال فريق آخر: كفرنا، وهذا قول قتادة. <b>ويحتمل</b> أن يكون خطابًا للكفرة فقط، أي: أنتم في جنس من الأقوال مختلف في نفسه، قوم منكم يقولون: ساحر، وقوم: كاهن، وقوم: شاعر، وقوم: مجنون إلى غير ذلك، وهذا قول ابن زيد».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٤٢، وابن جرير ٢١/٤٩٠. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٢٧.|3:عزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢١/٤٩٠.
  51,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُؤۡفَكُ عَنۡهُ مَنۡ أُفِكَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِك﴾</span>، قال: يُضَلُّ عنه مَن ضَلّ{1}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِك﴾</span>: يُؤفن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة، ومعمر- في قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِك﴾</span>، قال: يُصرف عنه مَن صُرِف{3}. (١٣/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِكَ﴾</span>: فالمأفوك عنه اليوم، يعني: كتاب الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِكَ﴾</span> يعني: عن الإيمان بالقرآن، يعني: يُصرف عن القرآن مَن كذّب به، يعني: الخرّاصين، يقول: الكذّابون الذين يخرصون الكذب{5}<span class=comment-ref>٦١٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨١</span> ذكر <u>ابنُ عطية</u> (٨/٦٤-٦٥) في عود الضمير في قوله: <span class="qpc-hafs">﴿عنه﴾</span> عدة احتمالات، فقال: «والضمير في: <span class="qpc-hafs">﴿عنه﴾</span> قال الحسن وقتادة: <b>هو عائد على</b> محمد <b>أو</b> كتابه وشرعه، و<span class="qpc-hafs">﴿يُؤْفَكُ﴾</span> معناه: يُصرف، فالمعنى: يُصرف عن كتاب الله مَن صُرف ممن غلبت شقاوته، وكان قتادة يقول: المأفوك منا اليوم عن كتاب الله كثيرًا. <b>ويحتمل</b> أن يعود الضمير على القول، أي: يُصرف بسببه مَن أراد الإسلام، بأن يقال له: هو سحر، هو كهانة. وهذا حكاه الزهراوي. <b>ويحتمل</b> أن يعود الضمير في <span class="qpc-hafs">﴿عنه﴾</span> على القول، أي: يُصرف عنه بتوفيق الله إلى الإسلام مَن غَلبت سعادته، وهذا على أن يكون قوله: <span class="qpc-hafs">﴿إنكم لفي قول مختلف﴾</span> للكفار فقط». ثم <span class="comment-type-4">علّق</span> على الاحتمال الأخير، فقال: «وهذا وجه حسن لا يخل به، إلا أنّ <span class="mustanad">عُرف الاستعمال</span> في»أفك«إنما هو في الصرف من خير إلى شر، وتأمل ذلك تجدها أبدًا في المصروفين المذمومين».</p><p>وذكر <u>ابنُ القيم</u> (٣/٣٣) القول بعود الضمير على محمد ﷺ، و<span class="comment-type-1">وجّهه</span>، فقال: «والمعنى: يُصرف عنه مَن صُرف حتى يكذّب به».</div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يُؤْفَكُ عَنْهُ مَن أُفِكَ﴾</span>، قال: يُؤفك عنه المشركون{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مجاهد ص٦١٧، وأخرجه ابن جرير ٢١/٤٩١، وقال: «قال ابن عمرو في حديثه: يوفى، أو يؤفن، أو كلمة تشبهها. وقال الحارث: يؤفن، بغير شكّ». وأخرجه إسحاق البستي ص٤٢٢ من طريق ابن جريج، ووقع في النسخة: يوفق دون إعجام الفاء ولعله تحريف من «يؤفن» كما ذكر محققه.|3:أخرجه عبد الرزاق ٢/٢٤٣، وابن جرير ٢١/٤٩١. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢١/٤٩١. وعلقه إسحاق البستي ص٤٢٢ بلفظ: أفك عنه اليوم كثير، يعني كتاب الله.|5:تفسير مقاتل بن سليمان ٤/١٢٧-١٢٨.|6:أخرجه ابن جرير ٢١/٤٩٢.
  51,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُتِلَ ٱلۡخَرَّ ٰ⁠صُونَ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: ما كان في القرآن «قُتّل» بالتشديد فهو عذاب، وما كان <span class="qpc-hafs">﴿قُتل﴾</span> بالتخفيف فهو رحمة{1}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: لُعِن المرتابون{2}<span class=comment-ref>٦١٨٢</span>. (١٣/٦٦٨)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٢</span> <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٨/٦٥) أن قوله: <span class="qpc-hafs">﴿قتل﴾</span> دعاء عليهم، <span class="mustanad">كقول القائل</span>: قاتلك الله. ثم <span class="comment-type-2">انتقد</span> <span class="mustanad">-مستندًا إلى ظاهر اللفظ</span>- ما جاء في قول ابن عباس، فقال: «وقال بعض المفسرين معناه: لُعن الخراصون. وهذا تفسير لا تعطيه اللفظة».</div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: الكَهَنة{3}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span> هم الكَهَنة الذين يتخرصون على علم الغيب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: الذين يَخْرُصون الكذب، كقوله في «عبس» [١٧]: <span class="qpc-hafs">﴿قُتِلَ الإنْسانُ﴾</span>{5}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: الذين يقولون: لا نُبعث، ولا يوقنون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: الكذّابون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: الكذّابون{8}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُون﴾</span>، قال: أهل الغِرّة والظنون{9}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: هي مثل التي في «عبس» [١٧]: <span class="qpc-hafs">﴿قُتِلَ الأِنْسانُ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... يقول: الكذّابون الذين يخرصون الكذب، <span class="qpc-hafs">﴿قُتِلَ﴾</span> يعني: لُعن <span class="qpc-hafs">﴿الخَرّاصُونَ﴾</span> نظيرها في النحل{11}، وكانوا سبعة عشر رجلًا، فقال لهم الوليد بن المُغيرة المخزومي: لينطَلِق كلُّ أربعة منكم أيام الموسم فليجلسوا على طريق ليصدّوا الناس عن النبي ﷺ. وتخرّصهم أنهم قالوا للناس: إنه ساحر، ومجنون، وشاعر، وكاهن، وكذاب. وبقي الوليد بمكة يصدّقهم بما يقولون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قُتِلَ الخَرّاصُونَ﴾</span>، قال: القوم الذين كانوا يتخرَّصون الكذبَ على رسول الله ﷺ، قالت طائفة: إنما هو ساحر، والذي جاء به سحر. وقالت طائفة: إنما هو شاعر، والذي جاء به شعر. وقالت طائفة: إنما هو كاهن، والذي جاء به كهانة. وقالت طائفة: <span class="qpc-hafs">﴿أساطِيرُ الأَوَّلِينَ اكْتَتَبَها فَهِيَ تُمْلى عَلَيْهِ بُكْرَةً وأَصِيلًا﴾</span> [الفرقان:٥]. يتخرّصون على رسول الله ﷺ{6}<span class=comment-ref>٦١٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٣</span> اختُلف في تفسير قوله: <span class="qpc-hafs">﴿الخراصون﴾</span> على قولين: <b>الأول</b>: أنهم الكهنة الذين يتخرصون الكذب والباطل. <b>الثاني</b>: أنهم المرتابون.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u>(٢١/٤٩٢) القول الأول <span class="mustanad">مستندًا إلى أقوال السلف</span>، فقال: «قوله تعالى: <span class="qpc-hafs">﴿قتل الخراصون﴾</span> يقول -تعالى ذكره-: لُعن المتكهنون الذين يتخرّصون الكذب والباطل فيتطيبونه».</div></p></div>",footnotes:1:أخرجه الطبراني (١١١٧٥).|2:أخرجه ابن جرير ٢١/٤٩٢، وابن أبي حاتم -كما في الإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر. وعزا ابن حجر في الفتح ٨/٥٩٩ إلى ابن جرير عن ابن عباس -من طريق علي- في الآية قال: لُعن الكذابون.|3:أخرجه ابن جرير ٢١/٤٩٢. وعزاه السيوطي إلى ابن أبي حاتم.|4:تفسير الثعلبي ٩/١١١.|5:أخرجه ابن جرير ٢١/٤٩٢. وهو في تفسير مجاهد ص٦١٨ دون آخره. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه ابن جرير ٢١/٤٩٣.|7:أخرجه عبد الرزاق ٢/٢٤٢.|8:أخرجه عبد الرزاق -كما في الفتح ٨/٥٩٩-.|9:أخرجه ابن جرير ٢١/٤٩٣ دون لفظ: الغرة. وعلقه إسحاق البستي ص٤٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:أخرجه ابن المنذر -كما في الفتح ٨/٦٠١-.|11:لعله يقصد قوله تعالى: <span class="qpc-hafs">﴿وإنْ هُمْ إلّا يَخْرُصُونَ﴾</span> [الأنعام:١١٦، يونس:٦٦] ولكنها ليست في النحل.|12:تفسير مقاتل بن سليمان ٤/١٢٨.|13:أخرجه ابن جرير ٢١/٤٩٣.
  51,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ هُمۡ فِی غَمۡرَةࣲ سَاهُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُونَ﴾</span>، قال: في غفلة لاهون{1}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ﴾</span>: يعني: الكفر والشكّ{2}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُون﴾</span>، قال: في ضلالتهم يتمادَوْن{3}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُونَ﴾</span>، قال: قلبه في كنانة{4}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُون﴾</span>، قال: في عمًى وشُبهة{5}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي غَمْرَةٍ ساهُونَ﴾</span>، يعني: في غفلة لاهون عن أمر الله تعالى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿غَمْرَةٍ ساهُونَ﴾</span>، قال: في غفلة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فِي غَمْرَةٍ ساهُونَ﴾</span>، قال: ساهون عمّا أتاهم، وعمّا نزل عليهم، وعمّا أمرهم الله -تبارك وتعالى-. وقرأ قول الله -جلّ ثناؤه-: <span class="qpc-hafs">﴿بَلْ قُلُوبُهُمْ فِي غَمْرَةٍ مِن هَذا﴾</span> الآية [المؤمنون:٦٣]، وقال: ألا ترى الشيء إذا أخذْتَه ثم غمَرْتَه في الماء؟{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٩٤. وعزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن جرير ٢١/٤٩٤، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٠، والإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.|4:تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وذكر محققو الدر أنه في نسخة منه بلفظ: كآبة.|5:عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن جرير ٢١/٤٩٤ بلفظ: غمرة وشبهة. وكذلك علقه إسحاق البستي ص٤٢٢.|6:تفسير مقاتل بن سليمان ٤/١٢٨.|7:أخرجه ابن جرير ٢١/٤٩٤.|8:أخرجه ابن جرير ٢١/٤٩٤.
  51,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَسۡـَٔلُونَ أَیَّانَ یَوۡمُ ٱلدِّینِ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يَسْأَلُونَ أيّانَ يَوْمُ الدِّينِ يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span> قال: فِتنتهم أنهم سألوا عن يوم الدِّين وهم موقوفون على النار، <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ هَذا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span> فقالوا حين وُقفوا: <span class="qpc-hafs">﴿يا ويْلَنا هَذا يَوْمُ الدِّينِ﴾</span> [الصافات:٢٠]. وقال الله -تبارك وتعالى-: <span class="qpc-hafs">﴿هَذا يَوْمُ الفَصْلِ الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span> [الصافات:٢١]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَسْأَلُونَ أيّانَ يَوْمُ الدِّين﴾</span>، قال: يقولون: متى يوم الدِّين؟ أوَ يكون يوم الدِّين؟{2}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَسْئَلُونَ﴾</span> النبي ﷺ <span class="qpc-hafs">﴿أيّانَ﴾</span> يقول: متى <span class="qpc-hafs">﴿يَوْمُ الدِّينِ﴾</span> يعني: يوم الحساب، فقالوا: يا محمد -وهم الخرّاصون-، متى يكون الذي تعِدنا به؟! تكذيبًا به، من أمر الحساب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أيّانَ يَوْمُ الدِّينِ﴾</span>، قال: الذين كانوا يجحدون أنهم يُدانون، أو يُبعثون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٩٦.|2:تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٥-٤٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/١٢٨.|4:أخرجه ابن جرير ٢١/٤٩٥.
  51,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ هُمۡ عَلَى ٱلنَّارِ یُفۡتَنُونَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُون﴾</span>، قال: يُعذّبون{1}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق حماد بن زيد، عن عمرو بن مالك- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُعذّبون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥١<span class="dash">-</span></span> عن <span class="name-2">أبي الجوزاء</span> -من طريق جعفر بن سليمان، عن عمرو بن مالك- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: المناقشة في الأعمال{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُون﴾</span>، قال: يُعَذَّبون عليها ويُحرقون، كما يُفتن الذّهب في النار{4}. (١٣/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، يقول: يُنضَجون بالنار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span> يقول: يُطبخون. ويُقال أيضًا <span class="qpc-hafs">﴿يُفْتَنُونَ﴾</span>: يُكذِّبون، كل هذا يقال{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حُصين- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُعذّبون في النار، يُحرقون فيها، ألم ترَ أنّ الذَّهب إذا أُلقي في النار قيل: فُتِن؟{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس، ومبارك- <span class="qpc-hafs">﴿يفتنون﴾</span>: يُعذَّبون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٧<span class="dash">-</span></span> عن قرة: سمعت <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿يفتنون﴾</span> يُقَرَّرون بذنوبهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٨<span class="dash">-</span></span> قال إسحاق البستي: وجدت في كتاب أبي في تفسير <span class="name-2">قتادة</span>: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُنضَجون بالنار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span> يعني: يُعذّبون، يُحرقون، كقوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ فَتَنُوا المُؤْمِنِينَ والمُؤْمِناتِ﴾</span> [البروج:١٠]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، يقول: يُحرَقون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ﴾</span>، قال: يُحرقون بالنار{12}<span class=comment-ref>٦١٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٤</span> في قوله: <span class="qpc-hafs">﴿يوم هم على النار يفتنون﴾</span> قولان: <b>الأول</b>: أنهم يُحرقون ويُعذّبون بالنار. <b>الثاني</b>: أنهم يُكذّبون.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٤٩٨) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، وعلَّل ذلك بقوله: «لأن الفتنة أصلها: الاختبار، وإنما يقال: فتنت الذهب بالنار: إذا طبختها بها لتعرف جودتها؛ فكذلك قوله: <span class="qpc-hafs">﴿يوم هم على النار يفتنون﴾</span> يُحرقون بها كما يُحرق الذهب بها».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٦٥-٦٦): «و<span class="qpc-hafs">﴿يفتنون﴾</span> معناه: يُحرقون ويُعذّبون في النار. قاله ابن عباس، ومجاهد، وعكرمة، <span class="mustanad">والجميع</span>».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ القيم</u> (٣/٣٣-٣٤ بتصرف) على القول الأول، فقال: «والمشهور في تفسير هذا الحرف أنه بمعنى: يُحرقون، ولكن لفظة <span class="qpc-hafs">﴿على﴾</span> تعطي معنًى زائدًا على ما ذكروه، ولو كان المراد نفس الحرق لقيل: يوم هم في النار يفتنون. ولهذا لَمّا علم هؤلاء ذلك قال كثير منهم <span class="qpc-hafs">﴿على﴾</span> بمعنى: في، كما تكون»في«بمعنى: على. ومَن جعل الفتنة ههنا مِن الحريق <span class="mustanad">أخذه من قوله تعالى</span> <span class="qpc-hafs">﴿إنَّ الَّذِينَ فَتَنُوا المُؤْمِنِينَ والمُؤْمِناتِ ثُمَّ لَمْ يَتُوبُوا﴾</span> [البروج:١٠]، واستشهد على ذلك أيضًا بهذه اللفظة التي في الذّاريات». ثم قال: «والظاهر أنّ فتنتهم على النار قبل فتنتهم فيها، لهم عند عرضهم عليها ووقوفهم عليها فتنة، وعند دخولهم والتعذيب بها فتنة أشد منها. وحقيقة الأمر أنّ الفتنة تُطلق على: العذاب وسببه، ولهذا سمى الله الكفر: فتنة، فهم لما أتَوا بالفتنة التي هي أسباب العذاب في الدنيا سمّى جزاءهم: فتنة، ولهذا قال: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span> وكان وقوفهم على النار وعرضهم عليها مِن أعظم فتنتهم، وآخر هذه الفتنة دخول النار والتعذيب بها، ففُتنوا أولًا بأسباب الدنيا وزينتها، ثم فُتنوا بإرسال الرسل إليهم، ثم فُتنوا بمخالفتهم وتكذيبهم، ثم فُتنوا بعذاب الدنيا، ثم فُتنوا بعذاب الموت، ثم يُفتنون في موقف القيامة، ثم إذا حُشروا إلى النار وُقِفوا عليها وعُرضوا عليها وذلك من أعظم فتنتهم، ثم الفتنة الكبرى التي أنسَتهم جميع الفتن قبلها».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٤٩٥، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٠، والإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٨٧ (٣٦٨٠٣)، وابن أبي الدنيا في صفة النار ٦/٤٤٢ (١٩٤)، والحربي في غريب الحديث ٣/٩٣٦.|3:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٨٧ (٣٦٨٠٤).|4:تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٦، مقتصرًا على شطره الثاني ٢١/٤٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:أخرجه ابن جرير ٢١/٤٩٦.|6:أخرجه ابن جرير ٢١/٤٩٧ وإسحاق البستي ص٤٢٢.|7:أخرجه ابن جرير ٢١/٤٩٦. وهو عند سفيان الثوري ص٢٨١، وإسحاق البستي ص٤٢٢ بالاقتصار على لفظ: يُحرقون.|8:أخرجه الحربي في غريب الحديث ٣/٩٣٦.|9:أخرجه الحربي في غريب الحديث ٣/٩٣٦، وإسحاق البستي ص٤٢٣ وقال فيه: أحسبه قال: يعيرون بذنوبهم. قال محقّقه: كلمة «يعيرون» عليها ضبة.|10:تفسير إسحاق البستي ص٤٢٣.|11:تفسير مقاتل بن سليمان ٤/١٢٨.|12:أخرجه ابن جرير ٢١/٤٩٧.|13:أخرجه ابن جرير ٢١/٤٩٧.
  51,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذُوقُوا۟ فِتۡنَتَكُمۡ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span>، يقول: تكذيبكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٣<span class="dash">-</span></span> عن <span class="name-2">أبي الجوزاء</span>، <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُم﴾</span>، قال: عذابكم{2}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فِتْنَتَكُمْ﴾</span>، قال: حريقكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُم﴾</span>، يقول: حريقكم، ويقال: كذبكم{1}<span class=comment-ref>٦١٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٥</span> في قوله: <span class="qpc-hafs">﴿ذوقوا فتنتكم﴾</span> قولان: <b>الأول</b>: ذوقوا تكذيبكم. <b>الثاني</b>: ذوقوا حريقكم وعذابكم.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٤٩٩) القول الأول <span class="mustanad">مستندًا إلى أقوال السلف</span>.</div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ هَذا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span>، قال: تكذيبكم، به تُكذِّبون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلى النّارِ يُفْتَنُونَ ذُوقُوا فِتْنَتَكُم﴾</span>، قال: يوم يُعذّبون، فيقول: ذوقوا عذابكم{6}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span> يعني: عذابكم، <span class="qpc-hafs">﴿هذا﴾</span> العذاب <span class="qpc-hafs">﴿الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span> في الدنيا استهزاءً به وتكذيبًا بأنّه غير نازل بنا، لقولهم في الدنيا للنبي ﷺ: متى هذا الوعد الذي تعِدنا به؟!{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُم﴾</span>، قال: حريقكم{2}. (١٣/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span>، يقول: احتراقكم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ﴾</span>، قال: ذوقوا عذابكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- أنه سُئِل عن قوله: <span class="qpc-hafs">﴿ذُوقُوا فِتْنَتَكُمْ هَذا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ﴾</span>. فقال: هذا الذي فُتنتم به، ألم تر إلى الدينار إذا أُدخل النار قيل: قد اختُبر وفُتن؟!{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٠٠.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٤٩٩.|4:أخرجه ابن جرير ٢١/٥٠٠.|5:أخرجه إسحاق البستي ص٤٢٣.|6:أخرجه عبد الرزاق ٢/٢٤٢، وابن جرير ٢١/٤٩٩، وبنحوه من طريق سعيد. وعلقه إسحاق البستي ص٤٢٣.|7:تفسير مقاتل بن سليمان ٤/١٢٨.|8:عزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن جرير ٢١/٤٩٩.|10:أخرجه ابن جرير ٢١/٥٠٠.|11:أخرجه إسحاق البستي في تفسيره ص٤٢٣.
  51,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَعُیُونٍ ۝١٥ ءَاخِذِینَ مَاۤ ءَاتَىٰهُمۡ رَبُّهُمۡۚ إِنَّهُمۡ كَانُوا۟ قَبۡلَ ذَ ٰ⁠لِكَ مُحۡسِنِینَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُسْلِم البَطِين- في قوله: <span class="qpc-hafs">﴿آخِذِينَ ما آتاهُمْ رَبُّهُمْ﴾</span> قال: الفرائض، <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُحْسِنِين﴾</span> قال: قبل أن تنزل الفرائض يعملون{1}<span class=comment-ref>٦١٨٦</span>. (١٣/٦٧١)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٦</span> لم يذكر <u>ابنُ جرير</u> (٢١/٥٠٠) غير قول ابن عباس.</p><p>ونقل <u>ابنُ عطية</u> (٨/٦٦) عن ابن عباس قوله: «المعنى: <span class="qpc-hafs">﴿آخِذِينَ﴾</span> في دنياهم <span class="qpc-hafs">﴿ما آتاهُمْ رَبُّهُمْ﴾</span> من أوامره ونواهيه وفرائضه وشرعه». و<span class="comment-type-1">وجَّهه</span> بقوله: «فالحال على هذا محكية، وهي متقدمة في الزمان على كونهم في جنات وعيون»، ونقل <u>ابنُ عطية</u> (٥/١٧٤ ط.دار الكتب العلمية) عن جماعة من المفسرين: أن «معنى قوله: <span class="qpc-hafs">﴿آخذين ما آتاهم ربهم﴾</span> أي: مُحصّلين لنعم الله التي أعطاهم من جنته ورضوانه». و<span class="comment-type-1">وجَّهه</span> بقوله: «وهذه حال متصلة في المعنى بكونهم في الجنات». ثم <span class="comment-type-3">رجَّحه</span> قائلًا: «وهذا التأويل أرجح عندي؛ <span class="mustanad">لاستقامة الكلام به</span>».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٣/٢١١) أثر ابن عباس، فقال: «وهذا الإسناد ضعيف، ولا يصح عن ابن عباس. وقد رواه عثمان بن أبي شيبة، عن معاوية بن هشام، عن سفيان، عن أبي عمر البزار، عن مُسْلِم البَطِين، عن سعيد بن جُبَير، عن ابن عباس، فذكره». ثم <span class="comment-type-2">انتقد</span> -<span class="mustanad">مستندًا إلى اللغة</span>- تفسير <u>ابن جرير</u> الآية على ما جاء في قول ابن عباس، فقال: «والذي فسّر به ابن جرير فيه نظر؛ لأن قوله: <span class="qpc-hafs">﴿آخذين﴾</span> حال من قوله: <span class="qpc-hafs">﴿في جنات وعيون﴾</span>، فالمتقون في حال كونهم في الجنات والعيون آخذون ما آتاهم ربهم، أي: من النعيم والسرور والغبطة».</div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٤<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿آخِذِينَ ما آتاهُمْ رَبُّهُمْ﴾</span> آخذين بما أمرهم ربُهم، عاملين بالفرائض التي أوجبها عليهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ وعُيُونٍ﴾</span> يعني: بساتين وأنهار جارية، <span class="qpc-hafs">﴿آخِذِينَ﴾</span> في الآخرة <span class="qpc-hafs">﴿ما آتاهُمْ رَبُّهُمْ﴾</span> يعني: ما أعطاهم ربهم مِن الخير والكرامة في الجنة؛ <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذلِكَ﴾</span> الثواب في الدنيا <span class="qpc-hafs">﴿مُحْسِنِينَ﴾</span> في أعمالهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٦<span class="dash">-</span></span> عن محمد بن حُمَيد، قال:حدّثني <span class="name-3">سفيان الثوري</span> في قوله تعالى: <span class="qpc-hafs">﴿إن المتقين في جنات وعيون آخذين ما آتاهم ربهم﴾</span> قال: من ثواب الفرائض؛ <span class="qpc-hafs">﴿إنهم كانوا قبل ذلك محسنين﴾</span> قال: كانوا متطوّعين{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٠١. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|2:تفسير الثعلبي ٩/١١١.|3:تفسير مقاتل بن سليمان ٤/١٢٨.|4:أخرجه أبو نعيم في حلية الأولياء ٧/٧٧.
  51,16,""
  51,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَانُوا۟ قَلِیلࣰا مِّنَ ٱلَّیۡلِ مَا یَهۡجَعُونَ ۝١٧﴾</span> - تفسير الآية، ونزولها</h3></p><p><div></p><p><p><span class="item-no">٧٢٤٧٧<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>مَن صلّى أربعًا بعد المغرب مِن قبل أن يكلّم أحدًا كان أفضل مِن قيام نصف ليلة، وهي التي يقول الله تعالى: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، وهي التي يقول الله تعالى: <span class="qpc-hafs">﴿تَتَجافى جُنُوبُهُمْ عَنِ المَضاجِعِ﴾</span></b> [السجدة:١٦]، <b>وهي التي يقول الله تعالى: <span class="qpc-hafs">﴿ودَخَلَ المَدِينَةَ عَلى حِينِ غَفْلَةٍ مِن أهْلِها﴾</span></b> [القصص:١٥] ...»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن رَواحة</span> -من طريق الحسن- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: هجعوا قليلًا، ثم مدُّوها إلى السَّحر{2}. (١٣/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: ما تأتي عليهم ليلة ينامون حتى يُصبحوا لا يُصلُّون فيها{3}. (١٣/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، يقول: قليلًا ما كانوا ينامون{4}. (١٣/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨١<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: كانوا يُصَلُّون بين المغرب والعشاء، وكذلك <span class="qpc-hafs">﴿تَتَجافى جُنُوبُهُمْ﴾</span> [السجدة:١٦]{5}. (١٣/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٢<span class="dash">-</span></span> عن <span class="name-2">الأحْنَف بن قيس</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا لا ينامون إلا قليلًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٣<span class="dash">-</span></span> عن <span class="name-2">مُطَرِّف بن عبد الله</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: لا ينتبهون إلا قاموا يُصَلُّون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٤<span class="dash">-</span></span> عن <span class="name-2">مُطَرِّف بن عبد الله</span> -من طريق قتادة- قال: كانوا قلَّ ليلة إلا يصيبون منها{8}. (١٣/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن علي</span> -من طريق قتادة- قال: لا ينامون حتى يُصلُّوا العَتَمَة{9}. (١٣/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٦<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span> قال: قال رجل مِن أهل مكة -سماه قتادة- قال: صلاة العَتَمَة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق عاصم- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: لا ينامون عن العشاء الآخرة{11}. (١٣/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع بن أنس- قال: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span> كانوا يصيبون من الليل حظًّا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق عاصم- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: قليلًا ما ينامون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>: ما ينامون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: قليل ما يرقدون ليلةً حتى الصباح لا يتهجّدون{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مسلم بن خالد، عن ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا قلّ ليلة تمرّ بهم إلا أصابوا منها خيرًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا لا ينامون الليل كلّه{17}. (١٣/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق الزُّبير بن عَديّ- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا قليلًا مِن الناس الذين يفعلون ذلك إذ ذاك{18}. (١٣/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق الزُّبير بن عَديّ- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: المتقين هم القليل، كانوا مِن الناس قليلًا{19}. (١٣/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿كانُوا قَلِيلًا﴾</span> يقول: المحسنون كانوا قليلًا، هذه مفصولة، ثم استأنف، فقال: <span class="qpc-hafs">﴿مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span> الهُجوع النوم{20}. (١٣/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، يقول: إنّ المحسنين كانوا قليلًا، ثم ابتدئ فقيل: <span class="qpc-hafs">﴿مِنَ اللَّيْلِ ما يَهْجَعُونَ وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>، كما قال: <span class="qpc-hafs">﴿والَّذِينَ آمَنُوا بِاللَّهِ ورُسُلِهِ أُولَئِكَ هُمُ الصِّدِّيقُونَ﴾</span> ثم قال: <span class="qpc-hafs">﴿والشُّهَداءُ عِنْدَ رَبِّهِمْ لَهُمْ أجْرُهُمْ ونُورُهُمْ﴾</span> [الحديد:١٩]{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٨<span class="dash">-</span></span> عن مالك بن دينار: سألتُ <span class="name-2">سالم بن عبد الله</span> عن النوم قبل العشاء، فانتهرني، وقال: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: ما بين المغرب والعشاء يُصَلُّون{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٤٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن أبي الحسن</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: قلَّ ليلة أتَتْ عليهم هَجعوها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: قيام الليل{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>: يُكابدون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٢<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: كان <span class="name-2">الحسن</span> يقول: كانوا قليلًا من الليل ما ينامون{26}. (١٣/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٣<span class="dash">-</span></span> عن قتادة، في قول الله ﷿: <span class="qpc-hafs">﴿كانوا قليلًا من الليل ما يهجعون﴾</span>، قال <span class="name-2">الحسن</span>: ما ينامون حتى يُصَلُّون العَتَمَة{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ابن عون- قال: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: مدُّوا الصلاة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس بن عبيد- قال: مدُّوا في الصلاة ونشطوا، حتى كان الاستغفار بسَحَر{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٦<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي معشر- في قول الله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>: كانوا قليلًا مِن الليل ما ينامون{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: كان لهم قليل من الليل ما يهجعون، كانوا يُصَلُّونه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٨<span class="dash">-</span></span> قال <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق معمر- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>: كانوا يُصَلُّون كثيرًا من الليل{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٠٩<span class="dash">-</span></span> عن <span class="name-2">يزيد بن أبي حبيب</span> -من طريق ابن لَهيعة-: أنّ ناسًا مِن أصحاب رسول الله ﷺ كانوا ينضحون لناسٍ مِن الأنصار بالدلاء على الثمار مِن أوّل الليل، ثم [...] قليلًا، ثم يُصَلُّون آخر الليل، قال الله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿قليلا من الليل ما يهجعون﴾</span>، قال: قليلًا ما ينامون{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا يُصيبون من الليل حظًّا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الله بن أبي نَجِيح</span> -من طريق ابن عُلَيَّة- يقول في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا قليلًا ما ينامون ليلة حتى الصباح{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: كانوا قليلًا ما ينامون من الليل. قال: ذاك الهَجْع. قال: والعرب تقول: إذا سافرتَ اهجع بنا قليلًا. قال: وقال رجلٌ مِن بني تميم لأبي: يا أبا أسامة، صفة لا أجدها فينا، ذكر الله -تبارك وتعالى- قومًا فقال: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، ونحن -واللهِ- قليلًا من الليل ما نقوم. قال: فقال <span class="name-2">أبي</span>: طوبى لِمَن رَقد إذا نعس، واتّقى الله إذا استيقظ{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١٤<span class="dash">-</span></span> عن <span class="name-3">الأوزاعي</span> -من طريق العباس بن الوليد- <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: قليلًا ما تجد المؤمن ينام ليلته كلّها{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span> ما ينامون{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥١٦<span class="dash">-</span></span> عن <span class="name-3">حفص بن مَيْسرة</span>، قال: بلغني في قول الله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span> ما بين المغرب والعشاء، كانت الأنصار يُصَلُّون المغرب فينصرفون إلى قباء، فبدا لهم، فأقاموا حتى صَلُّوا العشاء، فنَزَلَتْ فيهم هذه الآية: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span> ما بين المغرب والعشاء، <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span> يَغدون من قباء فيُصَلُّون في مسجد النبي{40}<span class=comment-ref>٦١٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٧</span> اختُلف في تفسير قوله: <span class="qpc-hafs">﴿كانوا قليلًا من الليل ما يهجعون﴾</span> على أقوال: <b>الأول</b>: معناه: كانوا قليلًا من الليل لا يهجعون، وقالوا: <span class="qpc-hafs">﴿ما﴾</span> بمعنى الجحد. <b>الثاني</b>: كانوا قليلًا من الليل يهجعون، ووجهوا <span class="qpc-hafs">﴿ما﴾</span> التي في قوله: <span class="qpc-hafs">﴿ما يهجعون﴾</span> إلى أنها صلة. <b>الثالث</b>: معناه: كانوا يُصَلُّون العَتَمَة. <b>الرابع</b>: أن معناه: كان هؤلاء المحسنون قبل أن تُفرض عليهم الفرائض قليلًا من الناس، والكلام بعد قوله: <span class="qpc-hafs">﴿إنهم كانوا قبل ذلك محسنين﴾</span> كانوا قليلًا مستأنف بقوله: <span class="qpc-hafs">﴿من الليل ما يهجعون﴾</span>.</p><p>وقد <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢١/٥٠٦) أنه على القول الثاني «يجوز أن تكون <span class="qpc-hafs">﴿ما﴾</span> في موضع رفع، ويكون تأويل الكلام: كانوا قليلًا من الليل هجوعهم». ثم قال: «وأما مَن جعل <span class="qpc-hafs">﴿ما﴾</span> صلة فإنه لا موضع لها؛ ويكون تأويل الكلام على مذهبه: كانوا يهجعون قليل الليل، وإذا كانت <span class="qpc-hafs">﴿ما﴾</span> صلة كان القليل منصوبًا بـ<span class="qpc-hafs">﴿يهجعون﴾</span>».</p><p>و<span class="comment-type-4">علّق</span> على القول الثالث، فقال: «وعلى هذا التأويل <span class="qpc-hafs">﴿ما﴾</span> في معنى الجحد». و<span class="comment-type-4">علّق</span> على القول الرابع، فقال: «فالواجب أن تكون <span class="qpc-hafs">﴿ما﴾</span> على هذا التأويل بمعنى الجحد».</p><p>ثم <span class="comment-type-3">رجّح</span> (٢١/٥٠٩) <span class="mustanad">-مستندًا إلى الأغلب من ظاهر اللفظ-</span> القول الثاني، فقال: «وأولى الأقوال بالصحة في تأويل قوله: <span class="qpc-hafs">﴿كانوا قليلًا من الليل ما يهجعون﴾</span> قول مَن قال: كانوا قليلًا من الليل هجوعهم؛ لأن الله -تبارك وتعالى- وصفهم بذلك مدحًا لهم، وأثنى عليهم به، فوصفهم بكثرة العمل، وسهر الليل، ومكابدته فيما يُقرّبهم منه ويرضيه عنهم أولى وأشبه من وصفهم من قلّة العمل، وكثرة النوم، مع أنّ الذي اخترنا في ذلك هو أغلب المعاني على ظاهر التنزيل».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٨/٦٧) حيث قال: «وظاهر الآية عندي أنهم كانوا يقومون الأكثر من ليلهم، أي: من كل ليلة». وبيّن أن <span class="qpc-hafs">﴿ما﴾</span> على هذا مصدرية و<span class="qpc-hafs">﴿قليلًا﴾</span> خبر كان، و«الهجوع» مرتفع بـ<span class="qpc-hafs">﴿قليلًا﴾</span> على أنه فاعل، ويكون المعنى على هذا:«كانوا قليلًا من الليل هجوعهم».</p><p>و<span class="comment-type-4">كذا</span> <u>ابنُ تيمية</u> (٦/١٠٢) <span class="mustanad">مستندًا إلى النظائر،</span> فقال: «وأصح الأقوال: أنّ معناه: كانوا يهجعون قليلًا. فـ<span class="qpc-hafs">﴿قليلًا﴾</span> منصوب بـ<span class="qpc-hafs">﴿يهجعون﴾</span> و<span class="qpc-hafs">﴿ما﴾</span> مؤكدة. وهذا مثل قوله: <span class="qpc-hafs">﴿بل لعنهم الله بكفرهم فقليلا ما يؤمنون﴾</span> [البقرة:٨٨]، وقوله: <span class="qpc-hafs">﴿كانوا قليلًا من الليل ما يهجعون﴾</span> هو مُفسّر في سورة المزمل بقوله: <span class="qpc-hafs">﴿قم الليل إلا قليلا*نصفه أو انقص منه قليلا * أو زد عليه ورتل القرآن ترتيلا﴾</span> [المزمل:٢-٤]، فهذا المستثنى من الأمر هو القليل المذكور في تلك السور، وهو قليل بالنسبة إلى مجموع الليل والنهار؛ فإنهم إذا هجعوا ثلثه أو نصفه أو ثلثاه فهذا قليل بالنسبة إلى ما لم يهجعوه من الليل والنهار، وسواء ناموا بالنهار أو لم يناموا».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ القيم</u> (٣/٣٥) <span class="mustanad">-مستندًا إلى الدلالة العقلية، والسنة، والنظائر</span>- القول الأول بقوله: «وهذا ضعيف لوجوه» ثم ذكر لضعفه عدة وجوه، أهمها ما يلي: ١- أنّ هذا ليس بلازم لوصف المتقين الذين يستحقون هذا الجزاء. ٢- أنّ قيام مَن نام من الليل نصفه أحبّ إلى الله من قيام مَن قامه كلّه. ٣- أنه لو كان هذا مرادًا لكان النبي أولى به، وما قام ليلة حتى الصباح. ٤- أنه سبحانه لما أمره بقيام الليل في سورة المزمل إنما أمره بقيام النصف أو النقصان منه أو الزيادة عليه فذكر له هذه المراتب الثلاثة، ولم يذكر قيامه كلّه.</div></p><p><h3><span class="qpc-hafs">﴿كَانُوا۟ قَلِیلࣰا مِّنَ ٱلَّیۡلِ مَا یَهۡجَعُونَ ۝١٧﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٥١٧<span class="dash">-</span></span> عن عطاء [بن أبي رباح] -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُون﴾</span>، قال: ذلك إذ أُمِروا بقيام الليل، فكان أبو ذرٍّ يعتمد على العصا، فمكثوا شهرين، ثم نَزَلَتْ الرخصة: <span class="qpc-hafs">﴿فاقْرَءُوا ما تَيَسَّرَ مِنه﴾</span> [المزمل:٢٠]{41}. (١٣/٦٧٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَانُوا۟ قَلِیلࣰا مِّنَ ٱلَّیۡلِ مَا یَهۡجَعُونَ ۝١٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٥١٨<span class="dash">-</span></span> عن <span class="name-2">الأحْنَف بن قيس</span> -من طريق قتادة- وقرأ هذه الآية: <span class="qpc-hafs">﴿كانُوا قليلًا مِنَ اللَّيْلِ ما يَهْجَعُونَ﴾</span>، قال: لستُ مِن أهل هذه الآية{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبوالفضل الزُّهريّ في حديثه ص٥٥٨-٥٥٩ (٥٦٩)، من طريق محمد بن عبد الله بن حُميد العقدي بمكة، نا عثمان بن عبد الله بن عفان السامي، نا محمد بن إبراهيم، عن عبيد الله بن أبي سعيد، عن طاووس، عن ابن عباس به.</p><p>محمد بن عبد الله بن حميد العقدي، وعثمان بن عبد الله بن عفان السامي، ومحمد بن إبراهيم، وعبيد الله بن أبي سعيد، لم أقف على مَن ذكرهم بجرح أو تعديل.|2:أخرجه ابن أبي شيبة ٢/٢٣٨. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.|3:أخرجه ابن أبي شيبة ٢/٢٣٩، وابن نصر – كما في مختصر قيام الليل (٩)، والحاكم ٢/٤٦٧، والبيهقي في شعب الإيمان (٣١٠٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه. وأخرجه ابن جرير ٢١/٥٠٣ بلفظ: لم يكن يمضي عليهم ليلة إلا يأخذون منها ولو شيئًا.|4:أخرجه ابن جرير ٢١/٥٠٨، وابن نصر في مختصر قيام الليل (٩). وعزاه السيوطي إلى ابن المنذر.|5:أخرجه أبو داود (١٣٢٢)، وابن جرير ١٨/٦٠٩ في سورة السجدة بلفظ: كانوا يتنفلون فيما بين المغرب والعشاء، وكذلك تتجافى جنوبهم، والحاكم ٢/٤٦٧، والبيهقي في سننه ٣/١٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|6:أخرجه ابن جرير ٢١/٥٠٥.|7:أخرجه ابن أبي الدنيا في التهجد وقيام الليل ١/٣٣٧ (٤٤٥).|8:أخرجه ابن أبي شيبة ٢/٢٣٨، وابن جرير ٢١/٥٠٢-٥٠٣.|9:أخرجه ابن أبي شيبة ٢/٢٣٨، وابن جرير ٢١/٥٠٢.|10:أخرجه ابن جرير ٢١/٥٠٦.|11:أخرجه ابن أبي شيبة ٢/٢٣٨، وابن نصر في مختصر قيام الليل (١٠)، وابن جرير ٢١/٥٠٣ بلفظ: لا ينامون بين المغرب والعشاء.|12:أخرجه ابن جرير ٢١/٥٠٣.|13:أخرجه ابن أبي الدنيا في التهجد وقيام الليل ١/٣٤٥ (٤٩١).|14:أخرجه سفيان الثوري ص٢٨١، وابن جرير ٢١/٥٠٦، وابن أبي الدنيا في التهجد وقيام الليل ١/٣٠٨ (٣٠١).|15:تفسير مجاهد ص٦١٨، وأخرجه ابن جرير ٢١/٥٠٤.|16:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٢٠ (٤٢).|17:تفسير مجاهد ص٦١٨، وأخرجه ابن أبي شيبة ٢/٢٣٨، وابن نصر في مختصر قيام الليل (١٠).|18:أخرجه ابن جرير ٢١/٥٠٧، وابن أبي الدنيا في التهجد وقيام الليل ١/٣٠٩ (٣٠٧). وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن أبي شيبة ٢/٢٣٨-٢٣٩.|20:أخرجه محمد بن نصر في مختصر قيام الليل (١٠)، وابن جرير ٢١/٥٠٨.|21:أخرجه ابن جرير ٢١/٥٠٧.|22:أخرجه ابن أبي الدنيا في التهجد وقيام الليل ١/٣٠٩ (٣٠٦).|23:أخرجه ابن جرير ٢١/٥٠٥، وابن أبي الدنيا في التهجد وقيام الليل ١/٣٠٨ (٣٠٠).|24:أخرجه عبد الرزاق ٢/٢٤٣ بنحوه، وابن جرير ٢١/٥٠٤-٥٠٥.|25:أخرجه ابن أبي الدنيا في التهجد وقيام الليل ١/٣٣٧ (٤٤٥).|26:أخرجه ابن أبي شيبة ٢/٢٣٨، وابن جرير ٢١/٥٠٤-٥٠٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٤- بنحوه.|27:أخرجه عبد الله بن أحمد في زوائد الزهد ص٢٩٩.|28:أخرجه ابن أبي الدنيا في التهجد وقيام الليل ١/٣٠٨ (٢٩٩).|29:أخرجه ابن جرير ٢١/٥٠٥، كما أخرجه بنحوه إسحاق البستي ص٤٢٥ من طريق هشام.|30:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٥٦ (١١٠)، وسعيد بن منصور في سننه -التفسير ٧/٤١٦ (٢٠٥١).|31:أخرجه ابن جرير ٢١/٥٠٣.|32:أخرجه عبد الرزاق ٢/٢٤٣، وابن جرير ٢١/٥٠٦.|33:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٣٩ (٦٨).|34:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٣.|35:أخرجه ابن جرير ٢١/٥٠٣.|36:أخرجه ابن جرير ٢١/٥٠٤.|37:أخرجه ابن جرير ٢١/٥٠٩.|38:أخرجه البيهقي في شعب الإيمان ٦/٣٩٣ (٢٩٠٠).|39:تفسير مقاتل بن سليمان ٤/١٢٩.|40:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٤٦-٤٧ (١٠٠).|41:أخرجه ابن أبي شيبة ٢/٢٣٨، وابن نصر في مختصر قيام الليل (١٠). وعزاه السيوطي إلى ابن المنذر.|42:أخرجه ابن جرير ٢١/٥٠٥.
  51,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبِٱلۡأَسۡحَارِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥١٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- أنه سمعه يقول: السَّحَر: هو السُّدس الأخير من الليل{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبِٱلۡأَسۡحَارِ هُمۡ یَسۡتَغۡفِرُونَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٢٠<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: <b>«إنّ آخر الليل في التَّهجُّد أحبُّ إلَيَّ مِن أوله؛ لأنّ الله يقول: <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُون﴾</span></b>»{2}. (١٣/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢١<span class="dash">-</span></span> عن ابن عمر، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُون﴾</span>، قال: <b>«يُصَلُّون</b>»{3}. (١٣/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق جَبَلَة بن سُحَيم- في قوله: <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُون﴾</span>، قال: يُصَلُّون{4}. (١٣/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>، قال: يُصَلُّون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>، يقول: يقومون فيُصَلُّون. يقول: كانوا يقومون وينامون، كما قال الله لمحمد ﷺ: <span class="qpc-hafs">﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ونِصْفَهُ وثُلُثَهُ﴾</span> فهذا نوم، وهذا قيام <span class="qpc-hafs">﴿وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ﴾</span> [المزمل:٢٠] كذلك يقومون ثلثًا ونصفًا وثلثين. يقول: ينامون ويقومون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس بن عبيد- <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>، قال: صَلّوا، فلما كان السَّحَر استغفروا{7}. (١٣/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>، قال: مدُّوا الصلاة إلى السَّحَر، ثم دَعَوا وتضرَّعوا {8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبِالأَسْحارِ﴾</span> يعني: آخر الليل <span class="qpc-hafs">﴿هُمْ يَسْتَغْفِرُونَ﴾</span> يعني: يُصَلُّون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وبِالأَسْحارِ هُمْ يَسْتَغْفِرُونَ﴾</span>، قال: هم المؤمنون. قال: وبَلَغنا: أنّ نبي الله يعقوب ﵇ حين سألوه أن يستغفر لهم <span class="qpc-hafs">﴿قالُوا يا أبانا اسْتَغْفِرْ لَنا ذُنُوبَنا﴾</span>؛ <span class="qpc-hafs">﴿قالَ سَوْفَ أسْتَغْفِرُ لَكُمْ رَبِّي﴾</span> [يوسف:٩٧،٩٨]. قال: قال بعض أهل العلم: إنه أخَّر الاستغفار إلى السَّحَر. قال: وذكر بعضُ أهل العلم: أنّ الساعة التي تُفتح فيها أبواب الجنة السَّحَر{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥١١.|2:عزاه السيوطي إلى ابن مردويه.|3:عزاه السيوطي إلى ابن مردويه.</p><p>قال الألوسي في تفسيره ١٤/١٠: «ولا أراه يصح».|4:أخرجه عبد الرزاق ٢/٢٤٥، وابن أبي شيبة ١٣/٣٢٧، وابن جرير ٢١/٥١٠، وابن أبي الدنيا في التهجد وقيام الليل ١/٣٤٥ (٤٨٧). وعزاه السيوطي إلى ابن مردويه، وابن المنذر، وابن أبي حاتم.|5:تفسير مجاهد ص٦١٩، وأخرجه ابن جرير ٢١/٥١٠.|6:أخرجه ابن جرير ٢١/٥٠٩-٥١٠، وإسحاق البستي ص٤٢٦.|7:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦١٨- من طريق ورقاء، وابن أبي شيبة ٢/٢٣٨، وابن نصر في مختصر قيام الليل (٩)، وابن جرير ٢١/٥٠٥، ٥١٠، وابن أبي الدنيا في التهجد وقيام الليل ١/٣٠٨ (٢٩٨). وعزاه السيوطي إلى ابن المنذر.|8:أخرجه أحمد في الزهد (٣٢٢).|9:تفسير مقاتل بن سليمان ٤/١٢٩.|10:أخرجه ابن جرير ٢١/٥١٠.
  51,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝١٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن بن محمد بن الحَنفيّة</span>، قال: بَعَث رسولُ الله ﷺ سَريّة، فأصابوا وغنموا، فجاء قومٌ بعد ما فرغوا؛ فنَزَلَتْ: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُومِ﴾</span>{1}<span class=comment-ref>٦١٨٨</span>. (١٣/٦٧٥)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٨</span> ذكر <u>ابنُ كثير</u> (١٣/٢١٦) هذا الأثر، ثم <span class="comment-type-4">علّق</span> قائلًا: «وهذا يقتضي أن هذه مدنية». و<span class="comment-type-2">انتقده</span> -<span class="mustanad">مستندًا إلى أحوال النزول-</span> بقوله: «وليس كذلك، بل هي مكية شاملة لما بعدها».</div></p><p><h3><span class="qpc-hafs">﴿وَفِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٣٠<span class="dash">-</span></span> عن فاطمة بنت قيس: أنها سألت النبيَّ ﷺ عن هذه الآية: (وفِي أمْوالِهِمْ حَقٌّ معلوم){2}، قال: <b>«إنّ في المال حقًّا سوى الزّكاة»</b>. وتلا هذه الآية: <span class="qpc-hafs">﴿لَيْسَ البِرَّ أنْ تُوَلُّوا وُجُوهَكُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿وفِي الرِّقابِ وأَقامَ الصَّلاةَ وآتى الزّكاة﴾</span> [البقرة:١٧٧]{3}. (١٣/٦٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ﴾</span>، قال: سوى الزّكاة؛ يَصِلُ بها رَحِمًا، أو يَقْري بها ضيفًا، أو يُعين بها محرومًا{4}. (١٣/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٢<span class="dash">-</span></span> عن قَزَعة: أنّ رجلًا سأل <span class="name-1">ابن عمر</span> عن قوله: (وفِي أمْوالِهِمْ حَقٌّ معلوم){5}، قال: هي الزّكاة، وفي سوى ذلك حقوق{6}<span class=comment-ref>٦١٨٩</span>. (١٣/٦٧٦)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨٩</span> ذكر <u>ابنُ عطية</u> (٨/٦٨) نحو هذا القول عن منذر بن سعيد، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لأحوال النزول</span> فقال: «وقال منذر بن سعيد: هي الزّكاة المفروضة. وهذا ضعيف؛ لأن السورة مكية، وفرض الزّكاة بالمدينة».</div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق الأعمش- قال: كانوا يرون في أموالهم حقًّا سوى الزّكاة{7}. (١٣/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ﴾</span>، قال: سوى الزّكاة{8}. (١٣/٦٧٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٣٥<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>ليس المسكين الذي تردّه التمرة والتمرتان، ولا الأكلة والأكلتان</b>». قالوا: فمَن المسكين؟ قال: «<b>الذي ليس له ما يغنيه، ولا يُعلم مكانه فيُتصدّق عليه، فذلك المحروم</b>»{9}. (١٣/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span>، أنّ النبي ﷺ قال: «<b>ليس المسكين الذي تردّه التمرة والتمرتان، والأكلة والأكلتان</b>». قيل: فمَن المسكين، يا رسول الله؟ قال: «<b>الذي لا يجد غنًى، ولا يُعْلَم بحاجته فيُتصدّق عليه</b>». قال <span class="name-2">الزُّهريّ</span>: فذلك المحروم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٧<span class="dash">-</span></span> عن إبراهيم -من طريق الحكم-: أنّ أناسًا قدموا على <span class="name-1">علي</span> ﵁ الكوفة بعد وقعة الجمل، فقال: اقسموا لهم. قال: هذا المحروم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٨<span class="dash">-</span></span> عن عُروة بن الزبير، قال: سألتُ <span class="name-1">عائشة</span> عن المحروم في هذه الآية. فقالت: هو المُحارَفُ{12}، الذي لا يكاد يتيسّر له مكسبه{4}. (١٣/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قيس بن كُركُم- قال: المحروم: المُحارَف الذي ليس له في الإسلام سهم{14}. (١٣/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قيس بن كُركُم- أنّه سُئِل عن السائل والمحروم. قال: السائل: الذي يسأل الناس، والمحروم: الذي ليس له سهم في المسلمين{15}. (١٣/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قال: المحروم: هو المُحارَف الذي يطلب الدنيا وتُدبر عنه، ولا يسأل الناس، فأمر الله المؤمنين برِفْدِه{16}. (١٣/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٢<span class="dash">-</span></span> عن أبي قِلابة، قال: كان رجل باليمامة، فجاء السّيلُ، فذهب بماله، فقال <span class="name-1">رجلٌ مِن أصحاب النَّبِيّ</span> ﷺ: هذا المحروم، فأعْطوه{17}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span>، قال: المحروم: المُحارَف{6}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span> -من طريق بكير بن الأشج- قال: المحروم: المُحارَف{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٥<span class="dash">-</span></span> عن أبي بشر، قال: سألتُ <span class="name-2">سعيد بن جُبَير</span> عن المحروم، فلم يقل فيه شيئًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٦<span class="dash">-</span></span> وسألت <span class="name-2">عطاء</span>، فقال: هو المحدود. وزعم أن المحدود: المُحارَف{20}. (١٣/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: المحروم: الذي ليس له في الغنيمة شيء{21}. (١٣/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النّخْعي</span> -من طريق منصور-، مثله{22}. (١٣/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لِلسّائِلِ والمَحْرُوم﴾</span>، قال: السائل: الذي يسأل بكفّه، والمحروم: المُحارَف{23}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: المحروم: الذي لا ينمو له مال في قضاء الله{24}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حُصين- قال: المحروم: المُحارَف الذي لا يثبت له مال{25}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، قال: هو المُحارَف. وتلا هذه الآية: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٦-٦٧]، قال: هلكت ثمارهم، وحُرِموا بركة أرضهم{6}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، قال: أعياني أن أعلم ما المحروم{6}. (١٣/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٤<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج- أنه قال: <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span> هو المُحارَف في الرزق والتجارة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- أنه كان يقول في <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span>: الرجل صاحب الحَرْث بين الحروث، يزرعون جميعًا، فيطعم بعضهم نَفْع زَرْعِه، ويحُرمه الآخر، فعليهم أن يجبروه بينهم، فقال: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٣-٦٧]، قال: <span class="qpc-hafs">﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ فَلَمّا رَأَوْها قالُوا إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [القلم:٢٥]، قال: جميع الناس كلهم يقولون: المُحارَف في التجارة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: السائل: الذي يسأل بكفّه، والمحروم: المُتَعَفِّف{30}. (١٣/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق معمر- <span class="qpc-hafs">﴿لِلسّائِلِ والمَحْرُومِ﴾</span>، قال: السائل: الذي يسأل، والمحروم: المتعفّف الذي لا يسأل{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الله بن عيّاش- في قول الله: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُومِ﴾</span>، قال: ليس ذلك بالزّكاة، ولكن ذلك مِمّا يُنفِقُون مِن أموالهم بعد إخراج الزّكاة، والمحروم: الذي يُصاب زرعه أو ثمره أو نَسْل ماشيته، فيكون له حقٌّ على مَن لم يصبه ذلك من المسلمين، كما قال لأصحاب الجنة حين أهلك جنتهم قالوا: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٧]{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٥٩<span class="dash">-</span></span> عن <span class="name-2">نافع</span> -من طريق أيوب- قال: المحروم: المُحارَف{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦٠<span class="dash">-</span></span> عن ابن أبي الزناد، عن أبيه، قال: سمعتُ مِمَّن أقْتَدِي برأيه يقول في <span class="qpc-hafs">﴿لِلسّائِلِ والمَحْرُومِ﴾</span>: إنّ المحروم الذي يحارف، لا يكاد يتوجّه إلى شيء من التجارة إلا نكب عنه الرزق{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ﴾</span> يعني: المسكين، <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span> الفقير الذي لا سهم له{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦٢<span class="dash">-</span></span> عن عبد الله بن وهب، قال: قال لي <span class="name-3">مالك [بن أنس]</span>: <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span> عندي: الفقير الذي يُحرم الرزق{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُومِ﴾</span>، قال: المحروم: المصاب ثمره وزرعه. وقرأ: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَه﴾</span> حتى بلغ: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٣-٦٧]، وقال أصحاب الجنة: <span class="qpc-hafs">﴿إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [القلم:٢٦-٢٧]{37}<span class=comment-ref>٦١٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٠</span> اختلف السلف فيمن أراد الله بقوله: <span class="qpc-hafs">﴿والمحروم﴾</span> على أقوال: <b>الأول</b>: أنه المحارَف الذي لا سهم له في الإسلام. <b>الثاني</b>: أنه المتعفف الذي لا يسأل الناس. <b>الثالث</b>: أنه الذي لا سهم له في الغنيمة. <b>الرابع</b>: أنه الذي لا ينمى له مال. <b>الخامس</b>: أنه الذي قد ذهب ثمره وزرعه.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢١/٥١٨) هذه الأقوال، ثم <span class="comment-type-3">رجّح</span> صحّة جميعها <span class="mustanad">-مستندًا إلى العموم-</span> فيها، فقال: «والصواب من القول في ذلك عندي: أنه الذي قد حُرم الرزق واحتاج، وقد يكون ذلك بذهاب ماله وثمره، فصار ممن حرمه الله ذلك، وقد يكون بسبب تعفّفه وترْكه المسألة، ويكون بأنّه لا سهم له في الغنيمة لغيبته عن الوقعة، فلا قول في ذلك أولى بالصواب من أن تعم، كما قال -جلَّ ثناؤه-: <span class="qpc-hafs">﴿وفي أموالهم حق للسائل والمحروم﴾</span>».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٦٨): «واختلف الناس في المحروم اختلافًا هو عندي تخليط من المتأخرين؛ إذ المعنى واحد، وإنما عبّر علماء السلف في ذلك بعبارات على جهة المثالات، فجعلها المتأخرون أقوالًا». ثم <span class="comment-type-3">رجّح</span>: «أنه الذي لا مال له لحرمانٍ أصابه، وإلا فالذي تُصاب ثمرته وله مال كثير غيرها فليس في هذه الآية <span class="mustanad">بإجماع</span>». وزاد <b>قولًا سادسًا</b> عن عمر بن عبد العزيز: أن المحروم هو الكلب. ثم <span class="comment-type-1">وجّهه</span> بقوله: «وقد يكون الكلب محرومًا في بعض الأوقات والحالات، ألا ترى إلى الذي كان يأكل الثرى من العطش ... الحديث».</div></p><p><h3><span class="qpc-hafs">﴿لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝١٩﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ﴾</span> يعني: المسكين، <span class="qpc-hafs">﴿والمَحْرُومِ﴾</span> الفقير الذي لا سهم له، ولم يجعل الله للفقراء سهمًا في الفيء ولا في الخُمس، فمَن سمّى الفقير المحروم لأنّ الله حرمهم نصيبهم، فلما نَزَلَتْ «براءة» بدأ الله بهم، فقال تعالى: <span class="qpc-hafs">﴿إنَّما الصَّدَقاتُ لِلْفُقَراءِ﴾</span> [التوبة:٦٠] فبدأ بهم، فنَسَختْ هذه الآية <span class="qpc-hafs">﴿المَحْرُوم﴾</span>{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿إنّما الصَّدقاتُ للفُقراء﴾</span> الآية: نَسَخت هذه الآيةُ كلَّ صدقةٍ في القرآن؛ قوله: <span class="qpc-hafs">﴿وءات ذا القُربى حَقَّه﴾</span> [الإسراء:٢٦]، وقوله: <span class="qpc-hafs">﴿إن تُبْدُوا الصَّدقات﴾</span> [البقرة:٢٧١]، وقوله: <span class="qpc-hafs">﴿وفي أموالهم حقٌ للسائل والمحروم﴾</span>{39}<span class=comment-ref>٦١٩١</span>. (٧/٤٠٩)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩١</span> <span class="comment-type-3">رجح</span> <u>ابنُ عطية</u> (٨/٦٨) أن هذه الآية محكمة، فقال:«الصحيح أنها محكمة، وأن هذا الحق هو على وجه الندب، لا على وجه الفرض». ثم ذكر عن بعض أهل التأويل أن ذلك كان ثم نُسخ بالزّكاة، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الدلالة التاريخية</span>، فقال: «وقال قوم من المتأولين: كان هذا ثُم نُسخ بالزّكاة، وهذا غير قوي، وما شرع الله ﷿ بمكة قبل الهجرة شيئًا من أخذ الأموال».</div></p><p><h3><span class="qpc-hafs">﴿لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝١٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٦٦<span class="dash">-</span></span> عن غَزْوان أبي حاتم، قال: بَينا أبو ذرّ عند باب عثمان لم يُؤذن له إذ مرَّ به رجلٌ مِن قريش، فقال له: يا أبا ذر، ما يَحْبِسُك ههنا؟ قال: يأبى هؤلاء أن يأذنوا لي، فدخل الرجل، فقال: يا أمير المؤمنين، ما بال أبي ذرٍّ على الباب لا يُؤذن له. فأمر، فأُذن له، فجاء حتى جلس ناحية القوم، قال: وميراث عبد الرحمن بن عوف يُقسم، فقال عثمان لكعب: يا أبا إسحاق، أرأيتَ المال إذا أُدِّي زكاته هل يُخشى على صاحبه فيه تَبعة؟ فقال: لا. فقام أبو ذرّ ومعه عصاه، فضرب بها بين أُذني كعب، ثم قال: يا ابن اليهودية، أنت تزعم أنّه ليس عليه حقٌّ في ماله إذا أدّى الزّكاة! واللهُ يقول: <span class="qpc-hafs">﴿ويُؤْثِرُونَ عَلى أنْفُسِهِمْ﴾</span> الآية [الحشر:٩]، والله يقول: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span> الآية [الإنسان:٨]، والله يقول: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُومِ﴾</span> [الذّاريات:١٩]. فجعل يذكر نحو هذا من القرآن، فقال عثمان للقرشي: إنما نكره أن نأذن لأبي ذرٍّ مِن أجل ما ترى{40}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٤٤، وابن أبي شيبة ١٢/٤١٢، وابن جرير ٢١/٥١٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|2:كذا في المصدر، وذكر محققو الدر أنه كذا في نُسَخه، والآية في هذه السورة: <span class="qpc-hafs">﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُوم﴾</span>، وفي سورة المعارج: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ (٢٤) لِلسّائِلِ والمَحْرُومِ﴾</span>.|3:أخرجه البيهقي في الكبرى ٤/١٤٢ (٧٢٤٢)، وأخرجه الترمذي ٢/١٩٧-١٩٨ (٦٦٥، ٦٦٦)، وابن ماجه ٣/٩ (١٧٨٩) كلاهما دون ذكر الآية.</p><p>وقال الترمذي: «هذا حديث إسناده ليس بذاك، وأبو حمزة ميمون الأعور يُضعّف، وروى بيان وإسماعيل بن سالم عن الشعبي هذا الحديث قوله، وهذا أصح». وقال البيهقي في الكبرى ٤/١٤٢ (٧٢٤٢): «فهذا حديث يُعرف بأبي حمزة ميمون الأعور، كوفي، وقد جرّحه أحمد بن حنبل ويحيى بن معين فمَن بعدهما مِن حفاظ الحديث». وقال الدارقطني في العلل ١٥/٣٧٦ (٤٠٨٤): «يرويه أبو حمزة ميمون عن الشعبي عن فاطمة بنت قيس عن النبي ﷺ، وكلاهما ضعيفان». وقال النووي في الخلاصة ٢/١٠٧٧-١٠٧٨ (٣٨٣٧): «حديث منكر». وقال المناوي في فيض القدير ٥/٣٧٥ (٧٦٤١): «قال النووي: ضعيف جدًّا. وقال ابن القطان: فيه أبو حمزة ميمون الأعور، ضعيف. وقال الحافظ ابن حجر: هذا حديث مضطرب المتن، والاضطراب موجب للضعف؛ وذلك لأنّ فاطمة روته عن المصطفى ﷺ بلفظ: «<b>إن في المال حقًّا سوى الزّكاة</b>». فرواه عنها الترمذي هكذا، وروته بلفظ: «<b>ليس في المال حق سوى الزّكاة</b>». فرواه عنها ابن ماجه كذلك، وتعقّبه الشيخ زكريا: بأن شرط الاضطراب عدم إمكان الجمع، وهو ممكن بحمل الأول على المستحب، والثاني على الواجب. ومن العجب قول البيهقي: هذا خرجه أصحابنا في تعاليقهم، ولا أحفظ له إسنادًا».|4:عزاه السيوطي إلى ابن أبي حاتم.|5:ذكر محققو الدر أنه كذا في نُسَخه.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن أبي شيبة ٣/١٩٠-١٩١.|8:تفسير مجاهد ص٦١٩، وأخرجه ابن أبي شيبة ٣/١٩١، ومن طريق منصور أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:أخرجه أحمد ١٢/٥٠٣-٥٠٥ (٧٥٣٩، ٧٥٤٠)، ١٦/٩٤ (١٠٠٦٧)، وأبو داود ٣/٧٣-٧٤ (١٦٣١، ١٦٣٢)، وابن حبان ٨/١٣٨-١٣٩ (٣٣٥١). وابن جرير ٢١/٥١٥ من مرسل الزهري.</p><p>قال أبو داود: «روى محمد بن ثور وعبد الرزاق عن معمر، جعلا المحروم من كلام الزُّهريّ، وهو أصح». وقال الألباني في صحيح أبي داود ٥/٣٣٢-٣٣٣ (١٤٤٢): «قلت: وهو كما قال، والحديث بدون هذه الزيادة صحيح من الطريقين، وهما على شرط الشيخين. وقد أخرجاه من طرق أخرى بدونها، فهي زيادة شاذة، والصحيح أنها مقطوعة من كلام الزُّهريّ».|10:أخرجه عبد الرزاق ٢/٢٤٣.|11:أخرجه ابن جرير ٢١/٥١٦.|12:المُحارَف -بفتح الراء-: هو المحروم المحدود الذي إذا طلب فلا يُرزق، أو يكون لا يسعى في الكسب. النهاية (حرف).|13:عزاه السيوطي إلى ابن أبي حاتم.|14:أخرجه ابن أبي شيبة ١٢/٤١٢-٤١٣، وابن جرير ٢١/٥١٢.|15:أخرجه ابن جرير ٢١/٥١٣ بلفظ: السائل: الذي يسأل، والمحروم: المُحارَف الذي ليس له في الإسلام سهم. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.|16:أخرجه ابن جرير ٢١/٥١١، ٥١٤ مختصرًا، وبنحوه من طريق مجاهد، وسعيد. وعزاه السيوطي إلى ابن أبي حاتم.|17:أخرجه ابن جرير ٢١/٥١٣. وعزاه السيوطي إلى ابن المنذر.|18:عزاه السيوطي إلى عبد بن حميد.|19:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٧-١١٨ (٢٧٠)، وابن جرير ٢١/٥١٣-٥١٤، كذلك أخرجه من طريق قتادة.|20:أخرجه ابن جرير ٢١/٥١٤ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.|21:أخرجه ابن أبي شيبة ١٢/٤١٣.|22:أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥١٦، وابن أبي شيبة ١٢/٤١٣.|23:تفسير مجاهد ص٦١٩ مختصرًا، وأخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥١٢ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.|24:أخرجه ابن جرير ٢١/٥١٣ بلفظ: هو الرجل المحارف الذي لا يكون له مال إلا ذهب، قضى الله له ذلك. وعزاه السيوطي إلى عبد بن حميد.|25:أخرجه ابن جرير ٢١/٥١٧. وعزاه السيوطي إلى عبد بن حميد.|26:عزاه السيوطي إلى عبد بن حميد.|27:عزاه السيوطي إلى عبد بن حميد.|28:أخرجه عبد الرزاق ٢/٢٤٤ من طريق ابن أبي نجيح، وعبد الله بن وهب في الجامع -تفسير القرآن ١/١٢٠ (٢٧٥).|29:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٧٥-٧٦ (١٤٦).|30:أخرجه ابن جرير ٢١/٥١٤-٥١٥ بنحوه. وعزاه السيوطي إلى ابن المنذر.|31:أخرجه عبد الرزاق ٢/٢٤٣، وابن جرير ٢١/٥١٥. كما أخرج شطره الثاني عبد الله بن وهب في الجامع -تفسير القرآن ٢/٣٥ (٦٠) من طريق ابن أبي ذئب وزاد: ولا يعرفون مكانه يتصدقون عليه.|32:أخرجه ابن جرير ٢١/٥١٧، وأخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٦٠ (٣٣٤) من طريق عبد الرحمن مختصرًا.|33:أخرجه ابن جرير ٢١/٥١٤.|34:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦٥ (١٤٣).|35:تفسير مقاتل بن سليمان ٤/١٢٩.|36:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٣٥ (٦٠).|37:أخرجه ابن جرير ٢١/٥١٧.|38:تفسير مقاتل بن سليمان ٤/١٢٩.|39:عزاه السيوطي إلى ابن المنذر.|40:أخرجه البيهقي في شعب الإيمان ٦/٤٨٢-٤٨٣ (٣٠٣٧).
  51,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِی ٱلۡأَرۡضِ ءَایَـٰتࣱ لِّلۡمُوقِنِینَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وفِي الأَرْضِ آياتٌ لِلْمُوقِنِينَ﴾</span>، قال: يقول: مُعتبَرٌ لِمَن اعتبر{1}. (١٣/٦٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وفِي الأَرْضِ آياتٌ لِلْمُوقِنِينَ﴾</span>: إذا سار في أرض الله رأى عِبرًا، وآياتٍ عظامًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي الأَرْضِ آياتٌ لِلْمُوقِنِينَ﴾</span>، يعني: ما فيها من الجبال، والبحار، والأشجار، والثمار، والنَّبت عامًا بعام، ففي هذا كلّه آيات، يعني: عِبرة للموقنين بالرّبّ تعالى؛ لتعرفوا صُنعه فتوحِّدوه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥١٨، وأبو الشيخ في العظمة (١٧). وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢١/٥١٨.|3:تفسير مقاتل بن سليمان ٤/١٢٩.
  51,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِیۤ أَنفُسِكُمۡۚ أَفَلَا تُبۡصِرُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٧٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ أفَلا تُبْصِرُون﴾</span>، قال: سبيل الغائط والبول{1}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ أفَلا تُبْصِرُون﴾</span>: يريد: اختلاف الألسنة، والصُّور، والألوان، والطبائع{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزبير</span> -من طريق ابن المرتفع- في قوله: <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ أفَلا تُبْصِرُون﴾</span>، قال: سبيل الغائط والبول{3}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ أفَلا تُبْصِرُون﴾</span>، قال: مَن تَفكّر في خَلْقه علِم أنّما لِينَت مفاصلُه للعبادة{4}. (١٣/٦٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ﴾</span>، قال: يقول: في خَلْقه أيضًا إذا فكّر، فيه مُعتبر{5}. (١٣/٦٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ أفَلا تُبْصِرُون﴾</span>، قال: ما يدخل من طعامكم، وما يخرج{6}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي﴾</span> خَلْق <span class="qpc-hafs">﴿أنْفُسِكُمْ﴾</span> حين كنتم نُطفة، ثم عَلقَة، ثم مُضغة، ثم عظامًا، ثم لحمًا، ثم ينفخ فيه الروح، ففي هذا كله آية <span class="qpc-hafs">﴿أفَلا﴾</span> يعني: أفهلّا <span class="qpc-hafs">﴿تُبْصِرُونَ﴾</span> قدرة الرّبّ تعالى أنّ الذي خلقكم قادر على أن يبعثكم كما خلقكم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>-من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وفِي أنْفُسِكُمْ أفَلا تُبْصِرُونَ﴾</span>، وقرأ قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿ومِن آياتِهِ أنْ خَلَقَكُمْ مِن تُرابٍ ثُمَّ إذا أنْتُمْ بَشَرٌ تَنْتَشِرُونَ﴾</span> [الروم:٢٠]، قال: وفينا آيات كثيرة؛ هذا السمع والبصر واللسان والقلب، لا يدري أحدٌ ما هو أسود أو أحمر، وهذا الكلام الذي يتلجلج به، وهذا القلب أيُّ شيء هو، إنما هو بِضْعَةٌ في جوفه، يجعل الله فيه العقل، أفيدري أحد ما ذاك العقل، وما صفته، وكيف هو؟{8}<span class=comment-ref>٦١٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٢</span> في قوله: <span class="qpc-hafs">﴿وفي أنفسكم أفلا تبصرون﴾</span> قولان: <b>الأول</b>: وفي سبيل الخلاء من البول والغائط عِبرة لكم. <b>الثاني</b>: وفي تسوية الله -تبارك وتعالى- مفاصل أبدانكم وجوارحكم دلالة لكم على أن خُلقتم لعبادته.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢١/٥٢٠) القولين، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">العموم</span> وقال: «الصواب من القول في ذلك أن يقال: معنى ذلك: وفي أنفسكم أيضًا -أيها الناس- آيات وعِبر تدلّكم على وحدانية صانعكم، وأنه لا إله لكم سواه؛ إذ كان لا شيء يقدر على أن يخلق مثل خلْقه إياكم، <span class="qpc-hafs">﴿أفلا تبصرون﴾</span> يقول: أفلا تنظرون في ذلك فتتفكّروا فيه؛ فتعلموا حقيقة وحدانية خالقكم».</div></p></div>",footnotes:1:عزاه السيوطي إلى الخرائطي في مساوئ الأخلاق.|2:تفسير البغوي ٧/٣٧٥.|3:أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥١٩، والبيهقي في شعب الإيمان (٨٢٠٨)، وابن أبي الدنيا في التواضع والخمول ٣/٥٧٦ (٢١٢)، وكتاب الجوع ٤/١٠٨ (١٦٩). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن المنذر، وابن أبي حاتم. وأخرجه الثعلبي في تفسيره ٩/١١٣ عن الزبير بن العوام.|4:أخرجه أبو الشيخ (١٨). وعلقه إسحاق البستي ص٤٢٨. وعزاه السيوطي إلى ابن جرير، وابن المنذر.|5:أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥١٨ مختصرًا، وأبو الشيخ في العظمة (١٧). وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن أبي حاتم -كما في الفتح ٨/٥٩٩-.|7:تفسير مقاتل بن سليمان ٤/١٢٩. وفي تفسير البغوي ٧/٣٧٥ بنحو آخره منسوبًا إلى مقاتل دون تعيينه.|8:أخرجه ابن جرير ٢١/٥١٩-٥٢٠.
  51,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِی ٱلسَّمَاۤءِ رِزۡقُكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٧٨<span class="dash">-</span></span> عن علي، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُون﴾</span>، قال: «<b>المطر</b>»{1}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٧٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ﴾</span>، يعني: المطر؛ الذي هو سبب الأرزاق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- قال: إنِّي لأعرفُ الثَّلج وما رأيته؛ في قوله: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُون﴾</span> قال: الثَّلج منه{3}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</span>، قال: الثَّلج، وكلّ عينٍ ذائبة مِن الثَّلج لا تنقص{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</span>، قال: رزقكم المطر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُويبر- في قوله: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ﴾</span>، قال: المطر{6}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبد الكريم- قال: في السحاب فيه -واللهِ- رزقكم، ولكنكم تُحرمونه بخطاياكم وأعمالكم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٥<span class="dash">-</span></span> عن سفيان الثوري، قال: قرأ <span class="name-2">واصلٌ الأحدب</span> هذه الآية: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</span>، فقال: ألا إنّ رزقي في السماء وأنا أطلبه في الأرض! فدخل خَرِبةً، فمكث ثلاثًا لا يُصِيب شيئًا، فلما كان اليوم الثالث إذا هو بِدَوْخَلَّةٍ{8} من رُطَب، وكان له أخٌ أحسن نيّة منه، فدخل معه، فصارتا دَوْخَلَّتَيْن، فلم يزل ذلك دأْبهما حتى فرّق الموتُ بينهما{9}<span class=comment-ref>٦١٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٣</span> نقل <u>ابنُ عطية</u> (٨/٦٩) عن مجاهد وواصل الأحدب قولهم في معنى الآية: «أراد القضاء والقدر». و<span class="comment-type-1">وجَّهه</span> بقوله: «أي: الرزق عند الله تعالى، يأتي به كيف شاء، لا ربَّ غيره».</div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ﴾</span>، يعني: المطر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ﴾</span>، قال: رزقكم المطر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٨٨<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ﴾</span>، قال: الغيث{12}<span class=comment-ref>٦١٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٤</span> <span class="comment-type-4">قال</span> <u>ابن جرير</u> (٢١/٥٢٠): «وقوله: <span class="qpc-hafs">﴿وفي السماء رزقكم﴾</span> يقول -تعالى ذكره-: <span class="qpc-hafs">﴿وفي السماء﴾</span> المطر والثلج اللذان بهما تخرج الأرض <span class="qpc-hafs">﴿رزقكم﴾</span> وقوتكم من الطعام والثمار وغير ذلك، <span class="mustanad">وبنحو الذي قلنا في ذلك قال بعض أهل التأويل</span>». وذكر آثار السلف الدالة على ذلك، ثم ذكر قول واصل الأحدب، ولم يعلّق عليه.</p><p>وقد <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٤٢) القول بأن الرزق المطر كما في آثار السلف، وزاد <b>قولين آخرين</b>، فقال: «أما الرزق ففُسّر بالمطر، وفُسّر بالجنة، وفُسّر برزق الدنيا والآخرة». ثم <span class="comment-type-4">علّق</span> قائلًا: «ولا ريب أن المطر من الرحمة، وأن الجنة مستقر الرحمة، فرِزْق الدارين في السماء التي هي في العلو».</div></p><p><h3><span class="qpc-hafs">﴿وَمَا تُوعَدُونَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</span>، يقول: الجنة في السماء، وما تُوعدون مِن خير أو شر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق رجل- <span class="qpc-hafs">﴿وما تُوعَدُونَ﴾</span>، يقول: الجنة والنار{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿وما تُوعَدُون﴾</span>، قال: الجنة والنار{15}. (١٣/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق أبي بكر بن عبد الله- قال: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</span> الساعة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩٣<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وما تُوعَدُون﴾</span> من الثواب والعقاب{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما تُوعَدُونَ﴾</span> مِن أمر الساعة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩٥<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وما تُوعَدُونَ﴾</span>: مِن الجنة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٥٩٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وما تُوعَدُونَ﴾</span>: الجنة{12}<span class=comment-ref>٦١٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٥</span> في قوله: <span class="qpc-hafs">﴿وما توعدون﴾</span> أقوال للسلف: <b>الأول</b>: ما توعدون مِن خير أو شرٍّ. <b>الثاني</b>: ما توعدون من الجنة والنار. <b>الثالث</b>: ما توعدون من أمر الساعة. <b>الرابع</b>: ما توعدون من الثواب والعقاب.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٥٢٣) <span class="mustanad">-مستندًا إلى دلالة العموم</span>- القول الأول، فقال: «لأنّ الله عمّ الخبر بقوله: <span class="qpc-hafs">﴿وما توعدون﴾</span> عن كل ما وُعِدنا من خير أو شر، ولم يخصّص بذلك بعضًا دون بعض، فهو على عمومه كما عمّه الله».</p><p>وقد ذكر <u>ابنُ القيم</u> (٣/٤٢-٤٣) هذه الأقوال، ثم <span class="comment-type-4">علّق</span> بقوله: «كون الجنة والخير في السماء فلا إشكال فيه، وكون النار في السماء وما يوعد به أهلها يحتاج إلى تبيين». ثم <span class="comment-type-4">علّق</span> بقوله: «فإذا نظرتَ إلى أسباب الخير والشر وأسباب دخول الجنة والنار وافتراق الناس وانقسامهم إلى شقيّ وسعيد وجدتَ ذلك كلّه بقضاء الله وقدره النازل مِن السماء، وذلك كلّه مُثبت في السماء في صحف الملائكة وفي اللوح المحفوظ قبل العمل وبعده، فالأمر كلّه من السماء. وقول من قال: من أمر الساعة؛ يكشف عن هذا المعنى، فإنّ أمر الساعة يأتي من السماء، وهو الموعود بها، فالجنة والنار الغاية التي لأجلها قامت الساعة». ثم <span class="comment-type-4">علّق</span> قائلًا: «فصح كل ما قال السلف في ذلك».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٦٩): «و<span class="qpc-hafs">﴿توعدون﴾</span> <b>يحتمل</b> أن يكون مِن الوعد، <b>ويحتمل</b> أن يكون من الوعيد، والكلّ في السماء».</div></p><p><h3><span class="qpc-hafs">﴿وَمَا تُوعَدُونَ ۝٢٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٩٧<span class="dash">-</span></span> عن إسماعيل بن أُميّة، قال -أحسبه أو غيره-: أنّ رسول الله ﷺ سمع رجلًا ومُطِروا يقول:</p><p>ومُطِرنا ببعض عَثانِينِ{21} الأسد</p><p>فقال: «<b>كذبتَ، بل هو رزق الله</b>»{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أورده الديلمي في الفردوس ٤/٤٠٧ (٧١٨٣). وعزاه السيوطي إلى ابن النقور.|2:تفسير البغوي ٧/٣٧٥.|3:أخرجه أبو الشيخ في العظمة (٧٦٣)، وابن أبي الدنيا في المطر والرعد والبرق والريح ٨/٤٣٣ (٧٩).|4:أخرجه ابن جرير ٢١/٥٢٠.|5:أخرجه ابن جرير ٢١/٥٢١، وابن أبي الدنيا في المطر والرعد والبرق والريح ٨/٤٣٣ (٧٨).|6:أخرجه ابن جرير ٢١/٥٢٠، وأبو الشيخ (٧٤٦).|7:أخرجه ابن جرير ٢١/٥٢١.|8:الدَّوخَلَّة -مُشَدَّدة اللّام-: خُوص يوضع فيه التمر والرطب. النهاية، ولسان العرب (دوخل).|9:أخرجه ابن جرير ٢١/٥٢١، وابن أبي الدنيا في الأولياء ٢/٤١١ (٨٤).|10:تفسير مقاتل بن سليمان ٤/١٢٩.|11:أخرجه ابن جرير ٢١/٥٢١.|12:أخرجه إسحاق البستي ص٤٢٩.|13:تفسير مجاهد ص٦١٩، وأخرجه ابن جرير ٢١/٥٢٢.|14:أخرجه إسحاق البستي ص٤٢٨.|15:أخرجه ابن جرير ٢١/٥٢٢، وأبو الشيخ (٧٤٦).|16:أخرجه الثعلبي ٩/١١٤.|17:تفسير البغوي ٤/٢٨٤.|18:تفسير مقاتل بن سليمان ٤/١٢٩.|19:أخرجه ابن جرير ٢١/٥٢٣.|20:أخرجه إسحاق البستي ص٤٢٩.|21:قال سفيان -كما في التمهيد لابن عبد البر ١٦/٢٨٤-: عثانين الأسد: الذراع والجبهة. والذراع والجبهة من أسماء النجوم، كما في تفسير البغوي ٤/١٢١.|22:أخرجه ابن جرير ٢١/٥٢١ مرسلًا.
  51,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَرَبِّ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٩٨<span class="dash">-</span></span> عن الحسن البصري في قوله: <span class="qpc-hafs">﴿فَوَرَبِّ السَّماءِ والأَرْض﴾</span> الآية قال: بلغني أن رسول الله ﷺ قال: «<b>قاتل الله أقوامًا أقْسَم لهم ربّهم بنفسه فلم يُصدّقوه</b>»{1}. (١٣/٦٨٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَحَقࣱّ مِّثۡلَ مَاۤ أَنَّكُمۡ تَنطِقُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٥٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَوَرَبِّ السَّماءِ والأَرْضِ إنَّهُ لَحَقٌّ﴾</span> يعني: لكائن، يعني: أمر الساعة <span class="qpc-hafs">﴿مِثْلَ ما أنَّكُمْ تَنْطِقُونَ﴾</span> يعني: تتكلمون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿فَوَرَبِّ السَّماءِ والأَرْضِ إنَّهُ لَحَقّ﴾</span>، قال: لكلّ شيء ذَكَرَه في هذه السورة{3}. (١٣/٦٨٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَحَقࣱّ مِّثۡلَ مَاۤ أَنَّكُمۡ تَنطِقُونَ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٠١<span class="dash">-</span></span> عن أبي العلاء بن الشِّخِّير –من طريق الجريري- قال: لَمّا نَزَلَتْ: <span class="qpc-hafs">﴿فَوَرَبِّ السَّماءِ والأَرْضِ إنَّهُ لَحَقٌّ مِثْلَ ما أنَّكُمْ تَنْطِقُونَ﴾</span> خرج رجال بأيديهم العصي، قالوا: أين الذين كلَّفوا ربنا حتى حلف؟!{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٢٣. وعزاه السيوطي إلى أبي حاتم مرسلًا.|2:تفسير مقاتل بن سليمان ٤/١٢٩.|3:عزاه السيوطي إلى ابن المنذر.|4:ذكره الحافظ في المطالب العالية (إشراف: د. سعد الشثري) ١٥/٢٧٨ (٣٧٢٩).
  51,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ أَتَىٰكَ حَدِیثُ ضَیۡفِ إِبۡرَ ٰ⁠هِیمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٠٢<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ضَيْفِ إبْراهِيمَ المُكْرَمِين﴾</span> كانوا ثلاثة: جبريل، وميكائيل، ومعهما مَلك آخر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٠٣<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿ضَيْفِ إبْراهِيمَ المُكْرَمِين﴾</span> كان جبريل ومعه سبعة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ أتاكَ﴾</span> يعني: قد أتاك يا محمد <span class="qpc-hafs">﴿حَدِيثُ ضَيْفِ إبْراهِيمَ المُكْرَمِينَ﴾</span> يعني: جبريل، وميكائيل، ومَلك آخر{3}<span class=comment-ref>٦١٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٦</span> نقل <u>ابنُ عطية</u> (٨/٧٣) <b>رواية</b> ولم ينسبها: «أن أضياف إبراهيم ﵇ هؤلاء: هم جبريل، وميكائيل، وإسرافيل، وأتباع لهم من الملائكة».</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡمُكۡرَمِینَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٠٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿المُكْرَمِينَ﴾</span> سماهم مُكرمين لأنهم جاؤوا غير مَدْعُوّين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ضَيْفِ إبْراهِيمَ المُكْرَمِين﴾</span>، قال: خِدْمته إيّاهم بنفسه{5}. (١٣/٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ضَيْفِ إبْراهِيمَ المُكْرَمِين﴾</span>، قال: أكرمهم إبراهيم بالعِجل{6}<span class=comment-ref>٦١٩٧</span>. (١٣/٦٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٧</span> لم يذكر <u>ابنُ جرير</u> (٢١/٥٢٥) غير قول مجاهد.</p><p>ونقل <u>ابنُ عطية</u> (٨/٧٣) في معنى الآية <b>قولين</b> آخرين، فقال: «وجعلهم تعالى مُكرمين إما لأنهم عنده كذلك، وهذا قول الحسن ... وقيل: من حيث رفع مجالسهم».</p><p>وذكر <u>ابنُ القيم</u> (٣/٤٥) في قوله: <span class="qpc-hafs">﴿المكرمين﴾</span> قولين: <b>الأول</b>: أنهم مُكرمون لأن إبراهيم ﵇ أكرمهم بنفسه. <b>الثاني</b>: أنهم المُكرمون عند الله. ثم <span class="comment-type-4">علّق</span> بقوله: «ولا تنافي بين القولين؛ فالآية تدل على المعنيين».</div></p><p><div></p><p><p><span class="item-no">٧٢٦٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ أتاكَ حَدِيثُ ضَيْفِ إبْراهِيمَ المُكْرَمِينَ﴾</span> ... أكرمهم إبراهيم وأحسن القيام، ورأى هيئتهم حسنة، وكان لا يقوم على رأس ضيف قبل هؤلاء، فقام هو وامرأته سارة لخِدْمتهم، فسلّمَت الملائكة على إبراهيم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١١٦.|2:تفسير الثعلبي ٩/١١٦.|3:تفسير مقاتل بن سليمان ٤/١٢٩-١٣٠.|4:تفسير الثعلبي ٩/١١٦، وتفسير البغوي ٧/٣٧٦، وجاء في طبعة دار التفسير من تفسير الثعلبي ٢٤/٥٤٣: غير مذعورين.|5:أخرجه ابن أبي الدنيا في قرى الضيف (٨)، والثعلبي ٩/١١٦-١١٧، والبيهقي في شعب الإيمان (٩٦٣٦). وعزاه السيوطي إلى ابن المنذر.|6:تفسير مجاهد ص٦١٩، وأخرجه ابن جرير ٢١/٥٢٥ بلفظ: أكرمهم إبراهيم، وأمر أهله لهم بالعجل حينئذ. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:تفسير مقاتل بن سليمان ٤/١٢٩-١٣٠.
  51,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰاۖ قَالَ سَلَـٰمࣱ قَوۡمࣱ مُّنكَرُونَ ۝٢٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٠٩<span class="dash">-</span></span> قال سفيان الثوري: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (قالُواْ سِلْمًا قالَ سِلْمٌ){1}<span class=comment-ref>٦١٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٨</span> ذكر <u>ابنُ جرير</u> (٢١/٥٢٦) هذه القراءة، وقراءة من قرأ ذلك بالألف، و<span class="comment-type-1">وجّههما</span> فقال: «واختلفت القراء في قراءة ذلك، فقرأته عامة قراء المدينة والبصرة: <span class="qpc-hafs">﴿قال سلام﴾</span> بالألف بمعنى: قال إبراهيم لهم: سلام عليكم. وقرأ ذلك عامة قراء الكوفة: ‹سِلْمٌ› بغير ألف، بمعنى قال: أنتم سِلم».</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٨/٧٣) هذه القراءة، فقال: «وقرأ ابن وثّاب، والنخعي، وحمزة، والكسائي، وطلحة، وابن جبير: ‹قالَ سِلْمٌ› بكسر السين وسكون اللام. والمعنى: نحن سِلم وأنتم سِلم».</div></p><p><h3><span class="qpc-hafs">﴿إِذۡ دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰاۖ قَالَ سَلَـٰمࣱ قَوۡمࣱ مُّنكَرُونَ ۝٢٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٦١٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إذْ دَخَلُوا عَلَيْهِ فَقالُوا سَلامًا قالَ سَلامٌ قَوْمٌ مُنْكَرُونَ﴾</span>، قال في نفسه: هؤلاء قوم لا نعرفهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦١١<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحي</span>: <span class="qpc-hafs">﴿إذْ دَخَلُوا عَلَيْهِ فَقالُوا سَلامًا قالَ سَلامٌ قَوْمٌ مُنْكَرُونَ﴾</span> أنكَر سلامهم في ذلك الزمان، وفي تلك الأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذْ دَخَلُوا عَلَيْهِ فَقالُوا سَلامًا﴾</span> فردّ عليهم إبراهيم، فقال: <span class="qpc-hafs">﴿سَلامٌ قَوْمٌ مُنْكَرُونَ﴾</span> يقول: أنكرهم إبراهيم ﷺ، وظنّ أنهم مِن الإنس{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه سفيان الثوري ص٢٨١.</p><p>وهي قراءة شاذة.|2:تفسير البغوي ٧/٣٧٦.|3:تفسير البغوي ٧/٣٧٦.|4:تفسير مقاتل بن سليمان ٤/١٣٠.
  51,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرَاغَ إِلَىٰۤ أَهۡلِهِۦ فَجَاۤءَ بِعِجۡلࣲ سَمِینࣲ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَراغَ إلى أهْلِهِ فَجاءَ بِعِجْلٍ سَمِين﴾</span>، قال: كان عامَّة مالِ إبراهيم البقر{1}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَراغَ﴾</span> يعني: فمال <span class="qpc-hafs">﴿إلى أهْلِهِ فَجاءَ﴾</span> إليهم <span class="qpc-hafs">﴿بِعِجْلٍ سَمِينٍ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٢٦ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٣٠.
  51,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَرَّبَهُۥۤ إِلَیۡهِمۡ قَالَ أَلَا تَأۡكُلُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: أتى الرسل إبراهيم حين بُعثوا إلى قوم لوط فنزلوا به يستضيفونه فجاءهم بالعِجل الحَنيذ، قال: فلما وُضع بين أيديهم كفّوا عنه، فلم يتناولوا منه شيئًا، فقال لهم إبراهيم حين رآهم لا يطعمون: ما لكم لا تطعمون؟ قالوا: إنّا لا نُصيب طعامًا إلا بثمن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقَرَّبَهُ إلَيْهِمْ﴾</span> وهو مشوي، وقال إبراهيم: <span class="qpc-hafs">﴿ألا تَأْكُلُونَ﴾</span> فقالوا: يا إبراهيم، لا نأكل إلا بالثمن. قال إبراهيم: كُلوا، وأَعطوا الثمن. فقالوا: وما ثمنه؟ قال: إذا أكَلتم فقولوا: بسم الله، وإذا فَرغتم فقولوا: الحمد لله. فعجبت الملائكة لقوله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَرَّبَهُۥۤ إِلَیۡهِمۡ قَالَ أَلَا تَأۡكُلُونَ ۝٢٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٦١٧<span class="dash">-</span></span> عن <span class="name-2">عَون بن أبي شَدّاد</span> -من طريق نوح بن قيس-: أنّ ضيف إبراهيم المُكرمين لما دخلوا عليه فقرَّب إليهم العجل مشويًّا، فمَسحه جبريل ﵇ بجناحه، فقام العِجل يَدْرُجُ{3} في الدار حتى لحق بأمه، فحينئذ عرف أنهم ملائكة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٤٢٩، وابن جرير مطولًا ١٢/٤٧٣.|2:تفسير مقاتل بن سليمان ٤/١٣٠.|3:يَدْرُج: يمشي. النهاية واللسان (درج).|4:أخرجه الثعلبي ٩/١١٧.
  51,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَوۡجَسَ مِنۡهُمۡ خِیفَةࣰۖ قَالُوا۟ لَا تَخَفۡۖ وَبَشَّرُوهُ بِغُلَـٰمٍ عَلِیمࣲ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بَشَّرُوهُ بِغُلامٍ عَلِيم﴾</span>، قال: هو إسماعيل{1}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَوْجَسَ مِنهُمْ خِيفَةً﴾</span> فخاف، وأخذته الرّعدة، وضحكت امرأته سارة وهي قائمة مِن رعدة إبراهيم، وقالت في نفسها: إبراهيم معه أهله وولده وخَدمه، وهؤلاء ثلاثة نَفرٍ! فقال جبريل -صلى الله عليه- لسارة: أيتها الصالحة، إنّكِ ستلدين غلامًا. فذلك قوله: <span class="qpc-hafs">﴿قالُوا لا تَخَفْ وبَشَّرُوهُ بِغُلامٍ﴾</span> يعني: إسحاق، <span class="qpc-hafs">﴿عَلِيمٍ﴾</span> يعني: حليم{2}<span class=comment-ref>٦١٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩٩</span> اختلف السلف في قوله: <span class="qpc-hafs">﴿وبشروه بغلام عليم﴾</span> على قولين: <b>الأول</b>: أنه إسحاق. <b>الثاني</b>: أنه إسماعيل.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٥٢٧) <span class="mustanad">-مستندًا إلى دلالة ظاهر اللفظ، والتاريخ</span>- أن المُبشَّر به هو إسحاق، وعلَّل ذلك بقوله: «وإنما قلتُ: عني به إسحاق؛ لأن البشارة كانت بالولد من سارة، وإسماعيل لهاجر لا لسارة».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٨/٧٤) بقوله: «والأول أرجح». و<span class="comment-type-2">انتقد</span> الثاني بقوله: «وهذا وهم».</div></p></div>",footnotes:1:تفسير مجاهد ص٦١٩، وأخرجه ابن جرير ٢١/٥٢٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٤/١٣٠.
  51,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَقۡبَلَتِ ٱمۡرَأَتُهُۥ فِی صَرَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلَتِ امْرَأَتُهُ فِي صَرَّة﴾</span>، قال: في صيحة{1}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فِي صَرَّة﴾</span>، قال: صيحة{2}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فِي صَرَّةٍ﴾</span>: يعني: صيحة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فِي صَرَّةٍ﴾</span>، قال: أقْبَلتْ تَرِنّ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٤<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن عبد الله بن سابِط الجُمَحيّ</span> -من طريق العلاء بن عبد الكريم اليامي- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلَتِ امْرَأَتُهُ فِي صَرَّةٍ﴾</span>، قال: في صيحة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٥<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي رافع</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿فأقبلت امرأته في صرة﴾</span>، قال: صيحة، فَوَلْوَلَتْ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَقْبَلَتِ امْرَأَتُهُ﴾</span> سارة <span class="qpc-hafs">﴿فِي صَرَّةٍ﴾</span> يعني: في صيحة، وقالت: أوه، يا عجباه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلَتِ امْرَأَتُهُ فِي صَرَّةٍ﴾</span>، قال: الصّرة: الصيحة{3}<span class=comment-ref>٦٢٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٠</span> نقل <u>ابنُ عطية</u> (٨/٧٤، ٧٥) في معنى: <span class="qpc-hafs">﴿في صَرَّةٍ﴾</span> عن النحاس قوله: «وقيل: <span class="qpc-hafs">﴿في صَرَّةٍ﴾</span> في جماعة نسوة يتبادرن نظرًا إلى الملائكة».</div></p><p><h3><span class="qpc-hafs">﴿فَصَكَّتۡ وَجۡهَهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق على- في قوله: <span class="qpc-hafs">﴿فَصَكَّتْ﴾</span>، قال: لَطَمَتْ{9}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span>، قال: ضربت بيدها على جبهتها، وقالت: يا ويلتاه{10}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span>، قال: وضَعتْ راحتها على جبهتها؛ كالإنسان إذا عجب{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣١<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن عبد الله بن سابِط الجُمَحيّ</span> -من طريق سفيان، عن العلاء بن عبد الكريم اليامي- في قوله: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span>، قال: قالت هكذا. وضرب سفيان بيده على جبهته{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا بشَّر جبريل سارة بإسحاق، ومن وراء إسحاق يعقوب، ضَربتْ جبهتها عجبًا، فذلك قوله: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span>، يعني: فضَربتْ بيدها جبينها أو خدّها تَعجُّبًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿فصكت وجهها﴾</span>، قال: ضربت على جبينها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٥<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span>: وضَعتْ يدها على جبهتها تَعجُّبًا{12}<span class=comment-ref>٦٢٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠١</span> اختلف السلف في قوله: <span class="qpc-hafs">﴿فصكت وجهها﴾</span> على قولين: <b>الأول</b>: لَطَمَت. <b>الثاني</b>: معناه: ضَربتْ بيدها جبهتها.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢١/٥٣٠) القولين، ثم قال <span class="comment-type-4">معلّقًا</span>: «<span class="mustanad">والصّكّ عند العرب</span>: هو الضرب. وقد قيل: إنّ صكّها وجهها، أن جمعت أصابعها، فضَربتْ بها جبهتها».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٧٥) على الأول، فقال: «وهذا مما يفعله الذي يَرِد عليه أمر يَسْتَهْوله». و<span class="comment-type-4">علّق</span> على الثاني، فقال: «وهذا مستعمل في الناس حتى الآن».</div></p><p><h3><span class="qpc-hafs">﴿وَقَالَتۡ عَجُوزٌ عَقِیمࣱ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٣٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق مُشاش- أنّه سُئل عن: <span class="qpc-hafs">﴿عَجُوزٌ عَقِيم﴾</span>، وعن: <span class="qpc-hafs">﴿الرِّيحَ العَقِيم﴾</span> [الذاريات:٤١]، وعن: <span class="qpc-hafs">﴿عَذابُ يَوْمٍ عَقِيمٍ﴾</span> [الحج:٥٥]، فقال: العجوز العقيم: التي لا ولد لها، وأما الريح العقيم: فالتي لا بركة فيها ولا منفعة ولا تُلقِح، وأما عذاب يوم عقيم: فيوم لا ليلة له{17}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لما قال لها جبريل: إنّك ستلدين. فضَربتْ جبهتها، فذلك قوله: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها وقالَتْ عَجُوزٌ عَقِيمٌ﴾</span>، كنتُ شابّة عقيم، فكيف وأنا اليوم عجوز؟! فضَحكتْ تَعَجُّبًا، وقالت: أنا ألد؟! كيف يكون هذا وأنا عجوز وهذا بَعْلي شيخًا؟!{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَتْ عَجُوزٌ﴾</span> مِن الكِبَر، <span class="qpc-hafs">﴿عَقِيمٌ﴾</span> مِن الولد{19}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٢٨-٥٢٩ من طريقي علي وعطية، وابن أبي حاتم -كما في الإتقان ٢/٤٤-. وعزاه ابن حجر في الفتح ٨/٦٠٠ إلى ابن أبي حاتم من طريق مجاهد، وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٦٢٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٩-، وابن جرير ٢١/٥٢٨. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|3:أخرجه ابن جرير ٢١/٥٢٩.|4:أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥٢٨-٥٢٩ من طريقي معمر وسعيد.|5:أخرجه ابن جرير ٢١/٥٢٩.|6:أخرجه ابن عساكر في تاريخ دمشق ٦٩/١٨٨.|7:تفسير مقاتل بن سليمان ٤/١٣٠.|8:أخرجه ابن جرير ٢١/٥٢٩.|9:أخرجه ابن جرير ٢١/٥٢٩، وابن أبي حاتم -كما في الإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.|10:تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٣٠ مختصرًا، وأخرجه سعيد بن منصور -كما في الفتح ٨/٥٩٩- من طريق الأعمش.. وعزاه السيوطي إلى ابن المنذر.|11:أخرجه إسحاق البستي ص٤٣٠.|12:أخرجه ابن جرير ٢١/٥٣٠.|13:أخرجه ابن جرير ٢١/٥٣٠.|14:تفسير مقاتل بن سليمان ٤/١٣٠.|15:أخرجه ابن جرير ١٢/٤٨١.|16:أخرجه ابن جرير ٢١/٥٣٠.|17:أخرجه ابن جرير ٢١/٥٣١ مختصرًا بنحوه، كذلك من طريق أبي ساسان أيضًا، وأخرجه ابن المنذر -كما في الفتح ٨/٦٠١- مختصرًا. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|18:أخرجه إسحاق البستي ص٤٣٠.|19:تفسير مقاتل بن سليمان ٤/١٣٠-١٣١.
  51,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ كَذَ ٰ⁠لِكِ قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ ٱلۡحَكِیمُ ٱلۡعَلِیمُ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿قالَ رَبُّكِ﴾</span> ستلدين غلامًا، <span class="qpc-hafs">﴿إنَّهُ هُوَ الحَكِيمُ﴾</span> حكَم أمر الولد في بطن سارة، <span class="qpc-hafs">﴿العَلِيمُ﴾</span> بخلْقه{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣٠-١٣١.