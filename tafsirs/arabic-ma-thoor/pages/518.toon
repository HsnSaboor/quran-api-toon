quran[15]{c,v,t}:
50,1," مقدمة السورة ٧١٨٨٩- عن أبي أُمامة، قال: قال رسول الله ﷺ: «أعطاني ربّي السَّبع الطُّوَل مكان التوراة، والمِئين مكان الإنجيل، وفُضِّلتُ بالمُفصّل»{1}. (١٣/٦٠٧) ٧١٨٩٠- عن أبي قِلابة، عن النبيِّ ﷺ، قال: «أُعطِيتُ السَّبع مكان التوراة، وأُعطِيتُ المثاني مكان الإنجيل، وأُعطِيتُ كذا مكان الزَّبُور، وفُضِّلتُ بالمُفصّل»{2}. (١٣/٦٠٨) ٧١٨٩١- عن واثِلة، قال: قال رسول الله ﷺ: «أُعطيتُ مكان التوراة السَّبع الطُّوال، وأُعطِيتُ مكان الزَّبُور المِئين، وأُعطِيتُ مكان الإنجيل المثاني، وفُضِّلتُ بالمُفصّل»{3}. (١٣/٦٠٩) ٧١٨٩٢- عن أوْس بن حُذَيفة، قال: قدِمنا في وفْد ثَقِيف، فسألتُ أصحاب رسول الله ﷺ: كيف تُحزِّبون القرآن؟ قالوا: ثلاث، وخمس، وسبع، وتسع، وإحدى عشرة، وثلاث عشرة، وحزب المُفصّل وحده{4}. (١٣/٦١٠) ٧١٨٩٣- عن عبد الله بن مسعود -من طريق عبد الله بن حبيب- قال: نزل المُفصّل بمكة، فمكثنا حِجَجًا نقرؤه لا ينزل غيره{5}. (١٣/٦٠٩) ٧١٨٩٤- عن عبد الله بن مسعود -من طريق المسيّب- قال: الطُّوَل كالتوراة، والمئُون كالإنجيل، والمثاني كالزَّبُور، وسائر القرآن بعدُ فضلٌ على الكتب{6}. (١٣/٦٠٨) ٧١٨٩٥- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: إنّ لكلّ شيء لُبابًا، وإنّ لُباب القرآن المُفصّل{7}. (١٣/٦٠٩) ٧١٨٩٦- عن عبد الله بن عباس -من طريق مجاهد-: مكِّيَّة{8}. (ز) ٧١٨٩٧- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكِّيَّة، وذكرها بمسمى: <q>﴿ق والقرآن المجيد﴾</q>، وأنها نزلت بعد سورة المرسلات{9}. (ز) ٧١٨٩٨- عن عبد الله بن عباس، قال: نزلت سورة ق بمكّة{10}. (١٣/٦٠٩) ٧١٨٩٩- عن عبد الله بن الزبير، مثله{10}. (١٣/٦٠٩) ٧١٩٠٠- عن عكرمة مولى ابن عباس= (ز) ٧١٩٠١- والحسن البصري -من طريق يزيد النحوي-: مكِّيَّة، وذكراها بمسمى: <q>﴿ق والقرآن المجيد﴾</q>{12}. (ز) ٧١٩٠٢- عن قتادة بن دعامة -من طرق-: مكِّيَّة{13}. (ز) ٧١٩٠٣- عن محمد بن مسلم الزُّهريّ: مكِّيَّة، وذكرها <q>﴿ق والقرآن المجيد﴾</q>، وأنها نزلت بعد سورة المرسلات{14}. (ز) ٧١٩٠٤- عن علي بن أبي طلحة: مكِّيَّة{15}. (ز) ٧١٩٠٥- قال مقاتل بن سليمان: سورة ق مكِّيَّة، عددها خمس وأربعون آية كوفيّة{16}٦١١٨. (ز) ٦١١٨ ذكر ابنُ عطية (٨/٢٩) أن هذه السورة مكية بإجماع من المتأولين. <q>﴿قۤۚ﴾</q> - تفسير ٧١٩٠٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ق﴾</q> و<q>﴿ن﴾</q> [القلم: ١] وأشباه هذا: فإنه قسَمٌ أقسَمه الله، وهو اسم من أسماء الله{17}. (١٣/٦١٢) ٧١٩٠٧- عن عبد الله بن عباس، أنه قال: <q>﴿ق﴾</q> هو جبل أخضر من زُمُرّد، خُضرة السماء منه{18}. (ز) ٧١٩٠٨- عن عبد الله بن عباس -من طريق عكرمة- قال: خلَق الله جبلًا يُقال له: ق، محيط بالعالم، وعروقه إلى الصخرة التي عليها الأرض، فإذا أراد الله أن يُزلزل قريةً أمر ذلك الجبل، فحرَّك ذلك العِرْق الذي يلي تلك القرية، فيُزلزِلها ويحرِّكها، فمِن ثَمَّ تَحَرَّك القريةُ دون القرية{19}. (١٣/٦١٣) ٧١٩٠٩- عن عبد الله بن عباس -من طريق ليث بن أبي سليم، عن مجاهد- قال: خلَق الله تعالى مِن وراء هذه الأرض بحرًا محيطًا بها، ثم خلق مِن وراء ذلك جبلًا يُقال له: ق، السماء الدنيا مُترفرِفة عليه، ثم خلَق من وراء ذلك الجبل أرضًا مثل تلك الأرض سبع مرات، ثم خلق مِن وراء ذلك بحرًا محيطًا بها، ثم خلق من وراء ذلك جبلًا يُقال له: ق، السماء الثانية مُترفرِفة عليه، حتى عدَّ سبع أرَضين، وسبعة أبحر، وسبعة أجبُل، وسبع سموات، قال: وذلك قوله: <q>﴿والبَحْرُ يَمُدُّهُ مِن بَعْدِهِ سَبْعَةُ أبْحُرٍ﴾</q> [لقمان:٢٧]{20}٦١١٩. (١٣/٦١٢) ٦١١٩ ذكر ابن كثير (١٣/١٨٠-١٨١) أنه أثر غريب لا يصحّ سنده عن ابن عباس، وقال: «والذي رواه ابن أبي طلحة، عن ابن عباس في قوله: <q>﴿ق﴾</q> قال: هو اسم من أسماء الله ﷿. والذي ثبت عن مجاهد: أنه حرف من حروف الهجاء، كقوله: (ص، ن، حم، طس، الم) ونحو ذلك. فهذه تبعد ما تقدم عن ابن عباس». ٧١٩١٠- عن عبد الله بن بُرَيدة، في قوله: <q>﴿ق﴾</q>، قال: جبل من زُمُرّد، محيط بالدنيا، عليه كَنَفا السماء{21}. (١٣/٦١٣) ٧١٩١١- عن مجاهد بن جبر -من طريق عبد الملك ابن جُرَيْج- قال: <q>﴿ق﴾</q> جبل محيط بالأرض{22}. (١٣/٦١٣) ٧١٩١٢- قال عكرمة مولى ابن عباس= (ز) ٧١٩١٣- والضَّحّاك بن مُزاحِم: <q>﴿ق﴾</q> هو جبل محيط بالأرض، مِن زُمُرّدة خضراء، خُضرة السماء منه، وعليه كتفا السماء، والسماء عليه مُقَبَّبة، وما أصاب الناس مِن زُمُرّد فهو مِمّا تساقط مِن ذلك الجبل{23}. (ز) ٧١٩١٤- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿ق﴾</q> اسم مِن أسماء القرآن{24}. (١٣/٦١٣) ٧١٩١٥- قال محمد بن كعب القُرَظيّ: <q>﴿ق﴾</q> افتتاح أسماء الله: قدير، وقادر، وقاهر، وقاض، وقابض{25}. (ز) ٧١٩١٦- قال مقاتل بن سليمان: <q>﴿ق﴾</q> جبل مِن زُمُرُّدة خضراء، محيط بالعالم، فخُضرة السماء منه، ليس من الخلْق شيء على خَلْقه، وتنبت الجبال منه، وهو وراء الجبال، وعروق الجبال كلّها مِن قاف، فإذا أراد الله تعالى زلزلة أرضٍ أوحى إلى المَلَك الذي عنده أن يُحَرِّك عِرقًا مِن الجبل، فتتحرك الأرض التي يريد، وهو أول جبل خُلِقَ، ثم أبو قبيس بعده، وهو الجبل الذي الصفا تحته ودون قاف بمسيرة سنة، جبلٌ تغرب فيه الشمس، يُقال له: الحجاب، فذلك قوله: <q>﴿حَتّى تَوارَتْ بِالحِجابِ﴾</q> [ص:٣٢] يعني: بالجبل، وهو من وراء الحجاب، وله وجهٌ كوجه الإنسان، وقلبٌ كقلوب الملائكة في الخشية لله{26}٦١٢٠. (ز) ٦١٢٠ انتقد ابنُ كثير (١٣/١٨٠) القول بأن «ق»: جبل محيط بالأرض مستندًا للدلالة العقلية، فقال: «وكأنّ هذا -والله أعلم- من خرافات بني إسرائيل التي أخذها عنهم بعض الناس، لما رأى من جواز الرواية عنهم فيما لا يُصدّق ولا يُكذّب. وعندي أن هذا وأمثاله وأشباهه من اختلاق بعض زنادقتهم، يُلبّسون به على الناس أمر دينهم، كما افُتري في هذه الأمة -مع جلالة قدْر علمائها وحفّاظها وأئمتها- أحاديث عن النبي ﷺ وما بالعهد مِن قِدَم، فكيف بأمة بني إسرائيل مع طول المدى، وقلّة الحفّاظ النُّقّاد فيهم، وشُرْبهم الخمور، وتحريف علمائهم الكَلِم عن مواضعه، وتبديل كتب الله وآياته! وإنما أباح الشارعُ الرواية عنهم في قوله: «وحدِّثوا عن بني إسرائيل، ولا حرج» فيما قد يجوّزه العقل، فأما فيما تحيله العقول، ويُحكم عليه بالبطلان، ويغلب على الظّنون كذبه، فليس من هذا القبيل». ونقل (١٣/١٨١) قولًا آخر بأن المراد بـ<q>﴿ق﴾</q>: «قُضي الأمر، والله». وأن قوله: <q>﴿ق﴾</q> دلّتْ على المحذوف من بقيّة الكَلِم كقول الشاعر: قلت لها: قفي فقالت: قاف وانتقده مستندًا للغة، فقال: «وفي هذا التفسير نظر؛ لأنّ الحذف في الكلام إنما يكون إذا دلّ دليل عليه، ومِن أين يُفهم هذا من ذِكر هذا الحرف؟». وساق ابنُ عطية (٨/٣٠-٣١) الأقوال الواردة عدا قول القُرظيّ، ثم علَّق بقوله: «و<q>﴿ق﴾</q> على هذه الأقوال: مُقسَم به وبالقرآن المجيد، وجواب القسم منتظَر». وذكر القول الذي قاله ابن كثير، وذكر أقوالًا غيرها، فقال: «قال القُرظيّ: هو دال على أسماء الله تعالى هي: قادر، وقاهر، وقريب، وقاض، وقابض. وقيل: المعنى: قُضي الأمر من رسالتك ونحوه، <q>﴿والقرآن المجيد﴾</q> فجواب القسم في الكلام الذي يدل عليه قاف. وقال قوم: المعنى: قِف عند أمرنا. وقيل المعنى: قُهر هؤلاء الكفرة، وهذا أيضًا وقع عليه القسَم». ثم أورد احتمالًا آخر، فقال: «ويحتمل أن يكون المعنى: قيامهم من القبور حق، والقرآن المجيد». وعلق عليه بقوله: «فيكون أول السورة مِن المعنى الذي اطَّرد بعد»، ثم قال: «وعلى هذه الأقوال فثَمّ كلام مضمر عنه وقع الإضراب، كأنه قال: ما كذّبوك ببرهان، ونحو هذا مما يليق مظهرًا». <q>﴿قۤۚ﴾</q> - آثار متعلقة بالآية ٧١٩١٧- قال وهْب بن مُنَبِّه: إنّ ذا القرنين أتى وأَشْرَفَ على جبل قاف، فرأى تحته وحوله جبالًا صغارًا، فقال له: ما أنت؟ قال: أنا قاف. قال: فما هذه الجبال حولك؟ قال: هي عروقي، وما من مدينة من المدائن إلا وفيها عِرْقٌ من عروقي، فإذا أراد الله ﷿ أن يُزلزل تلك الأرض أمرني، فحرّكتُ عِرقي ذلك، فتزلزلت تلك الأرض. فقال له: يا قاف، فأخبِرْني بشيءٍ مِن عظمة الله. قال: إنّ شأن ربّنا لعظيم، تَقْصُرُ عنه الصفات، وتنقضي دونه الأوهام. قال: فأخبِرني بأدنى ما يوصف منها. قال: إنّ ورائي لَأرضًا مسيرة خمسمائة عام، في عَرض خمسمائة عام، مِن جبال ثلجٍ يَحْطِمُ بعضه بعضًا، لولا ذاك الثلج لاحترقتُ من حرّ جهنم. قال: زدني. قال: إنّ جبريل ﵇ واقف بين يدي الله سبحانه تَرْعُدُ فرائصه، يخْلق الله من كل رِعْدَةٍ مائة ألف مَلك، فأولئك الملائكة وقوف وصفوف بين يدي الله سبحانه، مُنكِّسو رؤوسهم، فإذا أذن الله لهم في الكلام قالوا: لا إله إلا الله، وهو قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا لا يَتَكَلَّمُونَ إلّا مَن أذِنَ لَهُ الرَّحْمَنُ وقالَ صَوابًا﴾</q> [النبأ:٣٨]، يعني: قول: لا إله إلا الله{27}. (ز) <q>﴿وَٱلۡقُرۡءَانِ ٱلۡمَجِیدِ ۝١﴾</q> - تفسير ٧١٩١٨- عن عبد الله بن عباس -من طريق علي- <q>﴿والقُرْآنِ المَجِيدِ﴾</q>، قال: الكريم{28}. (١٣/٦١٤) ٧١٩١٩- عن عبد الله بن عباس، قال: <q>﴿والقُرْآنِ المَجِيدِ﴾</q> ليس شيء أحسن منه ولا أفضل{29}. (١٣/٦١٤) ٧١٩٢٠- عن سعيد بن جُبَير -من طريق جعفر بن أبي المُغيرة- <q>﴿ق والقُرْآنِ المَجِيدِ﴾</q>، قال: الكريم{30}. (ز) ٧١٩٢١- قال مقاتل بن سليمان: <q>﴿والقُرْآنِ المَجِيدِ﴾</q>، يعني: والقرآن الكريم{26}. (ز) ",footnotes:1:أخرجه الطبراني في الكبير ٨/٢٥٨ (٨٠٠٣، ٨٠٠٤). قال الهيثمي في المجمع ٧/١٥٨ (١١٦٢٦): «فيه ليث بن أبي سليم، وقد ضعّفه جماعة، ويُعتبر بحديثه، وبقية رجاله رجال الصحيح».أخرجه ابن الضريس في فضائل القرآن ص٨٢ (١٥٧)، ص١٢٧ (٢٩٩)، وابن جرير ١/٩٦-٩٧ بنحوه. وقال الألباني في الصحيحة ٣/٤٦٩: «إسناده صحيح مرسل».أخرجه أحمد ٢٨/١٨٨ (١٦٩٨٢)، وابن جرير ١/٩٦، والثعلبي ٩/٦٨. قال المنذري في الترغيب والترهيب ٢/٢٤٠ (٢٢٤٢): «رواه أحمد، وفي إسناده عمران القطان». وقال ابن كثير في تفسيره ١/١٥٤ عن رواية نسبها لأبي عبيد: «هذا حديث غريب، وسعيد بن بشير فيه لين». وقال الهيثمي في المجمع ٧/٤٦ (١١١٠٩): «رواه أحمد، وفيه عمران القطان، وثّقه ابن حبان وغيره، وضعّفه النسائي وغيره، وبقية رجاله ثقات». وقال المناوي في التيسير ١/١٧٢: «وفيه عمران القطان». وقال الألباني في الصحيحة ٣/٤٦٩ (١٤٨٠): «وهذا إسناد حسن، رجاله ثقات رجال الشيخين، غير عمران القطان فهو حسن الحديث، للخلاف المعروف فيه ... فالحديث بمجموع طرقه صحيح».أخرجه ابن أبي شيبة ٢/٥٠١-٥٠٢، وأحمد ٢٦/٨٨-٨٩ (١٦١٦٦)، وأبو داود (١٣٩٣)، وابن ماجه (١٣٤٥).أخرجه الطبراني في الأوسط (٦٣٤٤). وقال الهيثمي في مجمع الزوائد ٧/١٥٧: «فيه خديج بن معاوية، وثّقه أحمد وغيره، وضعّفه جماعة».أخرجه ابن جرير ١/٩٧.أخرجه الدارمي ٢/٤٤٧، والطبراني (٨٦٤٤)، والبيهقي في الشعب (٢٤٨٧). وعزاه السيوطي إلى محمد بن نصر.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (ت: اللاحم) ٣/٢٠ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصَيف عن مجاهد.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/١٠٧.أخرجه ابن جرير ٢١/٤٠٠. وعزاه السيوطي إلى ابن المنذر مختصرًا.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٦٩-. وتفسير الثعلبي ٩/٩٢-٩٣ وذكر أنه رواية أبي الحوراء، عن عبد الله بن عباس.أخرجه ابن أبي الدنيا في العقوبات (٢٢)، وأبو الشيخ في العظمة (٩٩١).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٧٢-.أخرجه أبو الشيخ (٩٩٢)، والحاكم ٢/٤٦٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه عبد الرزاق ٢/٢٣٦.تفسير الثعلبي ٩/٩٢-٩٣.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ٩/٩٢.تفسير مقاتل بن سليمان ٤/١٠٩.تفسير الثعلبي ٩/٩٣.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢١/٤٠١.تفسير مقاتل بن سليمان ٤/١٠٩.
50,2," <q>﴿بَلۡ عَجِبُوۤا۟ أَن جَاۤءَهُم مُّنذِرࣱ مِّنۡهُمۡ فَقَالَ ٱلۡكَـٰفِرُونَ هَـٰذَا شَیۡءٌ عَجِیبٌ ۝٢﴾</q> - تفسير ٧١٩٢٢- قال ⟨الحسن البصري:⟩{ت} وقع القَسَم على تعجُّب المشركين مما جاء به محمد{1}. (ز) ٧١٩٢٣- قال مقاتل بن سليمان: <q>﴿بَلْ عَجِبُوا أنْ جاءَهُمْ مُنْذِرٌ مِنهُمْ﴾</q> يعني: محمدًا، <q>﴿فَقالَ الكافِرُونَ﴾</q> من أهل مكة: <q>﴿هذا شَيْءٌ عَجِيبٌ﴾</q> يعني: هكذا الأمر! عجيب أن يكون محمدٌ رسولًا، وذلك أنّ كفار مكّة كذّبوا بمحمد ﷺ{2}٦١٢١. (ز) ٦١٢١ على هذا القول فالضمير في قوله: <q>﴿عجبوا﴾</q> للكافرين، وكرّر الكلام تأكيدًا ومبالغة، وهو ما ذكره ابنُ عطية (٨/٣٢)، ثم بيّن أن الإشارة بـ<q>﴿هذا﴾</q> عليه تحتمل احتمالين: الأول: أن تكون إلى نفس مجيء البشر. الثاني: أن تكون إلى القول الذي يتضمنه الإنذار، وهو الخبر بالبعث. وعلَّق عليه بقوله: «ويؤيد هذا القول ما يأتي بعد». وساق قولًا آخر وهو: أن يكون الضمير لجميع الناس مؤمنهم وكافرهم. وعلَّق عليه بقوله: «لأن كل مفطور عجِب من بعثة بشر رسولًا لله، لكن المؤمنون نظروا واهتدوا، والكافرون بقوا في عمايتهم، وصمّوا وحاجّوا بذلك العجب، ولذلك قوله تعالى: <q>﴿فقال الكافرون هذا شيء عجيب﴾</q>». ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٦٩-.تفسير مقاتل بن سليمان ٤/١٠٩-١١٠.
50,3," <q>﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰاۖ ذَ ٰ⁠لِكَ رَجۡعُۢ بَعِیدࣱ ۝٣﴾</q> - نزول الآية ٧١٩٢٤- قال مقاتل بن سليمان: <q>﴿أإذا مِتْنا وكُنّا تُرابًا ذلِكَ رَجْعٌ﴾</q> نزلَتْ في أُبيّ بن خلف الجُمَحي، وأبي الأشدّين، واسمه: أسيد بن كلدة، وهما من بني جُمح، ونبيه ومُنَبِّه أخوين، ابني الحجاج السَّهميّين، وكلّهم من قريش، وقالوا: إنّ الله لا يُحيينا، وكيف يَقْدِرُ علينا إذا كُنّا ترابًا وضَلَلنا في الأرض؟!{1}. (ز) <q>﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰاۖ ذَ ٰ⁠لِكَ رَجۡعُۢ بَعِیدࣱ ۝٣﴾</q> - تفسير الآية ٧١٩٢٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿أإذا مِتْنا وكُنّا تُرابًا ذلِكَ رَجْعٌ﴾</q>، قالوا: كيف يُحيينا الله، وقد صِرنا عظامًا ورُفاتًا، وضَلَلنا في الأرض؟!{2}٦١٢٢. (ز) ٦١٢٢ قال ابن جرير (٢١/٤٠٣-٤٠٤): «في هذا الكلام متروكٌ استُغْنِي بدلالة ما ذُكر عليه مِن ذكره، وذلك أنّ الله دلّ بخبره عن تكذيب هؤلاء المشركين الذين ابتدأ هذه السورة بالخبر عن تكذيبهم رسوله محمدًا ﷺ بقوله: <q>﴿بل عجبوا أن جاءهم منذر منهم فقال الكافرون هذا شيء عجيب﴾</q> على وعيده إيّاهم على تكذيبهم محمدًا ﷺ، فكأنه قال لهم -إذ قالوا منكرين رسالة الله رسوله محمدًا ﷺ: <q>﴿هذا شيء عجيب﴾</q>-: ستعلمون -أيها القوم- إذا أنتم بُعثتم يوم القيامة ما يكون حالكم في تكذيبكم محمدًا ﷺ، وإنكاركم نبوته. فقالوا مجيبين رسول الله ﷺ: <q>﴿أئذا متنا وكنا ترابا﴾</q> نعلم ذلك، ونرى ما تعِدنا على تكذيبك <q>﴿ذلك رجع بعيد﴾</q> أي: أن ذلك غير كائن، ولسنا راجعين أحياء بعد مماتنا. فاستغني بدلالة قوله: <q>﴿بل عجبوا أن جاءهم منذر منهم فقال الكافرون هذا شيء عجيب﴾</q> مِن ذِكر ما ذكرت مِن الخبر عن وعيدهم». ثم ذكر أن قول الضَّحّاك فيه دلالة على صحة ما قاله مِن أنهم أنكروا البعث إذا تُوعّدوا به. ٧١٩٢٦- قال مقاتل بن سليمان: <q>﴿أإذا مِتْنا وكُنّا تُرابًا ذلِكَ رَجْعٌ﴾</q> إلى الحياة <q>﴿بَعِيدٌ﴾</q> بأنّ البعث غير كائن{1}. (ز) ٧١٩٢٧- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ذَلِكَ رَجْعٌ بَعِيدٌ﴾</q>، قال: أنكروا البعث، فقالوا: مَن يستطيع أن يُرْجعنا ويُحيينا؟!{4}. (١٣/٦١٤) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٣.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن المنذر -كما في الفتح ٨/٥٩٣-.
50,4," <q>﴿قَدۡ عَلِمۡنَا مَا تَنقُصُ ٱلۡأَرۡضُ مِنۡهُمۡۖ﴾</q> - تفسير ٧١٩٢٨- عن عبد الله بن عباس، <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q>، قال: مِن أجسادهم، وما يذهب منها{1}. (١٣/٦١٤) ٧١٩٢٩- عن عبد الله بن عباس -من طريق عطية- <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q>، قال: ما تأكل الأرض من لحومهم، وأبشارهم، وعِظامهم، وأشعارهم{2}. (١٣/٦١٤) ٧١٩٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q>، قال: من عظامهم{3}. (ز) ٧١٩٣١- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿قد علمنا ماتنقص الأرض منهم﴾</q>، قال: ما تأكل الأرض من دمائهم، ولحومهم، وأشعارهم{4}. (ز) ٧١٩٣٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q>، يقول: ما أكَلت الأرض منهم ونحن عالِمون به، وهم عندي مع عِلْمي فيهم في كتاب حفيظ{5}. (ز) ٧١٩٣٣- عن الحسن البصري -من طريق عوف- قال: <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q> ما تأكل الأرض من أبدانهم{6}٦١٢٣. (ز) ٦١٢٣ نسب ابنُ عطية (٨/٣٣) هذا القولَ للسُّدّي، ثم علَّق، بقوله: «وهذا قول حسن، مضمّنه الوعيد». ٧١٩٣٤- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q>، يعني: الموت، تأكلهم الأرض إذا ماتوا{7}. (١٣/٦١٤) ٧١٩٣٥- قال إسماعيل السُّدِّيّ: <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q> هو الموت، يقول: قد علِمنا مَن يموت منهم، ومَن يبقى{8}. (ز) ٧١٩٣٦- قال مقاتل بن سليمان: <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q> يقول: ما أكَلت مِن الموتى من لحوم، وعروق، وعظام بني آدم، ما خلا العُصْعُصَ{9}، وتأكل لحوم الأنبياء والعروق، ما خلا عظامهم، مع عِلْمي فيهم{10}٦١٢٤. (ز) ٦١٢٤ نقل ابن عطية (٨/٣٣) عن الثعلبي أنّ ابن عباس قال: معناه: قد علمنا ما تنقص أرض بالإيمان من الكفرة الذين يدخلون في الإيمان. وانتقده مستندًا للسياق، فقال: «وهذا قول أجنبي من المعنى الذي قبلُ وبعدُ». وذكر أنّ حفظ ما تنقص الأرض إنما هو ليعود بعينه يوم القيامة، وأن هذا هو الحق. ونقل عن بعض الأصوليين أنهم ذهبوا إلى أن الأجساد المُبعثرة المبعوثة يجوز أن تكون غير هذه. وانتقده مستندًا للقرآن، فقال: «وهذا عندي خلافٌ لظاهر كتاب الله، ولو كانت غيرها فكيف كانت تشهد الأيدي والأرجل على الكفرة إلى غير ذلك مما يقتضي أنّ أجساد الدنيا هي التي تعود». <q>﴿وَعِندَنَا كِتَـٰبٌ حَفِیظُۢ ۝٤﴾</q> - تفسير ٧١٩٣٧- عن الضَّحّاك بن مُزاحِم، <q>﴿وعِنْدَنا كِتابٌ حَفِيظٌ﴾</q>، قال: لِعِدّتهم، وأسمائهم{11}. (١٣/٦١٤) ٧١٩٣٨- عن الحسن البصري -من طريق عوف- قال: <q>﴿قَدْ عَلِمْنا ما تَنْقُصُ الأَرْضُ مِنهُمْ﴾</q> ما تأكل الأرض مِن أبدانهم، <q>﴿وعندنا﴾</q> بذلك <q>﴿كتاب حفيظ﴾</q>{6}. (ز) ٧١٩٣٩- قال مقاتل بن سليمان: <q>﴿وعِنْدَنا كِتابٌ حَفِيظٌ﴾</q> يعني: محفوظ من الشياطين، يعني: اللوح المحفوظ{10}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢١/٤٠٤.تفسير مجاهد ص٦١٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٦-، وابن جرير ٢١/٤٠٤. وعلّقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التفسير، عقب باب تفسير سورة ق ٤/١٨٣٤.أخرجه إسحاق البستي ص٤٠٠.أخرجه ابن جرير ٢١/٤٠٥.أخرجه عبد الرزاق ٣/٢٢٧.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٤-٤٠٥، ومن طريق سعيد بنحوه.تفسير الثعلبي ٩/٩٤، وتفسير البغوي ٧/٣٥٦.هو عَظْم عَجْب الذَّنَب. النهاية (عصعص).تفسير مقاتل بن سليمان ٤/١١٠.أخرجه إسحاق البستي ص٤٠٠ من طريق جويبر بلفظ: بعدتهم وأسمائهم. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٣/٢٢٧.تفسير مقاتل بن سليمان ٤/١١٠.
50,5," <q>﴿بَلۡ كَذَّبُوا۟ بِٱلۡحَقِّ لَمَّا جَاۤءَهُمۡ﴾</q> - تفسير ٧١٩٤٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلْ كَذَّبُوا بِالحَقِّ لَمّا جاءَهُمْ﴾</q>: أي: كذّبوا بالقرآن{1}. (ز) ٧١٩٤١- قال مقاتل بن سليمان: <q>﴿بَلْ كَذَّبُوا بِالحَقِّ﴾</q> يعني: بالقرآن <q>﴿لَمّا جاءَهُمْ﴾</q> يعني: حين جاءهم به محمد{2}. (ز) <q>﴿فَهُمۡ فِیۤ أَمۡرࣲ مَّرِیجٍ ۝٥﴾</q> - تفسير ٧١٩٤٢- عن عبد الله بن عباس -من طريق علي- <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>، يقول: مُختَلِف{3}. (١٣/٦١٥) ٧١٩٤٣- عن عبد الله بن عباس -من طريق العَوفيّ- <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>، يقول: في أمر ضلالة{4}. (١٣/٦١٥) ٧١٩٤٤- عن عبد الله بن عباس -من طريق أبي جَمرة- أنه سُئِل عن قوله: <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>. يقول: المريج: الشيء المُنكر المُتغيّر، أما سمعت قول الشاعر: فجالتْ والتمستُ به حشاها فخرّ كأنه خَوْطٌ{5} مريجُ؟{6}. (١٣/٦١٥) ٧١٩٤٥- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>. قال: مُختلط. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر: فَراغَتْ فانتَفَذَتْ به حشاها فخرّ كأنه خوطٌ مريجُ؟{7}. (١٣/٦١٦) ٧١٩٤٦- عن سعيد بن جبير-من طريق جعفر بن أبي المغيرة- في قوله: <q>﴿فَهُمْ فِي أمْرٍ مَرِيجٍ﴾</q>، قال: مُلْتَبِس{4}. (ز) ٧١٩٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>، قال: مُلتبس{9}. (١٣/٦١٦) ٧١٩٤٨- قال الحسن البصري: <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q> ما ترك قومٌ الحقَّ إلا مَرَج أمرهم{10}. (ز) ٧١٩٤٩- قال عطية بن سعد العَوفيّ: <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q> أمر ضلالة{11}. (ز) ٧١٩٥٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>، قال: مُلْتَبِسٌ عليهم أمره{1}. (ز) ٧١٩٥١- عن قتادة بن دعامة -من طريق معمر- <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>، قال: مَن ترك الحق مَرَج عليه رأيه، والتبس عليه دينه{13}. (ز) ٧١٩٥٢- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿أمر مريج﴾</q>، قال: أمرٌ مُلتبسٌ{14}. (ز) ٧١٩٥٣- قال مقاتل بن سليمان: <q>﴿فَهُمْ فِي أمْرٍ مَرِيجٍ﴾</q>، يعني: مُختلفٌ مُلتبسٌ{2}. (ز) ٧١٩٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿فِي أمْرٍ مَرِيجٍ﴾</q>، قال: المريج: المُختلط{16}٦١٢٥. (ز) ٦١٢٥ اختُلف في قوله: <q>﴿مريج﴾</q> على أقوال: الأول: أنّ المريج: المختلط. الثاني: المختلف. الثالث: في أمر ضلالة. الرابع: الملتبس. الخامس: المُنكر. وذكر ابنُ جرير (٢١/٤٠٨) أن هذه الأقوال متقاربة المعاني بدلالة اللغة، فقال معللًا: «لأن الشيء المُختلف مُلتبسٌ معناه مشكل، وإذا كان كذلك كان منكرًا؛ لأنّ المعروف واضح بيّن، وإذا كان غير معروف كان لاشك ضلالة؛ لأن الهدى بيّن لا لبس فيه». وعلَّق ابنُ عطية (٨/٣٤) على القول الأول الذي قاله ابن عباس، وابن زيد، فقال: «أي: بعضهم يقول: ساحر. وبعضهم يقول: كاهن. وبعضهم يقول: شاعر. إلى غير ذلك من تخليطهم، وكذلك عادت فكرةُ كلِّ واحد منهم مختلطة في نفسها». وذكر قولًا آخر بأن المريج: المضطرب، وعلَّق عليه بقوله: «وهو قريب من الأول». ",footnotes:1:أخرجه ابن جرير ٢١/٤٠٥، ٤٠٧.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٦، وابن أبي حاتم -كما في الإتقان ٢/٤٣-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤٠٧.الخوط: الغصن الناعم. مختار الصحاح (خوط).أخرجه ابن جرير ٢١/٤٠٦. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر.أخرجه الطستي في مسائله -كما في الإتقان ٢/٩٦-. وعزاه السيوطي إلى ابن الأنباري في الوقف، والخطيب في تلخيص المتشابه.أخرجه ابن جرير ٢١/٤٠٧.تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤٠٧، ومن طريق جعفر أيضًا. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر.تفسير البغوي ٧/٣٥٧.تفسير الثعلبي ٩/٩٤.أخرجه ابن جرير ٢١/٤٠٥، ٤٠٧.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٧.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٨.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٨.
50,6," <q>﴿أَفَلَمۡ یَنظُرُوۤا۟ إِلَى ٱلسَّمَاۤءِ فَوۡقَهُمۡ كَیۡفَ بَنَیۡنَـٰهَا وَزَیَّنَّـٰهَا﴾</q> - تفسير ٧١٩٥٥- قال مقاتل بن سليمان: <q>﴿أفَلَمْ يَنْظُرُوا إلى السَّماءِ فَوْقَهُمْ كَيْفَ بَنَيْناها﴾</q> بغير عَمد، <q>﴿وزَيَّنّاها﴾</q> بالكواكب{1}. (ز) <q>﴿وَمَا لَهَا مِن فُرُوجࣲ ۝٦﴾</q> - تفسير ٧١٩٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وما لَها مِن فُرُوجٍ﴾</q>، قال: شُقوق{2}٦١٢٦. (١٣/٦١٦) ٦١٢٦ ساق ابنُ كثير (١٣/١٨٣) هذا القول، وساق قولين آخرين: الأول: أن معنى <q>﴿فروج﴾</q>: صدوع. الثاني: أن معناها: فتوق. ثم علَّق بقوله: «والمعنى متقارب، كقوله تعالى: <q>﴿الذي خلق سبع سموات طباقا ما ترى في خلق الرحمن من تفاوت فارجع البصر هل ترى من فطور. ثم ارجع البصر كرتين ينقلب إليك البصر خاسئا وهو حسير﴾</q> [الملك:٣-٤]». ٧١٩٥٧- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- قال: <q>﴿ما لها من فروج﴾</q> مِن شُقوق{3}. (ز) ٧١٩٥٨- قال مقاتل بن سليمان: <q>﴿وما لَها مِن فُرُوجٍ﴾</q> يعني: مِن خَلَل{1}. (ز) ٧١٩٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وما لَها مِن فُرُوجٍ﴾</q> وقد سأله: الفُروج: الشيء المُتَبرِّئ بعضُه مِن بعض؟ قال: نعم{5}٦١٢٧. (ز) ٦١٢٧ ذكر ابنُ عطية (٨/٣٥) أنّ النقّاش حكى أن هذه الآية تُعطي أن السماء مستديرة، وانتقده، فقال: «وليس الأمر كما حُكي، إذا تُدُبّر اللفظ وما يقتضي». ",footnotes:1:تفسير مقاتل بن سليمان ٤/١١٠.تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤٠٨ بلفظ: شق. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر.أخرجه إسحاق البستي ص٤٠٠.تفسير مقاتل بن سليمان ٤/١١٠.أخرجه ابن جرير ٢١/٤٠٩.
50,7," <q>﴿وَٱلۡأَرۡضَ مَدَدۡنَـٰهَا وَأَلۡقَیۡنَا فِیهَا رَوَ ٰ⁠سِیَ وَأَنۢبَتۡنَا فِیهَا مِن كُلِّ زَوۡجِۭ بَهِیجࣲ ۝٧﴾</q> - تفسير ٧١٩٦٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿مِن كُلِّ زَوْجٍ بَهِيجٍ﴾</q>. قال: الزّوج: الواحد، والبهيج: الحَسن. قال: وهل تعرف العرب ذلك؟ قال: نعم؛ أما سمعت الأعشى وهو يقول: وكلّ زوجٍ من الدِّيباج يَلبَسه أبو قدامة محْبُوًّا بذاك معا؟{1}. (١٣/٦١٦) ٧١٩٦١- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿بَهِيجٍ﴾</q>، يقول: حَسن{2}. (ز) ٧١٩٦٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿مِن كُلِّ زَوْجٍ بَهِيجٍ﴾</q>، قال: حَسن{3}. (١٣/٦١٦) ٧١٩٦٣- قال مقاتل بن سليمان: <q>﴿والأَرْضَ مَدَدْناها﴾</q> يعني: بسطناها مسيرةَ خمسمائة سنة مِن تحت الكعبة، <q>﴿وأَلْقَيْنا فِيها رَواسِيَ﴾</q> يعني: الجبال، وهي ستة أجبُل، والجبال كلّها مِن هذه الستة الأجبُل، <q>﴿وأَنْبَتْنا فِيها﴾</q> في الأرض <q>﴿مِن كُلِّ زَوْجٍ﴾</q> يعني: مِن كلّ صنفٍ مِن النّبْت <q>﴿بَهِيجٍ﴾</q> يعني: حَسن{4}. (ز) ٧١٩٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- وقد سأله: البهيج: هو الحَسن المنظر؟ قال: نعم{5}. (ز) ",footnotes:1:مسائل نافع (٢٣٠). وعزاه السيوطي إلى الطستي.أخرجه ابن جرير ٢١/٤٠٩.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤٠٩ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/١١٠-١١١.أخرجه ابن جرير ٢١/٤٠٩-٤١٠.
50,8," <q>﴿تَبۡصِرَةࣰ﴾</q> - تفسير ٧١٩٦٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تَبْصِرَةً﴾</q>، قال: بصيرة{1}. (١٣/٦١٦) ٧١٩٦٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿تَبْصِرَةً وذِكْرى﴾</q>، قال: تبصرة من الله{2}. (ز) ٧١٩٦٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿تَبْصِرَةً﴾</q>، قال: نِعَمٌ تبصرةً للعباد{3}. (١٣/٦١٦) ٧١٩٦٨- قال مقاتل بن سليمان: <q>﴿تَبْصِرَةً وذِكْرى﴾</q>، يعني: هذا الذي ذَكر مِن خلْقه جعله تبصرةً وتفكِرة{4}. (ز) <q>﴿وَذِكۡرَىٰ لِكُلِّ عَبۡدࣲ مُّنِیبࣲ ۝٨﴾</q> - تفسير ٧١٩٦٩- عن مجاهد بن جبر -من طريق جابر-= (ز) ٧١٩٧٠- وعطاء -من طريق جابر- في قوله: <q>﴿مُنِيبٍ﴾</q>، قالا: مُخْبِت{5}. (١٣/٦١٧) ٧١٩٧١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وذِكْرى لِكُلِّ عَبْدٍ مُنِيبٍ﴾</q>، قال: المُنيب: المُقبِل بقلبه إلى الله{6}. (١٣/٦١٦) ٧١٩٧٢- قال مقاتل بن سليمان: <q>﴿لِكُلِّ عَبْدٍ مُنِيبٍ﴾</q>، يعني: مُخلِص القلب بالتوحيد{4}. (ز) ٧١٩٧٣- عن سفيان بن عُيَينة -من طريق ابن أبي عمر- في قوله: <q>﴿تبصرة وذكرى لكل عبد منيب﴾</q>، قال: راجع. قال سفيان: والإنابة: الاقبال{8}. (ز) ",footnotes:1:تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤١٠، والفريابي -كما في تغليق التعليق ٤/٣١٦، والفتح ٨/٥٩٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/٢٣٦، وابن جرير ٢١/٤١٠.أخرجه ابن جرير ٢١/٤١٠ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد. وعزاه ابن حجر في الفتح ٨/٥٩٣ إلى عبد الرزاق عن معمر عن قتادة بلفظ: نعمة من الله ﷿.تفسير مقاتل بن سليمان ٤/١١١.أخرجه ابن جرير ٢١/٤١٠. وعزاه السيوطي إلى عَبد بن حميد.أخرجه ابن جرير ٢١/٤١٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/١١١.أخرجه إسحاق البستي ص٤٠٢.
50,9," <q>﴿وَنَزَّلۡنَا مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ مُّبَـٰرَكࣰا﴾</q> - تفسير ٧١٩٧٤- عن عبد الله بن عباس -من طريق ابن أبي مُلَيْكَة- أنه كان إذا أمطرت السماء يقول: يا جارية، أخرِجي سَرْجي، أخرِجي ثيابي. ويقول: <q>﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</q>{1}. (١٣/٦١٧) ٧١٩٧٥- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</q>، قال: المطر{2}. (١٣/٦١٧) ٧١٩٧٦- عن ميمون بن مهران -من طريق أبي المليح- قال: البرَكة في القرآن المطر، <q>﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</q>{3}. (١٣/٦١٧) ٧١٩٧٧- قال مقاتل بن سليمان: <q>﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</q> يعني: المطر، فيه البركة، حياة كلّ شيء{4}٦١٢٨. (ز) ٦١٢٨ قال ابنُ عطية (٨/٣٥ بتصرف): «قوله تعالى: <q>﴿ماء مباركا﴾</q> قيل: يعني: جميع المطر، كله يتصف بالبركة، وإن ضرّ بعضه أحيانًا ففيه مع ذلك الضر الخاص البركة العامة. وقال بعض المفسرين: <q>﴿ماء مباركًا﴾</q> يريد به: ماء مخصوصًا خالصًا للبركة، ينزله الله كل سنة، وليس كل المطر يتصف بذلك». <q>﴿فَأَنۢبَتۡنَا بِهِۦ جَنَّـٰتࣲ وَحَبَّ ٱلۡحَصِیدِ ۝٩﴾</q> - تفسير ٧١٩٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وحَبَّ الحَصِيدِ﴾</q>، قال: الحِنطة{5}. (١٣/٦١٧) ٧١٩٧٩- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿وحب الحصيد﴾</q>، قال: الحِنطة، والشعير{6}. (ز) ٧١٩٨٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وحَبَّ الحَصِيدِ﴾</q>، قال: هو البُرّ والشّعير{7}. (١٣/٦١٧) ٧١٩٨١- قال مقاتل بن سليمان: <q>﴿فَأَنْبَتْنا بِهِ جَنّاتٍ﴾</q> يعني: بساتين، <q>﴿وحَبَّ الحَصِيدِ﴾</q> يعني: حين يخرج من سُنبله{4}. (ز) <q>﴿فَأَنۢبَتۡنَا بِهِۦ جَنَّـٰتࣲ وَحَبَّ ٱلۡحَصِیدِ ۝٩﴾</q> - آثار متعلقة بالآية ٧١٩٨٢- عن القاسم بن أبي بزَّة، قال: سأل رجلٌ عبد الله بن الزبير عن طين المطر. فقال: تسألني عن طهورين جميعًا، قال الله: <q>﴿ونَزَّلْنا مِنَ السَّماءِ ماءً مُبارَكًا﴾</q>، وقال رسول الله ﷺ: «جُعلتْ لي الأرض مسجدًا وطهورًا»{9}. (ز) ",footnotes:1:أخرجه البخاري في الأدب المفرد (١٢٢٨).أخرجه أبو الشيخ في العظمة (٧٤٠).أخرجه أبو الشيخ (٧٣٩).تفسير مقاتل بن سليمان ٤/١١١.تفسير مجاهد ص٦١٣، وأخرجه ابن جرير ٢١/٤١١، والفريابي -كما في الفتح ٨/٥٩٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه إسحاق البستي ص٤٠١.أخرجه عبد الرزاق ٢/٢٣٦-٢٣٧، وابن جرير ٢١/٤١١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/١١١.أخرجه عبد الرزاق ١/٣٢ (٩٨).
50,10," <q>﴿وَٱلنَّخۡلَ بَاسِقَـٰتࣲ﴾</q> - تفسير ٧١٩٨٣- عن قُطْبة، قال: سمعتُ النَّبِيّ ﷺ يقرأ في الصبح: <q>﴿ق﴾</q>، فلما أتى على هذه الآية: <q>﴿والنَّخْلَ باسِقاتٍ لَها طَلْعٌ نَضِيدٌ﴾</q> قال قُطْبة: فجعلتُ أقول: ما بُسُوقها؟ فقال: «طُولها»{1}. (١٣/٦١٨) ٧١٩٨٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>، قال: الطُّول{2}. (١٣/٦١٨) ٧١٩٨٥- عن عبد الله بن شدّاد -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>، قال: بُسُوقها: طُولها في إقامة{3}. (١٣/٦١٨) ٧١٩٨٦- عن إسماعيل بن أبي خالد، قال: سألت عبد الله بن شَدّاد بن الهاد عن قول الله: <q>﴿والنخل باسقات لها طلع نضيد﴾</q>. قال: طُولهنّ، واستواؤهنّ{4}. (ز) ٧١٩٨٧- قال سعيد بن جُبَير: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q> مستويات{5}. (ز) ٧١٩٨٨- عن عبد الله بن عثمان بن خُثَيم، قال: سألتُ عكرمة عن قوله: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>، فقلت: ما بُسُوقها؟ قال: بُسُوقها: طَلْعها؛ ألم ترَ أنّه يقال للشاة إذا حانَ وِلادها: أبْسَقَت؟= (ز) ٧١٩٨٩- قال: فرجعتُ إلى سعيد بن جُبَير، فقلت له: فقال: كذب، بُسُوقها: طُولها في كلام العرب؛ ألم تر أن الله قال: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q> ثم قال: <q>﴿طَلْعٌ نَضِيدٌ﴾</q>{6}. (١٣/٦١٨) ٧١٩٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>، قال: الطّوال{7}. (ز) ٧١٩٩١- عن عكرمة مولى ابن عباس، قال: بُسُوقها: التفافها{8}. (١٣/٦١٨) ٧١٩٩٢- عن عكرمة مولى ابن عباس -من طريق سماك- <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>: الباسقات: الطّوال{9}. (ز) ٧١٩٩٣- قال الحسن البصري: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q> مَواقير حَوامل{10}. (ز) ٧١٩٩٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>: يعني: طولها{11}. (ز) ٧١٩٩٥- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿والنخل باسقات﴾</q>، قال: طوال{12}. (ز) ٧١٩٩٦- قال مقاتل بن سليمان: <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>، يعني: وأنبَتنا بالماء النَّخلَ الطّوال{13}. (ز) ٧١٩٩٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿والنَّخْلَ باسِقاتٍ﴾</q>، قال: البُسُوق: الطُّول{14}. (ز) <q>﴿لَّهَا طَلۡعࣱ نَّضِیدࣱ ۝١٠﴾</q> - تفسير ٧١٩٩٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿طَلْعٌ نَضِيدٌ﴾</q>، قال: مُتراكِمٌ بعضه على بعض{15}. (١٣/٦١٩) ٧١٩٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿طَلْعٌ نَضِيدٌ﴾</q>، قال: المُنَضَّد{16}. (ز) ٧٢٠٠٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿طَلْعٌ نَضِيدٌ﴾</q>، قال: نُضِّد بعضه على بعض{17}. (ز) ٧٢٠٠١- قال ابن شهاب: والنّضيد: الذي بعضه فوق بعض{18}. (ز) ٧٢٠٠٢- قال مقاتل بن سليمان: <q>﴿لَها طَلْعٌ﴾</q> يعني: الثمر <q>﴿نَضِيدٌ﴾</q> يعني: منضود بعضه على بعض، مثل قوله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q> [الواقعة:٩]{13}. (ز) <q>﴿لَّهَا طَلۡعࣱ نَّضِیدࣱ ۝١٠﴾</q> - آثار متعلقة بالآية ٧٢٠٠٣- عن مَسروق بن الأجدع الهَمداني -من طريق أبي عبيدة بن عبد الله بن مسعود- قال: الجنّة نَخلْها نضيدٌ من أصلها إلى فرعها، وتمرتها كالقِلال، كلما نُزعت تمرة عادت مكانها أخرى، وأنهار تجري في غير أخدود، والعنقود منها اثنا عشر ذراعًا{20}. (ز) ",footnotes:1:أخرجه مسلم ١/٣٣٦، ٣٣٧ (٤٥٧) مختصرًا، والحاكم ٢/٥٠٤ (٣٧٢٨) واللفظ له. قال الحاكم: «قد أخرج مسلم هذا الحديث بغير هذه السياقة، ولم يذكر تفسير البسوق فيه، وهو صحيح على شرطه». ووافقه الذهبي.أخرجه ابن جرير ٢١/٤١٢ بلفظ: الطوال، ومن طريق العوفي أيضًا، وابن أبي حاتم -كما في الإتقان ٢/٤٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤١٢. وعزاه السيوطي إلى ابن المنذر بلفظ: استقامتها.أخرجه إسحاق البستي ص٤٠٢.تفسير الثعلبي ٩/٩٥، وتفسير البغوي ٧/٣٥٧.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مجاهد ص٦١٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣١٦-، وابن جرير ٢١/٤١٢. وعلقه البخاري في صحيحه ٤/١٨٣٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٤١٢-٤١٣.تفسير الثعلبي ٩/٩٥.أخرجه عبد الرزاق ٢/٢٣٧، وابن جرير ٢١/٤١٣، وكذلك من طريق سعيد، كما أخرجه سعيد بن منصور في سننه -التفسير ٧/٣٩٩ (٢٠٣٤) من طريق أبي عوانة عن قتادة قال: الطوال.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٨.تفسير مقاتل بن سليمان ٤/١١١.أخرجه ابن جرير ٢١/٤١٣.أخرجه ابن جرير ٢١/٤١٣-٤١٤ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢١/٤١٤.أخرجه ابن جرير ٢١/٤١٤، كما أخرجه عبد الرزاق ٢/٢٣٧، وابن جرير ٢١/٤١٤ بنحوه من طريق معمر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٠١ (١٩٨)، ولم يتبين الطريق في النسخة.تفسير مقاتل بن سليمان ٤/١١١.أخرجه سفيان الثوري ص٢٨٠، وإسحاق البستي ص٤٠٢.
50,11," <q>﴿رِّزۡقࣰا لِّلۡعِبَادِۖ وَأَحۡیَیۡنَا بِهِۦ بَلۡدَةࣰ مَّیۡتࣰاۚ كَذَ ٰ⁠لِكَ ٱلۡخُرُوجُ ۝١١﴾</q> - تفسير ٧٢٠٠٤- قال مقاتل بن سليمان: وجعلنا هذا كلّه <q>﴿رِزْقًا لِلْعِبادِ﴾</q>، ثم قال: <q>﴿وأَحْيَيْنا بِهِ﴾</q> يعني: بالماء <q>﴿بَلْدَةً مَيْتًا﴾</q> لم يكن عليها نَبْت؛ فنَبَتت الأرض، <q>﴿كَذلِكَ الخُرُوجُ﴾</q> يقول: وهكذا تَخرجون مِن القبور بالماء، كما أخرجت النَّبْت من الأرض بالماء، فهذا كله مِن صنيعه ليعرفوا توحيد الرب وقدرته على البعث{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١١١.
50,12," <q>﴿كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ وَأَصۡحَـٰبُ ٱلرَّسِّ وَثَمُودُ ۝١٢﴾</q> - تفسير ٧٢٠٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وأَصْحابُ الرَّسِّ﴾</q>، قال: بئر{1}. (ز) ٧٢٠٠٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿وأَصْحابُ الرَّسِّ﴾</q>: الرّس: بئر قُتل فيها صاحب يس{1}. (ز) ٧٢٠٠٧- عن عكرمة مولى ابن عباس -من طريق أبي بكير- <q>﴿وأَصْحابُ الرَّسِّ﴾</q>: أنهم قوم رسُّوا نبيّهم في بئر{1}. (ز) ٧٢٠٠٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأَصْحابُ الرَّسِّ﴾</q>، قال: كانوا بحِجْر، بناحية اليمامة، على آبار{4}. (ز) ٧٢٠٠٩- قال مقاتل بن سليمان: <q>﴿كَذَّبَتْ قَبْلَهُمْ﴾</q> قبل أهل مكة <q>﴿أصْحابُ الرَّسِّ﴾</q> يعني: أصحاب البئر، واسمها: قلج، وهي البئر التي قُتل فيها حَبيب النَّجار صاحب ياسين{5}٦١٢٩. (ز) ٦١٢٩ ذكر ابنُ عطية (٨/٣٧) أن كعب الأحبار قال: أصحاب الرس هم أصحاب الأخدود. وانتقده مستندًا للتاريخ، فقال: «وهذا ضعيف؛ لأن أصحاب الأخدود لم يُكَذِّبوا نبيًّا، إنما هو مَلك أحرق قومًا». ",footnotes:1:أخرجه ابن جرير ٢١/٤١٥.أخرجه ابن جرير ٢١/٤١٥.أخرجه ابن جرير ٢١/٤١٥.أخرجه عبد الرزاق ٢/٢٣٧.تفسير مقاتل بن سليمان ٤/١١١.
50,13," <q>﴿وَعَادࣱ وَفِرۡعَوۡنُ وَإِخۡوَ ٰ⁠نُ لُوطࣲ ۝١٣ وَأَصۡحَـٰبُ ٱلۡأَیۡكَةِ﴾</q> - تفسير ٧٢٠١٠- عن قتادة بن دعامة -من طريق عمرو بن عبد الله- أنه قال: <q>﴿الأَيْكة﴾</q> الشّجر المُلتَفّ، وأصحاب الرَّسّ كانتا أُمّتَين، فبعث الله إليهم نبيًّا واحدًا؛ شُعيبًا، وعذّبهما الله بعذابين{1}. (ز) ٧٢٠١١- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأَصْحابُ الأَيْكَةِ﴾</q>، قال: كانوا أصحاب غَيْضَة{2}، وكانت عامّة شَجَرهم الدَّوم{3}. (ز) ٧٢٠١٢- قال مقاتل بن سليمان: <q>﴿وأَصْحابُ الأَيْكَةِ﴾</q> يعني: غَيْضَةُ الشجر، أكثرها الدَّوم الـمـُــــقْل، وهم قوم شُعيب ﵇{4}. (ز) <q>﴿وَقَوۡمُ تُبَّعࣲۚ﴾</q> - تفسير ٧٢٠١٣- قال ⟨قتادة بن دعامة:⟩{ت} ذمّ الله تعالى قوم تُبّع، ولم يذُمّه{5}. (ز) ٧٢٠١٤- قال مقاتل بن سليمان: <q>﴿وقَوْمُ تُبَّعٍ﴾</q> بن أبي شراح، ويقال: شراحيل الحميري{4}. (ز) ٧٢٠١٥- عن محمد بن إسحاق -من طريق سلمة-: وكان قوم تُبّع أهل أوثان يعبدونها{7}. (ز) <q>﴿كُلࣱّ كَذَّبَ ٱلرُّسُلَ فَحَقَّ وَعِیدِ ۝١٤﴾</q> - تفسير ٧٢٠١٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَحَقَّ وعِيدِ﴾</q>، قال: ما أُهلكوا به، تخويفًا لهؤلاء{8}. (١٣/٦١٩) ٧٢٠١٧- قال مقاتل بن سليمان: <q>﴿كُلٌّ﴾</q> كلّ هؤلاء <q>﴿كَذَّبَ الرُّسُلَ فَحَقَّ وعِيدِ﴾</q> يعني: فوجب عليهم عذابي، فعذّبتُهم، فاحذروا -يا أهل مكة- مثل عذاب الأمم الخالية، فلا تُكذّبوا محمدًا ﷺ{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٤١٥-٤١٦.وهي الشجر الملتف. النهاية (غيض).أخرجه عبد الرزاق ٢/٢٣٧.تفسير مقاتل بن سليمان ٤/١١١.تفسير البغوي ٧/٣٥٨.تفسير مقاتل بن سليمان ٤/١١١.أخرجه ابن جرير ٢١/٤١٦. وقد تقدم الآثار مفصلةً عن تُبَّع وخبره عند تفسير قوله تعالى: <q>﴿أهُمْ خَيْرٌ أمْ قَوْمُ تُبَّعٍ﴾</q> [الدخان:٣٧].أخرجه ابن جرير ٢١/٤١٩. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/١١١.
  50,14,""
50,15," <q>﴿أَفَعَیِینَا بِٱلۡخَلۡقِ ٱلۡأَوَّلِۚ بَلۡ هُمۡ فِی لَبۡسࣲ مِّنۡ خَلۡقࣲ جَدِیدࣲ ۝١٥﴾</q> - تفسير ٧٢٠١٨- عن عبد الله بن عباس -من طريق علي- <q>﴿أفَعَيِينا بِالخَلْقِ الأَوَّلِ﴾</q> يقول: لم يُعْيِنا الخَلْق الأول، <q>﴿بَلْ هُمْ فِي لَبْسٍ مِن خَلْقٍ جَدِيدٍ﴾</q> يقول: في شكٍّ مِن البعث{1}. (١٣/٦١٩) ٧٢٠١٩- عن أبي مَيْسَرَة -من طريق عطاء بن السّائِب- <q>﴿أفَعَيِينا بِالخَلْقِ الأَوَّلِ﴾</q> قال: أنّا خَلقناكم، <q>﴿بَلْ هُمْ فِي لَبْسٍ مِن خَلْقٍ جَدِيدٍ﴾</q> قال: هم الكفار، أن يُخلقوا من بعد الموت{2}. (ز) ٧٢٠٢٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أفَعَيِينا بِالخَلْقِ الأَوَّلِ﴾</q> قال: أفعَيِيَ علينا حين أنشأناكم، <q>﴿بَلْ هُمْ فِي لَبْسٍ مِن خَلْقٍ جَدِيدٍ﴾</q> قال: يَمتَرون بالبعث{3}. (١٣/٦١٩) ٧٢٠٢١- قال الحسن البصري: <q>﴿أفَعَيِينا بِالخَلْقِ الأَوَّلِ﴾</q>، يعني: خَلْق آدم، أي: لم يعيَ به{4}. (ز) ٧٢٠٢٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلْ هُمْ فِي لَبْسٍ مِن خَلْقٍ جَدِيدٍ﴾</q>: أي: شكّ. والخَلْق الجديد: البعْث بعد الموت، فصار الناس فيه رجلين: مكذِّب، ومصدِّق{5}. (ز) ٧٢٠٢٣- قال مقاتل بن سليمان: <q>﴿أفَعَيِينا بِالخَلْقِ الأَوَّلِ﴾</q> ذلك أنّ كفار مكة كذّبوا بالبعث، يقول الله تعالى: أعَجزتُ عن الخَلْق حين خلقْتُهم ولم يكونوا شيئًا، فكيف أعيى عن بَعْثهم؟! فلم يُصدّقوا، فقال الله: بل يبعثهم الله <q>﴿بَلْ هُمْ فِي لَبْسٍ مِن خَلْقٍ جَدِيدٍ﴾</q> في شكٍّ من البعْث بعد الموت{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٤٢٠-٤٢١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢١/٤٢٠-٤٢١، وأخرج إسحاق البستي ص٤٠٣ نحوه من طريق عطاء بن السائب عن ميمون بن ميسرة أبي صالح! ولعل المقصود هو ميسرة أبو صالح.تفسير مجاهد ص٦١٤، وأخرجه ابن جرير ٢١/٤٢٠. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٧١-.أخرجه ابن جرير ٢١/٤٢١، كما أخرجه عبد الرزاق ٢/٢٣٧، وابن جرير ٢١/٤٢١ من طريق معمر مختصرًا.تفسير مقاتل بن سليمان ٤/١١٢.
