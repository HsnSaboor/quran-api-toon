quran[30]{c,v,t}:
  78,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٠٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (١٥/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسَمّاها: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span>، وذكر أنها نزلت بعد: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٤<span class="dash">-</span></span> عن عبد الله بن الزُّبير، قال: نزلت <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span> بمكة{3}. (١٥/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٦<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسَمَّياها: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٨<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، وسَمّاها: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span>، ونزلت بعد: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٠٩<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٠<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة النبأ مكّيّة، عددها أربعون آية كوفي{8}<span class=comment-ref>٦٩٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٧</span> قال <u>ابنُ عطية</u> (٨/٥١٢): «وهي مكّيّة <span class="mustanad">بإجماع</span>».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|5:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|6:تنزيل القرآن ص٣٧-٤٢.|7:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|8:تفسير مقاتل بن سليمان ٤/٥٥٥.
  78,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَمَّ یَتَسَاۤءَلُونَ ۝١ عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨١١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق محمد بن جُحادة- قال: لَمّا بُعِث النبيُّ ﷺ جَعلوا يتساءلون بينهم؛ فنزلت: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>{1}<span class=comment-ref>٦٩٧٨</span>. (١٥/١٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٨</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٥) غير قول الحسن.</div></p><p><div></p><p><p><span class="item-no">٨٠٨١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span> نزلت في أبي لبابة وأصحابه، وذلك أنّ كفار مكة كانوا يجتمعون عند رسول الله ﷺ، ويَسمعون حديثه، فإذا حَدَّثهم خالفوا قوله، واستهزؤوا منه، وسخروا؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿أنْ إذا سَمِعْتُمْ﴾</span> يا محمد <span class="qpc-hafs">﴿آياتِ اللَّهِ يُكْفَرُ بِها ويُسْتَهْزَأُ بِها فَلا تَقْعُدُوا مَعَهُمْ حَتّى يَخُوضُوا فِي حَدِيثٍ غَيْرِهِ﴾</span> [النساء:١٤٠]. فكان رسول الله ﷺ يُحَدِّث المؤمنين، فإذا رأى رجلًا مِن المشركين كفَّ عن الحديث حتى يَذهب، ثم أقبلوا بجماعتهم، فقالوا: يا محمد، أبخلتَ بما كنتَ تُحدِّثنا؟ لو أنك حَدّثتنا عن القرون الأولى فإنّ حديثك عجبٌ. قال: «<b>لا، واللهِ، لا أُحدِّثكم بعد يومي هذا، وربي قد نهاني عنه</b>». فأنزل الله تعالى: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَمَّ یَتَسَاۤءَلُونَ ۝١ عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>، قال: القرآن{3}. (١٥/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عَنِ النَّبَإ العَظِيمِ﴾</span>، قال: القرآن{4}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</span>، قال: القرآن{5}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عَنِ النَّبَإ العَظِيمِ﴾</span>: وهو البعْث بعد الموت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ﴾</span> استفهام للنبي ﷺ: عن أيِّ شيء يتساءلون؟ ... <span class="qpc-hafs">﴿عَنِ النَّبَإ العَظِيمِ﴾</span> يعني: القرآن، كقوله: <span class="qpc-hafs">﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ﴾</span> [ص:٦٧] لأنه كلام الله تعالى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ الَّذِي هُمْ فِيهِ مُخْتَلِفُون﴾</span>، قال: يوم القيامة. قال: قالوا: هذا اليوم الذي تزعمون أنّا نحيا فيه وآباؤنا. قال: فهم فيه مُختلِفون، لا يؤمنون به، فقال الله: <span class="qpc-hafs">﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ أنْتُمْ عَنْهُ مُعْرِضُونَ﴾</span> [ص:٦٧-٦٨] يوم القيامة لا يؤمنون به{6}<span class=comment-ref>٦٩٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٧٩</span> ذكر <u>ابنُ عطية</u> (٨/٥١٢) في عَوْد الضمير في قوله: <span class="qpc-hafs">﴿يتساءلون﴾</span> احتمالين: <b>الأول</b>: «أن يريد: جميع العالم». و<span class="comment-type-1">وجّهه</span> بقوله: «فيكون الاختلاف حينئذ يُراد به تصديق المؤمنين، وتكذيب الكافرين، ونزغات الملحدين». <b>الثاني</b>: «أن يراد بالضمير: الكفار من قريش». <span class="comment-type-1">ووجّهه</span> بقوله: «فيكون الاختلاف شكّ بعض وتكذيب بعض، وقولهم سحرٌ وكهانة وشِعر وجنون وغير ذلك».</p><p>وذكر <u>ابنُ عطية</u> (٨/٥١٢) إضافة إلى ما ورد في أقوال السلف في المراد بالنبأ العظيم <b>قولًا</b> آخر، فقال: «و<span class="qpc-hafs">﴿النبأ العظيم﴾</span> قال قوم: هو الشرع الذي جاء به محمد ﷺ».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.|2:تفسير مقاتل بن سليمان ٤/٥٥٧.|3:عزاه السيوطي إلى ابن مردويه.|4:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|5:أخرجه عبد الرزاق ٢/٣٤٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر. والوارد عن ابن جرير الرواية التالية.|6:أخرجه ابن جرير ٢٤/٦.|7:تفسير مقاتل بن سليمان ٤/٥٥٧.|8:أخرجه ابن جرير ٢٤/٦.
  78,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی هُمۡ فِیهِ مُخۡتَلِفُونَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span>، قال: مُصدِّق، ومُكذِّب{1}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span>، قال: هو البعْث بعد الموت، صار الناس فيه رجلين؛ مُصدِّق، ومُكذِّب، فأمّا الموت فأَقرُّوا به كلّهم لمعاينتهم إياه، واختلفوا في البعْث بعد الموت{2}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span> يقول: لِمَ يسألون عن القرآن وهم يخالفونه، ولا يؤمنون به؟! فصَدَّق بعضُهم به، وكفر بعضُهم به، فاختلفوا فيه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|2:أخرجه ابن جرير ٢٤/٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥٥٧-٥٥٨.
  78,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّا سَیَعۡلَمُونَ ۝٤ ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في حَيّين من أحياء العرب، يعني: [بني] عبد مناف بن قُصي، وبني سهم بن عمرو بن هُصَيص بن كعب{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَلَّا سَیَعۡلَمُونَ ۝٤ ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٢٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق ثابت-: <span class="qpc-hafs">﴿كَلّا سَيَعْلَمُونَ﴾</span> الكفار، <span class="qpc-hafs">﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span> المؤمنون. وكذلك كان يقرؤها{2}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿كَلّا سَيَعْلَمُونَ ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span>، قال: وعيد بعد وعيد{3}. (١٥/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم الوعيد، فقال: <span class="qpc-hafs">﴿كَلّا سَيَعْلَمُونَ﴾</span> إذا قُتِلوا ببدر، وتَوفّتهم الملائكة ظالمي أنفسهم، يَضربون وجوههم وأدبارهم، ثم قال: <span class="qpc-hafs">﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span> وعيد على أثر وعيد ...، نظيرها في <span class="qpc-hafs">﴿ألْهاكُمُ التَّكاثُرُ﴾</span>{4}<span class=comment-ref>٦٩٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٠</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٤/٧-٨) أنّ قوله: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> في الموضعين وعيد، كما أفاده قول مقاتل، وقول الحسن، ثم ذكر قول الضَّحّاك، ولم يعلّق عليه.</p><p>وذكر <u>ابنُ عطية</u> (٨/٥١٣) في الآية قراءات، و<span class="comment-type-1">وجّه</span> المعنى عليها، فقال: «وقرأ السبعة، والحسن، وأبو جعفر، وشيبة، والأعمش: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> بالياء في الموضعين على ذِكر الغائب، فظاهر الكلام أنه ردٌّ على الكفار في تكذيبهم وعيد لهم في المستقبل، وكرّر الزجر تأكيدًا، وقال الضَّحّاك: المعنى: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> يعني: الكفار على جهة الوعيد، <span class="qpc-hafs">﴿ثم كلا سيعلمون﴾</span> يعني: المؤمنين على جهة الوعد. وقرأ ابن عامر فيما روى عنه مالك بن دينار والحسن بخلاف: (كَلّا سَتَعْلَمُونَ) بالتاء في الموضعين على مخاطبة الحاضر، كأنه تعالى يقول: قُل لهم، يا محمد، وكرِّر عليهم الزجر والوعيد تأكيدًا. وكلّ تأويل في هذه القراءة غير هذا فمتعسف. وقرأ قوم: <span class="qpc-hafs">﴿كلا سيعلمون﴾</span> بالياء على جهة الردّ والوعيد للكفار، (ثم كلا ستعلمون) بالتاء من فوق على جهة الردّ على الكفار والوعد للمؤمنين».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨.|2:أخرجه ابن جرير ٢٤/٨.|3:عزاه السيوطي إلى ابن المنذر.|4:تفسير مقاتل بن سليمان ٤/٥٥٨. وأشار بالنظير إلى قوله تعالى: <span class="qpc-hafs">﴿كلا سوف تعلمون ثم كلا سوف تعلمون﴾</span> [التكاثر:٣-٤].
  78,5,""
  78,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ مِهَـٰدࣰا ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٢٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿الأَرْضَ مِهادًا﴾</span> قال: فِراشًا{1}. (١٥/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</span> قال: بِساطًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿مَعاشًا﴾</span>، قال: نِعمٌ من الله يعدّها عليكم، يا بني آدم؛ لِتعمَلوا لأداء شُكرها{3}. (١٥/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر صُنعه ليَعتبروا إذا بُعثوا يوم القيامة وقد كذّبوا بالقيامة والبعْث، فعَظّم الرّبُّ نفسه -تبارك وتعالى- فقال: <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</span> يعني: فِراشًا، وأيضًا بِساطًا مسيرة خمسمائة عام{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٣٠<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</span>، قال: فُرِشَتْ لكم{3}. (١٥/١٩١)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٣٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.|2:أخرجه بن جرير ٢٤/٨.|3:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|4:تفسير مقاتل بن سليمان ٤/٥٥٨.|5:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.
  78,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡجِبَالَ أَوۡتَادࣰا ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والجِبالَ أوْتادا﴾</span> على الأرض لِئلّا تزول بأهلها، فاستَقرّتْ، وخَلَق الجبال بعد خَلْق الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٣٢<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، <span class="qpc-hafs">﴿والجِبالَ أوْتادًا﴾</span>، قال: أُوتِدَتْ بها{2}. (١٥/١٩١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡجِبَالَ أَوۡتَادࣰا ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: لَمّا أراد اللهُ أن يَخلُق الخَلْق أرسل الريح، فسَحَّت{3} الماءَ حتى أبْدَتْ عن حشَفَة، وهي التي تحت الكعبة، ثم مدَّ الأرضَ حتى بلَغتْ ما شاء الله مِن الطول والعرض، وكانت هكذا تَميد -وقال بيده هكذا وهكذا-، فجعل الله الجبال رواسي أوتادًا، فكان أبو قبيس مِن أول جبل وُضِع في الأرض{4}. (١٥/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٣٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: إنّ الأرض أول ما خُلِقتْ خُلِقتْ من عند بيت المقدس، وُضِعتْ طينة، فقيل لها: اذهبي هكذا وهكذا وهكذا. وخُلِقتْ على صخرة، والصخرة على حوت، والحوت على الماء، فأَصبحتْ وهي تميع. فقالت الملائكة: يا ربّ، مَن يُسكِّن هذه؟ فأصبحت الجبال فيها أوتادًا، فقالت الملائكة: يا ربّ، أخلَقتَ خَلْقًا هو أشدُّ مِن هذه؟ قال: الحديد. قالوا: فخَلَقتَ خَلْقًا هو أشد من الحديد؟ قال: النار. قالوا: فخَلَقتَ خَلْقًا هو أشد من النار؟ قال: الماء. قالوا: فخَلَقتَ خَلْقًا هو أشد من الماء؟ قال: الريح. قالوا: فخَلَقتَ خَلْقًا هو أشد من الريح؟ قال: البناء. قالوا: فخَلَقتَ خَلْقًا هو أشد من البناء؟ قال: ابن آدم{5}. (١٥/١٩٢)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨.|2:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|3:سحَّ الماء وغيره يسُحُّه سحًّا: صبه صبًّا متتابعًا كثيرًا. اللسان (سحح).|4:أخرجه الحاكم ٢/٥١٢، والواحدي في الوسيط ٤/٤١٢.|5:عزاه السيوطي إلى ابن المنذر.
  78,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَخَلَقۡنَـٰكُمۡ أَزۡوَ ٰ⁠جࣰا ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وخَلَقْناكُمْ أزْواجًا﴾</span>، قال: اثنين اثنين{1}. (١٥/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وخَلَقْناكُمْ أزْواجًا﴾</span> يعني: أصنافًا؛ ذكورًا وإناثًا، سُودًا وبِيضًا وحُمرًا وأدمًا، ولغات شتّى، فذلك قوله: <span class="qpc-hafs">﴿وخَلَقْناكُمْ أزْواجًا﴾</span> فهذا كلّه عَظمته{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن جرير، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/٥٥٨.
  78,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا نَوۡمَكُمۡ سُبَاتࣰا ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذَكر نِعمته، فقال: <span class="qpc-hafs">﴿وجَعَلْنا نَوْمَكُمْ سُباتًا﴾</span> يقول: إذا دَخل الليل أدرككم النوم فتَستريحون، ولولا النومُ ما استرحتم أبدًا مِن الحِرص وطلب المعيشة، فذلك قوله: <span class="qpc-hafs">﴿سُباتًا﴾</span> لأنه يسبتُ، والنائم مَسبوت كأنه ميّت لا يَعقل{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨-٥٥٩.
  78,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ٱلَّیۡلَ لِبَاسࣰا ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سفيان- <span class="qpc-hafs">﴿وجَعَلْنا اللَّيْلَ لِباسًا﴾</span>، قال: سَكَنًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلْنا اللَّيْلَ لِباسًا﴾</span> يعني: سَكنًا، كقوله: <span class="qpc-hafs">﴿هُنَّ لِباسٌ لَكُمْ﴾</span> [البقرة:١٨٧] يعني: سَكنًا لكم، فألبَسكم ظُلمته على خير وشرّ كثير{2}<span class=comment-ref>٦٩٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥١٤) في قوله: <span class="qpc-hafs">﴿لباسا﴾</span> <b>قولًا</b>، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «ويقال: جعله لِباسًا لأنه يطمس نور الأبصار، ويُلبس عليها الأشياء، والتصريف يُضعّف هذا القول، لأنه كان يجب أن يكون: مُلبسًا، ولا يقال: لِباسًا؛ إلا من لبس الثياب».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٩.|2:تفسير مقاتل بن سليمان ٤/٥٥٩.
  78,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ٱلنَّهَارَ مَعَاشࣰا ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٤٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وجَعَلْنا النَّهارَ مَعاشًا﴾</span> يريد: تَبتغون فيه مِن فضل الله، وما قَسم لكم مِن رزقه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وجَعَلْنا النَّهارَ مَعاشًا﴾</span>، قال: يَبتغون مِن فضل الله{2}. (١٥/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وجَعَلْنا النَّهارَ مَعاشًا﴾</span> لكي تَنتشروا لمعيشتكم، فهذان نِعمتان مِن نِعَم الله عليكم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٣١٢.|2:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٠. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥٥٩.
  78,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبَنَیۡنَا فَوۡقَكُمۡ سَبۡعࣰا شِدَادࣰا ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٤٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وبَنَيْنا فَوْقَكُمْ سَبْعًا شِدادًا﴾</span>، يريد: سبع سماوات{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر مُلكه وجَبروته وارتفاعه، فقال: <span class="qpc-hafs">﴿وبَنَيْنا فَوْقَكُمْ سَبْعًا شِدادًا﴾</span> يعني بالسبع: السموات، وغِلظ كلّ سماء مسيرة عام، وبين كلّ سماءين مثل ذلك، نظيرها في المؤمنون [١٧]: <span class="qpc-hafs">﴿خَلَقْنا فَوْقَكُمْ سَبْعَ طَرائِقَ﴾</span>، فذلك قوله: <span class="qpc-hafs">﴿شِدادًا﴾</span>، قال: وهي فوقكم، يا بني آدم، فاحذروا، لا تَخرّ عليكم إنْ عَصيتم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٣١٢.|2:تفسير مقاتل بن سليمان ٤/٥٥٩.
  78,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا سِرَاجࣰا وَهَّاجࣰا ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وجَعَلْنا سِراجًا وهّاجًا﴾</span>، قال: مُضيئًا{1}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿وجَعَلْنا سِراجًا وهّاجًا﴾</span>، قول: سِراجًا منيرًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وجَعَلْنا سِراجًا وهّاجًا﴾</span>، قال: يتلألأ{3}. (١٥/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وجَعَلْنا سِراجًا وهّاجًا﴾</span>، قال: الوهّاج: المنير{4}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿سراجا وهاجا﴾</span>، قال: الوهج: المنير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وجَعَلْنا سِراجًا وهّاجًا﴾</span> يعني: الشمس وحرّها مُضيئًا، يقول: جَعل فيها نورًا وحرًّا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿سِراجًا وهّاجًا﴾</span>، قال: يتلألأ ضوءَه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/١١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٤/١١.|3:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١١، وأبو الشيخ في العظمة (٦١٨). وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.|4:أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/١١، والخرائطي في مكارم الأخلاق (٥٨٨- منتقى) مختصرًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|5:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.|6:تفسير مقاتل بن سليمان ٤/٥٥٩.|7:أخرجه ابن جرير ٢٤/١١.
  78,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَ ٰ⁠تِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٥٢<span class="dash">-</span></span> عن قتادة -من طريق أبي عوانة- قال: في مصحف <span class="name-1">الفضل بن عباس</span>: (وأَنزَلْنا بِالمُعْصِراتِ مَآءً ثَجّاجًا){1}. (١٥/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٣<span class="dash">-</span></span> عن قتادة، قال: في قراءة <span class="name-1">ابن عباس</span>: (وأَنزَلْنا بِالمُعْصِراتِ): بالرياح{2}. (١٥/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: (وأَنزَلْنا بِالمُعْصِراتِ): الريح. وكذلك كان يقرؤها: (بِالمُعْصِراتِ مَآءً ثَجّاجًا): منصبًّا{3}. (١٥/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- أنه كان يقرأ: (وأَنزَلْنا بِالمُعْصِراتِ)، يعني: الرياح{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَ ٰ⁠تِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٥٦<span class="dash">-</span></span> قال <span class="name-1">أُبيّ بن كعب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٧<span class="dash">-</span></span> و<span class="name-2">سعيد بن جُبَير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٨<span class="dash">-</span></span> و<span class="name-2">زيد بن أسلم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٥٩<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿مِنَ المُعْصِراتِ﴾</span>، أي: من السموات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق قيس بن السّكن- في قوله: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ ماءً ثَجّاجًا﴾</span>، قال: يَبعث الله الريح، فتَحمل الماء من السماء، فتَمْرِي به السحاب، فتدُرّ كما تدُرّ اللّقحة، والثَّجاج ينزل من السماء أمثال العَزالِي{6}، فتَصرِفه الرياح، فيَنزل مُتفرّقًا{7}. (١٥/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: الرياح{8}. (١٥/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: السحاب{9}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>. قال: السحاب يَعصِر بعضها بعضًا، فيَخرج الماء مِن بين السحابتين. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ النّابغة وهو يقول:</p><p>تجُرُّ بها الأرواح من بين شمأل وبين صَباها المعصراتُ الدَّوامسُ؟{10}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٤<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٥<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span> هي السحاب التي تَتحلَّب بالمطر ولَمّا تُمطر، كالمرأة المُعصر، وهي التي دنا حيضها ولم تحض{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: الريح{12}. (١٥/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: السحاب{13}. (١٥/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: من السماء{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٦٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي حمزة العطار- <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: المُعصرات: السحاب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: من السماء، وبعضهم يقول: الريح{16}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</span>، قال: من السحاب{17}. (١٥/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٢<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿مِنَ المُعْصِرات﴾</span>، قال: المُعصرات: السحاب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِرات﴾</span>، قال: المُعصرات: الرياح. وقرأ قوله: <span class="qpc-hafs">﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا﴾</span> إلى آخر الآية [الروم:٤٨]{4}<span class=comment-ref>٦٩٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٢</span> اختُلف في المراد بالمُعصرات على أقوال: <b>الأول</b>: الرياح. <b>الثاني</b>: السحاب. <b>الثالث</b>: السماء.</p><p>وقد <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٤٢٤) قراءة تقوي القول الأول، فقال: «وقرأ ابن الزُّبير، وابن عباس، والفضل بن عباس، وقتادة، وعكرمة: (وأَنزَلْنا بِالمُعْصِراتِ)، فهذا يقوي أنه أراد الرياح».</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٨/٥١٤-٥١٥) تفسير المعصرات بالسحاب بأنه: "مأخوذ من العَصر؛ لأنّ السحاب يَنعصر فيخرج منه الماء، وهذا قول الجمهور، وبه فسّر الحسن بن محمد العنبري القاضي بيت حسان:</p><p>كلتاهما حَلَب العصير</p><p>وقال بعض مَن سَمّيت: هي السحاب التي فيها الماء ولــمـّـا تُمطر كالمرأة المُعصر، وهي التي دنا حيضها ولم تَحض بعد. وقال ابن كيسان: قيل للسحاب مُعصرات من حيث تغيث، فهي من العُصرة، ومنه قوله تعالى: <span class="qpc-hafs">﴿وفِيهِ يَعْصِرُونَ﴾</span> [يوسف:٤٩]".</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ كثير</u> (١٤/٢٢٨) القول الأول بقوله: «ومعنى هذا القول: أنها تَستدرّ المطر من السحاب».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/١٤) القول الثاني، و<span class="comment-type-2">انتقد</span> القولين الآخريين <span class="mustanad">مستندًا إلى الدلالة العقلية، والأغلب من اللغة</span>، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: إنّ الله أخبر أنه أنزل من المُعصرات، وهي التي قد تَحلّبتْ بالماء من السحاب ماء، وإنما قلنا ذلك أولى بالصواب لأن القول في ذلك على أحد الأقوال الثلاثة التي ذكرت، والرياح لا ماء فيها فينزل منها، وإنما ينزل بها، وكان يصحّ أن تكون الرياح لو كانت القراءة: (وأَنزَلْنا بِالمُعْصِراتِ)، فلما كانت القراءة: <span class="qpc-hafs">﴿من المعصرات﴾</span> عُلم أنّ المعني بذلك ما وصفت، فإن ظنّ ظانٌّ أنّ الباء قد تعقب في مثل هذا الموضع»مِن«؛ قيل: ذلك وإن كان كذلك فالأغلب من معنى مِن غير ذلك، والتأويل على الأغلب مِن معنى الكلام. فإن قال: فإنّ السماء قد يجوز أن تكون مرادًا بها. قيل: إنّ ذلك وإن كان كذلك فإنّ الأغلب من نزول الغيث من السحاب دون غيره».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> <span class="mustanad">مستندًا إلى النظائر</span>، فقال: «والأظهر أنّ المراد بالمُعصرات: السحاب، كما قال الله تعالى: <span class="qpc-hafs">﴿الله الذي يرسل الرياح فتثير سحابا فيبسطه في السماء كيف يشاء ويجعله كسفا فترى الودق يخرج من خلاله﴾</span> [الروم:٤٨]، أي: مِن بينه».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> القول الثالث بقوله: «وهذا قول غريب».</div></p><p><h3><span class="qpc-hafs">﴿مَاۤءࣰ ثَجَّاجࣰا ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span>، قال: مُنصَبًّا{20}.(١٥/١٩٣) (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿ثَجّاجًا﴾</span>. قال: الثَّجاج: الكثير الذي يَنبتُ منه الزرع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ أبا ذُؤيب يقول:</p><p>سقى أُمَّ عمرو كلَّ آخر ليلة غمائمُ سُود ماؤهن ثجيج؟{21}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ماء ثجاجا﴾</span>، قال: مُنصبًّا يَنصب{22}. (١٥/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span>، قال: صبًّا. أو قال: كثيرًا{13}. (١٥/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي حمزة العطار- <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span> ... الثّجاج: الماء الكثير يُنبتُ الله به الحَبّ{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span>، قال: الثّجاج: المُنصَبُّ{25}. (١٥/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span> مُتتابعًا يتلو بعضه بعضًا{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span>، قال: مُنصبًّا{27}. (١٥/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذَكر نِعَمَه، فقال: <span class="qpc-hafs">﴿وأَنْزَلْنا مِنَ المُعْصِراتِ ماءً ثَجّاجًا﴾</span> يعني: مطرًا كثيرًا مُنصَبًّا يتبع بعضه بعضًا، وذلك أنّ الله ﷿ يُرسل الرياح، فتأخذ الماء مِن سماء الدنيا مِن بحر الأرزاق، ولا تقوم الساعة ما دام به قطرة ماء، فذلك قوله: <span class="qpc-hafs">﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</span> [الذاريات:٢٢]، قال: تجيء الريح، فتُثير سحابًا، [فتُلقحه]، ثم تمطر، وتخرج الريح والمطر جميعًا من خلل السحاب{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span>، قال: مُتتابعًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ماءً ثَجّاجًا﴾</span>، قال: كثيرًا{29}<span class=comment-ref>٦٩٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٣</span> في قوله: <span class="qpc-hafs">﴿ثجاجا﴾</span> قولان: <b>الأول</b>: مُنصبًّا مُتتابعًا. <b>الثاني</b>: كثيرًا.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/١٤-١٥) القول الأول، و<span class="comment-type-2">انتقد</span> الثاني <span class="mustanad">مستندًا إلى أقوال السلف، واللغة، والنظائر</span>، فقال: «وأما قوله: <span class="qpc-hafs">﴿ماء ثجاجا﴾</span> يقول: ماء مُنصبًّا يتبع بعضه بعضًا، كثج دماء البدن، وذلك سفكها، وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على ذلك، ثم قال: «ولا يُعرف في كلام العرب من صفة الكثرة الثّجّ، وإنما الثّجّ: الصَّبّ المُتتابع. ومنه قول النبي ﷺ: «<b>أفضل الحج: العَجّ، والثّجّ</b>». يعني بالثّجّ: صبّ دماء الهدايا والبدن بذبحها، يقال منه: ثججت دمه فأنا أثجّه ثجًّا، وقد ثجّ الدمُ فهو يثج ثجوجًا».</div></p></div>",footnotes:1:أخرجه سعيد بن منصور ٨/٢٤٦ (٢٣٨٠). وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن الزبير، وعكرمة، ومجاهد، وقتادة، وغيرهم. انظر: مختصر ابن خالويه ص١٦٨.|2:عزاه السيوطي إلى ابن جرير، وابن الأنباري في المصاحف. وعند ابن جرير ٢٤/١٢ عن قتادة -من طريق سعيد- بلفظ: «هي في بعض القراءات»، دون ذكر ابن عباس.|3:عزاه السيوطي إلى الخرائطي في مكارم الأخلاق.|4:أخرجه ابن جرير ٢٤/١٢.|5:تفسير الثعلبي ١٠/١١٤، وتفسير البغوي ٨/٣١٣ عنهم دون أُبَيّ بن كعب.|6:العزالي: جمع عزلاء، وهي فم المزادة الأسفل، شبه اتساع المطر واندفاقه بالذي يخرج من فم المزادة. النهاية (عزل).|7:أخرجه الشافعي ١/٣٩٩ (٤٩٣ - شفاء العي)، وسعيد بن منصور ٨/٢٤٦ (٢٣٧٩)، والخرائطي (٥٥٩ - منتقى)، والبيهقي في سُنَنِه ٣/٣٦٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن مردويه.|8:أخرجه أبو يعلى (٢٦٦٣)، وابن جرير ٢٤/١١-١٢، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٢٧-. وعزاه السيوطي إلى عَبد بن حُمَيد، والخرائطي.|9:أخرجه ابن جرير ٢٤/١٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:أخرجه الطستي -كما في الإتقان ٢/٨٣-.|11:تفسير الثعلبي ١٠/١١٤، وتفسير البغوي ٨/٣١٢ بنحوه.|12:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٣-. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.|13:عزاه السيوطي إلى عَبد بن حُمَيد.|14:أخرجه ابن جرير ٢٤/١٣.|15:أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٣)-.|16:أخرجه عبد الرزاق ٢/٣٤٢ واللفظ له، وابن جرير ٢٤/١٣، ومن طريق سعيد أيضًا بنحوه، والخرائطي في مكارم الأخلاق (٥٨٨- منتقى) مختصرًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|17:أخرجه ابن جرير ٢٤/١٣. وعزاه السيوطي إلى عَبد بن حُمَيد.|18:أخرجه ابن جرير ٢٤/١٣.|19:أخرجه ابن جرير ٢٤/١٢.|20:أخرجه أبو يعلى (٢٦٦٣)، وابن جرير ٢٤/١٤-١٥، وكذلك من طريق عطية، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٢٧-. وعزاه السيوطي إلى الخرائطي، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.|21:مسائل نافع (٢٤٧).|22:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٥ بنحوه. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.|23:عزاه السيوطي إلى عَبد بن حُمَيد.|24:أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٣)-.|25:أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/١٥، والخرائطي في مكارم الأخلاق (٥٨٨- منتقى). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|26:تفسير الثعلبي ١٠/١١٤، وتفسير البغوي ٨/٣١٣.|27:أخرجه ابن جرير ٢٤/١٥. وعزاه السيوطي إلى عَبد بن حُمَيد.|28:تفسير مقاتل بن سليمان ٤/٥٥٩-٥٦٠.|29:أخرجه ابن جرير ٢٤/١٥.|30:أخرجه ابن جرير ٢٤/١٥.
  78,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّنُخۡرِجَ بِهِۦ حَبࣰّا وَنَبَاتࣰا ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿لِنُخْرِجَ بِهِ﴾</span> يعني: بالمطر <span class="qpc-hafs">﴿حَبًّا﴾</span> يعني بالحبوب: كلّ شيء يُزرع ويُحصد؛ مِن البُرّ، والشعير، والسمسم، ونحوها من الحبوب، قال: <span class="qpc-hafs">﴿ونَباتًا﴾</span> يعني: كلّ شيء يَنبتُ في الجبال والصحاري من الشجر والكلأ، فذلك النبات، وهي تَنبتُ عامًا بعام من قِبل نفسها{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٠.
  78,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَنَّـٰتٍ أَلۡفَافًا ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، قال: مُجتمعة{1}. (١٥/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، يقول: جنات التَفَّ بعضها ببعض{2}. (١٥/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، قال: مُلتفّة{3}. (١٥/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٨٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، قال: الزرع إذا كان بعضُه إلى جنب بعض{4}. (١٥/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، قال: مُلتفّة بعضها إلى بعض{5}. (١٥/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span> يعني: وبساتين مُلتفّة بعضها إلى بعض مِن كثرة الشجر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٢<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، قال: مُلتفّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجَنّاتٍ ألْفافًا﴾</span>، قال: هي المُلتفّة بعضها فوق بعض{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/١٦، وابن أبي حاتم -كما في الإتقان ٢/٥٢-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٤/١٧.|3:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|4:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|5:أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/١٧، وكذلك من طريق سعيد. وعزاه السيوطي إلى عَبد بن حُمَيد.|6:تفسير مقاتل بن سليمان ٤/٥٦٠.|7:أخرجه ابن جرير ٢٤/١٧.|8:أخرجه ابن جرير ٢٤/١٧.
  78,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ یَوۡمَ ٱلۡفَصۡلِ كَانَ مِیقَـٰتࣰا ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ كانَ مِيقاتًا﴾</span>، قال: هو يوم عَظَّمه الله، وهو يوم يُفصَل فيه بين الأولين والآخرين{1}. (١٥/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال: <span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ﴾</span> يعني: يوم القضاء -وهو يوم القيامة- بين الخلائق <span class="qpc-hafs">﴿كانَ مِيقاتًا﴾</span> يعني: كان ميقات الكافر، وذلك أنهم كانوا يقولون: <span class="qpc-hafs">﴿مَتى هَذا الوَعْدُ إنْ كُنْتُمْ صادِقِينَ﴾</span> [الملك:٢٥]؛ فأَنزل الله ﷿ يُخبرهم بأنّ ميقات ذلك اليوم كائن يوم الفصل، يا معشر الكفار، فتُجازون ما وعدكم على ألسنة الرُّسُل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/١٨ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/٥٦٠.
  78,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ یُنفَخُ فِی ٱلصُّورِ فَتَأۡتُونَ أَفۡوَاجࣰا ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٨٩٦<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: سُئِل النبيُّ ﷺ عن الصُّور، فقال: «<b>قرنٌ يُنفخُ فيه</b>»{1}. (٦/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٧<span class="dash">-</span></span> عن معاذ بن جبل، قال: يا رسول الله، ما قول الله: <span class="qpc-hafs">﴿يَوْمَ يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أفْواجًا﴾</span>؟ فقال: «<b>يا معاذ، سألتَ عن عظيم من الأمر</b>». ثم أرسل عينيه، ثم قال: «<b>عشرة أصناف قد ميّزهم الله مِن جماعة المسلمين، فبدَّل صورهم؛ فبعضهم على صورة القِردة، وبعضهم على صورة الخنازير، وبعضهم منكوسون، أرجلهم فوق وجوههم أسفل، يُسحبون عليها، وبعضهم عُمْيٌ يَتردّدون، وبعضهم صُمٌّ بُكمٌ لا يَعقلون، وبعضهم يَمضَغُون ألسنتهم وهي مُدلاة على صدورهم، يَسيل القِيح من أفواههم لُعابًا، يَقْذَرُهم أهل الجمع، وبعضهم مُقطّعة أيديهم وأرجلهم، وبعضهم مُصلَّبون على جذوع من نار، وبعضهم أشدُّ نَتنًا مِن الجِيَف، وبعضهم يَلبسون جِبابًا سابغة من قَطِران لازقة بجلودهم، فأما الذين على صورة القِردة فالقتّات من الناس، وأما الذين على صورة الخنازير فأكَلة السُّحت، والمُنكّسون على وجوههم فأكَلة الربا، والعُمي مَن يَجُور في الحكم، والصُّمّ البُكم المُعجبون بأعمالهم، والذين يَمضَغُون ألسنتهم فالعلماء والقصّاص مِن الذين يخالف قولهُم أعمالهَم، والمُقطّعة أيديهم وأرجلهم الذين يؤذون الجيران، والمُصلَّبون على جذوع من نار فالسُّعاة بالناس إلى السلطان، والذين هم أشد نَتنًا مِن الجِيَف الذين يتمتعون بالشهوات واللذات ويمنعون حقّ الله وحقّ الفقراء من أموالهم، والذين يَلبسون الجِباب فأهل الكِبْر والخُيلاء والفَخْر</b>»{2}. (١٥/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أفْواجًا﴾</span>، قال: زُمَرًا زمَرًا{3}. (١٥/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٨٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبرهم أيضًا، فقال: <span class="qpc-hafs">﴿يَوْمَ يُنْفَخُ فِي الصُّورِ﴾</span>، وذلك أنّ إسرافيل ﵇ يَنفخ فيها، فيقول: أيّتها العظام البالية، وأيّتها العروق المُتقطّعة، وأيّتها اللحوم المُتمزّقة، وأيّتها الأشعار الساقطة، اجتمعنَّ لِنَنفخَ فيكم أرواحَكم، ونجازيكم بأعمالكم. ويُديم المَلَك الصوت، فتجتمع الأرواح كلّها في القَرْن، والقَرْن طوله طول السموات والأرض، فتَخرج أرواحهم مثل النّحل؛ سُود وبِيض، شقي وسعيد، أرواح المؤمنين بِيض كأمثال النّحل مِن السماء إلى وادٍ بدمشق يقال له: الجابية، وتَخرج أرواح الكفار مِن الأرض السُّفلى سُود إلى وادٍ بحضرموت يُقال له: بَرَهُوت، وكلّ روح أعرَف بجسد صاحبه مِن أحدكم إلى منزله <span class="qpc-hafs">﴿فَتَأْتُونَ أفْواجًا﴾</span>، ثم ينزل إسرافيل من فوق السماء السابعة، فيَجلس على صخرة بيت المقدس، فيَأخذ أرواح الكفار والمؤمنين ويَجعلهم في القَرْن، ودائرة القَرْن مسيرة خمسمائة عام، ثم يَنفخ في القَرْن، فتَطير الأرواح حتى تطبق ما بين السماء والأرض، فتَذهب كلّ روح، فتقع في جسد صاحبها، فيَخرج الناس من قبورهم فوجًا فوجًا، فذلك قوله: <span class="qpc-hafs">﴿فَتَأْتُونَ أفْواجًا﴾</span> يعني: زمرًا زمرًا، وفِرقًا فِرقًا، وأممًا أممًا{4}<span class=comment-ref>٦٩٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٤</span> أفادت آثار السلف أنّ الصُّور: هو القَرْن الذي يُنفخ فيه لِبَعْث الناس. وقد <span class="comment-type-4">ذكر</span> ذلك <u>ابنُ عطية</u> (٨/٥١٦)، ثم <span class="comment-type-4">ذكر</span> احتمالًا آخر، فقال: «ويحتمل هذا الموضع أن يكون»الصُّور«فيه جمع صورة، أي: يوم يرد الله فيه الأرواح إلى الأبدان، هذا قول بعضهم في الصُّورِ، وجوزه أبو حاتم». ثم <span class="comment-type-3">رجّح</span> -<span class="mustanad">مستندًا إلى أقوال السلف، والنظائر</span>- الأول، فقال: «والأول أشهر، وبه تظاهرت الآثار، وهو ظاهر كتاب الله تعالى في قوله: <span class="qpc-hafs">﴿ثُمَّ نُفِخَ فِيهِ أُخْرى﴾</span> [الزمر:٦٨]».</div></p></div>",footnotes:1:أخرجه أحمد ١١/٥٣ (٦٥٠٧)، ١١/٤١٠ (٦٨٠٥)، وأبو داود ٧/١٢١ (٤٧٤٢)، والترمذي ٤/٤٢٧-٤٢٨ (٢٥٩٩)، ٥/٤٥١ (٣٥٢٥)، وابن حبان ١٦/٣٠٣ (٧٣١٢)، والحاكم ٢/٤٧٣ (٣٦٣١)، ٢/٥٥٠ (٣٨٧٠)، ٤/٦٠٤ (٨٦٨٠)، ويحيى بن سلام ١/٢٠٩، ٢/٨١٢، وابن جرير ١٥/٤١٦، ٢٤/١٩، وابن أبي حاتم ٤/١٣٢٣ (٧٤٨٣)، ٩/٢٩٢٨ (١٦٦١٩)، والثعلبي ٧/٢٢٦، ٨/٢٥٤.</p><p>قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وأورده الألباني في الصحيحة ٣/٦٨ (١٠٨٠).</p><p>وقد تقدم تخريجه عند تفسير قوله تعالى: <span class="qpc-hafs">﴿ولَهُ المُلْكُ يَوْمَ يُنْفَخُ فِي الصُّورِ﴾</span> [الأنعام:٧٣]. كذلك تقدمت الآثار في بيان الصور هناك.|2:أخرجه ابن مردويه -كما في تخريج الكشاف ٤/١٤٣-١٤٥-، والثعلبي ١٠/١١٥.</p><p>قال الألباني في الضعيفة ١٣/٩٩٤ (٦٤٤٤): «موضوع».|3:تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٩، وابن أبي حاتم -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|4:تفسير مقاتل بن سليمان ٤/٥٦٠-٥٦١.
  78,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفُتِحَتِ ٱلسَّمَاۤءُ فَكَانَتۡ أَبۡوَ ٰ⁠بࣰا ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفُتِحَتِ السَّماءُ﴾</span> يعني: وفُرجت السماء، يعني: وفُتِقت السماء فتَقطّعتْ، <span class="qpc-hafs">﴿فَكانَتْ أبْوابًا﴾</span> يعني: خللًا خللًا، فشبّهها الله بالغيم إذا انكشف بعد المطر، ثم تَهيج به الريح الشمال الباردة، فينقطع، فيصير كالأبواب{1}<span class=comment-ref>٦٩٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٥</span> ذكر <u>ابنُ عطية</u> (٨/٥١٦) في قوله: <span class="qpc-hafs">﴿فكانت أبوابا﴾</span> قولين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فكانت أبوابا﴾</span> <b>قيل</b>: معناه: تتفطّر وتتشقّق حتى يكون فيها فتوح كالأبواب في الجدران. <b>وقال آخرون</b> -فيما حكى مكي بن أبي طالب-: الأبواب هنا فِلَق الخشب التي تُجعل أبوابًا لفتوح الجدران، أي: تتقطّع السماء قِطعًا صغارًا حتى تكون كألواح الأبواب. و<span class="comment-type-3">رجّح</span> القول الأول بقوله:»والقول الأول أحسن". ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦١.
  78,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَسُیِّرَتِ ٱلۡجِبَالُ فَكَانَتۡ سَرَابًا ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وسُيِّرَتِ الجِبالُ فَكانَتْ سَرابًا﴾</span>، قال: سراب الشمس: الآل{1}. (١٥/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٠٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٠٣<span class="dash">-</span></span> و<span class="name-2">عطاءِ بن أبي رباح</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٠٤<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- قالوا: السّراب كهيئة الآل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وسُيِّرَتِ الجِبالُ﴾</span> يعني: وانقلعت الجبال مِن أماكنها، فطارتْ بين السماء والأرض مِن خشية الله، فضَرب الله لها مثلًا، فقال: <span class="qpc-hafs">﴿فَكانَتْ سَرابًا﴾</span> يعني: مثل السّراب الذي يكون بالقاع، يحسبه الظمآن ماء، فإذا أتاه لم يجده شيئًا، فذلك قوله: <span class="qpc-hafs">﴿تَحْسَبُها جامِدَةً﴾</span> [النمل:٨٨] يعني: مِن بعيد يَحسبها جبلًا قائمًا، فإذا انتهى إليه ومسّه لم يجده شيئًا، فتصير الجبالُ أول مرة كالمُهل، ثم تصير الثانية كالعِهن المنفوش، ثم تَذهب فتصير لا شيء، فتراها تحسبها جبالًا، فإذا مسَستها لم تجدها شيئًا، فذلك قوله: <span class="qpc-hafs">﴿وسُيِّرَتِ الجِبالُ﴾</span> يعني: انقطعت الجبال مِن خشية الله ﷿ يوم القيامة، <span class="qpc-hafs">﴿فَكانَتْ سَرابًا﴾</span> فما حالك، يا ابن آدم؟!{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٥-.|3:تفسير مقاتل بن سليمان ٤/٥٦١-٥٦٢.
  78,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادࣰا ۝٢١﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في الوليد بن المُغيرة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادࣰا ۝٢١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٠٧<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق عمرو بن مالك- في قوله: <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span>، قال: صارت{2}. (١٥/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span>، قال: لا يَدخل الجنةَ أحدٌ حتى يجتاز النار{3}. (١٥/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٠٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي سهل- في قوله: <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span>، قال: تَرْصُدهم، واللهِ. قال: وبينما رجل يمرّ إذ استقبله آخر، قال: أبَلغك أنّ بالطريق رَصَدًا؟ قال: نعم. قال: فخذْ حِذرك إذًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبد الله بن بكر- <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span>، قال: ألا إنّ على الباب الرَصَد، فمَن جاء بجواز جاز، ومن لم يَجِئْ بجواز حُبس{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span>، قال: تَعلَّموا أنه لا سبيل إلى الجنة حتى تُقطع النار، وقال في آية أخرى: <span class="qpc-hafs">﴿وإنْ مِنكُمْ إلّا وارِدُها﴾</span> [مريم:٧١]{6}. (١٥/١٩٩-٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق بكر بن مُضر- كان يقول: إنّ بين أيديكم مرصدًا، فخذوا له جوازَه. ثم قرأ: <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا لِلطّاغِينَ مَآبًا﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span>، قال: عليها ثلاث قناطر{8}. (١٥/١٩٩)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٢.|2:أخرجه ابن أبي شيبة ١٤/١٨. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، ابن المنذر.|3:أخرجه ابن جرير ٢٤/٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|4:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٨٧ (٣٦٤١٧)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤٢ (٢٠١)- من طريق فضالة.|5:أخرجه ابن جرير ٢٤/٢٠، والبيهقي في شعب الإيمان ٣/١٥٥-١٥٦ (٨٧٤).|6:أخرجه ابن جرير ٢٤/٢١ مختصرًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|7:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦٨ (١٥٤).|8:أخرجه ابن جرير ٢٤/٢١.
  78,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّلطَّـٰغِینَ مَـَٔابࣰا ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لِلطّاغِينَ مَآبًا﴾</span>، قال: مأوى، ومنزلًا{1}. (١٥/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا لِلطّاغِينَ﴾</span> يعني: للكافرين <span class="qpc-hafs">﴿مَآبًا﴾</span> يعني: للمشركين مرجعًا إليها، نزلت في الوليد بن المغيرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿مَآبًا﴾</span>، يقول: مَرجعًا، ومنزلًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/٥٦٢.|3:أخرجه ابن جرير ٢٤/٢١.
  78,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّـٰبِثِینَ فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٩١٧<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span> أنه قرأها: ‹لَبِثِينَ فِيهَآ أحْقابًا› بغير ألف{1}. (١٥/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٨<span class="dash">-</span></span> عن <span class="name-2">عمرو بن شرحبيل</span> أنه قرأها: ‹لَبِثِينَ فِيهَآ أحْقابًا›{2}. (١٥/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩١٩<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿لابِثِينَ فِيهَآ أحْقابًا﴾</span> بالألف{2}<span class=comment-ref>٦٩٨٦</span>. (١٥/٢٠٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٦</span> <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/٢٢) -<span class="mustanad">مستندًا إلى الأفصح لغة</span>- قراءة مَن قرأ: <span class="qpc-hafs">﴿لابثين﴾</span> بالألف، فقال: «وأفصح القراءتين وأصحّهما مخرجًا في العربية قراءةُ مَن قرأ ذلك بالألف؛ وذلك أنّ العرب لا تكاد توقع الصفة إذا جاءت على (فَعِل) فتُعمِلها في شيء وتنصبه بها، لا يكادون أن يقولوا: هذا رجل بَخِلٌ بماله، ولا عَسِرٌ علينا، ولا هو خَصِمٌ لنا. لأنّ (فَعِل) لا يأتي صفة إلا مدحًا أو ذمًّا، فلا يَعمل المدح والذم في غيره، وإذ أرادوا إعمال ذلك في الاسم أو غيره جعلوه فاعلًا، فقالوا: هو باخل بماله، وهو طامع فيما عندنا، فلذلك قلتّ: إنّ <span class="qpc-hafs">﴿لابثين﴾</span> أصح مخرجًا في العربية وأفصح، ولم أحلّ قراءة مَن قرأ: ‹لَبِثِينَ › وإن كان غيرها أفصح؛ لأن العرب ربما أعملت المدح في الأسماء».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥١٨) قراءة: ‹لَبِثِينَ ›، ثم <span class="comment-type-2">انتقدها</span> -<span class="mustanad">مستندًا إلى اللغة</span>- عليها قائلًا: «وهي قراءة معترضة لأنّ (فَعِلًا) إنما يكون لما صار خُلُقًا؛ كحَذِر وفَرِق، وقد جاء شاذًّا فيما ليس بخُلُق».</div></p><p><h3><span class="qpc-hafs">﴿لَّـٰبِثِینَ فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٢٠<span class="dash">-</span></span> عن أبي أُمامة، عن النبيِّ ﷺ، قال: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: «<b>الحُقُب ألف شهر، والشهر ثلاثون يومًا، والسنة اثنا عشر شهرًا، والسنة ثلاثمائة وستون يومًا، كلّ يوم منها ألف سنة مما تَعُدُّون؛ فالحُقُب ثلاثون ألف سنة</b>»{4}. (١٥/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢١<span class="dash">-</span></span> عن أبي هريرة رفعه: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: «<b>الحُقُب ثمانون سنة</b>»{5}. (١٥/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٢<span class="dash">-</span></span> عن ابن عمر، عن النبيِّ ﷺ، قال: «<b>واللهِ، لا يخرج من النار أحد حتى يَمكث فيها أحقابًا، والحُقُب بضع وثمانون سنة، كلّ سنة ثلاثمائة وستون يومًا، واليوم ألف سنة مما تَعُدُّون</b>»{6}. (١٥/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٣<span class="dash">-</span></span> عن عُبادة بن الصّامت، قال: قال رسول الله ﷺ: «<b>الحُقُب أربعون سنة</b>»{7}. (١٥/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرّة- قال: لو عَلم أهل النار أنهم يَلبثون في النار عدد حصى الدنيا لفرحوا، ولو عَلم أهل الجنة أنهم يَلبثون في الجنة عدد حصى الدنيا لحزنوا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الضحى- قال: لا يَعلم عدد الأحقاب إلا الله ﷿{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عمرو بن ميمون- في قوله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: الحُقُب ثمانون سنة{10}. (١٥/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٧<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق شريك، عن عاصم بن أبي النجود، عن أبي صالح - <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: الحُقُب ثمانون سنة، والسنة ثلاثمائة وستون يومًا، واليوم كألف سنة مما تَعُدُّون{11}. (١٥/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٨<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق حماد بن سلمة، عن عاصم بن أبي النجود، عن أبي صالح - <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: الحُقُب ثمانون عامًا، اليوم منها كسُدس الدنيا{12}. (١٥/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عمرو بن ميمون- وفي قوله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: الحُقُب الواحد ثمانون سنة{13}. (١٥/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي سنان- قال: الحُقُب ثمانون سنة{14}. (١٥/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: سنين{15}. (١٥/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عمر</span>: فلا يَتّكِلنّ أحدٌ على أنه يَخرج من النار{16}. (١٥/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٣<span class="dash">-</span></span> قال علي بن أبي طالب <span class="name-2">لهلال الهَجَرِيّ</span>: ما تجدون الحُقُب في كتاب الله؟ قال: نجده ثمانين سنة، كلّ سنة اثنا عشر شهرًا، كلّ شهر ثلاثون يومًا، كلّ يوم ألف سنة{17}. (١٥/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٤<span class="dash">-</span></span> عن <span class="name-2">بشير بن كعب</span> -من طريق إسحاق بن سُويد- في قوله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: بلغني: أنّ الحُقُب ثلاثمائة سنة، كلّ سنة ثلاثمائة وستون يومًا، كلّ يوم ألف سنة{18}. (١٥/٢٠٠-٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق الأعمش- في قوله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: الحُقُب ثمانون سنة، السنة ثلاثمائة وستون يومًا، اليوم سنة أو ألف سنة{19}. (١٥/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٦<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span> الأحقاب ثلاثة وأربعون حُقُبًا، كلّ حُقُب سبعون خريفًا، كلّ خريف سبعمائة سنة، كلّ سنة ثلاثمائة وستون يومًا، كلّ يوم ألف سنة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٧<span class="dash">-</span></span> عن <span class="name-2">خالد بن معدان</span> -من طريق عامر بن جَشِيب- في قوله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، وقوله: <span class="qpc-hafs">﴿إلّا ما شاءَ رَبُّكَ﴾</span> [هود:١٠٧]: إنهما في أهل التوحيد مِن أهل القِبلة{21}. (١٥/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: ليس لها أجل، كلّما مضى حُقُب دخل في الأخرى{22}. (١٥/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٣٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سالم- قال: الحُقُب الواحد سبعون سنة، كلّ يوم منها ألف سنة{23}. (١٥/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق جعفر بن جسر، عن أبيه- قال: والحُقُب الواحد ثمانون ألف سنة، والسنة ثلاثمائة وستون يومًا، وكلّ يوم <span class="qpc-hafs">﴿عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾</span> [الحج:٤٧]{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- في قوله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: أما الأحقاب فلا يَدري أحد ما هي، وأما الحُقُب الواحد: فسبعون ألف سنة، كلّ يوم كألف سنة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: الأحقاب ما لا انقطاع له، كلّما مضى حُقُب جاء بعده حُقُب. قال: وذُكر لنا أنّ الحُقُب: ثمانون سنة من سني يوم القيامة{26}. (١٥/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٣<span class="dash">-</span></span> عن <span class="name-2">سيّار أبي الحكم</span>، قال: الحُقُب: ثمانون سنة، والسنة ثلاثمائة وستون يومًا، واليوم كألف سنة مما تَعُدُّون{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، قال: لا يَدري أحدُكم تلك الأحقاب، إلا أنّ الحُقُب الواحد ثمانون سنة، السنة ثلاثمائة وستون يومًا، اليوم الواحد مِقدار ألف سنة، والحُقُب الواحد ثمانية عشر ألف سنة{28}. (١٥/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span> الحُقُب الواحد سبع عشرة ألف سنة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لابِثِينَ فِيها﴾</span> يعني: في جهنم <span class="qpc-hafs">﴿أحْقابًا﴾</span> يعني: في جهنم أحقابًا، وهي سبعة عشر حُقُبًا، يعني: الأزمنة والأحقاب لا يَدري عددها، ولا يَعلم منتهاها إلا الله ﷿، الحُقُب الواحد ثمانون سنة، السنة فيها ثلاثمائة وستون يومًا، كلّ يوم فيها مِقدار ألف سنة، وكان هذا بمكة{30}<span class=comment-ref>٦٩٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٧</span> اختُلف في الموصوف باللبث أحقابًا على قولين: <b>الأول</b>: الكفار. <b>الثاني</b>: عُصاة المؤمنين. وكذا اختُلف في مدة الحُقُب على أقوال: <b>الأول</b>: ألف شهر. <b>الثاني</b>: ثلاثون ألف سنة. <b>الثالث</b>: ثمانون سنة. <b>الرابع</b>: بضع وثمانون سنة. <b>الخامس</b>: أربعون سنة. <b>السادس</b>: ثلاثمائة سنة. <b>السابع</b>: ثمانون ألف سنة. <b>الثامن</b>: سبعون ألف سنة. <b>التاسع</b>: سبع عشرة ألف سنة. <b>العاشر</b>: أنّ الحُقُب لا حَدّ له.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢٤/٢٦ بتصرف) هذا الخلاف، ثم قال: «الذي قاله قتادة والربيع بن أنس في ذلك أصح. فإن قيل: فما للكفار عند الله عذاب إلا أحقابًا. قيل: إنّ الربيع وقتادة قد قالا: إنّ هذه الأحقاب لا انقضاء لها ولا انقطاع. وقد يحتمل أن يكون معنى ذلك: <span class="qpc-hafs">﴿لابثين فيها أحقابا﴾</span>، في هذا النوع من العذاب هو أنهم: <span class="qpc-hafs">﴿لا يذوقون فيها بردا ولا شرابا إلا حميما وغساقا﴾</span>، فإذا انقضتْ تلك الأحقاب صار لهم من العذاب أنواع غير ذلك، <span class="mustanad">كما قال -جلّ ثناؤه- في كتابه</span>: <span class="qpc-hafs">﴿وإن للطاغين لشر مآب جهنم يصلونها فبئس المهاد هذا فليذوقوه حميم وغساق وآخر من شكله أزواج﴾</span> [ص:٥٥-٥٨]، وهذا القول عندي <span class="comment-type-3">أشبه بمعنى الآية</span>».</p><p>وذكر <u>ابنُ عطية</u> (٨/٥١٨) هذه الأقوال، ثم قال <span class="comment-type-4">معلّقًا</span>: «اللازم أنّ الله تعالى أخبر عن الكفار أنهم يَلبثون أحْقابًا، كلّما مَرّ حُقُب جاء غيره إلى ما لا نهاية». و<span class="comment-type-2">انتقد</span> -<span class="mustanad">مستندًا إلى السياق</span>- قول مَن جعلها في عُصاة المؤمنين بقوله: «وهذا أيضًا ضعيف، ما بعده في السورة يرد عليه».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٦/٤٥٣) نحو ما جاء في كلام <u>ابن جرير</u> مِن أنّ قوله: <span class="qpc-hafs">﴿لابثين فيها أحقابا﴾</span> أي: في هذا النوع من العذاب عن الزّجّاج، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الدلالة العقلية، والإجماع</span>، فقال: «وهذا الذي قاله الزّجّاج شاذٌّ، خلاف ما عليه الأولون والآخرون، وهو خلاف ما دلّ عليه القرآن، فإنّ هذا يقتضي أنهم يَبقون بعد الأحقاب فيها، ولكن لا يَذوقون البرد والشراب حينئذ، وهذا باطل قطعًا، ثم إذا ذاقوا البَرد والشراب فهذا نعيم، فكيف يكونون مُعذّبين فيها ذلك؟!».</div></p><p><h3><span class="qpc-hafs">﴿لَّـٰبِثِینَ فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٤٧<span class="dash">-</span></span> عن عمرو بن أبي سَلمة، قال: سألت أبا معاذ الخراساني عن قول الله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>. فأَخبَرنا عن <span class="name-3">مقاتل بن حيّان</span> قال: منسوخة، نَسَخَتْها: <span class="qpc-hafs">﴿فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</span>{31}<span class=comment-ref>٦٩٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٤/٢٧) هذا القول، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى دلالة العقل</span>، فقال: «ولا معنى لهذا القول؛ لأن قوله: <span class="qpc-hafs">﴿لابثين فيها أحقابا﴾</span> خبر، والأخبار لا يكون فيها نسخ، وإنما النسخ يكون في الأمر والنهي».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٥١٢).</div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، وروح، وقرأ بقية العشرة: <span class="qpc-hafs">﴿لابِثِينَ﴾</span> بألف بعد اللام. انظر: النشر ٢/٣٩٧، والإتحاف ص٥٦٩.|2:عزاه السيوطي إلى عَبد بن حُمَيد.|3:عزاه السيوطي إلى عَبد بن حُمَيد.|4:أخرجه ابن أبي عمر العدني في مسنده -كما في إتحاف الخيرة المهرة ٦/٢٩٨ (٥٨٨٩)-، والطبراني في الكبير ٨/٢٤٤ (٧٩٥٧) مختصرًا، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٠٥-٣٠٦-، من طريق جعفر بن الزُّبير، عن القاسم، عن أبي أُمامة به.</p><p>وقال ابن كثير: «حديث منكر جدًّا، والقاسم هو والراوي عنه -وهو جعفر بن الزُّبير- كلاهما متروك». وقال الهيثمي في المجمع ٧/١٣٣ (١١٤٦٢): «فيه جعفر بن الزُّبير، وهو ضعيف». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٨ (٥٨٨٩): «هذا إسناد ضعيف؛ لضعف جعفر، والقاسم هو ابن عبد الرحمن». وقال السيوطي: «سند ضعيف».|5:أخرجه البزار ١٦/٢٠ (٩٠٤٩)، من طريق الحجاج بن نصير، عن همام عن عاصم، عن أبي صالح، عن أبي هريرة به.</p><p>قال البزار: «هذا الحديث لا نعلم أحدًا رفعه إلا الحجّاج بن نصير عن همام، وغيره يُوقفه». وقال الهيثمي في المجمع ٧/١٣٣ (١١٤٦١): «فيه حجّاج بن نصير، وثّقه ابن حبان، وقال: يخطئ ويَهم، وضعّفه جماعة، وبقية رجاله ثقات». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٨ (٥٨٨٩): «في سنده الحجّاج بن نصير، وهو ضعيف». وأورده الدارقطني في العلل ٨/٢٠٩ (١٥١٩). والسيوطي في اللآلئ المصنوعة ٢/٣٨٧.|6:أخرجه البزار ١٢/٢٤٠ (٥٩٨٠)، وأبو بكر الشافعي في الغيلانيات ١/٤٢٨ (٤٧٧)، والثعلبي ١٠/١١٦، من طريق سليمان بن مسلم، عن سليمان التيمي، عن نافع، عن ابن عمر به.</p><p>ذكره ابن الجوزي في الموضوعات ٣/٢٦٧. وقال الهيثمي في المجمع ١٠/٣٩٥ (١٨٦٣٢): «فيه سليمان بن مسلم الخشّاب، وهو ضعيف جدًّا». وقال السيوطي في اللآلئ المصنوعة ٢/٣٨٦: «قال ابن عدي: هذا حديث منكر جدًّا. وسليمان شبه المجهول، وروى عن التيميّ ما ليس من حديثه بحديثه، وقال الحافظ أبو الحسن الهيثمي وأبو الفضل بن حجر في الزوائد: هذا الحديث موضوع في نقدي». وأورده الألباني في الضعيفة ١١/٦٣٩.|7:أخرجه ابن عدي في الكامل ٦٥/٢٢٨، من طريق عمرو بن شمر، عن ليث بن أبي سليم، عن عبد الرحمن بن سابط، عن عُبادة بن الصّامت به.</p><p>وقال ابن عدي: «غير محفوظ». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٢٥٩ (٢٧١٠): «عمرو متروك الحديث، والحديث غير محفوظ».|8:تفسير البغوي ٨/٣١٥.|9:تفسير الثعلبي ١٠/١١٦.|10:أخرجه الحاكم ٢/٥١٢. وعزاه السيوطي إلى سعيد بن منصور.|11:أخرجه ابن جرير ٢٤/٢٤، وهناد (٢١٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|12:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٥-، وفي لفظ آخر عنده: ستة أيام منها كالدنيا كلها. وعزاه السيوطي إلى عَبد بن حُمَيد.|13:أخرجه سعيد بن منصور ٨/٢٤٧ (٢٣٨٢)، وابن جرير ١٥/٣١٠. وعزاه السيوطي إلى ابن المنذر.|14:أخرجه ابن جرير ٢٤/٢٤.|15:عزاه السيوطي إلى ابن أبي حاتم.|16:أخرجه البزار (٣٥٠٣- كشف)، والديلمي (٧٠٢٩). وعزاه السيوطي إلى ابن مردويه.|17:أخرجه عبد الرزاق ٢/٣٤٢-٣٤٣، وابن جرير ٢٤/٢٤، وهناد (٢٢٠). وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.|18:أخرجه ابن جرير ٢٤/٢٣-٢٤.|19:أخرجه ابن جرير ٢٤/٢٤، والشك في الأثر منه.|20:تفسير البغوي ٨/٣١٤.|21:أخرجه ابن جرير ٢٤/٢٦.|22:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٥-. وعزاه السيوطي إلى عَبد بن حُمَيد.|23:أخرجه ابن جرير ٢٤/٢٥ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.|24:أخرجه ابن أبي الدنيا في كتاب صفة النار، ومن طريق هشام أيضًا -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٧)-.|25:أخرجه ابن جرير ٢٤/٢٦.|26:أخرجه عبد الرزاق ٢/٣٤٢ من طريق معمر بلفظ: بلغنا أنّ الحُقُب ثمانون سنة من سني الآخرة، وابن جرير ٢٤/٢٥ من طريق معمر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|27:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٤٨ (٢٣٨٣).|28:أخرجه ابن جرير ٢٤/٢٥ دون آخره. وعزاه السيوطي إلى عَبد بن حُمَيد، وأبي الشيخ.|29:تفسير الثعلبي ١٠/١١٦، وتفسير البغوي ٨/٣١٥.|30:تفسير مقاتل بن سليمان ٤/٥٦٢.|31:أخرجه ابن جرير ٢٤/٢٧.
  78,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا یَذُوقُونَ فِیهَا بَرۡدࣰا وَلَا شَرَابًا ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: زمهرير جهنم يكون لهم من العذاب؛ لأن الله يقول: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</span>{1}. (١٥/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح- قال: لا يذقون فيها بَرد الشراب، ولا الشراب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</span> أنّ البَرد: النوم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥١<span class="dash">-</span></span> عن <span class="name-2">مُرّة</span>، <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا﴾</span>، قال: نومًا{4}. (١٥/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٢<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا﴾</span>، أي: رَوْحًا، وراحة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق جعفر بن جسر، عن أبيه- <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</span>: البَرد: النوم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأنزل الله ﷿: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها﴾</span> في تلك الأحقاب <span class="qpc-hafs">﴿بَرْدًا﴾</span> يعني: بَرد الكافور، <span class="qpc-hafs">﴿ولا شَرابًا﴾</span> يعني: الخمر كفعل أهل الجنة، <span class="qpc-hafs">﴿لا يَذُوقُونَ﴾</span> في جهنم <span class="qpc-hafs">﴿بَرْدًا ولا شَرابًا﴾</span> يعني: لا يذوقون فيها روحًا طيبًا، ولا شرابًا باردًا يَنفعهم مِن هذه النار{7}<span class=comment-ref>٦٩٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٨٩</span> في قوله: <span class="qpc-hafs">﴿بردا﴾</span> ثلاثة أقوال: <b>الأول</b>: بَرد الهواء. <b>الثاني</b>: النوم. <b>الثالث</b>: الراحة.</p><p>ولم يذكر <u>ابنُ جرير</u> (٢٤/٢٧) غير القولين الأوليين، و<span class="comment-type-3">رجّح</span> القول الأول، و<span class="comment-type-2">انتقد</span> الثاني <span class="mustanad">مستندًا إلى الأغلب لغة</span>، فقال: «وقوله: <span class="qpc-hafs">﴿لا يذوقون فيها بردا ولا شرابا﴾</span> يقول: لا يَطعمون فيها بردًا يُبرد حرّ السعير عنهم، إلا الغسّاق، ولا شرابًا يَرويهم من شدة العطش الذي بهم، إلا الحميم». فقال: «وقد زعم بعض أهل العلم بكلام العرب أنّ البَرد في هذا الموضع: النوم ...، وتأويل كتاب الله على الأغلب من معروف كلام العرب، دون غيره».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٥١٩) على القول الأول والثاني بقوله: «فالذوق على هذين القولين مستعار».</div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.|2:أخرجه الفراء في معاني القرآن ٣/٢٢٨.|3:تفسير البغوي ٨/٣١٥.|4:عزاه السيوطي إلى ابن المنذر.|5:تفسير الثعلبي ١٠/١١٧، وتفسير البغوي ٨/٣١٥.|6:أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٧)-.|7:تفسير مقاتل بن سليمان ٤/٥٦٢-٥٦٣.
  78,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا حَمِیمࣰا وَغَسَّاقࣰا ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٥٥<span class="dash">-</span></span> عن أبي هريرة، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا إلّا حَمِيمًا﴾</span> قال: «<b>قد انتهى حرّه</b>». <span class="qpc-hafs">﴿وغَسّاقًا﴾</span> قال: «<b>قد انتهى بَرده، وإنّ الرجل إذا أدنى الإناء من فِيه سقط فَروة وجهه، حتى يَبقى عظامًا تَقَعْقَع</b>{1}»{2}. (١٥/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق أبي مالك- أنه قال: أتدرون أيَّ شيء الغسّاق؟ قالوا: الله أعلم. قال: هو القِيح الغليظ، لو أنّ قطرة منه تُهراق بالمغرب لأَنتن أهل المشرق، ولو تُهراق بالمشرق لأَنتن أهل المغرب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿إلّا حَمِيمًا وغَسّاقًا﴾</span>، قال: الحميم: الحارّ الذي يَحرق. والغسّاق: الزمهرير البارد{4}. (١٥/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق الربيع- <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا إلّا حَمِيمًا وغَسّاقًا﴾</span>، قال: فاستثنى مِن الشراب الحميم، ومن البارد الغسّاق، وهو الزمهرير{5}. (١٥/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٥٩<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٠<span class="dash">-</span></span> و<span class="name-2">إبراهيم [النَّخْعي]</span> -من طريق منصور- <span class="qpc-hafs">﴿إلّا حَمِيمًا وغَسّاقًا﴾</span>، قالا: غُسالة أهل النار. وفي لفظ: ما يَسيل من صديدهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿حميما وغساقا﴾</span>، قال: الغسّاق: ما يَنقطع مِن جلود أهل النار، وصديدهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٢<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن بُرَيْدة</span> -من طريق صالح بن حيّان- قال: الغسّاق بالطُّخارية: هو المُنتِن{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿إلّا حَمِيمًا وغَسّاقًا﴾</span>، قال: لا يستطيعونه مِن بَرده{9}. (١٥/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي عمرو- في قوله: <span class="qpc-hafs">﴿وغَسّاقًا﴾</span>، قال: ما يَخرج من أبصارهم مِن القيح والدّم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق جعفر بن جسر، عن أبيه- <span class="qpc-hafs">﴿إلّا حَمِيمًا وغَسّاقًا﴾</span>، قال: شَرابَيْن في النار؛ يقال لأحدهما: حميم، والآخر: غسّاق{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٦<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span> -من طريق ابن إدريس، عن أبيه- في قوله: <span class="qpc-hafs">﴿حَمِيمًا وغَسّاقًا﴾</span>، قال: هو الذي يَسيل مِن جلودهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وغَسّاقًا﴾</span>: كُنّا نُحدَّث أنّ الغسّاق: ما يَسيل مِن بين جِلده ولحمه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا إلّا حَمِيمًا وغَسّاقًا﴾</span>: فاستثنى من الشراب الحميم، ومن البارد الغسّاق{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٦٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: الغسّاق: الزمهرير{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى، فقال: <span class="qpc-hafs">﴿إلّا حَمِيمًا﴾</span> يعني: حارًّا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق الضَّحّاك بن مخلد- أنه قال: بلَغني: أنّه ما يَسيل مِن دموعهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إلّا حَمِيمًا وغَسّاقًا﴾</span>، قال: الحميم: دموع أعينهم في النار، يجتمع في خنادق النار، فيُسقَونه. والغسّاق: الصّديد الذي يَخرج من جلودهم، مما تَصهرهم النار في حياض يجتمع فيها، فيُسقَونه{18}<span class=comment-ref>٦٩٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٩٠</span> اختُلف في الغسّاق على أقوال: <b>الأول</b>: ما يَسيل مِن جلود أهل النار من الصديد. <b>الثاني</b>: الزمهرير. <b>الثالث</b>: المُنتِن.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٥٢٠) على القول الأول، فقال: «يقال: غسق الجرح: إذا سال منه قِيح ودم، وغَسقت العين: إذا دمعتْ وإذا خرج قَذاها».</p><p>وقد ذكر <u>ابنُ جرير</u> (٢٤/٣١) هذه الأقوال، ثم <span class="comment-type-4">جمع</span> بينها، فقال: «والغسّاق عندي: هو الفعال، من قولهم: غَسقتْ عينُ فلان: إذا سالتْ دموعها، وغَسق الجرح: إذا سال صديده، <span class="mustanad">ومنه قول الله</span>: <span class="qpc-hafs">﴿ومن شر غاسق إذا وقب﴾</span> [الفلق:٣] يعني بالغاسق: الليل إذا لبس الأشياء وغطاها، وإنما أريد بذلك هجومه على الأشياء هجوم السيل السائل، فإذا كان الغسّاق هو ما وصفتُ من الشيء السائل فالواجب أن يقال: الذي وعد الله هؤلاء القوم، وأخبر أنهم يذوقونه في الآخرة من الشراب، هو السائل من الزمهرير في جهنم، الجامع مع شدة بَرده النَّتن».</div></p><p><h3><span class="qpc-hafs">﴿إِلَّا حَمِیمࣰا وَغَسَّاقࣰا ۝٢٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٧٣<span class="dash">-</span></span> عن أبي سعيد الخُدري، عن النبي ﷺ، قال: «<b>لو أنّ دَلوًا من غسّاق يُهراق إلى الدنيا لأَنتن أهل الدنيا</b>»{19}. (ز)</p></p><p></div></p></div>",footnotes:1:تقعقع: تضطرب وتتحرك. النهاية (قعقع).|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ٢٤/٣٣.|4:أخرجه ابن جرير ٢٤/٣٠ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|5:أخرجه هناد (٢٩٢)، وابن جرير ٢٤/٢٨، ٣١، وعنده في الموضع الأول عن الربيع. وعزاه السيوطي إلى عَبد بن حُمَيد.|6:أخرجه ابن جرير ٢٤/٢٩.|7:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٤٩ (٢٣٨٤)، وابن جرير ٢٤/٣٠ بنحوه.|8:أخرجه ابن جرير ٢٤/٣١.|9:أخرجه ابن جرير ٢٤/٣٠، ٣١ بطرق وألفاظ متعددة. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.|10:أخرجه ابن جرير ٢٤/٢٨.|11:أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٧)-.|12:أخرجه ابن جرير ٢٤/٢٨.|13:أخرجه ابن جرير ٢٤/٢٩.|14:أخرجه ابن جرير ٢٤/٢٨.|15:أخرجه ابن جرير ٢٤/٣١.|16:تفسير مقاتل بن سليمان ٤/٥٦٢.|17:أخرجه ابن جرير ٢٤/٢٩.|18:أخرجه ابن جرير ٢٤/٣٠.|19:أخرجه أحمد ١٧/٣٣١ (١١٢٣٠)، ١٨/٣١٠ (١١٧٨٦)، والترمذي ٤/٥٤٠-٥٤١ (٢٧٦٦)، والحاكم ٤/٦٤٤ (٨٧٧٩)، وابن جرير ٢٠/١٣٠، ٢٤/٣١-٣٢، من طريق درّاج، عن أبي الهيثم، عن أبي سعيد الخُدري به.</p><p>قال الترمذي: «هذا حديث إنما نعرفه من حديث رشدين بن سعد، وفي رشدين بن سعد مقال، وقد تُكلّم فيه من قِبل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص.
  78,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿جَزَاۤءࣰ وِفَاقًا ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span>، قال: وافق أعمالهم{1}. (١٥/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span>، يقول: وافق الجزاء العمل{2}. (١٥/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٦<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span> على قدْر أعمالهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٨<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span> كانت أعمالهم سيئةً، فأثابهم الله بما يَسوؤهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span>، قال: جزاء وافق أعمال القوم؛ أعمال السوء{5}. (١٥/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span>، قال: ثواب وافق أعمالهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span> كما أنه ليس في الأعمال أخبث مِن الشّرك بالله ﷿، وكذلك ليس مِن العذاب شيء أخبث من النار، فوافقت النارُ الشّركَ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿جَزاءً وِفاقًا﴾</span>، قال: عَمِلوا شرًّا فجُزوا شرًّا، وعَملوا حسنًا فجُزوا حسنًا. ثم قرأ قول الله: <span class="qpc-hafs">﴿ثُمَّ كانَ عاقِبَةَ الَّذِينَ أساءُوا السُّوأى﴾</span> [الروم:١٠]{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٣٣، وابن أبي حاتم -كما في الإتقان ٢/٥٢-. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٦٩٥، وأخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٩-، وابن جرير ٢٤/٣٤. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|3:تفسير الثعلبي ١٠/١١٧.|4:تفسير الثعلبي ١٠/١١٧، وتفسير البغوي ١٠/١١٧.|5:أخرجه عبد الرزاق ٢/٣٤٣ من طريق معمر، وابن جرير ٢٤/٣٣ بنحوه، كذلك من طريق معمر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.|6:أخرجه ابن جرير ٢٤/٣٣.|7:تفسير مقاتل بن سليمان ٤/٥٦٣.|8:أخرجه ابن جرير ٢٤/٣٣.
  78,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوا۟ لَا یَرۡجُونَ حِسَابࣰا ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، في قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</span>، قال: لا يَرجون ثوابًا، ولا يَخافون عقابًا{1}. (١٥/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</span>، قال: لا يَخافونه. وفي لفظ: لا يُبالون فيُصَدِّقون بالبعْث{2}. (١٥/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</span>: أي: لا يَخافون حسابًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</span>، يعني: أنهم كانوا لا يَخافون مِن العذاب أن يُحاسبوا بأعمالهم الخبيثة إذا عَملوها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</span>، قال: لا يؤمنون بالبعْث ولا بالحساب، وكيف يرجو الحساب مَن لا يُوقن أنه يحيا، ولا يُوقن بالبعْث. وقرأ قول الله: <span class="qpc-hafs">﴿بَلْ قالُوا مِثْلَ ما قالَ الأَوَّلُونَ قالُوا أإذا مِتْنا وكُنّا تُرابًا﴾</span> إلى: <span class="qpc-hafs">﴿أساطِيرُ الأَوَّلِينَ﴾</span> [المؤمنون:٨١-٨٣]. وقرأ: <span class="qpc-hafs">﴿هَلْ نَدُلُّكُمْ عَلى رَجُلٍ يُنَبِّئُكُمْ إذا مُزِّقْتُمْ كُلَّ مُمَزَّقٍ﴾</span> إلى قوله: <span class="qpc-hafs">﴿جَدِيد﴾</span> [سبأ:٧]. فقال بعضهم لبعض: ما له؟ <span class="qpc-hafs">﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</span> [سبأ:٨]؟ الرجل مجنون حين يُخبِرنا بهذا؟{5}<span class=comment-ref>٦٩٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٩١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥٢١-٥٢١) القول بأنّ قوله: <span class="qpc-hafs">﴿يرجون﴾</span> معناه: يَخافون، كما في آثار السلف، ثم ذكر <b>قولًا آخر</b>، فقال: «وقال غيره: الرجاء هنا على بابه، ولا رجاء إلا وهو مُقترن بخوف، ولا خوف إلا وهو مُقترن برجاء، فذكر أحد القسمين لأنّ المقصد العبارة عن تكذيبهم كأنه قال: إنهم كانوا لا يُصدِّقون بالحساب، فلذلك لا يَرجونه ولا يَخافونه».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٦٩٥ بنحوه، وأخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٩-، وابن جرير ٢٤/٣٤. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ٢٤/٣٤.|4:تفسير مقاتل بن سليمان ٤/٥٦٣.|5:أخرجه ابن جرير ٢٤/٣٤-٣٥.
  78,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَّبُوا۟ بِـَٔایَـٰتِنَا كِذَّابࣰا ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿وكَذَّبُوا بِآياتِنا﴾</span> يعني: القرآن <span class="qpc-hafs">﴿كِذّابًا﴾</span> يعني: تكذيبًا بما فيه من الأمر والنهي{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٣.
  78,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُلَّ شَیۡءٍ أَحۡصَیۡنَـٰهُ كِتَـٰبࣰا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رَجع إلى أعمالهم الخبيثة، فقال: <span class="qpc-hafs">﴿وكُلَّ شَيْءٍ أحْصَيْناهُ﴾</span> من الأعمال <span class="qpc-hafs">﴿كِتابًا﴾</span> يعني: ثَبّتناه مكتوبًا عندنا في كتاب حفيظ، يعني: اللوح المحفوظ، <span class="qpc-hafs">﴿كِتابًا﴾</span> يعني: ما عَملوا من السيئات أثبتناه في اللوح المحفوظ. مثلها في يس [١٢]: <span class="qpc-hafs">﴿وكُلَّ شَيْءٍ أحْصَيْناهُ فِي إمامٍ مُبِينٍ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٣.
  78,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَذُوقُوا۟ فَلَن نَّزِیدَكُمۡ إِلَّا عَذَابًا ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٩٩٠<span class="dash">-</span></span> عن جابر، عن النبي ﷺ أنه قال: «<b>الزيادة خمسة أنهار من تحت العرش على رؤوس أهل النار؛ ثلاثة أنهار على مِقدار الليل، ونهران على مِقدار النهار، كقوله في النّحل</b> [٨٨]: <b><span class="qpc-hafs">﴿زِدْناهُمْ عَذابًا فَوْقَ العَذابِ بِما كانُوا يُفْسِدُونَ﴾</span></b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٩١<span class="dash">-</span></span> سئل <span class="name-1">أبو بَرزة الأَسلميّ</span> -من طريق الحسن- عن أشدّ آية في كتاب الله. فقال: قول الله: <span class="qpc-hafs">﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</span>، قال: فهو مِقدار ساعة بساعة، ويوم بيوم، وشهر بشهر، وسنة بسنة، أشدّ عذابًا، حتى لو أنّ رجلًا من أهل النار أُخرج من المشرق لمات أهل المغرب، ولو أُخرج من المغرب لمات أهل المشرق؛ من نَتن ريحه. قال أبو بَرزة: شهدتُ رسول الله ﷺ حين تلاها، فقال: «<b>هَلك القوم بمعاصيهم ربّهم، وغَضب عليهم، فأبى إذ غَضب عليهم إلا أن يَنتقم منهم</b>»{2}. (١٥/٢٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٩٢<span class="dash">-</span></span> عن الحسن بن دينار، قال: سألتُ <span class="name-1">أبا بَرزة الأَسلميّ</span> عن أشدّ آية في كتاب الله على أهل النار. فقال: قول الله: <span class="qpc-hafs">﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</span>{3}. (١٥/٢٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق أبي أيوب الأزدي- قال: ما أُنزِلَتْ على أهل النار آية قطّ أشدّ منها: <span class="qpc-hafs">﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</span>، فهم في مزيد مِن عذاب الله أبدًا{4}. (١٥/٢٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٩٤<span class="dash">-</span></span> عن الحسين بن واقد، قال: سمعت <span class="name-2">علي بن الحسين</span> يقول: أشد آية على أهل النار <span class="qpc-hafs">﴿فذوقوا فلن نزيدكم إلا عذابا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خُليد بن دَعلج- قال: ما زال أهل النار يَأملون الخروج لقول الله: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span> حتى نزلت: <span class="qpc-hafs">﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</span> فهم في مزيد أبدًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٩٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رَجع إلى أهل النار الذين قال فيهم: <span class="qpc-hafs">﴿لابِثِينَ فِيها أحْقابًا﴾</span>، فذَكر أنّ الخَزنة تقول لهم: <span class="qpc-hafs">﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</span> بعد هذه السنين، فأمّا الزيادة فالأنهار، أمّا «الآن» الذي ذكره الله ﷿ في «الرحمن» فليس له مُنتهى{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه مقاتل بن سليمان في تفسيره ٤/٥٦٤، من طريق أبي الزُّبير، عن جابر به.</p><p>وفي سنده مقاتل بن سليمان، وهو متروك الحديث. الميزان ٤/١٧٣.|2:أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤٠-٤٤١ (١٨٦)-، والبيهقي في البعث والنشور ص٣١٨(٥٧٩) مختصرًا، من طريق جعفر بن جسر بن فرقد، عن أبيه، عن أبي برزة به. وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف جدًّا؛ فيه جسر بن فرقد، وهو أبوجعفر القصاب، قال البخاري: «ليس بذاك عندهم». وقال ابن معين: «ليس بشيء». وقال النسائي: «ضعيف». كما في لسان الميزان لابن حجر ٢/١٠٤. وقال ابنُ كثير ١٤/٢٣٤ بعد ذكر هذا الأثر: «جسر بن فرقد: ضعيف الحديث بالكلية». وفيه أيضًا ابنه جعفر بن جسر، قال العقيلي: «في حفظه اضطراب شديد، كان يذهب إلى القدر، وحدّث بمناكير». كما في لسان الميزان لابن حجر ٢/٤٤٦.|3:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣١، وفتح الباري ٦/٣٣٣، مرفوعًا-، والطبراني -كما في مجمع الزوائد ٧/١٣٣-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن مردويه.</p><p>قال ابن كثير: «جسر بن فرقد ضعيف الحديث بالكلية». وقال الهيثمي: «فيه شعيب بن بيان، وهو ضعيف».|4:أخرجه ابن جرير ٢٤/٣٦ بنحوه، ومن طريق قتادة أيضًا. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٤-٨٥-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن مردويه.|5:أخرجه الواحدي مطولًا في أسباب النزول ص ١٠٦.|6:أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٥-٤٢٦ (١٢٠)-، وابن جرير ٢٤/٣٦ من طريق سعيد مقتصرًا على آخره.|7:تفسير مقاتل بن سليمان ٤/٥٦٣. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span> [الرحمن:٤٤].