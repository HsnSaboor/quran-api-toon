quran[30]{c,v,t}:
78,1," مقدمة السورة ٨٠٨٠٢- عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (١٥/١٨٩) ٨٠٨٠٣- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسَمّاها: <q>﴿عَمَّ يَتَساءَلُونَ﴾</q>، وذكر أنها نزلت بعد: <q>﴿سَأَلَ سائِلٌ﴾</q>{2}. (ز) ٨٠٨٠٤- عن عبد الله بن الزُّبير، قال: نزلت <q>﴿عَمَّ يَتَساءَلُونَ﴾</q> بمكة{3}. (١٥/١٨٩) ٨٠٨٠٥- عن عكرمة مولى ابن عباس= (ز) ٨٠٨٠٦- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسَمَّياها: <q>﴿عَمَّ يَتَساءَلُونَ﴾</q>{4}. (ز) ٨٠٨٠٧- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٨٠٨٠٨- عن محمد بن مسلم الزُّهريّ: مكّيّة، وسَمّاها: <q>﴿عَمَّ يَتَساءَلُونَ﴾</q>، ونزلت بعد: <q>﴿سَأَلَ سائِلٌ﴾</q>{6}. (ز) ٨٠٨٠٩- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٨٠٨١٠- قال مقاتل بن سليمان: سورة النبأ مكّيّة، عددها أربعون آية كوفي{8}٦٩٧٧. (ز) ٦٩٧٧ قال ابنُ عطية (٨/٥١٢): «وهي مكّيّة بإجماع». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٥٥.
78,2," <q>﴿عَمَّ یَتَسَاۤءَلُونَ ۝١ عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾</q> - نزول الآية ٨٠٨١١- عن الحسن البصري -من طريق محمد بن جُحادة- قال: لَمّا بُعِث النبيُّ ﷺ جَعلوا يتساءلون بينهم؛ فنزلت: <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</q>{1}٦٩٧٨. (١٥/١٨٩) ٦٩٧٨ لم يذكر ابنُ جرير (٢٤/٥) غير قول الحسن. ٨٠٨١٢- قال مقاتل بن سليمان: <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</q> نزلت في أبي لبابة وأصحابه، وذلك أنّ كفار مكة كانوا يجتمعون عند رسول الله ﷺ، ويَسمعون حديثه، فإذا حَدَّثهم خالفوا قوله، واستهزؤوا منه، وسخروا؛ فأنزل الله تعالى: <q>﴿أنْ إذا سَمِعْتُمْ﴾</q> يا محمد <q>﴿آياتِ اللَّهِ يُكْفَرُ بِها ويُسْتَهْزَأُ بِها فَلا تَقْعُدُوا مَعَهُمْ حَتّى يَخُوضُوا فِي حَدِيثٍ غَيْرِهِ﴾</q> [النساء:١٤٠]. فكان رسول الله ﷺ يُحَدِّث المؤمنين، فإذا رأى رجلًا مِن المشركين كفَّ عن الحديث حتى يَذهب، ثم أقبلوا بجماعتهم، فقالوا: يا محمد، أبخلتَ بما كنتَ تُحدِّثنا؟ لو أنك حَدّثتنا عن القرون الأولى فإنّ حديثك عجبٌ. قال: «لا، واللهِ، لا أُحدِّثكم بعد يومي هذا، وربي قد نهاني عنه». فأنزل الله تعالى: <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</q>{2}. (ز) <q>﴿عَمَّ یَتَسَاۤءَلُونَ ۝١ عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾</q> - تفسير الآية ٨٠٨١٣- عن عبد الله بن عباس، في قوله: <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</q>، قال: القرآن{3}. (١٥/١٨٩) ٨٠٨١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿عَنِ النَّبَإ العَظِيمِ﴾</q>، قال: القرآن{4}. (١٥/١٩٠) ٨٠٨١٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ﴾</q>، قال: القرآن{5}. (١٥/١٩٠) ٨٠٨١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿عَنِ النَّبَإ العَظِيمِ﴾</q>: وهو البعْث بعد الموت{6}. (ز) ٨٠٨١٧- قال مقاتل بن سليمان: <q>﴿عَمَّ يَتَساءَلُونَ﴾</q> استفهام للنبي ﷺ: عن أيِّ شيء يتساءلون؟ ... <q>﴿عَنِ النَّبَإ العَظِيمِ﴾</q> يعني: القرآن، كقوله: <q>﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ﴾</q> [ص:٦٧] لأنه كلام الله تعالى{2}. (ز) ٨٠٨١٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ الَّذِي هُمْ فِيهِ مُخْتَلِفُون﴾</q>، قال: يوم القيامة. قال: قالوا: هذا اليوم الذي تزعمون أنّا نحيا فيه وآباؤنا. قال: فهم فيه مُختلِفون، لا يؤمنون به، فقال الله: <q>﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ أنْتُمْ عَنْهُ مُعْرِضُونَ﴾</q> [ص:٦٧-٦٨] يوم القيامة لا يؤمنون به{6}٦٩٧٩. (ز) ٦٩٧٩ ذكر ابنُ عطية (٨/٥١٢) في عَوْد الضمير في قوله: <q>﴿يتساءلون﴾</q> احتمالين: الأول: «أن يريد: جميع العالم». ووجّهه بقوله: «فيكون الاختلاف حينئذ يُراد به تصديق المؤمنين، وتكذيب الكافرين، ونزغات الملحدين». الثاني: «أن يراد بالضمير: الكفار من قريش». ووجّهه بقوله: «فيكون الاختلاف شكّ بعض وتكذيب بعض، وقولهم سحرٌ وكهانة وشِعر وجنون وغير ذلك». وذكر ابنُ عطية (٨/٥١٢) إضافة إلى ما ورد في أقوال السلف في المراد بالنبأ العظيم قولًا آخر، فقال: «و<q>﴿النبأ العظيم﴾</q> قال قوم: هو الشرع الذي جاء به محمد ﷺ». ",footnotes:1:أخرجه ابن جرير ٢٤/٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.تفسير مقاتل بن سليمان ٤/٥٥٧.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر. والوارد عن ابن جرير الرواية التالية.أخرجه ابن جرير ٢٤/٦.تفسير مقاتل بن سليمان ٤/٥٥٧.أخرجه ابن جرير ٢٤/٦.
78,3," <q>﴿ٱلَّذِی هُمۡ فِیهِ مُخۡتَلِفُونَ ۝٣﴾</q> - تفسير ٨٠٨١٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</q>، قال: مُصدِّق، ومُكذِّب{1}. (١٥/١٩٠) ٨٠٨٢٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عَمَّ يَتَساءَلُونَ عَنِ النَّبَإ العَظِيمِ الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</q>، قال: هو البعْث بعد الموت، صار الناس فيه رجلين؛ مُصدِّق، ومُكذِّب، فأمّا الموت فأَقرُّوا به كلّهم لمعاينتهم إياه، واختلفوا في البعْث بعد الموت{2}. (١٥/١٩٠) ٨٠٨٢١- قال مقاتل بن سليمان: قال: <q>﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</q> يقول: لِمَ يسألون عن القرآن وهم يخالفونه، ولا يؤمنون به؟! فصَدَّق بعضُهم به، وكفر بعضُهم به، فاختلفوا فيه{3}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٧-٥٥٨.
78,4," <q>﴿كَلَّا سَیَعۡلَمُونَ ۝٤ ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾</q> - نزول الآية ٨٠٨٢٢- قال مقاتل بن سليمان: نزلت في حَيّين من أحياء العرب، يعني: [بني] عبد مناف بن قُصي، وبني سهم بن عمرو بن هُصَيص بن كعب{1}. (ز) <q>﴿كَلَّا سَیَعۡلَمُونَ ۝٤ ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾</q> - تفسير الآية ٨٠٨٢٣- عن الضَّحّاك بن مُزاحِم -من طريق ثابت-: <q>﴿كَلّا سَيَعْلَمُونَ﴾</q> الكفار، <q>﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</q> المؤمنون. وكذلك كان يقرؤها{2}. (١٥/١٩٠) ٨٠٨٢٤- عن الحسن البصري، في قوله: <q>﴿كَلّا سَيَعْلَمُونَ ثُمَّ كَلّا سَيَعْلَمُونَ﴾</q>، قال: وعيد بعد وعيد{3}. (١٥/١٩٠) ٨٠٨٢٥- قال مقاتل بن سليمان: ثم خوّفهم الوعيد، فقال: <q>﴿كَلّا سَيَعْلَمُونَ﴾</q> إذا قُتِلوا ببدر، وتَوفّتهم الملائكة ظالمي أنفسهم، يَضربون وجوههم وأدبارهم، ثم قال: <q>﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</q> وعيد على أثر وعيد ...، نظيرها في <q>﴿ألْهاكُمُ التَّكاثُرُ﴾</q>{4}٦٩٨٠. (ز) ٦٩٨٠ بيّن ابنُ جرير (٢٤/٧-٨) أنّ قوله: <q>﴿كلا سيعلمون﴾</q> في الموضعين وعيد، كما أفاده قول مقاتل، وقول الحسن، ثم ذكر قول الضَّحّاك، ولم يعلّق عليه. وذكر ابنُ عطية (٨/٥١٣) في الآية قراءات، ووجّه المعنى عليها، فقال: «وقرأ السبعة، والحسن، وأبو جعفر، وشيبة، والأعمش: <q>﴿كلا سيعلمون﴾</q> بالياء في الموضعين على ذِكر الغائب، فظاهر الكلام أنه ردٌّ على الكفار في تكذيبهم وعيد لهم في المستقبل، وكرّر الزجر تأكيدًا، وقال الضَّحّاك: المعنى: <q>﴿كلا سيعلمون﴾</q> يعني: الكفار على جهة الوعيد، <q>﴿ثم كلا سيعلمون﴾</q> يعني: المؤمنين على جهة الوعد. وقرأ ابن عامر فيما روى عنه مالك بن دينار والحسن بخلاف: (كَلّا سَتَعْلَمُونَ) بالتاء في الموضعين على مخاطبة الحاضر، كأنه تعالى يقول: قُل لهم، يا محمد، وكرِّر عليهم الزجر والوعيد تأكيدًا. وكلّ تأويل في هذه القراءة غير هذا فمتعسف. وقرأ قوم: <q>﴿كلا سيعلمون﴾</q> بالياء على جهة الردّ والوعيد للكفار، (ثم كلا ستعلمون) بالتاء من فوق على جهة الردّ على الكفار والوعد للمؤمنين». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨.أخرجه ابن جرير ٢٤/٨.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٨. وأشار بالنظير إلى قوله تعالى: <q>﴿كلا سوف تعلمون ثم كلا سوف تعلمون﴾</q> [التكاثر:٣-٤].
  78,5,""
78,6," <q>﴿أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ مِهَـٰدࣰا ۝٦﴾</q> - تفسير ٨٠٨٢٦- عن الحسن البصري -من طريق معمر- في قوله تعالى: <q>﴿الأَرْضَ مِهادًا﴾</q> قال: فِراشًا{1}. (١٥/١٩١) ٨٠٨٢٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</q> قال: بِساطًا{2}. (ز) ٨٠٨٢٨- عن قتادة بن دعامة، في قوله: <q>﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</q> إلى قوله: <q>﴿مَعاشًا﴾</q>، قال: نِعمٌ من الله يعدّها عليكم، يا بني آدم؛ لِتعمَلوا لأداء شُكرها{3}. (١٥/١٩١) ٨٠٨٢٩- قال مقاتل بن سليمان: ثم ذكر صُنعه ليَعتبروا إذا بُعثوا يوم القيامة وقد كذّبوا بالقيامة والبعْث، فعَظّم الرّبُّ نفسه -تبارك وتعالى- فقال: <q>﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</q> يعني: فِراشًا، وأيضًا بِساطًا مسيرة خمسمائة عام{4}. (ز) ٨٠٨٣٠- عن سفيان، <q>﴿ألَمْ نَجْعَلِ الأَرْضَ مِهادًا﴾</q>، قال: فُرِشَتْ لكم{3}. (١٥/١٩١) ",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٣٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.أخرجه بن جرير ٢٤/٨.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٨.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.
78,7," <q>﴿وَٱلۡجِبَالَ أَوۡتَادࣰا ۝٧﴾</q> - تفسير ٨٠٨٣١- قال مقاتل بن سليمان: <q>﴿والجِبالَ أوْتادا﴾</q> على الأرض لِئلّا تزول بأهلها، فاستَقرّتْ، وخَلَق الجبال بعد خَلْق الأرض{1}. (ز) ٨٠٨٣٢- عن سفيان، <q>﴿والجِبالَ أوْتادًا﴾</q>، قال: أُوتِدَتْ بها{2}. (١٥/١٩١) <q>﴿وَٱلۡجِبَالَ أَوۡتَادࣰا ۝٧﴾</q> - آثار متعلقة بالآية ٨٠٨٣٣- عن عبد الله بن عباس -من طريق عطاء- قال: لَمّا أراد اللهُ أن يَخلُق الخَلْق أرسل الريح، فسَحَّت{3} الماءَ حتى أبْدَتْ عن حشَفَة، وهي التي تحت الكعبة، ثم مدَّ الأرضَ حتى بلَغتْ ما شاء الله مِن الطول والعرض، وكانت هكذا تَميد -وقال بيده هكذا وهكذا-، فجعل الله الجبال رواسي أوتادًا، فكان أبو قبيس مِن أول جبل وُضِع في الأرض{4}. (١٥/١٩١) ٨٠٨٣٤- عن الحسن البصري، قال: إنّ الأرض أول ما خُلِقتْ خُلِقتْ من عند بيت المقدس، وُضِعتْ طينة، فقيل لها: اذهبي هكذا وهكذا وهكذا. وخُلِقتْ على صخرة، والصخرة على حوت، والحوت على الماء، فأَصبحتْ وهي تميع. فقالت الملائكة: يا ربّ، مَن يُسكِّن هذه؟ فأصبحت الجبال فيها أوتادًا، فقالت الملائكة: يا ربّ، أخلَقتَ خَلْقًا هو أشدُّ مِن هذه؟ قال: الحديد. قالوا: فخَلَقتَ خَلْقًا هو أشد من الحديد؟ قال: النار. قالوا: فخَلَقتَ خَلْقًا هو أشد من النار؟ قال: الماء. قالوا: فخَلَقتَ خَلْقًا هو أشد من الماء؟ قال: الريح. قالوا: فخَلَقتَ خَلْقًا هو أشد من الريح؟ قال: البناء. قالوا: فخَلَقتَ خَلْقًا هو أشد من البناء؟ قال: ابن آدم{5}. (١٥/١٩٢) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.سحَّ الماء وغيره يسُحُّه سحًّا: صبه صبًّا متتابعًا كثيرًا. اللسان (سحح).أخرجه الحاكم ٢/٥١٢، والواحدي في الوسيط ٤/٤١٢.عزاه السيوطي إلى ابن المنذر.
78,8," <q>﴿وَخَلَقۡنَـٰكُمۡ أَزۡوَ ٰ⁠جࣰا ۝٨﴾</q> - تفسير ٨٠٨٣٥- عن مجاهد بن جبر، في قوله: <q>﴿وخَلَقْناكُمْ أزْواجًا﴾</q>، قال: اثنين اثنين{1}. (١٥/١٩٢) ٨٠٨٣٦- قال مقاتل بن سليمان: ثم قال: <q>﴿وخَلَقْناكُمْ أزْواجًا﴾</q> يعني: أصنافًا؛ ذكورًا وإناثًا، سُودًا وبِيضًا وحُمرًا وأدمًا، ولغات شتّى، فذلك قوله: <q>﴿وخَلَقْناكُمْ أزْواجًا﴾</q> فهذا كلّه عَظمته{2}. (ز) ",footnotes:1:عزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن جرير، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٨.
78,9," <q>﴿وَجَعَلۡنَا نَوۡمَكُمۡ سُبَاتࣰا ۝٩﴾</q> - تفسير ٨٠٨٣٧- قال مقاتل بن سليمان: ثم ذَكر نِعمته، فقال: <q>﴿وجَعَلْنا نَوْمَكُمْ سُباتًا﴾</q> يقول: إذا دَخل الليل أدرككم النوم فتَستريحون، ولولا النومُ ما استرحتم أبدًا مِن الحِرص وطلب المعيشة، فذلك قوله: <q>﴿سُباتًا﴾</q> لأنه يسبتُ، والنائم مَسبوت كأنه ميّت لا يَعقل{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٥٨-٥٥٩.
78,10," <q>﴿وَجَعَلۡنَا ٱلَّیۡلَ لِبَاسࣰا ۝١٠﴾</q> - تفسير ٨٠٨٣٨- عن قتادة بن دعامة -من طريق سفيان- <q>﴿وجَعَلْنا اللَّيْلَ لِباسًا﴾</q>، قال: سَكَنًا{1}. (ز) ٨٠٨٣٩- قال مقاتل بن سليمان: <q>﴿وجَعَلْنا اللَّيْلَ لِباسًا﴾</q> يعني: سَكنًا، كقوله: <q>﴿هُنَّ لِباسٌ لَكُمْ﴾</q> [البقرة:١٨٧] يعني: سَكنًا لكم، فألبَسكم ظُلمته على خير وشرّ كثير{2}٦٩٨١. (ز) ٦٩٨١ ذكر ابنُ عطية (٨/٥١٤) في قوله: <q>﴿لباسا﴾</q> قولًا، وانتقده مستندًا إلى اللغة، فقال: «ويقال: جعله لِباسًا لأنه يطمس نور الأبصار، ويُلبس عليها الأشياء، والتصريف يُضعّف هذا القول، لأنه كان يجب أن يكون: مُلبسًا، ولا يقال: لِباسًا؛ إلا من لبس الثياب». ",footnotes:1:أخرجه ابن جرير ٢٤/٩.تفسير مقاتل بن سليمان ٤/٥٥٩.
78,11," <q>﴿وَجَعَلۡنَا ٱلنَّهَارَ مَعَاشࣰا ۝١١﴾</q> - تفسير ٨٠٨٤٠- قال عبد الله بن عباس: <q>﴿وجَعَلْنا النَّهارَ مَعاشًا﴾</q> يريد: تَبتغون فيه مِن فضل الله، وما قَسم لكم مِن رزقه{1}. (ز) ٨٠٨٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وجَعَلْنا النَّهارَ مَعاشًا﴾</q>، قال: يَبتغون مِن فضل الله{2}. (١٥/١٩٢) ٨٠٨٤٢- قال مقاتل بن سليمان: ثم قال: <q>﴿وجَعَلْنا النَّهارَ مَعاشًا﴾</q> لكي تَنتشروا لمعيشتكم، فهذان نِعمتان مِن نِعَم الله عليكم{3}. (ز) ",footnotes:1:تفسير البغوي ٨/٣١٢.تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٠. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٥٩.
78,12," <q>﴿وَبَنَیۡنَا فَوۡقَكُمۡ سَبۡعࣰا شِدَادࣰا ۝١٢﴾</q> - تفسير ٨٠٨٤٣- قال عبد الله بن عباس: <q>﴿وبَنَيْنا فَوْقَكُمْ سَبْعًا شِدادًا﴾</q>، يريد: سبع سماوات{1}. (ز) ٨٠٨٤٤- قال مقاتل بن سليمان: ثم ذكر مُلكه وجَبروته وارتفاعه، فقال: <q>﴿وبَنَيْنا فَوْقَكُمْ سَبْعًا شِدادًا﴾</q> يعني بالسبع: السموات، وغِلظ كلّ سماء مسيرة عام، وبين كلّ سماءين مثل ذلك، نظيرها في المؤمنون [١٧]: <q>﴿خَلَقْنا فَوْقَكُمْ سَبْعَ طَرائِقَ﴾</q>، فذلك قوله: <q>﴿شِدادًا﴾</q>، قال: وهي فوقكم، يا بني آدم، فاحذروا، لا تَخرّ عليكم إنْ عَصيتم{2}. (ز) ",footnotes:1:تفسير البغوي ٨/٣١٢.تفسير مقاتل بن سليمان ٤/٥٥٩.
78,13," <q>﴿وَجَعَلۡنَا سِرَاجࣰا وَهَّاجࣰا ۝١٣﴾</q> - تفسير ٨٠٨٤٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وجَعَلْنا سِراجًا وهّاجًا﴾</q>، قال: مُضيئًا{1}. (١٥/١٩٣) ٨٠٨٤٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وجَعَلْنا سِراجًا وهّاجًا﴾</q>، قول: سِراجًا منيرًا{2}. (ز) ٨٠٨٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وجَعَلْنا سِراجًا وهّاجًا﴾</q>، قال: يتلألأ{3}. (١٥/١٩٢) ٨٠٨٤٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿وجَعَلْنا سِراجًا وهّاجًا﴾</q>، قال: الوهّاج: المنير{4}. (١٥/١٩٣) ٨٠٨٤٩- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿سراجا وهاجا﴾</q>، قال: الوهج: المنير{5}. (ز) ٨٠٨٥٠- قال مقاتل بن سليمان: ثم قال: <q>﴿وجَعَلْنا سِراجًا وهّاجًا﴾</q> يعني: الشمس وحرّها مُضيئًا، يقول: جَعل فيها نورًا وحرًّا{6}. (ز) ٨٠٨٥١- عن سفيان [الثوري] -من طريق مهران- <q>﴿سِراجًا وهّاجًا﴾</q>، قال: يتلألأ ضوءَه{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/١١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١١.تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١١، وأبو الشيخ في العظمة (٦١٨). وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/١١، والخرائطي في مكارم الأخلاق (٥٨٨- منتقى) مختصرًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٥٥٩.أخرجه ابن جرير ٢٤/١١.
78,14," <q>﴿وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَ ٰ⁠تِ﴾</q> - قراءات ٨٠٨٥٢- عن قتادة -من طريق أبي عوانة- قال: في مصحف الفضل بن عباس: (وأَنزَلْنا بِالمُعْصِراتِ مَآءً ثَجّاجًا){1}. (١٥/١٩٥) ٨٠٨٥٣- عن قتادة، قال: في قراءة ابن عباس: (وأَنزَلْنا بِالمُعْصِراتِ): بالرياح{2}. (١٥/١٩٥) ٨٠٨٥٤- عن مجاهد بن جبر: (وأَنزَلْنا بِالمُعْصِراتِ): الريح. وكذلك كان يقرؤها: (بِالمُعْصِراتِ مَآءً ثَجّاجًا): منصبًّا{3}. (١٥/١٩٦) ٨٠٨٥٥- عن عكرمة مولى ابن عباس -من طريق يزيد- أنه كان يقرأ: (وأَنزَلْنا بِالمُعْصِراتِ)، يعني: الرياح{4}. (ز) <q>﴿وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَ ٰ⁠تِ﴾</q> - تفسير الآية ٨٠٨٥٦- قال أُبيّ بن كعب= (ز) ٨٠٨٥٧- وسعيد بن جُبَير= (ز) ٨٠٨٥٨- وزيد بن أسلم= (ز) ٨٠٨٥٩- ومقاتل بن حيّان: <q>﴿مِنَ المُعْصِراتِ﴾</q>، أي: من السموات{5}. (ز) ٨٠٨٦٠- عن عبد الله بن مسعود -من طريق قيس بن السّكن- في قوله: <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ ماءً ثَجّاجًا﴾</q>، قال: يَبعث الله الريح، فتَحمل الماء من السماء، فتَمْرِي به السحاب، فتدُرّ كما تدُرّ اللّقحة، والثَّجاج ينزل من السماء أمثال العَزالِي{6}، فتَصرِفه الرياح، فيَنزل مُتفرّقًا{7}. (١٥/١٩٤) ٨٠٨٦١- عن عبد الله بن عباس -من طريق عطية- <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: الرياح{8}. (١٥/١٩٤) ٨٠٨٦٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: السحاب{9}. (١٥/١٩٣) ٨٠٨٦٣- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>. قال: السحاب يَعصِر بعضها بعضًا، فيَخرج الماء مِن بين السحابتين. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ النّابغة وهو يقول: تجُرُّ بها الأرواح من بين شمأل وبين صَباها المعصراتُ الدَّوامسُ؟{10}. (١٥/١٩٣) ٨٠٨٦٤- قال أبو العالية الرِّياحيّ= (ز) ٨٠٨٦٥- والضَّحّاك بن مُزاحِم: <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q> هي السحاب التي تَتحلَّب بالمطر ولَمّا تُمطر، كالمرأة المُعصر، وهي التي دنا حيضها ولم تحض{11}. (ز) ٨٠٨٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: الريح{12}. (١٥/١٩٢) ٨٠٨٦٧- عن عكرمة مولى ابن عباس، <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: السحاب{13}. (١٥/١٩٥) ٨٠٨٦٨- عن الحسن البصري -من طريق أبي رجاء- <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: من السماء{14}. (ز) ٨٠٨٦٩- عن الحسن البصري -من طريق أبي حمزة العطار- <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: المُعصرات: السحاب{15}. (ز) ٨٠٨٧٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: من السماء، وبعضهم يقول: الريح{16}. (١٥/١٩٣) ٨٠٨٧١- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ﴾</q>، قال: من السحاب{17}. (١٥/١٩٥) ٨٠٨٧٢- عن سفيان [الثوري] -من طريق مهران- <q>﴿مِنَ المُعْصِرات﴾</q>، قال: المُعصرات: السحاب{14}. (ز) ٨٠٨٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَنْزَلْنا مِنَ المُعْصِرات﴾</q>، قال: المُعصرات: الرياح. وقرأ قوله: <q>﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا﴾</q> إلى آخر الآية [الروم:٤٨]{4}٦٩٨٢. (ز) ٦٩٨٢ اختُلف في المراد بالمُعصرات على أقوال: الأول: الرياح. الثاني: السحاب. الثالث: السماء. وقد ذكر ابنُ عطية (٥/٤٢٤) قراءة تقوي القول الأول، فقال: «وقرأ ابن الزُّبير، وابن عباس، والفضل بن عباس، وقتادة، وعكرمة: (وأَنزَلْنا بِالمُعْصِراتِ)، فهذا يقوي أنه أراد الرياح». ووجّه ابنُ عطية (٨/٥١٤-٥١٥) تفسير المعصرات بالسحاب بأنه: "مأخوذ من العَصر؛ لأنّ السحاب يَنعصر فيخرج منه الماء، وهذا قول الجمهور، وبه فسّر الحسن بن محمد العنبري القاضي بيت حسان: كلتاهما حَلَب العصير وقال بعض مَن سَمّيت: هي السحاب التي فيها الماء ولــمـّـا تُمطر كالمرأة المُعصر، وهي التي دنا حيضها ولم تَحض بعد. وقال ابن كيسان: قيل للسحاب مُعصرات من حيث تغيث، فهي من العُصرة، ومنه قوله تعالى: <q>﴿وفِيهِ يَعْصِرُونَ﴾</q> [يوسف:٤٩]". ووجّه ابنُ كثير (١٤/٢٢٨) القول الأول بقوله: «ومعنى هذا القول: أنها تَستدرّ المطر من السحاب». وقد رجّح ابنُ جرير (٢٤/١٤) القول الثاني، وانتقد القولين الآخريين مستندًا إلى الدلالة العقلية، والأغلب من اللغة، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: إنّ الله أخبر أنه أنزل من المُعصرات، وهي التي قد تَحلّبتْ بالماء من السحاب ماء، وإنما قلنا ذلك أولى بالصواب لأن القول في ذلك على أحد الأقوال الثلاثة التي ذكرت، والرياح لا ماء فيها فينزل منها، وإنما ينزل بها، وكان يصحّ أن تكون الرياح لو كانت القراءة: (وأَنزَلْنا بِالمُعْصِراتِ)، فلما كانت القراءة: <q>﴿من المعصرات﴾</q> عُلم أنّ المعني بذلك ما وصفت، فإن ظنّ ظانٌّ أنّ الباء قد تعقب في مثل هذا الموضع»مِن«؛ قيل: ذلك وإن كان كذلك فالأغلب من معنى مِن غير ذلك، والتأويل على الأغلب مِن معنى الكلام. فإن قال: فإنّ السماء قد يجوز أن تكون مرادًا بها. قيل: إنّ ذلك وإن كان كذلك فإنّ الأغلب من نزول الغيث من السحاب دون غيره». وبنحوه ابنُ كثير مستندًا إلى النظائر، فقال: «والأظهر أنّ المراد بالمُعصرات: السحاب، كما قال الله تعالى: <q>﴿الله الذي يرسل الرياح فتثير سحابا فيبسطه في السماء كيف يشاء ويجعله كسفا فترى الودق يخرج من خلاله﴾</q> [الروم:٤٨]، أي: مِن بينه». وانتقد ابنُ كثير القول الثالث بقوله: «وهذا قول غريب». <q>﴿مَاۤءࣰ ثَجَّاجࣰا ۝١٤﴾</q> - تفسير ٨٠٨٧٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ماءً ثَجّاجًا﴾</q>، قال: مُنصَبًّا{20}.(١٥/١٩٣) (١٥/١٩٣) ٨٠٨٧٥- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿ثَجّاجًا﴾</q>. قال: الثَّجاج: الكثير الذي يَنبتُ منه الزرع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ أبا ذُؤيب يقول: سقى أُمَّ عمرو كلَّ آخر ليلة غمائمُ سُود ماؤهن ثجيج؟{21}. (١٥/١٩٣) ٨٠٨٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ماء ثجاجا﴾</q>، قال: مُنصبًّا يَنصب{22}. (١٥/١٩٢) ٨٠٨٧٧- عن عكرمة مولى ابن عباس: <q>﴿ماءً ثَجّاجًا﴾</q>، قال: صبًّا. أو قال: كثيرًا{13}. (١٥/١٩٥) ٨٠٨٧٨- عن الحسن البصري -من طريق أبي حمزة العطار- <q>﴿ماءً ثَجّاجًا﴾</q> ... الثّجاج: الماء الكثير يُنبتُ الله به الحَبّ{15}. (ز) ٨٠٨٧٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿ماءً ثَجّاجًا﴾</q>، قال: الثّجاج: المُنصَبُّ{25}. (١٥/١٩٣) ٨٠٨٨٠- قال قتادة بن دعامة: <q>﴿ماءً ثَجّاجًا﴾</q> مُتتابعًا يتلو بعضه بعضًا{26}. (ز) ٨٠٨٨١- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿ماءً ثَجّاجًا﴾</q>، قال: مُنصبًّا{27}. (١٥/١٩٥) ٨٠٨٨٢- قال مقاتل بن سليمان: ثم ذَكر نِعَمَه، فقال: <q>﴿وأَنْزَلْنا مِنَ المُعْصِراتِ ماءً ثَجّاجًا﴾</q> يعني: مطرًا كثيرًا مُنصَبًّا يتبع بعضه بعضًا، وذلك أنّ الله ﷿ يُرسل الرياح، فتأخذ الماء مِن سماء الدنيا مِن بحر الأرزاق، ولا تقوم الساعة ما دام به قطرة ماء، فذلك قوله: <q>﴿وفِي السَّماءِ رِزْقُكُمْ وما تُوعَدُونَ﴾</q> [الذاريات:٢٢]، قال: تجيء الريح، فتُثير سحابًا، [فتُلقحه]، ثم تمطر، وتخرج الريح والمطر جميعًا من خلل السحاب{28}. (ز) ٨٠٨٨٣- عن سفيان [الثوري] -من طريق مهران- <q>﴿ماءً ثَجّاجًا﴾</q>، قال: مُتتابعًا{29}. (ز) ٨٠٨٨٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ماءً ثَجّاجًا﴾</q>، قال: كثيرًا{29}٦٩٨٣. (ز) ٦٩٨٣ في قوله: <q>﴿ثجاجا﴾</q> قولان: الأول: مُنصبًّا مُتتابعًا. الثاني: كثيرًا. وقد رجّح ابنُ جرير (٢٤/١٤-١٥) القول الأول، وانتقد الثاني مستندًا إلى أقوال السلف، واللغة، والنظائر، فقال: «وأما قوله: <q>﴿ماء ثجاجا﴾</q> يقول: ماء مُنصبًّا يتبع بعضه بعضًا، كثج دماء البدن، وذلك سفكها، وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على ذلك، ثم قال: «ولا يُعرف في كلام العرب من صفة الكثرة الثّجّ، وإنما الثّجّ: الصَّبّ المُتتابع. ومنه قول النبي ﷺ: «أفضل الحج: العَجّ، والثّجّ». يعني بالثّجّ: صبّ دماء الهدايا والبدن بذبحها، يقال منه: ثججت دمه فأنا أثجّه ثجًّا، وقد ثجّ الدمُ فهو يثج ثجوجًا». ",footnotes:1:أخرجه سعيد بن منصور ٨/٢٤٦ (٢٣٨٠). وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة، تروى أيضًا عن ابن الزبير، وعكرمة، ومجاهد، وقتادة، وغيرهم. انظر: مختصر ابن خالويه ص١٦٨.عزاه السيوطي إلى ابن جرير، وابن الأنباري في المصاحف. وعند ابن جرير ٢٤/١٢ عن قتادة -من طريق سعيد- بلفظ: «هي في بعض القراءات»، دون ذكر ابن عباس.عزاه السيوطي إلى الخرائطي في مكارم الأخلاق.أخرجه ابن جرير ٢٤/١٢.تفسير الثعلبي ١٠/١١٤، وتفسير البغوي ٨/٣١٣ عنهم دون أُبَيّ بن كعب.العزالي: جمع عزلاء، وهي فم المزادة الأسفل، شبه اتساع المطر واندفاقه بالذي يخرج من فم المزادة. النهاية (عزل).أخرجه الشافعي ١/٣٩٩ (٤٩٣ - شفاء العي)، وسعيد بن منصور ٨/٢٤٦ (٢٣٧٩)، والخرائطي (٥٥٩ - منتقى)، والبيهقي في سُنَنِه ٣/٣٦٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن مردويه.أخرجه أبو يعلى (٢٦٦٣)، وابن جرير ٢٤/١١-١٢، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٢٧-. وعزاه السيوطي إلى عَبد بن حُمَيد، والخرائطي.أخرجه ابن جرير ٢٤/١٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطستي -كما في الإتقان ٢/٨٣-.تفسير الثعلبي ١٠/١١٤، وتفسير البغوي ٨/٣١٢ بنحوه.تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٣-. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/١٣.أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٣)-.أخرجه عبد الرزاق ٢/٣٤٢ واللفظ له، وابن جرير ٢٤/١٣، ومن طريق سعيد أيضًا بنحوه، والخرائطي في مكارم الأخلاق (٥٨٨- منتقى) مختصرًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/١٣.أخرجه ابن جرير ٢٤/١٢.أخرجه أبو يعلى (٢٦٦٣)، وابن جرير ٢٤/١٤-١٥، وكذلك من طريق عطية، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٢٧-. وعزاه السيوطي إلى الخرائطي، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.مسائل نافع (٢٤٧).تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٥ بنحوه. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٣)-.أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/١٥، والخرائطي في مكارم الأخلاق (٥٨٨- منتقى). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/١١٤، وتفسير البغوي ٨/٣١٣.أخرجه ابن جرير ٢٤/١٥. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٥٥٩-٥٦٠.أخرجه ابن جرير ٢٤/١٥.أخرجه ابن جرير ٢٤/١٥.
78,15," <q>﴿لِّنُخۡرِجَ بِهِۦ حَبࣰّا وَنَبَاتࣰا ۝١٥﴾</q> - تفسير ٨٠٨٨٥- قال مقاتل بن سليمان: قال: <q>﴿لِنُخْرِجَ بِهِ﴾</q> يعني: بالمطر <q>﴿حَبًّا﴾</q> يعني بالحبوب: كلّ شيء يُزرع ويُحصد؛ مِن البُرّ، والشعير، والسمسم، ونحوها من الحبوب، قال: <q>﴿ونَباتًا﴾</q> يعني: كلّ شيء يَنبتُ في الجبال والصحاري من الشجر والكلأ، فذلك النبات، وهي تَنبتُ عامًا بعام من قِبل نفسها{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٠.
78,16," <q>﴿وَجَنَّـٰتٍ أَلۡفَافًا ۝١٦﴾</q> - تفسير ٨٠٨٨٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، قال: مُجتمعة{1}. (١٥/١٩٦) ٨٠٨٨٧- عن عبد الله بن عباس -من طريق عطية- <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، يقول: جنات التَفَّ بعضها ببعض{2}. (١٥/١٩٧) ٨٠٨٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، قال: مُلتفّة{3}. (١٥/١٩٦) ٨٠٨٨٩- عن عكرمة مولى ابن عباس، <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، قال: الزرع إذا كان بعضُه إلى جنب بعض{4}. (١٥/١٩٦) ٨٠٨٩٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، قال: مُلتفّة بعضها إلى بعض{5}. (١٥/١٩٦) ٨٠٨٩١- قال مقاتل بن سليمان: <q>﴿وجَنّاتٍ ألْفافًا﴾</q> يعني: وبساتين مُلتفّة بعضها إلى بعض مِن كثرة الشجر{6}. (ز) ٨٠٨٩٢- عن سفيان [الثوري] -من طريق مهران- <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، قال: مُلتفّة{2}. (ز) ٨٠٨٩٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وجَنّاتٍ ألْفافًا﴾</q>، قال: هي المُلتفّة بعضها فوق بعض{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/١٦، وابن أبي حاتم -كما في الإتقان ٢/٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٧.تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٢، وابن جرير ٢٤/١٧، وكذلك من طريق سعيد. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٥٦٠.أخرجه ابن جرير ٢٤/١٧.أخرجه ابن جرير ٢٤/١٧.
78,17," <q>﴿إِنَّ یَوۡمَ ٱلۡفَصۡلِ كَانَ مِیقَـٰتࣰا ۝١٧﴾</q> - تفسير ٨٠٨٩٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّ يَوْمَ الفَصْلِ كانَ مِيقاتًا﴾</q>، قال: هو يوم عَظَّمه الله، وهو يوم يُفصَل فيه بين الأولين والآخرين{1}. (١٥/١٩٧) ٨٠٨٩٥- قال مقاتل بن سليمان: فقال: <q>﴿إنَّ يَوْمَ الفَصْلِ﴾</q> يعني: يوم القضاء -وهو يوم القيامة- بين الخلائق <q>﴿كانَ مِيقاتًا﴾</q> يعني: كان ميقات الكافر، وذلك أنهم كانوا يقولون: <q>﴿مَتى هَذا الوَعْدُ إنْ كُنْتُمْ صادِقِينَ﴾</q> [الملك:٢٥]؛ فأَنزل الله ﷿ يُخبرهم بأنّ ميقات ذلك اليوم كائن يوم الفصل، يا معشر الكفار، فتُجازون ما وعدكم على ألسنة الرُّسُل{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/١٨ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٦٠.
78,18," <q>﴿یَوۡمَ یُنفَخُ فِی ٱلصُّورِ فَتَأۡتُونَ أَفۡوَاجࣰا ۝١٨﴾</q> - تفسير ٨٠٨٩٦- عن عبد الله بن عمرو، قال: سُئِل النبيُّ ﷺ عن الصُّور، فقال: «قرنٌ يُنفخُ فيه»{1}. (٦/٩٦) ٨٠٨٩٧- عن معاذ بن جبل، قال: يا رسول الله، ما قول الله: <q>﴿يَوْمَ يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أفْواجًا﴾</q>؟ فقال: «يا معاذ، سألتَ عن عظيم من الأمر». ثم أرسل عينيه، ثم قال: «عشرة أصناف قد ميّزهم الله مِن جماعة المسلمين، فبدَّل صورهم؛ فبعضهم على صورة القِردة، وبعضهم على صورة الخنازير، وبعضهم منكوسون، أرجلهم فوق وجوههم أسفل، يُسحبون عليها، وبعضهم عُمْيٌ يَتردّدون، وبعضهم صُمٌّ بُكمٌ لا يَعقلون، وبعضهم يَمضَغُون ألسنتهم وهي مُدلاة على صدورهم، يَسيل القِيح من أفواههم لُعابًا، يَقْذَرُهم أهل الجمع، وبعضهم مُقطّعة أيديهم وأرجلهم، وبعضهم مُصلَّبون على جذوع من نار، وبعضهم أشدُّ نَتنًا مِن الجِيَف، وبعضهم يَلبسون جِبابًا سابغة من قَطِران لازقة بجلودهم، فأما الذين على صورة القِردة فالقتّات من الناس، وأما الذين على صورة الخنازير فأكَلة السُّحت، والمُنكّسون على وجوههم فأكَلة الربا، والعُمي مَن يَجُور في الحكم، والصُّمّ البُكم المُعجبون بأعمالهم، والذين يَمضَغُون ألسنتهم فالعلماء والقصّاص مِن الذين يخالف قولهُم أعمالهَم، والمُقطّعة أيديهم وأرجلهم الذين يؤذون الجيران، والمُصلَّبون على جذوع من نار فالسُّعاة بالناس إلى السلطان، والذين هم أشد نَتنًا مِن الجِيَف الذين يتمتعون بالشهوات واللذات ويمنعون حقّ الله وحقّ الفقراء من أموالهم، والذين يَلبسون الجِباب فأهل الكِبْر والخُيلاء والفَخْر»{2}. (١٥/١٩٧) ٨٠٨٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَوْمَ يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أفْواجًا﴾</q>، قال: زُمَرًا زمَرًا{3}. (١٥/١٩٧) ٨٠٨٩٩- قال مقاتل بن سليمان: ثم أخبرهم أيضًا، فقال: <q>﴿يَوْمَ يُنْفَخُ فِي الصُّورِ﴾</q>، وذلك أنّ إسرافيل ﵇ يَنفخ فيها، فيقول: أيّتها العظام البالية، وأيّتها العروق المُتقطّعة، وأيّتها اللحوم المُتمزّقة، وأيّتها الأشعار الساقطة، اجتمعنَّ لِنَنفخَ فيكم أرواحَكم، ونجازيكم بأعمالكم. ويُديم المَلَك الصوت، فتجتمع الأرواح كلّها في القَرْن، والقَرْن طوله طول السموات والأرض، فتَخرج أرواحهم مثل النّحل؛ سُود وبِيض، شقي وسعيد، أرواح المؤمنين بِيض كأمثال النّحل مِن السماء إلى وادٍ بدمشق يقال له: الجابية، وتَخرج أرواح الكفار مِن الأرض السُّفلى سُود إلى وادٍ بحضرموت يُقال له: بَرَهُوت، وكلّ روح أعرَف بجسد صاحبه مِن أحدكم إلى منزله <q>﴿فَتَأْتُونَ أفْواجًا﴾</q>، ثم ينزل إسرافيل من فوق السماء السابعة، فيَجلس على صخرة بيت المقدس، فيَأخذ أرواح الكفار والمؤمنين ويَجعلهم في القَرْن، ودائرة القَرْن مسيرة خمسمائة عام، ثم يَنفخ في القَرْن، فتَطير الأرواح حتى تطبق ما بين السماء والأرض، فتَذهب كلّ روح، فتقع في جسد صاحبها، فيَخرج الناس من قبورهم فوجًا فوجًا، فذلك قوله: <q>﴿فَتَأْتُونَ أفْواجًا﴾</q> يعني: زمرًا زمرًا، وفِرقًا فِرقًا، وأممًا أممًا{4}٦٩٨٤. (ز) ٦٩٨٤ أفادت آثار السلف أنّ الصُّور: هو القَرْن الذي يُنفخ فيه لِبَعْث الناس. وقد ذكر ذلك ابنُ عطية (٨/٥١٦)، ثم ذكر احتمالًا آخر، فقال: «ويحتمل هذا الموضع أن يكون»الصُّور«فيه جمع صورة، أي: يوم يرد الله فيه الأرواح إلى الأبدان، هذا قول بعضهم في الصُّورِ، وجوزه أبو حاتم». ثم رجّح -مستندًا إلى أقوال السلف، والنظائر- الأول، فقال: «والأول أشهر، وبه تظاهرت الآثار، وهو ظاهر كتاب الله تعالى في قوله: <q>﴿ثُمَّ نُفِخَ فِيهِ أُخْرى﴾</q> [الزمر:٦٨]». ",footnotes:1:أخرجه أحمد ١١/٥٣ (٦٥٠٧)، ١١/٤١٠ (٦٨٠٥)، وأبو داود ٧/١٢١ (٤٧٤٢)، والترمذي ٤/٤٢٧-٤٢٨ (٢٥٩٩)، ٥/٤٥١ (٣٥٢٥)، وابن حبان ١٦/٣٠٣ (٧٣١٢)، والحاكم ٢/٤٧٣ (٣٦٣١)، ٢/٥٥٠ (٣٨٧٠)، ٤/٦٠٤ (٨٦٨٠)، ويحيى بن سلام ١/٢٠٩، ٢/٨١٢، وابن جرير ١٥/٤١٦، ٢٤/١٩، وابن أبي حاتم ٤/١٣٢٣ (٧٤٨٣)، ٩/٢٩٢٨ (١٦٦١٩)، والثعلبي ٧/٢٢٦، ٨/٢٥٤. قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وأورده الألباني في الصحيحة ٣/٦٨ (١٠٨٠). وقد تقدم تخريجه عند تفسير قوله تعالى: <q>﴿ولَهُ المُلْكُ يَوْمَ يُنْفَخُ فِي الصُّورِ﴾</q> [الأنعام:٧٣]. كذلك تقدمت الآثار في بيان الصور هناك.أخرجه ابن مردويه -كما في تخريج الكشاف ٤/١٤٣-١٤٥-، والثعلبي ١٠/١١٥. قال الألباني في الضعيفة ١٣/٩٩٤ (٦٤٤٤): «موضوع».تفسير مجاهد ص٦٩٤، وأخرجه ابن جرير ٢٤/١٩، وابن أبي حاتم -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٦٠-٥٦١.
78,19," <q>﴿وَفُتِحَتِ ٱلسَّمَاۤءُ فَكَانَتۡ أَبۡوَ ٰ⁠بࣰا ۝١٩﴾</q> - تفسير ٨٠٩٠٠- قال مقاتل بن سليمان: <q>﴿وفُتِحَتِ السَّماءُ﴾</q> يعني: وفُرجت السماء، يعني: وفُتِقت السماء فتَقطّعتْ، <q>﴿فَكانَتْ أبْوابًا﴾</q> يعني: خللًا خللًا، فشبّهها الله بالغيم إذا انكشف بعد المطر، ثم تَهيج به الريح الشمال الباردة، فينقطع، فيصير كالأبواب{1}٦٩٨٥. (ز) ٦٩٨٥ ذكر ابنُ عطية (٨/٥١٦) في قوله: <q>﴿فكانت أبوابا﴾</q> قولين، فقال: «وقوله تعالى: <q>﴿فكانت أبوابا﴾</q> قيل: معناه: تتفطّر وتتشقّق حتى يكون فيها فتوح كالأبواب في الجدران. وقال آخرون -فيما حكى مكي بن أبي طالب-: الأبواب هنا فِلَق الخشب التي تُجعل أبوابًا لفتوح الجدران، أي: تتقطّع السماء قِطعًا صغارًا حتى تكون كألواح الأبواب. ورجّح القول الأول بقوله:»والقول الأول أحسن". ولم يذكر مستندًا. ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦١.
78,20," <q>﴿وَسُیِّرَتِ ٱلۡجِبَالُ فَكَانَتۡ سَرَابًا ۝٢٠﴾</q> - تفسير ٨٠٩٠١- عن عبد الله بن عباس، في قوله: <q>﴿وسُيِّرَتِ الجِبالُ فَكانَتْ سَرابًا﴾</q>، قال: سراب الشمس: الآل{1}. (١٥/١٩٩) ٨٠٩٠٢- عن عامر الشعبي= (ز) ٨٠٩٠٣- وعطاءِ بن أبي رباح= (ز) ٨٠٩٠٤- وعكرمة مولى ابن عباس -من طريق جابر- قالوا: السّراب كهيئة الآل{2}. (ز) ٨٠٩٠٥- قال مقاتل بن سليمان: <q>﴿وسُيِّرَتِ الجِبالُ﴾</q> يعني: وانقلعت الجبال مِن أماكنها، فطارتْ بين السماء والأرض مِن خشية الله، فضَرب الله لها مثلًا، فقال: <q>﴿فَكانَتْ سَرابًا﴾</q> يعني: مثل السّراب الذي يكون بالقاع، يحسبه الظمآن ماء، فإذا أتاه لم يجده شيئًا، فذلك قوله: <q>﴿تَحْسَبُها جامِدَةً﴾</q> [النمل:٨٨] يعني: مِن بعيد يَحسبها جبلًا قائمًا، فإذا انتهى إليه ومسّه لم يجده شيئًا، فتصير الجبالُ أول مرة كالمُهل، ثم تصير الثانية كالعِهن المنفوش، ثم تَذهب فتصير لا شيء، فتراها تحسبها جبالًا، فإذا مسَستها لم تجدها شيئًا، فذلك قوله: <q>﴿وسُيِّرَتِ الجِبالُ﴾</q> يعني: انقطعت الجبال مِن خشية الله ﷿ يوم القيامة، <q>﴿فَكانَتْ سَرابًا﴾</q> فما حالك، يا ابن آدم؟!{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٥-.تفسير مقاتل بن سليمان ٤/٥٦١-٥٦٢.
78,21," <q>﴿إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادࣰا ۝٢١﴾</q> - نزول الآيات ٨٠٩٠٦- قال مقاتل بن سليمان: نزلت في الوليد بن المُغيرة{1}. (ز) <q>﴿إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادࣰا ۝٢١﴾</q> - تفسير الآية ٨٠٩٠٧- عن أبي الجَوْزاء -من طريق عمرو بن مالك- في قوله: <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q>، قال: صارت{2}. (١٥/١٩٩) ٨٠٩٠٨- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q>، قال: لا يَدخل الجنةَ أحدٌ حتى يجتاز النار{3}. (١٥/١٩٩) ٨٠٩٠٩- عن الحسن البصري -من طريق أبي سهل- في قوله: <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q>، قال: تَرْصُدهم، واللهِ. قال: وبينما رجل يمرّ إذ استقبله آخر، قال: أبَلغك أنّ بالطريق رَصَدًا؟ قال: نعم. قال: فخذْ حِذرك إذًا{4}. (ز) ٨٠٩١٠- عن الحسن البصري -من طريق عبد الله بن بكر- <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q>، قال: ألا إنّ على الباب الرَصَد، فمَن جاء بجواز جاز، ومن لم يَجِئْ بجواز حُبس{5}. (ز) ٨٠٩١١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q>، قال: تَعلَّموا أنه لا سبيل إلى الجنة حتى تُقطع النار، وقال في آية أخرى: <q>﴿وإنْ مِنكُمْ إلّا وارِدُها﴾</q> [مريم:٧١]{6}. (١٥/١٩٩-٢٠٠) ٨٠٩١٢- عن محمد بن كعب القُرَظيّ -من طريق بكر بن مُضر- كان يقول: إنّ بين أيديكم مرصدًا، فخذوا له جوازَه. ثم قرأ: <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا لِلطّاغِينَ مَآبًا﴾</q>{7}. (ز) ٨٠٩١٣- عن سفيان [الثوري] -من طريق مهران- <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q>، قال: عليها ثلاث قناطر{8}. (١٥/١٩٩) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٢.أخرجه ابن أبي شيبة ١٤/١٨. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، ابن المنذر.أخرجه ابن جرير ٢٤/٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٨٧ (٣٦٤١٧)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤٢ (٢٠١)- من طريق فضالة.أخرجه ابن جرير ٢٤/٢٠، والبيهقي في شعب الإيمان ٣/١٥٥-١٥٦ (٨٧٤).أخرجه ابن جرير ٢٤/٢١ مختصرًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦٨ (١٥٤).أخرجه ابن جرير ٢٤/٢١.
78,22," <q>﴿لِّلطَّـٰغِینَ مَـَٔابࣰا ۝٢٢﴾</q> - تفسير ٨٠٩١٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لِلطّاغِينَ مَآبًا﴾</q>، قال: مأوى، ومنزلًا{1}. (١٥/١٩٩) ٨٠٩١٥- قال مقاتل بن سليمان: <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا لِلطّاغِينَ﴾</q> يعني: للكافرين <q>﴿مَآبًا﴾</q> يعني: للمشركين مرجعًا إليها، نزلت في الوليد بن المغيرة{2}. (ز) ٨٠٩١٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿مَآبًا﴾</q>، يقول: مَرجعًا، ومنزلًا{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٦٢.أخرجه ابن جرير ٢٤/٢١.
78,23," <q>﴿لَّـٰبِثِینَ فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾</q> - قراءات ٨٠٩١٧- عن عمرو بن ميمون أنه قرأها: ‹لَبِثِينَ فِيهَآ أحْقابًا› بغير ألف{1}. (١٥/٢٠٣) ٨٠٩١٨- عن عمرو بن شرحبيل أنه قرأها: ‹لَبِثِينَ فِيهَآ أحْقابًا›{2}. (١٥/٢٠٣) ٨٠٩١٩- عن عاصم أنه قرأ: <q>﴿لابِثِينَ فِيهَآ أحْقابًا﴾</q> بالألف{2}٦٩٨٦. (١٥/٢٠٣) ٦٩٨٦ رجّح ابنُ جرير (٢٤/٢٢) -مستندًا إلى الأفصح لغة- قراءة مَن قرأ: <q>﴿لابثين﴾</q> بالألف، فقال: «وأفصح القراءتين وأصحّهما مخرجًا في العربية قراءةُ مَن قرأ ذلك بالألف؛ وذلك أنّ العرب لا تكاد توقع الصفة إذا جاءت على (فَعِل) فتُعمِلها في شيء وتنصبه بها، لا يكادون أن يقولوا: هذا رجل بَخِلٌ بماله، ولا عَسِرٌ علينا، ولا هو خَصِمٌ لنا. لأنّ (فَعِل) لا يأتي صفة إلا مدحًا أو ذمًّا، فلا يَعمل المدح والذم في غيره، وإذ أرادوا إعمال ذلك في الاسم أو غيره جعلوه فاعلًا، فقالوا: هو باخل بماله، وهو طامع فيما عندنا، فلذلك قلتّ: إنّ <q>﴿لابثين﴾</q> أصح مخرجًا في العربية وأفصح، ولم أحلّ قراءة مَن قرأ: ‹لَبِثِينَ › وإن كان غيرها أفصح؛ لأن العرب ربما أعملت المدح في الأسماء». وذكر ابنُ عطية (٨/٥١٨) قراءة: ‹لَبِثِينَ ›، ثم انتقدها -مستندًا إلى اللغة- عليها قائلًا: «وهي قراءة معترضة لأنّ (فَعِلًا) إنما يكون لما صار خُلُقًا؛ كحَذِر وفَرِق، وقد جاء شاذًّا فيما ليس بخُلُق». <q>﴿لَّـٰبِثِینَ فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾</q> - تفسير الآية ٨٠٩٢٠- عن أبي أُمامة، عن النبيِّ ﷺ، قال: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: «الحُقُب ألف شهر، والشهر ثلاثون يومًا، والسنة اثنا عشر شهرًا، والسنة ثلاثمائة وستون يومًا، كلّ يوم منها ألف سنة مما تَعُدُّون؛ فالحُقُب ثلاثون ألف سنة»{4}. (١٥/٢٠٢) ٨٠٩٢١- عن أبي هريرة رفعه: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: «الحُقُب ثمانون سنة»{5}. (١٥/٢٠١) ٨٠٩٢٢- عن ابن عمر، عن النبيِّ ﷺ، قال: «واللهِ، لا يخرج من النار أحد حتى يَمكث فيها أحقابًا، والحُقُب بضع وثمانون سنة، كلّ سنة ثلاثمائة وستون يومًا، واليوم ألف سنة مما تَعُدُّون»{6}. (١٥/٢٠٢) ٨٠٩٢٣- عن عُبادة بن الصّامت، قال: قال رسول الله ﷺ: «الحُقُب أربعون سنة»{7}. (١٥/٢٠٣) ٨٠٩٢٤- عن عبد الله بن مسعود -من طريق مُرّة- قال: لو عَلم أهل النار أنهم يَلبثون في النار عدد حصى الدنيا لفرحوا، ولو عَلم أهل الجنة أنهم يَلبثون في الجنة عدد حصى الدنيا لحزنوا{8}. (ز) ٨٠٩٢٥- عن عبد الله بن مسعود -من طريق أبي الضحى- قال: لا يَعلم عدد الأحقاب إلا الله ﷿{9}. (ز) ٨٠٩٢٦- عن عبد الله بن مسعود -من طريق عمرو بن ميمون- في قوله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: الحُقُب ثمانون سنة{10}. (١٥/٢٠١) ٨٠٩٢٧- عن أبي هريرة -من طريق شريك، عن عاصم بن أبي النجود، عن أبي صالح - <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: الحُقُب ثمانون سنة، والسنة ثلاثمائة وستون يومًا، واليوم كألف سنة مما تَعُدُّون{11}. (١٥/٢٠١) ٨٠٩٢٨- عن أبي هريرة -من طريق حماد بن سلمة، عن عاصم بن أبي النجود، عن أبي صالح - <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: الحُقُب ثمانون عامًا، اليوم منها كسُدس الدنيا{12}. (١٥/٢٠٢) ٨٠٩٢٩- عن عبد الله بن عمرو -من طريق عمرو بن ميمون- وفي قوله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: الحُقُب الواحد ثمانون سنة{13}. (١٥/٢٠٣) ٨٠٩٣٠- عن عبد الله بن عباس -من طريق أبي سنان- قال: الحُقُب ثمانون سنة{14}. (١٥/٢٠٣) ٨٠٩٣١- عن عبد الله بن عباس، <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: سنين{15}. (١٥/٢٠٠) ٨٠٩٣٢- قال عبد الله بن عمر: فلا يَتّكِلنّ أحدٌ على أنه يَخرج من النار{16}. (١٥/٢٠٢) ٨٠٩٣٣- قال علي بن أبي طالب لهلال الهَجَرِيّ: ما تجدون الحُقُب في كتاب الله؟ قال: نجده ثمانين سنة، كلّ سنة اثنا عشر شهرًا، كلّ شهر ثلاثون يومًا، كلّ يوم ألف سنة{17}. (١٥/٢٠١) ٨٠٩٣٤- عن بشير بن كعب -من طريق إسحاق بن سُويد- في قوله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: بلغني: أنّ الحُقُب ثلاثمائة سنة، كلّ سنة ثلاثمائة وستون يومًا، كلّ يوم ألف سنة{18}. (١٥/٢٠٠-٢٠١) ٨٠٩٣٥- عن سعيد بن جُبَير -من طريق الأعمش- في قوله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: الحُقُب ثمانون سنة، السنة ثلاثمائة وستون يومًا، اليوم سنة أو ألف سنة{19}. (١٥/٢٠٢) ٨٠٩٣٦- قال مجاهد بن جبر: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q> الأحقاب ثلاثة وأربعون حُقُبًا، كلّ حُقُب سبعون خريفًا، كلّ خريف سبعمائة سنة، كلّ سنة ثلاثمائة وستون يومًا، كلّ يوم ألف سنة{20}. (ز) ٨٠٩٣٧- عن خالد بن معدان -من طريق عامر بن جَشِيب- في قوله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، وقوله: <q>﴿إلّا ما شاءَ رَبُّكَ﴾</q> [هود:١٠٧]: إنهما في أهل التوحيد مِن أهل القِبلة{21}. (١٥/٢٠٤) ٨٠٩٣٨- عن الحسن البصري -من طريق المبارك- <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: ليس لها أجل، كلّما مضى حُقُب دخل في الأخرى{22}. (١٥/٢٠٠) ٨٠٩٣٩- عن الحسن البصري -من طريق سالم- قال: الحُقُب الواحد سبعون سنة، كلّ يوم منها ألف سنة{23}. (١٥/٢٠٠) ٨٠٩٤٠- عن الحسن البصري -من طريق جعفر بن جسر، عن أبيه- قال: والحُقُب الواحد ثمانون ألف سنة، والسنة ثلاثمائة وستون يومًا، وكلّ يوم <q>﴿عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾</q> [الحج:٤٧]{24}. (ز) ٨٠٩٤١- عن الحسن البصري -من طريق هشام- في قوله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: أما الأحقاب فلا يَدري أحد ما هي، وأما الحُقُب الواحد: فسبعون ألف سنة، كلّ يوم كألف سنة{21}. (ز) ٨٠٩٤٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: الأحقاب ما لا انقطاع له، كلّما مضى حُقُب جاء بعده حُقُب. قال: وذُكر لنا أنّ الحُقُب: ثمانون سنة من سني يوم القيامة{26}. (١٥/١٩٩) ٨٠٩٤٣- عن سيّار أبي الحكم، قال: الحُقُب: ثمانون سنة، والسنة ثلاثمائة وستون يومًا، واليوم كألف سنة مما تَعُدُّون{27}. (ز) ٨٠٩٤٤- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، قال: لا يَدري أحدُكم تلك الأحقاب، إلا أنّ الحُقُب الواحد ثمانون سنة، السنة ثلاثمائة وستون يومًا، اليوم الواحد مِقدار ألف سنة، والحُقُب الواحد ثمانية عشر ألف سنة{28}. (١٥/٢٠٠) ٨٠٩٤٥- قال مقاتل بن حيّان: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q> الحُقُب الواحد سبع عشرة ألف سنة{29}. (ز) ٨٠٩٤٦- قال مقاتل بن سليمان: <q>﴿لابِثِينَ فِيها﴾</q> يعني: في جهنم <q>﴿أحْقابًا﴾</q> يعني: في جهنم أحقابًا، وهي سبعة عشر حُقُبًا، يعني: الأزمنة والأحقاب لا يَدري عددها، ولا يَعلم منتهاها إلا الله ﷿، الحُقُب الواحد ثمانون سنة، السنة فيها ثلاثمائة وستون يومًا، كلّ يوم فيها مِقدار ألف سنة، وكان هذا بمكة{30}٦٩٨٧. (ز) ٦٩٨٧ اختُلف في الموصوف باللبث أحقابًا على قولين: الأول: الكفار. الثاني: عُصاة المؤمنين. وكذا اختُلف في مدة الحُقُب على أقوال: الأول: ألف شهر. الثاني: ثلاثون ألف سنة. الثالث: ثمانون سنة. الرابع: بضع وثمانون سنة. الخامس: أربعون سنة. السادس: ثلاثمائة سنة. السابع: ثمانون ألف سنة. الثامن: سبعون ألف سنة. التاسع: سبع عشرة ألف سنة. العاشر: أنّ الحُقُب لا حَدّ له. وقد ذكر ابنُ جرير (٢٤/٢٦ بتصرف) هذا الخلاف، ثم قال: «الذي قاله قتادة والربيع بن أنس في ذلك أصح. فإن قيل: فما للكفار عند الله عذاب إلا أحقابًا. قيل: إنّ الربيع وقتادة قد قالا: إنّ هذه الأحقاب لا انقضاء لها ولا انقطاع. وقد يحتمل أن يكون معنى ذلك: <q>﴿لابثين فيها أحقابا﴾</q>، في هذا النوع من العذاب هو أنهم: <q>﴿لا يذوقون فيها بردا ولا شرابا إلا حميما وغساقا﴾</q>، فإذا انقضتْ تلك الأحقاب صار لهم من العذاب أنواع غير ذلك، كما قال -جلّ ثناؤه- في كتابه: <q>﴿وإن للطاغين لشر مآب جهنم يصلونها فبئس المهاد هذا فليذوقوه حميم وغساق وآخر من شكله أزواج﴾</q> [ص:٥٥-٥٨]، وهذا القول عندي أشبه بمعنى الآية». وذكر ابنُ عطية (٨/٥١٨) هذه الأقوال، ثم قال معلّقًا: «اللازم أنّ الله تعالى أخبر عن الكفار أنهم يَلبثون أحْقابًا، كلّما مَرّ حُقُب جاء غيره إلى ما لا نهاية». وانتقد -مستندًا إلى السياق- قول مَن جعلها في عُصاة المؤمنين بقوله: «وهذا أيضًا ضعيف، ما بعده في السورة يرد عليه». وذكر ابنُ تيمية (٦/٤٥٣) نحو ما جاء في كلام ابن جرير مِن أنّ قوله: <q>﴿لابثين فيها أحقابا﴾</q> أي: في هذا النوع من العذاب عن الزّجّاج، وانتقده مستندًا إلى الدلالة العقلية، والإجماع، فقال: «وهذا الذي قاله الزّجّاج شاذٌّ، خلاف ما عليه الأولون والآخرون، وهو خلاف ما دلّ عليه القرآن، فإنّ هذا يقتضي أنهم يَبقون بعد الأحقاب فيها، ولكن لا يَذوقون البرد والشراب حينئذ، وهذا باطل قطعًا، ثم إذا ذاقوا البَرد والشراب فهذا نعيم، فكيف يكونون مُعذّبين فيها ذلك؟!». <q>﴿لَّـٰبِثِینَ فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾</q> - النسخ في الآية ٨٠٩٤٧- عن عمرو بن أبي سَلمة، قال: سألت أبا معاذ الخراساني عن قول الله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>. فأَخبَرنا عن مقاتل بن حيّان قال: منسوخة، نَسَخَتْها: <q>﴿فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</q>{31}٦٩٨٨. (ز) ٦٩٨٨ ذكر ابنُ جرير (٢٤/٢٧) هذا القول، وانتقده مستندًا إلى دلالة العقل، فقال: «ولا معنى لهذا القول؛ لأن قوله: <q>﴿لابثين فيها أحقابا﴾</q> خبر، والأخبار لا يكون فيها نسخ، وإنما النسخ يكون في الأمر والنهي». وبنحوه قال ابنُ عطية (٨/٥١٢). ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد. وهي قراءة متواترة، قرأ بها حمزة، وروح، وقرأ بقية العشرة: <q>﴿لابِثِينَ﴾</q> بألف بعد اللام. انظر: النشر ٢/٣٩٧، والإتحاف ص٥٦٩.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي عمر العدني في مسنده -كما في إتحاف الخيرة المهرة ٦/٢٩٨ (٥٨٨٩)-، والطبراني في الكبير ٨/٢٤٤ (٧٩٥٧) مختصرًا، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٠٥-٣٠٦-، من طريق جعفر بن الزُّبير، عن القاسم، عن أبي أُمامة به. وقال ابن كثير: «حديث منكر جدًّا، والقاسم هو والراوي عنه -وهو جعفر بن الزُّبير- كلاهما متروك». وقال الهيثمي في المجمع ٧/١٣٣ (١١٤٦٢): «فيه جعفر بن الزُّبير، وهو ضعيف». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٨ (٥٨٨٩): «هذا إسناد ضعيف؛ لضعف جعفر، والقاسم هو ابن عبد الرحمن». وقال السيوطي: «سند ضعيف».أخرجه البزار ١٦/٢٠ (٩٠٤٩)، من طريق الحجاج بن نصير، عن همام عن عاصم، عن أبي صالح، عن أبي هريرة به. قال البزار: «هذا الحديث لا نعلم أحدًا رفعه إلا الحجّاج بن نصير عن همام، وغيره يُوقفه». وقال الهيثمي في المجمع ٧/١٣٣ (١١٤٦١): «فيه حجّاج بن نصير، وثّقه ابن حبان، وقال: يخطئ ويَهم، وضعّفه جماعة، وبقية رجاله ثقات». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٨ (٥٨٨٩): «في سنده الحجّاج بن نصير، وهو ضعيف». وأورده الدارقطني في العلل ٨/٢٠٩ (١٥١٩). والسيوطي في اللآلئ المصنوعة ٢/٣٨٧.أخرجه البزار ١٢/٢٤٠ (٥٩٨٠)، وأبو بكر الشافعي في الغيلانيات ١/٤٢٨ (٤٧٧)، والثعلبي ١٠/١١٦، من طريق سليمان بن مسلم، عن سليمان التيمي، عن نافع، عن ابن عمر به. ذكره ابن الجوزي في الموضوعات ٣/٢٦٧. وقال الهيثمي في المجمع ١٠/٣٩٥ (١٨٦٣٢): «فيه سليمان بن مسلم الخشّاب، وهو ضعيف جدًّا». وقال السيوطي في اللآلئ المصنوعة ٢/٣٨٦: «قال ابن عدي: هذا حديث منكر جدًّا. وسليمان شبه المجهول، وروى عن التيميّ ما ليس من حديثه بحديثه، وقال الحافظ أبو الحسن الهيثمي وأبو الفضل بن حجر في الزوائد: هذا الحديث موضوع في نقدي». وأورده الألباني في الضعيفة ١١/٦٣٩.أخرجه ابن عدي في الكامل ٦٥/٢٢٨، من طريق عمرو بن شمر، عن ليث بن أبي سليم، عن عبد الرحمن بن سابط، عن عُبادة بن الصّامت به. وقال ابن عدي: «غير محفوظ». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٢٥٩ (٢٧١٠): «عمرو متروك الحديث، والحديث غير محفوظ».تفسير البغوي ٨/٣١٥.تفسير الثعلبي ١٠/١١٦.أخرجه الحاكم ٢/٥١٢. وعزاه السيوطي إلى سعيد بن منصور.أخرجه ابن جرير ٢٤/٢٤، وهناد (٢١٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٥-، وفي لفظ آخر عنده: ستة أيام منها كالدنيا كلها. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه سعيد بن منصور ٨/٢٤٧ (٢٣٨٢)، وابن جرير ١٥/٣١٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٢٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البزار (٣٥٠٣- كشف)، والديلمي (٧٠٢٩). وعزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٣٤٢-٣٤٣، وابن جرير ٢٤/٢٤، وهناد (٢٢٠). وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٢٣-٢٤.أخرجه ابن جرير ٢٤/٢٤، والشك في الأثر منه.تفسير البغوي ٨/٣١٤.أخرجه ابن جرير ٢٤/٢٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٥-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٢٥ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي الدنيا في كتاب صفة النار، ومن طريق هشام أيضًا -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٧)-.أخرجه ابن جرير ٢٤/٢٦.أخرجه عبد الرزاق ٢/٣٤٢ من طريق معمر بلفظ: بلغنا أنّ الحُقُب ثمانون سنة من سني الآخرة، وابن جرير ٢٤/٢٥ من طريق معمر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٤٨ (٢٣٨٣).أخرجه ابن جرير ٢٤/٢٥ دون آخره. وعزاه السيوطي إلى عَبد بن حُمَيد، وأبي الشيخ.تفسير الثعلبي ١٠/١١٦، وتفسير البغوي ٨/٣١٥.تفسير مقاتل بن سليمان ٤/٥٦٢.أخرجه ابن جرير ٢٤/٢٧.
78,24," <q>﴿لَّا یَذُوقُونَ فِیهَا بَرۡدࣰا وَلَا شَرَابًا ۝٢٤﴾</q> - تفسير ٨٠٩٤٨- عن عبد الله بن مسعود، قال: زمهرير جهنم يكون لهم من العذاب؛ لأن الله يقول: <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</q>{1}. (١٥/٢٠٤) ٨٠٩٤٩- عن عبد الله بن عباس -من طريق أبي صالح- قال: لا يذقون فيها بَرد الشراب، ولا الشراب{2}. (ز) ٨٠٩٥٠- عن عبد الله بن عباس: <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</q> أنّ البَرد: النوم{3}. (ز) ٨٠٩٥١- عن مُرّة، <q>﴿لا يَذُوقُونَ فِيها بَرْدًا﴾</q>، قال: نومًا{4}. (١٥/٢٠٥) ٨٠٩٥٢- قال عطاء: <q>﴿لا يَذُوقُونَ فِيها بَرْدًا﴾</q>، أي: رَوْحًا، وراحة{5}. (ز) ٨٠٩٥٣- عن الحسن البصري -من طريق جعفر بن جسر، عن أبيه- <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</q>: البَرد: النوم{6}. (ز) ٨٠٩٥٤- قال مقاتل بن سليمان: وأنزل الله ﷿: <q>﴿لا يَذُوقُونَ فِيها﴾</q> في تلك الأحقاب <q>﴿بَرْدًا﴾</q> يعني: بَرد الكافور، <q>﴿ولا شَرابًا﴾</q> يعني: الخمر كفعل أهل الجنة، <q>﴿لا يَذُوقُونَ﴾</q> في جهنم <q>﴿بَرْدًا ولا شَرابًا﴾</q> يعني: لا يذوقون فيها روحًا طيبًا، ولا شرابًا باردًا يَنفعهم مِن هذه النار{7}٦٩٨٩. (ز) ٦٩٨٩ في قوله: <q>﴿بردا﴾</q> ثلاثة أقوال: الأول: بَرد الهواء. الثاني: النوم. الثالث: الراحة. ولم يذكر ابنُ جرير (٢٤/٢٧) غير القولين الأوليين، ورجّح القول الأول، وانتقد الثاني مستندًا إلى الأغلب لغة، فقال: «وقوله: <q>﴿لا يذوقون فيها بردا ولا شرابا﴾</q> يقول: لا يَطعمون فيها بردًا يُبرد حرّ السعير عنهم، إلا الغسّاق، ولا شرابًا يَرويهم من شدة العطش الذي بهم، إلا الحميم». فقال: «وقد زعم بعض أهل العلم بكلام العرب أنّ البَرد في هذا الموضع: النوم ...، وتأويل كتاب الله على الأغلب من معروف كلام العرب، دون غيره». وعلّق ابنُ عطية (٨/٥١٩) على القول الأول والثاني بقوله: «فالذوق على هذين القولين مستعار». ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه الفراء في معاني القرآن ٣/٢٢٨.تفسير البغوي ٨/٣١٥.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/١١٧، وتفسير البغوي ٨/٣١٥.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٧)-.تفسير مقاتل بن سليمان ٤/٥٦٢-٥٦٣.
78,25," <q>﴿إِلَّا حَمِیمࣰا وَغَسَّاقࣰا ۝٢٥﴾</q> - تفسير ٨٠٩٥٥- عن أبي هريرة، عن النبيِّ ﷺ، في قوله: <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا إلّا حَمِيمًا﴾</q> قال: «قد انتهى حرّه». <q>﴿وغَسّاقًا﴾</q> قال: «قد انتهى بَرده، وإنّ الرجل إذا أدنى الإناء من فِيه سقط فَروة وجهه، حتى يَبقى عظامًا تَقَعْقَع{1}»{2}. (١٥/٢٠٤) ٨٠٩٥٦- عن عبد الله بن عمرو -من طريق أبي مالك- أنه قال: أتدرون أيَّ شيء الغسّاق؟ قالوا: الله أعلم. قال: هو القِيح الغليظ، لو أنّ قطرة منه تُهراق بالمغرب لأَنتن أهل المشرق، ولو تُهراق بالمشرق لأَنتن أهل المغرب{3}. (ز) ٨٠٩٥٧- عن عبد الله بن عباس -من طريق علي- <q>﴿إلّا حَمِيمًا وغَسّاقًا﴾</q>، قال: الحميم: الحارّ الذي يَحرق. والغسّاق: الزمهرير البارد{4}. (١٥/٢٠٤) ٨٠٩٥٨- عن أبي العالية الرِّياحيّ -من طريق الربيع- <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا إلّا حَمِيمًا وغَسّاقًا﴾</q>، قال: فاستثنى مِن الشراب الحميم، ومن البارد الغسّاق، وهو الزمهرير{5}. (١٥/٢٠٤) ٨٠٩٥٩- عن أبي رَزِين [مسعود بن مالك الأسدي]= (ز) ٨٠٩٦٠- وإبراهيم [النَّخْعي] -من طريق منصور- <q>﴿إلّا حَمِيمًا وغَسّاقًا﴾</q>، قالا: غُسالة أهل النار. وفي لفظ: ما يَسيل من صديدهم{6}. (ز) ٨٠٩٦١- عن إبراهيم النَّخْعي -من طريق منصور- في قوله: <q>﴿حميما وغساقا﴾</q>، قال: الغسّاق: ما يَنقطع مِن جلود أهل النار، وصديدهم{7}. (ز) ٨٠٩٦٢- عن عبد الله بن بُرَيْدة -من طريق صالح بن حيّان- قال: الغسّاق بالطُّخارية: هو المُنتِن{8}. (ز) ٨٠٩٦٣- عن مجاهد بن جبر -من طريق ليث- <q>﴿إلّا حَمِيمًا وغَسّاقًا﴾</q>، قال: لا يستطيعونه مِن بَرده{9}. (١٥/٢٠٤) ٨٠٩٦٤- عن عكرمة مولى ابن عباس -من طريق أبي عمرو- في قوله: <q>﴿وغَسّاقًا﴾</q>، قال: ما يَخرج من أبصارهم مِن القيح والدّم{10}. (ز) ٨٠٩٦٥- عن الحسن البصري -من طريق جعفر بن جسر، عن أبيه- <q>﴿إلّا حَمِيمًا وغَسّاقًا﴾</q>، قال: شَرابَيْن في النار؛ يقال لأحدهما: حميم، والآخر: غسّاق{11}. (ز) ٨٠٩٦٦- عن عطية بن سعد العَوفيّ -من طريق ابن إدريس، عن أبيه- في قوله: <q>﴿حَمِيمًا وغَسّاقًا﴾</q>، قال: هو الذي يَسيل مِن جلودهم{10}. (ز) ٨٠٩٦٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وغَسّاقًا﴾</q>: كُنّا نُحدَّث أنّ الغسّاق: ما يَسيل مِن بين جِلده ولحمه{6}. (ز) ٨٠٩٦٨- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا إلّا حَمِيمًا وغَسّاقًا﴾</q>: فاستثنى من الشراب الحميم، ومن البارد الغسّاق{10}. (ز) ٨٠٩٦٩- عن الربيع بن أنس -من طريق أبي جعفر- قال: الغسّاق: الزمهرير{8}. (ز) ٨٠٩٧٠- قال مقاتل بن سليمان: ثم استثنى، فقال: <q>﴿إلّا حَمِيمًا﴾</q> يعني: حارًّا{16}. (ز) ٨٠٩٧١- عن سفيان [الثوري] -من طريق الضَّحّاك بن مخلد- أنه قال: بلَغني: أنّه ما يَسيل مِن دموعهم{6}. (ز) ٨٠٩٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إلّا حَمِيمًا وغَسّاقًا﴾</q>، قال: الحميم: دموع أعينهم في النار، يجتمع في خنادق النار، فيُسقَونه. والغسّاق: الصّديد الذي يَخرج من جلودهم، مما تَصهرهم النار في حياض يجتمع فيها، فيُسقَونه{18}٦٩٩٠. (ز) ٦٩٩٠ اختُلف في الغسّاق على أقوال: الأول: ما يَسيل مِن جلود أهل النار من الصديد. الثاني: الزمهرير. الثالث: المُنتِن. وعلّق ابنُ عطية (٨/٥٢٠) على القول الأول، فقال: «يقال: غسق الجرح: إذا سال منه قِيح ودم، وغَسقت العين: إذا دمعتْ وإذا خرج قَذاها». وقد ذكر ابنُ جرير (٢٤/٣١) هذه الأقوال، ثم جمع بينها، فقال: «والغسّاق عندي: هو الفعال، من قولهم: غَسقتْ عينُ فلان: إذا سالتْ دموعها، وغَسق الجرح: إذا سال صديده، ومنه قول الله: <q>﴿ومن شر غاسق إذا وقب﴾</q> [الفلق:٣] يعني بالغاسق: الليل إذا لبس الأشياء وغطاها، وإنما أريد بذلك هجومه على الأشياء هجوم السيل السائل، فإذا كان الغسّاق هو ما وصفتُ من الشيء السائل فالواجب أن يقال: الذي وعد الله هؤلاء القوم، وأخبر أنهم يذوقونه في الآخرة من الشراب، هو السائل من الزمهرير في جهنم، الجامع مع شدة بَرده النَّتن». <q>﴿إِلَّا حَمِیمࣰا وَغَسَّاقࣰا ۝٢٥﴾</q> - آثار متعلقة بالآية ٨٠٩٧٣- عن أبي سعيد الخُدري، عن النبي ﷺ، قال: «لو أنّ دَلوًا من غسّاق يُهراق إلى الدنيا لأَنتن أهل الدنيا»{19}. (ز) ",footnotes:1:تقعقع: تضطرب وتتحرك. النهاية (قعقع).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٤/٣٣.أخرجه ابن جرير ٢٤/٣٠ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه هناد (٢٩٢)، وابن جرير ٢٤/٢٨، ٣١، وعنده في الموضع الأول عن الربيع. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٢٩.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٤٩ (٢٣٨٤)، وابن جرير ٢٤/٣٠ بنحوه.أخرجه ابن جرير ٢٤/٣١.أخرجه ابن جرير ٢٤/٣٠، ٣١ بطرق وألفاظ متعددة. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٢٨.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٧)-.أخرجه ابن جرير ٢٤/٢٨.أخرجه ابن جرير ٢٤/٢٩.أخرجه ابن جرير ٢٤/٢٨.أخرجه ابن جرير ٢٤/٣١.تفسير مقاتل بن سليمان ٤/٥٦٢.أخرجه ابن جرير ٢٤/٢٩.أخرجه ابن جرير ٢٤/٣٠.أخرجه أحمد ١٧/٣٣١ (١١٢٣٠)، ١٨/٣١٠ (١١٧٨٦)، والترمذي ٤/٥٤٠-٥٤١ (٢٧٦٦)، والحاكم ٤/٦٤٤ (٨٧٧٩)، وابن جرير ٢٠/١٣٠، ٢٤/٣١-٣٢، من طريق درّاج، عن أبي الهيثم، عن أبي سعيد الخُدري به. قال الترمذي: «هذا حديث إنما نعرفه من حديث رشدين بن سعد، وفي رشدين بن سعد مقال، وقد تُكلّم فيه من قِبل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص.
78,26," <q>﴿جَزَاۤءࣰ وِفَاقًا ۝٢٦﴾</q> - تفسير ٨٠٩٧٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿جَزاءً وِفاقًا﴾</q>، قال: وافق أعمالهم{1}. (١٥/٢٠٥) ٨٠٩٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿جَزاءً وِفاقًا﴾</q>، يقول: وافق الجزاء العمل{2}. (١٥/٢٠٥) ٨٠٩٧٦- قال الضَّحّاك بن مُزاحِم: <q>﴿جَزاءً وِفاقًا﴾</q> على قدْر أعمالهم{3}. (ز) ٨٠٩٧٧- قال الحسن البصري= (ز) ٨٠٩٧٨- وعكرمة مولى ابن عباس: <q>﴿جَزاءً وِفاقًا﴾</q> كانت أعمالهم سيئةً، فأثابهم الله بما يَسوؤهم{4}. (ز) ٨٠٩٧٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿جَزاءً وِفاقًا﴾</q>، قال: جزاء وافق أعمال القوم؛ أعمال السوء{5}. (١٥/٢٠٥) ٨٠٩٨٠- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿جَزاءً وِفاقًا﴾</q>، قال: ثواب وافق أعمالهم{6}. (ز) ٨٠٩٨١- قال مقاتل بن سليمان: <q>﴿جَزاءً وِفاقًا﴾</q> كما أنه ليس في الأعمال أخبث مِن الشّرك بالله ﷿، وكذلك ليس مِن العذاب شيء أخبث من النار، فوافقت النارُ الشّركَ{7}. (ز) ٨٠٩٨٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿جَزاءً وِفاقًا﴾</q>، قال: عَمِلوا شرًّا فجُزوا شرًّا، وعَملوا حسنًا فجُزوا حسنًا. ثم قرأ قول الله: <q>﴿ثُمَّ كانَ عاقِبَةَ الَّذِينَ أساءُوا السُّوأى﴾</q> [الروم:١٠]{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٣٣، وابن أبي حاتم -كما في الإتقان ٢/٥٢-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٩٥، وأخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٩-، وابن جرير ٢٤/٣٤. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ١٠/١١٧.تفسير الثعلبي ١٠/١١٧، وتفسير البغوي ١٠/١١٧.أخرجه عبد الرزاق ٢/٣٤٣ من طريق معمر، وابن جرير ٢٤/٣٣ بنحوه، كذلك من طريق معمر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٣٣.تفسير مقاتل بن سليمان ٤/٥٦٣.أخرجه ابن جرير ٢٤/٣٣.
78,27," <q>﴿إِنَّهُمۡ كَانُوا۟ لَا یَرۡجُونَ حِسَابࣰا ۝٢٧﴾</q> - تفسير ٨٠٩٨٣- عن سعيد بن جُبَير، في قوله: <q>﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</q>، قال: لا يَرجون ثوابًا، ولا يَخافون عقابًا{1}. (١٥/٢٠٥) ٨٠٩٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</q>، قال: لا يَخافونه. وفي لفظ: لا يُبالون فيُصَدِّقون بالبعْث{2}. (١٥/٢٠٥) ٨٠٩٨٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</q>: أي: لا يَخافون حسابًا{3}. (ز) ٨٠٩٨٦- قال مقاتل بن سليمان: ثم قال: <q>﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</q>، يعني: أنهم كانوا لا يَخافون مِن العذاب أن يُحاسبوا بأعمالهم الخبيثة إذا عَملوها{4}. (ز) ٨٠٩٨٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّهُمْ كانُوا لا يَرْجُونَ حِسابًا﴾</q>، قال: لا يؤمنون بالبعْث ولا بالحساب، وكيف يرجو الحساب مَن لا يُوقن أنه يحيا، ولا يُوقن بالبعْث. وقرأ قول الله: <q>﴿بَلْ قالُوا مِثْلَ ما قالَ الأَوَّلُونَ قالُوا أإذا مِتْنا وكُنّا تُرابًا﴾</q> إلى: <q>﴿أساطِيرُ الأَوَّلِينَ﴾</q> [المؤمنون:٨١-٨٣]. وقرأ: <q>﴿هَلْ نَدُلُّكُمْ عَلى رَجُلٍ يُنَبِّئُكُمْ إذا مُزِّقْتُمْ كُلَّ مُمَزَّقٍ﴾</q> إلى قوله: <q>﴿جَدِيد﴾</q> [سبأ:٧]. فقال بعضهم لبعض: ما له؟ <q>﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</q> [سبأ:٨]؟ الرجل مجنون حين يُخبِرنا بهذا؟{5}٦٩٩١. (ز) ٦٩٩١ ذكر ابنُ عطية (٨/٥٢١-٥٢١) القول بأنّ قوله: <q>﴿يرجون﴾</q> معناه: يَخافون، كما في آثار السلف، ثم ذكر قولًا آخر، فقال: «وقال غيره: الرجاء هنا على بابه، ولا رجاء إلا وهو مُقترن بخوف، ولا خوف إلا وهو مُقترن برجاء، فذكر أحد القسمين لأنّ المقصد العبارة عن تكذيبهم كأنه قال: إنهم كانوا لا يُصدِّقون بالحساب، فلذلك لا يَرجونه ولا يَخافونه». ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٩٥ بنحوه، وأخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٩-، وابن جرير ٢٤/٣٤. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٣٤.تفسير مقاتل بن سليمان ٤/٥٦٣.أخرجه ابن جرير ٢٤/٣٤-٣٥.
78,28," <q>﴿وَكَذَّبُوا۟ بِـَٔایَـٰتِنَا كِذَّابࣰا ۝٢٨﴾</q> - تفسير ٨٠٩٨٨- قال مقاتل بن سليمان: قال: <q>﴿وكَذَّبُوا بِآياتِنا﴾</q> يعني: القرآن <q>﴿كِذّابًا﴾</q> يعني: تكذيبًا بما فيه من الأمر والنهي{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٣.
78,29," <q>﴿وَكُلَّ شَیۡءٍ أَحۡصَیۡنَـٰهُ كِتَـٰبࣰا ۝٢٩﴾</q> - تفسير ٨٠٩٨٩- قال مقاتل بن سليمان: ثم رَجع إلى أعمالهم الخبيثة، فقال: <q>﴿وكُلَّ شَيْءٍ أحْصَيْناهُ﴾</q> من الأعمال <q>﴿كِتابًا﴾</q> يعني: ثَبّتناه مكتوبًا عندنا في كتاب حفيظ، يعني: اللوح المحفوظ، <q>﴿كِتابًا﴾</q> يعني: ما عَملوا من السيئات أثبتناه في اللوح المحفوظ. مثلها في يس [١٢]: <q>﴿وكُلَّ شَيْءٍ أحْصَيْناهُ فِي إمامٍ مُبِينٍ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٣.
78,30," <q>﴿فَذُوقُوا۟ فَلَن نَّزِیدَكُمۡ إِلَّا عَذَابًا ۝٣٠﴾</q> - تفسير ٨٠٩٩٠- عن جابر، عن النبي ﷺ أنه قال: «الزيادة خمسة أنهار من تحت العرش على رؤوس أهل النار؛ ثلاثة أنهار على مِقدار الليل، ونهران على مِقدار النهار، كقوله في النّحل [٨٨]: <q>﴿زِدْناهُمْ عَذابًا فَوْقَ العَذابِ بِما كانُوا يُفْسِدُونَ﴾</q>»{1}. (ز) ٨٠٩٩١- سئل أبو بَرزة الأَسلميّ -من طريق الحسن- عن أشدّ آية في كتاب الله. فقال: قول الله: <q>﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</q>، قال: فهو مِقدار ساعة بساعة، ويوم بيوم، وشهر بشهر، وسنة بسنة، أشدّ عذابًا، حتى لو أنّ رجلًا من أهل النار أُخرج من المشرق لمات أهل المغرب، ولو أُخرج من المغرب لمات أهل المشرق؛ من نَتن ريحه. قال أبو بَرزة: شهدتُ رسول الله ﷺ حين تلاها، فقال: «هَلك القوم بمعاصيهم ربّهم، وغَضب عليهم، فأبى إذ غَضب عليهم إلا أن يَنتقم منهم»{2}. (١٥/٢٠٦) ٨٠٩٩٢- عن الحسن بن دينار، قال: سألتُ أبا بَرزة الأَسلميّ عن أشدّ آية في كتاب الله على أهل النار. فقال: قول الله: <q>﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</q>{3}. (١٥/٢٠٦) ٨٠٩٩٣- عن عبد الله بن عمرو -من طريق أبي أيوب الأزدي- قال: ما أُنزِلَتْ على أهل النار آية قطّ أشدّ منها: <q>﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</q>، فهم في مزيد مِن عذاب الله أبدًا{4}. (١٥/٢٠٦) ٨٠٩٩٤- عن الحسين بن واقد، قال: سمعت علي بن الحسين يقول: أشد آية على أهل النار <q>﴿فذوقوا فلن نزيدكم إلا عذابا﴾</q>{5}. (ز) ٨٠٩٩٥- عن قتادة بن دعامة -من طريق خُليد بن دَعلج- قال: ما زال أهل النار يَأملون الخروج لقول الله: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q> حتى نزلت: <q>﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</q> فهم في مزيد أبدًا{6}. (ز) ٨٠٩٩٦- قال مقاتل بن سليمان: ثم رَجع إلى أهل النار الذين قال فيهم: <q>﴿لابِثِينَ فِيها أحْقابًا﴾</q>، فذَكر أنّ الخَزنة تقول لهم: <q>﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إلّا عَذابًا﴾</q> بعد هذه السنين، فأمّا الزيادة فالأنهار، أمّا «الآن» الذي ذكره الله ﷿ في «الرحمن» فليس له مُنتهى{7}. (ز) ",footnotes:1:أخرجه مقاتل بن سليمان في تفسيره ٤/٥٦٤، من طريق أبي الزُّبير، عن جابر به. وفي سنده مقاتل بن سليمان، وهو متروك الحديث. الميزان ٤/١٧٣.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤٠-٤٤١ (١٨٦)-، والبيهقي في البعث والنشور ص٣١٨(٥٧٩) مختصرًا، من طريق جعفر بن جسر بن فرقد، عن أبيه، عن أبي برزة به. وعزاه السيوطي إلى ابن مردويه. إسناده ضعيف جدًّا؛ فيه جسر بن فرقد، وهو أبوجعفر القصاب، قال البخاري: «ليس بذاك عندهم». وقال ابن معين: «ليس بشيء». وقال النسائي: «ضعيف». كما في لسان الميزان لابن حجر ٢/١٠٤. وقال ابنُ كثير ١٤/٢٣٤ بعد ذكر هذا الأثر: «جسر بن فرقد: ضعيف الحديث بالكلية». وفيه أيضًا ابنه جعفر بن جسر، قال العقيلي: «في حفظه اضطراب شديد، كان يذهب إلى القدر، وحدّث بمناكير». كما في لسان الميزان لابن حجر ٢/٤٤٦.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣١، وفتح الباري ٦/٣٣٣، مرفوعًا-، والطبراني -كما في مجمع الزوائد ٧/١٣٣-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن مردويه. قال ابن كثير: «جسر بن فرقد ضعيف الحديث بالكلية». وقال الهيثمي: «فيه شعيب بن بيان، وهو ضعيف».أخرجه ابن جرير ٢٤/٣٦ بنحوه، ومن طريق قتادة أيضًا. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٤-٨٥-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن مردويه.أخرجه الواحدي مطولًا في أسباب النزول ص ١٠٦.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٥-٤٢٦ (١٢٠)-، وابن جرير ٢٤/٣٦ من طريق سعيد مقتصرًا على آخره.تفسير مقاتل بن سليمان ٤/٥٦٣. يشير إلى قوله تعالى: <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q> [الرحمن:٤٤].
