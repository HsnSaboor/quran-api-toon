quran[7]{c,v,t}:
  29,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا كَانَ جَوَابَ قَوۡمِهِۦۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فما كان جواب قومه﴾</span>، قال: قوم إبراهيم{1}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> ثم ذكر إبراهيم ﵇ في التقديم، قال: <span class="qpc-hafs">﴿فما كان جواب قومه﴾</span>، يعني: قوم إبراهيم ﵇، حين دعاهم إلى الله ﷿، ونهاهم عن عبادة الأصنام {2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فما كان جواب قومه﴾</span> قوم إبراهيم <span class="qpc-hafs">﴿إلا أن قالوا اقتلوه أو حرقوه﴾</span> يقوله بعضهم لبعض{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّاۤ أَن قَالُوا۟ ٱقۡتُلُوهُ أَوۡ حَرِّقُوهُ فَأَنجَىٰهُ ٱللَّهُ مِنَ ٱلنَّارِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٥٩<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فأنجاه الله من النار﴾</span>، قال: ما أحْرَقَتِ النارُ منه إلا وثاقَه{4}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> قوله: <span class="qpc-hafs">﴿إلا أن قالوا اقتلوه أو حرقوه﴾</span> بالنار، فقذفوه في النار، <span class="qpc-hafs">﴿فأنجاه الله من النار﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> قوله: <span class="qpc-hafs">﴿إن في ذلك لآياتٍ﴾</span> يعني ﷿: إنّ في النار التي لم تُحْرِق إبراهيمَ ﵇ لَعِبرةً <span class="qpc-hafs">﴿لقومٍ يؤمنون﴾</span> يعني: يُصَدِّقون بتوحيد الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يؤمنون﴾</span>، أي: فيما صنع الله بإبراهيم وما نجاه من النار، وإنما يعتبر المؤمنون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٨١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وورد في المطبوع من تفسير ابن أبي حاتم ٩/٣٠٤٧ عن قتادة، من طريق سعيد: <span class="qpc-hafs">﴿فما كان جواب قومه﴾</span> قوم لوط ﷺ. وهذا تفسير الآية التي تشبه هذه الآية في سورة النمل [٥٦].تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٥.أخرجه ابن جرير ١٨/٣٨١، وابن أبي حاتم ٩/٣٠٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٥.
  29,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ إِنَّمَا ٱتَّخَذۡتُم مِّن دُونِ ٱللَّهِ أَوۡثَـٰنࣰا مَّوَدَّةَ بَیۡنِكُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ ثُمَّ یَوۡمَ ٱلۡقِیَـٰمَةِ یَكۡفُرُ بَعۡضُكُم بِبَعۡضࣲ وَیَلۡعَنُ بَعۡضُكُم بَعۡضࣰا وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٢٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٦٣<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (إنَّما مَوَدَّةُ بَيْنِكُمْ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ إِنَّمَا ٱتَّخَذۡتُم مِّن دُونِ ٱللَّهِ أَوۡثَـٰنࣰا مَّوَدَّةَ بَیۡنِكُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان بن عبد الرحمن- في قوله: <span class="qpc-hafs">﴿وقال إنما اتخذتم من دون الله أوثانا مودة بينكم في الحياة الدنيا﴾</span>، قال: اتخذوها لثوابها في الحياة الدنيا{2}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال﴾</span> لهم إبراهيم ﵇: <span class="qpc-hafs">﴿إنما اتخذتم﴾</span> الأوثان آلهة <span class="qpc-hafs">﴿من دون الله﴾</span> ﷿ <span class="qpc-hafs">﴿أوثانًا مودة بينكم في الحياة الدنيا﴾</span> يعني: بين الأتباع والقادة؛ مودة على عبادة الأصنام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقال﴾</span> إبراهيم: <span class="qpc-hafs">﴿إنما اتخذتم من دون الله أوثانا مودة بينكم﴾</span> يوادُّ بعضكم بعضًا، أي: يُحِبُّ بعضكم بعضًا على عبادة الأوثان <span class="qpc-hafs">﴿في الحياة الدنيا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ یَوۡمَ ٱلۡقِیَـٰمَةِ یَكۡفُرُ بَعۡضُكُم بِبَعۡضࣲ وَیَلۡعَنُ بَعۡضُكُم بَعۡضࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ثم يوم القيامة يكفر بعضكم ببعض ويلعن بعضكم بعضا﴾</span>، قال: صارت كلُّ خلَّةٍ في الدنيا عداوةً على أهلها يوم القيامة، إلا خلة المتقين{5}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٦٨<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: يتبرأ بعضكم من بعض{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم﴾</span> إذا كان <span class="qpc-hafs">﴿يوم القيامة يكفر بعضكم ببعضٍ﴾</span> يقول: تَتَبَرَّأ القادةُ من الأتباع، <span class="qpc-hafs">﴿ويلعن بعضكم بعضًا﴾</span> يقول: ويلعن الأتباعُ القادةَ؛ مِن الأمم الخالية وهذه الأمة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ثم يوم القيامة يكفر بعضكم ببعض﴾</span>، أي: بِوِلاية بعض{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال لهم إبراهيم ﵇: <span class="qpc-hafs">﴿ومأواكم النار﴾</span> يعني: مصيركم إلى النار، <span class="qpc-hafs">﴿وما لكم من ناصرين﴾</span> يعني: مانعين مِن العذاب يمنعونكم منه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٨.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١١٦.أخرجه ابن أبي حاتم ٩/٣٠٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ٢/٦٢٦.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٦.تفسير مقاتل بن سليمان ٣/٣٧٩.
  29,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَـَٔامَنَ لَهُۥ لُوطࣱۘ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿فآمن له لوط﴾</span>، قال: صدَّق لوطٌ إبراهيمَ{1}. (١١/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- وفي قوله: <span class="qpc-hafs">﴿فآمن له لوط﴾</span>، قال: فصدَّقة لوط{2}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فآمن له لوطٌ﴾</span>، يعني: فصدق بإبراهيمَ لوطٌ ﵉، وهو أولُ مَن صدَّق بإبراهيم حين رأى إبراهيم لم تَضُرَّه النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فآمن له لوط﴾</span>، قال: صدَّقه لوط، صدَّق إبراهيم، قال: أرأيت المؤمنين، أليس آمنوا لرسول الله ﷺ ما جاء به؟ قال: فالإيمان: التصديق. وقال ابن زيد في حديث الذئب الذي كلَّم الرجل، فأخبر به النبي ﷺ، فقال رسول الله ﷺ: «<b>فآمنتُ له أنا، وأبو بكر، وعمر</b>». وليس أبو بكر ولا عمر معه. يعني «<b>آمنتُ له</b>»: صدَّقتُه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فآمن له لوط﴾</span>، أي: فصدَّقه لوط{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ إِنِّی مُهَاجِرٌ إِلَىٰ رَبِّیۤۖ إِنَّهُۥ هُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٧٧<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق مسلمة بن عبد الله- في قوله: <span class="qpc-hafs">﴿وقال إني مهاجر إلى ربي﴾</span>، قال: إلى حرّان{6}. (١١/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وقال إني مهاجر إلى ربي﴾</span>، قال: هو إبراهيم ﵇ القائل: <span class="qpc-hafs">﴿إني مهاجر إلى ربي﴾</span>{7}. (١١/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خليد بن دعلج- في قوله: <span class="qpc-hafs">﴿وقال إني مهاجر إلى ربي﴾</span>، قال: إلى الشام كان مهاجره{8}. (١١/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقال إني مهاجر إلى ربي﴾</span>، قال: هاجرا جميعًا من كُوثى، وهي من سواد الكوفة، إلى الشام{9}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال﴾</span> إبراهيم ﵇: <span class="qpc-hafs">﴿إني مهاجرٌ إلى ربي﴾</span> يعني: هجر قومَه المشركين من أرض كوثى هو ولوط وسارة أخت لوط ﵈ إلى الأرض المقدسة، <span class="qpc-hafs">﴿إلى ربي﴾</span> يعني: إلى رضا ربي. وقال في الصافات [٩٩]: <span class="qpc-hafs">﴿إنى ذاهبٌ إلى ربي﴾</span> يعني: إلى رضا ربي <span class="qpc-hafs">﴿سيهدين﴾</span>. فهاجر وهو ابن خمس وسبعين سنة، <span class="qpc-hafs">﴿إنه هو العزيز الحكيم﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿فآمن له لوط وقال إني مهاجر إلى ربي﴾</span>، قال: إلى حرّان، ثم أُمِر بعدُ بالشامِ الذي هاجر إبراهيم، وهو أول من هاجر، يقول: <span class="qpc-hafs">﴿فآمن له لوط وقال إني مهاجر﴾</span> الآية{11}. (١١/٥٤١) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إني مهاجر إلى ربي﴾</span>، قال: كانت هجرتُه إلى الشام{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقال إني مهاجر إلى ربي﴾</span> يقوله إبراهيم، هاجر مِن أرض العراق إلى أرض الشام{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ إِنِّی مُهَاجِرٌ إِلَىٰ رَبِّیۤۖ إِنَّهُۥ هُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٢٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٨٥<span class="dash">-</span></span> عن زيد بن ثابت، قال: قال رسول الله ﷺ: «<b>ما كان بين عثمان ورُقَيَّة؛ وبين لوط مِن مهاجِر</b>{5}»{15}. (١١/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٦<span class="dash">-</span></span> عن عبد الله بن عمر، أنّ النبي ﷺ قال: «<b>سيهاجر خيار أهل الأرض هجرةً بعد هجرةٍ إلى مهاجَر إبراهيم ﵇</b>»{16}. (١١/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٧<span class="dash">-</span></span> عن أنس بن مالك، قال: أوَّلُ مَن هاجر من المسلمين إلى الحبشة بأهله عثمان بن عفان، فقال النبي ﷺ: «<b>صحبهما الله، إنّ عثمان لَأَوَّلُ مَن هاجر إلى الله بأهله بعد لوط</b>»{17}. (١١/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٨<span class="dash">-</span></span> عن أسماء بنت أبي بكر، قالت: هاجر عثمانُ إلى الحبشة، فقال النبي ﷺ: «<b>إنّه لَأَوَّلُ مَن هاجر بعد إبراهيم ولوط</b>»{18}. (١١/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: أول من هاجر إلى رسول الله ﷺ عثمانُ بن عفان، كما هاجر لوطٌ إلى إبراهيم{19}. (١١/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٩٠<span class="dash">-</span></span> قال قتادة: وذُكِر لنا: أنّ نبي الله ﷺ قال: «<b>إنها ستكون هجرة بعد هجرة، ينحاز أهل الأرض إلى مهاجَر إبراهيم، ويبقى في الأرض شرار أهلها، حتى تلفظَهم وتَقْذَرَهُم، وتحشرهم النارُ مع القردة والخنازير</b>»{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٩١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثم إنّ نمرود كفَّ عن إبراهيم، ومنعه الله منه، واستجاب لإبراهيم رجالٌ مِن قومه حيث رأوا ما صنع اللهُ -تبارك وتعالى- به على خوفٍ من نمرود [و]ملئهم، فآمن له لوط، وكان ابنَ أخيه، وآمنت به سارةُ، وكانت بنتَ عمه، ثم خرج إبراهيم ﵇ مهاجرًا إلى ربه، وخرج معه لوط مهاجرًا، وتزوج سارةَ بنت عمه، فخرج بها يلتمس الفرار بدينه والأمانة على ربه، حتى نزل حرّان، فمكث بها ما شاء الله أن يمكث، ثم خرج منها مهاجرًا حتى قدم مصر، وبها فرعون من الفراعنة الأولى، وكانت سارةُ مِن أحسن الناس فيما يُقال، وكانت لا تعصي إبراهيمَ شيئًا، ولذلك أكرمها الله{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن حسان الكناني</span> -من طريق الوليد بن مسلم- قال: هاجر لوط -وهو ابن أخي إبراهيم- بامرأته إلى إبراهيم بالشام، وكان بين امرأته وبين سارة بعضُ ما يكون بين النساء، فقال له إبراهيم: يا ابن أخي، قد جرى بين هاتين، وأنا أتخوَّف أن يُحْدِث ذلك في قلبي عليك، فتحول. فتحوَّلا، قال: فنزل بمدائن قوم لوط{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٩.أخرجه ابن جرير ١٨/٣٨٤-٣٨٥.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه ابن أبي حاتم ٩/٣٠٥٠.أخرجه إسحاق البستي في تفسيره ص٦٩، وابن جرير ١٨/٣٨٥، وابن أبي حاتم ٩/٣٠٥٠ من طريق جويبر.أخرجه ابن عساكر ١/١٦٣.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠ من طريق شيبان بن عبد الرحمن. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٩.أخرجه ابن جرير ١٨/٣٨٥. وعزا السيوطي أوله إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٨٤.تفسير يحيى بن سلّام ٢/٦٢٦.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه الدولابي في الكنى والأسماء ٢/٧٤١ (١٢٨٤)، والطبراني في الكبير ٥/١٣٩ (٤٨٨١).</p><p>قال الهيثمي في المجمع ٩/٨١ (١٤٤٩٩): «رواه الطبراني، وفيه عثمان بن خالد العثماني، وهو متروك». وقال المناوي في فيض القدير ٥/٤٦٢ (٧٩٦٥): «رمز المصنف -السيوطي- لحسنه». وقال الألباني في الضعيفة ٩/٤٥٢ (٤٤٦٤): «موضوع».أخرجه أحمد ٩/٣٩٥-٣٩٦ (٥٥٦٢)، وابن عساكر في تاريخ دمشق ١/١٦٣ واللفظ له.</p><p>قال ابن كثير في تفسيره ٦/٢٧٤: «غريب من حديث نافع. والظاهر أن الأوزاعي قد رواه عن شيخ له من الضعفاء، والله أعلم. وروايته من حديث عبد الله بن عمرو بن العاص أقرب إلى الحفظ». وقال الهيثمي في المجمع ٥/٢٥١ (٩٢٨٥): «رواه أحمد في حديث طويل في قتال أهل البغي، وفيه أبو جناب الكلبي، وهو ضعيف». وقال ابن حجر في فتح الباري ١١/٣٨٠: «أخرجه أحمد، وسنده لا بأس به». وقال الألباني في الصحيحة ٧/٦١٣-٦١٤: «وهذا إسناد رجاله ثقات رجال البخاري، فهو صحيح؛ لولا الواسطة بين الأوزاعي ونافع فإنه لم يسم، مع أن رواية الأوزاعي عن نافع ثابتة في صحيح البخاري. وعلى كل حال فهو شاهد صالح، وبه يرتقي الحديث إلى مرتبة الصحة».أخرجه ابن أبي عاصم في كتاب السنة ٢/٥٩٦ (١٣١١)، والطبراني في الكبير ١/٩٠ (١٤٣).أخرجه ابن عساكر في تاريخ دمشق ٣/١٥٠، ٣٩/٣٠-٣١، وابن منده -كما في الإصابة ٨/١٣٨-١٣٩-.</p><p>قال ابن حجر: «بسند واهٍ».أخرجه ابن عساكر ٣٩/٣٠، ٥٠/٣٠٨.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠-٣٠٥١ (١٧٢٤٩).أخرجه ابن أبي حاتم ٩/٣٠٥٠-٣٠٥١.أخرجه ابن أبي حاتم ٩/٣٠٥١.
  29,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَهَبۡنَا لَهُۥۤ إِسۡحَـٰقَ وَیَعۡقُوبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ووهبنا له إسحاق ويعقوب﴾</span>، قال: هما ولدا إبراهيم{1}<span class=comment-ref>٥٠٣٧</span>. (١١/٥٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٣٧</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١٠/٥٠٧) على قول ابن عباس، فقال: «فأما ما رواه العوفي عن ابن عباس في قوله: <span class="qpc-hafs">﴿ووهبنا له إسحاق ويعقوب نافلة﴾</span>، قال: هما ولدا إبراهيم. فمعناه: أنّ ولد الولد بمنزلة الولد، فإنّ هذا أمر لايكاد يخفى على من هو دون ابن عباس».</div></p><p><div></p><p><p><span class="item-no">٥٩٧٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿ووهبنا له إسحاق ويعقوب﴾</span>، قال: أعطينا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ووهبنا له﴾</span> يعني: لإبراهيم <span class="qpc-hafs">﴿إسحاق ويعقوب﴾</span> ابن إسحاق بالأرض المقدسة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا فِی ذُرِّیَّتِهِ ٱلنُّبُوَّةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلنا في ذريته﴾</span> يعني: ذرية إبراهيم <span class="qpc-hafs">﴿النبوة﴾</span> يعني: إسماعيل، وإسحاق، ويعقوب ﵈{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٧٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قوله: <span class="qpc-hafs">﴿الكتاب﴾</span>، قال: الخطُّ بالقلم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والكتاب﴾</span>، يعني: صحف إبراهيم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٧٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والكتاب﴾</span>، فكان أول كتاب أُنزل بَعْدُ كتابُ موسى وما بعده من الكتب{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَیۡنَـٰهُ أَجۡرَهُۥ فِی ٱلدُّنۡیَاۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٠٠<span class="dash">-</span></span> عن عبيد، قال: سمعت الضحاك يقول: <span class="qpc-hafs">﴿آتَيْناهُ أجْرَهُ فِي الدُّنْيا﴾</span> في حرف <span class="name-1">ابن مسعود</span>: (آتَيْناهُ فِي الدُّنْيا حَسَنَةً وإنَّهُ فِي الآخِرَةِ لَمِنَ الصّالِحِينَ){8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَیۡنَـٰهُ أَجۡرَهُۥ فِی ٱلدُّنۡیَاۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: الذِّكْرُ الحَسَنُ{9}. (١١/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مندل عمَّن ذكره- <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: الولد الصالح، والثَّناء{10}. (١١/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿أجره في الدنيا﴾</span>، قال: إنّ الله -تبارك وتعالى- رضي لأهل الأديان بدينهم، فليس أهلُ دين إلا وهم يَتَوَلَّوْنَ إبراهيمَ ويَرْضَوْنَ عنه{11}. (١١/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: الثناء{12}. (١١/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٥<span class="dash">-</span></span> عن سفيان الثوري، قال: بلغني عن <span class="name-2">مجاهد</span> في قول الله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: <span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span> [الصافات:٧٨]، قال: الثناء الصالح{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٦<span class="dash">-</span></span> عن ليث، قال: أرسل مجاهد رجلًا إلى <span class="name-2">عكرمة مولى ابن عباس</span> يسأله عن قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا وإنه في الآخرة لمن الصالحين﴾</span>. قال: فقال: أجره في الدنيا أنّ كُلَّ مِلَّة تَتَوَلّاه، وهو عند الله من الصالحين. قال: فرجع إلى <span class="name-2">مجاهد</span>، فقال: أصاب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: لسان الصِّدق الذي جعل له{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٨<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج-: إبراهيمُ تَوَلّاهُ الأُمَمُ كلُّها؛ اليهود والنصارى والمجوس والناس أجمعون، وشهدوا له بالعدل، فذلك اللسان الصدق، وهو الأجر الذي آتيناه في الدنيا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٠٩<span class="dash">-</span></span> عن ابن عيينة: أنّ <span class="name-2">عكرمة مولى ابن عباس</span> سُئِل عن قوله تعالى: <span class="qpc-hafs">﴿وأتيناه أجره في الدنيا﴾</span>. قال: لقد غُصْتَ عليه في بحرٍ عميق، فمَن أنت؟ قال: سعيد بن جبير. قال: لقد علمت. ثم قال: أبقى له ثناء حسنًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن حسين- في قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: نيته الصالحة التي اكتسب بها الأجرَ في الآخرة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- وفي قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: عافية، وعملًا صالحًا، وثناء حسنًا، فلستَ تلاقي أحدًا مِن أهل الملل إلا يَرضى إبراهيمَ ويتولّاه{19}. (١١/٥٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، قال: هي كقوله: <span class="qpc-hafs">﴿وآتيناه في الدنيا حسنة﴾</span> [النحل:١٢٢]. قال: وقال: ليس من أهل دين إلا وهم يتولونه{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>: هو الولد الصالح{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وكَذَلِكَ نُرِي إبْراهِيمَ مَلَكُوتَ السَّماواتِ والأَرْضِ ولِيَكُونَ مِنَ المُوقِنِينَ﴾</span> [الأنعام:٧٥]، قال: أُقِيم على صخرة، وفُتِحَت له السموات، فنظر إلى مُلْكِ الله فيها، حتى نظر إلى مكانه في الجنة، وفُتِحَت له الأرضون حتى نظر إلى أسفل الأرض، فذلك قوله: <span class="qpc-hafs">﴿وآتيناه أجره في الدنيا﴾</span>، يقول: آتيناه مكانه في الجنة. ويقال: <span class="qpc-hafs">﴿أجره﴾</span>: الثناء الحسن{22}. (٦/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٥<span class="dash">-</span></span> عن <span class="name-2">زياد بن أبي مريم</span> -من طريق خُصيف- في قوله: <span class="qpc-hafs">﴿آتيناه﴾</span>، قال: أعطيناه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتيناه أجره﴾</span> يعني: أعطيناه جزاءَه <span class="qpc-hafs">﴿في الدنيا﴾</span> يعني: الثناء الحسن والمقالة الحسنة مِن أهل الأديان كلها؛ لِمُضِيِّه على رضوان الله حين أُلْقِي في النار، وكَسَر الأصنام، ومُضِيّه على ذبح ابنه، فجميع أهل الأديان يقولون: إبراهيم مِنّا. لا يَتَبَرَّأُ منه أحدٌ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٧<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وآتيناه أجره﴾</span>، قال: أعطيناه أجره <span class="qpc-hafs">﴿في الدنيا﴾</span>، فليس من أهل دين إلا وهم يتولونه ويحبونه، وهو مثلُ قوله: <span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span> [الصافات:٧٨]، أي: أبقينا عليه في الآخرين الثناءَ الحسن{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ فِی ٱلۡـَٔاخِرَةِ لَمِنَ ٱلصَّـٰلِحِینَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨١٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وإنه في الآخرة لمن الصالحين﴾</span>: مثل آدم، ونوح{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وإنه في الآخرة لمن الصالحين﴾</span>، قال: وهو عند الله من الصالحين{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنه﴾</span> يعني: إبراهيم <span class="qpc-hafs">﴿في الآخرة لمن الصالحين﴾</span>، نظيرها في النحل{28}{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- يقول: <span class="qpc-hafs">﴿من الصالحين﴾</span>، قال: <span class="qpc-hafs">﴿الصالحين﴾</span>: الأنبياء، والمؤمنون{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإنه في الآخرة لمن الصالحين﴾</span>، قال: لَمِن أهل الجنة{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٨٦، وابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٥١.تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير مقاتل بن سليمان ٣/٣٨٠.أخرجه ابن أبي حاتم ٩/٣٠٥٢، وأورده في تفسير قوله تعالى: <span class="qpc-hafs">﴿ويُعَلِّمُهُمُ الكِتابَ والحِكْمَةَ ويُزَكِّيهِمْ﴾</span> [البقرة:١٢٩]، ونحوها من الآيات، وفي تفسير قوله تعالى: <span class="qpc-hafs">﴿ويُعَلِّمُهُ الكِتابَ والحِكْمَةَ والتَّوْراةَ والإنْجِيلَ﴾</span> [آل عمران:٤٨].تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه إسحاق البستي في تفسيره ص٦٩.</p><p>وقراءة ابن مسعود شاذة.أخرجه ابن جرير ١٨/٣٨٧، وابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٨٧.أخرجه ابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى ابن جرير، وابن المنذر. وجاء عند ابن جرير موقوفًا على عكرمة كما سيأتي.أخرجه يحيى بن سلّام ٢/٦٢٦، وابن جرير ١٨/٣٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن وهب في الجامع ١/٨٩ (٢٠٢).أخرجه ابن جرير ١٨/٣٨٦.أخرجه ابن أبي حاتم ٩/٣٠٥٢.أخرجه ابن أبي حاتم ٩/٣٠٥٣.أخرجه ابن أبي الدنيا في كتاب مكارم الأخلاق -موسوعة الإمام ابن أبي الدنيا ٣/٤٣٢ (١٨)-.أخرجه ابن أبي حاتم ٩/٣٠٥٣.أخرجه ابن جرير ١٨/٣٨٧، وابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق في تفسيره ٢/٩٦.تفسير البغوي ٦/٢٣٩.أخرجه ابن جرير ٩/٣٤٩، وابن أبي حاتم ٤/١٣٢٦، وأخرجه سعيد بن منصور (٨٣٣-تفسير) من طريق الحكم بن ظُهير. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٥٢.تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير يحيى بن سلّام ٢/٦٢٦.تفسير البغوي ٦/٢٣٩.أخرجه ابن جرير ١٨/٣٨٦.يشير إلى قوله تعالى: <span class="qpc-hafs">﴿وآتيناه في الدنيا حسنة وإنه في الآخرة لمن الصالحين﴾</span> [النحل:١٢٢].تفسير مقاتل بن سليمان ٣/٣٨٠.أخرجه ابن أبي حاتم ٩/٣٠٥٣.تفسير يحيى بن سلّام ٢/٦٢٦.
  29,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلُوطًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولوطا﴾</span>، أي: وأرسلنا لوطًا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَ لِقَوۡمِهِۦۤ إِنَّكُمۡ لَتَأۡتُونَ ٱلۡفَـٰحِشَةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٢٤<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: وهي إتيانُ الرجالِ في أدبارهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿ولوطًا إذ قال لقومه إنكم لتأتون الفاحشة﴾</span>: يعني: المعصية، يعني: إتيان الرجال في أدبارهم ليلًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إذ قال لقومه إنكم لتأتون الفاحشة﴾</span>، والفاحشة: المعصية{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا سَبَقَكُم بِهَا مِنۡ أَحَدࣲ مِّنَ ٱلۡعَـٰلَمِینَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٢٧<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنكم لتأتون الفاحشة ما سبقكم بها من أحد من العالمين﴾</span>، قال: ما نَزا ذَكَرٌ على ذَكَرٍ حتى كان قومُ لوط{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿ما سبقكم بها من أحدٍ من العالمين﴾</span>: فيما مضى قبلكم، وكانوا لا يأتون إلا الغرباء{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ٢/٦٢٧.علقه يحيى بن سلّام ٢/٦٢٧.تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير يحيى بن سلّام ٢/٦٢٧.أخرجه ابن جرير ١٨/٣٨٨، وابن أبي حاتم ٩/٣٠٥٤ بذكر الآية ٨٠ من سورة الأعراف: <span class="qpc-hafs">﴿ولُوطًا إذْ قالَ لِقَوْمِهِ أتَأْتُونَ الفاحِشَةَ ما سَبَقَكُم بِها مِن أحَدٍ مِّن العالَمِينَ﴾</span>.تفسير مقاتل بن سليمان ٣/٣٨٠.
  29,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَىِٕنَّكُمۡ لَتَأۡتُونَ ٱلرِّجَالَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أئنكم لتأتون الرجال﴾</span> في أدبارهم، وهذا على الاستفهام، أي: إنكم تفعلون ذلك{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَقۡطَعُونَ ٱلسَّبِیلَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿أئنكم لتأتون الرجال وتقطعون السبيل﴾</span>: يعني: المسافر، وذلك أنهم إذا جلسوا في ناديهم -يعني: في مجالسهم- رَمَوُا ابنَ السبيل بالحجارة والخذف{2}، فيقطعون سبيل المسافر، فذلك قوله ﷿: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، يعني: في مجالسكم المنكر، يعني: الخذف بالحجارة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وتقطعون السبيل﴾</span>، قال: الطريق؛ اذا مر بهم المسافرُ -وهو ابن السبيل- قطعوا به، وعملوا به ذلك العمل الخبيث{4}. (١١/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وتقطعون السبيل﴾</span> على الغرباء، فتأتونهم في أدبارهم، وكانوا لا يفعلون ذلك إلا بالغرباء، وكانوا يتعرضون الطرق، ويأخذون الغرباء، ولا يفعله بعضهم ببعض{1}<span class=comment-ref>٥٠٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٣٨</span> نقل <u>ابنُ عطية</u> (٦/٦٤٠) في معنى الآية <b>أقوالًا</b> أخرى قائلًا: «فقالت فرقة: كان قطع الطريق بالسلْب فاشيًا فيهم... وقالت فرقة: بل أراد قَطْعَ سبيل النسل في ترك النساء وإتيان الرجال. وقالت فرقة: أراد أنهم بفَتْح الأُحدوثة عنهم يقطعون سبل الناس عن قصدهم في التجارات وغيرها».</div></p><p><h3><span class="qpc-hafs">﴿وَتَأۡتُونَ فِی نَادِیكُمُ ٱلۡمُنكَرَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٣٣<span class="dash">-</span></span> عن أبي صالح مولى أم هانئ، عن أم هانئ بنت أبي طالب، قالت: سألتُ رسولَ الله ﷺ عن قول الله تعالى: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>. قال: «<b>كانوا يجلسون بالطريق، فَيَخْذِفون أبناء السبيل، ويسخرون منهم</b>»{6}. (١١/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٤<span class="dash">-</span></span> عن معاوية، قال: قال رسول الله ﷺ: «<b>إنّ قوم لوط كانوا يجلسون في مجالسهم وعند كل رجل منهم قصعة فيها حصى، فإذا مرَّ بهم عابرُ سبيل حذفوه، فأيهم أصابه كان أولى به</b>». وذلك قول الله سبحانه: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٥<span class="dash">-</span></span> عن جابر بن عبد الله: أنّ النبي ﷺ نهى عن الخَذْف، وهو قول الله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>{8}. (١١/٥٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن سلام</span>، في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: كان يبزُق بعضُهم على بعض{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٧<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة بن الزبير- في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قالت: الضراط{10}. (١١/٥٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: في مجالسكم{11}. (١١/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: الخذف{12}. (١١/٥٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: الخذف. فقال رجل: وما لو قلت هكذا؟! فأخذ ابن عمر كفًّا مِن حَصْباء، فضرب به وجهه، وقال: في حديث رسول الله ﷺ تأخذ بالمعاريض!{8}. (١١/٥٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور بن المعتمر- في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: كان يُجامِع بعضُهم بعضًا في المجالس{14}. (١١/٥٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحكم- في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: الصفير، ولعب الحمام، والجَلاهق{15}، وحَلُّ أزْرارِ القَباء{16}{17}. (١١/٥٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمر بن أبي زائدة- <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: كانوا يُؤذون أهلَ الطريق، ويخذفون الناس{18}. (١١/٥٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٤<span class="dash">-</span></span> عن <span class="name-2">القاسم بن محمد بن أبي بكر الصديق</span> -من طريق يزيد بن بكر- أنّه سُئِل عن قول الله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، ماذا كان المنكر الذي كانوا يأتون؟ قال: كانوا يتضارطون في مجالسهم، يضرط بعضهم على بعض، والنادي هو المجلس{19}. (١١/٥٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٥<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span> -من طريق سليمان بن ظريف- قال: كان مِن أخلاق قوم لوط مَضْغُ العلك، وتطريف الأصابع بالحناء، وحل الإزار، والصفير، والحَذْف، واللوطية{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: كانوا يعملون الفاحشة في مجالسهم{21}. (١١/٥٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: كل مَن مَرَّ بهم حذفوه، فهو المنكر{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أئنكم لتأتون الرجال وتقطعون السبيل﴾</span> يعني: المسافر، وذلك أنهم إذا جلسوا في ناديهم -يعني: في مجالسهم- رَمَوُا ابنَ السبيل بالحجارة والخذف، فيقطعون سبيل المسافر، فذلك قوله ﷿: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span> يعني: في مجالسكم المنكر، يعني: الخذف بالحجارة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span>، قال: ناديهم: المجالس. والمنكر: عملهم الخبيث الذي كانوا يعملونه؛ كانوا يعترضون بالراكب، فيأخذونه ويركبونه. وقرأ: <span class="qpc-hafs">﴿أتأتون الفاحشة وأنتم تبصرون﴾</span> [النمل:٥٤]، وقرأ: <span class="qpc-hafs">﴿ما سبقكم بها من أحد من العالمين﴾</span>{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وتأتون في ناديكم المنكر﴾</span> في مجمعكم، والمنكر: الفاحشة، يعني: فعلهم ذلك{1}<span class=comment-ref>٥٠٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٣٩</span> اختلف في المنكر الذي عناه الله في الآية على أقوال: <b>الأول</b>: أنه الضّراط. <b>الثاني</b>: أنهم كانوا يحذفون مَن مَرَّ بهم. <b>الثالث</b>: أنه إتيان الفاحشة في المجالس. <b>الرابع:</b> الصفير، ولعب الحمام، وتطريف الأصابع بالحناء، ونبذ الحياء.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٦٤١) على القول الرابع بقوله: «وقد توجد هذه الأشياء في بعض عصاة أمة محمد ﷺ، فالتناهي واجب».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٨/٣٩٢) <span class="mustanad">مستندًا إلى السنة</span> القول الثاني، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: معناه: وتحذفون في مجالسكم المارَّةَ بكم، وتسخرون منهم؛ لما ذكرنا من الرواية بذلك عن رسول الله ﷺ».</div></p><p><h3><span class="qpc-hafs">﴿فَمَا كَانَ جَوَابَ قَوۡمِهِۦۤ إِلَّاۤ أَن قَالُوا۟ ٱئۡتِنَا بِعَذَابِ ٱللَّهِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٥١<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- يعني: قوله: <span class="qpc-hafs">﴿إن كنت من الصادقين﴾</span> بما تقول أنّه كما تقول{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿فما كان جواب قومه﴾</span>: أي: قوم لوط ﵇، حين نهاهم عن الفاحشة والمنكر <span class="qpc-hafs">﴿إلا أن قالوا﴾</span> للوط ﵇: <span class="qpc-hafs">﴿ائتنا بعذاب الله إن كنت من الصادقين﴾</span> يعني: بأنّ العذاب نازل بهم في الدنيا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فما كان جواب قومه إلا أن قالوا ائتنا بعذاب الله إن كنت من الصادقين﴾</span> وذلك لِما كان يَعِدُهم به مِن العذاب{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ٢/٦٢٧.الخذف: هو رميك بحصاة أو نواة؛ تأخذها بين سبّابتيك وترمي بها، أو تتخذ مخذفة من خشب ثم ترمي به الحصاة بين إبهامك والسبابة. النهاية (خذف).تفسير مقاتل بن سليمان ٣/٣٨٠-٣٨١.أخرجه ابن جرير ١٨/٣٨٨، وابن أبي حاتم ٩/٣٠٥٤.تفسير يحيى بن سلّام ٢/٦٢٧.أخرجه أحمد ٤٤/٤٥٩ (٢٦٨٩١)، ٤٥/٣٨١ (٢٧٣٨٣)، والترمذي ٥/٤١٠-٤١١ (٣٤٦٧)، والحاكم ٢/٤٤٤ (٣٥٣٧)، ٤/٣١٦ (٧٧٦١)، وابن جرير ١٨/٣٨٩، ٣٩٠، ٣٩١، وابن أبي حاتم ٩/٣٠٥٤ (١٧٢٧١)، والثعلبي ٧/٢٧٧.</p><p>قال الترمذي: «هذا حديث حسن، إنما نعرفه من حديث حاتم بن أبي صغيرة عن سماك». وقال الدارقطني في العلل ١٥/٢٣٥ (٣٩٨٣): «يرويه حاتم بن أبي صغيرة أبو يونس، واختلف عنه؛ فرواه إسماعيل بن مهدي عن بشر بن المفضل عن أبي يونس عن سماك عن أبي صالح عن أم سلمة. ورواه غيره عن أبي يونس عن سماك عن أبي صالح عن أم هانئ، وهو المحفوظ». وقال البيهقي في الشعب ٩/١٠٨-١٠٩ (٦٣٣١): «تابعه يزيد بن زريع وغيره، عن حاتم بن أبي صغيرة». وقال الحاكم: «صحيح على شرط مسلم، ولم يخرجاه». وقال ابن حجر في إتحاف المهرة ١٨/١٥ (٢٣٣٠٢): «أبو صالح متروك الحديث».أخرجه الثعلبي ٧/٢٧٧ من طريق موسى بن محمد، قال: حدثنا الحسن بن علوية، قال: حدثنا إسماعيل بن عيسى، قال: حدثنا المسيب، قال: سمعت زياد بن أبي زياد، عن معاوية به.عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٦/٢٤٠.أخرجه البخاري في تاريخه ٦/١٩٦، وابن جرير ١٨/٣٨٩، وابن أبي حاتم ٩/٣٠٥٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ١٨/٣٩٢، وابن أبي حاتم ٩/٣٠٥٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٨/٣٩١-٣٩٢، وإسحاق البستي في تفسيره ص٧٠، وابن أبي حاتم ٩/٣٠٥٥، والخرائطي في مساوئ الأخلاق (٤٤٧). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.الجَلاهق: جمع جُلاهِق، وهو البندق الذي يرمى به. وقيل: هو الطين المدوَّر. التاج (جلهق).القَباء: ثوب يلبس فوق الثياب أو القميص، ويتمنطق به. الوسيط (قبى).أخرجه ابن أبي حاتم ٩/٣٠٥٥.أخرجه ابن جرير ١٨/٣٩٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٣٠٥٤-٣٠٥٥. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٦/٢٤٠.أخرجه ابن جرير ١٨/٣٩٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٣٩٠.تفسير مقاتل بن سليمان ٣/٣٨٠-٣٨١.أخرجه ابن جرير ١٨/٣٩٢.تفسير يحيى بن سلّام ٢/٦٢٧.أخرجه ابن أبي حاتم ٩/٣٠٥٥.تفسير مقاتل بن سليمان ٣/٣٨٠-٣٨١.تفسير يحيى بن سلّام ٢/٦٢٧.
  29,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ ٱنصُرۡنِی عَلَى ٱلۡقَوۡمِ ٱلۡمُفۡسِدِینَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- قوله: <span class="qpc-hafs">﴿قال رب انصرني على القوم المفسدين﴾</span>، قال: كان فسادُهم ذلك في معصية الله؛ لأنه مَن عصى الله في الأرض أو أمر بمعصية الله فقد أفسد في الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> فدعا لوطٌ ربَّه ﷿، فـ<span class="qpc-hafs">﴿قال رب انصرني على القوم المفسدين﴾</span>، يعني: العاصين، يعني بالفساد: إتيان الرجال في أدبارهم. يقول: رب انصرني بتحقيق قولي في العذاب عليهم بما كذبون، يعني: بتكذيبهم إيّاي حين قالوا: إنّ العذاب ليس بنازل بهم في الدنيا. فأهلكهم الله ﷿ بالخسف والحصب، وكان لوط ﵇ قد أنذرهم العذاب، فذلك قوله: <span class="qpc-hafs">﴿ولقد أنذرهم بطشتنا﴾</span> [القمر:٣٦]، يعني: عذابنا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> لوط: <span class="qpc-hafs">﴿رب انصرني على القوم المفسدين﴾</span> المشركين، وهو أعظم الفساد، والمعاصي كلها مِن الفساد، وأعظمها الشرك، وكانوا على الشِّرك؛ جاحدين نبيَّهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٥٥.تفسير مقاتل بن سليمان ٣/٣٨١.تفسير يحيى بن سلّام ٢/٦٢٧.