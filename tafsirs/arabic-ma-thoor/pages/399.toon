quran[7]{c,v,t}:
29,24," <q>﴿فَمَا كَانَ جَوَابَ قَوۡمِهِۦۤ﴾</q> - تفسير ٥٩٧٥٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فما كان جواب قومه﴾</q>، قال: قوم إبراهيم{1}. (١١/٥٤٠) ٥٩٧٥٧- قال مقاتل بن سليمان ثم ذكر إبراهيم ﵇ في التقديم، قال: <q>﴿فما كان جواب قومه﴾</q>، يعني: قوم إبراهيم ﵇، حين دعاهم إلى الله ﷿، ونهاهم عن عبادة الأصنام {2}. (ز) ٥٩٧٥٨- قال يحيى بن سلّام: <q>﴿فما كان جواب قومه﴾</q> قوم إبراهيم <q>﴿إلا أن قالوا اقتلوه أو حرقوه﴾</q> يقوله بعضهم لبعض{3}. (ز) <q>﴿إِلَّاۤ أَن قَالُوا۟ ٱقۡتُلُوهُ أَوۡ حَرِّقُوهُ فَأَنجَىٰهُ ٱللَّهُ مِنَ ٱلنَّارِۚ﴾</q> - تفسير ٥٩٧٥٩- عن كعب الأحبار -من طريق قتادة- في قوله: <q>﴿فأنجاه الله من النار﴾</q>، قال: ما أحْرَقَتِ النارُ منه إلا وثاقَه{4}. (١١/٥٤٠) ٥٩٧٦٠- قال مقاتل بن سليمان قوله: <q>﴿إلا أن قالوا اقتلوه أو حرقوه﴾</q> بالنار، فقذفوه في النار، <q>﴿فأنجاه الله من النار﴾</q>{2}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٢٤﴾</q> - تفسير ٥٩٧٦١- قال مقاتل بن سليمان قوله: <q>﴿إن في ذلك لآياتٍ﴾</q> يعني ﷿: إنّ في النار التي لم تُحْرِق إبراهيمَ ﵇ لَعِبرةً <q>﴿لقومٍ يؤمنون﴾</q> يعني: يُصَدِّقون بتوحيد الله ﷿{2}. (ز) ٥٩٧٦٢- قال يحيى بن سلّام: <q>﴿إن في ذلك لآيات لقوم يؤمنون﴾</q>، أي: فيما صنع الله بإبراهيم وما نجاه من النار، وإنما يعتبر المؤمنون{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٨١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وورد في المطبوع من تفسير ابن أبي حاتم ٩/٣٠٤٧ عن قتادة، من طريق سعيد: <q>﴿فما كان جواب قومه﴾</q> قوم لوط ﷺ. وهذا تفسير الآية التي تشبه هذه الآية في سورة النمل [٥٦].تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٥.أخرجه ابن جرير ١٨/٣٨١، وابن أبي حاتم ٩/٣٠٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٥.
29,25," <q>﴿وَقَالَ إِنَّمَا ٱتَّخَذۡتُم مِّن دُونِ ٱللَّهِ أَوۡثَـٰنࣰا مَّوَدَّةَ بَیۡنِكُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ ثُمَّ یَوۡمَ ٱلۡقِیَـٰمَةِ یَكۡفُرُ بَعۡضُكُم بِبَعۡضࣲ وَیَلۡعَنُ بَعۡضُكُم بَعۡضࣰا وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٢٥﴾</q> - قراءات ٥٩٧٦٣- عن الأعمش: في قراءة عبد الله [بن مسعود]: (إنَّما مَوَدَّةُ بَيْنِكُمْ){1}. (ز) <q>﴿وَقَالَ إِنَّمَا ٱتَّخَذۡتُم مِّن دُونِ ٱللَّهِ أَوۡثَـٰنࣰا مَّوَدَّةَ بَیۡنِكُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ﴾</q> - تفسير ٥٩٧٦٤- عن قتادة بن دعامة -من طريق شيبان بن عبد الرحمن- في قوله: <q>﴿وقال إنما اتخذتم من دون الله أوثانا مودة بينكم في الحياة الدنيا﴾</q>، قال: اتخذوها لثوابها في الحياة الدنيا{2}. (١١/٥٤٠) ٥٩٧٦٥- قال مقاتل بن سليمان: <q>﴿وقال﴾</q> لهم إبراهيم ﵇: <q>﴿إنما اتخذتم﴾</q> الأوثان آلهة <q>﴿من دون الله﴾</q> ﷿ <q>﴿أوثانًا مودة بينكم في الحياة الدنيا﴾</q> يعني: بين الأتباع والقادة؛ مودة على عبادة الأصنام{3}. (ز) ٥٩٧٦٦- قال يحيى بن سلّام: <q>﴿وقال﴾</q> إبراهيم: <q>﴿إنما اتخذتم من دون الله أوثانا مودة بينكم﴾</q> يوادُّ بعضكم بعضًا، أي: يُحِبُّ بعضكم بعضًا على عبادة الأوثان <q>﴿في الحياة الدنيا﴾</q>{4}. (ز) <q>﴿ثُمَّ یَوۡمَ ٱلۡقِیَـٰمَةِ یَكۡفُرُ بَعۡضُكُم بِبَعۡضࣲ وَیَلۡعَنُ بَعۡضُكُم بَعۡضࣰا﴾</q> - تفسير ٥٩٧٦٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ثم يوم القيامة يكفر بعضكم ببعض ويلعن بعضكم بعضا﴾</q>، قال: صارت كلُّ خلَّةٍ في الدنيا عداوةً على أهلها يوم القيامة، إلا خلة المتقين{5}. (١١/٥٤٠) ٥٩٧٦٨- تفسير إسماعيل السُّدِّيّ: يتبرأ بعضكم من بعض{6}. (ز) ٥٩٧٦٩- قال مقاتل بن سليمان: <q>﴿ثم﴾</q> إذا كان <q>﴿يوم القيامة يكفر بعضكم ببعضٍ﴾</q> يقول: تَتَبَرَّأ القادةُ من الأتباع، <q>﴿ويلعن بعضكم بعضًا﴾</q> يقول: ويلعن الأتباعُ القادةَ؛ مِن الأمم الخالية وهذه الأمة{3}. (ز) ٥٩٧٧٠- قال يحيى بن سلّام: <q>﴿ثم يوم القيامة يكفر بعضكم ببعض﴾</q>، أي: بِوِلاية بعض{4}. (ز) <q>﴿وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٢٥﴾</q> - تفسير ٥٩٧٧١- قال مقاتل بن سليمان: ثم قال لهم إبراهيم ﵇: <q>﴿ومأواكم النار﴾</q> يعني: مصيركم إلى النار، <q>﴿وما لكم من ناصرين﴾</q> يعني: مانعين مِن العذاب يمنعونكم منه{3}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٨. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١١٦.أخرجه ابن أبي حاتم ٩/٣٠٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ٢/٦٢٦.تفسير مقاتل بن سليمان ٣/٣٧٩.تفسير يحيى بن سلّام ٢/٦٢٦.تفسير مقاتل بن سليمان ٣/٣٧٩.
29,26," <q>﴿فَـَٔامَنَ لَهُۥ لُوطࣱۘ﴾</q> - تفسير ٥٩٧٧٢- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿فآمن له لوط﴾</q>، قال: صدَّق لوطٌ إبراهيمَ{1}. (١١/٥٤١) ٥٩٧٧٣- عن قتادة بن دعامة -من طريق سعيد- وفي قوله: <q>﴿فآمن له لوط﴾</q>، قال: فصدَّقة لوط{2}. (١١/٥٤٠) ٥٩٧٧٤- قال مقاتل بن سليمان: <q>﴿فآمن له لوطٌ﴾</q>، يعني: فصدق بإبراهيمَ لوطٌ ﵉، وهو أولُ مَن صدَّق بإبراهيم حين رأى إبراهيم لم تَضُرَّه النار{3}. (ز) ٥٩٧٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فآمن له لوط﴾</q>، قال: صدَّقه لوط، صدَّق إبراهيم، قال: أرأيت المؤمنين، أليس آمنوا لرسول الله ﷺ ما جاء به؟ قال: فالإيمان: التصديق. وقال ابن زيد في حديث الذئب الذي كلَّم الرجل، فأخبر به النبي ﷺ، فقال رسول الله ﷺ: «فآمنتُ له أنا، وأبو بكر، وعمر». وليس أبو بكر ولا عمر معه. يعني «آمنتُ له»: صدَّقتُه{4}. (ز) ٥٩٧٧٦- قال يحيى بن سلّام: <q>﴿فآمن له لوط﴾</q>، أي: فصدَّقه لوط{5}. (ز) <q>﴿وَقَالَ إِنِّی مُهَاجِرٌ إِلَىٰ رَبِّیۤۖ إِنَّهُۥ هُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٢٦﴾</q> - تفسير ٥٩٧٧٧- عن كعب الأحبار -من طريق مسلمة بن عبد الله- في قوله: <q>﴿وقال إني مهاجر إلى ربي﴾</q>، قال: إلى حرّان{6}. (١١/٥٤١) ٥٩٧٧٨- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وقال إني مهاجر إلى ربي﴾</q>، قال: هو إبراهيم ﵇ القائل: <q>﴿إني مهاجر إلى ربي﴾</q>{7}. (١١/٥٤١) ٥٩٧٧٩- عن قتادة بن دعامة -من طريق خليد بن دعلج- في قوله: <q>﴿وقال إني مهاجر إلى ربي﴾</q>، قال: إلى الشام كان مهاجره{8}. (١١/٥٤١) ٥٩٧٨٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وقال إني مهاجر إلى ربي﴾</q>، قال: هاجرا جميعًا من كُوثى، وهي من سواد الكوفة، إلى الشام{9}. (١١/٥٤٠) ٥٩٧٨١- قال مقاتل بن سليمان: <q>﴿وقال﴾</q> إبراهيم ﵇: <q>﴿إني مهاجرٌ إلى ربي﴾</q> يعني: هجر قومَه المشركين من أرض كوثى هو ولوط وسارة أخت لوط ﵈ إلى الأرض المقدسة، <q>﴿إلى ربي﴾</q> يعني: إلى رضا ربي. وقال في الصافات [٩٩]: <q>﴿إنى ذاهبٌ إلى ربي﴾</q> يعني: إلى رضا ربي <q>﴿سيهدين﴾</q>. فهاجر وهو ابن خمس وسبعين سنة، <q>﴿إنه هو العزيز الحكيم﴾</q>{3}. (ز) ٥٩٧٨٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿فآمن له لوط وقال إني مهاجر إلى ربي﴾</q>، قال: إلى حرّان، ثم أُمِر بعدُ بالشامِ الذي هاجر إبراهيم، وهو أول من هاجر، يقول: <q>﴿فآمن له لوط وقال إني مهاجر﴾</q> الآية{11}. (١١/٥٤١) (ز) ٥٩٧٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إني مهاجر إلى ربي﴾</q>، قال: كانت هجرتُه إلى الشام{12}. (ز) ٥٩٧٨٤- قال يحيى بن سلّام: <q>﴿وقال إني مهاجر إلى ربي﴾</q> يقوله إبراهيم، هاجر مِن أرض العراق إلى أرض الشام{5}. (ز) <q>﴿وَقَالَ إِنِّی مُهَاجِرٌ إِلَىٰ رَبِّیۤۖ إِنَّهُۥ هُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٢٦﴾</q> - آثار متعلقة بالآية ٥٩٧٨٥- عن زيد بن ثابت، قال: قال رسول الله ﷺ: «ما كان بين عثمان ورُقَيَّة؛ وبين لوط مِن مهاجِر{5}»{15}. (١١/٥٤٢) ٥٩٧٨٦- عن عبد الله بن عمر، أنّ النبي ﷺ قال: «سيهاجر خيار أهل الأرض هجرةً بعد هجرةٍ إلى مهاجَر إبراهيم ﵇»{16}. (١١/٥٤٢) ٥٩٧٨٧- عن أنس بن مالك، قال: أوَّلُ مَن هاجر من المسلمين إلى الحبشة بأهله عثمان بن عفان، فقال النبي ﷺ: «صحبهما الله، إنّ عثمان لَأَوَّلُ مَن هاجر إلى الله بأهله بعد لوط»{17}. (١١/٥٤٢) ٥٩٧٨٨- عن أسماء بنت أبي بكر، قالت: هاجر عثمانُ إلى الحبشة، فقال النبي ﷺ: «إنّه لَأَوَّلُ مَن هاجر بعد إبراهيم ولوط»{18}. (١١/٥٤٢) ٥٩٧٨٩- عن عبد الله بن عباس، قال: أول من هاجر إلى رسول الله ﷺ عثمانُ بن عفان، كما هاجر لوطٌ إلى إبراهيم{19}. (١١/٥٤٣) ٥٩٧٩٠- قال قتادة: وذُكِر لنا: أنّ نبي الله ﷺ قال: «إنها ستكون هجرة بعد هجرة، ينحاز أهل الأرض إلى مهاجَر إبراهيم، ويبقى في الأرض شرار أهلها، حتى تلفظَهم وتَقْذَرَهُم، وتحشرهم النارُ مع القردة والخنازير»{20}. (ز) ٥٩٧٩١- عن محمد بن إسحاق -من طريق سلمة- قال: ثم إنّ نمرود كفَّ عن إبراهيم، ومنعه الله منه، واستجاب لإبراهيم رجالٌ مِن قومه حيث رأوا ما صنع اللهُ -تبارك وتعالى- به على خوفٍ من نمرود [و]ملئهم، فآمن له لوط، وكان ابنَ أخيه، وآمنت به سارةُ، وكانت بنتَ عمه، ثم خرج إبراهيم ﵇ مهاجرًا إلى ربه، وخرج معه لوط مهاجرًا، وتزوج سارةَ بنت عمه، فخرج بها يلتمس الفرار بدينه والأمانة على ربه، حتى نزل حرّان، فمكث بها ما شاء الله أن يمكث، ثم خرج منها مهاجرًا حتى قدم مصر، وبها فرعون من الفراعنة الأولى، وكانت سارةُ مِن أحسن الناس فيما يُقال، وكانت لا تعصي إبراهيمَ شيئًا، ولذلك أكرمها الله{21}. (ز) ٥٩٧٩٢- عن عبد الرحمن بن حسان الكناني -من طريق الوليد بن مسلم- قال: هاجر لوط -وهو ابن أخي إبراهيم- بامرأته إلى إبراهيم بالشام، وكان بين امرأته وبين سارة بعضُ ما يكون بين النساء، فقال له إبراهيم: يا ابن أخي، قد جرى بين هاتين، وأنا أتخوَّف أن يُحْدِث ذلك في قلبي عليك، فتحول. فتحوَّلا، قال: فنزل بمدائن قوم لوط{22}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٩.أخرجه ابن جرير ١٨/٣٨٤-٣٨٥.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه ابن أبي حاتم ٩/٣٠٥٠.أخرجه إسحاق البستي في تفسيره ص٦٩، وابن جرير ١٨/٣٨٥، وابن أبي حاتم ٩/٣٠٥٠ من طريق جويبر.أخرجه ابن عساكر ١/١٦٣.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠ من طريق شيبان بن عبد الرحمن. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٩.أخرجه ابن جرير ١٨/٣٨٥. وعزا السيوطي أوله إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٨٤.تفسير يحيى بن سلّام ٢/٦٢٦.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه الدولابي في الكنى والأسماء ٢/٧٤١ (١٢٨٤)، والطبراني في الكبير ٥/١٣٩ (٤٨٨١). قال الهيثمي في المجمع ٩/٨١ (١٤٤٩٩): «رواه الطبراني، وفيه عثمان بن خالد العثماني، وهو متروك». وقال المناوي في فيض القدير ٥/٤٦٢ (٧٩٦٥): «رمز المصنف -السيوطي- لحسنه». وقال الألباني في الضعيفة ٩/٤٥٢ (٤٤٦٤): «موضوع».أخرجه أحمد ٩/٣٩٥-٣٩٦ (٥٥٦٢)، وابن عساكر في تاريخ دمشق ١/١٦٣ واللفظ له. قال ابن كثير في تفسيره ٦/٢٧٤: «غريب من حديث نافع. والظاهر أن الأوزاعي قد رواه عن شيخ له من الضعفاء، والله أعلم. وروايته من حديث عبد الله بن عمرو بن العاص أقرب إلى الحفظ». وقال الهيثمي في المجمع ٥/٢٥١ (٩٢٨٥): «رواه أحمد في حديث طويل في قتال أهل البغي، وفيه أبو جناب الكلبي، وهو ضعيف». وقال ابن حجر في فتح الباري ١١/٣٨٠: «أخرجه أحمد، وسنده لا بأس به». وقال الألباني في الصحيحة ٧/٦١٣-٦١٤: «وهذا إسناد رجاله ثقات رجال البخاري، فهو صحيح؛ لولا الواسطة بين الأوزاعي ونافع فإنه لم يسم، مع أن رواية الأوزاعي عن نافع ثابتة في صحيح البخاري. وعلى كل حال فهو شاهد صالح، وبه يرتقي الحديث إلى مرتبة الصحة».أخرجه ابن أبي عاصم في كتاب السنة ٢/٥٩٦ (١٣١١)، والطبراني في الكبير ١/٩٠ (١٤٣).أخرجه ابن عساكر في تاريخ دمشق ٣/١٥٠، ٣٩/٣٠-٣١، وابن منده -كما في الإصابة ٨/١٣٨-١٣٩-. قال ابن حجر: «بسند واهٍ».أخرجه ابن عساكر ٣٩/٣٠، ٥٠/٣٠٨.أخرجه ابن جرير ١٨/٣٨٤، وابن أبي حاتم ٩/٣٠٥٠-٣٠٥١ (١٧٢٤٩).أخرجه ابن أبي حاتم ٩/٣٠٥٠-٣٠٥١.أخرجه ابن أبي حاتم ٩/٣٠٥١.
29,27," <q>﴿وَوَهَبۡنَا لَهُۥۤ إِسۡحَـٰقَ وَیَعۡقُوبَ﴾</q> - تفسير ٥٩٧٩٣- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿ووهبنا له إسحاق ويعقوب﴾</q>، قال: هما ولدا إبراهيم{1}٥٠٣٧. (١١/٥٤٣) ٥٠٣٧ علّق ابنُ كثير (١٠/٥٠٧) على قول ابن عباس، فقال: «فأما ما رواه العوفي عن ابن عباس في قوله: <q>﴿ووهبنا له إسحاق ويعقوب نافلة﴾</q>، قال: هما ولدا إبراهيم. فمعناه: أنّ ولد الولد بمنزلة الولد، فإنّ هذا أمر لايكاد يخفى على من هو دون ابن عباس». ٥٩٧٩٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿ووهبنا له إسحاق ويعقوب﴾</q>، قال: أعطينا{2}. (ز) ٥٩٧٩٥- قال مقاتل بن سليمان: <q>﴿ووهبنا له﴾</q> يعني: لإبراهيم <q>﴿إسحاق ويعقوب﴾</q> ابن إسحاق بالأرض المقدسة{3}. (ز) <q>﴿وَجَعَلۡنَا فِی ذُرِّیَّتِهِ ٱلنُّبُوَّةَ﴾</q> - تفسير ٥٩٧٩٦- قال مقاتل بن سليمان: <q>﴿وجعلنا في ذريته﴾</q> يعني: ذرية إبراهيم <q>﴿النبوة﴾</q> يعني: إسماعيل، وإسحاق، ويعقوب ﵈{3}. (ز) <q>﴿وَٱلۡكِتَـٰبَ﴾</q> - تفسير ٥٩٧٩٧- عن عبد الله بن عباس -من طريق عكرمة- قوله: <q>﴿الكتاب﴾</q>، قال: الخطُّ بالقلم{5}. (ز) ٥٩٧٩٨- قال مقاتل بن سليمان: <q>﴿والكتاب﴾</q>، يعني: صحف إبراهيم{3}. (ز) ٥٩٧٩٩- قال يحيى بن سلّام: <q>﴿والكتاب﴾</q>، فكان أول كتاب أُنزل بَعْدُ كتابُ موسى وما بعده من الكتب{7}. (ز) <q>﴿وَءَاتَیۡنَـٰهُ أَجۡرَهُۥ فِی ٱلدُّنۡیَاۖ﴾</q> - قراءات ٥٩٨٠٠- عن عبيد، قال: سمعت الضحاك يقول: <q>﴿آتَيْناهُ أجْرَهُ فِي الدُّنْيا﴾</q> في حرف ابن مسعود: (آتَيْناهُ فِي الدُّنْيا حَسَنَةً وإنَّهُ فِي الآخِرَةِ لَمِنَ الصّالِحِينَ){8}. (ز) <q>﴿وَءَاتَیۡنَـٰهُ أَجۡرَهُۥ فِی ٱلدُّنۡیَاۖ﴾</q> - تفسير الآية ٥٩٨٠١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: الذِّكْرُ الحَسَنُ{9}. (١١/٥٤٣) ٥٩٨٠٢- عن عبد الله بن عباس -من طريق مندل عمَّن ذكره- <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: الولد الصالح، والثَّناء{10}. (١١/٥٤٣) ٥٩٨٠٣- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿أجره في الدنيا﴾</q>، قال: إنّ الله -تبارك وتعالى- رضي لأهل الأديان بدينهم، فليس أهلُ دين إلا وهم يَتَوَلَّوْنَ إبراهيمَ ويَرْضَوْنَ عنه{11}. (١١/٥٤٣) ٥٩٨٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: الثناء{12}. (١١/٥٤٣) ٥٩٨٠٥- عن سفيان الثوري، قال: بلغني عن مجاهد في قول الله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: <q>﴿وتركنا عليه في الآخرين﴾</q> [الصافات:٧٨]، قال: الثناء الصالح{13}. (ز) ٥٩٨٠٦- عن ليث، قال: أرسل مجاهد رجلًا إلى عكرمة مولى ابن عباس يسأله عن قوله: <q>﴿وآتيناه أجره في الدنيا وإنه في الآخرة لمن الصالحين﴾</q>. قال: فقال: أجره في الدنيا أنّ كُلَّ مِلَّة تَتَوَلّاه، وهو عند الله من الصالحين. قال: فرجع إلى مجاهد، فقال: أصاب{14}. (ز) ٥٩٨٠٧- عن عكرمة مولى ابن عباس -من طريق ابن جريج- في قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: لسان الصِّدق الذي جعل له{15}. (ز) ٥٩٨٠٨- قال عكرمة مولى ابن عباس -من طريق ابن جريج-: إبراهيمُ تَوَلّاهُ الأُمَمُ كلُّها؛ اليهود والنصارى والمجوس والناس أجمعون، وشهدوا له بالعدل، فذلك اللسان الصدق، وهو الأجر الذي آتيناه في الدنيا{16}. (ز) ٥٩٨٠٩- عن ابن عيينة: أنّ عكرمة مولى ابن عباس سُئِل عن قوله تعالى: <q>﴿وأتيناه أجره في الدنيا﴾</q>. قال: لقد غُصْتَ عليه في بحرٍ عميق، فمَن أنت؟ قال: سعيد بن جبير. قال: لقد علمت. ثم قال: أبقى له ثناء حسنًا{17}. (ز) ٥٩٨١٠- عن الحسن البصري -من طريق سفيان بن حسين- في قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: نيته الصالحة التي اكتسب بها الأجرَ في الآخرة{16}. (ز) ٥٩٨١١- عن قتادة بن دعامة -من طريق سعيد- وفي قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: عافية، وعملًا صالحًا، وثناء حسنًا، فلستَ تلاقي أحدًا مِن أهل الملل إلا يَرضى إبراهيمَ ويتولّاه{19}. (١١/٥٤٠) ٥٩٨١٢- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وآتيناه أجره في الدنيا﴾</q>، قال: هي كقوله: <q>﴿وآتيناه في الدنيا حسنة﴾</q> [النحل:١٢٢]. قال: وقال: ليس من أهل دين إلا وهم يتولونه{20}. (ز) ٥٩٨١٣- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>: هو الولد الصالح{21}. (ز) ٥٩٨١٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وكَذَلِكَ نُرِي إبْراهِيمَ مَلَكُوتَ السَّماواتِ والأَرْضِ ولِيَكُونَ مِنَ المُوقِنِينَ﴾</q> [الأنعام:٧٥]، قال: أُقِيم على صخرة، وفُتِحَت له السموات، فنظر إلى مُلْكِ الله فيها، حتى نظر إلى مكانه في الجنة، وفُتِحَت له الأرضون حتى نظر إلى أسفل الأرض، فذلك قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q>، يقول: آتيناه مكانه في الجنة. ويقال: <q>﴿أجره﴾</q>: الثناء الحسن{22}. (٦/١٠٤) ٥٩٨١٥- عن زياد بن أبي مريم -من طريق خُصيف- في قوله: <q>﴿آتيناه﴾</q>، قال: أعطيناه{15}. (ز) ٥٩٨١٦- قال مقاتل بن سليمان: <q>﴿وآتيناه أجره﴾</q> يعني: أعطيناه جزاءَه <q>﴿في الدنيا﴾</q> يعني: الثناء الحسن والمقالة الحسنة مِن أهل الأديان كلها؛ لِمُضِيِّه على رضوان الله حين أُلْقِي في النار، وكَسَر الأصنام، ومُضِيّه على ذبح ابنه، فجميع أهل الأديان يقولون: إبراهيم مِنّا. لا يَتَبَرَّأُ منه أحدٌ{3}. (ز) ٥٩٨١٧- عن يحيى بن سلّام، في قوله: <q>﴿وآتيناه أجره﴾</q>، قال: أعطيناه أجره <q>﴿في الدنيا﴾</q>، فليس من أهل دين إلا وهم يتولونه ويحبونه، وهو مثلُ قوله: <q>﴿وتركنا عليه في الآخرين﴾</q> [الصافات:٧٨]، أي: أبقينا عليه في الآخرين الثناءَ الحسن{7}. (ز) <q>﴿وَإِنَّهُۥ فِی ٱلۡـَٔاخِرَةِ لَمِنَ ٱلصَّـٰلِحِینَ ۝٢٧﴾</q> - تفسير ٥٩٨١٨- قال عبد الله بن عباس، في قوله: <q>﴿وإنه في الآخرة لمن الصالحين﴾</q>: مثل آدم، ونوح{21}. (ز) ٥٩٨١٩- عن عكرمة مولى ابن عباس -من طريق مجاهد- في قوله: <q>﴿وإنه في الآخرة لمن الصالحين﴾</q>، قال: وهو عند الله من الصالحين{14}. (ز) ٥٩٨٢٠- قال مقاتل بن سليمان: <q>﴿وإنه﴾</q> يعني: إبراهيم <q>﴿في الآخرة لمن الصالحين﴾</q>، نظيرها في النحل{28}{3}. (ز) ٥٩٨٢١- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- يقول: <q>﴿من الصالحين﴾</q>، قال: <q>﴿الصالحين﴾</q>: الأنبياء، والمؤمنون{16}. (ز) ٥٩٨٢٢- قال يحيى بن سلّام: <q>﴿وإنه في الآخرة لمن الصالحين﴾</q>، قال: لَمِن أهل الجنة{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٨٦، وابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٥١.تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير مقاتل بن سليمان ٣/٣٨٠.أخرجه ابن أبي حاتم ٩/٣٠٥٢، وأورده في تفسير قوله تعالى: <q>﴿ويُعَلِّمُهُمُ الكِتابَ والحِكْمَةَ ويُزَكِّيهِمْ﴾</q> [البقرة:١٢٩]، ونحوها من الآيات، وفي تفسير قوله تعالى: <q>﴿ويُعَلِّمُهُ الكِتابَ والحِكْمَةَ والتَّوْراةَ والإنْجِيلَ﴾</q> [آل عمران:٤٨].تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير يحيى بن سلّام ٢/٦٢٦.أخرجه إسحاق البستي في تفسيره ص٦٩. وقراءة ابن مسعود شاذة.أخرجه ابن جرير ١٨/٣٨٧، وابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٨٧.أخرجه ابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى ابن جرير، وابن المنذر. وجاء عند ابن جرير موقوفًا على عكرمة كما سيأتي.أخرجه يحيى بن سلّام ٢/٦٢٦، وابن جرير ١٨/٣٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن وهب في الجامع ١/٨٩ (٢٠٢).أخرجه ابن جرير ١٨/٣٨٦.أخرجه ابن أبي حاتم ٩/٣٠٥٢.أخرجه ابن أبي حاتم ٩/٣٠٥٣.أخرجه ابن أبي الدنيا في كتاب مكارم الأخلاق -موسوعة الإمام ابن أبي الدنيا ٣/٤٣٢ (١٨)-.أخرجه ابن أبي حاتم ٩/٣٠٥٣.أخرجه ابن جرير ١٨/٣٨٧، وابن أبي حاتم ٩/٣٠٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق في تفسيره ٢/٩٦.تفسير البغوي ٦/٢٣٩.أخرجه ابن جرير ٩/٣٤٩، وابن أبي حاتم ٤/١٣٢٦، وأخرجه سعيد بن منصور (٨٣٣-تفسير) من طريق الحكم بن ظُهير. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٥٢.تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير يحيى بن سلّام ٢/٦٢٦.تفسير البغوي ٦/٢٣٩.أخرجه ابن جرير ١٨/٣٨٦.يشير إلى قوله تعالى: <q>﴿وآتيناه في الدنيا حسنة وإنه في الآخرة لمن الصالحين﴾</q> [النحل:١٢٢].تفسير مقاتل بن سليمان ٣/٣٨٠.أخرجه ابن أبي حاتم ٩/٣٠٥٣.تفسير يحيى بن سلّام ٢/٦٢٦.
29,28," <q>﴿وَلُوطًا﴾</q> - تفسير ٥٩٨٢٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولوطا﴾</q>، أي: وأرسلنا لوطًا{1}. (ز) <q>﴿إِذۡ قَالَ لِقَوۡمِهِۦۤ إِنَّكُمۡ لَتَأۡتُونَ ٱلۡفَـٰحِشَةَ﴾</q> - تفسير ٥٩٨٢٤- تفسير إسماعيل السُّدِّيّ: وهي إتيانُ الرجالِ في أدبارهم{2}. (ز) ٥٩٨٢٥- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿ولوطًا إذ قال لقومه إنكم لتأتون الفاحشة﴾</q>: يعني: المعصية، يعني: إتيان الرجال في أدبارهم ليلًا{3}. (ز) ٥٩٨٢٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿إذ قال لقومه إنكم لتأتون الفاحشة﴾</q>، والفاحشة: المعصية{1}. (ز) <q>﴿مَا سَبَقَكُم بِهَا مِنۡ أَحَدࣲ مِّنَ ٱلۡعَـٰلَمِینَ ۝٢٨﴾</q> - تفسير ٥٩٨٢٧- عن عمرو بن دينار -من طريق ابن أبي نجيح- في قوله: <q>﴿إنكم لتأتون الفاحشة ما سبقكم بها من أحد من العالمين﴾</q>، قال: ما نَزا ذَكَرٌ على ذَكَرٍ حتى كان قومُ لوط{5}. (ز) ٥٩٨٢٨- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿ما سبقكم بها من أحدٍ من العالمين﴾</q>: فيما مضى قبلكم، وكانوا لا يأتون إلا الغرباء{3}. (ز) ",footnotes:1:تفسير يحيى بن سلّام ٢/٦٢٧.علقه يحيى بن سلّام ٢/٦٢٧.تفسير مقاتل بن سليمان ٣/٣٨٠.تفسير يحيى بن سلّام ٢/٦٢٧.أخرجه ابن جرير ١٨/٣٨٨، وابن أبي حاتم ٩/٣٠٥٤ بذكر الآية ٨٠ من سورة الأعراف: <q>﴿ولُوطًا إذْ قالَ لِقَوْمِهِ أتَأْتُونَ الفاحِشَةَ ما سَبَقَكُم بِها مِن أحَدٍ مِّن العالَمِينَ﴾</q>.تفسير مقاتل بن سليمان ٣/٣٨٠.
29,29," <q>﴿أَىِٕنَّكُمۡ لَتَأۡتُونَ ٱلرِّجَالَ﴾</q> - تفسير ٥٩٨٢٩- قال يحيى بن سلّام: <q>﴿أئنكم لتأتون الرجال﴾</q> في أدبارهم، وهذا على الاستفهام، أي: إنكم تفعلون ذلك{1}. (ز) <q>﴿وَتَقۡطَعُونَ ٱلسَّبِیلَ﴾</q> - تفسير ٥٩٨٣٠- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿أئنكم لتأتون الرجال وتقطعون السبيل﴾</q>: يعني: المسافر، وذلك أنهم إذا جلسوا في ناديهم -يعني: في مجالسهم- رَمَوُا ابنَ السبيل بالحجارة والخذف{2}، فيقطعون سبيل المسافر، فذلك قوله ﷿: <q>﴿وتأتون في ناديكم المنكر﴾</q>، يعني: في مجالسكم المنكر، يعني: الخذف بالحجارة{3}. (ز) ٥٩٨٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وتقطعون السبيل﴾</q>، قال: الطريق؛ اذا مر بهم المسافرُ -وهو ابن السبيل- قطعوا به، وعملوا به ذلك العمل الخبيث{4}. (١١/٥٤٤) ٥٩٨٣٢- قال يحيى بن سلّام: <q>﴿وتقطعون السبيل﴾</q> على الغرباء، فتأتونهم في أدبارهم، وكانوا لا يفعلون ذلك إلا بالغرباء، وكانوا يتعرضون الطرق، ويأخذون الغرباء، ولا يفعله بعضهم ببعض{1}٥٠٣٨. (ز) ٥٠٣٨ نقل ابنُ عطية (٦/٦٤٠) في معنى الآية أقوالًا أخرى قائلًا: «فقالت فرقة: كان قطع الطريق بالسلْب فاشيًا فيهم... وقالت فرقة: بل أراد قَطْعَ سبيل النسل في ترك النساء وإتيان الرجال. وقالت فرقة: أراد أنهم بفَتْح الأُحدوثة عنهم يقطعون سبل الناس عن قصدهم في التجارات وغيرها». <q>﴿وَتَأۡتُونَ فِی نَادِیكُمُ ٱلۡمُنكَرَۖ﴾</q> - تفسير ٥٩٨٣٣- عن أبي صالح مولى أم هانئ، عن أم هانئ بنت أبي طالب، قالت: سألتُ رسولَ الله ﷺ عن قول الله تعالى: <q>﴿وتأتون في ناديكم المنكر﴾</q>. قال: «كانوا يجلسون بالطريق، فَيَخْذِفون أبناء السبيل، ويسخرون منهم»{6}. (١١/٥٤٤) ٥٩٨٣٤- عن معاوية، قال: قال رسول الله ﷺ: «إنّ قوم لوط كانوا يجلسون في مجالسهم وعند كل رجل منهم قصعة فيها حصى، فإذا مرَّ بهم عابرُ سبيل حذفوه، فأيهم أصابه كان أولى به». وذلك قول الله سبحانه: <q>﴿وتأتون في ناديكم المنكر﴾</q>{7}. (ز) ٥٩٨٣٥- عن جابر بن عبد الله: أنّ النبي ﷺ نهى عن الخَذْف، وهو قول الله: <q>﴿وتأتون في ناديكم المنكر﴾</q>{8}. (١١/٥٤٥) ٥٩٨٣٦- عن عبد الله بن سلام، في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: كان يبزُق بعضُهم على بعض{9}. (ز) ٥٩٨٣٧- عن عائشة -من طريق عروة بن الزبير- في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قالت: الضراط{10}. (١١/٥٤٦) ٥٩٨٣٨- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: في مجالسكم{11}. (١١/٥٤٤) ٥٩٨٣٩- عن عبد الله بن عباس، في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: الخذف{12}. (١١/٥٤٥) ٥٩٨٤٠- عن عبد الله بن عمر، في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: الخذف. فقال رجل: وما لو قلت هكذا؟! فأخذ ابن عمر كفًّا مِن حَصْباء، فضرب به وجهه، وقال: في حديث رسول الله ﷺ تأخذ بالمعاريض!{8}. (١١/٥٤٥) ٥٩٨٤١- عن مجاهد بن جبر -من طريق منصور بن المعتمر- في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: كان يُجامِع بعضُهم بعضًا في المجالس{14}. (١١/٥٤٥) ٥٩٨٤٢- عن مجاهد بن جبر -من طريق الحكم- في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: الصفير، ولعب الحمام، والجَلاهق{15}، وحَلُّ أزْرارِ القَباء{16}{17}. (١١/٥٤٦) ٥٩٨٤٣- عن عكرمة مولى ابن عباس -من طريق عمر بن أبي زائدة- <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: كانوا يُؤذون أهلَ الطريق، ويخذفون الناس{18}. (١١/٥٤٥) ٥٩٨٤٤- عن القاسم بن محمد بن أبي بكر الصديق -من طريق يزيد بن بكر- أنّه سُئِل عن قول الله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، ماذا كان المنكر الذي كانوا يأتون؟ قال: كانوا يتضارطون في مجالسهم، يضرط بعضهم على بعض، والنادي هو المجلس{19}. (١١/٥٤٦) ٥٩٨٤٥- عن مكحول الشامي -من طريق سليمان بن ظريف- قال: كان مِن أخلاق قوم لوط مَضْغُ العلك، وتطريف الأصابع بالحناء، وحل الإزار، والصفير، والحَذْف، واللوطية{9}. (ز) ٥٩٨٤٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: كانوا يعملون الفاحشة في مجالسهم{21}. (١١/٥٤٦) ٥٩٨٤٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: كل مَن مَرَّ بهم حذفوه، فهو المنكر{22}. (ز) ٥٩٨٤٨- قال مقاتل بن سليمان: <q>﴿أئنكم لتأتون الرجال وتقطعون السبيل﴾</q> يعني: المسافر، وذلك أنهم إذا جلسوا في ناديهم -يعني: في مجالسهم- رَمَوُا ابنَ السبيل بالحجارة والخذف، فيقطعون سبيل المسافر، فذلك قوله ﷿: <q>﴿وتأتون في ناديكم المنكر﴾</q> يعني: في مجالسكم المنكر، يعني: الخذف بالحجارة{3}. (ز) ٥٩٨٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وتأتون في ناديكم المنكر﴾</q>، قال: ناديهم: المجالس. والمنكر: عملهم الخبيث الذي كانوا يعملونه؛ كانوا يعترضون بالراكب، فيأخذونه ويركبونه. وقرأ: <q>﴿أتأتون الفاحشة وأنتم تبصرون﴾</q> [النمل:٥٤]، وقرأ: <q>﴿ما سبقكم بها من أحد من العالمين﴾</q>{24}. (ز) ٥٩٨٥٠- قال يحيى بن سلّام: قال: <q>﴿وتأتون في ناديكم المنكر﴾</q> في مجمعكم، والمنكر: الفاحشة، يعني: فعلهم ذلك{1}٥٠٣٩. (ز) ٥٠٣٩ اختلف في المنكر الذي عناه الله في الآية على أقوال: الأول: أنه الضّراط. الثاني: أنهم كانوا يحذفون مَن مَرَّ بهم. الثالث: أنه إتيان الفاحشة في المجالس. الرابع: الصفير، ولعب الحمام، وتطريف الأصابع بالحناء، ونبذ الحياء. وعلَّق ابنُ عطية (٦/٦٤١) على القول الرابع بقوله: «وقد توجد هذه الأشياء في بعض عصاة أمة محمد ﷺ، فالتناهي واجب». وقد رجّح ابنُ جرير (١٨/٣٩٢) مستندًا إلى السنة القول الثاني، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: معناه: وتحذفون في مجالسكم المارَّةَ بكم، وتسخرون منهم؛ لما ذكرنا من الرواية بذلك عن رسول الله ﷺ». <q>﴿فَمَا كَانَ جَوَابَ قَوۡمِهِۦۤ إِلَّاۤ أَن قَالُوا۟ ٱئۡتِنَا بِعَذَابِ ٱللَّهِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٢٩﴾</q> - تفسير ٥٩٨٥١- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- يعني: قوله: <q>﴿إن كنت من الصادقين﴾</q> بما تقول أنّه كما تقول{17}. (ز) ٥٩٨٥٢- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿فما كان جواب قومه﴾</q>: أي: قوم لوط ﵇، حين نهاهم عن الفاحشة والمنكر <q>﴿إلا أن قالوا﴾</q> للوط ﵇: <q>﴿ائتنا بعذاب الله إن كنت من الصادقين﴾</q> يعني: بأنّ العذاب نازل بهم في الدنيا{3}. (ز) ٥٩٨٥٣- قال يحيى بن سلّام: <q>﴿فما كان جواب قومه إلا أن قالوا ائتنا بعذاب الله إن كنت من الصادقين﴾</q> وذلك لِما كان يَعِدُهم به مِن العذاب{1}. (ز) ",footnotes:1:تفسير يحيى بن سلّام ٢/٦٢٧.الخذف: هو رميك بحصاة أو نواة؛ تأخذها بين سبّابتيك وترمي بها، أو تتخذ مخذفة من خشب ثم ترمي به الحصاة بين إبهامك والسبابة. النهاية (خذف).تفسير مقاتل بن سليمان ٣/٣٨٠-٣٨١.أخرجه ابن جرير ١٨/٣٨٨، وابن أبي حاتم ٩/٣٠٥٤.تفسير يحيى بن سلّام ٢/٦٢٧.أخرجه أحمد ٤٤/٤٥٩ (٢٦٨٩١)، ٤٥/٣٨١ (٢٧٣٨٣)، والترمذي ٥/٤١٠-٤١١ (٣٤٦٧)، والحاكم ٢/٤٤٤ (٣٥٣٧)، ٤/٣١٦ (٧٧٦١)، وابن جرير ١٨/٣٨٩، ٣٩٠، ٣٩١، وابن أبي حاتم ٩/٣٠٥٤ (١٧٢٧١)، والثعلبي ٧/٢٧٧. قال الترمذي: «هذا حديث حسن، إنما نعرفه من حديث حاتم بن أبي صغيرة عن سماك». وقال الدارقطني في العلل ١٥/٢٣٥ (٣٩٨٣): «يرويه حاتم بن أبي صغيرة أبو يونس، واختلف عنه؛ فرواه إسماعيل بن مهدي عن بشر بن المفضل عن أبي يونس عن سماك عن أبي صالح عن أم سلمة. ورواه غيره عن أبي يونس عن سماك عن أبي صالح عن أم هانئ، وهو المحفوظ». وقال البيهقي في الشعب ٩/١٠٨-١٠٩ (٦٣٣١): «تابعه يزيد بن زريع وغيره، عن حاتم بن أبي صغيرة». وقال الحاكم: «صحيح على شرط مسلم، ولم يخرجاه». وقال ابن حجر في إتحاف المهرة ١٨/١٥ (٢٣٣٠٢): «أبو صالح متروك الحديث».أخرجه الثعلبي ٧/٢٧٧ من طريق موسى بن محمد، قال: حدثنا الحسن بن علوية، قال: حدثنا إسماعيل بن عيسى، قال: حدثنا المسيب، قال: سمعت زياد بن أبي زياد، عن معاوية به.عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٦/٢٤٠.أخرجه البخاري في تاريخه ٦/١٩٦، وابن جرير ١٨/٣٨٩، وابن أبي حاتم ٩/٣٠٥٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ١٨/٣٩٢، وابن أبي حاتم ٩/٣٠٥٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٨/٣٩١-٣٩٢، وإسحاق البستي في تفسيره ص٧٠، وابن أبي حاتم ٩/٣٠٥٥، والخرائطي في مساوئ الأخلاق (٤٤٧). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.الجَلاهق: جمع جُلاهِق، وهو البندق الذي يرمى به. وقيل: هو الطين المدوَّر. التاج (جلهق).القَباء: ثوب يلبس فوق الثياب أو القميص، ويتمنطق به. الوسيط (قبى).أخرجه ابن أبي حاتم ٩/٣٠٥٥.أخرجه ابن جرير ١٨/٣٩٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٣٠٥٤-٣٠٥٥. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٦/٢٤٠.أخرجه ابن جرير ١٨/٣٩٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٣٩٠.تفسير مقاتل بن سليمان ٣/٣٨٠-٣٨١.أخرجه ابن جرير ١٨/٣٩٢.تفسير يحيى بن سلّام ٢/٦٢٧.أخرجه ابن أبي حاتم ٩/٣٠٥٥.تفسير مقاتل بن سليمان ٣/٣٨٠-٣٨١.تفسير يحيى بن سلّام ٢/٦٢٧.
29,30," <q>﴿قَالَ رَبِّ ٱنصُرۡنِی عَلَى ٱلۡقَوۡمِ ٱلۡمُفۡسِدِینَ ۝٣٠﴾</q> - تفسير ٥٩٨٥٤- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- قوله: <q>﴿قال رب انصرني على القوم المفسدين﴾</q>، قال: كان فسادُهم ذلك في معصية الله؛ لأنه مَن عصى الله في الأرض أو أمر بمعصية الله فقد أفسد في الأرض{1}. (ز) ٥٩٨٥٥- قال مقاتل بن سليمان: فدعا لوطٌ ربَّه ﷿، فـ<q>﴿قال رب انصرني على القوم المفسدين﴾</q>، يعني: العاصين، يعني بالفساد: إتيان الرجال في أدبارهم. يقول: رب انصرني بتحقيق قولي في العذاب عليهم بما كذبون، يعني: بتكذيبهم إيّاي حين قالوا: إنّ العذاب ليس بنازل بهم في الدنيا. فأهلكهم الله ﷿ بالخسف والحصب، وكان لوط ﵇ قد أنذرهم العذاب، فذلك قوله: <q>﴿ولقد أنذرهم بطشتنا﴾</q> [القمر:٣٦]، يعني: عذابنا{2}. (ز) ٥٩٨٥٦- قال يحيى بن سلّام: <q>﴿قال﴾</q> لوط: <q>﴿رب انصرني على القوم المفسدين﴾</q> المشركين، وهو أعظم الفساد، والمعاصي كلها مِن الفساد، وأعظمها الشرك، وكانوا على الشِّرك؛ جاحدين نبيَّهم{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٥٥.تفسير مقاتل بن سليمان ٣/٣٨١.تفسير يحيى بن سلّام ٢/٦٢٧.
