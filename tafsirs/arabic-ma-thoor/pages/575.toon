tafsir[18]{c,v,t}:
73,20," <q>﴿إِنَّ رَبَّكَ یَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَیِ ٱلَّیۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَاۤىِٕفَةࣱ مِّنَ ٱلَّذِینَ مَعَكَۚ﴾</q> - نزول الآية، والنسخ فيها{1} ٧٩٥٤٢- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: أنها [أي: سورة المزمل] نزلت بمكة، فهي مكّيّة، إلا آيتين منها، فإنهما نَزَلَتا بالمدينة؛ وهما قوله تعالى: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ﴾</q> إلى آخرها{2}. (ز) ٧٩٥٤٣- عن عبد الله بن عباس -من طريق عكرمة- قال: لَمّا نزل أول المزمل كانوا يقومون نحوًا مِن قيامهم في شهر رمضان، وكان بين أولها وآخرها نحو من سنة{3}. (ز) ٧٩٥٤٤- عن عبد الله بن عباس -من طريق عطاء- <q>﴿يا أيُّها المزمل قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</q>: فلمّا قدم النبي ﷺ المدينة نَسَخَتْها هذه الآية: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ونِصْفَهُ وثُلُثَهُ وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ﴾</q> إلى آخرها{4}. (ز) ٧٩٥٤٥- عن مَسروق بن الأَجْدع الهَمداني -من طريق الشعبي-: هذه الآية: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ونِصْفَهُ وثُلُثَهُ وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ﴾</q> نَسَخَتْ: <q>﴿قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</q>{5}. (ز) ٧٩٥٤٦- عن عكرمة مولى ابن عباس: <q>﴿يا أيُّها المزمل قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</q> الآية، قال: لَبِثوا بذلك سنة، فشَقّ عليهم، وتوَرّمتْ أقدامهم، ثم نَسخَها آخر السورة: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</q>{6}. (١٥/٥٩) ٧٩٥٤٧- عن الحسن البصري، قال: لما نزلت على النبيِّ ﷺ: <q>﴿يا أيُّها المزمل قُمِ اللَّيْلَ﴾</q> قام رسول الله ﷺ وقام المسلمون معه حَوْلًا كاملًا حتى تَورّمتْ أقدامهم، فأنزل الله بعد الحَوْل: <q>﴿إنَّ رَبَّكَ يَعْلَمُ﴾</q> إلى قوله: <q>﴿ما تَيَسَّرَ مِنهُ﴾</q>. قال الحسن: فالحمد لله الذي جَعله تَطوّعًا بعد فريضة، ولابد من قيام الليل{6}. (١٥/٥٩) ٧٩٥٤٨- عن قتادة بن دعامة -من طريق سعيد- قال: فَرض الله قيام الليل في أول هذه السورة، فقام أصحاب النبيِّ ﷺ حتى انتَفختْ أقدامهم، وأَمسَك الله خاتمتها حَوْلًا، ثم أنزل الله التّخفيف في آخرها فقال: <q>﴿عَلِمَ أنْ سَيَكُونُ مِنكُمْ مَرْضى﴾</q> إلى قوله: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</q>، فنَسَخ ما كان قبلها، فقال: <q>﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</q> فريضتان واجبتان، ليس فيهما رخصة{8}. (١٥/٥٨) ٧٩٥٤٩- قال مقاتل بن سليمان: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ﴾</q> إلى الصلاة <q>﴿أدْنى﴾</q> يعني: أقل <q>﴿مِن ثُلُثَيِ اللَّيْلِ﴾</q> وذلك أنّ النبي ﷺ والمؤمنين كانوا يقومون في أول الإسلام من الليل نصفه وثُلثه، وهذا قبل أن تُفرض الصلوات الخمس، فقاموا سنة، فشقّ ذلك عليهم، فنَزَلَت الرّخصة بعد ذلك عند السنة، فذلك قوله: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ ... وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</q> يعني: وأَتِمُّوا الصلوات الخمس، وأَعطُوا الزكاة المفروضة من أموالكم، فنُسِخَ قيام الليل على المؤمنين، وثَبتَ قيام الليل على النبي ﷺ، وكان بين أول هذه السورة وآخرها سنة، حتى فُرضت الصلوات الخمس، والزكاة{9}. (ز) <q>﴿إِنَّ رَبَّكَ یَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَیِ ٱلَّیۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَاۤىِٕفَةࣱ مِّنَ ٱلَّذِینَ مَعَكَۚ﴾</q> - تفسير ٧٩٥٥٠- عن سعيد بن جُبَير -من طريق جعفر-= (ز) ٧٩٥٥١- والحسن البصري -من طريق عباد- <q>﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</q>، قالا: لن تُطيقوه{10}. (١٥/٥٨) ٧٩٥٥٢- عن مجاهد بن جبر: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</q> قال: أنْ خَفّف عنهم في القيام، <q>﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</q> قال: علم أن لن تُطيقوا قيام الليل، <q>﴿فَتابَ عَلَيْكُمْ﴾</q> قال: ثم أنبأنا الله تعالى بخصال المؤمنين، فقال: <q>﴿عَلِمَ أنْ سَيَكُونُ مِنكُمْ مَّرْضى﴾</q> إلى آخر الآية{11}. (١٥/٥٨) ٧٩٥٥٣- عن قتادة بن دعامة، في قوله: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ﴾</q> الآية، قال: أدنى من ثُلثي الليل، وأدنى من نصفه، وأدنى من ثُلثه{11}. (١٥/٥٨) ٧٩٥٥٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</q> قيام الليل كُتب عليكم، <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</q>{13}. (ز) ٧٩٥٥٥- قال عطاء: <q>﴿واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ﴾</q>، يريد: لا يَفوته عِلْمُ ما تَفعلون، أي: أنه يَعلم مقادير الليل والنهار، فيَعلم القَدْر الذي تقومون من الليل{14}. (ز) ٧٩٥٥٦- قال مقاتل بن سليمان: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ﴾</q> إلى الصلاة <q>﴿أدْنى﴾</q> يعني: أقل <q>﴿مِن ثُلُثَيِ اللَّيْلِ﴾</q> ... <q>﴿وطائِفَةٌ مِنَ الَّذِينَ مَعَكَ﴾</q> من المؤمنين يقومون نصفه وثلثه، ويقومون وينامون، <q>﴿واللَّهُ يُقَدِّرُ اللَّيْلَ والنَّهارَ عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</q> يعني: قيام ثُلثي الليل الأول، ولا نصف الليل، ولا ثُلث الليل، <q>﴿فَتابَ عَلَيْكُمْ﴾</q> يعني: فتَجاوز عنكم في التّخفيف بعد قوله: <q>﴿قُمِ اللَّيْلَ إلّا قَلِيلًا﴾</q>{15}. (ز) ٧٩٥٥٧- عن سفيان [الثوري] -من طريق مهران- <q>﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</q>: أن لن تُطيقوه{16}. (ز) <q>﴿إِنَّ رَبَّكَ یَعۡلَمُ أَنَّكَ تَقُومُ أَدۡنَىٰ مِن ثُلُثَیِ ٱلَّیۡلِ وَنِصۡفَهُۥ وَثُلُثَهُۥ وَطَاۤىِٕفَةࣱ مِّنَ ٱلَّذِینَ مَعَكَۚ﴾</q> - آثار متعلقة بالآية ٧٩٥٥٨- عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «خَلّتان لا يُحصيهما رجل مسلم إلا أدخلتاه الجنة، وهما يسير، ومَن يعمل بهما قليل: يُسبّح الله في دُبُر كلّ صلاة عشرًا، ويَحمده عشرًا، ويُكبّره عشرًا». قال: فأنا رأيتُ رسول الله ﷺ يَعقدها بيده، قال: «فتلك خمسون ومائة باللسان، وألف وخمسمائة في الميزان. وإذا أوى إلى فراشه سبّح وحمد وكبّر مائة، قال: فتلك مائة باللسان، وألف في الميزان، فأيّكم يعمل في اليوم الواحد ألفين وخمسمائة سيئة؟!». قالوا: فكيف لا نُحصيهما؟ قال: «ويأتي أحدكم الشيطان وهو في صلاته، فيقول: اذكر كذا، اذكر كذا. حتى يَنفَتل، ولعله لا يَعقل، ويأتيه وهو في مَضجعه فلا يزال ينوّمه حتى ينام»{17}. (ز) <q>﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنَ ٱلۡقُرۡءَانِۚ﴾</q> - تفسير ٧٩٥٥٩- عن ابن عباس، عن النبي ﷺ: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</q>، قال: «مائة آية»{18}. (ز) ٧٩٥٦٠- قال سعيد بن جُبَير: خمسون آية{19}. (ز) ٧٩٥٦١- قال الحسن البصري -من طريق ربيع-: مَن قرأ مائة آية في ليلة لم يُحاجّه القرآن{20}. (ز) ٧٩٥٦٢- عن أبي رجاء محمد، قال: قلتُ للحسن: يا أبا سعيد، ما تقول في رجلٍ قد استَظهر القرآنَ كلّه عن ظهر قلبه، فلا يقوم به، إنما يُصلّي المكتوبة؟ قال: يَتوسّد القرآن، لعن الله ذاك؛ قال الله للعبد الصالح: <q>﴿وإنَّهُ لَذُو عِلْمٍ لِما عَلَّمْناهُ﴾</q> [يوسف:٦٨]، <q>﴿وعُلِّمْتُمْ ما لَمْ تَعْلَمُوا أنْتُمْ ولا آباؤُكُمْ﴾</q> [الأنعام:٩١]. قلت: يا أبا سعيد، قال الله: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</q>! قال: نعم، ولو خمسين آية{20}. (ز) ٧٩٥٦٣- قال إسماعيل السُّدِّيّ -من طريق عثمان-: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</q> مائة آية{20}. (ز) ٧٩٥٦٤- قال مقاتل بن سليمان: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</q> عليكم في الصلاة{23}. (ز) <q>﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنَ ٱلۡقُرۡءَانِۚ﴾</q> - آثار متعلقة بالآية ٧٩٥٦٥- قال كعب الأحبار -من طريق أبي صالح-: مَن قرأ في ليلة مائة آية كُتب من القانتين{20}. (ز) ٧٩٥٦٦- عن مَسروق بن الأَجْدع الهَمداني -من طريق الشعبي- قال: هذه الآية خيرٌ لأمة محمد ﷺ مِن أن يُعطى كلّ رجل مثل الدنيا <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنَ القُرْآنِ﴾</q>{5}. (ز) <q>﴿عَلِمَ أَن سَیَكُونُ مِنكُم مَّرۡضَىٰ وَءَاخَرُونَ یَضۡرِبُونَ فِی ٱلۡأَرۡضِ یَبۡتَغُونَ مِن فَضۡلِ ٱللَّهِ وَءَاخَرُونَ یُقَـٰتِلُونَ فِی سَبِیلِ ٱللَّهِۖ﴾</q> - تفسير ٧٩٥٦٧- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «ما مِن جالبٍ يَجلب طعامًا إلى بلد من بلدان المسلمين، فيَبيعه بسعر يومه، إلا كانت منَزِلَتُه عند الله منزلة الشهيد». ثم قرأ رسول الله ﷺ: <q>﴿وآخَرُونَ يَضْرِبُونَ فِي الأَرْضِ يَبْتَغُونَ مِن فَضْلِ اللَّهِ وآخَرُونَ يُقاتِلُونَ فِي سَبِيلِ اللَّهِ﴾</q>{26}. (١٥/٦٠) ٧٩٥٦٨- عن عمر بن الخطاب -من طريق عبيد الله- قال: ما من حالٍ يأتيني عليه الموت بعد الجهاد في سبيل الله أحبّ إلي من أن يأتيني وأنا بين شُعْبَتَيْ رَحْلي، ألتمس من فضل الله. ثم تلا هذه الآية: <q>﴿وآخَرُونَ يَضْرِبُونَ فِي الأَرْضِ يَبْتَغُونَ مِن فَضْلِ اللَّهِ وآخَرُونَ يُقاتِلُونَ فِي سَبِيلِ اللَّهِ﴾</q>{27}. (١٥/٦٠) ٧٩٥٦٩- قال مقاتل بن سليمان: <q>﴿عَلِمَ أنْ سَيَكُونُ مِنكُمْ مَرْضى﴾</q> فلا يُطيقون قيام [الليل]، <q>﴿وآخَرُونَ يَضْرِبُونَ فِي الأَرْضِ﴾</q> تجارًا <q>﴿يَبْتَغُونَ مِن فَضْلِ اللَّهِ﴾</q> يعني: يَطلبون من فضل الله الرزق، <q>﴿وآخَرُونَ يُقاتِلُونَ فِي سَبِيلِ اللَّهِ﴾</q> ولا يطيقون قيام الليل، فهذه رخصة من الله ﷿ لهم بعد التشديد{23}. (ز) <q>﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنۡهُۚ﴾</q> - تفسير ٧٩٥٧٠- عن عبد الله بن عباس، عن النبيِّ ﷺ: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</q>، قال: «مائة آية»{29}. (١٥/٥٩) ٧٩٥٧١- عن قيس بن أبي حازم، قال: صَلَّيتُ خلف عبد الله بن عباس، فقرأ في أول ركعة بـ<q>﴿الحَمْدُ لِلَّهِ﴾</q>، وأول آية من البقرة، ثم ركع، فلما انصرف أقبَل علينا، فقال: إنّ الله يقول: <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</q>{30}. (١٥/٥٩) ٧٩٥٧٢- عن الحسن البصري -من طريق الربيع بن زيد- <q>﴿فاقْرَءُوا ما تَيَسَّرَ مِنهُ﴾</q>، قال: يعني: في صلاة المغرب والعشاء{31}. (ز) ٧٩٥٧٣- عن جعفر بن محمد -من طريق ابنه موسى- في هذه الآية، قال: ما تَيَسَّرَ لكم فيه خشوع القلب، وصفاء السِّر{32}. (ز) ٧٩٥٧٤- قال مقاتل بن سليمان: <q>﴿فاقْرَءُوا ما تَيَسَّرَ﴾</q> عليكم <q>﴿مِنهُ﴾</q> يعني: من القرآن، فلم يُوقِّت شيئًا في صلواتكم الخمس منه{9}. (ز) <q>﴿فَٱقۡرَءُوا۟ مَا تَیَسَّرَ مِنۡهُۚ﴾</q> - آثار متعلقة بالآية ٧٩٥٧٥- عن أبي سعيد الخدري، قال: أمرنا رسول الله ﷺ أن نقرأ بفاتحة الكتاب، وما تيسّر{34}. (١٥/٥٩) <q>﴿وَأَقِیمُوا۟ ٱلصَّلَوٰةَ وَءَاتُوا۟ ٱلزَّكَوٰةَ وَأَقۡرِضُوا۟ ٱللَّهَ قَرۡضًا حَسَنࣰاۚ﴾</q> - تفسير ٧٩٥٧٦- قال عبد الله بن عباس: <q>﴿وأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾</q>، يريد: ما سوى الزكاة؛ من صِلة الرَّحِم، وقِرى الضيف{35}. (ز) ٧٩٥٧٧- قال الحسن البصري: <q>﴿وأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾</q> هذا في التَّطوّع{36}. (ز) ٧٩٥٧٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</q>: فهما فريضتان واجبتان، لا رخصة لأحد فيهما، فأدّوهما إلى الله -تعالى ذِكْره-{37}٦٨٦٢. (ز) ٦٨٦٢ قال ابنُ عطية (٨/٤٤٨): «والصلاة والزكاة هنا المفروضتان، ومَن قال: إنّ القيام بالليل غير واجب قال: معنى الآية: خُذوا من هذا الثِّقل بما تيسّر وحافِظوا على فرائضكم. ومَن قال: إنّ شيئًا من القيام واجب قال: قرنه الله بالفرائض لأنه فرض». ٧٩٥٧٩- قال مقاتل بن سليمان: <q>﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</q> يعني: وأَتِمُّوا الصلوات الخمس، وأَعطوا الزكاة المفروضة من أموالكم، فنُسِخَ قيام الليل على المؤمنين، وثَبتَ قيام الليل على النبي ﷺ، وكان بين أول هذه السورة وآخرها سنة، حتى فُرضت الصلوات الخمس والزكاة، فهما واجبتان، فذلك قوله: <q>﴿وأَقِيمُوا الصَّلاةَ وآتُوا الزَّكاةَ﴾</q> يقول: وأَعطوا الزكاة من أموالكم، <q>﴿وأَقْرِضُوا اللَّهَ﴾</q> يعني: التَّطوّع <q>﴿قَرْضًا حَسَنًا﴾</q> يعني بالحسن: طيِّبة بها نفسه، يَحتسبها تَطوّعًا بعد الفريضة، <q>﴿وما تُقَدِّمُوا لِأَنْفُسِكُمْ مِن خَيْرٍ﴾</q> يعني: مِن صدقة؛ فريضة كانت أو تَطوّعًا؛ يقول: <q>﴿تَجِدُوهُ عِنْدَ اللَّهِ هُوَ خَيْرًا﴾</q> ثوابًا عند الله في التقديم <q>﴿هُوَ خَيْرًا وأَعْظَمَ أجْرًا﴾</q> يقول: أفضل مما أعطيتم من أموالكم وأعظم أجرًا، يعني: وأكثر خيرًا وأفضل خيرًا في الآخرة، <q>﴿واسْتَغْفِرُوا اللَّهَ﴾</q> من الذّنوب؛ <q>﴿إنَّ اللَّهَ غَفُورٌ﴾</q> لكم عند الاستغفار إذا استغفرتموه، <q>﴿رَحِيمٌ﴾</q> حين رخّص لكم بالتوبة{9}. (ز) ٧٩٥٨٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَقْرِضُوا اللَّهَ قَرْضًا حَسَنًا﴾</q>، قال: القرض: النوافل، سوى الزكاة{37}. (ز) ",footnotes:1:تقدم في أول السورة آثار في ذلك.أخرجه النحاس في الناسخ والمنسوخ ص٧٥١، من طريق يموت بن المُزَرِّع، عن أبي حاتم سهل بن محمد السِّجستاني، عن أبي عبيدة معمر بن المثنى، عن يونس بن حبيب، عن أبي عمرو بن العلاء، عن مجاهد، عن ابن عباس به. وسنده صحيح.أخرجه ابن جرير ٢٣/٣٦٢، من طريق سِماك، عن عكرمة، عن ابن عباس به. وسنده ضعيف؛ من أجل رواية سِماك بن حرب عن عكرمة، قال ابن حجر في التقريب (٢٦٢٤): «روايته عن عكرمة خاصة مضطربة».أخرجه القاسم بن سلام في الناسخ والمنسوخ ص٢٥٦ (٤٦٧)، والنحاس في الناسخ والمنسوخ ص٧٥٣، من طريق عطاء الخُراسانيّ، عن ابن عباس به.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٠-.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن نصر في مختصر قيام الليل ص٣، وابن جرير ٢٣/٣٩٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٢-. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٧٨-٤٧٩.أخرجه ابن جرير ٢٣/٣٩٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٣٩٥.تفسير البغوي ٨/٢٥٧.تفسير مقاتل بن سليمان ٤/٤٧٨، ٤٧٩.أخرجه ابن جرير ٢٣/٣٩٤.أخرجه أحمد ١١/٤٠-٤١ (٦٤٩٨)، ١١/٥٠٩-٥١١ (٦٩١٠)، وابن ماجه ٢/٨٦ (٩٢٦)، وأبو داود ٧/٤٠١-٤٠٢ (٥٠٦٥)، والترمذي ٦/٣٣-٣٤ (٣٧٠٩)، والنسائي ٣/٧٤ (١٣٤٨)، وابن حبان ٥/٣٥٤ (٢٠١٢)، ٥/٣٦١-٣٦٢ (٢٠١٨)، وابن جرير ٢٣/٣٩٤-٣٩٥، من طريق عطاء بن السّائِب، عن أبيه، عن عبد الله بن عمرو به. قال الترمذي: «هذا حديث حسن صحيح». وقال النووي في الأذكار ص١٥٢-١٥٣ (٤١١): «إسناده صحيح، إلا أنّ فيه عطاء بن السّائِب، وفيه اختلاف بسب اختلاطه؛ وقد أشار أيوب السّختياني إلى صحة حديثه هذا». وقال المناوي في التيسير ١/٥١٦: «إسناد صحيح».أخرجه الطبراني في الكبير ١١/٢٩ (١٠٩٤٠). وأورده الديلمي في الفردوس ٣/١٥١ (٤٤٠٩). قال ابن كثير في تفسيره ٨/٢٥٩: «وهذا حديث غريب جدًّا». وقال الهيثمي في المجمع ٧/١٣٠ (١١٤٤٧): «فيه عبد الرحمن بن طاووس، ولم أعرفه، وبقية رجاله وُثِّقوا».تفسير الثعلبي ١٠/٦٥.أخرجه ابن جرير ٢٣/٣٩٦.أخرجه ابن جرير ٢٣/٣٩٦.أخرجه ابن جرير ٢٣/٣٩٦.تفسير مقاتل بن سليمان ٤/٤٧٩.أخرجه ابن جرير ٢٣/٣٩٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٠-.أخرجه ابن مردويه -كما في تخريج الكشاف ٤/١١٢-، وفي إسناده فرقد السبخي. قال العراقي في تخريج أحاديث الإحياء ص٥١٦: «سند ضعيف». وقال ابن حجر في الكافِ الشاف ص١٧٩ (٢٤٣): «فرقد ضعيف».أخرجه البيهقي في شعب الإيمان (١٢٥٦). وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٧٩.تقدم تخريجه برقم (٢٣٨).أخرجه الدارقطني ١/٣٣٨، والبيهقي في سننه ٢/٤٠.تفسير الثعلبي ١٠/٦٥، وتفسير البغوي ٨/٢٥٧.أخرجه الثعلبي ١٠/٦٦.تفسير مقاتل بن سليمان ٤/٤٧٨-٤٧٩.أخرجه أحمد ١٧/٣٠ (١٠٩٩٨)، ١٨/١٣ (١١٤١٥)، ١٨/٤١٢ (١١٩٢٢)، وأبو داود ٢/١١١-١١٢ (٨١٨)، وابن حبان ٥/٩٢ (١٧٩٠)، من طريق قتادة، عن أبي نضرة، عن أبي سعيد به. قال ابن حجر في الفتح ٢/٢٤٣: «سند قوي». وقال في التلخيص الحبير ١/٥٦٧: «إسناده صحيح». وقال القاري في مرقاة المفاتيح ٢/٦٨٣: «صحّ عن أبي سعيد». وقال الشوكاني في نيل الأوطار ٢/٢٤٨: «قال ابن سيد الناس: وإسناده صحيح، ورجاله ثقات». وقال الألباني في صحيح أبي داود ٣/٤٠١ (٧٧٧): «إسناده صحيح، على شرط مسلم».تفسير البغوي ٨/٢٥٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٢-.أخرجه ابن جرير ٢٣/٣٩٨.تفسير مقاتل بن سليمان ٤/٤٧٨-٤٧٩.أخرجه ابن جرير ٢٣/٣٩٨.
74,1," مقدمة السورة ٧٩٥٨١- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة المُدَّثِّر بمكة{1}. (١٥/٦١) ٧٩٥٨٢- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٦١) ٧٩٥٨٣- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكّيّة، ونزلت بعد: <q>﴿يا أيُّها المُزَّمِّل﴾</q>{3}. (ز) ٧٩٥٨٤- عن عكرمة مولى ابن عباس= (ز) ٧٩٥٨٥- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز) ٧٩٥٨٦- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٧٩٥٨٧- عن محمد بن مسلم الزُّهريّ: مكّيّة،، وذكرها بمسمّى: <q>﴿يا أيها المُدَّثِّر﴾</q>، وأنها نزلت بعد: <q>﴿يا أيُّها المُزَّمِّل﴾</q>{6}. (ز) ٧٩٥٨٨- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٧٩٥٨٩- قال مقاتل بن سليمان: سورة المُدَّثِّر مكّيّة، عددها ست وخمسون آية كوفي{8}٦٨٦٣. (ز) ٦٨٦٣ قال ابن عطية (٨/٤٥٠): «وهي مكّيّة بإجماع من أهل التأويل». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٥٧) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤، من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٨٧.
74,2," <q>﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١ قُمۡ فَأَنذِرۡ ۝٢﴾</q> - نزول الآيات ٧٩٥٩٠- عن يحيى بن أبي كَثِير، قال: سألتُ أبا سَلمة بن عبد الرحمن عن أول ما نَزَل من القرآن. فقال: <q>﴿يا أيُّها المُدَّثِّر﴾</q>. قلتُ: يقولون: <q>﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</q>. فقال أبو سَلمة: سألتُ جابر بن عبد الله عن ذلك، قلتُ له مثل ما قلتَ، قال جابر: لا أُحدِّثك إلا ما حَدَّثنا رسول الله ﷺ، قال: «جاورتُ بحِراء، فلمّا قَضيتُ جواري هبَطتُ، فنُوديتُ، فنَظرتُ عن يميني، فلم أرَ شيئًا، ونظرتُ عن شمالي، فلم أرَ شيئًا، ونظرتُ خلفي، فلم أرَ شيئًا، فرفعتُ رأسي فإذا المَلَك الذي جاءني بحِراء جالس على كرسي بين السماء والأرض، فجُئِثْتُ{1} منه رُعبًا، فرجعتُ فقلتُ: دَثِّروني، فدَثَّروني»، فنزلت: <q>﴿يا أيُّها المُدَّثِّر قُمْ فَأَنْذِرْ﴾</q> إلى قوله: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>{2}٦٨٦٤. (١٥/٦١) ٦٨٦٤ رجّح ابنُ كثير (١٤/١٧٦) بهذا الأثر أنّ الآيات الأولى من سورة اقرأ هي أول آيات القرآن نزولًا، حيث قال معلقًا على هذا الأثر: «هذا السياق هو المحفوظ، وهو يقتضي أنه قد نَزل الوحي قبل هذا؛ لقوله: «فإذا المَلَك الذي جاءني بحِراء». وهو جبريل حين أتاه بقوله: <q>﴿اقرأ باسم ربك الذي خلق ...﴾</q>، ثم إنه حَصل بعد هذا فترة، ثم نزل الملك بعد هذا». ثم وجّه ما جاء في بعض الروايات عن جابر وتفيد أنّ آيات المُدَّثِّر هي أول آيات القرآن نزولًا بقوله: «ووجه الجمع: أنّ أول شيء نَزل بعد فترة الوحي هذه السورة». وبنحوه قال ابنُ تيمية (٦/٤١٩). ٧٩٥٩١- عن عبد الله بن عباس -من طريق ابن أبي مُلَيْكَة-: أنّ الوليد بن المُغيرة صَنع لقريش طعامًا، فلمّا أكلوا قال: ما تقولون في هذا الرجل؟ فقال بعضهم: ساحر. وقال بعضهم: ليس بساحر. وقال بعضهم: كاهن. وقال بعضهم: ليس بكاهن. وقال بعضهم: شاعر. وقال بعضهم: ليس بشاعر. وقال بعضهم: سحرٌ يُؤثر. فاجتمع رأيهم على أنه سحرٌ يُؤثر، فبَلغ ذلك النبيَّ ﷺ، فحَزن، وقنَّع رأسه، وتَدثّر؛ فأنزل الله: <q>﴿يا أيُّها المُدَّثِّر﴾</q> إلى قوله: <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q>{3}. (١٥/٦٢) ٧٩٥٩٢- عن إبراهيم النَّخَعي -من طريق المُغيرة- <q>﴿يا أيُّها المُدَّثِّر﴾</q>، قال: كان مُتَدَثِّرًا في قَطيفة، وذُكر أنّ هذه الآية أول شيء نَزل من القرآن على رسول الله ﷺ، وأنه قيل له: <q>﴿يا أيُّها المُدَّثِّر﴾</q>{4}. (ز) ٧٩٥٩٣- عن محمد ابن شهاب الزُّهريّ -من طريق معمر- قال: فَتَر الوحيُ عن رسول الله ﷺ فَتْرةً، فحَزِن حُزنًا، فجعل يعدو إلى شواهق رؤوس الجبال ليَتَردّى منها، فكلّما أوفى بذُروة جبل تبَدّى له جبريل ﵇، فيقول: إنّك نبي الله. فيَسكن لذلك جأْشه، وتَرجع إليه نفسه؛ فكان النبي ﷺ يُحدِّث عن ذلك، قال: «فبينما أنا أمشي يومًا إذ رأيتُ المَلَك الذي كان يأتيني بحِراء على كرسي بين السماء والأرض، فجُثِثْتُ{5} منه رُعبًا، فرَجعتُ إلى خديجة، فقلتُ: زَمِّلُوني». فزَمَّلناه، أي: فدَثَّرناه؛ فأنزل الله: <q>﴿يا أيُّها المُدَّثِّر قُمْ فَأَنْذِرْ ورَبَّكَ فَكَبِّرْ وثِيابَكَ فَطَهِّرْ﴾</q>. قال الزُّهريّ: فكان أول شيء أُنزل عليه: <q>﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</q> حتى بلغ: <q>﴿ما لَمْ يَعْلَمْ﴾</q>{6}٦٨٦٥. (ز) ٦٨٦٥ لم يذكر ابن جرير (٢٣/٤٠٠-٤٠٣) غير قول الزُّهريّ، وإبراهيم النَّخَعي. ٧٩٥٩٤- عن محمد ابن شهاب الزُّهريّ أنه قال: ... ويزعم ناسٌ أنّ <q>﴿يا أيها المُدَّثِّر﴾</q> أول سورة أُنزِلَتْ عليه، والله أعلم{7}. (ز) ٧٩٥٩٥- قال مقاتل بن سليمان: <q>﴿يا أيُّها المُدَّثِّر﴾</q>، يعني: النبي ﷺ، وذلك أنّ كفار مكة آذَوه، فانطَلق إلى جبل حِراء ليتوارى عنهم، فبينما هو يمشي إذ سمع مناديًا يقول: يا محمد. فنظر يمينًا وشمالًا وإلى السماء، فلم يرَ شيئًا، فمَضى على وجهه، فنُودي الثانية: يا محمد. فنظر يمينًا وشمالًا ومن خلفه، فلم يرَ شيئًا إلا السماء، ففَزع، وقال: لعلّ هذا شيطان يدعوني. فمَضى على وجهه، فنودي في قفاه: يا محمد، يا محمد. فنظر خلفه وعن يمينه وعن شماله، ثم نظر إلى السماء، فرأى مثل السرير بين السماء والأرض، وعليه دَرْبوكة{8} قد غَطَّت الأُفُق، وعليه جبريل ﵇ مثل النور المتوقِّد يتلألأ، حتى كاد أن يَغشى البصر، ففَزع فزعًا شديدًا، ثم وقَع مغشيًّا عليه، ولبث ساعة، ثم أفاق، فقام يمشي -وبه رِعْدة شديدة، ورِجلاه تَصطكّان- راجعًا حتى دخل على خديجة، فدعا بماء، فصَبّه عليه، فقال: دثِّروني. فدَثَّروه بقَطيفة حتى استدفأ، فلمّا أفاق قال: لقد أشفقتُ على نفسي. قالت له خديجة: أبشِر، فواللهِ، لا يسوءُك الله أبدًا؛ لأنك تَصدق الحديث، وتَصِل الرَّحِم، وتَحمل الكَلّ، وتَقري الضيف، وتُعين على نوائب الخير. فأتاه جبريل ﵇ وهو مُتَقنِّع بالقَطيفة، فقال: يا أيها المُتَدَثِّر بقَطيفته، المُتَقَنِّع فيها{9}. (ز) ٧٩٥٩٦- قال يحيى بن سلّام: قال جابر بن عبد الله: <q>﴿يا أيُّها المُدَّثِّر﴾</q> هذه أول آية نزلت على النبي، والعامّة على أنّ أول ما نَزل: <q>﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</q>{10}٦٨٦٦. (ز) ٦٨٦٦ في أول آيات القرآن نزولًا قولان، كما في قول يحيى بن سلام. وقد رجح ابنُ عطية (٨/٤٥١) -مستندًا إلى السنة- أن الآيات الأولى من سورة اقرأ هي أول القرآن نزولًا، فقال: «واختلف الناس في أول ما نزل من كتاب الله تعالى؛ فقال جابر بن عبد الله، وأبو سلمة، والنَّخَعي، ومجاهد هو: <q>﴿يا أيُّها المُدَّثِّر﴾</q> الآيات. وقال الزُّهريّ، والجمهور هو: <q>﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</q>، وهذا هو الأصح، وحديث صدر كتاب البخاري نص في ذلك». ٧٩٥٩٧- قال ابن هشام: حَدَّثني بعض أهل العلم: أنّ أشدّ ما لقي رسول الله ﷺ من قريش أنه خرج يومًا فلم يَلقه أحد من الناس إلا كَذَّبه وآذاه، لا حرٌّ ولا عبدٌ، فرجع رسول الله ﷺ إلى منزله، فتَدثَّر من شدّة ما أصابه؛ فأَنزل الله تعالى عليه: <q>﴿يا أيها المُدَّثِّر قم فأنذر﴾</q>{11}. (ز) <q>﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١﴾</q> - تفسير ٧٩٥٩٨- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿يا أيُّها المُدَّثِّر﴾</q>، قال: دُثِّرْتَ هذا الأمرَ، فقُم به{12}. (١٥/٦٣) ٧٩٥٩٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿يا أيُّها المُدَّثِّر﴾</q>، قال: النائم{13}. (١٥/٦٤) ٧٩٦٠٠- عن إبراهيم النَّخَعي-من طريق المغيرة- <q>﴿يا أيُّها المُدَّثِّر﴾</q>، قال: كان مُتَدَثِّرًا في قَطيفة، يعني: شَملة صغيرة الخَمْلِ{14}. (١٥/٦٣) ٧٩٦٠١- عن عكرمة مولى ابن عباس -من طريق داود- في قوله: <q>﴿يا أيُّها المُدَّثِّر﴾</q>، أنه قال: دُثِّرْتَ هذا الأمر فقُم به{15}. (ز) ٧٩٦٠٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يا أيُّها المُدَّثِّر﴾</q>، قال: المُتَدَثِّر في ثيابه{16}. (١٥/٦٣) ٧٩٦٠٣- قال مقاتل بن سليمان: <q>﴿يا أيُّها المُدَّثِّر﴾</q> يعني: النبي ﷺ ... أتاه جبريل ﵇ وهو مُتَقنِّع بالقَطيفة، فقال: يا أيها المُتَدَثِّر بقَطيفته، المُتَقَنِّع فيها{9}. (ز) <q>﴿قُمۡ فَأَنذِرۡ ۝٢﴾</q> - تفسير ٧٩٦٠٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قُمْ فَأَنْذِرْ﴾</q>، قال: أنذِر عذابَ ربك، ووقائعَه في الأمم، وشدّة نِقمته إذا انتقم{16}. (١٥/٦٣) ٧٩٦٠٥- قال مقاتل بن سليمان: <q>﴿قُمْ فَأَنْذِرْ﴾</q> كفارَ مكةَ العذابَ إن لم يُوحِّدوا الله تعالى{9}. (ز) ",footnotes:1:أي: ذُعرتُ وخِفتُ. يُقال: جُئِث الرجل: إذا فزع. النهاية (جأث).أخرجه البخاري ٦/١٦١-١٦٢ (٤٩٢٢- ٤٩٢٤)، ومسلم ١/١٤٤ (١٦١)، وابن جرير ٢٣/٤٠٠-٤٠٣، وابن مردويه -كما في التغليق ٤/٣٥٤-، والثعلبي ١٠/٦٧-٦٨.أخرجه الطبراني في الكبير ١١/١٢٥ (١١٢٥٠). قال الهيثمي في المجمع ٧/١٣١ (١١٤٤٨): «وفيه إبراهيم بن يزيد الخوزي، وهو متروك». وقال السيوطي: «سند ضعيف».أخرجه ابن جرير ٢٣/٤٠٠.أي: فزعت منه وخفت. وقيل معناه: قلعت من مكاني، من قوله تعالى: <q>﴿اجتثت من فوق الأرض﴾</q> [إبراهيم:٢٦]، وقال الحربي: أراد جُئِثت، فجعل مكان الهمزة ثاء. النهاية (جثث).أخرجه عبد الرزاق ٢/٣٢٧، وابن جرير ٢٣/٤٠٣.أخرجه البيهقي في دلائل النبوة ٢/١٤٢.دَرْبوكة: في كتاب «تكملة المعاجم العربية» لرينهارت بيتر ٤/٣١٤: دَرْبوكة: محفَّة، مَحْمَل ... دربوكة بالكاف الفارسية، وهي شبه قفص من الخشب تنقل فيه العروس الشابة يوم الزفاف من بيت أهلها إلى بيت الزوجية.تفسير مقاتل بن سليمان ٤/٤٨٩-٤٩٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٤-.سيرة ابن هشام ١/٢٧٤-٢٧٥.أخرجه الحاكم ٢/٥٠٦.أخرجه ابن جرير ٢٣/٤٠٤ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٣/٤٠٠، وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٠٤.أخرجه ابن جرير ٢٣/٤٠٤. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨٩-٤٩٠.أخرجه ابن جرير ٢٣/٤٠٤. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٨٩-٤٩٠.
74,3," <q>﴿وَرَبَّكَ فَكَبِّرۡ ۝٣﴾</q> - تفسير ٧٩٦٠٦- عن أبي مالك غَزْوان الغفاري، <q>﴿ورَبَّكَ فَكَبِّرْ﴾</q>، قال: عَظِّم{1}. (١٥/٦٤) ٧٩٦٠٧- قال مقاتل بن سليمان: <q>﴿ورَبَّكَ فَكَبِّرْ﴾</q> يعني: فعَظِّم، ولا تعظمن كفار مكة في نفسك. فقام من مضجعه ذلك، فقال: «الله أكبر كبيرًا». فكبّرتْ خديجة، وخَرجتْ، وعَلمتْ أنه قد أُوحي إليه{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٠.
74,4," <q>﴿وَثِیَابَكَ فَطَهِّرۡ ۝٤﴾</q> - تفسير ٧٩٦٠٨- قال أُبيّ بن كعب: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q> لا تلبسها على غَدرٍ، ولا على ظُلمٍ، ولا إثم، البسْها وأنت بَرٌّ جواد طاهر{1}. (ز) ٧٩٦٠٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: لا تَكُن ثيابُك التي تلبِس من مَكْسِبة{2} باطل{3}. (١٥/٦٤) ٧٩٦١٠- عن عبد الله بن عباس -من طريق عطاء- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: من الإثم. قال: وهي في كلام العرب: نقيُّ الثياب{4}. (١٥/٦٤) ٧٩٦١١- عن عبد الله بن عباس، في قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: مِن الغدر، لا تَكُن غدّارًا{5}. (١٥/٦٥) ٧٩٦١٢- عن عبد الله بن عباس، <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: لستَ بساحر، ولا كاهن{5}. (١٥/٦٦) ٧٩٦١٣- عن عكرمة: أنّ عبد الله بن عباس سُئل عن قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>. قال: لا تَلبسها على غَدْرةٍ، ولا فَجْرةٍ. ثم قال: ألا تسمعون قول غَيلان بن سَلمة: وإني بحمد الله لا ثوبَ فاجرٍ لَبِستُ ولا من غَدْرةٍ أتقنّع{7}. (١٥/٦٥) ٧٩٦١٤- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق منصور- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: عمَلك أصلِحْهُ، كان أهل الجاهلية إذا كان الرجل حسنَ العمل قالوا: فلانٌ طاهر الثياب{8}. (١٥/٦٥) ٧٩٦١٥- عن سعيد بن جُبَير، قال: كان الرجل في الجاهلية إذا كان غدّارًا قالوا: فلانٌ دَنِسُ الثياب{9}. (١٥/٦٥) ٧٩٦١٦- قال سعيد بن جُبَير: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q> وقلبك ونيَّتك فطهِّر{10}. (ز) ٧٩٦١٧- عن إبراهيم النَّخَعي، <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: مِن الإثم{11}. (١٥/٦٣) ٧٩٦١٨- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: وعمَلَك فأصلِح{12}. (١٥/٦٦) ٧٩٦١٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: لستَ بكاهن، ولا ساحر؛ فأَعرِض عما قالوا{13}. (١٥/٦٦) ٧٩٦٢٠- عن مجاهد بن جبر، <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: ليس ثيابه الذي يَلبس{14}. (١٥/٦٦) ٧٩٦٢١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، يقول: لا تَلبس ثيابك على معصية{15}. (ز) ٧٩٦٢٢- عن الضَّحّاك بن مُزاحِم-من طريق أبي روق- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>: وعمَلك فأصلِح{16}. (ز) ٧٩٦٢٣- عن عكرمة مولى ابن عباس -من طريق الأَجْلَح- قال: لا تَلبس ثيابك على معصية{17}. (ز) ٧٩٦٢٤- عن أبي مالك غَزْوان الغفاري، <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: عَنى نفسه{14}. (١٥/٦٦) ٧٩٦٢٥- عن عامر الشعبي= (ز) ٧٩٦٢٦- وعطاء -من طريق جابر- قالا: من الخطايا{17}. (ز) ٧٩٦٢٧- قال طاووس بن كيسان: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q> وثيابك فقصِّر؛ لأنّ تقصير الثياب طُهرةٌ لها{10}. (ز) ٧٩٦٢٨- عن الحسن البصري، في قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: خُلُقك فحَسِّنه{21}. (١٥/٦٦) ٧٩٦٢٩- عن محمد بن سيرين -من طريق ابن عون- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: اغسلها بالماء{22}. (١٥/٦٧) ٧٩٦٣٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، يقول: طهِّرها من المعاصي، وهي كلمة عربية، كانت العرب إذا نَكث الرجل ولم يُوفِ بعهده قالوا: إنّ فلانًا لَدَنِسُ الثياب. وإذا وفى وأَصلَح قالوا: إنّ فلانًا لَطاهرُ الثياب{23}. (١٥/٦٣) ٧٩٦٣١- قال محمد بن كعب القُرَظيّ: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q> وخُلقك فحسِّن{10}. (ز) ٧٩٦٣٢- عن محمد ابن شهاب الزُّهريّ: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q> نفسك فطهِّر عن الذّنب{25}. (ز) ٧٩٦٣٣- قال إسماعيل السُّدِّيّ: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q> يقال للرجل إذا كان صالحًا: إنّه لَطاهرُ الثياب، وإذا كان فاجرًا: إنّه لَخبيث الثياب{16}. (ز) ٧٩٦٣٤- عن يزيد بن مَرثَد، في قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>: أنه أُلقي على رسول الله ﷺ سلا{27} شاة{21}. (١٥/٦٧) ٧٩٦٣٥- قال مقاتل بن سليمان: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، يقول: طهِّر بالتوبة من المعاصي. وكانت العرب تقول للرجل إذا أذنب: إنّه دَنِس الثياب، وإذا تَوقّى قالوا: إنّه لَطاهرُ الثياب{29}. (ز) ٧٩٦٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وثِيابَكَ فَطَهِّرْ﴾</q>، قال: كان المشركون لا يَتطهَّرون، فأمره أن يَتطهَّر، ويُطهِّر ثيابه{30}٦٨٦٧. (ز) ٦٨٦٧ اختُلف في قوله: <q>﴿وثيابك فطهر﴾</q> على أقوال: الأول: لا تَلبس ثيابك على معصية، ولا على غَدْرة. الثاني: لا تَلبس ثيابك من مَكسبٍ غير طيّب. الثالث: أصلِح عملك. الرابع: اغسلها بالماء، وطهِّرها من النجاسة. الخامس: حَسِّن خُلقك. السادس: طهِّر قلبك ونيّتك. وعلّق ابنُ عطية (٨/٤٥٢) على القول الأول والثاني بقوله: «وهذا كلّه معنًى قريب بعضه من بعض». وقد رجّح ابنُ جرير (٢٣/٤٠٩-٤١٠) -مستندًا إلى أنه الأظهر- القول الرابع، فقال: «وهذا القول الذي قاله ابن سيرين، وابن زيد في ذلك أظهر معانيه». ثم قال معلقًا: «والذي قاله ابن عباس، وعكرمة، ومَن ذكرنا قوله عليه أكثر السلف من أنه عني به: جسمك فطَهِّر من الذّنوب. والله أعلم بمراده من ذلك». ولم يذكر ابنُ تيمية (٦/٤٢٠-٤٢٢) غير القول الثالث والرابع، ورجّح أنّ الآية تعمّهما، فقال: «والأشبه -والله أعلم- أنّ الآية تعمُّ نوعي الطهارة، وتشمل هذا كلَّه، فيكون مأمورًا بتطهير الثياب المتضمّنة تطهير البدن والنفس مِن كلّ ما يُستقذر شرعًا مِن الأعيان والأخلاق والأعمال؛ لأنّ تطهيرها أن تُجعل طاهرة، ومتى اتصل بها وبصاحبها شيءٌ مِن النجاسة لم تكن مُطهّرة على الإطلاق؛ فإنها متى أُزيل عنها نَجسٌ دون نَجس لم تكن قد طَهرتْ حتى يزال عنها كلّ نَجس، بل كلّ ما أمر الله باجتنابه من الأرجاس وجَب التطهير منه، وهو داخل في عموم هذا الخطاب». ",footnotes:1:تفسير الثعلبي ١٠/٦٨، وتفسير البغوي ٨/٢٦٤.المَكْسِبة والكسب والكِسبة بمعنًى. التاج (كسب).أخرجه ابن جرير ٢٣/٤٠٨ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٣/٤٠٦، وفي لفظ عنده: من الذنوب، والحاكم ٢/٥٠٦. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٤٠٥. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن الأنباري في الوقف والابتداء، وابن مردويه.أخرجه ابن جرير ٢٣/٤٠٩، وابن أبي شيبة ١٣/٤١٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٥.عزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر. وأخرجه ابن جرير ٢٣/٤٠٦ من طريق مغيرة بلفظ: من الذّنوب.أخرجه ابن جرير ٢٣/٤٠٨. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٠٧.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٤.أخرجه ابن جرير ٢٣/٤٠٨.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٠٨.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٠٧، وعبد الرزاق ٢/٣٢٧-٣٢٨ من طريق معمر بنحوه، وكذا ابن جرير. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٤- بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٥.تفسير الثعلبي ١٠/٦٨، وتفسير البغوي ٨/٢٦٤، وجاء عقبه: فكنى عن النفس بالثوب.تفسير الثعلبي ١٠/٦٩، وتفسير البغوي ٨/٢٦٤.السلا: الجلد الرقيق الذي يخرج فيه الولد مِن بطن أمه ملفوفًا فيه، وقيل في الماشية: السلا، وفي الناس: المشيمة. والأول أشبه؛ لأنّ المشيمة تخرج بعد الولد، ولا يكون فيها حين يخرج. النهاية ٢/٣٩٦.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤٠٩.
74,5," <q>﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ ۝٥﴾</q> - قراءات ٧٩٦٣٧- عن جابر بن عبد الله، قال: سمعتُ رسول الله ﷺ يقرأ: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q> برفع الراء ...{1}. (١٥/٦٧) ٧٩٦٣٨- عن عبد الله بن مسعود، أنه قرأ على رسول الله ﷺ: ‹والرِّجْزَ فاهْجُرْ› بالكسر{2}. (١٥/٦٧) ٧٩٦٣٩- عن أبي محمد يحيى بن زكريا الكوفي -ويُعرف بابن أبي الحواجب-، قال: كنت آخِذًا بيد الأعمش أقوده، فقلت له: كيف تقرأ: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q> أو ‹والرِّجْزَ فاهْجُرْ›؟ فقال: أوَهمَّك ذلك؟ قرأتُ القرآن على يحيى بن وثّاب ثلاثين مرة كلّه يقرأ كذلك، وكذلك قرأ يحيى على عَلقمة، وكذلك قرأ عَلقمة على ابن مسعود، وابن مسعود على رسول الله ﷺ، يعني: <q>﴿الرُّجْزَ﴾</q> بالضم{3}. (ز) ٧٩٦٤٠- عن الحسن البصري، أنه كان يقرؤها: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q> بالرفع ...{4}٦٨٦٨. (١٥/٦٧) ٦٨٦٨ ذكر ابن جرير (٢٣/٤١٠) قراءة الرفع والكسر، ووجّههما، فقال: «فمَن ضَم الراء وجّهه إلى الأوثان، وقال: معنى الكلام: والأوثان فاهجُر عبادتها، واترك خدمتها. ومَن كسر الراء وجّهه إلى العذاب، وقال: معناه: والعذاب فاهجُر. أي: ما أوجب لك العذاب من الأعمال فاهجُر». وعلّق عليهما قائلًا: «والصواب من القول في ذلك أنهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب، والضم والكسر في ذلك لغتان بمعنًى واحد، ولم نجد أحدًا من متقدمي أهل التأويل فَرّق بين تأويل ذلك، وإنما فَرّق بين ذلك فيما بلغنا الكسائي». وعلّق ابنُ عطية (٥/٣٩٣ ط: دار الكتب العلمية بتصرف) على القراءتين بقوله: «قيل: هما بمعنًى، يراد بهما: الأصنام والأوثان، وقيل: هما لمعنيين: الكسر للنّتن والنقائص وفُجور الكفار، والضم لصنمين إساف ونائلة». <q>﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ ۝٥﴾</q> - تفسير الآية ٧٩٦٤١- عن جابر بن عبد الله، قال: سمعتُ رسول الله ﷺ يقرأ: <q>﴿والرُّجْز فاهْجُرْ﴾</q> برفع الراء، وقال: «هي الأوثان»{5}. (١٥/٦٧) ٧٩٦٤٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: الأصنام{6}. (١٥/٦٤) ٧٩٦٤٣- عن عبد الله بن عباس، <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>: معناه: اترك المآثم{7}٦٨٦٩. (ز) ٦٨٦٩ ذكر ابنُ عطية (٨/٤٥٢) قولًا آخر عن ابن عباس، فقال: «وقال ابن عباس: الرُّجز: السخط». ثم وجّهه بقوله: «فالمعنى: اهجر ما يؤدي إليه، ويُوجبه». ٧٩٦٤٤- قال أبو العالية الرِّياحيّ= (ز) ٧٩٦٤٥- والربيع بن أنس: <q>﴿الرُّجز﴾</q> -بضم الراء-: الصنم. -وبالكسر-: النجاسة والمعصية{8}. (ز) ٧٩٦٤٦- عن إبراهيم النَّخَعي -من طريق مغيرة- <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: الإثم{9}. (١٥/٦٣) ٧٩٦٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: الأوثان{10}. (١٥/٦٦) ٧٩٦٤٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، يقول: اهجر المعصية{11}. (ز) ٧٩٦٤٩- قال الضَّحّاك بن مُزاحِم: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، يعني: الشّرك{7}. (ز) ٧٩٦٥٠- عن أبي مالك غَزْوان الغفاري، <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: الشيطان، والأوثان{13}. (١٥/٦٤) ٧٩٦٥١- عن عكرمة مولى ابن عباس -من طريق جابر- <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: الأوثان{14}. (ز) ٧٩٦٥٢- عن الحسن البصري أنه كان يقرؤها: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q> بالرفع، وقال: هي الأوثان{4}. (١٥/٦٧) ٧٩٦٥٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: هما صنمان كانا عند البيت؛ إساف ونائلة، يَمسح وجوههما مَن أتى عليهما من المشركين، فأمر الله نبيَّه ﷺ أن يَهجرهما ويُجانبهما{16}. (١٥/٦٣) ٧٩٦٥٤- عن محمد ابن شهاب الزُّهريّ -من طريق معمر- <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: هي الأوثان{17}. (ز) ٧٩٦٥٥- عن عطاء الخراساني -من طريق يونس بن يزيد- <q>﴿والرجز فاهجر﴾</q>، قال: الأوثان{18}. (ز) ٧٩٦٥٦- قال محمد بن السّائِب الكلبي: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، يعني: العذاب{7}. (ز) ٧٩٦٥٧- قال مقاتل بن سليمان: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q> يعني: الأوثان؛ يساف ونائلة، وهما صنمان عند البيت، يَمسح وجوهَهما مَن مَرّ بهما مِن كفار مكة، فأمَر الله -تبارك وتعالى- النبيَّ ﷺ أن يجتنبهما. يعني بالرجز: أوثانًا لا تَتحرّك، بمنزلة الإبل، يعني: داء يأخذها ذلك الداء فلا تَتحرّك مِن وجع الرّجز، فشبّه الآلهة بها{20}. (ز) ٧٩٦٥٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿والرُّجْزَ فاهْجُرْ﴾</q>، قال: الرُّجز: آلهتهم التي كانوا يَعبدون، أمَره أن يَهجرها، فلا يأتيها، ولا يَقربها{14}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٢٧٥ (٢٩٩٢)، من طريق محمد بن كثير المصيصي، عن معمر، عن الزُّهريّ، عن أبي سَلمة بن عبد الرحمن، عن جابر بن عبد الله به. قال ابن عدي في الكامل ٧/٥٠٠-٥٠١ (١٧٣٢) في ترجمة محمد بن كثير أبي يوسف المصيصي: «حدثنا ابن حماد، حدثني عبد الله بن أحمد، سمعت أبي، وذكر محمد بن كثير المصيصي فضعّفه جدًّا، وقال: سمع من معمر، ثم بَعَث إلى اليمن بعد، فأخذها، فرواها. يعني: أحاديث معمر. وقال: هو منكر الحديث. أو قال: هو يروي أشياء مُنكرة». ثم ذكر الحديث، وقال عقبه: «ومحمد بن كثير له روايات عن معمر، والأوزاعي خاصة، أحاديث عداد مما لا يُتابعه أحد عليه». والقراءة متواترة، قرأ بها يعقوب، وأبو جعفر، وحفص، وقرأ بقية العشرة: ‹والرِّجْزَ› بكسر الراء. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٧١.أخرجه الطبراني (١٠٠٧٠)، والحاكم ٢/٢٥١. وعزاه السيوطي إلى ابن مردويه. وصححه الحاكم.ذكره في الإيماء ٤/٥١٤ (٤٠٧٠)، وعزاه إلى الأفراد لابن شاهين (٤٩).عزاه السيوطي إلى عَبد بن حُمَيد.تقدم تخريجه في قراءات الآية.أخرجه ابن جرير ٢٣/٤١٠ بنحوه، ومن طريق علي بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.تفسير البغوي ٨/٢٦٥.أخرجه ابن جرير ٢٣/٤١١. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١١، كذلك من طريق جابر أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٢.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١١.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤١١. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٢٨، وابن جرير ٢٣/٤١١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٥.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤١١.
74,6," <q>﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾</q> - قراءات ٧٩٦٥٩- عن حمّاد بن أبي سليمان، قال: قرأتُ في مصحف أُبيّ [بن كعب]: (ولا تَمْنُنْ أن تَستَكْثِر){1}. (١٥/٦٨) ٧٩٦٦٠- قال يحيى بن سلام: وكان الحسن البصري يقرؤها: (تَسْتَكْثِرْ) موقوفة{2}٦٨٧٠. (ز) ٦٨٧٠ علق ابنُ عطية (٨/٣٩٣ ط: دار الكتب العلمية) على هذه القراءة، فقال: «وقرأ الحسن بن أبي الحسن: (تَسْتَكْثِرْ) بجزم الراء، وذلك كأنه قال: لا تَسْتَكْثِرْ». <q>﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾</q> - تفسير الآية ٧٩٦٦١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ الرجل عطاءً رجاءَ أن يُعطيك أكثر منه{3}. (١٥/٦٨) ٧٩٦٦٢- عن عبد الله بن عباس، <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q> قال: لا تَقُلْ: قد دَعوتُهم فلم يُقبل مني. عُد، فادْعُهم، <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q> على ذلك{4}. (١٥/٦٩) ٧٩٦٦٣- عن عبد الله بن عمر -من طريق نافع- <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ شيئًا تَطلب أكثر منه{5}. (ز) ٧٩٦٦٤- عن أبي الأَحْوَص= (ز) ٧٩٦٦٥- وضَمْرة بن حبيب -من طريق أرطاة- في قوله: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ شيئًا لِتُعطى أكثر منه{6}. (ز) ٧٩٦٦٦- عن إبراهيم النَّخَعي -من طريق مُغيرة- <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ شيئًا لِتُعطى أكثرَ منه{7}. (١٥/٦٣) ٧٩٦٦٧- قال مجاهد بن جبر: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q> كان هذا للنبيِّ ﷺ خاصة{8}. (ز) ٧٩٦٦٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ مُصانعةً؛ رجاء أفضل منه من الثواب{9}. (١٥/٦٦) ٧٩٦٦٩- عن مجاهد بن جبر -من طريق خُصَيف- في قوله: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تَضْعُف أن تَستَكْثِر من الخير. قال: <q>﴿تَمْنُن﴾</q> في كلام العرب: تَضْعُف{10}. (ز) ٧٩٦٧٠- عن مجاهد بن جبر، <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعَظِّم عملَك في عينك أن تَستَكْثِر من الخير{11}. (١٥/٦٨) ٧٩٦٧١- قال الضَّحّاك بن مُزاحِم -من طريق أبي حُجَيرة-: هما رِبَوان؛ حلال وحرام، فأمّا الحلال فالهدايا، وأمّا الحرام فالربا{12}. (ز) ٧٩٦٧٢- عن الضَّحّاك بن مُزاحِم، <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ شيئًا لتُعطى أكثر منه، وهي للنبي ﷺ خاصة، والناس مُوَسَّع عليهم{13}. (١٥/٦٨) ٧٩٦٧٣- عن عكرمة مولى ابن عباس: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، يقول: ولا تُعطِ شيئًا لتُعطى أكثر منه، وإنما نزل هذا في النبيِّ ﷺ{14}. (١٥/٦٨) ٧٩٦٧٤- قال طاووس بن كيسان -من طريق ابنه-= (ز) ٧٩٦٧٥- وقتادة بن دعامة -من طريق معمر - <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ شيئًا لتُثاب أفضل منه{15}. (ز) ٧٩٦٧٦- عن الحسن البصري، (ولا تَمْنُن تَسْتَكْثِرْ)، قال: لا تَستَكْثِر عملك{16}. (١٥/٦٨) ٧٩٦٧٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تُعطِ شيئًا لمثابة الدنيا، ولا لِمُجازاة الناس{17}. (١٥/٦٣) ٧٩٦٧٨- قال محمد بن كعب القُرَظيّ: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q> لا تُعطِ مالَك مُصانعة{18}. (ز) ٧٩٦٧٩- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا يَكثُر عملك في عينك، فإنه فيما أنعم الله عليك وأعطاك قليل{19}. (ز) ٧٩٦٨٠- قال مقاتل بن سليمان: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، يقول: ولا تُعطِ عطيةً لِتُعطى أكثر من عَطِيّتك{20}. (ز) ٧٩٦٨١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾</q>، قال: لا تَمْنُن بالنبوة والقرآن الذي أرسلناك به تَسْتَكْثِرهم به، تأخذ عليه عِوضًا من الدنيا{10}٦٨٧١. (ز) ٦٨٧١ اختُلف في قوله: <q>﴿ولا تمنن تستكثر﴾</q> على أقوال: الأول: ولا تُعطِ -يا محمد- عَطِيّة لِتُعطى أكثر منها. الثاني: ولا تَمْنُن عملك على ربّك تَسْتَكْثِر. الثالث: لا تَضْعُف أن تَسْتَكْثِر من الخير. الرابع: لا تَمْنُن بالنبوة على الناس، تأخذ عليه منهم أجرًا. ووجّه ابنُ عطية (٨/٤٥٣) القول الأول، فقال: «فكأنه من قولهم: مَنَّ إذا أعطى، وقال الضَّحّاك: وهذا خاصٌّ بالنبي ﵇، ومباح لأُمّته، لكن لا أجر لهم فيه. قال مكي: وهذا معنى قوله تعالى: <q>﴿وما آتَيْتُمْ مِن رِبًا لِيَرْبُوا فِي أمْوالِ النّاسِ فَلا يَرْبُوا عِنْدَ اللَّهِ﴾</q> [الروم:٣٩]». وانتقده مستندًا للسياق، فقال: «وهذا معنًى أجنبي مِن معنى هذه السورة». وعلّق على القول الثاني بقوله: «ففي هذا التأويل تحريض على الجد، وتخويف». وعلّق على القول الثالث، فقال: «وقال مجاهد: معناه: ولا تَضْعُف تَسْتَكْثِر ما حمّلناك من أعباء الرسالة وتَسْتَكْثِر من الخير. فهذه من قولهم: حبل منين، أي: ضعيف». وقد رجح ابنُ جرير (٢٣/٤١٧) -مستندًا إلى السياق، والقراءات- القول الثاني، فقال: «وإنما قلتُ ذلك أولى بالصواب؛ لأن ذلك في سياق آيات تَقدّم فيهنّ أمْر الله نبيّه ﷺ بالجد في الدعاء إليه، والصبر على ما يَلقى من الأذى فيه، فهذه بأن تكون من أنواع تلك أشبه منها بأن تكون من غيرها. وذكر عن عبد الله بن مسعود أنّ ذلك في قراءته: (ولا تَمْنُنْ أن تَسْتَكْثِر)». ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٥-. وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة، تروى أيضًا عن عبد الله بن مسعود. انظر: مختصر ابن خالويه ص١٦٤.تفسير ابن أبي زمنين ٥/٥٥. وهي قراءة شاذة. انظر: المحتسب ٢/٢٣٧.أخرجه ابن جرير ٢٣/٤١٢، والطبراني (١٢٦٧٢)، والبيهقي ٧/٥١ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢٢ (٢٣١١٦).أخرجه ابن جرير ٢٣/٤١٢.أخرجه ابن جرير ٢٣/٤١٣، كذلك من طريق منصور بنحوه، وبه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢١ (٢٣١١١). وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٧٠، وتفسير البغوي ٨/٢٦٥.أخرجه ابن جرير ٢٣/٤١٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٦.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٤.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرج شطره الأول ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢١ (٢٣١١٣)، وابن جرير ٢٣/٤١٣ من طريق سلمة بن نُبيط. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٥- بنحوه. وأخرج شطره الثاني ابن جرير ٢٣/٤١٤- ٤١٥ من طريق سفيان عن رجل.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وأخرج شطره الأول ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢١ (٢٣١١٢)، وابن جرير ٢٣/٤١٣ من طريق شعبة، عمن سمع عكرمة.أخرجه عبد الرزاق ٢/٣٢٨، وابن جرير ٢٣/٤١٤.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرج تفسيره ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٥٢٢ (٢٣١١٥)، وابن جرير ٢٣/٤١٥، من طريق سفيان بن حسين، بلفظ: لا تمنن عملك تَسْتَكْثِره على ربك. وعند ابن جرير أيضًا من طريق عوف، وأبي سهل أيضًا. كذلك عند عبد الرزاق في تفسيره ٢/٣٢٨ بلفظ: لا تمنن عملك ولا تَسْتَكْثِر.أخرجه ابن جرير ٢٣/٤١٤. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٧٠.أخرجه ابن جرير ٢٣/٤١٥.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤١٦.
74,7," <q>﴿وَلِرَبِّكَ فَٱصۡبِرۡ ۝٧﴾</q> - تفسير ٧٩٦٨٢- عن إبراهيم النَّخَعي -من طريق مُغيرة- <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q>، قال: إذا أعطيتَ عَطِيّةً فأَعطِها لربّك، واصبر حتى يكون هو الذي يُثيبُك{1}. (١٥/٦٣) ٧٩٦٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q>، قال: على ما أُوذيتَ{2}. (١٥/٦٦) ٧٩٦٨٤- قال زيد بن أسلم: <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q> إذا أعطيتَ عَطِيّة فأَعطِها لربّك، واصبر حتى يكون هو الذي يُثيبُك عليها{3}. (ز) ٧٩٦٨٥- قال مقاتل بن سليمان: <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q> يُعزِّي نبيَّه ﷺ ليَصبر على الأذى والتكذيب من كفار مكة{4}٦٨٧٢. (ز) ٦٨٧٢ قال ابنُ جرير (٢٣/٤١٧): «وقوله: <q>﴿ولربك فاصبر﴾</q> يقول -تعالى ذِكْره-: ولربك فاصبر على ما لَقِيتَ فيه من المكروه. وبنحو الذي قلنا في ذلك قال جماعة من أهل التأويل على اختلاف فيه بين أهل التأويل». ثم ذكر قول مجاهد، وابن زيد، وإبراهيم النَّخَعي. ٧٩٦٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولِرَبِّكَ فاصْبِرْ﴾</q>، قال: حُمِّل أمرًا عظيمًا؛ محاربة العرب، ثم العَجَم من بعد العرب في الله{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٤١٨. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٧٠.تفسير مقاتل بن سليمان ٤/٤٩٠.أخرجه ابن جرير ٢٣/٤١٧.
74,8," <q>﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾</q> - تفسير ٧٩٦٨٧- عن عبد الله بن عباس، قال: لَمّا نزلت: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q> قال رسول الله ﷺ: «كيف أنعَم وصاحبُ الصُّور قد التَقم القَرن، وحَنى جَبهته، يَستمع متى يُؤمر؟!». قالوا: كيف نقول، يا رسول الله؟ قال: «قولوا: حَسْبنا الله ونِعْم والوكيل، على الله توكَّلنا»{1}. (١٥/٦٩) ٧٩٦٨٨- عن عبد الله بن عباس -من طريق العَوفيّ- قوله: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، قال: هو يوم يُنفخ في الصُّور الذي يُنفخ فيه. قال ابن عباس: إنّ نبي الله ﷺ خرج إلى أصحابه، فقال: «كيف أنعَم وصاحب القَرن قد التَقم القَرن، وحَنى جَبهته، ثم أقبل بأُذُنه يَستمع متى يُؤمر بالصيحة». فاشتدّ ذلك على أصحابه، فأمَرهم أن يقولوا: «حَسْبنا الله ونِعْم والوكيل، على الله توكَّلنا»{2}. (ز) ٧٩٦٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، قال: الصُّور{3}. (١٥/٦٩) ٧٩٦٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿النّاقور﴾</q> الصُّور؛ كهيئة البُوق{4}. (١٥/٦٩) ٧٩٦٩١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، يعني: الصُّور{5}. (ز) ٧٩٦٩٢- عن عكرمة مولى ابن عباس -من طريق أبي رجاء-= (ز) ٧٩٦٩٣- وعامر الشعبي= (ز) ٧٩٦٩٤- وأبي مالك غَزْوان الغفاري، مثله{6}. (١٥/٦٩) ٧٩٦٩٥- قال الحسن البصري -من طريق معمر- <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، قال: إذا نُفخ في الصُّور{5}. (ز) ٧٩٦٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، قال: فإذا نُفخ في الصُّور{8}. (١٥/٦٩) ٧٩٦٩٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فإذا نقر في الناقور﴾</q>: والنّاقور: الصُّور، والصُّور: الخَلْق{5}. (ز) ٧٩٦٩٨- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، قال: النّاقور: الصُّور{5}. (ز) ٧٩٦٩٩- قال مقاتل بن سليمان: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، يعني: نُفخ في الصُّور، والنّاقور: القَرن الذي يَنفخ فيه إسرافيل، وهو الصُّور{11}. (ز) ٧٩٧٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q>، قال: الصُّور{5}. (ز) <q>﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾</q> - آثار متعلقة بالآية ٧٩٧٠١- عن بَهْز بن حكيم، قال: أمَّنا زُرارة بن أوْفى، فقرأ المدثِّر، فلما بلغ: <q>﴿فَإذا نُقِرَ فِي النّاقُورِ﴾</q> خرّ مَيِّتًا، فكنتُ في مَن حَمله{13}. (١٥/٧٠) ",footnotes:1:عزاه السيوطي إلى ابن مردويه. كما عزاه إلى ابن أبي شيبة والطبراني، وليس عندهما قوله: لما نزلت، كما في الأثر التالي.أخرجه أحمد ٥/١٤٤-١٤٥ (٣٠٠٨)، والحاكم ٤/٦٠٣ (٨٦٧٧)، وابن جرير ٢٣/٤١٨-٤١٩، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٦٤-، والثعلبي ١٠/٧١. قال ابن كثير في تفسيره ٢/١٧١: «حديث جيد». وقال الذهبي في التلخيص: «عطية -العَوفيّ- ضعيف». وقال الهيثمي في المجمع ١٠/٣٣١ (١٨٣٠٨): «فيه عطية العَوفيّ، وهو ضعيف، وفيه توثيق ليّن». وأورده الألباني في الصحيحة ٣/٦٦ (١٠٧٩).أخرجه ابن جرير ٢٣/٤٢٠-٤٢١. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٣/٤١٩، وبنحوه من طريق جابر. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٢٠.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه عن عكرمة آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٣-، وابن جرير ٢٣/٤١٩.أخرجه ابن جرير ٢٣/٤٢٠.أخرجه عبد الرزاق ٢/٣٢٨، وابن جرير ٢٣/٤٢٠. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٢٠.أخرجه ابن جرير ٢٣/٤٢٠.تفسير مقاتل بن سليمان ٤/٤٩٠-٤٩١.أخرجه ابن جرير ٢٣/٤٢٠.أخرجه ابن سعد ٧/١٥٠، والحاكم ٢/٥٠٦.
74,9," <q>﴿فَذَ ٰ⁠لِكَ یَوۡمَىِٕذࣲ یَوۡمٌ عَسِیرٌ ۝٩ عَلَى ٱلۡكَـٰفِرِینَ غَیۡرُ یَسِیرࣲ ۝١٠﴾</q> - تفسير ٧٩٧٠٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يَوْمٌ عَسِيرٌ﴾</q>، قال: شديد{1}. (١٥/٦٩) ٧٩٧٠٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَذَلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ﴾</q> قال: شديد، ثم بَيَّن على مَن مَشقَّتُه وعُسْرُه، فقال: <q>﴿عَلى الكافِرِينَ غَيْرُ يَسِيرٍ﴾</q>{2}. (١٥/٧٠) ٧٩٧٠٤- قال مقاتل بن سليمان: <q>﴿فَذلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ﴾</q> يعني: مَشقَّتَه وشدّته، <q>﴿عَلى الكافِرِينَ غَيْرُ يَسِيرٍ﴾</q> يعني: غير هيّن، ويَهُونُ ذلك على المؤمن كأدنى صلاته{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٤٢٠-٤٢١. وعلقه البخاري في صحيحه ٤/١٨٧٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرج أوله ابن جرير ٢٣/٤٢٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٩١.
  74,10,""
74,11," <q>﴿ذَرۡنِی وَمَنۡ خَلَقۡتُ وَحِیدࣰا ۝١١﴾</q> الآيات - نزول الآيات ٧٩٧٠٥- عن عبد الله بن عباس -من طريق عكرمة-: أنّ الوليد بن المُغيرة جاء إلى النبيِّ ﷺ، فقَرأ عليه القرآن، فكأنه رَقَّ له، فبَلغ ذلك أبا جهل، فأتاه، فقال: يا عمّ، إنّ قومك يريدون أن يجمعوا لك مالًا ليُعطوكه، فإنك أتيتَ محمدًا لتَعرَّض لِما قِبلَه. قال: قد عَلمتْ قريش أني مِن أكثرها مالًا. قال: فقُلْ فيه قولًا يَبلغ قومك أنّك مُنكِرٌ له، أو أنك كارهٌ له. قال: وماذا أقول؟ فواللهِ، ما فيكم رجل أعلم بالشِّعر مني، ولا برَجَزِهِ ولا بقِصِيده مني، ولا بأشعار الجنّ، واللهِ، ما يُشبه الذي يقول شيئًا من هذا، وواللهِ، إنّ لِقَوْله الذي يقول حلاوة، وإنّ عليه لَطُلاوة{1}، وإنه لَمُثمِرٌ أعلاه، مُغدِقٌ أسفله، وإنّه لَيَعلو وما يُعلى، وإنه ليَحْطِم ما تحته. قال: لا يرضى عنك قومك حتى تقول فيه. قال: فدعني حتى أُفكّر. فلما فَكّر قال: هذا سحرٌ يُؤثر؛ يَأْثُره عن غيره. فنَزلت: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>{2}. (١٥/٧٢) ٧٩٧٠٦- عن عكرمة مولى ابن عباس -من طريق معمر، عن رجل-، مثله{3}. (ز) ٧٩٧٠٧- عن عكرمة مولى ابن عباس -من طريق أيوب- في قول الوليد بن المُغيرة: إنّه يأمر بالعدل، والإحسان{4}. (ز) ٧٩٧٠٨- عن عبد الله بن عباس -من طريق عطية- قال: دَخل الوليدُ بن المُغيرة على أبي بكر، فسأله عن القرآن، فلمّا أخبَره خرج على قريش، فقال: يا عجبًا لِما يقول ابنُ أبي كَبْشَة، فواللهِ، ما هو بشعرٍ، ولا بسحرٍ، ولا بهَذْي من الجنون، وإنّ قوله لَمِن كلام الله. فلمّا سمع النّفرُ مِن قريش ائتمروا، وقالوا: واللهِ، لَئِن صَبأ الوليدُ لَتَصْبأنّ قريشٌ. فلما سمع بذلك أبو جهل قال: واللهِ، أنا أكفيكم شأنَه. فانطَلق حتى دَخل عليه بيتَه، فقال للوليد: ألم ترَ قومك قد جَمعوا لك الصدقة؟ فقال: ألستُ أكثرهم مالًا وولدًا؟! فقال له أبو جهل: يَتحدَّثون أنك إنما تَدخل على ابن أبي قُحافة لِتُصيب من طعامه. فقال الوليد: لقد تَحدّث بهذا عشيرتي! فواللهِ، لا أقرب ابنَ أبي قُحافة، ولا عمر، ولا ابن أبي كَبْشَة، وما قوله إلا سحرٌ يُؤثر. فأَنزل الله: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q> إلى قوله: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q>{5}. (١٥/٧٤) ٧٩٧٠٩- عن عبد الله بن عباس -من طريق ابن إسحاق بسنده- قال: أنزل الله في الوليد بن المُغيرة قوله: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، وقوله: <q>﴿فَوَرَبِّكَ لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾</q> [الحجر:٩٢] إلى آخرها{6}. (ز) ٧٩٧١٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، قال: نزلت في الوليد بن المُغيرة{7}. (١٥/٧١) ٧٩٧١١- عن قتادة بن دعامة -من طريق معمر- أنه قال: خَرج مِن بطن أمه وحيدًا. قال: نزلت فيه هذه الآيات حتى بلغ: <q>﴿عليها تسعة عشر﴾</q>{8}. (ز) ٧٩٧١٢- قال مقاتل بن سليمان: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، يعني: الوليد بن المُغيرة المخزومي، كان يُسمّى: الوحيد في قومه، وذلك أنّ الله ﷿ أنزل على النبي ﷺ: <q>﴿حم، تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ. غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</q> [غافر:١-٣، فلما نزلت هذه الآية قام النبيُّ ﷺ في المسجد الحرام، فقرأها، والوليد بن المُغيرة قريبًا منه يستمع إلى قراءته، فلمّا فَطِن ﷺ أنّ الوليد بن المُغيرة يَستمع إلى قراءته أعاد النبيُّ ﷺ يقرأ هذه الآية: <q>﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ﴾</q> إلى قوله: <q>﴿لا إلهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</q> ... فلمّا سمعها الوليد انطلَق حتى أتى مجلس بني مخزوم، فقال: واللهِ، لَقد سمعتُ مِن محمد كلامًا آنفًا ما هو مِن كلام الإنس، ولا مِن كلام الجنّ، وإنّ أسفله لَمُغدِق، وإنّ أعلاه لَمُونقٌ، وإنّ له لَحلاوة، وإنّ عليه لَطُلاوة، وإنه لَيَعلو وما يُعلى. ثم انصرف إلى منزله، فقالت قريش: لقد صَبأ الوليد، واللهِ، لئن صَبأ لتَصبونّ قريش كلّها. وكان يقال للوليد: ريحانة قريش، فقال أبو جهل: أنا أكفيكموه. فانطلَق أبو جهل حتى دَخل على الوليد، فقعد إليه كَشَبَه الحزين، فقال له الوليد: ما لي أراك -يا ابن أخي- حزينًا؟ فقال أبو جهل: ما يمنعني أن لا أحزن وهذه قريش يَجمعون لك نفقةً لِيُعينوك على كِبَرك، ويزعمون أنك إنما زَيّنتَ قول محمد لِتُصيب مِن فضل طعامه. فغضب الوليدُ عند ذلك، وقال: أوَليس قد عَلمتْ قريشٌ أني مِن أكثرهم مالًا وولدًا، وهل يَشبع محمدٌ وأصحابُه مِن الطعام فيكون لهم فضل؟ فقال أبو جهل: فإنهم يزعمون أنك إنما زَيّنتَ قول محمد من أجل ذلك. فقام الوليد، فانطلَق مع أبي جهل، حتى أتى مجلس قومه بني مخزوم، فقال: تزعمون أنّ محمدًا كاهن، فهل سمعتموه يُخبر بما يكون في غد؟ قالوا: اللهم، لا. قال: وتزعمون أنّ محمدًا شاعر، فهل رأيتموه يَنطق فيكم بشعرٍ قطّ؟ قالوا: اللهم، لا. قال: وتزعمون أنّ محمدًا كذّاب، فهل رأيتموه يَكذب فيكم قطّ؟ قالوا: اللهم، لا. وكان يُسمّى محمد ﷺ قبل النبوة: الأمين، فبَرّأه من هذه المقالة كلّها، فقالت قريش: وما هو، يا أبا المُغيرة؟ فتفَكّر في نفسه ما يقول عن محمد ﷺ: <q>﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</q> فقَدَّر له السحر، <q>﴿فَقُتِلَ﴾</q> يعني: لُعِن <q>﴿كَيْفَ قَدَّرَ﴾</q> لمحمد ﷺ السحر، <q>﴿ثُمَّ نَظَرَ ثُمَّ عَبَسَ﴾</q> يقول: ثم كَلَح، <q>﴿وبَسَرَ﴾</q> يعني: وتَغيّر لونه، [<q>﴿ثم أدبر﴾</q>]{9} يعني: أعرَض عن الإيمان، <q>﴿واسْتَكْبَرَ﴾</q> عنه، فقال الوليد لقومه: <q>﴿إنْ هذا﴾</q> الذي يقول محمد <q>﴿إلّا سِحْرٌ يُؤْثَرُ﴾</q>. فقال له قومه: وما السِّحر، يا أبا المُغيرة؟ وفرحوا، فقال: شيء يكون ببابل، إذا تعلّمه الإنسان يُفرِّق بين الاثنين، ومحمد يَأْثُره ولمّا يحذقه بعدُ، وايمُ الله، لقد أصاب فيه حاجته، أما رأيتموه فَرّق بين فلان وبين أهله، وبين فلان وبين أبيه، وبين فلان وبين أخيه، وبين فلان وبين مولاه، فهذا الذي يقول محمد سحرٌ يُؤثر عن مُسَيلمة بن حبيب -الحنفي الكذّاب-. يقول: يرويه عنه، فذلك قوله: <q>﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ إنْ هَذا إلّا قَوْلُ البَشَرِ﴾</q> يقول: إنْ هذا الذي يقول محمد إلا قول البشر. قال الوليد بن المُغيرة: عن يَسار أبي فكيهة، هو الذي يأتيه به من مُسَيلمة –الكذّاب-، فجَعل الله له سَقر، وهو الباب الخامس مِن جهنم، فلمّا قال ذلك الوليد شَقّ ذلك على النبي ﷺ ما لم يشقّ عليه فيما قُذف بغيره من الكذب؛ فأَنزل الله تعالى على نبيّه ﷺ يعزيه ليَصبِر على تكذيبهم، فقال: يا محمد <q>﴿كَذلِكَ ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلّا قالُوا ساحِرٌ أوْ مَجْنُونٌ﴾</q> [الذاريات:٥٢]، وأَنزل في الوليد بن المُغيرة: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>{10}. (ز) ٧٩٧١٣- تفسير الكلبي: <q>﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</q> إلى قوله: <q>﴿إنْ هَذا إلّا قَوْلُ البَشَرِ﴾</q> أنّ الوليد بن المُغيرة قال: يا قوم، إنّ أمْر هذا الرجل -يعني: النبي ﷺ- قد فشا، وقد حضَر الموسم، وإنّ الناس سيسألونكم عنه، ... بنحو ما سبق مختصرًا{11}. (ز) ٧٩٧١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q> إلى قوله: <q>﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</q> حتى بلَغ: <q>﴿سَأُصْلِيهِ سَقَرَ﴾</q>، قال: هذه الآيات أُنزِلَتْ في الوليد بن المُغيرة{12}. (ز) <q>﴿ذَرۡنِی وَمَنۡ خَلَقۡتُ وَحِیدࣰا ۝١١﴾</q> - تفسير ٧٩٧١٥- عن عبد الله بن عباس، <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، قال: الوليد بن المُغيرة{13}. (١٥/٧٠) ٧٩٧١٦- قال عبد الله بن عباس: وكان يُسمّى: الوحيد في قومه{14}. (ز) ٧٩٧١٧- عن سعيد بن جُبَير، <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q> الآيات، قال: هو الوليد بن المُغيرة بن هشام المَخزوميّ، وكان له ثلاثة عشر ولدًا، كلّهم ربّ بيت، فلما نزلت: <q>﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</q> لم يَزل في إدبار مِن الدنيا في نفسه وماله وولده حتى أخرجه الله من الدنيا{15}. (١٥/٧١) ٧٩٧١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وحِيدًا﴾</q>، قال: خَلَقتُه وحده، ليس له مال ولا ولد{7}. (١٥/٧١) ٧٩٧١٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، يعني: الوليد بن المُغيرة{12}. (ز) ٧٩٧٢٠- عن عامر الشعبي -من طريق حُصَين- في قوله ﷿: <q>﴿ذرني ومن خلقت وحيدًا﴾</q>، قال: هو الوليد بن المُغيرة المَخزوميّ{18}. (ز) ٧٩٧٢١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، قال: هو الوليد بن المُغيرة، أخرجه الله مِن بطن أمه وحيدًا، لا مال له ولا ولد، فرَزقه الله المال والولد والثّروة والنّماء{19}. (١٥/٧٠) ٧٩٧٢٢- عن أبي مالك غَزْوان الغفاري، <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، قال: الوليد بن المُغيرة{20}. (١٥/٧١) ٧٩٧٢٣- قال مقاتل بن سليمان: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q>، يعني: الوليد بن المُغيرة المَخزوميّ، كان يُسمّى: الوحيد في قومه ...{10}. (ز) ٧٩٧٢٤- قال مقاتل بن سليمان: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q> يقول: خَلِّ بيني -يا محمد- وبين مَن خَلقتُ وحيدًا. يقول: حين لم يكن له مال ولا بنون، يعني: خَلِّ بيني وبينه، فأنا أتفرّد بهلاكه، وأمّا الوليد يعني: خَلَقتُه وحده ليس له شيء{22}٦٨٧٣. (ز) ٦٨٧٣ أفادت الآثار أنّ وصف الوليد بالوحيد لأنه وُلد بلا مال ولا ولد، ثم رزقه الله المال والولد. وقد ذكر ابنُ عطية (٨/٤٥٥) هذا القول، وزاد عليه قولًا آخر، فقال: «وقيل: المعنى: خَلَقتُه وحدي، لم يشركني فيه أحد». وعلّق عليه قائلًا: «فـ<q>﴿وحيدا﴾</q> حال من التاء في <q>﴿خَلَقْتُ﴾</q>». ",footnotes:1:أي: رونقًا وحُسنًا، وقد تفتح الطاء. النهاية (طلا).أخرجه الحاكم ٢/٥٥٠ (٣٨٧٢)، والبيهقي في دلائل النبوة ٢/١٩٨، وفي الشعب ١/٢٨٨ (١٣٣)، والواحدي في أسباب النزول ص٤٤٧، من طريق عبد الرزاق، عن معمر، عن أيوب السّختياني، عن عكرمة، عن ابن عباس به، وأخرجه أيضًا ابن جرير ٢٣/٤٢٩ من طريق معمر، عن عباد بن منصور، عن عكرمة به. قال الحاكم: «هذا حديث صحيح الإسناد، على شرط البخاري، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال البيهقي: «رواه حماد بن زيد، عن أيوب، عن عكرمة مُرسلًا».أخرجه عبد الرزاق ٢/٣٢٨-٣٢٩.أخرجه عبد الرزاق ٢/٣٢٩. وذكر محققه أنّ المراد هو: «أنّ ثناء الوليد السابق على القرآن كان بعد سماعه قوله تعالى: <q>﴿إنَّ اللَّهَ يَأْمُرُ بِالعَدْلِ والإحْسانِ﴾</q> الآية [النحل:٩٠]».أخرجه أبو نعيم في دلائل النبوة ص٢٣٣ (١٨٤) دون ذكر الآية، وابن جرير ٢٣/٤٢٩-٤٣٠، من طريق عطية العَوفيّ، عن ابن عباس به. الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ٢٣/٤٢١، من طريق محمد بن إسحاق، عن محمد بن أبي محمد، عن سعيد بن جُبَير، أو عكرمة، عن ابن عباس به. إسناده جيد. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ٢٣/٤٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٢٩، وابن جرير ٢٣/٤٢٩.سقطت من المطبوع.تفسير مقاتل بن سليمان ٤/٤٩١-٤٩٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٦-٥٧-.أخرجه ابن جرير ٢٣/٤٢٢.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ١٠/٧١.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٢١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٢٢.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٩٧ (٢٣٢٩).أخرجه ابن جرير ٢٣/٤٢١. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩١-٤٩٣.تفسير مقاتل بن سليمان ٤/٤٩٤.
74,12," <q>﴿وَجَعَلۡتُ لَهُۥ مَالࣰا مَّمۡدُودࣰا ۝١٢﴾</q> - تفسير ٧٩٧٢٥- عن عمر بن الخطاب -من طريق عطاء- أنه سُئل عن قوله: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>. قال: غَلة شهر بشهر{1}٦٨٧٤. (١٥/٧٢) ٦٨٧٤ علّق ابنُ عطية (٨/٤٥٥) على قول عمر، فقال: «فهو مَدٌّ في الزمان لا ينقطع». ٧٩٧٢٦- عن عبد الله بن عباس، <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>، قال: ألف دينار{2}. (١٥/٧١) ٧٩٧٢٧- قال عبد الله بن عباس: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q> تسعة آلاف مثقال فِضّة{3}. (ز) ٧٩٧٢٨- عن عبد الله بن عباس: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q> كان له بين مكة والطائف إبل وخيل ونَعم وغنم، وكان له عِير كثيرة، وعبيدٌ، وجوار{4}. (ز) ٧٩٧٢٩- قال سعيد بن جُبَير -من طريق محمد بن سوقة- <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>: ألف دينار{5}. (ز) ٧٩٧٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>، قال: ألف دينار{6}. (١٥/٧١) ٧٩٧٣١- عن النعمان بن سالم -من طريق شعبة- في قوله: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>، قال: الأرض{7}. (١٥/٧٢) ٧٩٧٣٢- عن إبراهيم بن المهاجر -من طريق قيس بن الربيع- قال: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>، قال: ألف دينار{8}. (ز) ٧٩٧٣٣- قال قتادة بن دعامة: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q> أربعة آلاف دينار{9}. (ز) ٧٩٧٣٤- قال مقاتل بن سليمان: يقول ﷿: فأَعطيتُه المالَ والولد، فذلك قوله: <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q> يعني بالمال: بُستانه الذي له بالطائف، والممدود: الذي لا يَنْقطع خيره شتًاء ولا صيفًا، كقوله: <q>﴿وظِلٍّ مَمْدُودٍ﴾</q> [الواقعة:٣٠]، يعني: لا يَنقطع{10}. (ز) ٧٩٧٣٥- عن سفيان [الثوري] -من طريق مهران- <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>، قال: بلَغني: أنه أربعة آلاف دينار{11}. (ز) ٧٩٧٣٦- عن سفيان، <q>﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾</q>، قال: ألف ألف{12}٦٨٧٥. (١٥/٧٢) ٦٨٧٥ علّق ابن عطية (٨/٤٥٥) على قول مَن حدّ المال الممدود بعدد معين بقوله: «فهذا مَدّ في العدد». ورجّح ابنُ جرير (٢٣/٤٢٤) العموم، وأنّ المال الممدود هو الكثير، الممدود عدده أو مساحته، دون تعيين لحدّه أو مقداره، فقال: «والصواب من القول في ذلك أن يُقال كما قال الله: <q>﴿وجعلت له مالا ممدودًا﴾</q>، وهو الكثير الممدود عدده أو مساحته». ",footnotes:1:أخرجه ابن جرير ٢٣/٤٢٣. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه، والدينوري في المجالسة.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٧١، وفيه تصحفت إلى: سبعة آلاف، وتفسير البغوي ٨/٢٦٦.تفسير البغوي ٨/٢٦٦.أخرجه ابن جرير ٢٣/٤٢٢.أخرجه عبد الرزاق ٢/٣٢٩، وابن جرير ٢٣/٤٢٢، ومن طريق إبراهيم أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٢٣. وعزاه السيوطي إلى ابن مردويه.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٣ (٢٥٧).تفسير الثعلبي ١٠/٧١، وتفسير البغوي ٨/٢٦٦.تفسير مقاتل بن سليمان ٤/٤٩٤.أخرجه ابن جرير ٢٣/٤٢٣.عزاه السيوطي إلى عبد بن حميد. وفي تفسير الثعلبي ١٠/ ٧١ عن سفيان الثوري.
74,13," <q>﴿وَبَنِینَ شُهُودࣰا ۝١٣﴾</q> - تفسير ٧٩٧٣٧- قال سعيد بن جُبَير: <q>﴿وبَنِينَ شُهُودًا﴾</q> كانوا ثلاثة عشر ولدًا{1}. (ز) ٧٩٧٣٨- عن مجاهد بن جبر -من طريق إبراهيم- <q>﴿وبَنِينَ﴾</q> قال: كانوا عشرة، <q>﴿شُهُودًا﴾</q> قال: لا يَغيبون{2}. (١٥/٧١) ٧٩٧٣٩- عن أبي مالك غَزْوان الغفاري، <q>﴿وبَنِينَ شُهُودًا﴾</q>، قال: كانوا ثلاثة عشر{3}. (١٥/٧١) ٧٩٧٤٠- قال قتادة بن دعامة: <q>﴿وبَنِينَ شُهُودًا﴾</q> حُضورًا بمكة، لا يَغيبون عنه، وكانوا عشرة{4}. (ز) ٧٩٧٤١- قال مقاتل بن سليمان: <q>﴿وبَنِينَ شُهُودًا﴾</q> يعني: حُضورًا، لا يَغيبون أبدًا عنه في تجارة ولا غيرها؛ لكثرة أموالهم بمكة، وكلّهم رجال، منهم الوليد بن الوليد، وخالد بن الوليد -وهو سيف الله أسلم بعد ذلك-، وعمارة بن الوليد، وهشام بن الوليد، والعاص بن الوليد، وقيس بن الوليد، وعبد شمس بن الوليد{5}. (ز) ",footnotes:1:تفسير الثعلبي ١٠/٧٢.أخرجه ابن جرير ٢٣/٤٢٤ دون شطره الثاني. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير البغوي ٨/٢٦٧.تفسير مقاتل بن سليمان ٤/٤٩٤.
74,14," <q>﴿وَمَهَّدتُّ لَهُۥ تَمۡهِیدࣰا ۝١٤﴾</q> - تفسير ٧٩٧٤٢- قال عبد الله بن عباس: <q>﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</q>، يعني: المال بعضه على بعض، كما تُمهد الفُرش{1}. (ز) ٧٩٧٤٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</q>، قال: بَسطتُ له من المال والولد{2}. (١٥/٧١) ٧٩٧٤٤- قال محمد بن السّائِب الكلبي: <q>﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</q>، يعني: المال بعضه على بعض، كما يُمهد الفُرش{3}. (ز) ٧٩٧٤٥- قال مقاتل بن سليمان: <q>﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</q>، يقول: بَسطتُ له في المال والولد والخير بَسطًا{4}. (ز) ٧٩٧٤٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾</q>، قال: بُسِط له{5}. (ز) ",footnotes:1:تفسير الثعلبي ١٠/٧٢.أخرجه ابن جرير ٢٣/٤٢٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٨/٢٦٧.تفسير مقاتل بن سليمان ٤/٤٩٤.أخرجه ابن جرير ٢٣/٤٢٥.
74,15," <q>﴿ثُمَّ یَطۡمَعُ أَنۡ أَزِیدَ ۝١٥ كَلَّاۤۖ﴾</q> - تفسير ٧٩٧٤٧- عن مجاهد بن جبر <q>﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ * كَلّا﴾</q>، قال: فما زال يَرى النقصان في ماله وولده حتى هَلك{1}. (١٥/٧١) ٧٩٧٤٨- عن أبي مالك غَزْوان الغفاري، <q>﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ * كَلّا﴾</q>، قال: فلم يُولَد له بعد يومئذ، ولم يَزدد له من المال إلا ما كان{2}. (١٥/٧١) ٧٩٧٤٩- قال الحسن البصري: <q>﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ﴾</q> ثم يطمع أنْ أُدخله الجنة{3}. (ز) ٧٩٧٥٠- قال مقاتل بن سليمان: <q>﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ﴾</q> يقول: ثم يرجو أنْ أزيده في ماله وولده، <q>﴿كَلّا﴾</q> لا أزيده، بل أقطع ذلك عنه وأُهلكه، ثم مَنعه الله المال، فلم يُعطه شيئًا حتى افتقر وسأل الناس، فأَهلكه الله تعالى، ومات فقيرًا في المُستهزئين، ثم نَعتَ عمله الخبيث، فقال: <q>﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</q>{4}. (ز) <q>﴿كَلَّاۤۖ إِنَّهُۥ كَانَ لِـَٔایَـٰتِنَا عَنِیدࣰا ۝١٦﴾</q> - تفسير ٧٩٧٥١- عن عبد الله بن عباس -من طريق علي- <q>﴿عَنِيدًا﴾</q>، قال: جَحودًا{5}. (١٥/٧٤) ٧٩٧٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</q>، قال: مُعانِدًا عنها، مُجانِبًا لها{6}. (١٥/٧١) ٧٩٧٥٣- عن أبي مالك غَزْوان الغفاري، <q>﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</q>، قال: مُشاقًّا{2}. (١٥/٧١) ٧٩٧٥٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿كَلّا إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</q>، قال: كفورًا بآيات الله، جَحودًا بها{8}. (١٥/٧٠) ٧٩٧٥٥- قال مقاتل بن سليمان: <q>﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾</q> يعني: كان عن آيات القرآن مُعرِضًا مُجانبًا له، لا يُؤمن بالقرآن. ثم أخبر الله تعالى ما يَصنع به في الآخرة، فقال: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>{9}٦٨٧٦. (ز) ٦٨٧٦ ذكر ابنُ عطية (٨/٤٥٥-٤٥٦) أنّ قوله: <q>﴿لآياتنا﴾</q> هي العِبر، ثم ذكر القول بأنها آيات القرآن، كما في قول مقاتل، ورجّحه مستندًا إلى السياق، فقال: «ويحتمل أن يريد بالآيات: آيات القرآن، وهو الأصح في التأويل؛ بسبب كلام الوليد في القرآن بأنه سحرٌ». ٧٩٧٥٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿لِآياتِنا عَنِيدًا﴾</q>، قال: مُشاقًّا{10}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٦-، وذكر عقبه: لقول المشرك: <q>﴿ولَئِنْ رُجِعْتُ إلى رَبِّي﴾</q> [فصلت:٥٠] كما يقولون: <q>﴿إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</q> [فصلت:٥٠] للجنة إن كانت جنة".تفسير مقاتل بن سليمان ٤/٤٩٤-٤٩٥.أخرجه ابن جرير ٢٣/٤٢٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٢٦، ومن طريق جابر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٢٦. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٩٥.أخرجه ابن جرير ٢٣/٤٢٦. وعقبه مباشرة في نفس السطر: «وقيل: عنيدًا، وهو مِن عاند معاندة فهو مُعانِد، كما قيل: عام قابل، وإنما هو مُقبل». ويظهر من صنيع الطبعة أنه من كلام سفيان، والأشبه أنه من كلام ابن جرير.
  74,16,""
74,17," <q>﴿سَأُرۡهِقُهُۥ صَعُودًا ۝١٧﴾</q> - تفسير ٧٩٧٥٧- عن أبي سعيد الخدري، عن النبيِّ ﷺ، قال: «الصَّعود: جبل في النار، يَصعد فيه الكافر سبعين خريفًا، ثم يَهوي وهو كذلك فيه أبدًا»{1}. (١٥/٧٤) ٧٩٧٥٨- عن عبد الله بن عباس، في قوله: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>، قال: جبل في النار{2}. (١٥/٧٥) ٧٩٧٥٩- عن عبد الله بن عباس، قال: صَعُودٌ: صخرة في جهنم، يُسحب عليها الكافر على وجهه{3}. (١٥/٧٥) ٧٩٧٦٠- عن أبي سعيد الخُدري -من طريق عطية العَوفيّ- في قوله: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>، قال: هو جبل في النار، يُكلّفون أن يصعدوا فيه، فكُلّما وضعوا أيديهم عليه ذابتْ، فإذا رفعوها عادتْ كما كانت{4}. (١٥/٧٢) ٧٩٧٦١- عن أبي سعيد الخُدري -من طريق عطية العَوفيّ- قال: إنّ صَعُودًا صخرة في جهنم، إذا وضعوا أيديهم عليها ذابتْ، فإذا رفعوها عادتْ، واقتحامها: <q>﴿فَكُّ رَقَبَةٍ أوْ إطْعامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ﴾</q> [البلد:١٣-١٤]{5}. (١٥/٧٥) ٧٩٧٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>، قال: مَشقّة مِن العذاب{6}. (١٥/٧١) ٧٩٧٦٣- عن الضَّحّاك بن مُزاحِم، <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>، قال: صخرة ملساء في جهنم، يُكلّفون الصُّعود عليها{7}. (١٥/٧٥) ٧٩٧٦٤- عن الحسن البصري، في قوله: <q>﴿صَعُودًا﴾</q>، قال: جبلًا في جهنم{7}. (١٥/٧٥) ٧٩٧٦٥- عن الحسن البصري= (ز) ٧٩٧٦٦- وقتادة بن دعامة -من طريق عمرو- في قوله تعالى: <q>﴿سأرهقه صعودًا﴾</q>، قال: عذابًا لا راحة فيه{9}. (ز) ٧٩٧٦٧- عن شُفَيّ بن ماتع الأَصبحيّ -من طريق أيوب بن بَشِير- قال: في جهنم جبل يُدعى: صَعودًا، يَطْلُع فيه الكافر أربعين خريفًا قبل أن يرقاه، قال الله ﷿: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>{10}. (ز) ٧٩٧٦٨- عن قتادة بن دعامة -من طريق أبي هلال- <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>، قال: مَشقّة من العذاب{11}. (ز) ٧٩٧٦٩- قال محمد بن السّائِب الكلبي: الصعود: صخرة ملساء في النار، يُكلّف أن يَصعدها، لا يُترك أن يَتنفّس في صعوده، ويُجذب مِن أمامه بسلاسل مِن حديد، ويُضرب مِن خلفه بمَقامع مِن حديد، فيَصعدها في أربعين عامًا، فإذا بَلغ ذروتها أُحْدِرَ إلى أسفلها، ثم يُكلّف أن يَصعدها، ويُجذب من أمامه، ويُضرب من خلفه، فذلك دأْبه أبدًا أبدًا{12}. (ز) ٧٩٧٧٠- قال مقاتل بن سليمان: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q> يعني: سُأكَلّفه أن يَصعد على صخرة من النار ملساء في الباب الخامس، واسم ذلك الباب: سَقر، في تلك الصخرة كُوًى{13} تَخرج منها ريح، وهي ريح حارة، وهي التي ذَكر الله تعالى <q>﴿عَذابَ السَّمُومِ﴾</q> [الطور:٢٧]، فإذا أصابته تلك الريح تَناثر لحمه، يقول الله -جلّ وعزّ-: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q> يقول: سأُغشي وجهه تلك الصخرة، وهي جبلٌ من نار، طوله مسيرة سبعين سنة، ويَصعد به فيها على وجهه، فإذا بلَغ الكافر أعلاها انحطّ إلى أسفلها، ثم يُكلّف أيضًا صُعودها، ويَخرج إليه من كُوى تلك الصخرة ريح باردة من فوقها ومن تحتها، تَقْطَعُ تلك الريحُ لحمه وجِلدة وجهه، فكُلّما أصعد أصابته تلك الريح وإذا انحطّ، حتى يَنتثِر اللحم من العظم، ثم يَشرب من عين آنية، التي قد انتهى حرّها، فهذا دأْبه أبدًا{14}. (ز) ٧٩٧٧١- عن عبد الرحمن بن زيد بن أسلم- من طريق ابن وهب- قال في قوله: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q>، قال: تعبًا مِن العذاب{15}. (ز) ",footnotes:1:أخرجه أحمد ١٨/٢٤٠ (١١٧١٢)، والترمذي ٤/٢٨٤، ٥/٢٨٦ (٢٥٧٦، ٣٣٢٦)، وابن حبان ١٦/٥٠٨ (٧٤٦٧)، والحاكم ٢/٥٥١ (٣٨٧٣)، ٤/٦٣٩ (٨٧٦٤)، وابن جرير ٢/١٦٤، ٢٣/٤٢٧، كلهم من طريق درّاج، عن أبي الهيثم، عن أبي سعيد.. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه. قال الترمذي: «هذا حديث غريب، لا نعرفه مرفوعًا إلا من حديث ابن لهيعة». ولكن ابن لهيعة لم ينفرد به، بل قد تابعه عمرو بن الحارث عند ابن جرير وابن أبي حاتم وابن حبان والحاكم، فالكلام ينحصر في رواية «دراج عن أبي الهيثم». قال ابن معين: «ما كان هكذا بهذا الإسناد فليس به بأس». الكامل لابن عدي ٤/١٠. وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «صحيح». ولكن قال أحمد بن حنبل: «أحاديث دراج عن أبي الهيثم عن أبي سعيد فيها ضعف». الكامل لابن عدي ٤/١٠. وقال ابن كثير: «وهذا الحديث بهذا الإسناد مرفوعًا منكر».عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه هناد (٢٨١).أخرجه عبد الرزاق ٢/٣٣١، وابن أبي الدنيا (٣٠)، والطبراني في الأوسط (٥٥٣٧)، وابن مردويه -كما في تخريج الكشاف ٤/١٢٠-، والبيهقي في البعث (٥٣٩). وعزاه السيوطي إلى سعيد بن منصور، والفريابي، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٢٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه أسد بن موسى في الزهد ص٣٤ (٣٨)، وابن جرير ٢٣/٤٢٧ عن قتادة فقط من طريق سعيد.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٠٧ (٣٧)-.أخرجه ابن جرير ٢٣/٤٢٧.تفسير البغوي ٨/٢٦٨.كُوًى: جمع كَوّة، وهي الخَرْقُ في الحائط، والثُّقْب في البيت ونحوه. القاموس (كو)، واللسان (كوة).تفسير مقاتل بن سليمان ٤/٤٩٥.أخرجه ابن جرير ٢٣/٤٢٨.
