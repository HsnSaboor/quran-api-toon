quran[8]{c,v,t}:
10,54," <q>﴿وَلَوۡ أَنَّ لِكُلِّ نَفۡسࣲ ظَلَمَتۡ مَا فِی ٱلۡأَرۡضِ لَٱفۡتَدَتۡ بِهِۦۗ وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلۡعَذَابَۖ وَقُضِیَ بَیۡنَهُم بِٱلۡقِسۡطِ وَهُمۡ لَا یُظۡلَمُونَ ۝٥٤﴾</q> - تفسير ٣٤٥٦٥- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿وهم لا يظلمون﴾</q>، يعني: مِن أعمالهم، فلا يُنقَص من حسابهم{1}، ولا يُزاد على سيِّئاتهم{2}. (ز) ٣٤٥٦٦- قال مقاتل بن سليمان: قوله: <q>﴿ولَوْ أنَّ لِكُلِّ نَفْسٍ﴾</q> كافِرة <q>﴿ظَلَمَتْ ما فِي الأَرْضِ﴾</q> مالًا <q>﴿لافْتَدَتْ بِهِ﴾</q> نفسَها يوم القيامة مِن عذاب جهنم، <q>﴿وأَسَرُّوا النَّدامَةَ لَمّا رَأَوُا العَذابَ﴾</q> يعني: حين رأوا العذاب، <q>﴿وقُضِيَ بَيْنَهُمْ بِالقِسْطِ﴾</q> يعني: بالعدل، وصاروا إلى جهنم بشِرْكهم، وصار المؤمنون إلى الجنة بإيمانهم، <q>﴿وهُمْ لا يُظْلَمُونَ﴾</q>{3}. (ز) ",footnotes:1:كذا في المطبوع، ولعلها: حسناتهم.أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.
10,55," <q>﴿أَلَاۤ إِنَّ لِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۗ أَلَاۤ إِنَّ وَعۡدَ ٱللَّهِ حَقࣱّ وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَعۡلَمُونَ ۝٥٥﴾</q> - تفسير ٣٤٥٦٧- قال مقاتل بن سليمان: قوله: <q>﴿ألا إنَّ لِلَّهِ ما فِي السَّماواتِ والأَرْضِ﴾</q> يقول: هو ربُّ مَن فيهما، <q>﴿ألا إنَّ وعْدَ اللَّهِ حَقٌّ﴾</q> أنّ مَن وحَّده أثابه الجنة، ومَن كفر به عاقبه بالنار، <q>﴿ولَكِنَّ أكْثَرَهُمْ لا يَعْلَمُونَ﴾</q> يعني: مِن كلِّ ألفٍ تسعمائةٌ وتسعة [وتسعون] إلى النار، وواحد إلى الجنة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤١-٢٤٢.
10,56," <q>﴿هُوَ یُحۡیِۦ وَیُمِیتُ وَإِلَیۡهِ تُرۡجَعُونَ ۝٥٦﴾</q> - تفسير ٣٤٥٦٨- قال مقاتل بن سليمان: ثم أخبر بصنيعه لِيُوَحَّد، فقال: <q>﴿هُوَ يُحْيِي﴾</q> مِن النُّطَف، <q>﴿ويُمِيتُ﴾</q> مِن بعد الحياة، فاعبدوا مَن يُحْيِي ويُمِيت، <q>﴿وإلَيْهِ تُرْجَعُونَ﴾</q> مِن بعد الموت، فيجزيكم في الآخرة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٢.
10,57," <q>﴿یَـٰۤأَیُّهَا ٱلنَّاسُ قَدۡ جَاۤءَتۡكُم مَّوۡعِظَةࣱ مِّن رَّبِّكُمۡ﴾</q> - تفسير ٣٤٥٦٩- عن عامر الشعبي -من طريق بيان- قوله: <q>﴿موعظة﴾</q>، قال: موعظة مِن الجهل{1}. (ز) ٣٤٥٧٠- قال مقاتل بن سليمان: <q>﴿يا أيُّها النّاسُ قَدْ جاءَتْكُمْ مَوْعِظَةٌ﴾</q> يعني: بَيِّنة <q>﴿مِن رَبِّكُمْ﴾</q> وهو ما بَيَّن اللهُ في القرآن{2}. (ز) <q>﴿وَشِفَاۤءࣱ لِّمَا فِی ٱلصُّدُورِ﴾</q> - تفسير ٣٤٥٧١- عن أبي سعيد الخدريِّ، قال: جاء رجلٌ إلى النبيِّ ﷺ، فقال: إنِّي أشْتَكي صَدْري. فقال: «اقرَأ القرآنَ». يقول الله: <q>﴿وشِفَآءٌ لِما فِي الصُّدُورِ﴾</q>{3}. (٧/٦٦٥) ٣٤٥٧٢- عن واثلةَ بن الأسْقَع: أنّ رجلًا شَكا إلى النبيِّ ﷺ وجعَ حَلْقِه، قال: «عليك بقراءةِ القرآنِ»{4}. (٧/٦٦٥) ٣٤٥٧٣- عن أبي الأَحْوصِ، قال: جاء رجلٌ إلى عبد الله بن مسعود، فقال: إنّ أخي يَشْتَكي بطنَه، فوُصِف له الخمرُ. فقال: سبحانَ اللهِ! ما جعَل اللهُ في رِجْسٍ شفاءً، إنّما الشفاءُ في شيئين؛ القرآنِ، والعسلِ، فهما شفاءٌ لمِا في الصدورِ، وشفاءٌ للناسِ{5}. (٧/٦٦٥) ٣٤٥٧٤- عن عبد الله بن مسعود -من طريق أبي الأحْوصِ- قال: في القرآنِ شفاءان؛ القرآنُ، والعسلُ، فالقرآنُ شفاءٌ لما في الصدورِ، والعسلُ شفاءٌ مِن كلِّ داءٍ{1}. (٧/٦٦٥) ٣٤٥٧٥- عن مجاهد بن جبر -من طريق ليث- <q>﴿وشفاء﴾</q>، قال: الشفاء: القرآن{1}. (ز) ٣٤٥٧٦- عن الحسن البصري، قال: إنّ الله تعالى جعَل القرآنَ شِفاءً لِما في الصدورِ، ولم يجعلْه شفاءً لأمْراضِكم{8}. (٧/٦٦٥) ٣٤٥٧٧- عن طلحةَ بنِ مُصَرِّفٍ -من طريق عيسى بن عمر- قال: كان يُقال: إنّ المريضَ إذا قُرِئ عندَه القرآنُ وجَد له خِفَّةً، فدخَلتُ على خيثمةَ وهو مريضٌ، فقلت: إنِّي أراك اليومَ صالحًا. قال: إنّه قُرِئَ عندي القرآن{9}. (٧/٦٦٦) ٣٤٥٧٨- قال مقاتل بن سليمان: <q>﴿وشِفاءٌ لِما فِي الصُّدُورِ﴾</q> مِن الكُفر والشِّرك{2}. (ز) <q>﴿وَهُدࣰى﴾</q> - تفسير ٣٤٥٧٩- عن سعيد بن جبير -من طريق عطاء بن دينار- <q>﴿هدى﴾</q>، يعني: تبيانًا{11}. (ز) ٣٤٥٨٠- عن عامر الشعبي -من طريق بيان- <q>﴿هدى﴾</q>، قال: هُدًى مِن الضلالة{1}. (ز) ٣٤٥٨١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿هدى﴾</q>، قال: نور{11}. (ز) ٣٤٥٨٢- قال مقاتل بن سليمان: <q>﴿و﴾</q>هذا القرآن <q>﴿هُدًى﴾</q> مِن الضلالة{2}. (ز) <q>﴿وَرَحۡمَةࣱ لِّلۡمُؤۡمِنِینَ ۝٥٧﴾</q> - تفسير ٣٤٥٨٣- عن أبي العالية الرياحي -من طريق الربيع بن أنس- قوله: <q>﴿ورحمة﴾</q>، قال: رحمة القرآن{11}. (ز) ٣٤٥٨٤- قال مقاتل بن سليمان: <q>﴿ورَحْمَةٌ لِلْمُؤْمِنِينَ﴾</q> لِمَن أحلَّ حلاله، وحرَّم حرامه{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٧.تفسير مقاتل بن سليمان ٢/٢٤٢.عزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه البيهقي في الشعب ٤/١٧١ (٢٣٤٤)، من طُرُق، عن مكحول، عن واثلة بن الأسقع به. إسناده ضعيف؛ مكحول الشامي كثير الإرسال جدًّا، وقد نص أبو زرعة وأبو حاتم الرازِيَّين وغيرُهما أنّه لم يسمع من واثِلة بن الأسقع، وينظر: جامع التحصيل للعلائي ص٢٨٥.أخرجه الطبراني (٨٩١٠). وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٥٧.أخرجه ابن أبي حاتم ٦/١٩٥٧.عزاه السيوطي إلى أبي الشيخ.أخرجه البيهقي (٢٥٧٩).تفسير مقاتل بن سليمان ٢/٢٤٢.أخرجه ابن أبي حاتم ٦/١٩٥٨.أخرجه ابن أبي حاتم ٦/١٩٥٧.أخرجه ابن أبي حاتم ٦/١٩٥٨.تفسير مقاتل بن سليمان ٢/٢٤٢.أخرجه ابن أبي حاتم ٦/١٩٥٨.تفسير مقاتل بن سليمان ٢/٢٤٢.
10,58," <q>﴿قُلۡ بِفَضۡلِ ٱللَّهِ وَبِرَحۡمَتِهِۦ فَبِذَ ٰ⁠لِكَ فَلۡیَفۡرَحُوا۟ هُوَ خَیۡرࣱ مِّمَّا یَجۡمَعُونَ ۝٥٨﴾</q> - قراءات ٣٤٥٨٥- عن ابن عمرَ، عن النبيِّ ﷺ، أنّه كان يقرأُ: ‹فَبِذَلِكَ فَلْتَفْرَحُواْ›{1}. (٧/٦٦٧) ٣٤٥٨٦- عن أُبَيِّ بن كعب، قال: أقْرَأني رسول الله ﷺ: ‹فَبِذَلِكَ فَلْتَفْرَحُواْ› بالتاءِ{2}. (٧/٦٦٦) ٣٤٥٨٧- عن أُبَيِّ بن كعب -من طريق ابن أبْزى، عن أبيه- قال: قال رسول الله ﷺ: «إنّ الله أمَرني أن أقرأَ عليك القرآن». فقلت: أسَمّاني لك؟ قال: «نعم». قيل لأبيٍّ: أفَرِحْتَ بذلك؟ قال: وما يمنعُني، واللهُ يقول: ‹قُلْ بِفَضْلِ الله وبِرَحْمَتِه فَبِذَلِكَ فَلْتَفْرَحُواْ هُوَ خَيْرٌ مِّمّا تَجْمَعُونَ›. هكذا قرَأها بالتاِء{3}. (٧/٦٦٦) ٣٤٥٨٨- عن أبي بن كعب – من طريق ابن أبزى عن أبيه - أنه كان يقرأ: ‹فَبِذَلِكَ فَلْتَفْرَحُواْ هُوَ خَيْرٌ مِّمّا تَجْمَعُونَ› بالتاءِ{4}٣١٢٧. (٧/٦٦٦) ٣١٢٧ قُرِئَ قوله تعالى: <q>﴿فَلْيَفْرَحُوا﴾</q> بالياء على أنّه خبرٌ عن أهل الشرك بالله، والمعنى على ذلك: فبالإسلام والقرآن الذي دعاهم إليه فليفرح هؤلاء المشركون، فهما خيرٌ من المال الذي يجمعون. وقُرِئَ أيضًا: ‹فَلْتَفْرَحُوا› بالتاء على أنّه خطاب لأهل الإيمان، والمعنى على ذلك: فبالإسلام والقرآن فليفرح أهل الإيمان، فهما خيرٌ من حطام الدنيا، وما فيها من الزهرة الفانية. ورجَّحَ ابنُ جرير (١٢/١٩٩-٢٠٠) قراءة <q>﴿فَلْيَفْرَحُوا﴾</q> بالياء؛ لإجماع الحُجَّة من القراء عليها، وصحتها في العربية. <q>﴿قُلۡ بِفَضۡلِ ٱللَّهِ وَبِرَحۡمَتِهِۦ فَبِذَ ٰ⁠لِكَ فَلۡیَفۡرَحُوا۟﴾</q> - تفسير ٣٤٥٨٩- عن أنس، قال: قال رسول الله ﷺ: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: «فضلُ اللهِ: القرآنُ، ورحمتُه: أن جعَلكم مِن أهلِه»{5}. (٧/٦٦٧) ٣٤٥٩٠- عن أيْفع الكِلاعيِّ، قال: لَمّا قدم خَراجُ العراق إلى عمر خرج عمرُ ومولًى له، فجعل يَعُدُّ الإبلَ، فإذا هو أكثرُ مِن ذلك، فجعل عمرُ يقولُ: الحمدُ لله. وجعل مولاه يقولُ: هذا -واللهِ- من فضل اللهِ ورحمته. فقال عمرُ: كذبتَ، ليس هذا هو الذي يقولُ: <q>﴿قل بفضلِ اللهِ وبرحمته فبذلك فليفرحوا هُو خيرٌ مما يجمعونَ﴾</q>{6}. (٧/٦٧٠) ٣٤٥٩١- عن أبي سعيد الخدريِّ -من طريق عطية العوفي- في قوله: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: فضلُ اللهِ: القرآنُ، ورحمتُه: أن جعَلكم مِن أهلِه{7}. (٧/٦٦٧) ٣٤٥٩٢- عن البراء -من طريق أبي سعيد الخدري-: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، فضلُ اللهِ: القرآنُ، ورحمتُه: أن جعَلهم مِن أهلِه{8}. (٧/٦٦٧) ٣٤٥٩٣- عن عبد الله بن عباس، في قوله: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: بكتابِ الله، وبالإسلامِ{9}. (٧/٦٦٨) ٣٤٥٩٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: فَضْلُه: الإسلامُ، ورحمتُه: القرآنُ{10}. (٧/٦٦٨) ٣٤٥٩٥- عن عبد الله بن عباس -من طريق عطية العوفي- في الآية، قال: فضلُ اللهِ: القرآنُ، <q>﴿وبِرَحْمَتِهِ﴾</q>: حينَ جعَلهم مِن أهلِ القرآنِ{11}. (٧/٦٦٨) ٣٤٥٩٦- عن عبد الله بن عباس، في الآية، قال: فضلُ الله: العلمُ، ورحمتُه: محمدٌ ﷺ؛ قال الله: <q>﴿ومَآ أرْسَلْناكَ إلا رَحْمَةً لِلعالَمِينَ﴾</q> [الأنبياء:١٠٧]{12}. (٧/٦٦٨) ٣٤٥٩٧- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- <q>﴿قُلْ بِفَضْلِ الله﴾</q> قال: النبي ﷺ، <q>﴿وبرحمته﴾</q> قال: علي بن أبي طالبٍ ﵄{13}. (٧/٦٦٩) ٣٤٥٩٨- قال عبد الله بن عمر: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q> فضل الله: الإسلام، <q>﴿وبرحمته﴾</q>: تزيينه في القلب{14}. (ز) ٣٤٥٩٩- عن هلال بن يِسافٍ -من طريق سفيان، عن منصور- <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: فضلُ الله: الإسلامُ، ورحمتُه: القرآنُ{15}. (٧/٦٦٩) ٣٤٦٠٠- عن هلالِ بن يِساف -من طريق فضيل، عن منصور- في قوله: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: بالإسلامِ الذي هَداكم، وبالقرآنِ الذي عَلَّمكم{16}. (٧/٦٦٩) ٣٤٦٠١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: القرآن{17}. (٧/٦٦٨) ٣٤٦٠٢- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في الآية، قال: فضلُ اللهِ: القرانُ، ورحمتُه: الإسلامُ{18}. (٧/٦٦٩) ٣٤٦٠٣- عن خالد بن معدان: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q> فضل الله: الإسلام، <q>﴿وبرحمته﴾</q>: السنة{14}. (ز) ٣٤٦٠٤- عن سالم بن عبد الله بن عمر -من طريق منصور- <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>: الإسلامِ، والقرآنِ{20}. (٧/٦٦٨) ٣٤٦٠٥- عن الحسن البصري -من طريق مَعْمَر- <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، قال: فضلُه: الإسلامُ، ورحمتُه: القرآنُ{21}. (٧/٦٦٩) ٣٤٦٠٦- عن قتادة بن دعامة -من طريق سعيد-، مثلَه{22}. (٧/٦٦٩) ٣٤٦٠٧- عن الحسن البصري -من طريق أبي سهيل كثير بن زياد- في قول الله: <q>﴿فبذلك فليفرحوا﴾</q>: بالإسلام، والقرآن{23}. (ز) ٣٤٦٠٨- عن القاسم بن أبي بَزَّة، قال: بالقرآن{23}. (ز) ٣٤٦٠٩- عن زيد بن أسلمَ -من طريق ابنه عبد الرحمن- في الآيةِ، قال: فضلُ اللهِ: القرآنُ، ورحمتُه: الإسلامُ{25}. (٧/٦٦٩) ٣٤٦١٠- قال مقاتل بن سليمان: <q>﴿قُلْ بِفَضْلِ اللَّهِ﴾</q> يعني: القرآن، <q>﴿وبِرَحْمَتِهِ﴾</q>: الإسلام{26}. (ز) ٣٤٦١١- روى سفيان بن عيينة: <q>﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</q>، فضل الله: التوفيق، ورحمته: العِصْمَة{27}٣١٢٨. (ز) ٣١٢٨ أفادت الآثارُ الاختلاف في المراد بفضل الله ورحمته في الآية على عِدَّة أقوال: أولها: أنّ فضل الله: الإسلام، ورحمته: القرآن. وثانيها: أنّ فضل الله: القرآن، ورحمته: الإسلام. وثالثها: أنّ فضل الله: العلم، ورحمته: محمد ﷺ. وعلَّقَ ابنُ القيم (٢/٣٨ بتصرف) على القولين الأول والثاني بقوله: «التحقيق: أنّ كُلًّا منهما فيه الوصفان الفضل والرحمة، وهما الأمران اللذان امْتَنَّ الله بهما على رسوله ﷺ، فقال: <q>﴿وكذلك أوحينا إليك روحا من أمرنا ما كنت تدري ما الكتاب ولا الإيمان﴾</q> [الشورى:٥٢]، والله ﷾ إنّما رفع مَن رفع بالكتاب والإيمان، ووَضَع مَن وضَع بعدمها، ففضله: الإسلام والإيمان، ورحمته: العلم والقرآن، وهو يُحِبُّ مِن عبده أن يفرح بذلك ويُسَرُّ به، بل يُحِبُّ مِن عبده أن يفرح بالحسنة إذا عملها وأن يُسَرَّ بها، وهو في الحقيقة فَرَحٌ بفضل الله حيث وفَّقه الله لها، وأعانه عليها، ويسَّرها له، ففي الحقيقة إنما يفرح العبد بفضل الله وبرحمته». وذَهَبَ ابنُ جرير (١٢/١٩٤) إلى القول الأول مستندًا إلى أقوال السلف. وذَهَبَ ابنُ عطية (٤/٤٩٣-٤٩٤) إلى الجمعِ مستندًا لعدمِ المُخصّص، فقال: «لا وجه عندي لشيء من هذا التخصيص، إلا أن يستند منه شيء إلى النبي ﷺ، وإنما الذي يقتضيه اللفظ ويلزم منه أنّ الفضل هو هداية الله تعالى إلى دينه والتوفيق إلى اتباع شريعته، والرحمة هي عفوه وسكنى جنته التي جعلها جزاء على التَّشرُّع بالإسلام والإيمان به. ومعنى الآية: قل -يا محمد- لجميع الناس: بفضل الله وبرحمته فليقع الفرح منكم، لا بأمور الدنيا وما جمع من حطامها. فالمؤمنون يُقال لهم: فلتفرحوا وهم مُتَلَبِّسون بعِلَّة الفرح وسببه، ومُحَصِّلون لفضل الله، مُنتَظِرون الرحمة. والكافرون يقال لهم: بفضل الله وبرحمته فلتفرحوا، على معنى: أن لو اتفق لكم، أو لو سُعِدتُم بالهداية إلى تحصيل ذلك». <q>﴿هُوَ خَیۡرࣱ مِّمَّا یَجۡمَعُونَ ۝٥٨﴾</q> - تفسير ٣٤٦١٢- عن أنسٍ، قال: قال رسول الله ﷺ: «مَن هداه اللهُ للإسلام، وعلَّمه القرآن، ثُمَّ شكا الفاقَة؛ كتب اللهُ الفقرَ بين عينيه إلى يوم يلقاه». ثم تلا النبيُّ ﷺ: «<q>﴿قُلْ بفضل الله وبرحمتهِ فبذلك فليفرحُوا هو خيرٌ مما يجمعونَ﴾</q> مِن عَرَضِ الدنيا مِن الأموال»{28}. (٧/٦٧٠) ٣٤٦١٣- عن عبد الله بن عباس -من طريق ابن جُرَيْج- <q>﴿خيرٌ ممّا يجمعونَ﴾</q>، قال: مِن الأموال، والحَرْث، والأنعام{29}. (٧/٦٧٠) ٣٤٦١٤- عن هلال بن يساف -من طريق منصور-: <q>﴿فبذلك فليفرحوا هو خير مما يجمعون﴾</q> مِن الذَّهَب، والفِضَّة{30}. (ز) ٣٤٦١٥- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- قوله: <q>﴿هو خير مما يجمعون﴾</q>، قال: خيرٌ مِمّا تجمع الكفارُ مِن الأموال{31}. (ز) ٣٤٦١٦- عن الحسن البصري، مثله{32}. (ز) ٣٤٦١٧- عن محمد بن كعبٍ القرظي -من طريق أبي معشر- في الآية، قال: إذا عملتَ خيرًا حَمِدتَ الله عليه، فافرح فهو خيرٌ مما تجمعون من الدنيا{23}. (٧/٦٧٠) ٣٤٦١٨- عن أبي التَّيّاح -من طريق هارون- <q>﴿فبذلك فليفرحوا هو خير مما يجمعون﴾</q>، يعني: الكُفّار{4}٣١٢٩. (ز) ٣١٢٩ ذكر ابنُ عطية (٤/٤٩٥) فائدة لطيفة، فقال: «إن قيل: كيف أمر الله بالفرح في هذه الآية وقد ورد ذمُّه في قوله: <q>﴿لفرح فخور﴾</q> [هود:١٠]، وفي قوله: <q>﴿لا تفرح إن الله لا يحب الفرحين﴾</q> [القصص:٧٦]؟ قيل: إنّ الفرح إذا ورد مقيدًا في خير فليس بمذموم، وكذلك هو في هذه الآية، وإذا ورد مقيدًا في شر أو مُطلقًا لَحِقَه ذمٌّ؛ إذ ليس من أفعال الآخرة، بل ينبغي أن يغلب على الإنسان حزنه على ذنبه وخوفه لربه». وبنحوه قال ابنُ القيم (٢/٣٨). ٣٤٦١٩- قال مقاتل بن سليمان: <q>﴿فَبِذَلِكَ فَلْيَفْرَحُوا﴾</q> معشر المسلمين، <q>﴿هُوَ خَيْرٌ مِمّا يَجْمَعُونَ﴾</q> مِن الأموال. فلمّا نزلت هذه الآيةُ قرأها النبيُّ ﷺ مرّاتٍ{26}. (ز) ",footnotes:1:أخرجه ابن أبي عمر العدني -كما في المطالب العالية ١٤/٧٢٢ (٣٦٣١)-، من طريق بشر بن السري، عن عبد الله بن المبارك، عن فضيل بن مرزوق، عن عطية العوفي، عن ابن عمر به. قال الدارقطني في أطراف الغرائب والأفراد ٣/٤٠٣: «تفرَّد به عليُّ بن سعيد بن بشير، عن ابن أبي عمر، عن بشر بن السري، عن عبد الله بن المبارك، عن فضيل بن مرزوق، عن عطية». ومع غرابته ففيه عطية العوفي، وقد تقدّم ضعفه، فكيف إذا تفرّد. و‹فَلْتَفْرَحُواْ› بالتاء قراءة متواترة، قرأ بها رويس عن يعقوب، وقرأ بقية العشرة: <q>﴿فَلْيَفْرَحُواْ﴾</q> بالياء. انظر: النشر ٢/٢٨٥، والإتحاف ص٣١٦.أخرجه الطيالسي في مسنده ١/٤٤٠ (٥٤٧) واللفظ له، وأبو داود ٦/١٠٧ (٣٩٨١). ينظر: تخريج الحديث السابق.أخرجه أحمد ٣٥/٧١-٧٤ (٢١١٣٦-٢١١٣٧)، وأبو داود ٦/١٠٧ (٣٩٨٠)، والحاكم ٢/٢٦٣، وابن جرير ١٢/١٩٨، وابن أبي حاتم ٦/١٩٥٩ (١٠٤٣١)، من طريق يحيى بن سعيد، عن أجلح، ثنا عبد الله بن عبد الرحمن بن أبزي، عن أبيه، عن أُبَيٍّ به. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». قال الألباني في الصحيحة ٦/٩٦٣: «ووافقه الذهبي، وهو كما قالا». و‹تَجْمَعُونَ› بالتاء قراءة متواترة، قرأ بها ابن عامر، وأبو جعفر، ورويس، وقرأ بقية العشرة: <q>﴿يَجْمَعُونَ﴾</q> بالياء. انظر: النشر ٢/٢٨٥، والإتحاف ص٣١٦.أخرجه ابن جرير ١٢/١٩٨.أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٢/١٢٨-. وأورده الديلمي في الفردوس ٣/٢١٧ (٤٦٢٦). قال الزيلعي بعد ذكره لرواية ابن مردويه: «غريب مرفوعًا».أخرجه ابن أبي حاتم ٦/١٩٦٠، والطبراني -كما في تفسير ابن كثير ٤/٢١١-.أخرجه سعيد بن منصور (١٠٦٤ - تفسير)، وابن أبي شيبة ١٠/٥٠١، وابن جرير ١٢/١٩٤-١٩٥، وابن أبي حاتم ٦/١٩٥٨، والبيهقي في شعب الإيمان (٢٥٩٨). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه الطبراني في الأوسط (٥٥١٢).أخرجه سعيد بن منصور (١٠٦٣- تفسير)، والبيهقي (٢٥٩٥). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/١٩٦-١٩٧، وابن أبي حاتم ٦/١٩٥٩، والبيهقي (٢٥٩٦). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٠/٥٠٢، وابن جرير ١٢/١٩٧، وابن أبي حاتم ٦/١٩٥٩، والبيهقي (٢٥٩٧). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه الخطيب ٥/١٥، وابن عساكر ٤٢/٣٦٢.تفسير الثعلبي ٥/١٣٥، وتفسير البغوي ٤/١٣٨.أخرجه ابن جرير ١٢/١٩٥-١٩٦، والبيهقي (٢٦٠١).أخرجه ابن جرير ١٢/١٩٥-١٩٦، والبيهقي (٢٦٠٢).أخرجه ابن أبي شيبة ١٠/٥٠٢، وابن جرير ١٢/١٩٦.أخرجه سعيد بن منصور (١٠٦٥ - تفسير)، وابن جرير ١٢/١٩٧-١٩٨، والبيهقي (٢٦٠٠).تفسير الثعلبي ٥/١٣٥، وتفسير البغوي ٤/١٣٨.أخرجه ابن أبي شيبة ١٠/٥٠٢.أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/١٩٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٦٣-.أخرجه ابن جرير ١٢/١٩٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٦٣-.أخرجه ابن أبي حاتم ٦/١٩٥٩.أخرجه ابن أبي حاتم ٦/١٩٥٩.أخرجه ابن جرير ٢/١٩٧، وابن أبي حاتم ٦/١٩٥٩، والبيهقي (٢٥٩٩).تفسير مقاتل بن سليمان ٢/٢٤٢.تفسير الثعلبي ٥/١٣٥.أخرجه ابن بشران في أماليه ١/٢١٢ (٤٩٣)، من طريق إسماعيل بن أبي زياد، عن أبان بن أبي عياش، عن أنس به. إسناده ضعيف جِدًّا؛ فيه أبان بن أبي عياش، قال عنه ابن حجر في التقريب (١٤٢): «متروك». والراوي عنه إسماعيل بن أبي زياد، إن كان هو ابن مسلم الشامي فهو «متروك الحديث» أيضًا كما في اللسان لابن حجر ٢/١٢٦.أخرجه ابن جرير ٢/١٩٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/١٩٥.أخرجه ابن أبي حاتم ٦/١٩٦٠.علَّقه ابن أبي حاتم ٦/١٩٦٠.أخرجه ابن أبي حاتم ٦/١٩٥٩.أخرجه ابن جرير ١٢/١٩٨.تفسير مقاتل بن سليمان ٢/٢٤٢.
10,59," <q>﴿قُلۡ أَرَءَیۡتُم مَّاۤ أَنزَلَ ٱللَّهُ لَكُم مِّن رِّزۡقࣲ فَجَعَلۡتُم مِّنۡهُ حَرَامࣰا وَحَلَـٰلࣰا قُلۡ ءَاۤللَّهُ أَذِنَ لَكُمۡۖ أَمۡ عَلَى ٱللَّهِ تَفۡتَرُونَ ۝٥٩﴾</q> - تفسير ٣٤٦٢٠- عن عبد الله بن عباس -من طريق عطِيَّة- في قوله: <q>﴿قل أرأيتُم ما أنزلَ اللهُ لكُم من رزقٍ﴾</q> الآية، قال: هم أهلُ الشِّرك، كانوا يُحِلُّون مِن الحرث والأنعام ما شاءوا، ويُحَرِّمون ما شاءوا{1}. (٧/٦٧١) ٣٤٦٢١- عن عبد الله بن عباس -من طريق علي- قال: إنّ أهل الجاهلية كانوا يُحَرِّمون أشياء أحلَّها اللهُ من الثياب وغيرها، وهو قول الله: <q>﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</q>، وهو هذا؛ فأنزل الله تعالى: <q>﴿قل من حرم زينة الله التي أخرج لعباده ...﴾</q> [الأعراف:٣٢] الآية{2}. (ز) ٣٤٦٢٢- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿فَجَعَلْتُمْ مِنهُ حَرامًا وحَلالًا﴾</q>، قال: الحَرْث، والأنعام{2}. (ز) ٣٤٦٢٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فجعلتم منه حراما وحلالا﴾</q>، قال: في البَحِيرة، والسّائِبة{4}. (ز) ٣٤٦٢٤- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- قال في قوله: <q>﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</q>: هو الذي قال الله: <q>﴿وجعلوا لله مما ذرأ من الحرث والأنعام نصيبا﴾</q> إلى قوله: <q>﴿ساء ما يحكمون﴾</q> [الأنعام:١٣٦]{5}. (ز) ٣٤٦٢٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</q> الآية، يقول: كلّ رزق لم أُحَرِّم حَرَّمتُموه على أنفسكم مِن نسائكم وأموالكم وأولادكم، <q>﴿آلله أذن لكم﴾</q> فيما حرَّمتُم من ذلك، <q>﴿أم على الله تفترون﴾</q>{6}. (ز) ٣٤٦٢٦- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> لكفار قريش، وخزاعة، وثقيف، وعامر بن صَعْصَعَة، وبني مدلج، والحارث ابني عبد مناة، قل لهم: <q>﴿أرَأَيْتُمْ ما أنْزَلَ اللَّهُ لَكُمْ مِن رِزْقٍ﴾</q> يعني: البَحِيرة، والسائبة، والوَصِيلَة، والحامِ، <q>﴿فَجَعَلْتُمْ مِنهُ حَرامًا﴾</q> يعني: حرَّمتم منه ما شئتُم، <q>﴿وحَلالًا﴾</q> يعني: وحلَّلْتُم منه ما شئتُم، <q>﴿قُلْ آللَّهُ أذِنَ لَكُمْ أمْ عَلى اللَّهِ تَفْتَرُونَ﴾</q>{7}. (ز) ٣٤٦٢٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</q>، فقرأ حتى بلغ: <q>﴿أم على الله تفترون﴾</q>، وقرأ: <q>﴿وقالوا ما في بطون هذه الأنعام خالصة لذكورنا ومحرم على أزواجنا﴾</q> [الأنعام:١٣٩]، وقرأ: <q>﴿وقالوا هذه أنعام وحرث حجر﴾</q> حتى بلغ: <q>﴿لا يذكرون اسم الله عليها﴾</q> [الأنعام:١٣٨]. فقال: هذا قوله، جعل لهم رزقًا، فجعلوا منه حرامًا وحلالًا، وحرَّموا بعضه، وأحلُّوا بعضه. وقرأ: <q>﴿ثمانية أزواج من الضأن اثنين ومن المعز اثنين قل آلذكرين حرم أم الأنثيين أما اشتملت عليه أرحام الأنثيين﴾</q>، أي: هذين حرَّم على هؤلاء الذين يقولون، وأَحَلَّ لهؤلاء؟ <q>﴿نبئوني بعلم إن كنتم صادقين﴾</q> [الأنعام:١٤٣]، <q>﴿أم كنتم شهداء إذ وصاكم الله بهذا﴾</q> [الأنعام:١٤٤] إلى آخر الآيات{8}. (ز) <q>﴿قُلۡ أَرَءَیۡتُم مَّاۤ أَنزَلَ ٱللَّهُ لَكُم مِّن رِّزۡقࣲ فَجَعَلۡتُم مِّنۡهُ حَرَامࣰا وَحَلَـٰلࣰا قُلۡ ءَاۤللَّهُ أَذِنَ لَكُمۡۖ أَمۡ عَلَى ٱللَّهِ تَفۡتَرُونَ ۝٥٩﴾</q> - آثار متعلقة بالآية ٣٤٦٢٨- عن أبي سعيد مولى أبي أسيد الأنصاريِّ، قال: أتى وفدُ أهل مصرَ عثمانَ، فقالوا له: ادعُ بالمصحف، وافتتح السابعةَ. وكانوا يُسَمُّون سورة يونس: السّابِعة، فقرأها حتى أتى على هذه الآية: <q>﴿قل أرأيتم ما أنزل اللهُ لكُم من رزقٍ فجعلتُم منه حرامًا وحلالًا﴾</q> الآية. فقالوا له: قِفْ، أرَأَيْتَ ما حَمَيْتَ مِن الحِمى، آللَّهُ أذِن لك أم على الله تفترِي؟ فقال: امْضِه، إنّما نزلت في كذا وكذا، فأمّا الحِمى فإنّ عُمَرَ حَمى الحِمى قبلي لإبلِ الصدقة، فلمّا وُلِّيتُ وزادَتْ إبِلُ الصَّدقة زِدتُ في الحِمى{9}. (٧/٦٧١) ",footnotes:1:أخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه.أخرجه ابن جرير ١٢/٢٠١.أخرجه ابن جرير ١٢/٢٠١.تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦١.أخرجه ابن جرير ١٢/٢٠٣، وابن أبي حاتم ٦/١٩٦١.أخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦٠ بنحوه.تفسير مقاتل بن سليمان ٢/٢٤٢.أخرجه ابن جرير ١٢/٢٠٢.أخرجه ابن أبي شيبة ١٥/٢١٥، ٢١٦ مطولًا، والحاكم ٢/٣٣٩، والبيهقي في سننه ٦/١٤٧، وابن عساكر ٣٩/٢٥٧، ٣٢٣، والبزار في البحر الزخار المعروف بمسند البزار ٢/٤٢-٤٥ (٣٨٩).
10,60," <q>﴿وَمَا ظَنُّ ٱلَّذِینَ یَفۡتَرُونَ عَلَى ٱللَّهِ ٱلۡكَذِبَ یَوۡمَ ٱلۡقِیَـٰمَةِۗ إِنَّ ٱللَّهَ لَذُو فَضۡلٍ عَلَى ٱلنَّاسِ وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَشۡكُرُونَ ۝٦٠﴾</q> - تفسير ٣٤٦٢٩- قال مقاتل بن سليمان: <q>﴿وما ظَنُّ الَّذِينَ يَفْتَرُونَ﴾</q> في الدنيا <q>﴿عَلى اللَّهِ الكَذِبَ﴾</q> فزعموا: أنّ له شريكًا <q>﴿يَوْمَ القِيامَةِ إنَّ اللَّهَ لَذُو فَضْلٍ عَلى النّاسِ﴾</q> حين لا يُؤاخِذهم عند كُلِّ ذَنب، <q>﴿ولَكِنَّ أكْثَرَهُمْ لا يَشْكُرُونَ﴾</q> هذه النِّعَم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٢.
10,61," <q>﴿وَمَا تَكُونُ فِی شَأۡنࣲ وَمَا تَتۡلُوا۟ مِنۡهُ مِن قُرۡءَانࣲ وَلَا تَعۡمَلُونَ مِنۡ عَمَلٍ إِلَّا كُنَّا عَلَیۡكُمۡ شُهُودًا إِذۡ تُفِیضُونَ فِیهِۚ﴾</q> - تفسير ٣٤٦٣٠- عن عبد الله بن عباس -من طريق علي- <q>﴿إذ تُفيضون فيه﴾</q>، قال: إذ تفعَلون{1}. (٧/٦٧٢) ٣٤٦٣١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح-: <q>﴿إذ تفيضون فيه﴾</q> في الحقِّ ما كان{2}. (ز) ٣٤٦٣٢- عن الضحاك بن مزاحم -من طريق أبي رَوْق- <q>﴿إذ تفيضون فيه﴾</q>، يقول: تُشِيعُون في القرآن مِن الكَذِب{3}. (ز) ٣٤٦٣٣- قال مقاتل بن سليمان: <q>﴿وما تَكُونُ فِي شَأْنٍ وما تَتْلُو مِنهُ مِن قُرْآنٍ ولا تَعْمَلُونَ مِن عَمَلٍ إلّا كُنّا عَلَيْكُمْ شُهُودًا﴾</q> يعني: إلا وقد عَلِمْتُه قبل أن تَعْمَلُوه <q>﴿إذْ تُفِيضُونَ فِيهِ﴾</q> وأنا شاهِدُكم، يعني: إذ تعملونه{4}٣١٣٠. (ز) ٣١٣٠ اختُلِف في تأويل قوله تعالى: <q>﴿إذ تفيضون فيه﴾</q> على ثلاثة أقوال: أولها: إذ تفعلون. وثانيها: إذ تُشِيعون في القرآن الكذبَ. وثالثها: إذ تفيضون في الحق. ورجَّحَ ابنُ جرير (١٢/٢٠٥-٢٠٦) القولَ الأولَ -وهو قول عبد الله بن عباس- استنادًا إلى السياق، فقال: «إنما اخترنا القول الذي اخترناه فيه لأنّه -تعالى ذِكْرُه- أخبر أنّه لا يعمل عبادُه عملًا إلا كان شاهدَه، ثم وصل ذلك بقوله: <q>﴿إذ تفيضون فيه﴾</q>، فكان معلومًا أن قوله: <q>﴿إذ تفيضون فيه﴾</q> إنما هو خبرٌ منه عن وقت عمل العاملين أنّه له شاهد، لا عن وقْت تلاوة النبي ﷺ القرآن؛ لأنّ ذلك لو كان خبرًا عن شهوده -تعالى ذِكْرُه- وقتَ إفاضة القوم في القرآن لكانت القراءة بالياء: إذ يفيضون فيه. خبرًا منه عن المكذبين فيه. فإن قال قائل: ليس ذلك خبرًا عن المكذبين، ولكنه خطاب للنبي ﷺ أنّه شاهده إذْ تلا القرآن. فإنّ ذلك لو كان كذلك لكان التنزيل: إذ تفيض فيه. لأنّ النبي ﷺ واحدٌ لا جمع، كما قال: <q>﴿وما تتلوا منه من قرآن﴾</q>، فأفرده بالخطاب، ولكن ذلك في ابتدائه خطابَه ﷺ بالإفراد، ثم عَوْده إلى إخراج الخطاب على الجمع نظير قوله: <q>﴿يا أيُّها النَّبِيُّ إذا طَلَّقْتُمُ النِّساءَ﴾</q> [الطلاق:١]، وذلك أنّ في قوله: <q>﴿إذا طلقتم النساء﴾</q> دليلًا واضِحًا على صرفه الخطابَ إلى جماعة المسلمين مع النبي ﷺ مع جماعة الناس غيره؛ لأنه ابتدأ خطابه، ثم صرف الخطابَ إلى جماعة الناس، والنبي ﷺ فيهم. وخبرٌ عن أنّه لا يعمل أحدٌ من عباده عملًا إلا وهو له شاهد، يُحْصِي عليه ويعلمُه، كما قال: <q>﴿وما يعزب عن ربك﴾</q> يا محمد عملَ خلقِه، ولا يذهب عليه عِلْمُ شيءٍ حيث كان من أرض أو سماء». وفي كلام ابن عطية (٤/٤٩٦)، وابن كثير (٧/٣٧٤) ما يُفيدُ ذهابهما إلى هذا القول. <q>﴿وَمَا یَعۡزُبُ عَن رَّبِّكَ مِن مِّثۡقَالِ ذَرَّةࣲ فِی ٱلۡأَرۡضِ وَلَا فِی ٱلسَّمَاۤءِ﴾</q> - تفسير ٣٤٦٣٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وما يَعْزُبُ﴾</q>، قال: ما يَغِيبُ{5}. (٧/٦٧٢) ٣٤٦٣٥- عن مجاهد بن جبر -من طريق يحيى-، مثله{6}. (٧/٦٧٢) ٣٤٦٣٦- عن إسماعيل السدي: <q>﴿وما يعزُبُ عن رَّبك من مثقال ذرَّة﴾</q>، قال: لا يَغِيبُ عنه وزنُ ذرةٍ{7}. (٧/٦٧٢) ٣٤٦٣٧- قال مقاتل بن سليمان: <q>﴿وما يَعْزُبُ﴾</q> يعني: وما يَغِيب <q>﴿عَنْ رَبِّكَ مِن مِثْقالِ ذَرَّةٍ﴾</q> يعني: وزن ذرَّة <q>﴿فِي الأَرْضِ ولا فِي السَّماءِ﴾</q>{8}. (ز) <q>﴿وَلَاۤ أَصۡغَرَ مِن ذَ ٰ⁠لِكَ وَلَاۤ أَكۡبَرَ إِلَّا فِی كِتَـٰبࣲ مُّبِینٍ ۝٦١﴾</q> - تفسير ٣٤٦٣٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿في كتاب مبين﴾</q>، قال: كلُّ ذلك في كتابٍ عند الله مبين{9}. (ز) ٣٤٦٣٩- عن إسماعيل السُّدِّيّ، <q>﴿ولا أصغر من ذلكَ ولا أكبر إلا في كتاب مبين﴾</q>، قال: هو الكتاب الذي عند الله{7}٣١٣١. (٧/٦٧٢) ٣١٣١ قال ابنُ عطية (٤/٤٩٧): «ويحتمل أن يريد تحصيل الكتبة، ويكون القصد ذكر الأعمال المذكورة قبل». ٣٤٦٤٠- قال مقاتل بن سليمان: <q>﴿ولا أصْغَرَ مِن ذَلِكَ ولا أكْبَرَ إلّا فِي كِتابٍ مُبِينٍ﴾</q>، يعني: اللوح المحفوظ{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٢٠٤، وابن أبي حاتم ٦/١٩٦٢. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦٣.أخرجه ابن جرير ١٢/٢٠٥.تفسير مقاتل بن سليمان ٢/٢٤٢-٢٤٣.أخرجه ابن جرير ١٢/٢٠٨. وابن أبي حاتم ٦/١٩٦٢. وعزاه السيوطي إلى عبد بن حميد، والفريابي، وابن المنذر.أخرجه ابن جرير ١٢/٢٠٨. وعزاه السيوطي إلى الفريابي.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٢٤٣.أخرجه ابن أبي حاتم ٦/١٩٦٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٢٤٣.
