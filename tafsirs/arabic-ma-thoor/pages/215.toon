quran[8]{c,v,t}:
  10,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ أَنَّ لِكُلِّ نَفۡسࣲ ظَلَمَتۡ مَا فِی ٱلۡأَرۡضِ لَٱفۡتَدَتۡ بِهِۦۗ وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلۡعَذَابَۖ وَقُضِیَ بَیۡنَهُم بِٱلۡقِسۡطِ وَهُمۡ لَا یُظۡلَمُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿وهم لا يظلمون﴾</span>، يعني: مِن أعمالهم، فلا يُنقَص من حسابهم{1}، ولا يُزاد على سيِّئاتهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ولَوْ أنَّ لِكُلِّ نَفْسٍ﴾</span> كافِرة <span class="qpc-hafs">﴿ظَلَمَتْ ما فِي الأَرْضِ﴾</span> مالًا <span class="qpc-hafs">﴿لافْتَدَتْ بِهِ﴾</span> نفسَها يوم القيامة مِن عذاب جهنم، <span class="qpc-hafs">﴿وأَسَرُّوا النَّدامَةَ لَمّا رَأَوُا العَذابَ﴾</span> يعني: حين رأوا العذاب، <span class="qpc-hafs">﴿وقُضِيَ بَيْنَهُمْ بِالقِسْطِ﴾</span> يعني: بالعدل، وصاروا إلى جهنم بشِرْكهم، وصار المؤمنون إلى الجنة بإيمانهم، <span class="qpc-hafs">﴿وهُمْ لا يُظْلَمُونَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:كذا في المطبوع، ولعلها: حسناتهم.|2:أخرجه ابن أبي حاتم ٦/١٩٥٦.|3:تفسير مقاتل بن سليمان ٢/٢٤١.
  10,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَاۤ إِنَّ لِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۗ أَلَاۤ إِنَّ وَعۡدَ ٱللَّهِ حَقࣱّ وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَعۡلَمُونَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ألا إنَّ لِلَّهِ ما فِي السَّماواتِ والأَرْضِ﴾</span> يقول: هو ربُّ مَن فيهما، <span class="qpc-hafs">﴿ألا إنَّ وعْدَ اللَّهِ حَقٌّ﴾</span> أنّ مَن وحَّده أثابه الجنة، ومَن كفر به عاقبه بالنار، <span class="qpc-hafs">﴿ولَكِنَّ أكْثَرَهُمْ لا يَعْلَمُونَ﴾</span> يعني: مِن كلِّ ألفٍ تسعمائةٌ وتسعة [وتسعون] إلى النار، وواحد إلى الجنة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤١-٢٤٢.
  10,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ یُحۡیِۦ وَیُمِیتُ وَإِلَیۡهِ تُرۡجَعُونَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر بصنيعه لِيُوَحَّد، فقال: <span class="qpc-hafs">﴿هُوَ يُحْيِي﴾</span> مِن النُّطَف، <span class="qpc-hafs">﴿ويُمِيتُ﴾</span> مِن بعد الحياة، فاعبدوا مَن يُحْيِي ويُمِيت، <span class="qpc-hafs">﴿وإلَيْهِ تُرْجَعُونَ﴾</span> مِن بعد الموت، فيجزيكم في الآخرة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٢.
  10,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّاسُ قَدۡ جَاۤءَتۡكُم مَّوۡعِظَةࣱ مِّن رَّبِّكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٦٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق بيان- قوله: <span class="qpc-hafs">﴿موعظة﴾</span>، قال: موعظة مِن الجهل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها النّاسُ قَدْ جاءَتْكُمْ مَوْعِظَةٌ﴾</span> يعني: بَيِّنة <span class="qpc-hafs">﴿مِن رَبِّكُمْ﴾</span> وهو ما بَيَّن اللهُ في القرآن{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَشِفَاۤءࣱ لِّمَا فِی ٱلصُّدُورِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٧١<span class="dash">-</span></span> عن أبي سعيد الخدريِّ، قال: جاء رجلٌ إلى النبيِّ ﷺ، فقال: إنِّي أشْتَكي صَدْري. فقال: «<b>اقرَأ القرآنَ</b>». يقول الله: <span class="qpc-hafs">﴿وشِفَآءٌ لِما فِي الصُّدُورِ﴾</span>{3}. (٧/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٢<span class="dash">-</span></span> عن واثلةَ بن الأسْقَع: أنّ رجلًا شَكا إلى النبيِّ ﷺ وجعَ حَلْقِه، قال: «<b>عليك بقراءةِ القرآنِ</b>»{4}. (٧/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٣<span class="dash">-</span></span> عن أبي الأَحْوصِ، قال: جاء رجلٌ إلى <span class="name-1">عبد الله بن مسعود</span>، فقال: إنّ أخي يَشْتَكي بطنَه، فوُصِف له الخمرُ. فقال: سبحانَ اللهِ! ما جعَل اللهُ في رِجْسٍ شفاءً، إنّما الشفاءُ في شيئين؛ القرآنِ، والعسلِ، فهما شفاءٌ لمِا في الصدورِ، وشفاءٌ للناسِ{5}. (٧/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحْوصِ- قال: في القرآنِ شفاءان؛ القرآنُ، والعسلُ، فالقرآنُ شفاءٌ لما في الصدورِ، والعسلُ شفاءٌ مِن كلِّ داءٍ{1}. (٧/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿وشفاء﴾</span>، قال: الشفاء: القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: إنّ الله تعالى جعَل القرآنَ شِفاءً لِما في الصدورِ، ولم يجعلْه شفاءً لأمْراضِكم{8}. (٧/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٧<span class="dash">-</span></span> عن <span class="name-2">طلحةَ بنِ مُصَرِّفٍ</span> -من طريق عيسى بن عمر- قال: كان يُقال: إنّ المريضَ إذا قُرِئ عندَه القرآنُ وجَد له خِفَّةً، فدخَلتُ على خيثمةَ وهو مريضٌ، فقلت: إنِّي أراك اليومَ صالحًا. قال: إنّه قُرِئَ عندي القرآن{9}. (٧/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وشِفاءٌ لِما فِي الصُّدُورِ﴾</span> مِن الكُفر والشِّرك{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُدࣰى﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿هدى﴾</span>، يعني: تبيانًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق بيان- <span class="qpc-hafs">﴿هدى﴾</span>، قال: هُدًى مِن الضلالة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿هدى﴾</span>، قال: نور{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>هذا القرآن <span class="qpc-hafs">﴿هُدًى﴾</span> مِن الضلالة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرَحۡمَةࣱ لِّلۡمُؤۡمِنِینَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٨٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع بن أنس- قوله: <span class="qpc-hafs">﴿ورحمة﴾</span>، قال: رحمة القرآن{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورَحْمَةٌ لِلْمُؤْمِنِينَ﴾</span> لِمَن أحلَّ حلاله، وحرَّم حرامه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٧.|2:تفسير مقاتل بن سليمان ٢/٢٤٢.|3:عزاه السيوطي إلى ابن المنذر، وابن مردويه.|4:أخرجه البيهقي في الشعب ٤/١٧١ (٢٣٤٤)، من طُرُق، عن مكحول، عن واثلة بن الأسقع به.</p><p>إسناده ضعيف؛ مكحول الشامي كثير الإرسال جدًّا، وقد نص أبو زرعة وأبو حاتم الرازِيَّين وغيرُهما أنّه لم يسمع من واثِلة بن الأسقع، وينظر: جامع التحصيل للعلائي ص٢٨٥.|5:أخرجه الطبراني (٨٩١٠). وعزاه السيوطي إلى أبي الشيخ.|6:أخرجه ابن أبي حاتم ٦/١٩٥٧.|7:أخرجه ابن أبي حاتم ٦/١٩٥٧.|8:عزاه السيوطي إلى أبي الشيخ.|9:أخرجه البيهقي (٢٥٧٩).|10:تفسير مقاتل بن سليمان ٢/٢٤٢.|11:أخرجه ابن أبي حاتم ٦/١٩٥٨.|12:أخرجه ابن أبي حاتم ٦/١٩٥٧.|13:أخرجه ابن أبي حاتم ٦/١٩٥٨.|14:تفسير مقاتل بن سليمان ٢/٢٤٢.|15:أخرجه ابن أبي حاتم ٦/١٩٥٨.|16:تفسير مقاتل بن سليمان ٢/٢٤٢.
  10,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ بِفَضۡلِ ٱللَّهِ وَبِرَحۡمَتِهِۦ فَبِذَ ٰ⁠لِكَ فَلۡیَفۡرَحُوا۟ هُوَ خَیۡرࣱ مِّمَّا یَجۡمَعُونَ ۝٥٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٨٥<span class="dash">-</span></span> عن ابن عمرَ، عن النبيِّ ﷺ، أنّه كان يقرأُ: ‹فَبِذَلِكَ فَلْتَفْرَحُواْ›{1}. (٧/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨٦<span class="dash">-</span></span> عن أُبَيِّ بن كعب، قال: أقْرَأني رسول الله ﷺ: ‹فَبِذَلِكَ فَلْتَفْرَحُواْ› بالتاءِ{2}. (٧/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨٧<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span> -من طريق ابن أبْزى، عن أبيه- قال: قال رسول الله ﷺ: «<b>إنّ الله أمَرني أن أقرأَ عليك القرآن</b>». فقلت: أسَمّاني لك؟ قال: «<b>نعم</b>». قيل لأبيٍّ: أفَرِحْتَ بذلك؟ قال: وما يمنعُني، واللهُ يقول: ‹قُلْ بِفَضْلِ الله وبِرَحْمَتِه فَبِذَلِكَ فَلْتَفْرَحُواْ هُوَ خَيْرٌ مِّمّا تَجْمَعُونَ›. هكذا قرَأها بالتاِء{3}. (٧/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٨٨<span class="dash">-</span></span> عن <span class="name-1">أبي بن كعب</span> – من طريق ابن أبزى عن أبيه - أنه كان يقرأ: ‹فَبِذَلِكَ فَلْتَفْرَحُواْ هُوَ خَيْرٌ مِّمّا تَجْمَعُونَ› بالتاءِ{4}<span class=comment-ref>٣١٢٧</span>. (٧/٦٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٧</span> قُرِئَ قوله تعالى: <span class="qpc-hafs">﴿فَلْيَفْرَحُوا﴾</span> بالياء على أنّه خبرٌ عن أهل الشرك بالله، والمعنى على ذلك: فبالإسلام والقرآن الذي دعاهم إليه فليفرح هؤلاء المشركون، فهما خيرٌ من المال الذي يجمعون. وقُرِئَ أيضًا: ‹فَلْتَفْرَحُوا› بالتاء على أنّه خطاب لأهل الإيمان، والمعنى على ذلك: فبالإسلام والقرآن فليفرح أهل الإيمان، فهما خيرٌ من حطام الدنيا، وما فيها من الزهرة الفانية.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (١٢/١٩٩-٢٠٠) قراءة <span class="qpc-hafs">﴿فَلْيَفْرَحُوا﴾</span> بالياء؛ <span class="mustanad">لإجماع الحُجَّة من القراء عليها، وصحتها في العربية.</span></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ بِفَضۡلِ ٱللَّهِ وَبِرَحۡمَتِهِۦ فَبِذَ ٰ⁠لِكَ فَلۡیَفۡرَحُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٨٩<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: «<b>فضلُ اللهِ: القرآنُ، ورحمتُه: أن جعَلكم مِن أهلِه</b>»{5}. (٧/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٠<span class="dash">-</span></span> عن أيْفع الكِلاعيِّ، قال: لَمّا قدم خَراجُ العراق إلى عمر خرج عمرُ ومولًى له، فجعل يَعُدُّ الإبلَ، فإذا هو أكثرُ مِن ذلك، فجعل <span class="name-1">عمرُ</span> يقولُ: الحمدُ لله. وجعل مولاه يقولُ: هذا -واللهِ- من فضل اللهِ ورحمته. فقال عمرُ: كذبتَ، ليس هذا هو الذي يقولُ: <span class="qpc-hafs">﴿قل بفضلِ اللهِ وبرحمته فبذلك فليفرحوا هُو خيرٌ مما يجمعونَ﴾</span>{6}. (٧/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩١<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدريِّ</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: فضلُ اللهِ: القرآنُ، ورحمتُه: أن جعَلكم مِن أهلِه{7}. (٧/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٢<span class="dash">-</span></span> عن <span class="name-1">البراء</span> -من طريق أبي سعيد الخدري-: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، فضلُ اللهِ: القرآنُ، ورحمتُه: أن جعَلهم مِن أهلِه{8}. (٧/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: بكتابِ الله، وبالإسلامِ{9}. (٧/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: فَضْلُه: الإسلامُ، ورحمتُه: القرآنُ{10}. (٧/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في الآية، قال: فضلُ اللهِ: القرآنُ، <span class="qpc-hafs">﴿وبِرَحْمَتِهِ﴾</span>: حينَ جعَلهم مِن أهلِ القرآنِ{11}. (٧/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: فضلُ الله: العلمُ، ورحمتُه: محمدٌ ﷺ؛ قال الله: <span class="qpc-hafs">﴿ومَآ أرْسَلْناكَ إلا رَحْمَةً لِلعالَمِينَ﴾</span> [الأنبياء:١٠٧]{12}. (٧/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله﴾</span> قال: النبي ﷺ، <span class="qpc-hafs">﴿وبرحمته﴾</span> قال: علي بن أبي طالبٍ ﵄{13}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عمر</span>: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span> فضل الله: الإسلام، <span class="qpc-hafs">﴿وبرحمته﴾</span>: تزيينه في القلب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٩٩<span class="dash">-</span></span> عن <span class="name-2">هلال بن يِسافٍ</span> -من طريق سفيان، عن منصور- <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: فضلُ الله: الإسلامُ، ورحمتُه: القرآنُ{15}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٠<span class="dash">-</span></span> عن <span class="name-2">هلالِ بن يِساف</span> -من طريق فضيل، عن منصور- في قوله: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: بالإسلامِ الذي هَداكم، وبالقرآنِ الذي عَلَّمكم{16}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: القرآن{17}. (٧/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في الآية، قال: فضلُ اللهِ: القرانُ، ورحمتُه: الإسلامُ{18}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٣<span class="dash">-</span></span> عن <span class="name-2">خالد بن معدان</span>: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span> فضل الله: الإسلام، <span class="qpc-hafs">﴿وبرحمته﴾</span>: السنة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٤<span class="dash">-</span></span> عن <span class="name-2">سالم بن عبد الله بن عمر</span> -من طريق منصور- <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>: الإسلامِ، والقرآنِ{20}. (٧/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، قال: فضلُه: الإسلامُ، ورحمتُه: القرآنُ{21}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثلَه{22}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي سهيل كثير بن زياد- في قول الله: <span class="qpc-hafs">﴿فبذلك فليفرحوا﴾</span>: بالإسلام، والقرآن{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٨<span class="dash">-</span></span> عن <span class="name-2">القاسم بن أبي بَزَّة</span>، قال: بالقرآن{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٠٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلمَ</span> -من طريق ابنه عبد الرحمن- في الآيةِ، قال: فضلُ اللهِ: القرآنُ، ورحمتُه: الإسلامُ{25}. (٧/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ اللَّهِ﴾</span> يعني: القرآن، <span class="qpc-hafs">﴿وبِرَحْمَتِهِ﴾</span>: الإسلام{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١١<span class="dash">-</span></span> روى <span class="name-3">سفيان بن عيينة</span>: <span class="qpc-hafs">﴿قُلْ بِفَضْلِ الله وبِرَحْمَتِه﴾</span>، فضل الله: التوفيق، ورحمته: العِصْمَة{27}<span class=comment-ref>٣١٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٨</span> أفادت الآثارُ الاختلاف في المراد بفضل الله ورحمته في الآية على عِدَّة أقوال: <b>أولها</b>: أنّ فضل الله: الإسلام، ورحمته: القرآن. <b>وثانيها</b>: أنّ فضل الله: القرآن، ورحمته: الإسلام. <b>وثالثها</b>: أنّ فضل الله: العلم، ورحمته: محمد ﷺ.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ القيم</u> (٢/٣٨ بتصرف) على القولين الأول والثاني بقوله: «التحقيق: أنّ كُلًّا منهما فيه الوصفان الفضل والرحمة، وهما الأمران اللذان امْتَنَّ الله بهما على رسوله ﷺ، فقال: <span class="qpc-hafs">﴿وكذلك أوحينا إليك روحا من أمرنا ما كنت تدري ما الكتاب ولا الإيمان﴾</span> [الشورى:٥٢]، والله ﷾ إنّما رفع مَن رفع بالكتاب والإيمان، ووَضَع مَن وضَع بعدمها، ففضله: الإسلام والإيمان، ورحمته: العلم والقرآن، وهو يُحِبُّ مِن عبده أن يفرح بذلك ويُسَرُّ به، بل يُحِبُّ مِن عبده أن يفرح بالحسنة إذا عملها وأن يُسَرَّ بها، وهو في الحقيقة فَرَحٌ بفضل الله حيث وفَّقه الله لها، وأعانه عليها، ويسَّرها له، ففي الحقيقة إنما يفرح العبد بفضل الله وبرحمته».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (١٢/١٩٤) إلى القول الأول <span class="mustanad">مستندًا إلى أقوال السلف</span>.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (٤/٤٩٣-٤٩٤) إلى الجمعِ <span class="mustanad">مستندًا لعدمِ المُخصّص</span>، فقال: «لا وجه عندي لشيء من هذا التخصيص، إلا أن يستند منه شيء إلى النبي ﷺ، وإنما الذي يقتضيه اللفظ ويلزم منه أنّ الفضل هو هداية الله تعالى إلى دينه والتوفيق إلى اتباع شريعته، والرحمة هي عفوه وسكنى جنته التي جعلها جزاء على التَّشرُّع بالإسلام والإيمان به. ومعنى الآية: قل -يا محمد- لجميع الناس: بفضل الله وبرحمته فليقع الفرح منكم، لا بأمور الدنيا وما جمع من حطامها. فالمؤمنون يُقال لهم: فلتفرحوا وهم مُتَلَبِّسون بعِلَّة الفرح وسببه، ومُحَصِّلون لفضل الله، مُنتَظِرون الرحمة. والكافرون يقال لهم: بفضل الله وبرحمته فلتفرحوا، على معنى: أن لو اتفق لكم، أو لو سُعِدتُم بالهداية إلى تحصيل ذلك».</div></p><p><h3><span class="qpc-hafs">﴿هُوَ خَیۡرࣱ مِّمَّا یَجۡمَعُونَ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٦١٢<span class="dash">-</span></span> عن أنسٍ، قال: قال رسول الله ﷺ: «<b>مَن هداه اللهُ للإسلام، وعلَّمه القرآن، ثُمَّ شكا الفاقَة؛ كتب اللهُ الفقرَ بين عينيه إلى يوم يلقاه</b>». ثم تلا النبيُّ ﷺ: «<b><span class="qpc-hafs">﴿قُلْ بفضل الله وبرحمتهِ فبذلك فليفرحُوا هو خيرٌ مما يجمعونَ﴾</span> مِن عَرَضِ الدنيا مِن الأموال</b>»{28}. (٧/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿خيرٌ ممّا يجمعونَ﴾</span>، قال: مِن الأموال، والحَرْث، والأنعام{29}. (٧/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٤<span class="dash">-</span></span> عن <span class="name-2">هلال بن يساف</span> -من طريق منصور-: <span class="qpc-hafs">﴿فبذلك فليفرحوا هو خير مما يجمعون﴾</span> مِن الذَّهَب، والفِضَّة{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قوله: <span class="qpc-hafs">﴿هو خير مما يجمعون﴾</span>، قال: خيرٌ مِمّا تجمع الكفارُ مِن الأموال{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، مثله{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعبٍ القرظي</span> -من طريق أبي معشر- في الآية، قال: إذا عملتَ خيرًا حَمِدتَ الله عليه، فافرح فهو خيرٌ مما تجمعون من الدنيا{23}. (٧/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦١٨<span class="dash">-</span></span> عن <span class="name-2">أبي التَّيّاح</span> -من طريق هارون- <span class="qpc-hafs">﴿فبذلك فليفرحوا هو خير مما يجمعون﴾</span>، يعني: الكُفّار{4}<span class=comment-ref>٣١٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٩٥) فائدة لطيفة، فقال: «إن قيل: كيف أمر الله بالفرح في هذه الآية وقد ورد ذمُّه في قوله: <span class="qpc-hafs">﴿لفرح فخور﴾</span> [هود:١٠]، وفي قوله: <span class="qpc-hafs">﴿لا تفرح إن الله لا يحب الفرحين﴾</span> [القصص:٧٦]؟ قيل: إنّ الفرح إذا ورد مقيدًا في خير فليس بمذموم، وكذلك هو في هذه الآية، وإذا ورد مقيدًا في شر أو مُطلقًا لَحِقَه ذمٌّ؛ إذ ليس من أفعال الآخرة، بل ينبغي أن يغلب على الإنسان حزنه على ذنبه وخوفه لربه».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٢/٣٨).</div></p><p><div></p><p><p><span class="item-no">٣٤٦١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَبِذَلِكَ فَلْيَفْرَحُوا﴾</span> معشر المسلمين، <span class="qpc-hafs">﴿هُوَ خَيْرٌ مِمّا يَجْمَعُونَ﴾</span> مِن الأموال. فلمّا نزلت هذه الآيةُ قرأها النبيُّ ﷺ مرّاتٍ{26}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي عمر العدني -كما في المطالب العالية ١٤/٧٢٢ (٣٦٣١)-، من طريق بشر بن السري، عن عبد الله بن المبارك، عن فضيل بن مرزوق، عن عطية العوفي، عن ابن عمر به.</p><p>قال الدارقطني في أطراف الغرائب والأفراد ٣/٤٠٣: «تفرَّد به عليُّ بن سعيد بن بشير، عن ابن أبي عمر، عن بشر بن السري، عن عبد الله بن المبارك، عن فضيل بن مرزوق، عن عطية». ومع غرابته ففيه عطية العوفي، وقد تقدّم ضعفه، فكيف إذا تفرّد.</p><p>و‹فَلْتَفْرَحُواْ› بالتاء قراءة متواترة، قرأ بها رويس عن يعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿فَلْيَفْرَحُواْ﴾</span> بالياء. انظر: النشر ٢/٢٨٥، والإتحاف ص٣١٦.|2:أخرجه الطيالسي في مسنده ١/٤٤٠ (٥٤٧) واللفظ له، وأبو داود ٦/١٠٧ (٣٩٨١).</p><p>ينظر: تخريج الحديث السابق.|3:أخرجه أحمد ٣٥/٧١-٧٤ (٢١١٣٦-٢١١٣٧)، وأبو داود ٦/١٠٧ (٣٩٨٠)، والحاكم ٢/٢٦٣، وابن جرير ١٢/١٩٨، وابن أبي حاتم ٦/١٩٥٩ (١٠٤٣١)، من طريق يحيى بن سعيد، عن أجلح، ثنا عبد الله بن عبد الرحمن بن أبزي، عن أبيه، عن أُبَيٍّ به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». قال الألباني في الصحيحة ٦/٩٦٣: «ووافقه الذهبي، وهو كما قالا».</p><p>و‹تَجْمَعُونَ› بالتاء قراءة متواترة، قرأ بها ابن عامر، وأبو جعفر، ورويس، وقرأ بقية العشرة: <span class="qpc-hafs">﴿يَجْمَعُونَ﴾</span> بالياء. انظر: النشر ٢/٢٨٥، والإتحاف ص٣١٦.|4:أخرجه ابن جرير ١٢/١٩٨.|5:أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٢/١٢٨-. وأورده الديلمي في الفردوس ٣/٢١٧ (٤٦٢٦).</p><p>قال الزيلعي بعد ذكره لرواية ابن مردويه: «غريب مرفوعًا».|6:أخرجه ابن أبي حاتم ٦/١٩٦٠، والطبراني -كما في تفسير ابن كثير ٤/٢١١-.|7:أخرجه سعيد بن منصور (١٠٦٤ - تفسير)، وابن أبي شيبة ١٠/٥٠١، وابن جرير ١٢/١٩٤-١٩٥، وابن أبي حاتم ٦/١٩٥٨، والبيهقي في شعب الإيمان (٢٥٩٨). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|8:أخرجه الطبراني في الأوسط (٥٥١٢).|9:أخرجه سعيد بن منصور (١٠٦٣- تفسير)، والبيهقي (٢٥٩٥). وعزاه السيوطي إلى ابن المنذر.|10:أخرجه ابن جرير ١٢/١٩٦-١٩٧، وابن أبي حاتم ٦/١٩٥٩، والبيهقي (٢٥٩٦). وعزاه السيوطي إلى ابن المنذر.|11:أخرجه ابن أبي شيبة ١٠/٥٠٢، وابن جرير ١٢/١٩٧، وابن أبي حاتم ٦/١٩٥٩، والبيهقي (٢٥٩٧). وعزاه السيوطي إلى ابن المنذر.|12:عزاه السيوطي إلى أبي الشيخ.|13:أخرجه الخطيب ٥/١٥، وابن عساكر ٤٢/٣٦٢.|14:تفسير الثعلبي ٥/١٣٥، وتفسير البغوي ٤/١٣٨.|15:أخرجه ابن جرير ١٢/١٩٥-١٩٦، والبيهقي (٢٦٠١).|16:أخرجه ابن جرير ١٢/١٩٥-١٩٦، والبيهقي (٢٦٠٢).|17:أخرجه ابن أبي شيبة ١٠/٥٠٢، وابن جرير ١٢/١٩٦.|18:أخرجه سعيد بن منصور (١٠٦٥ - تفسير)، وابن جرير ١٢/١٩٧-١٩٨، والبيهقي (٢٦٠٠).|19:تفسير الثعلبي ٥/١٣٥، وتفسير البغوي ٤/١٣٨.|20:أخرجه ابن أبي شيبة ١٠/٥٠٢.|21:أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/١٩٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٦٣-.|22:أخرجه ابن جرير ١٢/١٩٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٦٣-.|23:أخرجه ابن أبي حاتم ٦/١٩٥٩.|24:أخرجه ابن أبي حاتم ٦/١٩٥٩.|25:أخرجه ابن جرير ٢/١٩٧، وابن أبي حاتم ٦/١٩٥٩، والبيهقي (٢٥٩٩).|26:تفسير مقاتل بن سليمان ٢/٢٤٢.|27:تفسير الثعلبي ٥/١٣٥.|28:أخرجه ابن بشران في أماليه ١/٢١٢ (٤٩٣)، من طريق إسماعيل بن أبي زياد، عن أبان بن أبي عياش، عن أنس به.</p><p>إسناده ضعيف جِدًّا؛ فيه أبان بن أبي عياش، قال عنه ابن حجر في التقريب (١٤٢): «متروك». والراوي عنه إسماعيل بن أبي زياد، إن كان هو ابن مسلم الشامي فهو «متروك الحديث» أيضًا كما في اللسان لابن حجر ٢/١٢٦.|29:أخرجه ابن جرير ٢/١٩٦. وعزاه السيوطي إلى ابن المنذر.|30:أخرجه ابن جرير ١٢/١٩٥.|31:أخرجه ابن أبي حاتم ٦/١٩٦٠.|32:علَّقه ابن أبي حاتم ٦/١٩٦٠.|33:أخرجه ابن أبي حاتم ٦/١٩٥٩.|34:أخرجه ابن جرير ١٢/١٩٨.|35:تفسير مقاتل بن سليمان ٢/٢٤٢.
  10,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُم مَّاۤ أَنزَلَ ٱللَّهُ لَكُم مِّن رِّزۡقࣲ فَجَعَلۡتُم مِّنۡهُ حَرَامࣰا وَحَلَـٰلࣰا قُلۡ ءَاۤللَّهُ أَذِنَ لَكُمۡۖ أَمۡ عَلَى ٱللَّهِ تَفۡتَرُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٦٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطِيَّة- في قوله: <span class="qpc-hafs">﴿قل أرأيتُم ما أنزلَ اللهُ لكُم من رزقٍ﴾</span> الآية، قال: هم أهلُ الشِّرك، كانوا يُحِلُّون مِن الحرث والأنعام ما شاءوا، ويُحَرِّمون ما شاءوا{1}. (٧/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: إنّ أهل الجاهلية كانوا يُحَرِّمون أشياء أحلَّها اللهُ من الثياب وغيرها، وهو قول الله: <span class="qpc-hafs">﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</span>، وهو هذا؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿قل من حرم زينة الله التي أخرج لعباده ...﴾</span> [الأعراف:٣٢] الآية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿فَجَعَلْتُمْ مِنهُ حَرامًا وحَلالًا﴾</span>، قال: الحَرْث، والأنعام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فجعلتم منه حراما وحلالا﴾</span>، قال: في البَحِيرة، والسّائِبة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قال في قوله: <span class="qpc-hafs">﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</span>: هو الذي قال الله: <span class="qpc-hafs">﴿وجعلوا لله مما ذرأ من الحرث والأنعام نصيبا﴾</span> إلى قوله: <span class="qpc-hafs">﴿ساء ما يحكمون﴾</span> [الأنعام:١٣٦]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</span> الآية، يقول: كلّ رزق لم أُحَرِّم حَرَّمتُموه على أنفسكم مِن نسائكم وأموالكم وأولادكم، <span class="qpc-hafs">﴿آلله أذن لكم﴾</span> فيما حرَّمتُم من ذلك، <span class="qpc-hafs">﴿أم على الله تفترون﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> لكفار قريش، وخزاعة، وثقيف، وعامر بن صَعْصَعَة، وبني مدلج، والحارث ابني عبد مناة، قل لهم: <span class="qpc-hafs">﴿أرَأَيْتُمْ ما أنْزَلَ اللَّهُ لَكُمْ مِن رِزْقٍ﴾</span> يعني: البَحِيرة، والسائبة، والوَصِيلَة، والحامِ، <span class="qpc-hafs">﴿فَجَعَلْتُمْ مِنهُ حَرامًا﴾</span> يعني: حرَّمتم منه ما شئتُم، <span class="qpc-hafs">﴿وحَلالًا﴾</span> يعني: وحلَّلْتُم منه ما شئتُم، <span class="qpc-hafs">﴿قُلْ آللَّهُ أذِنَ لَكُمْ أمْ عَلى اللَّهِ تَفْتَرُونَ﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٢٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا﴾</span>، فقرأ حتى بلغ: <span class="qpc-hafs">﴿أم على الله تفترون﴾</span>، وقرأ: <span class="qpc-hafs">﴿وقالوا ما في بطون هذه الأنعام خالصة لذكورنا ومحرم على أزواجنا﴾</span> [الأنعام:١٣٩]، وقرأ: <span class="qpc-hafs">﴿وقالوا هذه أنعام وحرث حجر﴾</span> حتى بلغ: <span class="qpc-hafs">﴿لا يذكرون اسم الله عليها﴾</span> [الأنعام:١٣٨]. فقال: هذا قوله، جعل لهم رزقًا، فجعلوا منه حرامًا وحلالًا، وحرَّموا بعضه، وأحلُّوا بعضه. وقرأ: <span class="qpc-hafs">﴿ثمانية أزواج من الضأن اثنين ومن المعز اثنين قل آلذكرين حرم أم الأنثيين أما اشتملت عليه أرحام الأنثيين﴾</span>، أي: هذين حرَّم على هؤلاء الذين يقولون، وأَحَلَّ لهؤلاء؟ <span class="qpc-hafs">﴿نبئوني بعلم إن كنتم صادقين﴾</span> [الأنعام:١٤٣]، <span class="qpc-hafs">﴿أم كنتم شهداء إذ وصاكم الله بهذا﴾</span> [الأنعام:١٤٤] إلى آخر الآيات{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُم مَّاۤ أَنزَلَ ٱللَّهُ لَكُم مِّن رِّزۡقࣲ فَجَعَلۡتُم مِّنۡهُ حَرَامࣰا وَحَلَـٰلࣰا قُلۡ ءَاۤللَّهُ أَذِنَ لَكُمۡۖ أَمۡ عَلَى ٱللَّهِ تَفۡتَرُونَ ۝٥٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٦٢٨<span class="dash">-</span></span> عن أبي سعيد مولى أبي أسيد الأنصاريِّ، قال: أتى وفدُ أهل مصرَ <span class="name-1">عثمانَ</span>، فقالوا له: ادعُ بالمصحف، وافتتح السابعةَ. وكانوا يُسَمُّون سورة يونس: السّابِعة، فقرأها حتى أتى على هذه الآية: <span class="qpc-hafs">﴿قل أرأيتم ما أنزل اللهُ لكُم من رزقٍ فجعلتُم منه حرامًا وحلالًا﴾</span> الآية. فقالوا له: قِفْ، أرَأَيْتَ ما حَمَيْتَ مِن الحِمى، آللَّهُ أذِن لك أم على الله تفترِي؟ فقال: امْضِه، إنّما نزلت في كذا وكذا، فأمّا الحِمى فإنّ عُمَرَ حَمى الحِمى قبلي لإبلِ الصدقة، فلمّا وُلِّيتُ وزادَتْ إبِلُ الصَّدقة زِدتُ في الحِمى{9}. (٧/٦٧١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه.|2:أخرجه ابن جرير ١٢/٢٠١.|3:أخرجه ابن جرير ١٢/٢٠١.|4:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦١.|5:أخرجه ابن جرير ١٢/٢٠٣، وابن أبي حاتم ٦/١٩٦١.|6:أخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦٠ بنحوه.|7:تفسير مقاتل بن سليمان ٢/٢٤٢.|8:أخرجه ابن جرير ١٢/٢٠٢.|9:أخرجه ابن أبي شيبة ١٥/٢١٥، ٢١٦ مطولًا، والحاكم ٢/٣٣٩، والبيهقي في سننه ٦/١٤٧، وابن عساكر ٣٩/٢٥٧، ٣٢٣، والبزار في البحر الزخار المعروف بمسند البزار ٢/٤٢-٤٥ (٣٨٩).
  10,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا ظَنُّ ٱلَّذِینَ یَفۡتَرُونَ عَلَى ٱللَّهِ ٱلۡكَذِبَ یَوۡمَ ٱلۡقِیَـٰمَةِۗ إِنَّ ٱللَّهَ لَذُو فَضۡلٍ عَلَى ٱلنَّاسِ وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَشۡكُرُونَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٦٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما ظَنُّ الَّذِينَ يَفْتَرُونَ﴾</span> في الدنيا <span class="qpc-hafs">﴿عَلى اللَّهِ الكَذِبَ﴾</span> فزعموا: أنّ له شريكًا <span class="qpc-hafs">﴿يَوْمَ القِيامَةِ إنَّ اللَّهَ لَذُو فَضْلٍ عَلى النّاسِ﴾</span> حين لا يُؤاخِذهم عند كُلِّ ذَنب، <span class="qpc-hafs">﴿ولَكِنَّ أكْثَرَهُمْ لا يَشْكُرُونَ﴾</span> هذه النِّعَم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٢.
  10,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا تَكُونُ فِی شَأۡنࣲ وَمَا تَتۡلُوا۟ مِنۡهُ مِن قُرۡءَانࣲ وَلَا تَعۡمَلُونَ مِنۡ عَمَلٍ إِلَّا كُنَّا عَلَیۡكُمۡ شُهُودًا إِذۡ تُفِیضُونَ فِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٦٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿إذ تُفيضون فيه﴾</span>، قال: إذ تفعَلون{1}. (٧/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح-: <span class="qpc-hafs">﴿إذ تفيضون فيه﴾</span> في الحقِّ ما كان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي رَوْق- <span class="qpc-hafs">﴿إذ تفيضون فيه﴾</span>، يقول: تُشِيعُون في القرآن مِن الكَذِب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما تَكُونُ فِي شَأْنٍ وما تَتْلُو مِنهُ مِن قُرْآنٍ ولا تَعْمَلُونَ مِن عَمَلٍ إلّا كُنّا عَلَيْكُمْ شُهُودًا﴾</span> يعني: إلا وقد عَلِمْتُه قبل أن تَعْمَلُوه <span class="qpc-hafs">﴿إذْ تُفِيضُونَ فِيهِ﴾</span> وأنا شاهِدُكم، يعني: إذ تعملونه{4}<span class=comment-ref>٣١٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٣٠</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿إذ تفيضون فيه﴾</span> على ثلاثة أقوال: <b>أولها</b>: إذ تفعلون. <b>وثانيها</b>: إذ تُشِيعون في القرآن الكذبَ. <b>وثالثها</b>: إذ تفيضون في الحق.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (١٢/٢٠٥-٢٠٦) القولَ الأولَ -وهو قول عبد الله بن عباس- <span class="mustanad">استنادًا إلى السياق</span>، فقال: «إنما اخترنا القول الذي اخترناه فيه لأنّه -تعالى ذِكْرُه- أخبر أنّه لا يعمل عبادُه عملًا إلا كان شاهدَه، ثم وصل ذلك بقوله: <span class="qpc-hafs">﴿إذ تفيضون فيه﴾</span>، فكان معلومًا أن قوله: <span class="qpc-hafs">﴿إذ تفيضون فيه﴾</span> إنما هو خبرٌ منه عن وقت عمل العاملين أنّه له شاهد، لا عن وقْت تلاوة النبي ﷺ القرآن؛ لأنّ ذلك لو كان خبرًا عن شهوده -تعالى ذِكْرُه- وقتَ إفاضة القوم في القرآن لكانت القراءة بالياء: إذ يفيضون فيه. خبرًا منه عن المكذبين فيه. فإن قال قائل: ليس ذلك خبرًا عن المكذبين، ولكنه خطاب للنبي ﷺ أنّه شاهده إذْ تلا القرآن. فإنّ ذلك لو كان كذلك لكان التنزيل: إذ تفيض فيه. لأنّ النبي ﷺ واحدٌ لا جمع، كما قال: <span class="qpc-hafs">﴿وما تتلوا منه من قرآن﴾</span>، فأفرده بالخطاب، ولكن ذلك في ابتدائه خطابَه ﷺ بالإفراد، ثم عَوْده إلى إخراج الخطاب على الجمع نظير قوله: <span class="qpc-hafs">﴿يا أيُّها النَّبِيُّ إذا طَلَّقْتُمُ النِّساءَ﴾</span> [الطلاق:١]، وذلك أنّ في قوله: <span class="qpc-hafs">﴿إذا طلقتم النساء﴾</span> دليلًا واضِحًا على صرفه الخطابَ إلى جماعة المسلمين مع النبي ﷺ مع جماعة الناس غيره؛ لأنه ابتدأ خطابه، ثم صرف الخطابَ إلى جماعة الناس، والنبي ﷺ فيهم. وخبرٌ عن أنّه لا يعمل أحدٌ من عباده عملًا إلا وهو له شاهد، يُحْصِي عليه ويعلمُه، كما قال: <span class="qpc-hafs">﴿وما يعزب عن ربك﴾</span> يا محمد عملَ خلقِه، ولا يذهب عليه عِلْمُ شيءٍ حيث كان من أرض أو سماء».</p><p>وفي كلام <u>ابن عطية</u> (٤/٤٩٦)، و<u>ابن كثير</u> (٧/٣٧٤) ما يُفيدُ <span class="comment-type-4">ذهابهما</span> إلى هذا القول.</div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَعۡزُبُ عَن رَّبِّكَ مِن مِّثۡقَالِ ذَرَّةࣲ فِی ٱلۡأَرۡضِ وَلَا فِی ٱلسَّمَاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وما يَعْزُبُ﴾</span>، قال: ما يَغِيبُ{5}. (٧/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق يحيى-، مثله{6}. (٧/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>: <span class="qpc-hafs">﴿وما يعزُبُ عن رَّبك من مثقال ذرَّة﴾</span>، قال: لا يَغِيبُ عنه وزنُ ذرةٍ{7}. (٧/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿وما يَعْزُبُ﴾</span> يعني: وما يَغِيب <span class="qpc-hafs">﴿عَنْ رَبِّكَ مِن مِثْقالِ ذَرَّةٍ﴾</span> يعني: وزن ذرَّة <span class="qpc-hafs">﴿فِي الأَرْضِ ولا فِي السَّماءِ﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَاۤ أَصۡغَرَ مِن ذَ ٰ⁠لِكَ وَلَاۤ أَكۡبَرَ إِلَّا فِی كِتَـٰبࣲ مُّبِینٍ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٦٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿في كتاب مبين﴾</span>، قال: كلُّ ذلك في كتابٍ عند الله مبين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿ولا أصغر من ذلكَ ولا أكبر إلا في كتاب مبين﴾</span>، قال: هو الكتاب الذي عند الله{7}<span class=comment-ref>٣١٣١</span>. (٧/٦٧٢)</p></p><p></div></p><p><div><span class=comment-ref>٣١٣١</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٤/٤٩٧): «ويحتمل أن يريد تحصيل الكتبة، ويكون القصد ذكر الأعمال المذكورة قبل».</div></p><p><div></p><p><p><span class="item-no">٣٤٦٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿ولا أصْغَرَ مِن ذَلِكَ ولا أكْبَرَ إلّا فِي كِتابٍ مُبِينٍ﴾</span>، يعني: اللوح المحفوظ{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٢٠٤، وابن أبي حاتم ٦/١٩٦٢. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/٢٠٢، وابن أبي حاتم ٦/١٩٦٣.|3:أخرجه ابن جرير ١٢/٢٠٥.|4:تفسير مقاتل بن سليمان ٢/٢٤٢-٢٤٣.|5:أخرجه ابن جرير ١٢/٢٠٨. وابن أبي حاتم ٦/١٩٦٢. وعزاه السيوطي إلى عبد بن حميد، والفريابي، وابن المنذر.|6:أخرجه ابن جرير ١٢/٢٠٨. وعزاه السيوطي إلى الفريابي.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٢/٢٤٣.|9:أخرجه ابن أبي حاتم ٦/١٩٦٣.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٢٤٣.