tafsir[9]{c,v,t}:
6,82," <q>﴿ٱلَّذِینَ ءَامَنُوا۟ وَلَمۡ یَلۡبِسُوۤا۟ إِیمَـٰنَهُم بِظُلۡمٍ أُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡأَمۡنُ وَهُم مُّهۡتَدُونَ ۝٨٢﴾</q> - نزول الآية وتفسيرها ٢٥٤٠١- عن عبد الله بن مسعود، قال: لَمّا نزلت هذه الآية: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q> شَقَّ ذلك على الناس، فقالوا: يا رسول الله، وأيُّنا لا يظلمُ نفسَه؟! قال: «إنّه ليس الذي تعنُون، ألم تسمعوا ما قال العبد الصالح: <q>﴿إن الشرك لظلم عظيم﴾</q>؟ [لقمان:١٣]. إنما هو الشرك»{1}. (٦/١١٦) ٢٥٤٠٢- عن علي بن أبي طالب -من طريق زياد بن حَرْمَلة- في قوله: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>، قال: نزَلت هذه في إبراهيم وأصحابه خاصة، ليس في هذه الأُمَّة{2}. (٦/١١٨) ٢٥٤٠٣- عن بكر بن سَوادة -من طريق عبيد الله بن زَحْرٍ- قال: حمَل رجلٌ من العدوِّ على المسلمين، فقتَل رجلًا، ثم حمَل، فقتَل آخر، ثم حمَل، فقتَل آخر، ثم قال: أينفَعُني الإسلامُ بعدَ هذا؟ قالوا: ما ندري. فذكَروا ذلك لرسول الله ﷺ، فقال: «نعم». فضرَب فرسَه، فدخَل فيهم، ثم حمَل على أصحابه، فقتَل رجلًا، ثم آخر، ثم آخر، ثم قُتِل. قال: فيُرَون أن هذه الآية نزَلت فيه: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q> الآية{3}. (٦/١٢٠) ٢٥٤٠٤- عن أبي بكر الصديق -من طريق الأسود بن هلال- أنّه سُئِل عن هذه الآية: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>. قال: ما تقولون؟ قالوا: لم يَظلِموا. قال: حمَلْتم الأمْرَ على أشَدِّه؛ <q>﴿بظلم﴾</q>: بشرْكٍ، ألم تسمَعْ إلى قول الله: <q>﴿إن الشرك لظلم عظيم﴾</q>؟ [لقمان:١٣]{4}. (٦/١١٦) ٢٥٤٠٥- عن عمر بن الخطاب: <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشِرْك{5}. (٦/١١٧) ٢٥٤٠٦- عن ابن عباس: أنّ عمر بن الخطاب كان إذا دخَل بيتَه نشَر المصحفَ يقرؤُه، فدخل ذاتَ يوم، فقرَأ سورةَ الأنعام، فأتى على هذه الآية: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q> إلى آخر الآية. فانتعَل وأخَذ رداءَه، ثم أتى أُبَيّ بن كعب، فقال: يا أبا المنذر، أتيتُ على هذه الآية: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>، وقد ترى أنّا نظلِمُ ونفعلُ ونفعل. فقال: يا أمير المؤمنين، إنّ هذا ليس بذاك، يقول الله: <q>﴿إن الشرك لظلم عظيم﴾</q> [لقمان:١٣]. إنّما ذلك الشِّرْكُ{6}. (٦/١١٧) ٢٥٤٠٧- عن أُبَيّ بن كعب -من طريق ابن عباس- في قوله: <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: ذاك الشِّرْك{7}. (٦/١١٧) ٢٥٤٠٨- عن سلمان الفارسي -من طريق أبي الأشعر العَبْدِيِّ، عن أبيه- أنّه سُئِل عن هذه الآية: <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>. قال: إنّما عنى به الشرْكَ، ألم تسمع الله يقول: <q>﴿إن الشرك لظلم عظيم﴾</q>؟ [لقمان:١٣]{8}. (٦/١١٧) ٢٥٤٠٩- عن حذيفة بن اليمان -من طريق عيسى، وكُرْدوس- <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشْرِكٍ{9}. (٦/١١٧) ٢٥٤١٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشِرْك{10}. (٦/١١٨) ٢٥٤١١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>، يقول: بكُفْر{11}. (ز) ٢٥٤١٢- عن عمرو بن شرحبيل -من طريق أبي إسحاق- في قوله: <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشِرْك{12}. (ز) ٢٥٤١٣- عن علقمة بن قيس النخعي -من طريق إبراهيم- في قوله: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشِرْك{13}. (ز) ٢٥٤١٤- عن أبي عبد الرحمن السُّلَمي -من طريق أبي حصين- قال: بشِرْك{14}. (ز) ٢٥٤١٥- عن سعيد بن جبير، في قوله: <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، يقول: لم يخلِطوا إيمانَهم بشرك{15}. (٦/١١٨) ٢٥٤١٦- عن إبراهيم النخعي -من طريق الحسن بن عبيد الله- <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشِرْك{16}. (ز) ٢٥٤١٧- عن مجاهد بن جبر، <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشِرْك{17}. (٦/١١٨) ٢٥٤١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بعبادة الأوثان{18}. (٦/١١٨) ٢٥٤١٩- عن عكرمة مولى ابن عباس -من طريق سماك- <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>، قال: هي لِمَن هاجر إلى المدينة{19}. (ز) ٢٥٤٢٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>، أي: بشِرْك{20}. (ز) ٢٥٤٢١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولم يلبسوا﴾</q> يخلطوا، <q>﴿إيمانهم بظلم﴾</q>، قال: بشرك{21}. (ز) ٢٥٤٢٢- قال مقاتل بن سليمان: فقال: <q>﴿الذين آمنوا﴾</q> بربٍّ واحد، <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q> يعني: ولم يخلطوا تصديقهم بشرك، فلم يعبدوا غيره{22}. (ز) ٢٥٤٢٣- عن عبد الملك ابن جُرَيج -من طريق حجّاج- <q>﴿فأي الفريقين أحق بالأمن إن كنتم تعلمون﴾</q> أمَن يعبد ربًّا واحدًا أم من يعبد أربابًا كثيرة؟ يقول قومه: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q> بعبادة الأوثان، وهي حجة إبراهيم <q>﴿أولئك لهم الأمن وهم مهتدون﴾</q>{23}٢٣٣٠. (ز) ٢٣٣٠ علَّق ابنُ عطية (٣/٤٠٧) على قول ابن جريج، فقال: «ويجيء هذا من الحُجَّة أيضًا أن أقرُّوا بالحق وهم قد ظلموا في الإشراك». ٢٥٤٢٤- قال محمد بن إسحاق -من طريق سلمة بن الفضل- قال: يقول الله -تعالى ذِكْرُه-: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q> أي: الذين أخلصوا كإخلاص إبراهيم ﷺ لعبادة الله وتوحيده، <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q> أي: بشرك{24}. (ز) ٢٥٤٢٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولم يلبسوا إيمانهم بظلم﴾</q>، قال: بشرك{21}٢٣٣١. (ز) ٢٣٣١ رجَّح ابنُ جرير (٩/٣٧٨) مستندًا إلى السنة قول أبي بكر الصديق وما في معناه أنّ معنى: <q>﴿بظلم﴾</q>، أي: بشرك. ٢٥٤٢٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأي الفريقين أحق بالأمن إن كنتم تعلمون﴾</q> قال: فقال اللهُ، وقضى بينهم: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>. قال: بشرك، قال: <q>﴿أولئك لهم الأمن وهم مهتدون﴾</q> فأمّا الذنوب فليس يبرأ منها أحد{23}٢٣٣٢. (ز) ٢٣٣٢ أفادت الآثار اختلاف المفسرين في قائل: <q>﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</q> على قولين: الأول: أنها قولٌ من الله ﷿ فيه فصل القضاء بين إبراهيم ﵇ وبين المشركين من قومه. الثاني: أنها من قول قوم إبراهيم ﵇ لإبراهيم ﵇ حين قال لهم: <q>﴿أيُّ الفَرِيقَيْنِ أحَقُّ بِالأَمْنِ﴾</q>. وقد رجَّح ابنُ جرير (٩/٣٦٩) القول الأول، وهو قول ابن زيد، وابن إسحاق، وانتَقَد قولَ ابن جريج مستندًا إلى الدلالة العقلية، فقال: «لو كان مِن قول قوم إبراهيم الذين كانوا يعبدون الأوثان ويُشركونها في عبادة الله لكانوا قد أقرُّوا بالتوحيد، واتبعوا إبراهيم على ما كانوا يخالفونه فيه من التوحيد، ولكنه كما ذكرتُ من تأويله بَدِيًّا». ووافقه ابنُ عطية (٣/٤٠٧) مستندًا إلى الأفصح لغة، والأظهر سياقًا، فقال: «وهذا هو البيِّن الفصيح الذي يرتبط به معنى الآية، ويحسن رصفها، وهو خبرٌ من الله تعالى». <q>﴿أُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡأَمۡنُ وَهُم مُّهۡتَدُونَ ۝٨٢﴾</q> - تفسير ٢٥٤٢٧- قال مقاتل بن سليمان: <q>﴿أولئك لهم الأمن وهم مهتدون﴾</q> من الضلالة{22}. (ز) ٢٥٤٢٨- قال محمد بن إسحاق -من طريق سلمة بن الفضل- قال: <q>﴿أولئك لهم الأمن وهم مهتدون﴾</q>، الأمن من العذاب، والهدى في الحجة بالمعرفة والاستقامة، يقول الله تعالى: <q>﴿وتلك حجتنا آتيناها إبراهيم على قومه نرفع درجات من نشاء إن ربك حكيم عليم﴾</q>{28}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡأَمۡنُ وَهُم مُّهۡتَدُونَ ۝٨٢﴾</q> - آثار متعلقة بالآية ٢٥٤٢٩- عن سَخْبرةَ، قال: قال رسول الله ﷺ: «مَنِ ابتُلي فصَبر، وأُعطِيَ فشكر، وظُلم فغفَر، وظَلم فاستغفَر». ثم سكت النبي ﷺ، فقيل: يا رسول الله، ما له؟ قال: <q>﴿أولئك لهم الأمن وهم مهتدون﴾</q>{29}. (٦/١٢٠) ٢٥٤٣٠- عن جرير بن عبد الله، قال: خرَجْنا مع رسول ﷺ، فلما برَزْنا من المدينة إذا راكبٌ يُوضِعُ{30} نحونا، فانتهى إلينا، فسلَّم، فقال له النبي ﷺ: «مِن أينَ أقبَلْتَ؟». فقال: مِن أهلي وولدي وعشيرتي، أُريدُ رسول الله ﷺ. قال: «قد أصَبْتَه». قال: علِّمني ما الإيمان. قال: «تشهدُ أن لا إله إلا الله، وأنّ محمدًا رسول الله، وتقيمُ الصلاة، وتُؤتي الزكاة، وتصوم رمضان، وتحُجُّ البيت». قال: قد أقرَرْتُ. ثم إنّ بعيرَه دخَلَتْ يدُه في شبكة جُرذان، فهوى، ووقَع الرجلُ على هامَتِه، فمات. فقال رسول الله ﷺ: «هذا من الذين عمِلوا قليلًا وأُجِروا كثيرًا، هذا مِن الذين قال الله: <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم أولئك لهم الأمن وهم مهتدون﴾</q>. إنِّي رأيتُ الحور العين يُدخِلنَ في فِيهِ مِن ثمار الجنة، فعلِمْتُ أنّ الرجلَ مات جائعًا»{31}. (٦/١١٩) ٢٥٤٣١- عن عبد الله بن عباس، قال: كُنّا معَ رسول الله ﷺ في مسير سارَه، إذ عرَض له أعرابيٌّ، فقال: والذي بعَثك بالحق، لقد خرَجتُ من بلادي وتِلادِي{32} لأهتدِيَ بهُداك، وآخُذَ من قولك، فاعرِضْ عليَّ. فعرَض عليه الإسلام، فقبِل، فازدحمنا حوله، فدخَل خُفُّ بَكْرِه في ثقب جُرذان، فتَردّى الأعرابيُّ، فانكسَرَت عُنُقُه، فقال رسول الله ﷺ: «أسمِعتم بالذي عمِل قليلًا وأُجِر كثيرًا؟ هذا منهم، أسمِعتم بـ<q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>؟ هذا منهم»{33}. (٦/١١٩) ٢٥٤٣٢- عن إبراهيم التَّيْمِيِّ: أنّ رجلًا سأل عنها النبي ﷺ، فسكت حتى جاء رجلٌ فأسلَم، فلم يلبَثْ إلّا قليلًا حتى قاتَل فاستُشهِد، فقال النبي ﷺ: «هذا منهم؛ من <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>»{34}. (٦/١٢٠) ",footnotes:1:أخرجه البخاري ١/١٥-١٦ (٣٢)، ٤/١٤١ (٣٣٦٠)، ٤/١٦٣ (٣٤٢٨، ٣٤٢٩)، ٦/٥٦ (٤٦٢٩)، ٦/١١٤-١١٥ (٤٧٧٦)، ٩/١٣ (٦٩١٨)، ٩/١٨ (٦٩٣٧)، ومسلم ١/١١٤ (١٢٤)، ويحيى بن سلام ٢/٦٧٣، وعبد الرزاق في تفسيره ٢/٥٦ (٨٢٣)، وابن جرير ٩/٣٧٠-٣٧١، ٣٧١-٣٧٢، ٣٧٦، وابن أبي حاتم ٤/١٣٣٣ (٧٥٤٢). وأورده الثعلبي ٤/١٦٦، ومقاتل بن سليمان ٥/٥.أخرجه الحاكم ٢/٣٤٦ (٣٢٣٢)، وابن جرير ٩/٣٧٨، وابن أبي حاتم ٤/١٣٣٣ (٧٥٤٤)، من طريق زياد بن علاقة، عن زياد بن حرملة، عن علي به. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الشيخ أحمد شاكر في تحقيقه لتفسير الطبري ١١/٥٠٣: «الخبر ضعيف؛ لجهالة زياد بن حرملة، حتى يعرف من هو».أخرجه ابن أبي حاتم ٤/١٣٣٣-١٣٣٤.أخرجه ابن جرير ٩/٣٧٢، والحكيم الترمذي في نوادر الأصول ١/٢٣١. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وأبي الشيخ، وابن مردُويه.عزاه السيوطي إلى أبي الشيخ.أخرجه الحاكم ٣/٣٠٥ وعنده: عن سعيد أنّ عمر. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٩/٣٧٤-٣٧٥. وعزاه السيوطي إلى عبد بن حميد وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٢-٣٧٣. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وأبي الشيخ، وأبي نصر السِّجْزِي في الإبانة.أخرجه ابن جرير ٩/٣٧٣. وعزاه السيوطي إلى الفريابي، وأبي عبيد، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٣-٣٧٤، وكذا من طريق عطية العوفي. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٣.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٣٢ (٨٨٦)، وابن جرير ٩/٣٧٥.أخرجه ابن جرير ٩/٣٧١.أخرجه ابن جرير ٩/٣٧٧.أخرجه ابن أبي حاتم ٤/١٣٣٣.أخرجه ابن جرير ٩/٣٧٥.عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.تفسير مجاهد ص٣٢٥، وأخرجه ابن جرير ٩/٣٧٦. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٨.عزا أوَّله ابنُ حجر في الفتح ٨/٢٩١ إلى ابن أبي حاتم. وأخرج آخره ابنُ جرير ٩/٣٧٦.أخرجه ابن جرير ٩/٣٧٦.تفسير مقاتل بن سليمان ١/٥٧٢.أخرجه ابن جرير ٩/٣٦٩.أخرجه ابن جرير ٩/٣٦٨، ٣٧٧.أخرجه ابن جرير ٩/٣٧٦.أخرجه ابن جرير ٩/٣٦٩.تفسير مقاتل بن سليمان ١/٥٧٢.أخرجه ابن جرير ٩/٣٦٨.أخرجه الطبراني في الكبير ٧/١٣٨ (٦٦١٤)، والبيهقي في الشعب ٦/٢٤٧-٢٤٨ (٤١١٧)، والواحدي في التفسير الوسيط ٢/٢٩٣ (٣٣٥)، من طريق محمد بن المعلى، عن زياد بن خيثمة، عن أبي داود، عن عبد الله بن سخبرة، عن سخبرة به. وهو عند البيهقي على الشك: عبد الله بن سخبرة أو سخبرة به. قال البيهقي: «ورواه أيضًا علي بن بحر، عن محمد بن المعلى الكوفي، وليس بالقوي». وقال الهيثمي في المجمع ١٠/٢٨٤ (١٨٠٤٨): «فيه أبو داود الأعمى، وهو متروك». وقال ابن حجر في الإصابة ٣/٣٠ (٣١٠٥): «وفي سنده أبو داود -الأعمى أحد المتروكين-». وقال في الفتح ١٠/١٠٩: «سند حسن». وقال المناوي في فيض القدير ٦/٢٢ (٨٢٨١): «ورمز المصنف-السيوطي- لحسنه». وقال في التيسير بشرح الجامع الصغير ٢/٣٨٥: «إسناده حسن». وقال الألباني في الضعيفة ١٠/٢٩ (٤٥٢٧): «ضعيف جدًّا».يُوضِع الراكب إيضاعًا، إذا حمَل بعيرَه على سرعة السير. النهاية (وضع).أخرجه أحمد ٣١/٥١٢-٥١٣ (١٩١٧٦)، ٣١/٥١٤ (١٩١٧٧)، وأبو نعيم في الحلية ٤/٢٠٣، من طريق إسحاق بن يوسف، عن أبي جناب، عن زاذان، عن جرير بن عبد الله به. قال الهيثمي في المجمع ١/٤١-٤٢ (١١٦): «في إسناده أبو جناب، وهو مُدَلِّس، وقد عنعنه».التالد: المال القديم الذي ولد عندك. النهاية (تَلِدَ).أخرجه الحكيم الترمذي في نوادر الأصول (١٥٥٦)، وابن أبي حاتم ٤/١٣٣٤ (٧٥٤٦)، من طريق يوسف بن موسى القطان، عن عمران بن أبي عمر الرازي، عن علي بن عبد الأعلى، عن أبيه، عن سعيد بن جبير، عن ابن عباس به.أخرجه سعيد بن منصور في التفسير من سننه ٥/٣١-٣٢ (٨٨٥) مرسلًا.
6,83," <q>﴿وَتِلۡكَ حُجَّتُنَاۤ ءَاتَیۡنَـٰهَاۤ إِبۡرَ ٰ⁠هِیمَ عَلَىٰ قَوۡمِهِۦۚ﴾</q> - تفسير ٢٥٤٣٣- عن مجاهد بن جبر -من طريق سفيان الثوري، عن رجل حدَّثه- <q>﴿وتلك حجتنا آتيناها إبراهيم على قومه﴾</q>، قال: هي <q>﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</q>{1}. (ز) ٢٥٤٣٤- عن مجاهد بن جبر -من طريق ابن جريج- قال: قال إبراهيم حين سأل: أي الفريقين أحق بالأمن؟ قال: هي حُجَّة إبراهيم{1}. (ز) ٢٥٤٣٥- عن الربيع بن أنس -من طريق عبد الله بن أبي جعفر، عن أبيه - في قوله: <q>﴿وتلك حجتنا آتيناها إبراهيم على قومه﴾</q>، قال: ذاك في الخصومة التي كانت بينه وبين قومه، والخصومة التي كانت بينه وبين الجبّار الذي يُسَمّى: نمرود{3}. (٦/١٢١) ٢٥٤٣٦- قال مقاتل بن سليمان: أقرُّوا بقول إبراهيم، وفَلَحَ{4} عليهم، فذلك قوله: <q>﴿وتلك حجتنا آتيناها إبراهيم على قومه نرفع درجات من نشاء﴾</q>{5}. (ز) ٢٥٤٣٧- عن عبد الملك ابن جُرَيج، في قوله: <q>﴿وتلك حجتنا آتيناها إبراهيم على قومه﴾</q>، قال: خصَمَهم{6}. (٦/١٢١) <q>﴿نَرۡفَعُ دَرَجَـٰتࣲ مَّن نَّشَاۤءُۗ﴾</q> - تفسير ٢٥٤٣٨- عن الضحاك بن مزاحم، قال: إنّ للعلماء درجاتٍ كدرجات الشهداء{7}. (٦/١٢١) ٢٥٤٣٩- عن زيد بن أسلم -من طريق مالك بن أنس- في قوله: <q>﴿نرفع درجات من نشاء﴾</q>، قال: بالعِلْم{8}. (٦/١٢١) <q>﴿إِنَّ رَبَّكَ حَكِیمٌ عَلِیمࣱ ۝٨٣﴾</q> - تفسير ٢٥٤٤٠- قال مقاتل بن سليمان: <q>﴿إن ربك حكيم﴾</q> في أمره، <q>﴿عليم﴾</q> بخَلْقه{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٩/٣٧٩.أخرجه ابن جرير ٩/٣٧٩.أخرجه ابن أبي حاتم ٤/١٣٣٥. وعزاه السيوطي إلى أبي الشيخ.الفلاح: البقاء والفوز والظفر، وهو من أفْلَحَ. النهاية (فَلَحَ).تفسير مقاتل بن سليمان ١/٥٧٢.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه أحمد ١/٥٠٠ (٤٤٩). وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٧٢.
6,84," <q>﴿وَوَهَبۡنَا لَهُۥۤ إِسۡحَـٰقَ وَیَعۡقُوبَۚ كُلًّا هَدَیۡنَاۚ وَنُوحًا هَدَیۡنَا مِن قَبۡلُۖ وَمِن ذُرِّیَّتِهِۦ دَاوُۥدَ وَسُلَیۡمَـٰنَ وَأَیُّوبَ وَیُوسُفَ وَمُوسَىٰ وَهَـٰرُونَۚ وَكَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡمُحۡسِنِینَ ۝٨٤﴾</q> - تفسير ٢٥٤٤١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿ووهبنا له إسحاق ويعقوب كلا هدينا ونوحا هدينا من قبل﴾</q>. ثم قال في إبراهيم: <q>﴿ومن ذريته داود وسليمان﴾</q> إلى قوله: <q>﴿وإسماعيل واليسع ويونس ولوطا وكلا فضلنا على العالمين﴾</q>. ثم قال في الأنبياء الذين سماهم الله في هذه الآية: <q>﴿فبهداهم اقتده﴾</q>{1}. (٦/١٢٢) ٢٥٤٤٢- قال مقاتل بن سليمان: قال: <q>﴿ووهبنا له﴾</q> يعني: لإبراهيم <q>﴿إسحاق ويعقوب كلا هدينا﴾</q> للإيمان، <q>﴿ونوحا هدينا﴾</q> إلى الإسلام <q>﴿من قبل﴾</q> إبراهيم، <q>﴿ومن ذريته﴾</q> يعني: من ذُرِّيَّة نوحٍ <q>﴿داودُ وسليمان وأيوب ويوسف وموسى وهارون وكذلك﴾</q> يعني: هكذا <q>﴿نجزي المحسنين﴾</q> يعني: هؤلاء الذين ذكرهم الله{2}٢٣٣٣. (ز) ٢٣٣٣ نقل ابنُ عطية (٣/٤٠٨) عن الزجّاج: أن الضمير في <q>﴿ذُرَّيَتِهِ﴾</q> جائزٌ أن يعود على إبراهيم ﵇، ثم استدرك عليه قائلًا: «ويعترض هذا بذكر لوط ﵇، وهو ليس من ذرية إبراهيم ﵇، بل هو ابن أخيه، وقيل: ابن أخته، ويتخرج عند من يرى الخال أبًا». ورجَّح ابنُ جرير (٩/٣٨١-٣٨٢) مستندًا إلى دلالة السياق، والتاريخ، والعقل عود الضمير في قوله تعالى: <q>﴿ومِن ذُرِّيَّتِهِ داوُدَ﴾</q> إلى نوح، وعلَّل ذلك قائلًا: «أنّ الله -تعالى ذِكْرُه- ذَكَر في سياق الآيات التي تتلو هذه الآية لوطًا، فقال: <q>﴿وإسْماعِيلَ واليَسَعَ ويُونُسَ ولُوطًا وكِلا فَضَّلْنا عَلى العالَمِينَ﴾</q>، ومعلومٌ أنّ لوطًا لم يكن من ذرية إبراهيم، فإذ كان ذلك كذلك، وكان معطوفًا على أسماء مَن سَمَّيْنا مِن ذريته؛ كان لا شك أنه لو أُرِيد بالذرية ذرية إبراهيم لما دخل يونس ولوطٌ فيهم، ولا شكَّ أن لوطًا ليس من ذرية إبراهيم، ولكنه من ذرية نوح، فلذلك وجب أن تكون الهاء في الذرية من ذكر نوح». ووافقه ابنُ عطية (٣/٤٠٩) قائلًا: «وهذا هو الجيِّد». وذكر ابنُ كثير (٦/١٠٧) أنّ هذا القول ظاهر لا إشكال فيه، ثم بيَّن أن القول بعود الضمير على إبراهيم ﵇ حسن؛ لكون الكلام سيق من أجله، ووجَّهه من جهة النظائر بما يدفع الإشكال عنه من كون لوط ﵇ ليس من ذرية إبراهيم ﵇، فقال: «اللهم إلا أن يقال: إنّه دخل في الذُرِّيَّة تغليبًا، كما في قوله تعالى: <q>﴿أمْ كُنْتُمْ شُهَداءَ إذْ حَضَرَ يَعْقُوبَ المَوْتُ إذْ قالَ لِبَنِيهِ ما تَعْبُدُونَ مِن بَعْدِي قالُوا نَعْبُدُ إلَهَكَ وإلَهَ آبائِكَ إبْراهِيمَ وإسْماعِيلَ وإسْحاقَ إلَهًا واحِدًا ونَحْنُ لَهُ مُسْلِمُون﴾</q> [البقرة:١٣٣]، فإسماعيل عمُّه، ودخل في آبائه تغليبًا. وكما قال في قوله: <q>﴿فَسَجَدَ المَلائِكَةُ كُلُّهُمْ أجْمَعُونَ * إلا إبْلِيسَ﴾</q> [الحجر:٣٠-٣١]، فدخل إبليس في أمر الملائكة بالسجود، وذُمَّ على المخالفة؛ لأنه كان قد تشبه بهم، فعومل معاملتهم، ودخل معهم تغليبًا، وكان من الجن، وطبيعتهم النار، والملائكة من النور». ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٥٧٢.
6,85," <q>﴿وَزَكَرِیَّا وَیَحۡیَىٰ وَعِیسَىٰ﴾</q> - تفسير ٢٥٤٤٣- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: الخالُ والد، والعمُّ والد، نسَب الله عيسى إلى أخواله، قال: <q>﴿ومن ذريته﴾</q> حتى بلَغ إلى قوله: <q>﴿وزكريا ويحيى وعيسى﴾</q>{1}. (٦/١٢٢) <q>﴿وَإِلۡیَاسَۖ كُلࣱّ مِّنَ ٱلصَّـٰلِحِینَ ۝٨٥﴾</q> - تفسير ٢٥٤٤٤- عن عبد الله بن مسعود -من طريق عبيدة بن ربيعة- قال: إدريس هو إلياس، وإسرائيل هو يعقوب{2}٢٣٣٤. (ز) ٢٣٣٤ ذكر ابنُ جرير (٩/٣٨٣) اختلافًا في إلياس من هو؟ فذكر عن ابن إسحاق قوله: هو إلياس بن تسبى بن فِنحاص بن العيزار بن هارون بن عمران ابن أخي موسى نبي الله ﷺ. وذكر قول ابن مسعود: بأنه إدريس. وذكر بأنّ أهل الأنساب يقولون: إدريس جدُّ نوح، وأنّه روي عن وهب بن منبه أيضًا. ثم رجَّح مستندًا إلى دلالة التاريخ، والعقل قول أهل الأنساب، وبيَّن علَّة ذلك، فقال: «وذلك أنّ الله تعالى نسب إلياس في هذه الآية إلى نوح، وجعله من ذريته، ونوح هو ابنُ إدريسَ عند أهل العلم، فمُحالٌ أن يكون جَدُّ أبيه منسوبًا إلى أنه من ذريته». ٢٥٤٤٥- قال محمد بن إسحاق: هو إلياس بن تسبى بن فِنحاص بن العيزار بن هارون بن عمران ابن أخي موسى نبي الله ﷺ{3}. (ز) <q>﴿وَإِلۡیَاسَۖ كُلࣱّ مِّنَ ٱلصَّـٰلِحِینَ ۝٨٥﴾</q> - آثار متعلقة بالآية ٢٥٤٤٦- عن أبي حرب بن أبي الأسود، قال: أرسَل الحجاج إلى يحيى بن يَعمَرَ، فقال: بلَغني: أنّك تزعُمُ أنّ الحسن والحسين من ذُرِّيَّة النبي ﷺ، تجدُه في كتاب الله، وقد قرَأتُه من أوَّله إلى آخره فلم أجِدْه! قال: أليس تقرأُ سورة الأنعام: <q>﴿ومن ذريته داود وسليمان﴾</q> حتى بلَغ: <q>﴿ويحيى وعيسى﴾</q>؟ قال: بلى. قال: أليس عيسى من ذرية إبراهيم وليس له أب؟ قال: صَدقْتَ{4}. (٦/١٢١) ٢٥٤٤٧- عن عبد الملك بن عمير، قال: دخل يحيى بن يَعمَر على الحجّاج، فذكَر الحسين، فقال الحجاج: لم يكن من ذرية النبي ﷺ. فقال يحيى: كذَبْتَ. قال: لَتَأْتِيَنِّي على ما قلتَ ببيِّنة. فتلا: <q>﴿ومن ذريته داود وسليمان﴾</q> إلى قوله: <q>﴿وعيسى وإلياس﴾</q>. فأخبَر تعالى أنّ عيسى من ذرية آدم بأُمِّه. قال: صدَقْت{5}. (٦/١٢٢) ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٣٨٣، وابن أبي حاتم ٤/١٣٣٦. وفي تفسير البغوي ٣/١٦٥ بلفظ: هو إدريس، وله اسمان، مثل: يعقوب، وإسرائيل.علَّقه ابن جرير ٩/٣٨٣.أخرجه ابن أبي حاتم ٤/١٣٣٥.أخرجه الحاكم ٣/١٦٤، والبيهقي ٦/١٦٦. وعزاه السيوطي إلى أبي الشيخ.
6,86," <q>﴿وَإِسۡمَـٰعِیلَ وَٱلۡیَسَعَ وَیُونُسَ وَلُوطࣰاۚ وَكُلࣰّا فَضَّلۡنَا عَلَى ٱلۡعَـٰلَمِینَ ۝٨٦﴾</q> - تفسير ٢٥٤٤٨- قال مقاتل بن سليمان: <q>﴿وإسماعيل واليسع ويونس ولوطا وكلا فضلنا﴾</q> بالنُّبُوَّة من الجن والإنس <q>﴿على العالمين﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٧٢. وستأتي رواية ابن إسحاق وغيره لقصة اليسع ضمن قصة إلياس ﵉، وذلك عند تفسير قوله تعالى: <q>﴿وإنَّ إلْياسَ لَمِنَ المُرْسَلِينَ﴾</q> الآيات [الصافات:١٢٣-١٣٢].
6,87," <q>﴿وَمِنۡ ءَابَاۤىِٕهِمۡ وَذُرِّیَّـٰتِهِمۡ وَإِخۡوَ ٰ⁠نِهِمۡۖ وَٱجۡتَبَیۡنَـٰهُمۡ وَهَدَیۡنَـٰهُمۡ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٨٧﴾</q> - تفسير ٢٥٤٤٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿واجتبيناهم﴾</q>، قال: أخلَصْناهم{1}. (٦/١٢٢) ٢٥٤٥٠- قال مقاتل بن سليمان: <q>﴿واجتبيناهم﴾</q>، يعني: واستخلصناهم بالنُّبُوَّة{2}. (ز) <q>﴿وَهَدَیۡنَـٰهُمۡ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٨٧﴾</q> - تفسير ٢٥٤٥١- قال مقاتل بن سليمان: <q>﴿وهديناهم إلى صراط مستقيم﴾</q>، يعني: الإسلام{2}. (ز) ",footnotes:1:تفسير مجاهد ص٣٢٥، وأخرجه ابن جرير ٩/٣٨٦، وابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٧٣.تفسير مقاتل بن سليمان ١/٥٧٣.
6,88," <q>﴿ذَ ٰ⁠لِكَ هُدَى ٱللَّهِ یَهۡدِی بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۚ وَلَوۡ أَشۡرَكُوا۟ لَحَبِطَ عَنۡهُم مَّا كَانُوا۟ یَعۡمَلُونَ ۝٨٨﴾</q> - تفسير ٢٥٤٥٢- قال مقاتل بن سليمان: <q>﴿ذلك هدى الله يهدي به من يشاء﴾</q> يعني: ثمانية عشر نبيا <q>﴿من عباده﴾</q> فيعطيه النبوة، <q>﴿ولو أشركوا﴾</q> بالله <q>﴿لحبط عنهم ما كانوا يعملون﴾</q>{1}. (ز) ٢٥٤٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قوله: <q>﴿ولو أشركوا لحبط عنهم ما كانوا يعملون﴾</q>، قال: يريد هؤلاء الذين قال: هديناهم وفضَّلْناهم{2}. (٦/١٢٣) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن أبي حاتم ٤/١٣٣٧.
6,89," <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ ءَاتَیۡنَـٰهُمُ ٱلۡكِتَـٰبَ﴾</q> - تفسير ٢٥٤٥٤- عن جُويرية بن بشير: سمعتُ رجلًا سأَل الحسن البصري عن قوله: <q>﴿الذين آتيناهم الكتاب والحكم والنبوة﴾</q>، مَن هم، يا أبا سعيد؟ قال: هم الذين في صدر هذه الآية{1}. (٦/١٢٣) ٢٥٤٥٥- قال مقاتل بن سليمان: ذكر ما أعْطى النبيين، فقال: <q>﴿أولئك الذين آتيناهم الكتاب﴾</q>، يعني: أعطيناهم{2}. (ز) <q>﴿ٱلۡكِتَـٰبَ﴾</q> - تفسير ٢٥٤٥٦- قال مقاتل بن سليمان: <q>﴿الكتاب﴾</q>، يعني: كتاب إبراهيم، والتوراة، والزبور، والإنجيل{2}. (ز) <q>﴿وَٱلۡحُكۡمَ وَٱلنُّبُوَّةَۚ﴾</q> - تفسير ٢٥٤٥٧- عن عبد الله بن عباس -من طريق عكرمة- قال: الحكم: العِلْم{4}. (ز) ٢٥٤٥٨- عن مجاهد بن جبر -من طريق مالك بن شدّاد- في قوله: <q>﴿أولئك الذين آتيناهم الكتاب والحكم والنبوة﴾</q>، قال: الحُكْم: اللُّب{5}٢٣٣٥. (٦/١٢٣) ٢٣٣٥ ذكر ابنُ جرير (٩/٣٨٧) أنّ معنى: <q>﴿والحُكْمَ﴾</q> «يعني: الفهم بالكتاب، ومعرفة ما فيه من الأحكام». ثم وجَّه قول مجاهد، فقال: «وعنى بذلك مجاهدٌ -إن شاء الله- ما قلتُ؛ لأن اللُّبَّ هو العقل، فكأنّه أراد أنّ الله آتاهم العقل بالكتاب، وهو بمعنى ما قلنا من أنّه الفهم به». ٢٥٤٥٩- عن عكرمة مولى ابن عباس -من طريق إسماعيل بن مسلم- قال: الحكم: اللُّب{4}. (ز) ٢٥٤٦٠- قال مقاتل بن سليمان: <q>﴿والحكم﴾</q>، يعني: العِلم، والفَهم، والنبوة{2}. (ز) <q>﴿فَإِن یَكۡفُرۡ بِهَا هَـٰۤؤُلَاۤءِ فَقَدۡ وَكَّلۡنَا بِهَا قَوۡمࣰا لَّیۡسُوا۟ بِهَا بِكَـٰفِرِینَ ۝٨٩﴾</q> - تفسير ٢٥٤٦١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿فإن يكفر بها هؤلاء﴾</q> يعني: أهل مكة، يقول: إن يكفُروا بالقرآن <q>﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</q> يعني: أهل المدينة والأنصار{8}٢٣٣٦. (٦/١٢٣) ٢٣٣٦ وجَّه ابنُ عطية (٣/٤١١-٤١٢) قول ابن عباس من طريق علي بن أبي طلحة، وقول الضحاك وما في معناه بقوله: «فالآية -على هذا التأويل- وإن كان القصد في نزولها هذين الصنفين؛ فهي تعُمُّ الكفرة والمؤمنين إلى يوم القيامة». ٢٥٤٦٢- عن عبد الله بن عباس -من طريق العوفي- قال: كان أهل الإيمان قد تبوَّءوا الدار والإيمان قبلَ أن يقدَمَ عليهم رسول الله ﷺ، فلمّا أنزَل الله الآياتِ جحَد بها أهل مكة، فقال الله: <q>﴿فإن يكفر بها هؤلاء فقد وكلنا بها قوما ليسوا بها بكافرين﴾</q>{9}. (٦/١٢٤) ٢٥٤٦٣- عن سعيد بن المسيب، في الآية، قال: <q>﴿فإن يكفر بها﴾</q> أهل مكة <q>﴿فقد وكلنا بها﴾</q> أهل المدينة من الأنصار{10}. (٦/١٢٤) ٢٥٤٦٤- عن أبي رجاء العُطاردي -من طريق عوف- في قوله: <q>﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</q>، قال: هم الملائكة{11}. (٦/١٢٤) ٢٥٤٦٥- قال مجاهد بن جبر: <q>﴿فإن يكفر بها هؤلاء﴾</q> الكفار، يعني: أهل مكة؛ <q>﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</q> يعني: الأنصار وأهل المدينة{12}. (ز) ٢٥٤٦٦- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿فإن يكفر بها هؤلاء﴾</q> قال: إن يكفر بها أهل مكة <q>﴿فقد وكلنا بها قوما﴾</q> أهل المدينة الأنصار، <q>﴿ليسوا بها بكافرين﴾</q>{13}. (ز) ٢٥٤٦٧- عن الحسن البصري -من طريق أبي هلال- في قوله: <q>﴿فإن يكفر بها هؤلاء﴾</q> إن يكفر بها أُمَّتك{14}. (ز) ٢٥٤٦٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فإن يكفر بها هؤلاء﴾</q> قال: أهل مكة كفار قريش؛ <q>﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</q> وهم الأنبياء الذين قَصَّ الله على نبيه الثمانية عشر، الذين قال الله: <q>﴿فبهداهم اقتده﴾</q>{15}. (٦/١٢٣) ٢٥٤٦٩- عن قتادة بن دعامة -من طريق أبي هلال- في قول الله تعالى: <q>﴿فإن يكفر بها هؤلاء﴾</q> قال: أهل مكة؛ <q>﴿فقد وكلنا بها﴾</q> أهل المدينة{16}. (ز) ٢٥٤٧٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فإن يكفر بها هؤلاء﴾</q> يقول: إن يكفر بها قريش؛ <q>﴿فقد وكلنا بها﴾</q> الأنصار{17}. (ز) ٢٥٤٧١- قال مقاتل بن سليمان: <q>﴿فإن يكفر بها هؤلاء﴾</q> من أهل مكة بما أعطى الله النبيين من الكتب؛ <q>﴿فقد وكلنا بها﴾</q> يعني: بالكتب <q>﴿قوما ليسوا بها بكافرين﴾</q> يعني: أهل المدينة من الأنصار{2}. (ز) ٢٥٤٧٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿فإن يكفر بها هؤلاء﴾</q> أهل مكة؛ <q>﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</q> أهل المدينة{19}٢٣٣٧. (ز) ٢٣٣٧ أفادت الآثار اختلاف المفسرين في المعنيِّ بـ<q>﴿هَؤُلاءِ﴾</q>، والمعنيِّ بالقوم الموكَّلين بها على أقوال: الأول: فإن يكفر بها كفار قريش، فقد وكَّلنا بها الأنصار. وهو قول قتادة من طريق أبي هلال، والضحاك، والسدي، وابن جريج، وابن عباس. الثاني: فإن يكفر بها أهل مكة، فقد وكَّلنا بها الملائكة. وهو قول أبي رجاء العطاردي. الثالث: فإن يكفر بها كفار قريش، فقد وكَّلنا بها الأنبياء الذين ذُكِروا في الآيات السابقة. وهو قول قتادة من طريق معمر. وقد رجَّح ابنُ جرير (٩/٣٩٠) مستندًا إلى السياق القول الثالث، وقال معلِّلًا: «وذلك أنّ الخبر في الآيات قبلها عنهم مضى، وفي التي بعدها عنهم ذُكِر، فما بينها بأن يكون خبرًا عنهم أوْلى وأحقُّ من أن يكون خبرًا عن غيرهم». واختار ابنُ القيم (١/٣٥٤-٣٥٥) الجمع بين هذه الأقوال كلها عدا القول بكون القوم الموكلين بها هم الملائكة، مستندًا إلى زمن النزول، فقال: «السورة مكية، والإشارة بقوله: <q>﴿هَؤُلاءِ﴾</q> إلى مَن كفر به من قومه أصلًا، ومَن عداهم تبعًا، فيدخل فيها كلُّ مَن كفر بما جاء به من هذه الأمة، والقوم الموكَّلون بها هم الأنبياء أصلًا، والمؤمنون بهم تبعًا، فيدخل كل مَن قام بحفظها، والذبِّ عنها، والدعوة إليها، وهذا ينتظم في الأقوال التي قيلت في الآية». وانتقد مستندًا إلى السياق، ونظائر القرآن قولَ من قال: إنهم الملائكة، فقال: «وأما قول من قال: إنهم الملائكة، فضعيف جدًّا لا يدل عليه السياق، وتأباه لفظة <q>﴿قَوْمًا﴾</q>؛ إذ الغالب في القرآن، بل المطرد تخصيص القوم ببني آدم دون الملائكة، وأما قول إبراهيم لهم: <q>﴿قَوْمٌ مُنْكَرُونَ﴾</q> [الذاريات:٢٥] فإنّما قاله لَمّا ظنهم من الإنس». ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٣٧.تفسير مقاتل بن سليمان ١/٥٧٣.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن أبي حاتم ٤/١٣٣٨.أخرجه ابن جرير ٩/٣٨٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٤/١٣٣٨.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن جرير ٩/٣٨٩، وابن أبي حاتم ٤/١٣٣٨-١٣٣٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٣٨٩. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٩/٣٨٩-٣٩٠، وابن أبي حاتم ٤/١٣٣٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير البغوي ٣/١٦٦.أخرجه ابن جرير ٩/٣٨٨. وعلَّقه ابن أبي حاتم ٤/١٣٣٨.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٣٢٥-، وابن أبي حاتم ٤/١٣٣٨. وعند يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٨٣-: يعني: المشركين.أخرجه عبد الرزاق ١/٢١٣، وابن جرير ٩/٣٩٠، وابن أبي حاتم ٤/١٣٣٨-١٣٣٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٣٨٨.أخرجه ابن جرير ٩/٣٨٩. وعلَّقه ابن أبي حاتم ٤/١٣٣٨.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن جرير ٩/٣٨٩.
6,90," <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَى ٱللَّهُۖ فَبِهُدَىٰهُمُ ٱقۡتَدِهۡۗ﴾</q> - قراءات ٢٥٤٧٣- عن عاصم ابن أبي النجود أنّه قرأ: <q>﴿فَبِهُداهُمُ اقْتَدِهْ﴾</q> بيَّن الهاء إذا وصَل، ولا يُدغِمُها{1}. (٦/١٢٥) <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَى ٱللَّهُۖ فَبِهُدَىٰهُمُ ٱقۡتَدِهۡۗ﴾</q> - تفسير الآية ٢٥٤٧٤- عن العوّام، قال: سألتُ مجاهدًا عن سجدةٍ في ص. فقال: سألت ابن عباس: من أين سجدت؟ فقال: أوَما تقرأ: <q>﴿ومن ذريته داود وسليمان﴾</q> ... <q>﴿أولئك الذين هدى الله فبهداهم اقتده﴾</q>؟ فكان داود مِمَّن أُمِر نبيكم ﷺ أن يقتدي به، فسجدها داود ﵇، فسجدها رسول الله ﷺ{2}. (٦/١٢٤) ٢٥٤٧٥- عن عبد الله بن عباس -من طريق علي بن أبي طلحة-: قال في الأنبياء الذين سماهم الله في هذه الآية: <q>﴿فبهداهم اقتده﴾</q>{3}. (٦/١٢٢) ٢٥٤٧٦- عن العوام، قال: قال لي مجاهد: فيم السجدة التي في ص؟ قال: إنّ الله ذكر الأنبياء، ثم قال: <q>﴿أولئك الذين هدى الله فبهداهم اقتده﴾</q>. فاقتدى رسول الله ﷺ، واقتدينا نحن برسول الله ﷺ{4}. (ز) ٢٥٤٧٧- عن قتادة بن دعامة -من طريق شيبان- قال: قصَّ الله عليه ثمانيةَ عشر نبيا، ثُمَّ أمَره أن يَقتدِيَ بهم، وأنتم فاقتدوا بالصالحين قبلكم{5}. (٦/١٢٥) ٢٥٤٧٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثُمَّ رجع إلى النبي ﷺ، فقال: <q>﴿أولئك الذين هدى الله فبهداهم اقتده﴾</q>{6}. (ز) ٢٥٤٧٩- قال مقاتل بن سليمان: ثم ذكر النبيين الثمانية عشر، فقال: <q>﴿أولئك الذين هدى الله﴾</q> لدينه؛ <q>﴿فبهداهم اقتده﴾</q> يقول للنبي ﷺ: فبِسُنَّتهم اقتدِ{7}. (ز) ٢٥٤٨٠- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿ووهبنا له إسحاق ويعقوب﴾</q> إلى قوله: <q>﴿أولئك الذين هدى الله فبهداهم اقتده﴾</q> يا محمد{6}. (ز) ٢٥٤٨١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أولئك الذين هدى الله﴾</q> يا محمد؛ <q>﴿فبهداهم اقتده﴾</q> ولا تقتد بهؤلاء{9}٢٣٣٨. (ز) ٢٣٣٨ ذكر ابنُ جرير (٩/٣٩١-٣٩٢) في تفسير قوله تعالى: <q>﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</q> معنيين بناءً على المعاني التي تقدَّم ذكرها في المعنيِّ بقوله تعالى: <q>﴿فَإنْ يَكْفُرْ بِها هَؤُلاءِ فَقَدْ وكَّلْنا بِها قَوْمًا لَيْسُوا بِها بِكافِرِينَ﴾</q>: الأول: مَن قال بأنّ القوم الذين وُكِّلوا بها هم الأنبياء المُسَمَّوْنَ في الآيات المتقدمة، فإنهم جعلوا قوله: <q>﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</q> تعود على قوله: <q>﴿فَقَدْ وكَّلْنا بِها قَوْمًا لَيْسُوا بِها بِكافِرِينَ﴾</q>، والمعنى: <q>﴿أُولَئِكَ﴾</q> هؤلاء القوم الذين وكَّلنا بآياتنا وليسوا بها بكافرين، هم الذين <q>﴿هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</q>. والثاني: مَن قال بأن القوم الذين وُكِّلوا بها هم أهل المدينة، أو أنهم هم الملائكة، فإنهم جعلوا قوله: <q>﴿فَإنْ يَكْفُرْ بِها هَؤُلاءِ فَقَدْ وكَّلْنا بِها قَوْمًا لَيْسُوا بِها بِكافِرِينَ﴾</q> اعتراضًا بين الكلامين، ثم ردُّوا قوله: <q>﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</q> على قوله: <q>﴿أُولَئِكَ الَّذِينَ آتَيْناهُمُ الكِتابَ والحُكْمَ والنُّبُوَّةَ﴾</q>. <q>﴿قُل لَّاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ أَجۡرًاۖ﴾</q> - تفسير ٢٥٤٨٢- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿قل لا أسألكم عليه أجرا﴾</q>، قال: قل لهم، يا محمد: لا أسألُكم على ما أدْعُوكم إليه عَرَضًا مِن عَرَض الدنيا{10}. (٦/١٢٥) ٢٥٤٨٣- عن عطاء بن دينار -من طريق أبي أيوب- في قول الله تعالى: <q>﴿لا أسئلكم عليه أجرا﴾</q>، يقول: لا أسألكم على ما جئتكم به أجرًا{10}. (ز) ٢٥٤٨٤- قال مقاتل بن سليمان: <q>﴿قل لا أسئلكم عليه﴾</q> يعني: على الإيمان بالقرآن <q>﴿أجرا﴾</q> يعني: جميلًا{7}. (ز) ٢٥٤٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قول الله: <q>﴿قل لا أسئلكم عليه أجرا﴾</q>، يقول: لا أسألكم على القرآن أجرًا{10}. (ز) <q>﴿إِنۡ هُوَ إِلَّا ذِكۡرَىٰ لِلۡعَـٰلَمِینَ ۝٩٠﴾</q> - تفسير ٢٥٤٨٦- قال مقاتل بن سليمان: <q>﴿إن هو﴾</q> يعني: ما القرآن <q>﴿إلا ذكرى﴾</q> يعني: تذكرة للعالمين{7}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حُمَيد. <q>﴿فَبِهُداهُمُ اقْتَدِهْ﴾</q> بإسكان الهاء، قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، ويعقوب، وخلف العاشر، فإنهم حذفوها، وما عدا ابن عامر، فإنه قرأ بكسرها على اختلاف عنه في إشباع هذه الكسرة، وعدمها. انظر: النشر ٢/١٤٢.أخرجه البخاري ٤/١٦١ (٣٤٢١)، ٦/٥٧ (٤٦٣٢)، ٦/١٢٤ (٤٨٠٦، ٤٨٠٧)، وابن أبي حاتم ٤/١٣٣٩-١٣٤٠ (٧٥٧٩).أخرجه ابن جرير ٩/٣٩٢، وابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٣٨ (٨٨٨).أخرجه ابن أبي حاتم ٤/١٣٤٠. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٩/٣٩٢.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن جرير ٩/٣٩٢.أخرجه ابن جرير ٩/٣٩٢، وابن أبي حاتم ٤/١٣٤٠ من طريق أصبغ بن الفرج.أخرجه ابن أبي حاتم ٤/١٣٤٠.أخرجه ابن أبي حاتم ٤/١٣٤٠.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن أبي حاتم ٤/١٣٤٠.تفسير مقاتل بن سليمان ١/٥٧٣.
