quran[9]{c,v,t}:
  6,82,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ ءَامَنُوا۟ وَلَمۡ یَلۡبِسُوۤا۟ إِیمَـٰنَهُم بِظُلۡمٍ أُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡأَمۡنُ وَهُم مُّهۡتَدُونَ ۝٨٢﴾</span> - نزول الآية وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span> شَقَّ ذلك على الناس، فقالوا: يا رسول الله، وأيُّنا لا يظلمُ نفسَه؟! قال: «<b>إنّه ليس الذي تعنُون، ألم تسمعوا ما قال العبد الصالح: <span class="qpc-hafs">﴿إن الشرك لظلم عظيم﴾</span>؟</b> [لقمان:١٣]. <b>إنما هو الشرك</b>»{1}. (٦/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق زياد بن حَرْمَلة- في قوله: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>، قال: نزَلت هذه في إبراهيم وأصحابه خاصة، ليس في هذه الأُمَّة{2}. (٦/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٣<span class="dash">-</span></span> عن <span class="name-2">بكر بن سَوادة</span> -من طريق عبيد الله بن زَحْرٍ- قال: حمَل رجلٌ من العدوِّ على المسلمين، فقتَل رجلًا، ثم حمَل، فقتَل آخر، ثم حمَل، فقتَل آخر، ثم قال: أينفَعُني الإسلامُ بعدَ هذا؟ قالوا: ما ندري. فذكَروا ذلك لرسول الله ﷺ، فقال: «<b>نعم</b>». فضرَب فرسَه، فدخَل فيهم، ثم حمَل على أصحابه، فقتَل رجلًا، ثم آخر، ثم آخر، ثم قُتِل. قال: فيُرَون أن هذه الآية نزَلت فيه: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span> الآية{3}. (٦/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٤<span class="dash">-</span></span> عن <span class="name-1">أبي بكر الصديق</span> -من طريق الأسود بن هلال- أنّه سُئِل عن هذه الآية: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>. قال: ما تقولون؟ قالوا: لم يَظلِموا. قال: حمَلْتم الأمْرَ على أشَدِّه؛ <span class="qpc-hafs">﴿بظلم﴾</span>: بشرْكٍ، ألم تسمَعْ إلى قول الله: <span class="qpc-hafs">﴿إن الشرك لظلم عظيم﴾</span>؟ [لقمان:١٣]{4}. (٦/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٥<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>: <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشِرْك{5}. (٦/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٦<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>: أنّ عمر بن الخطاب كان إذا دخَل بيتَه نشَر المصحفَ يقرؤُه، فدخل ذاتَ يوم، فقرَأ سورةَ الأنعام، فأتى على هذه الآية: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span> إلى آخر الآية. فانتعَل وأخَذ رداءَه، ثم أتى <span class="name-1">أُبَيّ بن كعب</span>، فقال: يا أبا المنذر، أتيتُ على هذه الآية: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>، وقد ترى أنّا نظلِمُ ونفعلُ ونفعل. فقال: يا أمير المؤمنين، إنّ هذا ليس بذاك، يقول الله: <span class="qpc-hafs">﴿إن الشرك لظلم عظيم﴾</span> [لقمان:١٣]. إنّما ذلك الشِّرْكُ{6}. (٦/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٧<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق ابن عباس- في قوله: <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: ذاك الشِّرْك{7}. (٦/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٨<span class="dash">-</span></span> عن <span class="name-1">سلمان الفارسي</span> -من طريق أبي الأشعر العَبْدِيِّ، عن أبيه- أنّه سُئِل عن هذه الآية: <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>. قال: إنّما عنى به الشرْكَ، ألم تسمع الله يقول: <span class="qpc-hafs">﴿إن الشرك لظلم عظيم﴾</span>؟ [لقمان:١٣]{8}. (٦/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٠٩<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق عيسى، وكُرْدوس- <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشْرِكٍ{9}. (٦/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشِرْك{10}. (٦/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>، يقول: بكُفْر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٢<span class="dash">-</span></span> عن <span class="name-2">عمرو بن شرحبيل</span> -من طريق أبي إسحاق- في قوله: <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشِرْك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٣<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس النخعي</span> -من طريق إبراهيم- في قوله: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشِرْك{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٤<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السُّلَمي</span> -من طريق أبي حصين- قال: بشِرْك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، يقول: لم يخلِطوا إيمانَهم بشرك{15}. (٦/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق الحسن بن عبيد الله- <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشِرْك{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشِرْك{17}. (٦/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بعبادة الأوثان{18}. (٦/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>، قال: هي لِمَن هاجر إلى المدينة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>، أي: بشِرْك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولم يلبسوا﴾</span> يخلطوا، <span class="qpc-hafs">﴿إيمانهم بظلم﴾</span>، قال: بشرك{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال: <span class="qpc-hafs">﴿الذين آمنوا﴾</span> بربٍّ واحد، <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span> يعني: ولم يخلطوا تصديقهم بشرك، فلم يعبدوا غيره{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿فأي الفريقين أحق بالأمن إن كنتم تعلمون﴾</span> أمَن يعبد ربًّا واحدًا أم من يعبد أربابًا كثيرة؟ يقول قومه: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span> بعبادة الأوثان، وهي حجة إبراهيم <span class="qpc-hafs">﴿أولئك لهم الأمن وهم مهتدون﴾</span>{23}<span class=comment-ref>٢٣٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٣/٤٠٧) على قول ابن جريج، فقال: «ويجيء هذا من الحُجَّة أيضًا أن أقرُّوا بالحق وهم قد ظلموا في الإشراك».</div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة بن الفضل- قال: يقول الله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span> أي: الذين أخلصوا كإخلاص إبراهيم ﷺ لعبادة الله وتوحيده، <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span> أي: بشرك{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولم يلبسوا إيمانهم بظلم﴾</span>، قال: بشرك{21}<span class=comment-ref>٢٣٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٣٧٨) <span class="mustanad">مستندًا إلى السنة</span> قول أبي بكر الصديق وما في معناه أنّ معنى: <span class="qpc-hafs">﴿بظلم﴾</span>، أي: بشرك.</div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأي الفريقين أحق بالأمن إن كنتم تعلمون﴾</span> قال: فقال اللهُ، وقضى بينهم: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>. قال: بشرك، قال: <span class="qpc-hafs">﴿أولئك لهم الأمن وهم مهتدون﴾</span> فأمّا الذنوب فليس يبرأ منها أحد{23}<span class=comment-ref>٢٣٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٢</span> أفادت الآثار اختلاف المفسرين في قائل: <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</span> على قولين: <b>الأول:</b> أنها قولٌ من الله ﷿ فيه فصل القضاء بين إبراهيم ﵇ وبين المشركين من قومه. <b>الثاني:</b> أنها من قول قوم إبراهيم ﵇ لإبراهيم ﵇ حين قال لهم: <span class="qpc-hafs">﴿أيُّ الفَرِيقَيْنِ أحَقُّ بِالأَمْنِ﴾</span>.</p><p>وقد <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٣٦٩) القول الأول، وهو قول ابن زيد، وابن إسحاق، و<span class="comment-type-2">انتَقَد</span> قولَ ابن جريج <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «لو كان مِن قول قوم إبراهيم الذين كانوا يعبدون الأوثان ويُشركونها في عبادة الله لكانوا قد أقرُّوا بالتوحيد، واتبعوا إبراهيم على ما كانوا يخالفونه فيه من التوحيد، ولكنه كما ذكرتُ من تأويله بَدِيًّا».</p><p>ووافقه <u>ابنُ عطية</u> (٣/٤٠٧) <span class="mustanad">مستندًا إلى الأفصح لغة، والأظهر سياقًا</span>، فقال: «وهذا هو البيِّن الفصيح الذي يرتبط به معنى الآية، ويحسن رصفها، وهو خبرٌ من الله تعالى».</div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡأَمۡنُ وَهُم مُّهۡتَدُونَ ۝٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أولئك لهم الأمن وهم مهتدون﴾</span> من الضلالة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة بن الفضل- قال: <span class="qpc-hafs">﴿أولئك لهم الأمن وهم مهتدون﴾</span>، الأمن من العذاب، والهدى في الحجة بالمعرفة والاستقامة، يقول الله تعالى: <span class="qpc-hafs">﴿وتلك حجتنا آتيناها إبراهيم على قومه نرفع درجات من نشاء إن ربك حكيم عليم﴾</span>{28}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ لَهُمُ ٱلۡأَمۡنُ وَهُم مُّهۡتَدُونَ ۝٨٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٢٩<span class="dash">-</span></span> عن سَخْبرةَ، قال: قال رسول الله ﷺ: «<b>مَنِ ابتُلي فصَبر، وأُعطِيَ فشكر، وظُلم فغفَر، وظَلم فاستغفَر</b>». ثم سكت النبي ﷺ، فقيل: يا رسول الله، ما له؟ قال: <span class="qpc-hafs">﴿أولئك لهم الأمن وهم مهتدون﴾</span>{29}. (٦/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٠<span class="dash">-</span></span> عن جرير بن عبد الله، قال: خرَجْنا مع رسول ﷺ، فلما برَزْنا من المدينة إذا راكبٌ يُوضِعُ{30} نحونا، فانتهى إلينا، فسلَّم، فقال له النبي ﷺ: «<b>مِن أينَ أقبَلْتَ؟</b>». فقال: مِن أهلي وولدي وعشيرتي، أُريدُ رسول الله ﷺ. قال: «<b>قد أصَبْتَه</b>». قال: علِّمني ما الإيمان. قال: «<b>تشهدُ أن لا إله إلا الله، وأنّ محمدًا رسول الله، وتقيمُ الصلاة، وتُؤتي الزكاة، وتصوم رمضان، وتحُجُّ البيت</b>». قال: قد أقرَرْتُ. ثم إنّ بعيرَه دخَلَتْ يدُه في شبكة جُرذان، فهوى، ووقَع الرجلُ على هامَتِه، فمات. فقال رسول الله ﷺ: «<b>هذا من الذين عمِلوا قليلًا وأُجِروا كثيرًا، هذا مِن الذين قال الله: <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم أولئك لهم الأمن وهم مهتدون﴾</span>. إنِّي رأيتُ الحور العين يُدخِلنَ في فِيهِ مِن ثمار الجنة، فعلِمْتُ أنّ الرجلَ مات جائعًا</b>»{31}. (٦/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣١<span class="dash">-</span></span> عن عبد الله بن عباس، قال: كُنّا معَ رسول الله ﷺ في مسير سارَه، إذ عرَض له أعرابيٌّ، فقال: والذي بعَثك بالحق، لقد خرَجتُ من بلادي وتِلادِي{32} لأهتدِيَ بهُداك، وآخُذَ من قولك، فاعرِضْ عليَّ. فعرَض عليه الإسلام، فقبِل، فازدحمنا حوله، فدخَل خُفُّ بَكْرِه في ثقب جُرذان، فتَردّى الأعرابيُّ، فانكسَرَت عُنُقُه، فقال رسول الله ﷺ: «<b>أسمِعتم بالذي عمِل قليلًا وأُجِر كثيرًا؟ هذا منهم، أسمِعتم بـ<span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>؟ هذا منهم</b>»{33}. (٦/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٢<span class="dash">-</span></span> عن إبراهيم التَّيْمِيِّ: أنّ رجلًا سأل عنها النبي ﷺ، فسكت حتى جاء رجلٌ فأسلَم، فلم يلبَثْ إلّا قليلًا حتى قاتَل فاستُشهِد، فقال النبي ﷺ: «<b>هذا منهم؛ من <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span></b>»{34}. (٦/١٢٠)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ١/١٥-١٦ (٣٢)، ٤/١٤١ (٣٣٦٠)، ٤/١٦٣ (٣٤٢٨، ٣٤٢٩)، ٦/٥٦ (٤٦٢٩)، ٦/١١٤-١١٥ (٤٧٧٦)، ٩/١٣ (٦٩١٨)، ٩/١٨ (٦٩٣٧)، ومسلم ١/١١٤ (١٢٤)، ويحيى بن سلام ٢/٦٧٣، وعبد الرزاق في تفسيره ٢/٥٦ (٨٢٣)، وابن جرير ٩/٣٧٠-٣٧١، ٣٧١-٣٧٢، ٣٧٦، وابن أبي حاتم ٤/١٣٣٣ (٧٥٤٢). وأورده الثعلبي ٤/١٦٦، ومقاتل بن سليمان ٥/٥.أخرجه الحاكم ٢/٣٤٦ (٣٢٣٢)، وابن جرير ٩/٣٧٨، وابن أبي حاتم ٤/١٣٣٣ (٧٥٤٤)، من طريق زياد بن علاقة، عن زياد بن حرملة، عن علي به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الشيخ أحمد شاكر في تحقيقه لتفسير الطبري ١١/٥٠٣: «الخبر ضعيف؛ لجهالة زياد بن حرملة، حتى يعرف من هو».أخرجه ابن أبي حاتم ٤/١٣٣٣-١٣٣٤.أخرجه ابن جرير ٩/٣٧٢، والحكيم الترمذي في نوادر الأصول ١/٢٣١. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وأبي الشيخ، وابن مردُويه.عزاه السيوطي إلى أبي الشيخ.أخرجه الحاكم ٣/٣٠٥ وعنده: عن سعيد أنّ عمر. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٩/٣٧٤-٣٧٥. وعزاه السيوطي إلى عبد بن حميد وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٢-٣٧٣. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وأبي الشيخ، وأبي نصر السِّجْزِي في الإبانة.أخرجه ابن جرير ٩/٣٧٣. وعزاه السيوطي إلى الفريابي، وأبي عبيد، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٣-٣٧٤، وكذا من طريق عطية العوفي. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٣.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٣٢ (٨٨٦)، وابن جرير ٩/٣٧٥.أخرجه ابن جرير ٩/٣٧١.أخرجه ابن جرير ٩/٣٧٧.أخرجه ابن أبي حاتم ٤/١٣٣٣.أخرجه ابن جرير ٩/٣٧٥.عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.تفسير مجاهد ص٣٢٥، وأخرجه ابن جرير ٩/٣٧٦. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٣٧٨.عزا أوَّله ابنُ حجر في الفتح ٨/٢٩١ إلى ابن أبي حاتم. وأخرج آخره ابنُ جرير ٩/٣٧٦.أخرجه ابن جرير ٩/٣٧٦.تفسير مقاتل بن سليمان ١/٥٧٢.أخرجه ابن جرير ٩/٣٦٩.أخرجه ابن جرير ٩/٣٦٨، ٣٧٧.أخرجه ابن جرير ٩/٣٧٦.أخرجه ابن جرير ٩/٣٦٩.تفسير مقاتل بن سليمان ١/٥٧٢.أخرجه ابن جرير ٩/٣٦٨.أخرجه الطبراني في الكبير ٧/١٣٨ (٦٦١٤)، والبيهقي في الشعب ٦/٢٤٧-٢٤٨ (٤١١٧)، والواحدي في التفسير الوسيط ٢/٢٩٣ (٣٣٥)، من طريق محمد بن المعلى، عن زياد بن خيثمة، عن أبي داود، عن عبد الله بن سخبرة، عن سخبرة به. وهو عند البيهقي على الشك: عبد الله بن سخبرة أو سخبرة به.</p><p>قال البيهقي: «ورواه أيضًا علي بن بحر، عن محمد بن المعلى الكوفي، وليس بالقوي». وقال الهيثمي في المجمع ١٠/٢٨٤ (١٨٠٤٨): «فيه أبو داود الأعمى، وهو متروك». وقال ابن حجر في الإصابة ٣/٣٠ (٣١٠٥): «وفي سنده أبو داود -الأعمى أحد المتروكين-». وقال في الفتح ١٠/١٠٩: «سند حسن». وقال المناوي في فيض القدير ٦/٢٢ (٨٢٨١): «ورمز المصنف-السيوطي- لحسنه». وقال في التيسير بشرح الجامع الصغير ٢/٣٨٥: «إسناده حسن». وقال الألباني في الضعيفة ١٠/٢٩ (٤٥٢٧): «ضعيف جدًّا».يُوضِع الراكب إيضاعًا، إذا حمَل بعيرَه على سرعة السير. النهاية (وضع).أخرجه أحمد ٣١/٥١٢-٥١٣ (١٩١٧٦)، ٣١/٥١٤ (١٩١٧٧)، وأبو نعيم في الحلية ٤/٢٠٣، من طريق إسحاق بن يوسف، عن أبي جناب، عن زاذان، عن جرير بن عبد الله به.</p><p>قال الهيثمي في المجمع ١/٤١-٤٢ (١١٦): «في إسناده أبو جناب، وهو مُدَلِّس، وقد عنعنه».التالد: المال القديم الذي ولد عندك. النهاية (تَلِدَ).أخرجه الحكيم الترمذي في نوادر الأصول (١٥٥٦)، وابن أبي حاتم ٤/١٣٣٤ (٧٥٤٦)، من طريق يوسف بن موسى القطان، عن عمران بن أبي عمر الرازي، عن علي بن عبد الأعلى، عن أبيه، عن سعيد بن جبير، عن ابن عباس به.أخرجه سعيد بن منصور في التفسير من سننه ٥/٣١-٣٢ (٨٨٥) مرسلًا.
  6,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتِلۡكَ حُجَّتُنَاۤ ءَاتَیۡنَـٰهَاۤ إِبۡرَ ٰ⁠هِیمَ عَلَىٰ قَوۡمِهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان الثوري، عن رجل حدَّثه- <span class="qpc-hafs">﴿وتلك حجتنا آتيناها إبراهيم على قومه﴾</span>، قال: هي <span class="qpc-hafs">﴿الذين آمنوا ولم يلبسوا إيمانهم بظلم﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قال: قال إبراهيم حين سأل: أي الفريقين أحق بالأمن؟ قال: هي حُجَّة إبراهيم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق عبد الله بن أبي جعفر، عن أبيه - في قوله: <span class="qpc-hafs">﴿وتلك حجتنا آتيناها إبراهيم على قومه﴾</span>، قال: ذاك في الخصومة التي كانت بينه وبين قومه، والخصومة التي كانت بينه وبين الجبّار الذي يُسَمّى: نمرود{3}. (٦/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أقرُّوا بقول إبراهيم، وفَلَحَ{4} عليهم، فذلك قوله: <span class="qpc-hafs">﴿وتلك حجتنا آتيناها إبراهيم على قومه نرفع درجات من نشاء﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span>، في قوله: <span class="qpc-hafs">﴿وتلك حجتنا آتيناها إبراهيم على قومه﴾</span>، قال: خصَمَهم{6}. (٦/١٢١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَرۡفَعُ دَرَجَـٰتࣲ مَّن نَّشَاۤءُۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٣٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، قال: إنّ للعلماء درجاتٍ كدرجات الشهداء{7}. (٦/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٣٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق مالك بن أنس- في قوله: <span class="qpc-hafs">﴿نرفع درجات من نشاء﴾</span>، قال: بالعِلْم{8}. (٦/١٢١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ حَكِیمٌ عَلِیمࣱ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن ربك حكيم﴾</span> في أمره، <span class="qpc-hafs">﴿عليم﴾</span> بخَلْقه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٣٧٩.أخرجه ابن جرير ٩/٣٧٩.أخرجه ابن أبي حاتم ٤/١٣٣٥. وعزاه السيوطي إلى أبي الشيخ.الفلاح: البقاء والفوز والظفر، وهو من أفْلَحَ. النهاية (فَلَحَ).تفسير مقاتل بن سليمان ١/٥٧٢.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه أحمد ١/٥٠٠ (٤٤٩). وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٧٢.
  6,84,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَهَبۡنَا لَهُۥۤ إِسۡحَـٰقَ وَیَعۡقُوبَۚ كُلًّا هَدَیۡنَاۚ وَنُوحًا هَدَیۡنَا مِن قَبۡلُۖ وَمِن ذُرِّیَّتِهِۦ دَاوُۥدَ وَسُلَیۡمَـٰنَ وَأَیُّوبَ وَیُوسُفَ وَمُوسَىٰ وَهَـٰرُونَۚ وَكَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡمُحۡسِنِینَ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿ووهبنا له إسحاق ويعقوب كلا هدينا ونوحا هدينا من قبل﴾</span>. ثم قال في إبراهيم: <span class="qpc-hafs">﴿ومن ذريته داود وسليمان﴾</span> إلى قوله: <span class="qpc-hafs">﴿وإسماعيل واليسع ويونس ولوطا وكلا فضلنا على العالمين﴾</span>. ثم قال في الأنبياء الذين سماهم الله في هذه الآية: <span class="qpc-hafs">﴿فبهداهم اقتده﴾</span>{1}. (٦/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿ووهبنا له﴾</span> يعني: لإبراهيم <span class="qpc-hafs">﴿إسحاق ويعقوب كلا هدينا﴾</span> للإيمان، <span class="qpc-hafs">﴿ونوحا هدينا﴾</span> إلى الإسلام <span class="qpc-hafs">﴿من قبل﴾</span> إبراهيم، <span class="qpc-hafs">﴿ومن ذريته﴾</span> يعني: من ذُرِّيَّة نوحٍ <span class="qpc-hafs">﴿داودُ وسليمان وأيوب ويوسف وموسى وهارون وكذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿نجزي المحسنين﴾</span> يعني: هؤلاء الذين ذكرهم الله{2}<span class=comment-ref>٢٣٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٣</span> نقل <u>ابنُ عطية</u> (٣/٤٠٨) عن الزجّاج: أن الضمير في <span class="qpc-hafs">﴿ذُرَّيَتِهِ﴾</span> جائزٌ أن يعود على إبراهيم ﵇، ثم <span class="comment-type-2">استدرك</span> عليه قائلًا: «ويعترض هذا بذكر لوط ﵇، وهو ليس من ذرية إبراهيم ﵇، بل هو ابن أخيه، وقيل: ابن أخته، ويتخرج عند من يرى الخال أبًا».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٣٨١-٣٨٢) <span class="mustanad">مستندًا إلى دلالة السياق، والتاريخ، والعقل</span> عود الضمير في قوله تعالى: <span class="qpc-hafs">﴿ومِن ذُرِّيَّتِهِ داوُدَ﴾</span> إلى نوح، وعلَّل ذلك قائلًا: «أنّ الله -تعالى ذِكْرُه- ذَكَر في سياق الآيات التي تتلو هذه الآية لوطًا، فقال: <span class="qpc-hafs">﴿وإسْماعِيلَ واليَسَعَ ويُونُسَ ولُوطًا وكِلا فَضَّلْنا عَلى العالَمِينَ﴾</span>، ومعلومٌ أنّ لوطًا لم يكن من ذرية إبراهيم، فإذ كان ذلك كذلك، وكان معطوفًا على أسماء مَن سَمَّيْنا مِن ذريته؛ كان لا شك أنه لو أُرِيد بالذرية ذرية إبراهيم لما دخل يونس ولوطٌ فيهم، ولا شكَّ أن لوطًا ليس من ذرية إبراهيم، ولكنه من ذرية نوح، فلذلك وجب أن تكون الهاء في الذرية من ذكر نوح».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ عطية</u> (٣/٤٠٩) قائلًا: «وهذا هو الجيِّد».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٦/١٠٧) أنّ هذا القول ظاهر لا إشكال فيه، ثم بيَّن أن القول بعود الضمير على إبراهيم ﵇ <span class="comment-type-3">حسن</span>؛ لكون الكلام <span class="mustanad">سيق من أجله</span>، و<span class="comment-type-1">وجَّهه</span> <span class="mustanad">من جهة النظائر</span> بما يدفع الإشكال عنه من كون لوط ﵇ ليس من ذرية إبراهيم ﵇، فقال: «اللهم إلا أن يقال: إنّه دخل في الذُرِّيَّة تغليبًا، كما في قوله تعالى: <span class="qpc-hafs">﴿أمْ كُنْتُمْ شُهَداءَ إذْ حَضَرَ يَعْقُوبَ المَوْتُ إذْ قالَ لِبَنِيهِ ما تَعْبُدُونَ مِن بَعْدِي قالُوا نَعْبُدُ إلَهَكَ وإلَهَ آبائِكَ إبْراهِيمَ وإسْماعِيلَ وإسْحاقَ إلَهًا واحِدًا ونَحْنُ لَهُ مُسْلِمُون﴾</span> [البقرة:١٣٣]، فإسماعيل عمُّه، ودخل في آبائه تغليبًا. وكما قال في قوله: <span class="qpc-hafs">﴿فَسَجَدَ المَلائِكَةُ كُلُّهُمْ أجْمَعُونَ * إلا إبْلِيسَ﴾</span> [الحجر:٣٠-٣١]، فدخل إبليس في أمر الملائكة بالسجود، وذُمَّ على المخالفة؛ لأنه كان قد تشبه بهم، فعومل معاملتهم، ودخل معهم تغليبًا، وكان من الجن، وطبيعتهم النار، والملائكة من النور».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٥٧٢.
  6,85,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَزَكَرِیَّا وَیَحۡیَىٰ وَعِیسَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- قال: الخالُ والد، والعمُّ والد، نسَب الله عيسى إلى أخواله، قال: <span class="qpc-hafs">﴿ومن ذريته﴾</span> حتى بلَغ إلى قوله: <span class="qpc-hafs">﴿وزكريا ويحيى وعيسى﴾</span>{1}. (٦/١٢٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِلۡیَاسَۖ كُلࣱّ مِّنَ ٱلصَّـٰلِحِینَ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عبيدة بن ربيعة- قال: إدريس هو إلياس، وإسرائيل هو يعقوب{2}<span class=comment-ref>٢٣٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٤</span> ذكر <u>ابنُ جرير</u> (٩/٣٨٣) اختلافًا في إلياس من هو؟ فذكر عن ابن إسحاق قوله: هو إلياس بن تسبى بن فِنحاص بن العيزار بن هارون بن عمران ابن أخي موسى نبي الله ﷺ. وذكر قول ابن مسعود: بأنه إدريس. وذكر بأنّ أهل الأنساب يقولون: إدريس جدُّ نوح، وأنّه روي عن وهب بن منبه أيضًا.</p><p>ثم <span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى دلالة التاريخ، والعقل</span> قول أهل الأنساب، وبيَّن علَّة ذلك، فقال: «وذلك أنّ الله تعالى نسب إلياس في هذه الآية إلى نوح، وجعله من ذريته، ونوح هو ابنُ إدريسَ عند أهل العلم، فمُحالٌ أن يكون جَدُّ أبيه منسوبًا إلى أنه من ذريته».</div></p><p><div></p><p><p><span class="item-no">٢٥٤٤٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: هو إلياس بن تسبى بن فِنحاص بن العيزار بن هارون بن عمران ابن أخي موسى نبي الله ﷺ{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِلۡیَاسَۖ كُلࣱّ مِّنَ ٱلصَّـٰلِحِینَ ۝٨٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤٦<span class="dash">-</span></span> عن أبي حرب بن أبي الأسود، قال: أرسَل الحجاج إلى <span class="name-2">يحيى بن يَعمَرَ</span>، فقال: بلَغني: أنّك تزعُمُ أنّ الحسن والحسين من ذُرِّيَّة النبي ﷺ، تجدُه في كتاب الله، وقد قرَأتُه من أوَّله إلى آخره فلم أجِدْه! قال: أليس تقرأُ سورة الأنعام: <span class="qpc-hafs">﴿ومن ذريته داود وسليمان﴾</span> حتى بلَغ: <span class="qpc-hafs">﴿ويحيى وعيسى﴾</span>؟ قال: بلى. قال: أليس عيسى من ذرية إبراهيم وليس له أب؟ قال: صَدقْتَ{4}. (٦/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٤٧<span class="dash">-</span></span> عن عبد الملك بن عمير، قال: دخل <span class="name-2">يحيى بن يَعمَر</span> على الحجّاج، فذكَر الحسين، فقال الحجاج: لم يكن من ذرية النبي ﷺ. فقال يحيى: كذَبْتَ. قال: لَتَأْتِيَنِّي على ما قلتَ ببيِّنة. فتلا: <span class="qpc-hafs">﴿ومن ذريته داود وسليمان﴾</span> إلى قوله: <span class="qpc-hafs">﴿وعيسى وإلياس﴾</span>. فأخبَر تعالى أنّ عيسى من ذرية آدم بأُمِّه. قال: صدَقْت{5}. (٦/١٢٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٣٨٣، وابن أبي حاتم ٤/١٣٣٦. وفي تفسير البغوي ٣/١٦٥ بلفظ: هو إدريس، وله اسمان، مثل: يعقوب، وإسرائيل.علَّقه ابن جرير ٩/٣٨٣.أخرجه ابن أبي حاتم ٤/١٣٣٥.أخرجه الحاكم ٣/١٦٤، والبيهقي ٦/١٦٦. وعزاه السيوطي إلى أبي الشيخ.
  6,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِسۡمَـٰعِیلَ وَٱلۡیَسَعَ وَیُونُسَ وَلُوطࣰاۚ وَكُلࣰّا فَضَّلۡنَا عَلَى ٱلۡعَـٰلَمِینَ ۝٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإسماعيل واليسع ويونس ولوطا وكلا فضلنا﴾</span> بالنُّبُوَّة من الجن والإنس <span class="qpc-hafs">﴿على العالمين﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٥٧٢.</p><p><b>وستأتي رواية ابن إسحاق وغيره لقصة اليسع ضمن قصة إلياس ﵉، وذلك عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وإنَّ إلْياسَ لَمِنَ المُرْسَلِينَ﴾</span> الآيات</b> [الصافات:١٢٣-١٣٢].
  6,87,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَابَاۤىِٕهِمۡ وَذُرِّیَّـٰتِهِمۡ وَإِخۡوَ ٰ⁠نِهِمۡۖ وَٱجۡتَبَیۡنَـٰهُمۡ وَهَدَیۡنَـٰهُمۡ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿واجتبيناهم﴾</span>، قال: أخلَصْناهم{1}. (٦/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واجتبيناهم﴾</span>، يعني: واستخلصناهم بالنُّبُوَّة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَدَیۡنَـٰهُمۡ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهديناهم إلى صراط مستقيم﴾</span>، يعني: الإسلام{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٢٥، وأخرجه ابن جرير ٩/٣٨٦، وابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٧٣.تفسير مقاتل بن سليمان ١/٥٧٣.
  6,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ هُدَى ٱللَّهِ یَهۡدِی بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۚ وَلَوۡ أَشۡرَكُوا۟ لَحَبِطَ عَنۡهُم مَّا كَانُوا۟ یَعۡمَلُونَ ۝٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك هدى الله يهدي به من يشاء﴾</span> يعني: ثمانية عشر نبيا <span class="qpc-hafs">﴿من عباده﴾</span> فيعطيه النبوة، <span class="qpc-hafs">﴿ولو أشركوا﴾</span> بالله <span class="qpc-hafs">﴿لحبط عنهم ما كانوا يعملون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قوله: <span class="qpc-hafs">﴿ولو أشركوا لحبط عنهم ما كانوا يعملون﴾</span>، قال: يريد هؤلاء الذين قال: هديناهم وفضَّلْناهم{2}. (٦/١٢٣)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن أبي حاتم ٤/١٣٣٧.
  6,89,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ ءَاتَیۡنَـٰهُمُ ٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٥٤<span class="dash">-</span></span> عن جُويرية بن بشير: سمعتُ رجلًا سأَل <span class="name-2">الحسن البصري</span> عن قوله: <span class="qpc-hafs">﴿الذين آتيناهم الكتاب والحكم والنبوة﴾</span>، مَن هم، يا أبا سعيد؟ قال: هم الذين في صدر هذه الآية{1}. (٦/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ذكر ما أعْطى النبيين، فقال: <span class="qpc-hafs">﴿أولئك الذين آتيناهم الكتاب﴾</span>، يعني: أعطيناهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الكتاب﴾</span>، يعني: كتاب إبراهيم، والتوراة، والزبور، والإنجيل{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡحُكۡمَ وَٱلنُّبُوَّةَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الحكم: العِلْم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مالك بن شدّاد- في قوله: <span class="qpc-hafs">﴿أولئك الذين آتيناهم الكتاب والحكم والنبوة﴾</span>، قال: الحُكْم: اللُّب{5}<span class=comment-ref>٢٣٣٥</span>. (٦/١٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٥</span> ذكر <u>ابنُ جرير</u> (٩/٣٨٧) أنّ معنى: <span class="qpc-hafs">﴿والحُكْمَ﴾</span> «يعني: الفهم بالكتاب، ومعرفة ما فيه من الأحكام». ثم <span class="comment-type-1">وجَّه</span> قول مجاهد، فقال: «وعنى بذلك مجاهدٌ -إن شاء الله- ما قلتُ؛ لأن اللُّبَّ هو العقل، فكأنّه أراد أنّ الله آتاهم العقل بالكتاب، وهو بمعنى ما قلنا من أنّه الفهم به».</div></p><p><div></p><p><p><span class="item-no">٢٥٤٥٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق إسماعيل بن مسلم- قال: الحكم: اللُّب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والحكم﴾</span>، يعني: العِلم، والفَهم، والنبوة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِن یَكۡفُرۡ بِهَا هَـٰۤؤُلَاۤءِ فَقَدۡ وَكَّلۡنَا بِهَا قَوۡمࣰا لَّیۡسُوا۟ بِهَا بِكَـٰفِرِینَ ۝٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> يعني: أهل مكة، يقول: إن يكفُروا بالقرآن <span class="qpc-hafs">﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</span> يعني: أهل المدينة والأنصار{8}<span class=comment-ref>٢٣٣٦</span>. (٦/١٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٦</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٤١١-٤١٢) قول ابن عباس من طريق علي بن أبي طلحة، وقول الضحاك وما في معناه بقوله: «فالآية -على هذا التأويل- وإن كان القصد في نزولها هذين الصنفين؛ فهي تعُمُّ الكفرة والمؤمنين إلى يوم القيامة».</div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: كان أهل الإيمان قد تبوَّءوا الدار والإيمان قبلَ أن يقدَمَ عليهم رسول الله ﷺ، فلمّا أنزَل الله الآياتِ جحَد بها أهل مكة، فقال الله: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء فقد وكلنا بها قوما ليسوا بها بكافرين﴾</span>{9}. (٦/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>، في الآية، قال: <span class="qpc-hafs">﴿فإن يكفر بها﴾</span> أهل مكة <span class="qpc-hafs">﴿فقد وكلنا بها﴾</span> أهل المدينة من الأنصار{10}. (٦/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٤<span class="dash">-</span></span> عن <span class="name-2">أبي رجاء العُطاردي</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</span>، قال: هم الملائكة{11}. (٦/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٥<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> الكفار، يعني: أهل مكة؛ <span class="qpc-hafs">﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</span> يعني: الأنصار وأهل المدينة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> قال: إن يكفر بها أهل مكة <span class="qpc-hafs">﴿فقد وكلنا بها قوما﴾</span> أهل المدينة الأنصار، <span class="qpc-hafs">﴿ليسوا بها بكافرين﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي هلال- في قوله: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> إن يكفر بها أُمَّتك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> قال: أهل مكة كفار قريش؛ <span class="qpc-hafs">﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</span> وهم الأنبياء الذين قَصَّ الله على نبيه الثمانية عشر، الذين قال الله: <span class="qpc-hafs">﴿فبهداهم اقتده﴾</span>{15}. (٦/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي هلال- في قول الله تعالى: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> قال: أهل مكة؛ <span class="qpc-hafs">﴿فقد وكلنا بها﴾</span> أهل المدينة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> يقول: إن يكفر بها قريش؛ <span class="qpc-hafs">﴿فقد وكلنا بها﴾</span> الأنصار{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> من أهل مكة بما أعطى الله النبيين من الكتب؛ <span class="qpc-hafs">﴿فقد وكلنا بها﴾</span> يعني: بالكتب <span class="qpc-hafs">﴿قوما ليسوا بها بكافرين﴾</span> يعني: أهل المدينة من الأنصار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿فإن يكفر بها هؤلاء﴾</span> أهل مكة؛ <span class="qpc-hafs">﴿فقد وكلنا بها قوما ليسوا بها بكافرين﴾</span> أهل المدينة{19}<span class=comment-ref>٢٣٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٧</span> أفادت الآثار اختلاف المفسرين في المعنيِّ بـ<span class="qpc-hafs">﴿هَؤُلاءِ﴾</span>، والمعنيِّ بالقوم الموكَّلين بها على أقوال: <b>الأول:</b> فإن يكفر بها كفار قريش، فقد وكَّلنا بها الأنصار. وهو قول قتادة من طريق أبي هلال، والضحاك، والسدي، وابن جريج، وابن عباس. <b>الثاني:</b> فإن يكفر بها أهل مكة، فقد وكَّلنا بها الملائكة. وهو قول أبي رجاء العطاردي. <b>الثالث:</b> فإن يكفر بها كفار قريش، فقد وكَّلنا بها الأنبياء الذين ذُكِروا في الآيات السابقة. وهو قول قتادة من طريق معمر.</p><p>وقد <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٣٩٠) <span class="mustanad">مستندًا إلى السياق</span> القول الثالث، وقال معلِّلًا: «وذلك أنّ الخبر في الآيات قبلها عنهم مضى، وفي التي بعدها عنهم ذُكِر، فما بينها بأن يكون خبرًا عنهم أوْلى وأحقُّ من أن يكون خبرًا عن غيرهم».</p><p>و<span class="comment-type-3">اختار</span> <u>ابنُ القيم</u> (١/٣٥٤-٣٥٥) الجمع بين هذه الأقوال كلها عدا القول بكون القوم الموكلين بها هم الملائكة، <span class="mustanad">مستندًا إلى زمن النزول</span>، فقال: «السورة مكية، والإشارة بقوله: <span class="qpc-hafs">﴿هَؤُلاءِ﴾</span> إلى مَن كفر به من قومه أصلًا، ومَن عداهم تبعًا، فيدخل فيها كلُّ مَن كفر بما جاء به من هذه الأمة، والقوم الموكَّلون بها هم الأنبياء أصلًا، والمؤمنون بهم تبعًا، فيدخل كل مَن قام بحفظها، والذبِّ عنها، والدعوة إليها، وهذا ينتظم في الأقوال التي قيلت في الآية».</p><p>و<span class="comment-type-2">انتقد</span> <span class="mustanad">مستندًا إلى السياق، ونظائر القرآن</span> قولَ من قال: إنهم الملائكة، فقال: «وأما قول من قال: إنهم الملائكة، فضعيف جدًّا لا يدل عليه السياق، وتأباه لفظة <span class="qpc-hafs">﴿قَوْمًا﴾</span>؛ إذ الغالب في القرآن، بل المطرد تخصيص القوم ببني آدم دون الملائكة، وأما قول إبراهيم لهم: <span class="qpc-hafs">﴿قَوْمٌ مُنْكَرُونَ﴾</span> [الذاريات:٢٥] فإنّما قاله لَمّا ظنهم من الإنس».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٣٧.تفسير مقاتل بن سليمان ١/٥٧٣.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن أبي حاتم ٤/١٣٣٨.أخرجه ابن جرير ٩/٣٨٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٤/١٣٣٨.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن جرير ٩/٣٨٩، وابن أبي حاتم ٤/١٣٣٨-١٣٣٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٣٨٩. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٩/٣٨٩-٣٩٠، وابن أبي حاتم ٤/١٣٣٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير البغوي ٣/١٦٦.أخرجه ابن جرير ٩/٣٨٨. وعلَّقه ابن أبي حاتم ٤/١٣٣٨.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٣٢٥-، وابن أبي حاتم ٤/١٣٣٨. وعند يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٨٣-: يعني: المشركين.أخرجه عبد الرزاق ١/٢١٣، وابن جرير ٩/٣٩٠، وابن أبي حاتم ٤/١٣٣٨-١٣٣٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٣٨٨.أخرجه ابن جرير ٩/٣٨٩. وعلَّقه ابن أبي حاتم ٤/١٣٣٨.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن جرير ٩/٣٨٩.
  6,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَى ٱللَّهُۖ فَبِهُدَىٰهُمُ ٱقۡتَدِهۡۗ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٧٣<span class="dash">-</span></span> عن <span class="name-2">عاصم ابن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿فَبِهُداهُمُ اقْتَدِهْ﴾</span> بيَّن الهاء إذا وصَل، ولا يُدغِمُها{1}. (٦/١٢٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَى ٱللَّهُۖ فَبِهُدَىٰهُمُ ٱقۡتَدِهۡۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٧٤<span class="dash">-</span></span> عن العوّام، قال: سألتُ مجاهدًا عن سجدةٍ في ص. فقال: سألت <span class="name-1">ابن عباس</span>: من أين سجدت؟ فقال: أوَما تقرأ: <span class="qpc-hafs">﴿ومن ذريته داود وسليمان﴾</span> ... <span class="qpc-hafs">﴿أولئك الذين هدى الله فبهداهم اقتده﴾</span>؟ فكان داود مِمَّن أُمِر نبيكم ﷺ أن يقتدي به، فسجدها داود ﵇، فسجدها رسول الله ﷺ{2}. (٦/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة-: قال في الأنبياء الذين سماهم الله في هذه الآية: <span class="qpc-hafs">﴿فبهداهم اقتده﴾</span>{3}. (٦/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٦<span class="dash">-</span></span> عن العوام، قال: قال لي <span class="name-2">مجاهد</span>: فيم السجدة التي في ص؟ قال: إنّ الله ذكر الأنبياء، ثم قال: <span class="qpc-hafs">﴿أولئك الذين هدى الله فبهداهم اقتده﴾</span>. فاقتدى رسول الله ﷺ، واقتدينا نحن برسول الله ﷺ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- قال: قصَّ الله عليه ثمانيةَ عشر نبيا، ثُمَّ أمَره أن يَقتدِيَ بهم، وأنتم فاقتدوا بالصالحين قبلكم{5}. (٦/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثُمَّ رجع إلى النبي ﷺ، فقال: <span class="qpc-hafs">﴿أولئك الذين هدى الله فبهداهم اقتده﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر النبيين الثمانية عشر، فقال: <span class="qpc-hafs">﴿أولئك الذين هدى الله﴾</span> لدينه؛ <span class="qpc-hafs">﴿فبهداهم اقتده﴾</span> يقول للنبي ﷺ: فبِسُنَّتهم اقتدِ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿ووهبنا له إسحاق ويعقوب﴾</span> إلى قوله: <span class="qpc-hafs">﴿أولئك الذين هدى الله فبهداهم اقتده﴾</span> يا محمد{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٨١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أولئك الذين هدى الله﴾</span> يا محمد؛ <span class="qpc-hafs">﴿فبهداهم اقتده﴾</span> ولا تقتد بهؤلاء{9}<span class=comment-ref>٢٣٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٩/٣٩١-٣٩٢) في تفسير قوله تعالى: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</span> معنيين بناءً على المعاني التي تقدَّم ذكرها في المعنيِّ بقوله تعالى: <span class="qpc-hafs">﴿فَإنْ يَكْفُرْ بِها هَؤُلاءِ فَقَدْ وكَّلْنا بِها قَوْمًا لَيْسُوا بِها بِكافِرِينَ﴾</span>: <b>الأول</b>: مَن قال بأنّ القوم الذين وُكِّلوا بها هم الأنبياء المُسَمَّوْنَ في الآيات المتقدمة، فإنهم جعلوا قوله: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</span> تعود على قوله: <span class="qpc-hafs">﴿فَقَدْ وكَّلْنا بِها قَوْمًا لَيْسُوا بِها بِكافِرِينَ﴾</span>، والمعنى: <span class="qpc-hafs">﴿أُولَئِكَ﴾</span> هؤلاء القوم الذين وكَّلنا بآياتنا وليسوا بها بكافرين، هم الذين <span class="qpc-hafs">﴿هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</span>. و<b>الثاني</b>: مَن قال بأن القوم الذين وُكِّلوا بها هم أهل المدينة، أو أنهم هم الملائكة، فإنهم جعلوا قوله: <span class="qpc-hafs">﴿فَإنْ يَكْفُرْ بِها هَؤُلاءِ فَقَدْ وكَّلْنا بِها قَوْمًا لَيْسُوا بِها بِكافِرِينَ﴾</span> اعتراضًا بين الكلامين، ثم ردُّوا قوله: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ هَدى اللَّهُ فَبِهُداهُمُ اقْتَدِهْ﴾</span> على قوله: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ آتَيْناهُمُ الكِتابَ والحُكْمَ والنُّبُوَّةَ﴾</span>.</div></p><p><h3><span class="qpc-hafs">﴿قُل لَّاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ أَجۡرًاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿قل لا أسألكم عليه أجرا﴾</span>، قال: قل لهم، يا محمد: لا أسألُكم على ما أدْعُوكم إليه عَرَضًا مِن عَرَض الدنيا{10}. (٦/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٨٣<span class="dash">-</span></span> عن <span class="name-3">عطاء بن دينار</span> -من طريق أبي أيوب- في قول الله تعالى: <span class="qpc-hafs">﴿لا أسئلكم عليه أجرا﴾</span>، يقول: لا أسألكم على ما جئتكم به أجرًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل لا أسئلكم عليه﴾</span> يعني: على الإيمان بالقرآن <span class="qpc-hafs">﴿أجرا﴾</span> يعني: جميلًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قول الله: <span class="qpc-hafs">﴿قل لا أسئلكم عليه أجرا﴾</span>، يقول: لا أسألكم على القرآن أجرًا{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا ذِكۡرَىٰ لِلۡعَـٰلَمِینَ ۝٩٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن هو﴾</span> يعني: ما القرآن <span class="qpc-hafs">﴿إلا ذكرى﴾</span> يعني: تذكرة للعالمين{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حُمَيد.</p><p><span class="qpc-hafs">﴿فَبِهُداهُمُ اقْتَدِهْ﴾</span> بإسكان الهاء، قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، ويعقوب، وخلف العاشر، فإنهم حذفوها، وما عدا ابن عامر، فإنه قرأ بكسرها على اختلاف عنه في إشباع هذه الكسرة، وعدمها. انظر: النشر ٢/١٤٢.أخرجه البخاري ٤/١٦١ (٣٤٢١)، ٦/٥٧ (٤٦٣٢)، ٦/١٢٤ (٤٨٠٦، ٤٨٠٧)، وابن أبي حاتم ٤/١٣٣٩-١٣٤٠ (٧٥٧٩).أخرجه ابن جرير ٩/٣٩٢، وابن أبي حاتم ٤/١٣٣٦. وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٣٨ (٨٨٨).أخرجه ابن أبي حاتم ٤/١٣٤٠. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٩/٣٩٢.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن جرير ٩/٣٩٢.أخرجه ابن جرير ٩/٣٩٢، وابن أبي حاتم ٤/١٣٤٠ من طريق أصبغ بن الفرج.أخرجه ابن أبي حاتم ٤/١٣٤٠.أخرجه ابن أبي حاتم ٤/١٣٤٠.تفسير مقاتل بن سليمان ١/٥٧٣.أخرجه ابن أبي حاتم ٤/١٣٤٠.تفسير مقاتل بن سليمان ١/٥٧٣.