نذر، وأبي الشيخ، وابن مردويه.أخرجه ابن أبي حاتم ٧/٢٢٠٢.تفسير البغوي ٤/٢٨٢.عزاه السيوطي إلى ابن جرير.أخرجه ابن جرير ١٣/٣٦١.أخرجه ابن جرير ١٣/٣٥٩-٣٦٠، والحاكم ٢/٥٧٢. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٣/٣٥٩.تفسير الثعلبي ٥/٢٦٠، وتفسير البغوي ٤/٢٨١.عزاه السيوطي إلى أبي الشيخ.المُرُّ: دواء كالصَّبِر؛ سمي به لمرارته. النهاية (مرر).أخرجه ابن جرير ١٣/٣٦٩، وابن أبي حاتم ٧/٢٢٠٥.عزاه السيوطي إلى أحمد في الزهد.تفسير مقاتل بن سليمان ٢/٣٥١.
12,101," <q>﴿رَبِّ قَدۡ ءَاتَیۡتَنِی مِنَ ٱلۡمُلۡكِ﴾</q> - تفسير ٣٨٣٦٨- قال مقاتل بن سليمان: قال: <q>﴿رب قد آتيتني﴾</q> يعني: قد أعطيتني <q>﴿من الملك﴾</q> على أهلِ مِصْرَ ثمانين سنة{1}. (ز) ٣٨٣٦٩- عن أبي الأعْيَس [الخولاني] -من طريق ابن جابر- قال: لَمّا قال يوسف: <q>﴿رب قد ءاتيتنى من الملك﴾</q> إلى قوله: <q>﴿توفنى مسلمًا وألحقنى بالصالحين﴾</q> شكر اللهُ له ذلك، فزاده في عمره ثمانين عامًا{2}. (٨/٣٤٤) <q>﴿وَعَلَّمۡتَنِی مِن تَأۡوِیلِ ٱلۡأَحَادِیثِۚ﴾</q> - تفسير ٣٨٣٧٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وعلمتني من تأويل الأحاديث﴾</q>، قال: العِبارَة{3}. (ز) ٣٨٣٧١- قال مقاتل بن سليمان: قال: <q>﴿وعلمتني من تأويل الأحاديث﴾</q>، <q>﴿من﴾</q> هاهُنا صِلَة، يعني: تعبير الرؤيا{1}. (ز) <q>﴿فَاطِرَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ أَنتَ وَلِیِّۦ فِی ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِۖ﴾</q> - تفسير ٣٨٣٧٢- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿فاطر السماوات والأرض﴾</q>، قال: بَدِيع السموات والأرض{5}. (ز) ٣٨٣٧٣- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿فاطر السماوات والأرض﴾</q>، قال: خالق السموات والأرض{5}. (ز) ٣٨٣٧٤- قال مقاتل بن سليمان: قال: <q>﴿فاطر السماوات والأرض﴾</q> يعني: خالق السموات والأرض، قال: كُن <q>﴿أنت وليي في الدنيا والآخرة﴾</q>{1}. (ز) <q>﴿تَوَفَّنِی مُسۡلِمࣰا﴾</q> - تفسير ٣٨٣٧٥- عن عبد الله بن عباس -من طريق قتادة- قال: ما سأل نبِيٌّ الوفاةَ غير يوسف{5}. (٨/٣٤٥) ٣٨٣٧٦- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: لَمْ يَتَمَنَّ الموتَ نبيٌّ قطُّ غيرُ يوسف{9}. (ز) ٣٨٣٧٧- عن السدي، قال: وقال يوسف ﵇: <q>﴿رب قد آتيتنى من الملك﴾</q> إلى قوله: <q>﴿توفني مسلمًا وألحقني بالصالحين﴾</q>، قال ابن عباس: أولُ نبيٍّ سأل اللهَ الموتَ يوسفُ{10}. (٨/٢٠٠) ٣٨٣٧٨- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في الآية، قال: اشتاق إلى لقاء الله، وأحبَّ أن يَلْحَق به وبآبائه، فدعا اللهَ أن يَتَوَفّاه، وأن يُلْحِقَه بهم، ولم يسأل نبيٌّ قطُّ الموتَ غيرُ يوسف، فقال: <q>﴿رب قد ءاتيتنى من الملك﴾</q> الآية. قال عبد الملك ابن جُرَيْج: وأنا أقول: في بعضِ القرآن مَن قال مِن الأنبياء: تَوَفَّني{11}. (٨/٣٤٤) ٣٨٣٧٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿توفنى مسلمًا وألحقنى بالصالحين﴾</q>، يقول: تَوَفَّني على طاعتك، واغفِر لي إذا تَوَفَّيتَنِي{12}. (٨/٣٤٥) ٣٨٣٨٠- قال مقاتل بن سليمان: فلمّا جمع الله ليوسف شَمْلَهُ، فأَقَرَّ بعينه وهو مغموسٌ في المُلْكِ والنِّعمة؛ اشتاق إلى الله وإلى آياته، فتَمَنّى الموت، قال: <q>﴿توفني مسلما﴾</q>، يعني: مُخْلِصًا بتوحيدك{13}. (ز) ٣٨٣٨١- عن سعيد، قال: سمعت سفيان [بن عيينة] تلا هذه الآية: <q>﴿رب قد آتيتني من الملك وعلمتني من تأويل الأحاديث فاطر السموات والأرض أنت وليي في الدنيا والآخرة توفني مسلما﴾</q>، قال: ما سألها أحدٌ قبلَه حين اجتمع له أبواه وفرِح، سأل ربَّه أن يتوفاه، ويلحقه بالصالحين{14}٣٤٦٤. (ز) ٣٤٦٤ ذكر ابنُ كثير (٨/٧٧-٧٨) أنّ هذا الدعاء من يوسف ﵇ يحتمل عدة احتمالات: الأول: أنّه قاله عند احتضاره. الثاني: أنّه سأل الوفاة على الإسلام واللحاق بالصالحين إذا حان أجله، وانقضى عمره؛ لا أنه سأل ذلك منجزًا، كما يقول الداعي لغيره: أماتك الله على الإسلام. الثالث: أنه سأل ذلك منجزًا، وكان ذلك سائغًا في مِلَّتهم. الرابع: أنّه أول مَن سأل إنجاز ذلك. ونسب ابنُ عطية (٥/١٥٦) الاحتمال الثاني للمهدوي، ورجَّحه، فقال: «وهو الأقوى عندي». ولم يذكر مستندًا. وكذا رجَّحه ابنُ تيمية (٤/٦٧بتصرف) مستندًا إلى النظائر، فقال: «والصحيح أنه لم يسأل الموتَ، ولم يَتَمَنَّه، وإنّما سأل أنّه إذا مات يموت على الإسلام؛ فسأل الصفة لا الموصوف كما أمر الله بذلك؛ وأمر به خليله إبراهيم، وإسرائيل». <q>﴿وَأَلۡحِقۡنِی بِٱلصَّـٰلِحِینَ ۝١٠١﴾</q> - تفسير ٣٨٣٨٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح-: أنّ يوسف النبيَّ ﷺ لَمّا جمع بينه وبين أبيه وإخوته -وهو يومئذ مَلِكُ مصر- اشتاق إلى الله، وإلى آبائه الصالحين إبراهيم وإسحاق، قال: <q>﴿رب قد آتيتني من الملك، وعلمتني من تأويل الأحاديث، فاطر السموات والأرض، أنت وليي في الدنيا والآخرة، توفني مسلما وألحقني بالصالحين﴾</q>{3}. (ز) ٣٨٣٨٣- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿وألحقنى بالصالحين﴾</q>، قال: يعني: إبراهيم، وإسماعيل، وإسحاق، ويعقوب{16}. (٨/٣٤٥) ٣٨٣٨٤- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- في قوله: <q>﴿توفنى مسلمًا وألحقني بالصالحين﴾</q>، قال: يعني: أهل الجنة{17}. (٨/٣٤٥) ٣٨٣٨٥- عن الحسن البصري -من طريق المبارك بن فضالة- في قوله: <q>﴿قد آتيتني من الملك وعلمتني من تأويل الأحاديث﴾</q> إلى قوله: <q>﴿توفني مسلما وألحقني بالصالحين﴾</q>، قال: إنّ يوسف أُلْقِيَ في الجُبِّ وهو ابنُ سبع عشرة سنة، وغاب عن أبيه ثمانين سنة، وعاش بعد ما لقي أباه وجمع الله له شملَه ورأى تأويل رؤياه ثلاثًا وعشرين سنة، ومات وهو ابنُ عشرين ومائة سنة، فلمّا جمع الله له شملَه ورأى تأويل رؤياه اشتاق إلى ربِّه، فقال: <q>﴿توفني مسلما وألحقني بالصالحين﴾</q>. يعني بآبائه: إبراهيم، وإسحق، ويعقوب. قال الحسن البصري: وكذلك العبدُ الصالحُ يشتاق إلى ربه عز و جل{18}. (٨/٣٤١) ٣٨٣٨٦- عن وهب بن مُنَبِّه -من طريق ابنه إدريس- قال: لَمّا أُوتي يوسف مِن الملك ما أُوتِيَ تاقت نفسُه إلى آبائه، قال: <q>﴿رب قد ءاتيتنى من الملك﴾</q> إلى قوله: <q>﴿وألحقنى بالصالحين﴾</q>. قال: بآبائه إبراهيم، وإسحاق، ويعقوب{19}. (٨/٣٤٥) ٣٨٣٨٧- عن قتادة بن دعامة -من طريق سعيد- قال: لَمّا قدِم على يوسف أبواه وإخوتُه، وجمع الله شملَه، وأقرَّ عينَه، وهو يومئذ مغموسٌ في بيت نعيمٍ من الدنيا؛ اشتاق إلى آبائه الصالحين؛ إبراهيم وإسحاق ويعقوب، فسأل اللهَ القبضَ، ولم يَتَمَنَّ الموتَ أحدٌ قطُّ نبيٌّ ولا غيره إلا يوسف{20}. (٨/٣٤٥) ٣٨٣٨٨- قال مقاتل بن سليمان: قال: <q>﴿وألحقني بالصالحين﴾</q>، يعني: أباه يعقوب، وإسحاق، وإبراهيم{1}. (ز) ٣٨٣٨٩- عن محمد بن إسحاق -من طريق سلمة- قال: قال يوسف حين رأى ما رأى مِن كرامة الله وفضلِه عليه وعلى أهل بيته حين جمع اللهُ له شملَه، وردَّه على والده، وجمع بينه وبينه فيما هو فيه مِن المُلْك والبَهْجَة: <q>﴿يا أبت هذا تأويل رؤياي من قبل قد جعلها ربي حقا﴾</q> إلى قوله: <q>﴿إنه هو العليم الحكيم﴾</q>. ثم ارْعَوى يوسف، وذكر أنّ ما هو فيه مِن الدنيا بائِدٌ وذاهِب، فقال: <q>﴿رب قد آتيتني من الملك وعلمتني من تأويل الأحاديث، فاطر السموات والأرض﴾</q> إلى قوله: <q>﴿وألحقني بالصالحين﴾</q>{22}. (ز) <q>﴿وَأَلۡحِقۡنِی بِٱلصَّـٰلِحِینَ ۝١٠١﴾</q> - آثار متعلقة بالآية ٣٨٣٩٠- عن عروة بن الزبير، قال: إنّ الله حين أمر موسى ﵇ بالسَّيْر ببني إسرائيل؛ أمَرَه أن يَحْتَمِلَ معه عظام يوسف ﵇، وأن لا يُخَلِّفَها بأرض مصر، وأن يسير بها حتى يضعها بالأرض المُقَدَّسة، فسأل موسى عمَّن يعرِفُ موضعَ قبره، فما وجد إلا عجوزًا مِن بني إسرائيل، فقالت: يا نبيَّ الله، أنا أعرف مكانه، إن أنت أخرجتني معك ولم تُخَلِّفني بأرض مصر دَلَلْتُك عليه. قال: أفعلُ. وقد كان موسى وعَدَ بني إسرائيل أن يسير بهم إذا طلع القمر، فدعا ربَّه أن يُؤَخِّر طلوعه حتى يفرُغ مِن أمر يوسف، ففعل، فخرجت به العجوز حتى أرَتْه إيّاه في ناحية مِن النيل في الماء، فاستخرجه موسى صندوقًا مِن مرمر، فاحْتَمَلَه{23}. (٨/٣٤٧) ٣٨٣٩١- عن سعيد بن عبد العزيز -من طريق أبي مسهر-: أنّ يوسف لَمّا حضرته الوفاة قال: يا إخوتاه، إنِّي لم أنتصر مِن أحد ظلمني في الدنيا، وإني كنت أُحِبُّ أن أُظهِرَ الحسنة وأُخفِيَ السيئة، فذاك زادي مِن الدنيا. يا إخوتاه، إنِّي أشركت آبائي في أعمالهم، فأَشْرِكُوني معهم في قبورهم. وأَخَذَ عليهم بالميثاق، فلم يفعلوا حتى بعث الله موسى، فسأل عن قبره، فلم يجد أحدًا يُخبِرُه إلا امرأةً يُقال لها: شارحُ بنت شيرا بن يعقوب، فقالت: أدُلُّك عليه على أن أشترط عليك. قال: ذاك لكِ. قالت: أصيرُ شابَّة كُلَّما كَبِرْتُ. قال: ذلك لكِ. قالت: وأكونُ معكَ في درجتكَ يوم القيامة. فكأنّه امتنع، فأُمْرِ أن يُمْضِي لها ذلك، ففَعَل، فدَلَّته عليه، فأخرجه، فكانتْ كُلَّما كانت بنتَ خمسين سنة صارت مثل ابنة ثلاثين، حتى عُمِّرَت عُمُر نسرين ألف وستمائة سنة أو ألف وأربعمائة، حتى أدركها سليمان بن داود ﵇، فتَزَوَّجها{24}. (٨/٣٤٦) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٥٢.أخرجه ابن أبي حاتم ٧/٢٢٠٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٦٦.تفسير مقاتل بن سليمان ٢/٣٥٢.أخرجه ابن أبي حاتم ٧/٢٢٠٤.أخرجه ابن أبي حاتم ٧/٢٢٠٤.تفسير مقاتل بن سليمان ٢/٣٥٢.أخرجه ابن أبي حاتم ٧/٢٢٠٤.أخرجه مقاتل بن سليمان في تفسيره ٢/٣٥١.أخرجه ابن جرير ١٣/٣٦٥، وابن أبي حاتم ٧/٢٢٠٤.أخرجه ابن جرير ١٣/٣٦٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٦٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٥١-٣٥٢.أخرجه سعيد بن منصور (ت: سعد آل حميد) ٥/٤١١ (١٠١).أخرجه ابن جرير ١٣/٣٦٦.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢٢٠٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مجاهد ص٤٠١ مطولًا، وأَخرجه ابن أبي شيبة ١١/٥٦٤، وأحمد في الزهد ص٨٠-٨١، وابن عبد الحكم في فتوح مصر ص١٩، وابن جرير ١٣/٣٦٠، وابن أبي حاتم ٧/٢٢٠٢، والحاكم ٢/٥٧١، وفيه: وأُلْقِيَ في الجُبِّ وهو ابن اثنتي عشرة سنة. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه مختصرًا.أخرجه ابن أبي حاتم ٧/٢٢٠٥-٢٢٠٦.أخرجه ابن جرير ١٣/٣٦٥-٣٦٦ بنحوه، وابن أبي حاتم ٧/٢٢٠٥ بنحوه. وعزاه السيوطي إلى أحمد في الزهد.تفسير مقاتل بن سليمان ٢/٣٥٢.أخرجه ابن جرير ١٣/٣٦٧، وابن أبي حاتم ٧/٢٢٠٤.أخرجه ابن أبي حاتم ٨/٢٧٦٨ مختصرًا. وعزاه السيوطي إلى ابن إسحاق.أخرجه ابن أبي حاتم ٧/٢٢٠٥.
12,102," <q>﴿ذَ ٰ⁠لِكَ مِنۡ أَنۢبَاۤءِ ٱلۡغَیۡبِ نُوحِیهِ إِلَیۡكَۖ﴾</q> - تفسير ٣٨٣٩٢- عن أبي مالك غَزْوان الغِفاري -من طريق السدي- قوله: <q>﴿ذلك من أنباء الغيب﴾</q>، يعني: هذا أحاديث{1}. (ز) ٣٨٣٩٣- قال مقاتل بن سليمان: قال: <q>﴿ذلك﴾</q> الخبر <q>﴿من أنباء﴾</q> يعني: من أحاديث <q>﴿الغيب﴾</q> غاب -يا محمد- أمرُ يوسفَ ويعقوبَ وبنيه عنك حتى أعلمناك، <q>﴿نوحيه إليك﴾</q>لم تَشْهَدْه، ولم تَعْلَمْه{2}. (ز) ٣٨٣٩٤- عن محمد بن إسحاق -من طريق عبد الله بن إدريس- <q>﴿ذلك من أنباء الغيب نوحيه إليك﴾</q>: ثُمَّ قد جئتَهم بخبرِ ما غَيَّبوا عنك مِمّا عندهم، جئتهم به دليلًا علي نُبُوَّتك، والحُجَّة لكَ عليهم{1}. (ز) <q>﴿وَمَا كُنتَ لَدَیۡهِمۡ إِذۡ أَجۡمَعُوۤا۟ أَمۡرَهُمۡ وَهُمۡ یَمۡكُرُونَ ۝١٠٢﴾</q> - تفسير ٣٨٣٩٥- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿وما كنت لديهم إذ أجمعوا أمرَهُم وهم يمكرون﴾</q>، قال: هم بنو يعقوب، إذ يمكرون بيوسف{4}. (٨/٣٤٧) ٣٨٣٩٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وما كنت لديهم﴾</q> يعني: محمدًا ﷺ. يقول: وما كنت لديهم وهُم يُلقونه في غيابة الجب، <q>﴿وهم يمكرون﴾</q> بيوسف{5}. (٨/٣٤٧) ٣٨٣٩٧- عن عطاء الخراساني -من طريق عثمان بن عطاء- قوله: <q>﴿إذ أجمعوا أمرهم وهم يمكرون﴾</q>، قال: فَهُم بنو يعقوب، إذ يمكرون بيوسف{6}. (ز) ٣٨٣٩٨- قال مقاتل بن سليمان: قال: <q>﴿وما كنت لديهم﴾</q> يعني: عند إخوة يوسف <q>﴿إذ أجمعوا أمرهم وهم يمكرون﴾</q> بيوسف ﵇{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢٢٠٦.تفسير مقاتل بن سليمان ٢/٣٥٢.أخرجه ابن أبي حاتم ٧/٢٢٠٦.أخرجه ابن جرير ١٣/٣٧٠، وابن أبي حاتم ٧/٢٢٠٦ وفيه عن عطاء الخراساني من قوله. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٧٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢٢٠٦، وأبو جعفر الرملي في جزئه ص٨٧ (تفسير عطاء الخراساني) من طريق يونس بن يزيد.تفسير مقاتل بن سليمان ٢/٣٥٢.
12,103," <q>﴿وَمَاۤ أَكۡثَرُ ٱلنَّاسِ وَلَوۡ حَرَصۡتَ بِمُؤۡمِنِینَ ۝١٠٣﴾</q> - تفسير ٣٨٣٩٩- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿بمؤمنين﴾</q>، قال: مُصَدِّقين{1}. (ز) ٣٨٤٠٠- قال مقاتل بن سليمان: قال: <q>﴿وما أكثر الناس﴾</q> يعني: كفار مكة <q>﴿ولو حرصت بمؤمنين﴾</q> يعني: بمُصَدِّقين. فيها تقديم{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢٢٠٦.تفسير مقاتل بن سليمان ٢/٣٥٢.
