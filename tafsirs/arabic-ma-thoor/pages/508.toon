quran[8]{c,v,t}:
  47,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یُدۡخِلُ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ جَنَّـٰتࣲ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ وَٱلَّذِینَ كَفَرُوا۟ یَتَمَتَّعُونَ وَیَأۡكُلُونَ كَمَا تَأۡكُلُ ٱلۡأَنۡعَـٰمُ وَٱلنَّارُ مَثۡوࣰى لَّهُمۡ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر مُستقرّ المؤمنين والكافرين في الآخرة، فقال: <span class="qpc-hafs">﴿إنَّ اللَّهَ يُدْخِلُ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ جَنّاتٍ تَجْرِي مِن تَحْتِها الأَنْهارُ﴾</span> يعني: البساتين تجري من تحتها الأنهار، <span class="qpc-hafs">﴿والَّذِينَ كَفَرُوا يَتَمَتَّعُونَ ويَأْكُلُونَ﴾</span> لا يلتَفِتون إلى الآخرة <span class="qpc-hafs">﴿كَما تَأْكُلُ الأَنْعامُ﴾</span> ليس لهم هَمٌّ إلا الأكل والشّرب في الدنيا <span class="qpc-hafs">﴿والنّارُ مَثْوىً لَهُمْ﴾</span> يقول: هي مأواهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿والَّذِينَ كَفَرُوا يَتَمَتَّعُونَ ويَأْكُلُونَ كَما تَأْكُلُ الأَنْعامُ﴾</span>، قال: لا يَلْتَفت إلى آخرته{2}. (١٣/٣٦١)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٥-٤٦.|2:عزاه السيوطي إلى ابن المنذر.
  47,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَأَیِّن مِّن قَرۡیَةٍ هِیَ أَشَدُّ قُوَّةࣰ مِّن قَرۡیَتِكَ ٱلَّتِیۤ أَخۡرَجَتۡكَ أَهۡلَكۡنَـٰهُمۡ فَلَا نَاصِرَ لَهُمۡ ۝١٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: أنّ النبيّ ﷺ لَمّا خرج مِن مكة إلى الغار التفتَ إلى مكة، وقال: «<b>أنتِ أحبُّ بلاد الله إلى الله، وأنتِ أحبُّ بلاد الله إلَيَّ، ولولا أنّ أهلَكِ أخرجوني منك لم أخرج منك، فأعتى الأعداء مَن عتا على الله في حَرمه، أو قَتَل غير قاتله، أو قَتَل بذُحُول{1} أهل الجاهلية</b>». فأنزل الله تعالى: <span class="qpc-hafs">﴿وكَأَيِّنْ مِن قَرْيَةٍ هِيَ أشَدُّ قُوَّةً مِن قَرْيَتِكَ الَّتِي أخْرَجَتْكَ أهْلَكْناهُمْ فَلا ناصِرَ لَهُمْ﴾</span>{2}<span class=comment-ref>٦٠١٢</span>. (١٣/٣٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٦٤٥) في نزول هذه الآية عدة أقوال، فقال: «<b>ويقال</b>: إنّ هذه الآية نزلت إثر خروج رسول الله ﷺ من مكة في طريق المدينة. <b>وقيل</b>: نزلت بالمدينة. <b>وقيل</b>: نزلت بمكة عام دخلها رسول الله ﷺ بعد الحديبية. <b>وقيل</b> نزلت: عام الفتح وهو مقبل إليها». ثم <span class="comment-type-4">علّق</span> عليها جميعًا بقوله: «وهذا كله حكمه حكم المدني».</div></p><p><h3><span class="qpc-hafs">﴿وَكَأَیِّن مِّن قَرۡیَةٍ هِیَ أَشَدُّ قُوَّةࣰ مِّن قَرۡیَتِكَ ٱلَّتِیۤ أَخۡرَجَتۡكَ أَهۡلَكۡنَـٰهُمۡ فَلَا نَاصِرَ لَهُمۡ ۝١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٢٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وكَأَيِّنْ مِن قَرْيَةٍ هِيَ أشَدُّ قُوَّةً مِن قَرْيَتِكَ﴾</span> كم رجال هم أشدّ مِن أهل مكة؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وكَأَيِّنْ مِن قَرْيَةٍ هِيَ أشَدُّ قُوَّةً مِن قَرْيَتِكَ﴾</span>، قال: قَرْيَته: مكة{4}. (١٣/٣٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم ليحذروا، فقال: <span class="qpc-hafs">﴿وكَأَيِّنْ﴾</span> يقول: وكم <span class="qpc-hafs">﴿مِن قَرْيَةٍ﴾</span> قد مضَتْ فيما خلا كانت <span class="qpc-hafs">﴿هِيَ أشَدُّ قُوَّةً﴾</span> يعني: أشدّ بطْشًا وأكثر عددًا <span class="qpc-hafs">﴿مِن قَرْيَتِكَ﴾</span> يعني: مكة <span class="qpc-hafs">﴿الَّتِي أخْرَجَتْكَ﴾</span> يعني: أهل مكة حين أخْرجوا النبيَّ ﷺ. ثم رجع إلى الأمم الخالية في التقديم، فقال: <span class="qpc-hafs">﴿أهْلَكْناهُمْ﴾</span> بالعذاب حين كذّبوا رسلهم، <span class="qpc-hafs">﴿فَلا ناصِرَ لَهُمْ﴾</span> يقول: فلم يكن لهم مانِعٌ يمنعهم مِن العذاب الذي نَزَل بهم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:الذُّحول: جمع ذحْل: وهو الثأْر، وقيل: هو العداوة والحقد. لسان العرب (ذحل).|2:أخرجه الفاكهي في أخبار مكة ٢/٢٤١ (١٤٧٤) مختصرًا، وأبو يعلى -كما في المطالب العالية ١٥/٢٢٠-٢٢١ (٣٧١٦)-، وابن جرير ٢١/١٩٨، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣١٢- واللفظ له، من طريق المعتمر بن سليمان، عن أبيه، عن حُبيش، عن عكرمة، عن ابن عباس به.</p><p>إسناده صحيح.|3:تفسير البغوي ٧/٢٨٢.|4:أخرجه عبد الرزاق ٢/٢٢٢، وابن جرير ٢١/١٩٨ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٤٦.
  47,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَمَن كَانَ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّهِۦ كَمَن زُیِّنَ لَهُۥ سُوۤءُ عَمَلِهِۦ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُم ۝١٤﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أفَمَن كانَ عَلى بَيِّنَةٍ مِن رَبِّهِ﴾</span> قال: هو محمد ﷺ؛ <span class="qpc-hafs">﴿كَمَن زُيِّنَ لَهُ سُوءُ عَمَلِهِ﴾</span> قال: هم المشركون{1}<span class=comment-ref>٦٠١٣</span>. (١٣/٣٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٣</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/١٩٩): «وقيل: إنّ الذي عني بقوله: <span class="qpc-hafs">﴿أفمن كان على بينة من ربه﴾</span>: نبيّنا -عليه الصلاة والسلام-، وإنّ الذي عني بقوله: <span class="qpc-hafs">﴿كمن زين له سوء عمله﴾</span>: هم المشركون».</p><p>وذكر ذلك <u>ابنُ عطية</u> (٥/١١٣)، ثم <span class="comment-type-4">علّق</span> قائلًا: «وبقي اللفظ عامًّا لأهل هاتين الصفتين غابر الدهر».</div></p><p><div></p><p><p><span class="item-no">٧٠٨٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَمَن كانَ عَلى بَيِّنَةٍ مِن رَبِّهِ﴾</span> يعني: على بيان مِن ربِّه، وهو النبيُّ ﷺ؛ <span class="qpc-hafs">﴿كَمَن زُيِّنَ لَهُ سُوءُ عَمَلِهِ﴾</span> الكفر، <span class="qpc-hafs">﴿واتَّبَعُوا أهْواءَهُمْ﴾</span> نزلتْ في نَفرٍ مِن قريش؛ في أبي جهل بن هشام، وأبي حُذيفة بن المغيرة المخزوميين، فليسا بسواء؛ لأن النبي ﷺ مصيره إلى الجنة، وأبو حذيفة وأبو جهل مُخلّدان في النار{2}<span class=comment-ref>٦٠١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٤</span> <span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٧/٦٤٥) أن قوله: <span class="qpc-hafs">﴿على بينة﴾</span> معناه: «على قضية واضحة، وعقيدة نيّرة بيّنة». ثم ذكر <b>احتمالًا آخر</b>، فقال: «ويحتمل أن يكون المعنى: على أمر بيّن، ودين بيّن، وألحق الهاء للمبالغة كعلّامة ونسّابة».</div></p><p><h3><span class="qpc-hafs">﴿أَفَمَن كَانَ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّهِۦ كَمَن زُیِّنَ لَهُۥ سُوۤءُ عَمَلِهِۦ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُم ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كل هَوًى ضلالة{3}. (١٣/٣٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٣١<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span>، قال: ما ذكر الله هَوًى في القرآن إلا ذمّه{3}. (١٣/٣٦٢)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/٤٦.|3:عزاه السيوطي إلى ابن المنذر.|4:عزاه السيوطي إلى ابن المنذر.
  47,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّثَلُ ٱلۡجَنَّةِ ٱلَّتِی وُعِدَ ٱلۡمُتَّقُونَۖ فِیهَاۤ أَنۡهَـٰرࣱ مِّن مَّاۤءٍ غَیۡرِ ءَاسِنࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٣٢<span class="dash">-</span></span> عن أبي معاذ البصري: أنّ عليًّا كان عند النبي ﷺ -فذكر حديثًا طويلًا مرفوعًا فيه ذكر الجنة- قال: <span class="qpc-hafs">﴿وأنهار من ماء غير آسن﴾</span>، قال: صافٍ لا كدَر فيه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٣٣<span class="dash">-</span></span> عن محمد بن السّائِب الكلبي، في قوله: <span class="qpc-hafs">﴿مَثَلُ الجَنَّةِ الَّتِي وُعِدَ المُتَّقُونَ فِيها أنْهارٌ مِن ماءٍ غَيْرِ آسِنٍ﴾</span> الآية، قال: حدثني أبو صالح، عن ابن عباس، قال: قال رسول الله ﷺ: «<b>لَمّا أُسرِي بي، فانطلق بي الملَك، فانتهى بي إلى نهر الخمر، فإذا عليه إبراهيم ﵇، فقلتُ للملَك: أيُّ نهرٍ هذا؟ فقال: هذا نهر دِجلة. فقلتُ له: إنّه ماء. قال: هو في ماءٍ في الدنيا، يسقي اللهُ به مَن يشاء، وهو في الآخرة خمرٌ لأهل الجنة</b>». قال: «<b>ثم انطلقتُ مع المَلك إلى نهر الرُّبّ، فقلتُ للمَلك: أيُّ نهر هذا؟ قال: هو جَيْحُون، وهو الماء غير آسِن، وهو في الدنيا ماء، يسقي الله به مَن يشاء، وهو في الآخرة ماء غير آسِن. ثم انطلق بي، فأبلغني نهر اللّبن الذي يلي القِبلة، فقلتُ للمَلك: أيُّ نهر هذا؟ قال: هذا نهر الفُرات. فقلتُ: هو ماء؟ قال: هو ماء، يسقي الله به مَن يشاء في الدنيا، وهو لبن في الآخرة لذُرّية المؤمنين الذين ﵃ وعن آبائهم. ثم انطلَق بي، فأبلغني نهر العسل الذي يخرج مِن جانب المدينة، فقلتُ للمَلك الذي أُرسل معي: أي نهر هذا؟ قال: هذا نهر مِصر. قلت: ماء هو؟ قال: هو ماء، يسقي الله به مَن يشاء، وهو في الآخرة عسل لأهل الجنة</b>». <span class="qpc-hafs">﴿ولَهُمْ فِيها مِن كُلِّ الثَّمَراتِ﴾</span> يقول: في الجنة، <span class="qpc-hafs">﴿ومَغْفِرَةٌ مِن رَبِّهِمْ﴾</span> يقول: لذنوبهم{2}. (١٣/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله <span class="qpc-hafs">﴿أنْهارٌ مِن ماءٍ غَيْرِ آسِنٍ﴾</span>، قال: غير مُتغيّر{3}. (١٣/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٣٥<span class="dash">-</span></span> عن سعد بن طريف، قال: سألتُ أبا إسحاق عن: <span class="qpc-hafs">﴿ماءٍ غَيْرِ آسِنٍ﴾</span>. قال: سألتُ عنها <span class="name-2">الحارث [بن عبد الله الأعور]</span>، فحدثني: أنّ الماء الذي غير آسِن: تسنيم. قال: بلغني: أنه لا تمسّه يد، وأنه يجيء الماء هكذا حتى يدخل في فيه{4}. (١٣/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿مِن ماءٍ غَيْرِ آسِنٍ﴾</span>، قال: غير مُنتن{5}. (١٣/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَثَلُ الجَنَّةِ الَّتِي وُعِدَ المُتَّقُونَ﴾</span> ... يقول: شبَهُ الجنّة في الفضل والخير كشبهِ النار في الشدة وألوان العذاب، ثم ذكر ما أعدّ لأهل الجنة من الشراب، وما أعدّ لأهل النار من الشراب، <span class="qpc-hafs">﴿فِيها﴾</span> يعني: في الجنة <span class="qpc-hafs">﴿أنْهارٌ مِن ماءٍ غَيْرِ آسِنٍ﴾</span> يقول: لا يتغيّر كما يتغيّر ماء أهل الدنيا، فينتن{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّثَلُ ٱلۡجَنَّةِ ٱلَّتِی وُعِدَ ٱلۡمُتَّقُونَۖ فِیهَاۤ أَنۡهَـٰرࣱ مِّن مَّاۤءٍ غَیۡرِ ءَاسِنࣲ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٣٨<span class="dash">-</span></span> عن أبي وائل، قال: جاء رجل يُقال له: نَهِيكُ بن سنان إلى <span class="name-1">ابن مسعود</span>، فقال: يا أبا عبد الرحمن، كيف تقرأ هذا الحرف، أياء تجده أم ألفًا؟ (مِن مَّآءٍ غَيْرِ ياسِنٍ) أو <span class="qpc-hafs">﴿مِن ماءٍ غَيْرِ آسِنٍ﴾</span>؟ فقال له عبد الله: وكلّ القرآن أحصيتَ غير هذا؟! فقال: إني لَأقرأ المُفصّل في ركعة. قال: هذًّا كهذِّ الشِّعْر، إنّ قومًا يقرءون القرآن لا يجاوز تراقِيَهم، ولكنّ القرآن إذا وقع في القلب فرسَخ نَفع، إنِّي لأعرف النظائر التي كان يقرأ بهنّ رسول الله ﷺ{7}. (١٣/٣٦٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنۡهَـٰرࣱ مِّن لَّبَنࣲ لَّمۡ یَتَغَیَّرۡ طَعۡمُهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٣٩<span class="dash">-</span></span> عن عكرمة، <span class="qpc-hafs">﴿وأَنْهارٌ مِن لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ﴾</span>، قال: قال <span class="name-1">ابن عباس</span>:لم يُحْلَبْ{8}. (١٣/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان-، مثله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن</span> <span class="name-2">جُبير</span>، في قوله: <span class="qpc-hafs">﴿وأَنْهارٌ مِن لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ﴾</span>، قال: لم يخرج من بين فرْثٍ ودم{10}. (١٣/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنْهارٌ مِن لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ﴾</span> كما يتغيّر لبنُ أهل الدنيا عن حاله الأولى فيمخض{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنۡهَـٰرࣱ مِّنۡ خَمۡرࣲ لَّذَّةࣲ لِّلشَّـٰرِبِینَ وَأَنۡهَـٰرࣱ مِّنۡ عَسَلࣲ مُّصَفࣰّىۖ وَلَهُمۡ فِیهَا مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ وَمَغۡفِرَةࣱ مِّن رَّبِّهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٤٣<span class="dash">-</span></span> عن سعد بن طريف، قال: سألتُ عنها <span class="name-2">الحارث [بن عبد الله الأعور]</span>: <span class="qpc-hafs">﴿وأَنْهارٌ مِن خَمْرٍ لَذَّةٍ لِلشّارِبِينَ﴾</span>. فقال: لم تَدُسْه المجوس، ولم ينفخ فيه الشيطان، ولم تؤذها شمس، ولكنها فَوْحاء. قال: قلت لعكرمة: ما الفَوْحاء؟ قال: الصفراء{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن</span> <span class="name-2">جُبير</span>، في قوله: <span class="qpc-hafs">﴿وأَنْهارٌ مِن خَمْرٍ لَذَّةٍ لِلشّارِبِينَ﴾</span> قال: لم تَدُسْه الرّجال بأرجلها، <span class="qpc-hafs">﴿وأَنْهارٌ مِن عَسَلٍ مُصَفًّى﴾</span> قال: لم يخرج مِن بطون النّحل{10}. (١٣/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- قوله: <span class="qpc-hafs">﴿فيها من كل الثمرات﴾</span> فما في الدنيا من شجرة إلا وهي في الجنة، حتى الحنظل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنْهارٌ مِن خَمْرٍ لَذَّةٍ لِلشّارِبِينَ﴾</span> لا يُصدّعون عنها ولا يسكرون كخمر الدنيا، تجري لذّة للشاربين، <span class="qpc-hafs">﴿وأَنْهارٌ مِن عَسَلٍ مُصَفًّى﴾</span> ليس فيه عكَر ولا كدَر كعسل أهل الدنيا، فهذه الأنهار الأربعة تفجّر مِن الكوثر إلى سائر أهل الجنة، <span class="qpc-hafs">﴿ولَهُمْ فِيها مِن كُلِّ الثَّمَراتِ ومَغْفِرَةٌ﴾</span> لذنوبهم <span class="qpc-hafs">﴿مِن رَبِّهِمْ﴾</span> فهذا للمتقينَ الشركَ في الآخرة{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنۡهَـٰرࣱ مِّنۡ خَمۡرࣲ لَّذَّةࣲ لِّلشَّـٰرِبِینَ وَأَنۡهَـٰرࣱ مِّنۡ عَسَلࣲ مُّصَفࣰّىۖ وَلَهُمۡ فِیهَا مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ وَمَغۡفِرَةࣱ مِّن رَّبِّهِمۡۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٤٧<span class="dash">-</span></span> عن معاوية بن حيدة: سمعتُ رسول الله ﷺ يقول: «<b>في الجنّة بحرُ اللّبن، وبحر الماء، وبحر العسل، وبحر الخمر، ثم تَشَقَّق الأنهارُ منها بعد</b>»{16}. (١٣/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٤٨<span class="dash">-</span></span> عن <span class="name-2">كعب</span>، قال: نهر النيل نهر العسل في الجنّة، ونهر دِجلة نهر اللّبن في الجنّة، ونهر الفُرات نهر الخمر في الجنّة، ونهر سَيْحانَ نهر الماء في الجنة{17}. (١٣/٣٦٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَمَنۡ هُوَ خَـٰلِدࣱ فِی ٱلنَّارِ وَسُقُوا۟ مَاۤءً حَمِیمࣰا فَقَطَّعَ أَمۡعَاۤءَهُمۡ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٤٩<span class="dash">-</span></span> عن أبي أُمامة، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿ويُسْقى مِن ماءٍ صَدِيدٍ يَتَجَرَّعُهُ﴾</span> [إبراهيم:١٦-١٧]، قال: «<b>يُقرّب إليه، فيتكرّهه، فإذا أُدني منه شوى وجهه، ووقعت فَرْوة رأسه، فإذا شربه قطّع أمعاءه، حتى يخرج مِن دُبره، يقول الله ﷿: <span class="qpc-hafs">﴿وسُقُوا ماءً حَمِيمًا فَقَطَّعَ أمْعاءَهُمْ﴾</span>. ويقول الله: <span class="qpc-hafs">﴿وإنْ يَسْتَغِيثُوا يُغاثُوا بِماءٍ كالمُهْلِ يَشْوِي الوُجُوهَ بِئْسَ الشَّرابُ﴾</span></b> [الكهف:٢٩]»{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر مُستقرّ الكفّار، فقال: <span class="qpc-hafs">﴿كَمَن هُوَ خالِدٌ فِي النّارِ﴾</span> يعني: أبا جهل بن هشام، وأبا حذيفة المخزوميين، وأصحابهما في النار، <span class="qpc-hafs">﴿وسُقُوا ماءً حَمِيمًا﴾</span> يعني: شديد الحرّ الذي قد انتهى حرّه، تستعر عليهم جهنم، فهي تغلي منذ خُلِقت السماوات والأرض، <span class="qpc-hafs">﴿فَقَطَّعَ﴾</span> الماء <span class="qpc-hafs">﴿أمْعاءَهُمْ﴾</span> في الخوف من شدّة الحرّ{19}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٨١-.</p><p>قال ابن حجر: «من طريق مرسل، من رواية أبي معاذ البصري».|2:عزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف جدًّا. وينظر: مقدمة الموسوعة.|3:أخرجه ابن جرير ٢١/٢٠٠، وابن أبي حاتم -كما في التغليق ٤/٣١٢-.|4:أخرجه ابن جرير ٢١/٢٠٠.|5:أخرجه عبد الرزاق ٢/٢٢٢، وابن جرير ٢١/٢٠٠. وعزاه السيوطي إلى عبد بن حميد.|6:تفسير مقاتل بن سليمان ٤/٤٦.|7:أخرجه مسلم (٨٢٢)، وابن أبي شيبة ٢/٥٢٠، والترمذي (٦٠٢)، وأخرجه البخاري (٧٧٥) والنسائي (١٠٠٤) بدون ذكر الآية.|8:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وعنده موقوف على عكرمة كما في التالي.|9:أخرجه ابن جرير ٢١/٢٠٠.|10:عزاه السيوطي إلى ابن المنذر.|11:تفسير مقاتل بن سليمان ٤/٤٦.|12:أخرجه ابن جرير ٢١/٢٠١.|13:عزاه السيوطي إلى ابن المنذر.|14:أخرجه ابن أبي حاتم ٢/٥٢٣، وذلك في تفسير قوله تعالى: <span class="qpc-hafs">﴿لَهُ فِيها مِن كُلِّ الثَّمَراتِ﴾</span> [البقرة:٢٦٦]! والأشبه أنه تفسير لهذه الآية، وربما ذكره في تفسيرها، لكنه من المفقود من تفسيره.|15:تفسير مقاتل بن سليمان ٤/٤٦-٤٧.|16:أخرجه أحمد ٣٣/٢٤٦ (٢٠٠٥٢)، والترمذي ٤/٥٢٨-٥٢٩ (٢٧٤٤)، وابن حبان ١٦/٤٢٤ (٧٤٠٩).</p><p>قال الترمذي: «هذا حديث حسن صحيح».|17:أخرجه الحارث بن أبي أسامة في مسنده (١٠٤٧- بغية)، والبيهقي (٢٩٠).|18:أخرجه أحمد ٣٦/٦١٥ (٢٢٢٨٥)، والترمذي ٤/٥٣٨-٥٣٩ (٢٧٦٣)، والحاكم ٢/٣٨٢ (٣٣٣٩)، ٢/٤٠٠ (٣٣٩٣)، ٢/٤٩٦ (٣٧٠٤)، وابن جرير ١٣/٦٢٠، ١٥/٢٥١، ٢١/٢٠٢. وأورده الثعلبي ٥/٣١٠.</p><p>قال الترمذي: «هذا حديث غريب، وهكذا قال محمد بن إسماعيل عن عبيد الله بن بسر، ولا نعرف عبيد الله بن بسر إلا في هذا الحديث، وقد روى صفوان بن عمرو عن عبد الله بن بسر صاحب النبي ﷺ غير هذا الحديث، وعبد الله بن بسر له أخٌ قد سمِع من النبي ﷺ، وأخته قد سمعت من النبي ﷺ، وعبيد الله بن بسر الذي روى عنه صفوان بن عمرو هذا الحديث رجل آخر ليس بصاحب». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الألباني في الضعيفة ١٤/٩٢٤ (٦٨٩٧): «ضعيف».|19:تفسير مقاتل بن سليمان ٤/٤٧.كذا جاء اللفظ في مطبوعته، ولعلها: في الجوف.
  47,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡهُم مَّن یَسۡتَمِعُ إِلَیۡكَ حَتَّىٰۤ إِذَا خَرَجُوا۟ مِنۡ عِندِكَ قَالُوا۟ لِلَّذِینَ أُوتُوا۟ ٱلۡعِلۡمَ مَاذَا قَالَ ءَانِفًاۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ طَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمۡ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُمۡ ۝١٦﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: كانوا يدخلون على رسول الله ﷺ، فإذا خرجوا من عنده قالوا لابن عباس: ماذا قال آنفًا؟ فيقول: كذا وكذا. وكان ابن عباس مِن أصغر القوم؛ فأنزل الله: <span class="qpc-hafs">﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</span>، فكان ابنُ عباس مِن الذين أوتوا العلم{1}. (١٣/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، قال: كان المؤمنون والمنافقون يجتمعون إلى النبيِّ ﷺ، فيستمع المؤمنون منه ما يقول ويَعُونه، ويسمعه المنافقون فلا يَعُونه، فإذا خرجوا سألوا المؤمنين: ماذا قال آنفًا؟ فنزلت: <span class="qpc-hafs">﴿ومِنهُمْ مَن يَسْتَمِعُ إلَيْكَ﴾</span> الآية{2}. (١٣/٣٦٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡهُم مَّن یَسۡتَمِعُ إِلَیۡكَ حَتَّىٰۤ إِذَا خَرَجُوا۟ مِنۡ عِندِكَ قَالُوا۟ لِلَّذِینَ أُوتُوا۟ ٱلۡعِلۡمَ مَاذَا قَالَ ءَانِفًاۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ طَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمۡ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُمۡ ۝١٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يحيى بن الجزار، أو سعيد بن جُبير- في قوله: <span class="qpc-hafs">﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</span>، قال: أنا منهم، وقد سُئلت فيمن سُئل{3}. (١٣/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</span>: أنا منهم، وسُئلت وسأُسأل{4}. (١٣/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح- قال: هو عبد الله بن مسعود{5}. (١٣/٣٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٦<span class="dash">-</span></span> عن <span class="name-2">ابن بُرَيدة</span> -من طريق صالح بن حيّان- <span class="qpc-hafs">﴿قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</span>: هو عبد الله بن مسعود{6}. (١٣/٣٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٧<span class="dash">-</span></span> عن <span class="name-2">القاسم بن عبد الرحمن</span> -من طريق مسعر- قال: كان أبو الدّرداء مِن الذين أُوتوا العلم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومِنهُمْ مَن يَسْتَمِعُ إلَيْكَ﴾</span> الآية، قال: هؤلاء المنافقون، دخل رجلان؛ فرجل عقل عن الله وانتفع بما سمع، ورجل لم يعقل عن الله فلم ينتفع بما سمع، كان يقال: الناس ثلاثة: فسامع عامل، وسامع غافل، وسامع تارك{8}. (١٣/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِنهُمْ﴾</span> يعني: من المنافقين <span class="qpc-hafs">﴿مَن يَسْتَمِعُ إلَيْكَ﴾</span> يعني: إلى حديثك بالقرآن يا محمد <span class="qpc-hafs">﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ﴾</span> منهم رفاعة بن زيد، والحارث بن عمرو، وحليف بن زهرة، وذلك أنّ النبي ﷺ خَطَب يوم الجُمعة، فعاب المنافقين، وكانوا في المسجد، فكَظموا عند النبي ﷺ، فلمّا خرجوا -يعني: المنافقين- من الجمعة: <span class="qpc-hafs">﴿قالُوا لِلَّذِينَ أُوتُوا العِلْمَ﴾</span> وهو الهُدى، يعني: القرآن، يعني: عبد الله بن مسعود الهُذلي: <span class="qpc-hafs">﴿ماذا قالَ﴾</span> محمد <span class="qpc-hafs">﴿آنِفًا﴾</span>. وقد سمعوا قول النبي ﷺ فلم يفقهوه، <span class="qpc-hafs">﴿أُولئِكَ الَّذِينَ طَبَعَ اللَّهُ عَلى قُلُوبِهِمْ﴾</span> يعني: ختم الله على قلوبهم بالكفر فلا يعقلون الإيمان، <span class="qpc-hafs">﴿واتَّبَعُوا أهْواءَهُمْ﴾</span> في الكفر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومِنهُمْ مَن يَسْتَمِعُ إلَيْكَ حَتّى إذا خَرَجُوا مِن عِنْدِكَ﴾</span> إلى آخر الآية، قال: هؤلاء المنافقون، والذين أوتوا العلم: الصحابة ﵃{10}<span class=comment-ref>٦٠١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٥</span> ذكر ابنُ عطية (٧/٦٤٧) أن المفسرين يقولون: <span class="qpc-hafs">﴿آنفا﴾</span> معناه: الساعة الماضية القريبة منّا، وعلَّق عليه، بقوله: «وهذا تفسير بالمعنى».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ٢١/٢٠٤، والحاكم ٢/٤٥٧.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن عساكر ٣٣/١٤٤.|6:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٧/١٩٧ (٣٢٩٠٥)، وابن عساكر ٣٣/١٤٤.|7:أخرجه سعيد بن منصور في سننه -التفسير ٧/٣٥٩ (١٩٩٣) في تفسير هذه الآية.|8:أخرجه ابن جرير ٢١/٢٠٣، وأخرجه عبد الرزاق ٢/٢٢٢ من طريق معمر مختصرًا، وكذا ابن جرير ٢١/٢٠٤. وعزاه السيوطي إلى عبد بن حميد.|9:تفسير مقاتل بن سليمان ٤/٤٧.|10:أخرجه ابن جرير ٢١/٢٠٤.
  47,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ ٱهۡتَدَوۡا۟ زَادَهُمۡ هُدࣰى وَءَاتَىٰهُمۡ تَقۡوَىٰهُمۡ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</span>، قال: لَمّا أُنزل القرآن آمنوا به فكان هُدًى، فلما تبيّن الناسخ مِن المنسوخ زادهم هُدًى{1}<span class=comment-ref>٦٠١٦</span>. (١٣/٣٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٦</span> لم يذكر <u>ابنُ جرير</u> (٢١/٢٠٥) غير قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٢<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبير</span>: <span class="qpc-hafs">﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</span> وآتاهم ثواب تقواهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يونس-: أنّ ناسًا مِن أهل الكتاب آمنوا برُسلهم وصدّقوهم، وآمنوا بمحمد ﷺ قبل أن يُبعَث، فلمّا بُعِث كفروا به، فذلك قوله: <span class="qpc-hafs">﴿فَأَمّا الَّذِينَ اسْوَدَّتْ وُجُوهُهُمْ أكَفَرْتُمْ بَعْدَ إيمانِكُمْ﴾</span> [آل عمران:١٠٦]، وكان قومٌ مِن أهل الكتاب آمنوا برُسلهم وبمحمد ﷺ قبل أن يُبعَث، فلمّا بُعِث آمنوا به، فذلك قوله: <span class="qpc-hafs">﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</span>{3}. (١٣/٣٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٤<span class="dash">-</span></span> عن معقل بن عبيد الله الجزري، قال: قلتُ ل<span class="name-2">عطاء بن أبي رباح</span>: إنّ هاهنا قومًا يزعمون: أنّ الإيمان لا يزيد ولا ينقص. فقال: <span class="qpc-hafs">﴿والذين اهتدوا زادهم هدى وآتاهم تقواهم﴾</span> فما هذا الهُدى الذي زادهم الله؟!{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والَّذِينَ اهْتَدَوْا﴾</span> مِن الضّلالة <span class="qpc-hafs">﴿زادَهُمْ هُدىً﴾</span> بالمُحكم الذي نسخ الأمر الأول، <span class="qpc-hafs">﴿وآتاهُمْ تَقْواهُمْ﴾</span> وبيّن لهم التّقوى، يعني: عملًا بالمُحكم، حتى عملوا بالمُحكم{5}<span class=comment-ref>٦٠١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٧</span> ذكر <u>ابنُ عطية</u> (٧/٦٤٨) عدة احتمالات في الفاعل في قوله: <span class="qpc-hafs">﴿زادهم هدى﴾</span>: <b>الأول</b>: أن يكون الفاعل الله تعالى. و<span class="comment-type-4">علّق</span> عليه بقوله: «والزيادة في هذا المعنى تكون <b>إما</b> بزيادة التفهيم والأدلة، و<b>إما</b> بورود الشرائع والنواهي والأخبار فيزيد الاهتداء لتزيد علم ذلك كله والإيمان به وذلك بفضل الله تعالى». <b>الثاني</b>: أن يكون الفاعل قول المنافقين واضطرابهم في الآية التي قبلها. و<span class="comment-type-4">علّق</span> عليه قائلًا: «لأن ذلك مما يتعجّب المؤمن منه ويحمد الله على إيمانه، ويتزيّد بصيرة في دينه، فكأنه قال: المهتدون والمؤمنون زادهم فعل هؤلاء المنافقين هدى، أي: كانت الزيادة بسببه، فأسند الفعل إليه». <b>الثالث</b>: أن يكون الفاعل النبي محمد ﷺ، وذلك على قول مَن جعل الآية في قوم من النصارى. ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «وقوله على هذا القول: <span class="qpc-hafs">﴿اهتدوا﴾</span> يريد في إيمانهم بعيسى ﵇ ثم زادهم محمد هدًى حين آمنوا به». ثم <span class="comment-type-3">رجّح</span> القول الأول بقوله: «وأقواها أن الفاعل الله تعالى». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٢٠٥. وعزاه السيوطي إلى ابن مردويه.|2:تفسير الثعلبي ٩/٣٣، وتفسير البغوي ٧/٢٨٣.|3:أخرجه البيهقي في الدلائل ٢/٧٧. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه أبو نعيم في حلية الأولياء ٣/٣١٤.|5:تفسير مقاتل بن سليمان ٤/٤٧.
  47,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَهَلۡ یَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأۡتِیَهُم بَغۡتَةࣰۖ فَقَدۡ جَاۤءَ أَشۡرَاطُهَاۚ فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٦٦<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (فَهَلْ يَنظُرُونَ إلّا السّاعَةَ تَأْتِيَهُم بَغْتَةً){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٧<span class="dash">-</span></span> عن الفراء، قال: حدثني أبو جعفر الرؤاسي، قال: قلت <span class="name-2">لأبي عمرو بن العلاء</span>: ما هذه الفاء التي في قوله: <span class="qpc-hafs">﴿فَقَدْ جاءَ أشْراطُها﴾</span>؟ قال: جواب الجزاء. قال: قلتُ: إنها <span class="qpc-hafs">﴿أنْ تَأْتِيَهُمْ﴾</span> مفتوحة؟ قال: فقال: معاذ الله، إنما هي (إن تَأْتِهِمْ). قال الفرّاء: فظننتُ أنّه أخذها عن أهل مكة؛ لأنه عليهم قرأ، وهي أيضًا في بعض مصاحف الكوفيين: (تَأْتِهِم) بسينة{2} واحدة، ولم يقرأ بها أحد منهم {3}<span class=comment-ref>٦٠١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٨</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> ٢١/ ٢٠٦ هذه القراءة، فقال: «وتأويل الكلام على قراءة مَن قرأ ذلك بكسر ألف (إن) وجزم (تَأْتِهِمْ): فهل ينظرون إلا الساعة؟ فيجعل الخبر عن انتظار هؤلاء الكفار الساعة متناهيًا عند قوله: <span class="qpc-hafs">﴿إلا الساعة﴾</span>، ثم يبتدأ الكلام فيقال: إن تأتهم الساعة بغتة فقد جاء أشراطها، فتكون الفاء من قوله: <span class="qpc-hafs">﴿فقد جاء﴾</span> جواب الجزاء».</div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ یَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأۡتِیَهُم بَغۡتَةࣰۖ فَقَدۡ جَاۤءَ أَشۡرَاطُهَاۚ فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَقَدْ جاءَ أشْراطُها﴾</span>، قال: أوّل الساعات{4}. (١٣/٣٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿فَقَدْ جاءَ أشْراطُها﴾</span>: يعني: أشراط الساعة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فَقَدْ جاءَ أشْراطُها﴾</span>، قال: محمد ﷺ مِن أشراطها{6}. (١٣/٣٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧١<span class="dash">-</span></span> عن سعيد بن أبي عَرُوبة، في قوله: <span class="qpc-hafs">﴿فَهَلْ يَنْظُرُونَ إلّا السّاعَةَ أنْ تَأْتِيَهُمْ بَغْتَةً فَقَدْ جاءَ أشْراطُها﴾</span>، قال: كان <span class="name-2">قتادة</span> يقول: قد دَنَتِ الساعة، ودنا منكم فَناء، ودنا مِن الله فراغ للعباد. قال <span class="name-2">قتادة</span>: وذُكر لنا: أنّ نبي الله ﷺ خطب أصحابه بعد العصر حتى كادت الشمس تغرب، ولم يبق منها إلا شِفٌّ -أي: شيء-، فقال: «<b>والذي نفس محمد بيده، ما مَثل ما مضى مِن الدنيا فيما بقي منها إلا مَثل ما مضى مِن يومكم هذا فيما بقي منه، وما بقي منه إلا اليسير</b>»{7}. (١٣/٣٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّف أهلَ مكة، فقال: <span class="qpc-hafs">﴿فَهَلْ يَنْظُرُونَ إلّا السّاعَةَ﴾</span> يعني: القيامة <span class="qpc-hafs">﴿أنْ تَأْتِيَهُمْ بَغْتَةً﴾</span> يعني: فجأة، <span class="qpc-hafs">﴿فَقَدْ جاءَ أشْراطُها﴾</span> يعني: أعلامها، يعني: انشقاق القمر، وخروج الدَّجّال، وخروج النبي ﷺ، فقد عاينوا هذا كلّه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَقَدْ جاءَ أشْراطُها﴾</span>، قال: أشراطها: آياتها{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهَلۡ یَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأۡتِیَهُم بَغۡتَةࣰۖ فَقَدۡ جَاۤءَ أَشۡرَاطُهَاۚ فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</span> - آثار متعلقة بالآية{10}</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٧٤<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>بُعِثتُ أنا والساعة كهاتين</b>». وأشار بالسّبابة والوُسطى{11}. (١٣/٣٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٥<span class="dash">-</span></span> عن أنس، سمعتُ رسول الله ﷺ يقول: «<b>إنّ مِن أشراط الساعة أن يُرفع العلم، ويظهر الجهل، ويُشرَب الخمر، ويظهر الزِّنا، ويَقِلُّ الرِّجال، ويكثر النساء؛ حتى يكون على خمسين امرأة قيِّم واحد</b>»{12}. (١٣/٣٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٦<span class="dash">-</span></span> عن أنس، أنّ عبد الله بن سلام قال: يا رسول الله، ما أول أشراط الساعة؟ قال: «<b>نار تَحشُر الناس من المشرق إلى المغرب</b>»{13}. (١٣/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٧<span class="dash">-</span></span> عن أبي هريرة، قال: كان رسول الله ﷺ يومًا بارزًا للناس، فأتاه رجل، فقال: يا رسول الله، متى الساعة؟ فقال: «<b>ما المسئول عنها بأعلم مِن السائل، ولكن سأُحَدِّثُك عن أشراطها؛ إذا ولدَت الأمَة ربَّتها فذاك مِن أشراطها، وإذا كانت الحُفاة العُراة رِعاء الشّاء رءوس الناس فذاك من أشراطها، وإذا تطاول رِعاء الغنم في البنيان فذاك من أشراطها</b>»{14}. (١٣/٣٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٨<span class="dash">-</span></span> عن عبد الله بن مسعود: سمعت رسول الله ﷺ يقول: «<b>يكون بين يدي الساعة أيامٌ يُرفع فيها العلم، ويَنزل فيها الجهل، ويَكثر فيها الهَرْج</b>»{15}. (١٣/٣٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٧٩<span class="dash">-</span></span> عن معاذ بن جبل، قال: قال رسول الله ﷺ: «<b>سِتٌّ من أشراط الساعة: موتي، وفتْح بيت المقدس، وموتٌ يأخذ في الناس كقُعاص</b>{16} <b>الغنم، وفتنة يدخل حربُها بيت كل مسلم، وأنْ يُعطى الرجل ألف دينار فيسخَطها، وأن تَغدِرَ الرّوم فيسيرون بثمانين بندًا</b>{17}، <b>تحت كلّ بند اثنا عشر ألفًا</b>»{18}. (١٣/٤١٢-٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٠<span class="dash">-</span></span> عن عوف بن مالك الأشجعي، قال: أتيتُ رسول الله ﷺ في غزوة تبوك وهو في قُبّة أدَمٍ، فقال: «<b>اعدُد ستًا بين يدي الساعة: موتي، ثم فتْح بيت المقدس، ثم مُوتان يأخذكم كقُعاص الغنم، ثم استفاضة المال حتى يُعطى الرجل مائة دينار فيظلّ ساخطًا، ثم فتنة لا يبقى بيت مِن العرب إلا دخلته، ثم هُدنة تكون بينكم وبين بني الأصفر فيَغدِرُون، فيأتونكم تحت ثمانين راية، تحت كل راية اثنا عشر ألفًا</b>». زاد أحمد: «<b>فُسطاط المسلمين يومئذ في أرض يُقال لها: الغُوطَةُ. في مدينة يقال لها: دمشق</b>»{19}. (١٣/٤١٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</span>، قال: إذا جاءتهم الساعة فأنّى لهم أن يَذَّكَّرُوا ويتوبوا ويعملوا؟{20}. (١٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</span> فيها تقديم، يقول: مِن أين لهم التذكرة والتوبة عند الساعة إذا جاءتهم وقد فرّطوا فيها؟!{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</span>، يقول: إذا جاءت الساعة أنّى لهم الذِّكرى؟!{4}. (١٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٤<span class="dash">-</span></span> عن <span class="name-3">معمر بن راشد</span>، في قوله تعالى: <span class="qpc-hafs">﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</span>، قال: قد أنى لهم أن يتذكّروا أو يتوبوا؟! قال: إذا جاءتهم الساعة{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</span>، قال: الساعة، لا ينفعهم عند الساعة ذِكراهم{24}<span class=comment-ref>٦٠١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٠١٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٦٤٩) في قوله: <span class="qpc-hafs">﴿فأنى لهم إذا جاءتهم ذكراهم﴾</span> احتمالين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فأنى لهم﴾</span> الآية، <b>يحتمل</b> أن يكون المعنى: فأنّى لهم الخلاص أو النجاة إذ جاءتهم الذكرى بما كانوا يخبرون به في الدنيا فيكذّبون به وجاءهم العذاب مع ذلك. <b>ويحتمل</b> أن يكون المعنى: فأنّى لهم ذكراهم وعملهم بحسبها إذا جاءتهم الساعة. وهذا تأويل قتادة، <span class="mustanad">نظيره</span>: <span class="qpc-hafs">﴿وأنى لهم التناوش من مكان بعيد﴾</span> [سبأ:٥٢]».</div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٥.</p><p>وهي قراءة شاذة.|2:قال محققو معاني القرآن للفراء: كذا فى جميع النسخ، وقد تكون بسِنَّة.|3:معاني القرآن للفراء ٣/٦١، وأخرجه ابن جرير ٢١/٢٠٦.</p><p>وهي قراءة شاذة. ينظر: المحتسب في تبيين وجوه شواذ القراءات ٢/٢٧٠.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ٢١/٢٠٧.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:عزاه السيوطي إلى ابن مردويه. وأخرجه ابن جرير ٢١/٢٠٧ مختصرًا.|8:تفسير مقاتل بن سليمان ٤/٤٧-٤٨.|9:أخرجه ابن جرير ٢١/٢٠٧.|10:⟨أورد السيوطي عند تفسير هذه الآية ١٣/٣٦٨ – ٤٢٦ آثارًا كثيرة جدًّا عن أشراط الساعة وفتن آخر الزمان.⟩{ع}|11:أخرجه البخاري ٨/١٠٥-١٠٦ (٦٥٠٤)، ومسلم ٤/٢٢٦٨-٢٢٦٩ (٢٩٥١).|12:أخرجه البخاري ١/٢٧ (٨٠، ٨١)، ٧/٣٧ (٥٢٣١)، ٨/١٦٤ (٦٨٠٨)، ومسلم ٤/٢٠٥٦ (٢٦٧١).|13:أخرجه البخاري ٤/١٣٢ (٣٣٢٩) مطولًا، ٥/٦٩ (٣٩٣٨)، ٦/١٩ (٤٤٨٠)، والثعلبي ٩/٩ مطولًا. وعزاه السيوطي إلى ابن مردويه.|14:أخرجه البخاري ١/١٩ (٥٠)، ٦/١١٥ (٤٧٧٧)، ومسلم ١/٣٩-٤٠ (٩، ١٠).|15:أخرجه البخاري ٩/٤٨-٤٩ (٧٠٦٦)، ومسلم ٤/٢٠٥٦ (٢٦٧٢).|16:القُعاص -بالضم-: داء يأخذ الغنم لا يُلْبِثُها أن تموت. النهاية (قعص).|17:البند: العلم الكبير، وجمعه بنود. النهاية (بند).|18:أخرجه أحمد ٣٦/٣١٨ (٢١٩٩٢).</p><p>قال الهيثمي في المجمع ٧/٣٢٢ (١٢٤٣٢): «رواه أحمد والطبراني، وفيه النهاس بن قهم، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٨/١٠١ (٧٥٨١): «رواه أبو بكر بن أبي شيبة بسند فيه النهاس بن قهم، وهو ضعيف، وله شاهد من حديث عبد الله بن عمرو، رواه أحمد بن حنبل». وقال الألباني في الصحيحة ٤/٥٠٥ (١٨٨٣): «وهذا ضعيف منقطع، أبو عمار لم يسمع من معاذ».|19:أخرجه البخاري ٤/١٠١ (٣١٧٦)، وأحمد ٣٩/٤١١-٤١٢ (٢٣٩٨٥).|20:أخرجه ابن جرير ٢١/٢٠٨. وعزاه السيوطي إلى عبد بن حميد.|21:تفسير مقاتل بن سليمان ٤/٤٨.|22:عزاه السيوطي إلى ابن المنذر.|23:أخرجه عبد الرزاق ٢/٢٢٢ في تفسيره. جاء هكذا في المطبوع منه بتحقيق: د.مصطفى مسلم؛ عن معمر، وقد يكون فيه سقط، وهو عن معمر عن قتادة.|24:أخرجه ابن جرير ٢١/٢٠٨.
  47,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱعۡلَمۡ أَنَّهُۥ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٨٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٧<span class="dash">-</span></span> و<span class="name-3">سفيان بن عُيَينة</span>: هذا مُتَّصِلٌ بما قبله، معناه: فاعلم أنّه لا ملجأ ولا مَفْزع عند قيام الساعة إلا إلى الله{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱسۡتَغۡفِرۡ لِذَنۢبِكَ وَلِلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٨٨<span class="dash">-</span></span> عن أبي هريرة، في قوله: <span class="qpc-hafs">﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span>، قال رسول الله ﷺ: «<b>إني لأستغفر الله في اليوم سبعين مرة</b>»{2}. (١٣/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن سَرْجَس</span>، قال: أتيت النبيَّ ﷺ، فأكلتُ معه مِن طعام، فقلتُ: غفر الله لك، يا رسول الله. قال: «<b>ولك</b>». فقيل: أسْتغفرَ لك رسول الله؟ قال: نعم، ولكم. وقرأ: <span class="qpc-hafs">﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span>{3}. (١٣/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٠<span class="dash">-</span></span> عن عبيد بن المغيرة، قال: سمعتُ <span class="name-1">حذيفة</span> تلا قوله تعالى: <span class="qpc-hafs">﴿فاعْلَمْ أنَّهُ لا إلَهَ إلّا اللَّهُ واسْتَغْفِرْ لِذَنْبِكَ﴾</span>. قال: كنت ذَرِبَ اللِّسان{4} على أهلي، فقلتُ: يا رسول الله، إنِّي أخشى أن يُدخلني لساني النار. فقال النبيُّ ﷺ: «<b>فأين أنت مِن الاستغفار، إني لأستغفر الله في كلّ يوم مائة مرة</b>»{5}. (١٣/٤٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩١<span class="dash">-</span></span> عن ابن جُرَيْج، قال: قلت ل<span class="name-2">عطاء [بن أبي رباح]</span>: أستغفرُ للمؤمنين والمؤمنات؟ قال: نعم، قد أُمر النبي ﷺ بذلك، فإنّ ذلك الواجب على الناس؛ قال الله لنبيّه ﷺ: <span class="qpc-hafs">﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span>. قلت: أفتدع ذلك في المكتوبة أبدًا؟ قال: لا. قلتُ: فبِمن تبدأ، بنفسك أم بالمؤمنين؟ قال: بل بنفسي كما قال الله: <span class="qpc-hafs">﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاعْلَمْ أنَّهُ لا إلهَ إلّا اللَّهُ واسْتَغْفِرْ لِذَنْبِكَ لِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span> ولِذنوب المؤمنين والمؤمنات، يعني: المُصدِّقين بتوحيد الله والمُصدّقات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٣<span class="dash">-</span></span> عن يحيى بن عمر بن شداد التيمي، قال: قال لي <span class="name-3">سفيان بن عُيَينة</span>: ... ودعا لك محمد ﷺ. قال: قلت: وأين دعا لي؟ .... قال: ... أما سمعتَ قول الله ﷿: <span class="qpc-hafs">﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span>، فكان النبي ﷺ أطوع لله، وأبرّ بأُمّته وأرأف وأرحم مِن أنْ يأمره بشيء فيهم فلا يفعله{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱسۡتَغۡفِرۡ لِذَنۢبِكَ وَلِلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٩٤<span class="dash">-</span></span> عن عبد الله بن عمرو، عن النبي ﷺ، قال: «<b>أفضل الذّكر: لا إله إلا الله، وأفضل الدعاء: الاستغفار</b>». ثم قرأ: <span class="qpc-hafs">﴿فاعْلَمْ أنَّهُ لا إلَهَ إلّا اللَّهُ واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</span>{9}. (١٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٥<span class="dash">-</span></span> عن أبي بكر الصّدّيق، عن رسول الله ﷺ قال: «<b>عليكم بـ: لا إله إلا الله، والاستغفار، فأكثروا منهما؛ فإنّ إبليس قال: أهلكتُ الناس بالذنوب، وأهلكوني بـ: لا إله إلا الله والاستغفار، فلما رأيتُ ذلك أهلكتُهم بالأهواء، وهم يحسبون أنهم مُهْتَدُون</b>»{10}. (١٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٦<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>إنِّي لَأستغفر في اليوم وأتوب سبعين مرة، أو أكثر</b>»{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٧<span class="dash">-</span></span> عن عُبادة بن الصامت، قال: سمعتُ رسول الله ﷺ يقول: «<b>مَن استغفر للمؤمنين والمؤمنات كتب الله له بكل مؤمن ومؤمنة حسنة</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٨٩٨<span class="dash">-</span></span> عن أبي تَوبة الرّبيع بن نافع الحلبي الطَرْسوسي، قال: سُئِل <span class="name-3">سفيان بن عُيَينة</span> عن فضل العلم. فقال: ألم تسمع إلى قوله حين بدأ به، فقال: <span class="qpc-hafs">﴿فاعلم أنه لا إله إلا الله﴾</span>، ثم أمره بالعمل، فقال: <span class="qpc-hafs">﴿واستغفر لذنبك﴾</span>؟ وهو شهادة أن لا إله إلا الله، لا يغفر إلا بها، مَن قالها غُفِر له{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ یَعۡلَمُ مُتَقَلَّبَكُمۡ وَمَثۡوَىٰكُمۡ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٨٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ﴾</span> في الدنيا، <span class="qpc-hafs">﴿ومَثْواكُمْ﴾</span> في الآخرة{14}. (١٣/٤٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠١<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ ومَثْواكُمْ﴾</span> مُنصرفكم ومُنتشركم في أعمالكم في الدنيا، ومثواكم: مصيركم إلى الجنة أو إلى النار{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٢<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿مُتَقَلَّبَكُمْ﴾</span> مِن أصلاب الآباء إلى أرحام الأمهات، <span class="qpc-hafs">﴿ومَثْواكُمْ﴾</span> مقامكم في الأرض{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ﴾</span> يعني: مُنتشركم بالنهار، <span class="qpc-hafs">﴿ومَثْواكُمْ﴾</span> يعني: مأواكم بالليل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٩٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ ومَثْواكُمْ﴾</span>، قال: مُتَقَلَّب كلّ دابَّة بالليل والنهار{18}<span class=comment-ref>٦٠٢٠</span>. (١٣/٤٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٠٢٠</span> في قوله: <span class="qpc-hafs">﴿متقلبكم ومثواكم﴾</span> قولان: <b>الأول</b>: أن معناه: يعلم تصرّفكم في نهاركم، ومستقركم في ليلكم. <b>الثاني</b>: أن معناه: مُتقلّبكم في الدنيا، ومثواكم في قبوركم.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٣/٧٤) الأول بقوله: «والأول أولى وأظهر». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير الثعلبي ٩/٣٤، وتفسير البغوي ٧/٢٨٥.</p><p><b>وأورد السيوطي عند تفسير هذه الآية ١٣/٤٢٧-٤٣٣ آثارًا كثيرة في فضل: لا إله إلا الله.</b>|2:أخرجه الترمذي ٥/٤٦٢-٤٦٣ (٣٥٤١)، وعبد الرزاق ٣/٢٠٧ (٢٨٨٢).</p><p>قال الترمذي: «هذا حديث حسن صحيح».</p><p>وأصل الحديث في صحيح البخاري ٨/٦٧ (٦٣٠٧) بلفظ: «أكثر من سبعين مرة» دون ذكر الآية.|3:أخرجه مسلم ٤/١٨٢٣ (٢٣٤٦)، وابن جرير ٢١/٢٠٩، والثعلبي ٩/٣٤.|4:ذَرِب اللسان: حادَّ اللسان لا يُبالي ما قال. النهاية (ذرب).|5:أخرجه أحمد ٣٨/٣٦٥ (٢٣٣٤٠)، ٣٨/٣٨٤ (٢٣٣٦٢)، ٣٨/٣٨٩ (٢٣٣٧١)، ٣٨/٤١٩ (٢٣٤٢١)، وابن ماجه ٤/٧٢٠ (٣٨١٧)، وابن حبان ٣/٢٠٥ (٩٢٦)، والحاكم ١/٦٩١ (١٨٨١-١٨٨٢)، ٢/٤٩٦ (٣٧٠٦)، وعبد الرزاق ٣/٢٠٧ (٢٨٨٣).</p><p>قال البزار في مسنده ٧/٣٧٢-٣٧٣ (٢٩٧٠): «وقد روى هذا الحديث عن أبي إسحاق عن عبيد عن حذيفة جماعة». وقال ابن عدي في الكامل ٧/٤٩٩ (١٧٣١) في ترجمة محمد بن كثير: «وهذا عن عمرو بن قيس لا أعرفه إلا من حديث ابن كثير عنه». وقال الحاكم في الموضع الثالث: «هذا حديث صحيح الإسناد، ولم يخرجاه هكذا». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١٢٠٤-١٢٠٥ (٢٥٧٥): «رواه كثير بن سليم عن أنس، وكثير متروك الحديث». وقال ابن كثير في جامع المسانيد ٢/٣٨٨ (٢٢٣٩): «اضطرب الرواة عنه في اسم راويه عن حذيفة». وقال البوصيري في مصباح الزجاجة ٤/٣٤ (٩٣٣١): «هذا إسناد فيه أبو المغيرة البجلي، مضطرب الحديث عن حذيفة، قاله الذهبي في الكاشف». وقال ابن حجر في الأمالي المطلقة ص٢٥٣ (١٤٩): «هذا حديث حسن». وقال السيوطي في اللآلئ المصنوعة ٢/٢٥٧: «وأصح من ذلك في معناه حديث حذيفة». وقال الفتني في تذكرة الموضوعات ص١٦٩: «وبمجموع طرقه يبعد الحكم بوضعه، وإنْ كان أصح من حديث أبي هريرة». وقال الصنعاني في سبل السلام ٢/٦٨٤: «وهو أصح».|6:أخرجه عبد الرزاق في مصنفه ٢/٢١٧ (٣١٢٢).|7:تفسير مقاتل بن سليمان ٤/٤٨.|8:أخرجه ابن أبي الدنيا مطولًا في حسن الظن بالله ١/٩٠-٩١ (٧٩)، وكذلك أبو نعيم في حلية الأولياء ٧/٢٧٩.|9:أخرجه الطبراني في الكبير في المجلد (١٣، ١٤) ١٤/٩٧ (١٤٧١٣)، والديلمي في مسند الفردوس١/٣٥٢ (١٤١٢) دون ذكر الآية. وعزاه السيوطي إلى ابن مردويه.</p><p>قال الهيثمي في المجمع١٠/٨٤ (١٦٨١٧): «رواه الطبراني، وفيه الإفريقي وغيره مِن الضعفاء». وقال المناوي في فيض القدير ٥/٤٦٦ (٧٩٨٢): «رمز -السيوطي- لحُسنه». وقال الألباني في الضعيفة ٦/٣٦٥ (٢٨٤٢): «ضعيف».|10:أخرجه ابن أبي عاصم في كتاب السنة ١/٩ (٧)، وأبو يعلى في مسنده ١/١٢٣ (١٣٦).</p><p>قال ابن كثير في تفسيره ٢/١٢٤: «عثمان بن مطر وشيخه ضعيفان». وقال الهيثمي في المجمع ١٠/٢٠٧ (١٧٥٧٤): «وفيه عثمان بن مطر، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٧/٤٢٢ (٧٢٣٧): «بسند ضعيف». وقال المناوي في التيسير ٢/١٤٦: «وإسناده ضعيف». وقال الألباني في الضعيفة ١٢/١١٦ (٥٥٦٠): «موضوع».|11:أخرجه البخاري ٨/٦٧ (٦٣٠٧)، وعبد الرزاق ٣/٢٠٧ (٢٨٨٢).|12:أخرجه الطبراني في مسند الشاميين ٣/٢٣٤ (٢١٥٥).</p><p>قال الهيثمي في المجمع١٠/٢١٠ (١٧٥٩٨): «وإسناده جيد». والمناوي في التيسير ٢/٣٩٦: «وإسناده جيد».|13:أخرجه أبو نعيم في حلية الأولياء ٧/٢٨٥.|14:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|15:تفسير الثعلبي ٩/٣٤-٣٥، وتفسير البغوي ٧/٢٨٥.|16:تفسير الثعلبي ٩/٣٤، وتفسير البغوي ٧/٢٨٥.|17:تفسير مقاتل بن سليمان ٤/٤٨.|18:عزاه السيوطي إلى ابن المنذر.