quran[8]{c,v,t}:
47,12," <q>﴿إِنَّ ٱللَّهَ یُدۡخِلُ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ جَنَّـٰتࣲ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ وَٱلَّذِینَ كَفَرُوا۟ یَتَمَتَّعُونَ وَیَأۡكُلُونَ كَمَا تَأۡكُلُ ٱلۡأَنۡعَـٰمُ وَٱلنَّارُ مَثۡوࣰى لَّهُمۡ ۝١٢﴾</q> - تفسير ٧٠٨٢٢- قال مقاتل بن سليمان: ثم ذكر مُستقرّ المؤمنين والكافرين في الآخرة، فقال: <q>﴿إنَّ اللَّهَ يُدْخِلُ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ جَنّاتٍ تَجْرِي مِن تَحْتِها الأَنْهارُ﴾</q> يعني: البساتين تجري من تحتها الأنهار، <q>﴿والَّذِينَ كَفَرُوا يَتَمَتَّعُونَ ويَأْكُلُونَ﴾</q> لا يلتَفِتون إلى الآخرة <q>﴿كَما تَأْكُلُ الأَنْعامُ﴾</q> ليس لهم هَمٌّ إلا الأكل والشّرب في الدنيا <q>﴿والنّارُ مَثْوىً لَهُمْ﴾</q> يقول: هي مأواهم{1}. (ز) ٧٠٨٢٣- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿والَّذِينَ كَفَرُوا يَتَمَتَّعُونَ ويَأْكُلُونَ كَما تَأْكُلُ الأَنْعامُ﴾</q>، قال: لا يَلْتَفت إلى آخرته{2}. (١٣/٣٦١) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٥-٤٦.عزاه السيوطي إلى ابن المنذر.
47,13," <q>﴿وَكَأَیِّن مِّن قَرۡیَةٍ هِیَ أَشَدُّ قُوَّةࣰ مِّن قَرۡیَتِكَ ٱلَّتِیۤ أَخۡرَجَتۡكَ أَهۡلَكۡنَـٰهُمۡ فَلَا نَاصِرَ لَهُمۡ ۝١٣﴾</q> - نزول الآية ٧٠٨٢٤- عن عبد الله بن عباس -من طريق عكرمة-: أنّ النبيّ ﷺ لَمّا خرج مِن مكة إلى الغار التفتَ إلى مكة، وقال: «أنتِ أحبُّ بلاد الله إلى الله، وأنتِ أحبُّ بلاد الله إلَيَّ، ولولا أنّ أهلَكِ أخرجوني منك لم أخرج منك، فأعتى الأعداء مَن عتا على الله في حَرمه، أو قَتَل غير قاتله، أو قَتَل بذُحُول{1} أهل الجاهلية». فأنزل الله تعالى: <q>﴿وكَأَيِّنْ مِن قَرْيَةٍ هِيَ أشَدُّ قُوَّةً مِن قَرْيَتِكَ الَّتِي أخْرَجَتْكَ أهْلَكْناهُمْ فَلا ناصِرَ لَهُمْ﴾</q>{2}٦٠١٢. (١٣/٣٦٢) ٦٠١٢ ذكر ابنُ عطية (٧/٦٤٥) في نزول هذه الآية عدة أقوال، فقال: «ويقال: إنّ هذه الآية نزلت إثر خروج رسول الله ﷺ من مكة في طريق المدينة. وقيل: نزلت بالمدينة. وقيل: نزلت بمكة عام دخلها رسول الله ﷺ بعد الحديبية. وقيل نزلت: عام الفتح وهو مقبل إليها». ثم علّق عليها جميعًا بقوله: «وهذا كله حكمه حكم المدني». <q>﴿وَكَأَیِّن مِّن قَرۡیَةٍ هِیَ أَشَدُّ قُوَّةࣰ مِّن قَرۡیَتِكَ ٱلَّتِیۤ أَخۡرَجَتۡكَ أَهۡلَكۡنَـٰهُمۡ فَلَا نَاصِرَ لَهُمۡ ۝١٣﴾</q> - تفسير الآية ٧٠٨٢٥- قال عبد الله بن عباس: <q>﴿وكَأَيِّنْ مِن قَرْيَةٍ هِيَ أشَدُّ قُوَّةً مِن قَرْيَتِكَ﴾</q> كم رجال هم أشدّ مِن أهل مكة؟!{3}. (ز) ٧٠٨٢٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وكَأَيِّنْ مِن قَرْيَةٍ هِيَ أشَدُّ قُوَّةً مِن قَرْيَتِكَ﴾</q>، قال: قَرْيَته: مكة{4}. (١٣/٣٦٢) ٧٠٨٢٧- قال مقاتل بن سليمان: ثم خوّفهم ليحذروا، فقال: <q>﴿وكَأَيِّنْ﴾</q> يقول: وكم <q>﴿مِن قَرْيَةٍ﴾</q> قد مضَتْ فيما خلا كانت <q>﴿هِيَ أشَدُّ قُوَّةً﴾</q> يعني: أشدّ بطْشًا وأكثر عددًا <q>﴿مِن قَرْيَتِكَ﴾</q> يعني: مكة <q>﴿الَّتِي أخْرَجَتْكَ﴾</q> يعني: أهل مكة حين أخْرجوا النبيَّ ﷺ. ثم رجع إلى الأمم الخالية في التقديم، فقال: <q>﴿أهْلَكْناهُمْ﴾</q> بالعذاب حين كذّبوا رسلهم، <q>﴿فَلا ناصِرَ لَهُمْ﴾</q> يقول: فلم يكن لهم مانِعٌ يمنعهم مِن العذاب الذي نَزَل بهم{5}. (ز) ",footnotes:1:الذُّحول: جمع ذحْل: وهو الثأْر، وقيل: هو العداوة والحقد. لسان العرب (ذحل).أخرجه الفاكهي في أخبار مكة ٢/٢٤١ (١٤٧٤) مختصرًا، وأبو يعلى -كما في المطالب العالية ١٥/٢٢٠-٢٢١ (٣٧١٦)-، وابن جرير ٢١/١٩٨، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣١٢- واللفظ له، من طريق المعتمر بن سليمان، عن أبيه، عن حُبيش، عن عكرمة، عن ابن عباس به. إسناده صحيح.تفسير البغوي ٧/٢٨٢.أخرجه عبد الرزاق ٢/٢٢٢، وابن جرير ٢١/١٩٨ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٦.
47,14," <q>﴿أَفَمَن كَانَ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّهِۦ كَمَن زُیِّنَ لَهُۥ سُوۤءُ عَمَلِهِۦ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُم ۝١٤﴾</q> - نزول الآية، وتفسيرها ٧٠٨٢٨- عن قتادة بن دعامة، في قوله: <q>﴿أفَمَن كانَ عَلى بَيِّنَةٍ مِن رَبِّهِ﴾</q> قال: هو محمد ﷺ؛ <q>﴿كَمَن زُيِّنَ لَهُ سُوءُ عَمَلِهِ﴾</q> قال: هم المشركون{1}٦٠١٣. (١٣/٣٦٢) ٦٠١٣ قال ابنُ جرير (٢١/١٩٩): «وقيل: إنّ الذي عني بقوله: <q>﴿أفمن كان على بينة من ربه﴾</q>: نبيّنا -عليه الصلاة والسلام-، وإنّ الذي عني بقوله: <q>﴿كمن زين له سوء عمله﴾</q>: هم المشركون». وذكر ذلك ابنُ عطية (٥/١١٣)، ثم علّق قائلًا: «وبقي اللفظ عامًّا لأهل هاتين الصفتين غابر الدهر». ٧٠٨٢٩- قال مقاتل بن سليمان: <q>﴿أفَمَن كانَ عَلى بَيِّنَةٍ مِن رَبِّهِ﴾</q> يعني: على بيان مِن ربِّه، وهو النبيُّ ﷺ؛ <q>﴿كَمَن زُيِّنَ لَهُ سُوءُ عَمَلِهِ﴾</q> الكفر، <q>﴿واتَّبَعُوا أهْواءَهُمْ﴾</q> نزلتْ في نَفرٍ مِن قريش؛ في أبي جهل بن هشام، وأبي حُذيفة بن المغيرة المخزوميين، فليسا بسواء؛ لأن النبي ﷺ مصيره إلى الجنة، وأبو حذيفة وأبو جهل مُخلّدان في النار{2}٦٠١٤. (ز) ٦٠١٤ بيّن ابنُ عطية (٧/٦٤٥) أن قوله: <q>﴿على بينة﴾</q> معناه: «على قضية واضحة، وعقيدة نيّرة بيّنة». ثم ذكر احتمالًا آخر، فقال: «ويحتمل أن يكون المعنى: على أمر بيّن، ودين بيّن، وألحق الهاء للمبالغة كعلّامة ونسّابة». <q>﴿أَفَمَن كَانَ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّهِۦ كَمَن زُیِّنَ لَهُۥ سُوۤءُ عَمَلِهِۦ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُم ۝١٤﴾</q> - آثار متعلقة بالآية ٧٠٨٣٠- عن عبد الله بن عباس، قال: كل هَوًى ضلالة{3}. (١٣/٣٦٢) ٧٠٨٣١- عن طاووس بن كيسان، قال: ما ذكر الله هَوًى في القرآن إلا ذمّه{3}. (١٣/٣٦٢) ",footnotes:1:عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٦.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.
47,15," <q>﴿مَّثَلُ ٱلۡجَنَّةِ ٱلَّتِی وُعِدَ ٱلۡمُتَّقُونَۖ فِیهَاۤ أَنۡهَـٰرࣱ مِّن مَّاۤءٍ غَیۡرِ ءَاسِنࣲ﴾</q> - تفسير ٧٠٨٣٢- عن أبي معاذ البصري: أنّ عليًّا كان عند النبي ﷺ -فذكر حديثًا طويلًا مرفوعًا فيه ذكر الجنة- قال: <q>﴿وأنهار من ماء غير آسن﴾</q>، قال: صافٍ لا كدَر فيه{1}. (ز) ٧٠٨٣٣- عن محمد بن السّائِب الكلبي، في قوله: <q>﴿مَثَلُ الجَنَّةِ الَّتِي وُعِدَ المُتَّقُونَ فِيها أنْهارٌ مِن ماءٍ غَيْرِ آسِنٍ﴾</q> الآية، قال: حدثني أبو صالح، عن ابن عباس، قال: قال رسول الله ﷺ: «لَمّا أُسرِي بي، فانطلق بي الملَك، فانتهى بي إلى نهر الخمر، فإذا عليه إبراهيم ﵇، فقلتُ للملَك: أيُّ نهرٍ هذا؟ فقال: هذا نهر دِجلة. فقلتُ له: إنّه ماء. قال: هو في ماءٍ في الدنيا، يسقي اللهُ به مَن يشاء، وهو في الآخرة خمرٌ لأهل الجنة». قال: «ثم انطلقتُ مع المَلك إلى نهر الرُّبّ، فقلتُ للمَلك: أيُّ نهر هذا؟ قال: هو جَيْحُون، وهو الماء غير آسِن، وهو في الدنيا ماء، يسقي الله به مَن يشاء، وهو في الآخرة ماء غير آسِن. ثم انطلق بي، فأبلغني نهر اللّبن الذي يلي القِبلة، فقلتُ للمَلك: أيُّ نهر هذا؟ قال: هذا نهر الفُرات. فقلتُ: هو ماء؟ قال: هو ماء، يسقي الله به مَن يشاء في الدنيا، وهو لبن في الآخرة لذُرّية المؤمنين الذين ﵃ وعن آبائهم. ثم انطلَق بي، فأبلغني نهر العسل الذي يخرج مِن جانب المدينة، فقلتُ للمَلك الذي أُرسل معي: أي نهر هذا؟ قال: هذا نهر مِصر. قلت: ماء هو؟ قال: هو ماء، يسقي الله به مَن يشاء، وهو في الآخرة عسل لأهل الجنة». <q>﴿ولَهُمْ فِيها مِن كُلِّ الثَّمَراتِ﴾</q> يقول: في الجنة، <q>﴿ومَغْفِرَةٌ مِن رَبِّهِمْ﴾</q> يقول: لذنوبهم{2}. (١٣/٣٦٤) ٧٠٨٣٤- عن عبد الله بن عباس -من طريق علي- في قوله <q>﴿أنْهارٌ مِن ماءٍ غَيْرِ آسِنٍ﴾</q>، قال: غير مُتغيّر{3}. (١٣/٣٦٣) ٧٠٨٣٥- عن سعد بن طريف، قال: سألتُ أبا إسحاق عن: <q>﴿ماءٍ غَيْرِ آسِنٍ﴾</q>. قال: سألتُ عنها الحارث [بن عبد الله الأعور]، فحدثني: أنّ الماء الذي غير آسِن: تسنيم. قال: بلغني: أنه لا تمسّه يد، وأنه يجيء الماء هكذا حتى يدخل في فيه{4}. (١٣/٣٦٥) ٧٠٨٣٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿مِن ماءٍ غَيْرِ آسِنٍ﴾</q>، قال: غير مُنتن{5}. (١٣/٣٦٣) ٧٠٨٣٧- قال مقاتل بن سليمان: <q>﴿مَثَلُ الجَنَّةِ الَّتِي وُعِدَ المُتَّقُونَ﴾</q> ... يقول: شبَهُ الجنّة في الفضل والخير كشبهِ النار في الشدة وألوان العذاب، ثم ذكر ما أعدّ لأهل الجنة من الشراب، وما أعدّ لأهل النار من الشراب، <q>﴿فِيها﴾</q> يعني: في الجنة <q>﴿أنْهارٌ مِن ماءٍ غَيْرِ آسِنٍ﴾</q> يقول: لا يتغيّر كما يتغيّر ماء أهل الدنيا، فينتن{6}. (ز) <q>﴿مَّثَلُ ٱلۡجَنَّةِ ٱلَّتِی وُعِدَ ٱلۡمُتَّقُونَۖ فِیهَاۤ أَنۡهَـٰرࣱ مِّن مَّاۤءٍ غَیۡرِ ءَاسِنࣲ﴾</q> - آثار متعلقة بالآية ٧٠٨٣٨- عن أبي وائل، قال: جاء رجل يُقال له: نَهِيكُ بن سنان إلى ابن مسعود، فقال: يا أبا عبد الرحمن، كيف تقرأ هذا الحرف، أياء تجده أم ألفًا؟ (مِن مَّآءٍ غَيْرِ ياسِنٍ) أو <q>﴿مِن ماءٍ غَيْرِ آسِنٍ﴾</q>؟ فقال له عبد الله: وكلّ القرآن أحصيتَ غير هذا؟! فقال: إني لَأقرأ المُفصّل في ركعة. قال: هذًّا كهذِّ الشِّعْر، إنّ قومًا يقرءون القرآن لا يجاوز تراقِيَهم، ولكنّ القرآن إذا وقع في القلب فرسَخ نَفع، إنِّي لأعرف النظائر التي كان يقرأ بهنّ رسول الله ﷺ{7}. (١٣/٣٦٥) <q>﴿وَأَنۡهَـٰرࣱ مِّن لَّبَنࣲ لَّمۡ یَتَغَیَّرۡ طَعۡمُهُۥ﴾</q> - تفسير ٧٠٨٣٩- عن عكرمة، <q>﴿وأَنْهارٌ مِن لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ﴾</q>، قال: قال ابن عباس:لم يُحْلَبْ{8}. (١٣/٣٦٣) ٧٠٨٤٠- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان-، مثله{4}. (ز) ٧٠٨٤١- عن سعيد بن جُبير، في قوله: <q>﴿وأَنْهارٌ مِن لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ﴾</q>، قال: لم يخرج من بين فرْثٍ ودم{10}. (١٣/٣٦٣) ٧٠٨٤٢- قال مقاتل بن سليمان: <q>﴿وأَنْهارٌ مِن لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ﴾</q> كما يتغيّر لبنُ أهل الدنيا عن حاله الأولى فيمخض{6}. (ز) <q>﴿وَأَنۡهَـٰرࣱ مِّنۡ خَمۡرࣲ لَّذَّةࣲ لِّلشَّـٰرِبِینَ وَأَنۡهَـٰرࣱ مِّنۡ عَسَلࣲ مُّصَفࣰّىۖ وَلَهُمۡ فِیهَا مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ وَمَغۡفِرَةࣱ مِّن رَّبِّهِمۡۖ﴾</q> - تفسير ٧٠٨٤٣- عن سعد بن طريف، قال: سألتُ عنها الحارث [بن عبد الله الأعور]: <q>﴿وأَنْهارٌ مِن خَمْرٍ لَذَّةٍ لِلشّارِبِينَ﴾</q>. فقال: لم تَدُسْه المجوس، ولم ينفخ فيه الشيطان، ولم تؤذها شمس، ولكنها فَوْحاء. قال: قلت لعكرمة: ما الفَوْحاء؟ قال: الصفراء{12}. (ز) ٧٠٨٤٤- عن سعيد بن جُبير، في قوله: <q>﴿وأَنْهارٌ مِن خَمْرٍ لَذَّةٍ لِلشّارِبِينَ﴾</q> قال: لم تَدُسْه الرّجال بأرجلها، <q>﴿وأَنْهارٌ مِن عَسَلٍ مُصَفًّى﴾</q> قال: لم يخرج مِن بطون النّحل{10}. (١٣/٣٦٣) ٧٠٨٤٥- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- قوله: <q>﴿فيها من كل الثمرات﴾</q> فما في الدنيا من شجرة إلا وهي في الجنة، حتى الحنظل{14}. (ز) ٧٠٨٤٦- قال مقاتل بن سليمان: <q>﴿وأَنْهارٌ مِن خَمْرٍ لَذَّةٍ لِلشّارِبِينَ﴾</q> لا يُصدّعون عنها ولا يسكرون كخمر الدنيا، تجري لذّة للشاربين، <q>﴿وأَنْهارٌ مِن عَسَلٍ مُصَفًّى﴾</q> ليس فيه عكَر ولا كدَر كعسل أهل الدنيا، فهذه الأنهار الأربعة تفجّر مِن الكوثر إلى سائر أهل الجنة، <q>﴿ولَهُمْ فِيها مِن كُلِّ الثَّمَراتِ ومَغْفِرَةٌ﴾</q> لذنوبهم <q>﴿مِن رَبِّهِمْ﴾</q> فهذا للمتقينَ الشركَ في الآخرة{15}. (ز) <q>﴿وَأَنۡهَـٰرࣱ مِّنۡ خَمۡرࣲ لَّذَّةࣲ لِّلشَّـٰرِبِینَ وَأَنۡهَـٰرࣱ مِّنۡ عَسَلࣲ مُّصَفࣰّىۖ وَلَهُمۡ فِیهَا مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ وَمَغۡفِرَةࣱ مِّن رَّبِّهِمۡۖ﴾</q> - آثار متعلقة بالآية ٧٠٨٤٧- عن معاوية بن حيدة: سمعتُ رسول الله ﷺ يقول: «في الجنّة بحرُ اللّبن، وبحر الماء، وبحر العسل، وبحر الخمر، ثم تَشَقَّق الأنهارُ منها بعد»{16}. (١٣/٣٦٣) ٧٠٨٤٨- عن كعب، قال: نهر النيل نهر العسل في الجنّة، ونهر دِجلة نهر اللّبن في الجنّة، ونهر الفُرات نهر الخمر في الجنّة، ونهر سَيْحانَ نهر الماء في الجنة{17}. (١٣/٣٦٤) <q>﴿كَمَنۡ هُوَ خَـٰلِدࣱ فِی ٱلنَّارِ وَسُقُوا۟ مَاۤءً حَمِیمࣰا فَقَطَّعَ أَمۡعَاۤءَهُمۡ ۝١٥﴾</q> - تفسير ٧٠٨٤٩- عن أبي أُمامة، عن النبي ﷺ، في قوله: <q>﴿ويُسْقى مِن ماءٍ صَدِيدٍ يَتَجَرَّعُهُ﴾</q> [إبراهيم:١٦-١٧]، قال: «يُقرّب إليه، فيتكرّهه، فإذا أُدني منه شوى وجهه، ووقعت فَرْوة رأسه، فإذا شربه قطّع أمعاءه، حتى يخرج مِن دُبره، يقول الله ﷿: <q>﴿وسُقُوا ماءً حَمِيمًا فَقَطَّعَ أمْعاءَهُمْ﴾</q>. ويقول الله: <q>﴿وإنْ يَسْتَغِيثُوا يُغاثُوا بِماءٍ كالمُهْلِ يَشْوِي الوُجُوهَ بِئْسَ الشَّرابُ﴾</q> [الكهف:٢٩]»{18}. (ز) ٧٠٨٥٠- قال مقاتل بن سليمان: ثم ذكر مُستقرّ الكفّار، فقال: <q>﴿كَمَن هُوَ خالِدٌ فِي النّارِ﴾</q> يعني: أبا جهل بن هشام، وأبا حذيفة المخزوميين، وأصحابهما في النار، <q>﴿وسُقُوا ماءً حَمِيمًا﴾</q> يعني: شديد الحرّ الذي قد انتهى حرّه، تستعر عليهم جهنم، فهي تغلي منذ خُلِقت السماوات والأرض، <q>﴿فَقَطَّعَ﴾</q> الماء <q>﴿أمْعاءَهُمْ﴾</q> في الخوف من شدّة الحرّ{19}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٨١-. قال ابن حجر: «من طريق مرسل، من رواية أبي معاذ البصري».عزاه السيوطي إلى ابن مردويه. إسناده ضعيف جدًّا. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ٢١/٢٠٠، وابن أبي حاتم -كما في التغليق ٤/٣١٢-.أخرجه ابن جرير ٢١/٢٠٠.أخرجه عبد الرزاق ٢/٢٢٢، وابن جرير ٢١/٢٠٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٦.أخرجه مسلم (٨٢٢)، وابن أبي شيبة ٢/٥٢٠، والترمذي (٦٠٢)، وأخرجه البخاري (٧٧٥) والنسائي (١٠٠٤) بدون ذكر الآية.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وعنده موقوف على عكرمة كما في التالي.أخرجه ابن جرير ٢١/٢٠٠.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٦.أخرجه ابن جرير ٢١/٢٠١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٢/٥٢٣، وذلك في تفسير قوله تعالى: <q>﴿لَهُ فِيها مِن كُلِّ الثَّمَراتِ﴾</q> [البقرة:٢٦٦]! والأشبه أنه تفسير لهذه الآية، وربما ذكره في تفسيرها، لكنه من المفقود من تفسيره.تفسير مقاتل بن سليمان ٤/٤٦-٤٧.أخرجه أحمد ٣٣/٢٤٦ (٢٠٠٥٢)، والترمذي ٤/٥٢٨-٥٢٩ (٢٧٤٤)، وابن حبان ١٦/٤٢٤ (٧٤٠٩). قال الترمذي: «هذا حديث حسن صحيح».أخرجه الحارث بن أبي أسامة في مسنده (١٠٤٧- بغية)، والبيهقي (٢٩٠).أخرجه أحمد ٣٦/٦١٥ (٢٢٢٨٥)، والترمذي ٤/٥٣٨-٥٣٩ (٢٧٦٣)، والحاكم ٢/٣٨٢ (٣٣٣٩)، ٢/٤٠٠ (٣٣٩٣)، ٢/٤٩٦ (٣٧٠٤)، وابن جرير ١٣/٦٢٠، ١٥/٢٥١، ٢١/٢٠٢. وأورده الثعلبي ٥/٣١٠. قال الترمذي: «هذا حديث غريب، وهكذا قال محمد بن إسماعيل عن عبيد الله بن بسر، ولا نعرف عبيد الله بن بسر إلا في هذا الحديث، وقد روى صفوان بن عمرو عن عبد الله بن بسر صاحب النبي ﷺ غير هذا الحديث، وعبد الله بن بسر له أخٌ قد سمِع من النبي ﷺ، وأخته قد سمعت من النبي ﷺ، وعبيد الله بن بسر الذي روى عنه صفوان بن عمرو هذا الحديث رجل آخر ليس بصاحب». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الألباني في الضعيفة ١٤/٩٢٤ (٦٨٩٧): «ضعيف».تفسير مقاتل بن سليمان ٤/٤٧.كذا جاء اللفظ في مطبوعته، ولعلها: في الجوف.
47,16," <q>﴿وَمِنۡهُم مَّن یَسۡتَمِعُ إِلَیۡكَ حَتَّىٰۤ إِذَا خَرَجُوا۟ مِنۡ عِندِكَ قَالُوا۟ لِلَّذِینَ أُوتُوا۟ ٱلۡعِلۡمَ مَاذَا قَالَ ءَانِفًاۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ طَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمۡ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُمۡ ۝١٦﴾</q> - نزول الآية ٧٠٨٥١- عن عكرمة مولى ابن عباس، قال: كانوا يدخلون على رسول الله ﷺ، فإذا خرجوا من عنده قالوا لابن عباس: ماذا قال آنفًا؟ فيقول: كذا وكذا. وكان ابن عباس مِن أصغر القوم؛ فأنزل الله: <q>﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</q>، فكان ابنُ عباس مِن الذين أوتوا العلم{1}. (١٣/٣٦٦) ٧٠٨٥٢- عن عبد الملك ابن جُرَيْج، قال: كان المؤمنون والمنافقون يجتمعون إلى النبيِّ ﷺ، فيستمع المؤمنون منه ما يقول ويَعُونه، ويسمعه المنافقون فلا يَعُونه، فإذا خرجوا سألوا المؤمنين: ماذا قال آنفًا؟ فنزلت: <q>﴿ومِنهُمْ مَن يَسْتَمِعُ إلَيْكَ﴾</q> الآية{2}. (١٣/٣٦٥) <q>﴿وَمِنۡهُم مَّن یَسۡتَمِعُ إِلَیۡكَ حَتَّىٰۤ إِذَا خَرَجُوا۟ مِنۡ عِندِكَ قَالُوا۟ لِلَّذِینَ أُوتُوا۟ ٱلۡعِلۡمَ مَاذَا قَالَ ءَانِفًاۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ طَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمۡ وَٱتَّبَعُوۤا۟ أَهۡوَاۤءَهُمۡ ۝١٦﴾</q> - تفسير الآية ٧٠٨٥٣- عن عبد الله بن عباس -من طريق يحيى بن الجزار، أو سعيد بن جُبير- في قوله: <q>﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</q>، قال: أنا منهم، وقد سُئلت فيمن سُئل{3}. (١٣/٣٦٦) ٧٠٨٥٤- عن عبد الله بن عباس، في قوله: <q>﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</q>: أنا منهم، وسُئلت وسأُسأل{4}. (١٣/٣٦٦) ٧٠٨٥٥- عن عبد الله بن عباس -من طريق أبي صالح- قال: هو عبد الله بن مسعود{5}. (١٣/٣٦٧) ٧٠٨٥٦- عن ابن بُرَيدة -من طريق صالح بن حيّان- <q>﴿قالُوا لِلَّذِينَ أُوتُوا العِلْمَ ماذا قالَ آنِفًا﴾</q>: هو عبد الله بن مسعود{6}. (١٣/٣٦٧) ٧٠٨٥٧- عن القاسم بن عبد الرحمن -من طريق مسعر- قال: كان أبو الدّرداء مِن الذين أُوتوا العلم{7}. (ز) ٧٠٨٥٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ومِنهُمْ مَن يَسْتَمِعُ إلَيْكَ﴾</q> الآية، قال: هؤلاء المنافقون، دخل رجلان؛ فرجل عقل عن الله وانتفع بما سمع، ورجل لم يعقل عن الله فلم ينتفع بما سمع، كان يقال: الناس ثلاثة: فسامع عامل، وسامع غافل، وسامع تارك{8}. (١٣/٣٦٦) ٧٠٨٥٩- قال مقاتل بن سليمان: <q>﴿ومِنهُمْ﴾</q> يعني: من المنافقين <q>﴿مَن يَسْتَمِعُ إلَيْكَ﴾</q> يعني: إلى حديثك بالقرآن يا محمد <q>﴿حَتّى إذا خَرَجُوا مِن عِنْدِكَ﴾</q> منهم رفاعة بن زيد، والحارث بن عمرو، وحليف بن زهرة، وذلك أنّ النبي ﷺ خَطَب يوم الجُمعة، فعاب المنافقين، وكانوا في المسجد، فكَظموا عند النبي ﷺ، فلمّا خرجوا -يعني: المنافقين- من الجمعة: <q>﴿قالُوا لِلَّذِينَ أُوتُوا العِلْمَ﴾</q> وهو الهُدى، يعني: القرآن، يعني: عبد الله بن مسعود الهُذلي: <q>﴿ماذا قالَ﴾</q> محمد <q>﴿آنِفًا﴾</q>. وقد سمعوا قول النبي ﷺ فلم يفقهوه، <q>﴿أُولئِكَ الَّذِينَ طَبَعَ اللَّهُ عَلى قُلُوبِهِمْ﴾</q> يعني: ختم الله على قلوبهم بالكفر فلا يعقلون الإيمان، <q>﴿واتَّبَعُوا أهْواءَهُمْ﴾</q> في الكفر{9}. (ز) ٧٠٨٦٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومِنهُمْ مَن يَسْتَمِعُ إلَيْكَ حَتّى إذا خَرَجُوا مِن عِنْدِكَ﴾</q> إلى آخر الآية، قال: هؤلاء المنافقون، والذين أوتوا العلم: الصحابة ﵃{10}٦٠١٥. (ز) ٦٠١٥ ذكر ابنُ عطية (٧/٦٤٧) أن المفسرين يقولون: <q>﴿آنفا﴾</q> معناه: الساعة الماضية القريبة منّا، وعلَّق عليه، بقوله: «وهذا تفسير بالمعنى». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢٠٤، والحاكم ٢/٤٥٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن عساكر ٣٣/١٤٤.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٧/١٩٧ (٣٢٩٠٥)، وابن عساكر ٣٣/١٤٤.أخرجه سعيد بن منصور في سننه -التفسير ٧/٣٥٩ (١٩٩٣) في تفسير هذه الآية.أخرجه ابن جرير ٢١/٢٠٣، وأخرجه عبد الرزاق ٢/٢٢٢ من طريق معمر مختصرًا، وكذا ابن جرير ٢١/٢٠٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٧.أخرجه ابن جرير ٢١/٢٠٤.
47,17," <q>﴿وَٱلَّذِینَ ٱهۡتَدَوۡا۟ زَادَهُمۡ هُدࣰى وَءَاتَىٰهُمۡ تَقۡوَىٰهُمۡ ۝١٧﴾</q> - تفسير ٧٠٨٦١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</q>، قال: لَمّا أُنزل القرآن آمنوا به فكان هُدًى، فلما تبيّن الناسخ مِن المنسوخ زادهم هُدًى{1}٦٠١٦. (١٣/٣٦٧) ٦٠١٦ لم يذكر ابنُ جرير (٢١/٢٠٥) غير قول ابن عباس. ٧٠٨٦٢- قال سعيد بن جُبير: <q>﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</q> وآتاهم ثواب تقواهم{2}. (ز) ٧٠٨٦٣- عن عكرمة مولى ابن عباس -من طريق يونس-: أنّ ناسًا مِن أهل الكتاب آمنوا برُسلهم وصدّقوهم، وآمنوا بمحمد ﷺ قبل أن يُبعَث، فلمّا بُعِث كفروا به، فذلك قوله: <q>﴿فَأَمّا الَّذِينَ اسْوَدَّتْ وُجُوهُهُمْ أكَفَرْتُمْ بَعْدَ إيمانِكُمْ﴾</q> [آل عمران:١٠٦]، وكان قومٌ مِن أهل الكتاب آمنوا برُسلهم وبمحمد ﷺ قبل أن يُبعَث، فلمّا بُعِث آمنوا به، فذلك قوله: <q>﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</q>{3}. (١٣/٣٦٧) ٧٠٨٦٤- عن معقل بن عبيد الله الجزري، قال: قلتُ لعطاء بن أبي رباح: إنّ هاهنا قومًا يزعمون: أنّ الإيمان لا يزيد ولا ينقص. فقال: <q>﴿والذين اهتدوا زادهم هدى وآتاهم تقواهم﴾</q> فما هذا الهُدى الذي زادهم الله؟!{4}. (ز) ٧٠٨٦٥- قال مقاتل بن سليمان: <q>﴿والَّذِينَ اهْتَدَوْا﴾</q> مِن الضّلالة <q>﴿زادَهُمْ هُدىً﴾</q> بالمُحكم الذي نسخ الأمر الأول، <q>﴿وآتاهُمْ تَقْواهُمْ﴾</q> وبيّن لهم التّقوى، يعني: عملًا بالمُحكم، حتى عملوا بالمُحكم{5}٦٠١٧. (ز) ٦٠١٧ ذكر ابنُ عطية (٧/٦٤٨) عدة احتمالات في الفاعل في قوله: <q>﴿زادهم هدى﴾</q>: الأول: أن يكون الفاعل الله تعالى. وعلّق عليه بقوله: «والزيادة في هذا المعنى تكون إما بزيادة التفهيم والأدلة، وإما بورود الشرائع والنواهي والأخبار فيزيد الاهتداء لتزيد علم ذلك كله والإيمان به وذلك بفضل الله تعالى». الثاني: أن يكون الفاعل قول المنافقين واضطرابهم في الآية التي قبلها. وعلّق عليه قائلًا: «لأن ذلك مما يتعجّب المؤمن منه ويحمد الله على إيمانه، ويتزيّد بصيرة في دينه، فكأنه قال: المهتدون والمؤمنون زادهم فعل هؤلاء المنافقين هدى، أي: كانت الزيادة بسببه، فأسند الفعل إليه». الثالث: أن يكون الفاعل النبي محمد ﷺ، وذلك على قول مَن جعل الآية في قوم من النصارى. ثم علّق عليه قائلًا: «وقوله على هذا القول: <q>﴿اهتدوا﴾</q> يريد في إيمانهم بعيسى ﵇ ثم زادهم محمد هدًى حين آمنوا به». ثم رجّح القول الأول بقوله: «وأقواها أن الفاعل الله تعالى». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن جرير ٢١/٢٠٥. وعزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٣٣، وتفسير البغوي ٧/٢٨٣.أخرجه البيهقي في الدلائل ٢/٧٧. وعزاه السيوطي إلى ابن المنذر.أخرجه أبو نعيم في حلية الأولياء ٣/٣١٤.تفسير مقاتل بن سليمان ٤/٤٧.
47,18," <q>﴿فَهَلۡ یَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأۡتِیَهُم بَغۡتَةࣰۖ فَقَدۡ جَاۤءَ أَشۡرَاطُهَاۚ فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</q> - قراءات ٧٠٨٦٦- عن الأعمش: في قراءة عبد الله [بن مسعود]: (فَهَلْ يَنظُرُونَ إلّا السّاعَةَ تَأْتِيَهُم بَغْتَةً){1}. (ز) ٧٠٨٦٧- عن الفراء، قال: حدثني أبو جعفر الرؤاسي، قال: قلت لأبي عمرو بن العلاء: ما هذه الفاء التي في قوله: <q>﴿فَقَدْ جاءَ أشْراطُها﴾</q>؟ قال: جواب الجزاء. قال: قلتُ: إنها <q>﴿أنْ تَأْتِيَهُمْ﴾</q> مفتوحة؟ قال: فقال: معاذ الله، إنما هي (إن تَأْتِهِمْ). قال الفرّاء: فظننتُ أنّه أخذها عن أهل مكة؛ لأنه عليهم قرأ، وهي أيضًا في بعض مصاحف الكوفيين: (تَأْتِهِم) بسينة{2} واحدة، ولم يقرأ بها أحد منهم {3}٦٠١٨. (ز) ٦٠١٨ وجّه ابنُ جرير ٢١/ ٢٠٦ هذه القراءة، فقال: «وتأويل الكلام على قراءة مَن قرأ ذلك بكسر ألف (إن) وجزم (تَأْتِهِمْ): فهل ينظرون إلا الساعة؟ فيجعل الخبر عن انتظار هؤلاء الكفار الساعة متناهيًا عند قوله: <q>﴿إلا الساعة﴾</q>، ثم يبتدأ الكلام فيقال: إن تأتهم الساعة بغتة فقد جاء أشراطها، فتكون الفاء من قوله: <q>﴿فقد جاء﴾</q> جواب الجزاء». <q>﴿فَهَلۡ یَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأۡتِیَهُم بَغۡتَةࣰۖ فَقَدۡ جَاۤءَ أَشۡرَاطُهَاۚ فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</q> - تفسير الآية ٧٠٨٦٨- عن عبد الله بن عباس، في قوله: <q>﴿فَقَدْ جاءَ أشْراطُها﴾</q>، قال: أوّل الساعات{4}. (١٣/٣٦٨) ٧٠٨٦٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿فَقَدْ جاءَ أشْراطُها﴾</q>: يعني: أشراط الساعة{5}. (ز) ٧٠٨٧٠- عن الحسن البصري، في قوله: <q>﴿فَقَدْ جاءَ أشْراطُها﴾</q>، قال: محمد ﷺ مِن أشراطها{6}. (١٣/٣٦٨) ٧٠٨٧١- عن سعيد بن أبي عَرُوبة، في قوله: <q>﴿فَهَلْ يَنْظُرُونَ إلّا السّاعَةَ أنْ تَأْتِيَهُمْ بَغْتَةً فَقَدْ جاءَ أشْراطُها﴾</q>، قال: كان قتادة يقول: قد دَنَتِ الساعة، ودنا منكم فَناء، ودنا مِن الله فراغ للعباد. قال قتادة: وذُكر لنا: أنّ نبي الله ﷺ خطب أصحابه بعد العصر حتى كادت الشمس تغرب، ولم يبق منها إلا شِفٌّ -أي: شيء-، فقال: «والذي نفس محمد بيده، ما مَثل ما مضى مِن الدنيا فيما بقي منها إلا مَثل ما مضى مِن يومكم هذا فيما بقي منه، وما بقي منه إلا اليسير»{7}. (١٣/٣٦٨) ٧٠٨٧٢- قال مقاتل بن سليمان: ثم خوّف أهلَ مكة، فقال: <q>﴿فَهَلْ يَنْظُرُونَ إلّا السّاعَةَ﴾</q> يعني: القيامة <q>﴿أنْ تَأْتِيَهُمْ بَغْتَةً﴾</q> يعني: فجأة، <q>﴿فَقَدْ جاءَ أشْراطُها﴾</q> يعني: أعلامها، يعني: انشقاق القمر، وخروج الدَّجّال، وخروج النبي ﷺ، فقد عاينوا هذا كلّه{8}. (ز) ٧٠٨٧٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَقَدْ جاءَ أشْراطُها﴾</q>، قال: أشراطها: آياتها{5}. (ز) <q>﴿فَهَلۡ یَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأۡتِیَهُم بَغۡتَةࣰۖ فَقَدۡ جَاۤءَ أَشۡرَاطُهَاۚ فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</q> - آثار متعلقة بالآية{10} ٧٠٨٧٤- عن أنس، قال: قال رسول الله ﷺ: «بُعِثتُ أنا والساعة كهاتين». وأشار بالسّبابة والوُسطى{11}. (١٣/٣٦٨) ٧٠٨٧٥- عن أنس، سمعتُ رسول الله ﷺ يقول: «إنّ مِن أشراط الساعة أن يُرفع العلم، ويظهر الجهل، ويُشرَب الخمر، ويظهر الزِّنا، ويَقِلُّ الرِّجال، ويكثر النساء؛ حتى يكون على خمسين امرأة قيِّم واحد»{12}. (١٣/٣٦٩) ٧٠٨٧٦- عن أنس، أنّ عبد الله بن سلام قال: يا رسول الله، ما أول أشراط الساعة؟ قال: «نار تَحشُر الناس من المشرق إلى المغرب»{13}. (١٣/٤٢٥) ٧٠٨٧٧- عن أبي هريرة، قال: كان رسول الله ﷺ يومًا بارزًا للناس، فأتاه رجل، فقال: يا رسول الله، متى الساعة؟ فقال: «ما المسئول عنها بأعلم مِن السائل، ولكن سأُحَدِّثُك عن أشراطها؛ إذا ولدَت الأمَة ربَّتها فذاك مِن أشراطها، وإذا كانت الحُفاة العُراة رِعاء الشّاء رءوس الناس فذاك من أشراطها، وإذا تطاول رِعاء الغنم في البنيان فذاك من أشراطها»{14}. (١٣/٣٧٠) ٧٠٨٧٨- عن عبد الله بن مسعود: سمعت رسول الله ﷺ يقول: «يكون بين يدي الساعة أيامٌ يُرفع فيها العلم، ويَنزل فيها الجهل، ويَكثر فيها الهَرْج»{15}. (١٣/٣٧٢) ٧٠٨٧٩- عن معاذ بن جبل، قال: قال رسول الله ﷺ: «سِتٌّ من أشراط الساعة: موتي، وفتْح بيت المقدس، وموتٌ يأخذ في الناس كقُعاص{16} الغنم، وفتنة يدخل حربُها بيت كل مسلم، وأنْ يُعطى الرجل ألف دينار فيسخَطها، وأن تَغدِرَ الرّوم فيسيرون بثمانين بندًا{17}، تحت كلّ بند اثنا عشر ألفًا»{18}. (١٣/٤١٢-٤١٣) ٧٠٨٨٠- عن عوف بن مالك الأشجعي، قال: أتيتُ رسول الله ﷺ في غزوة تبوك وهو في قُبّة أدَمٍ، فقال: «اعدُد ستًا بين يدي الساعة: موتي، ثم فتْح بيت المقدس، ثم مُوتان يأخذكم كقُعاص الغنم، ثم استفاضة المال حتى يُعطى الرجل مائة دينار فيظلّ ساخطًا، ثم فتنة لا يبقى بيت مِن العرب إلا دخلته، ثم هُدنة تكون بينكم وبين بني الأصفر فيَغدِرُون، فيأتونكم تحت ثمانين راية، تحت كل راية اثنا عشر ألفًا». زاد أحمد: «فُسطاط المسلمين يومئذ في أرض يُقال لها: الغُوطَةُ. في مدينة يقال لها: دمشق»{19}. (١٣/٤١٢) <q>﴿فَأَنَّىٰ لَهُمۡ إِذَا جَاۤءَتۡهُمۡ ذِكۡرَىٰهُمۡ ۝١٨﴾</q> - تفسير ٧٠٨٨١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</q>، قال: إذا جاءتهم الساعة فأنّى لهم أن يَذَّكَّرُوا ويتوبوا ويعملوا؟{20}. (١٣/٤٢٦) ٧٠٨٨٢- قال مقاتل بن سليمان: <q>﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</q> فيها تقديم، يقول: مِن أين لهم التذكرة والتوبة عند الساعة إذا جاءتهم وقد فرّطوا فيها؟!{21}. (ز) ٧٠٨٨٣- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</q>، يقول: إذا جاءت الساعة أنّى لهم الذِّكرى؟!{4}. (١٣/٤٢٦) ٧٠٨٨٤- عن معمر بن راشد، في قوله تعالى: <q>﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</q>، قال: قد أنى لهم أن يتذكّروا أو يتوبوا؟! قال: إذا جاءتهم الساعة{23}. (ز) ٧٠٨٨٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَأَنّى لَهُمْ إذا جاءَتْهُمْ ذِكْراهُمْ﴾</q>، قال: الساعة، لا ينفعهم عند الساعة ذِكراهم{24}٦٠١٩. (ز) ٦٠١٩ ذكر ابنُ عطية (٧/٦٤٩) في قوله: <q>﴿فأنى لهم إذا جاءتهم ذكراهم﴾</q> احتمالين، فقال: «وقوله تعالى: <q>﴿فأنى لهم﴾</q> الآية، يحتمل أن يكون المعنى: فأنّى لهم الخلاص أو النجاة إذ جاءتهم الذكرى بما كانوا يخبرون به في الدنيا فيكذّبون به وجاءهم العذاب مع ذلك. ويحتمل أن يكون المعنى: فأنّى لهم ذكراهم وعملهم بحسبها إذا جاءتهم الساعة. وهذا تأويل قتادة، نظيره: <q>﴿وأنى لهم التناوش من مكان بعيد﴾</q> [سبأ:٥٢]». ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٥. وهي قراءة شاذة.قال محققو معاني القرآن للفراء: كذا فى جميع النسخ، وقد تكون بسِنَّة.معاني القرآن للفراء ٣/٦١، وأخرجه ابن جرير ٢١/٢٠٦. وهي قراءة شاذة. ينظر: المحتسب في تبيين وجوه شواذ القراءات ٢/٢٧٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٢٠٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه. وأخرجه ابن جرير ٢١/٢٠٧ مختصرًا.تفسير مقاتل بن سليمان ٤/٤٧-٤٨.أخرجه ابن جرير ٢١/٢٠٧.⟨أورد السيوطي عند تفسير هذه الآية ١٣/٣٦٨ – ٤٢٦ آثارًا كثيرة جدًّا عن أشراط الساعة وفتن آخر الزمان.⟩{ع}أخرجه البخاري ٨/١٠٥-١٠٦ (٦٥٠٤)، ومسلم ٤/٢٢٦٨-٢٢٦٩ (٢٩٥١).أخرجه البخاري ١/٢٧ (٨٠، ٨١)، ٧/٣٧ (٥٢٣١)، ٨/١٦٤ (٦٨٠٨)، ومسلم ٤/٢٠٥٦ (٢٦٧١).أخرجه البخاري ٤/١٣٢ (٣٣٢٩) مطولًا، ٥/٦٩ (٣٩٣٨)، ٦/١٩ (٤٤٨٠)، والثعلبي ٩/٩ مطولًا. وعزاه السيوطي إلى ابن مردويه.أخرجه البخاري ١/١٩ (٥٠)، ٦/١١٥ (٤٧٧٧)، ومسلم ١/٣٩-٤٠ (٩، ١٠).أخرجه البخاري ٩/٤٨-٤٩ (٧٠٦٦)، ومسلم ٤/٢٠٥٦ (٢٦٧٢).القُعاص -بالضم-: داء يأخذ الغنم لا يُلْبِثُها أن تموت. النهاية (قعص).البند: العلم الكبير، وجمعه بنود. النهاية (بند).أخرجه أحمد ٣٦/٣١٨ (٢١٩٩٢). قال الهيثمي في المجمع ٧/٣٢٢ (١٢٤٣٢): «رواه أحمد والطبراني، وفيه النهاس بن قهم، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٨/١٠١ (٧٥٨١): «رواه أبو بكر بن أبي شيبة بسند فيه النهاس بن قهم، وهو ضعيف، وله شاهد من حديث عبد الله بن عمرو، رواه أحمد بن حنبل». وقال الألباني في الصحيحة ٤/٥٠٥ (١٨٨٣): «وهذا ضعيف منقطع، أبو عمار لم يسمع من معاذ».أخرجه البخاري ٤/١٠١ (٣١٧٦)، وأحمد ٣٩/٤١١-٤١٢ (٢٣٩٨٥).أخرجه ابن جرير ٢١/٢٠٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٢٢٢ في تفسيره. جاء هكذا في المطبوع منه بتحقيق: د.مصطفى مسلم؛ عن معمر، وقد يكون فيه سقط، وهو عن معمر عن قتادة.أخرجه ابن جرير ٢١/٢٠٨.
47,19," <q>﴿فَٱعۡلَمۡ أَنَّهُۥ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ﴾</q> - تفسير ٧٠٨٨٦- عن أبي العالية الرِّياحيّ= (ز) ٧٠٨٨٧- وسفيان بن عُيَينة: هذا مُتَّصِلٌ بما قبله، معناه: فاعلم أنّه لا ملجأ ولا مَفْزع عند قيام الساعة إلا إلى الله{1}. (ز) <q>﴿وَٱسۡتَغۡفِرۡ لِذَنۢبِكَ وَلِلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِۗ﴾</q> - تفسير ٧٠٨٨٨- عن أبي هريرة، في قوله: <q>﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q>، قال رسول الله ﷺ: «إني لأستغفر الله في اليوم سبعين مرة»{2}. (١٣/٤٣١) ٧٠٨٨٩- عن عبد الله بن سَرْجَس، قال: أتيت النبيَّ ﷺ، فأكلتُ معه مِن طعام، فقلتُ: غفر الله لك، يا رسول الله. قال: «ولك». فقيل: أسْتغفرَ لك رسول الله؟ قال: نعم، ولكم. وقرأ: <q>﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q>{3}. (١٣/٤٣١) ٧٠٨٩٠- عن عبيد بن المغيرة، قال: سمعتُ حذيفة تلا قوله تعالى: <q>﴿فاعْلَمْ أنَّهُ لا إلَهَ إلّا اللَّهُ واسْتَغْفِرْ لِذَنْبِكَ﴾</q>. قال: كنت ذَرِبَ اللِّسان{4} على أهلي، فقلتُ: يا رسول الله، إنِّي أخشى أن يُدخلني لساني النار. فقال النبيُّ ﷺ: «فأين أنت مِن الاستغفار، إني لأستغفر الله في كلّ يوم مائة مرة»{5}. (١٣/٤٣٢) ٧٠٨٩١- عن ابن جُرَيْج، قال: قلت لعطاء [بن أبي رباح]: أستغفرُ للمؤمنين والمؤمنات؟ قال: نعم، قد أُمر النبي ﷺ بذلك، فإنّ ذلك الواجب على الناس؛ قال الله لنبيّه ﷺ: <q>﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q>. قلت: أفتدع ذلك في المكتوبة أبدًا؟ قال: لا. قلتُ: فبِمن تبدأ، بنفسك أم بالمؤمنين؟ قال: بل بنفسي كما قال الله: <q>﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q>{6}. (ز) ٧٠٨٩٢- قال مقاتل بن سليمان: <q>﴿فاعْلَمْ أنَّهُ لا إلهَ إلّا اللَّهُ واسْتَغْفِرْ لِذَنْبِكَ لِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q> ولِذنوب المؤمنين والمؤمنات، يعني: المُصدِّقين بتوحيد الله والمُصدّقات{7}. (ز) ٧٠٨٩٣- عن يحيى بن عمر بن شداد التيمي، قال: قال لي سفيان بن عُيَينة: ... ودعا لك محمد ﷺ. قال: قلت: وأين دعا لي؟ .... قال: ... أما سمعتَ قول الله ﷿: <q>﴿واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q>، فكان النبي ﷺ أطوع لله، وأبرّ بأُمّته وأرأف وأرحم مِن أنْ يأمره بشيء فيهم فلا يفعله{8}. (ز) <q>﴿وَٱسۡتَغۡفِرۡ لِذَنۢبِكَ وَلِلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِۗ﴾</q> - آثار متعلقة بالآية ٧٠٨٩٤- عن عبد الله بن عمرو، عن النبي ﷺ، قال: «أفضل الذّكر: لا إله إلا الله، وأفضل الدعاء: الاستغفار». ثم قرأ: <q>﴿فاعْلَمْ أنَّهُ لا إلَهَ إلّا اللَّهُ واسْتَغْفِرْ لِذَنْبِكَ ولِلْمُؤْمِنِينَ والمُؤْمِناتِ﴾</q>{9}. (١٣/٤٢٦) ٧٠٨٩٥- عن أبي بكر الصّدّيق، عن رسول الله ﷺ قال: «عليكم بـ: لا إله إلا الله، والاستغفار، فأكثروا منهما؛ فإنّ إبليس قال: أهلكتُ الناس بالذنوب، وأهلكوني بـ: لا إله إلا الله والاستغفار، فلما رأيتُ ذلك أهلكتُهم بالأهواء، وهم يحسبون أنهم مُهْتَدُون»{10}. (١٣/٤٢٧) ٧٠٨٩٦- عن أبي هريرة، عن النبي ﷺ، قال: «إنِّي لَأستغفر في اليوم وأتوب سبعين مرة، أو أكثر»{11}. (ز) ٧٠٨٩٧- عن عُبادة بن الصامت، قال: سمعتُ رسول الله ﷺ يقول: «مَن استغفر للمؤمنين والمؤمنات كتب الله له بكل مؤمن ومؤمنة حسنة»{12}. (ز) ٧٠٨٩٨- عن أبي تَوبة الرّبيع بن نافع الحلبي الطَرْسوسي، قال: سُئِل سفيان بن عُيَينة عن فضل العلم. فقال: ألم تسمع إلى قوله حين بدأ به، فقال: <q>﴿فاعلم أنه لا إله إلا الله﴾</q>، ثم أمره بالعمل، فقال: <q>﴿واستغفر لذنبك﴾</q>؟ وهو شهادة أن لا إله إلا الله، لا يغفر إلا بها، مَن قالها غُفِر له{13}. (ز) <q>﴿وَٱللَّهُ یَعۡلَمُ مُتَقَلَّبَكُمۡ وَمَثۡوَىٰكُمۡ ۝١٩﴾</q> - تفسير ٧٠٨٩٩- عن عبد الله بن عباس: <q>﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ﴾</q> في الدنيا، <q>﴿ومَثْواكُمْ﴾</q> في الآخرة{14}. (١٣/٤٣٤) ٧٠٩٠٠- قال عبد الله بن عباس= (ز) ٧٠٩٠١- والضَّحّاك بن مُزاحِم: <q>﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ ومَثْواكُمْ﴾</q> مُنصرفكم ومُنتشركم في أعمالكم في الدنيا، ومثواكم: مصيركم إلى الجنة أو إلى النار{15}. (ز) ٧٠٩٠٢- قال عكرمة مولى ابن عباس: <q>﴿مُتَقَلَّبَكُمْ﴾</q> مِن أصلاب الآباء إلى أرحام الأمهات، <q>﴿ومَثْواكُمْ﴾</q> مقامكم في الأرض{16}. (ز) ٧٠٩٠٣- قال مقاتل بن سليمان: <q>﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ﴾</q> يعني: مُنتشركم بالنهار، <q>﴿ومَثْواكُمْ﴾</q> يعني: مأواكم بالليل{7}. (ز) ٧٠٩٠٤- عن عبد الملك ابن جُرَيْج، <q>﴿واللَّهُ يَعْلَمُ مُتَقَلَّبَكُمْ ومَثْواكُمْ﴾</q>، قال: مُتَقَلَّب كلّ دابَّة بالليل والنهار{18}٦٠٢٠. (١٣/٤٣٤) ٦٠٢٠ في قوله: <q>﴿متقلبكم ومثواكم﴾</q> قولان: الأول: أن معناه: يعلم تصرّفكم في نهاركم، ومستقركم في ليلكم. الثاني: أن معناه: مُتقلّبكم في الدنيا، ومثواكم في قبوركم. وقد رجّح ابنُ كثير (١٣/٧٤) الأول بقوله: «والأول أولى وأظهر». ولم يذكر مستندًا. ",footnotes:1:تفسير الثعلبي ٩/٣٤، وتفسير البغوي ٧/٢٨٥. وأورد السيوطي عند تفسير هذه الآية ١٣/٤٢٧-٤٣٣ آثارًا كثيرة في فضل: لا إله إلا الله.أخرجه الترمذي ٥/٤٦٢-٤٦٣ (٣٥٤١)، وعبد الرزاق ٣/٢٠٧ (٢٨٨٢). قال الترمذي: «هذا حديث حسن صحيح». وأصل الحديث في صحيح البخاري ٨/٦٧ (٦٣٠٧) بلفظ: «أكثر من سبعين مرة» دون ذكر الآية.أخرجه مسلم ٤/١٨٢٣ (٢٣٤٦)، وابن جرير ٢١/٢٠٩، والثعلبي ٩/٣٤.ذَرِب اللسان: حادَّ اللسان لا يُبالي ما قال. النهاية (ذرب).أخرجه أحمد ٣٨/٣٦٥ (٢٣٣٤٠)، ٣٨/٣٨٤ (٢٣٣٦٢)، ٣٨/٣٨٩ (٢٣٣٧١)، ٣٨/٤١٩ (٢٣٤٢١)، وابن ماجه ٤/٧٢٠ (٣٨١٧)، وابن حبان ٣/٢٠٥ (٩٢٦)، والحاكم ١/٦٩١ (١٨٨١-١٨٨٢)، ٢/٤٩٦ (٣٧٠٦)، وعبد الرزاق ٣/٢٠٧ (٢٨٨٣). قال البزار في مسنده ٧/٣٧٢-٣٧٣ (٢٩٧٠): «وقد روى هذا الحديث عن أبي إسحاق عن عبيد عن حذيفة جماعة». وقال ابن عدي في الكامل ٧/٤٩٩ (١٧٣١) في ترجمة محمد بن كثير: «وهذا عن عمرو بن قيس لا أعرفه إلا من حديث ابن كثير عنه». وقال الحاكم في الموضع الثالث: «هذا حديث صحيح الإسناد، ولم يخرجاه هكذا». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١٢٠٤-١٢٠٥ (٢٥٧٥): «رواه كثير بن سليم عن أنس، وكثير متروك الحديث». وقال ابن كثير في جامع المسانيد ٢/٣٨٨ (٢٢٣٩): «اضطرب الرواة عنه في اسم راويه عن حذيفة». وقال البوصيري في مصباح الزجاجة ٤/٣٤ (٩٣٣١): «هذا إسناد فيه أبو المغيرة البجلي، مضطرب الحديث عن حذيفة، قاله الذهبي في الكاشف». وقال ابن حجر في الأمالي المطلقة ص٢٥٣ (١٤٩): «هذا حديث حسن». وقال السيوطي في اللآلئ المصنوعة ٢/٢٥٧: «وأصح من ذلك في معناه حديث حذيفة». وقال الفتني في تذكرة الموضوعات ص١٦٩: «وبمجموع طرقه يبعد الحكم بوضعه، وإنْ كان أصح من حديث أبي هريرة». وقال الصنعاني في سبل السلام ٢/٦٨٤: «وهو أصح».أخرجه عبد الرزاق في مصنفه ٢/٢١٧ (٣١٢٢).تفسير مقاتل بن سليمان ٤/٤٨.أخرجه ابن أبي الدنيا مطولًا في حسن الظن بالله ١/٩٠-٩١ (٧٩)، وكذلك أبو نعيم في حلية الأولياء ٧/٢٧٩.أخرجه الطبراني في الكبير في المجلد (١٣، ١٤) ١٤/٩٧ (١٤٧١٣)، والديلمي في مسند الفردوس١/٣٥٢ (١٤١٢) دون ذكر الآية. وعزاه السيوطي إلى ابن مردويه. قال الهيثمي في المجمع١٠/٨٤ (١٦٨١٧): «رواه الطبراني، وفيه الإفريقي وغيره مِن الضعفاء». وقال المناوي في فيض القدير ٥/٤٦٦ (٧٩٨٢): «رمز -السيوطي- لحُسنه». وقال الألباني في الضعيفة ٦/٣٦٥ (٢٨٤٢): «ضعيف».أخرجه ابن أبي عاصم في كتاب السنة ١/٩ (٧)، وأبو يعلى في مسنده ١/١٢٣ (١٣٦). قال ابن كثير في تفسيره ٢/١٢٤: «عثمان بن مطر وشيخه ضعيفان». وقال الهيثمي في المجمع ١٠/٢٠٧ (١٧٥٧٤): «وفيه عثمان بن مطر، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٧/٤٢٢ (٧٢٣٧): «بسند ضعيف». وقال المناوي في التيسير ٢/١٤٦: «وإسناده ضعيف». وقال الألباني في الضعيفة ١٢/١١٦ (٥٥٦٠): «موضوع».أخرجه البخاري ٨/٦٧ (٦٣٠٧)، وعبد الرزاق ٣/٢٠٧ (٢٨٨٢).أخرجه الطبراني في مسند الشاميين ٣/٢٣٤ (٢١٥٥). قال الهيثمي في المجمع١٠/٢١٠ (١٧٥٩٨): «وإسناده جيد». والمناوي في التيسير ٢/٣٩٦: «وإسناده جيد».أخرجه أبو نعيم في حلية الأولياء ٧/٢٨٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٩/٣٤-٣٥، وتفسير البغوي ٧/٢٨٥.تفسير الثعلبي ٩/٣٤، وتفسير البغوي ٧/٢٨٥.تفسير مقاتل بن سليمان ٤/٤٨.عزاه السيوطي إلى ابن المنذر.
