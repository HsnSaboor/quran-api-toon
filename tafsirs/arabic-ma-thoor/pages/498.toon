44,50," <q>﴿ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩ إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ۝٥٠﴾</q> - تفسير ٧٠١٥٢- عن عبد الله بن عباس، في قوله: <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q>، يقول: لستَ بعزيز، ولا كريم{1}. (١٣/٢٨٦) ٧٠١٥٣- قال مقاتل بن سليمان: ثم يقول له المَلك: <q>﴿ذُقْ﴾</q> العذاب، أيها المتعزّز المتكرّم، يوبّخه ويصغّره بذلك، يقول: <q>﴿إنَّكَ﴾</q> زعمت في الدنيا <q>﴿أنْتَ العَزِيزُ﴾</q> يعني: المنيع، <q>﴿الكَرِيمُ﴾</q> يعني: المتكرّم. قال: فكان أبو جهل يقول في الدنيا: أنا أعزّ قريش وأكرمها. فلمّا ذاق شِدّة العذاب في الآخرة قال له المَلك: <q>﴿إنَّ هَذا ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</q> يعني: تشكُّون في الدنيا أنه غير كائن، فهذا مستقرّ الكفار{2}. (ز) ٧٠١٥٤- عن عبد الملك ابن جُريج، في قوله: <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q>، قال: هو يومئذ ذليل، ولكن يَستهزئ به، كما كنتَ تُعزّز في الدنيا، وتُكرّم بغير كرم الله وعزّه{3}. (١٣/٢٨٨) <q>﴿ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩ إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ۝٥٠﴾</q> - آثار متعلقة بالآية ٧٠١٥٥- عن أبي هريرة، رفعه: «إنّ الله له ثلاثة أثواب؛ اتَّزر بالعِزَّة، وتَسَرْبَل بالرحمة، وارتدى بالكبرياء، فمَن تعزَّز بغير ما أعزّه الله فذلك الذي يُقال له: <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q>، ومَن رحم الناس ﵀، فذلك الذي تسرْبل بِسرْباله الذي ينبغي له، ومَن تكبّر فقد نازع الله رداءه الذي ينبغي له؛ فإنه -تبارك وتعالى- يقول: لا ينبغي لِمَن نازعني أن أُدخِله الجنة»{4}. (١٣/٣٠٩) ٧٠١٥٦- عن أبي هريرة، عن كعب نحوه{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٨٢٥.عزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في شعب الإيمان ١٠/٤٦٧ (٧٨١٠)، من طريق بكار بن قتيبة القاضي، عن صفوان بن عيسى، عن ابن عجلان، عن سعيد المقبري، عن أبي هريرة به. وسنده ليّن؛ فيه محمد بن عجلان، قال عنه ابن حجر في تقريب التهذيب (٦١٣٦): «صدوق، إلا أنه اختلطت عليه أحاديث أبي هريرة».أخرجه ابن جرير ٢١/٦٢.
44,51," <q>﴿إِنَّ ٱلۡمُتَّقِینَ فِی مَقَامٍ أَمِینࣲ ۝٥١ فِی جَنَّـٰتࣲ وَعُیُونࣲ ۝٥٢﴾</q> - تفسير ٧٠١٥٧- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿مَقامٍ أمِينٍ﴾</q>، قال: أمِنوا الموت أن يموتوا، وأمِنوا الهَرَم أن يَهْرموا، ولا يجوعوا، ولا يعْروا{1}. (١٣/٢٨٨) ٧٠١٥٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</q>، قال: أمين مِن الشيطان، والأوصاب، والأحزان{2}٥٩٢٨. (١٣/٢٨٩) ٥٩٢٨ لم يذكر ابنُ جرير (٢١/٦٤) غير قول قتادة. ٧٠١٥٩- قال مقاتل بن سليمان: ثم ذكر مُستقر المؤمنين، فقال: <q>﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</q> في مساكن، آمنين مِن الخوف والموت، <q>﴿فِي جَنّاتٍ وعُيُونٍ﴾</q> يعني: بساتين، وأنهار جارية{3}. (ز) ٧٠١٦٠- عن عبد الملك ابن جُريْج، في قوله: <q>﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</q>، قال: أمِنوا الموت والعذاب{4}. (١٣/٢٨٨) ٧٠١٦١- عن الوليد، قال: قال زهير بن محمد: <q>﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</q>، قال: أمِنوا فيه مِن الموت{5}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٤٥ (٣٦٦٤٦).أخرجه ابن جرير ٢١/٦٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٨٢٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا في ذكر الموت ٥/٤٩٩ (٣١٧).
  44,52,""
44,53," <q>﴿یَلۡبَسُونَ مِن سُندُسࣲ وَإِسۡتَبۡرَقࣲ مُّتَقَـٰبِلِینَ ۝٥٣﴾</q> - تفسير ٧٠١٦٢- قال كعب الأحبار: <q>﴿يَلْبَسُونَ مِن سُندُسٍ وإسْتَبْرَقٍ﴾</q> في الجنّة شجر تُنبِت الإستبرق والحرير، منه يكون لباس أهل الجنّة{1}. (ز) ٧٠١٦٣- عن عكرمة مولى ابن عباس -من طريق قتادة- في قوله: <q>﴿مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</q>، قال: الإستبرق: الدِّيباج الغليظ{2}. (ز) ٧٠١٦٤- قال الحسن البصري: <q>﴿مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</q> هما جميعًا حرير{3}. (ز) ٧٠١٦٥- قال مقاتل بن سليمان: <q>﴿يَلْبَسُونَ مِن سُندُسٍ وإسْتَبْرَقٍ﴾</q> يعني: الدِّيباج <q>﴿مُتَقابِلِينَ﴾</q> في الزيارة{4}. (ز) ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٨-.أخرجه ابن جرير ٢١/٦٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٧-.تفسير مقاتل بن سليمان ٣/٨٢٥.
44,54," <q>﴿كَذَ ٰ⁠لِكَ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ ۝٥٤﴾</q> - قراءات ٧٠١٦٦- عن قتادة، قال: في حرف ابن مسعود: (بعِيسٍ عِينٍ){1}٥٩٢٩. (١٣/٢٨٩) ٥٩٢٩ ذكر ابنُ عطية (٧/٥٨٥) قراءة ابن مسعود، وعلّق عليها فقال: «وقرأ ابن مسعود: (عِيسٍ)، وهو جمع عيساء، وهي أيضًا البيضاء، وكذلك هي من النوق». <q>﴿كَذَ ٰ⁠لِكَ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ ۝٥٤﴾</q> - تفسير الآية ٧٠١٦٧- قال أبو هُريرة: <q>﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</q> لَسْنَ مِن نساء الدنيا{2}. (ز) ٧٠١٦٨- عن عبد الله بن عمرو، قال: لشَفر المرأةِ أطولُ مِن جناح النّسر{3}. (١٣/٢٩١) ٧٠١٦٩- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿وحُورٌ عِينٌ﴾</q>. قال: الحَوراء: البيضاء المُنعَّمة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الأعشى وهو يقول: وحورٌ كأمثال الدُّمى ومناصفٌ وماءٌ وريحانٌ وراحٌ يصفِّق؟{4}. (١٣/٢٨٩) ٧٠١٧٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</q>، قال: أنكحناهم حُورًا، والحُور التي يُحار فيها الطرْف باديًا، يُرى مخّ سُوقهن مِن وراء ثيابهنّ، ويَرى الناظر وجهَه في كبِد إحداهن كالمرآة مِن رقّة الجلد وصفاء اللون{5}٥٩٣٠. (١٣/٢٨٩) ٥٩٣٠ انتقد ابنُ جرير (٢١/٦٥-٦٦) -مستندًا إلى اللغة، وأقوال السلف، والقراءات- قول مجاهد، فقال: «وهذا الذي قاله مجاهد مِن أنّ الحُور إنما معناها: أنه يحار فيها الطرف. قول لا معنى له في كلام العرب؛ لأنّ الحور إنما هو جمع حوراء، كالحمر جمع حمراء، والسود: جمع سوداء، والحوراء إنما هي فعلاء من الحور، وهو نقاء البياض، كما قيل للنقي البياض من الطعام: الحواري. وقد بيَّنا معنى ذلك بشواهده فيما مضى قبل، وبنحو الذي قلنا في معنى ذلك قال سائر أهل التأويل». وذكر أقوال السلف الدالة على أنّ الحَوراء هي البيضاء النقية، واستدل كذلك بقراءة ابن مسعود الواردة بالآثار على ضعف قول مجاهد، حيث قال عقب ذكره لها: "وقرأ ابن مسعود هذه، يعني: أن معنى الحُور غير الذي ذهب إليه مجاهد؛ لأن العيس عند العرب جمع عيساء، وهي البيضاء من الإبل، كما قال الأعشى: ومَهْمَهٍ نازِحٍ تَعْوِي الذّئاب به كَلَّفْتُ أعْيَسَ تَحْت الرَّحْل نَعّابا يعني بالأعيس: جملًا أبيض". وذكر ابنُ القيم (٢/٤٤٣) قول مجاهد، ثم علّق بقوله: «وهذا من الاتفاق، وليست اللفظة مُشتقّة من الحيرة». ثم رجّح أن الحُور: «مأخوذ مِن الحَور في العين، وهو شدة بياضها مع قوة سوادها، فهو يتضمن الأمرين، وأن العِين هنّ اللائي جمعتْ أعينهنّ صفات الحُسن والملاحة». ٧٠١٧١- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿بِحُورٍ عِينٍ﴾</q>، قال: الحُور: البيض. والعِين: العِظام الأعين{6}. (١٣/٢٩٠) ٧٠١٧٢- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</q>، قال: هي لغة يمانية؛ وذلك أنّ أهل اليمن يقولون: زوّجنا فلانًا بفلانة{7}. (١٣/٢٩١) ٧٠١٧٣- قال الحسن البصري: <q>﴿كَذَلِكَ وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</q>، أي: كذلك حكم الله لأهل الجنة بهذا{8}. (ز) ٧٠١٧٤- عن الحسن البصري -من طريق معمر، عمن سمع الحسن- يقول: <q>﴿كَذَلِكَ وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</q> الحُور العِين مِن نساء الدنيا، يُنشئهن الله خَلْقًا آخر{2}. (ز) ٧٠١٧٥- قال قتادة بن دعامة: <q>﴿بِحُورٍ عِينٍ﴾</q> الحُور: البيض. والعِين: عِظام العيون{8}. (ز) ٧٠١٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</q>، قال: بِيض عِين. قال: وفي قراءة ابن مسعود (بِعِيسٍ عِينٍ){11}. (١٣/٢٨٩) ٧٠١٧٧- عن عطاء الخراساني -من طريق ابنه عثمان- في قوله: <q>﴿بِحُورٍ عِينٍ﴾</q>، قال: سُود الحَدَقة، عظيمة العين{12}. (١٣/٢٨٩) ٧٠١٧٨- قال مقاتل بن سليمان: <q>﴿كَذلِكَ وزَوَّجْناهُمْ بِحُورٍ﴾</q> يعني: بِيض الوجوه <q>﴿عِينٍ﴾</q> يعني: حِسان العيون، ثم أخبر عنهم، فقال: <q>﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ﴾</q>{13}. (ز) <q>﴿كَذَ ٰ⁠لِكَ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ ۝٥٤﴾</q> - آثار متعلقة بالآية ٧٠١٧٩- عن أبي أمامة، قال: قال رسول الله ﷺ: «خُلق الحُور العِين من الزّعفران»{14}. (١٣/٢٩٠) ٧٠١٨٠- عن عائشة، قالت: قال رسول الله ﷺ: «حُور العِين خُلِقْن من تسبيح الملائكة»{15}. (١٣/٢٩١) ٧٠١٨١- عن أنس، قال: قال رسول الله ﷺ: «لو أنّ حَوراء بَزَقَتْ في بحر لُجِّيٍّ لَعَذُب ذلك البحر مِن عذوبة ريقها»{16}. (١٣/٢٩١) ٧٠١٨٢- عن مجاهد بن جبر -من طريق ليث- قال: خُلق الحُور العِين من الزّعفران{17}. (١٣/٢٩٠) ٧٠١٨٣- عن زيد بن أسلم، قال: إنّ الله لم يخلق الحُور العِين من تراب، إنّما خَلَقهنّ مِن مِسك وكافور وزعفران{18}. (١٣/٢٩٠) ٧٠١٨٤- عن يزيد بن أبي مريم، أنه سأل الحسن، فقال: يا أبا سعيد، ما الحُور العِين؟ قال: عجائزكم هؤلاء الدُّرْدُ{19}! يُنشِئهنّ اللهُ خلْقًا آخر. فقال له يزيد بن أبي مريم: عمَّن يُذكر هذا، يا أبا سعيد؟ قال: فحَسَر الحسنُ عن ذراعيه، ثم قال: حدّثني فلان، وفلان. حتى عدَّ من المهاجرين خمسة، وعدّ من الأنصار أربعة{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد. وذكره سفيان الثوري ص٢٨٣ في تفسيره عند الآية ٢٠ من سورة الطور. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٤٦، المحتسب ٢/٢٦١.أخرجه عبد الرزاق ٢/٢١٠.أخرجه ابن أبي الدنيا في صفة الجنة (٣٠٧).مسائل نافع (٢٤٩). وعزاه السيوطي إلى الطستي.تفسير مجاهد ص٥٩٨، وأخرجه ابن جرير ٢١/٦٥، والفريابي -كما في تغليق التعليق ٤/٣١٠، والفتح ٨/٥٧٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه هناد في الزهد (٢٦). وعزاه السيوطي إلى عبد بن حميد. وأخرجه البيهقي في البعث (٣٥٩) من طريق أبي روق بلفظ: بيض حسان العيون.عزاه السيوطي إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٨-.أخرجه عبد الرزاق ٢/٢١٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٨-.أخرجه ابن جرير ٢١/٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٩٨-، والبيهقي في البعث (٣٩٧).تفسير مقاتل بن سليمان ٣/٨٢٥-٨٢٦.أخرجه الطبراني في الكبير ٨/٢٠٠ (٧٨١٣)، وأبو نعيم في صفة الجنة ٢/٢١٦ (٣٨٣). قال الهيثمي في المجمع ١٠/٤١٩ (١٨٧٦٣): «رواه الطبراني في الكبير، والأوسط، وفي إسنادهما ضعفاء». وقال الألباني في الضعيفة ٨/٣٣ عن إسناد أبي نعيم: «إسناد واهٍ».أخرجه الثعلبي ٩/٢١١. وأورده الديلمي في الفردوس ٢/١٩٢ (٢٩٥٥). قال الألباني في الضعيفة ٨/٣٣-٣٤ (٣٥٤٠): «ضعيف ... فالحديث منكر المتن، وإسناده مظلم».أخرجه أبو نعيم الأصبهاني في صفة الجنة ٢/٢١٨ (٣٨٦) بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٦١-، والثعلبي ٩/١٩٥-١٩٦. قال الألباني في الضعيفة ١٤/٩٣٦ (٦٩٠٣): «ضعيف».أخرجه ابن جرير ٢٢/٣٠٣ في سورة الواقعة، وأخرج مثله عن ليث بن أبي سليم.أخرجه ابن المبارك (١٥٣٧ - زوائد الحسين).الدَّرَد: ذهاب الأسنان. لسان العرب (درد).أخرجه عبد الرزاق ٢/٢١٠.
44,55," <q>﴿یَدۡعُونَ فِیهَا بِكُلِّ فَـٰكِهَةٍ ءَامِنِینَ ۝٥٥﴾</q> - تفسير ٧٠١٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ آمِنِينَ﴾</q>، قال: أمِنوا مِن الموت، والأوصاب، والشيطان{1}٥٩٣١. (١٣/٢٨٩) ٥٩٣١ بيّن ابنُ جرير (٢١/٦٧) أن قوله: <q>﴿آمنين﴾</q> معناه: «آمنين فيها مِن انقطاع تلك النِّعَم عنهم ونفادها وفنائها، ومن غائلة أذاها ومكروهها». ثم ذكر قول قتادة، ولم يعلّق عليه. ٧٠١٨٦- قال مقاتل بن سليمان: <q>﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ﴾</q> مِن ألوان الفاكهة <q>﴿آمِنِينَ﴾</q> من الموت{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٦٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٨٢٥-٨٢٦.
44,56," <q>﴿لَا یَذُوقُونَ فِیهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝٥٦﴾</q> - قراءات ٧٠١٨٧- في قراءة ابن مسعود: (لا يَذُوقُونَ فِيها طَعْمَ المَوْتِ){1}. (١٣/٢٩٢) <q>﴿لَا یَذُوقُونَ فِیهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝٥٦﴾</q> - تفسير الآية ٧٠١٨٨- قال مقاتل بن سليمان: <q>﴿لا يَذُوقُونَ فِيها المَوْتَ﴾</q> أبدًا، <q>﴿إلّا المَوْتَةَ الأُولى﴾</q> التي كانت في الدنيا، <q>﴿ووَقاهُمْ﴾</q> يعني: الرّبّ تعالى <q>﴿عَذابَ الجَحِيمِ﴾</q>{2}٥٩٣٢. (ز) ٥٩٣٢ بيّن ابنُ جرير (٢١/٦٧-٦٩) أن قوله: <q>﴿لا يذوقون فيها إلا الموتة الأولى﴾</q> معناه: «لا يذوق هؤلاء المتّقون في الجنّة الموت بعد الموتة الأولى التي ذاقوها في الدنيا». ثم ذكر عن بعض أهل اللغة أنه وجّه <q>﴿إلا﴾</q> في هذا الموضع إلى أنها بمعنى: سوى. وانتقده مستندًا إلى الأغلب من عادة العرب في كلامها، فقال: «وليس للذي قال مِن ذلك عندي وجه مفهوم؛ لأنّ الأغلب من قول القائل: لا أذوق اليوم الطعام إلا الطعام الذي ذقته قبل اليوم. أنه يريد الخبر عن قائله أن عنده طعامًا في ذلك اليوم ذائقه وطاعمه دون سائر الأطعمة غيره، وإذا كان ذلك الأغلب من معناه وجب أن يكون قد أثبت بقوله: <q>﴿إلا الموتة الأولى﴾</q> موتة مِن نوع الأولى هم ذائقوها، ومعلوم أنّ ذلك ليس كذلك؛ لأن الله ﷿ قد أمَّن أهل الجنة في الجنة إذا هم دخلوها من الموت، ولكن ذلك كما وصفتُ من معناه، وإنما جاز أن توضع <q>﴿إلا﴾</q> في موضع»بعد«لتقارب معنييهما في هذا الموضع». واستدرك ابنُ عطية (٧/٥٨٥) على ابن جرير في انتقاده هذا القول، فقال: «قدّر قوم <q>﴿إلّا﴾</q> بسوى، وضعّف ذلك الطبري، وقدّرها ببعد، وليس تضعيفه بصحيح، بل يصح المعنى بسوى ويَتَّسِق». <q>﴿لَا یَذُوقُونَ فِیهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝٥٦﴾</q> - آثار متعلقة بالآية ٧٠١٨٩- عن أنس بن مالك، عن النبيِّ ﷺ، قال: «يُجاء بالموت يوم القيامة في صورة كبْشٍ أملح، فيُوقَف بين أهل الجنة والنار، فيعرفه هؤلاء، ويعرفه هؤلاء، فيقول أهل النار: اللهم، سلِّطْهُ علينا. ويقول أهل الجنّة: اللهم، إنّك قضيتَ ألّا نذوق فيها الموتَ إلا الموتة الأولى. فيُذبح بينهما، فييأسُ أهلُ النار مِن الموت، ويأمن أهلُ الجنة مِن الموت»{3}. (١٣/٢٩٢) ٧٠١٩٠- عن جابر بن عبد الله، قال: قيل: يا رسول الله، أينام أهل الجنة؟ قال: «لا، النوم أخو الموت، وأهل الجنّة لا يموتون ولا ينامون»{4}. (١٣/٢٩٢) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٣٨.تفسير مقاتل بن سليمان ٣/٨٢٦.عزاه السيوطي إلى ابن مردويه.أخرجه الطبراني في الأوسط ١/٢٨٢ (٩١٩)، وأبو نعيم في صفة الجنة ١/١١٧ (٩٠). قال الهيثمي في المجمع ١٠/٤١٥ (١٨٧٤٠): «رواه الطبراني في الأوسط، والبزار، ورجال البزار رجال الصحيح». وقال السيوطي: «بسند صحيح». وأورده الألباني في الصحيحة ٣/٧٤ (١٠٨٧).
44,57," <q>﴿فَضۡلࣰا مِّن رَّبِّكَۚ ذَ ٰ⁠لِكَ هُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٥٧﴾</q> - تفسير ٧٠١٩١- قال مقاتل بن سليمان: ذلك الذي ذُكِر في الجنة كان: <q>﴿فَضْلًا مِن رَبِّكَ ذلِكَ هُوَ الفَوْزُ العَظِيمُ﴾</q> يعني: الكبير، يعني: النّجاة العظيمة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٢٦.
44,58," <q>﴿فَإِنَّمَا یَسَّرۡنَـٰهُ بِلِسَانِكَ لَعَلَّهُمۡ یَتَذَكَّرُونَ ۝٥٨﴾</q> - تفسير ٧٠١٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</q>: يعني: القرآن{1}. (١٣/٢٩٢) ٧٠١٩٣- قال مقاتل بن سليمان: قوله: <q>﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</q> يعني: القرآن، يقول: هوَّنّاه على لسانك <q>﴿لَعَلَّهُمْ﴾</q> يقول: لكي <q>﴿يَتَذَكَّرُونَ﴾</q> فيؤمنوا بالقرآن، فلم يؤمنوا به{2}. (ز) ٧٠١٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</q>، قال: القرآن. ويسّرناه: أطلَق به لسانه{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٧٠، وعبد بن حميد -كما في تغليق التعليق ٤/٣١٠-٣١١-.تفسير مقاتل بن سليمان ٣/٨٢٦.أخرجه ابن جرير ٢١/٧٠.
44,59," <q>﴿فَٱرۡتَقِبۡ إِنَّهُم مُّرۡتَقِبُونَ ۝٥٩﴾</q> - تفسير ٧٠١٩٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فارْتَقِبْ إنَّهُمْ مُرْتَقِبُونَ﴾</q>: فانتَظِر إنهم مُنتظرون{1}. (١٣/٢٩٢) ٧٠١٩٦- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿فارْتَقِبْ﴾</q> يقول: انتَظِر بهم العذاب، <q>﴿إنَّهُمْ مُرْتَقِبُونَ﴾</q> يعني: مُنتظرون بهم العذاب{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٧١، وعبد بن حميد -كما في تغليق التعليق ٤/٣١٠-٣١١-.تفسير مقاتل بن سليمان ٣/٨٢٦.
