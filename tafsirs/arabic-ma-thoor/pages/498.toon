quran[20]{c,v,t}:
  44,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ یَوۡمَ ٱلۡفَصۡلِ مِیقَـٰتُهُمۡ أَجۡمَعِینَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ مِيقاتُهُمْ أجْمَعِينَ﴾</span>، قال: يوم يُفصل بين الناس بأعمالهم، يومًا وقّته للأولين والآخرين{1}. (١٣/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم، فقال: <span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ﴾</span> يعني: يوم القضاء <span class="qpc-hafs">﴿مِيقاتُهُمْ﴾</span> يعني: ميعادهم <span class="qpc-hafs">﴿يَوْمَ﴾</span> يعني: يوم القيامة، يقول: يوافي يوم القيامة الأولون والآخرون، [وهو]{2} يوم الجمعة، هذه الأمة وسواهم مِن الأمم الخالية{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٢. وعزاه السيوطي إلى عبد بن حميد.|2:في مطبوعة المصدر: وهم.|3:تفسير مقاتل بن سليمان ٣/٨٢٤.
  44,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ لَا یُغۡنِی مَوۡلًى عَن مَّوۡلࣰى شَیۡـࣰٔا وَلَا هُمۡ یُنصَرُونَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٠٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا﴾</span>، قال: ولِيٌّ عن ولِيٍّ{1}. (١٣/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا﴾</span>، قال: انقطعت الأسباب يومئذ، وذهبت الآصار، وصار الناسُ إلى أعمالهم، فمَن أصاب يومئذٍ خيرًا سَعِد به، ومَن أصاب يومئذ شرًّا شَقِي به{2}. (١٣/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نَعتَ الله ذلك اليوم، فقال: <span class="qpc-hafs">﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا﴾</span> وهم الكفار، يقول: يوم لا يغني ولِيٌّ عن وليّه، يقول: لا يقدر قريب لقرابته الكافر شيئًا مِن المنفعة، <span class="qpc-hafs">﴿ولا هُمْ يُنْصَرُونَ﴾</span> يقول: ولا هم يُمنَعون من العذاب{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢١/٥٢ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.|3:تفسير مقاتل بن سليمان ٣/٨٢٤.
  44,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا مَن رَّحِمَ ٱللَّهُۚ إِنَّهُۥ هُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إلّا مَن رَحِمَ اللَّهُ﴾</span> يعني: مِن المؤمنين يشفع بعضهم لبعض؛ فينفعهم ذلك عند الله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى المؤمنين، فقال: <span class="qpc-hafs">﴿إلّا مَن رَحِمَ اللَّهُ﴾</span> من المؤمنين، فإنه يشفع لهم، <span class="qpc-hafs">﴿إنَّهُ هُوَ العَزِيزُ﴾</span> في نِقمته مِن أعدائه الذين لا شفاعة لهم، <span class="qpc-hafs">﴿الرَّحِيمُ﴾</span> بالمؤمنين الذين استثنى في هذه الآية{2}<span class=comment-ref>٥٩٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٢</span> قال <u>ابنُ عطية</u> (٧/٥٨٢): «قوله: <span class="qpc-hafs">﴿ولا هُمْ يُنْصَرُونَ﴾</span> إن كان الضمير يُراد به: العالم، فيصح أن تكون <span class="qpc-hafs">﴿مَن﴾</span> في قوله: <span class="qpc-hafs">﴿إلا من رحم الله﴾</span> في موضع نصب على الاستثناء المتصل. وإن كان الضمير يراد به: الكفار، فالاستثناء منقطع، ويصح أنْ يكون في موضع رفع على الابتداء، والخبر مقدر، تقديره: فإنه يغني بعضهم عن بعض في الشفاعة ونحوها. أو يكون تقديره: فإنّ الله ينصره».</div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٦-.|2:تفسير مقاتل بن سليمان ٣/٨٢٤.
  44,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ شَجَرَتَ ٱلزَّقُّومِ ۝٤٣ طَعَامُ ٱلۡأَثِیمِ ۝٤٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠١١٠<span class="dash">-</span></span> عن أُبي بن كعب، أنّه كان يُقرئ رجلًا فارسيًّا، فكان إذا قرأ عليه: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيمِ﴾</span> قال: طعام اليتيم. فمرّ به النبيُّ ﷺ، فقال: «<b>قلْ له: طعام الظالم</b>». فقالها، ففَصُحَت بها لسانه{1}. (١٣/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١١١<span class="dash">-</span></span> أقرأ <span class="name-1">عبد الله بن مسعود</span> رجلًا: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيمِ﴾</span>، فقال الرجل: طعام اليتيم. فردَّدها عليه، فلم يستقم بها لسانه، فقال: أتستطيع أنْ تقول: طعام الفاجر؟ قال: نعم. قال: فافعل{2}. (١٣/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١١٢<span class="dash">-</span></span> عن همّام بن الحارث، قال: كان <span class="name-1">أبو الدّرداء</span> يُقرئ رجلًا: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيمِ﴾</span>. فجعل الرجل يقول: طعام اليتيم. فلمّا رأى أبو الدّرداء أنّه لا يفهم قال: إنّ شجرة الزّقوم طعام الفاجر{3}<span class=comment-ref>٥٩٢٣</span>. (١٣/٢٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٣</span> ذكر <u>ابنُ عطية</u> (٣/٧٦) أثر أبي الدراداء، وبيّن أنّ هذا منه ﵁ على جهة التفسير، وليست قراءة.</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ شَجَرَتَ ٱلزَّقُّومِ ۝٤٣ طَعَامُ ٱلۡأَثِیمِ ۝٤٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١١٣<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيّ</span>، قال: إنّ أبا جهل كان يأتي بالتّمر والزُّبْد، فيقول: تزقّموا، فهذا الزَّقوم الذي يَعِدُكم به محمد. فنزلتْ: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيم﴾</span>{4}. (١٣/٢٨٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ شَجَرَتَ ٱلزَّقُّومِ ۝٤٣ طَعَامُ ٱلۡأَثِیمِ ۝٤٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيمِ﴾</span>، قال: أبو جهل{5}. (١٣/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span> -من طريق عطاء بن السائب- <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيمِ﴾</span>، قال: الأثيم أبو جهل{6}. (١٣/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿إنَّ شَجَرَةَ الزَّقُّومِ طَعامُ الأَثِيمِ﴾</span>، يعني: الآثم بربّه، فهو أبو جهل بن هشام{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ طَعامُ الأَثِيم﴾</span>، قال: أبو جهل{8}<span class=comment-ref>٥٩٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٤</span> ذكر <u>ابنُ عطية</u> (٧/٥٨٢) قول ابن زيد، ثم قال <span class="comment-type-4">معلّقًا</span>: «ثم هي بالمعنى تتناول كلَّ أثيم، وهو كلّ فاجر يكتسب الإثم».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (١٢/٣٥١) قال: «وذكر غير واحد أنّه أبو جهل، ولا شكّ في دخوله في هذه الآية، ولكن ليست خاصّة به».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ شَجَرَتَ ٱلزَّقُّومِ ۝٤٣ طَعَامُ ٱلۡأَثِیمِ ۝٤٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١١٨<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>أيّها الناس، اتّقوا الله حقّ تُقاته، فلو أنّ قَطرة من الزَّقوم قُطرت على الأرض لأمرَّت على أهل الدنيا معيشتهم، فكيف بمَن تكون طعامه وليس لهم طعام غيره</b>»{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: لو أنّ قَطرة مِن زقُّوم جهنم أُنزلتْ إلى الدنيا لأفسدتْ على الناس معايشهم{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الديلمي -كما في كنز العمال للمتقي الهندي ٢/٦٠٨-٦٠٩ (٤٨٧٤)-. وعزاه السيوطي إلى ابن مردويه.</p><p>وقراءة العشرة <span class="qpc-hafs">﴿طَعامُ الأَثِيمِ﴾</span>، أما (طَعامُ الظّالِمِ) فإن ثبتت قراءة فهي شاذة، وكذلك (طَعامُ الفاجِرِ).|2:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٥٥ (١١٨)، وأبو عبيد في فضائله ص١٨٣، وابن الأنباري -كما في تفسير القرطبي ١٦/١٤٩-. وعزاه السيوطي إلى ابن المنذر. وأورد القراءة مقاتل بن سليمان ٣/٨٢٤.|3:أخرجه ابن جرير ٢١/٥٣-٥٤، والحاكم ٢/٤٥١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|4:عزاه السيوطي إلى سعيد بن منصور.|5:عزاه السيوطي إلى ابن مردويه.|6:أخرجه الخطيب في تاريخه ٦/٢٦٤، ٩/٢٣٩. وعزاه السيوطي إلى ابن أبي حاتم.|7:تفسير مقاتل بن سليمان ٣/٨٢٤.|8:أخرجه ابن جرير ٢١/٥٤.|9:أخرجه أحمد ٤/٤٦٧ (٢٧٣٥)، ٥/٢٣٦ (٣١٣٦)، والترمذي ٤/٥٤١ (٢٧٦٧)، وابن ماجه ٥/٣٧٥-٣٧٦ (٤٣٢٥)، والحاكم ٢/٣٢٢ (٣١٥٨)، وابن حبان ١٦/٥١١ (٧٤٧٠).</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه».|10:أخرجه ابن جرير ٢١/٥٤.
  44,44,"44:43"
  44,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَٱلۡمُهۡلِ یَغۡلِی فِی ٱلۡبُطُونِ ۝٤٥ كَغَلۡیِ ٱلۡحَمِیمِ ۝٤٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠١٢٠<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢١<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، أنهما قرءا: ‹كالمُهْلِ تَغْلِي فِي البُطُونِ› بالتاء{1}. (١٣/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَزين</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٣<span class="dash">-</span></span> و<span class="name-2">إبراهيم</span> أنهما كانا يقرآن: ‹كالمُهْلِ تَغْلِي›، قالا: هي الشّجرة{2}<span class=comment-ref>٥٩٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٥</span> ذكر <u>ابنُ جرير</u> (٢١/٥٨) هذه القراءة، و<span class="comment-type-1">وجّهها</span>، فقال: «قرأته عامة قراء المدينة والبصرة والكوفة ‹تَغْلِي› بالتاء، بمعنى: أنّ شجرة الزّقوم تغلي في بطونهم، فأنّثوا ‹تَغْلِي› لتأنيث الشجرة». ثم ذكر قراءة من قرأ ذلك بالياء، و<span class="comment-type-1">وجّهها</span>، فقال: «وقرأ ذلك بعض قراء أهل الكوفة <span class="qpc-hafs">﴿يغلي﴾</span> بمعنى: طعام الأثيم يغلي، أو المُهل يغلي، فذكَّره بعضهم لتذكير الطعام، ووجَّه معناه إلى أنّ الطعام هو الذي يغلي في بطونهم، وبعضُهم لتذكير المُهل، ووجّهه إلى أنه صفة للمُهل الذي يغلي».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٧/٥٨٣).</p><p>ثم <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> على القراءتين بقوله: «والصواب من القول في ذلك أنهما قراءتان معروفتان صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿كَٱلۡمُهۡلِ یَغۡلِی فِی ٱلۡبُطُونِ ۝٤٥ كَغَلۡیِ ٱلۡحَمِیمِ ۝٤٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٢٤<span class="dash">-</span></span> عن أبي سعيد الخُدري، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿بِماءٍ كالمُهْلِ﴾</span> [الكهف:٢٩]، قال: «<b>كعَكر الزّيت، فإذا قرّبه إلى وجهه سقطتْ فَرْوة وجهه فيه</b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الحسن- <span class="qpc-hafs">﴿كالمُهْلِ يَغْلِي فِي البُطُونِ﴾</span>، أنه سُئِل عن المُهل الذي يقولون يوم القيامة: شراب أهل النار. وهو على بيت المال، قال: فدعا بذهبٍ وفِضّة، فأذابهما، فقال: هذا أشبه شيء في الدنيا بالمُهل الذي هو لون السماء يوم القيامة، وشراب أهل النار، غير أنّ ذلك هو أشد حرًّا من هذا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الحسن- أنه رأى فِضّة قد أُذيبت، فقال: هذا المُهل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- أنه سأله عن قوله: <span class="qpc-hafs">﴿كالمُهْلِ﴾</span>. قال: كَدُرْدِيِّ{6} الزّيت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿كالمُهْلِ﴾</span>، قال: ماء غليظ، كَدُرْدِيِّ الزّيت{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كالمُهْلِ يَغْلِي فِي البُطُونِ﴾</span>، قال: أسْود، كمُهل الزّيت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق يزيد بن أبي سمية- قال: هل تدرون ما المُهل؟ المُهل: مُهل الزّيت. يعني: آخره{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جبير]</span> -من طريق سالم- <span class="qpc-hafs">﴿كالمُهْلِ﴾</span>، قال: كدُردِيِّ الزّيت{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿كالمُهْلِ﴾</span>، قال: أشدُّ ما يكون حرًّا{12}. (٩/٥٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كالمُهْلِ﴾</span> يعني: الزّقُّوم، أسْود غليظ، كَدُرْدِيِّ الزّيت، <span class="qpc-hafs">﴿يَغْلِي فِي البُطُونِ كَغَلْيِ الحَمِيمِ﴾</span> يعني: الماء الحار، بلسان بَربر وأفريقية. الزّقُّوم يعنون: التّمر والزُّبْد، زعم ذلك عبد الله بن الزّبعرى السهمي، وذلك أنّ أبا جهل قال لهم: إنّ محمدًا يزعم أنّ النار تنهت{13} الشّجر، وإنما النار تأكل الشّجر، فما الزَّقُّوم عندكم؟ فقال عبد الله بن الزّبعرى: التّمر والزُّبْد. فقال أبو جهل بن هشام: يا جارية، ابغِنا تمرًا وزُبدًا. فقال: تزقّموا{14}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا ابن كثير، وحفصًا عن عاصم، ورويس؛ فإنهم قرءوا: <span class="qpc-hafs">﴿يَغْلِي﴾</span> بالياء على التذكير. انظر: النشر ٢/٣٧١، والإتحاف ص٥٠٠.|2:أخرجه سعيد بن منصور في سننه -التفسير ٧/٣٢٨ (١٩٦٩).|3:أخرجه أحمد ١٨/٢١٠ (١١٦٧٢)، والترمذي ٤/٥٣٧-٥٣٨ (٢٧٦١)، ٤/٥٣٩-٥٤٠ (٢٧٦٤)، ٥/٥١٦ (٣٦١٠)، والحاكم ٢/٥٤٤ (٣٨٥٠)، وابن حبان ١٦/٥١٤ (٧٤٧٣)، وابن جرير ١٥/٢٥٠، ٢١/٥٧.</p><p>قال الترمذي: «هذا حديث لا نعرفه إلا مِن حديث رشدين بن سعد، ورشدين قد تُكُلِّم فيه مِن قِبَل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».|4:أخرجه ابن جرير ٢١/٥٦. كما أخرج نحوه من طريق عمرو بن ميمون، وقتادة، وعبد الله بن سفيان الأسدي ٢١/٥٦-٥٧.|5:أخرجه ابن جرير ٢١/٥٥.|6:الدُرْدِيّ: أصله ما يَرْكُدُ في أسفل كلِّ مائع، كالأشربة والأدهان. النهاية (درد).|7:أخرجه ابن جرير ٢١/٥٥.|8:أخرجه ابن جرير ٢١/٥٥، وابن أبي حاتم -كما في تغليق التعليق ٤/٣١٠-.|9:أخرجه ابن جرير ٢١/٥٥.|10:أخرجه ابن جرير ٢١/٥٧.|11:أخرجه ابن جرير ٢١/٥٧.|12:عزاه السيوطي في الدر إلى عبد بن حميد، وكذا ابن حجر في الفتح ٨/٥٧٠ بلفظ: هو الذي انتهى حره.|13:كذا في مطبوعة المصدر. ولعلها: تنبت. وجاء في معنى تنهت: تصوت. النهاية (نهت).|14:تفسير مقاتل بن سليمان ٣/٨٢٤-٨٢٥.
  44,46,"44:45"
  44,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خُذُوهُ فَٱعۡتِلُوهُ إِلَىٰ سَوَاۤءِ ٱلۡجَحِیمِ ۝٤٧ ثُمَّ صُبُّوا۟ فَوۡقَ رَأۡسِهِۦ مِنۡ عَذَابِ ٱلۡحَمِیمِ ۝٤٨ ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩﴾</span> - نزول الآيات، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٠١٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، قال: هو أبو جهل بن هشام{1}. (١٣/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس، قال: لقي رسول الله ﷺ أبا جهل، فقال: «<b>إنّ الله أمرني أن أقول لك: <span class="qpc-hafs">﴿أوْلى لَكَ فَأَوْلى ثُمَّ أوْلى لَكَ فَأَوْلى﴾</span></b> [القيامة:٣٤-٣٥]». قال: فنَزع ثوبه مِن يده، وقال: ما تستطيع لي أنت ولا صاحبك مِن شيء، لقد علمتَ أنِّي أمْنعُ أهلَ بطحاء، وأنا العزيز الكريم. فقتَله اللهُ يومَ بدر، وأذلّه، وعيّره بكلمته، وأنزل: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>{2}. (١٣/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٦<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق معمر- قال لما نزلتْ: <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ إلى سَواءِ الجَحِيمِ﴾</span>؛ قال أبو جهل: ما بين جَبليها رجلٌ أعزّ ولا أكرم مني. فقال الله: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>{3}. (١٣/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِن عَذابِ الحَمِيمِ﴾</span>: نزلتْ في عدوِّ الله أبي جهل، لقِيَ النبيَّ ﷺ، فأخذه، فهزّه، ثم قال: «<b>أولى لك -يا أبا جهل- فأولى، ثم أولى لك فأولى، ذُقْ إنك أنتَ العزيز الكريم</b>». وذلك أنه قال: أيوعدني محمد؟! واللهِ، لَأنا أعزُّ مَن مشى بين جَبليها. وفيه نزلتْ: <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا أوْ كَفُورًا﴾</span> [الإنسان:٢٤]، وفيه نزلتْ: <span class="qpc-hafs">﴿كَلّا لا تُطِعْهُ واسْجُدْ واقْتَرِبْ﴾</span> [العلق:١٩]. وقال قتادة: نزلتْ في أبي جهل وأصحابه الذين قتل اللهُ -تبارك وتعالى- يوم بدر: <span class="qpc-hafs">﴿ألَمْ تَرَ إلى الَّذِينَ بَدَّلُوا نِعْمَتَ اللَّهِ كُفْرًا وأَحَلُّوا قَوْمَهُمْ دارَ البَوارِ﴾</span> [إبراهيم:٢٨]{4}. (١٣/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ إلى سَواءِ الجَحِيمِ﴾</span>، قال: هذا لأبي جهل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٣٩<span class="dash">-</span></span> عن عبد الملك، قال: أُخبرتُ: أنّ أبا جهل قال: يا معشر قريش، أخبِروني باسمي. فذَكَرتْ له ثلاثة أسماء: عمرو، والجلاس، وأبو الحكم، قال: ما أصبتم اسمي، ألا أخبركم؟ قالوا: بلى. قال: اسمي: العزيز الكريم. فنزلت: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</span> الآيات{6}. (١٣/٢٨٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿خُذُوهُ فَٱعۡتِلُوهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ﴾</span>، قال: خذوه فاقصفوه كما يُقصف الحطب{7}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ﴾</span>، قال: ادفعوه{8}<span class=comment-ref>٥٩٢٦</span>. (١٣/٢٨٥-٢٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٦</span> لم يذكر <u>ابنُ جرير</u> (٢١/٥٩) غير قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٧٠١٤٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ﴾</span>، قال: خذوه فادفعوه{7}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ﴾</span>، يعني: فَجُرُّوه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿ للخَزنة: <span class="qpc-hafs">﴿خُذُوهُ﴾</span> يعني: أبا جهل، <span class="qpc-hafs">﴿فاعْتِلُوهُ﴾</span> يقول: فادفعوه على وجهه <span class="qpc-hafs">﴿إلى سَواءِ الجَحِيمِ﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤٥<span class="dash">-</span></span> عن <span class="name-3">النضر بن إسماعيل</span> -من طريق فضيل بن عبد الوهاب- قال: إذا قال: <span class="qpc-hafs">﴿خُذُوهُ﴾</span> يبتدره أكثر مِن ربيعة ومُضر{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَىٰ سَوَاۤءِ ٱلۡجَحِیمِ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span>، <span class="qpc-hafs">﴿إلى سَواءِ الجَحِيمِ﴾</span>، قال: وسَط الجحيم{13}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، مثله{6}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿إلى سَواءِ الجَحِيمِ﴾</span>، قال: وسَط الجحيم{7}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلى سَواءِ الجَحِيمِ﴾</span>: إلى وسَط النار{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلى سَواءِ الجَحِيمِ﴾</span> يعني: وسَط الجحيم، وهو الباب السادس من النار{11}<span class=comment-ref>٥٩٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٥٨٣-٥٨٤): «والسواء: الوسط. وقيل: المُعْظَم. وذلك متلازم، المُعْظم أبدًا من مثل هذا إنما هو في الوسط».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ صُبُّوا۟ فَوۡقَ رَأۡسِهِۦ مِنۡ عَذَابِ ٱلۡحَمِیمِ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ﴾</span> أبي جهل، وذلك أنّ الملَك مِن خُزّان جهنم يضربه على رأسه بمقْمعة مِن حديد، فينقب عن دماغه، فيجري دماغه على جسده، ثم يصبّ الملَك في النقْب ماءً حميمًا قد انتهى حَرُّه، فيقع في بطنه{11}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه الأموي في مغازيه -كما في تفسير ابن كثير ٧/٢٤٦-.|3:أخرجه عبد الرزاق ٢/٢٠٩، وابن جرير ٢١/٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه ابن جرير ٢١/٦١. وعزاه السيوطي إلى عبد بن حميد مختصرًا.|5:أخرجه ابن جرير ٢١/٦١.|6:عزاه السيوطي إلى ابن المنذر.|7:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:تفسير مجاهد ص٥٩٨، وأخرجه ابن جرير ٢١/٥٩، والفريابي -كما في تغليق التعليق ٤/٣١٠، والفتح ٨/٥٧٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٦-.|11:تفسير مقاتل بن سليمان ٣/٨٢٥.|12:أخرجه ابن أبي الدنيا في صفة النار ٦/٤٥٢ (٢٤٠).|13:عزاه السيوطي إلى عبد بن حميد.|14:عزاه السيوطي إلى ابن المنذر.|15:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|16:أخرجه ابن جرير ٢١/٦٠.|17:تفسير مقاتل بن سليمان ٣/٨٢٥.|18:تفسير مقاتل بن سليمان ٣/٨٢٥.
  44,48,"44:47"
  44,49,"44:47"
  44,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩ إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، يقول: لستَ بعزيز، ولا كريم{1}. (١٣/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم يقول له المَلك: <span class="qpc-hafs">﴿ذُقْ﴾</span> العذاب، أيها المتعزّز المتكرّم، يوبّخه ويصغّره بذلك، يقول: <span class="qpc-hafs">﴿إنَّكَ﴾</span> زعمت في الدنيا <span class="qpc-hafs">﴿أنْتَ العَزِيزُ﴾</span> يعني: المنيع، <span class="qpc-hafs">﴿الكَرِيمُ﴾</span> يعني: المتكرّم. قال: فكان أبو جهل يقول في الدنيا: أنا أعزّ قريش وأكرمها. فلمّا ذاق شِدّة العذاب في الآخرة قال له المَلك: <span class="qpc-hafs">﴿إنَّ هَذا ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</span> يعني: تشكُّون في الدنيا أنه غير كائن، فهذا مستقرّ الكفار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريج</span>، في قوله: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، قال: هو يومئذ ذليل، ولكن يَستهزئ به، كما كنتَ تُعزّز في الدنيا، وتُكرّم بغير كرم الله وعزّه{3}. (١٣/٢٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِیزُ ٱلۡكَرِیمُ ۝٤٩ إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ۝٥٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥٥<span class="dash">-</span></span> عن أبي هريرة، رفعه: «<b>إنّ الله له ثلاثة أثواب؛ اتَّزر بالعِزَّة، وتَسَرْبَل بالرحمة، وارتدى بالكبرياء، فمَن تعزَّز بغير ما أعزّه الله فذلك الذي يُقال له: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span>، ومَن رحم الناس ﵀، فذلك الذي تسرْبل بِسرْباله الذي ينبغي له، ومَن تكبّر فقد نازع الله رداءه الذي ينبغي له؛ فإنه -تبارك وتعالى- يقول: لا ينبغي لِمَن نازعني أن أُدخِله الجنة</b>»{4}. (١٣/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٦<span class="dash">-</span></span> عن أبي هريرة، عن <span class="name-2">كعب</span> نحوه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٨٢٥.|3:عزاه السيوطي إلى ابن المنذر.|4:أخرجه البيهقي في شعب الإيمان ١٠/٤٦٧ (٧٨١٠)، من طريق بكار بن قتيبة القاضي، عن صفوان بن عيسى، عن ابن عجلان، عن سعيد المقبري، عن أبي هريرة به.</p><p>وسنده ليّن؛ فيه محمد بن عجلان، قال عنه ابن حجر في تقريب التهذيب (٦١٣٦): «صدوق، إلا أنه اختلطت عليه أحاديث أبي هريرة».|5:أخرجه ابن جرير ٢١/٦٢.
  44,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی مَقَامٍ أَمِینࣲ ۝٥١ فِی جَنَّـٰتࣲ وَعُیُونࣲ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿مَقامٍ أمِينٍ﴾</span>، قال: أمِنوا الموت أن يموتوا، وأمِنوا الهَرَم أن يَهْرموا، ولا يجوعوا، ولا يعْروا{1}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span>، قال: أمين مِن الشيطان، والأوصاب، والأحزان{2}<span class=comment-ref>٥٩٢٨</span>. (١٣/٢٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٨</span> لم يذكر <u>ابنُ جرير</u> (٢١/٦٤) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٧٠١٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر مُستقر المؤمنين، فقال: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span> في مساكن، آمنين مِن الخوف والموت، <span class="qpc-hafs">﴿فِي جَنّاتٍ وعُيُونٍ﴾</span> يعني: بساتين، وأنهار جارية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span>، قال: أمِنوا الموت والعذاب{4}. (١٣/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦١<span class="dash">-</span></span> عن الوليد، قال: قال <span class="name-3">زهير بن محمد</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي مَقامٍ أمِينٍ﴾</span>، قال: أمِنوا فيه مِن الموت{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٤٥ (٣٦٦٤٦).|2:أخرجه ابن جرير ٢١/٦٤. وعزاه السيوطي إلى عبد بن حميد.|3:تفسير مقاتل بن سليمان ٣/٨٢٥.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن أبي الدنيا في ذكر الموت ٥/٤٩٩ (٣١٧).
  44,52,"44:51"
  44,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَلۡبَسُونَ مِن سُندُسࣲ وَإِسۡتَبۡرَقࣲ مُّتَقَـٰبِلِینَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٦٢<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: <span class="qpc-hafs">﴿يَلْبَسُونَ مِن سُندُسٍ وإسْتَبْرَقٍ﴾</span> في الجنّة شجر تُنبِت الإستبرق والحرير، منه يكون لباس أهل الجنّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</span>، قال: الإستبرق: الدِّيباج الغليظ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</span> هما جميعًا حرير{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَلْبَسُونَ مِن سُندُسٍ وإسْتَبْرَقٍ﴾</span> يعني: الدِّيباج <span class="qpc-hafs">﴿مُتَقابِلِينَ﴾</span> في الزيارة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٨-.|2:أخرجه ابن جرير ٢١/٦٤.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٧-.|4:تفسير مقاتل بن سليمان ٣/٨٢٥.
  44,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ ۝٥٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠١٦٦<span class="dash">-</span></span> عن قتادة، قال: في حرف <span class="name-1">ابن مسعود</span>: (بعِيسٍ عِينٍ){1}<span class=comment-ref>٥٩٢٩</span>. (١٣/٢٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٢٩</span> ذكر <u>ابنُ عطية</u> (٧/٥٨٥) قراءة ابن مسعود، و<span class="comment-type-4">علّق</span> عليها فقال: «وقرأ ابن مسعود: (عِيسٍ)، وهو جمع عيساء، وهي أيضًا البيضاء، وكذلك هي من النوق».</div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ ۝٥٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٦٧<span class="dash">-</span></span> قال <span class="name-1">أبو هُريرة</span>: <span class="qpc-hafs">﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</span> لَسْنَ مِن نساء الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، قال: لشَفر المرأةِ أطولُ مِن جناح النّسر{3}. (١٣/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿وحُورٌ عِينٌ﴾</span>. قال: الحَوراء: البيضاء المُنعَّمة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الأعشى وهو يقول:</p><p>وحورٌ كأمثال الدُّمى ومناصفٌ وماءٌ وريحانٌ وراحٌ يصفِّق؟{4}. (١٣/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</span>، قال: أنكحناهم حُورًا، والحُور التي يُحار فيها الطرْف باديًا، يُرى مخّ سُوقهن مِن وراء ثيابهنّ، ويَرى الناظر وجهَه في كبِد إحداهن كالمرآة مِن رقّة الجلد وصفاء اللون{5}<span class=comment-ref>٥٩٣٠</span>. (١٣/٢٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٠</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٢١/٦٥-٦٦) -<span class="mustanad">مستندًا إلى اللغة</span>، <span class="mustanad">وأقوال السلف، والقراءات</span>- قول مجاهد، فقال: «وهذا الذي قاله مجاهد مِن أنّ الحُور إنما معناها: أنه يحار فيها الطرف. قول لا معنى له في كلام العرب؛ لأنّ الحور إنما هو جمع حوراء، كالحمر جمع حمراء، والسود: جمع سوداء، والحوراء إنما هي فعلاء من الحور، وهو نقاء البياض، كما قيل للنقي البياض من الطعام: الحواري. وقد بيَّنا معنى ذلك بشواهده فيما مضى قبل، وبنحو الذي قلنا في معنى ذلك قال سائر أهل التأويل». وذكر أقوال السلف الدالة على أنّ الحَوراء هي البيضاء النقية، واستدل كذلك بقراءة ابن مسعود الواردة بالآثار على ضعف قول مجاهد، حيث قال عقب ذكره لها: "وقرأ ابن مسعود هذه، يعني: أن معنى الحُور غير الذي ذهب إليه مجاهد؛ لأن العيس عند العرب جمع عيساء، وهي البيضاء من الإبل، كما قال الأعشى:</p><p>ومَهْمَهٍ نازِحٍ تَعْوِي الذّئاب به كَلَّفْتُ أعْيَسَ تَحْت الرَّحْل نَعّابا</p><p>يعني بالأعيس: جملًا أبيض".</p><p>وذكر <u>ابنُ القيم</u> (٢/٤٤٣) قول مجاهد، ثم <span class="comment-type-4">علّق</span> بقوله: «وهذا من الاتفاق، وليست اللفظة مُشتقّة من الحيرة». ثم <span class="comment-type-3">رجّح</span> أن الحُور: «مأخوذ مِن الحَور في العين، وهو شدة بياضها مع قوة سوادها، فهو يتضمن الأمرين، وأن العِين هنّ اللائي جمعتْ أعينهنّ صفات الحُسن والملاحة».</div></p><p><div></p><p><p><span class="item-no">٧٠١٧١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿بِحُورٍ عِينٍ﴾</span>، قال: الحُور: البيض. والعِين: العِظام الأعين{6}. (١٣/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</span>، قال: هي لغة يمانية؛ وذلك أنّ أهل اليمن يقولون: زوّجنا فلانًا بفلانة{7}. (١٣/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿كَذَلِكَ وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</span>، أي: كذلك حكم الله لأهل الجنة بهذا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر، عمن سمع الحسن- يقول: <span class="qpc-hafs">﴿كَذَلِكَ وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</span> الحُور العِين مِن نساء الدنيا، يُنشئهن الله خَلْقًا آخر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٥<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿بِحُورٍ عِينٍ﴾</span> الحُور: البيض. والعِين: عِظام العيون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وزَوَّجْناهُمْ بِحُورٍ عِينٍ﴾</span>، قال: بِيض عِين. قال: وفي قراءة ابن مسعود (بِعِيسٍ عِينٍ){11}. (١٣/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- في قوله: <span class="qpc-hafs">﴿بِحُورٍ عِينٍ﴾</span>، قال: سُود الحَدَقة، عظيمة العين{12}. (١٣/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ وزَوَّجْناهُمْ بِحُورٍ﴾</span> يعني: بِيض الوجوه <span class="qpc-hafs">﴿عِينٍ﴾</span> يعني: حِسان العيون، ثم أخبر عنهم، فقال: <span class="qpc-hafs">﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ﴾</span>{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ ۝٥٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٧٩<span class="dash">-</span></span> عن أبي أمامة، قال: قال رسول الله ﷺ: «<b>خُلق الحُور العِين من الزّعفران</b>»{14}. (١٣/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٨٠<span class="dash">-</span></span> عن عائشة، قالت: قال رسول الله ﷺ: «<b>حُور العِين خُلِقْن من تسبيح الملائكة</b>»{15}. (١٣/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٨١<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>لو أنّ حَوراء بَزَقَتْ في بحر لُجِّيٍّ لَعَذُب ذلك البحر مِن عذوبة ريقها</b>»{16}. (١٣/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: خُلق الحُور العِين من الزّعفران{17}. (١٣/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٨٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، قال: إنّ الله لم يخلق الحُور العِين من تراب، إنّما خَلَقهنّ مِن مِسك وكافور وزعفران{18}. (١٣/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٨٤<span class="dash">-</span></span> عن يزيد بن أبي مريم، أنه سأل <span class="name-2">الحسن</span>، فقال: يا أبا سعيد، ما الحُور العِين؟ قال: عجائزكم هؤلاء الدُّرْدُ{19}! يُنشِئهنّ اللهُ خلْقًا آخر. فقال له يزيد بن أبي مريم: عمَّن يُذكر هذا، يا أبا سعيد؟ قال: فحَسَر الحسنُ عن ذراعيه، ثم قال: حدّثني فلان، وفلان. حتى عدَّ من المهاجرين خمسة، وعدّ من الأنصار أربعة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد. وذكره سفيان الثوري ص٢٨٣ في تفسيره عند الآية ٢٠ من سورة الطور.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٤٦، المحتسب ٢/٢٦١.|2:أخرجه عبد الرزاق ٢/٢١٠.|3:أخرجه ابن أبي الدنيا في صفة الجنة (٣٠٧).|4:مسائل نافع (٢٤٩). وعزاه السيوطي إلى الطستي.|5:تفسير مجاهد ص٥٩٨، وأخرجه ابن جرير ٢١/٦٥، والفريابي -كما في تغليق التعليق ٤/٣١٠، والفتح ٨/٥٧٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه هناد في الزهد (٢٦). وعزاه السيوطي إلى عبد بن حميد. وأخرجه البيهقي في البعث (٣٥٩) من طريق أبي روق بلفظ: بيض حسان العيون.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٨-.|9:أخرجه عبد الرزاق ٢/٢١٠.|10:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٠٨-.|11:أخرجه ابن جرير ٢١/٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|12:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٩٨-، والبيهقي في البعث (٣٩٧).|13:تفسير مقاتل بن سليمان ٣/٨٢٥-٨٢٦.|14:أخرجه الطبراني في الكبير ٨/٢٠٠ (٧٨١٣)، وأبو نعيم في صفة الجنة ٢/٢١٦ (٣٨٣).</p><p>قال الهيثمي في المجمع ١٠/٤١٩ (١٨٧٦٣): «رواه الطبراني في الكبير، والأوسط، وفي إسنادهما ضعفاء». وقال الألباني في الضعيفة ٨/٣٣ عن إسناد أبي نعيم: «إسناد واهٍ».|15:أخرجه الثعلبي ٩/٢١١. وأورده الديلمي في الفردوس ٢/١٩٢ (٢٩٥٥).</p><p>قال الألباني في الضعيفة ٨/٣٣-٣٤ (٣٥٤٠): «ضعيف ... فالحديث منكر المتن، وإسناده مظلم».|16:أخرجه أبو نعيم الأصبهاني في صفة الجنة ٢/٢١٨ (٣٨٦) بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٦١-، والثعلبي ٩/١٩٥-١٩٦.</p><p>قال الألباني في الضعيفة ١٤/٩٣٦ (٦٩٠٣): «ضعيف».|17:أخرجه ابن جرير ٢٢/٣٠٣ في سورة الواقعة، وأخرج مثله عن ليث بن أبي سليم.|18:أخرجه ابن المبارك (١٥٣٧ - زوائد الحسين).|19:الدَّرَد: ذهاب الأسنان. لسان العرب (درد).|20:أخرجه عبد الرزاق ٢/٢١٠.
  44,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَدۡعُونَ فِیهَا بِكُلِّ فَـٰكِهَةٍ ءَامِنِینَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ آمِنِينَ﴾</span>، قال: أمِنوا مِن الموت، والأوصاب، والشيطان{1}<span class=comment-ref>٥٩٣١</span>. (١٣/٢٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣١</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢١/٦٧) أن قوله: <span class="qpc-hafs">﴿آمنين﴾</span> معناه: «آمنين فيها مِن انقطاع تلك النِّعَم عنهم ونفادها وفنائها، ومن غائلة أذاها ومكروهها». ثم ذكر قول قتادة، ولم يعلّق عليه.</div></p><p><div></p><p><p><span class="item-no">٧٠١٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ﴾</span> مِن ألوان الفاكهة <span class="qpc-hafs">﴿آمِنِينَ﴾</span> من الموت{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٦٧. وعزاه السيوطي إلى عبد بن حميد.|2:تفسير مقاتل بن سليمان ٣/٨٢٥-٨٢٦.
  44,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَذُوقُونَ فِیهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝٥٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠١٨٧<span class="dash">-</span></span> في قراءة <span class="name-1">ابن مسعود</span>: (لا يَذُوقُونَ فِيها طَعْمَ المَوْتِ){1}. (١٣/٢٩٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یَذُوقُونَ فِیهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝٥٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها المَوْتَ﴾</span> أبدًا، <span class="qpc-hafs">﴿إلّا المَوْتَةَ الأُولى﴾</span> التي كانت في الدنيا، <span class="qpc-hafs">﴿ووَقاهُمْ﴾</span> يعني: الرّبّ تعالى <span class="qpc-hafs">﴿عَذابَ الجَحِيمِ﴾</span>{2}<span class=comment-ref>٥٩٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٢</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢١/٦٧-٦٩) أن قوله: <span class="qpc-hafs">﴿لا يذوقون فيها إلا الموتة الأولى﴾</span> معناه: «لا يذوق هؤلاء المتّقون في الجنّة الموت بعد الموتة الأولى التي ذاقوها في الدنيا». ثم ذكر عن بعض أهل اللغة أنه وجّه <span class="qpc-hafs">﴿إلا﴾</span> في هذا الموضع إلى أنها بمعنى: سوى. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الأغلب من عادة العرب في كلامها</span>، فقال: «وليس للذي قال مِن ذلك عندي وجه مفهوم؛ لأنّ الأغلب من قول القائل: لا أذوق اليوم الطعام إلا الطعام الذي ذقته قبل اليوم. أنه يريد الخبر عن قائله أن عنده طعامًا في ذلك اليوم ذائقه وطاعمه دون سائر الأطعمة غيره، وإذا كان ذلك الأغلب من معناه وجب أن يكون قد أثبت بقوله: <span class="qpc-hafs">﴿إلا الموتة الأولى﴾</span> موتة مِن نوع الأولى هم ذائقوها، ومعلوم أنّ ذلك ليس كذلك؛ لأن الله ﷿ قد أمَّن أهل الجنة في الجنة إذا هم دخلوها من الموت، ولكن ذلك كما وصفتُ من معناه، وإنما جاز أن توضع <span class="qpc-hafs">﴿إلا﴾</span> في موضع»بعد«لتقارب معنييهما في هذا الموضع».</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٧/٥٨٥) على ابن جرير في انتقاده هذا القول، فقال: «قدّر قوم <span class="qpc-hafs">﴿إلّا﴾</span> بسوى، وضعّف ذلك الطبري، وقدّرها ببعد، وليس تضعيفه بصحيح، بل يصح المعنى بسوى ويَتَّسِق».</div></p><p><h3><span class="qpc-hafs">﴿لَا یَذُوقُونَ فِیهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝٥٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٠١٨٩<span class="dash">-</span></span> عن أنس بن مالك، عن النبيِّ ﷺ، قال: «<b>يُجاء بالموت يوم القيامة في صورة كبْشٍ أملح، فيُوقَف بين أهل الجنة والنار، فيعرفه هؤلاء، ويعرفه هؤلاء، فيقول أهل النار: اللهم، سلِّطْهُ علينا. ويقول أهل الجنّة: اللهم، إنّك قضيتَ ألّا نذوق فيها الموتَ إلا الموتة الأولى. فيُذبح بينهما، فييأسُ أهلُ النار مِن الموت، ويأمن أهلُ الجنة مِن الموت</b>»{3}. (١٣/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٩٠<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قيل: يا رسول الله، أينام أهل الجنة؟ قال: «<b>لا، النوم أخو الموت، وأهل الجنّة لا يموتون ولا ينامون</b>»{4}. (١٣/٢٩٢)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٣٨.|2:تفسير مقاتل بن سليمان ٣/٨٢٦.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه الطبراني في الأوسط ١/٢٨٢ (٩١٩)، وأبو نعيم في صفة الجنة ١/١١٧ (٩٠).</p><p>قال الهيثمي في المجمع ١٠/٤١٥ (١٨٧٤٠): «رواه الطبراني في الأوسط، والبزار، ورجال البزار رجال الصحيح». وقال السيوطي: «بسند صحيح». وأورده الألباني في الصحيحة ٣/٧٤ (١٠٨٧).
  44,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَضۡلࣰا مِّن رَّبِّكَۚ ذَ ٰ⁠لِكَ هُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ذلك الذي ذُكِر في الجنة كان: <span class="qpc-hafs">﴿فَضْلًا مِن رَبِّكَ ذلِكَ هُوَ الفَوْزُ العَظِيمُ﴾</span> يعني: الكبير، يعني: النّجاة العظيمة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٢٦.
  44,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنَّمَا یَسَّرۡنَـٰهُ بِلِسَانِكَ لَعَلَّهُمۡ یَتَذَكَّرُونَ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</span>: يعني: القرآن{1}. (١٣/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</span> يعني: القرآن، يقول: هوَّنّاه على لسانك <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> يقول: لكي <span class="qpc-hafs">﴿يَتَذَكَّرُونَ﴾</span> فيؤمنوا بالقرآن، فلم يؤمنوا به{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</span>، قال: القرآن. ويسّرناه: أطلَق به لسانه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٧٠، وعبد بن حميد -كما في تغليق التعليق ٤/٣١٠-٣١١-.|2:تفسير مقاتل بن سليمان ٣/٨٢٦.|3:أخرجه ابن جرير ٢١/٧٠.
  44,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱرۡتَقِبۡ إِنَّهُم مُّرۡتَقِبُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠١٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فارْتَقِبْ إنَّهُمْ مُرْتَقِبُونَ﴾</span>: فانتَظِر إنهم مُنتظرون{1}. (١٣/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿فارْتَقِبْ﴾</span> يقول: انتَظِر بهم العذاب، <span class="qpc-hafs">﴿إنَّهُمْ مُرْتَقِبُونَ﴾</span> يعني: مُنتظرون بهم العذاب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٧١، وعبد بن حميد -كما في تغليق التعليق ٤/٣١٠-٣١١-.|2:تفسير مقاتل بن سليمان ٣/٨٢٦.