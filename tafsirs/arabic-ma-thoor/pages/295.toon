tafsir[5]{c,v,t}:
18,16," <q>﴿وَإِذِ ٱعۡتَزَلۡتُمُوهُمۡ وَمَا یَعۡبُدُونَ إِلَّا ٱللَّهَ﴾</q> - تفسير الآية، وقراءات فيها ٤٤٤٨٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذِ اعْتَزَلْتُمُوهُمْ وما يَعْبُدُونَ إلّا اللَّهَ﴾</q>، قال: هي في مصحف ابن مسعود: (وما يَعْبُدُونَ مِن دُونِ اللهِ). فهذا تفسيرها{1}٣٩٧٢. (٩/٥٠٦) ٣٩٧٢ علَّق ابنُ عطية (٥/٥٧٧) على قول قتادة بقوله: «فعلى ما قال قتادة تكون <q>﴿إلّا﴾</q> بمنزلة: غير، و<q>﴿ما﴾</q> من قوله: <q>﴿وما يَعْبُدُونَ﴾</q> في موضع نصب عطفًا على الضمير في قوله: <q>﴿اعْتَزَلْتُمُوهُمْ﴾</q>». ٤٤٤٨٧- عن عطاء الخراساني، في قوله: <q>﴿وإذِ اعْتَزَلْتُمُوهُمْ وما يَعْبُدُونَ إلّا اللَّهَ﴾</q>، قال: كان قومُ الفتيةِ يعبدون الله، ويعبدون معه آلهة شتّى، فاعتزلت الفتية عبادة تلك الآلهة، ولم تعتزل عبادة الله{2}. (٩/٥٠٦) ٤٤٤٨٨- قال مقاتل بن سليمان: ثم قال الفتية بعضهم لبعض: <q>﴿وإذِ اعْتَزَلْتُمُوهُمْ وما يَعْبُدُونَ﴾</q> من دون الله من الآلهة، ثم استثنوا، فقالوا: <q>﴿إلّا اللَّهَ﴾</q> فلا تعتزلوا معرفته، لأنّهم عرفوا أنّ الله تعالى ربهم، وهو خلقهم، وخلق الأشياء كلها{3}. (ز) ٤٤٤٨٩- قال يحيى بن سلّام: قال: <q>﴿وإذِ اعْتَزَلْتُمُوهُمْ﴾</q> يقوله بعضهم لبعض، <q>﴿وما يَعْبُدُونَ إلّا اللَّهَ﴾</q> أي: وما يعبدون من دون الله، أي: وما يعبدون سوى الله{4}٣٩٧٣. (ز) ٣٩٧٣ قال ابنُ عطية (٥/٥٧٦): «وقولهم: <q>﴿وإذِ اعْتَزَلْتُمُوهُمْ﴾</q> الآية، إن كان»القيام«في قوله: <q>﴿إذْ قامُوا﴾</q> عزمًا -كما تضمن التأويل الواحد، وكان القول منهم فيما بينهم- فهذه المقالة يصح أن تكون من قولهم الذي قالوه عند قيامهم؛ وإن كان»القيام«المذكور مقامهم بين يدي الملك؛ فهذه المقالة لا تترتب أن تكون من مقالهم بين يدي الملك، بل يكون في الكلام حذف، تقديره: وقال بعضهم لبعض. وبهذا يترجح أن قوله تعالى: <q>﴿إذْ قامُوا فَقالُوا﴾</q> إنما المراد به: إذ عزموا ونفذوا لأمرهم». <q>﴿فَأۡوُۥۤا۟ إِلَى ٱلۡكَهۡفِ﴾</q> - تفسير ٤٤٤٩٠- عن مجاهد بن جبر، في قوله: <q>﴿فأووا إلى الكهف﴾</q>، قال: كان كهفُهم بين جبلين{5}. (٩/٥٠٦) ٤٤٤٩١- قال مقاتل بن سليمان: ثم قال بعضهم لبعض: <q>﴿فأووا إلى الكهف﴾</q>، يعني: انتهوا إلى الكهف. كقوله سبحانه: <q>﴿إذ أوينا إلى الصخرة﴾</q> [الكهف:٦٣]{3}. (ز) ٤٤٤٩٢- قال يحيى بن سلّام: <q>﴿فأووا إلى الكهف﴾</q>، يعني: فانتهوا إلى الكهف{4}. (ز) <q>﴿یَنشُرۡ لَكُمۡ رَبُّكُم مِّن رَّحۡمَتِهِۦ﴾</q> - تفسير ٤٤٤٩٣- قال مقاتل بن سليمان: <q>﴿ينشر لكم﴾</q> يعني: يبسط لكم <q>﴿ربكم من رحمته﴾</q> رِزْقًا{3}. (ز) ٤٤٤٩٤- قال يحيى بن سلّام: <q>﴿ينشر لكم ربكم﴾</q>، يعني: يبسط لكم ربُّكم{4}. (ز) <q>﴿وَیُهَیِّئۡ لَكُم مِّنۡ أَمۡرِكُم مِّرۡفَقࣰا ۝١٦﴾</q> - تفسير ٤٤٤٩٥- عن إسماعيل السدي، في قوله: <q>﴿ويهيئ لكم من أمركم مرفقا﴾</q>، يقول: غداء{5}. (٩/٥٠٧) ٤٤٤٩٦- قال مقاتل بن سليمان: <q>﴿ويهيئ لكم من أمركم مرفقا﴾</q>، يعني: ما يرفق بكم؛ فهيَّأ الله لكم الرقود في الغار. فكان هذا مِن قول الفتية{3}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/١٧٤، وابن جرير ١٥/١٨٢. وعزاه السيوطي إلى ابن أبي حاتم. و(مِن دُونِ اللهِ) قراءة شاذة، وقراءة العشرة <q>﴿إلّا اللَّهَ﴾</q>. ينظر: البحر المحيط ٦/١٠٣.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٧٧.تفسير يحيى بن سلام ١/١٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٧٧.تفسير يحيى بن سلام ١/١٧٤.تفسير مقاتل بن سليمان ٢/٥٧٧.تفسير يحيى بن سلام ١/١٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٧٧.
18,17," <q>﴿وَتَرَى ٱلشَّمۡسَ إِذَا طَلَعَت تَّزَ ٰ⁠وَرُ عَن كَهۡفِهِمۡ ذَاتَ ٱلۡیَمِینِ﴾</q> - قراءات ٤٤٤٩٧- عن حاتم بن ورْدانَ، قال: سمعت أيوب السختياني يقرأ: ‹تَزْوَرُّ عَن كَهْفِهِمْ›{1}. (ز) <q>﴿وَتَرَى ٱلشَّمۡسَ إِذَا طَلَعَت تَّزَ ٰ⁠وَرُ عَن كَهۡفِهِمۡ ذَاتَ ٱلۡیَمِینِ﴾</q> - تفسير الآية ٤٤٤٩٨- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿تزاور﴾</q>، قال: تميل{2}. (٩/٥٠٧) ٤٤٤٩٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لو أنّ الشمس تطلع عليهم لأحرقتهم، ولو أنهم لا يُقَلَّبُون لأكلتهم الأرض. قال: وذلك قوله: <q>﴿وترى الشمس إذا طلعت تزاور عن كهفهم ذات اليمين وإذا غربت تقرضهم ذات الشمال﴾</q>{3}. (ز) ٤٤٥٠٠- عن سعيد بن جبير -من طريق سالم الأفطس- قال: <q>﴿وترى الشمس إذا طلعت تزاور عن كهفهم ذات اليمين﴾</q>، قال: تميل{4}. (ز) ٤٤٥٠١- قال الحسن البصري: لا تدخل الشمس كهفَهم على حال{5}. (ز) ٤٤٥٠٢- عن قتادة بن دعامة -من طريق معمر- قوله: <q>﴿تزاور عن كهفهم ذات اليمين﴾</q>، قال: تميل عن كهفهم ذات اليمين{6}. (ز) ٤٤٥٠٣- عن محمد بن السائب الكلبي -من طريق سفيان- في قوله: <q>﴿تزاور عن كهفهم ذات اليمين وإذا غربت تقرضهم ذات الشمال﴾</q>، قال: تتركهم ذات الشمال. قال: وباب الكهف مستقبل بَنات نَعْشٍ{7}{8}. (ز) ٤٤٥٠٤- قال مقاتل بن سليمان: يقول الله -تبارك وتعالى-: <q>﴿وترى الشمس إذا طلعت تزاور عن كهفهم﴾</q> يعني: تميل عن كهفهم فتدعهم <q>﴿ذات اليمين﴾</q>{9}. (ز) ٤٤٥٠٥- قال يحيى بن سلام: <q>﴿وترى الشمس إذا طلعت تزاور عن كهفهم﴾</q>: تَعْدِل عن كهفهم{10}. (ز) <q>﴿وَإِذَا غَرَبَت تَّقۡرِضُهُمۡ ذَاتَ ٱلشِّمَالِ﴾</q> - تفسير ٤٤٥٠٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿تقرضهم﴾</q>، قال: تَذَرُهم{11}. (٩/٥٠٧) ٤٤٥٠٧- عن سعيد بن جبير -من طريق سالم- <q>﴿وإذا غربت تقرضهم﴾</q> قال: تتركهم <q>﴿ذات الشمال﴾</q>{12}. (ز) ٤٤٥٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تقرضهم﴾</q>، قال: تتركهم{13}. (٩/٥٠٧) ٤٤٥٠٩- عن قتادة بن دعامة -من طريق معمر- قوله: <q>﴿تقرضهم ذات الشمال﴾</q>، قال: تدعهم ذات الشمال{14}. (ز) ٤٤٥١٠- قال مقاتل بن سليمان: <q>﴿وإذا غربت﴾</q> الشمس <q>﴿تقرضهم﴾</q> يعني: تدعهم <q>﴿ذات الشمال﴾</q>{9}٣٩٧٤. (ز) ٣٩٧٤ على هذا القول فالشمس لا تصيبهم ألبتة، وهو ما علَّق ابنُ عطية (٥/٥٧٩) عليه بقوله: «كأنها عنده تقطع كلّ ما لا تناله عن نفسها». ثم ذكر أن هناك فرقة مـِمَّن قرأ <q>﴿تقرضهم﴾</q> بالتاء تأول أن الشمس كانت بالعشي تنالهم، فكأنها تقرضهم، أي: تقتطعهم مما لا تناله، ونقل عنهم أنهم قالوا: كان في مسها لهم بالعشي صلاح لأجسامهم. وبيَّن (٥/٥٨٩-٥٩٠) أن قوله <q>﴿ذات اليمين وذات الشمال﴾</q> يحتمل احتمالين: الأول: أن يريد: ذات يمين الكهف بأن نقدر باب الكهف بمثابة وجه إنسان فإن الشمس تجيء منه أول النهار عن يمين، وآخره عن شمال. الثاني: ويحتمل أن يريد: ذات يمين الشمس وذات شمالها، بأن نقدر الشعاع الممتد منها إلى الكهف بمثابة وجه إنسان. ورجَّح الاحتمالَ الأول، فقال: «والوجه الأول أصح». ولم يذكر مستندًا. ٤٤٥١١- عن مقاتل بن حيان، في قوله: <q>﴿تقرضهم﴾</q>، قال: تُجاوِزهم{16}. (ز) <q>﴿وَهُمۡ فِی فَجۡوَةࣲ مِّنۡهُۚ﴾</q> - تفسير ٤٤٥١٢- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿وهم في فجوة منه﴾</q>، قال: يعني بالفجوة: الخلوة من الأرض. ويعني بالخلوة: الناحية من الأرض{17}. (٩/٥٠٧) ٤٤٥١٣- عن سعيد بن جبير -من طريق سالم الأفطس- <q>﴿وهم في فجوة منه﴾</q>، قال: المكان الواسع{18}. (ز) ٤٤٥١٤- عن سعيد بن جبير -من طريق سالم الأفطس- <q>﴿وهم في فجوة منه﴾</q>، قال: المكان الداخل{19}. (ز) ٤٤٥١٥- عن مجاهد بن جبر، في قوله: <q>﴿وهم في فجوة منه﴾</q>، قال: المكان الداخل{13}. (٩/٥٠٧) ٤٤٥١٦- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿وهم في فجوة منه﴾</q>، قال: المكان الذاهب{21}. (ز) ٤٤٥١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهم في فجوة منه﴾</q>، قال: كهف الفتية بين جبلين{22}. (ز) ٤٤٥١٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وهم في فجوة منه﴾</q> يقول: في فضاء من الكهف، قال الله: <q>﴿ذلك من آيات الله﴾</q>{23}. (ز) ٤٤٥١٩- عن أبي مالك غزوان الغفاري، في قوله: <q>﴿وهم في فجوة منه﴾</q>، قال: ناحية{24}. (٩/٥٠٧) ٤٤٥٢٠- قال مقاتل بن سليمان: <q>﴿وهم في فجوة منه﴾</q>، يعني: في زاوية من الكهف{25}. (ز) <q>﴿ذَ ٰ⁠لِكَ مِنۡ ءَایَـٰتِ ٱللَّهِۗ﴾</q> - تفسير ٤٤٥٢١- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> يعني: هذا الذي ذكر مِن أمر الفتية <q>﴿من آيات الله﴾</q> يعني: مِن علامات الله وصُنعِه{25}. (ز) ٤٤٥٢٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وهم في فجوة منه﴾</q>، قال: أي: في فضاء من الكهف. وتلك آية{27}. (ز) <q>﴿مَن یَهۡدِ ٱللَّهُ فَهُوَ ٱلۡمُهۡتَدِۖ وَمَن یُضۡلِلۡ فَلَن تَجِدَ لَهُۥ وَلِیࣰّا مُّرۡشِدࣰا ۝١٧﴾</q> - تفسير ٤٤٥٢٣- قال مقاتل بن سليمان: <q>﴿من يهد الله﴾</q> لدينه <q>﴿فهو المهتد ومن يضلل﴾</q> عن دينه الإسلام <q>﴿فلن تجد له وليا﴾</q> يعني: صاحبًا <q>﴿مرشدا﴾</q> يعني: يرشده إلى الهُدى؛ لأن وليه مثله في الضلالة{25}. (ز) ",footnotes:1:أخرجه ابن الأعرابي في معجمه ١/٣٩٥ (٧٥٥). وهي قراءة متواترة، قرأ بها ابن عامر، ويعقوب، وقرأ حمزة، والكسائي، وعاصم، وخلف العاشر: <q>﴿تَزاوَرُ﴾</q> بفتح الزاي وتخفيفها وألف بعدها، وقرأ بقية العشرة: <q>﴿تَزّاوَرُ﴾</q> بفتح الزاي وتشديدها وألف بعدها. انظر: النشر ٢/٣١٠، والإتحاف ص٣٦٤.أخرجه ابن جرير ١٥/١٨٥، ١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وينظر: الإتقان ٢/٢٥.أخرجه ابن جرير ١٥/١٨٦.أخرجه ابن جرير ١٥/١٨٥.علقه يحيى بن سلام ١/١٧٥.أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/١٨٦. وعلقه يحيى بن سلام ١/١٧٤ وزاد: <q>﴿ذات اليمين﴾</q>: تدعهم ذات اليمين.بَناتُ نَعْشٍ: سبعة كواكب. لسان العرب (نعش).أخرجه إسحاق البستي في تفسيره ص١١٤.تفسير مقاتل بن سليمان ٢/٥٧٧-٥٧٨.تفسير يحيى بن سلام ١/١٧٤.أخرجه ابن جرير ١٥/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وينظر: الإتقان ٢/٢٥.أخرجه ابن جرير ١٥/١٨٨.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/١٨٨. وعلقه يحيى بن سلام ١/١٧٤، ووقع فيه: تدعهم ذات اليمين!تفسير مقاتل بن سليمان ٢/٥٧٧-٥٧٨.تفسير الثعلبي ٦/١٥٩.أخرجه إسحاق البستي في تفسيره ص١١٦ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص١١٥.أخرجه ابن جرير ١٥/١٨٩.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/١٨٩، وإسحاق البستي في تفسيره ص١١٥.تفسير مجاهد ص٤٤٦.أخرجه يحيى بن سلام ١/١٧٥، وابن جرير ١٥/١٨٩.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٥٧٨.تفسير مقاتل بن سليمان ٢/٥٧٨.أخرجه يحيى بن سلام ١/١٧٥.تفسير مقاتل بن سليمان ٢/٥٧٨.
18,18," <q>﴿وَتَحۡسَبُهُمۡ أَیۡقَاظࣰا وَهُمۡ رُقُودࣱۚ﴾</q> - تفسير ٤٤٥٢٤- عن قتادة بن دعامة: <q>﴿وتحسبهم﴾</q> يا محمد <q>﴿أيقاظا وهم رقود﴾</q> يقول: في رقدتهم الأولى{1}. (٩/٥٠٧) ٤٤٥٢٥- قال مقاتل بن سليمان: <q>﴿وتحسبهم أيقاظا﴾</q> حين يقلبون، وأعينهم مفتَّحة، <q>﴿وهم رقود﴾</q> يعني: نيام{2}. (ز) ٤٤٥٢٦- قال يحيى بن سلام: <q>﴿وتحسبهم أيقاظا وهم رقود﴾</q>، مُفَتَّحة أعينُهم وهم موتى{3}٣٩٧٥. (ز) ٣٩٧٥ على هذا القول فالرائي يحسبهم أيقاظًا لكون عيونهم مفتحة وهم رقود. وهو ما ذكره ابنُ عطية (٥/٥٨٠-٥٨١ بتصرف)، ثم قال: «ولو صحَّ فتح أعينهم بسند يقطع العذر كان أبين في أن يحسب عليهم التيقُّظ». ثم ساق احتمالين آخرين: أحدهما: أنّ الرائي يحسبهم أيقاظًا لشدة الحفظ الذي كان عليهم وقِلّة التغير، وذلك أن الغالب على النُّوّام أن يكون لهم استرخاء وهيئات تقتضي النوم، وربّ نائم على أحوال لم تتغير على حالة اليقظة، فيحسبه الرائي يقظانًا وإن كان مسدود العينين. والآخر: أن التقلب هو الذي من أجله كان الرائي يحسبهم أيْقاظًا. وانتقده مستندًا لمخالفته لظاهر الآية، فقال: «وهذا -وإن كان التقلب لمن صادف رؤيته دليلًا على ذلك- فإنّ ألفاظ الآية لم تسُقْه إلا خبرًا مستأنفًا». <q>﴿وَنُقَلِّبُهُمۡ ذَاتَ ٱلۡیَمِینِ وَذَاتَ ٱلشِّمَالِۖ﴾</q> - تفسير ٤٤٥٢٧- قال أبو هريرة: كان لهم في كل سنة تقليبتان{4}. (ز) ٤٤٥٢٨- عن عبد الله بن عباس، في قوله: <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q>، قال: ستة أشهر على ذي الجنب، وستة أشهر على ذي الجنب{5}. (٩/٥٠٧) ٤٤٥٢٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q>، قال: لو أنّهم لا يقلبون لأكلتهم الأرض{6}. (ز) ٤٤٥٣٠- قال عبد الله بن عباس: كانوا يقلّبون في السنة مرة من جانب إلى جانب؛ لئلا تأكل الأرض لحومهم{4}. (ز) ٤٤٥٣١- عن سعيد بن جبير، في قوله: <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q>، قال: كي لا تأكل الأرضُ لحومَهم{8}. (٩/٥٠٨) ٤٤٥٣٢- عن مجاهد بن جبر، في قوله: <q>﴿ونقلبهم﴾</q>، قال: في التسع سنين ليس فيما سواه{9}. (٩/٥٠٨) ٤٤٥٣٣- عن الضحاك بن مزاحم، قال: كان يقلبهم جبريل ﵇ كل عام مرتين؛ لئلا تأكل الأرضُ لحومَهم{10}. (ز) ٤٤٥٣٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q>، قال: وهذا التقليب في رقدتهم الأولى، كانوا يقلبون في كل عام مرة{11}. (٩/٥٠٧) ٤٤٥٣٥- قال قتادة بن دعامة: <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q>، ذاك في رقدتهم الأولى قبل أن يموتوا{12}. (ز) ٤٤٥٣٦- عن أبي عياض -من طريق عبد ربه- في قوله: <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q>، قال: في كل عام مرتين{13}. (٩/٥٠٨) ٤٤٥٣٧- قال مقاتل بن سليمان: <q>﴿ونقلبهم ذات اليمين وذات الشمال﴾</q> على جنوبهم، وهم رقود لا يشعرون{2}٣٩٧٦. (ز) ٣٩٧٦ علَّق ابنُ عطية (٥/٥٨١) بعد ذكره لأقوال المفسرين بقوله: «وآية الله في نومهم هذه المدة الطويلة وحياتهم دون تَغَذٍّ أذهب في الغرابة مِن حفظهم مع مسِّ الشمس ولزوم الأرض، ولكنها روايات تختلف وتتأمل بعد». وذكر أن ظاهر كلام المفسرين أن التقليب كان بأمر الله وفعل ملائكته. ثم ساق احتمالًا آخر، فقال: «ويحتمل أن يكون ذلك بإقدار الله إياهم على ذلك وهم في غمرة النوم، وهم لا ينتبهون، كما يعتري كثيرًا من النّوام؛ لأن القوم لم يكونوا موتى». <q>﴿وَكَلۡبُهُم﴾</q> - تفسير ٤٤٥٣٨- عن علي بن أبي طالب: اسمه: ريان{15}. (ز) ٤٤٥٣٩- قال عبد الله بن سلام: بسيط{4}. (ز) ٤٤٥٤٠- عن عبد الله بن عباس -من طريق أبي روق، عن الضحاك- في قوله:... الكلب اسمه: قطمير، دون الكردي وفوق القبطي، لا أظن فوق القبطي{17}. (٩/٥١٣) ٤٤٥٤١- قال عبد الله بن عباس: كان كلبًا أغَرَّ{18}{19}. (ز) ٤٤٥٤٢- قال كعب الأحبار: [اسمه] صهباء{20}. (ز) ٤٤٥٤٣- عن مجاهد بن جبر، في قوله: <q>﴿وكلبهم﴾</q>، قال: اسم كلبهم: قطمور{1}. (٩/٥٠٨) ٤٤٥٤٤- عن الحسن البصري قال: اسم كلب أصحاب الكهف: قطمير{1}. (٩/٥٠٨) ٤٤٥٤٥- قال وهب بن منبه: اسمه تقي{23}. (ز) ٤٤٥٤٦- قال محمد بن كعب القرظي: من شدة صفرته يضرب إلى الحمرة{4}. (ز) ٤٤٥٤٧- عن شبل قال: زعم عبد الله بن كثير أن اسم كلبهم قطمير{25}. (ز) ٤٤٥٤٨- قال إسماعيل السدي: اسمه تور{26}. (ز) ٤٤٥٤٩- قال شعيب الجبائي: حمران{4}. (ز) ٤٤٥٥٠- قال مقاتل: كان أصفر{28}. (ز) ٤٤٥٥١- قال محمد بن السائب الكلبي: لونه كالخَلَنجِ{29}{28}. (ز) ٤٤٥٥٢- قال مقاتل بن سليمان: <q>﴿وكلبهم﴾</q>، اسمه: قمطير{31}{2}. (ز) ٤٤٥٥٣- قال الأوزاعي: بتور{33}. (ز) ٤٤٥٥٤- عن كثير النواء -من طريق سفيان- قال: كان كلب أصحاب الكهف أصفر{34}٣٩٧٧. (٩/٥٠٩) ٣٩٧٧ أفادت الآثار الاختلاف في لون الكلب، وهو ما انتقده ابنُ كثير (٩/١١٧) لعدم الدليل على شيء منها، فقال: «واختلفوا في لونه على أقوال لا حاصل لها، ولا طائل تحتها، ولا دليل عليها، ولا حاجة إليها، بل هي مما ينهى عنه؛ فإن مستندها رجم بالغيب». ٤٤٥٥٥- عن سفيان، قال: قال رجل بالكوفة يقال له: عبيد، وكان لا يُتَّهَم بكذب، قال: رأيت كلب أصحاب الكهف أحمر، كأنه كساء أنبجاني{34}. (٩/٥٠٩) ٤٤٥٥٦- عن عبد الملك ابن جريج، قال: قلت لرجل من أهل العلم: زعموا أنّ كلبهم كان أسدًا. قال: لعمرُ الله، ما كان أسدًا، ولكنه كان كلبًا أحمر، خرجوا به من بيوتهم، يقال له: قطمور{36}٣٩٧٨. (٩/٥٠٨) ٣٩٧٨ اختُلِف هل كان كلْب أصحاب الكهف كلب من كلابهم كان معهم، أم كان لغيرهم وتبعهم؟ ورجَّح ابنُ كثير (٩/١١٦) القول الأول، وهو أنّ الكلب كان كلب صيد لأحدهم. فقال: «وهو الأشبه». ولم يذكر مستندًا. وذكر ابنُ عطية (٥/٥٨١) أنّ أكثر المفسرين على القول الأول، ثم ذكر قولًا بأنه كان أحدهم، وكان قعد عند باب الغار طليعة لهم. ووجَّهه بقوله: «فسُمِّي باسم الحيوان الملازم لذلك الموضع من الناس، كما سُمِّي النجم التابع للجوزاء: كلبًا؛ لأنه منها كالكلب من الإنسان، ويقال له: كلب الجبّار». وانتقده مستندًا لدلالة العقل، فقال: «أما إن هذا القول يضعفه بسط الذراعين؛ فإنهما في العرف في صفة الكلب حقيقة، ومنه قول النبي ﷺ: «ولا يبسط أحدكم ذراعيه في السجود انبساط الكلب»». ثم قال: «وقد حكى أبو عمر المطرز في كتاب اليواقيت أنه قُرئ: (وكالِبُهُم باسِطٌ ذِراعَيْهِ) فيحتمل أن يريد بـ»الكالب«هذا الرجل على ما روي؛ إذْ بسْط الذراعين واللصوق بالأرض مع رفع الوجه للتطلع هي هيئة الربيئة المستخفي بنفسه، ويحتمل أن يريد بالكالب: الكلب». <q>﴿بَـٰسِطࣱ ذِرَاعَیۡهِ بِٱلۡوَصِیدِۚ﴾</q> - تفسير ٤٤٥٥٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بالوصيد﴾</q>، قال: بالفناء{37}. (٩/٥١٠) ٤٤٥٥٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿بالوصيد﴾</q>، قال: بالباب{38}. (٩/٥١٠) ٤٤٥٥٩- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وكلبهم باسط ذراعيه بالوصيد﴾</q>، يعني: فناءهم. ويُقال: الوصيد: الصعيد{39}. (ز) ٤٤٥٦٠- عن سعيد بن جبير -من طريق هارون بن عنترة- في قوله: <q>﴿بالوصيد﴾</q>، قال: بالصعيد{40}. (٩/٥١٠) ٤٤٥٦١- عن سعيد بن جبير -من طريق سالم الأفطس- <q>﴿وكلبهم باسط ذراعيه بالوصيد﴾</q>، قال: بالفناء{41}. (ز) ٤٤٥٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بالوصيد﴾</q>، قال: بالفناء{42}. (ز) ٤٤٥٦٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان- في قوله: <q>﴿بالوصيد﴾</q>، قال: يعني: بالفناء{43}. (ز) ٤٤٥٦٤- عن عطية العوفي، في قوله: <q>﴿بالوصيد﴾</q>، قال: بفناء باب الكهف{1}. (٩/٥١٠) ٤٤٥٦٥- قال عطاء: الوصيد: عتبة الباب{28}. (ز) ٤٤٥٦٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وكلبهم باسط ذراعيه بالوصيد﴾</q>، يقول: بفناء الكهف{46}. (ز) ٤٤٥٦٧- قال إسماعيل السدي: الوصيد: الباب{28}. (ز) ٤٤٥٦٨- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿باسط ذراعيه بالوصيد﴾</q>، قال: بالفناء{48}. (ز) ٤٤٥٦٩- عن عبد الله بن حميد المكي، في قوله: <q>﴿وكلبهم باسط ذراعيه بالوصيد﴾</q>، قال: جعل رزقه في لحس ذراعيه{1}. (٩/٥٠٩) ٤٤٥٧٠- قال مقاتل بن سليمان: <q>﴿باسط ذراعيه بالوصيد﴾</q>، يعني: الفضاء الذي على باب الكهف، وكان الكلب لمكسلمينا، وكان راعي غنم، فبسط الكلب ذراعيه على باب الكهف ليحرسهم، وأنام الله ﷿ الكلب في تلك السنين كما أنام الفتية{2}. (ز) ٤٤٥٧١- عن عبد الملك ابن جريج، في قوله: <q>﴿وكلبهم باسط ذراعيه بالوصيد﴾</q>، قال: يمسك عليهم باب الكهف{36}. (٩/٥١٠) ٤٤٥٧٢- عن عمرو -من طريق الحكم بن بَشير- في قوله: <q>﴿وكلبهم باسط ذراعيه بالوصيد﴾</q>، قال: الوصيد: الصعيد؛ التراب{39}. (ز) ٤٤٥٧٣- عن عُبيد السَّواق، قال: رأيت كلب أصحاب الكهف صغيرًا زِئْنِيًّا -يعني: صِينِيًّا- باسطًا ذراعيه بفناء باب الكهف، وهو يقول هكذا، يضرب بأذنيه{53}٣٩٧٩. (٩/٥٠٩) ٣٩٧٩ اختُلِف في تأويل الوصيد على أقوال: الأول: الفِناء. والثاني: الباب. والثالث: الصَّعيد. ورجَّح ابنُ جرير (١٥/١٩٤ بتصرف) مستندًا إلى دلالة اللفظ القول الأول والثاني، دون الثالث الذي قاله ابن عباس من طريق العوفي، وسعيد بن جبير، وعمرو، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: الوصيد: الباب، أو فناء الباب حيث يغلق الباب. وذلك أن الباب يوصد، وإيصاده: إطباقه وإغلاقه، من قول الله ﷿: <q>﴿إنها عليهم مؤصدة﴾</q> [الهمزة:٨]... فكأن معنى الكلام: وكلبهم باسط ذراعيه بفناء كهفهم عند الباب، يحفظ عليهم بابه». وبنحوه ابنُ عطية (٥/٥٨٢)، وابنُ كثير (٩/١١٥). <q>﴿لَوِ ٱطَّلَعۡتَ عَلَیۡهِمۡ لَوَلَّیۡتَ مِنۡهُمۡ فِرَارࣰا وَلَمُلِئۡتَ مِنۡهُمۡ رُعۡبࣰا ۝١٨﴾</q> - تفسير ٤٤٥٧٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: غزونا مع معاوية نحو الروم، فمررنا بالكهف الذي فيه أصحاب الكهف، فقال معاوية: لو كُشِف لنا عن هؤلاء فنظرنا إليهم. فقال ابن عباس ﵃: لقد مُنِع ذلك من هو خير منك، فقال: <q>﴿لو اطلعت عليهم لوليت منهم فرارا﴾</q>. فبعث معاوية ناسًا، فقال: اذهبوا، فانظروا. فلما دخلوا الكهف بعث الله عليهم ريحًا، فأخرجتهم{54}. (٩/٤٩٥) ٤٤٥٧٥- عن شَهْر بن حَوْشَب، قال: كان لي صاحب ماضٍ{55} شديد النفس، فمر بجانب كهفهم، فقال: لا أنتهي حتى أنظر إليهم. فقيل له: لا تفعل، أما تقرأ: <q>﴿لو اطلعت عليهم لوليت منهم فرارا ولملئت منهم رعبا﴾</q>؟ فأبى إلا أن ينظر، فأشرف عليهم، فابيضَّتْ عيناه، وتَغَيَّر شعره، وكان يخبر الناس بعد يقول: عدتهم سبعة{1}. (٩/٥١٠) ٤٤٥٧٦- قال محمد بن السائب الكلبي: لأنّ أعينهم كانت مفتحة كالمستيقظ الذي يريد أن يتكلم، وهم نيام{57}. (ز) ٤٤٥٧٧- قال مقاتل بن سليمان: يقول للنبي ﷺ: <q>﴿لو اطلعت عليهم﴾</q> حين نُقَلِّبهم <q>﴿لوليت منهم فرارا ولملئت منهم رعبا﴾</q>{2}. (ز) ٤٤٥٧٨- قال يحيى بن سلام: <q>﴿لو اطلعت عليهم لوليت منهم فرارا ولملئت منهم رعبا﴾</q> لحالهم{3}٣٩٨٠. (ز) ٣٩٨٠ ذكر ابنُ عطية (٥/٥٨٣) قولًا مفاده: أن فتية أهل الكهف إنما حفَّهم هذا الرعب لطول شعورهم وأظفارهم. وانتقده مستندًا لمخالفته لظاهر القرآن، فقال: «وهذا قول بعيد، ولو كانت حالهم هكذا لم يقولوا: <q>﴿لَبِثْنا يَوْمًا أوْ بَعْضَ يَوْمٍ﴾</q>». ثم قال: «وإنما الصحيح في أمرهم: أنّ الله ﷿ حفظ لهم الحالة التي ناموا عليها؛ لتكون لهم ولغيرهم فيهم آية، فلم يبْل لهم ثوب، ولا تغيرت صفة، ولا أنكر الناهض إلى المدينة إلا معالم الأرض والبناء، ولو كانت في نفسه حالة ينكرها لكانت عليه أهم، ولروي ذلك». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٧٨.تفسير يحيى بن سلام ١/١٧٥.تفسير الثعلبي ٦/١٦٠.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٥/١٩١.تفسير الثعلبي ٦/١٦٠.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه مقاتل بن سليمان ٢/٥٧٨.أخرجه ابن جرير ١٥/١٩١. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/١٧٥.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٩٠-٤٩١ (٣٦٨١٥)، ويحيى بن سلام ١/١٧٥ من طريق قتادة. وعلَّقه ابن جرير ١٥/١٩١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٧٨.تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨. وفي طبعة دار التفسير لتفسير الثعلبي ١٧/٦٦: كان اسمه زبار.تفسير الثعلبي ٦/١٦٠.أخرجه الطبراني في الأوسط (٦١١٣).الغُرَّة -بالضم-: بياض في الجبهة. والأغر: الأبيض من كل شيء. لسان العرب (غرر).تفسير البغوي ٥/١٥٨، وتفسير الثعلبي ٦/١٦٠.تفسير الثعلبي (طبعة دار التفسير) ١٧/٦٨. وتصحفت في طبعة دار إحياء التراث العربي ٦/١٦٠ إلى أصْهَب. وفي تفسير البغوي ٥/١٥٨: صَهِيلَة.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي (طبعة دار التفسير) ١٧/٦٨. وفي طبعة دار إحياء التراث العربي ٦/١٦٠: نقيا.تفسير الثعلبي ٦/١٦٠.أخرجه الثعلبي في تفسيره (ط: دار التفسير) ١٧/٦٧.تفسير البغوي ٥/١٥٨، وفي مطبوعة تفسير الثعلبي ٦/١٦٠: نون.تفسير الثعلبي ٦/١٦٠.تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.الخَلَنج: شجر فارسي مُعرَّب، تُتخذ من خشبه الأواني. لسان العرب (خلنج).تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.كذا في مطبوعة المصدر. ولعله «قطمير» كما تقدم عن غير واحد.تفسير مقاتل بن سليمان ٢/٥٧٨.تفسير البغوي ٥/١٥٨، وفي تفسير الثعلبي ٦/١٦٠: نتوى. وفي طبعة دار التفسير ١٧/٦٦: تنوه.أخرجه إسحاق البستي في تفسيره ص١١٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص١١٨. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/١٩٢. وعزاه السيوطي إلى ابن المنذر، وأبي حاتم.أخرجه ابن جرير ١٥/١٩٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/١٩٣.أخرجه ابن جرير ١٥/١٩٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/١٩٢.أخرجه ابن جرير ١٥/١٩٢، ومن طريق ابن جريج أيضًا. وفي تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ١٥/١٥٨ بلفظ: فناء الكهف.أخرجه ابن جرير ١٥/١٩٣. وفي تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨ بلفظ: فناء الكهف.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.أخرجه عبد الرزاق ٢/٣٩٩، وابن جرير ١٥/١٩٣ من طريق سعيد. وعلَّقه يحيى بن سلام ١/١٧٥.تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.أخرجه أبو جعفر الرملي في جزئه ص٩٥ (تفسير عطاء الخراساني).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٧٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/١٩٣.عزاه السيوطي إلى ابن أبي حاتم، من طريق جرير.أخرجه ابن أبي شيبة -كما في تخريج أحاديث الكشاف ٢/٣١٠، ولم يذكر لفظه-، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٤-٢٤٦-، والثعلبي ٦/١٦١، والبغوي ٥/١٥٩. وعزاه السيوطي إلى ابن المنذر.ذكر محققو الدر أنها في إحدى نسخه: مات.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/١٦١، وتفسير البغوي ٥/١٥٩.تفسير مقاتل بن سليمان ٢/٥٧٨.تفسير يحيى بن سلام ١/١٧٥.
18,19," <q>﴿وَكَذَ ٰ⁠لِكَ بَعَثۡنَـٰهُمۡ لِیَتَسَاۤءَلُوا۟ بَیۡنَهُمۡۚ قَالَ قَاۤىِٕلࣱ مِّنۡهُمۡ كَمۡ لَبِثۡتُمۡۖ قَالُوا۟ لَبِثۡنَا یَوۡمًا أَوۡ بَعۡضَ یَوۡمࣲۚ قَالُوا۟ رَبُّكُمۡ أَعۡلَمُ بِمَا لَبِثۡتُمۡ﴾</q> - تفسير ٤٤٥٧٩- قال مقاتل بن سليمان: <q>﴿وكذلك﴾</q> يعني: وهكذا <q>﴿بعثناهم﴾</q> من نومهم فقاموا؛ <q>﴿ليتساءلوا بينهم﴾</q> فـ<q>﴿قال قائل منهم﴾</q> وهو مكسلمينا، وهو أكبرهم سنًّا: <q>﴿كم لبثتم﴾</q> رقودًا؟ <q>﴿قالوا لبثنا يوما﴾</q> وكانوا دخلوا الغار غدوة، وبعثوا من آخر النهار، فمن ثَمَّ قالوا: <q>﴿أو بعض يوم قالوا﴾</q> يعني: الأكبر، وهو مكسلمينا وحده: <q>﴿ربكم أعلم بما لبثتم﴾</q> في رقودكم منكم. فردوا العلم إلى الله ﷿{1}. (ز) ٤٤٥٨٠- قال يحيى بن سلام: <q>﴿وكذلك بعثناهم ليتساءلوا بينهم قال قائل منهم كم لبثتم قالوا لبثنا يوما أو بعض يوم﴾</q>، وكانوا دخلوا الكهف في أول النهار. قال: فنظروا، فإذا هو قد بقي من الشمس بَقِيَّة؛ فقالوا: <q>﴿أو بعض يوم﴾</q> ثم إنهم شكوا، فردوا علم ذلك إلى الله، <q>﴿قالوا ربكم أعلم بما لبثتم﴾</q> يقوله بعضهم لبعض{2}. (ز) <q>﴿فَٱبۡعَثُوۤا۟ أَحَدَكُم بِوَرِقِكُمۡ هَـٰذِهِۦۤ إِلَى ٱلۡمَدِینَةِ فَلۡیَنظُرۡ أَیُّهَاۤ أَزۡكَىٰ طَعَامࣰا﴾</q> - تفسير ٤٤٥٨١- عن عبد الله بن عباس، في قوله: <q>﴿أزكى طعاما﴾</q>، قال: أحَلَّ ذبيحةً، وكانوا يذبحون للطواغيت{3}. (٩/٥١١) ٤٤٥٨٢- عن عبد الله بن عباس، في قوله: <q>﴿أزكى طعاما﴾</q>، يعني: أطهر؛ لأنهم كانوا يذبحون الخنازير{4}. (٩/٥١١) ٤٤٥٨٣- عن سعيد بن جبير -من طريق أبي حصين- <q>﴿أيها أزكى طعاما﴾</q>، قال: أيها أحلُّ{5}٣٩٨١. (ز) ٣٩٨١ علَّق ابنُ عطية (٥/٥٨٥) على هذا القول الذي قاله ابن عباس، وسعيد بن جبير، بقوله: «من جهة ذبائح الكفرة، وغير ذلك». ٤٤٥٨٤- عن عكرمة مولى ابن عباس -من طريق أبي حصين-، مثله، إلا أنه قال: أيُّهُ أكثر{6}٣٩٨٢. (ز) ٣٩٨٢ وجَّه ابنُ جرير (١٥/٢١٤) قول عكرمة بقوله: "وإنما وجَّه مَن وجَّه تأويل <q>﴿أزكى﴾</q> إلى الأكثر لأنه وجد العرب تقول: قد زكا مال فلان: إذا كثر، وكما قال الشاعر: قبائلنا سبع وأنتم ثلاثة... وللسبع أزكى من ثلاث وأطيب بمعنى: أكثر، وذلك وإن كان كذلك فإن الحلال الجيد وإن قل أكثرُ من الحرام الخبيث وإن كثر". وبنحوه ابنُ كثير (٩/١١٨). ٤٤٥٨٥- عن الضحاك بن مزاحم، في قوله: <q>﴿أيها أزكى طعاما﴾</q>، قال: أطْيَب{7}. (ز) ٤٤٥٨٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أزكى طعاما﴾</q>، قال: خير طعامًا، يعني: أجوده{6}. (ز) ٤٤٥٨٧- قال مقاتل بن حيان: أجود طعامًا{9}. (ز) ٤٤٥٨٨- قال مقاتل بن سليمان: ثم قال مكسلمينا: <q>﴿فابعثوا أحدكم بورقكم﴾</q> يعني: الدراهم <q>﴿هذه﴾</q> التي معكم <q>﴿إلى المدينة﴾</q> فبعثوا يمليخا، <q>﴿فلينظر أيها أزكى طعاما﴾</q> يعني: أطيب طعامًا{10}. (ز) ٤٤٥٨٩- قال يحيى بن سلام: <q>﴿فابعثوا أحدكم بورقكم هذه﴾</q> أي: بدراهمكم هذه <q>﴿إلى المدينة﴾</q> وكانت معهم دارهم، <q>﴿فلينظر أيها أزكى طعاما﴾</q> وقد كان مِن طعام قومهم ما لا يستحلون أكله{2}٣٩٨٣. (ز) ٣٩٨٣ اختُلِف في المراد بقوله: <q>﴿أيها أزكى طعاما﴾</q> على أقوال: الأول: أكثر طعامًا. والثاني: أحل طعامًا. والثالث: خير طعامًا. ورجَّح ابنُ جرير (١٥/٢١٣-٢١٤) القول الثاني والثالث مستندًا إلى الدلالات العقلية، فقال: «وأولى الأقوال عندي في ذلك بالصواب قولُ مَن قال: معنى ذلك: أحل وأطهر. وذلك أنّه لا معنى في اختيار الأكثر طعامًا للشراء منه، إلا بمعنى إذا كان أكثرهم طعامًا، كان خليقًا أن يكون الأفضل منه عنده أوجد، وإذا شُرط على المأمور الشراء من صاحب الأفضل فقد أمر بشراء الجيد، كان ما عند المشتري ذلك منه قليلًا الجيد أو كثيرًا». وبنحوه ابنُ كثير (٩/١١٨). <q>﴿فَلۡیَأۡتِكُم بِرِزۡقࣲ مِّنۡهُ﴾</q> - تفسير ٤٤٥٩٠- عن عبد الله بن عبيد بن عمير -من طريق عبد العزيز بن أبي روّاد- <q>﴿فليأتكم برزق منه﴾</q>، قال: بطعام{12}. (ز) <q>﴿وَلۡیَتَلَطَّفۡ وَلَا یُشۡعِرَنَّ بِكُمۡ أَحَدًا ۝١٩﴾</q> - تفسير ٤٤٥٩١- قال مقاتل بن سليمان: <q>﴿وليتلطف﴾</q> يعني: ولْيَتَرَفَّق حتى لا يُفْطَنَ له، <q>﴿ولا يشعرن بكم أحدا﴾</q> يعني: ولا يعلمنَّ بمكانكم أحدًا من الناس{1}. (ز) ٤٤٥٩٢- قال يحيى بن سلام: <q>﴿فليأتكم برزق منه وليتلطف ولا يشعرن﴾</q>: لا يُعْلِمَنَّ{14}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٧٩.تفسير يحيى بن سلام ١/١٧٥.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/١٧٥، وعبد الرزاق ٢/٤٠٠، وابن جرير ١٥/٢١٣.أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/٢١٣.تفسير الثعلبي ٦/١٦١.أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/٢١٣.تفسير الثعلبي ٦/١٦١، وتفسير البغوي ٥/١٦٠.تفسير مقاتل بن سليمان ٢/٥٧٩. وأخرج ابن جرير ١٥/٢١٢ من طريق سفيان عن مقاتل دون تعيين: <q>﴿فابعثوا أحدكم بورقكم هذه﴾</q>: اسمه يمليخ.تفسير يحيى بن سلام ١/١٧٥.أخرجه ابن جرير ١٥/٢١٤.تفسير مقاتل بن سليمان ٢/٥٧٩.تفسير يحيى بن سلام ١/١٧٦.
18,20," <q>﴿إِنَّهُمۡ إِن یَظۡهَرُوا۟ عَلَیۡكُمۡ یَرۡجُمُوكُمۡ﴾</q> - تفسير ٤٤٥٩٣- قال مقاتل بن سليمان: <q>﴿إنهم إن يظهروا عليكم يرجموكم﴾</q>، يعني: يقتلوكم{1}. (ز) ٤٤٥٩٤- عن عبد الملك ابن جريج -من طريق حجاج- في قوله: <q>﴿إنهم إن يظهروا عليكم يرجموكم﴾</q>، قال: يشتموكم بالقول؛ يؤذوكم{2}٣٩٨٤. (ز) ٣٩٨٤ لم يذكر ابنُ جرير (١٥/٢١٥) غير قول ابن جريج. ٤٤٥٩٥- قال يحيى بن سلام: <q>﴿إنهم إن يظهروا عليكم يرجموكم﴾</q> يقتلوكم بالحجارة{3}٣٩٨٥. (ز) ٣٩٨٥ اختُلِف هل المراد الرجم بالحجارة، أو بالقول؟ ورجَّح ابنُ عطية (٥/٥٨٦) مستندًا إلى دلالة العقل، والتاريخ القولَ الأول الذي قاله مقاتل، وابن سلام، فقال: «وهو الأصح؛ لأنه كان عازمًا على قتلهم لو ظفر بهم، والرجم فيما سلف هي كانت -على ما ذكر- قِتْلة مخالف دين الناس، إذ هي أشفى لجملة ذلك في الدين، ولهم فيها مشاركة». <q>﴿أَوۡ یُعِیدُوكُمۡ فِی مِلَّتِهِمۡ﴾</q> - تفسير ٤٤٥٩٦- قال مقاتل بن سليمان: <q>﴿أو يعيدوكم في ملتهم﴾</q>، يعني: في دينهم: الكفر{1}. (ز) ٤٤٥٩٧- قال يحيى بن سلام: <q>﴿أو يعيدوكم في ملتهم﴾</q> في الكفر{3}. (ز) <q>﴿وَلَن تُفۡلِحُوۤا۟ إِذًا أَبَدࣰا ۝٢٠﴾</q> - تفسير ٤٤٥٩٨- قال مقاتل بن سليمان: <q>﴿ولن تفلحوا إذا أبدا﴾</q>، كان هذا مِن قول مكسلمينا يقوله للفتية، فلما ذهب يمليخا إلى القرية أنكروا دراهم دقيوس الجبار الذي فرَّ منه الفتية، فلما رأوا ذلك قالوا: هذا رجل وجد كنزًا. فلما خاف أن يُعَذَّب أخبرهم بأمر الفتية، فانطلقوا معه إلى الكهف، فلما انتهى يمليخا إلى الكهف ودخل سدَّ اللهُ ﷿ بابَ الكهف عليهم، فلم يخلص إليهم أحد{1}. (ز) ٤٤٥٩٩- قال يحيى بن سلام: <q>﴿ولن تفلحوا إذا أبدا﴾</q> إن فعلتم{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٧٩.أخرجه ابن جرير ١٥/٢١٥.تفسير يحيى بن سلام ١/١٧٦.تفسير مقاتل بن سليمان ٢/٥٧٩.تفسير يحيى بن سلام ١/١٧٦.تفسير مقاتل بن سليمان ٢/٥٧٩.تفسير يحيى بن سلام ١/١٧٦.
