quran[5]{c,v,t}:
  18,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذِ ٱعۡتَزَلۡتُمُوهُمۡ وَمَا یَعۡبُدُونَ إِلَّا ٱللَّهَ﴾</span> - تفسير الآية، وقراءات فيها</h3></p><p><div></p><p><p><span class="item-no">٤٤٤٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذِ اعْتَزَلْتُمُوهُمْ وما يَعْبُدُونَ إلّا اللَّهَ﴾</span>، قال: هي في مصحف <span class="name-1">ابن مسعود</span>: (وما يَعْبُدُونَ مِن دُونِ اللهِ). فهذا تفسيرها{1}<span class=comment-ref>٣٩٧٢</span>. (٩/٥٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٥/٥٧٧) على قول قتادة بقوله: «فعلى ما قال قتادة تكون <span class="qpc-hafs">﴿إلّا﴾</span> بمنزلة: غير، و<span class="qpc-hafs">﴿ما﴾</span> من قوله: <span class="qpc-hafs">﴿وما يَعْبُدُونَ﴾</span> في موضع نصب عطفًا على الضمير في قوله: <span class="qpc-hafs">﴿اعْتَزَلْتُمُوهُمْ﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٤٤٤٨٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>، في قوله: <span class="qpc-hafs">﴿وإذِ اعْتَزَلْتُمُوهُمْ وما يَعْبُدُونَ إلّا اللَّهَ﴾</span>، قال: كان قومُ الفتيةِ يعبدون الله، ويعبدون معه آلهة شتّى، فاعتزلت الفتية عبادة تلك الآلهة، ولم تعتزل عبادة الله{2}. (٩/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال الفتية بعضهم لبعض: <span class="qpc-hafs">﴿وإذِ اعْتَزَلْتُمُوهُمْ وما يَعْبُدُونَ﴾</span> من دون الله من الآلهة، ثم استثنوا، فقالوا: <span class="qpc-hafs">﴿إلّا اللَّهَ﴾</span> فلا تعتزلوا معرفته، لأنّهم عرفوا أنّ الله تعالى ربهم، وهو خلقهم، وخلق الأشياء كلها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وإذِ اعْتَزَلْتُمُوهُمْ﴾</span> يقوله بعضهم لبعض، <span class="qpc-hafs">﴿وما يَعْبُدُونَ إلّا اللَّهَ﴾</span> أي: وما يعبدون من دون الله، أي: وما يعبدون سوى الله{4}<span class=comment-ref>٣٩٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٣</span> قال <u>ابنُ عطية</u> (٥/٥٧٦): «وقولهم: <span class="qpc-hafs">﴿وإذِ اعْتَزَلْتُمُوهُمْ﴾</span> الآية، إن كان»القيام«في قوله: <span class="qpc-hafs">﴿إذْ قامُوا﴾</span> عزمًا -كما تضمن التأويل الواحد، وكان القول منهم فيما بينهم- فهذه المقالة يصح أن تكون من قولهم الذي قالوه عند قيامهم؛ وإن كان»القيام«المذكور مقامهم بين يدي الملك؛ فهذه المقالة لا تترتب أن تكون من مقالهم بين يدي الملك، بل يكون في الكلام حذف، تقديره: وقال بعضهم لبعض. وبهذا يترجح أن قوله تعالى: <span class="qpc-hafs">﴿إذْ قامُوا فَقالُوا﴾</span> إنما المراد به: إذ عزموا ونفذوا لأمرهم».</div></p><p><h3><span class="qpc-hafs">﴿فَأۡوُۥۤا۟ إِلَى ٱلۡكَهۡفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٤٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فأووا إلى الكهف﴾</span>، قال: كان كهفُهم بين جبلين{5}. (٩/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال بعضهم لبعض: <span class="qpc-hafs">﴿فأووا إلى الكهف﴾</span>، يعني: انتهوا إلى الكهف. كقوله سبحانه: <span class="qpc-hafs">﴿إذ أوينا إلى الصخرة﴾</span> [الكهف:٦٣]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأووا إلى الكهف﴾</span>، يعني: فانتهوا إلى الكهف{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَنشُرۡ لَكُمۡ رَبُّكُم مِّن رَّحۡمَتِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٤٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ينشر لكم﴾</span> يعني: يبسط لكم <span class="qpc-hafs">﴿ربكم من رحمته﴾</span> رِزْقًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ينشر لكم ربكم﴾</span>، يعني: يبسط لكم ربُّكم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُهَیِّئۡ لَكُم مِّنۡ أَمۡرِكُم مِّرۡفَقࣰا ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٤٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿ويهيئ لكم من أمركم مرفقا﴾</span>، يقول: غداء{5}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويهيئ لكم من أمركم مرفقا﴾</span>، يعني: ما يرفق بكم؛ فهيَّأ الله لكم الرقود في الغار. فكان هذا مِن قول الفتية{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/١٧٤، وابن جرير ١٥/١٨٢. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>و(مِن دُونِ اللهِ) قراءة شاذة، وقراءة العشرة <span class="qpc-hafs">﴿إلّا اللَّهَ﴾</span>. ينظر: البحر المحيط ٦/١٠٣.|2:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٥٧٧.|4:تفسير يحيى بن سلام ١/١٧٤.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٢/٥٧٧.|7:تفسير يحيى بن سلام ١/١٧٤.|8:تفسير مقاتل بن سليمان ٢/٥٧٧.|9:تفسير يحيى بن سلام ١/١٧٤.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٥٧٧.
  18,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَرَى ٱلشَّمۡسَ إِذَا طَلَعَت تَّزَ ٰ⁠وَرُ عَن كَهۡفِهِمۡ ذَاتَ ٱلۡیَمِینِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٤٤٩٧<span class="dash">-</span></span> عن حاتم بن ورْدانَ، قال: سمعت <span class="name-2">أيوب السختياني</span> يقرأ: ‹تَزْوَرُّ عَن كَهْفِهِمْ›{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَرَى ٱلشَّمۡسَ إِذَا طَلَعَت تَّزَ ٰ⁠وَرُ عَن كَهۡفِهِمۡ ذَاتَ ٱلۡیَمِینِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٤٤٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿تزاور﴾</span>، قال: تميل{2}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٤٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لو أنّ الشمس تطلع عليهم لأحرقتهم، ولو أنهم لا يُقَلَّبُون لأكلتهم الأرض. قال: وذلك قوله: <span class="qpc-hafs">﴿وترى الشمس إذا طلعت تزاور عن كهفهم ذات اليمين وإذا غربت تقرضهم ذات الشمال﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- قال: <span class="qpc-hafs">﴿وترى الشمس إذا طلعت تزاور عن كهفهم ذات اليمين﴾</span>، قال: تميل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لا تدخل الشمس كهفَهم على حال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قوله: <span class="qpc-hafs">﴿تزاور عن كهفهم ذات اليمين﴾</span>، قال: تميل عن كهفهم ذات اليمين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق سفيان- في قوله: <span class="qpc-hafs">﴿تزاور عن كهفهم ذات اليمين وإذا غربت تقرضهم ذات الشمال﴾</span>، قال: تتركهم ذات الشمال. قال: وباب الكهف مستقبل بَنات نَعْشٍ{7}{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وترى الشمس إذا طلعت تزاور عن كهفهم﴾</span> يعني: تميل عن كهفهم فتدعهم <span class="qpc-hafs">﴿ذات اليمين﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿وترى الشمس إذا طلعت تزاور عن كهفهم﴾</span>: تَعْدِل عن كهفهم{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا غَرَبَت تَّقۡرِضُهُمۡ ذَاتَ ٱلشِّمَالِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿تقرضهم﴾</span>، قال: تَذَرُهم{11}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- <span class="qpc-hafs">﴿وإذا غربت تقرضهم﴾</span> قال: تتركهم <span class="qpc-hafs">﴿ذات الشمال﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تقرضهم﴾</span>، قال: تتركهم{13}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قوله: <span class="qpc-hafs">﴿تقرضهم ذات الشمال﴾</span>، قال: تدعهم ذات الشمال{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا غربت﴾</span> الشمس <span class="qpc-hafs">﴿تقرضهم﴾</span> يعني: تدعهم <span class="qpc-hafs">﴿ذات الشمال﴾</span>{9}<span class=comment-ref>٣٩٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٤</span> على هذا القول فالشمس لا تصيبهم ألبتة، وهو ما <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٥/٥٧٩) عليه بقوله: «كأنها عنده تقطع كلّ ما لا تناله عن نفسها». ثم <span class="comment-type-4">ذكر</span> أن هناك فرقة مـِمَّن قرأ <span class="qpc-hafs">﴿تقرضهم﴾</span> بالتاء تأول أن الشمس كانت بالعشي تنالهم، فكأنها تقرضهم، أي: تقتطعهم مما لا تناله، ونقل عنهم أنهم قالوا: كان في مسها لهم بالعشي صلاح لأجسامهم. وبيَّن (٥/٥٨٩-٥٩٠) أن قوله <span class="qpc-hafs">﴿ذات اليمين وذات الشمال﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يريد: ذات يمين الكهف بأن نقدر باب الكهف بمثابة وجه إنسان فإن الشمس تجيء منه أول النهار عن يمين، وآخره عن شمال. <b>الثاني</b>: ويحتمل أن يريد: ذات يمين الشمس وذات شمالها، بأن نقدر الشعاع الممتد منها إلى الكهف بمثابة وجه إنسان.</p><p>و<span class="comment-type-3">رجَّح</span> الاحتمالَ الأول، فقال: «والوجه الأول أصح». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٤٤٥١١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، في قوله: <span class="qpc-hafs">﴿تقرضهم﴾</span>، قال: تُجاوِزهم{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ فِی فَجۡوَةࣲ مِّنۡهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: يعني بالفجوة: الخلوة من الأرض. ويعني بالخلوة: الناحية من الأرض{17}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: المكان الواسع{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: المكان الداخل{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: المكان الداخل{13}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: المكان الذاهب{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: كهف الفتية بين جبلين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span> يقول: في فضاء من الكهف، قال الله: <span class="qpc-hafs">﴿ذلك من آيات الله﴾</span>{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥١٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، في قوله: <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: ناحية{24}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، يعني: في زاوية من الكهف{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مِنۡ ءَایَـٰتِ ٱللَّهِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> يعني: هذا الذي ذكر مِن أمر الفتية <span class="qpc-hafs">﴿من آيات الله﴾</span> يعني: مِن علامات الله وصُنعِه{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وهم في فجوة منه﴾</span>، قال: أي: في فضاء من الكهف. وتلك آية{27}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَن یَهۡدِ ٱللَّهُ فَهُوَ ٱلۡمُهۡتَدِۖ وَمَن یُضۡلِلۡ فَلَن تَجِدَ لَهُۥ وَلِیࣰّا مُّرۡشِدࣰا ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من يهد الله﴾</span> لدينه <span class="qpc-hafs">﴿فهو المهتد ومن يضلل﴾</span> عن دينه الإسلام <span class="qpc-hafs">﴿فلن تجد له وليا﴾</span> يعني: صاحبًا <span class="qpc-hafs">﴿مرشدا﴾</span> يعني: يرشده إلى الهُدى؛ لأن وليه مثله في الضلالة{25}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن الأعرابي في معجمه ١/٣٩٥ (٧٥٥).</p><p>وهي قراءة متواترة، قرأ بها ابن عامر، ويعقوب، وقرأ حمزة، والكسائي، وعاصم، وخلف العاشر: <span class="qpc-hafs">﴿تَزاوَرُ﴾</span> بفتح الزاي وتخفيفها وألف بعدها، وقرأ بقية العشرة: <span class="qpc-hafs">﴿تَزّاوَرُ﴾</span> بفتح الزاي وتشديدها وألف بعدها. انظر: النشر ٢/٣١٠، والإتحاف ص٣٦٤.|2:أخرجه ابن جرير ١٥/١٨٥، ١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وينظر: الإتقان ٢/٢٥.|3:أخرجه ابن جرير ١٥/١٨٦.|4:أخرجه ابن جرير ١٥/١٨٥.|5:علقه يحيى بن سلام ١/١٧٥.|6:أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/١٨٦. وعلقه يحيى بن سلام ١/١٧٤ وزاد: <span class="qpc-hafs">﴿ذات اليمين﴾</span>: تدعهم ذات اليمين.|7:بَناتُ نَعْشٍ: سبعة كواكب. لسان العرب (نعش).|8:أخرجه إسحاق البستي في تفسيره ص١١٤.|9:تفسير مقاتل بن سليمان ٢/٥٧٧-٥٧٨.|10:تفسير يحيى بن سلام ١/١٧٤.|11:أخرجه ابن جرير ١٥/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وينظر: الإتقان ٢/٢٥.|12:أخرجه ابن جرير ١٥/١٨٨.|13:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|14:أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/١٨٨. وعلقه يحيى بن سلام ١/١٧٤، ووقع فيه: تدعهم ذات اليمين!|15:تفسير مقاتل بن سليمان ٢/٥٧٧-٥٧٨.|16:تفسير الثعلبي ٦/١٥٩.|17:أخرجه إسحاق البستي في تفسيره ص١١٦ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.|18:أخرجه إسحاق البستي في تفسيره ص١١٥.|19:أخرجه ابن جرير ١٥/١٨٩.|20:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|21:أخرجه ابن جرير ١٥/١٨٩، وإسحاق البستي في تفسيره ص١١٥.|22:تفسير مجاهد ص٤٤٦.|23:أخرجه يحيى بن سلام ١/١٧٥، وابن جرير ١٥/١٨٩.|24:عزاه السيوطي إلى ابن المنذر.|25:تفسير مقاتل بن سليمان ٢/٥٧٨.|26:تفسير مقاتل بن سليمان ٢/٥٧٨.|27:أخرجه يحيى بن سلام ١/١٧٥.|28:تفسير مقاتل بن سليمان ٢/٥٧٨.
  18,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَحۡسَبُهُمۡ أَیۡقَاظࣰا وَهُمۡ رُقُودࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وتحسبهم﴾</span> يا محمد <span class="qpc-hafs">﴿أيقاظا وهم رقود﴾</span> يقول: في رقدتهم الأولى{1}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتحسبهم أيقاظا﴾</span> حين يقلبون، وأعينهم مفتَّحة، <span class="qpc-hafs">﴿وهم رقود﴾</span> يعني: نيام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿وتحسبهم أيقاظا وهم رقود﴾</span>، مُفَتَّحة أعينُهم وهم موتى{3}<span class=comment-ref>٣٩٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٥</span> على هذا القول فالرائي يحسبهم أيقاظًا لكون عيونهم مفتحة وهم رقود. وهو ما <span class="comment-type-4">ذكره</span> <u>ابنُ عطية</u> (٥/٥٨٠-٥٨١ بتصرف)، ثم قال: «ولو صحَّ فتح أعينهم بسند يقطع العذر كان أبين في أن يحسب عليهم التيقُّظ». ثم ساق احتمالين آخرين: <b>أحدهما</b>: أنّ الرائي يحسبهم أيقاظًا لشدة الحفظ الذي كان عليهم وقِلّة التغير، وذلك أن الغالب على النُّوّام أن يكون لهم استرخاء وهيئات تقتضي النوم، وربّ نائم على أحوال لم تتغير على حالة اليقظة، فيحسبه الرائي يقظانًا وإن كان مسدود العينين. <b>والآخر</b>: أن التقلب هو الذي من أجله كان الرائي يحسبهم أيْقاظًا. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لمخالفته لظاهر الآية</span>، <span class="comment-type-4">فقال</span>: «وهذا -وإن كان التقلب لمن صادف رؤيته دليلًا على ذلك- فإنّ ألفاظ الآية لم تسُقْه إلا خبرًا مستأنفًا».</div></p><p><h3><span class="qpc-hafs">﴿وَنُقَلِّبُهُمۡ ذَاتَ ٱلۡیَمِینِ وَذَاتَ ٱلشِّمَالِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٢٧<span class="dash">-</span></span> قال <span class="name-1">أبو هريرة</span>: كان لهم في كل سنة تقليبتان{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span>، قال: ستة أشهر على ذي الجنب، وستة أشهر على ذي الجنب{5}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span>، قال: لو أنّهم لا يقلبون لأكلتهم الأرض{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كانوا يقلّبون في السنة مرة من جانب إلى جانب؛ لئلا تأكل الأرض لحومهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span>، قال: كي لا تأكل الأرضُ لحومَهم{8}. (٩/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ونقلبهم﴾</span>، قال: في التسع سنين ليس فيما سواه{9}. (٩/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، قال: كان يقلبهم جبريل ﵇ كل عام مرتين؛ لئلا تأكل الأرضُ لحومَهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span>، قال: وهذا التقليب في رقدتهم الأولى، كانوا يقلبون في كل عام مرة{11}. (٩/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٥<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span>، ذاك في رقدتهم الأولى قبل أن يموتوا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٦<span class="dash">-</span></span> عن <span class="name-2">أبي عياض</span> -من طريق عبد ربه- في قوله: <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span>، قال: في كل عام مرتين{13}. (٩/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونقلبهم ذات اليمين وذات الشمال﴾</span> على جنوبهم، وهم رقود لا يشعرون{2}<span class=comment-ref>٣٩٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٥/٥٨١) بعد ذكره لأقوال المفسرين بقوله: «وآية الله في نومهم هذه المدة الطويلة وحياتهم دون تَغَذٍّ أذهب في الغرابة مِن حفظهم مع مسِّ الشمس ولزوم الأرض، ولكنها روايات تختلف وتتأمل بعد». وذكر أن ظاهر كلام المفسرين أن التقليب كان بأمر الله وفعل ملائكته. ثم ساق <b>احتمالًا آخر</b>، فقال: «ويحتمل أن يكون ذلك بإقدار الله إياهم على ذلك وهم في غمرة النوم، وهم لا ينتبهون، كما يعتري كثيرًا من النّوام؛ لأن القوم لم يكونوا موتى».</div></p><p><h3><span class="qpc-hafs">﴿وَكَلۡبُهُم﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٣٨<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>: اسمه: ريان{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٣٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن سلام</span>: بسيط{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي روق، عن الضحاك- في قوله:... الكلب اسمه: قطمير، دون الكردي وفوق القبطي، لا أظن فوق القبطي{17}. (٩/٥١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كان كلبًا أغَرَّ{18}{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٢<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: [اسمه] صهباء{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وكلبهم﴾</span>، قال: اسم كلبهم: قطمور{1}. (٩/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> قال: اسم كلب أصحاب الكهف: قطمير{1}. (٩/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٥<span class="dash">-</span></span> قال <span class="name-2">وهب بن منبه</span>: اسمه تقي{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٦<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>: من شدة صفرته يضرب إلى الحمرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٧<span class="dash">-</span></span> عن شبل قال: زعم <span class="name-2">عبد الله بن كثير</span> أن اسم كلبهم قطمير{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السدي</span>: اسمه تور{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٤٩<span class="dash">-</span></span> قال <span class="name-3">شعيب الجبائي</span>: حمران{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: كان أصفر{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: لونه كالخَلَنجِ{29}{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكلبهم﴾</span>، اسمه: قمطير{31}{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٣<span class="dash">-</span></span> قال <span class="name-3">الأوزاعي</span>: بتور{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٤<span class="dash">-</span></span> عن <span class="name-3">كثير النواء</span> -من طريق سفيان- قال: كان كلب أصحاب الكهف أصفر{34}<span class=comment-ref>٣٩٧٧</span>. (٩/٥٠٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٧</span> أفادت الآثار الاختلاف في لون الكلب، وهو ما <span class="comment-type-2">انتقده</span> <u>ابنُ كثير</u> (٩/١١٧) <span class="mustanad">لعدم الدليل على شيء منها</span>، فقال: «واختلفوا في لونه على أقوال لا حاصل لها، ولا طائل تحتها، ولا دليل عليها، ولا حاجة إليها، بل هي مما ينهى عنه؛ فإن مستندها رجم بالغيب».</div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٥<span class="dash">-</span></span> عن سفيان، قال: قال رجل بالكوفة يقال له: عبيد، وكان لا يُتَّهَم بكذب، قال: رأيت كلب أصحاب الكهف أحمر، كأنه كساء أنبجاني{34}. (٩/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٦<span class="dash">-</span></span> عن عبد الملك ابن جريج، قال: قلت لرجل من أهل العلم: زعموا أنّ كلبهم كان أسدًا. قال: لعمرُ الله، ما كان أسدًا، ولكنه كان كلبًا أحمر، خرجوا به من بيوتهم، يقال له: قطمور{36}<span class=comment-ref>٣٩٧٨</span>. (٩/٥٠٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٨</span> اختُلِف هل كان كلْب أصحاب الكهف كلب من كلابهم كان معهم، أم كان لغيرهم وتبعهم؟</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٩/١١٦) القول الأول، وهو أنّ الكلب كان كلب صيد لأحدهم. فقال: «وهو الأشبه». ولم يذكر مستندًا.</p><p>وذكر <u>ابنُ عطية</u> (٥/٥٨١) أنّ أكثر المفسرين على القول الأول، ثم ذكر قولًا بأنه كان أحدهم، وكان قعد عند باب الغار طليعة لهم. و<span class="comment-type-1">وجَّهه</span> بقوله: «فسُمِّي باسم الحيوان الملازم لذلك الموضع من الناس، كما سُمِّي النجم التابع للجوزاء: كلبًا؛ لأنه منها كالكلب من الإنسان، ويقال له: كلب الجبّار». و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لدلالة العقل</span>، فقال: «أما إن هذا القول يضعفه بسط الذراعين؛ فإنهما في العرف في صفة الكلب حقيقة، ومنه قول النبي ﷺ: «<b>ولا يبسط أحدكم ذراعيه في السجود انبساط الكلب</b>»». ثم قال: «وقد حكى أبو عمر المطرز في كتاب اليواقيت أنه قُرئ: (وكالِبُهُم باسِطٌ ذِراعَيْهِ) <b>فيحتمل</b> أن يريد بـ»الكالب«هذا الرجل على ما روي؛ إذْ بسْط الذراعين واللصوق بالأرض مع رفع الوجه للتطلع هي هيئة الربيئة المستخفي بنفسه، و<b>يحتمل</b> أن يريد بالكالب: الكلب».</div></p><p><h3><span class="qpc-hafs">﴿بَـٰسِطࣱ ذِرَاعَیۡهِ بِٱلۡوَصِیدِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بالوصيد﴾</span>، قال: بالفناء{37}. (٩/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿بالوصيد﴾</span>، قال: بالباب{38}. (٩/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿وكلبهم باسط ذراعيه بالوصيد﴾</span>، يعني: فناءهم. ويُقال: الوصيد: الصعيد{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق هارون بن عنترة- في قوله: <span class="qpc-hafs">﴿بالوصيد﴾</span>، قال: بالصعيد{40}. (٩/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- <span class="qpc-hafs">﴿وكلبهم باسط ذراعيه بالوصيد﴾</span>، قال: بالفناء{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بالوصيد﴾</span>، قال: بالفناء{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿بالوصيد﴾</span>، قال: يعني: بالفناء{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٤<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، في قوله: <span class="qpc-hafs">﴿بالوصيد﴾</span>، قال: بفناء باب الكهف{1}. (٩/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٥<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: الوصيد: عتبة الباب{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وكلبهم باسط ذراعيه بالوصيد﴾</span>، يقول: بفناء الكهف{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السدي</span>: الوصيد: الباب{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿باسط ذراعيه بالوصيد﴾</span>، قال: بالفناء{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٦٩<span class="dash">-</span></span> عن عبد الله بن حميد المكي، في قوله: <span class="qpc-hafs">﴿وكلبهم باسط ذراعيه بالوصيد﴾</span>، قال: جعل رزقه في لحس ذراعيه{1}. (٩/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿باسط ذراعيه بالوصيد﴾</span>، يعني: الفضاء الذي على باب الكهف، وكان الكلب لمكسلمينا، وكان راعي غنم، فبسط الكلب ذراعيه على باب الكهف ليحرسهم، وأنام الله ﷿ الكلب في تلك السنين كما أنام الفتية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿وكلبهم باسط ذراعيه بالوصيد﴾</span>، قال: يمسك عليهم باب الكهف{36}. (٩/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٢<span class="dash">-</span></span> عن عمرو -من طريق الحكم بن بَشير- في قوله: <span class="qpc-hafs">﴿وكلبهم باسط ذراعيه بالوصيد﴾</span>، قال: الوصيد: الصعيد؛ التراب{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٣<span class="dash">-</span></span> عن عُبيد السَّواق، قال: رأيت كلب أصحاب الكهف صغيرًا زِئْنِيًّا -يعني: صِينِيًّا- باسطًا ذراعيه بفناء باب الكهف، وهو يقول هكذا، يضرب بأذنيه{53}<span class=comment-ref>٣٩٧٩</span>. (٩/٥٠٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٧٩</span> اختُلِف في تأويل الوصيد على أقوال: <b>الأول</b>: الفِناء. <b>والثاني</b>: الباب. <b>والثالث</b>: الصَّعيد.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/١٩٤ بتصرف) <span class="mustanad">مستندًا إلى دلالة اللفظ</span> القول الأول والثاني، دون الثالث الذي قاله ابن عباس من طريق العوفي، وسعيد بن جبير، وعمرو، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: الوصيد: الباب، أو فناء الباب حيث يغلق الباب. وذلك أن الباب يوصد، وإيصاده: إطباقه وإغلاقه، من قول الله ﷿: <span class="qpc-hafs">﴿إنها عليهم مؤصدة﴾</span> [الهمزة:٨]... فكأن معنى الكلام: وكلبهم باسط ذراعيه بفناء كهفهم عند الباب، يحفظ عليهم بابه».</p><p>وبنحوه <u>ابنُ عطية</u> (٥/٥٨٢)، و<u>ابنُ كثير</u> (٩/١١٥).</div></p><p><h3><span class="qpc-hafs">﴿لَوِ ٱطَّلَعۡتَ عَلَیۡهِمۡ لَوَلَّیۡتَ مِنۡهُمۡ فِرَارࣰا وَلَمُلِئۡتَ مِنۡهُمۡ رُعۡبࣰا ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: غزونا مع معاوية نحو الروم، فمررنا بالكهف الذي فيه أصحاب الكهف، فقال معاوية: لو كُشِف لنا عن هؤلاء فنظرنا إليهم. فقال ابن عباس ﵃: لقد مُنِع ذلك من هو خير منك، فقال: <span class="qpc-hafs">﴿لو اطلعت عليهم لوليت منهم فرارا﴾</span>. فبعث معاوية ناسًا، فقال: اذهبوا، فانظروا. فلما دخلوا الكهف بعث الله عليهم ريحًا، فأخرجتهم{54}. (٩/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٥<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span>، قال: كان لي صاحب ماضٍ{55} شديد النفس، فمر بجانب كهفهم، فقال: لا أنتهي حتى أنظر إليهم. فقيل له: لا تفعل، أما تقرأ: <span class="qpc-hafs">﴿لو اطلعت عليهم لوليت منهم فرارا ولملئت منهم رعبا﴾</span>؟ فأبى إلا أن ينظر، فأشرف عليهم، فابيضَّتْ عيناه، وتَغَيَّر شعره، وكان يخبر الناس بعد يقول: عدتهم سبعة{1}. (٩/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: لأنّ أعينهم كانت مفتحة كالمستيقظ الذي يريد أن يتكلم، وهم نيام{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول للنبي ﷺ: <span class="qpc-hafs">﴿لو اطلعت عليهم﴾</span> حين نُقَلِّبهم <span class="qpc-hafs">﴿لوليت منهم فرارا ولملئت منهم رعبا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿لو اطلعت عليهم لوليت منهم فرارا ولملئت منهم رعبا﴾</span> لحالهم{3}<span class=comment-ref>٣٩٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٨٠</span> ذكر <u>ابنُ عطية</u> (٥/٥٨٣) قولًا مفاده: أن فتية أهل الكهف إنما حفَّهم هذا الرعب لطول شعورهم وأظفارهم. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لمخالفته لظاهر القرآن</span>، فقال: «وهذا قول بعيد، ولو كانت حالهم هكذا لم يقولوا: <span class="qpc-hafs">﴿لَبِثْنا يَوْمًا أوْ بَعْضَ يَوْمٍ﴾</span>». ثم قال: «وإنما الصحيح في أمرهم: أنّ الله ﷿ حفظ لهم الحالة التي ناموا عليها؛ لتكون لهم ولغيرهم فيهم آية، فلم يبْل لهم ثوب، ولا تغيرت صفة، ولا أنكر الناهض إلى المدينة إلا معالم الأرض والبناء، ولو كانت في نفسه حالة ينكرها لكانت عليه أهم، ولروي ذلك».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٥٧٨.|3:تفسير يحيى بن سلام ١/١٧٥.|4:تفسير الثعلبي ٦/١٦٠.|5:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|6:أخرجه ابن جرير ١٥/١٩١.|7:تفسير الثعلبي ٦/١٦٠.|8:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|9:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:أخرجه مقاتل بن سليمان ٢/٥٧٨.|11:أخرجه ابن جرير ١٥/١٩١. وعزاه السيوطي إلى ابن أبي حاتم.|12:علقه يحيى بن سلام ١/١٧٥.|13:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٩٠-٤٩١ (٣٦٨١٥)، ويحيى بن سلام ١/١٧٥ من طريق قتادة. وعلَّقه ابن جرير ١٥/١٩١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|14:تفسير مقاتل بن سليمان ٢/٥٧٨.|15:تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨. وفي طبعة دار التفسير لتفسير الثعلبي ١٧/٦٦: كان اسمه زبار.|16:تفسير الثعلبي ٦/١٦٠.|17:أخرجه الطبراني في الأوسط (٦١١٣).|18:الغُرَّة -بالضم-: بياض في الجبهة. والأغر: الأبيض من كل شيء. لسان العرب (غرر).|19:تفسير البغوي ٥/١٥٨، وتفسير الثعلبي ٦/١٦٠.|20:تفسير الثعلبي (طبعة دار التفسير) ١٧/٦٨. وتصحفت في طبعة دار إحياء التراث العربي ٦/١٦٠ إلى أصْهَب. وفي تفسير البغوي ٥/١٥٨: صَهِيلَة.|21:عزاه السيوطي إلى ابن أبي حاتم.|22:عزاه السيوطي إلى ابن أبي حاتم.|23:تفسير الثعلبي (طبعة دار التفسير) ١٧/٦٨. وفي طبعة دار إحياء التراث العربي ٦/١٦٠: نقيا.|24:تفسير الثعلبي ٦/١٦٠.|25:أخرجه الثعلبي في تفسيره (ط: دار التفسير) ١٧/٦٧.|26:تفسير البغوي ٥/١٥٨، وفي مطبوعة تفسير الثعلبي ٦/١٦٠: نون.|27:تفسير الثعلبي ٦/١٦٠.|28:تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.|29:الخَلَنج: شجر فارسي مُعرَّب، تُتخذ من خشبه الأواني. لسان العرب (خلنج).|30:تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.|31:كذا في مطبوعة المصدر. ولعله «قطمير» كما تقدم عن غير واحد.|32:تفسير مقاتل بن سليمان ٢/٥٧٨.|33:تفسير البغوي ٥/١٥٨، وفي تفسير الثعلبي ٦/١٦٠: نتوى. وفي طبعة دار التفسير ١٧/٦٦: تنوه.|34:أخرجه إسحاق البستي في تفسيره ص١١٨. وعزاه السيوطي إلى ابن أبي حاتم.|35:أخرجه إسحاق البستي في تفسيره ص١١٨. وعزاه السيوطي إلى ابن أبي حاتم.|36:عزاه السيوطي إلى ابن المنذر.|37:أخرجه ابن جرير ١٥/١٩٢. وعزاه السيوطي إلى ابن المنذر، وأبي حاتم.|38:أخرجه ابن جرير ١٥/١٩٤. وعزاه السيوطي إلى ابن المنذر.|39:أخرجه ابن جرير ١٥/١٩٣.|40:أخرجه ابن جرير ١٥/١٩٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|41:أخرجه ابن جرير ١٥/١٩٢.|42:أخرجه ابن جرير ١٥/١٩٢، ومن طريق ابن جريج أيضًا. وفي تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ١٥/١٥٨ بلفظ: فناء الكهف.|43:أخرجه ابن جرير ١٥/١٩٣. وفي تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨ بلفظ: فناء الكهف.|44:عزاه السيوطي إلى ابن أبي حاتم.|45:تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.|46:أخرجه عبد الرزاق ٢/٣٩٩، وابن جرير ١٥/١٩٣ من طريق سعيد. وعلَّقه يحيى بن سلام ١/١٧٥.|47:تفسير الثعلبي ٦/١٦٠، وتفسير البغوي ٥/١٥٨.|48:أخرجه أبو جعفر الرملي في جزئه ص٩٥ (تفسير عطاء الخراساني).|49:عزاه السيوطي إلى ابن أبي حاتم.|50:تفسير مقاتل بن سليمان ٢/٥٧٨.|51:عزاه السيوطي إلى ابن المنذر.|52:أخرجه ابن جرير ١٥/١٩٣.|53:عزاه السيوطي إلى ابن أبي حاتم، من طريق جرير.|54:أخرجه ابن أبي شيبة -كما في تخريج أحاديث الكشاف ٢/٣١٠، ولم يذكر لفظه-، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٤-٢٤٦-، والثعلبي ٦/١٦١، والبغوي ٥/١٥٩. وعزاه السيوطي إلى ابن المنذر.|55:ذكر محققو الدر أنها في إحدى نسخه: مات.|56:عزاه السيوطي إلى ابن أبي حاتم.|57:تفسير الثعلبي ٦/١٦١، وتفسير البغوي ٥/١٥٩.|58:تفسير مقاتل بن سليمان ٢/٥٧٨.|59:تفسير يحيى بن سلام ١/١٧٥.
  18,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ بَعَثۡنَـٰهُمۡ لِیَتَسَاۤءَلُوا۟ بَیۡنَهُمۡۚ قَالَ قَاۤىِٕلࣱ مِّنۡهُمۡ كَمۡ لَبِثۡتُمۡۖ قَالُوا۟ لَبِثۡنَا یَوۡمًا أَوۡ بَعۡضَ یَوۡمࣲۚ قَالُوا۟ رَبُّكُمۡ أَعۡلَمُ بِمَا لَبِثۡتُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكذلك﴾</span> يعني: وهكذا <span class="qpc-hafs">﴿بعثناهم﴾</span> من نومهم فقاموا؛ <span class="qpc-hafs">﴿ليتساءلوا بينهم﴾</span> فـ<span class="qpc-hafs">﴿قال قائل منهم﴾</span> وهو مكسلمينا، وهو أكبرهم سنًّا: <span class="qpc-hafs">﴿كم لبثتم﴾</span> رقودًا؟ <span class="qpc-hafs">﴿قالوا لبثنا يوما﴾</span> وكانوا دخلوا الغار غدوة، وبعثوا من آخر النهار، فمن ثَمَّ قالوا: <span class="qpc-hafs">﴿أو بعض يوم قالوا﴾</span> يعني: الأكبر، وهو مكسلمينا وحده: <span class="qpc-hafs">﴿ربكم أعلم بما لبثتم﴾</span> في رقودكم منكم. فردوا العلم إلى الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿وكذلك بعثناهم ليتساءلوا بينهم قال قائل منهم كم لبثتم قالوا لبثنا يوما أو بعض يوم﴾</span>، وكانوا دخلوا الكهف في أول النهار. قال: فنظروا، فإذا هو قد بقي من الشمس بَقِيَّة؛ فقالوا: <span class="qpc-hafs">﴿أو بعض يوم﴾</span> ثم إنهم شكوا، فردوا علم ذلك إلى الله، <span class="qpc-hafs">﴿قالوا ربكم أعلم بما لبثتم﴾</span> يقوله بعضهم لبعض{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱبۡعَثُوۤا۟ أَحَدَكُم بِوَرِقِكُمۡ هَـٰذِهِۦۤ إِلَى ٱلۡمَدِینَةِ فَلۡیَنظُرۡ أَیُّهَاۤ أَزۡكَىٰ طَعَامࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أزكى طعاما﴾</span>، قال: أحَلَّ ذبيحةً، وكانوا يذبحون للطواغيت{3}. (٩/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أزكى طعاما﴾</span>، يعني: أطهر؛ لأنهم كانوا يذبحون الخنازير{4}. (٩/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي حصين- <span class="qpc-hafs">﴿أيها أزكى طعاما﴾</span>، قال: أيها أحلُّ{5}<span class=comment-ref>٣٩٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٨١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٥/٥٨٥) على هذا القول الذي قاله ابن عباس، وسعيد بن جبير، بقوله: «من جهة ذبائح الكفرة، وغير ذلك».</div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي حصين-، مثله، إلا أنه قال: أيُّهُ أكثر{6}<span class=comment-ref>٣٩٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٨٢</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١٥/٢١٤) قول عكرمة بقوله: "وإنما وجَّه مَن وجَّه تأويل <span class="qpc-hafs">﴿أزكى﴾</span> إلى الأكثر لأنه وجد العرب تقول: قد زكا مال فلان: إذا كثر، وكما قال الشاعر:</p><p>قبائلنا سبع وأنتم ثلاثة... وللسبع أزكى من ثلاث وأطيب</p><p>بمعنى: أكثر، وذلك وإن كان كذلك فإن الحلال الجيد وإن قل أكثرُ من الحرام الخبيث وإن كثر".</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (٩/١١٨).</div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿أيها أزكى طعاما﴾</span>، قال: أطْيَب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أزكى طعاما﴾</span>، قال: خير طعامًا، يعني: أجوده{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: أجود طعامًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال مكسلمينا: <span class="qpc-hafs">﴿فابعثوا أحدكم بورقكم﴾</span> يعني: الدراهم <span class="qpc-hafs">﴿هذه﴾</span> التي معكم <span class="qpc-hafs">﴿إلى المدينة﴾</span> فبعثوا يمليخا، <span class="qpc-hafs">﴿فلينظر أيها أزكى طعاما﴾</span> يعني: أطيب طعامًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿فابعثوا أحدكم بورقكم هذه﴾</span> أي: بدراهمكم هذه <span class="qpc-hafs">﴿إلى المدينة﴾</span> وكانت معهم دارهم، <span class="qpc-hafs">﴿فلينظر أيها أزكى طعاما﴾</span> وقد كان مِن طعام قومهم ما لا يستحلون أكله{2}<span class=comment-ref>٣٩٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٨٣</span> اختُلِف في المراد بقوله: <span class="qpc-hafs">﴿أيها أزكى طعاما﴾</span> على أقوال: <b>الأول</b>: أكثر طعامًا. <b>والثاني</b>: أحل طعامًا. <b>والثالث</b>: خير طعامًا.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٢١٣-٢١٤) القول الثاني والثالث <span class="mustanad">مستندًا إلى الدلالات العقلية</span>، فقال: «وأولى الأقوال عندي في ذلك بالصواب قولُ مَن قال: معنى ذلك: أحل وأطهر. وذلك أنّه لا معنى في اختيار الأكثر طعامًا للشراء منه، إلا بمعنى إذا كان أكثرهم طعامًا، كان خليقًا أن يكون الأفضل منه عنده أوجد، وإذا شُرط على المأمور الشراء من صاحب الأفضل فقد أمر بشراء الجيد، كان ما عند المشتري ذلك منه قليلًا الجيد أو كثيرًا».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (٩/١١٨).</div></p><p><h3><span class="qpc-hafs">﴿فَلۡیَأۡتِكُم بِرِزۡقࣲ مِّنۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٩٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبيد بن عمير</span> -من طريق عبد العزيز بن أبي روّاد- <span class="qpc-hafs">﴿فليأتكم برزق منه﴾</span>، قال: بطعام{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیَتَلَطَّفۡ وَلَا یُشۡعِرَنَّ بِكُمۡ أَحَدًا ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وليتلطف﴾</span> يعني: ولْيَتَرَفَّق حتى لا يُفْطَنَ له، <span class="qpc-hafs">﴿ولا يشعرن بكم أحدا﴾</span> يعني: ولا يعلمنَّ بمكانكم أحدًا من الناس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿فليأتكم برزق منه وليتلطف ولا يشعرن﴾</span>: لا يُعْلِمَنَّ{14}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٧٩.|2:تفسير يحيى بن سلام ١/١٧٥.|3:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.|4:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|5:أخرجه يحيى بن سلام ١/١٧٥، وعبد الرزاق ٢/٤٠٠، وابن جرير ١٥/٢١٣.|6:أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/٢١٣.|7:تفسير الثعلبي ٦/١٦١.|8:أخرجه عبد الرزاق ٢/٤٠٠، وابن جرير ١٥/٢١٣.|9:تفسير الثعلبي ٦/١٦١، وتفسير البغوي ٥/١٦٠.|10:تفسير مقاتل بن سليمان ٢/٥٧٩. وأخرج ابن جرير ١٥/٢١٢ من طريق سفيان عن مقاتل دون تعيين: <span class="qpc-hafs">﴿فابعثوا أحدكم بورقكم هذه﴾</span>: اسمه يمليخ.|11:تفسير يحيى بن سلام ١/١٧٥.|12:أخرجه ابن جرير ١٥/٢١٤.|13:تفسير مقاتل بن سليمان ٢/٥٧٩.|14:تفسير يحيى بن سلام ١/١٧٦.
  18,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ إِن یَظۡهَرُوا۟ عَلَیۡكُمۡ یَرۡجُمُوكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنهم إن يظهروا عليكم يرجموكم﴾</span>، يعني: يقتلوكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿إنهم إن يظهروا عليكم يرجموكم﴾</span>، قال: يشتموكم بالقول؛ يؤذوكم{2}<span class=comment-ref>٣٩٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٨٤</span> لم يذكر <u>ابنُ جرير</u> (١٥/٢١٥) غير قول ابن جريج.</div></p><p><div></p><p><p><span class="item-no">٤٤٥٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿إنهم إن يظهروا عليكم يرجموكم﴾</span> يقتلوكم بالحجارة{3}<span class=comment-ref>٣٩٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩٨٥</span> اختُلِف هل المراد الرجم بالحجارة، أو بالقول؟</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٥/٥٨٦) <span class="mustanad">مستندًا إلى دلالة العقل، والتاريخ</span> القولَ الأول الذي قاله مقاتل، وابن سلام، فقال: «وهو الأصح؛ لأنه كان عازمًا على قتلهم لو ظفر بهم، والرجم فيما سلف هي كانت -على ما ذكر- قِتْلة مخالف دين الناس، إذ هي أشفى لجملة ذلك في الدين، ولهم فيها مشاركة».</div></p><p><h3><span class="qpc-hafs">﴿أَوۡ یُعِیدُوكُمۡ فِی مِلَّتِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو يعيدوكم في ملتهم﴾</span>، يعني: في دينهم: الكفر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿أو يعيدوكم في ملتهم﴾</span> في الكفر{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَن تُفۡلِحُوۤا۟ إِذًا أَبَدࣰا ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٥٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولن تفلحوا إذا أبدا﴾</span>، كان هذا مِن قول مكسلمينا يقوله للفتية، فلما ذهب يمليخا إلى القرية أنكروا دراهم دقيوس الجبار الذي فرَّ منه الفتية، فلما رأوا ذلك قالوا: هذا رجل وجد كنزًا. فلما خاف أن يُعَذَّب أخبرهم بأمر الفتية، فانطلقوا معه إلى الكهف، فلما انتهى يمليخا إلى الكهف ودخل سدَّ اللهُ ﷿ بابَ الكهف عليهم، فلم يخلص إليهم أحد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام:</span> <span class="qpc-hafs">﴿ولن تفلحوا إذا أبدا﴾</span> إن فعلتم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٧٩.|2:أخرجه ابن جرير ١٥/٢١٥.|3:تفسير يحيى بن سلام ١/١٧٦.|4:تفسير مقاتل بن سليمان ٢/٥٧٩.|5:تفسير يحيى بن سلام ١/١٧٦.|6:تفسير مقاتل بن سليمان ٢/٥٧٩.|7:تفسير يحيى بن سلام ١/١٧٦.