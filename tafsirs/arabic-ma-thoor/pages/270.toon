quran[8]{c,v,t}:
  16,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ یَوۡمَ ٱلۡقِیَـٰمَةِ یُخۡزِیهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٠٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى الخرّاصين في التقديم، فقال سبحانه: <span class="qpc-hafs">﴿ثم يوم القيامة يخزيهم﴾</span>، يعني: يعذبهم. كقوله سبحانه: <span class="qpc-hafs">﴿يَوْمَ لا يُخْزِي اللَّهُ النَّبِيَّ والَّذِينَ آمَنُوا مَعَهُ﴾</span> [التحريم:٨]، يعني: لا يعذب الله النبيَّ والمؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٠٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ثم يوم القيامة يخزيهم﴾</span> في النار، بعد عذاب الدنيا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَقُولُ أَیۡنَ شُرَكَاۤءِیَ ٱلَّذِینَ كُنتُمۡ تُشَـٰۤقُّونَ فِیهِمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٠٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿تُشاقون فيهم﴾</span>، يقول: تُخالفوني{3}<span class=comment-ref>٣٦٦١</span>. (٩/٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٦١</span> لم يذكر <u>ابنُ جرير</u> (١٤/٢٠٨) في معنى: <span class="qpc-hafs">﴿تُشاقُّونَ فِيهِمْ﴾</span> سوى قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٤١٠٩٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿تشاقون فيهم﴾</span>، يعني: تُحاجُّون فيهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٠٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويقول أين شركائي الذين كنتم تشاقون﴾</span> يعني: تحاجون <span class="qpc-hafs">﴿فيهم﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٠٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ويقول أين شركائي﴾</span> أي: الذين زعمتم أنهم شركائي، <span class="qpc-hafs">﴿الذين كنتم تشاقون فيهم﴾</span> تفارقون فيهم، يعني: المحاربة والعداوة. عادوا اللهَ في الأوثان، فعبدوها من دونه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ ٱلَّذِینَ أُوتُوا۟ ٱلۡعِلۡمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٠٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال الذين أوتوا العلم﴾</span> وهم الحَفَظَة من الملائكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٠٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال الذين أوتوا العلم﴾</span> وهم المؤمنون{2}<span class=comment-ref>٣٦٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٦٢</span> ذكر <u>ابنُ عطية</u> (٥/٣٤٦) في معنى قوله تعالى: <span class="qpc-hafs">﴿قالَ الَّذِينَ أُوتُوا العِلْمَ﴾</span> قول مقاتل، ويحيى بن سلام، ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والصواب أن <span class="mustanad">يعمَّ</span> جميع مَن آتاه الله علم ذلك مِن جميع مَن حضر الموقف مِن مَلَك أو إنسي، وغير ذلك».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡخِزۡیَ ٱلۡیَوۡمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٠٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الخزي اليوم﴾</span>، يعني: الهوان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٠٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن الخزي اليوم﴾</span>، يعني: إن الهوان اليوم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلسُّوۤءَ عَلَى ٱلۡكَـٰفِرِینَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٠٠<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿والسوء﴾</span>، يعني: العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسوء﴾</span> يعني: العذاب <span class="qpc-hafs">﴿على الكافرين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿على الكافرين﴾</span>، وهذا الكلام يوم القيامة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٦.|2:تفسير يحيى بن سلام ١/٦٠.|3:أخرجه ابن جرير ١٤/٢٠٨، وابن أبي حاتم -كما في الإتقان ٢/٢٣-.|4:علَّقه يحيى بن سلام ١/٦٠.|5:تفسير مقاتل بن سليمان ٢/٤٦٦.|6:تفسير يحيى بن سلام ١/٦٠.|7:تفسير مقاتل بن سليمان ٢/٤٦٦.|8:تفسير يحيى بن سلام ١/٦٠.|9:تفسير مقاتل بن سليمان ٢/٤٦٦.|10:تفسير يحيى بن سلام ١/٦٠.|11:علَّقه يحيى بن سلام ١/٦٠.|12:تفسير مقاتل بن سليمان ٢/٤٦٦.|13:تفسير يحيى بن سلام ١/٦٠.
  16,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ ظَالِمِیۤ أَنفُسِهِمۡۖ فَأَلۡقَوُا۟ ٱلسَّلَمَ مَا كُنَّا نَعۡمَلُ مِن سُوۤءِۭۚ بَلَىٰۤۚ إِنَّ ٱللَّهَ عَلِیمُۢ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤١١٠٣<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (الَّذِينَ تَوَفّاهُمُ المَلائِكَةُ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ ظَالِمِیۤ أَنفُسِهِمۡۖ فَأَلۡقَوُا۟ ٱلسَّلَمَ مَا كُنَّا نَعۡمَلُ مِن سُوۤءِۭۚ بَلَىٰۤۚ إِنَّ ٱللَّهَ عَلِیمُۢ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤١١٠٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمرو بن دينار- قال: كان ناس بمكة أقرُّوا بالإسلام ولم يهاجروا، فأُخرِج بهم كَرْهًا إلى بدر، فقُتِل بعضهم؛ فأنزل الله فيهم: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة ظالمي أنفسهم﴾</span>{2}<span class=comment-ref>٣٦٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٦٣</span> <span class="comment-type-2">استدرك</span> <u>ابن عطية</u> (٥/٣٤٧) <span class="mustanad">مستندًا إلى أحوال النزول</span> على قول عكرمة، فقال: «وإنما اشتبهت عليه بالآية الأخرى التي نزلت في أولئك باتفاقٍ من العلماء». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وعلى هذا القول يحسن قطع <span class="qpc-hafs">﴿الَّذِينَ﴾</span>، ورفعه بالابتداء».</div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ ظَالِمِیۤ أَنفُسِهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٠٥<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: عنى بذلك: مَن قُتِل من قريش وأهل مكة ببدر وقد أخرج إليها كرهًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٠٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: هي وفاة إلى النار؛ حشر إلى النار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتهم، فقال: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة﴾</span> يعني: ملك الموت وأعوانه <span class="qpc-hafs">﴿ظالمي أنفسهم﴾</span> وهم ستة؛ ثلاثة يَلُون أرواح المؤمنين، وثلاثة يَلُون أرواح الكافرين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة ظالمي أنفسهم﴾</span>، قال بعضهم: توفاهم عند الموت{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَلۡقَوُا۟ ٱلسَّلَمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٠٩<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: فأعْطَوُا الإسلام؛ أسلموا فلم يقبل ذلك منهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١١٠<span class="dash">-</span></span> تفسير <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿فألقوا السلم﴾</span>: استسلموا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فألقوا السلم﴾</span>، يعني: الخضوع والاستسلام{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا كُنَّا نَعۡمَلُ مِن سُوۤءِۭۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١١٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: إن في القيامة مواطن؛ فمنها موطن يُقِرُّون فيه بأعمالهم الخبيثة، وهو قوله: <span class="qpc-hafs">﴿وشهدوا على أنفسهم أنهم كانوا كافرين﴾</span> [الأنعام:١٣٠]، ومنها موطن يجحدون فيه، فقالوا: <span class="qpc-hafs">﴿ما كنا نعمل من سوء﴾</span>. فقيل لهم: <span class="qpc-hafs">﴿بلى إن الله عليم بما كنتم تعملون﴾</span> [النحل:٢٨] في الدنيا أنكم مشركون. وقالوا: <span class="qpc-hafs">﴿والله ربنا ما كنا مشركين انظر كيف كذبوا على أنفسهم﴾</span> فادَّعَوْا أنهم لم يكونوا مشركين، <span class="qpc-hafs">﴿وضل عنهم ما كانوا يفترون﴾</span> [الأنعام: ٢٤] من عبادتهم الأوثان، فلم تغن عنهم شيئًا. وإنّ آخرها موطنًا أن يختم على أفواههم، وتَكَلَّمَ أيديهم، وتشهد أرجلهم بما كانوا يكسبون: يعملون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١١٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ما كنا نعمل من سوء﴾</span>: يعني: مِن شرك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قالوا: <span class="qpc-hafs">﴿ما كنا نعمل من سوء﴾</span>، يعني: مِن شرك، لقولهم في الأنعام [٢٣]: <span class="qpc-hafs">﴿والله ربنا ما كنا مشركين﴾</span>{5}<span class=comment-ref>٣٦٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٦٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٥/٣٤٧) في معنى: <span class="qpc-hafs">﴿ما كُنّا نَعْمَلُ مِن سُوء﴾</span>: «ويحتمل قولهم: <span class="qpc-hafs">﴿ما كُنّا نَعْمَلُ مِن سُوءٍ﴾</span> وجهين: <b>أحدهما</b>: أنهم كذبوا وقصدوا الكذب اعتصامًا منهم به، على نحو قولهم: <span class="qpc-hafs">﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</span> [الأنعام:٢٣]. <b>والآخر</b>: أنهم أخبروا عن أنفسهم أنهم لم يكونوا يعملون سوءًا، فأخبروا عن ظنهم بأنفسهم، وهو كذب في نفسه».</div></p><p><h3><span class="qpc-hafs">﴿بَلَىٰۤۚ إِنَّ ٱللَّهَ عَلِیمُۢ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فكذبهم الله ﷿، فردَّت عليهم خزنة جهنم مِن الملائكة، فقالوا: <span class="qpc-hafs">﴿بلى﴾</span> قد عملتم السوء، <span class="qpc-hafs">﴿إن الله عليم بما كنتم تعملون﴾</span> يعني: بما كنتم مشركين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢١.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٥/٤٧٢.|2:أخرجه ابن جرير ١٤/٢٠٨.|3:تفسير الثعلبي ٦/١٤، وتفسير البغوي ٤/١٧.|4:علقه يحيى بن سلام ١/٦٠.|5:تفسير مقاتل بن سليمان ٢/٤٦٦.|6:تفسير يحيى بن سلام ١/٦٠.|7:علَّقه يحيى بن سلام ١/٦٠.|8:علَّقه يحيى بن سلام ١/٦٠.|9:تفسير مقاتل بن سليمان ٢/٤٦٦.|10:علَّقه يحيى بن سلام ١/٦٠.|11:علَّقه يحيى بن سلام ١/٦٠.|12:تفسير مقاتل بن سليمان ٢/٤٦٦.|13:تفسير مقاتل بن سليمان ٢/٤٦٦.
  16,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱدۡخُلُوۤا۟ أَبۡوَ ٰ⁠بَ جَهَنَّمَ خَـٰلِدِینَ فِیهَاۖ فَلَبِئۡسَ مَثۡوَى ٱلۡمُتَكَبِّرِینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالت الخزنة لهم: <span class="qpc-hafs">﴿فادخلوا أبواب جهنم خالدين فيها﴾</span> من الموت، <span class="qpc-hafs">﴿فلبئس مثوى﴾</span> يعني: مأوى <span class="qpc-hafs">﴿المتكبرين﴾</span> عن التوحيد. فأخبر الله عنهم في الدنيا، وأخبر بمصيرهم في الآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿خالدين فيها فلبئس مثوى المتكبرين﴾</span> عن عبادة الله{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٦.|2:تفسير يحيى بن سلام ١/٦١.
  16,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقِیلَ لِلَّذِینَ ٱتَّقَوۡا۟﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤١١١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> في قوله تعالى: <span class="qpc-hafs">﴿ماذا أنزل ربكم قالوا خيرا﴾</span>: وذلك أن الرجل كان يبعثه قومه وافدًا إلى مكة، ليأتيهم بخبر محمد ﷺ، فيأتي الموسم، فيمر على هؤلاء الرهط من قريش الذين على طريق مكة، فيسألهم عن النبي ﷺ: فيصدونه عنه لئلّا يلقاه. فيقول: بئس الرجل الوافد أنا لقومي أن أرجع قبل أن ألقى محمدًا ﷺ وأنا منه على مسيرة ليلة أو ليلتين، وأسمع منه. فيسير حتى يدخل مكة، فيلقى المؤمنين، فيسألهم عن النبي ﷺ، وعن قولهم، فيقولون للوافد: أنزَل اللهُ ﷿ خيرًا؛ بعث رسولًا ﷺ، وأنزل كتابًا يأمر فيه بالخير، وينهى عن الشر. ففيهم نزلت: <span class="qpc-hafs">﴿وقيل للذين اتقوا ماذا أنزل ربكم قالوا خيرا﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقِیلَ لِلَّذِینَ ٱتَّقَوۡا۟﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤١١١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقيل للذين اتقوا﴾</span>، قال: هؤلاء المؤمنون{2}. (٩/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال تعالى: <span class="qpc-hafs">﴿وقيل للذين اتقوا﴾</span>، يعني: الذين عبدوا ربهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَاذَاۤ أَنزَلَ رَبُّكُمۡۚ قَالُوا۟ خَیۡرࣰاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٢١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- يقال لهم: <span class="qpc-hafs">﴿ماذا أنزل ربكم﴾</span>؟ فيقولون: <span class="qpc-hafs">﴿خيرًا﴾</span>{2}. (٩/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال تعالى: <span class="qpc-hafs">﴿ماذا أنزل ربكم قالوا﴾</span> أنزل <span class="qpc-hafs">﴿خيرا﴾</span> ... ثم انقطع الكلام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقيل للذين اتقوا ماذا أنزل ربكم قالوا خيرا﴾</span>، أي: أنزل خيرًا. ثم انقطع الكلام{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّلَّذِینَ أَحۡسَنُوا۟ فِی هَـٰذِهِ ٱلدُّنۡیَا حَسَنَةࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٢٤<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>إنّ الله لا يظلم المؤمن حسنة؛ يثاب عليها الرزق في الدنيا، ويُجزى بها في الآخرة</b>»{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٥<span class="dash">-</span></span> قال يحيى بن سلّام: وبلغني عن <span class="name-1">علي بن أبي طالب</span> في تفسيرها نحو ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا فِي هَذِهِ الدُّنْيا حَسَنَةٌ﴾</span>: هي تضعيف الأجر إلى العشر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا فِي هَذِهِ الدُّنْيا حَسَنَةٌ﴾</span>: هي الرزق الحسن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٨<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا فِي هَذِهِ الدُّنْيا حَسَنَةٌ﴾</span>: هي النصر، والفتح{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٢٩<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، يقول: للذين أحسنوا في هذه الدنيا؛ تكون لهم حسنتهم في الآخرة الجنة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿للذين أحسنوا﴾</span>، أي: آمنوا بالله، وكتبه، وأمَرُوا بطاعته، وحَثُّوا عباد الله على الخير، ودَعَوهم إليه{13}. (٩/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿للذين أحسنوا في هذه الدنيا حسنة﴾</span>، يقول: مال{14}. (٩/٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله سبحانه: <span class="qpc-hafs">﴿للذين أحسنوا﴾</span> العمل <span class="qpc-hafs">﴿في هذه الدنيا﴾</span> لهم <span class="qpc-hafs">﴿حسنة﴾</span> في الآخرة، يعني: الجنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿للذين أحسنوا﴾</span> آمنوا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَدَارُ ٱلۡـَٔاخِرَةِ خَیۡرࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٣٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيُّ</span>: <span class="qpc-hafs">﴿ولدار الآخرة خير﴾</span>، وهي الجنة{14}. (٩/٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال تعالى: <span class="qpc-hafs">﴿ولدار الآخرة خير﴾</span>، يعني: الجنة أفضل من ثواب المشركين في الدنيا الذي ذكر في هذه الآية الأولى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولدار الآخرة خير﴾</span> من الدنيا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَنِعۡمَ دَارُ ٱلۡمُتَّقِینَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿ولنعم دار المتقين﴾</span> الشركَ، يُثنِي على الجنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولنعم دار المتقين﴾</span> الجنة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٧.|2:أخرجه ابن جرير ١٤/٢١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٤٦٦.|4:أخرجه ابن جرير ١٤/٢١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٤٦٧.|6:تفسير يحيى بن سلام ١/٦١.|7:أخرجه مسلم ٤/٢١٦٢ (٢٨٠٨) مطولًا، ويحيى بن سلام ١/٦١، وابن جرير ٧/٣٠، ٢٤/٥٦٨. وأورده الثعلبي ٣/٣٠٨.|8:تفسير يحيى بن سلام ١/٦١.|9:تفسير البغوي ٥/١٧.|10:تفسير البغوي ٥/١٧.|11:تفسير البغوي ٥/١٧.|12:علَّقه يحيى بن سلام ١/٦١.|13:أخرجه ابن جرير ١٤/٢١١ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|14:عزاه السيوطي إلى ابن أبي حاتم.|15:تفسير مقاتل بن سليمان ٢/٤٦٧.|16:تفسير يحيى بن سلام ١/٦١.|17:عزاه السيوطي إلى ابن أبي حاتم.|18:تفسير مقاتل بن سليمان ٢/٤٦٧.|19:تفسير يحيى بن سلام ١/٦١.|20:تفسير مقاتل بن سليمان ٢/٤٦٧.|21:تفسير يحيى بن سلام ١/٦١.
  16,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ یَدۡخُلُونَهَا تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم بَيَّنَ لهم الدار، فقال سبحانه: <span class="qpc-hafs">﴿جنات عدن يدخلونها تجري من تحتها الأنهار﴾</span>، يعني: الأنهار تجري تحت البساتين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿جنات عدن يدخلونها تجري من تحتها الأنهار﴾</span>، وقد فسرنا <span class="qpc-hafs">﴿عدن﴾</span> قبل هذا الموضع، نُسِبَتِ الجنانُ كلُّها إليها{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَهُمۡ فِیهَا مَا یَشَاۤءُونَۚ كَذَ ٰ⁠لِكَ یَجۡزِی ٱللَّهُ ٱلۡمُتَّقِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لهم فيها ما يشاءُون﴾</span> يعني: في الجنان، <span class="qpc-hafs">﴿كذلك يجزي الله المتقين﴾</span> الشرك{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٧.|2:تفسير يحيى بن سلام ١/٦١.|3:تفسير مقاتل بن سليمان ٢/٤٦٧.
  16,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ طَیِّبِینَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة طيبين﴾</span>، قال: أحياءً وأمواتًا، قدَّر الله ذلك لهم{1}. (٩/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: زاكية أفعالهم وأقوالهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال -جلَّ ثناؤه-: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة طيبين﴾</span> في الدنيا، يعني: ملك الموت وحده، ثم انقطع الكلام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة﴾</span> تقبض أرواحهم <span class="qpc-hafs">﴿طيبين﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَقُولُونَ سَلَـٰمٌ عَلَیۡكُمُ ٱدۡخُلُوا۟ ٱلۡجَنَّةَ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٤٦<span class="dash">-</span></span> عن تميم الداري، عن النبي ﷺ، قال: «<b>يقول الله لملك الموت: انطلق إلى وليي، فائتني به، فإني قد جربته بالسراء والضراء فوجدته حيث أحب، فائتني به لأريحه من هموم الدنيا وغمومها. فينطلق إليه ملك الموت، ومعه خمسمائة من الملائكة، معهم أكفان وحَنُوطٌ من حنوط الجنة، ومعهم ضَبائِرُ</b>{5} <b>الريحان، أصل الريحانة واحد وفي رأسها عشرون لونًا، لكل لون منها ريح سوى ريح صاحبه، ومعهم الحرير الأبيض فيه المسك الأَذْفَر، فيجلس ملك الموت عند رأسه، وتَحْتَوِشُهُ</b>{6} <b>الملائكة، ويضع كل ملَك منهم يده على عضو من أعضائه، ويبسط ذلك الحرير الأبيض والمسك الأذفر تحت ذقنه، ويفتح له باب إلى الجنة، فإن نفسه لَتَعَلَّلُ</b>{7} <b>عند ذلك بطرف الجنة؛ مرة بأزواجها، ومرة بكسوتها، ومرة بثمارها، كما يعلل الصبيَّ أهلُه إذا بكى، وإن أزواجه لَيَبْتَهِشْنَ</b>{8} <b>عند ذلك ابتهاشًا، وتَنزُو</b>{9} <b>الروح نَزْوًا، ويقول ملك الموت: اخرجي أيتها الروح الطيبة إلى سدر مخضود، وطلح منضود، وظل ممدود، وماء مسكوب. وملَك الموت أشدُّ تلطُّفًا به من الوالدة بولدها، يعرف أن ذلك الروح حبيب إلى ربه، كريم على الله، فهو يلتمس بلطفه تلك الروح رضا الله عنه، فسلَّ روحه كما تُسَلُّ الشعرة من العجين، وإن روحه لتخرج والملائكة حوله يقولون: سلام عليكم، ادخلوا الجنة بما كنتم تعملون. وذلك قوله: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة طيبين يقولون سلام عليكم﴾</span>. قال: <span class="qpc-hafs">﴿فأما إن كان من المقربين فروح وريحان وجنة نعيم﴾</span></b> [الواقعة:٨٩]. <b>قال: روح من جهد الموت، وروح يؤتى به عند خروج نفسه، وجنة نعيم أمامه. فإذا قبض ملك الموت روحه يقول الروح للجسد: لقد كنت بي سريعًا إلى طاعة الله، بطيئًا عن معصيته، فهنيئًا لك اليوم؛ فقد نجوت وأنجيت. ويقول الجسد للروح مثل ذلك، وتبكي عليه بقاع الأرض التي كان يطيع الله عليها كل باب من السماء كان يصعد منه عمله وينزل منه رزقه أربعين ليلة، فإذا قبضت الملائكة روحه أقامت الخمسمائة ملك عند جسده، لا يقلبه بنو آدم لشِقٍّ إلا قلبته الملائكة ﵈ قبلهم، وعَلَتْه بأكفان قبل أكفانهم، وحنوط قبل حنوطهم، ويقوم من باب بيته إلى باب قبره صفّان من الملائكة يستقبلونه بالاستغفار، ويصيح إبليس عند ذلك صيحة تَتَصَدَّع منها بعض عظام جسده، ويقول لجنوده: الويل لكم؛ كيف خلص هذا العبد منكم؟ فيقولون: إنّ هذا كان معصومًا. فإذا صعد ملك الموت بروحه إلى السماء يستقبله جبريل في سبعين ألفًا من الملائكة، كلهم يأتيه من ربه، فإذا انتهى ملك الموت إلى العرش خرَّت الروح ساجدة لربها، فيقول الله لملك الموت: انطلق بروح عبدي فضعه في سدر مخضود، وطلح منضود، وظل ممدود، وماء مسكوب. فإذا وُضِع في قبره جاءت الصلاة فكانت عن يمينه، وجاء الصيام فكان عن يساره، وجاء القرآن والذِّكر فكانا عند رأسه، وجاء مشيه إلى الصلاة فكان عند رجليه، وجاء الصبر فكان ناحية القبر، ويبعث الله عُنُقًا من العذاب فيأتيه عن يمينه، فتقول الصلاة: وراءكَ، واللهِ، ما زال دائبًا عمره كله، وإنما استراح الآن حين وضع في قبره. فيأتيه عن يساره، فيقول الصيام مثل ذلك، فيأتيه من قِبَل رأسه، فيقول له مثل ذلك، فلا يأتيه العذاب من ناحية فيلتمس هل يجد لها مساغًا إلا وجد وليَّ الله قد أحرزته الطاعة، فيخرج عنه العذاب عندما يرى، ويقول الصبرُ لسائر الأعمال: أما إنه لم يمنعني أن أباشره بنفسي إلا أني نظرت ما عندكم، فلو عجزتم كنت أنا صاحبُه، فأما إذا أجزأتم عنه فأنا ذخر له عند الميزان. قال: ويبعث الله إليه ملَكين أبصارهما كالبرق الخاطف، وأصواتهما كالرعد القاصف، وأنيابهما كالصَّياصِيِّ</b>{10}، <b>وأنفاسهما كاللهب؛ يطآن في أشعارهما بين منكبي كل واحد منهما مسيرة كذا وكذا، قد نزعت منهما الرأفة والرحمة إلا بالمؤمنين، يقال لهما: منكر ونكير، وفي يد كل واحد منهما مطرقة لو اجتمع عليها الثقلان لم يقلوها. فيقولان له: اجلس. فيستوي جالسًا في قبره، فتسقط أكفانه في حقويه، فيقولان له: من ربك؟ وما دينك؟ ومن نبيك؟ فيقول: ربي الله وحده لا شريك له، والإسلام ديني، ومحمد نبي، وهو خاتم النبيين. فيقولان له: صدقت، فيدفعان القبر، فيُوسِّعانه من بين يديه، ومن خلفه، وعن يمينه، وعن يساره، ومن قِبَل رأسه، ومن قِبَل رجليه، ثم يقولان له: انظر فوقك. فينظر، فإذا هو مفتوح إلى الجنة، فيقولان له: هذا منزلك، يا وليَّ الله، لِما أطعت الله».</b> قال رسول الله ﷺ: <b>«فوالذي نفس محمد بيده، إنه لتصل إلى قلبه فرحة لا تَرْتَدُّ أبدًا، فيقال له: انظر تحتك. فينظر تحته، فإذا هو مفتوح إلى النار، فيقولان: يا وليَّ الله، نجوت من هذا. فوالذي نفسي بيده، إنّه لَتَصِل إلى قلبه عند ذلك فرحة لا ترتد أبدًا، ويفتح له سبعة وسبعون بابًا إلى الجنة يأتيه ريحها وبردها حتى يبعثه الله تعالى من قبره».</b> قال: <b>«ويقول الله تعالى لملَك الموت: انطلق إلى عدوي، فائتني به، فإني قد بسطت له رزقي، وسربلته نعمتي، وأبى إلا معصيتي، فائتني به لأنتقم منه اليوم. فينطلق إليه ملك الموت في أكره صورة رآها أحد من الناس، له ثنتا عشرة عينًا، ومعه سَفُّودٌ</b>{11} <b>من النار كثير الشوك، ومعه خمسمائة من الملائكة، معهم نحاس وجمر مِن جمر جهنم، معهم سياط من النار تأجج، فيضربه ملك الموت بذلك السفود ضربة، يغيب أصلُ كل شوكة من ذلك السفود في أصل كل شعرة وعِرق من عروقه، ثم يلويه ليًّا شديدًا، فينزع روحَه من أظفار قدميه، فيلقيها في عقبيه، فيسكر عدوُّ الله عند ذلك سكرة، وتضرب الملائكة وجهه ودبره بتلك السياط، ثم يجذبه جذبة، فينزع روحه من عَقِبَيه، فيلقيها في ركبتيه، فيسكر عدوُّ الله سكرة، وتضرب الملائكة وجهه ودبره، ثم كذلك إلى حقويه، ثم كذلك إلى صدره، ثم كذلك إلى حلقه، ثم تبسط الملائكة ذلك النحاس وجمر جهنم تحت ذقنه، ثم يقول ملك الموت: اخرجي -أيتها النفس اللعينة الملعونة- إلى سموم وحميم، وظل من يحموم، لا بارد ولا كريم. فإذا قبض ملك الموت روحه قالت الروح للجسد: جزاك الله عني شرًّا، لقد كنت بي سريعًا إلى معصية الله، بطيئًا بي عن طاعة الله، فقد هلكت وأهلكت. ويقول الجسد للروح مثل ذلك، وتلعنه بقاع الأرض التي كان يعصي الله تعالى عليها، وتنطلق جنود إبليس إليه يُبَشِّرونه بأنهم قد أوردوا عبدًا من بني آدم النار، فإذا وضع في قبره ضُيِّق عليه قبرُه حتى تختلف أضلاعه؛ فتدخل اليمنى في اليسرى، واليسرى في اليمنى، ويبعث الله إليه حيّات دهمًا، تأخذ بأرنبته وإبهام قدميه، فتقرِضُه حتى تلتقي في وسطه، قال: ويبعث الله إليه الملَكين، فيقولان له: من ربك؟ وما دينك؟ ومن نبيُّك، فيقول: لا أدري. فيقال له: لا دريت، ولا تليت. فيضربانه ضربة يتطاير الشرار في قبره، ثم يعود، فيقولان له: انظر فوقك. فينظر، فإذا باب مفتوح من الجنة، فيقولان: عدوَّ الله، لو أطعت اللهَ كان هذا منزلك. فوالذي نفس محمد بيده، إنّه لتصل إلى قلبه عند ذلك حسرةٌ لا ترتدُّ أبدًا، ويفتح له باب إلى النار، فيقال: عدوَّ الله، هذا منزلك لما عصيت الله. ويفتح له سبعة وسبعون بابًا إلى النار، يأتيه حرها وسمومها، حتى يبعثه الله يوم القيامة إلى النار</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي صخر- قال: إذا استنقَعَتْ{13} نفسُ العبد المؤمن جاءه الملَك، فقال: السلام عليك، وليَّ الله، الله يقرأ عليك السلام. ثم نزع{14} بهذه الآية: <span class="qpc-hafs">﴿الذين تتوفاهم الملائكة طيبين يقولون سلام عليكم﴾</span>{15}. (٩/٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر سبحانه عن قول خَزَنَة الجنة من الملائكة في الآخرة لهم: <span class="qpc-hafs">﴿يقولون سلام عليكم ادخلوا الجنة بما كنتم تعملون﴾</span> في دار الدنيا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٤٩<span class="dash">-</span></span> عن <span class="name-3">حيوة بن شريح</span>، قال: إنّ الملائكة تأتي ولي الله عند الموت، فتقول: السلام عليك، يا ولي الله، الله يقرأ عليك السلام. وتبشره بالجنة. قال <span class="name-3">يحيى بن سلّام</span>: فهو قوله: <span class="qpc-hafs">﴿تتوفاهم الملائكة طيبين يقولون سلام عليكم﴾</span>{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٠<span class="dash">-</span></span> عن <span class="name-3">الخليل بن مرة</span>، قال: يقول الله: ادخلوا الجنة برحمتي، واقتسموها بأعمالكم{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/٦٢ من طريق ابن مجاهد، وابن جرير ١٤/٢١٢-٢١٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:تفسير الثعلبي ٦/١٥، وتفسير البغوي ٥/١٧.|3:تفسير مقاتل بن سليمان ٢/٤٦٧.|4:تفسير يحيى بن سلام ١/٦١.|5:ضَبَّر الشيء: جمعه. لسان العرب (ضبر).|6:يقال: احتوش القوم على فلان إذا جعلوه وسْطهم. النهاية (حوش).|7:تَعَلَّلَ بالأمر واعْتَلَّ: تشاغل. لسان العرب (علل).|8:البَهْش: الإسراع إلى المعروف بالفرح. لسان العرب (بهش).|9:قال ابن فارس: النون والزاء أصلٌ صحيح يدل على خِفة وقِلة. معجم مقاييس اللغة (نز).|10:الصياصي: جمع صيصية، وهي قرن البقر والظباء. تاج العروس (صيص).|11:السَّفُّودُ والسُّفُّود -بالتشديد-: حديدة ذات شُعَب، مُعَقَّفَة، يُشوى به اللحم. لسان العرب (سفد).|12:أخرجه أبو يعلى-كما في تفسير ابن كثير ٤/٥٠٤-٥٠٧-.</p><p>قال ابن كثير: «هذا حديث غريب جدًّا، وسياق عجيب، ويزيد الرقاشي -راويه عن أنس- له غرائب ومنكرات، وهو ضعيف الرواية عند الأئمة». وقال ابن حجر في المطالب العالية ١٨/٥٤٠-٥٤٥ (٤٥٥٨): «هذا حديث عجيب السياق، وهو شاهد لكثير مما ثبت في حديث البراء ﵁ الطويل المشهور، ولكن هذا الإسناد غريب، لا نعرف أحدًا روى عن أنس عن تميم الداري ﵄ إلا من هذا الوجه، ويزيد الرقاشي سيء الحفظ جدًّا، كثير المناكير، كان لا يضبط الإسناد، فيلزق بأنس ﵁ كل شيء يسمعه من غيره، ودونه أيضًا من هو مثله، أو أشد ضعفًا».|13:استنقعت نفس المؤمن: اجتمعت في فيه تريد الخروج، كما يستنقع الماء في قراره، وأراد بالنفس الروح. النهاية (نقع) ٥/١٠٨.|14:انتزع بالآية والشِّعر: تمثل. اللسان (نزع).|15:أخرجه ابن جرير ١٤/٢١٣، وأبو الشيخ في العظمة (٤٤٠)، والبيهقي في شعب الإيمان (٤٠٢). وعزاه السيوطي إلى ابن المبارك، وابن المنذر، وابن أبي حاتم، وأبو القاسم بن مَنده في كتاب الأحوال.|16:تفسير مقاتل بن سليمان ٢/٤٦٧.|17:تفسير يحيى بن سلام ١/٦٢.|18:تفسير يحيى بن سلام ١/٦٢.
  16,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ یَنظُرُونَ إِلَّاۤ أَن تَأۡتِیَهُمُ ٱلۡمَلَـٰۤىِٕكَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿هل ينظرون إلا أن تأتيهم الملائكة﴾</span>، يقول: عند الموت، حين تتوفاهم{1}. (٩/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٢<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿هل ينظرون إلا أن تأتيهم الملائكة﴾</span> بعذابهم، يعني: مشركي العرب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿هل ينظرون إلا أن تأتيهم الملائكة﴾</span>، قال: بالموت. وقال في آية أخرى: <span class="qpc-hafs">﴿ولو ترى إذ يتوفى الذين كفروا الملائكة﴾</span> [الأنفال:٥٠]، وهو ملك الموت، وله رُسُلٌ{3}. (٩/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٤<span class="dash">-</span></span> تفسير <span class="name-2">قتادة بن دعامة</span>: قوله: <span class="qpc-hafs">﴿هل ينظرون﴾</span> ما ينظرون <span class="qpc-hafs">﴿إلا أن تأتيهم الملائكة﴾</span>، وهو عند الموت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى كفار مكة، فقال: <span class="qpc-hafs">﴿هل﴾</span> يعني: ما <span class="qpc-hafs">﴿ينظرون إلا أن تأتيهم الملائكة﴾</span> بالموت، يعني: ملك الموت وحده ﵇{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ یَأۡتِیَ أَمۡرُ رَبِّكَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أو يأتي أمر ربك﴾</span>، قال: ذلك يوم القيامة{1}. (٩/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أو يأتي أمر ربك﴾</span>، يعني: النفخة الأولى التي يُهلِك اللهُ بها آخرَ كفار هذه الأمة الدائنين بدين أبي جهل وأصحابه، قبل عذاب الآخرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أو يأتيَ أمر ربك﴾</span>، وذاكم يوم القيامة{8}. (٩/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو يأتي أمر ربك﴾</span>، يعني: العذاب في الدنيا{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ فَعَلَ ٱلَّذِینَ مِن قَبۡلِهِمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿فعل الذين﴾</span> يعني: لعن الذين <span class="qpc-hafs">﴿من قبلهم﴾</span>، ونزل العذاب بهم قبل كُفّار مكة من الأمم الخالية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٦١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿كذلك فعل الذين من قبلهم﴾</span>، كذلك كذب الذين من قبل مشركي العرب كما كذب مشركو العرب، فأهلكناهم بالعذاب{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا ظَلَمَهُمُ ٱللَّهُ وَلَـٰكِن كَانُوۤا۟ أَنفُسَهُمۡ یَظۡلِمُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٦٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ينقصون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما ظلمهم الله﴾</span> فعذَّبهم على غير ذنب، <span class="qpc-hafs">﴿ولكن كانوا أنفسهم يظلمون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما ظلمهم الله ولكن كانوا أنفسهم يظلمون﴾</span> يَضُرُّون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢١٥.|2:علَّقه يحيى بن سلام ١/٦٢.|3:أخرجه ابن جرير ١٤/٢١٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير يحيى بن سلام ١/٦٢.|5:تفسير مقاتل بن سليمان ٢/٤٦٨.|6:أخرجه ابن جرير ١٤/٢١٥.|7:تفسير يحيى بن سلام ١/٦٢.|8:أخرجه ابن جرير ١٤/٢١٥. وعلقه يحيى بن سلام ١/٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:تفسير مقاتل بن سليمان ٢/٤٦٨.|10:تفسير مقاتل بن سليمان ٢/٤٦٨.|11:تفسير يحيى بن سلام ١/٦٢.|12:علقه يحيى بن سلام ١/٦٢.|13:تفسير مقاتل بن سليمان ٢/٤٦٨.|14:تفسير يحيى بن سلام ١/٦٢.
  16,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَصَابَهُمۡ سَیِّـَٔاتُ مَا عَمِلُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٦٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فأصابهم سيئات ما عملوا﴾</span>: أي: عذاب ما عملوا من الشرك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأصابهم سيئات﴾</span> يعني: عذاب <span class="qpc-hafs">﴿ما عملوا﴾</span> يعني: في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأصابهم سيئات ما عملوا﴾</span> ثواب ما عملوا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١١٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحاق بهم﴾</span> يعني: ودار بهم العذاب <span class="qpc-hafs">﴿ما كانوا به﴾</span> بالعذاب <span class="qpc-hafs">﴿يستهزئون﴾</span> بأنّه غير نازل بهم في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١٦٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وحاق بهم ما كانوا به يستهزئون﴾</span> ثواب ما كانوا به يستهزئون بآيات الله وبالرسل{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٦٢.|2:تفسير مقاتل بن سليمان ٢/٤٦٨.|3:تفسير يحيى بن سلام ١/٦٢.|4:تفسير مقاتل بن سليمان ٢/٤٦٨.|5:تفسير يحيى بن سلام ١/٦٢.