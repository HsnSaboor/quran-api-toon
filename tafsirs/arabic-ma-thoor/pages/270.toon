tafsir[8]{c,v,t}:
16,27," <q>﴿ثُمَّ یَوۡمَ ٱلۡقِیَـٰمَةِ یُخۡزِیهِمۡ﴾</q> - تفسير ٤١٠٩٠- قال مقاتل بن سليمان: ثم رجع إلى الخرّاصين في التقديم، فقال سبحانه: <q>﴿ثم يوم القيامة يخزيهم﴾</q>، يعني: يعذبهم. كقوله سبحانه: <q>﴿يَوْمَ لا يُخْزِي اللَّهُ النَّبِيَّ والَّذِينَ آمَنُوا مَعَهُ﴾</q> [التحريم:٨]، يعني: لا يعذب الله النبيَّ والمؤمنين{1}. (ز) ٤١٠٩١- قال يحيى بن سلّام: قوله: <q>﴿ثم يوم القيامة يخزيهم﴾</q> في النار، بعد عذاب الدنيا{2}. (ز) <q>﴿وَیَقُولُ أَیۡنَ شُرَكَاۤءِیَ ٱلَّذِینَ كُنتُمۡ تُشَـٰۤقُّونَ فِیهِمۡۚ﴾</q> - تفسير ٤١٠٩٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿تُشاقون فيهم﴾</q>، يقول: تُخالفوني{3}٣٦٦١. (٩/٤٣) ٣٦٦١ لم يذكر ابنُ جرير (١٤/٢٠٨) في معنى: <q>﴿تُشاقُّونَ فِيهِمْ﴾</q> سوى قول ابن عباس. ٤١٠٩٣- قال إسماعيل السُّدِّيّ: <q>﴿تشاقون فيهم﴾</q>، يعني: تُحاجُّون فيهم{4}. (ز) ٤١٠٩٤- قال مقاتل بن سليمان: <q>﴿ويقول أين شركائي الذين كنتم تشاقون﴾</q> يعني: تحاجون <q>﴿فيهم﴾</q>{1}. (ز) ٤١٠٩٥- قال يحيى بن سلّام: قوله: <q>﴿ويقول أين شركائي﴾</q> أي: الذين زعمتم أنهم شركائي، <q>﴿الذين كنتم تشاقون فيهم﴾</q> تفارقون فيهم، يعني: المحاربة والعداوة. عادوا اللهَ في الأوثان، فعبدوها من دونه{2}. (ز) <q>﴿قَالَ ٱلَّذِینَ أُوتُوا۟ ٱلۡعِلۡمَ﴾</q> - تفسير ٤١٠٩٦- قال مقاتل بن سليمان: <q>﴿قال الذين أوتوا العلم﴾</q> وهم الحَفَظَة من الملائكة{1}. (ز) ٤١٠٩٧- قال يحيى بن سلّام: <q>﴿قال الذين أوتوا العلم﴾</q> وهم المؤمنون{2}٣٦٦٢. (ز) ٣٦٦٢ ذكر ابنُ عطية (٥/٣٤٦) في معنى قوله تعالى: <q>﴿قالَ الَّذِينَ أُوتُوا العِلْمَ﴾</q> قول مقاتل، ويحيى بن سلام، ثم رجَّح قائلًا: «والصواب أن يعمَّ جميع مَن آتاه الله علم ذلك مِن جميع مَن حضر الموقف مِن مَلَك أو إنسي، وغير ذلك». <q>﴿إِنَّ ٱلۡخِزۡیَ ٱلۡیَوۡمَ﴾</q> - تفسير ٤١٠٩٨- قال مقاتل بن سليمان: <q>﴿إن الخزي اليوم﴾</q>، يعني: الهوان{1}. (ز) ٤١٠٩٩- قال يحيى بن سلّام: <q>﴿إن الخزي اليوم﴾</q>، يعني: إن الهوان اليوم{2}. (ز) <q>﴿وَٱلسُّوۤءَ عَلَى ٱلۡكَـٰفِرِینَ ۝٢٧﴾</q> - تفسير ٤١١٠٠- تفسير إسماعيل السُّدِّيّ: <q>﴿والسوء﴾</q>، يعني: العذاب{4}. (ز) ٤١١٠١- قال مقاتل بن سليمان: <q>﴿والسوء﴾</q> يعني: العذاب <q>﴿على الكافرين﴾</q>{1}. (ز) ٤١١٠٢- قال يحيى بن سلّام: <q>﴿على الكافرين﴾</q>، وهذا الكلام يوم القيامة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦٠.أخرجه ابن جرير ١٤/٢٠٨، وابن أبي حاتم -كما في الإتقان ٢/٢٣-.علَّقه يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦٠.علَّقه يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦٠.
16,28," <q>﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ ظَالِمِیۤ أَنفُسِهِمۡۖ فَأَلۡقَوُا۟ ٱلسَّلَمَ مَا كُنَّا نَعۡمَلُ مِن سُوۤءِۭۚ بَلَىٰۤۚ إِنَّ ٱللَّهَ عَلِیمُۢ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾</q> - قراءات ٤١١٠٣- عن الأعمش: في قراءة عبد الله [بن مسعود]: (الَّذِينَ تَوَفّاهُمُ المَلائِكَةُ){1}. (ز) <q>﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ ظَالِمِیۤ أَنفُسِهِمۡۖ فَأَلۡقَوُا۟ ٱلسَّلَمَ مَا كُنَّا نَعۡمَلُ مِن سُوۤءِۭۚ بَلَىٰۤۚ إِنَّ ٱللَّهَ عَلِیمُۢ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾</q> - نزول الآية ٤١١٠٤- عن عكرمة مولى ابن عباس -من طريق عمرو بن دينار- قال: كان ناس بمكة أقرُّوا بالإسلام ولم يهاجروا، فأُخرِج بهم كَرْهًا إلى بدر، فقُتِل بعضهم؛ فأنزل الله فيهم: <q>﴿الذين تتوفاهم الملائكة ظالمي أنفسهم﴾</q>{2}٣٦٦٣. (ز) ٣٦٦٣ استدرك ابن عطية (٥/٣٤٧) مستندًا إلى أحوال النزول على قول عكرمة، فقال: «وإنما اشتبهت عليه بالآية الأخرى التي نزلت في أولئك باتفاقٍ من العلماء». ثم وجَّهه بقوله: «وعلى هذا القول يحسن قطع <q>﴿الَّذِينَ﴾</q>، ورفعه بالابتداء». <q>﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ ظَالِمِیۤ أَنفُسِهِمۡۖ﴾</q> - تفسير ٤١١٠٥- قال عكرمة مولى ابن عباس: عنى بذلك: مَن قُتِل من قريش وأهل مكة ببدر وقد أخرج إليها كرهًا{3}. (ز) ٤١١٠٦- قال الحسن البصري: هي وفاة إلى النار؛ حشر إلى النار{4}. (ز) ٤١١٠٧- قال مقاتل بن سليمان: ثم نعتهم، فقال: <q>﴿الذين تتوفاهم الملائكة﴾</q> يعني: ملك الموت وأعوانه <q>﴿ظالمي أنفسهم﴾</q> وهم ستة؛ ثلاثة يَلُون أرواح المؤمنين، وثلاثة يَلُون أرواح الكافرين{5}. (ز) ٤١١٠٨- قال يحيى بن سلّام: قوله: <q>﴿الذين تتوفاهم الملائكة ظالمي أنفسهم﴾</q>، قال بعضهم: توفاهم عند الموت{6}. (ز) <q>﴿فَأَلۡقَوُا۟ ٱلسَّلَمَ﴾</q> - تفسير ٤١١٠٩- تفسير الحسن البصري: فأعْطَوُا الإسلام؛ أسلموا فلم يقبل ذلك منهم{7}. (ز) ٤١١١٠- تفسير قتادة بن دعامة: <q>﴿فألقوا السلم﴾</q>: استسلموا{7}. (ز) ٤١١١١- قال مقاتل بن سليمان: <q>﴿فألقوا السلم﴾</q>، يعني: الخضوع والاستسلام{5}. (ز) <q>﴿مَا كُنَّا نَعۡمَلُ مِن سُوۤءِۭۚ﴾</q> - تفسير ٤١١١٢- قال الحسن البصري: إن في القيامة مواطن؛ فمنها موطن يُقِرُّون فيه بأعمالهم الخبيثة، وهو قوله: <q>﴿وشهدوا على أنفسهم أنهم كانوا كافرين﴾</q> [الأنعام:١٣٠]، ومنها موطن يجحدون فيه، فقالوا: <q>﴿ما كنا نعمل من سوء﴾</q>. فقيل لهم: <q>﴿بلى إن الله عليم بما كنتم تعملون﴾</q> [النحل:٢٨] في الدنيا أنكم مشركون. وقالوا: <q>﴿والله ربنا ما كنا مشركين انظر كيف كذبوا على أنفسهم﴾</q> فادَّعَوْا أنهم لم يكونوا مشركين، <q>﴿وضل عنهم ما كانوا يفترون﴾</q> [الأنعام: ٢٤] من عبادتهم الأوثان، فلم تغن عنهم شيئًا. وإنّ آخرها موطنًا أن يختم على أفواههم، وتَكَلَّمَ أيديهم، وتشهد أرجلهم بما كانوا يكسبون: يعملون{7}. (ز) ٤١١١٣- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿ما كنا نعمل من سوء﴾</q>: يعني: مِن شرك{7}. (ز) ٤١١١٤- قال مقاتل بن سليمان: ثم قالوا: <q>﴿ما كنا نعمل من سوء﴾</q>، يعني: مِن شرك، لقولهم في الأنعام [٢٣]: <q>﴿والله ربنا ما كنا مشركين﴾</q>{5}٣٦٦٤. (ز) ٣٦٦٤ قال ابنُ عطية (٥/٣٤٧) في معنى: <q>﴿ما كُنّا نَعْمَلُ مِن سُوء﴾</q>: «ويحتمل قولهم: <q>﴿ما كُنّا نَعْمَلُ مِن سُوءٍ﴾</q> وجهين: أحدهما: أنهم كذبوا وقصدوا الكذب اعتصامًا منهم به، على نحو قولهم: <q>﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</q> [الأنعام:٢٣]. والآخر: أنهم أخبروا عن أنفسهم أنهم لم يكونوا يعملون سوءًا، فأخبروا عن ظنهم بأنفسهم، وهو كذب في نفسه». <q>﴿بَلَىٰۤۚ إِنَّ ٱللَّهَ عَلِیمُۢ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٨﴾</q> - تفسير ٤١١١٥- قال مقاتل بن سليمان: فكذبهم الله ﷿، فردَّت عليهم خزنة جهنم مِن الملائكة، فقالوا: <q>﴿بلى﴾</q> قد عملتم السوء، <q>﴿إن الله عليم بما كنتم تعملون﴾</q> يعني: بما كنتم مشركين{5}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢١. وهي قراءة شاذة. انظر: البحر المحيط ٥/٤٧٢.أخرجه ابن جرير ١٤/٢٠٨.تفسير الثعلبي ٦/١٤، وتفسير البغوي ٤/١٧.علقه يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦٠.علَّقه يحيى بن سلام ١/٦٠.علَّقه يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.علَّقه يحيى بن سلام ١/٦٠.علَّقه يحيى بن سلام ١/٦٠.تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير مقاتل بن سليمان ٢/٤٦٦.
16,29," <q>﴿فَٱدۡخُلُوۤا۟ أَبۡوَ ٰ⁠بَ جَهَنَّمَ خَـٰلِدِینَ فِیهَاۖ فَلَبِئۡسَ مَثۡوَى ٱلۡمُتَكَبِّرِینَ ۝٢٩﴾</q> - تفسير ٤١١١٦- قال مقاتل بن سليمان: قالت الخزنة لهم: <q>﴿فادخلوا أبواب جهنم خالدين فيها﴾</q> من الموت، <q>﴿فلبئس مثوى﴾</q> يعني: مأوى <q>﴿المتكبرين﴾</q> عن التوحيد. فأخبر الله عنهم في الدنيا، وأخبر بمصيرهم في الآخرة{1}. (ز) ٤١١١٧- قال يحيى بن سلّام: <q>﴿خالدين فيها فلبئس مثوى المتكبرين﴾</q> عن عبادة الله{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٦.تفسير يحيى بن سلام ١/٦١.
16,30," <q>﴿وَقِیلَ لِلَّذِینَ ٱتَّقَوۡا۟﴾</q> - نزول الآية ٤١١١٨- قال مقاتل بن سليمان في قوله تعالى: <q>﴿ماذا أنزل ربكم قالوا خيرا﴾</q>: وذلك أن الرجل كان يبعثه قومه وافدًا إلى مكة، ليأتيهم بخبر محمد ﷺ، فيأتي الموسم، فيمر على هؤلاء الرهط من قريش الذين على طريق مكة، فيسألهم عن النبي ﷺ: فيصدونه عنه لئلّا يلقاه. فيقول: بئس الرجل الوافد أنا لقومي أن أرجع قبل أن ألقى محمدًا ﷺ وأنا منه على مسيرة ليلة أو ليلتين، وأسمع منه. فيسير حتى يدخل مكة، فيلقى المؤمنين، فيسألهم عن النبي ﷺ، وعن قولهم، فيقولون للوافد: أنزَل اللهُ ﷿ خيرًا؛ بعث رسولًا ﷺ، وأنزل كتابًا يأمر فيه بالخير، وينهى عن الشر. ففيهم نزلت: <q>﴿وقيل للذين اتقوا ماذا أنزل ربكم قالوا خيرا﴾</q>{1}. (ز) <q>﴿وَقِیلَ لِلَّذِینَ ٱتَّقَوۡا۟﴾</q> - تفسير الآية ٤١١١٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وقيل للذين اتقوا﴾</q>، قال: هؤلاء المؤمنون{2}. (٩/٤٤) ٤١١٢٠- قال مقاتل بن سليمان: قال تعالى: <q>﴿وقيل للذين اتقوا﴾</q>، يعني: الذين عبدوا ربهم{3}. (ز) <q>﴿مَاذَاۤ أَنزَلَ رَبُّكُمۡۚ قَالُوا۟ خَیۡرࣰاۗ﴾</q> - تفسير ٤١١٢١- قال قتادة بن دعامة -من طريق سعيد- يقال لهم: <q>﴿ماذا أنزل ربكم﴾</q>؟ فيقولون: <q>﴿خيرًا﴾</q>{2}. (٩/٤٤) ٤١١٢٢- قال مقاتل بن سليمان: قال تعالى: <q>﴿ماذا أنزل ربكم قالوا﴾</q> أنزل <q>﴿خيرا﴾</q> ... ثم انقطع الكلام{1}. (ز) ٤١١٢٣- قال يحيى بن سلّام: <q>﴿وقيل للذين اتقوا ماذا أنزل ربكم قالوا خيرا﴾</q>، أي: أنزل خيرًا. ثم انقطع الكلام{6}. (ز) <q>﴿لِّلَّذِینَ أَحۡسَنُوا۟ فِی هَـٰذِهِ ٱلدُّنۡیَا حَسَنَةࣱۚ﴾</q> - تفسير ٤١١٢٤- عن أنس بن مالك، قال: قال رسول الله ﷺ: «إنّ الله لا يظلم المؤمن حسنة؛ يثاب عليها الرزق في الدنيا، ويُجزى بها في الآخرة»{7}. (ز) ٤١١٢٥- قال يحيى بن سلّام: وبلغني عن علي بن أبي طالب في تفسيرها نحو ذلك{6}. (ز) ٤١١٢٦- قال عبد الله بن عباس في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا فِي هَذِهِ الدُّنْيا حَسَنَةٌ﴾</q>: هي تضعيف الأجر إلى العشر{9}. (ز) ٤١١٢٧- قال مجاهد بن جبر، في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا فِي هَذِهِ الدُّنْيا حَسَنَةٌ﴾</q>: هي الرزق الحسن{9}. (ز) ٤١١٢٨- قال الضحاك بن مزاحم، في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا فِي هَذِهِ الدُّنْيا حَسَنَةٌ﴾</q>: هي النصر، والفتح{9}. (ز) ٤١١٢٩- تفسير الحسن البصري، يقول: للذين أحسنوا في هذه الدنيا؛ تكون لهم حسنتهم في الآخرة الجنة{12}. (ز) ٤١١٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿للذين أحسنوا﴾</q>، أي: آمنوا بالله، وكتبه، وأمَرُوا بطاعته، وحَثُّوا عباد الله على الخير، ودَعَوهم إليه{13}. (٩/٤٤) ٤١١٣١- قال إسماعيل السُّدِّيّ: <q>﴿للذين أحسنوا في هذه الدنيا حسنة﴾</q>، يقول: مال{14}. (٩/٤١) ٤١١٣٢- قال مقاتل بن سليمان: يقول الله سبحانه: <q>﴿للذين أحسنوا﴾</q> العمل <q>﴿في هذه الدنيا﴾</q> لهم <q>﴿حسنة﴾</q> في الآخرة، يعني: الجنة{1}. (ز) ٤١١٣٣- قال يحيى بن سلّام: قوله: <q>﴿للذين أحسنوا﴾</q> آمنوا{6}. (ز) <q>﴿وَلَدَارُ ٱلۡـَٔاخِرَةِ خَیۡرࣱۚ﴾</q> - تفسير ٤١١٣٤- قال إسماعيل السُّدِّيُّ: <q>﴿ولدار الآخرة خير﴾</q>، وهي الجنة{14}. (٩/٤١) ٤١١٣٥- قال مقاتل بن سليمان: قال تعالى: <q>﴿ولدار الآخرة خير﴾</q>، يعني: الجنة أفضل من ثواب المشركين في الدنيا الذي ذكر في هذه الآية الأولى{1}. (ز) ٤١١٣٦- قال يحيى بن سلّام: <q>﴿ولدار الآخرة خير﴾</q> من الدنيا{6}. (ز) <q>﴿وَلَنِعۡمَ دَارُ ٱلۡمُتَّقِینَ ۝٣٠﴾</q> - تفسير ٤١١٣٧- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿ولنعم دار المتقين﴾</q> الشركَ، يُثنِي على الجنة{1}. (ز) ٤١١٣٨- قال يحيى بن سلّام: <q>﴿ولنعم دار المتقين﴾</q> الجنة{6}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٧.أخرجه ابن جرير ١٤/٢١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٦.أخرجه ابن جرير ١٤/٢١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦١.أخرجه مسلم ٤/٢١٦٢ (٢٨٠٨) مطولًا، ويحيى بن سلام ١/٦١، وابن جرير ٧/٣٠، ٢٤/٥٦٨. وأورده الثعلبي ٣/٣٠٨.تفسير يحيى بن سلام ١/٦١.تفسير البغوي ٥/١٧.تفسير البغوي ٥/١٧.تفسير البغوي ٥/١٧.علَّقه يحيى بن سلام ١/٦١.أخرجه ابن جرير ١٤/٢١١ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦١.تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦١.
16,31," <q>﴿جَنَّـٰتُ عَدۡنࣲ یَدۡخُلُونَهَا تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ﴾</q> - تفسير ٤١١٣٩- قال مقاتل بن سليمان: ثم بَيَّنَ لهم الدار، فقال سبحانه: <q>﴿جنات عدن يدخلونها تجري من تحتها الأنهار﴾</q>، يعني: الأنهار تجري تحت البساتين{1}. (ز) ٤١١٤٠- قال يحيى بن سلّام: <q>﴿جنات عدن يدخلونها تجري من تحتها الأنهار﴾</q>، وقد فسرنا <q>﴿عدن﴾</q> قبل هذا الموضع، نُسِبَتِ الجنانُ كلُّها إليها{2}. (ز) <q>﴿لَهُمۡ فِیهَا مَا یَشَاۤءُونَۚ كَذَ ٰ⁠لِكَ یَجۡزِی ٱللَّهُ ٱلۡمُتَّقِینَ ۝٣١﴾</q> - تفسير ٤١١٤١- قال مقاتل بن سليمان: <q>﴿لهم فيها ما يشاءُون﴾</q> يعني: في الجنان، <q>﴿كذلك يجزي الله المتقين﴾</q> الشرك{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦١.تفسير مقاتل بن سليمان ٢/٤٦٧.
16,32," <q>﴿ٱلَّذِینَ تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰۤىِٕكَةُ طَیِّبِینَ﴾</q> - تفسير ٤١١٤٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿الذين تتوفاهم الملائكة طيبين﴾</q>، قال: أحياءً وأمواتًا، قدَّر الله ذلك لهم{1}. (٩/٤٤) ٤١١٤٣- قال مجاهد بن جبر: زاكية أفعالهم وأقوالهم{2}. (ز) ٤١١٤٤- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال -جلَّ ثناؤه-: <q>﴿الذين تتوفاهم الملائكة طيبين﴾</q> في الدنيا، يعني: ملك الموت وحده، ثم انقطع الكلام{3}. (ز) ٤١١٤٥- قال يحيى بن سلّام: <q>﴿الذين تتوفاهم الملائكة﴾</q> تقبض أرواحهم <q>﴿طيبين﴾</q>{4}. (ز) <q>﴿یَقُولُونَ سَلَـٰمٌ عَلَیۡكُمُ ٱدۡخُلُوا۟ ٱلۡجَنَّةَ بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٣٢﴾</q> - تفسير ٤١١٤٦- عن تميم الداري، عن النبي ﷺ، قال: «يقول الله لملك الموت: انطلق إلى وليي، فائتني به، فإني قد جربته بالسراء والضراء فوجدته حيث أحب، فائتني به لأريحه من هموم الدنيا وغمومها. فينطلق إليه ملك الموت، ومعه خمسمائة من الملائكة، معهم أكفان وحَنُوطٌ من حنوط الجنة، ومعهم ضَبائِرُ{5} الريحان، أصل الريحانة واحد وفي رأسها عشرون لونًا، لكل لون منها ريح سوى ريح صاحبه، ومعهم الحرير الأبيض فيه المسك الأَذْفَر، فيجلس ملك الموت عند رأسه، وتَحْتَوِشُهُ{6} الملائكة، ويضع كل ملَك منهم يده على عضو من أعضائه، ويبسط ذلك الحرير الأبيض والمسك الأذفر تحت ذقنه، ويفتح له باب إلى الجنة، فإن نفسه لَتَعَلَّلُ{7} عند ذلك بطرف الجنة؛ مرة بأزواجها، ومرة بكسوتها، ومرة بثمارها، كما يعلل الصبيَّ أهلُه إذا بكى، وإن أزواجه لَيَبْتَهِشْنَ{8} عند ذلك ابتهاشًا، وتَنزُو{9} الروح نَزْوًا، ويقول ملك الموت: اخرجي أيتها الروح الطيبة إلى سدر مخضود، وطلح منضود، وظل ممدود، وماء مسكوب. وملَك الموت أشدُّ تلطُّفًا به من الوالدة بولدها، يعرف أن ذلك الروح حبيب إلى ربه، كريم على الله، فهو يلتمس بلطفه تلك الروح رضا الله عنه، فسلَّ روحه كما تُسَلُّ الشعرة من العجين، وإن روحه لتخرج والملائكة حوله يقولون: سلام عليكم، ادخلوا الجنة بما كنتم تعملون. وذلك قوله: <q>﴿الذين تتوفاهم الملائكة طيبين يقولون سلام عليكم﴾</q>. قال: <q>﴿فأما إن كان من المقربين فروح وريحان وجنة نعيم﴾</q> [الواقعة:٨٩]. قال: روح من جهد الموت، وروح يؤتى به عند خروج نفسه، وجنة نعيم أمامه. فإذا قبض ملك الموت روحه يقول الروح للجسد: لقد كنت بي سريعًا إلى طاعة الله، بطيئًا عن معصيته، فهنيئًا لك اليوم؛ فقد نجوت وأنجيت. ويقول الجسد للروح مثل ذلك، وتبكي عليه بقاع الأرض التي كان يطيع الله عليها كل باب من السماء كان يصعد منه عمله وينزل منه رزقه أربعين ليلة، فإذا قبضت الملائكة روحه أقامت الخمسمائة ملك عند جسده، لا يقلبه بنو آدم لشِقٍّ إلا قلبته الملائكة ﵈ قبلهم، وعَلَتْه بأكفان قبل أكفانهم، وحنوط قبل حنوطهم، ويقوم من باب بيته إلى باب قبره صفّان من الملائكة يستقبلونه بالاستغفار، ويصيح إبليس عند ذلك صيحة تَتَصَدَّع منها بعض عظام جسده، ويقول لجنوده: الويل لكم؛ كيف خلص هذا العبد منكم؟ فيقولون: إنّ هذا كان معصومًا. فإذا صعد ملك الموت بروحه إلى السماء يستقبله جبريل في سبعين ألفًا من الملائكة، كلهم يأتيه من ربه، فإذا انتهى ملك الموت إلى العرش خرَّت الروح ساجدة لربها، فيقول الله لملك الموت: انطلق بروح عبدي فضعه في سدر مخضود، وطلح منضود، وظل ممدود، وماء مسكوب. فإذا وُضِع في قبره جاءت الصلاة فكانت عن يمينه، وجاء الصيام فكان عن يساره، وجاء القرآن والذِّكر فكانا عند رأسه، وجاء مشيه إلى الصلاة فكان عند رجليه، وجاء الصبر فكان ناحية القبر، ويبعث الله عُنُقًا من العذاب فيأتيه عن يمينه، فتقول الصلاة: وراءكَ، واللهِ، ما زال دائبًا عمره كله، وإنما استراح الآن حين وضع في قبره. فيأتيه عن يساره، فيقول الصيام مثل ذلك، فيأتيه من قِبَل رأسه، فيقول له مثل ذلك، فلا يأتيه العذاب من ناحية فيلتمس هل يجد لها مساغًا إلا وجد وليَّ الله قد أحرزته الطاعة، فيخرج عنه العذاب عندما يرى، ويقول الصبرُ لسائر الأعمال: أما إنه لم يمنعني أن أباشره بنفسي إلا أني نظرت ما عندكم، فلو عجزتم كنت أنا صاحبُه، فأما إذا أجزأتم عنه فأنا ذخر له عند الميزان. قال: ويبعث الله إليه ملَكين أبصارهما كالبرق الخاطف، وأصواتهما كالرعد القاصف، وأنيابهما كالصَّياصِيِّ{10}، وأنفاسهما كاللهب؛ يطآن في أشعارهما بين منكبي كل واحد منهما مسيرة كذا وكذا، قد نزعت منهما الرأفة والرحمة إلا بالمؤمنين، يقال لهما: منكر ونكير، وفي يد كل واحد منهما مطرقة لو اجتمع عليها الثقلان لم يقلوها. فيقولان له: اجلس. فيستوي جالسًا في قبره، فتسقط أكفانه في حقويه، فيقولان له: من ربك؟ وما دينك؟ ومن نبيك؟ فيقول: ربي الله وحده لا شريك له، والإسلام ديني، ومحمد نبي، وهو خاتم النبيين. فيقولان له: صدقت، فيدفعان القبر، فيُوسِّعانه من بين يديه، ومن خلفه، وعن يمينه، وعن يساره، ومن قِبَل رأسه، ومن قِبَل رجليه، ثم يقولان له: انظر فوقك. فينظر، فإذا هو مفتوح إلى الجنة، فيقولان له: هذا منزلك، يا وليَّ الله، لِما أطعت الله». قال رسول الله ﷺ: «فوالذي نفس محمد بيده، إنه لتصل إلى قلبه فرحة لا تَرْتَدُّ أبدًا، فيقال له: انظر تحتك. فينظر تحته، فإذا هو مفتوح إلى النار، فيقولان: يا وليَّ الله، نجوت من هذا. فوالذي نفسي بيده، إنّه لَتَصِل إلى قلبه عند ذلك فرحة لا ترتد أبدًا، ويفتح له سبعة وسبعون بابًا إلى الجنة يأتيه ريحها وبردها حتى يبعثه الله تعالى من قبره». قال: «ويقول الله تعالى لملَك الموت: انطلق إلى عدوي، فائتني به، فإني قد بسطت له رزقي، وسربلته نعمتي، وأبى إلا معصيتي، فائتني به لأنتقم منه اليوم. فينطلق إليه ملك الموت في أكره صورة رآها أحد من الناس، له ثنتا عشرة عينًا، ومعه سَفُّودٌ{11} من النار كثير الشوك، ومعه خمسمائة من الملائكة، معهم نحاس وجمر مِن جمر جهنم، معهم سياط من النار تأجج، فيضربه ملك الموت بذلك السفود ضربة، يغيب أصلُ كل شوكة من ذلك السفود في أصل كل شعرة وعِرق من عروقه، ثم يلويه ليًّا شديدًا، فينزع روحَه من أظفار قدميه، فيلقيها في عقبيه، فيسكر عدوُّ الله عند ذلك سكرة، وتضرب الملائكة وجهه ودبره بتلك السياط، ثم يجذبه جذبة، فينزع روحه من عَقِبَيه، فيلقيها في ركبتيه، فيسكر عدوُّ الله سكرة، وتضرب الملائكة وجهه ودبره، ثم كذلك إلى حقويه، ثم كذلك إلى صدره، ثم كذلك إلى حلقه، ثم تبسط الملائكة ذلك النحاس وجمر جهنم تحت ذقنه، ثم يقول ملك الموت: اخرجي -أيتها النفس اللعينة الملعونة- إلى سموم وحميم، وظل من يحموم، لا بارد ولا كريم. فإذا قبض ملك الموت روحه قالت الروح للجسد: جزاك الله عني شرًّا، لقد كنت بي سريعًا إلى معصية الله، بطيئًا بي عن طاعة الله، فقد هلكت وأهلكت. ويقول الجسد للروح مثل ذلك، وتلعنه بقاع الأرض التي كان يعصي الله تعالى عليها، وتنطلق جنود إبليس إليه يُبَشِّرونه بأنهم قد أوردوا عبدًا من بني آدم النار، فإذا وضع في قبره ضُيِّق عليه قبرُه حتى تختلف أضلاعه؛ فتدخل اليمنى في اليسرى، واليسرى في اليمنى، ويبعث الله إليه حيّات دهمًا، تأخذ بأرنبته وإبهام قدميه، فتقرِضُه حتى تلتقي في وسطه، قال: ويبعث الله إليه الملَكين، فيقولان له: من ربك؟ وما دينك؟ ومن نبيُّك، فيقول: لا أدري. فيقال له: لا دريت، ولا تليت. فيضربانه ضربة يتطاير الشرار في قبره، ثم يعود، فيقولان له: انظر فوقك. فينظر، فإذا باب مفتوح من الجنة، فيقولان: عدوَّ الله، لو أطعت اللهَ كان هذا منزلك. فوالذي نفس محمد بيده، إنّه لتصل إلى قلبه عند ذلك حسرةٌ لا ترتدُّ أبدًا، ويفتح له باب إلى النار، فيقال: عدوَّ الله، هذا منزلك لما عصيت الله. ويفتح له سبعة وسبعون بابًا إلى النار، يأتيه حرها وسمومها، حتى يبعثه الله يوم القيامة إلى النار»{12}. (ز) ٤١١٤٧- عن محمد بن كعب القرظي -من طريق أبي صخر- قال: إذا استنقَعَتْ{13} نفسُ العبد المؤمن جاءه الملَك، فقال: السلام عليك، وليَّ الله، الله يقرأ عليك السلام. ثم نزع{14} بهذه الآية: <q>﴿الذين تتوفاهم الملائكة طيبين يقولون سلام عليكم﴾</q>{15}. (٩/٤٤) ٤١١٤٨- قال مقاتل بن سليمان: ثم أخبر سبحانه عن قول خَزَنَة الجنة من الملائكة في الآخرة لهم: <q>﴿يقولون سلام عليكم ادخلوا الجنة بما كنتم تعملون﴾</q> في دار الدنيا{3}. (ز) ٤١١٤٩- عن حيوة بن شريح، قال: إنّ الملائكة تأتي ولي الله عند الموت، فتقول: السلام عليك، يا ولي الله، الله يقرأ عليك السلام. وتبشره بالجنة. قال يحيى بن سلّام: فهو قوله: <q>﴿تتوفاهم الملائكة طيبين يقولون سلام عليكم﴾</q>{17}. (ز) ٤١١٥٠- عن الخليل بن مرة، قال: يقول الله: ادخلوا الجنة برحمتي، واقتسموها بأعمالكم{17}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/٦٢ من طريق ابن مجاهد، وابن جرير ١٤/٢١٢-٢١٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/١٥، وتفسير البغوي ٥/١٧.تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦١.ضَبَّر الشيء: جمعه. لسان العرب (ضبر).يقال: احتوش القوم على فلان إذا جعلوه وسْطهم. النهاية (حوش).تَعَلَّلَ بالأمر واعْتَلَّ: تشاغل. لسان العرب (علل).البَهْش: الإسراع إلى المعروف بالفرح. لسان العرب (بهش).قال ابن فارس: النون والزاء أصلٌ صحيح يدل على خِفة وقِلة. معجم مقاييس اللغة (نز).الصياصي: جمع صيصية، وهي قرن البقر والظباء. تاج العروس (صيص).السَّفُّودُ والسُّفُّود -بالتشديد-: حديدة ذات شُعَب، مُعَقَّفَة، يُشوى به اللحم. لسان العرب (سفد).أخرجه أبو يعلى-كما في تفسير ابن كثير ٤/٥٠٤-٥٠٧-. قال ابن كثير: «هذا حديث غريب جدًّا، وسياق عجيب، ويزيد الرقاشي -راويه عن أنس- له غرائب ومنكرات، وهو ضعيف الرواية عند الأئمة». وقال ابن حجر في المطالب العالية ١٨/٥٤٠-٥٤٥ (٤٥٥٨): «هذا حديث عجيب السياق، وهو شاهد لكثير مما ثبت في حديث البراء ﵁ الطويل المشهور، ولكن هذا الإسناد غريب، لا نعرف أحدًا روى عن أنس عن تميم الداري ﵄ إلا من هذا الوجه، ويزيد الرقاشي سيء الحفظ جدًّا، كثير المناكير، كان لا يضبط الإسناد، فيلزق بأنس ﵁ كل شيء يسمعه من غيره، ودونه أيضًا من هو مثله، أو أشد ضعفًا».استنقعت نفس المؤمن: اجتمعت في فيه تريد الخروج، كما يستنقع الماء في قراره، وأراد بالنفس الروح. النهاية (نقع) ٥/١٠٨.انتزع بالآية والشِّعر: تمثل. اللسان (نزع).أخرجه ابن جرير ١٤/٢١٣، وأبو الشيخ في العظمة (٤٤٠)، والبيهقي في شعب الإيمان (٤٠٢). وعزاه السيوطي إلى ابن المبارك، وابن المنذر، وابن أبي حاتم، وأبو القاسم بن مَنده في كتاب الأحوال.تفسير مقاتل بن سليمان ٢/٤٦٧.تفسير يحيى بن سلام ١/٦٢.تفسير يحيى بن سلام ١/٦٢.
16,33," <q>﴿هَلۡ یَنظُرُونَ إِلَّاۤ أَن تَأۡتِیَهُمُ ٱلۡمَلَـٰۤىِٕكَةُ﴾</q> - تفسير ٤١١٥١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿هل ينظرون إلا أن تأتيهم الملائكة﴾</q>، يقول: عند الموت، حين تتوفاهم{1}. (٩/٤٥) ٤١١٥٢- تفسير الحسن البصري: <q>﴿هل ينظرون إلا أن تأتيهم الملائكة﴾</q> بعذابهم، يعني: مشركي العرب{2}. (ز) ٤١١٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هل ينظرون إلا أن تأتيهم الملائكة﴾</q>، قال: بالموت. وقال في آية أخرى: <q>﴿ولو ترى إذ يتوفى الذين كفروا الملائكة﴾</q> [الأنفال:٥٠]، وهو ملك الموت، وله رُسُلٌ{3}. (٩/٤٥) ٤١١٥٤- تفسير قتادة بن دعامة: قوله: <q>﴿هل ينظرون﴾</q> ما ينظرون <q>﴿إلا أن تأتيهم الملائكة﴾</q>، وهو عند الموت{4}. (ز) ٤١١٥٥- قال مقاتل بن سليمان: ثم رجع إلى كفار مكة، فقال: <q>﴿هل﴾</q> يعني: ما <q>﴿ينظرون إلا أن تأتيهم الملائكة﴾</q> بالموت، يعني: ملك الموت وحده ﵇{5}. (ز) <q>﴿أَوۡ یَأۡتِیَ أَمۡرُ رَبِّكَۚ﴾</q> - تفسير ٤١١٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أو يأتي أمر ربك﴾</q>، قال: ذلك يوم القيامة{1}. (٩/٤٥) ٤١١٥٧- تفسير الحسن البصري: <q>﴿أو يأتي أمر ربك﴾</q>، يعني: النفخة الأولى التي يُهلِك اللهُ بها آخرَ كفار هذه الأمة الدائنين بدين أبي جهل وأصحابه، قبل عذاب الآخرة{4}. (ز) ٤١١٥٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أو يأتيَ أمر ربك﴾</q>، وذاكم يوم القيامة{8}. (٩/٤٥) ٤١١٥٩- قال مقاتل بن سليمان: <q>﴿أو يأتي أمر ربك﴾</q>، يعني: العذاب في الدنيا{5}. (ز) <q>﴿كَذَ ٰ⁠لِكَ فَعَلَ ٱلَّذِینَ مِن قَبۡلِهِمۡۚ﴾</q> - تفسير ٤١١٦٠- قال مقاتل بن سليمان: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿فعل الذين﴾</q> يعني: لعن الذين <q>﴿من قبلهم﴾</q>، ونزل العذاب بهم قبل كُفّار مكة من الأمم الخالية{5}. (ز) ٤١١٦١- قال يحيى بن سلّام: <q>﴿كذلك فعل الذين من قبلهم﴾</q>، كذلك كذب الذين من قبل مشركي العرب كما كذب مشركو العرب، فأهلكناهم بالعذاب{4}. (ز) <q>﴿وَمَا ظَلَمَهُمُ ٱللَّهُ وَلَـٰكِن كَانُوۤا۟ أَنفُسَهُمۡ یَظۡلِمُونَ ۝٣٣﴾</q> - تفسير ٤١١٦٢- قال الحسن البصري: ينقصون{12}. (ز) ٤١١٦٣- قال مقاتل بن سليمان: <q>﴿وما ظلمهم الله﴾</q> فعذَّبهم على غير ذنب، <q>﴿ولكن كانوا أنفسهم يظلمون﴾</q>{5}. (ز) ٤١١٦٤- قال يحيى بن سلّام: <q>﴿وما ظلمهم الله ولكن كانوا أنفسهم يظلمون﴾</q> يَضُرُّون{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢١٥.علَّقه يحيى بن سلام ١/٦٢.أخرجه ابن جرير ١٤/٢١٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ١/٦٢.تفسير مقاتل بن سليمان ٢/٤٦٨.أخرجه ابن جرير ١٤/٢١٥.تفسير يحيى بن سلام ١/٦٢.أخرجه ابن جرير ١٤/٢١٥. وعلقه يحيى بن سلام ١/٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٨.تفسير مقاتل بن سليمان ٢/٤٦٨.تفسير يحيى بن سلام ١/٦٢.علقه يحيى بن سلام ١/٦٢.تفسير مقاتل بن سليمان ٢/٤٦٨.تفسير يحيى بن سلام ١/٦٢.
16,34," <q>﴿فَأَصَابَهُمۡ سَیِّـَٔاتُ مَا عَمِلُوا۟﴾</q> - تفسير ٤١١٦٥- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿فأصابهم سيئات ما عملوا﴾</q>: أي: عذاب ما عملوا من الشرك{1}. (ز) ٤١١٦٦- قال مقاتل بن سليمان: <q>﴿فأصابهم سيئات﴾</q> يعني: عذاب <q>﴿ما عملوا﴾</q> يعني: في الدنيا{2}. (ز) ٤١١٦٧- قال يحيى بن سلّام: <q>﴿فأصابهم سيئات ما عملوا﴾</q> ثواب ما عملوا{3}. (ز) <q>﴿وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٣٤﴾</q> - تفسير ٤١١٦٨- قال مقاتل بن سليمان: <q>﴿وحاق بهم﴾</q> يعني: ودار بهم العذاب <q>﴿ما كانوا به﴾</q> بالعذاب <q>﴿يستهزئون﴾</q> بأنّه غير نازل بهم في الدنيا{2}. (ز) ٤١١٦٩- قال يحيى بن سلّام: <q>﴿وحاق بهم ما كانوا به يستهزئون﴾</q> ثواب ما كانوا به يستهزئون بآيات الله وبالرسل{3}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٦٢.تفسير مقاتل بن سليمان ٢/٤٦٨.تفسير يحيى بن سلام ١/٦٢.تفسير مقاتل بن سليمان ٢/٤٦٨.تفسير يحيى بن سلام ١/٦٢.
