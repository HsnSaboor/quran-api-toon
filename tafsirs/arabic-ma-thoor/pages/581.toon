quran[31]{c,v,t}:
77,20," <q>﴿أَلَمۡ نَخۡلُقكُّم مِّن مَّاۤءࣲ مَّهِینࣲ ۝٢٠﴾</q> - تفسير ٨٠٧١١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿ألَمْ نَخْلُقْكُمْ مِن ماءٍ مَهِينٍ﴾</q>: يعني بالمهين: الضعيف{1}٦٩٦٧. (١٥/١٧٨) ٦٩٦٧ قال ابنُ جرير (٢٣/٥٩٤) مبيّنًا معنى الآية استنادًا إلى أثر ابن عباس: «يقول -تعالى ذِكْره-: <q>﴿ألم نخلقكم﴾</q> أيها الناس <q>﴿من ماء مهين﴾</q> يعني: من نُطفة ضعيفة». ٨٠٧١٢- عن مجاهد بن جبر، في قوله: <q>﴿مِن ماءٍ مَهِينٍ﴾</q>، قال: ضعيف{2}. (١٥/١٧٨) ٨٠٧١٣- قال مقاتل بن سليمان: ثم بيّن لهم بَدء خَلْق أنفسهم؛ لئلا يُكذّبوا بالبعث، وليَعتبِروا، فقال: يا مَعشر المُكذِّبين، <q>﴿ألَمْ نَخْلُقْكُمْ مِن ماءٍ مَهِينٍ﴾</q>. يقول: ماء ضعيف، وهو النّطفة{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٤.عزاه السيوطي إلى ابن جرير، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
77,21," <q>﴿فَجَعَلۡنَـٰهُ فِی قَرَارࣲ مَّكِینٍ ۝٢١ إِلَىٰ قَدَرࣲ مَّعۡلُومࣲ ۝٢٢﴾</q> - تفسير ٨٠٧١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَجَعَلْناهُ فِي قَرارٍ مَكِينٍ﴾</q>، قال: الرَّحِم{1}. (١٥/١٧٨) ٨٠٧١٥- قال مقاتل بن سليمان: <q>﴿فَجَعَلْناهُ فِي قَرارٍ مَكِينٍ﴾</q> يعني: الماء يَتمَكّن في الرَّحِم، <q>﴿إلى قَدَرٍ مَعْلُومٍ﴾</q> يعني: تسعة أشهُر{2}. (ز) ",footnotes:1:تفسير مجاهد ص٦٩١، وأخرجه ابن جرير ٢٣/٥٩٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٤.
  77,22,""
77,23," <q>﴿فَقَدَرۡنَا فَنِعۡمَ ٱلۡقَـٰدِرُونَ ۝٢٣ وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٢٤﴾</q> - تفسير ٨٠٧١٦- عن الضَّحّاك بن مُزاحِم -من طريق جُويبر- <q>﴿فَقَدَرْنا فَنِعْمَ القادِرُونَ﴾</q> قال: فخَلَقنا فنِعْم المالكون{1}. (١٥/١٧٩) ٨٠٧١٧- قال مقاتل بن سليمان: <q>﴿فَقَدَرْنا﴾</q> الصّبيَّ في رَحِم أُمّه تسعة أشهُر، ودون ذلك أو فوق ذلك، فقال الله ﷿: <q>﴿فَنِعْمَ القادِرُونَ﴾</q>، ثم قال: <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>{2}. (ز) ٨٠٧١٨- عن عبد الملك ابن جُرَيْج، <q>﴿فَقَدَرْنا فَنِعْمَ القادِرُونَ﴾</q>، قال: فمَلكنا فنِعْم المالكون{3}. (١٥/١٧٩) ",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٦.تفسير مقاتل بن سليمان ٤/٥٤٤.عزاه السيوطي إلى ابن المنذر.
  77,24,""
77,25," <q>﴿أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ كِفَاتًا ۝٢٥ أَحۡیَاۤءࣰ وَأَمۡوَ ٰ⁠تࣰا ۝٢٦﴾</q> - تفسير ٨٠٧١٩- عن عبد الله بن مسعود -من طريق الرّبيع بن خُثَيْم-: أنه أخذ قَمْلَة، فدفنها في المسجد، ثم قرأ: <q>﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</q>{1}. (١٥/١٧٩) ٨٠٧٢٠- عن عبد الله بن عباس -من طريق علي- <q>﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا﴾</q>، قال:كِنًّا{2}. (١٥/١٧٩) ٨٠٧٢١- عن مجاهد بن جبر -من طريق عثمان بن الأسود- <q>﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا﴾</q>، قال: تَكْفِتُهم أمواتًا، وتَكُفّ أذاهم أحياء{3}. (١٥/١٧٩) ٨٠٧٢٢- عن مجاهد بن جبر، <q>﴿كِفاتًا﴾</q> قال: تَكْفِتُ الميت، ولا يُرى منه شيء. وقوله: <q>﴿أحْياءً﴾</q> الرجل في بيته لا يُرى من عمله شيء{4}. (١٥/١٧٩) ٨٠٧٢٣- عن مجاهد بن جبر -من طريق ليث- قال: إذا وجدتَ قَمْلَة في المسجد فادفنها، ويقول: <q>﴿ألم نجعل الأرض كفاتا أحياء وأمواتا﴾</q>{5}. (ز) ٨٠٧٢٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</q>، قال: أحياء يكونون فيها، ويُغيِّبون فيها ما أرادوا. وفي لفظ: يُغيِّبون فيها ما أرادوا. وقوله: <q>﴿أحْياءً وأَمْواتًا﴾</q>، قال: يُدفنون فيها{6}. (ز) ٨٠٧٢٥- عن عامرالشعبي -من طريق بيان- <q>﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</q>، قال: بَطنها لأمواتكم، وظَهرها لأحيائكم{7}. (ز) ٨٠٧٢٦- عن بَيان بن بِشر، قال: خَرجْنا في جنازة فيها عامر الشعبي، فلما انتَهينا إلى الجبّان تلا هذه الآية: <q>﴿ألم نجعل الأرض كفاتا أحياء وأمواتا﴾</q>، قال: كِفات الأموات -وأشار إلى القبور-، وهذه كِفات الأحياء -وأشار بيده إلى البيوت-{8}. (ز) ٨٠٧٢٧- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿أحْياءً وأَمْواتًا﴾</q>، قال: أحياء فوقها على ظهرها، وأمواتًا يُقبرون فيها{9}. (ز) ٨٠٧٢٨- قال مقاتل بن سليمان: قال: <q>﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا أحْياءً وأَمْواتًا﴾</q> أليس قد جَعل لكم الأرض كِفاتًا لكم، تَدفِنون فيها أمواتكم، وتَبثُّون عليها أحياءكم، وتَسكنون عليها؟! فقد كَفت الموتى والأحياء{10}٦٩٦٨. (ز) ٦٩٦٨ قال ابنُ جرير (٢٣/٥٩٦) مبيّنًا معنى الآية استنادًا إلى أقوال السلف: «يقول -تعالى ذِكْره- مُنبِّهًا عباده على نِعَمه عليهم: <q>﴿ألم نجعل﴾</q> أيها الناس <q>﴿الأرض﴾</q> لكم <q>﴿كفاتا﴾</q> يقول: وعاء، يُقال: هذا كِفْتُ هذا وكَفِيتُه: إذا كان وعاءه. وإنما معنى الكلام: ألم نجعل الأرض كِفات أحيائكم وأمواتكم، تَكْفِتُ أحياءكم في المساكن والمنازل، فتضمّهم فيها وتجمعهم، وأمواتكم في بطنِها في القبور، فيُدفنون فيها». وذكر احتمالًا آخر، فقال: «وجائز أن يكون عُنِي بقوله: <q>﴿كفاتا أحياء وأمواتا﴾</q> تَكْفِتُ أذاهم في حال حياتهم، وجيَفَهم بعد مماتهم». وذكر ابنُ عطية (٨/٥٠٦) نحو قول ابن جرير في معنى <q>﴿كِفاتًا﴾</q>، ثم قال: «و<q>﴿أحياء﴾</q> -على هذا التأويل- معمول لقوله سبحانه: <q>﴿كِفاتًا﴾</q> لأنه مصدر». ونقل عن بعض المتأولين: أنّ «<q>﴿أحْياءً وأَمْواتًا﴾</q> إنما هو بمعنى أنّ الأرض فيها أقطارٌ أحياءٌ وأقطارٌ أموات». ووجَّهه بقوله: «يراد: ما يُنبت وما لا يُنبت، فنصب <q>﴿أحْياءً﴾</q> -على هذا- إنما هو على الحال من الأرض». ثم رجَّح قائلًا: «والتأويل الأول أقوى». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن أبي شيبة ٢/٣٦٨، وابن جرير ٢٣/٥٩٧، والبيهقي في سننه ٢/٢٩٤. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٥٩٦، وابن أبي حاتم -كما في الإتقان ٢/٥١-.أخرجه ابن جرير ٢٣/٥٩٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٣٨ (٢٣٧٤)، وابن جرير ٢٣/٥٩٧ بنحوه.تفسير مجاهد ص٦٩١، وأخرجه ابن جرير ٢٣/٥٩٨.أخرجه ابن جرير ٢٣/٥٩٧.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٣٧ (٢٣٧٢).أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٥٩٨، وبنحوه من طريق سعيد.تفسير مقاتل بن سليمان ٤/٥٤٤-٥٤٥.
  77,26,""
77,27," <q>﴿وَجَعَلۡنَا فِیهَا رَوَ ٰ⁠سِیَ شَـٰمِخَـٰتࣲ وَأَسۡقَیۡنَـٰكُم مَّاۤءࣰ فُرَاتࣰا ۝٢٧﴾</q> - تفسير ٨٠٧٢٩- عن عبد الله بن عباس -من طريق علي- <q>﴿رَواسِيَ﴾</q>، قال: جبالًا مُشرِفات{1}. (١٥/١٨٠) ٨٠٧٣٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجَعَلْنا فِيها رَواسِيَ شامِخاتٍ﴾</q>: يعني: الجبال{2}. (ز) ٨٠٧٣١- قال مقاتل بن سليمان: فقال: <q>﴿وجَعَلْنا فِيها رَواسِيَ شامِخاتٍ﴾</q> وهي جبال راسخة في الأرض أوتادًا{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٩، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٥٩٨.تفسير مقاتل بن سليمان ٤/٥٤٥.
77,28," <q>﴿وَأَسۡقَیۡنَـٰكُم مَّاۤءࣰ فُرَاتࣰا ۝٢٧ وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٢٨﴾</q> - تفسير ٨٠٧٣٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فُراتًا﴾</q>: عَذْبًا{1}. (١٥/١٨٠) ٨٠٧٣٣- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿وأَسْقَيْناكُمْ ماءً فُراتًا﴾</q>، قال: مِن أربعة أنهار: سَيْحان، وجَيْحان، والنّيل، والفُرات، وكلّ ماء يَشربه ابن آدم فهو من هذه الأنهار٦٩٦٩، وهي تَخرج من تحت صخرة من عند بيت المقدس؛ وأما سَيْحان فهو ببلخ، وأما جَيْحان فدِجْلة، وأما الفُرات ففُرات الكوفة، وأما النّيل فهو نيل مصر{2}. (ز) ٦٩٦٩ نقل ابنُ عطية (٨/٥٠٧) عن عكرمة نحو قول ابن عباس، فقال: «حُكي عن عكرمة أنّ كل ماء في الأرض فهو من هذه». أي: من هذه الأنهار الأربعة، وانتقده قائلًا: «وفي هذا بُعْد». ٨٠٧٣٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿ماءً فُراتًا﴾</q>، قال: عَذْبًا{3}. (ز) ٨٠٧٣٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَسْقَيْناكُمْ ماءً فُراتًا﴾</q>: أي: ماء عَذْبًا{4}. (ز) ٨٠٧٣٦- قال مقاتل بن سليمان: ثم قال: <q>﴿وأَسْقَيْناكُمْ ماءً فُراتًا﴾</q> يقول: ماء حُلوًا، <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q> بالبعث، وقد عَلِموا أنّ الله تعالى قد خَلَق هذه الأشياء كلّها{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٥٩٩، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٥٩٩-٦٠٠.تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٥٩٩.أخرجه ابن جرير ٢٣/٥٩٩.تفسير مقاتل بن سليمان ٤/٥٤٥.
77,29," <q>﴿ٱنطَلِقُوۤا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ ۝٢٩﴾</q> - تفسير ٨٠٧٣٧- قال مقاتل بن سليمان: قوله: <q>﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</q> في الدنيا أنّه غير كائن، وهي النار، وذلك أنه إذا انطلَق أهلُ النار وهي تُهمْهِم زَفرتْ جهنمُ زَفرةً واحدة، فيَخرج عُنُق، فيُحيط بأهلها، ثم تَزْفُر زفرةً أخرى، فيَخرج عُنُق لها من نار، وتُحيط بهم، ثم تَزْفِرُ الثالثة، فيَخرج عُنُق، فيُحيط بالآخرين، فتصير حولهم سُرادق من نار، فيَخرج دُخان من جهنم، فيقوم فوقهم، فيظنّ أهلها أنه ظِلٌّ، وأنه سينفعهم من هذه النار، فيَنطلِقون كلّهم بأجمعهم، فيَستظِلّون تحتها، فيَجدونها أشدّ حرًّا من السُّرادق، فذلك قوله: <q>﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</q>، وهو شِعْب بجهنم، أنهم كَذّبوا الرُّسُل في الدنيا بأنّ العذاب في الآخرة ليس بكائن، فتقول لهم الملائكة الخُزّان: <q>﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٥.
77,30," <q>﴿ٱنطَلِقُوۤا۟ إِلَىٰ ظِلࣲّ ذِی ثَلَـٰثِ شُعَبࣲ ۝٣٠﴾</q> - تفسير ٨٠٧٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q>: دُخان جهنم{1}٦٩٧٠. (١٥/١٨٠) ٦٩٧٠ نقل ابنُ عطية (٨/٥٠٧) رواية -ولم ينسبها-: أن دخان جهنم «يعلو من ثلاثة مواضع، فيراه الكفار، فيظنون أنه مُغْنٍ، فيُهرعون إليه، فيجدونه على أسوأ وصف». ونقل عن ابن عباس في معنى الآية قوله: «هذه المخاطبة إنما تقال يومئذ لِعَبَدَة الصليب إذا اتَّبع كلّ أحد ما كان يعبد، فيكون المؤمنون في ظِلّ الله تعالى، ولا ظلَّ إلا ظلُّه، ويقال لعَبَدة الصليب: انطَلِقُوا إلى ظِلِّ معبودكم، وهو الصليب، له ثَلاثُ شُعَبٍ، والشُّعب تفرق الجسم الواحد فرقًا، ثم نفى تعالى عنه محاسن الظِّل». ٨٠٧٣٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q>، قال: هو كقوله: <q>﴿نارًا أحاطَ بِهِمْ سُرادِقُها﴾</q> [الكهف:٢٩] قال: والسُّرادق: دُخان النار. فأحاط بهم سُرادقها، ثم تَفَرّق، فكان ثلاث شُعَب، فقال: <q>﴿انْطَلِقُوا إلى ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q>؛ شُعبة هاهنا، وشُعبة هاهنا، وشُعبة هاهنا، <q>﴿لا ظَلِيلٍ ولا يُغْنِي مِنَ اللَّهَبِ﴾</q>{2}. (١٥/١٨٠) ٨٠٧٤٠- عن محمد بن السّائِب الكلبي -من طريق معمر- في قوله: <q>﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q>، قال: هو كقوله: <q>﴿نارًا أحاطَ بِهِمْ سُرادِقُها﴾</q> [الكهف:٢٩]، والسُّرادق: الدُّخان؛ دُخان النار، فأحاط بهم سُرادقها، ثم تَفَرّق فكان ثلاث شُعَب؛ شُعبة ههنا، وشُعبة ههنا، وشُعبة ههنا{3}. (١٥/١٨٠) ٨٠٧٤١- قال مقاتل: <q>﴿ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q> هو السُّرادق، والظِّلّ من يَحموم{4}. (ز) ٨٠٧٤٢- قال مقاتل بن سليمان: <q>﴿انْطَلِقُوا إلى ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q> لأنها تَنقطع ثلاث قِطع{5}. (ز) ",footnotes:1:تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٦٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٦٠٠-٦٠١.أخرجه عبد الرزاق ١/٤٠٢، ٢/٣٤٠.تفسير الثعلبي ١٠/١١٠.تفسير مقاتل بن سليمان ٤/٥٤٥.
77,31," <q>﴿لَّا ظَلِیلࣲ وَلَا یُغۡنِی مِنَ ٱللَّهَبِ ۝٣١﴾</q> - تفسير ٨٠٧٤٣- قال محمد بن السّائِب الكلبي: <q>﴿لا ظَلِيلٍ ولا يُغْنِي مِنَ اللَّهَبِ﴾</q> لا يُردّ لهب جهنم عنكم{1}. (ز) ٨٠٧٤٤- قال مقاتل بن سليمان: قوله: <q>﴿لا ظَلِيلٍ﴾</q> يقول: لا بارد، <q>﴿ولا يُغْنِي مِنَ اللَّهَبِ﴾</q> يقول: مِن ذلك السُّرادق الذي قد أحاط حولهم{2}. (ز) ",footnotes:1:تفسير البغوي ٦/٣٠٦.تفسير مقاتل بن سليمان ٤/٥٤٥.
77,32," <q>﴿إِنَّهَا تَرۡمِی بِشَرَرࣲ كَٱلۡقَصۡرِ ۝٣٢﴾</q> - قراءات ٨٠٧٤٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- أنه قرأها: (كالقَصَرِ) بفتح القاف والصاد، قال: قَصَر النّخل. يعني: الأعناق{1}. (١٥/١٨١) ٨٠٧٤٦- عن عكرمة مولى ابن عباس أنه كان يقرأ: <q>﴿كالقَصْرِ﴾</q>، قال: كقطعة النّخلة الحادرة{2}. (١٥/١٨٤) ٨٠٧٤٧- عن الحسن البصري -من طريق هارون- أنه قرأ: <q>﴿كالقَصْرِ﴾</q> بجزم الصاد، وقال: هو الجَزْل من الخَشَب{3}. (١٥/١٨٣) <q>﴿إِنَّهَا تَرۡمِی بِشَرَرࣲ كَٱلۡقَصۡرِ ۝٣٢﴾</q> - تفسير الآية ٨٠٧٤٨- عن عبد الله بن مسعود -من طريق عَلقمة- في قوله: <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: إنها ليستْ كالشجر والجبال، ولكنها مِثل المدائن والحُصون{4}. (١٥/١٨٢) ٨٠٧٤٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿بِشَرَرٍ كالقَصْرِ﴾</q>، قال: مثل قَصْر النّخلة{5}. (ز) ٨٠٧٥٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بِشَرَرٍ كالقَصْرِ﴾</q>، قال: كالقَصْر العظيم{6}. (١٥/١٨٠) ٨٠٧٥١- عن عبد الله بن عباس -من طريق عبد الرحمن بن عابس- في قوله: <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: كُنّا نرفع الخَشَب بقِصَر ثلاثة أذرع أو أقل، فنرفعه للشتاء، فنُسمِّيه: القَصْر{7}. (١٥/١٨١) ٨٠٧٥٢- عن عبد الله بن عباس، (كالقَصَرِ)، قال: كجذور الشجر{8}. (١٥/١٨١) ٨٠٧٥٣- عن عبد الله بن عباس -من طريق عبد الرحمن بن عابس- قال: كانت العرب تقول في الجاهلية: اقصُرُوا لنا الحَطَب، فيُقطع على قَدْر الذّراع والذّراعين{9}. (١٥/١٨١) ٨٠٧٥٤- عن عبد الله بن عباس، في قوله: <q>﴿كالقَصْرِ﴾</q>، قال: هو القصر{10}. (١٥/١٨٢) ٨٠٧٥٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>: فالقَصْر: الشجر المُقطّع. ويقال: القَصْر: النّخل المقطوع{5}. (ز) ٨٠٧٥٦- عن علقمة بن قيس -من طريق أبي إسحاق- <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: ليس كالخَشَب، ولكن كالقصور والمدائن{12}. (ز) ٨٠٧٥٧- عن سعيد بن جُبَير، في قوله: <q>﴿كالقَصْرِ﴾</q>، قال: مثل قَصْر النّخلة{13}. (١٥/١٨٢) ٨٠٧٥٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كالقَصْرِ﴾</q>، قال: حِزَم الشجر، وقِطَع النّخل{14}. (١٥/١٨٣) ٨٠٧٥٩- عن مجاهد بن جبر -من طريق خُصَيف- <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: ذكَر القصرَ{15}. (ز) ٨٠٧٦٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في الآية: <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: القَصْر: أصول الشجر العِظام، كأنها أجْواز الإبل الصُّفر{16}. (١٥/١٨٣) ٨٠٧٦١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿كالقَصْرِ﴾</q>، قال: أصول الشجر، وأصول النّخل{17}. (١٥/١٨٣) ٨٠٧٦٢- قال محمد بن كعب القُرَظيّ -من طريق أبي صخر- في قول الله: <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: إنّ على جهنم سُورًا، فما خرج مِن وراء السُّور مِمّا يَرجع فيها في عِظَم القَصْر، ولون القار{18}. (ز) ٨٠٧٦٣- عن الأسود -من طريق عطاء بن السّائِب- <q>﴿تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>، قال: مثل القَصْر{19}. (ز) ٨٠٧٦٤- قال مقاتل بن سليمان: ثم ذَكر الظِّل، فقال: <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q> وهو أصول الشجر يكون في البَريّة، فإذا جاء الشتاء قُطعتْ أغصانها، فتبقى أصولها، فيَحرقها البرد، فَتَسْوَدُّ، فتراها في البَريّة كأمثال الجمال إذا أُنيخَتْ في البَريّة، فذلك قوله: <q>﴿إنَّها تَرْمِي بِشَرَرٍ كالقَصْرِ﴾</q>{20}٦٩٧١. (ز) ٦٩٧١ اختَلف القراء في قراءة قوله تعالى: <q>﴿كالقصر﴾</q> على وجهين: الأول: بسكون الصاد -وهي قراءة الجمهور-، هكذا <q>﴿كالقَصْر﴾</q>، واخْتُلِف في المعنى -على هذه القراءة- على قولين: أولهما: أنّ القَصْر هنا واحد القصور. وثانيهما: أنّ المراد به هنا الغليظ من الخَشَب، كأصول النّخل، وما أشبه ذلك. والثاني: بفتح الصاد -وهي قراءة لابن عباس-، هكذا (كالقَصَر)، بمعنى: أعناق الدواب. ورجَّحَ ابنُ جرير (٢٣/٦٠٤-٦٠٥) قراءة الجمهور، والتأويل الأول لها استنادًا إلى السياق، ولغة العرب، فقال: «وأولى القراءتين بالصواب في ذلك عندنا ما عليه قُراء الأمصار، وهو سكون الصاد، وأولى التأويلات به أنه القَصْر من القصور، وذلك لدلالة قوله: <q>﴿كأنه جمالات صفر﴾</q> على صحته، والعرب تشبّه الإبل بالقصور المبنيّة ...، وقيل: <q>﴿بشرر كالقصر﴾</q> ولم يقل: كالقصور. والشّرر جماع، كما قيل: <q>﴿سيهزم الجمع ويولون الدبر﴾</q> [القمر:٤٥]، ولم يقل: الأدبار. لأنّ الدُّبر بمعنى الأدبار، وفعل ذلك توفيقًا بين رؤوس الآيات ومقاطع الكلام؛ لأن العرب تَفعل ذلك كذلك، وبلسانها نزل القرآن. وقيل: <q>﴿كالقصر﴾</q>، ومعنى الكلام: كعِظَم القَصْر، كما قيل: <q>﴿تدور أعينهم كالذي يغشى عليه من الموت﴾</q> [الأحزاب:١٩]، ولم يقل: كعيون الذي يُغشى عليه. لأنّ المراد في التشبيه الفعل لا العين». واستشهد بأثر الأسود. ورجَّح ابنُ عطية (٨/٥٠٨) قول ابن عباس من طريق عبد الرحمن بن عابس وما في معناه؛ أنّ القصر: «خشبٌ كان في الجاهلية يُقطَع من جَزْل الحطب من النّخل وغيره، على قدْر الذراع وفوقه ودونه، يُستَعَدُّ به للشتاء» قائلًا: «وهو المراد في الآية، وإنما سُمّي بالقَصْر لأنه يحيط بالقصرة». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن جرير ٢٣/٦٠٤. وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة، تروى أيضًا عن سعيد بن جبير. انظر: المحتسب ٢/٣٤٦، ومختصر ابن خالويه ص١٦٧.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.أخرجه ابن جرير ٢٣/٦٠٤.أخرجه الطبراني في الأوسط (٩١٢). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٦٠٣.أخرجه ابن جرير ٢٣/٦٠١، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤١، وهناد (٢٧٣)، والبخاري (٤٩٣٢-٤٩٣٣)، وابن جرير ٢٣/٦٠٢ بنحوه، وابن مردويه -كما في فتح الباري ٨/٦٨٨- بنحوه، والحاكم ٢/٥١١. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن مردويه -كما في فتح الباري ٧/٦٨٨-، وابن جرير ٢٣/٦٠٢ بنحوه.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٦٠٣.أخرجه ابن أبي الدنيا في كتاب صفة النار -ضمن موسوعة الإمام ابن أبي الدنيا ٦/٤٣٨ (١٧٣)-.عزاه السيوطي إلى ابن جرير وهو في بعض نسخ ابن جرير، وفي نسخة التركي ٢٣/٦٠٣ عن سعيد بن جُبَير، عن ابن عباس، كما تقدم.تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٦٠٣ بلفظ: حِزَم الشجر، يعني الحزمة. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٦٠١.أخرجه ابن جرير ٢٣/٦٠٣-٦٠٤. وقال عقبه: وسط كل شيء: جَوْزه.أخرجه عبد الرزاق ٢/٣٤٠ من طريق معمر، وابن جرير ٢٣/٦٠٣ بنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٥٢ (١١٢)، وابن جرير ٢٣/٦٠١-٦٠٢.أخرجه ابن جرير ٢٣/٦٠٥.تفسير مقاتل بن سليمان ٤/٥٤٥-٥٤٦.
77,33," <q>﴿كَأَنَّهُۥ جِمَـٰلَتࣱ صُفۡرࣱ ۝٣٣﴾</q> - قراءات ٨٠٧٦٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- أنه كان يقرأ: ‹جُمالاتٌ› بضم الجيم {1}٦٩٧٢. (١٥/١٨١) ٦٩٧٢ اختَلف القُراء في قراءة قوله تعالى: <q>﴿جمالات﴾</q> على ثلاثة أوجه: الأول: بكسر الجيم، وتاء مفتوحة في آخرها -وهي قراءة عامة أهل المدينة والبصرة، وبعض الكوفيّين-، هكذا ‹جِمالاتٌ›، على أنها جمع جِمال. والثاني: بكسر الجيم، وهاء التأنيث في آخرها -وهي قراءة عامة الكوفيّين-، هكذا <q>﴿جِمالَتٌ﴾</q>، على أنها جمع جَمَل،كما يقال: حِجارة جمع حَجَر. والثالث: بضم الجيم، وتاء مفتوحة في آخرها -وهي قراءة لابن عباس-، هكذا ‹جُمالات›، على أنها جمع «جُمالة» أي: الشيء المجمل. وعلَّقَ ابنُ عطية (٨/٥٠٩ بتصرف) على هذه الأوجه بقوله: «ضم الجيم فيها من»الجُمْلة«لا من»الجَمَل«، وكسرها من»الجَمَل«لا من»الجُمْلة«». وذَهَبَ ابنُ جرير (٢٣/٦٠٩) إلى صحة الوجهين الأول والثاني، فقال: «الصواب من القول في ذلك أنّ لقارئ ذلك اختيار أي القراءتين شاء من كسر الجيم وقراءتها بالتاء وكسر الجيم، وقراءتها بالهاء التي تصير في الوصل تاء؛ لأنهما القراءتان المعروفتان في قراء الأمصار». وانتَقَدَ (٢٣/٦٠٩) الوجه الثالث، فقال: «أما ضم الجيم فلا أستجيزه؛ لإجماع الحُجّة من القرأة على خلافه». <q>﴿كَأَنَّهُۥ جِمَـٰلَتࣱ صُفۡرࣱ ۝٣٣﴾</q> - تفسير الآية ٨٠٧٦٦- عن عبد الله بن عباس -من طريق علي-: ‹جِمالاتٌ صُفْرٌ›، قال: قِطَع النّحاس{2}. (١٥/١٨٠) ٨٠٧٦٧- عن عبد الله بن عباس -من طريق عبد الرحمن بن عابس- أنه سئل عن قوله: <q>﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</q>. قال: حِبال السُّفن يُجمع بعضها إلى بعض حتى تكون كأوساط الرجال{3}. (١٥/١٨١) ٨٠٧٦٨- عن عبد الله بن عباس، في قوله: ‹كَأَنَّهُ جِمالاتٌ صُفْرٌ›، قال: الإبل{4}. (١٥/١٨٢) ٨٠٧٦٩- عن سعيد بن جُبَير -من طريق أبي بشر- في قوله: <q>﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</q>: الحِبال{5}. (١٥/١٨٢) ٨٠٧٧٠- عن سعيد بن جُبَير -من طريق هلال بن خَبّاب- في قوله: <q>﴿جِمالَتٌ صُفْرٌ﴾</q>، قال: قُلُوس الجسر{6}. (ز) ٨٠٧٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</q>، قال: حِبال الجُسور{7}. (١٥/١٨٣) ٨٠٧٧٢- عن مجاهد بن جبر -من طريق خُصَيف- <q>﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</q>، قال: هي الإبل{8}. (ز) ٨٠٧٧٣- عن عكرمة مولى ابن عباس أنه كان يقرأ: ‹جِمالاتٌ صُفْرٌ›، قال: القَلُوص{9}. (١٥/١٨٤) ٨٠٧٧٤- عن الحسن البصري في قوله: ‹كأنه جِمالاتٌ صُفْر› قال: الصُّفر السُّود{10}. (١٥/١٨٢) ٨٠٧٧٥- عن الحسن البصري -من طريق داود بن أبي هند- <q>﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</q>، قال: الأيْنُق السُّود{11}. (١٥/١٨٣) ٨٠٧٧٦- عن قتادة بن دعامة -من طريق معمر- (كَأَنَّهُ جِمالاتٌ صُفْرٌ)، قال: كأنه نُوق سُود{12}. (١٥/١٨٣) ٨٠٧٧٧- قال مقاتل بن سليمان: <q>﴿كَأَنَّهُ جِمالَتٌ صُفْرٌ﴾</q>، يقول: كأنها جِمال سوداء إذا رأيتَها من مكان بعيد{13}٦٩٧٣. (ز) ٦٩٧٣ اختُلِف في تأويل قوله تعالى: <q>﴿جمالات صفر﴾</q> على ثلاثة أقوال: الأول: أنّها الجِمال الصُّفْر، وأراد بالصُّفْر: السُّود، سُمِّيت «صُفْرًا» لأنّ سَوادها يَضرِب إلى الصُّفرة. وهو قول الحسن، ومجاهد، وقتادة. والثاني: أنها قُلُوس السُّفن، والقُلُوس: جمْع قَلْس، وهو حَبل ضخم من لِيف. وهو قول ابن عباس، وسعيد بن جُبَير. والثالث: أنها قِطَع النّحاس. وهو قولٌ آخر لابن عباس. وعلَّق ابنُ عطية (٨/٥٠٩) على القول الثالث بقوله: «وكان اشتقاق هذه اللفظة من اسم الجملة». ورجَّحَ ابنُ جرير (٢٣/٦٠٨) القولَ الأولَ استنادًا إلى لغة العرب، فقال: «أولى الأقوال عندي بالصواب قول مَن قال: عُني بالجمالات الصُّفر: الإبل السُّود؛ لأن ذلك هو المعروف من كلام العرب، وأنّ الجِمالات جمع جِمال، نظير: رجال، ورجالات، وبيوت، وبيوتات». ونقل ابنُ عطية عن جمهور الناس أنّ «الصُّفْر: الفاقعة؛ لأنها أشبه بلون الشَّرَر». <q>﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾</q> - تفسير ٨٠٧٧٨- قال مقاتل بن سليمان: <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q> بالبعْث{13}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٦٠٩. وعزاه السيوطي إلى ابن المنذر. و‹جُمالاتٌ› بضم الجيم قراءة متواترة، قرأ بها رويس، وكسرها على التوحيد: <q>﴿جِمالَتٌ﴾</q> حمزة، والكسائي، وخلف، وحفص، وكسرها على الجمع بقية العشرة: ‹جِمالاتٌ›. انظر: النشر ٢/٣٩٧، والإتحاف ص٥٦٨.أخرجه ابن جرير ٢٣/٦٠٨، وابن أبي حاتم -كما في الإتقان ٢/٥١-٥٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤١، وهناد (٢٧٣)، والبخاري (٤٩٣٢-٤٩٣٣)، وابن جرير ٢٣/٦٠٦، ٦٠٧، ٦٠٨ وبنحوه من طريق عطية وسليمان، وابن مردويه -كما في فتح الباري ٨/٦٨٨- بنحوه، والحاكم ٢/٥١١. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٦٠٧. وعزاه السيوطي إليه بلفظ: هو الجسر. وفي لفظ: كالجبال.أخرجه ابن جرير ٢٣/٦٠٧ من طرق.تفسير مجاهد ص٦٩٢، وأخرجه ابن جرير ٢٣/٦٠٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٦٠٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن الأنباري في كتاب الأضداد ص١٦٠، ١٦١.أخرجه ابن جرير ٢٣/٦٠٥-٦٠٦ بلفظ: الأينق السود.أخرجه عبد الرزاق ٢/٣٤٠، وابن جرير ٢٣/٦٠٦، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٦.تفسير مقاتل بن سليمان ٤/٥٤٦.
77,34," <q>﴿هَـٰذَا یَوۡمُ لَا یَنطِقُونَ ۝٣٥ وَلَا یُؤۡذَنُ لَهُمۡ فَیَعۡتَذِرُونَ ۝٣٦﴾</q> - تفسير ٨٠٧٧٩- عن عبد الله بن الصّامت، قال: قلت لعبد الله بن عمرو بن العاص: أرأيتَ قول الله: <q>﴿هَذا يَوْمُ لا يَنْطِقُونَ ولا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</q>. قال: إنّ يوم القيامة يوم له حالات وتارات؛ في حال لا يَنطِقون، وفي حال يَنطِقون، وفي حال يَعْتذِرون، لا أُحدِّثكم إلا ما حدَّثنا رسول الله ﷺ، قال: «إذا كان يوم القيامة يَنزل الجبّار في ظُلَل من الغمام -وكلّ أُمّة جاثية- في ثلاث حُجُب، مسيرة كلّ حجاب خمسون ألف سنة؛ حِجاب من نور، وحِجاب من ظُلمة، وحِجاب من ماء، لا يُرى لذلك، فيَأمر بذلك الماء فيعود في تلك الظُّلمة، ولا تَسمع نفس ذلك القول إلا ذَهبت، فعند ذلك لا يَنطِقون»{1}. (١٥/١٨٤) ٨٠٧٨٠- عن عبد الله بن عباس -من طريق عكرمة- أنّ نافع بن الأزرق سأله عن قوله تعالى: <q>﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</q>، و<q>﴿فَلا تَسْمَعُ إلّا هَمْسًا﴾</q> [طه:١٠٨]، و<q>﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q> [الصافات:٢٧، والطور:٢٥]، و<q>﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</q> [الحاقة:١٩]، فما هذا؟ قال: ويحك! هل سألتَ عن هذا أحدًا قبلي؟ قال: لا. قال: أما إنك لو كنتَ سألتَ هَلكتَ؛ أليس قال الله تعالى: <q>﴿وإنَّ يَوْمًا عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾</q> [الحج:٤٧]؟ قال: بلى. قال: وإنّ لكلّ مقدار يوم من هذه الأيام لونًا من الألوان{2}. (١٥/١٨٤) ٨٠٧٨١- عن أبي الضُّحى، أنّ نافع بن الأزرق وعطية أتيا ابن عباس، فقالا: يا ابن عباس، أخبِرنا عن قول الله: <q>﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</q>، وقوله: <q>﴿ثُمَّ إنَّكُمْ يَوْمَ القِيامَةِ عِنْدَ رَبِّكُمْ تَخْتَصِمُونَ﴾</q> [الزمر:٣١]، وقوله: <q>﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</q> [الأنعام:٢٣]، وقوله: <q>﴿ولا يَكْتُمُونَ اللَّهَ حَدِيثًا﴾</q> [النساء:٤٢]. قال: ويحك، يا ابن الأزرق، إنه يوم طويل، وفيه مواقف؛ تأتي عليهم ساعة لا يَنطِقون، ثم يُؤذن لهم فيَختَصِمون، ثم يَمكُثون ما شاء الله يَحلِفون ويَجْحدون، فإذا فَعلوا ذلك خَتم الله على أفواههم، ويَأمر جوارحهم، فتَشهد على أعمالهم بما صَنعوا، ثم تَنطِق ألسنتهم فيَشهدون على أنفسهم بما صَنعوا. قال: وذلك قوله: <q>﴿ولا يَكْتُمُونَ اللَّهَ حَدِيثًا﴾</q>{3}. (١٥/١٨٥) ٨٠٧٨٢- عن عكرمة أنه سُئل عن قوله: <q>﴿يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q> [المعارج:٤]. قال: ألا أُخبرِكم بأشدّ مما تسألون عنه؟ قال ابن عباس، وذَكر: <q>﴿لا يُسْأَلُ عَنْ ذَنْبِهِ إنْسٌ ولا جانٌّ﴾</q> [الرحمن:٣٩]، <q>﴿فَوَرَبِّكَ لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾</q> [الحجر:٩٢]، و<q>﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</q>، قال ابن عباس: إنها أيام كثيرة في يوم واحد، فيَصنع الله فيها ما يشاء، فمنها: <q>﴿يَوْمُ لا يَنْطِقُونَ﴾</q>، ومنها: <q>﴿يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</q> [الإنسان:١٠]{4}. (١٥/١٨٥) ٨٠٧٨٣- عن قتادة، قال جاء رجل إلى عكرمة، فقال: أرأيتَ قول الله تعالى: <q>﴿هذا يوم لا ينطقون﴾</q>، وقوله: <q>﴿ثُمَّ إنَّكُمْ يَوْمَ القِيامَةِ عِنْدَ رَبِّكُمْ تَخْتَصِمُونَ﴾</q> [الزمر:٣١]؟ قال: إنها مواقف، فأما موقف منها فتكلموا واختصموا، ثم ختم الله على أفواههم، فتكلمت أيديهم وأرجلهم، فحينئذ لا ينطقون{5}. (ز) ٨٠٧٨٤- قال مقاتل بن سليمان: ثم ذَكر الويل متى يكون، فقال: <q>﴿هَذا يَوْمُ لا يَنْطِقُونَ ولا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</q>، فقال: أن تَعتذروا{6}. (ز) <q>﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾</q> - تفسير ٨٠٧٨٥- قال مقاتل بن سليمان: <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q> بالبعث{6}. (ز) ",footnotes:1:عزاه ابن حجر في الفتح ٨/٦٨٦ إلى ابن مردويه مقتصرًا على أوله، وعزاه إليه بتمامه السيوطي ١٥/١٨٤.أخرجه الحاكم ٤/٥٧٣.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٢-، وعبد بن حميد -كما في فتح الباري ٨/٦٨٦-.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/١٦٢.تفسير مقاتل بن سليمان ٤/٥٤٦.تفسير مقاتل بن سليمان ٤/٥٤٦.
  77,35,""
  77,36,""
77,37," <q>﴿هَـٰذَا یَوۡمُ ٱلۡفَصۡلِۖ جَمَعۡنَـٰكُمۡ وَٱلۡأَوَّلِینَ ۝٣٨﴾</q> - تفسير ٨٠٧٨٦- عن أبي عبد الله الجَدَليّ، قال: أتيتُ بيت المقدس، فإذا عُبادة بن الصّامت وعبد الله بن عمرو وكعب الأحبار يتَحدَّثون في بيت المقدس، فقال عُبادة: إذا كان يوم القيامة جُمِع الناسُ في صعيد واحد، فيَنفُذُهم البَصر، ويَسمَعهم الداعي، ويقول الله: <q>﴿هَذا يَوْمُ الفَصْلِ جَمَعْناكُمْ والأَوَّلِينَ فَإنْ كانَ لَكُمْ كَيْدٌ فَكِيدُونِ﴾</q> اليوم لا ينجو مني جبّار عنيد، ولا شيطان مريد. فقال عبد الله بن عمرو: إنّا نجد في الكتاب أنه يَخرج يومئذ عُنُق من النار، فيَنطلِق مُعْنِقًا{1}، حتى إذا كان بين ظهراني الناس قال: يا أيها الناس، إني بُعثتُ إلى ثلاثة أنا أعرفُ بهم من الوالد بولده، ومِن الأخ بأخيه، لا يُغنيهم مِنِّي وزَر، ولا تُخفِيهم مني خافية: الذي يجعل مع الله إلهًا آخر، وكلّ جبار عنيد، وكلّ شيطان مريد. قال: فَينطوي عليهم، فيَقذِفهم في النار قبل الحساب بأربعين -إمّا قال: يومًا، وإما عامًا-. قال: ويُهرَع قوم إلى الجنة، فتقول لهم الملائكة: قِفوا للحساب. فيقولون: واللهِ، ما كانت لنا أموال، وما كُنّا بعُمّال. فيقول الله: صدق عبادي، أنا أحقّ مَن أوفى بعهده، ادخُلوا الجنة. فيَدخلون الجنة قبل الحساب بأربعين -إمّا قال: يومًا، وإما عامًا-{2}. (١٥/١٨٦) ٨٠٧٨٧- قال مقاتل بن سليمان: ثم قال: إنّ <q>﴿هَذا﴾</q> الويل <q>﴿يَوْمُ الفَصْلِ﴾</q> وهو يوم القيامة، وهو يوم الدّين <q>﴿جَمَعْناكُم﴾</q> يا معشر أهل مكة، وسائر الناس ممن بعدكم، <q>﴿والأَوَّلِينَ﴾</q> الذين كَذّبوا بالبعْث من قبلكم من الأمم الخالية{3}. (ز) ",footnotes:1:معنقًا: مسرعًا. اللسان (عنق).أخرجه ابن أبي شيبة ١٣/١٧٠-١٧١. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٦.
  77,38,""
77,39," <q>﴿فَإِن كَانَ لَكُمۡ كَیۡدࣱ فَكِیدُونِ ۝٣٩ وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝٤٠﴾</q> - تفسير ٨٠٧٨٨- قال مقاتل بن سليمان: <q>﴿فَإنْ كانَ لَكُمْ كَيْدٌ فَكِيدُونِ﴾</q> فإن كان لكم مَكرٌ فامكُروا، <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q> بالبعْث{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٦.
  77,40,""
77,41," <q>﴿إِنَّ ٱلۡمُتَّقِینَ فِی ظِلَـٰلࣲ وَعُیُونࣲ ۝٤١ وَفَوَ ٰ⁠كِهَ مِمَّا یَشۡتَهُونَ ۝٤٢﴾</q> - تفسير ٨٠٧٨٩- قال مقاتل بن سليمان: قوله: <q>﴿إنَّ المُتَّقِينَ﴾</q> يعني به: المُوَحِّدين <q>﴿فِي ظِلالٍ وعُيُونٍ﴾</q> يعني: في جنات. يقول: في البساتين، ونعيم؛ فهو اللّباس الذي يَلبسون من سُندسٍ وإسْتَبرق والحرير والنّساء، <q>﴿وفَواكِهَ مِمّا يَشْتَهُونَ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٦.
  77,42,""
77,43," <q>﴿كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٤٣ إِنَّا كَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡمُحۡسِنِینَ ۝٤٤﴾</q> - تفسير ٨٠٧٩٠- عن عكرمة مولى ابن عباس، في قوله: <q>﴿كُلُوا واشْرَبُوا هَنِيئًا﴾</q>: أي: لا موت{1}. (١٥/١٨٧) ٨٠٧٩١- قال مقاتل بن سليمان: <q>﴿كُلُوا واشْرَبُوا هَنِيئًا بِما كُنْتُمْ تَعْمَلُونَ﴾</q> مِن الحسنات في دار الدنيا، ثم يا محمد <q>﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾</q> يقول: هكذا نجزي المُحسِنين مِن أُمّتك بأعمالهم في الجنة، ثم قال الله تعالى لكفار مكة: <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q> بالبعث{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٦.
  77,44,""
77,45," <q>﴿كُلُوا۟ وَتَمَتَّعُوا۟ قَلِیلًا إِنَّكُم مُّجۡرِمُونَ ۝٤٦﴾</q> - تفسير ٨٠٧٩٢- قال مقاتل بن سليمان: <q>﴿كُلُوا وتَمَتَّعُوا قَلِيلًا إنَّكُمْ مُجْرِمُونَ﴾</q> فيَحِلُّ بكم ما أُحِلَّ بالذين من قبلكم من العذاب{1}. (ز) ٨٠٧٩٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كُلُوا وتَمَتَّعُوا قَلِيلًا﴾</q>، قال: عني بذلك أهل الكفر{2}٦٩٧٤. (١٥/١٨٧) ٦٩٧٤ قال ابنُ عطية (٨/٥١٠): «قوله تعالى: <q>﴿كلوا وتمتعوا﴾</q> مخاطبة لقريش، على معنى: قل لهم، يا محمد. وهذه صيغة أمر معناها التهديد والوعيد، وقد بيّن ذلك قوله: <q>﴿قليلا﴾</q>، ثم بيّن تعالى لهم الإجرام الموجب لتعذيبهم. وقال مَن جعل السورة كلّها مكّية: إنّ هذه الآية في كفار قريش، وقال مَن جعل هذه الآية منها مدنية:»إن هذه الآية نزلت في المنافقين«. وقال مقاتل:»نزلت في ثقيف؛ لأنهم قالوا للنبي ﷺ: حُطَّ عنّا الصلاة؛ فإنّا لا ننحَني؛ لأنها مَسَبَّة، فأبى رسول الله ﷺ، وقال: «لا خير في دين لا صلاة فيه»". ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٦-٥٤٧.أخرجه ابن جرير ٢٣/٦١٢.
  77,46,""
77,47," <q>﴿وَإِذَا قِیلَ لَهُمُ ٱرۡكَعُوا۟ لَا یَرۡكَعُونَ ۝٤٨﴾</q> - نزول الآية ٨٠٧٩٤- قال مقاتل: نزلت في ثَقيف حيثُ أمرهم رسول الله ﷺ بالصلاة، فقالوا: لا ننحني؛ فإنها مَسَبّةٌ علينا. فقال رسول الله ﷺ: «لا خير في دينٍ ليس فيه ركوع ولا سجود»{1}. (ز) <q>﴿وَإِذَا قِیلَ لَهُمُ ٱرۡكَعُوا۟ لَا یَرۡكَعُونَ ۝٤٨﴾</q> - تفسير الآية ٨٠٧٩٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وإذا قِيلَ لَهُمُ ارْكَعُوا لا يَرْكَعُونَ﴾</q>، يقول: يُدعَون يوم القيامة إلى السجود، فلا يستطيعون السجود؛ مِن أجل أنهم لم يكونوا يَسجدون لله في الدنيا{2}. (١٥/١٨٨) ٨٠٧٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وإذا قِيلَ لَهُمُ ارْكَعُوا﴾</q>، قال: صَلُّوا{3}. (١٥/١٨٧) ٨٠٧٩٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا قِيلَ لَهُمُ ارْكَعُوا﴾</q>، قال: عليكم بإحسان الركوع؛ فإنّ الصلاة من الله بمكان. قال: وذُكر لنا: أنّ حُذيفة رأى رجلًا يُصلّي ولا يركع، كأنه بعير نافر، قال: لو مات هذا ما مات على شيء مِن سُنّة الإسلام. قال: وحُدِّثنا: أنّ ابن مسعود رأى رجلًا يُصلّي ولا يركع، وآخر يَجرّ إزاره، فضحك، قالوا: ما يُضحكك، يا ابن مسعود؟ قال: أضحكني رجلان؛ أحدهما لا يَنظر الله إليه، والآخر لا يَقبل الله صلاته{4}. (١٥/١٨٧-١٨٨) ٨٠٧٩٨- قال مقاتل بن سليمان: قال: <q>﴿وإذا قِيلَ لَهُمُ ارْكَعُوا لا يَرْكَعُونَ﴾</q>، يعني: الصلوات الخمس، قالوا: لا نُصلّي إلا أن يكون بين أيدينا أوثانًا{5}٦٩٧٥. (ز) ٦٩٧٥ اختلف أهل التأويل في الحين الذي يقال لهم فيه ذلك، على ثلاثة أقوال: الأول: أنّ ذلك يوم القيامة حين يُدعَون إلى السجود فلا يستطيعون. وهذا قول ابن عباس. والثاني: أنّ ذلك في الدنيا. وهذا قول قتادة. والثالث: أنّ ذلك في الدنيا، وعُني بالركوع في هذا الموضع الصلاة. وهذا قول مجاهد. واختار ابنُ جرير (٢٣/٦١٤) العموم، وأنّ ذلك خبر من الله تعالى عن مخالفة هؤلاء المجرمين، فقال: «أولى الأقوال في ذلك أن يُقال: إنّ ذلك خبر من الله -تعالى ذِكْره- عن هؤلاء القوم المجرمين أنهم كانوا له مخالفين في أمره ونهيه، لا يأتمرون لأمره، ولا ينتهون عما نهاهم عنه». ونقل ابنُ عطية (٨/٥١١) عن بعض المتأولين أنه «عني بالركوع: التواضع». <q>﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٥﴾</q> - تفسير ٨٠٧٩٩- قال مقاتل بن سليمان: <q>﴿ويْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q> بالبعث{6}. (ز) ",footnotes:1:تفسير الثعلبي ١٠/١١١-١١٢.أخرجه ابن جرير ٢٣/٦١٣.تفسير مجاهد ص٦٩٣، وأخرجه ابن جرير ٢٣/٦١٣-٦١٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٦١٣ دون قول حُذيفة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٤٧. و«أوثانا» كذا في المطبوع بالنصب.تفسير مقاتل بن سليمان ٤/٥٤٧.
  77,48,""
77,49," <q>﴿فَبِأَیِّ حَدِیثِۭ بَعۡدَهُۥ یُؤۡمِنُونَ ۝٥٠﴾</q> - تفسير ٨٠٨٠٠- قال مقاتل بن سليمان: <q>﴿فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ﴾</q> يعني: بالقرآن{1}٦٩٧٦. (ز) ٦٩٧٦ قال ابنُ عطية (٨/٥١١): «قوله تعالى: <q>﴿فبأي حديث بعده يؤمنون﴾</q> يؤيّد أنّ الآية كلّها في قريش، والحديث الذي يقتضيه الضمير في <q>﴿بعده﴾</q> هو القرآن، وهذا توقيف وتوبيخ». <q>﴿فَبِأَیِّ حَدِیثِۭ بَعۡدَهُۥ یُؤۡمِنُونَ ۝٥٠﴾</q> - آثار متعلقة بالآية ٨٠٨٠١- عن أبي هريرة، قال: قال رسول الله ﷺ: «مَن قرأ منكم: <q>﴿والتِّينِ والزَّيْتُونِ﴾</q> فانتهى إلى آخرها: <q>﴿ألَيْسَ اللَّهُ بِأَحْكَمِ الحاكِمِينَ﴾</q> فليَقُلْ: بلى، وأنا على ذلك من الشّاهدين. ومَن قرأ: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q> فانتهى إلى: <q>﴿ألَيْسَ ذَلِكَ بِقادِرٍ عَلى أنْ يُحْيِيَ المَوْتى﴾</q> فليَقُلْ: بلى. ومَن قرأ: <q>﴿والمرسلات﴾</q> فبَلغ: <q>﴿فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ﴾</q> فليَقُلْ: آمَنّا بالله»{2}. (١٥/١٤٠) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٤٧.سبق تخريجه في آخر سورة القيامة.
  77,50,""
