quran[24]{c,v,t}:
37,1," مقدمة السورة ٦٥٠٣٠- عن عبد الله بن عباس -من طريق مجاهد-: مكية{1}. (ز) ٦٥٠٣١- عن عبد الله بن عباس، قال: نزلت سورة الصافات بمكة{2}. (١٢/٣٨٢) ٦٥٠٣٢- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد الأنعام{3}. (ز) ٦٥٠٣٣- عن عكرمة= (ز) ٦٥٠٣٤- والحسن البصري -من طريق يزيد النحوي-: مكية{4}. (ز) ٦٥٠٣٥- عن قتادة -من طرق-: مكية{5}. (ز) ٦٥٠٣٦- عن محمد بن مسلم الزهري: مكية، ونزلت بعد الأنعام{6}. (ز) ٦٥٠٣٧- عن علي بن أبي طلحة: مكية{7}. (ز) ٦٥٠٣٨- قال مقاتل بن سليمان: سورة الصافات مكية، وعددها مائة واثنتان وثمانون آية كوفية{8}. (ز) ٦٥٠٣٩- قال يحيى بن سلّام: سورة الصافات مكية كلها{9}٥٤٥٩. (ز) ٥٤٥٩ نَصَّ ابنُ عطية (٧/٢٧٠)، وكذا ابنُ كثير (١٢/٥) على مكية سورة الصافات، وقال ابن عطية: «هذه السورة مكية، وعَدُّها في المدني، والشامي، والكوفي مائة آية، وآيتان وثمانون آية». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٥٧) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خصيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٥٩٩.تفسير يحيى بن سلام ٢/٨٢٢.
37,2," <q>﴿وَٱلصَّـٰۤفَّـٰتِ صَفࣰّا ۝١ فَٱلزَّ ٰ⁠جِرَ ٰ⁠تِ زَجۡرࣰا ۝٢ فَٱلتَّـٰلِیَـٰتِ ذِكۡرًا ۝٣﴾</q> - تفسير ٦٥٠٤٠- عن عبد الله بن مسعود -من طريق مسروق- <q>﴿والصّافّاتِ صَفًّا﴾</q> قال: الملائكة، <q>﴿فالزّاجِراتِ زَجْرًا﴾</q> قال: الملائكة{1}. (١٢/٣٨٤) ٦٥٠٤١- عن مجاهد بن جبر= (ز) ٦٥٠٤٢- وعكرمة مولى ابن عباس، مثله{2}. (١٢/٣٨٤) ٦٥٠٤٣- عن عبد الله بن عباس، في قوله: <q>﴿والصّافّاتِ صَفًّا * فالزّاجِراتِ زَجْرًا * فالتّالِياتِ ذِكْرًا﴾</q>، قال: هم الملائكة{3}. (١٢/٣٨٤) ٦٥٠٤٤- عن مسروق بن الأجدع الهمداني -من طريق مسلم- قال: كان يقال في الصافات، والمرسلات، والنازعات: هي الملائكة{4}. (١٢/٣٨٤) ٦٥٠٤٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿والصافات صفا﴾</q> قال: يعني: الملائكة، <q>﴿فالزاجرات زجرا﴾</q> قال: يعني: الملائكة، <q>﴿فالتاليات ذكرا﴾</q> قال: يعني: الملائكة{5}. (ز) ٦٥٠٤٦- عن مجاهد بن جبر -من طريق عاصم بن حكيم- قال: <q>﴿والصّافّاتِ صَفًّا * فالزّاجِراتِ زَجْرًا * فالتّالِياتِ ذِكْرًا﴾</q> هذا كله الملائكة، أقسم بهذا كله{6}. (ز) ٦٥٠٤٧- قال الحسن البصري: <q>﴿والصّافّاتِ صَفًّا﴾</q> هم الملائكة في السماء، يَصُفُّون كصفوف الخلق في الدنيا للصلاة{7}. (ز) ٦٥٠٤٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والصّافّاتِ صَفًّا﴾</q>، قال: قسمٌ؛ أقسم الله بخلقٍ ثم خلقٍ ثم خلقٍ. والصافات: الملائكة صفوفًا في السماء{8}٥٤٦٠. (١٢/٣٨٥) ٥٤٦٠ ذَهَبَ ابنُ جرير (١٩/٤٩٢)، وكذا ابنُ كثير (١٢/٦) إلى أنّ الصافات: نوع من الملائكة استنادًا إلى أقوال السلف، فقال ابنُ جرير: «أما الصافات: فإنها الملائكة الصافات لربها في السماء، وهي جمع صافة، فالصافات: جمع جمع، وبذلك جاء تأويل أهل التأويل». وقال في موضع لاحق (١٩/٤٩٤): «الله -تعالى ذكره- ابتدأ القسم بنوع من الملائكة، وهم الصافون، بإجماع من أهل التأويل». وذَكَرَ ابنُ عطية (٧/٢٧٠) قولًا آخر، فقال: «قالت فرقة: أراد: كل من يصف من بني آدم في قتال في سبيل الله، أو في صلاة وطاعة، والتقدير: والجماعات الصافات». ثم علَّقَ قائلًا: «واللفظ يحتمل أن يعم جميع هذه المذكورات». وذَكَرَ ابنُ القيم (٢/٣٦٥) قولًا آخر استنادًا إلى النظائر، فقال: «الصافات: الطير، كما قال تعالى: <q>﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ ويَقْبِضْن﴾</q> [الملك:١٩]، وقال تعالى: <q>﴿والطَّيْرُ صافّاتٍ﴾</q> [النور:٤١]». ثم علَّقَ قائلًا: «واللفظ يحتمل ذلك كله، وإن كان أحق مَن دخل فيه وأولى الملائكة؛ فإن الإقسام كالدليل والآية على صحة ما أقسم عليه من التوحيد، وما ذكر مِن غير الملائكة فهو من آثار الملائكة، وبواسطتها كان». ٦٥٠٤٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فالزّاجِراتِ زَجْرًا﴾</q>، قال: ما زجر الله عنه في القرآن{9}. (١٢/٣٨٥) ٦٥٠٥٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿والصّافّاتِ﴾</q> قال: هم الملائكة، <q>﴿فالزّاجِراتِ زَجْرًا﴾</q> قال: الملائكة تزجر السحاب{10}. (١٢/٣٨٥) ٦٥٠٥١- عن الربيع بن أنس، في قوله: <q>﴿فالزّاجِراتِ زَجْرًا﴾</q>، قال: ما زجر الله عنه في القرآن{11}. (١٢/٣٨٥) ٦٥٠٥٢- قال مقاتل بن سليمان: <q>﴿والصّافّاتِ صَفًّا﴾</q> يعني ﷿: صفوف الملائكة، <q>﴿فالزّاجِراتِ زَجْرًا﴾</q> الملائكة، يعني: به: الرعد، وهو مَلَك اسمه: الرعد، يزجر السحابَ بصوته، يسوقه إلى البلد الذي أُمر أن يُمطره، والبرق مخاريق مِن نار يسوق بها السحاب، فإذا صفَّ السحاب بعضه إلى بعض سطع منه نارٌ، فيصيب الله به من يشاء، وهي الصاعقة التي ذكر الله ﷿ في الرعد{12}. (ز) ٦٥٠٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والصّافّاتِ صَفًّا﴾</q>، قال: هذا قَسَمٌ أقسم الله به{13}. (ز) ٦٥٠٥٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿فالزّاجِراتِ زَجْرًا﴾</q> الملائكة، والرعد: مَلَكٌ يزجر السحاب، وقد قال في آية أخرى: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q> [الصافات:١٩]، وهي النفخة الآخرة، ينفخ فيه صاحب الصور{14}٥٤٦١. (ز) ٥٤٦١ اختُلِف في تأويل قوله تعالى: <q>﴿فالزّاجِراتِ زَجْرًا﴾</q> على قولين: أحدهما: أنها الملائكة التي تزجر السحاب، وغير ذلك من مخلوقات الله ﷿. وهو قول مجاهد، والسّدّيّ. والآخر: أنها آيات القرآن المتضمنة النواهي الشرعية. وهو قول قتادة. ورجَّحَ ابنُ جرير (١٩/٤٩٤) القولَ الأولَ استنادًا إلى السياق، فقال: «الذي هو أولى بتأويل الآية عندنا ما قاله مجاهد، ومن قال: هم الملائكة. لأن الله -تعالى ذِكْرُه- ابتدأ القَسَمَ بنوعٍ من الملائكة، وهم الصافون، بإجماع من أهل التأويل، فلأن يكون الذي بعده قَسَمًا بسائر أصنافهم أشبه». <q>﴿فَٱلتَّـٰلِیَـٰتِ ذِكۡرًا ۝٣﴾</q> - تفسير ٦٥٠٥٥- عن عبد الله بن مسعود -من طريق مسروق- <q>﴿فالتّالِياتِ ذِكْرًا﴾</q> قال: الملائكة{1}. (١٢/٣٨٤) ٦٥٠٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح-= (ز) ٦٥٠٥٧- وعكرمة مولى ابن عباس، مثله{16}. (١٢/٣٨٤) ٦٥٠٥٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فالتّالِياتِ ذِكْرًا﴾</q>، قال: ما يُتلى في القرآن مِن أخبار الأمم السالفة{17}. (١٢/٣٨٥) ٦٥٠٥٩- عن أبي صالح باذام، في قوله: <q>﴿فالتّالِياتِ ذِكْرًا﴾</q>، قال: الملائكة يجيئون بالكتاب والقرآن مِن عند الله إلى الناس{11}٥٤٦٢. (١٢/٣٨٥) ٥٤٦٢ ذكر ابنُ كثير (١٢/٦) هذا القول منسوبًا للسديّ، وقال بعده: «وهذه الآية كقوله تعالى: <q>﴿فالمُلْقِياتِ ذِكْرًا عُذْرًا أوْ نُذْرًا﴾</q> [المرسلات:٥]». ٦٥٠٦٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فالتّالِياتِ ذِكْرًا﴾</q>، قال: هم الملائكة{19}. (١٢/٣٨٥) ٦٥٠٦١- عن إسماعيل السُّدِّيّ: <q>﴿ذِكْرًا﴾</q>، يعني: الوحي، تتلو القرآن، الوحي الذي تأتي به الأنبياء{20}. (ز) ٦٥٠٦٢- قال مقاتل بن سليمان: <q>﴿فالتّالِياتِ ذِكْرًا﴾</q>، يعني به: الملائكة، وهو جبريل وحده ﵇، يتلو القرآن على الأنبياء من ربهم، وهو الملقيات ذِكرًا، يُلقي الذكر على الأنبياء{21}. (ز) ٦٥٠٦٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿فالتّالِياتِ﴾</q>، يعني: الملائكة{14}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٤٧، وابن جرير ١٩/٤٩٢، والطبراني في المعجم الكبير ٩/٢١٤ (٩٠٤١)، والحاكم ٢/٤٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه أبو الشيخ في العظمة (٥١٣). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٤٩٢. وعزاه السيوطي إلى سعيد بن منصور.تفسير مجاهد (٥٦٦)، وأخرجه ابن جرير ١٩/٤٩٣ مختصرًا.أخرجه يحيى بن سلّام ٢/٨٢٣.تفسير الثعلبي ٨/١٣٨، وتفسير البغوي ٦/٣٣، كلاهما عن ابن عباس ومسروق والحسن وقتادة.أخرجه يحيى بن سلّام ٢/٨٢٢، وعبد الرزاق ٢/١٤٧ من طريق معمر، وابن جرير ١٩/٤٩٣، ٤٩٥ واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٧ من طريق معمر، وابن جرير ١٩/٣٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٩٢-٤٩٣. وعلَّقه يحيى بن سلّام ٢/٨٢٢ مقتصرًا على شطره الأول. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠١.أخرجه ابن جرير ١٩/٤٩٣.تفسير يحيى بن سلّام ٢/٨٢٢.أخرجه عبد الرزاق ٢/١٤٧، وابن جرير ١٩/٤٩٢، والطبراني في المعجم الكبير ٩/٢١٤ (٩٠٤١)، والحاكم ٢/٤٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد. وقول مجاهد في تفسير مجاهد (٥٦٦)، وأخرجه ابن جرير ١٩/٤٩٤.أخرجه ابن جرير ١٩/٤٩٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٤٩٤. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلّام ٢/٨٢٢.تفسير مقاتل بن سليمان ٣/٦٠٢.تفسير يحيى بن سلّام ٢/٨٢٢.
  37,3,""
37,4," <q>﴿إِنَّ إِلَـٰهَكُمۡ لَوَ ٰ⁠حِدࣱ ۝٤﴾</q> - تفسير ٦٥٠٦٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ إلَهَكُمْ لَواحِدٌ﴾</q>، قال: وقع القَسَمُ على هذا{1}. (١٢/٣٨٥) ٦٥٠٦٥- قال مقاتل بن سليمان: <q>﴿إنَّ إلَهَكُمْ لَواحِدٌ﴾</q>، وذلك أنّ كفار مكة قالوا: يجعل محمد ﷺ الآلهة إلهًا واحدًا؟! فأقسم الله بهؤلاء الملائكة: <q>﴿إن إلهكم﴾</q> يعني: إن ربكم <q>﴿لواحد﴾</q> ليس له شريك{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٢.
37,5," <q>﴿رَّبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا وَرَبُّ ٱلۡمَشَـٰرِقِ ۝٥﴾</q> - تفسير ٦٥٠٦٦- عن مجاهد بن جبر، في قوله: <q>﴿ورَبُّ المَشارِقِ﴾</q>، قال: عدد أيام السنة، كل يوم مطلع ومغرب{1}. (١٢/٣٨٦) ٦٥٠٦٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿رَبُّ السَّماواتِ والأَرْضِ وما بَيْنَهُما ورَبُّ المَشارِقِ﴾</q>، قال: مشارق الشمس في الشتاء والصيف{2}. (ز) ٦٥٠٦٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ورَبُّ المَشارِقِ﴾</q>، قال: المشارق ثلاثمائة وستون مشرقًا، والمغارب ثلاثمائة وستون مغربًا في السنة. قال: والمشرقان: مشرق الشتاء، ومشرق الصيف. والمغربان: مغرب الشتاء، ومغرب الصيف{3}. (١٢/٣٨٥) ٦٥٠٦٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿المَشارِقِ﴾</q> ثلاثمائة وستون مشرقًا، والمغارب مثل ذلك، تطلع الشمس كل يوم مِن مشرق، وتغرب في مغرب{4}. (١٢/٣٨٦) ٦٥٠٧٠- قال مقاتل بن سليمان: ثم عظَّم نفسَه عن شِركهم، فقال ﷿: <q>﴿رَبُّ السَّماواتِ والأَرْضِ وما بَيْنَهُما ورَبُّ المَشارِقِ﴾</q>، يقول: أنا ربُّ ما بينهما مِن شيء مِن الآلهة وغيرها، وأنا ربُّ المشارق، يعني: مائة وسبعة وسبعين مشرقًا في السنة كلها، والمغارب مثل ذلك{5}. (ز) ٦٥٠٧١- قال يحيى بن سلّام: <q>﴿رَبُّ السَّماواتِ والأَرْضِ وما بَيْنَهُما ورَبُّ المَشارِقِ﴾</q> سمعت غير سعيد يقول: هي ثمانون ومائة منزلة، تطلع كل يوم في منزلة، حتى تنتهي إلى آخرها، ثم ترجع في الثمانين ومائة، فتكون ثلاث مائة وستين، فهي كل يوم في منزلة{6}٥٤٦٣. (ز) ٥٤٦٣ قال ابنُ القيم (٢/٣٦٦): «خصَّ المشارق ههنا بالذكر؛ إما لدلالتها على المغارب؛ إذ الأمران المتضايفان كل منهما يستلزم الآخر، وإما لكون المشارق مطلع الكواكب ومظاهر الأنوار، وإما توطئة لما ذكر بعدها من تزيين السماء بزينة الكواكب وجعلها حفظًا من كل شيطان، فذكر المشارق أنسب بهذا المعنى وأليق». وبنحوه قال ابنُ جرير (١٩/٤٩٦)، وكذا ابنُ عطية (٧/٢٧١)، وابنُ كثير (١٢/٧). <q>﴿رَّبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا وَرَبُّ ٱلۡمَشَـٰرِقِ ۝٥﴾</q> - آثار متعلقة بالآية ٦٥٠٧٢- عن عكرمة، قال: قال ابن عباس: إنّ الشمس تطلع كل سنة في ثلاثمائة وستين كُوّة، تطلع كل يوم في كُوّة، لا ترجع إلى تلك الكوة إلا ذلك اليوم مِن العام القابل، ولا تطلع إلا وهي كارهة، فتقول: ربِّ، لا تطلعني على عبادك؛ فإني أراهم يعصونك، يعلنون بمعاصيك. قال: أوَلَم تسمعوا إلى ما قال أمية بن أبي الصلت: ... حتى تُجر وتُجلد؟{7}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ في العظمة (٦٧٤). وفيه عن مجاهد من طريق ليث في تفسير قوله تعالى: <q>﴿رب المشارق والمغارب﴾</q> [الشعراء:٢٨] بنحوه.أخرجه ابن جرير ١٩/٤٩٦.أخرجه يحيى بن سلّام ٢/٨٢٣ بنحوه، وعبد الرزاق ٢/١٤٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٣٩٦، ٤٩٧ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠١.تفسير يحيى بن سلّام ٢/٨٢٣.أخرجه الثعلبي ٨/١٣٩.
37,6," <q>﴿إِنَّا زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِزِینَةٍ ٱلۡكَوَاكِبِ ۝٦﴾</q> - قراءات ٦٥٠٧٣- عن عبد الله بن مسعود، أنّه كان يقرأ: <q>﴿بِزِينَةٍ الكَواكِبِ﴾</q> منونة{1}. (١٢/٣٨٦) ٦٥٠٧٤- عن عاصم -من طريق أبي بكر- قال: من قرأها ‹بِزِينَةِ الكَواكِبِ› مضافًا ولم ينوّن فلم يجعلها زينة للسماء، وإنما جعل الزينة للكواكب{2}٥٤٦٤. (١٢/٣٨٦) ٥٤٦٤ اختلف القراء في قراءة قوله تعالى: <q>﴿بزينة الكواكب﴾</q> على أربعة أوجه: الأول: بتنوين <q>﴿بزينةٍ﴾</q>، وخفض <q>﴿الكواكب﴾</q> على البدلية، هكذا <q>﴿بِزِينَةٍ الكَواكِبِ﴾</q>، بمعنى: إنا زيَّنّا السماء الدنيا بزينةٍ هي الكواكب، كأنه قال: زيَّنّاها بالكواكب. والثاني: بإضافة «بزينة»، إلى «الكواكب»، هكذا ‹بِزِينَةِ الكَواكِبِ›، بمعنى: إنا زينا السماء الدنيا بتزيينها الكواكب، أي: زينتها الكواكب. والثالث: بتنوين «زينة»، ونصب «الكواكب»، هكذا (بِزِينَةٍ الكَواكِبَ)، بمعنى: إنا زينا السماء الدنيا بتزييننا الكواكبَ. والرابع: بتنوين «زينة»، ورفع «الكواكب»، هكذا (بِزِينَةٍ الكَواكِبُ)، بمعنى: إنا زينا السماء الدنيا بتزيينها الكواكبُ، أي: بأن زينتها الكواكبُ. علَّقَ ابنُ كثير (١٢/٧) على الوجهين الأول والثاني، بقوله: «كلاهما بمعنى واحد». وعلَّقَ ابنُ جرير (١٩/٤٩٧) على هذه الأوجه بقوله: «وذلك أنّ الزِّينة مصدرٌ، فجائزٌ توجيهُها إلى أيِّ هذه الوجوه التي وُصِفَت في العربية». ثم ذَهَبَ (١٩/٤٩٧) إلى صحة الوجهين الأول والثاني، مع كون وجه الخفض أعجب إليه، فقال: «أما القراءة فأعجبها إلَيّ بإضافة الزينة إلى الكواكب وخفض الكواكب؛ لصحة معنى ذلك في التأويل، والعربية، وأنها قراءة أكثر قراء الأمصار، وإن كان التنوين في الزينة وخفض الكواكب عندي صحيحًا أيضًا». وانْتَقَدَ القراءتين الثالثة والرابعة، فقال (١٩/٤٩٧-٤٩٨): «فأما النصب في»الكواكب«والرفع، فلا أستجيز القراءة بهما؛ لإجماع الحجة من القراء على خلافهما، وإن كان لهما في الإعراب والمعنى وجه صحيح». <q>﴿إِنَّا زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِزِینَةٍ ٱلۡكَوَاكِبِ ۝٦﴾</q> - تفسير الآية ٦٥٠٧٥- قال عبد الله بن عباس: <q>﴿بِزِينَةٍ الكَواكِبِ﴾</q> بضوء الكواكب{3}. (ز) ٦٥٠٧٦- قال مقاتل بن سليمان: ثم قال: <q>﴿إنّا زَيَّنّا السَّماءَ الدُّنْيا﴾</q> إنّا زيَّنا السماء الدنيا لأنها أدنى السماء مِن الأرض وأقربها <q>﴿بِزِينَةٍ الكَواكِبِ﴾</q> وهي مُعَلَّقة في السماء بهيئة القناديل{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها عاصم، وحمزة، وقرأ بقية العشرة: ‹بِزِينَةِ الكَواكِبِ› بالإضافة. انظر: النشر ٢/٣٥٦.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ٨/١٤٠، وتفسير البغوي ٦/٣٤.تفسير مقاتل بن سليمان ٣/٦٠٢.
37,7," <q>﴿وَحِفۡظࣰا مِّن كُلِّ شَیۡطَـٰنࣲ مَّارِدࣲ ۝٧﴾</q> - تفسير ٦٥٠٧٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وحِفْظًا﴾</q> يقول: جعلتها حفظًا <q>﴿مِن كل شيطان مارد﴾</q>{1}. (١٢/٣٨٧) ٦٥٠٧٨- قال مقاتل بن سليمان: <q>﴿وحِفْظًا﴾</q> يعني: زينة السماء بالكواكب <q>﴿مِن كُلِّ شَيْطانٍ مارِدٍ﴾</q> مُتَمَرِّد على الله ﷿ في المعصية{2}. (ز) ٦٥٠٧٩- قال يحيى بن سلّام: <q>﴿وحِفْظًا﴾</q> أي: وجعلناها -يعني: الكواكب- حفظًا للسماء <q>﴿مِن كُلِّ شَيْطانٍ مارِدٍ﴾</q> مَرَدَ على المعصية، أي: اجترأ على المعصية، وهم سراة إبليس{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٩٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٢.تفسير يحيى بن سلّام ٢/٨٢٣.
37,8," <q>﴿لَّا یَسَّمَّعُونَ إِلَى ٱلۡمَلَإِ ٱلۡأَعۡلَىٰ﴾</q> - قراءات ٦٥٠٨٠- عن عبد الله بن عباس، أنّه كان يقرأ: ‹لا يَسْمَعُونَ إلى المَلَإ الأَعْلى› مخفّفة. وقال: أنهم كانوا يتسمَّعون، ولكن لا يسمعون{1}٥٤٦٥. (١٢/٣٨٧) ٥٤٦٥ اختلف القراء في قراءة قوله تعالى: <q>﴿لا يسمعون إلى الملإ الأعلى﴾</q> على وجهين: الأول: بتسكين السين، وتخفيف الميم، هكذا: ‹لا يَسْمَعُونَ›، بمعنى: أنهم يتسَمَّعُون، ولا يسمعون. والثاني: بتشديد السين والميم، هكذا <q>﴿لا يَسَّمَّعُون﴾</q>، بمعنى: أنهم لا يتسَمَّعُون. ورَجَّحَ ابنُ جرير (١٩/٤٩٩)، وابنُ عطية (٧/٢٧٢) قراءة التخفيف استنادًا إلى الآثار، فقال ابنُ جرير: «أولى القراءتين في ذلك عندي بالصواب قراءة مَن قرأه بالتخفيف؛ لأن الأخبار الواردة عن رسول الله ﷺ وعن أصحابه: أن الشياطين قد تسمع الوحي، ولكنها ترمى بالشهب لئلا تسمع». وقال ابنُ عطية مستندًا إلى دلالة القرآن: «ينتفي على القراءة الأولى سمعهم وإن كانوا يستمعون، وهو المعنى الصحيح، ويعضده قوله تعالى: <q>﴿إنهم عن السمع لمعزولون﴾</q> [الشعراء:٢١٢]. وينتفي على القراءة الأخيرة أن يقع منهم استماع أو سماع، وظاهر الأحاديث أنهم يستمعون حتى الآن، لكنهم لا يسمعون». <q>﴿لَّا یَسَّمَّعُونَ إِلَى ٱلۡمَلَإِ ٱلۡأَعۡلَىٰ﴾</q> - تفسير الآية ٦٥٠٨١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿لا يَسَّمَّعُونَ إلى المَلَإ الأَعْلى﴾</q>، قال: مُنِعوها{2}. (ز) ٦٥٠٨٢- عن قتادة بن دعامة، في قوله: <q>﴿لا يَسَّمَّعُونَ إلى المَلَإ الأَعْلى﴾</q>، قال: مُنعوا بها. يعني: بالنجوم{3}. (١٢/٣٨٧) ٦٥٠٨٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿لا يَسَّمَّعُونَ إلى المَلَإ الأَعْلى﴾</q>، قال: الملائكة{4}. (١٢/٣٨٧) ٦٥٠٨٤- قال مقاتل بن سليمان: <q>﴿لا يَسَّمَّعُونَ إلى المَلَإ الأَعْلى﴾</q>، يعني: الملائكة، وكانوا قبل النبي ﷺ يسمعون كلام الملائكة{5}. (ز) ٦٥٠٨٥- قال يحيى بن سلّام: قوله ﷿: <q>﴿لا يَسَّمَّعُونَ﴾</q> أي: لِئَلّا يسمعوا <q>﴿إلى المَلَإ الأَعْلى﴾</q> الملائكة في السماء، وكانوا يسمعون قبل أن يُبعث النبيُّ ﷺ أخبارًا مِن أخبار السماء، فأمّا الوحي فلم يكونوا يقدرون على أن يسمعوه، وكانوا يقعدون منها مقاعد للسمع، فلمّا بَعَث اللهُ النبيَّ ﷺ مُنعوا مِن تلك المقاعد{6}. (ز) <q>﴿وَیُقۡذَفُونَ مِن كُلِّ جَانِبࣲ ۝٨﴾</q> - تفسير ٦٥٠٨٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ويُقْذَفُونَ مِن كُلِّ جانِبٍ﴾</q>، قال: يُرمَون مِن كل مكان{7}. (١٢/٣٨٧) ٦٥٠٨٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ويُقْذَفُونَ مِن كُلِّ جانِبٍ﴾</q>، قال: قذفًا قذفًا بالشُّهُب{8}. (١٢/٣٨٧) ٦٥٠٨٨- قال مقاتل بن سليمان: <q>﴿ويُقْذَفُونَ﴾</q> ويُرْمَون <q>﴿مِن كُلِّ جانِبٍ﴾</q> من كل ناحية{5}. (ز) ٦٥٠٨٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ويُقْذَفُونَ مِن كُلِّ جانِبٍ﴾</q>، قال: الشياطين يُدْحَرون بها عن الاستماع. وقرأ: <q>﴿إلّا مَن خَطِفَ الخَطْفَةَ فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q>{10}. (ز) ٦٥٠٩٠- قال يحيى بن سلّام: <q>﴿ويُقْذَفُونَ﴾</q>، أي: يُرْمَون{6}. (ز) <q>﴿وَیُقۡذَفُونَ مِن كُلِّ جَانِبࣲ ۝٨﴾</q> - آثار متعلقة بالآية ٦٥٠٩١- عن عائشة، أنها قالت: سمعتُ رسول الله ﷺ يقول: «إنّ الملائكة تنزل في العنان، وهو السحاب، فتذكر ما قُضي في السماء، فتسترق الشياطينُ السمعَ، فتسمعه، فتوحيه إلى الكهان، فيكذبون معها مائة كذبة مِن عند أنفسهم»{12}. (ز) ٦٥٠٩٢- عن عبد الله بن عباس، قال: حدثني رهطٌ مِن الأنصار، قالوا: بينا نحن جلوسٌ ذات ليلة مع رسول الله ﷺ، إذ رأى كوكبًا رُمي به، فقال: «ما تقولون في هذا الكوكب الذي يُرمى به؟». فقلنا: يُولد مولود، أو يهلك هالك، ويموت ملِك، ويملك ملِك. فقال رسول الله ﷺ: «ليس كذلك، ولكن الله كان إذا قضى أمرًا في السماء سبَّح لذلك حملةُ العرش، فيُسبِّح لتسبيحهم مَن يليهم مِن تحتهم مِن الملائكة، فما يزالون كذلك حتى ينتهي التسبيح إلى السماء الدنيا، فيقول أهل السماء الدنيا لِمَن يليهم من الملائكة: مِمَّ سبَّحتم؟ فيقولون: ما ندري، سمعنا مَن فوقنا مِن الملائكة سبَّحوا فسبَّحنا الله لتسبيحهم، ولكنا سنسأل. فيسألون من فوقهم، فما يزالون كذلك حتى يُنتهى إلى حملة العرش، فيقولون: قضى الله كذا وكذا. فيخبرون بهم مَن يليهم حتى ينتهوا إلى السماء الدنيا، فتسترق الجنُّ ما يقولون، فينزلون إلى أوليائهم مِن الإنس، فيلقونه على ألسنتهم بتوهّم منهم، فيخبرونهم به، فيكون بعضه حقًّا وبعضه كذبًا، فلم تزل الجنُّ كذلك حتى رُمُوا بهذه الشهب»{13}. (ز) ٦٥٠٩٣- عن محمد بن شهاب الزهري -من طريق معمر- أنّه سُئِل بعد أن حدَّث بهذا الحديث: أكان يُرمى بها في الجاهلية؟ قال: نعم، ولكنها غُلِّظت حين بُعِث النبيُّ ﷺ{14}. (ز) ٦٥٠٩٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: كان للجِنِّ مقاعد في السماء، يسمعون الوحي، وكان الوحيُ إذا أُوحي سمعت الملائكة كهيئة الحديدة يُرمى بها على الصفوان، فإذا سمعت الملائكةُ صلصلة الوحي خرَّ لجباههم مَن في السماء مِن الملائكة، فإذا نزل عليهم أصحابُ الوحي قالوا: <q>﴿ماذا قالَ رَبُّكُمْ قالوا: الحَقَّ وهُوَ العَلِيُّ الكَبِيرُ﴾</q> [سبأ:٢٣]. قال: فيتنادَوْن: قال ربكم الحق، وهو العلي الكبير. قال: فإذا أُنزل إلى السماء الدنيا قالوا: يكون في الأرض كذا وكذا موتًا، وكذا وكذا حياة، وكذا وكذا جدوبة، وكذا وكذا خصبًا، وما يريد أن يصنع، وما يريد أن يبتدئ -تبارك وتعالى-. فنزلت الجنُّ، فأوحوا إلى أوليائهم مِن الإنس بما يكون في الأرض، فبينا هم كذلك إذ بَعث الله النبي ﷺ، فزُجِرت الشياطين عن السماء، ورموهم بكواكب، فجعل لا يصعد أحد منهم إلا احترق، وفزع أهل الأرض لما رأوا في الكواكب، ولم يكن قبل ذلك، وقالوا: هلك مَن في السماء، وكان أهل الطائف أول مَن فزع، فينطلق الرجل إلى إبله، فينحر كل يوم بعيرًا لآلهتهم، وينطلق صاحب الغنم، فيذبح كل يوم شاة، وينطلق صاحب البقر فيذبح كل يوم بقرة، فقال لهم رجل: ويلكم! لا تهلكوا أموالكم؛ فإنّ معالمكم من الكواكب التي تهتدون بها لم يسقط منها شيء. فأقلعوا، وقد أسرعوا في أموالهم، وقال إبليس: حدث في الأرض حدث. فأُتي مِن كل أرض بتربة، فجعل لا يُؤتى بتربة أرض إلا شمّها، فلما أُتي بتربة تهامة قال: هاهنا حدث الحدث. وصرف الله إليه نفرًا من الجن وهو يقرأ القرآن، فقالوا: <q>﴿إنّا سَمِعْنا قُرْآنًا عَجَبًا﴾</q> [الجن:١] حتى ختم الآية، فولّوا إلى قومهم منذرين{15}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه. وهي قراءة العشرة ما عدا حمزة، والكسائي، وخلفًا، وحفصًا؛ فإنهم قرؤوا: <q>﴿لا يَسَّمَّعُونَ﴾</q> بتشديد السين والميم. انظر: النشر ٢/٣٥٦، والإتحاف ص٤٧١.أخرجه ابن جرير ١٩/٥٠٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٢.تفسير يحيى بن سلّام ٢/٨٢٣-٨٢٤.تفسير مجاهد (٥٦٦)، وأخرجه يحيى بن سلّام ٢/٨٢٤ من طريق ابن مجاهد، وابن جرير ١٩/٥٠٥، وعبد بن حميد -كما في تغليق التعليق ٤/٢٩٤-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٠٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦٠٢.أخرجه ابن جرير ١٩/٥٠٦.تفسير يحيى بن سلّام ٢/٨٢٣-٨٢٤.أخرجه البخاري ٤/١١١ (٣٢١٠)، وابن جرير ١٩/٥٠٤.أخرجه مسلم ٤/١٧٥٠ (٢٢٢٩)، وابن جرير ١٩/٥٠٠-٥٠١ واللفظ له. وتقدم الحديث بلفظ مسلم عند تفسير قوله تعالى: <q>﴿حَتّى إذا فُزِّعَ عَنْ قُلُوبِهِمْ﴾</q> [سبأ:٢٣].أخرجه ابن جرير ١٩/٥٠٢.أخرجه أحمد ٣/٢٨٣ (٢٤٨٢)، والنسائي في الكبرى (١١٦٢٦)، وابن جرير ١٩/٥٠٢.
37,9," <q>﴿دُحُورࣰاۖ﴾</q> - تفسير ٦٥٠٩٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿دُحُورًا﴾</q>، قال: مطرودين{1}. (١٢/٣٨٧) ٦٥٠٩٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿دُحُورًا﴾</q>، قال: قَذْفًا في النار{2}. (ز) ٦٥٠٩٧- قال مقاتل بن سليمان: <q>﴿دُحُورًا﴾</q>، يعني: طرْدًا بالشُّهُب مِن الكواكب، ثم ترجع الكواكب إلى أمكِنَتِها{3}. (ز) ٦٥٠٩٨- قال يحيى بن سلّام: <q>﴿دُحُورًا﴾</q> طردًا، يُطردون عن السماء{4}. (ز) <q>﴿وَلَهُمۡ عَذَابࣱ وَاصِبٌ ۝٩﴾</q> - تفسير ٦٥٠٩٩- قال عبد الله بن عباس: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q> شديد{5}. (ز) ٦٥١٠٠- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: لهم عذاب دائم{6}. (١٢/٣٨٧) ٦٥١٠١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: دائم{7}. (١٢/٣٨٧) ٦٥١٠٢- عن الضحاك بن مُزاحِم، في قوله: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: مُوجِع{8}. (١٢/٣٨٨) ٦٥١٠٣- عن أبي صالح باذام -من طريق إسماعيل ابن أبي خالد- <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: مُوجِع{9}. (١٢/٣٨٨) ٦٥١٠٤- عن عكرمة مولى ابن عباس -عن إسماعيل ابن أبي خالد، عمَّن ذكره- في قوله: <q>﴿عَذابٌ واصِبٌ﴾</q>، قال: دائِم{10}. (١٢/٣٨٨) ٦٥١٠٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: دائِم{11}. (١٢/٣٨٨) ٦٥١٠٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: مُوجِع{9}. (ز) ٦٥١٠٧- قال محمد بن السائب الكلبي: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q> مُوجِع{5}. (ز) ٦٥١٠٨- قال مقاتل بن سليمان: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q> يعني: دائم للشياطين مَن يستمع منهم، ومَن لم يستمع؛ عذاب دائم في الآخرة، والكواكب تَجرح ولا تقتل. نظيرها في تبارك: <q>﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا بِمَصابِيحَ وجَعَلْناها رُجُومًا لِلشَّياطِينِ وأَعْتَدْنا لَهُمْ عَذابَ السَّعِيرِ﴾</q> [الملك:٥]{3}. (ز) ٦٥١٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولَهُمْ عَذابٌ واصِبٌ﴾</q>، قال: الواصب: الدّائِب{6}٥٤٦٦. (ز) ٥٤٦٦ اختُلِف في تأويل قوله تعالى: <q>﴿واصب﴾</q> على قولين: أولهما: أنّ معناه: الدائم. والثاني: أن معناه: الموجع. ورجَّحَ ابنُ جرير (١٩/٥٠٧-٥٠٨) القولَ الأولَ -وهو قول ابن عباس من طريق عطية العوفي، ومجاهد، وقتادة، وعكرمة- استنادًا إلى النظائر، واللغة، فقال: "أولى التأويلين في ذلك بالصواب تأويل مَن قال: معناه: دائم خالص، وذلك أن الله ﷿ قال: <q>﴿وله الدين واصبا﴾</q> [النحل:٥٢]، فمعلوم أنه لم يصفه بالإيلام والإيجاع، وإنما وصفه بالثبات والخلوص، ومنه قول أبي الأسود الدؤلي: لا أشتري الحمد القليل بقاؤه ... يومًا بذم الدهر أجمع واصبا أي: دائمًا". وجمع ابنُ كثير (١٢/٧) بين القولين، فقال: «في الدار الآخرة لهم عذاب دائم موجع مستمر، كما قال: <q>﴿وأعتدنا لهم عذاب السعير﴾</q> [الملك:٥]». ",footnotes:1:تفسير مجاهد (٥٦٦)، وأخرجه يحيى بن سلّام ٢/٨٢٤ من طريق ابن مجاهد، وابن جرير ١٩/٥٠٦-٥٠٧، وعبد بن حميد -كما في تغليق التعليق ٤/٢٩٤-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٧.تفسير مقاتل بن سليمان ٣/٦٠٢.تفسير يحيى بن سلّام ٢/٨٢٤.تفسير الثعلبي ٨/١٤٠.أخرجه ابن جرير ١٩/٥٠٧.تفسير مجاهد (٥٦٦)، وأخرجه ابن جرير ١٩/٥٠٦-٥٠٧، وعبد بن حميد -كما في تغليق التعليق ٤/٢٩٤-. وعلَّقه يحيى بن سلّام ٢/٨٢٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٠٦.أخرجه ابن جرير ١٩/٥٠٧. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٥٠٧، وعبد الرزاق ٢/١٤٧ من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥٠٦.تفسير الثعلبي ٨/١٤٠.تفسير مقاتل بن سليمان ٣/٦٠٢.أخرجه ابن جرير ١٩/٥٠٧.
37,10," <q>﴿إِلَّا مَنۡ خَطِفَ ٱلۡخَطۡفَةَ فَأَتۡبَعَهُۥ شِهَابࣱ ثَاقِبࣱ ۝١٠﴾</q> - تفسير ٦٥١١٠- عن عبد الله بن عباس -من طريق عكرمة- قال: إذا رُمِي الشهاب لم يخطئ مَن رُمي به. وتلا: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q>{1}. (١٢/٣٨٨) ٦٥١١١- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q> إذا رأيتم الكوكب قد رُمي به فتوارى فإنّه لا يخطئ، وهو يُحْرِق ما أصاب، ولا يقتل{2}. (ز) ٦٥١١٢- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q>، قال: لا يُقتَلون بالشهاب، ولا يموتون، ولكنها تحرق وتخبِّل{3} وتجرح مِن غير قتل{4}. (١٢/٣٨٨) ٦٥١١٣- عن سعيد بن جبير، في قوله: <q>﴿إلّا مَن خَطِفَ الخَطْفَةَ﴾</q> يقول: إلا مَنِ استرق السمع مِن أصوات الملائكة <q>﴿فَأَتْبَعَهُ شِهابٌ﴾</q> يعني: الكواكب{5}. (١٢/٣٨٨) ٦٥١١٤- عن إبراهيم النخعي، في قوله: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q>، قال: إنّ الجِنِّي يجيء فيسترق، فإذا سرق السمع فرُمي بالشهاب قال للذي يليه: كان كذا وكذا{6}. (١٢/٣٨٩) ٦٥١١٥- عن الضحاك بن مزاحم، في قوله: <q>﴿شِهابٌ ثاقِبٌ﴾</q>، قال: ضوءه إذا انقضَّ فأصاب الشيطان{7}. (١٢/٣٨٩) ٦٥١١٦- عن يزيد الرقاشي، في قوله: <q>﴿شِهابٌ ثاقِبٌ﴾</q>، قال: يثقب الشيطان حتى يخرج من الجانب الآخر.= (ز) ٦٥١١٧- فذُكر ذلك لأبي مجلز، فقال: ليس ذاك، ولكن ثقوبه ضوؤه{8}. (١٢/٣٨٩) ٦٥١١٨- عن هارون الأعور، عن أبي عمرو، أنه كان يقرأ: <q>﴿إلا من خطف الخطفة﴾</q>، قال: وكان الحسن البصري يقول: <q>﴿فأتبعه شهاب ثاقب﴾</q> فأتبعه بشهاب مبين{9}. (ز) ٦٥١١٩- عن الحسن البصري: <q>﴿شِهابٌ ثاقِبٌ﴾</q> أنّه يقتله في أسرع مِن الطَّرف{10}. (ز) ٦٥١٢٠- عن الحسن البصري= (ز) ٦٥١٢١- وقتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ثاقِبٌ﴾</q>، قالا: مضيء{11}. (١٢/٣٨٩) ٦٥١٢٢- قال عطاء: <q>﴿شِهابٌ ثاقِبٌ﴾</q> سُمي النجم الذي يُرمى به الشياطين: ثاقبًا؛ لأنه يثقبهم{12}. (ز) ٦٥١٢٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q> من نار، وثقوبه: ضوؤه{13}. (ز) ٦٥١٢٤- عن إسماعيل السُّدِّيّ، قال: الثاقب: المحرق{5}. (١٢/٣٨٩) ٦٥١٢٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿شِهابٌ ثاقِبٌ﴾</q>، قال: شهاب مُضِيء، يُحْرِقه حين يُرْمى به{15}. (ز) ٦٥١٢٦- قال مقاتل بن سليمان: <q>﴿إلّا مَن خَطِفَ﴾</q> مِن الشياطين <q>﴿الخَطْفَةَ﴾</q> يخطف مِن الملائكة <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q> مِن الملائكة؛ الكواكب، يعني بالشهاب الثاقب: نارًا مضيئة، كقول موسى: <q>﴿أوْ آتِيكُمْ بِشِهابٍ قَبَسٍ﴾</q> [النمل:٧]، يعني: بنار مضيئة. فيها تقديم{16}. (ز) ٦٥١٢٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q>، قال: والثاقب: المستوقد. قال: والرجل يقول: أثقِب نارَك، ويقول: استثقب نارك: استوقد نارك{17}. (١٢/٣٨٩) ٦٥١٢٨- قال ⟨يحيى بن سلّام:⟩{تت} قوله ﷿: <q>﴿إلا مَن خَطِفَ الخَطْفَةَ فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q> رجع إلى أول الكلام <q>﴿وحِفْظًا مِن كُلِّ شَيْطانٍ مارِدٍ * لا يَسَّمَّعُونَ إلى المَلإ الأَعْلى﴾</q> <q>﴿إلّا مَن خَطِفَ الخَطْفَةَ﴾</q>، استمع الاستماعة كقوله: <q>﴿إلّا مَنِ اسْتَرَقَ السَّمْعَ فَأَتْبَعَهُ شِهابٌ مُبِينٌ﴾</q> [الحجر:١٨]. قال: <q>﴿فَأَتْبَعَهُ شِهابٌ ثاقِبٌ﴾</q> أي: مضيء{18}. (ز) <q>﴿إِلَّا مَنۡ خَطِفَ ٱلۡخَطۡفَةَ فَأَتۡبَعَهُۥ شِهَابࣱ ثَاقِبࣱ ۝١٠﴾</q> - آثار متعلقة بالآية ٦٥١٢٩- عن محمد بن سيرين، عن رجل، قال: كُنّا مع أبي قتادة على سطحٍ، فانقضَّ كوكبٌ، فنهانا أبو قتادة أن نُتبِعه أبصارَنا{19}. (ز) ٦٥١٣٠- عن عمرو، قال: سأل حفصٌ الحسنَ: أأتبع بصري الكوكب؟ فقال: قال الله: <q>﴿وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾</q> [الملك:٥]، وقال: <q>﴿أوَلَمْ يَنْظُرُوا فِي مَلَكُوتِ السَّماواتِ﴾</q> [الأعراف:١٨٥]، كيف نعلم إذا لم يُنظَر إليه؟ لَأُتْبِعَنَّه بصري{19}. (ز) ٦٥١٣١- عن عبيد الله، قال: سُئِل الضحاك: هل للشياطين أجنحة؟ فقال: كيف يطيرون إلى السماء إلا ولهم أجنحة؟!{21}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص١٩٨. وعزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ في العظمة.أخرجه يحيى بن سلّام ٢/٨٢٤، وأبو الشيخ في العظمة (٦٨٩) دون ذكر الآية.تخبَّل: الخَبْل فساد الأعضاء حتى لا يدري كيف يمشي. اللسان (خبل).أخرجه ابن جرير ١٩/٥٠٨ بنحوه. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي ص١٩٨.علقه يحيى بن سلّام ٢/٨٢٤.أخرجه عبد الرزاق ٧/١٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٦/٢٤، ٧/٣٣.أخرجه ابن جرير ١٩/٥٠٨، ويحيى بن سلّام ٢/٨٢٤ الشطر الثاني منه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٠٨.تفسير مقاتل بن سليمان ٣/٦٠٢.أخرجه ابن جرير ١٩/٥٠٩. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.تفسير يحيى بن سلّام ٢/٨٢٤.أخرجه يحيى بن سلّام ٢/٨٢٤.أخرجه يحيى بن سلّام ٢/٨٢٤.أخرجه ابن جرير ١٩/٥٠٩.
37,11," <q>﴿فَٱسۡتَفۡتِهِمۡ﴾</q> - تفسير ٦٥١٣٢- قال ⟨الحسن البصري:⟩{ت} <q>﴿فاسْتَفْتِهِمْ﴾</q> فحاجَّهم{1}. (ز) ٦٥١٣٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فاسْتَفْتِهِمْ﴾</q>: فاسألهم{2}. (ز) ٦٥١٣٤- قال مقاتل بن سليمان: قال -جلَّ وعزَّ-: <q>﴿فاسْتَفْتِهِمْ﴾</q>، يقول: سَلْهم{3}. (ز) ٦٥١٣٥- قال يحيى بن سلّام: <q>﴿فاسْتَفْتِهِمْ﴾</q>، يعني: المشركين{1}. (ز) <q>﴿أَهُمۡ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَاۤۚ﴾</q> - قراءات ٦٥١٣٦- عن عبيد، قال: سمعتُ الضحاك يقول: في قراءة ابن مسعود: (أهُمْ أشَدُّ خَلْقًا أم مَّنْ عَدَدْنا){5}. (ز) ٦٥١٣٧- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- أنّه قرأ: (أهُمْ أشَدُّ خَلْقًا أم مَّنْ عَدَدْنا){6}. (١٢/٣٩٠) <q>﴿أَهُمۡ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَاۤۚ﴾</q> - نزول الآية ٦٥١٣٨- قال مقاتل بن سليمان: <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q> نزلت في أبي الأشدَّين، واسمه: أُسَيْدُ بن كَلَدَة بن خلف الجمحي، وإنما كُني أبا الأشدين لشدة بطشه، وفي ركانة بن عبد يزيد بن هشام بن عبد مناف{7}. (ز) <q>﴿أَهُمۡ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَاۤۚ﴾</q> - تفسير الآية ٦٥١٣٩- عن سعيد بن جبير، في قوله: <q>﴿أمْ مَن خَلَقْنا﴾</q>، قال: مِن الأموات والملائكة{8}. (١٢/٣٩٠) ٦٥١٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q>، قال: السموات، والأرض، والجبال{9}. (١٢/٣٨٩) ٦٥١٤١- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- أنّه قرأ: (أهُمْ أشَدُّ خَلْقًا أم مَّنْ عَدَدْنا)، وفي قراءة عبد الله بن مسعود (عَدَدْنا)، يقول: <q>﴿رب السموات والأرض وما بينهما ورب المشارق﴾</q>، يقول: أهم أشد خلقًا أم السموات والأرض؟! يقول: السموات والأرض أشد خلقًا منهم{10}. (ز) ٦٥١٤٢- قال الحسن البصري: <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q> أم السماء والأرض{1}. (ز) ٦٥١٤٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أمْ مَن خَلَقْنا﴾</q>، قال: أم مَن عددنا عليك مِن خلْق السموات والأرض، قال الله تعالى: <q>﴿لَخَلْقُ السَّماواتِ والأَرْضِ أكْبَرُ مِن خَلْقِ النّاسِ﴾</q> [غافر:٥٧]{12}. (١٢/٣٩٠) ٦٥١٤٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فاسْتَفْتِهِمْ أهُمْ أشَدُّ خَلْقًا﴾</q> قال: يعني: المشركين، سلهم <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q>{6}. (ز) ٦٥١٤٥- قال إسماعيل السُّدِّيّ: <q>﴿أهُمْ أشَدُّ خَلْقًا﴾</q>، يعني: بعثًا في الآخرة{1}. (ز) ٦٥١٤٦- قال مقاتل بن سليمان: <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q> نزلت في أبي الأشدَّين ... وفي ركانة بن عبد يزيد ... يقول: سلْ هؤلاء: أهم أشد خلقًا بعد موتهم؛ لأنهم كفروا بالبعث <q>﴿أمْ مَن خَلَقْنا﴾</q> يعني: خلْق السموات والأرض وما بينهما والمشارق؛ لأنهم يعلمون أنّ الله -جلَّ وعزَّ- خلق هذه الأشياء، ثم أخبر عن خلق الإنسان{3}. (ز) ٦٥١٤٧- عن سفيان= (ز) ٦٥١٤٨- ومجاهد بن جبر: <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q>، يعني: السماء{1}. (ز) ٦٥١٤٩- قال يحيى بن سلّام: <q>﴿أهُمْ أشَدُّ خَلْقًا أمْ مَن خَلَقْنا﴾</q> ... وقال في آية أخرى: <q>﴿أأَنْتُمْ أشَدُّ خَلْقًا أمِ السَّماءُ بَناها * رَفَعَ سَمْكَها فَسَوّاها﴾</q> إلى قوله: <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q> [النازعات:٢٧-٣٠]، وقال: <q>﴿لَخَلْقُ السَّماواتِ والأَرْضِ أكْبَرُ مِن خَلْقِ النّاسِ﴾</q> [غافر:٥٧]، يقول: فاسألهم. على الاستفهام= (ز) ٦٥١٥٠- يحاجهم بذلك: أهم أشد خلقا أم السماء؟ في قول مجاهد= (ز) ٦٥١٥١- وفي قول الحسن: أم السماء والأرض؟ أي: إنهما أشد خلقًا منهم{17}. (ز) <q>﴿إِنَّا خَلَقۡنَـٰهُم مِّن طِینࣲ لَّازِبِۭ ۝١١﴾</q> - تفسير ٦٥١٥٢- عن عبد الله بن مسعود، قال: اللازب: الذي يلزق بعضُه إلى بعض{8}. (١٢/٣٩١) ٦٥١٥٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿مِن طِينٍ لازِبٍ﴾</q>، قال: مُلْتَصِق{19}. (١٢/٣٩٠) ٦٥١٥٤- عن عبد الله بن عباس، أن نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿مِن طِينٍ لازِبٍ﴾</q>. قال: الملتزق. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت النابغة وهو يقول: فلا تحسبون الخيرَ لا شرَ بعدَه ولا تحسبون الشرَ ضربةَ لازبِ{20}. (١٢/٣٩٠) ٦٥١٥٥- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿من طين لازب﴾</q>، قال: هو الطِّينُ الحُرُّ الجيد٥٤٦٧ اللَّزِج{21}. (ز) ٥٤٦٧ قال ابنُ جرير (١٩/٥١٠-٥١١): «خُلِقَ ابنُ آدم من تراب وماء ونار وهواء، والتراب إذا خُلِطَ بماءٍ صار طينًا لازبًا». وقال ابنُ عطية (٧/٢٧٤) بعد أن نقل كلام ابن جرير هذا: «وهو اللازم، أي: يلزم ما جاوره ويلصق به، وهو الصلصال كالفخار، وعَبَّرَ ابن عباس وعكرمة عن اللازب بالحُرِّ، أي: الكريم الجيِّد، وحقيقة المعنى ما ذكرناه، يقال: ضربة لازم، وضربة لازب، بمعنى واحد». ٦٥١٥٦- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿إنّا خَلَقْناهُمْ مِن طِينٍ لازِبٍ﴾</q>، قال: مِن التراب والماء؛ فيصير طينًا يلزق{22}. (ز) ٦٥١٥٧- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- قال: <q>﴿من طين لازب﴾</q>، اللازب: اللِّزج الطيب{22}. (ز) ٦٥١٥٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿مِن طِينٍ لازِبٍ﴾</q>، قال: اللازب: الجيِّد{24}. (١٢/٣٩١) ٦٥١٥٩- عن عبد الله بن عباس، في قوله: <q>﴿من مِن طِينٍ لازِبٍ﴾</q>، قال: اللازب والحمأ والطين واحد، كان أوله ترابًا، ثم صار حمأ مُنتنًا، ثم صار طينًا لازبًا، فخلق الله منه آدم{8}. (١٢/٣٩١) ٦٥١٦٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿طِينٍ لازِبٍ﴾</q>، قال: لازم مُنتِن{26}. (١٢/٣٩١) ٦٥١٦١- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- <q>﴿إنّا خَلَقْناهُمْ مِن طِينٍ لازِبٍ﴾</q>: واللازب: الطين الجيد{27}. (ز) ٦٥١٦٢- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿من طين لازب﴾</q>، قال: هو اللّازِق{28}. (ز) ٦٥١٦٣- قال الضحاك بن مزاحم: <q>﴿إنّا خَلَقْناهُمْ مِن طِينٍ لازِبٍ﴾</q> مُنتِن{29}. (ز) ٦٥١٦٤- عن عكرمة مولى ابن عباس -من طريق سماك- <q>﴿مِن طِينٍ لازِبٍ﴾</q>، قال: لازِج{30}. (١٢/٣٩١) ٦٥١٦٥- عن الحسن البصري: <q>﴿مِن طِينٍ لازِبٍ﴾</q> هو الطين الحُرُّ{1}. (ز) ٦٥١٦٦- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿مِن طِينٍ لازِبٍ﴾</q>، اللازب: الذي يلزق باليد{32}. (١٢/٣٩١) ٦٥١٦٧- قال ⟨إسماعيل السُّدِّيّ:⟩{ت} <q>﴿مِن طِينٍ لازِبٍ﴾</q> خالِص{33}. (ز) ٦٥١٦٨- قال مقاتل بن سليمان: ثم أخبر عن خلق الإنسان، فقال -جلَّ وعزَّ-: <q>﴿إنّا خَلَقْناهُمْ﴾</q> يعني: آدم <q>﴿مِن طِينٍ لازِبٍ﴾</q> يعني: لازب بعضه في البعض، فهذا أهون خلْقًا عِند هذا المكذِّب بالبعث مِن خلْق السموات والأرض وما بينهما والمشارق. ونزلت في أبي الأشدَّين أيضًا: <q>﴿أأَنْتُمْ أشَدُّ خَلْقًا﴾</q> بعثًا بعد الموت <q>﴿أمِ السَّماءُ بَناها﴾</q> [النازعات:٢٧]{7}. (ز) ٦٥١٦٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنّا خَلَقْناهُمْ مِن طِينٍ لازِبٍ﴾</q>، قال: اللازب: الذي يلتصق كأنه غراء؛ ذلك اللازب{28}. (ز) ٦٥١٧٠- قال يحيى بن سلّام: <q>﴿إنّا خَلَقْناهُمْ مِن طِينٍ لازِبٍ﴾</q> يلصق ويلزق واحد، هي لغة، وهي تقال بالسين: يلسق، أيضًا، يعني: خلق آدم؛ كان أول خلقه ترابًا، ثم كان طينًا، قال: من تراب، وقال: <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q> [الرحمن:١٤]، وهو التراب اليابس الذي يُسمع له صلصلة -في ما حدثني عثمان عن قتادة- وقال: <q>﴿مِن طِينٍ لازِبٍ﴾</q>، وقال: <q>﴿مِن حَمَإٍ مَسْنُونٍ﴾</q> [الحجر:٢٦]، يعني: الطين المنتن{36}. (ز) ",footnotes:1:علقه يحيى بن سلّام ٢/٨٢٥.أخرجه يحيى بن سلّام ٢/٨٢٥.تفسير مقاتل بن سليمان ٣/٦٠٢-٦٠٣.علقه يحيى بن سلّام ٢/٨٢٥.أخرجه ابن جرير ١٩/٥١٠، وإسحاق البستي ص١٩٧ واللفظ له. وهي قراءة شاذة. انظر: المحرر الوجيز ٤/٥٦٧، والبحر المحيط ٧/٣٣٩.أخرجه ابن جرير ١٩/٥١٠.تفسير مقاتل بن سليمان ٣/٦٠٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد (٥٦٧)، وأخرجه ابن جرير ١٩/٥٠٩-٥١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥١٠، وإسحاق البستي ص١٩٧ مختصرًا.علقه يحيى بن سلّام ٢/٨٢٥.أخرجه ابن جرير ١٩/٥١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥١٠.علقه يحيى بن سلّام ٢/٨٢٥.تفسير مقاتل بن سليمان ٣/٦٠٢-٦٠٣.علقه يحيى بن سلّام ٢/٨٢٥.تفسير يحيى بن سلّام ٢/٨٢٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الطستي -كما في الإتقان ٢/٧٥-٧٦-.أخرجه ابن جرير ١٩/٥١١.أخرجه ابن جرير ١٩/٥١٢.أخرجه ابن جرير ١٩/٥١٢.أخرجه ابن جرير ١٤/٥٧، ١٩/٥١١-٥١٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد (٥٦٧)، وأخرجه ابن جرير ١٩/١٥٣. وعلَّقه يحيى بن سلّام ٢/٨٢٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥١٢، وإسحاق البستي ص١٩٩ بلفظ: لاصق جيد.أخرجه ابن جرير ١٩/٥١٣.تفسير البغوي ٦/٣٥، وتفسير الثعلبي (ط: دار التفسير) ٢٢/٣٢٨، وفي (ط: دار إحياء التراث) ٨/١٤٠: الرمل!أخرجه ابن جرير ١٩/٥١٢، وأبو الشيخ في العظمة (١٠١٧).علقه يحيى بن سلّام ٢/٨٢٥.أخرجه عبد الرزاق ٢/١٤٨ من طريق معمر، وابن جرير ١٩/٥١٣. وعلَّقه يحيى بن سلّام ٢/٨٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٨/١٤٠.تفسير مقاتل بن سليمان ٣/٦٠٣.أخرجه ابن جرير ١٩/٥١٣.تفسير يحيى بن سلّام ٢/٨٢٥-٨٢٦.
37,12," <q>﴿بَلۡ عَجِبۡتَ وَیَسۡخَرُونَ ۝١٢﴾</q> - قراءات ٦٥١٧١- عن عبد الله بن مسعود -من طريق إبراهيم- أنّه كان يقرأ: ‹بَلْ عَجِبْتُ ويَسْخَرُونَ› بالرفع{1}. (١٢/٣٩٢) ٦٥١٧٢- عن عبد الله بن عباس، أنه قرأ: ‹بَلْ عَجِبْتُ ويَسْخَرُونَ›{2}. (١٢/٣٩٢) ٦٥١٧٣- عن الأعمش، عن أبي وائل، عن شُرَيح القاضي، أنه كان يقرأ هذه الآية: <q>﴿بَلْ عَجِبْتَ ويَسْخَرُونَ﴾</q> بالنصب، ويقول: إنّ الله لا يعجب مِن الشيء، إنما يَعجب مَن لا يعلم.= (ز) ٦٥١٧٤- قال الأعمش: فذكرتُ ذلك لإبراهيم النخعي، فقال: إنّ شريحًا كان مُعجبًا برأيه، وابن مسعود كان أعلم منه، كان يقرأها: ‹بَلْ عَجِبْتُ›{2}. (١٢/٣٩٢) <q>﴿بَلۡ عَجِبۡتَ وَیَسۡخَرُونَ ۝١٢﴾</q> - تفسير الآية ٦٥١٧٥- عن عبد الملك ابن جريج، في قوله: <q>﴿بَلْ عَجِبْتَ﴾</q>، قال النبي ﷺ: «عجبتُ بالقرآن حين أنزل، ويسخر منه ضُلّال بني آدم»{4}. (١٢/٣٩٣) ٦٥١٧٦- عن عبد الله بن مسعود -من طريق أبي وائل- أنه قرأ: ‹بَلْ عَجِبْتُ› بالرفع، ويقول: نظيرها <q>﴿وإنْ تَعْجَبْ فَعَجَبٌ قَوْلُهُمْ﴾</q> [الرعد:٥]{5}. (ز) ٦٥١٧٧- عن عبد الله بن عباس -من طريق الضحاك- قال: سبحان الله عجِب{6}. (ز) ٦٥١٧٨- عن سعيد بن جبير، في قوله: ‹بَلْ عَجِبْتُ›، قال: الله عجِب{5}. (ز) ٦٥١٧٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بَلْ عَجِبْتَ ويَسْخَرُونَ﴾</q>، قال: عجبتَ من كتاب الله ووحيه، <q>﴿ويَسْخَرُونَ﴾</q> مما جئتَ به{8}. (١٢/٣٩٢) ٦٥١٨٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بَلْ عَجِبْتَ﴾</q> قال: عجِب محمدٌ ﷺ من هذا القرآن حين أُعطيه، وسخر منه أهل الضلالة، <q>﴿ويَسْخَرُونَ﴾</q> يعني: أهل مكة{9}. (١٢/٣٩٣) ٦٥١٨١- عن إسماعيل السُّدِّيّ: <q>﴿بَلْ عَجِبْتَ﴾</q> لقد عجبت{10}. (ز) ٦٥١٨٢- قال مقاتل بن سليمان: ثم قال -جلَّ وعزَّ-: <q>﴿بَلْ عَجِبْتَ﴾</q> يا محمد من القرآن حين أُوحي إليك. نظيرها في الرعد [٥]: <q>﴿وإنْ تَعْجَبْ﴾</q> مِن القرآن <q>﴿فَعَجَبٌ قَوْلُهُمْ﴾</q> فاعْجَب مِن قولهم بتكذيبهم بالبعث٥٤٦٨. ثم قال -جلَّ وعزَّ-: <q>﴿ويَسْخَرُونَ﴾</q> يعني: كفار مكة سخروا مِن النبي ﷺ حين سمعوا منه القرآن{11}. (ز) ٥٤٦٨ اختلف القراء في قراءة قوله تعالى: <q>﴿بل عجبت﴾</q> على وجهين: الأول: بفتح التاء، بمعنى: بل عجبت أنت، يا محمد. وهي قراءة الجمهور. والثاني: بضم التاء، بمعنى: بل عَظُمَ عندي وكَبُرَ اتخاذهم لي شريكًا، وتكذيبهم تنزيلي. وذَهَبَ ابنُ جرير (١٩/٤٩٧) إلى أنهما قراءتان مشهورتان في قراء الأمصار، فبأيتهما قرأ القارئ فمصيب، ثم قال: «فإن قال قائل: وكيف يكون مصيبًا القارئ بهما مع اختلاف معنييهما؟ قيل: إنهما وإن اختلف معنياهما فكل واحد مِن معنييه صحيح، قد عجب محمد مما أعطاه الله من الفضل، وسخر منه أهل الشرك بالله، وقد عجب ربُّنا مِن عظيم ما قاله المشركون في الله، وسخر المشركون بما قالوه. فإن قال: أكان التنزيل بإحداهما أو بكلتيهما؟ قيل: التنزيل بكلتيهما. فإن قال: وكيف يكون تنزيل حرف مرتين؟ قيل: إنه لم ينزل مرتين، إنما أنزل مرة، ولكنه أُمِرَ ﷺ أن يقرأ بالقراءتين كلتيهما». وعلَّقَ ابنُ عطية (٧/٢٧٤-٢٧٥) [وما بين المعكوفين من ط: دار الكتب العلمية (٤/٥٣٦)] على قراءة ضم التاء، بقوله: «ومعنى ذلك من الله أنه صفة فعل، ونحوه قول النبي ﷺ: «يعجب الله تعالى إلى قوم يساقون إلى الجنة في السلاسل». وقوله:﵇: «يعجب الله من الشاب ليست له صبوة»، فإنما هي عبارة عما يظهره تعالى في جانب [المتعجب منه من التعظيم والتحقير حتى يصير الناس متعجبين] منه، فمعنى هذه الآية: بل عجبتُ من ضلالتهم وسوء نحلتهم، وجعلتها للناظرين فيها، وفيما اقترن معها من شرعي وهداي متعجّبًا». وما قاله ابن عطية فيه نظر، والحق إثبات صفه العَجب لله على ما يليق بكماله وعظمته وجلاله، كما جاء عن السلف من الصحابة والتابعين وأتباعهم. ينظر: الإبانة ٣/١٣١. ٦٥١٨٣- قال يحيى بن سلّام: <q>﴿ويَسْخَرُونَ﴾</q> هم، يعني: المشركين{12}. (ز) ",footnotes:1:أخرجه الطبراني ٩/١٥١، والحاكم ٢/٤٣٠ من طريق أبي وائل. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن أبي حاتم. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف، وقرأ بقية العشرة <q>﴿بَلْ عَجِبْتَ﴾</q> بالنصب. انظر: النشر ٢/٣٥٦، والإتحاف ص٤٧٢.أخرجه البيهقي في الأسماء والصفات (٩٩١، ٩٩٢) من طريق الأعمش. وعزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه البيهقي في الأسماء والصفات (٩٩١، ٩٩٢) من طريق الأعمش. وعزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٦٥-.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٦٦-.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٦٥-.أخرجه عبد الرزاق ٢/١٤٨ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٨٢٦، وابن جرير ١٩/٥١٤ دون قوله:«يعني أهل مكة». وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلّام ٢/٨٢٦.تفسير مقاتل بن سليمان ٣/٦٠٣.تفسير يحيى بن سلّام ٢/٨٢٦.
37,13," <q>﴿وَإِذَا ذُكِّرُوا۟ لَا یَذۡكُرُونَ ۝١٣﴾</q> - تفسير ٦٥١٨٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإذا ذُكِّرُوا لا يَذْكُرُونَ﴾</q>: أي: لا ينتفعون، ولا يُبصِرون{1}. (١٢/٣٩٣) ٦٥١٨٥- قال مقاتل بن سليمان: ثم قال: <q>﴿وإذا ذُكِّرُوا لا يَذْكُرُونَ﴾</q>، وإذا وُعِظوا بالقرآن لا يَتَّعِظون{2}. (ز) ٦٥١٨٦- قال يحيى بن سلّام: <q>﴿وإذا ذُكِّرُوا﴾</q> بالقرآن{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥١٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٣.تفسير يحيى بن سلّام ٢/٨٢٦.
37,14," <q>﴿وَإِذَا رَأَوۡا۟ ءَایَةࣰ﴾</q> - تفسير ٦٥١٨٧- قال عبد الله بن عباس: <q>﴿وإذا رَأَوْا آيَةً﴾</q>، يعني: انشقاق القمر{1}. (ز) ٦٥١٨٨- قال مقاتل بن سليمان: <q>﴿وإذا رَأَوْا آيَةً﴾</q>، يعني: انشقاق القمر بمكة، فصار نصفين{2}. (ز) ٦٥١٨٩- قال يحيى بن سلّام: <q>﴿وإذا رَأَوْا آيَةً﴾</q> إذا تُلِيَت عليهم آية{3}. (ز) ",footnotes:1:تفسير البغوي ٧/٣٦.تفسير مقاتل بن سليمان ٣/٦٠٣. وفي تفسير البغوي ٦/٢٤، ٧/٣٦ بنحوه منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلّام ٢/٨٢٦.
37,15," <q>﴿یَسۡتَسۡخِرُونَ ۝١٤ وَقَالُوۤا۟ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّبِینٌ ۝١٥﴾</q> - تفسير ٦٥١٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَسْتَسْخِرُونَ﴾</q>، قال: يستهزِئون ويسخرون{1}٥٤٦٩. (١٢/٣٩٣) ٥٤٦٩ قال ابنُ عطية (٧/٢٧٥): «قوله: <q>﴿يستسخرون﴾</q> معناه: يطلبون أن يكونوا ممن يسخر. ويجوز أن يكون بمعنى: يسخرون، كقوله تعالى: <q>﴿واستغنى الله﴾</q> [التغابن:٦] فيكون فَعَلَ واسْتَفْعَلَ بمعنى. وبهذا فَسَّرَه مجاهد وقتادة». ٦٥١٩١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإذا رَأَوْا آيَةً يَسْتَسْخِرُونَ﴾</q>: أي: يسخرون منها ويستهزئون{2}. (١٢/٣٩٣) ٦٥١٩٢- قال مقاتل بن سليمان: <q>﴿يَسْتَسْخِرُونَ﴾</q> سخروا، فقالوا: هذا عمل السحرة، فذلك قوله ﷿: <q>﴿وقالُوا إنْ هَذا إلّا سِحْرٌ مُبِينٌ﴾</q>. نظيرها في: <q>﴿اقْتَرَبَتِ السّاعَةُ وانْشَقَّ القَمَرُ * وإنْ يَرَوْا آيَةً يُعْرِضُوا ويَقُولُوا سِحْرٌ مُسْتَمِرٌّ﴾</q> [القمر:١-٢]{3}. (ز) ٦٥١٩٣- قال يحيى بن سلّام: <q>﴿يَسْتَسْخِرُونَ﴾</q> مِن السخرية، <q>﴿وقالُوا إنْ هَذا﴾</q> يعنون: القرآن <q>﴿إلا سِحْرٌ مُبِينٌ﴾</q> بيِّنٌ أنّه سِحرٌ{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥١٥-٥١٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٨ بنحوه، وابن جرير ١٩/٥١٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٣.تفسير يحيى بن سلّام ٢/٨٢٦.
37,16," <q>﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰا وَعِظَـٰمًا أَءِنَّا لَمَبۡعُوثُونَ ۝١٦ أَوَءَابَاۤؤُنَا ٱلۡأَوَّلُونَ ۝١٧﴾</q> - تفسير ٦٥١٩٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَبْعُوثُونَ﴾</q>: تكذيبًا بالبعث{1}. (ز) ٦٥١٩٥- قال مقاتل بن سليمان: <q>﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَبْعُوثُونَ﴾</q> بعد الموت، <q>﴿أوَآباؤُنا الأَوَّلُونَ﴾</q> أو يُبعث آباؤنا الأولون؟! قالوا ذلك تعجُّبًا{2}. (ز) ٦٥١٩٦- قال يحيى بن سلّام: <q>﴿أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا أئِنّا لَمَبْعُوثُونَ * أوَآباؤُنا الأَوَّلُونَ﴾</q> قالوا هذا الاستفهام، وهذا الاستفهام على إنكار، أي: لا نُبعث ولا آباؤنا الأولون{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥١٦. وعلَّقه يحيى بن سلّام ٢/٨٢٦.تفسير مقاتل بن سليمان ٣/٦٠٤.تفسير يحيى بن سلّام ٢/٨٢٦.
  37,17,""
37,18," <q>﴿قُلۡ نَعَمۡ وَأَنتُمۡ دَ ٰ⁠خِرُونَ ۝١٨﴾</q> - تفسير ٦٥١٩٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قُلْ نَعَمْ وأَنْتُمْ داخِرُونَ﴾</q>: صاغِرون{1}. (ز) ٦٥١٩٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وأَنْتُمْ داخِرُونَ﴾</q>، قال: صاغِرون{2}. (ز) ٦٥١٩٩- قال مقاتل بن سليمان: يقول الله ﷿ لنبيِّه ﷺ: <q>﴿قُلْ﴾</q> لكفار مكة: <q>﴿نَعَمْ وأَنْتُمْ داخِرُونَ﴾</q> وأنتم صاغِرون{3}. (ز) ٦٥٢٠٠- قال يحيى بن سلّام: قال الله: <q>﴿قُلْ نَعَمْ﴾</q> تُبعثون جميعًا{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥١٧. وعلَّقه يحيى بن سلّام ٢/٨٢٦.أخرجه ابن جرير ١٩/٥١٧.تفسير مقاتل بن سليمان ٣/٦٠٤.تفسير يحيى بن سلّام ٢/٨٢٦.
37,19," <q>﴿فَإِنَّمَا هِیَ زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ فَإِذَا هُمۡ یَنظُرُونَ ۝١٩﴾</q> - تفسير ٦٥٢٠١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَإنَّما هِيَ زَجْرَةٌ﴾</q>، قال: صيحة{1}. (١٢/٣٩٣) ٦٥٢٠٢- عن العوام بن حوشب، قال: قال إبراهيم التيمي: إنّ الله ﷿ عندما يريد أن يقيم الساعة أغْضَبُ ما يكون على خلْقه= (ز) ٦٥٢٠٣- قال العوام: وقال الحسن: الزجرة مِن الغضب، <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q>{2}. (ز) ٦٥٢٠٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فإنما هي زجرة واحدة﴾</q>، قال: نفخة واحدة، وهي النفخة الآخرة{3}. (١٢/٣٩٣) ٦٥٢٠٥- قال مقاتل بن سليمان: ثم أخبر عنهم ﷿: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q> صيحة واحدة مِن إسرافيل، لا مثنوية لها، <q>﴿فَإذا هُمْ يَنْظُرُونَ﴾</q> إلى البعث الذي كذَّبوا به{4}٥٤٧٠. (ز) ٥٤٧٠ قال ابنُ عطية (٧/٢٧٦): «قوله: <q>﴿ينظرون﴾</q> يحتمل أن يريد: بالأبصار، أي: ينظرون ما هم فيه، وصدق ما كانوا يكذبون به. ويحتمل أن يكون بمعنى: ينتظرون ما يفعل بهم ويؤمرون به». ٦٥٢٠٦- قال يحيى بن سلّام: قال: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q> النفخة الآخرة، <q>﴿فَإذا هُمْ يَنْظُرُونَ﴾</q> قد خرجوا مِن قبورهم ينظرون{5}. (ز) ",footnotes:1:أخرجه الفريابي -كما في تغليق التغليق ٥/١٧٩-. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي الدنيا في العقوبات ٤/٥٠١ (٢٦٦).أخرجه ابن جرير ١٩/٥١٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٤.تفسير يحيى بن سلّام ٢/٨٢٦.
37,20," <q>﴿وَقَالُوا۟ یَـٰوَیۡلَنَا هَـٰذَا یَوۡمُ ٱلدِّینِ ۝٢٠﴾</q> - تفسير ٦٥٢٠٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هَذا يَوْمُ الدِّينِ﴾</q>، قال: يدين اللهُ فيه العبادَ بأعمالهم{1}. (١٢/٣٩٤) ٦٥٢٠٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿هَذا يَوْمُ الدِّينِ﴾</q>، قال: يوم الحساب{2}. (ز) ٦٥٢٠٩- قال مقاتل بن سليمان: فلمّا نظروا وعاينوا البعث ذَكَروا قولَ الرسل: إنّ البعث حقٌّ. <q>﴿وقالُوا يا ويْلَنا هَذا يَوْمُ الدِّينِ﴾</q> يوم الحساب الذي أخبرنا به النبيُّ ﷺ{3}. (ز) ",footnotes:1:أخرجه يحيى بن سلّام ٢/٨٢٧، وابن جرير ١٩/٥١٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥١٨. وعلَّقه يحيى بن سلام ٢/٨٢٧.تفسير مقاتل بن سليمان ٣/٦٠٤.
37,21," <q>﴿هَـٰذَا یَوۡمُ ٱلۡفَصۡلِ ٱلَّذِی كُنتُم بِهِۦ تُكَذِّبُونَ ۝٢١﴾</q> - تفسير ٦٥٢١٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هَذا يَوْمُ الفَصْلِ﴾</q>: يعني: يوم القيامة{1}. (١٢/٣٩٤) ٦٥٢١١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿هَذا يَوْمُ الفَصْلِ﴾</q>، قال: يوم يقضي بين أهل الجنة وأهل النار{2}. (ز) ٦٥٢١٢- قال مقاتل بن سليمان: فردَّت عليهم الحفظةُ مِن الملائكة: <q>﴿هَذا يَوْمُ الفَصْلِ﴾</q> يوم القضاء <q>﴿الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</q> بأنّه كائن{3}. (ز) ٦٥٢١٣- قال يحيى بن سلّام: قال: <q>﴿هَذا يَوْمُ الفَصْلِ الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</q> يوم القضاء، يُقضى فيه بين المؤمنين والمشركين، فيدخل المؤمنون الجنة، ويدخل المشركون النار{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥١٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥١٩.تفسير مقاتل بن سليمان ٣/٦٠٤.تفسير يحيى بن سلّام ٢/٨٢٧.
37,22," <q>﴿ٱحۡشُرُوا۟ ٱلَّذِینَ ظَلَمُوا۟ وَأَزۡوَ ٰ⁠جَهُمۡ﴾</q> - نزول الآية ٦٥٢١٤- قال مقاتل بن سليمان: نزلت في كفار قريش{1}. (ز) <q>﴿ٱحۡشُرُوا۟ ٱلَّذِینَ ظَلَمُوا۟ وَأَزۡوَ ٰ⁠جَهُمۡ﴾</q> - تفسير الآية ٦٥٢١٥- عن عمر بن الخطاب، قال: سمعتُ رسول الله ﷺ يقول: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: «وضرباءهم»{2}. (ز) ٦٥٢١٦- عن عمر بن الخطاب -من طريق النعمان بن بشير- في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أمثالهم الذين هم مثلهم، يجيء أصحابُ الربا مع أصحاب الربا، وأصحاب الزنا مع أصحاب الزنا، وأصحاب الخمر مع أصحاب الخمر؛ أزواج في الجنة، وأزواج في النار{3}. (١٢/٣٩٤) ٦٥٢١٧- عن عمر بن الخطاب -من طريق النعمان بن بشير- قال في قوله: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q> [التكوير:٧]، قال: يُزوّج الرجل نظيره مِن أهل الجنة، ويُزوّج الرجل نظيره من أهل النار. ثم قال: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ وما كانُوا يَعْبُدُونَ * مِن دُونِ اللَّهِ فاهْدُوهُمْ إلى صِراطِ الجَحِيمِ﴾</q>{4}. (ز) ٦٥٢١٨- عن النعمان بن بشير -من طريق سماك بن حرب- في قوله تعالى: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أمثالهم الذين مثلهم{5}. (ز) ٦٥٢١٩- عن عبد الله بن عباس، في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: تقول الملائكة للزبانية: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>{6}. (١٢/٣٩٤) ٦٥٢٢٠- عن عبد الله بن عباس -من طريق عطية- قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، يعني: أتباعهم، ومن أشبههم مِن الظلمة{7}. (ز) ٦٥٢٢١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أشباههم. وفي لفظ: نظراؤهم{8}. (١٢/٣٩٤) ٦٥٢٢٢- عن سعيد بن جبير= (ز) ٦٥٢٢٣- وعكرمة مولى ابن عباس، مثله{9}. (١٢/٣٩٥) ٦٥٢٢٤- عن أبي العالية الرِّياحي -من طريق داود- <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: وأشياعهم{7}. (ز) ٦٥٢٢٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أمثالهم؛ القتلة مع القتلة، والزناة مع الزناة، وأكلة الربا مع أكلة الربا{11}. (١٢/٣٩٥) ٦٥٢٢٦- قال الضحاك بن مزاحم: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> قرناؤهم مِن الشياطين، كل كافر معه شيطانُه في سلسلة{12}. (ز) ٦٥٢٢٧- عن الحسن البصري: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> إنّ كل قوم يلحقون بصنفهم، وما كانوا يعبدون من دون الله{13}. (ز) ٦٥٢٢٨- عن الحسن البصري: يعني: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> الشياطين التي دعتهم إلى عبادة الأوثان، فإنما عبدوا الشياطين{13}. (ز) ٦٥٢٢٩- قال الحسن البصري: <q>﴿وأَزْواجَهُمْ﴾</q> المشركات{15}٥٤٧١. (ز) ٥٤٧١ قال ابنُ تيمية (٥/٣٤٠-٣٤١): «ليس المراد: أنه يحشر معهم زوجاتهم مطلقًا؛ فإن المرأة الصالحة قد يكون زوجها فاجرًا، بل كافرًا كامرأة فرعون. وكذلك الرجل الصالح قد تكون امرأته فاجرة، بل كافرة كامرأة نوح ولوط. لكن إذا كانت المرأة على دين زوجها دخلت في عموم الأزواج، ولهذا قال الحسن البصري: <q>﴿وأزواجهم﴾</q>: المشركات». ٦٥٢٣٠- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وأَزْواجَهُمْ﴾</q>، قال: هم وأشكالهم{16}. (ز) ٦٥٢٣١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أشباههم مِن الكفار مع الكُفّار{17}. (١٢/٣٩٥) ٦٥٢٣٢- قال قتادة بن دعامة= (ز) ٦٥٢٣٣- ومحمد بن السائب الكلبي: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> كل مَن عمل مثل عملهم؛ فأهل الخمر مع أهل الخمر، وأهل الزنا مع أهل الزنا{15}. (ز) ٦٥٢٣٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: وأشباههم{7}. (ز) ٦٥٢٣٥- قال إسماعيل السُّدِّيّ: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> سُوقوا الذين كفروا وشركاءهم مِن الشياطين إلى الحساب، <q>﴿وأَزْواجَهُمْ﴾</q> يعني: وقرناؤهم مِن الشياطين{13}. (ز) ٦٥٢٣٦- عن زيد بن أسلم، في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أزواجهم في الأعمال. وقرأ: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q> الآية [الواقعة:٧]، قال: فأصحاب الميمنة زوج، وأصحاب المشأمة زوج، والسابقون زوج{6}. (١٢/٣٩٥) ٦٥٢٣٧- قال محمد بن السائب الكلبي: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا﴾</q> الشياطين، <q>﴿وأَزْواجَهُمْ﴾</q> مَن عمِل بأعمالهم مِن بني آدم{13}. (ز) ٦٥٢٣٨- قال مقاتل بن سليمان: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا﴾</q> الذين أشركوا مِن بني آدم، <q>﴿وأَزْواجَهُمْ﴾</q> قرناءهم مِن الشياطين الذين أضلوهم، وكل كافر مع شيطان في سلسلة واحدة{23}. (ز) ٦٥٢٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q>، قال: أزواجهم في الأعمال. وقرأ: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً * فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ * وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ * والسّابِقُونَ السّابِقُونَ﴾</q> [الواقعة:٧-١٠]، فالسابقون زوج، وأصحاب الميمنة زوج، وأصحاب الشمال زوج. قال: كل مَن كان مِن هذا حشره الله معه. وقرأ: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q> [التكوير:٧]، قال: زُوِّجت على الأعمال، لكل واحد مِن هؤلاء زوج، زوَّج الله بعض هؤلاء بعضًا؛ زوَّج أصحاب اليمين أصحاب اليمين، وأصحاب المشأمة أصحاب المشأمة، والسابقين السابقين. قال: فهذا قوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> قال: أزواج الأعمال التي زوجهن الله{7}. (ز) ٦٥٢٤٠- قال يحيى بن سلّام: <q>﴿احْشُرُوا﴾</q> سوقوا <q>﴿الَّذِينَ ظَلَمُوا﴾</q> أشركوا، <q>﴿وأَزْواجَهُمْ﴾</q> أي: وأشكالهم{25}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٤.أخرجه الثعلبي ٨/١٤١، من طريق محمد بن عثمان بن أبي شيبة، قال: حدثنا عمي أبو بكر، قال: حدثنا وكيع، عن سفيان، عن سماك، عن النعمان بن بشير، عن عمر به مرفوعًا. إسناده ضعيف؛ فيه محمد بن عثمان بن أبي شيبة، قال ابن عدي: «لم أر له حديثًا منكرًا، وهو على ما وصف لي عبدان لا بأس به». وقال عبد الله بن أحمد بن حنبل: «كذاب». وقال ابن خراش: «كان يضع الحديث». وقال البرقاني: «لم أزل أسمعهم يذكرون أنه مقدوح فيه». كما في اللسان لابن حجر ٧/٣٤٠. وفيه أيضًا سماك بن حرب، قال عنه ابن حجر في التقريب (٢٦٢٤): «صدوق، وروايته عن عكرمة خاصة مضطربة، وقد تغيّر بأخَرَة فكان ربما تلقّن». وفي تهذيب التهذيب ٤/٢٠٤-٢٠٥: «ابن معين سُئِل عنه: ما الذي عابه؟ قال: أسند أحاديث لم يسندها غيره، وهو ثقة. وقال ابن عمار: يقولون إنه كان يغلط، ويختلفون في حديثه. وقال النسائي: كان ربما لُقّن، فإذا انفرد بأصلٍ لم يكن حجةً؛ لأنه كان يُلقَّن فيتلقَّن». وقد روى الحديث ابن جرير ١٩/٥١٩ و٢٤/١٤١، من طريق ابن مهدي عبد الرحمن، قال: حدثنا سفيان، عن سماك بن حرب، عن النعمان بن بشير، عن عمر به موقوفًا عليه مِن قوله. فكأن رواية الرفع خطأ.أخرجه الحاكم ٢/٣٤٠ مختصرًا، وابن منيع في مسنده -كما في المطالب (٤٠٧٥)-، وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في البعث. وأخرجه آدم بن أبي إياس -تفسير مجاهد (٥٦٧)- بلفظ: الصالح مع الصالح، والطالح مع الطالح. أخرجه ابن جرير ١٩/٥١٩، وإسحاق البستي ص٢٠١ بلفظ: ضرباؤهم.أخرجه يحيى بن سلام ٢/٨٢٧.أخرجه عبد الرزاق ٢/١٤٨، وإسحاق البستي ص٢٠٠ بلفظ: الذين هم مثلهم في العمل.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٢٠.أخرجه سفيان الثوري (٢٥٢)، وابن جرير ١٩/٥١٩-٥٢٠. وعزاه السيوطي إلى البيهقي في البعث، والفريابي، وسعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥٢٠.أخرجه ابن جرير ١٩/٥٢١ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٨/١٤١.علقه يحيى بن سلام ٢/٨٢٧.علقه يحيى بن سلام ٢/٨٢٧.تفسير الثعلبي ٨/١٤١، وتفسير البغوي ٧/٣٧.أخرجه عبد الرزاق ٢/١٤٨.أخرجه ابن جرير ١٩/٥٢١ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٨/١٤١، وتفسير البغوي ٧/٣٧.أخرجه ابن جرير ١٩/٥٢٠.علقه يحيى بن سلام ٢/٨٢٧.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٨٢٧.تفسير مقاتل بن سليمان ٣/٦٠٥. وآخره في تفسير الثعلبي ٨/١٤١ عن مقاتل مهملًا.أخرجه ابن جرير ١٩/٥٢٠.تفسير يحيى بن سلام ٢/٨٢٨.
37,23," <q>﴿وَمَا كَانُوا۟ یَعۡبُدُونَ ۝٢٢ مِن دُونِ ٱللَّهِ﴾</q> - تفسير ٦٥٢٤١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما كانُوا يَعْبُدُونَ * مِن دُونِ اللَّهِ﴾</q>، قال: الأصنام{1}. (١٢/٣٩٥) ٦٥٢٤٢- قال مقاتل بن سليمان: <q>﴿وما كانُوا يَعْبُدُونَ * مِن دُونِ اللَّهِ﴾</q> يعني: إبليس وجنده. نزلت في كفار قريش. نظيرها في يس [٦٠]: <q>﴿ألَمْ أعْهَدْ إلَيْكُمْ يا بَنِي آدَمَ أنْ لا تَعْبُدُوا الشَّيْطانَ﴾</q>. <q>﴿وما كانُوا يَعْبُدُونَ مِن دُونِ اللَّهِ﴾</q> يعني: إبليس وحده{2}٥٤٧٢. (ز) ٥٤٧٢ قال ابنُ عطية (٧/٢٧٧): «ما كانوا يعبدون من دون الله: مِن آدمي رَضِي بذلك، ومِن صنم ووثن توبيخًا لهم، وإظهارًا لسوء حالهم». وقال ابن تيمية (٥/٣٤٢): «يخرج مِن هذا مَن عُبِدَ مع كراهته لأن يُعْبَد ويطاع في معصية الله. فهم الذين سبقت لهم الحسنى، كالمسيح والعزير وغيرهما فأولئك مبعدون. وأما مَن رضي بأن يُعْبَد ويطاع في معصية الله فهو مستحق للوعيد، ولو لم يَأْمُر بذلك، فكيف إذا أمَر؟! وكذلك من أمر غيره بأن يعبد غير الله». <q>﴿فَٱهۡدُوهُمۡ إِلَىٰ صِرَ ٰ⁠طِ ٱلۡجَحِیمِ ۝٢٣﴾</q> - تفسير ٦٥٢٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فاهْدُوهُمْ إلى صِراطِ الجَحِيمِ﴾</q>، قال: وجِّهوهم{3}. (١٢/٣٩٥) ٦٥٢٤٤- عن عبد الله بن عباس، في قوله: <q>﴿فاهْدُوهُمْ﴾</q> قال: دُلُّوهم <q>﴿إلى صِراطِ الجَحِيمِ﴾</q> قال: طريق النار{4}. (١٢/٣٩٦) ٦٥٢٤٥- قال الضحاك بن مزاحم: <q>﴿وما كانُوا يَعْبُدُونَ مِن دُونِ اللَّهِ فاهْدُوهُمْ﴾</q> فادعوهم{5}. (ز) ٦٥٢٤٦- عن الحسن البصري، في قوله: <q>﴿فاهْدُوهُمْ إلى صِراطِ الجَحِيمِ﴾</q>، قال:سُوقوهم{6}. (١٢/٣٩٦) ٦٥٢٤٧- قال إسماعيل السُّدِّيّ: <q>﴿فاهْدُوهُمْ﴾</q> فادعوهم{7}. (ز) ٦٥٢٤٨- قال مقاتل بن سليمان: <q>﴿فاهْدُوهُمْ إلى صِراطِ﴾</q> يعني: ادعوهم إلى طريق <q>﴿الجَحِيمِ﴾</q>، والجحيم: ما عظَّم الله ﷿ مِن النار{8}. (ز) ٦٥٢٤٩- قال يحيى بن سلّام: <q>﴿مِن دُونِ اللَّهِ فاهْدُوهُمْ﴾</q> فادعوهم <q>﴿إلى صِراطِ﴾</q> إلى طريق <q>﴿الجَحِيمِ﴾</q>، والجحيم: اسم من أسماء جهنم، وهو الباب الخامس، وأسماء أبوابها السبعة: جهنم هو الباب الأعلى، ثم لظى، ثم الحطمة، ثم السعير، ثم الجحيم، ثم سقر، ثم الهاوية وهي الدرك الأسفل مِن النار، وهي جميعًا النار، وجهنم اسم جامع لتلك الأبواب، قال: <q>﴿فادْخُلُوا أبْوابَ جَهَنَّمَ﴾</q> [النحل:٢٩]، وكل باب منها هو النار: الأعلى جهنم، ثم لظى، والنار كلها لظى، قال: <q>﴿فَأَنْذَرْتُكُمْ نارًا تَلَظّى﴾</q> [الليل:١٤] تأجَّج، ثم الحطمة، والنار كلها حطمة، تحطم عظامهم وتأكل كل شيء إلا الفؤاد، قال: <q>﴿كَلّا لَيُنْبَذَنَّ فِي الحُطَمَةِ﴾</q> [الهمزة:٤]، ثم السعير، والنار كلها سعير سُعِّر بهم، قال: <q>﴿وسَيَصْلَوْنَ سَعِيرًا﴾</q> [النساء:١٠]، ثم الجحيم، والنار كلها جحيم، <q>﴿قالُوا ابْنُوا لَهُ بُنْيانًا فَأَلْقُوهُ فِي الجَحِيمِ﴾</q> [الصافات:٩٧] في النار، ثم سقر، والنار كلها سقر، قال: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q> [المدثر:٢٨]، فكذلك تفعل تلك الأبواب كلها بهم، لا تبقي أجسادهم حين يدخلونها، ولا تذر حين يجدد خلقهم حتى تأكل أجسادهم، وهو قوله: <q>﴿كُلَّما نَضِجَتْ جُلُودُهُمْ بَدَّلْناهُمْ جُلُودًا غَيْرَها﴾</q> [النساء:٥٦]، ثم الهاوية، والنار كلها هاوية، يهوون فيها، قال: <q>﴿فَأُمُّهُ هاوِيَةٌ﴾</q> [القارعة:٩]، غير أن هذه الأنواع التي وصف بها النار لكل باب مِن أبوابها اسمٌ مِن تلك الأنواع سُمِّيَتْ به، ولكل قوم مِن أهل النار منزل مِن تلك الأبواب التي سميت بهذه الأسماء{9}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٤-٦٠٥. وفي تفسير البغوي ٧/٣٧ بنحوه منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٩/٥٢٢، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.تفسير الثعلبي ٨/١٤١، وتفسير البغوي ٧/٣٧.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ٢/٨٢٧.تفسير مقاتل بن سليمان ٣/٦٠٤-٦٠٥.تفسير يحيى بن سلام ٢/٨٢٧-٨٢٨.
37,24," <q>﴿وَقِفُوهُمۡۖ إِنَّهُم مَّسۡـُٔولُونَ ۝٢٤﴾</q> - تفسير ٦٥٢٥٠- عن أنس بن مالك، قال: قال رسول الله ﷺ: «ما من داعٍ دعا إلى شيء إلا كان موقوفًا يوم القيامة، لازِمًا به، لا يُغادِره ولا يُفارِقه، وإن دعا رجلٌ رجلًا». ثم قرأ: <q>﴿وقفوهم إنهم مسؤولون﴾</q>{1}. (١٢/٣٩٦) ٦٥٢٥١- عن عبد الله بن عباس، في قوله: <q>﴿وقِفُوهُمْ إنَّهُمْ مَسْئُولُونَ﴾</q>، قال: احبسوهم إنّهم مُحاسَبون{2}. (١٢/٣٩٦) ٦٥٢٥٢- قال عبد الله بن عباس: <q>﴿وقِفُوهُمْ إنَّهُمْ مَسْئُولُونَ﴾</q> عن جميع أقوالهم وأفعالهم{3}. (ز) ٦٥٢٥٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: يحشر اللهُ الجنَّ والإنس إلى صُقع من الأرض، فيأخذون مقامهم منها، ثم ينزل الله سِبطًا مِن الملائكة، فيطيفون بالجن والإنس -أي: يُحْدِقون بهم-، ثم ينزل الله سبطًا من الملائكة، يطيفون بالملائكة وبالجن والإنس، ثم ينزل سبطًا ثالثًا، ورابعًا، وخامسًا، وسادسًا، وينزل الله ﷾ في السبط السابع، مجتنباه جهنم، فإذا رأوه الخلائق ابْذَعَرُّوا{4} فرارًا، فيقول: <q>﴿وقِفُوهُمْ إنَّهُمْ مَسْئُولُونَ * ما لَكُمْ لا تَناصَرُونَ * بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q>. فينادي: <q>﴿يا مَعْشَرَ الجِنِّ والإنْسِ إنِ اسْتَطَعْتُمْ أنْ تَنْفُذُوا مِن أقْطارِ السَّماواتِ والأَرْضِ فانْفُذُوا لا تَنْفُذُونَ إلّا بِسُلْطانٍ﴾</q> [الرحمن:٣٣]{5}. (ز) ٦٥٢٥٤- قال عبد الله بن عباس: <q>﴿إنَّهُمْ مَسْؤُلُونَ﴾</q> عن لا إله إلّا الله{6}. (ز) ٦٥٢٥٥- قال الضحاك بن مزاحم: <q>﴿إنَّهُمْ مَسْؤُلُونَ﴾</q> عن خطاياهم{7}. (ز) ٦٥٢٥٦- عن عطية بن سعد العوفي، في قوله: <q>﴿وقِفُوهُمْ إنَّهُمْ مَسْئُولُونَ﴾</q>، قال: يُوقَفون يوم القيامة حتى يُسألوا عن أعمالهم{8}. (١٢/٣٩٦) ٦٥٢٥٧- قال مقاتل بن سليمان: <q>﴿وقِفُوهُمْ إنَّهُمْ مَسْؤُلُونَ﴾</q> فلمّا سِيقوا إلى النار حُبِسوا، فسألهم خزنة جهنم: ألم تأتكم رسلكم بالبينات؟ قالوا: بلى، ولكن حقَّت كلمة العذاب على الكافرين{9}. (ز) ٦٥٢٥٨- قال يحيى بن سلّام: قوله ﷿: <q>﴿وقِفُوهُمْ﴾</q> أي: احبسوهم، وهذا قبل أن يدخلوا النار؛ <q>﴿إنَّهُمْ مَسْئُولُونَ﴾</q> عن لا إله إلا الله{10}٥٤٧٣. (ز) ٥٤٧٣ اختُلِف في الشيء الذي يُسْأَلون عنه على خمسة أقوال: الأول: عن لا إله إلا الله. والثاني: عن أعمالهم ويوقفون على قبحها. والثالث: هل يحبون شرب الماء البارد؟ والرابع: عما دعوا إليه من بدعة. والخامس: عما كانوا يعبدون من دون الله. وعلَّقَ ابنُ عطية (٧/٢٧٧) على القول الثاني، بقوله: «هذا قول مُتَّجه، عامٌّ في الهزء وغيره». وعلَّقَ على القول الثالث، بقوله: «هذا على طريق الهزْء بهم». ثم ذكر قولًا آخر محتملًا، فقال: «ويحتمل عندي أن يكون المعنى على ما فسره بقوله: <q>﴿ما لكم لا تناصرون﴾</q> أي: تسألون عن امتناعهم عن التناصر». <q>﴿وَقِفُوهُمۡۖ إِنَّهُم مَّسۡـُٔولُونَ ۝٢٤﴾</q> - آثار متعلقة بالآية ٦٥٢٥٩- عن أبي الزَّعْراء، قال: كنا عند عبد الله [بن مسعود]، فذكر قصة، ثم قال: يَتَمَثَّل اللهُ للخلق، فيلقاهم، فليس أحد مِن الخلق كان يعبد مِن دون الله شيئًا إلا وهو مرفوع له يتبعه، قال: فيلقى اليهود، فيقول: من تعبدون؟ فيقولون: نعبد عُزيرًا. قال: فيقول: هل يسركم الماء؟ فيقولون: نعم. فيريهم جهنم وهي كهيئة السراب، ثم قرأ: <q>﴿وعَرَضْنا جَهَنَّمَ يَوْمَئِذٍ لِلْكافِرِينَ عَرْضًا﴾</q> [الكهف:١٠٠]. قال: ثم يلقى النصارى، فيقول: مَن تعبدون؟ فيقولون: المسيح. فيقول: هل يسركم الماء؟ فيقولون: نعم. فيريهم جهنم وهي كهيئة السراب، ثم كذلك لمن كان يعبد من دون الله شيئًا، ثم قرأ عبد الله: <q>﴿وقِفُوهُمْ إنَّهُمْ مَسْئُولُونَ﴾</q>{11}. (ز) ",footnotes:1:أخرجه الترمذي ٥/٤٣٩ (٣٥٠٨)، والحاكم ٢/٤٦٧-٤٦٨ (٣٦١٠، ٣٦١١)، وابن جرير ١٩/٥٢٣، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٩-. قال الترمذي: «هذا حديث غريب». وقال الحاكم: «للحديث أصلًا بإسناد ما».أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.تفسير البغوي ٧/٣٧.ابْذَعَرَّ الناسُ: تَفَرَّقُوا. اللسان (بذر).أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٢٢-٢٢٣ (٢١١)-، وينظر: طبعة مكتبة آل ياسر ١٤١٣ﻫ بتحقيق: مجدي فتحي السيد ص١٣٢ (١٧٠).تفسير الثعلبي ٨/١٤٢، وتفسير البغوي ٧/٣٧.تفسير الثعلبي ٨/١٤٢.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٠٥.تفسير يحيى بن سلام ٢/٨٢٨.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٢١/٢٨١-٢٨٥ (٣٨٧٩٢) مطولًا، وابن جرير ١٩/٥٢٢.
