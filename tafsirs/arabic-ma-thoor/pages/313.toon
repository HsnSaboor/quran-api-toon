quran[25]{c,v,t}:
20,13," <q>﴿وَأَنَا ٱخۡتَرۡتُكَ فَٱسۡتَمِعۡ لِمَا یُوحَىٰۤ ۝١٣﴾</q> - قراءات ٤٧٥٠٩- عن الأعمش: قال في قراءة عبد الله [بن مسعود]: <q>﴿وأنا اخترتك فاستمع لما يوحى﴾</q>: ›اخْتَرْناكَ‹{1}. (ز) <q>﴿وَأَنَا ٱخۡتَرۡتُكَ فَٱسۡتَمِعۡ لِمَا یُوحَىٰۤ ۝١٣﴾</q> - تفسير الآية ٤٧٥١٠- قال مقاتل بن سليمان: <q>﴿وأنا اخترتك﴾</q> يا موسى للرسالة؛ <q>﴿فاستمع لما يوحى﴾</q> يعني: للذي يوحى إليك. والوحيُ ما ذكر الله ﷿: <q>﴿إنني أنا الله لا إله إلا أنا﴾</q>...= (ز) ٤٧٥١١- عن علقمة بن مرثد عن كعب [الأحبار]: أنّ موسى ﵇ كلَّمه ربُّه مرَّتين، ورأى محمدٌ ﷺ ربَّه جلَّ جلاله مرتين، وعصى آدم ﵇ ربَّه تعالى مرتين{2}. (ز) ٤٧٥١٢- قال يحيى بن سلّام: قوله: <q>﴿وأنا اخترتك﴾</q> أي: لرسالتي ولكلامي؛ <q>﴿فاستمع لما يوحى﴾</q> إليك{3}. (ز) ",footnotes:1:أخرجه الثوري في تفسيره ص١٩٣. و‹اخْتَرناكَ› قراءة حمزة، وقرأ البقية: <q>﴿اخترتك﴾</q>. انظر: النشر ٢/٣٢٠.تفسير مقاتل بن سليمان ٣/٢٣.تفسير يحيى بن سلّام ١/٢٥٤.
20,14," <q>﴿إِنَّنِیۤ أَنَا ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدۡنِی﴾</q> - تفسير ٤٧٥١٣- قال مقاتل بن سليمان: قوله سبحانه: <q>﴿فاعبدني﴾</q>، يعني: فوَحِّدني، فإنّه ليس معي إله{1}. (ز) <q>﴿إِنَّنِیۤ أَنَا ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدۡنِی﴾</q> - آثار متعلقة بالآية ٤٧٥١٤- عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «مكتوبٌ على باب الجنة: إنّني أنا الله لا إله إلا أنا، لا أُعَذِّب مَن قالها»{2}. (١٠/١٧٣) ٤٧٥١٥- عن علي بن أبي طالب، قال: حدَّثنا رسولُ الله ﷺ عن جبريل ﵇، قال: «قال الله ﷿: إنِّي أنا الله لا إله إلا أنا فاعبدني، مَن جاءني منكم بشهادة أن لا إله إلا الله بالإخلاص دخل حِصْنِي، ومَن دخل حِصْنِي أمِنَ عذابي»{3}. (١٠/١٧٥) ٤٧٥١٦- عن محمد بن أعْيَن، قال: قلتُ لابن المبارك: إنّ فلانًا يقول: مَن زعم أنّ قول الله تعالى: <q>﴿إنني أنا الله لا إله إلا أنا فاعبدني﴾</q> مخلوق؛ فهو كافر. فقال ابنُ المبارك: صَدَق{4}. (ز) <q>﴿وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ ۝١٤﴾</q> - قراءات ٤٧٥١٧- قال يونس: وكان ابن شهاب يقرؤها: (لِلذِّكْرى){5}. (١٠/١٧٦) <q>﴿وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ ۝١٤﴾</q> - تفسير الآية ٤٧٥١٨- عن قتادة، عن أنس بن مالك، أنّ رسول الله ﷺ قال: «إذا رقد أحدُكم عن الصلاة، أو غفل عنها؛ فلْيُصَلِّها إذا ذكرها؛ فإنّ الله قال: <q>﴿أقم الصلاة لذكري﴾</q>»{6}. (١٠/١٧٥) ٤٧٥١٩- عن أبي هريرة: أنّ رسول الله ﷺ حين قَفَل مِن غزوة خيبر سار ليلَه، حتى إذا أدركه الكرى عَرَّس{7}، وقال لبلال: «اكْلَأ لنا الليلَ». فصلّى بلالٌ ما قُدِّر له، ونام رسول الله ﷺ وأصحابه، فلما تقارب الفجرُ استند بلالٌ إلى راحلته مُواجِهَ الفجر، فغلبت بلالًا عيناه وهو مُسْتَنِدٌ إلى راحلته، فلم يستيقظ رسولُ الله ﷺ، ولا بلال، ولا أحد من أصحابه حتى ضربتهم الشمس، فكان رسول الله ﷺ أولهم استيقاظًا، ففزِع رسول الله ﷺ، فقال: «أي بلالُ». فقال بلال: أخذ بنفسي الذي أخذ -بأبي أنت وأمي يا رسول الله- بنفسك. قال: «اقْتادوا». فاقتادوا رواحلَهم شيئًا، ثم توضأ رسول الله ﷺ، وأمر بلالًا، فأقام الصلاة، فصلّى بهم الصبح، فلما قضى الصلاةَ قال: «مَن نسي الصلاةَ فلْيُصَلِّها إذا ذكرها». فإنّ الله قال: <q>﴿أقم الصلاة لذكري﴾</q>... {8}. (١٠/١٧٦) ٤٧٥٢٠- عن عبادة بن الصامت، قال: سُئِل رسولُ الله ﷺ عن رجل غَفِلَ عن الصلاة حتى طلعت الشمس أو غربت، ما كفارتها؟ قال: «يتقرَّب إلى الله، ويحسن وضوءه، ويصلي فيحسن الصلاة، ويستغفر الله، فلا كفارة لها إلا ذلك. إن الله يقول: <q>﴿وأقم الصلاة لذكري﴾</q>»{9}. (١٠/١٧٦) ٤٧٥٢١- عن سعيد بن المسيب، أنّ رسول الله ﷺ قال: «مَن نَسِي صلاةً فلْيُصَلِّها إذا ذكرها؛ فإنّ الله ﷿ يقول: <q>﴿وأقم الصلاة لذكري﴾</q>»{10}. (ز) ٤٧٥٢٢- عن سمرة بن يحيى، قال: نسيتُ صلاة العتمة حتى أصبحتُ، فغدوتُ إلى ابن عباس، فأخبرته، فقال: قُمْ، فَصَلِّها. ثم قرأ: <q>﴿وأقم الصلاة لذكري﴾</q>{11}. (١٠/١٧٦) ٤٧٥٢٣- عن إبراهيم النخعي، في قوله: <q>﴿وأقم الصلاة لذكري﴾</q>، قال: حين تَذْكُرُ{12}. (١٠/١٧٥) ٤٧٥٢٤- عن إبراهيم النخعي= (ز) ٤٧٥٢٥- وعامر الشعبي، في قوله: <q>﴿أقم الصلاة لذكري﴾</q>، قالا: صَلِّها إذا ذكرتَها وقد نسيتَها{13}. (١٠/١٧٧) ٤٧٥٢٦- عن إبراهيم النخعي -من طريق مغيرة- قال: مَن نام عن صلاةٍ أو نسيها يُصَلِّي متى ذكرها، عند طلوع الشمس وعند غروبها. ثم قرأ: <q>﴿وأقم الصلاة لذكري﴾</q>. قال: إذا ذكرتها فصَلِّها في أيِّ ساعة كنتَ{14}. (١٠/١٧٧) ٤٧٥٢٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وأقم الصلاة لذكري﴾</q>، قال: إذا صلّى عبدٌ ذَكَرَ ربَّه{15}. (١٠/١٧٥) ٤٧٥٢٨- قال مجاهد بن جبر: إذا تركتَ الصلاة ثم ذكرتَها فأقِمْها{16}. (ز) ٤٧٥٢٩- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿وأقم الصلاة لذكري﴾</q>، يقول: لتذكُرَني بها، يا موسى{1}٤٢٤٦. (ز) ٤٢٤٦ اختلف السلف في تفسير قوله: <q>﴿وأقم الصلاة لذكري﴾</q> على أقوال: الأول: أقِم الصلاة حين تذكرها. الثاني: أقم الصلاة لتذكرني بها. الثالث: أقم الصلاة لأذكرك بها. فعلى القول الأول تكون اللام وقتية، وعلى القولين الآخرين تكون اللام سببية كما ذكرَ ابنُ عطية (٦/٨٣)، وابنُ القيم (٢/١٧٩). وقد رجّح ابن جرير (١٦/٣٣ بتصرف) مستندًا إلى ظاهر لفظ الآية القول الثاني، فقال: «وأولى التأويلين في ذلك بالصواب تأويلُ مَن قال: معناه: أقم الصلاة لتذكرني فيها؛ لأن ذلك أظهر معنييه، وفي قوله: <q>﴿لذكري﴾</q> دلالة بينة على صحة ذلك». وبنحوه ابنُ القيم (٢/١٧٩)، وبيّن أن هذا القول يستلزم القولين الآخرين. وقوّى ابنُ كثير (٩/٣١٧-٣١٨ بتصرف) القول الأول بقوله: «ويشهد لهذا القول ما رواه الإمام أحمد ... عن أنس، عن النبي ﷺ، قال: «إذا رقد أحدكم عن الصلاة، أو غفل عنها، فليصلها إذا ذكرها؛ فإن الله تعالى قال: <q>﴿وأقم الصلاة لذكري﴾</q>». وفي الصحيحين عن أنس قال: قال رسول الله ﷺ: «من نام عن صلاة أو نسيها، فكفارتها أن يصليها إذا ذكرها، لا كفارة لها إلا ذلك»». واستدرك ابن جرير مستندًا لظاهر لفظ الآية على هذا القول، فقال: «ولو كان معناه: حين تذكرها؛ لكان التنزيل: أقم الصلاة لذكركها». وكذا استدرك ابنُ القيم مستندًا إلى اللغة ... وذكر أن تفسير الآية به فيه نظر؛ «لأن اللام الوقتية يليها أسماء المكان والظروف، والذِّكْرُ مصدر، إلا أن يقدر زمان محذوف: أي عند وقت ذكري، وهذا محتمل». <q>﴿وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ ۝١٤﴾</q> - آثار متعلقة بالآية ٤٧٥٣٠- عن أبي جُحَيْفَة، قال: كان رسول الله ﷺ في سفره الذي ناموا فيه حتى طلعت الشمس، ثم قال: «إنّكم كنتم أمواتًا، فردَّ الله إليكم أرواحَكم، فمَن نام عن الصلاة أو نسي صلاة فليُصَلِّها إذا ذكرها، وإذا استيقظ»{18}. (١٠/١٧٧) ٤٧٥٣١- عن أنس بن مالك، قال: خرج عمرُ بنُ الخطاب مُتَقَلِّدًا بالسيف، فلقِيَهُ رجلٌ مِن بني زُهْرَة، فقال له: أين تغدو، يا عمر؟ قال: أريد أن أقتل محمدًا. قال: وكيف تأمن بني هاشم وبني زُهْرَة؟ فقال له عمر: ما أراك إلا قد صَبَأتَ وتركت دينك! قال: أفلا أدُلُّك على العجب؟ إنّ أختك وخَتَنَك قد صَبَوا وتركا دينك. فمشى عمرُ ذامِرًا حتى أتاهما وعندهما خَبّابٌ، فلما سمع خبّاب بحِسِّ عمر توارى في البيت، فدخل عليهما، فقال: ما هذه الهَيْنَمَةُ{19} التي سمعتها عندكم؟ وكانوا يقرأون طه، فقالا: ما عدا حديثًا تحدَّثنا به. قال: فلعلَّكما قد صَبَوتُما. فقال له خَتَنُه: يا عمر، إن كان الحق في غير دينك؟ فوَثَب عمرُ على خَتَنِه، فوَطِئه وطأ شديدًا، فجاءت أختُه لتدفعه عن زوجها، فنَفَحَها نَفَحَة بيده، فدمّى وجهَها، فقال عمر: أعطُوني الكتابَ الذي هو عندكم فأقرأه. فقالت أختُه: إنّك رجس، وإنّه لا يمسه إلا المطهرون، فقم فتوضأ. فقام فتوضأ، ثم أخذ الكتاب، فقرأ: <q>﴿طه﴾</q> حتى انتهى إلى <q>﴿إنني أنا الله لا إله إلا أنا فاعبدني وأقم الصلاة لذكري﴾</q>. فقال عمر: دُلُّوني على محمد. فلما سمع خبّابٌ قولَ عمر خرج من البيت، فقال: أبشِر، يا عمر، فإنِّي أرجو أن تكون دعوةَ رسول الله ﷺ لك ليلة الخميس: «اللَّهُمَّ، أعِزَّ الإسلامَ بعمر بن الخطاب، أو بعمرو بن هشام». فخرج حتى أتى رسول الله ﷺ، فأسلم{20}. (١٠/١٧٣-١٧٤) ٤٧٥٣٢- عن عبد الله بن عباس، قال: إذا نسيتَ صلاةً فاقْضِها متى ما ذكرتَ{12}. (١٠/١٧٧) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.عزاه السيوطي إلى أبي الشيخ.أخرجه أبو نعيم في الحلية ٣/١٩٢، والشجري في ترتيب الأمالي ١/٥٤-٥٥ (١٨٥). قال أبو نعيم: «هذا حديث ثابت مشهور بهذا الإسناد من رواية الطاهرين عن آبائهم الطيبين». وقال الألباني في الضعيفة ٩/٣٧ (٤٠٣٧): «ضعيف».أخرجه ابن عساكر في تاريخ دمشق ٧١/١٧١. وتوضيح ذلك فيما رواه إسحاق البستي في تفسيره ص٢٣٢ عن قتيبة بن سعيد: مَن قال: قوله: يا موسى <q>﴿إنني أنا الله لا إله إلا أنا فاعبدني﴾</q> مخلوق؛ فهو كافر، وما كان الله -تبارك وتعالى- ليأمر محمدًا ﷺ بعبادة مخلوق.أخرجه مسلم ١/٤٧١ (٦٨٠). وقراءة ابن شهاب شاذة. ينظر: مختصر الشواذ لابن خالويه ص٩٠.أخرجه البخاري ١/١٢٢ (٥٩٧)، ومسلم ١/٤٧٧ (٦٨٤). وعزاه السيوطي إلى عبد بن حميد وابن مردويه. قال الحافظ في الفتح ٢/٧٢: وقد اختُلِف في ذكر هذه الآية هل هي مِن كلام قتادة أو هي من قول النبي ﷺ، وفي رواية مسلم عن هداب قال قتادة: <q>﴿وأقم الصلاة لذكرى﴾</q>. وفي روايته من طريق المثنى عن قتادة: قال رسول الله ﷺ: «إذا رقد أحدكم عن الصلاة أو غفل عنها فليصلها إذا ذكرها، فإن الله يقول: <q>﴿أقم الصلاة لذكري﴾</q>». وهذا ظاهر أن الجميع من كلام النبي ﷺ.التَّعْرِيس: نُزول المُسافر آخِرَ اللّيل نَزْلَةً للنَّوم والاسْتراحَة. النهاية (عرس).أخرجه مسلم ١/٤٧١ (٦٨٠).أخرجه الطبراني في الكبير -كما في مجمع الزوائد ١/٣٢٣ (١٨١٠)-. وقال الهيثمي: «فيه إسحاق بن يحيى، ولم يسمع من عبادة، ولم يرو عنه غير موسى بن عقبة».أخرجه يحيى بن سلّام ١/٢٥٥، والشافعي في مسنده ١/٢٣٠ (١٥١)، وعبد الرزاق في مصنفه ٢/٣ (٢٢٤٥)، وفي تفسيره ٢/٣٧٠ (١٨٠٦).عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن أبي شيبة ٢/٦٥.أخرجه يحيى بن سلّام ١/٢٥٥ من طريق ابن مجاهد، وابن جرير ١٦/٣٢ من طريق ابن أبي نَجِيح وابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٢٦٧.تفسير مقاتل بن سليمان ٣/٢٤.أخرجه ابن أبي شيبة ١/٤١١-٤١٢ (٤٧٣٨)، ٧/٢٨١-٢٨٢ (٣٦٠٩٧)، وأبو يعلى ٢/١٩٢، من طريق عبد الجبار بن العباس الهمداني، عن عون بن أبي جحيفة، عن أبيه به. قال العقيلي في الضعفاء ٣/٨٨: «لا يحفظ من حديث أبي جحيفة إلا عن هذا الشيخ، وقد روي هذا عن أبي قتادة وغيره بأسانيد جياد». وقال ابن عدي في الكامل ٧/١٧: «وهذا لا أعلم يرويه عن عون غير عبد الجبار هذا». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٧٦٢ (٣٩٩٩) عن عبد الجبار بن عباس راوي الحديث: «وليس بذاك». وقال الهيثمي في المجمع ١/٣٢٢ (١٨٠٣): «رواه أبو يعلى، والطبراني في الكبير، ورجاله ثقات». وقال البوصيري في إتحاف الخيرة ٢/٢٣٧ (١٤١٤): «هذا إسناد حسن، عبد الجبار بن عباس مختلف في توثيقه، وباقي رجال الإسناد مُحْتَجٌّ بهم في الصحيح». وقال الألباني في الصحيحة ١/٧٥٢ (٣٩٦) على رواية أبي يعلى: «إسناد جيد، رجاله كلهم ثقات، رجال الشيخين، غير عبد الجبار هذا، وهو صدوق يَتَشَيَّع».الهَيْنَمَة: الكلام الخفي الذي لا يُفهم. النهاية (هَيْنَم).أخرجه الحاكم ٤/٦٥ (٦٨٩٧) مختصرًا، والضياء المقدسي في الأحاديث المختارة ٧/١٤٠-١٤٢، من طريق القاسم بن عثمان أبي العلاء البصري، عن أنس به. قال البوصيري في إتحاف الخيرة ٧/١٦٦ (٦٥٨٩): «رواه أبو يعلى الموصلي بسند ضعيف؛ لضعف القاسم بن عثمان البصري».عزاه السيوطي إلى عبد بن حميد.
20,15," <q>﴿إِنَّ ٱلسَّاعَةَ ءَاتِیَةٌ أَكَادُ أُخۡفِیهَا﴾</q> - قراءات ٤٧٥٣٣- عن قتادة، قال: هي في قراءة أبي بن كعب: (أكادُ أُخْفِيها مِن نَّفْسِي){1}. (ز) ٤٧٥٣٤- عن الفراء، قال: في قراءة أبي بن كعب: (أكادُ أُخْفِيها مِن نَّفْسِي فَكَيْفَ أُطْلِعُكُمْ عَلَيْها){2}. (١٠/١٧٩) ٤٧٥٣٥- عن إسماعيل السُّدِّي، قال: ليس مِن أهل السموات والأرض أحدٌ إلا وقد أخْفى اللهُ عنه علمَ الساعة. وهي في قراءة ابن مسعود: (أكادُ أُخْفِيها من نَّفْسِي). يقول: كتمتها مِن الخلائق، حتى لو استطعت أن أكتمها من نفسي لفعلت{3}. (١٠/١٧٨) ٤٧٥٣٦- عن عبد الله بن عباس أنه قرأ: (أكادُ أُخْفِيها مِن نَّفْسِي)، يقول: لأنها لا تخفى مِن نفس الله أبدًا{4}. (١٠/١٧٨) ٤٧٥٣٧- عن وِقاء، قال: أقرأنيها سعيدُ بن جبير: (أكادُ أخْفِيها)، يعني: بنصب الألف وخفض الفاء. يقول: أُظْهِرُها. ثم قال أما سمعت قولَ الشاعر: دَأْبَ شهرين ثم شهرًا دَمِيكا بأرِيكَين يَخْفِيان غَمِيرا؟{5}٤٢٤٧. (١٠/١٧٩) ٤٢٤٧ وجّه ابنُ عطية (٦/٨٤) هذه القراءة، فقال: «وقرأ ابن كثير والحسن وعاصم: (أكادُ أخْفِيها) بفتح الهمزة، بمعنى: أظهرها، أي: أنها من صحة وقوعها وتيقن كونها تكاد تظهر، لكن تنحجب إلى الأجل المعلوم، والعرب تقول: أخفيت الشيء، بمعنى: أظهرته». وانتقدها ابن جرير (١٦/٣٧) مستندًا لمخالفتها قراءة الحجة المستفيضةَ، فقال: «والذي ذُكِر عن سعيد بن جبير من قراءة ذلك بفتح الألف قراءةٌ لا أستجيز القراءة بها؛ لخلافها قراءة الحُجَّة التي لا يجوز خلافُها فيما جاءت به نقلًا مستفيضًا». <q>﴿إِنَّ ٱلسَّاعَةَ ءَاتِیَةٌ أَكَادُ أُخۡفِیهَا﴾</q> - تفسير الآية ٤٧٥٣٨- قال عبد الله بن مسعود: أكاد أخفيها من نفسي؛ فكيف يعلمها مخلوق؟!{6}. (ز) ٤٧٥٣٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إن الساعة آتية أكاد أخفيها﴾</q>، يقول: لا أُظْهِرُ عليها أحدًا غيري{7}. (١٠/١٧٨) ٤٧٥٤٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿إن الساعة آتية أكاد أخفيها﴾</q>، قال: أكاد أخفيها من نفسي{8}. (١٠/١٧٨) ٤٧٥٤١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿إن الساعة آتية أكاد أخفيها﴾</q>، قال: لا تأتيكم إلا بغتة{9}. (ز) ٤٧٥٤٢- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿أكاد أخفيها﴾</q>، قال: لقد أخفاها، إنِّي أكاد أُخفيها مِن نفسي{10}. (ز) ٤٧٥٤٣- عن مجاهد بن جبر -من طُرُق- في قوله: <q>﴿أكاد أخفيها﴾</q>، قال: من نفسي{11}. (١٠/١٧٨) ٤٧٥٤٤- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿أكاد أخفيها﴾</q>، قال: يخفيها مِن نفسه{12}. (١٠/١٧٩) ٤٧٥٤٥- عن الحسن البصري -من طريق عمرو بن عبيد- في قوله ﷿: <q>﴿أكاد أخفيها﴾</q>، قال: أخفيها مِن نفسي{13}. (ز) ٤٧٥٤٦- عن قتادة بن دعامة -من طريق سعيد- قال: في بعض القراءة: (أكادُ أُخْفِيها من نَّفْسِي)، قال: لَعَمْرِي، لقد أخفاها اللهُ مِن الملائكة المقربين، ومِن الأنبياء والمرسلين{14}٤٢٤٨. (١٠/١٧٩) ٤٢٤٨ علّق ابنُ كثير (٩/٣١٩) على قول قتادة بقوله: «وهذا كقوله تعالى: <q>﴿قل لا يعلم من في السماوات والأرض الغيب إلا الله﴾</q> [النمل:٦٥]، وقال: <q>﴿ثقلت في السماوات والأرض لا تأتيكم إلا بغتة﴾</q> [الأعراف:١٨٧]، أي: ثَقُل عِلْمُها على أهل السموات والأرض». ٤٧٥٤٧- عن قتادة بن دعامة -من طريق سعيد- قال: قضى الله -تبارك وتعالى- ألّا تأتيكم الساعةُ إلا بغتةً{15}. (ز) ٤٧٥٤٨- قال مقاتل بن سليمان: ثم استأنف <q>﴿إن الساعة آتية﴾</q> يقول: إن الساعة جائيةٌ لا بُدَّ، (أكادُ أُخْفِيها مِن نَّفْسِي) في قراءة ابن مسعود، فكيف يَعْلَمُها أحدٌ، وقد كدت أن أخفيها من نفسي؛ لِئَلّا يعلمَها مخلوق{16}. (ز) ٤٧٥٤٩- قال سفيان الثوري، في قوله: <q>﴿إن الساعة آتية أكاد أخفيها﴾</q>، أي: من نفسي{17}٤٢٤٩. (ز) ٤٢٤٩ اختلف السلف في تفسير قوله: <q>﴿أكاد أخفيها﴾</q> على قولين: الأول: أكاد أخفيها من نفسي، فلا أُظْهِر عليها أحدًا من خلقي. الثاني: أكاد أظهرها. وقد رجّح ابن جرير (١٦/٣٧-٣٨ بتصرف) مستندًا إلى أقوال السلف وإلى اللغة القول الأول، فقال: «والذي هو أولى بتأويل الآية من القول قولُ مَن قال: معناه: أكاد أخفيها مِن نفسي. لأن تأويل أهل التأويل بذلك جاء، ولأنّ المعروف من معنى الإخفاء في كلام العرب: الستر. يقال: قد أخفيت الشيء: إذا سترته، فلما كان معروفًا في كلامهم أن يقول أحدهم إذا أراد المبالغة في الخبر عن إخفائه شيئًا هو له مُسِرٌّ: قد كدت أن أخفي هذا الأمر عن نفسي مِن شدة استسراري به، ولو قدرت أخفيه عن نفسي أخفيته. خاطبهم على حسب ما قد جرى به استعمالُهم في ذلك من الكلام بينهم، وما قد عرفوه في منطقهم». وأمّا ابنُ عطية (٦/٨٦) فقد ذكر قولًا عن بعض المفسرين لم يُسمِّه، ورجّحه مستندًا إلى الدلالة العقلية، فقال: «وقالت فرقة: <q>﴿أكادُ﴾</q> على بابها، بمعنى أنها مقاربة ما لم يقع، لكن الكلام جارٍ على استعارة العرب ومجازها، فلما كانت الآية عبارة عن شدة خفاء أمر القيامة ووقتها، وكان القَطْع بإتيانها مع جهل الوقت أهيب على النفوس؛ بالغ قوله تعالى في إعتام وقتها، فقال: <q>﴿أكادُ أُخْفِيها﴾</q> حتى لا تظهر البتة، ولكن ذلك لا يقع، ولا بد من ظهورها، هذا تلخيص هذا المعنى الذي أشار إليه بعض المفسرين، وهو الأقوى عندي. ورأى بعضُ القائلين بأن المعنى: أكادُ أُخْفِيها من نفسي. ما في القول من القلق، فقالوا: معنى من نفسي: من تلقائي، ومن عندي، وهذا رفض للمعنى الأول، ورجوع إلى هذا القول الذي اخترناه أخيرًا. فتأمله». وذكر ابن جرير (١٦/٣٨-٤١) عدة أقوال أخر لم ينسبها إلى أحد، وكذا فعلَ ابنُ عطية، وانتقد هو وابن جرير بعضَ تلك الأقوال لمخالفتها لغة العرب، وقولَ الحجة من أهل التأويل، ودلالة العقل. ٤٧٥٥٠- قال يحيى بن سلّام: قوله: <q>﴿إن الساعة﴾</q>، يعني: القيامة{18}. (ز) <q>﴿لِتُجۡزَىٰ كُلُّ نَفۡسِۭ بِمَا تَسۡعَىٰ ۝١٥﴾</q> - تفسير ٤٧٥٥١- عن مجاهد بن جبر، في قوله: <q>﴿لتجزى كل نفس بما تسعى﴾</q>، قال: لِتُعْطى ثوابَ ما تعمل{19}. (١٠/١٧٩) ٤٧٥٥٢- قال مقاتل بن سليمان: <q>﴿لتجزى كل نفس﴾</q> يقول سبحانه: الساعة آتيةٌ لتجزى كلُّ نفس بَرٍّ وفاجر <q>﴿بما تسعى﴾</q> إذا جاءت الساعة، يعني: بما تعمل في الدنيا{16}. (ز) ٤٧٥٥٣- قال يحيى بن سلّام: إنما تجيء الساعة <q>﴿لتجزى كل نفس بما تسعى﴾</q> بما تعمل{21}. (ز) ",footnotes:1:أخرجه يحيى بن سلّام ١/٢٥٦. وهي قراءة شاذة، تروى أيضًا عن ابن مسعود، وابن عباس، والسدي. انظر: مختصر ابن خالويه ص٩٠، والمحتسب ٢/٤٧.أخرجه ابن الأنباري. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٩٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم، وابن الأنباري.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٧٢-، وابن جرير ١٦/٣٦ بنحوه عن وقاء بن إياس. وعزاه السيوطي إلى ابن أبي حاتم، وابن الأنباري، وفيه عن ورقاء. و(أخْفِيها) بفتح الألف قراءة شاذة. انظر: مختصر ابن خالويه ص ٩٠.تفسير البغوي ٥/٢٦٧.أخرجه ابن جرير ١٦/٣٤، وابن أبي حاتم -كما في الإتقان ٢/٢٧-.أخرجه يحيى بن سلّام ١/٢٥٥ من طريق عكرمة، وابن جرير ١٦/٣٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٣٤.أخرجه عبد الله بن وهب في الجامع ١/٤٢ (٨٦).أخرجه ابن جرير ١٦/٣٤-٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري في المصاحف.أخرجه ابن جرير ١٦/٣٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٣، مما رواه الهذيل بن حبيب عن غير مقاتل؛ فقد رواه الهذيل، عن صيفي بن سالم، عن عمرو بن عبيد، عن الحسن.أخرجه ابن جرير ١٦/٣٥، وعبد الرزاق ٢/١٦ مختصرًا من طريق معمر. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٥٦.تفسير مقاتل بن سليمان ٣/٢٤.أخرجه الثوري في تفسيره ص١٩٣.تفسير يحيى بن سلّام ١/٢٥٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.
20,16," <q>﴿فَلَا یَصُدَّنَّكَ عَنۡهَا مَن لَّا یُؤۡمِنُ بِهَا﴾</q> - تفسير ٤٧٥٥٤- قال مقاتل بن سليمان: <q>﴿فلا يصدنك عنها﴾</q> يا محمد٤٢٥٠، يعني: عن إيمان بالساعة <q>﴿من لا يؤمن بها﴾</q> يعني: مَن لا يُصَدِّق بها أنها كائنة{1}. (ز) ٤٢٥٠ ذكر ابنُ عطية (٦/٨٧) نحو هذا القول عن النقاش، وانتقده، فقال: «وقال النقاش: الخطاب بـ<q>﴿فَلا يَصُدَّنَّكَ﴾</q> لمحمد ﷺ، وهذا بعيدٌ». وبيّن أنّ الخطاب لموسى ﵇. ٤٧٥٥٥- قال يحيى بن سلّام: قوله: <q>﴿فلا يصدنك عنها﴾</q> عن الإيمان بها؛ بالساعة{2}٤٢٥١. (ز) ٤٢٥١ قال ابنُ عطية (٦/٨٦-٨٧): «والضمير في قوله: <q>﴿عَنْها﴾</q> يريد: عن الإيمان بالساعة. فأوقع الضمير عليها، ويحتمل أن يعود على الصَّلاةَ. وقالت فرقة: المراد: عن لا إله إلا الله. وهذا مُتَّجِهٌ، والأوَّلان أبيَنُ وجهًا». وذكر ابن جرير (١٦/٤١) قولًا أن الضمير في: <q>﴿عنها﴾</q> كناية عن مطلق، ولم يقيده بالإيمان بالساعة، ثم انتقده مستندًا إلى السياق، فقال: «وكان بعضُهم يزعم أن الهاء والألف من قوله: <q>﴿فلا يصدنك عنها﴾</q> كناية عن ذكر الإيمان، قال: وإنما قيل <q>﴿عنها﴾</q> وهي كناية عن الإيمان كما قيل: <q>﴿إن ربك من بعدها لغفور رحيم﴾</q> [الأعراف:١٥٣] يذهب إلى الفعلة، ولم يَجْرِ للإيمان ذكر في هذا الموضع، فيجعل ذلك من ذكره، وإنما جرى ذكر الساعة، فهو بأن يكون مِن ذكرها أوْلى». <q>﴿وَٱتَّبَعَ هَوَىٰهُ فَتَرۡدَىٰ ۝١٦﴾</q> - تفسير ٤٧٥٥٦- قال إسماعيل السُّدِّي: <q>﴿واتبع هواه﴾</q> يعني: شهوته؛ <q>﴿فتردى﴾</q> يقول: فتهلك{3}. (ز) ٤٧٥٥٧- قال مقاتل بن سليمان: <q>﴿واتبع هواه﴾</q>، ثم قال للنبي ﷺ: <q>﴿فتردى﴾</q> يعني: فتهلك إن صدُّوك عن الإيمان بالساعة. فيها تقديم{1}. (ز) ٤٧٥٥٨- قال يحيى بن سلّام: قوله: <q>﴿فتردى﴾</q> في النار، والتردِّي: التباعد مِن الله{2}. (ز) <q>﴿وَٱتَّبَعَ هَوَىٰهُ فَتَرۡدَىٰ ۝١٦﴾</q> - آثار متعلقة بالآية ٤٧٥٥٩- عن عامر الشعبي= (ز) ٤٧٥٦٠- وابن شبرمة، قالا: إنّما سُمِّي: هَوًى؛ لأنه يهوي بصاحبه إلى النار{6}. (١٠/١٨٠) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.علَّقه يحيى بن سلّام ١/٢٥٦.تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.عزاه السيوطي إلى ابن أبي حاتم.
20,17," <q>﴿وَمَا تِلۡكَ بِیَمِینِكَ یَـٰمُوسَىٰ ۝١٧﴾</q> - تفسير ٤٧٥٦١- قال مقاتل بن سليمان: ثم قال ﷿ في مخاطبته لموسى ﵇: <q>﴿وما تلك بيمينك ياموسى﴾</q>، يعني: عصاه كانت بيده اليمنى، قال ذلك لموسى ﵇، وهو يريد أن يُحَوِّلها حيَّة{1}. (ز) ٤٧٥٦٢- قال يحيى بن سلّام: قوله: <q>﴿وما تلك بيمينك يا موسى﴾</q> يسأله عن العصا التي في يده اليمنى وهو أعلم بها، <q>﴿قال﴾</q> موسى: <q>﴿هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.
20,18," <q>﴿قَالَ هِیَ عَصَایَ أَتَوَكَّؤُا۟ عَلَیۡهَا﴾</q> - تفسير ٤٧٥٦٣- قال مقاتل بن سليمان: <q>﴿قال﴾</q> موسى ﵇: <q>﴿هي عصاي أتوكأ عليها﴾</q> يقول: أعتمد عليها إذا مَشَيْتُ{1}. (ز) ٤٧٥٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</q>، قال: يتوكأ عليها حين يمشي مع الغنم{2}. (١٠/١٨١) <q>﴿وَأَهُشُّ بِهَا عَلَىٰ غَنَمِی﴾</q> - تفسير ٤٧٥٦٥- عن عمرو بن ميمون، في قوله: <q>﴿وأهش بها على غنمي﴾</q>، قال: الهشُّ: أن يخبط الرجل بعصاه الشجرَ فيتناثرُ الوَرَق{3}. (١٠/١٨١) ٤٧٥٦٦- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وأهش بها على غنمي﴾</q>، قال: أضرب بها الشجرَ حتى يسقط منه ما تأكلُ غنمي{4}. (ز) ٤٧٥٦٧- عن عكرمة مولى ابن عباس -من طريق يزيد النحوي- في قوله: <q>﴿وأهش بها على غنمي﴾</q>، قال: أضرب بها الشجرَ فيتساقط منه الوَرَق على غنمي{5}. (١٠/١٨٠) ٤٧٥٦٨- عن ميمون بن مهران، قال: الهشُّ: أن يُولِج العصا بين الشُّعْبَيْن{6}، ثم يحركها حتى يسقط الورق. والخبط: أن يخبط حتى يسقط الورق{3}. (١٠/١٨١) ٤٧٥٦٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأهش بها على غنمي﴾</q>، قال: أخبط بها الشجر{8}. (١٠/١٨١) ٤٧٥٧٠- عن إسماعيل السُّدِّي -من طريق أسباط- <q>﴿وأهش بها على غنمي﴾</q>، يقول: أضرب بها الشجر للغنم، فيقع الوَرَق{9}. (ز) ٤٧٥٧١- قال مقاتل بن سليمان: <q>﴿وأهش بها على غنمي﴾</q>، يقول: أخبط بها الشجر فَيَتَهاشُّ الوَرَق في الأرض، فتأكله غنمي إذا رعيتها. وكانت صغارًا لا تَعْلُوَنَّ الشجر، وكان موسى ﵇ يضرب بعصاه الشجر فَيَتَهاشَّ الورقُ في الأرض، فتأكله غنمه{1}. (ز) ٤٧٥٧٢- عن مالك بن أنس، قال: الهشُّ أن يضع الرجل المحجن{11} في الغُصْن، ثم يحركه حتى يسقط ورقُه وثمره، ولا يكسر العود، فهذا الهش، ولا يخبط{3}. (١٠/١٨١) ٤٧٥٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</q>، قال: يَتَوَكَّأ عليها حين يمشي مع الغنم، ويَهُشُّ بها؛ يُحَرِّك الشجر حتى يسقط الورق؛ الحَبَلَة{13} وغيرها{2}. (١٠/١٨١) <q>﴿وَلِیَ فِیهَا مَـَٔارِبُ أُخۡرَىٰ ۝١٨﴾</q> - تفسير ٤٧٥٧٤- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿ولي فيها مآرب أخرى﴾</q>، قال: حَوائِج{15}. (١٠/١٨١) ٤٧٥٧٥- عن عبد الله بن عباس -من طريق قتادة-: عصا موسى. قال: أعطاه إيّاها ملَك مِن الملائكة إذ توجه إلى مدين، فكانت تُضيء له بالليل، ويضرب بها الأرضَ فيخرج له النبات، ويهش بها على غنمه ورق الشجر{16}. (١٠/١٨٠) ٤٧٥٧٦- عن عبد الله بن عباس: أنّ موسى كان يحمل عليها زادَه وسقاءه، فجعلت تُماشِيه وتحدِّثه، وكان يضرب بها الأرض فيخرج ما يأكل يَوْمَه، ويركزها فيخرج الماء، فإذا رفعها ذهب الماء، وإذا اشتهى ثمرة ركزها فَتَغَصَّنَتْ غصن الشجرة، وأورقت وأثمرت، وإذا أراد الاستقاء مِن البئر أدلاها، فطالَتْ على طول البئر، وصارت شُعْبَتاها كالدَّلْو حتى يَسْتَقِي، وكانت تُضِيء بالليل بمنزلة السِّراج، وإذا ظهر له عدوٌّ كانت تُحارب وتُناضِل عنه، فهذه المآرب{17}. (ز) ٤٧٥٧٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿مآرب أخرى﴾</q>، قال: حاجات ومنافع{18}. (١٠/١٨٢) ٤٧٥٧٨- عن الضحاك بن مزاحم، في قوله: <q>﴿مآرب أخرى﴾</q>، قال: حاجات أخرى{19}. (ز) ٤٧٥٧٩- عن وهب بن منبه -من طريق ابن إسحاق- <q>﴿ولي فيها مآرب أخرى﴾</q>: أي: منافع أخرى{19}. (ز) ٤٧٥٨٠- عن وهب بن منبه -من طريق عبد الصمد بن معقل- قال: ... كان لموسى في العصا مآرب، كان لها شعبتان، ومِحْجَنٌ تحت الشعبتين، فإذا طال الغُصْنُ حناه بالمِحْجَنِ، وإذا أراد كسره لواه بالشعبتين، وكان يتوكَّأُ عليها، ويَهُشُّ بها، وكان إذا شاء ألقاها على عاتقه، فعلق بها قوسه وكِنانَتَه ومِرْجامَه{21} ومِخْلاته{22} وثوبه وزادًا -إن كان معه-، وكان إذا أرْتَع في البَرِّيَّة حيث لا ظِلَّ له رَكَزَها، ثم عرَض بالوتد بين شعبتيها، وألقى فوقها كِساءه، فاستظلَّ بها ما كان مُرْتِعًا، وكان إذا ورد ماء يَقْصُر عنه رِشاؤُه{23} وصل بها، وكان يقاتل بها السِّباع عن غنمه{24}. (١٠/١٦٣-١٧٠) ٤٧٥٨١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولي فيها مآرب أخرى﴾</q>، قال: حاجات أخرى؛ منافع أخرى{25}. (١٠/١٨١) ٤٧٥٨٢- عن قتادة بن دعامة، في قوله: <q>﴿ولي فيها مآرب أخرى﴾</q>، قال: كانت تُضِيء له بالليل، وكانت عصا آدم ﵇{3}٤٢٥٢. (١٠/١٨٢) ٤٢٥٢ انتقد ابنُ كثير (٩/٣٢٠) مستندًا إلى الدلالة العقلية ما جاء في شأن عصا موسى مِن الأمور الخارقة، فقال: «وقد تكلَّف بعضُهم لذِكْرِ شيء من تلك المآرب التي أُبْهِمَتْ، فقيل: كانت تضيء له بالليل، وتحرس له الغنم إذا نام، ويغرسها فتصير شجرة تُظِلُّه، وغير ذلك من الأمور الخارقة للعادة. والظاهر أنها لم تكن كذلك، ولو كانت كذلك لما استنكر موسى صيرورتها ثعبانًا، فما كان يَفِرُّ منها هاربًا، ولكن كل ذلك من الأخبار الإسرائيلية. وكذا قول بعضهم: إنها كانت لآدم ﵇. وقول الآخر: إنها هي الدابة التي تخرج قبل يوم القيامة». ٤٧٥٨٣- عن إسماعيل السُّدِّي، في قوله: <q>﴿مآرب أخرى﴾</q>، يقول: حوائج أخرى، أحمل عليها المِزْوَد{27}، والسِّقاء{28}. (١٠/١٨٢) ٤٧٥٨٤- قال مقاتل بن سليمان: <q>﴿ولي فيها﴾</q> يعني: في العصا <q>﴿مآرب أخرى﴾</q> يعني: حوائج أخرى، وكان موسى ﵇ يحمل زادَه وسِقاءَه على عصاه، ويضرب الأرض بعصاه فيخرج ما يأكل يومه، ويركزها في الأرض فيخرج الماء، فإذا رفعها ذهب الماء، وتُضِيء بالليل في غير قَمَرٍ ليهتدي بها، ويرد بها غنمه عليه، فتقيه بإذن الله ﷿ مِن الآفات، ويقتل بها الحيّات والعقارب بإذن الله ﷿{1}. (ز) ٤٧٥٨٥- قال سفيان الثوري، في قوله: <q>﴿ولي فيها مآرب أخرى﴾</q>: حاجات أخرى{30}. (ز) ٤٧٥٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولي فيها مآرب أخرى﴾</q>، قال: حوائج أخرى سوى ذلك{31}. (ز) ٤٧٥٨٧- قال يحيى بن سلّام: بلغني: أنّ مِن تلك الحوائج الأخرى: أنه كان يستَظِلُّ بها{32}. (ز) <q>﴿وَلِیَ فِیهَا مَـَٔارِبُ أُخۡرَىٰ ۝١٨﴾</q> - آثار متعلقة بالآية ٤٧٥٨٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: كان اسمُ عصا موسى: ماشا{33}. (ز) ٤٧٥٨٩- عن سعيد بن جبير -من طريق جعفر- قال: كان اسم عصا موسى ﵇: يوشا{34}. (ز) ٤٧٥٩٠- عن سعيد بن جبير، قال: كانت عصا موسى ﵇ مِن عَوْسَج{35}. (ز) ٤٧٥٩١- عن أبي بكر، قال: سألتُ عكرمة، قال: أمّا عصا موسى فإنها خرج بها آدمُ من الجنة، ثم قبضها بعد ذلك جبرائيل ﵇، فلَقِي موسى بها ليلًا، فدفعها إليه{36}. (ز) ٤٧٥٩٢- عن إسماعيل السُّدِّي -من طريق أسباط- قال: ... فلما أتى الشيخَ، وقصَّ عليه القصص، قال: <q>﴿لا تخف نجوت من القوم الظالمين﴾</q>. فأمر إحدى ابنتيه أن تأتيه بعصا، وكانت تلك العصا عصًا استودعه إياها ملَك في صورة رجل، فدفعها إليه، فدخلت الجاريةُ، فأخذت العصا، فأتته بها، فلما رآها الشيخُ قال لابنته: ائتيه بغيرها. فألقتها، وأخذت تريد أن تأخذ غيرها، فلا يقع في يدها إلا هي، وجعل يَرْدُدُها، وكل ذلك لا يخرج في يدها غيرها، فلمّا رأى ذلك عهد إليه، فأخرجها معه، فرعى بها، ثم إنّ الشيخ ندِم، وقال: كانت وديعة. فخرج يتلقى موسى، فلما رآه قال: أعطني العصا. فقال موسى: هي عصاي. فأبى أن يعطيه، فاختصما، فرضيا أن يجعلا بينهما أولَ رجل يلقاهما، فأتاهما ملَك يمشي، فقضى بينهما، فقال: ضَعوها في الأرض، فمن حملها فهي له. فعالجها الشيخ فلم يُطِقْها، وأخذها موسى ﵇ بيده فرفعها، فتركها له الشيخ{37}. (١١/٤٤٣) ٤٧٥٩٣- عن محمد بن السائب الكلبي -من طريق معمر- قال: كان عصا موسى مِن عَوسَج{38}. (ز) ٤٧٥٩٤- قال مقاتل بن سليمان: دفع جبريلُ ﵇ العصا إلى موسى ﵇، وهو مُتَوَجِّه إلى مَدْيَن بالليل، واسم العصا: نفعه{39}. (ز) ٤٧٥٩٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: قال -يعني: أبا الجارية لَمّا زوجها موسى- لموسى: ادخل ذلك البيت، فخذ عصًا، فتَوَكَّأ عليها. فدخل، فلما وقف على باب البيت طارت إليه تلك العصا، فأخذها، فقال: ارْدُدْها، وخذ أخرى مكانها. قال: فردَّها، ثم ذهب ليأخذ أخرى، فطارت إليه كما هي، فقال: لا، ارْدُدْها. حتى فعل ذلك ثلاثًا، فقال: ارْدُدْها. فقال: لا آخذ غيرها اليوم. فالتفت إلى ابنته، فقال: يا بُنَيَّة، إنّ زوجك لَنَبِيٌّ{36}. (ز) ٤٧٥٩٦- عن مسلم -من طريق حبيب بن حسان- قال: عصا موسى هي الدابَّة مِن دابَّة الأرض{41}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.أخرجه ابن جرير ١٦/٤٣. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٤٤.أخرجه إسحاق البستي في تفسيره ص٢٣٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.الشعبان: الغصنان. اللسان (شعب).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٤٣، وعبد الرزاق ٢/١٦ من طريق معمر. وعلَّقه يحيى بن سلّام ١/٢٥٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٤٣.تفسير مقاتل بن سليمان ٣/٢٤.المِحْجَن: عصا مُعَقَّفَة الرأس كالصولجان. النهاية (حجن).عزاه السيوطي إلى ابن أبي حاتم.الحَبَلَة- بفتح الحاء والباء، وربما سُكِّنِت-: الأصل، أو القضيب من شجر الأعناب. النهاية (حبل).أخرجه ابن جرير ١٦/٤٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٣٦، وابن أبي حاتم -كما في التغليق ٣/١٤٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٧.تفسير الثعلبي ٦/٢٤٢، وتفسير البغوي ٥/٢٦٩.أخرجه ابن جرير ١٦/٤٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٤٦.أخرجه ابن جرير ١٦/٤٦.المِرْجامُ: الَّذِي تُرْجَمُ بِهِ الحِجارَةُ. اللسان (رجم).المِخلاة: ما يُجعل فيه الخلا، وهو علف الدابة الرطب. مختار الصحاح، ولسان العرب (خلا).الرِشاء: الحبل الذي يربط به الدلو ليتوصل به إلى الماء. النهاية (رشا).أخرجه أحمد في الزهد ص٦١-٦٦، وابن أبي حاتم ٩/٢٨٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلّام ١/٢٥٦ من طريق سعيد، وابن جرير ١٦/٤٦. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.المِزْوَد: الوعاء الذي يوضع فيه الشيء. غريب الحديث للحربي (زاد)أخرجه ابن جرير ١٦/٤٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٢٤.أخرجه الثوري في تفسيره ص١٩٣.أخرجه ابن جرير ١٦/٤٧.تفسير يحيى بن سلّام ١/٢٥٦.أخرجه ابن أبي حاتم ٨/٢٨٤٨ (١٦١٤٢).أخرجه إسحاق البستي في تفسيره ص٢٣٥.أخرجه ابن أبي حاتم ٨/٢٨٤٨ (١٦١٤٣).أخرجه ابن جرير ١٨/٢٣٣.أخرجه ابن جرير ١٨/٢٣٣، وابن أبي حاتم ٨/٢٩٦١، ٢٩٦٥.أخرجه عبد الرزاق ٢/٩١.تفسير مقاتل بن سليمان ٣/٢٥.أخرجه ابن جرير ١٨/٢٣٣.أخرجه ابن أبي حاتم ٩/٢٩٧٤.
20,19," <q>﴿قَالَ أَلۡقِهَا یَـٰمُوسَىٰ ۝١٩ فَأَلۡقَىٰهَا فَإِذَا هِیَ حَیَّةࣱ تَسۡعَىٰ ۝٢٠ قَالَ خُذۡهَا وَلَا تَخَفۡۖ﴾</q> - تفسير ٤٧٥٩٧- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿فألقاها فإذا هي حية تسعى﴾</q>: ولم تكن قبل ذلك حيَّة، فمرَّت بشجرةٍ فأكلتها، ومرت بصخرة فابتلعتها، فجعل موسى يسمع وقْعَ الصخرة في جوفها، فوَلّى مُدْبِرًا، فنودي: أن يا موسى، خُذها. فلم يأخذها، ثم نودي الثانية: أن خذها، ولا تخف. فقيل له في الثالثة: إنّك من الآمنين. فأخذها{1}. (١٠/١٨٢) ٤٧٥٩٨- عن وهب بن مُنَبِّه -من طريق ابن إسحاق-: <q>﴿قال ألقها يا موسى فألقاها فإذا هي حية تسعى﴾</q> تَهْتَزُّ، لها أنيابٌ وهيئةٌ كما شاء الله أن تكون، فرأى أمرًا فظيعًا، فوَلّى مدبرًا ولم يُعَقِّب، فناداه ربُّه: يا موسى، أقبل ولا تخف <q>﴿سنعيدها سيرتها الأولى﴾</q>{2}. (ز) ٤٧٥٩٩- عن قتادة بن دعامة -من طريق سعيد- قال: فإذا هي حيَّة أشْعَر ذَكَر{3}. (ز) ٤٧٦٠٠- عن إسماعيل السُّدِّي -من طريق أسباط- قال: قال له -يعني: لموسى- ربُّه: <q>﴿ألقها يا موسى﴾</q> يعني: عصاه، <q>﴿فألقاها فإذا هي حية تسعى﴾</q>، <q>﴿فلما رآها تهتز كأنها جان ولى مدبرا ولم يعقب﴾</q> فنودي: <q>﴿يا موسى لا تخف إني لا يخاف لدي المرسلون﴾</q> [النمل:١٠]{4}. (ز) ٤٧٦٠١- عن مالك بن دينار -من طريق أبي جعفر- قال: بلغني: أنّه كان بين لحيي عصا موسى حين عادت حيَّةً خمسون ذراعًا{5}. (ز) ٤٧٦٠٢- قال مقاتل بن سليمان: <q>﴿قال﴾</q> الله ﷿: <q>﴿ألقها يا موسى فألقاها﴾</q> مِن يده اليُمْنى <q>﴿فإذا هي حية تسعى﴾</q> على بطنها؛ ذكرًا أشعر، له عُرف، فخاف موسى ﵇ أن يأخذها، فـ<q>﴿قال﴾</q> له ربه ﷿: <q>﴿خذها ولا تخف﴾</q> منها{6}. (ز) ٤٧٦٠٣- قال محمد بن إسحاق: نظر موسى، فإذا العصا حيَّةٌ مِن أعظم ما يكون مِن الحيّات، صارت شعبتاها شِدْقَين لها، والمحجن عنقًا وعرفًا، تهتز كالنيازك، وعيناها تَتَّقِدان كالنار، تمرُّ بالصخرة العظيمة مثل الخَلِفَة{7} مِن الإبل فَتَلْقَمُها، وتَقْصِف الشجرة العظيمة بأنيابها، ويسمع لأسنانها صَريفٌ عظيم. فلما عاين ذلك موسى ولّى مُدبرًا وهرب، ثم ذكر ربَّه، فوقف استحياءً منه، ثم نودي: أن يا موسى، أقبِل وارجع حيث كنت. فرجع وهو شديد الخوف{8}. (ز) ٤٧٦٠٤- قال يحيى بن سلّام: <q>﴿تسعى﴾</q>، أي: تزحف على بطنها بسرعة{9}. (ز) <q>﴿سَنُعِیدُهَا سِیرَتَهَا ٱلۡأُولَىٰ ۝٢١﴾</q> - تفسير ٤٧٦٠٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿سنعيدها سيرتها الأولى﴾</q>، قال: حالتها الأولى{10}. (١٠/١٨٢) ٤٧٦٠٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿سنعيدها سيرتها الأولى﴾</q>، قال: هيئتها الأولى{11}. (١٠/١٨٢) ٤٧٦٠٧- عن وهب بن مُنَبِّه -من طريق ابن إسحاق- <q>﴿سنعيدها سيرتها الأولى﴾</q>: أي: سَنَرُدُّها عصًا كما كانت{2}. (ز) ٤٧٦٠٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿سنعيدها سيرتها الأولى﴾</q>، قال: إلى هيئتها الأولى{13}. (ز) ٤٧٦٠٩- قال مقاتل بن سليمان: <q>﴿سنعيدها سيرتها الأولى﴾</q>، يعني: سنعيدها عصًا كهيئتها الأولى عصًا، كما كانت أول مرة، فأهوى موسى بيده إلى ذَنَبِها، فقَبَض عليها، فصارت عصًا كما كانت{6}. (ز) ٤٧٦١٠- قال يحيى بن سلّام: قوله: <q>﴿قال خذها ولا تخف سنعيدها سيرتها الأولى﴾</q> عصًا{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٤٧، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٧٤-.أخرجه ابن جرير ١٦/٤٧.أخرجه يحيى بن سلّام ١/٢٥٧.أخرجه ابن جرير ١٦/٤٦.أخرجه عبد الرزاق ٢/١٦.تفسير مقاتل بن سليمان ٣/٢٥.الخَلِفَة- بفتح الخاء وكسر اللام-: الحامل مِن النوق. النهاية (خلف).تفسير البغوي ٥/٢٦٩.تفسير يحيى بن سلّام ١/٢٥٦.أخرجه ابن جرير ١٦/٤٨، وابن أبي حاتم -كما في الإتقان ٢/٢٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلّام ١/٢٥٧ من طريق ابن مجاهد، وابن جرير ١٦/٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٤٧.أخرجه يحيى بن سلّام ١/٢٥٧، وابن جرير ١٦/٤٧.تفسير مقاتل بن سليمان ٣/٢٥.أخرجه يحيى بن سلّام ١/٢٥٧.
