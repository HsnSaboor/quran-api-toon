quran[25]{c,v,t}:
  20,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَا ٱخۡتَرۡتُكَ فَٱسۡتَمِعۡ لِمَا یُوحَىٰۤ ۝١٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٠٩<span class="dash">-</span></span> عن الأعمش: قال في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: <span class="qpc-hafs">﴿وأنا اخترتك فاستمع لما يوحى﴾</span>: ›اخْتَرْناكَ‹{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَا ٱخۡتَرۡتُكَ فَٱسۡتَمِعۡ لِمَا یُوحَىٰۤ ۝١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنا اخترتك﴾</span> يا موسى للرسالة؛ <span class="qpc-hafs">﴿فاستمع لما يوحى﴾</span> يعني: للذي يوحى إليك. والوحيُ ما ذكر الله ﷿: <span class="qpc-hafs">﴿إنني أنا الله لا إله إلا أنا﴾</span>...= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥١١<span class="dash">-</span></span> عن علقمة بن مرثد عن <span class="name-2">كعب [الأحبار]</span>: أنّ موسى ﵇ كلَّمه ربُّه مرَّتين، ورأى محمدٌ ﷺ ربَّه جلَّ جلاله مرتين، وعصى آدم ﵇ ربَّه تعالى مرتين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأنا اخترتك﴾</span> أي: لرسالتي ولكلامي؛ <span class="qpc-hafs">﴿فاستمع لما يوحى﴾</span> إليك{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الثوري في تفسيره ص١٩٣.</p><p>و‹اخْتَرناكَ› قراءة حمزة، وقرأ البقية: <span class="qpc-hafs">﴿اخترتك﴾</span>. انظر: النشر ٢/٣٢٠.تفسير مقاتل بن سليمان ٣/٢٣.تفسير يحيى بن سلّام ١/٢٥٤.
  20,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّنِیۤ أَنَا ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدۡنِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله سبحانه: <span class="qpc-hafs">﴿فاعبدني﴾</span>، يعني: فوَحِّدني، فإنّه ليس معي إله{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّنِیۤ أَنَا ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدۡنِی﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥١٤<span class="dash">-</span></span> عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «<b>مكتوبٌ على باب الجنة: إنّني أنا الله لا إله إلا أنا، لا أُعَذِّب مَن قالها</b>»{2}. (١٠/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥١٥<span class="dash">-</span></span> عن علي بن أبي طالب، قال: حدَّثنا رسولُ الله ﷺ عن جبريل ﵇، قال: «<b>قال الله ﷿: إنِّي أنا الله لا إله إلا أنا فاعبدني، مَن جاءني منكم بشهادة أن لا إله إلا الله بالإخلاص دخل حِصْنِي، ومَن دخل حِصْنِي أمِنَ عذابي</b>»{3}. (١٠/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥١٦<span class="dash">-</span></span> عن محمد بن أعْيَن، قال: قلتُ لابن المبارك: إنّ فلانًا يقول: مَن زعم أنّ قول الله تعالى: <span class="qpc-hafs">﴿إنني أنا الله لا إله إلا أنا فاعبدني﴾</span> مخلوق؛ فهو كافر. فقال <span class="name-3">ابنُ المبارك</span>: صَدَق{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ ۝١٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٧٥١٧<span class="dash">-</span></span> قال يونس: وكان <span class="name-2">ابن شهاب</span> يقرؤها: (لِلذِّكْرى){5}. (١٠/١٧٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ ۝١٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥١٨<span class="dash">-</span></span> عن قتادة، عن أنس بن مالك، أنّ رسول الله ﷺ قال: «<b>إذا رقد أحدُكم عن الصلاة، أو غفل عنها؛ فلْيُصَلِّها إذا ذكرها؛ فإنّ الله قال</b>: <span class="qpc-hafs">﴿أقم الصلاة لذكري﴾</span>»{6}. (١٠/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥١٩<span class="dash">-</span></span> عن أبي هريرة: أنّ رسول الله ﷺ حين قَفَل مِن غزوة خيبر سار ليلَه، حتى إذا أدركه الكرى عَرَّس{7}، وقال لبلال: «<b>اكْلَأ لنا الليلَ</b>». فصلّى بلالٌ ما قُدِّر له، ونام رسول الله ﷺ وأصحابه، فلما تقارب الفجرُ استند بلالٌ إلى راحلته مُواجِهَ الفجر، فغلبت بلالًا عيناه وهو مُسْتَنِدٌ إلى راحلته، فلم يستيقظ رسولُ الله ﷺ، ولا بلال، ولا أحد من أصحابه حتى ضربتهم الشمس، فكان رسول الله ﷺ أولهم استيقاظًا، ففزِع رسول الله ﷺ، فقال: «<b>أي بلالُ</b>». فقال بلال: أخذ بنفسي الذي أخذ -بأبي أنت وأمي يا رسول الله- بنفسك. قال: «<b>اقْتادوا</b>». فاقتادوا رواحلَهم شيئًا، ثم توضأ رسول الله ﷺ، وأمر بلالًا، فأقام الصلاة، فصلّى بهم الصبح، فلما قضى الصلاةَ قال: «<b>مَن نسي الصلاةَ فلْيُصَلِّها إذا ذكرها</b>». فإنّ الله قال: <span class="qpc-hafs">﴿أقم الصلاة لذكري﴾</span>... {8}. (١٠/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٠<span class="dash">-</span></span> عن عبادة بن الصامت، قال: سُئِل رسولُ الله ﷺ عن رجل غَفِلَ عن الصلاة حتى طلعت الشمس أو غربت، ما كفارتها؟ قال: «<b>يتقرَّب إلى الله، ويحسن وضوءه، ويصلي فيحسن الصلاة، ويستغفر الله، فلا كفارة لها إلا ذلك. إن الله يقول</b>: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>»{9}. (١٠/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢١<span class="dash">-</span></span> عن سعيد بن المسيب، أنّ رسول الله ﷺ قال: «<b>مَن نَسِي صلاةً فلْيُصَلِّها إذا ذكرها؛ فإنّ الله ﷿ يقول</b>: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>»{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٢<span class="dash">-</span></span> عن سمرة بن يحيى، قال: نسيتُ صلاة العتمة حتى أصبحتُ، فغدوتُ إلى <span class="name-1">ابن عباس</span>، فأخبرته، فقال: قُمْ، فَصَلِّها. ثم قرأ: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>{11}. (١٠/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>، في قوله: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>، قال: حين تَذْكُرُ{12}. (١٠/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٥<span class="dash">-</span></span> و<span class="name-2">عامر الشعبي</span>، في قوله: <span class="qpc-hafs">﴿أقم الصلاة لذكري﴾</span>، قالا: صَلِّها إذا ذكرتَها وقد نسيتَها{13}. (١٠/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- قال: مَن نام عن صلاةٍ أو نسيها يُصَلِّي متى ذكرها، عند طلوع الشمس وعند غروبها. ثم قرأ: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>. قال: إذا ذكرتها فصَلِّها في أيِّ ساعة كنتَ{14}. (١٠/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>، قال: إذا صلّى عبدٌ ذَكَرَ ربَّه{15}. (١٠/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: إذا تركتَ الصلاة ثم ذكرتَها فأقِمْها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال تعالى: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span>، يقول: لتذكُرَني بها، يا موسى{1}<span class=comment-ref>٤٢٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٤٦</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span> على أقوال: <b>الأول</b>: أقِم الصلاة حين تذكرها. <b>الثاني</b>: أقم الصلاة لتذكرني بها. <b>الثالث</b>: أقم الصلاة لأذكرك بها. فعلى القول الأول تكون اللام وقتية، وعلى القولين الآخرين تكون اللام سببية كما <span class="comment-type-4">ذكرَ</span> <u>ابنُ عطية</u> (٦/٨٣)، و<u>ابنُ القيم</u> (٢/١٧٩).</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابن جرير</u> (١٦/٣٣ بتصرف) <span class="mustanad">مستندًا إلى ظاهر لفظ الآية</span> القول الثاني، فقال: «وأولى التأويلين في ذلك بالصواب تأويلُ مَن قال: معناه: أقم الصلاة لتذكرني فيها؛ لأن ذلك أظهر معنييه، وفي قوله: <span class="qpc-hafs">﴿لذكري﴾</span> دلالة بينة على صحة ذلك».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ القيم</u> (٢/١٧٩)، و<span class="comment-type-4">بيّن</span> أن هذا القول يستلزم القولين الآخرين.</p><p>و<span class="comment-type-3">قوّى</span> <u>ابنُ كثير</u> (٩/٣١٧-٣١٨ بتصرف) القول الأول بقوله: «ويشهد لهذا القول ما رواه الإمام أحمد ... عن أنس، عن النبي ﷺ، قال: «<b>إذا رقد أحدكم عن الصلاة، أو غفل عنها، فليصلها إذا ذكرها؛ فإن الله تعالى قال: <span class="qpc-hafs">﴿وأقم الصلاة لذكري﴾</span></b>». وفي الصحيحين عن أنس قال: قال رسول الله ﷺ: «<b>من نام عن صلاة أو نسيها، فكفارتها أن يصليها إذا ذكرها، لا كفارة لها إلا ذلك</b>»».</p><p>و<span class="comment-type-2">استدرك</span> <u>ابن جرير</u> <span class="mustanad">مستندًا لظاهر لفظ الآية</span> على هذا القول، فقال: «ولو كان معناه: حين تذكرها؛ لكان التنزيل: أقم الصلاة لذكركها».</p><p>وكذا <span class="comment-type-2">استدرك</span> <u>ابنُ القيم</u> <span class="mustanad">مستندًا إلى اللغة</span> ... وذكر أن تفسير الآية به فيه نظر؛ «لأن اللام الوقتية يليها أسماء المكان والظروف، والذِّكْرُ مصدر، إلا أن يقدر زمان محذوف: أي عند وقت ذكري، وهذا محتمل».</div></p><p><h3><span class="qpc-hafs">﴿وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٣٠<span class="dash">-</span></span> عن أبي جُحَيْفَة، قال: كان رسول الله ﷺ في سفره الذي ناموا فيه حتى طلعت الشمس، ثم قال: «<b>إنّكم كنتم أمواتًا، فردَّ الله إليكم أرواحَكم، فمَن نام عن الصلاة أو نسي صلاة فليُصَلِّها إذا ذكرها، وإذا استيقظ</b>»{18}. (١٠/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣١<span class="dash">-</span></span> عن أنس بن مالك، قال: خرج عمرُ بنُ الخطاب مُتَقَلِّدًا بالسيف، فلقِيَهُ رجلٌ مِن بني زُهْرَة، فقال له: أين تغدو، يا عمر؟ قال: أريد أن أقتل محمدًا. قال: وكيف تأمن بني هاشم وبني زُهْرَة؟ فقال له عمر: ما أراك إلا قد صَبَأتَ وتركت دينك! قال: أفلا أدُلُّك على العجب؟ إنّ أختك وخَتَنَك قد صَبَوا وتركا دينك. فمشى عمرُ ذامِرًا حتى أتاهما وعندهما خَبّابٌ، فلما سمع خبّاب بحِسِّ عمر توارى في البيت، فدخل عليهما، فقال: ما هذه الهَيْنَمَةُ{19} التي سمعتها عندكم؟ وكانوا يقرأون طه، فقالا: ما عدا حديثًا تحدَّثنا به. قال: فلعلَّكما قد صَبَوتُما. فقال له خَتَنُه: يا عمر، إن كان الحق في غير دينك؟ فوَثَب عمرُ على خَتَنِه، فوَطِئه وطأ شديدًا، فجاءت أختُه لتدفعه عن زوجها، فنَفَحَها نَفَحَة بيده، فدمّى وجهَها، فقال عمر: أعطُوني الكتابَ الذي هو عندكم فأقرأه. فقالت أختُه: إنّك رجس، وإنّه لا يمسه إلا المطهرون، فقم فتوضأ. فقام فتوضأ، ثم أخذ الكتاب، فقرأ: <span class="qpc-hafs">﴿طه﴾</span> حتى انتهى إلى <span class="qpc-hafs">﴿إنني أنا الله لا إله إلا أنا فاعبدني وأقم الصلاة لذكري﴾</span>. فقال عمر: دُلُّوني على محمد. فلما سمع خبّابٌ قولَ عمر خرج من البيت، فقال: أبشِر، يا عمر، فإنِّي أرجو أن تكون دعوةَ رسول الله ﷺ لك ليلة الخميس: «<b>اللَّهُمَّ، أعِزَّ الإسلامَ بعمر بن الخطاب، أو بعمرو بن هشام</b>». فخرج حتى أتى رسول الله ﷺ، فأسلم{20}. (١٠/١٧٣-١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: إذا نسيتَ صلاةً فاقْضِها متى ما ذكرتَ{12}. (١٠/١٧٧)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.عزاه السيوطي إلى أبي الشيخ.أخرجه أبو نعيم في الحلية ٣/١٩٢، والشجري في ترتيب الأمالي ١/٥٤-٥٥ (١٨٥).</p><p>قال أبو نعيم: «هذا حديث ثابت مشهور بهذا الإسناد من رواية الطاهرين عن آبائهم الطيبين». وقال الألباني في الضعيفة ٩/٣٧ (٤٠٣٧): «ضعيف».أخرجه ابن عساكر في تاريخ دمشق ٧١/١٧١. وتوضيح ذلك فيما رواه إسحاق البستي في تفسيره ص٢٣٢ عن قتيبة بن سعيد: مَن قال: قوله: يا موسى <span class="qpc-hafs">﴿إنني أنا الله لا إله إلا أنا فاعبدني﴾</span> مخلوق؛ فهو كافر، وما كان الله -تبارك وتعالى- ليأمر محمدًا ﷺ بعبادة مخلوق.أخرجه مسلم ١/٤٧١ (٦٨٠).</p><p>وقراءة ابن شهاب شاذة. ينظر: مختصر الشواذ لابن خالويه ص٩٠.أخرجه البخاري ١/١٢٢ (٥٩٧)، ومسلم ١/٤٧٧ (٦٨٤). وعزاه السيوطي إلى عبد بن حميد وابن مردويه.</p><p>قال الحافظ في الفتح ٢/٧٢: وقد اختُلِف في ذكر هذه الآية هل هي مِن كلام قتادة أو هي من قول النبي ﷺ، وفي رواية مسلم عن هداب قال قتادة: <span class="qpc-hafs">﴿وأقم الصلاة لذكرى﴾</span>. وفي روايته من طريق المثنى عن قتادة: قال رسول الله ﷺ: «<b>إذا رقد أحدكم عن الصلاة أو غفل عنها فليصلها إذا ذكرها، فإن الله يقول: <span class="qpc-hafs">﴿أقم الصلاة لذكري﴾</span></b>». وهذا ظاهر أن الجميع من كلام النبي ﷺ.التَّعْرِيس: نُزول المُسافر آخِرَ اللّيل نَزْلَةً للنَّوم والاسْتراحَة. النهاية (عرس).أخرجه مسلم ١/٤٧١ (٦٨٠).أخرجه الطبراني في الكبير -كما في مجمع الزوائد ١/٣٢٣ (١٨١٠)-.</p><p>وقال الهيثمي: «فيه إسحاق بن يحيى، ولم يسمع من عبادة، ولم يرو عنه غير موسى بن عقبة».أخرجه يحيى بن سلّام ١/٢٥٥، والشافعي في مسنده ١/٢٣٠ (١٥١)، وعبد الرزاق في مصنفه ٢/٣ (٢٢٤٥)، وفي تفسيره ٢/٣٧٠ (١٨٠٦).عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن أبي شيبة ٢/٦٥.أخرجه يحيى بن سلّام ١/٢٥٥ من طريق ابن مجاهد، وابن جرير ١٦/٣٢ من طريق ابن أبي نَجِيح وابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٢٦٧.تفسير مقاتل بن سليمان ٣/٢٤.أخرجه ابن أبي شيبة ١/٤١١-٤١٢ (٤٧٣٨)، ٧/٢٨١-٢٨٢ (٣٦٠٩٧)، وأبو يعلى ٢/١٩٢، من طريق عبد الجبار بن العباس الهمداني، عن عون بن أبي جحيفة، عن أبيه به.</p><p>قال العقيلي في الضعفاء ٣/٨٨: «لا يحفظ من حديث أبي جحيفة إلا عن هذا الشيخ، وقد روي هذا عن أبي قتادة وغيره بأسانيد جياد». وقال ابن عدي في الكامل ٧/١٧: «وهذا لا أعلم يرويه عن عون غير عبد الجبار هذا». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٧٦٢ (٣٩٩٩) عن عبد الجبار بن عباس راوي الحديث: «وليس بذاك». وقال الهيثمي في المجمع ١/٣٢٢ (١٨٠٣): «رواه أبو يعلى، والطبراني في الكبير، ورجاله ثقات». وقال البوصيري في إتحاف الخيرة ٢/٢٣٧ (١٤١٤): «هذا إسناد حسن، عبد الجبار بن عباس مختلف في توثيقه، وباقي رجال الإسناد مُحْتَجٌّ بهم في الصحيح». وقال الألباني في الصحيحة ١/٧٥٢ (٣٩٦) على رواية أبي يعلى: «إسناد جيد، رجاله كلهم ثقات، رجال الشيخين، غير عبد الجبار هذا، وهو صدوق يَتَشَيَّع».الهَيْنَمَة: الكلام الخفي الذي لا يُفهم. النهاية (هَيْنَم).أخرجه الحاكم ٤/٦٥ (٦٨٩٧) مختصرًا، والضياء المقدسي في الأحاديث المختارة ٧/١٤٠-١٤٢، من طريق القاسم بن عثمان أبي العلاء البصري، عن أنس به.</p><p>قال البوصيري في إتحاف الخيرة ٧/١٦٦ (٦٥٨٩): «رواه أبو يعلى الموصلي بسند ضعيف؛ لضعف القاسم بن عثمان البصري».عزاه السيوطي إلى عبد بن حميد.
  20,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلسَّاعَةَ ءَاتِیَةٌ أَكَادُ أُخۡفِیهَا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٣٣<span class="dash">-</span></span> عن قتادة، قال: هي في قراءة <span class="name-1">أبي بن كعب</span>: (أكادُ أُخْفِيها مِن نَّفْسِي){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣٤<span class="dash">-</span></span> عن الفراء، قال: في قراءة <span class="name-1">أبي بن كعب</span>: (أكادُ أُخْفِيها مِن نَّفْسِي فَكَيْفَ أُطْلِعُكُمْ عَلَيْها){2}. (١٠/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣٥<span class="dash">-</span></span> عن إسماعيل السُّدِّي، قال: ليس مِن أهل السموات والأرض أحدٌ إلا وقد أخْفى اللهُ عنه علمَ الساعة. وهي في قراءة <span class="name-1">ابن مسعود</span>: (أكادُ أُخْفِيها من نَّفْسِي). يقول: كتمتها مِن الخلائق، حتى لو استطعت أن أكتمها من نفسي لفعلت{3}. (١٠/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنه قرأ: (أكادُ أُخْفِيها مِن نَّفْسِي)، يقول: لأنها لا تخفى مِن نفس الله أبدًا{4}. (١٠/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣٧<span class="dash">-</span></span> عن وِقاء، قال: أقرأنيها <span class="name-2">سعيدُ بن جبير</span>: (أكادُ أخْفِيها)، يعني: بنصب الألف وخفض الفاء. يقول: أُظْهِرُها. ثم قال أما سمعت قولَ الشاعر:</p><p>دَأْبَ شهرين ثم شهرًا دَمِيكا بأرِيكَين يَخْفِيان غَمِيرا؟{5}<span class=comment-ref>٤٢٤٧</span>. (١٠/١٧٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٤٧</span> <span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٦/٨٤) هذه القراءة، فقال: «وقرأ ابن كثير والحسن وعاصم: (أكادُ أخْفِيها) بفتح الهمزة، بمعنى: أظهرها، أي: أنها من صحة وقوعها وتيقن كونها تكاد تظهر، لكن تنحجب إلى الأجل المعلوم، والعرب تقول: أخفيت الشيء، بمعنى: أظهرته».</p><p>و<span class="comment-type-2">انتقدها</span> <u>ابن جرير</u> (١٦/٣٧) <span class="mustanad">مستندًا لمخالفتها قراءة الحجة المستفيضةَ</span>، فقال: «والذي ذُكِر عن سعيد بن جبير من قراءة ذلك بفتح الألف قراءةٌ لا أستجيز القراءة بها؛ لخلافها قراءة الحُجَّة التي لا يجوز خلافُها فيما جاءت به نقلًا مستفيضًا».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلسَّاعَةَ ءَاتِیَةٌ أَكَادُ أُخۡفِیهَا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٣٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: أكاد أخفيها من نفسي؛ فكيف يعلمها مخلوق؟!{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها﴾</span>، يقول: لا أُظْهِرُ عليها أحدًا غيري{7}. (١٠/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها﴾</span>، قال: أكاد أخفيها من نفسي{8}. (١٠/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها﴾</span>، قال: لا تأتيكم إلا بغتة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- <span class="qpc-hafs">﴿أكاد أخفيها﴾</span>، قال: لقد أخفاها، إنِّي أكاد أُخفيها مِن نفسي{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طُرُق- في قوله: <span class="qpc-hafs">﴿أكاد أخفيها﴾</span>، قال: من نفسي{11}. (١٠/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿أكاد أخفيها﴾</span>، قال: يخفيها مِن نفسه{12}. (١٠/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد- في قوله ﷿: <span class="qpc-hafs">﴿أكاد أخفيها﴾</span>، قال: أخفيها مِن نفسي{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: في بعض القراءة: (أكادُ أُخْفِيها من نَّفْسِي)، قال: لَعَمْرِي، لقد أخفاها اللهُ مِن الملائكة المقربين، ومِن الأنبياء والمرسلين{14}<span class=comment-ref>٤٢٤٨</span>. (١٠/١٧٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٤٨</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (٩/٣١٩) على قول قتادة بقوله: «وهذا كقوله تعالى: <span class="qpc-hafs">﴿قل لا يعلم من في السماوات والأرض الغيب إلا الله﴾</span> [النمل:٦٥]، وقال: <span class="qpc-hafs">﴿ثقلت في السماوات والأرض لا تأتيكم إلا بغتة﴾</span> [الأعراف:١٨٧]، أي: ثَقُل عِلْمُها على أهل السموات والأرض».</div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: قضى الله -تبارك وتعالى- ألّا تأتيكم الساعةُ إلا بغتةً{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استأنف <span class="qpc-hafs">﴿إن الساعة آتية﴾</span> يقول: إن الساعة جائيةٌ لا بُدَّ، (أكادُ أُخْفِيها مِن نَّفْسِي) في قراءة ابن مسعود، فكيف يَعْلَمُها أحدٌ، وقد كدت أن أخفيها من نفسي؛ لِئَلّا يعلمَها مخلوق{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٤٩<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها﴾</span>، أي: من نفسي{17}<span class=comment-ref>٤٢٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٤٩</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿أكاد أخفيها﴾</span> على قولين: <b>الأول</b>: أكاد أخفيها من نفسي، فلا أُظْهِر عليها أحدًا من خلقي. <b>الثاني</b>: أكاد أظهرها.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابن جرير</u> (١٦/٣٧-٣٨ بتصرف) <span class="mustanad">مستندًا إلى أقوال السلف وإلى اللغة</span> القول الأول، فقال: «والذي هو أولى بتأويل الآية من القول قولُ مَن قال: معناه: أكاد أخفيها مِن نفسي. لأن تأويل أهل التأويل بذلك جاء، ولأنّ المعروف من معنى الإخفاء في كلام العرب: الستر. يقال: قد أخفيت الشيء: إذا سترته، فلما كان معروفًا في كلامهم أن يقول أحدهم إذا أراد المبالغة في الخبر عن إخفائه شيئًا هو له مُسِرٌّ: قد كدت أن أخفي هذا الأمر عن نفسي مِن شدة استسراري به، ولو قدرت أخفيه عن نفسي أخفيته. خاطبهم على حسب ما قد جرى به استعمالُهم في ذلك من الكلام بينهم، وما قد عرفوه في منطقهم».</p><p>وأمّا <u>ابنُ عطية</u> (٦/٨٦) فقد ذكر قولًا عن بعض المفسرين لم يُسمِّه، و<span class="comment-type-3">رجّحه</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وقالت فرقة: <span class="qpc-hafs">﴿أكادُ﴾</span> على بابها، بمعنى أنها مقاربة ما لم يقع، لكن الكلام جارٍ على استعارة العرب ومجازها، فلما كانت الآية عبارة عن شدة خفاء أمر القيامة ووقتها، وكان القَطْع بإتيانها مع جهل الوقت أهيب على النفوس؛ بالغ قوله تعالى في إعتام وقتها، فقال: <span class="qpc-hafs">﴿أكادُ أُخْفِيها﴾</span> حتى لا تظهر البتة، ولكن ذلك لا يقع، ولا بد من ظهورها، هذا تلخيص هذا المعنى الذي أشار إليه بعض المفسرين، وهو الأقوى عندي. ورأى بعضُ القائلين بأن المعنى: أكادُ أُخْفِيها من نفسي. ما في القول من القلق، فقالوا: معنى من نفسي: من تلقائي، ومن عندي، وهذا رفض للمعنى الأول، ورجوع إلى هذا القول الذي اخترناه أخيرًا. فتأمله».</p><p>وذكر <u>ابن جرير</u> (١٦/٣٨-٤١) عدة أقوال أخر لم ينسبها إلى أحد، وكذا فعلَ <u>ابنُ عطية</u>، و<span class="comment-type-2">انتقد</span> هو و<u>ابن جرير</u> بعضَ تلك الأقوال <span class="mustanad">لمخالفتها لغة العرب، وقولَ الحجة من أهل التأويل، ودلالة العقل</span>.</div></p><p><div></p><p><p><span class="item-no">٤٧٥٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿إن الساعة﴾</span>، يعني: القيامة{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِتُجۡزَىٰ كُلُّ نَفۡسِۭ بِمَا تَسۡعَىٰ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لتجزى كل نفس بما تسعى﴾</span>، قال: لِتُعْطى ثوابَ ما تعمل{19}. (١٠/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لتجزى كل نفس﴾</span> يقول سبحانه: الساعة آتيةٌ لتجزى كلُّ نفس بَرٍّ وفاجر <span class="qpc-hafs">﴿بما تسعى﴾</span> إذا جاءت الساعة، يعني: بما تعمل في الدنيا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٥٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: إنما تجيء الساعة <span class="qpc-hafs">﴿لتجزى كل نفس بما تسعى﴾</span> بما تعمل{21}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٢٥٦.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن مسعود، وابن عباس، والسدي. انظر: مختصر ابن خالويه ص٩٠، والمحتسب ٢/٤٧.أخرجه ابن الأنباري.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٩٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم، وابن الأنباري.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٧٢-، وابن جرير ١٦/٣٦ بنحوه عن وقاء بن إياس. وعزاه السيوطي إلى ابن أبي حاتم، وابن الأنباري، وفيه عن ورقاء.</p><p>و(أخْفِيها) بفتح الألف قراءة شاذة. انظر: مختصر ابن خالويه ص ٩٠.تفسير البغوي ٥/٢٦٧.أخرجه ابن جرير ١٦/٣٤، وابن أبي حاتم -كما في الإتقان ٢/٢٧-.أخرجه يحيى بن سلّام ١/٢٥٥ من طريق عكرمة، وابن جرير ١٦/٣٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٣٤.أخرجه عبد الله بن وهب في الجامع ١/٤٢ (٨٦).أخرجه ابن جرير ١٦/٣٤-٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري في المصاحف.أخرجه ابن جرير ١٦/٣٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٣، مما رواه الهذيل بن حبيب عن غير مقاتل؛ فقد رواه الهذيل، عن صيفي بن سالم، عن عمرو بن عبيد، عن الحسن.أخرجه ابن جرير ١٦/٣٥، وعبد الرزاق ٢/١٦ مختصرًا من طريق معمر. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٥٦.تفسير مقاتل بن سليمان ٣/٢٤.أخرجه الثوري في تفسيره ص١٩٣.تفسير يحيى بن سلّام ١/٢٥٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.
  20,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَا یَصُدَّنَّكَ عَنۡهَا مَن لَّا یُؤۡمِنُ بِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلا يصدنك عنها﴾</span> يا محمد<span class=comment-ref>٤٢٥٠</span>، يعني: عن إيمان بالساعة <span class="qpc-hafs">﴿من لا يؤمن بها﴾</span> يعني: مَن لا يُصَدِّق بها أنها كائنة{1}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٥٠</span> ذكر <u>ابنُ عطية</u> (٦/٨٧) نحو هذا القول عن النقاش، و<span class="comment-type-2">انتقده</span>، فقال: «وقال النقاش: الخطاب بـ<span class="qpc-hafs">﴿فَلا يَصُدَّنَّكَ﴾</span> لمحمد ﷺ، <b>وهذا بعيدٌ</b>». وبيّن أنّ الخطاب لموسى ﵇.</div></p><p><div></p><p><p><span class="item-no">٤٧٥٥٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فلا يصدنك عنها﴾</span> عن الإيمان بها؛ بالساعة{2}<span class=comment-ref>٤٢٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٥١</span> قال <u>ابنُ عطية</u> (٦/٨٦-٨٧): «والضمير في قوله: <span class="qpc-hafs">﴿عَنْها﴾</span> يريد: عن الإيمان بالساعة. فأوقع الضمير عليها، ويحتمل أن يعود على الصَّلاةَ. وقالت فرقة: المراد: عن لا إله إلا الله. وهذا مُتَّجِهٌ، والأوَّلان أبيَنُ وجهًا».</p><p>وذكر <u>ابن جرير</u> (١٦/٤١) قولًا أن الضمير في: <span class="qpc-hafs">﴿عنها﴾</span> كناية عن مطلق، ولم يقيده بالإيمان بالساعة، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى السياق، فقال</span>: «وكان بعضُهم يزعم أن الهاء والألف من قوله: <span class="qpc-hafs">﴿فلا يصدنك عنها﴾</span> كناية عن ذكر الإيمان، قال: وإنما قيل <span class="qpc-hafs">﴿عنها﴾</span> وهي كناية عن الإيمان <span class="mustanad">كما قيل</span>: <span class="qpc-hafs">﴿إن ربك من بعدها لغفور رحيم﴾</span> [الأعراف:١٥٣] يذهب إلى الفعلة، ولم يَجْرِ للإيمان ذكر في هذا الموضع، فيجعل ذلك من ذكره، وإنما جرى ذكر الساعة، فهو بأن يكون مِن ذكرها أوْلى».</div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبَعَ هَوَىٰهُ فَتَرۡدَىٰ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٥٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّي</span>: <span class="qpc-hafs">﴿واتبع هواه﴾</span> يعني: شهوته؛ <span class="qpc-hafs">﴿فتردى﴾</span> يقول: فتهلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتبع هواه﴾</span>، ثم قال للنبي ﷺ: <span class="qpc-hafs">﴿فتردى﴾</span> يعني: فتهلك إن صدُّوك عن الإيمان بالساعة. فيها تقديم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فتردى﴾</span> في النار، والتردِّي: التباعد مِن الله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبَعَ هَوَىٰهُ فَتَرۡدَىٰ ۝١٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٥٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٠<span class="dash">-</span></span> و<span class="name-3">ابن شبرمة</span>، قالا: إنّما سُمِّي: هَوًى؛ لأنه يهوي بصاحبه إلى النار{6}. (١٠/١٨٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.علَّقه يحيى بن سلّام ١/٢٥٦.تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.عزاه السيوطي إلى ابن أبي حاتم.
  20,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا تِلۡكَ بِیَمِینِكَ یَـٰمُوسَىٰ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿ في مخاطبته لموسى ﵇: <span class="qpc-hafs">﴿وما تلك بيمينك ياموسى﴾</span>، يعني: عصاه كانت بيده اليمنى، قال ذلك لموسى ﵇، وهو يريد أن يُحَوِّلها حيَّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وما تلك بيمينك يا موسى﴾</span> يسأله عن العصا التي في يده اليمنى وهو أعلم بها، <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.تفسير يحيى بن سلّام ١/٢٥٦.
  20,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ هِیَ عَصَایَ أَتَوَكَّؤُا۟ عَلَیۡهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى ﵇: <span class="qpc-hafs">﴿هي عصاي أتوكأ عليها﴾</span> يقول: أعتمد عليها إذا مَشَيْتُ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</span>، قال: يتوكأ عليها حين يمشي مع الغنم{2}. (١٠/١٨١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَهُشُّ بِهَا عَلَىٰ غَنَمِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٦٥<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span>، في قوله: <span class="qpc-hafs">﴿وأهش بها على غنمي﴾</span>، قال: الهشُّ: أن يخبط الرجل بعصاه الشجرَ فيتناثرُ الوَرَق{3}. (١٠/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وأهش بها على غنمي﴾</span>، قال: أضرب بها الشجرَ حتى يسقط منه ما تأكلُ غنمي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- في قوله: <span class="qpc-hafs">﴿وأهش بها على غنمي﴾</span>، قال: أضرب بها الشجرَ فيتساقط منه الوَرَق على غنمي{5}. (١٠/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٨<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span>، قال: الهشُّ: أن يُولِج العصا بين الشُّعْبَيْن{6}، ثم يحركها حتى يسقط الورق. والخبط: أن يخبط حتى يسقط الورق{3}. (١٠/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأهش بها على غنمي﴾</span>، قال: أخبط بها الشجر{8}. (١٠/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأهش بها على غنمي﴾</span>، يقول: أضرب بها الشجر للغنم، فيقع الوَرَق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأهش بها على غنمي﴾</span>، يقول: أخبط بها الشجر فَيَتَهاشُّ الوَرَق في الأرض، فتأكله غنمي إذا رعيتها. وكانت صغارًا لا تَعْلُوَنَّ الشجر، وكان موسى ﵇ يضرب بعصاه الشجر فَيَتَهاشَّ الورقُ في الأرض، فتأكله غنمه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٢<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span>، قال: الهشُّ أن يضع الرجل المحجن{11} في الغُصْن، ثم يحركه حتى يسقط ورقُه وثمره، ولا يكسر العود، فهذا الهش، ولا يخبط{3}. (١٠/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</span>، قال: يَتَوَكَّأ عليها حين يمشي مع الغنم، ويَهُشُّ بها؛ يُحَرِّك الشجر حتى يسقط الورق؛ الحَبَلَة{13} وغيرها{2}. (١٠/١٨١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِیَ فِیهَا مَـَٔارِبُ أُخۡرَىٰ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span>، قال: حَوائِج{15}. (١٠/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة-: عصا موسى. قال: أعطاه إيّاها ملَك مِن الملائكة إذ توجه إلى مدين، فكانت تُضيء له بالليل، ويضرب بها الأرضَ فيخرج له النبات، ويهش بها على غنمه ورق الشجر{16}. (١٠/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ موسى كان يحمل عليها زادَه وسقاءه، فجعلت تُماشِيه وتحدِّثه، وكان يضرب بها الأرض فيخرج ما يأكل يَوْمَه، ويركزها فيخرج الماء، فإذا رفعها ذهب الماء، وإذا اشتهى ثمرة ركزها فَتَغَصَّنَتْ غصن الشجرة، وأورقت وأثمرت، وإذا أراد الاستقاء مِن البئر أدلاها، فطالَتْ على طول البئر، وصارت شُعْبَتاها كالدَّلْو حتى يَسْتَقِي، وكانت تُضِيء بالليل بمنزلة السِّراج، وإذا ظهر له عدوٌّ كانت تُحارب وتُناضِل عنه، فهذه المآرب{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿مآرب أخرى﴾</span>، قال: حاجات ومنافع{18}. (١٠/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿مآرب أخرى﴾</span>، قال: حاجات أخرى{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٧٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span>: أي: منافع أخرى{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق عبد الصمد بن معقل- قال: ... كان لموسى في العصا مآرب، كان لها شعبتان، ومِحْجَنٌ تحت الشعبتين، فإذا طال الغُصْنُ حناه بالمِحْجَنِ، وإذا أراد كسره لواه بالشعبتين، وكان يتوكَّأُ عليها، ويَهُشُّ بها، وكان إذا شاء ألقاها على عاتقه، فعلق بها قوسه وكِنانَتَه ومِرْجامَه{21} ومِخْلاته{22} وثوبه وزادًا -إن كان معه-، وكان إذا أرْتَع في البَرِّيَّة حيث لا ظِلَّ له رَكَزَها، ثم عرَض بالوتد بين شعبتيها، وألقى فوقها كِساءه، فاستظلَّ بها ما كان مُرْتِعًا، وكان إذا ورد ماء يَقْصُر عنه رِشاؤُه{23} وصل بها، وكان يقاتل بها السِّباع عن غنمه{24}. (١٠/١٦٣-١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span>، قال: حاجات أخرى؛ منافع أخرى{25}. (١٠/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span>، قال: كانت تُضِيء له بالليل، وكانت عصا آدم ﵇{3}<span class=comment-ref>٤٢٥٢</span>. (١٠/١٨٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٥٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (٩/٣٢٠) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> ما جاء في شأن عصا موسى مِن الأمور الخارقة، فقال: «وقد تكلَّف بعضُهم لذِكْرِ شيء من تلك المآرب التي أُبْهِمَتْ، فقيل: كانت تضيء له بالليل، وتحرس له الغنم إذا نام، ويغرسها فتصير شجرة تُظِلُّه، وغير ذلك من الأمور الخارقة للعادة. والظاهر أنها لم تكن كذلك، ولو كانت كذلك لما استنكر موسى صيرورتها ثعبانًا، فما كان يَفِرُّ منها هاربًا، ولكن كل ذلك من الأخبار الإسرائيلية. وكذا قول بعضهم: إنها كانت لآدم ﵇. وقول الآخر: إنها هي الدابة التي تخرج قبل يوم القيامة».</div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span>، في قوله: <span class="qpc-hafs">﴿مآرب أخرى﴾</span>، يقول: حوائج أخرى، أحمل عليها المِزْوَد{27}، والسِّقاء{28}. (١٠/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولي فيها﴾</span> يعني: في العصا <span class="qpc-hafs">﴿مآرب أخرى﴾</span> يعني: حوائج أخرى، وكان موسى ﵇ يحمل زادَه وسِقاءَه على عصاه، ويضرب الأرض بعصاه فيخرج ما يأكل يومه، ويركزها في الأرض فيخرج الماء، فإذا رفعها ذهب الماء، وتُضِيء بالليل في غير قَمَرٍ ليهتدي بها، ويرد بها غنمه عليه، فتقيه بإذن الله ﷿ مِن الآفات، ويقتل بها الحيّات والعقارب بإذن الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٥<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span>: حاجات أخرى{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span>، قال: حوائج أخرى سوى ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: بلغني: أنّ مِن تلك الحوائج الأخرى: أنه كان يستَظِلُّ بها{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِیَ فِیهَا مَـَٔارِبُ أُخۡرَىٰ ۝١٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: كان اسمُ عصا موسى: ماشا{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٨٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قال: كان اسم عصا موسى ﵇: يوشا{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: كانت عصا موسى ﵇ مِن عَوْسَج{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩١<span class="dash">-</span></span> عن أبي بكر، قال: سألتُ <span class="name-2">عكرمة،</span> قال: أمّا عصا موسى فإنها خرج بها آدمُ من الجنة، ثم قبضها بعد ذلك جبرائيل ﵇، فلَقِي موسى بها ليلًا، فدفعها إليه{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّي</span> -من طريق أسباط- قال: ... فلما أتى الشيخَ، وقصَّ عليه القصص، قال: <span class="qpc-hafs">﴿لا تخف نجوت من القوم الظالمين﴾</span>. فأمر إحدى ابنتيه أن تأتيه بعصا، وكانت تلك العصا عصًا استودعه إياها ملَك في صورة رجل، فدفعها إليه، فدخلت الجاريةُ، فأخذت العصا، فأتته بها، فلما رآها الشيخُ قال لابنته: ائتيه بغيرها. فألقتها، وأخذت تريد أن تأخذ غيرها، فلا يقع في يدها إلا هي، وجعل يَرْدُدُها، وكل ذلك لا يخرج في يدها غيرها، فلمّا رأى ذلك عهد إليه، فأخرجها معه، فرعى بها، ثم إنّ الشيخ ندِم، وقال: كانت وديعة. فخرج يتلقى موسى، فلما رآه قال: أعطني العصا. فقال موسى: هي عصاي. فأبى أن يعطيه، فاختصما، فرضيا أن يجعلا بينهما أولَ رجل يلقاهما، فأتاهما ملَك يمشي، فقضى بينهما، فقال: ضَعوها في الأرض، فمن حملها فهي له. فعالجها الشيخ فلم يُطِقْها، وأخذها موسى ﵇ بيده فرفعها، فتركها له الشيخ{37}. (١١/٤٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- قال: كان عصا موسى مِن عَوسَج{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: دفع جبريلُ ﵇ العصا إلى موسى ﵇، وهو مُتَوَجِّه إلى مَدْيَن بالليل، واسم العصا: نفعه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: قال -يعني: أبا الجارية لَمّا زوجها موسى- لموسى: ادخل ذلك البيت، فخذ عصًا، فتَوَكَّأ عليها. فدخل، فلما وقف على باب البيت طارت إليه تلك العصا، فأخذها، فقال: ارْدُدْها، وخذ أخرى مكانها. قال: فردَّها، ثم ذهب ليأخذ أخرى، فطارت إليه كما هي، فقال: لا، ارْدُدْها. حتى فعل ذلك ثلاثًا، فقال: ارْدُدْها. فقال: لا آخذ غيرها اليوم. فالتفت إلى ابنته، فقال: يا بُنَيَّة، إنّ زوجك لَنَبِيٌّ{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٦<span class="dash">-</span></span> عن مسلم -من طريق حبيب بن حسان- قال: عصا موسى هي الدابَّة مِن دابَّة الأرض{41}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٤.أخرجه ابن جرير ١٦/٤٣. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٤٤.أخرجه إسحاق البستي في تفسيره ص٢٣٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.الشعبان: الغصنان. اللسان (شعب).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٤٣، وعبد الرزاق ٢/١٦ من طريق معمر. وعلَّقه يحيى بن سلّام ١/٢٥٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٤٣.تفسير مقاتل بن سليمان ٣/٢٤.المِحْجَن: عصا مُعَقَّفَة الرأس كالصولجان. النهاية (حجن).عزاه السيوطي إلى ابن أبي حاتم.الحَبَلَة- بفتح الحاء والباء، وربما سُكِّنِت-: الأصل، أو القضيب من شجر الأعناب. النهاية (حبل).أخرجه ابن جرير ١٦/٤٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٣٦، وابن أبي حاتم -كما في التغليق ٣/١٤٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٧.تفسير الثعلبي ٦/٢٤٢، وتفسير البغوي ٥/٢٦٩.أخرجه ابن جرير ١٦/٤٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٤٦.أخرجه ابن جرير ١٦/٤٦.المِرْجامُ: الَّذِي تُرْجَمُ بِهِ الحِجارَةُ. اللسان (رجم).المِخلاة: ما يُجعل فيه الخلا، وهو علف الدابة الرطب. مختار الصحاح، ولسان العرب (خلا).الرِشاء: الحبل الذي يربط به الدلو ليتوصل به إلى الماء. النهاية (رشا).أخرجه أحمد في الزهد ص٦١-٦٦، وابن أبي حاتم ٩/٢٨٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلّام ١/٢٥٦ من طريق سعيد، وابن جرير ١٦/٤٦. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.المِزْوَد: الوعاء الذي يوضع فيه الشيء. غريب الحديث للحربي (زاد)أخرجه ابن جرير ١٦/٤٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٢٤.أخرجه الثوري في تفسيره ص١٩٣.أخرجه ابن جرير ١٦/٤٧.تفسير يحيى بن سلّام ١/٢٥٦.أخرجه ابن أبي حاتم ٨/٢٨٤٨ (١٦١٤٢).أخرجه إسحاق البستي في تفسيره ص٢٣٥.أخرجه ابن أبي حاتم ٨/٢٨٤٨ (١٦١٤٣).أخرجه ابن جرير ١٨/٢٣٣.أخرجه ابن جرير ١٨/٢٣٣، وابن أبي حاتم ٨/٢٩٦١، ٢٩٦٥.أخرجه عبد الرزاق ٢/٩١.تفسير مقاتل بن سليمان ٣/٢٥.أخرجه ابن جرير ١٨/٢٣٣.أخرجه ابن أبي حاتم ٩/٢٩٧٤.
  20,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَلۡقِهَا یَـٰمُوسَىٰ ۝١٩ فَأَلۡقَىٰهَا فَإِذَا هِیَ حَیَّةࣱ تَسۡعَىٰ ۝٢٠ قَالَ خُذۡهَا وَلَا تَخَفۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٥٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿فألقاها فإذا هي حية تسعى﴾</span>: ولم تكن قبل ذلك حيَّة، فمرَّت بشجرةٍ فأكلتها، ومرت بصخرة فابتلعتها، فجعل موسى يسمع وقْعَ الصخرة في جوفها، فوَلّى مُدْبِرًا، فنودي: أن يا موسى، خُذها. فلم يأخذها، ثم نودي الثانية: أن خذها، ولا تخف. فقيل له في الثالثة: إنّك من الآمنين. فأخذها{1}. (١٠/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق-: <span class="qpc-hafs">﴿قال ألقها يا موسى فألقاها فإذا هي حية تسعى﴾</span> تَهْتَزُّ، لها أنيابٌ وهيئةٌ كما شاء الله أن تكون، فرأى أمرًا فظيعًا، فوَلّى مدبرًا ولم يُعَقِّب، فناداه ربُّه: يا موسى، أقبل ولا تخف <span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٥٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: فإذا هي حيَّة أشْعَر ذَكَر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسباط- قال: قال له -يعني: لموسى- ربُّه: <span class="qpc-hafs">﴿ألقها يا موسى﴾</span> يعني: عصاه، <span class="qpc-hafs">﴿فألقاها فإذا هي حية تسعى﴾</span>، <span class="qpc-hafs">﴿فلما رآها تهتز كأنها جان ولى مدبرا ولم يعقب﴾</span> فنودي: <span class="qpc-hafs">﴿يا موسى لا تخف إني لا يخاف لدي المرسلون﴾</span> [النمل:١٠]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠١<span class="dash">-</span></span> عن <span class="name-2">مالك بن دينار</span> -من طريق أبي جعفر- قال: بلغني: أنّه كان بين لحيي عصا موسى حين عادت حيَّةً خمسون ذراعًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> الله ﷿: <span class="qpc-hafs">﴿ألقها يا موسى فألقاها﴾</span> مِن يده اليُمْنى <span class="qpc-hafs">﴿فإذا هي حية تسعى﴾</span> على بطنها؛ ذكرًا أشعر، له عُرف، فخاف موسى ﵇ أن يأخذها، فـ<span class="qpc-hafs">﴿قال﴾</span> له ربه ﷿: <span class="qpc-hafs">﴿خذها ولا تخف﴾</span> منها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: نظر موسى، فإذا العصا حيَّةٌ مِن أعظم ما يكون مِن الحيّات، صارت شعبتاها شِدْقَين لها، والمحجن عنقًا وعرفًا، تهتز كالنيازك، وعيناها تَتَّقِدان كالنار، تمرُّ بالصخرة العظيمة مثل الخَلِفَة{7} مِن الإبل فَتَلْقَمُها، وتَقْصِف الشجرة العظيمة بأنيابها، ويسمع لأسنانها صَريفٌ عظيم. فلما عاين ذلك موسى ولّى مُدبرًا وهرب، ثم ذكر ربَّه، فوقف استحياءً منه، ثم نودي: أن يا موسى، أقبِل وارجع حيث كنت. فرجع وهو شديد الخوف{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿تسعى﴾</span>، أي: تزحف على بطنها بسرعة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سَنُعِیدُهَا سِیرَتَهَا ٱلۡأُولَىٰ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٧٦٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span>، قال: حالتها الأولى{10}. (١٠/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span>، قال: هيئتها الأولى{11}. (١٠/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٧<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span>: أي: سَنَرُدُّها عصًا كما كانت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span>، قال: إلى هيئتها الأولى{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span>، يعني: سنعيدها عصًا كهيئتها الأولى عصًا، كما كانت أول مرة، فأهوى موسى بيده إلى ذَنَبِها، فقَبَض عليها، فصارت عصًا كما كانت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٧٦١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿قال خذها ولا تخف سنعيدها سيرتها الأولى﴾</span> عصًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٤٧، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٧٤-.أخرجه ابن جرير ١٦/٤٧.أخرجه يحيى بن سلّام ١/٢٥٧.أخرجه ابن جرير ١٦/٤٦.أخرجه عبد الرزاق ٢/١٦.تفسير مقاتل بن سليمان ٣/٢٥.الخَلِفَة- بفتح الخاء وكسر اللام-: الحامل مِن النوق. النهاية (خلف).تفسير البغوي ٥/٢٦٩.تفسير يحيى بن سلّام ١/٢٥٦.أخرجه ابن جرير ١٦/٤٨، وابن أبي حاتم -كما في الإتقان ٢/٢٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلّام ١/٢٥٧ من طريق ابن مجاهد، وابن جرير ١٦/٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٤٧.أخرجه يحيى بن سلّام ١/٢٥٧، وابن جرير ١٦/٤٧.تفسير مقاتل بن سليمان ٣/٢٥.أخرجه يحيى بن سلّام ١/٢٥٧.
