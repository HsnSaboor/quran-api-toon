quran[27]{c,v,t}:
  37,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا لَكُمۡ لَا تَنَاصَرُونَ ۝٢٥ بَلۡ هُمُ ٱلۡیَوۡمَ مُسۡتَسۡلِمُونَ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ما لَكُمْ لا تَناصَرُونَ﴾</span> قال: لا تمانعون مِنّا، <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> مُسْتَنجِدون{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> خاضِعون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> مُنقادون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ما لَكُمْ لا تَناصَرُونَ﴾</span> قال: لا، واللهِ، لا يتناصرون، ولا يدفع بعضكم عن بعض، <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> يعني: في عذاب الله{4}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الخازن: <span class="qpc-hafs">﴿ما لَكُمْ لا تَناصَرُونَ﴾</span>. نظيرها في الشعراء [٩٣]: <span class="qpc-hafs">﴿هَلْ يَنْصُرُونَكُمْ أوْ يَنْتَصِرُونَ﴾</span>. يقول الكفار: ما لشركائكم الشياطين لا يمنعونكم مِن العذاب. يقول اللَّه ﷿ لمحمد ﷺ: <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> للعذاب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ما لَكُمْ لا تَناصَرُونَ﴾</span> يُقال لهم: <span class="qpc-hafs">﴿ما لَكُمْ لا تَناصَرُونَ﴾</span> لا ينصر بعضُكم بعضًا، <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> استسلموا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:تفسير الثعلبي ٨/١٤٣، وتفسير البغوي ٧/٣٨.|3:تفسير الثعلبي ٨/١٤٣، وتفسير البغوي ٧/٣٨.|4:أخرجه ابن جرير ١٩/٥٢٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٣/٦٠٥.|6:تفسير يحيى بن سلام ٢/٨٢٨.
  37,26,""
  37,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>: أقبل بعضُهم يلوم بعضًا{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، قال: ذلك إذا بُعِثوا في النفخة الثانية{2}. (١٢/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، قال: الإنس على الجن{3}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span> يتكلَّمون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span> الإنس والشياطين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ١٩/٥٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٦٠٥.|5:تفسير يحيى بن سلام ٢/٨٢٩.
  37,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّكُمۡ كُنتُمۡ تَأۡتُونَنَا عَنِ ٱلۡیَمِینِ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قال الضعفاء للذين استكبروا: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span> تقهروننا بالقُدرة مِنكم علينا{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، قال: عن الحق؛ الكفار تقوله للشياطين{2}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، أي: مِن قِبَل الدين، فتُضِلُّوننا عنه، وتروننا أن الدين ما تضلوننا به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحسين بن واقد- <span class="qpc-hafs">﴿قالوا إنكم كنتم تأتوننا عن اليمين﴾</span>، قال: مِن حيث نأمنكم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، قال: كانوا يأتونهم عند كل خير ليصدوهم عنه{5}. (١٢/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: قالت الإنسُ للجن: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>. قال: مِن قِبل الخير فتنهوننا عنه، وتُبَطِّئوننا عنه{6}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، قال: يفتِنوننا عن طاعة الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، قال: تأتوننا مِن قِبل الحقِّ تُزَيِّنون لنا الباطل، وتصدُّوننا عن الحق{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٧٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي:</span> <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span> مِن قِبَل الدِّين، فصددتمونا عنه، وزينتم لنا الضلالة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> قال قائل مِن الكفار لشركائهم الشياطين: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span> يعنون: مِن قِبل الحق. نظيرها في الحاقة [٤٥]: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span> بالحق. وقالوا للشياطين: أنتم زينتم لنا ما نحن عليه؛ فقلتم: إنّ هذا الذي نحنُ عليه هو الحق{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span> قال: قال بنو آدم للشياطين الذين كفروا: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، قال: تَحُولُون بيننا وبين الخير، ورددتمونا عن الإسلام والإيمان، والعمل بالخير الذي أمَر الله به{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> قالت الإنس للشياطين: <span class="qpc-hafs">﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>{12}<span class=comment-ref>٥٤٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٤</span> قال <u>ابنُ جرير</u> (١٩/٥٢٤-٥٢٥) مبيّنًا معنى الآية <span class="mustanad">استنادًا إلى أقوال السلف، واللغة</span>: "قالت الإنس للجن: إنكم -أيها الجن- كنتم تأتوننا مِن قِبَلِ الدِّين والحق، فتخدعوننا بأقوى الوجوه. واليمين: القوة والقدرة في كلام العرب، ومنه قول الشاعر:</p><p>إذا ما رايةٌ رُفِعَت لمجدٍ تَلَقَّاها عَرابةُ باليمينِ</p><p>يعني: بالقوة والقدرة".</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٧٨-٢٨٠ بتصرف): "اضطرب المتأولون في معنى قولهم: <span class="qpc-hafs">﴿عن اليمين﴾</span>، وعَبَّر ابن زيد وغيره عنه بـ:طريق الجنة والخير. ونحو هذا من العبارات التي هي تفسير بالمعنى لا تختص باللفظة، وبعضهم نحا في تفسير الآية إلى ما يختصها، <b>والذي يتحصل من ذلك معانٍ، منها:</b> أن يريد بـ<span class="qpc-hafs">﴿اليمين﴾</span>: القوة والشدة، فكأنهم قالوا: إنكم كنتم تغووننا بقوة منكم، وتحملوننا على طريق الضلالة بمتابعة منكم في شدة. فعَبَّر عن هذا المعنى بـ<span class="qpc-hafs">﴿اليمين﴾</span> <span class="mustanad">كما قالت العرب</span>: بيدين ما أورد. وكما قالوا: اليد -في غير موضع- عن القوة، وقد ذهب بعض الناس ببيت الشماخ هذا المذهب، وهو قوله:</p><p>إذا ما راية رفعت لمجد تلقاها عرابة باليمين</p><p>فقالوا: معناه: بقوة وعزيمة، وإلا فكل أحد يتلقاها بيمينه، لو كانت الجارحة، وأيضًا فلما استعار الراية للمجد فكذلك لم يرد باليمين الجارحة. <b>ومن المعاني التي تحتملها الآية</b> أن يريدوا: إنكم كنتم تأتوننا من الجهة التي يحسِّنها تمويهكم وإغواؤكم، ويظهر فيها أنها جهة الرشد والصواب، فتصير عندنا كاليمين التي نتيمَّن بالسانح الذي يجيؤنا من قِبَلِها ... فكأنهم شبهوا أقوال هؤلاء المغوين بالسوانح التي هي عندهم محمودة، كأن التمويه في هذه الغوايات قد أظهر فيها ما يوشك أن يُحمد به. <b>ومن المعاني التي تحتملها الآية</b> أن يريدوا: إنكم كنتم تأتوننا -أي: تقطعون بنا- عن أخبار الخير واليمن. فعَبَّر عنها بـ<span class="qpc-hafs">﴿اليمين﴾</span>؛ إذ اليمين هي الجهة التي يتيمن بكل ما كان منها وفيها. <b>ومن المعاني التي تحتملها الآية</b> أن يريدوا: إنكم كنتم تجيئوننا من جهة الشهوات وعدم النظر، والجهة الثقيلة من الإنسان وهي جهة اليمين منه؛ لأن كبده فيها، وجهة شماله فيها قلبه، وهي أخف، <span class="mustanad">وهذا معنى قول الشاعر</span>:</p><p>تركنا لهم شق الشمال</p><p>أي: نزلنا لهم عن موضع الهروب؛ لأن المنهزم إنما يرجع على شقه الأيسر؛ إذ هو أخف شقيه، وإذ قلب الإنسان في شماله، وثم نظره، فكأن هؤلاء كانوا يأتون من جهة الشهوات والثقل ... وأكثر ما يتمكن هذا التأويل مع إغواء الشياطين، وهو قَلِقٌ مع إغواء بني آدم. <b>وقيل</b>: المعنى: تحلفون لنا، وتأتوننا إتيان من إذا حلف صدقناه ... فاليمين على هذا: القَسَم«. ثم <span class="comment-type-4">بيَّن</span> أن بعض الناس ذهبوا في ذكر إبليس جهات بني آدم في قوله: <span class="qpc-hafs">﴿مِن بَيْنِ أيْدِيهِمْ ومِن خَلْفِهِمْ وعَنْ أيْمانِهِمْ وعَنْ شَمائِلِهِمْ﴾</span> [الأعراف:١٧] إلى ما ذكره من جهة الشهوات، فقالوا: ما بين يديه هي مغالطته فيما يراه، وما خلفه هو ما يسارق فيه الخفاء، وعن يمينه هو جانب شهواته، وعن شماله هو موضع نظره بقلبه وتحرزه، فقد يغلبه الشيطان فيه، ثم <span class="comment-type-4">علَّق</span> بقوله:»وهذا فيمن جعل هذا في جهات ابن آدم الخاصة بيديه، ومِن الناس مَن جعلها في جهات أموره وشؤونه؛ فيتسع التأويل على هذا".</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:أخرجه ابن جرير ١٩/٥٢٥. وعلَّقه يحيى بن سلام ٢/٨٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:تفسير الثعلبي ٨/١٤٣، وتفسير البغوي ٧/٣٨.|4:أخرجه إسحاق البستي ص٢٠١.|5:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:أخرجه ابن جرير ١٩/٥٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:أخرجه عبد الرزاق ٢/١٤٨.|8:أخرجه ابن جرير ١٩/٥٢٥.|9:علقه يحيى بن سلام ٢/٨٢٩.|10:تفسير مقاتل بن سليمان ٣/٦٠٥.|11:أخرجه ابن جرير ١٩/٥٢٥.|12:تفسير يحيى بن سلام ٢/٨٢٩.
  37,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَل لَّمۡ تَكُونُوا۟ مُؤۡمِنِینَ ۝٢٩ وَمَا كَانَ لَنَا عَلَیۡكُم مِّن سُلۡطَـٰنِۭۖ بَلۡ كُنتُمۡ قَوۡمࣰا طَـٰغِینَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قالُوا بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span> في علم الله، <span class="qpc-hafs">﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span> مُشركين في عِلم الله{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span>، قال: لو كنتم مؤمنين مُنِعْتُم مِنّا{2}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: قالت الجن للإنس: <span class="qpc-hafs">﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span> حتى بلغ <span class="qpc-hafs">﴿قَوْمًا طاغِينَ﴾</span>{3}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</span> مِن مُلك فنقهركم به على الشرك، <span class="qpc-hafs">﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span> تقوله الشياطين للمشركين مِن الإنس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</span>، قال: الحجة. وفي قوله <span class="qpc-hafs">﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span>، قال: كفار ضُلّال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> قالت لهم الشياطين: <span class="qpc-hafs">﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span> مُصَدِّقين بتوحيد الله ﷿، <span class="qpc-hafs">﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</span> مِن مُلْكٍ فنكرهكم على متابعتنا، <span class="qpc-hafs">﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span> عاصين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> قالت الشياطين للمشركين من الإنس: <span class="qpc-hafs">﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ * وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</span>. كقوله: <span class="qpc-hafs">﴿فَإنَّكُمْ﴾</span> يا بني إبليس <span class="qpc-hafs">﴿وما تَعْبُدُونَ * ما أنْتُمْ عَلَيْهِ بِفاتِنِينَ﴾</span> ليس لكم سلطان <span class="qpc-hafs">﴿إلا﴾</span> على <span class="qpc-hafs">﴿مَن هُوَ صالِ الجَحِيمِ﴾</span> [الصافات:١٦١-١٦٣]. <span class="qpc-hafs">﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span> تقوله الشياطين للمشركين من الإنس{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ١٩/٥٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:علقه يحيى بن سلام ٢/٨٢٩.|5:أخرجه ابن جرير ١٩/٥٢٦.|6:تفسير مقاتل بن سليمان ٣/٦٠٥.|7:تفسير يحيى بن سلام ٢/٨٢٩.
  37,30,""
  37,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَحَقَّ عَلَیۡنَا قَوۡلُ رَبِّنَاۤۖ إِنَّا لَذَاۤىِٕقُونَ ۝٣١ فَأَغۡوَیۡنَـٰكُمۡ إِنَّا كُنَّا غَـٰوِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span>: فوجب علينا قضاء ربنا؛ لأنا كنا أذلاء، وكنتم أعِزّاء{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span> قال: هذا قول الجن، <span class="qpc-hafs">﴿فَأَغْوَيْناكُمْ إنّا كُنّا غاوِينَ﴾</span> هذا قول الشياطين لضُلّال بني آدم{2}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فَأَغْوَيْناكُمْ﴾</span> قال: الشياطين تقول: أغويناكم في الدنيا <span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span>{3}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قالت الشياطين: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span> يومَ قال لإبليس: <span class="qpc-hafs">﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّنْ تَبِعَكَ مِنهُمْ أجْمَعِينَ﴾</span> [ص:٨٥] <span class="qpc-hafs">﴿إنّا لَذائِقُونَ فَأَغْوَيْناكُمْ﴾</span> يعني: أضللناكم عن الهدى، <span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span> ضالين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</span> هذا قول الشياطين، والقول هاهنا هو قوله: <span class="qpc-hafs">﴿ولَكِنْ حَقَّ القَوْلُ مِنِّي﴾</span> صدق القول مِنِّي <span class="qpc-hafs">﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنَ الجِنَّةِ والنّاسِ أجْمَعِينَ﴾</span> [السجدة:١٣]. قال: <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا إنّا لَذائِقُونَ﴾</span> أي: العذاب، <span class="qpc-hafs">﴿فَأَغْوَيْناكُمْ﴾</span> تقوله الشياطين للمشركين، أي: فأضللناكم، <span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span> ضالين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:أخرجه ابن جرير ١٩/٥٢٧ دون شطره الثاني. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٦٠٥-٦٠٦.|5:تفسير يحيى بن سلام ٢/٨٢٩.
  37,32,""
  37,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنَّهُمۡ یَوۡمَىِٕذࣲ فِی ٱلۡعَذَابِ مُشۡتَرِكُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</span> قال: كلهم <span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</span> ومَن أغْوَوا في الدنيا <span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>{2}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿مُشْتَرِكُونَ﴾</span> لا يمنعُ بعضُكم بعضًا من دخول النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</span> للكفار والشياطين <span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٢٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ فِي العَذابِ مُشْتَرِكُونَ﴾</span>، قال: هم والشياطين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿فَإنَّهُمْ يَوْمَئِذٍ فِي العَذابِ مُشْتَرِكُونَ﴾</span> يُقرَن كلُّ واحد منهم هو وشيطانه في سلسلة واحدة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:علقه يحيى بن سلام ٢/٨٢٨.|4:تفسير مقاتل بن سليمان ٣/٦٠٥-٦٠٦.|5:أخرجه ابن جرير ١٩/٥٢٧.|6:تفسير يحيى بن سلام ٢/٨٢٩-٨٣٠.
  37,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا كَذَ ٰ⁠لِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِینَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span>، يقول: إنّا هكذا نصنع بالمشركين{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> الذين جعلوا لله شركاء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> بالمشركين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.|2:تفسير البغوي ٧/٣٩.|3:تفسير يحيى بن سلام ٢/٨٣٠.
  37,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> نزلت في الملأ مِن قريش الذين مشَوْا إلى أبي طالب، فقال لهم النبي ﷺ: «<b>قولوا: لا إله إلا الله. تملكون بها العرب، وتدين لكم العجم بها</b>»{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٠٥<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: قال رسول الله ﷺ: «<b>أُمِرْتُ أن أُقاتِل الناس حتى يقولوا: لا إله إلا الله. فمَن قال: لا إله إلا الله. فقد عصم مِنِّي مالَه ونفسَه إلا بِحَقِّه، وحسابه على الله</b>». وأنزل الله في كتابه، وذكر قومًا استكبروا فقال: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>. وقال: <span class="qpc-hafs">﴿إذْ جَعَلَ الَّذِينَ كَفَرُوا فِي قُلُوبِهِمُ الحَمِيَّةَ حَمِيَّةَ الجاهِلِيَّةِ فَأَنْزَلَ اللَّهُ سَكِينَتَهُ عَلى رَسُولِهِ وعَلى المُؤْمِنِينَ وأَلْزَمَهُمْ كَلِمَةَ التَّقْوى وكانُوا أحَقَّ بِها وأَهْلَها﴾</span> [الفتح:٢٦] وهي: لا إله إلا الله محمد رسول الله، استكبر عنها المشركون يوم الحديبية، يوم كاتَبهم رسول الله ﷺ على قضية المدة{2}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>، قال: كانوا إذا لم يُشرِك بالله يستنكفون{3}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>، قال: يعني: المشركين خاصَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> يَتَكَبَّرون عنِ الهُدى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> عنها{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٠<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span>، قال: قال <span class="name-1">عمر بن الخطاب</span>: احضروا موتاكم، ولقِّنوهم لا إله إلا الله، فإنهم يرون ويسمعون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق سعيد بن رمانة- أنّه قيل له: أليس «لا إله إلا الله» مفتاح الجنة؟ قال: بلى. ولكن ليس مِن مفتاح إلا وله أسنان، فمَن جاء بأسنانه فُتِح له، ومن لا لم يُفتح له{8}. (١٢/٤٠٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.|2:أخرجه البيهقي في الأسماء والصفات ١/٢٦٣-٢٦٤ (١٩٦)، وابن جرير ٢١/٣٠٨-٣٠٩ واللفظ له، وأخرجه البخاري ٤/٤٨ (٢٩٤٦)، ٩/١٥ (٦٩٢٤)، ٩/٩٣ (٧٢٨٤)، ومسلم ١/٥١ (٢٠)، ١/٥٢ (٢١) كلاهما دون قوله: وأنزل الله في كتابه.|3:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|4:أخرجه ابن جرير ١٩/٥٢٨.|5:تفسير مقاتل بن سليمان ٣/٦٠٦.|6:تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.|7:أخرجه ابن جرير ١٩/٥٢٨.|8:أخرجه البخاري في تاريخه ١/٩٥، والبيهقى في الأسماء والصفات (٢٠٨).
  37,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ أَىِٕنَّا لَتَارِكُوۤا۟ ءَالِهَتِنَا لِشَاعِرࣲ مَّجۡنُونِۭ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ويَقُولُونَ أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span> لا يعقل. قال: فحكى الله صِدقَه، فقال: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ وصَدَّقَ المُرْسَلِينَ﴾</span>{1}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويَقُولُونَ أئِنّا لَتارِكُوا آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span>: يعنون: محمدًا ﷺ{2}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويَقُولُونَ﴾</span> يعني: المشركين، إذا دعاهم النبي ﷺ إلى الإيمان: <span class="qpc-hafs">﴿أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span> يعنون: النبي ﷺ، أي: لا نفعل{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|2:أخرجه ابن جرير ١٩/٥٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.
  37,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ جَاۤءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِینَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: قال: فحكى الله صِدْقَه، فقال: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ وصَدَّقَ المُرْسَلِينَ﴾</span>{1}. (١٢/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span> بالقرآن، <span class="qpc-hafs">﴿وصَدَّقَ المُرْسَلِينَ﴾</span> أي: صدّق مَن كان قبله مِن المرسلين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span>، يعني: بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُونَ أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span>. فقال -جل وعز-: <span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span> يعني: محمدًا ﷺ، جاء بالتوحيد، <span class="qpc-hafs">﴿وصَدَّقَ المُرْسَلِينَ﴾</span> قبله{4}<span class=comment-ref>٥٤٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٥</span> <span class="comment-type-4">قال</span> <u>ابنُ القيم</u> (٢/٣٦٧): «مجيئه تصديقٌ لهم من جهتين: مِن جهة إخبارهم بمجيئه ومبعثه، ومِن جهة إخباره بمثل ما أخبروا به، ومطابقة ما جاء به لما جاءوا به؛ فإن الرسول الأول إذا أتى بأمرٍ لا يعلم إلا بالوحي، ثم جاء نبي آخر لم يقارنه في الزمان ولا في المكان، ولا تلقى عنه ما جاء به، وأخبر بمثل ما أخبر به سواء؛ دلَّ ذلك على صدق الرسولين الأول والآخر، وكان ذلك بمنزلة رجلين أخبر أحدهما بخبر عن عيان، ثم جاء آخر من غير بلده وناحيته -بحيث يعلم أنه لم يجتمع به، ولا تلقى عنه، ولا عمن تلقى عنه-، فأخبر بمثل ما أخبر به الأول سواء؛ فإنه يضطر السامع إلى تصديق الأول والثاني. و<b>المعنى الثانى:</b> أنه لم يأتِ مُكَذِّبًا لِمَن قبله مِن الأنبياء، مُزْرِيًا عليهم، كما يفعل الملوك المتغلبون على الناس بمن تقدمهم من الملوك، بل جاء مصدقًا لهم، شاهدًا بنبوتهم، ولو كان كاذبًا متقولًا منشئًا من عنده سياسة لم يصدِّق من قبله، بل كان يُزْرِي بهم، ويطعن عليهم، كما يفعل أعداء الأنبياء».</p><p>وبنحو الكلام الأول <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١٢/١٥).</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|2:أخرجه ابن جرير ١٩/٥٢٩.|3:علقه يحيى بن سلام ٢/٨٣٠.|4:تفسير مقاتل بن سليمان ٣/٦٠٦.
  37,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّكُمۡ لَذَاۤىِٕقُوا۟ ٱلۡعَذَابِ ٱلۡأَلِیمِ ۝٣٨ وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّكُمْ لَذائِقُوا العَذابِ الأَلِيمِ﴾</span> يعني: الوجيع، <span class="qpc-hafs">﴿وما تُجْزَوْنَ﴾</span> في الآخرة <span class="qpc-hafs">﴿إلّا ما كُنْتُمْ تَعْمَلُونَ﴾</span> في الدنيا مِن الشرك، جزاءُ الشرك النارُ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إنَّكُمْ لَذائِقُو العَذابِ الأَلِيمِ﴾</span> المُوجِع، يقوله للمشركين، يعني: عذاب جهنم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.|2:تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.
  37,39,""
  37,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٤٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، أنه كان يقرأ: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>{1}. (١٢/٤٠٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٤٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٢٢<span class="dash">-</span></span> عن شدّاد بن أوس، قال: قال النبي ﷺ: «<b>إذا جمع الله الأولين والآخرين ببقيع واحد؛ ينفذهم البصر، ويُسمعهم الداعي، قال: أنا خير شريك، كلُّ عملٍ كان عُمِل لي في دار الدنيا كان لي فيه شريك فأنا أدعه اليوم، ولا أقبل اليوم إلا خالصًا»</b>. ثم قرأ: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، <span class="qpc-hafs">﴿فَمَن كانَ يَرْجُو لِقاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلًا صالِحًا ولا يُشْرِكْ بِعِبادَةِ رَبِّهِ أحَدًا﴾</span> [الكهف:١١٠]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، قال: هذه ثنية الله{3}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى المؤمنين، فقال: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> بالتوحيد، لا يذوقون العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، استثنى المؤمنين، وهم مِن كل ألفٍ واحدٌ{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور.</p><p>و<span class="qpc-hafs">﴿المُخْلَصِينَ﴾</span> بفتح اللام قراءة متواترة، قرأ بها نافع، وعاصم، وحمزة، والكسائي، وأبو جعفر، وخلف، وقرأ بقية العشرة: ‹المُخْلِصِينَ› بكسر اللام. انظر: النشر ٢/٢٩٥، والإتحاف ص٤٧٣.|2:أخرجه الطبراني في الكبير ٧/٢٩٠ (٧١٦٧)، والشجري في ترتيب الأمالي الخميسية ٢/٣٠٦ (٢٥٤٤)، من طريق حميد الشامي، عن محمود بن الربيع، عن شداد به.</p><p>إسناده ضعيف؛ لجهالة حميد الشامي، وهو ابن أبي حميد الحمصي، قال عنه ابن حجر في التقريب (١٥٦٧): «مجهول».|3:أخرجه ابن جرير ١٩/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٦٠٦.|5:تفسير يحيى بن سلام ٢/٨٣٠.
  37,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ لَهُمۡ رِزۡقࣱ مَّعۡلُومࣱ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span>، قال: في الجنة{1}. (١٢/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span>، قال: في الجنة{2}. (١٢/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأخبر ما أعدَّ لهم، فقال -جلَّ وعز-: <span class="qpc-hafs">﴿أُولئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span>، يعني بالمعلوم: حين يشتهونه يُؤتون به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</span> الجنة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٩/٥٣٠.|3:تفسير مقاتل بن سليمان ٣/٦٠٦.|4:تفسير يحيى بن سلام ٢/٨٣٠.
  37,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَ ٰ⁠كِهُ وَهُم مُّكۡرَمُونَ ۝٤٢ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝٤٣ عَلَىٰ سُرُرࣲ مُّتَقَـٰبِلِینَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم بيَّن الرِّزق، فقال -تبارك وتعالى-: <span class="qpc-hafs">﴿فَواكِهُ وهُمْ مُكْرَمُونَ * فِي جَنّاتِ النَّعِيمِ * عَلى سُرُرٍ مُتَقابِلِينَ﴾</span> في الزِّيارة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَواكِهُ وهُمْ مُكْرَمُونَ * فِي جَنّاتِ النَّعِيمِ * عَلى سُرُرٍ مُتَقابِلِينَ﴾</span> والسرر مرمولة بالذهب، وبقضبان اللؤلؤ الرطب، <span class="qpc-hafs">﴿مُتَقابِلِينَ﴾</span> لا ينظر بعضهم إلى قفا بعض{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.|2:تفسير يحيى بن سلام ٢/٨٣٠.
  37,43,""
  37,44,""
  37,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُطَافُ عَلَیۡهِم بِكَأۡسࣲ مِّن مَّعِینِۭ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿يُطافُ عَلَيْهِمْ بِكَأْسٍ مِن مَعِينٍ﴾</span>، قال: الخمر{1}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿بِكَأْسٍ مِن مَعِينٍ﴾</span>، قال: المعين: الخمر{2}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق سلمة بن نبيط- قال: <span class="qpc-hafs">﴿بِكَأْسٍ مِن مَعِينٍ﴾</span> كل كأسٍ ذكره الله في القرآن إنما عُنِي به الخمر{3}. (١٢/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿بِكَأْسٍ مِن مَعِينٍ﴾</span> هو الجاري{4}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بِكَأْسٍ مِن مَعِينٍ﴾</span>، قال: كأس مِن خمر جارية، والمعين هي الجارية{5}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿بِكَأْسٍ مِن مَعِينٍ﴾</span>، قال: الخمر. والكأس عند العرب: كلُّ إناء فيه شراب، فإن لم يكن فيه شرابٌ لم يكن كأسًا، ولكنه يكون إناء{6}<span class=comment-ref>٥٤٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٦</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٨٢): «وذهب بعض الناس إلى أن الكأس آنية مخصوصة في الأواني، وهو: كل ما اتسع فمه، ولم يكن له مقبض. ولا يراعى في ذلك كونه بخمرٍ أم لا».</div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>-من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿بكأس﴾</span>، قال: الخمر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُطافُ عَلَيْهِمْ﴾</span> يعني: يتقلب عليهم بأيدي الغلمان الخدم <span class="qpc-hafs">﴿بِكَأْسٍ﴾</span> يعني: الخمر <span class="qpc-hafs">﴿مِن مَعِينٍ﴾</span> يعني: الجاري{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يُطافُ عَلَيْهِمْ بِكَأْسٍ﴾</span> وهي الخمر <span class="qpc-hafs">﴿مِن مَعِينٍ﴾</span> الجاري الظاهر{9}<span class=comment-ref>٥٤٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٧</span> قال <u>ابنُ عطية</u> (٧/٢٨٢): «وقوله تعالى: <span class="qpc-hafs">﴿مِن مَعِينٍ﴾</span> يريد: مِن <b>جارٍ مطرد</b>، فالميم فيه أصلية؛ لأنه من الماء المعين. <b>ويحتمل</b> أن يكون من العين، فتكون الميم زائدة، أي: مما يعيّن بالعين غير مستور ولا في خزن».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٣٣، وابن أبي حاتم -كما في الإتقان ٢/٣٩-، والبيهقي في البعث (٣٥٧). وعزاه السيوطي إلى ابن المنذر.|2:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.|3:أخرجه ابن جرير ١٩/٥٣١ بنحوه، وهناد في الزهد (٧٢). وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٩/٥٣١. كما أخرجه بنحوه عبد الرزاق ٢/١٤٨ من طريق معمر، وابن أبي شيبة ١٤/٦٢،. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم بلفظ: كأس من خمر لم تُعصر.|6:أخرجه ابن جرير ١٩/٥٣١.|7:أخرجه أبو جعفر الرملي في جزئه ص١١٥ (تفسير عطاء الخراساني).|8:تفسير مقاتل بن سليمان ٣/٦٠٦.|9:تفسير يحيى بن سلام ٢/٨٣٠.
  37,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَیۡضَاۤءَ لَذَّةࣲ لِّلشَّـٰرِبِینَ ۝٤٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٤١<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، في قوله: <span class="qpc-hafs">﴿بَيْضاءَ﴾</span>، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (صَفْرَآءَ){1}. (١٢/٤٠١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَیۡضَاۤءَ لَذَّةࣲ لِّلشَّـٰرِبِینَ ۝٤٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٤٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿بَيْضاءَ﴾</span> خمر الجنة، أشدُّ بياضًا مِن اللبن{2}<span class=comment-ref>٥٤٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٧٢ ط: دار الكتب العلمية) أن قوله: <span class="qpc-hafs">﴿بَيْضاءَ﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يعود على الكأس. <b>الثاني</b>: أن يعود على الخمر. و<span class="comment-type-3">رجَّحه</span> بقوله: «وهو الأظهر». ثم أورد قول الحسن.</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٣١.</p><p>و<span class="qpc-hafs">﴿بَيْضاءَ﴾</span> قراءة العشرة، أما (صَفْرَآءَ) فقراءة شاذة. انظر: مختصر ابن خالويه ص١٢٨.|2:تفسير البغوي ٧/٤٠.
  37,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا فِیهَا غَوۡلࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>، قال: ليس فيها صُداع{1}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>، قال: هي الخمر، ليس فيها وجَع بطن{2}. (١٢/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: في الخمر أربع خصال: السُّكر، والصداع، والقَيْء، والبول، فنَزَّه اللهُ خمر الجنة عنها، <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span> لا تَغُول عقولهم مِن السُّكر{3}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرْني عن قوله: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>. قال: ليس فيها نتَنٌ، ولا كراهية كخمر الدنيا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت امرأ القيس وهو يقول:</p><p>رب كأسٍ شربتُ لا غول فيـ ـها وسقيتُ النديم منها مزاجا{4}. (١٢/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- في قوله: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>، قال: لا مكروه فيها، ولا أذى{5}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>، قال: وجَعُ بطن{6}. (١٢/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٤٩<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span> لا تغتال عقولَهم فتذهَب بها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span> صُداع{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لا فِيها غَوْل﴾</span>، قال: لا تغتال عقولهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>، أي: إثم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span> لا غائِلَة عليها يرجع منها الرأس، كفعل خمر الدنيا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span>، قال: الغول: ما يُوجع البطون، وشارب الخمر ههنا يشتكي بطنه{2}<span class=comment-ref>٥٤٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٧٩</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿لا فيها غول﴾</span> على خمسة أقوال: <b>الأول</b>: ليس فيها وجع البطن. و<b>الثاني</b>: ليس فيها صداع. و<b>الثالث</b>: ليس فيها ما يغتال العقل. و<b>الرابع</b>: ليس فيها إثم. و<b>الخامس</b>: ليس فيها أذى ولا مكروه.</p><p><span class="comment-type-4">ذهب</span> <u>ابنُ كثير</u> (١٢/١٧) إلى القول الأول، ونصَّ على أنه «الصحيح». وهو قول ابن عباس، ومجاهد، وابن زيد.</p><p>و<span class="comment-type-4">ذهب</span> <u>ابنُ جرير</u> (١٩/٥٣٤-٥٣٥)، و<span class="comment-type-4">كذا</span> <u>ابنُ عطية</u> (٧/٢٨٣) إلى أنّ اسم «الغول» يعُمّ كلّ تلك الأقوال، <span class="mustanad">استنادًا إلى اللغة والعموم</span>، فقال <u>ابنُ جرير</u>: «ولكل هذه الأقوال التي ذكرناها وجهٌ، وذلك أن الغول في كلام العرب: هو ما غال الإنسان فذهب به. فكل من ناله أمر يكرهه ضربوا له بذلك المثل، فقالوا: غالت فلانًا غول. فالذاهب العقل من شرب الشراب، والمشتكي البطن منه، والمصدع الرأس من ذلك، والذي ناله منه مكروه؛ كلهم قد غالته غول. فإذا كان ذلك كذلك، وكان الله -تعالى ذِكْرُه- قد نفى عن شراب الجنَّة أن يكون فيه غول، فالذي هو أولى بصفته أن يقال فيه كما قال -جل ثناؤه-: <span class="qpc-hafs">﴿لا فيها غول﴾</span> فيعم بنفي كل معاني الغول عنه، وأعم ذلك أن يقال: لا أذى فيها، ولا مكروه على شاربيها في جسم ولا عقل، ولا غير ذلك».</p><p>وقال <u>ابنُ عطية</u>: «والاسم أعم من هذا كله، فنفى عن خمر الجنة جميع أنواع الأذى؛ إذ هي موجودة في خمر الدنيا، نحا إلى هذا العموم سعيد بن جبير».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا هُمۡ عَنۡهَا یُنزَفُونَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، قال: لا تُنزف؛ فتذهَب عقولهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، قال: لا تُذْهِب عقولَهم{14}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span> لا يقيئون عنها كما يقيء صاحبُ خمر الدنيا عنها، والقيء مُستكْرَه{3}. (١٢/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>. قال: لا يسكرون. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عبد الله بن رواحة وهو يقول:</p><p>ثم لا يُنْزفون عنها ولكن يذهَب الهمُّ عنهم والغليل{4}. (١٢/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، قال: لا تُذهِب عقولهم{17}. (١٢/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لا فِيها غَوْلٌ ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، قال: لا تُذهب عقولهم، ولا تُصدِّع رؤوسهم، ولا تُوجع بطونهم{18}. (١٢/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، قال: لا تُنزف عقولهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، يعني: يسكرون، فتنزف عقولهم كخمر الدنيا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span>، قال: لا تنزف العقول{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</span> إذا شرِبوها لا تُذهب عقولهم، لا يسكرون{22}<span class=comment-ref>٥٤٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٠</span> <span class="comment-type-4">عَلَّقَ</span> <u>ابنُ جرير</u> (١٩/٥٣٦-٥٣٧) على الآثار، بقوله: "هذا التأويل الذي ذكرناه عمَّن ذكرنا عنه لم تُفَصِّل لنا رواتُه القراءةَ الذي هذا تأويلها، وقد يحتمل أن يكون ذلك تأويل قراءة مَن قرأها <span class="qpc-hafs">﴿يُنْزِفُون﴾</span>، و<span class="qpc-hafs">﴿يُنْزَفُون﴾</span> كلتيهما، وذلك أن <span class="mustanad">العرب تقول</span>: قد نُزِفَ الرجلُ فهو منزوف: إذا ذهب عقله من السكر، وأَنزَفَ فهو مُنزَف، محكية عنهم اللغتان كلتاهما في ذهاب العقل من السكر؛ وأما إذا فنيت خمر القوم فإني لم أسمع فيه إلا أنزَفَ القومُ بالألف، ومن الإنزاف -بمعنى: ذهاب العقل من السكر- قول الأبيرد:</p><p>لعمري لئن أنزفتم أو صحوتم ... لبئس الندامى كنتم آل أبجرا".</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٨٤-٢٨٥ بتصرف): «<span class="qpc-hafs">﴿يُنْزَفُون﴾</span> من أنزَفَ بمعنيين: <b>أحدهما</b>: سَكِرَ، ومنه قول الأبيرد الرياحي ... <b>والثاني</b>: بَعُدَ شرابُه، يقال: أنزف الرجل: إذا تم شرابه. فهذا كله منفي عن أهل الجنة».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٣٢، وابن أبي حاتم -كما في الإتقان ٢/٣٩-، والبيهقي في البعث (٣٥٧). وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ١٩/٥٣٣.|3:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|4:أخرجه الطستي -كما في الإتقان ٢/٧٤، ٩٦-.|5:أخرجه ابن جرير ١٩/٥٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|6:تفسير مجاهد (٥٦٨)، وأخرجه سفيان الثوري (٢٥٢) بنحوه، وابن جرير ١٩/٥٣٣، وهناد في الزهد (٧٣). وعلَّقه يحيى بن سلام ٢/٨٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|7:تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.|8:تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.|9:أخرجه ابن جرير ١٩/٥٣٣.|10:تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.|11:تفسير مقاتل بن سليمان ٣/٦٠٦.|12:أخرجه ابن جرير ١٩/٥٣٣.|13:أخرجه ابن جرير ١٩/٥٣٥-٥٣٦.|14:أخرجه ابن جرير ١٩/٥٣٥، وابن أبي حاتم -كما في الإتقان ٢/٣٩-، والبيهقي في البعث (٣٥٧). وعزاه السيوطي إلى ابن المنذر.|15:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|16:أخرجه الطستي -كما في الإتقان ٢/٧٤، ٩٦-.|17:تفسير مجاهد (٥٦٨)، وأخرجه ابن جرير ١٩/٥٣٦، وهناد في الزهد (٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|18:أخرجه عبد الرزاق ٢/١٤٨، وابن أبي شيبة ١٤/٦٢، وابن جرير ١٩/٥٣٦ من طريق سعيد مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|19:أخرجه ابن جرير ١٩/٥٣٣.|20:تفسير مقاتل بن سليمان ٣/٦٠٦.|21:أخرجه ابن جرير ١٩/٥٣٦.|22:تفسير يحيى بن سلام ٢/٨٣١.
  37,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعِندَهُمۡ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span>، يقول: عن غير أزواجهن{1}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span>، قال: قَصرن طرْفهن على أزواجِهِنَّ{2}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فضالة- <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span>: قصَرن طرْفهن على أزواجهن، فلا يُرِدْن غيرهم، واللهِ، ما هُنَّ مُتَبَرِّجات ولا مُتَطَلِّعات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ عِينٌ﴾</span>، قال: قصرن طرفهن على أزواجهن، فلا يُرِدْن غيرهم{4}. (١٢/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٦٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿قاصِراتُ الطَّرْفِ﴾</span>: يعني: قاصرات على أزواجهن، لا يبغين غيرهم{5}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span>، قال: قصرن أبصارهن وقلوبَهن على أزواجهن، فلا يُرِدْنَ غيرهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span> حافِظات النظر مِن الرجال غير أزواجهن، لا يَرَوْنَ غيرهم مِن العِشق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿قاصِراتُ الطَّرْفِ﴾</span>، قال: لا ينظُرْنَ إلّا إلى أزواجهن، قد قصرن أطرافهن على أزواجهن، ليس كما يكون نساء أهل الدنيا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</span>، يعني: الأزواج، قصرن طرفهن على أزواجهن، لا يُرِدْن غيرهم{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عِینࣱ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٧٤<span class="dash">-</span></span> عن أم سلمة زوج النبي ﷺ، أنّها قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله: <span class="qpc-hafs">﴿حُورٌ عِينٌ﴾</span> [الواقعة:٢٢]. قال: «<b>العين: الضِّخام العيون، شَفْرُ</b>{10} <b>الحوراء بمنزلة جناح النسر</b>»{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، قال: <span class="qpc-hafs">﴿عِينٌ﴾</span> شَفر عينها أطول مِن جناح النسر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عِينٌ﴾</span>، قال: حِسان العيون{13}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿عِينٌ﴾</span>، قال: العِين: العِظام الأعين{14}. (١٢/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿عِينٌ﴾</span>، قال: عِظام الأعين{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جل وعز-: <span class="qpc-hafs">﴿عِينٌ﴾</span>، يعني: حِسان الأعين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿عِينٌ﴾</span>، قال: العيناء: العَظيمة العين{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿عِينٌ﴾</span> عظام العيون، الواحدة منهن: عيناء، والعِين جماعتهن، نُسبن إلى عِظم العيون{9}<span class=comment-ref>٥٤٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨١</span> <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١٢/١٨): «<span class="qpc-hafs">﴿عين﴾</span> أي: حِسان الأعين. <b>وقيل</b>: ضِخام الأعين. وهو يرجع إلى الأول، وهي: النجلاء العيناء».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٣٧، وابن أبي حاتم -كما في في تغليق التعليق ٤/٢٩٤، والإتقان ٢/٣٩-، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد (٥٦٨)، وأخرجه ابن جرير ١٩/٥٣٨، وأخرجه من طريق منصور أيضًا. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه آدم بن أبي إياس -تفسير مجاهد (٥٦٨)-.|4:أخرجه عبد الرزاق ٢/١٤٩ من طريق معمر، وابن جرير ١٩/٥٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:عزاه السيوطي إلى ابن أبي حاتم. وقد وقع في الدر: لا يبغين غيرهن.|6:أخرجه ابن جرير ١٩/٥٣٨.|7:تفسير مقاتل بن سليمان ٣/٦٠٧.|8:أخرجه ابن جرير ١٩/٥٣٨.|9:تفسير يحيى بن سلام ٢/٨٣١.|10:الشفر -بالضم، وقد يفتح-: حرف جفن العين الذي ينبت عليه الشعر. النهاية (شفر).|11:أخرجه العقيلي في الضعفاء الكبير ٢/١٣٨ (٦٢٧) في ترجمة سليمان بن أبي كريمة عن هشام بن حسان، والطبراني في الأوسط ٣/٢٧٨ (٣١٤١) مطولًا، وابن جرير ١٩/٥٣٩.</p><p>قال العقيلي: «يحدّث بمناكير، ولا يتابع على كثير من حديثه». وقال ابن عدي في الكامل في الضعفاء ٤/٢٤٨-٢٤٩: منكر«. وقال الهيثمي في المجمع ١٠/٤١٧-٤١٨ (١٨٧٥٥):»رواه الطبراني في الأوسط والكبير بنحوه.. وفي إسنادهما سليمان بن أبي كريمة، وهو ضعيف".|12:علقه يحيى بن سلام ٢/٨٣١.|13:عزاه السيوطي إلى ابن جرير، وعبد بن حميد.|14:عزاه السيوطي إلى ابن أبي حاتم.|15:أخرجه ابن جرير ١٩/٥٣٩.|16:تفسير مقاتل بن سليمان ٣/٦٠٧.|17:أخرجه ابن جرير ١٩/٥٣٩.|18:تفسير يحيى بن سلام ٢/٨٣١.
  37,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَنَّهُنَّ بَیۡضࣱ مَّكۡنُونࣱ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٨٢<span class="dash">-</span></span> عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>. قال: «<b>رِقّتهن كرِقَّة الجِلدة التي في داخل البيضة مِمّا يلي القِشْر</b>»{1}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: اللؤلؤ المكنون{2}. (١٢/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: بياض البيضة يُنزَع عنها فوفها{3}، وغشاؤها الذي يكون في الفرْق{4}. (١٢/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: كأنّهُنَّ بطن البيض{5}. (١٢/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span> شبَّهَهُنَّ ببيض النعامة تكنها بالرِّيش من الريح والغبار، فلونها أبيض في صفرة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: محضون، لم تَمُر به الأيدي{7}. (١٢/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: البيض الذي لم تُلَوِّثه الأيدي{8}. (١٢/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>: لم تمر به الأيدي ولم تمسّه، يُشبهن بياضه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: بياض البيض حين يُنزع قشره{10}. (١٢/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحسن بن يزيد الأصم- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: البيض في عُشِّه المكنون{11}. (١٢/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: هو السِّحاء الذي يكون بين القشرة العليا ولباب البيضة{12}. (١٢/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: البيض الذي يُكنُّه الريش، مثل بيض النعام الذي أكنَّه الريشُ مِن الريح، فهو أبيض إلى الصفرة، فكانت تَتَرَقْرَقُ{13}، فذلك المكنون{7}. (١٢/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم شبَّههن ببياض البيض الذي الصُّفرة في جوفه، فقال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، قال: البيض الذي يُكنُّه الريش، مثل بيض النعام الذي قد أكنَّه الريش مِن الريح، فهو أبيض إلى الصفرة، فكأنه يَبْرُقُ، فذلك المكنون{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span> وبعضهم يقول: هي القشرة الداخلة. وبعضهم يقول: يعني بالبيض: اللؤلؤ، كقوله: <span class="qpc-hafs">﴿وحُورٌ عِينٌ * كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</span> [الواقعة:٢٢-٢٣] في أصدافه{17}<span class=comment-ref>٥٤٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٢</span> اختُلِف في تأويل قوله تعالى: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span> على ثلاثة أقوال: <b>الأول</b>: أنهن شُبِّهن ببطن البيض في البياض، وهو الذي داخل القشر، وذلك أن ذلك لم يمسه شيء. وهذا قول سعيد بن جبير، والسديّ، وقتادة. و<b>الثاني</b>: أنهن شُبِّهن بالبيض الذي يحضنه النعام، في بياض قشره الذي قد خالطته صفرة حسنة. وهذا قول ابن زيد. و<b>الثالث</b>: أنهن شُبِّهن باللؤلؤ المكنون في بياضه ونقائه. وهذا قول ابن عباس.</p><p>وزاد <u>ابنُ عطية</u> (٧/٢٨٦) <b>قولًا رابعًا</b>، <span class="comment-type-4">فقال</span>: «وقالت فرقة: إنما شبههن تعالى بالبيض المكنون تشبيهًا عامًّا؛ جملة المرأة بجملة البيضة، وأراد بذلك تناسب أجزاء المرأة، وأن كل جزء منها نسبته في الجودة إلى نوعه نسبة الآخر من أجزائه إلى نوعه، فنسبة شعرها إلى عينها مستوية؛ إذ هما غاية في نوعهما، والبيضة أشد الأشياء تناسب أجزاء؛ لأنك من حيث جئتها فالنظر فيها واحد».</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (١٩/٥٤١-٥٤٢ بتصرف) القولَ الأولَ <span class="mustanad">لدلالة اللغة، والعقل، وأقوال السلف</span>، و<span class="comment-type-2">انتَقَدَ</span> الثاني، فقال: «أولى الأقوال في ذلك بالصواب عندي قول مَن قال: شبهن في بياضهن وأنهن لم يمسهن قبل أزواجهن إنس ولا جان ببياض البيض الذي هو داخل القشر، وذلك هو الجلدة الملْبَسةُ المحَّ قبل أن تمسه يد أو شيء غيرها، وذلك لا شك هو المكنون؛ فأما القشرة العُليا فإن الطائر يمسها، والأيدي تباشرها، والعش يلقاها. والعرب تقول لكل مصون: مكنون ما كان ذلك الشيء؛ لؤلؤًا كان أو بيضًا أو متاعًا ... وتقول لكل شيء أضمرته الصدور: أكنته، فهو مُكَنٌّ. وبنحو الذي قلنا في ذلك جاء الأثر عن رسول الله ﷺ ... عن أم سلمة، قلت: يا رسول الله، أخبِرني عن قوله <span class="qpc-hafs">﴿كأنهن بيض مكنون﴾</span>. قال: «<b>رقتهن كرقة الجلدة التي رأيتها في داخل البيضة التي تلي القشر</b>» وهي الغِرْقيء».</p><p>و<span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٧/٢٨٦) القول الثالث، فقال: «هذا لا يصح عندي عن ابن عباس ﵄؛ لأنه <span class="mustanad">تردُّه اللفظة من الآية</span>».</div></p></div>",footnotes:1:أخرجه الطبراني مطولًا في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥. وعزاه السيوطي إلى ابن مردويه. وسيأتي مطولًا مع تخريجه عند تفسير قوله تعالى: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> [الرحمن:٧٠].</p><p>قال الطبراني في الأوسط: «لم يرو هذا الحديث عن هشام بن حسان إلا سليمان بن أبي كريمة، تفرَّد به عمرو بن هاشم». وقال ابن الجوزي في العلل المتناهية ٢/١٦١ (١٠٧٧): «هذا حديث لا يصح». وقال الضياء المقدسي في صفة الجنة ص١٢٤ (١١٩): «لا أعلمه رُوي إلا من طريق سليمان بن أبي كريمة، وفيه كلام». وقال ابن القيم في حادي الأرواح ص٢٢٩: «تفرد به سليمان بن أبي كريمة، ضعّفه أبو حاتم، وقال ابن عدي: عامة أحاديثه مناكير. ولم أر للمتقدمين فيه كلامًا، ثم ساق هذا الحديث من طريقه، وقال: لا يُعرف إلا بهذا السند». وقال ابن مفلح في الآداب الشرعية ٢/٢٠٧: «في إسناده سليمان بن أبي كريمة، وهو ضعيف». وقال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «فيه سليمان بن أبي كريمة؛ ضعّفه أبو حاتم، وابن عدي».|2:أخرجه ابن جرير ١٩/٥٤١، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٩٤، والإتقان ٢/٣٩-، والبيهقي في البعث (٢٧٧). وعزاه السيوطي إلى ابن المنذر.|3:الفُوف: القشرة التي على النَّواة، وكل قشرة فوف. النهاية واللسان (فوف).|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٩/٥٤٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم. وأخرجه إسحاق البستي ص٢٠١ موقوفًا على جعفر من قوله.|6:تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:أخرجه عبد الرزاق ٢/١٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:أخرجه ابن جرير ١٩/٥٤٠. وعلق يحيى بن سلام ٢/٨٣١ نحوه.|10:أخرجه ابن جرير ١٩/٥٤٠ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.|11:أخرجه سعيد بن منصور في سننه- التفسير ٧/١٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|12:أخرجه عبد الرزاق ٢/١٤٩. وعزاه السيوطي إلى ابن أبي حاتم.|13:ترَقرق الشيء: تلألأ. اللسان (رقق).|14:عزاه السيوطي إلى ابن أبي حاتم.|15:تفسير مقاتل بن سليمان ٣/٦٠٧.|16:أخرجه ابن جرير ١٩/٥٤٠.|17:تفسير يحيى بن سلام ٢/٨٣١.
  37,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٣٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، قال: أهل الجنة{1}. (١٢/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، أي: أهل الجنة حين يتكلمون، يكلِّم بعضهم بعضًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٣٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، قال: أهل الجنة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، يعني: أهل الجنة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٦٠٧.|3:أخرجه ابن جرير ١٩/٥٤٢.|4:تفسير يحيى بن سلام ٢/٨٣١.
  37,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ قَاۤىِٕلࣱ مِّنۡهُمۡ إِنِّی كَانَ لِی قَرِینࣱ ۝٥١ یَقُولُ أَءِنَّكَ لَمِنَ ٱلۡمُصَدِّقِینَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ * يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</span>، قال: هو الرجل المشرك يكون له الصاحبُ في الدنيا مِن أهل الإيمان، فيقول له المشرك: إنك لَتُصدِّق بأنّك مبعوثٌ مِن بعد الموت أئذا كنا ترابًا؟! فلمّا أن صاروا إلى الآخرة وأُدخل المؤمن الجنة، وأُدخل المشرك النار، فاطَّلع المؤمن فرأى صاحبه في سواء الجحيم، قال: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٢<span class="dash">-</span></span> عن <span class="name-2">فرات بن ثعلبة البهراني</span> -من طريق خصيف- في قوله: <span class="qpc-hafs">﴿إنِّي كانَ لِي قَرِينٌ﴾</span>، قال: ذُكر لي: أنّ رجلين كانا شريكين، فاجتمع لهما ثمانيةُ آلاف دينار، فكان أحدهما ليس له حِرفة، والآخر له حِرفة، فقال: إنه ليس لك حِرفة، فما أراني إلا مُفارقك ومُقاسمك. فقاسمه، ثم فارقه، ثم إنّ أحد الرجلين اشترى دارًا كانت لِمَلِك بألف دينار، فدعا صاحبه، فقال: كيف ترى هذه الدار؟ ابتعتها بألف دينار. فقال: ما أحسنها! فلما خرج قال: اللهم، إنّ صاحبي قد ابتاع هذه الدار، وإنِّي أسألك دارًا مِن الجنة. فتصدّق بألف دينار، ثم مكث ما شاء الله أن يمكث، ثم تزوج امرأةً بألف دينار، فدعاه، وصنع له طعامًا، فلمّا أتاه قال: إنِّي تزوجتُ هذه المرأة بألف دينار. قال: ما أحسن هذا! فلمّا خرج قال: اللهم، إن صاحبي تزوج امرأة بألف دينار، وإني أسألك امرأة مِن الحور العين. فتصدّق بألف دينار، ثم إنّه مكث ما شاء الله أن يمكث، ثم اشترى بستانين بألفي دينار، ثم دعاه، فأراه، وقال: إني ابتعت هذين البستانين بألفي دينار. فقال: ما أحسن هذا! فلمّا خرج قال: يا ربِّ، إن صاحبي قد ابتاع بستانين بألفي دينار، وإني أسألك بستانين في الجنة. فتصدق بألفي دينار، ثم إنّ الملك أتاهما، فتوفّاهما، فانطلق بهذا المتصدق، فأدخله دارًا تُعجِبه، فإذا امرأة يضيء ما تحتها مِن حُسنها، ثم أدخله البستانين وشيئًا الله به عليم، فقال عند ذلك: ما أشبه هذا برجلٍ كان مِن أمره كذا وكذا. قال: فإنه ذلك، ولك هذا المنزل والبستانان والمرأة. فقال: إنّه كان لي قرين يقول: <span class="qpc-hafs">﴿أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</span>. قيل له: فإنه في الجحيم. قال: <span class="qpc-hafs">﴿قالَ هَلْ أنْتُمْ مُطَّلِعُونَ * فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span>، فقال عند ذلك: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>{2}<span class=comment-ref>٥٤٨٣</span>. (١٢/٤٠٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٣</span> <span class="comment-type-4">عَلَّقَ</span> <u>ابنُ جرير</u> (١٩/٥٤٥) على هذا الأثر بقوله: «هذا التأويل الذي تأوله فرات بن ثعلبة يقوي قراءة مَن قرأ: (إنَّكَ لَمِنَ المصَّدِّقينَ) بتشديد الصاد، بمعنى: لمن المتصدِّقين؛ لأنه يذكر أن الله -تعالى ذكره- إنما أعطاه ما أعطاه على الصدقة لا على التصديق. وقراءة قراء الأمصار على خلاف ذلك، بل قراءتها بتخفيف الصاد وتشديد الدال، بمعنى: إنكار قرينه عليه التصديق أنه يبعث بعد الموت، كأنه قال: أتصدق بأنك تبعث بعد مماتك، وتجزى بعملك، وتحاسب؟ يدل على ذلك قول الله: <span class="qpc-hafs">﴿أئذا متنا وكنا ترابا وعظاما أئنا لمدينون﴾</span>، وهي القراءة الصحيحة عندنا التي لا يجوز خلافها؛ <span class="mustanad">لإجماع الحجة من القراء عليها</span>».</div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنِّي كانَ لِي قَرِينٌ﴾</span>، قال: شيطان{3}<span class=comment-ref>٥٤٨٤</span>. (١٢/٤٠٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٤</span> قال <u>ابنُ عطية</u> (٧/٢٨٦ بتصرف) <span class="comment-type-4">مُبيِّنًا</span> القرينين المذكورين: «<b>قال</b> ابنُ عباس وغيره: كان هذان من البشر مؤمن وكافر. <b>وقالت فرقة</b>: هما اللذان ذكر الله تعالى في قوله:<span class="qpc-hafs">﴿يا ويلتى ليتني لم أتخذ فلانا خليلًا﴾</span> [الفرقان:٢٨]. <b>وقال</b> مجاهد: كان إنسيًّا وجنيًّا مِن الشياطين الكفرة. والأول <span class="comment-type-3">أصوب</span>». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: <span class="qpc-hafs">﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ * يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</span> كانا شريكين في بني إسرائيل؛ أحدهما مؤمن، والآخر كافر، فافترقا على ستة آلاف دينار، كل واحد منهما ثلاثة آلاف دينار، ثم افترقا فمكثا ما شاء الله أن يمكثا، ثم التقيا، فقال الكافر للمؤمن: ما صنعت في مالك، أضربت به شيئًا، أتَّجَرْت به في شيء؟ قال له المؤمن: لا، فما صنعت أنت؟ قال: اشتريتُ به أرضًا ونخلًا وثمارًا وأنهارًا بألف دينار. فقال له المؤمن: أوَفعلت؟ قال: نعم. فرجع المؤمن، حتى إذا كان الليلُ فصلّى ما شاء الله أن يصلي، فلما انصرف أخذ ألف دينار، فوضعها بين يديه، ثم قال: اللهم، إنّ فلانًا -يعني: شريكه الكافر- اشترى أرضًا ونخلًا وثمارًا وأنهارًا بألف دينار، ثم يموت غدًا ويتركها، اللهم، إني أشتري منك بهذه الألف دينار أرضًا ونخلًا وثمارًا وأنهارًا في الجنة. ثم أصبح فقسمها في المساكين، ثم مكثا ما شاء الله أن يمكثا، ثم التقيا، فقال الكافر للمؤمن: ما صنعتَ في مالك أضربت به في شيء، أتَّجرت به في شئ؟ قال: لا. قال: فما صنعت أنت؟ قال: كانت ضيعتي قد اشتد علي مؤنتها، فاشتريت رقيقًا بألف دينار يقومون لي فيها، ويعملون لي فيها. فقال المؤمن: أوَفعلت؟ قال: نعم. فرجع المؤمن، حتى إذا كان الليل صلى ما شاء الله أن يصلي، فلما انصرف أخذ ألف دينار، فوضعها بين يديه، ثم قال: اللهمَّ، إنّ فلانًا اشترى رقيقًا مِن رقيق الدنيا بألف دينار، يموت غدًا فيتركهم، أو يموتون فيتركونه، اللهم، وإنِّي أشتري منك بهذه الألف دينار رقيقًا في الجنة. ثم أصبح فقسمها في المساكين، ثم مكثا ما شاء الله أن يمكثا، ثم التقيا، فقال الكافر للمؤمن: ما صنعت في مالك، أضربت به في شيء، أتجرت به في شيء؟ قال: لا، فما صنعت أنت؟ قال: كان أمري كله قد تم إلا شيئًا واحدًا؛ فلانة مات عنها زوجُها، فأصدقتها ألف دينار، فجاءتني بها ومثلها معها. فقال له المؤمن: أوَفعلت؟ قال: نعم. فرجع المؤمن، حتى إذا كان الليل صلى ما شاء الله أن يصلي، فلمّا انصرف أخذ الألف دينار الباقية، فوضعها بين يديه، وقال: اللهمَّ، إنّ فلانًا تزوج زوجة مِن أزواج الدنيا بألف دينار، ويموت غدًا فيتركها أو تموت فتتركه، اللهم، وإنِّي أخطب إليك بهذه الألف دينار حوراء عيناء في الجنة. ثم أصبح، فقسمها بين المساكين، فبقي المؤمنُ ليس عنده شيء، فلبس قميصًا مِن قطن، وكساء من صوف، ثم جعل يعمل ويحفر بقوته، فجاء رجل، فقال: يا عبد الله، أتُؤاجرني نفسك مشاهرة شهرًا بشهر، تقوم على دوابَّ لي؟ قال: نعم. فكان صاحب الدواب يغدو كل يوم ينظر إلى دوابه، فإذا رأى منها دابَّة ضامِرَةً أخذ برأسه، فوجأ{4} عنقه، ثم يقول له: سرقت شعير هذه البارحة. فلما رأى المؤمن الشدة قال: لآتِيَنَّ شريكي الكافر، فلَأعملنَّ في أرضه، يُطعمني هذه الكسرة يومًا بيوم، ويكسيني هذين الثوبين إذا بليا. فانطلق يريده، فانتهى إلى بابه، وهو ممسٍ، فإذا قصر مشيد في السماء، وإذا حوله البوابون، فقال لهم: استأذنوا لي صاحب هذا القصر؛ فإنّكم إن فعلتم ذلك سَرَّه. فقالوا له: انطلق، فإن كنت صادقًا فنم في ناحية، فإذا أصبحت فتعرَّض له. فانطلق المؤمن، فألقى نصف كسائه تحته ونصفه فوقه، ثم نام، فلما أصبح أتى شريكه، فتعرَّض له، فخرج شريكُه وهو راكب، فلمّا رآه عرفه، فوقف فسلم عليه وصافحه، ثم قال له: ألم تأخذ من المال مثل ما أخذت؟ فأين مالك؟ قال: لا تسألني عنه. قال: فما جاء بك؟ قال: جئتُ أعمل في أرضك هذه، تطعمني هذه الكسرة يومًا بيوم، وتكسوني هذين الثوبين إذا بليا. قال: لا ترى مِنِّي خيرًا حتى تخبرني ما صنعتَ في مالك. قال: أقرضتُه. قال: مَن؟ قال: المَليء الوفي. قال: مَن؟ قال: الله ربي. وهو مصافحه، فانتزع يده، ثم قال: <span class="qpc-hafs">﴿أإنَّكَ لَمِنَ المُصَدِّقِينَ * أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</span>؟! وتركه، فلما رآه المؤمن لا يلوي عليه رجع وتركه، يعيش المؤمن في شدة مِن الزمان، ويعيش الكافر في رخاء من الزمان. فإذا كان يوم القيامة، وأدخل الله المؤمن الجنة؛ يمر، فإذا هو بأرض ونخل وثمار وأنهار، فيقول: لِمَن هذا؟ فيقال: هذا لك. فيقول: أوَبلغ مِن فضل عملي أن أثاب بمثل هذا؟! ثم يمر فإذا هو برقيق لا تحصى عِدَّتهم، فيقول: لِمَن هذا؟ فيقال: هؤلاء لك. فيقول: أوَبلغ مِن فضل عملي أن أُثاب بمثل هذا؟! ثم يمر فإذا هو بقُبَّةٍ مِن ياقوتة حمراء مجوفة، فيها حوراء عيناء، فيقول: لِمَن هذه؟ فيقال: هذه لك. فيقول: أوَبلغ مِن فضل عملي أن أُثاب بمثل هذا؟! ثم يذكر شريكه الكافر، فيقول: <span class="qpc-hafs">﴿إنِّي كانَ لِي قَرِينٌ * يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</span>. قال: فالجنة عالية، والنار هاوية، فيريه الله شريكه في وسط الجحيم مِن بين أهل النار، فإذا رآه عرفه المؤمن، فيقول: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ * ولَوْلا نِعْمَةُ رَبِّي لَكُنْتُ مِنَ المُحْضَرِينَ * أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ * إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ * لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</span> بمثل ما قد مُنَّ عليه. قال: فيتذكر المؤمن ما مرَّ عليه في الدنيا مِن الشدة، فلا يذكر أشدَّ عليه مِن الموت{5}. (١٢/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق معمر- قال: كان رجلان شريكين، وكان لهما ثمانية آلاف دينار، فاقتسماها، فَعَمَدَ أحدُهما فأشترى بألف دينار أرضًا، فقال صاحبُه: اللهم، إنّ فلانًا اشترى بألف دينار أرضًا، وإنِّي أشتري منك بألف دينار أرضًا في الجنة. فتصدق بألف دينار، ثم ابتنى صاحبه دارًا بألف دينار، فقال هذا: اللهم، إن فلانًا ابتنى دارًا بألف دينار، وإنِّي أشتري منك دارًا في الجنة بألف دينار. فتصدّق بألف دينار، ثم تزوج صاحبُه امرأة، فأنفق عليها ألف دينار، فقال: اللهم، إنّ فلانا تزوج امرأة، فأنفق عليها ألف دينار، وإني أخطب إليك من نساء الجنة بألف دينار. فتصدَّق بألف دينار، ثم اشترى خدمًا ومتاعًا بألف دينار، فقال: اللهم، إنّ فلانًا اشترى خدمًا ومتاعًا بألف دينار، وإني أشتري منك خدمًا ومتاعًا في الجنة بألف دينار. فتصدق بألف دينار، ثم أصابته حاجة شديدة، فقال: لو أتيتُ صاحبي هذا لعلَّه ينالني معروف. فجلس على طريقه، فمرَّ به في حَشَمه وأهله، فقام إليه، فنظر الآخرُ فعرفه، فقال: فلان؟! فقال: نعم. فقال: ما شأنُك؟ فقال: أصابتني بعدك حاجةٌ، فأتيتك لتصيبني بخير. قال: فما فعل مالُك؛ فقد اقتسمنا مالًا واحدًا، فأخذت شطرَه وأنا شطرَه. فقال: اشتريتَ دارًا بألف دينار، ففعلتُ أنا كذلك، وفعلتَ أنت كذا، وفعلتُ أنا كذا. فقصّ عليه القصة، فقال: إنك لمن المصدقين بهذا؟! اذهب فواللهِ لا أعطيك شيئًا. فردّه، فقُضي لهما أن تُوفيا؛ فنزلت فيهما: <span class="qpc-hafs">﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</span> حتى بلغ: <span class="qpc-hafs">﴿أإنّا لَمَدِينُونَ﴾</span> قال: لَمُحاسبون{6}. (١٢/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ﴾</span> وذلك أنّ أخوين مِن بني إسرائيل -اسم أحدهما: فطرس، والآخر: سلخا- ورِث كلُّ واحدٍ منهما عن أبيه أربعة آلاف دينار، فأمّا أحدهما فأنفق ماله في طاعة الله ﷿، والمشرك الآخر أنفق مالَه في معصية الله ﷿ ومعيشة الدنيا، وهما اللذان ذكرهما الله ﷿ في سورة الكهف، فلمّا صارا إلى الآخرة أُدخِل المؤمن الجنة، وأُدخل المشرك النار، فلما أُدخل الجنة المؤمن ذكر أخاه، فقال لإخوانه من أهل الجنة: <span class="qpc-hafs">﴿إنِّي كانَ لِي قَرِينٌ﴾</span> يعني: صاحب، <span class="qpc-hafs">﴿يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</span> بالبعث{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ﴾</span> صاحب في الدنيا، <span class="qpc-hafs">﴿يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</span> على الاستفهام{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٤٣.|2:أخرجه سعيد بن منصور في سننه - التفسير ٧/١٤٨، وابن جرير ١٩/٥٤٣-٥٤٥.|3:تفسير مجاهد (٥٦٨)، وأخرجه يحيى بن سلام ٢/٨٣٢ من طريق ابن مجاهد، وابن جرير ١٩/٥٤٣، والفريابي -كما في التغليق ٤/٣٩٤-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:وجأ عنقه: ضربه. لسان العرب ١/١٩٠.|5:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/١٤-١٦-.|6:أخرجه عبد الرزاق ٢/١٤٩ مقتصرًا على أوله، وإسحاق البستي ص٢٠٢. وعزاه السيوطي إلى ابن المنذر.|7:تفسير مقاتل بن سليمان ٣/٦٠٧-٦٠٨.|8:تفسير يحيى بن سلام ٢/٨٣١.