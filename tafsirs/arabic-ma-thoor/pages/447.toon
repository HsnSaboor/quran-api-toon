quran[27]{c,v,t}:
37,25," <q>﴿مَا لَكُمۡ لَا تَنَاصَرُونَ ۝٢٥ بَلۡ هُمُ ٱلۡیَوۡمَ مُسۡتَسۡلِمُونَ ۝٢٦﴾</q> - تفسير ٦٥٢٦٠- عن عبد الله بن عباس، في قوله: <q>﴿ما لَكُمْ لا تَناصَرُونَ﴾</q> قال: لا تمانعون مِنّا، <q>﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q> مُسْتَنجِدون{1}. (١٢/٣٩٧) ٦٥٢٦١- قال عبد الله بن عباس: <q>﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q> خاضِعون{2}. (ز) ٦٥٢٦٢- قال الحسن البصري: <q>﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q> مُنقادون{2}. (ز) ٦٥٢٦٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ما لَكُمْ لا تَناصَرُونَ﴾</q> قال: لا، واللهِ، لا يتناصرون، ولا يدفع بعضكم عن بعض، <q>﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q> يعني: في عذاب الله{4}. (١٢/٣٩٧) ٦٥٢٦٤- قال مقاتل بن سليمان: يقول الخازن: <q>﴿ما لَكُمْ لا تَناصَرُونَ﴾</q>. نظيرها في الشعراء [٩٣]: <q>﴿هَلْ يَنْصُرُونَكُمْ أوْ يَنْتَصِرُونَ﴾</q>. يقول الكفار: ما لشركائكم الشياطين لا يمنعونكم مِن العذاب. يقول اللَّه ﷿ لمحمد ﷺ: <q>﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q> للعذاب{5}. (ز) ٦٥٢٦٥- قال يحيى بن سلّام: <q>﴿ما لَكُمْ لا تَناصَرُونَ﴾</q> يُقال لهم: <q>﴿ما لَكُمْ لا تَناصَرُونَ﴾</q> لا ينصر بعضُكم بعضًا، <q>﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</q> استسلموا{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.تفسير الثعلبي ٨/١٤٣، وتفسير البغوي ٧/٣٨.تفسير الثعلبي ٨/١٤٣، وتفسير البغوي ٧/٣٨.أخرجه ابن جرير ١٩/٥٢٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٥.تفسير يحيى بن سلام ٢/٨٢٨.
  37,26,""
37,27," <q>﴿وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ ۝٢٧﴾</q> - تفسير ٦٥٢٦٦- عن عبد الله بن عباس، في قوله: <q>﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>: أقبل بعضُهم يلوم بعضًا{1}. (١٢/٣٩٧) ٦٥٢٦٧- عن عبد الله بن عباس، في قوله: <q>﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>، قال: ذلك إذا بُعِثوا في النفخة الثانية{2}. (١٢/٣٩٨) ٦٥٢٦٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>، قال: الإنس على الجن{3}. (١٢/٣٩٧) ٦٥٢٦٩- قال مقاتل بن سليمان: <q>﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q> يتكلَّمون{4}. (ز) ٦٥٢٧٠- قال يحيى بن سلّام: <q>﴿وأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q> الإنس والشياطين{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٥.تفسير يحيى بن سلام ٢/٨٢٩.
37,28," <q>﴿قَالُوۤا۟ إِنَّكُمۡ كُنتُمۡ تَأۡتُونَنَا عَنِ ٱلۡیَمِینِ ۝٢٨﴾</q> - تفسير ٦٥٢٧١- عن عبد الله بن عباس، قال: قال الضعفاء للذين استكبروا: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q> تقهروننا بالقُدرة مِنكم علينا{1}. (١٢/٣٩٧) ٦٥٢٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تَأْتُونَنا عَنِ اليَمِينِ﴾</q>، قال: عن الحق؛ الكفار تقوله للشياطين{2}. (١٢/٣٩٩) ٦٥٢٧٣- قال الضحاك بن مزاحم: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>، أي: مِن قِبَل الدين، فتُضِلُّوننا عنه، وتروننا أن الدين ما تضلوننا به{3}. (ز) ٦٥٢٧٤- عن عكرمة مولى ابن عباس -من طريق الحسين بن واقد- <q>﴿قالوا إنكم كنتم تأتوننا عن اليمين﴾</q>، قال: مِن حيث نأمنكم{4}. (ز) ٦٥٢٧٥- عن الحسن البصري، في قوله: <q>﴿كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>، قال: كانوا يأتونهم عند كل خير ليصدوهم عنه{5}. (١٢/٣٩٨) ٦٥٢٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: قالت الإنسُ للجن: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>. قال: مِن قِبل الخير فتنهوننا عنه، وتُبَطِّئوننا عنه{6}. (١٢/٣٩٧) ٦٥٢٧٧- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>، قال: يفتِنوننا عن طاعة الله{7}. (ز) ٦٥٢٧٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>، قال: تأتوننا مِن قِبل الحقِّ تُزَيِّنون لنا الباطل، وتصدُّوننا عن الحق{8}. (ز) ٦٥٢٧٩- عن محمد بن السائب الكلبي: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q> مِن قِبَل الدِّين، فصددتمونا عنه، وزينتم لنا الضلالة{9}. (ز) ٦٥٢٨٠- قال مقاتل بن سليمان: <q>﴿قالُوا﴾</q> قال قائل مِن الكفار لشركائهم الشياطين: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q> يعنون: مِن قِبل الحق. نظيرها في الحاقة [٤٥]: <q>﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</q> بالحق. وقالوا للشياطين: أنتم زينتم لنا ما نحن عليه؛ فقلتم: إنّ هذا الذي نحنُ عليه هو الحق{10}. (ز) ٦٥٢٨١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q> قال: قال بنو آدم للشياطين الذين كفروا: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>، قال: تَحُولُون بيننا وبين الخير، ورددتمونا عن الإسلام والإيمان، والعمل بالخير الذي أمَر الله به{8}. (ز) ٦٥٢٨٢- قال يحيى بن سلّام: <q>﴿قالُوا﴾</q> قالت الإنس للشياطين: <q>﴿إنَّكُمْ كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</q>{12}٥٤٧٤. (ز) ٥٤٧٤ قال ابنُ جرير (١٩/٥٢٤-٥٢٥) مبيّنًا معنى الآية استنادًا إلى أقوال السلف، واللغة: "قالت الإنس للجن: إنكم -أيها الجن- كنتم تأتوننا مِن قِبَلِ الدِّين والحق، فتخدعوننا بأقوى الوجوه. واليمين: القوة والقدرة في كلام العرب، ومنه قول الشاعر: إذا ما رايةٌ رُفِعَت لمجدٍ تَلَقَّاها عَرابةُ باليمينِ يعني: بالقوة والقدرة". وقال ابنُ عطية (٧/٢٧٨-٢٨٠ بتصرف): "اضطرب المتأولون في معنى قولهم: <q>﴿عن اليمين﴾</q>، وعَبَّر ابن زيد وغيره عنه بـ:طريق الجنة والخير. ونحو هذا من العبارات التي هي تفسير بالمعنى لا تختص باللفظة، وبعضهم نحا في تفسير الآية إلى ما يختصها، والذي يتحصل من ذلك معانٍ، منها: أن يريد بـ<q>﴿اليمين﴾</q>: القوة والشدة، فكأنهم قالوا: إنكم كنتم تغووننا بقوة منكم، وتحملوننا على طريق الضلالة بمتابعة منكم في شدة. فعَبَّر عن هذا المعنى بـ<q>﴿اليمين﴾</q> كما قالت العرب: بيدين ما أورد. وكما قالوا: اليد -في غير موضع- عن القوة، وقد ذهب بعض الناس ببيت الشماخ هذا المذهب، وهو قوله: إذا ما راية رفعت لمجد تلقاها عرابة باليمين فقالوا: معناه: بقوة وعزيمة، وإلا فكل أحد يتلقاها بيمينه، لو كانت الجارحة، وأيضًا فلما استعار الراية للمجد فكذلك لم يرد باليمين الجارحة. ومن المعاني التي تحتملها الآية أن يريدوا: إنكم كنتم تأتوننا من الجهة التي يحسِّنها تمويهكم وإغواؤكم، ويظهر فيها أنها جهة الرشد والصواب، فتصير عندنا كاليمين التي نتيمَّن بالسانح الذي يجيؤنا من قِبَلِها ... فكأنهم شبهوا أقوال هؤلاء المغوين بالسوانح التي هي عندهم محمودة، كأن التمويه في هذه الغوايات قد أظهر فيها ما يوشك أن يُحمد به. ومن المعاني التي تحتملها الآية أن يريدوا: إنكم كنتم تأتوننا -أي: تقطعون بنا- عن أخبار الخير واليمن. فعَبَّر عنها بـ<q>﴿اليمين﴾</q>؛ إذ اليمين هي الجهة التي يتيمن بكل ما كان منها وفيها. ومن المعاني التي تحتملها الآية أن يريدوا: إنكم كنتم تجيئوننا من جهة الشهوات وعدم النظر، والجهة الثقيلة من الإنسان وهي جهة اليمين منه؛ لأن كبده فيها، وجهة شماله فيها قلبه، وهي أخف، وهذا معنى قول الشاعر: تركنا لهم شق الشمال أي: نزلنا لهم عن موضع الهروب؛ لأن المنهزم إنما يرجع على شقه الأيسر؛ إذ هو أخف شقيه، وإذ قلب الإنسان في شماله، وثم نظره، فكأن هؤلاء كانوا يأتون من جهة الشهوات والثقل ... وأكثر ما يتمكن هذا التأويل مع إغواء الشياطين، وهو قَلِقٌ مع إغواء بني آدم. وقيل: المعنى: تحلفون لنا، وتأتوننا إتيان من إذا حلف صدقناه ... فاليمين على هذا: القَسَم«. ثم بيَّن أن بعض الناس ذهبوا في ذكر إبليس جهات بني آدم في قوله: <q>﴿مِن بَيْنِ أيْدِيهِمْ ومِن خَلْفِهِمْ وعَنْ أيْمانِهِمْ وعَنْ شَمائِلِهِمْ﴾</q> [الأعراف:١٧] إلى ما ذكره من جهة الشهوات، فقالوا: ما بين يديه هي مغالطته فيما يراه، وما خلفه هو ما يسارق فيه الخفاء، وعن يمينه هو جانب شهواته، وعن شماله هو موضع نظره بقلبه وتحرزه، فقد يغلبه الشيطان فيه، ثم علَّق بقوله:»وهذا فيمن جعل هذا في جهات ابن آدم الخاصة بيديه، ومِن الناس مَن جعلها في جهات أموره وشؤونه؛ فيتسع التأويل على هذا". ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.أخرجه ابن جرير ١٩/٥٢٥. وعلَّقه يحيى بن سلام ٢/٨٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٨/١٤٣، وتفسير البغوي ٧/٣٨.أخرجه إسحاق البستي ص٢٠١.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٨.أخرجه ابن جرير ١٩/٥٢٥.علقه يحيى بن سلام ٢/٨٢٩.تفسير مقاتل بن سليمان ٣/٦٠٥.أخرجه ابن جرير ١٩/٥٢٥.تفسير يحيى بن سلام ٢/٨٢٩.
37,29," <q>﴿قَالُوا۟ بَل لَّمۡ تَكُونُوا۟ مُؤۡمِنِینَ ۝٢٩ وَمَا كَانَ لَنَا عَلَیۡكُم مِّن سُلۡطَـٰنِۭۖ بَلۡ كُنتُمۡ قَوۡمࣰا طَـٰغِینَ ۝٣٠﴾</q> - تفسير ٦٥٢٨٣- عن عبد الله بن عباس، في قوله: <q>﴿قالُوا بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</q> في علم الله، <q>﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</q> مُشركين في عِلم الله{1}. (١٢/٣٩٧) ٦٥٢٨٤- عن الحسن البصري، في قوله: <q>﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</q>، قال: لو كنتم مؤمنين مُنِعْتُم مِنّا{2}. (١٢/٣٩٩) ٦٥٢٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: قالت الجن للإنس: <q>﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</q> حتى بلغ <q>﴿قَوْمًا طاغِينَ﴾</q>{3}. (١٢/٣٩٧) ٦٥٢٨٦- قال إسماعيل السُّدِّيّ: <q>﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</q> مِن مُلك فنقهركم به على الشرك، <q>﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</q> تقوله الشياطين للمشركين مِن الإنس{4}. (ز) ٦٥٢٨٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</q>، قال: الحجة. وفي قوله <q>﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</q>، قال: كفار ضُلّال{5}. (ز) ٦٥٢٨٨- قال مقاتل بن سليمان: <q>﴿قالُوا﴾</q> قالت لهم الشياطين: <q>﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</q> مُصَدِّقين بتوحيد الله ﷿، <q>﴿وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</q> مِن مُلْكٍ فنكرهكم على متابعتنا، <q>﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</q> عاصين{6}. (ز) ٦٥٢٨٩- قال يحيى بن سلّام: <q>﴿قالُوا﴾</q> قالت الشياطين للمشركين من الإنس: <q>﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ * وما كانَ لَنا عَلَيْكُمْ مِن سُلْطانٍ﴾</q>. كقوله: <q>﴿فَإنَّكُمْ﴾</q> يا بني إبليس <q>﴿وما تَعْبُدُونَ * ما أنْتُمْ عَلَيْهِ بِفاتِنِينَ﴾</q> ليس لكم سلطان <q>﴿إلا﴾</q> على <q>﴿مَن هُوَ صالِ الجَحِيمِ﴾</q> [الصافات:١٦١-١٦٣]. <q>﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</q> تقوله الشياطين للمشركين من الإنس{7}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٢٩.أخرجه ابن جرير ١٩/٥٢٦.تفسير مقاتل بن سليمان ٣/٦٠٥.تفسير يحيى بن سلام ٢/٨٢٩.
  37,30,""
37,31," <q>﴿فَحَقَّ عَلَیۡنَا قَوۡلُ رَبِّنَاۤۖ إِنَّا لَذَاۤىِٕقُونَ ۝٣١ فَأَغۡوَیۡنَـٰكُمۡ إِنَّا كُنَّا غَـٰوِینَ ۝٣٢﴾</q> - تفسير ٦٥٢٩٠- عن عبد الله بن عباس، في قوله: <q>﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</q>: فوجب علينا قضاء ربنا؛ لأنا كنا أذلاء، وكنتم أعِزّاء{1}. (١٢/٣٩٧) ٦٥٢٩١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</q> قال: هذا قول الجن، <q>﴿فَأَغْوَيْناكُمْ إنّا كُنّا غاوِينَ﴾</q> هذا قول الشياطين لضُلّال بني آدم{2}. (١٢/٣٩٧) ٦٥٢٩٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فَأَغْوَيْناكُمْ﴾</q> قال: الشياطين تقول: أغويناكم في الدنيا <q>﴿إنّا كُنّا غاوِينَ﴾</q>{3}. (١٢/٣٩٩) ٦٥٢٩٣- قال مقاتل بن سليمان: ثم قالت الشياطين: <q>﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</q> يومَ قال لإبليس: <q>﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّنْ تَبِعَكَ مِنهُمْ أجْمَعِينَ﴾</q> [ص:٨٥] <q>﴿إنّا لَذائِقُونَ فَأَغْوَيْناكُمْ﴾</q> يعني: أضللناكم عن الهدى، <q>﴿إنّا كُنّا غاوِينَ﴾</q> ضالين{4}. (ز) ٦٥٢٩٤- قال يحيى بن سلّام: <q>﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا﴾</q> هذا قول الشياطين، والقول هاهنا هو قوله: <q>﴿ولَكِنْ حَقَّ القَوْلُ مِنِّي﴾</q> صدق القول مِنِّي <q>﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنَ الجِنَّةِ والنّاسِ أجْمَعِينَ﴾</q> [السجدة:١٣]. قال: <q>﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا إنّا لَذائِقُونَ﴾</q> أي: العذاب، <q>﴿فَأَغْوَيْناكُمْ﴾</q> تقوله الشياطين للمشركين، أي: فأضللناكم، <q>﴿إنّا كُنّا غاوِينَ﴾</q> ضالين{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.أخرجه ابن جرير ١٩/٥٢٧ دون شطره الثاني. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٥-٦٠٦.تفسير يحيى بن سلام ٢/٨٢٩.
  37,32,""
37,33," <q>﴿فَإِنَّهُمۡ یَوۡمَىِٕذࣲ فِی ٱلۡعَذَابِ مُشۡتَرِكُونَ ۝٣٣﴾</q> - تفسير ٦٥٢٩٥- عن عبد الله بن عباس: <q>﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</q> قال: كلهم <q>﴿فِي العَذابِ مُشْتَرِكُونَ﴾</q>{1}. (١٢/٣٩٧) ٦٥٢٩٦- عن إسماعيل السُّدِّيّ: <q>﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</q> ومَن أغْوَوا في الدنيا <q>﴿فِي العَذابِ مُشْتَرِكُونَ﴾</q>{2}. (١٢/٣٩٩) ٦٥٢٩٧- قال إسماعيل السُّدِّيّ: <q>﴿مُشْتَرِكُونَ﴾</q> لا يمنعُ بعضُكم بعضًا من دخول النار{3}. (ز) ٦٥٢٩٨- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿فَإنَّهُمْ يَوْمَئِذٍ﴾</q> للكفار والشياطين <q>﴿فِي العَذابِ مُشْتَرِكُونَ﴾</q>{4}. (ز) ٦٥٢٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَإنَّهُمْ يَوْمَئِذٍ فِي العَذابِ مُشْتَرِكُونَ﴾</q>، قال: هم والشياطين{5}. (ز) ٦٥٣٠٠- قال يحيى بن سلّام: قال: <q>﴿فَإنَّهُمْ يَوْمَئِذٍ فِي العَذابِ مُشْتَرِكُونَ﴾</q> يُقرَن كلُّ واحد منهم هو وشيطانه في سلسلة واحدة{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٨٢٨.تفسير مقاتل بن سليمان ٣/٦٠٥-٦٠٦.أخرجه ابن جرير ١٩/٥٢٧.تفسير يحيى بن سلام ٢/٨٢٩-٨٣٠.
37,34," <q>﴿إِنَّا كَذَ ٰ⁠لِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِینَ ۝٣٤﴾</q> - تفسير ٦٥٣٠١- عن عبد الله بن عباس: <q>﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</q>، يقول: إنّا هكذا نصنع بالمشركين{1}. (١٢/٣٩٧) ٦٥٣٠٢- قال عبد الله بن عباس: <q>﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</q> الذين جعلوا لله شركاء{2}. (ز) ٦٥٣٠٣- قال يحيى بن سلّام: قال: <q>﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</q> بالمشركين{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٦٥-.تفسير البغوي ٧/٣٩.تفسير يحيى بن سلام ٢/٨٣٠.
37,35," <q>﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</q> - نزول الآية ٦٥٣٠٤- قال مقاتل بن سليمان: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q> نزلت في الملأ مِن قريش الذين مشَوْا إلى أبي طالب، فقال لهم النبي ﷺ: «قولوا: لا إله إلا الله. تملكون بها العرب، وتدين لكم العجم بها»{1}. (ز) <q>﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</q> - تفسير الآية ٦٥٣٠٥- عن أبي هريرة، قال: قال رسول الله ﷺ: «أُمِرْتُ أن أُقاتِل الناس حتى يقولوا: لا إله إلا الله. فمَن قال: لا إله إلا الله. فقد عصم مِنِّي مالَه ونفسَه إلا بِحَقِّه، وحسابه على الله». وأنزل الله في كتابه، وذكر قومًا استكبروا فقال: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q>. وقال: <q>﴿إذْ جَعَلَ الَّذِينَ كَفَرُوا فِي قُلُوبِهِمُ الحَمِيَّةَ حَمِيَّةَ الجاهِلِيَّةِ فَأَنْزَلَ اللَّهُ سَكِينَتَهُ عَلى رَسُولِهِ وعَلى المُؤْمِنِينَ وأَلْزَمَهُمْ كَلِمَةَ التَّقْوى وكانُوا أحَقَّ بِها وأَهْلَها﴾</q> [الفتح:٢٦] وهي: لا إله إلا الله محمد رسول الله، استكبر عنها المشركون يوم الحديبية، يوم كاتَبهم رسول الله ﷺ على قضية المدة{2}. (١٢/٣٩٩) ٦٥٣٠٦- عن عبد الله بن عباس: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q>، قال: كانوا إذا لم يُشرِك بالله يستنكفون{3}. (١٢/٣٩٩) ٦٥٣٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q>، قال: يعني: المشركين خاصَّة{4}. (ز) ٦٥٣٠٨- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال -جلَّ وعزَّ-: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q> يَتَكَبَّرون عنِ الهُدى{1}. (ز) ٦٥٣٠٩- قال يحيى بن سلّام: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q> عنها{6}. (ز) <q>﴿إِنَّهُمۡ كَانُوۤا۟ إِذَا قِیلَ لَهُمۡ لَاۤ إِلَـٰهَ إِلَّا ٱللَّهُ یَسۡتَكۡبِرُونَ ۝٣٥﴾</q> - آثار متعلقة بالآية ٦٥٣١٠- عن قتادة، في قوله: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q>، قال: قال عمر بن الخطاب: احضروا موتاكم، ولقِّنوهم لا إله إلا الله، فإنهم يرون ويسمعون{4}. (ز) ٦٥٣١١- عن وهب بن مُنَبِّه -من طريق سعيد بن رمانة- أنّه قيل له: أليس «لا إله إلا الله» مفتاح الجنة؟ قال: بلى. ولكن ليس مِن مفتاح إلا وله أسنان، فمَن جاء بأسنانه فُتِح له، ومن لا لم يُفتح له{8}. (١٢/٤٠٠) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.أخرجه البيهقي في الأسماء والصفات ١/٢٦٣-٢٦٤ (١٩٦)، وابن جرير ٢١/٣٠٨-٣٠٩ واللفظ له، وأخرجه البخاري ٤/٤٨ (٢٩٤٦)، ٩/١٥ (٦٩٢٤)، ٩/٩٣ (٧٢٨٤)، ومسلم ١/٥١ (٢٠)، ١/٥٢ (٢١) كلاهما دون قوله: وأنزل الله في كتابه.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٩/٥٢٨.تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.أخرجه ابن جرير ١٩/٥٢٨.أخرجه البخاري في تاريخه ١/٩٥، والبيهقى في الأسماء والصفات (٢٠٨).
37,36," <q>﴿وَیَقُولُونَ أَىِٕنَّا لَتَارِكُوۤا۟ ءَالِهَتِنَا لِشَاعِرࣲ مَّجۡنُونِۭ ۝٣٦﴾</q> - تفسير ٦٥٣١٢- عن عبد الله بن عباس: <q>﴿ويَقُولُونَ أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</q> لا يعقل. قال: فحكى الله صِدقَه، فقال: <q>﴿بَلْ جاءَ بِالحَقِّ وصَدَّقَ المُرْسَلِينَ﴾</q>{1}. (١٢/٣٩٩) ٦٥٣١٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويَقُولُونَ أئِنّا لَتارِكُوا آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</q>: يعنون: محمدًا ﷺ{2}. (١٢/٣٩٧) ٦٥٣١٤- قال يحيى بن سلّام: <q>﴿ويَقُولُونَ﴾</q> يعني: المشركين، إذا دعاهم النبي ﷺ إلى الإيمان: <q>﴿أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</q> يعنون: النبي ﷺ، أي: لا نفعل{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٩/٥٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.
37,37," <q>﴿بَلۡ جَاۤءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِینَ ۝٣٧﴾</q> - تفسير ٦٥٣١٥- عن عبد الله بن عباس: قال: فحكى الله صِدْقَه، فقال: <q>﴿بَلْ جاءَ بِالحَقِّ وصَدَّقَ المُرْسَلِينَ﴾</q>{1}. (١٢/٣٩٩) ٦٥٣١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بَلْ جاءَ بِالحَقِّ﴾</q> بالقرآن، <q>﴿وصَدَّقَ المُرْسَلِينَ﴾</q> أي: صدّق مَن كان قبله مِن المرسلين{2}. (ز) ٦٥٣١٧- عن إسماعيل السُّدِّيّ: <q>﴿بَلْ جاءَ بِالحَقِّ﴾</q>، يعني: بالتوحيد{3}. (ز) ٦٥٣١٨- قال مقاتل بن سليمان: <q>﴿ويَقُولُونَ أئِنّا لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</q>. فقال -جل وعز-: <q>﴿بَلْ جاءَ بِالحَقِّ﴾</q> يعني: محمدًا ﷺ، جاء بالتوحيد، <q>﴿وصَدَّقَ المُرْسَلِينَ﴾</q> قبله{4}٥٤٧٥. (ز) ٥٤٧٥ قال ابنُ القيم (٢/٣٦٧): «مجيئه تصديقٌ لهم من جهتين: مِن جهة إخبارهم بمجيئه ومبعثه، ومِن جهة إخباره بمثل ما أخبروا به، ومطابقة ما جاء به لما جاءوا به؛ فإن الرسول الأول إذا أتى بأمرٍ لا يعلم إلا بالوحي، ثم جاء نبي آخر لم يقارنه في الزمان ولا في المكان، ولا تلقى عنه ما جاء به، وأخبر بمثل ما أخبر به سواء؛ دلَّ ذلك على صدق الرسولين الأول والآخر، وكان ذلك بمنزلة رجلين أخبر أحدهما بخبر عن عيان، ثم جاء آخر من غير بلده وناحيته -بحيث يعلم أنه لم يجتمع به، ولا تلقى عنه، ولا عمن تلقى عنه-، فأخبر بمثل ما أخبر به الأول سواء؛ فإنه يضطر السامع إلى تصديق الأول والثاني. والمعنى الثانى: أنه لم يأتِ مُكَذِّبًا لِمَن قبله مِن الأنبياء، مُزْرِيًا عليهم، كما يفعل الملوك المتغلبون على الناس بمن تقدمهم من الملوك، بل جاء مصدقًا لهم، شاهدًا بنبوتهم، ولو كان كاذبًا متقولًا منشئًا من عنده سياسة لم يصدِّق من قبله، بل كان يُزْرِي بهم، ويطعن عليهم، كما يفعل أعداء الأنبياء». وبنحو الكلام الأول قال ابنُ كثير (١٢/١٥). ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٩/٥٢٩.علقه يحيى بن سلام ٢/٨٣٠.تفسير مقاتل بن سليمان ٣/٦٠٦.
37,38," <q>﴿إِنَّكُمۡ لَذَاۤىِٕقُوا۟ ٱلۡعَذَابِ ٱلۡأَلِیمِ ۝٣٨ وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ ۝٣٩﴾</q> - تفسير ٦٥٣١٩- قال مقاتل بن سليمان: <q>﴿إنَّكُمْ لَذائِقُوا العَذابِ الأَلِيمِ﴾</q> يعني: الوجيع، <q>﴿وما تُجْزَوْنَ﴾</q> في الآخرة <q>﴿إلّا ما كُنْتُمْ تَعْمَلُونَ﴾</q> في الدنيا مِن الشرك، جزاءُ الشرك النارُ{1}. (ز) ٦٥٣٢٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿إنَّكُمْ لَذائِقُو العَذابِ الأَلِيمِ﴾</q> المُوجِع، يقوله للمشركين، يعني: عذاب جهنم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٢٨-٨٢٩.
  37,39,""
37,40," <q>﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٤٠﴾</q> - قراءات ٦٥٣٢١- عن مجاهد بن جبر، أنه كان يقرأ: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>{1}. (١٢/٤٠٠) <q>﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٤٠﴾</q> - تفسير الآية ٦٥٣٢٢- عن شدّاد بن أوس، قال: قال النبي ﷺ: «إذا جمع الله الأولين والآخرين ببقيع واحد؛ ينفذهم البصر، ويُسمعهم الداعي، قال: أنا خير شريك، كلُّ عملٍ كان عُمِل لي في دار الدنيا كان لي فيه شريك فأنا أدعه اليوم، ولا أقبل اليوم إلا خالصًا». ثم قرأ: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>، <q>﴿فَمَن كانَ يَرْجُو لِقاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلًا صالِحًا ولا يُشْرِكْ بِعِبادَةِ رَبِّهِ أحَدًا﴾</q> [الكهف:١١٠]{2}. (ز) ٦٥٣٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>، قال: هذه ثنية الله{3}. (١٢/٣٩٧) ٦٥٣٢٤- قال مقاتل بن سليمان: ثم استثنى المؤمنين، فقال: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q> بالتوحيد، لا يذوقون العذاب{4}. (ز) ٦٥٣٢٥- قال يحيى بن سلّام: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>، استثنى المؤمنين، وهم مِن كل ألفٍ واحدٌ{5}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور. و<q>﴿المُخْلَصِينَ﴾</q> بفتح اللام قراءة متواترة، قرأ بها نافع، وعاصم، وحمزة، والكسائي، وأبو جعفر، وخلف، وقرأ بقية العشرة: ‹المُخْلِصِينَ› بكسر اللام. انظر: النشر ٢/٢٩٥، والإتحاف ص٤٧٣.أخرجه الطبراني في الكبير ٧/٢٩٠ (٧١٦٧)، والشجري في ترتيب الأمالي الخميسية ٢/٣٠٦ (٢٥٤٤)، من طريق حميد الشامي، عن محمود بن الربيع، عن شداد به. إسناده ضعيف؛ لجهالة حميد الشامي، وهو ابن أبي حميد الحمصي، قال عنه ابن حجر في التقريب (١٥٦٧): «مجهول».أخرجه ابن جرير ١٩/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
37,41," <q>﴿أُو۟لَـٰۤىِٕكَ لَهُمۡ رِزۡقࣱ مَّعۡلُومࣱ ۝٤١﴾</q> - تفسير ٦٥٣٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</q>، قال: في الجنة{1}. (١٢/٣٩٧) ٦٥٣٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</q>، قال: في الجنة{2}. (١٢/٤٠٠) ٦٥٣٢٨- قال مقاتل بن سليمان: فأخبر ما أعدَّ لهم، فقال -جلَّ وعز-: <q>﴿أُولئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</q>، يعني بالمعلوم: حين يشتهونه يُؤتون به{3}. (ز) ٦٥٣٢٩- قال يحيى بن سلّام: <q>﴿أُولَئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ﴾</q> الجنة{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٣٠.تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
37,42," <q>﴿فَوَ ٰ⁠كِهُ وَهُم مُّكۡرَمُونَ ۝٤٢ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝٤٣ عَلَىٰ سُرُرࣲ مُّتَقَـٰبِلِینَ ۝٤٤﴾</q> - تفسير ٦٥٣٣٠- قال مقاتل بن سليمان: ثم بيَّن الرِّزق، فقال -تبارك وتعالى-: <q>﴿فَواكِهُ وهُمْ مُكْرَمُونَ * فِي جَنّاتِ النَّعِيمِ * عَلى سُرُرٍ مُتَقابِلِينَ﴾</q> في الزِّيارة{1}. (ز) ٦٥٣٣١- قال يحيى بن سلّام: <q>﴿فَواكِهُ وهُمْ مُكْرَمُونَ * فِي جَنّاتِ النَّعِيمِ * عَلى سُرُرٍ مُتَقابِلِينَ﴾</q> والسرر مرمولة بالذهب، وبقضبان اللؤلؤ الرطب، <q>﴿مُتَقابِلِينَ﴾</q> لا ينظر بعضهم إلى قفا بعض{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
  37,43,""
  37,44,""
37,45," <q>﴿یُطَافُ عَلَیۡهِم بِكَأۡسࣲ مِّن مَّعِینِۭ ۝٤٥﴾</q> - تفسير ٦٥٣٣٢- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿يُطافُ عَلَيْهِمْ بِكَأْسٍ مِن مَعِينٍ﴾</q>، قال: الخمر{1}. (١٢/٤٠١) ٦٥٣٣٣- عن سعيد بن جبير، في قوله: <q>﴿بِكَأْسٍ مِن مَعِينٍ﴾</q>، قال: المعين: الخمر{2}. (١٢/٤٠٣) ٦٥٣٣٤- عن الضحاك بن مُزاحِم -من طريق سلمة بن نبيط- قال: <q>﴿بِكَأْسٍ مِن مَعِينٍ﴾</q> كل كأسٍ ذكره الله في القرآن إنما عُنِي به الخمر{3}. (١٢/٤٠٠) ٦٥٣٣٥- عن الضحاك بن مزاحم: <q>﴿بِكَأْسٍ مِن مَعِينٍ﴾</q> هو الجاري{4}. (١٢/٤٠١) ٦٥٣٣٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بِكَأْسٍ مِن مَعِينٍ﴾</q>، قال: كأس مِن خمر جارية، والمعين هي الجارية{5}. (١٢/٤٠١) ٦٥٣٣٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿بِكَأْسٍ مِن مَعِينٍ﴾</q>، قال: الخمر. والكأس عند العرب: كلُّ إناء فيه شراب، فإن لم يكن فيه شرابٌ لم يكن كأسًا، ولكنه يكون إناء{6}٥٤٧٦. (ز) ٥٤٧٦ قال ابنُ عطية (٧/٢٨٢): «وذهب بعض الناس إلى أن الكأس آنية مخصوصة في الأواني، وهو: كل ما اتسع فمه، ولم يكن له مقبض. ولا يراعى في ذلك كونه بخمرٍ أم لا». ٦٥٣٣٨- عن عطاء الخراساني-من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿بكأس﴾</q>، قال: الخمر{7}. (ز) ٦٥٣٣٩- قال مقاتل بن سليمان: <q>﴿يُطافُ عَلَيْهِمْ﴾</q> يعني: يتقلب عليهم بأيدي الغلمان الخدم <q>﴿بِكَأْسٍ﴾</q> يعني: الخمر <q>﴿مِن مَعِينٍ﴾</q> يعني: الجاري{8}. (ز) ٦٥٣٤٠- قال يحيى بن سلّام: <q>﴿يُطافُ عَلَيْهِمْ بِكَأْسٍ﴾</q> وهي الخمر <q>﴿مِن مَعِينٍ﴾</q> الجاري الظاهر{9}٥٤٧٧. (ز) ٥٤٧٧ قال ابنُ عطية (٧/٢٨٢): «وقوله تعالى: <q>﴿مِن مَعِينٍ﴾</q> يريد: مِن جارٍ مطرد، فالميم فيه أصلية؛ لأنه من الماء المعين. ويحتمل أن يكون من العين، فتكون الميم زائدة، أي: مما يعيّن بالعين غير مستور ولا في خزن». ",footnotes:1:أخرجه ابن جرير ١٩/٥٣٣، وابن أبي حاتم -كما في الإتقان ٢/٣٩-، والبيهقي في البعث (٣٥٧). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٣١ بنحوه، وهناد في الزهد (٧٢). وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٥٣١. كما أخرجه بنحوه عبد الرزاق ٢/١٤٨ من طريق معمر، وابن أبي شيبة ١٤/٦٢،. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم بلفظ: كأس من خمر لم تُعصر.أخرجه ابن جرير ١٩/٥٣١.أخرجه أبو جعفر الرملي في جزئه ص١١٥ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٦٠٦.تفسير يحيى بن سلام ٢/٨٣٠.
37,46," <q>﴿بَیۡضَاۤءَ لَذَّةࣲ لِّلشَّـٰرِبِینَ ۝٤٦﴾</q> - قراءات ٦٥٣٤١- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿بَيْضاءَ﴾</q>، قال: في قراءة عبد الله [بن مسعود]: (صَفْرَآءَ){1}. (١٢/٤٠١) <q>﴿بَیۡضَاۤءَ لَذَّةࣲ لِّلشَّـٰرِبِینَ ۝٤٦﴾</q> - تفسير الآية ٦٥٣٤٢- قال الحسن البصري: <q>﴿بَيْضاءَ﴾</q> خمر الجنة، أشدُّ بياضًا مِن اللبن{2}٥٤٧٨. (ز) ٥٤٧٨ ذكر ابنُ عطية (٤/٤٧٢ ط: دار الكتب العلمية) أن قوله: <q>﴿بَيْضاءَ﴾</q> يحتمل احتمالين: الأول: أن يعود على الكأس. الثاني: أن يعود على الخمر. ورجَّحه بقوله: «وهو الأظهر». ثم أورد قول الحسن. ",footnotes:1:أخرجه ابن جرير ١٩/٥٣١. و<q>﴿بَيْضاءَ﴾</q> قراءة العشرة، أما (صَفْرَآءَ) فقراءة شاذة. انظر: مختصر ابن خالويه ص١٢٨.تفسير البغوي ٧/٤٠.
37,47," <q>﴿لَا فِیهَا غَوۡلࣱ﴾</q> - تفسير ٦٥٣٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لا فِيها غَوْلٌ﴾</q>، قال: ليس فيها صُداع{1}. (١٢/٤٠١) ٦٥٣٤٤- عن عبد الله بن عباس -من طريق عطية- <q>﴿لا فِيها غَوْلٌ﴾</q>، قال: هي الخمر، ليس فيها وجَع بطن{2}. (١٢/٤٠٢) ٦٥٣٤٥- عن عبد الله بن عباس، قال: في الخمر أربع خصال: السُّكر، والصداع، والقَيْء، والبول، فنَزَّه اللهُ خمر الجنة عنها، <q>﴿لا فِيها غَوْلٌ﴾</q> لا تَغُول عقولهم مِن السُّكر{3}. (١٢/٤٠١) ٦٥٣٤٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرْني عن قوله: <q>﴿لا فِيها غَوْلٌ﴾</q>. قال: ليس فيها نتَنٌ، ولا كراهية كخمر الدنيا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت امرأ القيس وهو يقول: رب كأسٍ شربتُ لا غول فيـ ـها وسقيتُ النديم منها مزاجا{4}. (١٢/٤٠٢) ٦٥٣٤٧- عن سعيد بن جبير -من طريق سالم الأفطس- في قوله: <q>﴿لا فِيها غَوْلٌ﴾</q>، قال: لا مكروه فيها، ولا أذى{5}. (١٢/٤٠٣) ٦٥٣٤٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لا فِيها غَوْلٌ﴾</q>، قال: وجَعُ بطن{6}. (١٢/٤٠٢) ٦٥٣٤٩- قال عامر الشعبي: <q>﴿لا فِيها غَوْلٌ﴾</q> لا تغتال عقولَهم فتذهَب بها{7}. (ز) ٦٥٣٥٠- قال الحسن البصري: <q>﴿لا فِيها غَوْلٌ﴾</q> صُداع{7}. (ز) ٦٥٣٥١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لا فِيها غَوْل﴾</q>، قال: لا تغتال عقولهم{2}. (ز) ٦٥٣٥٢- عن محمد بن السائب الكلبي: <q>﴿لا فِيها غَوْلٌ﴾</q>، أي: إثم{7}. (ز) ٦٥٣٥٣- قال مقاتل بن سليمان: <q>﴿لا فِيها غَوْلٌ﴾</q> لا غائِلَة عليها يرجع منها الرأس، كفعل خمر الدنيا{11}. (ز) ٦٥٣٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا فِيها غَوْلٌ﴾</q>، قال: الغول: ما يُوجع البطون، وشارب الخمر ههنا يشتكي بطنه{2}٥٤٧٩. (ز) ٥٤٧٩ اختُلِف في تأويل قوله تعالى: <q>﴿لا فيها غول﴾</q> على خمسة أقوال: الأول: ليس فيها وجع البطن. والثاني: ليس فيها صداع. والثالث: ليس فيها ما يغتال العقل. والرابع: ليس فيها إثم. والخامس: ليس فيها أذى ولا مكروه. ذهب ابنُ كثير (١٢/١٧) إلى القول الأول، ونصَّ على أنه «الصحيح». وهو قول ابن عباس، ومجاهد، وابن زيد. وذهب ابنُ جرير (١٩/٥٣٤-٥٣٥)، وكذا ابنُ عطية (٧/٢٨٣) إلى أنّ اسم «الغول» يعُمّ كلّ تلك الأقوال، استنادًا إلى اللغة والعموم، فقال ابنُ جرير: «ولكل هذه الأقوال التي ذكرناها وجهٌ، وذلك أن الغول في كلام العرب: هو ما غال الإنسان فذهب به. فكل من ناله أمر يكرهه ضربوا له بذلك المثل، فقالوا: غالت فلانًا غول. فالذاهب العقل من شرب الشراب، والمشتكي البطن منه، والمصدع الرأس من ذلك، والذي ناله منه مكروه؛ كلهم قد غالته غول. فإذا كان ذلك كذلك، وكان الله -تعالى ذِكْرُه- قد نفى عن شراب الجنَّة أن يكون فيه غول، فالذي هو أولى بصفته أن يقال فيه كما قال -جل ثناؤه-: <q>﴿لا فيها غول﴾</q> فيعم بنفي كل معاني الغول عنه، وأعم ذلك أن يقال: لا أذى فيها، ولا مكروه على شاربيها في جسم ولا عقل، ولا غير ذلك». وقال ابنُ عطية: «والاسم أعم من هذا كله، فنفى عن خمر الجنة جميع أنواع الأذى؛ إذ هي موجودة في خمر الدنيا، نحا إلى هذا العموم سعيد بن جبير». <q>﴿وَلَا هُمۡ عَنۡهَا یُنزَفُونَ ۝٤٧﴾</q> - تفسير ٦٥٣٥٥- عن عبد الله بن عباس -من طريق عطية- <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، قال: لا تُنزف؛ فتذهَب عقولهم{13}. (ز) ٦٥٣٥٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، قال: لا تُذْهِب عقولَهم{14}. (١٢/٤٠١) ٦٥٣٥٧- عن عبد الله بن عباس، قال: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q> لا يقيئون عنها كما يقيء صاحبُ خمر الدنيا عنها، والقيء مُستكْرَه{3}. (١٢/٤٠٢) ٦٥٣٥٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>. قال: لا يسكرون. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عبد الله بن رواحة وهو يقول: ثم لا يُنْزفون عنها ولكن يذهَب الهمُّ عنهم والغليل{4}. (١٢/٤٠٢) ٦٥٣٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، قال: لا تُذهِب عقولهم{17}. (١٢/٤٠٢) ٦٥٣٦٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لا فِيها غَوْلٌ ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، قال: لا تُذهب عقولهم، ولا تُصدِّع رؤوسهم، ولا تُوجع بطونهم{18}. (١٢/٤٠١) ٦٥٣٦١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، قال: لا تُنزف عقولهم{2}. (ز) ٦٥٣٦٢- قال مقاتل بن سليمان: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، يعني: يسكرون، فتنزف عقولهم كخمر الدنيا{11}. (ز) ٦٥٣٦٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q>، قال: لا تنزف العقول{21}. (ز) ٦٥٣٦٤- قال يحيى بن سلّام: <q>﴿ولا هُمْ عَنْها يُنْزَفُونَ﴾</q> إذا شرِبوها لا تُذهب عقولهم، لا يسكرون{22}٥٤٨٠. (ز) ٥٤٨٠ عَلَّقَ ابنُ جرير (١٩/٥٣٦-٥٣٧) على الآثار، بقوله: "هذا التأويل الذي ذكرناه عمَّن ذكرنا عنه لم تُفَصِّل لنا رواتُه القراءةَ الذي هذا تأويلها، وقد يحتمل أن يكون ذلك تأويل قراءة مَن قرأها <q>﴿يُنْزِفُون﴾</q>، و<q>﴿يُنْزَفُون﴾</q> كلتيهما، وذلك أن العرب تقول: قد نُزِفَ الرجلُ فهو منزوف: إذا ذهب عقله من السكر، وأَنزَفَ فهو مُنزَف، محكية عنهم اللغتان كلتاهما في ذهاب العقل من السكر؛ وأما إذا فنيت خمر القوم فإني لم أسمع فيه إلا أنزَفَ القومُ بالألف، ومن الإنزاف -بمعنى: ذهاب العقل من السكر- قول الأبيرد: لعمري لئن أنزفتم أو صحوتم ... لبئس الندامى كنتم آل أبجرا". وقال ابنُ عطية (٧/٢٨٤-٢٨٥ بتصرف): «<q>﴿يُنْزَفُون﴾</q> من أنزَفَ بمعنيين: أحدهما: سَكِرَ، ومنه قول الأبيرد الرياحي ... والثاني: بَعُدَ شرابُه، يقال: أنزف الرجل: إذا تم شرابه. فهذا كله منفي عن أهل الجنة». ",footnotes:1:أخرجه ابن جرير ١٩/٥٣٢، وابن أبي حاتم -كما في الإتقان ٢/٣٩-، والبيهقي في البعث (٣٥٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٥٣٣.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه الطستي -كما في الإتقان ٢/٧٤، ٩٦-.أخرجه ابن جرير ١٩/٥٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مجاهد (٥٦٨)، وأخرجه سفيان الثوري (٢٥٢) بنحوه، وابن جرير ١٩/٥٣٣، وهناد في الزهد (٧٣). وعلَّقه يحيى بن سلام ٢/٨٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.أخرجه ابن جرير ١٩/٥٣٣.تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.تفسير مقاتل بن سليمان ٣/٦٠٦.أخرجه ابن جرير ١٩/٥٣٣.أخرجه ابن جرير ١٩/٥٣٥-٥٣٦.أخرجه ابن جرير ١٩/٥٣٥، وابن أبي حاتم -كما في الإتقان ٢/٣٩-، والبيهقي في البعث (٣٥٧). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه الطستي -كما في الإتقان ٢/٧٤، ٩٦-.تفسير مجاهد (٥٦٨)، وأخرجه ابن جرير ١٩/٥٣٦، وهناد في الزهد (٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٨، وابن أبي شيبة ١٤/٦٢، وابن جرير ١٩/٥٣٦ من طريق سعيد مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٣٣.تفسير مقاتل بن سليمان ٣/٦٠٦.أخرجه ابن جرير ١٩/٥٣٦.تفسير يحيى بن سلام ٢/٨٣١.
37,48," <q>﴿وَعِندَهُمۡ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</q> - تفسير ٦٥٣٦٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q>، يقول: عن غير أزواجهن{1}. (١٢/٤٠٣) ٦٥٣٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q>، قال: قَصرن طرْفهن على أزواجِهِنَّ{2}. (١٢/٤٠٣) ٦٥٣٦٧- عن الحسن البصري -من طريق المبارك بن فضالة- <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q>: قصَرن طرْفهن على أزواجهن، فلا يُرِدْن غيرهم، واللهِ، ما هُنَّ مُتَبَرِّجات ولا مُتَطَلِّعات{3}. (ز) ٦٥٣٦٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ عِينٌ﴾</q>، قال: قصرن طرفهن على أزواجهن، فلا يُرِدْن غيرهم{4}. (١٢/٤٠٥) ٦٥٣٦٩- عن محمد بن كعب القرظي، في قوله: <q>﴿قاصِراتُ الطَّرْفِ﴾</q>: يعني: قاصرات على أزواجهن، لا يبغين غيرهم{5}. (١٢/٤٠٣) ٦٥٣٧٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q>، قال: قصرن أبصارهن وقلوبَهن على أزواجهن، فلا يُرِدْنَ غيرهم{6}. (ز) ٦٥٣٧١- قال مقاتل بن سليمان: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q> حافِظات النظر مِن الرجال غير أزواجهن، لا يَرَوْنَ غيرهم مِن العِشق{7}. (ز) ٦٥٣٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿قاصِراتُ الطَّرْفِ﴾</q>، قال: لا ينظُرْنَ إلّا إلى أزواجهن، قد قصرن أطرافهن على أزواجهن، ليس كما يكون نساء أهل الدنيا{6}. (ز) ٦٥٣٧٣- قال يحيى بن سلّام: <q>﴿وعِنْدَهُمْ قاصِراتُ الطَّرْفِ﴾</q>، يعني: الأزواج، قصرن طرفهن على أزواجهن، لا يُرِدْن غيرهم{9}. (ز) <q>﴿عِینࣱ ۝٤٨﴾</q> - تفسير ٦٥٣٧٤- عن أم سلمة زوج النبي ﷺ، أنّها قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله: <q>﴿حُورٌ عِينٌ﴾</q> [الواقعة:٢٢]. قال: «العين: الضِّخام العيون، شَفْرُ{10} الحوراء بمنزلة جناح النسر»{11}. (ز) ٦٥٣٧٥- عن عبد الله بن عمرو، قال: <q>﴿عِينٌ﴾</q> شَفر عينها أطول مِن جناح النسر{12}. (ز) ٦٥٣٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿عِينٌ﴾</q>، قال: حِسان العيون{13}. (١٢/٤٠٣) ٦٥٣٧٧- عن الضحاك بن مزاحم، في قوله: <q>﴿عِينٌ﴾</q>، قال: العِين: العِظام الأعين{14}. (١٢/٤٠٤) ٦٥٣٧٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿عِينٌ﴾</q>، قال: عِظام الأعين{15}. (ز) ٦٥٣٧٩- قال مقاتل بن سليمان: ثم قال -جل وعز-: <q>﴿عِينٌ﴾</q>، يعني: حِسان الأعين{7}. (ز) ٦٥٣٨٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿عِينٌ﴾</q>، قال: العيناء: العَظيمة العين{15}. (ز) ٦٥٣٨١- قال يحيى بن سلّام: <q>﴿عِينٌ﴾</q> عظام العيون، الواحدة منهن: عيناء، والعِين جماعتهن، نُسبن إلى عِظم العيون{9}٥٤٨١. (ز) ٥٤٨١ قال ابنُ كثير (١٢/١٨): «<q>﴿عين﴾</q> أي: حِسان الأعين. وقيل: ضِخام الأعين. وهو يرجع إلى الأول، وهي: النجلاء العيناء». ",footnotes:1:أخرجه ابن جرير ١٩/٥٣٧، وابن أبي حاتم -كما في في تغليق التعليق ٤/٢٩٤، والإتقان ٢/٣٩-، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٦٨)، وأخرجه ابن جرير ١٩/٥٣٨، وأخرجه من طريق منصور أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -تفسير مجاهد (٥٦٨)-.أخرجه عبد الرزاق ٢/١٤٩ من طريق معمر، وابن جرير ١٩/٥٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم. وقد وقع في الدر: لا يبغين غيرهن.أخرجه ابن جرير ١٩/٥٣٨.تفسير مقاتل بن سليمان ٣/٦٠٧.أخرجه ابن جرير ١٩/٥٣٨.تفسير يحيى بن سلام ٢/٨٣١.الشفر -بالضم، وقد يفتح-: حرف جفن العين الذي ينبت عليه الشعر. النهاية (شفر).أخرجه العقيلي في الضعفاء الكبير ٢/١٣٨ (٦٢٧) في ترجمة سليمان بن أبي كريمة عن هشام بن حسان، والطبراني في الأوسط ٣/٢٧٨ (٣١٤١) مطولًا، وابن جرير ١٩/٥٣٩. قال العقيلي: «يحدّث بمناكير، ولا يتابع على كثير من حديثه». وقال ابن عدي في الكامل في الضعفاء ٤/٢٤٨-٢٤٩: منكر«. وقال الهيثمي في المجمع ١٠/٤١٧-٤١٨ (١٨٧٥٥):»رواه الطبراني في الأوسط والكبير بنحوه.. وفي إسنادهما سليمان بن أبي كريمة، وهو ضعيف".علقه يحيى بن سلام ٢/٨٣١.عزاه السيوطي إلى ابن جرير، وعبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٣٩.تفسير مقاتل بن سليمان ٣/٦٠٧.أخرجه ابن جرير ١٩/٥٣٩.تفسير يحيى بن سلام ٢/٨٣١.
37,49," <q>﴿كَأَنَّهُنَّ بَیۡضࣱ مَّكۡنُونࣱ ۝٤٩﴾</q> - تفسير ٦٥٣٨٢- عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>. قال: «رِقّتهن كرِقَّة الجِلدة التي في داخل البيضة مِمّا يلي القِشْر»{1}. (١٤/١٥٩) ٦٥٣٨٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: اللؤلؤ المكنون{2}. (١٢/٤٠٣) ٦٥٣٨٤- عن عبد الله بن عباس، في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: بياض البيضة يُنزَع عنها فوفها{3}، وغشاؤها الذي يكون في الفرْق{4}. (١٢/٤٠٤) ٦٥٣٨٥- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: كأنّهُنَّ بطن البيض{5}. (١٢/٤٠٤) ٦٥٣٨٦- قال الحسن البصري: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q> شبَّهَهُنَّ ببيض النعامة تكنها بالرِّيش من الريح والغبار، فلونها أبيض في صفرة{6}. (ز) ٦٥٣٨٧- عن الحسن البصري، في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: محضون، لم تَمُر به الأيدي{7}. (١٢/٤٠٥) ٦٥٣٨٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: البيض الذي لم تُلَوِّثه الأيدي{8}. (١٢/٤٠٥) ٦٥٣٨٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>: لم تمر به الأيدي ولم تمسّه، يُشبهن بياضه{9}. (ز) ٦٥٣٩٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: بياض البيض حين يُنزع قشره{10}. (١٢/٤٠٤) ٦٥٣٩١- عن إسماعيل السُّدِّيّ -من طريق الحسن بن يزيد الأصم- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: البيض في عُشِّه المكنون{11}. (١٢/٤٠٤) ٦٥٣٩٢- عن عطاء الخراساني -من طريق معمر- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: هو السِّحاء الذي يكون بين القشرة العليا ولباب البيضة{12}. (١٢/٤٠٤) ٦٥٣٩٣- عن زيد بن أسلم، في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: البيض الذي يُكنُّه الريش، مثل بيض النعام الذي أكنَّه الريشُ مِن الريح، فهو أبيض إلى الصفرة، فكانت تَتَرَقْرَقُ{13}، فذلك المكنون{7}. (١٢/٤٠٥) ٦٥٣٩٤- قال مقاتل بن سليمان: ثم شبَّههن ببياض البيض الذي الصُّفرة في جوفه، فقال: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>{15}. (ز) ٦٥٣٩٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q>، قال: البيض الذي يُكنُّه الريش، مثل بيض النعام الذي قد أكنَّه الريش مِن الريح، فهو أبيض إلى الصفرة، فكأنه يَبْرُقُ، فذلك المكنون{16}. (ز) ٦٥٣٩٦- قال يحيى بن سلّام: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q> وبعضهم يقول: هي القشرة الداخلة. وبعضهم يقول: يعني بالبيض: اللؤلؤ، كقوله: <q>﴿وحُورٌ عِينٌ * كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</q> [الواقعة:٢٢-٢٣] في أصدافه{17}٥٤٨٢. (ز) ٥٤٨٢ اختُلِف في تأويل قوله تعالى: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q> على ثلاثة أقوال: الأول: أنهن شُبِّهن ببطن البيض في البياض، وهو الذي داخل القشر، وذلك أن ذلك لم يمسه شيء. وهذا قول سعيد بن جبير، والسديّ، وقتادة. والثاني: أنهن شُبِّهن بالبيض الذي يحضنه النعام، في بياض قشره الذي قد خالطته صفرة حسنة. وهذا قول ابن زيد. والثالث: أنهن شُبِّهن باللؤلؤ المكنون في بياضه ونقائه. وهذا قول ابن عباس. وزاد ابنُ عطية (٧/٢٨٦) قولًا رابعًا، فقال: «وقالت فرقة: إنما شبههن تعالى بالبيض المكنون تشبيهًا عامًّا؛ جملة المرأة بجملة البيضة، وأراد بذلك تناسب أجزاء المرأة، وأن كل جزء منها نسبته في الجودة إلى نوعه نسبة الآخر من أجزائه إلى نوعه، فنسبة شعرها إلى عينها مستوية؛ إذ هما غاية في نوعهما، والبيضة أشد الأشياء تناسب أجزاء؛ لأنك من حيث جئتها فالنظر فيها واحد». ورجَّحَ ابنُ جرير (١٩/٥٤١-٥٤٢ بتصرف) القولَ الأولَ لدلالة اللغة، والعقل، وأقوال السلف، وانتَقَدَ الثاني، فقال: «أولى الأقوال في ذلك بالصواب عندي قول مَن قال: شبهن في بياضهن وأنهن لم يمسهن قبل أزواجهن إنس ولا جان ببياض البيض الذي هو داخل القشر، وذلك هو الجلدة الملْبَسةُ المحَّ قبل أن تمسه يد أو شيء غيرها، وذلك لا شك هو المكنون؛ فأما القشرة العُليا فإن الطائر يمسها، والأيدي تباشرها، والعش يلقاها. والعرب تقول لكل مصون: مكنون ما كان ذلك الشيء؛ لؤلؤًا كان أو بيضًا أو متاعًا ... وتقول لكل شيء أضمرته الصدور: أكنته، فهو مُكَنٌّ. وبنحو الذي قلنا في ذلك جاء الأثر عن رسول الله ﷺ ... عن أم سلمة، قلت: يا رسول الله، أخبِرني عن قوله <q>﴿كأنهن بيض مكنون﴾</q>. قال: «رقتهن كرقة الجلدة التي رأيتها في داخل البيضة التي تلي القشر» وهي الغِرْقيء». وانتَقَدَ ابنُ عطية (٧/٢٨٦) القول الثالث، فقال: «هذا لا يصح عندي عن ابن عباس ﵄؛ لأنه تردُّه اللفظة من الآية». ",footnotes:1:أخرجه الطبراني مطولًا في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥. وعزاه السيوطي إلى ابن مردويه. وسيأتي مطولًا مع تخريجه عند تفسير قوله تعالى: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> [الرحمن:٧٠]. قال الطبراني في الأوسط: «لم يرو هذا الحديث عن هشام بن حسان إلا سليمان بن أبي كريمة، تفرَّد به عمرو بن هاشم». وقال ابن الجوزي في العلل المتناهية ٢/١٦١ (١٠٧٧): «هذا حديث لا يصح». وقال الضياء المقدسي في صفة الجنة ص١٢٤ (١١٩): «لا أعلمه رُوي إلا من طريق سليمان بن أبي كريمة، وفيه كلام». وقال ابن القيم في حادي الأرواح ص٢٢٩: «تفرد به سليمان بن أبي كريمة، ضعّفه أبو حاتم، وقال ابن عدي: عامة أحاديثه مناكير. ولم أر للمتقدمين فيه كلامًا، ثم ساق هذا الحديث من طريقه، وقال: لا يُعرف إلا بهذا السند». وقال ابن مفلح في الآداب الشرعية ٢/٢٠٧: «في إسناده سليمان بن أبي كريمة، وهو ضعيف». وقال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «فيه سليمان بن أبي كريمة؛ ضعّفه أبو حاتم، وابن عدي».أخرجه ابن جرير ١٩/٥٤١، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٩٤، والإتقان ٢/٣٩-، والبيهقي في البعث (٢٧٧). وعزاه السيوطي إلى ابن المنذر.الفُوف: القشرة التي على النَّواة، وكل قشرة فوف. النهاية واللسان (فوف).عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٥٤٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم. وأخرجه إسحاق البستي ص٢٠١ موقوفًا على جعفر من قوله.تفسير الثعلبي ٨/١٤٤، وتفسير البغوي ٧/٤٠.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٥٤٠. وعلق يحيى بن سلام ٢/٨٣١ نحوه.أخرجه ابن جرير ١٩/٥٤٠ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه سعيد بن منصور في سننه- التفسير ٧/١٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٩. وعزاه السيوطي إلى ابن أبي حاتم.ترَقرق الشيء: تلألأ. اللسان (رقق).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٧.أخرجه ابن جرير ١٩/٥٤٠.تفسير يحيى بن سلام ٢/٨٣١.
37,50," <q>﴿فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ ۝٥٠﴾</q> - تفسير ٦٥٣٩٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>، قال: أهل الجنة{1}. (١٢/٤٠٥) ٦٥٣٩٨- قال مقاتل بن سليمان: <q>﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>، أي: أهل الجنة حين يتكلمون، يكلِّم بعضهم بعضًا{2}. (ز) ٦٥٣٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>، قال: أهل الجنة{3}. (ز) ٦٥٤٠٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q>، يعني: أهل الجنة{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٧.أخرجه ابن جرير ١٩/٥٤٢.تفسير يحيى بن سلام ٢/٨٣١.
37,51," <q>﴿قَالَ قَاۤىِٕلࣱ مِّنۡهُمۡ إِنِّی كَانَ لِی قَرِینࣱ ۝٥١ یَقُولُ أَءِنَّكَ لَمِنَ ٱلۡمُصَدِّقِینَ ۝٥٢﴾</q> - تفسير ٦٥٤٠١- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ * يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</q>، قال: هو الرجل المشرك يكون له الصاحبُ في الدنيا مِن أهل الإيمان، فيقول له المشرك: إنك لَتُصدِّق بأنّك مبعوثٌ مِن بعد الموت أئذا كنا ترابًا؟! فلمّا أن صاروا إلى الآخرة وأُدخل المؤمن الجنة، وأُدخل المشرك النار، فاطَّلع المؤمن فرأى صاحبه في سواء الجحيم، قال: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q>{1}. (ز) ٦٥٤٠٢- عن فرات بن ثعلبة البهراني -من طريق خصيف- في قوله: <q>﴿إنِّي كانَ لِي قَرِينٌ﴾</q>، قال: ذُكر لي: أنّ رجلين كانا شريكين، فاجتمع لهما ثمانيةُ آلاف دينار، فكان أحدهما ليس له حِرفة، والآخر له حِرفة، فقال: إنه ليس لك حِرفة، فما أراني إلا مُفارقك ومُقاسمك. فقاسمه، ثم فارقه، ثم إنّ أحد الرجلين اشترى دارًا كانت لِمَلِك بألف دينار، فدعا صاحبه، فقال: كيف ترى هذه الدار؟ ابتعتها بألف دينار. فقال: ما أحسنها! فلما خرج قال: اللهم، إنّ صاحبي قد ابتاع هذه الدار، وإنِّي أسألك دارًا مِن الجنة. فتصدّق بألف دينار، ثم مكث ما شاء الله أن يمكث، ثم تزوج امرأةً بألف دينار، فدعاه، وصنع له طعامًا، فلمّا أتاه قال: إنِّي تزوجتُ هذه المرأة بألف دينار. قال: ما أحسن هذا! فلمّا خرج قال: اللهم، إن صاحبي تزوج امرأة بألف دينار، وإني أسألك امرأة مِن الحور العين. فتصدّق بألف دينار، ثم إنّه مكث ما شاء الله أن يمكث، ثم اشترى بستانين بألفي دينار، ثم دعاه، فأراه، وقال: إني ابتعت هذين البستانين بألفي دينار. فقال: ما أحسن هذا! فلمّا خرج قال: يا ربِّ، إن صاحبي قد ابتاع بستانين بألفي دينار، وإني أسألك بستانين في الجنة. فتصدق بألفي دينار، ثم إنّ الملك أتاهما، فتوفّاهما، فانطلق بهذا المتصدق، فأدخله دارًا تُعجِبه، فإذا امرأة يضيء ما تحتها مِن حُسنها، ثم أدخله البستانين وشيئًا الله به عليم، فقال عند ذلك: ما أشبه هذا برجلٍ كان مِن أمره كذا وكذا. قال: فإنه ذلك، ولك هذا المنزل والبستانان والمرأة. فقال: إنّه كان لي قرين يقول: <q>﴿أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</q>. قيل له: فإنه في الجحيم. قال: <q>﴿قالَ هَلْ أنْتُمْ مُطَّلِعُونَ * فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q>، فقال عند ذلك: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q>{2}٥٤٨٣. (١٢/٤٠٧) ٥٤٨٣ عَلَّقَ ابنُ جرير (١٩/٥٤٥) على هذا الأثر بقوله: «هذا التأويل الذي تأوله فرات بن ثعلبة يقوي قراءة مَن قرأ: (إنَّكَ لَمِنَ المصَّدِّقينَ) بتشديد الصاد، بمعنى: لمن المتصدِّقين؛ لأنه يذكر أن الله -تعالى ذكره- إنما أعطاه ما أعطاه على الصدقة لا على التصديق. وقراءة قراء الأمصار على خلاف ذلك، بل قراءتها بتخفيف الصاد وتشديد الدال، بمعنى: إنكار قرينه عليه التصديق أنه يبعث بعد الموت، كأنه قال: أتصدق بأنك تبعث بعد مماتك، وتجزى بعملك، وتحاسب؟ يدل على ذلك قول الله: <q>﴿أئذا متنا وكنا ترابا وعظاما أئنا لمدينون﴾</q>، وهي القراءة الصحيحة عندنا التي لا يجوز خلافها؛ لإجماع الحجة من القراء عليها». ٦٥٤٠٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنِّي كانَ لِي قَرِينٌ﴾</q>، قال: شيطان{3}٥٤٨٤. (١٢/٤٠٥) ٥٤٨٤ قال ابنُ عطية (٧/٢٨٦ بتصرف) مُبيِّنًا القرينين المذكورين: «قال ابنُ عباس وغيره: كان هذان من البشر مؤمن وكافر. وقالت فرقة: هما اللذان ذكر الله تعالى في قوله:<q>﴿يا ويلتى ليتني لم أتخذ فلانا خليلًا﴾</q> [الفرقان:٢٨]. وقال مجاهد: كان إنسيًّا وجنيًّا مِن الشياطين الكفرة. والأول أصوب». ولم يذكر مستندًا. ٦٥٤٠٤- عن إسماعيل السُّدِّيّ، قال: <q>﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ * يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</q> كانا شريكين في بني إسرائيل؛ أحدهما مؤمن، والآخر كافر، فافترقا على ستة آلاف دينار، كل واحد منهما ثلاثة آلاف دينار، ثم افترقا فمكثا ما شاء الله أن يمكثا، ثم التقيا، فقال الكافر للمؤمن: ما صنعت في مالك، أضربت به شيئًا، أتَّجَرْت به في شيء؟ قال له المؤمن: لا، فما صنعت أنت؟ قال: اشتريتُ به أرضًا ونخلًا وثمارًا وأنهارًا بألف دينار. فقال له المؤمن: أوَفعلت؟ قال: نعم. فرجع المؤمن، حتى إذا كان الليلُ فصلّى ما شاء الله أن يصلي، فلما انصرف أخذ ألف دينار، فوضعها بين يديه، ثم قال: اللهم، إنّ فلانًا -يعني: شريكه الكافر- اشترى أرضًا ونخلًا وثمارًا وأنهارًا بألف دينار، ثم يموت غدًا ويتركها، اللهم، إني أشتري منك بهذه الألف دينار أرضًا ونخلًا وثمارًا وأنهارًا في الجنة. ثم أصبح فقسمها في المساكين، ثم مكثا ما شاء الله أن يمكثا، ثم التقيا، فقال الكافر للمؤمن: ما صنعتَ في مالك أضربت به في شيء، أتَّجرت به في شئ؟ قال: لا. قال: فما صنعت أنت؟ قال: كانت ضيعتي قد اشتد علي مؤنتها، فاشتريت رقيقًا بألف دينار يقومون لي فيها، ويعملون لي فيها. فقال المؤمن: أوَفعلت؟ قال: نعم. فرجع المؤمن، حتى إذا كان الليل صلى ما شاء الله أن يصلي، فلما انصرف أخذ ألف دينار، فوضعها بين يديه، ثم قال: اللهمَّ، إنّ فلانًا اشترى رقيقًا مِن رقيق الدنيا بألف دينار، يموت غدًا فيتركهم، أو يموتون فيتركونه، اللهم، وإنِّي أشتري منك بهذه الألف دينار رقيقًا في الجنة. ثم أصبح فقسمها في المساكين، ثم مكثا ما شاء الله أن يمكثا، ثم التقيا، فقال الكافر للمؤمن: ما صنعت في مالك، أضربت به في شيء، أتجرت به في شيء؟ قال: لا، فما صنعت أنت؟ قال: كان أمري كله قد تم إلا شيئًا واحدًا؛ فلانة مات عنها زوجُها، فأصدقتها ألف دينار، فجاءتني بها ومثلها معها. فقال له المؤمن: أوَفعلت؟ قال: نعم. فرجع المؤمن، حتى إذا كان الليل صلى ما شاء الله أن يصلي، فلمّا انصرف أخذ الألف دينار الباقية، فوضعها بين يديه، وقال: اللهمَّ، إنّ فلانًا تزوج زوجة مِن أزواج الدنيا بألف دينار، ويموت غدًا فيتركها أو تموت فتتركه، اللهم، وإنِّي أخطب إليك بهذه الألف دينار حوراء عيناء في الجنة. ثم أصبح، فقسمها بين المساكين، فبقي المؤمنُ ليس عنده شيء، فلبس قميصًا مِن قطن، وكساء من صوف، ثم جعل يعمل ويحفر بقوته، فجاء رجل، فقال: يا عبد الله، أتُؤاجرني نفسك مشاهرة شهرًا بشهر، تقوم على دوابَّ لي؟ قال: نعم. فكان صاحب الدواب يغدو كل يوم ينظر إلى دوابه، فإذا رأى منها دابَّة ضامِرَةً أخذ برأسه، فوجأ{4} عنقه، ثم يقول له: سرقت شعير هذه البارحة. فلما رأى المؤمن الشدة قال: لآتِيَنَّ شريكي الكافر، فلَأعملنَّ في أرضه، يُطعمني هذه الكسرة يومًا بيوم، ويكسيني هذين الثوبين إذا بليا. فانطلق يريده، فانتهى إلى بابه، وهو ممسٍ، فإذا قصر مشيد في السماء، وإذا حوله البوابون، فقال لهم: استأذنوا لي صاحب هذا القصر؛ فإنّكم إن فعلتم ذلك سَرَّه. فقالوا له: انطلق، فإن كنت صادقًا فنم في ناحية، فإذا أصبحت فتعرَّض له. فانطلق المؤمن، فألقى نصف كسائه تحته ونصفه فوقه، ثم نام، فلما أصبح أتى شريكه، فتعرَّض له، فخرج شريكُه وهو راكب، فلمّا رآه عرفه، فوقف فسلم عليه وصافحه، ثم قال له: ألم تأخذ من المال مثل ما أخذت؟ فأين مالك؟ قال: لا تسألني عنه. قال: فما جاء بك؟ قال: جئتُ أعمل في أرضك هذه، تطعمني هذه الكسرة يومًا بيوم، وتكسوني هذين الثوبين إذا بليا. قال: لا ترى مِنِّي خيرًا حتى تخبرني ما صنعتَ في مالك. قال: أقرضتُه. قال: مَن؟ قال: المَليء الوفي. قال: مَن؟ قال: الله ربي. وهو مصافحه، فانتزع يده، ثم قال: <q>﴿أإنَّكَ لَمِنَ المُصَدِّقِينَ * أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</q>؟! وتركه، فلما رآه المؤمن لا يلوي عليه رجع وتركه، يعيش المؤمن في شدة مِن الزمان، ويعيش الكافر في رخاء من الزمان. فإذا كان يوم القيامة، وأدخل الله المؤمن الجنة؛ يمر، فإذا هو بأرض ونخل وثمار وأنهار، فيقول: لِمَن هذا؟ فيقال: هذا لك. فيقول: أوَبلغ مِن فضل عملي أن أثاب بمثل هذا؟! ثم يمر فإذا هو برقيق لا تحصى عِدَّتهم، فيقول: لِمَن هذا؟ فيقال: هؤلاء لك. فيقول: أوَبلغ مِن فضل عملي أن أُثاب بمثل هذا؟! ثم يمر فإذا هو بقُبَّةٍ مِن ياقوتة حمراء مجوفة، فيها حوراء عيناء، فيقول: لِمَن هذه؟ فيقال: هذه لك. فيقول: أوَبلغ مِن فضل عملي أن أُثاب بمثل هذا؟! ثم يذكر شريكه الكافر، فيقول: <q>﴿إنِّي كانَ لِي قَرِينٌ * يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</q>. قال: فالجنة عالية، والنار هاوية، فيريه الله شريكه في وسط الجحيم مِن بين أهل النار، فإذا رآه عرفه المؤمن، فيقول: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ * ولَوْلا نِعْمَةُ رَبِّي لَكُنْتُ مِنَ المُحْضَرِينَ * أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ * إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ * لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</q> بمثل ما قد مُنَّ عليه. قال: فيتذكر المؤمن ما مرَّ عليه في الدنيا مِن الشدة، فلا يذكر أشدَّ عليه مِن الموت{5}. (١٢/٤٠٩) ٦٥٤٠٥- عن عطاء الخراساني -من طريق معمر- قال: كان رجلان شريكين، وكان لهما ثمانية آلاف دينار، فاقتسماها، فَعَمَدَ أحدُهما فأشترى بألف دينار أرضًا، فقال صاحبُه: اللهم، إنّ فلانًا اشترى بألف دينار أرضًا، وإنِّي أشتري منك بألف دينار أرضًا في الجنة. فتصدق بألف دينار، ثم ابتنى صاحبه دارًا بألف دينار، فقال هذا: اللهم، إن فلانًا ابتنى دارًا بألف دينار، وإنِّي أشتري منك دارًا في الجنة بألف دينار. فتصدّق بألف دينار، ثم تزوج صاحبُه امرأة، فأنفق عليها ألف دينار، فقال: اللهم، إنّ فلانا تزوج امرأة، فأنفق عليها ألف دينار، وإني أخطب إليك من نساء الجنة بألف دينار. فتصدَّق بألف دينار، ثم اشترى خدمًا ومتاعًا بألف دينار، فقال: اللهم، إنّ فلانًا اشترى خدمًا ومتاعًا بألف دينار، وإني أشتري منك خدمًا ومتاعًا في الجنة بألف دينار. فتصدق بألف دينار، ثم أصابته حاجة شديدة، فقال: لو أتيتُ صاحبي هذا لعلَّه ينالني معروف. فجلس على طريقه، فمرَّ به في حَشَمه وأهله، فقام إليه، فنظر الآخرُ فعرفه، فقال: فلان؟! فقال: نعم. فقال: ما شأنُك؟ فقال: أصابتني بعدك حاجةٌ، فأتيتك لتصيبني بخير. قال: فما فعل مالُك؛ فقد اقتسمنا مالًا واحدًا، فأخذت شطرَه وأنا شطرَه. فقال: اشتريتَ دارًا بألف دينار، ففعلتُ أنا كذلك، وفعلتَ أنت كذا، وفعلتُ أنا كذا. فقصّ عليه القصة، فقال: إنك لمن المصدقين بهذا؟! اذهب فواللهِ لا أعطيك شيئًا. فردّه، فقُضي لهما أن تُوفيا؛ فنزلت فيهما: <q>﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَساءَلُونَ﴾</q> حتى بلغ: <q>﴿أإنّا لَمَدِينُونَ﴾</q> قال: لَمُحاسبون{6}. (١٢/٤٠٦) ٦٥٤٠٦- قال مقاتل بن سليمان: <q>﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ﴾</q> وذلك أنّ أخوين مِن بني إسرائيل -اسم أحدهما: فطرس، والآخر: سلخا- ورِث كلُّ واحدٍ منهما عن أبيه أربعة آلاف دينار، فأمّا أحدهما فأنفق ماله في طاعة الله ﷿، والمشرك الآخر أنفق مالَه في معصية الله ﷿ ومعيشة الدنيا، وهما اللذان ذكرهما الله ﷿ في سورة الكهف، فلمّا صارا إلى الآخرة أُدخِل المؤمن الجنة، وأُدخل المشرك النار، فلما أُدخل الجنة المؤمن ذكر أخاه، فقال لإخوانه من أهل الجنة: <q>﴿إنِّي كانَ لِي قَرِينٌ﴾</q> يعني: صاحب، <q>﴿يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</q> بالبعث{7}. (ز) ٦٥٤٠٧- قال يحيى بن سلّام: <q>﴿قالَ قائِلٌ مِنهُمْ إنِّي كانَ لِي قَرِينٌ﴾</q> صاحب في الدنيا، <q>﴿يَقُولُ أإنَّكَ لَمِنَ المُصَدِّقِينَ﴾</q> على الاستفهام{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٤٣.أخرجه سعيد بن منصور في سننه - التفسير ٧/١٤٨، وابن جرير ١٩/٥٤٣-٥٤٥.تفسير مجاهد (٥٦٨)، وأخرجه يحيى بن سلام ٢/٨٣٢ من طريق ابن مجاهد، وابن جرير ١٩/٥٤٣، والفريابي -كما في التغليق ٤/٣٩٤-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.وجأ عنقه: ضربه. لسان العرب ١/١٩٠.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/١٤-١٦-.أخرجه عبد الرزاق ٢/١٤٩ مقتصرًا على أوله، وإسحاق البستي ص٢٠٢. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٠٧-٦٠٨.تفسير يحيى بن سلام ٢/٨٣١.
