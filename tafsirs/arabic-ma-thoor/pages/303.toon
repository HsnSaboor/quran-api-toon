tafsir[14]{c,v,t}:
18,84," <q>﴿إِنَّا مَكَّنَّا لَهُۥ فِی ٱلۡأَرۡضِ وَءَاتَیۡنَـٰهُ مِن كُلِّ شَیۡءࣲ سَبَبࣰا ۝٨٤﴾</q> - تفسير ٤٥٦٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وآتيناه من كل شيء سببا﴾</q>، قال: عِلْمًا{1}. (٩/٦٦١) ٤٥٦٤٤- عن سعيد بن أبي هلال، أنّ معاوية بن أبي سفيان قال لكعب الأحبار: أنت تقول: إنّ ذا القرنين كان يربط خيله بالثريا؟! قال له كعب: إن كنتُ قلتُ ذاك فإنّ الله قال: <q>﴿وآتيناه من كل شيء سببا﴾</q>{2}٤٠٨٥. (٩/٦٦١) ٤٠٨٥ ذكر ابنُ كثير (٩/١٨٤ بتصرف) هذا القول، ثم علّق مستندًا إلى دلالة العقل قائلًا: «وهذا الذي أنكره معاوية ﵁ على كعب الأحبار هو الصواب، والحقُّ مع معاوية في الإنكار؛ فإن معاوية كان يقول عن كعب: إن كنا لنبلو عليه الكذب. يعني: فيما ينقله، لا أنه كان يتعمد نقل ما ليس في صحيفته، ولكن الشأن في صحيفته أنّها مِن الإسرائيليات التي غالبها مُبَدَّل مُصَحَّف مُحَرَّف مُخْتَلَق. وتأويل كعب قول الله: <q>﴿وآتَيْناهُ مِن كُلِّ شَيْءٍ سَبَبًا﴾</q> واستشهاده في ذلك على ما يجده في صحيفته مِن أنّه كان يربط خيله بالثريا غير صحيح ولا مطابِق؛ فإنه لا سبيل للبشر إلى شيء من ذلك، ولا إلى التَّرَقِّي في أسباب السموات». ٤٥٦٤٥- عن عبيد، قال: سمعت الضحاك بن مزاحم يقول: <q>﴿وآتيناه من كل شيء سببا﴾</q>، قال: عِلْمًا{3}. (ز) ٤٥٦٤٦- تفسير الحسن البصري: <q>﴿وآتيناه من كل شيء سببا﴾</q>: بلاغًا بحاجته{4}. (ز) ٤٥٦٤٧- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿إنا مكنا له في الأرض وآتيناه من كل شيء سببا﴾</q> أي: علمًا أن يطلب أسباب المنازل، <q>﴿ثم أتبع سببا﴾</q>{5}. (ز) ٤٥٦٤٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وآتيناه من كل شيء سببا﴾</q>، قال: منازل الأرض، وأعلامها{6}. (٩/٦٦٢) ٤٥٦٤٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وآتيناه من كل شيء سببا﴾</q>، أي: عِلمًا{7}. (ز) ٤٥٦٥٠- قال إسماعيل السدي: عِلمًا{8}. (ز) ٤٥٦٥١- قال مقاتل بن سليمان: <q>﴿إنا مكنًا له في الأرض وآتيناهُ من كُل شيء سببًا﴾</q>، يعني: علم أسباب منازل الأرض وطرقها{9}. (ز) ٤٥٦٥٢- عن يحيى بن شِبْل، قال: كنتُ جالسًا عند مقاتل بن سليمان، فجاء شابٌّ، فسأله: ما تقول في قول الله تعالى: <q>﴿كل شيء هالك إلا وجهه﴾</q> [القصص:٨٨]؟ قال: فقال مقاتل: هذا جَهْمِيٌّ. قال: ما أدري ما جهم! إن كان عندك عِلْمٌ فيما أقول، وإلّا فقل: لا أدري. فقال: ويحك، إنّ جهمًا -واللهِ- ما حجَّ هذا البيت، ولا جالس العلماء، إنّما كان رجلًا أُعْطِي لسانًا، وقوله تعالى: <q>﴿كل شيء هالك إلا وجهه﴾</q> إنما هو شيء في الروح، كما قال ههنا لملكة سبأ: <q>﴿وأوتيت من كل شيء﴾</q> [النمل:٢٣] لم تؤت إلا ملك بلادها، وكما قال: <q>﴿وآتيناه من كل شيء سببًا﴾</q> لم يُؤْتَ إلا ما في يده من الملك. ولم يدع في القرآن <q>﴿كل شيء﴾</q> و<q>﴿كل شيء﴾</q> إلا سَرَد علينا{10}. (ز) ٤٥٦٥٣- عن عبد الملك ابن جريج -من طريق حجاج- قوله: <q>﴿وآتيناه من كل شيء سببا﴾</q>، قال: عِلم كل شيء{11}. (ز) ٤٥٦٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وآتيناه من كل شيء سببا﴾</q>، قال: عِلْمًا، مِن ذلك تعليم الألسنة، كان لا يعرف قومًا إلا كلَّمهم بلسانهم{12}٤٠٨٦. (٩/٦٦١) ٤٠٨٦ لم يذكر ابنُ جرير (١٥/٣٧١-٣٧٢) في تفسير قوله: <q>﴿وآتيناه من كل شيء سببا﴾</q> غير قول ابن زيد ومَن وافقه. ٤٥٦٥٥- قال يحيى بن سلّام: بلغنا: أنّه ملَك مشارق الأرض، ومغاربها{13}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٣٧١، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٣٧٢، وإسحاق البستي في تفسيره ص١٥٣.علَّقه يحيى بن سلام ١/٢٠١. وفي تفسير الثعلبي ٦/١٩٠، وتفسير البغوي ٥/١٩٩: بلاغًا إلى حيث أراد.أخرجه ابن عساكر في تاريخ دمشق ١٧/٣٢٩.أخرجه عبد الرزاق ١/٤٠٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٣٧٢. وعلَّقه يحيى بن سلام ١/٢٠١ بلفظ: علمه الذي أُعطي.علقه يحيى بن سلام ١/٢٠١.تفسير مقاتل بن سليمان ٢/٦٠٠.أخرجه ابن عساكر في تاريخ دمشق ٦٠/١١٩.أخرجه ابن جرير ١٥/٣٧٢.أخرجه ابن جرير ١٥/٣٧٢ بلفظ: من كل شيء علمًا. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٢٠١.
18,85," <q>﴿فَأَتۡبَعَ سَبَبًا ۝٨٥﴾</q> - تفسير ٤٥٦٥٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فأتبع سببا﴾</q>، قال: المنزل{1}. (٩/٦٦١) ٤٥٦٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فأتبع سببا﴾</q>، قال: منزِلًا وطريقًا مِن المشرق إلى المغرب{2}. (٩/٦٦٢) ٤٥٦٥٨- عن مجاهد بن جبر -من طريق أبي يحيى-: طَرَفَي الأرض، ومنازلها{3}. (ز) ٤٥٦٥٩- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: ‹فاتَّبَعَ سَبَبًا›، قال: المنازل{4}. (ز) ٤٥٦٦٠- تفسير الحسن البصري <q>﴿فأتبع سببا﴾</q>: طرق الأرض ومعالمها بحاجته{5}. (ز) ٤٥٦٦١- قال قتادة بن دعامة -من طريق سعيد- ‹فاتَّبَعَ سَبَبا›، أي: اتَّبع منازل الأرض ومعالمها{6}. (ز) ٤٥٦٦٢- قال إسماعيل السدي: علمًا، يعني: علم منازل الأرض والطرق{5}. (ز) ٤٥٦٦٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأتبع سببا﴾</q>، قال: هذه لأن الطريق كما قال فرعون لهامان: <q>﴿ابن لي صرحا لعلي أبلغ الأسباب أسباب السموات﴾</q> [غافر:٣٦، ٣٧]: طريق السموات. قال: والشيء يكون اسمه واحدًا، وهو متفرق في المعنى. وقرأ: <q>﴿وتقطعت بهم الأسباب﴾</q> [البقرة:١٦٦]. قال: أسباب الأعمال{8}. (٩/٦٦٢) ",footnotes:1:أخرجه ابن جرير ١٥/٣٧٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٣٧٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٢٠١ بلفظ: طرق ...، وابن جرير ١٥/٣٧٤ مختصرًا.أخرجه ابن جرير ١٥/٣٧٤، وإسحاق البستي في تفسيره ص١٥٣. وقراءة ‹فاتَّبَعَ› بوصل الهمزة وتشديد التاء وفتحها قراءة ابن كثير، ونافع، وأبي عمرو، وأبي جعفر، ويعقوب، وقرأ الباقون: <q>﴿فاتْبَع﴾</q>. ينظر: النشر ٢/٣١٤، والإتحاف ص٢٩٤.علقه يحيى بن سلام ١/٢٠١.أخرجه ابن جرير ١٥/٣٧٣، وعبد الرزاق ١/٤٠٧ مختصرًا من طريق معمر. وعلقه يحيى بن سلام ١/٢٠١.علقه يحيى بن سلام ١/٢٠١.أخرجه ابن جرير مختصرًا ١٥/٣٧٤. وعزاه السيوطي إلى ابن أبي حاتم.
18,86," <q>﴿حَتَّىٰۤ إِذَا بَلَغَ مَغۡرِبَ ٱلشَّمۡسِ وَجَدَهَا تَغۡرُبُ فِی عَیۡنٍ حَمِئَةࣲ وَوَجَدَ عِندَهَا قَوۡمࣰاۖ قُلۡنَا یَـٰذَا ٱلۡقَرۡنَیۡنِ إِمَّاۤ أَن تُعَذِّبَ وَإِمَّاۤ أَن تَتَّخِذَ فِیهِمۡ حُسۡنࣰا ۝٨٦﴾</q> - قراءات ٤٥٦٦٤- عن أُبَيّ بن كعب: أنّ النبي ﷺ قرأ: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>{1}. (٩/٦٦٤) ٤٥٦٦٥- عن عبد الله بن عباس: أن النبي ﷺ كان يقرأ: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>{2}. (٩/٦٦٤) ٤٥٦٦٦- عن عبد الله بن عباس -من طريق مِصْدَع أبي يحيى- قال: أقرأنيه أُبيُّ بن كعب كما أقرأه رسول الله ﷺ: <q>﴿تَغْرُبُ فِي عَيْنٍ حَمِئَةٍ﴾</q> مخففة{3}. (٩/٦٦٤) ٤٥٦٦٧- عن طلحة بن عبيد الله أنّه كان يقرأ: ‹فِي عَيْنٍ حامِيَةٍ›{4}. (٩/٦٦٦) ٤٥٦٦٨- عن عبد الله بن عباس -من طريق عثمان بن أبي حاضر{5}- ذُكر له أن معاوية بن أبي سفيان قرأ الآية التي في سورة الكهف: ‹تَغْرُبُ فِي عَيْنٍ حامِيَةٍ›.= (ز) ٤٥٦٦٩- قال ابن عباس: فقلت لمعاوية: ما نقرؤها إلا: <q>﴿حَمِئَةٍ﴾</q>.= (ز) ٤٥٦٧٠- فسأل معاوية عبد الله بن عمرو: كيف تقرؤها؟ فقال عبد الله: كما قرأتها. قال ابن عباس: فقلت لمعاوية: في بيتي نزل القرآن. فأرسل إلى كعب، فقال له: أين تجد الشمس تغرب في التوراة؟ فقال له كعب: سل أهل العربية؛ فإنهم أعلم بها، وأما أنا فإني أجد الشمس تغرب في التوراة في ماء وطين. وأشار بيده إلى المغرب. قال ابن أبي حاضر: لو أني عندكما أيدتك بكلام وتزداد به بصيرة في: <q>﴿حَمِئَةٍ﴾</q>. قال ابن عباس: وما هو؟ قلت: فيما يأثر قول تبع فيما ذكر به ذا القرنين في كلفه بالعلم واتباعه إياه: قد كان ذو القرنين عُمِّر مسلمًا ملكًا تدين له الملوك وتحسد فأتى المشارق والمغارب يبتغي أسباب ملك من حكيم مرشد فرأى مغيب الشمس عند غروبها في عين ذي خُلُبٍ وثَأطٍ حَرْمَدِ فقال ابن عباس: ما الخُلُبُ؟ قلت: الطين، بكلامهم. قال: فما الثَّأط؟ قلت: الحَمْأَةُ. قال: فما الحَرْمَدُ؟ قلت: الأسود. فدعا ابنُ عباس غلامًا، فقال له: اكتب ما يقول هذا الرجل{6}. (٩/٦٦٢-٦٦٤) ٤٥٦٧١- عن عبد الله بن عباس -من طريق ابن حاضر- قال: كنا عند معاوية، فقرأ: ‹تَغْرُبُ فِي عَيْنٍ حامِيَةٍ›.= (ز) ٤٥٦٧٢- فقلت له: ما نقرؤها إلا: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>. فأرسل معاوية إلى كعب فقال: أين تجد الشمس في التوراة؟ قال: أمّا العربية فلا علم لي بها، وأما أنا فأجد الشمس في التوراة تغرب في ماء وطين{7}. (٩/٦٦٥) ٤٥٦٧٣- عن عبد الله بن عباس -من طريق الأعرج- قال: كان يقرؤها: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>. ثم فسرها: ذات حمأة{8}. (٩/٦٦٤) ٤٥٦٧٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- أنه كان يقرأ: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>، قال كعب: ما سمعت أحدًا يقرؤها كما هي في كتاب الله غير ابن عباس، فإنما نجدها في التوراة: تغرب في حمأة سوداء{9}٤٠٨٧. (٩/٦٦٥) ٤٠٨٧ وجّه ابنُ جرير (١٥/٣٧٤) هذه القراءة، فقال: «المعنى: أنها تغرب في عين ماء ذات حمأة». ٤٥٦٧٥- عن عبد الله بن عباس -من طريق عطاء- قال: خالفتُ عمرو بن العاص عند معاوية في: <q>﴿حَمِئَةٍ﴾</q>، و‹حامِيَةٍ›، قرأتُها: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>.= (ز) ٤٥٦٧٦- فقال عمرو: ‹حامِيَةٍ›. فسألنا كعبًا، فقال: إنها في كتاب الله المنزل: تغرب في طينة سوداء{10}. (٩/٦٦٥) ٤٥٦٧٧- عن الحسن البصري -من طريق معمر- في قوله: ‹فِي عَيْنٍ حامِيَةٍ›، قال: حارَّة. وكذلك قرأها الحسن{11}٤٠٨٨. (ز) ٤٠٨٨ وجّه ابنُ جرير (١٥/٣٧٥) هذه القراءة فقال: «يعني: أنها تغرب في عين ماء حارة». ٤٥٦٧٨- قال الحكم بن عمر: بعثني خالد بن عبد الله القسري وصاحب لي إلى قتادة [بن دعامة] الأعمى ليسأله عن ثمانية عشر ... وسألناه عن قوله تعالى: ‹تَغْرُبُ فِي عَيْنٍ حامِيَةٍ›، قال: لا <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>{12}. (ز) ٤٥٦٧٩- قال يحيى بن سلّام: <q>﴿حَتّى إذا بَلَغَ مَغْرِبَ الشَّمْسِ وجَدَها تَغْرُبُ فِي عَيْنٍ حَمِئَةٍ﴾</q>، وهي تُقْرَأ على وجهين: <q>﴿حَمِئَةٍ﴾</q>، و‹حامِيَةٍ›{13}٤٠٨٩. (ز) ٤٠٨٩ علّق ابنُ جرير (١٥/٣٧٧-٣٧٨) على الوجهين الوارد ذكرهما في قول يحيى بن سلام، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنهما قراءتان معروفتان مستفيضتان في قراءة الأمصار، ولكل واحدة منهما وجه صحيح ومعنًى مفهوم، وكِلا وجهيه غير مفسد أحدهما صاحبه، وذلك أنّه جائز أن تكون الشمس تغرب في عين حارة ذات حمأة وطين، فيكون القارئ ‹فِي عَيْنٍ حامِيَةٍ› واصفها بصفتها التي هي لها، وهي الحرارة، ويكون القارئ <q>﴿في عين حمئة﴾</q> واصفها بصفتها التي هي بها، وهي أنها ذات حمأة وطين». <q>﴿حَتَّىٰۤ إِذَا بَلَغَ مَغۡرِبَ ٱلشَّمۡسِ وَجَدَهَا تَغۡرُبُ فِی عَیۡنٍ حَمِئَةࣲ﴾</q> - تفسير ٤٥٦٨٠- عن أبي ذر جندب بن جنادة، قال: كُنتُ رِدْف رسول الله ﷺ وهو على حمار، فرأى الشمس حين غربت، فقال: «أتدري أين تغرب؟». قلت: الله ورسوله أعلم. قال: «فإنها تغرب في عين حامية». غير مهموزة{14}. (٩/٦٦٦) ٤٥٦٨١- عن عبد الله بن عمرو، قال: نَظَر رسولُ الله ﷺ إلى الشمس حين غابَتْ، فقال: «في نار الله الحامية، لولا ما يَزَعُها مِن أمر الله لأحرقت ما على الأرض»{15}. (٩/٦٦٦) ٤٥٦٨٢- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- ‹فِي عَيْنٍ حامِيَةٍ›، يقول: حارَّة{16}. (٩/٦٦٦) ٤٥٦٨٣- قال عبد الله بن عباس: إذا طلعت الشمسُ أشدّ حرًّا منها إذا غربت{17}. (ز) ٤٥٦٨٤- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿وجَدَها تَغْرُبُ فِي عَيْنٍ حَمِئَةٍ﴾</q>، قال: في طين أسود{18}. (ز) ٤٥٦٨٥- عن عبد الله بن عباس -من طريق عكرمة- أنه كان يقرأ: <q>﴿فِي عَيْنٍ حَمِئَةٍ﴾</q>، قال: ذات حَمْأةٍ{18}. (ز) ٤٥٦٨٦- عن أبي العالية الرياحي، قال: بلغني: أنّ الشمس تغرب في عين، تقذفها العين إلى المشرق{4}. (٩/٦٦٧) ٤٥٦٨٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿في عين حمئة﴾</q>: طينة سوداء ثأط{8}. (ز) ٤٥٦٨٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿تغرب في عين حمئة﴾</q>: والحمئة: الحَمْأةُ السوداء{22}. (ز) ٤٥٦٨٩- قال محمد بن السائب الكلبي -من طريق معمر-: طينة سوداء{23}. (ز) ٤٥٦٩٠- قال مقاتل بن سليمان: <q>﴿حتى إذا بلغ مغرب الشمس وجدها تغرب في عين حمئة﴾</q>، يعني: حارَّة سوداء{17}. (ز) ٤٥٦٩١- قال يحيى بن سلّام: يعني بالحمأة: الطين المُنتِن. ومن قرأها: ‹حامِيَةٍ› يقول: حارَّة{25}٤٠٩٠. (ز) ٤٠٩٠ قال ابنُ تيمية (٤/٢٦٤): «ومعنى <q>﴿تغرب في عين﴾</q>: أي: في رأي الناظر باتفاق المفسرين، وليس المراد أنها تسقط من الفلك فتغرب في تلك العين». <q>﴿وَوَجَدَ عِندَهَا قَوۡمࣰاۖ﴾</q> - تفسير ٤٥٦٩٢- عن سعيد بن المسيب قال: لولا أصوات السّافِرةِ{26} لسُمِع وجْبَةُ الشمس حين تقع عند غروبها{27}. (٩/٦٦٧) ٤٥٦٩٣- قال مقاتل بن سليمان: <q>﴿ووجد عندها قوما قلنا يا ذا القرنين﴾</q>، أوحى الله ﷿ إليه؛ جاءه جبريل ﵇، فخبَّره{17}. (ز) ٤٥٦٩٤- عن عبد الملك ابن جريج، في قوله: <q>﴿ووجد عندها قوما﴾</q>، قال: مدينةٌ لها اثنا عشر ألف باب، لولا أصواتُ أهلِها لَسَمِع الناسُ وُجُوب الشمس حين تَجِب{29}. (٩/٦٦٧) ٤٥٦٩٥- عن سعيد بن صالح، قال: كان يُقال: لولا لَغَط أهلُ الرومية سَمِع الناس وجْبَةَ الشمس حين تقع{30}٤٠٩١. (٩/٦٦٧) ٤٠٩١ قال ابنُ جرير (١٥/٣٧٨): «قوله: <q>﴿ووجد عندها قوما﴾</q>، ذُكِر أنّ أولئك القوم يقال لهم: ناسك». <q>﴿قُلۡنَا یَـٰذَا ٱلۡقَرۡنَیۡنِ إِمَّاۤ أَن تُعَذِّبَ وَإِمَّاۤ أَن تَتَّخِذَ فِیهِمۡ حُسۡنࣰا ۝٨٦﴾</q> - تفسير ٤٥٦٩٦- قال الحسن البصري: <q>﴿قلنا يا ذا القرنين إما أن تعذب﴾</q>، يعني: القتل. وذلك حُكْمُ الله فيمَن أظهر الشِّرك، إلا من حُكِم عليه بالجزية مِن أهل الكتاب إذا لم يُسْلِم وأَقَرَّ بالجزية، ومَن تقبل منه الجزية اليوم{31}. (ز) ٤٥٦٩٧- تفسير إسماعيل السدي: <q>﴿وإما أن تتخذ فيهم حسنا﴾</q>، يعني: العفو{32}. (ز) ٤٥٦٩٨- قال مقاتل بن سليمان: <q>﴿قلنا﴾</q>: فقال: <q>﴿إما أن تعذب وإما أن تتخذ فيهم حُسنًا﴾</q>، يقول: وإمّا أن تعفو عنهم. كلُّ هذا مِمّا أمره الله ﷿ به، وخيَّره{17}٤٠٩٢. (ز) ٤٠٩٢ ذكر ابنُ عطية (٥/٦٥٦) عن ابن جرير أنّه ذهب إلى أنّ اتخاذ الحُسْن هو: الأسر مع كفرهم. ثم علّق عليه بقوله: «فالمعنى على هذا: أنهم كفروا ولا بُدَّ، فخيَّره الله بين قتلهم أو أسرهم». ثم ذكر احتمالًا آخر أن يكون اتخاذ الحُسْن: ضرب الجزية. ثم انتقده مستندًا إلى ظاهر القرآن بقوله: «ولكن تقسيم ذي القرنين بعد هذا الأمر إلى كفر أو إيمان يرد هذا القول بعض الرد، فتأمله». ٤٥٦٩٩- قال يحيى بن سلّام: فحكَّموه، فحكم بينهم، فوافق حكمُه حكمَ الله{25}. (ز) ",footnotes:1:أخرجه الترمذي ٥/١٩٥ (٣١٦٥). قال الترمذي: «هذا حديث غريب لا نعرفه إلا من هذا الوجه، والصحيح ما روي عن ابن عباس قراءته». وهي قراءة نافع، وابن كثير، وأبي عمرو، ويعقوب، وحفص عن عاصم، وقرأ بقية العشرة: ‹فِي عَيْنٍ حامِيَةٍ› بألف بعد الحاء، وفتح الياء من غير همز. انظر: النشر ٢/٣١٤، والإتحاف ص٣٧١.أخرجه الحاكم ٢/٢٥٩ (٢٩٣٣)، ٢/٢٦٦ (٢٩٦٠). قال الطحاوي في شرح المشكل ١/٢٥٥ (٢٨٢): «وكأن هذا الحديث مما لم يرفعه أحدٌ مِن حديث حماد بن سلمة غير عبد الغفار بن داود، وهو مما يخطئه فيه أهل الحديث، ويقولون: إنّه موقوف على ابن عباس، وقد خالفه فيه أصحاب حماد فلم يرفعوه، فمِمَّن خالفه فيه منهم خالد بن عبد الرحمن الخراساني، وحجاج بن منهال الأنماطي». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الطبراني في الصغير ٢/٢٥١ (١١١٥): «لم يروه عن ابن خثيم إلا حماد، تفرّد به أبو صالح». وقال الهيثمي في المجمع ٧/٥٤ (١١١٥٣): «رواه الطبراني عن شيخه الوليد بن عدّاس المصري، وهو ضعيف».عزاه السيوطي إلى الحافظ عبد الغني بن سعيد في إيضاح الإشكال.عزاه السيوطي إلى سعيد بن منصور.كذا في النسخ وتفسير عبد الرزاق، والصواب: عثمان بن حاضر. وقال الحافظ: «وقال الميموني عن أحمد: ظنَّ عبد الرزاق غلطًا، فقال: عثمان بن أبي حاضر. وإنما هو: عثمان بن حاضر». ينظر: تهذيب التهذيب ٧/١٠٩-١١٠، وسيأتي على الصواب في الرواية التالية.أخرجه يحيى بن سلام ١/٢٠٢ مختصرًا، وعبد الرزاق ٢/٤١١-٤١٢، وابن جرير ١٥/٣٧٥، وابن أبي حاتم -كما في تفسير ابن كثير ٥/١٨٩-. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد الرزاق، وسعيد بن منصور، وابن جرير، وابن أبي حاتم.أخرجه ابن جرير ١٥/٣٧٦.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه عبد الرزاق ٢/٤١٠، وابن جرير ١٥/٣٧٧ من طريقه، وفي المطبوع من تفسير عبد الرزاق: <q>﴿عين حمئة﴾</q>. وأخرج ابن جرير ١٥/٣٧٧ عن أبي رجاء، قال: سمعت الحسن البصري يقول: ‹فِي عَيْنٍ حامِيَةٍ› قال: حارة.أخرجه ابن عساكر في تاريخ دمشق ١٥/٣٢-٣٣.تفسير يحيى بن سلام ١/٢٠١.أخرجه أبو داود ٦/١٢٤ (٤٠٠٢)، والحاكم ٢/٢٦٧ (٢٩٦١)، والثعلبي ٦/١٩٠. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البوصيري في إتحاف الخيرة ٦/٢٠٩ (٥٦٩٩): «هذا إسناد صحيح». وقال الألباني في الصحيحة ٥/٥٢٨ (٢٤٠٣): «إسناده صحيح، على شرط مسلم».أخرجه أحمد ١١/٥٢٦-٥٢٧ (٦٩٣٤)، وابن جرير ١٥/٣٧٨. وأورده الثعلبي ٦/١٩١. قال ابن كثير في تفسيره ٥/١٩٢: «وفي صحة رفع هذا الحديث نظر، ولعلَّه من كلام عبد الله بن عمرو مِن زامِلَتَيْه اللَّتَيْن وجدهما يوم اليرموك». وقال الهيثمي في المجمع ٨/١٣١ (١٣٣٦١): «رواه أحمد، وفيه راوٍ لم يُسَمَّ، وبقية رجاله ثقات». وقال البوصيري في إتحاف الخيرة ٨/٢٢٣ (٧٨٣٣): «رواه أبو بكر بن أبي شيبة، وأحمد بن منيع، وأبو يعلى بسند واحد، فيه راوٍ لم يُسَمّ».أخرجه ابن أبي حاتم -كما في الإتقان ٢/٢٦-.تفسير مقاتل بن سليمان ٢/٦٠٠.أخرجه ابن جرير ١٥/٣٧٥.أخرجه ابن جرير ١٥/٣٧٥.عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن جرير ١٥/٣٧٦.أخرجه ابن جرير ١٥/٣٧٧.أخرجه عبد الرزاق ٢/٤١٠.تفسير مقاتل بن سليمان ٢/٦٠٠.تفسير يحيى بن سلام ١/٢٠٢.السّافِرَةُ: أُمَّة من الروم. النهاية (سفر).عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٦٠٠.أخرجه أبو يعلى -كما في المطالب العالية (٤٠٣٩)-، وأبو الشيخ في العظمة (٩٧٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢٠٢.علَّقه يحيى بن سلام ١/٢٠٢.تفسير مقاتل بن سليمان ٢/٦٠٠.تفسير يحيى بن سلام ١/٢٠٢.
18,87," <q>﴿قَالَ أَمَّا مَن ظَلَمَ﴾</q> - تفسير ٤٥٧٠٠- عن الضحّاك بن مُزاحِم، في قوله: <q>﴿أما من ظلم﴾</q>، قال: مَن أشْرَك{1}. (٩/٦٦٨) ٤٥٧٠١- قال يحيى بن سلّام: <q>﴿قال أما من ظلم﴾</q>، يعني: مِن الشِّرك{2}. (ز) <q>﴿فَسَوۡفَ نُعَذِّبُهُۥ﴾</q> - تفسير ٤٥٧٠٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فسوف نعذبه﴾</q>، قال: القتل{3}. (٩/٦٦٨) ٤٥٧٠٣- عن إسماعيل السدي، قال: كان عذابه أنه كان يجعلهم في بقرٍ من صُفْرٍ{4}، ثم توقد تحتهم النار حتى يَتَقَطَّعوا فيها{5}. (٩/٦٦٨) ٤٥٧٠٤- قال مقاتل بن سليمان: <q>﴿قال﴾</q> ذو القرنين: <q>﴿أما من ظلم فسوف نُعذبهُ﴾</q>، يعني: نقتله{6}. (ز) ٤٥٧٠٥- قال يحيى بن سلّام: <q>﴿فسوف نعذبه﴾</q>، يعني: القتل{2}. (ز) <q>﴿ثُمَّ یُرَدُّ إِلَىٰ رَبِّهِۦ فَیُعَذِّبُهُۥ عَذَابࣰا نُّكۡرࣰا ۝٨٧﴾</q> - تفسير ٤٥٧٠٦- قال مقاتل بن سليمان: <q>﴿ثُم يُردُ إلى ربه فيعذبه﴾</q> في الآخرة بالنار <q>﴿عذابًا نكرًا﴾</q> يعني: فظِيعًا{6}. (ز) ٤٥٧٠٧- قال يحيى بن سلّام: <q>﴿ثم يرد إلى ربه فيعذبه عذابا نكرا﴾</q>: عظيمًا في الآخرة{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ١/٢٠٢.أخرجه عبد الرزاق ١/٤١٢، وابن جرير ١٥/٣٧٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.قال ابن الأثير: قال الحافظ أبو موسى: الذي يقع لي في معناه: أنّه لا يريد شيئًا مَصُوغًا على صورة البقرة، ولكنه ربما كانت قِدرًا كبيرة واسعة، فسمّاها: بقرة، مأخوذا من التَّبَقُّر: التوسع، أو كان شيئًا يَسَعُ بقرة تامة بِتَوابِلِها فسمِّيت بذلك. النهاية (بقر).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٠٠.تفسير يحيى بن سلام ١/٢٠٢.تفسير مقاتل بن سليمان ٢/٦٠٠.تفسير يحيى بن سلام ١/٢٠٢.
18,88," <q>﴿وَأَمَّا مَنۡ ءَامَنَ وَعَمِلَ صَـٰلِحࣰا﴾</q> - تفسير ٤٥٧٠٨- قال مقاتل بن سليمان: <q>﴿وأَما من آمن﴾</q> يعني: صَدَّق بتوحيد الله ﷿، <q>﴿وعمل صالحًا﴾</q>{1}. (ز) <q>﴿فَلَهُۥ جَزَاۤءً ٱلۡحُسۡنَىٰۖ﴾</q> - تفسير ٤٥٧٠٩- عن مسروق بن الأجدع، في قوله: <q>﴿فله جزاء الحسنى﴾</q>، قال: الحسنى له جزاء{2}. (٩/٦٦٨) ٤٥٧١٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وأما من آمن وعمل صالحا فله جزاء الحسنى﴾</q>، قال: <q>﴿فله جزاء الحسنى﴾</q>، قال: هي لا إله إلا الله، أي: الحسنى: هي لا إله إلا الله{3}. (ز) ٤٥٧١١- عن مجاهد بن جبر -من طريق سفيان، عن أبي هاشم صاحب الرُّمّان- قال: الجنة{3}. (ز) ٤٥٧١٢- قال إسماعيل السدي: <q>﴿فله جزاء الحسنى﴾</q>، يعني: العفو{5}. (ز) ٤٥٧١٣- قال مقاتل بن سليمان: <q>﴿فَلهُ جزاءً الحسنى﴾</q>، يعني: الجنة{1}٤٠٩٣. (ز) ٤٠٩٣ ذكر ابنُ عطية (٥/٦٥٦-٦٥٧) القول بأن الحسنى: الجنة، ثم بيّن احتمال الآية معنًى آخر، وهو «أن يريد بالحسنى: أعمالهم الصالحة في إيمانهم، فوعدهم بجزاء أعمالهم الصالحة». <q>﴿وَسَنَقُولُ لَهُۥ مِنۡ أَمۡرِنَا یُسۡرࣰا ۝٨٨﴾</q> - تفسير ٤٥٧١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وسنقول له من أمرنا يسرا﴾</q>، قال: معروفًا{7}٤٠٩٤. (٩/٦٦٨) ٤٠٩٤ لم يذكر ابنُ جرير (١٥/٣٨٠) غير قول مجاهد. ٤٥٧١٥- قال مقاتل بن سليمان: <q>﴿وسنقول له من أمرنا يُسرًا﴾</q>، يقول: سنَعِدُه معروفًا، فلم يؤمن منهم غير رجل واحد{1}. (ز) ٤٥٧١٦- قال يحيى بن سلّام: <q>﴿وسنقول له من أمرنا﴾</q> ما صَحِبْناه في الدنيا وصَحِبَنا <q>﴿يسرا﴾</q>، يعني: العارف{9}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٠٠.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٢٠٢.أخرجه يحيى بن سلام ١/٢٠٢.علقه يحيى بن سلام ١/٢٠٢.تفسير مقاتل بن سليمان ٢/٦٠٠.أخرجه يحيى بن سلام ١/٢٠٣ من طريق ابن مجاهد، وابن جرير ١٥/٣٨٠. وعزاه السيوطي إلى ابن ابي شيبة، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٠٠.تفسير يحيى بن سلام ١/٢٠٣.
18,89," <q>﴿ثُمَّ أَتۡبَعَ سَبَبًا ۝٨٩﴾</q> - تفسير ٤٥٧١٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ثم أتبع سببا﴾</q>: منازل الأرض ومعالمها{1}. (ز) ٤٥٧١٨- قال مقاتل بن سليمان، في قوله: <q>﴿ثم اتبع سببًا﴾</q>، يعني: علم منازل الأرض وطرقها{2}. (ز) ٤٥٧١٩- قال يحيى بن سلّام، في قوله: <q>﴿ثم أتبع سببا﴾</q>: طرق الأرض ومعالمها لحاجته، على ما وصفتُ من تفسيرهم فيها{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٣٨١.تفسير مقاتل بن سليمان ٢/٦٠٠.تفسير يحيى بن سلام ١/٢٠٣.
18,90," <q>﴿حَتَّىٰۤ إِذَا بَلَغَ مَطۡلِعَ ٱلشَّمۡسِ وَجَدَهَا تَطۡلُعُ عَلَىٰ قَوۡمࣲ لَّمۡ نَجۡعَل لَّهُم مِّن دُونِهَا سِتۡرࣰا ۝٩٠﴾</q> - تفسير ٤٥٧٢٠- عن سمرة بن جندب، قال: قال النبي ﷺ: «<q>﴿لم نجعل لهم من دونها سترا﴾</q>: بناء، لم يُبْنَ فيها بناءٌ قط، كانوا إذا طلعت الشمسُ دخلوا أسرابًا لهم حتى تزول الشمس»{1}. (٩/٦٦٨) ٤٥٧٢١- عن الحسن البصري -من طريق سهل بن أبي الصلت السَّرّاج- في قوله: <q>﴿تطلع على قوم لم نجعل لهم من دونها سترا﴾</q>، قال: أرضُهم لا تحمِلُ البناء، فإذا طلعت الشمس تغوَّروا في المياه، فإذا غربت خرجوا يتراعون كما تَراعى البهائم. ثم قال الحسن: هذا حديث سمرة{2}. (٩/٦٦٩) ٤٥٧٢٢- عن سعيد بن جبير، في الآية، قال: تطلع على قوم حمر قصار، مساكنهم الغيران، فيلقى لهم سمك أكثر معيشتهم{3}. (٩/٦٧٠) ٤٥٧٢٣- عن سلمة بن كهيل، في الآية، قال: ليست لهم أكنان، إذا طلعت الشمس طلعت عليهم، لأحدهم أذنان، يفترش واحدةً، ويلبس الأخرى{3}. (٩/٦٦٩) ٤٥٧٢٤- عن قتادة بن دعامة -من طريق معمر- في الآية، قال: ذُكر لنا: أنهم بأرض لا يثبت لهم فيها شيء، فهم إذا طلعت في أسراب، حتى إذا زالت الشمس خرجوا إلى حروثهم ومعايشهم{5}. (٩/٦٦٩) ٤٥٧٢٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وجدها تطلع على قوم﴾</q> الآية، قال: يُقال: إنّهم الزِّنج{6}. (٩/٦٦٩) ٤٥٧٢٦- قال محمد بن السائب الكلبي: هم تاريس وتاويل ومنسك، عراةٌ حفاةٌ عماةٌ عن الحق {7}. (ز) ٤٥٧٢٧- عن عبد الملك ابن جريج -من طريق حجّاج- في قوله: <q>﴿وجدها تطلع على قوم لم نجعل لهم من دونها سترا﴾</q>، قال: لم يبنوا فيها بناءً قطُّ، ولم يُبْنَ عليهم فيها بناءٌ قط. وكانوا إذا طلعت الشمس دخلوا أسرابًا لهم حتى تزول الشمس، أو دخلوا البحر، وذلك أنّ أرضهم ليس فيها جبل، وجاءهم جيشٌ مرَّةً، فقال لهم أهلها: لا تطلعنَّ عليكم الشمسُ وأنتم بها. فقالوا: لا نبرح حتى تطلع الشمس، ما هذه العظام؟ قالوا: هذه جِيَفُ جيش طلعت عليهم الشمس هاهنا، فماتوا. قال: فذهبوا هاربين في الأرض{8}٤٠٩٥. (ز) ٤٠٩٥ ذكر ابنُ عطية (٥/٦٥٧-٦٥٨) قول ابن جريج، ثم أردف معلِّقًا: «وكثر النقاش وغيره في هذا المعنى، والظاهر من اللفظ أنها عبارة بليغة عن قرب الشمس منهم وفعلها؛ لقدرة الله تعالى فيهم، ونيلها منهم، ولو كان لهم أسراب تغني لكان سترًا كثيفًا، وإنما هم في قبضة القدرة، سواء كان لهم أسراب أو دُور أو لم يكن، ألا ترى أنّ الستر -عندنا نحن- إنما هو من السحاب والغمام وبرد الهوى، ولو سلَّط الله علينا الشمس لأحرقتنا!». ٤٥٧٢٨- قال مقاتل بن سليمان: <q>﴿حتى إذا بلغَ مطلع الشمس وجدها تطلع على قومٍ لم نجعل لهم من دونها سترًا﴾</q>، يعني: مِن دون الشمس سترًا، كانوا يستقرون في الأرض في أسراب من شدة الحر، وكانوا في مكان لا يَسْتَقِرُّ عليهم البناء، فإذا زالت الشمسُ خرجوا إلى معايِشهم{9}٤٠٩٦. (ز) ٤٠٩٦ قال ابنُ جرير (١٥/٣٨١-٣٨٣) في تفسير الآية: «ووجد ذو القرنين الشمسَ تطلع على قوم لم يجعل الله لهم دون الشمس سترًا، وذلك أن أرضهم لا جبل فيها ولا شجر، ولا تحتمل بناء، فيسكنوا البيوت، وإنما يغورون في المياه، ويسربون في الأسراب». واستشهد عليه بقول الحسن، وقتادة من طريق سعيد، وابن جريج. وذكر قولًا آخر، ولم يعلق عليه. ",footnotes:1:أخرجه أبو الشيخ في العظمة ٤/١٤٤١، وأبو يعلى -كما في إتحاف الخيرة للبوصيري ٦/١٧٠-، وابن أبي حاتم ٧/٢٣٨٦ (١٢٩٦٠)، من طريق ابن جريج، قال: حُدّثت عن الحسن، عن سمرة به. إسناده ضعيفٌ؛ لانقطاعه، فلم يذكر ابن جريج عمّن حدّثه به عن الحسن.أخرجه الطيالسي -كما في تفسير ابن كثير ٥/١٩٠- واللفظ له، وأبو الشيخ (٩٧٩) من قول الحسن، وابن جرير ١٥/٣٨٢. وعلقه يحيى بن سلام ١/٢٠٣ بنحوه. وعزاه السيوطي إلى البزار في أماليه، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤١٢، ويحيى بن سلام ١/٢٠٣ بنحوه، وابن جرير ١٥/٣٨٢ من طريق سعيد أيضًا. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤١٢، وابن جرير ١٥/٣٨٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/١٩٢، وفي تفسير البغوي ٥/٢٠١: هم قوم عُراة، يفترش أحدُهم إحدى أذنيه، ويلتحف بالأخرى.أخرجه ابن جرير ١٥/٣٨٢.تفسير مقاتل بن سليمان ٢/٦٠٠.
18,91," <q>﴿كَذَ ٰ⁠لِكَۖ وَقَدۡ أَحَطۡنَا بِمَا لَدَیۡهِ خُبۡرࣰا ۝٩١﴾</q> - تفسير ٤٥٧٢٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بما لديه خبرا﴾</q>، قال: عِلمًا{1}. (٩/٦٧٠) ٤٥٧٣٠- قال مقاتل بن سليمان: ثم قال: <q>﴿كذلك﴾</q>، يعني: هكذا بلغ مطلع الشمس كما بلغ مغربها. ثم استأنف، فقال سبحانه: <q>﴿وقد أحطنا بما لديه خبرًا﴾</q>، يعني: بما عنده عِلمًا{2}. (ز) ٤٥٧٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كذلك وقد أحطنا بما لديه خبرا﴾</q>، قال: عِلْمًا{3}. (ز) ٤٥٧٣٢- قال يحيى بن سلّام، في قوله: <q>﴿كذلك وقد أحطنا بما لديه خبرا﴾</q>، أي: هكذا كان ما قصَّ مِن أمر ذي القرنين{4}٤٠٩٧. (ز) ٤٠٩٧ ذكر ابنُ عطية (٥/٦٥٨) احتمالين في قوله: <q>﴿كَذلِكَ﴾</q>، فقال: «وقوله: <q>﴿كَذلِكَ﴾</q> معناه: فَعَل معهم كفعله مع الأولين أهل المغرب، فأوجز بقوله: <q>﴿كَذلِكَ﴾</q>. ثم أخبر الله تعالى عن إحاطته بجميع ما لدى ذي القرنين، وما تصرف من أفعاله. ويحتمل أن يكون كَذلِكَ استئناف قول، ولا يكون راجعًا على الطائفة الأولى، فتأمله». ثم رجّح الأول بقوله: «والأول أصوب». <q>﴿ثُمَّ أَتۡبَعَ سَبَبًا ۝٨٩﴾</q> - تفسير ٤٥٧٣٣- قال مقاتل بن سليمان: <q>﴿ثُم اتبع سببًا﴾</q>، يعني: علم منازل الأرض، وطرقها{2}. (ز) ٤٥٧٣٤- تفسير الحسن البصري: <q>﴿ثم أتبع سببا﴾</q> طرق الأرض ومعالمها لحاجته{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٣٨٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٠١.أخرجه ابن جرير ١٥/٣٨٤.تفسير يحيى بن سلام ١/٢٠٣.تفسير مقاتل بن سليمان ٢/٦٠١.علقه يحيى بن سلام ١/٢٠٣.
18,92," <q>﴿حَتَّىٰۤ إِذَا بَلَغَ بَیۡنَ ٱلسَّدَّیۡنِ﴾</q> - تفسير ٤٥٧٣٥- عن عبد الله بن عباس، في قوله: <q>﴿حتى إذا بلغ بين السدين﴾</q>، قال: الجبلين؛ أرمينية، وأذربيجان{1}. (٩/٦٧٠) ٤٥٧٣٦- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿حتى إذا بلغ بين السدين﴾</q>، قال: الجبلين، الردم الذي بين يأجوج ومأجوج، أمتين من وراء ردم ذي القرنين. قال: الجبلين: أرمينية، وأذربيجان{2}٤٠٩٨. (ز) ٤٠٩٨ ذكر ابنُ عطية (٥/٦٥٨) إضافةً إلى ما ورد في أقوال السلف في تعيين الجبلين قولًا آخر، فقال: «وقالت فرقة: هما من وراء بلاد الترك، ذكره المهدوي». ثم انتقد ابنُ عطية تعيين مكان الجبلين مستندًا إلى الواقع، فقال: «وهذا كله غير متحقق، وإنما هما في طريق الأرض مما يلي المشرق، ويظهر من ألفاظ التواريخ أنه إلى ناحية الشمال، وأما تعيين موضع فيضعف». ٤٥٧٣٧- عن الضحاك بن مزاحم -من طريق عبيد- يقول في قوله: <q>﴿بين السدين﴾</q>، يعني: بين جبلين{3}. (ز) ٤٥٧٣٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿حتى إذا بلغ بين السدين﴾</q>: وهما جبلان، يعني: بين الجبلين{4}. (ز) ٤٥٧٣٩- قال مقاتل بن سليمان: <q>﴿حتى إذا بلغ بين السدين﴾</q>، يعني: بين الجبلين{5}. (ز) <q>﴿وَجَدَ مِن دُونِهِمَا قَوۡمࣰا لَّا یَكَادُونَ یَفۡقَهُونَ قَوۡلࣰا ۝٩٣﴾</q> - قراءات ٤٥٧٤٠- عن مجاهد بن جبر -من طريق حميد-: ‹لا يَكادُونَ يُفْقِهُونَ قَوْلًا›{6}. (ز) ٤٥٧٤١- عن تميم بن حَذْلَمٍ أنّه كان يقرأ: <q>﴿لا يَكادُونَ يَفْقَهُونَ قَوْلًا﴾</q>{7}. (٩/٦٧٠) ٤٥٧٤٢- قال يحيى بن سلّام: وهي تقرأ على وجه آخر: ‹لا يَكادُونَ يُفْقِهُونَ قَوْلًا›: لا يَفْقَهُ أحدٌ كلامَهم{8}٤٠٩٩. (ز) ٤٠٩٩ علّق ابنُ جرير (١٥/٣٨٨) على هذه القراءة والتي قبلها، فقال: «والصواب عندي من القول في ذلك: أنهما قراءتان مستفيضتان في قراءة الأمصار، غير دافعة إحداهما الأخرى، وذلك أنّ القوم الذين أخبر الله عنهم هذا الخبر جائزٌ أن كانوا لا يكادون يفقهون قولًا لغيرهم عنهم؛ فيكون صوابًا القراءة بذلك. وجائز أن يكونوا -مع كونهم كذلك- كانوا لا يكادون يُفقِهون غيرهم لِعلل: إما بألسنتهم، وإما بمنطقهم؛ فتكون القراءة بذلك أيضًا صوابًا». <q>﴿وَجَدَ مِن دُونِهِمَا قَوۡمࣰا لَّا یَكَادُونَ یَفۡقَهُونَ قَوۡلࣰا ۝٩٣﴾</q> - تفسير الآية ٤٥٧٤٣- قال مقاتل بن سليمان: <q>﴿وجَدَ مِن دُونِهِما قَوْمًا لا يَكادُونَ يَفْقَهُونَ قَوْلًا﴾</q>، يعني: لم يكن أحدٌ يعرفُ لغتَهم{5}. (ز) ٤٥٧٤٤- عن عبد الملك ابن جريج، في قوله: <q>﴿قَوْمًا لا يَكادُونَ يَفْقَهُونَ قَوْلًا﴾</q>، قال: الترك{10}٤١٠٠. (٩/٦٧٠) ٤١٠٠ ذكر ابنُ عطية (٥/٦٥٩) في المراد بـ«القوم» اختلافًا؛ أبشر هم أم جنّ؟ ثم رجّح الأول بقوله: «والأول أصح من وجوه». ولم يذكر مستندًا. ٤٥٧٤٥- قال يحيى بن سلّام: <q>﴿وجَدَ مِن دُونِهِما قَوْمًا لا يَكادُونَ يَفْقَهُونَ قَوْلًا﴾</q>: كلام غيرهم{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٣٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٣٨٤.أخرجه ابن جرير ١٥/٣٨٧.أخرجه عبد الرزاق ٢/٤١٢ من طريق معمر، ويحيى بن سلام ١/٢٠٣، وابن جرير ١٥/٣٨٧.تفسير مقاتل بن سليمان ٢/٦٠١.أخرجه ابن الأعرابي في معجمه ١/٣٩٥ (٧٥٩). وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <q>﴿يَفْقَهُونَ﴾</q> بفتح الياء والقاف. انظر: النشر ٢/٣١٥، والإتحاف ص٣٧٢.عزاه السيوطي إلى سعيد بن منصور.تفسير يحيى بن سلام ١/٢٠٣.تفسير مقاتل بن سليمان ٢/٦٠١.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٢٠٣.
  18,93,""
18,94," <q>﴿قَالُوا۟ یَـٰذَا ٱلۡقَرۡنَیۡنِ إِنَّ یَأۡجُوجَ وَمَأۡجُوجَ﴾</q> - تفسير ٤٥٧٤٦- عن زينب بنت جحش، قالت: استيقظ رسول الله ﷺ مِن نومه وهو مُحْمَرٌّ وجهُه، وهو يقول: «لا إله إلا الله، ويلٌ للعرب مِن شرٍّ قد اقترب، فُتِح اليومَ مِن رَدْمِ يأجوج ومأجوج مثلَ هذه». وحلَّق، قلت: يا رسول الله، أنهلك وفينا الصالحون؟ قال: «نعم، إذا كَثُر الخَبَث»{1}. (٩/٦٧٨) ٤٥٧٤٧- عن عبد الله بن مسعود، قال: أتينا نبيَّ الله ﷺ يومًا وهو في قُبَّة أدم له، فخرج إلينا، فحمد الله، ثم قال: «أيَسُرُّكم أنّكم رُبُع أهل الجنة؟». فقلنا: نعم، يا رسول الله. فقال: «أيَسُرُّكم أنّكم ثُلُث أهل الجنة؟». فقلنا: نعم، يا نبي الله. قال: «والذي نفسي بيده، إنِّي لَأرجو أن تكونوا نِصف أهلِ الجنة، إنّ مثلكم في سائر الأُمَم كمثل شعرة بيضاء في جنب ثور أسود، أو شعرة سوداء في جنب ثور أبيض، إنّ بعدكم يأجوج ومأجوج، إنّ الرجل منهم لَيترك بعده مِن الذرية ألفًا فما زاد، وإنّ وراءهم ثلاث أمم: منسك، وتاويل، وتاريس، لا يعلم عِدَّتَهم إلا الله»{2}. (٩/٦٧٠) ٤٥٧٤٨- عن حذيفة بن اليمان، قال: سألتُ رسول الله ﷺ عن يأجوج ومأجوج. فقال: «يأجوج أُمَّة، ومأجوج أمة، كل أُمَّة بأربعمائة ألف أُمَّة، لا يموت رجل منهم حتى ينظر إلى ألف رجل مِن صُلْبِه، كلٌّ قد حمل السلاح». قلت: يا رسول الله، صِفْهم لنا. قال: «هم ثلاثة أصناف، صِنفٌ منهم أمثال الأرز». قلت: وما الأرز؟ قال: «شجر بالشام، طول الشجرة عشرون ومائة ذراع في السماء». قال رسول الله ﷺ: «هؤلاء الذين لا يقوم لهم جبل ولا حديد، وصنف منهم يفترش إحدى أذنيه ويلتحف بالأخرى، لا يمرون بفيل ولا وحش ولا جمل ولا خنزير إلا أكلوه، ومَن مات منهم أكلوه، مُقَدِّمتهم بالشام، وساقتهم يشربون أنهار المشرق وبحيرة طَبَرِيَّة»{3}. (٩/٦٧٦) ٤٥٧٤٩- عن حذيفة بن اليمان، مرفوعًا: «إنّ يأجوج أُمَّة، ومأجوج أمة، كلُّ أُمَّة أربعمائة ألف أُمَّة، لا يموت الرجل منهم حتى ينظر إلى ألف ذَكَر مِن صُلبه كلهم قد حَمَل السلاح، وهم مِن ولد آدم، يسيرون إلى خراب الدنيا»{4}. (ز) ٤٥٧٥٠- عن عبد الله بن عمرو، عن النبي ﷺ، قال: «إنّ يأجوج ومأجوج مِن ولد آدم، ولو أرسلوا لأفسدوا على الناس معايشهم، ولا يموت منهم رجلٌ إلا ترك مِن ذريته ألفًا فصاعدًا، وإنّ من وراءهم ثلاث أمم: تاويل، وتاريس، ومنسك»{5}. (٩/٦٧٥) ٤٥٧٥١- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «بعثني الله ليلة أسري بي إلى يأجوج ومأجوج، فدعوتُهم إلى دين الله وعبادته، فأبوا أن يجيبوني، فهم في النار مع مَن عصى مِن ولد آدم وولد إبليس»{6}. (٩/٦٧٦) ٤٥٧٥٢- من طريق عمرو بن أوس، عن أبيه، قال: قال رسول الله ﷺ: «إنّ يأجوج ومأجوج لهم نساء يجامعون ما شاءوا، وشجر يُلَقِّحون ما شاءوا، ولا يموت رجل منهم إلا تَرَكَ من ذريته ألفًا فصاعدًا»{7}. (٩/٦٧٥) ٤٥٧٥٣- عن علي بن أبي طالب -من طريق عبد الله بن مالك الهمداني- أنّه سُئِل عن التُّرْك. فقال: هم سيّارة، ليس لهم أصل، هم مِن يأجوج ومأجوج، لكنهم خرجوا يُغِيرُون على الناس، فجاء ذو القرنين فسَدَّ بينهم وبين قومهم، فذهبوا سيّارَةً في الأرض{8}. (٩/٦٧٤) ٤٥٧٥٤- عن علي بن أبي طالب أنّه قال: منهم مَن طوله شبر، ومنهم مَن هو مُفْرِطٌ في الطول{9}. (ز) ٤٥٧٥٥- عن عبد الله بن سلام، قال: ما مات رجلٌ مِن يأجوج ومأجوج إلا ترك ألف ذُرِّيٍّ لصُلبه فصاعدًا{10}. (٩/٦٧٤) ٤٥٧٥٦- عن عبد الله بن عمرو -من طريق عمرو البكالي- قال: إنّ الله جَزَّأ الملائكة والإنس والجن عشرة أجزاء؛ فتسعة أجزاء منهم الملائكة، وجزء واحد الجن والإنس. وجزَّأ الملائكة عشرة أجزاء؛ تسعة أجزاء منهم الكَروبِيُّون الذي يُسَبِّحون الليل والنهار لا يفترون، وجزء واحد لرسالاته ولخزائنه وما يشاء مِن أمره. وجَزَّأ الإنس والجن عشرة أجزاء؛ فتسعة منهم الجن، والإنس جزء واحد، فلا يولد مِن الإنس ولَدٌ إلا وُلِد من الجن تسعة. وجَزَّأ الإنسَ عشرة أجزاء؛ تسعة منهم يأجوج ومأجوج، وجزء سائر الناس{11}. (٩/٦٧١) ٤٥٧٥٧- عن وهب بن جابر الخيواني، قال: سألت عبد الله بن عمرو عن يأجوج ومأجوج: أمِن بني آدم هم؟ قال: نعم، ومِن بعدهم ثلاث أمم لا يعلم عددهم إلا الله: تاويل، وتاريس، ومنسك{12}. (٩/٦٧٣) ٤٥٧٥٨- عن عبد الله بن عمرو، قال: يأجوج ومأجوج يَمُرُّ أوَّلهم بنهر مثل دجلة، ويمر آخرهم فيقول: قد كان في هذا النهر مرَّة ماءٌ. ولا يموت رجلٌ إلا ترك ألفًا مِن ذريته فصاعدًا، ومن بعدهم ثلاثة أمم ما يعلم عدتهم إلا الله: تاريس، وتاويل، وناسك أو منسك{13}. (٩/٦٨٣) ٤٥٧٥٩- عن عبد الله بن عمرو، قال: يأجوج ومأجوج لهم أنهار يَلِغُون ما شاؤوا، ونساء يجامعون ما شاؤوا، وشجر يلقحون ما شاؤوا، ولا يموت رجل إلا ترك مِن ذريته ألفًا فصاعدًا{14}٤١٠١. (٩/٦٧٣) ٤١٠١ ذكر ابنُ عطية (٥/٦٦٠) ما ورد في هذا القول وبعضَ ما روي من أخبار يأجوج ومأجوج، ثم علّق قائلًا: «وأخبارهم تضيق بها الصحف، فاختصرتها لضعف صحتها». ٤٥٧٦٠- عن ابن مسعود الثقفي، قال: حدثني ابن أخي أو ابن عمِّي، قال: قلتُ لعبد الله بن عمرو: يأجوج ومأجوج الأَذْرُع هم أم الأشبار؟ قال: يا ابن أخي، ما أجِدُ مِن ولد آدم بأعظم منهم ولا أطول، ولا يموت الميِّت منهم حتى يُولَد له ألفٌ فصاعِدًا. قال: فقلت: ما طعامهم؟ قال: هم في ماء ما شربوا، وفي شجر ما هضموا، وفي نساء ما نكحوا{15}. (ز) ٤٥٧٦١- عن عبد الله بن عباس، قال: يأجوج ومأجوج شِبْر وشبران، وأطولهم ثلاثة أشبار، وهُم مِن ولد آدم{16}. (٩/٦٧٥) ٤٥٧٦٢- عن كعب الأحبار، قال: خُلِق يأجوج ومأجوج [ثلاثة] أصناف: صنف أجسامهم كالأرز، وصنف أربعة أذرع طول، وأربعة أذرع عرض، وصنف يفترشون آذانهم ويلتحفون بالأخرى، يأكلون مَشائمَ{17} نسائهم{18}. (٩/٦٧٣) ٤٥٧٦٣- قال كعب الأحبار: هم نادرة في ولد آدم، وذلك أنّ آدم احْتَلَم ذات يوم، وامْتَزَجَتْ نطفتُه بالتراب، فخلق الله مِن ذلك الماء يأجوج ومأجوج، فهم يَتَّصلون بنا مِن جهة الأب دون الأم{19}٤١٠٢. (ز) ٤١٠٢ قال ابنُ كثير (٩/١٩١): «وقد حكى النووي ﵀ في شرح مسلم عن بعض الناس: أنّ يأجوج ومأجوج خُلِقوا من مَنِيٍّ خرج من آدم، فاختلط بالتراب، فخُلِقوا من ذلك، فعلى هذا يكونون مخلوقين من آدم، وليسوا من حواء. وهذا القول غريب جدًّا، لا دليل عليه لا من عقل ولا مِن نقل، ولا يجوز الاعتماد هاهنا على ما يحكيه بعضُ أهل الكتاب، لِما عندهم من الأحاديث المفتعلة». ٤٥٧٦٤- عن أبي العالية الرِّياحي: إنّ يأجوج ومأجوج يزيدون على الإنس الضِّعْفَين، وإنّ الجن يزيدون على الإنس كذلك، وإنّ يأجوج ومأجوج رجلان، اسمهما: يأجوج، ومأجوج{20}. (٩/٦٧٢) ٤٥٧٦٥- عن ⟨أبي الزاهرية [حُدَيْرُ بن كُرَيْبٍ الحِمْصِيّ]⟩{ت}= (ز) ٤٥٧٦٦- وشريح بن عبيد -من طريق معاوية-: أنّ يأجوج ومأجوج ثلاثة أصناف: صنف طولهم كطول الأرز، وصنف طوله وعرضه سواء، وصنف يفترش أحدهم أذنه، ويلتحف بالأخرى، فتغطي سائر جسده{21}. (ز) ٤٥٧٦٧- قال الضحاك بن مزاحم: هُم جِيل مِن التُّرْك{22}. (ز) ٤٥٧٦٨- عن قتادة بن دعامة، قال: إنّ الله جَزَّأ الإنس عشرة أجزاء، فتسعة منهم يأجوج ومأجوج، وجزء سائر الناس{23}. (٩/٦٧٢) ٤٥٧٦٩- عن قتادة بن دعامة، قال: يأجوج ومأجوج ثنتان وعشرون قبيلة، فسَدَّ ذو القرنين على إحدى وعشرين قبيلة، وكانت قبيلة منهم غازِية، وهم الأتراك{24}. (٩/٦٧٤) ٤٥٧٧٠- عن قتادة بن دعامة: أنّهم اثنان وعشرون قبيلة، بنى ذو القرنين السدَّ على إحدى وعشرين قبيلة، فبَقِيَت قبيلةٌ واحدة، فهم التُّرْك، سُمُّوا: الترك؛ لأنهم تُرِكوا خارجين{9}. (ز) ٤٥٧٧١- قال إسماعيل السدي: التُّرْك سَرِيَّةٌ مِن يأجوج ومأجوج، خرجت، فضرب ذو القرنين السدَّ، فبقيت خارجه، فجميع التُّرْكِ منهم{9}. (ز) ٤٥٧٧٢- عن عبدة بن أبي لبابة: أنّ الدنيا سبعة أقاليم، فيأجوج ومأجوج في ستة أقاليم، وسائر الناس في إقليم واحد{27}. (٩/٦٧٢) ٤٥٧٧٣- عن حسّان بن عَطِيَّة، قال: إنّ يأجوج ومأجوج خمس وعشرون أُمَّة، ليس منها أُمَّة تشبه الأخرى{28}. (٩/٦٧٤) ٤٥٧٧٤- عن حسان بن عطية، قال: يأجوج ومأجوج أُمَّتان، في كل أُمَّة أربعمائة أُمَّة، لا تشبه واحدةٌ منهم الأخرى، ولا يموت الرجل منهم حتى ينظر في مائة عين مِن ولده{29}. (٩/٦٧٣) ٤٥٧٧٥- قال مقاتل بن سليمان: <q>﴿قالوا يا ذا القرنين إن يأجوج ومأَجوجَ﴾</q>، وهما أخَوان مِن ولد يافث بن نوح{30}. (ز) ٤٥٧٧٦- عن خالد الأشج، قال: إن بني آدم وبني إبليس ثلاثة أثلاث؛ فثلثان بنو إبليس، وثلث بنو آدم. وبنو آدم ثلاثة أثلاث؛ فثلثان يأجوج ومأجوج، وثلث سائر الناس. والناس بعد ثلاثة أثلاث؛ ثلث الأندلس، وثلث الحبشة، وثلث سائر الناس العرب والعجم{28}. (٩/٦٧٤) <q>﴿مُفۡسِدُونَ فِی ٱلۡأَرۡضِ﴾</q> - تفسير ٤٥٧٧٧- تفسير إسماعيل السدي: <q>﴿مفسدون في الأرض﴾</q>، يعني: قاتلين الناس في الأرض{32}. (ز) ٤٥٧٧٨- قال محمد بن السائب الكلبي: فسادهم أنهم كانوا يخرجون أيام الربيع إلى أرضهم، فلا يَدَعون فيها شيئًا أخضر إلا أكلوه، ولا شيئًا يابسًا إلا احتملوا وأدخلوه أرضهم، وقد لقوا منهم أذًى شديدًا وقتلًا{33}. (ز) ٤٥٧٧٩- قال مقاتل بن سليمان: <q>﴿مُفسدون في الأَرض﴾</q>، يعني بالفساد: القتل، يعني: أرض المسلمين{30}. (ز) ٤٥٧٨٠- عن الوليد بن مسلم، قال: سمعتُ سعيد بن عبد العزيز يقول في قوله: <q>﴿إن يأجوج ومأجوج مفسدون في الأرض﴾</q>، قال: كانوا يأكلون الناس{35}٤١٠٣. (ز) ٤١٠٣ ذكر ابنُ جرير في صفة إفساد يأجوج ومأجوج قول سعيد بن عبد العزيز المفيد لوقوع الإفساد منهم، وقولًا آخر أنّ الآية معناها: أنهم سيفسدون في الأرض، لا أنهم كانوا يومئذ يفسدون. وقد رجّح ابنُ جرير (١٥/٤٠١) هذا الأخير مستندًا إلى السنة، حيث قال: «فالخبر الذي ذكرناه عن وهب بن منبه في قصة يأجوج ومأجوج يدُلُّ على أنّ الذين قالوا لذي القرنين: <q>﴿إن يأجوج ومأجوج مفسدون في الأرض﴾</q> إنما أعلموه خوفهم ما يحدث منهم مِن الإفساد في الأرض، لا أنّهم شَكَوا منهم فسادًا كان منهم فيهم أو في غيرهم، والأخبار عن رسول الله ﷺ تخبر عنهم أنهم سيكون منهم الإفساد في الأرض، ولا دلالة فيها أنهم قد كان منهم قبل إحداث ذي القرنين السدَّ الذي أحدثه بينهم وبين مَن دونهم مِن الناس غيرهم إفسادٌ. فإذا كان ذلك كذلك بالذي بينا فالصحيح من تأويل قوله: <q>﴿إن يأجوج ومأجوج مفسدون في الأرض﴾</q>: إن يأجوج ومأجوج سيفسدون في الأرض». ورجّح ابنُ عطية (٥/٦٥٩-٦٦٠) وقوع الإفساد منهم مستندًا إلى ظاهر الآية، فقال: «وقالت فرقة: إفسادهم هو الظلم، والغشم، والقتل، وسائر وجوه الإفساد المعلوم من البشر، وهذا أظهر الأقوال؛ لأن الطائفة الشاكية إنما شكت مِن ضُرٍّ قد نالَهم». ٤٥٧٨١- قال يحيى بن سلّام: يعني: أرض العرب، أرض الإسلام{36}. (ز) ٤٥٧٨٢- عن حبيب الأرَجانيِّ، في قوله: <q>﴿إن يأجوج ومأجوج مفسدون في الأرض﴾</q>، قال: كان فسادُهم أنهم كانوا يأكلون الناس{18}. (٩/٦٧٨) <q>﴿فَهَلۡ نَجۡعَلُ لَكَ خَرۡجًا عَلَىٰۤ أَن تَجۡعَلَ بَیۡنَنَا وَبَیۡنَهُمۡ سَدࣰّا ۝٩٤﴾</q> - تفسير ٤٥٧٨٣- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿فهل نجعل لك خرجا﴾</q>، قال: أجرًا عظيمًا{38}. (٩/٦٧٨) ٤٥٧٨٤- عن عكرمة مولى ابن عباس، قال: ما صنع الله فهو السُّدُّ، وما صنع الناس فهو السَّدُّ{24}. (٩/٦٧٩) ٤٥٧٨٥- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿فهل نجعل لك خرجا﴾</q>، قال: أجرًا{40}. (ز) ٤٥٧٨٦- عن عطاء الخراساني -من طريق يونس بن يزيد- وفي قول الله ﷿: ‹خَراجًا›{41}، قال: الخراج: الرَّيْع{42}. (ز) ٤٥٧٨٧- قال مقاتل بن سليمان: <q>﴿فهل نجعل لك خرجًا﴾</q> يعني: جُعْلًا، <q>﴿عَلى أن تجعل بيننا وبينهم سدًا﴾</q> لا يصلون إلينا{30}. (ز) ٤٥٧٨٨- قال أبو عمرو بن العلاء: الخرج: ما تبرَّعتَ به. والخراج: ما لَزِمَك أداؤه{44}. (ز) ",footnotes:1:أخرجه البخاري ٤/١٣٨ (٣٣٤٦)، ٤/١٩٨ (٣٥٩٨)، ٩/٤٨ (٧٠٥٩)، ٩/٦١ (٧١٣٥)، ومسلم ٤/٢٢٠٧- ٢٢٠٨ (٢٨٨٠)، وعبد الرزاق ٢/٢٩٣ (١٥٤٦).أخرجه ابن حبان ١٥/٢٤٠-٢٤١ (٦٨٢٨) مختصرًا، وابن أبي حاتم ٧/٢٣٨٧ (١٢٩٦٧) واللفظ له، من طريق زيد بن أبي أنيسة، عن أبي إسحاق، عن عمرو بن ميمون الأودي، عن ابن مسعود به. إسناده ضعيف؛ أبو إسحاق السبيعي قد اختلط، ولا يُعلَم هل سماع زيد بن أبي أنيسة عنه كان قبل اختلاطه أم بعده، وزيد بن أنيسة قال ابن حجر عنه في التقريب (٢١١٨): «ثقة له أفراد». والحديث ثابت في الصحيحين والسنن مِن طرقٍ عن أبي إسحاق عن عمرو عن ابن مسعود به دون ذكر يأجوج ومأجوج، فلعل هذا من أفراد زيدٍ التي أخطأ فيها.أخرجه الطبراني في الأوسط ٤/١٥٥ (٣٨٥٥)، وابن عدي في الكامل في الضعفاء ٧/٣٦٨-٣٦٩ (١٦٥٣) في ترجمة محمد بن إسحاق بن إبراهيم بن محمد بن عكاشة بن محصن الأسدي. قال الطبراني: «لم يروِ هذا الحديثَ عن الأعمش إلا محمد بن إسحاق، ولا عن محمد بن إسحاق إلا يحيى بن سعيد العطار». وقال ابن عدي: «هذه الأحاديث بأسانيدها مع غير هذا مما لم أذكره لمحمد بن إسحاق العكاشي كلها مناكير موضوعة». وقال الهيثمي في المجمع ٨/٦ (١٢٥٧٢): «رواه الطبراني في الأوسط، وفيه يحيى بن سعيد العطار، وهو ضعيف». وقال ابن حجر في الفتح ١٣/١٠٦: «وهو من رواية يحيى بن سعيد العطار، عن محمد بن إسحاق، عن الأعمش، والعطّار ضعيف جدًّا، ومحمد بن إسحاق قال ابن عدي: ليس هو صاحب المغازي، بل هو العكاشي. قال: والحديث موضوع. وقال ابن أبي حاتم: منكر. قلت: لكن لبعضه شاهد صحيح». وقال ابن عراق في تنزيه الشريعة ١/٢٣٧ (٢٢): «ورأيت بخط الشيخ تقي الدين القلقشندي على حاشية الموضوعات لابن الجوزي ما نصُّه: لم ينفرد به العكاشي إلا من حديث حذيفة، وقد رواه ابن حبان». وقال الألباني في الضعيفة ٩/١٦٤ (٤١٤٣): «موضوع».أخرجه ابن جرير ١٦/٣٩٧. وأورده الثعلبي ٦/٣٠٧، والبغوي في تفسيره ٥/٢٠٢ واللفظ له، من طريق عصام بن رواد بن الجراح، قال: حدثني أبي، قال: حدثنا سفيان بن سعيد الثوري، قال: حدثنا منصور بن المعتمر، عن ربعي بن حراش، قال: سمعت حذيفة به. إسناده ضعيف؛ فيه روّاد بن الجراح أبو عصام العسقلاني، قال عنه ابن حجر في التقريب (١٩٥٨): «صدوق اختلط بأخرة؛ فتُرِك، وفي حديثه عن الثوري ضعف شديد».أخرجه أبو داود الطيالسي ٤/٣٩ (٢٣٩٦)، والطبراني في الأوسط ٨/٢٦٧ (٨٥٩٨). قال ابن كثير في تفسيره ٥/٢٠٠: «هذا حديث غريب، بل منكر ضعيف». وقال الهيثمي في المجمع ٨/٦ (١٢٥٧١): «رواه الطبراني في الكبير، والأوسط، ورجاله ثقات». وقال الألباني في الضعيفة ٩/١٥٩ (٤١٤٢): «منكر».أخرجه نعيم بن حماد في كتاب الفتن ٢/٥٩٣ (١٦٥٣). قال السيوطي: «بسند واه». وقال الصالحي في سبل الهدى والرشاد ١٠/١٨٥: «بسند واهٍ جدًّا».أخرجه النسائي في الكبرى ١٠/١٨٦ (١١٢٧١)، وابن أبي حاتم وابن مردويه -كما في فتح الباري لابن حجر ١٣/١٠٩-. قال الألباني في الضعيفة ٧/١٩٢ (٣٢٠٩): «ضعيف».أخرجه إسحاق البستي في تفسيره ص١٥٤ بنحوه. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٢٠٢.أخرجه ابن جرير ١٦/٤٠٠. وعزاه السيوطي إلى ابن أبي شيبة.أخرجه الحاكم ٤/٤٩٠، كما أخرجه عبد الرزاق ٢/٢٨، وابن جرير ١٦/٤٠١ كلاهما بدون ذكر عبد الله. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٣٩٩.أخرجه يحيى بن سلام ١/٢٠٧ بنحوه، وابن جرير ١٦/٣٩٩، والحاكم ٤/٤٩٠.أخرجه ابن جرير ١٦/٣٩٩-٤٠٠.أخرجه يحيى بن سلام ١/٢٠٧.أخرجه الحاكم ٤/٥٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.يقال لِما يكون فيه الولد: المَشِيمَةُ، والكِيس، والحَوْران. لسان العرب (شيم).عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/١٩٣، وتفسير البغوي ٥/٢٠٣ واللفظ له.أخرجه ابن جرير ١٦/٣٩٨-٣٩٩ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٣٩٠.تفسير الثعلبي ٦/١٩٣، وتفسير البغوي ٥/٢٠٢.عزاه السيوطي إلى عبد الرزاق، ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٢٠٢.تفسير البغوي ٥/٢٠٢.أخرجه أبو الشيخ في العظمة (٩٤٣).عزاه السيوطي إلى ابن المنذر.أخرجه أبو الشيخ (٩٤٤). وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٦٠١.عزاه السيوطي إلى ابن المنذر.علقه يحيى بن سلام ١/٢٠٤.تفسير الثعلبي ٦/١٩٣، وتفسير البغوي ٥/٢٠٤.تفسير مقاتل بن سليمان ٢/٦٠١.أخرجه ابن جرير ١٥/٣٨٩.تفسير يحيى بن سلام ١/٢٠٤.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤١٢، وابن جرير ١٥/٤٠٢. وعلَّقه يحيى بن سلام ١/٢٠٤ بلفظ: جعلًا.‹خَراجًا› بفتح الراء وبعدها ألف؛ قرأ بها حمزة والكسائي وخلف. انظر: النشر ٢/٣١٥.أخرجه أبو جعفر الرملي في جزئه ص٩٦ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٢/٦٠١.تفسير الثعلبي ٦/١٩٩، وتفسير البغوي ٥/٢٠٤.
18,95," <q>﴿قَالَ مَا مَكَّنِّی فِیهِ رَبِّی خَیۡرࣱ﴾</q> - تفسير ٤٥٧٨٩- عن إسماعيل السدي، في قوله: <q>﴿ما مكني فيه ربي خير﴾</q>، قال: الذي أعطاني ربي هو خيرٌ مِن الذي تبذلون لي مِن الخراج{1}. (٩/٦٧٩) ٤٥٧٩٠- قال مقاتل بن سليمان: <q>﴿قال﴾</q> ذو القرنين: <q>﴿ما مكني فيه ربي خيرٌ﴾</q>، يقول: ما أعطاني ربي من الخير خيرٌ من جُعْلِكم، يعني: أُعْطِيَتكُمْ{2}. (ز) ٤٥٧٩١- قال يحيى بن سلّام: <q>﴿قال ما مكني فيه ربي خير﴾</q> مِن جُعْلِكُم{3}. (ز) <q>﴿فَأَعِینُونِی بِقُوَّةٍ﴾</q> - تفسير ٤٥٧٩٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فأعينوني بقوة﴾</q>، قال: برجال{4}. (ز) ٤٥٧٩٣- تفسير إسماعيل السدي: <q>﴿فأعينوني بقوة﴾</q>، يعني: عددًا مِن الرجال{5}. (ز) ٤٥٧٩٤- قال مقاتل بن سليمان: <q>﴿فأعينوني بقوةٍ﴾</q>، يعني: بعدد رجال. مثل قوله ﷿ في سورة هود: <q>﴿ويزدكم قوةَ إلى قوتكم﴾</q> [هود:٥٢]، يعني: عَدَدًا إلى عددكم{2}. (ز) <q>﴿أَجۡعَلۡ بَیۡنَكُمۡ وَبَیۡنَهُمۡ رَدۡمًا ۝٩٥﴾</q> - تفسير ٤٥٧٩٥- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿أجعل بينكم وبينهم ردما﴾</q>، قال: هو كأشدِّ الحِجاب{7}. (٩/٦٧٩) ٤٥٧٩٦- قال مقاتل بن سليمان: <q>﴿أجعل بينكم وبينهم ردمًا﴾</q> لا يَصِلون إليكم{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٠١.تفسير يحيى بن سلام ١/٢٠٤.أخرجه ابن جرير ١٥/٤٠٣.علقه يحيى بن سلام ١/٢٠٤.تفسير مقاتل بن سليمان ٢/٦٠١.أخرجه ابن جرير ١٥/٤٠٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٠١.
18,96," <q>﴿ءَاتُونِی زُبَرَ ٱلۡحَدِیدِۖ﴾</q> - تفسير ٤٥٧٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿زبر الحديد﴾</q>، قال: قِطَع الحديد{1}. (٩/٦٧٩) ٤٥٧٩٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال: أخبِرني عن قوله: <q>﴿زبر الحديد﴾</q>. قال: قِطَع الحديد. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت كعب بن مالك وهو يقول: تَلَظّى عليهم حين شَدَّ حَمِيُّها بزُبر الحديدِ والحجارة شاجِرُ{2}. (٩/٦٧٩) ٤٥٧٩٩- عن مجاهد بن جبر -من طريق أبي يحيى- قوله: <q>﴿آتوني زبر الحديد﴾</q>، قال: قِطَع الحديد{3}. (ز) ٤٥٨٠٠- عن أبي صالح باذام -من طريق إسماعيل- قوله: <q>﴿زبر الحديد﴾</q>، قال: قِطَع الحديد{4}. (ز) ٤٥٨٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿آتوني زبر الحديد﴾</q>، أي: فِلَقَ الحديد{5}. (ز) ٤٥٨٠٢- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله تعالى: <q>﴿زبر الحديد﴾</q> قال: قطع الحديد{6}. (ز) ٤٥٨٠٣- قال مقاتل بن سليمان: <q>﴿آتوني زُبر الحديد﴾</q>، يعني: قِطَع الحديد{7}. (ز) ٤٥٨٠٤- قال يحيى بن سلّام: <q>﴿آتوني﴾</q> أعطوني <q>﴿زبر الحديد﴾</q> قِطَع الحديد{8}. (ز) <q>﴿حَتَّىٰۤ إِذَا سَاوَىٰ بَیۡنَ ٱلصَّدَفَیۡنِ﴾</q> - قراءات ٤٥٨٠٥- عن إبراهيم النخعي -من طريق مغيرة- أنه كان يقرأ: <q>﴿بَيْنَ الصَّدَفَيْنِ﴾</q> –بفتحتين- قال: يعني: بين الجبلين{9}٤١٠٤. (٩/٦٨٠) ٤١٠٤ ذكر ابنُ جرير (١٥/٤٠٨) القراءات المختلفة في الآية، ثم رجّح هذه القراءة بقوله: «والفتح في الصاد والدال أشهر هذه اللغات، والقراءة بها أعجب إلَيَّ، وإن كنت مستجيزًا القراءة بجميعها لاتِّفاق معانيها. وإنما اخترت الفتح فيهما لما ذكرت من العلة». وقال ابنُ عطية (٥/٦٦٢) عَقِب ذكره القراءات المختلفة في الآية: «وكل ذلك بمعنًى واحد: هما الجبلان المتناوحان، وقيل: الصدفان: السطحان الأعليان مِن الجبلين. وهذا نحو مِن الأول». ٤٥٨٠٦- عن مجاهد بن جبر -من طريق حميد- قرأ: ‹بَيْنَ الصُّدُفَيْنِ›{10}. (ز) ٤٥٨٠٧- عن الحسن البصري، أنه كان يقرأ: ‹بَيْنَ الصُّدُفَيْنِ› بضمتين{11}. (٩/٦٨٠) <q>﴿حَتَّىٰۤ إِذَا سَاوَىٰ بَیۡنَ ٱلصَّدَفَیۡنِ﴾</q> - تفسير الآية ٤٥٨٠٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بين الصدفين﴾</q>، قال: الجبلين{12}. (٩/٦٧٩) ٤٥٨٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بين الصدفين﴾</q>، قال: رؤوس الجبلين{13}. (٩/٦٨٠) ٤٥٨١٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال في قوله: <q>﴿بين الصدفين﴾</q>، يعني: الجبلين، وهما مِن قِبَلِ أرمينية وأذربيجان{14}. (ز) ٤٥٨١١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿حتى إذا ساوى بين الصدفين﴾</q>: وهما الجَبَلان{14}. (ز) ٤٥٨١٢- قال مقاتل بن سليمان: <q>﴿حتى إذا ساوى بين الصدفين﴾</q>، يعني: حَشا بين الجبلين بالحديد. والصدفين: الجبلين، وبينهما واد عظيم{7}. (ز) <q>﴿قَالَ ٱنفُخُوا۟ۖ حَتَّىٰۤ إِذَا جَعَلَهُۥ نَارࣰا قَالَ ءَاتُونِیۤ أُفۡرِغۡ عَلَیۡهِ قِطۡرࣰا ۝٩٦﴾</q> - تفسير ٤٥٨١٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿قطرا﴾</q>، قال: النحاس{17}. (٩/٦٨٠) ٤٥٨١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿قطرا﴾</q>، قال: نُحاسًا{18}. (٩/٦٨٠) ٤٥٨١٥- عن الضحاك بن مزاحم -من طريق عبيد- قال في قوله: <q>﴿أفرغ عليه قطرا﴾</q>، يعني: النحاس{19}. (ز) ٤٥٨١٦- عن عكرمة مولى ابن عباس، في قوله: <q>﴿آتوني أفرغ عليه قطرا﴾</q>، قال: نحاسًا، فيلزم بعضه بعضًا{20}. (٩/٦٨٠) ٤٥٨١٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أفرغ عليه قطرا﴾</q>، أي: النحاس؛ لِنُلزمَه به{21}. (ز) ٤٥٨١٨- تفسير قتادة بن دعامة: <q>﴿أفرغ عليه قطرا﴾</q>، فيها تقديم. أعْطُوني قِطرًا أفرغ عليه. والقِطْر: النحاس. فجعل أساسه الحديد، وجعل ملاطه النحاس ليلزمه{22}. (ز) ٤٥٨١٩- قال مقاتل بن سليمان: <q>﴿قال انفخوا﴾</q> على الحديد، <q>﴿حتى إذا جعله نارًا قال آتوني أفرغ عليه قطرًا﴾</q> قال: أعطوني الصُّفْر المذاب أصُبُّه عليه لِيلحمه، فيكون أشدَّ له. قال رجل للنبي ﷺ: قد رأيت سدَّ يأجوج ومأجوج. قال النبي ﷺ: «انْعَتْهُ لي»، قال: هو كالبُرْدِ المُحَبَّرِ، طريقة سوداء وطريقة حمراء. قال النبي ﷺ: «نعم، قد رأيتَه»{23}٤١٠٥. (ز) ٤١٠٥ بيّن ابنُ عطية (٥/٦٦٢) أن هذا الأثر يؤيد قولَ مَن قال: إنّ القطر هو النحاس المذاب. ثم ذكر قولين آخرين في معنى القطر: الأول: أنه الرصاص المذاب. الثاني: أنه الحديد الذائب. ٤٥٨٢٠- قال يحيى بن سلّام: <q>﴿حتى إذا جعله نارا﴾</q> يعني: أحماه بالنار؛ <q>﴿قال آتوني﴾</q> أعطوني{8}. (ز) <q>﴿قَالَ ٱنفُخُوا۟ۖ حَتَّىٰۤ إِذَا جَعَلَهُۥ نَارࣰا قَالَ ءَاتُونِیۤ أُفۡرِغۡ عَلَیۡهِ قِطۡرࣰا ۝٩٦﴾</q> - آثار متعلقة بالآية ٤٥٨٢١- عن أبي هريرة، عن رسول الله ﷺ، قال: «إنّ يأجوج ومأجوج يحفرون السدَّ كل يوم، حتى إذا كادوا يرون شُعاع الشمس قال الذي عليهم: ارجعوا، فستفتحونه غدًا. فيعودون إليه كأشدَّ ما كان، حتى إذا بلغت مدتُهم وأراد الله أن يبعثهم على الناس حفروا، حتى إذا كادوا يرون شعاع الشمس قال الذي عليهم: ارجعوا، فستفتحونه غدًا -إن شاء الله-. ويستثني، فيعودون إليه وهو كهيئته حين تركوه، فيحفرونه، ويخرجون على الناس، فيستقون المياه، ويَتَحَصَّن الناس منهم في حصونهم، فيَرْمُون بسهامهم إلى السماء، فترجع مُخَضَّبَةً بالدماء، فيقولون: قهرنا مَن في الأرض، وعلونا مَن في السماء قَسْرًا وعُلُوًّا. فيبعث الله عليهم نَغْفًا في أقفائهم{25}، فيهلكون». قال رسول الله ﷺ: «فوالذي نفس محمد بيده، إنّ دوابَّ الأرض لَتَسْمَن وتبطر وتَشْكَرُ شَكَرًا{26} مِن لحومهم»{27}. (٩/٦٧٧) ٤٥٨٢٢- عن قتادة، قال: ذُكِر لنا: أنّ رجلًا قال: يا رسول الله، قد رأيتُ سدَّ يأجوج ومأجوج. قال: «انعته لي». فقال: هو كالبُرْد المُحَبَّر، طريقة سوداء وطريقة حمراء. قال: «قد رأيتَه»{28}. (٩/٦٧٦) ",footnotes:1:أخرجه ابن جرير ١٥/٤٠٥، ومن طريق العوفي وابن جريج أيضًا، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي -كما في الإتقان ٢/٨٩-.أخرجه يحيى بن سلام ١/٢٠٤، وابن جرير ١٥/٤٠٥.أخرجه ابن جرير ١٥/٤٠٥.أخرجه عبد الرزاق ٢/٤١٢ من طريق معمر بلفظ: قِطَع الحديد، وابن جرير ١٥/٤٠٥.أخرجه أبو جعفر الرملي في جزئه ص٩٥ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٢/٦٠١-٦٠٢.تفسير يحيى بن سلام ١/٢٠٤.أخرجه ابن جرير ١٥/٤٠٧. وعزاه السيوطي إلى سعيد بن منصور. وهي قراءة العشرة ما عدا ابن كثير، وأبا عمرو، ويعقوب، وابن عامر؛ فإنهم قرؤوا: ‹بَيْنَ الصُّدُفَيْنِ› بضم الصاد والدال، وما عدا أبا بكر عن عاصم؛ فإنه قرأ: ‹بَيْنَ الصُّدْفَيْنِ› بضم الصاد وإسكان الدال. انظر: النشر ٢/٣١٦، والإتحاف ص٣٧٣.أخرجه ابن الأعرابي في معجمه ١/٣٩٥ (٧٥٨).عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن جرير ١٥/٤٠٦، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٠٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٠٧.أخرجه ابن جرير ١٥/٤٠٧.تفسير مقاتل بن سليمان ٢/٦٠١-٦٠٢.أخرجه ابن جرير ١٥/٤٠٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٠٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٥/٤٠٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤١٣ من طريق معمر، وابن جرير ١٥/٤٠٩.علقه يحيى بن سلام ١/٢٠٤.تفسير مقاتل بن سليمان ٢/٦٠١-٦٠٢. وسيأتي تخريج الحديث في الآثار المتعلقة بالآية.تفسير يحيى بن سلام ١/٢٠٤.أقفاء: جمع قفا، وهو مؤخر العنق. لسان العرب (قفا).أي: تسمن وتمتلئ شحمًا. النهاية (شكر).أخرجه أحمد ١٦/٣٦٩-٣٧٠ (١٠٦٣٢)، والترمذي ٥/٣٧٤ (٣٤١٩)، وابن ماجه ٥/٢٠٧ (٤٠٨٠) واللفظ له، وابن حبان ١٥/٢٤٢- ٢٤٣ (٦٨٢٩)، والحاكم ٤/٥٣٤ (٨٥٠١)، ويحيى بن سلام ١/٢٠٥، وابن جرير ١٥/٣٩٨-٣٩٩. قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/١٩٧-١٩٨: «وهذا إسناده قوي، ولكن في رفعه نكارة». وقال ابن حجر في الفتح ١٣/١٠٩-١١٠ عن إسناد الحاكم: «وسنده صحيح».أخرجه يحيى بن سلام ١/٢٠٤، وابن جرير ١٥/٤٠٤. وأورده الثعلبي ٦/١٩٩. قال ابن كثير في البداية والنهاية ٢/٥٥٦: «ذكره البخاري مُعَلِّقًا بصيغة الجزم، ولم أره مسندًا مِن وجه مُتَّصل أرتضيه، غير أنّ ابن جرير رواه في تفسيره مرسلًا». وقال ابن حجر في الفتح ٦/٣٨٦: «وصله ابن أبي عمر، من طريق سعيد بن أبي عروبة، عن قتادة، عن رجل من أهل المدينة».
18,97," <q>﴿فَمَا ٱسۡطَـٰعُوۤا۟ أَن یَظۡهَرُوهُ وَمَا ٱسۡتَطَـٰعُوا۟ لَهُۥ نَقۡبࣰا ۝٩٧﴾</q> - تفسير ٤٥٨٢٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فما اسطاعوا أن يظهروه﴾</q>، قال: ما استطاعوا أن يَرْتَقوه{1}. (٩/٦٨٠) ٤٥٨٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فما اسطاعوا أن يظهروه﴾</q> قال: مِن فوقه، <q>﴿وما استطاعوا له نقبا﴾</q> قال: مِن أسفلِه{2}. (٩/٦٨١) ٤٥٨٢٥- قال إسماعيل السدي: <q>﴿أن يظهروه﴾</q>، يعني: يرتقوه، فيَعْلُوه{3}. (ز) ٤٥٨٢٦- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿فما اسطاعوا أن يظهروه﴾</q> يقول: أن يعلوه، <q>﴿وما استطاعوا له نقبا﴾</q> قال: مِن أسفله{4}. (٩/٦٨١) ٤٥٨٢٧- قال مقاتل بن سليمان: قول الله ﷿: <q>﴿فما اسطاعوا﴾</q> يعني: فما قدروا <q>﴿أن يظهروهُ﴾</q> على أن يعلوه مِن فوقه. مثل قوله في الزخرف [٣٣]: <q>﴿معارج عليها يظهرونَ﴾</q>، يعني: يرتقون. <q>﴿وما استطاعوا﴾</q> يعني: وما قدروا <q>﴿له نقبًا﴾</q> ... عن مقاتل، عن أبي إسحاق، قال: قال عليُّ بن أبي طالب: إنّهم خلف الرَّدْم، لا يموت منهم رجلٌ حتى يُولَد له ألف ذَكَر لصُلْبِه، وهم يغدون إليه كلَّ يوم، ويُعالِجون الرَّدْم، فإذا أمْسَوا يقولون: نرجِع فنفتحه غدًا. ولا يستثنون، حتى يُولَد فيهم رجلٌ مسلم، فإذا غدوا إليه قال لهم المسلم: قولوا: باسم الله. ويعالِجون حتى يتركوه رقيقًا كقشر البيض، ويروا ضوء الشمس، فإذا أصبحوا غَدَوا عليه، فيقول لهم المسلم: نرجع غدًا -إن شاء الله- فنفتحه. فإذا غدوا عليه، قال لهم المسلم: قولوا: باسم الله. فينقبونه، فيخرجون منه، فيطوفون الأرض، ويشربون ماء الفرات، فيجيء آخرهم، فيقول: قد كان هاهنا مَرَّة ماء. ويأكلون كل شيء حتى الشجر، ولا يأتون على شيء مِن غيرها إلا فَأَمُوه{5}{6}. (ز) ",footnotes:1:أخرجه عبد الرزاق ١/٤١٣، وابن جرير ١٥/٤١١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤١٠-٤١١. وعلَّقه يحيى بن سلام ١/٢٠٤. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٢٠٥.أخرجه ابن جرير ١٥/٤١١. وعزاه السيوطي إلى ابن المنذر.فأموه: ملؤوا أفواههم منه. التاج (فأم).تفسير مقاتل بن سليمان ٢/٦٠٢. وقد وقعت الكلمة الأخيرة فيه غير مهموزة (فاموه)، وعلق عليها محققه، فقال: هكذا في ا، ل. وقد يكون أصلها إلا أكلوه.
