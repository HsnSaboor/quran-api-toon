tafsir[5]{c,v,t}:
42,11," <q>﴿فَاطِرُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</q> - تفسير ٦٨٨٤٣- عن إسماعيل السُّدّيّ -من طريق أسباط- قوله: <q>﴿فاطِرُ السَّماواتِ والأَرْضِ﴾</q>، قال: خالق{1}. (ز) ٦٨٨٤٤- قال مقاتل بن سليمان: قوله: <q>﴿فاطِرُ السَّماواتِ والأَرْضِ﴾</q>، يعني: خالق السموات والأرض{2}. (ز) <q>﴿جَعَلَ لَكُم مِّنۡ أَنفُسِكُمۡ أَزۡوَ ٰ⁠جࣰا وَمِنَ ٱلۡأَنۡعَـٰمِ أَزۡوَ ٰ⁠جࣰا﴾</q> - تفسير ٦٨٨٤٥- قال مقاتل بن سليمان: <q>﴿جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</q> يقول: جعل بعضكم مِن بعض أزواجًا -يعني: الحلائل- لتسكنوا إليهن، <q>﴿ومِنَ الأَنْعامِ أزْواجًا﴾</q> يعني: ذكورًا وإناثًا{2}٥٧٨٩. (ز) ٥٧٨٩ ذكر ابن عطية (٧/٥٠٣) اختلافًا في المراد بالأزواج في الآية، ورجّح مستندًا إلى ظاهر الآية أنّ المراد بالأزواج: الإناث، فقال: «وقوله تعالى: <q>﴿جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</q> يريد: زوج الإنسان الأنثى، وبهذه النعمة اتفق الذرء، وليست الأزواج هاهنا الأنواع، وأما الأزواج المذكورة مع الأنعام فالظاهر أيضًا والمتسق أنه يريد: إناث الذكران، ويحتمل أن يريد: الأنواع، والأول أظهر». <q>﴿یَذۡرَؤُكُمۡ فِیهِۚ﴾</q> - تفسير ٦٨٨٤٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا ومِنَ الأَنْعامِ أزْواجًا يَذْرَؤُكُمْ فِيهِ﴾</q>، يقول: يجعل لكم فيه معيشةً تعيشون بها{4}. (ز) ٦٨٨٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿يَذْرَؤُكُمْ فِيهِ﴾</q>، قال: نسلًا مِن بعد نسل مِن الناس والأنعام{5}. (١٣/١٣٤) ٦٨٨٤٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يَذْرَؤُكُمْ فِيهِ﴾</q>، قال: عيشٌ من الله يُعِيشكم فيه{6}. (١٣/١٣٣) ٦٨٨٤٩- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿يَذْرَؤُكُمْ فِيهِ﴾</q>، قال: يخلقكم{4}. (١٣/١٣٤) ٦٨٨٥٠- عن منصور [بن المعتمر] -من طريق شعبة- قوله: <q>﴿يَذْرَؤُكُمْ فِيهِ﴾</q>، قال: يخلقكم{4}. (ز) ٦٨٨٥١- قال مقاتل بن سليمان: <q>﴿يَذْرَؤُكُمْ فِيهِ﴾</q>، يقول: يُعيشكم فيه فيما جعل مِن الذكور والإناث مِن الأنعام{2}٥٧٩٠. (ز) ٥٧٩٠ في قوله: <q>﴿يذرؤكم فيه﴾</q> قولان: الأول: يخلقكم فيه. الثاني: يعيشكم فيه. وقد ذكرهما ابن جرير (٢٠/٤٧٦)، ثم علّق بقوله: «وهذان القولان وإن اختلفا في اللفظ مِن قائليهما فقد يحتمل توجيههما إلى معنًى واحد، وهو أن يكون القائل في معناه: يعيشكم فيه. أراد بقوله ذلك: يحييكم بعيشكم به كما يُحيي مَن لم يخلق بتكوينه إياه، ونفخه الروح فيه حتى يعيش حيًّا». <q>﴿لَیۡسَ كَمِثۡلِهِۦ شَیۡءࣱۖ وَهُوَ ٱلسَّمِیعُ ٱلۡبَصِیرُ ۝١١﴾</q> - تفسير ٦٨٨٥٢- قال مقاتل بن سليمان: ثم عظّم نفسه، فقال: <q>﴿لَيْسَ كَمِثْلِهِ شَيْءٌ﴾</q> في القُدرة، <q>﴿وهُوَ السَّمِيعُ﴾</q> لقول كفار مكة، <q>﴿البَصِيرُ﴾</q> بما خلق{2}. (ز) <q>﴿لَیۡسَ كَمِثۡلِهِۦ شَیۡءࣱۖ وَهُوَ ٱلسَّمِیعُ ٱلۡبَصِیرُ ۝١١﴾</q> - آثار متعلقة بالآية ٦٨٨٥٣- عن أبي وائل، قال: بينما عبد الله [بن مسعود] يمدح ربَّه؛ إذ قال مِعضَد: نِعْم المرء يذْكُر. فقال عبد الله: إني لَأُجِلُّه عن ذلك، <q>﴿لَيْسَ كَمِثْلِهِ شَيْءٌ﴾</q>{11}. (١٣/١٣٤) ",footnotes:1:أخرجه ابن جرير ٢٠/٤٧٤.تفسير مقاتل بن سليمان ٣/٧٦٥.تفسير مقاتل بن سليمان ٣/٧٦٥.أخرجه ابن جرير ٢٠/٤٧٥.تفسير مجاهد ص٥٨٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٤، والفتح ٨/٥٦٣-، وابن جرير ٢٠/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٧٨، وعبد الرزاق ٢/١٩٠ من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٧٥.أخرجه ابن جرير ٢٠/٤٧٥.تفسير مقاتل بن سليمان ٣/٧٦٥.تفسير مقاتل بن سليمان ٣/٧٦٥.أخرجه البيهقي في الأسماء والصفات (٦٣٤). وعزاه السيوطي إلى عبد بن حميد.
42,12," <q>﴿لَهُۥ مَقَالِیدُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُۚ إِنَّهُۥ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝١٢﴾</q> - تفسير ٦٨٨٥٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</q>، قال: مفاتيح، بالفارسية{1}. (ز) ٦٨٨٥٥- عن الحسن البصري= (ز) ٦٨٨٥٦- وقتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</q>، قالا: مفاتيح السماوات والأرض{2}. (ز) ٦٨٨٥٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</q>، قال: خزائن السماوات والأرض{3}. (ز) ٦٨٨٥٨- عن محمد بن السّائِب الكلبي: <q>﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</q> مفاتيح الرزق في السموات والأرض؛ المطر والنبات{4}. (ز) ٦٨٨٥٩- قال مقاتل بن سليمان: <q>﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</q> يعني: مفاتيح، بلغة النّبط. مقاليد السماوات: المطر. والأرض: يعني: النبات، <q>﴿يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ﴾</q> يقول: يُوَسِّع الرزق على مَن يشاء مِن عباده، ويُقتر على مَن يشاء، <q>﴿إنَّهُ بِكُلِّ شَيْءٍ﴾</q> مِن البْسط والقتْر <q>﴿عَلِيمٌ﴾</q>{5}. (ز) <q>﴿لَهُۥ مَقَالِیدُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُۚ إِنَّهُۥ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝١٢﴾</q> - آثار متعلقة بالآية ٦٨٨٦٠- عن عبد الله بن مسعود، قال: إنّ ربكم ليس عنده ليل ولا نهار، نورُ السموات مِن نور وجهه، وإنّ مقدار كلِّ يوم من أيامكم عنده ثنتا عشرة ساعة، فيُعرض عليه أعمالكم بالأمس أول النهار اليوم، فينظر فيها ثلاث ساعات، فيطَّلع منها على ما يكره فيُغضبه ذلك، وأول مَن يعلم بغضبه حَمَلة العرش، يجدونه يثقُل عليهم، فيسبِّحه حَمَلة العرش الذين يحملون العرش وسرادقات العرش، والملائكة المقرّبون، وسائر الملائكة، وينفخ جبريل في القرْن، فلا يبقى شيء إلا سمعه، إلا الثَّقلين الجن والإنس، فيسبّحونه ثلاث ساعات حتى يمتلئ الرحمن رحمة، فتلك ست ساعات، ثم يُؤتى بما في الأرحام فينظر فيها ثلاث ساعات، فـ<q>﴿يُصَوِّرُكُمْ فِي الأَرْحامِ كَيْفَ يَشاءُ لا إلَهَ إلّا هُوَ العَزِيزُ الحَكِيمُ﴾</q> [آل عمران:٦]، <q>﴿يَخْلُقُ ما يَشاءُ يَهَبُ لِمَن يَشاءُ إناثًا ويَهَبُ لِمَن يَشاءُ الذُّكُورَ﴾</q> حتى بلغ: <q>﴿عَلِيم﴾</q> [الشورى:٤٩-٥٠] فتلك تسع ساعات، ثم ينظر في أرزاق الخلق كله ثلاث ساعات فـ<q>﴿يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ إنَّهُ بِكُلِّ شَيْءٍ عَلِيمٌ﴾</q> فتلك اثنتا عشرة ساعة. ثم قال: <q>﴿كُلَّ يَوْمٍ هُوَ فِي شَأْنٍ﴾</q> [الرحمن:٢٩] فهذا من شأن ربكم كل يوم{6}. (١٣/١٣٤) ",footnotes:1:تفسير مجاهد ص٥٨٨، وأخرجه ابن جرير ٢٠/٤٧٨.أخرجه عبد الرزاق ٢/١٩٠، وابن جرير ٢٠/٤٧٨. وذكره يحيى بن سلام -كما في تفسير ابن أبى زمنين ٤/١٦٣- عن قتادة.أخرجه ابن جرير ٢٠/٤٧٩.تفسير البغوي ٧/١٨٦.تفسير مقاتل بن سليمان ٣/٧٦٥.أخرجه الطبراني (٨٨٨٦)، وأبو الشيخ في العظمة (١١٣، ١٤٩)، وأبو نعيم في الحلية ١/١٣٧-١٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.
42,13," <q>﴿شَرَعَ لَكُم مِّنَ ٱلدِّینِ مَا وَصَّىٰ بِهِۦ نُوحࣰا وَٱلَّذِیۤ أَوۡحَیۡنَاۤ إِلَیۡكَ وَمَا وَصَّیۡنَا بِهِۦۤ إِبۡرَ ٰ⁠هِیمَ وَمُوسَىٰ وَعِیسَىٰۤۖ﴾</q> - تفسير ٦٨٨٦١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</q> إلى آخر الآية، قال: حسبُك ما قيل لك{1}. (ز) ٦٨٨٦٢- عن عبد الله بن عباس -من طريق علي- <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</q>: لم يبعث الله تعالى نبيًّا إلّا أوصاه بإقامة الصلاة، وإيتاء الزكاة، والإقرار لله بالطاعة{2}. (ز) ٦٨٨٦٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</q>، قال: وصّاك -يا محمد- وأنبياءَه كلهم دينًا واحدًا{3}. (١٣/١٣٥) ٦٨٨٦٤- قال الحسن البصري: <q>﴿شَرَعَ لَكُمْ﴾</q>، أي: فرض{4}. (ز) ٦٨٨٦٥- عن الحكم، في قوله: <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</q>، قال: جاء نوح بالشريعة؛ بتحريم الأمهات، والأخوات، والبنات{5}. (١٣/١٣٦) ٦٨٨٦٦- عن محمّد بن كعب القُرظي-من طريق أبي معشر- قال: ما خالف نبيٌّ نبيًّا قطّ في قِبلةٍ ولا في سُنَّة، إلا أنّ رسول الله ﷺ استقبل بيت المقدس مِن حيث قدم المدينة ستة عشر شهرًا. ثم قرأ: <q>﴿شرع لكم من الدين ما وصى به نوحًا﴾</q>{6}. (ز) ٦٨٨٦٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</q>، قال: الحلال والحرام{7}٥٧٩١. (١٣/١٣٦) ٥٧٩١ ذكر ابنُ عطية (٧/٥٠٥) أن اتفاق النبوات: «كان في المعتقدات، أو في جملة أمرها، مِن أن كل نبوة فإنما مضمنها معتقدات وأحكام، فيجيء المعنى على هذا: شرع لكم شرعة هي كشرعة نوح وإبراهيم وموسى وعيسى ﵈ في أنها ذات المعتقدات المشهورة التي هي في كل نبوءة وذات أحكام كما كانت تلك كلها». ثم بيّن أن قول قتادة يتخرّج على هذا المعنى، وكذا قول الحكم، ثم قال: «وأما الأحكام بانفرادها فهي في الشرائع مختلفة، وهي المراد في قوله تعالى: <q>﴿لِكُلٍّ جَعَلْنا مِنكُمْ شِرْعَةً ومِنهاجًا﴾</q> [المائدة:٤٨]». ٦٨٨٦٨- عن قتادة بن دعامة -من طريق سعيد-: بُعِث نوحٌ حين بُعِث بالشريعة بتحليل الحلال، وتحريم الحرام، <q>﴿وما وصَّيْنا بِهِ إبْراهِيمَ ومُوسى وعِيسى﴾</q>{8}. (١٣/١٣٦) ٦٨٨٦٩- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</q>، قال: هو الدِّين كله{9}. (ز) ٦٨٨٧٠- قال مقاتل بن سليمان: قوله: <q>﴿شَرَعَ لَكُمْ مِنَ الدِّينِ﴾</q> يقول: بيّن لكم، ويُقال: سنّ لكم آثار الإسلام، والـ<q>﴿من﴾</q> ها هنا صلة <q>﴿ما وصّى بِهِ نُوحًا والَّذِي أوْحَيْنا إلَيْكَ﴾</q> فيه تقديم، <q>﴿وما وصَّيْنا بِهِ إبْراهِيمَ ومُوسى وعِيسى﴾</q>{10}. (ز) <q>﴿شَرَعَ لَكُم مِّنَ ٱلدِّینِ مَا وَصَّىٰ بِهِۦ نُوحࣰا وَٱلَّذِیۤ أَوۡحَیۡنَاۤ إِلَیۡكَ وَمَا وَصَّیۡنَا بِهِۦۤ إِبۡرَ ٰ⁠هِیمَ وَمُوسَىٰ وَعِیسَىٰۤۖ﴾</q> - آثار متعلقة بالآية ٦٨٨٧١- عن زيد بن رفيع فقيه أهل الجزيرة، قال: بعث اللهُ نوحًا، وشرع له الدِّين، فكان الناس في شريعة نوح ما كانوا، فما أطفأها إلا الزَّندقة، ثم بعث الله إبراهيم، فكان الناس في شريعة مِن بعد إبراهيم ما كانوا، فما أطفأها إلا الزَّندقة، ثم بعث الله موسى وشرع له الدِّين، فكان الناس في شريعة مِن بعد موسى ما كانوا، فما أطفأها إلا الزَّندقة، ثم بعث الله عيسى وشرع له الدِّين، فكان الناس في شريعة عيسى ما كانوا، فما أطفأها إلا الزَّندقة. قال: ولا يُخافُ على هلاك هذا الدِّين إلا الزَّندقة{11}. (١٣/١٣٦) <q>﴿أَنۡ أَقِیمُوا۟ ٱلدِّینَ وَلَا تَتَفَرَّقُوا۟ فِیهِۚ﴾</q> - تفسير ٦٨٨٧٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أنْ أقِيمُوا الدِّينَ ولا تَتَفَرَّقُوا فِيهِ﴾</q>، قال: تعلّموا أنّ الفُرْقة هَلَكة، وأن الجماعة ثقة{12}. (١٣/١٣٧) ٦٨٨٧٣- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿أنْ أقِيمُوا الدِّينَ﴾</q>، قال: اعملوا به{1}. (١٣/١٣٧) ٦٨٨٧٤- قال مقاتل بن سليمان: <q>﴿أنْ أقِيمُوا الدِّينَ﴾</q> يعني: التوحيد، <q>﴿ولا تَتَفَرَّقُوا فِيهِ﴾</q>{10}. (ز) <q>﴿كَبُرَ عَلَى ٱلۡمُشۡرِكِینَ مَا تَدۡعُوهُمۡ إِلَیۡهِۚ﴾</q> - تفسير ٦٨٨٧٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿كَبُرَ عَلى المُشْرِكِينَ ما تَدْعُوهُمْ إلَيْهِ﴾</q>، قال: استكبر المشركون أن قيل لهم: لا إله إلا الله، فصادمها إبليس وجنوده ليردّوها، فأبى اللهُ إلا أن يُمضيها وينصرها ويُظهرها على ما ناوأها، وهي كلمة مَن خاصم بها فلج، ومَن انتصر بها نُصر{12}. (١٣/١٣٧) ٦٨٨٧٦- قال مقاتل بن سليمان: <q>﴿كَبُرَ عَلى المُشْرِكِينَ﴾</q> يقول: عظُم على مشركي مكة <q>﴿ما تَدْعُوهُمْ إلَيْهِ﴾</q> يا محمد، لقولهم: <q>﴿أجَعَلَ الآلِهَةَ إلهًا واحِدًا إنَّ هذا لَشَيْءٌ عُجابٌ﴾</q> [ص:٥] يعني: التوحيد{16}. (ز) <q>﴿ٱللَّهُ یَجۡتَبِیۤ إِلَیۡهِ مَن یَشَاۤءُ وَیَهۡدِیۤ إِلَیۡهِ مَن یُنِیبُ ۝١٣﴾</q> - تفسير ٦٨٨٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿اللَّهُ يَجْتَبِي إلَيْهِ مَن يَشاءُ﴾</q>، قال: يُخْلِصُ لنفسه مَن يشاء{17}. (١٣/١٣٧) ٦٨٨٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿اللَّهُ يَجْتَبِي إلَيْهِ مَن يَشاءُ ويَهْدِي إلَيْهِ مَن يُنِيبُ﴾</q>، يقول: ويُوَفِّق للعمل بطاعته، واتِّباع ما بَعث به نبيَّه -عليه الصلاة والسلام- مِن الحقِّ مَن أقبل إلى طاعته، وراجع التوبة مِن معاصيه{18}. (ز) ٦٨٨٧٩- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿ويَهْدِي إلَيْهِ مَن يُنِيبُ﴾</q>، قال: مَن يُقبل إلى طاعة الله{19}. (١٣/١٣٧) ٦٨٨٨٠- قال مقاتل بن سليمان: ثم اختصّ أولياءه، فقال: <q>﴿اللَّهُ يَجْتَبِي إلَيْهِ﴾</q> يقول: يستخلص لدينه <q>﴿مَن يَشاءُ﴾</q> <q>﴿و﴾</q>هو <q>﴿يَهْدِي إلَيْهِ﴾</q> إلى دينه <q>﴿مَن يُنِيبُ﴾</q> يعني: مَن يراجع التوبة{16}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٤٨١.تفسير الثعلبي ٨/٣٠٦.تفسير مجاهد ص٥٨٨، وأخرجه ابن جرير ٢٠/٤٨٠ بلفظ: بنحوه. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٦٣-.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن سعد في الطبقات ١/٢٠٩.أخرجه عبد الرزاق ٢/١٩٠، وابن جرير ٢٠/٤٨١ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٨٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٨٠.تفسير مقاتل بن سليمان ٣/٧٦٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٤٨٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٨١.تفسير مقاتل بن سليمان ٣/٧٦٥.أخرجه ابن جرير ٢٠/٤٨٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٦٦.تفسير مجاهد ص٥٨٨، وأخرجه ابن جرير ٦/٢٦٥ في تفسير قوله: <q>﴿ولَكِنَّ اللَّهَ يَجْتَبِي مِن رُسُلِهِ مَن يَشاءُ﴾</q> [آل عمران:١٧٩] قال: يخلصهم لنفسه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٨٢.أخرجه ابن جرير٢٠/٤٨٣-٤٨٤.تفسير مقاتل بن سليمان ٣/٧٦٦.
42,14," <q>﴿وَمَا تَفَرَّقُوۤا۟ إِلَّا مِنۢ بَعۡدِ مَا جَاۤءَهُمُ ٱلۡعِلۡمُ بَغۡیَۢا بَیۡنَهُمۡۚ﴾</q> - تفسير ٦٨٨٨١- قال عبد الله بن عباس: يعني: أهل الكتاب{1}. (ز) ٦٨٨٨٢- عن كعب الأحبار، <q>﴿وما تَفَرَّقُوا إلّا مِن بَعْدِ ما جاءَهُمُ العِلْمُ بَغْيًا بَيْنَهُمْ﴾</q>، قال: في الدنيا{2}. (١٣/١٣٨) ٦٨٨٨٣- عن سعيد بن جُبير، <q>﴿بَغْيًا بَيْنَهُمْ﴾</q>، قال: كثرتْ أموالهم، فبغى بعضهم على بعض{3}. (١٣/١٣٧) ٦٨٨٨٤- قال عطاء: <q>﴿بَغْيًا بَيْنَهُمْ﴾</q>، يعني: بغيًا بينهم على محمد ﷺ{4}. (ز) ٦٨٨٨٥- عن قتادة بن دعامة -من طريق معمر- أنّه تلا: <q>﴿وما تَفَرَّقُوا إلّا مِن بَعْدِ ما جاءَهُمُ العِلْمُ﴾</q>، فقال: إيّاكم والفُرْقةَ؛ فإنها هَلَكة{5}. (ز) ٦٨٨٨٦- قال مقاتل بن سليمان: ثم قال: <q>﴿وما تَفَرَّقُوا إلّا مِن بَعْدِ ما جاءَهُمُ العِلْمُ﴾</q> يعني: البيان <q>﴿بَغْيًا بَيْنَهُمْ﴾</q>{6}. (ز) <q>﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى لَّقُضِیَ بَیۡنَهُمۡۚ﴾</q> - تفسير ٦٨٨٨٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ إلى أجَلٍ مُسَمًّى﴾</q>، قال: يوم القيامة{7}. (ز) ٦٨٨٨٨- قال مقاتل بن سليمان: <q>﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</q> ولولا كلمة الفصل التي سبقت من ربك في الآخرة -يا محمد- في تأخير العذاب عنهم <q>﴿إلى أجَلٍ مُسَمًّى﴾</q> يعني به: القيامة؛ <q>﴿لَقُضِيَ بَيْنَهُمْ﴾</q> بين مَن آمن وبين مَن كفر، ولولا ذلك لَنَزل بهم العذاب في الدنيا حين كذّبوا واختلفوا{6}. (ز) <q>﴿وَإِنَّ ٱلَّذِینَ أُورِثُوا۟ ٱلۡكِتَـٰبَ مِنۢ بَعۡدِهِمۡ لَفِی شَكࣲّ مِّنۡهُ مُرِیبࣲ ۝١٤﴾</q> - تفسير ٦٨٨٨٩- قال مجاهد بن جبر: <q>﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</q>، معناه: مِن قبلهم{9}. (ز) ٦٨٨٩٠- قال قتادة بن دعامة: <q>﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</q>، معناه: من قبلهم{10}. (ز) ٦٨٨٩١- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</q>، قال: اليهود والنصارى{7}. (١٣/١٣٧) ٦٨٨٩٢- قال مقاتل بن سليمان: ثم قال: <q>﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</q> قوم نوح وإبراهيم وموسى وعيسى أُورثوا الكتاب مِن بعدهم: اليهود والنصارى، من بعد أنبيائهم <q>﴿لَفِي شَكٍّ مِنهُ﴾</q> يعني: من الكتاب الذي عندهم <q>﴿مُرِيبٍ﴾</q>{6}٥٧٩٢. (ز) ٥٧٩٢ على هذا القول فالإشارة إلى اليهود والنصارى، وهو ما ذكره ابنُ عطية (٧/٥٠٦)، وذكر قولًا آخر بأن الإشارة للعرب، ثم بيّن أن الضمير في قوله: <q>﴿لفي شك منه﴾</q> يحتمل عدة احتمالات، فقال: «والضمير في قوله: <q>﴿لَفِي شَكٍّ﴾</q> يحتمل أن يعود على الكِتاب، أو على محمد، أو على الأجل المسمى، أي: في شكٍّ مِن البعث على قول مَن رأى الإشارة إلى العرب». ",footnotes:1:تفسير الثعلبي ٨/٣٠٧، وتفسير البغوي ٧/١٨٧، وجاء عقبه: دليله ونظيره في سورة المنفكّين <q>﴿إلّا مِن بَعْدِ ما جاءَتْهُمُ البَيِّنَةُ﴾</q> [البينة:٤].عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٧/١٨٧.أخرجه عبد الرزاق ٢/١٩٠، وابن جرير ٢٠/٤٨٣.تفسير مقاتل بن سليمان ٣/٧٦٦.أخرجه ابن جرير ٢٠/٤٨٤.تفسير مقاتل بن سليمان ٣/٧٦٦.تفسير الثعلبي ٨/٣٠٧، وعقَّب عليه بقوله: أي: من قبل مشركي مكة، وهم اليهود والنصارى.تفسير البغوي ٧/١٨٧، وعقَّب عليه بقوله: أي: من قبل مشركي مكة.أخرجه ابن جرير ٢٠/٤٨٤.تفسير مقاتل بن سليمان ٣/٧٦٦.
42,15," <q>﴿فَلِذَ ٰ⁠لِكَ فَٱدۡعُۖ وَٱسۡتَقِمۡ كَمَاۤ أُمِرۡتَۖ وَلَا تَتَّبِعۡ أَهۡوَاۤءَهُمۡۖ﴾</q> - تفسير ٦٨٨٩٣- قال مقاتل بن سليمان: قوله: <q>﴿فَلِذلِكَ فادْعُ﴾</q> يعني: إلى التوحيد، يقول الله لنبيّه ﷺ: ادعُ أهل الكتاب إلى معرفة ربك؛ إلى هذا التوحيد، <q>﴿واسْتَقِمْ﴾</q> يقول: وامضِ <q>﴿كَما أُمِرْتَ﴾</q> بالتوحيد. كقوله في الزمر [٢]: <q>﴿فاعْبُدِ اللَّهَ﴾</q>. <q>﴿ولا تَتَّبِعْ أهْواءَهُمْ﴾</q> في ترْك الدعاء، وذلك حين دعاه أهلُ الكتاب إلى دينهم{1}٥٧٩٣. (ز) ٥٧٩٣ ذكر ابنُ جرير (٢٠/٤٨٥) في المشار إليه بـ<q>﴿ذلك﴾</q> قولين: الأول: أنه التوحيد. كما في قول مقاتل. الثاني: أنه القرآن. ورجّح -مستندًا إلى السياق- القول الأول، وعلَّل ذلك بقوله: «لأنه في سياق خبر الله -جل ثناؤه- عمّا شرع لكم من الدين لنبيه محمد ﷺ بإقامته، ولم يأت من الكلام ما يدلُّ على انصرافه عنه إلى غيره». وبيّن أن القول الثاني قريب المعنى مما رجحه. <q>﴿وَقُلۡ ءَامَنتُ بِمَاۤ أَنزَلَ ٱللَّهُ مِن كِتَـٰبࣲۖ وَأُمِرۡتُ لِأَعۡدِلَ بَیۡنَكُمُۖ﴾</q> - تفسير ٦٨٨٩٤- قال عبد الله بن عباس: <q>﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</q> أُمِرْتُ أن لا أحيفَ عليكم بأكثرَ مِمّا افترضَ اللهُ عليكم من الأحكام{2}. (ز) ٦٨٨٩٥- قال عبد الله بن عباس: <q>﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</q> لِأُسَوِّي بينكم في الدِّين، وأؤمن بكل كتاب وكل رسول{3}. (ز) ٦٨٨٩٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</q>، قال: أُمر نبي الله ﷺ أن يعدل، فعدل حتى مات، والعدلُ ميزان الله في الأرض، به يأخذ المظلوم من الظالم، والضعيف من الشديد، وبالعدل يُصدِّق الله الصادق، ويُكذّب الكاذب، وبالعدل يردّ المعتدي ويوبّخه{4}. (١٣/١٣٨) ٦٨٨٩٧- قال مقاتل بن سليمان: ثم قال: <q>﴿وقُلْ﴾</q> لأهل الكتاب: <q>﴿آمَنتُ﴾</q> يقول: صدّقتُ <q>﴿بِما أنْزَلَ اللَّهُ مِن كِتابٍ﴾</q> يعني: القرآن، والتوراة، والإنجيل، والزبور، <q>﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</q> بين أهل الكتاب في القول. يقول: أعدل بما آتاني الله في كتابه. والعدل: أنّه دعاهم إلى دينه{1}٥٧٩٤. (ز) ٥٧٩٤ قال ابنُ عطية (٧/٥٠٧): «قوله تعالى: <q>﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</q> قالت فرقة: اللام في <q>﴿لِأَعْدِلَ﴾</q> بمعنى: أن؛ لأن التقدير: بأن أعدل بينكم. وقالت فرقة: المعنى: وأمرت بما أمرت به من التبليغ والشرع لكي أعدل بينكم. فحذف من الكلام ما يدل الظاهر عليه». <q>﴿ٱللَّهُ رَبُّنَا وَرَبُّكُمۡۖ لَنَاۤ أَعۡمَـٰلُنَا وَلَكُمۡ أَعۡمَـٰلُكُمۡۖ لَا حُجَّةَ بَیۡنَنَا وَبَیۡنَكُمُۖ ٱللَّهُ یَجۡمَعُ بَیۡنَنَاۖ وَإِلَیۡهِ ٱلۡمَصِیرُ ۝١٥﴾</q> - تفسير ٦٨٨٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</q>، قال: لا خصومة بيننا وبينكم{6}. (١٣/١٣٨) ٦٨٨٩٩- قال مقاتل بن سليمان: قوله: <q>﴿اللَّهُ رَبُّنا ورَبُّكُمْ لَنا أعْمالُنا ولَكُمْ أعْمالُكُمْ﴾</q> يقول: لنا ديننا الذي نحن عليه، ولكم دينكم الذي أنتم عليه، <q>﴿لا حُجَّةَ﴾</q> يقول: لا خصومة <q>﴿بَيْنَنا وبَيْنَكُمُ﴾</q> في الدِّين، يعني: أهل الكتاب، <q>﴿اللَّهُ يَجْمَعُ بَيْنَنا﴾</q> في الآخرة، فيجازينا بأعمالنا ويجازيكم، <q>﴿وإلَيْهِ المَصِيرُ﴾</q>{1}. (ز) ٦٨٩٠٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</q> قال: نهاه الله أن يجادل، <q>﴿لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</q> لا خصومة بيننا وبينكم. وقرأ: <q>﴿ولا تُجادِلُوا أهْلَ الكِتابِ إلّا بِالَّتِي هِيَ أحْسَنُ﴾</q> إلى آخر الآية [العنكبوت:٤٦]{8}. (ز) <q>﴿ٱللَّهُ رَبُّنَا وَرَبُّكُمۡۖ لَنَاۤ أَعۡمَـٰلُنَا وَلَكُمۡ أَعۡمَـٰلُكُمۡۖ لَا حُجَّةَ بَیۡنَنَا وَبَیۡنَكُمُۖ ٱللَّهُ یَجۡمَعُ بَیۡنَنَاۖ وَإِلَیۡهِ ٱلۡمَصِیرُ ۝١٥﴾</q> - النسخ في الآية ٦٨٩٠١- قال مقاتل بن سليمان، في قوله: <q>﴿اللَّهُ رَبُّنا ورَبُّكُمْ لَنا أعْمالُنا ولَكُمْ أعْمالُكُمْ لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</q>: نَسخَتْها آيةُ القتال في براءة{9}٥٧٩٥. (ز) ٥٧٩٥ ذكر ابنُ كثير (١٢/٢٦٣) نحو هذا عن السُّدّي، وقوّاه مستندًا إلى زمن النُّزول، فقال: «قال السُّدّي: وذلك قبل نزول آية السيف. وهذا مُتَّجِه؛ لأن هذه الآية مكية، وآية السيف بعد الهجرة». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٦٦.تفسير البغوي ٧/١٨٨.تفسير الثعلبي ٨/٣٠٧.أخرجه ابن جرير ٢٠/٤٨٦. وعزاه السيوطي إلى عبد بن حميد. وتتمته عند ابن جرير: ذُكر لنا: أنّ نبي الله داود ﵇ كان يقول: ثلاث مَن كنّ فيه أعجبني جدًّا؛ القصد في الفاقة والغنى، والعدل في الرضا والغضب، والخشية في السر والعلانية. وثلاث مَن كنّ فيه أهَلَكْنَهُ: شحٌّ مُطاع، وهوًى متبع، وإعجاب المرء بنفسه. وأربع من أُعطيهن فقد أُعطي خير الدنيا والآخرة: لسان ذاكر، وقلب شاكر، وبدن صابر، وزوجة مؤمنة. وينظر: تفسير الثعلبي ٨/٣٠٧.تفسير مقاتل بن سليمان ٣/٧٦٦.تفسير مجاهد ص٥٨٩، وأخرجه الفريابي -كما في التغليق ٤/٣٠٤، والفتح ٨/٥٦٣-، وابن جرير ٢٠/٤٨٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٦٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٦٦.أخرجه ابن جرير ٢٠/٤٨٧.تفسير مقاتل بن سليمان ٣/٧٦٧.
