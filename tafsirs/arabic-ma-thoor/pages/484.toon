quran[5]{c,v,t}:
  42,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَاطِرُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فاطِرُ السَّماواتِ والأَرْضِ﴾</span>، قال: خالق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فاطِرُ السَّماواتِ والأَرْضِ﴾</span>، يعني: خالق السموات والأرض{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَعَلَ لَكُم مِّنۡ أَنفُسِكُمۡ أَزۡوَ ٰ⁠جࣰا وَمِنَ ٱلۡأَنۡعَـٰمِ أَزۡوَ ٰ⁠جࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</span> يقول: جعل بعضكم مِن بعض أزواجًا -يعني: الحلائل- لتسكنوا إليهن، <span class="qpc-hafs">﴿ومِنَ الأَنْعامِ أزْواجًا﴾</span> يعني: ذكورًا وإناثًا{2}<span class=comment-ref>٥٧٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٨٩</span> ذكر <u>ابن عطية</u> (٧/٥٠٣) اختلافًا في المراد بالأزواج في الآية، و<span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى ظاهر الآية</span> أنّ المراد بالأزواج: الإناث، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</span> يريد: زوج الإنسان الأنثى، وبهذه النعمة اتفق الذرء، وليست الأزواج هاهنا الأنواع، وأما الأزواج المذكورة مع الأنعام فالظاهر أيضًا والمتسق أنه يريد: إناث الذكران، ويحتمل أن يريد: الأنواع، والأول أظهر».</div></p><p><h3><span class="qpc-hafs">﴿یَذۡرَؤُكُمۡ فِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا ومِنَ الأَنْعامِ أزْواجًا يَذْرَؤُكُمْ فِيهِ﴾</span>، يقول: يجعل لكم فيه معيشةً تعيشون بها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يَذْرَؤُكُمْ فِيهِ﴾</span>، قال: نسلًا مِن بعد نسل مِن الناس والأنعام{5}. (١٣/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يَذْرَؤُكُمْ فِيهِ﴾</span>، قال: عيشٌ من الله يُعِيشكم فيه{6}. (١٣/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿يَذْرَؤُكُمْ فِيهِ﴾</span>، قال: يخلقكم{4}. (١٣/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥٠<span class="dash">-</span></span> عن <span class="name-2">منصور [بن المعتمر]</span> -من طريق شعبة- قوله: <span class="qpc-hafs">﴿يَذْرَؤُكُمْ فِيهِ﴾</span>، قال: يخلقكم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَذْرَؤُكُمْ فِيهِ﴾</span>، يقول: يُعيشكم فيه فيما جعل مِن الذكور والإناث مِن الأنعام{2}<span class=comment-ref>٥٧٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٩٠</span> في قوله: <span class="qpc-hafs">﴿يذرؤكم فيه﴾</span> قولان: <b>الأول</b>: يخلقكم فيه. <b>الثاني</b>: يعيشكم فيه. وقد ذكرهما <u>ابن جرير</u> (٢٠/٤٧٦)، ثم <span class="comment-type-4">علّق</span> بقوله: «وهذان القولان وإن اختلفا في اللفظ مِن قائليهما فقد يحتمل توجيههما إلى معنًى واحد، وهو أن يكون القائل في معناه: يعيشكم فيه. أراد بقوله ذلك: يحييكم بعيشكم به كما يُحيي مَن لم يخلق بتكوينه إياه، ونفخه الروح فيه حتى يعيش حيًّا».</div></p><p><h3><span class="qpc-hafs">﴿لَیۡسَ كَمِثۡلِهِۦ شَیۡءࣱۖ وَهُوَ ٱلسَّمِیعُ ٱلۡبَصِیرُ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عظّم نفسه، فقال: <span class="qpc-hafs">﴿لَيْسَ كَمِثْلِهِ شَيْءٌ﴾</span> في القُدرة، <span class="qpc-hafs">﴿وهُوَ السَّمِيعُ﴾</span> لقول كفار مكة، <span class="qpc-hafs">﴿البَصِيرُ﴾</span> بما خلق{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَیۡسَ كَمِثۡلِهِۦ شَیۡءࣱۖ وَهُوَ ٱلسَّمِیعُ ٱلۡبَصِیرُ ۝١١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٥٣<span class="dash">-</span></span> عن أبي وائل، قال: بينما <span class="name-1">عبد الله [بن مسعود]</span> يمدح ربَّه؛ إذ قال مِعضَد: نِعْم المرء يذْكُر. فقال عبد الله: إني لَأُجِلُّه عن ذلك، <span class="qpc-hafs">﴿لَيْسَ كَمِثْلِهِ شَيْءٌ﴾</span>{11}. (١٣/١٣٤)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٤٧٤.|2:تفسير مقاتل بن سليمان ٣/٧٦٥.|3:تفسير مقاتل بن سليمان ٣/٧٦٥.|4:أخرجه ابن جرير ٢٠/٤٧٥.|5:تفسير مجاهد ص٥٨٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٤، والفتح ٨/٥٦٣-، وابن جرير ٢٠/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه ابن جرير ٢٠/٤٧٨، وعبد الرزاق ٢/١٩٠ من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٠/٤٧٥.|8:أخرجه ابن جرير ٢٠/٤٧٥.|9:تفسير مقاتل بن سليمان ٣/٧٦٥.|10:تفسير مقاتل بن سليمان ٣/٧٦٥.|11:أخرجه البيهقي في الأسماء والصفات (٦٣٤). وعزاه السيوطي إلى عبد بن حميد.
  42,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَهُۥ مَقَالِیدُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُۚ إِنَّهُۥ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</span>، قال: مفاتيح، بالفارسية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥٦<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</span>، قالا: مفاتيح السماوات والأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</span>، قال: خزائن السماوات والأرض{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</span> مفاتيح الرزق في السموات والأرض؛ المطر والنبات{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَهُ مَقالِيدُ السَّماواتِ والأَرْضِ﴾</span> يعني: مفاتيح، بلغة النّبط. مقاليد السماوات: المطر. والأرض: يعني: النبات، <span class="qpc-hafs">﴿يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ﴾</span> يقول: يُوَسِّع الرزق على مَن يشاء مِن عباده، ويُقتر على مَن يشاء، <span class="qpc-hafs">﴿إنَّهُ بِكُلِّ شَيْءٍ﴾</span> مِن البْسط والقتْر <span class="qpc-hafs">﴿عَلِيمٌ﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَهُۥ مَقَالِیدُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُۚ إِنَّهُۥ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝١٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: إنّ ربكم ليس عنده ليل ولا نهار، نورُ السموات مِن نور وجهه، وإنّ مقدار كلِّ يوم من أيامكم عنده ثنتا عشرة ساعة، فيُعرض عليه أعمالكم بالأمس أول النهار اليوم، فينظر فيها ثلاث ساعات، فيطَّلع منها على ما يكره فيُغضبه ذلك، وأول مَن يعلم بغضبه حَمَلة العرش، يجدونه يثقُل عليهم، فيسبِّحه حَمَلة العرش الذين يحملون العرش وسرادقات العرش، والملائكة المقرّبون، وسائر الملائكة، وينفخ جبريل في القرْن، فلا يبقى شيء إلا سمعه، إلا الثَّقلين الجن والإنس، فيسبّحونه ثلاث ساعات حتى يمتلئ الرحمن رحمة، فتلك ست ساعات، ثم يُؤتى بما في الأرحام فينظر فيها ثلاث ساعات، فـ<span class="qpc-hafs">﴿يُصَوِّرُكُمْ فِي الأَرْحامِ كَيْفَ يَشاءُ لا إلَهَ إلّا هُوَ العَزِيزُ الحَكِيمُ﴾</span> [آل عمران:٦]، <span class="qpc-hafs">﴿يَخْلُقُ ما يَشاءُ يَهَبُ لِمَن يَشاءُ إناثًا ويَهَبُ لِمَن يَشاءُ الذُّكُورَ﴾</span> حتى بلغ: <span class="qpc-hafs">﴿عَلِيم﴾</span> [الشورى:٤٩-٥٠] فتلك تسع ساعات، ثم ينظر في أرزاق الخلق كله ثلاث ساعات فـ<span class="qpc-hafs">﴿يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ إنَّهُ بِكُلِّ شَيْءٍ عَلِيمٌ﴾</span> فتلك اثنتا عشرة ساعة. ثم قال: <span class="qpc-hafs">﴿كُلَّ يَوْمٍ هُوَ فِي شَأْنٍ﴾</span> [الرحمن:٢٩] فهذا من شأن ربكم كل يوم{6}. (١٣/١٣٤)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٥٨٨، وأخرجه ابن جرير ٢٠/٤٧٨.|2:أخرجه عبد الرزاق ٢/١٩٠، وابن جرير ٢٠/٤٧٨. وذكره يحيى بن سلام -كما في تفسير ابن أبى زمنين ٤/١٦٣- عن قتادة.|3:أخرجه ابن جرير ٢٠/٤٧٩.|4:تفسير البغوي ٧/١٨٦.|5:تفسير مقاتل بن سليمان ٣/٧٦٥.|6:أخرجه الطبراني (٨٨٨٦)، وأبو الشيخ في العظمة (١١٣، ١٤٩)، وأبو نعيم في الحلية ١/١٣٧-١٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.
  42,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿شَرَعَ لَكُم مِّنَ ٱلدِّینِ مَا وَصَّىٰ بِهِۦ نُوحࣰا وَٱلَّذِیۤ أَوۡحَیۡنَاۤ إِلَیۡكَ وَمَا وَصَّیۡنَا بِهِۦۤ إِبۡرَ ٰ⁠هِیمَ وَمُوسَىٰ وَعِیسَىٰۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</span> إلى آخر الآية، قال: حسبُك ما قيل لك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</span>: لم يبعث الله تعالى نبيًّا إلّا أوصاه بإقامة الصلاة، وإيتاء الزكاة، والإقرار لله بالطاعة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</span>، قال: وصّاك -يا محمد- وأنبياءَه كلهم دينًا واحدًا{3}. (١٣/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿شَرَعَ لَكُمْ﴾</span>، أي: فرض{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٥<span class="dash">-</span></span> عن <span class="name-2">الحكم</span>، في قوله: <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</span>، قال: جاء نوح بالشريعة؛ بتحريم الأمهات، والأخوات، والبنات{5}. (١٣/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٦<span class="dash">-</span></span> عن <span class="name-2">محمّد بن كعب القُرظي</span>-من طريق أبي معشر- قال: ما خالف نبيٌّ نبيًّا قطّ في قِبلةٍ ولا في سُنَّة، إلا أنّ رسول الله ﷺ استقبل بيت المقدس مِن حيث قدم المدينة ستة عشر شهرًا. ثم قرأ: <span class="qpc-hafs">﴿شرع لكم من الدين ما وصى به نوحًا﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</span>، قال: الحلال والحرام{7}<span class=comment-ref>٥٧٩١</span>. (١٣/١٣٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٩١</span> ذكر <u>ابنُ عطية</u> (٧/٥٠٥) أن اتفاق النبوات: «كان في المعتقدات، أو في جملة أمرها، مِن أن كل نبوة فإنما مضمنها معتقدات وأحكام، فيجيء المعنى على هذا: شرع لكم شرعة هي كشرعة نوح وإبراهيم وموسى وعيسى ﵈ في أنها ذات المعتقدات المشهورة التي هي في كل نبوءة وذات أحكام كما كانت تلك كلها». ثم بيّن أن قول قتادة يتخرّج على هذا المعنى، وكذا قول الحكم، ثم قال: «وأما الأحكام بانفرادها فهي في الشرائع مختلفة، وهي المراد في قوله تعالى: <span class="qpc-hafs">﴿لِكُلٍّ جَعَلْنا مِنكُمْ شِرْعَةً ومِنهاجًا﴾</span> [المائدة:٤٨]».</div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: بُعِث نوحٌ حين بُعِث بالشريعة بتحليل الحلال، وتحريم الحرام، <span class="qpc-hafs">﴿وما وصَّيْنا بِهِ إبْراهِيمَ ومُوسى وعِيسى﴾</span>{8}. (١٣/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٦٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ ما وصّى بِهِ نُوحًا﴾</span>، قال: هو الدِّين كله{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿شَرَعَ لَكُمْ مِنَ الدِّينِ﴾</span> يقول: بيّن لكم، ويُقال: سنّ لكم آثار الإسلام، والـ<span class="qpc-hafs">﴿من﴾</span> ها هنا صلة <span class="qpc-hafs">﴿ما وصّى بِهِ نُوحًا والَّذِي أوْحَيْنا إلَيْكَ﴾</span> فيه تقديم، <span class="qpc-hafs">﴿وما وصَّيْنا بِهِ إبْراهِيمَ ومُوسى وعِيسى﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿شَرَعَ لَكُم مِّنَ ٱلدِّینِ مَا وَصَّىٰ بِهِۦ نُوحࣰا وَٱلَّذِیۤ أَوۡحَیۡنَاۤ إِلَیۡكَ وَمَا وَصَّیۡنَا بِهِۦۤ إِبۡرَ ٰ⁠هِیمَ وَمُوسَىٰ وَعِیسَىٰۤۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٧١<span class="dash">-</span></span> عن <span class="name-2">زيد بن رفيع</span> فقيه أهل الجزيرة، قال: بعث اللهُ نوحًا، وشرع له الدِّين، فكان الناس في شريعة نوح ما كانوا، فما أطفأها إلا الزَّندقة، ثم بعث الله إبراهيم، فكان الناس في شريعة مِن بعد إبراهيم ما كانوا، فما أطفأها إلا الزَّندقة، ثم بعث الله موسى وشرع له الدِّين، فكان الناس في شريعة مِن بعد موسى ما كانوا، فما أطفأها إلا الزَّندقة، ثم بعث الله عيسى وشرع له الدِّين، فكان الناس في شريعة عيسى ما كانوا، فما أطفأها إلا الزَّندقة. قال: ولا يُخافُ على هلاك هذا الدِّين إلا الزَّندقة{11}. (١٣/١٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنۡ أَقِیمُوا۟ ٱلدِّینَ وَلَا تَتَفَرَّقُوا۟ فِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أنْ أقِيمُوا الدِّينَ ولا تَتَفَرَّقُوا فِيهِ﴾</span>، قال: تعلّموا أنّ الفُرْقة هَلَكة، وأن الجماعة ثقة{12}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أنْ أقِيمُوا الدِّينَ﴾</span>، قال: اعملوا به{1}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنْ أقِيمُوا الدِّينَ﴾</span> يعني: التوحيد، <span class="qpc-hafs">﴿ولا تَتَفَرَّقُوا فِيهِ﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَبُرَ عَلَى ٱلۡمُشۡرِكِینَ مَا تَدۡعُوهُمۡ إِلَیۡهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كَبُرَ عَلى المُشْرِكِينَ ما تَدْعُوهُمْ إلَيْهِ﴾</span>، قال: استكبر المشركون أن قيل لهم: لا إله إلا الله، فصادمها إبليس وجنوده ليردّوها، فأبى اللهُ إلا أن يُمضيها وينصرها ويُظهرها على ما ناوأها، وهي كلمة مَن خاصم بها فلج، ومَن انتصر بها نُصر{12}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَبُرَ عَلى المُشْرِكِينَ﴾</span> يقول: عظُم على مشركي مكة <span class="qpc-hafs">﴿ما تَدْعُوهُمْ إلَيْهِ﴾</span> يا محمد، لقولهم: <span class="qpc-hafs">﴿أجَعَلَ الآلِهَةَ إلهًا واحِدًا إنَّ هذا لَشَيْءٌ عُجابٌ﴾</span> [ص:٥] يعني: التوحيد{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱللَّهُ یَجۡتَبِیۤ إِلَیۡهِ مَن یَشَاۤءُ وَیَهۡدِیۤ إِلَیۡهِ مَن یُنِیبُ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿اللَّهُ يَجْتَبِي إلَيْهِ مَن يَشاءُ﴾</span>، قال: يُخْلِصُ لنفسه مَن يشاء{17}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿اللَّهُ يَجْتَبِي إلَيْهِ مَن يَشاءُ ويَهْدِي إلَيْهِ مَن يُنِيبُ﴾</span>، يقول: ويُوَفِّق للعمل بطاعته، واتِّباع ما بَعث به نبيَّه -عليه الصلاة والسلام- مِن الحقِّ مَن أقبل إلى طاعته، وراجع التوبة مِن معاصيه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ويَهْدِي إلَيْهِ مَن يُنِيبُ﴾</span>، قال: مَن يُقبل إلى طاعة الله{19}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم اختصّ أولياءه، فقال: <span class="qpc-hafs">﴿اللَّهُ يَجْتَبِي إلَيْهِ﴾</span> يقول: يستخلص لدينه <span class="qpc-hafs">﴿مَن يَشاءُ﴾</span> <span class="qpc-hafs">﴿و﴾</span>هو <span class="qpc-hafs">﴿يَهْدِي إلَيْهِ﴾</span> إلى دينه <span class="qpc-hafs">﴿مَن يُنِيبُ﴾</span> يعني: مَن يراجع التوبة{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٤٨١.|2:تفسير الثعلبي ٨/٣٠٦.|3:تفسير مجاهد ص٥٨٨، وأخرجه ابن جرير ٢٠/٤٨٠ بلفظ: بنحوه. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٦٣-.|5:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه ابن سعد في الطبقات ١/٢٠٩.|7:أخرجه عبد الرزاق ٢/١٩٠، وابن جرير ٢٠/٤٨١ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٠/٤٨٠. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن جرير ٢٠/٤٨٠.|10:تفسير مقاتل بن سليمان ٣/٧٦٥.|11:عزاه السيوطي إلى ابن المنذر.|12:أخرجه ابن جرير ٢٠/٤٨٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|13:أخرجه ابن جرير ٢٠/٤٨١.|14:تفسير مقاتل بن سليمان ٣/٧٦٥.|15:أخرجه ابن جرير ٢٠/٤٨٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|16:تفسير مقاتل بن سليمان ٣/٧٦٦.|17:تفسير مجاهد ص٥٨٨، وأخرجه ابن جرير ٦/٢٦٥ في تفسير قوله: <span class="qpc-hafs">﴿ولَكِنَّ اللَّهَ يَجْتَبِي مِن رُسُلِهِ مَن يَشاءُ﴾</span> [آل عمران:١٧٩] قال: يخلصهم لنفسه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|18:أخرجه ابن جرير ٢٠/٤٨٢.|19:أخرجه ابن جرير٢٠/٤٨٣-٤٨٤.|20:تفسير مقاتل بن سليمان ٣/٧٦٦.
  42,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا تَفَرَّقُوۤا۟ إِلَّا مِنۢ بَعۡدِ مَا جَاۤءَهُمُ ٱلۡعِلۡمُ بَغۡیَۢا بَیۡنَهُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٨١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: يعني: أهل الكتاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٢<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، <span class="qpc-hafs">﴿وما تَفَرَّقُوا إلّا مِن بَعْدِ ما جاءَهُمُ العِلْمُ بَغْيًا بَيْنَهُمْ﴾</span>، قال: في الدنيا{2}. (١٣/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span>، <span class="qpc-hafs">﴿بَغْيًا بَيْنَهُمْ﴾</span>، قال: كثرتْ أموالهم، فبغى بعضهم على بعض{3}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٤<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿بَغْيًا بَيْنَهُمْ﴾</span>، يعني: بغيًا بينهم على محمد ﷺ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- أنّه تلا: <span class="qpc-hafs">﴿وما تَفَرَّقُوا إلّا مِن بَعْدِ ما جاءَهُمُ العِلْمُ﴾</span>، فقال: إيّاكم والفُرْقةَ؛ فإنها هَلَكة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وما تَفَرَّقُوا إلّا مِن بَعْدِ ما جاءَهُمُ العِلْمُ﴾</span> يعني: البيان <span class="qpc-hafs">﴿بَغْيًا بَيْنَهُمْ﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى لَّقُضِیَ بَیۡنَهُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ إلى أجَلٍ مُسَمًّى﴾</span>، قال: يوم القيامة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</span> ولولا كلمة الفصل التي سبقت من ربك في الآخرة -يا محمد- في تأخير العذاب عنهم <span class="qpc-hafs">﴿إلى أجَلٍ مُسَمًّى﴾</span> يعني به: القيامة؛ <span class="qpc-hafs">﴿لَقُضِيَ بَيْنَهُمْ﴾</span> بين مَن آمن وبين مَن كفر، ولولا ذلك لَنَزل بهم العذاب في الدنيا حين كذّبوا واختلفوا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّ ٱلَّذِینَ أُورِثُوا۟ ٱلۡكِتَـٰبَ مِنۢ بَعۡدِهِمۡ لَفِی شَكࣲّ مِّنۡهُ مُرِیبࣲ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٨٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</span>، معناه: مِن قبلهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</span>، معناه: من قبلهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</span>، قال: اليهود والنصارى{7}. (١٣/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وإنَّ الَّذِينَ أُورِثُوا الكِتابَ مِن بَعْدِهِمْ﴾</span> قوم نوح وإبراهيم وموسى وعيسى أُورثوا الكتاب مِن بعدهم: اليهود والنصارى، من بعد أنبيائهم <span class="qpc-hafs">﴿لَفِي شَكٍّ مِنهُ﴾</span> يعني: من الكتاب الذي عندهم <span class="qpc-hafs">﴿مُرِيبٍ﴾</span>{6}<span class=comment-ref>٥٧٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٩٢</span> على هذا القول فالإشارة إلى اليهود والنصارى، وهو ما <span class="comment-type-4">ذكره</span> <u>ابنُ عطية</u> (٧/٥٠٦)، <span class="comment-type-4">وذكر</span> قولًا آخر بأن الإشارة للعرب، ثم <span class="comment-type-4">بيّن</span> أن الضمير في قوله: <span class="qpc-hafs">﴿لفي شك منه﴾</span> يحتمل عدة <b>احتمالات</b>، فقال: «والضمير في قوله: <span class="qpc-hafs">﴿لَفِي شَكٍّ﴾</span> <b>يحتمل</b> أن يعود على الكِتاب، أو على محمد، أو على الأجل المسمى، أي: في شكٍّ مِن البعث على قول مَن رأى الإشارة إلى العرب».</div></p></div>",footnotes:1:تفسير الثعلبي ٨/٣٠٧، وتفسير البغوي ٧/١٨٧، وجاء عقبه: دليله ونظيره في سورة المنفكّين <span class="qpc-hafs">﴿إلّا مِن بَعْدِ ما جاءَتْهُمُ البَيِّنَةُ﴾</span> [البينة:٤].|2:عزاه السيوطي إلى عبد بن حميد.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:تفسير البغوي ٧/١٨٧.|5:أخرجه عبد الرزاق ٢/١٩٠، وابن جرير ٢٠/٤٨٣.|6:تفسير مقاتل بن سليمان ٣/٧٦٦.|7:أخرجه ابن جرير ٢٠/٤٨٤.|8:تفسير مقاتل بن سليمان ٣/٧٦٦.|9:تفسير الثعلبي ٨/٣٠٧، وعقَّب عليه بقوله: أي: من قبل مشركي مكة، وهم اليهود والنصارى.|10:تفسير البغوي ٧/١٨٧، وعقَّب عليه بقوله: أي: من قبل مشركي مكة.|11:أخرجه ابن جرير ٢٠/٤٨٤.|12:تفسير مقاتل بن سليمان ٣/٧٦٦.
  42,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلِذَ ٰ⁠لِكَ فَٱدۡعُۖ وَٱسۡتَقِمۡ كَمَاۤ أُمِرۡتَۖ وَلَا تَتَّبِعۡ أَهۡوَاۤءَهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَلِذلِكَ فادْعُ﴾</span> يعني: إلى التوحيد، يقول الله لنبيّه ﷺ: ادعُ أهل الكتاب إلى معرفة ربك؛ إلى هذا التوحيد، <span class="qpc-hafs">﴿واسْتَقِمْ﴾</span> يقول: وامضِ <span class="qpc-hafs">﴿كَما أُمِرْتَ﴾</span> بالتوحيد. كقوله في الزمر [٢]: <span class="qpc-hafs">﴿فاعْبُدِ اللَّهَ﴾</span>. <span class="qpc-hafs">﴿ولا تَتَّبِعْ أهْواءَهُمْ﴾</span> في ترْك الدعاء، وذلك حين دعاه أهلُ الكتاب إلى دينهم{1}<span class=comment-ref>٥٧٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٩٣</span> ذكر <u>ابنُ جرير</u> (٢٠/٤٨٥) في المشار إليه بـ<span class="qpc-hafs">﴿ذلك﴾</span> قولين: <b>الأول</b>: أنه التوحيد. كما في قول مقاتل. <b>الثاني</b>: أنه القرآن.</p><p>و<span class="comment-type-3">رجّح</span> -<span class="mustanad">مستندًا إلى السياق</span>- القول الأول، وعلَّل ذلك بقوله: «لأنه في سياق خبر الله -جل ثناؤه- عمّا شرع لكم من الدين لنبيه محمد ﷺ بإقامته، ولم يأت من الكلام ما يدلُّ على انصرافه عنه إلى غيره». و<span class="comment-type-4">بيّن</span> أن القول الثاني قريب المعنى مما رجحه.</div></p><p><h3><span class="qpc-hafs">﴿وَقُلۡ ءَامَنتُ بِمَاۤ أَنزَلَ ٱللَّهُ مِن كِتَـٰبࣲۖ وَأُمِرۡتُ لِأَعۡدِلَ بَیۡنَكُمُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٩٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</span> أُمِرْتُ أن لا أحيفَ عليكم بأكثرَ مِمّا افترضَ اللهُ عليكم من الأحكام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</span> لِأُسَوِّي بينكم في الدِّين، وأؤمن بكل كتاب وكل رسول{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</span>، قال: أُمر نبي الله ﷺ أن يعدل، فعدل حتى مات، والعدلُ ميزان الله في الأرض، به يأخذ المظلوم من الظالم، والضعيف من الشديد، وبالعدل يُصدِّق الله الصادق، ويُكذّب الكاذب، وبالعدل يردّ المعتدي ويوبّخه{4}. (١٣/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وقُلْ﴾</span> لأهل الكتاب: <span class="qpc-hafs">﴿آمَنتُ﴾</span> يقول: صدّقتُ <span class="qpc-hafs">﴿بِما أنْزَلَ اللَّهُ مِن كِتابٍ﴾</span> يعني: القرآن، والتوراة، والإنجيل، والزبور، <span class="qpc-hafs">﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</span> بين أهل الكتاب في القول. يقول: أعدل بما آتاني الله في كتابه. والعدل: أنّه دعاهم إلى دينه{1}<span class=comment-ref>٥٧٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٩٤</span> قال <u>ابنُ عطية</u> (٧/٥٠٧): «قوله تعالى: <span class="qpc-hafs">﴿وأُمِرْتُ لِأَعْدِلَ بَيْنَكُمُ﴾</span> <b>قالت فرقة</b>: اللام في <span class="qpc-hafs">﴿لِأَعْدِلَ﴾</span> بمعنى: أن؛ لأن التقدير: بأن أعدل بينكم. <b>وقالت فرقة</b>: المعنى: وأمرت بما أمرت به من التبليغ والشرع لكي أعدل بينكم. فحذف من الكلام ما يدل الظاهر عليه».</div></p><p><h3><span class="qpc-hafs">﴿ٱللَّهُ رَبُّنَا وَرَبُّكُمۡۖ لَنَاۤ أَعۡمَـٰلُنَا وَلَكُمۡ أَعۡمَـٰلُكُمۡۖ لَا حُجَّةَ بَیۡنَنَا وَبَیۡنَكُمُۖ ٱللَّهُ یَجۡمَعُ بَیۡنَنَاۖ وَإِلَیۡهِ ٱلۡمَصِیرُ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٨٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</span>، قال: لا خصومة بيننا وبينكم{6}. (١٣/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٨٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿اللَّهُ رَبُّنا ورَبُّكُمْ لَنا أعْمالُنا ولَكُمْ أعْمالُكُمْ﴾</span> يقول: لنا ديننا الذي نحن عليه، ولكم دينكم الذي أنتم عليه، <span class="qpc-hafs">﴿لا حُجَّةَ﴾</span> يقول: لا خصومة <span class="qpc-hafs">﴿بَيْنَنا وبَيْنَكُمُ﴾</span> في الدِّين، يعني: أهل الكتاب، <span class="qpc-hafs">﴿اللَّهُ يَجْمَعُ بَيْنَنا﴾</span> في الآخرة، فيجازينا بأعمالنا ويجازيكم، <span class="qpc-hafs">﴿وإلَيْهِ المَصِيرُ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٩٠٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</span> قال: نهاه الله أن يجادل، <span class="qpc-hafs">﴿لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</span> لا خصومة بيننا وبينكم. وقرأ: <span class="qpc-hafs">﴿ولا تُجادِلُوا أهْلَ الكِتابِ إلّا بِالَّتِي هِيَ أحْسَنُ﴾</span> إلى آخر الآية [العنكبوت:٤٦]{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱللَّهُ رَبُّنَا وَرَبُّكُمۡۖ لَنَاۤ أَعۡمَـٰلُنَا وَلَكُمۡ أَعۡمَـٰلُكُمۡۖ لَا حُجَّةَ بَیۡنَنَا وَبَیۡنَكُمُۖ ٱللَّهُ یَجۡمَعُ بَیۡنَنَاۖ وَإِلَیۡهِ ٱلۡمَصِیرُ ۝١٥﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٩٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله: <span class="qpc-hafs">﴿اللَّهُ رَبُّنا ورَبُّكُمْ لَنا أعْمالُنا ولَكُمْ أعْمالُكُمْ لا حُجَّةَ بَيْنَنا وبَيْنَكُمُ﴾</span>: نَسخَتْها آيةُ القتال في براءة{9}<span class=comment-ref>٥٧٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٩٥</span> ذكر <u>ابنُ كثير</u> (١٢/٢٦٣) نحو هذا عن السُّدّي، و<span class="comment-type-3">قوّاه</span> <span class="mustanad">مستندًا إلى زمن النُّزول</span>، فقال: «قال السُّدّي: وذلك قبل نزول آية السيف. وهذا مُتَّجِه؛ لأن هذه الآية مكية، وآية السيف بعد الهجرة».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٦٦.|2:تفسير البغوي ٧/١٨٨.|3:تفسير الثعلبي ٨/٣٠٧.|4:أخرجه ابن جرير ٢٠/٤٨٦. وعزاه السيوطي إلى عبد بن حميد. وتتمته عند ابن جرير: ذُكر لنا: أنّ نبي الله داود ﵇ كان يقول: ثلاث مَن كنّ فيه أعجبني جدًّا؛ القصد في الفاقة والغنى، والعدل في الرضا والغضب، والخشية في السر والعلانية. وثلاث مَن كنّ فيه أهَلَكْنَهُ: شحٌّ مُطاع، وهوًى متبع، وإعجاب المرء بنفسه. وأربع من أُعطيهن فقد أُعطي خير الدنيا والآخرة: لسان ذاكر، وقلب شاكر، وبدن صابر، وزوجة مؤمنة. وينظر: تفسير الثعلبي ٨/٣٠٧.|5:تفسير مقاتل بن سليمان ٣/٧٦٦.|6:تفسير مجاهد ص٥٨٩، وأخرجه الفريابي -كما في التغليق ٤/٣٠٤، والفتح ٨/٥٦٣-، وابن جرير ٢٠/٤٨٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٦٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:تفسير مقاتل بن سليمان ٣/٧٦٦.|8:أخرجه ابن جرير ٢٠/٤٨٧.|9:تفسير مقاتل بن سليمان ٣/٧٦٧.