quran[15]{c,v,t}:
70,40," <q>﴿فَلَاۤ أُقۡسِمُ بِرَبِّ ٱلۡمَشَـٰرِقِ وَٱلۡمَغَـٰرِبِ إِنَّا لَقَـٰدِرُونَ ۝٤٠ عَلَىٰۤ أَن نُّبَدِّلَ خَیۡرࣰا مِّنۡهُمۡ وَمَا نَحۡنُ بِمَسۡبُوقِینَ ۝٤١﴾</q> - تفسير ٧٨٨٨٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾</q>، قال: للشمس كلّ يوم مَطلِع تَطلع فيه، ومَغرِب تغرب فيه، غير مَطلِعها بالأمس، وغير مَغرِبها بالأمس{1}. (١٤/٧٠٢) ٧٨٨٩٠- عن عبد الله بن عباس -من طريق عكرمة- قال: <q>﴿بِرَبِّ المَشارِقِ والمَغارِبِ﴾</q> إنّ الشمس تَطلع كلّ سنة في ثلاثمائة وستين كَوّة، تَطلع كلّ يوم في كَوّة؛ لا تَرجع إلى تلك الكَوّة إلى ذلك اليوم من العام المُقبل، ولا تَطلع إلا وهي كارهة، تقول: ربّ، لا تُطلعني على عبادك؛ فإني أراهم يَعصُونك، يَعملون بمعاصيك أراهم. قال: أولم تَسمعوا إلى قول أُميّة بن أبي الصّلت: حتى تُجرّ وتُجلَد؟ قلت: يا مولاه، وتُجلد الشمس؟ فقال: عضِضتَ بِهَنِ أبيك، إنما اضطره الرَّوِيُّ إلى الجَلْد{2}. (ز) ٧٨٨٩١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾</q>، قال: هو مَطلِع الشمس ومَغرِبها، ومَطلِع القمر ومَغرِبه{3}. (ز) ٧٨٨٩٢- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾</q>، قال: المنازل التي تجري فيها الشمس والقمر{4}. (١٤/٧٠٢) ٧٨٨٩٣- قال قتادة بن دعامة: <q>﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾</q> للشمس ثلاثمائة وستون مَشرقًا، وثلاثمائة وستون مغربًا{5}. (ز) ٧٨٨٩٤- قال مقاتل بن سليمان: <q>﴿فَلا أُقْسِمُ﴾</q> يقول: أُقسم <q>﴿بِرَبِّ المَشارِقِ والمَغارِبِ﴾</q> وهو مائة وثمانون مَشرقًا، ومائة وثمانون مَغربًا، في كلّ منزلة تَطلع يومين في السنة، تَطلع فيها الشمس وتَغرب فيها، فأَقسم الله تعالى بالمشارق والمغارب، فقال: <q>﴿إنّا لَقادِرُونَ عَلى أنْ نُبَدِّلَ خَيْرًا مِنهُمْ﴾</q> يعني: على أن نأتي بخلْقٍ أمثل منهم، وأطوع لله منهم، وأرضى منهم، <q>﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</q> يعني: وما نحن بُمعجزين إنْ أردنا ذلك{6}٦٨١٠. (ز) ٦٨١٠ ذكر ابنُ كثير (١٤/١٣٧) أنّ معنى قوله: <q>﴿أن نبدل خيرا منهم﴾</q>: أن نعيدهم بأبدان خير من هذه، فإنّ قدرته تعالى صالحة لذلك. ثم ساق هذا المعنى بأنه الإتيان بخلق أمثل وأطوع. ورجَّح -مستندًا إلى السياق- المعنى الأول، فقال: «والمعنى الأول أظهر؛ لدلالة الآيات الأُخَر عليه». ",footnotes:1:أخرجه ابن جرير ٢٣/٢٨٤ بنحوه. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٢٨٣.أخرجه ابن جرير ٢٣/٢٨٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٨-.تفسير مقاتل بن سليمان ٤/٤٣٩.
  70,41,""
70,42," <q>﴿فَذَرۡهُمۡ یَخُوضُوا۟ وَیَلۡعَبُوا۟ حَتَّىٰ یُلَـٰقُوا۟ یَوۡمَهُمُ ٱلَّذِی یُوعَدُونَ ۝٤٢﴾</q> - تفسير ٧٨٨٩٥- قال مقاتل بن سليمان: فقال الله ﷿: <q>﴿فَذَرْهُم﴾</q> خَلِّ عنهم يا محمد <q>﴿يَخُوضُوا﴾</q> في الباطل <q>﴿ويَلْعَبُوا﴾</q> يعني: ويلهوا في دنياهم؛ <q>﴿حَتّى يُلاقُوا يَوْمَهُمُ﴾</q> في الآخرة <q>﴿الَّذِي يُوعَدُونَ﴾</q> العذاب{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٩.
70,43," <q>﴿یَوۡمَ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ سِرَاعࣰا كَأَنَّهُمۡ إِلَىٰ نُصُبࣲ یُوفِضُونَ ۝٤٣﴾</q> - قراءات ٧٨٨٩٦- عن أبي العالية الرِّياحيّ أنه قرأ: ‹إلى نَصْبٍ يُوفِضُونَ› بنصب النون، على معنى الواحد{1}. (١٤/٧٠٣) ٧٨٨٩٧- عن عاصم أنه قرأ: ‹إلى نَصْبٍ يُوفِضُونَ› خفيفة، منصوبة النون، على معنى الوحدة{2}٦٨١١. (١٤/٧٠٣) ٦٨١١ اختُلف في قراءة قوله: <q>﴿نصب﴾</q>؛ فقرأ قوم: ‹نَصْبٍ› بفتح النون. وقرأ آخرون: <q>﴿نُصُب﴾</q> بضمّها مع الصاد. وذكر ابنُ جرير (٢٣/٢٨٥) «أنه أجمعت قُراء الأمصار على فتح النون، وأنّ مَن قرأ بالفتح يوجّه النصب إلى أنه مصدر من قول القائل: نَصَبْت الشيء أنصبه نصبًا». وكأن تأويله عندهم: «كأنهم إلى صنم منصوب يُسرعون سعيًا». وأنّ مَن قرأ بالضم فإنه يوجّهه إلى أنه واحد الأنصاب، وهي آلهتهم التي كانوا يعبدونها. وبنحوه قال ابنُ كثير (١٤/١٣٧). <q>﴿یَوۡمَ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ سِرَاعࣰا كَأَنَّهُمۡ إِلَىٰ نُصُبࣲ یُوفِضُونَ ۝٤٣﴾</q> - تفسير الآية ٧٨٨٩٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q>، قال: إلى عَلَم يَسْعَوْن{3}. (١٤/٧٠٢) ٧٨٨٩٩- عن مجاهد بن جبر -من طريق ابن أبى نجيح- <q>﴿إلى نُصُبٍ﴾</q> قال: غاية، <q>﴿يُوفِضُونَ﴾</q> قال: يَستَبِقون{4}. (١٤/٧٠٢) ٧٨٩٠٠- عن أبي العالية الرِّياحيّ -من طريق عَوْف-، مثله{5}. (١٤/٧٠٣) ٧٨٩٠١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿إلى نُصُبٍ يُوفِضُونَ﴾</q>: إلى عَلَم يَنطلِقون{6}. (ز) ٧٨٩٠٢- عن مسلم بن جُندُب الهُذلي -من طريق نافع بن أبي نعيم القارئ- عن قول الله: <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q>، قال: إلى غاية{7}. (ز) ٧٨٩٠٣- عن الحسن البصري -من طريق قُرّة- <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q>، قال: يَبْتَدِرون نُصبهم، أيّهم يَستلمه أول{8}. (١٤/٧٠٣) ٧٨٩٠٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿يَوْمَ يَخْرُجُونَ مِنَ الأَجْداثِ﴾</q> قال: القبور، <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q> قال: إلى عَلَم يَسعَون{9}. (١٤/٧٠٣) ٧٨٩٠٥- قال محمد بن كعب القُرَظيّ: <q>﴿إلى نُصُبٍ يُوفِضُونَ﴾</q> يشتدّون{10}. (ز) ٧٨٩٠٦- عن يحيى بن أبي كثير -من طريق أبي عمرو- في قوله تعالى: <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q>، قال: إلى غاية يَسْتَبِقون{6}. (ز) ٧٨٩٠٧- قال محمد بن السّائِب الكلبي: <q>﴿إلى نُصُبٍ يُوفِضُونَ﴾</q> إلى عَلَم وراية{12}. (ز) ٧٨٩٠٨- قال مقاتل بن سليمان: <q>﴿يَوْمَ يَخْرُجُونَ مِنَ الأَجْداثِ﴾</q> يعني: القبور <q>﴿سِراعًا﴾</q> إلى الصوت، <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q> يقول: كأنهم إلى عَلَم يَسعَون إليه قد نُصب لهم{13}. (ز) ٧٨٩٠٩- عن سفيان [الثوري] -من طريق مهران- في قوله: <q>﴿إلى نُصُبٍ يُوفِضُونَ﴾</q>، قال: إلى عَلَم يَسْتَبِقون{6}. (ز) ٧٨٩١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾</q> قال: النُّصب: حجارة كانوا يعبدونها، حجارة طوال يقال لها نُصب، وفي قوله: <q>﴿يُوفِضُونَ﴾</q> قال: يُسْرِعون إليه كما يُسرعون إلى نُصُب يُوفضون. قال ابن زيد: والأنصاب التي كان أهل الجاهلية يعبدونها ويأتونها ويعظِّمونها، كان أحدهم يَحمله معه، فإذا رأى أحسن منه أخذَه، وألقى هذا، فقال له: <q>﴿كَلٌّ عَلى مَوْلاهُ أيْنَما يُوَجِّهْهُ لا يَأْتِ بِخَيْرٍ هَلْ يَسْتَوِي هُوَ ومَن يَّأْمُرُ بِالعَدْلِ وهُوَ عَلى صَراطٍ مُّسْتَقِيمٍ﴾</q> [النحل:٧٦]{15}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي متواترة، قرأ بها العشرة ما عدا ابن عامر، وحفصًا؛ فإنهما قرآ: <q>﴿إلى نُصُبٍ يُوفِضُونَ﴾</q> بضم النون والصاد. انظر: النشر ٢/٣٩١، والإتحاف ص٥٥٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٨٥-٢٨٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرج ابن جرير ٢٣/٢٨٦ الشطر الثاني منه.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢٣/٢٨٥ بلفظ: إلى علامات يَستَبِقون.أخرجه ابن جرير ٢٣/٢٨٦.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٢٤ (٥٣).أخرجه ابن جرير ٢٣/٢٨٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٨، وابن جرير ٢٣/٢٨٤، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٤٢.أخرجه ابن جرير ٢٣/٢٨٦.تفسير الثعلبي ١٠/٤٢، وتفسير البغوي ٨/٢٢٦.تفسير مقاتل بن سليمان ٤/٤٣٩.أخرجه ابن جرير ٢٣/٢٨٦.أخرجه ابن جرير ٢٣/٢٨٦-٢٨٧.
70,44," <q>﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۚ﴾</q> - قراءات ٧٨٩١١- عن الحسن البصري -من طريق أبي الأشهب- أنه كان يقرؤها: (خاشِعًا أبْصارُهُمْ).= (ز) ٧٨٩١٢- قال: وكان أبو رجاء يقرؤها: <q>﴿خاشِعَةً أبْصارُهُمْ﴾</q>{1}. (١٤/٧٠٣) <q>﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۚ﴾</q> - تفسير الآية ٧٨٩١٣- قال قتادة بن دعامة: <q>﴿خاشِعَةً أبْصارُهُمْ﴾</q> بسواد الوجوه{2}. (ز) ٧٨٩١٤- قال مقاتل بن سليمان: <q>﴿خاشِعَةً أبْصارُهُمْ﴾</q> خافضة أبصارهم ذليلة عند مُعاينة النار، <q>﴿تَرْهَقُهُمْ ذِلَّةٌ﴾</q> يعني: تَغشاهم مَذَلّة{3}. (ز) <q>﴿ذَ ٰ⁠لِكَ ٱلۡیَوۡمُ ٱلَّذِی كَانُوا۟ یُوعَدُونَ ۝٤٤﴾</q> - تفسير ٧٨٩١٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿ذَلِكَ اليَوْمُ الَّذِي كانُوا يُوعَدُونَ﴾</q>، قال: ذلك يوم القيامة{4}. (١٤/٧٠٣) ٧٨٩١٦- قال مقاتل بن سليمان: يقول: <q>﴿ذلك﴾</q> الذي ذُكِر مِن أمر القيامة <q>﴿اليوم الَّذِي كانُوا يُوعَدُونَ﴾</q> الذي كانوا يُوعَدون فيه في الدنيا العذاب، وذلك أنّ الله أوعدهم في الدنيا على ألسنة الرُّسُل أنّ العذاب كائن، لما كذّب كفار مكة النبي ﷺ، فقال الله ﷿: <q>﴿فَذَرْهُم﴾</q> يعني: قريشًا، يعني: فخَلِّ عنهم <q>﴿يَخُوضُوا ويَلْعَبُوا حَتّى يُلاقُوا يَوْمَهُمُ الَّذِي يُوعَدُونَ﴾</q> العذاب فيه{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. و<q>﴿خاشِعَةً أبْصارُهُمْ﴾</q> قراءة العشرة، أما (خاشِعًا أبْصارُهُمْ) فهي قراءة شاذة.تفسير الثعلبي ١٠/٤٢.تفسير مقاتل بن سليمان ٤/٤٣٩-٤٤٠.أخرجه عبد الرزاق ٢/٣١٨، وابن جرير ٢٣/٢٨٦-٢٨٧، كذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٩-٤٤٠.
71,1," مقدمة السورة ٧٨٩١٧- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورةُ نوح بمكة{1}. (١٤/٧٠٤) ٧٨٩١٨- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها: <q>﴿إنّا أرْسَلْنا نُوحًا﴾</q>، وذكر أنها نزلت بعد سورة النَّحل{2}. (ز) ٧٨٩١٩- عن عبد الله بن الزبير، قال: نزلت سورةُ: <q>﴿إنّا أرْسَلْنا نُوحًا﴾</q> بمكة{3}. (١٤/٧٠٤) ٧٨٩٢٠- عن عكرمة مولى ابن عباس= (ز) ٧٨٩٢١- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز) ٧٨٩٢٢- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٧٨٩٢٣- عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة النّحل{6}. (ز) ٧٨٩٢٤- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٧٨٩٢٥- قال مقاتل بن سليمان: سورة نوح مكّيّة، عددها ثمان وعشرون آية كوفي{8}٦٨١٢. (ز) ٦٨١٢ ذكر ابنُ عطية (٨/٤١٥) أنّ السورة مكية بإجماع من المتأولين. ٧٨٩٢٦- عن عبد الله بن عباس، رفع الحديث إلى رسول الله ﷺ، قال: «إنّ الله يدعو نوحًا وقومه يوم القيامة أول الناس، فيقول: ماذا أجبتم نوحًا؟ فيقولون: ما دعانا، وما بلّغنا، ولا نَصَحنا، ولا أمرنا، ولا نَهانا. فيقول نوح: دَعَوتُهم -يا ربّ- دعاء فاشيًا في الأوّلين والآخرين أُمّة بعد أُمّة، حتى انتهى إلى خاتم النّبيّين أحمد، فانتَسخَه، وقرأه، وآمَن به، وصدّقه. فيقول للملائكة: ادعوا أحمدَ وأُمّته. فيأتي رسولُ الله ﷺ وأُمّتُه يَسعى نورهم بين أيديهم، فيقول نوح لمحمد وأُمّته: هل تَعلمون أني بلّغتُ قومي الرسالة، واجتهدتُ لهم بالنّصيحة، وجَهدتُ أن أستَنقِذهم مِن النار سِرًّا وجِهارًا، فلم يَزدهم دعائي إلا فِرارًا؟ فيقول رسول الله ﷺ وأُمّته: فإنّا نَشهد بما نَشَدْتَنا أنّك في جميع ما قلتَ مِن الصادقين. فيقول قوم نوح: وأنّى علِمْتَ هذا أنت وأُمّتك، ونحن أول الأمم، وأنتم آخر الأمم؟! فيقول رسول الله ﷺ: بسم الله الرحمن الرحيم <q>﴿إنّا أرْسَلْنا نُوحًا إلى قَوْمِهِ﴾</q>» حتى خَتَم السورة. فإذا خَتمَها قالت أُمّته: نَشهد: <q>﴿إنَّ هَذا لَهُوَ القَصَصُ الحَقُّ وما مِن إلَهٍ إلّا اللَّهُ وإنَّ اللَّهَ لَهُوَ العَزِيزُ الحَكِيمُ﴾</q> [آل عمران:٦٢]. فيقول الله عند ذلك: <q>﴿وامْتازُوا اليَوْمَ أيُّها المُجْرِمُونَ﴾</q> [يس:٥٩]{9}. (١٤/٧٠٤) <q>﴿إِنَّاۤ أَرۡسَلۡنَا نُوحًا إِلَىٰ قَوۡمِهِۦۤ أَنۡ أَنذِرۡ قَوۡمَكَ مِن قَبۡلِ أَن یَأۡتِیَهُمۡ عَذَابٌ أَلِیمࣱ ۝١﴾</q> - تفسير ٧٨٩٢٧- قال مقاتل بن سليمان: <q>﴿إنّا أرْسَلْنا نُوحًا إلى قَوْمِهِ﴾</q> ونوح بالسّريانيّة: الساكن الذي سَكنتْ إليه الأرض، وهو نوح بن لَمَك ﷺ <q>﴿أنْ أنْذِرْ قَوْمَكَ﴾</q> العذاب <q>﴿مِن قَبْلِ أنْ يَأْتِيَهُمْ عَذابٌ ألِيمٌ﴾</q> يعني: وجيعًا في الدنيا، وهو الغَرق{10}٦٨١٣. (ز) ٦٨١٣ ذكر ابنُ عطية (٨/٤١٥) أنّ قوله: <q>﴿أن أنذر قومك﴾</q> يحتمل احتمالين: الأول: أن تكون <q>﴿أن﴾</q> مُفسِّرة لا موضع لها من الإعراب. الثاني: أن يكون التقدير: «بأنْ أنذِر قومك». وعلَّق عليه بقوله: «وهي -على هذا- في موضع نصب عند قوم من النحاة، وفي موضع خفض عند آخرين». وبيّن أنّ العذاب الذي تُوّعدوا به يحتمل احتمالين: الأول: أن يكون عذاب الآخرة. الثاني: أن يكون عذاب الدنيا. ورجَّحه مستندًا إلى السياق، فقال: «وهو الأظهر، والأَليق بما يأتي بعد». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٤٩ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٤٧.أخرجه الحاكم ٢/٥٩٧ (٤٠١٢)، وفي إسناده عبد المنعم بن إدريس. قال الذهبي في التلخيص: «إسناده واهٍ». وقال ابن حجر في إتحاف المهرة ٨/١٢٨ (٩٠٥٧): «قلت: ولم يتكلّم عليه -أي: الحاكم-، وعبد المنعم كذّبوه».تفسير مقاتل بن سليمان ٤/٤٤٩.
71,2," <q>﴿قَالَ یَـٰقَوۡمِ إِنِّی لَكُمۡ نَذِیرࣱ مُّبِینٌ ۝٢﴾</q> - تفسير ٧٨٩٢٨- قال مقاتل بن سليمان: <q>﴿قالَ يا قَوْمِ إنِّي لَكُمْ نَذِيرٌ﴾</q> مِن العذاب <q>﴿مُبِينٌ﴾</q> يعني: بيِّن{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٤٩.
71,3," <q>﴿أَنِ ٱعۡبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُ وَأَطِیعُونِ ۝٣﴾</q> - تفسير ٧٨٩٢٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أنِ اعْبُدُوا اللَّهَ واتَّقُوهُ وأَطِيعُونِ﴾</q>، قال: بها أرسَل الله المُرسلين أن يُعبد الله وحده، وأن تُتّقى مَحارمه، وأن يُطاع أمْره{1}. (١٤/٧٠٥) ٧٨٩٣٠- قال مقاتل بن سليمان: <q>﴿أنِ اعْبُدُوا اللَّهَ﴾</q> يقول: أن وحِّدوا الله، <q>﴿واتَّقُوهُ﴾</q> أن تُشركوا به شيئًا، <q>﴿وأَطِيعُونِ﴾</q> فيما آمركم به مِن النصيحة بأنّه ليس له شريك{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٨٩. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٤٩.
71,4," <q>﴿یَغۡفِرۡ لَكُم مِّن ذُنُوبِكُمۡ وَیُؤَخِّرۡكُمۡ إِلَىٰۤ أَجَلࣲ مُّسَمًّىۚ﴾</q> - تفسير ٧٨٩٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ويُؤَخِّرْكُمْ إلى أجَلٍ مُسَمًّى﴾</q>، قال: ما قد خُطّ من الأَجل، فإذا جاء أجل الله لم يُؤخّر{1}. (١٤/٧٠٥) ٧٨٩٣٢- قال مقاتل بن سليمان: فإذا فَعلتم <q>﴿يَغْفِرْ لَكُمْ مِن ذُنُوبِكُمْ﴾</q> والـ<q>﴿من﴾</q> هاهنا صِلة. يقول: يَغفر لكم ذنوبكم، <q>﴿ويُؤَخِّرْكُمْ إلى أجَلٍ مُسَمًّى﴾</q> يعني: إلى منتهى آجالكم، فلا يُعاقبكم بالسّنين ولا بغيره{2}٦٨١٤. (ز) ٦٨١٤ ذكر ابنُ عطية (٨/٤١٦) أقوالًا في معنى <q>﴿من﴾</q>: الأول: أنها زائدة. ونسبه لِنُحاة الكوفة. ثم علَّق بقوله: «وأمّا الخليل وسيبويه فلا يجوز عندهم زيادتها في الواجب». وساق ابنُ كثير (١٤/١٣٨) هذا القول، ثم علَّق بقوله: «ولكنّ القول بزيادتها في الإثبات قليل. ومنه قول بعض العرب: قد كان من مطر». الثاني: أنها لبيان الجنس. وانتقده فقال: «وهذا ضعيف؛ لأنه ليس هنا جنس يُبَيّن». الثالث: أنها بمعنى «عن». وانتقده مستندًا للغة، فقال: «وهذا غير معروف في أحكام»من«». الرابع: أنها لابتداء الغاية، وعلَّق عليه بقوله: «وهذا قول يتجه، كأنه يقول: يبتدئ الغفران من هذه الذّنوب العِظام التي لهم». الخامس: أنها للتبعيض. ورجَّحه مستندًا إلى الدلالة العقلية، فقال: «وهذا عندي أبين الأقوال، وذلك أنه لو قال:»يَغْفِر لكم ذُنوبكم«لعمّ هذا اللفظ ما تَقدّم من الذّنوب وما تأخر عن إيمانهم، والإسلام يَجبّ ما قبله، فهي بعض من ذنوبهم، فالمعنى: يَغْفِر لكم ذُنوبكم». وذكر أنّ بعض المفسرين قال: أراد: يَغْفِر لكم من ذُنوبكم المهمّ المُوبق الكبير؛ لأنه أهمّ عليهم، وبه ربما كان اليأس عن الله قد وقع لهم. وعلَّق عليه بقوله: «وهذا قول مُضمّنه أنّ <q>﴿من﴾</q> للتبعيض». ٧٨٩٣٣- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿يَغْفِرْ لَكُمْ مِن ذُنُوبِكُمْ﴾</q> قال: الشّرك، <q>﴿ويُؤَخِّرْكُمْ إلى أجَلٍ مُسَمًّى﴾</q> قال: بغير عُقوبة{3}. (١٤/٧٠٥) <q>﴿إِنَّ أَجَلَ ٱللَّهِ إِذَا جَاۤءَ لَا یُؤَخَّرُۚ لَوۡ كُنتُمۡ تَعۡلَمُونَ ۝٤﴾</q> - تفسير ٧٨٩٣٤- قال الحسن البصري: <q>﴿إنَّ أجَلَ اللَّهِ﴾</q> يعني: القيامة{4}. (ز) ٧٨٩٣٥- قال مقاتل بن سليمان: <q>﴿إنَّ أجَلَ اللَّهِ﴾</q> في العذاب في الدنيا، وهو الغَرق، <q>﴿إذا جاءَ لا يُؤَخَّرُ لَوْ كُنْتُمْ تَعْلَمُونَ﴾</q> ولكنكم لا تعلمون{2}. (ز) ٧٨٩٣٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿إنَّ أجَلَ اللَّهِ إذا جاءَ لا يُؤَخَّرُ﴾</q>، قال: الموت{3}. (١٤/٧٠٥) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٤٩.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٩-.تفسير مقاتل بن سليمان ٤/٤٤٩.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.
71,5," <q>﴿قَالَ رَبِّ إِنِّی دَعَوۡتُ قَوۡمِی لَیۡلࣰا وَنَهَارࣰا ۝٥﴾</q> - تفسير ٧٨٩٣٧- قال مقاتل بن سليمان: <q>﴿قالَ رَبِّ إنِّي دَعَوْتُ قَوْمِي لَيْلًا ونَهارًا﴾</q> ليَسمعوا دُعائي{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٤٩.
71,6," <q>﴿فَلَمۡ یَزِدۡهُمۡ دُعَاۤءِیۤ إِلَّا فِرَارࣰا ۝٦﴾</q> - تفسير ٧٨٩٣٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَلَمْ يَزِدْهُمْ دُعائِي إلّا فِرارًا﴾</q>، قال: بلَغني: أنه كان يَذهب الرجل بابنه إلى نوح، فيقول لابنه: احذر هذا، لا يغُرَّنَّك، فإنّ أبي قد ذَهب بي وأنا مثلك، فحذّرني كما حذّرتك{1}. (١٤/٧٠٥) ٧٨٩٣٩- قال مقاتل بن سليمان: <q>﴿فَلَمْ يَزِدْهُمْ دُعائِي إلّا فِرارًا﴾</q>، يعني: تَباعُدًا مِن الإيمان{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣١٩، وابن جرير ٢٣/٢٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٤٩.
71,7," <q>﴿وَإِنِّی كُلَّمَا دَعَوۡتُهُمۡ لِتَغۡفِرَ لَهُمۡ جَعَلُوۤا۟ أَصَـٰبِعَهُمۡ فِیۤ ءَاذَانِهِمۡ﴾</q> - تفسير ٧٨٩٤٠- عن عبد الله بن عباس، في قوله: <q>﴿جَعَلُوا أصابِعَهُمْ فِي آذانِهِمْ﴾</q>، قال: لئلا يسمعوا ما يقول{1}. (١٤/٧٠٦) ٧٨٩٤١- عن عبد الله بن عباس -من طريق إسحاق بن بشر-: أن نوحًا بُعِث في الألفِ الثاني، وإن آدم لم يمُتْ حتى وُلِدَ له نوحٌ في آخر الألف الأوَّل، وكان قد فشَتْ فيهم المعاصي، وكثُرتِ الجبابرةُ، وعَتَوا عُتُوًّا كبيرًا، وكان نوحٌ يدعوهم ليلًا ونهارًا، سِرًّا وعلانية، صبورًا حليمًا، ولم يلقَ أحدٌ مِن الأنبياء أشدَّ مما لقِي نوحٌ، فكانوا يدخُلون عليه فيخنُقُونه، ويُضرَبُ في المجالس ويُطرَدُ، وكان لا يدَعُ على ما يُصنعُ به أن يدعُوَهم ويقولَ: يا ربِّ، اغفِرْ لقومي فإنهم لا يعلمون. فكان لا يزيدُهم ذلك إلّا فرارًا منه، حتى إنه لَيُكلِّمُ الرجلَ منهم، فيلُفُّ رأسَه بثوبه، ويجعلُ أصابعَه في أُذنَيه؛ لكيلا يسمعَ شيئًا من كلامه، فذلك قولُ الله: <q>﴿جعلُوا أصابعهم في آذانهم واستغْشوا ثيابهم﴾</q>{2}. (٦/٤٣٧) ٧٨٩٤٢- قال مقاتل بن سليمان: <q>﴿وإنِّي كُلَّما دَعَوْتُهُمْ﴾</q> إلى الإيمان، يعني: إلى الاستغفار <q>﴿لِتَغْفِرَ لَهُمْ جَعَلُوا أصابِعَهُمْ فِي آذانِهِمْ واسْتَغْشَوْا ثِيابَهُمْ﴾</q> لئلا يَسمعوا دُعائي{3}. (ز) ٧٨٩٤٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿جَعَلُوا أصابِعَهُمْ فِي آذانِهِمْ﴾</q> لئلا يَسمعوا كلام نوح ﵇{4}٦٨١٥. (ز) ٦٨١٥ ذكر ابنُ عطية (٨/٤١٧) أنّ قوله تعالى: <q>﴿جعلوا أصابعهم في آذانهم﴾</q> يحتمل أن يكون حقيقة، ويحتمل أن يكون عبارة عن إعراضهم، وشِدّة رفضهم لأقواله. <q>﴿وَٱسۡتَغۡشَوۡا۟ ثِیَابَهُمۡ﴾</q> - تفسير ٧٨٩٤٤- عن عبد الله بن عباس، في قوله: <q>﴿واسْتَغْشَوْا ثِيابَهُمْ﴾</q>، قال: لأن يَتنكّروا له فلا يَعرفهم{1}. (١٤/٧٠٦) ٧٨٩٤٥- عن عبد الله بن عباس، في قوله: <q>﴿واسْتَغْشَوْا ثِيابَهُمْ﴾</q>، قال: غَطَّوا وجوههم؛ لئلّا يَروا نوحًا، ولا يَسمعوا كلامه{6}. (١٤/٧٠٦) ٧٨٩٤٦- عن سعيد بن جُبَير، في قوله: <q>﴿واسْتَغْشَوْا ثِيابَهُمْ﴾</q>، قال: تَسَجَّوا بها{7}٦٨١٦. (١٤/٧٠٦) ٦٨١٦ ذكر ابنُ عطية (٨/٤١٧) أنّ قوله تعالى: <q>﴿واستغشوا ثيابهم﴾</q> يحتمل أن يكون حقيقة، ويحتمل أن يكون عبارة عن إعراضهم، وشِدّة رفضهم لأقواله. <q>﴿وَأَصَرُّوا۟ وَٱسۡتَكۡبَرُوا۟ ٱسۡتِكۡبَارࣰا ۝٧﴾</q> - تفسير ٧٨٩٤٧- عن عبد الله بن عباس، في قوله: <q>﴿واسْتَكْبَرُوا اسْتِكْبارًا﴾</q>، قال: ترَكوا التوبة{1}. (١٤/٧٠٦) ٧٨٩٤٨- قال مقاتل بن سليمان: <q>﴿وأَصَرُّوا﴾</q> وأقاموا على الكذب، <q>﴿واسْتَكْبَرُوا﴾</q> يعني: وتَكبّروا عن الإيمان <q>﴿اسْتِكْبارًا﴾</q> يعني: وتَكبُّرًا{3}. (ز) ٧٨٩٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَصَرُّوا﴾</q>، قال: الإصرارُ: إقامتهم على الشرك والكفر{10}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٦٢/٢٤٣-٢٤٥.تفسير مقاتل بن سليمان ٤/٤٤٩.أخرجه ابن جرير ٢٣/٢٩١.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٤٩.أخرجه ابن جرير ٢٣/٢٩٢.
71,8," <q>﴿ثُمَّ إِنِّی دَعَوۡتُهُمۡ جِهَارࣰا ۝٨﴾</q> - تفسير ٧٨٩٥٠- قال عبد الله بن عباس: <q>﴿ثُمَّ إنِّي دَعَوْتُهُمْ جِهارًا﴾</q> بأعلى صوتي{1}. (ز) ٧٨٩٥١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثُمَّ إنِّي دَعَوْتُهُمْ جِهارًا﴾</q>، قال: الكلام المُعلَن به{2}. (١٤/٧٠٦) ٧٨٩٥٢- قال مقاتل بن سليمان: <q>﴿ثُمَّ إنِّي دَعَوْتُهُمْ جِهارًا﴾</q>، يعني: مُجاهرة وعلانية{3}. (ز) ",footnotes:1:تفسير البغوي ٨/٢٣٠.أخرجه ابن جرير ٢٣/٢٩٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٤٩-٤٥٠.
71,9," <q>﴿ثُمَّ إِنِّیۤ أَعۡلَنتُ لَهُمۡ وَأَسۡرَرۡتُ لَهُمۡ إِسۡرَارࣰا ۝٩﴾</q> - تفسير ٧٨٩٥٣- قال عبد الله بن عباس: <q>﴿ثُمَّ إنِّي أعْلَنْتُ لَهُمْ وأَسْرَرْتُ لَهُمْ إسْرارًا﴾</q> يريد: الرجل بعد الرجل أكلّمه سِرًّا بيني وبينه، أدعوه إلى عبادتك وتَوحيدك{1}. (ز) ٧٨٩٥٤- عن مجاهد بن جبر، في قوله: <q>﴿ثُمَّ إنِّي أعْلَنْتُ لَهُمْ﴾</q> قال: صِحتُ، <q>﴿وأَسْرَرْتُ لَهُمْ إسْرارًا﴾</q> قال: النِّجاء{2}؛ نِجاء الرجل{3}. (١٤/٧٠٦) ٧٨٩٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أعْلَنْتُ لَهُمْ﴾</q> قال: صِحتُ، <q>﴿وأَسْرَرْتُ لَهُمْ إسْرارًا﴾</q> قال: فيما بيني وبينهم{4}. (ز) ٧٨٩٥٦- قال مقاتل بن سليمان: <q>﴿ثُمَّ إنِّي أعْلَنْتُ لَهُمْ وأَسْرَرْتُ لَهُمْ إسْرارًا﴾</q>، يعني: صِحتُ إليهم، وأَسْررْتُ لهم في بيوتهم إسرارًا{5}. (ز) ",footnotes:1:تفسير البغوي ٨/٢٣٠.ناجى الرجل مناجاةً ونجاءً: سارَّه. اللسان (نجي).عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٩٢، ٢٩٣.تفسير مقاتل بن سليمان ٤/٤٤٩-٤٥٠.
71,10," <q>﴿فَقُلۡتُ ٱسۡتَغۡفِرُوا۟ رَبَّكُمۡ إِنَّهُۥ كَانَ غَفَّارࣰا ۝١٠﴾</q> - تفسير ٧٨٩٥٧- قال مقاتل بن سليمان: <q>﴿فَقُلْتُ اسْتَغْفِرُوا رَبَّكُمْ﴾</q> من الشّرك، <q>﴿إنَّهُ كانَ غَفّارًا﴾</q> للذّنوب، كان ولم يَزل غَفّارًا للذّنوب{1}. (ز) ٧٨٩٥٨- عن سفيان بن عُيينة -من طريق سعيد- في قوله: <q>﴿استغفروا ربكم إنه كان غفارا﴾</q>، يقول: وحِّدوه{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٥٠.أخرجه أبو نعيم في حلية الأولياء ٧/٢٨٥.
