tafsir[8]{c,v,t}:
10,71," <q>﴿وَٱتۡلُ عَلَیۡهِمۡ نَبَأَ نُوحٍ إِذۡ قَالَ لِقَوۡمِهِۦ یَـٰقَوۡمِ إِن كَانَ كَبُرَ عَلَیۡكُم مَّقَامِی وَتَذۡكِیرِی بِـَٔایَـٰتِ ٱللَّهِ فَعَلَى ٱللَّهِ تَوَكَّلۡتُ﴾</q> - تفسير ٣٤٧٢٤- قال مقاتل بن سليمان: <q>﴿واتْلُ عَلَيْهِمْ﴾</q> يعني: واقرأ عليهم <q>﴿نَبَأَ نُوحٍ﴾</q> يعني: حديث نوح <q>﴿إذْ قالَ لِقَوْمِهِ يا قَوْمِ إنْ كانَ كَبُرَ عَلَيْكُمْ﴾</q> يعني: عَظُم عليكم <q>﴿مَقامِي﴾</q> يعني: طُول مُكْثِي فيكم، <q>﴿وتَذْكِيرِي بِآياتِ اللَّهِ﴾</q> يعني: تحذيري إيّاكم عقوبةَ الله؛ <q>﴿فَعَلى اللَّهِ تَوَكَّلْتُ﴾</q> يعني: بِالله احْتَرَزْتُ{1}. (ز) <q>﴿فَأَجۡمِعُوۤا۟ أَمۡرَكُمۡ وَشُرَكَاۤءَكُمۡ﴾</q> - تفسير ٣٤٧٢٥- عن الحسن البصري -من طريق هارون- <q>﴿فأجمعوا أمركم وشركاءكُم﴾</q>، أي: فلْيُجْمِعوا أمرَهم معكم{2}. (٧/٦٩٠) ٣٤٧٢٦- عن الأعرَج -من طريق أسيد- في قوله: <q>﴿فأجمعوا أمركُم وشركاءكُم﴾</q>، يقولُ: فأَحْكِموا أمرَكم، وادعوا شركاءكم{3}. (٧/٦٩٠) ٣٤٧٢٧- قال مقاتل بن سليمان: <q>﴿فَأَجْمِعُوا أمْرَكُمْ وشُرَكاءَكُمْ﴾</q>، وآلهتكم{1}. (ز) <q>﴿ثُمَّ لَا یَكُنۡ أَمۡرُكُمۡ عَلَیۡكُمۡ غُمَّةࣰ﴾</q> - تفسير ٣٤٧٢٨- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ثم لا يكن أمركم عليكُم غمَّةً﴾</q>، قال: لا يَكْبُرْ عليكم أمرُكم{5}. (٧/٦٩١) ٣٤٧٢٩- قال مقاتل بن سليمان: <q>﴿ثُمَّ لا يَكُنْ أمْرُكُمْ عَلَيْكُمْ غُمَّةً﴾</q> يعني: سوءا {1}.(ز) (ز) <q>﴿ثُمَّ ٱقۡضُوۤا۟ إِلَیَّ وَلَا تُنظِرُونِ ۝٧١﴾</q> - تفسير ٣٤٧٣٠- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿ثم اقضُوا إليَّ﴾</q> قال: انهضوا إلَيَّ، <q>﴿ولا تُنظرونِ﴾</q> يقولُ: ولا تُؤَخِّرُونِ{7}. (٧/٦٩١) ٣٤٧٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ثم اقضوا إليَّ﴾</q>، قال: ما في أنفسكم{8}. (٧/٦٩١) ٣٤٧٣٢- عن الضَّحّاك بن مُزاحِم، <q>﴿ثُمَّ اقْضُوا إلَيَّ﴾</q>، يعني: انْهَضُوا إلَيَّ{9}. (ز) ٣٤٧٣٣- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿ثم اقضوا إلي ولا تنظرون﴾</q>، قال: اقضوا إلَيَّ ما كنتم قاضِين{10}. (٧/٦٩١) ٣٤٧٣٤- قال مقاتل بن سليمان: <q>﴿ثُمَّ اقْضُوا إلَيَّ﴾</q> يعني: مِيلوا إلَيَّ، <q>﴿ولا تُنْظِرُونِ﴾</q> يعني: ولا تُمْهِلُون{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٤.أخرجه ابن أبي حاتم ٦/١٩٦٩.أخرجه ابن أبي حاتم ٦/١٩٦٧.تفسير مقاتل بن سليمان ٢/٢٤٤.أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/٢٣٣، وابن أبي حاتم ٦/١٩٦٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٤٤.أخرجه ابن أبي حاتم ٦/١٩٦٩، ١٩٧٠. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٨٢، وأخرجه ابن جرير ١٢/٢٣٤، وابن أبي حاتم ٦/١٩٧٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/١٤٢.أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/٢٣٣، وابن أبي حاتم ٦/١٩٧٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٤٤.
10,72," <q>﴿فَإِن تَوَلَّیۡتُمۡ فَمَا سَأَلۡتُكُم مِّنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَى ٱللَّهِۖ وَأُمِرۡتُ أَنۡ أَكُونَ مِنَ ٱلۡمُسۡلِمِینَ ۝٧٢﴾</q> - تفسير ٣٤٧٣٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿إن أجري﴾</q>، يقول: جزائي{1}. (ز) ٣٤٧٣٦- قال مقاتل بن سليمان: <q>﴿فَإنْ تَوَلَّيْتُمْ﴾</q> يعني: عَصَيْتُم <q>﴿فَما سَأَلْتُكُمْ مِن أجْرٍ﴾</q> يعني: مِن جُعْلٍ، <q>﴿إنْ أجْرِيَ﴾</q> يعني: ثوابي <q>﴿إلّا عَلى اللَّهِ وأُمِرْتُ أنْ أكُونَ مِنَ المُسْلِمِينَ﴾</q> يعني: مِن المُوَحِّدين{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٧٠.تفسير مقاتل بن سليمان ٢/٢٤٤.
10,73," <q>﴿فَكَذَّبُوهُ فَنَجَّیۡنَـٰهُ وَمَن مَّعَهُۥ فِی ٱلۡفُلۡكِ وَجَعَلۡنَـٰهُمۡ خَلَـٰۤىِٕفَ وَأَغۡرَقۡنَا ٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَاۖ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُنذَرِینَ ۝٧٣﴾</q> - تفسير ٣٤٧٣٧- قال مقاتل بن سليمان: <q>﴿فَكَذَّبُوهُ فَنَجَّيْناهُ ومَن مَعَهُ﴾</q> مِن المؤمنين <q>﴿فِي الفُلْكِ﴾</q> يعني: السفينة، <q>﴿وجَعَلْناهُمْ خَلائِفَ﴾</q> في الأرض مِن بعد نوح، <q>﴿وأَغْرَقْنا الَّذِينَ كَذَّبُوا بِآياتِنا﴾</q> يعني: بنوحٍ وما جاء به، <q>﴿فانْظُرْ﴾</q> يا محمد <q>﴿كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</q> يعني: المُحَذَّرين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٤.
10,74," <q>﴿ثُمَّ بَعَثۡنَا مِنۢ بَعۡدِهِۦ رُسُلًا إِلَىٰ قَوۡمِهِمۡ فَجَاۤءُوهُم بِٱلۡبَیِّنَـٰتِ فَمَا كَانُوا۟ لِیُؤۡمِنُوا۟ بِمَا كَذَّبُوا۟ بِهِۦ مِن قَبۡلُۚ كَذَ ٰ⁠لِكَ نَطۡبَعُ عَلَىٰ قُلُوبِ ٱلۡمُعۡتَدِینَ ۝٧٤﴾</q> - تفسير ٣٤٧٣٨- عن أُبَيِّ بن كعب -من طريق أبي العالية- في قوله: <q>﴿ثم بعثنا من بعده رسلا إلى قومهم فجاؤهم بالبينات فما كانوا ليؤمنوا بما كذبوا به من قبل﴾</q>: كان في عِلْمِه يوم أقَرُّوا به مَن يُصَدِّق به ومَن يُكَذِّب به، فكان عيسى ﵇ مِن تلك الأزواج التي أُخِذ عليها العَهْدُ والميثاقُ في زمان آدم{1}. (ز) ٣٤٧٣٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قوله: <q>﴿بما كذبوا به من قبل﴾</q> قولُ الله: <q>﴿ولو ردوا لعادوا لما نهوا عنه﴾</q> [الأنعام:٢٨]{1}. (ز) ٣٤٧٤٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿فما كانوا ليؤمنوا بما كذبوا به من قبل﴾</q>، قال: ذلك يوم أُخِذ منهم الميثاقُ آمنوا كرهًا{3}٣١٣٧. (ز) ٣١٣٧ ذكر ابنُ عطية (٤/٥٠٨) في معنى الآية قولًا آخر، فقال: «يحتمل اللفظ عندي معنًى آخر، وهو أن تكون»ما«مصدرية، والمعنى: فكذبوا رسلهم فكان عقابهم مِن الله أن لم يكونوا ليؤمنوا بتكذيبهم من قبل، أي: من سببه ومن جراه. ويؤيد هذا التأويلَ قولُه: <q>﴿كذلك نطبع﴾</q>». ٣٤٧٤١- قال مقاتل بن سليمان: <q>﴿ثُمَّ بَعَثْنا مِن بَعْدِهِ﴾</q> يعني: من بعد نوح <q>﴿رُسُلًا إلى قَوْمِهِمْ فَجاؤُهُمْ بِالبَيِّناتِ﴾</q>، ثُمَّ أخبر بعلمه فيهم، فقال: <q>﴿فَما كانُوا لِيُؤْمِنُواْ﴾</q> يعني: لِيُصَدِّقوا <q>﴿بِما كَذَّبُوا بِهِ﴾</q> يعني: العذاب <q>﴿مِن قَبْلُ﴾</q> نزول العذاب، <q>﴿كَذَلِكَ نَطْبَعُ﴾</q> يعني: هكذا نَخْتِم <q>﴿عَلى قُلُوبِ المُعْتَدِينَ﴾</q> يعني: الكافرين{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٧٢.أخرجه ابن أبي حاتم ٦/١٩٧٢.أخرجه ابن أبي حاتم ٦/١٩٧٢. وقد ذكر أيضًا هذه الآثار عند تفسير قوله تعالى:<q>﴿ولقد جاءتهم رسلهم بالبينات فما كانوا ليؤمنوا بما كذبوا من قبل كذلك يطبع الله على قلوب الكافرين﴾</q> [الأعراف:١٠١].تفسير مقاتل بن سليمان ٢/٢٤٤.
10,75," <q>﴿ثُمَّ بَعَثۡنَا مِنۢ بَعۡدِهِم مُّوسَىٰ وَهَـٰرُونَ إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦ بِـَٔایَـٰتِنَا فَٱسۡتَكۡبَرُوا۟ وَكَانُوا۟ قَوۡمࣰا مُّجۡرِمِینَ ۝٧٥﴾</q> - تفسير ٣٤٧٤٢- قال مقاتل بن سليمان: <q>﴿ثُمَّ بَعَثْنا مِن بَعْدِهِمْ﴾</q> مِن بعد الأُمَم <q>﴿مُوسى وهارُونَ إلى فِرْعَوْنَ ومَلائِهِ بِآياتِنا﴾</q> يعني: بعلاماتنا؛ اليد، والعصا، <q>﴿فاسْتَكْبَرُواْ﴾</q> يعني: فتكبّروا عن الإيمان، <q>﴿وكانُوا قَوْمًا مُجْرِمِينَ﴾</q> يعني: كافرين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٤-٢٤٥.
10,76," <q>﴿فَلَمَّا جَاۤءَهُمُ ٱلۡحَقُّ مِنۡ عِندِنَا قَالُوۤا۟ إِنَّ هَـٰذَا لَسِحۡرࣱ مُّبِینࣱ ۝٧٦ قَالَ مُوسَىٰۤ أَتَقُولُونَ لِلۡحَقِّ لَمَّا جَاۤءَكُمۡۖ أَسِحۡرٌ هَـٰذَا وَلَا یُفۡلِحُ ٱلسَّـٰحِرُونَ ۝٧٧﴾</q> - تفسير ٣٤٧٤٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا جاءهم رسولٌ مِن عند الله عارَضُوه، وحاصَروه{1}. (ز) ٣٤٧٤٤- قال مقاتل بن سليمان: <q>﴿فَلَمّا جاءَهُمُ الحَقُّ مِن عِنْدِنا﴾</q> يعني: موسى، وما جاء به من الآيات؛ <q>﴿قالُواْ إنَّ هَذا لَسِحْرٌ مُبِينٌ قالَ مُوسى أتَقُولُونَ لِلْحَقِّ﴾</q> اليد والعصا <q>﴿لَمّا جاءَكُمْ أسِحْرٌ هَذا ولا يُفْلِحُ السّاحِرُونَ﴾</q> في الدنيا والآخرة{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٧٣.تفسير مقاتل بن سليمان ٢/٢٤٥.
  10,77,""
10,78," <q>﴿قَالُوۤا۟ أَجِئۡتَنَا لِتَلۡفِتَنَا عَمَّا وَجَدۡنَا عَلَیۡهِ ءَابَاۤءَنَا﴾</q> - تفسير ٣٤٧٤٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿لتلفتنا﴾</q>، قال: لِتَلْوِيَنا{1}. (٧/٦٩١) ٣٤٧٤٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿لتلفتنا﴾</q>، قال: لِتَصُدَّنا عن آلهتنا{2}. (٧/٦٩١) ٣٤٧٤٧- قال مقاتل بن سليمان: <q>﴿قالُواْ أجِئْتَنا لِتَلْفِتَنا﴾</q> يعني: لِتَصُدَّنا <q>﴿عَمّا وجَدْنا عَلَيْهِ آباءَنا﴾</q> يعني: عما كانت آباؤنا تَعْبُد{3}. (ز) <q>﴿وَتَكُونَ لَكُمَا ٱلۡكِبۡرِیَاۤءُ فِی ٱلۡأَرۡضِ﴾</q> - تفسير ٣٤٧٤٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قوله: <q>﴿وتكون لكُما الكبرياء في الأرض﴾</q>، قال: العَظَمَةُ، والمُلْكُ، والسُّلطان{4}٣١٣٨. (٧/٦٩١) ٣١٣٨ قال ابنُ عطية (٤/٥١٠): «الكبرياء: مصدر مبالغ مِن الكبر، والمراد به في هذا الموضع: الملك. وكذلك قال فيه مجاهد بن جبر، والضحاك بن مزاحم، وأكثر المتأولين؛ لأنه أعظم تَكَبُّرِ الدنيا». ٣٤٧٤٩- عن مجاهد بن جبر -من طريق الأعمش- <q>﴿وتَكُونَ لَكُما الكِبْرِياءُ فِي الأَرْضِ﴾</q>: السلطان في الأرض{5}. (ز) ٣٤٧٥٠- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿وتكون لكما الكبرياء في الأرض﴾</q>، قال: الطّاعة{6}. (ز) ٣٤٧٥١- قال مقاتل بن سليمان: <q>﴿وتَكُونَ لَكُما الكِبْرِياءُ﴾</q> يعني: موسى وهارون <q>﴿الكبرياء﴾</q> يعني: الملك <q>﴿فِي الأَرْضِ﴾</q>{3}٣١٣٩. (ز) ٣١٣٩ قال ابنُ جرير (١٢/٢٤١): «هذه الأقوال كلها متقارباتُ المعاني، وذلك أنّ الملك سلطان، والطاعة ملك، غير أنّ معنى الكبرياء هو ما ثبت في كلام العرب، ثم يكون ذلك عَظَمَة بملك، وسلطان، وغير ذلك». <q>﴿وَمَا نَحۡنُ لَكُمَا بِمُؤۡمِنِینَ ۝٧٨﴾</q> - تفسير ٣٤٧٥٢- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿بمؤمنين﴾</q>، قال: بمُصَدِّقين{8}. (ز) ٣٤٧٥٣- قال مقاتل بن سليمان: <q>﴿وما نَحْنُ لَكُما بِمُؤْمِنِينَ﴾</q>، يعني: بمُصَدِّقين{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٢٣٩، وابن أبي حاتم ٦/١٩٧٣. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر.أخرجه ابن أبي حاتم ٦/١٩٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٤٥.تفسير مجاهد ص٣٨٢، وأخرجه ابن جرير ١٢/٢٤٠، وابن أبي حاتم ٦/١٩٧٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٢٤١.أخرجه ابن جرير ١٢/٢٤٠.تفسير مقاتل بن سليمان ٢/٢٤٥.أخرجه ابن أبي حاتم ٦/١٩٧٣.تفسير مقاتل بن سليمان ٢/٢٤٥.
