quran[8]{c,v,t}:
  10,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱتۡلُ عَلَیۡهِمۡ نَبَأَ نُوحٍ إِذۡ قَالَ لِقَوۡمِهِۦ یَـٰقَوۡمِ إِن كَانَ كَبُرَ عَلَیۡكُم مَّقَامِی وَتَذۡكِیرِی بِـَٔایَـٰتِ ٱللَّهِ فَعَلَى ٱللَّهِ تَوَكَّلۡتُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتْلُ عَلَيْهِمْ﴾</span> يعني: واقرأ عليهم <span class="qpc-hafs">﴿نَبَأَ نُوحٍ﴾</span> يعني: حديث نوح <span class="qpc-hafs">﴿إذْ قالَ لِقَوْمِهِ يا قَوْمِ إنْ كانَ كَبُرَ عَلَيْكُمْ﴾</span> يعني: عَظُم عليكم <span class="qpc-hafs">﴿مَقامِي﴾</span> يعني: طُول مُكْثِي فيكم، <span class="qpc-hafs">﴿وتَذْكِيرِي بِآياتِ اللَّهِ﴾</span> يعني: تحذيري إيّاكم عقوبةَ الله؛ <span class="qpc-hafs">﴿فَعَلى اللَّهِ تَوَكَّلْتُ﴾</span> يعني: بِالله احْتَرَزْتُ{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَجۡمِعُوۤا۟ أَمۡرَكُمۡ وَشُرَكَاۤءَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٢٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هارون- <span class="qpc-hafs">﴿فأجمعوا أمركم وشركاءكُم﴾</span>، أي: فلْيُجْمِعوا أمرَهم معكم{2}. (٧/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٢٦<span class="dash">-</span></span> عن <span class="name-2">الأعرَج</span> -من طريق أسيد- في قوله: <span class="qpc-hafs">﴿فأجمعوا أمركُم وشركاءكُم﴾</span>، يقولُ: فأَحْكِموا أمرَكم، وادعوا شركاءكم{3}. (٧/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَجْمِعُوا أمْرَكُمْ وشُرَكاءَكُمْ﴾</span>، وآلهتكم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ لَا یَكُنۡ أَمۡرُكُمۡ عَلَیۡكُمۡ غُمَّةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ثم لا يكن أمركم عليكُم غمَّةً﴾</span>، قال: لا يَكْبُرْ عليكم أمرُكم{5}. (٧/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ لا يَكُنْ أمْرُكُمْ عَلَيْكُمْ غُمَّةً﴾</span> يعني: سوءا {1}.(ز) (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱقۡضُوۤا۟ إِلَیَّ وَلَا تُنظِرُونِ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿ثم اقضُوا إليَّ﴾</span> قال: انهضوا إلَيَّ، <span class="qpc-hafs">﴿ولا تُنظرونِ﴾</span> يقولُ: ولا تُؤَخِّرُونِ{7}. (٧/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ثم اقضوا إليَّ﴾</span>، قال: ما في أنفسكم{8}. (٧/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٣٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿ثُمَّ اقْضُوا إلَيَّ﴾</span>، يعني: انْهَضُوا إلَيَّ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿ثم اقضوا إلي ولا تنظرون﴾</span>، قال: اقضوا إلَيَّ ما كنتم قاضِين{10}. (٧/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ اقْضُوا إلَيَّ﴾</span> يعني: مِيلوا إلَيَّ، <span class="qpc-hafs">﴿ولا تُنْظِرُونِ﴾</span> يعني: ولا تُمْهِلُون{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٤.|2:أخرجه ابن أبي حاتم ٦/١٩٦٩.|3:أخرجه ابن أبي حاتم ٦/١٩٦٧.|4:تفسير مقاتل بن سليمان ٢/٢٤٤.|5:أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/٢٣٣، وابن أبي حاتم ٦/١٩٦٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٤٤.|7:أخرجه ابن أبي حاتم ٦/١٩٦٩، ١٩٧٠. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير مجاهد ص٣٨٢، وأخرجه ابن جرير ١٢/٢٣٤، وابن أبي حاتم ٦/١٩٧٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|9:تفسير الثعلبي ٥/١٤٢.|10:أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/٢٣٣، وابن أبي حاتم ٦/١٩٧٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|11:تفسير مقاتل بن سليمان ٢/٢٤٤.
  10,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِن تَوَلَّیۡتُمۡ فَمَا سَأَلۡتُكُم مِّنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَى ٱللَّهِۖ وَأُمِرۡتُ أَنۡ أَكُونَ مِنَ ٱلۡمُسۡلِمِینَ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿إن أجري﴾</span>، يقول: جزائي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنْ تَوَلَّيْتُمْ﴾</span> يعني: عَصَيْتُم <span class="qpc-hafs">﴿فَما سَأَلْتُكُمْ مِن أجْرٍ﴾</span> يعني: مِن جُعْلٍ، <span class="qpc-hafs">﴿إنْ أجْرِيَ﴾</span> يعني: ثوابي <span class="qpc-hafs">﴿إلّا عَلى اللَّهِ وأُمِرْتُ أنْ أكُونَ مِنَ المُسْلِمِينَ﴾</span> يعني: مِن المُوَحِّدين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٧٠.|2:تفسير مقاتل بن سليمان ٢/٢٤٤.
  10,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَذَّبُوهُ فَنَجَّیۡنَـٰهُ وَمَن مَّعَهُۥ فِی ٱلۡفُلۡكِ وَجَعَلۡنَـٰهُمۡ خَلَـٰۤىِٕفَ وَأَغۡرَقۡنَا ٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَاۖ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُنذَرِینَ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَكَذَّبُوهُ فَنَجَّيْناهُ ومَن مَعَهُ﴾</span> مِن المؤمنين <span class="qpc-hafs">﴿فِي الفُلْكِ﴾</span> يعني: السفينة، <span class="qpc-hafs">﴿وجَعَلْناهُمْ خَلائِفَ﴾</span> في الأرض مِن بعد نوح، <span class="qpc-hafs">﴿وأَغْرَقْنا الَّذِينَ كَذَّبُوا بِآياتِنا﴾</span> يعني: بنوحٍ وما جاء به، <span class="qpc-hafs">﴿فانْظُرْ﴾</span> يا محمد <span class="qpc-hafs">﴿كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</span> يعني: المُحَذَّرين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٤.
  10,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ بَعَثۡنَا مِنۢ بَعۡدِهِۦ رُسُلًا إِلَىٰ قَوۡمِهِمۡ فَجَاۤءُوهُم بِٱلۡبَیِّنَـٰتِ فَمَا كَانُوا۟ لِیُؤۡمِنُوا۟ بِمَا كَذَّبُوا۟ بِهِۦ مِن قَبۡلُۚ كَذَ ٰ⁠لِكَ نَطۡبَعُ عَلَىٰ قُلُوبِ ٱلۡمُعۡتَدِینَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٣٨<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span> -من طريق أبي العالية- في قوله: <span class="qpc-hafs">﴿ثم بعثنا من بعده رسلا إلى قومهم فجاؤهم بالبينات فما كانوا ليؤمنوا بما كذبوا به من قبل﴾</span>: كان في عِلْمِه يوم أقَرُّوا به مَن يُصَدِّق به ومَن يُكَذِّب به، فكان عيسى ﵇ مِن تلك الأزواج التي أُخِذ عليها العَهْدُ والميثاقُ في زمان آدم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قوله: <span class="qpc-hafs">﴿بما كذبوا به من قبل﴾</span> قولُ الله: <span class="qpc-hafs">﴿ولو ردوا لعادوا لما نهوا عنه﴾</span> [الأنعام:٢٨]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فما كانوا ليؤمنوا بما كذبوا به من قبل﴾</span>، قال: ذلك يوم أُخِذ منهم الميثاقُ آمنوا كرهًا{3}<span class=comment-ref>٣١٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٣٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٠٨) في معنى الآية قولًا آخر، فقال: «يحتمل اللفظ عندي معنًى آخر، وهو أن تكون»ما«مصدرية، والمعنى: فكذبوا رسلهم فكان عقابهم مِن الله أن لم يكونوا ليؤمنوا بتكذيبهم من قبل، أي: من سببه ومن جراه. ويؤيد هذا التأويلَ قولُه: <span class="qpc-hafs">﴿كذلك نطبع﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٣٤٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ بَعَثْنا مِن بَعْدِهِ﴾</span> يعني: من بعد نوح <span class="qpc-hafs">﴿رُسُلًا إلى قَوْمِهِمْ فَجاؤُهُمْ بِالبَيِّناتِ﴾</span>، ثُمَّ أخبر بعلمه فيهم، فقال: <span class="qpc-hafs">﴿فَما كانُوا لِيُؤْمِنُواْ﴾</span> يعني: لِيُصَدِّقوا <span class="qpc-hafs">﴿بِما كَذَّبُوا بِهِ﴾</span> يعني: العذاب <span class="qpc-hafs">﴿مِن قَبْلُ﴾</span> نزول العذاب، <span class="qpc-hafs">﴿كَذَلِكَ نَطْبَعُ﴾</span> يعني: هكذا نَخْتِم <span class="qpc-hafs">﴿عَلى قُلُوبِ المُعْتَدِينَ﴾</span> يعني: الكافرين{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٧٢.|2:أخرجه ابن أبي حاتم ٦/١٩٧٢.|3:أخرجه ابن أبي حاتم ٦/١٩٧٢. وقد ذكر أيضًا هذه الآثار عند تفسير قوله تعالى:<span class="qpc-hafs">﴿ولقد جاءتهم رسلهم بالبينات فما كانوا ليؤمنوا بما كذبوا من قبل كذلك يطبع الله على قلوب الكافرين﴾</span> [الأعراف:١٠١].|4:تفسير مقاتل بن سليمان ٢/٢٤٤.
  10,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ بَعَثۡنَا مِنۢ بَعۡدِهِم مُّوسَىٰ وَهَـٰرُونَ إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦ بِـَٔایَـٰتِنَا فَٱسۡتَكۡبَرُوا۟ وَكَانُوا۟ قَوۡمࣰا مُّجۡرِمِینَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ بَعَثْنا مِن بَعْدِهِمْ﴾</span> مِن بعد الأُمَم <span class="qpc-hafs">﴿مُوسى وهارُونَ إلى فِرْعَوْنَ ومَلائِهِ بِآياتِنا﴾</span> يعني: بعلاماتنا؛ اليد، والعصا، <span class="qpc-hafs">﴿فاسْتَكْبَرُواْ﴾</span> يعني: فتكبّروا عن الإيمان، <span class="qpc-hafs">﴿وكانُوا قَوْمًا مُجْرِمِينَ﴾</span> يعني: كافرين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤٤-٢٤٥.
  10,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَاۤءَهُمُ ٱلۡحَقُّ مِنۡ عِندِنَا قَالُوۤا۟ إِنَّ هَـٰذَا لَسِحۡرࣱ مُّبِینࣱ ۝٧٦ قَالَ مُوسَىٰۤ أَتَقُولُونَ لِلۡحَقِّ لَمَّا جَاۤءَكُمۡۖ أَسِحۡرٌ هَـٰذَا وَلَا یُفۡلِحُ ٱلسَّـٰحِرُونَ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا جاءهم رسولٌ مِن عند الله عارَضُوه، وحاصَروه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا جاءَهُمُ الحَقُّ مِن عِنْدِنا﴾</span> يعني: موسى، وما جاء به من الآيات؛ <span class="qpc-hafs">﴿قالُواْ إنَّ هَذا لَسِحْرٌ مُبِينٌ قالَ مُوسى أتَقُولُونَ لِلْحَقِّ﴾</span> اليد والعصا <span class="qpc-hafs">﴿لَمّا جاءَكُمْ أسِحْرٌ هَذا ولا يُفْلِحُ السّاحِرُونَ﴾</span> في الدنيا والآخرة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٧٣.|2:تفسير مقاتل بن سليمان ٢/٢٤٥.
  10,77,""
  10,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَجِئۡتَنَا لِتَلۡفِتَنَا عَمَّا وَجَدۡنَا عَلَیۡهِ ءَابَاۤءَنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿لتلفتنا﴾</span>، قال: لِتَلْوِيَنا{1}. (٧/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٤٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿لتلفتنا﴾</span>، قال: لِتَصُدَّنا عن آلهتنا{2}. (٧/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُواْ أجِئْتَنا لِتَلْفِتَنا﴾</span> يعني: لِتَصُدَّنا <span class="qpc-hafs">﴿عَمّا وجَدْنا عَلَيْهِ آباءَنا﴾</span> يعني: عما كانت آباؤنا تَعْبُد{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَكُونَ لَكُمَا ٱلۡكِبۡرِیَاۤءُ فِی ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قوله: <span class="qpc-hafs">﴿وتكون لكُما الكبرياء في الأرض﴾</span>، قال: العَظَمَةُ، والمُلْكُ، والسُّلطان{4}<span class=comment-ref>٣١٣٨</span>. (٧/٦٩١)</p></p><p></div></p><p><div><span class=comment-ref>٣١٣٨</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٤/٥١٠): «الكبرياء: مصدر مبالغ مِن الكبر، والمراد به في هذا الموضع: الملك. وكذلك قال فيه مجاهد بن جبر، والضحاك بن مزاحم، وأكثر المتأولين؛ لأنه أعظم تَكَبُّرِ الدنيا».</div></p><p><div></p><p><p><span class="item-no">٣٤٧٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- <span class="qpc-hafs">﴿وتَكُونَ لَكُما الكِبْرِياءُ فِي الأَرْضِ﴾</span>: السلطان في الأرض{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٥٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿وتكون لكما الكبرياء في الأرض﴾</span>، قال: الطّاعة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَكُونَ لَكُما الكِبْرِياءُ﴾</span> يعني: موسى وهارون <span class="qpc-hafs">﴿الكبرياء﴾</span> يعني: الملك <span class="qpc-hafs">﴿فِي الأَرْضِ﴾</span>{3}<span class=comment-ref>٣١٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٣٩</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٢/٢٤١): «هذه الأقوال كلها متقارباتُ المعاني، وذلك أنّ الملك سلطان، والطاعة ملك، غير أنّ معنى الكبرياء هو ما ثبت في كلام العرب، ثم يكون ذلك عَظَمَة بملك، وسلطان، وغير ذلك».</div></p><p><h3><span class="qpc-hafs">﴿وَمَا نَحۡنُ لَكُمَا بِمُؤۡمِنِینَ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧٥٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿بمؤمنين﴾</span>، قال: بمُصَدِّقين{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٧٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما نَحْنُ لَكُما بِمُؤْمِنِينَ﴾</span>، يعني: بمُصَدِّقين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٢٣٩، وابن أبي حاتم ٦/١٩٧٣. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر.|2:أخرجه ابن أبي حاتم ٦/١٩٧٣. وعزاه السيوطي إلى أبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٢٤٥.|4:تفسير مجاهد ص٣٨٢، وأخرجه ابن جرير ١٢/٢٤٠، وابن أبي حاتم ٦/١٩٧٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|5:أخرجه ابن جرير ١٢/٢٤١.|6:أخرجه ابن جرير ١٢/٢٤٠.|7:تفسير مقاتل بن سليمان ٢/٢٤٥.|8:أخرجه ابن أبي حاتم ٦/١٩٧٣.|9:تفسير مقاتل بن سليمان ٢/٢٤٥.