tafsir[10]{c,v,t}:
23,18," <q>﴿وَأَنزَلۡنَا مِنَ ٱلسَّمَاۤءِ مَاۤءَۢ بِقَدَرࣲ فَأَسۡكَنَّـٰهُ فِی ٱلۡأَرۡضِۖ﴾</q> - تفسير ٥١٥١٧- عن ابن عباس، عن النبي ﷺ، قال: «أنزل الله من الجنة إلى الأرض خمسة أنهار: سَيْحون وهو نهر الهند، وجَيْحون وهو نهر بَلَخ، ودجلة والفرات وهما نهرا العراق، والنيل وهو نهر مصر، أنزلها الله مِن عين واحدة مِن عيون الجنة، مِن أسفل درجة من درجاتها، على جناحي جبريل، فاستودعها الجبال، وأجراها في الأرض، وجعلها منافع للناس في أصناف معايشهم، فذلك قوله: <q>﴿وأنزلنا من السماء ماء بقدر فأسكناه في الأرض﴾</q>. فإذا كان عند خروج يأجوج ومأجوج أرسل اللهُ جبريل فيرفع من الأرض: القرآن، والعلم كله، والحَجَر من ركن البيت، ومقام إبراهيم، وتابوت موسى بما فيه، وهذه الأنهار الخمسة، فيرفع كل ذلك إلى السماء، فذلك قوله: <q>﴿وإنا على ذهاب به لقادرون﴾</q>. فإذا رُفِعَت هذه الأشياء مِن الأرض فَقَد أهلُها خيرَ الدنيا والآخرة»{1}. (١٠/٥٨١) ٥١٥١٨- عن عبد الله بن عباس -من طريق الحسن بن مسلم- قوله: <q>﴿وأنزلنا من السماء ماء بقدر﴾</q>، قال: ما عام بأكثر مِن عام مطرًا -أو قال: ما مِن عامٍ-، ولكن الله يُصَرِّفه حيث شاء. وقرأ هذه الآية: <q>﴿ولقد صرفناه بينهم﴾</q> [الفرقان:٥٠]{2}. (ز) ٥١٥١٩- قال محمد بن السائب الكلبي: <q>﴿فأسكناه في الأرض﴾</q> يعني: الأنهار، والعيون، والرَّكِيَّ، يعني: الآبار{3}. (ز) ٥١٥٢٠- قال مقاتل بن سليمان: <q>﴿وأنزلنا من السماء ماء بقدر﴾</q> ما يكفيكم مِن المعيشة، يعني: العيون، <q>﴿فأسكناه﴾</q> يعني: فجعلنا <q>﴿في الأرض﴾</q>{4}. (ز) ٥١٥٢١- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿وأنزلنا من السماء ماء بقدر فأسكناه في الأرض﴾</q>: ماء هو مِن السماء{5}. (ز) ٥١٥٢٢- عن أبي عطّاف، قال: إنّ الله أنزل أربعة أنهار: دجلة، والفرات، وسَيْحون، وجَيْجون، وهو الماء الذي قال الله: <q>﴿وأنزلنا من السماء ماء بقدر﴾</q> الآية{6}٤٥٣٢. (١٠/٥٨٢) ٤٥٣٢ ذكر ابنُ عطية (٦/٢٨٦) أنّ ما ذُكر من كون المراد بالماء: المطر، أو الأنهار الأربعة سيحان وجيحان والفرات والنيل، داخل تحت الماء الذي أنزله الله تعالى. وذكر أنّ مجاهدًا قال: ليس في الأرض ماء إلا وهو من السماء. وانتقده مستندًا للسنة، والواقع بقوله: «ويمكن أن يقيد هذا بالعذْب، وإلاّ فالأُجاج ثابت في الأرض مع القحط، والعذب يقل مع القحط، وأيضًا فالأحاديث تقتضي الماء الذي كان قبل خلق السماوات والأرض، ولا محالة أنّ الله قد جعل في الأرض ماءً، وأنزل من السماء ماء». <q>﴿وَإِنَّا عَلَىٰ ذَهَابِۭ بِهِۦ لَقَـٰدِرُونَ ۝١٨﴾</q> - تفسير ٥١٥٢٣- قال مقاتل بن سليمان: <q>﴿وإنا على ذهاب به لقادرون﴾</q> فيَغُور في الأرض، يعني: فلا يُقْدَرُ عليه{4}. (ز) ٥١٥٢٤- قال يحيى بن سلّام: <q>﴿وإنا على ذهاب به﴾</q> على أن نذهب بذلك الماء <q>﴿لقادرون﴾</q>{8}. (ز) <q>﴿وَإِنَّا عَلَىٰ ذَهَابِۭ بِهِۦ لَقَـٰدِرُونَ ۝١٨﴾</q> - آثار متعلقة بالآية ٥١٥٢٥- عن علي -من طريق عمرو- قال: إنّ هذا الرزق يتنَزَّل مِن السماء كقطر المطر إلى كل نفس بما كتب الله لها{2}. (ز) ",footnotes:1:أخرجه أبو عمرو الداني في السنن الواردة في الفتن ٦/١٢١٧-١٢١٩(٦٧٧)، والخطيب في تاريخه ١/٣٦٣، والواحدي في الوسيط ٣/٢٨٧ (٦٤٦). وعزاه السيوطي إلى ابن مردويه. قال المقدسي في صفة الجنة ص١٠٨: «لا أعلم أنِّي سمعته إلا من طريق مسلمة بن علي، وهو من جملة الضعفاء». وقال ابن كثير في البداية والنهاية ٢٠/٣٠٢: «وهذا حديث غريب جدًّا، بل منكر، ومسلمة بن علي ضعيف الحديث عند الأئمة». وقال السيوطي: «بسند ضعيف». وقال الألباني في الضعيفة ٦/٢٠٦-٢٠٧ (٢٦٨٦): «موضوع».أخرجه يحيى بن سلام ١/٣٩٦.علَّقه يحيى بن سلام ١/٣٩٦.تفسير مقاتل بن سليمان ٣/١٥٣. وأوله في تفسير البغوي ٥/٤١٣ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٧/٢٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٣. وأوله في تفسير البغوي ٥/٤١٣ منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ١/٣٩٦.أخرجه يحيى بن سلام ١/٣٩٦.
23,19," <q>﴿فَأَنشَأۡنَا لَكُم بِهِۦ جَنَّـٰتࣲ مِّن نَّخِیلࣲ وَأَعۡنَـٰبࣲ لَّكُمۡ فِیهَا فَوَ ٰ⁠كِهُ كَثِیرَةࣱ وَمِنۡهَا تَأۡكُلُونَ ۝١٩﴾</q> - تفسير ٥١٥٢٦- عن إسماعيل السُّدِّيّ، <q>﴿فأنشأنا لكم به جنات﴾</q>، قال: هي البساتين{1}. (١٠/٥٨٢) ٥١٥٢٧- قال مقاتل بن سليمان: <q>﴿فأنشأنا﴾</q> يعني: فخلقنا <q>﴿لكم به﴾</q> بالماء <q>﴿جنات﴾</q> يعني: البساتين <q>﴿من نخيل وأعناب لكم فيها فواكه كثيرة ومنها تأكلون﴾</q>{2}. (ز) ٥١٥٢٨- قال يحيى بن سلّام: قوله: <q>﴿فأنشأنا لكم به﴾</q> خلقنا لكم به، أي: أنبتنا لكم به، بذلك الماء <q>﴿جنات من نخيل وأعناب لكم فيها﴾</q> في تلك الجنات <q>﴿فواكه كثيرة﴾</q> يعني: أنواع الفاكهة، <q>﴿ومنها تأكلون﴾</q>{3}٤٥٣٣. (ز) ٤٥٣٣ ذكر ابنُ عطية (٦/٢٨٦) أن الضمير في قوله: <q>﴿لَكُمْ فِيها﴾</q> يحتمل احتمالين: أحدهما: أن يعود على الجنات فيريد حينئذ جميع أنواع الفاكهة. والآخر: أن يعود على النخيل والأعناب خاصة، إذ فيها مراتب وأنواع. ثم رجَّح الأول مستندًا لدلالة العموم، قال: «والأول أعم لسائر الثمرات». <q>﴿فَأَنشَأۡنَا لَكُم بِهِۦ جَنَّـٰتࣲ مِّن نَّخِیلࣲ وَأَعۡنَـٰبࣲ لَّكُمۡ فِیهَا فَوَ ٰ⁠كِهُ كَثِیرَةࣱ وَمِنۡهَا تَأۡكُلُونَ ۝١٩﴾</q> - آثار متعلقة بالآية ٥١٥٢٩- عن عبد الله بن مسعود -من طريق المسعودي- قال: كل النخل ينبت في مُسْتَنقَعِ الماء الأول، إلا العجوة؛ فإنها من الجنة{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٤.تفسير يحيى بن سلام ١/٣٩٧.أخرجه يحيى بن سلام ١/٣٩٦.
23,20," <q>﴿وَشَجَرَةࣰ﴾</q> - تفسير ٥١٥٣٠- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وشجرة تخرج﴾</q>، قال: هي الزيتون{1}. (١٠/٥٨٢) ٥١٥٣١- عن الربيع بن أنس، <q>﴿وشجرة تخرج من طور سيناء﴾</q>، قال: هي الزيتون{2}. (١٠/٥٨٣) ٥١٥٣٢- قال مقاتل بن سليمان: ثم قال: <q>﴿و﴾</q>خلقنا <q>﴿شجرة﴾</q> يعني: الزيتون، وهو أول زيتونة خُلِقت{3}. (ز) ٥١٥٣٣- قال يحيى بن سلّام: قوله: <q>﴿وشجرة تخرج من طور سيناء﴾</q>، وهي الزيتونة{4}. (ز) <q>﴿تَخۡرُجُ مِن طُورِ سَیۡنَاۤءَ﴾</q> - قراءات ٥١٥٣٤- عن عاصم أنّه قرأ: <q>﴿مِن طُورِ سَيْنَآءَ﴾</q> بنصب السين، ممدودة، مهموزة الألف{5}٤٥٣٤. (١٠/٥٨٤) ٤٥٣٤ اختُلِف في قراءة: <q>﴿سيناء﴾</q>؛ فقرأ قوم بفتح السين، وقرأ آخرون بكسرها. ورجَّح ابنُ جرير (١٧/٢٩) صحة كلتا القراءتين لشهرتهما، واتحاد معناهما، فقال: «والصواب مِن القول في ذلك: أنهما قراءتان معروفتان في قرأة الأمصار بمعنًى واحد، فبأيتهما قرأ القارئ فمصيب». وذكر ابنُ عطية (٦/٢٨٧) أنه على فتح السين لا ينصرف الاسم بوجه، وعلى كسرها فالهمزة كهمزة حرباء. <q>﴿تَخۡرُجُ مِن طُورِ سَیۡنَاۤءَ﴾</q> - تفسير الآية ٥١٥٣٥- عن عبد الله بن عباس -من طريق عطاء الخراساني- قال: طور سيناء هو الجبل الذي نُودِي منه موسى{6}. (١٠/٥٨٢) ٥١٥٣٦- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وشجرة تخرج من طور سيناء﴾</q>، قال: هو جَبَل بالشام مبارك{7}٤٥٣٥. (ز) ٤٥٣٥ علَّق ابنُ جرير (١٧/٢٩) على هذا القول الذي قاله ابن عباس، ومجاهد، فقال: «كأنّ معنى الكلام عنده: وشجرة تخرج من جبل مبارك». ٥١٥٣٧- عن مجاهد بن جبر، قال: الطور: الجبل. وسيناء: الحجارة. وفي لفظ: وسيناء: الشجر{8}. (١٠/٥٨٣) ٥١٥٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿من طور سيناء﴾</q>، قال: المبارك{9}. (١٠/٥٨٣) ٥١٥٣٩- قال يحيى بن سلّام: وقال ابن مجاهد، عن أبيه: سيناء: المبارك، أي: الجبل المبارك؛ طور سينين{4}. (ز) ٥١٥٤٠- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿من طور سيناء﴾</q>، قال: الطور: الجبل، بالنبطية. وسيناء بالنبطية: الحسن{11}. (١٠/٥٨٢) ٥١٥٤١- عن عكرمة مولى ابن عباس: هو بالحبشية{12}. (ز) ٥١٥٤٢- قال عكرمة مولى ابن عباس: هو اسم المكان الذي فيه هذا الجبل{12}. (ز) ٥١٥٤٣- عن عطية العوفي، قال: سيناء اسم أرض{2}. (١٠/٥٨٣) ٥١٥٤٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿من طور سيناء﴾</q>، قال: جبل حسن{15}. (١٠/٥٨٢) ٥١٥٤٥- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿طور سيناء﴾</q>، قال: الجبل الذي نُودِي فيه موسى{16}. (ز) ٥١٥٤٦- عن محمد بن السائب الكلبي -من طريق مَعْمَر- <q>﴿طور سيناء﴾</q>، قال: جبل ذو شجر{17}. (١٠/٥٨٣) ٥١٥٤٧- قال مقاتل بن سليمان: <q>﴿تخرج من طور سيناء﴾</q>، يقول: تنبت في أصل الجبل الذي كلم الله ﷿ عليه موسى ﵇ ...، وكل جبل يحمل الثمار فهو سيناء، يعني: الحسن{18}. (ز) ٥١٥٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿طور سيناء﴾</q>، قال: هو جبل الطور الذي بالشام؛ جبل ببيت المقدس. قال: ممدود، هو بين مصر وبين أيْلة{19}. (ز) ٥١٥٤٩- قال يحيى بن سلّام: يعني: جبل بيت المقدس{4}٤٥٣٦. (ز) ٤٥٣٦ اختُلِف في معنى سيناء في قوله تعالى: <q>﴿طور سيناء﴾</q> على أقوال: الأول: المبارك. الثاني: حسن. الثالث: جبل ذو شجر. الرابع: اسم جبل معروف. ورجَّح ابنُ جرير (١٧/٣١ بتصرف) القول الرابع الذي قاله ابن عباس من طريق عطاء الخراساني، وابن زيد. وانتقد مستندًا للغة القولَ الأول الذي قاله ابن عباس من طريق العوفي، ومجاهد، والثاني الذي قاله قتادة، والضحاك، فقال: «والصواب من القول في ذلك أن يُقال: إنّ سيناء اسم أضيف إليه الطور يُعرَف به، كما قيل جبلا طيء، فأضيفا إلى طيء، ولكن القول في ذلك -إن شاء الله- كما قال ابن عباس مِن أنه جبل عُرِف بذلك، وأنه الجبل الذي نودي منه موسى ﷺ، وهو مع ذلك مبارك، لا أنّ معنى سيناء معنى مبارك». ثم قال: «ولو كان القول في ذلك كما قال مَن قال: معناه: جبل مبارك، أو كما قال مَن قال: معناه: حسن؛ لكان الطور مُنَوَّنًا، وكان قوله: <q>﴿سيناء﴾</q> مِن نعته. على أن سيناء بمعنى: مبارك وحسن، غير معروف في كلام العرب، فيجعل ذلك من نعت الجبل». وانتقدها ابنُ عطية كذلك بنحو كلام ابن جرير (٦/٢٨٧-٢٨٧). <q>﴿تَنۢبُتُ بِٱلدُّهۡنِ وَصِبۡغࣲ لِّلۡـَٔاكِلِینَ ۝٢٠﴾</q> - قراءات ٥١٥٥٠- عن الحسن البصري -من طريق عمرو- (تُنبَتُ بِالدُّهْنِ)= (ز) ٥١٥٥١- وهي في قراءة ابن مسعود: (تُخْرِجُ الدُّهْنَ){21}. (ز) ٥١٥٥٢- عن عاصم أنه قرأ: <q>﴿تَنْبُتُ﴾</q> بنصب التاء، ورفع الباء{8}. (١٠/٥٨٤) ٥١٥٥٣- عن سليمان بن عبد الملك أنّه كان يقرأ: <q>﴿تَنْبُتُ بالدهن﴾</q> بنصب التاء، ورفع الباء{23}٤٥٣٧. (١٠/٥٨٤) ٤٥٣٧ اختُلِف في قراءة قوله: <q>﴿تنبت﴾</q>؛ فقرأ قوم: <q>﴿تنبت﴾</q> بفتح التاء، وقرأ آخرون: ‹تُنبِتُ› بضم التاء. وذكر ابنُ جرير (١٧/٣١) أنّ الأولى بمعنى: تنبت هذه الشجرة بثمر الدهن، وأن الثانية بمعنى: تنبت الدهن: تخرجه. ثم قال (١٧/٣٢): «والقول عندي في ذلك أنهما لغتان: نبت، وأنبت». ثم رجَّح قراءة الفتح مستندًا إلى إجماع القراء، فقال: «غير أنّ ذلك وإن كان كذلك فإنّ القراءة التي لا أختار غيرها في ذلك قراءة من قرأ: <q>﴿تنبت﴾</q> بفتح التاء، لإجماع الحجة مِن القَرأَة عليها». وذكر ابنُ عطية (٦/٢٨٧) أن القراءة الثانية لها تقديران: أحدهما: أنّ الباء زائدة. وذكر أنّ الفارسي مثَّل له بقوله تعالى: <q>﴿ولا تلقوا بأيديكم إلى التهلكة﴾</q> [البقرة:٩٥]، ثم علَّق بقوله: «وهذا المثال عندي معترض». والآخر: تنبت جناها ومعه الدهن، والمفعول محذوف. <q>﴿تَنۢبُتُ بِٱلدُّهۡنِ وَصِبۡغࣲ لِّلۡـَٔاكِلِینَ ۝٢٠﴾</q> - تفسير الآية ٥١٥٥٤- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿تنبت بالدهن﴾</q>، قال: هو الزيت يُؤكَل، ويُدَّهَنُ به{24}. (١٠/٥٨٤) ٥١٥٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿تنبت بالدهن﴾</q>، قال: تُثْمِر الزيت{9}. (١٠/٥٨٣) ٥١٥٥٦- عن قتادة بن دعامة، في قوله: <q>﴿تنبت بالدهن وصبغ للآكلين﴾</q>، قال: جعل الله فيها دُهْنًا وأَدَمًا{26}. (١٠/٥٨٢) ٥١٥٥٧- عن إسماعيل السُّدِّيّ، <q>﴿وشجرة تخرج﴾</q> الآية، قال: هي شجرة الزيتون تنبت بالزيت، فهو دُهْن يدهن به، وهو صِبْغٌ للآكلين يأكله الناس{2}. (١٠/٥٨٣) ٥١٥٥٨- قال مقاتل بن سليمان: <q>﴿تنبت بالدهن﴾</q> يعني: تخرج بالذي فيه الدهن، يقول: هذه الشجرة تشرب الماء، وتخرج الزيت، فجعل الله ﷿ في هذه الشجرة أدمًا ودهنًا، <q>﴿و﴾</q>هي <q>﴿صبغ للآكلين﴾</q>{3}. (ز) ٥١٥٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تنبت بالدهن وصبغ للآكلين﴾</q>، قال: هذه الزيتون صِبْغ للآكلين، يأتَدِمُون به، ويَصْطَبِغون به{29}. (١٠/٥٨٤) <q>﴿تَنۢبُتُ بِٱلدُّهۡنِ وَصِبۡغࣲ لِّلۡـَٔاكِلِینَ ۝٢٠﴾</q> - آثار متعلقة بالآية ٥١٥٦٠- عن زيد بن أسلم، قال: قال رسول الله ﷺ: «الزيت شجرة مباركة؛ فأْتَدِموا به، وادَّهِنوا»{30}. (ز) ٥١٥٦١- عن مالك بن دينار، قال: حدَّثني مَن رأى عامر بن عبد قيس دعا بزيت، فصَبَّه في يده، -كذا وصف جعفر- ومسح إحداهما على الأخرى، ثم قال: <q>﴿وشجرة تخرج من طور سيناء تنبت بالدهن وصبغ للآكلين﴾</q>، قال: فدهن رأسه ولحيته{31}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٤.تفسير يحيى بن سلام ١/٣٩٧.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا نافعًا، وأبا جعفر، وابن كثير، وأبا عمرو؛ فإنهم قرؤوا: ‹سِينَآءَ› بكسر السين. انظر: النشر ٢/٣٢٨، والإتحاف ص٤٠٢.أخرجه ابن جرير ١٧/٣٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٢٩.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣٩٧ من طريق ابن مجاهد، وابن جرير ١٧/٢٩، ٣٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ١/٣٩٧.أخرجه ابن جرير ١٧/٣٠، وإسحاق البستي في تفسيره ص٣٩٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٤١٤.تفسير البغوي ٥/٤١٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٥، وابن جرير ١٧/٢٩-٣٠. وعلقه يحيى بن سلام ١/٣٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص٩٧ (تفسير عطاء الخراساني).أخرجه عبد الرزاق ٢/٤٥، وابن جرير ١٧/٣١ عن معمر عمَّن قاله، كذا مبهمًا. وعزاه السيوطي إلى ابن المنذر. وهو في تفسير الثعلبي ٧/٤٤ موقوف على معمر من قوله.تفسير مقاتل بن سليمان ٣/١٥٤. وفي تفسير البغوي ٥/٤١٤: قال مقاتل: كل جبل فيه أشجار مثمرة فهو سيناء، وسينين بلغة النبط.أخرجه ابن جرير ١٧/٣٠.تفسير يحيى بن سلام ١/٣٩٧.أخرجه إسحاق البستي في تفسيره ص٣٩٣. وكلتاهما شاذة، تروى أولاهما عن الزهري، والأعرج أيضًا، وقراءة ابن مسعود بلفظ: (يُخْرِجُ) عند ابن خالويه. انظر: مختصر ابن خالويه ص٩٩، والمحتسب ٢/٨٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا ابن كثير، وأبا عمرو، ورويس؛ فإنهم قرؤوا: ‹تُنبِتُ› بضم التاء وكسر الباء. انظر: النشر ٢/٣٢٩، والإتحاف ص٤٠٣.أخرجه ابن جرير ١٧/٣٣، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٩٧ من طريق ابن مجاهد، وابن جرير ١٧/٢٩، ٣٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٥ من طريق معمر بلفظ: الزيتون. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٤.أخرجه ابن جرير ١٧/٣٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٩٧، والترمذي ٤/ ٢٨٥ (١٨٥١) عن زيد بن أسلم، عن أبيه، عن عمر بلفظ: كلوا الزيت، وادَّهِنوا به؛ فإنّه مِن شجرة مباركة. قال ابن كثير ٦/١١٩: «رواه الترمذي وابن ماجه مِن غير وجه، عن عبد الرزاق. قال الترمذي: ولا يعرف إلا من حديثه، وكان يضطرب فيه، فربما ذكر فيه عمر، وربما لم يذكره».أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٩/٣٤٣-٣٤٤ (٣٦٢٦٠).
23,21," <q>﴿وَإِنَّ لَكُمۡ فِی ٱلۡأَنۡعَـٰمِ لَعِبۡرَةࣰۖ نُّسۡقِیكُم مِّمَّا فِی بُطُونِهَا وَلَكُمۡ فِیهَا مَنَـٰفِعُ كَثِیرَةࣱ وَمِنۡهَا تَأۡكُلُونَ ۝٢١﴾</q> - تفسير ٥١٥٦٢- عن مجاهد بن جبر، <q>﴿وإن لكم في الانعام﴾</q> قال: الإبل، والبقر، والضأن، والمعز، <q>﴿ولكم فيها منافع﴾</q> قال: ما تُنتِج، ومنها مركب ولبن ولحم{1}. (١٠/٥٨٤) ٥١٥٦٣- قال مقاتل بن سليمان: <q>﴿وإن لكم في الأنعام﴾</q> يعني: الإبل، والبقرة، والغنم <q>﴿لعبرة نسقيكم مما في بطونها﴾</q> يعني: اللبن، <q>﴿ولكم فيها منافع كثيرة﴾</q> يعني: في ظهورها، وألبانها، وأوبارها، وأصوافها، وأشعارها، <q>﴿ومنها تأكلون﴾</q> يعني: مِن النعم{2}. (ز) ٥١٥٦٤- قال يحيى بن سلّام: قوله: <q>﴿وإن لكم في الأنعام لعبرة﴾</q> لآية، <q>﴿نسقيكم مما في بطونها﴾</q> يعني: اللبن، <q>﴿ولكم فيها منافع كثيرة﴾</q> في ألبانها، وظهورها، وكل ما ينتفع به منها، <q>﴿ومنها تأكلون﴾</q> يعني: لحومها{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٤.تفسير يحيى بن سلام ١/٣٩٧.
23,22," <q>﴿وَعَلَیۡهَا وَعَلَى ٱلۡفُلۡكِ تُحۡمَلُونَ ۝٢٢﴾</q> - تفسير ٥١٥٦٥- عن أبي صالح [باذام]، في قوله: <q>﴿وعلى الفلك﴾</q>، قال: السُّفُن{1}. (١٠/٥٨٥) ٥١٥٦٦- قال مقاتل بن سليمان: في قوله تعالى: <q>﴿وعليها﴾</q> يعني: الإبل <q>﴿وعلى الفلك تحملون﴾</q> على ظهورها في أسفاركم، ففي هذا الذي ذُكِر مِن هؤلاء الآيات عبرة في توحيد الرب ﷿{2}. (ز) ٥١٥٦٧- قال يحيى بن سلّام: قوله: <q>﴿وعليها﴾</q> أي: وعلى الإبل، <q>﴿وعلى الفلك﴾</q> السفن <q>﴿تحملون﴾</q>، وقد يُقال: إنّها سُفُن البر. وقد قال في آية أخرى: <q>﴿وآية لهم أنا حملنا ذريتهم في الفلك المشحون (٤١) وخلقنا لهم من مثله ما يركبون﴾</q> [يس:٤١-٤٢]، وقال في آية أخرى: <q>﴿وجعل لكم من الفلك والأنعام ما تركبون﴾</q> [الزخرف:١٢]{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٤.تفسير يحيى بن سلام ١/٣٩٧.
23,23," <q>﴿وَلَقَدۡ أَرۡسَلۡنَا نُوحًا إِلَىٰ قَوۡمِهِۦ فَقَالَ یَـٰقَوۡمِ ٱعۡبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنۡ إِلَـٰهٍ غَیۡرُهُۥۤۚ أَفَلَا تَتَّقُونَ ۝٢٣﴾</q> - تفسير ٥١٥٦٨- قال مقاتل بن سليمان: <q>﴿ولقد أرسلنا نوحا إلى قومه فقال يا قوم اعبدوا الله﴾</q> يعني: وحِّدوا الله، <q>﴿ما لكم من إله غيره﴾</q> ليس لكم رب غيره، <q>﴿أفلا تتقون﴾</q> يقول: أفلا تعبدون الله ﷿{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٤.
23,24," <q>﴿فَقَالَ ٱلۡمَلَؤُا۟ ٱلَّذِینَ كَفَرُوا۟ مِن قَوۡمِهِۦ مَا هَـٰذَاۤ إِلَّا بَشَرࣱ مِّثۡلُكُمۡ یُرِیدُ أَن یَتَفَضَّلَ عَلَیۡكُمۡ وَلَوۡ شَاۤءَ ٱللَّهُ لَأَنزَلَ مَلَـٰۤىِٕكَةࣰ مَّا سَمِعۡنَا بِهَـٰذَا فِیۤ ءَابَاۤىِٕنَا ٱلۡأَوَّلِینَ ۝٢٤﴾</q> - تفسير ٥١٥٦٩- قال مقاتل بن سليمان: <q>﴿فقال الملأ﴾</q> يعني: الأشراف <q>﴿الذين كفروا من قومه ما هذا﴾</q> يعنون: نوحًا <q>﴿إلا بشر مثلكم﴾</q> ليس له عليكم فضل في شيء فتتبعونه، <q>﴿يريد﴾</q> نوح <q>﴿أن يتفضل عليكم ولو شاء الله لأنزل﴾</q> يعني: لأرسل <q>﴿ملائكة﴾</q> إلينا، فكانوا رُسُلَه، <q>﴿ما سمعنا بهذا﴾</q> التوحيد <q>﴿في آبآئنا الأولين﴾</q>{1}. (ز) ٥١٥٧٠- قال يحيى بن سلّام: قوله: <q>﴿فقال الملأ الذين كفروا من قومه ما هذا إلا بشر مثلكم﴾</q> يقوله بعضهم لبعض، <q>﴿يريد أن يتفضل عليكم﴾</q> بالرسالة، وما له عليكم مِن فَضْل، <q>﴿ولو شاء الله لأنزل ملائكة﴾</q> ولو أنزل ملائكة لآمَنّا، <q>﴿ما سمعنا بهذا في آبائنا الأولين﴾</q> أنّ رجلًا ادَّعى النُّبُوَّة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٤.تفسير يحيى بن سلام ١/٣٩٨.
23,25," <q>﴿إِنۡ هُوَ إِلَّا رَجُلُۢ بِهِۦ جِنَّةࣱ فَتَرَبَّصُوا۟ بِهِۦ حَتَّىٰ حِینࣲ ۝٢٥﴾</q> - تفسير ٥١٥٧١- قال مقاتل بن سليمان: <q>﴿إن هو﴾</q> يعنون: نوحًا <q>﴿إلا رجل به جنة﴾</q> يعني: جُنونًا، <q>﴿فتربصوا به حتى حين﴾</q> يعنون: الموت{1}. (ز) ٥١٥٧٢- قال يحيى بن سلّام: <q>﴿إن هو إلا رجل به جنة﴾</q> جنون، <q>﴿فتربصوا به حتى حين﴾</q> قال بعضهم: حتى يموت. وقال بعضهم: حتى يستبين جُنونه{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٥.تفسير يحيى بن سلام ١/٣٩٨.
23,26," <q>﴿قَالَ رَبِّ ٱنصُرۡنِی بِمَا كَذَّبُونِ ۝٢٦﴾</q> - تفسير ٥١٥٧٣- قال مقاتل بن سليمان: <q>﴿قال﴾</q> نوح: <q>﴿رب انصرني بما كذبون﴾</q> يقول: انصرني بتحقيق قولي في العذاب بأنّه نازِل بهم في الدنيا{1}. (ز) ٥١٥٧٤- قال يحيى بن سلّام: <q>﴿قال﴾</q> نوح: <q>﴿رب انصرني بما كذبون﴾</q>. وقال في آية أخرى: <q>﴿مغلوب فانتصر﴾</q> [القمر:١٠]{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٥.تفسير يحيى بن سلام ١/٣٩٨.
23,27," <q>﴿فَأَوۡحَیۡنَاۤ إِلَیۡهِ أَنِ ٱصۡنَعِ ٱلۡفُلۡكَ بِأَعۡیُنِنَا وَوَحۡیِنَا﴾</q> - تفسير ٥١٥٧٥- قال مقاتل بن سليمان: <q>﴿فأوحينا إليه أن اصنع الفلك﴾</q> يقول: اجعل السفينة <q>﴿بأعيننا ووحينا﴾</q> كما نأمرك{1}. (ز) <q>﴿فَإِذَا جَاۤءَ أَمۡرُنَا وَفَارَ ٱلتَّنُّورُ﴾</q> - تفسير ٥١٥٧٦- قال مقاتل بن سليمان: <q>﴿فإذا جاء أمرنا﴾</q> يقول ﷿: فإذا جاء قولُنا في نزول العذاب بهم في الدنيا، يعني: الغرق، <q>﴿وفار﴾</q> الماء مِن <q>﴿التنور﴾</q>، وكان التَّنُّور في أقصى مكان مِن دار نوح، وهو التَّنُّور الذي يُخبَز فيه، وكان في الشام بعَيْنِ ورْدَة{2}{3}٤٥٣٨٤٥٣٩. (ز) ٤٥٣٨ قال ابنُ عطية (٦/٢٩٠): «وقوله: <q>﴿أمْرُنا﴾</q> يحتمل أن يكون مصدرًا بمعنى: أن نأمر الماء بالفيض. ويحتمل أن يريد: واحد الأمور، أي: إهلاكنا للكفرة». ٤٥٣٩ رجَّح ابنُ عطية (٦/٢٩٠) أن التنور هو تنور الخبز، فقال: «والصحيح من الأقوال فيه: أنه تنور الخبز، وأنها أمارة كانت بين الله تعالى وبين نوح ﵇». ولم يذكر مستندًا. <q>﴿فَٱسۡلُكۡ فِیهَا مِن كُلࣲّ زَوۡجَیۡنِ ٱثۡنَیۡنِ وَأَهۡلَكَ إِلَّا مَن سَبَقَ عَلَیۡهِ ٱلۡقَوۡلُ مِنۡهُمۡۖ وَلَا تُخَـٰطِبۡنِی فِی ٱلَّذِینَ ظَلَمُوۤا۟ إِنَّهُم مُّغۡرَقُونَ ۝٢٧﴾</q> - تفسير ٥١٥٧٧- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿فاسلك فيها﴾</q>، يقول: اجعل معك في السفينة مِن كل زوجين اثنين{4}. (١٠/٥٨٥) ٥١٥٧٨- قال الحسن البصري: لم يحمل نوحٌ في السفينة إلّا مَن يلِد ويبيض، وأمّا ما يَتَوَلَّد مِن الطير من حشرات الأرض والبَقِّ والبعوض فلم يحمل منها شيئًا{5}. (ز) ٥١٥٧٩- قال مقاتل بن سليمان: <q>﴿فاسلك فيها من كل زوجين اثنين﴾</q> ذكر وأنثى، <q>﴿وأهلك﴾</q> فاحملهم معك في السفينة، ثم استثنى من الأهل <q>﴿إلا من سبق عليه القول منهم﴾</q> يعني: مَن سبقت عليهم كلمة العذاب، فكان ابنه وامرأته مِمَّن سبق عليه القول من أهله، ثم قال تعالى: <q>﴿ولا تخاطبني﴾</q> يقول: ولا تراجعني <q>﴿في الذين ظلموا﴾</q> يعني: أشركوا، <q>﴿إنهم مغرقون﴾</q> يعني بقوله: <q>﴿ولا تخاطبني﴾</q>: قول نوح ﵇ لربه ﷿: <q>﴿إن ابني من أهلي﴾</q> [هود:٤٥]، يقول الله: ولا تراجعني في ابنك كنعان؛ فإنّه من الذين ظلموا{1}. (ز) ٥١٥٨٠- قال يحيى بن سلّام: قوله: <q>﴿فاسلك فيها﴾</q> أي: فاحمل فيها <q>﴿من كل زوجين اثنين﴾</q> من كل صنفين اثنين. قوله: <q>﴿وأهلك﴾</q> أي: واحمل فيها أهلك، <q>﴿إلا من سبق عليه القول منهم﴾</q> ابنه الذي غرق. والقول: الغضب. <q>﴿ولا تخاطبني﴾</q> أي: ولا تراجعني <q>﴿في الذين ظلموا إنهم مغرقون﴾</q>{7}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٥.عين ورْدَة: موضع بالشام، وكان مكان دار نوح فيه. تفسير الثعلبي ٥/١٦٩.تفسير مقاتل بن سليمان ٣/١٥٥. وقد تقدمت الآثار في معنى التنور عند تفسير قوله تعالى: <q>﴿حَتّى إذا جاءَ أمْرُنا وفارَ التَّنُّورُ قُلْنا احْمِلْ فِيها مِن كُلٍّ زَوْجَيْنِ اثْنَيْنِ﴾</q> [هود:٤٠].أخرجه ابن جرير ١٧/٣٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٧/٤٦. وتقدم أيضًا عند آية سورة هود آثار السلف فيما أُمر نوح ﵇ بحمله معه.تفسير مقاتل بن سليمان ٣/١٥٥.تفسير يحيى بن سلام ١/٣٩٨-٣٩٩.
