quran[5]{c,v,t}:
  6,147,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِن كَذَّبُوكَ فَقُل رَّبُّكُمۡ ذُو رَحۡمَةࣲ وَ ٰ⁠سِعَةࣲ وَلَا یُرَدُّ بَأۡسُهُۥ عَنِ ٱلۡقَوۡمِ ٱلۡمُجۡرِمِینَ ۝١٤٧﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فإن كذبوك﴾</span>، قال: اليهود{1}. (٦/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: كانت اليهودُ يقولون: إنّما حرَّمه إسرائيل فنحن نُحَرِّمُه. فذلك قوله: <span class="qpc-hafs">﴿فإن كذبوك فقل ربكم﴾</span> الآية{2}. (٦/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: هذا ما أوحى الله إلى نبيه ﷺ أنّه مُحَرَّم؛ منه على المسلمين، ومنه على اليهود، فقال كفار العرب للنبي ﷺ: فإنّك لم تُصِب. يقول الله: <span class="qpc-hafs">﴿فإن كذبوك﴾</span> بما تقول من التحريم فقل لكُفّار مكة: <span class="qpc-hafs">﴿ربكم ذو رحمة واسعة﴾</span>، ملأت رحمتُه كلَّ شيء، لا يعجل عليكم بالعقوبة، <span class="qpc-hafs">﴿ولا يرد بأسه﴾</span> يقول: عذابه إذا جاء الوقت على مَن كذَّب بما يقول <span class="qpc-hafs">﴿عن القوم المجرمين﴾</span> يعني: كفار العرب{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٤٨، وابن أبي حاتم ٥/١٤١٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٦٤٨، وابن أبي حاتم ٥/١٤١٢.تفسير مقاتل بن سليمان ١/٥٩٥-٥٩٦.
  6,148,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَیَقُولُ ٱلَّذِینَ أَشۡرَكُوا۟ لَوۡ شَاۤءَ ٱللَّهُ مَاۤ أَشۡرَكۡنَا وَلَاۤ ءَابَاۤؤُنَا وَلَا حَرَّمۡنَا مِن شَیۡءࣲۚ كَذَ ٰ⁠لِكَ كَذَّبَ ٱلَّذِینَ مِن قَبۡلِهِمۡ حَتَّىٰ ذَاقُوا۟ بَأۡسَنَاۗ قُلۡ هَلۡ عِندَكُم مِّنۡ عِلۡمࣲ فَتُخۡرِجُوهُ لَنَاۤۖ إِن تَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَإِنۡ أَنتُمۡ إِلَّا تَخۡرُصُونَ ۝١٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿لوشاء الله ما أشركنا ولا آباؤنا﴾</span>، وقال: <span class="qpc-hafs">﴿كذلك كذب الذين من قبلهم﴾</span>، ثم قال: <span class="qpc-hafs">﴿ولو شاء الله ما أشركوا﴾</span> [الأنعام:١٠٧]، فإنهم قالوا: عبادتنا الآلهة تُقَرِّبنا إلى الله زُلْفى. فأخبرهم الله أنّها لا تقربهم. وقوله: <span class="qpc-hafs">﴿ولوشاء الله ما أشركوا﴾</span> يقول الله سبحانه: لو شئتُ لجمعتهم على الهدى أجمعين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سيقول الذين أشركوا لو شاء الله﴾</span> الآية، قال: هذا قولُ قريش: إنّ الله حرَّم هذا. يَعنون: البحيرة، والسائبة، والوصيلة، والحام{2}. (٦/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سيقول الذين أشركوا﴾</span> مع الله آلهةً، يعني: مشركي العرب: <span class="qpc-hafs">﴿لو شاء الله ما أشركنا ولا﴾</span> أشرك <span class="qpc-hafs">﴿آباؤنا ولا حرمنا من شيء﴾</span> يعني: الحرث والأنعام، ولكنَّ الله أمر بتحريمه، <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿كذب الذين من قبلهم﴾</span> من الأمم الخالية رسلَهم، كما كذَّب كفارُ مكة بمحمد ﷺ <span class="qpc-hafs">﴿حتى ذاقوا بأسنا﴾</span> يعني: عذابنا، <span class="qpc-hafs">﴿قل هل عندكم من علم فتخرجوه لنا﴾</span> يعني: بيانًا من الله بتحريمه فتُبَيِّنوه لنا، يقول الله: <span class="qpc-hafs">﴿إن تتبعون إلا الظن وإن أنتم إلا تخرصون﴾</span> الكذب{3}<span class=comment-ref>٢٤٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٢٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٣/٤٨٦) أن بعض المفسرين قال: إن هذه المقالة من المشركين على جهة الاستهزاء. و<span class="comment-type-2">انتقده</span> بقوله: «وهذا ضعيف».</div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٦٥٠، وابن أبي حاتم ٥/١٤١٢ مختصرًا.تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٥٠، وابن أبي حاتم ٥/١٤١٢، والبيهقي في الأسماء والصفات (٣٧٨). وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٩٦.
  6,149,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ فَلِلَّهِ ٱلۡحُجَّةُ ٱلۡبَـٰلِغَةُۖ فَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝١٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٢٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿قل فلله الحجة البالغة﴾</span>، قال: السلطان{1}. (٦/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٢٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- قال: لا حُجَّة لأحد عصى الله، ولكن لله الحجة البالغة على عباده. وقال الله: <span class="qpc-hafs">﴿فلو شاء لهداكم أجمعين﴾</span>. قال: <span class="qpc-hafs">﴿لا يسأل عما يفعل وهم يسألون﴾</span> [الأنبياء:٢٣]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لهم، يا محمد: <span class="qpc-hafs">﴿فلله الحجة البالغة فلو شاء لهداكم أجمعين﴾</span> لدينه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ فَلِلَّهِ ٱلۡحُجَّةُ ٱلۡبَـٰلِغَةُۖ فَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝١٤٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- أنّه قيل له: إنّ ناسًا يقولون: ليس الشرُّ بقَدَر. فقال ابن عباس: بينَنا وبين أهل القدر هذه الآية: <span class="qpc-hafs">﴿سيقول الذين أشركوا لو شاء الله ما أشركنا﴾</span> إلى قوله: <span class="qpc-hafs">﴿قل فلله الحجة البالغة فلو شاء لهداكم أجمعين﴾</span>. قال ابن عباس: والعجزُ والكَيْسُ من القَدَر{4}. (٦/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٣٠<span class="dash">-</span></span> عن <span class="name-2">علي بن زيد</span>، قال: انقَطَعَت حُجَّةُ القدرية عند هذه الآية: <span class="qpc-hafs">﴿قل فلله الحجة البالغة فلو شاء لهداكم أجمعين﴾</span>{1}. (٦/٢٥٠)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٥٣، وابن أبي حاتم ٥/١٤١٣.تفسير مقاتل بن سليمان ١/٥٩٦.أخرجه عبد الرزاق في مصنفه (٢٠٠٧٣)، وابن أبي حاتم ٥/١٤١٢-١٤١٣ كلاهما دون آخره، والحاكم ٢/٣١٧، والبيهقي في الأسماء والصفات (٣٨٠). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.عزاه السيوطي إلى أبي الشيخ.
  6,150,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ هَلُمَّ شُهَدَاۤءَكُمُ ٱلَّذِینَ یَشۡهَدُونَ أَنَّ ٱللَّهَ حَرَّمَ هَـٰذَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿الذين يشهدون أن الله حرم هذا﴾</span>، قال: البحائِرَ، والسَّوائب{1}. (٦/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿هلم شهداءكم الذين يشهدون أن الله حرم هذا﴾</span>، يقول: قل: أروني الذين يشهدون أنّ الله حرَّم هذا مما حَرَّمت العرب، وقالوا: أمرنا الله به. قال الله لرسوله: <span class="qpc-hafs">﴿فإن شهدوا فلا تشهد معهم﴾</span>{2}. (٦/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل هلم شهداءكم الذين يشهدون أن الله حرم هذا﴾</span> الحرثَ، والأنعام{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِن شَهِدُوا۟ فَلَا تَشۡهَدۡ مَعَهُمۡۚ وَلَا تَتَّبِعۡ أَهۡوَاۤءَ ٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا وَٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ وَهُم بِرَبِّهِمۡ یَعۡدِلُونَ ۝١٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن شهدوا﴾</span> أنّ الله حرمه <span class="qpc-hafs">﴿فلا تشهد معهم﴾</span> يأمر نبيه ﷺ أن لا يصدق قولهم، <span class="qpc-hafs">﴿ولا تتبع أهواء الذين كذبوا بآياتنا﴾</span> يعني: القرآن الذي فيه تحليل ما حرموا، <span class="qpc-hafs">﴿والذين لا يؤمنون بالآخرة﴾</span> يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال، <span class="qpc-hafs">﴿و﴾</span> الذين <span class="qpc-hafs">﴿هم بربهم يعدلون﴾</span> يعني: يُشرِكون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٦٥٦، وابن أبي حاتم ٥/١٤١٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٥٥، وابن أبي حاتم ٥/١٤١٣.تفسير مقاتل بن سليمان ١/٥٩٦.تفسير مقاتل بن سليمان ١/٥٩٦.
  6,151,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ تَعَالَوۡا۟ أَتۡلُ مَا حَرَّمَ رَبُّكُمۡ عَلَیۡكُمۡۖ أَلَّا تُشۡرِكُوا۟ بِهِۦ شَیۡـࣰٔاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل تعالوا أتل ما حرم ربكم عليكم﴾</span> يقول: تعالوا حتى أقرأ ما حرَّم عليكم: <span class="qpc-hafs">﴿ألا تشركوا به شيئا﴾</span> مِن خلقه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبِٱلۡوَ ٰ⁠لِدَیۡنِ إِحۡسَـٰنࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبالوالدين إحسانا﴾</span>، يعني بِرًّا بهما{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٣٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿وبالوالدين إحسانا﴾</span>، قال: قولوا صِدقًا فيما أمركم به، وفيما أمركم به من حقِّ الوالدين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوۤا۟ أَوۡلَـٰدَكُم مِّنۡ إِمۡلَـٰقࣲ نَّحۡنُ نَرۡزُقُكُمۡ وَإِیَّاهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ولا تقتلوا أولادكم من إملاق﴾</span>، قال: خشية الفقر{4}<span class=comment-ref>٢٤٣٠</span>. (٦/٢٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٣٠</span> ذكر <u>ابنُ عطية</u> (٣/٤٩١) أنّ الإملاق: «الفقر وعدم المال... يقال: أملق الرجل إذا افتقر». ونسبه لابن عباس وغيره، ثم <span class="comment-type-4">علَّق</span> بقوله: «ويشبه أن يكون معناه: أمْلَق، أي: لم يبق له إلا المَلَق، كما قالوا: أتْرَبَ إذا لم يبق له إلا التراب، وأَرْمَلَ إذا لم يبق له إلا الرمل». ثم نقل <b>أقوالًا</b> أخرى، فقال: «والمَلَق: الحجارة السود. واحدته: مَلَقَة، وذكر منذر بن سعيد أنّ الإملاق: الإنفاق، ويقال: أمْلَق ماله، بمعنى: أنفقه، وذُكِرَ أنّ عليًّا قال لامرأة: أمْلقي من مالك ما شئت. وذكر النقاش عن محمد بن نعيم الترمذي أنّه: السرف في الإنفاق، وحكى أيضًا النقاش عن مُؤَرِّجٍ أنه قال: الإملاق: الجوع، بلغة لخم».</div></p><p><div></p><p><p><span class="item-no">٢٦٦٣٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿من إملاق﴾</span>، يعني: من خشية فقر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان بن عبد الرحمن- <span class="qpc-hafs">﴿ولا تقتلوا أولادكم من إملاق﴾</span>، قال: من خشية الفاقَة. قال: وكان أهل الجاهلية يقتُلُ أحدُهم ابنتَه مخافة الفاقة عليها والسِّباءِ{6}. (٦/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولا تقتلوا أولادكم من إملاق﴾</span>، قال: الإملاق: الفقر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقتلوا أولادكم﴾</span> يعني: دفن البنات وهُنَّ أحياء <span class="qpc-hafs">﴿من إملاق﴾</span> يعني: خشية الفقر، <span class="qpc-hafs">﴿نحن نرزقكم وإياهم﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿من إملاق﴾</span>، قال: شياطينهم يأمرونهم أن يَئِدوا أولادَهم خيفة العَيْلَة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوا۟ ٱلۡفَوَ ٰ⁠حِشَ مَا ظَهَرَ مِنۡهَا وَمَا بَطَنَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٤٤<span class="dash">-</span></span> عن عمران بن حصين، أنّ رسول الله ﷺ قال: «<b>أرأَيتُم الزاني والسارق وشارب الخمر، ما تقولون فيهم؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>هُنَّ فواحش، وفيهِنَّ عقوبة</b>»{10}. (٦/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٥<span class="dash">-</span></span> عن أبي حازم الرهاويّ، أنّه سمِع مولاه يقول: كان رسول الله ﷺ يقول: «<b>مسألة الناس من الفواحش</b>»{11}. (٦/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها﴾</span> قال: نكاح الأمهات والبنات، <span class="qpc-hafs">﴿وما بطن﴾</span> قال: الزِّنا{12}. (٦/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، نحو شطره الأول{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٨<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٤٩<span class="dash">-</span></span> و<span class="name-2">محمد بن قيس</span>، نحو شطره الثاني{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها﴾</span> قال: العلانية، <span class="qpc-hafs">﴿وما بطن﴾</span> قال: السِّرّ{15}. (٦/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٢<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٣<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٤<span class="dash">-</span></span> و<span class="name-2">عطاء الخرساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٥<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>، نحو شطره الثاني{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>، قال: كانوا في الجاهلية لا يَرون بالزِّنا بأسًا في السِّرِّ، ويَسْتَقبِحُونه في العلانية، فحرَّم الله الزِّنا في السر والعلانية{17}. (٦/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٧<span class="dash">-</span></span> عن <span class="name-2">علي بن حسين</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٨<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٥٩<span class="dash">-</span></span> و<span class="name-2">أبي صالح باذام</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦١<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span> = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٢<span class="dash">-</span></span> و<span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٣<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>، نحو ذلك{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٤<span class="dash">-</span></span> عن <span class="name-2">علي بن حسين</span> -من طريق عمرو بن ثابت، عن أبيه- <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>، قال: ما بطن: نكاح امرأة الأب{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿الفواحش﴾</span>، يعني: الزِّنا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span> قال: ما ظهر: جمع بين الأختين، وتزويج الرجل امرأة أبيه من بعده، <span class="qpc-hafs">﴿وما بطن﴾</span>: الزنا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> في قوله:<span class="qpc-hafs">﴿ما ظهر﴾</span> نكاح الأمهات{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عيسى بن أبي حفصة- يقول في قوله: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>، قال: <span class="qpc-hafs">﴿ما ظهر﴾</span>: الخمر. <span class="qpc-hafs">﴿وما بطن﴾</span>: الزنا{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٦٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قوله: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>: كان أهل الجاهلية يَسْتَسِرُّون بالزنا، ويرون ذلك حلالًا ما كان سِرًّا، فحرَّم الله السِّرَّ منه والعلانية، <span class="qpc-hafs">﴿ما ظهر منها﴾</span> يعني: العلانية، <span class="qpc-hafs">﴿وما بطن﴾</span> يعني: السر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عثمان بن غياث- في قوله: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها﴾</span> قال: ظلم الناس، <span class="qpc-hafs">﴿وما بطن﴾</span> قال: الزِّنا، والسرقة{25}. (٦/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٢<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>، قال: سِرّها، وعلانيتها{27}. (٦/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿الفواحش ما ظهر منها﴾</span>، قال: العُرِيُّ، وكانوا يطوفون بالبيت عُراة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>: أمّا <span class="qpc-hafs">﴿ما ظهر منها﴾</span> فزواني الحوانيت، وأما <span class="qpc-hafs">﴿ما بطن﴾</span> فما خفي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن قيس</span> -من طريق أبي معشر- في قول الله تعالى: <span class="qpc-hafs">﴿ولا تقربوا الفواحش﴾</span>، قال: كانوا يمشون حول البيت عُراة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٧<span class="dash">-</span></span> عن <span class="name-3">يحيى بن جابر</span> -من طريق سليمان بن سليم- قال: بلغني: أنّ من الفواحش التي نهى الله عنها في كتابه تزويجُ الرجل المرأة، فإذا نَفَضَتْ له ولدَها طلَّقها من غير رِيبة{20}. (٦/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقربوا الفواحش﴾</span> يعني: الزنا؛ <span class="qpc-hafs">﴿ما ظهر منها﴾</span> يعني: السِّفاح علانية، <span class="qpc-hafs">﴿وما بطن﴾</span> يعني: الزِّنا في السِّر، تتخذ الخليلَ فيأتيها في السِّرِّ{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٧٩<span class="dash">-</span></span> عن <span class="name-3">معمر بن راشد</span>، في قوله تعالى: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span>، قال: سرها، وعلانيتها{33}<span class=comment-ref>٢٤٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٣١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٦٥٩)، و<u>ابنُ عطية</u> (٣/٤٩١) <span class="mustanad">استنادًا إلى دلالة العموم</span> قول قتادة من طريق سعيد أنّ معنى: <span class="qpc-hafs">﴿ما ظَهَرَ مِنها وما بَطَنَ﴾</span>، أي: علانيتها وسرها؛ لكون النهيِ عامًّا عن جميع أنواع الفواحش، ولأنّ <span class="qpc-hafs">﴿ظَهَرَ﴾</span> و<span class="qpc-hafs">﴿بَطَنَ﴾</span> حالتان تستوفيان أقسام ما جُعلَتْ له من الأشياء.</p><p>وبيَّن <u>ابنُ جرير</u> أنّ مَن خصَّص المعنى ببعض الفواحش ليس بمدفوعٍ صحته، غير أنه <span class="comment-type-2">انتَقَده</span> بقوله: «أنّ دليل الظاهر من التنزيل على النهي عن ظاهر كلِّ فاحشةٍ وباطنها، ولا خبرَ يَقْطَع العذر بأنّه عُنِي به بعضٌ دون جميع، وغير جائزٍ إحالة ظاهر كتاب الله إلى باطنٍ إلا بحجةٍ يجب التسليم لها». ووافقه <u>ابنُ عطية</u> مُبَيِّنًا أنّ هذا التخصيص «لا تقوم عليه حجة، بل هو دعوى مُجَرَّدة».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٨٠<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>لا يَحِلُّ دمُ امرئ مسلم يشهد أن لا إله إلا الله وأنِّي رسول الله إلا بإحدى ثلاث: الثيب الزاني، والنفس بالنفس، والتارك لدينه المفارق للجماعة</b>»{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ولا تقتلوا النفس﴾</span> يعني: نفس المؤمن <span class="qpc-hafs">﴿التي حرم الله﴾</span> قتلَها <span class="qpc-hafs">﴿إلا بالحق﴾</span>{19}. (٦/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقتلوا النفس التي حرم الله﴾</span> قتلها <span class="qpc-hafs">﴿إلا بالحق﴾</span> يعني: بالقصاص، والثيب الزاني بالرجم، والمرتد عن الإسلام، فهذا الحق{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُمۡ وَصَّىٰكُم بِهِۦ لَعَلَّكُمۡ تَعۡقِلُونَ ۝١٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلكم وصاكم به لعلكم﴾</span> يعني: لكي <span class="qpc-hafs">﴿تعقلون﴾</span> أنّه لم يُحَرِّم إلا ما ذكر في هذه الآيات الثلاث، ولم يُحَرِّم البحيرة، والسائبة، والوصيلة، والحام{32}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٥٩٦.تفسير مقاتل بن سليمان ١/٥٩٦.أخرجه ابن أبي حاتم ٥/١٤١٤.أخرجه ابن جرير ٩/٦٥٨، وابن أبي حاتم ٥/١٤١٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٩/٦٥٩.أخرجه ابن جرير ٩/٦٥٨ من طريق سعيد، وابن أبي حاتم ٥/١٤١٥. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٦٥٨.تفسير مقاتل بن سليمان ١/٥٩٦-٥٩٧.أخرجه ابن جرير ٩/٦٥٩.أخرجه الحارث في مسنده ١/١٧٦ (٢٩)، والطبراني في الكبير ١٨/١٤٠ (٢٩٣)، وابن أبي حاتم ٥/١٤١٥ (٨٠٦١)، ٥/١٤٦٠-١٤٦١ (٨٣٥٥) واللفظ له.</p><p>قال البيهقي في السنن الكبرى ٨/٣٦٤ (١٦٩٠١): «تفرَّد به عمر بن سعيد الدمشقي، وهو منكر الحديث، وإنما يعرف من حديث النعمان بن مرة مرسلًا». وقال الهيثمي في المجمع ١/١٠٣ (٣٨٤): «رواه الطبراني في الكبير، ورجاله ثقات، إلا أنّ الحسن مُدَلِّس وعنعنه».أخرجه ابن أبي حاتم ٥/١٤١٥ (٨٠٦٢)، ٥/١٤٦٩ (٨٤٠٨).</p><p>قال العراقي في تخريج أحاديث الإحياء ص١٥٦٤ (٣): «لم أجد له أصلًا». وقال الشوكاني في الفوائد المجموعة ص٦٥ (١٦): «قال في المختصر: لم يوجد». وقال الفتني في تذكرة الموضوعات ص٦٢: «لم يوجد».أخرجه ابن أبي حاتم ٥/١٤١٦-١٤١٧. وعزاه السيوطي إلى ابن مردويه.علَّقه ابن أبي حاتم ٥/١٤١٦. وعزاه ابن حجر في الفتح ٨/٣٠٢ إلى ابن جرير.علَّقه ابن أبي حاتم ٥/١٤١٧.عزاه السيوطي إلى ابن المنذر. وأخرج ابن أبي حاتم ٥/١٤١٦ شطره الثاني.علَّقه ابن أبي حاتم ٥/١٤١٦.أخرجه ابن جرير ٩/٦٦٠، وابن أبي حاتم ٥/١٤١٦. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.علَّقه ابن أبي حاتم ٥/١٤١٦.أخرجه ابن أبي حاتم ٥/١٤١٧.أخرجه ابن أبي حاتم ٥/١٤١٥.أخرجه ابن جرير ٩/٦٦١، وابن أبي حاتم ٥/١٤١٦ بلفظ: أمّا <span class="qpc-hafs">﴿ما ظهر منها﴾</span> فقوله: <span class="qpc-hafs">﴿ولا تنكحوا ما نكح آباؤكم﴾</span> [النساء:٢٢]، وقوله: <span class="qpc-hafs">﴿وأن تجمعوا بين الأختين﴾</span> [النساء:٢٣]".عزاه ابن حجر في الفتح ٨/٣٠٢ إلى ابن جرير.أخرجه ابن جرير ٩/٦٦١.أخرجه ابن جرير ٩/٦٠٥.أخرجه ابن أبي حاتم ٥/١٤١٦-١٤١٧. وعزاه السيوطي إلى أبي الشيخ.علَّقه ابن أبي حاتم ٥/١٤١٥.أخرجه ابن جرير ٩/٦٦٠. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤١٦.أخرجه ابن جرير ٩/٦٥٩.أخرجه ابن أبي حاتم ٥/١٤١٥.أخرجه ابن أبي حاتم ٥/١٤١٥.تفسير مقاتل بن سليمان ١/٥٩٧.أخرجه عبد الرزاق ٢/٢٢١.أخرجه البخاري ٩/٥ (٦٨٧٨)، ومسلم ٣/١٣٠٢-١٣٠٣ (١٦٧٦) واللفظ له.أخرجه ابن أبي حاتم ٥/١٤١٧.تفسير مقاتل بن سليمان ١/٥٩٧.تفسير مقاتل بن سليمان ١/٥٩٧.