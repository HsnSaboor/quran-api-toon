tafsir[5]{c,v,t}:
6,147," <q>﴿فَإِن كَذَّبُوكَ فَقُل رَّبُّكُمۡ ذُو رَحۡمَةࣲ وَ ٰ⁠سِعَةࣲ وَلَا یُرَدُّ بَأۡسُهُۥ عَنِ ٱلۡقَوۡمِ ٱلۡمُجۡرِمِینَ ۝١٤٧﴾</q> - نزول الآية، وتفسيرها ٢٦٦٢٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فإن كذبوك﴾</q>، قال: اليهود{1}. (٦/٢٤٨) ٢٦٦٢١- عن إسماعيل السدي -من طريق أسباط- قال: كانت اليهودُ يقولون: إنّما حرَّمه إسرائيل فنحن نُحَرِّمُه. فذلك قوله: <q>﴿فإن كذبوك فقل ربكم﴾</q> الآية{2}. (٦/٢٤٩) ٢٦٦٢٢- قال مقاتل بن سليمان: هذا ما أوحى الله إلى نبيه ﷺ أنّه مُحَرَّم؛ منه على المسلمين، ومنه على اليهود، فقال كفار العرب للنبي ﷺ: فإنّك لم تُصِب. يقول الله: <q>﴿فإن كذبوك﴾</q> بما تقول من التحريم فقل لكُفّار مكة: <q>﴿ربكم ذو رحمة واسعة﴾</q>، ملأت رحمتُه كلَّ شيء، لا يعجل عليكم بالعقوبة، <q>﴿ولا يرد بأسه﴾</q> يقول: عذابه إذا جاء الوقت على مَن كذَّب بما يقول <q>﴿عن القوم المجرمين﴾</q> يعني: كفار العرب{3}. (ز) ",footnotes:1:تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٤٨، وابن أبي حاتم ٥/١٤١٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٦٤٨، وابن أبي حاتم ٥/١٤١٢.تفسير مقاتل بن سليمان ١/٥٩٥-٥٩٦.
6,148," <q>﴿سَیَقُولُ ٱلَّذِینَ أَشۡرَكُوا۟ لَوۡ شَاۤءَ ٱللَّهُ مَاۤ أَشۡرَكۡنَا وَلَاۤ ءَابَاۤؤُنَا وَلَا حَرَّمۡنَا مِن شَیۡءࣲۚ كَذَ ٰ⁠لِكَ كَذَّبَ ٱلَّذِینَ مِن قَبۡلِهِمۡ حَتَّىٰ ذَاقُوا۟ بَأۡسَنَاۗ قُلۡ هَلۡ عِندَكُم مِّنۡ عِلۡمࣲ فَتُخۡرِجُوهُ لَنَاۤۖ إِن تَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَإِنۡ أَنتُمۡ إِلَّا تَخۡرُصُونَ ۝١٤٨﴾</q> - تفسير ٢٦٦٢٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: <q>﴿لوشاء الله ما أشركنا ولا آباؤنا﴾</q>، وقال: <q>﴿كذلك كذب الذين من قبلهم﴾</q>، ثم قال: <q>﴿ولو شاء الله ما أشركوا﴾</q> [الأنعام:١٠٧]، فإنهم قالوا: عبادتنا الآلهة تُقَرِّبنا إلى الله زُلْفى. فأخبرهم الله أنّها لا تقربهم. وقوله: <q>﴿ولوشاء الله ما أشركوا﴾</q> يقول الله سبحانه: لو شئتُ لجمعتهم على الهدى أجمعين{1}. (ز) ٢٦٦٢٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سيقول الذين أشركوا لو شاء الله﴾</q> الآية، قال: هذا قولُ قريش: إنّ الله حرَّم هذا. يَعنون: البحيرة، والسائبة، والوصيلة، والحام{2}. (٦/٢٤٩) ٢٦٦٢٥- قال مقاتل بن سليمان: <q>﴿سيقول الذين أشركوا﴾</q> مع الله آلهةً، يعني: مشركي العرب: <q>﴿لو شاء الله ما أشركنا ولا﴾</q> أشرك <q>﴿آباؤنا ولا حرمنا من شيء﴾</q> يعني: الحرث والأنعام، ولكنَّ الله أمر بتحريمه، <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿كذب الذين من قبلهم﴾</q> من الأمم الخالية رسلَهم، كما كذَّب كفارُ مكة بمحمد ﷺ <q>﴿حتى ذاقوا بأسنا﴾</q> يعني: عذابنا، <q>﴿قل هل عندكم من علم فتخرجوه لنا﴾</q> يعني: بيانًا من الله بتحريمه فتُبَيِّنوه لنا، يقول الله: <q>﴿إن تتبعون إلا الظن وإن أنتم إلا تخرصون﴾</q> الكذب{3}٢٤٢٩. (ز) ٢٤٢٩ ذكر ابنُ عطية (٣/٤٨٦) أن بعض المفسرين قال: إن هذه المقالة من المشركين على جهة الاستهزاء. وانتقده بقوله: «وهذا ضعيف». ",footnotes:1:أخرجه ابن جرير ٩/٦٥٠، وابن أبي حاتم ٥/١٤١٢ مختصرًا.تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٥٠، وابن أبي حاتم ٥/١٤١٢، والبيهقي في الأسماء والصفات (٣٧٨). وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٩٦.
6,149," <q>﴿قُلۡ فَلِلَّهِ ٱلۡحُجَّةُ ٱلۡبَـٰلِغَةُۖ فَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝١٤٩﴾</q> - تفسير ٢٦٦٢٦- عن عكرمة مولى ابن عباس: <q>﴿قل فلله الحجة البالغة﴾</q>، قال: السلطان{1}. (٦/٢٥٠) ٢٦٦٢٧- عن الربيع بن أنس -من طريق أبي جعفر الرازي- قال: لا حُجَّة لأحد عصى الله، ولكن لله الحجة البالغة على عباده. وقال الله: <q>﴿فلو شاء لهداكم أجمعين﴾</q>. قال: <q>﴿لا يسأل عما يفعل وهم يسألون﴾</q> [الأنبياء:٢٣]{2}. (ز) ٢٦٦٢٨- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لهم، يا محمد: <q>﴿فلله الحجة البالغة فلو شاء لهداكم أجمعين﴾</q> لدينه{3}. (ز) <q>﴿قُلۡ فَلِلَّهِ ٱلۡحُجَّةُ ٱلۡبَـٰلِغَةُۖ فَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝١٤٩﴾</q> - آثار متعلقة بالآية ٢٦٦٢٩- عن عبد الله بن عباس -من طريق طاووس- أنّه قيل له: إنّ ناسًا يقولون: ليس الشرُّ بقَدَر. فقال ابن عباس: بينَنا وبين أهل القدر هذه الآية: <q>﴿سيقول الذين أشركوا لو شاء الله ما أشركنا﴾</q> إلى قوله: <q>﴿قل فلله الحجة البالغة فلو شاء لهداكم أجمعين﴾</q>. قال ابن عباس: والعجزُ والكَيْسُ من القَدَر{4}. (٦/٢٤٩) ٢٦٦٣٠- عن علي بن زيد، قال: انقَطَعَت حُجَّةُ القدرية عند هذه الآية: <q>﴿قل فلله الحجة البالغة فلو شاء لهداكم أجمعين﴾</q>{1}. (٦/٢٥٠) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٥٣، وابن أبي حاتم ٥/١٤١٣.تفسير مقاتل بن سليمان ١/٥٩٦.أخرجه عبد الرزاق في مصنفه (٢٠٠٧٣)، وابن أبي حاتم ٥/١٤١٢-١٤١٣ كلاهما دون آخره، والحاكم ٢/٣١٧، والبيهقي في الأسماء والصفات (٣٨٠). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.عزاه السيوطي إلى أبي الشيخ.
6,150," <q>﴿قُلۡ هَلُمَّ شُهَدَاۤءَكُمُ ٱلَّذِینَ یَشۡهَدُونَ أَنَّ ٱللَّهَ حَرَّمَ هَـٰذَاۖ﴾</q> - تفسير ٢٦٦٣١- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿الذين يشهدون أن الله حرم هذا﴾</q>، قال: البحائِرَ، والسَّوائب{1}. (٦/٢٥٠) ٢٦٦٣٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿هلم شهداءكم الذين يشهدون أن الله حرم هذا﴾</q>، يقول: قل: أروني الذين يشهدون أنّ الله حرَّم هذا مما حَرَّمت العرب، وقالوا: أمرنا الله به. قال الله لرسوله: <q>﴿فإن شهدوا فلا تشهد معهم﴾</q>{2}. (٦/٢٥٠) ٢٦٦٣٣- قال مقاتل بن سليمان: <q>﴿قل هلم شهداءكم الذين يشهدون أن الله حرم هذا﴾</q> الحرثَ، والأنعام{3}. (ز) <q>﴿فَإِن شَهِدُوا۟ فَلَا تَشۡهَدۡ مَعَهُمۡۚ وَلَا تَتَّبِعۡ أَهۡوَاۤءَ ٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا وَٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ وَهُم بِرَبِّهِمۡ یَعۡدِلُونَ ۝١٥٠﴾</q> - تفسير ٢٦٦٣٤- قال مقاتل بن سليمان: <q>﴿فإن شهدوا﴾</q> أنّ الله حرمه <q>﴿فلا تشهد معهم﴾</q> يأمر نبيه ﷺ أن لا يصدق قولهم، <q>﴿ولا تتبع أهواء الذين كذبوا بآياتنا﴾</q> يعني: القرآن الذي فيه تحليل ما حرموا، <q>﴿والذين لا يؤمنون بالآخرة﴾</q> يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال، <q>﴿و﴾</q> الذين <q>﴿هم بربهم يعدلون﴾</q> يعني: يُشرِكون{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٩/٦٥٦، وابن أبي حاتم ٥/١٤١٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٥٥، وابن أبي حاتم ٥/١٤١٣.تفسير مقاتل بن سليمان ١/٥٩٦.تفسير مقاتل بن سليمان ١/٥٩٦.
6,151," <q>﴿قُلۡ تَعَالَوۡا۟ أَتۡلُ مَا حَرَّمَ رَبُّكُمۡ عَلَیۡكُمۡۖ أَلَّا تُشۡرِكُوا۟ بِهِۦ شَیۡـࣰٔاۖ﴾</q> - تفسير ٢٦٦٣٥- قال مقاتل بن سليمان: <q>﴿قل تعالوا أتل ما حرم ربكم عليكم﴾</q> يقول: تعالوا حتى أقرأ ما حرَّم عليكم: <q>﴿ألا تشركوا به شيئا﴾</q> مِن خلقه{1}. (ز) <q>﴿وَبِٱلۡوَ ٰ⁠لِدَیۡنِ إِحۡسَـٰنࣰاۖ﴾</q> - تفسير ٢٦٦٣٦- قال مقاتل بن سليمان: <q>﴿وبالوالدين إحسانا﴾</q>، يعني بِرًّا بهما{1}. (ز) ٢٦٦٣٧- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- في قول الله: <q>﴿وبالوالدين إحسانا﴾</q>، قال: قولوا صِدقًا فيما أمركم به، وفيما أمركم به من حقِّ الوالدين{3}. (ز) <q>﴿وَلَا تَقۡتُلُوۤا۟ أَوۡلَـٰدَكُم مِّنۡ إِمۡلَـٰقࣲ نَّحۡنُ نَرۡزُقُكُمۡ وَإِیَّاهُمۡۖ﴾</q> - تفسير ٢٦٦٣٨- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿ولا تقتلوا أولادكم من إملاق﴾</q>، قال: خشية الفقر{4}٢٤٣٠. (٦/٢٥٤) ٢٤٣٠ ذكر ابنُ عطية (٣/٤٩١) أنّ الإملاق: «الفقر وعدم المال... يقال: أملق الرجل إذا افتقر». ونسبه لابن عباس وغيره، ثم علَّق بقوله: «ويشبه أن يكون معناه: أمْلَق، أي: لم يبق له إلا المَلَق، كما قالوا: أتْرَبَ إذا لم يبق له إلا التراب، وأَرْمَلَ إذا لم يبق له إلا الرمل». ثم نقل أقوالًا أخرى، فقال: «والمَلَق: الحجارة السود. واحدته: مَلَقَة، وذكر منذر بن سعيد أنّ الإملاق: الإنفاق، ويقال: أمْلَق ماله، بمعنى: أنفقه، وذُكِرَ أنّ عليًّا قال لامرأة: أمْلقي من مالك ما شئت. وذكر النقاش عن محمد بن نعيم الترمذي أنّه: السرف في الإنفاق، وحكى أيضًا النقاش عن مُؤَرِّجٍ أنه قال: الإملاق: الجوع، بلغة لخم». ٢٦٦٣٩- عن الضحاك بن مُزاحِم -من طريق عبيد بن سليمان- في قوله: <q>﴿من إملاق﴾</q>، يعني: من خشية فقر{5}. (ز) ٢٦٦٤٠- عن قتادة بن دعامة -من طريق شيبان بن عبد الرحمن- <q>﴿ولا تقتلوا أولادكم من إملاق﴾</q>، قال: من خشية الفاقَة. قال: وكان أهل الجاهلية يقتُلُ أحدُهم ابنتَه مخافة الفاقة عليها والسِّباءِ{6}. (٦/٢٥٤) ٢٦٦٤١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولا تقتلوا أولادكم من إملاق﴾</q>، قال: الإملاق: الفقر{7}. (ز) ٢٦٦٤٢- قال مقاتل بن سليمان: <q>﴿ولا تقتلوا أولادكم﴾</q> يعني: دفن البنات وهُنَّ أحياء <q>﴿من إملاق﴾</q> يعني: خشية الفقر، <q>﴿نحن نرزقكم وإياهم﴾</q>{8}. (ز) ٢٦٦٤٣- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿من إملاق﴾</q>، قال: شياطينهم يأمرونهم أن يَئِدوا أولادَهم خيفة العَيْلَة{5}. (ز) <q>﴿وَلَا تَقۡرَبُوا۟ ٱلۡفَوَ ٰ⁠حِشَ مَا ظَهَرَ مِنۡهَا وَمَا بَطَنَۖ﴾</q> - تفسير ٢٦٦٤٤- عن عمران بن حصين، أنّ رسول الله ﷺ قال: «أرأَيتُم الزاني والسارق وشارب الخمر، ما تقولون فيهم؟». قالوا: الله ورسوله أعلم. قال: «هُنَّ فواحش، وفيهِنَّ عقوبة»{10}. (٦/٢٥٤) ٢٦٦٤٥- عن أبي حازم الرهاويّ، أنّه سمِع مولاه يقول: كان رسول الله ﷺ يقول: «مسألة الناس من الفواحش»{11}. (٦/٢٥٥) ٢٦٦٤٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿ولا تقربوا الفواحش ما ظهر منها﴾</q> قال: نكاح الأمهات والبنات، <q>﴿وما بطن﴾</q> قال: الزِّنا{12}. (٦/٢٥٥) ٢٦٦٤٧- عن سعيد بن جبير، نحو شطره الأول{13}. (ز) ٢٦٦٤٨- عن محمد ابن شهاب الزهري= (ز) ٢٦٦٤٩- ومحمد بن قيس، نحو شطره الثاني{14}. (ز) ٢٦٦٥٠- عن عبد الله بن عباس -من طريق عطاء- في قوله: <q>﴿ولا تقربوا الفواحش ما ظهر منها﴾</q> قال: العلانية، <q>﴿وما بطن﴾</q> قال: السِّرّ{15}. (٦/٢٥٤) ٢٦٦٥١- عن عكرمة مولى ابن عباس= (ز) ٢٦٦٥٢- وقتادة بن دعامة= (ز) ٢٦٦٥٣- وإسماعيل السُّدِّيّ= (ز) ٢٦٦٥٤- وعطاء الخرساني= (ز) ٢٦٦٥٥- والربيع بن أنس، نحو شطره الثاني{16}. (ز) ٢٦٦٥٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>، قال: كانوا في الجاهلية لا يَرون بالزِّنا بأسًا في السِّرِّ، ويَسْتَقبِحُونه في العلانية، فحرَّم الله الزِّنا في السر والعلانية{17}. (٦/٢٥٤) ٢٦٦٥٧- عن علي بن حسين= (ز) ٢٦٦٥٨- وعكرمة مولى ابن عباس= (ز) ٢٦٦٥٩- وأبي صالح باذام= (ز) ٢٦٦٦٠- وقتادة بن دعامة= (ز) ٢٦٦٦١- وإسماعيل السُّدِّيّ = (ز) ٢٦٦٦٢- وعطاء الخراساني= (ز) ٢٦٦٦٣- والربيع بن أنس، نحو ذلك{16}. (ز) ٢٦٦٦٤- عن علي بن حسين -من طريق عمرو بن ثابت، عن أبيه- <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>، قال: ما بطن: نكاح امرأة الأب{19}. (ز) ٢٦٦٦٥- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿الفواحش﴾</q>، يعني: الزِّنا{20}. (ز) ٢٦٦٦٦- عن مجاهد بن جبر -من طريق خُصَيف- <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q> قال: ما ظهر: جمع بين الأختين، وتزويج الرجل امرأة أبيه من بعده، <q>﴿وما بطن﴾</q>: الزنا{21}. (ز) ٢٦٦٦٧- عن مجاهد بن جبر في قوله:<q>﴿ما ظهر﴾</q> نكاح الأمهات{22}. (ز) ٢٦٦٦٨- عن الضحاك بن مزاحم -من طريق عيسى بن أبي حفصة- يقول في قوله: <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>، قال: <q>﴿ما ظهر﴾</q>: الخمر. <q>﴿وما بطن﴾</q>: الزنا{23}. (ز) ٢٦٦٦٩- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- قوله: <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>: كان أهل الجاهلية يَسْتَسِرُّون بالزنا، ويرون ذلك حلالًا ما كان سِرًّا، فحرَّم الله السِّرَّ منه والعلانية، <q>﴿ما ظهر منها﴾</q> يعني: العلانية، <q>﴿وما بطن﴾</q> يعني: السر{24}. (ز) ٢٦٦٧٠- عن عكرمة مولى ابن عباس -من طريق عثمان بن غياث- في قوله: <q>﴿ولا تقربوا الفواحش ما ظهر منها﴾</q> قال: ظلم الناس، <q>﴿وما بطن﴾</q> قال: الزِّنا، والسرقة{25}. (٦/٢٥٥) ٢٦٦٧١- عن الضحاك بن مزاحم= (ز) ٢٦٦٧٢- وإسماعيل السُّدِّيّ، نحو ذلك{26}. (ز) ٢٦٦٧٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>، قال: سِرّها، وعلانيتها{27}. (٦/٢٥٤) ٢٦٦٧٤- عن محمد ابن شهاب الزهري -من طريق يونس- في قوله: <q>﴿الفواحش ما ظهر منها﴾</q>، قال: العُرِيُّ، وكانوا يطوفون بالبيت عُراة{28}. (ز) ٢٦٦٧٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>: أمّا <q>﴿ما ظهر منها﴾</q> فزواني الحوانيت، وأما <q>﴿ما بطن﴾</q> فما خفي{5}. (ز) ٢٦٦٧٦- عن محمد بن قيس -من طريق أبي معشر- في قول الله تعالى: <q>﴿ولا تقربوا الفواحش﴾</q>، قال: كانوا يمشون حول البيت عُراة{20}. (ز) ٢٦٦٧٧- عن يحيى بن جابر -من طريق سليمان بن سليم- قال: بلغني: أنّ من الفواحش التي نهى الله عنها في كتابه تزويجُ الرجل المرأة، فإذا نَفَضَتْ له ولدَها طلَّقها من غير رِيبة{20}. (٦/٢٥٥) ٢٦٦٧٨- قال مقاتل بن سليمان: <q>﴿ولا تقربوا الفواحش﴾</q> يعني: الزنا؛ <q>﴿ما ظهر منها﴾</q> يعني: السِّفاح علانية، <q>﴿وما بطن﴾</q> يعني: الزِّنا في السِّر، تتخذ الخليلَ فيأتيها في السِّرِّ{32}. (ز) ٢٦٦٧٩- عن معمر بن راشد، في قوله تعالى: <q>﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</q>، قال: سرها، وعلانيتها{33}٢٤٣١. (ز) ٢٤٣١ رجَّح ابنُ جرير (٩/٦٥٩)، وابنُ عطية (٣/٤٩١) استنادًا إلى دلالة العموم قول قتادة من طريق سعيد أنّ معنى: <q>﴿ما ظَهَرَ مِنها وما بَطَنَ﴾</q>، أي: علانيتها وسرها؛ لكون النهيِ عامًّا عن جميع أنواع الفواحش، ولأنّ <q>﴿ظَهَرَ﴾</q> و<q>﴿بَطَنَ﴾</q> حالتان تستوفيان أقسام ما جُعلَتْ له من الأشياء. وبيَّن ابنُ جرير أنّ مَن خصَّص المعنى ببعض الفواحش ليس بمدفوعٍ صحته، غير أنه انتَقَده بقوله: «أنّ دليل الظاهر من التنزيل على النهي عن ظاهر كلِّ فاحشةٍ وباطنها، ولا خبرَ يَقْطَع العذر بأنّه عُنِي به بعضٌ دون جميع، وغير جائزٍ إحالة ظاهر كتاب الله إلى باطنٍ إلا بحجةٍ يجب التسليم لها». ووافقه ابنُ عطية مُبَيِّنًا أنّ هذا التخصيص «لا تقوم عليه حجة، بل هو دعوى مُجَرَّدة». <q>﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۚ﴾</q> - تفسير ٢٦٦٨٠- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «لا يَحِلُّ دمُ امرئ مسلم يشهد أن لا إله إلا الله وأنِّي رسول الله إلا بإحدى ثلاث: الثيب الزاني، والنفس بالنفس، والتارك لدينه المفارق للجماعة»{34}. (ز) ٢٦٦٨١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿ولا تقتلوا النفس﴾</q> يعني: نفس المؤمن <q>﴿التي حرم الله﴾</q> قتلَها <q>﴿إلا بالحق﴾</q>{19}. (٦/٢٥٥) ٢٦٦٨٢- قال مقاتل بن سليمان: <q>﴿ولا تقتلوا النفس التي حرم الله﴾</q> قتلها <q>﴿إلا بالحق﴾</q> يعني: بالقصاص، والثيب الزاني بالرجم، والمرتد عن الإسلام، فهذا الحق{32}. (ز) <q>﴿ذَ ٰ⁠لِكُمۡ وَصَّىٰكُم بِهِۦ لَعَلَّكُمۡ تَعۡقِلُونَ ۝١٥١﴾</q> - تفسير ٢٦٦٨٣- قال مقاتل بن سليمان: <q>﴿ذلكم وصاكم به لعلكم﴾</q> يعني: لكي <q>﴿تعقلون﴾</q> أنّه لم يُحَرِّم إلا ما ذكر في هذه الآيات الثلاث، ولم يُحَرِّم البحيرة، والسائبة، والوصيلة، والحام{32}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٩٦.تفسير مقاتل بن سليمان ١/٥٩٦.أخرجه ابن أبي حاتم ٥/١٤١٤.أخرجه ابن جرير ٩/٦٥٨، وابن أبي حاتم ٥/١٤١٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن جرير ٩/٦٥٩.أخرجه ابن جرير ٩/٦٥٨ من طريق سعيد، وابن أبي حاتم ٥/١٤١٥. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٦٥٨.تفسير مقاتل بن سليمان ١/٥٩٦-٥٩٧.أخرجه ابن جرير ٩/٦٥٩.أخرجه الحارث في مسنده ١/١٧٦ (٢٩)، والطبراني في الكبير ١٨/١٤٠ (٢٩٣)، وابن أبي حاتم ٥/١٤١٥ (٨٠٦١)، ٥/١٤٦٠-١٤٦١ (٨٣٥٥) واللفظ له. قال البيهقي في السنن الكبرى ٨/٣٦٤ (١٦٩٠١): «تفرَّد به عمر بن سعيد الدمشقي، وهو منكر الحديث، وإنما يعرف من حديث النعمان بن مرة مرسلًا». وقال الهيثمي في المجمع ١/١٠٣ (٣٨٤): «رواه الطبراني في الكبير، ورجاله ثقات، إلا أنّ الحسن مُدَلِّس وعنعنه».أخرجه ابن أبي حاتم ٥/١٤١٥ (٨٠٦٢)، ٥/١٤٦٩ (٨٤٠٨). قال العراقي في تخريج أحاديث الإحياء ص١٥٦٤ (٣): «لم أجد له أصلًا». وقال الشوكاني في الفوائد المجموعة ص٦٥ (١٦): «قال في المختصر: لم يوجد». وقال الفتني في تذكرة الموضوعات ص٦٢: «لم يوجد».أخرجه ابن أبي حاتم ٥/١٤١٦-١٤١٧. وعزاه السيوطي إلى ابن مردويه.علَّقه ابن أبي حاتم ٥/١٤١٦. وعزاه ابن حجر في الفتح ٨/٣٠٢ إلى ابن جرير.علَّقه ابن أبي حاتم ٥/١٤١٧.عزاه السيوطي إلى ابن المنذر. وأخرج ابن أبي حاتم ٥/١٤١٦ شطره الثاني.علَّقه ابن أبي حاتم ٥/١٤١٦.أخرجه ابن جرير ٩/٦٦٠، وابن أبي حاتم ٥/١٤١٦. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.علَّقه ابن أبي حاتم ٥/١٤١٦.أخرجه ابن أبي حاتم ٥/١٤١٧.أخرجه ابن أبي حاتم ٥/١٤١٥.أخرجه ابن جرير ٩/٦٦١، وابن أبي حاتم ٥/١٤١٦ بلفظ: أمّا <q>﴿ما ظهر منها﴾</q> فقوله: <q>﴿ولا تنكحوا ما نكح آباؤكم﴾</q> [النساء:٢٢]، وقوله: <q>﴿وأن تجمعوا بين الأختين﴾</q> [النساء:٢٣]".عزاه ابن حجر في الفتح ٨/٣٠٢ إلى ابن جرير.أخرجه ابن جرير ٩/٦٦١.أخرجه ابن جرير ٩/٦٠٥.أخرجه ابن أبي حاتم ٥/١٤١٦-١٤١٧. وعزاه السيوطي إلى أبي الشيخ.علَّقه ابن أبي حاتم ٥/١٤١٥.أخرجه ابن جرير ٩/٦٦٠. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤١٦.أخرجه ابن جرير ٩/٦٥٩.أخرجه ابن أبي حاتم ٥/١٤١٥.أخرجه ابن أبي حاتم ٥/١٤١٥.تفسير مقاتل بن سليمان ١/٥٩٧.أخرجه عبد الرزاق ٢/٢٢١.أخرجه البخاري ٩/٥ (٦٨٧٨)، ومسلم ٣/١٣٠٢-١٣٠٣ (١٦٧٦) واللفظ له.أخرجه ابن أبي حاتم ٥/١٤١٧.تفسير مقاتل بن سليمان ١/٥٩٧.تفسير مقاتل بن سليمان ١/٥٩٧.
