quran[8]{c,v,t}:
  41,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَیۡهِ یُرَدُّ عِلۡمُ ٱلسَّاعَةِۚ وَمَا تَخۡرُجُ مِن ثَمَرَ ٰ⁠تࣲ مِّنۡ أَكۡمَامِهَا وَمَا تَحۡمِلُ مِنۡ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلۡمِهِۦۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلَيْهِ يُرَدُّ عِلْمُ السّاعَةِ﴾</span> وذلك أنّ اليهود قالوا للنبي ﷺ: أخبِرنا عن الساعة؛ فإن كنتَ رسولًا كما زعمتَ عَلِمْتَها، وإلا علمنا أنك لستَ برسول، ولا نصدّقك. قال النبي ﷺ: «<b>لا يعلمها إلا الله، أردُّ علمَها إلى الله</b>». فقال الله ﷿ للنبي ﷺ: فإن كنتَ رددتَ علمها -يعني: علم الساعة- إلى الله؛ فإنّ الملائكة والخلْق كلهم ردّوا علم الساعة -يعني: القيامة- إلى الله ﷿{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَیۡهِ یُرَدُّ عِلۡمُ ٱلسَّاعَةِۚ وَمَا تَخۡرُجُ مِن ثَمَرَ ٰ⁠تࣲ مِّنۡ أَكۡمَامِهَا وَمَا تَحۡمِلُ مِنۡ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلۡمِهِۦۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٢١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿مِن أكْمامِها﴾</span>، يعني: الكُفُرّى{2} قبل أن ينشَقَّ، فإذا انشَقَّت فليست بأكمام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجِيح- في قوله: <span class="qpc-hafs">﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</span>، قال: حين تطلع{4}. (١٣/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٢٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إلَيْهِ يُرَدُّ عِلْمُ السّاعَةِ وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</span> هذا في النخل خاصَّة حين يطلع، لا يعلم أحدٌ كيف يُخرجه الله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</span>، قال: مِن طلْعِها، والأكمام: جمع كُمّة، وهو كلّ ظرف لماء أو غيره. والعرب تدعو قشر الكُفراة: كُمًّا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ويعلم <span class="qpc-hafs">﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</span> يعني: من أجوافها، يعني: الطّلْع، <span class="qpc-hafs">﴿وما تَحْمِلُ مِن أُنْثى﴾</span> ذكرًا أو أنثى، سويًّا وغير سوي، يقول: <span class="qpc-hafs">﴿ولا تَضَعُ إلّا بِعِلْمِهِ﴾</span> يقول: لا تحمل المرأةُ الولدَ ولا تضعه إلا بعلمه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یُنَادِیهِمۡ أَیۡنَ شُرَكَاۤءِی قَالُوۤا۟ ءَاذَنَّـٰكَ مَا مِنَّا مِن شَهِیدࣲ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿آذَنّاكَ﴾</span>، قال: أعلمناك{8}. (١٣/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿آذَنّاكَ ما مِنّا مِن شَهِيدٍ﴾</span>: قالوا: أطعناك ما مِنّا مِن شهيد على أنّ لك شريكًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَوْمَ يُنادِيهِمْ أيْنَ شُرَكائِي﴾</span> يقول: أسمعناك. كقوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span> [الانشقاق:٢]، يقول: سمعتْ لربها. <span class="qpc-hafs">﴿ما مِنّا مِن شَهِيدٍ﴾</span> يشهد بأنّ لك شريكًا، فتبرّءوا يومئذٍ مِن أن يكون مع الله شريك{1}<span class=comment-ref>٥٧٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩٣) أنّ الضمير في قوله: <span class="qpc-hafs">﴿يُنادِيهِمْ﴾</span> ظاهره والأسبق فيه أنه يريد به الكفار عبدة الأوثان. ثم قال: «و<b>يحتمل</b> أن يريد به: كل من عبد مِن دون الله من إنسان وغيره». و<span class="comment-type-2">انتقده</span> بقوله: «وفي هذا ضعف». ولم يذكر مستندًا.</p><p>ثم بيّن أن الضمير في قوله: <span class="qpc-hafs">﴿وضَلَّ عَنْهُمْ﴾</span> لا احتمال لعودته إلا على الكفار.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٧.|2:الكُفُرّى: وعاء طَلْعِ النخل. لسان العرب (كفر).|3:تفسير الثعلبي ٨/٢٩٩، وتفسير البغوي ٧/١٧٨.|4:تفسير مجاهد ص٥٨٧، وأخرجه ابن جرير ٢٠/٤٥٥. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.|5:ذكره يحيى بن سلام -كما في تفسير ابن أبى زمنين ٤/١٥٨.|6:أخرجه ابن جرير ٢٠/٤٥٥.|7:تفسير مقاتل بن سليمان ٣/٧٤٧.|8:أخرجه ابن جرير ٢٠/٤٥٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|9:أخرجه ابن جرير ٢٠/٤٥٦.|10:تفسير مقاتل بن سليمان ٣/٧٤٧.
  41,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَدۡعُونَ مِن قَبۡلُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضَلَّ عَنْهُمْ﴾</span> في الآخرة <span class="qpc-hafs">﴿ما كانُوا يَدْعُونَ مِن قَبْلُ﴾</span> يقول: يعبدون. يقول: ما عبدوا في الدنيا مِن قبل{1}<span class=comment-ref>٥٧٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩٣) أن قوله: <span class="qpc-hafs">﴿وضَلَّ عَنْهُمْ﴾</span> أي: نسوا ما كانوا يقولون في الدنيا ويدعون من الآلهة والأصنام. ثم ساق <b>احتمالًا آخر</b> فقال: «ويحتمل أن يريد: وضل عنهم الأصنام، أي: تَلِفَت عنهم، فلم يجدوا منها نصرًا، وتلاشى لهم أمرها».</div></p><p><h3><span class="qpc-hafs">﴿وَظَنُّوا۟ مَا لَهُم مِّن مَّحِیصࣲ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٣٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّي</span> -من طريق أسباط- <span class="qpc-hafs">﴿وظَنُّوا ما لَهُمْ مِن مَحِيصٍ﴾</span>: استيقنوا أنه ليس لهم ملجأ{2}<span class=comment-ref>٥٧٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩٣) أن قوله تعالى: <span class="qpc-hafs">﴿وظَنُّوا﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يكون متصلًا بما قبله، ويكون الوقف عليه، ويكون قوله سبحانه: <span class="qpc-hafs">﴿ما لَهُمْ مِن مَحِيصٍ﴾</span> استئناف، نفي أن يكون لهم منجىً أو موضع روغان، ... ويكون الظن -على هذا التأويل- على بابه، أي: ظنّوا أن هذه المقالة: <span class="qpc-hafs">﴿ما مِنّا مِن شَهِيدٍ﴾</span> منجاة لهم أو أمر يُمَوِّهون به. <b>الثاني</b>: أن يكون الوقف في قوله: <span class="qpc-hafs">﴿مِن قَبْلُ﴾</span>، ويكون <span class="qpc-hafs">﴿وظَنُّوا﴾</span> متصلًا بقوله: <span class="qpc-hafs">﴿ما لَهُمْ مِن مَحِيصٍ﴾</span>، أي: ظنّوا ذلك، ويكون الظن -على هذا التأويل- بمعنى اليقين. وبيّن أن السُّدّيّ فسّر به.</div></p><p><div></p><p><p><span class="item-no">٦٨٧٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وظَنُّوا﴾</span> يعني: وعلموا <span class="qpc-hafs">﴿ما لَهُمْ مِن مَحِيصٍ﴾</span> يعني: مِن فرار مِن النار{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٧.|2:أخرجه ابن جرير ٢٠/٤٥٧.|3:تفسير مقاتل بن سليمان ٣/٧٤٧.
  41,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا یَسۡـَٔمُ ٱلۡإِنسَـٰنُ مِن دُعَاۤءِ ٱلۡخَیۡرِ وَإِن مَّسَّهُ ٱلشَّرُّ فَیَـُٔوسࣱ قَنُوطࣱ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٣٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿لا يَسْأَمُ الإنْسانُ﴾</span>، قال: لا يمَلّ{1}. (١٣/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٣٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لا يَسْأَمُ الإنْسانُ مِن دُعاءِ الخَيْرِ﴾</span> يقول: الكافر، <span class="qpc-hafs">﴿وإنْ مَسَّهُ الشَّرُّ فَيَئُوسٌ قَنُوطٌ﴾</span> قانط من الخير{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَسْأَمُ الإنْسانُ﴾</span> يقول: لا يمَلّ الكافر <span class="qpc-hafs">﴿مِن دُعاءِ الخَيْرِ﴾</span> يقول: لا يزال يدعو ربَّه الخير والعافية، <span class="qpc-hafs">﴿وإنْ مَسَّهُ﴾</span> يعني: البلاء وشدة <span class="qpc-hafs">﴿فَيَئُوسٌ﴾</span> من الخير، <span class="qpc-hafs">﴿قَنُوطٌ﴾</span> من الرحمة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا يَسْأَمُ الإنْسانُ﴾</span>، قال: لا يمَلّ{2}<span class=comment-ref>٥٧٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩٣-٤٩٤) أنه قيل: إن هذه الآيات نزلت في كفار قريش؛ <b>قيل</b>: في الوليد بن المغيرة، و<b>قيل</b>: في عُتبة بن ربيعة، ثم <span class="comment-type-4">علَّق</span> بقوله: «وجلّ الآية يُعطي أنها نزلت في كفار، وإن كان أولها يتضمن خُلُقًا ربما شارك فيه بعضُ المؤمنين».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٠/٤٥٨.|3:تفسير مقاتل بن سليمان ٣/٧٤٨.|4:أخرجه ابن جرير ٢٠/٤٥٨.
  41,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَىِٕنۡ أَذَقۡنَـٰهُ رَحۡمَةࣰ مِّنَّا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ولَئِنْ أذَقْناهُ رَحْمَةً مِنّا﴾</span>، يقول: ولئن آتيناه خيرًا وعافية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿ولَئِنْ أذَقْناهُ رَحْمَةً مِنّا﴾</span>، قال: عافية{2}. (١٣/١٢٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِنۢ بَعۡدِ ضَرَّاۤءَ مَسَّتۡهُ لَیَقُولَنَّ هَـٰذَا لِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجِيح- في قوله: <span class="qpc-hafs">﴿لَيَقُولَنَّ هَذا لِي﴾</span>: أي: بعملي، وأنا محقوق بهذا{3}. (١٣/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مِن بَعْدِ ضَرّاءَ مَسَّتْهُ﴾</span> يعني: بعد بلاء وشِدَّة أصابته؛ <span class="qpc-hafs">﴿لَيَقُولَنَّ هَذا لِي﴾</span> يقول: أنا أحقُّ بهذا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَظُنُّ ٱلسَّاعَةَ قَاۤىِٕمَةࣰ وَلَىِٕن رُّجِعۡتُ إِلَىٰ رَبِّیۤ إِنَّ لِی عِندَهُۥ لَلۡحُسۡنَىٰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن بن محمد بن علي بن أبي طالب</span>، قال: الكافر في أُمنيتين؛ أما في الدنيا فيقول: <span class="qpc-hafs">﴿ولَئِنْ رُجِعْتُ إلى رَبِّي إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</span>. وأما في الآخرة فيقول: <span class="qpc-hafs">﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</span> [النبأ:٤٠]{5}<span class=comment-ref>٥٧٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٨</span> ساق <u>ابنُ عطية</u> (٧/٤٩٤) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «والأماني على الله تعالى وترك الجدّ في الطاعة مذموم لكل أحد، <span class="mustanad">فقد قال</span> ﷺ: «الكيّس مَن دان نفسه وعَمِل لِما بعد الموت، والعاجز مَن أتبع نفسه هواها، وتَمَنّى على الله الأماني»».</div></p><p><div></p><p><p><span class="item-no">٦٨٧٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</span>: يقول: غِنىً{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿وما أظُنُّ﴾</span> يقول: ما أحسب <span class="qpc-hafs">﴿السّاعَةَ قائِمَةً﴾</span> يعني: القيامة كائنة، ثم قال الكافر: <span class="qpc-hafs">﴿ولَئِنْ رُجِعْتُ إلى رَبِّي﴾</span> في الآخرة إن كانت آخرةٌ <span class="qpc-hafs">﴿إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</span> يعني: الجنة، كما أُعطيت في الدنيا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَنُنَبِّئَنَّ ٱلَّذِینَ كَفَرُوا۟ بِمَا عَمِلُوا۟ وَلَنُذِیقَنَّهُم مِّنۡ عَذَابٍ غَلِیظࣲ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٤٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَلَنُنَبِّئَنَّ الَّذِينَ كَفَرُوا بِما عَمِلُوا﴾</span> لنقفنَّهم على مساوئ أعمالهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَنُنَبِّئَنَّ الَّذِينَ كَفَرُوا بِما عَمِلُوا﴾</span> مِن أعمالهم الخبيثة، <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِن عَذابٍ غَلِيظٍ﴾</span> يعني: شديد، لا يُفتّر عنهم، وهم فيه مبلسون{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٨.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مجاهد ص٥٨٧، وأخرجه ابن جرير ٢٠/٤٥٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٣/٧٤٨.|5:أخرجه الثعلبي ٨/٣٠٠.|6:أخرجه ابن جرير ٢٠/٤٥٩.|7:تفسير مقاتل بن سليمان ٣/٧٤٨.|8:تفسير البغوي ٧/١٧٨.|9:تفسير مقاتل بن سليمان ٣/٧٤٨.
  41,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَاۤ أَنۡعَمۡنَا عَلَى ٱلۡإِنسَـٰنِ أَعۡرَضَ وَنَـَٔا بِجَانِبِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿أعْرَضَ ونَأى بِجانِبِهِ﴾</span> يقول: <span class="qpc-hafs">﴿أعْرَضَ﴾</span> صدّ بوجهه، <span class="qpc-hafs">﴿ونَأى بِجانِبِهِ﴾</span> يقول: تباعد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وإذا أنْعَمْنا عَلى الإنْسانِ﴾</span> بالخير والعافية <span class="qpc-hafs">﴿أعْرَضَ﴾</span> عن الدعاء فلا يدعو ربَّه، <span class="qpc-hafs">﴿ونَأى بِجانِبِهِ﴾</span> يقول: وتباعد بجانبه عن الدعاء في الرخاء{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَاۤءٍ عَرِیضࣲ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٤٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فَذُو دُعاءٍ عَرِيضٍ﴾</span>، يقول: كثير، وذلك قول الناس: أطال فلانٌ الدعاءَ: إذا أكثر، وكذلك: أعرض دعاءه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا مَسَّهُ الشَّرُّ﴾</span> بلاء أو شدة أصابته <span class="qpc-hafs">﴿فَذُو دُعاءٍ عَرِيضٍ﴾</span> يعني: دعاء كبير، يسأل ربَّه أن يكشف ما به مِن الشِّدَّة في الدعاء، ويُعرِض عن الدعاء في الرخاء{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٤٦٠.|2:تفسير مقاتل بن سليمان ٣/٧٤٨.|3:أخرجه ابن جرير ٢٠/٤٦٠.|4:تفسير مقاتل بن سليمان ٣/٧٤٨.
  41,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِن كَانَ مِنۡ عِندِ ٱللَّهِ ثُمَّ كَفَرۡتُم بِهِۦ مَنۡ أَضَلُّ مِمَّنۡ هُوَ فِی شِقَاقِۭ بَعِیدࣲ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد لكفار مكة: <span class="qpc-hafs">﴿أرَأَيْتُمْ إنْ كانَ﴾</span> هذا القرآن <span class="qpc-hafs">﴿مِن عِنْدِ اللَّهِ ثُمَّ كَفَرْتُمْ بِهِ﴾</span> وذلك أنهم قالوا للنبي ﷺ: ما هذا القرآن إلا شيءٌ ابتدعتَه مِن تلقاء نفسك، أما وجد اللهُ رسولًا غيرَك وأنت أحقرُنا وأنت أضعفُنا رُكْنًا وأقلّنا جُندًا؟! أو يرسل ملَكًا، إنّ هذا الذي جئت به لأمر عظيم. يقول الله: <span class="qpc-hafs">﴿مَن أضَلُّ﴾</span> يقول: فلا أحد أضل <span class="qpc-hafs">﴿مِمَّنْ هُوفِي شِقاقٍ بَعِيدٍ﴾</span> يعني: في ضلال طويل{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٨.
  41,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَنُرِیهِمۡ ءَایَـٰتِنَا فِی ٱلۡـَٔافَاقِ وَفِیۤ أَنفُسِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span>، قال: كانوا يُسافِرون، فيرَوْن آثارَ عاد وثمود، فيقولوا: واللهِ، لقد صدق محمد. وما أراهم <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> قال: الأمراض{1}. (١٣/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥١<span class="dash">-</span></span> عن <span class="name-2">المِنهال [بن عمرو]</span> -من طريق عمرو بن أبي قيس- في قوله: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span>، قال: ظهور محمد ﷺ على الناس{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق زيد بن أسلم- في قوله تعالى: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span> قال: ما يفتح الله عليهم من القرى، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> قال: فتح مكة{3}. (١٣/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span>، قال: محمد ﷺ{4}. (١٣/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِي الآفاقِ﴾</span> ما يُفتح مِن القُرى على محمد ﷺ والمسلمين، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> فتح مكة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span>، يعني: ما أهلَك به{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿فِي الآفاقِ﴾</span> يعني: وقائع الله في الأُمَم، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> يوم بدر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span> يقول: ما نفتح لك -يا محمد- من الآفاق، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> في أهل مكة، يقول: نفتح لك مكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٨<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span> يعني: أقطار الأرض والسماء؛ مِن الشمس والقمر والنجوم، والنبات والأشجار، والأنهار والبحار والأمطار، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> مِن لطيف الصّنعة، وبديع الحكمة، وسبيل الغائط والبول، حتى إنّ الرجل ليأكل ويشرب من مكان واحد، ويخرج ما يأكل ويشرب من مكانين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوّفهم، فقال: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا﴾</span> يعني: عذابنا <span class="qpc-hafs">﴿فِي الآفاقِ﴾</span> يعني: في البلاد ما بين اليمن والشام؛ عذاب قوم عاد، وثمود، وقوم لوط، كانوا يمرُّون عليهم، ونريهم العذاب، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> فهو القتل ببدر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span> قال: إمساك المطر عن الأرض كلها، <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> قال: البلايا التي تكون في أجسامهم{4}. (١٣/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</span>، قال: آفاق السماوات، نجومها وشمسها وقمرها اللاتي يجرين، وآيات في أنفسهم أيضًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وفِي أنْفُسِهِمْ﴾</span> يعني: من الجوع بمكة، والسيف يوم بدر{13}<span class=comment-ref>٥٧٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٩</span> اختُلف في معنى الآيات التي وعد الله هؤلاء القوم أن يريهم إياها على أقوال: <b>الأول</b>: أن في الآفاق: فتح أقطار الأرض، وفي أنفسهم: فتح مكة. <b>الثاني</b>: في الآفاق: ما أخبر به من حوادث الأمم، وفي أنفسهم: يوم بدر. <b>الثالث</b>: أنها في الآفاق إمساك القطر عن الأرض كلها، وفي أنفسهم: البلاء الذي يكون في أجسادهم. <b>الرابع</b>: أنها في الآفاق: انشقاق القمر، وفي أنفسهم: عبرة الإنسان بعجيب جسمه وخلقته. <b>الخامس</b>: أنها في الآفاق: الجوع بمكة، وفي أنفسهم: يوم بدر.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٤٩٦) على القول الأول الذي قاله السدي، والمنهال بن عمرو، والحسن، ومجاهد، بقوله: «وهذا تأويل حسن، ينتظم الإعلام بغيب ظهر وجوده بعد كذلك، ويجري مع لفظ الاستئناف الذي في الفعل».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٤٦٢) -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- القول الأول.</p><p>و<span class="comment-type-2">انتقد</span> البقية، فقال: «وذلك أنّ الله ﷿ وعد نبيَّه ﷺ أن يُري هؤلاء المشركين الذين كانوا به مكذِّبين آيات في الآفاق، وغير معقول أن يكون تهدّدهم بأن يريهم ما هم رأوه، بل الواجب أن يكون ذلك وعدًا منه لهم أن يريهم ما لم يكونوا رأوه قبل مِن ظهور نبيِّ الله ﷺ على أطراف بلدهم وعلى بلدهم، فأما النجوم والشمس والقمر فقد كانوا يرونها كثيرًا قبل وبعد، ولا وجه لتهددهم بأنه يريهم ذلك».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٧/٤٩٦)، و<span class="comment-type-2">انتقد</span> بقية الأقوال -<span class="mustanad">مستندًا لظاهر لفظ الآية</span>- بقوله: «وهذه آيات قد كانت مرئية، فليس هذا المعنى يجري مع قوله: سنري».</div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ یَتَبَیَّنَ لَهُمۡ أَنَّهُ ٱلۡحَقُّۗ أَوَلَمۡ یَكۡفِ بِرَبِّكَ أَنَّهُۥ عَلَىٰ كُلِّ شَیۡءࣲ شَهِیدٌ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى يَتَبَيَّنَ لَهُمْ أنَّهُ الحَقُّ﴾</span> يعني: أنّ هذا القرآن الحق مِن الله ﷿، <span class="qpc-hafs">﴿أوَلَمْ يَكْفِ بِرَبِّكَ﴾</span> شاهدًا أن هذا القرآن جاء من الله ﷿ <span class="qpc-hafs">﴿أنَّهُ عَلى كُلِّ شَيْءٍ شَهِيدٌ﴾</span>، كقوله في الأنعام [١٩]: <span class="qpc-hafs">﴿قُلِ اللَّهُ شَهِيدٌ بَيْنِي وبَيْنَكُمْ﴾</span>{10}<span class=comment-ref>٥٧٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٨٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٥/٤٦٩) أن القول بعود الضمير على القرآن في قوله: <span class="qpc-hafs">﴿أنه الحق﴾</span> هو قول السلف وعامة العلماء والمفسرين، ثم <span class="comment-type-4">ذكر</span> قولًا آخر بعوده على الله تعالى.</p><p>و<span class="comment-type-3">رجَّح</span> الأول <span class="mustanad">مستندًا إلى السياق</span>، فقال: «والصواب: الأول، كما قال: <span class="qpc-hafs">﴿قل أرأيتم إن كان من عند الله ثم كفرتم به﴾</span> وهذا هو القرآن. ثم قال بعد ذلك: <span class="qpc-hafs">﴿سنريهم آياتنا في الآفاق وفي أنفسهم حتى يتبين لهم أنه الحق﴾</span>، ثم قال: <span class="qpc-hafs">﴿أولم يكف بربك أنه على كل شيء شهيد﴾</span> فأخبر أنّه سيُري الناس في أنفسهم وفي الآفاق من الآيات العيانية المشهودة المعقولة ما يبيّن أنّ الآيات القرآنية المسموعة المتلوّة حق، فيتطابق العقل والسمع، ويتفق العيان والقرآن، وتصدق المعاينة للخبر».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.|2:أخرجه ابن جرير ٢٠/٤٦١.|3:أخرجه عبد الرزاق ٢/١٨٩. وعزاه السيوطي إلى ابن المنذر.|4:عزاه السيوطي إلى ابن المنذر.|5:تفسير البغوي ٧/١٧٩.|6:ذكره يحيى بن سلام -كما في تفسير ابن أبى زمنين ٤/١٥٩-.|7:تفسير الثعلبي ٨/٣٠٠، وتفسير البغوي ٧/١٧٩.|8:أخرجه ابن جرير ٢٠/٤٦١.|9:تفسير الثعلبي ٨/٣٠٠، وتفسير البغوي ٧/١٧٩.|10:تفسير مقاتل بن سليمان ٣/٧٤٨-٧٤٩.|11:عزاه السيوطي إلى ابن المنذر.|12:أخرجه ابن جرير ٢٠/٤٦٢.|13:تفسير ابن أبى زمنين ٤/١٦٠.|14:تفسير مقاتل بن سليمان ٣/٧٤٨-٧٤٩.
  41,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَاۤ إِنَّهُمۡ فِی مِرۡیَةࣲ مِّن لِّقَاۤءِ رَبِّهِمۡۗ أَلَاۤ إِنَّهُۥ بِكُلِّ شَیۡءࣲ مُّحِیطُۢ ۝٥٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٦٤<span class="dash">-</span></span> عن عاصم بن بهدلة، عن <span class="name-2">زِر</span>: <span class="qpc-hafs">﴿ألَآ إنَّهُمْ فِي مِرْيَةٍ﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦٥<span class="dash">-</span></span> وعن <span class="name-2">أبي عبد الرحمن السُلمي</span>: (فِي مُرْيَةٍ مِّن لِّقَآءِ رَبِّهِمْ)= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦٦<span class="dash">-</span></span> قال: وقال لنا <span class="name-2">عاصم</span>: ما رويت عن زِر فهو عن <span class="name-1">ابن مسعود</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦٧<span class="dash">-</span></span> وما رويت عن أبي عبد الرحمن السُلمي فهو عن <span class="name-1">علي</span> -رضوان الله عليه-{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَاۤ إِنَّهُمۡ فِی مِرۡیَةࣲ مِّن لِّقَاۤءِ رَبِّهِمۡۗ أَلَاۤ إِنَّهُۥ بِكُلِّ شَیۡءࣲ مُّحِیطُۢ ۝٥٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٦٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ألا إنَّهُمْ فِي مِرْيَةٍ مِن لِقاءِ رَبِّهِمْ﴾</span>: يقول: في شكٍّ مِن لقاء ربهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا إنَّهُمْ فِي مِرْيَةٍ مِن لِقاءِ رَبِّهِمْ﴾</span>، يعني: في شك مِن البعث وغيره{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٢٩٧.</p><p>و<span class="qpc-hafs">﴿فِي مِرْيَةٍ﴾</span> بكسر الميم قراءة العشرة، وأما (فِي مُرْيَةٍ) بضمّ الميم قراءة شاذة، تروى عن الحسن أيضًا. انظر: المحرر الوجيز ٥/٢٤، والبحر المحيط ٧/٤٨٣.|2:أخرجه ابن جرير ٢٠/٤٦٣.|3:تفسير مقاتل بن سليمان ٣/٧٤٩.