tafsir[8]{c,v,t}:
41,47," <q>﴿إِلَیۡهِ یُرَدُّ عِلۡمُ ٱلسَّاعَةِۚ وَمَا تَخۡرُجُ مِن ثَمَرَ ٰ⁠تࣲ مِّنۡ أَكۡمَامِهَا وَمَا تَحۡمِلُ مِنۡ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلۡمِهِۦۚ﴾</q> - نزول الآية ٦٨٧٢٠- قال مقاتل بن سليمان: <q>﴿إلَيْهِ يُرَدُّ عِلْمُ السّاعَةِ﴾</q> وذلك أنّ اليهود قالوا للنبي ﷺ: أخبِرنا عن الساعة؛ فإن كنتَ رسولًا كما زعمتَ عَلِمْتَها، وإلا علمنا أنك لستَ برسول، ولا نصدّقك. قال النبي ﷺ: «لا يعلمها إلا الله، أردُّ علمَها إلى الله». فقال الله ﷿ للنبي ﷺ: فإن كنتَ رددتَ علمها -يعني: علم الساعة- إلى الله؛ فإنّ الملائكة والخلْق كلهم ردّوا علم الساعة -يعني: القيامة- إلى الله ﷿{1}. (ز) <q>﴿إِلَیۡهِ یُرَدُّ عِلۡمُ ٱلسَّاعَةِۚ وَمَا تَخۡرُجُ مِن ثَمَرَ ٰ⁠تࣲ مِّنۡ أَكۡمَامِهَا وَمَا تَحۡمِلُ مِنۡ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلۡمِهِۦۚ﴾</q> - تفسير الآية ٦٨٧٢١- قال عبد الله بن عباس: <q>﴿مِن أكْمامِها﴾</q>، يعني: الكُفُرّى{2} قبل أن ينشَقَّ، فإذا انشَقَّت فليست بأكمام{3}. (ز) ٦٨٧٢٢- عن مجاهد بن جبر -من طريق ابن أبي نجِيح- في قوله: <q>﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</q>، قال: حين تطلع{4}. (١٣/١٢٥) ٦٨٧٢٣- قال الحسن البصري: <q>﴿إلَيْهِ يُرَدُّ عِلْمُ السّاعَةِ وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</q> هذا في النخل خاصَّة حين يطلع، لا يعلم أحدٌ كيف يُخرجه الله{5}. (ز) ٦٨٧٢٤- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</q>، قال: مِن طلْعِها، والأكمام: جمع كُمّة، وهو كلّ ظرف لماء أو غيره. والعرب تدعو قشر الكُفراة: كُمًّا{6}. (ز) ٦٨٧٢٥- قال مقاتل بن سليمان: ويعلم <q>﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</q> يعني: من أجوافها، يعني: الطّلْع، <q>﴿وما تَحْمِلُ مِن أُنْثى﴾</q> ذكرًا أو أنثى، سويًّا وغير سوي، يقول: <q>﴿ولا تَضَعُ إلّا بِعِلْمِهِ﴾</q> يقول: لا تحمل المرأةُ الولدَ ولا تضعه إلا بعلمه{1}. (ز) <q>﴿وَیَوۡمَ یُنَادِیهِمۡ أَیۡنَ شُرَكَاۤءِی قَالُوۤا۟ ءَاذَنَّـٰكَ مَا مِنَّا مِن شَهِیدࣲ ۝٤٧﴾</q> - تفسير ٦٨٧٢٦- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿آذَنّاكَ﴾</q>، قال: أعلمناك{8}. (١٣/١٢٦) ٦٨٧٢٧- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿آذَنّاكَ ما مِنّا مِن شَهِيدٍ﴾</q>: قالوا: أطعناك ما مِنّا مِن شهيد على أنّ لك شريكًا{9}. (ز) ٦٨٧٢٨- قال مقاتل بن سليمان: <q>﴿ويَوْمَ يُنادِيهِمْ أيْنَ شُرَكائِي﴾</q> يقول: أسمعناك. كقوله: <q>﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</q> [الانشقاق:٢]، يقول: سمعتْ لربها. <q>﴿ما مِنّا مِن شَهِيدٍ﴾</q> يشهد بأنّ لك شريكًا، فتبرّءوا يومئذٍ مِن أن يكون مع الله شريك{1}٥٧٧٤. (ز) ٥٧٧٤ ذكر ابنُ عطية (٧/٤٩٣) أنّ الضمير في قوله: <q>﴿يُنادِيهِمْ﴾</q> ظاهره والأسبق فيه أنه يريد به الكفار عبدة الأوثان. ثم قال: «ويحتمل أن يريد به: كل من عبد مِن دون الله من إنسان وغيره». وانتقده بقوله: «وفي هذا ضعف». ولم يذكر مستندًا. ثم بيّن أن الضمير في قوله: <q>﴿وضَلَّ عَنْهُمْ﴾</q> لا احتمال لعودته إلا على الكفار. ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٧.الكُفُرّى: وعاء طَلْعِ النخل. لسان العرب (كفر).تفسير الثعلبي ٨/٢٩٩، وتفسير البغوي ٧/١٧٨.تفسير مجاهد ص٥٨٧، وأخرجه ابن جرير ٢٠/٤٥٥. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبى زمنين ٤/١٥٨.أخرجه ابن جرير ٢٠/٤٥٥.تفسير مقاتل بن سليمان ٣/٧٤٧.أخرجه ابن جرير ٢٠/٤٥٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٠/٤٥٦.تفسير مقاتل بن سليمان ٣/٧٤٧.
41,48," <q>﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَدۡعُونَ مِن قَبۡلُۖ﴾</q> - تفسير ٦٨٧٢٩- قال مقاتل بن سليمان: <q>﴿وضَلَّ عَنْهُمْ﴾</q> في الآخرة <q>﴿ما كانُوا يَدْعُونَ مِن قَبْلُ﴾</q> يقول: يعبدون. يقول: ما عبدوا في الدنيا مِن قبل{1}٥٧٧٥. (ز) ٥٧٧٥ ذكر ابنُ عطية (٧/٤٩٣) أن قوله: <q>﴿وضَلَّ عَنْهُمْ﴾</q> أي: نسوا ما كانوا يقولون في الدنيا ويدعون من الآلهة والأصنام. ثم ساق احتمالًا آخر فقال: «ويحتمل أن يريد: وضل عنهم الأصنام، أي: تَلِفَت عنهم، فلم يجدوا منها نصرًا، وتلاشى لهم أمرها». <q>﴿وَظَنُّوا۟ مَا لَهُم مِّن مَّحِیصࣲ ۝٤٨﴾</q> - تفسير ٦٨٧٣٠- عن إسماعيل السُّدّي -من طريق أسباط- <q>﴿وظَنُّوا ما لَهُمْ مِن مَحِيصٍ﴾</q>: استيقنوا أنه ليس لهم ملجأ{2}٥٧٧٦. (ز) ٥٧٧٦ ذكر ابنُ عطية (٧/٤٩٣) أن قوله تعالى: <q>﴿وظَنُّوا﴾</q> يحتمل احتمالين: الأول: أن يكون متصلًا بما قبله، ويكون الوقف عليه، ويكون قوله سبحانه: <q>﴿ما لَهُمْ مِن مَحِيصٍ﴾</q> استئناف، نفي أن يكون لهم منجىً أو موضع روغان، ... ويكون الظن -على هذا التأويل- على بابه، أي: ظنّوا أن هذه المقالة: <q>﴿ما مِنّا مِن شَهِيدٍ﴾</q> منجاة لهم أو أمر يُمَوِّهون به. الثاني: أن يكون الوقف في قوله: <q>﴿مِن قَبْلُ﴾</q>، ويكون <q>﴿وظَنُّوا﴾</q> متصلًا بقوله: <q>﴿ما لَهُمْ مِن مَحِيصٍ﴾</q>، أي: ظنّوا ذلك، ويكون الظن -على هذا التأويل- بمعنى اليقين. وبيّن أن السُّدّيّ فسّر به. ٦٨٧٣١- قال مقاتل بن سليمان: <q>﴿وظَنُّوا﴾</q> يعني: وعلموا <q>﴿ما لَهُمْ مِن مَحِيصٍ﴾</q> يعني: مِن فرار مِن النار{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٧.أخرجه ابن جرير ٢٠/٤٥٧.تفسير مقاتل بن سليمان ٣/٧٤٧.
41,49," <q>﴿لَّا یَسۡـَٔمُ ٱلۡإِنسَـٰنُ مِن دُعَاۤءِ ٱلۡخَیۡرِ وَإِن مَّسَّهُ ٱلشَّرُّ فَیَـُٔوسࣱ قَنُوطࣱ ۝٤٩﴾</q> - تفسير ٦٨٧٣٢- عن عكرمة مولى ابن عباس، في قوله: <q>﴿لا يَسْأَمُ الإنْسانُ﴾</q>، قال: لا يمَلّ{1}. (١٣/١٢٦) ٦٨٧٣٣- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿لا يَسْأَمُ الإنْسانُ مِن دُعاءِ الخَيْرِ﴾</q> يقول: الكافر، <q>﴿وإنْ مَسَّهُ الشَّرُّ فَيَئُوسٌ قَنُوطٌ﴾</q> قانط من الخير{2}. (ز) ٦٨٧٣٤- قال مقاتل بن سليمان: <q>﴿لا يَسْأَمُ الإنْسانُ﴾</q> يقول: لا يمَلّ الكافر <q>﴿مِن دُعاءِ الخَيْرِ﴾</q> يقول: لا يزال يدعو ربَّه الخير والعافية، <q>﴿وإنْ مَسَّهُ﴾</q> يعني: البلاء وشدة <q>﴿فَيَئُوسٌ﴾</q> من الخير، <q>﴿قَنُوطٌ﴾</q> من الرحمة{3}. (ز) ٦٨٧٣٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا يَسْأَمُ الإنْسانُ﴾</q>، قال: لا يمَلّ{2}٥٧٧٧. (ز) ٥٧٧٧ ذكر ابنُ عطية (٧/٤٩٣-٤٩٤) أنه قيل: إن هذه الآيات نزلت في كفار قريش؛ قيل: في الوليد بن المغيرة، وقيل: في عُتبة بن ربيعة، ثم علَّق بقوله: «وجلّ الآية يُعطي أنها نزلت في كفار، وإن كان أولها يتضمن خُلُقًا ربما شارك فيه بعضُ المؤمنين». ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٥٨.تفسير مقاتل بن سليمان ٣/٧٤٨.أخرجه ابن جرير ٢٠/٤٥٨.
41,50," <q>﴿وَلَىِٕنۡ أَذَقۡنَـٰهُ رَحۡمَةࣰ مِّنَّا﴾</q> - تفسير ٦٨٧٣٦- قال مقاتل بن سليمان: ثم قال: <q>﴿ولَئِنْ أذَقْناهُ رَحْمَةً مِنّا﴾</q>، يقول: ولئن آتيناه خيرًا وعافية{1}. (ز) ٦٨٧٣٧- عن عبد الملك ابن جُريْج، في قوله: <q>﴿ولَئِنْ أذَقْناهُ رَحْمَةً مِنّا﴾</q>، قال: عافية{2}. (١٣/١٢٦) <q>﴿مِنۢ بَعۡدِ ضَرَّاۤءَ مَسَّتۡهُ لَیَقُولَنَّ هَـٰذَا لِی﴾</q> - تفسير ٦٨٧٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجِيح- في قوله: <q>﴿لَيَقُولَنَّ هَذا لِي﴾</q>: أي: بعملي، وأنا محقوق بهذا{3}. (١٣/١٢٦) ٦٨٧٣٩- قال مقاتل بن سليمان: <q>﴿مِن بَعْدِ ضَرّاءَ مَسَّتْهُ﴾</q> يعني: بعد بلاء وشِدَّة أصابته؛ <q>﴿لَيَقُولَنَّ هَذا لِي﴾</q> يقول: أنا أحقُّ بهذا{1}. (ز) <q>﴿وَمَاۤ أَظُنُّ ٱلسَّاعَةَ قَاۤىِٕمَةࣰ وَلَىِٕن رُّجِعۡتُ إِلَىٰ رَبِّیۤ إِنَّ لِی عِندَهُۥ لَلۡحُسۡنَىٰۚ﴾</q> - تفسير ٦٨٧٤٠- عن الحسن بن محمد بن علي بن أبي طالب، قال: الكافر في أُمنيتين؛ أما في الدنيا فيقول: <q>﴿ولَئِنْ رُجِعْتُ إلى رَبِّي إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</q>. وأما في الآخرة فيقول: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q> [النبأ:٤٠]{5}٥٧٧٨. (ز) ٥٧٧٨ ساق ابنُ عطية (٧/٤٩٤) هذا القول، ثم علَّق بقوله: «والأماني على الله تعالى وترك الجدّ في الطاعة مذموم لكل أحد، فقد قال ﷺ: «الكيّس مَن دان نفسه وعَمِل لِما بعد الموت، والعاجز مَن أتبع نفسه هواها، وتَمَنّى على الله الأماني»». ٦٨٧٤١- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</q>: يقول: غِنىً{6}. (ز) ٦٨٧٤٢- قال مقاتل بن سليمان: يقول: <q>﴿وما أظُنُّ﴾</q> يقول: ما أحسب <q>﴿السّاعَةَ قائِمَةً﴾</q> يعني: القيامة كائنة، ثم قال الكافر: <q>﴿ولَئِنْ رُجِعْتُ إلى رَبِّي﴾</q> في الآخرة إن كانت آخرةٌ <q>﴿إنَّ لِي عِنْدَهُ لَلْحُسْنى﴾</q> يعني: الجنة، كما أُعطيت في الدنيا{1}. (ز) <q>﴿فَلَنُنَبِّئَنَّ ٱلَّذِینَ كَفَرُوا۟ بِمَا عَمِلُوا۟ وَلَنُذِیقَنَّهُم مِّنۡ عَذَابٍ غَلِیظࣲ ۝٥٠﴾</q> - تفسير ٦٨٧٤٣- قال عبد الله بن عباس: <q>﴿فَلَنُنَبِّئَنَّ الَّذِينَ كَفَرُوا بِما عَمِلُوا﴾</q> لنقفنَّهم على مساوئ أعمالهم{8}. (ز) ٦٨٧٤٤- قال مقاتل بن سليمان: <q>﴿فَلَنُنَبِّئَنَّ الَّذِينَ كَفَرُوا بِما عَمِلُوا﴾</q> مِن أعمالهم الخبيثة، <q>﴿ولَنُذِيقَنَّهُمْ مِن عَذابٍ غَلِيظٍ﴾</q> يعني: شديد، لا يُفتّر عنهم، وهم فيه مبلسون{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٨.عزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٥٨٧، وأخرجه ابن جرير ٢٠/٤٥٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٤٨.أخرجه الثعلبي ٨/٣٠٠.أخرجه ابن جرير ٢٠/٤٥٩.تفسير مقاتل بن سليمان ٣/٧٤٨.تفسير البغوي ٧/١٧٨.تفسير مقاتل بن سليمان ٣/٧٤٨.
41,51," <q>﴿وَإِذَاۤ أَنۡعَمۡنَا عَلَى ٱلۡإِنسَـٰنِ أَعۡرَضَ وَنَـَٔا بِجَانِبِهِۦ﴾</q> - تفسير ٦٨٧٤٥- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿أعْرَضَ ونَأى بِجانِبِهِ﴾</q> يقول: <q>﴿أعْرَضَ﴾</q> صدّ بوجهه، <q>﴿ونَأى بِجانِبِهِ﴾</q> يقول: تباعد{1}. (ز) ٦٨٧٤٦- قال مقاتل بن سليمان: ثم قال: <q>﴿وإذا أنْعَمْنا عَلى الإنْسانِ﴾</q> بالخير والعافية <q>﴿أعْرَضَ﴾</q> عن الدعاء فلا يدعو ربَّه، <q>﴿ونَأى بِجانِبِهِ﴾</q> يقول: وتباعد بجانبه عن الدعاء في الرخاء{2}. (ز) <q>﴿وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَاۤءٍ عَرِیضࣲ ۝٥١﴾</q> - تفسير ٦٨٧٤٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فَذُو دُعاءٍ عَرِيضٍ﴾</q>، يقول: كثير، وذلك قول الناس: أطال فلانٌ الدعاءَ: إذا أكثر، وكذلك: أعرض دعاءه{1}. (ز) ٦٨٧٤٨- قال مقاتل بن سليمان: <q>﴿وإذا مَسَّهُ الشَّرُّ﴾</q> بلاء أو شدة أصابته <q>﴿فَذُو دُعاءٍ عَرِيضٍ﴾</q> يعني: دعاء كبير، يسأل ربَّه أن يكشف ما به مِن الشِّدَّة في الدعاء، ويُعرِض عن الدعاء في الرخاء{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٤٦٠.تفسير مقاتل بن سليمان ٣/٧٤٨.أخرجه ابن جرير ٢٠/٤٦٠.تفسير مقاتل بن سليمان ٣/٧٤٨.
41,52," <q>﴿قُلۡ أَرَءَیۡتُمۡ إِن كَانَ مِنۡ عِندِ ٱللَّهِ ثُمَّ كَفَرۡتُم بِهِۦ مَنۡ أَضَلُّ مِمَّنۡ هُوَ فِی شِقَاقِۭ بَعِیدࣲ ۝٥٢﴾</q> - تفسير ٦٨٧٤٩- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> يا محمد لكفار مكة: <q>﴿أرَأَيْتُمْ إنْ كانَ﴾</q> هذا القرآن <q>﴿مِن عِنْدِ اللَّهِ ثُمَّ كَفَرْتُمْ بِهِ﴾</q> وذلك أنهم قالوا للنبي ﷺ: ما هذا القرآن إلا شيءٌ ابتدعتَه مِن تلقاء نفسك، أما وجد اللهُ رسولًا غيرَك وأنت أحقرُنا وأنت أضعفُنا رُكْنًا وأقلّنا جُندًا؟! أو يرسل ملَكًا، إنّ هذا الذي جئت به لأمر عظيم. يقول الله: <q>﴿مَن أضَلُّ﴾</q> يقول: فلا أحد أضل <q>﴿مِمَّنْ هُوفِي شِقاقٍ بَعِيدٍ﴾</q> يعني: في ضلال طويل{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٨.
41,53," <q>﴿سَنُرِیهِمۡ ءَایَـٰتِنَا فِی ٱلۡـَٔافَاقِ وَفِیۤ أَنفُسِهِمۡ﴾</q> - تفسير ٦٨٧٥٠- عن عبد الله بن عباس، <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q>، قال: كانوا يُسافِرون، فيرَوْن آثارَ عاد وثمود، فيقولوا: واللهِ، لقد صدق محمد. وما أراهم <q>﴿وفِي أنْفُسِهِمْ﴾</q> قال: الأمراض{1}. (١٣/١٢٧) ٦٨٧٥١- عن المِنهال [بن عمرو] -من طريق عمرو بن أبي قيس- في قوله: <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q>، قال: ظهور محمد ﷺ على الناس{2}. (ز) ٦٨٧٥٢- عن مجاهد بن جبر -من طريق زيد بن أسلم- في قوله تعالى: <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q> قال: ما يفتح الله عليهم من القرى، <q>﴿وفِي أنْفُسِهِمْ﴾</q> قال: فتح مكة{3}. (١٣/١٢٦) ٦٨٧٥٣- عن مجاهد بن جبر، في قوله: <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q>، قال: محمد ﷺ{4}. (١٣/١٢٦) ٦٨٧٥٤- قال الحسن البصري: <q>﴿فِي الآفاقِ﴾</q> ما يُفتح مِن القُرى على محمد ﷺ والمسلمين، <q>﴿وفِي أنْفُسِهِمْ﴾</q> فتح مكة{5}. (ز) ٦٨٧٥٥- قال الحسن البصري: <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q>، يعني: ما أهلَك به{6}. (ز) ٦٨٧٥٦- قال قتادة بن دعامة: <q>﴿فِي الآفاقِ﴾</q> يعني: وقائع الله في الأُمَم، <q>﴿وفِي أنْفُسِهِمْ﴾</q> يوم بدر{7}. (ز) ٦٨٧٥٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q> يقول: ما نفتح لك -يا محمد- من الآفاق، <q>﴿وفِي أنْفُسِهِمْ﴾</q> في أهل مكة، يقول: نفتح لك مكة{2}. (ز) ٦٨٧٥٨- قال عطاء: <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q> يعني: أقطار الأرض والسماء؛ مِن الشمس والقمر والنجوم، والنبات والأشجار، والأنهار والبحار والأمطار، <q>﴿وفِي أنْفُسِهِمْ﴾</q> مِن لطيف الصّنعة، وبديع الحكمة، وسبيل الغائط والبول، حتى إنّ الرجل ليأكل ويشرب من مكان واحد، ويخرج ما يأكل ويشرب من مكانين{7}. (ز) ٦٨٧٥٩- قال مقاتل بن سليمان: ثم خوّفهم، فقال: <q>﴿سَنُرِيهِمْ آياتِنا﴾</q> يعني: عذابنا <q>﴿فِي الآفاقِ﴾</q> يعني: في البلاد ما بين اليمن والشام؛ عذاب قوم عاد، وثمود، وقوم لوط، كانوا يمرُّون عليهم، ونريهم العذاب، <q>﴿وفِي أنْفُسِهِمْ﴾</q> فهو القتل ببدر{10}. (ز) ٦٨٧٦٠- عن عبد الملك ابن جُريْج، <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q> قال: إمساك المطر عن الأرض كلها، <q>﴿وفِي أنْفُسِهِمْ﴾</q> قال: البلايا التي تكون في أجسامهم{4}. (١٣/١٢٥) ٦٨٧٦١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿سَنُرِيهِمْ آياتِنا فِي الآفاقِ﴾</q>، قال: آفاق السماوات، نجومها وشمسها وقمرها اللاتي يجرين، وآيات في أنفسهم أيضًا{12}. (ز) ٦٨٧٦٢- قال يحيى بن سلّام: <q>﴿وفِي أنْفُسِهِمْ﴾</q> يعني: من الجوع بمكة، والسيف يوم بدر{13}٥٧٧٩. (ز) ٥٧٧٩ اختُلف في معنى الآيات التي وعد الله هؤلاء القوم أن يريهم إياها على أقوال: الأول: أن في الآفاق: فتح أقطار الأرض، وفي أنفسهم: فتح مكة. الثاني: في الآفاق: ما أخبر به من حوادث الأمم، وفي أنفسهم: يوم بدر. الثالث: أنها في الآفاق إمساك القطر عن الأرض كلها، وفي أنفسهم: البلاء الذي يكون في أجسادهم. الرابع: أنها في الآفاق: انشقاق القمر، وفي أنفسهم: عبرة الإنسان بعجيب جسمه وخلقته. الخامس: أنها في الآفاق: الجوع بمكة، وفي أنفسهم: يوم بدر. وعلَّق ابنُ عطية (٧/٤٩٦) على القول الأول الذي قاله السدي، والمنهال بن عمرو، والحسن، ومجاهد، بقوله: «وهذا تأويل حسن، ينتظم الإعلام بغيب ظهر وجوده بعد كذلك، ويجري مع لفظ الاستئناف الذي في الفعل». ورجَّح ابنُ جرير (٢٠/٤٦٢) -مستندًا إلى الدلالة العقلية- القول الأول. وانتقد البقية، فقال: «وذلك أنّ الله ﷿ وعد نبيَّه ﷺ أن يُري هؤلاء المشركين الذين كانوا به مكذِّبين آيات في الآفاق، وغير معقول أن يكون تهدّدهم بأن يريهم ما هم رأوه، بل الواجب أن يكون ذلك وعدًا منه لهم أن يريهم ما لم يكونوا رأوه قبل مِن ظهور نبيِّ الله ﷺ على أطراف بلدهم وعلى بلدهم، فأما النجوم والشمس والقمر فقد كانوا يرونها كثيرًا قبل وبعد، ولا وجه لتهددهم بأنه يريهم ذلك». وكذا رجَّحه ابنُ عطية (٧/٤٩٦)، وانتقد بقية الأقوال -مستندًا لظاهر لفظ الآية- بقوله: «وهذه آيات قد كانت مرئية، فليس هذا المعنى يجري مع قوله: سنري». <q>﴿حَتَّىٰ یَتَبَیَّنَ لَهُمۡ أَنَّهُ ٱلۡحَقُّۗ أَوَلَمۡ یَكۡفِ بِرَبِّكَ أَنَّهُۥ عَلَىٰ كُلِّ شَیۡءࣲ شَهِیدٌ ۝٥٣﴾</q> - تفسير ٦٨٧٦٣- قال مقاتل بن سليمان: <q>﴿حَتّى يَتَبَيَّنَ لَهُمْ أنَّهُ الحَقُّ﴾</q> يعني: أنّ هذا القرآن الحق مِن الله ﷿، <q>﴿أوَلَمْ يَكْفِ بِرَبِّكَ﴾</q> شاهدًا أن هذا القرآن جاء من الله ﷿ <q>﴿أنَّهُ عَلى كُلِّ شَيْءٍ شَهِيدٌ﴾</q>، كقوله في الأنعام [١٩]: <q>﴿قُلِ اللَّهُ شَهِيدٌ بَيْنِي وبَيْنَكُمْ﴾</q>{10}٥٧٨٠. (ز) ٥٧٨٠ ذكر ابنُ تيمية (٥/٤٦٩) أن القول بعود الضمير على القرآن في قوله: <q>﴿أنه الحق﴾</q> هو قول السلف وعامة العلماء والمفسرين، ثم ذكر قولًا آخر بعوده على الله تعالى. ورجَّح الأول مستندًا إلى السياق، فقال: «والصواب: الأول، كما قال: <q>﴿قل أرأيتم إن كان من عند الله ثم كفرتم به﴾</q> وهذا هو القرآن. ثم قال بعد ذلك: <q>﴿سنريهم آياتنا في الآفاق وفي أنفسهم حتى يتبين لهم أنه الحق﴾</q>، ثم قال: <q>﴿أولم يكف بربك أنه على كل شيء شهيد﴾</q> فأخبر أنّه سيُري الناس في أنفسهم وفي الآفاق من الآيات العيانية المشهودة المعقولة ما يبيّن أنّ الآيات القرآنية المسموعة المتلوّة حق، فيتطابق العقل والسمع، ويتفق العيان والقرآن، وتصدق المعاينة للخبر». ",footnotes:1:عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٦١.أخرجه عبد الرزاق ٢/١٨٩. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٧/١٧٩.ذكره يحيى بن سلام -كما في تفسير ابن أبى زمنين ٤/١٥٩-.تفسير الثعلبي ٨/٣٠٠، وتفسير البغوي ٧/١٧٩.أخرجه ابن جرير ٢٠/٤٦١.تفسير الثعلبي ٨/٣٠٠، وتفسير البغوي ٧/١٧٩.تفسير مقاتل بن سليمان ٣/٧٤٨-٧٤٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٤٦٢.تفسير ابن أبى زمنين ٤/١٦٠.تفسير مقاتل بن سليمان ٣/٧٤٨-٧٤٩.
41,54," <q>﴿أَلَاۤ إِنَّهُمۡ فِی مِرۡیَةࣲ مِّن لِّقَاۤءِ رَبِّهِمۡۗ أَلَاۤ إِنَّهُۥ بِكُلِّ شَیۡءࣲ مُّحِیطُۢ ۝٥٤﴾</q> - قراءات ٦٨٧٦٤- عن عاصم بن بهدلة، عن زِر: <q>﴿ألَآ إنَّهُمْ فِي مِرْيَةٍ﴾</q>= (ز) ٦٨٧٦٥- وعن أبي عبد الرحمن السُلمي: (فِي مُرْيَةٍ مِّن لِّقَآءِ رَبِّهِمْ)= (ز) ٦٨٧٦٦- قال: وقال لنا عاصم: ما رويت عن زِر فهو عن ابن مسعود= (ز) ٦٨٧٦٧- وما رويت عن أبي عبد الرحمن السُلمي فهو عن علي -رضوان الله عليه-{1}. (ز) <q>﴿أَلَاۤ إِنَّهُمۡ فِی مِرۡیَةࣲ مِّن لِّقَاۤءِ رَبِّهِمۡۗ أَلَاۤ إِنَّهُۥ بِكُلِّ شَیۡءࣲ مُّحِیطُۢ ۝٥٤﴾</q> - تفسير الآية ٦٨٧٦٨- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ألا إنَّهُمْ فِي مِرْيَةٍ مِن لِقاءِ رَبِّهِمْ﴾</q>: يقول: في شكٍّ مِن لقاء ربهم{2}. (ز) ٦٨٧٦٩- قال مقاتل بن سليمان: <q>﴿ألا إنَّهُمْ فِي مِرْيَةٍ مِن لِقاءِ رَبِّهِمْ﴾</q>، يعني: في شك مِن البعث وغيره{3}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٢٩٧. و<q>﴿فِي مِرْيَةٍ﴾</q> بكسر الميم قراءة العشرة، وأما (فِي مُرْيَةٍ) بضمّ الميم قراءة شاذة، تروى عن الحسن أيضًا. انظر: المحرر الوجيز ٥/٢٤، والبحر المحيط ٧/٤٨٣.أخرجه ابن جرير ٢٠/٤٦٣.تفسير مقاتل بن سليمان ٣/٧٤٩.
