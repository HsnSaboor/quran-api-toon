quran[20]{c,v,t}:
  76,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَیۡنࣰا یَشۡرَبُ بِهَا عِبَادُ ٱللَّهِ یُفَجِّرُونَهَا تَفۡجِیرࣰا ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٣٩٩<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>أربع عيون في الجنة؛ عينان تَجريان من تحت العرش، إحداهما التي ذَكر الله: <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span>، والأخرى الزَّنجبيل، وعينان نَضّاختان من فوقُ، إحداهما التي ذَكر الله: <span class="qpc-hafs">﴿سَلْسَبِيلًا﴾</span>، والأخرى التّسنيم</b>»{1}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span> أي: يقودونها حيث شاؤوا مِن منازلهم وقصورهم، كمن يكون له نهر يُفَجِّره هاهنا وهاهنا إلى حيث يريد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عَيْنًا يَشْرَبُ بِها عِبادُ اللَّهِ يُفَجِّرُونَها تَفْجِيرًا﴾</span>، قال: يقودونها حيث شاؤوا{3}. (١٥/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span>، قال: الأنهار يُجرونها حيث شاؤوا{4}. (١٥/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عَيْنًا يَشْرَبُ بِها عِبادُ اللَّهِ يُفَجِّرُونَها تَفْجِيرًا﴾</span>، قال: يَسْتَقِيدُ{5} ماؤها، يُفجِّرونها حيث شاؤوا{3}. (١٥/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر الكافور، فقال: <span class="qpc-hafs">﴿عَيْنًا يَشْرَبُ بِها﴾</span> يعني: الخمر <span class="qpc-hafs">﴿عِبادُ اللَّهِ يُفَجِّرُونَها تَفْجِيرًا﴾</span> يعني: أولياء الله يَمزجون ذلك الخمر، ثم يُجاء بذلك الماء، فهو على بَرد الكافور، وطعم الزَّنجبيل، وريح المِسك، لا بمِسك أهل الدنيا ولا زَنجبيلهم ولا كافورهم، ولكن الله تعالى وصف ما عنده بما عندهم لتَهتدي إليه القلوب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٥<span class="dash">-</span></span> عن <span class="name-3">ابن شَوذب</span>، في قوله: <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span>، قال: معهم قُضبان ذهب، يُفجِّرون بها، قال: تَتبع قُضبانهم{8}. (١٥/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span>، قال: يُصَرِّفونها حيث شاؤوا{9}<span class=comment-ref>٦٩٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣١</span> ساق <u>ابنُ عطية</u> (٨/٤٨٩) هذا القول، ثم <span class="comment-type-4">ذكر</span> أنّ الثعلبي نقل أنه قيل بأنها عين في دار النبي ﷺ تَتَفَجَّر إلى دُور الأنبياء ﵈ والمؤمنين، و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا قول حسن».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد مرسلًا.|2:تفسير البغوي ٨/٢٩٣.|3:أخرجه ابن جرير ٢٣/٥٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:يستقيد: يذل لهم. التاج (قود).|6:أخرجه ابن جرير ٢٣/٥٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:تفسير مقاتل بن سليمان ٤/٥٢٤.|8:عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.|9:أخرجه ابن جرير ٢٣/٥٤١.
  76,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُوفُونَ بِٱلنَّذۡرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>-من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ﴾</span>، قال: إذا نَذروا في حقّ الله{1}. (١٥/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ﴾</span>، قال: كلُّ نذرٍ في شكر{2}. (١٥/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ﴾</span>، قال: كانوا يُوفُون بطاعة الله من الصلاة والزَّكاة، والحج والعُمرة، وما افتَرض عليهم، فسمّاهم الله الأبرار لذلك، فقال: <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ ويَخافُونَ يَوْمًا كانَ شَرُّهُ مُسْتَطِيرًا﴾</span>{3}. (١٥/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤١٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- قوله: <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ﴾</span>، قال: في غير معصية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ﴾</span> يعني: مَن نَذر لله نذرًا، فقضى الله حاجته؛ فيُوفي لله بما قد نَذره{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَخَافُونَ یَوۡمࣰا كَانَ شَرُّهُۥ مُسۡتَطِیرࣰا ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يَوْمًا كانَ شَرُّهُ مُسْتَطِيرًا﴾</span>، قال: فاشيًا{6}. (١٥/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يُوفُونَ بِالنَّذْرِ ويَخافُونَ يَوْمًا كانَ شَرُّهُ مُسْتَطِيرًا﴾</span>، قال: استطار -واللهِ- شرُّ ذلك اليوم حتى ملأ السموات والأرض{3}. (١٥/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿ويَخافُونَ يَوْمًا﴾</span> يعني: يوم القيامة <span class="qpc-hafs">﴿كانَ شَرُّهُ مُسْتَطِيرًا﴾</span> يعني: كان شرًّا فاشيًا في أهل السموات والأرض، فانشقّت السماء، وتناثرت الكواكب، وفَزعت الملائكة، وكُوِّرت الشمس والقمر، فذَهب ضوؤهما، وبُدِّلت الأرض، ونُسفت الجبال، وغارت المياه، وتكسّر كلّ شيء على الأرض مِن جبل أو بناء أو شجر، ففَشى شرُّ يوم القيامة فيها{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَخَافُونَ یَوۡمࣰا كَانَ شَرُّهُۥ مُسۡتَطِیرࣰا ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٤١٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: جاء رجل إلى النبيِّ ﷺ، فقال: إني نَذرتُ أنْ أنحر نفسي؟ فشُغل النبيُّ ﷺ، فذَهب الرجل، فوُجد يُريد أن يَنحر نفسه، فقال النبيُّ ﷺ: «<b>الحمد لله الذي جعل في أُمّتي مَن وفّى بالنَّذر ويخاف <span class="qpc-hafs">﴿يَوْمًا كانَ شَرُّهُ مُسْتَطِيرًا﴾</span>، أهْدِ مائة ناقة</b>»{9}. (١٥/١٥١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٤١. وعزاه السيوطي إلى عبد بن حميد.|2:عزاه السيوطي إلى عبد بن حميد.|3:أخرجه عبد الرزاق ٢/٣٣٦، وابن جرير ٢٣/٥٤١-٥٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|4:أخرجه ابن جرير ٢٣/٥٤٢.|5:تفسير مقاتل بن سليمان ٤/٥٢٤.|6:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٨٥-. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه عبد الرزاق ٢/٣٣٦، وابن جرير ٢٣/٥٤١-٥٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٤/٥٢٤.|9:أخرجه عبد الرزاق في مصنفه ٨/٤٦٣ (١٥٩١٤)، والطبراني في الكبير ١١/٤١٠ (١٢١٦٣)،</p><p>قال الجوزقاني في الأباطيل والمناكير والصحاح والمشاهير ٢/٢٠٠-٢٠١ (٥٥٤): «هذا حديث باطل». وقال ابن الجوزي في الموضوعات ٣/١٠٢: «هذا حديث لا يصحّ». وقال الهيثمي في المجمع ٤/١٨٩ (٦٩٧١): «رواه الطبراني في الكبير، وفيه رشدين بن كريب، وهو ضعيف جدًّا جدًّا». وقال الألباني في الضعيفة ١٣/٥٢٨ (٦٢٤٣): «موضوع».
  76,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیُطۡعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ مِسۡكِینࣰا وَیَتِیمࣰا وَأَسِیرًا ۝٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٤١٦<span class="dash">-</span></span> عن عبد الله بن عباس، في قوله: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ﴾</span> الآية، قال: نزلت هذه الآية في علي بن أبي طالب، وفاطمة بنت رسول الله ﷺ{1}. (١٥/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في الآية: وذلك أنّ علي بن أبي طالب ﵁ نَوْبَةً أجَّر نفسه يَسقي نخلًا بشيء مِن شعير ليلة حتى أصبح، وقَبض الشعير، وطَحن ثُلثه، فجعلوا منه شيئًا ليأكلوه، يقال له: الخَزِيرَة{2}، فلما تمّ إنضاجه أتى مسكينٌ، فأَخرَجوا إليه الطعام، ثم عَمل الثُّلث الثاني، فلمّا تم إنضاجُه أتى يتيم، فسأل، فأَطعَموه، ثم عَمل الثُّلث الباقي، فلمّا تمّ إنضاجه أتى أسيرٌ من المشركين، فأَطعَموه، وطَووا يومهم ذلك؛ فأُنزِلَت فيه هذه الآية{3}<span class=comment-ref>٦٩٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ تيمية</u> (٦/٤٣٩) القول بنزول الآية في علي وفاطمة وابنيهما <span class="mustanad">مستندًا لأحوال النزول، والنظائر، والواقع</span>، فقال: «أمّا نزول: <span class="qpc-hafs">﴿هل أتى﴾</span> في عليٍّ فمما اتفق أهل العلم بالحديث على أنه كذبٌ موضوع، وإنما يذكره من المفسرين مَن جرتْ عادته بذكر أشياء من الموضوعات، والدليل الظاهر على أنه كذبٌ: أنّ سورة <span class="qpc-hafs">﴿هل أتى﴾</span> مكّيّة باتفاق الناس، نزلت قبل الهجرة، وقبل أن يتزوج عليٌّ بفاطمة، ويُولد الحسن والحُسين، ... ولم يَنزل قطّ قرآنٌ في إنفاق علي بخصوصه؛ لأنه لم يكن له مال، بل كان قبل الهجرة في عيال النبي ﷺ، وبعد الهجرة كان أحيانًا يُؤجّر نفسه كلّ دلو بتمرة، ولما تزوّج بفاطمة لم يكن له مهر إلا دِرعه، وإنما أنفق على العُرس ما حصل له من غزوة بدر».</div></p><p><div></p><p><p><span class="item-no">٨٠٤١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في الآية، قال:لم يكن النبيُّ يَأسِر أهلَ الإسلام، ولكنها نزلت في أُسارى أهل الشّرك، كانوا يَأسِرونهم في الغزو، فنَزلت فيهم، فكان النبيُّ ﷺ يَأمر بالإصلاح لهم{4}. (١٥/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ﴾</span> أي: على حُبّهم الطعام <span class="qpc-hafs">﴿مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span> نزلت في أبي الدّحداح الأنصاري، ويقال: في علي بن أبي طالب ﵁، وذلك أنه صام يومًا، فلمّا أراد أن يُفطر دعا سائلٌ، فقال: عَشُّوني بما عندكم؛ فإني لم أُطْعَمِ اليومَ شيئًا. قال أبو الدّحداح أو عليٌّ: قُومي، فاثردي رغيفًا، وصُبّي عليه مرقة، وأَطعميه. ففَعلتْ ذلك، فما لبثوا أن جاءتْ جاريةٌ يتيمةٌ، فقالت: أطعموني؛ فإني ضعيفة لم أُطْعَمِ اليوم شيئًا. قال: يا أُمّ الدّحداح، قُومي، فاثردي رغيفًا، وأَطعميها، فإنّ هذه -واللهِ- أحقُّ مِن ذلك المسكين. فبينما هم كذلك إذ جاء على الباب سائل أسيرٌ ينادي: عَشّوا الغريب في بلادكم، فإني أسيرٌ في أيديكم، وقد أجهدني الجوع، فبالذي أعزّكم وأذلّني، لما أطعمتموني. فقال أبو الدّحداح: يا أُمّ الدّحداح، قُومي، ويحكِ، فاثردي رغيفًا، وأَطعمي الغريب الأسير، فإنّ هذا أحقّ من أولئك. فأَطعموا ثلاث أرغفة، وبقي لهم رغيف واحد؛ فأنزل الله -تبارك وتعالى- فيهم يَمدحهم بما فَعلوا، فقال: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُطۡعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٢٠<span class="dash">-</span></span> عن أُمّ الأسود سُرِّية <span class="name-2">الربيع بن خُثَيم</span>، قالت: كان <span class="name-2">الربيع</span> يُعجبه السُّكر يأكله، فإذا جاء السائل ناوله، فقلتُ: ما يَصنع بالسُّكر؟! الخبزُ خيرٌ له. قال: إني سمعتُ الله يقول: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ﴾</span>{6}. (١٥/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ﴾</span>، قال: وهم يَشتهُونه{7}. (١٥/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٢<span class="dash">-</span></span> عن أبي العُريان، قال: سألتُ سليمان بن قيس -أبا مقاتل بن سليمان- عن قوله: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا﴾</span>، قال: على حُبّهم للطعام{8}<span class=comment-ref>٦٩٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٣</span> على هذا القول فالضمير في قوله: <span class="qpc-hafs">﴿حبه﴾</span> عائد على الطعام، وهو ما ذكره <u>ابنُ عطية</u> (٨/٤٩٠)، ثم <span class="comment-type-4">ذكر</span> احتمالًا آخر بعوْده على الله تعالى، أي: لوجهه وابتغاء مرضاته، ونسبه لأبي سليمان الدّاراني. ثم <span class="comment-type-4">علَّق</span> بقوله: «والأول أمدح لهم؛ لأنّ فيه الإيثار على النفس، وعلى الاحتمال الثاني فقد يفعله الأغنياء أكثر».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٢٠٩ بتصرف) أنّ من قال بعوْد الضمير على الله تعالى فذلك <span class="mustanad">لدلالة السياق عليه</span>.</p><p>ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى النظائر</span>- عوْده على الطعام، فقال: «والأظهر أنّ الضمير عائد على الطعام، كقوله تعالى: <span class="qpc-hafs">﴿وآتى المال على حبه﴾</span> [البقرة:١٧٧]، وكقوله تعالى: <span class="qpc-hafs">﴿لن تنالوا البر حتى تنفقوا مما تحبون﴾</span> [آل عمران:٩٢]».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أنّ الحسين بن الفضل قال بعوْد الضمير على الإطعام، و<span class="comment-type-4">علَّق</span> عليه (٥/٤١٠ ط: دار الكتب العلمية) بقوله: «أي: مُحبّين في فعلهم ذلك، لا رياء فيه ولا تكلف».</div></p><p><h3><span class="qpc-hafs">﴿مِسۡكِینࣰا وَیَتِیمࣰا وَأَسِیرًا ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٢٣<span class="dash">-</span></span> عن أبي سعيد، عن النبيّ ﷺ، في قول الله: <span class="qpc-hafs">﴿مِسْكِينًا﴾</span> قال: «<b>فقيرًا</b>». <span class="qpc-hafs">﴿ويَتِيمًا﴾</span> قال: «<b>لا أب له</b>». <span class="qpc-hafs">﴿وأَسِيرًا﴾</span> قال: «<b>المملوك والمسجون</b>»{9}. (١٥/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح- في قوله: <span class="qpc-hafs">﴿وأَسِيرًا﴾</span>، قال: هو المُشرك{10}. (١٥/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٥<span class="dash">-</span></span> عن أبي رَزِين، قال: كنتُ مع <span class="name-2">شَقيق بن سَلمة</span>، فمَرّ عليه أُسارى مِن المشركين، فأَمرني أنْ أتصدّق عليهم. ثم تلا هذه الآية: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span>{11}. (١٥/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٧<span class="dash">-</span></span> و<span class="name-2">عطاء</span> -من طريق عمرو بن مُرّة- <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span>، قالا: من أهل القِبلة وغيرهم{12}. (١٥/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وأَسِيرًا﴾</span>، قال: هو المسجون{13}<span class=comment-ref>٦٩٣٤</span>. (١٥/١٥٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٤</span> ساق <u>ابنُ عطية</u> (٨/٤٩٠) هذا القول الذي قاله مجاهد، وعطاء، وابن جُبَير، ثم <span class="comment-type-4">علَّق</span> بقوله: «ولهذا يحضّ على صدقة السجن، فهذا تشبيه، ومنه قول عمر بن الخطاب ﵁: لا يُؤسر أحد في الإسلام بغير العدول».</div></p><p><div></p><p><p><span class="item-no">٨٠٤٢٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَسِيرًا﴾</span>، قال: ما أسَرت العرب من الهند وغيرهم، فإذا حُبسوا فعليكم أن تُطعموهم وتُسقوهم حتى يُقتلوا أو يُفدَوا{14}. (١٥/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي عمرو- قال في قوله: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span>: زعم أنه قال: كان الأَسرى في ذلك الزمانِ المُشرك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عثمان- قال: كان الأُسارى مشركين يوم نزلت هذه الآية: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span>{16}<span class=comment-ref>٦٩٣٥</span>. (١٥/١٥٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٥</span> ساق <u>ابنُ عطية</u> (٨/٤٩٠) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «لأنّ في كلّ كبد رَطبة أجرًا».</p><p>و<span class="comment-type-4">علَّق</span> عليه <u>ابنُ كثير</u> (١٤/٢١٠)، بقوله: «ويشهد لهذا <span class="mustanad">أنّ رسول الله ﷺ أمَر</span> أصحابه يوم بدر أن يُكرموا الأُسارى، فكانوا يُقدّمونهم على أنفسهم عند الغداء».</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> أنّ بعض العلماء قال: هذا إمّا نُسخ بآية السيف، وإمّا أنه مُحكمٌ لتُحفظ حياة الأسير إلى أن يَرى الإمام فيه ما يَرى.</div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في الآية، قال: لقد أمَر الله بالأُسارى أن يُحسن إليهم، وإنهم يومئذ لمشركون، فواللهِ، لَأخوك المسلم أعظم عليك حُرْمةً وحقًّا{17}. (١٥/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٣<span class="dash">-</span></span> قال <span class="name-2">أبو حمزة الثُّمالي</span>: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span> الأسير: المرأة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُطْعِمُونَ الطَّعامَ عَلى حُبِّهِ مِسْكِينًا ويَتِيمًا وأَسِيرًا﴾</span> يعني باليتيم: مَن لا أب له ولا أُمَّ، <span class="qpc-hafs">﴿وأَسِيرًا﴾</span> مِن أسارى المشركين{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وأَسِيرًا﴾</span>، قال: لم يكن الأسير على عهد رسول الله ﷺ إلا مِن المشركين{20}<span class=comment-ref>٦٩٣٦</span>. (١٥/١٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٦</span> اختُلف في المراد بالأسير في هذه الآية على أقوال: <b>الأول</b>: أنه الأسير من أهل الشّرك. <b>الثاني</b>: أنه المسجون من أهل القِبلة. <b>الثالث</b>: المرأة. و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٥٤٣-٥٤٤) أنّ «الأسير» هو الحربيّ من أهل دار الحرب يؤخذ قهرًا بالغلبة، أو من أهل القِبلة يؤخذ فيُحبس بحقٍّ.</p><p>ثم <span class="comment-type-3">رجَّح</span> (٢٣/٥٤٥) <span class="mustanad">العموم</span> في الآية، فقال: «والصواب من القول في ذلك أن يقال: إنّ الله وصف هؤلاء الأبرار بأنهم كانوا في الدنيا يُطعمون الأسير، والأسير الذي قد وصفت صفته؛ واسم الأسير قد يَشتمل على الفريقين، وقد عمّ الخبر عنهم أنهم يُطعمونهم، فالخبر على عمومه حتى يخصّه ما يجب التسليم له». ثم قال: «وأما قول مَن قال: لم يكن لهم أسيرٌ يومئذ إلا أهل الشّرك، فإنّ ذلك وإن كان كذلك فلم يخصص بالخبر المُوفون بالنذر يومئذ، وإنما هو خبرٌ من الله عن كلّ من كانت هذه صفته يومئذ وبعده إلى يوم القيامة، وكذلك الأسير معنيٌ به أسير المشركين والمسلمين يومئذ وبعد ذلك إلى قيام الساعة».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٤٩٠) على القول الثالث الذي قاله حمزة الثُّمالي، بقوله: «<span class="mustanad">ودليله قوله</span> ﷺ: «<b>استوصوا بالنساء خيرًا؛ فإنهن عوان عندكم</b>»».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:الخزيرة: لحم يُقطّع صغارًا، ويُصبّ عليه ماء كثير، فإذا نَضِج ذُرَّ عليه الدقيق، فإن لم يكن فيها لحم فهي عصيدة. النهاية (خزر).|3:أورده الواحدي في أسباب النزول ص٤٤٨، وابن الجوزي في التبصرة ١/٤٥٤، وأخرجه الثعلبي ١٠/٩٨-١٠٢ بنحوه مطولًا جدًّا من طريق الكلبي، عن أبي صالح، ومن طريق ليث، عن مجاهد.</p><p>والكلبي واهٍ جدًّا، وليث هو ابن أبي سُليم ضعيف الحفظ. وتقدّم الكلام عليهما مرارًا.|4:عزاه السيوطي إلى ابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٥٢٥. وأشار إلى قوله الثعلبي ١٠/٩٨ منسوبًا إلى مقاتل مهملًا، ثم ساق الخبر بسنده من طريق علي بن علي عن أبي حمزة الثُّمالي في قصة رجل من الأنصار.|6:أخرجه ابن سعد ٦/١٨٨.|7:أخرجه عبد الرزاق ٢/٣٣٦، وابن جرير ٢٣/٥٤٣، والبيهقي (٦٨٩٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:أخرجه ابن جرير ٢٣/٥٤٣.|9:أخرجه أبو نعيم ٥/١٠٥. وعزاه السيوطي إلى ابن مردويه.</p><p>قال أبو نعيم: «غريب من حديث عمرو، تفرّد به عبّاد عن عمّه».|10:أخرجه عبد الرزاق ٢/٣٣٧. وعزاه السيوطي إلى ابن المنذر.|11:أخرجه ابن أبي شيبة ٣/١٧٧.|12:أخرجه ابن جرير ٢٣/٥٤٥، وابن أبي شيبة ٣/١٧٧-١٧٨.|13:أخرجه عبد الرزاق ٢/٣٣٦، وابن جرير ٢٣/٥٤٤، والبيهقي (٦٨٩٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|14:عزاه السيوطي إلى عبد بن حميد.|15:أخرجه ابن جرير ٢٣/٥٤٤.|16:أخرجه ابن أبي شيبة ٣/١٧٨، والبيهقي ٩/١٢٩-١٣٠. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن مردويه. كما أخرج نحوه ابن جرير ٢٣/٥٤٤ من طريق أشعث بلفظ: ما كان أسراهم إلا المشركين.|17:أخرجه عبد الرزاق ٢/٣٣٦، وابن جرير ٢٣/٥٤٤ بنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|18:تفسير الثعلبي ١٠/٩٦.|19:تفسير مقاتل بن سليمان ٤/٥٢٥.|20:أخرجه أبو عبيد في غريب الحديث ٤/٣٥٠-٣٥١، والبيهقي (٩١٥٧).
  76,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّمَا نُطۡعِمُكُمۡ لِوَجۡهِ ٱللَّهِ لَا نُرِیدُ مِنكُمۡ جَزَاۤءࣰ وَلَا شُكُورًا ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٣٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- <span class="qpc-hafs">﴿إنَّما نُطْعِمُكُمْ لِوَجْهِ اللَّهِ لا نُرِيدُ مِنكُمْ جَزاءً ولا شُكُورًا﴾</span>، قال: أما -واللهِ- ما قالوه بألسنتهم، ولكن عَلمه الله مِن قلوبهم، فأَثنى عليهم؛ لِيَرْغَب في ذلك راغبٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سالم- في قوله: <span class="qpc-hafs">﴿إنَّما نُطْعِمُكُمْ لِوَجْهِ اللَّهِ﴾</span> الآية، قال: لم يقُل القوم ذلك حين أطعموهم، ولكن عَلِم اللهُ مِن قلوبهم، فأَثنى به عليهم؛ ليَرْغَب فيه راغبٌ{2}. (١٥/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّما نُطْعِمُكُمْ لِوَجْهِ اللَّهِ﴾</span> يعني: لمرضات الله تعالى، <span class="qpc-hafs">﴿لا نُرِيدُ مِنكُمْ جَزاءً ولا شُكُورًا﴾</span> يعني: أن تُثنوا به علينا{3}<span class=comment-ref>٦٩٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٤٩٠): «قوله تعالى: <span class="qpc-hafs">﴿إنما نطعمكم لوجه الله﴾</span> المعنى: يقولون لهم عند الإطعام، وهذا إمّا أن يكون المُطعِم يقول ذلك نصًّا فحكي ذلك، وإمّا أن يكون ذلك مما يقال في الأنفس وبالنية، فمدح بذلك. هذا هو تأويل مجاهد، وابن جُبَير».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٤٦.|2:أخرجه عبد الرزاق ٢/٣٣٦-٣٣٧، وابن جرير ٢٣/٥٤٦، والبيهقي (٦٨٩٧). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧١-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥٢٥.
  76,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا نَخَافُ مِن رَّبِّنَا یَوۡمًا عَبُوسࣰا قَمۡطَرِیرࣰا ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٣٩<span class="dash">-</span></span> عن أنس بن مالك، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>، قال: «<b>يَقبِض ما بين الأبصار</b>»{1}. (١٥/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمًا عَبُوسًا﴾</span> قال: ضَيّقًا، <span class="qpc-hafs">﴿قَمْطَرِيرًا﴾</span> قال: طويلًا{2}. (١٥/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿عَبُوسًا قَمْطَرِيرًا﴾</span>، قال: يَعْبِس الكافر يومئذ حتى يَسيل من بين عينيه عرقٌ مثل القَطِران{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>، قال: الذي يَنقبِض وجهه من شِدّة الوجع. قال: وهل تعرف العرب ذلك؟ قال: نعم. أما سمعتَ قول الشاعر وهو يقول:</p><p>ولا يوم الحَساب وكان يومًا عَبوسًا في الشدائد قمطريرا{4}. (١٥/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طرق- قال: <span class="qpc-hafs">﴿إنّا نَخافُ مِن رَبِّنا يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>، القَمْطَرير: الرجل المُنقبِض ما بين عينيه ووجهه{5}. (١٥/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- في قوله: <span class="qpc-hafs">﴿يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>، قال: يُقَبِّض ما بين العينين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿قَمْطَرِيرًا﴾</span>، قال: يُقَبِّضُ الوجه بالبُسُور{7}{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿يَوْمًا﴾</span> قال: يوم القيامة <span class="qpc-hafs">﴿عَبُوسًا﴾</span> قال: العابس الشَّفتَيْن، <span class="qpc-hafs">﴿قَمْطَرِيرًا﴾</span> قال: تُقبَض الوجوه بالبسور. وفي لفظ: انقباض ما بين عينيه ووجهه{9}. (١٥/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي عمرو- قال: القَمْطَرير: ما يَخرج مِن جباههم مثل القَطِران، فيَسيل على وجوههم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>، قال: يومًا تُقبض فيه الجباه من شِدّته{11}. (١٥/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إنّا نَخافُ مِن رَبِّنا يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>: عَبَستْ فيه الوجوه، وقَبَّضتْ ما بين أعينها كراهية ذلك اليوم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: العَبُوس: الذي لا انبساط فيه. والقمطرير: الشديد{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا نَخافُ مِن رَبِّنا يَوْمًا عَبُوسًا﴾</span> يعني: يوم الشِّدّة، <span class="qpc-hafs">﴿قَمْطَرِيرًا﴾</span> يعني: إذا عَرق الجبين فسال العَرق بين عينيه من شِدّة الهول{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنّا نَخافُ مِن رَبِّنا يَوْمًا عَبُوسًا قَمْطَرِيرًا﴾</span>، قال: العَبُوس: الشّرّ. والقَمْطَرير: الشديد{8}<span class=comment-ref>٦٩٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٨</span> أفادت الآثار أنّ البعض عبّر عن القَمْطَرير بالطويل، والبعض عبّر عنه بالشديد، وهو ما <span class="comment-type-4">علَّق</span> عليه <u>ابنُ عطية</u> (٨/٤٩٢) بقوله: «وذلك كلّه قريب في المعنى».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٢١١) -<span class="mustanad">مستندًا إلى اللغة</span>- أنّ تفسيره بالطويل هو أوضح العبارات، وأجلاها، وأحلاها، وأعلاها، وأولاها. ولم يذكر مستندًا.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن جرير ٢٣/٥٤٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ٢٣/٥٤٧، ٥٤٩.|4:أخرجه الطستي -كما في الإتقان ٢/٩٠-.|5:عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرج نحوه ابن جرير ٢٣/٥٤٧-٥٤٨ من طريق عطية، وعنترة.|6:أخرجه ابن جرير ٢٣/٥٤٨.|7:بالبُسُور: يقال: بَسَرَ يَبْسُر بَسْرًا وبُسُورا: عَبَسَ. اللسان والقاموس (بسر).|8:أخرجه ابن جرير ٢٣/٥٤٩.|9:عزاه السيوطي إلى عبد بن حميد. وأخرج نحوه ابن جرير مختصرًا ٢٣/٥٤٨ من طريق عمر بن ذر، ولفظه: هو المُقبِّض ما بين عينيه.|10:أخرجه ابن جرير ٢٣/٥٤٩.|11:أخرجه عبد الرزاق ٢/٣٣٧، وابن جرير ٢٣/٥٤٨. وعزاه السيوطي إلى عبد بن حميد.|12:أخرجه ابن جرير ٢٣/٥٤٨.|13:تفسير الثعلبي ١٠/٩٧، وتفسير البغوي ٨/٢٩٥.|14:تفسير مقاتل بن سليمان ٤/٥٢٥.|15:أخرجه ابن جرير ٢٣/٥٤٩.
  76,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَقَىٰهُمُ ٱللَّهُ شَرَّ ذَ ٰ⁠لِكَ ٱلۡیَوۡمِ وَلَقَّىٰهُمۡ نَضۡرَةࣰ وَسُرُورࣰا ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ولَقّاهُمْ نَضْرَةً وسُرُورًا﴾</span>، قال: نَضرةً في وجوههم، وسرورًا في صدورهم{1}. (١٥/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿ولَقّاهُمْ نَضْرَةً﴾</span> قال: في الوجوه، <span class="qpc-hafs">﴿وسُرُورًا﴾</span> قال: في الصدور والقلوب{2}. (١٥/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولَقّاهُمْ نَضْرَةً وسُرُورًا﴾</span> قال: نَضرةً في وجوههم، وسرورًا في قلوبهم{3}. (١٥/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿نضرة وسرورا﴾</span>، قال: الزّهرة في الوجه، والسرور في الصدر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فشَكر الله أمْرهم، فقال: <span class="qpc-hafs">﴿فَوَقاهُمُ اللَّهُ شَرَّ ذلِكَ اليَوْمِ﴾</span> يعني: يوم القيامة شرّ جهنم، <span class="qpc-hafs">﴿ولَقّاهُمْ نَضْرَةً وسُرُورًا﴾</span> نَضرةً في الوجوه، وسرورًا في القلوب، وذلك أنّ المسلم إذا خَرج من قبره يوم القيامة نَظر أمامه، فإذا هو بإنسان وجهه مثل الشمس يَضحك، طيّب النفس، وعليه ثياب بِيض، وعلى رأسه تاج، فيَنظر إليه حتى يَدنو منه، فيقول: سلام عليك، يا وليّ الله. فيقول: وعليك السلام، مَن أنت يا عبد الله؟ أنت مَلَك من الملائكة؟ فيقول: لا، واللهِ. فيقول: أنتَ نبي من الأنبياء؟ فيقول: لا، والله. فيقول: أنتَ من المُقرّبين؟ فيقول: لا، والله. فيقول: مَن أنتَ؟ فيقول: أنا عملك الصالح، أُبشِّرك بالجنة، والنجاة من النار. فيقول له: يا عبد الله، أبعلمٍ تُبشّرني؟ فيقول: نعم. فيقول: ما تريد مني؟ فيقول له: اركبني. فيقول: يا سبحان الله، ما ينبغي لمثلك أن يُركب عليه. فيقول: بلى، فإني طالما رَكبتك في دار الدنيا، فإنى أسألك بوجه الله إلا ما رَكبتني. فيركبه، فيقول: لا تَخفْ، أنا دليلك إلى الجنة. فيعمّ ذلك الفرح في وجهه حتى يتلألأ، ويُرى النورُ والسرورُ في قلبه، فذلك قوله: <span class="qpc-hafs">﴿ولَقّاهُمْ نَضْرَةً وسُرُورًا﴾</span>...{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٥٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَقّاهُمْ نَضْرَةً وسُرُورًا﴾</span>، قال: نِعمة وسرورًا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَوَقَىٰهُمُ ٱللَّهُ شَرَّ ذَ ٰ⁠لِكَ ٱلۡیَوۡمِ وَلَقَّىٰهُمۡ نَضۡرَةࣰ وَسُرُورࣰا ۝١١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٥٩<span class="dash">-</span></span> عن علي بن زُفر السّعدي، قال: كان <span class="name-2">الأَحْنَف بن قيس</span> يريد الصوم، فقيل له في ذلك، فقال: إني أُعِدّه ليومٍ شَرّه طويل. ثم تلا: <span class="qpc-hafs">﴿فَوَقاهُمُ اللَّهُ شَرَّ ذَلِكَ اليَوْمِ﴾</span>{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٨- من طريق المبارك بنحوه، وابن جرير ٢٣/٥٥٠، وعبد بن حميد -كما في التغليق ٣/٤٩٩-٥٠٠، وفتح الباري ٦/٣٢١-. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ٢٣/٥٥٠. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.|5:تفسير مقاتل بن سليمان ٤/٥٢٦-٥٢٧.|6:أخرجه ابن جرير ٢٣/٥٥٠.|7:أخرجه ابن أبي الدنيا في الأهوال ٦/١٣٦ (١٦).
  76,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَزَىٰهُم بِمَا صَبَرُوا۟ جَنَّةࣰ وَحَرِیرࣰا ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٦٠<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وجَزاهُمْ بِما صَبَرُوا﴾</span> على الفقر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وجَزاهُمْ بِما صَبَرُوا جَنَّةً وحَرِيرًا﴾</span> أدخَلهم الله الجنة، وأَلبسَهم الحرير{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٢<span class="dash">-</span></span> عن أبي حمزة الثُّمالي، عن <span class="name-2">أبي جعفر</span>، في قوله ﷿: <span class="qpc-hafs">﴿وجزاهم بما صبروا جنة وحريرًا﴾</span>، قال: بما صَبروا على الفقر، ومصائب الدنيا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وجَزاهُمْ بِما صَبَرُوا جَنَّةً وحَرِيرًا﴾</span>، قال: الصبر صبران: صبر على طاعة الله، وصبر عن معصية الله{4}. (١٥/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجَزاهُمْ بِما صَبَرُوا جَنَّةً وحَرِيرًا﴾</span>، يقول: وجزاهم بما صبروا على طاعة الله، وصبروا عن معصيته ومحارمه جنة وحريرًا {5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٥<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وجَزاهُمْ بِما صَبَرُوا﴾</span> على الجوع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٦<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿وجَزاهُمْ بِما صَبَرُوا﴾</span> على الصوم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر أولياءه، فقال: <span class="qpc-hafs">﴿وجَزاهُمْ﴾</span> بعد البشارة <span class="qpc-hafs">﴿بِما صَبَرُوا على البلاء جَنَّةً وحَرِيرًا﴾</span> فأمّا الجنة فيَتنعّمون فيها، وأمّا الحرير فيَلبسونه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٦٨<span class="dash">-</span></span> عن أحمد بن أبي الحواري، قال: سمعتُ <span class="name-3">أبا سليمان [الدّاراني]</span> يقول في قوله تعالى: <span class="qpc-hafs">﴿وجزاهم بما صبروا﴾</span>، قال: بما صبروا عن الشهوات{9}<span class=comment-ref>٦٩٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٣٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٩٢) أنّ قوله تعالى: <span class="qpc-hafs">﴿بما صبروا﴾</span> عامٌّ؛ عن الشهوات، وعلى الطاعات، والشدائد، ثم <span class="comment-type-4">علَّق</span> بقوله: «ففي هذا يدخل كلّ ما خَصَّ الناس من صوم وفقر ونحوه».</div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٩٧، وتفسير البغوي ٨/٢٩٥.|2:تفسير الثعلبي ١٠/٩٧، وتفسير البغوي ٨/٢٩٥.|3:أخرجه أبو نعيم في حلية الأولياء ١/٣٤٧.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٣/٥٥٠-٥٥١.|6:تفسير الثعلبي ١٠/٩٧، وتفسير البغوي ٨/٢٩٥.|7:تفسير الثعلبي ١٠/٩٧.|8:تفسير مقاتل بن سليمان ٤/٥٢٧.|9:أخرجه أبو نعيم في حلية الأولياء ٩/٢٦٨، وابن عساكر في تاريخ دمشق ١٥/٣٠٦.
  76,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُّتَّكِـِٔینَ فِیهَا عَلَى ٱلۡأَرَاۤىِٕكِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿مُتَّكِئِينَ فِيها عَلى الأَرائِكِ﴾</span>: يعني: الحِجال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن</span> <span class="name-2">جبر</span> -من طريق الحصين- <span class="qpc-hafs">﴿مُتَّكِئِينَ فِيها عَلى الأَرائِكِ﴾</span>، قال: السُّرر في الحِجال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿مُتَّكِئِينَ فِيها عَلى الأَرائِكِ﴾</span>، قال: كُنّا نُحدّث أنها الحِجال على السُّرر{3}. (١٥/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحسن بن يزيد الأصمّ- في قوله: <span class="qpc-hafs">﴿على الأرائك﴾</span>، قال: الحِجال على السُّرر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿على الأرائك﴾</span>، قال: السُّرر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ فِيها عَلى الأَرائِكِ﴾</span>، يعني: على السُّرر عليها الحِجال{6}<span class=comment-ref>٦٩٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٤٩٢) على هذا القول بقوله: «هذا شرط <span class="mustanad">لبعض اللغويين</span>». ثم <span class="comment-type-4">ذكر</span> أنّ بعض اللغويين قال: «كلّ ما يُتوسّد ويُفتَرش مما له حشو فهو أريكة، وإن لم يكن في حَجَلة».</div></p><p><h3><span class="qpc-hafs">﴿لَا یَرَوۡنَ فِیهَا شَمۡسࣰا وَلَا زَمۡهَرِیرࣰا ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٧٥<span class="dash">-</span></span> عن أبي هريرة، عن رسول الله ﷺ، في قوله: <span class="qpc-hafs">﴿لا يَرَوْنَ فِيها شَمْسًا ولا زَمْهَرِيرًا﴾</span>، قال: «<b>اشتكت النارُ إلى ربّها، فقالت: يا ربِّ، أكل بعضي بعضًا؛ فنَفِّسْني. فجَعل لها في كل عام نَفَسَيْن؛ نفسًا في الشتاء، ونفسًا في الصيف، فشِدّة البرد الذي تَجدون من زَمهرير جهنم، وشِدّة الحرّ الذي تَجدون من حرّ جهنم</b>»{7}. (١٥/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: الزّمهرير إنما هو لون من العذاب، إنّ الله تعالى قال: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</span> [النبأ:٢٤]{8}. (١٥/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٧<span class="dash">-</span></span> عن <span class="name-2">مُرّة بن عبد الله</span>{9} -من طريق السُّدِّيّ- قال في الزّمهرير: إنه لون من العذاب، قال الله: <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها بَرْدًا ولا شَرابًا﴾</span> [النبأ:٢٤]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿ولا زَمْهَرِيرًا﴾</span>. قال: كذلك أهل الجنة لا يُصيبهم حرّ الشمس فيؤذيهم، ولا البرد. قال: وهل تعرف العرب ذلك؟ قال: نعم. أما سمعتَ الأعشى وهو يقول:</p><p>بَرَهْرَهة{11} الخلق مثل الفَنيـ ـق{12} لم تَر شمسًا ولا زمهرِيرا{13}. (١٥/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٧٩<span class="dash">-</span></span> قال <span class="name-2">مُرّة الهَمداني</span>: <span class="qpc-hafs">﴿ولا زَمْهَرِيرًا﴾</span>، الزّمهرير: البرد القاطع{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- في قوله: <span class="qpc-hafs">﴿ولا زَمْهَرِيرًا﴾</span>، قال: بردًا مُفْظِعًا{15}. (١٥/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الزّمهرير: هو البرد الشديد{16}. (١٥/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لا يَرَوْنَ فِيها شَمْسًا ولا زَمْهَرِيرًا﴾</span>، قال: عَلِم اللهُ -تبارك وتعالى- أنّ شِدّة الحرّ تؤذي، وأنّ شِدّة البرد تؤذي، فَوقاهم الله عذابهما جميعًا. قال: وذُكر لنا: أنّ نبي الله ﷺ حدّث أنّ جهنم اشتكتْ إلى ربّها، فنفَّسها في كلّ عام نفَسَيْن؛ فشِدّة الحرّ من حرّها، وشِدّة البرد من زمهريرها{17}. (١٥/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿زمهريرا﴾</span>، قال: البرد الشديد{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَرَوْنَ فِيها شَمْسًا﴾</span> لا يُصيبهم حرّ الشمس، <span class="qpc-hafs">﴿ولا زَمْهَرِيرًا﴾</span> يعني: ولا يُصيبهم برد الزّمهرير؛ لأنه ليس فيها شتاء ولا صيف{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: <span class="qpc-hafs">﴿ولا زَمْهَرِيرًا﴾</span> هو شيء مثل رؤوس الإبَر، ينزل من السماء، في غاية البرد{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یَرَوۡنَ فِیهَا شَمۡسࣰا وَلَا زَمۡهَرِیرࣰا ۝١٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٨٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>اشتكت النارُ إلى ربّها، فقالت: يا ربِّ، أكل بعضي بعضًا. فجَعل لها نَفَسَيْن؛ نفسًا في الشتاء، ونفسًا في الصيف، فشِدّة ما تَجدون من البرد من زَمهريرها، وشِدّة ما تجدون في الصيف من الحرّ من سَمومها</b>»{21}. (١٥/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٧<span class="dash">-</span></span> عن أبي سعيد الخُدري أو أبي هريرة، عن رسول الله ﷺ أنه قال: «<b>إذا كان يوم حارٌّ ألقى الله سمْعه وبصره إلى أهل السماء وأهل الأرض، فإذا قال العبد: لا إله إلا الله، ما أشدّ حرّ هذا اليوم! اللهم، أجِرني من حرّ جهنم. قال الله ﷿ لجهنم: إنّ عبدًا من عبيدي استجارني منك، وإني أُشهِدكِ أني قد أجَرتُه. وإذا كان يومٌ شديد البرد ألقى الله سمْعه وبصره إلى أهل السماء وأهل الأرض، فإذا قال العبد: لا إله إلا الله، ما أشدّ برد هذا اليوم! اللهم، أجِِرني من زَمهرير جهنم. قال الله لجهنم: إنّ عبدًا من عبيدي استجارني من زَمهريركِ، وإني أُشهِدكِ أني قد أجَرتُه</b>». فقالوا: وما زَمهرير جهنم؟ قال: بيت يُلقى فيه الكافر، فيَتميّز مِن شِدّة بَردها بعضه من بعض{22}. (١٥/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عَلقمة- قال: الجنة سَجْسَج{23}؛ لا قرَّ فيها، ولا حَرَّ{24}. (١٥/١٥٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٥١.|2:أخرجه ابن جرير ٢٣/٥٥١.|3:أخرجه ابن جرير ٢٣/٥٥١. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٢٧ (٢٣٦١).|5:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.|6:تفسير مقاتل بن سليمان ٤/٥٢٧.|7:أخرجه البخاري (٥٣٦، ٣٢٦٠)، ومسلم (٦١٧)، وعبد الرزاق ٣/٣٧٥ (٣٤٢٩) واللفظ له.|8:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|9:قال محققوه: «كذا في النسخ». صوابه: مرة عن <span class="name-1">عبد الله</span>. ويشهد له الأثر السابق.|10:أخرجه ابن جرير ٢٣/٥٥٢.|11:البرهرهة: التي لها بريق من صفائها. اللسان (بره).|12:الفنيق: الفحل المكرم من الإبل، الذي لا يُركب لكرامته عندهم. اللسان (فنق).|13:أخرجه الطستي -كما في الإتقان ٢/٩٠-.|14:تفسير الثعلبي ١٠/٩٨.|15:أخرجه ابن جرير ٢٣/٥٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|16:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|17:أخرجه ابن جرير ٢٣/٥٥٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|18:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٥.|19:تفسير مقاتل بن سليمان ٤/٥٢٧.|20:تفسير الثعلبي ١٠/٩٨.|21:أخرجه البخاري ١/١١٣ (٥٣٧)، ٤/١٢٠ (٣٢٦٠)، ومسلم ١/٤٣١، ٤٣٢ (٦١٧)، وعبد الرزاق ٣/٣٧٥ (٣٤٢٩)، وابن جرير ٢٣/٥٥٢، جميعهم بنحوه.|22:أخرجه ابن السني في عمل اليوم والليلة ص٢٦٥ (٣٠٦)، والبيهقي في الأسماء والصفات ١/٤٥٩-٤٦٠ (٣٨٧).</p><p>قال السخاوي في المقاصد الحسنة ص٧١٤ (١٢٨٣): «سنده ضعيف». وقال العجلوني في كشف الخفاء ٢/٤٢٦ (٢٩٨٢): «سند ضعيف». وقال الألباني في الضعيفة ١٣/٩٥٠-٩٥١ (٦٤٢٨): «منكر».|23:سجسج: معتدل. النهاية (سجسج).|24:أخرجه ابن أبي شيبة ١٣/١٠٠.
  76,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَدَانِیَةً عَلَیۡهِمۡ ظِلَـٰلُهَا وَذُلِّلَتۡ قُطُوفُهَا تَذۡلِیلࣰا ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٨٩<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق أبي إسحاق- في قوله: <span class="qpc-hafs">﴿ودانِيَةً عَلَيْهِمْ ظِلالُها﴾</span> قال: قريبة، <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span> قال: إنّ أهل الجنة يأكلون مِن ثمار الجنة قيامًا، وقعودًا، ومُضطجعين، وعلى أي حال شاؤوا. وفي لفظ قال: ذُلِّلتْ لهم، فيتناولون منها كيف شاؤوا{1}. (١٥/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span>، قال: أُدنيتْ منهم يَتناولونها؛ إن قام ارتفعتْ بقدْره، وإن قعد تَدلَّتْ حتى يَتناولها، وإن اضطجع تَدلَّتْ حتى يَتناولها، فذلك تَذليلها{2}. (١٥/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: أرض الجنة مِن ورِق، وتُرابها مِسك، وأصول شجرها ذهبٌ ووَرِق، وأفنانها اللؤلؤ والزَّبَرْجد والوَرِق، والثمار بين ذلك، فمَن أكل قائمًا لم يُؤذه، ومَن أكل مُضطجعًا لم يُؤذه، ومَن أكل جالسًا لم يُؤذه: <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span>{3}. (١٥/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span>، قال: أُدْنِيَتْ منهم، يتناولونها وهم مُتَّكِئون{4}. (١٥/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span>، قال: إن قعدوا نالوها{4}. (١٥/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ودانِيَةً عَلَيْهِمْ ظِلالُها وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span>، قال: لا يَردّ أيديهم عنها بُعْدٌ ولا شوك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ودانِيَةً عَلَيْهِمْ ظِلالُها﴾</span> يعني: ظِلال الشجر، وذلك أنّ أهل الجنة يأكلون من الفواكه؛ إن شاؤوا نيامًا، وإن شاؤوا قعودًا، وإن شاؤوا قيامًا، إذا أرادوا دَنتْ منهم حتى يأخذوا منها، ثم تقوم قيامًا، فذلك قوله: <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها﴾</span> يعني: أغصانها <span class="qpc-hafs">﴿تَذليلًا﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span>، قال: يَتناوله كيف شاء جالسًا ومُتَّكِئًا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٩-، وابن جرير ٩/٤٤٧، ٢٣/٢٣٣-٢٣٤، وسعيد بن منصور -كما في فتح الباري ٨/٦٨٥-، وابن أبي شيبة ١٣/١٤٠-١٤١، وهناد (١٠٠، ١٠١)، وعبد الله بن أحمد ص٢١١، وابن أبي حاتم ٤/١٣٥٩ (٧٧٠٩)، والحاكم ٢/٥١١، والبيهقي (٣١٢، ٣١٣)، وابن أبي الدنيا في صفة الجنة ٦/٣٤٥ (١١٥). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.|2:أخرجه ابن جرير ٢٣/٥٥٣، وابن أبي الدنيا في صفة الجنة ٦/٣٤٤-٣٤٥ (١١٤). وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه سعيد بن منصور ٨/٢٢٩ (٢٣٦٤)، وابن أبي شيبة ١٣/٩٥، والبيهقي (٣١٤). وعزاه السيوطي إلى ابن المنذر.|4:عزاه السيوطي إلى عبد بن حميد.|5:عزاه السيوطي إلى عبد بن حميد.|6:أخرجه ابن جرير ٢٣/٥٥٤.|7:تفسير مقاتل بن سليمان ٤/٥٢٧.|8:أخرجه ابن جرير ٢٣/٥٥٤.
  76,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیُطَافُ عَلَیۡهِم بِـَٔانِیَةࣲ مِّن فِضَّةࣲ وَأَكۡوَابࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٤٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿وأَكْوابٍ﴾</span>، قال: ليس لها آذان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>-من طريق منصور- قال: الأكواب: الأقداح{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٤٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: الآنية: الأقداح، والأكواب المُكوكبات، وتقديرها أنها ليستْ بالمَلأى التي تَفيض، ولا ناقصة؛ بقدْر{3}. (١٥/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُطافُ عَلَيْهِمْ بِآنِيَةٍ مِن فِضَّةٍ وأَكْوابٍ﴾</span> فهي الأكواز مُدَوّرة الرؤوس التي ليس لها عُرى{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٥٥.|2:أخرجه ابن جرير ٢٣/٥٥٦.|3:أخرجه ابن أبي شيبة ١٣/٥٧٠، وهناد (٦٨). وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٤/٥٢٧-٥٢٨.
  76,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَكۡوَابࣲ كَانَتۡ قَوَارِیرَا۠ ۝١٥ قَوَارِیرَا۟ مِن فِضَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٠١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق قتادة- في قوله تعالى: <span class="qpc-hafs">﴿وأَكْوابٍ كانَتْ قَوارِيرا * قَوارِيرَ مِن فِضَّةٍ﴾</span>: هي من فِضّة، وصفاؤها مثل صفاء القوارير؛ في بياض الفِضّة، وصفاء القوارير{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قال: آنية من فِضّة، وصفاؤها كصفاء القوارير{2}. (١٥/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: لو أخذتَ فِضّة مِن فِضّة الدنيا، فضَربتَها حتى جَعلتَها مثل جناح الذباب لم يُر الماء من ورائها، ولكن قوارير الجنة بياض الفِضّة في صفاء القوارير{3}. (١٥/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق رجل- قال: ليس في الجنة شيء إلا قد أُعطيتم في الدنيا شِبْهَهُ، إلا: <span class="qpc-hafs">﴿قَوارِيرَ مِن فِضَّةٍ﴾</span>{4}. (١٥/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿قَوارِيرَ مِن فِضَّةٍ﴾</span>، قال: صفاء القوارير؛ وهي من فِضّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، في قوله: <span class="qpc-hafs">﴿قَوارِيرَ مِن فِضَّةٍ﴾</span>، قال: صفاؤها صفاء القوارير، وهي من فِضّة{6}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿قَوارِيرَ مِن فِضَّةٍ﴾</span>، قال: صفاء القوارير في بياض الفِضّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ويُطافُ عَلَيْهِمْ بِآنِيَةٍ مِن فِضَّةٍ﴾</span> الآية، قال: صفاء القوارير في بياض الفِضّة{8}. (١٥/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي هلال- قال: لو اجتمع أهلُ الدنيا على أن يعملوا إناءً من فضة يُرى ما فيه من خلفه كما يُرى في القوارير ما قَدَرُوا عليه{9}. (١٥/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق ابن أبي خالد- في قوله: <span class="qpc-hafs">﴿كانَتْ قَوارِيرا قَوارِيرَ مِن فِضَّةٍ﴾</span>، قال: كان تُرابها من فِضّة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١١<span class="dash">-</span></span> قال <span class="name-2">أبو حمزة الثمالي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٢<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿كانَتْ قَوارِيرا قَوارِيرَ مِن فِضَّةٍ﴾</span> إنّ الله جَعل قوارير كلّ قوم من تُراب أرضهم، وإنّ أرض الجنة من فِضّة، فجَعل منها قوارير يَشربون فيها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كانَتْ قَوارِيرا﴾</span> ولكنها من فِضّة، وذلك أنّ قوارير الدنيا من تُرابها، وقوارير الجنة من فِضّة، فذلك قوله: <span class="qpc-hafs">﴿كانَتْ قَوارِيرا﴾</span> ثم قَطعها، ثم استأنف فقال: <span class="qpc-hafs">﴿قَوارِيرَ مِن فِضَّةٍ قَدَّرُوها تَقْدِيرًا﴾</span>{12}<span class=comment-ref>٦٩٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٩٤) أنّ قوله تعالى: <span class="qpc-hafs">﴿مِن فِضَّةٍ﴾</span> يَقتضي أنها من زجاج ومن فِضّة، ثم قال: «وذلك متمكن؛ لكونه من زجاج في شفوفه ومن فِضّة في جوهره، وكذلك فِضّة الجنة شفافة».</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ القيم</u> (٣/٢٣٦) أنّ ابن قتيبة قال: الآية على التشبيه، أراد: قوارير كأنها من فِضّة، وهذا <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> [الرحمن:٥٨]، أي: لهنّ ألوان المرجان في صفاء الياقوت. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للغة</span>، فقال: «وهذا مردود عليه؛ فإنّ الآية صريحة أنها من فِضّة، و<span class="qpc-hafs">﴿مِن﴾</span> ههنا لبيان الجنس كما تقول: خاتم من فِضّة. ولا يُراد بذلك أنه يُشبه الفِضّة، بل جنسه ومادته الفِضّة».</div></p><p><h3><span class="qpc-hafs">﴿قَدَّرُوهَا تَقۡدِیرࣰا ۝١٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٥١٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> أنه كان يقرأ: (قُدّرُوها) برفع القاف{13}. (١٥/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأها: <span class="qpc-hafs">﴿قَدَّرُوها﴾</span> بنصب القاف{14}<span class=comment-ref>٦٩٤٢</span>. (١٥/١٦١)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٢</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿قدروها تقديرًا﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿قدروها﴾</span> بفتح القاف، و<b>قرأ آخرون</b> بضمها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٥٥٩) أنّ قراءة الفتح بمعنى: قَدّرها لهم السُّقاة الذين يطوفون بها عليهم. وأنّ قراءة الضم بمعنى: قُدِّرتْ عليهم، فلا زيادة فيها ولا نقصان. و<span class="comment-type-3">رجَّح</span> (٢٣/٥٦٠) قراءة الفتح <span class="mustanad">مستندًا إلى إجماع القُراء</span>، فقال: «والقراءة التي لا أستجيز القراءة بغيرها فتح القاف؛ لإجماع الحُجّة من القُراء عليه».</div></p><p><h3><span class="qpc-hafs">﴿قَدَّرُوهَا تَقۡدِیرࣰا ۝١٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٥١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: قُدِّرتْ للكفّ{15}. (١٥/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: أُتُوا بها على قَدْر الفم، لا يُفَضِّلون شيئًا، ولا يَشتَهون بعدها شيئًا{16}. (١٥/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: قدّرتها السُّقاة{17}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥١٩<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جبير]</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: قَدْرَ ريِّهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: ممتلئة لا تُهراق، وليست بناقصة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: لا تَتْرع فتُهراق، ولا يَنقُصون من مائها فتَنقُصَ، فهي مَلأى{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: قُدِّرت لرِيّ القوم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: قُدِّرتْ على قدْرِ رِيِّ القوم{22}. (١٥/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، أي: في أنفسهم، فأَتتْهم على نحو ما قَدّروا واشتهوا مِن صغار وكبار وأوساط{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٥<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٦<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span> على قدْر الكفّ{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قَوارِيرا مِن فِضَّةٍ قَدَّرُوها تَقْدِيرًا﴾</span> يعني: قُدِّرت الأكواب على الإناء، وقُدِّر الإناء على كفّ الخادم ورِيّ القوم، فذلك قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قَدَّرُوها تَقْدِيرًا﴾</span>، قال: قَدَّروها لرِيِّهم على قدْرِ شُربهم؛ أهل الجنة{19}<span class=comment-ref>٦٩٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٣</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿قوارير من فضة قدروها تقديرا﴾</span> على قولين: <b>الأول</b>: قَدّروها تقديرًا على قدْر رِيّهم؛ لا تَزيد ولا تنقص عن ذلك. <b>الثاني</b>: قَدَّروها على قدْر الكفّ.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (٣/٢٣٦) على القول الأول الذي قاله ابن عباس، ومجاهد، وسعيد بن جُبَير، وقتادة، وابن زيد، بقوله: «هذا أبلغ في لذّة الشارب، فلو نَقص عن رِيّه لنَقص التذاذه، ولو زاد حتى يَشمئز منه حصل له ملالةٌ وسآمةٌ من الباقي».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٤/٢١٣).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٢٣٧) أنّ <b>طائفة قالت</b>: الضمير يعود على الشّاربين، أي: قَدَّروا في أنفسهم شيئًا، فجاءهم الأمر بحسب ما قَدّروه وأرادوه، ثم <span class="comment-type-3">رجَّح</span> القول الأول -<span class="mustanad">مستندًا إلى أنّه الأعمّ</span>- بقوله: «وقول الجمهور أحسن وأبلغ، وهو مستلزم لهذا القول».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٢١٤) أنّ القول الثاني -الذي قاله ابن عباس من طريق عطية العَوفيّ، والربيع، والقُرَظيّ- لا ينافي القول الأول، فإنها مُقدّرة في القدْر والرّي.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أنّ الضمير في <span class="qpc-hafs">﴿قدروها﴾</span> يحتمل ثلاثة احتمالات: <b>الأول</b>: أن يكون الضمير للملائكة. <b>الثاني</b>: أن يكون للطائفين. <b>الثالث</b>: أن يكون للمُنعّمين. ثم <span class="comment-type-4">علَّق</span> بقوله: «والتقدير إمّا أن يكون على قدْر الأكُفّ. قاله الربيع. أو على قدْر الرِّيّ. قاله مجاهد. وهذا كلّه على قراءة مَن قرأ: (قَدَرُوها) بفتح القاف».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٧. وفي بعض نسخه عن قتادة.|2:أخرجه ابن جرير ٢٣/٥٥٥ بنحوه، والبيهقي (٣٤٣). وعزاه السيوطي إلى ابن المنذر.|3:أخرجه عبد الرزاق ٢/٣٣٨، والبيهقي (٣٤٨). وعزاه السيوطي إلى سعيد بن منصور.|4:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣١٦-.|5:أخرجه ابن جرير ٢٣/٥٥٥، ٥٥٧، ومن طريق سفيان بنحوه.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٣/٥٥٧.|8:أخرجه ابن جرير ٢٣/٥٥٥، ٥٥٧، وبنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن جرير ٢٣/٥٥٧. وعزاه السيوطي إلى ابن المنذر.|10:أخرجه ابن جرير ٢٣/٥٥٧، وابن أبي الدنيا في صفة الجنة ٦/٣٤٩ (١٤١).|11:تفسير الثعلبي ١٠/١٠٣، وتفسير البغوي ٨/٢٩٦ دون الثمالي.|12:تفسير مقاتل بن سليمان ٤/٥٢٧-٥٢٨.|13:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة، تروى أيضًا عن النبي ﷺ، وعلي، وابن عباس، وغيرهم. انظر: مختصر ابن خالويه ص١٦٦.|14:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.|15:أخرجه ابن جرير ٢٣/٥٥٩، والبيهقي (٣٤٣). وعزاه السيوطي إلى ابن المنذر.|16:عزاه السيوطي إلى الفريابي.|17:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|18:أخرجه ابن جرير ٢٣/٥٥٨.|19:أخرجه ابن جرير ٢٣/٥٥٩.|20:أخرجه ابن جرير ٢٣/٥٥٨.|21:أخرجه ابن جرير ٢٣/٥٥٨.|22:أخرجه عبد الرزاق ٢/٣٣٧ من طريق معمر بنحوه، وابن جرير ٢٣/٥٥٨-٥٥٩، وبنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.|23:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧١-.|24:تفسير الثعلبي ١٠/١٠٣. وفي طبعة دار التفسير ٢٨/٢٤٢: عن القرطبي بدل القرظي.|25:تفسير مقاتل بن سليمان ٤/٥٢٨.|26:أخرجه ابن جرير ٢٣/٥٥٩.
  76,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیُسۡقَوۡنَ فِیهَا كَأۡسࣰا كَانَ مِزَاجُهَا زَنجَبِیلًا ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٢٩<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>أربع عيون في الجنة: عينان تَجريان من تحت العرش؛ إحداهما التي ذَكر الله: <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span>، والأخرى الزَّنجبيل، وعينان نَضّاختان من فوقُ؛ إحداهما التي ذَكر الله: <span class="qpc-hafs">﴿سَلْسَبِيلًا﴾</span>، والأخرى التّسنيم</b>»{1}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كلّ ما ذَكر الله في القرآن مما في الجنة وسَمّاه؛ ليس له في الدنيا مِثْلٌ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿كانَ مِزاجُها زَنْجَبِيلًا﴾</span>، قال: يَأْثُر لهم ما كانوا يَشربون في الدنيا، فيُحبّبه إليهم بذلك{3}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿كانَ مِزاجُها زَنْجَبِيلًا﴾</span>، قال: يُمزج لهم بالزَّنجبيل{4}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿ويُسْقَوْنَ فِيها كَأْسًا﴾</span> يعني: خمرًا، وكلّ شراب في الإناء ليس بخمر، وليس هو بكأس. قال: <span class="qpc-hafs">﴿كانَ مِزاجُها زَنْجَبِيلًا﴾</span> يعني: كأنما قد مُزج فيه الزَّنجبيل{5}<span class=comment-ref>٦٩٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٩٥) أنّ <span class="qpc-hafs">﴿عينًا﴾</span> بدل من <span class="qpc-hafs">﴿كأسًا﴾</span> على هذا القول.</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد مرسلًا.|2:تفسير البغوي ٨/٢٩٦.|3:أخرجه ابن جرير ٢٣/٥٦٠. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه عبد الرزاق ٢/٣٣٨، وابن جرير ٢٣/٥٦٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٥٢٨.
  76,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَیۡنࣰا فِیهَا تُسَمَّىٰ سَلۡسَبِیلࣰا ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٣٤<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>أربع عيون في الجنة: عينان تَجريان من تحت العرش؛ إحداهما التي ذَكر الله: <span class="qpc-hafs">﴿يُفَجِّرُونَها تَفْجِيرًا﴾</span>، والأخرى الزَّنجبيل. وعينان نَضّاختان من فوقُ؛ إحداهما التي ذَكر الله: <span class="qpc-hafs">﴿سَلْسَبِيلًا﴾</span>، والأخرى التّسنيم</b>»{1}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٥<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٦<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيّان</span>: سُمّيتْ سلسبيلًا لأنها تَسيل عليهم في الطرق وفي منازلهم، تَنبع من أصل العرش مِن جنة عَدن إلى أهل الجِنان، وشراب الجنة على بَرد الكافور، وطعم الزَّنجبيل، وريح المِسك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عَيْنًا فِيها تُسَمّى سَلْسَبِيلًا﴾</span>، قال: حَديدة الجِرْيَة{3}. (١٥/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿تُسَمّى سَلْسَبِيلًا﴾</span>، قال: تَجري سَلِسَة السبيل{4}. (١٥/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿عَيْنًا فِيها تُسَمّى سَلْسَبِيلًا﴾</span>، قال: عين الخمر{5}. (١٥/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿عَيْنًا فِيها تُسَمّى سَلْسَبِيلًا﴾</span>، قال: سَلِسَةٌ، فهم يُصرِّفونها حيث شاءوا{6}. (١٥/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿كانَ مِزاجُها زَنْجَبِيلًا عَيْنًا فِيها تُسَمّى سَلْسَبِيلًا﴾</span>، قال: رقيقة يَشربها المُقرّبون صِرفًا، وتُمزج لسائر أهل الجنة{7}<span class=comment-ref>٦٩٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٩٥) أنّ <span class="qpc-hafs">﴿عينًا﴾</span> بدل من <span class="qpc-hafs">﴿زنجبيلًا﴾</span> على هذا القول الذي قاله قتادة من طريق سعيد.</div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿سلسبيلًا﴾</span>، قال: العين التي تُمزج بها الخمر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿عَيْنًا فِيها تُسَمّى سَلْسَبِيلًا﴾</span> عليهم مِن جنة عَدن، فتَمُرّ على كلّ جنة، ثم تَرجع لهم الجنة كلّها{9}<span class=comment-ref>٦٩٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٦</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿عينًا فيها تسمى سلسبيلًا﴾</span> على قولين: <b>الأول</b>: أنها سلِسة يُصرِّفونها حيث شاؤوا. <b>الثاني</b>: أنها شديدة الجِرْيَة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٥٦٤) العموم <span class="mustanad">لإجماعِ أهل التأويل</span>، فقال: «والصواب من القول في ذلك عندي أنّ قوله: <span class="qpc-hafs">﴿تسمى سلسبيلًا﴾</span> صفة للعين، وُصفتْ بالسّلاسة في الحَلْق، وفي حال الجري، وانقيادها لأهل الجنة يُصرِّفونها حيث شاؤوا. كما قال مجاهد، وقتادة. وإنما عنى بقوله: <span class="qpc-hafs">﴿تسمى﴾</span>: تُوصف. وإنما قلتُ ذلك أولى بالصواب لإجماع أهل التأويل على أنّ قوله: <span class="qpc-hafs">﴿سلسبيلا﴾</span> صفة لا اسم».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٢١٤) <b>قولًا</b> بأنّ السلسبيل اسم عين في الجنة. ونسبه لعكرمة. ثم <span class="comment-type-3">رجَّح</span> ما رجحه <u>ابنُ جرير</u> من عموم، فقال: «وهو كما قال».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٩٥) أنّ كون السلسبيل مصروفًا يؤكد أنه صفة لا اسمٌ.</p><p>و<span class="comment-type-4">نَقل</span> قولًا بأن المعنى: سَلْ سبيلًا إليها. و<span class="comment-type-2">انتقده</span> (٨/٤٩٦) <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وهذا قول ضعيف؛ لأنّ براعة القرآن وفصاحته لا تجيء هكذا، واللفظة معروفة في اللسان، وأنّ السلسل والسلسبيل بمعنى واحد متقارب».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد مرسلًا.|2:تفسير الثعلبي ١٠/١٠٤، وتفسير البغوي ٨/٢٩٧.|3:أخرجه عبد الرزاق ٢/٣٣٨، وابن جرير ٢٣/٥٦٢، وسعيد بن منصور -كما في التغليق ٣/٥٠٠-، وهناد (٩٦)، وعبد بن حميد -كما في فتح الباري ٦/٣٢١-، والبيهقي في البعث (٣٢١). وعزاه السيوطي إلى ابن المنذر.|4:عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢٣/٥٦٢، بلفظ: سَلِسَة الجِرية.|5:عزاه السيوطي إلى ابن المنذر.|6:أخرجه عبد الرزاق ٢/٣٣٨، وعبد بن حميد -كما في فتح الباري ٦/٣٢١-، وابن جرير ٢٣/٥٦١، وبنحوه من طريق سعيد. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٣/٥٦٠.|8:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٥.|9:تفسير مقاتل بن سليمان ٤/٥٢٨.
  76,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَطُوفُ عَلَیۡهِمۡ وِلۡدَ ٰ⁠نࣱ مُّخَلَّدُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وِلْدانٌ مُخَلَّدُونَ﴾</span>، قال: لا يموتون{1}<span class=comment-ref>٦٩٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٥٦٥) أنه <span class="mustanad">ذُكر عن العرب</span> أنها تقول للرجل إذا كَبِر وثبتَ سواد شعره: إنه لمُخلد. وكذلك إذا كَبِر وثَبتتْ أضراسه وأسنانه قيل: إنه لمُخلد. يراد به أنه ثابت الحال، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا تصحيح لما قال قتادة من أنّ معناه: لا يموتون؛ لأنهم إذا ثَبتوا على حال واحدة فلم يَتغيّروا بهرَم ولا شيب ولا موت فهم مُخلّدون».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> <b>قولًا</b> بأنّ <span class="qpc-hafs">﴿مخلدون﴾</span> معناه: مُقرّطون.</p><p>و<span class="comment-type-4">ذكره</span> <u>ابنُ عطية</u> (٨/٤٩٦).</p><p>ونسبه <u>ابنُ القيم</u> (٣/٢٣٧) لابن جُبَير.</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> أنّ الخَلَدات: حُلي تُعلّق في الآذان.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٣/٢٣٧).</p><p>و<span class="comment-type-1">وجّهه</span> <u>ابنُ كثير</u> (١٤/٢١٤) بقوله: «ومَن فسّرهم بأنهم مخرّصون في آذانهم الأقرطة. فإنما عبّر عن المعنى بذلك؛ لأنّ الصغير هو الذي يليق له ذلك دون الكبير».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> أنّ طائفة <span class="comment-type-4">جمعتْ</span> بين القولين، فقالت: هم ولدان، لا يَعرض لهم الكِبَر والهَرم، وفي آذانهم القِرَطَة. ثم <span class="comment-type-4">علَّق</span> بقوله: «فمَن قال: مُقرّطون. أراد هذا المعنى أنّ كونهم ولدانا أمْرٌ لازم لهم».</div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span> فأمّا الولدان فهم الغِلمان الذين لا يَشيبون أبدًا، <span class="qpc-hafs">﴿مُخَلَّدُونَ﴾</span> يعني: لا يَحتلمون، ولا يَشيبون أبدًا، هم على تلك الحال، لا يَختلفون، ولا يَكبرون{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا رَأَیۡتَهُمۡ حَسِبۡتَهُمۡ لُؤۡلُؤࣰا مَّنثُورࣰا ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق سعيد، عن قتادة، عن أبي أيوب- قال: إنّ أدنى أهل الجنة منزلًا مَن يسعى عليه ألف خادم، كلّ واحد على عَملٍ ليس عليه صاحبه. وتلا هذه الآية: <span class="qpc-hafs">﴿إذا رَأَيْتَهُمْ حَسِبْتَهُمْ لُؤْلُؤًا مَنثُورًا﴾</span>{3}. (١٥/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق سعيد، عن قتادة، عن أبي أيوب- قال: ما من أهل الجنة مِن أحد إلا يَسعى عليه ألفُ غلام، كلّ واحد على عَملٍ ما عليه صاحبه{4}. (١٥/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: بينا المؤمن على فراشه إذ أبصر شيئًا يسير نحوه، فجعل يقول: لؤلؤ، لؤلؤ. فإذا ولدان مُخلّدون كما وصفهم الله، وهي الآية: <span class="qpc-hafs">﴿إذا رَأَيْتَهُمْ حَسِبْتَهُمْ لُؤْلُؤًا مَنثُورًا﴾</span>{5}. (١٥/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إذا رَأَيْتَهُمْ حَسِبْتَهُمْ لُؤْلُؤًا مَنثُورًا﴾</span>، قال: من كثرتهم وحُسنهم{6}. (١٥/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا رَأَيْتَهُمْ حَسِبْتَهُمْ لُؤْلُؤًا مَنثُورًا﴾</span> في الحُسن والبياض، يعني: في الكثرة، مثل اللؤلؤ المنثور الذي لا يَتناهى عدده{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- قال: <span class="qpc-hafs">﴿حَسِبْتَهُمْ لُؤْلُؤًا مَنثُورًا﴾</span>، قال: في كثرة اللؤلؤ، وبياض اللؤلؤ{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا رَأَیۡتَهُمۡ حَسِبۡتَهُمۡ لُؤۡلُؤࣰا مَّنثُورࣰا ۝١٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٥٢<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>أنا أولهم خروجًا إذا خَرجوا، وأنا قائدهم إذا وفدوا، وأنا خطيبهم إذا أنصتُوا، وأنا مُستشفِعهم إذا حُبِسُوا، وأنا مُبشِّرهم إذا أيسوا، الكرامة والمفاتيح بيدي، ولواء الحمد بيدي، وآدم ومَن دونه تحت لوائي ولا فَخْر، يطوف عليهم ألف خادم، كأنهم بَيْض مكنون أو لؤلؤ منثور</b>»{9}. (١٥/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأَحْوَص- قال: يقول غِلمان أهل الجنة: مِن أين نَقطف لك؟ مِن أين نَسقيك؟{10}. (١٥/١٦٠، ١٦٦)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٨، وابن جرير ٢٣/٥٦٤، ومن طريق سعيد أيضًا.|2:تفسير مقاتل بن سليمان ٤/٥٢٨.|3:أخرجه ابن المبارك (١٥٨٠)، وهناد (١٧٤)، والبيهقي في البعث (٤١٢). وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٢٣/٥٦٦.|5:عزاه السيوطي إلى عبد بن حميد.|6:أخرجه عبد الرزاق ٢/٣٣٨، وعبد بن حميد -كما في فتح الباري ٦/٣٢١-، وابن جرير ٢٣/٥٦٤، كذلك من طريق سعيد. وعزاه السيوطي إلى ابن المنذر.|7:تفسير مقاتل بن سليمان ٤/٥٢٨.|8:أخرجه ابن جرير ٢٣/٥٦٦.|9:أخرجه الدارمي ١/٣٩-٤٠ (٤٨) بنحوه، والترمذي ٦/٢٠٧-٢٠٨ (٣٩٣٧) مختصرًا.</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال البغوي في شرح السنة ١٣/٢٠٣ (٣٦٢٤): «هذا حديث غريب».|10:أخرجه ابن أبي شيبة ١٣/١١٤.
  76,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا رَأَیۡتَ ثَمَّ رَأَیۡتَ نَعِیمࣰا وَمُلۡكࣰا كَبِیرًا ۝٢٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: دخل عمر بن الخطاب على رسول الله ﷺ وهو راقد على حصير مِن جريد، قد أثّر في جَنبه، فبكى عمر، فقال: «<b>ما يُبكيك</b>؟». فقال: ذكرتُ كِسرى ومُلكه، وقَيْصر ومُلكه، وصاحب الحبشة ومُلكه، وأنت رسول الله على حصير من جريد! فقال: «<b>أما ترضى أنّ لهم الدنيا ولنا الآخرة!</b>». فأَنزل الله: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span>{1}. (١٥/١٦٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا رَأَیۡتَ ثَمَّ رَأَیۡتَ نَعِیمࣰا وَمُلۡكࣰا كَبِیرًا ۝٢٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٥٥<span class="dash">-</span></span> عن الحسن البصري، أنّ رسول الله ﷺ قال: «<b>إنّ أدنى أهل الجنة منزلة الذي يَركب في ألف ألف مِن خَدَمه مِن الولدان المُخلّدين، على خيلٍ مِن ياقوت أحمر، لها أجنحة من ذهب، <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span></b>»{2}. (١٥/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الضَّحّاك بن مُزاحِم- قال: «<b>لو أنّ جارية أو خادمًا خَرجتْ إلى الدنيا لاقتتل عليها أهلُ الأرض كلّهم حتى يَتفانَوا، ولو أنّ الحُور العِين أرختْ ذؤابتها في الأرض لأَطفأت الشمسَ من نورها</b>». قيل: يا رسول الله، وكم بين الخادم والمخدوم؟ قال: «<b>والذي نفسي بيده، إنّ بين الخادم والمخدوم كالكوكب المضيء إلى جنب القمر في النصف</b>». قال: «<b>فبينما هو جالس على سريره إذ يبعث الله ﷿ إليه مَلَكًا معه سبعون حُلّة، كلّ حُلّة على لون واحد، ومعه التسليم والرضا، فيجيء المَلَك حتى يقوم على بابه، فيقول لحاجبه: ائذن لي على وليّ الله، فإني رسول ربّ العالمين إليه. فيقول الحاجب: والله، ما أملك منه المناجاة، ولكن سأذكرك إلى مَن يليني مِن الحَجبة. فلا يزالون يذكرون بعضهم إلى بعض حتى يأتيه الخَبر بعد سبعين بابًا، يقول: يا وليّ الله، إنّ رسول ربّ العزّة على الباب، فيَأذن له بالدخول عليه. فيقول: السلام عليك، يا وليّ الله، إنّ الله يُقرئك السلام، وهو عنك راضٍ. فلولا أنّ الله تعالى لم يَقضِ عليه الموت لمات من الفرح، فذلك قوله: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span></b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنه ذَكر مَراكب أهل الجنة، ثم تلا: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span>{4}. (١٥/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥٨<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق مِرْداس بن عبد الرحمن- في قوله: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span>، قال: يُرسِل إليهم ربُّهم الملائكةَ، فتأتي فتستأذن عليهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span>، قال: هو استئذان الملائكة عليهم: لا تدخل عليهم إلا بإذن{6}. (١٥/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عمّن سمع مجاهدًا- يقول: <span class="qpc-hafs">﴿وإذا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span>، قال: تسليم الملائكة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span> هو أنّ رسول ربّ العزّة مِن الملائكة لا يَدخل عليه إلا بإذنه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا رَأَيْتَ﴾</span> يا محمد <span class="qpc-hafs">﴿ثَمَّ﴾</span> يعني: هناك <span class="qpc-hafs">﴿رَأَيْتَ نَعِيمًا﴾</span> يعني بالنعيم: الذي هو فيه، <span class="qpc-hafs">﴿ومُلْكًا كَبِيرًا﴾</span> حين لا يَدخل عليه رسولُ ربّ العزّة إلا بإذن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿رَأَيْتَ نَعِيمًا ومُلْكًا كَبِيرًا﴾</span> وذلك أنّ الرجل مِن أهل الجنة له قصر، في ذلك القصر سبعون قصرًا، في كلّ قصر سبعون بيتًا، كلّ بيت مِن لؤلؤة مُجوّفة طولها في السماء فرسخٌ، وعَرضها فرسخٌ، عليها أربعة ألف مِصراع من ذهب، في ذلك البيت سرير منسوج بقُضبان الدُّرّ والياقوت، عن يمين السرير وعن يساره أربعون ألف كرسي مِن ذهب، قوائمها ياقوت أحمر، على ذلك السرير سبعون فراشًا، كلّ فراش على لون، وهو جالس فوقها، وهو متكئ على يساره، عليه سبعون حُلّة من دِيباج، الذي يلي جسده حريرة بيضاء، وعلى جبهته إكليلٌ مُكلّل بالزَّبَرْجَد والياقوت وألوان الجواهر، كلّ جوهرة على لون، وعلى رأسه تاج من ذهب، فيه سبعون ذُؤابة، في كلّ ذُؤابة دُرّة تساوي مال المشرق والمغرب، وفي يديه ثلاث أسورة، سوار من ذهب، وسوار من فِضّة، وسوار من لؤلؤ، وفي أصابع يديه ورِجليه خواتيم مِن ذهب وفِضّة فيه ألوان الفصوص، وبين يديه عشرة آلاف غلام لا يَكبرون ولا يَشِيبون أبدًا، ويوضع بين يديه مائدة من ياقوتة حمراء، طولها ميل في ميل، ويوضع على المائدة سبعون ألف إناء من ذهب وفِضّة، في كلّ إناء سبعون لونًا من الطعام، يأخذ اللقمة بيديه، فما يَخطر على باله حتى تتحوّل اللقمة عن حالها إلى الحال التي يشتهيها، وبين يديه غلمان بأيديهم أكواب من ذهب، وإناء من فِضّة معهم الخمر والماء، فيأكل على قدر أربعين رجلًا من الألوان كلّها، كلّما شبع من لون من الطعام سَقوه شربة مما يشتهي من الأشربة فَيَتَجَشَّأُ، فيَفتح الله تعالى عليه ألف باب مِن الشهوة مِن الشراب، فيدخل عليه الطير من الأبواب كأمثال النَّجائب، فيَقومون بين يديه صفًّا، فيَنعتُ كلٌّ نفسَه بصوتٍ مُطْرِبٍ لذيذ ألذّ مِن كلّ غناء في الدنيا، يقول: يا وليّ الله، كُلني؛ إنى كنتُ أرعى في روضة كذا وكذا من رياض الجنة. فيحلون عليه أصواتها، فيرفع بصره، فينظر إليهم، فينظر إلى أزهاها صوتًا، وأجودها نعتًا، فيشتهيها، فيَعلم الله ما وراء شهوته في قلبه من حُبّه، فيجيء الطير، فيقع على المائدة؛ بعضه قَدِيد، وبعضه شواء، أشدّ بياضًا من الثلج، وأحلى من العسل، فيأكل، حتى إذا شبع منها واكتفى طارت طيرًا كما كانت، فتَخرج من الباب الذي كانت دَخلتْ منه، فهو على الأرائك، وزوجته مُستقبلة، يبصر وجهه في وجهها من الصفاء والبياض، كلّما أراد أن يُجامعها ينظر إليها، فيستحي أن يَدعوها، فتَعلم ما يريد منها زوجها، فتدنو إليه، فتقول: بأبي وأمي، ارفع رأسك، فانظر إليّ، فإنك اليوم لي، وأنا لك. فيُجامعها على قوة مائة رجل من الأوّلين، وعلى شهوة أربعين رجلًا، كلّما أتاها وجدها عذراء، لا يَغفل عنها مقدار أربعين يومًا، فإذا فرَغ وجد ريح المِسك منها، فيزداد حُبًّا لها، فيها أربعة آلاف وثمانمائة زوجة مثلها، لكلّ زوجة سبعون خادمًا وجارية{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦٤<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق عبد الرحمن- يقول في قوله: <span class="qpc-hafs">﴿ومُلْكًا كَبِيرًا﴾</span>، قال: بلَغنا: أنه تسليم الملائكة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦٥<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران، والأَشْجعيّ- في قوله: <span class="qpc-hafs">﴿ومُلْكًا كَبِيرًا﴾</span>، قال: بلَغنا: أنه استئذان الملائكة عليهم{7}<span class=comment-ref>٦٩٤٨</span>. (١٥/١٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٤٨</span> ساق <u>ابنُ عطية</u> (٨/٤٩٦) هذا القول، ثم <span class="comment-type-4">بيَّن</span> أنّ أكثر المفسرين على أنّ «الملك الكبير» هو اتساع مواضعهم.</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:عزاه السيوطي إلى ابن وهب.|3:أخرجه مقاتل بن سليمان ٤/٥٣٠.|4:أخرجه الحاكم ٢/٥١١، والبيهقي (٤٤٥)، وابن أبي الدنيا في صفة الجنة -موسوعة ابن أبي الدنيا ٦/٣٦١ (٢٠١)-.|5:أخرجه ابن أبي الدنيا في صفة الجنة -موسوعة ابن أبي الدنيا ٦/٣٦١ (٢٠٢)-.|6:أخرجه ابن جرير ٢٣/٥٦٧، والبيهقي (٤٤٦)، وابن أبي الدنيا في صفة الجنة -موسوعة ابن أبي الدنيا ٦/٣٦٠ (١٩٨)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ٢٣/٥٦٧.|8:تفسير البغوي ٨/٢٩٧.|9:تفسير مقاتل بن سليمان ٤/٥٣١. وهو في تفسير البغوي ٨/٢٩٧ منسوبًا إلى مقاتل دون تعيينه.|10:تفسير مقاتل بن سليمان ٤/٥٢٨-٥٣٠.|11:أخرجه ابن جرير ٢٣/٥٦٧.|12:أخرجه ابن جرير ٢٣/٥٦٧.
  76,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَـٰلِیَهُمۡ ثِیَابُ سُندُسٍ خُضۡرࣱ وَإِسۡتَبۡرَقࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٦٦<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> أنه كان يقرأ: <span class="qpc-hafs">﴿عالِيَهُمْ ثِيابُ سُنْدُسٍ خُضْرٌ﴾</span>، قال: عَلَت الخُضرة، أكثر ثيابها الخُضرة{1}. (١٥/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: الإستبرق: الدِّيباج الغليظ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحُلُّوۤا۟ أَسَاوِرَ مِن فِضَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحلوا أساور من فضة﴾</span>، وقال في آية أخرى: <span class="qpc-hafs">﴿يحلون فيها من أساور من ذهب ولؤلؤا﴾</span> [الحج:٢٣، فاطر:٣٣]، فهي ثلاث أسورة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَقَىٰهُمۡ رَبُّهُمۡ شَرَابࣰا طَهُورًا ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٦٩<span class="dash">-</span></span> عن أبي هريرة أو غيره -شكّ أبو جعفر الرازي- قال: صَعد جبرائيل بالنبي ﷺ ليلة أُسري به إلى السماء السابعة، فاستَفتح، فقيل له: مَن هذا؟ فقال: جبرائيل. قيل: ومَن معك؟ قال: محمد. قالوا: أوَقد أُرسل إليه؟ قال: نعم. قالوا: حيّاه الله مِن أخٍ وخليفة، فنِعم الأخ ونِعم الخليفة، ونعم المجيء جاء. قال: فدَخل، فإذا هو برجلٍ أشْمط جالس على كرسي عند باب الجنة، وعنده قوم جلوس بِيض الوجوه أمثال القراطيس، وقوم في ألوانهم شيء، فقام الذين في ألوانهم شيء، فدَخلوا نهرًا، فاغتَسلوا فيه، فخَرجوا وقد خَلَص من ألوانهم شيء، ثم دَخلوا نهرًا آخر، فاغتَسلوا فيه، فخَرجوا وقد خَلصَتْ ألوانهم، فصارت مثل ألوان أصحابهم، فجاؤوا فجلسوا إلى أصحابهم، فقال: «<b>يا جبريل، مَن هذا الأشمط، ومَن هؤلاء البيض الوجوه، ومَن هؤلاء الذين في ألوانهم شيء، وما هذه الأنهار التي اغتَسلوا فيها فجاؤوا وقد صَفتْ ألوانهم؟</b>». قال: هذا أبوك إبراهيم، أول مَن شَمِط على الأرض، وأمّا هؤلاء البيض الوجوه فقوم لم يَلبِسوا إيمانهم بظُلم، وأمّا هؤلاء الذين في ألوانهم شيء فقوم خَلطوا عملًا صالحًا وآخر سيئًا فتابوا، فتاب الله عليهم، وأمّا الأنهار فأولها رحمة الله، والثاني نعمة الله، والثالث سقاهم ربهم شرابًا طهورًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿شَرابًا طَهُورًا﴾</span>، قال: ما ذَكر الله من الأشربة{5}. (١٥/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧١<span class="dash">-</span></span> عن <span class="name-2">أبي قِلابة عبد الله بن زيد الجرمي</span> -من طريق أبان- <span class="qpc-hafs">﴿وسَقاهُمْ رَبُّهُمْ شَرابًا طَهُورًا﴾</span>، قال: إنّ أهل الجنة إذا أكلوا أو شربوا ما شاء الله من الطعام والشراب دَعَوا بالشراب الطّهور، فيَشربون، فيطهّرهم، فيكون ما أكلوا وشَربوا جُشاء بريح مِسك، يَفيض من جلودهم، وتضْمُر لذلك بطونهم{6}. (١٥/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم التيميّ</span> -من طريق منصور- في هذه الآية: <span class="qpc-hafs">﴿وسَقاهُمْ رَبُّهُمْ شَرابًا طَهُورًا﴾</span>، قال: عرقٌ يَفيض من أعراضهم مِثل ريح المِسك{7}. (١٥/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم التيميّ</span> -من طريق مُغيرة- قال: بلَغني: أنه يُقسَم للرجل من أهل الجنة شهوة مائة رجل من أهل الدنيا، وأكْلُهم، ونَهْمَتهم، فإذا أكل سُقي شرابًا طهورًا، يَخرج من جِلده رشحًا كرشْح المِسك، ثم تعود شهوته{8}. (١٥/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وسَقاهُمْ رَبُّهُمْ شَرابًا طَهُورًا﴾</span> وذلك أنّ على باب الجنة شجرة يَنبع من ساقها عينان، فإذا جاز الرجل الصراط إلى العين يَدخل في عين منها، فيَغتسل فيها، فيَخرج وريحه أطيب من المِسك{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٣/٥٦٩.|3:تفسير مقاتل بن سليمان ٤/٥٣١.|4:أخرجه ابن جرير ٢٣/٥٧٠-٥٧١.|5:أخرجه ابن جرير ٢٣/٥٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه عبد الرزاق ٢/٣٣٨، وابن جرير ٢٣/٥٧٠ بنحوه، وابن أبي الدنيا في صفة الجنة -موسوعة ابن أبي الدنيا ٦/٣٤٧ (١٣٠)-. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه هناد (٦١)، وابن جرير ٢٣/٥٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:أخرجه ابن أبي شيبة ١٣/١٢٤، وابن جرير ٢٣/٥٦٩-٥٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:تفسير مقاتل بن سليمان ٤/٥٣٢.
  76,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ هَـٰذَا كَانَ لَكُمۡ جَزَاۤءࣰ وَكَانَ سَعۡیُكُم مَّشۡكُورًا ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وكانَ سَعْيُكُمْ مَشْكُورًا﴾</span>، فقال: لقد شَكر الله سعيًا قليلًا{1}. (١٥/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إنَّ هَذا كانَ لَكُمْ جَزاءً وكانَ سَعْيُكُمْ مَشْكُورًا﴾</span>: غفر لهم الذّنب، وشَكر لهم الحَسَن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ هَذا﴾</span> الذي قضيتُ لكم <span class="qpc-hafs">﴿كانَ لَكُمْ جَزاءً﴾</span> لأعمالكم، <span class="qpc-hafs">﴿وكانَ سَعْيُكُمْ﴾</span> يعني: عملكم <span class="qpc-hafs">﴿مَشْكُورًا﴾</span> يعني: شَكر الله أعمالهم، فأثابهم بها الجنة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٨-٣٣٩، وابن جرير ٢٣/٥٧٢. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٣/٥٧١.|3:تفسير مقاتل بن سليمان ٤/٥٣٣.
  76,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا نَحۡنُ نَزَّلۡنَا عَلَیۡكَ ٱلۡقُرۡءَانَ تَنزِیلࣰا ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٧٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّا نَحْنُ نَزَّلْنا عَلَيْكَ القُرْآنَ تَنْزِيلًا﴾</span> مُتفرِّقًا آية بعد آية، ولم يُنزله جملة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/١٠٦، وعقب الأثر: فلذلك قال: <span class="qpc-hafs">﴿نزّلنا﴾</span>.
  76,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ وَلَا تُطِعۡ مِنۡهُمۡ ءَاثِمًا أَوۡ كَفُورࣰا ۝٢٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا أوْ كَفُورًا﴾</span>، قال: حُدِّثنا: أنها نزلت في عدوّ الله أبي جهل{1}. (١٥/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- أنه بلَغه: أنّ أبا جهل قال لَمّا فُرضتْ على النبيّ ﷺ الصلاة، وهو يومئذ بمكة: لَئن رأيتُ محمدًا يُصلِّي لأطأنّ على عُنُقه. فأَنزَل الله في ذلك: <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا أوْ كَفُورًا﴾</span>{2}. (١٥/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: الكَفُور: هو عُتبة بن ربيعة، وذلك أنهم خَلَوا به في دار النّدوة، وفيهم عمرو بن عُمير بن مسعود الثَّقَفي، فقالوا: يا محمد، أخبِرنا لِمَ تركتَ دين آبائك وأجدادك؟ فقال الوليد بن المُغيرة: إن طلبتَ مالًا أعطيتُك نصف مالي على أن تَدعَ مقالتك هذه. وقال أبو البَخْتَريّ بن هشام: واللّات والعُزّى، إن ارتدّ عن دينه لأزوّجنه ابنتي؛ فإنها أحسن النساء، وأجملهنّ جمالًا، وأفصحهنّ قولًا، وأَبْلغهنّ علمًا، وقد عَلمت العُزّى بذلك. فسكَتَ النبي ﷺ عن ذلك، فلم يُجبهم شيئًا. فقال ابن مسعود الثَّقَفي: ما لك لا تُجيبنا؟! إن كنتَ تخاف عذاب ربّك وذمّه أجَرْتُك. فضحك النبيُّ ﷺ عند ذلك، وقَبض ثوبه، وقام عنهم، وقال: «<b>أصعب أقوال، وأضعف أعمال</b>». فأَنزَل الله ﷿: <span class="qpc-hafs">﴿إنّا نَحْنُ نَزَّلْنا عَلَيْكَ القُرْآنَ تَنْزِيلًا﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ وَلَا تُطِعۡ مِنۡهُمۡ ءَاثِمًا أَوۡ كَفُورࣰا ۝٢٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٨٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا﴾</span> وهو المُنافق أظهر الإسلام وقلبه على الشّرك، <span class="qpc-hafs">﴿أوْ كَفُورًا﴾</span> وهو المُشرك الجاحد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاصْبِرْ لِحُكْمِ رَبِّكَ﴾</span> يعني: حتى يَحكم الله بينك وبين أهل مكة، ولا تَشتُم إذا شُتِمتَ، ولا تَغتظْ إذا ضُربتَ، <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا﴾</span> وهو الوليد بن المُغيرة بن هشام المَخزوميّ، <span class="qpc-hafs">﴿أوْ كَفُورًا﴾</span> يعني: الوليد بن المُغيرة، وأبا البَخْتَريّ بن هشام{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٨٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿آثِمًا أوْ كَفُورًا﴾</span>، قال: كان أبو جهل يقول: لَئِن رأيتُ محمدًا يُصلِّي لأطأنّ على رقبته. فنَهاه أن يُطيعه{6}. (١٥/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٨٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تُطِعْ مِنهُمْ آثِمًا﴾</span> قال: الآثم: المُذنِب الظالم، والكَفُور، هذا كلّه واحد، وقيل: <span class="qpc-hafs">﴿أوْ كَفُورًا﴾</span> والمعنى: ولا كَفورًا{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٥٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|2:أخرجه عبد الرزاق ٢/٣٣٩، وابن جرير ٢٣/٥٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥٣٣-٥٣٤.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٧٥-.|5:تفسير مقاتل بن سليمان ٤/٥٣٣.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٣/٥٧٢.
  76,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱذۡكُرِ ٱسۡمَ رَبِّكَ بُكۡرَةࣰ وَأَصِیلࣰا ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واذْكُرِ اسْمَ رَبِّكَ بُكْرَةً﴾</span> يعني: إذا صَلَّيتَ صلاة الغداة -وهو بُكرة- فكبِّر واشهد أن لا إله إلا هو، <span class="qpc-hafs">﴿وأَصِيلًا﴾</span> إذا أمسيتَ وصَلَّيتَ صلاة المغرب فكبِّره واشهد أن لا إله إلا هو، فهو براءة من الشّرك، فذلك قوله: <span class="qpc-hafs">﴿واذْكُرِ اسْمَ رَبِّكَ﴾</span> بشهادة أن لا إله إلا هو. قال: كان رسول الله ﷺ يُصلِّي الغَداة، ثم يُكبِّر ثلاثًا، وإذا صَلّى المغرب كبّر ثلاثًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٥٨٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿واذْكُرِ اسْمَ رَبِّكَ بُكْرَةً وأَصِيلًا﴾</span>، قال: بُكرة: صلاة الصبح. وأصيلًا: صلاة الظهر؛ الأصيل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٣٤.|2:أخرجه ابن جرير ٢٣/٥٧٤