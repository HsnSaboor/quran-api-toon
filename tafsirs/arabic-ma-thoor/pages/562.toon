quran[12]{c,v,t}:
  67,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٧٧٧٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق الضَّحّاك- قال: أُنزلت <span class="qpc-hafs">﴿تبارك﴾</span> المُلك في أهل مكة، إلا ثلاث آيات{1}. (١٤/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٧٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها <span class="qpc-hafs">﴿تبارك﴾</span> المُلك، وذكر أنها بعد الطُّور{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٧٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيف عن مجاهد-: مكّيّة، وسمّاها: <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span>{3}. (١٤/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٠<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء عن مجاهد- قال: مكّيّة{4}. (١٤/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨١<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{5}. (١٤/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٢<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٣<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٤<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٥<span class="dash">-</span></span> عن محمد بن شهاب الزُّهريّ: مكّيّة، ونزلت بعد سورة الطُّور{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٦<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٧<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة المُلك مكّيّة، عددها ثلاثون آية{10}<span class=comment-ref>٦٦٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٦٩٦</span> قال <u>ابن عطية</u> (٨/٣٥٠): «وهي مكّيّة <span class="comment-type-1">بإجماع</span>».</div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ سورةً مِن كتاب الله ما هي إلا ثلاثون آية شَفَعتْ لرجل حتى غُفر له؛ <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span></b>»{11}. (١٤/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٨٩<span class="dash">-</span></span> عن عبد الله بن عباس، قال: ضَرب بعض أصحابُ النبيِّ ﷺ خِباءه على قبر، وهو لا يَحسَب أنه قبر، فإذا فيه إنسان يقرأ سورة المُلك حتى خَتمَها، فأتى النبيَّ ﷺ، فأَخبَره، فقال رسول الله ﷺ: «<b>هي المانعة، هي المُنجِية؛ تُنجِيه من عذاب القبر</b>»{12}. (١٤/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٠<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>إنِّي لَأجد في كتاب الله سورة هي ثلاثون آية، مَن قرأها عند نومه كُتب له منها ثلاثون حسنة، ومُحِي عنه ثلاثون سيئة، ورُفع له ثلاثون درجة، وبَعث الله إليه مَلكًا مِن الملائكة لِيَبسُط عليه جَناحه، ويَحفظه مِن كلّ سوء حتى يَستيقظ، وهي المُجادِلة؛ تُجادل عن صاحبها في القبر، وهي: <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span></b>»{13}. (١٤/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩١<span class="dash">-</span></span> عن عبد الله بن عباس، أنه قال لرجل: ألا أُتْحِفُك بحديث تَفرح به؟ قال: بلى. قال: اقرأ: <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span>، وعلِّمها أهلك وجميع ولدك وصبيان بيتك وجيرانك؛ فإنها المُنجِية والمُجادِلة يوم القيامة عند ربها لقارئها، وتَطلب له أن تُنجِيه من عذاب النار، ويَنجو بها صاحبها من عذاب القبر. قال: قال رسول الله ﷺ: «<b>لودِدتُ أنها في قلب كلِّ إنسان مِن أُمّتي</b>»{14}. (١٤/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٢<span class="dash">-</span></span> عن أنس مرفوعًا، قال: «<b>يُبعث رجل يوم القيامة لم يَترك شيئًا من المعاصي إلا رَكِبها، إلا أنه كان يُوَحِّد الله، ولم يكن يقرأ من القرآن إلا سورة واحدة، فيُؤمر به إلى النار، فطار مِن جوفه شيء كالشّهاب، فقالت: اللهم، إنِّي مما أنزَلَتْ على نبيّك ﷺ، وكان عبدك هذا يقرؤني. فما زالت تَشفع حتى أدخلتْه الجنة، وهي المُنجِية: <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span></b>»{15}. (١٤/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٣<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>إنّ رجلًا مِمّن كان قبلكم مات وليس معه شيء من كتاب الله إلا <span class="qpc-hafs">﴿تَبارَكَ﴾</span>، فلما وُضع في حُفرته أتاه المَلَك، فثارت السورة في وجهه، فقال لها: إنكِ من كتاب الله، وأنا أكره مساءتكِ، وإني لا أملك لكِ ولا له ولا لنفسي ضَرًّا ولا نَفعًا، فإنْ أردتِ هذا به فانطلِقي إلى الرّبّ، فاشفعي له. فانطلَقتْ إلى الرّبّ، فتقول: يا ربِّ، إنّ فلانًا عَمد إلَيّ مِن بين كتابك، فتعلَّمني، وتلاني، أفتحرقه أنتَ بالنار وتُعذِّبه وأنا في جوفه؟! فإن كنتَ فاعلًا به فامحُني مِن كتابكَ. فيقول: ألا أراكِ غضبتِ. فتقول: وحُقَّ لي أنْ أغضب. فيقول: اذهبي، فقد وهبتُه لكِ، وشَفّعتُكِ فيه. فتجيء، فَتَزبُر</b>{16} <b>المَلك، فيَخرج كاسِفَ البال</b>{17}، <b>لم يحْلَ</b>{18} <b>منه بشيء، فتجيء، فتضع فاها على فيه، فتقول: مرحبًا بهذا الفم فرُبّما تلاني، ومرحبًا بهذا الصدر فرُبّما وعاني، ومرحبًا بهاتين القدمين فرُبّما قامتا بي. وتُؤنسه في قبره مخافة الوحْشة عليه</b>». فلمّا حَدّث رسول الله ﷺ هذا الحديث لم يبقَ صغير ولا كبير ولا حُرّ ولا عبد إلا تعلَّمها، وسمّاها رسول الله ﷺ المُنجِية{19}. (١٤/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٤<span class="dash">-</span></span> عن رافع بن خُدَيج، وأبي هريرة، أنهما سمعا رسول الله ﷺ يقول: «<b>أُنزِلَتْ عليّ سورة تبارك -وهي ثلاثون آية- جملة واحدة</b>». وقال: «<b>هي المانعة في القبور، وإنّ قراءة <span class="qpc-hafs">﴿قُلْ هُوَ اللَّهُ أحَدٌ﴾</span> تَعدِل في الصلاة قراءة ثُلث القرآن، وإنّ قراءة <span class="qpc-hafs">﴿قُلْ يا أيُّها الكافِرُونَ﴾</span> في الصلاة تَعدِل ربع القرآن، وإنّ قراءة <span class="qpc-hafs">﴿إذا زُلْزِلَتِ﴾</span> في صلاة تَعدِل نصف القرآن</b>»{5}. (١٤/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٥<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>سورة تبارك هي المانعة من عذاب القبر</b>»{21}. (١٤/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٦<span class="dash">-</span></span> عن عبد العزيز، عن أبيه، قال: قال رسول الله ﷺ: «<b>دخل رجل الجنة بشفاعة سورة من القرآن، وما هي إلا ثلاثون آية: <span class="qpc-hafs">﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</span></b>»{5}. (١٤/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٧<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيْش- قال: يُؤتى الرجل في قبره، فيُؤتى من قِبَل رجليه، فتقول رِجلاه: ليس لكم على ما قِبَلي سبيل؛ قد كان يقوم علينا بسورة المُلك. ثم يُؤتى من قِبَل صدره، فيقول: ليس لكم على ما قِبَلي سبيل؛ قد كان وعى فيّ سورة الملك. ثم يُؤتى من قِبَل رأسه، فيقول: ليس لكم على ما قِبَلي سبيل؛ قد كان يقرأ بي سورة المُلك. فهي المانعة تمنع من عذاب القبر، وهي في التوراة سورة المُلك، مَن قرأها في ليلة فقد أكثر وأطيَب{23}. (١٤/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٨<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيْش- قال: كُنّا نُسمِّيها في عهد رسول الله ﷺ: المانعة، وإنها لفي كتاب الله: سورة المُلك. من قرأها في ليلة فقد أكثر وأطيَب{24}. (١٤/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٧٩٩<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق مُرّة- قال: إنّ الميت إذا مات أُوقدت حوله نيران، فتأكل كلّ نار ما يليها إن لم يكن له عمل يَحوُل بينه وبينها، وإنّ رجلًا مات ولم يكن يقرأ من القرآن إلا سورة ثلاثين آية، فأَتتْه من قِبَل رأسه، فقالتْ: إنه كان يقرأ بي. فأَتتْه من قِبَل رجليه، فقالتْ: إنه كان يقوم بي. فأتته من قِبَل جوفه، فقالتْ: إنه كان وعاني. فأَنجتْه. قال: فنظرتُ أنا ومَسروق في المصحف، فلم نجد سورة ثلاثين آية إلا <span class="qpc-hafs">﴿تبارك﴾</span>{25}. (١٤/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٠<span class="dash">-</span></span> عن مُرّة مثله، مرسلًا{26}. (١٤/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠١<span class="dash">-</span></span> عن مُرّة الهَمذاني، قال: أُتِيَ رجل من جوانب قبره، فجَعلتْ سورةٌ مِن القرآن ثلاثون آية تُجادِل عنه، حتى مَنعتْه من عذاب القبر، فنظرتُ أنا ومَسروق فلم نجدها إلا <span class="qpc-hafs">﴿تبارك﴾</span>{27}. (١٤/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٢<span class="dash">-</span></span> عن عمرو بن مُرّة، قال: كان يقال: إنّ من القرآن سورة تُجادِل عن صاحبها في القبر تكون ثلاثين آية. فنَظروا فوجدوها <span class="qpc-hafs">﴿تبارك﴾</span>{28}. (١٤/٦٠٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَبَـٰرَكَ ٱلَّذِی بِیَدِهِ ٱلۡمُلۡكُ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَبارَكَ﴾</span> يعني: افتَعل البركة، <span class="qpc-hafs">﴿وهُوَ عَلى كُلِّ شَيْءٍ﴾</span> أراده <span class="qpc-hafs">﴿قَدِيرٌ﴾</span>{29}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى جويبر في تفسيره.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤. وعزاه السيوطي إلى ابن مردويه.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٤٩.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٣٨٧أخرجه أحمد ١٣/٣٥٣ (٧٩٧٥)، ١٤/٢٨-٢٩ (٨٢٧٦)، وابن ماجه ٤/٧٠٣ (٣٧٨٦)، وأبو داود ٢/٥٤٧ (١٤٠٠)، والترمذي ٥/١٦٠-١٦١ (٣١١١)، والحاكم ١/٧٥٣ (٢٠٧٥)، من طريق شعبة، عن قتادة، عن عباس الجُشمي، عن أبي هريرة به.</p><p>قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٠ (٥٨٧٠): «إسناد صحيح».أخرجه الترمذي ٥/١٥٩-١٦٠ (٣١١٠)، والطبراني في الكبير ١٢/١٧٤ (١٢٨٠١)، من طريق يحيى بن عمرو بن مالك النكري، عن أبيه، عن أبي الجَوْزاء، عن ابن عباس به.</p><p>قال الترمذي: «هذا حديث غريب من هذا الوجه». وقال أبو نعيم في الحلية ٣/٨١: «غريب من حديث أبي الجَوْزاء، لم نكتبه مرفوعًا مجودًا إلا من حديث يحيى بن عمرو، عن أبيه». وقال البيهقي في دلائل النبوة ٧/٤١: «تفرّد به يحيى بن عمرو النكري، وهو ضعيف». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٥٥٣ (٣٤٤٥): «رواه يحيى بن عمرو بن مالك النكري، عن أبيه، عن أبي الجَوْزاء، عن ابن عباس. ويحيى ضعيف». وقال الألباني في الصحيحة ٣/١٣٢ معقّبًا على كلام أبي نعيم: «قلت: أبوه عمرو بن مالك صدوق له أوهام. وابنه يحيى ضعيف، ويقال: إنّ حماد بن زيد كذّبه كما في التقريب، وساق له في الميزان مِن مناكيره أحاديث هذا أحدها».أورده الديلمي في الفردوس ١/٦٢-٦٣ (١٧٩).</p><p>قال السيوطي: «سند واهٍ».أخرجه عبد بن حميد في المنتخب من مسنده ص٢٠٦ (٦٠٣) واللفظ له، والطبراني في الكبير ١١/٢٤١ (١١٦١٦)، من طريق إبراهيم بن الحكم، عن أبيه، عن عكرمة، عن ابن عباس به.</p><p>قال الهيثمي في المجمع ٧/١٢٧ (١١٤٢٩): «فيه إبراهيم بن الحكم بن أبان، وهو ضعيف».أورده الديلمي في الفردوس ٥/٤٦٧ (٨٧٧٨) من مسند أنس بن نفيل.زبر الرجل يزبره زبرًا: انتهره. لسان العرب (زبر).رجل كاسف البال: سيئ الحال. لسان العرب (كسف).أي: لم يظفر ولم يصب منه شيئًا. لسان العرب (حلي).أخرجه المستغفري في فضائل القرآن ٢/٦٤٦ (٩٦٠)، وابن عساكر في تاريخ دمشق ٦/٤٥-٤٦، من طريق خلف بن عبد الحميد، عن الفرات بن السّائِب، عن الزُّهريّ، عن أنس به.</p><p>وقال المستغفري: «قال أبو أحمد الحافظ: هذا حديث غريب من حديث الزُّهريّ عن أنس، منكر الإسناد والمتن جميعًا». وقال ابن كثير في تفسيره ٨/١٧٥: «حديث منكر جدًّا». وقال السيوطي: «سند ضعيف».عزاه السيوطي إلى ابن مردويه.أخرجه أبو الشيخ في طبقات المحدثين ٤/١٠-١١، والشجري في ترتيب الأمالي الخميسية ١/١٥٩ (٥٦٩)، من طريق أبي أحمد الزبيري، عن سفيان، عن عاصم، عن زر، عن عبد الله به.</p><p>قال المناوي في التيسير ٢/٦٢: «إسناد حسن». وقال في فيض القدير ٤/١١٥ (٤٧٢٧): «رمز المصنف -السيوطي- لحُسنه. قال الحافظ ابن حجر في أماليه: إنه حسن». وقال الألباني في الصحيحة ٣/١٣١ (١١٤٠): «السند حسن».عزاه السيوطي إلى ابن مردويه.أخرجه عبد الله بن وهب في الجامع -علوم القرآن ٣/٢٣ (٣٤)-، وابن نصر في قيام الليل ص٦٦، وابن الضريس (٢٣١)، والطبراني (٨٦٥١)، والحاكم ٢/٤٩٨، والبيهقي في شعب الإيمان (٢٥٠٩).أخرجه الطبراني (١٠٢٥٤). وعزاه السيوطي إلى ابن مردويه.أخرجه أبو عبيد ص١٣٩، والبيهقي في الدلائل ٧/٤١ مختصرًا.أخرجه الدارمي ٢/٤٥٥ وابن الضريس (٢٣٤).أخرجه ابن الضريس (٢٣٤).عزاه السيوطي إلى سعيد بن منصور.تفسير مقاتل بن سليمان ٤/٣٨٩.
  67,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی خَلَقَ ٱلۡمَوۡتَ وَٱلۡحَیَوٰةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٠٤<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</span>، قال: كان رسول الله ﷺ يقول: «<b>إنّ الله أذَلّ بني آدم بالموت، وجعل الدنيا دار حياة ثم دار موت، وجعل الآخرة دار جزاء ثم دار بقاء</b>»{1}. (١٤/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</span>، يريد: الموت في الدنيا، والحياة في الآخرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: خلق الله الموت على صورة كَبشٍ أمْلح، لا يمُرّ بشيء ولا يجد رِيحه شيء إلا مات، وخَلق الحياة على صورة فرسٍ بلقاء أنثى، وهي التي كان جبريل والأنبياء يَركبونها، لا تمُرّ بشيء ولا يجد ريحها شيء إلا حَيي، وهي التي أخذ السّامريُّ قبضة مِن أثرها فألقى على العجل فحَيي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر-: أنه يُجاء بالموت يوم القيامة في صورة كبش، فيقال: يا أهل الجنة، هل تعرفون هذا؟ فيقولون: نعم. ثم يُقال لأهل النار: هل تعرفون هذا؟ فيقولون: يا ربّ، هذا الموت. فَيُسْحَطُ سَحَطًا؛ يعني: يُذبح ذبحًا، ثم يقال: خلود لا موت فيه. قال <span class="name-3">معمر</span>: سمعتُ إنسانًا يقول: فما أتى على أهل النار يومٌ قطّ أشدّ حزنًا منه، وما أتى على أهل الجنة يوم قطّ أشد سرورًا منه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٠٩<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق عبد الصمد- قال: خلَق الله الموتَ كبشًا أملح مُستترًا بسواد وبياض، له أربعة أجنحة؛ جَناح تحت العرش، وجَناح في الثَّرى، وجَناح في المشرق، وجَناح في المغرب{5}. (١٤/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</span>، قال: الحياة فرس جبريل ﵇، والموت كبش أملح{6}. (١٤/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</span> فيُميت الأحياء، ويُحيي الموتى من نُطفة، ثم عَلقة، ثم يَنفخ فيه الروح، فيصير حيًّا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِیَبۡلُوَكُمۡ أَیُّكُمۡ أَحۡسَنُ عَمَلࣰاۚ وَهُوَ ٱلۡعَزِیزُ ٱلۡغَفُورُ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨١٢<span class="dash">-</span></span> عن أبي قتادة، قال: قلتُ: يا رسول الله، أرأيتَ قول الله تعالى: <span class="qpc-hafs">﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</span> ما عني به؟ قال: «<b>يقول: أيكم أحسن عقلًا</b>»{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٣<span class="dash">-</span></span> عن ابن عمر مرفوعًا: «<b><span class="qpc-hafs">﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</span>: «أحسن عقلًا، وأورع عن محارم الله، وأسرع في طاعة الله</b>»{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك بن مُزاحِم- قال: <span class="qpc-hafs">﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</span> أيّكم أتمُّ للفريضة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</span> أيّكم أزهد في الدنيا وأَتْرك لها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</span>، قال: أيّكم أكثر للموت ذِكرًا، وله أحسن استعدادًا، ومنه أشد خوفًا وحذرًا{12}. (١٤/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِيَبْلُوَكُمْ﴾</span> يعني: ليختبركم بها، <span class="qpc-hafs">﴿وهُوَ العَزِيزُ﴾</span> في مُلكه، في نِقمته لمن عصاه، <span class="qpc-hafs">﴿الغَفُورُ﴾</span> لذنوب المؤمنين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨١٨<span class="dash">-</span></span> عن <span class="name-3">فُضَيل بن عِياض</span> -من طريق إبراهيم بن الأشعث- <span class="qpc-hafs">﴿لِيَبْلُوَكُمْ أيُّكُمْ أحْسَنُ عَمَلًا﴾</span>، قال: أخلَصه وأَصوَبه، قال: إنّ العمل إذا كان خالصًا ولم يكن صوابًا لم يُقبل، وإذا كان صوابًا ولم يكن خالصًا لم يُقبل، حتى يكون خالصًا صوابًا، والخالص: إذا كان لله، والصواب: إذا كان على السُّنّة{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١١٨ مُقتصرًا على أوله. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٨/١٧٣.تفسير الثعلبي ٩/٣٥٥، وتفسير البغوي ٨/١٧٣.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١١٨ بنحوه.أخرجه أبو الشيخ في العظمة (٤٤١).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٣٨٩.أخرجه الحارث في مسنده ٢/٨٠٤ (٨٢٠)، والثعلبي ٩/٣٥٥، من طريق داود بن المحبر، عن ميسرة، عن محمد بن زيد، عن أبي سلمة، عن أبي قتادة به.</p><p>سنده شديد الضعف؛ فيه داود بن المحبر، قال عنه ابن حجر في التقريب (١٨١١): «متروك».أخرجه الحارث في مسنده ٢/٨٠٩ (٨٣١)، والدينوري في المجالسة وجواهر العلم ٢/١٢٥-١٢٦ (٢٦٢)، وابن جرير ١٢/٣٣٥، وابن أبي حاتم ٦/٢٠٠٦ (١٠٧٠٥)، والثعلبي ٩/٣٥٥، من طريق داود بن المحبر، عن عبد الواحد بن زياد، عن كليب بن وائل، عن ابن عمر به.</p><p>وقال السيوطي في الإتقان ٤/٢٦٢: «سند ضعيف».تفسير مقاتل بن سليمان ٤/٣٨٩.تفسير الثعلبي ٩/٣٥٦، وتفسير البغوي ٨/١٧٦.أخرجه ابن أبي الدنيا في قصر الأمل (١٣٢)، والبيهقي في شعب الإيمان (١٠٧٨٨).تفسير مقاتل بن سليمان ٤/٣٨٩.أخرجه ابن أبي الدنيا في كتاب الإخلاص والنية -موسوعة الإمام ابن أبي الدنيا ١/١٧٧ (٢٢)-، والثعلبي ٩/٣٥٦.
  67,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی خَلَقَ سَبۡعَ سَمَـٰوَ ٰ⁠تࣲ طِبَاقࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿سَبْعَ سَماواتٍ طِباقًا﴾</span>، قال: بعضها فوق بعض{1}. (١٤/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٢٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، مثله{2}. (١٤/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِي خَلَقَ سَبْعَ سَماواتٍ﴾</span> في يومين <span class="qpc-hafs">﴿طِباقًا﴾</span> بعضها فوق بعض، بين كلّ سماءين مسيرة خمسمائة سنة، وغِلظ كلّ سماء مسيرة خمسمائة سنة{3}<span class=comment-ref>٦٦٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٦٩٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/٧١) في قوله: <span class="qpc-hafs">﴿خلق سبع سموات طباقا﴾</span> قولين: <b>الأول</b>: أنهن متواصلات بمعنى أنهن علويات بعضهنّ فوق بعض. <b>الثاني</b>: أنهن متفاصلات بينهن خلاء.</p><p>و<span class="comment-type-3">رجّح</span> -<span class="mustanad">مستندًا إلى السنة</span>- الثاني بقوله: «أصحهما الثاني، كما دل على ذلك حديث الإسراء وغيره».</div></p><p><h3><span class="qpc-hafs">﴿مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنه قرأ: ‹مِن تَفَوُّتٍ›{4}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٢٣<span class="dash">-</span></span> عن <span class="name-2">عَلقمة بن قيس</span> أنه كان يقرأ: ‹ما تَرى فِي خَلْقِ الرَّحْمَنِ مِن تَفَوُّتٍ›{5}<span class=comment-ref>٦٦٩٨</span>. (١٤/٦٠٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٦٩٨</span> ذكر <u>ابنُ جرير</u> (٢٣/١٢٠) القراءتين، ثم <span class="comment-type-4">علّق</span> قائلًا: «والصواب من القول في ذلك أنهما قراءتان معروفتان بمعنى واحد، كما قيل: ولا تصاعر؛ ولا تصعر، وتعهدتُ فلانًا؛ وتعاهدتُه، وتظهرت؛ وتظاهرت، وكذلك التفاوت والتفوت».</p><p>و<span class="comment-type-4">علّق</span> عليهما <u>ابنُ عطية</u> (٨/٣٥٢) بقوله: «وهما بمعنى واحد».</div></p><p><h3><span class="qpc-hafs">﴿مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ما تَرى فِي خَلْقِ الرَّحْمَنِ مِن تَفاوُتٍ﴾</span> قال: ما يَفُوت بعضه بعضًا. تَفاوتٌ: تَفرّقٌ{6}. (١٤/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿مِن تَفاوُتٍ﴾</span>، قال: تَشقُّقٌ{7}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿مِن تَفاوُتٍ﴾</span>، قال: من اختلاف{8}<span class=comment-ref>٦٦٩٩</span>. (١٤/٦٠٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٦٩٩</span> لم يذكر <u>ابنُ جرير</u> (٢٣/١١٩) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٧٧٨٢٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله تعالى: <span class="qpc-hafs">﴿ما ترى في خلق الرحمن من تفاوت﴾</span>، قال: يقال: لا يَفُوت بعضه بعضًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما تَرى فِي خَلْقِ الرَّحْمنِ مِن تَفاوُتٍ﴾</span>، يقول: ما ترى ابن آدم في خَلْق السموات من عيب{3}<span class=comment-ref>٦٧٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٠</span> أفاد قول مقاتل أنّ قوله تعالى: <span class="qpc-hafs">﴿في خلق الرحمن﴾</span> مراد به السموات، وقد ذكر ذلك <u>ابنُ عطية</u> (٨/٣٥٢) وزاد <b>قولًا</b> آخر، فقال: «وقال آخرون: <span class="qpc-hafs">﴿في خلق الرحمن﴾</span> مَعنيّ به: جميع ما في خَلْق الله تعالى من الأشياء، فإنها لا تَفاوت فيها ولا فُطور، جارية على غير إتقان، ومتى كانت فُطور لا تُفسد الشيء المخلوق من حيث هو ذلك الشيء، بل هي إتقان فيه، فليست تلك المرادة في الآية، وقال مُنذر بن سعيد: أمَر الله تعالى بالنظر إلى السماء وخَلْقها، ثم أمر بالتكرير في النظر، وكذلك جميع المخلوقات متى نظرها ناظر ليرى فيها خللًا أو نقصًا، فإنّ بصره يَنقلب خاسئًا حسيرًا».</div></p><p><h3><span class="qpc-hafs">﴿فَٱرۡجِعِ ٱلۡبَصَرَ هَلۡ تَرَىٰ مِن فُطُورࣲ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿هَلْ تَرى مِن فُطُورٍ﴾</span>، قال: شُقوق{7}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿مِن فُطُورٍ﴾</span>، قال: تَشقُّقٌ أو خَلَل{2}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قال: <span class="qpc-hafs">﴿هَلْ تَرى مِن فُطُورٍ﴾</span>، الفطور: الوُهِيّ{13}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿هَلْ تَرى مِن فُطُورٍ﴾</span> اختلاف وشُطور{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٣<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: <span class="qpc-hafs">﴿هَلْ تَرى مِن فُطُورٍ﴾</span> عَيب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿مِن فُطُورٍ﴾</span>، قال: مِن خَلَل{16}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٥<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿هَلْ تَرى مِن فُطُورٍ﴾</span> فُروج{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿مِن فُطُورٍ﴾</span>، قال: مِن خَلَل{2}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- قوله ﷿: <span class="qpc-hafs">﴿هل ترى من فطور﴾</span>، قال: يقال: هل تَرى من تَشقُّق أو خَلل{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فارْجِعِ البَصَرَ﴾</span> يعني: أعِدِ البصرَ ثانية إلى السماوات، <span class="qpc-hafs">﴿هَلْ تَرى﴾</span> ابن آدم في السموات <span class="qpc-hafs">﴿مِن فُطُورٍ﴾</span> يعني: مِن فُروج{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٣٩<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿هَلْ تَرى مِن فُطُورٍ﴾</span>، قال: مِن شُقوق{21}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٣٨٩.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مِن تَفاوُتٍ﴾</span> بألف والتخفيف. انظر: النشر ٢/٣٨٩، والإتحاف ص٥٥٠.عزاه السيوطي إلى سعيد بن منصور.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، وابن مردويه.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١١٩ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٣٨٩.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢٠. والوُهِيّ: جمع وهْي، وهو الشق. اللسان (وهي).تفسير الثعلبي ٩/٣٥٧.تفسير الثعلبي ٩/٣٥٧.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١٢١، كذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٣٥٧.عزاه السيوطي إلى ابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٣٨٩.أخرجه ابن جرير ٢٣/١٢١.
  67,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱرۡجِعِ ٱلۡبَصَرَ كَرَّتَیۡنِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- <span class="qpc-hafs">﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾</span>، يقول: هل تَرى في السماء مِن خَلَل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾</span> مَرّة بعد مَرّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾</span>، يقول: أعِدِ البصرَ الثانية{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَنقَلِبۡ إِلَیۡكَ ٱلۡبَصَرُ خَاسِئࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يَنْقَلِبْ إلَيْكَ﴾</span>، قال: يَرجع إليك{4}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿خاسِئًا﴾</span>، قال: ذليلًا{5}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿خاسِئًا﴾</span>، قال: صاغرًا{4}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿خاسِئًا﴾</span>، قال: صاغرًا{7}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يَنْقَلِبْ إلَيْكَ البَصَرُ خاسِئًا﴾</span> أي: حاسرًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَنْقَلِبْ﴾</span> يعني: يَرجع <span class="qpc-hafs">﴿إلَيْكَ﴾</span> ابن آدم <span class="qpc-hafs">﴿البَصَرُ خاسِئًا﴾</span> يعني: إذا اشتدّ البصرُ يقع فيه الماء خاسئًا، يعني: صاغرًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿يَنْقَلِبْ إلَيْكَ البَصَرُ خاسِئًا﴾</span> الخاسئ، والخاسر واحد؛ حسُر طرْفه أن يرى فيها فَطْرًا، فرجع وهو حسير قبل أن يَرى فيها فَطْرًا. قال: فإذا جاء يوم القيامة انفطَرتْ، ثم انشقّتْ، ثم جاء أمر أكبر من ذلك؛ انكَشطتْ{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ حَسِیرࣱ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span>، قال: كَلِيل{11}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span>، قال: مُعْيٍ، ولا يَرى شيئًا{4}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ-: <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span> بسواد الليل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span>، قال: متوجع{14}. (١٤/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span>، قال: مُرجفٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span> قال: مُعْيٍ لا يَرى في خلْق الرحمن تَفاوتًا ولا خَللًا{16}. (١٤/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span>، يقول: هو المُعْيى{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُوَ حَسِيرٌ﴾</span> يعني: كالًّا مُنقطعًا، لا يَرى فيها عَيبًا ولا فُطورًا{18}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٢١.تفسير البغوي ٨/١٧٦.تفسير مقاتل بن سليمان ٤/٣٨٩-٣٩٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢١ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٢٢.تفسير مقاتل بن سليمان ٤/٣٨٩-٣٩٠.أخرجه ابن جرير ٢٣/١٢٢.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢١.عزاه السيوطي إلى ابن جرير، وابن المنذر. وفي ابن جرير ٢٣/١٢١ بلفظ: مرجف، من طريق علي كما في الأثر التالي.أخرجه ابن جرير ٢٣/١٢١.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١٢٢، كذا من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٠٥.تفسير مقاتل بن سليمان ٤/٣٩٠.
  67,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا﴾</span> لأنها أدنى السموات، وأقربها من الأرض مِن غيرها <span class="qpc-hafs">﴿بِمَصابِيحَ﴾</span> وحفظًا، يعني: الكواكب، <span class="qpc-hafs">﴿وجَعَلْناها﴾</span> يعني: الكواكب <span class="qpc-hafs">﴿رُجُومًا﴾</span> يعني: رميًا <span class="qpc-hafs">﴿لِلشَّياطِينِ﴾</span> يعني: إذا ارتَقوا إلى السماء، <span class="qpc-hafs">﴿وأَعْتَدْنا لَهُمْ﴾</span> يعني: للشياطين <span class="qpc-hafs">﴿عَذابَ السَّعِيرِ﴾</span> يعني: الوقود{1}<span class=comment-ref>٦٧٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠١</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٣٥٣): «أخبر تعالى أنه زيّن السماء الدنيا إلينا -أي: التي تلينا- بمصابيح، وهي النّجوم، فإن كانت جميع النّجوم في السماء الدنيا فهذا اللفظ عام للكواكب، وإن كان في سائر السماوات كواكب؛ فإما أن يريد كواكب سماء الدنيا فقط، وإما أن يريد الجميع على أنّ ما في غيرها لما كانت هي تشفّ عنه، ويظهر منها، فقد تزيّنتْ به بوجه ما، ومَن تكلّف القول لمواضع الكواكب وفي أي سماء هي فقوله ليس من الشريعة».</div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ ۝٥﴾</span> - آيات متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا بِمَصابِيحَ وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾</span>: إنّ الله -جلّ ثناؤه- إنما خلَق هذه النّجوم لثلاث خِصال: خَلَقها زِينة للسماء الدنيا، ورُجومًا للشياطين، وعلامات يُهتدى بها؛ فمَن يَتأوّل منها غير ذلك فقد قال برأيه، وأخطأ حظّه، وأضاع نصيبه، وتَكلّف ما لا عِلم له به{2}<span class=comment-ref>٦٧٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٣٥٣-٣٥٤): «<span class="qpc-hafs">﴿وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾</span> معناه: وجعلنا منها، وهذا كما تقول: أكرمتُ بني فلان وصنعتُ بهم، وأنتَ إنما فعلتَ ذلك ببعضهم دون بعض، ويوجب هذا التأويل في الآية <span class="mustanad">أنّ الكواكب الثابتة والبروج، وكلّ ما يُهتدى به في البر والبحر فليست برواجم</span>، وهذا نصٌ في حديث السير». ثم ذكر قول قتادة.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.أخرجه ابن جرير ٢٣/١٢٣، وأخرجه عبد بن حميد في تفسيره -كما في تغليق التعليق ٣/٤٨٩- من طريق شيبان بنحوه.
  67,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ عَذَابُ جَهَنَّمَۖ وَبِئۡسَ ٱلۡمَصِیرُ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِلَّذِينَ كَفَرُوا بِرَبِّهِمْ﴾</span> الذين كفروا بتوحيد الله، لهم في الآخرة <span class="qpc-hafs">﴿عَذابُ جَهَنَّمَ وبِئْسَ المَصِيرُ﴾</span> حيث يصيرون إليها{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.
  67,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذَاۤ أُلۡقُوا۟ فِیهَا سَمِعُوا۟ لَهَا شَهِیقࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا أُلْقُوا فِيها﴾</span> يعني: في جهنم، اختطفتهم الخَزنة بالكلاليب <span class="qpc-hafs">﴿سَمِعُوا لَها شَهِيقًا﴾</span> يعني: مثل نهيق الحمار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿سَمِعُوا لَها شَهِيقًا﴾</span>، قال: صِياحًا{2}. (١٤/٦٠٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهِیَ تَفُورُ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- في قوله: <span class="qpc-hafs">﴿وهِيَ تَفُورُ﴾</span>، قال: تفور بهم، كما يفور الحَبُّ القليل في الماء الكثير{3}. (١٤/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهِيَ تَفُورُ﴾</span>، يعني: تغلي{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهِیَ تَفُورُ ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٦٥<span class="dash">-</span></span> عن أبي يحيى، قال: إنّ الرجل لَيُجرّ إلى النار، فتنزوي ويَنقبض بعضها إلى بعض، فيقول لها الرحمن: ما لكِ؟ قالت: إنّه كان يستحي مني. فيقول: أرسِلوا عبدي. قال: وإنّ العبد ليُجرّ إلى النار، فيقول: يا ربّ، ما كان هذا الظنّ بك. قال: فما كان ظنّك؟ قال: كان ظني أن تَسعني رحمتكَ. فيقول: أرسِلوا عبدي. قال: وإنّ الرجل ليُجرّ إلى النار، فتَشهق إليه النار شَهيق البَغلة إلى الشّعير، ثم تَزفر زَفرة لا يبقى أحدٌ إلا خاف{5}. (١٤/٦٠٩٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.عزاه السيوطي إلى ابن المنذر.أخرجه هناد (٣١٣)، وابن جرير ٢٣/١٢٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٣٩٠.عزاه السيوطي إلى عبد بن حميد.
  67,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَكَادُ تَمَیَّزُ مِنَ ٱلۡغَیۡظِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿تَكادُ تَمَيَّزُ﴾</span>، قال: تَتفرّق{1}. (١٤/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- في قوله: <span class="qpc-hafs">﴿تَكادُ تَمَيَّزُ﴾</span>، قال: يُفارِق بعضُها بعضًا، وتَنفطر{2}. (١٤/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٦٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿تَكادُ تَمَيَّزُ﴾</span>، يقول: تَفرّق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَكادُ تَمَيَّزُ﴾</span> تَفرّق جهنم عليهم <span class="qpc-hafs">﴿مِنَ الغَيْظِ﴾</span> على الكفار تأخذهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٧٠<span class="dash">-</span></span> عن <span class="name-3">فُضَيل بن عِياض</span> -من طريق فضيل- في قوله: <span class="qpc-hafs">﴿تَكادُ تَمَيَّزُ مِنَ الغَيْظِ﴾</span>، قال: تَقَطَّع{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿تَكادُ تَمَيَّزُ مِنَ الغَيْظِ﴾</span>، قال: التَّميّز: التَّفرّق مِن الغيظ على أهل معاصي الله؛ غضبًا لله، وانتقامًا له{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُلَّمَاۤ أُلۡقِیَ فِیهَا فَوۡجࣱ سَأَلَهُمۡ خَزَنَتُهَاۤ أَلَمۡ یَأۡتِكُمۡ نَذِیرࣱ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كُلَّما أُلْقِيَ فِيها فَوْجٌ﴾</span> يعني: زُمرة؛ اختَطفتهم الخَزنة بالكلاليب، يعني: مشركي العرب واليهود والنصارى والمجوس وغيرهم <span class="qpc-hafs">﴿سَأَلَهُمْ خَزَنَتُها﴾</span> خُزّان جهنم: <span class="qpc-hafs">﴿ألَمْ يَأْتِكُمْ نَذِيرٌ﴾</span> يعني: رسول، وهو محمد ﷺ{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢٤.أخرجه ابن جرير ٢٣/١٢٥.تفسير مقاتل بن سليمان ٤/٣٩٠.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٢)-.أخرجه ابن جرير ٢٣/١٢٥.تفسير مقاتل بن سليمان ٤/٣٩٠.
  67,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَلَىٰ قَدۡ جَاۤءَنَا نَذِیرࣱ فَكَذَّبۡنَا وَقُلۡنَا مَا نَزَّلَ ٱللَّهُ مِن شَیۡءٍ إِنۡ أَنتُمۡ إِلَّا فِی ضَلَـٰلࣲ كَبِیرࣲ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا بَلى قَدْ جاءَنا نَذِيرٌ فَكَذَّبْنا﴾</span> بالنذير، يعني: النبي ﷺ، <span class="qpc-hafs">﴿وقُلْنا﴾</span> للنبي ﷺ: <span class="qpc-hafs">﴿ما نَزَّلَ اللَّهُ مِن شَيْءٍ﴾</span> يعني: ما أرسل الله من أحد، يعني: من نبي، وقالوا للرسول محمد ﷺ: ما بَعث الله من رسول. <span class="qpc-hafs">﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ كَبِيرٍ﴾</span> يعني: شِقاق{1}<span class=comment-ref>٦٧٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٥٥) في قائل: <span class="qpc-hafs">﴿إن أنتم إلا في ضلال كبير﴾</span> احتمالين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ كَبِيرٍ﴾</span> <b>يحتمل</b> أن يكون من قول الملائكة للكفار حين أخبروا عن أنفسهم أنهم كَذّبوا النُّذر، <b>ويحتمل</b> أن يكون من كلام الكفار للنّذر».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.
  67,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَوۡ كُنَّا نَسۡمَعُ أَوۡ نَعۡقِلُ مَا كُنَّا فِیۤ أَصۡحَـٰبِ ٱلسَّعِیرِ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٧٤<span class="dash">-</span></span> عن أبي سعيد الخُدري، أنّ رسول الله ﷺ، قال: «<b>إنّ لكل شيء دعامة، ودعامة المؤمن عقله، فبقدْر ما يَعقل يَعبُد ربه، ولَعَمري لقد ندم الكفار يوم القيامة، <span class="qpc-hafs">﴿وقالوا لو كنا نسمع أو نعقل ما كنا في أصحاب السعير﴾</span></b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٧٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لَوْ كُنّا نَسْمَعُ﴾</span> الهُدى أو نعقله؛ فنعمل به{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا لَوْ كُنّا نَسْمَعُ أوْ نَعْقِلُ﴾</span> المواعظ{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الواحدي في الوسيط ٤/٣٢٨.تفسير الثعلبي ٩/٣٥٨، وتفسير البغوي ٨/١٧٧.تفسير مقاتل بن سليمان ٤/٣٩١.
  67,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱعۡتَرَفُوا۟ بِذَنۢبِهِمۡ فَسُحۡقࣰا لِّأَصۡحَـٰبِ ٱلسَّعِیرِ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>-من طريق علي- <span class="qpc-hafs">﴿فَسُحْقًا﴾</span>، قال: بُعدًا{1}. (١٤/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿فَسُحْقًا﴾</span>، قال: بُعدًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حسان:</p><p>ألا مِن مُبلِّغ عنِّي أُبيًّا فقد أُلقيتَ في سُحق السعير؟{2}. (١٤/٦١١)</p><p>٧٧٨٧٨/ب عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سَلمة بن كُهيل- في قوله: <span class="qpc-hafs">﴿فَسُحْقًا﴾</span>، قال: سُحْقٌ: وادٍ في جهنم{3}<span class=comment-ref>٦٧٠٤</span>. (١٤/٦١١)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٤</span> لم يذكر <u>ابنُ جرير</u> (٢٣/١٢٦) غير قول سعيد بن جُبَير.</div></p><p><div></p><p><p><span class="item-no">٧٧٨٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿فاعْتَرَفُوا بِذَنْبِهِمْ﴾</span> يعني: بتكذيبهم الرُّسُل <span class="qpc-hafs">﴿فَسُحْقًا لِأَصْحابِ السَّعِيرِ﴾</span> يعني: الوقود{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٢٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى الطستي في مسائله.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٨/٥١٧ (٣٥٣٢٥)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٠٨ (٣٩)- وزاد: يقال له سُحْق، وابن جرير ٢٣/١٢٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٣٩١.
  67,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ یَخۡشَوۡنَ رَبَّهُم بِٱلۡغَیۡبِ لَهُم مَّغۡفِرَةࣱ وَأَجۡرࣱ كَبِیرࣱ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿إنَّ الَّذِينَ يَخْشَوْنَ رَبَّهُمْ بِالغَيْبِ﴾</span>، قال: أبو بكر، وعمر، وعلي، وأبو عبيدة بن الجرّاح{1}. (١٤/٦١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ يَخْشَوْنَ رَبَّهُمْ بِالغَيْبِ﴾</span> ولم يَروه، فآمنوا <span class="qpc-hafs">﴿لَهُمْ مَغْفِرَةٌ﴾</span> لذنوبهم، <span class="qpc-hafs">﴿وأَجْرٌ كَبِيرٌ﴾</span> يعني: جزاء كبيرًا في الجنة{2}<span class=comment-ref>٦٧٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٥</span> ذكر <u>ابنُ عطية</u> (٨/٣٥٦) في قوله: <span class="qpc-hafs">﴿بالغيب﴾</span> احتمالين، و<span class="comment-type-1">وجّههما</span>، فقال: «<span class="qpc-hafs">﴿بِالغَيْبِ﴾</span> يحتمل معنيين: <b>أحدهما</b>: بالغَيْبِ الذي أُخبروا به من الحَشْر والصراط والميزان والجنة والنار، فآمَنوا بذلك، وخَشوا ربهم فيه، ونحا إلى هذا قتادة. والمعنى <b>الثاني</b>: أنهم يَخشَون ربهم إذا غابوا عن أعين الناس، أي: في خلواتهم، ومنه <span class="mustanad">تقول العرب</span>: فلان سالم الغيب، أي: لا يضر، فالمعنى: يعملون بحسب الخشية في صلاتهم وعباداتهم، وانفرادهم، فالاحتمال الأول: مدحٌ بالإخلاص والإيمان، والثاني: مدحٌ بالأعمال الصالحة في الخلوات، وذلك أحرى أن يعملوها علانية».</div></p><p><div></p><p><p><span class="item-no">٧٧٨٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وأَجْرٌ كَبِيرٌ﴾</span>، قال: الجنة{3}. (١٤/٦١١)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٣٩١.عزاه السيوطي إلى ابن المنذر.