quran[12]{c,v,t}:
67,1," مقدمة السورة ٧٧٧٧٧- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: أُنزلت <q>﴿تبارك﴾</q> المُلك في أهل مكة، إلا ثلاث آيات{1}. (١٤/٥٩٩) ٧٧٧٧٨- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها <q>﴿تبارك﴾</q> المُلك، وذكر أنها بعد الطُّور{2}. (ز) ٧٧٧٧٩- عن عبد الله بن عباس -من طريق خُصَيف عن مجاهد-: مكّيّة، وسمّاها: <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q>{3}. (١٤/٥٩٩) ٧٧٧٨٠- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء عن مجاهد- قال: مكّيّة{4}. (١٤/٥٩٩) ٧٧٧٨١- عن عبد الله بن الزبير، مثله{5}. (١٤/٥٩٩) ٧٧٧٨٢- عن عكرمة مولى ابن عباس= (ز) ٧٧٧٨٣- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{6}. (ز) ٧٧٧٨٤- عن قتادة بن دعامة -من طرق-: مكّيّة{7}. (ز) ٧٧٧٨٥- عن محمد بن شهاب الزُّهريّ: مكّيّة، ونزلت بعد سورة الطُّور{8}. (ز) ٧٧٧٨٦- عن علي بن أبي طلحة: مكّيّة{9}. (ز) ٧٧٧٨٧- قال مقاتل بن سليمان: سورة المُلك مكّيّة، عددها ثلاثون آية{10}٦٦٩٦. (ز) ٦٦٩٦ قال ابن عطية (٨/٣٥٠): «وهي مكّيّة بإجماع». ٧٧٧٨٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ سورةً مِن كتاب الله ما هي إلا ثلاثون آية شَفَعتْ لرجل حتى غُفر له؛ <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q>»{11}. (١٤/٥٩٩) ٧٧٧٨٩- عن عبد الله بن عباس، قال: ضَرب بعض أصحابُ النبيِّ ﷺ خِباءه على قبر، وهو لا يَحسَب أنه قبر، فإذا فيه إنسان يقرأ سورة المُلك حتى خَتمَها، فأتى النبيَّ ﷺ، فأَخبَره، فقال رسول الله ﷺ: «هي المانعة، هي المُنجِية؛ تُنجِيه من عذاب القبر»{12}. (١٤/٦٠٠) ٧٧٧٩٠- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «إنِّي لَأجد في كتاب الله سورة هي ثلاثون آية، مَن قرأها عند نومه كُتب له منها ثلاثون حسنة، ومُحِي عنه ثلاثون سيئة، ورُفع له ثلاثون درجة، وبَعث الله إليه مَلكًا مِن الملائكة لِيَبسُط عليه جَناحه، ويَحفظه مِن كلّ سوء حتى يَستيقظ، وهي المُجادِلة؛ تُجادل عن صاحبها في القبر، وهي: <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q>»{13}. (١٤/٦٠٥) ٧٧٧٩١- عن عبد الله بن عباس، أنه قال لرجل: ألا أُتْحِفُك بحديث تَفرح به؟ قال: بلى. قال: اقرأ: <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q>، وعلِّمها أهلك وجميع ولدك وصبيان بيتك وجيرانك؛ فإنها المُنجِية والمُجادِلة يوم القيامة عند ربها لقارئها، وتَطلب له أن تُنجِيه من عذاب النار، ويَنجو بها صاحبها من عذاب القبر. قال: قال رسول الله ﷺ: «لودِدتُ أنها في قلب كلِّ إنسان مِن أُمّتي»{14}. (١٤/٦٠١) ٧٧٧٩٢- عن أنس مرفوعًا، قال: «يُبعث رجل يوم القيامة لم يَترك شيئًا من المعاصي إلا رَكِبها، إلا أنه كان يُوَحِّد الله، ولم يكن يقرأ من القرآن إلا سورة واحدة، فيُؤمر به إلى النار، فطار مِن جوفه شيء كالشّهاب، فقالت: اللهم، إنِّي مما أنزَلَتْ على نبيّك ﷺ، وكان عبدك هذا يقرؤني. فما زالت تَشفع حتى أدخلتْه الجنة، وهي المُنجِية: <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q>»{15}. (١٤/٦٠٤) ٧٧٧٩٣- عن أنس، قال: قال رسول الله ﷺ: «إنّ رجلًا مِمّن كان قبلكم مات وليس معه شيء من كتاب الله إلا <q>﴿تَبارَكَ﴾</q>، فلما وُضع في حُفرته أتاه المَلَك، فثارت السورة في وجهه، فقال لها: إنكِ من كتاب الله، وأنا أكره مساءتكِ، وإني لا أملك لكِ ولا له ولا لنفسي ضَرًّا ولا نَفعًا، فإنْ أردتِ هذا به فانطلِقي إلى الرّبّ، فاشفعي له. فانطلَقتْ إلى الرّبّ، فتقول: يا ربِّ، إنّ فلانًا عَمد إلَيّ مِن بين كتابك، فتعلَّمني، وتلاني، أفتحرقه أنتَ بالنار وتُعذِّبه وأنا في جوفه؟! فإن كنتَ فاعلًا به فامحُني مِن كتابكَ. فيقول: ألا أراكِ غضبتِ. فتقول: وحُقَّ لي أنْ أغضب. فيقول: اذهبي، فقد وهبتُه لكِ، وشَفّعتُكِ فيه. فتجيء، فَتَزبُر{16} المَلك، فيَخرج كاسِفَ البال{17}، لم يحْلَ{18} منه بشيء، فتجيء، فتضع فاها على فيه، فتقول: مرحبًا بهذا الفم فرُبّما تلاني، ومرحبًا بهذا الصدر فرُبّما وعاني، ومرحبًا بهاتين القدمين فرُبّما قامتا بي. وتُؤنسه في قبره مخافة الوحْشة عليه». فلمّا حَدّث رسول الله ﷺ هذا الحديث لم يبقَ صغير ولا كبير ولا حُرّ ولا عبد إلا تعلَّمها، وسمّاها رسول الله ﷺ المُنجِية{19}. (١٤/٦٠١) ٧٧٧٩٤- عن رافع بن خُدَيج، وأبي هريرة، أنهما سمعا رسول الله ﷺ يقول: «أُنزِلَتْ عليّ سورة تبارك -وهي ثلاثون آية- جملة واحدة». وقال: «هي المانعة في القبور، وإنّ قراءة <q>﴿قُلْ هُوَ اللَّهُ أحَدٌ﴾</q> تَعدِل في الصلاة قراءة ثُلث القرآن، وإنّ قراءة <q>﴿قُلْ يا أيُّها الكافِرُونَ﴾</q> في الصلاة تَعدِل ربع القرآن، وإنّ قراءة <q>﴿إذا زُلْزِلَتِ﴾</q> في صلاة تَعدِل نصف القرآن»{5}. (١٤/٦٠٠) ٧٧٧٩٥- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «سورة تبارك هي المانعة من عذاب القبر»{21}. (١٤/٦٠٠) ٧٧٧٩٦- عن عبد العزيز، عن أبيه، قال: قال رسول الله ﷺ: «دخل رجل الجنة بشفاعة سورة من القرآن، وما هي إلا ثلاثون آية: <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q>»{5}. (١٤/٦٠٦) ٧٧٧٩٧- عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيْش- قال: يُؤتى الرجل في قبره، فيُؤتى من قِبَل رجليه، فتقول رِجلاه: ليس لكم على ما قِبَلي سبيل؛ قد كان يقوم علينا بسورة المُلك. ثم يُؤتى من قِبَل صدره، فيقول: ليس لكم على ما قِبَلي سبيل؛ قد كان وعى فيّ سورة الملك. ثم يُؤتى من قِبَل رأسه، فيقول: ليس لكم على ما قِبَلي سبيل؛ قد كان يقرأ بي سورة المُلك. فهي المانعة تمنع من عذاب القبر، وهي في التوراة سورة المُلك، مَن قرأها في ليلة فقد أكثر وأطيَب{23}. (١٤/٦٠٣) ٧٧٧٩٨- عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيْش- قال: كُنّا نُسمِّيها في عهد رسول الله ﷺ: المانعة، وإنها لفي كتاب الله: سورة المُلك. من قرأها في ليلة فقد أكثر وأطيَب{24}. (١٤/٦٠٣) ٧٧٧٩٩- عن عبد الله بن مسعود -من طريق مُرّة- قال: إنّ الميت إذا مات أُوقدت حوله نيران، فتأكل كلّ نار ما يليها إن لم يكن له عمل يَحوُل بينه وبينها، وإنّ رجلًا مات ولم يكن يقرأ من القرآن إلا سورة ثلاثين آية، فأَتتْه من قِبَل رأسه، فقالتْ: إنه كان يقرأ بي. فأَتتْه من قِبَل رجليه، فقالتْ: إنه كان يقوم بي. فأتته من قِبَل جوفه، فقالتْ: إنه كان وعاني. فأَنجتْه. قال: فنظرتُ أنا ومَسروق في المصحف، فلم نجد سورة ثلاثين آية إلا <q>﴿تبارك﴾</q>{25}. (١٤/٦٠٣) ٧٧٨٠٠- عن مُرّة مثله، مرسلًا{26}. (١٤/٦٠٤) ٧٧٨٠١- عن مُرّة الهَمذاني، قال: أُتِيَ رجل من جوانب قبره، فجَعلتْ سورةٌ مِن القرآن ثلاثون آية تُجادِل عنه، حتى مَنعتْه من عذاب القبر، فنظرتُ أنا ومَسروق فلم نجدها إلا <q>﴿تبارك﴾</q>{27}. (١٤/٦٠٥) ٧٧٨٠٢- عن عمرو بن مُرّة، قال: كان يقال: إنّ من القرآن سورة تُجادِل عن صاحبها في القبر تكون ثلاثين آية. فنَظروا فوجدوها <q>﴿تبارك﴾</q>{28}. (١٤/٦٠٤) <q>﴿تَبَـٰرَكَ ٱلَّذِی بِیَدِهِ ٱلۡمُلۡكُ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝١﴾</q> - تفسير ٧٧٨٠٣- قال مقاتل بن سليمان: <q>﴿تَبارَكَ﴾</q> يعني: افتَعل البركة، <q>﴿وهُوَ عَلى كُلِّ شَيْءٍ﴾</q> أراده <q>﴿قَدِيرٌ﴾</q>{29}. (ز) ",footnotes:1:عزاه السيوطي إلى جويبر في تفسيره.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤. وعزاه السيوطي إلى ابن مردويه.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٤٩.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٣٨٧أخرجه أحمد ١٣/٣٥٣ (٧٩٧٥)، ١٤/٢٨-٢٩ (٨٢٧٦)، وابن ماجه ٤/٧٠٣ (٣٧٨٦)، وأبو داود ٢/٥٤٧ (١٤٠٠)، والترمذي ٥/١٦٠-١٦١ (٣١١١)، والحاكم ١/٧٥٣ (٢٠٧٥)، من طريق شعبة، عن قتادة، عن عباس الجُشمي، عن أبي هريرة به. قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البوصيري في إتحاف الخيرة المهرة ٦/٢٩٠ (٥٨٧٠): «إسناد صحيح».أخرجه الترمذي ٥/١٥٩-١٦٠ (٣١١٠)، والطبراني في الكبير ١٢/١٧٤ (١٢٨٠١)، من طريق يحيى بن عمرو بن مالك النكري، عن أبيه، عن أبي الجَوْزاء، عن ابن عباس به. قال الترمذي: «هذا حديث غريب من هذا الوجه». وقال أبو نعيم في الحلية ٣/٨١: «غريب من حديث أبي الجَوْزاء، لم نكتبه مرفوعًا مجودًا إلا من حديث يحيى بن عمرو، عن أبيه». وقال البيهقي في دلائل النبوة ٧/٤١: «تفرّد به يحيى بن عمرو النكري، وهو ضعيف». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٥٥٣ (٣٤٤٥): «رواه يحيى بن عمرو بن مالك النكري، عن أبيه، عن أبي الجَوْزاء، عن ابن عباس. ويحيى ضعيف». وقال الألباني في الصحيحة ٣/١٣٢ معقّبًا على كلام أبي نعيم: «قلت: أبوه عمرو بن مالك صدوق له أوهام. وابنه يحيى ضعيف، ويقال: إنّ حماد بن زيد كذّبه كما في التقريب، وساق له في الميزان مِن مناكيره أحاديث هذا أحدها».أورده الديلمي في الفردوس ١/٦٢-٦٣ (١٧٩). قال السيوطي: «سند واهٍ».أخرجه عبد بن حميد في المنتخب من مسنده ص٢٠٦ (٦٠٣) واللفظ له، والطبراني في الكبير ١١/٢٤١ (١١٦١٦)، من طريق إبراهيم بن الحكم، عن أبيه، عن عكرمة، عن ابن عباس به. قال الهيثمي في المجمع ٧/١٢٧ (١١٤٢٩): «فيه إبراهيم بن الحكم بن أبان، وهو ضعيف».أورده الديلمي في الفردوس ٥/٤٦٧ (٨٧٧٨) من مسند أنس بن نفيل.زبر الرجل يزبره زبرًا: انتهره. لسان العرب (زبر).رجل كاسف البال: سيئ الحال. لسان العرب (كسف).أي: لم يظفر ولم يصب منه شيئًا. لسان العرب (حلي).أخرجه المستغفري في فضائل القرآن ٢/٦٤٦ (٩٦٠)، وابن عساكر في تاريخ دمشق ٦/٤٥-٤٦، من طريق خلف بن عبد الحميد، عن الفرات بن السّائِب، عن الزُّهريّ، عن أنس به. وقال المستغفري: «قال أبو أحمد الحافظ: هذا حديث غريب من حديث الزُّهريّ عن أنس، منكر الإسناد والمتن جميعًا». وقال ابن كثير في تفسيره ٨/١٧٥: «حديث منكر جدًّا». وقال السيوطي: «سند ضعيف».عزاه السيوطي إلى ابن مردويه.أخرجه أبو الشيخ في طبقات المحدثين ٤/١٠-١١، والشجري في ترتيب الأمالي الخميسية ١/١٥٩ (٥٦٩)، من طريق أبي أحمد الزبيري، عن سفيان، عن عاصم، عن زر، عن عبد الله به. قال المناوي في التيسير ٢/٦٢: «إسناد حسن». وقال في فيض القدير ٤/١١٥ (٤٧٢٧): «رمز المصنف -السيوطي- لحُسنه. قال الحافظ ابن حجر في أماليه: إنه حسن». وقال الألباني في الصحيحة ٣/١٣١ (١١٤٠): «السند حسن».عزاه السيوطي إلى ابن مردويه.أخرجه عبد الله بن وهب في الجامع -علوم القرآن ٣/٢٣ (٣٤)-، وابن نصر في قيام الليل ص٦٦، وابن الضريس (٢٣١)، والطبراني (٨٦٥١)، والحاكم ٢/٤٩٨، والبيهقي في شعب الإيمان (٢٥٠٩).أخرجه الطبراني (١٠٢٥٤). وعزاه السيوطي إلى ابن مردويه.أخرجه أبو عبيد ص١٣٩، والبيهقي في الدلائل ٧/٤١ مختصرًا.أخرجه الدارمي ٢/٤٥٥ وابن الضريس (٢٣٤).أخرجه ابن الضريس (٢٣٤).عزاه السيوطي إلى سعيد بن منصور.تفسير مقاتل بن سليمان ٤/٣٨٩.
67,2," <q>﴿ٱلَّذِی خَلَقَ ٱلۡمَوۡتَ وَٱلۡحَیَوٰةَ﴾</q> - تفسير ٧٧٨٠٤- عن قتادة، في قوله: <q>﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</q>، قال: كان رسول الله ﷺ يقول: «إنّ الله أذَلّ بني آدم بالموت، وجعل الدنيا دار حياة ثم دار موت، وجعل الآخرة دار جزاء ثم دار بقاء»{1}. (١٤/٦٠٧) ٧٧٨٠٥- عن عبد الله بن عباس: <q>﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</q>، يريد: الموت في الدنيا، والحياة في الآخرة{2}. (ز) ٧٧٨٠٦- قال عبد الله بن عباس: خلق الله الموت على صورة كَبشٍ أمْلح، لا يمُرّ بشيء ولا يجد رِيحه شيء إلا مات، وخَلق الحياة على صورة فرسٍ بلقاء أنثى، وهي التي كان جبريل والأنبياء يَركبونها، لا تمُرّ بشيء ولا يجد ريحها شيء إلا حَيي، وهي التي أخذ السّامريُّ قبضة مِن أثرها فألقى على العجل فحَيي{3}. (ز) ٧٧٨٠٧- عن الحسن البصري= (ز) ٧٧٨٠٨- وقتادة بن دعامة -من طريق معمر-: أنه يُجاء بالموت يوم القيامة في صورة كبش، فيقال: يا أهل الجنة، هل تعرفون هذا؟ فيقولون: نعم. ثم يُقال لأهل النار: هل تعرفون هذا؟ فيقولون: يا ربّ، هذا الموت. فَيُسْحَطُ سَحَطًا؛ يعني: يُذبح ذبحًا، ثم يقال: خلود لا موت فيه. قال معمر: سمعتُ إنسانًا يقول: فما أتى على أهل النار يومٌ قطّ أشدّ حزنًا منه، وما أتى على أهل الجنة يوم قطّ أشد سرورًا منه{4}. (ز) ٧٧٨٠٩- عن وهْب بن مُنَبِّه -من طريق عبد الصمد- قال: خلَق الله الموتَ كبشًا أملح مُستترًا بسواد وبياض، له أربعة أجنحة؛ جَناح تحت العرش، وجَناح في الثَّرى، وجَناح في المشرق، وجَناح في المغرب{5}. (١٤/٦٠٧) ٧٧٨١٠- عن قتادة بن دعامة، في قوله: <q>﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</q>، قال: الحياة فرس جبريل ﵇، والموت كبش أملح{6}. (١٤/٦٠٧) ٧٧٨١١- قال مقاتل بن سليمان: <q>﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾</q> فيُميت الأحياء، ويُحيي الموتى من نُطفة، ثم عَلقة، ثم يَنفخ فيه الروح، فيصير حيًّا{7}. (ز) <q>﴿لِیَبۡلُوَكُمۡ أَیُّكُمۡ أَحۡسَنُ عَمَلࣰاۚ وَهُوَ ٱلۡعَزِیزُ ٱلۡغَفُورُ ۝٢﴾</q> - تفسير ٧٧٨١٢- عن أبي قتادة، قال: قلتُ: يا رسول الله، أرأيتَ قول الله تعالى: <q>﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</q> ما عني به؟ قال: «يقول: أيكم أحسن عقلًا»{8}. (ز) ٧٧٨١٣- عن ابن عمر مرفوعًا: «<q>﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</q>: «أحسن عقلًا، وأورع عن محارم الله، وأسرع في طاعة الله»{9}. (ز) ٧٧٨١٤- عن عبد الله بن عباس -من طريق الضَّحّاك بن مُزاحِم- قال: <q>﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</q> أيّكم أتمُّ للفريضة{7}. (ز) ٧٧٨١٥- قال الحسن البصري: <q>﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</q> أيّكم أزهد في الدنيا وأَتْرك لها{11}. (ز) ٧٧٨١٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾</q>، قال: أيّكم أكثر للموت ذِكرًا، وله أحسن استعدادًا، ومنه أشد خوفًا وحذرًا{12}. (١٤/٦٠٦) ٧٧٨١٧- قال مقاتل بن سليمان: <q>﴿لِيَبْلُوَكُمْ﴾</q> يعني: ليختبركم بها، <q>﴿وهُوَ العَزِيزُ﴾</q> في مُلكه، في نِقمته لمن عصاه، <q>﴿الغَفُورُ﴾</q> لذنوب المؤمنين{7}. (ز) ٧٧٨١٨- عن فُضَيل بن عِياض -من طريق إبراهيم بن الأشعث- <q>﴿لِيَبْلُوَكُمْ أيُّكُمْ أحْسَنُ عَمَلًا﴾</q>، قال: أخلَصه وأَصوَبه، قال: إنّ العمل إذا كان خالصًا ولم يكن صوابًا لم يُقبل، وإذا كان صوابًا ولم يكن خالصًا لم يُقبل، حتى يكون خالصًا صوابًا، والخالص: إذا كان لله، والصواب: إذا كان على السُّنّة{14}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١١٨ مُقتصرًا على أوله. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٨/١٧٣.تفسير الثعلبي ٩/٣٥٥، وتفسير البغوي ٨/١٧٣.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١١٨ بنحوه.أخرجه أبو الشيخ في العظمة (٤٤١).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٣٨٩.أخرجه الحارث في مسنده ٢/٨٠٤ (٨٢٠)، والثعلبي ٩/٣٥٥، من طريق داود بن المحبر، عن ميسرة، عن محمد بن زيد، عن أبي سلمة، عن أبي قتادة به. سنده شديد الضعف؛ فيه داود بن المحبر، قال عنه ابن حجر في التقريب (١٨١١): «متروك».أخرجه الحارث في مسنده ٢/٨٠٩ (٨٣١)، والدينوري في المجالسة وجواهر العلم ٢/١٢٥-١٢٦ (٢٦٢)، وابن جرير ١٢/٣٣٥، وابن أبي حاتم ٦/٢٠٠٦ (١٠٧٠٥)، والثعلبي ٩/٣٥٥، من طريق داود بن المحبر، عن عبد الواحد بن زياد، عن كليب بن وائل، عن ابن عمر به. وقال السيوطي في الإتقان ٤/٢٦٢: «سند ضعيف».تفسير مقاتل بن سليمان ٤/٣٨٩.تفسير الثعلبي ٩/٣٥٦، وتفسير البغوي ٨/١٧٦.أخرجه ابن أبي الدنيا في قصر الأمل (١٣٢)، والبيهقي في شعب الإيمان (١٠٧٨٨).تفسير مقاتل بن سليمان ٤/٣٨٩.أخرجه ابن أبي الدنيا في كتاب الإخلاص والنية -موسوعة الإمام ابن أبي الدنيا ١/١٧٧ (٢٢)-، والثعلبي ٩/٣٥٦.
67,3," <q>﴿ٱلَّذِی خَلَقَ سَبۡعَ سَمَـٰوَ ٰ⁠تࣲ طِبَاقࣰاۖ﴾</q> - تفسير ٧٧٨١٩- عن عبد الله بن عباس، في قوله: <q>﴿سَبْعَ سَماواتٍ طِباقًا﴾</q>، قال: بعضها فوق بعض{1}. (١٤/٦٠٧) ٧٧٨٢٠- عن عبد الملك ابن جُرَيْج، مثله{2}. (١٤/٦٠٧) ٧٧٨٢١- قال مقاتل بن سليمان: <q>﴿الَّذِي خَلَقَ سَبْعَ سَماواتٍ﴾</q> في يومين <q>﴿طِباقًا﴾</q> بعضها فوق بعض، بين كلّ سماءين مسيرة خمسمائة سنة، وغِلظ كلّ سماء مسيرة خمسمائة سنة{3}٦٦٩٧. (ز) ٦٦٩٧ ذكر ابنُ كثير (١٤/٧١) في قوله: <q>﴿خلق سبع سموات طباقا﴾</q> قولين: الأول: أنهن متواصلات بمعنى أنهن علويات بعضهنّ فوق بعض. الثاني: أنهن متفاصلات بينهن خلاء. ورجّح -مستندًا إلى السنة- الثاني بقوله: «أصحهما الثاني، كما دل على ذلك حديث الإسراء وغيره». <q>﴿مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ﴾</q> - قراءات ٧٧٨٢٢- عن عبد الله بن مسعود أنه قرأ: ‹مِن تَفَوُّتٍ›{4}. (١٤/٦٠٨) ٧٧٨٢٣- عن عَلقمة بن قيس أنه كان يقرأ: ‹ما تَرى فِي خَلْقِ الرَّحْمَنِ مِن تَفَوُّتٍ›{5}٦٦٩٨. (١٤/٦٠٨) ٦٦٩٨ ذكر ابنُ جرير (٢٣/١٢٠) القراءتين، ثم علّق قائلًا: «والصواب من القول في ذلك أنهما قراءتان معروفتان بمعنى واحد، كما قيل: ولا تصاعر؛ ولا تصعر، وتعهدتُ فلانًا؛ وتعاهدتُه، وتظهرت؛ وتظاهرت، وكذلك التفاوت والتفوت». وعلّق عليهما ابنُ عطية (٨/٣٥٢) بقوله: «وهما بمعنى واحد». <q>﴿مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ﴾</q> - تفسير الآية ٧٧٨٢٤- عن عبد الله بن عباس، في قوله: <q>﴿ما تَرى فِي خَلْقِ الرَّحْمَنِ مِن تَفاوُتٍ﴾</q> قال: ما يَفُوت بعضه بعضًا. تَفاوتٌ: تَفرّقٌ{6}. (١٤/٦٠٧) ٧٧٨٢٥- عن عبد الله بن عباس، في قوله: <q>﴿مِن تَفاوُتٍ﴾</q>، قال: تَشقُّقٌ{7}. (١٤/٦٠٨) ٧٧٨٢٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿مِن تَفاوُتٍ﴾</q>، قال: من اختلاف{8}٦٦٩٩. (١٤/٦٠٨) ٦٦٩٩ لم يذكر ابنُ جرير (٢٣/١١٩) غير قول قتادة. ٧٧٨٢٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله تعالى: <q>﴿ما ترى في خلق الرحمن من تفاوت﴾</q>، قال: يقال: لا يَفُوت بعضه بعضًا{9}. (ز) ٧٧٨٢٨- قال مقاتل بن سليمان: <q>﴿ما تَرى فِي خَلْقِ الرَّحْمنِ مِن تَفاوُتٍ﴾</q>، يقول: ما ترى ابن آدم في خَلْق السموات من عيب{3}٦٧٠٠. (ز) ٦٧٠٠ أفاد قول مقاتل أنّ قوله تعالى: <q>﴿في خلق الرحمن﴾</q> مراد به السموات، وقد ذكر ذلك ابنُ عطية (٨/٣٥٢) وزاد قولًا آخر، فقال: «وقال آخرون: <q>﴿في خلق الرحمن﴾</q> مَعنيّ به: جميع ما في خَلْق الله تعالى من الأشياء، فإنها لا تَفاوت فيها ولا فُطور، جارية على غير إتقان، ومتى كانت فُطور لا تُفسد الشيء المخلوق من حيث هو ذلك الشيء، بل هي إتقان فيه، فليست تلك المرادة في الآية، وقال مُنذر بن سعيد: أمَر الله تعالى بالنظر إلى السماء وخَلْقها، ثم أمر بالتكرير في النظر، وكذلك جميع المخلوقات متى نظرها ناظر ليرى فيها خللًا أو نقصًا، فإنّ بصره يَنقلب خاسئًا حسيرًا». <q>﴿فَٱرۡجِعِ ٱلۡبَصَرَ هَلۡ تَرَىٰ مِن فُطُورࣲ ۝٣﴾</q> - تفسير ٧٧٨٢٩- عن عبد الله بن عباس، في قوله: <q>﴿هَلْ تَرى مِن فُطُورٍ﴾</q>، قال: شُقوق{7}. (١٤/٦٠٨) ٧٧٨٣٠- عن عبد الله بن عباس، في قوله: <q>﴿مِن فُطُورٍ﴾</q>، قال: تَشقُّقٌ أو خَلَل{2}. (١٤/٦٠٩) ٧٧٨٣١- عن عبد الله بن عباس -من طريق العَوفيّ- قال: <q>﴿هَلْ تَرى مِن فُطُورٍ﴾</q>، الفطور: الوُهِيّ{13}. (١٤/٦٠٩) ٧٧٨٣٢- قال الضَّحّاك بن مُزاحِم: <q>﴿هَلْ تَرى مِن فُطُورٍ﴾</q> اختلاف وشُطور{14}. (ز) ٧٧٨٣٣- قال عطية بن سعد العَوفيّ: <q>﴿هَلْ تَرى مِن فُطُورٍ﴾</q> عَيب{14}. (ز) ٧٧٨٣٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿مِن فُطُورٍ﴾</q>، قال: مِن خَلَل{16}. (١٤/٦٠٨) ٧٧٨٣٥- قال محمد بن كعب القُرَظيّ: <q>﴿هَلْ تَرى مِن فُطُورٍ﴾</q> فُروج{14}. (ز) ٧٧٨٣٦- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿مِن فُطُورٍ﴾</q>، قال: مِن خَلَل{2}. (١٤/٦٠٩) ٧٧٨٣٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- قوله ﷿: <q>﴿هل ترى من فطور﴾</q>، قال: يقال: هل تَرى من تَشقُّق أو خَلل{9}. (ز) ٧٧٨٣٨- قال مقاتل بن سليمان: <q>﴿فارْجِعِ البَصَرَ﴾</q> يعني: أعِدِ البصرَ ثانية إلى السماوات، <q>﴿هَلْ تَرى﴾</q> ابن آدم في السموات <q>﴿مِن فُطُورٍ﴾</q> يعني: مِن فُروج{3}. (ز) ٧٧٨٣٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿هَلْ تَرى مِن فُطُورٍ﴾</q>، قال: مِن شُقوق{21}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٣٨٩.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وقرأ بقية العشرة: <q>﴿مِن تَفاوُتٍ﴾</q> بألف والتخفيف. انظر: النشر ٢/٣٨٩، والإتحاف ص٥٥٠.عزاه السيوطي إلى سعيد بن منصور.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، وابن مردويه.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١١٩ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٣٨٩.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢٠. والوُهِيّ: جمع وهْي، وهو الشق. اللسان (وهي).تفسير الثعلبي ٩/٣٥٧.تفسير الثعلبي ٩/٣٥٧.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١٢١، كذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٣٥٧.عزاه السيوطي إلى ابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٣٨٩.أخرجه ابن جرير ٢٣/١٢١.
67,4," <q>﴿ثُمَّ ٱرۡجِعِ ٱلۡبَصَرَ كَرَّتَیۡنِ﴾</q> - تفسير ٧٧٨٤٠- عن عبد الله بن عباس -من طريق العَوفيّ- <q>﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾</q>، يقول: هل تَرى في السماء مِن خَلَل{1}. (ز) ٧٧٨٤١- قال عبد الله بن عباس: <q>﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾</q> مَرّة بعد مَرّة{2}. (ز) ٧٧٨٤٢- قال مقاتل بن سليمان: <q>﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾</q>، يقول: أعِدِ البصرَ الثانية{3}. (ز) <q>﴿یَنقَلِبۡ إِلَیۡكَ ٱلۡبَصَرُ خَاسِئࣰا﴾</q> - تفسير ٧٧٨٤٣- عن عبد الله بن عباس، في قوله: <q>﴿يَنْقَلِبْ إلَيْكَ﴾</q>، قال: يَرجع إليك{4}. (١٤/٦٠٩) ٧٧٨٤٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿خاسِئًا﴾</q>، قال: ذليلًا{5}. (١٤/٦٠٨) ٧٧٨٤٥- عن عبد الله بن عباس، في قوله: <q>﴿خاسِئًا﴾</q>، قال: صاغرًا{4}. (١٤/٦٠٩) ٧٧٨٤٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿خاسِئًا﴾</q>، قال: صاغرًا{7}. (١٤/٦٠٨) ٧٧٨٤٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يَنْقَلِبْ إلَيْكَ البَصَرُ خاسِئًا﴾</q> أي: حاسرًا{8}. (ز) ٧٧٨٤٨- قال مقاتل بن سليمان: <q>﴿يَنْقَلِبْ﴾</q> يعني: يَرجع <q>﴿إلَيْكَ﴾</q> ابن آدم <q>﴿البَصَرُ خاسِئًا﴾</q> يعني: إذا اشتدّ البصرُ يقع فيه الماء خاسئًا، يعني: صاغرًا{3}. (ز) ٧٧٨٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿يَنْقَلِبْ إلَيْكَ البَصَرُ خاسِئًا﴾</q> الخاسئ، والخاسر واحد؛ حسُر طرْفه أن يرى فيها فَطْرًا، فرجع وهو حسير قبل أن يَرى فيها فَطْرًا. قال: فإذا جاء يوم القيامة انفطَرتْ، ثم انشقّتْ، ثم جاء أمر أكبر من ذلك؛ انكَشطتْ{8}. (ز) <q>﴿وَهُوَ حَسِیرࣱ ۝٤﴾</q> - تفسير ٧٧٨٥٠- عن عبد الله بن عباس، في قوله: <q>﴿وهُوَ حَسِيرٌ﴾</q>، قال: كَلِيل{11}. (١٤/٦٠٨) ٧٧٨٥١- عن عبد الله بن عباس، في قوله: <q>﴿وهُوَ حَسِيرٌ﴾</q>، قال: مُعْيٍ، ولا يَرى شيئًا{4}. (١٤/٦٠٩) ٧٧٨٥٢- عن عبد الله بن عباس -من طريق العَوفيّ-: <q>﴿وهُوَ حَسِيرٌ﴾</q> بسواد الليل{1}. (ز) ٧٧٨٥٣- عن عبد الله بن عباس، <q>﴿وهُوَ حَسِيرٌ﴾</q>، قال: متوجع{14}. (١٤/٦٠٩) ٧٧٨٥٤- عن عبد الله بن عباس -من طريق علي- <q>﴿وهُوَ حَسِيرٌ﴾</q>، قال: مُرجفٌ{1}. (ز) ٧٧٨٥٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿وهُوَ حَسِيرٌ﴾</q> قال: مُعْيٍ لا يَرى في خلْق الرحمن تَفاوتًا ولا خَللًا{16}. (١٤/٦٠٨) ٧٧٨٥٦- عن محمد بن السّائِب الكلبي -من طريق معمر- <q>﴿وهُوَ حَسِيرٌ﴾</q>، يقول: هو المُعْيى{17}. (ز) ٧٧٨٥٧- قال مقاتل بن سليمان: <q>﴿وهُوَ حَسِيرٌ﴾</q> يعني: كالًّا مُنقطعًا، لا يَرى فيها عَيبًا ولا فُطورًا{18}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/١٢١.تفسير البغوي ٨/١٧٦.تفسير مقاتل بن سليمان ٤/٣٨٩-٣٩٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢١ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٢٢.تفسير مقاتل بن سليمان ٤/٣٨٩-٣٩٠.أخرجه ابن جرير ٢٣/١٢٢.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢١.عزاه السيوطي إلى ابن جرير، وابن المنذر. وفي ابن جرير ٢٣/١٢١ بلفظ: مرجف، من طريق علي كما في الأثر التالي.أخرجه ابن جرير ٢٣/١٢١.أخرجه عبد الرزاق ٢/٣٠٤، وابن جرير ٢٣/١٢٢، كذا من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٠٥.تفسير مقاتل بن سليمان ٤/٣٩٠.
67,5," <q>﴿وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ ۝٥﴾</q> - تفسير ٧٧٨٥٨- قال مقاتل بن سليمان: <q>﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا﴾</q> لأنها أدنى السموات، وأقربها من الأرض مِن غيرها <q>﴿بِمَصابِيحَ﴾</q> وحفظًا، يعني: الكواكب، <q>﴿وجَعَلْناها﴾</q> يعني: الكواكب <q>﴿رُجُومًا﴾</q> يعني: رميًا <q>﴿لِلشَّياطِينِ﴾</q> يعني: إذا ارتَقوا إلى السماء، <q>﴿وأَعْتَدْنا لَهُمْ﴾</q> يعني: للشياطين <q>﴿عَذابَ السَّعِيرِ﴾</q> يعني: الوقود{1}٦٧٠١. (ز) ٦٧٠١ قال ابنُ عطية (٨/٣٥٣): «أخبر تعالى أنه زيّن السماء الدنيا إلينا -أي: التي تلينا- بمصابيح، وهي النّجوم، فإن كانت جميع النّجوم في السماء الدنيا فهذا اللفظ عام للكواكب، وإن كان في سائر السماوات كواكب؛ فإما أن يريد كواكب سماء الدنيا فقط، وإما أن يريد الجميع على أنّ ما في غيرها لما كانت هي تشفّ عنه، ويظهر منها، فقد تزيّنتْ به بوجه ما، ومَن تكلّف القول لمواضع الكواكب وفي أي سماء هي فقوله ليس من الشريعة». <q>﴿وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ ۝٥﴾</q> - آيات متعلقة بالآية ٧٧٨٥٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا بِمَصابِيحَ وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾</q>: إنّ الله -جلّ ثناؤه- إنما خلَق هذه النّجوم لثلاث خِصال: خَلَقها زِينة للسماء الدنيا، ورُجومًا للشياطين، وعلامات يُهتدى بها؛ فمَن يَتأوّل منها غير ذلك فقد قال برأيه، وأخطأ حظّه، وأضاع نصيبه، وتَكلّف ما لا عِلم له به{2}٦٧٠٢. (ز) ٦٧٠٢ قال ابنُ عطية (٨/٣٥٣-٣٥٤): «<q>﴿وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾</q> معناه: وجعلنا منها، وهذا كما تقول: أكرمتُ بني فلان وصنعتُ بهم، وأنتَ إنما فعلتَ ذلك ببعضهم دون بعض، ويوجب هذا التأويل في الآية أنّ الكواكب الثابتة والبروج، وكلّ ما يُهتدى به في البر والبحر فليست برواجم، وهذا نصٌ في حديث السير». ثم ذكر قول قتادة. ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.أخرجه ابن جرير ٢٣/١٢٣، وأخرجه عبد بن حميد في تفسيره -كما في تغليق التعليق ٣/٤٨٩- من طريق شيبان بنحوه.
67,6," <q>﴿وَلِلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ عَذَابُ جَهَنَّمَۖ وَبِئۡسَ ٱلۡمَصِیرُ ۝٦﴾</q> - تفسير ٧٧٨٦٠- قال مقاتل بن سليمان: <q>﴿ولِلَّذِينَ كَفَرُوا بِرَبِّهِمْ﴾</q> الذين كفروا بتوحيد الله، لهم في الآخرة <q>﴿عَذابُ جَهَنَّمَ وبِئْسَ المَصِيرُ﴾</q> حيث يصيرون إليها{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.
67,7," <q>﴿إِذَاۤ أُلۡقُوا۟ فِیهَا سَمِعُوا۟ لَهَا شَهِیقࣰا﴾</q> - تفسير ٧٧٨٦١- قال مقاتل بن سليمان: <q>﴿إذا أُلْقُوا فِيها﴾</q> يعني: في جهنم، اختطفتهم الخَزنة بالكلاليب <q>﴿سَمِعُوا لَها شَهِيقًا﴾</q> يعني: مثل نهيق الحمار{1}. (ز) ٧٧٨٦٢- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿سَمِعُوا لَها شَهِيقًا﴾</q>، قال: صِياحًا{2}. (١٤/٦٠٩) <q>﴿وَهِیَ تَفُورُ ۝٧﴾</q> - تفسير ٧٧٨٦٣- عن مجاهد بن جبر -من طريق سفيان- في قوله: <q>﴿وهِيَ تَفُورُ﴾</q>، قال: تفور بهم، كما يفور الحَبُّ القليل في الماء الكثير{3}. (١٤/٦١٠) ٧٧٨٦٤- قال مقاتل بن سليمان: <q>﴿وهِيَ تَفُورُ﴾</q>، يعني: تغلي{1}. (ز) <q>﴿وَهِیَ تَفُورُ ۝٧﴾</q> - آثار متعلقة بالآية ٧٧٨٦٥- عن أبي يحيى، قال: إنّ الرجل لَيُجرّ إلى النار، فتنزوي ويَنقبض بعضها إلى بعض، فيقول لها الرحمن: ما لكِ؟ قالت: إنّه كان يستحي مني. فيقول: أرسِلوا عبدي. قال: وإنّ العبد ليُجرّ إلى النار، فيقول: يا ربّ، ما كان هذا الظنّ بك. قال: فما كان ظنّك؟ قال: كان ظني أن تَسعني رحمتكَ. فيقول: أرسِلوا عبدي. قال: وإنّ الرجل ليُجرّ إلى النار، فتَشهق إليه النار شَهيق البَغلة إلى الشّعير، ثم تَزفر زَفرة لا يبقى أحدٌ إلا خاف{5}. (١٤/٦٠٩٠) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.عزاه السيوطي إلى ابن المنذر.أخرجه هناد (٣١٣)، وابن جرير ٢٣/١٢٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٣٩٠.عزاه السيوطي إلى عبد بن حميد.
67,8," <q>﴿تَكَادُ تَمَیَّزُ مِنَ ٱلۡغَیۡظِۖ﴾</q> - تفسير ٧٧٨٦٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿تَكادُ تَمَيَّزُ﴾</q>، قال: تَتفرّق{1}. (١٤/٦١٠) ٧٧٨٦٧- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: <q>﴿تَكادُ تَمَيَّزُ﴾</q>، قال: يُفارِق بعضُها بعضًا، وتَنفطر{2}. (١٤/٦١٠) ٧٧٨٦٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿تَكادُ تَمَيَّزُ﴾</q>، يقول: تَفرّق{3}. (ز) ٧٧٨٦٩- قال مقاتل بن سليمان: <q>﴿تَكادُ تَمَيَّزُ﴾</q> تَفرّق جهنم عليهم <q>﴿مِنَ الغَيْظِ﴾</q> على الكفار تأخذهم{4}. (ز) ٧٧٨٧٠- عن فُضَيل بن عِياض -من طريق فضيل- في قوله: <q>﴿تَكادُ تَمَيَّزُ مِنَ الغَيْظِ﴾</q>، قال: تَقَطَّع{5}. (ز) ٧٧٨٧١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿تَكادُ تَمَيَّزُ مِنَ الغَيْظِ﴾</q>، قال: التَّميّز: التَّفرّق مِن الغيظ على أهل معاصي الله؛ غضبًا لله، وانتقامًا له{3}. (ز) <q>﴿كُلَّمَاۤ أُلۡقِیَ فِیهَا فَوۡجࣱ سَأَلَهُمۡ خَزَنَتُهَاۤ أَلَمۡ یَأۡتِكُمۡ نَذِیرࣱ ۝٨﴾</q> - تفسير ٧٧٨٧٢- قال مقاتل بن سليمان: <q>﴿كُلَّما أُلْقِيَ فِيها فَوْجٌ﴾</q> يعني: زُمرة؛ اختَطفتهم الخَزنة بالكلاليب، يعني: مشركي العرب واليهود والنصارى والمجوس وغيرهم <q>﴿سَأَلَهُمْ خَزَنَتُها﴾</q> خُزّان جهنم: <q>﴿ألَمْ يَأْتِكُمْ نَذِيرٌ﴾</q> يعني: رسول، وهو محمد ﷺ{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/١٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢٤.أخرجه ابن جرير ٢٣/١٢٥.تفسير مقاتل بن سليمان ٤/٣٩٠.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٢)-.أخرجه ابن جرير ٢٣/١٢٥.تفسير مقاتل بن سليمان ٤/٣٩٠.
67,9," <q>﴿قَالُوا۟ بَلَىٰ قَدۡ جَاۤءَنَا نَذِیرࣱ فَكَذَّبۡنَا وَقُلۡنَا مَا نَزَّلَ ٱللَّهُ مِن شَیۡءٍ إِنۡ أَنتُمۡ إِلَّا فِی ضَلَـٰلࣲ كَبِیرࣲ ۝٩﴾</q> - تفسير ٧٧٨٧٣- قال مقاتل بن سليمان: <q>﴿قالُوا بَلى قَدْ جاءَنا نَذِيرٌ فَكَذَّبْنا﴾</q> بالنذير، يعني: النبي ﷺ، <q>﴿وقُلْنا﴾</q> للنبي ﷺ: <q>﴿ما نَزَّلَ اللَّهُ مِن شَيْءٍ﴾</q> يعني: ما أرسل الله من أحد، يعني: من نبي، وقالوا للرسول محمد ﷺ: ما بَعث الله من رسول. <q>﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ كَبِيرٍ﴾</q> يعني: شِقاق{1}٦٧٠٣. (ز) ٦٧٠٣ ذكر ابنُ عطية (٨/٣٥٥) في قائل: <q>﴿إن أنتم إلا في ضلال كبير﴾</q> احتمالين، فقال: «وقوله تعالى: <q>﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ كَبِيرٍ﴾</q> يحتمل أن يكون من قول الملائكة للكفار حين أخبروا عن أنفسهم أنهم كَذّبوا النُّذر، ويحتمل أن يكون من كلام الكفار للنّذر». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٠.
67,10," <q>﴿وَقَالُوا۟ لَوۡ كُنَّا نَسۡمَعُ أَوۡ نَعۡقِلُ مَا كُنَّا فِیۤ أَصۡحَـٰبِ ٱلسَّعِیرِ ۝١٠﴾</q> - تفسير ٧٧٨٧٤- عن أبي سعيد الخُدري، أنّ رسول الله ﷺ، قال: «إنّ لكل شيء دعامة، ودعامة المؤمن عقله، فبقدْر ما يَعقل يَعبُد ربه، ولَعَمري لقد ندم الكفار يوم القيامة، <q>﴿وقالوا لو كنا نسمع أو نعقل ما كنا في أصحاب السعير﴾</q>»{1}. (ز) ٧٧٨٧٥- قال عبد الله بن عباس: <q>﴿لَوْ كُنّا نَسْمَعُ﴾</q> الهُدى أو نعقله؛ فنعمل به{2}. (ز) ٧٧٨٧٦- قال مقاتل بن سليمان: <q>﴿وقالُوا لَوْ كُنّا نَسْمَعُ أوْ نَعْقِلُ﴾</q> المواعظ{3}. (ز) ",footnotes:1:أخرجه الواحدي في الوسيط ٤/٣٢٨.تفسير الثعلبي ٩/٣٥٨، وتفسير البغوي ٨/١٧٧.تفسير مقاتل بن سليمان ٤/٣٩١.
67,11," <q>﴿فَٱعۡتَرَفُوا۟ بِذَنۢبِهِمۡ فَسُحۡقࣰا لِّأَصۡحَـٰبِ ٱلسَّعِیرِ ۝١١﴾</q> - تفسير ٧٧٨٧٧- عن عبد الله بن عباس-من طريق علي- <q>﴿فَسُحْقًا﴾</q>، قال: بُعدًا{1}. (١٤/٦١١) ٧٧٨٧٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿فَسُحْقًا﴾</q>، قال: بُعدًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حسان: ألا مِن مُبلِّغ عنِّي أُبيًّا فقد أُلقيتَ في سُحق السعير؟{2}. (١٤/٦١١) ٧٧٨٧٨/ب عن سعيد بن جُبَير -من طريق سَلمة بن كُهيل- في قوله: <q>﴿فَسُحْقًا﴾</q>، قال: سُحْقٌ: وادٍ في جهنم{3}٦٧٠٤. (١٤/٦١١) ٦٧٠٤ لم يذكر ابنُ جرير (٢٣/١٢٦) غير قول سعيد بن جُبَير. ٧٧٨٧٩- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿فاعْتَرَفُوا بِذَنْبِهِمْ﴾</q> يعني: بتكذيبهم الرُّسُل <q>﴿فَسُحْقًا لِأَصْحابِ السَّعِيرِ﴾</q> يعني: الوقود{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/١٢٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى الطستي في مسائله.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٨/٥١٧ (٣٥٣٢٥)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٠٨ (٣٩)- وزاد: يقال له سُحْق، وابن جرير ٢٣/١٢٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٣٩١.
67,12," <q>﴿إِنَّ ٱلَّذِینَ یَخۡشَوۡنَ رَبَّهُم بِٱلۡغَیۡبِ لَهُم مَّغۡفِرَةࣱ وَأَجۡرࣱ كَبِیرࣱ ۝١٢﴾</q> - تفسير ٧٧٨٨٠- عن عبد الله بن عباس، <q>﴿إنَّ الَّذِينَ يَخْشَوْنَ رَبَّهُمْ بِالغَيْبِ﴾</q>، قال: أبو بكر، وعمر، وعلي، وأبو عبيدة بن الجرّاح{1}. (١٤/٦١١) ٧٧٨٨١- قال مقاتل بن سليمان: <q>﴿إنَّ الَّذِينَ يَخْشَوْنَ رَبَّهُمْ بِالغَيْبِ﴾</q> ولم يَروه، فآمنوا <q>﴿لَهُمْ مَغْفِرَةٌ﴾</q> لذنوبهم، <q>﴿وأَجْرٌ كَبِيرٌ﴾</q> يعني: جزاء كبيرًا في الجنة{2}٦٧٠٥. (ز) ٦٧٠٥ ذكر ابنُ عطية (٨/٣٥٦) في قوله: <q>﴿بالغيب﴾</q> احتمالين، ووجّههما، فقال: «<q>﴿بِالغَيْبِ﴾</q> يحتمل معنيين: أحدهما: بالغَيْبِ الذي أُخبروا به من الحَشْر والصراط والميزان والجنة والنار، فآمَنوا بذلك، وخَشوا ربهم فيه، ونحا إلى هذا قتادة. والمعنى الثاني: أنهم يَخشَون ربهم إذا غابوا عن أعين الناس، أي: في خلواتهم، ومنه تقول العرب: فلان سالم الغيب، أي: لا يضر، فالمعنى: يعملون بحسب الخشية في صلاتهم وعباداتهم، وانفرادهم، فالاحتمال الأول: مدحٌ بالإخلاص والإيمان، والثاني: مدحٌ بالأعمال الصالحة في الخلوات، وذلك أحرى أن يعملوها علانية». ٧٧٨٨٢- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وأَجْرٌ كَبِيرٌ﴾</q>، قال: الجنة{3}. (١٤/٦١١) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٣٩١.عزاه السيوطي إلى ابن المنذر.
