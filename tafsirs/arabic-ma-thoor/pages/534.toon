quran[27]{c,v,t}:
  55,68,""
  55,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِنَّ خَیۡرَ ٰ⁠تٌ حِسَانࣱ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٠١<span class="dash">-</span></span> عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿حُورٌ عِينٌ﴾</span> [الواقعة:٢٢]. قال: «<b>حُور: بِيض، عِين: ضخام العيون، شَفر الحوراء بمنزلة جَناح النّسور</b>». وفي لفظ ابن مردويه: «<b>شَفر الجُفون بمنزلة جَناح النّسر</b>». قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿كَأَنَّهُمْ لُؤْلُؤٌ مَكْنُونٌ﴾</span> [الطور:٢٤]. قال: «<b>صفاؤهنّ صفاء الدُّر في الأصداف التي لم تمسّه الأيدي</b>». قلت: يا رسول الله، أخبرِني عن قوله: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>. قال: «<b>خَيْرات الأخلاق، حِسان الوجوه</b>». قلت: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span> [الصافات:٤٩]. قال: «<b>رِقّتهن كرقَّة الجِلدة التي في داخل البيضة مما يلي القشر</b>». قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿عُرُبًا أتْرابًا﴾</span> [الواقعة:٣٧]. قال: «<b>هُنّ اللواتي قُبِضن في دار الدنيا عجائز رُمْصًا{1} شُمْطًا{2}، خلقهنّ الله بعد الكِبر، فجعلهنّ عذارى، عُربًا متعشِّقات مُحبّبات، أترابًا على ميلاد واحد</b>». قلتُ: يا رسول الله، أنساء الدنيا أفضل أم الحُور العين؟ قال: «<b>بل نساء الدنيا أفضل من الحُور العين؛ كفضل الظِّهارَةِ على البِطانة</b>». قلت: يا رسول الله، وبِمَ ذاك؟ قال: «<b>بصلاتهنّ وصيامهنّ وعبادتهنّ الله، ألبس الله وجوههنّ النور، وأجسادهنّ الحرير، بِيض الألوان، خُضر الثياب، صُفر الحلي، مَجامرُهنّ الدُّرّ، وأمشاطهنّ الذهب. يقلن: ألا نحن الخالدات فلا نموت أبدًا، ألا ونحن الناعمات فلا نبأس أبدًا، ألا ونحن المُقيمات فلا نَظْعن أبدًا، ألا ونحن الراضيات فلا نَسخط أبدًا، طُوبى لمن كُنّا له وكان لنا</b>». قلت: يا رسول الله، المرأة منا تتزوج الزوجين والثلاثة والأربعة، ثم تموت، فتدخل الجنة، ويدخلون معها، مَن يكون زوجها؟ قال: «<b>يا أُمّ سلمة، إنها تُخيّر، فتختار أحسنهم خُلقًا، فتقول: أي ربّ، إنّ هذا كان أحسنهم معي خُلقًا في دار الدنيا، فزوّجنيه. يا أُمّ سلمة، ذهب حُسن الخُلق بخير الدنيا والآخرة</b>»{3}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>: في كلّ خيمة زوجة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٣<span class="dash">-</span></span> قال <span class="name-1">جرير بن عبد الله</span>: مختارات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>، قال: النساء{6}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> خيِّرات فاضلات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- قال: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> عذارى الجنة{8}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> خَيرات الأخلاق، حِسان الوجوه{9}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل بن أبي خالد</span>: عذارى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ﴾</span> يعني: في الجنان الأربع <span class="qpc-hafs">﴿حِسانٌ﴾</span> يعني: خَيْرات الأخلاق، حِسان الوجوه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٠<span class="dash">-</span></span> عن <span class="name-3">الأوزاعي</span> -من طريق أبي عصام العسقلاني- <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span>، قال: لَسْنَ بذَرِبات اللسان{12}، ولا يغَرْنَ، ولا يؤذين{13}. (١٤/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> الخَيرات الحسان: الحُور العين{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِیهِنَّ خَیۡرَ ٰ⁠تٌ حِسَانࣱ ۝٧٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٦١٢<span class="dash">-</span></span> عن أنس بن مالك، عن النبيِّ ﷺ، قال: «<b>إنّ الحُور العين يتَغنّين في الجنة، يقلن: نحن الخَيرات الحسان، خُبِّئنا لأزواج كرام</b>»{15}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- قال: لكل مسلم خَيْرة{16}، ولكل خَيْرة خيمة، ولكل خيمة أربعة أبواب، يدخل عليها كلّ يوم مِن الله تحفة وكرامة وهديّة لم تكُن قبل ذلك، لا مَرِحات، ولا طمّاحات{17}، ولا بَخِرات{18}، ولا ذفِرات{19}، حُور عِين، كأنهنّ بَيضٌ مكنون{20}. (١٤/١٥٨)</p></p><p></div></p></div>",footnotes:1:الرَّمَصُ: هو البياض الذي تَقْطَعه العين ويجتمع في زوايا الأجفان. النهاية (رمص).|2:الشَّمَطُ: بياضُ شعر الرأس يخالط سواده، ولا يقال للمرأة: شيباء، ولكن شمطاء. لسان العرب (شمط).|3:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، واللفظ له، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥، من طريق عمرو بن هاشم البيروتي، عن سليمان بن أبي كريمة، عن هشام بن حسان، عن الحسن، عن أمه، عن أم سلمة به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال الطبراني في الأوسط: «لم يروِ هذا الحديثَ عن هشام بن حسان إلا سليمان بن أبي كريمة، تفرّد به عمرو بن هاشم». وقال ابن الجوزي في العلل المتناهية ٢/١٦١ (١٠٧٧): «هذا حديث لا يصِحّ». وقال الضياء المقدسي في صفة الجنة ص١٢٤ (١١٩): «لا أعلمه رُوي إلا من طريق سليمان بن أبي كريمة، وفيه كلام». وقال ابن القيم في حادي الأرواح ص٢٢٩: «تفرد به سليمان بن أبي كريمة، ضعّفه أبو حاتم، وقال ابن عدي: عامة أحاديثه مناكير، ولم أر للمتقدمين فيه كلامًا. ثم ساق هذا الحديث من طريقه، وقال: لا يُعرف إلا بهذا السند». وقال ابن مفلح في الآداب الشرعية ٢/٢٠٧: «في إسناده سليمان بن أبي كريمة، وهو ضعيف». وقال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «فيه سليمان بن أبي كريمة، ضعّفه أبو حاتم، وابن عدي».|4:أخرجه ابن جرير ٢٢/٢٦٢.|5:تفسير الثعلبي ٩/١٩٥.|6:عزاه السيوطي إلى ابن المنذر.|7:تفسير الثعلبي ٩/١٩٤.|8:أخرجه ابن أبي شيبة ١٣/٣٣٣. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٦٢، كذلك من طريق سعيد، وأبي العوام بنحوه. وعزاه السيوطي إلى عبد بن حميد.|10:تفسير الثعلبي ٩/١٩٥.|11:تفسير مقاتل بن سليمان ٤/٢٠٥.|12:ذَرِبَة: صخّابة، حديدة، سَلِيطة اللسان، فاحِشَة، طويلة اللسان. وذَرَبُ اللسان: حِدَّتُه. لسان العرب (ذرب).|13:أخرجه ابن المبارك في الزهد (١٥٣٩).|14:أخرجه ابن جرير ٢٢/٢٦٢.|15:أخرجه ابن أبي الدنيا في صفة الجنة ص١٨٦ (٢٤٩)، من طريق إسماعيل بن عمر، عن ابن أبي ذئب، عن ابن عبد الله بن رافع، عن بعض ولد أنس بن مالك، عن أنس بن مالك به.</p><p>وأخرجه ابن أبي شيبة ٧/٣٢ (٣٣٩٨٨)، من طريق شبابة بن سوار، عن ابن أبي ذئب، عمن سمع أنسًا به.</p><p>وسنده ضعيف؛ لجهالة الراوي عن أنس بن مالك.|16:الخَيْرَة: الفاضلة من كل شيء، جمعها الخَيْرات. التاج (خير).|17:امرأة طمّاحة: تَكُرُّ بنظرها يمينًا وشمالًا إلى غير زوجها. لسان العرب (طمح).|18:البَخَر: تَغَيُّر رِيح الفم. النهاية (بخر).|19:الدَّفْر -بالمهملة-: النَّتَن خاصة. وأما بالمعجمة والتحريك: فإنه يعم شدة ذكاء الرائحة؛ طيبة كانت أو خبيثة. التاج (دفر)، (ذفر).|20:أخرجه ابن أبي شيبة ١٣/٣٣٣، وابن أبي الدنيا في صفة الجنة (٣٢٠). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه. وعزاه السيوطي إلى ابن مردويه مرفوعًا أيضًا.
  55,70,""
  55,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حُورࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦١٤<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>لما أُسري بي دخلتُ الجنة، موضعًا يسمى: البَيْدَخ{1}، عليه خيام اللؤلؤ والزّبَرْجَد الأخضر والياقوت الأحمر، فنُوديتُ: السلام عليك، يا رسول الله. فقلتُ: يا جبريل، ما هذا النداء؟ قال: هؤلاء المقصورات في الخِيام، استأذَنّ ربّهنّ في السلام عليك، فأَذِن لهنّ، فطَفِقنَ يقُلنَ: نحن الراضيات فلا نسخط أبدًا، ونحن المُقيمات -وفي لفظ: الخالدات- فلا نَظْعن أبدًا</b>». وقرأ رسول الله ﷺ هذه الآية: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>{2}. (١٤/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿حُورٌ﴾</span>: بِيض{3}. (١٤/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: الحُور: سُود الحَدَق{4}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿حُورٌ﴾</span> النساء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: الحُور: البِيض، قلوبهم وأنفسهم وأبصارهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦١٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿حُورٌ﴾</span>: الحَوراء: العَيناء الحسناء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل- قال: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span> عذارى الجنة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span>، قال: الحُور: السُّود الحَدَق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، يعني بالحُور: البيضاء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران-: الحَوَر: سواد في بياض{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّقۡصُورَ ٰ⁠تࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span>: محبوسات{12}. (١٤/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق الربيع- <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span>: محبوسات في الخيام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> لا يَخرجن من بيوتهنّ{14}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> مقصورات قلوبهنّ وأبصارهنّ وأنفسهنّ على أزواجهنّ في خيام اللؤلؤ، لا يُرِدْن غيرهم{15}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span>: محبوسات، قصرن طرفهن وأنفسهن على أزواجهن{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٢٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ فِي الخِيامِ﴾</span> محبوسات في خيام اللؤلؤ{17}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> محبوسات، ليس بطوّافات في الطُّرق{18}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿مقصورات﴾</span>، قال: محبوسات{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٢<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span> -من طريق ابن يمان، عن أبي جعفر- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> محبوسات في الخِيام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٣<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span> -من طريق عبيد الله وابن اليمان، عن أبي جعفر- قال: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> قُصِر طَرفهنّ على أزواجهنّ{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span> و[يعني] بالمقصورات: المحبوسات على أزواجهنّ{10}<span class=comment-ref>٦٤٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٧</span> اختُلف في قوله: <span class="qpc-hafs">﴿مقصورات﴾</span> على قولين: <b>الأول</b>: قُصرن على أزواجهنّ فلا يُرِدن غيرهم. <b>الثاني</b>: محبوسات في الخيام.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢٢/٢٦٧) القولين، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">العموم</span>، فقال: «والصواب من القول في ذلك عندنا أن يُقال: إنّ الله -تبارك وتعالى- وصفهنّ بأنهنّ مقصورات في الخيام، والقصر: هو الحبس، ولم يخصّص وصفهنّ بأنهنّ محبوسات على معنًى من المعنيين اللذين ذكرنا دون الآخر، بل عمّ وصفهن بذلك، والصواب أن يعمّ الخبر عنهنّ بأنهنّ مقصورات في الخيام على أزواجهنّ فلا يُردن غيرهم، كما عمّ ذلك».</div></p><p><h3><span class="qpc-hafs">﴿فِی ٱلۡخِیَامِ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٣٥<span class="dash">-</span></span> عن الضَّحّاك بن مُزاحِم، قال: كان ابن مسعود يُحَدِّث عن نبيِّ الله ﷺ أنه قال: «<b>هي الدُّرّ المُجَوّف</b>». يعني: الخيام في قوله: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>{23}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٦<span class="dash">-</span></span> عن أبي مِجلز، أن رسول الله ﷺ قال في قول الله: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>: «<b>دُرّ مُجَوّف</b>»{24}. (١٤/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٧<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق أبي الأَحوص- قال: أتدرون ما <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>؟ قال: الخيام دُرّ مُجَوّف{25}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأَحوص- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> الدُّرّ المُجَوّف{26}. (١٤/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٣٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: لكلّ زوجة خيمةٌ مِن ياقوت أو لؤلؤة، طولها ستون ميلًا{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد- <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span>، قال: خيام اللؤلؤ، والخيمة من لؤلؤة واحدة مُجَوّفة، أربعة فراسخ في أربعة فراسخ، لها أربعة آلاف مِصراع من ذهب{28}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤١<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span>: ذُكر لنا: أنّ <span class="name-1">ابن عباس</span> كان يقول: الخَيمة دُرّة مُجَوّفة، فرسخٌ في فرسخٍ، لها أربعة آلاف باب من ذهب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span>، قال: الخيمة ميل في ميل، والميل ثلث الفرسخ{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون الأَوْدي</span> -من طريق حرب- قال: الخَيمة دُرّة مُجَوّفة{31}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٤<span class="dash">-</span></span> عن <span class="name-2">عمر بن ميمون</span> -من طريق حَزْن بن بِشر- في قوله تعالى: <span class="qpc-hafs">﴿مقصورات في الخيام﴾</span>: خَيمة مِن لؤلؤة واحدة، قصورها وأبوابها منها{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق موسى- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> دُرّ مُجَوّف{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: الخَيمة دُرّة مُجَوّفة{34}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> الخيام: اللؤلؤ والفِضة، كما يُقال، والله أعلم{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق محمد بن مروان- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> دُرّ مُجَوّف{36}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٤٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سلمة-، مثله{37}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> الخيام: الدُّرّ المُجَوّف{38}. (١٤/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥١<span class="dash">-</span></span> عن <span class="name-2">خُلَيد العَصَريّ</span> -من طريق قتادة- قال: لقد ذُكر لي: أنّ الخيمة لؤلؤة مُجَوّفة، لها سبعون مِصراعًا، كلّ ذلك من دُرّ{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، قال: في الحِجال{40}. (١٤/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: كان يُقال: مسكن المؤمن في الجنة يسير الراكب الجواد فيه ثلاث ليال، وأنهاره وجنانه وما أعدّ الله له مِن الكرامة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن جُحادَةَ</span>، في قول الله ﷾: <span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span>، قال: الخَيمة دُرّة، فرسخٌ في فرسخٍ، عليها أربعة ألف مِصراع من ذهب{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> في الحِجال{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي الخِيامِ﴾</span> يعني: الدُّرّ المُجَوّف، الدُّرّة الواحدة مثل القصر العظيم، جوفاء على قدر ميل في السماء، طولها فرسخ، وعرضها فرسخ، لها أربعة آلاف مِصراع من ذهب، فذلك قوله تعالى: <span class="qpc-hafs">﴿والمَلائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِن كُلِّ بابٍ﴾</span> [الرعد:٢٣]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، يُقال: خيامهم في الجنة من لؤلؤ{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی ٱلۡخِیَامِ ۝٧٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٥٨<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النَّبِيّ ﷺ، قال: «<b>الخَيمة دُرّة مُجَوّفة، طولها في السماء ستون ميلًا، في كلّ زاوية منها للمؤمن أهلٌ لا يراهم الآخرون، يطوف عليهم المؤمن</b>»{46}. (١٤/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٥٩<span class="dash">-</span></span> عن <span class="name-1">أبي الدّرداء</span>، قال: الخَيمة لؤلؤة واحدة، لها سبعون بابًا من دُرّ{47}. (١٤/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٠<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي المُهَزَّم- قال: دار المؤمن في الجنة من لؤلؤة، فيها أربعون بيتًا، في وسطها شجرة تُنبِت الحُلَل، فيأتيها، فيأخذ بأصبعه سبعين حُلّة مُمنطقَة{48} باللؤلؤ والمرجان{49}. (١٤/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦١<span class="dash">-</span></span> عن <span class="name-2">حِبّان بن أبي جَبَلة</span>، قال: إنّ نساء أهل الدنيا إذا دَخلن الجنة فُضِّلن على الحور العين؛ بأعمالهنَّ في الدنيا{50}. (١٤/١٦٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٦٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق رجل- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: منذ أُنشِئن{51}. (١٤/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span> لأنهنّ خُلقن في الجنة، يعني: لم يطأهنّ إنسٌ قبل أهل الجنة، <span class="qpc-hafs">﴿ولا جان﴾</span> يعني: ولا جنِّي{10}. (ز)</p></p><p></div></p></div>",footnotes:1:جاء في مسند أحمد (١٣٦٩٨) من حديث أنس: أنه اسم نهر في الجنة.|2:أخرجه البيهقي في البعث والنشور ص٢١٥ (٣٤٠)، والثعلبي ٩/١٩٦، من طريق علي بن أحمد بن عبدان، عن أحمد بن عبيد، عن الكديمي، عن حبان بن هلال، عن سليمان بن المغيرة، عن ثابت، عن أنس بن مالك به.</p><p>وسنده ضعيف؛ فيه محمد بن يونس الكديمي، قال عنه ابن حجر في تقريب التهذيب (٦٤١٩): «ضعيف».|3:أخرجه ابن جرير ٢٢/٢٦٤، ٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ٢٢/٣٠٣، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٣٣-٣٣٤-، وابن المنذر -كما في الفتح ٨/٦٢٤-.|5:أخرجه ابن جرير ٢٢/٢٦٤.|6:أخرجه ابن جرير ٢٢/٢٦٤.|7:أخرجه ابن جرير ٢٢/٢٦٤.|8:أخرجه ابن جرير ٢٢/٢٦٧، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٨/٤٦١ (٣٥١٩٤)، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٨٣ (٣١٢)-.|9:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣. والحَدَق: جمع حَدَقة وهي العين. النهاية (حدق).|10:تفسير مقاتل بن سليمان ٤/٢٠٥.|11:أخرجه ابن جرير ٢٢/٢٦٤.|12:أخرجه ابن جرير ٢٢/٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|13:أخرجه ابن جرير ٢٢/٢٦٦.|14:تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|15:أخرجه ابن جرير ٢٢/٢٦٥ وبنحوه من طريق أبي يحيى، وابن أبي شيبة ١٣/٥٦٨-٥٦٩، وهناد (١٧).|16:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤-.|17:أخرجه هناد (١٥)، وابن جرير ٢٢/٢٦٧ من طريق عبيد بنحوه.|18:أخرجه ابن جرير ٢٢/٢٦٧. وعزاه السيوطي إلى عبد بن حميد.|19:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.|20:أخرجه ابن جرير ٢٢/٢٦٦.|21:أخرجه ابن جرير ٢٢/٢٦٥.|22:تفسير مقاتل بن سليمان ٤/٢٠٥.|23:أخرجه ابن جرير ٢٢/٢٧٢، قال: حدثت عن الحسين، عن أبي معاذ، عن عبيد، عن الضَّحّاك، عن ابن مسعود به. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>وسنده ضعيف؛ لجهالة الراوي عن الحسين، والضحاك لم يدرك ابن مسعود.|24:أخرجه ابن جرير ٢٢/٢٧١، وابن أبي شيبة ١٣/١٣٤مرسلًا.|25:أخرجه ابن جرير ٢٢/٢٦٨-٢٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|26:أخرجه ابن جرير ٢٢/٢٦٨، ومسدد -كما في المطالب العالية (٤١٣٢)-، وابن أبي شيبة ١٣/١٣٤.|27:تفسير الثعلبي ٩/١٩٦.|28:أخرجه ابن أبي شيبة ١٣/١٣٣-١٣٥، وابن أبي الدنيا في صفة الجنة (٣٢٨)، وابن جرير ٢٢/٢٦٨-٢٦٩، وبنحوه من طريق مجاهد، وعكرمة، والبيهقي في البعث (٣٣٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|29:أخرجه ابن جرير ٢٢/٢٧١.|30:أخرجه عبد بن حميد -كما في الفتح ٨/٦٢٥-.|31:أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٥، وهناد (٥٢).|32:أخرجه أبو نعيم في حلية الأولياء ٤/١٤٩.|33:أخرجه ابن جرير ٢٢/٢٦٩.|34:أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٦، وهناد (١٧، ١٥٤).|35:تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٧٠، ٢٧١، ٢٧٢، من طريق منصور أيضًا.|36:أخرجه ابن أبي شيبة ١٣/١٣٥.|37:أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٦.|38:أخرجه ابن جرير ٢٢/٢٧١. وعزاه السيوطي إلى عبد بن حميد.|39:أخرجه ابن جرير ٢٢/٢٦٩.|40:أخرجه ابن جرير ٢٢/٢٦٦ بزيادة: محبوسات، وابن أبي شيبة ١٣/١٣٥.|41:أخرجه ابن جرير ٢٢/٢٧١.|42:أخرجه ابن المبارك في الزهد ١/٤٢١.|43:أخرجه ابن جرير ٢٢/٢٧٠.|44:تفسير مقاتل بن سليمان ٤/٢٠٥.|45:أخرجه ابن جرير ٢٢/٢٧١.|46:أخرجه البخاري ٤/١١٧-١١٨ (٣٢٤٣)، ٦/١٤٥ (٤٨٧٩)، ومسلم ٤/٢١٨٢ (٢٨٣٨).|47:أخرجه عبد الله بن أحمد في زوائد الزهد ص٢٣٣. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.|48:المِنطَق والمِنطقة والنِّطاق: كل ما شُد به وسطه. لسان العرب (نطق).|49:أخرجه ابن أبي شيبة ١٣/١٢٩.|50:أخرجه هناد (٢٣).|51:أخرجه هناد (٢٢).|52:تفسير مقاتل بن سليمان ٤/٢٠٥.
  55,72,""
  55,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٦٤<span class="dash">-</span></span> عن أبي بَكرة، عن النَّبِيّ ﷺ، قرأ: <b>(مُتَّكِئِينَ عَلى رَفارِفَ خُضْرٍ وعَباقِرِيَّ حِسانٍ)</b>{1}<span class=comment-ref>٦٤٠٨</span>. (١٤/١٦٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٨</span> ذكر <u>ابن جرير</u> (٢٢/٢٧٧ بتصرف) هذا الأثر عن النبي ﷺ، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لضعف السند، واللغة</span>، فقال: «وذُكر عن النبي ﷺ خبر غير محفوظ، ولا صحيح السند (رَفارِفَ خُضْرٍ وعَباقِرِيَّ) بالألف والإجراء، وهذه القراءة لو كانت صحيحة لوجب أن تكون الكلمتان غير مجراتين».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٨٤) هذه القراءة عن النبي ﷺ، وعن عثمان، وأورد <span class="comment-type-2">انتقاد</span> الزّجاج والرّماني عليها، فقال: «وغلّط الزّجاج والرّماني هذه القراءة». وذكر ابن عطية عن عثمان ﵁ أنه قرأ ذلك: (عَباقَريَّ) بفتح القاف والياء، ثم <span class="comment-type-4">علّق</span> بقوله: "وهذا على أن اسم الموضع (عباقر) بفتح القاف، والصحيح في اسم الموضع: (عبقر)، <span class="mustanad">قال الشاعر</span>:</p><p>كأن صليل المروحين تشذه صليل الزيوف يُنتقدن بعبقرا".</div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٥<span class="dash">-</span></span> عن أبي بكر بن عيّاش، قال: كان <span class="name-3">زُهير الفُرْقُبيّ</span> -وكان نحويًّا بصريًّا- يقرأ: (رَفارِفَ خُضْرٍ وعَباقِرِيَّ حِسانٍ){2}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٦<span class="dash">-</span></span> عن أبي طُعْمة -من طريق ابن لهيعة- يقرأ: (مُتَّكِئِينَ عَلى رَفارِفَ خُضْرٍ){3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٦٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، قال: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> فُضول المحابس{2}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: فُضول المحابس، والفُرُش، والبُسط{5}. (١٤/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: المحابس{6}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span> الرّفرف: الرياض{2}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧١<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span> الرّفرف: رياض الجنة، <span class="qpc-hafs">﴿خضر﴾</span> مُخضبة{8}<span class=comment-ref>٦٤٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٩</span> ذكر <u>ابنُ عطية</u> (٨/١٨٤) أنّ «الرَّفْرَف: ما تدلّى مِن الأَسِرّة مِن غالي الثياب والبُسُط». ونقل قول ابن جُبير في معنى: «الرفرف»، و<span class="comment-type-1">وجَّهه</span> بقوله: «ووَجْه قول ابن جُبير: أنه مِن رفَّ النَّبت: إذا نعُم وحسُن». ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأول أصوب وأبين». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: فُضول الفُرش{9}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: الرّفرف: المحابس{10}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: البُسط{11}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-: الرفرف: مرافق خُضر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: محابس خُضر{13}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٧<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span> البُسُط{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحسن بن يزيد بن الأصمّ- قال: <span class="qpc-hafs">﴿متكئين على رفرف﴾</span> المحابس{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٧٩<span class="dash">-</span></span> عن <span class="name-2">عاصم الحجدري</span>، (رَفْارَفٍ)، قال: وسائد{16}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن جُحادَةَ</span>، في قول الله ﷾: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفارَفٍ خُضْرٍ﴾</span>، قال: مجالس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿رفرف خضر﴾</span>، قال: الرّفرف: فُضول الفُرُش والمحابس{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span>، يعني: المحابس فوق الفُرش{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> الرّفرف: المحابس{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٤<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span>: هي الزّرابي{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٥<span class="dash">-</span></span> عن غَزْوان -من طريق سفيان- <span class="qpc-hafs">﴿رَفْرَفٍ خُضْرٍ﴾</span>، قال: فضول المحابس{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٦٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الزَّرابِيُّ{23}{6}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الزّرابي{6}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: والعبقري: الزّرابي{2}. (١٤/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٨٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، يعني: الوسائد{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿ولمن خافَ مقام ربه جنتان﴾</span> فذكر فضل ما بينهما، ثُمَّ ذكر <span class="qpc-hafs">﴿ومن دونهما جنتان فَبِأَي آلاء رَبكُما تُكَذِّبانِ مُدْهامّتان﴾</span> قال: خَضْراوان، <span class="qpc-hafs">﴿فيهما عَيْنان نَضّاخَتان﴾</span> وفي تلك <span class="qpc-hafs">﴿تَجْرِيانِ﴾</span>، <span class="qpc-hafs">﴿فيهما فاكِهَة ونَخلٌ ورُمّان﴾</span> وفي تلك <span class="qpc-hafs">﴿مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span>، <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حسان﴾</span> وفي تلك <span class="qpc-hafs">﴿قاصِراتُ الطّرفِ لم يَطْمِثهنّ إنْسٌ قبلهم ولا جان﴾</span>، <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> وفي تلك <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى فُرُشٍ بَطائِنُها من إسْتَبْرق﴾</span> قالَ: الدِّيباج، والعبقري: الزّرابي{28}. (١٤/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩١<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> هي الطّنافس المُخْملة إلى الرّقة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> العبقري: عتاق الزّرابي{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الدِّيباج الغليظ{31}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: العبقري: الزّرابي، وهي البُسُط{10}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الطَّنافس{33}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span>، قال: الزّرابي{34}. (١٤/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحسن بن يزيد بن الأصمّ- قال: <span class="qpc-hafs">﴿وعبقري حسان﴾</span> الزّرابي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن جُحادَةَ</span>، في قول الله ﷾: (وعَباقِرِيَّ حِسانٍ)، قال: طَنافس. وكان يقرأها: (وعَباقِرِيَّ){17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٩٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿عبقري﴾</span>: الزّرابي{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> يعني: الزّرابي، وهي الطّنافس المُخْملة، وهي الحِسان{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿وعَبْقَرِيٍّ حِسانٍ﴾</span> العبقري: الطنافس{39}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٢٧٣ (٢٩٨٦) وفيه: <span class="qpc-hafs">﴿رَفْرَفٍ﴾</span>، <span class="qpc-hafs">﴿(وعَبْقَرِيٍّ﴾</span>، وحفص بن عمر في جزء قراءات النبي ص١٥٧ (١١٤)، والثعلبي ٩/١٩٨، من طريق أبي عبد الرحمن عبد الله بن حفص الأرطباني، عن عاصم الجحدري، عن أبي بكرة به.</p><p>قال ابن جرير في التفسير ٢٢/٢٧٧: «ذُكر عن النبي ﷺ خبر غير محفوظ، ولا صحيح السند». فذكره. وقال: قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع، وعاصم لم يدرك أبا بكرة».</p><p>وهي قراءة شاذة، تروى أيضًا عن الفرقبي، وابن محيصن، وغيرهما. انظر: المحتسب ٢/٣٠٥، ومختصر ابن خالويه ص١٥١.|2:عزاه السيوطي إلى عبد بن حميد.|3:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٦٢ (١٤٤)-.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٣٠٥.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٢/٢٧٤-٢٧٥، وبنحوه من طريق عنترة، وابن أبي شيبة ١٣/١٣٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|6:أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|7:عزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن حجر في تغليق التعليق ٤/٦٣ بسنده إلى أبي نعيم عن سعيد بن جبير من طريق أبي بشر بلفظ: الرفرف: رياض الجنة، وتفسير البغوي ٧/٤٥٨.|9:أخرجه ابن جرير ٢٢/٢٧٧ مقتصرًا على آخره، وابن أبي شيبة ١٣/١٣٧، وهناد (٨٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:أخرجه ابن جرير ٢٢/٢٧٥ مقتصرًا على أوله، وابن أبي شيبة ١٣/١٣٦، وهناد (٨٢).|11:أخرجه ابن جرير ٢٢/٢٧٤ بنحوه، وابن أبي شيبة ١٣/١٣٧، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٣ (١٦٠)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:أخرجه ابن جرير ٢٢/٢٧٥.|13:أخرجه عبد الرزاق ٢/٢٦٧، وابن جرير ٢٢/٢٧٥-٢٧٧، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|14:تفسير الثعلبي ٩/١٩٧.|15:أخرجه سعيد بن منصور في سننه -التفسير ٧/٥١٦ (٢١٤٣).|16:عزاه السيوطي إلى ابن المنذر.|17:أخرجه ابن المبارك في الزهد ١/٤٢١.|18:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.|19:تفسير مقاتل بن سليمان ٤/٢٠٥.|20:أخرجه ابن جرير ٢٢/٢٧٥.|21:تفسير الثعلبي ٩/١٩٧، وتفسير البغوي ٧/٤٥٩.|22:أخرجه ابن جرير ٢٢/٢٧٤.|23:الزَّرابي: البُسُط، وقيل: كل ما بُسط واتُّكِئ عليه. لسان العرب (زرب).|24:أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|25:أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|26:عزاه السيوطي إلى عبد بن حميد.|27:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٥-.|28:عزاه السيوطي إلى ابن مردويه.|29:تفسير الثعلبي ٩/١٩٧، وتفسير البغوي ٧/٤٥٩.|30:أخرجه ابن جرير ٢٢/٢٧٦، وأخرجه ابن حجر في تغليق التعليق ٤/٦٣ بسنده إلى أبي نعيم عن سعيد بن جبير من طريق أبي بشر بلفظ: العبقري: الزرابي. وعزاه ابن حجر في الفتح ٧/٤٦ إلى عبد بن حميد.|31:أخرجه ابن جرير ٢٢/٢٧٧، وابن أبي شيبة ١٣/١٣٧، وهناد (٨٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|32:أخرجه ابن جرير ٢٢/٢٧٥ مقتصرًا على أوله، وابن أبي شيبة ١٣/١٣٦، وهناد (٨٢).|33:أخرجه ابن أبي شيبة ١٣/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|34:أخرجه عبد الرزاق ٢/٢٦٧، وابن جرير ٢٢/٢٧٥-٢٧٧، ومن طريق أبي العوام. وعزاه السيوطي إلى عبد بن حميد.|35:أخرجه سعيد بن منصور في سننه -التفسير ٧/٥١٦ (٢١٤٣).|36:أخرجه ابن المبارك في الزهد ١/٤٢١.|37:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.|38:تفسير مقاتل بن سليمان ٤/٢٠٥.|39:أخرجه ابن جرير ٢٢/٢٧٧.
  55,74,""
  55,75,""
  55,76,""
  55,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ذِي الجَلالِ والإكْرامِ﴾</span> يقول: ذو العظمة والكبرياء{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَبارَكَ اسْمُ رَبِّكَ ذِي الجَلالِ﴾</span> يعني بالجلال: العظيم، <span class="qpc-hafs">﴿والإكْرامِ﴾</span> يعني: الكريم؛ فلا أكرم منه، يمدح الرّبُّ نفسه -تبارك وتعالى-{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٠٤<span class="dash">-</span></span> عن أنس بن مالك، أنّ رسول الله ﷺ قال: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام</b>»{3}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٥<span class="dash">-</span></span> عن عبد الله بن عمر، عن النبيِّ ﷺ، قال: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام</b>»{4}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٦<span class="dash">-</span></span> عن ربيعة بن عامر، سمعتُ رسول الله ﷺ يقول: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام</b>»{5}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٧<span class="dash">-</span></span> عن أنس بن مالك قال: قال رسول الله ﷺ: «<b>ألِظّوا بـ: يا ذا الجلال والإكرام؛ فإنهما اسمان من أسماء الله العِظام</b>» {6}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٨<span class="dash">-</span></span> عن معاذ بن جبل، قال: سمع النبيُّ ﷺ رجلًا يقول: يا ذا الجلال والإكرام. قال: «<b>قد استُجيب لك؛ فَسَل</b>»{7}. (١٤/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٠٩<span class="dash">-</span></span> عن ثوبان، قال: كان رسول الله ﷺ إذا انصرف من صلاته استغفر الله ثلاثًا، ثم قال: «<b>اللهم، أنت السلام، ومنك السلام، تباركتَ يا ذا الجلال والإكرام</b>»{8}. (١٤/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٠<span class="dash">-</span></span> عن أنس بن مالك، قال: كنتُ مع رسول الله ﷺ جالسًا في الحلقة، ورجل قائم يصلي، فلمّا ركع وسجد تشهَّد ودعا، فقال في دعائه: اللهم، إني أسألك بأنّ لك الحمد، لا إله إلا أنت وحدك لا شريك لك، المنّان بديع السموات والأرض، يا ذا الجلال والإكرام، يا حيّ يا قيّوم، إني أسألك. فقال النبيُّ ﷺ: «<b>لقد دعا اللهَ باسمه العظيم؛ الذي إذا دُعِي به أجاب، وإذا سُئِل به أعطى</b>»{9}. (١٤/١٧٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٧٨.|2:تفسير مقاتل بن سليمان ٤/٢٠٥.|3:أخرجه الترمذي ٦/١٢٧ (٣٨٣٤)، من طريق محمد بن حاتم المكتب، عن أبي بدر شجاع بن الوليد، عن الرحيل بن معاوية، عن الرّقاشي، عن أنس بن مالك به.</p><p>وأخرجه أيضًا ٦/١٢٩ (٣٨٣٥)، والبزار ١٣/١٨٠ (٦٦٢٥)، من طريق المؤمل، عن حماد بن سلمة، عن حميد، عن أنس به.</p><p>قال الترمذي: «هذا حديث غريب، وقد رُوي هذا الحديث عن أنس مِن غير هذا الوجه». وقال في الموضع الثاني: «هذا حديث غريب، وليس بمحفوظ، وإنما يُروى هذا عن حماد بن سلمة، عن حميد، عن الحسن البصري، عن النبي ﷺ، وهذا أصح. والمؤمل غلط فيه، فقال: عن حميد، عن أنس، ولا يُتابع فيه». وأورده الدارقطني في العلل ١٢/٢٦ (٢٣٦٥). وقال ابن حجر في الكافي الشاف ص١٦٢ (٧٧): «يزيد ضعيف».|4:أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٣٩٦-، من طريق المعافى بن عمران، عن ابن عياش، عن عمر بن محمد بن زيد بن عبد الله بن عمر بن الخطاب، عن أبيه، عن عبد الله بن عمر به.</p><p>قال ابن حجر في الكافي الشاف ص١٦٢: «إسناده ضعيف».|5:أخرجه أحمد ٢٩/١٣٨ (١٧٥٩٦)، والحاكم ١/٦٧٦ (١٨٣٦)، من طريق عبد الله بن المبارك، عن يحيى بن حسان، عن ربيعة بن عامر به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن عساكر في تاريخه ١٨/٦٧: «قال ابن منده: هذا حديث غريب، لم نكتبه إلا من هذا الوجه». وأورده الألباني في الصحيحة ٤/٤٩ (١٥٣٦).|6:عزاه السيوطي إلى ابن مردويه.|7:أخرجه أحمد ٣٦/٣٤٧-٣٤٨ (٢٢٠١٧)، ٣٦/٣٧٩ (٢٢٠٥٦)، والترمذي ٦/١٣١-١٣٢ (٣٨٣٧-٣٨٣٨)، من طريق سعيد الجريري، عن أبي الورد بن ثمامة، عن اللجلاج، عن معاذ بن جبل به.</p><p>قال الترمذي: «هذا حديث حسن». وأورده ابن أبي حاتم في علل الحديث ٥/٣٨٢ (٢٠٦٣). وقال الألباني في الضعيفة ٧/٤٢٥ (٣٤١٦)، ١٠/٢٤ (٤٥٢٠): «ضعيف».|8:أخرجه مسلم ١/٤١٤ (٥٩١).|9:أخرجه أحمد ١٩/٢٣٨ (١٢٢٠٥)، وابن ماجه (٣٨٥٨)، من طريق وكيع، عن أبي خزيمة، عن أنس بن سيرين، عن أنس بن مالك به.</p><p>وأخرجه أحمد ٢٠/٦١ (١٢٦١١)، ٢١/١٩٢ (١٣٥٧٠)، وأبو داود ٢/٦١٢-٦١٣ (١٤٩٥)، والنسائي ٣/٥٢ (١٣٠٠)، وابن حبان ٣/١٧٥-١٧٦ (٨٩٣)، والحاكم ١/٦٨٣ (١٨٥٦)، من طريق خلف بن خليفة، عن حفص بن عمر، عن أنس به.</p><p>قال الترمذي: «هذا حديث غريب من هذا الوجه، وقد روي من غير هذا الوجه عن أنس». وقال الهيثمي في المجمع ١٠/١٥٦ (١٧٢٥٨): «رواه أحمد، والطبراني في الصغير، ورجال أحمد ثقات، إلا أن ابن إسحاق مدلّس، وإن كان ثقة». وقال الألباني في صحيح أبي داود ٥/٢٣٣ (١٣٤٢): «حديث صحيح». وأورده في الصحيحة ٧/١٢٠٩ (٣٤١١).
  55,78,""
  56,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٤٧١١<span class="dash">-</span></span> عن عبد الله بن عباس -من طرق- قال: نَزَلَتْ سورة الواقعة بمكة{1}. (١٤/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٢<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{2}. (١٤/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونَزَلَتْ بعد سورة طه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٤<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٥<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٦<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق همام-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٧<span class="dash">-</span></span> عن محمد بن شهاب الزُّهريّ: مكّيّة، ونَزَلَت بعد سورة طه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٨<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧١٩<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الواقعة مكّيّة، عددها ست وتسعون آية كوفي{8}<span class=comment-ref>٦٤١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٠</span> ذكر <u>ابنُ عطية</u> (٨/١٨٧) أنّ سورة الواقعة «مكية بإجماعٍ ممن يُعتدّ بقوله من المفسرين». ثم نقل قولًا ولم ينسبه، أنّ «فيها آيات مدنية، أو مما نزل في السَّفر». ثم <span class="comment-type-2">انتقده</span> -<span class="mustanad">مستندًا إلى عدم ثبوته</span>- قائلًا: «وهذا كله غير ثابت».</div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٠<span class="dash">-</span></span> عن عبد الله بن مسعود، سمعتُ رسول الله ﷺ يقول: «<b>مَن قرأ سورة الواقعة كلَّ ليلة لم تُصِبْه فاقةٌ أبدًا</b>»{9}<span class=comment-ref>٦٤١١</span>. (١٤/١٧٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/١٨٧) على هذا الحديث بقوله: «فيها ذكر القيامة وحظوظ الناس في الآخرة، وفَهْمُ ذلك غنًى لا فقر معه، مَن فَهِمَه شُغِل بالاستعداد».</div></p><p><div></p><p><p><span class="item-no">٧٤٧٢١<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال أبو بكر ﵁: يا رسول الله، قد شِبْتَ! قال: «<b>شيَّبتني هود، والواقعة، والمرسلات، و<span class="qpc-hafs">﴿عم يتساءلون﴾</span>، و<span class="qpc-hafs">﴿إذا الشمس كُوِّرت﴾</span></b>»{10}. (١٤/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٢<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأجْدع الهَمداني</span> -من طريق هلال- قال: مَن أراد أن يعلم نبأ الأوّلين والآخرين، ونبأ أهل الدنيا وأهل الآخرة، ونبأ الجنة والنار؛ فليقرأ: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span>{11}. (١٤/١٧٥، ٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك، وأبي صالح- في قوله: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span> قال: الساعة، <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</span> يقول: مَن كَذّب بها في الدنيا فإنه لا يُكذّب بها في الآخرة إذا وقَعتْ، <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span> قال: القيامة خافضة. يقول: خَفَضَتْ فأسمَعَت الأدنى، ورَفَعتْ فأسمَعَت الأقصى، كان القريب والبعيد فيها سواء. قال: وخَفَضَتْ أقوامًا قد كانوا في الدنيا مرتفعين، ورَفَعتْ أقوامًا حتى جَعلتْهم في أعلى عِلّيّين، <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span> قال: هي الزّلْزلة، <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا فَكانَتْ هَباءً مُنْبَثًّا﴾</span> قال الحكم: قال السُّدِّيّ: قال علي: هذا الهَرَج، هَرَج الدّواب الذي يُحرّك الغبار، <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span> قال: العباد يوم القيامة على ثلاثة منازل، <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span> هم الجمهور جماعة أهل الجنة، <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span> هم أصحاب الشمال، يقول: ما لهم وما أعدّ لهم، <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span> هم مثل النّبيّين، والصِّدِّيقين، والشهداء بالأعمال من الأوّلين والآخرين، <span class="qpc-hafs">﴿أُولَئِكَ المُقَرَّبُونَ﴾</span> قال: هم أقرب الناس من دار الرحمن مِن بُطْنان الجنة، وبُطْنانها: وسطها، <span class="qpc-hafs">﴿فِي جَنّاتِ النَّعِيمِ﴾</span>، <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ عَلى سُرُرٍ مَوْضُونَةٍ﴾</span> قال: المَوْضُونة: المَرْمُولة بالذّهب، المُكلّلة بالجوهر والياقوت، <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</span> قال ابن عباس: ما ينظر الرجل منهم في قفا صاحبه، يقول: حِلقًا حِلقًا، <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span> قال: خَلَقهم الله في الجنة كما خَلَق الحُور العين، لا يموتون، لا يَشيبون، ولا يَهْرمون، <span class="qpc-hafs">﴿بِأَكْوابٍ وأَبارِيقَ﴾</span> والأكواب: التي ليس لها آذان مثل الصّواع، والأباريق: التي لها الخراطيم والأعناق، <span class="qpc-hafs">﴿وكَأْسٍ مِن مَعِينٍ﴾</span> قال: الكأس من الخمر بعينها، ولا يكون كأس حتى يكون فيها الخمر، فإذا لم يكن فيها خمر فإنما هو إناء، والمَعين يقول: مِن خمرٍ جاري، <span class="qpc-hafs">﴿لا يُصَدَّعُونَ عَنْها﴾</span> عن الخمر، <span class="qpc-hafs">﴿ولا يُنْزِفُونَ﴾</span> لا تَذهب بعقولهم، <span class="qpc-hafs">﴿وفاكِهَةٍ مِمّا يَتَخَيَّرُونَ﴾</span> يقول: مما يشتهون، <span class="qpc-hafs">﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</span> يقول: يجيئهم الطير حتى يقع، فيَبسط جناحه، فيأكلون منه ما اشتَهوا نضيجًا لم تُنضجه النار، حتى إذا شَبعوا منه طار، فذَهب كما كان، <span class="qpc-hafs">﴿وحُورٌ عِينٌ﴾</span> قال: الحُور: البِيض، والعِين: العظام الأعين، حِسان، <span class="qpc-hafs">﴿كَأَمْثالِ اللُّؤْلُؤِ﴾</span> قال: كبياض اللؤلؤ التي لم تمسّهن الأيدي ولا الدّهر، <span class="qpc-hafs">﴿المَكْنُونِ﴾</span> الذي في الأصداف، <span class="qpc-hafs">﴿جَزاءً بِما كانُوا يَعْمَلُونَ لا يَسْمَعُونَ فِيها لَغْوًا﴾</span> قال: اللغو: الحَلف: لا واللهِ، وبلى واللهِ، <span class="qpc-hafs">﴿ولا تَأْثِيمًا﴾</span> قال: لا يَأْثمون، <span class="qpc-hafs">﴿إلّا قِيلًا سَلامًا سَلامًا﴾</span> يقول: التسليم منهم وعليهم، بعضهم على بعض، قال: هؤلاء المُقرّبون. ثم قال: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</span> وما أعدّ لهم! <span class="qpc-hafs">﴿فِي سِدْرٍ مَخْضُودٍ﴾</span> والمخضود: المُوقَر الذي لا شوك فيه، <span class="qpc-hafs">﴿وطَلْحٍ مَنضُودٍ وظِلٍّ مَمْدُودٍ﴾</span> يقول: ظِلّ الجنة لا ينقطع، ممدود عليهم أبدًا، <span class="qpc-hafs">﴿وماءٍ مَسْكُوبٍ﴾</span> يقول: مصبوب، <span class="qpc-hafs">﴿وفاكِهَةٍ كَثِيرَةٍ لا مَقْطُوعَةٍ﴾</span> قال: لا تَنقطع حينًا وتجيء حينًا مثل فاكهة الدنيا، <span class="qpc-hafs">﴿ولا مَمْنُوعَةٍ﴾</span> كما تُمنع في الدنيا إلا بثمن، <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span> يقول: بعضها فوق بعض. ثم قال: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span> قال: هؤلاء نساء أهل الجنة، وهؤلاء العُجُزُ الرُّمْصُ{12}، يقول: خَلقَهم خَلْقًا، <span class="qpc-hafs">﴿فَجَعَلْناهُنَّ أبْكارًا﴾</span> يقول: عذارى، <span class="qpc-hafs">﴿عُرُبًا﴾</span> والعُرُب: المُتحبّبات إلى أزواجهنّ، <span class="qpc-hafs">﴿أتْرابًا﴾</span> المُصطحبات اللاتي لا تَغَرْن، <span class="qpc-hafs">﴿لِأَصْحابِ اليَمِينِ ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> يقول: طائفة من الأوّلين، وطائفة من الآخرين، <span class="qpc-hafs">﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</span> ما لهم وما أعدّ لهم، <span class="qpc-hafs">﴿فِي سَمُومٍ﴾</span> قال: فَيح نار جهنم، <span class="qpc-hafs">﴿وحَمِيمٍ﴾</span> الماء الحارّ الذي قد انتهى حرّه، فليس فوقه حرّ، <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span> قال: من دُخان جهنم، <span class="qpc-hafs">﴿لا بارِدٍ ولا كَرِيمٍ إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</span> قال: مشركين جبّارين، <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ﴾</span> يُقيمون، <span class="qpc-hafs">﴿عَلى الحِنْثِ العَظِيمِ﴾</span> قال: على الإثم العظيم. قال: هو الشّرك، <span class="qpc-hafs">﴿وكانُوا يَقُولُونَ أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿أوَآباؤُنا الأَوَّلُونَ﴾</span> قال: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد: <span class="qpc-hafs">﴿إنَّ الأَوَّلِينَ والآخِرِينَ لَمَجْمُوعُونَ إلى مِيقاتِ يَوْمٍ مَعْلُومٍ﴾</span> قال: يوم القيامة، <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ أيُّها الضّالُّونَ المُكَذِّبُونَ﴾</span> قال: المشركون المُكذّبون <span class="qpc-hafs">﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ﴾</span> قال: والزَّقوم إذا أكَلوا منه غَصُّوا، والزَّقوم شجرة، <span class="qpc-hafs">﴿فَمالِئُونَ مِنها البُطُونَ﴾</span> قال: يَملؤون من الزَّقوم بطونهم، <span class="qpc-hafs">﴿فَشارِبُونَ عَلَيْهِ مِنَ الحَمِيمِ﴾</span> يقول: على الزَّقوم الحميم، <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span> هي الرّمال لو مَطرتْ عليها السماء أبدًا لم يُر فيها مستنقع، <span class="qpc-hafs">﴿هَذا نُزُلُهُمْ يَوْمَ الدِّينِ﴾</span> كرامة يوم الحساب، <span class="qpc-hafs">﴿نَحْنُ خَلَقْناكُمْ فَلَوْلا تُصَدِّقُونَ﴾</span> يقول: أفلا تُصدِّقون، <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</span> يقول: هذا ماء الرجل، <span class="qpc-hafs">﴿أأَنْتُمْ تَخْلُقُونَهُ أمْ نَحْنُ الخالِقُونَ نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span> في المتعجّل والمتأخّر، <span class="qpc-hafs">﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</span> يقول: <span class="qpc-hafs">﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</span> فيقول: نَذهب بكم ونَجيء بغيركم، <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> يقول: نخلُقكم فيما لا تعلمون؛ إن نشأ خلقناكم قِردة، وإن نشأ خلقناكم خنازير، <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى فَلَوْلا تَذَكَّرُونَ﴾</span> يقول: فهلّا تذكرون. ثم قال: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ﴾</span> يقول: ما تزرعون، <span class="qpc-hafs">﴿أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span> يقول: أليس نحن الذي نُنبتُه أم أنتم المُنبتُون؟! <span class="qpc-hafs">﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ﴾</span> يقول: تَنَدَّمون، <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span> يقول: إنّا لَمُوّارٌ{13} به، <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِن المُزْنِ﴾</span> يقول: من السحاب، <span class="qpc-hafs">﴿أمْ نَحْنُ المُنْزِلُونَ لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</span> يقول: مُرًّا، <span class="qpc-hafs">﴿فَلَوْلا تَشْكُرُونَ﴾</span> يقول: فهلّا تشكرون، <span class="qpc-hafs">﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾</span> يقول: تَقْدحون، <span class="qpc-hafs">﴿أأَنْتُمْ أنْشَأْتُمْ﴾</span> يقول: خلقتم <span class="qpc-hafs">﴿شَجَرَتَها أمْ نَحْنُ المُنْشِئُونَ﴾</span> قال: وهي مِن كل شجرة إلا في العُنّاب{14}، وتكون في الحجارة، <span class="qpc-hafs">﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</span> يقول: يُتذكّر بها نار الآخرة العليا، <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span> قال: والمُقوي: هو الذي لا يجد نارًا، فيُخرِج زِنده، فيَسْتَنوِر ناره، فهي متاع له، <span class="qpc-hafs">﴿فَسَبِّحْ بِاسْمِ رَبِّكَ العَظِيمِ﴾</span> يقول: فَصَلِّ لربّك العظيم، <span class="qpc-hafs">﴿فَلا أُقْسِمُ﴾</span> يقول: أُقسم <span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ﴾</span> قال: أتى ابنَ عباس عُلَيَّةُ بن الأسود أو نافعُ بن الحكم، فقال له: يا ابن عباس، إني أقرأ آيات من كتاب الله أخشى أن يكون قد دَخلني منها شيء. قال ابن عباس: ولِم ذلك؟ قال: لأني أسمع الله يقول: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةِ القَدْرِ﴾</span> [القدر:١]، ويقول: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ﴾</span> [الدخان:٣]، ويقول في آية أخرى: <span class="qpc-hafs">﴿شَهْرُ رَمَضانَ الَّذِي أُنْزِلَ فِيهِ القُرْآنُ﴾</span> [البقرة:١٨٥]، وقد نزل في الشهور كلّها؛ شوال وغيره. قال ابن عباس: ويلك! إنّ جُملة القرآن أُنزِل من السماء في ليلة القَدْر إلى بدء موقع النجوم. يقول: إلى سماء الدنيا، فنَزَل به جبريلُ في ليلة منه، وهي ليلة القَدْر المباركة، وهي في رمضان، ثم نزل به على محمد ﷺ في عشرين سنة الآية والآيتين والأكثر، فذلك قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ﴾</span> يقول: أُقسم <span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ وإنَّهُ لَقَسَمٌ﴾</span> والقَسم قَسمٌ، إلى قوله: <span class="qpc-hafs">﴿لا يَمَسُّهُ إلّا المُطَهَّرُونَ﴾</span> وهم السَّفرة، والسَّفرة: هم الكتبة. ثم قال: <span class="qpc-hafs">﴿تَنْزِيلٌ مِن رَبِّ العالَمِينَ أفَبِهَذا الحَدِيثِ أنْتُمْ مُدْهِنُون﴾</span> يقول: تَوَلَّوْن أهل الشّرك، <span class="qpc-hafs">﴿وتَجْعَلُونَ رِزْقَكُمْ﴾</span> قال ابن عباس: سافر النبيُّ ﷺ في حرٍّ، فعطش الناس عطشًا شديدًا حتى كادت أعناقهم أن تنقطع مِن العطش، فذُكِر ذلك له، قالوا: يا رسول الله، لو دعوتَ الله، فسَقانا. قال: «<b>لعلّي لو دعوتُ الله فسقاكم لقلتم: هذا بنَوء كذا وكذا</b>». قالوا: يا رسول الله، ما هذا بحين الأنواء. فدعا بماءٍ في مَطهرة، فتوضأ، ثم ركع ركعتين، ثم دعا الله، فهبّت رياحٌ، وهاج سحابٌ، ثم أرسَلتْ، فمُطروا حتى سال الوادي، فشَربوا، وسَقَوا دوابّهم، ثم مرَّ النبيُّ ﷺ برجل وهو يغترف بقَعْبٍ معه مِن الوادي، وهو يقول: نَوء كذا وكذا سقطت الغداة. قال: ونزلت هذه الآية: <span class="qpc-hafs">﴿وتَجْعَلُونَ رِزْقَكُمْ أنَّكُمْ تُكَذِّبُونَ﴾</span>{15}، <span class="qpc-hafs">﴿فَلَوْلا إذا بَلَغَتِ الحُلْقُومَ﴾</span> يقول: النّفس، <span class="qpc-hafs">﴿وأَنْتُمْ حِينَئِذٍ تَنْظُرُونَ ونَحْنُ أقْرَبُ إلَيْهِ مِنكُمْ﴾</span> يقول: الملائكة، <span class="qpc-hafs">﴿ولَكِنْ لا تُبْصِرُونَ﴾</span> يقول: لا تبصرون الملائكة، <span class="qpc-hafs">﴿فَلَوْلا﴾</span> يقول: هلا <span class="qpc-hafs">﴿إنْ كُنْتُمْ غَيْرَ مَدِينِينَ﴾</span> غير مُحاسبين، <span class="qpc-hafs">﴿تَرْجِعُونَها﴾</span> يقول: أن تُرجِعوا النّفس <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ فَأَمّا إنْ كانَ مِنَ المُقَرَّبِينَ﴾</span> مثل النّبيّين والصِّدِّيقين والشهداء بالأعمال، <span class="qpc-hafs">﴿فَرَوْحٌ﴾</span> الفَرَج، مثل قوله: <span class="qpc-hafs">﴿ولا تَيْأَسُوا مِن رَوْحِ اللَّهِ﴾</span> [يوسف:٨٧]، <span class="qpc-hafs">﴿ورَيْحانٌ﴾</span> الرّزق. قال ابن عباس: لا تَخرج رُوح المؤمن من بدنه حتى يأكل مِن ثمار الجنة قبل موته، <span class="qpc-hafs">﴿وجَنَّتُ نَعِيمٍ﴾</span> يقول: حُقِّقتْ له الجنة والآخرة، <span class="qpc-hafs">﴿وإمّا إنْ كانَ مِن أصْحابِ اليَمِينِ﴾</span> يقول: جمهور أهل الجنة، <span class="qpc-hafs">﴿فَسَلامٌ لَكَ مِن أصْحابِ اليَمِينِ وأَمّا إنْ كانَ مِنَ المُكَذِّبِينَ الضّالِّينَ﴾</span> وهم المشركون، <span class="qpc-hafs">﴿فَنُزُلٌ مِن حَمِيمٍ﴾</span> قال ابن عباس: لا يَخرج الكافرُ مِن بيته في الدنيا حتى يُسقى كأسًا من حميم، <span class="qpc-hafs">﴿وتَصْلِيَةُ جَحِيمٍ﴾</span> يقول: في الآخرة، <span class="qpc-hafs">﴿إنَّ هَذا لَهُوَ حَقُّ اليَقِينِ﴾</span> يقول: هذا القول الذي قَصَصنا عليك لهو حقّ اليقين، يقول: القرآن الصادق{2}. (١٤/٢٤٧-٢٥٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا وَقَعَتِ ٱلۡوَاقِعَةُ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span>، قال: يوم القيامة{17}. (١٤/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿الواقِعَةُ﴾</span> و<span class="qpc-hafs">﴿الطّامَّةُ﴾</span> [النازعات:٣٤] و<span class="qpc-hafs">﴿الصّاخَّةُ﴾</span> [عبس:٣٣]، ونحو هذا: من أسماء القيامة، عظّمه الله، وحذّر عباده{18}<span class=comment-ref>٦٤١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/١٨٨) على قول ابن عباس بقوله: «وهذه كلها أسماء تقتضي تعظيمها، وتشنيع أمرها».</div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- في قوله: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span>، قال: الساعة{2}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span>: يعني: الصَّيْحة{18}<span class=comment-ref>٦٤١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٣</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٨٨) قول الضَّحّاك بقوله: «وهي النفخة في الصور». ثم نقل عن بعض المفسّرين قولهم: «الواقعة: صخرة بيت المقدس، تقع عند القيامة». ثم <span class="comment-type-4">علَّق</span> بقوله: «فهذه كلها معانٍ لأجل القيامة».</div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span>، قال: نَزَلَتْ{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span> يعني: إذا وقعت الصيحة، وهي النّفخة الأولى{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه النحاس ص٧٤٩ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|5:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.|6:تنزيل القرآن ص٣٧-٤٢.|7:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|8:تفسير مقاتل بن سليمان ٤/٢١٢.|9:أخرجه أحمد في فضائل الصحابة ٢/٧٢٦ (١٢٤٧)، وابن السني في عمل اليوم والليلة ص٦٢٩-٦٣٠ (٦٨٠)، والثعلبي ٩/١٩٩.</p><p>قال الزيلعي في تخريج أحاديث الكشاف ٣/٤١٣-٤١٤ (١٢٩٥): «فقد تبيّن ضعف هذا الحديث من وجوه: <b>أحدها</b>: الانقطاع. كما ذكره الدارقطني، وابن أبي حاتم في علله نقلًا عن أبيه. <b>والثاني</b>: نكارة متنه. كما قال أحمد. <b>والثالث</b>: ضعف رواته. كما ذكره ابن الجوزي. <b>والرابع</b>: الاضطراب ... وقد اجتمع على ضعفه الإمام أحمد، وأبو حاتم، وابنه، والدارقطني، والبيهقي، وابن الجوزي، تلويحًا وتصريحًا». وقال العراقي في تخريج أحاديث الإحياء ص٤٠٧: «وللحارث بن أبي أسامة من حديث ابن مسعود بسند ضعيف». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٤٣٧: «الحديث منكر». وقال الألباني في الضعيفة ١/٤٥٧ (٢٨٩): «ضعيف».|10:أخرجه الترمذي ٥/٤٠٢ (٣٢٩٧)، والحاكم ٢/٣٧٤ (٣٣١٤).</p><p>قال الترمذي: «هذا حديث حسن غريب، لا نعرفه من حديث ابن عباس إلا من هذا الوجه. وروى علي بن صالح هذا الحديث عن أبي إسحاق، عن أبي جحيفة نحو هذا. ورُوي عن أبي إسحاق، عن أبي ميسرة شيء من هذا مرسلًا. وروى أبو بكر بن عياش، عن أبي إسحاق، عن عكرمة، عن النبي ﷺ نحو حديث شيبان، عن أبي إسحاق، ولم يذكر فيه عن ابن عباس». وقال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». ووافقه الذهبي.|11:أخرجه ابن أبي شيبة ١٣/٤٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:الرُّمْص: جمع رَمْصاء، والرَّمَصُ في العين كالغَمَص، وهو قَذًى تلفظ به. لسان العرب والقاموس (رمص).|13:مارَ يَمُور مَوْرًا: يذهبُ ويجيءُ ويتردّد. لسان العرب (مور).|14:العناب: شجر شائك من الفصيلة السِّدْرية، يبلغ ارتفاعه ستة أمتار، ويطلق العناب على ثمره أيضًا، وهو أحمر حلو لذيذ الطعم على شكل ثمرة النبق. المعجم الوسيط (عنب).|15:عزاه السيوطي إلى ابن مردويه.</p><p>إسناده جيد. وينظر: مقدمة الموسوعة.|16:عزاه السيوطي إلى ابن مردويه.|17:أخرجه ابن أبي شيبة ١٣/٣٧٢، وابن جرير ٢٢/٢٧٩ مختصرًا، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٨٨-. وعزاه السيوطي إلى ابن مردويه.|18:أخرجه ابن جرير ٢٢/٢٧٩.|19:عزاه السيوطي إلى ابن مردويه.|20:أخرجه ابن جرير ٢٢/٢٧٩.|21:أخرجه عبد الرزاق ٢/٢٦٩.|22:تفسير مقاتل بن سليمان ٤/٢١٥.
  56,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَیۡسَ لِوَقۡعَتِهَا كَاذِبَةٌ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> في قوله: <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</span>، قال: ليس لها مردود{1}. (١٤/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك، وأبي صالح- <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</span>، يقول: مَن كذّب بها في الدنيا فإنه لا يُكذّب بها في الآخرة إذا وقعت{2}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</span>، قال: مَثْنَوِيّة{3}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ليس لوقعتها كاذبة﴾</span>، قال: أي: ليس لها مَثْنَويّة، ولا رجعة، ولا ارتداد{4}<span class=comment-ref>٦٤١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٤</span> ذكر <u>ابن عطية</u> (٨/١٨٨) في معنى: <b><span class="qpc-hafs">﴿كاذِبَةٌ﴾</span></b> احتمالين: <b>الأول:</b> «أن يكون مصدرًا؛ كالعاقبة، والعافية، وخائنة الأعين». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فالمعنى: ليس لها تكذيبٌ ولا ردٌّ مَثْنَويَّةٌ. وهذا قول قتادة، والحسن». <b>والثاني:</b> «أن يكون صفةً لمقدَّر». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «كأنه تعالى قال: ليس لِوَقْعَتِها حال كاذبة، ويحتمل الكلام على هذا معنيين: <b>أحدهما</b>: كاذِبَةٌ، أي: مكذوبة فيما أخبر به عنها، وسماها <span class="qpc-hafs">﴿كاذِبَةٌ﴾</span> بهذا، كما تقول: قصة كاذبة، أي: مكذوب فيها. <b>والثاني:</b> حالٌ كاذبة، أي: لا يمضي وقوعها، كما تقول: فلان إذا حمل لم يكذب».</div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها﴾</span> يعني: ليس لصيحتها <span class="qpc-hafs">﴿كاذِبَةٌ﴾</span> أنها كائنة، ليس لها مَثْنَويّة، ولا ارتداد{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن أبي حاتم، وابن مردويه.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ٢٢/٢٨٠. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٢٢/٢٧٩.|5:تفسير مقاتل بن سليمان ٤/٢١٥.
  56,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خَافِضَةࣱ رَّافِعَةٌ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٣٥<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عثمان بن سراقة- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: الساعة؛ خَفَضَتْ أعداءَ الله إلى النار، ورَفَعَتْ أولياءَ الله إلى الجنة{1}. (١٤/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: تَخْفِض ناسًا، وترفع آخرين{2}. (١٤/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: أسمعت القريبَ، والبعيدَ{3}. (١٤/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: القيامة خافضة. يقول: خَفَضَتْ فأسمَعَت الأدنى، ورَفَعَتْ فأسمَعَت الأقصى، كان القريب والبعيد فيها سواء. قال: وخَفَضَتْ أقوامًا قد كانوا في الدنيا مرتفعين، ورَفَعَتْ أقوامًا حتى جعلتهم في أعلى عِلّيّين{4}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>: خَفَضَتْ فأسمَعَت الأدنى، ورَفَعَتْ فأسمَعَت الأقصى، فكان فيها القريب والبعيد سواء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: خَفَضَتْ وأسمَعَت الأدنى، ورَفَعَتْ فأسمَعَت الأقصى. قال: فكان القريب والبعيد من الله سواء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤١<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق أبي المليح الرقيّ- في قوله تعالى: <span class="qpc-hafs">﴿خافضة رافعة﴾</span>، قال: تَخْفِض أقوامًا، وترفع آخرين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي معشر- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: تَخْفِض رجالًا كانوا في الدنيا مرتفعين، وترفع رجالًا كانوا في الدنيا مُنخَفضين{8}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: خَفَضَتْ قومًا في عذاب الله، ورَفَعَتْ قومًا في كرامة الله{9}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span> قال: عَلَتْ كلّ سهل وجبل، حتى أسمَعَت القريب والبعيد، ثم رَفَعَتْ أقوامًا في كرامة الله، وخَفَضَتْ أقوامًا في عذاب الله{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٥<span class="dash">-</span></span> عن <span class="name-2">عثمان بن عبد الله بن سُراقةَ</span> -من طريق عبيد الله العَتَكيّ- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: الساعة؛ خَفَضَتْ أعداء الله إلى النار، ورَفَعَتْ أولياء الله إلى الجنة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق حماد- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: خَفَضَت المتكبرين، ورَفَعَت المتواضعين{12}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٧<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق أسامة- في قوله: <span class="qpc-hafs">﴿خافِضَةٌ رافِعَةٌ﴾</span>، قال: مَنِ انخفض يومئذٍ لم يرتفع أبدًا، ومَنِ ارتفع يومئذٍ لم ينخفض أبدًا{13}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خافِضَةٌ﴾</span> يقول: أسمَعَتِ القريب. ثم قال: <span class="qpc-hafs">﴿رافِعَةٌ﴾</span> يقول: أسمَعَت البعيد، فكانت صيحة، يعني: فصارت صيحة واحدة، أسمَعَت القريب والبعيد{14}<span class=comment-ref>٦٤١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٥</span> ذكر <u>ابنُ عطية</u> (٨/١٨٨) في معنى الآية عن جمهورٍ من المتأولين: أن «القيامة تنفطر بها السماء والأرض والجبال، وانهدام هذه البنية يرفع طائفة من الأجرام، ويخفض أخرى». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فكأنها عبارة عن شدة الهول والاضطراب».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٢٦-. وعزاه السيوطي إلى ابن جرير، وفيه موقوف على عثمان بن سراقة كما سيأتي ٢٢/٢٨٠.|2:أخرجه ابن أبي شيبة ١٣/٣٧٢، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٨٨-. وعزاه السيوطي إلى ابن مردويه، وابن جرير.|3:أخرجه ابن جرير ٢٢/٢٨١. وعزاه السيوطي إلى ابن مردويه.|4:عزاه السيوطي إلى ابن مردويه.|5:أخرجه ابن جرير ٢٢/٢٨١.|6:أخرجه ابن جرير ٢٢/٢٨١.|7:أخرجه أبو نعيم في حلية الأولياء ٤/٨٦.|8:أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٢٦-، وأبو الشيخ في العظمة (١٨٣). وعزاه السيوطي إلى ابن المنذر.|9:أخرجه عبد الرزاق ٢/٢٦٩، وابن جرير ٢٢/٢٨١ بلفظ: أسمعت القريب والبعيد، خافضة أقوامًا إلى عذاب الله، ورافعة أقوامًا إلى كرامة الله. وعزاه السيوطي إلى عبد بن حميد.|10:أخرجه ابن جرير ٢٢/٢٨٠.|11:أخرجه ابن جرير ٢٢/٢٨٠.|12:أخرجه أبو الشيخ (١٨٤).|13:أخرجه ابن أبي شيبة ١٣/٥٧٧.|14:تفسير مقاتل بن سليمان ٤/٢١٥.
  56,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذَا رُجَّتِ ٱلۡأَرۡضُ رَجࣰّا ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span>، قال: زُلْزلت{1}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span>، يقول: ترجف الأرض: تُزلزل{2}<span class=comment-ref>٦٤١٦</span>. (١٤/١٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/١٨٩) على قول ابن عباس بقوله: «ومنه: ارتَجَّ السهم في الغرض؛ إذا اضطرب بعد وقوعه. والرَّجة في الناس: الأمر المحرِّك».</div></p><p><div></p><p><p><span class="item-no">٧٤٧٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span>، قال: هي الزّلْزَلة{3}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span>، قال: زُلْزلتْ{4}. (١٤/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span>، قال: زُلْزلتْ زلزلة{5}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span> وذلك أنّ الله ﷿ إذا أوحى إليها اضطربت فَرَقًا مِن الله تعالى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</span>، يعني: إذا زُلْزلت الأرض زلزالها، يعني: رجًّا، شدة الزلزلة لا تسكن حتى تُلقي كلّ شيء في بطنها على ظهرها، يقول: إنها تضطرب وترتج؛ لأنّ زلزلة الدنيا لا تلبث حتى تسكن، وزلزلة الآخرة لا تسكن وترتجّ كرجّ الصبي في المهْد حتى ينكسر كلّ شيء عليها من جبل، أو مدينة، أو بناء، أو شجر، فيدخل فيها كلّ شيء خرج منها من شجر أو نبات، وتُلقي ما فيها من الموتى، والكنوز على ظهرها{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٨٢ بلفظ: زلزلها. وعزاه السيوطي إلى ابن المنذر.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن مردويه.|4:تفسير مجاهد ص٦٤٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤-، وابن جرير ٢٢/٢٨٢. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه عبد الرزاق ٢/٢٦٩، وابن جرير ٢٢/٢٨٢ كلاهما من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.|6:تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٧.|7:تفسير مقاتل بن سليمان ٤/٢١٥.
  56,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبُسَّتِ ٱلۡجِبَالُ بَسࣰّا ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: فُتِّتَتْ{1}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، يقول: فُتِّتَتْ فَتًّا{2}<span class=comment-ref>٦٤١٧</span>. (١٤/١٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٧</span> لم يذكر <u>ابنُ جرير</u> (٢٢/٢٨٣-٢٨٤) في معنى: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> سوى قول ابن عباس، ومجاهد، وعكرمة، وأبي صالح، والسُّدِّيّ من طريق سعيد بن الصلت، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٨<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٥٩<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> كُسِرتْ كسرًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: فُتِّتَتْ{4}. (١٤/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: كما يُبَسُّ السَّوِيق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: لُتَّت لتًّا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: فُتَّت فتًّا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> قُلِعَتْ مِن أصلها، فذهبتْ بعد ما كانت صخرًا صماء{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٥<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> بُسِطتْ بسطًا كالرّمل والتراب{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٦<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> أُذْهِبَتْ إذْهابًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٧<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٨<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> فُتّتْ فتًّا، فصارت كالدقيق المبْسوس، وهو المبلول{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله تعالى: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: حُتّت حتًّا{12}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: نُسِفتْ نسفًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٢<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سعيد بن الصلت- <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: فُتِّتَتْ فتًّا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق رجل- في قول الله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، يقول: حُتّتْ حتًّا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> سُيِّرت عن وجه الأرض تسييرًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span> يعني: فُتِّتت الجبال فتًّا، <span class="qpc-hafs">﴿فكانت﴾</span> يقول: فصارت بعد القوة والشدة عروقها في الأرض السابعة السفلى، ورأسها فوق الأرض العليا؛ من الخوف{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿وبُسَّتِ الجِبالُ بَسًّا﴾</span>، قال: صارت كثيبًا مهيلًا، كما قال جلّ وعزّ{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٨٣ بنحوه. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٥-.|3:تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٧.|4:تفسير مجاهد ص٦٤٠، وأخرجه ابن جرير ٢٢/٢٨٣-٢٨٤، وبنحوه من طريق منصور. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٢/٢٨٣-٢٨٤، والفريابي -كما في الفتح ٨/٦٢٥-.|6:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٥-.|7:أخرجه ابن جرير ٢٢/٢٨٣.|8:تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٨.|9:تفسير الثعلبي ٩/٢٠٠.|10:تفسير الثعلبي ٩/٢٠٠.|11:تفسير البغوي ٨/٧.|12:عزاه السوطي إلى ابن جرير، وعبد بن حميد.|13:أخرجه عبد الرزاق ٢/٢٦٩.|14:أخرجه ابن جرير ٢٢/٢٨٤.|15:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٢٤ (٢٨٤).|16:تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٧.|17:تفسير مقاتل بن سليمان ٤/٢١٥.|18:أخرجه ابن جرير ٢٢/٢٨٤.
  56,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَانَتۡ هَبَاۤءࣰ مُّنۢبَثࣰّا ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٧٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الحارث- قال: الهباء المُنبَثّ: رهْج الدّواب. والهباء المنثور: غُبار الشمس الذي تراه في شعاع الكَوَّة{1}. (١٤/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٨<span class="dash">-</span></span> قال السُّدِّيّ: قال <span class="name-1">علي [بن أبي طالب]</span> في قوله: <span class="qpc-hafs">﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</span>: هذا الهَرَج، هَرَج الدّواب الذي يحرّك الغبار{2}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</span>، قال: كشعاع الشمس{3}. (١٤/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</span>، قال: الهباء: الذي يطير من النار إذا اضطرمت يطير منها الشّرر، فإذا وقع لم يكن شيئًا{4}. (١٤/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</span>، قال: الهباء: ما يثور مع شعاع الشمس، وانبثاثه: تفرّقه{5}. (١٤/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جبير]</span> -من طريق عطاء- <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span>، قال: شعاع الشمس حين يدخل من الكَوّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span>، قال: الشعاع الذي يكون في الكَوّة{7}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [الغفاري]</span>، في قوله: <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span>، قال: الغبار الذي يخرج مِن الكَوّة مع شعاع الشمس{8}. (١٤/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span>، قال: هو الذي تراه في الشمس إذا دخَلَتْ من الكَوّة إلى البيت{8}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span> غُبارًا ذا هباء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٧<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: الهباء: ما تطاير مِن شَرر النار{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span>، قال: الهباء: ما تذروه الرياح مِن حُطام الشجر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٨٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿هباء منبثا﴾</span>، قال: ما تذروه الريح وتَبُثُّه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَباءً مُنْبَثًّا﴾</span> يعني: الغبار الذي تراه في الشمس إذا دخل مِن الكَوّة في البيت. والمُنبثّ: الذي ليس بشيء. والهباء المنثور: الذي يسطع مِن حوافر الخيل من الغبار. قال عبد الله بذلك حدثني أبي، عن أبي صالح، عن مقاتل، عن الحارث، عن علي ﵇{14}<span class=comment-ref>٦٤١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٨</span> اختُلف في معنى: «الهباء» في هذه الآية على أقوال: <b>الأول:</b> أنه ما يتطاير في الهواء من الأجزاء الدقيقة، ولا يكاد يُرى إلا في الشمس إذا دخلت من كَوة. <b>الثاني:</b> أنه ما يتطاير من يبس النبات. <b>الثالث:</b> ما يتطاير من حوافر الخيل والدواب. <b>الرابع:</b> ما يتطاير من شرر النار، فإذا طفئ لم يوجد شيء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/١٩٠) القول الأول، فقال: «والقول الأول في الهباء أحسن الأقوال». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه مقاتل بن سليمان ٤/٢١٥-٢١٦، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٠- مختصرًا، وعبد الرزاق ٢/٢٦٩ مختصرًا، وابن جرير ٢٢/٢٨٥ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ٢٢/٢٨٤. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢٢/٢٨٥. وعزاه السيوطي إلى ابن أبي حاتم.|5:عزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ٢٢/٢٨٤.|7:أخرجه ابن جرير ٢٢/٢٨٥ بلفظ: شعاع الشمس يدخل من الكوة، وليس بشيء. وعزاه السيوطي إلى عبد بن حميد.|8:عزاه السيوطي إلى عبد بن حميد.|9:عزاه السيوطي إلى عبد بن حميد.|10:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٦-.|11:تفسير الثعلبي ٩/٢٠١.|12:أخرجه عبد الرزاق ٢/٢٦٩، وابن جرير ٢٢/٢٨٥-٢٨٦، وبنحوه من طريق سعيد.|13:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٠.|14:تفسير مقاتل بن سليمان ٤/٢١٥-٢١٦.
  56,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُنتُمۡ أَزۡوَ ٰ⁠جࣰا ثَلَـٰثَةࣰ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span>، قال: أصنافًا{1}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span>، قال: هي التي في سورة الملائكة: <span class="qpc-hafs">﴿ثُمَّ أوْرَثْنا الكِتابَ الَّذِينَ اصْطَفَيْنا مِن عِبادِنا فَمِنهُمْ ظالِمٌ لِنَفْسِهِ ومِنهُمْ مُقْتَصِدٌ ومِنهُمْ سابِقٌ بِالخَيْراتِ﴾</span> [فاطر:٣٢]{2}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span>، قال: هذا حين تَزايَلَتْ{3} بهم المنازل، هم أصحاب اليمين، وأصحاب الشمال، والسابقون{4}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span>، قال: العباد يوم القيامة على ثلاثة منازل{5}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٥<span class="dash">-</span></span> عن <span class="name-2">عثمان بن عبد الله بن سُراقة</span> -من طريق عبيد الله العَتَكي- قوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span>، قال: اثنان في الجنة، وواحد في النار. يقول: الحُور العِين للسابقين، والعُرُب الأتْراب لأصحاب اليمين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span>، قال: منازل الناس يوم القيامة{7}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال ﷿: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span> وكنتم في الآخرة أصنافًا ثلاثة؛ صنفان في الجنة، وصنف في النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٧٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- يقول: وجدتُ الهوى ثلاثة أثلاث، فالمرء يجعل هواه عِلْمه، فيُدالُ{9} هواه على عِلْمه، ويقهر هواه عِلْمَه، حتى إنّ العلم مع الهوى قبيحٌ ذليل، والعلم ذليل الهوى غالب قاهر، فهذا الذي قد جعل الهوى والعلم في قلبه، فهذا مِن أزواج النار، وإذا كان مِمَّن يريد الله به خيرًا استَفاق واستَنبَه، فإذا هو عَوْنٌ للعلم على الهوى حتى يُديل الله العلم على الهوى، فإذا حَسُنتْ حال المؤمن، واستقامت طريقته كان الهوى ذليلًا، وكان العلم غالبًا قاهرًا، فإذا كان مِمّن يريد الله به خيرًا خَتَم عمله بإدالة العلم، فتَوفّاه حين توفّاه وعِلْمه هو القاهر، وهو العامل به، وهواه الذليل القبيح، ليس له في ذلك نصيب ولا فعل، والثالث: الذي قبّح الله هواه بعِلْمه، فلا يطمع هواه أن يغلب العلم، ولا أن يكون له مع العلم نصف ولا نصيب، فهذا الثالث، وهو خيرهم كلّهم، وهو الذي قال الله ﷿ في سورة الواقعة: <span class="qpc-hafs">﴿وكنتم أزواجا ثلاثة﴾</span> قال: فزوجان في الجنة، وزوج في النار. قال: والسابق الذي يكون العلم غالبًا للهوى، والآخر الذي ختم الله بإدالة العلم على الهوى، فهذان زوجان في الجنة، والآخر هواه قاهر لعِلْمه، فهذا زوج النار{10}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|3:تزايلتْ: تفرّقتْ. لسان العرب (زيل).|4:عزاه السيوطي إلى ابن المنذر.|5:عزاه السيوطي إلى ابن مردويه.|6:أخرجه ابن جرير ٢٢/٢٨٧.|7:أخرجه عبد الرزاق ٢/٢٦٩ مختصرًا، وابن جرير ٢٢/٢٨٦-٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:تفسير مقاتل بن سليمان ٤/٢١٦.|9:الإدالة: الغَلَبة. النهاية (دول).|10:أخرجه ابن جرير ٢٢/٢٨٨-٢٨٩.
  56,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ مَاۤ أَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٧٩٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span> وهم الذين كانوا على يمين آدم حين أُخرجت الذُّريّة من صُلبه، وقال الله تعالى لهم: هؤلاء في الجنة، ولا أُبالِي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span>: هم الجمهور، جماعة أهل الجنة{2}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠١<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span> هم الذين يُعطون كتبهم بأيمانهم{1}<span class=comment-ref>٦٤١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤١٩</span> نقل <u>ابنُ عطية</u> (٨/١٩١) قولًا أنّ أصحاب الميمنة: مؤمنون، وهم على يمين العرش. وأنّ أصحاب المشأمة: كافرون، وهم على شمال العرش. ثم <span class="comment-type-1">علَّق</span> على قول مَن قال: أصحاب الميمنة: هم مَن أخذ كتابه بيمينه، وأصحاب المشأمة: من أخذه بشماله. بقوله: «فعلى هذا ليست نسبة اليمين والشمال إلى العرش».</div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٣<span class="dash">-</span></span> و<span class="name-2">الربيع [بن أنس]</span>: <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span> هم الذين كانوا ميامين مُباركين على أنفسهم، وكانت أعمارهم في طاعة الله ﷿، وهم التابعون بإحسان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span>، قال: ماذا لهم، وماذا أعدّ لهم{5}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</span> يقول: ما لأصحاب اليمين من الخير والكرامة في الجنة{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ مَاۤ أَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ ۝٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٠٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>إنّ الله تعالى قَسَم الخلْق قسمين: فجعلني في خيرهما قسمًا، فذلك قوله: <span class="qpc-hafs">﴿وأَصْحابُ اليَمِينِ﴾</span></b> [الواقعة:٢٧]، <b><span class="qpc-hafs">﴿وأَصْحابُ الشِّمالِ﴾</span></b> [الواقعة:٤١]، <b>فأنا من أصحاب اليمين، وأنا من خير أصحاب اليمين، ثم جعل القسمين بيوتًا، فجعلني في خيرهما بيتًا، فذلك قوله: <span class="qpc-hafs">﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ والسّابِقُونَ السّابِقُونَ﴾</span></b> [الواقعة:٨-١٠]، <b>فأنا من خير السابقين، ثم جعل البيوت قبائل، فجعلني في خيرها قبيلة، فذلك قوله: <span class="qpc-hafs">﴿شُعُوبًا وقَبائِلَ﴾</span></b> [الحجرات:١٣]، <b>فأنا أتقى ولد آدم وأكرمهم على الله ﷿ ولا فَخْر، ثم جعل القبائل بيوتًا، فجعلني في خيرها بيتًا، فذلك قوله: <span class="qpc-hafs">﴿إنَّما يُرِيدُ اللَّهُ لِيُذْهِبَ عَنْكُمُ الرِّجْسَ أهْلَ البَيْتِ ويُطَهِّرَكُمْ تَطْهِيرًا﴾</span></b> [الأحزاب:٣٣]»{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/٢٠١، وتفسير البغوي ٨/٨.|2:عزاه السيوطي إلى ابن مردويه.|3:تفسير الثعلبي ٩/٢٠١، وتفسير البغوي ٨/٨.|4:تفسير الثعلبي ٩/٢٠١، وتفسير البغوي ٨/٨.|5:أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٤/٢١٦.|7:أخرجه الطبراني في الكبير ٣/٥٦ (٢٦٧٤)، ١٢/١٠٣ (١٢٦٠٤)، والثعلبي ٨/٤٤. وأورده الحكيم الترمذي في نوادر الأصول ١/٣٣٠-٣٣١.</p><p>قال ابن أبي حاتم في علل الحديث ٦/٤٩٠ (٢٦٩٣): «قال أبي: هذا حديث باطل». وقال الهيثمي في المجمع ٨/٢١٥ (١٣٨٢٢): «رواه الطبراني، وفيه يحيى بن عبد الحميد الحماني، وعباية بن ربعي، وكلاهما ضعيف». وقال الألباني في الضعيفة ١١/٨٥٥ (٥٤٩٥): «موضوع بهذا التمام».
  56,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ مَاۤ أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٠٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span> هم الذين كانوا على شمال آدم عند إخراج الذُّريّة، وقال الله لهم: هؤلاء في النار ولا أبالي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span>. قال: أصحاب الشمال. قال: وهل كانت العرب تعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: أما سمعت بقول زُهير بن أبي سُلمى:</p><p>نَزَلَ الشَّيْبُ بالشِّمالِ قَرِيبًا والمَرُوراتِ دائِيًا وحَقِيرا؟</p><p>قال: صَدقتَ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span>: هم أصحاب الشمال، يقول: ما لهم، وما أعدّ لهم{3}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٠<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span> هم الذين يُؤتون كتبهم بشمالهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span> هم المشائيم على أنفسهم، وكانت أعمارُهم في المعاصي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span>، قال: ماذا لهم، وماذا أعدّ لهم{6}. (١٤/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</span>، يقول: ما لأصحاب المشأمة مِن الشرِّ في جهنم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٨.|2:أخرجه الطبراني مطولًا في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).|3:عزاه السيوطي إلى ابن مردويه.|4:تفسير البغوي ٨/٨.|5:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٨.|6:أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|7:تفسير مقاتل بن سليمان ٤/٢١٦.
  56,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ ۝١٠﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٤٨١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>، قال: نَزَلَتْ في حِزْقيل مؤمن آل فرعون، وحَبيب النجار الذي ذُكر في <span class="qpc-hafs">﴿يس﴾</span>، وعلي بن أبي طالب، وكلّ رجل منهم سابق أُمّته، وعلِيٌّ أفضلهم سبقًا{1}. (١٤/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>، قال: يوشع بن نون سبق إلى موسى، ومؤمن آل يس سبق إلى عيسى، وعلي بن أبي طالب ﵁ سبق إلى محمد رسول الله ﷺ{2}. (١٤/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قال رسول الله ﷺ: «<span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ﴾</span> <b>أول مَن يُهَجِّرُ</b>{3} <b>إلى المسجد، وآخر مَن يخرج منه</b>»{4}. (١٤/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٧<span class="dash">-</span></span> عن <span class="name-1">النُّعمان بن بشير</span>، قال: قال رسول الله ﷺ: «<b><span class="qpc-hafs">﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</span></b> [التكوير:٧] <b>قال: الضُّرَباءُ</b>{5}؛ <b>كلّ رجل مع قوم كانوا يعملون بعمله، وذلك أنّ الله يقول: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ والسّابِقُونَ السّابِقُونَ﴾</span>، قال:</b> «<b>هم الضُّرَباء</b>»{6}. (١٤/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ﴾</span>، قال: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخَرِينَ﴾</span> فقال رسول الله ﷺ: «<b>سوّى بين أصحاب اليمين مِن الأمم الماضية، وبين أصحاب اليمين مِن هذه الأُمّة، وكان السابقون مِن الأمم أكثر مِن سابقي هذه الأُمّة</b>»{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨١٩<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span> إلى الصلوات الخمس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span> السابقون إلى الهجرة، هم السابقون في الآخرة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>، قال: من كلّ أُمّة{1}. (١٤/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>: هم مثل النّبيّين، والصِّدِّيقين، والشهداء بالأعمال مِن الأوّلين والآخرين{1}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{12}. (١٤/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٤<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق أبي علي- <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ فِي جَنّاتِ النَّعِيمِ﴾</span>، قال: هم أهل القرآن، وهم المتوَّجُون يوم القيامة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>: هم المُسارِعون إلى التوبة، وإلى أعمال البِرّ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٦<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: إلى الجهاد{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٧<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: السابقون إلى الإسلام{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٨<span class="dash">-</span></span> عن <span class="name-2">عثمان بن أبي سَوَدة</span> مولى عبادة بن الصامت -من طريق أبي عمرو- قال: بلغنا في هذه الآية: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span> أنهم السابقون إلى المساجد والخروج في سبيل الله{17}. (١٤/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٢٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>، السابقون: أصحاب النبي ﷺ، وأصحاب الأنبياء{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span> إلى قوله: <span class="qpc-hafs">﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> [الواقعة:٧-٤٠]، قال: سوّى بين أصحاب اليمين من الأمم الماضية وبين أصحاب اليمين من هذه الأُمّة، وكان السابقون من الأولين أكثر مِن سابقي هذه الأُمّة{19}<span class=comment-ref>٦٤٢٠</span>. (١٤/١٧٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٠</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٩٢) قول الحسن بقوله: «وذلك إما أن يقرن أصحاب الأنبياء ﵈ بجموعهم إلى أصحاب محمد ﷺ، فأولئك أكثر عددًا لا محالة، وإما أن يقرن أصحاب الأنبياء ﵈ ممن سبق في أثناء الأمم السّالِفَة إلى السابقين من جميع هذه الأُمّة؛ فأولئك أكثر».</div></p><p><div></p><p><p><span class="item-no">٧٤٨٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبد الله بن بكر- يقول: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ﴾</span>، قال: وأمّا المُقرّبون فقد مَضوا هنيئًا لهم، ولكن اللهم اجعلنا مِن أصحاب اليمين. قال: وأتى على هذه الآية <span class="qpc-hafs">﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</span> [النبأ:٢١]، قال: ألا على الباب رَصد؛ فمَن جاء بجواز جاز، ومَن لم يجئ بجواز حُبس{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق قرة- <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>: هم الذين صَلّوا إلى القِبلتين{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٣<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: إلى كلّ خير{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span>، قال: السابقون مِن كلّ أُمّة{23}<span class=comment-ref>٦٤٢١</span>. (١٤/١٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٣٥١) على هذه الأقوال بقوله: «وهذه الأقوال كلّها صحيحة؛ فإنّ المراد بالسابقين: هم المُبادِرون إلى فعل الخيرات كما أُمروا، كما قال تعالى: <b><span class="qpc-hafs">﴿وسارِعُوا إلى مَغْفِرَةٍ مِن رَبِّكُمْ وجَنَّةٍ عَرْضُها السَّمَواتُ والأرْضُ﴾</span></b> [آل عمران:١٣٣]، وقال: <b><span class="qpc-hafs">﴿سابِقُوا إلى مَغْفِرَةٍ مِن رَبِّكُمْ وجَنَّةٍ عَرْضُها كَعَرْضِ السَّماءِ والأرْضِ﴾</span></b> [الحديد:٢٢]، فمَن سابق في هذه الدنيا وسبق إلى الخير، كان في الآخرة من السابقين إلى الكرامة، فإنّ الجزاء من جنس العمل، وكما تدين تدان؛ ولهذا قال تعالى: <b><span class="qpc-hafs">﴿أُولَئِكَ المُقَرَّبُونَ فِي جَنّاتِ النَّعِيمِ﴾</span></b> [الواقعة:١١-١٢]».</div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٥<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: السابقون إلى إجابة الرسول في الدنيا، وهم السابقون إلى الجنة في العقبى{8}<span class=comment-ref>٦٤٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٢</span> <span class="comment-type-3">استظهر</span> <u>ابنُ القيم</u> (٨/١٠٧) في قوله تعالى: <span class="qpc-hafs">﴿والسّابِقُونَ السّابِقُونَ﴾</span> أن تكون «السابقون» الأولى غير الثانية، «ويكون المعنى: السابقون في الدنيا إلى الخيرات هم السابقون يوم القيامة إلى الجنات، والسابقون إلى الإيمان هم السابقون إلى الجنان».</div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٦<span class="dash">-</span></span> عن آدم بن عبد الله الخَثْعميّ، قال: سألتُ <span class="name-3">زيد بن علي</span> عن قول الله ﷿: <span class="qpc-hafs">﴿والسابقون السابقون أولئك المقربون﴾</span> مَن هؤلاء؟ قال: أبو بكر، وعمر. ثم قال: لا أنالني اللهُ شفاعةَ جدّي إن لم أُوالِهما{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسّابِقُونَ﴾</span> إلى الأنبياء، منهم أبو بكر وعلي ﵄، هم <span class="qpc-hafs">﴿السّابِقُونَ﴾</span> إلى الإيمان بالله ورسوله من كلّ أُمّة؛ هم السابقون إلى الجنة{26}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ ۝١٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٣٨<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>السابقون يوم القيامة أربعة</b>: <b>فأنا سابق العرب، وسلمان سابق فارس، وبلال سابق الحبشة، وصُهيب سابق الروم</b>»{27}. (١٤/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٣٩<span class="dash">-</span></span> عن عبد الله بن شُمَيط، قال: سمعت أبي يقول: الناس ثلاثة: فرجل ابتكر الخير في حَداثة سِنّه ثم داوم عليه حتى خرج عن الدنيا فهذا السابق المقرب، ورجل ابتكر عمره بالذنوب وطول الغفلة ثم تراجع بتوبة حتى ختم له بهذا فهو من أصحاب اليمين، ورجل ابتكر عمره بالذنوب ثم لم يزل عليها حتى حتى ختم له بهذا فهذا من أصحاب الشمال{28}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٩٠-. وعزاه السيوطي إلى ابن مردويه.|3:التهجِير: التبكير إلى كل شيء والمبادرة إليه. النهاية (هجر).|4:أورده الديلمي في الفردوس ٢/٣٤٨ (٣٥٧٤).|5:الضرباء: هم الأمثال والنُّظَراء، واحدهم: ضَرِيب. النهاية (ضرب).|6:أخرجه ابن جرير ٢٤/١٤٢، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥١٦-.</p><p>إسناده ضعيف؛ فيه الوليد بن عبد الله بن أبي ثور الهمداني الكوفي، قال عنه ابن حجر في التقريب (٧٤٣١): «ضعيف».|7:أخرجه ابن جرير ٢٢/٢٨٧ مرسلًا.|8:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.|9:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٨.|10:عزاه السيوطي إلى ابن مردويه.|11:عزاه السيوطي إلى ابن مردويه.|12:أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد بن حميد.|13:أخرجه الثعلبي ٩/٢٠٢، وأبو نعيم في حلية الأولياء ٥/٣٧٧ مختصرًا. وينظر: تفسير البغوي ٨/٩.|14:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.|15:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.|16:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٨.|17:أخرجه ابن جرير ٢٢/٢٩٠، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٢٥٥ (١٩٦٨٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. كما أخرج نحوه عبد الله بن أحمد في زوائد الزهد ص٢٦٣، وفيه: عن عثمان بن أبي مرة، وربما كان تصحيفًا.|18:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٧-.|19:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر. وأخرجه ابن جرير ٢٢/٢٨٧-٢٨٨ مرفوعًا، وقد تقدم.|20:أخرجه البيهقي في شعب الإيمان ٣/١٥٥-١٥٦ (٨٧٤).|21:أخرجه ابن جرير ٢٢/٢٩١.|22:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.|23:أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|24:تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.|25:أخرجه ابن عساكر في تاريخ دمشق ١٩/٤٦١.|26:تفسير مقاتل بن سليمان ٤/٢١٦.|27:عزاه السيوطي إلى عبد بن حميد مرسلًا.</p><p>ضعفه الألباني في السلسلة الضعيفة (٢٩٥٣).|28:أخرجه الثعلبي ٩/٢٠٢.
  56,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلۡمُقَرَّبُونَ ۝١١ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝١٢ ثُلَّةࣱ مِّنَ ٱلۡأَوَّلِینَ ۝١٣ وَقَلِیلࣱ مِّنَ ٱلۡـَٔاخِرِینَ ۝١٤﴾</span> - نزول الآيات، والنسخ فيها</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٤٠<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span> -من طريق عُروة بن رُوَيم- قال: لَمّا نَزَلَتْ: <span class="qpc-hafs">﴿إذا وقَعَتِ الواقِعَةُ﴾</span> ذُكر فيها: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ﴾</span>، قال عمر: يا رسول الله، ثُلّة من الأوّلين وقليل منّا؟ فأُمسك آخر السورة سنة، ثم نزل: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>. فقال رسول الله ﷺ: «<b>يا عمر، تعال فاسمع ما قد أنزل الله: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، ألا وإنّ مِن آدم إلَيَّ ثُلّة، وأُمّتي ثُلّة، ولن تُستَكمل ثُلّتنا حتى نستعين بالسُّودان مِن رُعاة الإبل، مِمّن يشهد أن لا إله إلا الله وحده لا شريك له</b>»{1}. (١٤/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٤٢<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: لَمّا نزلت: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ﴾</span> حزِن أصحابُ رسول الله ﷺ، وقالوا: إذن لا يكون مِن أُمّة محمد إلا قليل. فنَزَلَت نصفَ النهار: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، وتقايلها الناس، فنَسَخَت الآيةَ: <span class="qpc-hafs">﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</span>{2}. (١٤/١٨٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلۡمُقَرَّبُونَ ۝١١ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝١٢ ثُلَّةࣱ مِّنَ ٱلۡأَوَّلِینَ ۝١٣ وَقَلِیلࣱ مِّنَ ٱلۡـَٔاخِرِینَ ۝١٤﴾</span> - تفسير الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أُولَئِكَ المُقَرَّبُونَ﴾</span> قال: هم أقرب الناس مِن دار الرحمن مِن بُطنان الجنة، وبُطنانها: وسطها، <span class="qpc-hafs">﴿فِي جَنّاتِ النَّعِيمِ﴾</span>{2}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٤٤<span class="dash">-</span></span> عن <span class="name-2">عُرْوة بن الزّبير</span> -من طريق سعد بن إبراهيم- قال: كان يقال: تقدّموا تقدّموا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثُلَّةٌ﴾</span>، قال: أُمّة{5}. (١٤/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</span> يعني: جمعًا من الأوّلين، يعني: سابقي الأمم الخالية، وهم الذين عاينوا الأنبياءَ ﵈، فلم يشُكُّوا فيهم طَرْفة عين، فهم السابقون، <span class="qpc-hafs">﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</span> يعني: أُمّة محمد ﷺ، فهم أقلّ مِن سابقي الأمم الخالية، ثم ذكر ما أعدّ الله للسابقين من الخير{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</span> قال: مِمّن سبق، <span class="qpc-hafs">﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</span> قال: من هذه الأُمّة{7}<span class=comment-ref>٦٤٢٤</span>. (١٤/١٨٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٤</span> اختُلف في معنى: <b><span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ﴾</span></b> على قولين: <b>الأول:</b> أنّ الأوّلين مَن كان قبل محمد ﷺ، والآخرين أمَّته. <b>الثاني:</b> أنّ الأوّلين من صدر هذه الأمة، والآخرين من هذه الأمة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٦/١٨٥) القول الأول قائلًا: «والأول أصح».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٣/٣٥٣) -<span class="mustanad">مستندًا إلى دلالة القرآن، والعقل</span>- القول الأول، و<span class="comment-type-3">رجَّح</span> القول الثاني قائلًا: «لأنّ هذه الأُمّة هي خير الأمم بنصّ القرآن، فيبعد أن يكون المُقرّبون في غيرها أكثر منها، اللهم إلا أن يُقابل مجموع الأمم بهذه الأُمّة، والظاهر أنّ المُقرّبين من هؤلاء أكثر من سائر الأمم، والله أعلم. والقول الثاني في هذا المقام هو الراجح، وهو أن يكون المراد بقوله: <b><span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</span></b> أي: من صدر هذه الأُمّة، <b><span class="qpc-hafs">﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</span></b> أي: من هذه الأُمّة».</p><p>ونقل <u>ابنُ عطية</u> (٨/١٩٢-١٩٣) رواية «عن عائشة أنها تأوَّلت أنّ الفريقين في أُمّة كلّ نبي هي في الصدر ثُلّة، وفي آخر الأمة قليل».</div></p></div>",footnotes:1:أخرجه الطبراني في مسند الشاميين ١/٢٩٨ (٥٢٠)، وابن عساكر في تاريخه ٤٠/٢٢٩. وأخرج الثعلبي ٩/٢١١-٢١٢ نحوه، والبغوي في تفسيره ٨/١٦ موقوفًا على عروة بن رويم.<span class=comment-ref>٦٤٢٣</span> (١٤/١٨١)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٢٣</span> ذكر <u>ابنُ كثير</u> (١٣/٣٥٣) هذا الحديث من رواية ابن عساكر بسنده عن هشام بن عمار، عن عبد ربه بن صالح، عن عروة بن رويم، عن جابر بن عبد الله ﵁ مرفوعًا، ثم انتقده قائلًا: "هكذا أورده في ترجمة عروة بن رويم، إسنادًا ومتنًا، ولكن في إسناده نظر".</div></p><p><div></p><p><p><span class="item-no">٧٤٨٤١<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: لَمّا نَزَلَتْ: <span class="qpc-hafs">﴿ثلة من الأولين وقليل من الآخرين﴾</span> شقّ ذلك على المسلمين؛ فنَزَلَتْ: <span class="qpc-hafs">﴿ثلة من الأولين وثلة من الآخرين﴾</span> فقال: أنتم ثلث أهل الجنة، بل أنتم نصف أهل الجنة، وتُقاسِمونهم النصف الباقي[[أخرجه أحمد ١٥/٣٨ (٩٠٨٠).</p><p>إسناده ليّن؛ فيه شريك بن عبد الله النخعي القاضي، قال عنه ابن حجر في التقريب (٢٧٨٧): «صدوق يخطئ كثيرًا، تغيّر حفظه منذ ولي القضاء بالكوفة».|2:عزاه السيوطي إلى ابن مردويه.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه الثعلبي ٩/٢٠٣.|5:أخرجه الفريابي -كما في الفتح ٨/٦٢٦-، وعبد بن حميد -كما في تغليق التعليق ٤/٣٣٥-، وابن جرير ٢٢/٣٣٠.|6:تفسير مقاتل بن سليمان ٤/٢١٦.|7:عزاه السيوطي إلى ابن المنذر.
  56,12,""
  56,13,""
  56,14,""
  56,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَىٰ سُرُرࣲ مَّوۡضُونَةࣲ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>. قال: الموضونة: ما تُوضن بقضبان الفِضّة، عليها سبعون فراشًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ حسّان بن ثابت وهو يقول:</p><p>أعدَدتُ للهيجاء مَوْضُونة فَضفاضة كالنِّهْي{1} بالقاع؟{2}. (١٤/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>، قال: مصفوفة{3}. (١٤/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>، قال: مَرْمُولة{4} بالذّهب{5}. (١٤/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>، قال: يعني: الأسِرّة المُرمّلة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>، قال: المَوْضُونة: المَرْمُولة بالذّهب، المُكلّلة بالجوهر والياقوت{7}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مَوْضُونَةٍ﴾</span>، قال: مَرْمُولة بالذّهب{8}. (١٤/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي عتبة-، مثله{9}. (١٤/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>: الوضْن: التشبيك والنّسج، يقول: وسطها مُشبَّك منسوج{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٦<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿مَوْضُونَةٍ﴾</span> مصفوفة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- قوله: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>، قال: مُشبّكة بالدُّرّ والياقوت{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>: هي المرافق بين الفُرش{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: المَوْضُونة: المُرمّلة؛ وهو أوْثَر الأسِرّة{14}. (١٤/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: طول كلّ سرير ثلاثمائة ذراع، فإذا أراد العبدُ أن يجلس عليها تواضعت، فإذا جلس عليها ارتفعت{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span> كوَضْن الخرز في السّلك، يعني بالمَوْضُون: السُّرر وتشبكها، مُشبّكة أوساطها بقضبان الدُّر والياقوت والزَّبَرْجد{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</span>، قال: المَوْضُونة: المَرْمُولة بالجلد، ذاك الوَضين، منسوجة{17}. (ز)</p></p><p></div></p></div>",footnotes:1:النِّهْيُ والنَّهْي: الموضع الذي له حاجز يَنهى الماء أن يفِيض منه. المحكم لابن سيده (نهي).|2:عزاه السيوطي إلى الطستي، وذكر في مسائل نافع (٢٥٢).|3:أخرجه ابن جرير ٢٢/٢٩٤، والبيهقي في البعث والنشور (٣٤٧). وعزاه السيوطي إلى ابن المنذر.|4:مَرْمُولة بالذهب: مزينة به. لسان العرب (رمل).|5:أخرجه ابن جرير ٢٢/٢٩٢، وهناد (٧٧)، والبيهقي في البعث (٣٣٧، ٣٤٦)، وابن أبي الدنيا في صفة الجنة ٦/٣٥٣ (١٦٣) من طريق عكرمة. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وعبد بن حميد.|6:أخرجه ابن جرير ٢٢/٢٩٢.|7:عزاه السيوطي إلى ابن مردويه.|8:تفسير مجاهد ص٦٤٠، وأخرجه ابن أبي شيبة ١٣/١٣٩، وهناد (٧٥، ٧٦)، وابن جرير ٢٢/٢٩٢، ومن طريق حُصين أيضًا. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه هناد (٧٦).|10:أخرجه ابن جرير ٢٢/٢٩٣، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.|11:تفسير الثعلبي ٩/٢٠٣، وتفسير البغوي ٨/٩.|12:أخرجه ابن جرير ٢٢/٢٩٢، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.|13:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٠-.|14:أخرجه ابن جرير ٢٢/٢٩٣، وبنحوه من طريق أبي هلال. وعزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٢٧٠ من طريق معمر بنحوه.|15:تفسير الثعلبي ٩/٢٠٣.|16:تفسير مقاتل بن سليمان ٤/٢١٧.|17:أخرجه ابن جرير ٢٢/٢٩٣.
  56,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُّتَّكِـِٔینَ عَلَیۡهَا مُتَقَـٰبِلِینَ ۝١٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٦٣<span class="dash">-</span></span> عن أبي إسحاق، قال: في قراءة <span class="name-1">عبد الله</span> -يعني: <span class="name-1">ابن مسعود</span>-: (مُتَّكِئِينَ عَلَيْها ناعِمِينَ){1}. (١٤/١٨٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُّتَّكِـِٔینَ عَلَیۡهَا مُتَقَـٰبِلِینَ ۝١٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٨٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</span>: ما ينظر الرجل منهم في قفا صاحبه، يقول: حِلقًا حِلقًا{2}. (١٤/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</span>، قال: لا ينظر أحدُهم في قفا صاحبه{3}. (١٤/١٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</span> إذا زار بعضُهم بعضًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٨٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</span>، بلغني: أنّ ذلك إذا تزاوروا{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٨٠، ٢٢/٢٩٤.</p><p>وهي قراءة شاذة.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ١٤/٨٠، ٢٢/٢٩٤.|4:تفسير مقاتل بن سليمان ٤/٢١٧.|5:كما في تفسير ابن أبي زمنين ٤/٣٣٧.