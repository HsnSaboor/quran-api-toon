56,15," <q>﴿عَلَىٰ سُرُرࣲ مَّوۡضُونَةࣲ ۝١٥﴾</q> - تفسير ٧٤٨٤٨- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>. قال: الموضونة: ما تُوضن بقضبان الفِضّة، عليها سبعون فراشًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ حسّان بن ثابت وهو يقول: أعدَدتُ للهيجاء مَوْضُونة فَضفاضة كالنِّهْي{1} بالقاع؟{2}. (١٤/١٨٣) ٧٤٨٤٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>، قال: مصفوفة{3}. (١٤/١٨٢) ٧٤٨٥٠- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>، قال: مَرْمُولة{4} بالذّهب{5}. (١٤/١٨٢) ٧٤٨٥١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>، قال: يعني: الأسِرّة المُرمّلة{6}. (ز) ٧٤٨٥٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>، قال: المَوْضُونة: المَرْمُولة بالذّهب، المُكلّلة بالجوهر والياقوت{7}. (١٤/٢٤٨) ٧٤٨٥٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿مَوْضُونَةٍ﴾</q>، قال: مَرْمُولة بالذّهب{8}. (١٤/١٨٣) ٧٤٨٥٤- عن سعيد بن جُبَير -من طريق أبي عتبة-، مثله{9}. (١٤/١٨٣) ٧٤٨٥٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>: الوضْن: التشبيك والنّسج، يقول: وسطها مُشبَّك منسوج{10}. (ز) ٧٤٨٥٦- قال الضَّحّاك بن مُزاحِم: <q>﴿مَوْضُونَةٍ﴾</q> مصفوفة{11}. (ز) ٧٤٨٥٧- عن عكرمة مولى ابن عباس -من طريق يزيد- قوله: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>، قال: مُشبّكة بالدُّرّ والياقوت{12}. (ز) ٧٤٨٥٨- عن عكرمة مولى ابن عباس -من طريق جابر- <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>: هي المرافق بين الفُرش{13}. (ز) ٧٤٨٥٩- عن قتادة بن دعامة -من طريق سعيد- قال: المَوْضُونة: المُرمّلة؛ وهو أوْثَر الأسِرّة{14}. (١٤/١٨٣) ٧٤٨٦٠- قال محمد بن السّائِب الكلبي: طول كلّ سرير ثلاثمائة ذراع، فإذا أراد العبدُ أن يجلس عليها تواضعت، فإذا جلس عليها ارتفعت{15}. (ز) ٧٤٨٦١- قال مقاتل بن سليمان: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q> كوَضْن الخرز في السّلك، يعني بالمَوْضُون: السُّرر وتشبكها، مُشبّكة أوساطها بقضبان الدُّر والياقوت والزَّبَرْجد{16}. (ز) ٧٤٨٦٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿عَلى سُرُرٍ مَوْضُونَةٍ﴾</q>، قال: المَوْضُونة: المَرْمُولة بالجلد، ذاك الوَضين، منسوجة{17}. (ز) ",footnotes:1:النِّهْيُ والنَّهْي: الموضع الذي له حاجز يَنهى الماء أن يفِيض منه. المحكم لابن سيده (نهي).عزاه السيوطي إلى الطستي، وذكر في مسائل نافع (٢٥٢).أخرجه ابن جرير ٢٢/٢٩٤، والبيهقي في البعث والنشور (٣٤٧). وعزاه السيوطي إلى ابن المنذر.مَرْمُولة بالذهب: مزينة به. لسان العرب (رمل).أخرجه ابن جرير ٢٢/٢٩٢، وهناد (٧٧)، والبيهقي في البعث (٣٣٧، ٣٤٦)، وابن أبي الدنيا في صفة الجنة ٦/٣٥٣ (١٦٣) من طريق عكرمة. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وعبد بن حميد.أخرجه ابن جرير ٢٢/٢٩٢.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٠، وأخرجه ابن أبي شيبة ١٣/١٣٩، وهناد (٧٥، ٧٦)، وابن جرير ٢٢/٢٩٢، ومن طريق حُصين أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه هناد (٧٦).أخرجه ابن جرير ٢٢/٢٩٣، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.تفسير الثعلبي ٩/٢٠٣، وتفسير البغوي ٨/٩.أخرجه ابن جرير ٢٢/٢٩٢، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٠-.أخرجه ابن جرير ٢٢/٢٩٣، وبنحوه من طريق أبي هلال. وعزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٢٧٠ من طريق معمر بنحوه.تفسير الثعلبي ٩/٢٠٣.تفسير مقاتل بن سليمان ٤/٢١٧.أخرجه ابن جرير ٢٢/٢٩٣.
56,16," <q>﴿مُّتَّكِـِٔینَ عَلَیۡهَا مُتَقَـٰبِلِینَ ۝١٦﴾</q> - قراءات ٧٤٨٦٣- عن أبي إسحاق، قال: في قراءة عبد الله -يعني: ابن مسعود-: (مُتَّكِئِينَ عَلَيْها ناعِمِينَ){1}. (١٤/١٨٤) <q>﴿مُّتَّكِـِٔینَ عَلَیۡهَا مُتَقَـٰبِلِینَ ۝١٦﴾</q> - تفسير الآية ٧٤٨٦٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</q>: ما ينظر الرجل منهم في قفا صاحبه، يقول: حِلقًا حِلقًا{2}. (١٤/٢٤٨) ٧٤٨٦٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</q>، قال: لا ينظر أحدُهم في قفا صاحبه{3}. (١٤/١٨٤) ٧٤٨٦٦- قال مقاتل بن سليمان: <q>﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</q> إذا زار بعضُهم بعضًا{4}. (ز) ٧٤٨٦٧- قال يحيى بن سلّام: <q>﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</q>، بلغني: أنّ ذلك إذا تزاوروا{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٨٠، ٢٢/٢٩٤. وهي قراءة شاذة.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٤/٨٠، ٢٢/٢٩٤.تفسير مقاتل بن سليمان ٤/٢١٧.كما في تفسير ابن أبي زمنين ٤/٣٣٧.
