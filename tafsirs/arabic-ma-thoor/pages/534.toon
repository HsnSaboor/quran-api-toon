quran[27]{c,v,t}:
  55,68,""
55,69," <q>﴿فِیهِنَّ خَیۡرَ ٰ⁠تٌ حِسَانࣱ ۝٧٠﴾</q> - تفسير ٧٤٦٠١- عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله ﷿: <q>﴿حُورٌ عِينٌ﴾</q> [الواقعة:٢٢]. قال: «حُور: بِيض، عِين: ضخام العيون، شَفر الحوراء بمنزلة جَناح النّسور». وفي لفظ ابن مردويه: «شَفر الجُفون بمنزلة جَناح النّسر». قلتُ: يا رسول الله، أخبِرني عن قوله: <q>﴿كَأَنَّهُمْ لُؤْلُؤٌ مَكْنُونٌ﴾</q> [الطور:٢٤]. قال: «صفاؤهنّ صفاء الدُّر في الأصداف التي لم تمسّه الأيدي». قلت: يا رسول الله، أخبرِني عن قوله: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q>. قال: «خَيْرات الأخلاق، حِسان الوجوه». قلت: يا رسول الله، أخبِرني عن قوله: <q>﴿كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</q> [الصافات:٤٩]. قال: «رِقّتهن كرقَّة الجِلدة التي في داخل البيضة مما يلي القشر». قلتُ: يا رسول الله، أخبِرني عن قوله: <q>﴿عُرُبًا أتْرابًا﴾</q> [الواقعة:٣٧]. قال: «هُنّ اللواتي قُبِضن في دار الدنيا عجائز رُمْصًا{1} شُمْطًا{2}، خلقهنّ الله بعد الكِبر، فجعلهنّ عذارى، عُربًا متعشِّقات مُحبّبات، أترابًا على ميلاد واحد». قلتُ: يا رسول الله، أنساء الدنيا أفضل أم الحُور العين؟ قال: «بل نساء الدنيا أفضل من الحُور العين؛ كفضل الظِّهارَةِ على البِطانة». قلت: يا رسول الله، وبِمَ ذاك؟ قال: «بصلاتهنّ وصيامهنّ وعبادتهنّ الله، ألبس الله وجوههنّ النور، وأجسادهنّ الحرير، بِيض الألوان، خُضر الثياب، صُفر الحلي، مَجامرُهنّ الدُّرّ، وأمشاطهنّ الذهب. يقلن: ألا نحن الخالدات فلا نموت أبدًا، ألا ونحن الناعمات فلا نبأس أبدًا، ألا ونحن المُقيمات فلا نَظْعن أبدًا، ألا ونحن الراضيات فلا نَسخط أبدًا، طُوبى لمن كُنّا له وكان لنا». قلت: يا رسول الله، المرأة منا تتزوج الزوجين والثلاثة والأربعة، ثم تموت، فتدخل الجنة، ويدخلون معها، مَن يكون زوجها؟ قال: «يا أُمّ سلمة، إنها تُخيّر، فتختار أحسنهم خُلقًا، فتقول: أي ربّ، إنّ هذا كان أحسنهم معي خُلقًا في دار الدنيا، فزوّجنيه. يا أُمّ سلمة، ذهب حُسن الخُلق بخير الدنيا والآخرة»{3}. (١٤/١٥٩) ٧٤٦٠٢- عن عبد الله بن مسعود -من طريق مسروق- <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q>: في كلّ خيمة زوجة{4}. (ز) ٧٤٦٠٣- قال جرير بن عبد الله: مختارات{5}. (ز) ٧٤٦٠٤- عن مجاهد بن جبر، <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q>، قال: النساء{6}. (١٤/١٥٨) ٧٤٦٠٥- قال الحسن البصري: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> خيِّرات فاضلات{7}. (ز) ٧٤٦٠٦- عن أبي صالح [باذام] -من طريق إسماعيل- قال: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> عذارى الجنة{8}. (١٤/١٥٨) ٧٤٦٠٧- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> خَيرات الأخلاق، حِسان الوجوه{9}. (١٤/١٥٨) ٧٤٦٠٨- قال إسماعيل بن أبي خالد: عذارى{5}. (ز) ٧٤٦٠٩- قال مقاتل بن سليمان: <q>﴿فِيهِنَّ خَيْراتٌ﴾</q> يعني: في الجنان الأربع <q>﴿حِسانٌ﴾</q> يعني: خَيْرات الأخلاق، حِسان الوجوه{11}. (ز) ٧٤٦١٠- عن الأوزاعي -من طريق أبي عصام العسقلاني- <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q>، قال: لَسْنَ بذَرِبات اللسان{12}، ولا يغَرْنَ، ولا يؤذين{13}. (١٤/١٥٨) ٧٤٦١١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> الخَيرات الحسان: الحُور العين{4}. (ز) <q>﴿فِیهِنَّ خَیۡرَ ٰ⁠تٌ حِسَانࣱ ۝٧٠﴾</q> - آثار متعلقة بالآية ٧٤٦١٢- عن أنس بن مالك، عن النبيِّ ﷺ، قال: «إنّ الحُور العين يتَغنّين في الجنة، يقلن: نحن الخَيرات الحسان، خُبِّئنا لأزواج كرام»{15}. (١٤/١٥٩) ٧٤٦١٣- عن عبد الله بن مسعود -من طريق مسروق- قال: لكل مسلم خَيْرة{16}، ولكل خَيْرة خيمة، ولكل خيمة أربعة أبواب، يدخل عليها كلّ يوم مِن الله تحفة وكرامة وهديّة لم تكُن قبل ذلك، لا مَرِحات، ولا طمّاحات{17}، ولا بَخِرات{18}، ولا ذفِرات{19}، حُور عِين، كأنهنّ بَيضٌ مكنون{20}. (١٤/١٥٨) ",footnotes:1:الرَّمَصُ: هو البياض الذي تَقْطَعه العين ويجتمع في زوايا الأجفان. النهاية (رمص).الشَّمَطُ: بياضُ شعر الرأس يخالط سواده، ولا يقال للمرأة: شيباء، ولكن شمطاء. لسان العرب (شمط).أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، واللفظ له، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥، من طريق عمرو بن هاشم البيروتي، عن سليمان بن أبي كريمة، عن هشام بن حسان، عن الحسن، عن أمه، عن أم سلمة به. وعزاه السيوطي إلى ابن مردويه. قال الطبراني في الأوسط: «لم يروِ هذا الحديثَ عن هشام بن حسان إلا سليمان بن أبي كريمة، تفرّد به عمرو بن هاشم». وقال ابن الجوزي في العلل المتناهية ٢/١٦١ (١٠٧٧): «هذا حديث لا يصِحّ». وقال الضياء المقدسي في صفة الجنة ص١٢٤ (١١٩): «لا أعلمه رُوي إلا من طريق سليمان بن أبي كريمة، وفيه كلام». وقال ابن القيم في حادي الأرواح ص٢٢٩: «تفرد به سليمان بن أبي كريمة، ضعّفه أبو حاتم، وقال ابن عدي: عامة أحاديثه مناكير، ولم أر للمتقدمين فيه كلامًا. ثم ساق هذا الحديث من طريقه، وقال: لا يُعرف إلا بهذا السند». وقال ابن مفلح في الآداب الشرعية ٢/٢٠٧: «في إسناده سليمان بن أبي كريمة، وهو ضعيف». وقال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «فيه سليمان بن أبي كريمة، ضعّفه أبو حاتم، وابن عدي».أخرجه ابن جرير ٢٢/٢٦٢.تفسير الثعلبي ٩/١٩٥.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٩/١٩٤.أخرجه ابن أبي شيبة ١٣/٣٣٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٦٢، كذلك من طريق سعيد، وأبي العوام بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٩٥.تفسير مقاتل بن سليمان ٤/٢٠٥.ذَرِبَة: صخّابة، حديدة، سَلِيطة اللسان، فاحِشَة، طويلة اللسان. وذَرَبُ اللسان: حِدَّتُه. لسان العرب (ذرب).أخرجه ابن المبارك في الزهد (١٥٣٩).أخرجه ابن جرير ٢٢/٢٦٢.أخرجه ابن أبي الدنيا في صفة الجنة ص١٨٦ (٢٤٩)، من طريق إسماعيل بن عمر، عن ابن أبي ذئب، عن ابن عبد الله بن رافع، عن بعض ولد أنس بن مالك، عن أنس بن مالك به. وأخرجه ابن أبي شيبة ٧/٣٢ (٣٣٩٨٨)، من طريق شبابة بن سوار، عن ابن أبي ذئب، عمن سمع أنسًا به. وسنده ضعيف؛ لجهالة الراوي عن أنس بن مالك.الخَيْرَة: الفاضلة من كل شيء، جمعها الخَيْرات. التاج (خير).امرأة طمّاحة: تَكُرُّ بنظرها يمينًا وشمالًا إلى غير زوجها. لسان العرب (طمح).البَخَر: تَغَيُّر رِيح الفم. النهاية (بخر).الدَّفْر -بالمهملة-: النَّتَن خاصة. وأما بالمعجمة والتحريك: فإنه يعم شدة ذكاء الرائحة؛ طيبة كانت أو خبيثة. التاج (دفر)، (ذفر).أخرجه ابن أبي شيبة ١٣/٣٣٣، وابن أبي الدنيا في صفة الجنة (٣٢٠). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه. وعزاه السيوطي إلى ابن مردويه مرفوعًا أيضًا.
  55,70,""
55,71," <q>﴿حُورࣱ﴾</q> - تفسير ٧٤٦١٤- عن أنس بن مالك، قال: قال رسول الله ﷺ: «لما أُسري بي دخلتُ الجنة، موضعًا يسمى: البَيْدَخ{1}، عليه خيام اللؤلؤ والزّبَرْجَد الأخضر والياقوت الأحمر، فنُوديتُ: السلام عليك، يا رسول الله. فقلتُ: يا جبريل، ما هذا النداء؟ قال: هؤلاء المقصورات في الخِيام، استأذَنّ ربّهنّ في السلام عليك، فأَذِن لهنّ، فطَفِقنَ يقُلنَ: نحن الراضيات فلا نسخط أبدًا، ونحن المُقيمات -وفي لفظ: الخالدات- فلا نَظْعن أبدًا». وقرأ رسول الله ﷺ هذه الآية: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>{2}. (١٤/١٦١) ٧٤٦١٥- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿حُورٌ﴾</q>: بِيض{3}. (١٤/١٦١) ٧٤٦١٦- عن عبد الله بن عباس -من طريق عطاء- قال: الحُور: سُود الحَدَق{4}. (١٤/١٦٢) ٧٤٦١٧- عن مجاهد بن جبر -من طريق منصور- قال: <q>﴿حُورٌ﴾</q> النساء{5}. (ز) ٧٤٦١٨- عن مجاهد بن جبر -من طريق منصور- قال: الحُور: البِيض، قلوبهم وأنفسهم وأبصارهم{5}. (ز) ٧٤٦١٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿حُورٌ﴾</q>: الحَوراء: العَيناء الحسناء{5}. (ز) ٧٤٦٢٠- عن أبي صالح [باذام] -من طريق إسماعيل- قال: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q> عذارى الجنة{8}. (ز) ٧٤٦٢١- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿حور مقصورات في الخيام﴾</q>، قال: الحُور: السُّود الحَدَق{9}. (ز) ٧٤٦٢٢- قال مقاتل بن سليمان: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>، يعني بالحُور: البيضاء{10}. (ز) ٧٤٦٢٣- عن سفيان [الثوري] -من طريق مهران-: الحَوَر: سواد في بياض{5}. (ز) <q>﴿مَّقۡصُورَ ٰ⁠تࣱ﴾</q> - تفسير ٧٤٦٢٤- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿مَقْصُوراتٌ﴾</q>: محبوسات{12}. (١٤/١٦١) ٧٤٦٢٥- عن أبي العالية الرِّياحيّ -من طريق الربيع- <q>﴿مَقْصُوراتٌ﴾</q>: محبوسات في الخيام{13}. (ز) ٧٤٦٢٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿مَقْصُوراتٌ﴾</q> لا يَخرجن من بيوتهنّ{14}. (١٤/١٦٢) ٧٤٦٢٧- عن مجاهد بن جبر -من طريق منصور- قال: <q>﴿مَقْصُوراتٌ﴾</q> مقصورات قلوبهنّ وأبصارهنّ وأنفسهنّ على أزواجهنّ في خيام اللؤلؤ، لا يُرِدْن غيرهم{15}. (١٤/١٦٢) ٧٤٦٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿مَقْصُوراتٌ﴾</q>: محبوسات، قصرن طرفهن وأنفسهن على أزواجهن{16}. (ز) ٧٤٦٢٩- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- قال: <q>﴿مَقْصُوراتٌ فِي الخِيامِ﴾</q> محبوسات في خيام اللؤلؤ{17}. (١٤/١٦٢) ٧٤٦٣٠- عن الحسن البصري -من طريق أبي رجاء- قال: <q>﴿مَقْصُوراتٌ﴾</q> محبوسات، ليس بطوّافات في الطُّرق{18}. (١٤/١٦٢) ٧٤٦٣١- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿مقصورات﴾</q>، قال: محبوسات{19}. (ز) ٧٤٦٣٢- عن الربيع [بن أنس] -من طريق ابن يمان، عن أبي جعفر- قال: <q>﴿مَقْصُوراتٌ﴾</q> محبوسات في الخِيام{13}. (ز) ٧٤٦٣٣- عن الربيع [بن أنس] -من طريق عبيد الله وابن اليمان، عن أبي جعفر- قال: <q>﴿مَقْصُوراتٌ﴾</q> قُصِر طَرفهنّ على أزواجهنّ{21}. (ز) ٧٤٦٣٤- قال مقاتل بن سليمان: <q>﴿مَقْصُوراتٌ﴾</q> و[يعني] بالمقصورات: المحبوسات على أزواجهنّ{10}٦٤٠٧. (ز) ٦٤٠٧ اختُلف في قوله: <q>﴿مقصورات﴾</q> على قولين: الأول: قُصرن على أزواجهنّ فلا يُرِدن غيرهم. الثاني: محبوسات في الخيام. وقد ذكر ابنُ جرير (٢٢/٢٦٧) القولين، ثم رجّح العموم، فقال: «والصواب من القول في ذلك عندنا أن يُقال: إنّ الله -تبارك وتعالى- وصفهنّ بأنهنّ مقصورات في الخيام، والقصر: هو الحبس، ولم يخصّص وصفهنّ بأنهنّ محبوسات على معنًى من المعنيين اللذين ذكرنا دون الآخر، بل عمّ وصفهن بذلك، والصواب أن يعمّ الخبر عنهنّ بأنهنّ مقصورات في الخيام على أزواجهنّ فلا يُردن غيرهم، كما عمّ ذلك». <q>﴿فِی ٱلۡخِیَامِ ۝٧٢﴾</q> - تفسير ٧٤٦٣٥- عن الضَّحّاك بن مُزاحِم، قال: كان ابن مسعود يُحَدِّث عن نبيِّ الله ﷺ أنه قال: «هي الدُّرّ المُجَوّف». يعني: الخيام في قوله: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>{23}. (١٤/١٦٣) ٧٤٦٣٦- عن أبي مِجلز، أن رسول الله ﷺ قال في قول الله: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>: «دُرّ مُجَوّف»{24}. (١٤/١٦٤) ٧٤٦٣٧- عن عمر بن الخطاب -من طريق أبي الأَحوص- قال: أتدرون ما <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>؟ قال: الخيام دُرّ مُجَوّف{25}. (١٤/١٦٣) ٧٤٦٣٨- عن عبد الله بن مسعود -من طريق أبي الأَحوص- قال: <q>﴿فِي الخِيامِ﴾</q> الدُّرّ المُجَوّف{26}. (١٤/١٦٤) ٧٤٦٣٩- قال عبد الله بن مسعود: لكلّ زوجة خيمةٌ مِن ياقوت أو لؤلؤة، طولها ستون ميلًا{27}. (ز) ٧٤٦٤٠- عن عبد الله بن عباس -من طريق محمد- <q>﴿فِي الخِيامِ﴾</q>، قال: خيام اللؤلؤ، والخيمة من لؤلؤة واحدة مُجَوّفة، أربعة فراسخ في أربعة فراسخ، لها أربعة آلاف مِصراع من ذهب{28}. (١٤/١٦٣) ٧٤٦٤١- عن قتادة، في قوله: <q>﴿فِي الخِيامِ﴾</q>: ذُكر لنا: أنّ ابن عباس كان يقول: الخَيمة دُرّة مُجَوّفة، فرسخٌ في فرسخٍ، لها أربعة آلاف باب من ذهب{29}. (ز) ٧٤٦٤٢- عن عبد الله بن عباس، <q>﴿فِي الخِيامِ﴾</q>، قال: الخيمة ميل في ميل، والميل ثلث الفرسخ{30}. (ز) ٧٤٦٤٣- عن عمرو بن ميمون الأَوْدي -من طريق حرب- قال: الخَيمة دُرّة مُجَوّفة{31}. (١٤/١٦٦) ٧٤٦٤٤- عن عمر بن ميمون -من طريق حَزْن بن بِشر- في قوله تعالى: <q>﴿مقصورات في الخيام﴾</q>: خَيمة مِن لؤلؤة واحدة، قصورها وأبوابها منها{32}. (ز) ٧٤٦٤٥- عن سعيد بن جُبَير -من طريق موسى- قال: <q>﴿فِي الخِيامِ﴾</q> دُرّ مُجَوّف{33}. (ز) ٧٤٦٤٦- عن مجاهد بن جبر -من طريق منصور- قال: الخَيمة دُرّة مُجَوّفة{34}. (١٤/١٦٦) ٧٤٦٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿فِي الخِيامِ﴾</q> الخيام: اللؤلؤ والفِضة، كما يُقال، والله أعلم{35}. (ز) ٧٤٦٤٨- عن عكرمة مولى ابن عباس -من طريق محمد بن مروان- قال: <q>﴿فِي الخِيامِ﴾</q> دُرّ مُجَوّف{36}. (١٤/١٦٦) ٧٤٦٤٩- عن الضَّحّاك بن مُزاحِم -من طريق سلمة-، مثله{37}. (١٤/١٦٦) ٧٤٦٥٠- عن الحسن البصري -من طريق أبي رجاء- قال: <q>﴿فِي الخِيامِ﴾</q> الخيام: الدُّرّ المُجَوّف{38}. (١٤/١٦٢) ٧٤٦٥١- عن خُلَيد العَصَريّ -من طريق قتادة- قال: لقد ذُكر لي: أنّ الخيمة لؤلؤة مُجَوّفة، لها سبعون مِصراعًا، كلّ ذلك من دُرّ{33}. (ز) ٧٤٦٥٢- عن محمد بن كعب القُرَظيّ، <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>، قال: في الحِجال{40}. (١٤/١٦٧) ٧٤٦٥٣- عن قتادة بن دعامة -من طريق سعيد-: كان يُقال: مسكن المؤمن في الجنة يسير الراكب الجواد فيه ثلاث ليال، وأنهاره وجنانه وما أعدّ الله له مِن الكرامة{29}. (ز) ٧٤٦٥٤- عن محمد بن جُحادَةَ، في قول الله ﷾: <q>﴿حور مقصورات في الخيام﴾</q>، قال: الخَيمة دُرّة، فرسخٌ في فرسخٍ، عليها أربعة ألف مِصراع من ذهب{42}. (ز) ٧٤٦٥٥- عن الربيع بن أنس -من طريق أبي جعفر- قال: <q>﴿فِي الخِيامِ﴾</q> في الحِجال{43}. (ز) ٧٤٦٥٦- قال مقاتل بن سليمان: <q>﴿فِي الخِيامِ﴾</q> يعني: الدُّرّ المُجَوّف، الدُّرّة الواحدة مثل القصر العظيم، جوفاء على قدر ميل في السماء، طولها فرسخ، وعرضها فرسخ، لها أربعة آلاف مِصراع من ذهب، فذلك قوله تعالى: <q>﴿والمَلائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِن كُلِّ بابٍ﴾</q> [الرعد:٢٣]{10}. (ز) ٧٤٦٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>، يُقال: خيامهم في الجنة من لؤلؤ{29}. (ز) <q>﴿فِی ٱلۡخِیَامِ ۝٧٢﴾</q> - آثار متعلقة بالآية ٧٤٦٥٨- عن أبي موسى الأشعري، عن النَّبِيّ ﷺ، قال: «الخَيمة دُرّة مُجَوّفة، طولها في السماء ستون ميلًا، في كلّ زاوية منها للمؤمن أهلٌ لا يراهم الآخرون، يطوف عليهم المؤمن»{46}. (١٤/١٦٤) ٧٤٦٥٩- عن أبي الدّرداء، قال: الخَيمة لؤلؤة واحدة، لها سبعون بابًا من دُرّ{47}. (١٤/١٦٣) ٧٤٦٦٠- عن أبي هريرة -من طريق أبي المُهَزَّم- قال: دار المؤمن في الجنة من لؤلؤة، فيها أربعون بيتًا، في وسطها شجرة تُنبِت الحُلَل، فيأتيها، فيأخذ بأصبعه سبعين حُلّة مُمنطقَة{48} باللؤلؤ والمرجان{49}. (١٤/١٦٦) ٧٤٦٦١- عن حِبّان بن أبي جَبَلة، قال: إنّ نساء أهل الدنيا إذا دَخلن الجنة فُضِّلن على الحور العين؛ بأعمالهنَّ في الدنيا{50}. (١٤/١٦٧) <q>﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾</q> - تفسير ٧٤٦٦٢- عن عامر الشعبي -من طريق رجل- <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>، قال: منذ أُنشِئن{51}. (١٤/١٦٧) ٧٤٦٦٣- قال مقاتل بن سليمان: ثم قال: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q> لأنهنّ خُلقن في الجنة، يعني: لم يطأهنّ إنسٌ قبل أهل الجنة، <q>﴿ولا جان﴾</q> يعني: ولا جنِّي{10}. (ز) ",footnotes:1:جاء في مسند أحمد (١٣٦٩٨) من حديث أنس: أنه اسم نهر في الجنة.أخرجه البيهقي في البعث والنشور ص٢١٥ (٣٤٠)، والثعلبي ٩/١٩٦، من طريق علي بن أحمد بن عبدان، عن أحمد بن عبيد، عن الكديمي، عن حبان بن هلال، عن سليمان بن المغيرة، عن ثابت، عن أنس بن مالك به. وسنده ضعيف؛ فيه محمد بن يونس الكديمي، قال عنه ابن حجر في تقريب التهذيب (٦٤١٩): «ضعيف».أخرجه ابن جرير ٢٢/٢٦٤، ٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٣٠٣، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٣٣-٣٣٤-، وابن المنذر -كما في الفتح ٨/٦٢٤-.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٧، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٨/٤٦١ (٣٥١٩٤)، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٨٣ (٣١٢)-.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣. والحَدَق: جمع حَدَقة وهي العين. النهاية (حدق).تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٦٤.أخرجه ابن جرير ٢٢/٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٦٦.تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٦٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٦٥ وبنحوه من طريق أبي يحيى، وابن أبي شيبة ١٣/٥٦٨-٥٦٩، وهناد (١٧).أخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤-.أخرجه هناد (١٥)، وابن جرير ٢٢/٢٦٧ من طريق عبيد بنحوه.أخرجه ابن جرير ٢٢/٢٦٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.أخرجه ابن جرير ٢٢/٢٦٦.أخرجه ابن جرير ٢٢/٢٦٥.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧٢، قال: حدثت عن الحسين، عن أبي معاذ، عن عبيد، عن الضَّحّاك، عن ابن مسعود به. وعزاه السيوطي إلى ابن أبي حاتم. وسنده ضعيف؛ لجهالة الراوي عن الحسين، والضحاك لم يدرك ابن مسعود.أخرجه ابن جرير ٢٢/٢٧١، وابن أبي شيبة ١٣/١٣٤مرسلًا.أخرجه ابن جرير ٢٢/٢٦٨-٢٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٦٨، ومسدد -كما في المطالب العالية (٤١٣٢)-، وابن أبي شيبة ١٣/١٣٤.تفسير الثعلبي ٩/١٩٦.أخرجه ابن أبي شيبة ١٣/١٣٣-١٣٥، وابن أبي الدنيا في صفة الجنة (٣٢٨)، وابن جرير ٢٢/٢٦٨-٢٦٩، وبنحوه من طريق مجاهد، وعكرمة، والبيهقي في البعث (٣٣٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٧١.أخرجه عبد بن حميد -كما في الفتح ٨/٦٢٥-.أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٥، وهناد (٥٢).أخرجه أبو نعيم في حلية الأولياء ٤/١٤٩.أخرجه ابن جرير ٢٢/٢٦٩.أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٦، وهناد (١٧، ١٥٤).تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٧٠، ٢٧١، ٢٧٢، من طريق منصور أيضًا.أخرجه ابن أبي شيبة ١٣/١٣٥.أخرجه ابن جرير ٢٢/٢٧٠، وابن أبي شيبة ١٣/١٣٦.أخرجه ابن جرير ٢٢/٢٧١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٦٩.أخرجه ابن جرير ٢٢/٢٦٦ بزيادة: محبوسات، وابن أبي شيبة ١٣/١٣٥.أخرجه ابن جرير ٢٢/٢٧١.أخرجه ابن المبارك في الزهد ١/٤٢١.أخرجه ابن جرير ٢٢/٢٧٠.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧١.أخرجه البخاري ٤/١١٧-١١٨ (٣٢٤٣)، ٦/١٤٥ (٤٨٧٩)، ومسلم ٤/٢١٨٢ (٢٨٣٨).أخرجه عبد الله بن أحمد في زوائد الزهد ص٢٣٣. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.المِنطَق والمِنطقة والنِّطاق: كل ما شُد به وسطه. لسان العرب (نطق).أخرجه ابن أبي شيبة ١٣/١٢٩.أخرجه هناد (٢٣).أخرجه هناد (٢٢).تفسير مقاتل بن سليمان ٤/٢٠٥.
  55,72,""
55,73," <q>﴿مُتَّكِـِٔینَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾</q> - قراءات ٧٤٦٦٤- عن أبي بَكرة، عن النَّبِيّ ﷺ، قرأ: (مُتَّكِئِينَ عَلى رَفارِفَ خُضْرٍ وعَباقِرِيَّ حِسانٍ){1}٦٤٠٨. (١٤/١٦٩) ٦٤٠٨ ذكر ابن جرير (٢٢/٢٧٧ بتصرف) هذا الأثر عن النبي ﷺ، وانتقده مستندًا لضعف السند، واللغة، فقال: «وذُكر عن النبي ﷺ خبر غير محفوظ، ولا صحيح السند (رَفارِفَ خُضْرٍ وعَباقِرِيَّ) بالألف والإجراء، وهذه القراءة لو كانت صحيحة لوجب أن تكون الكلمتان غير مجراتين». وذكر ابنُ عطية (٨/١٨٤) هذه القراءة عن النبي ﷺ، وعن عثمان، وأورد انتقاد الزّجاج والرّماني عليها، فقال: «وغلّط الزّجاج والرّماني هذه القراءة». وذكر ابن عطية عن عثمان ﵁ أنه قرأ ذلك: (عَباقَريَّ) بفتح القاف والياء، ثم علّق بقوله: "وهذا على أن اسم الموضع (عباقر) بفتح القاف، والصحيح في اسم الموضع: (عبقر)، قال الشاعر: كأن صليل المروحين تشذه صليل الزيوف يُنتقدن بعبقرا". ٧٤٦٦٥- عن أبي بكر بن عيّاش، قال: كان زُهير الفُرْقُبيّ -وكان نحويًّا بصريًّا- يقرأ: (رَفارِفَ خُضْرٍ وعَباقِرِيَّ حِسانٍ){2}. (١٤/١٦٩) ٧٤٦٦٦- عن أبي طُعْمة -من طريق ابن لهيعة- يقرأ: (مُتَّكِئِينَ عَلى رَفارِفَ خُضْرٍ){3}. (ز) <q>﴿مُتَّكِـِٔینَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ﴾</q> - تفسير ٧٤٦٦٧- عن علي بن أبي طالب، قال: <q>﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</q> فُضول المحابس{2}. (١٤/١٦٨) ٧٤٦٦٨- عن عبد الله بن عباس -من طريق عطية- <q>﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ وعَبْقَرِيٍّ حِسانٍ﴾</q>، قال: فُضول المحابس، والفُرُش، والبُسط{5}. (١٤/١٦٧) ٧٤٦٦٩- عن عبد الله بن عباس -من طريق علي- <q>﴿رَفْرَفٍ خُضْرٍ﴾</q>، قال: المحابس{6}. (١٤/١٦٨) ٧٤٦٧٠- عن عبد الله بن عباس، قال: <q>﴿رَفْرَفٍ خُضْرٍ﴾</q> الرّفرف: الرياض{2}. (١٤/١٦٩) ٧٤٦٧١- قال سعيد بن جُبَير: <q>﴿رَفْرَفٍ خُضْرٍ﴾</q> الرّفرف: رياض الجنة، <q>﴿خضر﴾</q> مُخضبة{8}٦٤٠٩. (ز) ٦٤٠٩ ذكر ابنُ عطية (٨/١٨٤) أنّ «الرَّفْرَف: ما تدلّى مِن الأَسِرّة مِن غالي الثياب والبُسُط». ونقل قول ابن جُبير في معنى: «الرفرف»، ووجَّهه بقوله: «ووَجْه قول ابن جُبير: أنه مِن رفَّ النَّبت: إذا نعُم وحسُن». ثم رجَّح قائلًا: «والأول أصوب وأبين». ولم يذكر مستندًا. ٧٤٦٧٢- عن مجاهد بن جبر، <q>﴿رَفْرَفٍ خُضْرٍ﴾</q>، قال: فُضول الفُرش{9}. (١٤/١٦٨) ٧٤٦٧٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: الرّفرف: المحابس{10}. (١٤/١٦٨) ٧٤٦٧٤- عن الحسن البصري -من طريق أبي رجاء- <q>﴿رَفْرَفٍ خُضْرٍ﴾</q>، قال: البُسط{11}. (١٤/١٦٨) ٧٤٦٧٥- عن الحسن البصري -من طريق قتادة-: الرفرف: مرافق خُضر{12}. (ز) ٧٤٦٧٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿رَفْرَفٍ خُضْرٍ﴾</q>، قال: محابس خُضر{13}. (١٤/١٦٨) ٧٤٦٧٧- قال محمد بن كعب القُرَظيّ: <q>﴿رَفْرَفٍ خُضْرٍ﴾</q> البُسُط{14}. (ز) ٧٤٦٧٨- عن إسماعيل السُّدِّيّ -من طريق الحسن بن يزيد بن الأصمّ- قال: <q>﴿متكئين على رفرف﴾</q> المحابس{15}. (ز) ٧٤٦٧٩- عن عاصم الحجدري، (رَفْارَفٍ)، قال: وسائد{16}. (١٤/١٦٩) ٧٤٦٨٠- عن محمد بن جُحادَةَ، في قول الله ﷾: <q>﴿مُتَّكِئِينَ عَلى رَفارَفٍ خُضْرٍ﴾</q>، قال: مجالس{17}. (ز) ٧٤٦٨١- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿رفرف خضر﴾</q>، قال: الرّفرف: فُضول الفُرُش والمحابس{18}. (ز) ٧٤٦٨٢- قال مقاتل بن سليمان: <q>﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</q>، يعني: المحابس فوق الفُرش{19}. (ز) ٧٤٦٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</q> الرّفرف: المحابس{12}. (ز) ٧٤٦٨٤- قال سفيان بن عيينة: هي الزّرابي{21}. (ز) ٧٤٦٨٥- عن غَزْوان -من طريق سفيان- <q>﴿رَفْرَفٍ خُضْرٍ﴾</q>، قال: فضول المحابس{22}. (ز) <q>﴿وَعَبۡقَرِیٍّ حِسَانࣲ ۝٧٦﴾</q> - تفسير ٧٤٦٨٦- عن عبد الله بن عباس -من طريق علي- <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q>، قال: الزَّرابِيُّ{23}{6}. (١٤/١٦٨) ٧٤٦٨٧- عن عبد الله بن عباس -من طريق عطية- <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q>، قال: الزّرابي{6}. (١٤/١٦٨) ٧٤٦٨٨- عن عبد الله بن عباس، قال: والعبقري: الزّرابي{2}. (١٤/١٦٩) ٧٤٦٨٩- قال عبد الله بن عباس: <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q>، يعني: الوسائد{27}. (ز) ٧٤٦٩٠- عن عبد الله بن عباس، قال: <q>﴿ولمن خافَ مقام ربه جنتان﴾</q> فذكر فضل ما بينهما، ثُمَّ ذكر <q>﴿ومن دونهما جنتان فَبِأَي آلاء رَبكُما تُكَذِّبانِ مُدْهامّتان﴾</q> قال: خَضْراوان، <q>﴿فيهما عَيْنان نَضّاخَتان﴾</q> وفي تلك <q>﴿تَجْرِيانِ﴾</q>، <q>﴿فيهما فاكِهَة ونَخلٌ ورُمّان﴾</q> وفي تلك <q>﴿مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</q>، <q>﴿فِيهِنَّ خَيْراتٌ حسان﴾</q> وفي تلك <q>﴿قاصِراتُ الطّرفِ لم يَطْمِثهنّ إنْسٌ قبلهم ولا جان﴾</q>، <q>﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</q> وفي تلك <q>﴿مُتَّكِئِينَ عَلى فُرُشٍ بَطائِنُها من إسْتَبْرق﴾</q> قالَ: الدِّيباج، والعبقري: الزّرابي{28}. (١٤/١٧٠) ٧٤٦٩١- قال أبو العالية الرِّياحيّ: <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q> هي الطّنافس المُخْملة إلى الرّقة{21}. (ز) ٧٤٦٩٢- عن سعيد بن جُبَير، قال: <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q> العبقري: عتاق الزّرابي{30}. (ز) ٧٤٦٩٣- عن مجاهد بن جبر -من طريق سفيان- <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q>، قال: الدِّيباج الغليظ{31}. (١٤/١٦٨) ٧٤٦٩٤- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- قال: العبقري: الزّرابي، وهي البُسُط{10}. (١٤/١٦٨) ٧٤٦٩٥- عن الحسن البصري -من طريق أبي رجاء- <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q>، قال: الطَّنافس{33}. (١٤/١٦٨) ٧٤٦٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q>، قال: الزّرابي{34}. (١٤/١٦٨) ٧٤٦٩٧- عن إسماعيل السُّدِّيّ -من طريق الحسن بن يزيد بن الأصمّ- قال: <q>﴿وعبقري حسان﴾</q> الزّرابي{15}. (ز) ٧٤٦٩٨- عن محمد بن جُحادَةَ، في قول الله ﷾: (وعَباقِرِيَّ حِسانٍ)، قال: طَنافس. وكان يقرأها: (وعَباقِرِيَّ){17}. (ز) ٧٤٦٩٩- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿عبقري﴾</q>: الزّرابي{18}. (ز) ٧٤٧٠٠- قال مقاتل بن سليمان: <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q> يعني: الزّرابي، وهي الطّنافس المُخْملة، وهي الحِسان{19}. (ز) ٧٤٧٠١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿وعَبْقَرِيٍّ حِسانٍ﴾</q> العبقري: الطنافس{39}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٢٧٣ (٢٩٨٦) وفيه: <q>﴿رَفْرَفٍ﴾</q>، <q>﴿(وعَبْقَرِيٍّ﴾</q>، وحفص بن عمر في جزء قراءات النبي ص١٥٧ (١١٤)، والثعلبي ٩/١٩٨، من طريق أبي عبد الرحمن عبد الله بن حفص الأرطباني، عن عاصم الجحدري، عن أبي بكرة به. قال ابن جرير في التفسير ٢٢/٢٧٧: «ذُكر عن النبي ﷺ خبر غير محفوظ، ولا صحيح السند». فذكره. وقال: قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع، وعاصم لم يدرك أبا بكرة». وهي قراءة شاذة، تروى أيضًا عن الفرقبي، وابن محيصن، وغيرهما. انظر: المحتسب ٢/٣٠٥، ومختصر ابن خالويه ص١٥١.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٦٢ (١٤٤)-. وهي قراءة شاذة. انظر: المحتسب ٢/٣٠٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٧٤-٢٧٥، وبنحوه من طريق عنترة، وابن أبي شيبة ١٣/١٣٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن حجر في تغليق التعليق ٤/٦٣ بسنده إلى أبي نعيم عن سعيد بن جبير من طريق أبي بشر بلفظ: الرفرف: رياض الجنة، وتفسير البغوي ٧/٤٥٨.أخرجه ابن جرير ٢٢/٢٧٧ مقتصرًا على آخره، وابن أبي شيبة ١٣/١٣٧، وهناد (٨٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٥ مقتصرًا على أوله، وابن أبي شيبة ١٣/١٣٦، وهناد (٨٢).أخرجه ابن جرير ٢٢/٢٧٤ بنحوه، وابن أبي شيبة ١٣/١٣٧، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٣ (١٦٠)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٥.أخرجه عبد الرزاق ٢/٢٦٧، وابن جرير ٢٢/٢٧٥-٢٧٧، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٩٧.أخرجه سعيد بن منصور في سننه -التفسير ٧/٥١٦ (٢١٤٣).عزاه السيوطي إلى ابن المنذر.أخرجه ابن المبارك في الزهد ١/٤٢١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧٥.تفسير الثعلبي ٩/١٩٧، وتفسير البغوي ٧/٤٥٩.أخرجه ابن جرير ٢٢/٢٧٤.الزَّرابي: البُسُط، وقيل: كل ما بُسط واتُّكِئ عليه. لسان العرب (زرب).أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٧٤، ٢٧٦، والبيهقي في البعث والنشور (٣٣٨). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٥-.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/١٩٧، وتفسير البغوي ٧/٤٥٩.أخرجه ابن جرير ٢٢/٢٧٦، وأخرجه ابن حجر في تغليق التعليق ٤/٦٣ بسنده إلى أبي نعيم عن سعيد بن جبير من طريق أبي بشر بلفظ: العبقري: الزرابي. وعزاه ابن حجر في الفتح ٧/٤٦ إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٧٧، وابن أبي شيبة ١٣/١٣٧، وهناد (٨٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٧٥ مقتصرًا على أوله، وابن أبي شيبة ١٣/١٣٦، وهناد (٨٢).أخرجه ابن أبي شيبة ١٣/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٦٧، وابن جرير ٢٢/٢٧٥-٢٧٧، ومن طريق أبي العوام. وعزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه -التفسير ٧/٥١٦ (٢١٤٣).أخرجه ابن المبارك في الزهد ١/٤٢١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه ابن جرير ٢٢/٢٧٧.
