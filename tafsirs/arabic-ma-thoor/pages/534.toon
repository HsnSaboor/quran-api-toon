55,77," <q>﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾</q> - تفسير ٧٤٧٠٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ذِي الجَلالِ والإكْرامِ﴾</q> يقول: ذو العظمة والكبرياء{1}. (ز) ٧٤٧٠٣- قال مقاتل بن سليمان: <q>﴿تَبارَكَ اسْمُ رَبِّكَ ذِي الجَلالِ﴾</q> يعني بالجلال: العظيم، <q>﴿والإكْرامِ﴾</q> يعني: الكريم؛ فلا أكرم منه، يمدح الرّبُّ نفسه -تبارك وتعالى-{2}. (ز) <q>﴿تَبَـٰرَكَ ٱسۡمُ رَبِّكَ ذِی ٱلۡجَلَـٰلِ وَٱلۡإِكۡرَامِ ۝٧٨﴾</q> - آثار متعلقة بالآية ٧٤٧٠٤- عن أنس بن مالك، أنّ رسول الله ﷺ قال: «ألِظّوا بـ: يا ذا الجلال والإكرام»{3}. (١٤/١٧١) ٧٤٧٠٥- عن عبد الله بن عمر، عن النبيِّ ﷺ، قال: «ألِظّوا بـ: يا ذا الجلال والإكرام»{4}. (١٤/١٧١) ٧٤٧٠٦- عن ربيعة بن عامر، سمعتُ رسول الله ﷺ يقول: «ألِظّوا بـ: يا ذا الجلال والإكرام»{5}. (١٤/١٧١) ٧٤٧٠٧- عن أنس بن مالك قال: قال رسول الله ﷺ: «ألِظّوا بـ: يا ذا الجلال والإكرام؛ فإنهما اسمان من أسماء الله العِظام» {6}. (١٤/١٧١) ٧٤٧٠٨- عن معاذ بن جبل، قال: سمع النبيُّ ﷺ رجلًا يقول: يا ذا الجلال والإكرام. قال: «قد استُجيب لك؛ فَسَل»{7}. (١٤/١٧٠) ٧٤٧٠٩- عن ثوبان، قال: كان رسول الله ﷺ إذا انصرف من صلاته استغفر الله ثلاثًا، ثم قال: «اللهم، أنت السلام، ومنك السلام، تباركتَ يا ذا الجلال والإكرام»{8}. (١٤/١٧١) ٧٤٧١٠- عن أنس بن مالك، قال: كنتُ مع رسول الله ﷺ جالسًا في الحلقة، ورجل قائم يصلي، فلمّا ركع وسجد تشهَّد ودعا، فقال في دعائه: اللهم، إني أسألك بأنّ لك الحمد، لا إله إلا أنت وحدك لا شريك لك، المنّان بديع السموات والأرض، يا ذا الجلال والإكرام، يا حيّ يا قيّوم، إني أسألك. فقال النبيُّ ﷺ: «لقد دعا اللهَ باسمه العظيم؛ الذي إذا دُعِي به أجاب، وإذا سُئِل به أعطى»{9}. (١٤/١٧٠) ",footnotes:1:أخرجه ابن جرير ٢٢/٢٧٨.تفسير مقاتل بن سليمان ٤/٢٠٥.أخرجه الترمذي ٦/١٢٧ (٣٨٣٤)، من طريق محمد بن حاتم المكتب، عن أبي بدر شجاع بن الوليد، عن الرحيل بن معاوية، عن الرّقاشي، عن أنس بن مالك به. وأخرجه أيضًا ٦/١٢٩ (٣٨٣٥)، والبزار ١٣/١٨٠ (٦٦٢٥)، من طريق المؤمل، عن حماد بن سلمة، عن حميد، عن أنس به. قال الترمذي: «هذا حديث غريب، وقد رُوي هذا الحديث عن أنس مِن غير هذا الوجه». وقال في الموضع الثاني: «هذا حديث غريب، وليس بمحفوظ، وإنما يُروى هذا عن حماد بن سلمة، عن حميد، عن الحسن البصري، عن النبي ﷺ، وهذا أصح. والمؤمل غلط فيه، فقال: عن حميد، عن أنس، ولا يُتابع فيه». وأورده الدارقطني في العلل ١٢/٢٦ (٢٣٦٥). وقال ابن حجر في الكافي الشاف ص١٦٢ (٧٧): «يزيد ضعيف».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٣٩٦-، من طريق المعافى بن عمران، عن ابن عياش، عن عمر بن محمد بن زيد بن عبد الله بن عمر بن الخطاب، عن أبيه، عن عبد الله بن عمر به. قال ابن حجر في الكافي الشاف ص١٦٢: «إسناده ضعيف».أخرجه أحمد ٢٩/١٣٨ (١٧٥٩٦)، والحاكم ١/٦٧٦ (١٨٣٦)، من طريق عبد الله بن المبارك، عن يحيى بن حسان، عن ربيعة بن عامر به. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن عساكر في تاريخه ١٨/٦٧: «قال ابن منده: هذا حديث غريب، لم نكتبه إلا من هذا الوجه». وأورده الألباني في الصحيحة ٤/٤٩ (١٥٣٦).عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ٣٦/٣٤٧-٣٤٨ (٢٢٠١٧)، ٣٦/٣٧٩ (٢٢٠٥٦)، والترمذي ٦/١٣١-١٣٢ (٣٨٣٧-٣٨٣٨)، من طريق سعيد الجريري، عن أبي الورد بن ثمامة، عن اللجلاج، عن معاذ بن جبل به. قال الترمذي: «هذا حديث حسن». وأورده ابن أبي حاتم في علل الحديث ٥/٣٨٢ (٢٠٦٣). وقال الألباني في الضعيفة ٧/٤٢٥ (٣٤١٦)، ١٠/٢٤ (٤٥٢٠): «ضعيف».أخرجه مسلم ١/٤١٤ (٥٩١).أخرجه أحمد ١٩/٢٣٨ (١٢٢٠٥)، وابن ماجه (٣٨٥٨)، من طريق وكيع، عن أبي خزيمة، عن أنس بن سيرين، عن أنس بن مالك به. وأخرجه أحمد ٢٠/٦١ (١٢٦١١)، ٢١/١٩٢ (١٣٥٧٠)، وأبو داود ٢/٦١٢-٦١٣ (١٤٩٥)، والنسائي ٣/٥٢ (١٣٠٠)، وابن حبان ٣/١٧٥-١٧٦ (٨٩٣)، والحاكم ١/٦٨٣ (١٨٥٦)، من طريق خلف بن خليفة، عن حفص بن عمر، عن أنس به. قال الترمذي: «هذا حديث غريب من هذا الوجه، وقد روي من غير هذا الوجه عن أنس». وقال الهيثمي في المجمع ١٠/١٥٦ (١٧٢٥٨): «رواه أحمد، والطبراني في الصغير، ورجال أحمد ثقات، إلا أن ابن إسحاق مدلّس، وإن كان ثقة». وقال الألباني في صحيح أبي داود ٥/٢٣٣ (١٣٤٢): «حديث صحيح». وأورده في الصحيحة ٧/١٢٠٩ (٣٤١١).
  55,78,""
56,1," مقدمة السورة ٧٤٧١١- عن عبد الله بن عباس -من طرق- قال: نَزَلَتْ سورة الواقعة بمكة{1}. (١٤/١٧٣) ٧٤٧١٢- عن عبد الله بن الزبير، مثله{2}. (١٤/١٧٣) ٧٤٧١٣- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونَزَلَتْ بعد سورة طه{3}. (ز) ٧٤٧١٤- عن عكرمة مولى ابن عباس= (ز) ٧٤٧١٥- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز) ٧٤٧١٦- عن قتادة بن دعامة -من طريق همام-: مكّيّة{5}. (ز) ٧٤٧١٧- عن محمد بن شهاب الزُّهريّ: مكّيّة، ونَزَلَت بعد سورة طه{6}. (ز) ٧٤٧١٨- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٧٤٧١٩- قال مقاتل بن سليمان: سورة الواقعة مكّيّة، عددها ست وتسعون آية كوفي{8}٦٤١٠. (ز) ٦٤١٠ ذكر ابنُ عطية (٨/١٨٧) أنّ سورة الواقعة «مكية بإجماعٍ ممن يُعتدّ بقوله من المفسرين». ثم نقل قولًا ولم ينسبه، أنّ «فيها آيات مدنية، أو مما نزل في السَّفر». ثم انتقده -مستندًا إلى عدم ثبوته- قائلًا: «وهذا كله غير ثابت». ٧٤٧٢٠- عن عبد الله بن مسعود، سمعتُ رسول الله ﷺ يقول: «مَن قرأ سورة الواقعة كلَّ ليلة لم تُصِبْه فاقةٌ أبدًا»{9}٦٤١١. (١٤/١٧٣) ٦٤١١ علَّق ابنُ عطية (٨/١٨٧) على هذا الحديث بقوله: «فيها ذكر القيامة وحظوظ الناس في الآخرة، وفَهْمُ ذلك غنًى لا فقر معه، مَن فَهِمَه شُغِل بالاستعداد». ٧٤٧٢١- عن عبد الله بن عباس، قال: قال أبو بكر ﵁: يا رسول الله، قد شِبْتَ! قال: «شيَّبتني هود، والواقعة، والمرسلات، و<q>﴿عم يتساءلون﴾</q>، و<q>﴿إذا الشمس كُوِّرت﴾</q>»{10}. (١٤/١٧٤) ٧٤٧٢٢- عن مَسروق بن الأجْدع الهَمداني -من طريق هلال- قال: مَن أراد أن يعلم نبأ الأوّلين والآخرين، ونبأ أهل الدنيا وأهل الآخرة، ونبأ الجنة والنار؛ فليقرأ: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q>{11}. (١٤/١٧٥، ٢٤٦) ٧٤٧٢٣- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك، وأبي صالح- في قوله: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q> قال: الساعة، <q>﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</q> يقول: مَن كَذّب بها في الدنيا فإنه لا يُكذّب بها في الآخرة إذا وقَعتْ، <q>﴿خافِضَةٌ رافِعَةٌ﴾</q> قال: القيامة خافضة. يقول: خَفَضَتْ فأسمَعَت الأدنى، ورَفَعتْ فأسمَعَت الأقصى، كان القريب والبعيد فيها سواء. قال: وخَفَضَتْ أقوامًا قد كانوا في الدنيا مرتفعين، ورَفَعتْ أقوامًا حتى جَعلتْهم في أعلى عِلّيّين، <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q> قال: هي الزّلْزلة، <q>﴿وبُسَّتِ الجِبالُ بَسًّا فَكانَتْ هَباءً مُنْبَثًّا﴾</q> قال الحكم: قال السُّدِّيّ: قال علي: هذا الهَرَج، هَرَج الدّواب الذي يُحرّك الغبار، <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q> قال: العباد يوم القيامة على ثلاثة منازل، <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q> هم الجمهور جماعة أهل الجنة، <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q> هم أصحاب الشمال، يقول: ما لهم وما أعدّ لهم، <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q> هم مثل النّبيّين، والصِّدِّيقين، والشهداء بالأعمال من الأوّلين والآخرين، <q>﴿أُولَئِكَ المُقَرَّبُونَ﴾</q> قال: هم أقرب الناس من دار الرحمن مِن بُطْنان الجنة، وبُطْنانها: وسطها، <q>﴿فِي جَنّاتِ النَّعِيمِ﴾</q>، <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ عَلى سُرُرٍ مَوْضُونَةٍ﴾</q> قال: المَوْضُونة: المَرْمُولة بالذّهب، المُكلّلة بالجوهر والياقوت، <q>﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</q> قال ابن عباس: ما ينظر الرجل منهم في قفا صاحبه، يقول: حِلقًا حِلقًا، <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q> قال: خَلَقهم الله في الجنة كما خَلَق الحُور العين، لا يموتون، لا يَشيبون، ولا يَهْرمون، <q>﴿بِأَكْوابٍ وأَبارِيقَ﴾</q> والأكواب: التي ليس لها آذان مثل الصّواع، والأباريق: التي لها الخراطيم والأعناق، <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q> قال: الكأس من الخمر بعينها، ولا يكون كأس حتى يكون فيها الخمر، فإذا لم يكن فيها خمر فإنما هو إناء، والمَعين يقول: مِن خمرٍ جاري، <q>﴿لا يُصَدَّعُونَ عَنْها﴾</q> عن الخمر، <q>﴿ولا يُنْزِفُونَ﴾</q> لا تَذهب بعقولهم، <q>﴿وفاكِهَةٍ مِمّا يَتَخَيَّرُونَ﴾</q> يقول: مما يشتهون، <q>﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</q> يقول: يجيئهم الطير حتى يقع، فيَبسط جناحه، فيأكلون منه ما اشتَهوا نضيجًا لم تُنضجه النار، حتى إذا شَبعوا منه طار، فذَهب كما كان، <q>﴿وحُورٌ عِينٌ﴾</q> قال: الحُور: البِيض، والعِين: العظام الأعين، حِسان، <q>﴿كَأَمْثالِ اللُّؤْلُؤِ﴾</q> قال: كبياض اللؤلؤ التي لم تمسّهن الأيدي ولا الدّهر، <q>﴿المَكْنُونِ﴾</q> الذي في الأصداف، <q>﴿جَزاءً بِما كانُوا يَعْمَلُونَ لا يَسْمَعُونَ فِيها لَغْوًا﴾</q> قال: اللغو: الحَلف: لا واللهِ، وبلى واللهِ، <q>﴿ولا تَأْثِيمًا﴾</q> قال: لا يَأْثمون، <q>﴿إلّا قِيلًا سَلامًا سَلامًا﴾</q> يقول: التسليم منهم وعليهم، بعضهم على بعض، قال: هؤلاء المُقرّبون. ثم قال: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</q> وما أعدّ لهم! <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q> والمخضود: المُوقَر الذي لا شوك فيه، <q>﴿وطَلْحٍ مَنضُودٍ وظِلٍّ مَمْدُودٍ﴾</q> يقول: ظِلّ الجنة لا ينقطع، ممدود عليهم أبدًا، <q>﴿وماءٍ مَسْكُوبٍ﴾</q> يقول: مصبوب، <q>﴿وفاكِهَةٍ كَثِيرَةٍ لا مَقْطُوعَةٍ﴾</q> قال: لا تَنقطع حينًا وتجيء حينًا مثل فاكهة الدنيا، <q>﴿ولا مَمْنُوعَةٍ﴾</q> كما تُمنع في الدنيا إلا بثمن، <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q> يقول: بعضها فوق بعض. ثم قال: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q> قال: هؤلاء نساء أهل الجنة، وهؤلاء العُجُزُ الرُّمْصُ{12}، يقول: خَلقَهم خَلْقًا، <q>﴿فَجَعَلْناهُنَّ أبْكارًا﴾</q> يقول: عذارى، <q>﴿عُرُبًا﴾</q> والعُرُب: المُتحبّبات إلى أزواجهنّ، <q>﴿أتْرابًا﴾</q> المُصطحبات اللاتي لا تَغَرْن، <q>﴿لِأَصْحابِ اليَمِينِ ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> يقول: طائفة من الأوّلين، وطائفة من الآخرين، <q>﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</q> ما لهم وما أعدّ لهم، <q>﴿فِي سَمُومٍ﴾</q> قال: فَيح نار جهنم، <q>﴿وحَمِيمٍ﴾</q> الماء الحارّ الذي قد انتهى حرّه، فليس فوقه حرّ، <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q> قال: من دُخان جهنم، <q>﴿لا بارِدٍ ولا كَرِيمٍ إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</q> قال: مشركين جبّارين، <q>﴿وكانُوا يُصِرُّونَ﴾</q> يُقيمون، <q>﴿عَلى الحِنْثِ العَظِيمِ﴾</q> قال: على الإثم العظيم. قال: هو الشّرك، <q>﴿وكانُوا يَقُولُونَ أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا﴾</q> إلى قوله: <q>﴿أوَآباؤُنا الأَوَّلُونَ﴾</q> قال: <q>﴿قُلْ﴾</q> يا محمد: <q>﴿إنَّ الأَوَّلِينَ والآخِرِينَ لَمَجْمُوعُونَ إلى مِيقاتِ يَوْمٍ مَعْلُومٍ﴾</q> قال: يوم القيامة، <q>﴿ثُمَّ إنَّكُمْ أيُّها الضّالُّونَ المُكَذِّبُونَ﴾</q> قال: المشركون المُكذّبون <q>﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ﴾</q> قال: والزَّقوم إذا أكَلوا منه غَصُّوا، والزَّقوم شجرة، <q>﴿فَمالِئُونَ مِنها البُطُونَ﴾</q> قال: يَملؤون من الزَّقوم بطونهم، <q>﴿فَشارِبُونَ عَلَيْهِ مِنَ الحَمِيمِ﴾</q> يقول: على الزَّقوم الحميم، <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q> هي الرّمال لو مَطرتْ عليها السماء أبدًا لم يُر فيها مستنقع، <q>﴿هَذا نُزُلُهُمْ يَوْمَ الدِّينِ﴾</q> كرامة يوم الحساب، <q>﴿نَحْنُ خَلَقْناكُمْ فَلَوْلا تُصَدِّقُونَ﴾</q> يقول: أفلا تُصدِّقون، <q>﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</q> يقول: هذا ماء الرجل، <q>﴿أأَنْتُمْ تَخْلُقُونَهُ أمْ نَحْنُ الخالِقُونَ نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</q> في المتعجّل والمتأخّر، <q>﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</q> يقول: <q>﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</q> فيقول: نَذهب بكم ونَجيء بغيركم، <q>﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</q> يقول: نخلُقكم فيما لا تعلمون؛ إن نشأ خلقناكم قِردة، وإن نشأ خلقناكم خنازير، <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى فَلَوْلا تَذَكَّرُونَ﴾</q> يقول: فهلّا تذكرون. ثم قال: <q>﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ﴾</q> يقول: ما تزرعون، <q>﴿أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</q> يقول: أليس نحن الذي نُنبتُه أم أنتم المُنبتُون؟! <q>﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ﴾</q> يقول: تَنَدَّمون، <q>﴿إنّا لَمُغْرَمُونَ﴾</q> يقول: إنّا لَمُوّارٌ{13} به، <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q> <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِن المُزْنِ﴾</q> يقول: من السحاب، <q>﴿أمْ نَحْنُ المُنْزِلُونَ لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</q> يقول: مُرًّا، <q>﴿فَلَوْلا تَشْكُرُونَ﴾</q> يقول: فهلّا تشكرون، <q>﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾</q> يقول: تَقْدحون، <q>﴿أأَنْتُمْ أنْشَأْتُمْ﴾</q> يقول: خلقتم <q>﴿شَجَرَتَها أمْ نَحْنُ المُنْشِئُونَ﴾</q> قال: وهي مِن كل شجرة إلا في العُنّاب{14}، وتكون في الحجارة، <q>﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</q> يقول: يُتذكّر بها نار الآخرة العليا، <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q> قال: والمُقوي: هو الذي لا يجد نارًا، فيُخرِج زِنده، فيَسْتَنوِر ناره، فهي متاع له، <q>﴿فَسَبِّحْ بِاسْمِ رَبِّكَ العَظِيمِ﴾</q> يقول: فَصَلِّ لربّك العظيم، <q>﴿فَلا أُقْسِمُ﴾</q> يقول: أُقسم <q>﴿بِمَواقِعِ النُّجُومِ﴾</q> قال: أتى ابنَ عباس عُلَيَّةُ بن الأسود أو نافعُ بن الحكم، فقال له: يا ابن عباس، إني أقرأ آيات من كتاب الله أخشى أن يكون قد دَخلني منها شيء. قال ابن عباس: ولِم ذلك؟ قال: لأني أسمع الله يقول: <q>﴿إنّا أنْزَلْناهُ فِي لَيْلَةِ القَدْرِ﴾</q> [القدر:١]، ويقول: <q>﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ﴾</q> [الدخان:٣]، ويقول في آية أخرى: <q>﴿شَهْرُ رَمَضانَ الَّذِي أُنْزِلَ فِيهِ القُرْآنُ﴾</q> [البقرة:١٨٥]، وقد نزل في الشهور كلّها؛ شوال وغيره. قال ابن عباس: ويلك! إنّ جُملة القرآن أُنزِل من السماء في ليلة القَدْر إلى بدء موقع النجوم. يقول: إلى سماء الدنيا، فنَزَل به جبريلُ في ليلة منه، وهي ليلة القَدْر المباركة، وهي في رمضان، ثم نزل به على محمد ﷺ في عشرين سنة الآية والآيتين والأكثر، فذلك قوله: <q>﴿فَلا أُقْسِمُ﴾</q> يقول: أُقسم <q>﴿بِمَواقِعِ النُّجُومِ وإنَّهُ لَقَسَمٌ﴾</q> والقَسم قَسمٌ، إلى قوله: <q>﴿لا يَمَسُّهُ إلّا المُطَهَّرُونَ﴾</q> وهم السَّفرة، والسَّفرة: هم الكتبة. ثم قال: <q>﴿تَنْزِيلٌ مِن رَبِّ العالَمِينَ أفَبِهَذا الحَدِيثِ أنْتُمْ مُدْهِنُون﴾</q> يقول: تَوَلَّوْن أهل الشّرك، <q>﴿وتَجْعَلُونَ رِزْقَكُمْ﴾</q> قال ابن عباس: سافر النبيُّ ﷺ في حرٍّ، فعطش الناس عطشًا شديدًا حتى كادت أعناقهم أن تنقطع مِن العطش، فذُكِر ذلك له، قالوا: يا رسول الله، لو دعوتَ الله، فسَقانا. قال: «لعلّي لو دعوتُ الله فسقاكم لقلتم: هذا بنَوء كذا وكذا». قالوا: يا رسول الله، ما هذا بحين الأنواء. فدعا بماءٍ في مَطهرة، فتوضأ، ثم ركع ركعتين، ثم دعا الله، فهبّت رياحٌ، وهاج سحابٌ، ثم أرسَلتْ، فمُطروا حتى سال الوادي، فشَربوا، وسَقَوا دوابّهم، ثم مرَّ النبيُّ ﷺ برجل وهو يغترف بقَعْبٍ معه مِن الوادي، وهو يقول: نَوء كذا وكذا سقطت الغداة. قال: ونزلت هذه الآية: <q>﴿وتَجْعَلُونَ رِزْقَكُمْ أنَّكُمْ تُكَذِّبُونَ﴾</q>{15}، <q>﴿فَلَوْلا إذا بَلَغَتِ الحُلْقُومَ﴾</q> يقول: النّفس، <q>﴿وأَنْتُمْ حِينَئِذٍ تَنْظُرُونَ ونَحْنُ أقْرَبُ إلَيْهِ مِنكُمْ﴾</q> يقول: الملائكة، <q>﴿ولَكِنْ لا تُبْصِرُونَ﴾</q> يقول: لا تبصرون الملائكة، <q>﴿فَلَوْلا﴾</q> يقول: هلا <q>﴿إنْ كُنْتُمْ غَيْرَ مَدِينِينَ﴾</q> غير مُحاسبين، <q>﴿تَرْجِعُونَها﴾</q> يقول: أن تُرجِعوا النّفس <q>﴿إنْ كُنْتُمْ صادِقِينَ فَأَمّا إنْ كانَ مِنَ المُقَرَّبِينَ﴾</q> مثل النّبيّين والصِّدِّيقين والشهداء بالأعمال، <q>﴿فَرَوْحٌ﴾</q> الفَرَج، مثل قوله: <q>﴿ولا تَيْأَسُوا مِن رَوْحِ اللَّهِ﴾</q> [يوسف:٨٧]، <q>﴿ورَيْحانٌ﴾</q> الرّزق. قال ابن عباس: لا تَخرج رُوح المؤمن من بدنه حتى يأكل مِن ثمار الجنة قبل موته، <q>﴿وجَنَّتُ نَعِيمٍ﴾</q> يقول: حُقِّقتْ له الجنة والآخرة، <q>﴿وإمّا إنْ كانَ مِن أصْحابِ اليَمِينِ﴾</q> يقول: جمهور أهل الجنة، <q>﴿فَسَلامٌ لَكَ مِن أصْحابِ اليَمِينِ وأَمّا إنْ كانَ مِنَ المُكَذِّبِينَ الضّالِّينَ﴾</q> وهم المشركون، <q>﴿فَنُزُلٌ مِن حَمِيمٍ﴾</q> قال ابن عباس: لا يَخرج الكافرُ مِن بيته في الدنيا حتى يُسقى كأسًا من حميم، <q>﴿وتَصْلِيَةُ جَحِيمٍ﴾</q> يقول: في الآخرة، <q>﴿إنَّ هَذا لَهُوَ حَقُّ اليَقِينِ﴾</q> يقول: هذا القول الذي قَصَصنا عليك لهو حقّ اليقين، يقول: القرآن الصادق{2}. (١٤/٢٤٧-٢٥٤) <q>﴿إِذَا وَقَعَتِ ٱلۡوَاقِعَةُ ۝١﴾</q> - تفسير ٧٤٧٢٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q>، قال: يوم القيامة{17}. (١٤/١٧٥) ٧٤٧٢٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿الواقِعَةُ﴾</q> و<q>﴿الطّامَّةُ﴾</q> [النازعات:٣٤] و<q>﴿الصّاخَّةُ﴾</q> [عبس:٣٣]، ونحو هذا: من أسماء القيامة، عظّمه الله، وحذّر عباده{18}٦٤١٢. (ز) ٦٤١٢ علَّق ابنُ عطية (٨/١٨٨) على قول ابن عباس بقوله: «وهذه كلها أسماء تقتضي تعظيمها، وتشنيع أمرها». ٧٤٧٢٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- في قوله: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q>، قال: الساعة{2}. (١٤/٢٤٨) ٧٤٧٢٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q>: يعني: الصَّيْحة{18}٦٤١٣. (ز) ٦٤١٣ وجَّه ابنُ عطية (٨/١٨٨) قول الضَّحّاك بقوله: «وهي النفخة في الصور». ثم نقل عن بعض المفسّرين قولهم: «الواقعة: صخرة بيت المقدس، تقع عند القيامة». ثم علَّق بقوله: «فهذه كلها معانٍ لأجل القيامة». ٧٤٧٢٨- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q>، قال: نَزَلَتْ{21}. (ز) ٧٤٧٢٩- قال مقاتل بن سليمان: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q> يعني: إذا وقعت الصيحة، وهي النّفخة الأولى{22}. (ز) ",footnotes:1:أخرجه النحاس ص٧٤٩ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٢١٢.أخرجه أحمد في فضائل الصحابة ٢/٧٢٦ (١٢٤٧)، وابن السني في عمل اليوم والليلة ص٦٢٩-٦٣٠ (٦٨٠)، والثعلبي ٩/١٩٩. قال الزيلعي في تخريج أحاديث الكشاف ٣/٤١٣-٤١٤ (١٢٩٥): «فقد تبيّن ضعف هذا الحديث من وجوه: أحدها: الانقطاع. كما ذكره الدارقطني، وابن أبي حاتم في علله نقلًا عن أبيه. والثاني: نكارة متنه. كما قال أحمد. والثالث: ضعف رواته. كما ذكره ابن الجوزي. والرابع: الاضطراب ... وقد اجتمع على ضعفه الإمام أحمد، وأبو حاتم، وابنه، والدارقطني، والبيهقي، وابن الجوزي، تلويحًا وتصريحًا». وقال العراقي في تخريج أحاديث الإحياء ص٤٠٧: «وللحارث بن أبي أسامة من حديث ابن مسعود بسند ضعيف». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٤٣٧: «الحديث منكر». وقال الألباني في الضعيفة ١/٤٥٧ (٢٨٩): «ضعيف».أخرجه الترمذي ٥/٤٠٢ (٣٢٩٧)، والحاكم ٢/٣٧٤ (٣٣١٤). قال الترمذي: «هذا حديث حسن غريب، لا نعرفه من حديث ابن عباس إلا من هذا الوجه. وروى علي بن صالح هذا الحديث عن أبي إسحاق، عن أبي جحيفة نحو هذا. ورُوي عن أبي إسحاق، عن أبي ميسرة شيء من هذا مرسلًا. وروى أبو بكر بن عياش، عن أبي إسحاق، عن عكرمة، عن النبي ﷺ نحو حديث شيبان، عن أبي إسحاق، ولم يذكر فيه عن ابن عباس». وقال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». ووافقه الذهبي.أخرجه ابن أبي شيبة ١٣/٤٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.الرُّمْص: جمع رَمْصاء، والرَّمَصُ في العين كالغَمَص، وهو قَذًى تلفظ به. لسان العرب والقاموس (رمص).مارَ يَمُور مَوْرًا: يذهبُ ويجيءُ ويتردّد. لسان العرب (مور).العناب: شجر شائك من الفصيلة السِّدْرية، يبلغ ارتفاعه ستة أمتار، ويطلق العناب على ثمره أيضًا، وهو أحمر حلو لذيذ الطعم على شكل ثمرة النبق. المعجم الوسيط (عنب).عزاه السيوطي إلى ابن مردويه. إسناده جيد. وينظر: مقدمة الموسوعة.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٣/٣٧٢، وابن جرير ٢٢/٢٧٩ مختصرًا، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٨٨-. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٧٩.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٧٩.أخرجه عبد الرزاق ٢/٢٦٩.تفسير مقاتل بن سليمان ٤/٢١٥.
56,2," <q>﴿لَیۡسَ لِوَقۡعَتِهَا كَاذِبَةٌ ۝٢﴾</q> - تفسير ٧٤٧٣٠- عن عبد الله بن عباس في قوله: <q>﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</q>، قال: ليس لها مردود{1}. (١٤/١٧٥) ٧٤٧٣١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك، وأبي صالح- <q>﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</q>، يقول: مَن كذّب بها في الدنيا فإنه لا يُكذّب بها في الآخرة إذا وقعت{2}. (١٤/٢٤٨) ٧٤٧٣٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ﴾</q>، قال: مَثْنَوِيّة{3}. (١٤/١٧٦) ٧٤٧٣٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ليس لوقعتها كاذبة﴾</q>، قال: أي: ليس لها مَثْنَويّة، ولا رجعة، ولا ارتداد{4}٦٤١٤. (ز) ٦٤١٤ ذكر ابن عطية (٨/١٨٨) في معنى: <q>﴿كاذِبَةٌ﴾</q> احتمالين: الأول: «أن يكون مصدرًا؛ كالعاقبة، والعافية، وخائنة الأعين». ثم وجَّهه بقوله: «فالمعنى: ليس لها تكذيبٌ ولا ردٌّ مَثْنَويَّةٌ. وهذا قول قتادة، والحسن». والثاني: «أن يكون صفةً لمقدَّر». ثم وجَّهه بقوله: «كأنه تعالى قال: ليس لِوَقْعَتِها حال كاذبة، ويحتمل الكلام على هذا معنيين: أحدهما: كاذِبَةٌ، أي: مكذوبة فيما أخبر به عنها، وسماها <q>﴿كاذِبَةٌ﴾</q> بهذا، كما تقول: قصة كاذبة، أي: مكذوب فيها. والثاني: حالٌ كاذبة، أي: لا يمضي وقوعها، كما تقول: فلان إذا حمل لم يكذب». ٧٤٧٣٤- قال مقاتل بن سليمان: <q>﴿لَيْسَ لِوَقْعَتِها﴾</q> يعني: ليس لصيحتها <q>﴿كاذِبَةٌ﴾</q> أنها كائنة، ليس لها مَثْنَويّة، ولا ارتداد{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٨٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٧٩.تفسير مقاتل بن سليمان ٤/٢١٥.
56,3," <q>﴿خَافِضَةࣱ رَّافِعَةٌ ۝٣﴾</q> - تفسير ٧٤٧٣٥- عن عمر بن الخطاب -من طريق عثمان بن سراقة- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: الساعة؛ خَفَضَتْ أعداءَ الله إلى النار، ورَفَعَتْ أولياءَ الله إلى الجنة{1}. (١٤/١٧٥) ٧٤٧٣٦- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: تَخْفِض ناسًا، وترفع آخرين{2}. (١٤/١٧٥) ٧٤٧٣٧- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: أسمعت القريبَ، والبعيدَ{3}. (١٤/١٧٥) ٧٤٧٣٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: القيامة خافضة. يقول: خَفَضَتْ فأسمَعَت الأدنى، ورَفَعَتْ فأسمَعَت الأقصى، كان القريب والبعيد فيها سواء. قال: وخَفَضَتْ أقوامًا قد كانوا في الدنيا مرتفعين، ورَفَعَتْ أقوامًا حتى جعلتهم في أعلى عِلّيّين{4}. (١٤/٢٤٨) ٧٤٧٣٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>: خَفَضَتْ فأسمَعَت الأدنى، ورَفَعَتْ فأسمَعَت الأقصى، فكان فيها القريب والبعيد سواء{5}. (ز) ٧٤٧٤٠- عن عكرمة مولى ابن عباس -من طريق يزيد- قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: خَفَضَتْ وأسمَعَت الأدنى، ورَفَعَتْ فأسمَعَت الأقصى. قال: فكان القريب والبعيد من الله سواء{5}. (ز) ٧٤٧٤١- عن ميمون بن مهران -من طريق أبي المليح الرقيّ- في قوله تعالى: <q>﴿خافضة رافعة﴾</q>، قال: تَخْفِض أقوامًا، وترفع آخرين{7}. (ز) ٧٤٧٤٢- عن محمد بن كعب القُرَظيّ -من طريق أبي معشر- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: تَخْفِض رجالًا كانوا في الدنيا مرتفعين، وترفع رجالًا كانوا في الدنيا مُنخَفضين{8}. (١٤/١٧٦) ٧٤٧٤٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: خَفَضَتْ قومًا في عذاب الله، ورَفَعَتْ قومًا في كرامة الله{9}. (١٤/١٧٦) ٧٤٧٤٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q> قال: عَلَتْ كلّ سهل وجبل، حتى أسمَعَت القريب والبعيد، ثم رَفَعَتْ أقوامًا في كرامة الله، وخَفَضَتْ أقوامًا في عذاب الله{10}. (ز) ٧٤٧٤٥- عن عثمان بن عبد الله بن سُراقةَ -من طريق عبيد الله العَتَكيّ- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: الساعة؛ خَفَضَتْ أعداء الله إلى النار، ورَفَعَتْ أولياء الله إلى الجنة{10}. (ز) ٧٤٧٤٦- عن إسماعيل السُّدِّيّ -من طريق حماد- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: خَفَضَت المتكبرين، ورَفَعَت المتواضعين{12}. (١٤/١٧٦) ٧٤٧٤٧- عن زيد بن أسلم -من طريق أسامة- في قوله: <q>﴿خافِضَةٌ رافِعَةٌ﴾</q>، قال: مَنِ انخفض يومئذٍ لم يرتفع أبدًا، ومَنِ ارتفع يومئذٍ لم ينخفض أبدًا{13}. (١٤/١٧٦) ٧٤٧٤٨- قال مقاتل بن سليمان: <q>﴿خافِضَةٌ﴾</q> يقول: أسمَعَتِ القريب. ثم قال: <q>﴿رافِعَةٌ﴾</q> يقول: أسمَعَت البعيد، فكانت صيحة، يعني: فصارت صيحة واحدة، أسمَعَت القريب والبعيد{14}٦٤١٥. (ز) ٦٤١٥ ذكر ابنُ عطية (٨/١٨٨) في معنى الآية عن جمهورٍ من المتأولين: أن «القيامة تنفطر بها السماء والأرض والجبال، وانهدام هذه البنية يرفع طائفة من الأجرام، ويخفض أخرى». ثم وجَّهه بقوله: «فكأنها عبارة عن شدة الهول والاضطراب». ",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٢٦-. وعزاه السيوطي إلى ابن جرير، وفيه موقوف على عثمان بن سراقة كما سيأتي ٢٢/٢٨٠.أخرجه ابن أبي شيبة ١٣/٣٧٢، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٨٨-. وعزاه السيوطي إلى ابن مردويه، وابن جرير.أخرجه ابن جرير ٢٢/٢٨١. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٨١.أخرجه ابن جرير ٢٢/٢٨١.أخرجه أبو نعيم في حلية الأولياء ٤/٨٦.أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٢٦-، وأبو الشيخ في العظمة (١٨٣). وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٢٦٩، وابن جرير ٢٢/٢٨١ بلفظ: أسمعت القريب والبعيد، خافضة أقوامًا إلى عذاب الله، ورافعة أقوامًا إلى كرامة الله. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٨٠.أخرجه ابن جرير ٢٢/٢٨٠.أخرجه أبو الشيخ (١٨٤).أخرجه ابن أبي شيبة ١٣/٥٧٧.تفسير مقاتل بن سليمان ٤/٢١٥.
56,4," <q>﴿إِذَا رُجَّتِ ٱلۡأَرۡضُ رَجࣰّا ۝٤﴾</q> - تفسير ٧٤٧٤٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q>، قال: زُلْزلت{1}. (١٤/١٧٦) ٧٤٧٥٠- عن عبد الله بن عباس، في قوله: <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q>، يقول: ترجف الأرض: تُزلزل{2}٦٤١٦. (١٤/١٧٧) ٦٤١٦ علَّق ابنُ عطية (٨/١٨٩) على قول ابن عباس بقوله: «ومنه: ارتَجَّ السهم في الغرض؛ إذا اضطرب بعد وقوعه. والرَّجة في الناس: الأمر المحرِّك». ٧٤٧٥١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q>، قال: هي الزّلْزَلة{3}. (١٤/٢٤٨) ٧٤٧٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q>، قال: زُلْزلتْ{4}. (١٤/١٧٧) ٧٤٧٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q>، قال: زُلْزلتْ زلزلة{5}. (١٤/١٧٦) ٧٤٧٥٤- قال محمد بن السّائِب الكلبي: <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q> وذلك أنّ الله ﷿ إذا أوحى إليها اضطربت فَرَقًا مِن الله تعالى{6}. (ز) ٧٤٧٥٥- قال مقاتل بن سليمان: <q>﴿إذا رُجَّتِ الأَرْضُ رَجًّا﴾</q>، يعني: إذا زُلْزلت الأرض زلزالها، يعني: رجًّا، شدة الزلزلة لا تسكن حتى تُلقي كلّ شيء في بطنها على ظهرها، يقول: إنها تضطرب وترتج؛ لأنّ زلزلة الدنيا لا تلبث حتى تسكن، وزلزلة الآخرة لا تسكن وترتجّ كرجّ الصبي في المهْد حتى ينكسر كلّ شيء عليها من جبل، أو مدينة، أو بناء، أو شجر، فيدخل فيها كلّ شيء خرج منها من شجر أو نبات، وتُلقي ما فيها من الموتى، والكنوز على ظهرها{7}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٢٨٢ بلفظ: زلزلها. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٠، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤-، وابن جرير ٢٢/٢٨٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٩، وابن جرير ٢٢/٢٨٢ كلاهما من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٧.تفسير مقاتل بن سليمان ٤/٢١٥.
56,5," <q>﴿وَبُسَّتِ ٱلۡجِبَالُ بَسࣰّا ۝٥﴾</q> - تفسير ٧٤٧٥٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: فُتِّتَتْ{1}. (١٤/١٧٦) ٧٤٧٥٧- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، يقول: فُتِّتَتْ فَتًّا{2}٦٤١٧. (١٤/١٧٧) ٦٤١٧ لم يذكر ابنُ جرير (٢٢/٢٨٣-٢٨٤) في معنى: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> سوى قول ابن عباس، ومجاهد، وعكرمة، وأبي صالح، والسُّدِّيّ من طريق سعيد بن الصلت، وابن زيد. ٧٤٧٥٨- قال سعيد بن المسيّب= (ز) ٧٤٧٥٩- وإسماعيل السُّدِّيّ: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> كُسِرتْ كسرًا{3}. (ز) ٧٤٧٦٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: فُتِّتَتْ{4}. (١٤/١٧٧) ٧٤٧٦١- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: كما يُبَسُّ السَّوِيق{5}. (ز) ٧٤٧٦٢- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: لُتَّت لتًّا{2}. (ز) ٧٤٧٦٣- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: فُتَّت فتًّا{7}. (ز) ٧٤٧٦٤- عن الحسن البصري: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> قُلِعَتْ مِن أصلها، فذهبتْ بعد ما كانت صخرًا صماء{8}. (ز) ٧٤٧٦٥- عن عطية بن سعد العَوفيّ: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> بُسِطتْ بسطًا كالرّمل والتراب{9}. (ز) ٧٤٧٦٦- قال عطاء: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> أُذْهِبَتْ إذْهابًا{9}. (ز) ٧٤٧٦٧- قال عطاء= (ز) ٧٤٧٦٨- ومقاتل: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> فُتّتْ فتًّا، فصارت كالدقيق المبْسوس، وهو المبلول{11}. (ز) ٧٤٧٦٩- عن قتادة بن دعامة، في قوله تعالى: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: حُتّت حتًّا{12}. (١٤/١٧٦) ٧٤٧٧٠- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: نُسِفتْ نسفًا{13}. (ز) ٧٤٧٧١- عن أبي صالح [باذام]= (ز) ٧٤٧٧٢- وإسماعيل السُّدِّيّ -من طريق سعيد بن الصلت- <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: فُتِّتَتْ فتًّا{14}. (ز) ٧٤٧٧٣- عن زيد بن أسلم -من طريق رجل- في قول الله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، يقول: حُتّتْ حتًّا{15}. (ز) ٧٤٧٧٤- قال محمد بن السّائِب الكلبي: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> سُيِّرت عن وجه الأرض تسييرًا{3}. (ز) ٧٤٧٧٥- قال مقاتل بن سليمان: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q> يعني: فُتِّتت الجبال فتًّا، <q>﴿فكانت﴾</q> يقول: فصارت بعد القوة والشدة عروقها في الأرض السابعة السفلى، ورأسها فوق الأرض العليا؛ من الخوف{17}. (ز) ٧٤٧٧٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿وبُسَّتِ الجِبالُ بَسًّا﴾</q>، قال: صارت كثيبًا مهيلًا، كما قال جلّ وعزّ{14}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٢٨٣ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٥-.تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٧.تفسير مجاهد ص٦٤٠، وأخرجه ابن جرير ٢٢/٢٨٣-٢٨٤، وبنحوه من طريق منصور. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٨٣-٢٨٤، والفريابي -كما في الفتح ٨/٦٢٥-.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٥-.أخرجه ابن جرير ٢٢/٢٨٣.تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٨.تفسير الثعلبي ٩/٢٠٠.تفسير الثعلبي ٩/٢٠٠.تفسير البغوي ٨/٧.عزاه السوطي إلى ابن جرير، وعبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٩.أخرجه ابن جرير ٢٢/٢٨٤.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٢٤ (٢٨٤).تفسير الثعلبي ٩/٢٠٠، وتفسير البغوي ٨/٧.تفسير مقاتل بن سليمان ٤/٢١٥.أخرجه ابن جرير ٢٢/٢٨٤.
56,6," <q>﴿فَكَانَتۡ هَبَاۤءࣰ مُّنۢبَثࣰّا ۝٦﴾</q> - تفسير ٧٤٧٧٧- عن علي بن أبي طالب -من طريق الحارث- قال: الهباء المُنبَثّ: رهْج الدّواب. والهباء المنثور: غُبار الشمس الذي تراه في شعاع الكَوَّة{1}. (١٤/١٧٧) ٧٤٧٧٨- قال السُّدِّيّ: قال علي [بن أبي طالب] في قوله: <q>﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</q>: هذا الهَرَج، هَرَج الدّواب الذي يحرّك الغبار{2}. (١٤/٢٤٨) ٧٤٧٧٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</q>، قال: كشعاع الشمس{3}. (١٤/١٧٦) ٧٤٧٨٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</q>، قال: الهباء: الذي يطير من النار إذا اضطرمت يطير منها الشّرر، فإذا وقع لم يكن شيئًا{4}. (١٤/١٧٧) ٧٤٧٨١- عن عبد الله بن عباس، <q>﴿فَكانَتْ هَباءً مُنْبَثًّا﴾</q>، قال: الهباء: ما يثور مع شعاع الشمس، وانبثاثه: تفرّقه{5}. (١٤/١٧٧) ٧٤٧٨٢- عن سعيد [بن جبير] -من طريق عطاء- <q>﴿هَباءً مُنْبَثًّا﴾</q>، قال: شعاع الشمس حين يدخل من الكَوّة{6}. (ز) ٧٤٧٨٣- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿هَباءً مُنْبَثًّا﴾</q>، قال: الشعاع الذي يكون في الكَوّة{7}. (١٤/١٧٨) ٧٤٧٨٤- عن أبي مالك [الغفاري]، في قوله: <q>﴿هَباءً مُنْبَثًّا﴾</q>، قال: الغبار الذي يخرج مِن الكَوّة مع شعاع الشمس{8}. (١٤/١٧٧) ٧٤٧٨٥- عن الحسن البصري، في قوله: <q>﴿هَباءً مُنْبَثًّا﴾</q>، قال: هو الذي تراه في الشمس إذا دخَلَتْ من الكَوّة إلى البيت{8}. (١٤/١٧٨) ٧٤٧٨٦- قال الحسن البصري: <q>﴿هَباءً مُنْبَثًّا﴾</q> غُبارًا ذا هباء{10}. (ز) ٧٤٧٨٧- قال عطية بن سعد العَوفيّ: الهباء: ما تطاير مِن شَرر النار{11}. (ز) ٧٤٧٨٨- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿هَباءً مُنْبَثًّا﴾</q>، قال: الهباء: ما تذروه الرياح مِن حُطام الشجر{12}. (ز) ٧٤٧٨٩- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿هباء منبثا﴾</q>، قال: ما تذروه الريح وتَبُثُّه{13}. (ز) ٧٤٧٩٠- قال مقاتل بن سليمان: <q>﴿هَباءً مُنْبَثًّا﴾</q> يعني: الغبار الذي تراه في الشمس إذا دخل مِن الكَوّة في البيت. والمُنبثّ: الذي ليس بشيء. والهباء المنثور: الذي يسطع مِن حوافر الخيل من الغبار. قال عبد الله بذلك حدثني أبي، عن أبي صالح، عن مقاتل، عن الحارث، عن علي ﵇{14}٦٤١٨. (ز) ٦٤١٨ اختُلف في معنى: «الهباء» في هذه الآية على أقوال: الأول: أنه ما يتطاير في الهواء من الأجزاء الدقيقة، ولا يكاد يُرى إلا في الشمس إذا دخلت من كَوة. الثاني: أنه ما يتطاير من يبس النبات. الثالث: ما يتطاير من حوافر الخيل والدواب. الرابع: ما يتطاير من شرر النار، فإذا طفئ لم يوجد شيء. ورجَّح ابنُ عطية (٨/١٩٠) القول الأول، فقال: «والقول الأول في الهباء أحسن الأقوال». ولم يذكر مستندًا. ",footnotes:1:أخرجه مقاتل بن سليمان ٤/٢١٥-٢١٦، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٠- مختصرًا، وعبد الرزاق ٢/٢٦٩ مختصرًا، وابن جرير ٢٢/٢٨٥ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٨٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٨٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٨٤.أخرجه ابن جرير ٢٢/٢٨٥ بلفظ: شعاع الشمس يدخل من الكوة، وليس بشيء. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٦-.تفسير الثعلبي ٩/٢٠١.أخرجه عبد الرزاق ٢/٢٦٩، وابن جرير ٢٢/٢٨٥-٢٨٦، وبنحوه من طريق سعيد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٠.تفسير مقاتل بن سليمان ٤/٢١٥-٢١٦.
56,7," <q>﴿وَكُنتُمۡ أَزۡوَ ٰ⁠جࣰا ثَلَـٰثَةࣰ ۝٧﴾</q> - تفسير ٧٤٧٩١- عن عبد الله بن عباس، في قوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q>، قال: أصنافًا{1}. (١٤/١٧٨) ٧٤٧٩٢- عن عبد الله بن عباس، في قوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q>، قال: هي التي في سورة الملائكة: <q>﴿ثُمَّ أوْرَثْنا الكِتابَ الَّذِينَ اصْطَفَيْنا مِن عِبادِنا فَمِنهُمْ ظالِمٌ لِنَفْسِهِ ومِنهُمْ مُقْتَصِدٌ ومِنهُمْ سابِقٌ بِالخَيْراتِ﴾</q> [فاطر:٣٢]{2}. (١٤/١٧٨) ٧٤٧٩٣- عن عبد الله بن عباس، في قوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q>، قال: هذا حين تَزايَلَتْ{3} بهم المنازل، هم أصحاب اليمين، وأصحاب الشمال، والسابقون{4}. (١٤/١٧٨) ٧٤٧٩٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q>، قال: العباد يوم القيامة على ثلاثة منازل{5}. (١٤/٢٤٨) ٧٤٧٩٥- عن عثمان بن عبد الله بن سُراقة -من طريق عبيد الله العَتَكي- قوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q>، قال: اثنان في الجنة، وواحد في النار. يقول: الحُور العِين للسابقين، والعُرُب الأتْراب لأصحاب اليمين{6}. (ز) ٧٤٧٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q>، قال: منازل الناس يوم القيامة{7}. (١٤/١٧٨) ٧٤٧٩٧- قال مقاتل بن سليمان: قال ﷿: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q> وكنتم في الآخرة أصنافًا ثلاثة؛ صنفان في الجنة، وصنف في النار{8}. (ز) ٧٤٧٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- يقول: وجدتُ الهوى ثلاثة أثلاث، فالمرء يجعل هواه عِلْمه، فيُدالُ{9} هواه على عِلْمه، ويقهر هواه عِلْمَه، حتى إنّ العلم مع الهوى قبيحٌ ذليل، والعلم ذليل الهوى غالب قاهر، فهذا الذي قد جعل الهوى والعلم في قلبه، فهذا مِن أزواج النار، وإذا كان مِمَّن يريد الله به خيرًا استَفاق واستَنبَه، فإذا هو عَوْنٌ للعلم على الهوى حتى يُديل الله العلم على الهوى، فإذا حَسُنتْ حال المؤمن، واستقامت طريقته كان الهوى ذليلًا، وكان العلم غالبًا قاهرًا، فإذا كان مِمّن يريد الله به خيرًا خَتَم عمله بإدالة العلم، فتَوفّاه حين توفّاه وعِلْمه هو القاهر، وهو العامل به، وهواه الذليل القبيح، ليس له في ذلك نصيب ولا فعل، والثالث: الذي قبّح الله هواه بعِلْمه، فلا يطمع هواه أن يغلب العلم، ولا أن يكون له مع العلم نصف ولا نصيب، فهذا الثالث، وهو خيرهم كلّهم، وهو الذي قال الله ﷿ في سورة الواقعة: <q>﴿وكنتم أزواجا ثلاثة﴾</q> قال: فزوجان في الجنة، وزوج في النار. قال: والسابق الذي يكون العلم غالبًا للهوى، والآخر الذي ختم الله بإدالة العلم على الهوى، فهذان زوجان في الجنة، والآخر هواه قاهر لعِلْمه، فهذا زوج النار{10}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.تزايلتْ: تفرّقتْ. لسان العرب (زيل).عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٨٧.أخرجه عبد الرزاق ٢/٢٦٩ مختصرًا، وابن جرير ٢٢/٢٨٦-٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢١٦.الإدالة: الغَلَبة. النهاية (دول).أخرجه ابن جرير ٢٢/٢٨٨-٢٨٩.
56,8," <q>﴿فَأَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ مَاۤ أَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ ۝٨﴾</q> - تفسير ٧٤٧٩٩- قال عبد الله بن عباس: <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q> وهم الذين كانوا على يمين آدم حين أُخرجت الذُّريّة من صُلبه، وقال الله تعالى لهم: هؤلاء في الجنة، ولا أُبالِي{1}. (ز) ٧٤٨٠٠- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q>: هم الجمهور، جماعة أهل الجنة{2}. (١٤/٢٤٨) ٧٤٨٠١- قال الضَّحّاك بن مُزاحِم: <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q> هم الذين يُعطون كتبهم بأيمانهم{1}٦٤١٩. (ز) ٦٤١٩ نقل ابنُ عطية (٨/١٩١) قولًا أنّ أصحاب الميمنة: مؤمنون، وهم على يمين العرش. وأنّ أصحاب المشأمة: كافرون، وهم على شمال العرش. ثم علَّق على قول مَن قال: أصحاب الميمنة: هم مَن أخذ كتابه بيمينه، وأصحاب المشأمة: من أخذه بشماله. بقوله: «فعلى هذا ليست نسبة اليمين والشمال إلى العرش». ٧٤٨٠٢- قال الحسن البصري= (ز) ٧٤٨٠٣- والربيع [بن أنس]: <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q> هم الذين كانوا ميامين مُباركين على أنفسهم، وكانت أعمارهم في طاعة الله ﷿، وهم التابعون بإحسان{1}. (ز) ٧٤٨٠٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q>، قال: ماذا لهم، وماذا أعدّ لهم{5}. (١٤/١٧٨) ٧٤٨٠٥- قال مقاتل بن سليمان: <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ﴾</q> يقول: ما لأصحاب اليمين من الخير والكرامة في الجنة{6}. (ز) <q>﴿فَأَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ مَاۤ أَصۡحَـٰبُ ٱلۡمَیۡمَنَةِ ۝٨﴾</q> - آثار متعلقة بالآية ٧٤٨٠٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «إنّ الله تعالى قَسَم الخلْق قسمين: فجعلني في خيرهما قسمًا، فذلك قوله: <q>﴿وأَصْحابُ اليَمِينِ﴾</q> [الواقعة:٢٧]، <q>﴿وأَصْحابُ الشِّمالِ﴾</q> [الواقعة:٤١]، فأنا من أصحاب اليمين، وأنا من خير أصحاب اليمين، ثم جعل القسمين بيوتًا، فجعلني في خيرهما بيتًا، فذلك قوله: <q>﴿فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ والسّابِقُونَ السّابِقُونَ﴾</q> [الواقعة:٨-١٠]، فأنا من خير السابقين، ثم جعل البيوت قبائل، فجعلني في خيرها قبيلة، فذلك قوله: <q>﴿شُعُوبًا وقَبائِلَ﴾</q> [الحجرات:١٣]، فأنا أتقى ولد آدم وأكرمهم على الله ﷿ ولا فَخْر، ثم جعل القبائل بيوتًا، فجعلني في خيرها بيتًا، فذلك قوله: <q>﴿إنَّما يُرِيدُ اللَّهُ لِيُذْهِبَ عَنْكُمُ الرِّجْسَ أهْلَ البَيْتِ ويُطَهِّرَكُمْ تَطْهِيرًا﴾</q> [الأحزاب:٣٣]»{7}. (ز) ",footnotes:1:تفسير الثعلبي ٩/٢٠١، وتفسير البغوي ٨/٨.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢٠١، وتفسير البغوي ٨/٨.تفسير الثعلبي ٩/٢٠١، وتفسير البغوي ٨/٨.أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢١٦.أخرجه الطبراني في الكبير ٣/٥٦ (٢٦٧٤)، ١٢/١٠٣ (١٢٦٠٤)، والثعلبي ٨/٤٤. وأورده الحكيم الترمذي في نوادر الأصول ١/٣٣٠-٣٣١. قال ابن أبي حاتم في علل الحديث ٦/٤٩٠ (٢٦٩٣): «قال أبي: هذا حديث باطل». وقال الهيثمي في المجمع ٨/٢١٥ (١٣٨٢٢): «رواه الطبراني، وفيه يحيى بن عبد الحميد الحماني، وعباية بن ربعي، وكلاهما ضعيف». وقال الألباني في الضعيفة ١١/٨٥٥ (٥٤٩٥): «موضوع بهذا التمام».
56,9," <q>﴿وَأَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ مَاۤ أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ ۝٩﴾</q> - تفسير ٧٤٨٠٧- قال عبد الله بن عباس: <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q> هم الذين كانوا على شمال آدم عند إخراج الذُّريّة، وقال الله لهم: هؤلاء في النار ولا أبالي{1}. (ز) ٧٤٨٠٨- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿: <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q>. قال: أصحاب الشمال. قال: وهل كانت العرب تعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: أما سمعت بقول زُهير بن أبي سُلمى: نَزَلَ الشَّيْبُ بالشِّمالِ قَرِيبًا والمَرُوراتِ دائِيًا وحَقِيرا؟ قال: صَدقتَ{2}. (ز) ٧٤٨٠٩- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q>: هم أصحاب الشمال، يقول: ما لهم، وما أعدّ لهم{3}. (١٤/٢٤٨) ٧٤٨١٠- قال الضَّحّاك بن مُزاحِم: <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q> هم الذين يُؤتون كتبهم بشمالهم{1}. (ز) ٧٤٨١١- قال الحسن البصري: <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q> هم المشائيم على أنفسهم، وكانت أعمارُهم في المعاصي{5}. (ز) ٧٤٨١٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q>، قال: ماذا لهم، وماذا أعدّ لهم{6}. (١٤/١٧٨) ٧٤٨١٣- قال مقاتل بن سليمان: <q>﴿وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ﴾</q>، يقول: ما لأصحاب المشأمة مِن الشرِّ في جهنم{7}. (ز) ",footnotes:1:تفسير البغوي ٨/٨.أخرجه الطبراني مطولًا في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٨/٨.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٨.أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢١٦.
56,10," <q>﴿وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ ۝١٠﴾</q> - نزول الآية، وتفسيرها ٧٤٨١٤- عن عبد الله بن عباس، في قوله: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>، قال: نَزَلَتْ في حِزْقيل مؤمن آل فرعون، وحَبيب النجار الذي ذُكر في <q>﴿يس﴾</q>، وعلي بن أبي طالب، وكلّ رجل منهم سابق أُمّته، وعلِيٌّ أفضلهم سبقًا{1}. (١٤/١٨٠) ٧٤٨١٥- عن عبد الله بن عباس، في قوله: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>، قال: يوشع بن نون سبق إلى موسى، ومؤمن آل يس سبق إلى عيسى، وعلي بن أبي طالب ﵁ سبق إلى محمد رسول الله ﷺ{2}. (١٤/١٧٩) ٧٤٨١٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<q>﴿والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ﴾</q> أول مَن يُهَجِّرُ{3} إلى المسجد، وآخر مَن يخرج منه»{4}. (١٤/١٧٩) ٧٤٨١٧- عن النُّعمان بن بشير، قال: قال رسول الله ﷺ: «<q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q> [التكوير:٧] قال: الضُّرَباءُ{5}؛ كلّ رجل مع قوم كانوا يعملون بعمله، وذلك أنّ الله يقول: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ والسّابِقُونَ السّابِقُونَ﴾</q>، قال: «هم الضُّرَباء»{6}. (١٤/١٨٠) ٧٤٨١٨- عن الحسن البصري، في قوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً فَأَصْحابُ المَيْمَنَةِ ما أصْحابُ المَيْمَنَةِ وأَصْحابُ المَشْأَمَةِ ما أصْحابُ المَشْأَمَةِ والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ﴾</q>، قال: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخَرِينَ﴾</q> فقال رسول الله ﷺ: «سوّى بين أصحاب اليمين مِن الأمم الماضية، وبين أصحاب اليمين مِن هذه الأُمّة، وكان السابقون مِن الأمم أكثر مِن سابقي هذه الأُمّة»{7}. (ز) ٧٤٨١٩- قال علي بن أبي طالب: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q> إلى الصلوات الخمس{8}. (ز) ٧٤٨٢٠- قال عبد الله بن عباس: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q> السابقون إلى الهجرة، هم السابقون في الآخرة{9}. (ز) ٧٤٨٢١- عن عبد الله بن عباس، <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>، قال: من كلّ أُمّة{1}. (١٤/١٨٠) ٧٤٨٢٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>: هم مثل النّبيّين، والصِّدِّيقين، والشهداء بالأعمال مِن الأوّلين والآخرين{1}. (١٤/٢٤٨) ٧٤٨٢٣- عن قتادة بن دعامة -من طريق سعيد-، مثله{12}. (١٤/١٨٠) ٧٤٨٢٤- عن كعب الأحبار -من طريق أبي علي- <q>﴿والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ فِي جَنّاتِ النَّعِيمِ﴾</q>، قال: هم أهل القرآن، وهم المتوَّجُون يوم القيامة{13}. (ز) ٧٤٨٢٥- عن سعيد بن جُبَير: هم المُسارِعون إلى التوبة، وإلى أعمال البِرّ{8}. (ز) ٧٤٨٢٦- قال الضَّحّاك بن مُزاحِم: إلى الجهاد{8}. (ز) ٧٤٨٢٧- قال عكرمة مولى ابن عباس: السابقون إلى الإسلام{9}. (ز) ٧٤٨٢٨- عن عثمان بن أبي سَوَدة مولى عبادة بن الصامت -من طريق أبي عمرو- قال: بلغنا في هذه الآية: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q> أنهم السابقون إلى المساجد والخروج في سبيل الله{17}. (١٤/١٨٠) ٧٤٨٢٩- قال الحسن البصري: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>، السابقون: أصحاب النبي ﷺ، وأصحاب الأنبياء{18}. (ز) ٧٤٨٣٠- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q> إلى قوله: <q>﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> [الواقعة:٧-٤٠]، قال: سوّى بين أصحاب اليمين من الأمم الماضية وبين أصحاب اليمين من هذه الأُمّة، وكان السابقون من الأولين أكثر مِن سابقي هذه الأُمّة{19}٦٤٢٠. (١٤/١٧٩) ٦٤٢٠ وجَّه ابنُ عطية (٨/١٩٢) قول الحسن بقوله: «وذلك إما أن يقرن أصحاب الأنبياء ﵈ بجموعهم إلى أصحاب محمد ﷺ، فأولئك أكثر عددًا لا محالة، وإما أن يقرن أصحاب الأنبياء ﵈ ممن سبق في أثناء الأمم السّالِفَة إلى السابقين من جميع هذه الأُمّة؛ فأولئك أكثر». ٧٤٨٣١- عن الحسن البصري -من طريق عبد الله بن بكر- يقول: <q>﴿والسّابِقُونَ السّابِقُونَ أُولَئِكَ المُقَرَّبُونَ﴾</q>، قال: وأمّا المُقرّبون فقد مَضوا هنيئًا لهم، ولكن اللهم اجعلنا مِن أصحاب اليمين. قال: وأتى على هذه الآية <q>﴿إنَّ جَهَنَّمَ كانَتْ مِرْصادًا﴾</q> [النبأ:٢١]، قال: ألا على الباب رَصد؛ فمَن جاء بجواز جاز، ومَن لم يجئ بجواز حُبس{20}. (ز) ٧٤٨٣٢- عن محمد بن سيرين -من طريق قرة- <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>: هم الذين صَلّوا إلى القِبلتين{21}. (ز) ٧٤٨٣٣- قال محمد بن كعب القُرَظيّ: إلى كلّ خير{8}. (ز) ٧٤٨٣٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q>، قال: السابقون مِن كلّ أُمّة{23}٦٤٢١. (١٤/١٧٨) ٦٤٢١ علَّق ابنُ كثير (١٣/٣٥١) على هذه الأقوال بقوله: «وهذه الأقوال كلّها صحيحة؛ فإنّ المراد بالسابقين: هم المُبادِرون إلى فعل الخيرات كما أُمروا، كما قال تعالى: <q>﴿وسارِعُوا إلى مَغْفِرَةٍ مِن رَبِّكُمْ وجَنَّةٍ عَرْضُها السَّمَواتُ والأرْضُ﴾</q> [آل عمران:١٣٣]، وقال: <q>﴿سابِقُوا إلى مَغْفِرَةٍ مِن رَبِّكُمْ وجَنَّةٍ عَرْضُها كَعَرْضِ السَّماءِ والأرْضِ﴾</q> [الحديد:٢٢]، فمَن سابق في هذه الدنيا وسبق إلى الخير، كان في الآخرة من السابقين إلى الكرامة، فإنّ الجزاء من جنس العمل، وكما تدين تدان؛ ولهذا قال تعالى: <q>﴿أُولَئِكَ المُقَرَّبُونَ فِي جَنّاتِ النَّعِيمِ﴾</q> [الواقعة:١١-١٢]». ٧٤٨٣٥- قال الربيع بن أنس: السابقون إلى إجابة الرسول في الدنيا، وهم السابقون إلى الجنة في العقبى{8}٦٤٢٢. (ز) ٦٤٢٢ استظهر ابنُ القيم (٨/١٠٧) في قوله تعالى: <q>﴿والسّابِقُونَ السّابِقُونَ﴾</q> أن تكون «السابقون» الأولى غير الثانية، «ويكون المعنى: السابقون في الدنيا إلى الخيرات هم السابقون يوم القيامة إلى الجنات، والسابقون إلى الإيمان هم السابقون إلى الجنان». ٧٤٨٣٦- عن آدم بن عبد الله الخَثْعميّ، قال: سألتُ زيد بن علي عن قول الله ﷿: <q>﴿والسابقون السابقون أولئك المقربون﴾</q> مَن هؤلاء؟ قال: أبو بكر، وعمر. ثم قال: لا أنالني اللهُ شفاعةَ جدّي إن لم أُوالِهما{25}. (ز) ٧٤٨٣٧- قال مقاتل بن سليمان: <q>﴿والسّابِقُونَ﴾</q> إلى الأنبياء، منهم أبو بكر وعلي ﵄، هم <q>﴿السّابِقُونَ﴾</q> إلى الإيمان بالله ورسوله من كلّ أُمّة؛ هم السابقون إلى الجنة{26}. (ز) <q>﴿وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ ۝١٠﴾</q> - آثار متعلقة بالآية ٧٤٨٣٨- عن الحسن البصري، قال: قال رسول الله ﷺ: «السابقون يوم القيامة أربعة: فأنا سابق العرب، وسلمان سابق فارس، وبلال سابق الحبشة، وصُهيب سابق الروم»{27}. (١٤/١٧٩) ٧٤٨٣٩- عن عبد الله بن شُمَيط، قال: سمعت أبي يقول: الناس ثلاثة: فرجل ابتكر الخير في حَداثة سِنّه ثم داوم عليه حتى خرج عن الدنيا فهذا السابق المقرب، ورجل ابتكر عمره بالذنوب وطول الغفلة ثم تراجع بتوبة حتى ختم له بهذا فهو من أصحاب اليمين، ورجل ابتكر عمره بالذنوب ثم لم يزل عليها حتى حتى ختم له بهذا فهذا من أصحاب الشمال{28}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٩٠-. وعزاه السيوطي إلى ابن مردويه.التهجِير: التبكير إلى كل شيء والمبادرة إليه. النهاية (هجر).أورده الديلمي في الفردوس ٢/٣٤٨ (٣٥٧٤).الضرباء: هم الأمثال والنُّظَراء، واحدهم: ضَرِيب. النهاية (ضرب).أخرجه ابن جرير ٢٤/١٤٢، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥١٦-. إسناده ضعيف؛ فيه الوليد بن عبد الله بن أبي ثور الهمداني الكوفي، قال عنه ابن حجر في التقريب (٧٤٣١): «ضعيف».أخرجه ابن جرير ٢٢/٢٨٧ مرسلًا.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٨.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه الثعلبي ٩/٢٠٢، وأبو نعيم في حلية الأولياء ٥/٣٧٧ مختصرًا. وينظر: تفسير البغوي ٨/٩.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٨.أخرجه ابن جرير ٢٢/٢٩٠، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٢٥٥ (١٩٦٨٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. كما أخرج نحوه عبد الله بن أحمد في زوائد الزهد ص٢٦٣، وفيه: عن عثمان بن أبي مرة، وربما كان تصحيفًا.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٧-.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر. وأخرجه ابن جرير ٢٢/٢٨٧-٢٨٨ مرفوعًا، وقد تقدم.أخرجه البيهقي في شعب الإيمان ٣/١٥٥-١٥٦ (٨٧٤).أخرجه ابن جرير ٢٢/٢٩١.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.أخرجه ابن جرير ٢٢/٢٨٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٢٠٢، وتفسير البغوي ٨/٩.أخرجه ابن عساكر في تاريخ دمشق ١٩/٤٦١.تفسير مقاتل بن سليمان ٤/٢١٦.عزاه السيوطي إلى عبد بن حميد مرسلًا. ضعفه الألباني في السلسلة الضعيفة (٢٩٥٣).أخرجه الثعلبي ٩/٢٠٢.
56,11," <q>﴿أُو۟لَـٰۤىِٕكَ ٱلۡمُقَرَّبُونَ ۝١١ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝١٢ ثُلَّةࣱ مِّنَ ٱلۡأَوَّلِینَ ۝١٣ وَقَلِیلࣱ مِّنَ ٱلۡـَٔاخِرِینَ ۝١٤﴾</q> - نزول الآيات، والنسخ فيها ٧٤٨٤٠- عن جابر بن عبد الله -من طريق عُروة بن رُوَيم- قال: لَمّا نَزَلَتْ: <q>﴿إذا وقَعَتِ الواقِعَةُ﴾</q> ذُكر فيها: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ﴾</q>، قال عمر: يا رسول الله، ثُلّة من الأوّلين وقليل منّا؟ فأُمسك آخر السورة سنة، ثم نزل: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>. فقال رسول الله ﷺ: «يا عمر، تعال فاسمع ما قد أنزل الله: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، ألا وإنّ مِن آدم إلَيَّ ثُلّة، وأُمّتي ثُلّة، ولن تُستَكمل ثُلّتنا حتى نستعين بالسُّودان مِن رُعاة الإبل، مِمّن يشهد أن لا إله إلا الله وحده لا شريك له»{1}. (١٤/١٨١) ٧٤٨٤٢- عن أبي هريرة، قال: لَمّا نزلت: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ﴾</q> حزِن أصحابُ رسول الله ﷺ، وقالوا: إذن لا يكون مِن أُمّة محمد إلا قليل. فنَزَلَت نصفَ النهار: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، وتقايلها الناس، فنَسَخَت الآيةَ: <q>﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</q>{2}. (١٤/١٨٢) <q>﴿أُو۟لَـٰۤىِٕكَ ٱلۡمُقَرَّبُونَ ۝١١ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝١٢ ثُلَّةࣱ مِّنَ ٱلۡأَوَّلِینَ ۝١٣ وَقَلِیلࣱ مِّنَ ٱلۡـَٔاخِرِینَ ۝١٤﴾</q> - تفسير الآيات ٧٤٨٤٣- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أُولَئِكَ المُقَرَّبُونَ﴾</q> قال: هم أقرب الناس مِن دار الرحمن مِن بُطنان الجنة، وبُطنانها: وسطها، <q>﴿فِي جَنّاتِ النَّعِيمِ﴾</q>{2}. (١٤/٢٤٨) ٧٤٨٤٤- عن عُرْوة بن الزّبير -من طريق سعد بن إبراهيم- قال: كان يقال: تقدّموا تقدّموا{4}. (ز) ٧٤٨٤٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثُلَّةٌ﴾</q>، قال: أُمّة{5}. (١٤/١٨١) ٧٤٨٤٦- قال مقاتل بن سليمان: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</q> يعني: جمعًا من الأوّلين، يعني: سابقي الأمم الخالية، وهم الذين عاينوا الأنبياءَ ﵈، فلم يشُكُّوا فيهم طَرْفة عين، فهم السابقون، <q>﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</q> يعني: أُمّة محمد ﷺ، فهم أقلّ مِن سابقي الأمم الخالية، ثم ذكر ما أعدّ الله للسابقين من الخير{6}. (ز) ٧٤٨٤٧- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</q> قال: مِمّن سبق، <q>﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</q> قال: من هذه الأُمّة{7}٦٤٢٤. (١٤/١٨٢) ٦٤٢٤ اختُلف في معنى: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وقَلِيلٌ مِنَ الآخِرِينَ﴾</q> على قولين: الأول: أنّ الأوّلين مَن كان قبل محمد ﷺ، والآخرين أمَّته. الثاني: أنّ الأوّلين من صدر هذه الأمة، والآخرين من هذه الأمة. ورجَّح ابنُ تيمية (٦/١٨٥) القول الأول قائلًا: «والأول أصح». وانتقد ابنُ كثير (١٣/٣٥٣) -مستندًا إلى دلالة القرآن، والعقل- القول الأول، ورجَّح القول الثاني قائلًا: «لأنّ هذه الأُمّة هي خير الأمم بنصّ القرآن، فيبعد أن يكون المُقرّبون في غيرها أكثر منها، اللهم إلا أن يُقابل مجموع الأمم بهذه الأُمّة، والظاهر أنّ المُقرّبين من هؤلاء أكثر من سائر الأمم، والله أعلم. والقول الثاني في هذا المقام هو الراجح، وهو أن يكون المراد بقوله: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</q> أي: من صدر هذه الأُمّة، <q>﴿وقَلِيلٌ مِنَ الآخِرِينَ﴾</q> أي: من هذه الأُمّة». ونقل ابنُ عطية (٨/١٩٢-١٩٣) رواية «عن عائشة أنها تأوَّلت أنّ الفريقين في أُمّة كلّ نبي هي في الصدر ثُلّة، وفي آخر الأمة قليل». ",footnotes:1:أخرجه الطبراني في مسند الشاميين ١/٢٩٨ (٥٢٠)، وابن عساكر في تاريخه ٤٠/٢٢٩. وأخرج الثعلبي ٩/٢١١-٢١٢ نحوه، والبغوي في تفسيره ٨/١٦ موقوفًا على عروة بن رويم.٦٤٢٣ (١٤/١٨١) ٦٤٢٣ ذكر ابنُ كثير (١٣/٣٥٣) هذا الحديث من رواية ابن عساكر بسنده عن هشام بن عمار، عن عبد ربه بن صالح، عن عروة بن رويم، عن جابر بن عبد الله ﵁ مرفوعًا، ثم انتقده قائلًا: "هكذا أورده في ترجمة عروة بن رويم، إسنادًا ومتنًا، ولكن في إسناده نظر". ٧٤٨٤١- عن أبي هريرة، قال: لَمّا نَزَلَتْ: <q>﴿ثلة من الأولين وقليل من الآخرين﴾</q> شقّ ذلك على المسلمين؛ فنَزَلَتْ: <q>﴿ثلة من الأولين وثلة من الآخرين﴾</q> فقال: أنتم ثلث أهل الجنة، بل أنتم نصف أهل الجنة، وتُقاسِمونهم النصف الباقي[[أخرجه أحمد ١٥/٣٨ (٩٠٨٠). إسناده ليّن؛ فيه شريك بن عبد الله النخعي القاضي، قال عنه ابن حجر في التقريب (٢٧٨٧): «صدوق يخطئ كثيرًا، تغيّر حفظه منذ ولي القضاء بالكوفة».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه الثعلبي ٩/٢٠٣.أخرجه الفريابي -كما في الفتح ٨/٦٢٦-، وعبد بن حميد -كما في تغليق التعليق ٤/٣٣٥-، وابن جرير ٢٢/٣٣٠.تفسير مقاتل بن سليمان ٤/٢١٦.عزاه السيوطي إلى ابن المنذر.
