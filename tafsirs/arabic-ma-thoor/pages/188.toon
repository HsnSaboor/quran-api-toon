quran[7]{c,v,t}:
9,7," <q>﴿كَیۡفَ یَكُونُ لِلۡمُشۡرِكِینَ عَهۡدٌ عِندَ ٱللَّهِ وَعِندَ رَسُولِهِۦۤ﴾</q> - تفسير ٣١٧٥٤- قال مقاتل بن سليمان: ثم ذكَّرهم أيضًا مشركي مكة، فقال: <q>﴿كَيْفَ يَكُونُ لِلْمُشْرِكِينَ عَهْدٌ عِنْدَ اللَّهِ وعِنْدَ رَسُولِهِ﴾</q>{1}. (ز) ٣١٧٥٥- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿كيف يكون للمشركين﴾</q> الذين كانوا هم وأنتم على العهد العامِّ بأن لا تُخيفوهم ولا يُخِيفوكم من الحرمة، ولا في الشهر الحرام{2}. (ز) <q>﴿إِلَّا ٱلَّذِینَ عَـٰهَدتُّمۡ عِندَ ٱلۡمَسۡجِدِ ٱلۡحَرَامِۖ فَمَا ٱسۡتَقَـٰمُوا۟ لَكُمۡ فَٱسۡتَقِیمُوا۟ لَهُمۡۚ إِنَّ ٱللَّهَ یُحِبُّ ٱلۡمُتَّقِینَ ۝٧﴾</q> - تفسير ٣١٧٥٦- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، قال: قريش{3}. (٧/٢٤٨) ٣١٧٥٧- عن عبد الله بن عباس -من طريق علي- <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، يعني: أهل مكة{4}. (ز) ٣١٧٥٨- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q> يقول: هم قوم كان بينهم وبين النبي ﷺ مُدَّةٌ، ولا ينبغي لمشرك أن يدخل المسجد الحرام، ولا مَن يعطي المسلم الجزية، <q>﴿فما استقاموا لكم فاستقيموا لهم﴾</q> يعني: أهل العهد من المشركين{4}. (ز) ٣١٧٥٩- عن محمد بن عبّاد بن جعفر -من طريق ابن جُرَيْج- قوله: <q>﴿إلا الذين عاهدتم من المشركين﴾</q>، قال: هم جَذِيمة بكر كنانة{6}. (ز) ٣١٧٦٠- عن مجاهد بن جبر -من طريق ابن جُرَيج- <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، قال: أهل العهد من خزاعة{7}. (ز) ٣١٧٦١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q> قال: هو يوم الحديبية، <q>﴿فما استقاموا لكم فاستقيموا لهم﴾</q> قال: فلم يَسْتَقيِموا ونَقَضوا عهدَهم، أعانوا بني بكرٍ حِلفَ قريش على خزاعةَ حُلفاء النبيِّ ﷺ{8}. (٧/٢٤٩) ٣١٧٦٢- عن إسماعيل السدي -من طريق أسباط- في قوله: <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، قال: هم بنو جَذِيمة بن فلان{9}. (٧/٢٤٩) ٣١٧٦٣- قال محمد بن السائب الكلبي: هم من قبائل بكر: بنو جَذِيمة، وبنو مُدْلِج، وبنو ضَمْرَة، وبنو الدِّيل، وهم الذين كانوا قد دخلوا في عهد قريش يوم الحديبية، ولم يكن نقض العهدَ إلا قريشٌ وبنو الديل من بني بكر، فأُمِر بإتمام العهد لمن لَم ينقض، وهم بنو ضَمْرَة{10}. (ز) ٣١٧٦٤- قال مقاتل بن سليمان: ثم استثنى خزاعة، وبني مدلج، وبني خزيمة{11}، الذين أجَّلهم أربعة أشهر، فقال: <q>﴿إلّا الَّذِينَ عاهَدْتُمْ عِنْدَ المَسْجِدِ الحَرامِ﴾</q> بالحديبية، فلهم العهد، <q>﴿فَما اسْتَقامُوا لَكُمْ﴾</q> بالوفاء إلى مدتهم، يعني: تمام هذه أربعة الأشهر من يوم النحر، <q>﴿فاسْتَقِيمُوا لَهُمْ﴾</q> بالوفاء، <q>﴿إنَّ اللَّهَ يُحِبُّ المُتَّقِينَ﴾</q>{1}. (ز) ٣١٧٦٥- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- قال: كان النبيُّ ﷺ قد عاهَده أناسٌ من المشركين، وعاهَد أيضًا أناسًا مِن بني ضَمْرةَ بن بكر وكِنانة خاصَّةً، عاهَدهم عند المسجد الحرام، وجعَل مُدَّتَهم أربعةَ أشهر، وهم الذين ذكَر الله: <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، <q>﴿فما استقاموا لكم فاستقيموا لهم﴾</q>. يقول: ما وفَّوا لكم بالعهد فوَفُّوا لهم ...{13}. (٧/٢٤٨) ٣١٧٦٦- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، وهي قبائل بني بكر الذين كانوا دخلوا في عهد قريش، وعقدتم يوم الحديبية، إلى المدة التي كانت بين رسول الله ﷺ وبين قريش، فلم يكن نقضها إلا هذا الحيُّ من قريش، وبنو الدُّئِل من بكر، فأُمِر بإتمام العهد لمن لم يكن نَقَضَ عهده من بني بكر إلى مدته، <q>﴿فما استقاموا لكم﴾</q> الآية{2}. (ز) ٣١٧٦٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إلا الذين عاهدتم عند المسجد الحرام﴾</q>، قال: هؤلاء قريش{15}٢٨٩٤. (٧/٢٤٨) ٢٨٩٤ أفادت الآثارُ اختلافَ المفسرين في المعنيين بقوله: <q>﴿إلا الَّذِينَ عاهَدْتُمْ عِنْدَ المَسْجِدِ الحَرامِ﴾</q> على أقوال: الأول: أنهم جَذِيمَة بكر كنانة. الثاني: أنهم قريش. الثالث: أنهم قوم من خزاعة. ورجَّح ابنُ جرير (١١/٣٥٣) مستندًا إلى دلالة التاريخ القول الأول، وهو قول السدي، ومحمد بن عباد بن جعفر، وابن إسحاق، وانتقد القولين الآخرين، فقال: «وأولى هذه الأقوال بالصواب عندي قولُ مَن قال: هم بعض بني بكر من كنانة، ... وإنما قلتُ: هذا القول أولى الأقوال في ذلك بالصواب لأنّ الله تعالى أمر نبيَّه والمؤمنين بإتمام العهد لمن كانوا عاهدوه عند المسجد الحرام، ما استقاموا على عهدهم. وقد بيَّنّا أن هذه الآيات إنما نادى بها عليٌّ ﵁ في سنة تسع من الهجرة، وذلك بعد فتح مكة بسنة، فلم يكن بمكة من قريش ولا خزاعة كافرٌ يومئذٍ بينه وبين رسول الله ﷺ عهدٌ فيؤمر بالوفاء له بعهده ما استقام على عهده؛ لأنّ مَن كان منهم من ساكني مكة كان قد نقض العهد، وحورب قبل نزول هذه الآيات». وانتقد ابنُ عطية (٤/٢٦٤) مستندًا إلى دلالة التاريخ القول الثالث بقوله: «وهو مردود بإسلام خزاعة عام الفتح». وانتقد قولَ ابن زيد في القول بأنهم قريش، وأنّ هذه الآية نزلت فلم يستقيموا ... الخ، مستندًا إلى دلالة التاريخ قائلًا: «وهو ضعيف مُتناقِض؛ لأنّ قريشًا وقت الأذان بالأربعة الأشهر لم يكن منهم إلا مسلم، وذلك بعد فتح مكة بسنة، وكذلك خزاعة». ",footnotes:1:تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن جرير ١١/٣٥١.أخرجه ابن جرير ١١/٣٥١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٥٢.أخرجه ابن جرير ١١/٣٥٢.أخرجه ابن جرير ١١/٣٥٠.أخرجه ابن جرير ١١/٣٥٣.أخرجه عبد الرزاق ٢/٢٦٧-٢٦٨، وابن جرير ١١/٣٥٢، وابن أبي حاتم ٦/١٧٥٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٧٥٦. وأخرجه ابن جرير ١١/٣٥٠ بلفظ: بنو جَذِيمة بن الدُّئِل. قال الشيخ شاكر في تحقيقه لتفسير ابن جرير ١٤/١٤١: هكذا جاء هنا: بنو جذيمة بن الدئل ... ولا أعلم في الدئل بن بكر بن عبد مناة بن كنانة: جذيمة؛ فإنّ جذيمة كنانة إنما هم: بنو جذيمة بن عامر بن عبد مناة بن كنانة، أبناء عمومة الدئل، وبكر بن عبد مناة.تفسير الثعلبي ٥/١٤، وتفسير البغوي ٤/١٤.كذا في المطبوع، ولعلها تصحفت من: بني جَذِيمةَ.تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن أبي حاتم ٦/١٧٥٦-١٧٥٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٣٥١.أخرجه ابن جرير ١١/٣٥٢، وابن أبي حاتم ٦/١٧٥٧.
9,8," <q>﴿كَیۡفَ وَإِن یَظۡهَرُوا۟ عَلَیۡكُمۡ﴾</q> - تفسير ٣١٧٦٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿كيف وإن يظهروا عليكم﴾</q>: المشركون{1}. (ز) ٣١٧٦٩- قال مقاتل بن سليمان: ثم حَرَّض المؤمنين على قتال كُفّار مكة الذين لا عهد لهم؛ لأنّهم نقضوا العهد، <q>﴿كَيْفَ﴾</q> لا تقاتلونهم <q>﴿وإنْ يَظْهَرُوا عَلَيْكُمْ لا يَرْقُبُوا فِيكُمْ إلًّا ولا ذِمَّةً﴾</q>{2}. (ز) ٣١٧٧٠- عن محمد بن إسحاق -من طريق سلمة- <q>﴿كيف وإن يظهروا عليكم﴾</q> أي: المشركون الذين لا عهد لهم إلى مُدَّة مِن أهل العهد العام <q>﴿لا يرقبوا فيكم إلا ولا ذمة﴾</q>{3}. (ز) <q>﴿لَا یَرۡقُبُوا۟ فِیكُمۡ﴾</q> - تفسير ٣١٧٧١- قال عبد الله بن عباس: <q>﴿لا يرقبوا﴾</q>: لا يحفظوا{4}. (ز) ٣١٧٧٢- عن مجاهد بن جبر -من طريق شبل، عن ابن أبي نجيح- في قوله: <q>﴿لا يرقبوا فيكم﴾</q>: لا يرقبوا في محمد ﷺ إلًّا{5}. (ز) ٣١٧٧٣- قال الضحاك بن مزاحم: <q>﴿لا يرقبوا﴾</q>: لا ينتظروا{6}. (ز) <q>﴿إِلࣰّا وَلَا ذِمَّةࣰۚ﴾</q> - تفسير ٣١٧٧٤- عن أبي مجلز لاحق بن حميد -من طريق سليمان- في قوله: <q>﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</q>، قال: مِثل قوله: جبرائيل، ميكائيل، إسرافيل، كأنه يقول: يضيف جبر وميكا وإسراف إلى إيل.= (ز) ٣١٧٧٥- يقول عبد الله: <q>﴿لا يرقبون في مؤمن إلا﴾</q>، كأنه يقول: لا يرقبون الله{7}. (ز) ٣١٧٧٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إلا ولا ذمة﴾</q>، قال: الإلُّ: القرابة، والذِّمَّةُ: العهد{8}. (٧/٢٤٩) ٣١٧٧٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿إلا ولا ذمة﴾</q>. قال: الإلُّ: القرابة، والذِّمَّة: العهد. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول: جَزى الله إلًّا كان بَيْني وبَيْنَهُم جَزاءَ ظَلُومٍ لا يُؤخِّرُ عاجِلا{9}. (٧/٢٥٠) ٣١٧٧٨- عن ميمون بن مهران، أنّ نافع بن الأزرق قال لابن عباس: أخبِرني عن قول الله تعالى: <q>﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</q>. قال: الرَّحِمُ، وقال فيه حسان بن ثابت: لعَمْرُك إن إلَّك مِن قُريش كإلِّ السَّقْبِ{10} مِن رَأْلِ{11} النَّعام{12}. (٧/٢٥٠) ٣١٧٧٩- عن عبد الله بن عباس -من طريق الضحاك- قوله: <q>﴿لا يرقبوا فيكم إلا ولا ذمة﴾</q>، قال: الإلُّ: القرابة، والذِّمَّة: العهد{13}. (ز) ٣١٧٨٠- عن الضحاك بن مزاحم في أحد قوليه= (ز) ٣١٧٨١- وقتادة بن دعامة: أنّ الذِّمَّة: العهد{14}. (ز) ٣١٧٨٢- عن سعيد بن جبير، في قوله: <q>﴿إلا﴾</q> قال: إلهًا، <q>﴿ولا ذمة﴾</q> قال: العقد{14}. (ز) ٣١٧٨٣- عن مجاهد بن جبر -من طريق مَعْمَر، عن ابن أبي نَجِيح- <q>﴿لا يرقبوا فيكم إلا ولا ذمة﴾</q>: لا يراقبون اللهَ، ولا غيره{16}. (ز) ٣١٧٨٤- عن مجاهد بن جبر -من طريق سفيان، عن ابن أبي نجيح- قال: الإلُّ: الله ﷿{17}. (٧/٢٤٩) ٣١٧٨٥- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- <q>﴿إلا﴾</q>، قال: عهدًا{18}. (ز) ٣١٧٨٦- عن عبد الرحمن بن زيد بن أسلم، نحو ذلك{19}. (ز) ٣١٧٨٧- عن مجاهد بن جبر -من طريق خصيف- <q>﴿ولا ذمة﴾</q>، قال: الذِّمَّة: العهد{20}. (ز) ٣١٧٨٨- عن الضحاك بن مزاحم -من طريق حوشب-: الإلُّ: القرابة{21}. (ز) ٣١٧٨٩- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- قال: في قوله: <q>﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</q>، الإلُّ: القرابة، والذِّمة: الميثاق{22}. (ز) ٣١٧٩٠- عن الضحاك بن مزاحم - من طريق بديل- <q>﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</q>، قال: الذمة: الحِلْف{23}. (ز) ٣١٧٩١- عن عكرمة مولى ابن عباس، قال: الإلُّ: الله{24}. (٧/٢٤٩) ٣١٧٩٢- عن قتادة بن دعامة -من طريق معمر- قال: الإلُّ: الحِلْفُ، والذِّمَّةُ: العهد{25}. (٧/٢٤٩) ٣١٧٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط-: لا يرقبوا فيكم عهدًا، ولا قرابة، ولا ميثاقًا{26}. (ز) ٣١٧٩٤- قال مقاتل بن سليمان: <q>﴿لا يَرْقُبُوا فِيكُمْ إلًّا ولا ذِمَّةً﴾</q>، يقول: لا يحفظوا فيكم قرابةً ولا عهدًا{2}. (ز) ٣١٧٩٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا يرقبوا فيكم إلا ولا ذمة﴾</q> قال: لا يرقبوا فيكم عهدًا ولا ذِمَّةً. قال: إحداهما من صاحبتها كهيئة <q>﴿غفور رحيم﴾</q>. قال: فالكلمة واحدة، وهي تفترق. قال: والعهد: هو الذمة{28}٢٨٩٥. (ز) ٢٨٩٥ أفادت الآثارُ اختلاف المفسرين في معنى: الإلّ على أقوال: الأول: أنه القرابة. الثاني: أنه الله تعالى. الثالث: أنه الحِلف. الرابع: أنه العهد. ورجَّح ابنُ جرير (١١/٣٥٨) مستندًا إلى دلالة العموم شمول معنى اللفظ لجميع الأقوال، فبيَّن أن الإلّ: «اسم يشتمل على معانٍ ثلاثة: وهي العهد والعقد، والحِلف، والقرابة، وهو أيضًا بمعنى: الله. فإذ كانت الكلمة تشمل هذه المعاني الثلاثة، ولم يكن الله خصَّ من ذلك معنًى دون معنًى؛ فالصواب أن يَعُمَّ ذلك كما عمَّ بها -جلَّ ثناؤه- معانيها الثلاثة، فيقال: لا يرقبون في مؤمنٍ الله، ولا قرابة، ولا عهدًا، ولا ميثاقًا». ورجَّح ابنُ كثير (٧/١٥٤) القول الأول لكونِه الأشهر لغة، والأظهر لفظًا، وعليه الأكثر من المفسّرين، وهو قول ابن عباس، والضحاك، والسدي من طريق أسباط، فقال: «والقول الأول أشهر وأظهر، وعليه الأكثر». <q>﴿یُرۡضُونَكُم بِأَفۡوَ ٰ⁠هِهِمۡ وَتَأۡبَىٰ قُلُوبُهُمۡ وَأَكۡثَرُهُمۡ فَـٰسِقُونَ ۝٨﴾</q> - تفسير ٣١٧٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وأكثرهم فاسقون﴾</q>، قال: القرون الماضية{23}. (ز) ٣١٧٩٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأكثرهم فاسقون﴾</q>، قال: ذَمَّ اللهُ تعالى أكثرَ الناس{23}. (٧/٢٥٠) ٣١٧٩٨- قال مقاتل بن سليمان: <q>﴿يُرْضُونَكُمْ بِأَفْواهِهِمْ﴾</q> يعني: بألسنتهم، <q>﴿وتَأبى قُلُوبُهُمْ﴾</q> وكانوا يُحْسِنون القول للمؤمنين، فيرضونهم، وفي قلوبهم غيرُ ذلك، فأخبر عن قولهم، فذلك قوله: <q>﴿يُرْضُونَكُمْ بِأَفْواهِهِمْ﴾</q> يعني: بألسنتهم، <q>﴿وتَأبى قُلُوبُهُمْ وأَكْثَرُهُمْ فاسِقُونَ﴾</q>{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١١/٣٥٦، وابن أبي حاتم ٦/١٧٥٧.تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن جرير ١١/٣٥٩.تفسير الثعلبي ٥/١٤.أخرجه ابن أبي حاتم ٦/١٧٥٧.تفسير الثعلبي ٥/١٤، وتفسير البغوي ٤/١٥.أخرجه ابن جرير ١١/٣٥٥.أخرجه ابن جرير ١١/٣٥٥، وابن أبي حاتم ٦/١٧٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى الطستي. وينظر: الإتقان ٢/٩٨.السَّقْبُ: ولد الناقة، وقيل: الذَّكَر من ولد الناقة. اللسان (سقب).الرأْل: ولدُ النعام، وخصَّ بعضهم به الحَوْليَّ منها. اللسان (رأل).عزاه السيوطي إلى ابن الأنباري في كتاب الوقف والابتداءأخرجه ابن أبي حاتم ٦/١٧٥٨.علقه ابن أبي حاتم ٦/١٧٥٨.علقه ابن أبي حاتم ٦/١٧٥٨.أخرجه عبد الرزاق ١/٢٦٨، وابن جرير ١١/٣٥٥، وابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٥، وابن أبي حاتم ٦/١٧٥٨. وعزاه السيوطي إلى الفريابي، وأبي عبيد، وابن المنذر، وأبي الشيخ.تفسير مجاهد ص٣٦٥، وأخرجه ابن جرير ١١/٣٥٧ من طريق عيسى عن ابن أبي نجيح، وابن أبي حاتم ٦/١٧٥٨.علَّقه ابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٧. وعلَّقه ابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٥. وعلقه ابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٦.أخرجه ابن أبي حاتم ٦/١٧٥٩.عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٥٧، وابن أبي حاتم ٦/١٧٥٨ وعلَّق آخره. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٥٦، وابن أبي حاتم ٦/١٧٥٨.تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن جرير ١١/٣٥٧.أخرجه ابن أبي حاتم ٦/١٧٥٩.أخرجه ابن أبي حاتم ٦/١٧٥٩.تفسير مقاتل بن سليمان ٢/١٥٨.
9,9," <q>﴿ٱشۡتَرَوۡا۟ بِـَٔایَـٰتِ ٱللَّهِ ثَمَنࣰا قَلِیلࣰا فَصَدُّوا۟ عَن سَبِیلِهِۦۤۚ إِنَّهُمۡ سَاۤءَ مَا كَانُوا۟ یَعۡمَلُونَ ۝٩﴾</q> - تفسير ٣١٧٩٩- قال عبد الله بن عباس: وذلك أنّ أهلَ الطائف أمَدُّوهم بالأموال؛ لِيُقَوُّوهم على حربِ رسول الله ﷺ{1}. (ز) ٣١٨٠٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿اشتروا بآيات الله ثمنا قليلا﴾</q>، قال: أبو سفيان بن حرب أطعَم حلفاءَه، وترَك حلفاءَ محمد ﷺ{2}٢٨٩٦. (٧/٢٥٠) ٢٨٩٦ لم يذكر ابنُ جرير (١١/٣٦٠) في معنى: <q>﴿اشْتَرَوْا بِآياتِ اللَّهِ ثَمَنًا قَلِيلًا﴾</q> سوى قول مجاهد. ٣١٨٠١- قال عطاء: كان أبو سفيان يُعْطِي الناقةَ والطعامَ لِيَصُدَّ الناس بذلك عن مُتابَعَةِ النبي ﷺ{3}. (ز) ٣١٨٠٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿عن سبيله﴾</q>، قال: عن الإسلام{4}. (ز) ٣١٨٠٣- قال مقاتل بن سليمان: <q>﴿اشْتَرَوْا بِآياتِ اللَّهِ ثَمَنًا قَلِيلًا﴾</q>، يعني: باعوا إيمانًا بالقرآن بعَرَضٍ من الدنيا [يسيرٍ]، وذلك أنّ أبا سفيان كان يُعْطِي الناقةَ والطعامَ والشيءَ ليصد بذلك الناسَ عن متابعة النبي ﷺ، فذلك قوله: <q>﴿فَصَدُّوا﴾</q> الناسَ <q>﴿عَنْ سَبِيلِهِ﴾</q> أي: عن سبيل الله، يعني: عن دين الله، وهو الإسلام، <q>﴿إنَّهُمْ ساءَ﴾</q> يعني: بئس <q>﴿ما كانُوا يَعْمَلُونَ﴾</q> يعني: بئس ما عملوا بصدِّهم عن الإسلام{5}٢٨٩٧. (ز) ٢٨٩٧ ذكر ابنُ عطية (٤/٢٦٨) قولًا عن بعض الناس: بأنّ هذه الآية في اليهود، ثم انتَقَدَه مستندًا إلى مخالفة السياق قائلًا: «وهذا القول وإن كانت ألفاظُ هذه الآية تقتضيه؛ فما قبلها وما بعدها يَرُدُّه، ويتبرأ منه، ويختل أسلوب القول به». ",footnotes:1:تفسير الثعلبي ٥/١٥، وتفسير البغوي ٤/١٦.تفسير مجاهد ص٣٦٤، وأخرجه ابن جرير ١١/٣٦٠، وابن أبي حاتم ٦/١٧٥٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/١٥.أخرجه ابن أبي حاتم ٦/١٧٥٩.تفسير مقاتل بن سليمان ٢/١٥٨-١٥٩.
9,10," <q>﴿لَا یَرۡقُبُونَ فِی مُؤۡمِنٍ إِلࣰّا وَلَا ذِمَّةࣰۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُعۡتَدُونَ ۝١٠﴾</q> - تفسير ٣١٨٠٤- قال مقاتل بن سليمان: <q>﴿لا يَرْقُبُونَ فِي مُؤْمِنٍ إلًّا ولا ذِمَّةً﴾</q> يعني: لا يحفظون في مؤمن قرابةً ولا عهدًا، <q>﴿وأُولئِكَ هُمُ المُعْتَدُونَ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/١٥٩.
9,11," <q>﴿فَإِن تَابُوا۟ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ﴾</q> - تفسير ٣١٨٠٥- عن عبد الله [بن مسعود] -من طريق أبي عبيدة- قال: أُمِرْتُم بإقامة الصلاة، وإيتاء الزكاة، ومَن لم يُزَكِّ فلا صلاة له{1}. (ز) ٣١٨٠٦- عن عبد الله بن عباس -من طريق رجل- قال: حَرَّمتْ هذه الآيةُ قتالَ أو دماءَ أهلِ الصلاة: <q>﴿فإن تابوا وأقاموا الصلاة وءاتوا الزكاة فإخوانكم في الدين﴾</q>{2}. (٧/٢٥١) ٣١٨٠٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فإن تابوا وأقاموا الصلاة وءاتوا الزكاة فإخوانكم في الدين﴾</q>، يقول: إن ترَكوا اللاتَ والعُزّى، وشهِدوا أن لا إله إلا الله، وأنّ محمدًا رسول الله؛ فإخوانُكم في الدين{3}. (٧/٢٥٠) ٣١٨٠٨- قال مقاتل بن سليمان: <q>﴿فَإنْ تابُوا﴾</q> من الشرك، <q>﴿وأَقامُوا الصَّلاةَ وآتَوُا الزَّكاةَ﴾</q> أي: أقرُّوا بإقام الصلاة، وإيتاء الزكاة{4}. (ز) ٣١٨٠٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: افتُرِضَت الصلاةُ والزكاةُ جميعًا، لم يُفَرَّق بينهما. وقرأ: <q>﴿فإن تابوا وأقاموا الصلاة وآتوا الزكاة فإخوانكم في الدين﴾</q>، وأبى أن يقبلَ الصلاةَ إلا بالزكاة. وقال: رحم الله أبا بكر ما كان أفقهَه{1}٢٨٩٨. (ز) ٢٨٩٨ علَّق ابنُ عطية (٤/٢٦٨) على قول ابن زيد بقوله: «وعلى هذا مرَّ أبو بكر ﵄ وقت الرِّدَّة». <q>﴿فَإِخۡوَ ٰ⁠نُكُمۡ فِی ٱلدِّینِۗ وَنُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝١١﴾</q> - تفسير ٣١٨١٠- عن قتادة بن دعامة -من طريق شيبان بن عبد الرحمن- قوله: <q>﴿فإخوانكم في الدين﴾</q>، قال: فكونوا مِن إخوة الإسلام، مِمَّن يرعاهم، ويعاهد عليها، ويعظم حقَّها، فإنّ أفضل المسلمين أوصلُهم لإخوة الإسلام{6}. (ز) ٣١٨١١- قال مقاتل بن سليمان: <q>﴿فَإخْوانُكُمْ فِي الدِّينِ ونُفَصِّلُ ونبين الآياتِ لِقَوْمٍ يَعْلَمُونَ﴾</q> بتوحيد الله{4}. (ز) <q>﴿فَإِخۡوَ ٰ⁠نُكُمۡ فِی ٱلدِّینِۗ وَنُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝١١﴾</q> - آثار متعلقة بالآية ٣١٨١٢- عن أنس بن مالك، قال: قال رسول الله ﷺ: «مَن صلّى صلاتنا، واستقبل قبلتنا، وأكل ذبيحتنا؛ فذلك المسلمُ الذي له ذِمَّةُ الله وذِمَّةُ رسوله، فلا تَخْفِروا{8} اللهَ في ذِمَّته»{9}. (ز) ٣١٨١٣- عن أبي هريرة، قال: لَمّا تُوُفِّي رسولُ الله ﷺ، وكان أبو بكر بعده، وكَفَرَ مَن كَفَرَ مِن العرب؛ قال عمر بن الخطاب لأبي بكر: كيف تقاتلُ الناسَ وقد قال رسول الله ﷺ: «أُمِرْتُ أن أقاتل الناس حتى يقولوا: لا إله إلا الله. فمَن قال: لا إله إلا الله. عَصَمَ مِنِّي مالَه، ونفسَه، إلا بحقِّه، وحسابُه على الله»؟! فقال أبو بكر: واللهِ، لَأُقاتِلَنَّ مَن فَرَّق بين الصلاة والزكاة؛ فإنّ الزكاة حقُّ المال، واللهِ، لو منعوني عَناقًا{10} كانوا يُؤَدُّونها إلى رسول الله ﷺ لَقاتلتُهم على منعها. قال عمر: فواللهِ، ما هو إلا أن قد شُرِح صدرُ أبي بكر للقتال، فعرفتُ أنّه الحق{11}. (ز) ",footnotes:1:أخرجه ابن جرير ١١/٣٦٢.أخرجه ابن جرير ١١/٣٦٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٣٦١، وابن أبي حاتم ٦/١٧٦٠. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/١٥٩.أخرجه ابن جرير ١١/٣٦٢.أخرجه ابن أبي حاتم ٦/١٧٦٠.تفسير مقاتل بن سليمان ٢/١٥٩.تُخْفِروا الله: أي لا تنقُضوا عهدَه وذِمامه. النهاية (خفر).أخرجه البخاري ١/٨٧ (٣٩١).العَناق: الأنثى من أولاد المَعْز ما لم يَتِمَّ له سنة. النهاية (عنق).أخرجه البخاري ٢/١٠٥-١٠٦ (١٣٩٩، ١٤٠٠)، ٩/١٥ (٦٩٢٤، ٦٩٢٥)، ٩/٩٣-٩٤ (٧٢٨٤)، ومسلم ١/٥١ (٢٠).
9,12," <q>﴿وَإِن نَّكَثُوۤا۟ أَیۡمَـٰنَهُم مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ لَهُمۡ لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾</q> - قراءات ٣١٨١٤- عن الحسن البصري أنّه قرأ: ‹إنَّهُمْ لَآ إيمانَ› بكسر الألف{1}٢٨٩٩. (ز) ٢٨٩٩ وجَّه ابن جرير (١١/ ٣٦٦) قراءة الحسن فذكر أنها: «بمعنى: لا إسلام لهم. وقد يُتوجَّه لقراءته كذلك وجه غير هذا، وذلك أن يكون أراد بقراءته ذلك كذلك: أنهم لا أمان لهم، أي لا تُؤمِنوهم، ولكن اقتلوهم حيث وجدتموهم، كأنه أراد المصدر من قول القائل: آمنته، فأنا أومنه إيمانًا». ثم انتقدها مستندًا إلى الإجماع فقال: «والصواب من القراءات في ذلك الذي لا أستجيز القراءة بغيره، قراءة من قرأ بفتح الألف دون كسرها؛ لإجماع الحجة من القراء على القراءة به ورفض خلافه؛ ولإجماع أهل التأويل على ما ذكرت من أن تأويله لا عهد لهم. والأيمان التي هي بمعنى العهد، لا تكون إلا بفتح الألف؛ لأنها جمع يمين كانت على عقد كان بين المتوادعين». <q>﴿وَإِن نَّكَثُوۤا۟ أَیۡمَـٰنَهُم مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ لَهُمۡ لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾</q> - نزول الآية ٣١٨١٥- قال عبد الله بن عباس: نزلت في أبي سفيان بن حرب، والحارث بن هشام، وسهيل بن عمرو، وعكرمة بن أبي جهل، وسائر رؤساء قريش يومئذٍ الذين نقضوا العهد، وهم الذين هَمُّوا بإخراج الرسول{2}. (ز) ٣١٨١٦- قال محمد بن السائب الكلبي، في قوله: <q>﴿وإن نكثوا أيمانهم من بعد عهدهم وطعنوا في دينكم﴾</q> إلى قوله: <q>﴿والله عليم حكيم﴾</q>: إنّ رسول الله ﷺ كان وادَعَ أهل مكة سنة، وهو يومئذ بالحديبية، فحبسوه عن البيت، ثم صالحوه على أنّك ترجع عامَك هذا، ولا تَطَأ بلدَنا، ولا تنحر البُدْن من أرضنا، وأن نُخَلِّيها لك عامًا قابلًا ثلاثة أيام، ولا تأتينا بالسلاح إلا سلاحًا تجعلها في قِراب{3}، وأنّه مَن صَبَأَ مِنّا إليك فهو إلينا رَدٌّ. فصالحهم رسول الله على ذلك، فمكثوا ما شاء الله أن يمكثوا، ثم إنّ حلفاء رسول الله من خُزاعة قاتلوا حلفاء بني أُمِيَّة مِن بني كنانة؛ فأَمَدَّتْ بنو أُمَيَّةَ حلفاءَهم بالسلاح والطعام، فركب ثلاثون رجلًا من حُلفاء رسول الله من خُزاعة، فيهم بديل بن ورقاء، فناشدوا رسول الله الحِلْف، فأمر رسول الله ﷺ أن يعين حلفاءه، وأنزل الله على نبيه: <q>﴿وإن نكثوا أيمانهم من بعد عهدهم وطعنوا في دينكم فقاتلوا أئمة الكفر إنهم لا أيمان لهم﴾</q>: لا عهد لهم؛ <q>﴿لعلهم ينتهون﴾</q>{4}. (ز) <q>﴿وَإِن نَّكَثُوۤا۟ أَیۡمَـٰنَهُم مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ﴾</q> - تفسير ٣١٨١٧- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وإن نكثوا أيمانهم من بعد عهدهم﴾</q>، يقول اللهُ لنبيِّه ﷺ: وإن نكَثوا العهدَ الذي بينك وبينهم فقاتِلْهم؛ إنهم أئمةُ الكفر{5}. (٧/٢٥١) ٣١٨١٨- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿وإن نكثوا أيمانهم﴾</q>، قال: عهدَهم{6}. (٧/٢٥١) ٣١٨١٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وإنْ نَكَثُوا أيْمانَهُمْ﴾</q>: عهدهم الذي عاهدوا على الإسلام{7}. (ز) ٣١٨٢٠- قال مقاتل بن سليمان: <q>﴿وإنْ نَكَثُوا أيْمانَهُمْ مِن بَعْدِ عَهْدِهِمْ﴾</q> يعني: نقضوا عهدَهم، وذلك أنّ النبيَّ ﷺ واعد كُفّار مكة سنتين، وأنهم عمدوا فأعانوا كِنانة بالسِّلاح على قتال خزاعة، وخزاعة صُلْح النبي ﷺ، فكان في ذلك نكثٌ للعهد، فاستحلَّ النبيُّ ﷺ قتالَهم، فذلك قوله: <q>﴿وإنْ نَكَثُوا أيْمانَهُمْ﴾</q>، <q>﴿وطَعَنُوا فِي دِينِكُمْ﴾</q> فقالوا: ليس دينُ محمد بشيء{8}. (ز) <q>﴿فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ﴾</q> - تفسير ٣١٨٢١- عن عبد الرحمن بن جبير بن نفير: أنّه كان في عهد أبي بكر إلى الناس حينَ وجَّهَهم إلى الشام، فقال: إنّكم ستَجِدون قومًا مُحَوَّقةً{9} رءوسُهم، فاضرِبوا مقاعدَ الشيطان منهم بالسيوف، فواللهِ، لأن أقتُلَ رجلًا منهم أحبُّ إلَيَّ مِن أن أقتُلَ سبعينَ مِن غيرِهم، وذلك بأنّ الله تعالى يقول: <q>﴿فقاتلوا أئمة الكفر﴾</q>{10}. (٧/٢٥٣) ٣١٨٢٢- عن زيد بن وهب، في قوله: <q>﴿فقاتلوا أئمة الكفر﴾</q>، قال: كُنّا عندَ حذيفةَ [بن اليمان]، فقال: ما بَقِي مِن أصحاب هذه الآية إلا ثلاثة، ولا مِن المنافقين إلا أربعة. فقال أعرابيٌّ: إنّكم -أصحابَ محمدٍ ﷺ- تُخْبِروننا بأمورٍ لا نَدْري، فما بالُ هؤلاء الذين يَبْقُرون{11} بيوتَنا، ويَسْرِقون أعلاقَنا{12}؟ قال: أولئك الفُسّاق، أجَلْ، لم يَبْقَ منهم إلا أربعة؛ أحدُهم شيخٌ كبيرٌ، لو شَرِب الماءَ البارد لَما وجَد بَرْدَه{13}. (٧/٢٥٢) ٣١٨٢٣- عن حذيفة بن اليمان -من طريق زيد بن وهب- أنّهم ذكَروا عندَه هذه الآية، فقال: ما قُوتِل أهلُ هذه الآيةِ بعد{14}. (٧/٢٥٢) ٣١٨٢٤- عن علي بن أبي طالب، قال: واللهِ، ما قُوتِل أهلُ هذه الآية منذُ أُنزِلت: <q>﴿وإن نكثوا أيمانهم من بعد عهدهم﴾</q> الآية{15}. (٧/٢٥٣) ٣١٨٢٥- عن مصعب بن سعد، قال: مَرَّ سعد [بن أبي وقاص] برجلٍ مِن الخوارج، فقال الخارجيُّ لسعد: هذا مِن أئمةِ الكفر. فقال سعد: كَذَبْتَ، بل أنا قاتَلْتُ أئِمَّةَ الكفر{16}. (٧/٢٥٣) ٣١٨٢٦- عن عبد الله بن عباس، <q>﴿فقاتلوا أئمة الكفر﴾</q>، قال: رءوس قريش{17}. (٧/٢٥٢) ٣١٨٢٧- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿فقاتلوا أئمة الكفر﴾</q>، يعني: أهل العهد من المشركين، سمّاهم: أئمة الكفر، وهم كذلك{18}. (ز) ٣١٨٢٨- عن عبد الله بن عمر -من طريق مجاهد- في قوله: <q>﴿فقاتلوا أئمة الكفر﴾</q>، قال: أبو سفيان بن حرب منهم{19}. (٧/٢٥٢) ٣١٨٢٩- عن سعيد بن جبير، مثله{20}. (ز) ٣١٨٣٠- عن مجاهد بن جبر -من طريق أبي بشر- في قوله: <q>﴿فقاتلوا أئمة الكفر﴾</q>، قال: أبو سفيان{21}. (٧/٢٥٢) ٣١٨٣١- عن الضحاك بن مُزاحِم -من طريق عبيد بن سليمان- في قوله: <q>﴿فقاتلوا أئمة الكفر﴾</q>، يعني: رءوس المشركين، أهل مكة{22}. (ز) ٣١٨٣٢- عن الحسن البصري، <q>﴿فقاتلوا أئمة الكفر﴾</q>، قال: الدَّيْلمُ{23}. (٧/٢٥٢) ٣١٨٣٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أئمة الكفر﴾</q>، قال: أبو سفيان بن حرب، وأُمَيَّةُ بن خلف، وعُتْبةُ بن ربيعة، وأبو جهل بن هشام، وسُهَيلُ بن عمرو، وهم الذين نكَثوا عهدَ الله، وهَمُّوا بإخراجِ الرسول ﷺ من مكة{24}. (٧/٢٥١) ٣١٨٣٤- عن مالك بن أنس، مثلَه{25}. (٧/٢٥٢) ٣١٨٣٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وإن نكثوا أيمانهم﴾</q> إلى: <q>﴿ينتهون﴾</q>: هؤلاء قريش، يقول: إن نكثوا عهدهم الذي عاهدوا على الإسلام وطعنوا فيه، فقاتلوهم {26}. (ز) ٣١٨٣٦- قال مقاتل بن سليمان: <q>﴿فَقاتِلُوا أئِمَّةَ الكُفْرِ﴾</q>، يعني: قادة الكُفْر؛ كفار قريش: أبا سفيان بن حرب، والحارث بن هشام، وسهيل بن عمرو، وعكرمة بن أبي جهل، وغيرهم{8}٢٩٠٠. (ز) ٢٩٠٠ أفادت الآثارُ اختلافَ المفسرين في المعنيين بأئمة الكفر على قولين: الأول: هم أبو جهل، وعتبة بن ربيعة، وأبو سفيان بن حرب، ونظراؤهم. والثاني: أنه لم يأتِ أهلها بعدُ. ورجَّح ابنُ عطية (٤/٢٧٠) مستندًا إلى دلالة العموم شمول الآية لهذه الأقوال، فقال: «وأَصْوَبُ ما في هذا أن يُقال: إنّه لا يُعنى بها مُعيَّن، وإنما وقع الأمر بقتال أئمة الناكثين بالعهود من الكَفَرة إلى يوم القيامة دون تعيين، واقتضت حال كفار العرب ومحاربي رسول الله ﷺ أن تكون الإشارة إليهم أولًا بقوله: <q>﴿أئِمَّةَ الكُفْرِ﴾</q>، وهم حصلوا حينئذ تحت اللفظة؛ إذ الذي يتولى قتال النبي ﷺ والدفع في صدر شريعته هو إمام مَن يَكْفُر بذلك الشرع إلى يوم القيامة، ثم تأتي في كل جيل من الكفار أئمة خاصة بجيلٍ جيل». ووافقه ابنُ كثير (٧/١٥٥) فقال: «الآية عامَّةٌ، وإن كان سبب نزولها مشركي قريش، فهي عامَّة لهم ولغيرهم». وانتقد ابنُ عطية مستندًا إلى التاريخ قول قتادة بأنّه أبو جهل وأضرابه قائلًا: «وهذا -إن لم يُتَأَوَّل أنّه ذكرهم على جهة المثال- ضعيف؛ لأن الآية نزلت بعد بدر بكثير». ووجَّه قول حذيفة ﵁ بقوله: «يريد: لم ينقرضوا، فهم يحيون أبدًا ويُقاتلون». <q>﴿إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ لَهُمۡ﴾</q> - تفسير ٣١٨٣٧- عن حذيفة بن اليمان -من طريق صِلَة بن زُفَر- <q>﴿لا أيمان لهم﴾</q>، قال: لا عُهُودَ لهم{28}. (٧/٢٥٣) ٣١٨٣٨- عن عمار بن ياسر -من طريق صِلَة بن زُفَر- <q>﴿لا أيمان لهم﴾</q>: لا عُهُودَ لهم{29}. (٧/٢٥٣) ٣١٨٣٩- عن صِلَة بن زُفَر -من طريق أبي إسحاق- <q>﴿إنهم لا أيمان لهم﴾</q>: لا عهد لهم{30}. (ز) ٣١٨٤٠- عن عطية العوفي، قال: لا دين لهم {31}. (ز) ٣١٨٤١- قال مقاتل بن سليمان: <q>﴿إنَّهُمْ لا أيْمانَ لَهُمْ﴾</q>؛ لأنهم نقضوا العهد الذي كان بالحديبية{8}. (ز) <q>﴿لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾</q> - تفسير ٣١٨٤٢- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿لعلهم ينتهون﴾</q>، يعني: أهل العهد من المشركين{33}. (ز) ٣١٨٤٣- قال مقاتل بن سليمان: يقول: <q>﴿لَعَلَّهُمْ﴾</q> يعني: لكي <q>﴿يَنْتَهُونَ﴾</q> عن نقض العهد، ولا يَنقُضون{8}. (ز) ",footnotes:1:علقه ابن جرير ١١/٣٦٦. وهي قراءة متواترة، قرأ بها ابن عامر، وقرأ بقية العشرة: <q>﴿لَآ أيْمانَ﴾</q> بفتح الهمزة. انظر: النشر ٢/٢٧٨، والإتحاف ص٣٠٢.أورده الواحدي في أسباب النزول ص٢٤٣، والثعلبي ٥/١٦.القِراب: هو شبه الجِراب يطرح فيه الراكب سيفَه بغِمْدِهِ وسوطِهِ، وقد يطرح فيه زاده من تَمْرٍ وغيره. النهاية (قرب).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٩٦-.أخرجه ابن جرير ١١/٣٦٣، وابن أبي حاتم ٦/١٧٦٠-١٧٦١. وعزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٣٦٥، وأخرجه ابن جرير ١١/٣٦٥-٣٦٦. وعزاه السيوطي إلى عبيد بن حميد، وابن المنذر.أخرجه ابن جرير ١١/٣٦٦.تفسير مقاتل بن سليمان ٢/١٥٩.محوقة: مكنوسة. إذ الحوق: الكنس. أراد أنهم حلقوا وسط رءوسهم، فشبَّه إزالة الشعر منه بالكنس. النهاية (حوق).أخرجه ابن أبي حاتم ٦/١٧٦١.يَبْقُرون بيوتنا: أي: يفتحونها ويوسِّعونها. النهاية (بقر).الأعلاق جمع العِلْق -بالكسر-: وهو النَّفِيس من كل شيء. القاموس (علق).أخرجه ابن أبي شيبة ١٥/١٠٨، والبخاري (٤٦٥٨). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٥/٢٢، ١٠٨، وابن جرير ١١/٣٦٥، وابن أبي حاتم ٦/١٧٦١. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن مردويه -كما في تفسير ابن كثير ٤/٥٩-.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٣٦٣، وابن أبي حاتم ٦/١٧٦١.أخرجه ابن أبي حاتم ٦/١٧٦١، وعقّب عليه بقوله: يعني قبل أن يسلم. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.علَّقه ابن أبي حاتم ٦/١٧٦١.أخرجه ابن جرير ١١/٣٦٤، وابن عساكر -كما في مختصر تاريخ دمشق ١٢/٥١-، وفي التاريخ ٢٣/٤٣٨ تداخلٌ بين أثري مالك ومجاهد.أخرجه ابن جرير ١١/٣٦٤، وابن أبي حاتم ٦/١٧٦١.عزاه السيوطي إلى أبي الشيخ. والدَّيْلم: جٍيْل من الناس معروف يُسمّى التُّرْك. اللسان (دلم). وفي تاج العروس (دلم): هم أصحاب الشُّور الأعاجم من بلاد الشَّرق. وقال كراع: هم التُّرك.أخرجه عبد الرزاق ١/٢٦٨، وابن جرير ١١/٣٦٤-٣٦٥ وزاد: وليس -واللهِ- كما يتأوَّلُه أهلُ الشبهات والبدع والفرى على الله وعلى كتابه، وابن أبي حاتم ٦/١٧٦١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن عساكر -كما في مختصر تاريخ دمشق ١٢/٥١-، وفي التاريخ ٢٣/٤٣٨ تداخل بين أثري مالك ومجاهد.أخرجه ابن جرير ١١/٣٦٤.تفسير مقاتل بن سليمان ٢/١٥٩.أخرجه ابن جرير ١١/٣٦٦. وعلَّقه ابن أبي حاتم ٦/١٧٦٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي شيبة في مصنفه ١٥/٦٣٠ (٣١٠٨١)، وابن جرير ١١/٣٦٦، وابن أبي حاتم ٦/١٧٦٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٦٥، وابن أبي حاتم ٦/١٧٦٢.تفسير الثعلبي ٥/١٦.تفسير مقاتل بن سليمان ٢/١٥٩.أخرجه ابن أبي حاتم ٦/١٧٦٢.تفسير مقاتل بن سليمان ٢/١٥٩.
9,13," <q>﴿أَلَا تُقَـٰتِلُونَ قَوۡمࣰا نَّكَثُوۤا۟ أَیۡمَـٰنَهُمۡ وَهَمُّوا۟ بِإِخۡرَاجِ ٱلرَّسُولِ وَهُم بَدَءُوكُمۡ أَوَّلَ مَرَّةٍۚ أَتَخۡشَوۡنَهُمۡۚ فَٱللَّهُ أَحَقُّ أَن تَخۡشَوۡهُ إِن كُنتُم مُّؤۡمِنِینَ ۝١٣﴾</q> - نزول الآية ٣١٨٤٤- عن مجاهد بن جبر، في قوله: <q>﴿ألا تقاتلون قوما نكثوا أيمانهم﴾</q>، قال: قتالُ قريشٍ حلفاءَ النبي ﷺ، وهَمُّهم بإخراجِ الرسول زعَموا أنّ ذلك عامَ عمرة النبيِّ ﷺ، في العام السابع للحديبية، نكَثتْ قريشٌ العهد عهدَ الحديبية، وجعَلوا في أنفسِهم إذا دخَلوا مكةَ أن يُخْرِجوه منها، فذلك هَمُّهم بإخراجِه، فلم تُتابِعْهم خُزاعة على ذلك، فلمّا خرَج النبيُّ ﷺ مِن مكة قالت قريشٌ لخزاعة: عَمَّيتُمونا عن إخراجِه. فقاتَلوهم فقَتَلوا منهم رجالًا{1}. (٧/٢٥٣) ٣١٨٤٥- عن عكرمة -من طريق أيوب- في حديث فتح مكة: أنّ رسول الله ﷺ قال: «مَن أغلق بابَه فهو آمِن، ومَن ألقى سلاحه فهو آمِن». قال: فقاتلهم خزاعةُ إلى نصف النهار؛ وأنزل الله تعالى: <q>﴿ألا تقاتلون قوما نكثوا أيمانهم وهموا بإخراج الرسول﴾</q>{2}. (ز) <q>﴿أَلَا تُقَـٰتِلُونَ قَوۡمࣰا نَّكَثُوۤا۟ أَیۡمَـٰنَهُمۡ وَهَمُّوا۟ بِإِخۡرَاجِ ٱلرَّسُولِ﴾</q> - تفسير ٣١٨٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وهموا بإخراج الرسول﴾</q>، قال: مِن بين أظهُرِهم، فأخرَجوه{3}. (ز) ٣١٨٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: <q>﴿وهموا بإخراج الرسول﴾</q> يأثر ذلك الله تبارك وتعالى{4}. (ز) ٣١٨٤٨- قال مجاهد بن جبر: الذين هموا بإخراج الرسول هم أهل فارس والروم{5}. (ز) ٣١٨٤٩- قال الحسن البصري: <q>﴿وهموا بإخراج الرسول﴾</q> من المدينة{6}٢٩٠١. (ز) ٢٩٠١ وجَّه ابنُ عطية (٤/٢٧١) قول الحسن قائلًا: «وهذا يستقيم؛ كغزوة أحد، والأحزاب، وغيرهما». ٣١٨٥٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿ألا تقاتلون قوما نكثوا أيمانهم﴾</q> من بعد عهدهم، <q>﴿وهموا بإخراج الرسول﴾</q> يقول: هموا بإخراجه، فأخرجوه{7}٢٩٠٢. (ز) ٢٩٠٢ علَّق ابنُ عطية (٤/٢٧١-٢٧٢) على قول السدي قائلًا: «فهذا على أن يكون المعنى: همُّوا وفعلوا، أو على أن يُقال: همُّوا بإخراجه بأيديهم فلم يصلوا إلى ذلك، بل خرج بأمر الله ﷿». ثم وجَّه هذا الاحتمال بقوله: «وهذا يجري مع إنكار النبي ﷺ على أبي سفيان بن الحارث قوله: وردني لله مَن طَرَّدْتُ كل مُطَرَّد». ٣١٨٥١- عن محمد بن إسحاق -من طريق سلمة- قال: أمر اللهُ رسولَه بجهاد أهل الشرك؛ مِمَّن نَقَض مِن أهل العهد، ومَن كان من أهل العهد العامِّ بعد الأربعة الأشهر التي ضرب لهم أجلًا، إلا أن يعدُوَ فيها عادٍ منهم فيقتل بعدائه، فقال: <q>﴿ألا تقاتلون قوما نكثوا أيمانهم وهموا بإخراج الرسول﴾</q> إلى قوله: <q>﴿والله خبير بما تعملون﴾</q>{8}. (ز) ٣١٨٥٢- قال مقاتل بن سليمان: <q>﴿ألا تُقاتِلُونَ قَوْمًا نَكَثُوا أيْمانَهُمْ﴾</q> يعني: نقضوا عهدَهم حين أعانوا كنانة بالسلاح على خزاعة، وهم صلح النبي ﷺ، <q>﴿وهَمُّوا بِإخْراجِ الرَّسُولِ﴾</q> يعني: النبي ﷺ من مكة حين هَمُّوا في دار الندوة بقتل النبي ﷺ، أو بوثاقه، أو بإخراجه{9}. (ز) <q>﴿وَهُم بَدَءُوكُمۡ أَوَّلَ مَرَّةٍۚ﴾</q> - تفسير ٣١٨٥٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وهم بدؤكم أول مرة﴾</q>: قتال قريشٍ حلفاءَ محمد ﷺ{10}. (ز) ٣١٨٥٤- عن عكرمة مولى ابن عباس، نحو ذلك{11}. (ز) ٣١٨٥٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وهم بدءوكم أول مرة﴾</q> بالقتال{12}. (ز) ٣١٨٥٦- قال مقاتل بن سليمان: <q>﴿وهُمْ بَدَؤُكُمْ أوَّلَ مَرَّةٍ﴾</q> بالقتال، حين ساروا إلى قتالكم ببدر{9}. (ز) <q>﴿أَتَخۡشَوۡنَهُمۡۚ فَٱللَّهُ أَحَقُّ أَن تَخۡشَوۡهُ إِن كُنتُم مُّؤۡمِنِینَ ۝١٣﴾</q> - تفسير ٣١٨٥٧- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿مؤمنين﴾</q>، قال: مُصَدِّقين{14}. (ز) ٣١٨٥٨- قال مقاتل بن سليمان: <q>﴿أتَخْشَوْنَهُمْ﴾</q> فلا تقاتلونهم؟! <q>﴿فاللَّهُ أحَقُّ أنْ تَخْشَوْهُ﴾</q> في ترك أمره؛ <q>﴿إنْ كُنْتُمْ مُؤْمِنِينَ﴾</q> به، يعني: إن كنتم مصدِّقين بتوحيد الله ﷿{9}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٧٦٢ (١٠٠٢٨) من مرسل عكرمة.تفسير مجاهد ص٣٦٥.أخرجه ابن أبي حاتم ٦/١٧٦٢.تفسير الثعلبي ٥/١٦، وتفسير البغوي ٤/١٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٩٦-.أخرجه ابن جرير ١١/٣٦٨، وابن أبي حاتم ٦/١٧٦٢ بلفظ: وهموا بإخراج الرسول، يقول: هموا بإخراجه فأخرجوه.أخرجه ابن جرير ١١/٣٦٨.تفسير مقاتل بن سليمان ٢/١٥٩-١٦٠.تفسير مجاهد ص٣٦٥، وأخرجه ابن جرير ١١/٣٦٨، وابن أبي حاتم ٦/١٧٦٢.علَّقه ابن أبي حاتم ٦/١٧٦٢.أخرجه ابن جرير ١١/٣٦٨، وابن أبي حاتم ٦/١٧٦٣.تفسير مقاتل بن سليمان ٢/١٥٩-١٦٠.أخرجه ابن أبي حاتم ٦/١٧٦٣.تفسير مقاتل بن سليمان ٢/١٥٩-١٦٠.
