quran[7]{c,v,t}:
  9,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَیۡفَ یَكُونُ لِلۡمُشۡرِكِینَ عَهۡدٌ عِندَ ٱللَّهِ وَعِندَ رَسُولِهِۦۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكَّرهم أيضًا مشركي مكة، فقال: <span class="qpc-hafs">﴿كَيْفَ يَكُونُ لِلْمُشْرِكِينَ عَهْدٌ عِنْدَ اللَّهِ وعِنْدَ رَسُولِهِ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٥٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿كيف يكون للمشركين﴾</span> الذين كانوا هم وأنتم على العهد العامِّ بأن لا تُخيفوهم ولا يُخِيفوكم من الحرمة، ولا في الشهر الحرام{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلَّذِینَ عَـٰهَدتُّمۡ عِندَ ٱلۡمَسۡجِدِ ٱلۡحَرَامِۖ فَمَا ٱسۡتَقَـٰمُوا۟ لَكُمۡ فَٱسۡتَقِیمُوا۟ لَهُمۡۚ إِنَّ ٱللَّهَ یُحِبُّ ٱلۡمُتَّقِینَ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، قال: قريش{3}. (٧/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، يعني: أهل مكة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span> يقول: هم قوم كان بينهم وبين النبي ﷺ مُدَّةٌ، ولا ينبغي لمشرك أن يدخل المسجد الحرام، ولا مَن يعطي المسلم الجزية، <span class="qpc-hafs">﴿فما استقاموا لكم فاستقيموا لهم﴾</span> يعني: أهل العهد من المشركين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٥٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن عبّاد بن جعفر</span> -من طريق ابن جُرَيْج- قوله: <span class="qpc-hafs">﴿إلا الذين عاهدتم من المشركين﴾</span>، قال: هم جَذِيمة بكر كنانة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيج- <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، قال: أهل العهد من خزاعة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span> قال: هو يوم الحديبية، <span class="qpc-hafs">﴿فما استقاموا لكم فاستقيموا لهم﴾</span> قال: فلم يَسْتَقيِموا ونَقَضوا عهدَهم، أعانوا بني بكرٍ حِلفَ قريش على خزاعةَ حُلفاء النبيِّ ﷺ{8}. (٧/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، قال: هم بنو جَذِيمة بن فلان{9}. (٧/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: هم من قبائل بكر: بنو جَذِيمة، وبنو مُدْلِج، وبنو ضَمْرَة، وبنو الدِّيل، وهم الذين كانوا قد دخلوا في عهد قريش يوم الحديبية، ولم يكن نقض العهدَ إلا قريشٌ وبنو الديل من بني بكر، فأُمِر بإتمام العهد لمن لَم ينقض، وهم بنو ضَمْرَة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى خزاعة، وبني مدلج، وبني خزيمة{11}، الذين أجَّلهم أربعة أشهر، فقال: <span class="qpc-hafs">﴿إلّا الَّذِينَ عاهَدْتُمْ عِنْدَ المَسْجِدِ الحَرامِ﴾</span> بالحديبية، فلهم العهد، <span class="qpc-hafs">﴿فَما اسْتَقامُوا لَكُمْ﴾</span> بالوفاء إلى مدتهم، يعني: تمام هذه أربعة الأشهر من يوم النحر، <span class="qpc-hafs">﴿فاسْتَقِيمُوا لَهُمْ﴾</span> بالوفاء، <span class="qpc-hafs">﴿إنَّ اللَّهَ يُحِبُّ المُتَّقِينَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- قال: كان النبيُّ ﷺ قد عاهَده أناسٌ من المشركين، وعاهَد أيضًا أناسًا مِن بني ضَمْرةَ بن بكر وكِنانة خاصَّةً، عاهَدهم عند المسجد الحرام، وجعَل مُدَّتَهم أربعةَ أشهر، وهم الذين ذكَر الله: <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، <span class="qpc-hafs">﴿فما استقاموا لكم فاستقيموا لهم﴾</span>. يقول: ما وفَّوا لكم بالعهد فوَفُّوا لهم ...{13}. (٧/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، وهي قبائل بني بكر الذين كانوا دخلوا في عهد قريش، وعقدتم يوم الحديبية، إلى المدة التي كانت بين رسول الله ﷺ وبين قريش، فلم يكن نقضها إلا هذا الحيُّ من قريش، وبنو الدُّئِل من بكر، فأُمِر بإتمام العهد لمن لم يكن نَقَضَ عهده من بني بكر إلى مدته، <span class="qpc-hafs">﴿فما استقاموا لكم﴾</span> الآية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إلا الذين عاهدتم عند المسجد الحرام﴾</span>، قال: هؤلاء قريش{15}<span class=comment-ref>٢٨٩٤</span>. (٧/٢٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٨٩٤</span> أفادت الآثارُ اختلافَ المفسرين في المعنيين بقوله: <span class="qpc-hafs">﴿إلا الَّذِينَ عاهَدْتُمْ عِنْدَ المَسْجِدِ الحَرامِ﴾</span> على أقوال: <b>الأول:</b> أنهم جَذِيمَة بكر كنانة. <b>الثاني:</b> أنهم قريش. <b>الثالث:</b> أنهم قوم من خزاعة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١١/٣٥٣) <span class="mustanad">مستندًا إلى دلالة التاريخ</span> القول الأول، وهو قول السدي، ومحمد بن عباد بن جعفر، وابن إسحاق، و<span class="comment-type-2">انتقد</span> القولين الآخرين، فقال: «وأولى هذه الأقوال بالصواب عندي قولُ مَن قال: هم بعض بني بكر من كنانة، ... وإنما قلتُ: هذا القول أولى الأقوال في ذلك بالصواب لأنّ الله تعالى أمر نبيَّه والمؤمنين بإتمام العهد لمن كانوا عاهدوه عند المسجد الحرام، ما استقاموا على عهدهم. وقد بيَّنّا أن هذه الآيات إنما نادى بها عليٌّ ﵁ في سنة تسع من الهجرة، وذلك بعد فتح مكة بسنة، فلم يكن بمكة من قريش ولا خزاعة كافرٌ يومئذٍ بينه وبين رسول الله ﷺ عهدٌ فيؤمر بالوفاء له بعهده ما استقام على عهده؛ لأنّ مَن كان منهم من ساكني مكة كان قد نقض العهد، وحورب قبل نزول هذه الآيات».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٤/٢٦٤) <span class="mustanad">مستندًا إلى دلالة التاريخ</span> القول الثالث بقوله: «وهو مردود بإسلام خزاعة عام الفتح». و<span class="comment-type-2">انتقد</span> قولَ ابن زيد في القول بأنهم قريش، وأنّ هذه الآية نزلت فلم يستقيموا ... الخ، <span class="mustanad">مستندًا إلى دلالة التاريخ</span> قائلًا: «وهو ضعيف مُتناقِض؛ لأنّ قريشًا وقت الأذان بالأربعة الأشهر لم يكن منهم إلا مسلم، وذلك بعد فتح مكة بسنة، وكذلك خزاعة».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن جرير ١١/٣٥١.أخرجه ابن جرير ١١/٣٥١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٥٢.أخرجه ابن جرير ١١/٣٥٢.أخرجه ابن جرير ١١/٣٥٠.أخرجه ابن جرير ١١/٣٥٣.أخرجه عبد الرزاق ٢/٢٦٧-٢٦٨، وابن جرير ١١/٣٥٢، وابن أبي حاتم ٦/١٧٥٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٧٥٦. وأخرجه ابن جرير ١١/٣٥٠ بلفظ: بنو جَذِيمة بن الدُّئِل. قال الشيخ شاكر في تحقيقه لتفسير ابن جرير ١٤/١٤١: هكذا جاء هنا: بنو جذيمة بن الدئل ... ولا أعلم في الدئل بن بكر بن عبد مناة بن كنانة: جذيمة؛ فإنّ جذيمة كنانة إنما هم: بنو جذيمة بن عامر بن عبد مناة بن كنانة، أبناء عمومة الدئل، وبكر بن عبد مناة.تفسير الثعلبي ٥/١٤، وتفسير البغوي ٤/١٤.كذا في المطبوع، ولعلها تصحفت من: بني جَذِيمةَ.تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن أبي حاتم ٦/١٧٥٦-١٧٥٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٣٥١.أخرجه ابن جرير ١١/٣٥٢، وابن أبي حاتم ٦/١٧٥٧.
  9,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَیۡفَ وَإِن یَظۡهَرُوا۟ عَلَیۡكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٦٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿كيف وإن يظهروا عليكم﴾</span>: المشركون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم حَرَّض المؤمنين على قتال كُفّار مكة الذين لا عهد لهم؛ لأنّهم نقضوا العهد، <span class="qpc-hafs">﴿كَيْفَ﴾</span> لا تقاتلونهم <span class="qpc-hafs">﴿وإنْ يَظْهَرُوا عَلَيْكُمْ لا يَرْقُبُوا فِيكُمْ إلًّا ولا ذِمَّةً﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿كيف وإن يظهروا عليكم﴾</span> أي: المشركون الذين لا عهد لهم إلى مُدَّة مِن أهل العهد العام <span class="qpc-hafs">﴿لا يرقبوا فيكم إلا ولا ذمة﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یَرۡقُبُوا۟ فِیكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٧١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا يرقبوا﴾</span>: لا يحفظوا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق شبل، عن ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لا يرقبوا فيكم﴾</span>: لا يرقبوا في محمد ﷺ إلًّا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿لا يرقبوا﴾</span>: لا ينتظروا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلࣰّا وَلَا ذِمَّةࣰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٧٤<span class="dash">-</span></span> عن <span class="name-2">أبي مجلز لاحق بن حميد</span> -من طريق سليمان- في قوله: <span class="qpc-hafs">﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</span>، قال: مِثل قوله: جبرائيل، ميكائيل، إسرافيل، كأنه يقول: يضيف جبر وميكا وإسراف إلى إيل.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٥<span class="dash">-</span></span> يقول <span class="name-1">عبد الله</span>: <span class="qpc-hafs">﴿لا يرقبون في مؤمن إلا﴾</span>، كأنه يقول: لا يرقبون الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إلا ولا ذمة﴾</span>، قال: الإلُّ: القرابة، والذِّمَّةُ: العهد{8}. (٧/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿إلا ولا ذمة﴾</span>. قال: الإلُّ: القرابة، والذِّمَّة: العهد. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول:</p><p>جَزى الله إلًّا كان بَيْني وبَيْنَهُم جَزاءَ ظَلُومٍ لا يُؤخِّرُ عاجِلا{9}. (٧/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٨<span class="dash">-</span></span> عن ميمون بن مهران، أنّ نافع بن الأزرق قال لا<span class="name-1">بن عباس</span>: أخبِرني عن قول الله تعالى: <span class="qpc-hafs">﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</span>. قال: الرَّحِمُ، وقال فيه حسان بن ثابت:</p><p>لعَمْرُك إن إلَّك مِن قُريش كإلِّ السَّقْبِ{10} مِن رَأْلِ{11} النَّعام{12}. (٧/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿لا يرقبوا فيكم إلا ولا ذمة﴾</span>، قال: الإلُّ: القرابة، والذِّمَّة: العهد{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> في أحد قوليه= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨١<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: أنّ الذِّمَّة: العهد{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿إلا﴾</span> قال: إلهًا، <span class="qpc-hafs">﴿ولا ذمة﴾</span> قال: العقد{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مَعْمَر، عن ابن أبي نَجِيح- <span class="qpc-hafs">﴿لا يرقبوا فيكم إلا ولا ذمة﴾</span>: لا يراقبون اللهَ، ولا غيره{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن ابن أبي نجيح- قال: الإلُّ: الله ﷿{17}. (٧/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- <span class="qpc-hafs">﴿إلا﴾</span>، قال: عهدًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، نحو ذلك{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خصيف- <span class="qpc-hafs">﴿ولا ذمة﴾</span>، قال: الذِّمَّة: العهد{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق حوشب-: الإلُّ: القرابة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قال: في قوله: <span class="qpc-hafs">﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</span>، الإلُّ: القرابة، والذِّمة: الميثاق{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> - من طريق بديل- <span class="qpc-hafs">﴿لا يرقبون في مؤمن إلا ولا ذمة﴾</span>، قال: الذمة: الحِلْف{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الإلُّ: الله{24}. (٧/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: الإلُّ: الحِلْفُ، والذِّمَّةُ: العهد{25}. (٧/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: لا يرقبوا فيكم عهدًا، ولا قرابة، ولا ميثاقًا{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَرْقُبُوا فِيكُمْ إلًّا ولا ذِمَّةً﴾</span>، يقول: لا يحفظوا فيكم قرابةً ولا عهدًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا يرقبوا فيكم إلا ولا ذمة﴾</span> قال: لا يرقبوا فيكم عهدًا ولا ذِمَّةً. قال: إحداهما من صاحبتها كهيئة <span class="qpc-hafs">﴿غفور رحيم﴾</span>. قال: فالكلمة واحدة، وهي تفترق. قال: والعهد: هو الذمة{28}<span class=comment-ref>٢٨٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٨٩٥</span> أفادت الآثارُ اختلاف المفسرين في معنى: الإلّ على أقوال: <b>الأول:</b> أنه القرابة. <b>الثاني:</b> أنه الله تعالى. <b>الثالث:</b> أنه الحِلف. <b>الرابع:</b> أنه العهد.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١١/٣٥٨) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول معنى اللفظ لجميع الأقوال، فبيَّن أن الإلّ: «اسم يشتمل على معانٍ ثلاثة: وهي العهد والعقد، والحِلف، والقرابة، وهو أيضًا بمعنى: الله. فإذ كانت الكلمة تشمل هذه المعاني الثلاثة، ولم يكن الله خصَّ من ذلك معنًى دون معنًى؛ فالصواب أن يَعُمَّ ذلك كما عمَّ بها -جلَّ ثناؤه- معانيها الثلاثة، فيقال: لا يرقبون في مؤمنٍ الله، ولا قرابة، ولا عهدًا، ولا ميثاقًا».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٧/١٥٤) القول الأول <span class="mustanad">لكونِه الأشهر لغة، والأظهر لفظًا، وعليه الأكثر من المفسّرين</span>، وهو قول ابن عباس، والضحاك، والسدي من طريق أسباط، فقال: «والقول الأول أشهر وأظهر، وعليه الأكثر».</div></p><p><h3><span class="qpc-hafs">﴿یُرۡضُونَكُم بِأَفۡوَ ٰ⁠هِهِمۡ وَتَأۡبَىٰ قُلُوبُهُمۡ وَأَكۡثَرُهُمۡ فَـٰسِقُونَ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وأكثرهم فاسقون﴾</span>، قال: القرون الماضية{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأكثرهم فاسقون﴾</span>، قال: ذَمَّ اللهُ تعالى أكثرَ الناس{23}. (٧/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٧٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُرْضُونَكُمْ بِأَفْواهِهِمْ﴾</span> يعني: بألسنتهم، <span class="qpc-hafs">﴿وتَأبى قُلُوبُهُمْ﴾</span> وكانوا يُحْسِنون القول للمؤمنين، فيرضونهم، وفي قلوبهم غيرُ ذلك، فأخبر عن قولهم، فذلك قوله: <span class="qpc-hafs">﴿يُرْضُونَكُمْ بِأَفْواهِهِمْ﴾</span> يعني: بألسنتهم، <span class="qpc-hafs">﴿وتَأبى قُلُوبُهُمْ وأَكْثَرُهُمْ فاسِقُونَ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١١/٣٥٦، وابن أبي حاتم ٦/١٧٥٧.تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن جرير ١١/٣٥٩.تفسير الثعلبي ٥/١٤.أخرجه ابن أبي حاتم ٦/١٧٥٧.تفسير الثعلبي ٥/١٤، وتفسير البغوي ٤/١٥.أخرجه ابن جرير ١١/٣٥٥.أخرجه ابن جرير ١١/٣٥٥، وابن أبي حاتم ٦/١٧٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى الطستي. وينظر: الإتقان ٢/٩٨.السَّقْبُ: ولد الناقة، وقيل: الذَّكَر من ولد الناقة. اللسان (سقب).الرأْل: ولدُ النعام، وخصَّ بعضهم به الحَوْليَّ منها. اللسان (رأل).عزاه السيوطي إلى ابن الأنباري في كتاب الوقف والابتداءأخرجه ابن أبي حاتم ٦/١٧٥٨.علقه ابن أبي حاتم ٦/١٧٥٨.علقه ابن أبي حاتم ٦/١٧٥٨.أخرجه عبد الرزاق ١/٢٦٨، وابن جرير ١١/٣٥٥، وابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٥، وابن أبي حاتم ٦/١٧٥٨. وعزاه السيوطي إلى الفريابي، وأبي عبيد، وابن المنذر، وأبي الشيخ.تفسير مجاهد ص٣٦٥، وأخرجه ابن جرير ١١/٣٥٧ من طريق عيسى عن ابن أبي نجيح، وابن أبي حاتم ٦/١٧٥٨.علَّقه ابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٧. وعلَّقه ابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٥. وعلقه ابن أبي حاتم ٦/١٧٥٨.أخرجه ابن جرير ١١/٣٥٦.أخرجه ابن أبي حاتم ٦/١٧٥٩.عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٥٧، وابن أبي حاتم ٦/١٧٥٨ وعلَّق آخره. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٥٦، وابن أبي حاتم ٦/١٧٥٨.تفسير مقاتل بن سليمان ٢/١٥٨.أخرجه ابن جرير ١١/٣٥٧.أخرجه ابن أبي حاتم ٦/١٧٥٩.أخرجه ابن أبي حاتم ٦/١٧٥٩.تفسير مقاتل بن سليمان ٢/١٥٨.
  9,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱشۡتَرَوۡا۟ بِـَٔایَـٰتِ ٱللَّهِ ثَمَنࣰا قَلِیلࣰا فَصَدُّوا۟ عَن سَبِیلِهِۦۤۚ إِنَّهُمۡ سَاۤءَ مَا كَانُوا۟ یَعۡمَلُونَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧٩٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: وذلك أنّ أهلَ الطائف أمَدُّوهم بالأموال؛ لِيُقَوُّوهم على حربِ رسول الله ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿اشتروا بآيات الله ثمنا قليلا﴾</span>، قال: أبو سفيان بن حرب أطعَم حلفاءَه، وترَك حلفاءَ محمد ﷺ{2}<span class=comment-ref>٢٨٩٦</span>. (٧/٢٥٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٨٩٦</span> لم يذكر <u>ابنُ جرير</u> (١١/٣٦٠) في معنى: <span class="qpc-hafs">﴿اشْتَرَوْا بِآياتِ اللَّهِ ثَمَنًا قَلِيلًا﴾</span> سوى قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٣١٨٠١<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: كان أبو سفيان يُعْطِي الناقةَ والطعامَ لِيَصُدَّ الناس بذلك عن مُتابَعَةِ النبي ﷺ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿عن سبيله﴾</span>، قال: عن الإسلام{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اشْتَرَوْا بِآياتِ اللَّهِ ثَمَنًا قَلِيلًا﴾</span>، يعني: باعوا إيمانًا بالقرآن بعَرَضٍ من الدنيا [يسيرٍ]، وذلك أنّ أبا سفيان كان يُعْطِي الناقةَ والطعامَ والشيءَ ليصد بذلك الناسَ عن متابعة النبي ﷺ، فذلك قوله: <span class="qpc-hafs">﴿فَصَدُّوا﴾</span> الناسَ <span class="qpc-hafs">﴿عَنْ سَبِيلِهِ﴾</span> أي: عن سبيل الله، يعني: عن دين الله، وهو الإسلام، <span class="qpc-hafs">﴿إنَّهُمْ ساءَ﴾</span> يعني: بئس <span class="qpc-hafs">﴿ما كانُوا يَعْمَلُونَ﴾</span> يعني: بئس ما عملوا بصدِّهم عن الإسلام{5}<span class=comment-ref>٢٨٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٨٩٧</span> ذكر <u>ابنُ عطية</u> (٤/٢٦٨) قولًا عن بعض الناس: بأنّ هذه الآية في اليهود، ثم <span class="comment-type-2">انتَقَدَه</span> <span class="mustanad">مستندًا إلى مخالفة السياق</span> قائلًا: «وهذا القول وإن كانت ألفاظُ هذه الآية تقتضيه؛ فما قبلها وما بعدها يَرُدُّه، ويتبرأ منه، ويختل أسلوب القول به».</div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٥، وتفسير البغوي ٤/١٦.تفسير مجاهد ص٣٦٤، وأخرجه ابن جرير ١١/٣٦٠، وابن أبي حاتم ٦/١٧٥٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/١٥.أخرجه ابن أبي حاتم ٦/١٧٥٩.تفسير مقاتل بن سليمان ٢/١٥٨-١٥٩.
  9,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَرۡقُبُونَ فِی مُؤۡمِنٍ إِلࣰّا وَلَا ذِمَّةࣰۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُعۡتَدُونَ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَرْقُبُونَ فِي مُؤْمِنٍ إلًّا ولا ذِمَّةً﴾</span> يعني: لا يحفظون في مؤمن قرابةً ولا عهدًا، <span class="qpc-hafs">﴿وأُولئِكَ هُمُ المُعْتَدُونَ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/١٥٩.
  9,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِن تَابُوا۟ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله [بن مسعود]</span> -من طريق أبي عبيدة- قال: أُمِرْتُم بإقامة الصلاة، وإيتاء الزكاة، ومَن لم يُزَكِّ فلا صلاة له{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق رجل- قال: حَرَّمتْ هذه الآيةُ قتالَ أو دماءَ أهلِ الصلاة: <span class="qpc-hafs">﴿فإن تابوا وأقاموا الصلاة وءاتوا الزكاة فإخوانكم في الدين﴾</span>{2}. (٧/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فإن تابوا وأقاموا الصلاة وءاتوا الزكاة فإخوانكم في الدين﴾</span>، يقول: إن ترَكوا اللاتَ والعُزّى، وشهِدوا أن لا إله إلا الله، وأنّ محمدًا رسول الله؛ فإخوانُكم في الدين{3}. (٧/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنْ تابُوا﴾</span> من الشرك، <span class="qpc-hafs">﴿وأَقامُوا الصَّلاةَ وآتَوُا الزَّكاةَ﴾</span> أي: أقرُّوا بإقام الصلاة، وإيتاء الزكاة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٠٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: افتُرِضَت الصلاةُ والزكاةُ جميعًا، لم يُفَرَّق بينهما. وقرأ: <span class="qpc-hafs">﴿فإن تابوا وأقاموا الصلاة وآتوا الزكاة فإخوانكم في الدين﴾</span>، وأبى أن يقبلَ الصلاةَ إلا بالزكاة. وقال: رحم الله أبا بكر ما كان أفقهَه{1}<span class=comment-ref>٢٨٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٨٩٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٢٦٨) على قول ابن زيد بقوله: «وعلى هذا مرَّ أبو بكر ﵄ وقت الرِّدَّة».</div></p><p><h3><span class="qpc-hafs">﴿فَإِخۡوَ ٰ⁠نُكُمۡ فِی ٱلدِّینِۗ وَنُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان بن عبد الرحمن- قوله: <span class="qpc-hafs">﴿فإخوانكم في الدين﴾</span>، قال: فكونوا مِن إخوة الإسلام، مِمَّن يرعاهم، ويعاهد عليها، ويعظم حقَّها، فإنّ أفضل المسلمين أوصلُهم لإخوة الإسلام{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإخْوانُكُمْ فِي الدِّينِ ونُفَصِّلُ ونبين الآياتِ لِقَوْمٍ يَعْلَمُونَ﴾</span> بتوحيد الله{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِخۡوَ ٰ⁠نُكُمۡ فِی ٱلدِّینِۗ وَنُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝١١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣١٨١٢<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>مَن صلّى صلاتنا، واستقبل قبلتنا، وأكل ذبيحتنا؛ فذلك المسلمُ الذي له ذِمَّةُ الله وذِمَّةُ رسوله، فلا تَخْفِروا</b>{8} <b>اللهَ في ذِمَّته</b>»{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨١٣<span class="dash">-</span></span> عن أبي هريرة، قال: لَمّا تُوُفِّي رسولُ الله ﷺ، وكان أبو بكر بعده، وكَفَرَ مَن كَفَرَ مِن العرب؛ قال عمر بن الخطاب لأبي بكر: كيف تقاتلُ الناسَ وقد قال رسول الله ﷺ: «<b>أُمِرْتُ أن أقاتل الناس حتى يقولوا: لا إله إلا الله. فمَن قال: لا إله إلا الله. عَصَمَ مِنِّي مالَه، ونفسَه، إلا بحقِّه، وحسابُه على الله</b>»؟! فقال <span class="name-1">أبو بكر</span>: واللهِ، لَأُقاتِلَنَّ مَن فَرَّق بين الصلاة والزكاة؛ فإنّ الزكاة حقُّ المال، واللهِ، لو منعوني عَناقًا{10} كانوا يُؤَدُّونها إلى رسول الله ﷺ لَقاتلتُهم على منعها. قال عمر: فواللهِ، ما هو إلا أن قد شُرِح صدرُ أبي بكر للقتال، فعرفتُ أنّه الحق{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١١/٣٦٢.أخرجه ابن جرير ١١/٣٦٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٣٦١، وابن أبي حاتم ٦/١٧٦٠. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/١٥٩.أخرجه ابن جرير ١١/٣٦٢.أخرجه ابن أبي حاتم ٦/١٧٦٠.تفسير مقاتل بن سليمان ٢/١٥٩.تُخْفِروا الله: أي لا تنقُضوا عهدَه وذِمامه. النهاية (خفر).أخرجه البخاري ١/٨٧ (٣٩١).العَناق: الأنثى من أولاد المَعْز ما لم يَتِمَّ له سنة. النهاية (عنق).أخرجه البخاري ٢/١٠٥-١٠٦ (١٣٩٩، ١٤٠٠)، ٩/١٥ (٦٩٢٤، ٦٩٢٥)، ٩/٩٣-٩٤ (٧٢٨٤)، ومسلم ١/٥١ (٢٠).
  9,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن نَّكَثُوۤا۟ أَیۡمَـٰنَهُم مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ لَهُمۡ لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣١٨١٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قرأ: ‹إنَّهُمْ لَآ إيمانَ› بكسر الألف{1}<span class=comment-ref>٢٨٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٨٩٩</span> <span class="comment-type-1">وجَّه</span> <u>ابن جرير</u> (١١/ ٣٦٦) قراءة الحسن فذكر أنها: «بمعنى: لا إسلام لهم. وقد يُتوجَّه لقراءته كذلك وجه غير هذا، وذلك أن يكون أراد بقراءته ذلك كذلك: أنهم لا أمان لهم، أي لا تُؤمِنوهم، ولكن اقتلوهم حيث وجدتموهم، كأنه أراد المصدر من قول القائل: آمنته، فأنا أومنه إيمانًا».</p><p>ثم <span class="comment-type-2">انتقدها</span> <span class="mustanad">مستندًا إلى الإجماع</span> فقال: «والصواب من القراءات في ذلك الذي لا أستجيز القراءة بغيره، قراءة من قرأ بفتح الألف دون كسرها؛ لإجماع الحجة من القراء على القراءة به ورفض خلافه؛ ولإجماع أهل التأويل على ما ذكرت من أن تأويله لا عهد لهم. والأيمان التي هي بمعنى العهد، لا تكون إلا بفتح الألف؛ لأنها جمع يمين كانت على عقد كان بين المتوادعين».</div></p><p><h3><span class="qpc-hafs">﴿وَإِن نَّكَثُوۤا۟ أَیۡمَـٰنَهُم مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ لَهُمۡ لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣١٨١٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: نزلت في أبي سفيان بن حرب، والحارث بن هشام، وسهيل بن عمرو، وعكرمة بن أبي جهل، وسائر رؤساء قريش يومئذٍ الذين نقضوا العهد، وهم الذين هَمُّوا بإخراج الرسول{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨١٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿وإن نكثوا أيمانهم من بعد عهدهم وطعنوا في دينكم﴾</span> إلى قوله: <span class="qpc-hafs">﴿والله عليم حكيم﴾</span>: إنّ رسول الله ﷺ كان وادَعَ أهل مكة سنة، وهو يومئذ بالحديبية، فحبسوه عن البيت، ثم صالحوه على أنّك ترجع عامَك هذا، ولا تَطَأ بلدَنا، ولا تنحر البُدْن من أرضنا، وأن نُخَلِّيها لك عامًا قابلًا ثلاثة أيام، ولا تأتينا بالسلاح إلا سلاحًا تجعلها في قِراب{3}، وأنّه مَن صَبَأَ مِنّا إليك فهو إلينا رَدٌّ. فصالحهم رسول الله على ذلك، فمكثوا ما شاء الله أن يمكثوا، ثم إنّ حلفاء رسول الله من خُزاعة قاتلوا حلفاء بني أُمِيَّة مِن بني كنانة؛ فأَمَدَّتْ بنو أُمَيَّةَ حلفاءَهم بالسلاح والطعام، فركب ثلاثون رجلًا من حُلفاء رسول الله من خُزاعة، فيهم بديل بن ورقاء، فناشدوا رسول الله الحِلْف، فأمر رسول الله ﷺ أن يعين حلفاءه، وأنزل الله على نبيه: <span class="qpc-hafs">﴿وإن نكثوا أيمانهم من بعد عهدهم وطعنوا في دينكم فقاتلوا أئمة الكفر إنهم لا أيمان لهم﴾</span>: لا عهد لهم؛ <span class="qpc-hafs">﴿لعلهم ينتهون﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن نَّكَثُوۤا۟ أَیۡمَـٰنَهُم مِّنۢ بَعۡدِ عَهۡدِهِمۡ وَطَعَنُوا۟ فِی دِینِكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وإن نكثوا أيمانهم من بعد عهدهم﴾</span>، يقول اللهُ لنبيِّه ﷺ: وإن نكَثوا العهدَ الذي بينك وبينهم فقاتِلْهم؛ إنهم أئمةُ الكفر{5}. (٧/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وإن نكثوا أيمانهم﴾</span>، قال: عهدَهم{6}. (٧/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨١٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإنْ نَكَثُوا أيْمانَهُمْ﴾</span>: عهدهم الذي عاهدوا على الإسلام{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ نَكَثُوا أيْمانَهُمْ مِن بَعْدِ عَهْدِهِمْ﴾</span> يعني: نقضوا عهدَهم، وذلك أنّ النبيَّ ﷺ واعد كُفّار مكة سنتين، وأنهم عمدوا فأعانوا كِنانة بالسِّلاح على قتال خزاعة، وخزاعة صُلْح النبي ﷺ، فكان في ذلك نكثٌ للعهد، فاستحلَّ النبيُّ ﷺ قتالَهم، فذلك قوله: <span class="qpc-hafs">﴿وإنْ نَكَثُوا أيْمانَهُمْ﴾</span>، <span class="qpc-hafs">﴿وطَعَنُوا فِي دِينِكُمْ﴾</span> فقالوا: ليس دينُ محمد بشيء{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَـٰتِلُوۤا۟ أَىِٕمَّةَ ٱلۡكُفۡرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٢١<span class="dash">-</span></span> عن عبد الرحمن بن جبير بن نفير: أنّه كان في عهد <span class="name-1">أبي بكر</span> إلى الناس حينَ وجَّهَهم إلى الشام، فقال: إنّكم ستَجِدون قومًا مُحَوَّقةً{9} رءوسُهم، فاضرِبوا مقاعدَ الشيطان منهم بالسيوف، فواللهِ، لأن أقتُلَ رجلًا منهم أحبُّ إلَيَّ مِن أن أقتُلَ سبعينَ مِن غيرِهم، وذلك بأنّ الله تعالى يقول: <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>{10}. (٧/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٢<span class="dash">-</span></span> عن زيد بن وهب، في قوله: <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، قال: كُنّا عندَ <span class="name-1">حذيفةَ [بن اليمان]</span>، فقال: ما بَقِي مِن أصحاب هذه الآية إلا ثلاثة، ولا مِن المنافقين إلا أربعة. فقال أعرابيٌّ: إنّكم -أصحابَ محمدٍ ﷺ- تُخْبِروننا بأمورٍ لا نَدْري، فما بالُ هؤلاء الذين يَبْقُرون{11} بيوتَنا، ويَسْرِقون أعلاقَنا{12}؟ قال: أولئك الفُسّاق، أجَلْ، لم يَبْقَ منهم إلا أربعة؛ أحدُهم شيخٌ كبيرٌ، لو شَرِب الماءَ البارد لَما وجَد بَرْدَه{13}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٣<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق زيد بن وهب- أنّهم ذكَروا عندَه هذه الآية، فقال: ما قُوتِل أهلُ هذه الآيةِ بعد{14}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، قال: واللهِ، ما قُوتِل أهلُ هذه الآية منذُ أُنزِلت: <span class="qpc-hafs">﴿وإن نكثوا أيمانهم من بعد عهدهم﴾</span> الآية{15}. (٧/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٥<span class="dash">-</span></span> عن مصعب بن سعد، قال: مَرَّ <span class="name-1">سعد [بن أبي وقاص]</span> برجلٍ مِن الخوارج، فقال الخارجيُّ لسعد: هذا مِن أئمةِ الكفر. فقال سعد: كَذَبْتَ، بل أنا قاتَلْتُ أئِمَّةَ الكفر{16}. (٧/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، قال: رءوس قريش{17}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، يعني: أهل العهد من المشركين، سمّاهم: أئمة الكفر، وهم كذلك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، قال: أبو سفيان بن حرب منهم{19}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٢٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، مثله{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، قال: أبو سفيان{21}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، يعني: رءوس المشركين، أهل مكة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿فقاتلوا أئمة الكفر﴾</span>، قال: الدَّيْلمُ{23}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أئمة الكفر﴾</span>، قال: أبو سفيان بن حرب، وأُمَيَّةُ بن خلف، وعُتْبةُ بن ربيعة، وأبو جهل بن هشام، وسُهَيلُ بن عمرو، وهم الذين نكَثوا عهدَ الله، وهَمُّوا بإخراجِ الرسول ﷺ من مكة{24}. (٧/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٤<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span>، مثلَه{25}. (٧/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإن نكثوا أيمانهم﴾</span> إلى: <span class="qpc-hafs">﴿ينتهون﴾</span>: هؤلاء قريش، يقول: إن نكثوا عهدهم الذي عاهدوا على الإسلام وطعنوا فيه، فقاتلوهم {26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقاتِلُوا أئِمَّةَ الكُفْرِ﴾</span>، يعني: قادة الكُفْر؛ كفار قريش: أبا سفيان بن حرب، والحارث بن هشام، وسهيل بن عمرو، وعكرمة بن أبي جهل، وغيرهم{8}<span class=comment-ref>٢٩٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٠٠</span> أفادت الآثارُ اختلافَ المفسرين في المعنيين بأئمة الكفر على قولين: <b>الأول:</b> هم أبو جهل، وعتبة بن ربيعة، وأبو سفيان بن حرب، ونظراؤهم. <b>والثاني:</b> أنه لم يأتِ أهلها بعدُ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٤/٢٧٠) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول الآية لهذه الأقوال، فقال: «وأَصْوَبُ ما في هذا أن يُقال: إنّه لا يُعنى بها مُعيَّن، وإنما وقع الأمر بقتال أئمة الناكثين بالعهود من الكَفَرة إلى يوم القيامة دون تعيين، واقتضت حال كفار العرب ومحاربي رسول الله ﷺ أن تكون الإشارة إليهم أولًا بقوله: <span class="qpc-hafs">﴿أئِمَّةَ الكُفْرِ﴾</span>، وهم حصلوا حينئذ تحت اللفظة؛ إذ الذي يتولى قتال النبي ﷺ والدفع في صدر شريعته هو إمام مَن يَكْفُر بذلك الشرع إلى يوم القيامة، ثم تأتي في كل جيل من الكفار أئمة خاصة بجيلٍ جيل».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ كثير</u> (٧/١٥٥) فقال: «الآية عامَّةٌ، وإن كان سبب نزولها مشركي قريش، فهي عامَّة لهم ولغيرهم».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> <span class="mustanad">مستندًا إلى التاريخ</span> قول قتادة بأنّه أبو جهل وأضرابه قائلًا: «وهذا -إن لم يُتَأَوَّل أنّه ذكرهم على جهة المثال- ضعيف؛ لأن الآية نزلت بعد بدر بكثير».</p><p>و<span class="comment-type-1">وجَّه</span> قول حذيفة ﵁ بقوله: «يريد: لم ينقرضوا، فهم يحيون أبدًا ويُقاتلون».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ لَاۤ أَیۡمَـٰنَ لَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٣٧<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق صِلَة بن زُفَر- <span class="qpc-hafs">﴿لا أيمان لهم﴾</span>، قال: لا عُهُودَ لهم{28}. (٧/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٨<span class="dash">-</span></span> عن <span class="name-1">عمار بن ياسر</span> -من طريق صِلَة بن زُفَر- <span class="qpc-hafs">﴿لا أيمان لهم﴾</span>: لا عُهُودَ لهم{29}. (٧/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٣٩<span class="dash">-</span></span> عن <span class="name-2">صِلَة بن زُفَر</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿إنهم لا أيمان لهم﴾</span>: لا عهد لهم{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤٠<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، قال: لا دين لهم {31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُمْ لا أيْمانَ لَهُمْ﴾</span>؛ لأنهم نقضوا العهد الذي كان بالحديبية{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَنتَهُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿لعلهم ينتهون﴾</span>، يعني: أهل العهد من المشركين{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> يعني: لكي <span class="qpc-hafs">﴿يَنْتَهُونَ﴾</span> عن نقض العهد، ولا يَنقُضون{8}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه ابن جرير ١١/٣٦٦.</p><p>وهي قراءة متواترة، قرأ بها ابن عامر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿لَآ أيْمانَ﴾</span> بفتح الهمزة. انظر: النشر ٢/٢٧٨، والإتحاف ص٣٠٢.أورده الواحدي في أسباب النزول ص٢٤٣، والثعلبي ٥/١٦.القِراب: هو شبه الجِراب يطرح فيه الراكب سيفَه بغِمْدِهِ وسوطِهِ، وقد يطرح فيه زاده من تَمْرٍ وغيره. النهاية (قرب).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٩٦-.أخرجه ابن جرير ١١/٣٦٣، وابن أبي حاتم ٦/١٧٦٠-١٧٦١. وعزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٣٦٥، وأخرجه ابن جرير ١١/٣٦٥-٣٦٦. وعزاه السيوطي إلى عبيد بن حميد، وابن المنذر.أخرجه ابن جرير ١١/٣٦٦.تفسير مقاتل بن سليمان ٢/١٥٩.محوقة: مكنوسة. إذ الحوق: الكنس. أراد أنهم حلقوا وسط رءوسهم، فشبَّه إزالة الشعر منه بالكنس. النهاية (حوق).أخرجه ابن أبي حاتم ٦/١٧٦١.يَبْقُرون بيوتنا: أي: يفتحونها ويوسِّعونها. النهاية (بقر).الأعلاق جمع العِلْق -بالكسر-: وهو النَّفِيس من كل شيء. القاموس (علق).أخرجه ابن أبي شيبة ١٥/١٠٨، والبخاري (٤٦٥٨). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٥/٢٢، ١٠٨، وابن جرير ١١/٣٦٥، وابن أبي حاتم ٦/١٧٦١. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن مردويه -كما في تفسير ابن كثير ٤/٥٩-.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٣٦٣، وابن أبي حاتم ٦/١٧٦١.أخرجه ابن أبي حاتم ٦/١٧٦١، وعقّب عليه بقوله: يعني قبل أن يسلم. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.علَّقه ابن أبي حاتم ٦/١٧٦١.أخرجه ابن جرير ١١/٣٦٤، وابن عساكر -كما في مختصر تاريخ دمشق ١٢/٥١-، وفي التاريخ ٢٣/٤٣٨ تداخلٌ بين أثري مالك ومجاهد.أخرجه ابن جرير ١١/٣٦٤، وابن أبي حاتم ٦/١٧٦١.عزاه السيوطي إلى أبي الشيخ. والدَّيْلم: جٍيْل من الناس معروف يُسمّى التُّرْك. اللسان (دلم). وفي تاج العروس (دلم): هم أصحاب الشُّور الأعاجم من بلاد الشَّرق. وقال كراع: هم التُّرك.أخرجه عبد الرزاق ١/٢٦٨، وابن جرير ١١/٣٦٤-٣٦٥ وزاد: وليس -واللهِ- كما يتأوَّلُه أهلُ الشبهات والبدع والفرى على الله وعلى كتابه، وابن أبي حاتم ٦/١٧٦١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن عساكر -كما في مختصر تاريخ دمشق ١٢/٥١-، وفي التاريخ ٢٣/٤٣٨ تداخل بين أثري مالك ومجاهد.أخرجه ابن جرير ١١/٣٦٤.تفسير مقاتل بن سليمان ٢/١٥٩.أخرجه ابن جرير ١١/٣٦٦. وعلَّقه ابن أبي حاتم ٦/١٧٦٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي شيبة في مصنفه ١٥/٦٣٠ (٣١٠٨١)، وابن جرير ١١/٣٦٦، وابن أبي حاتم ٦/١٧٦٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٣٦٥، وابن أبي حاتم ٦/١٧٦٢.تفسير الثعلبي ٥/١٦.تفسير مقاتل بن سليمان ٢/١٥٩.أخرجه ابن أبي حاتم ٦/١٧٦٢.تفسير مقاتل بن سليمان ٢/١٥٩.
  9,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَا تُقَـٰتِلُونَ قَوۡمࣰا نَّكَثُوۤا۟ أَیۡمَـٰنَهُمۡ وَهَمُّوا۟ بِإِخۡرَاجِ ٱلرَّسُولِ وَهُم بَدَءُوكُمۡ أَوَّلَ مَرَّةٍۚ أَتَخۡشَوۡنَهُمۡۚ فَٱللَّهُ أَحَقُّ أَن تَخۡشَوۡهُ إِن كُنتُم مُّؤۡمِنِینَ ۝١٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣١٨٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ألا تقاتلون قوما نكثوا أيمانهم﴾</span>، قال: قتالُ قريشٍ حلفاءَ النبي ﷺ، وهَمُّهم بإخراجِ الرسول زعَموا أنّ ذلك عامَ عمرة النبيِّ ﷺ، في العام السابع للحديبية، نكَثتْ قريشٌ العهد عهدَ الحديبية، وجعَلوا في أنفسِهم إذا دخَلوا مكةَ أن يُخْرِجوه منها، فذلك هَمُّهم بإخراجِه، فلم تُتابِعْهم خُزاعة على ذلك، فلمّا خرَج النبيُّ ﷺ مِن مكة قالت قريشٌ لخزاعة: عَمَّيتُمونا عن إخراجِه. فقاتَلوهم فقَتَلوا منهم رجالًا{1}. (٧/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> -من طريق أيوب- في حديث فتح مكة: أنّ رسول الله ﷺ قال: «<b>مَن أغلق بابَه فهو آمِن، ومَن ألقى سلاحه فهو آمِن</b>». قال: فقاتلهم خزاعةُ إلى نصف النهار؛ وأنزل الله تعالى: <span class="qpc-hafs">﴿ألا تقاتلون قوما نكثوا أيمانهم وهموا بإخراج الرسول﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَا تُقَـٰتِلُونَ قَوۡمࣰا نَّكَثُوۤا۟ أَیۡمَـٰنَهُمۡ وَهَمُّوا۟ بِإِخۡرَاجِ ٱلرَّسُولِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وهموا بإخراج الرسول﴾</span>، قال: مِن بين أظهُرِهم، فأخرَجوه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿وهموا بإخراج الرسول﴾</span> يأثر ذلك الله تبارك وتعالى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: الذين هموا بإخراج الرسول هم أهل فارس والروم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٤٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وهموا بإخراج الرسول﴾</span> من المدينة{6}<span class=comment-ref>٢٩٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٠١</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٤/٢٧١) قول الحسن قائلًا: «وهذا يستقيم؛ كغزوة أحد، والأحزاب، وغيرهما».</div></p><p><div></p><p><p><span class="item-no">٣١٨٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ألا تقاتلون قوما نكثوا أيمانهم﴾</span> من بعد عهدهم، <span class="qpc-hafs">﴿وهموا بإخراج الرسول﴾</span> يقول: هموا بإخراجه، فأخرجوه{7}<span class=comment-ref>٢٩٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٠٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٢٧١-٢٧٢) على قول السدي قائلًا: «فهذا على أن يكون المعنى: همُّوا وفعلوا، أو على أن يُقال: همُّوا بإخراجه بأيديهم فلم يصلوا إلى ذلك، بل خرج بأمر الله ﷿». ثم <span class="comment-type-1">وجَّه</span> هذا الاحتمال بقوله: «وهذا يجري مع إنكار النبي ﷺ على أبي سفيان بن الحارث قوله: وردني لله مَن طَرَّدْتُ كل مُطَرَّد».</div></p><p><div></p><p><p><span class="item-no">٣١٨٥١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: أمر اللهُ رسولَه بجهاد أهل الشرك؛ مِمَّن نَقَض مِن أهل العهد، ومَن كان من أهل العهد العامِّ بعد الأربعة الأشهر التي ضرب لهم أجلًا، إلا أن يعدُوَ فيها عادٍ منهم فيقتل بعدائه، فقال: <span class="qpc-hafs">﴿ألا تقاتلون قوما نكثوا أيمانهم وهموا بإخراج الرسول﴾</span> إلى قوله: <span class="qpc-hafs">﴿والله خبير بما تعملون﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا تُقاتِلُونَ قَوْمًا نَكَثُوا أيْمانَهُمْ﴾</span> يعني: نقضوا عهدَهم حين أعانوا كنانة بالسلاح على خزاعة، وهم صلح النبي ﷺ، <span class="qpc-hafs">﴿وهَمُّوا بِإخْراجِ الرَّسُولِ﴾</span> يعني: النبي ﷺ من مكة حين هَمُّوا في دار الندوة بقتل النبي ﷺ، أو بوثاقه، أو بإخراجه{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُم بَدَءُوكُمۡ أَوَّلَ مَرَّةٍۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وهم بدؤكم أول مرة﴾</span>: قتال قريشٍ حلفاءَ محمد ﷺ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، نحو ذلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وهم بدءوكم أول مرة﴾</span> بالقتال{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُمْ بَدَؤُكُمْ أوَّلَ مَرَّةٍ﴾</span> بالقتال، حين ساروا إلى قتالكم ببدر{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَتَخۡشَوۡنَهُمۡۚ فَٱللَّهُ أَحَقُّ أَن تَخۡشَوۡهُ إِن كُنتُم مُّؤۡمِنِینَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٨٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿مؤمنين﴾</span>، قال: مُصَدِّقين{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أتَخْشَوْنَهُمْ﴾</span> فلا تقاتلونهم؟! <span class="qpc-hafs">﴿فاللَّهُ أحَقُّ أنْ تَخْشَوْهُ﴾</span> في ترك أمره؛ <span class="qpc-hafs">﴿إنْ كُنْتُمْ مُؤْمِنِينَ﴾</span> به، يعني: إن كنتم مصدِّقين بتوحيد الله ﷿{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٧٦٢ (١٠٠٢٨) من مرسل عكرمة.تفسير مجاهد ص٣٦٥.أخرجه ابن أبي حاتم ٦/١٧٦٢.تفسير الثعلبي ٥/١٦، وتفسير البغوي ٤/١٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٩٦-.أخرجه ابن جرير ١١/٣٦٨، وابن أبي حاتم ٦/١٧٦٢ بلفظ: وهموا بإخراج الرسول، يقول: هموا بإخراجه فأخرجوه.أخرجه ابن جرير ١١/٣٦٨.تفسير مقاتل بن سليمان ٢/١٥٩-١٦٠.تفسير مجاهد ص٣٦٥، وأخرجه ابن جرير ١١/٣٦٨، وابن أبي حاتم ٦/١٧٦٢.علَّقه ابن أبي حاتم ٦/١٧٦٢.أخرجه ابن جرير ١١/٣٦٨، وابن أبي حاتم ٦/١٧٦٣.تفسير مقاتل بن سليمان ٢/١٥٩-١٦٠.أخرجه ابن أبي حاتم ٦/١٧٦٣.تفسير مقاتل بن سليمان ٢/١٥٩-١٦٠.