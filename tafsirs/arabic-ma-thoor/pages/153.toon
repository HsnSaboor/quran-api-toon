quran[8]{c,v,t}:
  7,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَا رَبَّنَا ظَلَمۡنَاۤ أَنفُسَنَا وَإِن لَّمۡ تَغۡفِرۡ لَنَا وَتَرۡحَمۡنَا لَنَكُونَنَّ مِنَ ٱلۡخَـٰسِرِینَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحّاك- في قوله: <span class="qpc-hafs">﴿قالا﴾</span> قال: آدمُ وحوّاءُ: <span class="qpc-hafs">﴿ربَّنا ظلمنا أنفُسنا﴾</span> يعني: ذنبًا أذْنبْناه، فغفَره لهما{1}. (٦/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿قالا ربَّنا ظلمنا أنفُسَنا﴾</span> الآية، قال: هي الكلماتُ التي تلقّى آدمُ من ربِّه{2}. (٦/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر-، مثله{3}. (٦/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادةَ بن دعامة</span> -من طريق مَعْمَر- قال: قال آدم: يا ربِّ، أرأيتَ إن تبتُ فاستغفرتُ؟ قال: إذًا أُدْخِلُك الجنَّة. وأمّا إبليس فلم يستغفر، وإنما سأل النَّظِرةَ{4}، فأعطى كل واحد منهما الذي سَأَل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالا ربنا ظلمنا أنفسنا وإن لم تغفر لنا﴾</span> ذنوبنا، <span class="qpc-hafs">﴿وترحمنا﴾</span> وتتجاوز عنّا؛ <span class="qpc-hafs">﴿لنكونن من الخاسرين﴾</span> في العقوبة، فتاب آدمُ ﵇ يوم عاشوراء يوم الجمعة، فتاب اللهُ عليه{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَا رَبَّنَا ظَلَمۡنَاۤ أَنفُسَنَا وَإِن لَّمۡ تَغۡفِرۡ لَنَا وَتَرۡحَمۡنَا لَنَكُونَنَّ مِنَ ٱلۡخَـٰسِرِینَ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: إنّ المؤمنَ ليستحي ربَّه من الذنب إذا وقَع به، ثم يعلمُ بحمدِ الله أينَ المخرجُ؛ يعلمُ أنّ المخرجَ في الاستغفار والتوبة إلى الله ﷿، فلا يحتشِمنَّ رجلٌ من التوبةِ، فإنّه لولا التوبةُ لم يُخْلِص أحدٌ من عبادِ اللهِ، وبالتوبة أدرك الله أباكم الرئيسَ في الخيرِ من الذنب حين وقع فيه{7}. (٦/٣٤٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٥٤.|2:عزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ١٠/١١٦. وعزاه السيوطي إلى عبد بن حميد.|4:النَّظِرَةُ -بكسر الظاء-: التأْخير فِي الأَمر. لسان العرب (نظر).|5:أخرجه عبد الرزاق ٢/٢٢٦، وابن جرير ١٠/١١٦.|6:تفسير مقاتل بن سليمان ٢/٣٢.|7:عزاه السيوطي إلى أحمد في الزهد، وأبي الشَّيخ.
  7,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ٱهۡبِطُوا۟ بَعۡضُكُمۡ لِبَعۡضٍ عَدُوࣱّۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٨٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَبّادِ بْنِ مَيْسَرَةَ- قال: هبط آدم بالهند، وحواء بجدة، وإبليس بدست ميسان من البصرة على أميال، وهبطت الحية بأصبهان{1}<span class=comment-ref>٢٤٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٦/٢٧٦) عند تفسير قوله تعالى: <span class="qpc-hafs">﴿قالَ اهْبِطُوا بَعْضُكُمْ لِبَعْضٍ عَدُوٌّ﴾</span> بقوله: «وقد ذكر المفسرون الأماكنَ التي هبط فيها كل منهم، ويرجع حاصلُ تلك الأخبار إلى الإسرائيليات، والله أعلم بصحتها، ولو كان في تعيين تلك البقاع فائدةٌ تعود على المكلفين في أمر دينهم أو دنياهم لَذكرها الله تعالى في كتابه، أو رسولُه ﷺ».</div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي سالم- <span class="qpc-hafs">﴿اهبطوا بعضكم لبعض عدو﴾</span>، قال: آدم، وحواء، والحيَّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿اهبطوا بعضكم لبعض عدو﴾</span>، قال: فلَعَن الحيَّةَ، وقَطَع قوائمها، وتركها تمشي على بطنها، وجعل رزقها من التراب، وأُهبِطوا إلى الأرض: آدم، وحواء، وإبليس، والحيَّة{3}<span class=comment-ref>٢٤٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧٥</span> نقل <u>ابنُ عطية</u> (٣/٥٣٨) في معنى الآية عن فرقة قولهم: «هي مخاطبةٌ لآدم وذريته، وإبليس وذريته». ثم <span class="comment-type-2">انتقدهم</span> <span class="mustanad">مستندًا إلى دلالة العقل</span> قائلًا: «وهذا ضعيف؛ لِعَدَمهم في ذلك الوقت، فإن قيل: خاطبهم وأمرهم بشرط الوجود. فذلك يبعُد في هذه النازلة؛ لأنّ الأمر بشرط الوجود إنّما يصح إذا تَرَتَّب على المأمور بعد وجوده، وصحَّ معناه عليه، كالصلاة والصوم ونحو ذلك، وأما هنا فإنّ معنى الهبوط لا يُتَصَوَّر في بني آدم بعد وجودهم، ولا يتعلق بهم من الأمر به شيء. وأمّا قوله تعالى في آية أخرى: <span class="qpc-hafs">﴿اهْبِطا﴾</span> [طه:١٢٣] فهي مخاطبة لآدم وإبليس؛ بدليل بيانه العداوة بينهما».</div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأوحى إليهما: <span class="qpc-hafs">﴿قال اهبطوا﴾</span> من الجنة؛ آدم، وحواء، وإبليس، والحية، <span class="qpc-hafs">﴿بعضكم لبعض عدو﴾</span> يقول: إبليس لهما عدو، وهما لإبليس عدو{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَكُمۡ فِی ٱلۡأَرۡضِ مُسۡتَقَرࣱّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٨٦<span class="dash">-</span></span> عن كُرَيْبٍ، قال: دعاني <span class="name-1">ابنُ عبّاس</span>، فقال: اكتُبْ: بسم الله الرحمنِ الرحيمِ، من عبد الله إلى فلانٍ حبرِ تيماءَ، حدِّثْني عن قوله: <span class="qpc-hafs">﴿ولَكُم في الأرضِ مستقرٌّ ومتاعُ إلى حينٍ﴾</span>. فقال: هو مستقرُّه فوقَ الأرضِ، ومستقرُّه في الرَّحِم، ومستقرُّه تحت الأرض، ومستقرُّه حيثُ يصيرُ إلى الجنَّة أو إلى النارِ{5}. (٦/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿ولكم في الأرض مستقر﴾</span>، قال: القبور{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٨٩<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- في قوله: <span class="qpc-hafs">﴿ولكم في الأرض مستقر﴾</span>، قال: هو قوله: <span class="qpc-hafs">﴿الذي جعل لكم الأرض فراشا﴾</span> [البقرة:٢٢]{6}<span class=comment-ref>٢٤٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧٦</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٠/١١٨) <span class="mustanad">مستندًا إلى دلالة العموم، والنظائر</span> عمومَ معنى المستقر، فقال: «إنّ الله -تعالى ذِكْره- أخبر آدم وحواء وإبليس والحية إذ أهبطهم إلى الأرض أنّهم عدوٌّ بعضهم لبعض، وأنّ لهم مستقرًّا يستقرون فيه، ولم يَخْصُصْها بأنّ لهم فيها مستقرًّا في حال حياتهم دون حال موتهم، بل عمَّ الخبرُ عنها بأنّ لهم فيها مستقرًّا، فذلك على عمومه، كما عمَّ خبر الله ولهم فيها مستقرٌّ في حياتهم على ظهرها، وبعد وفاتهم في بطنها، كما قال -جل ثناؤه-: <span class="qpc-hafs">﴿ألَمْ نَجْعَلِ الأَرْضَ كِفاتًا * أحْياءً وأَمْواتًا﴾</span> [المرسلات:٢٥-٢٦]».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٣/٥٣٩) على قول أبي العالية، وابن عباس، فقال: «واللفظ يَعُمُّهما».</div></p><p><h3><span class="qpc-hafs">﴿وَمَتَـٰعٌ إِلَىٰ حِینࣲ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ومتاع إلى حين﴾</span>، قال: الحياة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيِّ، عمَّن حدَّثه- <span class="qpc-hafs">﴿ومتاع إلى حين﴾</span>، قال: إلى يوم القيامة، وإلى انقطاع الدنيا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- <span class="qpc-hafs">﴿ومتاع إلى حين﴾</span>، قال: الحين الذي لا يُدْرَك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ومتاع إلى حين﴾</span>، يقول: بلاغ إلى الموت{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكم في الأرض مستقر ومتاع إلى حين﴾</span>، يعني: إلى مُنتَهى آجالكم، وإبليس في النفخة الأولى{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٥٤-١٤٥٥.</p><p><b>وقد تقدمت الآثار عن ذلك في سورة البقرة [٣٥]، وكررها ابن أبي حاتم هنا كعادته.</b>|2:أخرجه ابن جرير ١٠/١١٧.|3:أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/١٣٥ (٩٤٣) بنحوه، وابن جرير ١٠/١١٧.|4:تفسير مقاتل بن سليمان ٢/٣٢.|5:عزاه السيوطي إلى أبي الشيخ.|6:أخرجه ابن جرير ١٠/١١٧، وابن أبي حاتم ٥/١٤٥٥.|7:علَّقه ابن أبي حاتم ٥/١٤٥٥.|8:أخرجه ابن جرير ١٠/١١٧، وابن أبي حاتم ٥/١٤٥٥.|9:أخرجه ابن أبي حاتم ٥/١٤٥٦.|10:أخرجه ابن جرير ١٠/١١٨.|11:أخرجه ابن أبي حاتم ٥/١٤٥٦.|12:أخرجه ابن أبي حاتم ٥/١٤٥٦.|13:تفسير مقاتل بن سليمان ٢/٣٢.
  7,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فِیهَا تَحۡیَوۡنَ وَفِیهَا تَمُوتُونَ وَمِنۡهَا تُخۡرَجُونَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال فيها تحيون﴾</span> يعني: في الأرض، <span class="qpc-hafs">﴿وفيها تموتون﴾</span> عند مُنتَهى آجالكم، <span class="qpc-hafs">﴿ومنها تخرجون﴾</span> يوم القيامة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٢.
  7,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰبَنِیۤ ءَادَمَ قَدۡ أَنزَلۡنَا عَلَیۡكُمۡ لِبَاسࣰا یُوَ ٰ⁠رِی سَوۡءَ ٰ⁠ تِكُمۡ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٢٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي سعد المدني- يقول في قوله: <span class="qpc-hafs">﴿يا بني آدم قد أنزلنا عليكم لباسا يواري سوآتكم وريشا﴾</span>، قال: أربعُ آياتٍ نَزَلت في قريش، كانوا في الجاهلية لا يطوفون بالبيت إلا عُراة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قولِه: <span class="qpc-hafs">﴿قد أنزلنا عليكُم لباسًا يُواري سوءاتكم﴾</span>، قال: نزَلت في الحُمْسِ من قريشٍ، ومَن كان يأخذُ مأخذها من قبائل العرب الأنصار؛ الأوس، والخزرج، وخزاعة، وثقيف، وبني عامر بن صعصعةَ، وبُطون كنانةَ بن بكر، كانوا لا يأكلون اللحم، ولا يأتونَ البيوتَ إلا من أدبارِها، ولا يَضطرِبُون{2} وبرًا ولا شعَرًا، إنما يَضطرِبُون الأُدْمَ، ويُلبِسون صِبيانَهم الرِّهاطَ{3}، وكانوا يطوفونَ عراةً إلا قريشًا، فإذا قدِمُوا طرَحُوا ثيابَهم التي قدِموا فيها، وقالوا: هذه ثيابُنا التي تطهَّرنا إلى ربِّنا فيها من الذنوبِ والخطايا. ثم قالوا لقريشٍ: مَن يُعِيرُنا مِئزَرًا؟ فإن لم يجدُوا طافوا عُراةً، فإذا فرغُوا من طوافهم أخَذوا ثيابَهم التي كانوا وضَعُوا{4}. (٦/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في ثقيف، وبني عامر بن صَعْصَعة، وخزاعة، وبني مدلج، وعامر والحارث ابْنَيْ عبدِ مناة، قالوا: لا نطوف بالبيت الحرام في الثياب التي نُقارِف فيها الذنوب، ولا يضربون على أنفسهم خِباءً من وبَر ولا صوف ولا شعر ولا أدَم{5}. فكانوا يطوفون بالبيت عراة، ونساءهم يَطُفْنَ بالليل؛ فأنزل الله: <span class="qpc-hafs">﴿يا بني آدم قد أنزلنا عليكم لباسا﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰبَنِیۤ ءَادَمَ قَدۡ أَنزَلۡنَا عَلَیۡكُمۡ لِبَاسࣰا یُوَ ٰ⁠رِی سَوۡءَ ٰ⁠ تِكُمۡ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٠٠<span class="dash">-</span></span> عن <span class="name-2">معبد الجُهَنِيِّ</span> -من طريق عوف- يقول في قوله: <span class="qpc-hafs">﴿يا بني آدم قد أنزلنا عليكم لباسا يواري سوآتكم وريشا﴾</span>، قال: اللِّباس الذي يلبسون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٠١<span class="dash">-</span></span> عن <span class="name-2">عُروة بن الزُّبير</span> -من طريق أبي سعد، عمَّن سمعه- في قوله: <span class="qpc-hafs">﴿لباسًا يُواري سَوْءاتكُم﴾</span>، قال: الثياب{8}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿يا بني آدم قد أنزلنا عليكُم لباسًا يُواري سوْءاتكُم﴾</span>، قال: كان أُناسٌ من العرب يَطوفونَ بالبيت عُراةً، فلا يلْبسُ أحدُهم ثوبًا طاف فيه{9}<span class=comment-ref>٢٤٧٧</span>. (٦/٣٥٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧٧</span> ذكر <u>ابنُ عطية</u> (٣/٥٤٤) في معنى الآية قوله: «هذه المخاطبة لجميع العالَم، والمقصود بها في ذلك الوقت مَن كان يطوف من العرب بالبيت عُراة».</p><p>ثم نقل أقوالًا في كونها عادةَ قبيلة من العرب قائلًا: «فقيل: كان ذلك من عادة قريش، وقال قتادة والضحاك: كان ذلك من عادة قبيلة من اليمن. وقيل: كانت العرب تطوف عُراة، إلا الحُمْس، وهم قريش ومن والاها».</p><p>ثم <span class="comment-type-3">رجَّح</span> الأخيرَ <span class="mustanad">مستندًا إلى دلالة الواقع</span> قائلًا: «وهذا هو الصحيح؛ لأنّ قريشًا لَمّا سَنُّوا بعد عام الفيل سُنَنًا عظَّموا بها حرمتهم كانت هذه من ذلك، فكان العربيُّ إمّا أن يعيره أحدٌ من الحُمْس ثوبًا فيطوف فيه، وإمّا أن يطوف في ثيابه ثم يلقيها، وتمادى الأمرُ حتى صار عند العرب قُرْبة، فكانت العرب تقول: نطوف عُراةً كما خرجنا من بطون أمهاتنا، ولا نطوف في ثيابٍ قد تَدَنَّسنا فيها بالذنوب. ومن طاف في ثيابه فكانت سُنَّتهم كما ذكرنا أن يرمي تلك الثياب ولا ينتفع بها، وتُسَمّى تلك الثياب: اللَّقى، ... فنهى اللهُ ﷿ عن جميع ذلك، ونُودِي بمكة في سنة تسع: لا يحج بعد العام مشرك، ولا يطوف بالبيت عريان».</div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- يقول في قوله: <span class="qpc-hafs">﴿قد أنزلنا عليكم لباسا يواري سوآتكم﴾</span>، قال: يعني: ثياب الرجل التي يلبسها{10}<span class=comment-ref>٢٤٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧٨</span> نقل <u>ابنُ عطية</u> (٣/٥٤١) في معنى: <span class="qpc-hafs">﴿أنزلنا﴾</span> احتمالين: <b>الأول:</b> «أن يريد التدَرُّج». و<span class="comment-type-1">وجَّهه</span> بقوله: "أي: لما أنزلنا المطر فكان عنه جميع ما يُلْبس قال عن اللباس: <span class="qpc-hafs">﴿أنزلنا﴾</span>. وهذا <span class="mustanad">نحو قول الشاعر</span> يصف مطرًا:</p><p>أقْبَلَ في المُسْتَنِّ مِن سَحابه أسْنِمةُ الآبالِ في ربابِهِ</p><p>أي: بالمال«، <b>والثاني:</b>»أن يريد: خلقنا«. ثم <span class="comment-type-4">علَّق</span> عليه بقوله:»فجاءت العبارة بـ<span class="qpc-hafs">﴿أنْزَلْنا﴾</span> <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿وأَنْزَلْنا الحَدِيدَ فِيهِ بَأْسٌ﴾</span> [الحديد:٢٥]، <span class="mustanad">وقوله تعالى</span>: <span class="qpc-hafs">﴿وأَنْزَلَ لَكُمْ مِنَ الأَنْعامِ ثَمانِيَةَ أزْواجٍ﴾</span> [الزمر:٦]، وأيضًا فخلْق الله ﷿ وأفعاله إنما هي من علوٍّ في القدر والمنزلة".</div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن علي بن الحسين</span> -من طريق عيسى بن المسيب- في قوله: <span class="qpc-hafs">﴿لباسًا يُواري سوءاتكُم﴾</span>، قال: لباسَ العامَّة{11}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿لباسًا يُواري سوءاتكُم﴾</span>، قال: هي الثيابُ{8}. (٦/٣٥٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرِیشࣰاۖ وَلِبَاسُ ٱلتَّقۡوَىٰ ذَ ٰ⁠لِكَ خَیۡرࣱۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٠٦<span class="dash">-</span></span> عن عثمانَ: سمعتُ رسولَ الله ﷺ يقرأ: (ورِياشًا)، ولم يَقُلْ:<span class="qpc-hafs">﴿ورِيشًا﴾</span>{13}. (٦/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٧<span class="dash">-</span></span> عن <span class="name-2">زرِّ بن حبيش</span> -من طريق عاصم- أنّه قرأها: (ورِياشًا){14}. (٦/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> أنّه قرأها: <span class="qpc-hafs">﴿ورِيشًا ولِباسُ التَّقْوى﴾</span> بالرفع{15}. (٦/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٠٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قرأها: (ورِياشًا){14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٠<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنّه قرأ: <span class="qpc-hafs">﴿ورِيشًا﴾</span> بغير ألفٍ، <span class="qpc-hafs">﴿ولِباسُ التَّقْوى﴾</span> بالرفعِ{17}. (٦/٣٥٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرِیشࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وريشًا﴾</span>، قال: المالَ، واللباسَ، والعيشَ، والنعيم{18}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: (ورِياشًا)، يقولُ: مالًا{19}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافعَ بن الأزرق قال له: أخبِرْني عن قوله ﷿: <span class="qpc-hafs">﴿وريشًا﴾</span>. قال: الرِّياش: المالُ. قال: وهل تعرِفُ العربُ ذلك ؟ قال: نعم، أما سمعت الشاعر وهو يقولُ:</p><p>فرِشْني بخيرٍ طالما قد بَرَيْتَني وخَيْرُ الموالي مَن يَريشُ ولا يَبْري{20}<span class=comment-ref>٢٤٧٩</span>. (٦/٣٥٢)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧٩</span> نقل <u>ابنُ عطية</u> (٣/٥٤٢) في معنى الرياش أنه: «جمع ريش، كبيرٍ وبيار، وذيب وذياب، ولِصْبٍ ولِصاب، وشِعْب وشِعاب. وقيل: الرياش: مصدر، مِن أراشه الله يريشه إذا أنعم عليه، والريش مصدر أيضًا من ذلك، وفي الحديث: «رجلٌ راشه الله مالًا». ثم <span class="comment-type-4">علَّق</span> بقوله:»ويشبه أنّ هذا كله من معنى ريش الطائر، وريش السهم، إذ هو لباسه وسُتْرَتُه وعونه على النفوذ، وراشَ الله مأخوذ من ذلك، ألا ترى أنها تُقرَن بِـ:بَرى". ثم استشهد ببيت الشعر الوارد في الأثر.</div></p><p><div></p><p><p><span class="item-no">٢٧٣١٤<span class="dash">-</span></span> عن <span class="name-2">معبد الجهني</span> -من طريق عوف- (ورِياشًا)، قال: الرِّياش: المَعاش{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٥<span class="dash">-</span></span> عن <span class="name-2">عُروة بن الزُّبير</span> -من طريق أبي سعد، عمَّن سمِعه- في قوله (ورِياشًا)، قال: المالَ{21}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: (ورِياشًا)، قال: المال{23}. (٦/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- قوله: (ورِياشًا)، يعني: المال{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿لباسًا يُواري سوءاتِكم وريشًا﴾</span>، قال: هو اللباسُ{25}. (٦/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣١٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن علي بن الحسين</span> -من طريق عيسى بن المسيب- في قوله: <span class="qpc-hafs">﴿وريشًا﴾</span> قال: لباسَ الزينة، <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span> قال: الإسلامُ{26}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: (رِياشًا)، قال: المال{27}. (٦/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: من أمري كان اللباس في الأرض، <span class="qpc-hafs">﴿يواري سوآتكم﴾</span> يعني: يُغَطِّي عوراتكم، <span class="qpc-hafs">﴿وريشا﴾</span> يعني: المال{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٢<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قول الله (لِباسًا يُوارِي سَوْءاتِكُمْ ورِياشًا ولِباس التَّقْوى)، قال: الريش: المال. والرِّياش: الثياب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: الرياشُ: الجمالُ{30}<span class=comment-ref>٢٤٨٠</span>. (٦/٣٥٢)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٠</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٣/١٤٣) أنّ الريش: هو الأثاث والمتاع، <span class="mustanad">مستندًا إلى لغة العرب</span>، فقال: «والصحيح أنّ الريش هو الأثاث والمتاع، قال أبو عمر: والعرب تقول: أعطاني فلان ريشَه، أي: كسوته وجهازه. وقال غيره: الرياش في كلام العرب: الأثاث، وما ظهر من المتاع والثياب والفرش ونحوها». و<span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> قولَ ابن زيد، فقال: «وهذا لأنّه مأخوذ من ريش الطائر، وهو ما يَرُوش به، ويدفع عنه الحرَّ والبرد، وجمال الطائر: ريشه».</div></p><p><h3><span class="qpc-hafs">﴿وَلِبَاسُ ٱلتَّقۡوَىٰ ذَ ٰ⁠لِكَ خَیۡرࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٢٤<span class="dash">-</span></span> عن الحسن، قال: قال رسولُ الله ﷺ: «<b>ما مِن عبدٍ عَمِل خيًرا أو شرًّا إلا كُسِيَ رداءَ عملِه حتى يعرِفوه، وتصديقُ ذلك في كتاب الله: <span class="qpc-hafs">﴿ولباسُ التَّقوى ذلكَ خيرٌ﴾</span></b>» الآية{31}. (٦/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٥<span class="dash">-</span></span> عن الحسن، قال: رأيتُ عثمانَ على المنبر، قال: يا أيُّها الناسُ، اتَّقوا الله في هذه السرائر، فإنِّي سمعتُ رسولَ الله ﷺ يقولُ: «<b>والذي نفسُ محمد بيده، ما عَمِل أحدٌ عملًا قطُّ سِرًّا إلّا ألْبسه اللهُ رداءَه علانيةً؛ إنْ خيرًا فخيرٌ، وإن شرًّا فشرٌّ</b>». ثم تلا هذه الآية (ورِياشًا -ولم يقل: <span class="qpc-hafs">﴿وريشا﴾</span>- ولِباس التَّقْوى ذَلِكَ خير)، قال: السَّمْتُ الحَسَن{32}. (٦/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span> قال: الإيمانُ، والعملُ الصالح، <span class="qpc-hafs">﴿ذلك خيرٌ﴾</span> قال: الإيمانُ والعملُ خيرٌ من الرِّيش، واللِّباس{33}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق زياد بن عمرو- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span>، قال: السَّمْتُ الحَسَنُ في الوجه{34}. (٦/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٨<span class="dash">-</span></span> عن <span class="name-2">مَعْبدٍ الجُهَنيِّ</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span> قال: هو الحياءُ، ألم تَرَ أن الله قال: <span class="qpc-hafs">﴿يا بني آدم قد أنزلْنا عليكُم لباسًا يُوارِي سوءاتكُم وريشًا ولباسُ التَّقوى﴾</span>؟! فاللِّباس الذي يُواري سوآتكم: هو لبُوسكم. والرِّياش: المعاشُ. ولباس التقوى: الحياءُ{35}. (٦/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٢٩<span class="dash">-</span></span> عن <span class="name-2">عُروة بن الزُّبير</span> -من طريق أبي سعد المدني، عمَّن سمعه- في قوله: <span class="qpc-hafs">﴿ولباسُ التقوى﴾</span>، قال: خشيةُ الله{36}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span>، قال: ما يَلْبسُ المتَّقون يومَ القيامة، ذلك خيرٌ مِن لباس أهل الدنيا{37}. (٦/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى ذلك خيرُ﴾</span>، قال: ما يلبسُ المتَّقون يومَ القيامةِ خيرٌ مما يلبسُ أهلُ الدنيا{31}. (٦/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٢<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: الإيمان عُرْيانٌ، لِباسه التقوى، وزِينَته الحياء، وفأله الفقه، ومآله العِفَّة، وثمره العمل الصالح{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span>، قال: هو الإيمانُ، وقد أنزل اللهُ اللباسَ. ثم قال: خيرُ اللباس التقوى{40}. (٦/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن علي بن الحسين</span> -من طريق عيسى بن المسيب- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span>، قال: الإسلامُ{37}. (٦/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٥<span class="dash">-</span></span> قال <span class="name-2">زيد بن علي بن الحسين</span>: لباس التقوى: الآلات التي يُتَّقى بها في الحرب؛ كالدِّرع، والمِغْفَر، والسّاعد، والساقين{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span> قال: الإيمانُ، <span class="qpc-hafs">﴿ذلك خيرٌ﴾</span> يقولُ: ذلك خيرٌ من الرِّياشِ والِّلباسِ يُوارِي سوآتكم{43}. (٦/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: هو العفاف{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولباس التقوى﴾</span> يعني: من العمل الصالح، <span class="qpc-hafs">﴿ذلك خير﴾</span> يقول: العمل الصالح خيرٌ من الثياب والمال{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿ولباس التقوى﴾</span>: الإيمان{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٤٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولباسُ التَّقوى﴾</span>، قال: يتَّقي اللهَ، فيُوارِي عورتَه، ذاك لباسُ التقوى{47}<span class=comment-ref>٢٤٨١</span>. (٦/٣٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٠/١٣١) <span class="mustanad">مستندًا إلى دلالة العموم</span> أنّ المعنى: استشعار النفوس تقوى الله في الانتهاء عما نهى الله عنه من معاصيه، والعمل بما أمر به من طاعته. ثم قال مُعَلِّلًا: «وإنّما قُلنا: عنى بلباس التقوى: استشعار النفس والقلب ذلك. لأنّ اللباسَ إنما هو ادِّراع ما يُلْبَس، واجتياب ما يُكْتَسى، أو تغطية بدنه أو بعضه به، فكلُّ من ادَّرَع شيئًا واجتابه حتى يُرى عينُه أو أثره عليه فهو له لابسٌ، ولذلك جعل -جلَّ ثناؤه- الرجال للنساء لباسًا، وهُنَّ لهم لباسًا، وجعل الليل لعباده لباسًا». وبيَّن أن جميع ما قيل في لباس التقوى داخلٌ تحت هذا المعنى، فقال: «لأنّ مَن اتقى الله كان به مؤمنًا، وبما أمره به عاملًا، ومنه خائفًا، وله مُراقِبًا، ومِن أن يُرى عند ما يَكْرَهه من عباده مُسْتَحْيِيًا، ومن كان كذلك ظهرت آثار الخير فيه، فحسن سَمْتُه وهَدْيه، ورُئِيَت عليه بهجة الإيمان ونوره».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u>(٣/٥٤٣) قول ابن عباس، ومعبد الجهني، وعثمان بن عفان، وعروة بن الزبير، وابن جريج، وابن زيد، وزيد بن علي، فقال: «وهذه كلها مُثُل، وهي من لباس التقوى».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٦/٢٧٩) بقوله: «وكلُّ هذه متقاربة».</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مِنۡ ءَایَـٰتِ ٱللَّهِ لَعَلَّهُمۡ یَذَّكَّرُونَ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: ذلك الثياب والمال مِن آيات الله، ومن صنعه <span class="qpc-hafs">﴿لعلهم﴾</span> يعني: لكي <span class="qpc-hafs">﴿يذَّكَّرون﴾</span> فيعتبروا في صُنْعِه؛ فيُوَحِّدوه{28}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مِنۡ ءَایَـٰتِ ٱللَّهِ لَعَلَّهُمۡ یَذَّكَّرُونَ ۝٢٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٤٢<span class="dash">-</span></span> عن عَلِيٍّ، قال: كان رسولُ الله ﷺ إذا لبس ثوبًا جديدًا قال: «<b>الحمد للهِ الذي كساني من الرِّياش ما أُوارِي به عَوْرتي، وأتجمَّل به في الناس</b>»{49}. (٦/٣٥١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰبَنِیۤ ءَادَمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٤٣<span class="dash">-</span></span> عن عبد الرحمن بن مَعْقِلٍ، قال: ذُكِر الجَدُّ عند <span class="name-1">ابن عباس</span>: فقال: أيُّ أبٍ لكم أكبرُ؟ فقال: آدم. قال: فإنّ الله يقول: <span class="qpc-hafs">﴿يا بني آدم﴾</span>{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا بني آدم﴾</span> يعنيهم{28}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/١٢٠.|2:يَضطرِبُون: يَنصِبُون ويُقِيمون على أوتاد مضروبة في الأرض. النهاية (ضرب).|3:الرَّهْط: جلد قَدْر ما بين الركبة والسُّرّة، تلبسه الجارية الصغيرة قبل أن تُدرك، وتلبسه أيضًا وهي حائض. لسان العرب (رهط).|4:عزاه السيوطي إلى ابن المنذر.|5:الأَدَم: الجلد. لسان العرب (أدم).|6:تفسير مقاتل بن سليمان ٢/٣٢-٣٣.|7:أخرجه ابن جرير ١٠/١٢٠.|8:أخرجه ابن جرير ١٠/١٢١.|9:تفسير مجاهد ص٣٣٤، وأخرجه ابن جرير ١٠/١٢٠، وابن أبي حاتم ٥/١٤٥٦. وعزاه السيوطي إلى عَبد بن حميد، وابن المنذر، وأبي الشيخ.|10:أخرجه ابن جرير ١٠/١٢١، وابن أبي حاتم ٥/١٤٥٦.|11:أخرجه ابن أبي حاتم ٥/١٤٥٦.|12:أخرجه ابن جرير ١٠/١٢١.|13:عزاه السيوطي إلى ابن مردويه.</p><p>وقراءة (ورِياشًا) قراءة شاذة، تروى أيضًا عن عن عاصم، وعن الحسن، وعن جماعة. انظر: مختصر ابن خالويه ص٤٨، والمحتسب ١/٢٤٦. وقراءة العشرة <span class="qpc-hafs">﴿ورِيشًا﴾</span>.|14:أخرجه ابن جرير ١٠/١٢٢.|15:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا نافعًا، وأبا جعفر، وابن عامر، والكسائي، فإنهم قرؤوا: ‹ولِباسَ التَّقْوى› بفتح السين. انظر: النشر ٢/٢٦٨، والإتحاف ص٢٨٢.|16:أخرجه ابن جرير ١٠/١٢٢.|17:عزاه السيوطي إلى عَبد بن حميد.|18:أخرجه ابن جرير ١٠/١٢٤، وابن أبي حاتم ٥/١٤٥٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|19:أخرجه ابن جرير ١٠/١٢٣، وابن أبي حاتم ٥/١٤٥٧.|20:أخرجه الطَّسْتيُّ -كما في الإتقان ٢/٦٩-.|21:أخرجه ابن جرير ١٠/١٢٤.|22:أخرجه ابن جرير ١٠/١٢٤.|23:تفسير مجاهد ص٣٣٤، وأخرجه ابن جرير ١٠/١٢٣، وابن أبي حاتم ٥/١٤٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|24:أخرجه ابن جرير ١٠/١٢٤.|25:عزاه السيوطي إلى ابن جرير، وعَبد بن حميد.|26:أخرجه ابن أبي حاتم ٥/١٤٥٧.|27:أخرجه ابن جرير ١٠/١٢٣-١٢٤.|28:تفسير مقاتل بن سليمان ٢/٣٣.|29:تفسير الثوري ص١١٢.|30:أخرجه ابن جرير ١٠/١٢٤-١٢٥، وابن أبي حاتم ٥/١٤٥٧.|31:عزاه السيوطي إلى أبي الشيخ.|32:أخرجه ابن جرير ١٠/١٢٧، وابن أبي حاتم ٥/١٤٥٨ (٨٣٤٢). وأورده الثعلبي ٤/٢٢٦.</p><p>قال ابن كثير في تفسيره ٣/٤٠١: «هكذا رواه ابن جرير من رواية سليمان بن أرقم، وفيه ضعف».|33:أخرجه ابن جرير ١٠/١٢٦، وابن أبي حاتم ٥/١٤٥٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|34:أخرجه ابن جرير ١٠/١٢٦-١٢٧.|35:أخرجه ابن جرير ١٠/١٢٥-١٢٦، وابن أبي حاتم ٥/١٤٥٨. وعزاه السيوطي إلى أبي عبيد، وعبد بن حميد، والحكيم الترمذي، وابن المنذر، وأبي الشيخ.|36:أخرجه ابن جرير ١٠/١٢٧.|37:أخرجه ابن أبي حاتم ٥/١٤٥٨.|38:عزاه السيوطي إلى أبي الشيخ.|39:تفسير الثعلبي ٤/٢٢٦.|40:أخرج ابن جرير ١٠/١٢٥. وعزاه السيوطي إلى عبد بن حميد.|41:أخرجه ابن أبي حاتم ٥/١٤٥٨.|42:تفسير البغوي ٣/٢٢٢. وفي تفسير الثعلبي ٤/٢٢٦ غير منسوب لقائل.|43:أخرجه ابن جرير ١٠/١٢٥، ١٣١.|44:تفسير البغوي ٣/٢٢٢.|45:تفسير مقاتل بن سليمان ٢/٣٣.|46:أخرجه ابن جرير ١٠/١٢٥.|47:أخرجه ابن جرير ١٠/١٢٨، وابن أبي حاتم ٥/١٤٥٨.|48:تفسير مقاتل بن سليمان ٢/٣٣.|49:أخرجه أحمد ٢/٤٥٧ (١٣٥٣)، ٢/٤٥٨ (١٣٥٥)، وابن أبي حاتم ٥/١٤٥٧ (٨٣٣٢).</p><p>قال الهيثمي في المجمع ٥/١١٨-١١٩ (٨٤٩١، ٨٤٩٢): «وفيه مختار بن نافع، وهو ضعيف». وقال المغربي في جمع الفوائد ٢/٤٠٠ (٥٧٤٥): «لأحمد والموصلي بضعف». وقال الألباني في الضعيفة ١٣/٥٦١ (٦٢٦٣): «ضعيف».|50:أخرجه ابن أبي حاتم ٥/١٤٥٩.|51:تفسير مقاتل بن سليمان ٢/٣٣.
  7,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَفۡتِنَنَّكُمُ ٱلشَّیۡطَـٰنُ كَمَاۤ أَخۡرَجَ أَبَوَیۡكُم مِّنَ ٱلۡجَنَّةِ یَنزِعُ عَنۡهُمَا لِبَاسَهُمَا لِیُرِیَهُمَا سَوۡءَ ٰ⁠ تِهِمَاۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الجوزاء- <span class="qpc-hafs">﴿ينزع عنهما لباسهما﴾</span>، قال: كان لباسهما الظُّفْر، بمنزلة الريش على الطير، فلمّا أصابا الخطيئة نُزِع عنهما، وتُرِكَت الأظفارُ تذكرة وزينة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٤٦<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق سهل- قال: كان لِباسُ آدمَ في الجنة الياقوت، فلمّا عصى قَلَصَ{2} فصار الظُّفْر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿ينزعُ عنهمُا لباسهما﴾</span>، قال: التَّقوى{4}<span class=comment-ref>٢٤٨٢</span>. (٦/٣٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٢</span> عبَّر <u>ابنُ عطية</u> (٣/٥٤٥) عن قول مجاهد، فقال: «وقال مجاهد: هي استعارة، وإنما أراد لبسة التُّقى المنزلة. ثم <span class="comment-type-2">انتَقَده</span> بقوله:»وهذا ضعيف".</div></p><p><div></p><p><p><span class="item-no">٢٧٣٤٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق شريك- <span class="qpc-hafs">﴿يَنْزِعُ عَنْهُما لِباسَهُما﴾</span>، قال: لباسُ كلِّ دابَّةٍ منها، ولباسُ الإنسانِ الظُّفْر، فأدْركت آدمَ التوبةُ عند ظُفْرِه، أو قال: أظفاره{5}. (٦/٣٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٤٩<span class="dash">-</span></span> عن <span class="name-2">وهبِ بنِ مُنَبِّه</span> -من طريق عمرو- <span class="qpc-hafs">﴿ينزعُ عنهُما لباسَهُما﴾</span>، قال: النُّور{6}. (٦/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يفتننكم الشيطان﴾</span> في دينكم؛ أمر الثياب، فيدعها عنكم، فتبدي عوراتكم، <span class="qpc-hafs">﴿كما أخرج أبويكم﴾</span> يعني: كما فعل بأبويكم آدم وحواء، فأخرجهما من الجنة، وبدت عورتهما، فذلك قوله: <span class="qpc-hafs">﴿ينزع عنهما لباسهما﴾</span> يعني ثيابهما؛ <span class="qpc-hafs">﴿ليريهما سوآتهما﴾</span> يعني: عوراتهما{7}<span class=comment-ref>٢٤٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٣</span> اختلف المفسرون في صفة اللباس الذي نزعه الشيطان عن آدم وحواء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٠/١٣٥) <span class="mustanad">مستندًا إلى ظاهر اللفظ</span> أنّ المراد: مطلق اللباس، دون تخصيص ذلك بلباس دون آخر، فقال: «إنّ الله تعالى حذَّر عباده أن يفتنهم الشيطان كما فتن أبويهم آدم وحواء، وأن يُجَرِّدهم من لباس الله الذي أنزله إليهم، كما نزع عن أبويهم لباسهما، واللباس المطلق من الكلام بغير إضافة إلى شيء في متعارف الناس: هو ما اجتاب فيه اللابس من أنواع الكُسى، أو غطّى بدنه أو بعضه. وإذ كان ذلك كذلك فالحقُّ أن يُقال: إنّ الذي أخبر اللهُ عن آدمَ وحواءَ من لباسهما الذي نزعه عنهما الشيطان هو بعض ما كانا يُواريان به أبدانهما وعورتهما. وقد يجوز أن يكون ذلك كان ظُفُرًا، ويجوز أن يكون ذلك كان نورًا، ويجوز أن يكون كان غير ذلك، ولا خبر عندنا بأيِّ ذلك كان تثبت به الحجة، فلا قول في ذلك أصوبُ من أن يقال كما قال الله: <span class="qpc-hafs">﴿يَنْزِعُ عَنْهُما لِباسَهُما﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ یَرَىٰكُمۡ هُوَ وَقَبِیلُهُۥ مِنۡ حَیۡثُ لَا تَرَوۡنَهُمۡۗ إِنَّا جَعَلۡنَا ٱلشَّیَـٰطِینَ أَوۡلِیَاۤءَ لِلَّذِینَ لَا یُؤۡمِنُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مخرمة- قال: أيُّما رجلٍ منكم تَخَيَّل له الشيطانُ حتى يراه فلا يَصُدَّنَّ عنه، ولْيَمْضِ قُدُمًا، فإنّهم منكم أشدُّ فَرَقًا منكم منهم، فإنّه إن صدَّ عنه ركبه، وإن مضى هرب منه.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٢<span class="dash">-</span></span> قال <span class="name-2">مجاهدٌ</span>: فأنا ابتُلِيتُ به حتى رأيتُه، فذكرتُ قولَ ابن عباس، فمضيتُ قُدُمًا، فهرَب مِنِّي{8}. (٦/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وقبيله﴾</span>: هو، وولده{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٤<span class="dash">-</span></span> عن <span class="name-2">مُطَرِّف بن عبد الله بن الشِّخِّير</span> -من طريق ثابت- أنّه كان يقولُ: لو أنّ رجلًا رأى صيدًا، والصيدُ لا يَراه، فخَتَلَه؛ ألم يُوشِك أن يأخذه؟ قالوا: بلى. قال: فإنّ الشيطانَ يرانا، ونحنُ لا نراه، وهو يُصِيبُ مِنّا{10}. (٦/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: سأل أن يَرى ولا يُرى، وأن يخرُج مِن تحت الثَّرى، وأنّه متى شاب عاد فتًى، فأُجيب{11}. (٦/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿إنهُ يراكُم هُو وقَبيلُهُ﴾</span>، قال: الجِنُّ، والشياطينُ{12}. (٦/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿قبيله﴾</span>: الجن والشياطين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- <span class="qpc-hafs">﴿إنهُ يراكُم هُوَ وقبيلُهُ من حيثُ لا ترونهُم﴾</span>، قال: واللهِ، إنّ عدوًّا يراك من حيثُ لا تَراه لَشديدُ المُؤنِة، إلا مَن عَصَم اللهُ{14}. (٦/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٥٩<span class="dash">-</span></span> قال <span class="name-2">مالك بن دينار</span>: <span class="qpc-hafs">﴿من حيث لا ترونهم﴾</span>، إنّ عدوًّا يراك ولا تراه لَشديد الخصومة والمُؤْنَة، إلّا مَن عَصَم اللهُ{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه يراكم هو وقبيله من حيث لا ترونهم﴾</span>، يقول: يراكم إبليسُ وجنودُه من الشياطين من حيث لا ترونهم، <span class="qpc-hafs">﴿إنا جعلنا الشياطين أولياء للذين لا يؤمنون﴾</span> يعني: لا يُصَدِّقون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وقَبيلُهُ﴾</span>، قال: نسلُه{17}. (٦/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٢<span class="dash">-</span></span> عن نُعيْم بن عمرَ، قال: الجنُّ لا يَرَوْن الشياطينَ بمنزلةِ الإنس{18}. (٦/٣٥٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/١٣٣، وابن أبي حاتم ٥/١٤٥٩ بنحوه.|2:بمعنى: انضم وانزوى. لسان العرب (قلص).|3:أخرجه ابن أبي حاتم ٥/١٤٥٩.|4:أخرجه ابن جرير ١٠/١٣٤، وابن أبي حاتم ٥/١٤٦٠. وعزاه السيوطي إلى ابن أبي شيبة، وعَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.|5:أخرجه ابن جرير ١٠/١٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|6:أخرجه ابن جرير ١٠/١٣٤. وعزاه السيوطي إلى عبد بن حميد.|7:تفسير مقاتل بن سليمان ٢/٣٣.|8:أخرجه أبو الشيخ في العظمة (١١٥٠).|9:تفسير البغوي ٣/٢٢٣.|10:أخرجه ابن أبي شيبة ١٣/٤٨٠.|11:عزاه السيوطي إلى أبي الشيخ.|12:تفسير مجاهد ص٣٣٤، وأخرجه ابن جرير ١٠/١٣٦، وابن أبي حاتم ٥/١٤٦٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١١٧-. وعزاه السيوطي إلى ابن أبي شيبة، وعَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.|13:تفسير البغوي ٣/٢٢٣.|14:أخرجه ابن أبي حاتم ٥/١٤٦٠. وعزاه السيوطي إلى عَبد بن حميد، وأبي الشيخ.|15:تفسير الثعلبي ٤/٢٢٧، وتفسير البغوي ٣/٢٢٣.|16:تفسير مقاتل بن سليمان ٢/٣٣.|17:أخرجه ابن جرير ١٠/١٣٦، وابن أبي حاتم ٥/١٤٦٠.|18:أخرجه أبو الشيخ في العظمة (١٠٩٤).
  7,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا فَعَلُوا۟ فَـٰحِشَةࣰ قَالُوا۟ وَجَدۡنَا عَلَیۡهَاۤ ءَابَاۤءَنَا وَٱللَّهُ أَمَرَنَا بِهَاۗ قُلۡ إِنَّ ٱللَّهَ لَا یَأۡمُرُ بِٱلۡفَحۡشَاۤءِۖ أَتَقُولُونَ عَلَى ٱللَّهِ مَا لَا تَعۡلَمُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وإذا فعلوا فاحشةً قالُوا وجدْنا عليهآ ءابآءنا﴾</span>، قال: كانوا يطوفون بالبيت عُراةً، فنُهُوا عن ذلك{1}. (٦/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٥<span class="dash">-</span></span> و<span class="name-2">عامر الشعبي</span> -من طريق عطاء السائب- <span class="qpc-hafs">﴿وإذا فعلوا فاحشة قالوا وجدنا عليها آباءنا﴾</span>، قال: كانوا يطوفون بالبيت عُراةً{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿وإذا فعلوا فاحشة﴾</span>، قال: الفاحشة ظُلم، والظُّلم فاحشة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿وإذا فعلوا فاحشة﴾</span>، قال: فاحشتهم أنّهم كانوا يطوفون حول البيت عُراة{4}. (٦/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿وإذا فَعَلُوا فاحِشَةً قالُوا وجَدْنا عَلَيْها آباءَنا واللَّهُ أمَرَنا بِها﴾</span>، قال: كانوا يطوفون بالبيت عُراةً، يقولون: نطوف كما ولدتنا أمهاتُنا. فتضع المرأةُ على قُبُلِها النِّسْعَةَ{5} أو الشيءَ، فتقول:</p><p>اليومَ يبدو بعضُه أو كلُّه فما بدا منه فلا أُحِلُّه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٦٩<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: الشرك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في الآية، قال: واللهِ، ما أكرَم اللهُ عبدًا قطُّ على معصيته، ولا رَضِيها له، ولا أمَر بها، ولكن رَضي لكم بطاعته، ونهاكم عن معصيته{8}. (٦/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيِّ</span> -من طريق موسى بن عبيدة- قال:كان المشركون؛ الرجالُ يطوفون بالبيت بالنهار عُراةً، والنساءُ بالليل عُراةً، ويقولون: إنّا وجدْنا عليها آباءنا، واللهُ أمرنا بها. فلما جاء الإسلامُ وأخلاقُه الكريمةُ نُهُوا عن ذلك{9}. (٦/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> – من طريق أسباط - في قوله:<span class="qpc-hafs">﴿وإذا فعلُوا فاحشةً﴾</span> الآية، قال: كان قبيلةٌ مِن العرب مِن أهل اليمن يطوفون بالبيت عُراةً، فإذا قيل لهم: لِمَ تفعلون ذلك؟ قالوا: وجدْنا عليها آباءَنا، واللهُ أمرنا بها{10}. (٦/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا فعلوا فاحشة﴾</span> يعني: معصيةً فيما حرَّموا من الحرث، والأنعام، والثياب، والألبان، فنُهُوا عن تحريم ذلك، <span class="qpc-hafs">﴿قالوا وجدنا عليها آباءنا والله أمرنا بها﴾</span> يعني: بتحريم ذلك. ثم قال: <span class="qpc-hafs">﴿قل﴾</span> يا محمد: <span class="qpc-hafs">﴿إن الله لا يأمر بالفحشاء﴾</span> يعني: بالمعاصي، فيحرم ذلك، وقل لهم: <span class="qpc-hafs">﴿أتقولون على الله﴾</span> ربكم إنّه حرم عليكم <span class="qpc-hafs">﴿ما لا تعلمون﴾</span> أنّه حرَّمه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وإذا فعلوا فاحشة﴾</span>، أي: إن أتَوْا فاحشةً{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/١٣٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|2:أخرجه ابن جرير ١٠/١٣٧.|3:أخرجه ابن أبي حاتم ٥/١٤٦١.|4:أخرجه ابن جرير ١٠/١٣٧، وابن أبي حاتم ٥/١٤٦١.|5:النِّسْعة -بالكسر-: سَيْرٌ مضفور، يُجعل زمامًا للبعير وغيره. لسان العرب (نسع).|6:أخرجه ابن جرير ١٠/١٣٧.|7:تفسير البغوي ٣/٢٢٣.|8:عزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن أبي حاتم ٥/١٤٦١، وعبد الله بن وهب في الجامع - تفسير القرآن ٢/١٢١-١٢٢ (٢٤٠).|10:أخرجه ابن جرير ١٠/١٣٨، وابن أبي حاتم ٥/١٤٦١.|11:تفسير مقاتل بن سليمان ٢/٣٣.|12:أخرجه ابن أبي حاتم ٥/١٤٦٠.
  7,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَمَرَ رَبِّی بِٱلۡقِسۡطِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿بالقسط﴾</span>، قال: بالعدل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>{2}= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿قل أمر ربي بالقسط﴾</span>: بلا إله إلا الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قُل أمرَ ربّي بالقسْط﴾</span>، قال: بالعدل{4}. (٦/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٧٩<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿قُل أمرَ ربّي بالقسْط﴾</span>: بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿قل أمر ربي بالقسط﴾</span>، والقسط: العَدْل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لهم: <span class="qpc-hafs">﴿أمر ربي بالقسط﴾</span> يعني: بالعَدْل{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقِیمُوا۟ وُجُوهَكُمۡ عِندَ كُلِّ مَسۡجِدࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وأقيمُوا وُجُوهّكُمْ عند كلُّ مسجدٍ﴾</span>، قال: إلى الكعبةِ حيثُ صلَّيَّتم؛ في كنيسةٍ، أو غيرها{8}. (٦/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مُزاحِم</span>: إذا حضرت الصلاةُ وأنتم عند مسجدٍ فصلوا فيه، ولا يقولنَّ أحدُكم: أُصَلِّي في مسجدي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأقيموا وجوهكم عند كل مسجد﴾</span>: هو المسجد الكعبة{10}<span class=comment-ref>٢٤٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٤</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٥٤٧) قول مجاهد، والسدي، فقال: «والمقصد على هذا: شرع القبلة، والأمر بالتزامها».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> (٣/١٥١) قول مجاهد، والسدي، وابن زيد، فقال: «وعلى هذا فإقامةُ الوجه: استقبال الكعبة».</p><p>ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى أحوال النزول</span> قائلًا: «وهذا فيه نظر؛ فإنّ الآية مَكِّيَّة، والكعبة إنّما فُرِضَت في المدينة». غير أنّه ذَكَر له <span class="comment-type-1">وجْهًا</span> يمكن أن يُحمَل عليه، فقال: «إلّا أن يُراد بإقامة الوجه: الاستقبال المأمور به».</div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿وأقيموا وجوهكم عند كل مسجد﴾</span>، قال: في الإخلاص أن لا تدعوا غيره، وأن تخلصوا له الدين{11}<span class=comment-ref>٢٤٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٥٤٧) قولَ الربيع، فقال: «فلا يُؤخَذ الوجه على أنّه الجارحة، بل هو المقصد والمنزع».</div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأقيموا وجوهكم﴾</span> يعني: وأمر ربي أن تقيموا وجوهكم، يعني: إلى القبلة <span class="qpc-hafs">﴿عند كل مسجد﴾</span> في بِيعَة، أو كنيسة، أو غيرها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأقيموا وجوهكم عند كل مسجد﴾</span>، قال: أقيموها للقبلة، هذه القبلة التي أمركم الله بها{10}<span class=comment-ref>٢٤٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٦</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٠/١٤١) <span class="mustanad">مستندًا إلى أحوال النُّزول، والدلالات العقلية</span> قولَ الربيع «وهو أنّ القوم أُمِروا أن يتوجَّهوا بصلاتهم إلى ربهم، لا إلى ما سواه من الأوثان والأصنام، وأن يجعلوا دعاءهم لله خالصًا، لا مكاءً، ولا تصدية». وبيَّن علَّة ذلك، فقال: «لأنّ الله -جلَّ ثناؤه- إنّما خاطب بهذه الآية قومًا من مشركي العرب، لم يكونوا أهل كنائس وبِيَعٍ، وإنما كانت الكنائس والبِيَع لأهل الكتابَيْن، فغير معقولٍ أن يُقال لمن لا يُصَلِّي في كنيسة ولا بِيعة: وجِّه وجْهك إلى الكعبة في كنيسة أو بِيعة».</div></p><p><h3><span class="qpc-hafs">﴿وَٱدۡعُوهُ مُخۡلِصِینَ لَهُ ٱلدِّینَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي العاليةِ الرِّياحِيِّ</span> -من طريق الربيع- في قوله: <span class="qpc-hafs">﴿وادعُوهُ مُخلصينَ لهُ الدّينَ كما بدأكمْ تعودونَ﴾</span>، يقولُ: أخلِصوا له الدينَ كما بدأكم في زمانِ آدم؛ حيث فَطَرهم على الإسلام. يقول: فادعُوه كذلك، لا تدْعو إلهًا غيره. وأمرَهم أن يُخلصوا له الدينَ، والدعوةَ، والعملَ، ثم يوجِّهوا وجوهَهم إلى البيت الحرام{1}. (٦/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٨٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وادعوه مخلصين له الدين﴾</span>، قال: أن تُخْلِصوا له الدين، والدعوة، والعمل، ثم تَوَجَّهون إلى البيت الحرام{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأمرهم بالصلاة والتوحيد، فذلك قوله: <span class="qpc-hafs">﴿وادعوه مخلصين﴾</span> يعني: مُوَحِّدين <span class="qpc-hafs">﴿له الدين﴾</span>{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَمَا بَدَأَكُمۡ تَعُودُونَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٣٩١<span class="dash">-</span></span> عن عبد الغفور بن عبد العزيز بن سعيد الأنصاريِّ، عن أبيه، عن جدِّه، أنّ رسولَ الله قال: «<b>إنّ الله تعالى يمسَخُ خَلْقًا كثيرًا، وإنّ الإنسانَ يَخْلو بمعصيته، فيقولُ الله تعالى: استهانةً بي؟! فيمسخُه، ثم يبعثُه يوم القيامة إنسانًا، يقولُ: <span class="qpc-hafs">﴿كما بدأكم تعودونَ﴾</span>، ثم يُدْخِلُه النارَ</b>»{17}. (٦/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله:<span class="qpc-hafs">﴿كما بدأكم تعودُوُن﴾</span> الآية: إنّ الله بدأ خلق بني آدم مؤمنًا وكافرًا، كما قال:<span class="qpc-hafs">﴿هو الَّذي خلقكم فمنكم كافرٌ ومنكم مؤمنٌ﴾</span> [التغابن:٢]، ثُمَّ يُعيدُهم يومَ القيامة كما بدأ مؤمنًا وكافرًا{18}. (٦/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span>، يقول: كما خلقناكم أول مرة كذلك تعودون{19}. (٦/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٤<span class="dash">-</span></span> عن <span class="name-1">جابر [بن عبد الله]</span> -من طريق رجل- في الآية، قال: يُبْعثون على ما كانوا عليه؛ المؤمن على إيمانه، والمنافقُ على نفاقه{20}. (٦/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- في قوله: <span class="qpc-hafs">﴿كما بدأكم تعودُونَ﴾</span>، قال: عادُوا إلى الله فيهم، ألا ترى أن يقولُ: <span class="qpc-hafs">﴿فريقًا هَدى وفريقًا حقَّ عبهم الضلالةُ﴾</span>؟{21}. (٦/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- <span class="qpc-hafs">﴿كما بدأكُم تعوُدُون﴾</span>، قال: كما كَتَب عليكم تكونون، <span class="qpc-hafs">﴿فريقًا هَدى وفريقًا حقَّ عليهمُ الضَّلالةُ﴾</span>{22}. (٦/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٨<span class="dash">-</span></span> و<span class="name-2">ابن رزين</span>{23}، قالا: إلى علمه تصيرون{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يزيد- في قوله: <span class="qpc-hafs">﴿كما بدأكُم تعُوُدُون﴾</span>، قال:يُبْعَثُ المؤمنُ مؤمنًا، ويُبعَثُ الكافرُ كافرًا{25}. (٦/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله:<span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span>، قال: هو الشقاوةُ، والسعادةُ{26}. (٦/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كَما بدأكُم تَعُودُنَ﴾</span>، قال: شقيٌّ، أو سعيدٌ{27}. (٦/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كَما بدأكُم تَعُودُنَ﴾</span> يحييكم بعد موتكم{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٣<span class="dash">-</span></span> عن <span class="name-2">الحسنِ البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿كما بدأكُم تعُوُدونَ﴾</span>، قال:كما بدَأكم ولم تكونوا شيئًا فأحياكم، كذلك يُميتُكم ثم يُحييكم يومَ القيامة{29}. (٦/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span>، قال: بدأ خلقهم ولم يكونوا شيئًا، ثم ذهبوا، ثم يعيدهم{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٥<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: بدأهم من التراب، وإلى التراب يعودون{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظِيِّ</span> -من طريق موسى بن عبيدة- في قوله: <span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span>، قال: مَن ابتدأ اللهُ خلْقَه على الهُدى والسعادةِ صيَّره إلى ما ابتَدأ عليه خلْقَه، كما فعل بالسَّحَرة؛ ابتدأ خَلْقَهم على الهُدى والسعادةِ حتى توفّاهم مسلمين، وكما فعَل إبليسَ؛ ابتدأ خلْقَه على الكُفرِ والضَّلالة، وعَمِل بعملِ الملائكةِ، فصيَّره اللهُ إلى ما ابتدأ خلْقَه عليه من الكُفر، قال اللهُ تعالى: <span class="qpc-hafs">﴿وكانَ من الكافرينَ﴾</span> [البقرة:٣٤]{32}. (٦/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿كما بدأكم تعودون فريقا هدى وفريقا حق عليهم الضلالة﴾</span>، يقول: <span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span> كما خلقناكم فريق مهتدون وفريق ضال؛ كذلك تعودون وتخرجون من بطون أمهاتكم{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿كما بدأكُمْ تعُودُونَ﴾</span>، قال: خلقهم من الترابِ، وإلى التراب يعودون. قال: وقيل في الحكمة: ما فخَر من خُلِق من التراب وإلى التراب يعود، وما تكبَّر مَن هو اليومَ حيٌّ وغدًا يموت، وإنّ الله وعد المتكبِّرين أن يضعَهم ويرفع المستضعفين، فقال: <span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم ومنها نخرجكم تارةً أخرى﴾</span> [طه:٥]. ثم قال: <span class="qpc-hafs">﴿فريقًا هدى وفريقًا حقَّ عليهمُ الضلالةُ﴾</span> ذلك بأنهم <span class="qpc-hafs">﴿اتخذُوا الشَّياطين أوليآء مِن اللهِ ويحسبُونَ أنهُم ُمْهتدونَ﴾</span>{34}. (٦/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٠٩<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: كما بدأكم [عرايا] تعودون [إليه عرايا]{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر-: كما بدأهم؛ كما خلقهم كذلك يعودون، مَن خلقه مؤمنًا وكافرًا أعاده كما بدأه{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span>، يعني: كما خلقكم سعداء وأشقياء كذلك تعودون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كما بدأكم تعودون﴾</span>، قال: كما خلقهم أوَّلًا كذلك يعيدهم آخِرًا{28}<span class=comment-ref>٢٤٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨٧</span> أفادت الآثارُ اختلاف المفسرين في معنى: <span class="qpc-hafs">﴿كَما بَدَأَكُمْ تَعُودُونَ﴾</span> على قولين: <b>الأول:</b> كما بدأكم أشقياء وسعداء كذلك تبعثون يوم القيامة. وهو قول ابن عباس من طريق علي بن أبي طلحة، وجابر، وأبي العالية، وسعيد بن جبير، ومجاهد، ومحمد بن كعب، والسدي. <b>الثاني:</b> كما خلقكم ولم تكونوا شيئًا تعودون بعد الفناء. وهو قول الحسن، وقتادة، وابن عباس من طريق عطية العوفي، ومجاهد، وابن زيد.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٥٤٨) القول الأول بقوله: «فالوَقْف في هذا التأويل على قوله: <span class="qpc-hafs">﴿تَعُودُونَ﴾</span> غير حسن، و<span class="qpc-hafs">﴿فَرِيقًا﴾</span> على هذا التأويل نصبٌ على الحال، والثاني عطف على الأول». و<span class="comment-type-1">وجَّه</span> (٣/٥٤٧) القول الثاني بقوله: «أي: كما أوجدكم واخترعكم كذلك يعيدكم بعد الموت، فالوقف على هذا التأويل على <span class="qpc-hafs">﴿تَعُودُونَ﴾</span>، و<span class="qpc-hafs">﴿فَرِيقًا﴾</span> نصب على <span class="qpc-hafs">﴿هَدى﴾</span>، والثاني منصوب بفعل تقديره: وعذَّب فريقًا أو أضل فريقًا حق عليهم».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٠/١٤٦-١٤٧) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القولَ الثاني، وعلَّل ذلك بأنّ الله تعالى أمر نبيه ﷺ أن يُعْلِم بما في هذه الآية قومًا مشركين أهل جاهلية، لا يؤمنون بالمعاد، ولا يصدقون بالقيامة، فأمره أن يدعوهم إلى الإقرار بالبعث، والثواب والعقاب، «وإذ كان ذلك كذلك فلا وجه لأن يُؤْمَر بدعاء مَن كان جاحدًا النشور بعد الممات إلى الإقرار بالصفة التي عليها يُنشَر مَن نُشِر، وإنّما يؤمر بالدعاء إلى ذلك مَن كان بالبعث مُصَدِّقًا، فأمّا مَن كان له جاحدًا فإنّما يُدعى إلى الإقرار به، ثم يُعَرَّف كيف شرائط البعث».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ القيم</u> (١/٣٨٥)، و<span class="comment-type-2">انتَقَد</span> القول الأول، فقال: «وهذا المعنى صحيحٌ في نفسه، دلَّ عليه القرآن، والسنة، والآثار السلفية، وإجماع أهل السنة، وأمّا كونه هو المراد بالآية ففيه ما فيه».</div></p><p><div></p><p><p><span class="item-no">٢٧٤١٣<span class="dash">-</span></span> عن عمر بن أبي معروف، قال: حدَّثني رجلٌ ثقةٌ، في قوله: <span class="qpc-hafs">﴿كما بدأكُم تعودونَ﴾</span>، قال: قُلْفًا{39} بُظْرًا{40}{41}. (٦/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١٤<span class="dash">-</span></span> عن مقاتل بن وهب العبديِّ: أنّ تأويلَ هذه الآية: <span class="qpc-hafs">﴿كما بدأكُم تعُودُون﴾</span> يكونُ في آخر هذه الأمَّة{41}. (٦/٣٦٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَمَا بَدَأَكُمۡ تَعُودُونَ ۝٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٧٤١٥<span class="dash">-</span></span> عن ابن عباس، عن النبي ﷺ، قال: «<b>يُحْشَر الناسُ عُراةً غُرْلًا، وأولُ مَن يكسى إبراهيمُ ﵇</b>». ثم قرأ: <span class="qpc-hafs">﴿كما بدأنا أول خلق نعيده﴾</span> [الأنبياء:١٠٤]{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١٦<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: «<b>تُبْعَث كلُّ نفسٍ على ما كانت عليه</b>»{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء بن السائب، عمَّن حدَّثه- أنّه ذَكَر القَدَرِيَّة، فقال: قاتلهم الله، أليس قد قال الله:<span class="qpc-hafs">﴿كما بدأكم تعودون فريقًا هدى وفريقا حقَّ عليهم الضلالةُ﴾</span>؟!{45}. (٦/٣٥٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٦٢.|2:علَّقه ابن أبي حاتم ٥/١٤٦٢.|3:تفسير الثعلبي ٤/٢٢٧، وتفسير البغوي ٣/٢٢٣.|4:أخرجه ابن جرير ١٠/١٣٩، وابن أبي حاتم ٥/١٤٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|5:تفسير الثعلبي ٤/٢٢٧، وتفسير البغوي ٣/٢٢٣.|6:أخرجه ابن جرير ١٠/١٣٩. وعلَّقه ابن أبي حاتم ٥/١٤٦٢.|7:تفسير مقاتل بن سليمان ٢/٣٣.|8:تفسير مجاهد ص٣٣٥، وأخرجه ابن جرير ١٠/١٤٠، وابن أبي حاتم ٥/١٤٦٢. وذكر نحوه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١١٨-. وعزاه السيوطي إلى ابن أبي شيبة، وعَبد بن حميد، وابن المنذر، وأبي الشيخ.|9:تفسير الثعلبي ٤/٢٢٧، وتفسير البغوي ٣/٢٢٣.|10:أخرجه ابن جرير ١٠/١٤٠.|11:أخرجه ابن جرير ١٠/١٤١.|12:تفسير مقاتل بن سليمان ٢/٣٣-٣٤.|13:أخرجه ابن جرير ١٠/١٤٠.|14:أخرجه ابن أبي حاتم ٥/١٤٦٢.|15:أخرجه ابن جرير ١٠/١٤٢.|16:تفسير مقاتل بن سليمان ٢/٣٣-٣٤.|17:أخرجه البخاري في الضعفاء -كما في ميزان الاعتدال للذهبي ٢/٦٤٢-.</p><p>قال الألباني في الضعيفة ١٤/٧٥٥ (٦٨٣١): «موضوع».|18:أخرجه ابن جرير ١٠/١٤٢، وابن أبي حاتم ٥/١٤٦٢. وعزاه السيوطي إلى خُشَيش في الاستقامة، وابن المنذر.|19:أخرجه ابن جرير ١٠/١٤٦، وابن أبي حاتم ٥/١٤٦٣.|20:أخرجه ابن جرير ١٠/١٤٢-١٤٣.|21:أخرجه ابن جرير ١٠/١٤٣، وابن أبي حاتم ٥/١٤٦٣. وعزاه السيوطي إلى عبد بن حميد،، وأبي الشيخ.|22:أخرجه ابن جرير ١٠/١٤٥. وعزاه السيوطي إلى عَبد بن حميد.|23:كذا في مطبوعة المصدر، ولعله: أبو رزين، تصحَّف.|24:علَّقه ابن أبي حاتم ٥/١٤٦٣.|25:أخرجه ابن جرير ١٠/١٤٤، وابن أبي حاتم ٥/١٤٦٢. وعزاه السيوطي إلى عَبد بن حميد.|26:عزاه السيوطي إلى سفيان بن عيينةَ في جامعه.|27:تفسير مجاهد ص٣٣٥، وأخرجه ابن جرير ١٠/١٤٥، وابن أبي حاتم ٥/١٤٦٢. وعزاه السيوطي إلى ابن أبي شيبةَ، وعَبد بن حميد، وابن المنذر، وأبي الشيخ.|28:أخرجه ابن جرير ١٠/١٤٦.|29:أخرجه ابن جرير ١٠/١٤٥. وعزاه السيوطي إلى ابن أبي شيبةَ، وابن المنذر.|30:أخرجه عبد الرزاق ٢/٢٢٥، وابن جرير ١٠/١٤٦.|31:تفسير البغوي ٣/٢٢٤-٢٢٥. وعقَّب عليه بقوله: نظيره قوله تعالى: <span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم﴾</span> [طه:٥٥].|32:أخرجه ابن جرير ١٠/١٤٣، وابن حاتم ٥/١٤٦٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|33:أخرجه ابن جرير ١٠/١٤٤، وابن أبي حاتم ٥/١٤٦٣ بنحوه.|34:أخرجه ابن أبي حاتم ٥/١٤٦٣.|35:تفسير الثعلبي ٤/٢٢٨، وعقَّب عليه بقوله: نظيره قوله: <span class="qpc-hafs">﴿ولقد جئتمونا فرادى كما خلقناكم أول مرة﴾</span> [الأنعام:٩٤].|36:أخرجه عبد الرزاق ٢/٢٢٥.|37:تفسير مقاتل بن سليمان ٢/٣٣-٣٤.|38:أخرجه ابن جرير ١٠/١٤٦.|39:الأَقْلَف: هو الذي لم يُخْتَن، والقُلْفَة: الجلدة التي تُقْطع من ذكر الصبي. النهاية (قَلَفَ).|40:البَظْرُ -بفتح الباء-: الهَنة التي تَقْطعها الخافضة من فرج المرأة عند الختان. النهاية (بَظَرَ).|41:عزاه السيوطي إلى أبي الشيخ.|42:عزاه السيوطي إلى أبي الشيخ.|43:أخرجه ابن جرير ١٠/١٤٧.|44:أخرجه ابن جرير ١٠/١٤٤، وأخرجه مسلم ٤/٢٢٠٦ (٢٨٧٨) بلفظ: «يُبعَث كلُّ عبدٍ على ما مات عليه».|45:أخرجه سعيدُ بن منصور (٩٤٥ - تفسير)، والبيهقي في القضاء والقدر ٢/٦١٨. وعزاه السيوطي إلى ابن المنذر.
  7,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرِیقًا هَدَىٰ وَفَرِیقًا حَقَّ عَلَیۡهِمُ ٱلضَّلَـٰلَةُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٤١٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿فريقا هدى﴾</span>، قال: في علمه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤١٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فريقا هدى﴾</span>، يقول: فريقًا مُهْتَدِين، <span class="qpc-hafs">﴿وفريقا حق عليهم الضلالة﴾</span> يقول: فريق ضُلّال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فريقا هدى﴾</span> لدينه، <span class="qpc-hafs">﴿وفريقا حق عليهم الضلالة﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمُ ٱتَّخَذُوا۟ ٱلشَّیَـٰطِینَ أَوۡلِیَاۤءَ مِن دُونِ ٱللَّهِ وَیَحۡسَبُونَ أَنَّهُم مُّهۡتَدُونَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٧٤٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحّاك- في قوله: <span class="qpc-hafs">﴿كَما بدأكُمْ تعُودُونَ﴾</span>، قال: إن تموتوا يحسبُ المُهْتدي أنّه على هُدًى، ويحسبُ الغنيُّ أنّه على هُدًى، حتى يتبيَّن له عندَ الموت، وكذلك يُبْعثون يومَ القيامة، وذلك قولُه: <span class="qpc-hafs">﴿ويحسبُون أنّهُم مُهْتَدونَ﴾</span>{4}. (٦/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنهم اتخذوا الشياطين أولياء﴾</span> يعني: أربابًا <span class="qpc-hafs">﴿من دون الله ويحسبون أنهم مهتدون﴾</span> أنهم على الهدى{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٦٣.|2:أخرجه ابن أبي حاتم ٥/١٤٦٣.|3:تفسير مقاتل بن سليمان ٢/٣٤.|4:أخرجه ابن أبي حاتم ٥/١٤٦٤.|5:تفسير مقاتل بن سليمان ٢/٣٤.