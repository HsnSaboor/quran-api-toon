٥). وأخرج ابن المنذر ١/٨٣ نحوه دون ذكر الآية الناسخة، وفيه: صار الأمر إلى الأمانة.أخرجه ابن أبي حاتم ٢/٥٦٦، وأبو نعيم في الحلية ٩/٤٨. كما أخرج نحوه ابن أبي شيبة (ت: محمد عوامة) ١٠/٥٧٠ (٢٠٧٣٣) من طريق سليمان التيمي. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٦٩- نحوه.أخرجه سفيان الثوري في تفسيره بنحوه ص٧٣، وابن جرير ٥/٧٤. وعلَّقه ابن أبي حاتم ٢/٥٦٦.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٥٧١ (٢٠٧٣٧).كافَرَه: جحده حقه. لسان العرب (كفر).أخرجه هنّاد في الزهد ٢/٤٥٥.أخرجه عبد الرزاق ١/١١١، وسعيد بن منصور (٤٦٦- تفسير)، وابن جرير ٥/١١٤، وابن المنذر (١٣٧)، والبيهقي ١٠/١٦١. وعزاه السيوطي إلى سفيان، وعبد بن حميد. والقراءة المذكورة قراءة شاذة نسبت لعمر، وابن مسعود، ومجاهد، والحسن، والضحاك. انظر: البحر المحيط ٢/٣٥٣-٣٥٤.أخرجه ابن جرير ٥/١١٤، وابن المنذر ١/٨٦.أخرجه ابن جرير ٥/١١٤، وابن المنذر ١/٨٦، والبيهقي في سننه ١٠/١٦١. وعلَّقه ابن أبي حاتم ٢/٥٦٧.أخرجه ابن جرير ٥/١١٧. وعلَّقه ابن أبي حاتم ٢/٥٦٧.أخرجه ابن جرير ٥/٩٥، ١١٥، وابن المنذر ١/٧٨، وابن أبي حاتم ٢/٥٦٣، والبيهقي في سننه ١٠/١٦١.أخرجه ابن جرير ٥/١١٥.أخرجه ابن جرير ٥/١١٤، وابن المنذر (١٣٦)، وابن أبي حاتم ٢/٥٦٧ واللفظ له، والبيهقي في سُنَنه ١٠/١٦٠. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٢/٥٦٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٦٩-. وعلَّقه ابن أبي حاتم ٢/٥٦٧.أخرجه عبد الرزاق ١/١١٠.أخرجه ابن جرير ٥/١١٦، وابن المنذر ١/٨٥ بنحوه من طريق جويبر. كما علَّقه ابن أبي حاتم ٢/٥٦٧.أخرجه ابن جرير ٥/٧٧، وابن المنذر بنحوه ١/٨٨. وعلَّقه ابن أبي حاتم ٢/٥٥٦.أخرجه ابن جرير ٥/١١٥، وابن المنذر ١/٨٥ بلفظ: «لا يضار، يقول له: تعال فاشهد، وهو يجد عنه مندوحة». وعلَّق ابن أبي حاتم ٢/٥٦٧ نحوه.علَّقه ابن المنذر ١/٨٥.أخرجه ابن جرير ٥/١١١.أخرجه عبد الرزاق ١/١١١، وابن جرير ٥/١١٧، وابن المنذر ١/٨٦ بنحوه. وعلَّقه ابن أبي حاتم ٢/٥٦٧.أخرجه ابن جرير ٥/١١٢، وابن المنذر ١/٨٧ بنحوه، والبيهقي ١٠/١٦١.أخرجه عبد الرزاق ١/١١١، وابن أبي حاتم ٢/٥٦٧، وابن المنذر ١/٨٧.تفسير ابن أبي زمنين ١/٢٦٩.أخرجه ابن جرير ٥/١١٢.أخرجه عبد الرزاق ١/١١٠، وابن جرير ٥/١١٢، وابن المنذر ١/٨٧، وابن أبي حاتم ٢/٥٦٧.أخرجه ابن جرير ٥/١١٦، وابن أبي حاتم ٢/ ٥٦٧.أخرجه ابن أبي حاتم ٢/٥٦٧.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٢٣-١٢٤ (٢٤٥). وعلَّقه ابن أبي حاتم ٢/٥٦٧.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن المنذر ١/٨٧. وعلَّقه ابن أبي حاتم ٢/٥٦٧.أخرجه ابن جرير ٥/١١٢.أخرجه ابن المنذر ١/٨٥، والبيهقي في السنن الكبرى ١٠/١٦١.أخرجه ابن جرير ٥/٩٥، ١١٩، وابن المنذر ١/٨٨، وابن أبي حاتم ٢/٥٦٨، والبيهقي في سننه ١٠/١٦١.علَّقه ابن أبي حاتم ٢/٥٦٨.أخرجه ابن أبي حاتم ٢/٥٦٨.أخرجه ابن جرير ٥/١١٨. وعلَّقه ابن أبي حاتم ٢/٥٦٨.أخرجه ابن جرير ٥/١١٩. وعلَّقه ابن أبي حاتم ٢/٥٦٨.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٨، وابن المنذر ١/٨٨ من طريق إسحاق، عمّن حدثه، عن مقاتل.علَّقه ابن المنذر ١/٨٨.أخرجه ابن جرير ٥/١١٩.أخرجه ابن أبي حاتم ٢/٥٥٧، ٥٦٨.أخرجه ابن جرير ٥/١٢٠.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه أبو نعيم في الحلية ١٠/١٥. قال أبو نعيم: «ذكر أحمد بن حنبل هذا الكلام عن بعض التابعين، عن عيسى بن مريم ﵇، فوَهِم بعضُ الرواة أنه ذكره عن النبي ﷺ، فوضع هذا الإسناد عليه؛ لسهولته وقربه، وهذا الحديث لا يحتمل بهذا الإسناد عن أحمد بن حنبل». وقال الحافظ العراقي في تخريج أحاديث الإحياء ١/٨٥ (٢): «أخرجه أبو نعيم في الحلية من حديث أنس، وضعَّفه». وقال الألباني في الضعيفة ١/٦١١ (٤٢٢): «موضوع».أخرجه الترمذي ٤/٦١٨ (٢٨٧٨). قال الترمذي: «هذا حديث ليس إسناده بمتصل، هو عندي مرسل، ولم يدرك عندي ابن أشوع يزيد بن سلمة». وقال البخاري -كما في علل الترمذي ص٣٤١-: «سعيد بن أشوع لم يسمع عندي من يزيد بن سلمة، وهو عندي حديث مرسل». وقال ابن حجر في الإصابة ٦/٦٦٠: «وهو منقطع كما قال». وقال الألباني في الضعيفة ٤/١٩٠-١٩١ (١٦٩٦): «ضعيف».أخرجه الطبراني في الأوسط ٣/٦٤ (٢٤٩٢)، وابن عبد البر في جامع بيان العلم وفضله ١/٤٠١ (٥٨٠). قال الطبراني: «لم يرو هذا الحديث عن أبي الزبير إلا ياسين». وقال الهيثمي في المجمع ١/١٣٦ (٥٧٤): «وفيه ياسين الزيات، وهو منكر الحديث». وقال الألباني في الضعيفة ٧/١٨٩ (٣٢٠٥): «إسناد ضعيف جدًّا».عزاه السيوطي إلى ابن أبي الدنيا في كتاب التقوى.عزاه السيوطي إلى أبي يعقوب البغدادي في كتاب رواية الكبار عن الصغار.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٥٧١ (٢٠٧٣٨).
