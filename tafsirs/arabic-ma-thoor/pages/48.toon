quran[1]{c,v,t}:
  2,282,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا تَدَایَنتُم بِدَیۡنٍ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى فَٱكۡتُبُوهُۚ وَلۡیَكۡتُب﴾</span> الآية - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٣١٠<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>، قال: لَمّا نزلت آيةُ الدَّيْن قال رسول الله ﷺ: «<b>إنّ أول مَن جحدَ آدمُ، إنّ الله لما خلق آدم مسَح ظهره، فأخرج منه ما هو ذارٍ</b>{1} <b>إلى يوم القيامة، فجعل يعرض ذريته عليه، فرأى فيهم رجلًا يَزْهَرُ</b>{2}، <b>قال: أيْ ربِّ، من هذا؟ قال: هذا ابنك داود. قال: أيْ ربِّ، كم عمره؟ قال: ستون عامًا. قال: ربِّ، زدْ في عمره. فقال: لا، إلا أن أزيده من عمرك. وكان عمر آدم ألف سنة، فزاده أربعين عامًا، فكتب عليه بذلك كتابًا، وأشهد عليه الملائكة، فلما احْتُضِرَ آدمُ وأتته الملائكة لتقبضه، قال: إنه قد بقي من عمري أربعون عامًا. فقيل له: إنك قد وهبتها لابنك داود. قال: ما فعلت. فأبرز الله عليه الكتاب، وأشهد عليه الملائكة، فكمَّل اللهُ لآدم ألفَ سنة، وأكمل لداود مائة عام</b>»{3}. (٣/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي نجيح، عن مجاهد- في قوله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين﴾</span>، قال: نزلت في السَّلَم في الحِنطة في كَيْل معلوم إلى أجل معلوم{4}<span class=comment-ref>١٠٦٥</span>. (٣/٣٩٣)</p></p><p></div></p><p><div><span class=comment-ref>١٠٦٥</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٢/١١٠) عموم الآية لكل دَيْن مؤجَّل، وبيَّن معنى قول ابن عباس، فقال: «معناه: أنّ سَلَمَ أهل المدينة كان سبب هذه الآية، ثم هي تتناول جميع المداينات <span class="mustanad">إجماعًا</span>».</p><p>وبنحوه قال <u>ابنُ جرير</u> (٥/٦٩-٧٠).</div></p><p><div></p><p><p><span class="item-no">١١٣١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق الزهري- أنّه بلَغه: أنّ أحدَثَ القرآنِ بالعرشِ آيةُ الدَّيْن{5}. (٣/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣١٣<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق عقيل- قال: آخِرُ القرآن عهدًا بالعرش آيةُ الرِّبا، وآيةُ الدَّيْن{6}. (٣/٣٩١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا تَدَایَنتُم بِدَیۡنٍ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي حسان الأعرج- قال: أشهَدُ أن السلف المضمون إلى أجل مُسَمًّى أنّ الله أحلَّه وأذِن فيه. ثم قرأ: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين إلى أجل مسمى﴾</span>{7}. (٣/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span>، قال: إلى أجل معلوم{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱكۡتُبُوهُۚ﴾</span> - نسخ الآية، وأحكامها</h3></p><p><div></p><p><p><span class="item-no">١١٣١٦<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق عبد الملك بن أبي نضرة، عن أبيه- أنّه قرأ هذه الآية: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين﴾</span> حتى إذا بلغ <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span>، قال: هذه نَسَخَتْ ما قبلها{9}. (٣/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة - <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين إلى أجل مسمى فاكتبوه﴾</span>: فأمَر بالشهادة عند المداينة، لكيلا يدخل في ذلك جحود ولا نسيان، فمن لم يشهد على ذلك فقد عصى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣١٨<span class="dash">-</span></span> عن <span class="name-2">أبي بردة بن أبي موسى</span> -من طريق الشعبي- قال: ثلاثة يدعون الله ولا يُستجاب لهم: رجل كان له دَيْن على رجل فلم يُشهد ... وذكر الحديث{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣١٩<span class="dash">-</span></span> عن ميمون أبي عمرو الأزدي{12} -من طريق مجاهد - قال: ثلاثة لا يستجاب لهم: رجل دان دَيْنًا إلى أجل فلم يُشهد عليه. وذكر بقية الحديث{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: ثلاثة لا يستجاب لهم دعوة: رجل باع ولم يُشهِد ولم يَكْتُب. وذكر بقية الحديث{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢١<span class="dash">-</span></span> عن ا<span class="name-2">لضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين إلى أجل مسمى فاكتبوه﴾</span>، قال: فما كان مِن بيع إلى أجل مسمى، صغير أو كبير؛ فإنّ الله قد أمر فيه بالكتاب والبينة إلى أجله، وقال: <span class="qpc-hafs">﴿ولا تسأموا أن تكتبوه صغيرا أو كبيرا إلى أجله﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود- في هذه الآية: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين إلى أجل مسمى فاكتبوه﴾</span> حتى بلغ هذا المكان: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا فليؤد الذي اؤتمن أمانته﴾</span>، قال: رخص في ذلك، فمن شاء أن يأتمن صاحبه فليأتمنه{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن أبي خالد- قال: فكانوا يرون أنّ هذه الآية: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span> نَسَخَتْ ما قبلها من الكتابة والشهود، رخصةً ورحمةً من الله{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٤<span class="dash">-</span></span> عن إسماعيل بن أبي خالد، قال: قلت <span class="name-2">للشعبيِّ</span>: أرأيتَ الرجل يستدين من الرجل الشيء، أحَتْمٌ عليه أن يُشْهِد؟ فقال: ألا ترى إلى قوله: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span>؟، قد نَسَخ ما كان قبله{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٥<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span>، قال: إن أشهدت فحَزْم، وإن لم تُشْهِد ففي حِلٍّ وسَعَة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٦<span class="dash">-</span></span> عن سليمان التيمي، قال: سألت <span class="name-2">الحسن [البصري]</span>، قلت: كلُّ مَن باع بيعًا ينبغي له أن يُشهِد؟ قال: ألم تر أنّ الله ﷿ يقول: <span class="qpc-hafs">﴿فليؤد الذي اؤتمن أمانته﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٧<span class="dash">-</span></span> عن ابن جريج، قال: قال غيرُ عطاء: نسخت الكتاب والشهادة: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٨<span class="dash">-</span></span> عن قتادة، قال: ذُكِر لنا: أنّ <span class="name-2">أبا سليمان المرعشي</span> كان رجلًا صَحِب كعبًا، فقال ذات يوم لأصحابه: هل تعلمون مظلومًا دعا ربه فلم يُسْتَجَب له؟ قالوا: وكيف يكون ذلك؟ قال: رجل باع بيعًا إلى أجل مسمى، فلم يكتُب ولم يُشهِد، فلما حَلَّ مالُه جحده صاحبه، فدعا ربه، فلم يستجب له لأنّه قد عصى ربَّه{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٢٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿إذا تداينتم بدين إلى أجل مسمى فاكتبوه﴾</span>: فكان هذا واجبًا، ثم جاءت الرخصة والسَّعَة، قال: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا فليؤد الذي اؤتمن أمانته وليتق الله ربه﴾</span>{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاكتبوه﴾</span>، يعني: اكتبوا الدين والأَجَل{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا تداينتم بدين إلى أجل مسمى فاكتبوه﴾</span>، قال: فمَنِ ادّان دَيْنًا فليكتب، ومن باع فليُشْهِد{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق علي القرشي- قوله: <span class="qpc-hafs">﴿فاكتبوه وليكتب بينكم كاتب بالعدل﴾</span> أنها منسوخة، نَسَخَتْها <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا فليؤد الذي اؤتمن أمانته﴾</span>{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب-: نسخ ذلك قوله: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا فليؤد الذي اؤتمن أمانته﴾</span>. قال: فلولا هذا الحرف لم ينبغِ لأحد أن يدّان بدَيْن إلا بكتاب وشهداء، أو بِرَهن، فلما جاءت هذه نَسَخَتْ هذا كلَّه، صار إلى الأمانة{16}<span class=comment-ref>١٠٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٦٦</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٥/٧٩) و<u>ابنُ عطية</u> (٢/١١١) <span class="mustanad">استنادًا إلى إمكان الجمع</span> القولَ بالنسخ؛ إذ النسخ لا يصار إليه إلا عند تعذر الجمع بين الآيتين.</p><p>وجَمَع <u>ابنُ جرير</u> بين الآيتين بكون كتابة الدين واجبة، وقوله تعالى: <span class="qpc-hafs">﴿فَإنْ أمِنَ بَعْضُكُمْ بَعْضًا﴾</span> مُرَخِّص في ترك كتابة الدين عند التعذر.</p><p>و<span class="comment-type-4">جَمَع</span> <u>ابنُ عطية</u> بين الآيتين بأن الأمر بكتابة الدين للندب والاحتياط، وليس في الآية ما يفيد منع الكتابة عند الائتمان حتى يُصارَ إلى النسخ.</p><p>وسيأتي توجيه ابن تيمية لمعنى النسخ عند السلف عند قوله تعالى: <span class="qpc-hafs">﴿وإنْ تُبْدُوا ما فِي أنْفُسِكُمْ أوْ تُخْفُوهُ يُحاسِبْكُمْ بِهِ اللَّهُ﴾</span>.</p><p>واستدلَّ <u>ابنُ كثير</u> (٢/٥٠٦) على عدمِ وجوبِ الكتابةِ بقوله: <span class="mustanad">«والدليل على ذلك أيضًا الحديث</span> الذي حكي عن شرع من قبلنا مقررًا في شرعنا، ولم ينكر عدم الكتابة والإشهاد». وذكر حديث: أن رجلًا من بني إسرائيل سأل بعض بني إسرائيل أن يُسْلفه ألف دينار، فقال: ائتني بشهداء أشهدهم. قال: كفى بالله شهيدًا. قال: ائتني بكفيل. قال: كفى بالله كفيلًا. قال: صدقت. فدفعها إليه إلى أجل مسمى ....</div></p><p><h3><span class="qpc-hafs">﴿فَٱكۡتُبُوهُۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٣٣٤<span class="dash">-</span></span> عن ابن عباس، قال: قدم النبيُّ ﷺ المدينةَ وهم يُسْلِفون في الثمار السنتين والثلاث، فقال: «<b>مَن أسلف فلْيُسْلِف في كَيْل معلوم، ووزن معلوم، إلى أجل معلوم</b>»{28}. (٣/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٥<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>، قال: لا سلف إلى العطاء، ولا إلى الحصاد، ولا إلى الأَندَر{29}، ولا إلى العصير، واضرب له أجلًا{30}. (٣/٣٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیَكۡتُب بَّیۡنَكُمۡ كَاتِبُۢ بِٱلۡعَدۡلِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٣٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿وليكتب بينكم﴾</span> بين البائع والمشتري <span class="qpc-hafs">﴿كاتب بالعدل﴾</span> قال: يعدل بينهما في كتابه، لا يَزِدْ على المطلوب، ولا ينقُصْ مِن حقِّ الطالب{31}. (٣/٣٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وليكتب بينكم كاتب بالعدل﴾</span>، قال: اتَّقى اللهَ كاتبٌ في كتابه، فلا يَدَعَنَّ منه حَقًّا، ولا يَزِيدَنَّ فيه باطلًا{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿بالعدل﴾</span>، يقول: بالحق{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وليكتب﴾</span> الكاتب بين البائع والمشترى <span class="qpc-hafs">﴿بينكم كاتب بالعدل﴾</span> يعدل بينهما في كتابه، فلا يزداد على المطلوب، ولا يُنقص من حق الطالب{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٠<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿وليكتب بينكم كاتب بالعدل﴾</span>: أمر الكاتبَ أن يكتب بينهما بالعدل{35}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَأۡبَ كَاتِبٌ أَن یَكۡتُبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، قال: واجب على الكاتب أن يكتب{36}. (٣/٣٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، قال: كانت عزيمة، فنسختها <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>{37}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي مصلح- في قوله: <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، يقول: لا ينبغي للكاتب أن يأبى أن يكتب كما علمه الله{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٥<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span> -من طريق جابر- قوله: <span class="qpc-hafs">﴿ولا يأب كاتب أن يكتب كما علمه الله﴾</span>، قالا: إذا لم يجدوا كاتبًا فدُعِيتَ فلا تَأْبَ أن تكتب لهم{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٦<span class="dash">-</span></span> عن ابن جريج، قال: قلت ل<span class="name-2">عطاء [بن أبي رباح]</span>: قوله: <span class="qpc-hafs">﴿ولا يأب كاتب أن يكتب﴾</span> أواجب أن لا يأبى أن يكتب؟ قال: نعم{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، قال: كانت الكُتّاب يومئذ قليلًا{41}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، قال: إن كان فارغًا{42}. (٣/٣٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٤٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-: <span class="qpc-hafs">﴿وليكتب بينكم كاتب بالعدل ولا يأب كاتب أن يكتب كما علمه الله﴾</span>، فكان هذا واجبًا على الكُتّاب{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يأب كاتب أن يكتب﴾</span>، وذلك أن الكُتّاب كانوا قليلًا على عهد رسول الله ﷺ{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، قال: الكاتب إذا كانت له حاجة ووجد غيره؛ فليمض لحاجته ويلتمس غيره، وذلك أن الكُتّاب في ذلك الزمان كانوا قليلًا{45}<span class=comment-ref>١٠٦٧</span>. (٣/٣٩٤)</p></p><p></div></p><p><div><span class=comment-ref>١٠٦٧</span> أفادت الآثارُ اختلاف المفسرين في وجوب الكتابة على الكاتب إذا استُكتِبَ؛ <b>فمِن قائل</b> بالوجوب، و<b>مِن قائل</b> بالندب.</p><p>وقد <span class="comment-type-3">رجَّح</span> <u>ابن جرير</u> (٥/٧٨) الوجوب، <span class="mustanad">استنادًا إلى أن أمر الله فرض لازم، ولا دليلَ يصرفُه إلى الإرشاد والندب</span>، ثم ردَّ دعوى نسخ الأمر بالكتابة فقال: «ولا وجه لاعتلال من اعتلَّ بأن الأمر بذلك منسوخ بقوله: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا فليؤد الذي اؤتمن أمانته﴾</span>؛ لأن ذلك إنما أذن الله -تعالى ذكره- به حيث لا سبيل إلى الكتاب أو إلى الكاتب، فأما والكتاب والكاتب موجودان، فالفرض -إذا كان الدَّيْن إلى أجل مسمى- ما أمر الله -تعالى ذكره- به في قوله: <span class="qpc-hafs">﴿فاكتبوه﴾</span> الآية، وإنما يكون الناسخ ما لم يَجُزِ اجتماع حكمه وحكم المنسوخ في حال واحدة، فأما ما كان أحدهما غير ناف حكم الآخر، فليس من الناسخ والمنسوخ في شيء».</p><p>ولم يحك <u>ابن عطية</u> (٢/١١٣) اختلاف المفسرين في ذلك، لكنه <span class="comment-type-3">رجَّح</span> أن الأمر للندب فقال: «وأما إذا عدم الكاتب فيتوجه وجوب الندب حينئذ على الحاضر، وأما الكتب في الجملة فندب، كقوله تعالى: <span class="qpc-hafs">﴿وافعلوا الخير﴾</span> [الحج:٧٧]، وهو من باب عون الضائع».</div></p><p><h3><span class="qpc-hafs">﴿كَمَا عَلَّمَهُ ٱللَّهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٥٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿كما علمه الله﴾</span>، قال: كما علَّمه الكتابةَ وترك غيره{45}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿كما علمه الله﴾</span>، قال: كما أمره الله{45}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يأب كاتب أن يكتب كما علمه الله﴾</span> الكتابة{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلۡیَكۡتُبۡ وَلۡیُمۡلِلِ ٱلَّذِی عَلَیۡهِ ٱلۡحَقُّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٥٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وليملل الذي عليه الحق﴾</span>، يعني: المطلوب، يقول: ليُمْلِ ما عليه من الحق على الكاتب، من حق المطلوب{45}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، نحو ذلك{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فليكتب﴾</span> الكاتبُ، <span class="qpc-hafs">﴿وليملل﴾</span> على الكاتب <span class="qpc-hafs">﴿الذي عليه الحق﴾</span> يعني: المطلوب{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق إسحاق، عمّن حدثه- في قوله: <span class="qpc-hafs">﴿وليملل الذي عليه الحق﴾</span>، قال: يعني الذي قِبَلَه الحق{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٥٩<span class="dash">-</span></span> عن الشافعي -من طريق يونس بن عبد الأعلى- في قوله: <span class="qpc-hafs">﴿وليملل الذي عليه الحق﴾</span> إنما معناه: أن يُقِرَّ قط بالحق، ليس معناه: أن يملي{45}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥ وَلَا یَبۡخَسۡ مِنۡهُ شَیۡـࣰٔاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿ولا يبخس منه شيئا﴾</span>، يقول: لا ينقص من حق الطالب شيئًا{54}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦١<span class="dash">-</span></span> عن عَبّاد بن منصور، قال: سألت <span class="name-2">الحسن [البصري]</span> عن قوله: <span class="qpc-hafs">﴿ولا يبخس منه شيئا﴾</span>. قال: لا يظلم منه شيئًا، ولا ينقص مما عليه شيئًا{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قول الله -جل وعز-: <span class="qpc-hafs">﴿يأيها الذين آمنوا إذا تداينتم بدين﴾</span> إلى قوله: <span class="qpc-hafs">﴿ولا يبخس منه شيئا﴾</span>، قال: لا يكتم منه شيئًا، اتقى الله شاهدٌ في شهادته، لا ينقص منها حقًّا، ولا يزيد فيها باطلًا، اتقى الله كاتب في كتابته، لا يدَعَنَّ منه حقًّا، ولا يزيدَنَّ فيه باطلًا{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وليتق الله ربه ولا يبخس منه شيئا﴾</span>، يقول: لا يظلم منه شيئًا{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خَوَّف المطلوب، فقال ﷿: <span class="qpc-hafs">﴿وليتق الله ربه ولا يبخس منه شيئا﴾</span>، يعني: ولا ينقص المطلوب من الحق شيئًا، كقوله ﷿: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span> [الأعراف:٨٥]{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق إسحاق، عمّن حدثه-: في قوله: <span class="qpc-hafs">﴿ولا يبخس منه شيئا﴾</span>، يقول: لا يُنقص منه شيئًا{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا يبخس منه شيئا﴾</span>، قال: لا يَنقُص من حقِّ هذا الرجل شيئًا إذا أمَلَّ{60}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِن كَانَ ٱلَّذِی عَلَیۡهِ ٱلۡحَقُّ سَفِیهًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٦٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿فإن كان الذي عليه الحق﴾</span>، يعني: المطلوب{61}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فإن كان الذي عليه الحق سفيها﴾</span>، قال: هو الجاهل بالإملاء{62}. (٣/٣٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٦٩<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٠<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، نحو ذلك{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿فإن كان الذي عليه الحق سفيها أو ضعيفا﴾</span>، قال: هو الصبي الصغير{64}. (٣/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿فإن كان الذي عليه الحق سفيها﴾</span>، أمّا السفيه: فهو الصغير{65}<span class=comment-ref>١٠٦٨</span>. (٣/٣٩٧)</p></p><p></div></p><p><div><span class=comment-ref>١٠٦٨</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/٨٢-٨٣) <span class="mustanad">مستندًا إلى لغة العرب</span> أنّ المراد بالسفيه: الجاهل بالإملاء.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٢/١١٤) <span class="mustanad">استنادًا إلى الدلالات العقلية</span> تفسيرَه: بالصبي الصغير.</p><p>وعلَّلَ <u>ابنُ جرير</u> ذلك بكون السفه في كلام العرب: الجهل، وبأنّ الصبي لا تجوز مداينته، وبأنّ الله استثنى من الذين أمرهم بإملال كتاب الدَّيْن ثلاثة أصناف متباينة ليس الصبي منهم، فأحدها: السفيه ذو القوة على الإملال لجهله بمواضع الصواب من الخطأ. وثانيها: الضعيف العاجز عن الإملال لعِيِّ لسانه أو خرَسٍ به. وثالثها: الممنوع من الإملال لكونه محبوسًا، أو غائبًا عن موضع الإملال.</p><p><span class="comment-type-2">وانتقد</span> <u>ابنُ جرير</u> (٥/٨٤) <span class="mustanad">مستندًا إلى دلالة العقل، وظاهر الآية</span> قول مَن فسَّر السفيه بالصغير في هذا الموضع، والضعيف بالكبير الأحمق؛ لكون ذلك يوجب أن يكون المراد من قوله تعالى: <span class="qpc-hafs">﴿أوْ لا يَسْتَطِيعُ أنْ يُمِلَّ﴾</span> العاجز عن الإملال من الرجال العقلاء؛ لعجز في لسانه، أو لِغَيْبَة، وذلك مُبْطِلٌ لمعنى قوله تعالى: <span class="qpc-hafs">﴿فَلْيُمْلِلْ ولِيُّهُ بِالعَدْلِ﴾</span>؛ لأنّ العاقل الرشيد لا يولّى عليه في ماله، وإن كان أخرس أو غائبًا، ولا يجوز حكم أحدٍ في ماله إلا بأمره.</div></p><p><div></p><p><p><span class="item-no">١١٣٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن كان الذي عليه الحق سفيها﴾</span>، يعني: جاهلًا بالإملاء{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ ضَعِیفًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿أو ضعيفا﴾</span>، يعني: عاجزًا، أو أخرسَ، أو رجلًا به حُمْقٌ{61}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أو ضعيفا﴾</span>، قال: هو الأحمق{68}. (٣/٣٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله -جلَّ وعز-: <span class="qpc-hafs">﴿فإن كان الذي عليه الحق سفيها أو ضعيفا﴾</span>، قال: هو الصبي الصغير، أو ضعيف في عقله، لا يعبِّر عن نفسه{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: أما الضعيف فهو الأحمق{70}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو ضعيفا﴾</span>، يعني: أو عاجزًا، أو به حمق{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٧٩<span class="dash">-</span></span> قال الشافعي: الذي يستحق أن يُحجَر [عليه]{63}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ لَا یَسۡتَطِیعُ أَن یُمِلَّ هُوَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿لا يستطيع أن يمل هو﴾</span>، قال: يقول: فإن عيِيَ عن ذلك{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار-: <span class="qpc-hafs">﴿أو لا يستطيع﴾</span> يعني: لا يُحْسِنُ <span class="qpc-hafs">﴿أن يمل هو﴾</span> قال: أن يُمِلَّ ما عليه{61}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، نحو شطره الأول{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿أو لا يستطيع أن يمل هو﴾</span> لا يعقل الإملاء؛ لعَيِّه، أو لخرسه، أو لسفهه{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلۡیُمۡلِلۡ وَلِیُّهُۥ بِٱلۡعَدۡلِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿فليملل وليه﴾</span>، قال: صاحب الدَّيْن{73}. (٣/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق ابن جريج، عن بعض أهل المدينة- أنّه كان يقول: <span class="qpc-hafs">﴿فليملل وليه﴾</span> الذي له الحق{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار-: <span class="qpc-hafs">﴿فليملل وليه﴾</span> وليُّ الحقِّ حقَّه <span class="qpc-hafs">﴿بالعدل﴾</span> يعني: الطالبُ، ولا يزدادُ شيئًا{79}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿فليملل وليه﴾</span>، قال: ولِيُّ السفيه، أو الضعيف{80}. (٣/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- <span class="qpc-hafs">﴿فليملل وليه بالعدل﴾</span>: بالحق. قال: ولِيُّ اليتيم الذي يجوز عليه أمره، يدوِّن على اليتيم الحق، فهو وليه بالعدل، هو الذي يمل بالحق{81}. (٣/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٨٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله ﷿: <span class="qpc-hafs">﴿فليملل وليه بالعدل﴾</span>، قال: بالحق{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿فليملل وليه بالعدل﴾</span>، يقول: ولي الحق{73}<span class=comment-ref>١٠٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٦٩</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٢/١١٤) <span class="mustanad">مستندًا إلى عدمِ صحّتِه عن ابن عباسٍ، وعدمِ مجيءِ الشريعةِ بمثله</span>: أن يكون الضمير في <span class="qpc-hafs">﴿وليه﴾</span> عائدًا على <span class="qpc-hafs">﴿الحق﴾</span>، فقال: «وهذا عندي شيءٌ لا يصِحُّ عن ابن عباس، وكيف تشهد على البينة على شيء، وتدخل مالًا في ذمة السفيه بإملاء الذي له الدَّيْن؟ هذا شيء ليس في الشريعة، والقول ضعيف، إلا أن يريد قائلُه أن الذي لا يستطيع أن يمل بمرضه إذا كان عاجزًا عن الإملاء فليملل صاحب الحق بالعدل، ويسمع الذي عجز، فإذا كمل الإملاء أقرَّ به، وهذا معنًى لم تعن الآية إليه، ولا يصح هذا إلا فيمن لا يستطيع أن يمل بمرض قط».</div></p><p><div></p><p><p><span class="item-no">١١٣٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى الذي له الحق فقال -سبحانه-: <span class="qpc-hafs">﴿فليملل وليه﴾</span> يعني: ولي الحق، فليملل هو <span class="qpc-hafs">﴿بالعدل﴾</span> يعني: بالحق، ولا يزداد شيئًا، ولا ينقص، كما قال للمطلوب قبل ذلك، وأمر كليهما بالعدل{84}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق إسحاق، عمَّن حدَّثه- في قوله: <span class="qpc-hafs">﴿فليملل وليه بالعدل﴾</span>، يعني بالولي: طالب الحق{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق ابن ثور- في قوله -جل وعز-: <span class="qpc-hafs">﴿فليملل وليه بالعدل﴾</span>، قال: كُنّا نقول: ولِيُّ السفيه والضعيف{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب-: <span class="qpc-hafs">﴿فإن كان الذي عليه الحق سفيها أو ضعيفا﴾</span> لا يعرف، فيُثْبِت لهذا حقَّه، ويجهل ذلك، فوليُّه بمنزلته حتى يضع لهذا حقَّه{80}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱسۡتَشۡهِدُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٣٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في الآية، قال: أمر بالشهادة عند المداينة لِكَيلا يدخل في ذلك جحودٌ ولا نسيان، فمَن لم يُشْهِد على ذلك فقد عصى{88}. (٣/٣٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق ليث، عن مجاهد- في قوله: <span class="qpc-hafs">﴿واستشهدوا شهيدين﴾</span>، قال: كان إذا باع بالنَّقْد أشْهَدَ ولم يكتب. قال مجاهد: وإذا باع بالنسيئة كتب وأَشْهَدَ{89}. (٣/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿واستشهدوا﴾</span>، يعني: على حقِّكم{90}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿واستشهدوا شهيدين من رجالكم فإن لم يكونا رجلين فرجل وامرأتان ممن ترضون من الشهداء أن تضل إحداهما فتذكر إحداهما الأخرى﴾</span>: علم اللهُ أن ستكون حقوقٌ، فأخذ لبعضكم من بعض الثقة، فخذوا بثقة الله، فإنّه أطوع لربكم، وأدرك لأموالكم، ولَعمري، لَئِن كان تقيًّا لا يزيده الكتاب إلا خيرًا، وإن كان فاجرًا فبالحَرى أن يُؤَدِّي إذا علم أن عليه شهودًا{91}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٣٩٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- في قوله: <span class="qpc-hafs">﴿واستشهدوا شهيدين من رجالكم﴾</span>، يقول: في الدَّيْن{92}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿واستشهدوا﴾</span> على حقِّكم{93}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿شَهِیدَیۡنِ مِن رِّجَالِكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٠١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿شهيدين من رجالكم﴾</span>، يعني: المسلمين الأحرار{90}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿واستشهدوا شهيدين من رجالكم﴾</span>، قال: من الأحرار{95}. (٣/٣٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿واستشهدوا شهيدين من رجالكم﴾</span>: أمر اللهُ أن تُشْهِدُوا ذَوَيْ عدلٍ من رجالكم، <span class="qpc-hafs">﴿فإن لم يكونا رجلين فرجل وامرأتان ممن ترضون من الشهداء﴾</span>{96}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿شَهِیدَیۡنِ مِن رِّجَالِكُمۡۖ﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">١١٤٠٤<span class="dash">-</span></span> عن أبي عبيد، قال: قد قبلها [يعني شهادة العبد] قومٌ علماءُ يقتدى بهم، منهم: <span class="name-1">أنس بن مالك</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٥<span class="dash">-</span></span> و<span class="name-2">محمد بن سيرين</span> وغيرهما، يحدثون عن المختار بن فلفل، أنه سأل أنس بن مالك عن شهادة العبد. فقال: جائزة إذا كان عدلًا{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٦<span class="dash">-</span></span> عن <span class="name-2">شُرَيح [القاضي]</span> -من طريق محمد-: أنّه كان يُجِيز شهادة العبيد{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: كان أهل مكة وأهل المدينة لا يُجِيزون شهادة العبد{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٨<span class="dash">-</span></span> عن داود بن أبي هند، قال: سألتُ <span class="name-2">مجاهدًا</span> عن الظِّهار مِن الأمَة، فقال: ليس بشيء. قلت: أليس يقول الله: <span class="qpc-hafs">﴿والذين يظاهرون من نسائهم﴾</span> [المجادلة:٣]، أفَلَسْنَ مِن النساء؟! فقال: واللهُ تعالى يقول: <span class="qpc-hafs">﴿واستشهدوا شهيدين من رجالكم﴾</span>، أفتجوز شهادة العبيد؟!{100}. (٣/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٠٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق زكريا-: لا تجوز شهادةُ امرأةٍ وعبدٍ في حدٍّ{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٠<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق عبد الملك- قال: لا تجوز شهادة العبد{97}<span class=comment-ref>١٠٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٠</span> بيَّن <u>ابنُ عطية</u> (٢/١١٥) أنّ قوله تعالى: <span class="qpc-hafs">﴿من رجالكم﴾</span> نصٌ في رفض الكفار والصبيان والنساء، وأما العبيد فاللفظ يتناولهم، ثم نقل أقوال العلماء في تجويز شهادة العبد ومنعها، وذكر أنّ من أجازها غلَّب لفظ الآية، ومَن منعها غلَّب نقص الرِّقِّ.</div></p><p><div></p><p><p><span class="item-no">١١٤١١<span class="dash">-</span></span> قال مالك: ومن الناس مَن يقول: لا تكون اليمين مع الشاهد الواحد، ويحتجُّ بقول الله -تبارك وتعالى، وقولُهُ الحقُّ-: <span class="qpc-hafs">﴿واستشهدوا شهيدين من رجالكم، فإن لم يكونا رجلين فرجل وامرأتان ممن ترضون من الشهداء﴾</span>. يقول: فإن لم يأت برجل وامرأتين فلا شيء له، ولا يحلف مع شاهده{103}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِن لَّمۡ یَكُونَا رَجُلَیۡنِ فَرَجُلࣱ وَٱمۡرَأَتَانِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤١٢<span class="dash">-</span></span> عن <span class="name-2">يزيد بن عبد الرحمن بن أبي مالك</span>، قال: لا تجوز شهادة أربع نسوة مكان رجلين في الحقوق، ولا تجوز شهادتهن إلا معهن رجل، ولا تجوز شهادة رجل وامرأة؛ لأنّ الله يقول: <span class="qpc-hafs">﴿فإن لم يكونا رجلين فرجل وامرأتان﴾</span>{104}. (٣/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿فإن لم يكونا رجلين فرجل وامرأتان﴾</span>: وذلك في الدَّيْن{96}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِن لَّمۡ یَكُونَا رَجُلَیۡنِ فَرَجُلࣱ وَٱمۡرَأَتَانِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٤١٤<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>ما رأيتُ مِن ناقصات عقل ودين أغلبَ لذي لُبٍّ</b>{106} <b>مِنكُنَّ</b>». قالت امرأةٌ: يا رسول الله، ما نقصانُ العقل والدين؟ قال: «<b>أما نقصان عقلها: فشهادة امرأتين تعدل شهادة رجل، فهذا نقصان العقل. وتمكث الليالي لا تصلي، وتفطر في رمضان، فهذا نقصان الدين</b>»{107}. (٣/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق القَعْقاع بن حكيم- قال: لا تجوز شهادةُ النساء وحدهن، إلا على ما لا يطَّلع عليه إلا هُنَّ مِن عورات النساء، وما أشبه ذلك من حَمْلِهِنَّ، وحَيْضِهِنَّ{108}. (٣/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٦<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق عبد الملك- قال: تجوز شهادةُ النساء في الاستهلال{109}، ولا يجوز في ذلك أقل من أربع{108}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٧<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق حجاج-: أجاز شهادةَ النساء في النكاح{108}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٨<span class="dash">-</span></span> عن <span class="name-2">مكحول</span> -من طريق ثور- قال: لا تجوز شهادة النساء إلا في الدَّيْن{108}. (٣/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤١٩<span class="dash">-</span></span> عن علي بن مَعْبَد، قال: سئل <span class="name-2">الزُّهْرِي</span> -وأبو المَلِيح عنده-: هل تجوز شهادة النساء؟ قال: تجوز فيما ذكر الله ﷿ من الدَّيْن، ولا تجوز في غير ذلك{97}. (٣/٣٩٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِمَّن تَرۡضَوۡنَ مِنَ ٱلشُّهَدَاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٢٠<span class="dash">-</span></span> عن ابن أبي مُلَيْكة، قال: كتبتُ إلى <span class="name-1">ابنِ عباس</span> أسأله عن شهادة الصبيان. فكتب إلَيَّ: إنّ الله يقول: <span class="qpc-hafs">﴿ممن ترضون من الشهداء﴾</span>، فليسوا مِمَّن نرضى؛ لا تجوز{114}. (٣/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢١<span class="dash">-</span></span> وقال <span class="name-1">عبد الله بن الزبير</span> -من طريق ابن أبي مُلَيْكة- في شهادة الصبيان: هم أحرى إذا سئلوا عما رأوا أن يشهدوا. قال ابن أبي مليكة: فما رأيت القضاة أخذت إلا بقول ابن الزبير{115}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعِيّ</span> -من طريق الأعمش- في قوله: <span class="qpc-hafs">﴿ممن ترضون من الشهداء﴾</span>: الذي لم يُعلم، أو يُرَ له حِرابة{116}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ممن ترضون من الشهداء﴾</span>، قال: عدلان، حُرّان، مسلمان{117}. (٣/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٤<span class="dash">-</span></span> وقال <span class="name-2">عامر الشعبي</span>: العَدْل: مَن لم يُطْعَن عليه في بطن ولا فَرْج{118}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: هو مَن لم يُعْلَم له خِزْيَة{118}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿ممن ترضون من الشهداء﴾</span>، قال: عدول{92}. (٣/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ممن ترضون من الشهداء﴾</span>، يقول: ولا يشهد الرجل على حقِّه إلا مرضيًّا، إن كان الشاهد رجلًا أو امرأة{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٢٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿ممن ترضون من الشهداء﴾</span>: يأمر بإشهاده العدل من الرجال والنساء{104}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن تَضِلَّ إِحۡدَىٰهُمَا فَتُذَكِّرَ إِحۡدَىٰهُمَا ٱلۡأُخۡرَىٰۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١١٤٢٩<span class="dash">-</span></span> عن الأعمش، قال: في قراءة <span class="name-1">ابن مسعود</span>: (أن تَضِلَّ إحْداهُما فَتُذَكِّرَها الأُخْرى){123}. (٣/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> أنّه كان يقرؤها: (فَتُذْكِرُ إحْداهُما الأُخْرى) مخففة{124}. (٣/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه كان يقرؤها: (فتَذْكُرَ إحْداهُما الأُخْرى) مُثقَّلة{125}. (٣/٤٠٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن تَضِلَّ إِحۡدَىٰهُمَا فَتُذَكِّرَ إِحۡدَىٰهُمَا ٱلۡأُخۡرَىٰۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١١٤٣٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿فإن لم يكونا رجلين فرجل وامرأتان ممن ترضون من الشهداء أن تضل إحداهما﴾</span> يقول: أن تنسى إحدى المرأتين الشهادة، <span class="qpc-hafs">﴿فتذكر إحداهما الأخرى﴾</span> يعني: تذكِّرُها التي حفظت شهادتها{54}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿أن تضل إحداهما﴾</span>، يقول: إن تنسَ إحداهما تذكرها الأخرى{127}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿أن تضل إحداهما﴾</span>، قال: <span class="qpc-hafs">﴿أن تضل﴾</span> أن تنسى، <span class="qpc-hafs">﴿فتذكر إحداهما الأخرى﴾</span>{128}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أن تضل إحداهما﴾</span>، يقول: تنسى إحداهما الشهادة، فتذكرها الأخرى{129}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿أن تضل إحداهما فتذكر إحداهما الأخرى﴾</span>، يقول: أن تنسى إحداهما فتذكرها الأخرى{129}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن تضل﴾</span> المرأة، يعني: أن تنسى <span class="qpc-hafs">﴿إحداهما﴾</span> الشهادة، <span class="qpc-hafs">﴿فتذكر إحداهما﴾</span> الشهادة <span class="qpc-hafs">﴿الأخرى﴾</span> يقول: تذكرها المرأة الأخرى التي حفظت شهادتهما{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-: <span class="qpc-hafs">﴿أن تضل﴾</span> أن تنسى <span class="qpc-hafs">﴿إحداهما فتذكر إحداهما الأخرى﴾</span> فتذكرها صاحبتها{132}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿أن تضل إحداهما فتذكر إحداهما الأخرى﴾</span>، قال: إن أخطأت الشهادةَ فذكَّرتها الأخرى. قال: و<span class="qpc-hafs">﴿تُذَكِّرُ﴾</span>، (فتُذْكِرُ) قال: كلاهما لغة، وهما سواء، ونحن نقرأ: <span class="qpc-hafs">﴿فتُذكِّر﴾</span>{91}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٠<span class="dash">-</span></span> عن أبي عُبَيد القاسم بن سلّام أنه قال: حُدِّثت عن <span class="name-3">سفيان بن عيينة</span> أنه قال: ليس تأويل قوله: <span class="qpc-hafs">﴿فتذكر إحداهما الأخرى﴾</span> من الذِّكْر بعد النسيان، إنما هو من الذَّكَر، بمعنى: أنها إذا شهدت مع الأخرى صارت شهادتهما كشهادة الذَكَر{134}<span class=comment-ref>١٠٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧١</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٥/٩١-٩٢)، و<u>ابنُ عطية</u> (٢/١١٩)، و<u>ابنُ القيم</u> (١/٢١٣)، و<u>ابنُ كثير</u> (٢/٥٠٨) هذا القول <span class="mustanad">استنادًا إلى الدلالات العقلية، ومخالفة الإجماع</span>، وذلك أنّ ضلال المرأة في الشهادة نسيانها إياها، فالضالَّة حينئذ محتاجة إلى التذكير لا إلى الإذكار، لأنه لا يحسن في مقابلة الضلال إلا الذِّكْر، إذ هو مقابل له ومضاد، وليس للإذكار في ذلك مدخل.</p><p><span class="comment-type-1">ووجَّه</span> <u>ابنُ جرير</u> (٥/٩١-٩٢) قول ابن عيينة بتوجيهٍ، إلا أنه <span class="comment-type-2">انتقده</span> أيضًا؛ لصيرورته إلى معنى التذكير الذي رجَّحه، وكونه مبنيًّا على قراءة خلاف التي اختارها، فقال: «إلا إن أراد أن الذاكرة إذا ضعفت صاحبتُها عن ذكر شهادتها، شحذتها على ذكر ما ضعفت عن ذكره فنسيته، فقوَّتها بالذِّكر حتى صيَّرتْها كالرجل في قوتها في ذِكر ما ضعُفَت عن ذِكْره من ذلك، كما يقال للشيء القوي في عمله: ذَكَرٌ، وكما يقال للسيف الماضي في ضربه: سيف ذَكَرٌ، ورجل ذَكَرٌ، يُراد به: ماض في عمله، قوي البطش، صحيح العزم. فإن كان ابن عيينة هذا أراد، فهو مذهبٌ من مذاهب تأويل ذلك، إلا أنه إذا تؤول كذلك، صار تأويله إلى نحو تأويلنا الذي تأولناه فيه، وإن خالفت القراءةُ بذلك المعنى القراءةَ التي اخترناها، بأن تصير القراءة حينئذ الصحيح بالذي اختار قراءته من تخفيف الكاف من قوله: (فتُذْكِر)، ولم نعلم أحدًا تأوَّل ذلك كذلك، فنستجيز قراءته كذلك بذلك المعنى».</div></p><p><div></p><p><p><span class="item-no">١١٤٤١<span class="dash">-</span></span> عن مجاهد بن موسى، قال: سمعتُ <span class="name-3">ابن عيينة</span> يقول: حفظت الحديث منذ خمس وسبعين سنة، وقد نسيت، ولكن إذا ذُكِّرتُ ذَكَرْتُ، هو مثل قول الله -جل وعز-: <span class="qpc-hafs">﴿فتذكر إحداهما الأخرى﴾</span>، لو قيل لي: هذا فلان. ثم لم يكن هو، لقلت: لا. ولو قيل: هو خلفك. فالتفتُّ فنظرتُ إليه، لقلت: نعم. فهذا ليس هو هذا{135}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَأۡبَ ٱلشُّهَدَاۤءُ إِذَا مَا دُعُوا۟ۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٤٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: كان الرجل يطوف في الحِواء{136} العظيم فيه القوم، فيدعوهم إلى الشهادة، فلا يتبعه أحد منهم؛ فأنزل الله هذه الآية{137}. (٣/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: كان الرجل يطوف في القوم الكثير يدعوهم ليشهدوا، فلا يتبعه أحد منهم؛ فأنزل الله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>{138}. (٣/٤٠١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَأۡبَ ٱلشُّهَدَاۤءُ إِذَا مَا دُعُوا۟ۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١١٤٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ولا يأب الشهداء﴾</span>، يعني: مَن احْتِيج إليه من المسلمين شَهِد على شهادة، أو كانت عنده شهادة؛ فلا يحلُّ له أن يأبى إذا ما دُعي{139}. (٣/٣٩٤، ٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا كانت عندهم شهادة{140}. (٣/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: الذي معه الشهادة{141}. (٣/٣٩٥، ٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا كانوا قد شهِدوا{142}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٨<span class="dash">-</span></span> عن مغيرة، قال: سألت <span class="name-2">إبراهيم [النَّخَعي]</span> قلت: أُدْعى إلى الشهادة وأنا أخاف أن أنسى؟ قال: فلا تشهد إن شئت{143}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا كانت عندك شهادة فأَقِمْها، فأما إذا دُعيت لتشهد؛ فإن شئت فاذهب، وإن شئت فلا تذهب{144}. (٣/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا كانوا قد شهدوا قبل ذلك{145}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- في قول الله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: هي واجبة{132}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر الجعفي- قال: الشاهد بالخيار ما لم يُشهد{147}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا كتب الرجل شهادته، أو أشهد لرجلٍ فشَهِد، والكاتب الذي يكتب الكتاب؛ إذا دعوا إلى مقطع الحق فعليهم أن يجيبوا، وأن يشهدوا بما أُشْهِدوا عليه{148}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: لإقامة الشهادة{149}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٥<span class="dash">-</span></span> عن يونس بن عبيد، عن <span class="name-2">الحسن</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٦<span class="dash">-</span></span> و<span class="name-2">عكرمة</span> في هذه الآية: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال أحدهما: إذا دُعي يشهد فلا يأب. وقال الآخر: إذا شهد فلا يأب أن يشهد{150}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق سفيان، عن جابر- قال: <span class="qpc-hafs">﴿لا يأب الشهداء إذا ما دعوا﴾</span>، قال: إن شاء شهد، وإن شاء لم يشهد، فإذا لم يوجد غيره شهد{151}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسرائيل، عن جابر- قال: إذا شهد فدُعِي فلا يأب، وإذا لم يشهد فهو بالخيار؛ فإن شاء شهد، وإن شاء لم يشهد{140}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٥٩<span class="dash">-</span></span> عن <span class="name-2">ربيعة [الرأي]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٠<span class="dash">-</span></span> و<span class="name-2">زيد بن أسلم</span>، نحو ذلك{153}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦١<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق سفيان، عن جابر- قال: الشاهد بالخيار ما لم يُشْهَدْ{154}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٢<span class="dash">-</span></span> عن عِمران بن حُدَيْر، قال: قلت <span class="name-2">لأبي مِجْلَز</span>: ناس يدعونني لأشهد بينهم، وأنا أكره أن أشهد بينهم؟ قال: دع ما تكره، فإذا شهدت فأجب إذا دعيت{155}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- في الآية، قال: جَمَعَتْ أمرين: لا تأبَ إذا كانت عندك شهادة أن تشهد، ولا تأبَ إذا دُعيت إلى شهادة{156}. (٣/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي حُرَّة- أنّه سأله سائل قال: أُدعى إلى الشهادة وأنا أكره أن أشهد عليها؟ قال: فلا تُجِبْ إن شئت{157}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٥<span class="dash">-</span></span> عن قتادة، <span class="qpc-hafs">﴿ولا يأب الشهداء﴾</span>، قال: كان <span class="name-2">الحسن</span> يتأولها: إذا كانت عنده شهادة فدعي ليقيمها{158}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: إن وُجِد غيرُه فهو واسع{159}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٧<span class="dash">-</span></span> عن <span class="name-2">عطية العَوْفِي</span> -من طريق فُضَيْل بن مرزوق- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: أمرت أن تشهد، فإن شئت فاشهد، وإن شئت فلا تشهد{160}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٨<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق محمد بن ثابت العَبْدِي-، بمثله{161}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٦٩<span class="dash">-</span></span> عن ابن جريج، قال: قلت ل<span class="name-2">عطاء [بن أبي رباح]</span>: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>. قال: هم الذين قد شهدوا. قال: ولا يضر إنسانًا أن يأبى أن يشهد إن شاء. قلتُ لعطاء: ما شأنه إذا دُعيَ أن يكتب وجب عليه أن لا يأبى، وإذا دُعِي أن يشهد لم يجب عليه أن يشهد إن شاء؟ قال: كذلك يجب على الكاتب أن يكتب، ولا يجب على الشاهد أن يشهد إن شاء؛ الشهداء كثير{162}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٠<span class="dash">-</span></span> عن أبي عامر المزني، قال: سمعت <span class="name-2">عطاء [بن أبي رباح]</span> يقول: ذلك في إقامة الشهادة. يعني: قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>{163}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: لا تأب أن تشهد إذا دعيت إلى شهادة{164}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، يقول: لا يأبَ الشاهدُ أن يتقدم فيشهد إذا كان فارِغًا{148}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابنه عبد الرحمن- في قول الله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا شهد ثم دُعِي إلى شهادته فلا ينبغي إلا أن يأتي يشهد{166}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، يقول: إذا ما دُعِي الرجل ليستشهد على أخيه فلا يأبَ إن كان فارغًا{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٥<span class="dash">-</span></span> قال عبد الله بن وهب: وسألتُ <span class="name-3">الليث بن سعد</span> عن قول الله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>. قال: ذلك إذا شَهِد قبل ذلك فلا يأب أن يُؤَدِّي شهادته. فقلتُ له: فقول رسول الله: «<b>حتى يشهد الرجل ولم يستشهد</b>». فقال: الذي يقع في قلبي من ذلك وأظنه: الذي يشهد بما لم يعلم. فقلت له: مثل شهادة الزور؟ قال: نعم{168}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span>، قال: إذا شهد فلا يأب إذا دعي أن يأتي يؤدي شهادة ويقيمها{169}<span class=comment-ref>١٠٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٢</span> أفادت الآثارُ اختلافَ المفسِّرين في المراد من الشهادة التي نهى الله عن إباء الإجابة إليها؛ <b>فمِن قائل</b>: إنها شهادة الأداء لأمرٍ حصل. و<b>مِن قائلٍ</b>: إنها شهادة تحمُّل. و<b>مِن قائلٍ</b> بكليهما.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/١٠٠-١٠٢) أنّ المراد بها شهادة الأداء، و<span class="comment-type-2">انتَقَدَ</span> القول بكونها شهادة التحمُّل <span class="mustanad">مستندًا إلى دلالة العقل، واللغة</span>، وذلك أنّ: أ) اسم <span class="qpc-hafs">﴿الشهداء﴾</span> يُطلق على مَن وقعت منه الشهادة، لا على من دُعِيَ إليها ولم تقع منه بعد؛ إذ لو جاز إطلاقها عليه لم يكن على الأرض أحدٌ له عقل صحيح إلا وهو مستحق أن يقال له: شاهد، بمعنى أنه سيشهدُ، أو أنّه يصلح لأن يشهد. ب) أنّ أل في <span class="qpc-hafs">﴿الشهداء﴾</span> للعهد، فالمعنيُّ بالنهي عن ترك الإجابة للشهادة أشخاص معلومون قد عُرِفوا بالشهادة، ولو كان المراد غيرهم لقيل: ولا يأب شاهد إذا ما دُعي.</p><p>ثم بيَّن <u>ابنُ جرير</u> أنّ من دُعيَ لتحمل الشهادة في موضع ليس به سواه ممن يصلح للشهادة تعيَّن عليه إجابة داعيه، ولكنَّ تعيُّنَ ذلك عليه ليس من هذه الآية.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابن عطية</u> (٢/١٢٠) ما أفاده قول ابن عباس من طريق علي بن أبي طلحة، وقول الحسن من طريق معمر، في احتمال الآية لشهادتي التحمل والأداء، وأن ذلك على جهة الندب، وجعل الوجوب خاصًا بما إذا «عُلِمَ أنّ الحق يذهب ويتلف بتأخر الشاهد عن الشهادة، فواجِبٌ عليه القيامُ بها، لا سيَّما إن كانت محصَّلة وكان الدعاء إلى أدائها؛ لأنها قلادة في العنق، وأمانة تقتضي الأداء».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَسۡـَٔمُوۤا۟ أَن تَكۡتُبُوهُ صَغِیرًا أَوۡ كَبِیرًا إِلَىٰۤ أَجَلِهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٧٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿ولا تسأموا﴾</span> يقول: لا تَمَلُّوا <span class="qpc-hafs">﴿أن تكتبوه صغيرا أو كبيرا﴾</span> يعني: أن تكتبوا قليل الحق وكثيره <span class="qpc-hafs">﴿إلى أجله﴾</span> لأنّ الكتاب أحْصى للأجل والمال{170}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿ولا تسأموا أن تكتبوه صغيرا أو كبيرا إلى أجله﴾</span>، قال: هو الحق الذي بينهما الدَّيْن{171}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تسأموا﴾</span> يقول: ولا تملُّوا، وكل شيء في القرآن <span class="qpc-hafs">﴿تسأموا﴾</span> يعني: تملوا، <span class="qpc-hafs">﴿أن تكتبوه صغيرا أو كبيرا﴾</span> يعني: قليل الحق وكثيره <span class="qpc-hafs">﴿إلى أجله﴾</span> لأن الكتاب أحْصى للأجل، وأَحْفَظُ للمال{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٠<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿ولا تسأموا أن تكتبوه صغيرا أو كبيرا إلى أجله﴾</span>: جَمَعَتِ الصغير والكبير في الدَّيْن، سواء أُمِر أن يشهد عليه، وأن يكتب{173}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨١<span class="dash">-</span></span> عن <span class="name-3">شريك [بن عبد الله القاضي]</span> -من طريق يحيى بن آدم- في قوله: <span class="qpc-hafs">﴿ولا تسأموا أن تكتبوه صغيرا أو كبيرا إلى أجله﴾</span>، قال: الحق{174}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُمۡ أَقۡسَطُ عِندَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٨٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، في قوله: <span class="qpc-hafs">﴿أقسط عند الله﴾</span>، قالت: أعدل{175}. (٣/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿ذلكم﴾</span> يعني: الكتاب <span class="qpc-hafs">﴿أقسط عند الله﴾</span> يعني: أعدل{173}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي مصلح- في قوله: <span class="qpc-hafs">﴿أقسط عند الله﴾</span>، يقول: ذلكم طاعة الله{173}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ذلكم أقسط عند الله﴾</span>، يقول: أعدل عند الله{178}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلكم﴾</span> يعني: الكتاب <span class="qpc-hafs">﴿أقسط﴾</span> يعني: أعدل <span class="qpc-hafs">﴿عند الله﴾</span>{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٧<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق محمد بن يوسف- في قوله: <span class="qpc-hafs">﴿ذلكم أقسط عند الله﴾</span>، قال: أعدل عند الله{180}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقۡوَمُ لِلشَّهَـٰدَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وأقوم﴾</span> يعني: أصْوَب <span class="qpc-hafs">﴿للشهادة﴾</span>{173}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأقوم﴾</span> يعني: وأصوب <span class="qpc-hafs">﴿للشهادة﴾</span>{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٠<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق محمد بن يوسف- في قوله: <span class="qpc-hafs">﴿وأَقْوَمُ لِلشَّهادَةِ﴾</span>، قال: أثْبَتُ للشهادة{183}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَدۡنَىٰۤ أَلَّا تَرۡتَابُوۤا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٩١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وأدنى﴾</span> يقول: وأجدر <span class="qpc-hafs">﴿ألا ترتابوا﴾</span> ألّا تَشُكُّوا في الحق والأجل والشهادة إذا كان مكتوبًا. ثُمَّ استثنى، فقال: <span class="qpc-hafs">﴿إلا أن تكون تجارة حاضرة﴾</span>{184}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي مصلح- في قوله: <span class="qpc-hafs">﴿وأدنى ألا ترتابوا﴾</span>، يقول: أجدر ألا تنسَوْا{184}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأدنى ألا ترتابوا﴾</span>، يقول: ألا تَشُكُّوا في الشهادة{186}<span class=comment-ref>١٠٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٣</span> قال <u>ابنُ جرير</u> (٥/١٠٤): «ويعني بقوله: <span class="qpc-hafs">﴿أن لا ترتابوا﴾</span>: من أن لا تشكوا في الشهادة». <span class="mustanad">واستشهد عليه بقول السُّدِّي</span>، ولم يذكر غيرَه.</div></p><p><div></p><p><p><span class="item-no">١١٤٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأدنى ألا ترتابوا﴾</span> يعني: وأجدر ألا تَشُكُّوا -نظيرها <span class="qpc-hafs">﴿ذلك أدنى أن يأتوا بالشهادة﴾</span> [المائدة:١٠٨] أي: أجدر، ونظيرها في الأحزاب [٥١]: <span class="qpc-hafs">﴿ذلك أدنى﴾</span> يعني: أجدر <span class="qpc-hafs">﴿أن تقر أعينهن﴾</span>- في الحق، والأجل، والشهادة إذا كان مكتوبًا{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف - قال: إذا كان في الكتاب{184}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٦<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق محمد بن يوسف- في قوله: <span class="qpc-hafs">﴿وأدنى ألا ترتابوا﴾</span>، قال: لا تَشُكُّوا{189}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّاۤ أَن تَكُونَ تِجَـٰرَةً حَاضِرَةࣰ تُدِیرُونَهَا بَیۡنَكُمۡ فَلَیۡسَ عَلَیۡكُمۡ جُنَاحٌ أَلَّا تَكۡتُبُوهَاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٤٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿إلا أن تكون تجارة حاضرة﴾</span> يعني: يدًا بيد <span class="qpc-hafs">﴿تديرونها بينكم﴾</span> يعني: ليس فيها أجل؛ <span class="qpc-hafs">﴿فليس عليكم جناح﴾</span> يعني: حرج <span class="qpc-hafs">﴿ألا تكتبوها﴾</span> يعني: التجارة الحاضرة{190}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿ولا تسأموا أن تكتبوه صغيرا أو كبيرا إلى أجله﴾</span> إلى قوله: <span class="qpc-hafs">﴿فليس عليكم جناح ألا تكتبوها﴾</span>، قال: أمر الله أن لا تسأموا أن تكتبوه صغيرًا أو كبيرًا إلى أجله، وأمر ما كان يدًا بيد أن يشهد عليه صغيرًا كان أو كبيرًا، ورخص لهم أن لا يكتبوه{191}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٤٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿إلا أن تكون تجارة حاضرة تديرونها بينكم﴾</span>، يقول: معكم بالبلد تُدِيرونها، فتأخذ وتعطى، فليس على هؤلاء جناح أن لا يكتبوها{192}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رَخَّص في الاستثناء، فقال: <span class="qpc-hafs">﴿إلا أن تكون تجارة حاضرة تديرونها بينكم﴾</span> وليس فيها أجل؛ <span class="qpc-hafs">﴿فليس عليكم جناح﴾</span> يعني: حرج <span class="qpc-hafs">﴿ألا تكتبوها﴾</span> يعني: التجارة الحاضرة إذا كانت يدًا بيد على كل حال{193}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف - في قوله تعالى: <span class="qpc-hafs">﴿تديرونها بينكم﴾</span>، يعني: ليس فيها أجل{194}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَشۡهِدُوۤا۟ إِذَا تَبَایَعۡتُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٥٠٢<span class="dash">-</span></span> عن مجاهد: في قوله: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: كان <span class="name-1">ابن عمر</span> إذا باع بِنَقْدٍ أشهد، ولم يكتب{195}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، يعني: أشهِدُوا على حقِّكم إذا كان فيه أجلٌ أو لم يكن، فأشْهِدوا على حقِّكم على كل حال{194}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، نحو ذلك{197}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٥<span class="dash">-</span></span> عن <span class="name-2">جابر بن زيد</span>: أنّه اشترى سَوْطًا فأَشْهَد، وقال: قال الله: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>{198}. (٣/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم [النَّخَعيّ]</span> -من طريق مغيرة- في الآية، قال: أشهِدْ إذا بعتَ وإذا اشتريتَ، ولو دَسْتَجَةَ{199} بَقْل{200}. (٣/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله ﷿: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: إذا كان نسيئة كتب، وإذا كان نقدًا أشهد{201}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: أشْهِدُوا ولو على دَسْتَجَة من بقل{41}. (٣/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٠٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر-: <span class="qpc-hafs">﴿إلا أن تكون تجارة حاضرة تديرونها بينكم فليس عليكم جناح ألا تكتبوها﴾</span>، ولكن أشهدوا عليها إذا تبايعتم، أمر الله ما كان يدًا بيد أن يُشْهِدوا عليه صغيرًا كان أو كبيرًا{203}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: إن شاء أشهد، وإن شاء لم يُشهِد. قال: وقرأ: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا فليؤد الذي اؤتمن أمانته﴾</span> [البقرة: ٢٨٣]{204}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١١<span class="dash">-</span></span> عن الرَّبيع بن صَبيح، قال: قلت ل<span class="name-2">لحسن [البصري]</span>: يا أبا سعيد، قول الله ﷿: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قلتُ: أبيع الرجلَ بنقد، وأنا أعلم أنه لا ينقدني شهرين ولا ثلاثة، أترى بأسًا ألا أشهد عليه؟ قال: إن أشهدت فهو ثقة للذي لك، وإن لم تشهد فلا بأس{205}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٢<span class="dash">-</span></span> عن سليمان التيمي، قال: سألت <span class="name-2">الحسن [البصري]</span> عنها. فقال: إن شاء أشهد، وإن شاء لم يُشْهِد، ألا تسمع قوله ﷿: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span>{206}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٣<span class="dash">-</span></span> عن ابن جريج، قال: وقال <span class="name-2">عطاء [بن أبي رباح]</span> في قوله: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>: على الدرهم، والنصف درهم{207}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٤<span class="dash">-</span></span> عن <span class="name-2">أيوب [السِّخْتِيانِيّ]</span> -من طريق حماد بن زيد- في هذه الآية: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: هو بالخيار{206}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأشهدوا﴾</span> على حقِّكم <span class="qpc-hafs">﴿إذا تبايعتم﴾</span>{209}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَشۡهِدُوۤا۟ إِذَا تَبَایَعۡتُمۡۚ﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">١١٥١٦<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق عبد الملك بن أبي نضرة، عن أبيه- في قوله: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: نَسَخَتْها <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span> [البقرة:٢٨٣]{210}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿وأشهدوا إذا تبايعتم﴾</span>، قال: نَسَخَتْها: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span> [البقرة:٢٨٣]{211}. (٣/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن أبي خالد- قال: فكانوا يرون أنّ هذه الآية: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span> نَسَخَتْ ما قبلها من الكتابة والشهود رُخْصَةً ورحمةً من الله{212}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥١٩<span class="dash">-</span></span> عن العلاء بن المسيب، قال: سمعت <span class="name-2">الحَكَم [بن عُتَيْبة]</span> قرأ: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span> [البقرة:٢٨٣]، قال: نَسَخَتْ هذه الشهودَ{213}<span class=comment-ref>١٠٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٤</span> أفادت الآثارُ اختلاف المفسرين في قوله تعالى: <span class="qpc-hafs">﴿وأَشْهِدُوا إذا تَبايَعْتُمْ﴾</span> بين <b>قائل</b> بوجوب الإشهاد على البيع، و<b>قائل</b> بنسخ الوجوب، و<b>قائل</b> بالندب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/١١١) القول بالوجوب <span class="mustanad">استنادًا إلى دلالة الأمر على الوجوب</span>، فقال: «وأولى الأقوال في ذلك بالصواب: أنّ الإشهاد على كل مبيع ومُشتَرى حقٌّ واجبٌ وفرضٌ لازمٌ؛ لِما قد بَيَّنّا مِن أن كل أمرٍ لله ففرضٌ، إلا ما قامت حجَّتُه من الوجه الذي يجب التسليم له بأنه ندب وإرشاد».</p><p><span class="comment-type-2">وانتقد</span> <u>ابنُ عطية</u> (٢/١٢٢) <span class="mustanad">استنادًا إلى الدلالات العقلية</span> ما رجَّحه ابن جرير بقوله: «والوجوب في ذلك قَلِق، أما في الدقائق فصعبٌ شاقٌّ، وأما ما كثُرَ فربما يقصد التاجر الاستيلاف بترك الإشهاد، وقد يكون عادة في بعض البلاد، وقد يَسْتَحيي من العالِم والرجل الكبير الموقَّر فلا يُشهِد عليه، فيَدْخُل ذلك كله في الائتمان».</p><p><span class="comment-type-3">ورجَّح</span> <u>ابنُ عطية</u> (٢/١٢٢) و<u>ابنُ كثير</u> (٢/٥١٠) القول بالندب، قال <u>ابنُ عطية</u>: «ويبقى الأمر بالإشهاد ندبًا لما فيه من المصلحة في الأغلب، ما لم يقع عذر يمنع منه كما ذكرنا».</p><p>وذكر <u>ابنُ كثير</u> أنّه <span class="mustanad">قول الجمهور</span>، <span class="mustanad">واستدلَّ على الندب بحديث</span> خزيمة بن ثابت الأنصاري، وفيه: أن النبي ﷺ اشترى من أعرابيٍّ فرسًا، فأنكر الأعرابيُّ، وقال: هَلُمَّ شهيدًا يشهد أني بايعتك، ... حتى جاء خزَيْمة، فاستمع لمراجعة النبي ﷺ ومراجعة الأعرابي، فقال خزيمة: أنا أشهد أنك قد بايعته. الحديث، ثم ذكر <u>ابنُ كثير</u> أنّ الاحتياط هو الإشهاد، مستندًا إلى حديث «ثلاثة يدعون الله فلا يستجاب لهم: ..، ورَجلٌ أقْرضَ رجُلًا مالًا فلم يُشْهد».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٥/١١١) القول بالنسخ، فقال: «وقد دَلَّلْنا على وهْي قول من قال: إنه منسوخ بقوله: <span class="qpc-hafs">﴿فَلْيُؤَدِّ الَّذِي اؤْتُمِنَ أمانَتَهُ﴾</span> فيما مضى». وقد مرَّ ذكره عند قوله تعالى أول هذه الآية: <span class="qpc-hafs">﴿فاكْتُبُوهُ﴾</span>.</div></p><p><h3><span class="qpc-hafs">﴿وَأَشۡهِدُوۤا۟ إِذَا تَبَایَعۡتُمۡۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٢٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، قال: ثلاثة لا يستمع الله تعالى لهم دعاء: رجل معه امرأة زَنّاء، كلما قضى شهوته منها قال: ربِّ، اغفر لي. فيقول الربُّ -تبارك وتعالى-: تحول عنها وأنا أغفر لك، وإلا فلا. ورجل باع بيعًا إلى أجل مسمى ولم يُشهِد ولم يكتب، فكافرَه{214} الرجُلُ بماله، فيقول: يا ربِّ، كافَرَني فلان بمالي. فيقول الرب: لا آجُرُك ولا أُجِيبُك، إني أمرتُك بالكتاب والشُّهود فعصيتني. ورجل يأكل مال قوم وهو ينظر إليهم، ويقول: يا ربِّ، اغفر لي ما آكُلُ من مالهم. فيقول الرب تعالى: رُدَّ إليهم مالهم وإلا فلا{215}. (٣/٤٠٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یُضَاۤرَّ كَاتِبࣱ وَلَا شَهِیدࣱۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١١٥٢١<span class="dash">-</span></span> عن عكرمة، قال: كان <span class="name-1">عمر بن الخطاب</span> يقرؤها: (ولا يُضارَرْ كاتِبٌ ولا شَهِيدٌ)، يعني: بالبناء للمفعول{216}. (٣/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الضحاك- أنّه كان يقرأ: (ولا يُضارَرْ){217}. (٣/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الله بن كثير- أنّه كان يقرأ: (ولا يُضارَرْ كاتِبٌ ولا شَهِيدٌ). وأنّه كان يقول في تأويلها: ينطلق الذي له الحق فيدعو كاتبه وشاهده إلى أن يشهد، ولعله يكون في شغل أو حاجة ليُؤَثِّمه إن ترك ذلك حينئذ لشغله وحاجته. وقال مجاهد: لا يقم عن شغله وحاجته، فيجد في نفسه أو يحرج{218}. (٣/٤٠٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یُضَاۤرَّ كَاتِبࣱ وَلَا شَهِیدࣱۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٢٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿ولا يأب كاتب أن يكتب كما علمه الله﴾</span> كان أحدهم يجيء إلى الكاتب، فيقول: اكتب لي. فيقول: إني مشغول، أو لي حاجة، فانطلق إلى غيري. فيلزمه، ويقول: إنّك قد أُمِرْت أن تكتب لي. فلا يدعه، ويضاره بذلك وهو يجد غيره، ويأتي الرجل فيقول: انطلق معي فأُشهدك. فيقول: اذهب إلى غيري فإني مشغول، أو لي حاجة. فيلزمه، ويقول: قد أُمِرْتَ أن تتبعني. فيضاره بذلك، وهو يجد غيره؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>{219}. (٣/٤٠٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یُضَاۤرَّ كَاتِبࣱ وَلَا شَهِیدࣱۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة-: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، والضرار: أن يقول الرجل للرجل وهو عنه غنيٌّ: إنّ الله قد أمرك أن لا تأبى إذا دُعِيت. فيضاره بذلك وهو مُكْتَفٍ بغيره؛ فنهاه الله عن ذلك، وقال: <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق بكم﴾</span>{220}. (٣/٣٩٤، ٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، يقول: إنه يكون للكاتب والشاهد حاجة ليس منها بُدٌّ، فيقول: خَلُّوا سبيله{221}. (٣/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- في قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: يأتي الرجلُ الرجلين، فيدعوهما إلى الكتاب والشهادة، فيقولان: إنّا على حاجة. فيقول: إنّكما قد أُمِرْتُما أن تُجِيبا. فليس له أن يُضارَّهما{222}. (٣/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٢٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٢٩<span class="dash">-</span></span> و<span class="name-2">عطية العوفي</span>، نحو ذلك{223}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، نحو ذلك{224}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٢<span class="dash">-</span></span> و<span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج- في قوله تعالى: <span class="qpc-hafs">﴿ولا شهيد﴾</span>، قال: إذا كان قد شَهِد قبل هذا{147}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٣<span class="dash">-</span></span> عن عبيد بن سليمان، قال: سمعت <span class="name-2">الضحاك</span> في قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>: هو الرجل يدعو الكاتب أو الشاهد وهما على حاجة مُهِمَّة، فيقولان: إنّا على حاجة مهمة، فاطلب غيرنا. فيقول: واللهِ، لقد أمركما اللهُ أن تجيبا. فأمره أن يطلب غيرهما، ولا يضارهما، يعني: لا يشغلهما عن حاجتهما المهمة وهو يجد غيرهما{226}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿ولا يأب كاتب﴾</span>، قال: كانت عزيمةً، فَنَسَخَتْها <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>{227}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: يكون به العِلَّة، أو يكون مشغولًا، يقول: فلا يضاره{228}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٦<span class="dash">-</span></span> وقال <span class="name-3">الكلبي،</span> نحو ذلك{229}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٧<span class="dash">-</span></span> عن <span class="name-2">طاووس</span> -من طريق ابنه-: <span class="qpc-hafs">﴿ولا يضار كاتب﴾</span> فيكْتُبَ ما لم يُمَلَّ عليه، <span class="qpc-hafs">﴿ولا شهيد﴾</span> بما لم يستشهد{230}. (٣/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٨<span class="dash">-</span></span> عن <span class="name-2">طاووس</span> -من طريق ابنه- <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، يقول: إنّ لي حاجة فدعني. فيقول: لا، اكتب لي. ولا شهيدٌ كذلك{231}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٣٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس-: <span class="qpc-hafs">﴿ولا يضار كاتب﴾</span> فيزيد شيئًا أو يُحرِّف، <span class="qpc-hafs">﴿ولا شهيد﴾</span> لا يكتم الشهادة، ولا يشهد إلا بحق{232}. (٣/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٠<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: أن يُؤَدِّيا ما قِبَلهما{233}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤١<span class="dash">-</span></span> قال يحيى بن سلّام: بلغني عن <span class="name-2">عطاء</span> أنّه قال: هي في الوجهين جميعًا؛ إذا دُعِي ليُشهد، أو لِيَشْهَد بما عنده{234}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: اتقى اللهَ شاهدٌ في شهادته، لا يَنقُص منها حقًّا، ولا يزيد فيها باطلًا، اتقى الله كاتبٌ في كتابه، فلا يدَعنَّ منه حقًّا، ولا يزيدَن فيه باطلًا{235}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: لا يُضارَّ كاتِبٌ فيكتب ما لم يُمْلِل عليه، ولا شهيدٌ فيشهد بما لم يشهد{236}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، يقول: ليس ينبغي أن تعترض رجلًا له حاجةٌ فتُضارّه، فتقول له: اكتب لي. فلا تتركه حتى يكتب لك، وتفوته حاجتُه، ولا شاهدًا مِن شهودك وهو مشغول، فتقول: اذهب فاشهد لي. تحبسه عن حاجته وأنت تَجِدُ غيرَه{237}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- قال: وكان السلطان القاضي لا يترك رجلًا يشتم رجلًا، ولا يشتم شهيدًا، وذلك أنّ الله تعالى قال: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>{238}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٦<span class="dash">-</span></span> عن يعقوب، قال: سألت <span class="name-2">زيد بن أسلم</span> عن قول الله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>. قال: لا يضار الكاتب فيكتب غير الحق، ولا يضار الشهيد فيشهد بالباطل{239}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، يقول: لا يعمد أحدكم إلى الكاتب والشاهد فيدعوهما إلى الكتابة والشهادة ولهما حاجة، فيقول: اكتب لي، فإنّ الله أمرك أن تكتب لي. فيضاره بذلك وهو يجد غيره، ويقول للشاهد وهو يجد غيره: اشهد لي على حقِّي، فإنّ الله قد أمرك أن تشهد على حقي. وهو يجد غيره مَن يشهد له على حقه، فيضاره بذلك، فأمر الله ﷿ أن يُترَكا لحاجتهما، ويُلتمَس غيرهما{209}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٨<span class="dash">-</span></span> عن إسحاق، قال: حُدِّثْتُ عن [<span class="name-3">مقاتل</span>] <span class="name-3">بن حيان</span>، في قوله -جل وعز-: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: هو الرجل يدعو الكاتبَ أو الشاهدَ ولهما حاجة، فيطلب طلبه، فيقولا: التَمِسْ غيرَنا. فيقول: قد أمركما الله أن تشهدا وتكتبا. لِيُضارَّهما بذلك، فأمره الله ﷿ أن لا يضار الكاتب ولا الشاهد، ويلتمس غيرهما، قال: فإن لم تفعلوا <span class="qpc-hafs">﴿فإنه فسوق بكم﴾</span>{241}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، قال: لا يضارَّ كاتب فيكتب غير الذي أُمْلِي عليه. قال: والكُتاَّب يومئذ قليل، ولا يدرون أي شيء يُكْتَب، فيضارَّ فيكتُب غيرَ الذي أُمْلي عليه، فيُبْطِل حقَّهم. قال: والشهيد يضار فيحوَّل شهادته، فيبطل حقَّهم{235}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٠<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>: هو الرجل يأتي الرجل، فيقول: لا أريد إلا أنت. لِينظُرْ غيرَه. والشهيد: أن يأتي الرجل ليشهده، فيقول: أنا مشغول فانظر غيري. فلا يضاره، فيقول: لا أريد غيرك. لِيُشْهِد غيرَه{243}<span class=comment-ref>١٠٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٥</span> أفادت الآثار اختلاف المفسرين في المخاطب بالنهي في قوله تعالى: <span class="qpc-hafs">﴿ولا يُضارَّ كاتِبٌ ولا شَهِيدٌ﴾</span>، وقد حكى <u>ابنُ عطية</u> (٢/١٢٢، ١٢٣) هذا الخلاف مُلَخَّصًا، و<span class="comment-type-1">وجَّه</span> أقوال المفسرين، فقال: «واختلف الناس في معنى قوله تعالى: <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>، فقال الحسن، وقتادة، وطاووس، وابن زيد، وغيرهم: المعنى: ولا يضارَّ الكاتب بأن يكتب ما لم يُمْل عليه، ولا يضارَّ الشاهد بأن يزيد في الشهادة أو ينقص منها. وقال مثله ابن عباس، ومجاهد، وعطاء، إلا أنهم قالوا: لا يضار الكاتب والشاهد بأن يمتنعا. قال القاضي أبو محمد: ولفظ الضرر يعم هذا والقول الأول، والأصل في <span class="qpc-hafs">﴿يضار﴾</span> على هذين القولين: يُضارِر -بكسر الراء-، ثم وقع الإدغام، وفُتحت الراء في الجزم لخفة الفتحة. وقال ابن عباس أيضًا، ومجاهد، والضحاك، والسدي، وطاووس، وغيرهم: معنى الآية <span class="qpc-hafs">﴿ولا يضار كاتب ولا شهيد﴾</span>: بأن يؤذيه طالب الكتبة أو الشهادة، فيقول: اكتب لي، أو اشهد لي. في وقتِ عُذْر أو شُغْلٍ للكاتب أو الشاهد، فإذا اعتذرا بعذرهما حرَّج وآذاهما، وقال: خالفْتَ أمر الله. ونحو هذا من القول، ولفظ المضارَّة إذ هو من اثنين يقتضي هذه المعاني كلها، والكاتب والشهيد على القول الأول رفع بفعلهما، وفي القول الثاني رفع على المفعول الذي لم يُسَمَّ فاعله، وأصل: <span class="qpc-hafs">﴿يضار﴾</span> على القول الثاني: يُضارَر، بفتح الراء».</p><p>وبنحو توجيهه <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٥/١١٣-١١٤).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/١١٧، ١١٨) <span class="mustanad">مستندًا إلى السياق، ولغة العرب، ورسم المصحف</span>: أنّ المخاطَب: المُسْتكْتِب والمُستَشْهِد، وأنهما نُهِيا عن الإضرار بالكاتب أو الشاهد؛ لأنّ الخطاب بالأمر والنهي من أول الآية إلى آخرها خطاب لأهل الحقوق والمكتوب بينهم الكتاب، وما كان من أمر أو نهي فيها لغيرهم جاء بصيغة الغائب غير المخاطب، كقوله تعالى: <span class="qpc-hafs">﴿ولْيَكْتُبْ بَيْنَكُمْ كاتِبٌ بِالعَدْلِ﴾</span>، فتوجيه الكلام إلى ما كان نظيرًا له في سياق الآية أوْلى من توجيهه إلى ما كان مُنْعَدِلًا عنه، ولأنّ النهي لو كان للكاتب والشاهد لقيل: وإن يفْعلا فإنه فسوقٌ بهما؛ لأنهما اثنان".</div></p><p><h3><span class="qpc-hafs">﴿وَإِن تَفۡعَلُوا۟ فَإِنَّهُۥ فُسُوقُۢ بِكُمۡۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٥٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق﴾</span>، يعني بالفسوق: المعصية{244}. (٣/٣٩٤، ٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٣<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٤<span class="dash">-</span></span> و<span class="name-3">عطاء بن دينار</span>، نحو ذلك{245}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وإن تفعلوا﴾</span> يعني: إن تضارُّوا الكاتبَ أو الشاهدَ وما نهيتم عنه <span class="qpc-hafs">﴿فإنه فسوق بكم﴾</span>. ثم خوَّفهم، فقال: <span class="qpc-hafs">﴿واتقوا الله﴾</span>{246}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق بكم﴾</span>، يقول: إن تفعلوا غيرَ الذي أمركم به فإنه فسوق بكم{247}. (٣/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي-: <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق بكم﴾</span>، والفسوق: العصيان{248}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق بكم﴾</span>، يقول: وإن تضاروا الكاتب والشاهد وما نُهِيتم عنه فإنه إثم بِكُم{209}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٥٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿وإن تفعلوا﴾</span>، يقول: وإن لم تفعلوا الذي أمركم الله في آية الدَّيْن فإنه إثمٌ ومعصية{250}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٠<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>: <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق بكم﴾</span>، قال: معصية{251}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب-: <span class="qpc-hafs">﴿وإن تفعلوا فإنه فسوق بكم﴾</span>، الفسوق: الكَذِب، قال: هذا فسوق؛ لأنّه كَذَب الكاتبُ فحوَّل كتابَه فكذَب، وكذَب الشاهدُ فحوَّل شهادتَه، فأخبرهم الله ﷿ أنه كَذِب{252}<span class=comment-ref>١٠٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٦</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٢/١٢٤) معنى الفسق على ذلك القول بأن المراد به المعنى الشرعي للفسق، فقال: «مَن جعل المُضارَّة المنهي عنها زيادة الكاتب والشاهد فيما أملي عليهما، أو نقصهما منه؛ فالفسوق على عُرْفه في الشرع، وهو مواقعة الكبائر؛ لأن هذا من الكذب المؤذي في الأموال والأبْشار، وفيه إبطال الحق».</div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّقُوا۟ ٱللَّهَۖ وَیُعَلِّمُكُمُ ٱللَّهُۗ وَٱللَّهُ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝٢٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٥٦٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار-: <span class="qpc-hafs">﴿واتقوا الله﴾</span>ولا تعصوه فيها، <span class="qpc-hafs">﴿والله بكل شيء عليم﴾</span> يعني: من أعمالكم{54}. (٣/٣٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿واتقوا الله ويعلمكم الله﴾</span>، قال: هذا تعليم علَّمَكُمُوه، فخذوا به{254}. (٣/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوفهم، فقال سبحانه: <span class="qpc-hafs">﴿واتقوا الله﴾</span> ولا تعصوه فيهما، <span class="qpc-hafs">﴿ويعلمكم الله والله بكل شيء عليم﴾</span> من أعمالكم عليم{209}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّقُوا۟ ٱللَّهَۖ وَیُعَلِّمُكُمُ ٱللَّهُۗ وَٱللَّهُ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝٢٨٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٦٥<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>من عَمِل بما عَلِم ورَّثه الله عِلْم ما لم يعلم</b>»{256}. (٣/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٦<span class="dash">-</span></span> عن يزيد بن سلمة الجعْفيِّ أنّه قال: يا رسول الله، إنِّي سمعت منك حديثًا كثيرًا، أخاف أن ينسيني أولَه آخرُه، فحدثني بكلمة تكون جِماعًا. قال: «<b>اتَّقِ الله فيما تعلم</b>»{257}. (٣/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٧<span class="dash">-</span></span> عن جابر، قال: قال رسول الله ﷺ: «<b>من معادن التقوى: تَعَلُّمُك إلى ما علِمتَ ما لم تَعْلَمْ، والنَّقْصُ والتقصير فيما عَلِمْتَ قِلَّةُ الزيادة فيه، وإنما يزهد الرجل في علم ما لم يعلم قِلَّةُ الانتفاع بما قد علم</b>»{258}. (٣/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٨<span class="dash">-</span></span> عن <span class="name-2">زياد بن حُدَير</span>، قال: ما فَقِه قومٌ لم يَبْلُغُوا التُّقى{259}. (٣/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٦٩<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، قال: مَن عَمِل بما يعلم وُفِّق لما لا يَعلمُ{260}. (٣/٤٠٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّقُوا۟ ٱللَّهَۖ وَیُعَلِّمُكُمُ ٱللَّهُۗ وَٱللَّهُ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝٢٨٢﴾</span> - من أحكام آية الدَّيْن</h3></p><p><div></p><p><p><span class="item-no">١١٥٧٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق مجالد- قال: البيوع ثلاثة: بيعُ شُهودٍ وكتابٍ، وبيعٌ بِرِهانٍ مقبوضةٍ، وبيعٌ بالأمانة. ثم قرأ آية الدَّيْن{261}. (ز)</p></p><p></div></p></div>",footnotes:1:أي: خالق. لسان العرب (ذرأ).|2:الأَزْهَر من الرجال: الأبيض، العتيق البياض، النَّيِّر، الحسن، وهو أحسن البياض، كأن له بريقًا ونُورًا يُزْهِرُ كما يُزْهِرُ النجم والسراج. لسان العرب (زهر).|3:أخرجه أحمد ٤/١٢٧ (٢٢٧٠)، ٥/٤٦٣ (٣٥١٩)، وابن أبي حاتم ٢/٥٥٥ (٢٩٥٠).</p><p>قال الهيثمي في المجمع ٨/٢٠٦ (١٣٧٩٤): «وفيه علي بن زيد، وضعفه الجمهور، وبقية رجاله ثقات».|4:أخرجه البيهقي ٦/٣١ (١١٠٨٢)، وابن جرير ٥/٧٠ واللفظ له، وابن أبي حاتم ٢/٥٥٤ (٢٩٤٧).</p><p>قال ابن الملقّن في البدر المنير ٦/٦١٦: «بإسناد الصحيح».|5:أخرجه ابن جرير ٥/٦٨.|6:أخرجه أبو عبيد في فضائله ٢/٢٢٤.|7:أخرجه الشافعي ٢/٣٦٠ (٥٩٨ – شفاء العي)، وعبد الرزاق (١٤٠٦٤)، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٤١٩ (٢٢٧٥٨)، وابن جرير ٥/٧١، وابن المنذر (٦٦)، وابن أبي حاتم ٢/٥٥٤، والطبراني (١٢٩٠٣)، والحاكم ٢/٢٨٦، والبيهقي ٦/١٨، ١٩. وعلَّقه البخاري ٣/٨٦ [ويُنظر: الفتح ٤/٤٣٤]. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن أبي حاتم ٢/٥٧٤.|9:أخرجه البخاري في التاريخ الكبير ١/٢٣٢، والنحاس في ناسخه ص٢٦٧-٢٦٨، وابن ماجه (٢٣٦٥)، وابن جرير ٥/٧٥-٧٦، وابن المنذر (٧٤)، وابن أبي حاتم ٢/٥٧٠ (٣٠٤١)، وأبو نعيم في الحلية ٩/٤٨، والبيهقي في سُنَنِه ١٠/١٤٥. وعزاه السيوطي إلى أبي داود في ناسخه.|10:أخرجه ابن المنذر ١/٦٧، وابن أبي حاتم ٢/٥٧٥.|11:أخرجه ابن المنذر ١/٦٧ (٧١)، وابن جرير ٦/٣٩٢. وأخرجه الحاكم مرفوعًا ٢/٣٣١ (٣١٨١).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه لتوقيف أصحاب شعبة هذا الحديث على أبي موسى». وقال الذهبي: «على شرط البخاري ومسلم، ولم يخرجاه». وقال الألباني في الصحيحة ٤/٤٢١ (١٨٠٥): «فالسند ظاهره الصحة، لكن قد يعلّه توقيف أصحاب شعبة له، إلا أنه لم ينفرد به معاذ بن معاذ، بل تابعه داود بن إبراهيم الواسطي».|12:كذا في المطبوع، ولم يتبين لنا من هو، ولعله تصحيف من: أبي معمر عبد الله بن سخبرة الأزدي.|13:أخرجه ابن المنذر ١/٦٧ (٧٢).|14:أخرجه ابن أبي شيبة ٤/٢٩٩ (٢٠٣٦٧)، وابن المنذر ١/٦٨ (٧٣) واللفظ له.|15:أخرجه ابن المنذر ١/٦٦، وبنحوه ابن جرير ٥/٧٢، وابن أبي حاتم ٢/٥٥٥.|16:أخرجه ابن جرير ٥/٧٤.|17:أخرجه سفيان الثوري في تفسيره بنحوه ص٧٣، وابن جرير ٥/٧٤.|18:أخرجه ابن جرير ٥/٧٥.|19:أخرجه ابن جرير ٥/٧٥.|20:أخرجه ابن جرير ٥/٧٤.|21:أخرجه ابن جرير ٥/٧٤.|22:أخرجه ابن جرير ٥/٧٣.|23:أخرجه ابن جرير ٥/٧٢، وابن أبي حاتم ٢/٥٧٥ مختصرًا.|24:تفسير مقاتل بن سليمان ١/٢٢٨.|25:أخرجه ابن جرير ٥/٧٢، وابن المنذر ١/٦٧ من طريق محمد بن ثور.|26:أخرجه ابن أبي حاتم ٢/٥٧٥.|27:أخرجه ابن جرير ٥/٧٤.|28:أخرجه البخاري ٣/٨٥ (٢٢٣٩، ٢٢٤٠، ٢٢٤١)، ٣/٨٧ (٢٢٥٣)، ومسلم ٣/١٢٢٦ (١٦٠٤).|29:الأندر: البيدر، وهو الموضع الذي يداس فيه الطعام بلغة أهل الشام. النهاية في غريب الحديث والأثر (أندر).|30:أخرجه البيهقي ٦/٢٥.|31:أخرجه ابن أبي حاتم ٢/٥٥٦.|32:أخرجه ابن جرير ٥/٧٦، وابن المنذر ١/٧١، وابن أبي حاتم ٢/٥٥٨.|33:أخرجه ابن جرير ٥/٨١، وابن المنذر ١/٦٨، وابن أبي حاتم ٢/٥٥٨.|34:تفسير مقاتل بن سليمان ١/٢٢٨.|35:أخرجه ابن أبي حاتم ٢/٥٥٦، وابن المنذر ١/٦٨ من طريق إسحاق عمَّن حدَّثه.|36:أخرجه ابن جرير ٥/٧٧، وابن المنذر ١/٦٩، وابن أبي حاتم ٢/٥٥٨، وأخرجه عبد الرزاق في مصنفه (١٥٥٦٠)، وابن جرير من طريق ابن جريج ٥/٧٧. وعزاه السيوطي إلى عبد بن حميد.|37:أخرجه ابن جرير ٥/٧٧. وعلَّقه ابن أبي حاتم ٢/٥٥٦.|38:أخرجه ابن جرير ٥/٧٨.|39:أخرجه ابن جرير ٥/٧٧، وابن المنذر ١/٧٠. وعلَّقه ابن أبي حاتم ٢/٥٥٦.|40:أخرجه عبد الرزاق في مصنفه (١٥٥٦٠)، وابن جرير ٥/٧٧، وابن المنذر ١/٦٩.|41:عزاه السيوطي إلى عَبد بن حُمَيد.|42:أخرجه ابن جرير ٥/٧٨، وابن المنذر ١/٧٠، وابن أبي حاتم ٢/٥٥٧.|43:أخرجه ابن جرير ٥/٧٨، وابن أبي حاتم ٢/٥٥٧.|44:تفسير مقاتل بن سليمان ١/٢٢٨.|45:أخرجه ابن أبي حاتم ٢/٥٥٧.|46:أخرجه ابن أبي حاتم ٢/٥٥٧.|47:أخرجه ابن أبي حاتم ٢/٥٥٧.|48:تفسير مقاتل بن سليمان ١/٢٢٨.|49:أخرجه ابن أبي حاتم ٢/٥٥٧.|50:علَّقه ابن أبي حاتم ٢/٥٥٧.|51:تفسير مقاتل بن سليمان ١/٢٢٨.|52:أخرجه ابن المنذر ١/٧٠، وابن أبي حاتم ٢/٥٥٨ نحوه.|53:أخرجه ابن أبي حاتم ٢/٥٥٧.|54:أخرجه ابن أبي حاتم ٢/٥٥٧، ٥٦٨.|55:أخرجه ابن أبي حاتم ٢/٥٥٨.|56:أخرجه ابن جرير مختصرًا ٥/٧٦، وابن المنذر ١/٧١، وابن أبي حاتم ٢/٥٥٨.|57:أخرجه ابن جرير ٥/٨١. وعلَّقه ابن أبي حاتم ٢/٥٥٨.|58:تفسير مقاتل بن سليمان ١/٢٢٨.|59:أخرجه ابن المنذر ١/٧١.|60:أخرجه ابن جرير ٥/٨١.|61:أخرجه ابن أبي حاتم ٢/٥٥٩.|62:أخرجه ابن جرير ٥/٨٢، وابن أبي حاتم ٢/٥٥٩.|63:علَّقه ابن أبي حاتم ٢/٥٥٩.|64:أخرجه ابن جرير ٥/٨٢.|65:أخرجه ابن جرير ٥/٨٢، وابن المنذر ١/٧٢، وابن أبي حاتم ٢/٥٥٩.|66:تفسير مقاتل بن سليمان ١/٢٢٨.|67:أخرجه ابن أبي حاتم ٢/٥٥٩.|68:أخرجه ابن جرير ٥/٨٥. وعلَّقه ابن أبي حاتم ٢/٥٥٩.|69:أخرجه ابن المنذر ١/٧٢.|70:أخرجه ابن جرير ٥/٨٥، وابن المنذر ١/٧٢، وابن أبي حاتم ٢/٥٥٩.|71:تفسير مقاتل بن سليمان ١/٢٢٨.|72:علَّقه ابن أبي حاتم ٢/٥٥٩.|73:أخرجه ابن جرير ٥/٨٤.|74:أخرجه ابن أبي حاتم ٢/٥٥٩.|75:علَّقه ابن أبي حاتم ٢/٥٥٩.|76:تفسير مقاتل بن سليمان ١/٢٢٨.|77:أخرجه ابن جرير ٥/٨٤.|78:أخرجه ابن المنذر ١/٧٢.|79:أخرجه ابن أبي حاتم ٢/٥٥٩-٥٦٠.|80:أخرجه ابن جرير ٥/٨٥.|81:أخرجه ابن المنذر ١/٧٢، وابن أبي حاتم ٢/٥٥٩ مختصرًا.|82:أخرجه ابن المنذر ١/٧٣.|83:أخرجه ابن جرير ٥/٨٤.|84:تفسير مقاتل بن سليمان ١/٢٢٨-٢٢٩.|85:أخرجه ابن المنذر ١/٧٢، وابن أبي حاتم ٢/٥٦٠ بلفظ: ولي طالبه.|86:أخرجه ابن المنذر ١/٧٣.|87:أخرجه ابن جرير ٥/٨٥.|88:أخرجه ابن أبي حاتم ٢/٥٥٥. وعزاه السيوطي إلى ابن جرير، وابن المنذر.|89:أخرجه ابن المنذر ١/٧٤، وابن أبي حاتم ٢/٥٦٠ ناسبًا الأثر كله من قول مجاهد. وعزاه السيوطي إلى عبد بن حميد.|90:أخرجه ابن أبي حاتم ٢/٥٦٠.|91:أخرجه ابن جرير ٥/٩٣.|92:أخرجه ابن جرير ٥/٨٧.|93:تفسير مقاتل بن سليمان ١/٢٢٩.|94:أخرجه ابن أبي حاتم ٢/٥٦٠.|95:أخرجه سفيان الثوري في تفسيره ص٧٣، وسعيد بن منصور في سننه ٢/٩٩١ (٤٥٦- تفسير)، وابن جرير ٥/٨٦، وابن المنذر ١/٧٤، والبيهقي ١/١٦١، كما أخرجه ابن أبي حاتم ٢/٥٦٠ من طريق ليث بلفظ: «شاهدين حرين وليس العبدين رجلان، هما عبدين [كذا في المطبوع] كما سماهما الله». وعزاه السيوطي إلى سفيان بن عيينة، وعَبد بن حُمَيد.|96:أخرجه ابن جرير ٥/٨٧، وابن أبي حاتم ٢/٥٦١.|97:أخرجه ابن المنذر ١/٧٥.|98:أخرجه ابن المنذر ١/٧٥.|99:أخرجه ابن المنذر ١/٧٥.|100:أخرجه سعيد بن منصور (٤٥٧ – تفسير).|101:أخرجه ابن المنذر ١/٧٥.|102:أخرجه ابن المنذر ١/٧٥.|103:أخرجه مالك في الموطأ (ت: د. بشار عواد) ٢/٢٦٧ (٢١٢٢).|104:أخرجه ابن أبي حاتم ٢/٥٦١.|105:أخرجه ابن جرير ٥/٨٧، وابن أبي حاتم ٢/٥٦١.|106:لُبُّ الرجل: ما جُعِلَ في قلبه من العقل. لسان العرب (لبب).|107:أخرجه مسلم ١/٨٦ (٨٠) من حديث أبي هريرة وأبي سعيد الخدري، وأخرجه البخاري ١/٨٣، ٢/١٤٩ (٣٠٤، ١٤٦٢) من حديث أبي سعيد الخدري بنحو هذا اللفظ.|108:أخرجه ابن المنذر ١/٧٦.|109:اسْتَهَلَّ الصبي: رفع صوته بالبكاء. القاموس المحيط (هلل).|110:أخرجه ابن المنذر ١/٧٦.|111:أخرجه ابن المنذر ١/٧٦.|112:أخرجه ابن المنذر ١/٧٦.|113:أخرجه ابن المنذر ١/٧٥.|114:أخرجه سعيد بن منصور (٤٥٥ – تفسير)، وابن أبي حاتم ٢/٥٦١، والحاكم ٢/٢٨٦، والبيهقي في سُنَنه ١٠/١٦١-١٦٢.|115:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٨٠ (٢١٤٣٣)، والحاكم (ت: مصطفى عطا) ٢/٣١٤ (٣١٣١/٢٥٠)، والبيهقي في الكبرى ١٠/١٦٢. وهو تتمة الحديث السابق.|116:أخرجه ابن المنذر ١/٧٧، وابن أبي حاتم ٢/٥٦١، وفي المطبوع منه: خوبه. وذكر محقق النسخة المرقومة بالآلة الكاتبة ٣/١١٧٧ أنه كذا في الأصل، وفي تفسير الثعلبي ٢/٢٩٣: مَن لم يظهر منه ريبة.|117:أخرجه الشافعي ٧/١٢٦، والبيهقي ١٠/١٦٣.|118:تفسير الثعلبي ٢/٢٩٣.|119:تفسير الثعلبي ٢/٢٩٣.|120:أخرجه ابن جرير ٥/٨٧.|121:تفسير مقاتل بن سليمان ١/٢٢٩.|122:أخرجه ابن أبي حاتم ٢/٥٦١.|123:أخرجه ابن أبي داود في المصاحف ص٥٨.</p><p>والقراءة شاذة. انظر: تفسير الألوسي ٣/٥٩.|124:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>والقراءة شاذة منسوبة إلى مجاهد، وحميد بن عبد الرحمن. انظر: البحر المحيط ٢/٣٤٩.|125:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>في إتحاف فضلاء البشر ص٢١٣ أن قراءة الحسن من ذَكَر كَنَصَر، فتكون قراءته (فتذكُر) كتنصُر، وعلى هذا فالمراد بالتثقيل ضم الكاف.|126:أخرجه ابن أبي حاتم ٢/٥٥٧، ٥٦٨.|127:أخرجه ابن جرير ٥/٩٣. وعلَّقه ابن أبي حاتم ٢/٥٦٢.|128:أخرجه ابن المنذر ١/٧٧، وابن أبي حاتم ٢/٥٦٢.|129:أخرجه ابن جرير ٥/٩٣، وابن أبي حاتم ٢/٥٦٢.|130:أخرجه ابن جرير ٥/٩٣، وابن أبي حاتم ٢/٥٦٢.|131:تفسير مقاتل بن سليمان ١/٢٢٩.|132:أخرجه ابن أبي حاتم ٢/٥٦٢.|133:أخرجه ابن جرير ٥/٩٣.|134:أخرجه ابن جرير ٥/٨٩، وابن المنذر ١/٧٨.|135:أخرجه ابن المنذر ١/٧٧.|136:الحِواء: اسم المكان الذي يَحْوِي الشيء، أي: يجمعه ويضمه. لسان العرب (حوا).|137:أخرجه ابن جرير ٥/٩٤، وزاد فيه: وكان قتادة يتأول هذه الآية: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span> ليشهدوا لرجل على رجل. وعلَّقه ابن أبي حاتم ٢/ ٥٦٣. وذكر نحوه يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٦٩-. وعزاه السيوطي إلى عبد بن حميد.|138:أخرجه ابن جرير ٥/٩٤، وابن أبي حاتم ٢/٥٦٣.|139:أخرجه ابن جرير ٥/٩٥، وابن المنذر ١/٧٨، وابن أبي حاتم ٢/٥٦٣، والبيهقي في سننه ١٠/١٦١.|140:أخرجه ابن أبي حاتم ٢/٥٦٣.|141:أخرجه ابن أبي حاتم ٢/٥٦٣. كما أخرجه ابن جرير ٥/٩٨، وابن المنذر ١/٨٠ نحوه من طريق سالم الأفطس. كذلك عزا السيوطيُّ إلى عبد بن حميد نحوه.|142:أخرجه ابن جرير ٥/٩٨. وعلَّقه ابن أبي حاتم ٢/٥٦٢.|143:أخرجه سعيد بن منصور في سننه (٤٦١-تفسير)، وابن جرير ٥/٩٨.|144:أخرجه ابن جرير ٥/٩٧، وابن المنذر ١/٨٠. وعلَّقه ابن أبي حاتم ٢/٥٦٢. وعزاه السيوطي إلى سفيان، وعَبد بن حُمَيد. كما أخرجه ابن جرير ٥/٩٦، ٩٧ من طريق ابن أبي نجيح بلفظ: «إذا كانت عندك شهادة فدعيت». وفي لفظ آخر: إذا كانوا قد شهدوا قبل ذلك، وبنحوه عبد الرزاق ١/١٠، وابن المنذر ١/٨٠.|145:تفسير مجاهد ص٢٤٦، وأخرج نحوه عبد الرزاق ١/١٠، وابن أبي شيبة في مصنفه ١١/٤٣٤-٤٣٥ (٢٢٨١٩)، وابن جرير ٥/٩٦، ٩٧، وابن المنذر ١/٨٠.|146:أخرجه ابن أبي حاتم ٢/٥٦٢.|147:أخرجه عبد الرزاق ١/١١٠.|148:أخرجه ابن جرير ٥/٩٩.|149:أخرجه سعيد بن منصور في سننه (٤٦٠- تفسير)، وابن جرير ٥/٩٧، وابن المنذر ١/٨٠.|150:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٩٨ (١٨٧).|151:أخرجه ابن جرير ٥/٩٥.|152:أخرجه ابن أبي حاتم ٢/٥٦٣.|153:علَّقه ابن أبي حاتم ٢/٥٦٢.|154:أخرجه ابن أبي شيبة ٧/٧٢، وابن جرير ٥/٩٧، وابن أبي حاتم ٢/٥٦٢.|155:أخرجه ابن أبي شيبة ٧/٧١، وابن جرير ٥/٩٧، وابن المنذر ١/٧٩.|156:أخرجه عبد الرزاق في تفسيره ١/١١٠، وابن جرير ٥/٩٥، وبنحوه ابن المنذر ١/٧٩. وعلَّقه ابن أبي حاتم ٢/٥٦٣. كما أخرجه ابن جرير من طريق يونس ٥/٩٦ بلفظ: «لإقامتها، ولابتدائها، إذا دعاه ليشهده، وإذا دعاه ليقيمها». وبنحوه ابن المنذر ١/٧٩.|157:أخرجه ابن جرير ٥/٩٨.|158:أخرجه سعيد بن منصور في سننه (٤٦٣-تفسير)، وابن جرير ٥/٩٩.|159:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٦٩-.|160:أخرجه ابن جرير ٥/١٠٠.|161:أخرجه سعيد بن منصور في سننه (٤٥٨-تفسير)، وابن أبي شيبة ٧/٧٢، وابن جرير ٥/١٠٠.|162:أخرجه عبد الرزاق في مصنفه مختصرًا (١٥٥٦٠)، وابن جرير ٥/٩٩، وابن المنذر ١/٦٩. وأخرج ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٤٣٤ (٢٢٨١٥) من طريق محمد بن ثابت، عن عطاء أنه سئل: <span class="qpc-hafs">﴿ولا يأب الشهداء إذا ما دعوا﴾</span> قبل أن شهدوا، أو بعد؟ قال: لا، بل بعد ما شهدوا.|163:أخرجه ابن جرير ٥/٩٨، وابن المنذر ١/٧٩.|164:أخرجه عبد الرزاق في تفسيره ١/١١٠، وابن جرير ٥/٩٥.|165:أخرجه ابن جرير ٥/٩٩.|166:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٩٧ (١٨٦)، وابن أبي حاتم ٢/٥٦٢ من طريقه.|167:تفسير مقاتل بن سليمان ١/٢٢٩.|168:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٩٧ (١٨٥).|169:أخرجه عبد الرزاق في مصنفه مختصرًا (١٥٥٦٠)، وابن جرير ٥/٩٩، وابن المنذر ١/٦٩.|170:أخرجه ابن أبي حاتم ٢/٥٦٣-٥٦٤.|171:أخرجه ابن جرير ٥/١٠٢.|172:تفسير مقاتل بن سليمان ١/٢٢٩.|173:أخرجه ابن أبي حاتم ٢/٥٦٤.|174:أخرجه ابن المنذر ١/٨١.|175:عزاه السيوطي إلى ابن المنذر.|176:أخرجه ابن أبي حاتم ٢/٥٦٤.|177:أخرجه ابن أبي حاتم ٢/٥٦٤.|178:أخرجه ابن جرير ٥/١٠٤، وابن المنذر ١/٨١، وابن أبي حاتم ٢/٥٦٤.|179:تفسير مقاتل بن سليمان ١/٢٢٩.|180:أخرجه ابن المنذر ١/٨١. وعلَّقه ابن أبي حاتم ٢/٥٦٤.|181:أخرجه ابن أبي حاتم ٢/٥٦٤.|182:تفسير مقاتل بن سليمان ١/٢٢٩.|183:أخرجه ابن المنذر ١/٨١، وابن أبي حاتم ٢/٥٦٥.|184:أخرجه ابن أبي حاتم ٢/٥٦٥.|185:أخرجه ابن أبي حاتم ٢/٥٦٥.|186:أخرجه ابن جرير ٥/١٠٤، وابن المنذر ١/٨٢، وابن أبي حاتم ٢/٥٦٥.|187:تفسير مقاتل بن سليمان ١/٢٢٩.|188:أخرجه ابن أبي حاتم ٢/٥٦٥.|189:أخرجه ابن المنذر ١/٨٢. وعلَّقه ابن أبي حاتم ٢/٥٦٥.|190:أخرجه ابن أبي حاتم ٢/٥٦٥-٥٦٦.|191:أخرجه ابن جرير ٥/١٠٦، وابن المنذر ١/٨٢ بنحوه. وعلَّقه ابن أبي حاتم ٢/٥٦٥.|192:أخرجه ابن جرير ٥/١٠٦، وابن أبي حاتم ٢/٥٦٥-٥٦٦.|193:تفسير مقاتل بن سليمان ١/٢٢٩-٢٣٠.|194:أخرجه ابن أبي حاتم ٢/٥٦٦.|195:أخرجه سفيان الثوري في تفسيره ص٧٣.|196:أخرجه ابن أبي حاتم ٢/٥٦٦.|197:علَّقه ابن أبي حاتم ٢/٥٦٦.|198:أخرجه ابن المنذر ١/٨٤. وعلَّقه ابن أبي حاتم ٢/٥٦٦.|199:الدَّسْتَجَة: الحزمة، فارسي معرب. لسان العرب (دستج).|200:أخرجه النحاس في ناسخه ص٢٦٧.|201:أخرجه سفيان الثوري في تفسيره ص٧٣، وابن المنذر ١/٨٤.|202:عزاه السيوطي إلى عَبد بن حُمَيد.|203:أخرجه ابن جرير ٥/١١٠، وابن المنذر ١/٨٤. وعلَّقه ابن أبي حاتم ٢/٥٦٦.|204:أخرجه سفيان الثوري في تفسيره ص٧٣، وابن جرير من طريق سفيان عن رجل ٥/١١٠، وأخرج نحوه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٥٧١ (٢٠٧٣٤) من طريق هشيم عن إسماعيل. كما أخرج نحوه ابن جرير ٥/١١٠، وابن المنذر ١/٨٣ من طريق داود، دون ذكر الآية آخره. وعلَّق ابن أبي حاتم ٢/٥٦٦ نحوه.|205:أخرجه ابن جرير ٥/١١٠.|206:أخرجه ابن المنذر ١/٨٣.|207:أخرجه ابن المنذر ١/٨٤. وعلَّقه ابن أبي حاتم ٢/٥٦٦، والنحاس في ناسخه (ت: اللاحم) ٢/١١٠.|208:أخرجه ابن المنذر ١/٨٣.|209:تفسير مقاتل بن سليمان ١/٢٣٠.|210:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٥٧١ (٢٠٧٣٥). وأخرج ابن المنذر ١/٨٣ نحوه دون ذكر الآية الناسخة، وفيه: صار الأمر إلى الأمانة.|211:أخرجه ابن أبي حاتم ٢/٥٦٦، وأبو نعيم في الحلية ٩/٤٨. كما أخرج نحوه ابن أبي شيبة (ت: محمد عوامة) ١٠/٥٧٠ (٢٠٧٣٣) من طريق سليمان التيمي. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٦٩- نحوه.|212:أخرجه سفيان الثوري في تفسيره بنحوه ص٧٣، وابن جرير ٥/٧٤. وعلَّقه ابن أبي حاتم ٢/٥٦٦.|213:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٥٧١ (٢٠٧٣٧).|214:كافَرَه: جحده حقه. لسان العرب (كفر).|215:أخرجه هنّاد في الزهد ٢/٤٥٥.|216:أخرجه عبد الرزاق ١/١١١، وسعيد بن منصور (٤٦٦- تفسير)، وابن جرير ٥/١١٤، وابن المنذر (١٣٧)، والبيهقي ١٠/١٦١. وعزاه السيوطي إلى سفيان، وعبد بن حميد.</p><p>والقراءة المذكورة قراءة شاذة نسبت لعمر، وابن مسعود، ومجاهد، والحسن، والضحاك. انظر: البحر المحيط ٢/٣٥٣-٣٥٤.|217:أخرجه ابن جرير ٥/١١٤، وابن المنذر ١/٨٦.|218:أخرجه ابن جرير ٥/١١٤، وابن المنذر ١/٨٦، والبيهقي في سننه ١٠/١٦١. وعلَّقه ابن أبي حاتم ٢/٥٦٧.|219:أخرجه ابن جرير ٥/١١٧. وعلَّقه ابن أبي حاتم ٢/٥٦٧.|220:أخرجه ابن جرير ٥/٩٥، ١١٥، وابن المنذر ١/٧٨، وابن أبي حاتم ٢/٥٦٣، والبيهقي في سننه ١٠/١٦١.|221:أخرجه ابن جرير ٥/١١٥.|222:أخرجه ابن جرير ٥/١١٤، وابن المنذر (١٣٦)، وابن أبي حاتم ٢/٥٦٧ واللفظ له، والبيهقي في سُنَنه ١٠/١٦٠. وعزاه السيوطي إلى عبد بن حميد.|223:علَّقه ابن أبي حاتم ٢/٥٦٧.|224:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٦٩-. وعلَّقه ابن أبي حاتم ٢/٥٦٧.|225:أخرجه عبد الرزاق ١/١١٠.|226:أخرجه ابن جرير ٥/١١٦، وابن المنذر ١/٨٥ بنحوه من طريق جويبر. كما علَّقه ابن أبي حاتم ٢/٥٦٧.|227:أخرجه ابن جرير ٥/٧٧، وابن المنذر بنحوه ١/٨٨. وعلَّقه ابن أبي حاتم ٢/٥٥٦.|228:أخرجه ابن جرير ٥/١١٥، وابن المنذر ١/٨٥ بلفظ: «لا يضار، يقول له: تعال فاشهد، وهو يجد عنه مندوحة». وعلَّق ابن أبي حاتم ٢/٥٦٧ نحوه.|229:علَّقه ابن المنذر ١/٨٥.|230:أخرجه ابن جرير ٥/١١١.|231:أخرجه عبد الرزاق ١/١١١، وابن جرير ٥/١١٧، وابن المنذر ١/٨٦ بنحوه. وعلَّقه ابن أبي حاتم ٢/٥٦٧.|232:أخرجه ابن جرير ٥/١١٢، وابن المنذر ١/٨٧ بنحوه، والبيهقي ١٠/١٦١.|233:أخرجه عبد الرزاق ١/١١١، وابن أبي حاتم ٢/٥٦٧، وابن المنذر ١/٨٧.|234:تفسير ابن أبي زمنين ١/٢٦٩.|235:أخرجه ابن جرير ٥/١١٢.|236:أخرجه عبد الرزاق ١/١١٠، وابن جرير ٥/١١٢، وابن المنذر ١/٨٧، وابن أبي حاتم ٢/٥٦٧.|237:أخرجه ابن جرير ٥/١١٦، وابن أبي حاتم ٢/ ٥٦٧.|238:أخرجه ابن أبي حاتم ٢/٥٦٧.|239:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٢٣-١٢٤ (٢٤٥). وعلَّقه ابن أبي حاتم ٢/٥٦٧.|240:تفسير مقاتل بن سليمان ١/٢٣٠.|241:أخرجه ابن المنذر ١/٨٧. وعلَّقه ابن أبي حاتم ٢/٥٦٧.|242:أخرجه ابن جرير ٥/١١٢.|243:أخرجه ابن المنذر ١/٨٥، والبيهقي في السنن الكبرى ١٠/١٦١.|244:أخرجه ابن جرير ٥/٩٥، ١١٩، وابن المنذر ١/٨٨، وابن أبي حاتم ٢/٥٦٨، والبيهقي في سننه ١٠/١٦١.|245:علَّقه ابن أبي حاتم ٢/٥٦٨.|246:أخرجه ابن أبي حاتم ٢/٥٦٨.|247:أخرجه ابن جرير ٥/١١٨. وعلَّقه ابن أبي حاتم ٢/٥٦٨.|248:أخرجه ابن جرير ٥/١١٩. وعلَّقه ابن أبي حاتم ٢/٥٦٨.|249:تفسير مقاتل بن سليمان ١/٢٣٠.|250:أخرجه ابن أبي حاتم ٢/٥٦٨، وابن المنذر ١/٨٨ من طريق إسحاق، عمّن حدثه، عن مقاتل.|251:علَّقه ابن المنذر ١/٨٨.|252:أخرجه ابن جرير ٥/١١٩.|253:أخرجه ابن أبي حاتم ٢/٥٥٧، ٥٦٨.|254:أخرجه ابن جرير ٥/١٢٠.|255:تفسير مقاتل بن سليمان ١/٢٣٠.|256:أخرجه أبو نعيم في الحلية ١٠/١٥.</p><p>قال أبو نعيم: «ذكر أحمد بن حنبل هذا الكلام عن بعض التابعين، عن عيسى بن مريم ﵇، فوَهِم بعضُ الرواة أنه ذكره عن النبي ﷺ، فوضع هذا الإسناد عليه؛ لسهولته وقربه، وهذا الحديث لا يحتمل بهذا الإسناد عن أحمد بن حنبل». وقال الحافظ العراقي في تخريج أحاديث الإحياء ١/٨٥ (٢): «أخرجه أبو نعيم في الحلية من حديث أنس، وضعَّفه». وقال الألباني في الضعيفة ١/٦١١ (٤٢٢): «موضوع».|257:أخرجه الترمذي ٤/٦١٨ (٢٨٧٨).</p><p>قال الترمذي: «هذا حديث ليس إسناده بمتصل، هو عندي مرسل، ولم يدرك عندي ابن أشوع يزيد بن سلمة». وقال البخاري -كما في علل الترمذي ص٣٤١-: «سعيد بن أشوع لم يسمع عندي من يزيد بن سلمة، وهو عندي حديث مرسل». وقال ابن حجر في الإصابة ٦/٦٦٠: «وهو منقطع كما قال». وقال الألباني في الضعيفة ٤/١٩٠-١٩١ (١٦٩٦): «ضعيف».|258:أخرجه الطبراني في الأوسط ٣/٦٤ (٢٤٩٢)، وابن عبد البر في جامع بيان العلم وفضله ١/٤٠١ (٥٨٠).</p><p>قال الطبراني: «لم يرو هذا الحديث عن أبي الزبير إلا ياسين». وقال الهيثمي في المجمع ١/١٣٦ (٥٧٤): «وفيه ياسين الزيات، وهو منكر الحديث». وقال الألباني في الضعيفة ٧/١٨٩ (٣٢٠٥): «إسناد ضعيف جدًّا».|259:عزاه السيوطي إلى ابن أبي الدنيا في كتاب التقوى.|260:عزاه السيوطي إلى أبي يعقوب البغدادي في كتاب رواية الكبار عن الصغار.|261:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٥٧١ (٢٠٧٣٨).