quran[8]{c,v,t}:
16,65," <q>﴿وَٱللَّهُ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَحۡیَا بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۤۚ﴾</q> - تفسير ٤١٥٠٨- قال مقاتل بن سليمان: ثم ذكر صنعه؛ ليعرف توحيده، فقال تعالى: <q>﴿واللَّهُ أنْزَلَ مِنَ السَّماءِ ماءً﴾</q> يعني: المطر، <q>﴿فَأَحْيا بِهِ الأَرْضَ بَعْدَ مَوْتِها﴾</q> بالنبات{1}. (ز) ٤١٥٠٩- قال يحيى بن سلّام: قوله: <q>﴿والله أنزل من السماء ماء فأحيا به الأرض بعد موتها﴾</q> الأرض اليابسة التي ليس فيها نبات، فيحييها بالمطر، وتُنبِتُ بعد إذ لم يكن فيها نبات{2}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَسۡمَعُونَ ۝٦٥﴾</q> - تفسير ٤١٥١٠- قال مقاتل بن سليمان: <q>﴿إنَّ فِي ذلِكَ لَآيَةً﴾</q> يقول: إنّ في المطر والنبات لعبرة وآية <q>﴿لِقَوْمٍ يَسْمَعُونَ﴾</q> المواعظ{1}. (ز) ٤١٥١١- قال يحيى بن سلّام: قوله: <q>﴿إن في ذلك لآية لقوم يسمعون﴾</q>، فيعلمون أنّ الذي أحيا هذه الأرض الميتة حتى أنبتت قادرٌ على أن يحيي الموتى؛ لأنّ المشركين لا يُقِرّون بالبعث{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.
16,66," <q>﴿وَإِنَّ لَكُمۡ فِی ٱلۡأَنۡعَـٰمِ لَعِبۡرَةࣰۖ نُّسۡقِیكُم مِّمَّا فِی بُطُونِهِۦ مِنۢ بَیۡنِ فَرۡثࣲ وَدَمࣲ لَّبَنًا خَالِصࣰا﴾</q> - تفسير ٤١٥١٢- قال عبد الله بن عباس: إذا أكلت الدابة العلف، واستقر في كرشها، وطحنته، فكان أسفله فرثًا، وأوسطه اللبن، وأعلاه الدم، والكبد مسلطة عليها، تقسمها بتقدير الله تعالى، فيجري الدم في العروق، واللبن في الضرع، ويبقى الفرث كما هو{1}. (ز) ٤١٥١٣- عن محمد بن سيرين: أن عبد الله بن عباس شَرِب لَبَنًا، فقال له مُطَرِّفٌ: ألا تَمَضْمَضْتَ؟ فقال: ما أُباليه بالَةً{2}، اِسمَحْ يُسْمَحْ لك{3}. فقال قائلٌ: إنه يخرُجُ مِن بين فَرْثٍ ودمٍ. قال ابن عباس: وقد قال الله: <q>﴿لبنًا خالصًا سائغًا للشاربين﴾</q>{4}. (٩/٦٨) ٤١٥١٤- قال مقاتل بن سليمان: <q>﴿وإنَّ لَكُمْ فِي الأَنْعامِ لَعِبْرَةً﴾</q> يعني: التفكر، <q>﴿نُسْقِيكُمْ مِمّا فِي بُطُونِهِ مِن بَيْنِ فَرْثٍ ودَمٍ لَبَنًا خالِصًا﴾</q> من القَذَر{5}٣٦٩٦. (ز) ٣٦٩٦ ذكر ابنُ عطية (٥/٣٧٧-٣٧٨) في عود الضمير من قوله: <q>﴿مما في بطونه﴾</q> عدة أقوال، فقال: "وقوله: <q>﴿مِمّا فِي بُطُونِهِ﴾</q> الضمير عائد على الجنس، وعلى المذكور، كما قال الشاعر: مثل الفراخ نتفت حواصله وهذا كثير، لقوله تعالى: <q>﴿إنَّ هذِهِ تَذْكِرَةٌ﴾</q> [الإنسان:٢٩]، <q>﴿فَمَن شاءَ ذَكَرَهُ﴾</q> [المدثر:٥٥]. وقيل: إنما قال: <q>﴿مِمّا فِي بُطُونِهِ﴾</q> لأن الأنعام والنعم واحد فرد، والضمير على معنى: النعم. وقالت فرقة: الضمير عائد على البعض، إذ الذكور لا ألبان لها، فكأن العبرة إنما هي في بعض الأنعام". وذكر ابنُ كثير (٨/٣٢٣) في عود الضمير قولين، وعلّق عليهما، فقال: «وأفرد هاهنا الضمير عودًا على معنى: النعم، أو الضمير عائد على الحيوان؛ فإن الأنعام حيوانات، أي: نسقيكم مما في بطن هذا الحيوان، وفي الآية الأخرى: <q>﴿مما في بطونها﴾</q> [المؤمنون:٢١]، ويجوز هذا وهذا، كما في قوله تعالى: <q>﴿كلا إنه تذكرة فمن شاء ذكره﴾</q> [المدثر:٥٤-٥٥]، وفي قوله تعالى: <q>﴿وإني مرسلة إليهم بهدية فناظرة بم يرجع المرسلون فلما جاء سليمان﴾</q> [النمل:٣٥-٣٦] أي: المال». <q>﴿سَاۤىِٕغࣰا لِّلشَّـٰرِبِینَ ۝٦٦﴾</q> - تفسير ٤١٥١٥- عن يحيى بن عبد الرحمن بن أبي لَبِيبَةَ، عن أبيه، عن جدِّه، أن رسولَ الله ﷺ قال: «ما شرِب أحدٌ لبنًا فشَرِقَ؛ إن اللهَ يقول: <q>﴿لبنًا خالصًا سآئغًا للشاربين﴾</q>»{6}. (٩/٦٨) ٤١٥١٦- قال مقاتل بن سليمان: <q>﴿سائِغًا لِلشّارِبِينَ﴾</q> يسيغ مَن يشربه، وهو لا يسيغ الفرث والدم{5}. (ز) ٤١٥١٧- قال يحيى بن سلّام: قوله: <q>﴿وإن لكم في الأنعام لعبرة نسقيكم مما في بطونه من بين فرث ودم لبنا خالصا سائغا للشاربين﴾</q>، يقول: ففي هذا اللبن الذي أخرجه الله من بين فرث ودم آية لقوم يعقلون، فيعلمون أن الذي أخرجه من بين فرث ودم قادر على أن يحيي الموتى{8}. (ز) ",footnotes:1:تفسير الثعلبي ٦/٢٧، وتفسير البغوي ٥/٢٨.ما أباليه بالة: ما أكترث له. الصحاح (بلي).اسْمَحْ يُسْمَحْ لك: سَهِّل يُسَهَّل عليك. النهاية (سمح).أخرجه عبد الرزاق (٦٨٦). وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٥.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.
16,67," <q>﴿وَمِن ثَمَرَ ٰ⁠تِ ٱلنَّخِیلِ وَٱلۡأَعۡنَـٰبِ تَتَّخِذُونَ مِنۡهُ سَكَرࣰا وَرِزۡقًا حَسَنًاۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</q> - نزول الآية ٤١٥١٨- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق مغيرة- في الآية، قال: نزَل هذا وهم يَشرَبون الخمر قبلَ أن يَنزِلَ تحريمُها{1}. (٩/٦٩) ٤١٥١٩- عن قتادة بن دعامة -من طريق همام، وعثمان- قال: نزلت قبل تحريم الخمر{2}. (ز) ٤١٥٢٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</q>: ونزلت هذه الآية ولم تُحَرَّم الخمر يومئذ، وإنما جاء تحريمها بعد ذلك في سورة المائدة{3}. (ز) <q>﴿وَمِن ثَمَرَ ٰ⁠تِ ٱلنَّخِیلِ وَٱلۡأَعۡنَـٰبِ تَتَّخِذُونَ مِنۡهُ سَكَرࣰا وَرِزۡقًا حَسَنًاۚ﴾</q> - تفسير ٤١٥٢١- عن عبد الله بن مسعود -من طريق مُرة- قال: السَّكَرُ خمرٌ{4}. (٩/٧١) ٤١٥٢٢- وعن سعيد بن جبير -من طريق سالم-= (ز) ٤١٥٢٣- والحسن البصري -من طريق يونس-= (ز) ٤١٥٢٤- وعامر الشعبي -من طريق مُغيرة-= (ز) ٤١٥٢٥- وإبراهيم النخعي -من طريق مُغيرة-= (ز) ٤١٥٢٦- وأبي رَزِين [مسعود بن مالك الأسدي] -من طريق مُغيرة-، مثله{5}. (٩/٧١) ٤١٥٢٧- عن عبد الله بن عباس -من طريق عمرو بن سفيان- أنّه سُئِل عن قوله: <q>﴿تتخذون منه سكرًا ورزقًا حسنًا﴾</q>. قال: السكر: ما حرم من ثمرتها. والرزقُ الحسنُ: ما حَلَّ مِن ثمرتها{6}. (٩/٦٩) ٤١٥٢٨- عن عبد الله بن عباس، في الآية، قال: السَّكَرُ: الخَلُّ، والنبيذ، وما أشْبَهَه. والرزقُ الحسَنُ: التمرُ، والزبيبُ، وما أشْبَهَه{7}. (٩/٧٠) ٤١٥٢٩- عن عبد الله بن عباس، في الآية، قال: السَّكَرُ: الحرامُ منه. والرزقُ الحَسَنُ: زَبِيبُه، وخَلُّه، وعنبُه، ومنافعُه{8}. (٩/٦٩) ٤١٥٣٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿تتخذون منه سكرًا ورزقًا حسنًا﴾</q>، قال: فحَرَّم اللهُ بعدَ ذلك السَّكَرَ مع تحريم الخمر؛ لأنه منه، ثم قال: <q>﴿ورزقًا حسنًا﴾</q> فهو الحلالُ مِن الخَلِّ، والزبيبِ، والنبيذ، وأشْباهِ ذلك، فأقَرَّه اللهُ، وجعَله حلالًا للمسلمين{9}. (٩/٧٠) ٤١٥٣١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿تتخذون منه سكرًا﴾</q>، قال: إن الناسَ كانوا يُسَمُّون الخمرَ: سَكَرًا، وكانوا يشرَبونها، ثم سَمّاها اللهُ بعدَ ذلك: الخمرَ، حين حُرِّمَت. وكان ابن عباس يزعُمُ أن الحبشة يُسَمُّون الخلَّ: السَّكَرَ. وقوله: <q>﴿ورزقًا حسنًا﴾</q>، يعني: بذلك الحلالَ؛ التمرَ، والزبيبَ، وما كان حلالًا لا يُسْكِر{10}. (٩/٧٠) ٤١٥٣٢- عن عبد الله بن عمر -من طريق سعيد بن جبير- أنه سُئِل عن السَّكَرِ. فقال: الخمرُ بعينِها{11}. (٩/٧٠) ٤١٥٣٣- عن عبد الرحمن بن أبي ليلى -من طريق أبي فروة- قال: السَّكَرُ: خمر{12}. (ز) ٤١٥٣٤- عن سعيد بن جبير -من طريق أبي حصين- قال: السَّكَرُ الحرامُ، والرزقُ الحسنُ الحلال{13}. (٩/٧١) ٤١٥٣٥- عن مجاهد بن جبر -من طريق أبي كدينة، عن ليث- قال: السَّكَرُ: الخمر. والرزق الحسن: الرطب، والأعناب{14}. (ز) ٤١٥٣٦- عن مجاهد بن جبر -من طريق مندل، عن ليث- <q>﴿تتخذون منه سكرا ورزقا حسنا﴾</q>، قال: ما كانوا يتخذون من النخل النبيذ، والرزق الحسن: ما كانوا يصنعون من الزبيب والتمر{15}. (ز) ٤١٥٣٧- عن مجاهد بن جبر -من طريق ابن مجاهد- <q>﴿تتخذون منه سكرا﴾</q>، قال: هي الخمر قبل أن تحرم، <q>﴿ورزقا حسنا﴾</q> طعامًا{16}. (ز) ٤١٥٣٨- عن عبيد، قال: سمعت الضحاك بن مزاحم يقول في قوله: <q>﴿تتخذون منه سكرا﴾</q>: يعني: ما أسكر من العنب والتمر، <q>﴿ورزقا حسنا﴾</q> يعني: ثمرتها{17}. (ز) ٤١٥٣٩- عن أبي روق، قال: قلت للشعبي: أرأيت قوله تعالى: <q>﴿تتخذون منه سكرا﴾</q>، أهو هذا السَّكَرُ الذي تصنعه النبَط؟ قال: لا، هذا خمر، إنما السَّكَرُ الذي قال الله -تعالى ذكره-: النبيذ، والخل. والرزق الحسن: التمر، والزبيب{17}. (ز) ٤١٥٤٠- قال عامر الشعبي: السَّكَرُ: ما شربت. والرزق الحسن: ما أكلت{19}. (ز) ٤١٥٤١- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿تتخذون منه سكرًا﴾</q>، قال: ذَكَر الله نعمته في السَّكَر قبل تحريم الخمر{20}. (٩/٧١) ٤١٥٤٢- عن الحسن البصري -من طريق منصور، وعوف- قال: السَّكَرُ: ما حرم الله منه. والرزق: ما أحل الله منه{21}. (ز) ٤١٥٤٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</q>: أما السكر: فخمور هذه الأعاجم. وأما الرزق الحسن: فما تنتبذون، وما تُخلِّلون، وما تأكلون{22}. (٩/٧١) (ز) ٤١٥٤٤- عن منصور بن المعتمر -من طريق هشيم- قال: السَّكَرُ: ما حرم الله منه. والرزق: ما أحل الله منه{21}. (ز) ٤١٥٤٥- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿سكرا ورزقا حسنا﴾</q>، قال: السَّكَرُ: النبيذ. قال: والرزق الحسن: الزبيب{24}. (ز) ٤١٥٤٦- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿ومِن ثَمَراتِ النَّخِيلِ والأَعْنابِ تَتَّخِذُونَ مِنهُ سَكَرًا﴾</q> يعني بالثمرات: لأنها جماعة ثمر. يعني بالسكر: ما حرم من الشراب مما يسكرون من ثمره، يعني: النخيل والأعناب، <q>﴿ورِزْقًا حَسَنًا﴾</q> يعني: طيبًا -نسختها الآية التي في المائدة، كقوله ﷿: <q>﴿قَرْضًا حَسَنًا﴾</q> [البقرة:٢٤٥]، يعني: طيبة بها أنفسهم- بما لا يسكر منها من الشراب وثمرتها؛ فهذا الرزق الحسن{25}. (ز) ٤١٥٤٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تتخذون منه سكرا ورزقا حسنا﴾</q>، قال: الحلال: ما كان على وجه الحلال، حتى غيَّروها، فجعلوا منها سكرًا{17}. (ز) ٤١٥٤٨- قال يحيى بن سلّام: قوله: <q>﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</q>، أي: وجعل لكم من ثمرات النخيل والأعناب ما تتخذون منه سكرًا، ورزقًا حسنًا{27}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</q> - تفسير ٤١٥٤٩- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿إنَّ فِي ذلِكَ لَآيَةً لِقَوْمٍ يَعْقِلُونَ﴾</q>، يعني: فيما ذُكِر من اللبن والثمار لعبرة لقوم يعقلون بتوحيد الله ﷿{25}. (ز) ٤١٥٥٠- قال يحيى بن سلّام: قوله: <q>﴿إن في ذلك لآية لقوم يعقلون﴾</q> هي مثل الأولى{29}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</q> - النسخ في الآية ٤١٥٥١- عن عبد الله بن مسعود= (ز) ٤١٥٥٢- وعبد الله بن عمر= (ز) ٤١٥٥٣- وسعيد بن جبير= (ز) ٤١٥٥٤- ومجاهد بن جبر، قالوا: وهذا قبل تحريم الخمر{19}. (ز) ٤١٥٥٥- عن عبد الله بن عباس، في الآية، قال: السَّكَرُ: النَّبيذُ. والرزقُ الحسنُ: الزَّبيبُ. فنسَخَتْها هذه الآية: <q>﴿إنما الخمر والميسر﴾</q> [المائدة:٩٠]{31}. (٩/٦٩) ٤١٥٥٦- عن إبراهيم النخعي= (ز) ٤١٥٥٧- وعامر الشعبي -من طريق مغيرة- في قوله: <q>﴿تتخذون منه سكرًا﴾</q>، قالا: هي منسوخة{32}. (٩/٧١) ٤١٥٥٨- عن عبد الرحمن بن أبي ليلى= (ز) ٤١٥٥٩- وإبراهيم النخعي= (ز) ٤١٥٦٠- وأيوب [السختياني]= (ز) ٤١٥٦١- ومحمد بن السائب الكلبي، قالوا: وهذا قبل تحريم الخمر{33}. (ز) ٤١٥٦٢- تفسير مجاهد بن جبر -من طريق ابن مجاهد-: <q>﴿سكرا﴾</q> الخمر قبل تحريمها{34}. (ز) ٤١٥٦٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿تتخذون منه سكرًا﴾</q>، قال: خُمُورَ الأعاجم، ونُسِخت في سورة المائدة{35}. (٩/٧١) ٤١٥٦٤- قال مقاتل بن سليمان: <q>﴿تتخذون منه سكرًا ورِزْقًا حَسَنًا﴾</q>، نسختها الآية التي في المائدة{36}{25}٣٦٩٧. (ز) ٣٦٩٧ اختلف السلف في تفسير قوله: <q>﴿تتخذون منه سكرا ورزقا حسنا﴾</q> على أقوال: الأول: عنى بالسكر: الخمر. وبالرزق الحسن: التمر والزبيب. وقال أصحاب هذا القول: إنما نزلت هذه الآية قبل تحريم الخمر، ثم حرمت بعد. الثاني: السكر بمنزلة الخمر في التحريم، وليس بخمر، وقالوا: هو نقيع التمر والزبيب إذا اشتد وصار يسكر شاربه. الثالث: السكر: هو كل ما كان حلالًا شربه؛ كالنبيذ الحلال، والخل، والرطب. والرزق الحسن: التمر، والزبيب. وقد علّق ابنُ جرير (١٤/٢٨٤-٢٨٥ بتصرف) على القول الثالث بقوله: «وعلى هذا التأويل الآية غير منسوخة، بل حكمها ثابت». ثم رجّحه، ورجّح عدم النسخ في الآية، وانتقد بقية الأقوال مستندًا إلى لغة العرب، وعدم وجود دليل على النسخ، وقال: «وذلك أن السكر في كلام العرب على أحد أوجه أربعة: أحدها: ما أسكر من الشراب. والثاني: ما طعم من الطعام. والثالث: السكون. والرابع: المصدر من قولهم: سكر فلان يسكر سُكْرًا وسَكْرًا وسَكَرًا، فإذا كان ذلك كذلك، وكان ما يسكر من الشراب حرامًا، وكان غير جائز لنا أن نقول: هو منسوخ، إذ كان المنسوخ هو ما نفى حكمه الناسخ، وما لا يجوز اجتماع الحكم به وناسخه، ولم يكن في حكم الله -تعالى ذكره- بتحريم الخمر دليل على أن السكر الذي هو غير الخمر وغير ما يسكر من الشراب حرام، إذ كان السكر أحد معانيه عند العرب، ومن نزل بلسانه القرآن هو كل ما طعم، ولم يكن مع ذلك، إذ لم يكن في نفس التنزيل دليل على أنه منسوخ، أو ورد بأنه منسوخ خبر من الرسول، ولا أجمعت عليه الأمة؛ فوجب القول بما قلنا من أن معنى السكر في هذا الموضع: هو كل ما حل شربه مما يتخذ من ثمر النخل والكرم، وفسد أن يكون معناه: الخمر، أو ما يسكر من الشراب، وخرج من أن يكون معناه: السكر نفسه؛ إذ كان السكر ليس مما يتخذ من النخل والكرم، ومن أن يكون بمعنى السكون». وقال ابنُ عطية (٥/٣٧٩): «والسكر: ما يسكر. هذا هو المشهور في اللغة». وانتقد دعوى النسخ، فقال: «وقال بعض الفرقة التي رأت السكر الخمر: إنّ هذه الآية منسوخة بتحريم الخمر. وفي هذه المقالة درك؛ لأن النسخ إنما يكون في حكم مستقر مشروع». <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</q> - آثار متعلقة بالآية ٤١٥٦٥- عن أبي هريرة، قال: قال رسول ﷺ: «لكم في العنبِ أشياءُ؛ تأكُلون عنبًا، وتشرَبونه عصيرًا ما لم يَنِشَّ{38}، وتتخِذون منه زَبِيبًا، ورُبًّا{39}»{40}. (٩/٧١) ٤١٥٦٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «إن الخمر من هاتين الشجرتين: النخلة، والعنبة»{41}. (ز) ٤١٥٦٧- عن أبي بردة بن أبي موسى الأشعري، قال: قال عمر بن الخطاب: إنّ هذه الأنبذة تنبذ من خمسة أشياء: من التمر، والزبيب، والعسل، والبر، والشعير، فما خمَّرتم منه فعتقتم فهو خمر{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٧٨. وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه يحيى بن سلام ١/٧٣.أخرجه عبد الرزاق في تفسيره ٢/٣٥٧ بلفظ: ونسخت في سورة المائدة، وابن جرير ١٤/٢٨٠، والنحاس في ناسخه ٢/٤٨٦ بنحوه.أخرجه ابن أبي شيبة ٢٠/٤٨٧، وابن جرير ١٤/٢٨٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٧/٤٨٧.أخرجه يحيى بن سلام ١/٧٣، وعبد الرزاق ١/٣٥٧، وأبي داود -كما في تغليق التعليق ٤/٢٣٧، وفتح الباري ٨/٣٨٧-، وابن جرير ١٤/٢٧٥-٢٧٨، والنحاس ص٤٥٢، والحاكم ٢/٣٥٥، والبيهقي في سننه ٨/٢٩٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وأبو داود في ناسخه، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى الفريابي، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٤/٢٨٢، والبيهقي ٨/٢٩٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨١ بنحوه. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ٧/٤٨٨ بلفظ: أنه سئل عن السكر؟ فقال: الخمر ليس لها كنية. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨٢.أخرجه النسائي في الكبرى (٦٧٨٩).أخرجه ابن جرير ١٤/٢٨٠.أخرجه ابن جرير ١٤/٢٨٤.أخرجه يحيى بن سلام ١/٧٢، وأخرج أوله ابن جرير ١٤/٢٨٠ من طريق ليث.أخرجه ابن جرير ١٤/٢٨٣.أخرجه ابن جرير ١٤/٢٨٣.تفسير الثعلبي ٦/٢٧، وتفسير البغوي ٥/٢٨.أخرجه ابن جرير ١٤/٢٧٩. وعزاه السيوطي إلى ابن المنذر بلفظ: ذكَر اللهُ نعمتَه عليهم في الخمرِ قبلَ أن يُحَرِّمَها عليهم.أخرجه ابن جرير ١٤/٢٧٩.أخرجه ابن جرير ١٤/٢٨٠، والنحاس في ناسخه (ت: اللاحم) ٢/٤٨٦ بنحوه. كذلك أخرجه يحيى بن سلام نحوه ١/٧٣ من طريق همام وعثمان، وعبد الرزاق في تفسيره ٢/٣٥٧ بنحوه من طريق معمر.أخرجه ابن جرير ١٤/٢٧٩.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء الخراساني) ص٩٦.تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن جرير ١٤/٢٨٣.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٣.تفسير الثعلبي ٦/٢٧، وتفسير البغوي ٥/٢٨.عزاه السيوطي إلى أبي داود في ناسخه، وابن المنذر، وابن أبي حاتم.أخرجه البيهقي ٨/٢٩٧. وعزاه السيوطي إلى ابن الأنباري.تفسير الثعلبي ٦/٢٧.علَّقه يحيى بن سلام ١/٧٢.أخرجه عبد الرزاق ١/٣٥٧ من طريق معمر، والنحاس ص٥٤٢. وعزاه السيوطي إلى ابن الأنباري في المصاحف.يشير إلى قوله تعالى: <q>﴿يا أيُّها الَّذِينَ آمَنُوا إنَّما الخَمْرُ والمَيْسِرُ والأَنْصابُ والأَزْلامُ رِجْسٌ مِن عَمَلِ الشَّيْطانِ فاجْتَنِبُوهُ لَعَلَّكُمْ تُفْلِحُونَ. إنَّما يُرِيدُ الشَّيْطانُ أنْ يُوقِعَ بَيْنَكُمُ العَداوَةَ والبَغْضاءَ فِي الخَمْرِ والمَيْسِرِ ويَصُدَّكُمْ عَنْ ذِكْرِ اللَّهِ وعَنِ الصَّلاةِ فَهَلْ أنْتُمْ مُنْتَهُونَ﴾</q> [المائدة:٩٠-٩١].تفسير مقاتل بن سليمان ٢/٤٧٦.النَّشِيش: أول أخْذ العصير في الغليان، والخمر تَنِشُّ إذا أخذت في الغليان. لسان العرب (نشش).ارتب العنب: إذا طبخ حتى يكون رُبًّا يؤتدم به. اللسان (ربب).أخرجه العقيلي في الضعفاء ١/٩٣ (١٠٥) في ترجمة إسماعيل بن مسلم اليشكري، والخطيب في تاريخ بغداد ٢/١٠٦ (١٨٢). قال العقيلي: «إسماعيل بن مسلم اليشكري عن ابن عون لا يعرف بنقل الحديث، وحديثه منكر غير محفوظ». وقال السيوطي في اللآلئ المصنوعة ٢/١٧٨: «لا يصح». وقال ابن عراق الكناني في تنزيه الشريعة ٢/٢٣٥: «ولا يصح».أخرجه مسلم ٣/١٥٧٣ (١٩٨٥)، ويحيى بن سلام ١/٧٣. وأورده الثعلبي ٢/١٤٤.أخرجه يحيى بن سلام ١/٧٣.
16,68," <q>﴿وَأَوۡحَىٰ رَبُّكَ إِلَى ٱلنَّحۡلِ﴾</q> - تفسير ٤١٥٦٨- عن عبد الله بن عباس، في قوله: <q>﴿وأوحى ربُّك إلى النحل﴾</q>، قال: ألْهَمَها{1}. (٩/٧٢) ٤١٥٦٩- عن عبد الله بن عباس -من طريق العَوْفي- في قوله: <q>﴿وأوحى ربك إلى النحل﴾</q>، قال: أمَرها أن تأكُلَ مِن كلِّ الثمرات، وأمَرَها أن تَتَّبِعَ سُبُلَ ربِّها ذُلُلًا{2}. (٩/٧٢) ٤١٥٧٠- عن مجاهد بن جبر -من طريق ابن أبي الصباح، عن رجل- في قوله: <q>﴿وأوحى ربك إلى النحل﴾</q>، قال: ألْهَمَها إلهامًا{3}. (٩/٧٢) ٤١٥٧١- عن الضحاك بن مزاحم، في قوله: <q>﴿وأوحى ربك إلى النحل﴾</q>، قال: ألْهَمَها إلهامًا، ولم يُرسِلْ إليها رسولًا{4}. (٩/٧٢) ٤١٥٧٢- عن الحسن البصري، قال: النحلُ دابةٌ أصغرُ مِن الجُندُب، ووَحْيُه إليها قَذْفٌ في قلوبِها{1}. (٩/٧٢) ٤١٥٧٣- قال الحسن البصري، في قول الله: <q>﴿وأوحى ربك إلى النحل﴾</q>، وقوله: <q>﴿وإذ أوحيت إلى الحواريين﴾</q> [المائدة:١١١]، <q>﴿وأوحينا إلى أم موسى﴾</q> [القصص:٧]: إلهام ألْهَمَهُم{6}. (ز) ٤١٥٧٤- قال إسماعيل السُّدِّيّ: وكل شيء من الحيوان إلهام{7}. (ز) ٤١٥٧٥- عن محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿وأوحى ربك إلى النحل﴾</q>، قال: قذف في أنفسها{8}. (ز) ٤١٥٧٦- قال مقاتل بن سليمان: ثم قال: <q>﴿وأَوْحى رَبُّكَ إلى النَّحْلِ﴾</q> إلهامًا من الله ﷿، يقول: قذف فيها{9}. (ز) ٤١٥٧٧- قال يحيى بن سلّام: قوله: <q>﴿وأوحى ربك إلى النحل﴾</q>، أي: ألهمها{10}٣٦٩٨. (ز) ٣٦٩٨ ذكر ابنُ عطية (٥/٣٧٩) عدة معانٍ للوحي، ثم بيَّن أن الوحي في هذه الآية هو وحي الإلهام باتفاق المتأولين. <q>﴿أَنِ ٱتَّخِذِی مِنَ ٱلۡجِبَالِ بُیُوتࣰا وَمِنَ ٱلشَّجَرِ وَمِمَّا یَعۡرِشُونَ ۝٦٨﴾</q> - تفسير ٤١٥٧٨- قال مقاتل بن سليمان: <q>﴿أنِ اتَّخِذِي مِنَ الجِبالِ بُيُوتًا ومِنَ الشَّجَرِ ومِمّا يَعْرِشُونَ﴾</q>، يعني: ومما يبنون من البيوت{9}. (ز) ٤١٥٧٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يعرشون﴾</q>، قال: الكَرْمُ{12}٣٦٩٩. (ز) ٣٦٩٩ بيّن ابنُ جرير (١٤/٢٨٦-٢٨٧) أن قوله: <q>﴿مما يعرشون﴾</q> معناه: ما يبنون من السقوف. وذكر قول ابن زيد، ولم يعلق عليه. ورجّح ابنُ عطية (٥/٣٧٩-٣٨٠) أن عَرَشَ معناه: هيَّأ، وأكثر ما يستعمل فيما يكون من اتفاق الأغصان والخشب وترتيب ظلالها، ومنه العريش الذي صُنع لرسول الله ﷺ يوم بدر، ومن هذا هي لفظة العرش«. ثم ذكر ابن عطية قول ابن زيد، وقول ابن جرير أن يعرشون معناه: ما يبنون من السقوف. وانتقدهما، فقال:»وهذا منهما تفسير غير متقن". ولم يذكر مستندًا. ٤١٥٨٠- قال يحيى بن سلّام: <q>﴿أن اتخذي من الجبال بيوتا ومن الشجر ومما يعرشون﴾</q>، أي: ومما يبنون{10}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.جامع ابن وهب -تفسير القرآن ٢/٥٣-٥٤ (١٠٣).علَّقه يحيى بن سلام ١/٧٣.أخرجه عبد الرزاق في تفسيره ٢/٣٥٧، وابن جرير ١٤/٢٨٦ وأبهمه قائلًا: عن معمر عن أصحابه.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٣.تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن جرير ١٤/٢٨٧.تفسير يحيى بن سلام ١/٧٣.
16,69," <q>﴿ثُمَّ كُلِی مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ فَٱسۡلُكِی﴾</q> - تفسير ٤١٥٨١- قال مقاتل بن سليمان: <q>﴿ثُمَّ كُلِي مِن كُلِّ الثَّمَراتِ فاسْلُكِي﴾</q>، يقول: فادخلي{1}. (ز) <q>﴿سُبُلَ رَبِّكِ ذُلُلࣰاۚ﴾</q> - تفسير ٤١٥٨٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فاسلُكي سبل ربك ذللًا﴾</q>، قال: طُرُقًا، لا يَتَوعَّرُ عليها مكانٌ سَلَكَتْه{2}. (٩/٧٣) ٤١٥٨٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فاسلكي سبل ربك ذللًا﴾</q>، قال: مُطِيعةً{3}٣٧٠٠. (٩/٧٣) ٣٧٠٠ ذكر ابن كثير (٨/٣٢٥) قول قتادة ونحوه عن ابن زيد، وعلّق عليه، فقال: «وقال قتادة، وعبد الرحمن بن زيد بن أسلم: <q>﴿فاسلكي سبل ربك ذللا﴾</q> أي: مطيعة. فجعلاه حالًا من السالكة». ٤١٥٨٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فاسلكي سبل ربك ذللًا﴾</q>، قال: ذَلِيلةً لذلك{4}. (٩/٧٣) ٤١٥٨٥- قال مقاتل بن سليمان: <q>﴿سُبُلَ رَبِّكِ﴾</q> في الجبال، وخلل الشجر، <q>﴿ذُلُلًا﴾</q> لأن الله تعالى ذلَّل لها طرقها حيثما توجهت{1}. (ز) ٤١٥٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في الآية، قال: الذَّلُولُ الذي يُقادُ ويُذْهَبُ به حيثُ أراد صاحبُه. قال: فهم يَخْرُجون بالنحل، ويَنتَجِعون{6} بها، ويذهَبون وهي تَتْبَعُهم. وقرأ: <q>﴿أولم يروا أنا خلقنا لهم مما عملت أيدينا أنعامًا فهم لها مالكون * وذللناها لهم﴾</q> الآية [يس:٧١-٧٢]{7}. (٩/٧٣) ٤١٥٨٧- قال سعيد: سمعت سفيان [بن عيينة] يقول في قوله: <q>﴿فاسلكي سبل ربك ذللا﴾</q>، قال: ليس يُعْيِيها جبل ولا غيره{8}٣٧٠١. (ز) ٣٧٠١ في قوله تعالى: <q>﴿ذللا﴾</q> قولان: الأول: مذللة لك. الثاني: مطيعة. وقد ذكر ابن جرير (١٤/٢٨٨) القولين، وعلَّق على الأول وهو قول مجاهد ومن وافقه، فقال: «وعلى هذا التأويل الذي تأوله مجاهد الذلل من نعت السبل. والتأويل على قوله: <q>﴿فاسلكي سبل ربك ذللا﴾</q> الذلل لك: لا يتوعر عليك سبيل سلكتيه، ثم أسقطت الألف واللام فنصب على الحال». وعلَّق على الثاني، فقال: «فعلى هذا القول الذلل من نعت النحل». وعلَّق على القولين، فقال: «وكلا القولين غير بعيد من الصواب في الصحة؛ وجهان مخرجان». ثم رجّح مستندًا إلى اللغة القول الأول، فقال: «غير أنا اخترنا أن يكون نعتًا للسبل؛ لأنها إليها أقرب». أي: في الذِّكر. ووافقه ابنُ كثير (٨/٣٢٥) بقوله: «والقول الأول أظهر، وهو أنه حال من الطريق، أي: فاسلكيها مذللة لك. نص عليه مجاهد». ٤١٥٨٨- قال يحيى بن سلّام: <q>﴿ثم كلي من كل الثمرات فاسلكي سبل ربك﴾</q> طرق ربك التي جعل الله لك{9}. (ز) <q>﴿یَخۡرُجُ مِنۢ بُطُونِهَا شَرَابࣱ مُّخۡتَلِفٌ أَلۡوَ ٰ⁠نُهُۥ﴾</q> - تفسير ٤١٥٨٩- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿يخرج من بطونها شرابٌ مختلفٌ ألوانه فيه شفاء للناس﴾</q>، يعني: العسل{10}. (٩/٧٣) ٤١٥٩٠- عن إسماعيل السُّدِّيّ، وفي قوله: <q>﴿يخرج من بطونها شرابٌ مختلفٌ ألوانه﴾</q>، قال: هذا العسلُ{4}. (٩/٧٣) ٤١٥٩١- قال مقاتل بن سليمان: <q>﴿يَخْرُجُ مِن بُطُونِها شَرابٌ﴾</q> يعني: عملًا{12}، <q>﴿مُخْتَلِفٌ ألْوانُهُ﴾</q> أبيض وأصفر، وأحمر{1}. (ز) ٤١٥٩٢- قال يحيى بن سلّام: <q>﴿يخرج من بطونها شراب﴾</q> يعني: العسل، <q>﴿مختلف ألوانه﴾</q>{9}. (ز) <q>﴿فِیهِ شِفَاۤءࣱ لِّلنَّاسِۚ﴾</q> - تفسير ٤١٥٩٣- عن نافع: أن عبد الله بن عمر كان لا يشكُو قُرْحَةً ولا شيئًا إلا جعَل عليه عسَلًا، حتى الدُّمَّلَ إذا كان به طَلاه عسَلًا، فقلنا له: تُداوِي الدُّمَّلَ بالعسل؟ فقال: أليس يقولُ الله: <q>﴿فيه شفاءٌ للناس﴾</q>؟{15}٣٧٠٢. (٩/٧٥) ٣٧٠٢ قال ابنُ عطية (٥/٣٨١): «وقوله: <q>﴿فِيهِ شِفاءٌ لِلنّاسِ﴾</q> الضمير للعسل، قاله الجمهور، ولا يقتضي العموم في كل علة، وفي كل إنسان، بل هو خبر عن أنه يشفي كما يشفي غيره من الأدوية في بعض، وعلى حال دون حال، ففي الآية إخبار منبه على أنه دواء لمّا كَثُرَ الشفاء به، وصار خليطًا ومعينًا للأدوية والأشربة والمعاجين». ثم ذكر هذا الأثر عن ابن عمر، وعلّق عليه بقوله: «وهذا يقتضي أنه يرى الشفاء به على العموم». ٤١٥٩٤- عن مجاهد بن جبر -من طريق ليث- <q>﴿فيه شفاء للناس﴾</q>، قال: في القرآن شفاء{16}. (ز) ٤١٥٩٥- عن مجاهد بن جبر، في قوله: <q>﴿شراب مختلف ألوانه فيه شفاء للناس﴾</q>، قال: هو العسلُ فيه الشِّفاءُ، وفي القرآن{17}. (٩/٧٤) ٤١٥٩٦- عن الضحاك بن مزاحم -من طريق ثابت- في قوله: <q>﴿يخرج من بطونها شراب مختلف ألوانه فيه شفاء للناس﴾</q>، قال: يعني: القرآن{18}. (ز) ٤١٥٩٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يخرج من بطونها شراب مختلف ألوانه، فيه شفاء للناس﴾</q>: ففيه شفاء -كما قال الله تعالى- من الأدواء، وقد كان ينهى عن تغريق النحل، وعن قتلها{19}. (ز) ٤١٥٩٨- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿يخرج من بطونها شرابٌ مختلفٌ ألوانه﴾</q> قال: هذا العسلُ، <q>﴿فيه شفاء للناس﴾</q> يقول: فيه شفاءُ الأوجاع التي شِفاؤُها فيه{4}. (٩/٧٣) ٤١٥٩٩- قال مقاتل بن سليمان: <q>﴿فِيهِ شِفاءٌ لِلنّاسِ﴾</q>، يعني: العسل شفاء لبعض الأوجاع{1}. (ز) ٤١٦٠٠- قال يحيى بن سلّام: <q>﴿يخرج من بطونها شراب﴾</q> يعني: العسل، <q>﴿مختلف ألوانه فيه شفاء للناس﴾</q> دواء{9}٣٧٠٣. (ز) ٣٧٠٣ اختلف السلف فيما عنى الله بقوله: <q>﴿فيه شفاء للناس﴾</q> على قولين: الأول: أنه القرآن. الثاني: أنه العسل. وقد رجّح ابنُ جرير (١٤/٢٩١) القول الثاني مستندًا إلى السياق، وعلل ذلك بقوله: «لأن قوله: <q>﴿فيه﴾</q> في سياق الخبر عن العسل، فأن تكون الهاء من ذكر العسل إذ كانت في سياق الخبر عنه أولى من غيره». وكذا ابنُ كثير (٨/٣٢٦-٣٢٩) مستندًا إلى السنة، وذكر عدة أحاديث في كون العسل شفاء. وبنحوهما ابنُ القيم (٢/١١٣بتصرف)، حيث قال: «الصحيح: رجوع الضمير إلى الشراب، وهو قول ابن مسعود، وابن عباس، والحسن، وقتادة، والأكثرين، فإنه هو المذكور، والكلام سيق لأجله، ولا ذكر للقرآن في الآية، وهذا الحديث الصحيح وهو قوله: «صدق الله» كالصريح فيه». وذكر ابنُ كثير (٨/٣٢٦) القول الأول عن مجاهد، ثم انتقده مستندًا للسياق قائلًا: «وهذا قول صحيح في نفسه، ولكن ليس هو الظاهر هاهنا من سياق الآية؛ فإن الآية إنما ذكر فيها العسل، ولم يتابع مجاهد على قوله هاهنا، وإنما الذي قاله ذكروه في قوله تعالى: <q>﴿وننزل من القرآن ما هو شفاء ورحمة للمؤمنين﴾</q> الآية [الإسراء:٨٢]، وقوله تعالى: <q>﴿يا أيها الناس قد جاءتكم موعظة من ربكم وشفاء لما في الصدور وهدى ورحمة للمؤمنين﴾</q> [يونس:٥٧]». وذكر ابنُ عطية (٥/٣٨١) قولًا ثالثًا، وانتقده مستندًا لدلالة العقل، فقال: «وذهب قوم من أهل الجهالة إلى أن هذه الآية إنما يراد بها: أهل البيت ورجال بني هاشم، وأنهم النحل، وأن الشراب: القرآن والحكمة، وقد ذكر بعضهم هذا في مجلس المنصور أبي جعفر العباسي: فقال له رجل ممن حضر: جعل الله طعامك وشرابك مما يخرج من بطون بني هاشم. فأضحك الحاضرين، وبهت الآخر، وظهرت سخافة قوله». <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٦٩﴾</q> - تفسير ٤١٦٠١- قال مقاتل بن سليمان: <q>﴿إنَّ فِي ذلِكَ لَآيَةً﴾</q> يعني: فيما ذُكِر من أمر النحل وما يخرج من بطونها لَعبرة <q>﴿لِقَوْمٍ يَتَفَكَّرُونَ﴾</q> في توحيد الله ﷿{1}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٦٩﴾</q> - آثار متعلقة بالآية ٤١٦٠٢- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «عليكم بالشِّفاءَين: العسل، والقرآن»{24}. (٩/٧٤) ٤١٦٠٣- عن عبد الله بن مسعود -من طريق الأسود- قال: عليكم بالشِّفاءَين: العسلِ، والقرآن{25}. (٩/٧٤) ٤١٦٠٤- عن عبد الله بن عباس، عن النبيّ ﷺ، قال: «الشفاءُ في ثلاثة: في شَرْطةِ مِحْجَمٍ، أو شَرْبةِ عسل، أو كَيَّةٍ بنار، وأنا أنهى أُمَّتي عن الكَيِّ»{26}. (٩/٧٤) ٤١٦٠٥- عن معاوية بن حُدَيْجٍ، قال: قال رسول الله ﷺ: «إن كان في شيءٍ شِفاءٌ؛ ففي شَرْطةِ مِحْجَم، أو شَرْبة مِن عسل، أو كَيَّةٍ بنار تُصِيبُ ألَمًا، وما أُحِبُّ أن أكْتَوِيَ»{27}. (٩/٧٦) ٤١٦٠٦- عن أبي سعيد الخدري، أن رجلًا أتى النَّبي ﷺ، فقال: يا رسول الله، إن أخي اسْتَطْلَقَ بطنُه. فقال: «اسْقِه عَسَلًا». فسَقاه عسلًا، ثم جاء، فقال: سقيتُه عسلًا، فما زادَه إلا اسْتِطْلاقًا. فقال رسول الله ﷺ: «اذهبْ، فاسقِه عسلًا». فذهَب، فسقاه عسلًا، ثم جاء، فقال: ما زاده إلا اسْتِطْلاقًا. قال رسول الله ﷺ: «صَدَق اللهُ، وكَذَب بطنُ أخيك، اذهَبْ، فاسْقِه عسَلًا». فذهَب، فسَقاه، فبَرَأَ{28}. (٩/٧٥) ٤١٦٠٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «مَن لَعِقَ العسلَ ثلاثَ غَدَواتٍ كلَّ شهرٍ لم يُصِبْه عظيمٌ مِن البلاء»{29}. (٩/٧٥) ٤١٦٠٨- عن عامر بن مالك، قال: بعَثْتُ إلى النبيِّ ﷺ مِن وعْك كان بي ألتمسُ منه دواءً أو شفاءً، فبعَث إلَيَّ بِعُكَّةٍ{30} مِن عسل{31}. (٩/٧٥) ٤١٦٠٩- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: إنّ العسلَ شفاءٌ مِن كلِّ داءٍ، والقرآن شفاءٌ لما في الصدور{32}. (٩/٧٤) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن جرير ١٤/٢٨٧-٢٨٨ كذلك من طريق ابن جريج. وعلقه يحيى بن سلام ١/٧٤، وعقَّب عليه بقوله: يعني: أنت مطيعة. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ١/٣٥٧ من طريق معمر، وابن جرير ١٤/٢٨٨. وعلقه يحيى بن سلام ١/٧٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٦.النُجعة: طلب الكلأ ومساقط الغيث. اللسان (نجع).أخرجه ابن جرير ١٤/٢٨٨-٢٨٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه سعيد بن منصور في سننه - التفسير ٦/٦٢ (١٢٣٠).تفسير يحيى بن سلام ١/٧٤.أخرجه ابن جرير ١٤/٢٩١.عزاه السيوطي إلى ابن أبي حاتم.كذا في مطبوعة المصدر، ولعلها: عسلًا.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٤.عزاه السيوطي إلى حميد بن زَنجُويه.أخرجه ابن أبي شيبة ١٠/٤٨٦، وابن جرير ١٤/٢٨٩.عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن أبي حاتم.أخرجه العقيلي في كتاب الضعفاء ٣/٥١ (٧٨٣).أخرجه ابن جرير ١٤/٢٩٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٤.تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن ماجه ٤/٥٠٧ (٣٤٥٢)، والحاكم ٤/٤٤٧ (٨٢٢٥)، عن زيد بن الحباب، عن سفيان، عن أبي إسحاق، عن أبي الأحوص، عن عبد الله مرفوعًا.أخرجه ابن أبي شيبة ١٠/٤٨٥، والطبراني (٨٩١٠). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه البخاري ٧/١٢٢-١٢٣ (٥٦٨٠، ٥٦٨١).أخرجه أحمد ٤٥/٢٢٩ (٢٧٢٥٦). قال الهيثمي في المجمع ٥/٩١ (٨٣١٣): «ورجال أحمد رجال الصحيح، خلا سويد بن قيس، وهو ثقة». وقال الصالحي في سبل الهدى والرشاد ١٢/١٤٧: «رجال ثقات».أخرجه البخاري ٧/١٢٣ (٥٦٨٤)، ٧/١٢٨ (٥٧١٦)، ومسلم ٤/١٧٣٦، ١٧٣٧ (٢٢١٧).أخرجه ابن ماجه ٤/٥٠٦ (٣٤٥٠)، من طريق الزبير بن سعيد الهاشمي، عن عبد الحميد بن سالم، عن أبي هريرة به. إسناده ضعيف منقطع. قال العقيلي في الضعفاء ٣/٤٠ (٩٩٦) في ترجمة عبد الحميد بن سالم: «حدثني آدم بن موسى، قال سمعت البخاري قال: عبد الحميد بن سالم، عن أبي هريرة: «من لعق العسل»؛ لا يُعرف له سماع من أبي هريرة ... هذا الحديث ... ليس له أصل عن ثقة». وقال ابن الجوزي في الموضوعات ٣/٢١٥: «هذا حديث لا يصح». وقال الذهبي في المغني في الضعفاء ١/٣٦٩ (٣٤٩١): «الخبر منكر». وقال ابن كثير في تفسيره ٤/٥٨٤: «الزبير بن سعيد متروك». وقال البوصيري في مصباح الزجاجة ٤/٥٤ (٩٩١١): «هذا إسناد فيه لين، ومع ذلك فهو منقطع». وقال ابن حجر في الفتح ١٠/١٤٠: «سند ضعيف». وقال ابن عراق الكناني في تنزيه الشريعة ٢/٣٦٠ (٢٧): «لا يصح». وقال المناوي في التيسير ٢/٤٤٢: «وفيه انقطاع وضعف». وقال الألباني في الضعيفة ٢/١٨٣ (٧٦٢): «ضعيف».العكة: وعاء من جلود مستدير، يختص بالسمن والعسل، وهو بالسمن أخص. النهاية (عكك) ٣/٢٨٤.أخرجه ابن الأعرابي في معجمه ٢/٥٢٩-٥٣٠ (٩٩٧)، والبيهقي في الشعب ٨/٨٥-٨٦ (٥٥٣١)، وابن عساكر في تاريخ دمشق ٢٦/٩٨، من طرق عن إسماعيل بن بهرام، نا الأشجعي، عن مسعر، عن خشرم بن حسان، عن عامر به. قال ابن عساكر: «تابعه (أي: ابن بهرام) موسى بن نصر، عن الفرات بن خالد، عن مسعر مرفوعًا. ورواه غيرهما عن مسعر مرسلًا». وفيه خشرم بن حسان ذكره البخاري في التاريخ ٣/٢١٧، ونقل عن أبي أحمد الزبيري أنه: «مرسل». وقال ابن حبان في الثقات ٦/٢٧٥: «يروي المراسيل».أخرجه ابن أبي شيبة ١٠/٤٨٥-٤٨٦، وابن جرير ١٤/٢٩٠، والحاكم ٤/٢٢٢.
16,70," <q>﴿وَٱللَّهُ خَلَقَكُمۡ ثُمَّ یَتَوَفَّىٰكُمۡۚ﴾</q> - تفسير ٤١٦١٠- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿واللَّهُ خَلَقَكُمْ﴾</q> ولم تكونوا شيئًا؛ لتعتبروا في البعث، <q>﴿ثُمَّ يَتَوَفّاكُمْ﴾</q> عند آجالكم{1}. (ز) ٤١٦١١- قال يحيى بن سلّام: قوله: <q>﴿ثم يتوفاكم﴾</q> يميتكم{2}. (ز) <q>﴿وَمِنكُم مَّن یُرَدُّ إِلَىٰۤ أَرۡذَلِ ٱلۡعُمُرِ﴾</q> - تفسير ٤١٦١٢- عن علي بن أبي طالب -من طريق الأصبغ بن نُباتة- في قوله: <q>﴿ومنكم من يرد إلى أرذل العمر﴾</q>، قال: خمسٌ وسبعونَ سنة{3}٣٧٠٤. (٩/٧٨) ٣٧٠٤ لم يذكر ابنُ جرير (١٤/٢٩٢) غير قول علي. ووجّهه ابنُ عطية (٥/٣٨٢) بقوله: «وهذا في الأغلب، وهذا لا ينحصر إلى مدة معينة، وإنما هو بحسب إنسان وإنسان، والمعنى: منكم من يرد إلى أرذل عمره؛ ورب من يكون ابن خمسين سنة وهو في أرذل عمره، ورب ابن مائة وتسعين ليس في أرذل عمره». ٤١٦١٣- قال قتادة بن دعامة: أرذل العمر تسعون سنة{4}. (ز) ٤١٦١٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ومنكم من يرد إلى أرذل العمر﴾</q> الآية، قال: أرْذَلُ العُمُر: هو الخَرَف{5}. (٩/٧٩) ٤١٦١٥- قال مقاتل بن سليمان: <q>﴿ومِنكُمْ مَن يُرَدُّ إلى أرْذَلِ العُمُرِ﴾</q>، يعني: الهَرَم{1}. (ز) ٤١٦١٦- قال يحيى بن سلّام: قوله: <q>﴿ومنكم من يرد إلى أرذل العمر﴾</q> إلى الهرم{2}. (ز) <q>﴿لِكَیۡ لَا یَعۡلَمَ بَعۡدَ عِلۡمࣲ شَیۡـًٔاۚ﴾</q> - تفسير ٤١٦١٧- عن عكرمة مولى ابن عباس -من طريق عاصم- قال: مَن قرَأ القرآن لم يُرَدَّ إلى أرذلِ العُمُر. ثم قرَأ: <q>﴿لِكي لا يَعلَمَ بعد عِلم شيئًا﴾</q>{8}. (٩/٧٩) ٤١٦١٨- قال يحيى بن سلّام: قوله: <q>﴿لكي لا يعلم بعد علم شيئا﴾</q> يصير بمنزلة الطفل الذي لا يعقل شيئًا{2}. (ز) <q>﴿إِنَّ ٱللَّهَ عَلِیمࣱ قَدِیرࣱ ۝٧٠﴾</q> - تفسير ٤١٦١٩- قال مقاتل بن سليمان: <q>﴿إنَّ اللَّهَ عَلِيمٌ﴾</q> بالبعث أنّه كائن، <q>﴿قَدِيرٌ﴾</q> يعني: قادرًا عليه{1}. (ز) <q>﴿إِنَّ ٱللَّهَ عَلِیمࣱ قَدِیرࣱ ۝٧٠﴾</q> - آثار متعلقة بالآية ٤١٦٢٠- عن أنس بن مالك، قال: قال رسول الله ﷺ: «المولودُ حتى يَبْلُغَ الحِنثَ ما عَمِلَ مِن حسنةٍ أُثْبِت لوالدِه أو لوالدَيه، وإن عمِل سيئةً لم تُكْتَبْ عليه ولا على والدَيه، فإذا بلَغ الحِنثَ، وجَرى عليه القلم؛ أُمِر الملكان اللَّذان معه فحَفِظاه وسدَّداه، فإذا بلَغ أربعين سنةً في الإسلام أمَّنَه اللهُ من البَلايا الثلاثة؛ من الجنون، والجُذامِ، والبَرَص، فإذا بلَغ الخمسين ضاعَفَ اللهُ حسناتِه، فإذا بلَغ ستينَ رزَقه اللهُ الإنابة إليه فيما يُحِبُّ، فإذا بلَغ سبعينَ أحَبَّه أهلُ السماء، فإذا بلَغ ثمانين سنةً كتَب اللهُ حسناتِه وتجاوَز عن سيئاتِه، فإذا بلَغ تسعين سنةً غفَر الله ما تقدَّم مِن ذنبِه وما تأخَّر، وشَفَّعه في أهل بيته، وكان اسمُه عندَه أسيرَ اللهِ في أرضِه، فإذا بلَغ أرْذَلَ العُمُر -<q>﴿لكي لا يعلم بعد علم شيئًا﴾</q>- كتَب اللهُ له مثلَ ما كان يعمَلُ في صحتِه من الخير، وإن عمِل سيئةً لم تُكْتَبْ عليه»{11}. (٩/٨٠) ٤١٦٢١- عن سعد بن أبي وقاص، عن النَّبي ﷺ أنه كان يَدْعو: «اللهم، إني أعوذ بك من البُخْل، وأعوذ بك من الجُبْن، وأعوذ بك أن أُرَدَّ إلى أرذل العُمُر، وأعوذ بك من فتنة الدنيا، وأعوذ بك من عذاب القبر»{12}. (٩/٨٠) ٤١٦٢٢- عن طاووس بن كيسان -من طريق ابن طاووس- قال: إنّ العالِمَ لا يَخْرَفُ{13}. (٩/٧٩) ٤١٦٢٣- عن عبد الملك بن عُمير -من طريق الحكم بن هشام الثقفي- قال: كان يقالُ: إنّ أبْقى الناسِ عُقُولًا قُرّاءُ القرآن{14}. (٩/٧٩) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٤.أخرجه ابن جرير ١٤/٢٩٢.تفسير الثعلبي ٦/٢٩، وتفسير البغوي ٥/٣٠.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٨٨-.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٤.أخرجه ابن أبي شيبة ١٠/٤٦٨. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ١/٧٤.تفسير مقاتل بن سليمان ٢/٤٧٧.أخرجه أحمد ٢١/١٢ (١٣٢٧٩)، وأبو يعلى (٣٦٧٨، ٤٢٤٦-٤٢٤٩)، واللفظ لأبي يعلى في الموضع الأول. وعزاه السيوطي إلى ابن مردويه. قال محققو المسند: «إسناده ضعيف جدًّا». وهو عند أحمد ٩/٤٤٥ (٥٦٢٦) مختصرًا موقوفًا على أنس. وقال محققو المسند أيضًا: «إسناده ضعيف جدًّا».أخرجه البخاري (٦٣٧٠).أخرجه ابن أبي شيبة ١٤/٥٤.أخرجه ابن أبي شيبة ١٠/٤٦٨.
16,71," <q>﴿وَٱللَّهُ فَضَّلَ بَعۡضَكُمۡ عَلَىٰ بَعۡضࣲ فِی ٱلرِّزۡقِۚ فَمَا ٱلَّذِینَ فُضِّلُوا۟ بِرَاۤدِّی رِزۡقِهِمۡ عَلَىٰ مَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ﴾</q> - تفسير ٤١٦٢٤- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿والله فضل بعضكم على بعض في الرزق﴾</q> الآية، يقول: لم يكونوا ليُشْرِكوا عبيدَهم في أموالهم ونسائهم، فكيف يُشرِكون عبيدي معي في سُلْطاني؟! فذلك قوله: <q>﴿أفبنعمة الله يجحدون﴾</q>{1}. (٩/٨١) ٤١٦٢٥- عن عبد الله بن عباس -من طريق ابن جريج- قال: هذه الآية في شأن عيسى ابن مريم، يعني بذلك: نفسه، إنما عيسى عبد، فيقول الله: واللهِ، ما تشركون عبيدكم في الذي لكم؛ فتكونوا أنتم وهم سواء، فكيف ترضون لي بما لا ترضون لأنفسكم؟!{2}. (ز) ٤١٦٢٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في الآية، قال: هذا مَثَلٌ لآلهةِ الباطل مع الله{3}. (٩/٨١) ٤١٦٢٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والله فضل بعضكم على بعض في الرزق﴾</q> الآية، قال: هذا مَثَلٌ ضَرَبه الله، فهل منكم مِن أحدٍ يُشارِكُ مملوكَه في زوجتِه وفي فراشِه فتَعْدِلون بالله خلقَه وعبادَه؟! فإن لم تَرْضَ لنفسِك بهذا؛ فاللهُ أحقُّ أن تُبَرِّئَه مِن ذلك، ولا تَعْدِلْ بالله أحدًا مِن عبادِه وخلقِه{4}. (٩/٨١) ٤١٦٢٨- عن عطاء الخراساني، في الآية، قال: هذا مَثَلٌ ضرَبه الله في شأن الآلهة، فقال: كيف تَعْدِلون عبادي بي، ولا تَعْدِلون عبيدَكم بأنفسِكم، وتَرُدُّون ما فُضِّلْتُم به عليهم، فتكونون أنتم وهم في الرِّزْق سَواء؟!{5}. (٩/٨٢) ٤١٦٢٩- قال مقاتل بن سليمان: <q>﴿واللَّهُ فَضَّلَ بَعْضَكُمْ عَلى بَعْضٍ فِي الرِّزْقِ﴾</q> يعني: جعل بعضكم أحرارًا، وبعضكم عبيدًا، فوسَّع على بعض الناس، وقتَّر على بعض، <q>﴿فَما الَّذِينَ فُضِّلُوا﴾</q> يعني: الرزق من الأموال <q>﴿بِرادِّي رِزْقِهِمْ﴾</q> يقول: برادي أموالهم <q>﴿عَلى ما مَلَكَتْ أيْمانُهُمْ﴾</q> يعني: عبيدهم؛ يقول: أفيشركونهم وعبيدهم في أموالهم{6}. (ز) ٤١٦٣٠- قال يحيى بن سلّام: قوله: <q>﴿والله فضل بعضكم على بعض في الرزق فما الذين فضلوا﴾</q> يعني: في الرزق <q>﴿برادي رزقهم على ما ملكت أيمانهم﴾</q>{7}. (ز) <q>﴿فَهُمۡ فِیهِ سَوَاۤءٌۚ﴾</q> - تفسير ٤١٦٣١- تفسير إسماعيل السُّدِّيّ: <q>﴿فهم فيه سواء﴾</q>، يعني: شرعًا سواء{8}. (ز) ٤١٦٣٢- قال مقاتل بن سليمان: <q>﴿فَهُمْ فِيهِ سَواءٌ﴾</q>، فيكونون فيه سواء، بأنهم قوم لا يعقلون شيئًا{6}. (ز) ٤١٦٣٣- قال يحيى بن سلّام: يقول: هل منكم من أحد يكون هو ومملوكه في أهله وماله سواء؟ أي: إنكم لا تفعلون ذلك بمملوككم حتى تكونوا في ذلك سواء؛ فالله أحق ألا يشرك به أحد من خلقه. وهو كقوله: <q>﴿ضرب لكم مثلا من أنفسكم هل لكم من ما ملكت أيمانكم من شركاء في ما رزقناكم فأنتم فيه سواء تخافونهم كخيفتكم أنفسكم﴾</q> [الروم:٢٨] كخيفة بعضكم بعضًا{7}. (ز) <q>﴿أَفَبِنِعۡمَةِ ٱللَّهِ یَجۡحَدُونَ ۝٧١﴾</q> - تفسير ٤١٦٣٤- قال قتادة بن دعامة: والجحد لا يكون إلا من بعد المعرفة{8}. (ز) ٤١٦٣٥- قال مقاتل بن سليمان: <q>﴿أفَبِنِعْمَةِ اللَّهِ يَجْحَدُونَ﴾</q>، يعني: ينكرون بأن الله يكون واحدًا لا شريك له، وهو ربُّ هذه النِّعَم؟! يقول: كيف أُشْرِكُ الملائكةَ وغيرَهم في ملكي وأنتم لا ترضون الشركة من عبيدكم في أموال؟! فكما لا تدخلون عبيدكم في أموالكم فكذلك لا أدخل معي شريكًا في ملكي، وهم عبادي. وذلك حين قال كفار مكة في إحرامهم: لبيك لا شريك لك، إلا شريكًا هو لك، تملكه وما ملك. نظيرها في الروم: <q>﴿ضَرَبَ لَكُمْ مَثَلًا مِن أنْفُسِكُمْ ...﴾</q> إلى آخر الآية [الروم:٢٨]{6}. (ز) ٤١٦٣٦- قال يحيى بن سلّام: <q>﴿أفبنعمة الله يجحدون﴾</q> على الاستفهام، أي: قد جحدوا بنعمة الله{7}. (ز) <q>﴿أَفَبِنِعۡمَةِ ٱللَّهِ یَجۡحَدُونَ ۝٧١﴾</q> - آثار متعلقة بالآية ٤١٦٣٧- عن الحسن البصري، قال: كتب عمر بن الخطاب إلى أبي موسى الأشعري: اقْنَعْ برزقِك في الدنيا؛ فإنّ الرحمن فضَّل بعضَ عباده على بعض في الرزق، بَلاءً يَبْتلِي به كُلًّا، فيَبْتَلي به مَن بسَط له كيف شُكْرُه فيه، وشُكْرُه للهِ أداؤُه الحقَّ الذي افتَرض عليه فيما رزَقه وخَوَّلَه{14}. (٩/٨٢) ",footnotes:1:أخرجه ابن جرير ١٤/٢٩٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٩٤.أخرجه ابن جرير ١٤/٢٩٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٧٥، وابن جرير ١٤/٢٩٤-٢٩٥، وأخرجه عبد الرزاق ١/٣٥٨ من طريق معمر بنحوه، وكذلك ابن جرير ١٤/٢٩٤-٢٩٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.علَّقه يحيى بن سلام ١/٧٥.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.علَّقه يحيى بن سلام ١/٧٥.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٤/٥٠٥-.
16,72," <q>﴿وَٱللَّهُ جَعَلَ لَكُم مِّنۡ أَنفُسِكُمۡ أَزۡوَ ٰ⁠جࣰا﴾</q> - تفسير ٤١٦٣٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والله جعل لكم من أنفسكم أزواجًا﴾</q>، قال: خلق آدمَ، ثم خلَق زوجتَه منه{1}٣٧٠٥. (٩/٨٢) ٣٧٠٥ لم يذكر ابنُ جرير (١٤/٢٩٥) غير قول قتادة. ٤١٦٣٩- قال مقاتل بن سليمان: <q>﴿واللَّهُ جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</q>، يقول: بعضكم من بعض{2}. (ز) ٤١٦٤٠- قال يحيى بن سلّام: قوله: <q>﴿والله جعل لكم من أنفسكم أزواجا﴾</q>، يعني: النساء، والنساء من الرجال{3}٣٧٠٦. (ز) ٣٧٠٦ وجَّه ابن عطية (٥/٣٨٣) قول قتادة، فقال: «فمن حيث كانا مبتدأ الجميع ساغ حمل أمرهما على الجميع؛ حتى صار الأمر كأن النساء خلقن من أنفس الرجال». ثم رجّح مستندًا إلى النظائر أن «<q>﴿مِن أنْفُسِكُمْ﴾</q> أي: من نوعكم، وعلى خلقتكم، كما قال تعالى: <q>﴿لَقَدْ جاءَكُمْ رَسُولٌ مِن أنْفُسِكُمْ﴾</q> [التوبة:١٢٨]». <q>﴿وَجَعَلَ لَكُم مِّنۡ أَزۡوَ ٰ⁠جِكُم بَنِینَ وَحَفَدَةࣰ﴾</q> - تفسير ٤١٦٤١- عن عبد الله بن مسعود -من طريق زر بن حُبيش- في قوله: <q>﴿بنين وحفدة﴾</q>، قال: الحَفَدةُ: الأَخْتانُ{4}{5}. (٩/٨٢) ٤١٦٤٢- عن زر بن حبيش، قال: قال لي عبد الله بن مسعود: ما الحفدة، يا زر؟ قال: قلت: هم أحفاد الرجل مِن ولده، وولد ولده. قال: لا، هم الأصهار{6}. (ز) ٤١٦٤٣- عن عبد الله بن عباس -من طريق علي- قال: الحَفَدةُ: الأَصْهار{7}. (٩/٨٣) ٤١٦٤٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: الحَفَدةُ: الولدُ، وولدُ الولد{8}. (٩/٨٣) ٤١٦٤٥- عن عبد الله بن عباس -من طريق مجاهد، وسعيد بن جبير- في هذه الآية: <q>﴿بنين وحفدة﴾</q>، قال: الحفدة: البنون{9}. (ز) ٤١٦٤٦- عن عبد الله بن عباس، قال: الحَفَدةُ: بنو البنين{10}. (٩/٨٣) ٤١٦٤٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبرني عن قوله ﷿: <q>﴿بنين وحفدة﴾</q>. قال: ولدُ الولد، وهم الأَعْوانُ. قال: وهل تعرِفُ العربُ ذلك؟ قال: نعم، أما سمِعتَ الشاعرَ وهو يقولُ: حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُسْلِمَتْ بأَكُفِّهِنَّ أزِمَّةُ الأَجْمالِ؟{11}. (٩/٨٣) ٤١٦٤٨- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك بن مزاحم- أن نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿: <q>﴿بنين وحفدة﴾</q>، ما البنون والحفدة؟ قال: أما بنوك فإنهم يعاطونك، وأما حفدتك فإنهم خدمك. قال: وهل كانت العرب تعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: نعم، أما سمعت قول أمية بن أبي الصلت الثقفي: حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُلْقِيَت بأَكُفِّهِنَّ أزِمَّةُ الأَجْمالِ؟{12}. (ز) ٤١٦٤٩- عن أبي حمزة، قال: سُئِل عبد الله بن عباس عن قوله: <q>﴿بنين وحفدة﴾</q>. قال: مَن أعانك فقد حفَدك، أما سمِعتَ قول الشاعر: حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُسْلِمَتْ بأَكُفِّهِنَّ أزِمَّةُ الأَجْمالِ؟{6}. (٩/٨٣) ٤١٦٥٠- عن عبد الله بن عباس -من طريق العوفي- قال: الحَفَدة: بنو امرأةِ الرجلِ ليسوا منه{14}. (٩/٨٣) ٤١٦٥١- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وجعل لكم من أزواجكم بنين وحفدة﴾</q> ... وقال: الحفدة: الرجل يعمل بين يدي الرجل، يقول: فلان يحفد لنا. ويزعم رجال: أنّ الحفدة: أختان الرجل{15}. (ز) ٤١٦٥٢- عن عبد الله بن عباس -من طريق عكرمة- قال: الأختان{16}. (ز) ٤١٦٥٣- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿بنين وحفدة﴾</q>، قال: الحفدة: الأختان{16}. (ز) ٤١٦٥٤- عن إبراهيم النخعي -من طريق مغيرة- قال: الحفدة: الخَتَنُ{16}. (ز) ٤١٦٥٥- عن إبراهيم النخعي -من طريق مغيرة- قال: الحفدة: هم الأصهار{19}. (ز) ٤١٦٥٦- عن أبي الضُّحى مسلم بن صبيح -من طريق الأعمش- قال: الحفدة: الأختان{20}. (ز) ٤١٦٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: الحفدة: الخَدَم{21}. (ز) ٤١٦٥٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بنين وحفدة﴾</q>، قال: ابنه، وخادمه{22}. (ز) ٤١٦٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول الله تعالى: <q>﴿بنين وحفدة﴾</q>، قال: أنصارًا، وأعوانًا، وخدامًا{22}. (ز) ٤١٦٦٠- قال مجاهد بن جبر: هم الأعوان؛ مَن أعانك فقد حفدك{24}. (ز) ٤١٦٦١- عن الضحاك بن مزاحم -من طريق جويبر- قال: هم الخَدَم{25}. (ز) ٤١٦٦٢- عن عبيد بن سليمان، قال: سمعت الضحاك بن مزاحم يقول في قوله: <q>﴿بنين وحفدة﴾</q>: يعني: ولد الرجل يحفدونه ويخدمونه، وكانت العرب إنما تخدمهم أولادهم الذكور{26}. (ز) ٤١٦٦٣- عن عكرمة مولى ابن عباس -من طريق سماك- قال: الحَفَدةُ: الخُدّام{27}. (٩/٨٤) ٤١٦٦٤- عن عكرمة مولى ابن عباس -من طريق حصين- قال: هم الذين يُعِينون الرجل من ولده وخدمه{21}. (ز) ٤١٦٦٥- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- <q>﴿وحفدة﴾</q>، قال: الحفدة: مَن خدمك مِن ولدك{29}. (ز) ٤١٦٦٦- عن طاووس بن كيسان -من طريق ابن طاووس- قال: الحفدة: الخدم{22}. (ز) ٤١٦٦٧- عن أبي مالك غزوان الغفاري -من طريق السدي- قال: الحَفَدةُ: الأَعْوان{31}. (٩/٨٤) ٤١٦٦٨- عن الحسن البصري -من طريق منصور- قال: هم الخدم{32}. (ز) ٤١٦٦٩- عن الحسن البصري -من طريق أبي هلال الراسبي- قال: الحَفَدة: البنونَ، وبنو البنين، ومَن أعانَك مِن أهلٍ أو خادمٍ فقد حَفَدك{33}. (٩/٨٤) ٤١٦٧٠- قال عطاء: هم ولد الرجل الذين يعينونه ويحفدونه ويرفدونه ويخدمونه{34}. (ز) ٤١٦٧١- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿وجعل لكم من أزواجكم بنين وحفدة﴾</q>، مَهَنَةً{35} يمْهنُونك ويخدُمونك من ولدك، كرامة أكرمكم الله بها{36}. (ز) ٤١٦٧٢- قال محمد بن السائب الكلبي: البنين: الصغار. والحفدة: كبار الأولاد الذين يعينونه على عمله{24}. (ز) ٤١٦٧٣- قال مقاتل بن سليمان: <q>﴿وجَعَلَ لَكُمْ مِن أزْواجِكُمْ بَنِين﴾</q> يعني بالبنين: الصغار، <q>﴿وحَفَدَةً﴾</q> والحفدة: [الكبار]{38}، يحفدون أباهم بالخدمة، وذلك أنهم كانوا في الجاهلية يخدمهم أولادهم{39}. (ز) ٤١٦٧٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وجعل لكم من أزواجكم بنين وحفدة﴾</q>، قال: الحفدة: الخدم من ولد الرجل هم ولده، وهم يخدمونه، قال: وليس تكون العبيد من الأزواج، كيف يكون من زوجي عبد؟! إنما الحفدة: ولد الرجل، وخَدَمه{26}٣٧٠٧. (ز) ٣٧٠٧ اختلف السلف في المعني بالحفدة على أقوال: الأول: الأختان. الثاني: أعوان الرجل وخدمه. الثالث: ولد الرجل، وولد ولده. الرابع: بنو امرأة الرجل من غيره. ووجّه ابن عطية (٥/٣٨٣) القول الثالث، فقال: «وقالت فرقة: الحفدة: هم البنون. وهذا يستقيم على أن تكون الواو عاطفة صفة لهم، كما لو قال: جعلنا لهم بنين وأعوانًا، أي: وهم لهم أعوان، فكأنه قال: وهم حفدة». وقد رجّح ابنُ جرير (١٤/٣٠٣-٣٠٤ بتصرف) مستندًا إلى اللغة أن الحفدة: هم المسرعون في خدمة الرجل، وأن ذلك يعم جميع هذه الأقوال، فقال: «والحفدة في كلام العرب: جمع حافد، والحافد في كلامهم: هو المتخفف في الخدمة والعمل، والحفد: خفة العمل، يقال: مر البعير يحفد حفدانًا: إذا مر يسرع في سيره، ومنه قولهم: إليك نسعى ونحفد، أي: نسرع إلى العمل بطاعتك ... وإذ كان معنى الحفدة ما ذكرنا من أنهم المسرعون في خدمة الرجل المتخففون فيها، وكان أولادنا وأزواجنا الذين يصلحون للخدمة منا ومن غيرنا، وأختاننا الذين هم أزواج بناتنا من أزواجنا، وخدمنا من مماليكنا، إذا كانوا يحفدوننا فيستحقون اسم حفدة، ولم يكن الله تعالى دل بظاهر تنزيله ولا على لسان رسوله ﷺ ولا بحجة عقل على أنه عنى بذلك نوعًا من الحفدة دون نوع منهم، وكان قد أنعم بكل ذلك علينا؛ لم يكن لنا أن نوجه ذلك إلى خاص من الحفدة دون عام، إلا ما اجتمعت الأمة عليه أنه غير داخل فيهم، وإذا كان ذلك كذلك فلكل الأقوال التي ذكرنا عمن ذكرنا وجه في الصحة، ومخرج في التأويل، وإن كان أولى بالصواب من القول ما اخترنا لما بينا من الدليل». وذكر ابنُ عطية (٥/٣٨٣-٣٨٤) هذه الأقوال، ثم علَّق قائلًا: «ولا خلاف أن معنى الحفد: الخدمة، والبر، والمشي مسرعًا في الطاعة، ومنه في القنوت: «وإليك نسعى ونحفد» ... وهذه الفرق التي ذكرت أقوالها إنما بَنَتْ على أنّ كل أحد جعل له من زوجه بنون وحفدة، وهذا إنما هو في الغالب وعظم الناس». ثم ذكر احتمالًا آخر، فقال: «ويحتمل عندي أن قوله: <q>﴿من أزواجكم﴾</q> إنما هو على العموم والاشتراك، أي: من أزواج البشر جعل الله لهم البنين، ومنهم جعل الخدمة فمن لم تكن له قط زوجة فقد جعل الله له حفدة، وحصل تحت النعمة، وأولئك الحفدة هم من الأزواج، وهكذا تترتب النعمة التي تشمل جميع العالم، وتستقيم لفظة»الحفدة«على مجراها في اللغة، إذ البشر بجملتهم لا يستغني أحد منهم عن حفدة». وعلَّق ابنُ كثير (٨/٣٣٢-٣٣٣) عليها قائلًا: «فمن جعل <q>﴿وحفدة﴾</q> متعلقًا بـ<q>﴿أزواجكم﴾</q> فلا بد أن يكون المراد: الأولاد، وأولاد الأولاد، والأصهار؛ لأنهم أزواج البنات، وأولاد الزوجة. وكما قال الشعبي والضحاك، فإنهم غالبًا يكونون تحت كنف الرجل، وفي حجره، وفي خدمته. وقد يكون هذا هو المراد من قوله عليه الصلاة والسلام في حديث بصرة بن أكثم: «والولد عبد لك». رواه أبو داود. وأما من جعل الحفدة: هم الخدم؛ فعنده أنه معطوف على قوله: <q>﴿والله جعل لكم من أنفسكم أزواجا﴾</q>، أي: وجعل لكم الأزواج والأولاد، [وجعل لكم خدامًا]». <q>﴿وَرَزَقَكُم مِّنَ ٱلطَّیِّبَـٰتِۚ﴾</q> - تفسير ٤١٦٧٥- قال مقاتل بن سليمان: قال الله ﷿ <q>﴿ورَزَقَكُمْ مِنَ الطَّيِّباتِ﴾</q>، يعني: الحب، والعسل، ونحوه، وجعل رزق غيركم من الدواب والطير لا يشبه أرزاقكم في الطيب والحسن{41}. (ز) <q>﴿أَفَبِٱلۡبَـٰطِلِ یُؤۡمِنُونَ وَبِنِعۡمَتِ ٱللَّهِ هُمۡ یَكۡفُرُونَ ۝٧٢﴾</q> - تفسير ٤١٦٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أفبالباطل يؤمنون﴾</q>، قال: بالشرك{42}. (٩/٨٤) ٤١٦٧٧- قال إسماعيل السُّدِّيّ: <q>﴿أفبالباطل يؤمنون﴾</q>، يعني: بعبادة الشيطان -الشرك- يُصَدِّقون{43}. (ز) ٤١٦٧٨- قال مقاتل بن سليمان: <q>﴿أفَبِالباطِلِ يُؤْمِنُونَ﴾</q> يعني: أفبالشيطان يصدقون بأنّ مع الله ﷿ شريكًا، <q>﴿وبِنِعْمَتِ اللَّهِ﴾</q> الذي أطعمهم من جوع وآمنهم من خوف <q>﴿هُمْ يَكْفُرُونَ﴾</q> بتوحيد الله؛ أفلا يؤمنون برب هذه النعم فيوحدونه؟!{41}. (ز) ٤١٦٧٩- عن عبد الملك ابن جريج، في قوله: <q>﴿أفبالباطل يؤمنون﴾</q> قال: الشيطان، <q>﴿وبنعمتِ الله﴾</q> قال: محمد ﷺ{45}. (٩/٨٤) ٤١٦٨٠- قال يحيى بن سلّام: قوله: <q>﴿أفبالباطل يؤمنون﴾</q> على الاستفهام، أي: قد آمنوا بالباطل، والباطل إبليس، <q>﴿وبنعمت الله هم يكفرون﴾</q> هو كقوله: <q>﴿ألم تر إلى الذين بدلوا نعمت الله كفرا﴾</q> [إبراهيم:٢٨]، وكقوله: <q>﴿وتجعلون رزقكم أنكم تكذبون﴾</q> [الواقعة:٨٢]، يقول: تجعلون مكان الشكر: التكذيب{46}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/٧٥، وابن جرير ١٤/٢٩٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.الأختان: أبو امرأة الرجل، وأخو امرأته، وكل مَن كان مِن قِبَل امرأته. اللسان (ختن).أخرجه يحيى بن سلام ١/٧٦، والبخاري في تاريخه ٦/١٥٤، وابن جرير ١٤/٢٩٦، والطبراني (٩٠٨٨، ٩٠٩٠، ٩٠٩٢، ٩٠٩٣)، والحاكم ٢/٣٥٥، والبيهقي في سُنَنِه ٧/٧٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٩٨.أخرجه ابن جرير ١٤/٢٩٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٠١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٠١.عزاه السيوطي إلى ابن أبي حاتم.مسائل نافع (٥). وعزاه السيوطي إلى الطستي.أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه ابن جرير ١٤/٢٩٨.أخرجه ابن جرير ١٤/٣٠٢-٣٠٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٠٢-٣٠٣.أخرجه ابن جرير ١٤/٢٩٧.أخرجه ابن جرير ١٤/٢٩٧.أخرجه ابن جرير ١٤/٢٩٧.أخرجه سعيد بن منصور في سننه - التفسير ٦/٦٥ (١٢٣٥).أخرجه ابن جرير ١٤/٢٩٦.أخرجه ابن جرير ١٤/٢٩٩.أخرجه ابن جرير ١٤/٣٠٠.أخرجه ابن جرير ١٤/٣٠٠.تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١.أخرجه سعيد بن منصور في سننه - التفسير ٦/٦٥ (١٢٣٤).أخرجه ابن جرير ١٤/٣٠٢.أخرجه ابن جرير ١٤/٢٩٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٩٩.أخرجه عبد الرزاق في تفسيره ٢/٣٥٨ بلفظ: الحفدة: مَن يخدمك مِن ولدك وولد ولدك، وابن جرير ١٤/٢٩٩.أخرجه ابن جرير ١٤/٣٠٠.أخرجه ابن جرير ١٤/٣٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٧٥، وسعيد بن منصور في سننه - التفسير ٦/٦٥ (١٢٣٤).أخرجه يحيى بن سلام ١/٧٥، وابن جرير ١٤/٢٩٩.تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١ بلفظ: هم ولد ولد الرجل، الذين يعينونه ويخدمونه.الـمَهْنَة -بفتح الميم-: هي الخدمة. ولا يقال: مِهنة –بالكسر-. النهاية (مهن).أخرجه يحيى بن سلام ١/٧٦ مختصرًا، وابن جرير ١٤/٣٠٠.تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١.في المطبوع: الكفار!تفسير مقاتل بن سليمان ٢/٤٧٧. وفي تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١ بنحوه منسوبًا إلى مقاتل دون تمييز.أخرجه ابن جرير ١٤/٣٠٢.تفسير مقاتل بن سليمان ٢/٤٧٨.أخرجه ابن جرير ١٨/٤٤٣ ذكره في [العنكبوت: ٦٧]، وابن أبي حاتم ٩/٣٠٨٣.علَّقه يحيى بن سلام ١/٧٦.تفسير مقاتل بن سليمان ٢/٤٧٨.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٧٦.
