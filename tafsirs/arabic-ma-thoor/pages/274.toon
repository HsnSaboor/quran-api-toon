quran[8]{c,v,t}:
  16,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَحۡیَا بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر صنعه؛ ليعرف توحيده، فقال تعالى: <span class="qpc-hafs">﴿واللَّهُ أنْزَلَ مِنَ السَّماءِ ماءً﴾</span> يعني: المطر، <span class="qpc-hafs">﴿فَأَحْيا بِهِ الأَرْضَ بَعْدَ مَوْتِها﴾</span> بالنبات{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿والله أنزل من السماء ماء فأحيا به الأرض بعد موتها﴾</span> الأرض اليابسة التي ليس فيها نبات، فيحييها بالمطر، وتُنبِتُ بعد إذ لم يكن فيها نبات{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَسۡمَعُونَ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ فِي ذلِكَ لَآيَةً﴾</span> يقول: إنّ في المطر والنبات لعبرة وآية <span class="qpc-hafs">﴿لِقَوْمٍ يَسْمَعُونَ﴾</span> المواعظ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿إن في ذلك لآية لقوم يسمعون﴾</span>، فيعلمون أنّ الذي أحيا هذه الأرض الميتة حتى أنبتت قادرٌ على أن يحيي الموتى؛ لأنّ المشركين لا يُقِرّون بالبعث{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.
  16,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ لَكُمۡ فِی ٱلۡأَنۡعَـٰمِ لَعِبۡرَةࣰۖ نُّسۡقِیكُم مِّمَّا فِی بُطُونِهِۦ مِنۢ بَیۡنِ فَرۡثࣲ وَدَمࣲ لَّبَنًا خَالِصࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥١٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: إذا أكلت الدابة العلف، واستقر في كرشها، وطحنته، فكان أسفله فرثًا، وأوسطه اللبن، وأعلاه الدم، والكبد مسلطة عليها، تقسمها بتقدير الله تعالى، فيجري الدم في العروق، واللبن في الضرع، ويبقى الفرث كما هو{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥١٣<span class="dash">-</span></span> عن محمد بن سيرين: أن <span class="name-1">عبد الله بن عباس</span> شَرِب لَبَنًا، فقال له مُطَرِّفٌ: ألا تَمَضْمَضْتَ؟ فقال: ما أُباليه بالَةً{2}، اِسمَحْ يُسْمَحْ لك{3}. فقال قائلٌ: إنه يخرُجُ مِن بين فَرْثٍ ودمٍ. قال <span class="name-1">ابن عباس</span>: وقد قال الله: <span class="qpc-hafs">﴿لبنًا خالصًا سائغًا للشاربين﴾</span>{4}. (٩/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّ لَكُمْ فِي الأَنْعامِ لَعِبْرَةً﴾</span> يعني: التفكر، <span class="qpc-hafs">﴿نُسْقِيكُمْ مِمّا فِي بُطُونِهِ مِن بَيْنِ فَرْثٍ ودَمٍ لَبَنًا خالِصًا﴾</span> من القَذَر{5}<span class=comment-ref>٣٦٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٣٧٧-٣٧٨) في عود الضمير من قوله: <span class="qpc-hafs">﴿مما في بطونه﴾</span> عدة أقوال، فقال: "وقوله: <span class="qpc-hafs">﴿مِمّا فِي بُطُونِهِ﴾</span> الضمير عائد على الجنس، وعلى المذكور، <span class="mustanad">كما قال الشاعر</span>:</p><p>مثل الفراخ نتفت حواصله</p><p>وهذا كثير، <span class="mustanad">لقوله تعالى</span>: <span class="qpc-hafs">﴿إنَّ هذِهِ تَذْكِرَةٌ﴾</span> [الإنسان:٢٩]، <span class="qpc-hafs">﴿فَمَن شاءَ ذَكَرَهُ﴾</span> [المدثر:٥٥]. وقيل: إنما قال: <span class="qpc-hafs">﴿مِمّا فِي بُطُونِهِ﴾</span> لأن الأنعام والنعم واحد فرد، والضمير على معنى: النعم. وقالت فرقة: الضمير عائد على البعض، إذ الذكور لا ألبان لها، فكأن العبرة إنما هي في بعض الأنعام".</p><p>وذكر <u>ابنُ كثير</u> (٨/٣٢٣) في عود الضمير قولين، و<span class="comment-type-4">علّق</span> عليهما، فقال: «وأفرد هاهنا الضمير عودًا على معنى: النعم، أو الضمير عائد على الحيوان؛ فإن الأنعام حيوانات، أي: نسقيكم مما في بطن هذا الحيوان، وفي الآية الأخرى: <span class="qpc-hafs">﴿مما في بطونها﴾</span> [المؤمنون:٢١]، ويجوز هذا وهذا، <span class="mustanad">كما في قوله تعالى</span>: <span class="qpc-hafs">﴿كلا إنه تذكرة فمن شاء ذكره﴾</span> [المدثر:٥٤-٥٥]، <span class="mustanad">وفي قوله تعالى</span>: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية فناظرة بم يرجع المرسلون فلما جاء سليمان﴾</span> [النمل:٣٥-٣٦] أي: المال».</div></p><p><h3><span class="qpc-hafs">﴿سَاۤىِٕغࣰا لِّلشَّـٰرِبِینَ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥١٥<span class="dash">-</span></span> عن يحيى بن عبد الرحمن بن أبي لَبِيبَةَ، عن أبيه، عن جدِّه، أن رسولَ الله ﷺ قال: «<b>ما شرِب أحدٌ لبنًا فشَرِقَ؛ إن اللهَ يقول</b>: <span class="qpc-hafs">﴿لبنًا خالصًا سآئغًا للشاربين﴾</span>»{6}. (٩/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سائِغًا لِلشّارِبِينَ﴾</span> يسيغ مَن يشربه، وهو لا يسيغ الفرث والدم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وإن لكم في الأنعام لعبرة نسقيكم مما في بطونه من بين فرث ودم لبنا خالصا سائغا للشاربين﴾</span>، يقول: ففي هذا اللبن الذي أخرجه الله من بين فرث ودم آية لقوم يعقلون، فيعلمون أن الذي أخرجه من بين فرث ودم قادر على أن يحيي الموتى{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٦/٢٧، وتفسير البغوي ٥/٢٨.ما أباليه بالة: ما أكترث له. الصحاح (بلي).اسْمَحْ يُسْمَحْ لك: سَهِّل يُسَهَّل عليك. النهاية (سمح).أخرجه عبد الرزاق (٦٨٦). وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٥.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.
  16,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن ثَمَرَ ٰ⁠تِ ٱلنَّخِیلِ وَٱلۡأَعۡنَـٰبِ تَتَّخِذُونَ مِنۡهُ سَكَرࣰا وَرِزۡقًا حَسَنًاۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤١٥١٨<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق مغيرة- في الآية، قال: نزَل هذا وهم يَشرَبون الخمر قبلَ أن يَنزِلَ تحريمُها{1}. (٩/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق همام، وعثمان- قال: نزلت قبل تحريم الخمر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</span>: ونزلت هذه الآية ولم تُحَرَّم الخمر يومئذ، وإنما جاء تحريمها بعد ذلك في سورة المائدة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِن ثَمَرَ ٰ⁠تِ ٱلنَّخِیلِ وَٱلۡأَعۡنَـٰبِ تَتَّخِذُونَ مِنۡهُ سَكَرࣰا وَرِزۡقًا حَسَنًاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرة- قال: السَّكَرُ خمرٌ{4}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٢<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span> -من طريق سالم-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٣<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق يونس-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٤<span class="dash">-</span></span> و<span class="name-2">عامر الشعبي</span> -من طريق مُغيرة-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٥<span class="dash">-</span></span> و<span class="name-2">إبراهيم النخعي</span> -من طريق مُغيرة-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٦<span class="dash">-</span></span> و<span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق مُغيرة-، مثله{5}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن سفيان- أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿تتخذون منه سكرًا ورزقًا حسنًا﴾</span>. قال: السكر: ما حرم من ثمرتها. والرزقُ الحسنُ: ما حَلَّ مِن ثمرتها{6}. (٩/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: السَّكَرُ: الخَلُّ، والنبيذ، وما أشْبَهَه. والرزقُ الحسَنُ: التمرُ، والزبيبُ، وما أشْبَهَه{7}. (٩/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: السَّكَرُ: الحرامُ منه. والرزقُ الحَسَنُ: زَبِيبُه، وخَلُّه، وعنبُه، ومنافعُه{8}. (٩/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرًا ورزقًا حسنًا﴾</span>، قال: فحَرَّم اللهُ بعدَ ذلك السَّكَرَ مع تحريم الخمر؛ لأنه منه، ثم قال: <span class="qpc-hafs">﴿ورزقًا حسنًا﴾</span> فهو الحلالُ مِن الخَلِّ، والزبيبِ، والنبيذ، وأشْباهِ ذلك، فأقَرَّه اللهُ، وجعَله حلالًا للمسلمين{9}. (٩/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرًا﴾</span>، قال: إن الناسَ كانوا يُسَمُّون الخمرَ: سَكَرًا، وكانوا يشرَبونها، ثم سَمّاها اللهُ بعدَ ذلك: الخمرَ، حين حُرِّمَت. وكان <span class="name-1">ابن عباس</span> يزعُمُ أن الحبشة يُسَمُّون الخلَّ: السَّكَرَ. وقوله: <span class="qpc-hafs">﴿ورزقًا حسنًا﴾</span>، يعني: بذلك الحلالَ؛ التمرَ، والزبيبَ، وما كان حلالًا لا يُسْكِر{10}. (٩/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق سعيد بن جبير- أنه سُئِل عن السَّكَرِ. فقال: الخمرُ بعينِها{11}. (٩/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٣<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق أبي فروة- قال: السَّكَرُ: خمر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي حصين- قال: السَّكَرُ الحرامُ، والرزقُ الحسنُ الحلال{13}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي كدينة، عن ليث- قال: السَّكَرُ: الخمر. والرزق الحسن: الرطب، والأعناب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مندل، عن ليث- <span class="qpc-hafs">﴿تتخذون منه سكرا ورزقا حسنا﴾</span>، قال: ما كانوا يتخذون من النخل النبيذ، والرزق الحسن: ما كانوا يصنعون من الزبيب والتمر{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن مجاهد- <span class="qpc-hafs">﴿تتخذون منه سكرا﴾</span>، قال: هي الخمر قبل أن تحرم، <span class="qpc-hafs">﴿ورزقا حسنا﴾</span> طعامًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٨<span class="dash">-</span></span> عن عبيد، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرا﴾</span>: يعني: ما أسكر من العنب والتمر، <span class="qpc-hafs">﴿ورزقا حسنا﴾</span> يعني: ثمرتها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٣٩<span class="dash">-</span></span> عن أبي روق، قال: قلت ل<span class="name-2">لشعبي</span>: أرأيت قوله تعالى: <span class="qpc-hafs">﴿تتخذون منه سكرا﴾</span>، أهو هذا السَّكَرُ الذي تصنعه النبَط؟ قال: لا، هذا خمر، إنما السَّكَرُ الذي قال الله -تعالى ذكره-: النبيذ، والخل. والرزق الحسن: التمر، والزبيب{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٠<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: السَّكَرُ: ما شربت. والرزق الحسن: ما أكلت{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرًا﴾</span>، قال: ذَكَر الله نعمته في السَّكَر قبل تحريم الخمر{20}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور، وعوف- قال: السَّكَرُ: ما حرم الله منه. والرزق: ما أحل الله منه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</span>: أما السكر: فخمور هذه الأعاجم. وأما الرزق الحسن: فما تنتبذون، وما تُخلِّلون، وما تأكلون{22}. (٩/٧١) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٤<span class="dash">-</span></span> عن <span class="name-2">منصور بن المعتمر</span> -من طريق هشيم- قال: السَّكَرُ: ما حرم الله منه. والرزق: ما أحل الله منه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿سكرا ورزقا حسنا﴾</span>، قال: السَّكَرُ: النبيذ. قال: والرزق الحسن: الزبيب{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿ومِن ثَمَراتِ النَّخِيلِ والأَعْنابِ تَتَّخِذُونَ مِنهُ سَكَرًا﴾</span> يعني بالثمرات: لأنها جماعة ثمر. يعني بالسكر: ما حرم من الشراب مما يسكرون من ثمره، يعني: النخيل والأعناب، <span class="qpc-hafs">﴿ورِزْقًا حَسَنًا﴾</span> يعني: طيبًا -نسختها الآية التي في المائدة، كقوله ﷿: <span class="qpc-hafs">﴿قَرْضًا حَسَنًا﴾</span> [البقرة:٢٤٥]، يعني: طيبة بها أنفسهم- بما لا يسكر منها من الشراب وثمرتها؛ فهذا الرزق الحسن{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرا ورزقا حسنا﴾</span>، قال: الحلال: ما كان على وجه الحلال، حتى غيَّروها، فجعلوا منها سكرًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</span>، أي: وجعل لكم من ثمرات النخيل والأعناب ما تتخذون منه سكرًا، ورزقًا حسنًا{27}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿إنَّ فِي ذلِكَ لَآيَةً لِقَوْمٍ يَعْقِلُونَ﴾</span>، يعني: فيما ذُكِر من اللبن والثمار لعبرة لقوم يعقلون بتوحيد الله ﷿{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿إن في ذلك لآية لقوم يعقلون﴾</span> هي مثل الأولى{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٤١٥٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٢<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عمر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٣<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٤<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، قالوا: وهذا قبل تحريم الخمر{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: السَّكَرُ: النَّبيذُ. والرزقُ الحسنُ: الزَّبيبُ. فنسَخَتْها هذه الآية: <span class="qpc-hafs">﴿إنما الخمر والميسر﴾</span> [المائدة:٩٠]{31}. (٩/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٧<span class="dash">-</span></span> و<span class="name-2">عامر الشعبي</span> -من طريق مغيرة- في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرًا﴾</span>، قالا: هي منسوخة{32}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٨<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٥٩<span class="dash">-</span></span> و<span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٠<span class="dash">-</span></span> و<span class="name-2">أيوب [السختياني]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦١<span class="dash">-</span></span> و<span class="name-3">محمد بن السائب الكلبي</span>، قالوا: وهذا قبل تحريم الخمر{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٢<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span> -من طريق ابن مجاهد-: <span class="qpc-hafs">﴿سكرا﴾</span> الخمر قبل تحريمها{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿تتخذون منه سكرًا﴾</span>، قال: خُمُورَ الأعاجم، ونُسِخت في سورة المائدة{35}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تتخذون منه سكرًا ورِزْقًا حَسَنًا﴾</span>، نسختها الآية التي في المائدة{36}{25}<span class=comment-ref>٣٦٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٧</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿تتخذون منه سكرا ورزقا حسنا﴾</span> على أقوال: <b>الأول</b>: عنى بالسكر: الخمر. وبالرزق الحسن: التمر والزبيب. وقال أصحاب هذا القول: إنما نزلت هذه الآية قبل تحريم الخمر، ثم حرمت بعد. <b>الثاني</b>: السكر بمنزلة الخمر في التحريم، وليس بخمر، وقالوا: هو نقيع التمر والزبيب إذا اشتد وصار يسكر شاربه. <b>الثالث</b>: السكر: هو كل ما كان حلالًا شربه؛ كالنبيذ الحلال، والخل، والرطب. والرزق الحسن: التمر، والزبيب. وقد <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٤/٢٨٤-٢٨٥ بتصرف) على القول الثالث بقوله: «وعلى هذا التأويل الآية غير منسوخة، بل حكمها ثابت».</p><p>ثم <span class="comment-type-3">رجّحه</span>، <span class="comment-type-3">ورجّح</span> عدم النسخ في الآية، و<span class="comment-type-2">انتقد</span> بقية الأقوال <span class="mustanad">مستندًا إلى لغة العرب، وعدم وجود دليل على النسخ</span>، وقال: «وذلك أن السكر في كلام العرب على أحد أوجه أربعة: أحدها: ما أسكر من الشراب. والثاني: ما طعم من الطعام. والثالث: السكون. والرابع: المصدر من قولهم: سكر فلان يسكر سُكْرًا وسَكْرًا وسَكَرًا، فإذا كان ذلك كذلك، وكان ما يسكر من الشراب حرامًا، وكان غير جائز لنا أن نقول: هو منسوخ، إذ كان المنسوخ هو ما نفى حكمه الناسخ، وما لا يجوز اجتماع الحكم به وناسخه، ولم يكن في حكم الله -تعالى ذكره- بتحريم الخمر دليل على أن السكر الذي هو غير الخمر وغير ما يسكر من الشراب حرام، إذ كان السكر أحد معانيه عند العرب، ومن نزل بلسانه القرآن هو كل ما طعم، ولم يكن مع ذلك، إذ لم يكن في نفس التنزيل دليل على أنه منسوخ، أو ورد بأنه منسوخ خبر من الرسول، ولا أجمعت عليه الأمة؛ فوجب القول بما قلنا من أن معنى السكر في هذا الموضع: هو كل ما حل شربه مما يتخذ من ثمر النخل والكرم، وفسد أن يكون معناه: الخمر، أو ما يسكر من الشراب، وخرج من أن يكون معناه: السكر نفسه؛ إذ كان السكر ليس مما يتخذ من النخل والكرم، ومن أن يكون بمعنى السكون».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٥/٣٧٩): «والسكر: ما يسكر. هذا هو المشهور في اللغة».</p><p>و<span class="comment-type-2">انتقد</span> دعوى النسخ، فقال: «وقال بعض الفرقة التي رأت السكر الخمر: إنّ هذه الآية منسوخة بتحريم الخمر. وفي هذه المقالة درك؛ لأن النسخ إنما يكون في حكم مستقر مشروع».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٦٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٥٦٥<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول ﷺ: «<b>لكم في العنبِ أشياءُ؛ تأكُلون عنبًا، وتشرَبونه عصيرًا ما لم يَنِشَّ</b>{38}، <b>وتتخِذون منه زَبِيبًا، ورُبًّا</b>{39}»{40}. (٩/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إن الخمر من هاتين الشجرتين: النخلة، والعنبة</b>»{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٧<span class="dash">-</span></span> عن أبي بردة بن أبي موسى الأشعري، قال: قال <span class="name-1">عمر بن الخطاب</span>: إنّ هذه الأنبذة تنبذ من خمسة أشياء: من التمر، والزبيب، والعسل، والبر، والشعير، فما خمَّرتم منه فعتقتم فهو خمر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٧٨. وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه يحيى بن سلام ١/٧٣.أخرجه عبد الرزاق في تفسيره ٢/٣٥٧ بلفظ: ونسخت في سورة المائدة، وابن جرير ١٤/٢٨٠، والنحاس في ناسخه ٢/٤٨٦ بنحوه.أخرجه ابن أبي شيبة ٢٠/٤٨٧، وابن جرير ١٤/٢٨٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٧/٤٨٧.أخرجه يحيى بن سلام ١/٧٣، وعبد الرزاق ١/٣٥٧، وأبي داود -كما في تغليق التعليق ٤/٢٣٧، وفتح الباري ٨/٣٨٧-، وابن جرير ١٤/٢٧٥-٢٧٨، والنحاس ص٤٥٢، والحاكم ٢/٣٥٥، والبيهقي في سننه ٨/٢٩٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وأبو داود في ناسخه، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى الفريابي، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٤/٢٨٢، والبيهقي ٨/٢٩٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨١ بنحوه. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ٧/٤٨٨ بلفظ: أنه سئل عن السكر؟ فقال: الخمر ليس لها كنية. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨٢.أخرجه النسائي في الكبرى (٦٧٨٩).أخرجه ابن جرير ١٤/٢٨٠.أخرجه ابن جرير ١٤/٢٨٤.أخرجه يحيى بن سلام ١/٧٢، وأخرج أوله ابن جرير ١٤/٢٨٠ من طريق ليث.أخرجه ابن جرير ١٤/٢٨٣.أخرجه ابن جرير ١٤/٢٨٣.تفسير الثعلبي ٦/٢٧، وتفسير البغوي ٥/٢٨.أخرجه ابن جرير ١٤/٢٧٩. وعزاه السيوطي إلى ابن المنذر بلفظ: ذكَر اللهُ نعمتَه عليهم في الخمرِ قبلَ أن يُحَرِّمَها عليهم.أخرجه ابن جرير ١٤/٢٧٩.أخرجه ابن جرير ١٤/٢٨٠، والنحاس في ناسخه (ت: اللاحم) ٢/٤٨٦ بنحوه. كذلك أخرجه يحيى بن سلام نحوه ١/٧٣ من طريق همام وعثمان، وعبد الرزاق في تفسيره ٢/٣٥٧ بنحوه من طريق معمر.أخرجه ابن جرير ١٤/٢٧٩.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء الخراساني) ص٩٦.تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن جرير ١٤/٢٨٣.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٣.تفسير الثعلبي ٦/٢٧، وتفسير البغوي ٥/٢٨.عزاه السيوطي إلى أبي داود في ناسخه، وابن المنذر، وابن أبي حاتم.أخرجه البيهقي ٨/٢٩٧. وعزاه السيوطي إلى ابن الأنباري.تفسير الثعلبي ٦/٢٧.علَّقه يحيى بن سلام ١/٧٢.أخرجه عبد الرزاق ١/٣٥٧ من طريق معمر، والنحاس ص٥٤٢. وعزاه السيوطي إلى ابن الأنباري في المصاحف.يشير إلى قوله تعالى: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إنَّما الخَمْرُ والمَيْسِرُ والأَنْصابُ والأَزْلامُ رِجْسٌ مِن عَمَلِ الشَّيْطانِ فاجْتَنِبُوهُ لَعَلَّكُمْ تُفْلِحُونَ. إنَّما يُرِيدُ الشَّيْطانُ أنْ يُوقِعَ بَيْنَكُمُ العَداوَةَ والبَغْضاءَ فِي الخَمْرِ والمَيْسِرِ ويَصُدَّكُمْ عَنْ ذِكْرِ اللَّهِ وعَنِ الصَّلاةِ فَهَلْ أنْتُمْ مُنْتَهُونَ﴾</span> [المائدة:٩٠-٩١].تفسير مقاتل بن سليمان ٢/٤٧٦.النَّشِيش: أول أخْذ العصير في الغليان، والخمر تَنِشُّ إذا أخذت في الغليان. لسان العرب (نشش).ارتب العنب: إذا طبخ حتى يكون رُبًّا يؤتدم به. اللسان (ربب).أخرجه العقيلي في الضعفاء ١/٩٣ (١٠٥) في ترجمة إسماعيل بن مسلم اليشكري، والخطيب في تاريخ بغداد ٢/١٠٦ (١٨٢).</p><p>قال العقيلي: «إسماعيل بن مسلم اليشكري عن ابن عون لا يعرف بنقل الحديث، وحديثه منكر غير محفوظ». وقال السيوطي في اللآلئ المصنوعة ٢/١٧٨: «لا يصح». وقال ابن عراق الكناني في تنزيه الشريعة ٢/٢٣٥: «ولا يصح».أخرجه مسلم ٣/١٥٧٣ (١٩٨٥)، ويحيى بن سلام ١/٧٣. وأورده الثعلبي ٢/١٤٤.أخرجه يحيى بن سلام ١/٧٣.
  16,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَوۡحَىٰ رَبُّكَ إِلَى ٱلنَّحۡلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأوحى ربُّك إلى النحل﴾</span>، قال: ألْهَمَها{1}. (٩/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوْفي- في قوله: <span class="qpc-hafs">﴿وأوحى ربك إلى النحل﴾</span>، قال: أمَرها أن تأكُلَ مِن كلِّ الثمرات، وأمَرَها أن تَتَّبِعَ سُبُلَ ربِّها ذُلُلًا{2}. (٩/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي الصباح، عن رجل- في قوله: <span class="qpc-hafs">﴿وأوحى ربك إلى النحل﴾</span>، قال: ألْهَمَها إلهامًا{3}. (٩/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿وأوحى ربك إلى النحل﴾</span>، قال: ألْهَمَها إلهامًا، ولم يُرسِلْ إليها رسولًا{4}. (٩/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: النحلُ دابةٌ أصغرُ مِن الجُندُب، ووَحْيُه إليها قَذْفٌ في قلوبِها{1}. (٩/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قول الله: <span class="qpc-hafs">﴿وأوحى ربك إلى النحل﴾</span>، وقوله: <span class="qpc-hafs">﴿وإذ أوحيت إلى الحواريين﴾</span> [المائدة:١١١]، <span class="qpc-hafs">﴿وأوحينا إلى أم موسى﴾</span> [القصص:٧]: إلهام ألْهَمَهُم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: وكل شيء من الحيوان إلهام{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وأوحى ربك إلى النحل﴾</span>، قال: قذف في أنفسها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وأَوْحى رَبُّكَ إلى النَّحْلِ﴾</span> إلهامًا من الله ﷿، يقول: قذف فيها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأوحى ربك إلى النحل﴾</span>، أي: ألهمها{10}<span class=comment-ref>٣٦٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٨</span> ذكر <u>ابنُ عطية</u> (٥/٣٧٩) عدة معانٍ للوحي، ثم <span class="comment-type-4">بيَّن</span> أن الوحي في هذه الآية هو وحي الإلهام <span class="mustanad">باتفاق المتأولين</span>.</div></p><p><h3><span class="qpc-hafs">﴿أَنِ ٱتَّخِذِی مِنَ ٱلۡجِبَالِ بُیُوتࣰا وَمِنَ ٱلشَّجَرِ وَمِمَّا یَعۡرِشُونَ ۝٦٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنِ اتَّخِذِي مِنَ الجِبالِ بُيُوتًا ومِنَ الشَّجَرِ ومِمّا يَعْرِشُونَ﴾</span>، يعني: ومما يبنون من البيوت{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يعرشون﴾</span>، قال: الكَرْمُ{12}<span class=comment-ref>٣٦٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٩</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (١٤/٢٨٦-٢٨٧) أن قوله: <span class="qpc-hafs">﴿مما يعرشون﴾</span> معناه: ما يبنون من السقوف. وذكر قول ابن زيد، ولم يعلق عليه.</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٥/٣٧٩-٣٨٠) أن عَرَشَ معناه: هيَّأ، وأكثر ما يستعمل فيما يكون من اتفاق الأغصان والخشب وترتيب ظلالها، ومنه العريش الذي صُنع لرسول الله ﷺ يوم بدر، ومن هذا هي لفظة العرش«. ثم ذكر <u>ابن عطية</u> قول ابن زيد، وقول <u>ابن جرير</u> أن يعرشون معناه: ما يبنون من السقوف. و<span class="comment-type-2">انتقدهما</span>، فقال:»وهذا منهما تفسير غير متقن". ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٤١٥٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أن اتخذي من الجبال بيوتا ومن الشجر ومما يعرشون﴾</span>، أي: ومما يبنون{10}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٨٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.جامع ابن وهب -تفسير القرآن ٢/٥٣-٥٤ (١٠٣).علَّقه يحيى بن سلام ١/٧٣.أخرجه عبد الرزاق في تفسيره ٢/٣٥٧، وابن جرير ١٤/٢٨٦ وأبهمه قائلًا: عن معمر عن أصحابه.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٣.تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن جرير ١٤/٢٨٧.تفسير يحيى بن سلام ١/٧٣.
  16,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ كُلِی مِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ فَٱسۡلُكِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ كُلِي مِن كُلِّ الثَّمَراتِ فاسْلُكِي﴾</span>، يقول: فادخلي{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سُبُلَ رَبِّكِ ذُلُلࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فاسلُكي سبل ربك ذللًا﴾</span>، قال: طُرُقًا، لا يَتَوعَّرُ عليها مكانٌ سَلَكَتْه{2}. (٩/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فاسلكي سبل ربك ذللًا﴾</span>، قال: مُطِيعةً{3}<span class=comment-ref>٣٧٠٠</span>. (٩/٧٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٠</span> ذكر <u>ابن كثير</u> (٨/٣٢٥) قول قتادة ونحوه عن ابن زيد، و<span class="comment-type-4">علّق</span> عليه، فقال: «وقال قتادة، وعبد الرحمن بن زيد بن أسلم: <span class="qpc-hafs">﴿فاسلكي سبل ربك ذللا﴾</span> أي: مطيعة. فجعلاه حالًا من السالكة».</div></p><p><div></p><p><p><span class="item-no">٤١٥٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فاسلكي سبل ربك ذللًا﴾</span>، قال: ذَلِيلةً لذلك{4}. (٩/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سُبُلَ رَبِّكِ﴾</span> في الجبال، وخلل الشجر، <span class="qpc-hafs">﴿ذُلُلًا﴾</span> لأن الله تعالى ذلَّل لها طرقها حيثما توجهت{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في الآية، قال: الذَّلُولُ الذي يُقادُ ويُذْهَبُ به حيثُ أراد صاحبُه. قال: فهم يَخْرُجون بالنحل، ويَنتَجِعون{6} بها، ويذهَبون وهي تَتْبَعُهم. وقرأ: <span class="qpc-hafs">﴿أولم يروا أنا خلقنا لهم مما عملت أيدينا أنعامًا فهم لها مالكون * وذللناها لهم﴾</span> الآية [يس:٧١-٧٢]{7}. (٩/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٨٧<span class="dash">-</span></span> قال سعيد: سمعت <span class="name-3">سفيان [بن عيينة]</span> يقول في قوله: <span class="qpc-hafs">﴿فاسلكي سبل ربك ذللا﴾</span>، قال: ليس يُعْيِيها جبل ولا غيره{8}<span class=comment-ref>٣٧٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠١</span> في قوله تعالى: <span class="qpc-hafs">﴿ذللا﴾</span> قولان: <b>الأول</b>: مذللة لك. <b>الثاني</b>: مطيعة. وقد ذكر <u>ابن جرير</u> (١٤/٢٨٨) القولين، <span class="comment-type-4">وعلَّق</span> على الأول وهو قول مجاهد ومن وافقه، فقال: «وعلى هذا التأويل الذي تأوله مجاهد الذلل من نعت السبل. والتأويل على قوله: <span class="qpc-hafs">﴿فاسلكي سبل ربك ذللا﴾</span> الذلل لك: لا يتوعر عليك سبيل سلكتيه، ثم أسقطت الألف واللام فنصب على الحال». و<span class="comment-type-4">علَّق</span> على الثاني، فقال: «فعلى هذا القول الذلل من نعت النحل». و<span class="comment-type-4">علَّق</span> على القولين، فقال: «وكلا القولين غير بعيد من الصواب في الصحة؛ وجهان مخرجان».</p><p>ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى اللغة</span> القول الأول، فقال: «غير أنا اخترنا أن يكون نعتًا للسبل؛ لأنها إليها أقرب». أي: في الذِّكر.</p><p>ووافقه <u>ابنُ كثير</u> (٨/٣٢٥) بقوله: «والقول الأول أظهر، وهو أنه حال من الطريق، أي: فاسلكيها مذللة لك. نص عليه مجاهد».</div></p><p><div></p><p><p><span class="item-no">٤١٥٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ثم كلي من كل الثمرات فاسلكي سبل ربك﴾</span> طرق ربك التي جعل الله لك{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَخۡرُجُ مِنۢ بُطُونِهَا شَرَابࣱ مُّخۡتَلِفٌ أَلۡوَ ٰ⁠نُهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿يخرج من بطونها شرابٌ مختلفٌ ألوانه فيه شفاء للناس﴾</span>، يعني: العسل{10}. (٩/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، وفي قوله: <span class="qpc-hafs">﴿يخرج من بطونها شرابٌ مختلفٌ ألوانه﴾</span>، قال: هذا العسلُ{4}. (٩/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَخْرُجُ مِن بُطُونِها شَرابٌ﴾</span> يعني: عملًا{12}، <span class="qpc-hafs">﴿مُخْتَلِفٌ ألْوانُهُ﴾</span> أبيض وأصفر، وأحمر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يخرج من بطونها شراب﴾</span> يعني: العسل، <span class="qpc-hafs">﴿مختلف ألوانه﴾</span>{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِیهِ شِفَاۤءࣱ لِّلنَّاسِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٩٣<span class="dash">-</span></span> عن نافع: أن <span class="name-1">عبد الله بن عمر</span> كان لا يشكُو قُرْحَةً ولا شيئًا إلا جعَل عليه عسَلًا، حتى الدُّمَّلَ إذا كان به طَلاه عسَلًا، فقلنا له: تُداوِي الدُّمَّلَ بالعسل؟ فقال: أليس يقولُ الله: <span class="qpc-hafs">﴿فيه شفاءٌ للناس﴾</span>؟{15}<span class=comment-ref>٣٧٠٢</span>. (٩/٧٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٥/٣٨١): «وقوله: <span class="qpc-hafs">﴿فِيهِ شِفاءٌ لِلنّاسِ﴾</span> الضمير للعسل، قاله الجمهور، ولا يقتضي العموم في كل علة، وفي كل إنسان، بل هو خبر عن أنه يشفي كما يشفي غيره من الأدوية في بعض، وعلى حال دون حال، ففي الآية إخبار منبه على أنه دواء لمّا كَثُرَ الشفاء به، وصار خليطًا ومعينًا للأدوية والأشربة والمعاجين». ثم ذكر هذا الأثر عن ابن عمر، و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا يقتضي أنه يرى الشفاء به على العموم».</div></p><p><div></p><p><p><span class="item-no">٤١٥٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿فيه شفاء للناس﴾</span>، قال: في القرآن شفاء{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿شراب مختلف ألوانه فيه شفاء للناس﴾</span>، قال: هو العسلُ فيه الشِّفاءُ، وفي القرآن{17}. (٩/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق ثابت- في قوله: <span class="qpc-hafs">﴿يخرج من بطونها شراب مختلف ألوانه فيه شفاء للناس﴾</span>، قال: يعني: القرآن{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يخرج من بطونها شراب مختلف ألوانه، فيه شفاء للناس﴾</span>: ففيه شفاء -كما قال الله تعالى- من الأدواء، وقد كان ينهى عن تغريق النحل، وعن قتلها{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿يخرج من بطونها شرابٌ مختلفٌ ألوانه﴾</span> قال: هذا العسلُ، <span class="qpc-hafs">﴿فيه شفاء للناس﴾</span> يقول: فيه شفاءُ الأوجاع التي شِفاؤُها فيه{4}. (٩/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِ شِفاءٌ لِلنّاسِ﴾</span>، يعني: العسل شفاء لبعض الأوجاع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يخرج من بطونها شراب﴾</span> يعني: العسل، <span class="qpc-hafs">﴿مختلف ألوانه فيه شفاء للناس﴾</span> دواء{9}<span class=comment-ref>٣٧٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٣</span> اختلف السلف فيما عنى الله بقوله: <span class="qpc-hafs">﴿فيه شفاء للناس﴾</span> على قولين: <b>الأول</b>: أنه القرآن. <b>الثاني</b>: أنه العسل.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٤/٢٩١) القول الثاني <span class="mustanad">مستندًا إلى السياق</span>، وعلل ذلك بقوله: «لأن قوله: <span class="qpc-hafs">﴿فيه﴾</span> في سياق الخبر عن العسل، فأن تكون الهاء من ذكر العسل إذ كانت في سياق الخبر عنه أولى من غيره».</p><p>و<span class="comment-type-4">كذا</span> <u>ابنُ كثير</u> (٨/٣٢٦-٣٢٩) <span class="mustanad">مستندًا إلى السنة</span>، وذكر عدة أحاديث في كون العسل شفاء.</p><p>و<span class="comment-type-4">بنحوهما</span> <u>ابنُ القيم</u> (٢/١١٣بتصرف)، حيث قال: «الصحيح: رجوع الضمير إلى الشراب، وهو قول ابن مسعود، وابن عباس، والحسن، وقتادة، والأكثرين، فإنه هو المذكور، والكلام سيق لأجله، ولا ذكر للقرآن في الآية، وهذا الحديث الصحيح وهو قوله: «<b>صدق الله</b>» كالصريح فيه».</p><p>وذكر <u>ابنُ كثير</u> (٨/٣٢٦) القول الأول عن مجاهد، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للسياق</span> قائلًا: «وهذا قول صحيح في نفسه، ولكن ليس هو الظاهر هاهنا من سياق الآية؛ فإن الآية إنما ذكر فيها العسل، ولم يتابع مجاهد على قوله هاهنا، وإنما الذي قاله ذكروه في قوله تعالى: <span class="qpc-hafs">﴿وننزل من القرآن ما هو شفاء ورحمة للمؤمنين﴾</span> الآية [الإسراء:٨٢]، وقوله تعالى: <span class="qpc-hafs">﴿يا أيها الناس قد جاءتكم موعظة من ربكم وشفاء لما في الصدور وهدى ورحمة للمؤمنين﴾</span> [يونس:٥٧]».</p><p>وذكر <u>ابنُ عطية</u> (٥/٣٨١) قولًا ثالثًا، <span class="comment-type-2">وانتقده</span> <span class="mustanad">مستندًا لدلالة العقل</span>، فقال: «وذهب قوم من أهل الجهالة إلى أن هذه الآية إنما يراد بها: أهل البيت ورجال بني هاشم، وأنهم النحل، وأن الشراب: القرآن والحكمة، وقد ذكر بعضهم هذا في مجلس المنصور أبي جعفر العباسي: فقال له رجل ممن حضر: جعل الله طعامك وشرابك مما يخرج من بطون بني هاشم. فأضحك الحاضرين، وبهت الآخر، وظهرت سخافة قوله».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ فِي ذلِكَ لَآيَةً﴾</span> يعني: فيما ذُكِر من أمر النحل وما يخرج من بطونها لَعبرة <span class="qpc-hafs">﴿لِقَوْمٍ يَتَفَكَّرُونَ﴾</span> في توحيد الله ﷿{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٦٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٦٠٢<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>عليكم بالشِّفاءَين: العسل، والقرآن</b>»{24}. (٩/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الأسود- قال: عليكم بالشِّفاءَين: العسلِ، والقرآن{25}. (٩/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٤<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبيّ ﷺ، قال: «<b>الشفاءُ في ثلاثة: في شَرْطةِ مِحْجَمٍ، أو شَرْبةِ عسل، أو كَيَّةٍ بنار، وأنا أنهى أُمَّتي عن الكَيِّ</b>»{26}. (٩/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٥<span class="dash">-</span></span> عن معاوية بن حُدَيْجٍ، قال: قال رسول الله ﷺ: «<b>إن كان في شيءٍ شِفاءٌ؛ ففي شَرْطةِ مِحْجَم، أو شَرْبة مِن عسل، أو كَيَّةٍ بنار تُصِيبُ ألَمًا، وما أُحِبُّ أن أكْتَوِيَ</b>»{27}. (٩/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٦<span class="dash">-</span></span> عن أبي سعيد الخدري، أن رجلًا أتى النَّبي ﷺ، فقال: يا رسول الله، إن أخي اسْتَطْلَقَ بطنُه. فقال: «<b>اسْقِه عَسَلًا</b>». فسَقاه عسلًا، ثم جاء، فقال: سقيتُه عسلًا، فما زادَه إلا اسْتِطْلاقًا. فقال رسول الله ﷺ: «<b>اذهبْ، فاسقِه عسلًا</b>». فذهَب، فسقاه عسلًا، ثم جاء، فقال: ما زاده إلا اسْتِطْلاقًا. قال رسول الله ﷺ: «<b>صَدَق اللهُ، وكَذَب بطنُ أخيك، اذهَبْ، فاسْقِه عسَلًا</b>». فذهَب، فسَقاه، فبَرَأَ{28}. (٩/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>مَن لَعِقَ العسلَ ثلاثَ غَدَواتٍ كلَّ شهرٍ لم يُصِبْه عظيمٌ مِن البلاء</b>»{29}. (٩/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٨<span class="dash">-</span></span> عن عامر بن مالك، قال: بعَثْتُ إلى النبيِّ ﷺ مِن وعْك كان بي ألتمسُ منه دواءً أو شفاءً، فبعَث إلَيَّ بِعُكَّةٍ{30} مِن عسل{31}. (٩/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: إنّ العسلَ شفاءٌ مِن كلِّ داءٍ، والقرآن شفاءٌ لما في الصدور{32}. (٩/٧٤)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن جرير ١٤/٢٨٧-٢٨٨ كذلك من طريق ابن جريج. وعلقه يحيى بن سلام ١/٧٤، وعقَّب عليه بقوله: يعني: أنت مطيعة. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ١/٣٥٧ من طريق معمر، وابن جرير ١٤/٢٨٨. وعلقه يحيى بن سلام ١/٧٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٦.النُجعة: طلب الكلأ ومساقط الغيث. اللسان (نجع).أخرجه ابن جرير ١٤/٢٨٨-٢٨٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه سعيد بن منصور في سننه - التفسير ٦/٦٢ (١٢٣٠).تفسير يحيى بن سلام ١/٧٤.أخرجه ابن جرير ١٤/٢٩١.عزاه السيوطي إلى ابن أبي حاتم.كذا في مطبوعة المصدر، ولعلها: عسلًا.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٤.عزاه السيوطي إلى حميد بن زَنجُويه.أخرجه ابن أبي شيبة ١٠/٤٨٦، وابن جرير ١٤/٢٨٩.عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن أبي حاتم.أخرجه العقيلي في كتاب الضعفاء ٣/٥١ (٧٨٣).أخرجه ابن جرير ١٤/٢٩٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٦.تفسير يحيى بن سلام ١/٧٤.تفسير مقاتل بن سليمان ٢/٤٧٦.أخرجه ابن ماجه ٤/٥٠٧ (٣٤٥٢)، والحاكم ٤/٤٤٧ (٨٢٢٥)، عن زيد بن الحباب، عن سفيان، عن أبي إسحاق، عن أبي الأحوص، عن عبد الله مرفوعًا.أخرجه ابن أبي شيبة ١٠/٤٨٥، والطبراني (٨٩١٠). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه البخاري ٧/١٢٢-١٢٣ (٥٦٨٠، ٥٦٨١).أخرجه أحمد ٤٥/٢٢٩ (٢٧٢٥٦).</p><p>قال الهيثمي في المجمع ٥/٩١ (٨٣١٣): «ورجال أحمد رجال الصحيح، خلا سويد بن قيس، وهو ثقة». وقال الصالحي في سبل الهدى والرشاد ١٢/١٤٧: «رجال ثقات».أخرجه البخاري ٧/١٢٣ (٥٦٨٤)، ٧/١٢٨ (٥٧١٦)، ومسلم ٤/١٧٣٦، ١٧٣٧ (٢٢١٧).أخرجه ابن ماجه ٤/٥٠٦ (٣٤٥٠)، من طريق الزبير بن سعيد الهاشمي، عن عبد الحميد بن سالم، عن أبي هريرة به.</p><p>إسناده ضعيف منقطع. قال العقيلي في الضعفاء ٣/٤٠ (٩٩٦) في ترجمة عبد الحميد بن سالم: «حدثني آدم بن موسى، قال سمعت البخاري قال: عبد الحميد بن سالم، عن أبي هريرة: «<b>من لعق العسل</b>»؛ لا يُعرف له سماع من أبي هريرة ... هذا الحديث ... ليس له أصل عن ثقة». وقال ابن الجوزي في الموضوعات ٣/٢١٥: «هذا حديث لا يصح». وقال الذهبي في المغني في الضعفاء ١/٣٦٩ (٣٤٩١): «الخبر منكر». وقال ابن كثير في تفسيره ٤/٥٨٤: «الزبير بن سعيد متروك». وقال البوصيري في مصباح الزجاجة ٤/٥٤ (٩٩١١): «هذا إسناد فيه لين، ومع ذلك فهو منقطع». وقال ابن حجر في الفتح ١٠/١٤٠: «سند ضعيف». وقال ابن عراق الكناني في تنزيه الشريعة ٢/٣٦٠ (٢٧): «لا يصح». وقال المناوي في التيسير ٢/٤٤٢: «وفيه انقطاع وضعف». وقال الألباني في الضعيفة ٢/١٨٣ (٧٦٢): «ضعيف».العكة: وعاء من جلود مستدير، يختص بالسمن والعسل، وهو بالسمن أخص. النهاية (عكك) ٣/٢٨٤.أخرجه ابن الأعرابي في معجمه ٢/٥٢٩-٥٣٠ (٩٩٧)، والبيهقي في الشعب ٨/٨٥-٨٦ (٥٥٣١)، وابن عساكر في تاريخ دمشق ٢٦/٩٨، من طرق عن إسماعيل بن بهرام، نا الأشجعي، عن مسعر، عن خشرم بن حسان، عن عامر به.</p><p>قال ابن عساكر: «تابعه (أي: ابن بهرام) موسى بن نصر، عن الفرات بن خالد، عن مسعر مرفوعًا. ورواه غيرهما عن مسعر مرسلًا». وفيه خشرم بن حسان ذكره البخاري في التاريخ ٣/٢١٧، ونقل عن أبي أحمد الزبيري أنه: «مرسل». وقال ابن حبان في الثقات ٦/٢٧٥: «يروي المراسيل».أخرجه ابن أبي شيبة ١٠/٤٨٥-٤٨٦، وابن جرير ١٤/٢٩٠، والحاكم ٤/٢٢٢.
  16,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ خَلَقَكُمۡ ثُمَّ یَتَوَفَّىٰكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿واللَّهُ خَلَقَكُمْ﴾</span> ولم تكونوا شيئًا؛ لتعتبروا في البعث، <span class="qpc-hafs">﴿ثُمَّ يَتَوَفّاكُمْ﴾</span> عند آجالكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ثم يتوفاكم﴾</span> يميتكم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنكُم مَّن یُرَدُّ إِلَىٰۤ أَرۡذَلِ ٱلۡعُمُرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦١٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الأصبغ بن نُباتة- في قوله: <span class="qpc-hafs">﴿ومنكم من يرد إلى أرذل العمر﴾</span>، قال: خمسٌ وسبعونَ سنة{3}<span class=comment-ref>٣٧٠٤</span>. (٩/٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٤</span> لم يذكر <u>ابنُ جرير</u> (١٤/٢٩٢) غير قول علي.</p><p>و<span class="comment-type-1">وجّهه</span> <u>ابنُ عطية</u> (٥/٣٨٢) بقوله: «وهذا في الأغلب، وهذا لا ينحصر إلى مدة معينة، وإنما هو بحسب إنسان وإنسان، والمعنى: منكم من يرد إلى أرذل عمره؛ ورب من يكون ابن خمسين سنة وهو في أرذل عمره، ورب ابن مائة وتسعين ليس في أرذل عمره».</div></p><p><div></p><p><p><span class="item-no">٤١٦١٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: أرذل العمر تسعون سنة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ومنكم من يرد إلى أرذل العمر﴾</span> الآية، قال: أرْذَلُ العُمُر: هو الخَرَف{5}. (٩/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِنكُمْ مَن يُرَدُّ إلى أرْذَلِ العُمُرِ﴾</span>، يعني: الهَرَم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومنكم من يرد إلى أرذل العمر﴾</span> إلى الهرم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِكَیۡ لَا یَعۡلَمَ بَعۡدَ عِلۡمࣲ شَیۡـًٔاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦١٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عاصم- قال: مَن قرَأ القرآن لم يُرَدَّ إلى أرذلِ العُمُر. ثم قرَأ: <span class="qpc-hafs">﴿لِكي لا يَعلَمَ بعد عِلم شيئًا﴾</span>{8}. (٩/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿لكي لا يعلم بعد علم شيئا﴾</span> يصير بمنزلة الطفل الذي لا يعقل شيئًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ عَلِیمࣱ قَدِیرࣱ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ اللَّهَ عَلِيمٌ﴾</span> بالبعث أنّه كائن، <span class="qpc-hafs">﴿قَدِيرٌ﴾</span> يعني: قادرًا عليه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ عَلِیمࣱ قَدِیرࣱ ۝٧٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٦٢٠<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>المولودُ حتى يَبْلُغَ الحِنثَ ما عَمِلَ مِن حسنةٍ أُثْبِت لوالدِه أو لوالدَيه، وإن عمِل سيئةً لم تُكْتَبْ عليه ولا على والدَيه، فإذا بلَغ الحِنثَ، وجَرى عليه القلم؛ أُمِر الملكان اللَّذان معه فحَفِظاه وسدَّداه، فإذا بلَغ أربعين سنةً في الإسلام أمَّنَه اللهُ من البَلايا الثلاثة؛ من الجنون، والجُذامِ، والبَرَص، فإذا بلَغ الخمسين ضاعَفَ اللهُ حسناتِه، فإذا بلَغ ستينَ رزَقه اللهُ الإنابة إليه فيما يُحِبُّ، فإذا بلَغ سبعينَ أحَبَّه أهلُ السماء، فإذا بلَغ ثمانين سنةً كتَب اللهُ حسناتِه وتجاوَز عن سيئاتِه، فإذا بلَغ تسعين سنةً غفَر الله ما تقدَّم مِن ذنبِه وما تأخَّر، وشَفَّعه في أهل بيته، وكان اسمُه عندَه أسيرَ اللهِ في أرضِه، فإذا بلَغ أرْذَلَ العُمُر -<span class="qpc-hafs">﴿لكي لا يعلم بعد علم شيئًا﴾</span>- كتَب اللهُ له مثلَ ما كان يعمَلُ في صحتِه من الخير، وإن عمِل سيئةً لم تُكْتَبْ عليه</b>»{11}. (٩/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢١<span class="dash">-</span></span> عن سعد بن أبي وقاص، عن النَّبي ﷺ أنه كان يَدْعو: «<b>اللهم، إني أعوذ بك من البُخْل، وأعوذ بك من الجُبْن، وأعوذ بك أن أُرَدَّ إلى أرذل العُمُر، وأعوذ بك من فتنة الدنيا، وأعوذ بك من عذاب القبر</b>»{12}. (٩/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٢<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابن طاووس- قال: إنّ العالِمَ لا يَخْرَفُ{13}. (٩/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٣<span class="dash">-</span></span> عن <span class="name-2">عبد الملك بن عُمير</span> -من طريق الحكم بن هشام الثقفي- قال: كان يقالُ: إنّ أبْقى الناسِ عُقُولًا قُرّاءُ القرآن{14}. (٩/٧٩)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٤.أخرجه ابن جرير ١٤/٢٩٢.تفسير الثعلبي ٦/٢٩، وتفسير البغوي ٥/٣٠.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٨٨-.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٤.أخرجه ابن أبي شيبة ١٠/٤٦٨. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلام ١/٧٤.تفسير مقاتل بن سليمان ٢/٤٧٧.أخرجه أحمد ٢١/١٢ (١٣٢٧٩)، وأبو يعلى (٣٦٧٨، ٤٢٤٦-٤٢٤٩)، واللفظ لأبي يعلى في الموضع الأول. وعزاه السيوطي إلى ابن مردويه.</p><p>قال محققو المسند: «إسناده ضعيف جدًّا».</p><p>وهو عند أحمد ٩/٤٤٥ (٥٦٢٦) مختصرًا موقوفًا على أنس.</p><p>وقال محققو المسند أيضًا: «إسناده ضعيف جدًّا».أخرجه البخاري (٦٣٧٠).أخرجه ابن أبي شيبة ١٤/٥٤.أخرجه ابن أبي شيبة ١٠/٤٦٨.
  16,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ فَضَّلَ بَعۡضَكُمۡ عَلَىٰ بَعۡضࣲ فِی ٱلرِّزۡقِۚ فَمَا ٱلَّذِینَ فُضِّلُوا۟ بِرَاۤدِّی رِزۡقِهِمۡ عَلَىٰ مَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿والله فضل بعضكم على بعض في الرزق﴾</span> الآية، يقول: لم يكونوا ليُشْرِكوا عبيدَهم في أموالهم ونسائهم، فكيف يُشرِكون عبيدي معي في سُلْطاني؟! فذلك قوله: <span class="qpc-hafs">﴿أفبنعمة الله يجحدون﴾</span>{1}. (٩/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- قال: هذه الآية في شأن عيسى ابن مريم، يعني بذلك: نفسه، إنما عيسى عبد، فيقول الله: واللهِ، ما تشركون عبيدكم في الذي لكم؛ فتكونوا أنتم وهم سواء، فكيف ترضون لي بما لا ترضون لأنفسكم؟!{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في الآية، قال: هذا مَثَلٌ لآلهةِ الباطل مع الله{3}. (٩/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والله فضل بعضكم على بعض في الرزق﴾</span> الآية، قال: هذا مَثَلٌ ضَرَبه الله، فهل منكم مِن أحدٍ يُشارِكُ مملوكَه في زوجتِه وفي فراشِه فتَعْدِلون بالله خلقَه وعبادَه؟! فإن لم تَرْضَ لنفسِك بهذا؛ فاللهُ أحقُّ أن تُبَرِّئَه مِن ذلك، ولا تَعْدِلْ بالله أحدًا مِن عبادِه وخلقِه{4}. (٩/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>، في الآية، قال: هذا مَثَلٌ ضرَبه الله في شأن الآلهة، فقال: كيف تَعْدِلون عبادي بي، ولا تَعْدِلون عبيدَكم بأنفسِكم، وتَرُدُّون ما فُضِّلْتُم به عليهم، فتكونون أنتم وهم في الرِّزْق سَواء؟!{5}. (٩/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّهُ فَضَّلَ بَعْضَكُمْ عَلى بَعْضٍ فِي الرِّزْقِ﴾</span> يعني: جعل بعضكم أحرارًا، وبعضكم عبيدًا، فوسَّع على بعض الناس، وقتَّر على بعض، <span class="qpc-hafs">﴿فَما الَّذِينَ فُضِّلُوا﴾</span> يعني: الرزق من الأموال <span class="qpc-hafs">﴿بِرادِّي رِزْقِهِمْ﴾</span> يقول: برادي أموالهم <span class="qpc-hafs">﴿عَلى ما مَلَكَتْ أيْمانُهُمْ﴾</span> يعني: عبيدهم؛ يقول: أفيشركونهم وعبيدهم في أموالهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٣٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿والله فضل بعضكم على بعض في الرزق فما الذين فضلوا﴾</span> يعني: في الرزق <span class="qpc-hafs">﴿برادي رزقهم على ما ملكت أيمانهم﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُمۡ فِیهِ سَوَاۤءٌۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٣١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ:</span> <span class="qpc-hafs">﴿فهم فيه سواء﴾</span>، يعني: شرعًا سواء{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهُمْ فِيهِ سَواءٌ﴾</span>، فيكونون فيه سواء، بأنهم قوم لا يعقلون شيئًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يقول: هل منكم من أحد يكون هو ومملوكه في أهله وماله سواء؟ أي: إنكم لا تفعلون ذلك بمملوككم حتى تكونوا في ذلك سواء؛ فالله أحق ألا يشرك به أحد من خلقه. وهو كقوله: <span class="qpc-hafs">﴿ضرب لكم مثلا من أنفسكم هل لكم من ما ملكت أيمانكم من شركاء في ما رزقناكم فأنتم فيه سواء تخافونهم كخيفتكم أنفسكم﴾</span> [الروم:٢٨] كخيفة بعضكم بعضًا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِنِعۡمَةِ ٱللَّهِ یَجۡحَدُونَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٣٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: والجحد لا يكون إلا من بعد المعرفة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَبِنِعْمَةِ اللَّهِ يَجْحَدُونَ﴾</span>، يعني: ينكرون بأن الله يكون واحدًا لا شريك له، وهو ربُّ هذه النِّعَم؟! يقول: كيف أُشْرِكُ الملائكةَ وغيرَهم في ملكي وأنتم لا ترضون الشركة من عبيدكم في أموال؟! فكما لا تدخلون عبيدكم في أموالكم فكذلك لا أدخل معي شريكًا في ملكي، وهم عبادي. وذلك حين قال كفار مكة في إحرامهم: لبيك لا شريك لك، إلا شريكًا هو لك، تملكه وما ملك. نظيرها في الروم: <span class="qpc-hafs">﴿ضَرَبَ لَكُمْ مَثَلًا مِن أنْفُسِكُمْ ...﴾</span> إلى آخر الآية [الروم:٢٨]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أفبنعمة الله يجحدون﴾</span> على الاستفهام، أي: قد جحدوا بنعمة الله{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِنِعۡمَةِ ٱللَّهِ یَجۡحَدُونَ ۝٧١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٦٣٧<span class="dash">-</span></span> عن الحسن البصري، قال: كتب <span class="name-1">عمر بن الخطاب</span> إلى أبي موسى الأشعري: اقْنَعْ برزقِك في الدنيا؛ فإنّ الرحمن فضَّل بعضَ عباده على بعض في الرزق، بَلاءً يَبْتلِي به كُلًّا، فيَبْتَلي به مَن بسَط له كيف شُكْرُه فيه، وشُكْرُه للهِ أداؤُه الحقَّ الذي افتَرض عليه فيما رزَقه وخَوَّلَه{14}. (٩/٨٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٩٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٩٤.أخرجه ابن جرير ١٤/٢٩٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٧٥، وابن جرير ١٤/٢٩٤-٢٩٥، وأخرجه عبد الرزاق ١/٣٥٨ من طريق معمر بنحوه، وكذلك ابن جرير ١٤/٢٩٤-٢٩٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.علَّقه يحيى بن سلام ١/٧٥.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.علَّقه يحيى بن سلام ١/٧٥.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٤/٥٠٥-.
  16,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ جَعَلَ لَكُم مِّنۡ أَنفُسِكُمۡ أَزۡوَ ٰ⁠جࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والله جعل لكم من أنفسكم أزواجًا﴾</span>، قال: خلق آدمَ، ثم خلَق زوجتَه منه{1}<span class=comment-ref>٣٧٠٥</span>. (٩/٨٢)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٥</span> لم يذكر <u>ابنُ جرير</u> (١٤/٢٩٥) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٤١٦٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّهُ جَعَلَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</span>، يقول: بعضكم من بعض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿والله جعل لكم من أنفسكم أزواجا﴾</span>، يعني: النساء، والنساء من الرجال{3}<span class=comment-ref>٣٧٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٦</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٥/٣٨٣) قول قتادة، فقال: «فمن حيث كانا مبتدأ الجميع ساغ حمل أمرهما على الجميع؛ حتى صار الأمر كأن النساء خلقن من أنفس الرجال». ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى النظائر</span> أن «<span class="qpc-hafs">﴿مِن أنْفُسِكُمْ﴾</span> أي: من نوعكم، وعلى خلقتكم، كما قال تعالى: <span class="qpc-hafs">﴿لَقَدْ جاءَكُمْ رَسُولٌ مِن أنْفُسِكُمْ﴾</span> [التوبة:١٢٨]».</div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلَ لَكُم مِّنۡ أَزۡوَ ٰ⁠جِكُم بَنِینَ وَحَفَدَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زر بن حُبيش- في قوله: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>، قال: الحَفَدةُ: الأَخْتانُ{4}{5}. (٩/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٢<span class="dash">-</span></span> عن <span class="name-2">زر بن حبيش</span>، قال: قال لي <span class="name-1">عبد الله بن مسعود</span>: ما الحفدة، يا زر؟ قال: قلت: هم أحفاد الرجل مِن ولده، وولد ولده. قال: لا، هم الأصهار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الحَفَدةُ: الأَصْهار{7}. (٩/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: الحَفَدةُ: الولدُ، وولدُ الولد{8}. (٩/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد، وسعيد بن جبير- في هذه الآية: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>، قال: الحفدة: البنون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: الحَفَدةُ: بنو البنين{10}. (٩/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبرني عن قوله ﷿: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>. قال: ولدُ الولد، وهم الأَعْوانُ. قال: وهل تعرِفُ العربُ ذلك؟ قال: نعم، أما سمِعتَ الشاعرَ وهو يقولُ:</p><p>حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُسْلِمَتْ بأَكُفِّهِنَّ أزِمَّةُ الأَجْمالِ؟{11}. (٩/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك بن مزاحم- أن نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>، ما البنون والحفدة؟ قال: أما بنوك فإنهم يعاطونك، وأما حفدتك فإنهم خدمك. قال: وهل كانت العرب تعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: نعم، أما سمعت قول أمية بن أبي الصلت الثقفي:</p><p>حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُلْقِيَت بأَكُفِّهِنَّ أزِمَّةُ الأَجْمالِ؟{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٤٩<span class="dash">-</span></span> عن أبي حمزة، قال: سُئِل <span class="name-1">عبد الله بن عباس</span> عن قوله: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>. قال: مَن أعانك فقد حفَدك، أما سمِعتَ قول الشاعر:</p><p>حَفَدَ الوَلائِدُ حَوْلَهُنَّ وأُسْلِمَتْ بأَكُفِّهِنَّ أزِمَّةُ الأَجْمالِ؟{6}. (٩/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: الحَفَدة: بنو امرأةِ الرجلِ ليسوا منه{14}. (٩/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿وجعل لكم من أزواجكم بنين وحفدة﴾</span> ... وقال: الحفدة: الرجل يعمل بين يدي الرجل، يقول: فلان يحفد لنا. ويزعم رجال: أنّ الحفدة: أختان الرجل{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الأختان{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- <span class="qpc-hafs">﴿بنين وحفدة﴾</span>، قال: الحفدة: الأختان{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- قال: الحفدة: الخَتَنُ{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٥<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- قال: الحفدة: هم الأصهار{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٦<span class="dash">-</span></span> عن <span class="name-2">أبي الضُّحى مسلم بن صبيح</span> -من طريق الأعمش- قال: الحفدة: الأختان{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: الحفدة: الخَدَم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بنين وحفدة﴾</span>، قال: ابنه، وخادمه{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله تعالى: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>، قال: أنصارًا، وأعوانًا، وخدامًا{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٠<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: هم الأعوان؛ مَن أعانك فقد حفدك{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- قال: هم الخَدَم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٢<span class="dash">-</span></span> عن عبيد بن سليمان، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿بنين وحفدة﴾</span>: يعني: ولد الرجل يحفدونه ويخدمونه، وكانت العرب إنما تخدمهم أولادهم الذكور{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- قال: الحَفَدةُ: الخُدّام{27}. (٩/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حصين- قال: هم الذين يُعِينون الرجل من ولده وخدمه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- <span class="qpc-hafs">﴿وحفدة﴾</span>، قال: الحفدة: مَن خدمك مِن ولدك{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٦<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابن طاووس- قال: الحفدة: الخدم{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السدي- قال: الحَفَدةُ: الأَعْوان{31}. (٩/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور- قال: هم الخدم{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٦٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي هلال الراسبي- قال: الحَفَدة: البنونَ، وبنو البنين، ومَن أعانَك مِن أهلٍ أو خادمٍ فقد حَفَدك{33}. (٩/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٠<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: هم ولد الرجل الذين يعينونه ويحفدونه ويرفدونه ويخدمونه{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿وجعل لكم من أزواجكم بنين وحفدة﴾</span>، مَهَنَةً{35} يمْهنُونك ويخدُمونك من ولدك، كرامة أكرمكم الله بها{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: البنين: الصغار. والحفدة: كبار الأولاد الذين يعينونه على عمله{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلَ لَكُمْ مِن أزْواجِكُمْ بَنِين﴾</span> يعني بالبنين: الصغار، <span class="qpc-hafs">﴿وحَفَدَةً﴾</span> والحفدة: [الكبار]{38}، يحفدون أباهم بالخدمة، وذلك أنهم كانوا في الجاهلية يخدمهم أولادهم{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجعل لكم من أزواجكم بنين وحفدة﴾</span>، قال: الحفدة: الخدم من ولد الرجل هم ولده، وهم يخدمونه، قال: وليس تكون العبيد من الأزواج، كيف يكون من زوجي عبد؟! إنما الحفدة: ولد الرجل، وخَدَمه{26}<span class=comment-ref>٣٧٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٧٠٧</span> اختلف السلف في المعني بالحفدة على أقوال: <b>الأول</b>: الأختان. <b>الثاني</b>: أعوان الرجل وخدمه. <b>الثالث</b>: ولد الرجل، وولد ولده. <b>الرابع</b>: بنو امرأة الرجل من غيره.</p><p>و<span class="comment-type-1">وجّه</span> <u>ابن عطية</u> (٥/٣٨٣) القول الثالث، فقال: «وقالت فرقة: الحفدة: هم البنون. وهذا يستقيم على أن تكون الواو عاطفة صفة لهم، كما لو قال: جعلنا لهم بنين وأعوانًا، أي: وهم لهم أعوان، فكأنه قال: وهم حفدة».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٤/٣٠٣-٣٠٤ بتصرف) <span class="mustanad">مستندًا إلى اللغة</span> أن الحفدة: هم المسرعون في خدمة الرجل، وأن ذلك يعم جميع هذه الأقوال، فقال: «والحفدة في كلام العرب: جمع حافد، والحافد في كلامهم: هو المتخفف في الخدمة والعمل، والحفد: خفة العمل، يقال: مر البعير يحفد حفدانًا: إذا مر يسرع في سيره، ومنه قولهم: إليك نسعى ونحفد، أي: نسرع إلى العمل بطاعتك ... وإذ كان معنى الحفدة ما ذكرنا من أنهم المسرعون في خدمة الرجل المتخففون فيها، وكان أولادنا وأزواجنا الذين يصلحون للخدمة منا ومن غيرنا، وأختاننا الذين هم أزواج بناتنا من أزواجنا، وخدمنا من مماليكنا، إذا كانوا يحفدوننا فيستحقون اسم حفدة، ولم يكن الله تعالى دل بظاهر تنزيله ولا على لسان رسوله ﷺ ولا بحجة عقل على أنه عنى بذلك نوعًا من الحفدة دون نوع منهم، وكان قد أنعم بكل ذلك علينا؛ لم يكن لنا أن نوجه ذلك إلى خاص من الحفدة دون عام، إلا ما اجتمعت الأمة عليه أنه غير داخل فيهم، وإذا كان ذلك كذلك فلكل الأقوال التي ذكرنا عمن ذكرنا وجه في الصحة، ومخرج في التأويل، وإن كان أولى بالصواب من القول ما اخترنا لما بينا من الدليل».</p><p>وذكر <u>ابنُ عطية</u> (٥/٣٨٣-٣٨٤) هذه الأقوال، ثم <span class="comment-type-4">علَّق</span> قائلًا: «ولا خلاف أن معنى الحفد: الخدمة، والبر، والمشي مسرعًا في الطاعة، ومنه في القنوت: «<b>وإليك نسعى ونحفد</b>» ... وهذه الفرق التي ذكرت أقوالها إنما بَنَتْ على أنّ كل أحد جعل له من زوجه بنون وحفدة، وهذا إنما هو في الغالب وعظم الناس». ثم ذكر <b>احتمالًا آخر</b>، فقال: «ويحتمل عندي أن قوله: <span class="qpc-hafs">﴿من أزواجكم﴾</span> إنما هو على العموم والاشتراك، أي: من أزواج البشر جعل الله لهم البنين، ومنهم جعل الخدمة فمن لم تكن له قط زوجة فقد جعل الله له حفدة، وحصل تحت النعمة، وأولئك الحفدة هم من الأزواج، وهكذا تترتب النعمة التي تشمل جميع العالم، وتستقيم لفظة»الحفدة«على مجراها في اللغة، إذ البشر بجملتهم لا يستغني أحد منهم عن حفدة».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٨/٣٣٢-٣٣٣) عليها قائلًا: «فمن جعل <span class="qpc-hafs">﴿وحفدة﴾</span> متعلقًا بـ<span class="qpc-hafs">﴿أزواجكم﴾</span> فلا بد أن يكون المراد: الأولاد، وأولاد الأولاد، والأصهار؛ لأنهم أزواج البنات، وأولاد الزوجة. وكما قال الشعبي والضحاك، فإنهم غالبًا يكونون تحت كنف الرجل، وفي حجره، وفي خدمته. وقد يكون هذا هو المراد من قوله عليه الصلاة والسلام في حديث بصرة بن أكثم: «<b>والولد عبد لك</b>». رواه أبو داود. وأما من جعل الحفدة: هم الخدم؛ فعنده أنه معطوف على قوله: <span class="qpc-hafs">﴿والله جعل لكم من أنفسكم أزواجا﴾</span>، أي: وجعل لكم الأزواج والأولاد، [وجعل لكم خدامًا]».</div></p><p><h3><span class="qpc-hafs">﴿وَرَزَقَكُم مِّنَ ٱلطَّیِّبَـٰتِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال الله ﷿ <span class="qpc-hafs">﴿ورَزَقَكُمْ مِنَ الطَّيِّباتِ﴾</span>، يعني: الحب، والعسل، ونحوه، وجعل رزق غيركم من الدواب والطير لا يشبه أرزاقكم في الطيب والحسن{41}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَبِٱلۡبَـٰطِلِ یُؤۡمِنُونَ وَبِنِعۡمَتِ ٱللَّهِ هُمۡ یَكۡفُرُونَ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أفبالباطل يؤمنون﴾</span>، قال: بالشرك{42}. (٩/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أفبالباطل يؤمنون﴾</span>، يعني: بعبادة الشيطان -الشرك- يُصَدِّقون{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَبِالباطِلِ يُؤْمِنُونَ﴾</span> يعني: أفبالشيطان يصدقون بأنّ مع الله ﷿ شريكًا، <span class="qpc-hafs">﴿وبِنِعْمَتِ اللَّهِ﴾</span> الذي أطعمهم من جوع وآمنهم من خوف <span class="qpc-hafs">﴿هُمْ يَكْفُرُونَ﴾</span> بتوحيد الله؛ أفلا يؤمنون برب هذه النعم فيوحدونه؟!{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿أفبالباطل يؤمنون﴾</span> قال: الشيطان، <span class="qpc-hafs">﴿وبنعمتِ الله﴾</span> قال: محمد ﷺ{45}. (٩/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أفبالباطل يؤمنون﴾</span> على الاستفهام، أي: قد آمنوا بالباطل، والباطل إبليس، <span class="qpc-hafs">﴿وبنعمت الله هم يكفرون﴾</span> هو كقوله: <span class="qpc-hafs">﴿ألم تر إلى الذين بدلوا نعمت الله كفرا﴾</span> [إبراهيم:٢٨]، وكقوله: <span class="qpc-hafs">﴿وتجعلون رزقكم أنكم تكذبون﴾</span> [الواقعة:٨٢]، يقول: تجعلون مكان الشكر: التكذيب{46}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/٧٥، وابن جرير ١٤/٢٩٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٧.تفسير يحيى بن سلام ١/٧٥.الأختان: أبو امرأة الرجل، وأخو امرأته، وكل مَن كان مِن قِبَل امرأته. اللسان (ختن).أخرجه يحيى بن سلام ١/٧٦، والبخاري في تاريخه ٦/١٥٤، وابن جرير ١٤/٢٩٦، والطبراني (٩٠٨٨، ٩٠٩٠، ٩٠٩٢، ٩٠٩٣)، والحاكم ٢/٣٥٥، والبيهقي في سُنَنِه ٧/٧٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٩٨.أخرجه ابن جرير ١٤/٢٩٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٠١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٠١.عزاه السيوطي إلى ابن أبي حاتم.مسائل نافع (٥). وعزاه السيوطي إلى الطستي.أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه ابن جرير ١٤/٢٩٨.أخرجه ابن جرير ١٤/٣٠٢-٣٠٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٠٢-٣٠٣.أخرجه ابن جرير ١٤/٢٩٧.أخرجه ابن جرير ١٤/٢٩٧.أخرجه ابن جرير ١٤/٢٩٧.أخرجه سعيد بن منصور في سننه - التفسير ٦/٦٥ (١٢٣٥).أخرجه ابن جرير ١٤/٢٩٦.أخرجه ابن جرير ١٤/٢٩٩.أخرجه ابن جرير ١٤/٣٠٠.أخرجه ابن جرير ١٤/٣٠٠.تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١.أخرجه سعيد بن منصور في سننه - التفسير ٦/٦٥ (١٢٣٤).أخرجه ابن جرير ١٤/٣٠٢.أخرجه ابن جرير ١٤/٢٩٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٩٩.أخرجه عبد الرزاق في تفسيره ٢/٣٥٨ بلفظ: الحفدة: مَن يخدمك مِن ولدك وولد ولدك، وابن جرير ١٤/٢٩٩.أخرجه ابن جرير ١٤/٣٠٠.أخرجه ابن جرير ١٤/٣٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٧٥، وسعيد بن منصور في سننه - التفسير ٦/٦٥ (١٢٣٤).أخرجه يحيى بن سلام ١/٧٥، وابن جرير ١٤/٢٩٩.تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١ بلفظ: هم ولد ولد الرجل، الذين يعينونه ويخدمونه.الـمَهْنَة -بفتح الميم-: هي الخدمة. ولا يقال: مِهنة –بالكسر-. النهاية (مهن).أخرجه يحيى بن سلام ١/٧٦ مختصرًا، وابن جرير ١٤/٣٠٠.تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١.في المطبوع: الكفار!تفسير مقاتل بن سليمان ٢/٤٧٧. وفي تفسير الثعلبي ٦/٣٠، وتفسير البغوي ٥/٣١ بنحوه منسوبًا إلى مقاتل دون تمييز.أخرجه ابن جرير ١٤/٣٠٢.تفسير مقاتل بن سليمان ٢/٤٧٨.أخرجه ابن جرير ١٨/٤٤٣ ذكره في [العنكبوت: ٦٧]، وابن أبي حاتم ٩/٣٠٨٣.علَّقه يحيى بن سلام ١/٧٦.تفسير مقاتل بن سليمان ٢/٤٧٨.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٧٦.