quran[27]{c,v,t}:
68,16," <q>﴿سَنَسِمُهُۥ عَلَى ٱلۡخُرۡطُومِ ۝١٦﴾</q> - تفسير ٧٨١٧٧- عن عبد الله بن عمرو، عن النبي ﷺ، قال: «مَن مات همّازًا لمّازًا مُلَقِّبًا للناس كان علامته يوم القيامة أن يَسِمَه الله على الخُرطوم مِن كِلا الشِّدْقين»{1}. (١٤/٦٣٦) ٧٨١٧٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</q>: فقاتل يوم بدر، فخُطم بالسيف في القتال{2}. (١٤/٦٣٥) ٧٨١٧٩- قال أبو العالية الرِّياحيّ= (ز) ٧٨١٨٠- ومجاهد بن جبر: سنشينه على أنفه، ونُسوّد وجهه، فنَجعل له عَلَمًا في الآخرة يُعرف به، وهو سواد الوجه{3}. (ز) ٧٨١٨١- قال الضَّحّاك بن مُزاحِم: <q>﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</q> سَنكويه على وجهه{3}. (ز) ٧٨١٨٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</q>، قال: سِيما على أنفه لا تُفارقه{5}. (١٤/٦٣٥) ٧٨١٨٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿سَنَسِمُهُ عَلى الخُرْطُومِ﴾</q>، قال: سَنسِمه بسِيما لا تُفارقه آخرَ ما عليه{6}. (١٤/٦٣٥) ٧٨١٨٤- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿سَنَسِمُهُ﴾</q> بالسّواد <q>﴿عَلى الخُرْطُومِ﴾</q> يعني: على الأنف، وهو الوليد، وذلك أنه يَسْوَدُّ وجهه، وتزوق{7} عيناه، مَنكوس الوجه، مغلولًا في الحديد، قبل دخول النار{8}٦٧٣٤. (ز) ٦٧٣٤ اختُلف في <q>﴿سنسمه على الخرطوم﴾</q> على أقوال: الأول أنّ المعنى: سَنخطمه بالسيف، فنجعل ذلك علامة باقية، وسمة ثابتة فيه ما عاش. الثاني: سِيما على أنفه. الثالث: سَنسمه سمة أهل النار. أي: سنُسوّد وجهه. الرابع: سَنشينه شينًا باقيًا. وعلَّق ابنُ عطية (٨/٣٧٢) على القول الأخير الذي قاله قتادة من طريق سعيد، بقوله: «فيكون ذلك كالوسم على الأنف ثابتًا بيّنًا، وهذا المعنى كما تقول: سأطوقك طوق الحمامة، أي: أُثبت الأمر بَيّنًا فيك». ورجَّحه ابنُ جرير (٢٣/١٧٠-١٧١)، فقال: «وأولى القولين بالصواب في تأويل ذلك عندي قول مَن قال: معنى ذلك: سُنبين أمره بيانًا واضحًا حتى يعرفوه، فلا يخفى عليهم، كما لا تخفى السمة على الخرطوم». ولم يذكر مستندًا، ثم قال: «وقد يحتمل أيضًا أن يكون خطم بالسيف، فجمع له مع بيان عيوبه للناس الخطم بالسيف». وعلَّق ابنُ كثير (١٤/٩٤) عليه بقوله: «وهو مُتَّجِه». ",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٢١-، والطبراني في الأوسط (٨٨٠١)، والبيهقي في شعب الإيمان (٦٧٤٤). وعزاه السيوطي إلى ابن مردويه. وقال الهيثمي في مجمع الزوائد ٧/٢١٣: «فيه عبد الله بن صالح، وثَّقه عبد الملك بن شعيب، وضعّفه غيره».أخرجه ابن جرير ٢٣/١٧٠. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.تفسير الثعلبي ١٠/١٥، وتفسير البغوي ٨/١٩٤.تفسير الثعلبي ١٠/١٥، وتفسير البغوي ٨/١٩٤.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٧٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٧٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.كذا في مطبوعة المصدر، ولعلها: وتَزْرَقُّ.تفسير مقاتل بن سليمان ٤/٤٠٥.
68,17," <q>﴿إِنَّا بَلَوۡنَـٰهُمۡ كَمَا بَلَوۡنَاۤ أَصۡحَـٰبَ ٱلۡجَنَّةِ﴾</q> - تفسير ٧٨١٨٥- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</q> قال: كانوا من أهل الكتاب{1}. (١٤/٦٣٦) ٧٨١٨٦- عن عبد الله بن عباس، في قوله: <q>﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</q>، قال: هم ناس مِن الحبشة، كانت لأبيهم جَنَّة، وكان يُطعم منها المساكين، فمات أبوهم، فقال بنوه: إن كان أبونا لَأحمق؛ حين كان يُطعم المساكين. فأَقسموا ليَصْرِمُنَّها مصبحين، وأن لا يُطعموا مسكينًا{2}. (١٤/٦٣٦) ٧٨١٨٧- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- في قوله ﷿: <q>﴿إنّا بَلَوْناهُمْ كَما بَلَوْنا أصْحابُ الجَنَّةِ﴾</q>، قال: كان بُستانٌ باليمن يقال له: الضَّرَوان، دون صنعاء بفَرسَخيْن، يطؤه أهل الطريق، كان غَرسَه قومٌ مِن أهل الصلاة، وكان لرجل، فمات، فورثه ثلاثة بنين له، وكان يكون للمساكين إذا صَرموا نخلهم كلُّ شيء تَعدّاه المِنجَل{3} فلم يجزُّه، وإذا طُرح من فوق النخل إلى البساط فكلّ شيء يَسقط على البساط فهو أيضًا للمساكين، وإذا حَصدوا زَرْعهم فكلّ شيء تَعدّاه المِنجَل فهو للمساكين، وإذا داسُوه كان لهم كلّ شيء يَنتثر أيضًا، فلمّا مات الأب ووَرثه هؤلاء الإخوة عن أبيهم فقالوا: واللهِ، إنّ المال لَقليل، وإنّ العيال لَكثير، وإنما كان هذا الأمر يفعل إذ كان المال كثيرًا والعيال قليلًا، فأمّا إذا قلَّ المال وكثُر العيال فإنّا لا نستطيع أن نفعل هذا. فتَحالفوا بينهم يومًا لَيَغدُوُّن غدوة قبل خروج الناس، فليصرِمُنَّ نخلهم، ولم يستثنوا، يقول: لم يقولوا: إن شاء الله. فغدا القوم بِسُدْفَة{4} من الليل إلى جنتهم لِيَصرموها قبل أن يَخرج المساكين، فرَأوها مُسوَدَّة، وقد طاف عليها من الليل طائف من العذاب، فأَحرقها، فأصبحت كالصريم{5}. (ز) ٧٨١٨٨- عن سعيد بن جُبَير -من طريق تميم بن عبد الرحمن- في قوله: <q>﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</q>، قال: هي أرض باليمن يُقال لها: ضَرَوان، بينها وبين صنعاء ستة أميال{6}. (١٤/٦٣٧) ٧٨١٨٩- عن عكرمة مولى ابن عباس -من طريق سِماك- في قوله: <q>﴿لا يدخلنها اليوم عليكم مسكين﴾</q>، قال: هم ناس من الحبشة، كانت لأبيهم جَنّة، وكان يُطعم المساكين منها، فمات أبوهم، فقال بنوه: واللهِ، إن كان أبونا لَأحمق حتى يُطعم المساكين. فأجمعوا <q>﴿ليصرمنها مصبحين ولا يستثنون﴾</q>، وألّا يُطعموا مسكينًا{7}. (ز) ٧٨١٩٠- عن قتادة بن دعامة، في قوله: <q>﴿إنّا بَلَوْناهُمْ كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</q>، قال: هؤلاء ناسٌ قصّ الله عليكم حديثهم، وبيّن لكم أمْرهم{8}. (١٤/٦٣٦) ٧٨١٩١- عن قتادة بن دعامة -من طريق معمر- قال: كانت الجَنّةُ لشيخ مِن بني إسرائيل، وكان يُمسك قُوت سَنَتِه، ويَتصدّق بالفضل، وكان بنوه يَنْهَونَه عن الصّدقة، فلمّا مات أبوهم غَدَوْا عليها، فقالوا: لا يَدخُلنّها اليوم عليكم مسكين{9}. (١٤/٦٣٧) ٧٨١٩٢- قال محمد بن السّائِب الكلبي: <q>﴿كَما بَلَوْنا أصْحابَ الجَنَّةِ﴾</q> أنهم كانوا أبناء قوم صالحين، وأنّ آباءهم كانوا جعلوا مِن جنّتهم حظًّا للمساكين وأبناء السبيل، فخَلف مِن بعدهم أبناؤهم، فقالوا: كَبرنا وكثُر عيالنا، فليس للمساكين عندنا شيء؛ فتَقاسموا{10}. (ز) ٧٨١٩٣- قال مقاتل بن سليمان: ثم رجع في التقديم، فقال: <q>﴿إنّا بَلَوْناهُمْ﴾</q> يقول: إنّا ابتليناهم -يعني: أهل مكة- بالجوع <q>﴿كَما بَلَوْنا﴾</q> يقول: كما ابتلينا <q>﴿أصْحابَ الجَنَّةِ﴾</q> بالجوع حين هَلكتْ جَنّتهم، كان فيها نخل وزرع وأعناب، ورثوها عن آبائهم، واسم الجَنّة: الصّريم. وهذا مَثلٌ ضربه الله تعالى لأهل مكة؛ ليَعتبروا عن دينهم، وكانت جَنّتهم دون صنعاء اليمن بفَرسَخين، وكانوا مسلمين، وهذا بعد عيسى ابن مريم ﵇، وكان آباؤهم صالحين، يَجعلون للمساكين من الثمار والزرع والنخل ما أخطأ الرجل، فلم يَره حين يَصْرِمهُ، وما أخطأ المِنجَلُ، وما ذَرتْه الريح، وما بقي في الأرض مِن الطعام حين يُرفع، وكان هذا شيئًا كثيرًا، فقال القوم: كَثُرت العيال، وهذا طعام كثير، اغدُوا سِرًّا جنّتكم، فاصرِموها، ولا تُؤذِنوا المساكين، كان آباؤهم يُخبِرون المساكين، فيَجتمعون عند صِرامِ جَنّتهم، وعند الحصاد{11}. (ز) <q>﴿إِذۡ أَقۡسَمُوا۟ لَیَصۡرِمُنَّهَا مُصۡبِحِینَ ۝١٧﴾</q> - تفسير ٧٨١٩٤- عن أبي مالك غَزْوان الغفاري، في قوله: <q>﴿لَيَصْرِمُنَّها مُصْبِحِينَ﴾</q>، قال: ليَحْضُرُنّها{12}. (١٤/٦٣٧) ٧٨١٩٥- قال مقاتل بن سليمان: <q>﴿إذْ أقْسَمُوا لَيَصْرِمُنَّها مُصْبِحِينَ﴾</q> ليَصرِمُنّها إذا أصبحوا{11}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/١٧٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.المِنجَل: ما يُحْصَد به، من النَّجْل: وهو القَطْع. لسان العرب (نجل).السُّدْفة: من الأضْداد، تقع على الضياء والظُّلْمة، ومنهم من يجعلها اختلاط الضوء والظُّلمة معًا كوقت ما بين طلوع الفجر والإسْفار. النهاية (سدف).أخرجه الثعلبي ١٠/١٦، والبغوي ٨/١٩٤-١٩٥.أخرجه عبد الرزاق ٢/٣١١، وابن جرير ٢٣/١٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٤-١٤٥ (٢٢٧٠).عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٠-٢١-.تفسير مقاتل بن سليمان ٤/٤٠٥-٤٠٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٥-٤٠٦.
68,18," <q>﴿وَلَا یَسۡتَثۡنُونَ ۝١٨﴾</q> - تفسير ٧٨١٩٦- عن أبي صالح، في قوله: <q>﴿ولا يَسْتَثْنُونَ﴾</q>، قال: كان استثناؤهم: سبحان الله{1}. (١٤/٦٣٧) ٧٨١٩٧- قال مقاتل بن سليمان: <q>﴿ولا يَسْتَثْنُونَ﴾</q> فيقولون: إن شاء الله{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦.
68,19," <q>﴿فَطَافَ عَلَیۡهَا طَاۤىِٕفࣱ مِّن رَّبِّكَ وَهُمۡ نَاۤىِٕمُونَ ۝١٩﴾</q> - تفسير ٧٨١٩٨- عن عبد الله بن عباس -من طريق أبي ظَبْيان- في قوله: <q>﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ﴾</q>، قال: هو أمرٌ من الله{1}. (١٤/٦٣٨) ٧٨١٩٩- عن قتادة بن دعامة، في قوله: <q>﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ وهُمْ نائِمُونَ﴾</q>، قال: أتاها أمرُ اللهِ ليلًا{2}. (١٤/٦٣٨) ٧٨٢٠٠- قال مقاتل بن سليمان: فسمع الله تعالى قولَهم، فبعث نارًا مِن السماء في الليل على جَنّتهم، فأَحْرقتْها حتى صارت سوداء، فذلك قوله: <q>﴿فَطافَ عَلَيْها﴾</q> يعني: على الجنة <q>﴿طائِفٌ﴾</q> يعني: عذاب <q>﴿مِن رَبِّكَ﴾</q> يا محمد ليلًا، <q>﴿وهُمْ نائِمُونَ﴾</q>{3}٦٧٣٥. (ز) ٦٧٣٥ ذكر ابنُ عطية (٨/٣٧٣) أنّ الفراء خصص «الطائف» بأنه الأمر الذي يأتي بالليل، وانتقده مستندًا إلى النظائر، فقال: «ويرُدّه قوله تعالى: <q>﴿إذا مسهم طائف من الشيطان﴾</q> [الأعراف:٢٠١]». ٧٨٢٠١- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ﴾</q>، قال: عذاب، عُنُق مِن نار خَرجتْ من وادي الجنة؛ جَنّتهم{4}. (١٤/٦٣٨) ",footnotes:1:أخرجه ابن جرير ١٠/٣٨١، ٢٣/١٧٣، ومن طريق العَوفيّ أيضًا.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦.عزاه السيوطي إلى ابن المنذر.
68,20," <q>﴿فَأَصۡبَحَتۡ كَٱلصَّرِیمِ ۝٢٠﴾</q> - تفسير ٧٨٢٠٢- قال عبد الله بن عباس: <q>﴿كالصَّرِيمِ﴾</q> كالرّماد الأسود؛ بلغة خزيمة{1}. (ز) ٧٨٢٠٣- عن عبد الله بن عباس -من طريق شيخ مِن كلب يُقال له: سليمان- في قوله: <q>﴿كالصَّرِيمِ﴾</q>، قال: مثل الليل الأسود{2}. (١٤/٦٣٩) ٧٨٢٠٤- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿كالصَّرِيمِ﴾</q>، قال: الذّاهِب. قال: وهل تَعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر: غدوتُ عليه غُدوة فوجدتُه قُعودًا لديه بالصّريم عواذله؟{3}. (١٤/٦٣٩) ٧٨٢٠٥- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال: أخبِرني عن قول الله ﷿: <q>﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</q>، ما الصريم؟ قال: كالليل المُظلِم. قال: وهل كانت العرب تَعرف ذلك قبل أن ينزل الكتاب على محمد ﷺ؟ قال: نعم، أما سمعتَ قول نابغة بني ذبيان: لا تَزْجُرُوا مُكَفَهِرُّ الأَكْفاءِ لَهُ كالليل يَخْلُطُ أصْرامًا بأَصْرامِ؟ قال: صَدَقتَ{4}. (ز) ٧٨٢٠٦- عن سعيد بن جُبَير -من طريق تميم بن عبد الرحمن- قال: هي أرض باليمن يُقال لها: ضَرَوان، بينها وبين صنعاء ستة أميال{5}٦٧٣٦. (ز) ٦٧٣٦ ذكر ابنُ جرير (٢٣/ ١٧٤) أنه «اختلف أهل التأويل في الذي عُني بالصريم؛ فقال بعضهم: عُني به: الليل الأسود. وقال بعضهم: معنى ذلك: فأصبحت جنتهم محترقة سوداء كسواد الليل المظلم البهيم». ثم ساق أثر ابن عباس مِن طريق شيخ من كلب، ثم قال: «وقال آخرون: بل معنى ذلك: فأصبحت كأرض تُدعى الصريم معروفة بهذا الاسم». ثم ساق قول سعيد بن جبير. وقد تقدم الأثر في أول القصة على أنه اسم للجنة كما ورد في بعض المصادر. ٧٨٢٠٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</q>، قال: كالليل المُظلِم{6}. (١٤/٦٣٨) ٧٨٢٠٨- عن مَطر بن ميمون، مثله{6}. (١٤/٦٣٨) ٧٨٢٠٩- قال الحسن البصري: <q>﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</q>، أي: صُرم منها الخير، فليس فيها شيء{1}. (ز) ٧٨٢١٠- عن قتادة بن دعامة، في قوله: <q>﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</q>، قال: كأنها قد صُرِمَتْ{9}. (١٤/٦٣٨) ٧٨٢١١- قال مقاتل بن سليمان: <q>﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</q> أصبحتْ -يعني: الجَنّة- سوداء مثل الليل{10}٦٧٣٧. (ز) ٦٧٣٧ علَّق ابنُ عطية (٨/٣٧٣) على هذا القول بقوله: «من حيث اسودت جنتهم». ونَقل عن آخرين أنهم قالوا: أراد به الصبح، وعلَّق عليه بقوله: «مِن حيث ابيضتْ كالحصيد». وذكر أنّ سفيان الثوري قال: الصريم يُقال لليل والنهار، ووجّهه بقوله: «من حيث كلّ واحد منهما ينصرم من صاحبه». ٧٨٢١٢- قال عبد الرحمن بن زيد بن أسلم: <q>﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</q> كالأرض المَصْرومة{11}. (ز) <q>﴿فَأَصۡبَحَتۡ كَٱلصَّرِیمِ ۝٢٠﴾</q> - آثار متعلقة بالآية ٧٨٢١٣- عن ابن مسعود، قال: قال رسول الله ﷺ: «إيّاكم والمعاصيَ، فإنّ العبد لَيُذنب الذّنب فيَنسى به الباب مِن العلم، وإنّ العبد ليُذنب الذّنب فيُحرم به قيام الليل، وإنّ العبد ليُذنب الذّنب فيَنسى فيُحرم به رزقًا قد كان هُيِّئ له». ثم تلا رسول الله ﷺ: «<q>﴿فَطافَ عَلَيْها طائِفٌ مِن رَبِّكَ وهُمْ نائِمُونَ فَأَصْبَحَتْ كالصَّرِيمِ﴾</q>، قد حُرموا خير جنتهم بذنبهم»{12}. (١٤/٦٣٨) ",footnotes:1:تفسير الثعلبي ١٠/١٦، وتفسير البغوي ٨/١٩٥.أخرجه ابن جرير ٢٣/١٧٤. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأورد ابن جرير في آخر الآثر عن بعض رواته –كما يظهر-: "قال: وقال في ذلك أبو عمرو بن العلاء ﵀:أخرجه الطستي في مسائل نافع (١٦).أخرجه الطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه ابن جرير ٢٣/١٧٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٦، وتفسير البغوي ٨/١٩٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦.تفسير الثعلبي ١٠/١٦.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٩٦- وفي إسناده: عمر بن صبح. وأورده الديلمي في الفردوس ١/٣٨٣ (١٥٤٢). قال ابن عدي في الكامل ٦/٤٧ (١١٩٧) في ترجمة عمر بن صبح: «منكر الحديث». وقال الذهبي في ميزان الاعتدال ٣/٢٠٦ (٦١٤٧) في ترجمة عمر بن صبح: «ليس بثقة، ولا مأمون. قال ابن حبان: كان ممن يضع الحديث ...، قال الدارقطني وغيره: متروك. وقال الأزدي: كذاب».
68,21," <q>﴿فَتَنَادَوۡا۟ مُصۡبِحِینَ ۝٢١ أَنِ ٱغۡدُوا۟ عَلَىٰ حَرۡثِكُمۡ إِن كُنتُمۡ صَـٰرِمِینَ ۝٢٢﴾</q> - تفسير ٧٨٢١٤- عن مجاهد بن جبر، في قوله: أن <q>﴿اغْدُوا عَلى حَرْثِكُمْ﴾</q>، قال: كان عِنَبًا{1}. (١٤/٦٣٩) ٧٨٢١٥- قال مقاتل بن سليمان: <q>﴿فَتَنادَوْا مُصْبِحِينَ﴾</q> يقول: لَمّا أصبحوا قال بعضهم لبعض: <q>﴿أنِ اغْدُوا عَلى حَرْثِكُمْ إنْ كُنْتُمْ صارِمِينَ﴾</q> الجَنّة، يقول: الحرْث والثمار والزرع، ولا يَعلمون أنها احترقتْ{2}٦٧٣٨. (ز) ٦٧٣٨ ذكر ابنُ عطية (٨/٣٧٣) أنّ قوله: <q>﴿إن كنتم صارمين﴾</q> يحتمل احتمالين: الأول: «أن يكون من صِرام النخل». الثاني: «أن يريد: إن كنتم من أهل عزم وإقدام على آرائكم، من قولك: سيف صارم». ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٠٦.
  68,22,""
68,23," <q>﴿فَٱنطَلَقُوا۟ وَهُمۡ یَتَخَـٰفَتُونَ ۝٢٣﴾</q> - تفسير ٧٨٢١٦- عن عبد الله بن عباس، في قوله: <q>﴿وهُمْ يَتَخافَتُونَ﴾</q>، قال: الإسرار، والكلام الخفِيُّ{1}. (١٤/٦٣٩) ٧٨٢١٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وهُمْ يَتَخافَتُونَ﴾</q>، قال: يُسِرِّون بينهم أن لا يَدخُلنّها اليومَ عليكم مسكين{2}. (١٤/٦٣٩) ٧٨٢١٨- قال مقاتل بن سليمان: <q>﴿فانْطَلَقُوا وهُمْ يَتَخافَتُونَ﴾</q> يعني: يَتشاورون{3} فيما بينهم، وهو الخفيّ من الكلام، فقالوا سِرًّا: <q>﴿أنْ لا يَدْخُلَنَّها اليَوْمَ عَلَيْكُمْ مِسْكِينٌ﴾</q>{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٧٦، وبنحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.ذكر محققه أن في بعض النسخ تعليق في الحاشية على الكلمة: يتسارّون. وهو أقرب للسياق.تفسير مقاتل بن سليمان ٤/٤٠٦.
68,24," <q>﴿أَن لَّا یَدۡخُلَنَّهَا ٱلۡیَوۡمَ عَلَیۡكُم مِّسۡكِینࣱ ۝٢٤﴾</q> - تفسير ٧٨٢١٩- عن مجاهد بن جبر -من طريق أبي بشر- في قوله: <q>﴿أنْ لا يَدْخُلَنَّها اليَوْمَ عَلَيْكُمْ مِسْكِينٌ﴾</q>، قال: أضمَروا في أنفسهم أن لا يدخل عليهم مسكين{1}. (ز) ",footnotes:1:تفسير مجاهد ص٦٦٩.
68,25," <q>﴿وَغَدَوۡا۟ عَلَىٰ حَرۡدࣲ قَـٰدِرِینَ ۝٢٥﴾</q> - تفسير ٧٨٢٢٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿عَلى حَرْدٍ قادِرِينَ﴾</q>، يقول: ذو قدرة{1}. (١٤/٦٤٠) ٧٨٢٢١- قال أبو العالية الرِّياحيّ: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q> على جدّ وجَهد{2}. (ز) ٧٨٢٢٢- قال إبراهيم النَّخْعي= (ز) ٧٨٢٢٣- ومحمد بن كعب القُرَظيّ: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q> على أمْرٍ مُجمع قد أسّسوه بينهم{3}. (ز) ٧٨٢٢٤- عن مجاهد بن جبر -من طريق حجّاج، عمّن حدثه- في قول الله: <q>﴿على حرد قادرين﴾</q>، قال: على جِدٍّ قادرين في أنفسهم{4}. (ز) ٧٨٢٢٥- عن مجاهد بن جبر، قال: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>، قال: غَدَوا على أمْرٍ قد قَدَرُوا عليه، وأجمعوا عليه في أنفسهم أن لا يَدخل عليهم مسكين{5}. (١٤/٦٤٠) ٧٨٢٢٦- عن مجاهد بن جبر -من طريق إبراهيم بن المهاجر- قال: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q> قال: كان حرْثٌ لأبيهم، وكانوا إخوة، فقالوا: لا نُطعم مسكينًا منه حتى نَعلم ما يَخرج منه، <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q> على أمْرٍ قد أسّسوه بينهم{4}. (ز) ٧٨٢٢٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ﴾</q>، قال: على غيظ{7}. (١٤/٦٤٠) ٧٨٢٢٨- عن عكرمة مولى ابن عباس -من طريق سِماك- في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ﴾</q>، قال: على أمْرٍ مُجمَع{8}. (ز) ٧٨٢٢٩- عن عامر الشعبي، في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ﴾</q>: يعني: المساكين؛ بجِدٍّ{9}. (١٤/٦٤٠) ٧٨٢٣٠- قال عامر الشعبي: <q>﴿وغَدَوْا عَلى حَرْدٍ﴾</q> على حَنق وغضبٍ مِن المساكين{10}. (ز) ٧٨٢٣١- عن الحسن البصري -من طريق معمر- في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ﴾</q>، قال: على فَقْر{11}. (١٤/٦٤٠) ٧٨٢٣٢- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>، قال: على جَهد. أو قال: على جِدٍّ{12}. (ز) ٧٨٢٣٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>، قال: غدا القومُ وهم مُحرِدون{13} إلى جَنّتهم، قادرون عليها في أنفسهم{14}. (١٤/٦٣٩) ٧٨٢٣٤- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>، يقول: على جِدٍّ مِن أمْرهم{15}. (١٤/٦٣٧) ٧٨٢٣٥- قال إسماعيل السُّدِّيّ: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>، الحَرْد: اسم الجنة{16}٦٧٣٩. (ز) ٦٧٣٩ انتقد ابنُ كثير (١٤/٩٦) قول السُّدِّيّ بقوله: «أبْعَد السُّدِّيُّ في قوله هذا». ٧٨٢٣٦- قال مقاتل بن سليمان: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q> على حِدّة في أنفسهم، قادرين على جَنّتهم{17}٦٧٤٠. (ز) ٦٧٤٠ ذكر ابنُ تيمية (٦/٣٧٨) «أنّ»الحرد«يرجع إلى القصد، وأنهم غَدوا بإرادة جازمة وقدرة، ولكنّ الله أعجزهم». ثم ساق هذا القول الذي قاله مجاهد، وقتادة، ومقاتل، وعلَّق بقوله: «وقول مَن قال: ... أي: ظنّوا أنّ الأمر يبقى كما كان، ولو كان كذلك لتمّتْ قدرتهم، لكن سُلبوا القدرة بإهلاك جَنّتهم». ٧٨٢٣٧- عن سفيان [الثوري] -من طريق مهران- <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>، قال: على حَنق{18}٦٧٤١. (ز) ٦٧٤١ علَّق ابنُ جرير (٢٣/١٧٨) على هذا القول بقوله: "وكأنّ سفيان ذهب في تأويله هذا إلى مثل قول الأشهب بن رميلة: سُودُ شَرًى لاقتْ أُسُود خفيَّةٍ تَساقَوْا على حَرْدٍ دماءَ الأساوِدِ يعني: على غضب". وبنحوه قال ابنُ عطية (٨/٣٧٤)، وزاد فقال: «يقال: حَرِد الرجل يحرد حرَدًا: إذا غضب». ٧٨٢٣٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ﴾</q>: على جِدٍّ، قادرين في أنفسهم{4}٦٧٤٢. (ز) ٦٧٤٢ اختُلف في معنى الحرد على أقوال: الأول: أنّ معناه: على قصد. الثاني: على قدرة في أنفسهم وجِدّ. الثالث: على فاقة وحاجة. الرابع: على حَنق. الخامس: أنّ «الحرد» اسم الجنة. السادس: على منع. ذكره ابنُ جرير (٢٣/١٧٨-١٧٩)، ونسبه لبعض أهل اللغة من البصرة. وذكر أنّ مَن قال بالقول الأخير وجّه المعنى إلى أنه من قولهم: حارَدت السنة إذا لم يكن فيها مطر. وبنحوه قال ابنُ عطية (٨/٣٧٤). وانتقده ابنُ جرير مستندًا لأقوال السلف، فقال: «وهذا قول لا نَعلم له قائلًا مِن متقدمي العلم قاله، وإن كان له وجْه، فإذا كان ذلك كذلك، وكان غير جائز عندنا أن يُتعدى ما أجمعتْ عليه الحُجّة، فما صحّ من الأقوال في ذلك إلا أحد الأقوال التي ذكرناها عن أهل العلم». ورجَّح -مستندًا إلى اللغة، وأقوال السلف- القول الأول الذي قاله وعكرمة، ومجاهد، من طريقي إبراهيم بن المهاجر، وابن أبي نجيح، وذلك أنّ «المعروف من معنى الحرد في كلام العرب: القصد، من قولهم: قد حرَد فلان حرْد فلان: إذا قصد قصده؛ يعني: يقصد قصدها». وعلَّق ابنُ عطية (٨/٣٧٤) على القول الأول بقوله: «وبذلك فسّر بعض اللغويين». وذكر ابنُ تيمية (٦/٣٧٩) «أنّ»الحرد«يحتمل أن يُراد به: المنع، والقصْد، والغضب». فقال: «الحرد فيه معنى العزم الشديد؛ فإنّ هذا اللفظ يقتضي هذا، وحرد السنة والناقة لما فيه من معنى الشدة، وكذلك الحَنق والغضب فيه شدة؛ فكان لهم عزم شديد على أخْذها، وعلى حرمان المساكين». وبنحوه قال ابنُ عطية (٨/٣٧٤). وذكر (٨/٣٧٥) أنّ قوله تعالى: <q>﴿قادرين﴾</q> يحتمل احتمالين: الأول: «أن يكون من القدرة، أي: هم قادرون في زعمهم». الثاني: «أن يكون من التقدير، كأنهم قد قَدَروا على المساكين، أي: ضيّقوا عليهم». وعلَّق عليه بقوله: «ومنه قوله تعالى: <q>﴿ومن قُدِر عليه رزقه﴾</q> [الطلاق:٧]». ",footnotes:1:أخرجه ابن جرير ٢٣/١٧٦. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/١٧، وتفسير البغوي ٨/١٩٦.تفسير الثعلبي ١٠/١٧، وتفسير البغوي ٨/١٩٦ عن القُرَظيّ.أخرجه ابن جرير ٢٣/١٧٧.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد. وعند ابن جرير ٢٣/١٧٧ من طريق ابن أبي نجيح بلفظ: على أمر مجمع.أخرجه ابن جرير ٢٣/١٧٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٤٤-١٤٥ (٢٢٧٠)، وابن جرير ٢٣/١٧٨.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٩٦.أخرجه عبد الرزاق ٢/٣١٠، وابن جرير ٢٣/١٧٨ بلفظ: على فاقة. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٧٦.محردون: مِن الحَرْدِ، والحَرْدُ: القصد والمنع والغيظ والغضب. لسان العرب (حرد).أخرجه ابن جرير ٢٣/١٧٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٠٩، وابن جرير ٢٣/١٧٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/١٧.تفسير مقاتل بن سليمان ٤/٤٠٦.أخرجه ابن جرير ٢٣/١٧٨.أخرجه ابن جرير ٢٣/١٧٧.
68,26," <q>﴿فَلَمَّا رَأَوۡهَا قَالُوۤا۟ إِنَّا لَضَاۤلُّونَ ۝٢٦﴾</q> - تفسير ٧٨٢٣٩- عن عبد الله بن عباس، في قوله: <q>﴿قالُوا إنّا لَضالُّونَ﴾</q>، قال: أضلَلنا مكان جَنّتنا{1}. (١٤/٦٤٠) ٧٨٢٤٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿إنّا لَضالُّونَ﴾</q>، قال: أخطأنا الطريق{2}. (١٤/٦٤١) ٧٨٢٤١- قال مقاتل بن سليمان: <q>﴿فَلَمّا رَأَوْها﴾</q> ليس فيها شيءٌ ظنّوا أنهم أخطأوا الطريق؛ <q>﴿قالُوا إنّا لَضالُّونَ﴾</q> عنها{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٠٩-٣١٠، وابن جرير ٢٣/١٨٠ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٠٦-٤٠٧.
68,27," <q>﴿بَلۡ نَحۡنُ مَحۡرُومُونَ ۝٢٧﴾</q> - تفسير ٧٨٢٤٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، قال: بل حُورِفْنا{1} فحُرمناها{2}. (١٤/٦٤١) ٧٨٢٤٣- عن محمد بن كعب القُرَظيّ -من طريق أيوب بن موسى- قال: المحروم: الذي تُصيبه الجائحة، قال الله: <q>﴿وغَدَوْا عَلى حَرْدٍ قادِرِينَ فَلَمّا رَأَوْها قالُوا إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، وقال: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</q> [الواقعة:٦٥-٦٧]، قال: المحروم: الذي تُصيبه الجائحة{3}. (ز) ٧٨٢٤٤- قال زيد بن أسلم -من طريق ابن عيّاش-: ... المحروم: الذي يُصاب زرْعه أو حرْثه أو نسْل ماشيته، فيكون له حقٌّ على مَن لم يُصِبْه من المسلمين، كما قال لأصحاب الجنة حين أهلك جَنّتهم، فقالوا: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، وقال أيضًا: <q>﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</q> [الواقعة:٦٥-٦٧]{4}. (ز) ٧٨٢٤٥- قال مقاتل بن سليمان: ثم إنهم عرفوا الأعلام، فعَلموا أنهم عقوبة، فقالوا: <q>﴿بَلْ نَحْنُ﴾</q> يعني: ولكن نحن <q>﴿مَحْرُومُونَ﴾</q> يقول: حُرمنا خير هذه الجَنّة{5}. (ز) ٧٨٢٤٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q> قال: لَمّا تبيّنوا وعرفوا معالم جَنّتهم قالوا: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q> مُحارَفون{6}. (١٤/٦٤١) ",footnotes:1:حُورِف كسْب فلان: إذا شُدِّدَ عليه في معاشه، وضُيِّق كأنه مِيلَ برزقه عنه، من الانحراف عن الشيء وهو المَيْل عنه. النهاية (حرف).أخرجه عبد الرزاق ٢/٣٠٩-٣١٠، وابن جرير ٢٣/١٨٠ من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٠٣-١٠٤ (٢٠٢).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦١-٦٢ (١٣٦).تفسير مقاتل بن سليمان ٤/٤٠٦-٤٠٧.عزاه السيوطي إلى ابن المنذر.
68,28," <q>﴿قَالَ أَوۡسَطُهُمۡ﴾</q> - تفسير ٧٨٢٤٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿قالَ أوْسَطُهُمْ﴾</q>، قال: أعْدلهم{1}. (١٤/٦٤١) ٧٨٢٤٨- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿قالَ أوْسَطُهُمْ﴾</q> قال: أعْدلهم، ويقال: قال خيرُهم، وقال في البقرة [١٤٣]: <q>﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا﴾</q>، قال: الوَسَط: العَدْل{2}. (ز) ٧٨٢٤٩- عن سعيد بن جُبَير -من طريق جعفر- <q>﴿قالَ أوْسَطُهُمْ﴾</q>، قال: أعْدلهم{2}. (ز) ٧٨٢٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿قالَ أوْسَطُهُمْ﴾</q>، قال: أعْدلهم{4}. (١٤/٦٤١) ٧٨٢٥١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿قالَ أوْسَطُهُمْ﴾</q>، يقول: أعْدلهم{5}. (ز) ٧٨٢٥٢- عن عكرمة مولى ابن عباس، في قوله: <q>﴿قالَ أوْسَطُهُمْ﴾</q>: يعني: أعْدلهم، وكلّ شيء في كتاب الله أوْسط فهو أعْدل{6}. (١٤/٦٤١) ٧٨٢٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قالَ أوْسَطُهُمْ﴾</q>، قال: أعْدلهم قولًا، وكان أسرع القوم فزعًا، وأحسنهم رَجعة{7}. (١٤/٦٤١) ٧٨٢٥٤- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله الله ﷿: <q>﴿قال أوسطهم﴾</q>، يقول: أفضلهم، وأَعْدلهم{8}. (ز) ٧٨٢٥٥- قال مقاتل بن سليمان: <q>﴿قالَ أوْسَطُهُمْ﴾</q> يعني: أعْدلهم قولًا. نظيرها في سورة البقرة [١٤٣]: <q>﴿أُمَّةً وسَطًا﴾</q>، يعني: عَدلًا{9}. (ز) <q>﴿أَلَمۡ أَقُل لَّكُمۡ لَوۡلَا تُسَبِّحُونَ ۝٢٨﴾</q> - تفسير ٧٨٢٥٦- عن مجاهد بن جبر -من طريق سفيان- <q>﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</q>، قال: يقول: تَستَثنُون، فكان التسبيح فيهم الاستثناء{10}. (ز) ٧٨٢٥٧- قال أبو صالح [باذام]: <q>﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</q> كان استثناؤهم سبحان الله{11}. (ز) ٧٨٢٥٨- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</q>، قال: كان استثناؤهم في ذلك الزمان: التسبيح{12}. (١٤/٦٤١) ٧٨٢٥٩- قال مقاتل بن سليمان: <q>﴿ألَمْ أقُلْ لَكُمْ لَوْلا تُسَبِّحُونَ﴾</q>، فتقولون: إن شاء الله تعالى{9}. (ز) ٧٨٢٦٠- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿لَوْلا تُسَبِّحُونَ﴾</q>، قال: لولا تَستَثنُون، عند قولهم: <q>﴿ليَصْرِمُنّها مُصبحين﴾</q>. ولا يَستَثنُون عند ذلك، وكان التسبيح استثناؤهم، كما نقول نحن: إن شاء الله{14}٦٧٤٣. (١٤/٦٤٢) ٦٧٤٣ انتقد ابنُ عطية (٨/٣٧٥) هذا القول مستندًا لظاهر الآية، فقال: «وهذا يردّ عليه قولهم: <q>﴿سبحان ربنا﴾</q>. فبادر القوم، وتابوا عند ذلك، وسبّحوا، واعترفوا بظُلمهم في اعتقادهم منع الفقراء». ",footnotes:1:أخرجه ابن جرير ٢٣/١٨١، وابن أبي حاتم -كما في الإتقان ٢/٤٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٨١.أخرجه ابن جرير ٢٣/١٨١.أخرجه ابن جرير ٢٣/١٨١، ومن طريق إبراهيم أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٨٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/١٨١، كما أخرجه عبد الرزاق ٢/٣٠٩-٣١٠ بنحوه من طريق معمر، وكذا ابن جرير. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٢.تفسير مقاتل بن سليمان ٤/٤٠٧.أخرجه ابن جرير ٢٣/١٨٢، ومن طريق إبراهيم أيضًا.تفسير الثعلبي ١٠/١٧، وتفسير البغوي ٨/١٩٦. وقد تقدمت رواية السيوطي لها في الدر ١٤/٦٣٧ عند قوله تعالى: <q>﴿ولا يَسْتَثْنُونَ﴾</q>. وعزاها إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٠٧.عزاه السيوطي إلى ابن المنذر.
68,29," <q>﴿قَالُوا۟ سُبۡحَـٰنَ رَبِّنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝٢٩ فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَلَـٰوَمُونَ ۝٣٠ قَالُوا۟ یَـٰوَیۡلَنَاۤ إِنَّا كُنَّا طَـٰغِینَ ۝٣١ عَسَىٰ رَبُّنَاۤ أَن یُبۡدِلَنَا خَیۡرࣰا مِّنۡهَاۤ إِنَّاۤ إِلَىٰ رَبِّنَا رَ ٰ⁠غِبُونَ ۝٣٢﴾</q> - تفسير ٧٨٢٦١- قال مقاتل بن سليمان: <q>﴿فَأَقْبَلَ بَعْضُهُمْ عَلى بَعْضٍ يَتَلاوَمُونَ﴾</q> يقول: يلوم بعضهم بعضًا في منْع حقوق المساكين، <q>﴿قالُوا يا ويْلَنا إنّا كُنّا طاغِينَ﴾</q> يقول: لقد طَغَينا في نعمة الله تعالى، قالوا: <q>﴿عَسى رَبُّنا أنْ يُبْدِلَنا خَيْرًا مِنها﴾</q> يعني: خيرًا مِن جَنّتنا التي هَلكتْ؛ <q>﴿إنّا إلى رَبِّنا راغِبُونَ﴾</q> في الدعاء إليه{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٠٧.
