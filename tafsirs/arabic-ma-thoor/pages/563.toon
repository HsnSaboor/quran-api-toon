tafsir[14]{c,v,t}:
67,13," <q>﴿وَأَسِرُّوا۟ قَوۡلَكُمۡ أَوِ ٱجۡهَرُوا۟ بِهِۦۤۖ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝١٣﴾</q> - نزول الآية ٧٧٨٨٣- قال عبد الله بن عباس: <q>﴿وأَسِرُّوا قَوْلَكُمْ﴾</q> نزلت في المشركين، كانوا يَنالون مِن رسول الله ﷺ، فيُخبِره جبريل ﵇ بما قالوا، فقال بعضهم لبعض: أسِرُّوا قولكم؛ كي لا يسمع إله محمد{1}. (ز) <q>﴿وَأَسِرُّوا۟ قَوۡلَكُمۡ أَوِ ٱجۡهَرُوا۟ بِهِۦۤۖ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝١٣﴾</q> - تفسير الآية ٧٧٨٨٤- قال مقاتل بن سليمان: <q>﴿وأَسِرُّوا قَوْلَكُمْ﴾</q> في النبي ﷺ في القلوب، <q>﴿أوِ اجْهَرُوا بِهِ﴾</q> يعني: أو تَكلّموا به علانية. يعني به: كفار مكة؛ <q>﴿إنَّهُ عَلِيمٌ بِذاتِ الصُّدُورِ﴾</q> يعني: بما في القلوب{2}. (ز) ",footnotes:1:أورده الثعلبي ٩/٣٥٩، والواحدي في أسباب النزول ص٤٤٢، والبغوي ٨/١٧٨.تفسير مقاتل بن سليمان ٤/٣٩١.
67,14," <q>﴿أَلَا یَعۡلَمُ مَنۡ خَلَقَ وَهُوَ ٱللَّطِیفُ ٱلۡخَبِیرُ ۝١٤﴾</q> - تفسير ٧٧٨٨٥- قال مقاتل بن سليمان: <q>﴿ألا يَعْلَمُ مَن خَلَقَ﴾</q> يقول: أنا خلقتُ السِّرَّ في القلوب، ألا أكون عالِمًا بما أخلق من السّرّ في القلوب، <q>﴿وهُوَ اللَّطِيفُ الخَبِيرُ﴾</q> يعني: لَطف عِلْمه بما في القلوب، خبيرٌ بما فيها من السِّرِّ والوسوسة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩١.
67,15," <q>﴿هُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ ذَلُولࣰا فَٱمۡشُوا۟ فِی مَنَاكِبِهَا وَكُلُوا۟ مِن رِّزۡقِهِۦۖ وَإِلَیۡهِ ٱلنُّشُورُ ۝١٥﴾</q> - تفسير ٧٧٨٨٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿مَناكِبِها﴾</q>، قال: جبالها{1}. (١٤/٦١٢) ٧٧٨٨٧- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: <q>﴿مَناكِبِها﴾</q>، قال: أطرافها{2}. (١٤/٦١٢) ٧٧٨٨٨- عن قتادة: أنّ بَشير بن كعب قرأ هذه الآية: <q>﴿فامْشُوا فِي مَناكِبِها﴾</q>، فقال لجاريته: إن دريتِ ما مَناكبها فأنت حُرّة لوجه الله. فقالت: فإن مناكبها: جبالها. فسأل أبا الدّرداء، فقال: دعْ ما يَريبك إلى ما لا يَريبك{3}. (١٤/٦١٢) ٧٧٨٨٩- قال الضَّحّاك بن مُزاحِم: <q>﴿مَناكِبِها﴾</q> آكامها{4}. (ز) ٧٧٨٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مَناكِبِها﴾</q>، قال: أطرافها، وفِجاجها{5}٦٧٠٦. (١٤/٦١٢) ٦٧٠٦ ذكر ابنُ عطية (٨/٣٥٧) قول مجاهد، وعلّق عليه قائلًا: «وهذا قول جارٍ مع اللغة؛ لأنها تنكب يَمنة ويَسرة، وينكب الماشي فيها في مناكب». ٧٧٨٩١- قال مجاهد بن جبر= (ز) ٧٧٨٩٢- والحسن البصري: <q>﴿مَناكِبِها﴾</q> طرقها{6}. (ز) ٧٧٨٩٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿مَناكِبِها﴾</q>، قال: في جبالها{7}. (ز) ٧٧٨٩٤- قال محمد بن السّائِب الكلبي: <q>﴿مَناكِبِها﴾</q> أطرافها{8}. (ز) ٧٧٨٩٥- قال مقاتل بن سليمان: <q>﴿هُوَ الَّذِي جَعَلَ لَكُمُ الأَرْضَ ذَلُولًا﴾</q> أثبَتها بالجبال؛ لئلا تزول بأهلها، <q>﴿فامْشُوا﴾</q> يعني: فمُرّوا <q>﴿فِي مَناكِبِها﴾</q> يعني: في نواحيها وجوانبها آمنين كيف شِئتم، <q>﴿وكُلُوا مِن رِزْقِهِ﴾</q> الحلال، <q>﴿وإلَيْهِ النُّشُورُ﴾</q> يقول: إلى الله تُبعثُون مِن قبوركم أحياء بعد الموت{9}٦٧٠٧. (ز) ٦٧٠٧ في قوله: <q>﴿مناكبها﴾</q> قولان: الأول: جبالها. الثاني: نواحيها وأطرافها. وعلّق ابنُ القيم (٣/١٧٤) على القول الأول، فقال: «وحسُن التعبير بمناكبها عن طُرقها وفِجاجها لما تقدّم من وصفها بكونها ذلولًا، فالماشي عليها يطأ على مناكبها، وهو أعلى شيء فيها، ولهذا فُسّرتْ المناكب بالجبل؛ كمناكب الإنسان وهي أعاليه. قالوا: وذلك تنبيه على أنّ المشي في سُهولها أيسر». وقد رجّح ابنُ جرير (٢٣/١٢٩) القول الثاني مستندًا إلى اللغة، فقال: «وأولى القولين عندي بالصواب قول مَن قال: معنى ذلك: فامشوا في نواحيها وجوانبها، وذلك أنّ نواحيها نظير مناكب الإنسان التي هي من أطرافه». ورجّح ابنُ القيم -مستندًا إلى الدلالة العقلية- أنّ المناكب هي الأعالي، فقال: «والذي يظهر أنّ المراد بالمناكب: الأعالي. وهذا الوجه الذي يمشي عليه الحيوان هو العالي من الأرض دون الوجه المقابل له، فإن سطح الكرة أعلاها، والمشي إنما يقع في سَطحها، وحسُن التعبير عنه بالمناكب لما تقدم من وصفها بأنها ذلول». ",footnotes:1:أخرجه ابن جرير ٢٣/١٢٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/١٢٨.أخرجه ابن جرير ٢٣/١٢٨-١٢٩. وعزاه السيوطي إلى ابن المنذر، واللفظ له.تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨. وجاء في طبعة دار التفسير لتفسير الثعلبي ٢٧/١٠٧: أكمامها.تفسير مجاهد ص٦٦٧، وأخرجه ابن جرير ٢٣/١٢٩ ولفظه: طرقها وفجاجها. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٣-. وفي تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨ عن الحسن بلفظ: سُبلها.أخرجه عبد الرزاق ٢/٣٠٥، وابن جرير ٢٣/١٢٨ من طريقي معمر وسعيد.تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨.تفسير مقاتل بن سليمان ٤/٣٩١. وتفسير <q>﴿مناكبها﴾</q> عند البغوي ٨/١٧٨، والثعلبي ٩/٣٥٩ منسوبًا إلى مقاتل دون تعيينه.
67,16," <q>﴿ءَأَمِنتُم مَّن فِی ٱلسَّمَاۤءِ أَن یَخۡسِفَ بِكُمُ ٱلۡأَرۡضَ﴾</q> - تفسير ٧٧٨٩٦- قال عبد الله بن عباس: <q>﴿أأَمِنتُمْ مَن فِي السَّماءِ﴾</q>، أي: عذاب مَن في السماء إنْ عَصَيتموه{1}. (ز) ٧٧٨٩٧- عن مجاهد بن جبر، في قوله: <q>﴿أأَمِنتُمْ مَن فِي السَّماءِ﴾</q>، قال: الله تعالى{2}. (١٤/٦١٣) ٧٧٨٩٨- قال مقاتل بن سليمان: <q>﴿أأَمِنتُمْ﴾</q> عقوبة <q>﴿مَن فِي السَّماءِ﴾</q> يعني: الرّبّ -تبارك وتعالى- نفسه؛ لأنه في السماء العُليا{3}. (ز) <q>﴿فَإِذَا هِیَ تَمُورُ ۝١٦﴾</q> - تفسير ٧٧٨٩٩- عن مجاهد بن جبر، في قوله: <q>﴿فَإذا هِيَ تَمُورُ﴾</q>، قال: يمُور بعضها في بعض، واستدارتها{4}. (١٤/٦١٣) ٧٧٩٠٠- قال الضَّحّاك بن مُزاحِم: <q>﴿فَإذا هِيَ تَمُورُ﴾</q> تدور بهم، وهم في قَعرها{5}. (ز) ٧٧٩٠١- قال الحسن البصري: <q>﴿فَإذا هِيَ تَمُورُ﴾</q> أي: تتحرّك بأهلها{6}. (ز) ٧٧٩٠٢- قال مقاتل بن سليمان: <q>﴿فَإذا هِيَ تَمُورُ﴾</q> يعني: فإذا هي تدور بكم إلى الأرض السُّفلى{3}. (ز) ",footnotes:1:تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨.عزاه السيوطي إلى ابن جرير، والفريابي، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩١.عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن جرير، وابن المنذر.تفسير الثعلبي ٩/٣٦٠.تفسير الثعلبي ٩/٣٦٠، وتفسير البغوي ٨/١٧٨.تفسير مقاتل بن سليمان ٤/٣٩١.
67,17," <q>﴿أَمۡ أَمِنتُم مَّن فِی ٱلسَّمَاۤءِ أَن یُرۡسِلَ عَلَیۡكُمۡ حَاصِبࣰاۖ فَسَتَعۡلَمُونَ كَیۡفَ نَذِیرِ ۝١٧﴾</q> - تفسير ٧٧٩٠٣- قال مقاتل بن سليمان: <q>﴿أمْ أمِنتُمْ﴾</q> عقوبة <q>﴿مَن فِي السَّماءِ﴾</q> يعني: الرّبّ ﷿ <q>﴿أنْ يُرْسِلَ عَلَيْكُمْ حاصِبًا﴾</q> يعني: الحجارة من السماء، كما فَعل بمن كان قبلكم مِن كفار العرب الخالية؛ قوم لوط وغيرهم، <q>﴿فَسَتَعْلَمُونَ﴾</q> يا أهل مكة عند نزول العذاب <q>﴿كَيْفَ نَذِيرِ﴾</q> يقول: كيف عذابي{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٢.
67,18," <q>﴿وَلَقَدۡ كَذَّبَ ٱلَّذِینَ مِن قَبۡلِهِمۡ فَكَیۡفَ كَانَ نَكِیرِ ۝١٨﴾</q> - تفسير ٧٧٩٠٤- قال مقاتل بن سليمان: <q>﴿ولَقَدْ كَذَّبَ الَّذِينَ مِن قَبْلِهِمْ﴾</q> يعني: قبل كفار مكة مِن الأمم الخالية؛ رُسلَهم، فعذّبناهم <q>﴿فَكَيْفَ كانَ نَكِيرِ﴾</q> يعني: تغييري وإنكاري، ألم يجدوا العذاب حقًّا، يُخوّف كفار مكة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٢.
67,19," <q>﴿أَوَلَمۡ یَرَوۡا۟ إِلَى ٱلطَّیۡرِ فَوۡقَهُمۡ صَـٰۤفَّـٰتࣲ وَیَقۡبِضۡنَۚ مَا یُمۡسِكُهُنَّ إِلَّا ٱلرَّحۡمَـٰنُۚ إِنَّهُۥ بِكُلِّ شَیۡءِۭ بَصِیرٌ ۝١٩﴾</q> - تفسير ٧٧٩٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ﴾</q> قال: <q>﴿صافّاتٍ﴾</q> يَبسُطنَ أجنحتهنّ، <q>﴿ويَقْبِضْنَ﴾</q> قال: يَضربنَ بأجنحتهنّ{1}. (١٤/٦١٣) ٧٧٩٠٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿صافّاتٍ﴾</q>، قال: الطير يَصُفّ جناحه كما رأيتَ، ثم يَقبضه{2}. (ز) ٧٧٩٠٧- قال مقاتل بن سليمان: <q>﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ ويَقْبِضْنَ﴾</q> يعني: الأجنحة؛ حين يُردنَ أن يَقعنَ، <q>﴿ما يُمْسِكُهُنَّ إلّا الرَّحْمنُ﴾</q> عند القَبْض والبَسْط{3}. (ز) ",footnotes:1:تفسير مجاهد ص٦٦٧، وأخرج نحوه ابن جرير ٢٣/١٣٠، وأخرج شطره الأول الفريابي، وعبد بن حميد -كما في تغليق التعليق ٤/٣٤٦-، وابن أبي حاتم -كما في الفتح ٦/٣٤٨، ٨/٦٦١-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٠٥، وابن جرير ٢٣/١٣٠.تفسير مقاتل بن سليمان ٤/٣٩٢.
67,20," <q>﴿أَمَّنۡ هَـٰذَا ٱلَّذِی هُوَ جُندࣱ لَّكُمۡ یَنصُرُكُم مِّن دُونِ ٱلرَّحۡمَـٰنِۚ﴾</q> - تفسير ٧٧٩٠٨- قال عبد الله بن عباس: <q>﴿جُنْدٌ لَكُمْ﴾</q> أي: مَنعة لكم{1}. (ز) ٧٧٩٠٩- قال مقاتل بن سليمان: <q>﴿أمَّنْ هذا الَّذِي هُوَ جُنْدٌ﴾</q> يعني: حزب <q>﴿لَكُمْ﴾</q> يا أهل مكة <q>﴿يَنْصُرُكُمْ﴾</q> يمنعكم <q>﴿مِن دُونِ الرَّحْمنِ﴾</q> إذا نزل بكم العذاب{2}. (ز) <q>﴿إِنِ ٱلۡكَـٰفِرُونَ إِلَّا فِی غُرُورٍ ۝٢٠﴾</q> - تفسير ٧٧٩١٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿إلّا فِي غُرُورٍ﴾</q>. قال: في باطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حسان: تَمنَّتك الأماني من بعيد وقول الكفر يَرجع في غُرور؟{3}. (١٤/٦١٤) ٧٧٩١١- قال مقاتل بن سليمان: <q>﴿إنِ الكافِرُونَ﴾</q> يعني: ما <q>﴿إلّا فِي غُرُورٍ﴾</q> في باطل، الذي ليس بشيء{2}. (ز) ",footnotes:1:تفسير الثعلبي ٩/٣٦٠، وتفسير البغوي ٨/١٧٩.تفسير مقاتل بن سليمان ٤/٣٩٢.عزاه السيوطي إلى الطستي.تفسير مقاتل بن سليمان ٤/٣٩٢.
67,21," <q>﴿أَمَّنۡ هَـٰذَا ٱلَّذِی یَرۡزُقُكُمۡ إِنۡ أَمۡسَكَ رِزۡقَهُۥۚ بَل لَّجُّوا۟ فِی عُتُوࣲّ وَنُفُورٍ ۝٢١﴾</q> - تفسير ٧٧٩١٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فِي عُتُوٍّ ونُفُورٍ﴾</q>، قال: في ضلال{1}. (١٤/٦١٤) ٧٧٩١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فِي عُتُوٍّ ونُفُورٍ﴾</q>، قال: كُفور{2}. (١٤/٦١٤) ٧٧٩١٤- قال مقاتل بن سليمان: <q>﴿أمَّنْ هذا الَّذِي يَرْزُقُكُمْ﴾</q> من المطر، من الآلهة غيري <q>﴿إنْ أمْسَكَ رِزْقَهُ﴾</q> عنكم، فهاتُوا المطر. يقول الله تعالى: أنا الرّزاق، <q>﴿بَلْ لَجُّوا فِي عُتُوٍّ﴾</q> يعني: تَمادَوا في الكفر، <q>﴿ونُفُورٍ﴾</q> يعني: تَباعُد من الإيمان{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/١٣١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٦٦٧، وأخرجه عبد بن حميد -كما في تغليق التعليق ٤/٣٤٦-، وابن جرير ٢٣/١٣٢. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٢-٣٩٣.
67,22," <q>﴿أَفَمَن یَمۡشِی مُكِبًّا عَلَىٰ وَجۡهِهِۦۤ أَهۡدَىٰۤ أَمَّن یَمۡشِی سَوِیًّا عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٢٢﴾</q> - تفسير ٧٧٩١٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</q> قال: في الضّلالة، <q>﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</q> قال: مُهتديًا{1}. (١٤/٦١٤) ٧٧٩١٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</q> قال: في الضّلالة، <q>﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</q> قال: على الحقّ المستقيم{2}. (١٤/٦١٤) ٧٧٩١٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</q> يعني: الكافر، <q>﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</q> المؤمن{3}. (ز) ٧٧٩١٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</q> قال: هو الكافر عمِل بمعصية الله، فحَشره الله يوم القيامة على وجهه، <q>﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</q> قال: المؤمن عمِل بطاعة الله، فحَشره الله على طاعته{4}. (١٤/٦١٥) ٧٧٩١٩- قال مقاتل بن سليمان: <q>﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ﴾</q> يعني: الكافر يمشي ضالًّا في الكفر أعمى القلب، يعني: أبا جهل بن هشام <q>﴿أهْدى أمَّنْ يَمْشِي سَوِيًّا﴾</q> يعني: النبي ﷺ مُؤمنًا مُهتديًا، نقيّ القلب <q>﴿عَلى صِراطٍ مُسْتَقِيمٍ﴾</q> يعني: طريق الإسلام{5}٦٧٠٨. (ز) ٦٧٠٨ قال ابنُ جرير (٢٣/١٣٢): «قوله تعالى: <q>﴿أفمن يمشي مكبا على وجهه أهدى أمن يمشي سويا على صراط مستقيم﴾</q> يقول -تعالى ذِكره-: أفمن يمشي -أيها الناس- مُكبًّا على وجهه لا يُبصر ما بين يديه، وما عن يمينه وشماله <q>﴿أهدى﴾</q> أشدّ استقامة على الطريق، وأهدى له، <q>﴿أمن يمشي سويا﴾</q> مَشي بني آدم على قدميه <q>﴿على صراط مستقيم﴾</q> يقول: على طريق لا اعوجاج فيه». وذكر على ذلك أقوال السلف، ثم ذكر قول مَن قال: عُني بذلك: أنّ الكافر يحشره الله يوم القيامة على وجهه. ولم يعلّق عليه. وذكر ابنُ عطية (٨/٣٦٠-٣٦١) في نزول هذه الآية عدة أقوال، ثم وجّه معنى الآية عليها، فقال: «واخَتلف أهل التأويل في سبب قوله: <q>﴿أفَمَن يَمْشِي مُكِبًّا﴾</q> الآية، فقال جماعة مِن رواة الأسباب: نزلت مثلًا لأبي جهل بن هشام وحمزة بن عبد المطلب. وقال ابن عباس، وابن الكلبي، وغيره: نزلت مثلًا لأبي جهل بن هشام ومحمد ﷺ. وقال ابن عباس أيضًا، ومجاهد، والضَّحّاك: نزلت مثالًا للمؤمنين والكافرين على العموم. وقال قتادة: نزلت مُخبرة عن حال القيامة، وإنّ الكفار يمشُون فيها على وجوههم، والمؤمنون يمشُون على استقامة، وقيل للنبي: كيف يمشي الكافر على وجهه؟ قال: «إنّ الذي أمشاه في الدنيا على رجليه قادر على أن يُمشيه في الآخرة على وجهه». فوقف الكفار على هاتين الحالتين حينئذ، ففي الأقوال الثلاثة الأُول المشي مجاز يُتخيّل، وفي القول الرابع هو حقيقة يقع يوم القيامة». ",footnotes:1:أخرجه ابن جرير ٢٣/١٣٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٦٦٧، وأخرجه ابن جرير ٢٣/١٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/١٣٣.أخرجه عبد الرزاق ٢/٣٠٥، وابن جرير ٢٣/١٣٣-١٣٤ بنحوه من طريق سعيد، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٨٦ (١٢٠)- من طريق خليد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٣٩٣. وتفسير <q>﴿قَلِيلًا ما تَشْكُرُونَ﴾</q> بنحوه في تفسير البغوي ٨/١٨٠ منسوبًا إلى مقاتل دون تعيينه.
67,23," <q>﴿قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ ۝٢٣﴾</q> - تفسير ٧٧٩٢٠- قال مقاتل بن سليمان: <q>﴿قُلْ هُوَ الَّذِي أنْشَأَكُمْ﴾</q> يعني: خَلَقكم، <q>﴿وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ﴾</q> يعني: القلوب، <q>﴿قَلِيلًا ما تَشْكُرُونَ﴾</q> يعني بالقليل: أنهم قوم لا يَعقلون، فيشكروا ربّ هذه النعم البَيِّنة في حُسن خَلْقهم، فيُوحِّدونه{1}. (ز) <q>﴿قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ ۝٢٣﴾</q> - آثار متعلقة بالآية ٧٧٩٢١- عن عبد الله بن عباس قال: قال النَّبِيّ ﷺ: «مَن اشتكى ضِرسه فليَضع أصبعه عليه، وليقرأ هذه الآية: <q>﴿هُوَ الَّذِي أنْشَأَكُمْ وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ قَلِيلًا ما تَشْكُرُونَ﴾</q>»{2}. (١٤/٦١٢) ٧٧٩٢٢- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «مَن اشتكى ضِرسه فليَضع أصبعه عليه، وليقرأ هاتين الآيتين سبع مرات: <q>﴿وهُوَ الَّذِي أنْشَأَكُمْ مِن نَفْسٍ واحِدَةٍ فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ قَدْ فَصَّلْنا الآياتِ لِقَوْمٍ يَفْقَهُونَ﴾</q> [الأنعام:٩٨]، <q>﴿هُوَ الَّذِي أنْشَأَكُمْ وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ قَلِيلًا ما تَشْكُرُونَ﴾</q> فإنه يَبْرأ بإذن الله تعالى»{3}. (١٤/٦١٢) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣. وتفسير <q>﴿قَلِيلًا ما تَشْكُرُونَ﴾</q> بنحوه عند البغوي ٨/١٨٠ منسوبًا إلى مقاتل دون تعيينه.أخرجه البيهقي في الدعوات الكبير ٢/٢٥٦ (٦٠٨)، والخطيب في تاريخ بغداد ١٠/٧٣ (٢٩٥٨)، من طريق سليمان بن ربيع، عن همام بن مسلم، عن مقاتل بن حيّان، عن عكرمة، عن ابن عباس به. وقال البيهقي: «هذا إسناد فيه مَن هو مجهول لا يُعرف».عزاه السيوطي إلى الدارقطني في الأفراد.
67,24," <q>﴿قُلۡ هُوَ ٱلَّذِی ذَرَأَكُمۡ فِی ٱلۡأَرۡضِ وَإِلَیۡهِ تُحۡشَرُونَ ۝٢٤﴾</q> - تفسير ٧٧٩٢٣- قال مقاتل بن سليمان: <q>﴿قُلْ هُوَ الَّذِي ذَرَأَكُمْ فِي الأَرْضِ﴾</q> يعني: خَلَقكم في الأرض، <q>﴿وإلَيْهِ﴾</q> يعني: إلى الله <q>﴿تُحْشَرُونَ﴾</q> في الآخرة، فيَجزيكم بأعمالكم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣.
67,25," <q>﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٥﴾</q> - تفسير ٧٧٩٢٤- قال مقاتل بن سليمان: <q>﴿ويَقُولُونَ مَتى هذا الوَعْدُ﴾</q> متى هذا الذي تُوعدنا به؛ <q>﴿إنْ كُنْتُمْ صادِقِينَ﴾</q> بأنّ العذاب نازِل بنا في الدنيا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣.
67,26," <q>﴿قُلۡ إِنَّمَا ٱلۡعِلۡمُ عِندَ ٱللَّهِ وَإِنَّمَاۤ أَنَا۠ نَذِیرࣱ مُّبِینࣱ ۝٢٦﴾</q> - تفسير ٧٧٩٢٥- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> لكفار مكة: <q>﴿إنَّما العِلْمُ﴾</q> يعني: عِلْم نزول العذاب بكم ببدر <q>﴿عِنْدَ اللَّهِ﴾</q> وليس بيدي، <q>﴿وإنَّما أنا نَذِيرٌ﴾</q> بالعذاب <q>﴿مُبِينٌ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣.
