quran[14]{c,v,t}:
  67,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَسِرُّوا۟ قَوۡلَكُمۡ أَوِ ٱجۡهَرُوا۟ بِهِۦۤۖ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝١٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٨٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وأَسِرُّوا قَوْلَكُمْ﴾</span> نزلت في المشركين، كانوا يَنالون مِن رسول الله ﷺ، فيُخبِره جبريل ﵇ بما قالوا، فقال بعضهم لبعض: أسِرُّوا قولكم؛ كي لا يسمع إله محمد{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَسِرُّوا۟ قَوۡلَكُمۡ أَوِ ٱجۡهَرُوا۟ بِهِۦۤۖ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَسِرُّوا قَوْلَكُمْ﴾</span> في النبي ﷺ في القلوب، <span class="qpc-hafs">﴿أوِ اجْهَرُوا بِهِ﴾</span> يعني: أو تَكلّموا به علانية. يعني به: كفار مكة؛ <span class="qpc-hafs">﴿إنَّهُ عَلِيمٌ بِذاتِ الصُّدُورِ﴾</span> يعني: بما في القلوب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أورده الثعلبي ٩/٣٥٩، والواحدي في أسباب النزول ص٤٤٢، والبغوي ٨/١٧٨.|2:تفسير مقاتل بن سليمان ٤/٣٩١.
  67,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَا یَعۡلَمُ مَنۡ خَلَقَ وَهُوَ ٱللَّطِیفُ ٱلۡخَبِیرُ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا يَعْلَمُ مَن خَلَقَ﴾</span> يقول: أنا خلقتُ السِّرَّ في القلوب، ألا أكون عالِمًا بما أخلق من السّرّ في القلوب، <span class="qpc-hafs">﴿وهُوَ اللَّطِيفُ الخَبِيرُ﴾</span> يعني: لَطف عِلْمه بما في القلوب، خبيرٌ بما فيها من السِّرِّ والوسوسة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩١.
  67,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ ذَلُولࣰا فَٱمۡشُوا۟ فِی مَنَاكِبِهَا وَكُلُوا۟ مِن رِّزۡقِهِۦۖ وَإِلَیۡهِ ٱلنُّشُورُ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿مَناكِبِها﴾</span>، قال: جبالها{1}. (١٤/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- في قوله: <span class="qpc-hafs">﴿مَناكِبِها﴾</span>، قال: أطرافها{2}. (١٤/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٨٨<span class="dash">-</span></span> عن قتادة: أنّ <span class="name-2">بَشير بن كعب</span> قرأ هذه الآية: <span class="qpc-hafs">﴿فامْشُوا فِي مَناكِبِها﴾</span>، فقال لجاريته: إن دريتِ ما مَناكبها فأنت حُرّة لوجه الله. فقالت: فإن مناكبها: جبالها. فسأل أبا الدّرداء، فقال: دعْ ما يَريبك إلى ما لا يَريبك{3}. (١٤/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٨٩<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿مَناكِبِها﴾</span> آكامها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مَناكِبِها﴾</span>، قال: أطرافها، وفِجاجها{5}<span class=comment-ref>٦٧٠٦</span>. (١٤/٦١٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٦</span> ذكر <u>ابنُ عطية</u> (٨/٣٥٧) قول مجاهد، و<span class="comment-type-4">علّق</span> عليه قائلًا: «وهذا قول <span class="mustanad">جارٍ مع اللغة</span>؛ لأنها تنكب يَمنة ويَسرة، وينكب الماشي فيها في مناكب».</div></p><p><div></p><p><p><span class="item-no">٧٧٨٩١<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٢<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿مَناكِبِها﴾</span> طرقها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿مَناكِبِها﴾</span>، قال: في جبالها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿مَناكِبِها﴾</span> أطرافها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُوَ الَّذِي جَعَلَ لَكُمُ الأَرْضَ ذَلُولًا﴾</span> أثبَتها بالجبال؛ لئلا تزول بأهلها، <span class="qpc-hafs">﴿فامْشُوا﴾</span> يعني: فمُرّوا <span class="qpc-hafs">﴿فِي مَناكِبِها﴾</span> يعني: في نواحيها وجوانبها آمنين كيف شِئتم، <span class="qpc-hafs">﴿وكُلُوا مِن رِزْقِهِ﴾</span> الحلال، <span class="qpc-hafs">﴿وإلَيْهِ النُّشُورُ﴾</span> يقول: إلى الله تُبعثُون مِن قبوركم أحياء بعد الموت{9}<span class=comment-ref>٦٧٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٧</span> في قوله: <span class="qpc-hafs">﴿مناكبها﴾</span> قولان: <b>الأول</b>: جبالها. <b>الثاني</b>: نواحيها وأطرافها.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ القيم</u> (٣/١٧٤) على القول الأول، فقال: «وحسُن التعبير بمناكبها عن طُرقها وفِجاجها لما تقدّم من وصفها بكونها ذلولًا، فالماشي عليها يطأ على مناكبها، وهو أعلى شيء فيها، ولهذا فُسّرتْ المناكب بالجبل؛ كمناكب الإنسان وهي أعاليه. قالوا: وذلك تنبيه على أنّ المشي في سُهولها أيسر».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٣/١٢٩) القول الثاني <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وأولى القولين عندي بالصواب قول مَن قال: معنى ذلك: فامشوا في نواحيها وجوانبها، وذلك أنّ نواحيها نظير مناكب الإنسان التي هي من أطرافه».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ القيم</u> -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- أنّ المناكب هي الأعالي، فقال: «والذي يظهر أنّ المراد بالمناكب: الأعالي. وهذا الوجه الذي يمشي عليه الحيوان هو العالي من الأرض دون الوجه المقابل له، فإن سطح الكرة أعلاها، والمشي إنما يقع في سَطحها، وحسُن التعبير عنه بالمناكب لما تقدم من وصفها بأنها ذلول».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٢٧. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٣/١٢٨.|3:أخرجه ابن جرير ٢٣/١٢٨-١٢٩. وعزاه السيوطي إلى ابن المنذر، واللفظ له.|4:تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨. وجاء في طبعة دار التفسير لتفسير الثعلبي ٢٧/١٠٧: أكمامها.|5:تفسير مجاهد ص٦٦٧، وأخرجه ابن جرير ٢٣/١٢٩ ولفظه: طرقها وفجاجها. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|6:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٣-. وفي تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨ عن الحسن بلفظ: سُبلها.|7:أخرجه عبد الرزاق ٢/٣٠٥، وابن جرير ٢٣/١٢٨ من طريقي معمر وسعيد.|8:تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨.|9:تفسير مقاتل بن سليمان ٤/٣٩١. وتفسير <span class="qpc-hafs">﴿مناكبها﴾</span> عند البغوي ٨/١٧٨، والثعلبي ٩/٣٥٩ منسوبًا إلى مقاتل دون تعيينه.
  67,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ءَأَمِنتُم مَّن فِی ٱلسَّمَاۤءِ أَن یَخۡسِفَ بِكُمُ ٱلۡأَرۡضَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٩٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿أأَمِنتُمْ مَن فِي السَّماءِ﴾</span>، أي: عذاب مَن في السماء إنْ عَصَيتموه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿أأَمِنتُمْ مَن فِي السَّماءِ﴾</span>، قال: الله تعالى{2}. (١٤/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٨٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أأَمِنتُمْ﴾</span> عقوبة <span class="qpc-hafs">﴿مَن فِي السَّماءِ﴾</span> يعني: الرّبّ -تبارك وتعالى- نفسه؛ لأنه في السماء العُليا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هِیَ تَمُورُ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٨٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فَإذا هِيَ تَمُورُ﴾</span>، قال: يمُور بعضها في بعض، واستدارتها{4}. (١٤/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٠٠<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿فَإذا هِيَ تَمُورُ﴾</span> تدور بهم، وهم في قَعرها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٠١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَإذا هِيَ تَمُورُ﴾</span> أي: تتحرّك بأهلها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا هِيَ تَمُورُ﴾</span> يعني: فإذا هي تدور بكم إلى الأرض السُّفلى{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/٣٥٩، وتفسير البغوي ٨/١٧٨.|2:عزاه السيوطي إلى ابن جرير، والفريابي، وعبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٣٩١.|4:عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن جرير، وابن المنذر.|5:تفسير الثعلبي ٩/٣٦٠.|6:تفسير الثعلبي ٩/٣٦٠، وتفسير البغوي ٨/١٧٨.|7:تفسير مقاتل بن سليمان ٤/٣٩١.
  67,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ أَمِنتُم مَّن فِی ٱلسَّمَاۤءِ أَن یُرۡسِلَ عَلَیۡكُمۡ حَاصِبࣰاۖ فَسَتَعۡلَمُونَ كَیۡفَ نَذِیرِ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ أمِنتُمْ﴾</span> عقوبة <span class="qpc-hafs">﴿مَن فِي السَّماءِ﴾</span> يعني: الرّبّ ﷿ <span class="qpc-hafs">﴿أنْ يُرْسِلَ عَلَيْكُمْ حاصِبًا﴾</span> يعني: الحجارة من السماء، كما فَعل بمن كان قبلكم مِن كفار العرب الخالية؛ قوم لوط وغيرهم، <span class="qpc-hafs">﴿فَسَتَعْلَمُونَ﴾</span> يا أهل مكة عند نزول العذاب <span class="qpc-hafs">﴿كَيْفَ نَذِيرِ﴾</span> يقول: كيف عذابي{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٢.
  67,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ كَذَّبَ ٱلَّذِینَ مِن قَبۡلِهِمۡ فَكَیۡفَ كَانَ نَكِیرِ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ كَذَّبَ الَّذِينَ مِن قَبْلِهِمْ﴾</span> يعني: قبل كفار مكة مِن الأمم الخالية؛ رُسلَهم، فعذّبناهم <span class="qpc-hafs">﴿فَكَيْفَ كانَ نَكِيرِ﴾</span> يعني: تغييري وإنكاري، ألم يجدوا العذاب حقًّا، يُخوّف كفار مكة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٢.
  67,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ إِلَى ٱلطَّیۡرِ فَوۡقَهُمۡ صَـٰۤفَّـٰتࣲ وَیَقۡبِضۡنَۚ مَا یُمۡسِكُهُنَّ إِلَّا ٱلرَّحۡمَـٰنُۚ إِنَّهُۥ بِكُلِّ شَیۡءِۭ بَصِیرٌ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ﴾</span> قال: <span class="qpc-hafs">﴿صافّاتٍ﴾</span> يَبسُطنَ أجنحتهنّ، <span class="qpc-hafs">﴿ويَقْبِضْنَ﴾</span> قال: يَضربنَ بأجنحتهنّ{1}. (١٤/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿صافّاتٍ﴾</span>، قال: الطير يَصُفّ جناحه كما رأيتَ، ثم يَقبضه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ ويَقْبِضْنَ﴾</span> يعني: الأجنحة؛ حين يُردنَ أن يَقعنَ، <span class="qpc-hafs">﴿ما يُمْسِكُهُنَّ إلّا الرَّحْمنُ﴾</span> عند القَبْض والبَسْط{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦٦٧، وأخرج نحوه ابن جرير ٢٣/١٣٠، وأخرج شطره الأول الفريابي، وعبد بن حميد -كما في تغليق التعليق ٤/٣٤٦-، وابن أبي حاتم -كما في الفتح ٦/٣٤٨، ٨/٦٦١-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه عبد الرزاق ٢/٣٠٥، وابن جرير ٢٣/١٣٠.|3:تفسير مقاتل بن سليمان ٤/٣٩٢.
  67,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمَّنۡ هَـٰذَا ٱلَّذِی هُوَ جُندࣱ لَّكُمۡ یَنصُرُكُم مِّن دُونِ ٱلرَّحۡمَـٰنِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٠٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿جُنْدٌ لَكُمْ﴾</span> أي: مَنعة لكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمَّنْ هذا الَّذِي هُوَ جُنْدٌ﴾</span> يعني: حزب <span class="qpc-hafs">﴿لَكُمْ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿يَنْصُرُكُمْ﴾</span> يمنعكم <span class="qpc-hafs">﴿مِن دُونِ الرَّحْمنِ﴾</span> إذا نزل بكم العذاب{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنِ ٱلۡكَـٰفِرُونَ إِلَّا فِی غُرُورٍ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿إلّا فِي غُرُورٍ﴾</span>. قال: في باطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حسان:</p><p>تَمنَّتك الأماني من بعيد وقول الكفر يَرجع في غُرور؟{3}. (١٤/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنِ الكافِرُونَ﴾</span> يعني: ما <span class="qpc-hafs">﴿إلّا فِي غُرُورٍ﴾</span> في باطل، الذي ليس بشيء{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/٣٦٠، وتفسير البغوي ٨/١٧٩.|2:تفسير مقاتل بن سليمان ٤/٣٩٢.|3:عزاه السيوطي إلى الطستي.|4:تفسير مقاتل بن سليمان ٤/٣٩٢.
  67,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمَّنۡ هَـٰذَا ٱلَّذِی یَرۡزُقُكُمۡ إِنۡ أَمۡسَكَ رِزۡقَهُۥۚ بَل لَّجُّوا۟ فِی عُتُوࣲّ وَنُفُورٍ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فِي عُتُوٍّ ونُفُورٍ﴾</span>، قال: في ضلال{1}. (١٤/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فِي عُتُوٍّ ونُفُورٍ﴾</span>، قال: كُفور{2}. (١٤/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمَّنْ هذا الَّذِي يَرْزُقُكُمْ﴾</span> من المطر، من الآلهة غيري <span class="qpc-hafs">﴿إنْ أمْسَكَ رِزْقَهُ﴾</span> عنكم، فهاتُوا المطر. يقول الله تعالى: أنا الرّزاق، <span class="qpc-hafs">﴿بَلْ لَجُّوا فِي عُتُوٍّ﴾</span> يعني: تَمادَوا في الكفر، <span class="qpc-hafs">﴿ونُفُورٍ﴾</span> يعني: تَباعُد من الإيمان{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٣١. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مجاهد ص٦٦٧، وأخرجه عبد بن حميد -كما في تغليق التعليق ٤/٣٤٦-، وابن جرير ٢٣/١٣٢. وعزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٣٩٢-٣٩٣.
  67,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَمَن یَمۡشِی مُكِبًّا عَلَىٰ وَجۡهِهِۦۤ أَهۡدَىٰۤ أَمَّن یَمۡشِی سَوِیًّا عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</span> قال: في الضّلالة، <span class="qpc-hafs">﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> قال: مُهتديًا{1}. (١٤/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</span> قال: في الضّلالة، <span class="qpc-hafs">﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> قال: على الحقّ المستقيم{2}. (١٤/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</span> يعني: الكافر، <span class="qpc-hafs">﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> المؤمن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾</span> قال: هو الكافر عمِل بمعصية الله، فحَشره الله يوم القيامة على وجهه، <span class="qpc-hafs">﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> قال: المؤمن عمِل بطاعة الله، فحَشره الله على طاعته{4}. (١٤/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ﴾</span> يعني: الكافر يمشي ضالًّا في الكفر أعمى القلب، يعني: أبا جهل بن هشام <span class="qpc-hafs">﴿أهْدى أمَّنْ يَمْشِي سَوِيًّا﴾</span> يعني: النبي ﷺ مُؤمنًا مُهتديًا، نقيّ القلب <span class="qpc-hafs">﴿عَلى صِراطٍ مُسْتَقِيمٍ﴾</span> يعني: طريق الإسلام{5}<span class=comment-ref>٦٧٠٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٠٨</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٣/١٣٢): «قوله تعالى: <span class="qpc-hafs">﴿أفمن يمشي مكبا على وجهه أهدى أمن يمشي سويا على صراط مستقيم﴾</span> يقول -تعالى ذِكره-: أفمن يمشي -أيها الناس- مُكبًّا على وجهه لا يُبصر ما بين يديه، وما عن يمينه وشماله <span class="qpc-hafs">﴿أهدى﴾</span> أشدّ استقامة على الطريق، وأهدى له، <span class="qpc-hafs">﴿أمن يمشي سويا﴾</span> مَشي بني آدم على قدميه <span class="qpc-hafs">﴿على صراط مستقيم﴾</span> يقول: على طريق لا اعوجاج فيه». وذكر على ذلك <span class="mustanad">أقوال السلف</span>، ثم ذكر قول مَن قال: عُني بذلك: أنّ الكافر يحشره الله يوم القيامة على وجهه. ولم يعلّق عليه.</p><p>وذكر <u>ابنُ عطية</u> (٨/٣٦٠-٣٦١) في نزول هذه الآية عدة أقوال، ثم <span class="comment-type-1">وجّه</span> معنى الآية عليها، فقال: «واخَتلف أهل التأويل في سبب قوله: <span class="qpc-hafs">﴿أفَمَن يَمْشِي مُكِبًّا﴾</span> الآية، <b>فقال</b> جماعة مِن رواة الأسباب: نزلت مثلًا لأبي جهل بن هشام وحمزة بن عبد المطلب. <b>وقال</b> ابن عباس، وابن الكلبي، وغيره: نزلت مثلًا لأبي جهل بن هشام ومحمد ﷺ. <b>وقال</b> ابن عباس أيضًا، ومجاهد، والضَّحّاك: نزلت مثالًا للمؤمنين والكافرين على العموم. <b>وقال</b> قتادة: نزلت مُخبرة عن حال القيامة، وإنّ الكفار يمشُون فيها على وجوههم، والمؤمنون يمشُون على استقامة، وقيل للنبي: كيف يمشي الكافر على وجهه؟ قال: «<b>إنّ الذي أمشاه في الدنيا على رجليه قادر على أن يُمشيه في الآخرة على وجهه</b>». فوقف الكفار على هاتين الحالتين حينئذ، ففي الأقوال الثلاثة الأُول المشي مجاز يُتخيّل، وفي القول الرابع هو حقيقة يقع يوم القيامة».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٣٣. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مجاهد ص٦٦٧، وأخرجه ابن جرير ٢٣/١٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه ابن جرير ٢٣/١٣٣.|4:أخرجه عبد الرزاق ٢/٣٠٥، وابن جرير ٢٣/١٣٣-١٣٤ بنحوه من طريق سعيد، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٨٦ (١٢٠)- من طريق خليد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٣٩٣. وتفسير <span class="qpc-hafs">﴿قَلِيلًا ما تَشْكُرُونَ﴾</span> بنحوه في تفسير البغوي ٨/١٨٠ منسوبًا إلى مقاتل دون تعيينه.
  67,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ هُوَ الَّذِي أنْشَأَكُمْ﴾</span> يعني: خَلَقكم، <span class="qpc-hafs">﴿وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ﴾</span> يعني: القلوب، <span class="qpc-hafs">﴿قَلِيلًا ما تَشْكُرُونَ﴾</span> يعني بالقليل: أنهم قوم لا يَعقلون، فيشكروا ربّ هذه النعم البَيِّنة في حُسن خَلْقهم، فيُوحِّدونه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٢١<span class="dash">-</span></span> عن عبد الله بن عباس قال: قال النَّبِيّ ﷺ: «<b>مَن اشتكى ضِرسه فليَضع أصبعه عليه، وليقرأ هذه الآية: <span class="qpc-hafs">﴿هُوَ الَّذِي أنْشَأَكُمْ وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ قَلِيلًا ما تَشْكُرُونَ﴾</span></b>»{2}. (١٤/٦١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٧٩٢٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>مَن اشتكى ضِرسه فليَضع أصبعه عليه، وليقرأ هاتين الآيتين سبع مرات: <span class="qpc-hafs">﴿وهُوَ الَّذِي أنْشَأَكُمْ مِن نَفْسٍ واحِدَةٍ فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ قَدْ فَصَّلْنا الآياتِ لِقَوْمٍ يَفْقَهُونَ﴾</span></b> [الأنعام:٩٨]، <b><span class="qpc-hafs">﴿هُوَ الَّذِي أنْشَأَكُمْ وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ قَلِيلًا ما تَشْكُرُونَ﴾</span> فإنه يَبْرأ بإذن الله تعالى</b>»{3}. (١٤/٦١٢)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣. وتفسير <span class="qpc-hafs">﴿قَلِيلًا ما تَشْكُرُونَ﴾</span> بنحوه عند البغوي ٨/١٨٠ منسوبًا إلى مقاتل دون تعيينه.|2:أخرجه البيهقي في الدعوات الكبير ٢/٢٥٦ (٦٠٨)، والخطيب في تاريخ بغداد ١٠/٧٣ (٢٩٥٨)، من طريق سليمان بن ربيع، عن همام بن مسلم، عن مقاتل بن حيّان، عن عكرمة، عن ابن عباس به.</p><p>وقال البيهقي: «هذا إسناد فيه مَن هو مجهول لا يُعرف».|3:عزاه السيوطي إلى الدارقطني في الأفراد.
  67,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ هُوَ ٱلَّذِی ذَرَأَكُمۡ فِی ٱلۡأَرۡضِ وَإِلَیۡهِ تُحۡشَرُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ هُوَ الَّذِي ذَرَأَكُمْ فِي الأَرْضِ﴾</span> يعني: خَلَقكم في الأرض، <span class="qpc-hafs">﴿وإلَيْهِ﴾</span> يعني: إلى الله <span class="qpc-hafs">﴿تُحْشَرُونَ﴾</span> في الآخرة، فيَجزيكم بأعمالكم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣.
  67,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُونَ مَتى هذا الوَعْدُ﴾</span> متى هذا الذي تُوعدنا به؛ <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> بأنّ العذاب نازِل بنا في الدنيا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣.
  67,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ إِنَّمَا ٱلۡعِلۡمُ عِندَ ٱللَّهِ وَإِنَّمَاۤ أَنَا۠ نَذِیرࣱ مُّبِینࣱ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٧٩٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> لكفار مكة: <span class="qpc-hafs">﴿إنَّما العِلْمُ﴾</span> يعني: عِلْم نزول العذاب بكم ببدر <span class="qpc-hafs">﴿عِنْدَ اللَّهِ﴾</span> وليس بيدي، <span class="qpc-hafs">﴿وإنَّما أنا نَذِيرٌ﴾</span> بالعذاب <span class="qpc-hafs">﴿مُبِينٌ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٣٩٣.