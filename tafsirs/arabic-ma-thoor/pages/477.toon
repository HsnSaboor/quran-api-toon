41,11," <q>﴿ثُمَّ ٱسۡتَوَىٰۤ إِلَى ٱلسَّمَاۤءِ وَهِیَ دُخَانࣱ﴾</q> - تفسير ٦٨٣٧٠- عن عبد الله بن مسعود، وناس من أصحاب النبي ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز) ٦٨٣٧١- وعبد الله بن عباس -من طريق السُّدّيّ عن أبي مالك وأبي صالح- <q>﴿ثم استوى إلى السماء وهي دخان﴾</q>: وكان ذلك الدُّخان مِن تنفُّس الماء حين تنفَّس، فجعلها سماءً واحدة، ثم فتَقها فجعلها سبع سماوات{1}. (ز) ٦٨٣٧٢- عن سعيد بن جُبير، قال: سألتُ ابنَ عباس عن قوله: <q>﴿وكانَ عَرْشُهُ عَلى المَآءِ﴾</q> [هود:٧]؛ قلت: على أيِّ شيءٍ كان الماءُ قبل أن يُخلَق شيء؟ قال: على متن الريح. قال ابن جُريْج: قال سعيد بن جُبير: فقال ابنُ عباس: فكان يصعد إلى السماء بخار كبخار الأنهار، فاستصبر فعاد صَبِيرًا{2}، فذلك قوله: <q>﴿ثُمَّ اسْتَوى إلى السَّماءِ وهِيَ دُخانٌ﴾</q> ...{3}. (ز) ٦٨٣٧٣- قال الحسن البصري: <q>﴿وهِيَ دُخانٌ﴾</q> ملتصقة بالأرض{4}. (ز) ٦٨٣٧٤- قال مقاتل بن سليمان: <q>﴿ثُمَّ اسْتَوى إلى السَّماءِ وهِيَ دُخانٌ﴾</q> قبل ذلك{5}. (ز) <q>﴿فَقَالَ لَهَا وَلِلۡأَرۡضِ ٱئۡتِیَا طَوۡعًا أَوۡ كَرۡهࣰا قَالَتَاۤ أَتَیۡنَا طَاۤىِٕعِینَ ۝١١﴾</q> - تفسير ٦٨٣٧٥- عن عبد الله بن عباس -من طريق سفيان، عن ابن جريج، عن سليمان الأحول، عن طاووس- في قوله: <q>﴿فَقالَ لَها ولِلْأَرْضِ ائْتِيا طَوْعًا أوكَرْهًا﴾</q> قال: قال للسماء: أخرِجي شمسَكِ، وقمرَكِ، ونجومَكِ. وقال للأرض: شقِّقي أنهارَكِ، وأخرجي ثمارك. فقالتا: <q>﴿أتَيْنا طائِعِينَ﴾</q>{6}. (١٣/٩٥) ٦٨٣٧٦- عن عبد الله بن عباس -من طريق ابن عُليَّة، عن ابن جريج، عن سليمان الأحول، عن طاووس- في قوله: <q>﴿ائْتِيا﴾</q>، قال: أعْطِيا. وفي قوله: <q>﴿قالَتا أتَيْنا﴾</q>، قال: أعطينا{7}. (١٣/٩٥) ٦٨٣٧٧- عن الحسن البصري -من طريق ابن شَوْذب- في قول الله ﷿: <q>﴿ائتيا طوعًا أوكرهًا﴾</q>، قال: لو عَصَتا لَعذَّبهما عذابًا يجِدان ألَمَه{8}. (ز) ٦٨٣٧٨- قال مقاتل بن سليمان: <q>﴿فَقالَ لَها ولِلْأَرْضِ ائْتِيا طَوْعًا أوكَرْهًا﴾</q> عبادتي ومعرفتي، يعني: أعْطِيا الطاعة طيعًا <q>﴿أو كَرْهًا﴾</q>، وذلك أنّ الله تعالى حين خلقهما عرض عليهما الطاعة بالشهوات واللذات على الثواب والعقاب، فأبين أن [يحْملنها] مِن المخافة، فقال لهما الرب: ائتيا المعرفية لربكما والذِّكر له على غير ثواب ولا عقاب طوْعًا أوكرْهًا. <q>﴿قالَتا أتَيْنا طائِعِينَ﴾</q> يعني: أعطيناه طائعين{5}٥٧٣٩. (ز) ٥٧٣٩ ذكر ابنُ عطية (٧/٤٦٨) أنه اختُلف في هذه المقالة مِن السماء والأرض على قولين: الأول: أنها نطقت حقيقة، وجعل الله تعالى لها حياة وإدراكًا يقتضي نطقها. الثاني: أن هذا مجاز، وإنما المعنى أنها ظهر منها من اختيار الطاعة والخضوع والتذلل ما هو بمنزلة القول: أتَيْنا طائِعِين. ورجَّح القولَ الأول مستندًا إلى دلالة العقل، فقال: «والقول الأول أحسن؛ لأنه لا شيء يدفعه، ولأن العبرة به أتم، والقدرة فيه أظهر». ٦٨٣٧٩- عن حمّاد بن سَلمة -من طريق هُدْبة بن خالد- في قول الله ﷿، قال: لَمّا قال للسماوات والأرض: <q>﴿ائتيا طوعا أو كرها قالتا أتينا طائعين﴾</q>؛ أجابه أرضُ أصْبَهان، فأصْبَهان فَمُ الدنيا ولسانها{10}. (ز) <q>﴿فَقَالَ لَهَا وَلِلۡأَرۡضِ ٱئۡتِیَا طَوۡعًا أَوۡ كَرۡهࣰا قَالَتَاۤ أَتَیۡنَا طَاۤىِٕعِینَ ۝١١﴾</q> - آثار متعلقة بالآية ٦٨٣٨٠- عن علي بن أبي طالب -من طريق العبري- أنّه حلف ذات يوم، فقال: والذي خلق السماءَ مِن دُخان وماء{11}. (ز) ٦٨٣٨١- عن سعيد بن جُبير، قال: قال رجل لابن عباس: إنِّي أجِدُ في القرآن أشياء تَخْتَلِفُ علَيَّ: .... <q>﴿أمِ السَّماءُ بَناها﴾</q> إلى قوله: <q>﴿دَحاها﴾</q> [النازعات:٢٧-٣٠] فذكر خلْق السماء قبل خلْق الأرض، ثم قال: <q>﴿أئِنَّكُمْ لَتَكْفُرُونَ بِالَّذِي خَلَقَ الأَرْضَ فِي يَوْمَيْنِ﴾</q> إلى قوله: <q>﴿طَآئِعِينَ﴾</q> فذكر في هذه خلْق الأرض قبل خلْق السماء؟ ... [فأجاب ابن عباس]: خلَق الأرض في يومين، ثم خلَق السماء، ثم استوى إلى السماء فسواهن في يومين آخرين، ثم دحا الأرض، ودَحْوُها: أنْ أخْرَجَ منها الماء والمرعى، وخلَق الجبال والجمال والآكام وما بينهما في يومين آخرين، فذلك قوله: <q>﴿دَحاها﴾</q>{12}. (ز) ",footnotes:1:أخرجه ابن جرير ١/٤٦١ مطولًا.الصَّبير: سحاب أبيض متراكب متكاثف، يعني: تكاثف البخار وتراكم فصار سحابًا. النهاية (صبر).أخرجه عبد الرزاق في مصنفه ٥/٩٠-٩١ (٩٠٨٩).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٤٧-.تفسير مقاتل بن سليمان ٣/٧٣٧.أخرجه الحاكم ١/٢٧، والبيهقي في الأسماء والصفات (٨١٤). وعزاه السيوطي إلى ابن المنذر. كما أخرجه ابن جرير ٢٠/٣٩١ بنحوه من طريق مجاهد.أخرجه ابن جرير ٢٠/٣٩٢، وابن أبي حاتم -كما في التغليق ٤/٣٠٠-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن أحمد في زوائد الزهد ص٣٢٥.تفسير مقاتل بن سليمان ٣/٧٣٧.أخرجه أبو نعيم في أخبار أصبهان ١/٤١.أخرجه ابن أبي حاتم ٩/٣٠٦٤.أخرجه البخاري في صحيحه (ت: مصطفى البغا)، كتاب التفسير، باب تفسير سورة فصلت ٤/١٨١٦.
