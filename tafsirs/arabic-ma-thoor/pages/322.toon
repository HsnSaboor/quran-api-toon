tafsir[10]{c,v,t}:
21,1," مقدمة السورة ٤٨٦٨٠- عن عبد الله بن مسعود -من طريق عبد الرحمن بن يزيد- قال: بنو إسرائيل، والكهف، ومريم، وطه، والأنبياء؛ هُنَّ مِن العِتاق الأُوَل{1}، وهُنَّ مِن تِلادي{2}{3}٤٣٢٥. (١٠/٢٦٩) ٤٣٢٥ علَّق ابنُ عطية (٦/١٥١) على قول ابن مسعود بقوله: «يريد: مِن قديم ما كسبتُ وحفظتُ مِن القرآن، كالمال التّلاد». ٤٨٦٨١- عن عامر بن ربيعة -من طريق زيد بن أسلم-: أنّه نَزَل به رجلٌ مِن العرب، وأكرم عامِرٌ مثواه، وكلَّم فيه رسول اللهَ ﷺ، فجاء الرجلُ، فقال: إنِّي اسْتَقْطَعْتُ رسولَ الله ﷺ وادِيًا ما في العرب أفضل منه، وقد أردتُ أن أقطع لك منه قطعةً تكون لك ولعَقِبك. فقال عامر: لا حاجة لي في قَطِيعَتِكَ؛ نزلت اليومَ سورةٌ أذْهَلَتْنا عن الدنيا: <q>﴿اقترب للناس حسابهم وهم في غفلة معرضون﴾</q>{4}. (١٠/٢٧٠) ٤٨٦٨٢- عن عبد الله بن عباس -من طريق خصيف، عن مجاهد-: مكية{5}. (١٠/٢٦٩) ٤٨٦٨٣- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: نزلت سورة الأنبياء بمكة{6}. (١٠/٢٦٩) ٤٨٦٨٤- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد إبراهيم{7}. (ز) ٤٨٦٨٥- عن عبد الله بن الزبير، قال: نزلت سورة الأنبياء بمكة{8}. (١٠/٢٦٩) ٤٨٦٨٦- قال عكرمة مولى ابن عباس= (ز) ٤٨٦٨٧- والحسن البصري -من طريق يزيد النحوي-: مكية{9}. (ز) ٤٨٦٨٨- قال قتادة بن دعامة -من طُرُق-: مكية{10}. (ز) ٤٨٦٨٩- قال محمد ابن شهاب الزهري: مكية، ونزلت بعد إبراهيم{11}. (ز) ٤٨٦٩٠- قال علي بن أبي طلحة: مكية{12}. (ز) ٤٨٦٩١- قال مقاتل بن سليمان: مكية، وهي مائة واثنتا عشرة آية كوفية{13}. (ز) ٤٨٦٩٢- قال يحيى بن سلّام: مكية كلها{14}٤٣٢٦. (ز) ٤٣٢٦ ذكر ابنُ عطية (٦/١٥١) أنّ السورة مكية بإجماع. <q>﴿ٱقۡتَرَبَ لِلنَّاسِ حِسَابُهُمۡ وَهُمۡ فِی غَفۡلَةࣲ مُّعۡرِضُونَ ۝١﴾</q> - نزول الآية ٤٨٦٩٣- عن قتادة بن دعامة -من طريق سعيد- قال: لَمّا نزلت هذه الآيةُ قال أُناسٌ مِن أهل الضلالة: زعم صاحبُكم هذا أنّ الساعة قد اقتربت. فتَناهَوْا قليلًا{15}، ثم عادوا إلى أعمالهم، أعمال السوء. فلمّا نزل: <q>﴿أتى أمر الله فلا تستعجلوه﴾</q> [النحل:١] قال أُناس مِن أهل الضلالة: يزعم هذا الرجلُ أنه قد أتى أمر الله. فتناهوا قليلًا، ثم عادوا؛ فأنزل الله -تبارك وتعالى- في سورة هود [٨]: <q>﴿ولئن أخرنا عنهم العذاب إلى أمة معدودة ليقولن ما يحبسه﴾</q>؟ قال الله: <q>﴿ألا يوم يأتيهم ليس مصروفا عنهم﴾</q> يعني: العذاب{16}. (٨/٢٠) ٤٨٦٩٤- قال مقاتل بن سليمان: <q>﴿اقترب للناس حسابهم﴾</q> نزلت في كُفّار مكة{17}٤٣٢٧. (ز) ٤٣٢٧ ذكر ابنُ عطية (٦/١٥١) أن قوله تعالى: <q>﴿اقْتَرَبَ لِلنّاسِ حِسابُهُمْ﴾</q> عام في جميع الناس، وإن كان المشار إليه في ذلك الوقت: كُفار قريش، وأنّه يدل على ذلك ما بعده من الآيات. <q>﴿ٱقۡتَرَبَ لِلنَّاسِ حِسَابُهُمۡ﴾</q> - تفسير ٤٨٦٩٥- عن عبد الملك ابن جُرَيْج -من طريق أبي خالد الأحمر- في قوله: <q>﴿اقترب للناس حسابهم﴾</q>، قال: ما يُوعَدون{18}. (١٠/٢٧٠) ٤٨٦٩٦- قال يحيى بن سلّام، في قوله: <q>﴿اقترب للناس حسابهم﴾</q>: أي: إنّ ذلك قريب{14}. (ز) <q>﴿وَهُمۡ فِی غَفۡلَةࣲ مُّعۡرِضُونَ ۝١﴾</q> - تفسير ٤٨٦٩٧- عن أبي هريرة، عن النبي ﷺ، في قوله: <q>﴿اقترب للناس حسابهم وهم في غفلة معرضون﴾</q>، قال: «في الدنيا»{20}. (١٠/٢٧٠) ٤٨٦٩٨- عن أبي سعيد، عن النبي ﷺ، في قوله: <q>﴿فِي غَفْلَةٍ مُعْرِضُونَ﴾</q>، قال: «في الدنيا»{21}. (ز) ٤٨٦٩٩- قال مقاتل بن سليمان: <q>﴿وهم في غفلة معرضون﴾</q> لا يؤمنون به، يعني: بالحساب يوم القيامة{17}. (ز) ٤٨٧٠٠- قال يحيى بن سلّام، في قوله: <q>﴿وهم في غفلة معرضون﴾</q>: يعني: المشركين في غفلة من الآخرة، معرضون عن القرآن{14}. (ز) ",footnotes:1:العِتاق الأول: السُّور التي أُنزلتْ أولًا بمكة. النهاية (عتق).التّالِد: المالُ القديمُ الَّذي وُلِدَ عِنْدَك. النهاية (تلد).أخرجه البخاري (٤٧٣٩)، وابن الضريس (٢١٠).أخرجه أبو نعيم في الحلية ١/١٧٩، وابن عساكر ٢٥/٣٢٧ مرسلًا. وعزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه النحاس في ناسخه ص٥٥٥. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى البخاري، وابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص ٣٩٥-٣٩٦ من طريق سعيد، وأبي بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٢/٧٠.تفسير يحيى بن سلّام ١/٢٩٧.عقّب يحيى بن سلّام على ذلك بقوله ١/٢٩٨: ليس يعني: عن شِركهم.أخرجه يحيى بن سلّام ١/٢٩٨ مرسلًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩.أخرجه ابن أبي شيبة ١٤/٥١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٩٧.أخرجه ابن جرير ١٦/٢٢١-٢٢٢، من طريق أبي معاوية، عن الأعمش، عن أبي صالح، عن أبي هريرة به. وعزاه السيوطي إلى ابن مردويه بلفظ: من أمر الدنيا. وسنده صحيح.أخرجه النسائي في الكبرى ١٠/١٨٦ (١١٢٦٩)، من طريق أبي معاوية، عن الأعمش، عن أبي صالح، عن أبي سعيد به. وسنده صحيح.تفسير مقاتل بن سليمان ٣/٦٩.تفسير يحيى بن سلّام ١/٢٩٧.
21,2," <q>﴿مَا یَأۡتِیهِم مِّن ذِكۡرࣲ مِّن رَّبِّهِم مُّحۡدَثٍ إِلَّا ٱسۡتَمَعُوهُ وَهُمۡ یَلۡعَبُونَ ۝٢﴾</q> - تفسير ٤٨٧٠١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ما يأتيهم من ذكر من ربهم﴾</q>، يقول: ما ينزل عليهم شيء مِن القرآن{1}. (١٠/٢٧٠) ٤٨٧٠٢- قال قتادة بن دعامة: كلما نزل مِن القرآن شيءٌ أعرضوا عنه{2}. (ز) ٤٨٧٠٣- تفسير إسماعيل السُّدِّيّ: <q>﴿ما يأتيهم من ذكر من ربهم محدث﴾</q>، يعني: القرآن{2}. (ز) ٤٨٧٠٤- قال مقاتل: يُحْدِث الله الأمرَ بعد الأمر{4}. (ز) ٤٨٧٠٥- قال مقاتل بن سليمان: ثم نَعَتَهم، فقال سبحانه: <q>﴿ما يأتيهم من ذكر من ربهم﴾</q> يعني: مِن بيانٍ مِن ربِّهم، يعني: القرآن <q>﴿محدث﴾</q> يقول: الذي يُحْدِث الله ﷿ إلى النبي ﷺ من القرآن، لا مُحْدَث عند الله تعالى؛ <q>﴿إلا استمعوه وهم يلعبون﴾</q> يعني: لاهين عن القرآن{5}. (ز) ٤٨٧٠٦- قال يحيى بن سلّام: <q>﴿إلا استمعوه وهم يلعبون﴾</q> يسمعونه بآذانهم، ولا تقبله قلوبُهم{6}٤٣٢٨. (ز) ٤٣٢٨ ساق ابنُ عطية (٦/١٥١-١٥٢) هذا القول، ثم ذكر أنّ فرقة قالت: المراد بالذكر: أقوال النبي ﷺ في أمر الشريعة، ووعْظه، وتذكيره. ووجَّهه بقوله: «فهو مُحْدَث على الحقيقة، وجعله <q>﴿من ربهم﴾</q> مِن حيث إنّ النبي ﷺ لا ينطق عن الهوى، ولا يقول إلا ما هو من عند الله». وذكر أنّ فرقة أخرى قالت: الذِّكْر: الرسول نفسه. وأنّها احتجَّت بقوله تعالى: <q>﴿قَدْ أنْزَلَ اللَّهُ إلَيْكُمْ ذِكْرًا رَسُولًا يَتْلُوا عَلَيْكُمْ آياتِ اللَّهِ مُبَيِّناتٍ﴾</q> [الطلاق:١١]. ووجَّهه بقوله: «فهو مُحْدَثٌ على الحقيقة، ويكون قوله: <q>﴿اسْتَمَعُوهُ﴾</q> بمعنى: استمعوا إليه». ",footnotes:1:أخرجه ابن جرير ١٦/٢٢٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٢٩٨.علَّقه يحيى بن سلّام ١/٢٩٨.تفسير الثعلبي ٦/٢٦٩، وتفسير البغوي ٥/٣٠٩.تفسير مقاتل بن سليمان ٣/٦٩.تفسير يحيى بن سلّام ١/٢٩٨.
21,3," <q>﴿لَاهِیَةࣰ قُلُوبُهُمۡۗ﴾</q> - تفسير ٤٨٧٠٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لاهية قلوبهم﴾</q>، قال: غافِلة{1}. (١٠/٢٧٠) ٤٨٧٠٨- قال مقاتل بن سليمان: <q>﴿لاهية قلوبهم﴾</q>، يعني: غافِلة قلوبهم عنه{2}. (ز) <q>﴿وَأَسَرُّوا۟ ٱلنَّجۡوَى ٱلَّذِینَ ظَلَمُوا۟ هَلۡ هَـٰذَاۤ إِلَّا بَشَرࣱ مِّثۡلُكُمۡۖ﴾</q> - تفسير ٤٨٧٠٩- عن قتادة بن دعامة في قوله: <q>﴿وأسروا النجوى الذين ظلموا﴾</q>، يقول: أسروا الذين ظلموا النجوى{3}. (١٠/٢٧٠) ٤٨٧١٠- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وأسروا النجوى﴾</q> قال: أسروا نجواهم بينهم؛ <q>﴿هل هذا إلا بشر مثلكم﴾</q> يعنون: محمدًا ﷺ{4}. (١٠/٢٧٠) ٤٨٧١١- قال مقاتل بن سليمان: <q>﴿وأسروا النجوى الذين ظلموا﴾</q> فهو أبو جهل، والوليد بن المغيرة، وعقبة بن أبى مُعيط، قالوا سِرًّا فيما بينهم: <q>﴿هل هذا﴾</q> يعنون: محمدًا ﷺ: <q>﴿إلا بشر مثلكم﴾</q> لا يَفْضُلُكم بشيءٍ فتَتَّبِعونه{2}. (ز) ٤٨٧١٢- قال يحيى بن سلّام، في قوله: <q>﴿وأسروا النجوى الذين ظلموا﴾</q>: الذين أشركوا، أسروا ذلك فيما بينهم، يقول بعضهم لبعض: <q>﴿هل هذا﴾</q> يعنون: محمدًا ﷺ <q>﴿إلا بشر مثلكم﴾</q>{6}. (ز) <q>﴿أَفَتَأۡتُونَ ٱلسِّحۡرَ وَأَنتُمۡ تُبۡصِرُونَ ۝٣﴾</q> - تفسير ٤٨٧١٣- عن إسماعيل السدي، في قوله: <q>﴿أفتأتون السحر﴾</q>: يقولون: إنّ متابعة محمد ﷺ متابعةُ السِّحْرِ{4}. (١٠/٢٧٠) ٤٨٧١٤- قال مقاتل بن سليمان: <q>﴿أفتأتون السحر﴾</q> يعني: القرآن <q>﴿وأنتم تبصرون﴾</q> أنّه سِحْر{2}. (ز) ٤٨٧١٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أفتأتون السحر وأنتم تبصرون﴾</q>، قال: قاله أهلُ الكفر لنبيِّهم لَمّا جاء به مِن عند الله، زعموا أنّه ساحر، وأنّ ما جاء به سحر، قالوا: أتأتون السحر وأنتم تبصرون؟!{9}. (ز) ٤٨٧١٦- قال يحيى بن سلّام: في قوله: <q>﴿أفتأتون السحر﴾</q> يعنون: القرآن، أي: أفتُصَدِّقون به، <q>﴿وأنتم تبصرون﴾</q> أنّه سحر{6}. (ز) <q>﴿أَفَتَأۡتُونَ ٱلسِّحۡرَ وَأَنتُمۡ تُبۡصِرُونَ ۝٣﴾</q> - آثار متعلقة بالآية ٤٨٧١٧- عن جُندُب البجلي -من طريق أبي عثمان النهدي-: أنّه قَتَلَ ساحرًا كان عند الوليد بن عقبة، ثم قال: أتأتون السحر وأنتم تبصرون؟!{11}. (١٠/٢٧١) ",footnotes:1:أخرجه ابن جرير ١٦/٢٢٣. وعلَّقه يحيى بن سلّام ١/٢٩٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩.تفسير يحيى بن سلّام ١/٢٩٨-٢٩٩.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩.أخرجه ابن جرير ١٦/٢٢٤.تفسير يحيى بن سلّام ١/٢٩٨-٢٩٩.أخرجه أبو نعيم في المعرفة ١/٤٧١ (١٥٩٤)، والطبراني (٢/١٧٧)، والبيهقي في سننه ٨/١٣٦، وابن عساكر ١١/٣٠٩. وعزاه السيوطي إلى ابن منده.
21,4," <q>﴿قَالَ رَبِّی یَعۡلَمُ ٱلۡقَوۡلَ فِی ٱلسَّمَاۤءِ وَٱلۡأَرۡضِۖ وَهُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٤﴾</q> - تفسير ٤٨٧١٨- عن إسماعيل السدي، في قوله: ‹قُل رَّبِّي يَعْلَمُ القَوْلَ›، قال: الغيب{1}. (١٠/٢٧٠) ٤٨٧١٩- قال مقاتل بن سليمان: <q>﴿قال﴾</q> لهم محمد ﷺ: <q>﴿ربي يعلم القول﴾</q> يعني: السِّرَّ الذي فيما بينهم <q>﴿في السماء والأرض وهو السميع﴾</q> لسِرِّهم، <q>﴿العليم﴾</q> به{2}. (ز) ٤٨٧٢٠- قال يحيى بن سلّام: قال الله للنبي ﷺ: ‹قُل رَّبِّي يَعْلَمُ القَوْلَ› يعني: السِّرَّ، <q>﴿في السماء والأرض وهو السميع العليم﴾</q> لا أسمعَ منه، ولا أعلمَ منه{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم. قراءة <q>﴿قال﴾</q> هي قراءة حفص، وحمزة، والكسائي، وخلف العاشر، وقرأ الباقون ‹قُل›. انظر: النشر ٢/٣٢٣.تفسير مقاتل بن سليمان ٣/٦٩.تفسير يحيى بن سلّام ١/٢٩٩.
21,5," <q>﴿بَلۡ قَالُوۤا۟ أَضۡغَـٰثُ أَحۡلَـٰمِۭ﴾</q> - تفسير ٤٨٧٢١- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿أضغاث أحلام﴾</q>، قال: مُشْتَبِهَة{1}. (ز) ٤٨٧٢٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح، وابن جُرَيْج- في قوله: <q>﴿أضغاث أحلام﴾</q>، قال: أهاويلها{2}. (ز) ٤٨٧٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بل قالوا أضغاث أحلام﴾</q>: أي: فعل الأحلام، إنّما هي رؤيا رآها{3}. (١٠/٢٧١) ٤٨٧٢٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿بل قالوا أضغاث أحلام﴾</q>، قال: أباطيل أحلام{4}. (١٠/٢٧٠) ٤٨٧٢٥- قال مقاتل بن سليمان: <q>﴿بل قالوا أضغاث أحلام﴾</q>، يعني: جماعات أحلام، يعنون: القرآن، قالوا: هي أحلام كاذبة مُخْتَلِطة، يراها محمد ﷺ في المنام، فيخبرنا بها{5}. (ز) ٤٨٧٢٦- قال يحيى بن سلّام: ثم قال: <q>﴿بل قالوا أضغاث أحلام﴾</q>، يعنون: القرآن، أي: أخلاط أحلام. وقال بعضهم: كَذِبُ أحلام{6}. (ز) <q>﴿بَلِ ٱفۡتَرَىٰهُ بَلۡ هُوَ شَاعِرࣱ﴾</q> - تفسير ٤٨٧٢٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بل افتراه بل هو شاعر﴾</q>: كل هذا قد كان منه{7}. (١٠/٢٧١) ٤٨٧٢٨- قال مقاتل بن سليمان: ثم قال: <q>﴿بل افتراه﴾</q> يعنون: بل يخلق محمدٌ ﷺ القرآنَ من تلقاء نفسه، ثم قال: <q>﴿بل هو﴾</q> يعني: محمدًا ﷺ <q>﴿شاعر﴾</q>{5}. (ز) ٤٨٧٢٩- قال يحيى بن سلّام: <q>﴿بل افتراه﴾</q> محمدٌ، <q>﴿بل هو﴾</q> بل محمدٌ <q>﴿شاعر فليأتنا بآية كما أرسل الأولون﴾</q>{6}. (ز) <q>﴿فَلۡیَأۡتِنَا بِـَٔایَةࣲ كَمَاۤ أُرۡسِلَ ٱلۡأَوَّلُونَ ۝٥﴾</q> - تفسير ٤٨٧٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فليأتنا بآية كما أرسل الأولون﴾</q>: كما جاء موسى وعيسى بالبينات والرُّسُل{10}. (١٠/٢٧١) ٤٨٧٣١- قال مقاتل بن سليمان: فإن كان صادقًا <q>﴿فليأتنا بآية كما أرسل الأولون﴾</q> مِن الأنبياء ﵈ بالآيات إلى قومهم، كل هذا مِن قول هؤلاء النفر، كما أرسل موسى، وعيسى، وداود، وسليمان ﵈ بالآيات والعجائب{5}. (ز) <q>﴿فَلۡیَأۡتِنَا بِـَٔایَةࣲ كَمَاۤ أُرۡسِلَ ٱلۡأَوَّلُونَ ۝٥﴾</q> - آثار متعلقة بالآية ٤٨٧٣٢- عن عُلَيّ بن رَباح اللَّخْمي: حدثني مَن شهد عبادة بن الصامت، يقول: كُنّا في المسجد، ومعنا أبو بكر الصديق، يُقْرِئُ بعضُنا بعضًا القرآن، فجاء عبدُ الله بن أُبَيِّ بن سَلُول، ومعه نُمْرُقة{12} وزِرْبِيَّة{13}، فوضع واتَّكأ، وكان صبيحًا فصيحًا جَدِلًا، فقال: يا أبا بكر، قُل لمحمد يأتينا بآيةٍ كما جاء الأوَّلون؛ جاء موسى بالألواح، وجاء داود بالزبور، وجاء صالح بالناقة، وجاء عيسى بالإنجيل وبالمائدة. فبكى أبو بكر، فخرج رسول الله ﷺ، فقال أبو بكر: قوموا إلى رسول الله ﷺ نستغيث به من هذا المنافق. فقال رسول الله ﷺ: «إنّه لا يُقام لي، إنّما يُقام لله ﷿». فقلنا: يا رسول الله، إنّا لقينا مِن هذا المنافق. فقال: «إنّ جبريل قال لي: اخرُج، فأَخْبِر بنِعَم الله التي أنعم بها عليك، وفضيلته التي فُضِّلت بها. فبشَّرني أنِّي بُعِثْتُ إلى الأحمر والأسود، وأمرني أن أنذرَ الجن، وآتاني كتابه وأنا أُمِّيٌّ، وغفرَ ذنبي ما تقدم وما تأخر، وذكرَ اسمي في الأذان، وأيَّدني بالملائكة، وآتاني النصر، وجعلَ الرعبَ أمامي، وآتاني الكوثرَ، وجعلَ حوضي مِن أعظم الحِياض يوم القيامة، ووعدني المقامَ المحمودَ والناسُ مُهْطِعون مقنعو رؤوسهم، وجعلني في أول زمرة تخرج مِن الناس، وأدخل في شفاعتي سبعين ألفًا مِن أُمَّتي الجنةَ بغير حساب، وآتاني السلطانَ والمُلْكَ، وجعلني في أعلى غرفةٍ في الجنة في جنات النعيم، فليس فوقي أحدٌ إلا الملائكة الذين يحملون العرش، وأحلَّ لي الغنائم، ولم تحلَّ لأحد كان قبلنا»{14}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٢٦.أخرجه يحيى بن سلّام ١/٢٩٩ من طريق ابن مجاهد، وابن جرير ١٦/٢٢٦.أخرجه جرير ١٦/٢٢٦. وعلق يحيى بن سلّام ١/٢٩٩ أوله. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩-٧٠.تفسير يحيى بن سلّام ١/٢٩٩.أخرجه جرير ١٦/٢٢٦ بلفظ: كل هذا قد كان منهم. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩-٧٠.تفسير يحيى بن سلّام ١/٢٩٩.أخرجه جرير ١٦/٢٢٦. وعلَّقه يحيى بن سلّام ١/٢٩٩ بلفظ: كما أرسل موسى وعيسى فيما يزعم محمد. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٩-٧٠.نُمْرُقة: وِسادة. النهاية (نمرق).الزِرْبِيّة: الطِّنفِسَة. وقيل: البساطُ ذُو الخَمْلِ، وتُكسَرُ زايها وتُفتح وتُضم، وجمعُها: زَرابِيُّ. النهاية (زرب).أخرجه ابن أبي حاتم ٨/٢٤٤٤ (١٣٥٩٨)، من طريق ابن لهيعة، عن الحارث بن يزيد الحضرمي، عن عُلَيّ بن رَباح اللّخْمي، عمن شهد عبادة بن الصامت به. قال ابن كثير: «وهذا الحديث غريب جدًّا».
21,6," <q>﴿مَاۤ ءَامَنَتۡ قَبۡلَهُم مِّن قَرۡیَةٍ أَهۡلَكۡنَـٰهَاۤۖ أَفَهُمۡ یُؤۡمِنُونَ ۝٦﴾</q> - نزول الآية ٤٨٧٣٣- عن قتادة بن دعامة -من طريق سعيد- قال: قال أهلُ مكة للنبي ﷺ: إن كان ما تقول حقًّا، ويسرُّك أن نُؤْمِن؛ فحوِّل لنا الصفا ذهبًا. فأتاه جبريل، فقال: إن شئتَ كان الذي سألك قومُك، ولكنه إن كان ثم لم يؤمنوا لم يُناظَروا، وإن شئت اسْتَأنَيْتَ بقومك. قال: «بل أسْتَأْني بقومي». فأنزل الله: <q>﴿ما آمنت قبلهم من قرية أهلكناها أفهم يؤمنون﴾</q>{1}. (١٠/٢٧١) <q>﴿مَاۤ ءَامَنَتۡ قَبۡلَهُم مِّن قَرۡیَةٍ أَهۡلَكۡنَـٰهَاۤۖ أَفَهُمۡ یُؤۡمِنُونَ ۝٦﴾</q> - تفسير الآية ٤٨٧٣٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿أفهم يؤمنون﴾</q>، قال: يُصَدِّقون بذلك{2}. (١٠/٢٧٢) ٤٨٧٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ما آمنت قبلهم من قرية أهلكناها﴾</q>: أي: أنّ الرُّسُلَ كانوا إذا جاؤوا قومَهم بالآيات فلم يؤمنوا لم يُناظَروا{3}. (١٠/٢٧١) ٤٨٧٣٦- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿ما آمنت﴾</q> يقول: ما صدَّقت بالآيات <q>﴿قبلهم﴾</q> يعني: قبل كفار مكة <q>﴿من قرية أهلكناها﴾</q> بالعذاب في الدنيا، يعني: كفار الأمم الخالية؛ <q>﴿أفهم يؤمنون﴾</q> يعني: كُفّار مكة، أفهم يصدقون بالآيات؟! فقد كذَّبت بها الأمم الخالية من قبلهم، بأنهم لا يصدقون. ثم قالوا في الفرقان [٤١]: <q>﴿أهذا الذي بعث الله رسولا﴾</q> يأكل ويشرب، وتَرَكَ الملائكة فلم يرسلهم؟!{4}. (ز) ٤٨٧٣٧- قال يحيى بن سلّام: أي: إنّ القوم إذا كذبوا رسولهم، وسألوه الآية، فجاءتهم الآية، فلم يؤمنوا؛ أهلكهم الله. أفهم يؤمنون إن جاءتهم آية؟! أي: لا يؤمنون إن جاءتهم الآية{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٦٣٦-٦٣٧، ويحيى بن سلّام ١/١٤٤.أخرجه ابن جرير ١٦/٢٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٢٧، ويحيى بن سلّام ١/٢٩٩ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧١.تفسير يحيى بن سلّام ١/٢٩٩-٣٠٠.
21,7," <q>﴿وَمَاۤ أَرۡسَلۡنَا قَبۡلَكَ إِلَّا رِجَالࣰا نُّوحِیۤ إِلَیۡهِمۡۖ فَسۡـَٔلُوۤا۟ أَهۡلَ ٱلذِّكۡرِ إِن كُنتُمۡ لَا تَعۡلَمُونَ ۝٧﴾</q> - نزول الآية ٤٨٧٣٨- قال مقاتل بن سليمان: ثم قالوا [أي كفار مكة] في الفرقان [٤١]: <q>﴿أهذا الذي بعث الله رسولا﴾</q> يأكل ويشرب، وتَرَكَ الملائكة فلم يرسلهم؟! فأنزل الله ﷿ في قولهم: <q>﴿وما أرسلنا قبلك إلا رجالا نوحي إليهم فاسألوا﴾</q>{1}. (ز) <q>﴿وَمَاۤ أَرۡسَلۡنَا قَبۡلَكَ إِلَّا رِجَالࣰا نُّوحِیۤ إِلَیۡهِمۡۖ فَسۡـَٔلُوۤا۟ أَهۡلَ ٱلذِّكۡرِ إِن كُنتُمۡ لَا تَعۡلَمُونَ ۝٧﴾</q> - تفسير الآية ٤٨٧٣٩- عن جابر الجعفي، قال: لَمّا نزلت: <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q> قال عليُّ [بن أبي طالب]: نحن أهل الذِّكْر{2}. (ز) ٤٨٧٤٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، يقول: فاسألوا أهل التوراة والإنجيل -قال ابن جرير: أُراه قال: يخبروكم- أنّ الرُّسُلَ كانوا رجالًا يأكلون الطعام، ويمشون في الأسواق{3}. (ز) ٤٨٧٤١- عن عطاء [بن أبي رباح] أو غيره -من طريق ابن جريج- <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: هم أهل الكتاب{4}. (ز) ٤٨٧٤٢- عن محمد بن السائب الكلبي -من طريق مَعْمَر- في قوله تعالى: <q>﴿فسئلوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: يعني: أهل التوراة، يقول: سلوهم: هل جاءهم إلا رجالٌ يُوحى إليهم؟{5}. (ز) ٤٨٧٤٣- قال مقاتل بن سليمان: <q>﴿وما أرسلنا قبلك إلا رجالا نوحي إليهم فاسألوا﴾</q> يا معشر كُفّار مكة <q>﴿أهل الذكر﴾</q> يعني: مؤمني أهل التوراة <q>﴿إن كنتم لا تعلمون﴾</q> أنّ الرسل كانوا مِن البشر؛ فسيُخْبِرُونكم: أنّ الله ﷿ ما بعث رسولًا إلا مِن البشر{1}. (ز) ٤٨٧٤٤- قال سفيان الثوري، في قوله: <q>﴿فسئلوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: أهل التوراة، والإنجيل، ومَن كان يعلم{7}. (ز) ٤٨٧٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: أهل القرآن، والذِّكْرُ: القرآن. وقرأ: <q>﴿إنا نحن نزلنا الذكر وإنا له لحافظون﴾</q> [الحجر:٩]{2}. (ز) ٤٨٧٤٦- قال يحيى بن سلّام: أهل التوراة عبد الله بن سلام وأصحابه المؤمنون، يعني: مَن آمن منهم، وقوله: <q>﴿إن كنتم لا تعلمون﴾</q> وهم لا يعلمون. وهي كلمة عربية. يقول: إن كنت لا تصدق فاسأل، وهو يعلم أنه قد كَذَّبَ{9}٤٣٢٩. (ز) ٤٣٢٩ أفادت الآثار الاختلاف في أهل الذكر؛ فقال قوم: هم أهل الكتاب. وقال آخرون: هم أهل القرآن. وعلَّق ابنُ عطية (٦/١٥٤) بعد ذكره للقولين بقوله: «وهذا موضعٌ ينبغي أن يُتَأَمَّل، وذلك أن الذِّكْرَ هو كل ما يأتي من تذكير الله تعالى عبادَه؛ فأهل القرآن أهل ذكر، وهذا ما أراد علي بن أبي طالب». وانتقد القول الثاني مستندًا إلى الدلالات العقلية، فقال: «وأما المحال على سؤالهم في هذه الآية فلا يَصِحُّ أن يكونوا أهل القرآن في ذلك الوقت؛ لأنهم كانوا خصومهم، وإنما أحيلوا على سؤال أحبار أهل الكتاب مِن حيث كانوا موافقين لهم على ترك الإيمان بمحمد ﷺ، فتجيء شهادتهم بأنّ الرسل قديمًا من البشر، لا مطعن فيها؛ لازمة لكفار قريش». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧١.أخرجه ابن جرير ١٦/٢٢٩.أخرجه ابن جرير ١٦/٢٢٨. وعلق يحيى بن سلّام ١/٣٠٠ أوله.أخرجه إسحاق البستي في تفسيره ص٢٩٣.أخرجه عبد الرزاق ٢/٢٢.تفسير مقاتل بن سليمان ٣/٧١.تفسير الثوري ص١٩٩.أخرجه ابن جرير ١٦/٢٢٩.تفسير يحيى بن سلّام ١/٣٠٠.
21,8," <q>﴿وَمَا جَعَلۡنَـٰهُمۡ جَسَدࣰا لَّا یَأۡكُلُونَ ٱلطَّعَامَ﴾</q> - تفسير ٤٨٧٤٧- عن عبد الله بن عباس، في قوله: <q>﴿وما جعلناهم جسدا لا يأكلون الطعام﴾</q>، يقول: لم نجعلهم جسدًا ليس يأكلون الطعام، إنما جعلناهم جسدًا يأكلون الطعام{1}. (١٠/٢٧٢) ٤٨٧٤٨- عن مجاهد بن جبر -من طريق الثوري- في قوله: <q>﴿وما جعلناهم جسدا﴾</q>، قال: ليس فيهم الرُّوح{2}. (ز) ٤٨٧٤٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وما جعلناهم جسدا لا يأكلون الطعام﴾</q>، قال: لم أجعلهم جسدًا ليس فيها أرواح لا يأكلون الطعام، ولكنا جعلناهم جسدًا فيها أرواح يأكلون الطعام{3}. (ز) ٤٨٧٥٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وما جعلناهم جسدا لا يأكلون الطعام﴾</q>، يقول: ما جعلناهم جسدًا إلا ليأكلوا الطعام{3}. (ز) ٤٨٧٥١- قال مقاتل بن سليمان: نزل في قولهم: <q>﴿أهذا الذي بعث الله رسولا﴾</q> يأكل ويشرب، ويترك الملائكة فلا يرسلهم، فقال سبحانه: <q>﴿وما جعلناهم جسدا﴾</q> يعني: الأنبياء ﵈، والجسد الذي ليس فيه روح، كقوله سبحانه: <q>﴿عِجْلًا جَسَدًا﴾</q> [الأعراف:١٤٨]، <q>﴿لا يأكلون الطعام﴾</q> ولا يشربون، ولكن جعلناهم جسدًا فيها أرواح، يأكلون الطعام، ويذوقون الموت، وذلك قوله سبحانه: <q>﴿وما كانوا خالدين﴾</q>{5}٤٣٣٠. (ز) ٤٣٣٠ ذَكَر ابنُ عطية (٦/١٥٥) أنّ معنى قوله: <q>﴿وما جعلناهم جسدا﴾</q> على قولين: أحدهما: أنّ الجسد يقع على ما لا يَتَغَذّى. والآخر: أن الجسد يعم المتغذي وغير المتغذي. ثم علَّق بقوله: «فـ<q>﴿جَعَلْناهُمْ جَسَدًا﴾</q> على التأويل الأول منفي، وعلى الثاني مُوجب، والنفي واقع على صفته». ٤٨٧٥٢- قال يحيى بن سلّام: قوله: <q>﴿وما جعلناهم جسدا﴾</q> يعني: النبيين <q>﴿لا يأكلون الطعام﴾</q> أي: ولكنا جعلناهم جسدًا يأكلون الطعام. وقد قال المشركون: قال: <q>﴿مال هذا الرسول يأكل الطعام ويمشي في الأسواق﴾</q> [الفرقان:٧]{6}. (ز) <q>﴿وَمَا كَانُوا۟ خَـٰلِدِینَ ۝٨﴾</q> - تفسير ٤٨٧٥٣- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿وما كانوا خالدين﴾</q>، قال: لا بُدَّ لهم مِن الموت؛ أن يموتوا{7}. (١٠/٢٧٢) ٤٨٧٥٤- قال مقاتل بن سليمان: <q>﴿وما كانوا خالدين﴾</q> في الدنيا{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير الثوري ص١٩٩، وأخرجه يحيى بن سلّام ١/٣٠٠ من طريق الأعمش.أخرجه ابن جرير ١٦/٢٢٩.أخرجه ابن جرير ١٦/٢٢٩.تفسير مقاتل بن سليمان ٣/٧١.تفسير يحيى بن سلّام ١/٣٠٠.أخرجه يحيى بن سلّام ١/٣٠٠، وابن جرير ١٦/٢٣٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧١.
21,9," <q>﴿ثُمَّ صَدَقۡنَـٰهُمُ ٱلۡوَعۡدَ فَأَنجَیۡنَـٰهُمۡ وَمَن نَّشَاۤءُ﴾</q> - تفسير ٤٨٧٥٥- قال مقاتل بن سليمان: <q>﴿ثم صدقناهم الوعد﴾</q> يعني: الرسل. الوعد يعني: العذاب في الدنيا إلى قومهم، <q>﴿فأنجيناهم﴾</q> يعني: الرسل مِن العذاب، <q>﴿ومن نشاء﴾</q> مِن المؤمنين{1}. (ز) ٤٨٧٥٦- قال يحيى بن سلّام، في قوله: <q>﴿ثم صدقناهم الوعد﴾</q>: كانت الرسل تُحَذِّرُ قومَها عذابَ الله في الدنيا وعذابَه في الآخرة إن لم يؤمنوا؛ فلمّا لم يُؤمِنوا صدق الله رسله الوعد، فأنزل العذاب على قومهم. قال: <q>﴿فأنجيناهم ومن نشاء﴾</q>، يعني: النبي والمؤمنين{2}. (ز) <q>﴿وَأَهۡلَكۡنَا ٱلۡمُسۡرِفِینَ ۝٩﴾</q> - تفسير ٤٨٧٥٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأهلكنا المسرفين﴾</q>، قال: هم المشركون{3}. (١٠/٢٧٢) ٤٨٧٥٨- قال مقاتل بن سليمان: <q>﴿وأهلكنا المسرفين﴾</q>، يقول: وعذَّبنا المشركين في الدنيا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢.تفسير يحيى بن سلّام ١/٣٠٠.أخرجه ابن جرير ١٦/٢٣١. وعلَّقه يحيى بن سلّام ١/٣٠١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٢.
21,10," <q>﴿لَقَدۡ أَنزَلۡنَاۤ إِلَیۡكُمۡ كِتَـٰبࣰا فِیهِ ذِكۡرُكُمۡۚ أَفَلَا تَعۡقِلُونَ ۝١٠﴾</q> - تفسير ٤٨٧٥٩- عن عبد الله بن عباس -من طريق سليمان بن قَتَّة- في قوله: <q>﴿لقد أنزلنا إليكم كتابا فيه ذكركم﴾</q>، قال: فيه شَرَفُكم{1}. (١٠/٢٧٢) ٤٨٧٦٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿كتابا فيه ذكركم﴾</q>، قال: فيه حديثكم{2}. (١٠/٢٧٢) ٤٨٧٦١- عن الحسن البصري -من طريق يونس- في قوله: <q>﴿كتابا فيه ذكركم﴾</q>، قال: فيه دينُكم، أمسكَ عليكم دينَكم بكتابكم{3}. (١٠/٢٧٣) ٤٨٧٦٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿كتابا فيه ذكركم﴾</q>، يقول: فيه ذِكْرُ ما تعنون به، وأمر آخرتكم ودنياكم{4}. (١٠/٢٧٣) ٤٨٧٦٣- قال مقاتل بن سليمان: <q>﴿لقد أنزلنا إليكم﴾</q> يا أهل مكة <q>﴿كتابا فيه ذكركم﴾</q> يعني: شرفكم، <q>﴿أفلا تعقلون﴾</q>. مثل قوله تعالى: <q>﴿وإنه لذكر لك ولقومك﴾</q> [الزخرف:٤٤]، يعني: شَرَفًا لك ولقومك{5}. (ز) ٤٨٧٦٤- قال سفيان الثوري: في قوله: <q>﴿لقد أنزلنا اليكم كتابًا فيه ذكركم﴾</q> قال: شرفكم، <q>﴿وإنه لذكر لك ولقومك﴾</q> [الزخرف:٤٤] قال: شرفٌ لك ولقومك{6}. (ز) ٤٨٧٦٥- عن سفيان [بن عيينة] -من طريق الحسين-: نزل القرآن بمكارم الأخلاق، ألم تسمعه يقول: <q>﴿لقد أنزلنا إليكم كتابا فيه ذكركم أفلا تعقلون﴾</q>{7}٤٣٣١. (ز) ٤٣٣١ ذكر ابن جرير (١٦/٢٣٢) أن قول سفيان كقول مَن قالوا: الذكر: الشرف. ٤٨٧٦٦- قال يحيى بن سلّام، في قوله: <q>﴿لقد أنزلنا إليكم كتابا﴾</q>: القرآن، <q>﴿فيه ذكركم﴾</q> فيه شرفكم، يعني: قريشًا، أي: لِمَن آمن به، <q>﴿أفلا تعقلون﴾</q> يقوله للمشركين{8}٤٣٣٢. (ز) ٤٣٣٢ اختُلِف في معنى قوله: <q>﴿فيه ذكركم﴾</q>؛ فقال قوم: معناه: فيه حديثكم. وقال آخرون: شرفكم. ورجَّح ابنُ جرير (١٦/٢٣٢) مستندًا إلى ظاهر لفظ الآية القولَ الثاني الذي قاله ابن عباس، ومقاتل، والثوري، ويحيى بن سلّام، فقال: «وهذا القول الثاني أشبه بمعنى الكلمة ... وذلك أنه شَرَفٌ لمن اتبعه وعمل بما فيه». وعلَّق ابنُ عطية (٦/١٥٥) على القولين بقوله: «وقوله تعالى: <q>﴿فِيهِ ذِكْرُكُمْ﴾</q> يحتمل أن يريد: فيه الذكر الذي أنزله الله تعالى إليكم بأمر دينكم وآخرتكم ونجاتكم من عذابه، فأضاف الذكر إليهم حيث هو في أمرهم، ويحتمل أن يريد: فيه شرفكم وذكركم آخر الدهر، كما تذكر عظام الأمور، وفي هذا تحريض». ",footnotes:1:أخرجه البيهقي في شعب الإيمان (١٦١٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٦/٢٣٢، وأخرجه من طريق ابن جريج وزاد في آخره: قال في «قد أفلح»: <q>﴿بل أتيناهم بذكرهم فهم عن ذكرهم معرضون﴾</q> [المؤمنون:٧١]. وعزاه السيوطي باللفظ الذي في المتن إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٢.تفسير الثوري ص١٩٩.أخرجه ابن جرير ١٦/٢٣٢٩، وأخرج نحوه أبو نعيم في حلية الأولياء ٧/٢٩١ عن أبي توبة الربيع، قال: سُئِل سفيان بن عيينة عن قوله: <q>﴿لقد أنزلنا إليكم كتابًا فيه ذكركم أفلا تعقلون﴾</q>. قال: أُنزِل عليه القرآن بمكارم الأخلاق، فهم الذين كانوا يشرفون بها، ويَفْضُل بعضهم بعضًا بها، مِن حُسن الجوار، ووفاء بالعهد، وصدق الحديث، وأداء الأمانة. فقال: إنما جاءكم محمد ﷺ بمكارم أخلاقكم التي كنتم بها تشرفون وتعظمون، انظروا هل جاء بشيء مما كنتم تَعِيبُون من الأخلاق القبيحة التي كنتم تعيبونها؛ فلم يقبح القبيح، ولم يحسن الحسن؟.تفسير يحيى بن سلّام ١/٣٠١.
