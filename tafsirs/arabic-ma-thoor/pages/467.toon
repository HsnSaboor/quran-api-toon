quran[8]{c,v,t}:
  39,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَرَى ٱلۡمَلَـٰۤىِٕكَةَ حَاۤفِّینَ مِنۡ حَوۡلِ ٱلۡعَرۡشِ یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٥١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، <span class="qpc-hafs">﴿وتَرى المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ﴾</span>، قال: مُدِيرِين به{1}. (١٢/٧٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وتَرى المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ﴾</span>، قال: مُحدِقين به{2}. (١٢/٧٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وتَرى المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ﴾</span>، قال: مُحدِقين حول العرش. قال: العرش: السرير{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَرى﴾</span> يا محمد <span class="qpc-hafs">﴿المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ﴾</span> يعني: يذكرونه بأمر ربهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَرَى ٱلۡمَلَـٰۤىِٕكَةَ حَاۤفِّینَ مِنۡ حَوۡلِ ٱلۡعَرۡشِ یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٥٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق أبي قبيل- قال: جبل الخليل والطور والجُوديّ، يكون كل واحد منهم يوم القيامة لؤلؤة بيضاء تضيء ما بين السماء والأرض، يرجعن إلى بيت المقدس، حتى يُجعلن في زواياه، ويضع عليها كرسيه حتى يقضي بين أهل الجنة والنار، و<span class="qpc-hafs">﴿المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ وقُضِيَ بَيْنَهُمْ بِالحَقِّ﴾</span>{5}. (١٢/٧٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُضِیَ بَیۡنَهُم بِٱلۡحَقِّۚ وَقِیلَ ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وقُضِي َبَيْنَهُمْ بِالحَق ِّوَقِيل الحَمْد ُلِلَّه ِرَب ِّالعالَمِينَ﴾</span>، قال: افتتح أول الخلق بالحمد، وختم بالحمد؛ فتح بقوله: <span class="qpc-hafs">﴿الحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ﴾</span> [الأنعام:١]، وختم بقوله: <span class="qpc-hafs">﴿وقِيلَ الحَمْد ُلِلَّه ِرَب ِّالعالَمِينَ﴾</span>{6}. (١٢/٧٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقُضِيَ بَيْنَهُمْ بِالحَقِّ وقِيلَ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span> وذلك أنّ الله -تبارك وتعالى- افتتح الخلْق بالحمد، وختم بالحمد، فقال: <span class="qpc-hafs">﴿الحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ...﴾</span> [الأنعام: ١]، وختم بالحمد حين قال: <span class="qpc-hafs">﴿وقُضِيَ بَيْنَهُمْ بِالحَقِّ﴾</span> يعني: بالعدل، <span class="qpc-hafs">﴿وقِيلَ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُضِیَ بَیۡنَهُم بِٱلۡحَقِّۚ وَقِیلَ ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٧٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٥٨<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span>، قال: مَن أراد أن يعرف قضاء الله في خلْقه فليقرأ آخر سورة الغُرَف{1}. (١٢/٧٣٦)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٢٧١. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٢٧١.تفسير مقاتل بن سليمان ٣/٦٨٩.أخرجه ابن عساكر ٢/٣٤٨-٣٤٩.أخرجه عبد الرزاق ٢/١٧٧ من طريق معمر، وابن جرير ٢٠/٢٧٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٨٩.عزاه السيوطي إلى عبد بن حميد.
  40,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٥٩<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أُنزلت الحواميم السّبع بمكة{1}. (١٣/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٠<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مكية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦١<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيْف، عن مجاهد-: مكية، وذكرها باسم: حم المؤمن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أُنزلت «حم المؤمن» بمكة{4}. (١٣/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكية، وذكرها باسم: حم المؤمن، وأنها نزلت بعد سورة الزمر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٤<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: نزلت المؤمن بمكة{4}. (١٣/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٥<span class="dash">-</span></span> عن سَمُرَة بن جُندَب، قال: نزلت الحواميم جميعًا بمكة{7}. (١٣/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٦<span class="dash">-</span></span> عن عامر الشعبي، قال: أخبرني مسروق: أنّ «آل حم» إنما أُنزلت بمكة{8}. (١٣/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٧<span class="dash">-</span></span> عن عكرمة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية، وذكراها باسم: حم المؤمن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٦٩<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكية{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٠<span class="dash">-</span></span> عن محمد ابن شهاب الزُّهري: مكية، وذكرها باسم: حم المؤمن، وأنها نزلت بعد سورة الزمر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧١<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٢<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة المؤمن مكية، عددها خمس وثمانون آية كوفي{13}<span class=comment-ref>٥٦٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٦٥٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤١٨) أن هذه السورة مكية <span class="mustanad">بإجماع</span>، ثم نقل قولًا بمدنية بعض آياتها، و<span class="comment-type-2">انتقده</span>، و<span class="comment-type-3">رجَّح</span> الأول، فقال: «وذلك ضعيف، والأول أصح». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٣<span class="dash">-</span></span> قال الثمالي: إنما سميت بذلك مِن أجل حزقيل مؤمن آل فرعون، مكية{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٤<span class="dash">-</span></span> عن الخليل بن مُرّة، أنّ رسول الله ﷺ قال: «<b>الحواميم سبع، وأبواب جهنم سبع، تجيء كلُّ <span class="qpc-hafs">﴿حم﴾</span> منها تقف على باب من هذه الأبواب، تقول: اللهم، لا يدخل هذا الباب مَن كان يؤمن بي ويقرؤني</b>»{15}. (١٣/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن</span> <span class="name-1">مسعود</span> -من طريق مجاهد- قال: الحواميم ديباج القرآن{16}<span class=comment-ref>٥٦٦٠</span>. (١٣/٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٦٦٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٤١٨) على هذا الحديث بقوله: «وقفه الزَّجّاج على ابن مسعود». ثم <span class="comment-type-4">ذكر</span> أن معنى الديباج: «أنها خلت من الأحكام، وقُصرت على المواعظ والزجر وطرق الآخرة محضًا، وأيضًا فهي قصار، لا يلحق لقارئ فيها سآمة».</div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٦<span class="dash">-</span></span> عن زِرّ بن حُبَيْش، قال: قرأتُ القرآن من أوله إلى آخره على <span class="name-1">علي بن أبي طالب</span>، فلما بلغتُ الحواميم قال لي: قد بلغتَ عرائس القرآن{17}. (١٣/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٧<span class="dash">-</span></span> عن سعد بن إبراهيم -من طريق مسعر- قال: كُنّ الحواميم يُسمَّيْنَ: العرائس{18}. (١٣/٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حمۤ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٧٨<span class="dash">-</span></span> عن عكرمة، قال: قال رسول الله ﷺ: «<span class="qpc-hafs">﴿<b>حم﴾</span> اسم من أسماء الله تعالى، وهي مفاتيح خزائن ربك تعالى</b>»{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٧٩<span class="dash">-</span></span> عن أنس بن مالك أنه قال: سأل أعرابيٌّ رسولَ الله ﷺ: ما <span class="qpc-hafs">﴿حم﴾</span>؟ فإنّا لا نعرفها في لغتنا. فقال: «<b>بدء أسماء وفواتح سور</b>»{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span> حروف الرحمن مُقطّعة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: <span class="qpc-hafs">﴿حم﴾</span> قسَم أقسمه الله، وهو اسم من أسماء الله{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدّيّ-: <span class="qpc-hafs">﴿حم﴾</span> اسم الله الأعظم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٣<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، قال: <span class="qpc-hafs">﴿حم﴾</span> اسم من أسماء الله{4}<span class=comment-ref>٥٦٦١</span>. (١٣/٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٦٦١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٢/١٦٦-١٦٧) أن من قالوا بهذا القول <span class="mustanad">احتجوا لقولهم بقول الشاعر</span>:</p><p>يُذَكِّرُنِي حامِيمَ والرُّمْح شاجِر فَهَلا تَلا حم قَبْل التَّقَدُّم</p><p>ثم ساق حديث المهلّب بن أبي صُفرة -الوارد في الآثار المتعلقة بالآية-، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا إسناد صحيح».</p><p><span class="comment-type-4">وذكر</span> <u>ابن جرير</u> (٢٠/٢٧٥-٢٧٦) هذا البيت تحت قول مَن قال: إن <span class="qpc-hafs">﴿حم﴾</span> اسم. ثم قال: «وحُدِّثت عن معمر بن المثنى، أنه قال: قال يونس -يعني: الجرمي-: ومَن قال هذا القول فهو منكر عليه؛ لأنّ السورة <span class="qpc-hafs">﴿حم﴾</span> ساكنة الحروف، فخَرجت مخرج التهجي، وهذه أسماء سور خرجت متحركات، وإذا سُميت سورة بشيء من هذه الأحرف المجزومة دخله الإعراب. والقول في ذلك عندي <span class="mustanad">نظير القول في أخواتها</span>، وقد بينا ذلك، في قوله: <span class="qpc-hafs">﴿الم﴾</span> [البقرة:١]، ففي ذلك كفاية عن إعادته في هذا الموضع، إذ كان القول في <span class="qpc-hafs">﴿حم﴾</span> وجميع ما جاء في القرآن على هذا الوجه، أعني: حروف التهجي قولًا واحدًا».</div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٤<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٥<span class="dash">-</span></span> و<span class="name-2">عطاء الخُراسانِيّ</span>: <span class="qpc-hafs">﴿حم﴾</span> الحاء افتتاح أسمائه: حكيم، حميد، حيّ، حليم، حنان، والميم افتتاح أسمائه: مالك، مجيد، منّان{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- قال: <span class="qpc-hafs">﴿ألم﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ألمص﴾</span>، و<span class="qpc-hafs">﴿ص﴾</span> فواتح افتتح الله بها القرآن{26}. (١/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيْف- قال: فواتح السور كلها <span class="qpc-hafs">﴿ألم﴾</span>، و<span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ق﴾</span>، وغير ذلك هجاء موضوع{27}. (١/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٨<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿حم﴾</span> معناه: قضى ما هو كائن{28}<span class=comment-ref>٥٦٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٦٦٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤١٩) أن الضَّحّاك والكسائي ذكرا أن <span class="qpc-hafs">﴿حم﴾</span> هجاء: حُمَّ -بضم الحاء، وشد الميم المفتوحة-، ثم <span class="comment-type-4">علَّق</span> بقوله: «كأنه يقول: حمّ الأمر، ووقع تنزيل الكتاب من الله».</div></p><p><div></p><p><p><span class="item-no">٦٧٧٨٩<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: <span class="qpc-hafs">﴿حم﴾</span> شعار السورة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿حم﴾</span>، ما أدري ما تفسير <span class="qpc-hafs">﴿حم﴾</span> و<span class="qpc-hafs">﴿طسم﴾</span> وأشباه ذلك! غير أنّ قومًا مِن السلف كانوا يقولون: أسماء السور وفواتحها{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿حم﴾</span>، قال: اسم من أسماء القرآن{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرظيّ</span>: <span class="qpc-hafs">﴿حم﴾</span> أقسم الله تعالى بِحِلْمه ومُلكه أن لا يُعذِّب أحدًا عاد إليه، يقول: لا إله إلا الله؛ مُخلِصًا من قلبه{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿حم﴾</span> مِن حروف أسماء الله{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حمۤ ۝١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٩٤<span class="dash">-</span></span> عن البراء بن عازب، أنّ رسول الله ﷺ قال: «<b>إنكم تَلْقَون عدوَّكم غدًا، فليكن شعاركم: <span class="qpc-hafs">﴿حم﴾</span> لا يُنصرون</b>»{34}. (١٣/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩٥<span class="dash">-</span></span> عن أنس، قال: انهزم المسلمون بحُنَين، فأخذ رسول الله ﷺ حفنةً مِن تراب، فرمى بها في وجوههم، وقال: «<span class="qpc-hafs">﴿<b>حم﴾</span> لا يُنصرون</b>». فانهزم القوم، وما رميناهم بسهم، ولا طعنّا برُمح{35}. (١٣/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩٦<span class="dash">-</span></span> عن شيبة بن عثمان، قال: لَمّا كان يوم حُنَين تناول رسولُ الله ﷺ مِن الحصْباء، فنفخ في وجوههم، وقال: «<b>شاهت الوجوه، <span class="qpc-hafs">﴿حم﴾</span> لا يُنصرون</b>»{36}. (١٣/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٧٩٧<span class="dash">-</span></span> عن المُهَلَّب بن أبي صُفْرة، قال: حدثني مَن سمِع النبيَّ ﷺ يقول ليلة الخندق: «<b>إن بُيِّتم الليلةَ فقولوا: <span class="qpc-hafs">﴿حم﴾</span> لا يُنصرون</b>»{37}. (١٣/٩)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الضريس، والنحاس، والبيهقي في الدلائل.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١.</p><p>قال السيوطي في الإتقان في علوم القرآن ١/٥٠: «... إسناده جيد، رجاله كلهم ثقات من علماء العربية المشهورين».أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه الديلمي (٦٨١٣). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢١/١٢٥-١٢٦.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٧٠٣.تفسير الثعلبي ٨/٢٦١. وفي طبعة دار التفسير ٢٣/١٤٩: خربيل.أخرجه البيهقي في شعب الإيمان (٢٤٧٩).</p><p>ضعفه الألباني في ضعيف الجامع (٢٨٠٢).أخرجه أبو عبيد ص١٣٧، وابن الضريس ص٢-٣، وإسحاق البستي ص٢٧٥، والحاكم ٢/٤٣٧، والبيهقي في شعب الإيمان (٢٤٧١). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن النجار في تاريخه.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٥٥٧ (٣٠٩١٤)، والدارمي ٢/٤٥٨، وابن نصر في مختصر قيام الليل ص٦٩.أخرجه الثعلبي ٨/٢٦٣ مرسلًا.أورده الثعلبي ٨/٢٦٣.أخرجه ابن جرير ٢٠/٢٧٤.أخرجه ابن جرير ٢٠/٢٧٤.أخرجه البغوي ٧/١٣٥.عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٧/١٣٥. وفي تفسير الثعلبي ٨/٢٦٣ عن عطاء دون سعيد، وفيه: «ملك» بدل «مالك».أخرجه ابن جرير ١/٢٠٥، وابن أبي حاتم ٥/١٤٣٧، كما أخرجه ابن جرير من طريق سفيان، عن ابن أبي نجيح. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ ابن حيان. وتقدم في سورة البقرة.أخرجه ابن جرير ١/٢٠٩. وعزاه السيوطي إلى ابن المنذر. وعزاه ابن حجر ٨/٥٥٤ إلى ابن أبي حاتم بلفظ: هجاء مقطوع. وتقدم في سورة البقرة.تفسير الثعلبي ٨/٢٦٣، وتفسير البغوي ٧/١٣٥، وعقّبا عليه بأنه كأنه أشار إلى أن معناه: حُمّ -بضم الحاء وتشديد الميم-.تفسير الثعلبي ٨/٢٦٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٢٥-.أخرجه عبد الرزاق ٢/١٧٨ من طريق معمر، وابن جرير ٢٠/٢٧٥.تفسير الثعلبي ٨/٢٦٣.أخرجه ابن جرير ٢٠/٢٧٤.أخرجه أحمد ٣٠/٥١٩ (١٨٥٤٩)، والحاكم ٢/١١٧-١١٨ (٢٥١٤، ٢٥١٥).</p><p>قال البوصيري في إتحاف الخيرة ٥/١٣١ (٤٣٨٢) بعد ذكره لرواية أبي يعلى والنسائي للحديث: «هذا إسناد حسن». وأورده الألباني في الصحيحة ٧/٢٥٩ (٣٠٩٧).أخرجه الطبراني في الأوسط ٤/٢٠٢ (٣٩٧٨)، والأصبهاني في دلائل النبوة ص٢٢٨ (٣٣٢).</p><p>قال الطبراني: «لم يرو هذا الحديث عن ثابت إلا عمارة بن زاذان، تفرد به مؤمل». وقال الهيثمي في المجمع ٦/١٨٣ (١٠٢٨٣): «رواه الطبراني في الأوسط، فيه أحمد بن محمد بن القاسم، وهو ضعيف».أخرجه الطبراني في الكبير ٧/٢٩٨ (٧١٩٢) مطولًا.</p><p>قال الهيثمي في المجمع ٦/١٨٤ (١٠٢٨٥): «فيه أبوبكر الهذلي، وهو ضعيف».أخرجه أحمد ٢٧/١٦٢ (١٦٦١٥)، ٣٨/٢٥٣ (٢٣٢٠٤)، وأبو داود ٤/٢٣٨ (٢٥٩٧)، والترمذي ٣/٤٨٣ (١٧٧٧)، والحاكم ٢/١١٧ (٢٥١٢، ٢٥١٣).</p><p>قال الحاكم في الموضع الأول: «وهكذا رواه زهير بن معاوية، عن أبي إسحاق». وقال الذهبي في التلخيص: «تابعه زهير بن معاوية، على شرط البخاري ومسلم». وقال الحاكم في الموضع الآخر: «هذا حديث صحيح الإسناد، على شرط الشيخين، إلا أن فيه إرسالًا، فإذا الرجل الذي لم يُسمّه المّهلَّب بن أبي صُفْرة البراء بن عازب». وقال الألباني في صحيح أبي داود ٧/٣٤٧ (٢٣٣٧): «إسناده صحيح».
  40,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَنزِیلُ ٱلۡكِتَـٰبِ مِنَ ٱللَّهِ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَنْزِيلُ الكِتابِ مِنَ اللَّهِ﴾</span> يقول: قُضي تنزيل الكتاب <span class="qpc-hafs">﴿العَزِيزِ﴾</span> في مُلكه، <span class="qpc-hafs">﴿العَلِيمِ﴾</span> بخلقه{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٠٥.
  40,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿غَافِرِ ٱلذَّنۢبِ وَقَابِلِ ٱلتَّوۡبِ شَدِیدِ ٱلۡعِقَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٧٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق أسلم- في قوله: <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ﴾</span> الآية، قال: <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ﴾</span> لِمَن يقول: لا إله إلا الله، <span class="qpc-hafs">﴿وقابِلِ التَّوْبِ﴾</span> ممن يقول: لا إله إلا الله، <span class="qpc-hafs">﴿شَدِيدِ العِقابِ﴾</span> لمن لا يقول: لا إله إلا الله{1}. (١٣/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، مثله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق شَبِيب بن بشر- في قوله: <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ﴾</span>، قال: <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ﴾</span> لِمَن لم يتب، <span class="qpc-hafs">﴿وقابِلِ التَّوْبِ﴾</span> مِمَّن تاب{3}. (١٣/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق حماد بن سلمة- في قوله ﷿: <span class="qpc-hafs">﴿غافر الذنب﴾</span> قال: لِمَن قال: لا إله إلا الله، <span class="qpc-hafs">﴿وقابل التوب﴾</span> مِِمَّن قال: لا إله إلا الله، <span class="qpc-hafs">﴿شديد العقاب﴾</span> لمن لم يقل: لا إله إلا الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ﴾</span> يعني: من الشرك، <span class="qpc-hafs">﴿شَدِيدِ العِقابِ﴾</span> لِمَن لم يوحّده{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذِی ٱلطَّوۡلِۖ لَاۤ إِلَـٰهَ إِلَّا هُوَۖ إِلَیۡهِ ٱلۡمَصِیرُ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span>، قال: ذي السَّعة والغِنى{6}. (١٣/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ذِي الطَّوْل﴾</span> ذي الغنى عَمَّن لا يقول: لا إله إلا الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق أسلم-: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span> ذي الغِنى، <span class="qpc-hafs">﴿لا إلَهَ إلّا هُوَ﴾</span> كانت كُفّار قريش لا يُوَحِّدونه، فوحَّد نفسه، <span class="qpc-hafs">﴿إلَيْهِ المَصِيرُ﴾</span> مصير مَن يقول: لا إله إلا الله، فيُدخله الجنة، ومصير مَن لا يقول: لا إله إلا الله، فيُدخله النار{1}. (١٣/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span>، قال: ذي الغِنى{9}. (١٣/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span>: ذي إنعام{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٠٩<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span> ذي المَنّ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span>، قال: ذي المنّ{12}. (١٣/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span> ذي الفضل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span>، قال: ذي النِّعَم{14}. (١٣/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدّيّ</span>: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span> ذي السَّعَة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span> يعني: ذي الغنى عمَّن لا يُوَحِّده، <span class="qpc-hafs">﴿لا إلَهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</span> يعني: مصير العباد إليه في الآخرة، فيجزيهم بأعمالهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span>، قال: الطول: القدرة، ذاك الطول{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذِی ٱلطَّوۡلِۖ لَاۤ إِلَـٰهَ إِلَّا هُوَۖ إِلَیۡهِ ٱلۡمَصِیرُ ۝٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨١٦<span class="dash">-</span></span> عن قتادة بن دعامة، قال: كان شابٌّ بالمدينة صاحبَ عبادة، وكان عمرُ مُعجبًا به، فانطلق إلى مصر، فَفَسُد، فجعل لا يمتنع عن شرٍّ، فقدم على عمر بعضُ أهله، فسأله حتى سأله عن الشابّ، فقال: لا تسألني عنه. قال: لِمَ؟ قال: إنّه فسد وخلع. فكتب إليه عمر: مِن عمر إلى فلان، <span class="qpc-hafs">﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلَهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</span>. فجعل يقترئها على نفسه، فأقبل بخير{18}. (١٣/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٧<span class="dash">-</span></span> عن أبي إسحاق السَّبِيعي، قال: جاء رجلٌ إلى عمر بن الخطاب، فقال: يا أمير المؤمنين، إن قتلتُ فهل لي مِن توبة؟ فقرأ عليه: <span class="qpc-hafs">﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ﴾</span>. وقال: اعمل ولا تيأس{19}. (١٣/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨١٨<span class="dash">-</span></span> عن يزيد بن الأصم: أن رجلًا كان ذا بأس، وكان يُوفَد إلى عمر لبأسه، وكان مِن أهل الشام، وأن عمر فقَدَه، فسأل عنه، فقيل له: تتابع في هذا الشراب. فدعا عمرُ كاتبَه، فقال: اكتب: مِن عمر بن الخطاب إلى فلان بن فلان، سلام عليك، فإني أحمد إليك الله الذي لا إله إلا هو، <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلَهَ إلّا هُوَ إلَيْهِ المَصِر﴾</span>. ثم دعا، وأمَّن مَن عنده، فدعَوا له أن يُقبِل الله عليه بقلبه، وأن يتوب الله عليه. فلما أتَت الصحيفةُ الرجلَ جعل يقرؤها، ويقول: <span class="qpc-hafs">﴿غافِرِ الذَّنْبِ﴾</span> قد وعدني اللهُ أن يغفر لي، <span class="qpc-hafs">﴿وقابِلِ التَّوْبِ شَدِيدِ العِقابِ﴾</span> قد حذَّرني الله عقابه، <span class="qpc-hafs">﴿ذِي الطَّوْلِ﴾</span> والطَّوْل: الخير الكثير، <span class="qpc-hafs">﴿إلَيْهِ المَصِير﴾</span>. فلم يزل يردّدها على نفسه حتى بكى، ثم نزع فأحسن النزع. فلما بلغ عمرُ أمرَه قال: هكذا فاصنعوا، إذا رأيتم أخًا لكم زلَّ زلَّة فسدِّدوه ووفِّقوه، وادعوا الله له أن يتوب عليه، ولا تكونوا أعوانًا للشيطان عليه{20}. (١٣/١١)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الأوسط (٩٤٨١). وعزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٨/٢٦٤، وتفسير البغوي ٧/١٣٨.أخرجه أبو الشيخ في العظمة (١٧٩).أخرجه الطبراني في الدعاء ٣/١٥١٣.تفسير مقاتل بن سليمان ٣/٧٠٥.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٥٥، والإتقان ٢/٤١-، وابن جرير ٢٠/٢٧٨، والبيهقي في الأسماء والصفات (٦٩). وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٨/٢٦٤، وتفسير البغوي ٧/١٣٨.أخرجه الطبراني في الأوسط (٩٤٨١). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٠/٢٧٨. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مجاهد ص٥٨٢.تفسير الثعلبي ٨/٢٦٤.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٥٥-. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ٨/٢٦٤، وتفسير البغوي ٦/١٣٨.أخرجه ابن جرير ٢٠/٢٧٩، وأخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٥٥- بلفظ: ذي النعماء. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير الثعلبي ٨/٢٦٤.تفسير مقاتل بن سليمان ٣/٧٠٥.أخرجه ابن جرير ٢٠/٢٧٨.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/٢٤٧ (٢٨٣٢١)، وابن جرير ٢٠/٢٧٧، وابن أبي حاتم -كما في تفسير ابن كثير ٧/١١٨- واللفظ له. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد بن حميد -كما في تفسير أحاديث الكشاف ٣/٢١٥-٢١٦-، وإسحاق البستي ص٢٧٦ بنحوه.
  40,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا یُجَـٰدِلُ فِیۤ ءَایَـٰتِ ٱللَّهِ إِلَّا ٱلَّذِینَ كَفَرُوا۟ فَلَا یَغۡرُرۡكَ تَقَلُّبُهُمۡ فِی ٱلۡبِلَـٰدِ ۝٤﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٧٨١٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك الغِفاري</span>، في قوله: <span class="qpc-hafs">﴿ما يُجادِلُ فِي آياتِ اللَّهِ إلّا الَّذِينَ كَفَرُوا﴾</span>: نزلت في الحارث بن قيس السهمي{1}. (١٣/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فَلا يَغْرُرْكَ تَقَلُّبُهُمْ فِي البِلادِ﴾</span>، قال: فسادهم فيها، وكفرهم{2}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَلا يَغْرُرْكَ تَقَلُّبُهُمْ فِي البِلادِ﴾</span>، قال: إقبالهم، وإدبارهم، وتقلّبهم في أسفارهم{3}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما يُجادِلُ﴾</span> يعني: يُماري <span class="qpc-hafs">﴿فِي آياتِ اللَّهِ﴾</span> يعني: آيات القرآن <span class="qpc-hafs">﴿إلّا الَّذِينَ كَفَرُوا﴾</span> يعني: الحارث بن قيس السهمي، <span class="qpc-hafs">﴿فَلا يَغْرُرْكَ﴾</span> يا محمد <span class="qpc-hafs">﴿تَقَلُّبُهُمْ فِي البِلادِ﴾</span> يعني: كفار مكة. يقول: لا يغررك ما هم فيه مِن الخير، والسّعة من الرزق؛ فإنّه متاع قليل، مُمتَّعون به إلى آجالهم في الدنيا{4}<span class=comment-ref>٥٦٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٦٦٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٢٢) أن قوله: <span class="qpc-hafs">﴿فَلا يَغْرُرْكَ﴾</span> أنزله منزلة: فلا يحزنك ولا يهمنّك. لتدل الآية على أنهم ينبغي أن لا يغتروا بإملاء الله تعالى لهم، فالخطاب له ﷺ، والإشارة إلى مَن يقع منه الاغترار، ثم <span class="comment-type-4">أورد</span> احتمالًا آخر، فقال: «و<b>يُحتمل</b> أن يكون <span class="qpc-hafs">﴿يَغْرُرْكَ﴾</span> بمعنى: تظن أن وراء تقلّبهم وإمهالهم خيرًا لهم، فتقول: عسى أن لا يُعذَّبوا».</div></p><p><h3><span class="qpc-hafs">﴿مَا یُجَـٰدِلُ فِیۤ ءَایَـٰتِ ٱللَّهِ إِلَّا ٱلَّذِینَ كَفَرُوا۟ فَلَا یَغۡرُرۡكَ تَقَلُّبُهُمۡ فِی ٱلۡبِلَـٰدِ ۝٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٢٣<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ جِدالًا في القرآن كفر</b>»{5}. (١٣/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٤<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>مِراءٌ في القرآن كفر</b>»{6}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٥<span class="dash">-</span></span> عن أبي جُهَيْم، قال: اختلف رجلان مِن أصحاب النبيِّ ﷺ في آيةٍ، فقال أحدهما: تلقيتُها مِن في رسول الله ﷺ. وقال الآخر: أنا تلقّيتُها مِن في رسول الله ﷺ. فأتيا النبيَّ ﷺ، فذكرا ذلك له، فقال: «<b>أُنزل القرآن على سبعة أحرف، وإياكم والمراءَ فيه؛ فإنّ المراء فيه كفر</b>»{7}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٦<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جده، قال: سمع رسولُ الله ﷺ قومًا يتمارون في القرآن، فقال: «<b>إنّما هلك مَن كان قبلكم بهذا، ضربوا كتابَ الله ﷿ بعضه ببعض، وإنّما نزل كتابُ اللهِ يُصَدِّق بعضُه بعضًا، فلا تُكَذِّبوا بعضه ببعض، فما علمتم منه فقولوه، وما جهلتم منه فكِلوه إلى عالمه</b>»{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع بن أنس- قال: آيتان ما أشدهما على الذين يجادلون في القرآن: <span class="qpc-hafs">﴿ما يُجادِلُ فِي آياتِ اللَّهِ إلّا الَّذِينَ كَفَرُوا﴾</span>، و<span class="qpc-hafs">﴿وإنَّ الَّذِينَ اخْتَلَفُوا فِي الكِتابِ لَفِي شِقاقٍ بَعِيدٍ﴾</span> [البقرة:١٧٦]{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٠/٢٨٠، وعبد الرزاق ٢/١٧٨ من طريق معمر. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٥.أخرجه أحمد ١٢/٤٧٦ (٧٥٠٨)، ١٦/١٥٥ (١٠٢٠٢)، ١٦/٢٦٠ (١٠٤١٤)، والحاكم ٢/٢٤٣ (٢٨٨٣)، والثعلبي ٨/٢٦٥.</p><p>قال الحاكم: «حديث المعتمر عن محمد بن عمرو صحيح، على شرط مسلم، ولم يخرجاه، فأمّا عمر بن أبي سلمة فإنهما لم يحتجا به». وقال المناوي في فيض القدير ٣/٣٥٥ (٣٦١٤): «وعمر هذا أورده الذهبي في الضعفاء، وقال: ضعّفه ابن معين. وقال النسائي: ليس بقوي».أخرجه أحمد ١٣/٢٤١ (٧٨٤٨)، ١٦/١٣٣ (١٠١٤٣)، ١٥/٢٨٨ (٩٤٧٩)، ١٦/٣١٨ (١٠٥٣٩)، وأبو داود ٧/١٢ (٤٦٠٣)، وابن حبان ٤/٣٢٤-٣٢٥ (١٤٦٤)، والحاكم ٢/٢٤٣ (٢٨٨٢).</p><p>قال الحاكم: «تابعه عمر بن أبي سلمة، عن أبيه». وقال الذهبي في التلخيص: «على شرط مسلم».أخرجه أحمد ٢٩/٨٥ (١٧٥٤٢).</p><p>قال الهيثمي في المجمع ٧/١٥١ (١١٥٧٣): «ورجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٦/٣٢٤-٣٢٥ (٥٩٣٧/٣): «هذا إسناد رجاله ثقات». وقال المناوي في التيسير ٢/٢٠٢: «وإسناده صحيح». وقال الألباني في الصحيحة ٤/٢٧: «وسنده صحيح، على شرط الشيخين».أخرجه أحمد ١١/٣٥٣-٣٥٤ (٦٧٤١)، من طريق عبد الرزاق، عن معمر، عن الزهري، عن عمرو بن شعيب، عن أبيه، عن جده به.</p><p>إسناده حسن.أخرجه الثعلبي ٨/٢٦٥. وينظر: تفسير البغوي ٧/١٣٨.
  40,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ وَٱلۡأَحۡزَابُ مِنۢ بَعۡدِهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿والأَحْزابُ مِن بَعْدِهِمْ﴾</span>، قال: مِن بعد قوم نوح عاد وثمود وتلك القرون، كانوا أحزابًا على الكفر{1}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍ والأَحْزابُ مِن بَعْدِهِمْ﴾</span>، قال: الكُفّار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذَّبَتْ قَبْلَهُمْ﴾</span> قبل أهل مكة <span class="qpc-hafs">﴿قَوْمُ نُوحٍ﴾</span> رسولهم نوحًا ﵇ <span class="qpc-hafs">﴿والأَحْزابُ﴾</span> يعني: الأمم الخالية رسلهم <span class="qpc-hafs">﴿مِن بَعْدِهِمْ﴾</span> يعني: مِن بعد قوم نوح{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَمَّتۡ كُلُّ أُمَّةِۭ بِرَسُولِهِمۡ لِیَأۡخُذُوهُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٣١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وهَمَّتْ كُلُّ أُمَّةٍ بِرَسُولِهِمْ لِيَأْخُذُوه﴾</span> ليقتلوه ويُهلكوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وهَمَّتْ كُلُّ أُمَّةٍ بِرَسُولِهِمْ لِيَأْخُذُوه﴾</span>: أي: ليقتلوه{5}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهَمَّتْ كُلُّ أُمَّةٍ بِرَسُولِهِمْ لِيَأْخُذُوه﴾</span>، يعني: ليقتلوه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَـٰدَلُوا۟ بِٱلۡبَـٰطِلِ لِیُدۡحِضُوا۟ بِهِ ٱلۡحَقَّ فَأَخَذۡتُهُمۡۖ فَكَیۡفَ كَانَ عِقَابِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَأَخَذْتُهُمْ فَكَيْفَ كانَ عِقابِ﴾</span>، قال: شديدٌ، واللهِ{7}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجادَلُوا﴾</span> يعني: وخاصموا رسلَهم <span class="qpc-hafs">﴿بِالباطِلِ لِيُدْحِضُوا بِهِ الحَقَّ﴾</span> يعني: لِيُبطلوا به الحقَّ الذي جاءت به الرسلُ، وجدالهم أنهم قالوا لرسلهم: ما أنتم إلا بشر مثلنا، وما نحن إلا بشر مثلكم، ألا أرسل الله ملائكة! فهذا جدالهم كما قالوا للنبي ﷺ، <span class="qpc-hafs">﴿فَأَخَذْتُهُمْ﴾</span> بالعذاب، <span class="qpc-hafs">﴿فَكَيْفَ كانَ عِقابِ﴾</span> يعني: عقابي، أليس وجدوه حقًّا؟{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَـٰدَلُوا۟ بِٱلۡبَـٰطِلِ لِیُدۡحِضُوا۟ بِهِ ٱلۡحَقَّ فَأَخَذۡتُهُمۡۖ فَكَیۡفَ كَانَ عِقَابِ ۝٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٣٦<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ، قال: «<b>مَن أعان باطِلًا لِيُدحِض بباطله حقًّا فقد برئت منه ذِمَّةُ الله، وذِمَّةُ رسوله</b>»{9}. (١٣/١٦)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٧٨. وعزاه السيوطي إلى عبد بن حُمَيد، وابن جرير.أخرجه ابن جرير ٢٠/٢٨٠.تفسير مقاتل بن سليمان ٣/٧٠٥-٧٠٦.تفسير البغوي ٧/١٣٩.أخرجه ابن جرير ٢٠/٢٨١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٥-٧٠٦.أخرجه ابن جرير ٢٠/٢٨٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٥-٧٠٦.أخرجه الحاكم ٤/١١٢ (٧٠٥٢)، وفيه حنش الرحبي.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وتعقّبه الذهبي في التلخيص بقوله: «حنش الرحبي ضعيف». قال ابن القيسراني في تذكرة الحفاظ ص٣٠٣ (٧٦٠): «الحديث منكر». وقال الهيثمي في المجمع ٤/٢٠٥ (٧٠٦٣): «رواه الطبراني في الثلاثة، وفي إسناد الكبير: حنش، وهو متروك، وزعم أبو محصن أنه شيخ صدق، وفي إسناد الصغير والأوسط: سعيد بن رحمة، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٧/٣٨٤ (٧١٣٤): «رواه مسدّد، والطبراني، والأصبهاني، ومدار أسانيدهم على حسين بن قيس، المعروف بحنش، وهو ضعيف». وأورده الألباني في الصحيحة ٣/١٧ (١٠٢٠).
  40,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ حَقَّتۡ كَلِمَتُ رَبِّكَ عَلَى ٱلَّذِینَ كَفَرُوۤا۟ أَنَّهُمۡ أَصۡحَـٰبُ ٱلنَّارِ ۝٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٣٧<span class="dash">-</span></span> عن النضر، عن هارون، عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٣٨<span class="dash">-</span></span> و<span class="name-2">أبي عمرو</span>: <span class="qpc-hafs">﴿وكذلك حقَّتْ كَلمت ربك﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٣٩<span class="dash">-</span></span> و<span class="name-2">الأعرج</span>: ‹كَلِماتُ رَبِّكَ›{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ حَقَّتۡ كَلِمَتُ رَبِّكَ عَلَى ٱلَّذِینَ كَفَرُوۤا۟ أَنَّهُمۡ أَصۡحَـٰبُ ٱلنَّارِ ۝٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وكَذَلِكَ حَقَّتْ كَلِمَتُ رَبِّكَ عَلى الَّذِينَ كَفَرُوا﴾</span>، قال: حقَّ عليهم العذابُ بأعمالهم{2}. (١٣/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكَذَلِكَ﴾</span> يعني: وهكذا عذَّبتُهم، <span class="qpc-hafs">﴿وكَذَلِكَ حَقَّتْ كَلِمَتُ رَبِّكَ﴾</span> يقول: وجبت كلمة العذاب مِن ربك <span class="qpc-hafs">﴿عَلى الَّذِينَ كَفَرُوا أنَّهُمْ أصْحابُ النّارِ﴾</span> حين قال لإبليس: <span class="qpc-hafs">﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّنْ تَبِعَكَ مِنهُمْ أجْمَعِينَ﴾</span> [ص:٨٥]{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٢٧٧.</p><p>و‹كَلِماتُ› بالجمع قراءة متواترة، قرأ بها نافع، وأبو جعفر، وابن عامر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿كَلِمَتُ﴾</span> على الإفراد. انظر: الإتحاف ص٤٨٤.أخرجه عبد الرزاق ٢/١٧٨. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٦.
  40,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یَحۡمِلُونَ ٱلۡعَرۡشَ وَمَنۡ حَوۡلَهُۥ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: في بعض القراءة: (الَّذِينَ يَحْمِلُونَ العَرْشَ والَّذِينَ حَوْلَهُ المَلَآئِكَةُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ){1}. (١٣/٢١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یَحۡمِلُونَ ٱلۡعَرۡشَ وَمَنۡ حَوۡلَهُۥ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِينَ يَحْمِلُونَ العَرْشَ﴾</span> فيها إضمار، وهم أول مَن خلَق الله تعالى مِن الملائكة، وذلك أن الله -تبارك وتعالى- قال: <span class="qpc-hafs">﴿والمَلائِكَةُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ ويَسْتَغْفِرُونَ لِمَن فِي الأَرْضِ﴾</span> [الشورى:٥]، فاختصّ في «حم المؤمن» من الملائكة حملة العرش، <span class="qpc-hafs">﴿ومَن حَوْلَهُ﴾</span> يقول: ومَن حول العرش مِن الملائكة، اختصّ استغفارُ الملائكة بالمؤمنين من أهل الأرض، فقال: <span class="qpc-hafs">﴿الَّذِينَ يَحْمِلُونَ العَرْشَ ومَن حَوْلَهُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یَحۡمِلُونَ ٱلۡعَرۡشَ وَمَنۡ حَوۡلَهُۥ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٤٤<span class="dash">-</span></span> عن عبد الله بن عباس: أنّ رسول الله ﷺ خرج على أصحابه، فقال: «<b>ما جمَعَكم؟</b>». قالوا: اجتمعنا نذكر ربَّنا، ونتفكر في عظمته. فقال: «<b>لن تُدركوا التفكّر في عظمته، ألا أخبركم ببعض عظمة ربكم</b>!». قيل: بلى، يا رسول الله. قال: «إ<b>نَّ مَلكًا مِن حَمَلة العرش يُقال له: إسرافيل، زاوِية مِن زوايا العرش على كاهله، قد مَرَقَتْ قدماه في الأرض السابعة السفلى، ومَرَقَ رأسُه مِن السماء السابعة العليا، في مِثله مِن خليقة ربكم تعالى</b>»{3}. (١٣/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٤٥<span class="dash">-</span></span> عن جابر، أنّ النبيَّ ﷺ قال: «<b>أُذِن لي أن أُحدِّث عن مَلَك مِن ملائكة الله مِن حَمَلة العرش، ما بين شحْمة أُذنه إلى عاتقه مسيرة سبعمائة سنة</b>»{4}. (١٣/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٤٦<span class="dash">-</span></span> عن أم سعد، قالت: سمعتُ النبيَّ ﷺ يقول: «<b>العرش على ملَك مِن لؤلؤة على صورة ديك، رِجلاه في تُخُوم الأرض، وجناحاه في المشرق، وعُنقه تحت العرش</b>»{5}. (١٣/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٤٧<span class="dash">-</span></span> عن مكحول، قال: قال رسول الله ﷺ: «<b>إنّ في حَمَلة العرش أربعة أملاك، مَلك على صورة سيِّد الصُّوَر، وهو ابن آدم، ومَلك على صورة سيّد السِّباع، وهو الأسد، ومَلك على صورة سيّد الأنعام، وهو الثَّور، فما زال غضبان مُذ يوم العِجل إلى ساعتي هذه، ومَلك على صورة سيّد الطير، وهو النّسر</b>»{6}. (١٣/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: حَمَلة العرش ما بين كَعْبِ أحدهم إلى أسفل قدميه مسيرة خمسمائة عام، وذُكر: أنّ خُطْوة ملك الموت ما بين المشرق والمغرب{7}. (١٣/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق أبي قبيل- يقول: حَمَلةُ العرش ثمانية، ما بين مُؤق أحدهم إلى مُؤخّر عينيه مسيرة خمسمائة عام{8}. (١٣/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥٠<span class="dash">-</span></span> عن <span class="name-2">عُروة بن الزبير</span>، قال: حَمَلة العرش منهم مَن صورتُه صورةُ الإنسان، ومنهم مَن صورتُه صورة النّسر، ومنهم مَن صورته صورة الثَّور، ومنهم مَن صورته صورة الأسد{9}. (١٣/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥١<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق عبد الصمد- قال: حَمَلة العرش الذي يحملونه، لكل مَلك منهم أربعة وجوه، وأربعة أجنحة، جناحان على وجهه مِن أن ينظر إلى العرش فيَصعق، وجناحان يطير بهما، أقدامهم في الثَّرى، والعرش على أكتافهم، لكل واحد منهم وجه ثَور، ووجه أسد، ووجه إنسان، ووجه نسر، ليس لهم كلام إلا أن يقولوا: قُدّوس، الله القوي، ملأت عظمته السموات والأرض{10}. (١٣/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥٢<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق عبد المنعم بن إدريس، عن أبيه- قال: حَمَلة العرش اليوم أربعة، فإذا كان يوم القيامة أُيِّدوا بأربعة آخرين، مَلك منهم في صورة إنسان يشفع لبني آدم في أرزاقهم، ومَلك منهم في صورة نِسر يشفع للطير في أرزاقهم، ومَلك منهم في صورة ثَور يشفع للبهائم في أرزاقهم، ومَلَك في صورة أسد يشفع للسباع في أرزاقها، فلما حملوا العرش وقعوا على رُكَبهم مِن عظمة الله، فلُقِّنوا: لا حول ولا قوة إلا بالله. فاستَوَوا قيامًا على أرجلهم{11}. (١٣/١٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ﴾</span>، يقول: يذكرون الله بأمره، ويؤمنون به، ويصدِّقون بالله ﷿ بأنّه واحد لا شريك له{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٥٤<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>أُذِن لي أن أُحَدِّث عن مَلَك قد مَرَقَتْ رِجلاه الأرضَ السابعة، والعرش على مَنكِبه، وهو يقول: سبحانك أين كنت وأين تكون</b>»{13}. (١٣/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥٥<span class="dash">-</span></span> عن جعفر، قال: سمعتُ يزيدًا يقول: قال رجل <span class="name-1">لابن عباس</span>: لا إله الا الله، نعرف أنّ الله هو أكبر من كل شيء، والحمد لله، نعرف أنّ الحمد لله، فما سبحان الله؟ قال ابن عباس: وما تنكر منها؟! هي كلمة وضعها الله لنفسه، وأمر ملائكته به، وفزّع إليه الأخيار من خلقه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥٦<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span> -من طريق هارون بن رِئاب- قال: حملة العرش ثمانية، فأربعة منهم يقولون: سبحانك اللهم وبحمدك، لك الحمد على حِلمك بعد علمك. وأربعة منهم يقولون: سبحانك اللهم وبحمدك، لك الحمد على عفوك بعد قدرتك. قال: وكأنهم ينظرون ذنوب بني آدم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥٧<span class="dash">-</span></span> عن <span class="name-2">هارون بن رِئاب</span> -من طريق الأوزاعي- قال: حَمَلة العرش ثمانية، يتجاوبون بصوت رخيم، يقول أربعة منهم: سبحانك وبحمدك على على حِلمك بعد علمك. وأربعة منهم يقولون: سبحانك وبحمدك، عفوك بعد قدرتك{16}. (١٣/١٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَسۡتَغۡفِرُونَ لِلَّذِینَ ءَامَنُوا۟ۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</span>: لأهل لا إله إلا الله{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</span> حين قالوا: <span class="qpc-hafs">﴿فاغْفِرْ لِلَّذِينَ تابُوا﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَسۡتَغۡفِرُونَ لِلَّذِینَ ءَامَنُوا۟ۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٦٠<span class="dash">-</span></span> عن قتادة: <span class="qpc-hafs">﴿ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</span>، قال <span class="name-2">مُطَرِّف بن عبد الله بن الشِّخِّير</span>: وجدنا أنصحَ عبادِ الله لعباده الملائكة، ووجدنا أغشَّ عبادِ الله لعبادِ الله الشياطين{19}. (١٣/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٦١<span class="dash">-</span></span> ذكر يحيى بن عمر بن شداد التيمي مولى لبني تيم بن مرة قال: قال لي <span class="name-3">سفيان بن عُيْينة</span> ...: أبْشِر، فإنك على خير، تدري مَن دعا لك؟ قال: قلتُ: ومَن دعا لي؟ قال: دعا لك حَمَلةُ العرش. قال: قلتُ: دعا لي حَمَلةُ العرش! قال: نعم، ودعا لك نبيُّ الله نوح ﵇. قال: قلتُ: دعا لي حَمَلة العرش، ودعا لي نوح! قال: نعم، ودعا لك خليل الله إبراهيم. قال: قلتُ: دعا لي هؤلاء كلهم؟ قال: نعم، ودعا لك محمد. قال: قلتُ: وأين دعا لي هؤلاء؟ قال: في كتاب الله، أما سمعت قوله: <span class="qpc-hafs">﴿الَّذِينَ يَحْمِلُونَ العَرْشَ ومَن حَوْلَهُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ ويُؤْمِنُونَ بِهِ ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</span> ...{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا وَسِعۡتَ كُلَّ شَیۡءࣲ رَّحۡمَةࣰ وَعِلۡمࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالت الملائكة: <span class="qpc-hafs">﴿رَبَّنا وسِعْتَ كُلَّ شَيْءٍ﴾</span> يعني: ملأتَ كل شيء من الحيوان في السموات والأرض <span class="qpc-hafs">﴿رَحْمَةً﴾</span> يعني: نعمة يتقلَّبون فيها، <span class="qpc-hafs">﴿وعِلْمًا﴾</span> يقول: علم مَن فيهما مِن الخلْق{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱغۡفِرۡ لِلَّذِینَ تَابُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فاغْفِرْ لِلَّذِينَ تابُوا﴾</span>، قال: تابوا من الشرك{22}. (١٣/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاغْفِرْ لِلَّذِينَ تابُوا﴾</span> من الشرك{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبَعُوا۟ سَبِیلَكَ وَقِهِمۡ عَذَابَ ٱلۡجَحِیمِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٧٨٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿واتَّبَعُوا سَبِيلَكَ﴾</span>، قال: طاعتك{24}. (١٣/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٧٨٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتَّبَعُوا سَبِيلَكَ﴾</span> يعني: دينك، <span class="qpc-hafs">﴿وقِهِمْ عَذابَ الجَحِيمِ﴾</span>{23}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حُمَيد.</p><p>وهي قراءة شاذة.تفسير مقاتل بن سليمان ٣/٧٠٦.أخرجه أبو الشيخ في العظمة ٢/٦٩٧-٦٩٨، وأبو نعيم في الحلية ٦/٦٥-٦٦. وأورد الثعلبي ٨/٢٦٦ نحوه.</p><p>قال أبو نعيم: «تفرّد به إسماعيل بن عيّاش، عن الأحوص، عن شهر بن حوشب، عن ابن عباس، ورواه عبد الجليل بن عطية، عن شهر، عن عبد الله بن سلام».أخرجه أبو داود ٧/١٠٩ (٤٧٢٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢١٢-. وأورده الثعلبي ٨/٢٦٦.</p><p>قال ابن كثير: «وهذا إسناد جيد، رجاله ثقات». وقال الهيثمي في المجمع ١/٨٠ (٢٥٦): «رواه الطبراني في الأوسط، ورجاله رجال الصحيح». وقال ابن حجر في الفتح ٨/٦٦٥: «إسناده على شرط الصحيح». وقال السيوطي: «بسند صحيح». وأورده الألباني في الصحيحة ١/٢٨٢ (١٥١).أخرجه ابن أبي شيبة في العرش وما روي فيه ص٤٤٩-٤٥٠ (٦٨). وعزاه السيوطي إلى ابن مردويه.أخرجه أبو الشيخ (٣٤٠) مرسلًا.أخرجه البيهقي في الأسماء والصفات (٨٤٨). وعزاه السيوطي إلى عبد بن حُمَيد، وابن مردويه.أخرجه أبو الشيخ (٤٨٠). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في الأسماء والصفات عقب الأثر (٨٤٨).أخرجه أبو الشيخ (٢٣١).أخرجه أبو الشيخ (٤٨٥).تفسير مقاتل بن سليمان ٣/٧٠٦.أخرجه أبو يعلى ١١/٤٩٦ (٦٦١٩). وعزاه السيوطي إلى ابن مردويه.</p><p>قال الهيثمي في المجمع ١/٨٠ (٢٥٧)، ٨/١٣٥ (١٣٣٨١): «ورجاله رجال الصحيح». وقال السيوطي: «بسند صحيح».أخرجه إسحاق البستي ص٢٧٦.أخرجه البغوي ٦/١٤١.أخرجه أبو الشيخ (٤٨٣)، والبيهقي في شعب الإيمان (٣٦٤). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٢٨٣.تفسير مقاتل بن سليمان ٣/٧٠٦.أخرجه عبد الرزاق ٢/١٧٨، وابن جرير ٢٠/٢٨٧. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن أبي الدنيا في كتاب حُسن الظنّ بالله -موسوعة الإمام ابن أبي الدنيا ١/٩٠-٩١ (٧٩)-، وأبو نعيم في حلية الأولياء ١/٧٧-٧٨.تفسير مقاتل بن سليمان ٣/٧٠٦-٧٠٧.أخرجه عبد الرزاق ٢/١٧٨ من طريق معمر، وابن جرير ٢٠/٢٨٤. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٧.أخرجه عبد الرزاق ٢/١٧٨ من طريق معمر، وابن جرير ٢٠/٢٨٥. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٧.