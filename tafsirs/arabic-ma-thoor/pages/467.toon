quran[8]{c,v,t}:
39,75," <q>﴿وَتَرَى ٱلۡمَلَـٰۤىِٕكَةَ حَاۤفِّینَ مِنۡ حَوۡلِ ٱلۡعَرۡشِ یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡۚ﴾</q> - تفسير ٦٧٧٥١- عن عطاء، <q>﴿وتَرى المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ﴾</q>، قال: مُدِيرِين به{1}. (١٢/٧٣٥) ٦٧٧٥٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وتَرى المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ﴾</q>، قال: مُحدِقين به{2}. (١٢/٧٣٥) ٦٧٧٥٣- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وتَرى المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ﴾</q>، قال: مُحدِقين حول العرش. قال: العرش: السرير{3}. (ز) ٦٧٧٥٤- قال مقاتل بن سليمان: <q>﴿وتَرى﴾</q> يا محمد <q>﴿المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ﴾</q> يعني: يذكرونه بأمر ربهم{4}. (ز) <q>﴿وَتَرَى ٱلۡمَلَـٰۤىِٕكَةَ حَاۤفِّینَ مِنۡ حَوۡلِ ٱلۡعَرۡشِ یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡۚ﴾</q> - آثار متعلقة بالآية ٦٧٧٥٥- عن كعب الأحبار -من طريق أبي قبيل- قال: جبل الخليل والطور والجُوديّ، يكون كل واحد منهم يوم القيامة لؤلؤة بيضاء تضيء ما بين السماء والأرض، يرجعن إلى بيت المقدس، حتى يُجعلن في زواياه، ويضع عليها كرسيه حتى يقضي بين أهل الجنة والنار، و<q>﴿المَلائِكَةَ حافِّينَ مِن حَوْلِ العَرْشِ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ وقُضِيَ بَيْنَهُمْ بِالحَقِّ﴾</q>{5}. (١٢/٧٣٥) <q>﴿وَقُضِیَ بَیۡنَهُم بِٱلۡحَقِّۚ وَقِیلَ ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٧٥﴾</q> - تفسير ٦٧٧٥٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وقُضِي َبَيْنَهُمْ بِالحَق ِّوَقِيل الحَمْد ُلِلَّه ِرَب ِّالعالَمِينَ﴾</q>، قال: افتتح أول الخلق بالحمد، وختم بالحمد؛ فتح بقوله: <q>﴿الحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ﴾</q> [الأنعام:١]، وختم بقوله: <q>﴿وقِيلَ الحَمْد ُلِلَّه ِرَب ِّالعالَمِينَ﴾</q>{6}. (١٢/٧٣٥) ٦٧٧٥٧- قال مقاتل بن سليمان: <q>﴿وقُضِيَ بَيْنَهُمْ بِالحَقِّ وقِيلَ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q> وذلك أنّ الله -تبارك وتعالى- افتتح الخلْق بالحمد، وختم بالحمد، فقال: <q>﴿الحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ...﴾</q> [الأنعام: ١]، وختم بالحمد حين قال: <q>﴿وقُضِيَ بَيْنَهُمْ بِالحَقِّ﴾</q> يعني: بالعدل، <q>﴿وقِيلَ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>{4}. (ز) <q>﴿وَقُضِیَ بَیۡنَهُم بِٱلۡحَقِّۚ وَقِیلَ ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٧٥﴾</q> - آثار متعلقة بالآية ٦٧٧٥٨- عن وهْب بن مُنَبِّه، قال: مَن أراد أن يعرف قضاء الله في خلْقه فليقرأ آخر سورة الغُرَف{1}. (١٢/٧٣٦) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٢٧١. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٢٧١.تفسير مقاتل بن سليمان ٣/٦٨٩.أخرجه ابن عساكر ٢/٣٤٨-٣٤٩.أخرجه عبد الرزاق ٢/١٧٧ من طريق معمر، وابن جرير ٢٠/٢٧٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٨٩.عزاه السيوطي إلى عبد بن حميد.
40,1," مقدمة السورة ٦٧٧٥٩- عن عبد الله بن عباس، قال: أُنزلت الحواميم السّبع بمكة{1}. (١٣/٥) ٦٧٧٦٠- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مكية{2}. (ز) ٦٧٧٦١- عن عبد الله بن عباس -من طريق خُصَيْف، عن مجاهد-: مكية، وذكرها باسم: حم المؤمن{3}. (ز) ٦٧٧٦٢- عن عبد الله بن عباس، قال: أُنزلت «حم المؤمن» بمكة{4}. (١٣/٥) ٦٧٧٦٣- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكية، وذكرها باسم: حم المؤمن، وأنها نزلت بعد سورة الزمر{5}. (ز) ٦٧٧٦٤- عن عبد الله بن الزبير، قال: نزلت المؤمن بمكة{4}. (١٣/٥) ٦٧٧٦٥- عن سَمُرَة بن جُندَب، قال: نزلت الحواميم جميعًا بمكة{7}. (١٣/٦) ٦٧٧٦٦- عن عامر الشعبي، قال: أخبرني مسروق: أنّ «آل حم» إنما أُنزلت بمكة{8}. (١٣/٥) ٦٧٧٦٧- عن عكرمة= (ز) ٦٧٧٦٨- والحسن البصري -من طريق يزيد النحوي-: مكية، وذكراها باسم: حم المؤمن{9}. (ز) ٦٧٧٦٩- عن قتادة بن دعامة -من طرق-: مكية{10}. (ز) ٦٧٧٧٠- عن محمد ابن شهاب الزُّهري: مكية، وذكرها باسم: حم المؤمن، وأنها نزلت بعد سورة الزمر{11}. (ز) ٦٧٧٧١- عن علي بن أبي طلحة: مكية{12}. (ز) ٦٧٧٧٢- قال مقاتل بن سليمان: سورة المؤمن مكية، عددها خمس وثمانون آية كوفي{13}٥٦٥٩. (ز) ٥٦٥٩ ذكر ابنُ عطية (٧/٤١٨) أن هذه السورة مكية بإجماع، ثم نقل قولًا بمدنية بعض آياتها، وانتقده، ورجَّح الأول، فقال: «وذلك ضعيف، والأول أصح». ولم يذكر مستندًا. ٦٧٧٧٣- قال الثمالي: إنما سميت بذلك مِن أجل حزقيل مؤمن آل فرعون، مكية{14}. (ز) ٦٧٧٧٤- عن الخليل بن مُرّة، أنّ رسول الله ﷺ قال: «الحواميم سبع، وأبواب جهنم سبع، تجيء كلُّ <q>﴿حم﴾</q> منها تقف على باب من هذه الأبواب، تقول: اللهم، لا يدخل هذا الباب مَن كان يؤمن بي ويقرؤني»{15}. (١٣/٧) ٦٧٧٧٥- عن عبد الله بن مسعود -من طريق مجاهد- قال: الحواميم ديباج القرآن{16}٥٦٦٠. (١٣/٦) ٥٦٦٠ علَّق ابنُ عطية (٧/٤١٨) على هذا الحديث بقوله: «وقفه الزَّجّاج على ابن مسعود». ثم ذكر أن معنى الديباج: «أنها خلت من الأحكام، وقُصرت على المواعظ والزجر وطرق الآخرة محضًا، وأيضًا فهي قصار، لا يلحق لقارئ فيها سآمة». ٦٧٧٧٦- عن زِرّ بن حُبَيْش، قال: قرأتُ القرآن من أوله إلى آخره على علي بن أبي طالب، فلما بلغتُ الحواميم قال لي: قد بلغتَ عرائس القرآن{17}. (١٣/١٤٣) ٦٧٧٧٧- عن سعد بن إبراهيم -من طريق مسعر- قال: كُنّ الحواميم يُسمَّيْنَ: العرائس{18}. (١٣/٧) <q>﴿حمۤ ۝١﴾</q> - تفسير ٦٧٧٧٨- عن عكرمة، قال: قال رسول الله ﷺ: «<q>﴿حم﴾</q> اسم من أسماء الله تعالى، وهي مفاتيح خزائن ربك تعالى»{19}. (ز) ٦٧٧٧٩- عن أنس بن مالك أنه قال: سأل أعرابيٌّ رسولَ الله ﷺ: ما <q>﴿حم﴾</q>؟ فإنّا لا نعرفها في لغتنا. فقال: «بدء أسماء وفواتح سور»{20}. (ز) ٦٧٧٨٠- عن عبد الله بن عباس -من طريق عكرمة-: <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ن﴾</q> حروف الرحمن مُقطّعة{21}. (ز) ٦٧٧٨١- عن عبد الله بن عباس -من طريق علي- قال: <q>﴿حم﴾</q> قسَم أقسمه الله، وهو اسم من أسماء الله{21}. (ز) ٦٧٧٨٢- عن عبد الله بن عباس -من طريق السُّدّيّ-: <q>﴿حم﴾</q> اسم الله الأعظم{23}. (ز) ٦٧٧٨٣- عن أبي أُمامة، قال: <q>﴿حم﴾</q> اسم من أسماء الله{4}٥٦٦١. (١٣/٩) ٥٦٦١ ذكر ابنُ كثير (١٢/١٦٦-١٦٧) أن من قالوا بهذا القول احتجوا لقولهم بقول الشاعر: يُذَكِّرُنِي حامِيمَ والرُّمْح شاجِر فَهَلا تَلا حم قَبْل التَّقَدُّم ثم ساق حديث المهلّب بن أبي صُفرة -الوارد في الآثار المتعلقة بالآية-، ثم علَّق بقوله: «وهذا إسناد صحيح». وذكر ابن جرير (٢٠/٢٧٥-٢٧٦) هذا البيت تحت قول مَن قال: إن <q>﴿حم﴾</q> اسم. ثم قال: «وحُدِّثت عن معمر بن المثنى، أنه قال: قال يونس -يعني: الجرمي-: ومَن قال هذا القول فهو منكر عليه؛ لأنّ السورة <q>﴿حم﴾</q> ساكنة الحروف، فخَرجت مخرج التهجي، وهذه أسماء سور خرجت متحركات، وإذا سُميت سورة بشيء من هذه الأحرف المجزومة دخله الإعراب. والقول في ذلك عندي نظير القول في أخواتها، وقد بينا ذلك، في قوله: <q>﴿الم﴾</q> [البقرة:١]، ففي ذلك كفاية عن إعادته في هذا الموضع، إذ كان القول في <q>﴿حم﴾</q> وجميع ما جاء في القرآن على هذا الوجه، أعني: حروف التهجي قولًا واحدًا». ٦٧٧٨٤- قال سعيد بن جُبير= (ز) ٦٧٧٨٥- وعطاء الخُراسانِيّ: <q>﴿حم﴾</q> الحاء افتتاح أسمائه: حكيم، حميد، حيّ، حليم، حنان، والميم افتتاح أسمائه: مالك، مجيد، منّان{25}. (ز) ٦٧٧٨٦- عن مجاهد بن جبر -من طريق ابن جُرَيْج- قال: <q>﴿ألم﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ألمص﴾</q>، و<q>﴿ص﴾</q> فواتح افتتح الله بها القرآن{26}. (١/١٢٣) ٦٧٧٨٧- عن مجاهد بن جبر -من طريق خُصَيْف- قال: فواتح السور كلها <q>﴿ألم﴾</q>، و<q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ق﴾</q>، وغير ذلك هجاء موضوع{27}. (١/١٢٤) ٦٧٧٨٨- قال الضَّحّاك بن مُزاحِم: <q>﴿حم﴾</q> معناه: قضى ما هو كائن{28}٥٦٦٢. (ز) ٥٦٦٢ ذكر ابنُ عطية (٧/٤١٩) أن الضَّحّاك والكسائي ذكرا أن <q>﴿حم﴾</q> هجاء: حُمَّ -بضم الحاء، وشد الميم المفتوحة-، ثم علَّق بقوله: «كأنه يقول: حمّ الأمر، ووقع تنزيل الكتاب من الله». ٦٧٧٨٩- قال عامر الشعبي: <q>﴿حم﴾</q> شعار السورة{29}. (ز) ٦٧٧٩٠- قال الحسن البصري: <q>﴿حم﴾</q>، ما أدري ما تفسير <q>﴿حم﴾</q> و<q>﴿طسم﴾</q> وأشباه ذلك! غير أنّ قومًا مِن السلف كانوا يقولون: أسماء السور وفواتحها{30}. (ز) ٦٧٧٩١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿حم﴾</q>، قال: اسم من أسماء القرآن{31}. (ز) ٦٧٧٩٢- قال محمد بن كعب القُرظيّ: <q>﴿حم﴾</q> أقسم الله تعالى بِحِلْمه ومُلكه أن لا يُعذِّب أحدًا عاد إليه، يقول: لا إله إلا الله؛ مُخلِصًا من قلبه{29}. (ز) ٦٧٧٩٣- عن إسماعيل السُّدّيّ -من طريق أسباط- قوله: <q>﴿حم﴾</q> مِن حروف أسماء الله{21}. (ز) <q>﴿حمۤ ۝١﴾</q> - آثار متعلقة بالآية ٦٧٧٩٤- عن البراء بن عازب، أنّ رسول الله ﷺ قال: «إنكم تَلْقَون عدوَّكم غدًا، فليكن شعاركم: <q>﴿حم﴾</q> لا يُنصرون»{34}. (١٣/١٠) ٦٧٧٩٥- عن أنس، قال: انهزم المسلمون بحُنَين، فأخذ رسول الله ﷺ حفنةً مِن تراب، فرمى بها في وجوههم، وقال: «<q>﴿حم﴾</q> لا يُنصرون». فانهزم القوم، وما رميناهم بسهم، ولا طعنّا برُمح{35}. (١٣/١٠) ٦٧٧٩٦- عن شيبة بن عثمان، قال: لَمّا كان يوم حُنَين تناول رسولُ الله ﷺ مِن الحصْباء، فنفخ في وجوههم، وقال: «شاهت الوجوه، <q>﴿حم﴾</q> لا يُنصرون»{36}. (١٣/١٠) ٦٧٧٩٧- عن المُهَلَّب بن أبي صُفْرة، قال: حدثني مَن سمِع النبيَّ ﷺ يقول ليلة الخندق: «إن بُيِّتم الليلةَ فقولوا: <q>﴿حم﴾</q> لا يُنصرون»{37}. (١٣/٩) ",footnotes:1:عزاه السيوطي إلى ابن الضريس، والنحاس، والبيهقي في الدلائل.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١. قال السيوطي في الإتقان في علوم القرآن ١/٥٠: «... إسناده جيد، رجاله كلهم ثقات من علماء العربية المشهورين».أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه الديلمي (٦٨١٣). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢١/١٢٥-١٢٦.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٧٠٣.تفسير الثعلبي ٨/٢٦١. وفي طبعة دار التفسير ٢٣/١٤٩: خربيل.أخرجه البيهقي في شعب الإيمان (٢٤٧٩). ضعفه الألباني في ضعيف الجامع (٢٨٠٢).أخرجه أبو عبيد ص١٣٧، وابن الضريس ص٢-٣، وإسحاق البستي ص٢٧٥، والحاكم ٢/٤٣٧، والبيهقي في شعب الإيمان (٢٤٧١). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن النجار في تاريخه.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٥٥٧ (٣٠٩١٤)، والدارمي ٢/٤٥٨، وابن نصر في مختصر قيام الليل ص٦٩.أخرجه الثعلبي ٨/٢٦٣ مرسلًا.أورده الثعلبي ٨/٢٦٣.أخرجه ابن جرير ٢٠/٢٧٤.أخرجه ابن جرير ٢٠/٢٧٤.أخرجه البغوي ٧/١٣٥.عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٧/١٣٥. وفي تفسير الثعلبي ٨/٢٦٣ عن عطاء دون سعيد، وفيه: «ملك» بدل «مالك».أخرجه ابن جرير ١/٢٠٥، وابن أبي حاتم ٥/١٤٣٧، كما أخرجه ابن جرير من طريق سفيان، عن ابن أبي نجيح. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ ابن حيان. وتقدم في سورة البقرة.أخرجه ابن جرير ١/٢٠٩. وعزاه السيوطي إلى ابن المنذر. وعزاه ابن حجر ٨/٥٥٤ إلى ابن أبي حاتم بلفظ: هجاء مقطوع. وتقدم في سورة البقرة.تفسير الثعلبي ٨/٢٦٣، وتفسير البغوي ٧/١٣٥، وعقّبا عليه بأنه كأنه أشار إلى أن معناه: حُمّ -بضم الحاء وتشديد الميم-.تفسير الثعلبي ٨/٢٦٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٢٥-.أخرجه عبد الرزاق ٢/١٧٨ من طريق معمر، وابن جرير ٢٠/٢٧٥.تفسير الثعلبي ٨/٢٦٣.أخرجه ابن جرير ٢٠/٢٧٤.أخرجه أحمد ٣٠/٥١٩ (١٨٥٤٩)، والحاكم ٢/١١٧-١١٨ (٢٥١٤، ٢٥١٥). قال البوصيري في إتحاف الخيرة ٥/١٣١ (٤٣٨٢) بعد ذكره لرواية أبي يعلى والنسائي للحديث: «هذا إسناد حسن». وأورده الألباني في الصحيحة ٧/٢٥٩ (٣٠٩٧).أخرجه الطبراني في الأوسط ٤/٢٠٢ (٣٩٧٨)، والأصبهاني في دلائل النبوة ص٢٢٨ (٣٣٢). قال الطبراني: «لم يرو هذا الحديث عن ثابت إلا عمارة بن زاذان، تفرد به مؤمل». وقال الهيثمي في المجمع ٦/١٨٣ (١٠٢٨٣): «رواه الطبراني في الأوسط، فيه أحمد بن محمد بن القاسم، وهو ضعيف».أخرجه الطبراني في الكبير ٧/٢٩٨ (٧١٩٢) مطولًا. قال الهيثمي في المجمع ٦/١٨٤ (١٠٢٨٥): «فيه أبوبكر الهذلي، وهو ضعيف».أخرجه أحمد ٢٧/١٦٢ (١٦٦١٥)، ٣٨/٢٥٣ (٢٣٢٠٤)، وأبو داود ٤/٢٣٨ (٢٥٩٧)، والترمذي ٣/٤٨٣ (١٧٧٧)، والحاكم ٢/١١٧ (٢٥١٢، ٢٥١٣). قال الحاكم في الموضع الأول: «وهكذا رواه زهير بن معاوية، عن أبي إسحاق». وقال الذهبي في التلخيص: «تابعه زهير بن معاوية، على شرط البخاري ومسلم». وقال الحاكم في الموضع الآخر: «هذا حديث صحيح الإسناد، على شرط الشيخين، إلا أن فيه إرسالًا، فإذا الرجل الذي لم يُسمّه المّهلَّب بن أبي صُفْرة البراء بن عازب». وقال الألباني في صحيح أبي داود ٧/٣٤٧ (٢٣٣٧): «إسناده صحيح».
40,2," <q>﴿تَنزِیلُ ٱلۡكِتَـٰبِ مِنَ ٱللَّهِ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٢﴾</q> - تفسير ٦٧٧٩٨- قال مقاتل بن سليمان: <q>﴿تَنْزِيلُ الكِتابِ مِنَ اللَّهِ﴾</q> يقول: قُضي تنزيل الكتاب <q>﴿العَزِيزِ﴾</q> في مُلكه، <q>﴿العَلِيمِ﴾</q> بخلقه{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٠٥.
40,3," <q>﴿غَافِرِ ٱلذَّنۢبِ وَقَابِلِ ٱلتَّوۡبِ شَدِیدِ ٱلۡعِقَابِ﴾</q> - تفسير ٦٧٧٩٩- عن عبد الله بن عمر -من طريق أسلم- في قوله: <q>﴿غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ﴾</q> الآية، قال: <q>﴿غافِرِ الذَّنْبِ﴾</q> لِمَن يقول: لا إله إلا الله، <q>﴿وقابِلِ التَّوْبِ﴾</q> ممن يقول: لا إله إلا الله، <q>﴿شَدِيدِ العِقابِ﴾</q> لمن لا يقول: لا إله إلا الله{1}. (١٣/١٣) ٦٧٨٠٠- قال عبد الله بن عباس، مثله{2}. (ز) ٦٧٨٠١- عن الحسن البصري -من طريق شَبِيب بن بشر- في قوله: <q>﴿غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ﴾</q>، قال: <q>﴿غافِرِ الذَّنْبِ﴾</q> لِمَن لم يتب، <q>﴿وقابِلِ التَّوْبِ﴾</q> مِمَّن تاب{3}. (١٣/١٢) ٦٧٨٠٢- عن محمد بن السّائِب الكلبي -من طريق حماد بن سلمة- في قوله ﷿: <q>﴿غافر الذنب﴾</q> قال: لِمَن قال: لا إله إلا الله، <q>﴿وقابل التوب﴾</q> مِِمَّن قال: لا إله إلا الله، <q>﴿شديد العقاب﴾</q> لمن لم يقل: لا إله إلا الله{4}. (ز) ٦٧٨٠٣- قال مقاتل بن سليمان: <q>﴿غافِرِ الذَّنْبِ﴾</q> يعني: من الشرك، <q>﴿شَدِيدِ العِقابِ﴾</q> لِمَن لم يوحّده{5}. (ز) <q>﴿ذِی ٱلطَّوۡلِۖ لَاۤ إِلَـٰهَ إِلَّا هُوَۖ إِلَیۡهِ ٱلۡمَصِیرُ ۝٣﴾</q> - تفسير ٦٧٨٠٤- عن عبد الله بن عباس -من طريق علي- <q>﴿ذِي الطَّوْلِ﴾</q>، قال: ذي السَّعة والغِنى{6}. (١٣/١٢) ٦٧٨٠٥- قال عبد الله بن عباس: <q>﴿ذِي الطَّوْل﴾</q> ذي الغنى عَمَّن لا يقول: لا إله إلا الله{2}. (ز) ٦٧٨٠٦- عن عبد الله بن عمر -من طريق أسلم-: <q>﴿ذِي الطَّوْلِ﴾</q> ذي الغِنى، <q>﴿لا إلَهَ إلّا هُوَ﴾</q> كانت كُفّار قريش لا يُوَحِّدونه، فوحَّد نفسه، <q>﴿إلَيْهِ المَصِيرُ﴾</q> مصير مَن يقول: لا إله إلا الله، فيُدخله الجنة، ومصير مَن لا يقول: لا إله إلا الله، فيُدخله النار{1}. (١٣/١٣) ٦٧٨٠٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول الله: <q>﴿ذِي الطَّوْلِ﴾</q>، قال: ذي الغِنى{9}. (١٣/١٣) ٦٧٨٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول الله: <q>﴿ذِي الطَّوْلِ﴾</q>: ذي إنعام{10}. (ز) ٦٧٨٠٩- قال الضَّحّاك بن مُزاحِم: <q>﴿ذِي الطَّوْلِ﴾</q> ذي المَنّ{11}. (ز) ٦٧٨١٠- عن عكرمة مولى ابن عباس، <q>﴿ذِي الطَّوْلِ﴾</q>، قال: ذي المنّ{12}. (١٣/١٣) ٦٧٨١١- قال الحسن البصري: <q>﴿ذِي الطَّوْلِ﴾</q> ذي الفضل{13}. (ز) ٦٧٨١٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ذِي الطَّوْلِ﴾</q>، قال: ذي النِّعَم{14}. (١٣/١٣) ٦٧٨١٣- قال إسماعيل السُّدّيّ: <q>﴿ذِي الطَّوْلِ﴾</q> ذي السَّعَة{11}. (ز) ٦٧٨١٤- قال مقاتل بن سليمان: <q>﴿ذِي الطَّوْلِ﴾</q> يعني: ذي الغنى عمَّن لا يُوَحِّده، <q>﴿لا إلَهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</q> يعني: مصير العباد إليه في الآخرة، فيجزيهم بأعمالهم{5}. (ز) ٦٧٨١٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله <q>﴿ذِي الطَّوْلِ﴾</q>، قال: الطول: القدرة، ذاك الطول{17}. (ز) <q>﴿ذِی ٱلطَّوۡلِۖ لَاۤ إِلَـٰهَ إِلَّا هُوَۖ إِلَیۡهِ ٱلۡمَصِیرُ ۝٣﴾</q> - آثار متعلقة بالآية ٦٧٨١٦- عن قتادة بن دعامة، قال: كان شابٌّ بالمدينة صاحبَ عبادة، وكان عمرُ مُعجبًا به، فانطلق إلى مصر، فَفَسُد، فجعل لا يمتنع عن شرٍّ، فقدم على عمر بعضُ أهله، فسأله حتى سأله عن الشابّ، فقال: لا تسألني عنه. قال: لِمَ؟ قال: إنّه فسد وخلع. فكتب إليه عمر: مِن عمر إلى فلان، <q>﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلَهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾</q>. فجعل يقترئها على نفسه، فأقبل بخير{18}. (١٣/١٢) ٦٧٨١٧- عن أبي إسحاق السَّبِيعي، قال: جاء رجلٌ إلى عمر بن الخطاب، فقال: يا أمير المؤمنين، إن قتلتُ فهل لي مِن توبة؟ فقرأ عليه: <q>﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ﴾</q>. وقال: اعمل ولا تيأس{19}. (١٣/١٢) ٦٧٨١٨- عن يزيد بن الأصم: أن رجلًا كان ذا بأس، وكان يُوفَد إلى عمر لبأسه، وكان مِن أهل الشام، وأن عمر فقَدَه، فسأل عنه، فقيل له: تتابع في هذا الشراب. فدعا عمرُ كاتبَه، فقال: اكتب: مِن عمر بن الخطاب إلى فلان بن فلان، سلام عليك، فإني أحمد إليك الله الذي لا إله إلا هو، <q>﴿غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلَهَ إلّا هُوَ إلَيْهِ المَصِر﴾</q>. ثم دعا، وأمَّن مَن عنده، فدعَوا له أن يُقبِل الله عليه بقلبه، وأن يتوب الله عليه. فلما أتَت الصحيفةُ الرجلَ جعل يقرؤها، ويقول: <q>﴿غافِرِ الذَّنْبِ﴾</q> قد وعدني اللهُ أن يغفر لي، <q>﴿وقابِلِ التَّوْبِ شَدِيدِ العِقابِ﴾</q> قد حذَّرني الله عقابه، <q>﴿ذِي الطَّوْلِ﴾</q> والطَّوْل: الخير الكثير، <q>﴿إلَيْهِ المَصِير﴾</q>. فلم يزل يردّدها على نفسه حتى بكى، ثم نزع فأحسن النزع. فلما بلغ عمرُ أمرَه قال: هكذا فاصنعوا، إذا رأيتم أخًا لكم زلَّ زلَّة فسدِّدوه ووفِّقوه، وادعوا الله له أن يتوب عليه، ولا تكونوا أعوانًا للشيطان عليه{20}. (١٣/١١) ",footnotes:1:أخرجه الطبراني في الأوسط (٩٤٨١). وعزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٨/٢٦٤، وتفسير البغوي ٧/١٣٨.أخرجه أبو الشيخ في العظمة (١٧٩).أخرجه الطبراني في الدعاء ٣/١٥١٣.تفسير مقاتل بن سليمان ٣/٧٠٥.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٥٥، والإتقان ٢/٤١-، وابن جرير ٢٠/٢٧٨، والبيهقي في الأسماء والصفات (٦٩). وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٨/٢٦٤، وتفسير البغوي ٧/١٣٨.أخرجه الطبراني في الأوسط (٩٤٨١). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٠/٢٧٨. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مجاهد ص٥٨٢.تفسير الثعلبي ٨/٢٦٤.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٥٥-. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ٨/٢٦٤، وتفسير البغوي ٦/١٣٨.أخرجه ابن جرير ٢٠/٢٧٩، وأخرجه ابن أبي حاتم -كما في فتح الباري ٨/٥٥٥- بلفظ: ذي النعماء. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير الثعلبي ٨/٢٦٤.تفسير مقاتل بن سليمان ٣/٧٠٥.أخرجه ابن جرير ٢٠/٢٧٨.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/٢٤٧ (٢٨٣٢١)، وابن جرير ٢٠/٢٧٧، وابن أبي حاتم -كما في تفسير ابن كثير ٧/١١٨- واللفظ له. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد بن حميد -كما في تفسير أحاديث الكشاف ٣/٢١٥-٢١٦-، وإسحاق البستي ص٢٧٦ بنحوه.
40,4," <q>﴿مَا یُجَـٰدِلُ فِیۤ ءَایَـٰتِ ٱللَّهِ إِلَّا ٱلَّذِینَ كَفَرُوا۟ فَلَا یَغۡرُرۡكَ تَقَلُّبُهُمۡ فِی ٱلۡبِلَـٰدِ ۝٤﴾</q> - نزول الآية، وتفسيرها ٦٧٨١٩- عن أبي مالك الغِفاري، في قوله: <q>﴿ما يُجادِلُ فِي آياتِ اللَّهِ إلّا الَّذِينَ كَفَرُوا﴾</q>: نزلت في الحارث بن قيس السهمي{1}. (١٣/١٤) ٦٧٨٢٠- عن قتادة بن دعامة، في قوله: <q>﴿فَلا يَغْرُرْكَ تَقَلُّبُهُمْ فِي البِلادِ﴾</q>، قال: فسادهم فيها، وكفرهم{2}. (١٣/١٥) ٦٧٨٢١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَلا يَغْرُرْكَ تَقَلُّبُهُمْ فِي البِلادِ﴾</q>، قال: إقبالهم، وإدبارهم، وتقلّبهم في أسفارهم{3}. (١٣/١٥) ٦٧٨٢٢- قال مقاتل بن سليمان: <q>﴿ما يُجادِلُ﴾</q> يعني: يُماري <q>﴿فِي آياتِ اللَّهِ﴾</q> يعني: آيات القرآن <q>﴿إلّا الَّذِينَ كَفَرُوا﴾</q> يعني: الحارث بن قيس السهمي، <q>﴿فَلا يَغْرُرْكَ﴾</q> يا محمد <q>﴿تَقَلُّبُهُمْ فِي البِلادِ﴾</q> يعني: كفار مكة. يقول: لا يغررك ما هم فيه مِن الخير، والسّعة من الرزق؛ فإنّه متاع قليل، مُمتَّعون به إلى آجالهم في الدنيا{4}٥٦٦٣. (ز) ٥٦٦٣ ذكر ابنُ عطية (٧/٤٢٢) أن قوله: <q>﴿فَلا يَغْرُرْكَ﴾</q> أنزله منزلة: فلا يحزنك ولا يهمنّك. لتدل الآية على أنهم ينبغي أن لا يغتروا بإملاء الله تعالى لهم، فالخطاب له ﷺ، والإشارة إلى مَن يقع منه الاغترار، ثم أورد احتمالًا آخر، فقال: «ويُحتمل أن يكون <q>﴿يَغْرُرْكَ﴾</q> بمعنى: تظن أن وراء تقلّبهم وإمهالهم خيرًا لهم، فتقول: عسى أن لا يُعذَّبوا». <q>﴿مَا یُجَـٰدِلُ فِیۤ ءَایَـٰتِ ٱللَّهِ إِلَّا ٱلَّذِینَ كَفَرُوا۟ فَلَا یَغۡرُرۡكَ تَقَلُّبُهُمۡ فِی ٱلۡبِلَـٰدِ ۝٤﴾</q> - آثار متعلقة بالآية ٦٧٨٢٣- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ جِدالًا في القرآن كفر»{5}. (١٣/١٤) ٦٧٨٢٤- عن أبي هريرة، قال: قال رسول الله ﷺ: «مِراءٌ في القرآن كفر»{6}. (١٣/١٥) ٦٧٨٢٥- عن أبي جُهَيْم، قال: اختلف رجلان مِن أصحاب النبيِّ ﷺ في آيةٍ، فقال أحدهما: تلقيتُها مِن في رسول الله ﷺ. وقال الآخر: أنا تلقّيتُها مِن في رسول الله ﷺ. فأتيا النبيَّ ﷺ، فذكرا ذلك له، فقال: «أُنزل القرآن على سبعة أحرف، وإياكم والمراءَ فيه؛ فإنّ المراء فيه كفر»{7}. (١٣/١٥) ٦٧٨٢٦- عن عمرو بن شعيب، عن أبيه، عن جده، قال: سمع رسولُ الله ﷺ قومًا يتمارون في القرآن، فقال: «إنّما هلك مَن كان قبلكم بهذا، ضربوا كتابَ الله ﷿ بعضه ببعض، وإنّما نزل كتابُ اللهِ يُصَدِّق بعضُه بعضًا، فلا تُكَذِّبوا بعضه ببعض، فما علمتم منه فقولوه، وما جهلتم منه فكِلوه إلى عالمه»{8}. (ز) ٦٧٨٢٧- عن أبي العالية الرِّياحي -من طريق الربيع بن أنس- قال: آيتان ما أشدهما على الذين يجادلون في القرآن: <q>﴿ما يُجادِلُ فِي آياتِ اللَّهِ إلّا الَّذِينَ كَفَرُوا﴾</q>، و<q>﴿وإنَّ الَّذِينَ اخْتَلَفُوا فِي الكِتابِ لَفِي شِقاقٍ بَعِيدٍ﴾</q> [البقرة:١٧٦]{9}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٠/٢٨٠، وعبد الرزاق ٢/١٧٨ من طريق معمر. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٥.أخرجه أحمد ١٢/٤٧٦ (٧٥٠٨)، ١٦/١٥٥ (١٠٢٠٢)، ١٦/٢٦٠ (١٠٤١٤)، والحاكم ٢/٢٤٣ (٢٨٨٣)، والثعلبي ٨/٢٦٥. قال الحاكم: «حديث المعتمر عن محمد بن عمرو صحيح، على شرط مسلم، ولم يخرجاه، فأمّا عمر بن أبي سلمة فإنهما لم يحتجا به». وقال المناوي في فيض القدير ٣/٣٥٥ (٣٦١٤): «وعمر هذا أورده الذهبي في الضعفاء، وقال: ضعّفه ابن معين. وقال النسائي: ليس بقوي».أخرجه أحمد ١٣/٢٤١ (٧٨٤٨)، ١٦/١٣٣ (١٠١٤٣)، ١٥/٢٨٨ (٩٤٧٩)، ١٦/٣١٨ (١٠٥٣٩)، وأبو داود ٧/١٢ (٤٦٠٣)، وابن حبان ٤/٣٢٤-٣٢٥ (١٤٦٤)، والحاكم ٢/٢٤٣ (٢٨٨٢). قال الحاكم: «تابعه عمر بن أبي سلمة، عن أبيه». وقال الذهبي في التلخيص: «على شرط مسلم».أخرجه أحمد ٢٩/٨٥ (١٧٥٤٢). قال الهيثمي في المجمع ٧/١٥١ (١١٥٧٣): «ورجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٦/٣٢٤-٣٢٥ (٥٩٣٧/٣): «هذا إسناد رجاله ثقات». وقال المناوي في التيسير ٢/٢٠٢: «وإسناده صحيح». وقال الألباني في الصحيحة ٤/٢٧: «وسنده صحيح، على شرط الشيخين».أخرجه أحمد ١١/٣٥٣-٣٥٤ (٦٧٤١)، من طريق عبد الرزاق، عن معمر، عن الزهري، عن عمرو بن شعيب، عن أبيه، عن جده به. إسناده حسن.أخرجه الثعلبي ٨/٢٦٥. وينظر: تفسير البغوي ٧/١٣٨.
40,5," <q>﴿كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ وَٱلۡأَحۡزَابُ مِنۢ بَعۡدِهِمۡۖ﴾</q> - تفسير ٦٧٨٢٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿والأَحْزابُ مِن بَعْدِهِمْ﴾</q>، قال: مِن بعد قوم نوح عاد وثمود وتلك القرون، كانوا أحزابًا على الكفر{1}. (١٣/١٥) ٦٧٨٢٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍ والأَحْزابُ مِن بَعْدِهِمْ﴾</q>، قال: الكُفّار{2}. (ز) ٦٧٨٣٠- قال مقاتل بن سليمان: <q>﴿كَذَّبَتْ قَبْلَهُمْ﴾</q> قبل أهل مكة <q>﴿قَوْمُ نُوحٍ﴾</q> رسولهم نوحًا ﵇ <q>﴿والأَحْزابُ﴾</q> يعني: الأمم الخالية رسلهم <q>﴿مِن بَعْدِهِمْ﴾</q> يعني: مِن بعد قوم نوح{3}. (ز) <q>﴿وَهَمَّتۡ كُلُّ أُمَّةِۭ بِرَسُولِهِمۡ لِیَأۡخُذُوهُۖ﴾</q> - تفسير ٦٧٨٣١- قال عبد الله بن عباس: <q>﴿وهَمَّتْ كُلُّ أُمَّةٍ بِرَسُولِهِمْ لِيَأْخُذُوه﴾</q> ليقتلوه ويُهلكوه{4}. (ز) ٦٧٨٣٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وهَمَّتْ كُلُّ أُمَّةٍ بِرَسُولِهِمْ لِيَأْخُذُوه﴾</q>: أي: ليقتلوه{5}. (١٣/١٥) ٦٧٨٣٣- قال مقاتل بن سليمان: <q>﴿وهَمَّتْ كُلُّ أُمَّةٍ بِرَسُولِهِمْ لِيَأْخُذُوه﴾</q>، يعني: ليقتلوه{3}. (ز) <q>﴿وَجَـٰدَلُوا۟ بِٱلۡبَـٰطِلِ لِیُدۡحِضُوا۟ بِهِ ٱلۡحَقَّ فَأَخَذۡتُهُمۡۖ فَكَیۡفَ كَانَ عِقَابِ ۝٥﴾</q> - تفسير ٦٧٨٣٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَأَخَذْتُهُمْ فَكَيْفَ كانَ عِقابِ﴾</q>، قال: شديدٌ، واللهِ{7}. (١٣/١٥) ٦٧٨٣٥- قال مقاتل بن سليمان: <q>﴿وجادَلُوا﴾</q> يعني: وخاصموا رسلَهم <q>﴿بِالباطِلِ لِيُدْحِضُوا بِهِ الحَقَّ﴾</q> يعني: لِيُبطلوا به الحقَّ الذي جاءت به الرسلُ، وجدالهم أنهم قالوا لرسلهم: ما أنتم إلا بشر مثلنا، وما نحن إلا بشر مثلكم، ألا أرسل الله ملائكة! فهذا جدالهم كما قالوا للنبي ﷺ، <q>﴿فَأَخَذْتُهُمْ﴾</q> بالعذاب، <q>﴿فَكَيْفَ كانَ عِقابِ﴾</q> يعني: عقابي، أليس وجدوه حقًّا؟{3}. (ز) <q>﴿وَجَـٰدَلُوا۟ بِٱلۡبَـٰطِلِ لِیُدۡحِضُوا۟ بِهِ ٱلۡحَقَّ فَأَخَذۡتُهُمۡۖ فَكَیۡفَ كَانَ عِقَابِ ۝٥﴾</q> - آثار متعلقة بالآية ٦٧٨٣٦- عن عبد الله بن عباس، عن النبي ﷺ، قال: «مَن أعان باطِلًا لِيُدحِض بباطله حقًّا فقد برئت منه ذِمَّةُ الله، وذِمَّةُ رسوله»{9}. (١٣/١٦) ",footnotes:1:أخرجه عبد الرزاق ٢/١٧٨. وعزاه السيوطي إلى عبد بن حُمَيد، وابن جرير.أخرجه ابن جرير ٢٠/٢٨٠.تفسير مقاتل بن سليمان ٣/٧٠٥-٧٠٦.تفسير البغوي ٧/١٣٩.أخرجه ابن جرير ٢٠/٢٨١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٥-٧٠٦.أخرجه ابن جرير ٢٠/٢٨٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٥-٧٠٦.أخرجه الحاكم ٤/١١٢ (٧٠٥٢)، وفيه حنش الرحبي. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وتعقّبه الذهبي في التلخيص بقوله: «حنش الرحبي ضعيف». قال ابن القيسراني في تذكرة الحفاظ ص٣٠٣ (٧٦٠): «الحديث منكر». وقال الهيثمي في المجمع ٤/٢٠٥ (٧٠٦٣): «رواه الطبراني في الثلاثة، وفي إسناد الكبير: حنش، وهو متروك، وزعم أبو محصن أنه شيخ صدق، وفي إسناد الصغير والأوسط: سعيد بن رحمة، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٧/٣٨٤ (٧١٣٤): «رواه مسدّد، والطبراني، والأصبهاني، ومدار أسانيدهم على حسين بن قيس، المعروف بحنش، وهو ضعيف». وأورده الألباني في الصحيحة ٣/١٧ (١٠٢٠).
40,6," <q>﴿وَكَذَ ٰ⁠لِكَ حَقَّتۡ كَلِمَتُ رَبِّكَ عَلَى ٱلَّذِینَ كَفَرُوۤا۟ أَنَّهُمۡ أَصۡحَـٰبُ ٱلنَّارِ ۝٦﴾</q> - قراءات ٦٧٨٣٧- عن النضر، عن هارون، عن الحسن البصري= (ز) ٦٧٨٣٨- وأبي عمرو: <q>﴿وكذلك حقَّتْ كَلمت ربك﴾</q>= (ز) ٦٧٨٣٩- والأعرج: ‹كَلِماتُ رَبِّكَ›{1}. (ز) <q>﴿وَكَذَ ٰ⁠لِكَ حَقَّتۡ كَلِمَتُ رَبِّكَ عَلَى ٱلَّذِینَ كَفَرُوۤا۟ أَنَّهُمۡ أَصۡحَـٰبُ ٱلنَّارِ ۝٦﴾</q> - تفسير الآية ٦٧٨٤٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وكَذَلِكَ حَقَّتْ كَلِمَتُ رَبِّكَ عَلى الَّذِينَ كَفَرُوا﴾</q>، قال: حقَّ عليهم العذابُ بأعمالهم{2}. (١٣/١٥) ٦٧٨٤١- قال مقاتل بن سليمان: <q>﴿وكَذَلِكَ﴾</q> يعني: وهكذا عذَّبتُهم، <q>﴿وكَذَلِكَ حَقَّتْ كَلِمَتُ رَبِّكَ﴾</q> يقول: وجبت كلمة العذاب مِن ربك <q>﴿عَلى الَّذِينَ كَفَرُوا أنَّهُمْ أصْحابُ النّارِ﴾</q> حين قال لإبليس: <q>﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّنْ تَبِعَكَ مِنهُمْ أجْمَعِينَ﴾</q> [ص:٨٥]{3}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٢٧٧. و‹كَلِماتُ› بالجمع قراءة متواترة، قرأ بها نافع، وأبو جعفر، وابن عامر، وقرأ بقية العشرة: <q>﴿كَلِمَتُ﴾</q> على الإفراد. انظر: الإتحاف ص٤٨٤.أخرجه عبد الرزاق ٢/١٧٨. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٦.
40,7," <q>﴿ٱلَّذِینَ یَحۡمِلُونَ ٱلۡعَرۡشَ وَمَنۡ حَوۡلَهُۥ﴾</q> - قراءات ٦٧٨٤٢- عن قتادة بن دعامة، قال: في بعض القراءة: (الَّذِينَ يَحْمِلُونَ العَرْشَ والَّذِينَ حَوْلَهُ المَلَآئِكَةُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ){1}. (١٣/٢١) <q>﴿ٱلَّذِینَ یَحۡمِلُونَ ٱلۡعَرۡشَ وَمَنۡ حَوۡلَهُۥ﴾</q> - تفسير الآية ٦٧٨٤٣- قال مقاتل بن سليمان: <q>﴿الَّذِينَ يَحْمِلُونَ العَرْشَ﴾</q> فيها إضمار، وهم أول مَن خلَق الله تعالى مِن الملائكة، وذلك أن الله -تبارك وتعالى- قال: <q>﴿والمَلائِكَةُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ ويَسْتَغْفِرُونَ لِمَن فِي الأَرْضِ﴾</q> [الشورى:٥]، فاختصّ في «حم المؤمن» من الملائكة حملة العرش، <q>﴿ومَن حَوْلَهُ﴾</q> يقول: ومَن حول العرش مِن الملائكة، اختصّ استغفارُ الملائكة بالمؤمنين من أهل الأرض، فقال: <q>﴿الَّذِينَ يَحْمِلُونَ العَرْشَ ومَن حَوْلَهُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</q>{2}. (ز) <q>﴿ٱلَّذِینَ یَحۡمِلُونَ ٱلۡعَرۡشَ وَمَنۡ حَوۡلَهُۥ﴾</q> - آثار متعلقة بالآية ٦٧٨٤٤- عن عبد الله بن عباس: أنّ رسول الله ﷺ خرج على أصحابه، فقال: «ما جمَعَكم؟». قالوا: اجتمعنا نذكر ربَّنا، ونتفكر في عظمته. فقال: «لن تُدركوا التفكّر في عظمته، ألا أخبركم ببعض عظمة ربكم!». قيل: بلى، يا رسول الله. قال: «إنَّ مَلكًا مِن حَمَلة العرش يُقال له: إسرافيل، زاوِية مِن زوايا العرش على كاهله، قد مَرَقَتْ قدماه في الأرض السابعة السفلى، ومَرَقَ رأسُه مِن السماء السابعة العليا، في مِثله مِن خليقة ربكم تعالى»{3}. (١٣/٢١) ٦٧٨٤٥- عن جابر، أنّ النبيَّ ﷺ قال: «أُذِن لي أن أُحدِّث عن مَلَك مِن ملائكة الله مِن حَمَلة العرش، ما بين شحْمة أُذنه إلى عاتقه مسيرة سبعمائة سنة»{4}. (١٣/١٧) ٦٧٨٤٦- عن أم سعد، قالت: سمعتُ النبيَّ ﷺ يقول: «العرش على ملَك مِن لؤلؤة على صورة ديك، رِجلاه في تُخُوم الأرض، وجناحاه في المشرق، وعُنقه تحت العرش»{5}. (١٣/١٩) ٦٧٨٤٧- عن مكحول، قال: قال رسول الله ﷺ: «إنّ في حَمَلة العرش أربعة أملاك، مَلك على صورة سيِّد الصُّوَر، وهو ابن آدم، ومَلك على صورة سيّد السِّباع، وهو الأسد، ومَلك على صورة سيّد الأنعام، وهو الثَّور، فما زال غضبان مُذ يوم العِجل إلى ساعتي هذه، ومَلك على صورة سيّد الطير، وهو النّسر»{6}. (١٣/١٩) ٦٧٨٤٨- عن عبد الله بن عباس، قال: حَمَلة العرش ما بين كَعْبِ أحدهم إلى أسفل قدميه مسيرة خمسمائة عام، وذُكر: أنّ خُطْوة ملك الموت ما بين المشرق والمغرب{7}. (١٣/٢٠) ٦٧٨٤٩- عن عبد الله بن عمر -من طريق أبي قبيل- يقول: حَمَلةُ العرش ثمانية، ما بين مُؤق أحدهم إلى مُؤخّر عينيه مسيرة خمسمائة عام{8}. (١٣/١٨) ٦٧٨٥٠- عن عُروة بن الزبير، قال: حَمَلة العرش منهم مَن صورتُه صورةُ الإنسان، ومنهم مَن صورتُه صورة النّسر، ومنهم مَن صورته صورة الثَّور، ومنهم مَن صورته صورة الأسد{9}. (١٣/٢٠) ٦٧٨٥١- عن وهْب بن مُنَبِّه -من طريق عبد الصمد- قال: حَمَلة العرش الذي يحملونه، لكل مَلك منهم أربعة وجوه، وأربعة أجنحة، جناحان على وجهه مِن أن ينظر إلى العرش فيَصعق، وجناحان يطير بهما، أقدامهم في الثَّرى، والعرش على أكتافهم، لكل واحد منهم وجه ثَور، ووجه أسد، ووجه إنسان، ووجه نسر، ليس لهم كلام إلا أن يقولوا: قُدّوس، الله القوي، ملأت عظمته السموات والأرض{10}. (١٣/١٨) ٦٧٨٥٢- عن وهْب بن مُنَبِّه -من طريق عبد المنعم بن إدريس، عن أبيه- قال: حَمَلة العرش اليوم أربعة، فإذا كان يوم القيامة أُيِّدوا بأربعة آخرين، مَلك منهم في صورة إنسان يشفع لبني آدم في أرزاقهم، ومَلك منهم في صورة نِسر يشفع للطير في أرزاقهم، ومَلك منهم في صورة ثَور يشفع للبهائم في أرزاقهم، ومَلَك في صورة أسد يشفع للسباع في أرزاقها، فلما حملوا العرش وقعوا على رُكَبهم مِن عظمة الله، فلُقِّنوا: لا حول ولا قوة إلا بالله. فاستَوَوا قيامًا على أرجلهم{11}. (١٣/١٨) <q>﴿یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡ﴾</q> - تفسير ٦٧٨٥٣- قال مقاتل بن سليمان: <q>﴿يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ﴾</q>، يقول: يذكرون الله بأمره، ويؤمنون به، ويصدِّقون بالله ﷿ بأنّه واحد لا شريك له{2}. (ز) <q>﴿یُسَبِّحُونَ بِحَمۡدِ رَبِّهِمۡ﴾</q> - آثار متعلقة بالآية ٦٧٨٥٤- عن أبي هريرة، قال: قال رسول الله ﷺ: «أُذِن لي أن أُحَدِّث عن مَلَك قد مَرَقَتْ رِجلاه الأرضَ السابعة، والعرش على مَنكِبه، وهو يقول: سبحانك أين كنت وأين تكون»{13}. (١٣/١٦) ٦٧٨٥٥- عن جعفر، قال: سمعتُ يزيدًا يقول: قال رجل لابن عباس: لا إله الا الله، نعرف أنّ الله هو أكبر من كل شيء، والحمد لله، نعرف أنّ الحمد لله، فما سبحان الله؟ قال ابن عباس: وما تنكر منها؟! هي كلمة وضعها الله لنفسه، وأمر ملائكته به، وفزّع إليه الأخيار من خلقه{14}. (ز) ٦٧٨٥٦- عن شَهْر بن حَوْشَب -من طريق هارون بن رِئاب- قال: حملة العرش ثمانية، فأربعة منهم يقولون: سبحانك اللهم وبحمدك، لك الحمد على حِلمك بعد علمك. وأربعة منهم يقولون: سبحانك اللهم وبحمدك، لك الحمد على عفوك بعد قدرتك. قال: وكأنهم ينظرون ذنوب بني آدم{15}. (ز) ٦٧٨٥٧- عن هارون بن رِئاب -من طريق الأوزاعي- قال: حَمَلة العرش ثمانية، يتجاوبون بصوت رخيم، يقول أربعة منهم: سبحانك وبحمدك على على حِلمك بعد علمك. وأربعة منهم يقولون: سبحانك وبحمدك، عفوك بعد قدرتك{16}. (١٣/١٧) <q>﴿وَیَسۡتَغۡفِرُونَ لِلَّذِینَ ءَامَنُوا۟ۖ﴾</q> - تفسير ٦٧٨٥٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</q>: لأهل لا إله إلا الله{17}. (ز) ٦٧٨٥٩- قال مقاتل بن سليمان: <q>﴿ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</q> حين قالوا: <q>﴿فاغْفِرْ لِلَّذِينَ تابُوا﴾</q>{2}. (ز) <q>﴿وَیَسۡتَغۡفِرُونَ لِلَّذِینَ ءَامَنُوا۟ۖ﴾</q> - آثار متعلقة بالآية ٦٧٨٦٠- عن قتادة: <q>﴿ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</q>، قال مُطَرِّف بن عبد الله بن الشِّخِّير: وجدنا أنصحَ عبادِ الله لعباده الملائكة، ووجدنا أغشَّ عبادِ الله لعبادِ الله الشياطين{19}. (١٣/٢١) ٦٧٨٦١- ذكر يحيى بن عمر بن شداد التيمي مولى لبني تيم بن مرة قال: قال لي سفيان بن عُيْينة ...: أبْشِر، فإنك على خير، تدري مَن دعا لك؟ قال: قلتُ: ومَن دعا لي؟ قال: دعا لك حَمَلةُ العرش. قال: قلتُ: دعا لي حَمَلةُ العرش! قال: نعم، ودعا لك نبيُّ الله نوح ﵇. قال: قلتُ: دعا لي حَمَلة العرش، ودعا لي نوح! قال: نعم، ودعا لك خليل الله إبراهيم. قال: قلتُ: دعا لي هؤلاء كلهم؟ قال: نعم، ودعا لك محمد. قال: قلتُ: وأين دعا لي هؤلاء؟ قال: في كتاب الله، أما سمعت قوله: <q>﴿الَّذِينَ يَحْمِلُونَ العَرْشَ ومَن حَوْلَهُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ ويُؤْمِنُونَ بِهِ ويَسْتَغْفِرُونَ لِلَّذِينَ آمَنُوا﴾</q> ...{20}. (ز) <q>﴿رَبَّنَا وَسِعۡتَ كُلَّ شَیۡءࣲ رَّحۡمَةࣰ وَعِلۡمࣰا﴾</q> - تفسير ٦٧٨٦٢- قال مقاتل بن سليمان: قالت الملائكة: <q>﴿رَبَّنا وسِعْتَ كُلَّ شَيْءٍ﴾</q> يعني: ملأتَ كل شيء من الحيوان في السموات والأرض <q>﴿رَحْمَةً﴾</q> يعني: نعمة يتقلَّبون فيها، <q>﴿وعِلْمًا﴾</q> يقول: علم مَن فيهما مِن الخلْق{21}. (ز) <q>﴿فَٱغۡفِرۡ لِلَّذِینَ تَابُوا۟﴾</q> - تفسير ٦٧٨٦٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فاغْفِرْ لِلَّذِينَ تابُوا﴾</q>، قال: تابوا من الشرك{22}. (١٣/٢١) ٦٧٨٦٤- قال مقاتل بن سليمان: <q>﴿فاغْفِرْ لِلَّذِينَ تابُوا﴾</q> من الشرك{23}. (ز) <q>﴿وَٱتَّبَعُوا۟ سَبِیلَكَ وَقِهِمۡ عَذَابَ ٱلۡجَحِیمِ ۝٧﴾</q> - تفسير ٦٧٨٦٥- عن قتادة بن دعامة، في قوله: <q>﴿واتَّبَعُوا سَبِيلَكَ﴾</q>، قال: طاعتك{24}. (١٣/٢١) ٦٧٨٦٦- قال مقاتل بن سليمان: <q>﴿واتَّبَعُوا سَبِيلَكَ﴾</q> يعني: دينك، <q>﴿وقِهِمْ عَذابَ الجَحِيمِ﴾</q>{23}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حُمَيد. وهي قراءة شاذة.تفسير مقاتل بن سليمان ٣/٧٠٦.أخرجه أبو الشيخ في العظمة ٢/٦٩٧-٦٩٨، وأبو نعيم في الحلية ٦/٦٥-٦٦. وأورد الثعلبي ٨/٢٦٦ نحوه. قال أبو نعيم: «تفرّد به إسماعيل بن عيّاش، عن الأحوص، عن شهر بن حوشب، عن ابن عباس، ورواه عبد الجليل بن عطية، عن شهر، عن عبد الله بن سلام».أخرجه أبو داود ٧/١٠٩ (٤٧٢٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢١٢-. وأورده الثعلبي ٨/٢٦٦. قال ابن كثير: «وهذا إسناد جيد، رجاله ثقات». وقال الهيثمي في المجمع ١/٨٠ (٢٥٦): «رواه الطبراني في الأوسط، ورجاله رجال الصحيح». وقال ابن حجر في الفتح ٨/٦٦٥: «إسناده على شرط الصحيح». وقال السيوطي: «بسند صحيح». وأورده الألباني في الصحيحة ١/٢٨٢ (١٥١).أخرجه ابن أبي شيبة في العرش وما روي فيه ص٤٤٩-٤٥٠ (٦٨). وعزاه السيوطي إلى ابن مردويه.أخرجه أبو الشيخ (٣٤٠) مرسلًا.أخرجه البيهقي في الأسماء والصفات (٨٤٨). وعزاه السيوطي إلى عبد بن حُمَيد، وابن مردويه.أخرجه أبو الشيخ (٤٨٠). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في الأسماء والصفات عقب الأثر (٨٤٨).أخرجه أبو الشيخ (٢٣١).أخرجه أبو الشيخ (٤٨٥).تفسير مقاتل بن سليمان ٣/٧٠٦.أخرجه أبو يعلى ١١/٤٩٦ (٦٦١٩). وعزاه السيوطي إلى ابن مردويه. قال الهيثمي في المجمع ١/٨٠ (٢٥٧)، ٨/١٣٥ (١٣٣٨١): «ورجاله رجال الصحيح». وقال السيوطي: «بسند صحيح».أخرجه إسحاق البستي ص٢٧٦.أخرجه البغوي ٦/١٤١.أخرجه أبو الشيخ (٤٨٣)، والبيهقي في شعب الإيمان (٣٦٤). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٢٨٣.تفسير مقاتل بن سليمان ٣/٧٠٦.أخرجه عبد الرزاق ٢/١٧٨، وابن جرير ٢٠/٢٨٧. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن أبي الدنيا في كتاب حُسن الظنّ بالله -موسوعة الإمام ابن أبي الدنيا ١/٩٠-٩١ (٧٩)-، وأبو نعيم في حلية الأولياء ١/٧٧-٧٨.تفسير مقاتل بن سليمان ٣/٧٠٦-٧٠٧.أخرجه عبد الرزاق ٢/١٧٨ من طريق معمر، وابن جرير ٢٠/٢٨٤. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٧.أخرجه عبد الرزاق ٢/١٧٨ من طريق معمر، وابن جرير ٢٠/٢٨٥. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٠٧.
