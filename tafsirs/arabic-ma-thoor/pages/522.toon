quran[21]{c,v,t}:
51,31," <q>﴿قَالَ فَمَا خَطۡبُكُمۡ أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٣١ قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٣٢﴾</q> - تفسير ٧٢٦٤٠- قال مقاتل بن سليمان: <q>﴿قالَ فَما خَطْبُكُمْ﴾</q> يعني: ما أمركم <q>﴿أيُّها المُرْسَلُونَ قالُوا﴾</q> قال جبريل: <q>﴿إنّا أُرْسِلْنا إلى قَوْمٍ مُجْرِمِينَ﴾</q> يعني: كفارًا ظَلمةً، يعنون: قوم لوط{1}٦٢٠٢. (ز) ٦٢٠٢ نقل ابنُ عطية (٨/٧٥) في معنى «الخَطْب» قولًا، ولم ينسبه أنه «إنما يُعبَّر به عن الشدائد والمكاره حتى قالوا: خطوب الزمان. وغير ذلك». ووجَّهه بقوله: «وكأنّه يقول: ما هذه الطامة التي جئتم لها؟». ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣١.
  51,32,""
51,33," <q>﴿لِنُرۡسِلَ عَلَیۡهِمۡ حِجَارَةࣰ مِّن طِینࣲ ۝٣٣﴾</q> - تفسير ٧٢٦٤١- قال محمد بن السّائِب الكلبي: <q>﴿حِجارَةً مِن طِينٍ﴾</q> مِن سَنك وكل{1}٦٢٠٣. (ز) ٦٢٠٣ نقل ابنُ عطية (٨/٧٥) رواية ولم ينسبها «أنه طين طُبخ في نار جهنم حتى صار حجارة كالآجُرِّ». ٧٢٦٤٢- قال مقاتل بن سليمان: <q>﴿لِنُرْسِلَ﴾</q> يعني: لكي نُرسل <q>﴿عَلَيْهِمْ حِجارَةً مِن طِينٍ﴾</q> خلطة الحجارة، الطين مُلْزقٌ بالحجر{2}. (ز) ",footnotes:1:تفسير الثعلبي ٩/١١٧، وأورد عقبه: وهو الحجر والطين بالفارسية، بيانه قوله: <q>﴿من سجيل﴾</q>.تفسير مقاتل بن سليمان ٤/١٣١.
51,34," <q>﴿مُّسَوَّمَةً عِندَ رَبِّكَ لِلۡمُسۡرِفِینَ ۝٣٤﴾</q> - تفسير ٧٢٦٤٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿مسومة﴾</q>، قال: مُعلَّمة{1}. (ز) ٧٢٦٤٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</q>، قال: المُسوّمة: الحجارة المَختومة؛ يكون الحَجر أبيض فيه نقطة سوداء، أو يكون الحَجر أسود فيه نقطة بيضاء، فذلك تسويمها، <q>﴿عِنْدَ رَبِّكَ﴾</q> يا إبراهيم <q>﴿للمُسرفين﴾</q> يعني: للمُتعدِّين حدود الله، الكافرين به من قوم لوط{2}. (ز) ٧٢٦٤٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مُسَوَّمَةً﴾</q>: يعني: مُعلَّمة{3}. (ز) ٧٢٦٤٦- قال مقاتل بن سليمان: <q>﴿مُسَوَّمَةً﴾</q> يعني: مُعلَّمة <q>﴿عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</q> يعني: المشركين، والشِّرك أسرف الذنوب وأعظمها{4}٦٢٠٤. (ز) ٦٢٠٤ ذكر ابنُ عطية (٨/٧٥) في قوله: <q>﴿مسومة﴾</q> عدة أقوال، فقال: «و<q>﴿مسومة﴾</q> قيل: معناه: متروكة، وسومها من الإهلاك والانصباب. وقيل: معناه: مُعلَّمة بعلامتها مِن السيما والسومى، وهي العلامة، أي: أنها ليست مِن حجارة الدنيا. وقيل: معناه: على كل حجر اسم المضروب به. وقيل: كان عليها أمثال الخواتم. وقال ابن عباس: تسويمها إن كان في الحجارة السُّود نُقطٌ بِيض وفي البِيض سُودٌ». ثم قال معلّقًا: «ويحتمل أن يكون المعنى: أنها بجملتها معلومة عند ربك لهذا المعنى مُعلّمة له، لا أنّ كلّ واحد منها له علامة خاصة به». ",footnotes:1:أخرجه ابن المنذر -كما في الفتح ٨/٦٠١-.أخرجه ابن جرير ٢١/٥٣٢ وجاء عقبه مضمومًا إليه: <q>﴿فَأَخْرَجْنا مَن كانَ فِيها مِنَ المُؤْمِنِينَ﴾</q> يقول تعالى ذكره: فأخرجنا مَن كان في قرية سدوم -قرية قوم لوط- من أهل الإيمان بالله، وهم لوط وابنتاه، وكنّى عن القرية بقوله: <q>﴿مَن كانَ فِيها﴾</q> ولم يجر لها ذلك قبل ذلك. والأظهر أنّ هذا كلام ابن جرير وليس تتمة تفسير ابن عباس.تفسير مجاهد ص٦٢٠.تفسير مقاتل بن سليمان ٤/١٣١.
51,35," <q>﴿فَأَخۡرَجۡنَا مَن كَانَ فِیهَا مِنَ ٱلۡمُؤۡمِنِینَ ۝٣٥ فَمَا وَجَدۡنَا فِیهَا غَیۡرَ بَیۡتࣲ مِّنَ ٱلۡمُسۡلِمِینَ ۝٣٦﴾</q> - تفسير ٧٢٦٤٧- عن سعيد بن جُبَير، قال: كانوا ثلاثة عشر{1}. (١٣/٦٨٢) ٧٢٦٤٨- عن مجاهد بن جبر، في قوله: <q>﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</q>، قال: لوط وابنتيه{2}. (١٣/٦٨١) ٧٢٦٤٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</q>، قال: لو كان فيها أكثر من ذلك لنجّاهم الله؛ ليعلموا أنّ الإيمان عند الله محفوظ، لا ضَيعة على أهله{3}. (١٣/٦٨٢) ٧٢٦٥٠- قال مقاتل بن سليمان: <q>﴿فَأَخْرَجْنا مَن كانَ فِيها﴾</q> يعني: في قرية لوط <q>﴿مِنَ المُؤْمِنِينَ﴾</q> يعني: المُصَدِّقين بتوحيد الله تعالى، <q>﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</q> يعني: المُخلصين، فهو لوط وابنتيه ريثا الكُبرى، وزُعوتا الصُّغرى{4}. (ز) ٧٢٦٥١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</q>، قال: هؤلاء قوم لوط، لم يجدوا فيها غير لوط{5}. (ز) ٧٢٦٥٢- عن أبي المثنى= (ز) ٧٢٦٥٣- ومسلم أبي حسبة الأشجعي -من طريق صفوان- قال الله: <q>﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</q> لوطًا وابنتيه. قال: فحَلّ بهم العذاب. قال الله: <q>﴿وتَرَكْنا فِيها آيَةً لِلَّذِينَ يَخافُونَ العَذابَ الأَلِيمَ﴾</q>{5}. (ز) <q>﴿فَأَخۡرَجۡنَا مَن كَانَ فِیهَا مِنَ ٱلۡمُؤۡمِنِینَ ۝٣٥ فَمَا وَجَدۡنَا فِیهَا غَیۡرَ بَیۡتࣲ مِّنَ ٱلۡمُسۡلِمِینَ ۝٣٦﴾</q> - آثار متعلقة بالآية ٧٢٦٥٤- عن عبد الله بن أبي زكريا، قال: ما من أُمّة يكون فيهم خمسة عشر رجلًا يستغفرون الله في كل يوم خمسًا وعشرين مرّة فتُعذَّب تلك الأُمَّة، واقرأوا إن شئتم: <q>﴿فأخرجنا من كان فيها من المؤمنين فما وجدنا فيها غير بيت من المسلمين﴾</q>{7}. (ز) ٧٢٦٥٥- عن سفيان الثوري -من طريق أيوب بن سُويد- قال: الإسلام والإيمان سواء ثم قرأ: <q>﴿فأخرجنا من كان فيها من المؤمنين فما وجدنا فيها غير بيت من المسلمين﴾</q>{8}٦٢٠٥. (ز) ٦٢٠٥ ذكر ابن كثير (١٣/٢١٩) نحو ما جاء في قول الثوري، وعلّق فقال: «احتجّ بهذه الآية مَن ذهب إلى رأي المعتزلة، ممن لا يفرّق بين مسمّى الإيمان والإسلام؛ لأنه أطلق عليهم المؤمنين والمسلمين. وهذا الاستدلال ضعيف؛ لأن هؤلاء كانوا قومًا مؤمنين، وعندنا أنّ كلّ مؤمن مسلم لا ينعكس، فاتفق الاسمان هاهنا لخصوصية الحال، ولا يلزم ذلك في كل حال». وبنحوه ابنُ تيمية (٦/١٠٤-١٠٥)، حيث نقل هذا عن الخطابي، وقال: «والذي اختاره الخطابي هو قول مَن فرَّق بينهما كأبي جعفر، وحمّاد بن زيد، وعبد الرحمن بن مهدي، وهو قول أحمد بن حنبل وغيره، ولا علمتُ أحدًا من المتقدّمين خالف هؤلاء فجعل نفس الإسلام نفس الإيمان؛ ولهذا كان عامّة أهل السنة على هذا الذي قاله هؤلاء. كما ذكره الخطابي». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢١/٥٣٢-٥٣٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/١٣١.أخرجه ابن جرير ٢١/٥٣٣.أخرجه ابن جرير ٢١/٥٣٣.أخرجه أبو نعيم في حلية الأولياء ٥/١٤٩.أخرجه أبو نعيم في حلية الأولياء ٧/٣٤.
  51,36,""
51,37," <q>﴿وَتَرَكۡنَا فِیهَاۤ ءَایَةࣰ لِّلَّذِینَ یَخَافُونَ ٱلۡعَذَابَ ٱلۡأَلِیمَ ۝٣٧﴾</q> - تفسير ٧٢٦٥٦- عن أبي العالية الرِّياحي -من طريق الربيع- <q>﴿العَذابَ الأَلِيمَ﴾</q>، قال: المُوجِع{1}. (ز) ٧٢٦٥٧- قال مقاتل بن سليمان: <q>﴿وتَرَكْنا فِيها آيَةً﴾</q> يعني: عِبرة لِمَن بعدهم <q>﴿لِلَّذِينَ يَخافُونَ العَذابَ الأَلِيمَ﴾</q> يعني: الوجيع، نظيرها في هود{2}{3}٦٢٠٦. (ز) ٦٢٠٦ ذكر ابن عطية (٨/٧٦) في معنى الآية احتمالين، فقال: «المعنى: وتركنا في القرية المذكورة، وهي سدوم أثرًا من العذاب باقيًا مؤرخًا لا يفنى ذكره فهو آية، أي علامة على قدرة الله وانتقامه من الكفرة. ويحتمل أن يكون المعنى: وتركنا في أمرها. كما قال: <q>﴿لقد كان في يوسف﴾</q> [يوسف:٧]». ٧٢٦٥٨- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وتَرَكْنا فِيها آيَةً﴾</q>، قال: ترك فيها صخرًا منضودًا {4}. (١٣/٦٨٢) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٠-.لعل مراد مقاتل الآية قبل السابقة، وهي قوله تعالى: <q>﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</q>، ونظيرها في سورة هود [٨٢-٨٣]: <q>﴿وأَمْطَرْنا عَلَيْها حِجارَةً مِن سِجِّيلٍ مَنضُودٍ مُسَوَّمَةً عِنْدَ رَبِّكَ﴾</q>.تفسير مقاتل بن سليمان ٤/١٣١.عزاه السيوطي إلى ابن المنذر.
51,38," <q>﴿وَفِی مُوسَىٰۤ إِذۡ أَرۡسَلۡنَـٰهُ إِلَىٰ فِرۡعَوۡنَ بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٣٨﴾</q> - تفسير ٧٢٦٥٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إلى فِرْعَوْنَ بِسُلْطانٍ مُبِينٍ﴾</q>، يقول: بعُذرٍ مُبين{1}. (ز) ٧٢٦٦٠- قال مقاتل بن سليمان: <q>﴿وفِي مُوسى إذْ أرْسَلْناهُ إلى فِرْعَوْنَ بِسُلْطانٍ مُبِينٍ﴾</q>، يعني: بحُجّةٍ بيّنةٍ واضحةٍ، وهي: اليد والعصا{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٥٣٤تفسير مقاتل بن سليمان ٤/١٣١.
51,39," <q>﴿فَتَوَلَّىٰ بِرُكۡنِهِۦ وَقَالَ سَـٰحِرٌ أَوۡ مَجۡنُونࣱ ۝٣٩﴾</q> - تفسير ٧٢٦٦١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q>، قال: بقومه{1}. (١٣/٦٨٢) ٧٢٦٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q>، قال: بعَضُده وأصحابه{2}. (١٣/٦٨٢) ٧٢٦٦٣- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q>، قال: بقومه{3}. (ز) ٧٢٦٦٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q>: غلب عدوُّ الله على قومه{4}. (ز) ٧٢٦٦٥- قال محمد بن السّائِب الكلبي: <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q> بجنوده، <q>﴿وقالَ ساحِرٌ أوْ مَجْنُونٌ﴾</q> موسى{5}. (ز) ٧٢٦٦٦- قال مقاتل بن سليمان: <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q> يعني: فأعرض فرعونُ عن الحقّ بمَيْله، يعني: عن الإيمان حين قال: <q>﴿ما أُرِيكُمْ إلّا ما أرى وما أهْدِيكُمْ إلّا سَبِيلَ الرَّشادِ﴾</q> [غافر:٢٩]، <q>﴿وقالَ﴾</q> فرعون لموسى ﵇: هو <q>﴿ساحِرٌ أوْ مَجْنُونٌ﴾</q>{6}. (ز) ٧٢٦٦٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله -تبارك وتعالى-: <q>﴿فَتَوَلّى بِرُكْنِهِ﴾</q>، قال: بجُموعه التي معه. وقرأ: <q>﴿قالَ لَوْ أنَّ لِي بِكُمْ قُوَّةً أوْ آوِي إلى رُكْنٍ شَدِيدٍ﴾</q> [هود:٨٠]، قال: إلى قوةٍ من الناس؛ إلى رُكنٍ أجاهدكم به. قال: وفرعون وجنوده ومَن معه رُكنه. قال: وما كان مع لوط مؤمن واحد. قال: وعرض عليهم أن يُنكحهم بناته؛ رجاء أن يكون له منهم عَضُدٌ يُعينه، أو يدفع عنه. وقرأ: <q>﴿هَؤُلاءِ بَناتِي هُنَّ أطْهَرُ لَكُمْ﴾</q> [هود:٧٨]، قال: يريد النكاح، فأَبَوا عليه. وقرأ قول الله -تبارك وتعالى-: <q>﴿لَقَدْ عَلِمْتَ ما لَنا فِي بَناتِكَ مِن حَقٍّ وإنَّكَ لَتَعْلَمُ ما نُرِيدُ﴾</q> [هود:٧٩]. أصل الرُّكن: الجانب والناحية التي يَعتَمِد عليها، ويَقْوى بها{4}٦٢٠٧. (ز) ٦٢٠٧ قال ابنُ جرير (٢١/٥٣٤-٥٣٥): «وقوله: <q>﴿فتولى بركنه﴾</q> يقول: فأدبر فرعونُ كما أرسلنا إليه موسى بقومه مِن جنده وأصحابه، وبنحو الذي قلنا في ذلك قال أهل التأويل وإن اختلفت ألفاظ قائليه فيه». ثم ذكر قول ابن عباس، ومجاهد، وقتادة، وابن زيد. وبيّن ابنُ كثير (١٣/٢٢٠ بتصرف) أنّ قوله: <q>﴿تولى بركنه﴾</q> معناه: «أي: فأعرض فرعونُ عمّا جاءه به موسى مِن الحقّ المُبين استكبارًا». ورجّحه -مستندًا إلى النظائر- بقوله: «هذا المعنى قويٌّ، كقوله: <q>﴿ثاني عطفه ليضل عن سبيل الله﴾</q> [الحج:٩]، أي: مُعرِضٌ عن الحقّ مستكبر». ",footnotes:1:أخرجه ابن جرير ٢١/٥٣٤ بلفظ: بقوته، أو بقومه، أبو جعفر يشكّ. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٣٤.أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥٣٥.أخرجه ابن جرير ٢١/٥٣٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٨-.تفسير مقاتل بن سليمان ٤/١٣١-١٣٢.أخرجه ابن جرير ٢١/٥٣٥.
51,40," <q>﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ فِی ٱلۡیَمِّ﴾</q> - قراءات ٧٢٦٦٨- في قراءة عبد الله: (فَأَخَذْناهُ وجُنُودَهُ فَنَبَذْناهُ){1}. (ز) <q>﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ فِی ٱلۡیَمِّ﴾</q> - تفسير الآية ٧٢٦٦٩- قال مقاتل بن سليمان: <q>﴿فأَخَذْناهُ﴾</q> يعني: فرعون <q>﴿وجُنُودَهُ فَنَبَذْناهُمْ فِي اليَمِ﴾</q> يعني: في نهر مصر النيل، فأُغرقوا أجمعين، ثم قال لفرعون: <q>﴿وهُوَ مُلِيمٌ﴾</q>{2}. (ز) <q>﴿وَهُوَ مُلِیمࣱ ۝٤٠﴾</q> - تفسير ٧٢٦٧٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وهُوَ مُلِيمٌ﴾</q>، قال: مُلِيمٌ في عباد الله{3}. (١٣/٦٨٢) ٧٢٦٧١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وهُوَ مُلِيمٌ﴾</q>، أي: مُلِيم في نِقمة الله{4}. (ز) ٧٢٦٧٢- قال مقاتل بن سليمان: <q>﴿وهُوَ مُلِيمٌ﴾</q>، يعني: مُذنبٌ، يقول: استلام إلى ربه{2}. (ز) ",footnotes:1:علقه ابن جرير ٢١/٥٣٦. وهي قراءة شاذة. انظر: المحرر الوجيز ٥/١٨٠.تفسير مقاتل بن سليمان ٤/١٣٢.أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٣٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٣٦، ووقع في بعض النسخ: في نعمة الله، وهو كذلك في تفسير إسحاق البستي ص٤٣١.تفسير مقاتل بن سليمان ٤/١٣٢.
51,41," <q>﴿وَفِی عَادٍ إِذۡ أَرۡسَلۡنَا عَلَیۡهِمُ ٱلرِّیحَ ٱلۡعَقِیمَ ۝٤١﴾</q> - تفسير ٧٢٦٧٣- عن ابن عمرو، قال: قال رسول الله ﷺ: «الرِّيح مُسجنةٌ في الأرض الثانية، فلمّا أراد الله أن يُهلِكَ عادًا أمر خازن الرِّيح أن يُرسل عليهم ريحًا تُهلِك عادًا، قال: أي ربِّ، أُرْسل عليهم مِن الرِّيح قدْر مَنخَر الثَّور. قال له الجبار: لا، إذن تُكفأ الأرض ومَن عليها، ولكن أرْسل عليهم بقدر خاتم. فهي التي قال الله: <q>﴿ما تَذَرُ مِن شَيْءٍ أتَتْ عَلَيْهِ إلّا جَعَلَتْهُ﴾</q>»{1}. (١٣/٦٨٣) ٧٢٦٧٤- عن رجل من رَبيعة، قال: قدمتُ المدينة، فدخلتُ على رسول الله ﷺ، فذكرتُ عنده وافد عاد، فقلتُ: أعوذ بالله أنْ أكون مثلَ وافد عاد. قال رسول الله ﷺ: «وما وافِد عاد؟». فقلتُ: على الخبير سقطتَ، إنّ عادًا لما أقْحَطَتْ بعثتْ قَيْلًا، فنزل على بكر بن معاوية، فسقاه الخمر، وغَنَّته الجرادتان، ثم خرج يريد جبال مَهَرة، فقال: اللهم، إني لم آتِك لمريضٍ فأداويَه، ولا لأسيرٍ فأفاديَه، فاسْقِ عبدك ما كنت مُسقيه، واسْقِ معه بكر بن معاوية. يَشكُر له الخمر الذي سقاه، فرُفع له سحابات، فقيل له: اختر إحداهنّ. فاختار السوداء منهنّ، فقيل له: خُذها رمادًا رِمْدِدًا{2}، لا تذر مِن عاد أحدًا. وذُكر: أنه لم يُرسَل عليهم من الرِّيح إلا قدْر هذه الحلقة، يعني: حلقة الخاتم. ثم قرأ: <q>﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ * ما تَذَرُ مِن شَيْءٍ أتَتْ عَلَيْهِ إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</q>{3}. (١٣/٦٨٤) ٧٢٦٧٥- عن علي بن أبي طالب -من طريق خليفة بن الحُصين- قال: <q>﴿الرِّيحَ العَقِيمَ﴾</q> النَّكباء{4}٦٢٠٨. (١٣/٦٨٤) ٦٢٠٨ انتقد ابنُ عطية (٨/٧٨) -مستندًا إلى السنة- هذا القول، فقال: «وهذا عندي لا يصح عن عليٍّ ﵁؛ لأنه مردود بقوله ﷺ: «نُصرتُ بالصّبا، وأُهلكت عاد بالدّبور»». ٧٢٦٧٦- عن عبد الله بن عمرو -من طريق عطاء- قال: الرِّياح ثمانٍ: أربعٌ منها عذاب، وأربعٌ منها رحمة، فأما العذاب منها: فالقاصف، والعاصف، والعقيم، والصرصر، قال الله تعالى: <q>﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</q> [فصلت:١٦]، قال: مشؤومات، وأما رياح الرحمة: فالناشرات، والمبشّرات، والمرسلات، والذّاريات{5}. (٢/١١١) ٧٢٦٧٧- عن عبد الله بن عباس -من طريق عكرمة- قال: ما هبَّتْ ريحٌ قطُّ إلا جثا النبيُّ ﷺ على ركبتيه، وقال: «اللَّهُمَّ، اجعلها رحمةً، ولا تجعلها عذابًا، اللهم، اجعلها رياحًا، ولا تجعلها ريحًا». قال ابن عباس: في كتاب الله ﷿: <q>﴿إنا أرسلنا عليهم ريحا صرصرا﴾</q> [القمر:١٩]، <q>﴿إذ أرسلنا عليهم الريح العقيم﴾</q> [الذاريات:٤١]، وقال: <q>﴿وأرسلنا الرياح لواقح﴾</q> [الحجر:٢٢]، وقال: <q>﴿أن يرسل الرياح مبشرات﴾</q> [الروم:٤١]{6}. (ز) ٧٢٦٧٨- عن عبد الله بن عباس -من طريق وهب- قال: الرياح ثمان: أربع رحمة، وأربع عذاب؛ الرحمة: المنتشرات، والمبشرات، والمرسلات، والرخاء. والعذاب: العاصف، والقاصف، وهما في البحر، والعقيم، والصرصر، وهما في البر{7}. (٢/١١٢) ٧٢٦٧٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿الرِّيحَ العَقِيمَ﴾</q>، قال: الشديدة التي لا تُلْقِح شيئًا{8}. (١٣/٦٨٣) ٧٢٦٨٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</q>، قال: التي لا تُلْقِح الشجر، ولا تثير السحاب{9}. (١٣/٦٨٣) ٧٢٦٨١- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿الرِّيحَ العَقِيمَ﴾</q>، قال: ريح لا بركة فيها، ولا منفعة، ولا ينزل منها غيث، ولا يُلْقَح منها شجر{10}. (١٣/٦٨٣) ٧٢٦٨٢- عن سعيد بن المسيّب -من طريق الحارث بن عبد الرحمن- قال: <q>﴿الرِّيحَ العَقِيمَ﴾</q> الجَنُوب{11}. (١٣/٦٨٤) ٧٢٦٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿الرِّيحَ العَقِيمَ﴾</q> الصّبا التي لا تُلْقِح شيئًا{12}. (١٣/٦٨٤) ٧٢٦٨٤- عن الضَّحّاك بن مُزاحِم -من طريق أبي ساسان- عن قوله: <q>﴿الرِّيحَ العَقِيمَ﴾</q>، قال: الريح التي ليس فيها بركة، ولا تُلْقِح الشجر{13}. (ز) ٧٢٦٨٥- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿الرِّيحَ العَقِيمَ﴾</q> التي لا تُنبت{14}. (١٣/٦٨٤) ٧٢٦٨٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</q> إنّ مِن الريح عقيمًا وعذابًا حين تُرسَل لا تُلْقِح شيئًا، ومِن الرِّيح رحمة يُثير الله -تبارك وتعالى- بها السحاب، ويُنزل بها الغيث. وذُكر لنا: أن رسول الله ﷺ كان يقول: «نُصرتُ بالصّبا، وأُهلِكَت عادٌ بالدّبور»{15}. (ز) ٧٢٦٨٧- عن عبد الله بن عباس -من طريق مجاهد-، مثله{15}. (ز) ٧٢٦٨٨- عن محمد بن شهاب الزُّهريّ -من طريق عقيل بن خالد- قال: <q>﴿الرِّيحَ العَقِيمَ﴾</q> الجنوب، وهي التي عذّب اللهُ بها قومَ عاد{17}. (ز) ٧٢٦٨٩- قال مقاتل بن سليمان: <q>﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ﴾</q> باليمن <q>﴿الرِّيحَ العَقِيمَ﴾</q> التي تُهلك، ولا تُلْقِح الشجر، ولا تُثير السحاب، وهي عذابٌ على مَن أُرسِلَتْ عليه{18}. (ز) ٧٢٦٩٠- عن سفيان [الثوري] -من طريق مهران- قال: <q>﴿الرِّيحَ العَقِيمَ﴾</q> التي لا تُلْقِح شيئًا{15}. (ز) ٧٢٦٩١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</q>، قال: إنّ الله -تبارك وتعالى- يُرسل الرِّياح نَشرًا بين يدي رحمته، فيُحْيِي به الأصلَ والشجرَ، وهذه لا تُحيي ولا تُلْقِح، هي عقيمٌ ليس فيها مِن الخير شيء، إنما هي عذاب لا تُلْقِح شيئًا، وهذه تُلْقِح. وقرأ: <q>﴿وأَرْسَلْنا الرِّياح لَواقِحَ﴾</q> [الحجر:٢٢]{15}٦٢٠٩. (ز) ٦٢٠٩ لم يذكر ابن جرير (٢١/٥٣٧-٥٣٩) غير قول ابن زيد وما في معناه. ",footnotes:1:أخرجه الحاكم ٤/٦٣٦ (٨٧٥٦) مطولًا، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٢٣-٣٢٤، ٧/٤٢٣-. قال الحاكم: «هذا حديث تفرّد به أبو السّمح عن عيسى بن هلال، وقد ذكرت فيما تقدم عدالته بنص الإمام يحيى بن معين ﵁، والحديث صحيح، ولم يخرجاه». وقال الذهبي في التلخيص: «بل منكر». وقال ابن كثير في تفسيره ١٣/٢٢٠: «هذا الحديث رفْعه منكر، والأقرب أن يكون موقوفًا على عبد الله بن عمرو، من زاملتيه اللتين أصابهما يوم اليرموك».الرِّمْدِد -بالكسر-: المتناهي في الاحتراق والدِّقَّة. النهاية (رمد).أخرجه أحمد ٢٥/٣٠٤-٣٠٦ (١٥٩٥٣، ١٥٩٥٤)، والترمذي (٣٢٧٣، ٣٢٧٤)، والنسائي في الكبرى (٨٦٠٧)، وابن ماجه (٢٨١٦). وعزاه السيوطي إلى ابن مردويه.أخرجه إسحاق البستي ص٤٣٢. وعزاه السيوطي إلى الفريابي، وابن المنذر.أخرجه ابن أبي الدنيا في المطر والرعد والبرق والريح ٨/٤٥١ (١٧٤).أخرجه الطبراني في الدعوات الكبير ١/٤٨٠ (٣٦٩)، وأبو الشيخ في العظمة ٤/١٣٥١-١٣٥٢. وأثر ابن عباس أورده البغوي في تفسيره ٤/٣٧٦.أخرجه أبو الشيخ في العظمة (٨٤٢).أخرجه ابن جرير ٢١/٥٣٧، والحاكم ٢/٤٦٧. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢١/٥٣٧.أخرجه أبو الشيخ في العظمة (٨٥٧).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٣٦ (٦٢)، وابن جرير ٢١/٥٣٨، وأبو الشيخ في العظمة (٨٥٠). وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٣٧ بلفظ: ليس فيها رحمة ولا نبات، ولا تُلْقِح نباتًا. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٣٧، ٥٣٨، ٥٣٩، وبنحوه من طريق مشاش، وعبيد.أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٣٩.أخرجه ابن جرير ٢١/٥٣٩.أخرجه ابن جرير ٢١/٥٣٩.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥١ (٣٠٩).تفسير مقاتل بن سليمان ٤/١٣٢.أخرجه ابن جرير ٢١/٥٣٩.أخرجه ابن جرير ٢١/٥٣٩.
51,42," <q>﴿مَا تَذَرُ مِن شَیۡءٍ أَتَتۡ عَلَیۡهِ إِلَّا جَعَلَتۡهُ كَٱلرَّمِیمِ ۝٤٢﴾</q> - تفسير ٧٢٦٩٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</q>، قال: كالشيء الهالك{1}. (١٣/٦٨٣) ٧٢٦٩٣- عن عبد الله بن عباس -من طريق طاووس- قال: كان وادٍ لقوم عاد، كان إذا أُمطِروا مِن نحو ذلك الوادي وأتاهم الغَيم من قِبله كان ذلك العام خِصبٍ متعالم فيهم، فبعث اللهُ عليهم العذاب مِن قِبَل ذلك الوادي، فجعل هودٌ يدعوهم ويقول: إنّ العذاب قد أظلّكم. فيقولون: كذبتَ، هذا عارضٌ ممطرنا. فنَزَلَت الريح، فنَسَفَت الرّعاة، فجَعَلتْ تمرُّ على الرجل بغنمه ورعاته حتى يعرفها، ثم يحلّق بهم في السماء حتى تقذفهم في البحر، ثم نَسَفَت البيوت حتى جعلتهم كالرميم{2}. (ز) ٧٢٦٩٤- قال أبو العالية الرِّياحي: <q>﴿إلا جَعَلَتْهُ كالرَّمِيمِ﴾</q> كالتُّراب المدقوق{3}. (ز) ٧٢٦٩٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كالرميم﴾</q>، قال: الشيء الهالك{4}. (١٣/٦٨٤) ٧٢٦٩٦- عن مجاهد بن جبر -من طريق ابن جُرَيْج- قال: <q>﴿إلا جَعَلَتْهُ كالرَّمِيمِ﴾</q> الهامد{5}. (ز) ٧٢٦٩٧- قال مجاهد بن جبر: <q>﴿إلا جَعَلَتْهُ كالرَّمِيمِ﴾</q> كالتِّبن اليابس{3}. (ز) ٧٢٦٩٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</q>، قال: كرميم الشجر{7}٦٢١٠. (١٣/٦٨٤) ٦٢١٠ لم يذكر ابنُ جرير (٢١/٥٤٠-٥٤١) غير قول قتادة، ومجاهد من طريق ابن أبي نجيح، وابن عباس من طريق عطية العوفي. ٧٢٦٩٩- قال مقاتل بن سليمان: <q>﴿ما تَذَرُ﴾</q> تلك الريح <q>﴿مِن شَيْءٍ أتَتْ عَلَيْهِ﴾</q> مِن أنفسهم وأنعامهم وأموالهم <q>﴿إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</q> يقول: إلا جعلته باليًا كالتُّراب، بعد ما كانوا مثل نخلٍ منقعرٍ صاروا رميمًا{8}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٥٤٠.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٣٩-٤٠ (٨٢).تفسير البغوي ٧/٣٧٨.تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٤٠. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي ص٤٣٣.تفسير البغوي ٧/٣٧٨.أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٤٠-٥٤١، وبنحوه من طريق سعيد.تفسير مقاتل بن سليمان ٤/١٣٢. وفي تفسير الثعلبي ٩/١١٨ نحو آخره مختصرًا منسوبًا إلى مقاتل دون تعيينه.
51,43," <q>﴿وَفِی ثَمُودَ إِذۡ قِیلَ لَهُمۡ تَمَتَّعُوا۟ حَتَّىٰ حِینࣲ ۝٤٣﴾</q> - تفسير ٧٢٧٠٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وفِي ثَمُودَ إذْ قِيلَ لَهُمْ تَمَتَّعُوا حَتّى حِينٍ﴾</q>، قال: ثلاثة أيام{1}. (١٣/٦٨٥) ٧٢٧٠١- قال مقاتل بن سليمان: <q>﴿وفِي ثَمُودَ﴾</q> آية <q>﴿إذْ قِيلَ لَهُمْ﴾</q> قال لهم نبيُّهم صالح: <q>﴿تَمَتَّعُوا حَتّى حِينٍ﴾</q> يعني: إلى آجالكم{2}٦٢١١. (ز) ٦٢١١ ذكر ابنُ كثير (١٣/٢٢١) نحو ما جاء في قول مقاتل عن ابن جرير، ثم قال معلّقًا: «والظاهر أن هذه كقوله: <q>﴿وأما ثمود فهديناهم فاستحبوا العمى على الهدى فأخذتهم صاعقة العذاب الهون﴾</q> [فصلت:١٧]. وهكذا قال هاهنا: <q>﴿وفي ثمود إذ قيل لهم تمتعوا حتى حين فعتوا عن أمر ربهم فأخذتهم الصاعقة وهم ينظرون﴾</q>، وذلك أنهم انتظروا العذاب ثلاثة أيام، وجاءهم في صبيحة اليوم الرابع بكرة النهار». وذكر ابنُ عطية (٨/٧٨) في قوله: <q>﴿تمتعوا حتى حين﴾</q> احتمالين، ورتّب عليهما المعنى في قوله: <q>﴿فعتوا عن أمر ربهم﴾</q>، فقال: «وقوله تعالى: <q>﴿وفي ثمود إذ قيل لهم تمتعوا حتى حين﴾</q> يحتمل أن يريد: إذ قيل لهم في أول بعْث صالح: آمِنوا وأطيعوا فتمتعوا متاعًا حسنًا إلى آجالكم. وهو الحين على هذا التأويل، وهو قول الحسن حكاه عنه الرماني، ويجيء قوله تعالى: <q>﴿فعتوا﴾</q> مُرتّبًا لفظًا في الآية ومعنًى في الوجود متأخرًا عن القول لهم تمتعوا، ويحتمل أن يريد: إذ قيل لهم بعد عقر الناقة: تمتّعوا في داركم ثلاثة. وهي الحين على هذا التأويل، وهو قول الفراء، ويجيء قوله: <q>﴿فعتوا﴾</q> غير مُرتّب المعنى في وجوده؛ لأن عُتوّهم كان قبل أن يقال لهم: تمتعوا، وكأن المعنى فكان من أمرهم قبل هذه المقالة أنْ عتَوا، وهو السبب في أن قيل لهم ذلك وعُذّبوا». ",footnotes:1:أخرجه البيهقي في سننه ١٠/٦٢.تفسير مقاتل بن سليمان ٤/١٣٢.
51,44," <q>﴿فَعَتَوۡا۟ عَنۡ أَمۡرِ رَبِّهِمۡ فَأَخَذَتۡهُمُ ٱلصَّـٰعِقَةُ وَهُمۡ یَنظُرُونَ ۝٤٤﴾</q> - قراءات ٧٢٧٠٢- عن عمر بن الخطاب -من طريق عمرو بن ميمون الأْودي- أنه قرأ ذلك: ‹فَأَخَذَتْهُمُ الصَّعْقَةُ› بغير ألف{1}٦٢١٢. (ز) ٦٢١٢ ذكر ابنُ جرير (٢١/٥٤٣) هذه القراءة وقراءة مَن قرأ ذلك بالألف: <q>﴿الصاعقة﴾</q>، ثم رجّحها مستندًا لإجماع الحجة من القراء، فقال: «وبالألف نقرأ <q>﴿الصاعقة﴾</q>؛ لإجماع الحجة من القراء عليها». وذكرهما ابنُ عطية (٨/٧٩)، ثم قال معلّقًا: «وهي على القراءتين: الصيحة العظيمة». <q>﴿فَعَتَوۡا۟ عَنۡ أَمۡرِ رَبِّهِمۡ فَأَخَذَتۡهُمُ ٱلصَّـٰعِقَةُ وَهُمۡ یَنظُرُونَ ۝٤٤﴾</q> - تفسير الآية ٧٢٧٠٣- قال عبد الله بن عباس: <q>﴿فَأَخَذَتْهُمُ الصّاعِقَةُ﴾</q> الموت{2}. (ز) ٧٢٧٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَعَتَوْا﴾</q>، قال: عَلوا. وفي قوله: <q>﴿فَأَخَذَتْهُمُ الصّاعِقَةُ وهُمْ يَنْظُرُونَ﴾</q>، قال: فجأة{3}. (١٣/٦٨٥) ٧٢٧٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿فَأَخَذَتْهُمُ الصّاعِقَةُ وهُمْ يَنْظُرُونَ﴾</q>: وهم ينتظرون، وذلك أنّ ثمود وُعِدت العذاب قبل نزوله بهم بثلاثة أيام، وجعل لنزوله عليهم علامات في تلك الثلاثة، فظهرت العلامات التي جُعلتْ لهم الدّالة على نزولها في تلك الأيام، فأصبحوا في اليوم الرابع موقنين بأنّ العذاب بهم نازل، ينتظرون حلوله بهم{4}٦٢١٣. (ز) ٦٢١٣ ذكر ابنُ عطية (٨/٧٩) في قوله: <q>﴿وهم ينظرون﴾</q> احتمالين، فقال: «وقوله: <q>﴿وهم ينظرون﴾</q> يحتمل أن يريد: فجأة وهم يُبصرون بعيونهم حالهم، ويحتمل أن يريد: وهم ينظرون ذلك في تلك الأيام الثلاثة التي أُعلموا به فيها ورأوا علاماته في تلوّنه. وهذا قول مجاهد». ٧٢٧٠٦- قال مقاتل بن سليمان: <q>﴿فَعَتَوْا﴾</q> يقول: فعَصَوا <q>﴿عَنْ أمْرِ رَبِّهِمْ فَأَخَذَتْهُمُ الصّاعِقَةُ﴾</q> يعني: العذاب، وهو الموت، من صيحة جبريل <q>﴿وهُمْ يَنْظُرُونَ﴾</q>{5}. (ز) ٧٢٧٠٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَعَتَوْا عَنْ أمْرِ رَبِّهِمْ﴾</q>، قال: العاتي: العاصي التارك لأمر الله ﷿{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/٥٤٢. وهي قراءة متواترة، قرأ بها الكسائي، وقرأ الباقون: <q>﴿فَأَخَذَتْهُمُ الصّاعِقَةُ﴾</q> بالألف. انظر: النشر ٢/٣٧٧، والإتحاف ص٥١٧.تفسير البغوي ٧/٣٧٨.تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٤٢ بنحوه. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر.أخرجه ابن جرير ٢١/٥٤٢.تفسير مقاتل بن سليمان ٤/١٣٢. وفي تفسير البغوي ٧/٣٧٨ نحو آخره مختصرًا منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢١/٥٤١.
51,45," <q>﴿فَمَا ٱسۡتَطَـٰعُوا۟ مِن قِیَامࣲ﴾</q> - تفسير ٧٢٧٠٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</q>، قال: ما استطاع القوم نهوضًا لعقوبة الله -تبارك وتعالى-{1}٦٢١٤. (١٣/٦٨٥) ٦٢١٤ لم يذكر ابنُ جرير (٢١/٥٤٣) عن السلف غير قول قتادة. ثم ذكر قولًا عن بعض أهل اللغة، فقال: «وكان بعض أهل العربية يقول: معنى قوله: <q>﴿فما استطاعوا من قيام﴾</q>: فما قاموا بها. قال: لو كانت فما استطاعوا من إقامة، لكان صوابًا، وطرح الألف منها كقوله: <q>﴿أنبتكم من الأرض نباتا﴾</q> [نوح:١٧]». ونقل ابنُ عطية (٨/٧٩) عن قتادة وغيره في قوله: <q>﴿مِن قِيامٍ﴾</q> أنّ «معناه: من قيام بالأمر ودفعْه». ووجَّهه بقوله: «كما تقول: فلان له بكذا وكذا قيام، أي: استصلاح وانتهاض». ٧٢٧٠٩- قال إسماعيل السُّدِّيّ: <q>﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</q> فما أطاقوا أن يقوموا للعذاب{2}. (ز) ٧٢٧١٠- قال مقاتل بن سليمان: <q>﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</q>، يعني: أن يقوموا للعذاب حين غَشِيهم{3}. (ز) ٧٢٧١١- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</q>، قال: لم يستطيعوا أن ينهضوا بعقوبة الله إذ نَزَلَتْ بهم{4}. (١٣/٦٨٥) <q>﴿وَمَا كَانُوا۟ مُنتَصِرِینَ ۝٤٥﴾</q> - تفسير ٧٢٧١٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وما كانُوا مُنْتَصِرِينَ﴾</q>، قال: ما كانت عندهم مِن قُوّة يمتنعون بها مِن الله ﷿{5}٦٢١٥. (ز) ٦٢١٥ قال ابنُ جرير (٢١/٥٤٣) في تفسير الآية: «وقوله: <q>﴿وما كانوا منتصرين﴾</q> يقول: وما كانوا قادرين على أن يستقيدوا مِمَّن أحلّ بهم العقوبة التي حلّتْ بهم». ثم ذكر قول قتادة ولم يعلّق عليه. ٧٢٧١٣- قال مقاتل بن سليمان: <q>﴿وما كانُوا مُنْتَصِرِينَ﴾</q>، يعني: ممتنعين من العذاب حين أُهلكوا {3}. (ز) ٧٢٧١٤- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وما كانُوا مُنْتَصِرِينَ﴾</q>، قال:لم يستطيعوا امتناعًا مِن أمر الله{4}. (١٣/٦٨٥) ",footnotes:1:أخرجه ابن جرير ٢١/٥٤٣، كذلك أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٤٣ من طريق معمر بلفظ: من نهوض.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٩-.تفسير مقاتل بن سليمان ٤/١٣٢.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٤٣-٥٤٤.تفسير مقاتل بن سليمان ٤/١٣٢.عزاه السيوطي إلى ابن المنذر.
51,46," <q>﴿وَقَوۡمَ نُوحࣲ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٤٦﴾</q> - قراءات ٧٢٧١٥- عن هارون الأعور، عن أبي عمرو بن العلاء: ‹وقَوْمِ نُوحٍ مِّن قَبْلُ›، يقول: وفي قوم نوح{1}٦٢١٦. (ز) ٦٢١٦ وجّه ابنُ جرير (٢١/٥٤٤-٥٤٥) هذه القراءة، فقال: «وقرأ ذلك عامة قراء الكوفة والبصرة: <q>﴿وقومِ نوح﴾</q> بخفض القوم على معنى: وفي قوم نوح عطفًا بالقوم على موسى في قوله: <q>﴿وفي موسى إذ أرسلناه إلى فرعون﴾</q>». ووجّه معنى الآية عليها، فقال: «وتأويل ذلك في قراءة مَن قرأه خفضًا: وفي قوم نوح لهم أيضًا عبرة إذ أهلكناهم من قبل ثمود لمّا كذبوا رسولنا نوحًا؛ <q>﴿إنهم كانوا قوما فاسقين﴾</q> يقول: إنهم كانوا مخالفين أمر الله، خارجين عن طاعته». وجعلها ابنُ عطية (٨/٧٩-٨٠) على هذه القراءة معطوفة على قوله: <q>﴿وفي ثمود﴾</q>. وذكر ابنُ جرير قراءة مَن قرأ ذلك بنصب: <q>﴿وقوم﴾</q>، وذكر فيها عدة احتمالات رتّب عليها معنى الآية، فقال: «ولنَصْب ذلك وجوه: أحدها: أن يكون القوم عطفًا على الهاء والميم في قوله: <q>﴿فأخذتهم الصاعقة﴾</q>؛ إذ كان كل عذاب مُهلك تسمّيه العرب: صاعقة، فيكون معنى الكلام حينئذ: فأخذتهم الصاعقة وأخذتْ قوم نوح من قبل. والثاني: أن يكون منصوبًا بمعنى الكلام، إذ كان فيما مضى من أخبار الأمم قبل دلالة على المراد من الكلام، وأن معناه: أهلكنا هذه الأمم وأهلكنا قوم نوح من قبل. والثالث: أن يضمر له فعلًا ناصبًا، فيكون معنى الكلام: واذكر لهم قوم نوح، كما قال: <q>﴿وإبراهيم إذ قال لقومه﴾</q> [العنكبوت:١٦] ونحو ذلك، بمعنى: أخبِرهم واذكر لهم». وعلى هذه القراءة ففي عطفها احتمالين ذكرهما ابنُ عطية، فقال: «وهو عطف إما على الضمير في قوله: <q>﴿فأخذتهم﴾</q> إذ هو بمنزلة: أهلكناهم، وإما على الضمير في قوله: <q>﴿نبذناهم﴾</q>». ثم رجّح ابنُ جرير: أنهما «قراءتان معروفتان في قراءة الأمصار؛ فبأيتهما قرأ القارئ فمصيب». وزاد ابنُ عطية أن ذلك قُرأ بالرفع، ووجّهه، فقال: «وقرأ أبو عمرو فيما روى عنه عبد الوارث: (وقَوْمُ نُوحٍ) بالرفع، وذلك على الابتداء وإضمار الخبر». <q>﴿وَقَوۡمَ نُوحࣲ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٤٦﴾</q> - تفسير الآية ٧٢٧١٦- قال مقاتل بن سليمان: <q>﴿و﴾</q>في <q>﴿قَوْمَ نُوحٍ﴾</q> آية <q>﴿مِن قَبْلُ﴾</q> هؤلاء الذين ذكر <q>﴿إنَّهُمْ كانُوا قَوْمًا فاسِقِينَ﴾</q> يعني: عاصين{2}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٤٣٣. وهي قراءة متواترة، قرأ بها أبو عمرو، وحمزة، والكسائي، وخلف، وقرأ الباقون: <q>﴿قَوْمَ نُوحٍ﴾</q> بالنصب. النشر ٢/٣٧٧، والإتحاف ص٥١٧.تفسير مقاتل بن سليمان ٤/١٣٢.
51,47," <q>﴿وَٱلسَّمَاۤءَ بَنَیۡنَـٰهَا بِأَیۡی۟دࣲ﴾</q> - تفسير ٧٢٧١٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: بقُوّة{1}. (١٣/٦٨٦) ٧٢٧١٨- عن سعيد [بن جُبَيْر] -من طريق جعفر- في قوله: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: بقُوّة{2}. (ز) ٧٢٧١٩- عن حمّاد [بن أبي سليمان] -من طريق رقبة- في قوله: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: بقُوّة.= (ز) ٧٢٧٢٠- وكذلك قال إبراهيم [النخعي]{3}. (ز) ٧٢٧٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: يعني: بقُوّة{4}. (١٣/٦٨٦) ٧٢٧٢٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>: أي: بقُوّة{5}. (ز) ٧٢٧٢٣- عن منصور بن المعتمر -من طريق شعبة- أنه قال في هذه الآية: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: بقُوّة{5}. (ز) ٧٢٧٢٤- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿بنيناها بأيد﴾</q>، قال: الأيد: القوة{7}. (ز) ٧٢٧٢٥- قال مقاتل بن سليمان: <q>﴿و﴾</q>في <q>﴿السَّماءَ﴾</q> آية <q>﴿بَنَيْناها بِأَيْدٍ﴾</q> يعني: بقُوّة{8}. (ز) ٧٢٧٢٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: بقوة{5}. (ز) ٧٢٧٢٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q>، قال: بقُوّة؛ بشِدّة{5}. (ز) <q>﴿وَإِنَّا لَمُوسِعُونَ ۝٤٧﴾</q> - تفسير ٧٢٧٢٨- قال عبد الله بن عباس: <q>﴿وإنّا لَمُوسِعُونَ﴾</q> قادرون{11}. (ز) ٧٢٧٢٩- قال عبد الله بن عباس: <q>﴿وإنّا لَمُوسِعُونَ﴾</q> لَمُوسعون الرّزق على خَلْقنا{11}. (ز) ٧٢٧٣٠- قال الضَّحّاك بن مُزاحِم: <q>﴿وإنّا لَمُوسِعُونَ﴾</q> أغنياء{11}. (ز) ٧٢٧٣١- قال الحسن البصري: <q>﴿وإنّا لَمُوسِعُونَ﴾</q> مُطيقون{11}. (ز) ٧٢٧٣٢- عن ابن أبي نجيح، في قوله: <q>﴿وإنّا لَمُوسِعُونَ﴾</q>، قال: أن نخلق سماء مثلها{15}. (ز) ٧٢٧٣٣- قال مقاتل بن سليمان: <q>﴿وإنّا لَمُوسِعُونَ﴾</q>، يعني: نحن قادرون على أن نُوسعها كما نريد{8}. (ز) ٧٢٧٣٤- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وإنّا لَمُوسِعُونَ﴾</q>، قال: لنخلق سماء مثلها{17}. (١٣/٦٨٦) ٧٢٧٣٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإنّا لَمُوسِعُونَ﴾</q>، قال: أوسعها جلّ جلاله{5}٦٢١٧. (ز) ٦٢١٧ قال ابنُ جرير (٢١/٥٤٦): «وقوله: <q>﴿وإنا لموسعون﴾</q> يقول: لذو سَعة بخلْقها وخلْق ما شئنا أن نخلقه وقدرة عليه، ومنه قوله: <q>﴿على الموسع قدره وعلى المقتر قدره﴾</q> [البقرة:٢٣٦]، يراد به: القوي». وذكر قول ابن زيد. وذكر ابنُ عطية (٨/٨٠) في قوله: <q>﴿وإنا لموسعون﴾</q> احتمالين، فقال: «وقوله: <q>﴿لموسعون﴾</q> يحتمل أن يريد: إنّا نوسع الأشياء قوة وقدرة، كما قال تعالى: <q>﴿على الموسع قدره﴾</q> [البقرة:٢٣٦] أي: الذي يوسع أهله إنفاقًا، ويحتمل أن يريد: لموسعون في بناء السماء، أي: جعلناها واسعة». ونقل عن الحسن قوله: «أوسع الرزق بمطر السماء». ",footnotes:1:أخرجه ابن جرير ٢١/٥٤٥، وابن أبي حاتم -كما في الإتقان ٢/٤٤-، والبيهقي في الأسماء والصفات (٢٥٢). وعزاه السيوطي إلى ابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير يحيى بن يمان) ص٣٨، وإسحاق البستي ص٤٣٥.أخرجه إسحاق البستي ص٤٣٥.تفسير مجاهد ص٦٢١، وأخرجه ابن جرير ٢١/٥٤٥، والبيهقي (٢٥٣).أخرجه ابن جرير ٢١/٥٤٦.أخرجه ابن جرير ٢١/٥٤٦.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤.تفسير مقاتل بن سليمان ٤/١٣٢.أخرجه ابن جرير ٢١/٥٤٦.أخرجه ابن جرير ٢١/٥٤٦.تفسير البغوي ٧/٣٧٩.تفسير البغوي ٧/٣٧٩.تفسير البغوي ٧/٣٧٩.تفسير البغوي ٧/٣٧٩.أخرجه ابن أبي حاتم -في الفتح ٨/٦٠٠-.تفسير مقاتل بن سليمان ٤/١٣٢.عزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه ابن جرير ٢١/٥٤٦.
51,48," <q>﴿وَٱلۡأَرۡضَ فَرَشۡنَـٰهَا فَنِعۡمَ ٱلۡمَـٰهِدُونَ ۝٤٨﴾</q> - تفسير ٧٢٧٣٦- قال عبد الله بن عباس: <q>﴿فَنِعْمَ الماهِدُونَ﴾</q> نِعم ما وطَّأتُ لعبادي{1}. (ز) ٧٢٧٣٧- قال مقاتل بن سليمان: <q>﴿و﴾</q>في <q>﴿الأَرْضَ﴾</q> آية <q>﴿فَرَشْناها﴾</q> مسيرة خمسمائة عام في خمسمائة عام من تحت الكعبة، <q>﴿فَنِعْمَ الماهِدُونَ﴾</q> يعني الرّبُّ تعالى: نفسَه{2}. (ز) ٧٢٧٣٨- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿والأَرْضَ فَرَشْناها فَنِعْمَ الماهِدُونَ﴾</q>، قال: الفارشون{3}. (١٣/٦٨٦) ",footnotes:1:تفسير البغوي ٧/٣٧٩.تفسير مقاتل بن سليمان ٤/١٣٢-١٣٣.عزاه السيوطي إلى ابن جرير، وابن المنذر.
51,49," <q>﴿وَمِن كُلِّ شَیۡءٍ خَلَقۡنَا زَوۡجَیۡنِ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٤٩﴾</q> - تفسير ٧٢٧٣٩- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</q>، قال: الكفر والإيمان، والشّقوة والسعادة، والهُدى والضّلالة، والليل والنهار، والسماء والأرض، والجنّ والإنس، والبَرّ والبحر، والشمس والقمر، وبُكرة وعشِيّة، ونحو هذا كله{1}. (١٣/٦٨٦) ٧٢٧٤٠- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</q>، قال: الشمس والقمر{2}. (ز) ٧٢٧٤١- قال محمد بن السّائِب الكلبي: <q>﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</q> هو كقوله: <q>﴿وأَنَّهُ خَلَقَ الزَّوْجَيْنِ الذَّكَرَ والأُنْثى﴾</q> [النجم:٤٥] الذَّكر زوج، والأنثى زوج{3}. (ز) ٧٢٧٤٢- قال مقاتل بن سليمان: <q>﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</q> يعني: صنفين، يعني: الليل والنهار، والدنيا والآخرة، والشمس والقمر، والبَرّ والبحر، والشتاء والصيف، والبَرْد والحرّ، والسَّهل والجبل، والسَّبخة والعذبة؛ <q>﴿لَعَلَّكُمْ تَذَكَّرُونَ﴾</q> فيما خلق أنّه ليس له عدل ولا مثيل، فتوحِّدونه{4}. (ز) ٧٢٧٤٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</q>، قال: ذكرًا وأنثى، ذاك الزّوجان. وقرأ: <q>﴿وأَصْلَحْنا لَهُ زَوْجَهُ﴾</q> [الأنبياء:٩٠]، قال: امرأته{5}٦٢١٨. (ز) ٦٢١٨ في قوله: <q>﴿خلقنا زوجين﴾</q> قولان: الأول: ومن كل شيء خلقنا نوعين مختلفين؛ كالشقاء والسعادة، والهدى والضلالة، ونحو ذلك. الثاني: عنى بالزوجين: الذكر والأنثى. وقد رجّح ابنُ جرير (٢١/٥٤٨) -مستندًا إلى دلالة العقل- القول الأول، فقال: «وأولى القولين في ذلك قول مجاهد، وهو أن الله -تبارك وتعالى- خلق لكل ما خلق مِن خلْقه ثانيًا له مخالفًا في معناه، فكلّ واحد منهما زوج للآخر، ولذلك قيل: خلقنا زوجين، وإنما نبّه -جلّ ثناؤه- بذلك من قوله على قدرته على خلْق ما يشاء خلْقه مِن شيء، وأنّه ليس كالأشياء التي شأنها فعل نوع واحد دون خلافه؛ إذ كل ما صفته فعل نوع واحد دون ما عداه كالنار التي شأنها التسخين، ولا تصلح للتبريد، وكالثلج الذي شأنه التبريد، ولا يصلح للتسخين، فلا يجوز أن يوصف بالكمال، وإنما كمال المدح للقادر على فعل كلّ ما شاء فعله مِن الأشياء المختلفة والمتفقة». ",footnotes:1:أخرجه ابن جرير ٢١/٥٤٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢١/٥٤٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٠-.تفسير مقاتل بن سليمان ٤/١٣٣.أخرجه ابن جرير ٢١/٥٤٨.
51,50," <q>﴿فَفِرُّوۤا۟ إِلَى ٱللَّهِۖ إِنِّی لَكُم مِّنۡهُ نَذِیرࣱ مُّبِینࣱ ۝٥٠﴾</q> - تفسير ٧٢٧٤٤- قال عبد الله بن عباس: <q>﴿فَفِرُّوا إلى اللَّهِ﴾</q> فِرُّوا منه إليه، واعملوا بطاعته{1}. (ز) ٧٢٧٤٥- عن محمد بن عبد الله بن عمرو بن عثمان بن عفان -من طريق محمد بن معز- في قوله سبحانه: <q>﴿فَفِرُّوا إلى اللَّهِ﴾</q>، قال: اخرجوا إلى مكة{2}. (ز) ٧٢٧٤٦- قال مقاتل بن سليمان: <q>﴿فَفِرُّوا إلى اللَّهِ﴾</q> مِن ذنوبكم، <q>﴿إنِّي لَكُمْ مِنهُ نَذِيرٌ مُبِينٌ﴾</q>{3}. (ز) ",footnotes:1:تفسير الثعلبي ٩/١١٩، وتفسير البغوي ٧/٣٧٩.أخرجه الثعلبي ٩/١١٩.تفسير مقاتل بن سليمان ٤/١٣٣.
51,51," <q>﴿وَلَا تَجۡعَلُوا۟ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَۖ إِنِّی لَكُم مِّنۡهُ نَذِیرࣱ مُّبِینࣱ ۝٥١﴾</q> - تفسير ٧٢٧٤٧- قال مقاتل بن سليمان: <q>﴿ولا تَجْعَلُوا مَعَ اللَّهِ إلهًا آخَرَ﴾</q> فإن فعلتم فـ<q>﴿إنِّي لَكُمْ مِنهُ نَذِيرٌ﴾</q> يعني: مِن عذابه <q>﴿مُبِينٌ﴾</q>، فرَدُّوا عليه: إنك ساحر مجنون{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣٣.
