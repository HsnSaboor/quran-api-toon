quran[21]{c,v,t}:
  51,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فَمَا خَطۡبُكُمۡ أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٣١ قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ فَما خَطْبُكُمْ﴾</span> يعني: ما أمركم <span class="qpc-hafs">﴿أيُّها المُرْسَلُونَ قالُوا﴾</span> قال جبريل: <span class="qpc-hafs">﴿إنّا أُرْسِلْنا إلى قَوْمٍ مُجْرِمِينَ﴾</span> يعني: كفارًا ظَلمةً، يعنون: قوم لوط{1}<span class=comment-ref>٦٢٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٢</span> نقل <u>ابنُ عطية</u> (٨/٧٥) في معنى «الخَطْب» قولًا، ولم ينسبه أنه «إنما يُعبَّر به عن الشدائد والمكاره حتى قالوا: خطوب الزمان. وغير ذلك». و<span class="comment-type-1">وجَّهه</span> بقوله: «وكأنّه يقول: ما هذه الطامة التي جئتم لها؟».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣١.
  51,32,""
  51,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِنُرۡسِلَ عَلَیۡهِمۡ حِجَارَةࣰ مِّن طِینࣲ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٤١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿حِجارَةً مِن طِينٍ﴾</span> مِن سَنك وكل{1}<span class=comment-ref>٦٢٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٣</span> نقل <u>ابنُ عطية</u> (٨/٧٥) رواية ولم ينسبها «أنه طين طُبخ في نار جهنم حتى صار حجارة كالآجُرِّ».</div></p><p><div></p><p><p><span class="item-no">٧٢٦٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِنُرْسِلَ﴾</span> يعني: لكي نُرسل <span class="qpc-hafs">﴿عَلَيْهِمْ حِجارَةً مِن طِينٍ﴾</span> خلطة الحجارة، الطين مُلْزقٌ بالحجر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١١٧، وأورد عقبه: وهو الحجر والطين بالفارسية، بيانه قوله: <span class="qpc-hafs">﴿من سجيل﴾</span>.|2:تفسير مقاتل بن سليمان ٤/١٣١.
  51,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُّسَوَّمَةً عِندَ رَبِّكَ لِلۡمُسۡرِفِینَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿مسومة﴾</span>، قال: مُعلَّمة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span>، قال: المُسوّمة: الحجارة المَختومة؛ يكون الحَجر أبيض فيه نقطة سوداء، أو يكون الحَجر أسود فيه نقطة بيضاء، فذلك تسويمها، <span class="qpc-hafs">﴿عِنْدَ رَبِّكَ﴾</span> يا إبراهيم <span class="qpc-hafs">﴿للمُسرفين﴾</span> يعني: للمُتعدِّين حدود الله، الكافرين به من قوم لوط{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مُسَوَّمَةً﴾</span>: يعني: مُعلَّمة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُسَوَّمَةً﴾</span> يعني: مُعلَّمة <span class="qpc-hafs">﴿عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span> يعني: المشركين، والشِّرك أسرف الذنوب وأعظمها{4}<span class=comment-ref>٦٢٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٧٥) في قوله: <span class="qpc-hafs">﴿مسومة﴾</span> عدة أقوال، فقال: «و<span class="qpc-hafs">﴿مسومة﴾</span> <b>قيل</b>: معناه: متروكة، وسومها من الإهلاك والانصباب. <b>وقيل</b>: معناه: مُعلَّمة بعلامتها مِن السيما والسومى، وهي العلامة، أي: أنها ليست مِن حجارة الدنيا. <b>وقيل</b>: معناه: على كل حجر اسم المضروب به. <b>وقيل</b>: كان عليها أمثال الخواتم. <b>وقال ابن عباس</b>: تسويمها إن كان في الحجارة السُّود نُقطٌ بِيض وفي البِيض سُودٌ». ثم قال <span class="comment-type-4">معلّقًا</span>: «ويحتمل أن يكون المعنى: أنها بجملتها معلومة عند ربك لهذا المعنى مُعلّمة له، لا أنّ كلّ واحد منها له علامة خاصة به».</div></p></div>",footnotes:1:أخرجه ابن المنذر -كما في الفتح ٨/٦٠١-.|2:أخرجه ابن جرير ٢١/٥٣٢ وجاء عقبه مضمومًا إليه: <span class="qpc-hafs">﴿فَأَخْرَجْنا مَن كانَ فِيها مِنَ المُؤْمِنِينَ﴾</span> يقول تعالى ذكره: فأخرجنا مَن كان في قرية سدوم -قرية قوم لوط- من أهل الإيمان بالله، وهم لوط وابنتاه، وكنّى عن القرية بقوله: <span class="qpc-hafs">﴿مَن كانَ فِيها﴾</span> ولم يجر لها ذلك قبل ذلك. والأظهر أنّ هذا كلام ابن جرير وليس تتمة تفسير ابن عباس.|3:تفسير مجاهد ص٦٢٠.|4:تفسير مقاتل بن سليمان ٤/١٣١.
  51,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخۡرَجۡنَا مَن كَانَ فِیهَا مِنَ ٱلۡمُؤۡمِنِینَ ۝٣٥ فَمَا وَجَدۡنَا فِیهَا غَیۡرَ بَیۡتࣲ مِّنَ ٱلۡمُسۡلِمِینَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: كانوا ثلاثة عشر{1}. (١٣/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span>، قال: لوط وابنتيه{2}. (١٣/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span>، قال: لو كان فيها أكثر من ذلك لنجّاهم الله؛ ليعلموا أنّ الإيمان عند الله محفوظ، لا ضَيعة على أهله{3}. (١٣/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَخْرَجْنا مَن كانَ فِيها﴾</span> يعني: في قرية لوط <span class="qpc-hafs">﴿مِنَ المُؤْمِنِينَ﴾</span> يعني: المُصَدِّقين بتوحيد الله تعالى، <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span> يعني: المُخلصين، فهو لوط وابنتيه ريثا الكُبرى، وزُعوتا الصُّغرى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٥١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span>، قال: هؤلاء قوم لوط، لم يجدوا فيها غير لوط{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٥٢<span class="dash">-</span></span> عن أبي المثنى= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٥٣<span class="dash">-</span></span> ومسلم أبي حسبة الأشجعي -من طريق صفوان- قال الله: <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span> لوطًا وابنتيه. قال: فحَلّ بهم العذاب. قال الله: <span class="qpc-hafs">﴿وتَرَكْنا فِيها آيَةً لِلَّذِينَ يَخافُونَ العَذابَ الأَلِيمَ﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخۡرَجۡنَا مَن كَانَ فِیهَا مِنَ ٱلۡمُؤۡمِنِینَ ۝٣٥ فَمَا وَجَدۡنَا فِیهَا غَیۡرَ بَیۡتࣲ مِّنَ ٱلۡمُسۡلِمِینَ ۝٣٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٥٤<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي زكريا</span>، قال: ما من أُمّة يكون فيهم خمسة عشر رجلًا يستغفرون الله في كل يوم خمسًا وعشرين مرّة فتُعذَّب تلك الأُمَّة، واقرأوا إن شئتم: <span class="qpc-hafs">﴿فأخرجنا من كان فيها من المؤمنين فما وجدنا فيها غير بيت من المسلمين﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٥٥<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق أيوب بن سُويد- قال: الإسلام والإيمان سواء ثم قرأ: <span class="qpc-hafs">﴿فأخرجنا من كان فيها من المؤمنين فما وجدنا فيها غير بيت من المسلمين﴾</span>{8}<span class=comment-ref>٦٢٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٥</span> ذكر <u>ابن كثير</u> (١٣/٢١٩) نحو ما جاء في قول الثوري، و<span class="comment-type-4">علّق</span> فقال: «احتجّ بهذه الآية مَن ذهب إلى رأي المعتزلة، ممن لا يفرّق بين مسمّى الإيمان والإسلام؛ لأنه أطلق عليهم المؤمنين والمسلمين. وهذا الاستدلال ضعيف؛ لأن هؤلاء كانوا قومًا مؤمنين، وعندنا أنّ كلّ مؤمن مسلم لا ينعكس، فاتفق الاسمان هاهنا لخصوصية الحال، ولا يلزم ذلك في كل حال».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ تيمية</u> (٦/١٠٤-١٠٥)، حيث نقل هذا عن الخطابي، وقال: «والذي اختاره الخطابي هو قول مَن فرَّق بينهما كأبي جعفر، وحمّاد بن زيد، وعبد الرحمن بن مهدي، وهو قول أحمد بن حنبل وغيره، <span class="mustanad">ولا علمتُ أحدًا من المتقدّمين</span> خالف هؤلاء فجعل نفس الإسلام نفس الإيمان؛ ولهذا كان عامّة أهل السنة على هذا الذي قاله هؤلاء. كما ذكره الخطابي».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ٢١/٥٣٢-٥٣٣. وعزاه السيوطي إلى ابن المنذر.|4:تفسير مقاتل بن سليمان ٤/١٣١.|5:أخرجه ابن جرير ٢١/٥٣٣.|6:أخرجه ابن جرير ٢١/٥٣٣.|7:أخرجه أبو نعيم في حلية الأولياء ٥/١٤٩.|8:أخرجه أبو نعيم في حلية الأولياء ٧/٣٤.
  51,36,""
  51,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَرَكۡنَا فِیهَاۤ ءَایَةࣰ لِّلَّذِینَ یَخَافُونَ ٱلۡعَذَابَ ٱلۡأَلِیمَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٥٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع- <span class="qpc-hafs">﴿العَذابَ الأَلِيمَ﴾</span>، قال: المُوجِع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَرَكْنا فِيها آيَةً﴾</span> يعني: عِبرة لِمَن بعدهم <span class="qpc-hafs">﴿لِلَّذِينَ يَخافُونَ العَذابَ الأَلِيمَ﴾</span> يعني: الوجيع، نظيرها في هود{2}{3}<span class=comment-ref>٦٢٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٦</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/٧٦) في معنى الآية احتمالين، فقال: «<b>المعنى</b>: وتركنا في القرية المذكورة، وهي سدوم أثرًا من العذاب باقيًا مؤرخًا لا يفنى ذكره فهو آية، أي علامة على قدرة الله وانتقامه من الكفرة. <b>ويحتمل</b> أن يكون المعنى: وتركنا في أمرها. <span class="mustanad">كما قال</span>: <span class="qpc-hafs">﴿لقد كان في يوسف﴾</span> [يوسف:٧]».</div></p><p><div></p><p><p><span class="item-no">٧٢٦٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وتَرَكْنا فِيها آيَةً﴾</span>، قال: ترك فيها صخرًا منضودًا {4}. (١٣/٦٨٢)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٠-.|2:لعل مراد مقاتل الآية قبل السابقة، وهي قوله تعالى: <span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span>، ونظيرها في سورة هود [٨٢-٨٣]: <span class="qpc-hafs">﴿وأَمْطَرْنا عَلَيْها حِجارَةً مِن سِجِّيلٍ مَنضُودٍ مُسَوَّمَةً عِنْدَ رَبِّكَ﴾</span>.|3:تفسير مقاتل بن سليمان ٤/١٣١.|4:عزاه السيوطي إلى ابن المنذر.
  51,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِی مُوسَىٰۤ إِذۡ أَرۡسَلۡنَـٰهُ إِلَىٰ فِرۡعَوۡنَ بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إلى فِرْعَوْنَ بِسُلْطانٍ مُبِينٍ﴾</span>، يقول: بعُذرٍ مُبين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي مُوسى إذْ أرْسَلْناهُ إلى فِرْعَوْنَ بِسُلْطانٍ مُبِينٍ﴾</span>، يعني: بحُجّةٍ بيّنةٍ واضحةٍ، وهي: اليد والعصا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٣٤|2:تفسير مقاتل بن سليمان ٤/١٣١.
  51,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّىٰ بِرُكۡنِهِۦ وَقَالَ سَـٰحِرٌ أَوۡ مَجۡنُونࣱ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span>، قال: بقومه{1}. (١٣/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span>، قال: بعَضُده وأصحابه{2}. (١٣/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span>، قال: بقومه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span>: غلب عدوُّ الله على قومه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span> بجنوده، <span class="qpc-hafs">﴿وقالَ ساحِرٌ أوْ مَجْنُونٌ﴾</span> موسى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span> يعني: فأعرض فرعونُ عن الحقّ بمَيْله، يعني: عن الإيمان حين قال: <span class="qpc-hafs">﴿ما أُرِيكُمْ إلّا ما أرى وما أهْدِيكُمْ إلّا سَبِيلَ الرَّشادِ﴾</span> [غافر:٢٩]، <span class="qpc-hafs">﴿وقالَ﴾</span> فرعون لموسى ﵇: هو <span class="qpc-hafs">﴿ساحِرٌ أوْ مَجْنُونٌ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٦٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿فَتَوَلّى بِرُكْنِهِ﴾</span>، قال: بجُموعه التي معه. وقرأ: <span class="qpc-hafs">﴿قالَ لَوْ أنَّ لِي بِكُمْ قُوَّةً أوْ آوِي إلى رُكْنٍ شَدِيدٍ﴾</span> [هود:٨٠]، قال: إلى قوةٍ من الناس؛ إلى رُكنٍ أجاهدكم به. قال: وفرعون وجنوده ومَن معه رُكنه. قال: وما كان مع لوط مؤمن واحد. قال: وعرض عليهم أن يُنكحهم بناته؛ رجاء أن يكون له منهم عَضُدٌ يُعينه، أو يدفع عنه. وقرأ: <span class="qpc-hafs">﴿هَؤُلاءِ بَناتِي هُنَّ أطْهَرُ لَكُمْ﴾</span> [هود:٧٨]، قال: يريد النكاح، فأَبَوا عليه. وقرأ قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿لَقَدْ عَلِمْتَ ما لَنا فِي بَناتِكَ مِن حَقٍّ وإنَّكَ لَتَعْلَمُ ما نُرِيدُ﴾</span> [هود:٧٩]. أصل الرُّكن: الجانب والناحية التي يَعتَمِد عليها، ويَقْوى بها{4}<span class=comment-ref>٦٢٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٧</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/٥٣٤-٥٣٥): «وقوله: <span class="qpc-hafs">﴿فتولى بركنه﴾</span> يقول: فأدبر فرعونُ كما أرسلنا إليه موسى بقومه مِن جنده وأصحابه، <span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span> وإن اختلفت ألفاظ قائليه فيه». ثم ذكر قول ابن عباس، ومجاهد، وقتادة، وابن زيد.</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ كثير</u> (١٣/٢٢٠ بتصرف) أنّ قوله: <span class="qpc-hafs">﴿تولى بركنه﴾</span> معناه: «أي: فأعرض فرعونُ عمّا جاءه به موسى مِن الحقّ المُبين استكبارًا». و<span class="comment-type-3">رجّحه</span> <span class="mustanad">-مستندًا إلى النظائر</span>- بقوله: «هذا المعنى قويٌّ، كقوله: <span class="qpc-hafs">﴿ثاني عطفه ليضل عن سبيل الله﴾</span> [الحج:٩]، أي: مُعرِضٌ عن الحقّ مستكبر».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٣٤ بلفظ: بقوته، أو بقومه، أبو جعفر يشكّ. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٣٤.|3:أخرجه عبد الرزاق ٢/٢٤٤، وابن جرير ٢١/٥٣٥.|4:أخرجه ابن جرير ٢١/٥٣٥.|5:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٨-.|6:تفسير مقاتل بن سليمان ٤/١٣١-١٣٢.|7:أخرجه ابن جرير ٢١/٥٣٥.
  51,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ فِی ٱلۡیَمِّ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٦٨<span class="dash">-</span></span> في قراءة <span class="name-1">عبد الله</span>: (فَأَخَذْناهُ وجُنُودَهُ فَنَبَذْناهُ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ فِی ٱلۡیَمِّ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأَخَذْناهُ﴾</span> يعني: فرعون <span class="qpc-hafs">﴿وجُنُودَهُ فَنَبَذْناهُمْ فِي اليَمِ﴾</span> يعني: في نهر مصر النيل، فأُغرقوا أجمعين، ثم قال لفرعون: <span class="qpc-hafs">﴿وهُوَ مُلِيمٌ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ مُلِیمࣱ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وهُوَ مُلِيمٌ﴾</span>، قال: مُلِيمٌ في عباد الله{3}. (١٣/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وهُوَ مُلِيمٌ﴾</span>، أي: مُلِيم في نِقمة الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُوَ مُلِيمٌ﴾</span>، يعني: مُذنبٌ، يقول: استلام إلى ربه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه ابن جرير ٢١/٥٣٦.</p><p>وهي قراءة شاذة. انظر: المحرر الوجيز ٥/١٨٠.|2:تفسير مقاتل بن سليمان ٤/١٣٢.|3:أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٣٦. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢١/٥٣٦، ووقع في بعض النسخ: في نعمة الله، وهو كذلك في تفسير إسحاق البستي ص٤٣١.|5:تفسير مقاتل بن سليمان ٤/١٣٢.
  51,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِی عَادٍ إِذۡ أَرۡسَلۡنَا عَلَیۡهِمُ ٱلرِّیحَ ٱلۡعَقِیمَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٧٣<span class="dash">-</span></span> عن ابن عمرو، قال: قال رسول الله ﷺ: «<b>الرِّيح مُسجنةٌ في الأرض الثانية، فلمّا أراد الله أن يُهلِكَ عادًا أمر خازن الرِّيح أن يُرسل عليهم ريحًا تُهلِك عادًا، قال: أي ربِّ، أُرْسل عليهم مِن الرِّيح قدْر مَنخَر الثَّور. قال له الجبار: لا، إذن تُكفأ الأرض ومَن عليها، ولكن أرْسل عليهم بقدر خاتم. فهي التي قال الله: <span class="qpc-hafs">﴿ما تَذَرُ مِن شَيْءٍ أتَتْ عَلَيْهِ إلّا جَعَلَتْهُ﴾</span></b>»{1}. (١٣/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٤<span class="dash">-</span></span> عن رجل من رَبيعة، قال: قدمتُ المدينة، فدخلتُ على رسول الله ﷺ، فذكرتُ عنده وافد عاد، فقلتُ: أعوذ بالله أنْ أكون مثلَ وافد عاد. قال رسول الله ﷺ: «<b>وما وافِد عاد؟</b>». فقلتُ: على الخبير سقطتَ، إنّ عادًا لما أقْحَطَتْ بعثتْ قَيْلًا، فنزل على بكر بن معاوية، فسقاه الخمر، وغَنَّته الجرادتان، ثم خرج يريد جبال مَهَرة، فقال: اللهم، إني لم آتِك لمريضٍ فأداويَه، ولا لأسيرٍ فأفاديَه، فاسْقِ عبدك ما كنت مُسقيه، واسْقِ معه بكر بن معاوية. يَشكُر له الخمر الذي سقاه، فرُفع له سحابات، فقيل له: اختر إحداهنّ. فاختار السوداء منهنّ، فقيل له: خُذها رمادًا رِمْدِدًا{2}، لا تذر مِن عاد أحدًا. وذُكر: أنه لم يُرسَل عليهم من الرِّيح إلا قدْر هذه الحلقة، يعني: حلقة الخاتم. ثم قرأ: <span class="qpc-hafs">﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ * ما تَذَرُ مِن شَيْءٍ أتَتْ عَلَيْهِ إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</span>{3}. (١٣/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق خليفة بن الحُصين- قال: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> النَّكباء{4}<span class=comment-ref>٦٢٠٨</span>. (١٣/٦٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٨</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٨/٧٨) <span class="mustanad">-مستندًا إلى السنة</span>- هذا القول، فقال: «وهذا عندي لا يصح عن عليٍّ ﵁؛ لأنه مردود بقوله ﷺ: «<b>نُصرتُ بالصّبا، وأُهلكت عاد بالدّبور</b>»».</div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عطاء- قال: الرِّياح ثمانٍ: أربعٌ منها عذاب، وأربعٌ منها رحمة، فأما العذاب منها: فالقاصف، والعاصف، والعقيم، والصرصر، قال الله تعالى: <span class="qpc-hafs">﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</span> [فصلت:١٦]، قال: مشؤومات، وأما رياح الرحمة: فالناشرات، والمبشّرات، والمرسلات، والذّاريات{5}. (٢/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: ما هبَّتْ ريحٌ قطُّ إلا جثا النبيُّ ﷺ على ركبتيه، وقال: «<b>اللَّهُمَّ، اجعلها رحمةً، ولا تجعلها عذابًا، اللهم، اجعلها رياحًا، ولا تجعلها ريحًا</b>». قال ابن عباس: في كتاب الله ﷿: <span class="qpc-hafs">﴿إنا أرسلنا عليهم ريحا صرصرا﴾</span> [القمر:١٩]، <span class="qpc-hafs">﴿إذ أرسلنا عليهم الريح العقيم﴾</span> [الذاريات:٤١]، وقال: <span class="qpc-hafs">﴿وأرسلنا الرياح لواقح﴾</span> [الحجر:٢٢]، وقال: <span class="qpc-hafs">﴿أن يرسل الرياح مبشرات﴾</span> [الروم:٤١]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق وهب- قال: الرياح ثمان: أربع رحمة، وأربع عذاب؛ الرحمة: المنتشرات، والمبشرات، والمرسلات، والرخاء. والعذاب: العاصف، والقاصف، وهما في البحر، والعقيم، والصرصر، وهما في البر{7}. (٢/١١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span>، قال: الشديدة التي لا تُلْقِح شيئًا{8}. (١٣/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</span>، قال: التي لا تُلْقِح الشجر، ولا تثير السحاب{9}. (١٣/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span>، قال: ريح لا بركة فيها، ولا منفعة، ولا ينزل منها غيث، ولا يُلْقَح منها شجر{10}. (١٣/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span> -من طريق الحارث بن عبد الرحمن- قال: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> الجَنُوب{11}. (١٣/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> الصّبا التي لا تُلْقِح شيئًا{12}. (١٣/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي ساسان- عن قوله: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span>، قال: الريح التي ليس فيها بركة، ولا تُلْقِح الشجر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> التي لا تُنبت{14}. (١٣/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</span> إنّ مِن الريح عقيمًا وعذابًا حين تُرسَل لا تُلْقِح شيئًا، ومِن الرِّيح رحمة يُثير الله -تبارك وتعالى- بها السحاب، ويُنزل بها الغيث. وذُكر لنا: أن رسول الله ﷺ كان يقول: «<b>نُصرتُ بالصّبا، وأُهلِكَت عادٌ بالدّبور</b>»{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد-، مثله{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق عقيل بن خالد- قال: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> الجنوب، وهي التي عذّب اللهُ بها قومَ عاد{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ﴾</span> باليمن <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> التي تُهلك، ولا تُلْقِح الشجر، ولا تُثير السحاب، وهي عذابٌ على مَن أُرسِلَتْ عليه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٠<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- قال: <span class="qpc-hafs">﴿الرِّيحَ العَقِيمَ﴾</span> التي لا تُلْقِح شيئًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وفِي عادٍ إذْ أرْسَلْنا عَلَيْهِمُ الرِّيحَ العَقِيمَ﴾</span>، قال: إنّ الله -تبارك وتعالى- يُرسل الرِّياح نَشرًا بين يدي رحمته، فيُحْيِي به الأصلَ والشجرَ، وهذه لا تُحيي ولا تُلْقِح، هي عقيمٌ ليس فيها مِن الخير شيء، إنما هي عذاب لا تُلْقِح شيئًا، وهذه تُلْقِح. وقرأ: <span class="qpc-hafs">﴿وأَرْسَلْنا الرِّياح لَواقِحَ﴾</span> [الحجر:٢٢]{15}<span class=comment-ref>٦٢٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠٩</span> لم يذكر <u>ابن جرير</u> (٢١/٥٣٧-٥٣٩) غير قول ابن زيد وما في معناه.</div></p></div>",footnotes:1:أخرجه الحاكم ٤/٦٣٦ (٨٧٥٦) مطولًا، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٢٣-٣٢٤، ٧/٤٢٣-.</p><p>قال الحاكم: «هذا حديث تفرّد به أبو السّمح عن عيسى بن هلال، وقد ذكرت فيما تقدم عدالته بنص الإمام يحيى بن معين ﵁، والحديث صحيح، ولم يخرجاه». وقال الذهبي في التلخيص: «بل منكر». وقال ابن كثير في تفسيره ١٣/٢٢٠: «هذا الحديث رفْعه منكر، والأقرب أن يكون موقوفًا على عبد الله بن عمرو، من زاملتيه اللتين أصابهما يوم اليرموك».|2:الرِّمْدِد -بالكسر-: المتناهي في الاحتراق والدِّقَّة. النهاية (رمد).|3:أخرجه أحمد ٢٥/٣٠٤-٣٠٦ (١٥٩٥٣، ١٥٩٥٤)، والترمذي (٣٢٧٣، ٣٢٧٤)، والنسائي في الكبرى (٨٦٠٧)، وابن ماجه (٢٨١٦). وعزاه السيوطي إلى ابن مردويه.|4:أخرجه إسحاق البستي ص٤٣٢. وعزاه السيوطي إلى الفريابي، وابن المنذر.|5:أخرجه ابن أبي الدنيا في المطر والرعد والبرق والريح ٨/٤٥١ (١٧٤).|6:أخرجه الطبراني في الدعوات الكبير ١/٤٨٠ (٣٦٩)، وأبو الشيخ في العظمة ٤/١٣٥١-١٣٥٢. وأثر ابن عباس أورده البغوي في تفسيره ٤/٣٧٦.|7:أخرجه أبو الشيخ في العظمة (٨٤٢).|8:أخرجه ابن جرير ٢١/٥٣٧، والحاكم ٢/٤٦٧. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|9:أخرجه ابن جرير ٢١/٥٣٧.|10:أخرجه أبو الشيخ في العظمة (٨٥٧).|11:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٣٦ (٦٢)، وابن جرير ٢١/٥٣٨، وأبو الشيخ في العظمة (٨٥٠). وعزاه السيوطي إلى ابن المنذر.|12:تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٣٧ بلفظ: ليس فيها رحمة ولا نبات، ولا تُلْقِح نباتًا. وعزاه السيوطي إلى ابن المنذر.|13:أخرجه ابن جرير ٢١/٥٣٧، ٥٣٨، ٥٣٩، وبنحوه من طريق مشاش، وعبيد.|14:أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٣٩.|15:أخرجه ابن جرير ٢١/٥٣٩.|16:أخرجه ابن جرير ٢١/٥٣٩.|17:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥١ (٣٠٩).|18:تفسير مقاتل بن سليمان ٤/١٣٢.|19:أخرجه ابن جرير ٢١/٥٣٩.|20:أخرجه ابن جرير ٢١/٥٣٩.
  51,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا تَذَرُ مِن شَیۡءٍ أَتَتۡ عَلَیۡهِ إِلَّا جَعَلَتۡهُ كَٱلرَّمِیمِ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٦٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</span>، قال: كالشيء الهالك{1}. (١٣/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- قال: كان وادٍ لقوم عاد، كان إذا أُمطِروا مِن نحو ذلك الوادي وأتاهم الغَيم من قِبله كان ذلك العام خِصبٍ متعالم فيهم، فبعث اللهُ عليهم العذاب مِن قِبَل ذلك الوادي، فجعل هودٌ يدعوهم ويقول: إنّ العذاب قد أظلّكم. فيقولون: كذبتَ، هذا عارضٌ ممطرنا. فنَزَلَت الريح، فنَسَفَت الرّعاة، فجَعَلتْ تمرُّ على الرجل بغنمه ورعاته حتى يعرفها، ثم يحلّق بهم في السماء حتى تقذفهم في البحر، ثم نَسَفَت البيوت حتى جعلتهم كالرميم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٤<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحي</span>: <span class="qpc-hafs">﴿إلا جَعَلَتْهُ كالرَّمِيمِ﴾</span> كالتُّراب المدقوق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كالرميم﴾</span>، قال: الشيء الهالك{4}. (١٣/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- قال: <span class="qpc-hafs">﴿إلا جَعَلَتْهُ كالرَّمِيمِ﴾</span> الهامد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿إلا جَعَلَتْهُ كالرَّمِيمِ﴾</span> كالتِّبن اليابس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</span>، قال: كرميم الشجر{7}<span class=comment-ref>٦٢١٠</span>. (١٣/٦٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٠</span> لم يذكر <u>ابنُ جرير</u> (٢١/٥٤٠-٥٤١) غير قول قتادة، ومجاهد من طريق ابن أبي نجيح، وابن عباس من طريق عطية العوفي.</div></p><p><div></p><p><p><span class="item-no">٧٢٦٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما تَذَرُ﴾</span> تلك الريح <span class="qpc-hafs">﴿مِن شَيْءٍ أتَتْ عَلَيْهِ﴾</span> مِن أنفسهم وأنعامهم وأموالهم <span class="qpc-hafs">﴿إلّا جَعَلَتْهُ كالرَّمِيمِ﴾</span> يقول: إلا جعلته باليًا كالتُّراب، بعد ما كانوا مثل نخلٍ منقعرٍ صاروا رميمًا{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٤٠.|2:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٣٩-٤٠ (٨٢).|3:تفسير البغوي ٧/٣٧٨.|4:تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٤٠. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه إسحاق البستي ص٤٣٣.|6:تفسير البغوي ٧/٣٧٨.|7:أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٤٠-٥٤١، وبنحوه من طريق سعيد.|8:تفسير مقاتل بن سليمان ٤/١٣٢. وفي تفسير الثعلبي ٩/١١٨ نحو آخره مختصرًا منسوبًا إلى مقاتل دون تعيينه.
  51,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِی ثَمُودَ إِذۡ قِیلَ لَهُمۡ تَمَتَّعُوا۟ حَتَّىٰ حِینࣲ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وفِي ثَمُودَ إذْ قِيلَ لَهُمْ تَمَتَّعُوا حَتّى حِينٍ﴾</span>، قال: ثلاثة أيام{1}. (١٣/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي ثَمُودَ﴾</span> آية <span class="qpc-hafs">﴿إذْ قِيلَ لَهُمْ﴾</span> قال لهم نبيُّهم صالح: <span class="qpc-hafs">﴿تَمَتَّعُوا حَتّى حِينٍ﴾</span> يعني: إلى آجالكم{2}<span class=comment-ref>٦٢١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١١</span> ذكر <u>ابنُ كثير</u> (١٣/٢٢١) نحو ما جاء في قول مقاتل عن ابن جرير، ثم قال <span class="comment-type-4">معلّقًا</span>: «والظاهر أن هذه <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿وأما ثمود فهديناهم فاستحبوا العمى على الهدى فأخذتهم صاعقة العذاب الهون﴾</span> [فصلت:١٧]. وهكذا قال هاهنا: <span class="qpc-hafs">﴿وفي ثمود إذ قيل لهم تمتعوا حتى حين فعتوا عن أمر ربهم فأخذتهم الصاعقة وهم ينظرون﴾</span>، وذلك أنهم انتظروا العذاب ثلاثة أيام، وجاءهم في صبيحة اليوم الرابع بكرة النهار».</p><p>وذكر <u>ابنُ عطية</u> (٨/٧٨) في قوله: <span class="qpc-hafs">﴿تمتعوا حتى حين﴾</span> <b>احتمالين،</b> و<span class="comment-type-4">رتّب عليهما المعنى</span> في قوله: <span class="qpc-hafs">﴿فعتوا عن أمر ربهم﴾</span>، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿وفي ثمود إذ قيل لهم تمتعوا حتى حين﴾</span> <b>يحتمل</b> أن يريد: إذ قيل لهم في أول بعْث صالح: آمِنوا وأطيعوا فتمتعوا متاعًا حسنًا إلى آجالكم. وهو الحين على هذا التأويل، وهو قول الحسن حكاه عنه الرماني، ويجيء قوله تعالى: <span class="qpc-hafs">﴿فعتوا﴾</span> مُرتّبًا لفظًا في الآية ومعنًى في الوجود متأخرًا عن القول لهم تمتعوا، <b>ويحتمل</b> أن يريد: إذ قيل لهم بعد عقر الناقة: تمتّعوا في داركم ثلاثة. وهي الحين على هذا التأويل، وهو قول الفراء، ويجيء قوله: <span class="qpc-hafs">﴿فعتوا﴾</span> غير مُرتّب المعنى في وجوده؛ لأن عُتوّهم كان قبل أن يقال لهم: تمتعوا، وكأن المعنى فكان من أمرهم قبل هذه المقالة أنْ عتَوا، وهو السبب في أن قيل لهم ذلك وعُذّبوا».</div></p></div>",footnotes:1:أخرجه البيهقي في سننه ١٠/٦٢.|2:تفسير مقاتل بن سليمان ٤/١٣٢.
  51,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَعَتَوۡا۟ عَنۡ أَمۡرِ رَبِّهِمۡ فَأَخَذَتۡهُمُ ٱلصَّـٰعِقَةُ وَهُمۡ یَنظُرُونَ ۝٤٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٠٢<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عمرو بن ميمون الأْودي- أنه قرأ ذلك: ‹فَأَخَذَتْهُمُ الصَّعْقَةُ› بغير ألف{1}<span class=comment-ref>٦٢١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٢</span> ذكر <u>ابنُ جرير</u> (٢١/٥٤٣) هذه القراءة وقراءة مَن قرأ ذلك بالألف: <span class="qpc-hafs">﴿الصاعقة﴾</span>، ثم <span class="comment-type-3">رجّحها</span> <span class="mustanad">مستندًا لإجماع الحجة من القراء،</span> فقال: «وبالألف نقرأ <span class="qpc-hafs">﴿الصاعقة﴾</span>؛ لإجماع الحجة من القراء عليها».</p><p>وذكرهما <u>ابنُ عطية</u> (٨/٧٩)، ثم قال <span class="comment-type-4">معلّقًا</span>: «وهي على القراءتين: الصيحة العظيمة».</div></p><p><h3><span class="qpc-hafs">﴿فَعَتَوۡا۟ عَنۡ أَمۡرِ رَبِّهِمۡ فَأَخَذَتۡهُمُ ٱلصَّـٰعِقَةُ وَهُمۡ یَنظُرُونَ ۝٤٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٠٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَأَخَذَتْهُمُ الصّاعِقَةُ﴾</span> الموت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَعَتَوْا﴾</span>، قال: عَلوا. وفي قوله: <span class="qpc-hafs">﴿فَأَخَذَتْهُمُ الصّاعِقَةُ وهُمْ يَنْظُرُونَ﴾</span>، قال: فجأة{3}. (١٣/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿فَأَخَذَتْهُمُ الصّاعِقَةُ وهُمْ يَنْظُرُونَ﴾</span>: وهم ينتظرون، وذلك أنّ ثمود وُعِدت العذاب قبل نزوله بهم بثلاثة أيام، وجعل لنزوله عليهم علامات في تلك الثلاثة، فظهرت العلامات التي جُعلتْ لهم الدّالة على نزولها في تلك الأيام، فأصبحوا في اليوم الرابع موقنين بأنّ العذاب بهم نازل، ينتظرون حلوله بهم{4}<span class=comment-ref>٦٢١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٣</span> ذكر <u>ابنُ عطية</u> (٨/٧٩) في قوله: <span class="qpc-hafs">﴿وهم ينظرون﴾</span> <b>احتمالين</b>، فقال: «وقوله: <span class="qpc-hafs">﴿وهم ينظرون﴾</span> <b>يحتمل</b> أن يريد: فجأة وهم يُبصرون بعيونهم حالهم، <b>ويحتمل</b> أن يريد: وهم ينظرون ذلك في تلك الأيام الثلاثة التي أُعلموا به فيها ورأوا علاماته في تلوّنه. وهذا قول مجاهد».</div></p><p><div></p><p><p><span class="item-no">٧٢٧٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَعَتَوْا﴾</span> يقول: فعَصَوا <span class="qpc-hafs">﴿عَنْ أمْرِ رَبِّهِمْ فَأَخَذَتْهُمُ الصّاعِقَةُ﴾</span> يعني: العذاب، وهو الموت، من صيحة جبريل <span class="qpc-hafs">﴿وهُمْ يَنْظُرُونَ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٠٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَعَتَوْا عَنْ أمْرِ رَبِّهِمْ﴾</span>، قال: العاتي: العاصي التارك لأمر الله ﷿{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٤٢.</p><p>وهي قراءة متواترة، قرأ بها الكسائي، وقرأ الباقون: <span class="qpc-hafs">﴿فَأَخَذَتْهُمُ الصّاعِقَةُ﴾</span> بالألف. انظر: النشر ٢/٣٧٧، والإتحاف ص٥١٧.|2:تفسير البغوي ٧/٣٧٨.|3:تفسير مجاهد ص٦٢٠، وأخرجه ابن جرير ٢١/٥٤٢ بنحوه. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر.|4:أخرجه ابن جرير ٢١/٥٤٢.|5:تفسير مقاتل بن سليمان ٤/١٣٢. وفي تفسير البغوي ٧/٣٧٨ نحو آخره مختصرًا منسوبًا إلى مقاتل دون تعيينه.|6:أخرجه ابن جرير ٢١/٥٤١.
  51,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا ٱسۡتَطَـٰعُوا۟ مِن قِیَامࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</span>، قال: ما استطاع القوم نهوضًا لعقوبة الله -تبارك وتعالى-{1}<span class=comment-ref>٦٢١٤</span>. (١٣/٦٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٤</span> لم يذكر <u>ابنُ جرير</u> (٢١/٥٤٣) عن السلف غير قول قتادة. ثم ذكر <b>قولًا عن بعض أهل اللغة</b>، فقال: «وكان بعض أهل العربية يقول: معنى قوله: <span class="qpc-hafs">﴿فما استطاعوا من قيام﴾</span>: فما قاموا بها. قال: لو كانت فما استطاعوا من إقامة، لكان صوابًا، وطرح الألف منها <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿أنبتكم من الأرض نباتا﴾</span> [نوح:١٧]».</p><p>ونقل <u>ابنُ عطية</u> (٨/٧٩) عن قتادة وغيره في قوله: <span class="qpc-hafs">﴿مِن قِيامٍ﴾</span> أنّ «معناه: من قيام بالأمر ودفعْه». و<span class="comment-type-1">وجَّهه</span> بقوله: «كما تقول: فلان له بكذا وكذا قيام، أي: استصلاح وانتهاض».</div></p><p><div></p><p><p><span class="item-no">٧٢٧٠٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</span> فما أطاقوا أن يقوموا للعذاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</span>، يعني: أن يقوموا للعذاب حين غَشِيهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧١١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿فَما اسْتَطاعُوا مِن قِيامٍ﴾</span>، قال: لم يستطيعوا أن ينهضوا بعقوبة الله إذ نَزَلَتْ بهم{4}. (١٣/٦٨٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا كَانُوا۟ مُنتَصِرِینَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وما كانُوا مُنْتَصِرِينَ﴾</span>، قال: ما كانت عندهم مِن قُوّة يمتنعون بها مِن الله ﷿{5}<span class=comment-ref>٦٢١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٥</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/٥٤٣) في تفسير الآية: «وقوله: <span class="qpc-hafs">﴿وما كانوا منتصرين﴾</span> يقول: وما كانوا قادرين على أن يستقيدوا مِمَّن أحلّ بهم العقوبة التي حلّتْ بهم». <span class="mustanad">ثم ذكر قول قتادة</span> ولم يعلّق عليه.</div></p><p><div></p><p><p><span class="item-no">٧٢٧١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما كانُوا مُنْتَصِرِينَ﴾</span>، يعني: ممتنعين من العذاب حين أُهلكوا {3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وما كانُوا مُنْتَصِرِينَ﴾</span>، قال:لم يستطيعوا امتناعًا مِن أمر الله{4}. (١٣/٦٨٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٤٣، كذلك أخرجه عبد الرزاق ٢/٢٤٥، وابن جرير ٢١/٥٤٣ من طريق معمر بلفظ: من نهوض.|2:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٨٩-.|3:تفسير مقاتل بن سليمان ٤/١٣٢.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ٢١/٥٤٣-٥٤٤.|6:تفسير مقاتل بن سليمان ٤/١٣٢.|7:عزاه السيوطي إلى ابن المنذر.
  51,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَوۡمَ نُوحࣲ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٤٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٢٧١٥<span class="dash">-</span></span> عن هارون الأعور، عن <span class="name-2">أبي عمرو بن العلاء</span>: ‹وقَوْمِ نُوحٍ مِّن قَبْلُ›، يقول: وفي قوم نوح{1}<span class=comment-ref>٦٢١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٦</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (٢١/٥٤٤-٥٤٥) هذه القراءة، فقال: «وقرأ ذلك عامة قراء الكوفة والبصرة: <span class="qpc-hafs">﴿وقومِ نوح﴾</span> بخفض القوم على معنى: وفي قوم نوح عطفًا بالقوم على موسى في قوله: <span class="qpc-hafs">﴿وفي موسى إذ أرسلناه إلى فرعون﴾</span>». و<span class="comment-type-1">وجّه</span> معنى الآية عليها، فقال: «وتأويل ذلك في قراءة مَن قرأه خفضًا: وفي قوم نوح لهم أيضًا عبرة إذ أهلكناهم من قبل ثمود لمّا كذبوا رسولنا نوحًا؛ <span class="qpc-hafs">﴿إنهم كانوا قوما فاسقين﴾</span> يقول: إنهم كانوا مخالفين أمر الله، خارجين عن طاعته».</p><p>و<span class="comment-type-4">جعلها</span> <u>ابنُ عطية</u> (٨/٧٩-٨٠) على هذه القراءة معطوفة على قوله: <span class="qpc-hafs">﴿وفي ثمود﴾</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> قراءة مَن قرأ ذلك بنصب: <span class="qpc-hafs">﴿وقوم﴾</span>، وذكر فيها عدة احتمالات رتّب عليها معنى الآية، فقال: «ولنَصْب ذلك وجوه: <b>أحدها</b>: أن يكون القوم عطفًا على الهاء والميم في قوله: <span class="qpc-hafs">﴿فأخذتهم الصاعقة﴾</span>؛ إذ كان كل عذاب مُهلك تسمّيه العرب: صاعقة، فيكون معنى الكلام حينئذ: فأخذتهم الصاعقة وأخذتْ قوم نوح من قبل. <b>والثاني</b>: أن يكون منصوبًا بمعنى الكلام، إذ كان فيما مضى من أخبار الأمم قبل دلالة على المراد من الكلام، وأن معناه: أهلكنا هذه الأمم وأهلكنا قوم نوح من قبل. <b>والثالث</b>: أن يضمر له فعلًا ناصبًا، فيكون معنى الكلام: واذكر لهم قوم نوح، <span class="mustanad">كما قال</span>: <span class="qpc-hafs">﴿وإبراهيم إذ قال لقومه﴾</span> [العنكبوت:١٦] ونحو ذلك، بمعنى: أخبِرهم واذكر لهم». وعلى هذه القراءة ففي عطفها <b>احتمالين</b> <span class="comment-type-4">ذكرهما</span> <u>ابنُ عطية</u>، فقال: «وهو عطف إما على الضمير في قوله: <span class="qpc-hafs">﴿فأخذتهم﴾</span> إذ هو بمنزلة: أهلكناهم، وإما على الضمير في قوله: <span class="qpc-hafs">﴿نبذناهم﴾</span>».</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u>: أنهما «قراءتان معروفتان في قراءة الأمصار؛ فبأيتهما قرأ القارئ فمصيب».</p><p>وزاد <u>ابنُ عطية</u> أن ذلك قُرأ بالرفع، و<span class="comment-type-1">وجّهه</span>، فقال: «وقرأ أبو عمرو فيما روى عنه عبد الوارث: (وقَوْمُ نُوحٍ) بالرفع، وذلك على الابتداء وإضمار الخبر».</div></p><p><h3><span class="qpc-hafs">﴿وَقَوۡمَ نُوحࣲ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٤٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٢٧١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>في <span class="qpc-hafs">﴿قَوْمَ نُوحٍ﴾</span> آية <span class="qpc-hafs">﴿مِن قَبْلُ﴾</span> هؤلاء الذين ذكر <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَوْمًا فاسِقِينَ﴾</span> يعني: عاصين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٤٣٣.</p><p>وهي قراءة متواترة، قرأ بها أبو عمرو، وحمزة، والكسائي، وخلف، وقرأ الباقون: <span class="qpc-hafs">﴿قَوْمَ نُوحٍ﴾</span> بالنصب. النشر ٢/٣٧٧، والإتحاف ص٥١٧.|2:تفسير مقاتل بن سليمان ٤/١٣٢.
  51,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّمَاۤءَ بَنَیۡنَـٰهَا بِأَیۡی۟دࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: بقُوّة{1}. (١٣/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧١٨<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جُبَيْر]</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: بقُوّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧١٩<span class="dash">-</span></span> عن <span class="name-2">حمّاد [بن أبي سليمان]</span> -من طريق رقبة- في قوله: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: بقُوّة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٠<span class="dash">-</span></span> وكذلك قال <span class="name-2">إبراهيم [النخعي]</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: يعني: بقُوّة{4}. (١٣/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>: أي: بقُوّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٣<span class="dash">-</span></span> عن <span class="name-2">منصور بن المعتمر</span> -من طريق شعبة- أنه قال في هذه الآية: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: بقُوّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٤<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿بنيناها بأيد﴾</span>، قال: الأيد: القوة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>في <span class="qpc-hafs">﴿السَّماءَ﴾</span> آية <span class="qpc-hafs">﴿بَنَيْناها بِأَيْدٍ﴾</span> يعني: بقُوّة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: بقوة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span>، قال: بقُوّة؛ بشِدّة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَمُوسِعُونَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٢٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span> قادرون{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٢٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span> لَمُوسعون الرّزق على خَلْقنا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٠<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span> أغنياء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span> مُطيقون{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٢<span class="dash">-</span></span> عن <span class="name-2">ابن أبي نجيح</span>، في قوله: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span>، قال: أن نخلق سماء مثلها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span>، يعني: نحن قادرون على أن نُوسعها كما نريد{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span>، قال: لنخلق سماء مثلها{17}. (١٣/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإنّا لَمُوسِعُونَ﴾</span>، قال: أوسعها جلّ جلاله{5}<span class=comment-ref>٦٢١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٧</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢١/٥٤٦): «وقوله: <span class="qpc-hafs">﴿وإنا لموسعون﴾</span> يقول: لذو سَعة بخلْقها وخلْق ما شئنا أن نخلقه وقدرة عليه، <span class="mustanad">ومنه قوله</span>: <span class="qpc-hafs">﴿على الموسع قدره وعلى المقتر قدره﴾</span> [البقرة:٢٣٦]، يراد به: القوي». <span class="mustanad">وذكر قول ابن زيد</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٨٠) في قوله: <span class="qpc-hafs">﴿وإنا لموسعون﴾</span> <b>احتمالين</b>، فقال: «وقوله: <span class="qpc-hafs">﴿لموسعون﴾</span> <b>يحتمل</b> أن يريد: إنّا نوسع الأشياء قوة وقدرة، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿على الموسع قدره﴾</span> [البقرة:٢٣٦] أي: الذي يوسع أهله إنفاقًا، <b>ويحتمل</b> أن يريد: لموسعون في بناء السماء، أي: جعلناها واسعة». ونقل عن الحسن قوله: «أوسع الرزق بمطر السماء».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٤٥، وابن أبي حاتم -كما في الإتقان ٢/٤٤-، والبيهقي في الأسماء والصفات (٢٥٢). وعزاه السيوطي إلى ابن المنذر.|2:أخرجه أبو جعفر الرملي في جزئه (تفسير يحيى بن يمان) ص٣٨، وإسحاق البستي ص٤٣٥.|3:أخرجه إسحاق البستي ص٤٣٥.|4:تفسير مجاهد ص٦٢١، وأخرجه ابن جرير ٢١/٥٤٥، والبيهقي (٢٥٣).|5:أخرجه ابن جرير ٢١/٥٤٦.|6:أخرجه ابن جرير ٢١/٥٤٦.|7:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٤.|8:تفسير مقاتل بن سليمان ٤/١٣٢.|9:أخرجه ابن جرير ٢١/٥٤٦.|10:أخرجه ابن جرير ٢١/٥٤٦.|11:تفسير البغوي ٧/٣٧٩.|12:تفسير البغوي ٧/٣٧٩.|13:تفسير البغوي ٧/٣٧٩.|14:تفسير البغوي ٧/٣٧٩.|15:أخرجه ابن أبي حاتم -في الفتح ٨/٦٠٠-.|16:تفسير مقاتل بن سليمان ٤/١٣٢.|17:عزاه السيوطي إلى ابن جرير، وابن المنذر.|18:أخرجه ابن جرير ٢١/٥٤٦.
  51,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ فَرَشۡنَـٰهَا فَنِعۡمَ ٱلۡمَـٰهِدُونَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٣٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَنِعْمَ الماهِدُونَ﴾</span> نِعم ما وطَّأتُ لعبادي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>في <span class="qpc-hafs">﴿الأَرْضَ﴾</span> آية <span class="qpc-hafs">﴿فَرَشْناها﴾</span> مسيرة خمسمائة عام في خمسمائة عام من تحت الكعبة، <span class="qpc-hafs">﴿فَنِعْمَ الماهِدُونَ﴾</span> يعني الرّبُّ تعالى: نفسَه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٣٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿والأَرْضَ فَرَشْناها فَنِعْمَ الماهِدُونَ﴾</span>، قال: الفارشون{3}. (١٣/٦٨٦)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/٣٧٩.|2:تفسير مقاتل بن سليمان ٤/١٣٢-١٣٣.|3:عزاه السيوطي إلى ابن جرير، وابن المنذر.
  51,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن كُلِّ شَیۡءٍ خَلَقۡنَا زَوۡجَیۡنِ لَعَلَّكُمۡ تَذَكَّرُونَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</span>، قال: الكفر والإيمان، والشّقوة والسعادة، والهُدى والضّلالة، والليل والنهار، والسماء والأرض، والجنّ والإنس، والبَرّ والبحر، والشمس والقمر، وبُكرة وعشِيّة، ونحو هذا كله{1}. (١٣/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</span>، قال: الشمس والقمر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٤١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</span> هو كقوله: <span class="qpc-hafs">﴿وأَنَّهُ خَلَقَ الزَّوْجَيْنِ الذَّكَرَ والأُنْثى﴾</span> [النجم:٤٥] الذَّكر زوج، والأنثى زوج{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</span> يعني: صنفين، يعني: الليل والنهار، والدنيا والآخرة، والشمس والقمر، والبَرّ والبحر، والشتاء والصيف، والبَرْد والحرّ، والسَّهل والجبل، والسَّبخة والعذبة؛ <span class="qpc-hafs">﴿لَعَلَّكُمْ تَذَكَّرُونَ﴾</span> فيما خلق أنّه ليس له عدل ولا مثيل، فتوحِّدونه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومِن كُلِّ شَيْءٍ خَلَقْنا زَوْجَيْنِ﴾</span>، قال: ذكرًا وأنثى، ذاك الزّوجان. وقرأ: <span class="qpc-hafs">﴿وأَصْلَحْنا لَهُ زَوْجَهُ﴾</span> [الأنبياء:٩٠]، قال: امرأته{5}<span class=comment-ref>٦٢١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١٨</span> في قوله: <span class="qpc-hafs">﴿خلقنا زوجين﴾</span> قولان: <b>الأول</b>: ومن كل شيء خلقنا نوعين مختلفين؛ كالشقاء والسعادة، والهدى والضلالة، ونحو ذلك. <b>الثاني</b>: عنى بالزوجين: الذكر والأنثى.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢١/٥٤٨) -<span class="mustanad">مستندًا إلى دلالة العقل-</span> القول الأول، فقال: «وأولى القولين في ذلك قول مجاهد، وهو أن الله -تبارك وتعالى- خلق لكل ما خلق مِن خلْقه ثانيًا له مخالفًا في معناه، فكلّ واحد منهما زوج للآخر، ولذلك قيل: خلقنا زوجين، وإنما نبّه -جلّ ثناؤه- بذلك من قوله على قدرته على خلْق ما يشاء خلْقه مِن شيء، وأنّه ليس كالأشياء التي شأنها فعل نوع واحد دون خلافه؛ إذ كل ما صفته فعل نوع واحد دون ما عداه كالنار التي شأنها التسخين، ولا تصلح للتبريد، وكالثلج الذي شأنه التبريد، ولا يصلح للتسخين، فلا يجوز أن يوصف بالكمال، وإنما كمال المدح للقادر على فعل كلّ ما شاء فعله مِن الأشياء المختلفة والمتفقة».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢١/٥٤٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢١/٥٤٧.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٢٩٠-.|4:تفسير مقاتل بن سليمان ٤/١٣٣.|5:أخرجه ابن جرير ٢١/٥٤٨.
  51,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَفِرُّوۤا۟ إِلَى ٱللَّهِۖ إِنِّی لَكُم مِّنۡهُ نَذِیرࣱ مُّبِینࣱ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٤٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَفِرُّوا إلى اللَّهِ﴾</span> فِرُّوا منه إليه، واعملوا بطاعته{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٤٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن عبد الله بن عمرو بن عثمان بن عفان</span> -من طريق محمد بن معز- في قوله سبحانه: <span class="qpc-hafs">﴿فَفِرُّوا إلى اللَّهِ﴾</span>، قال: اخرجوا إلى مكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٢٧٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَفِرُّوا إلى اللَّهِ﴾</span> مِن ذنوبكم، <span class="qpc-hafs">﴿إنِّي لَكُمْ مِنهُ نَذِيرٌ مُبِينٌ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١١٩، وتفسير البغوي ٧/٣٧٩.|2:أخرجه الثعلبي ٩/١١٩.|3:تفسير مقاتل بن سليمان ٤/١٣٣.
  51,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَجۡعَلُوا۟ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَۖ إِنِّی لَكُم مِّنۡهُ نَذِیرࣱ مُّبِینࣱ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٢٧٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَجْعَلُوا مَعَ اللَّهِ إلهًا آخَرَ﴾</span> فإن فعلتم فـ<span class="qpc-hafs">﴿إنِّي لَكُمْ مِنهُ نَذِيرٌ﴾</span> يعني: مِن عذابه <span class="qpc-hafs">﴿مُبِينٌ﴾</span>، فرَدُّوا عليه: إنك ساحر مجنون{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٣٣.