quran[8]{c,v,t}:
34,32," <q>﴿قَالَ ٱلَّذِینَ ٱسۡتَكۡبَرُوا۟ لِلَّذِینَ ٱسۡتُضۡعِفُوۤا۟ أَنَحۡنُ صَدَدۡنَـٰكُمۡ عَنِ ٱلۡهُدَىٰ بَعۡدَ إِذۡ جَاۤءَكُمۖ بَلۡ كُنتُم مُّجۡرِمِینَ ۝٣٢﴾</q> - تفسير ٦٣٥٣٢- قال إسماعيل السُّدِّيّ: <q>﴿عَنِ الهُدى﴾</q>، يعني: عن الإيمان{1}. (ز) ٦٣٥٣٣- قال مقاتل بن سليمان: فرَدَّت القادة -وهم الكبراء- على الضعفاء -وهم الأتباع-: <q>﴿قالَ الَّذِينَ اسْتَكْبَرُوا لِلَّذِينَ اسْتُضْعِفُوا أنَحْنُ صَدَدْناكُمْ عَنِ الهُدى﴾</q> يعني: أنحنُ منعناكم عن الإيمان <q>﴿بَعْدَ إذْ جاءَكُمْ بَلْ كُنْتُمْ مُجْرِمِينَ﴾</q>{2}. (ز) ٦٣٥٣٤- قال يحيى بن سلّام: <q>﴿قالَ الَّذِينَ اسْتَكْبَرُوا﴾</q> يعني: الكبراء والقادة في الكفر <q>﴿لِلَّذِينَ اسْتُضْعِفُوا﴾</q> يعني: الأتباع: <q>﴿أنَحْنُ صَدَدْناكُمْ﴾</q> على الاستفهام <q>﴿عَنِ الهُدى﴾</q> يعني: عن الإيمان <q>﴿بَعْدَ إذْ جاءَكُمْ بَلْ كُنْتُمْ مُجْرِمِينَ﴾</q> مشركين{3}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٧٦٢.تفسير مقاتل بن سليمان ٣/٥٣٤.تفسير يحيى بن سلام ٢/٧٦٢.
34,33," <q>﴿وَقَالَ ٱلَّذِینَ ٱسۡتُضۡعِفُوا۟ لِلَّذِینَ ٱسۡتَكۡبَرُوا۟ بَلۡ مَكۡرُ ٱلَّیۡلِ وَٱلنَّهَارِ﴾</q> - تفسير ٦٣٥٣٥- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q>، قال: مَرُّ الليل والنهار{1}. (١٢/٢١٩) ٦٣٥٣٦- عن الحسن البصري -من طريق عمرو-: <q>﴿وقالَ الَّذِينَ اسْتُضْعِفُوا﴾</q> بنو آدم، <q>﴿لِلَّذِينَ اسْتَكْبَرُوا﴾</q> الشياطين{2}. (ز) ٦٣٥٣٧- عن الحسن البصري، في قوله: <q>﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q>: أي: بل مكركم بالليل والنهار، أي: كذبكم وكفركم{3}. (ز) ٦٣٥٣٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q>، قال: بل مكركم بالليل والنهار{4}. (١٢/٢١٩) ٦٣٥٣٩- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q>، يقول: غرَّكم اختلاف الليل والنهار{5}. (١٢/٢١٨) ٦٣٥٤٠- عن محمد بن السائب الكلبي، قال: <q>﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q> بل قولكم لنا بالليل والنهار{3}. (ز) ٦٣٥٤١- قال مقاتل بن سليمان: فرَدَّتِ الضعفاءُ على الكبراء، فقالوا: <q>﴿وقالَ الَّذِينَ اسْتُضْعِفُوا لِلَّذِينَ اسْتَكْبَرُوا بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q> بل قولهم كذب بالليل والنهار{7}. (ز) ٦٣٥٤٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q>، قال: بل مكركم بنا في الليل والنهار، يا أيها العظماء الرؤساء، حتى أزَلْتُمُونا عن عبادة الله{8}. (١٢/٢١٩) ٦٣٥٤٣- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿بل مكر الليل والنهار إذ تأمروننا أن نكفر بالله ونجعل له أندادًا﴾</q>، قال: أعمالكم بالليل والنهار. قال سفيان: وكل مكر في القرآن فهو عمل{9}. (ز) ٦٣٥٤٤- قال يحيى بن سلّام: <q>﴿وقالَ الَّذِينَ اسْتُضْعِفُوا لِلَّذِينَ اسْتَكْبَرُوا بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</q>، أي: بل مكركم بالليل والنهار{10}. (ز) <q>﴿إِذۡ تَأۡمُرُونَنَاۤ أَن نَّكۡفُرَ بِٱللَّهِ وَنَجۡعَلَ لَهُۥۤ أَندَادࣰاۚ﴾</q> - تفسير ٦٣٥٤٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ونَجْعَلَ لَهُ أنْدادًا﴾</q>: شركاء{11}. (ز) ٦٣٥٤٦- قال مقاتل بن سليمان: <q>﴿إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ﴾</q> بتوحيد الله ﷿، <q>﴿ونَجْعَلَ لَهُ أنْدادًا﴾</q> يعني: وتأمرونا أن نجعل له شريكًا{7}. (ز) ٦٣٥٤٧- قال يحيى بن سلّام: <q>﴿إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ ونَجْعَلَ لَهُ أنْدادًا﴾</q>، يعني: أوثانهم عدَلوها بالله؛ فعبدوها دونه{10}. (ز) <q>﴿وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلۡعَذَابَۚ﴾</q> - تفسير ٦٣٥٤٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وأَسَرُّوا النَّدامَةَ﴾</q> بينهم <q>﴿لَمّا رَأَوُا العَذابَ﴾</q>{11}٥٣٣٨. (ز) ٥٣٣٨ لم يذكر ابنُ جرير (١٩/٢٩٢-٢٩٣) في معنى: <q>﴿وأَسَرُّوا النَّدامَةَ لَمّا رَأَوُا العَذابَ﴾</q> سوى قول قتادة. ونقل ابنُ عطية (٧/١٨٩) عن بعض الناس أن <q>﴿وأَسَرُّوا﴾</q> بمعنى: «أظهروا، وهي من الأضداد». ثم علَّق بقوله: «وهذا كلام مَن لم يعتبر المعنى، أمّا نفس الندامة فلا تكون إلا مُسْتَسَرَّة ضرورة، وأما الظاهر عنها فغيرها، ولم يثبت قط في لغة أن»أسَرَّ«من الأضداد». ٦٣٥٤٩- قال مقاتل بن سليمان: <q>﴿وأَسَرُّوا النَّدامَةَ﴾</q> في أنفسهم <q>﴿لَمّا رَأَوُا العَذابَ﴾</q> حين عاينوا العذاب في الآخرة{7}. (ز) ٦٣٥٥٠- قال يحيى بن سلّام: <q>﴿وأَسَرُّوا النَّدامَةَ﴾</q> في أنفسهم يوم القيامة <q>﴿لَمّا رَأَوُا العَذابَ﴾</q>{10}. (ز) <q>﴿وَجَعَلۡنَا ٱلۡأَغۡلَـٰلَ فِیۤ أَعۡنَاقِ ٱلَّذِینَ كَفَرُوا۟ۖ هَلۡ یُجۡزَوۡنَ إِلَّا مَا كَانُوا۟ یَعۡمَلُونَ ۝٣٣﴾</q> - تفسير ٦٣٥٥١- قال مقاتل بن سليمان: <q>﴿وجَعَلْنا الأَغْلالَ فِي أعْناقِ الَّذِينَ كَفَرُوا﴾</q> وذلك أنّ الله ﷿ يأمر خزنة جهنم أن يجعلوا الأغلال في أعناق الذين كفروا بتوحيد الله ﷿، وقالت لهم الخزنة: <q>﴿هَلْ يُجْزَوْنَ﴾</q> في الآخرة <q>﴿إلّا ما كانُوا يَعْمَلُونَ﴾</q> مِن الكفر في الدنيا{17}. (ز) ٦٣٥٥٢- قال يحيى بن سلّام: <q>﴿وجَعَلْنا الأَغْلالَ فِي أعْناقِ الَّذِينَ كَفَرُوا هَلْ يُجْزَوْنَ إلّا﴾</q> على الاستفهام <q>﴿ما كانُوا يَعْمَلُونَ﴾</q> أي: أنّهُم لا يُجْزَون إلا ما كانوا يعملون{10}. (ز) <q>﴿وَجَعَلۡنَا ٱلۡأَغۡلَـٰلَ فِیۤ أَعۡنَاقِ ٱلَّذِینَ كَفَرُوا۟ۖ هَلۡ یُجۡزَوۡنَ إِلَّا مَا كَانُوا۟ یَعۡمَلُونَ ۝٣٣﴾</q> - آثار متعلقة بالآية ٦٣٥٥٣- عن الحسن بن يحيى الخُشني قال: ما في جهنم دارٌ، ولا مغارٌ، ولا غلٌّ، ولا قيد، ولا سلسلة إلا اسمُ صاحبها عليه مكتوب.= (ز) ٦٣٥٥٤- فحُدِّث به أبو سليمان الداراني فبكى، ثم قال: فكيف به لو جُمِع هذا كله عليه، فجُعل القيد في رجليه، والغل في يديه، والسلسلة في عنقه، ثم أُدخل الدار، وأُدخل المغار؟!{19}. (١٢/٢١٩) ",footnotes:1:أخرجه ابن أبي شيبة ١٣/٥٣٩، وابن جرير ١٩/٢٩٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ٢/٧٦٣.علقه يحيى بن سلام ٢/٧٦٣.أخرجه عبد الرزاق ٢/١٣٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٧٦٣.تفسير مقاتل بن سليمان ٣/٥٣٤.أخرجه ابن جرير ١٩/٢٩٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي ص١٥٧.تفسير يحيى بن سلام ٢/٧٦٣.أخرجه ابن جرير ١٩/٢٩٢.تفسير مقاتل بن سليمان ٣/٥٣٤.تفسير يحيى بن سلام ٢/٧٦٣.أخرجه ابن جرير ١٩/٢٩٢.تفسير مقاتل بن سليمان ٣/٥٣٤.تفسير يحيى بن سلام ٢/٧٦٣.تفسير مقاتل بن سليمان ٣/٥٣٤-٥٣٥.تفسير يحيى بن سلام ٢/٧٦٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٠٧-٥٠٨-.
34,34," <q>﴿وَمَاۤ أَرۡسَلۡنَا فِی قَرۡیَةࣲ مِّن نَّذِیرٍ إِلَّا قَالَ مُتۡرَفُوهَاۤ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٣٤﴾</q> - نزول الآية ٦٣٥٥٥- عن أبي رَزِين -من طريق سفيان بن عاصم- قال: كان رجلان شريكين، خرج أحدهما إلى الساحل، وبقي الآخر، فلما بُعِث النبيُّ ﷺ كتب إلى صاحبه يسأله: ما فعل؟ فكتب إليه أنّه لم يتبعه أحدٌ مِن قريش إلا رذالة الناس ومساكينهم، فترك تجارته، ثم أتى صاحبه، فقال: دُلَّني عليه. وكان يقرأ الكتب، فأتى النبيَّ ﷺ، فقال: إلامَ تدعو؟ قال: «إلى كذا وكذا». قال: أشهد أنّك رسول الله. قال: «وما عِلمُك بذلك؟». قال: إنّه لم يُبعَث نبيٌّ إلا اتبعه رذالة الناس ومساكينهم. فنزلت هذه الآية: <q>﴿وما أرْسَلْنا فِي قَرْيَةٍ مِن نَذِيرٍ إلّا قالَ مُتْرَفُوها﴾</q> الآيات. فأرسل إليه النبيُّ ﷺ: «إنّ اللهَ قد أنزل تصديقَ ما قلتَ»{1}. (١٢/٢٢٠) <q>﴿وَمَاۤ أَرۡسَلۡنَا فِی قَرۡیَةࣲ مِّن نَّذِیرٍ إِلَّا قَالَ مُتۡرَفُوهَاۤ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٣٤﴾</q> - تفسير الآية ٦٣٥٥٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إلّا قالَ مُتْرَفُوها﴾</q>، قال: هم جبابرتهم، ورؤوسهم، وأشرافهم، وقادتهم في الشر{2}. (١٢/٢٢٠) ٦٣٥٥٧- قال مقاتل بن سليمان: <q>﴿وما أرْسَلْنا فِي قَرْيَةٍ مِن نَذِيرٍ﴾</q> من رسول <q>﴿إلّا قالَ مُتْرَفُوها﴾</q> أغنياؤها وجبابرتها للرسل: <q>﴿إنّا بِما أُرْسِلْتُمْ بِهِ﴾</q> بالتوحيد <q>﴿كافِرُونَ﴾</q>{3}. (ز) ٦٣٥٥٨- عن عبد الملك ابن جريج، في قوله: <q>﴿إلّا قالَ مُتْرَفُوها﴾</q>، قال: جبابرتها{4}. (١٢/٢٢١) ٦٣٥٥٩- قال يحيى بن سلّام: <q>﴿وما أرْسَلْنا فِي قَرْيَةٍ مِن نَذِيرٍ﴾</q> من نبيٍّ يُنذرهم عذابَ الدنيا وعذابَ الآخرة <q>﴿إلّا قالَ مُتْرَفُوها﴾</q> جبابرتها، والمترفون: أهل السعة والنعمة: <q>﴿إنّا بِما أُرْسِلْتُمْ بِهِ كافِرُونَ﴾</q> فاتبعهم على ذلك السفلة، فجحدوا كلُّهم{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٠٨-. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر مرسلًا.أخرجه ابن جرير ١٩/٢٩٣ بنحوه، وعبد الرزاق ٢/١٩٥ من طريق معمر مختصرًا. وعلَّقه يحيى بن سلام ٢/٧٦٣ مقتصرًا على لفظ: جبابرتها. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٣٥.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ٢/٧٦٣.
34,35," <q>﴿وَقَالُوا۟ نَحۡنُ أَكۡثَرُ أَمۡوَ ٰ⁠لࣰا وَأَوۡلَـٰدࣰا وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝٣٥﴾</q> - تفسير ٦٣٥٦٠- قال مقاتل بن سليمان: <q>﴿وقالُوا﴾</q> أيضًا لفقراء المسلمين: أهؤلاء خَيرٌ مِنّا، أم هم أولى بالله مِنّا؟! <q>﴿نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا وما نَحْنُ بِمُعَذَّبِينَ﴾</q>{1}٥٣٣٩. (ز) ٥٣٣٩ ذكر ابنُ عطية (٧/١٨٩) احتمالًا آخر، فقال: «يحتمل أن يكون الضمير في <q>﴿قالوا﴾</q> لقريش، ويكون كلام المترفين قد تقدم، ثم تطَّرد الآية بعد». وذكر أن معنى: <q>﴿نَحْنُ أكْثَرُ أمْوالا وأَوْلادًا وما نَحْنُ بِمُعَذَّبِينَ﴾</q>: «الاحتجاج بأن الله لم يُعْطِنا هذا وقدَّره لنا إلا لرضاه عنّا وعن طريقتنا، ونحن ممن لا يُعَذَّب البَتَّة؛ إذ الله -الذي تزعم أنت علمَه بجميع الأشياء وإحاطته- قد قدَّر علينا النِّعم، فهو إذًا راضٍ عنّا». ثم ذكر عن بعض المفسرين أن معنى: <q>﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</q> أي: بالفقر، وانتقده قائلًا: «وهذا ليس كالأول في القوة». ٦٣٥٦١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</q>، قالوا: <q>﴿نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا﴾</q> فأخبرهم الله أنه ليست أموالكم ولا أولادكم بالتي تقربكم عندنا زلفى، <q>﴿إلّا مَن آمَنَ وعَمِلَ صالِحًا﴾</q> قال: وهذا قول المشركين لرسول الله ﷺ وأصحابه؛ قالوا: لو لم يكن الله عَنّا راضيًا لم يعطنا هذا. كما قال قارون: لولا أن الله رضي بي وبحالي ما أعطاني هذا. قال: <q>﴿أوَلَمْ يَعْلَمْ أنَّ اللَّهَ قَدْ أهْلَكَ مِن قَبْلِهِ مِنَ القُرُونِ﴾</q> [القصص:٧٨]{2}. (ز) ٦٣٥٦٢- قال يحيى بن سلّام: <q>﴿وقالُوا نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا﴾</q> قالوا ذلك للأنبياء والمؤمنين، يُعَيِّرونهم بالفقر وبقِلَّة المال، <q>﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</q>{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٥.تفسير يحيى بن سلام ٢/٧٦٣.
34,36," <q>﴿قُلۡ إِنَّ رَبِّی یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُ وَلَـٰكِنَّ أَكۡثَرَ ٱلنَّاسِ لَا یَعۡلَمُونَ ۝٣٦﴾</q> - تفسير ٦٣٥٦٣- قال مقاتل بن سليمان: <q>﴿قُلْ إنَّ رَبِّي يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ﴾</q> ويُقَتِّر على من يشاء، <q>﴿ولَكِنَّ أكْثَرَ النّاسِ﴾</q> كفار مكة <q>﴿لا يَعْلَمُونَ﴾</q> أنّ البسط والقتر بيد الله ﷿{1}. (ز) ٦٣٥٦٤- قال يحيى بن سلّام: <q>﴿قُلْ إنَّ رَبِّي يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ﴾</q> أي: ويُقَتِّر عليه الرزق، فأما المؤمن فذلك نظرٌ مِن الله له، <q>﴿ولَكِنَّ أكْثَرَ النّاسِ لا يَعْلَمُونَ﴾</q> يعني: جماعة المشركين لا يعلمون{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٣-٧٦٤.
34,37," <q>﴿وَمَاۤ أَمۡوَ ٰ⁠لُكُمۡ وَلَاۤ أَوۡلَـٰدُكُم بِٱلَّتِی تُقَرِّبُكُمۡ عِندَنَا زُلۡفَىٰۤ﴾</q> - تفسير ٦٣٥٦٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عِنْدَنا زُلْفى﴾</q>، قال: قُرْبى{1}. (١٢/٢٢١) ٦٣٥٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</q>، قال: لا تعتبروا الناس بكثرة المال والولد؛ وإنّ الكافر يُعطى المال، ورُبَّما حَبَسَهُ عن المؤمن{2}. (١٢/٢٢١) ٦٣٥٦٧- قال مقاتل بن سليمان: <q>﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</q>، يعني: قُرْبَة{3}. (ز) ٦٣٥٦٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</q>، قالوا: <q>﴿نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا﴾</q>. فأخبرهم الله أنّه ليست أموالكم ولا أولادكم بالتي تقربكم عندنا زلفى، <q>﴿إلّا مَن آمَنَ وعَمِلَ صالِحًا﴾</q>{4}. (ز) ٦٣٥٦٩- قال يحيى بن سلّام: <q>﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ﴾</q> يقوله للمشركين <q>﴿بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</q> والزلفى: القرابة؛ لقولهم للأنبياء والمؤمنين: نحن أكثر أموالًا وأولادًا منكم{5}. (ز) <q>﴿إِلَّا مَنۡ ءَامَنَ وَعَمِلَ صَـٰلِحࣰا﴾</q> - تفسير ٦٣٥٧٠- قال عبد الله بن عباس: <q>﴿وعَمِلَ صالِحًا﴾</q>، يريد: إيمانه وعمله يُقرِّبه مِنِّي{6}. (ز) ٦٣٥٧١- عن إسماعيل السُّدِّيّ: <q>﴿وعَمِلَ صالِحًا﴾</q> فإنّ ذلك يُقرِّب إلى الله{7}. (ز) ٦٣٥٧٢- قال مقاتل بن سليمان: <q>﴿إلّا مَن آمَنَ﴾</q> صدّق بالله، <q>﴿وعَمِلَ صالِحًا﴾</q>{3}. (ز) ٦٣٥٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿إلّا مَن آمَنَ وعَمِلَ صالِحًا﴾</q>، قال: لم تضرهم أموالهم ولا أولادهم في الدنيا؛ للمؤمنين. وقرأ: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q> [يونس:٢٦]، فالحسنى: الجنة. والزيادة: ما أعطاهم الله في الدنيا؛ لم يحاسبهم به كما حاسب الآخرين{9}٥٣٤٠. (ز) ٥٣٤٠ نقل ابنُ جرير (١٩/٢٩٧) عن بعضهم أنّ معنى قوله تعالى: <q>﴿وما أمْوالُكُمْ ولا أوْلادَكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى إلا مَن آمَنَ وعَمِلَ صالِحًا﴾</q>: «وما أموالكم ولا أولادكم بالتي تقرِّبكم عندنا زُلفى، إلا من آمن وعمل صالحًا، فإنه تُقَرِّبهم أموالهم وأولادهم -بطاعتهم الله في ذلك، وأدائهم فيه حقَّه إلى الله- زُلفى، دون أهل الكفر بالله». وذكر قول ابن زيد، ثم وجَّه هذا المعنى بقوله: «فـ<q>﴿من﴾</q> على هذا التأويل نصبٌ بوقوع»تقرب«عليه». ٦٣٥٧٤- قال يحيى بن سلّام: <q>﴿إلّا﴾</q> استثنى <q>﴿مَن آمَنَ﴾</q> أي: ليس القربة عندنا إلا لِمَن آمن، <q>﴿وعَمِلَ صالِحًا﴾</q> فإنّ ذلك يُقَرِّب إلى الله{5}. (ز) <q>﴿فَأُو۟لَـٰۤىِٕكَ لَهُمۡ جَزَاۤءُ ٱلضِّعۡفِ بِمَا عَمِلُوا۟﴾</q> - تفسير ٦٣٥٧٥- عن مجاهد بن جبر -من طريق عاصم بن حكيم- في قوله <q>﴿جَزاءُ الضِّعْفِ﴾</q>، قال: تضعيف الحسنة{11}. (١٢/٢٢٢) ٦٣٥٧٦- عن محمد بن كعب القرظي –من طريق ابي مودود- قال: إذا كان المؤمن غنيًّا تقيًّا آتاه الله أجرَه مرَّتين. وتلا هذه الآية: <q>﴿وما أمْوالُكُمْ﴾</q> إلى قوله: <q>﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ﴾</q> قال: تضعيف الحسنة{12}. (١٢/٢٢٢) ٦٣٥٧٧- قال مقاتل بن سليمان: <q>﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ بِما عَمِلُوا﴾</q> مِن الخير؛ نجزي بالحسنة الواحدة عشرةً فصاعدًا{3}. (ز) ٦٣٥٧٨- عن عبد الرحمن بن زيد بن أسلم، في قوله: <q>﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ بِما عَمِلُوا﴾</q>، قال: بأعمالهم، بالواحدة عشرًا، وفي سبيل الله بالواحد سبعمائة{14}. (١٢/٢٢٢) ٦٣٥٧٩- قال يحيى بن سلّام: <q>﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ﴾</q> قال: تضعيف الحسنات، كقوله: <q>﴿مَن جاءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</q> [الأنعام:١٦٠]، ثم نزل بعد ذلك بالمدينة: <q>﴿مَثَلُ الَّذِينَ يُنْفِقُونَ أمْوالَهُمْ فِي سَبِيلِ اللَّهِ كَمَثَلِ حَبَّةٍ أنْبَتَتْ سَبْعَ سَنابِلَ فِي كُلِّ سُنْبُلَةٍ مِائَةُ حَبَّةٍ واللَّهُ يُضاعِفُ لِمَن يَشاءُ﴾</q> [البقرة:٢٦١]، ثم صارت بعدُ في الأعمال الصالحة كلها؛ الواحد سبعمائة{15}. (ز) <q>﴿وَهُمۡ فِی ٱلۡغُرُفَـٰتِ ءَامِنُونَ ۝٣٧﴾</q> - تفسير ٦٣٥٨٠- قال مقاتل بن سليمان: <q>﴿وهُمْ فِي الغُرُفاتِ﴾</q> غرف الجنة <q>﴿آمِنُونَ﴾</q> مِن الموت{3}. (ز) ٦٣٥٨١- قال يحيى بن سلّام: <q>﴿وهُمْ فِي الغُرُفاتِ﴾</q> يعني: غرف الجنة <q>﴿آمِنُونَ﴾</q> من النار، ومِن الموت، ومن الخروج منها، ومِن الأحزان، ومِن الأسقام{15}. (ز) <q>﴿وَهُمۡ فِی ٱلۡغُرُفَـٰتِ ءَامِنُونَ ۝٣٧﴾</q> - آثار متعلقة بالآية ٦٣٥٨٢- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ الله لا ينظر إلى صُوَركم وأموالكم، ولكن ينظر إلى قلوبكم وأعمالكم»{18}. (١٢/٢٢١) ٦٣٥٨٣- عن طاووس بن كيسان أنّه كان يقول: اللهم، ارزقني الإيمان والعمل، وجنِّبني المال والولد؛ فإنِّي سمعتُ فيما أوحيتَ: <q>﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</q>{19}. (١٢/٢٢١) ",footnotes:1:تفسير مجاهد (٥٥٦)، وأخرجه ابن جرير ١٩/٢٩٥-٢٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٩٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٥.تفسير يحيى بن سلام ٢/٧٦٤.تفسير البغوي ٦/٤٠٢.علقه يحيى بن سلام ٢/٧٦٤.تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٧.تفسير يحيى بن سلام ٢/٧٦٤.أخرجه يحيى بن سلام ٢/٧٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الحكيم الترمذي في نوادر الأصول ١/٢١٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٧-٢٩٨. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ٢/٧٦٥.تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٥.أخرجه مسلم ٤/١٩٨٧ (٢٥٦٤).عزاه السيوطي إلى ابن أبي حاتم.
34,38," <q>﴿وَٱلَّذِینَ یَسۡعَوۡنَ فِیۤ ءَایَـٰتِنَا مُعَـٰجِزِینَ أُو۟لَـٰۤىِٕكَ فِی ٱلۡعَذَابِ مُحۡضَرُونَ ۝٣٨﴾</q> - تفسير ٦٣٥٨٤- عن الحسن البصري، في قوله: <q>﴿والَّذِينَ يَسْعَوْنَ فِي آياتِنا مُعاجِزِينَ﴾</q>: يَظُنُّون أنّهم يسبقونا حتى لا نقدر عليهم فنعذبهم{1}. (ز) ٦٣٥٨٥- عن قتادة بن دعامة، في قوله: <q>﴿أُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</q>: محضرون في العذاب{1}. (ز) ٦٣٥٨٦- عن محمد بن السائب الكلبي: <q>﴿مُعاجِزِينَ﴾</q> يبطئون الناس عن آياتنا، أي: عن الإيمان بها ويجحدون بها، <q>﴿أُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</q> مُدخَلون{1}. (ز) ٦٣٥٨٧- قال مقاتل بن سليمان: <q>﴿والَّذِينَ يَسْعَوْنَ فِي آياتِنا مُعاجِزِينَ﴾</q> يقول: عملوا بالتكذيب بالقرآن، مُثبِّطين عن الإيمان بالقرآن، <q>﴿أُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</q> النار{4}. (ز) ٦٣٥٨٨- قال يحيى بن سلّام: <q>﴿والَّذِينَ يَسْعَوْنَ﴾</q> يعملون {5}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٧٦٥.علقه يحيى بن سلام ٢/٧٦٥.علقه يحيى بن سلام ٢/٧٦٥.تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٥.
34,39," <q>﴿قُلۡ إِنَّ رَبِّی یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ مِنۡ عِبَادِهِۦ وَیَقۡدِرُ لَهُۥۚ﴾</q> - تفسير ٦٣٥٨٩- قال مقاتل بن سليمان: <q>﴿قُلْ إنَّ رَبِّي يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ﴾</q> يُوَسِّع الرِّزق على من يشاء <q>﴿مِن عِبادِهِ ويَقْدِرُ لَهُ﴾</q> ويُقَتِّر{1}. (ز) ٦٣٥٩٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿قل إن ربي يبسط الرزق لمن يشاء من عباده ويقدر له﴾</q> وهي مثل الأولى{2}. (ز) <q>﴿وَمَاۤ أَنفَقۡتُم مِّن شَیۡءࣲ فَهُوَ یُخۡلِفُهُۥۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٣٩﴾</q> - تفسير ٦٣٥٩١- عن علي بن أبي طالب، قال: سمعتُ رسولَ الله ﷺ يقول: «إنّ لكل يوم نحسًا، فادفعوا نحسَ ذلك اليوم بالصدقة». ثم قال: اقرؤوا مواضع الخَلَف، فإني سمعت الله يقول: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>، إذا لم تُنفِقُوا كيف يُخْلِف؟{3}. (١٢/٢٢٥) ٦٣٥٩٢- عن عمر بن الخطاب -من طريق يحيى بن عبد الرحمن، عن أبيه- أنّه قال لصهيب: إنّك رجلٌ لا تُمْسِكُ شيئًا! قال: إنِّي سمعتُ الله ﷿ يقول: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ وهُوَ خَيْرُالرّازِقِينَ﴾</q>{4}. (ز) ٦٣٥٩٣- عن أبي أُمامة، قال: إنّكم تُؤَوِّلون هذه الآية على غير تأويلها: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>. وسمِعتُ رسولَ الله ﷺ يقول -وإلا فصُمَّتا-: «إيّاكم والسرفَ في المال والنفقةَ، وعليكم بالاقتصاد، فما افتقر قومٌ قطُّ اقتَصدوا»{5}. (ز) ٦٣٥٩٤- عن عبد الله بن عباس -من طريق عمرو بن قيس- في قوله: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>، قال: في غير إسرافٍ، ولا تقتير{6}. (١٢/٢٢٣) ٦٣٥٩٥- عن سعيد بن جبير -من طريق المنهال بن عمرو- في قوله: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>، قال: في غير إسراف، ولا تقتير{7}٥٣٤١. (١٢/٢٢٣) ٥٣٤١ لم يذكر ابنُ جرير (١٩/٢٩٩) في معنى: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q> سوى قول سعيد بن جبير، من طريق المنهال بن عمرو. ٦٣٥٩٦- عن مجاهد بن جبر -من طريق أبي يونس- قال: إذا كان لأحدكم شيءٌ فليقتصد، ولا يتَأَوَّل هذه الآية: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>؛ فإنّ الرِّزْق مقسومٌ. يقول: لعلَّ رزقه قليل، وهو ينفق نفقة الموسع عليه{8}. (١٢/٢٢٤) ٦٣٥٩٧- عن مجاهد بن جبر، في قوله: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>، قال: ما كان من خَلَفٍ فهو منه، ورُبَّما أنفق الإنسان ماله كله في الخير، ولم يُخلَف حتى يموت. ومثلها: <q>﴿وما مِن دابَّةٍ فِي الأَرْضِ إلّا عَلى اللَّهِ رِزْقُها﴾</q> [هود:٦]، يقول: ما أتاها من رزق فمنه، وربما لم يرزقها حتى تموت{9}. (١٢/٢٢٤) ٦٣٥٩٨- عن الضَّحّاك بن مُزاحِم، أنّه سُئِل عن قوله: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q> النفقة في سبيل الله؟ قال: لا، ولكن نفقة الرجل على نفسه، وأهله؛ فالله يُخْلِفه{10}. (١٢/٢٢٣) ٦٣٥٩٩- عن إسماعيل السُّدِّيّ: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ﴾</q> أي: في طاعة الله <q>﴿فَهُوَ يُخْلِفُهُ﴾</q> يعني: في الآخرة= (ز) ٦٣٦٠٠- قال يحيى بن سلّام: أي: أن يُخلَفوا خيرًا في الآخرة، ويُعوِّضكم من الجنة{11}. (ز) ٦٣٦٠١- قال محمد بن السائب الكلبي: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q> ما تصدقَّتُم من صدقة وأنفقتم في الخير من نفقة فهو يخلفه على المنفق؛ إما أن يعجله في الدنيا، وإما أن يدَّخره له في الآخرة{12}. (ز) ٦٣٦٠٢- قال مقاتل بن سليمان: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q> يقول الله ﷿: أخلفه لكم وأعطيكموه، <q>﴿وهُوَ خَيْرُ الرّازِقِينَ﴾</q>. مثل قوله ﷿: <q>﴿وأَنْفِقُوا مِمّا جَعَلَكُمْ مُسْتَخْلَفِينَ فِيهِ﴾</q> [الحديد:٧]{13}. (ز) ٦٣٦٠٣- قال يحيى بن سلّام: <q>﴿فَهُوَ يُخْلِفُهُ وهُوَ خَيْرُ الرّازِقِينَ﴾</q> ليس يعني: أنّه إذا أنفق شيئًا أخلف له مثله، ولكن يقول: الخلف كله مِن الله؛ أْكَثَر مِمّا أنفق أو أقَلّ، ليس يخلف النفقة ويرزق العباد إلا الله{2}. (ز) <q>﴿وَمَاۤ أَنفَقۡتُم مِّن شَیۡءࣲ فَهُوَ یُخۡلِفُهُۥۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٣٩﴾</q> - آثار متعلقة بالآية ٦٣٦٠٤- عن حذيفة، قال: قال رسول الله ﷺ: «ألا إنّ بعد زمانكم هذا زمانًا عَضُوضًا؛ يعَضُّ المُوسِرُ على ما في يده حذار الإنفاق، قال الله: <q>﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</q>»{15}. (١٢/٢٢٥) ٦٣٦٠٥- عن أبي هريرة، أنّ رسول الله ﷺ قال: «ما مِن يومٍ يُصبِح العبادُ فيه إلا ملكان ينزلان، فيقول أحدُهما: اللهُمَّ، أعْطِ مُنفِقًا خَلَفًا. ويقول الآخر: اللهم، أعْطِ مُمْسِكًا تلفًا»{16}. (ز) ٦٣٦٠٦- عن أبي هريرة، أنّ رسول الله ﷺ قال: «قال الله: أنفِق -يا ابن آدم- أُنفِقْ عليك»{17}. (١٢/٢٢٥) ٦٣٦٠٧- عن جابر، قال: قال رسول الله ﷺ: «كلُّ معروفٍ صدقةٌ، وما أنفق المرءُ على نفسه وأهله كُتِب له به صدقة، وما وقى به عِرْضَهُ كُتب له به صدقة، وكل نفقة أنفقها مؤمنٌ فعلى الله خَلفها ضامن، إلا نفقة في معصية أو بنيان». قيل لابن المنكدر: وما أراد بـ«ما وقى به المرءُ عِرْضَه كُتب له به صدقة»؟ قال: ما أعطى الشاعر، وذا اللسان المُتَّقى{18}. (١٢/٢٢٤) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٦.عزاه السيوطي إلى ابن مردويه. قال الألباني في الضعيفة ١٤/٤٣٦ (٦٦٩٩): «منكر».أخرجه الثعلبي ٨/٩٢.أخرجه الثعلبي ٨/٩٢، من طريق عمرو بن الحصين، قال: حدثنا ابن [علاثة] وهو محمد، عن الأوزاعي، عن ابن أبي موسى، عن أبي أمامة به. وأورده الديلمي في الفردوس ١/٣٨٧ (١٥٦٠). إسناده ضعيف جدًّا؛ فيه عمرو بن الحصين العُقيلي، قال عنه ابن حجر في التقريب (٥٠١٢): «متروك».أخرجه البخاري في الأدب المفرد (٤٤٣)، والبيهقي في شعب الإيمان (٦٥٥٠، ٦٥٥١). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه سفيان الثوري (٢٤٤)، ويحيى بن سلام ٢/٧٦٦، وابن أبي شيبة ٩/٩٥، وابن جرير ١٩/٢٩٨-٢٩٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه سفيان الثوري في تفسيره (٢٤٤)، ويحيى بن سلام ٢/٧٦٦ من طريق ابن سعد بنحوه. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.علقه يحيى بن سلام ٢/٧٦٦.تفسير الثعلبي ٨/٩١، وتفسير البغوي ٦/٤٠٢.تفسير مقاتل بن سليمان ٣/٥٣٥-٥٣٦.تفسير يحيى بن سلام ٢/٧٦٦.أخرجه ابن أبي حاتم، وأبو يعلى -كما في تفسير ابن كثير ٦/٥٢٣-. قال ابن كثير (١١/٢٩٣-٢٩٤) هذا الحديث من رواية أبي يعلى بسنده عن روح بن حاتم، عن هشيم، عن الكوثر بن حكيم، عن مكحول، عن حذيفة مرفوعًا، ثم علَّق قائلًا: «هذا حديث غريب من هذا الوجه، وفي إسناده ضعف».أخرجه البخاري ٢/١١٥ (١٤٤٢)، ومسلم ٢/٧٠٠ (١٠١٠).أخرجه البخاري ٧/٦٢ (٥٣٥٢)، ومسلم ٢/٦٩٠ (٩٩٣).أخرجه أحمد ٢٣/١٦١ (١٤٨٧٧) بنحوه، والحاكم ٢/٥٧ (٢٣١١)، والبيهقي في شعب الإيمان (١٠٧١٢)، والثعلبي ٨/٩٢. قال الحاكم: «هذا حديث صحيح، ولم يخرجاه، وشاهده ليس من شرط هذا الكتاب». وتعقّبه الذهبي في التلخيص بقوله: «عبد الحميد ضعّفوه». وقال الهيثمي في المجمع ٣/١٣٦ (٤٧٥٢): «رواه بطوله أبو يعلى، واختصره الإمام أحمد كما تقدم، وفي إسناد أحمد: المنكدر بن محمد بن المنكدر، وثّقه أحمد وغيره، وضعّفه النسائي وغيره، وفي إسناد أبي يعلى مسور بن الصّلت، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٤/١٨٤ (٣٣٨٨): «هذا إسناد ضعيف؛ لضعف مسور بن الصلت». وقال المناوي في فيض القدير ٥/٣٢ (٦٣٥٣): «وقال في الميزان: غريب جِدًّا». وقال الألباني في الضعيفة ٢/٣٠١ (٨٩٨): «ضعيف ... لكن الجملتان الأوليان من الحديث صحيحتان؛ لأنّ لهما شواهد كثيرة في الصحيحين وغيرهما».
