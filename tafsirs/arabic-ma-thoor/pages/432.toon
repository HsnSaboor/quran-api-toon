quran[8]{c,v,t}:
  34,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ٱلَّذِینَ ٱسۡتَكۡبَرُوا۟ لِلَّذِینَ ٱسۡتُضۡعِفُوۤا۟ أَنَحۡنُ صَدَدۡنَـٰكُمۡ عَنِ ٱلۡهُدَىٰ بَعۡدَ إِذۡ جَاۤءَكُمۖ بَلۡ كُنتُم مُّجۡرِمِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٣٢<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿عَنِ الهُدى﴾</span>، يعني: عن الإيمان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدَّت القادة -وهم الكبراء- على الضعفاء -وهم الأتباع-: <span class="qpc-hafs">﴿قالَ الَّذِينَ اسْتَكْبَرُوا لِلَّذِينَ اسْتُضْعِفُوا أنَحْنُ صَدَدْناكُمْ عَنِ الهُدى﴾</span> يعني: أنحنُ منعناكم عن الإيمان <span class="qpc-hafs">﴿بَعْدَ إذْ جاءَكُمْ بَلْ كُنْتُمْ مُجْرِمِينَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالَ الَّذِينَ اسْتَكْبَرُوا﴾</span> يعني: الكبراء والقادة في الكفر <span class="qpc-hafs">﴿لِلَّذِينَ اسْتُضْعِفُوا﴾</span> يعني: الأتباع: <span class="qpc-hafs">﴿أنَحْنُ صَدَدْناكُمْ﴾</span> على الاستفهام <span class="qpc-hafs">﴿عَنِ الهُدى﴾</span> يعني: عن الإيمان <span class="qpc-hafs">﴿بَعْدَ إذْ جاءَكُمْ بَلْ كُنْتُمْ مُجْرِمِينَ﴾</span> مشركين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٧٦٢.تفسير مقاتل بن سليمان ٣/٥٣٤.تفسير يحيى بن سلام ٢/٧٦٢.
  34,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلَّذِینَ ٱسۡتُضۡعِفُوا۟ لِلَّذِینَ ٱسۡتَكۡبَرُوا۟ بَلۡ مَكۡرُ ٱلَّیۡلِ وَٱلنَّهَارِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٣٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span>، قال: مَرُّ الليل والنهار{1}. (١٢/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو-: <span class="qpc-hafs">﴿وقالَ الَّذِينَ اسْتُضْعِفُوا﴾</span> بنو آدم، <span class="qpc-hafs">﴿لِلَّذِينَ اسْتَكْبَرُوا﴾</span> الشياطين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٣٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span>: أي: بل مكركم بالليل والنهار، أي: كذبكم وكفركم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span>، قال: بل مكركم بالليل والنهار{4}. (١٢/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٣٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span>، يقول: غرَّكم اختلاف الليل والنهار{5}. (١٢/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، قال: <span class="qpc-hafs">﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span> بل قولكم لنا بالليل والنهار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدَّتِ الضعفاءُ على الكبراء، فقالوا: <span class="qpc-hafs">﴿وقالَ الَّذِينَ اسْتُضْعِفُوا لِلَّذِينَ اسْتَكْبَرُوا بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span> بل قولهم كذب بالليل والنهار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span>، قال: بل مكركم بنا في الليل والنهار، يا أيها العظماء الرؤساء، حتى أزَلْتُمُونا عن عبادة الله{8}. (١٢/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿بل مكر الليل والنهار إذ تأمروننا أن نكفر بالله ونجعل له أندادًا﴾</span>، قال: أعمالكم بالليل والنهار. قال <span class="name-3">سفيان</span>: وكل مكر في القرآن فهو عمل{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقالَ الَّذِينَ اسْتُضْعِفُوا لِلَّذِينَ اسْتَكْبَرُوا بَلْ مَكْرُ اللَّيْلِ والنَّهارِ﴾</span>، أي: بل مكركم بالليل والنهار{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ تَأۡمُرُونَنَاۤ أَن نَّكۡفُرَ بِٱللَّهِ وَنَجۡعَلَ لَهُۥۤ أَندَادࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ونَجْعَلَ لَهُ أنْدادًا﴾</span>: شركاء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ﴾</span> بتوحيد الله ﷿، <span class="qpc-hafs">﴿ونَجْعَلَ لَهُ أنْدادًا﴾</span> يعني: وتأمرونا أن نجعل له شريكًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ ونَجْعَلَ لَهُ أنْدادًا﴾</span>، يعني: أوثانهم عدَلوها بالله؛ فعبدوها دونه{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلۡعَذَابَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وأَسَرُّوا النَّدامَةَ﴾</span> بينهم <span class="qpc-hafs">﴿لَمّا رَأَوُا العَذابَ﴾</span>{11}<span class=comment-ref>٥٣٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٣٨</span> لم يذكر <u>ابنُ جرير</u> (١٩/٢٩٢-٢٩٣) في معنى: <span class="qpc-hafs">﴿وأَسَرُّوا النَّدامَةَ لَمّا رَأَوُا العَذابَ﴾</span> سوى قول قتادة.</p><p>ونقل <u>ابنُ عطية</u> (٧/١٨٩) عن بعض الناس أن <span class="qpc-hafs">﴿وأَسَرُّوا﴾</span> بمعنى: «أظهروا، وهي من الأضداد». ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا كلام مَن لم يعتبر المعنى، أمّا نفس الندامة فلا تكون إلا مُسْتَسَرَّة ضرورة، وأما الظاهر عنها فغيرها، ولم يثبت قط في لغة أن»أسَرَّ«من الأضداد».</div></p><p><div></p><p><p><span class="item-no">٦٣٥٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَسَرُّوا النَّدامَةَ﴾</span> في أنفسهم <span class="qpc-hafs">﴿لَمّا رَأَوُا العَذابَ﴾</span> حين عاينوا العذاب في الآخرة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأَسَرُّوا النَّدامَةَ﴾</span> في أنفسهم يوم القيامة <span class="qpc-hafs">﴿لَمّا رَأَوُا العَذابَ﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ٱلۡأَغۡلَـٰلَ فِیۤ أَعۡنَاقِ ٱلَّذِینَ كَفَرُوا۟ۖ هَلۡ یُجۡزَوۡنَ إِلَّا مَا كَانُوا۟ یَعۡمَلُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلْنا الأَغْلالَ فِي أعْناقِ الَّذِينَ كَفَرُوا﴾</span> وذلك أنّ الله ﷿ يأمر خزنة جهنم أن يجعلوا الأغلال في أعناق الذين كفروا بتوحيد الله ﷿، وقالت لهم الخزنة: <span class="qpc-hafs">﴿هَلْ يُجْزَوْنَ﴾</span> في الآخرة <span class="qpc-hafs">﴿إلّا ما كانُوا يَعْمَلُونَ﴾</span> مِن الكفر في الدنيا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجَعَلْنا الأَغْلالَ فِي أعْناقِ الَّذِينَ كَفَرُوا هَلْ يُجْزَوْنَ إلّا﴾</span> على الاستفهام <span class="qpc-hafs">﴿ما كانُوا يَعْمَلُونَ﴾</span> أي: أنّهُم لا يُجْزَون إلا ما كانوا يعملون{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ٱلۡأَغۡلَـٰلَ فِیۤ أَعۡنَاقِ ٱلَّذِینَ كَفَرُوا۟ۖ هَلۡ یُجۡزَوۡنَ إِلَّا مَا كَانُوا۟ یَعۡمَلُونَ ۝٣٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٥٣<span class="dash">-</span></span> عن <span class="name-3">الحسن بن يحيى الخُشني</span> قال: ما في جهنم دارٌ، ولا مغارٌ، ولا غلٌّ، ولا قيد، ولا سلسلة إلا اسمُ صاحبها عليه مكتوب.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٥٤<span class="dash">-</span></span> فحُدِّث به <span class="name-3">أبو سليمان الداراني</span> فبكى، ثم قال: فكيف به لو جُمِع هذا كله عليه، فجُعل القيد في رجليه، والغل في يديه، والسلسلة في عنقه، ثم أُدخل الدار، وأُدخل المغار؟!{19}. (١٢/٢١٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٣/٥٣٩، وابن جرير ١٩/٢٩٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ٢/٧٦٣.علقه يحيى بن سلام ٢/٧٦٣.أخرجه عبد الرزاق ٢/١٣٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٧٦٣.تفسير مقاتل بن سليمان ٣/٥٣٤.أخرجه ابن جرير ١٩/٢٩٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي ص١٥٧.تفسير يحيى بن سلام ٢/٧٦٣.أخرجه ابن جرير ١٩/٢٩٢.تفسير مقاتل بن سليمان ٣/٥٣٤.تفسير يحيى بن سلام ٢/٧٦٣.أخرجه ابن جرير ١٩/٢٩٢.تفسير مقاتل بن سليمان ٣/٥٣٤.تفسير يحيى بن سلام ٢/٧٦٣.تفسير مقاتل بن سليمان ٣/٥٣٤-٥٣٥.تفسير يحيى بن سلام ٢/٧٦٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٠٧-٥٠٨-.
  34,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَرۡسَلۡنَا فِی قَرۡیَةࣲ مِّن نَّذِیرٍ إِلَّا قَالَ مُتۡرَفُوهَاۤ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٣٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٥٥<span class="dash">-</span></span> عن أبي رَزِين -من طريق سفيان بن عاصم- قال: كان رجلان شريكين، خرج أحدهما إلى الساحل، وبقي الآخر، فلما بُعِث النبيُّ ﷺ كتب إلى صاحبه يسأله: ما فعل؟ فكتب إليه أنّه لم يتبعه أحدٌ مِن قريش إلا رذالة الناس ومساكينهم، فترك تجارته، ثم أتى صاحبه، فقال: دُلَّني عليه. وكان يقرأ الكتب، فأتى النبيَّ ﷺ، فقال: إلامَ تدعو؟ قال: «<b>إلى كذا وكذا</b>». قال: أشهد أنّك رسول الله. قال: «<b>وما عِلمُك بذلك</b>؟». قال: إنّه لم يُبعَث نبيٌّ إلا اتبعه رذالة الناس ومساكينهم. فنزلت هذه الآية: <span class="qpc-hafs">﴿وما أرْسَلْنا فِي قَرْيَةٍ مِن نَذِيرٍ إلّا قالَ مُتْرَفُوها﴾</span> الآيات. فأرسل إليه النبيُّ ﷺ: «<b>إنّ اللهَ قد أنزل تصديقَ ما قلتَ</b>»{1}. (١٢/٢٢٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَرۡسَلۡنَا فِی قَرۡیَةࣲ مِّن نَّذِیرٍ إِلَّا قَالَ مُتۡرَفُوهَاۤ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٣٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلّا قالَ مُتْرَفُوها﴾</span>، قال: هم جبابرتهم، ورؤوسهم، وأشرافهم، وقادتهم في الشر{2}. (١٢/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أرْسَلْنا فِي قَرْيَةٍ مِن نَذِيرٍ﴾</span> من رسول <span class="qpc-hafs">﴿إلّا قالَ مُتْرَفُوها﴾</span> أغنياؤها وجبابرتها للرسل: <span class="qpc-hafs">﴿إنّا بِما أُرْسِلْتُمْ بِهِ﴾</span> بالتوحيد <span class="qpc-hafs">﴿كافِرُونَ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿إلّا قالَ مُتْرَفُوها﴾</span>، قال: جبابرتها{4}. (١٢/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أرْسَلْنا فِي قَرْيَةٍ مِن نَذِيرٍ﴾</span> من نبيٍّ يُنذرهم عذابَ الدنيا وعذابَ الآخرة <span class="qpc-hafs">﴿إلّا قالَ مُتْرَفُوها﴾</span> جبابرتها، والمترفون: أهل السعة والنعمة: <span class="qpc-hafs">﴿إنّا بِما أُرْسِلْتُمْ بِهِ كافِرُونَ﴾</span> فاتبعهم على ذلك السفلة، فجحدوا كلُّهم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٠٨-. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر مرسلًا.أخرجه ابن جرير ١٩/٢٩٣ بنحوه، وعبد الرزاق ٢/١٩٥ من طريق معمر مختصرًا. وعلَّقه يحيى بن سلام ٢/٧٦٣ مقتصرًا على لفظ: جبابرتها. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٣٥.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ٢/٧٦٣.
  34,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ نَحۡنُ أَكۡثَرُ أَمۡوَ ٰ⁠لࣰا وَأَوۡلَـٰدࣰا وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا﴾</span> أيضًا لفقراء المسلمين: أهؤلاء خَيرٌ مِنّا، أم هم أولى بالله مِنّا؟! <span class="qpc-hafs">﴿نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا وما نَحْنُ بِمُعَذَّبِينَ﴾</span>{1}<span class=comment-ref>٥٣٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٣٩</span> ذكر <u>ابنُ عطية</u> (٧/١٨٩) <b>احتمالًا</b> آخر، فقال: «يحتمل أن يكون الضمير في <span class="qpc-hafs">﴿قالوا﴾</span> لقريش، ويكون كلام المترفين قد تقدم، ثم تطَّرد الآية بعد». وذكر أن معنى: <span class="qpc-hafs">﴿نَحْنُ أكْثَرُ أمْوالا وأَوْلادًا وما نَحْنُ بِمُعَذَّبِينَ﴾</span>: «الاحتجاج بأن الله لم يُعْطِنا هذا وقدَّره لنا إلا لرضاه عنّا وعن طريقتنا، ونحن ممن لا يُعَذَّب البَتَّة؛ إذ الله -الذي تزعم أنت علمَه بجميع الأشياء وإحاطته- قد قدَّر علينا النِّعم، فهو إذًا راضٍ عنّا». ثم ذكر عن بعض المفسرين أن معنى: <span class="qpc-hafs">﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</span> أي: بالفقر، و<span class="comment-type-2">انتقده</span> قائلًا: «وهذا ليس كالأول في القوة».</div></p><p><div></p><p><p><span class="item-no">٦٣٥٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</span>، قالوا: <span class="qpc-hafs">﴿نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا﴾</span> فأخبرهم الله أنه ليست أموالكم ولا أولادكم بالتي تقربكم عندنا زلفى، <span class="qpc-hafs">﴿إلّا مَن آمَنَ وعَمِلَ صالِحًا﴾</span> قال: وهذا قول المشركين لرسول الله ﷺ وأصحابه؛ قالوا: لو لم يكن الله عَنّا راضيًا لم يعطنا هذا. كما قال قارون: لولا أن الله رضي بي وبحالي ما أعطاني هذا. قال: <span class="qpc-hafs">﴿أوَلَمْ يَعْلَمْ أنَّ اللَّهَ قَدْ أهْلَكَ مِن قَبْلِهِ مِنَ القُرُونِ﴾</span> [القصص:٧٨]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقالُوا نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا﴾</span> قالوا ذلك للأنبياء والمؤمنين، يُعَيِّرونهم بالفقر وبقِلَّة المال، <span class="qpc-hafs">﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٥.تفسير يحيى بن سلام ٢/٧٦٣.
  34,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ إِنَّ رَبِّی یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُ وَلَـٰكِنَّ أَكۡثَرَ ٱلنَّاسِ لَا یَعۡلَمُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ إنَّ رَبِّي يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ﴾</span> ويُقَتِّر على من يشاء، <span class="qpc-hafs">﴿ولَكِنَّ أكْثَرَ النّاسِ﴾</span> كفار مكة <span class="qpc-hafs">﴿لا يَعْلَمُونَ﴾</span> أنّ البسط والقتر بيد الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قُلْ إنَّ رَبِّي يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ ويَقْدِرُ﴾</span> أي: ويُقَتِّر عليه الرزق، فأما المؤمن فذلك نظرٌ مِن الله له، <span class="qpc-hafs">﴿ولَكِنَّ أكْثَرَ النّاسِ لا يَعْلَمُونَ﴾</span> يعني: جماعة المشركين لا يعلمون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٣-٧٦٤.
  34,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَمۡوَ ٰ⁠لُكُمۡ وَلَاۤ أَوۡلَـٰدُكُم بِٱلَّتِی تُقَرِّبُكُمۡ عِندَنَا زُلۡفَىٰۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عِنْدَنا زُلْفى﴾</span>، قال: قُرْبى{1}. (١٢/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</span>، قال: لا تعتبروا الناس بكثرة المال والولد؛ وإنّ الكافر يُعطى المال، ورُبَّما حَبَسَهُ عن المؤمن{2}. (١٢/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</span>، يعني: قُرْبَة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</span>، قالوا: <span class="qpc-hafs">﴿نَحْنُ أكْثَرُ أمْوالًا وأَوْلادًا﴾</span>. فأخبرهم الله أنّه ليست أموالكم ولا أولادكم بالتي تقربكم عندنا زلفى، <span class="qpc-hafs">﴿إلّا مَن آمَنَ وعَمِلَ صالِحًا﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٦٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ﴾</span> يقوله للمشركين <span class="qpc-hafs">﴿بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</span> والزلفى: القرابة؛ لقولهم للأنبياء والمؤمنين: نحن أكثر أموالًا وأولادًا منكم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا مَنۡ ءَامَنَ وَعَمِلَ صَـٰلِحࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٧٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span>، يريد: إيمانه وعمله يُقرِّبه مِنِّي{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span> فإنّ ذلك يُقرِّب إلى الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا مَن آمَنَ﴾</span> صدّق بالله، <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿إلّا مَن آمَنَ وعَمِلَ صالِحًا﴾</span>، قال: لم تضرهم أموالهم ولا أولادهم في الدنيا؛ للمؤمنين. وقرأ: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span> [يونس:٢٦]، فالحسنى: الجنة. والزيادة: ما أعطاهم الله في الدنيا؛ لم يحاسبهم به كما حاسب الآخرين{9}<span class=comment-ref>٥٣٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٤٠</span> نقل <u>ابنُ جرير</u> (١٩/٢٩٧) عن بعضهم أنّ معنى قوله تعالى: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادَكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى إلا مَن آمَنَ وعَمِلَ صالِحًا﴾</span>: «وما أموالكم ولا أولادكم بالتي تقرِّبكم عندنا زُلفى، إلا من آمن وعمل صالحًا، فإنه تُقَرِّبهم أموالهم وأولادهم -بطاعتهم الله في ذلك، وأدائهم فيه حقَّه إلى الله- زُلفى، دون أهل الكفر بالله». وذكر قول ابن زيد، ثم <span class="comment-type-1">وجَّه</span> هذا المعنى بقوله: «فـ<span class="qpc-hafs">﴿من﴾</span> على هذا التأويل نصبٌ بوقوع»تقرب«عليه».</div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إلّا﴾</span> استثنى <span class="qpc-hafs">﴿مَن آمَنَ﴾</span> أي: ليس القربة عندنا إلا لِمَن آمن، <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span> فإنّ ذلك يُقَرِّب إلى الله{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأُو۟لَـٰۤىِٕكَ لَهُمۡ جَزَاۤءُ ٱلضِّعۡفِ بِمَا عَمِلُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عاصم بن حكيم- في قوله <span class="qpc-hafs">﴿جَزاءُ الضِّعْفِ﴾</span>، قال: تضعيف الحسنة{11}. (١٢/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> –من طريق ابي مودود- قال: إذا كان المؤمن غنيًّا تقيًّا آتاه الله أجرَه مرَّتين. وتلا هذه الآية: <span class="qpc-hafs">﴿وما أمْوالُكُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ﴾</span> قال: تضعيف الحسنة{12}. (١٢/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ بِما عَمِلُوا﴾</span> مِن الخير؛ نجزي بالحسنة الواحدة عشرةً فصاعدًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ بِما عَمِلُوا﴾</span>، قال: بأعمالهم، بالواحدة عشرًا، وفي سبيل الله بالواحد سبعمائة{14}. (١٢/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَأُولَئِكَ لَهُمْ جَزاءُ الضِّعْفِ﴾</span> قال: تضعيف الحسنات، كقوله: <span class="qpc-hafs">﴿مَن جاءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</span> [الأنعام:١٦٠]، ثم نزل بعد ذلك بالمدينة: <span class="qpc-hafs">﴿مَثَلُ الَّذِينَ يُنْفِقُونَ أمْوالَهُمْ فِي سَبِيلِ اللَّهِ كَمَثَلِ حَبَّةٍ أنْبَتَتْ سَبْعَ سَنابِلَ فِي كُلِّ سُنْبُلَةٍ مِائَةُ حَبَّةٍ واللَّهُ يُضاعِفُ لِمَن يَشاءُ﴾</span> [البقرة:٢٦١]، ثم صارت بعدُ في الأعمال الصالحة كلها؛ الواحد سبعمائة{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ فِی ٱلۡغُرُفَـٰتِ ءَامِنُونَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُمْ فِي الغُرُفاتِ﴾</span> غرف الجنة <span class="qpc-hafs">﴿آمِنُونَ﴾</span> مِن الموت{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهُمْ فِي الغُرُفاتِ﴾</span> يعني: غرف الجنة <span class="qpc-hafs">﴿آمِنُونَ﴾</span> من النار، ومِن الموت، ومن الخروج منها، ومِن الأحزان، ومِن الأسقام{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ فِی ٱلۡغُرُفَـٰتِ ءَامِنُونَ ۝٣٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٨٢<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ الله لا ينظر إلى صُوَركم وأموالكم، ولكن ينظر إلى قلوبكم وأعمالكم</b>»{18}. (١٢/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٨٣<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> أنّه كان يقول: اللهم، ارزقني الإيمان والعمل، وجنِّبني المال والولد؛ فإنِّي سمعتُ فيما أوحيتَ: <span class="qpc-hafs">﴿وما أمْوالُكُمْ ولا أوْلادُكُمْ بِالَّتِي تُقَرِّبُكُمْ عِنْدَنا زُلْفى﴾</span>{19}. (١٢/٢٢١)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد (٥٥٦)، وأخرجه ابن جرير ١٩/٢٩٥-٢٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٩٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٥.تفسير يحيى بن سلام ٢/٧٦٤.تفسير البغوي ٦/٤٠٢.علقه يحيى بن سلام ٢/٧٦٤.تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٧.تفسير يحيى بن سلام ٢/٧٦٤.أخرجه يحيى بن سلام ٢/٧٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الحكيم الترمذي في نوادر الأصول ١/٢١٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٣٥.أخرجه ابن جرير ١٩/٢٩٧-٢٩٨. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ٢/٧٦٥.تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٥.أخرجه مسلم ٤/١٩٨٧ (٢٥٦٤).عزاه السيوطي إلى ابن أبي حاتم.
  34,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یَسۡعَوۡنَ فِیۤ ءَایَـٰتِنَا مُعَـٰجِزِینَ أُو۟لَـٰۤىِٕكَ فِی ٱلۡعَذَابِ مُحۡضَرُونَ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿والَّذِينَ يَسْعَوْنَ فِي آياتِنا مُعاجِزِينَ﴾</span>: يَظُنُّون أنّهم يسبقونا حتى لا نقدر عليهم فنعذبهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</span>: محضرون في العذاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٨٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿مُعاجِزِينَ﴾</span> يبطئون الناس عن آياتنا، أي: عن الإيمان بها ويجحدون بها، <span class="qpc-hafs">﴿أُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</span> مُدخَلون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والَّذِينَ يَسْعَوْنَ فِي آياتِنا مُعاجِزِينَ﴾</span> يقول: عملوا بالتكذيب بالقرآن، مُثبِّطين عن الإيمان بالقرآن، <span class="qpc-hafs">﴿أُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</span> النار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والَّذِينَ يَسْعَوْنَ﴾</span> يعملون {5}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٧٦٥.علقه يحيى بن سلام ٢/٧٦٥.علقه يحيى بن سلام ٢/٧٦٥.تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٥.
  34,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ إِنَّ رَبِّی یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ مِنۡ عِبَادِهِۦ وَیَقۡدِرُ لَهُۥۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ إنَّ رَبِّي يَبْسُطُ الرِّزْقَ لِمَن يَشاءُ﴾</span> يُوَسِّع الرِّزق على من يشاء <span class="qpc-hafs">﴿مِن عِبادِهِ ويَقْدِرُ لَهُ﴾</span> ويُقَتِّر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿قل إن ربي يبسط الرزق لمن يشاء من عباده ويقدر له﴾</span> وهي مثل الأولى{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنفَقۡتُم مِّن شَیۡءࣲ فَهُوَ یُخۡلِفُهُۥۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٥٩١<span class="dash">-</span></span> عن علي بن أبي طالب، قال: سمعتُ رسولَ الله ﷺ يقول: «<b>إنّ لكل يوم نحسًا، فادفعوا نحسَ ذلك اليوم بالصدقة</b>». ثم قال: اقرؤوا مواضع الخَلَف، فإني سمعت الله يقول: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>، إذا لم تُنفِقُوا كيف يُخْلِف؟{3}. (١٢/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٢<span class="dash">-</span></span> عن عمر بن الخطاب -من طريق يحيى بن عبد الرحمن، عن أبيه- أنّه قال ل<span class="name-1">صهيب</span>: إنّك رجلٌ لا تُمْسِكُ شيئًا! قال: إنِّي سمعتُ الله ﷿ يقول: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ وهُوَ خَيْرُالرّازِقِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٣<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، قال: إنّكم تُؤَوِّلون هذه الآية على غير تأويلها: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>. وسمِعتُ رسولَ الله ﷺ يقول -وإلا فصُمَّتا-: «<b>إيّاكم والسرفَ في المال والنفقةَ، وعليكم بالاقتصاد، فما افتقر قومٌ قطُّ اقتَصدوا</b>»{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن قيس- في قوله: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>، قال: في غير إسرافٍ، ولا تقتير{6}. (١٢/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق المنهال بن عمرو- في قوله: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>، قال: في غير إسراف، ولا تقتير{7}<span class=comment-ref>٥٣٤١</span>. (١٢/٢٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٤١</span> لم يذكر <u>ابنُ جرير</u> (١٩/٢٩٩) في معنى: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span> سوى قول سعيد بن جبير، من طريق المنهال بن عمرو.</div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يونس- قال: إذا كان لأحدكم شيءٌ فليقتصد، ولا يتَأَوَّل هذه الآية: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>؛ فإنّ الرِّزْق مقسومٌ. يقول: لعلَّ رزقه قليل، وهو ينفق نفقة الموسع عليه{8}. (١٢/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>، قال: ما كان من خَلَفٍ فهو منه، ورُبَّما أنفق الإنسان ماله كله في الخير، ولم يُخلَف حتى يموت. ومثلها: <span class="qpc-hafs">﴿وما مِن دابَّةٍ فِي الأَرْضِ إلّا عَلى اللَّهِ رِزْقُها﴾</span> [هود:٦]، يقول: ما أتاها من رزق فمنه، وربما لم يرزقها حتى تموت{9}. (١٢/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span> النفقة في سبيل الله؟ قال: لا، ولكن نفقة الرجل على نفسه، وأهله؛ فالله يُخْلِفه{10}. (١٢/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٥٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ﴾</span> أي: في طاعة الله <span class="qpc-hafs">﴿فَهُوَ يُخْلِفُهُ﴾</span> يعني: في الآخرة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: أي: أن يُخلَفوا خيرًا في الآخرة، ويُعوِّضكم من الجنة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span> ما تصدقَّتُم من صدقة وأنفقتم في الخير من نفقة فهو يخلفه على المنفق؛ إما أن يعجله في الدنيا، وإما أن يدَّخره له في الآخرة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span> يقول الله ﷿: أخلفه لكم وأعطيكموه، <span class="qpc-hafs">﴿وهُوَ خَيْرُ الرّازِقِينَ﴾</span>. مثل قوله ﷿: <span class="qpc-hafs">﴿وأَنْفِقُوا مِمّا جَعَلَكُمْ مُسْتَخْلَفِينَ فِيهِ﴾</span> [الحديد:٧]{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَهُوَ يُخْلِفُهُ وهُوَ خَيْرُ الرّازِقِينَ﴾</span> ليس يعني: أنّه إذا أنفق شيئًا أخلف له مثله، ولكن يقول: الخلف كله مِن الله؛ أْكَثَر مِمّا أنفق أو أقَلّ، ليس يخلف النفقة ويرزق العباد إلا الله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنفَقۡتُم مِّن شَیۡءࣲ فَهُوَ یُخۡلِفُهُۥۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٣٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٣٦٠٤<span class="dash">-</span></span> عن حذيفة، قال: قال رسول الله ﷺ: «<b>ألا إنّ بعد زمانكم هذا زمانًا عَضُوضًا؛ يعَضُّ المُوسِرُ على ما في يده حذار الإنفاق، قال الله</b>: <span class="qpc-hafs">﴿وما أنْفَقْتُمْ مِن شَيْءٍ فَهُوَ يُخْلِفُهُ﴾</span>»{15}. (١٢/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠٥<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>ما مِن يومٍ يُصبِح العبادُ فيه إلا ملكان ينزلان، فيقول أحدُهما: اللهُمَّ، أعْطِ مُنفِقًا خَلَفًا. ويقول الآخر: اللهم، أعْطِ مُمْسِكًا تلفًا</b>»{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠٦<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>قال الله: أنفِق -يا ابن آدم- أُنفِقْ عليك</b>»{17}. (١٢/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٦٠٧<span class="dash">-</span></span> عن جابر، قال: قال رسول الله ﷺ: «<b>كلُّ معروفٍ صدقةٌ، وما أنفق المرءُ على نفسه وأهله كُتِب له به صدقة، وما وقى به عِرْضَهُ كُتب له به صدقة، وكل نفقة أنفقها مؤمنٌ فعلى الله خَلفها ضامن، إلا نفقة في معصية أو بنيان</b>». قيل لابن المنكدر: وما أراد بـ«<b>ما وقى به المرءُ عِرْضَه كُتب له به صدقة</b>»؟ قال: ما أعطى الشاعر، وذا اللسان المُتَّقى{18}. (١٢/٢٢٤)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٣٥.تفسير يحيى بن سلام ٢/٧٦٦.عزاه السيوطي إلى ابن مردويه.</p><p>قال الألباني في الضعيفة ١٤/٤٣٦ (٦٦٩٩): «منكر».أخرجه الثعلبي ٨/٩٢.أخرجه الثعلبي ٨/٩٢، من طريق عمرو بن الحصين، قال: حدثنا ابن [علاثة] وهو محمد، عن الأوزاعي، عن ابن أبي موسى، عن أبي أمامة به. وأورده الديلمي في الفردوس ١/٣٨٧ (١٥٦٠).</p><p>إسناده ضعيف جدًّا؛ فيه عمرو بن الحصين العُقيلي، قال عنه ابن حجر في التقريب (٥٠١٢): «متروك».أخرجه البخاري في الأدب المفرد (٤٤٣)، والبيهقي في شعب الإيمان (٦٥٥٠، ٦٥٥١). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه سفيان الثوري (٢٤٤)، ويحيى بن سلام ٢/٧٦٦، وابن أبي شيبة ٩/٩٥، وابن جرير ١٩/٢٩٨-٢٩٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه سفيان الثوري في تفسيره (٢٤٤)، ويحيى بن سلام ٢/٧٦٦ من طريق ابن سعد بنحوه. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.علقه يحيى بن سلام ٢/٧٦٦.تفسير الثعلبي ٨/٩١، وتفسير البغوي ٦/٤٠٢.تفسير مقاتل بن سليمان ٣/٥٣٥-٥٣٦.تفسير يحيى بن سلام ٢/٧٦٦.أخرجه ابن أبي حاتم، وأبو يعلى -كما في تفسير ابن كثير ٦/٥٢٣-.</p><p>قال ابن كثير (١١/٢٩٣-٢٩٤) هذا الحديث من رواية أبي يعلى بسنده عن روح بن حاتم، عن هشيم، عن الكوثر بن حكيم، عن مكحول، عن حذيفة مرفوعًا، ثم علَّق قائلًا: «هذا حديث غريب من هذا الوجه، وفي إسناده ضعف».أخرجه البخاري ٢/١١٥ (١٤٤٢)، ومسلم ٢/٧٠٠ (١٠١٠).أخرجه البخاري ٧/٦٢ (٥٣٥٢)، ومسلم ٢/٦٩٠ (٩٩٣).أخرجه أحمد ٢٣/١٦١ (١٤٨٧٧) بنحوه، والحاكم ٢/٥٧ (٢٣١١)، والبيهقي في شعب الإيمان (١٠٧١٢)، والثعلبي ٨/٩٢.</p><p>قال الحاكم: «هذا حديث صحيح، ولم يخرجاه، وشاهده ليس من شرط هذا الكتاب». وتعقّبه الذهبي في التلخيص بقوله: «عبد الحميد ضعّفوه». وقال الهيثمي في المجمع ٣/١٣٦ (٤٧٥٢): «رواه بطوله أبو يعلى، واختصره الإمام أحمد كما تقدم، وفي إسناد أحمد: المنكدر بن محمد بن المنكدر، وثّقه أحمد وغيره، وضعّفه النسائي وغيره، وفي إسناد أبي يعلى مسور بن الصّلت، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٤/١٨٤ (٣٣٨٨): «هذا إسناد ضعيف؛ لضعف مسور بن الصلت». وقال المناوي في فيض القدير ٥/٣٢ (٦٣٥٣): «وقال في الميزان: غريب جِدًّا». وقال الألباني في الضعيفة ٢/٣٠١ (٨٩٨): «ضعيف ... لكن الجملتان الأوليان من الحديث صحيحتان؛ لأنّ لهما شواهد كثيرة في الصحيحين وغيرهما».