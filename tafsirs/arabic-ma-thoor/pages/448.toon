tafsir[25]{c,v,t}:
  37,52,""
37,53," <q>﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰا وَعِظَـٰمًا أَءِنَّا لَمَدِینُونَ ۝٥٣﴾</q> - تفسير ٦٥٤٠٨- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿أإنّا لَمَدِينُونَ﴾</q>، يقول: أئنا لَمُجازَون بالعمل؟! كما تدين تُدان{1}. (ز) ٦٥٤٠٩- عن مجاهد بن جبر، في قوله: <q>﴿أإنّا لَمَدِينُونَ﴾</q>، قال: لَمُحاسبون{2}. (١٢/٤١٣) ٦٥٤١٠- عن قتادة بن دعامة -من طريق سعيد-، مثله{3}. (١٢/٤١٣) ٦٥٤١١- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿أإنّا لَمَدِينُونَ﴾</q>، قال: غير مُحاسَبين{4}. (ز) ٦٥٤١٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</q>: يعني: لَمُحاسبون{5}٥٤٨٥. (ز) ٥٤٨٥ عَلَّقَ ابنُ كثير (١٢/٢٠) على قول ابن عباس، وقول مجاهد، والسديّ، بقوله: «وكلاهما صحيح». ٦٥٤١٣- عن عطاء الخراساني -من طريق معمر- قوله: <q>﴿أإذا متنا وكنا ترابا وعظاما أإنا لمدينون﴾</q>: أإنا لمحاسبون{6}. (١٢/٤٠٦) ٦٥٤١٤- قال مقاتل بن سليمان: <q>﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</q>، يعني: المحاسبين في أعمالِنا{7}. (ز) ٦٥٤١٥- قال يحيى بن سلّام: <q>﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</q> هما اللذان في سورة الكهف: <q>﴿واضْرِبْ لَهُمْ مَثَلًا رَجُلَيْنِ جَعَلْنا لِأَحَدِهِما جَنَّتَيْنِ﴾</q> [الكهف:٣٢] إلى آخر قصتهما. <q>﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</q> أي: لا نُبعث، ولا نُحاسب{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٤٥.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٥٤٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧٥ (٩٣)-.أخرجه ابن جرير ١٩/٥٤٦. وعلَّقه يحيى بن سلام ٢/٨٣١.أخرجه إسحاق البستي ص٢٠٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٠٧-٦٠٨.تفسير يحيى بن سلام ٢/٨٣١.
37,54," <q>﴿قَالَ هَلۡ أَنتُم مُّطَّلِعُونَ ۝٥٤﴾</q> - قراءات ٦٥٤١٦- عن السُّدِّيّ، قوله: <q>﴿قالَ هَلْ أنْتُم مُّطَّلِعُونَ﴾</q>، قال: كان ابنُ عباس يقرؤها: (هَلْ أنْتُم مُّطْلِعُونِ* فَأُطْلِعَ فَرَآهُ فِي سَوَآءِ الجَحِيمِ){1}٥٤٨٦. (ز) ٥٤٨٦ اسْتَدْرَكَ ابنُ جرير (١٩/٥٤٨-٥٤٩) على هذه القراءة مستندًا إلى اللغة بقوله: "هذه القراءة التي ذكرها السدي عن ابن عباس أنه كان يقرأ في <q>﴿مُطَّلِعُون﴾</q> إن كانت محفوظة عنه فإنها من شواذ الحروف، وذلك أنّ العرب لا تؤثر في المَكْنِي من الأسماء [الضمير] إذا اتصل بفاعل على الإضافة في جمع أو توحيد، لا يكادون أن يقولوا: أنت مكلمني، ولا: أنتما مكلماني، ولا: أنتم مكلموني، ولا: مكلمونني، وإنما يقولون: أنت مكلمي، وأنتما مكلماي، وأنتم مكلمي. وإن قال قائل منهم ذلك، قاله على وجه الغلط توهمًا به: أنت تكلمني، وأنتما تكلمانني، وأنتم تكلمونني، كما قال الشاعر: وما أدري وظني كل ظن... أمسلمني إلى قومي شراحي؟ فقال: مسلمني. وليس ذلك وجه الكلام، بل وجه الكلام: أمسلمي. فأما إذا كان الاسم ظاهرًا، ولم يكن متصلًا بالفاعل، فإنهم ربما أضافوا، وربما لم يضيفوا، فيقال: هذا مكلم أخاك، ومكلم أخيك، وهذان مكلما أخيك، ومكلمان أخاك، وهؤلاء مكلمو أخيك، ومكلمون أخاك؛ وإنما تختار الإضافة في المكني المتصل بفاعل لمصير الحرفين باتصال أحدهما بصاحبه، كالحرف الواحد". وقال ابنُ عطية (٧/٢٨٧): «رَدَّ هذه القراءةَ أبو حاتم وغيره، ولَحَّنُوها، وذلك أنها جمعت بين ياء الإضافة ونون المتكلم، والوجه أن يقال: مُطْلِعِيَّ. ووَجَّهَ القراءة أبو الفتح ابن جني، وقال: أنزل الفاعل منزلة الفعل المضارع». <q>﴿قَالَ هَلۡ أَنتُم مُّطَّلِعُونَ ۝٥٤﴾</q> - تفسير الآية ٦٥٤١٧- قال عبد الله بن عباس: <q>﴿هَلْ أنْتُمْ مُطَّلِعُونَ﴾</q>، وذلك أنّ في الجنة كُوًى، فينظر أهلُها منها إلى النار وأهلِها{2}. (ز) ٦٥٤١٨- عن عبد الله بن عباس، في قوله: (هَلْ أنتُم مُّطْلِعُونِ)، يقول: مطلعونِ إليه حتى أنظر إليه في النار{3}. (١٢/٤١٣) ٦٥٤١٩- عن قتادة بن دعامة -من طريق سعيد- قال: (هَلْ أنتُم مُّطْلِعُونِ)، قال: سأل ربَّه أن يُطْلِعَه{4}. (ز) ٦٥٤٢٠- قال مقاتل بن سليمان: ثم قالَ المؤمنُ لإخوانه في الجنة٥٤٨٧: <q>﴿هل أنْتُمْ مُطَّلِعُونَ﴾</q> إلى النار؛ فتنظرون منزلة أخي؟ فردوا عليه: أنت أعرف به مِنّا، فاطَّلِع أنت. ولأهل الجنة في منازلهم كُوًى، فإذا شاءوا نظروا إلى أهل النار{5}. (ز) ٥٤٨٧ اختلف في قائل:<q>﴿هَلْ أنْتُمْ مُطَّلِعُونَ﴾</q> على ثلاثة أقوال: الأول: أنه قول المؤمن لأصحابه ومحادثيه. والثاني: أنه قول الملائكة لأهل الجنة. والثالث: أنه قول الله ﷿ لأهل الجنة. وذَهَبَ ابنُ القيم (٢/٣٦٨) إلى أنّ القول الأول هو الصحيح وأظهر الأقوال؛ لدلالة السياق. وبيَّن ابنُ عطية (٧/٢٨٧) أن القول الأول يحتمل أن يكون المخاطَب بـ<q>﴿أنتم﴾</q> فيه: الملائكة، أو رفقاؤه في الجنة، أو خَدَمَتَه. ",footnotes:1:أخرجه ابن جرير ١٩/٥٤٨. وقراءة ابن عباس شاذة، تروى أيضًا عن أبي عمرو، وابن محيصن، وغيرهما. انظر: المحتسب ٢/٢١٩، ومختصر ابن خالويه ص١٢٨.تفسير الثعلبي ٨/١٤٥، وتفسير البغوي ٧/٤١.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٤٧، وإسحاق البستي ص٢٠٣ من طريق معمر.تفسير مقاتل بن سليمان ٣/٦٠٨.
37,55," <q>﴿فَٱطَّلَعَ فَرَءَاهُ فِی سَوَاۤءِ ٱلۡجَحِیمِ ۝٥٥﴾</q> - تفسير ٦٥٤٢١- عن عبد الله بن مسعود -من طريق القاسم بن عبد الرحمن- في قوله: <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q>، قال: اطلع، ثم التفت إلى أصحابه، فقال: لقد رأيتُ جماجمَ القوم تغلي{1}. (١٢/٤١٣) ٦٥٤٢٢- عن كعب الأحبار -من طريق قتادة- قال: في الجنة كُوًى، فإذا أراد أحدٌ مِن أهلها أن ينظر إلى عدُوِّه في النار اطَّلَع، فازداد شكرًا{2}. (١٢/٤١٤) ٦٥٤٢٣- عن خليد العصري -من طريق قتادة- في قول الله: <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q>، قال: في وسطها. قال: رأى جماجمهم تغلي، فقال: فلان؟! واللهِ، لولا أنّ الله عرَّفه إيّاه ما عرفه، لقد تغير حِبْرُه وسِبْرُه{3}، فعند ذلك يقول: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q>{4}. (ز) ٦٥٤٢٤- عن مطرف بن عبد الله -من طريق قتادة- في قوله: <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q>، قال: واللهِ، لولا أنّه عرَّفه ما عرفه، لقد غيَّرت النارُ حِبره وسِبره{5}. (ز) ٦٥٤٢٥- قال الحسن البصري: <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q> هذه -واللهِ- الدُّولة{6}. (ز) ٦٥٤٢٦- عن قتادة بن دعامة -من طريق محمد بن يسار- <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q>، قال: ذُكِر لنا: أنّه إذ ذاك اطَّلع، فرأى جماجم القوم تغلي{7}. (ز) ٦٥٤٢٧- عن قتادة بن دعامة -من طريق معمر- في قوله: (هَلْ أنتُم مُّطْلِعُونِ) قال: سأل ربَّه أن يطلعه، <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q> يقول: في وسطها، فرأى جماجمهم تغلي، فقال: فلان! ولولا أنّ الله عرَّفه إيّاه لما عرفه، لقد تغيَّر حِبره وسبره، فعند ذلك قال: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q>{8}. (١٢/٤١٤) ٦٥٤٢٨- عن محمد بن كعب -من طريق أبي معشر- في قوله ﷿: <q>﴿إني كان لي قرين * يقول أءنك لمن المصدقين﴾</q> إلى قوله ﷿: <q>﴿فاطلع فرآه في سواء الجحيم﴾</q>، قال: أبصرهم وجماجم تغلي، فعرَّفه الله إيّاه، ولقد غيَّرتِ النار حِبْرَه وسِبْرَه. فقال سفيان: يعني: لونه وصورته{9}. (ز) ٦٥٤٢٩- قال مقاتل بن سليمان: <q>﴿فاطَّلَعَ﴾</q> المؤمنُ <q>﴿فَرَآهُ﴾</q> فرأى أخاه <q>﴿فِي سَواءِ﴾</q> يعني: في وسط <q>﴿الجَحِيمِ﴾</q> أسود الوجه، أزرق العينين، مقرونًا مع شيطانه في سلسلة{10}. (ز) <q>﴿فِی سَوَاۤءِ ٱلۡجَحِیمِ ۝٥٥﴾</q> - تفسير ٦٥٤٣٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فِي سَواءِ الجَحِيمِ﴾</q>، قال: في وسط الجحيم{11}. (١٢/٤١٣) ٦٥٤٣١- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿فِي سَواءِ الجَحِيمِ﴾</q>. قال: وسط الجحيم. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت قول الشاعر: رماها بسهمٍ فاستوى في سوائِها وكان قَبُولًا للهوادِي الطَّوارقِ{12}. (١٢/٤١٣) ٦٥٤٣٢- عن خليد العصري -من طريق قتادة- في قول الله: <q>﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</q>، قال: في وسطها{13}. (ز) ٦٥٤٣٣- عن الحسن البصري -من طريق عباد بن راشد- في قوله: <q>﴿فِي سَواءِ الجَحِيمِ﴾</q>، قال: في وسط الجحيم{14}. (ز) ٦٥٤٣٤- عن قتادة بن دعامة -من طريق سعيد، وأبي هلال- قال: <q>﴿فِي سَواءِ الجَحِيمِ﴾</q>، أي: في وسط الجحيم{15}. (ز) ٦٥٤٣٥- قال مقاتل بن سليمان: <q>﴿سَواءِ﴾</q> يعني: في وسط <q>﴿الجَحِيمِ﴾</q>{10}. (ز) ٦٥٤٣٦- قال يحيى بن سلّام: <q>﴿هَلْ أنْتُمْ مُطَّلِعُونَ * فاطَّلَعَ﴾</q> فرأى صاحبَه <q>﴿فِي سَواءِ الجَحِيمِ﴾</q> يعني: في وسط الجحيم{17}. (ز) ",footnotes:1:أخرجه هناد (٣١٠). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٥٦-٤٥٧ (٢٥٥)-، وإسحاق البستي ص٢٠٤. وعزاه السيوطي إلى ابن أبي حاتم.حِبْرُه وسِبْرُه: لونه وهيئته. مختار الصحاح ١/٦٥.أخرجه عبد الرزاق ٢/١٤٩، وابن جرير ١٩/٥٤٧ مختصرًا.أخرجه ابن جرير ١٩/٥٤٨.علقه يحيى بن سلام ٢/٨٣٢.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٥٦-٤٥٧ (٢٥٥)-، وإسحاق البستي ص٢٠٤.أخرجه إسحاق البستي ص٢٠٣-٢٠٤. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم. وهو عند عبد الرزاق وابن جرير عن خليد العصري كما تقدم. وعلقه يحيى بن سلام ٢/٨٣٢ مختصرًا.أخرجه سعيد بن منصور في سننه- التفسير ٧/١٥٠ (١٨١١).تفسير مقاتل بن سليمان ٣/٦٠٨.أخرجه ابن جرير ١٩/٥٤٦-٥٤٧، ومن طريق عطية والسدي أيضًا، وابن أبي حاتم -كما الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي في مسائله -كما في الإتقان ٢/٨٨-. والهوادي جمع هادية: وهي مِن كل شيء أوله وما تقدم منه، ومنه هوادي الخيل والوحوش. والطوارق جمع طارقة: وهي التي تسير ليلًا. اللسان (هوي، طرق).أخرجه عبد الرزاق ٢/١٤٩.أخرجه ابن جرير ١٩/٥٤٧.أخرجه ابن جرير ١٩/٥٤٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٨.تفسير يحيى بن سلام ٢/٨٣٢.
37,56," <q>﴿قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرۡدِینِ ۝٥٦﴾</q> - تفسير ٦٥٤٣٧- قال مجاهد بن جبر: <q>﴿قال تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q> يقوله المؤمنُ لشيطانه{1}. (ز) ٦٥٤٣٨- عن قتادة بن دعامة، في قوله: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q>، يقول: لَتهلكني لو أطعتك{2}. (١٢/٤١٤) ٦٥٤٣٩- قال إسماعيل السُّدِّيّ: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q>، يعني: تاللهِ، لقد كدت تغوين{3}. (ز) ٦٥٤٤٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿إنْ كِدْتَ لَتُرْدِينِ﴾</q>، قال: لَتهلكني{4}. (ز) ٦٥٤٤١- قال مقاتل بن سليمان: قال المؤمن: <q>﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q> لتغويني؛ فأنزل منزلتك في النار{5}. (ز) ٦٥٤٤٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿قال تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</q> لتباعدني مِن الله. يقوله المؤمن لصاحبه{6}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٨٣٣.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٣٢.أخرجه ابن جرير ١٩/٥٤٩.تفسير مقاتل بن سليمان ٣/٦٠٨.تفسير يحيى بن سلام ٢/٨٣٢-٨٣٣.
37,57," <q>﴿وَلَوۡلَا نِعۡمَةُ رَبِّی لَكُنتُ مِنَ ٱلۡمُحۡضَرِینَ ۝٥٧﴾</q> - تفسير ٦٥٤٤٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولَوْلا نِعْمَةُ رَبِّي لَكُنْتُ مِنَ المُحْضَرِينَ﴾</q>، قال: في النار{1}. (١٢/٤١٤) ٦٥٤٤٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</q>، قال: مِن المُعَذَّبين{2}. (ز) ٦٥٤٤٥- قال مقاتل بن سليمان: <q>﴿ولَوْلا نِعْمَةُ رَبِّي﴾</q> يقول: لولا ما أنعم الله عَلَيَّ بالإسلام <q>﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</q> النار{3}. (ز) ٦٥٤٤٦- قال يحيى بن سلّام: <q>﴿ولَوْلا نِعْمَةُ رَبِّي﴾</q> الإسلام <q>﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</q> معك في النار{4}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٤٩، وإسحاق البستي ص٢٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ١٩/٥٥٠ من طريق سعيد بلفظ: في عذاب الله.أخرجه ابن جرير ١٩/٥٥٠.تفسير مقاتل بن سليمان ٣/٦٠٨.تفسير يحيى بن سلام ٢/٨٣٢-٨٣٣.
37,58," <q>﴿أَفَمَا نَحۡنُ بِمَیِّتِینَ ۝٥٨ إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝٥٩ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٦٠ لِمِثۡلِ هَـٰذَا فَلۡیَعۡمَلِ ٱلۡعَـٰمِلُونَ ۝٦١﴾</q> - تفسير ٦٥٤٤٧- عن عبد الله بن عباس، قال: قول الله لأهل الجنة: <q>﴿كُلُوا واشْرَبُوا هَنِيئًا بِما كُنْتُمْ تَعْمَلُونَ﴾</q> [المرسلات:٤٣]، قال: قول الله: <q>﴿هَنِيئًا﴾</q> أي: لا تموتون فيها، فعندها قالوا: <q>﴿أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ * إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</q> قال: هذا قول أهل الجنة، يقول الله: <q>﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</q>{1}. (١٢/٤١٥) ٦٥٤٤٨- عن الحسن البصري -من طريق المبارك- قال: علِموا أنّ كل نعيم بعده الموتُ يقطعه، فقالوا: <q>﴿أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ﴾</q>؟ قيل: لا. قالوا: <q>﴿إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</q>{2}. (١٢/٤١٤) ٦٥٤٤٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</q> إلى قوله: <q>﴿الفَوْزُ العَظِيمُ﴾</q> قال: هذا قول أهل الجنة، يقول الله: <q>﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</q>{3}. (١٢/٤١٤) ٦٥٤٥٠- قال مقاتل بن سليمان: ثم انقطع الكلام، ثم أقبل المؤمنُ على أصحابه، فقال: <q>﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</q> عرف المؤمنُ أنّ كلَّ نعيم معه الموت فليس بتامٍّ، <q>﴿إلّا مَوْتَتَنا الأُولى﴾</q> التي كانت في الدنيا، <q>﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</q> فقيل له: إنّك لا تموت فيها. فقال عند ذلك: <q>﴿إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</q>. ثم انقطع كلام المؤمن، يقول الله ﷿: <q>﴿لِمِثْلِ هَذا﴾</q> النعيم الذي ذُكِر قبل هذه الآية في قوله: <q>﴿أولئِكَ لَهُمْ رِزْقٌ معلوم﴾</q>؛ <q>﴿فَلْيَعْمَلِ العامِلُونَ﴾</q> فليسارع المسارعون{4}. (ز) ٦٥٤٥١- قال يحيى بن سلّام: قال: <q>﴿أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى﴾</q> وليس هي إلا موتة واحدة التي كانت في الدنيا، كقوله: <q>﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</q> [النجم:٥٠] ولم يكن عاد قبلها، <q>﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</q> قاله على الاستفهام، وهذا استفهام على سرور، قد أمِن ذلك، <q>﴿إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</q> النجاة العظيمة من النار إلى الجنة، قال الله ﷿: <q>﴿لِمِثْلِ هَذا﴾</q> يعني: ما وُصِف مِمّا فيه أهل الجنة <q>﴿فَلْيَعْمَلِ العامِلُونَ﴾</q>{5}٥٤٨٨. (ز) ٥٤٨٨ قال ابنُ عطية (٧/٢٨٩): «قوله تعالى: <q>﴿إن هذا لهو الفوز العظيم﴾</q> إلى قوله: <q>﴿فليعمل العاملون﴾</q> يحتمل أن يكون من خطاب المؤمن لقرينه. وإليه ذهب قتادة. ويحتمل أن يكون من خطاب الله تعالى لمحمد ﷺ وأمته، ويَقْوى هذا؛ لأن قول المؤمن: <q>﴿لمثل هذا فليعمل العاملون﴾</q>، والآخرة ليست بدار عمل يُقْلِقُ إلا على تجوُّز، كأنه يقول: لمثل هذا كان ينبغي أن يعمل العاملون». <q>﴿أَفَمَا نَحۡنُ بِمَیِّتِینَ ۝٥٨ إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝٥٩ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٦٠ لِمِثۡلِ هَـٰذَا فَلۡیَعۡمَلِ ٱلۡعَـٰمِلُونَ ۝٦١﴾</q> - آثار متعلقة بالآية ٦٥٤٥٢- عن البراء بن عازب، قال: كنتُ أمشي مع رسول الله ﷺ، يدُه في يدي، فرأى جنازة، فأسرع المشي حتى أتى القبر، ثم جثا على ركبتيه، فجعل يبكي حتى بلَّ الثرى، ثم قال: «لمثل هذا فليعمل العاملون»{6}. (١٢/٤١٥) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص٢٠٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٨-٦٠٩.تفسير يحيى بن سلام ٢/٨٣٢-٨٣٣.أخرجه أحمد ٣٠/٥٦٣ (١٨٦٠١)، وابن ماجه ٥/٢٨٦ (٤١٩٥)، بلفظ: «لمثل هذا فأعدوا» عند ابن ماجه، وبلفظ: «لمثل هذا اليوم فأعدوا» عند أحمد، وابن أبي شيبة ٧/٧٩ بلفظ: «لمثل هذا فليعمل العاملون، فأعدوا» من طريق أبي رجاء عبد الله بن واقد الخراساني عن محمد بن مالك عن البراء به. وعزاه السيوطي إلى ابن مردويه. قال النووي في المجموع ٥/٩٥: «بإسناد حسن». وقال المنذري في الترغيب والترهيب ٤/١٢٠: «بإسناد حسن». وقال البوصيري في مصباح الزجاجة ٤/٢٣٤: «هذا إسناد ضعيف، فيه مقال، محمد بن مالك قال فيه أبو حاتم: لا بأس به. وذكره ابن حبان في الثقات، وقال: لم يسمع من البراء بن عازب شيئًا، وذكره أيضًا في الضعفاء، وقال: كان يخطىء كثيرًا، لا يجوز الاحتجاج بخبره إذا انفرد».
  37,59,""
  37,60,""
  37,61,""
37,62," <q>﴿أَذَ ٰ⁠لِكَ خَیۡرࣱ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ ۝٦٢ إِنَّا جَعَلۡنَـٰهَا فِتۡنَةࣰ لِّلظَّـٰلِمِینَ ۝٦٣ إِنَّهَا شَجَرَةࣱ تَخۡرُجُ فِیۤ أَصۡلِ ٱلۡجَحِیمِ ۝٦٤﴾</q> - نزول الآيات ٦٥٤٥٣- عن عبد الله بن عباس، قال: مرَّ أبو جهلٍ برسول الله ﷺ وهو جالس، فلمّا بعُد قال رسول الله ﷺ: <q>﴿أوْلى لَكَ فَأَوْلى * ثُمَّ أوْلى لَكَ فَأَوْلى﴾</q> [القيامة:٣٤-٣٥]. فسمع أبو جهل، فقال: مَن تُوعِد، يا محمد؟ قال: «إيّاك». فقال: بِمَ تُوعِدُني؟ فقال: «أُوعِدُك بالعزيز الكريم». فقال أبو جهل: أليس أنا العزيز الكريم؟! فأنزل الله: <q>﴿إنَّ شَجَرَتَ الزَّقُّومِ * طَعامُ الأَثِيمِ﴾</q> إلى قوله: <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q> [الدخان:٤٣-٤٩]. فلمّا بلغ أبا جهل ما نزل فيه جمَع أصحابه، فأخرج إليهم زبدًا وتمرًا، فقال: تزقَّموا مِن هذا، فواللهِ، ما يتوعدكم محمدًا إلا بهذا. فأنزل الله: <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ﴾</q> إلى قوله: <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q>. فقال في الشَّوب: إنها تختلط باللبنِ، فتشوبُه به، فإنّ لهم على ما يأكلون <q>﴿لَشَوْبًا مِن حَمِيمٍ﴾</q>{1}. (١٢/٤١٦) ٦٥٤٥٤- عن قتادة بن دعامة -من طريق سعيد- قال: لَمّا ذَكر اللهُ شجرة الزقوم افتتن بها الظَّلَمة، فقال أبو جهل: يزعم صاحبُكم هذا أنّ في النار شجرةً، والنار تأكل الشجر، وإنّا -واللهِ- ما نعلمُ الزقومَ إلا التَّمر والزبد، فتَزَقّموا. فأنزل اللهُ حين عجِبوا أن يكون في النار شجرة: <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ* طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</q>{2}. (١٢/٤١٥) ٦٥٤٥٥- عن إسماعيل السُّدِّيّ، قال: لَمّا نزلت: <q>﴿أذَلِكَ خَيْرٌ نُزُلًا أمْ شَجَرَةُ الزَّقُّومِ﴾</q> قالوا: ما نعرف هذه الشجرة؟ فقال عبد الله بن الزِّبَعْرى: لكني -واللهِ- أعرفها، هي شجرةٌ تكون بإفريقية. فلما نزل: <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ * طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</q> قالوا: ما يشبه هذه التي يصف محمدٌ ما قال ابن الزِّبعرى{3}. (ز) ٦٥٤٥٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قال أبو جهل: لَمّا نزلت: <q>﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</q> [الدخان: ٤٣] قال: تعرفونها في كلام العرب؟ أنا آتيكم بها. فدعا جاريةً، فقال: ائتيني بتمر وزبد. فقال: دونكم تزقَّموا، فهذا الزقوم الذي يُخَوِّفكم به محمد. فأنزل الله تفسيرها: <q>﴿أذَلِكَ خَيْرٌ نُزُلًا أمْ شَجَرَةُ الزَّقُّومِ * إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</q>{4}. (ز) <q>﴿أَذَ ٰ⁠لِكَ خَیۡرࣱ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ ۝٦٢ إِنَّا جَعَلۡنَـٰهَا فِتۡنَةࣰ لِّلظَّـٰلِمِینَ ۝٦٣﴾</q> - تفسير ٦٥٤٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</q>، قال: قول أبي جهل: إنّما الزقوم التمر والزبد أتزقَّمه{5}. (١٢/٤١٦) ٦٥٤٥٨- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿فِتْنَةً لِلظّالِمِينَ﴾</q>، قال: زادهم تكذيبًا حين أخبرهم أنّ في النار شجرة، فقال: يخبرهم أنّ في النار شجرة، والنار تحرق الشجر! فأخبرهم أنّ غذاءها مِن النار{6}. (ز) ٦٥٤٥٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</q>، قال: لأبي جهل وأصحابه{4}. (ز) ٦٥٤٦٠- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿أذلِكَ خَيْرٌ نُزُلًا﴾</q> للمؤمنين أمْ نزل الكافر <q>﴿شَجَرَةُ الزَّقُّومِ﴾</q> وهي النار للذين استكبروا عن «لا إله إلا الله» حين أمرهم النبي ﷺ بها، ثم قال -جلَّ وعزَّ-: <q>﴿إنّا جَعَلْناها﴾</q> يعني: الزقوم <q>﴿فِتْنَةً لِلظّالِمِينَ﴾</q> يعني: لمشركي مكة؛ منهم عبد الله بن الزِّبعرى، وأبو جهل بن هشام، والملأ من قريش الذين مشوا إلى أبي طالب، وذلك أنّ ابن الزِّبعرى قال: إنّ الزقوم بكلام اليمن: التمر والزبد. فقال أبو جهل: يا جارية، ابغِنا تمرًا وزبدًا. ثم قال لأصحابه: تزقّموا مِن هذا الذي يُخَوِّفُنا به محمد، يزعم أنّ النار تنبت الشجر، والنار تحرق الشجر! فكان الزقومُ فتنةً لهم{8}. (ز) ٦٥٤٦١- قال يحيى بن سلّام: ثم قال: <q>﴿أذَلِكَ خَيْرٌ نُزُلًا أمْ شَجَرَةُ الزَّقُّومِ﴾</q> أي: إنّه خير نُزُلًا مِن شجرة الزقوم، <q>﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</q> للمشركين. بلغني: أنها في الباب السادس، وأنّها تحيا بلهب النار كما يحيا شجرُكم ببرد الماء. قال: فلا بُدَّ لأهل النار مِن أن ينحدروا إليها، يعني: مَن كان فوقها، فيأكلون منها{9}. (ز) <q>﴿إِنَّهَا شَجَرَةࣱ تَخۡرُجُ فِیۤ أَصۡلِ ٱلۡجَحِیمِ ۝٦٤﴾</q> - تفسير ٦٥٤٦٢- قال الحسن البصري: <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ﴾</q>، أصلها في قَعْر جهنم، وأغصانها ترتفع إلى دَركاتها{10}. (ز) ٦٥٤٦٣- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ﴾</q>، أي: غُذِّيَتْ بالنار، ومنها خُلِقَتْ{11}. (١٢/٤١٥) ٦٥٤٦٤- قال مقاتل بن سليمان: فأخبر الله ﷿ أنها لا تشبه النخل، ولا طلعها كطلع النخل، فقال تبارك وتعالى: <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ﴾</q> تنبت <q>﴿فِي أصْلِ الجَحِيمِ﴾</q>{8}. (ز) <q>﴿إِنَّهَا شَجَرَةࣱ تَخۡرُجُ فِیۤ أَصۡلِ ٱلۡجَحِیمِ ۝٦٤﴾</q> - آثار متعلقة بالآية ٦٥٤٦٥- عن عبد الله بن عباس -من طريق مجاهد- قال: لو أنّ قطرةً مِن زقّومِ جهنم أُنزلت إلى الأرض لأفسدتْ على الناس مَعايِشَهم{13}. (١٢/٤١٧) ٦٥٤٦٦- عن أبي عمران الجوني، قال: بلغنا: أنّ ابنَ آدم لا ينهش مِن شجرة الزقوم نهشةً إلا نهشَتْ مِنه مثلَها{14}. (١٢/٤١٦) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/٥٥٢. وعلَّقه يحيى بن سلام ٢/٨٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٣٣.أخرجه ابن جرير ١٩/٥٥٢.تفسير مجاهد (٥٦٨)، وأخرجه ابن جرير ١٩/٥٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٥٠.أخرجه ابن جرير ١٩/٥٥٢.تفسير مقاتل بن سليمان ٣/٦٠٩.تفسير يحيى بن سلام ٢/٨٣٣-٨٣٤.تفسير الثعلبي ٨/١٤٦، وتفسير البغوي ٧/٤٢.أخرجه ابن جرير ١٩/٥٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٧ (٧٩)-، وابن أبي شيبة ١٣/١٦١.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٨)-. وعزاه السيوطي إلى عبد الله بن أحمد بن حنبل في زوائد الزهد، وابن المنذر.
  37,63,""
  37,64,""
37,65," <q>﴿طَلۡعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّیَـٰطِینِ ۝٦٥﴾</q> - تفسير ٦٥٤٦٧- عن عبد الله بن عباس= (ز) ٦٥٤٦٨- ومحمد بن كعب القرظي: <q>﴿كأنه رؤوس الشياطين﴾</q> هم الشياطين بأعيانهم، شبَّهه بها لقبحها{1}. (ز) ٦٥٤٦٩- عن وهب بن مُنَبِّه، في قوله: <q>﴿طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</q>، قال: شعور الشياطين قائِمَة إلى السماء{2}. (١٢/٤١٦) ٦٥٤٧٠- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</q>، قال: يُشَبِّهها بذلك{3}. (١٢/٤١٥) ٦٥٤٧١- قال مقاتل بن سليمان: <q>﴿طَلْعُها﴾</q> تمرها <q>﴿كَأَنَّهُ رُؤُسُ الشَّياطِينِ﴾</q>{4}. (ز) ٦٥٤٧٢- قال يحيى بن سلّام: وقوله: <q>﴿طَلْعُها﴾</q> أي: ثمرتها <q>﴿كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</q> يقبِّحها بذلك. وقال بعضهم: رءوس الحيات{5}٥٤٨٩. (ز) ٥٤٨٩ اختُلِف في معنى قوله تعالى: <q>﴿طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</q> على ثلاثة أقوال: الأول: شُبِّهَ طلعها بما استقر في النفوس من كراهة رؤوس الشياطين وقبحها، وإن كانت لم تُرَ. والثاني: شُبِّهَ طلعها بنوع من الحيّات رؤُوسها بشعة المنظر. والثالث: شُبِّهَ طلعها بجنس من النبات طلعه في غاية الفحاشة. ذكر الأقوال الثلاثة ابنُ جرير (١٩/٥٥٣)، وابنُ عطية (٧/٢٩٠-٢٩٢)، وكذلك ابنُ كثير (١٢/٢٦) لكنه اسْتَدْرَكَ على القولين الثاني والثالث، بقوله: «وفي هذين الاحتمالين نظر». ثم اختارالقول الأول، فقال: «والأول أقوى وأولى». ولم يذكر مستندًا. ",footnotes:1:تفسير الثعلبي ٨/١٤٦، وتفسير البغوي ٧/٤٢ وقال عقبه: لأنّ الناس إذا وصفوا شيئًا بغاية القبح قالوا: كأنه شيطان، وإن كانت الشياطين لا ترى؛ لأن قبح صورتها متصور في النفس.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٩. كذا جاء في مطبوعته، ولعلها: ثمرها.تفسير يحيى بن سلام ٢/٨٣٣-٨٣٤.
37,66," <q>﴿فَإِنَّهُمۡ لَـَٔاكِلُونَ مِنۡهَا فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ۝٦٦ ثُمَّ إِنَّ لَهُمۡ عَلَیۡهَا لَشَوۡبࣰا مِّنۡ حَمِیمࣲ ۝٦٧﴾</q> - تفسير ٦٥٤٧٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q>، قال: لَمَزْجًا{1}. (١٢/٤١٧) ٦٥٤٧٤- عن عبد الله بن عباس: أن نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿لَشَوْبًا مِن حَمِيمٍ﴾</q>. قال: يختلط الحميم والغساق. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر: تلك المكارم لا قَعْبانِ من لبن شِيبا بماء فعادا بعدً أبوالا{2}؟. (١٢/٤١٧) ٦٥٤٧٥- عن عبد الله بن عباس، قال: <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q> فقال في الشَّوب: إنها تختلط باللبن فتشوبه به، فإن لهم على ما يأكلون <q>﴿لَشَوْبًا مِن حَمِيمٍ﴾</q>{3}. (١٢/٤١٦) ٦٥٤٧٦- عن عبد الله بن عباس، في قوله: <q>﴿لَشَوْبًا مِن حَمِيمٍ﴾</q>، قال: يُخلَط طعامُهم، ويُشاب بالحميم{4}. (١٢/٤١٨) ٦٥٤٧٧- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q>: يعني: شُرب الحميم على الزَّقُّوم{5}. (ز) ٦٥٤٧٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q>، قال: مِزاجًا مِن حميم{6}. (١٢/٤١٨) ٦٥٤٧٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q>، قال: الشوب: الخلط، وهو المَزْج{5}. (ز) ٦٥٤٨٠- قال مقاتل بن سليمان: <q>﴿فَإنَّهُمْ لَآكِلُونَ مِنها﴾</q> مِن ثمرتها، <q>﴿فَمالِئُونَ مِنها﴾</q> مِن ثمرها <q>﴿البُطُونَ ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا﴾</q> يعني: لَمِزاجًا <q>﴿مِن حَمِيمٍ﴾</q> يشربون على إثر الزقوم الحميم الحار الذي قد انتهى حرُّه{8}. (ز) ٦٥٤٨١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q>، قال: حميم يُشاب لهم بغسّاق مما تغسق أعينهم، وصديد مِن قيحهم ودمائهم مما يخرج من أجسادهم{5}. (ز) ٦٥٤٨٢- قال يحيى بن سلّام: قال: <q>﴿فَإنَّهُمْ لَآكِلُونَ مِنها فَمالِئُونَ مِنها﴾</q> مِن الشجرة <q>﴿البُطُونَ ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا﴾</q> لَمِزاجًا <q>﴿مِن حَمِيمٍ﴾</q> وهو الماء الحار فيقطع أمعاءهم، كقوله: <q>﴿وسُقُوا ماءً حَمِيمًا﴾</q> حارًّا <q>﴿فَقَطَّعَ أمْعاءَهُمْ﴾</q> [محمد:١٥]، والحميم: الحارُّ الذي لا يُستطاع من حَرِّه{10}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٥٥. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي -كما في الإتقان ٢/٧٦-. والقعبان: مثنى قعب، وهو القدح الضخم. اللسان (قعب).عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٥٥٥.أخرجه ابن جرير ١٩/٥٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٥.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن جرير ١٩/٥٥٥.تفسير يحيى بن سلام ٢/٨٣٣-٨٣٤.
  37,67,""
37,68," <q>﴿ثُمَّ إِنَّ مَرۡجِعَهُمۡ لَإِلَى ٱلۡجَحِیمِ ۝٦٨﴾</q> - قراءات ٦٥٤٨٣- عن السُّدِّيّ، قال: قراءة عبد الله [بن مسعود]: (ثُمَّ إنَّ مُنقَلَبَهُمْ لَإلى الجَحِيمِ){1}. (ز) ٦٥٤٨٤- عن ابن جريج، قال: في قراءة ابن مسعود: (ثُمَّ إنَّ مَقِيلَهُمْ لَإلى الجَحِيمِ){2}. (١٢/٤١٨) <q>﴿ثُمَّ إِنَّ مَرۡجِعَهُمۡ لَإِلَى ٱلۡجَحِیمِ ۝٦٨﴾</q> - تفسير الآية ٦٥٤٨٥- عن عبد الله بن مسعود -من طريق السُّدِّيّ- قال: لا ينتصف النهارُ يوم القيامة حتى يقيل هؤلاء، ويقيل هؤلاء؛ أهل الجنة وأهل النار. ثم قرأ: (ثُمَّ إنَّ مَقِيلَهُمْ لَإلى الجَحِيمِ){3}. (١٢/٤١٨) ٦٥٤٨٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ثُمَّ إنَّ مَرْجِعَهُمْ لَإلى الجَحِيمِ﴾</q>، قال: فهم في عَناء وعذاب بين نار وحميم. وتلا هذه الآية: <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q> [الرحمن:٤٤]{4}٥٤٩٠. (١٢/٤١٨) ٥٤٩٠ عَلَّقَ ابنُ كثير (١٢/٢٩) على أثر قتادة هذا بقوله: «هكذا تلا قتادة هذه الآية عند هذه الآية، وهو تفسير حَسَنٌ قويٌّ». ٦٥٤٨٧- قال مقاتل بن سليمان: <q>﴿ثُمَّ إنَّ مَرْجِعَهُمْ﴾</q> بعد الزقوم وشرب الحميم٥٤٩١ <q>﴿لَإلى الجَحِيمِ﴾</q>، وذلك قوله: <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q> [الرحمن:٤٤]{5}. (ز) ٥٤٩١ قال ابنُ عطية (٧/٢٩٢): «قوله تعالى: <q>﴿ثم إن مرجعهم﴾</q> يحتمل أن يكون لهم انتقال أجساد في وقت الأكل والشرب، ثم يرجعون إلى معظم الجحيم وكثرته، ذكره الرماني وشبَّهه بقوله تعالى: <q>﴿يطوفون بينها وبين حميم آن﴾</q> [الرحمن:٤٤]. ويحتمل أن يكون الرجوع إنما هو من حال ذلك الأكل المعذب إلى حال الاحتراق دون أكل. وبكل احتمالٍ قيل». ٦٥٤٨٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثُمَّ إنَّ مَرْجِعَهُمْ لَإلى الجَحِيمِ﴾</q>، قال: موتهم{6}. (ز) ٦٥٤٨٩- قال يحيى بن سلّام: قال: <q>﴿ثُمَّ إنَّ مَرْجِعَهُمْ لَإلى الجَحِيمِ﴾</q>، كقوله: <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q> [الرحمن:٤٤] قد انتهى حرُّه{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٥٦. وهي قراءة شاذة. انظر: المحرر الوجيز ٤/٤٧٦، والجامع لأحكام القرآن ١٨/٤٥.أخرجه أبو عبيد في فضائل القرآن (١٨٢). وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة. انظر: المحرر الوجيز ٤/٤٧٦.أخرجه ابن جرير ١٧/٤٣٥، ١٩/٥٥٦، وابن أبي حاتم ٨/٢٦٨٠ (١٥٠٧٩). وعزاه السيوطي إلى ابن المنذر. وفي رواية ابن جرير بدل آية الصافات: ثم قال: <q>﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًا وأَحْسَنُ مَقِيلًا﴾</q> [الفرقان:٢٤].أخرجه ابن جرير ١٩/٥٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن جرير ١٩/٥٥٦.تفسير يحيى بن سلام ٢/٨٣٤.
37,69," <q>﴿إِنَّهُمۡ أَلۡفَوۡا۟ ءَابَاۤءَهُمۡ ضَاۤلِّینَ ۝٦٩﴾</q> - تفسير ٦٥٤٩٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنَّهُمْ ألْفَوْا آباءَهُمْ﴾</q>، قال: وجدوا آباءهم ضالين{1}. (١٢/٤١٩) ٦٥٤٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنَّهُمْ ألْفَوْا آباءَهُمْ ضالِّينَ﴾</q>، قال: جاهلين{2}. (١٢/٤١٩) ٦٥٤٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّهُمْ ألْفَوْا آباءَهُمْ﴾</q>، قال: وجدوا آباءهم ضالين{3}. (١٢/٤١٩) ٦٥٤٩٣- قال مقاتل بن سليمان: <q>﴿إنَّهُمْ ألْفَوْا وجدوا آباءَهُمْ ضالِّينَ﴾</q> عن الهُدى{4}. (ز) ٦٥٤٩٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿إنَّهُمْ ألْفَوْا﴾</q> وجدوا، أدركوا <q>﴿آباءَهُمْ ضالِّينَ﴾</q>{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٥٧، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦٠٩.تفسير يحيى بن سلام ٢/٨٣٤.
37,70," <q>﴿فَهُمۡ عَلَىٰۤ ءَاثَـٰرِهِمۡ یُهۡرَعُونَ ۝٧٠﴾</q> - تفسير ٦٥٤٩٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</q>، قال: كهيئة الهرولة{1}. (١٢/٤١٩) ٦٥٤٩٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</q>: أي: يُسرِعون إسراعًا في ذلك{2}. (١٢/٤١٩) ٦٥٤٩٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿يُهْرَعُونَ﴾</q>، قال: يُسرِعون{3}. (ز) ٦٥٤٩٨- قال محمد بن السائب الكلبي: <q>﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</q> يعملون مثل أعمالهم{4}. (ز) ٦٥٤٩٩- قال مقاتل بن سليمان: <q>﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</q>، يقول: يَسْعَوْن في مثل أعمالِ آبائهم{5}. (ز) ٦٥٥٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿يُهْرَعُونَ إلَيْهِ﴾</q> [هود:٧٨]، قال: يستعجلون إليه{3}. (ز) ٦٥٥٠١- قال يحيى بن سلّام: قوله ﷿: <q>﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</q>، والإهراع: الإسراع{7}. (ز) <q>﴿فَهُمۡ عَلَىٰۤ ءَاثَـٰرِهِمۡ یُهۡرَعُونَ ۝٧٠﴾</q> - آثار متعلقة بالآية ٦٥٥٠٢- قال يحيى بن سلّام: نرى أنّ الذي ينجو مِن النار: مَن ولدته أمُّه لا يسمع الصوت، والذي يتخبطه الشيطان من المس، والاثنان الآخران ليس لهما عذر: الذي مات قبل الإسلام، ومَن أدركه الإسلام وهو هَرِم قد ذهب عقله، وهو قول الله ﷿: <q>﴿إنَّهُمْ ألْفَوْا آباءَهُمْ ضالِّينَ * فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</q>{8}. (ز) ",footnotes:1:تفسير مجاهد (٥٦٨)، وأخرجه يحيى بن سلام ٢/٨٣٤، وابن جرير ١٩/٥٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٧، وعبد الرزاق ٢/١٤٩ من طريق معمر مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥٥٧.تفسير البغوي ٧/٤٣.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن جرير ١٩/٥٥٧.تفسير يحيى بن سلام ٢/٨٣٤.تفسير يحيى بن سلام ٢/٦٥٨.
37,71," <q>﴿وَلَقَدۡ ضَلَّ قَبۡلَهُمۡ أَكۡثَرُ ٱلۡأَوَّلِینَ ۝٧١﴾</q> - تفسير ٦٥٥٠٣- قال إسماعيل السُّدِّيّ: <q>﴿ولَقَدْ ضَلَّ قَبْلَهُمْ أكْثَرُ الأَوَّلِينَ﴾</q>، يعني: غوي قبلَهم أكثرُ الأولين، فكفروا{1}. (ز) ٦٥٥٠٤- قال مقاتل بن سليمان: <q>﴿ولَقَدْ ضَلَّ قَبْلَهُمْ﴾</q> قبل أهل مكة <q>﴿أكْثَرُ الأَوَّلِينَ﴾</q> مِن الأُمَم{2}. (ز) ٦٥٥٠٥- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولَقَدْ ضَلَّ قَبْلَهُمْ﴾</q> قبل مشركي العرب <q>﴿أكْثَرُ الأَوَّلِينَ﴾</q>، كقوله: <q>﴿كانَ أكْثَرُهُمْ مُشْرِكِينَ﴾</q> [الروم:٤٢]{3}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٨٣٤.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٤-٨٣٥.
37,72," <q>﴿وَلَقَدۡ أَرۡسَلۡنَا فِیهِم مُّنذِرِینَ ۝٧٢ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُنذَرِینَ ۝٧٣﴾</q> - تفسير ٦٥٥٠٦- عن الحسن البصري، في قوله: <q>﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</q>، قال: كيف عذّب اللهُ قومَ نوح، وقومَ لوط، وقومَ صالح، والأممَ التي عذَّب الله{1}. (١٢/٤١٩) ٦٥٥٠٧- قال مقاتل بن سليمان: <q>﴿ولَقَدْ أرْسَلْنا فِيهِمْ مُنْذِرِينَ﴾</q> رسلًا يُنذرونهم العذابَ، فكذَّبوا الرسل، فعذَّبهم الله ﷿ في الدنيا، <q>﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</q> يُحَذِّر كفارَ مكة لِئَلّا يُكَذِّبوا محمدًا ﷺ فينزل بهم العذاب في الدنيا{2}. (ز) ٦٥٥٠٨- قال يحيى بن سلّام: <q>﴿ولَقَدْ أرْسَلْنا فِيهِمْ﴾</q> في الذين قبلهم <q>﴿مُنْذِرِينَ﴾</q> يعني: الرسل، أي: فكذّبوهم <q>﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنذَرِينَ﴾</q> الذين أنذرهم الرسل فكذبوهم، عاقبتهم أن دمَّر اللهُ عليهم، ثُمَّ صيَّرهم إلى النار{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٤-٨٣٥.
  37,73,""
37,74," <q>﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٧٤﴾</q> - تفسير ٦٥٥٠٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>، قال: الذين استخلصهم اللهُ{1}. (١٢/٤١٩) ٦٥٥١٠- قال مقاتل بن سليمان: ثم استثنى، فقال -جلَّ وعزَّ-: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q> الموحدين، فإنهم نجوا من العذاب بالتوحيد{2}. (ز) ٦٥٥١١- قال يحيى بن سلّام: قوله ﷿: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>، استثنى مَن آمن وصدَّق الرُّسُل{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٥٨-٥٥٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٤-٨٣٥.
37,75," <q>﴿وَلَقَدۡ نَادَىٰنَا نُوحࣱ فَلَنِعۡمَ ٱلۡمُجِیبُونَ ۝٧٥﴾</q> - تفسير ٦٥٥١٢- عن عائشة، قالت: كان النبيُّ ﷺ إذا صلّى في بيتي، فمرَّ بهذه الآية: <q>﴿ولَقَدْ نادانا نُوحٌ فَلَنِعْمَ المُجِيبُونَ﴾</q>؛ قال: «صدقتَ، ربَّنا، أنت خيرُ مَن دُعِي، وأقربُ مَن بُغِي، فنِعم المَدْعِيُّ، ونِعْم المُعطي، ونِعْم المسؤول، ونِعْم المولى، وأنت ربُّنا ونِعْم النصير»{1}. (١٢/٤٢٠) ٦٥٥١٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولَقَدْ نادانا نُوحٌ فَلَنِعْمَ المُجِيبُونَ﴾</q>، قال: أجابه الله تعالى{2}. (١٢/٤٢٠) ٦٥٥١٤- قال مقاتل بن سليمان: <q>﴿ولَقَدْ نادانا نُوحٌ﴾</q> في «اقتربت»: <q>﴿فَدَعا رَبَّهُ أنِّي مَغْلُوبٌ فانْتَصِرْ﴾</q> [القمر:١٠]، وفي الأنبياء{3}. فأنجاه ربُّه، فغرَّقهم بالماء، فذلك قوله ﷿: <q>﴿فَلَنِعْمَ المُجِيبُونَ﴾</q> يعني الربُّ: نفسَه تعالى{4}. (ز) ٦٥٥١٥- عن مقاتل -من طريق إسحاق بن بشر- قال: <q>﴿ولقد نادنا نوح﴾</q> يعني: انتصرنا، <q>﴿فلنعم﴾</q> ما نصرنا{5}. (ز) ٦٥٥١٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولَقَدْ نادانا نُوحٌ﴾</q> يعني: حيثُ دعا على قومه، <q>﴿فَلَنِعْمَ المُجِيبُونَ﴾</q> له، أجبناه فأهلكناهم{6}. (ز) ",footnotes:1:أخرجه ابن بشران في أماليه ١/٩٧-٩٨ (١٩٣)، من طريق عباد بن أحمد بن عبد الرحمن العرزمي، حدثني عمي، عن أبيه، عن جابر، عن عامر، عن مسروق، عن عائشة به. وعزاه السيوطي إلى ابن مردويه. إسناده ضعيف جدًّا؛ مظلم مسلسل بالضعفاء، فيه عباد بن أحمد العرزمي، قال الذهبي في المغني (٣٠٢٨): «قال الدارقطني: متروك». وعمّه وجدّه محمد بن عبد الرحمن بن محمد العرزمي، قال الدارقطني: «متروك الحديث هو وأبوه وجده». كما في لسان الميزان لابن حجر ٧/٢٩٧. وجابر هو ابن يزيد الجعفي، قال عنه ابن حجر في التقريب (٨٧٨): «ضعيف رافضي».أخرجه ابن جرير ١٩/٥٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.يشير إلى الآية ٧٦ من سورة الأنبياء، وهي: <q>﴿ونوحا إذ نادى من قبل فاستجبنا له فنجيناه وأهله من الكرب العظيم﴾</q>.تفسير مقاتل بن سليمان ٣/٦١٠.أخرجه ابن عساكر في تاريخ دمشق ٦٢/٢٥٧.تفسير يحيى بن سلام ٢/٨٣٥.
37,76," <q>﴿وَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥ مِنَ ٱلۡكَرۡبِ ٱلۡعَظِیمِ ۝٧٦﴾</q> - تفسير ٦٥٥١٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</q>، قال: مِن غرَقِ الطُّوفان{1}٥٤٩٢. (١٢/٤٢٠) ٥٤٩٢ قال ابنُ عطية (٧/٢٩٣): «ومِن الكرب: تكذيب الكفرة، وركوب الماء وهوله». وبنحوه ابنُ جرير (١٩/٥٥٩)، وكذا ابنُ كثير (١٢/٣٠). ٦٥٥١٨- قال مقاتل بن سليمان: <q>﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</q> الهول الشديد، وهو الغرق{2}. (ز) ٦٥٥١٩- قال يحيى بن سلّام: <q>﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</q> من الغرق{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٥٦٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٥.
