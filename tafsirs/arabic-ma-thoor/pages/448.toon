quran[25]{c,v,t}:
  37,52,""
  37,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَءِذَا مِتۡنَا وَكُنَّا تُرَابࣰا وَعِظَـٰمًا أَءِنَّا لَمَدِینُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿أإنّا لَمَدِينُونَ﴾</span>، يقول: أئنا لَمُجازَون بالعمل؟! كما تدين تُدان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿أإنّا لَمَدِينُونَ﴾</span>، قال: لَمُحاسبون{2}. (١٢/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{3}. (١٢/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿أإنّا لَمَدِينُونَ﴾</span>، قال: غير مُحاسَبين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</span>: يعني: لَمُحاسبون{5}<span class=comment-ref>٥٤٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٥</span> <span class="comment-type-4">عَلَّقَ</span> <u>ابنُ كثير</u> (١٢/٢٠) على قول ابن عباس، وقول مجاهد، والسديّ، بقوله: «وكلاهما صحيح».</div></p><p><div></p><p><p><span class="item-no">٦٥٤١٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق معمر- قوله: <span class="qpc-hafs">﴿أإذا متنا وكنا ترابا وعظاما أإنا لمدينون﴾</span>: أإنا لمحاسبون{6}. (١٢/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</span>، يعني: المحاسبين في أعمالِنا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</span> هما اللذان في سورة الكهف: <span class="qpc-hafs">﴿واضْرِبْ لَهُمْ مَثَلًا رَجُلَيْنِ جَعَلْنا لِأَحَدِهِما جَنَّتَيْنِ﴾</span> [الكهف:٣٢] إلى آخر قصتهما. <span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</span> أي: لا نُبعث، ولا نُحاسب{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٤٥.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٥٤٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧٥ (٩٣)-.أخرجه ابن جرير ١٩/٥٤٦. وعلَّقه يحيى بن سلام ٢/٨٣١.أخرجه إسحاق البستي ص٢٠٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٠٧-٦٠٨.تفسير يحيى بن سلام ٢/٨٣١.
  37,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ هَلۡ أَنتُم مُّطَّلِعُونَ ۝٥٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٤١٦<span class="dash">-</span></span> عن السُّدِّيّ، قوله: <span class="qpc-hafs">﴿قالَ هَلْ أنْتُم مُّطَّلِعُونَ﴾</span>، قال: كان <span class="name-1">ابنُ عباس</span> يقرؤها: (هَلْ أنْتُم مُّطْلِعُونِ* فَأُطْلِعَ فَرَآهُ فِي سَوَآءِ الجَحِيمِ){1}<span class=comment-ref>٥٤٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٦</span> <span class="comment-type-2">اسْتَدْرَكَ</span> <u>ابنُ جرير</u> (١٩/٥٤٨-٥٤٩) على هذه القراءة <span class="mustanad">مستندًا إلى اللغة</span> بقوله: "هذه القراءة التي ذكرها السدي عن ابن عباس أنه كان يقرأ في <span class="qpc-hafs">﴿مُطَّلِعُون﴾</span> إن كانت محفوظة عنه فإنها من شواذ الحروف، وذلك أنّ العرب لا تؤثر في المَكْنِي من الأسماء [الضمير] إذا اتصل بفاعل على الإضافة في جمع أو توحيد، لا يكادون أن يقولوا: أنت مكلمني، ولا: أنتما مكلماني، ولا: أنتم مكلموني، ولا: مكلمونني، وإنما يقولون: أنت مكلمي، وأنتما مكلماي، وأنتم مكلمي. وإن قال قائل منهم ذلك، قاله على وجه الغلط توهمًا به: أنت تكلمني، وأنتما تكلمانني، وأنتم تكلمونني، كما قال الشاعر:</p><p>وما أدري وظني كل ظن... أمسلمني إلى قومي شراحي؟</p><p>فقال: مسلمني. وليس ذلك وجه الكلام، بل وجه الكلام: أمسلمي. فأما إذا كان الاسم ظاهرًا، ولم يكن متصلًا بالفاعل، فإنهم ربما أضافوا، وربما لم يضيفوا، فيقال: هذا مكلم أخاك، ومكلم أخيك، وهذان مكلما أخيك، ومكلمان أخاك، وهؤلاء مكلمو أخيك، ومكلمون أخاك؛ وإنما تختار الإضافة في المكني المتصل بفاعل لمصير الحرفين باتصال أحدهما بصاحبه، كالحرف الواحد".</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٨٧): «رَدَّ هذه القراءةَ أبو حاتم وغيره، ولَحَّنُوها، وذلك أنها جمعت بين ياء الإضافة ونون المتكلم، والوجه أن يقال: مُطْلِعِيَّ. ووَجَّهَ القراءة أبو الفتح ابن جني، وقال: أنزل الفاعل منزلة الفعل المضارع».</div></p><p><h3><span class="qpc-hafs">﴿قَالَ هَلۡ أَنتُم مُّطَّلِعُونَ ۝٥٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٤١٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿هَلْ أنْتُمْ مُطَّلِعُونَ﴾</span>، وذلك أنّ في الجنة كُوًى، فينظر أهلُها منها إلى النار وأهلِها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: (هَلْ أنتُم مُّطْلِعُونِ)، يقول: مطلعونِ إليه حتى أنظر إليه في النار{3}. (١٢/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: (هَلْ أنتُم مُّطْلِعُونِ)، قال: سأل ربَّه أن يُطْلِعَه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قالَ المؤمنُ لإخوانه في الجنة<span class=comment-ref>٥٤٨٧</span>: <span class="qpc-hafs">﴿هل أنْتُمْ مُطَّلِعُونَ﴾</span> إلى النار؛ فتنظرون منزلة أخي؟ فردوا عليه: أنت أعرف به مِنّا، فاطَّلِع أنت. ولأهل الجنة في منازلهم كُوًى، فإذا شاءوا نظروا إلى أهل النار{5}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٧</span> اختلف في قائل:<span class="qpc-hafs">﴿هَلْ أنْتُمْ مُطَّلِعُونَ﴾</span> على ثلاثة أقوال: <b>الأول</b>: أنه قول المؤمن لأصحابه ومحادثيه. و<b>الثاني</b>: أنه قول الملائكة لأهل الجنة. و<b>الثالث</b>: أنه قول الله ﷿ لأهل الجنة.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ القيم</u> (٢/٣٦٨) إلى أنّ القول الأول هو الصحيح وأظهر الأقوال؛ <span class="mustanad">لدلالة السياق</span>.</p><p>و<span class="comment-type-4">بيَّن</span> <u>ابنُ عطية</u> (٧/٢٨٧) أن القول الأول يحتمل أن يكون المخاطَب بـ<span class="qpc-hafs">﴿أنتم﴾</span> فيه: الملائكة، أو رفقاؤه في الجنة، أو خَدَمَتَه.</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٤٨.</p><p>وقراءة ابن عباس شاذة، تروى أيضًا عن أبي عمرو، وابن محيصن، وغيرهما. انظر: المحتسب ٢/٢١٩، ومختصر ابن خالويه ص١٢٨.تفسير الثعلبي ٨/١٤٥، وتفسير البغوي ٧/٤١.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٤٧، وإسحاق البستي ص٢٠٣ من طريق معمر.تفسير مقاتل بن سليمان ٣/٦٠٨.
  37,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱطَّلَعَ فَرَءَاهُ فِی سَوَاۤءِ ٱلۡجَحِیمِ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق القاسم بن عبد الرحمن- في قوله: <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span>، قال: اطلع، ثم التفت إلى أصحابه، فقال: لقد رأيتُ جماجمَ القوم تغلي{1}. (١٢/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٢<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق قتادة- قال: في الجنة كُوًى، فإذا أراد أحدٌ مِن أهلها أن ينظر إلى عدُوِّه في النار اطَّلَع، فازداد شكرًا{2}. (١٢/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٣<span class="dash">-</span></span> عن <span class="name-2">خليد العصري</span> -من طريق قتادة- في قول الله: <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span>، قال: في وسطها. قال: رأى جماجمهم تغلي، فقال: فلان؟! واللهِ، لولا أنّ الله عرَّفه إيّاه ما عرفه، لقد تغير حِبْرُه وسِبْرُه{3}، فعند ذلك يقول: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٤<span class="dash">-</span></span> عن <span class="name-2">مطرف بن عبد الله</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span>، قال: واللهِ، لولا أنّه عرَّفه ما عرفه، لقد غيَّرت النارُ حِبره وسِبره{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span> هذه -واللهِ- الدُّولة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق محمد بن يسار- <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span>، قال: ذُكِر لنا: أنّه إذ ذاك اطَّلع، فرأى جماجم القوم تغلي{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: (هَلْ أنتُم مُّطْلِعُونِ) قال: سأل ربَّه أن يطلعه، <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span> يقول: في وسطها، فرأى جماجمهم تغلي، فقال: فلان! ولولا أنّ الله عرَّفه إيّاه لما عرفه، لقد تغيَّر حِبره وسبره، فعند ذلك قال: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>{8}. (١٢/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب</span> -من طريق أبي معشر- في قوله ﷿: <span class="qpc-hafs">﴿إني كان لي قرين * يقول أءنك لمن المصدقين﴾</span> إلى قوله ﷿: <span class="qpc-hafs">﴿فاطلع فرآه في سواء الجحيم﴾</span>، قال: أبصرهم وجماجم تغلي، فعرَّفه الله إيّاه، ولقد غيَّرتِ النار حِبْرَه وسِبْرَه. فقال <span class="name-3">سفيان</span>: يعني: لونه وصورته{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاطَّلَعَ﴾</span> المؤمنُ <span class="qpc-hafs">﴿فَرَآهُ﴾</span> فرأى أخاه <span class="qpc-hafs">﴿فِي سَواءِ﴾</span> يعني: في وسط <span class="qpc-hafs">﴿الجَحِيمِ﴾</span> أسود الوجه، أزرق العينين، مقرونًا مع شيطانه في سلسلة{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی سَوَاۤءِ ٱلۡجَحِیمِ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فِي سَواءِ الجَحِيمِ﴾</span>، قال: في وسط الجحيم{11}. (١٢/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿فِي سَواءِ الجَحِيمِ﴾</span>. قال: وسط الجحيم. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>رماها بسهمٍ فاستوى في سوائِها وكان قَبُولًا للهوادِي الطَّوارقِ{12}. (١٢/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٢<span class="dash">-</span></span> عن <span class="name-2">خليد العصري</span> -من طريق قتادة- في قول الله: <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ فِي سَواءِ الجَحِيمِ﴾</span>، قال: في وسطها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن راشد- في قوله: <span class="qpc-hafs">﴿فِي سَواءِ الجَحِيمِ﴾</span>، قال: في وسط الجحيم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد، وأبي هلال- قال: <span class="qpc-hafs">﴿فِي سَواءِ الجَحِيمِ﴾</span>، أي: في وسط الجحيم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَواءِ﴾</span> يعني: في وسط <span class="qpc-hafs">﴿الجَحِيمِ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿هَلْ أنْتُمْ مُطَّلِعُونَ * فاطَّلَعَ﴾</span> فرأى صاحبَه <span class="qpc-hafs">﴿فِي سَواءِ الجَحِيمِ﴾</span> يعني: في وسط الجحيم{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه هناد (٣١٠). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٥٦-٤٥٧ (٢٥٥)-، وإسحاق البستي ص٢٠٤. وعزاه السيوطي إلى ابن أبي حاتم.حِبْرُه وسِبْرُه: لونه وهيئته. مختار الصحاح ١/٦٥.أخرجه عبد الرزاق ٢/١٤٩، وابن جرير ١٩/٥٤٧ مختصرًا.أخرجه ابن جرير ١٩/٥٤٨.علقه يحيى بن سلام ٢/٨٣٢.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٥٦-٤٥٧ (٢٥٥)-، وإسحاق البستي ص٢٠٤.أخرجه إسحاق البستي ص٢٠٣-٢٠٤. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم. وهو عند عبد الرزاق وابن جرير عن خليد العصري كما تقدم. وعلقه يحيى بن سلام ٢/٨٣٢ مختصرًا.أخرجه سعيد بن منصور في سننه- التفسير ٧/١٥٠ (١٨١١).تفسير مقاتل بن سليمان ٣/٦٠٨.أخرجه ابن جرير ١٩/٥٤٦-٥٤٧، ومن طريق عطية والسدي أيضًا، وابن أبي حاتم -كما الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي في مسائله -كما في الإتقان ٢/٨٨-. والهوادي جمع هادية: وهي مِن كل شيء أوله وما تقدم منه، ومنه هوادي الخيل والوحوش. والطوارق جمع طارقة: وهي التي تسير ليلًا. اللسان (هوي، طرق).أخرجه عبد الرزاق ٢/١٤٩.أخرجه ابن جرير ١٩/٥٤٧.أخرجه ابن جرير ١٩/٥٤٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٨.تفسير يحيى بن سلام ٢/٨٣٢.
  37,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرۡدِینِ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٣٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿قال تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span> يقوله المؤمنُ لشيطانه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>، يقول: لَتهلكني لو أطعتك{2}. (١٢/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٣٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>، يعني: تاللهِ، لقد كدت تغوين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿إنْ كِدْتَ لَتُرْدِينِ﴾</span>، قال: لَتهلكني{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال المؤمن: <span class="qpc-hafs">﴿تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span> لتغويني؛ فأنزل منزلتك في النار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿قال تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span> لتباعدني مِن الله. يقوله المؤمن لصاحبه{6}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٨٣٣.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٣٢.أخرجه ابن جرير ١٩/٥٤٩.تفسير مقاتل بن سليمان ٣/٦٠٨.تفسير يحيى بن سلام ٢/٨٣٢-٨٣٣.
  37,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا نِعۡمَةُ رَبِّی لَكُنتُ مِنَ ٱلۡمُحۡضَرِینَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولَوْلا نِعْمَةُ رَبِّي لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span>، قال: في النار{1}. (١٢/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span>، قال: مِن المُعَذَّبين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْلا نِعْمَةُ رَبِّي﴾</span> يقول: لولا ما أنعم الله عَلَيَّ بالإسلام <span class="qpc-hafs">﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span> النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَوْلا نِعْمَةُ رَبِّي﴾</span> الإسلام <span class="qpc-hafs">﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span> معك في النار{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٤٩، وإسحاق البستي ص٢٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ١٩/٥٥٠ من طريق سعيد بلفظ: في عذاب الله.أخرجه ابن جرير ١٩/٥٥٠.تفسير مقاتل بن سليمان ٣/٦٠٨.تفسير يحيى بن سلام ٢/٨٣٢-٨٣٣.
  37,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَمَا نَحۡنُ بِمَیِّتِینَ ۝٥٨ إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝٥٩ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٦٠ لِمِثۡلِ هَـٰذَا فَلۡیَعۡمَلِ ٱلۡعَـٰمِلُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قول الله لأهل الجنة: <span class="qpc-hafs">﴿كُلُوا واشْرَبُوا هَنِيئًا بِما كُنْتُمْ تَعْمَلُونَ﴾</span> [المرسلات:٤٣]، قال: قول الله: <span class="qpc-hafs">﴿هَنِيئًا﴾</span> أي: لا تموتون فيها، فعندها قالوا: <span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ * إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</span> قال: هذا قول أهل الجنة، يقول الله: <span class="qpc-hafs">﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</span>{1}. (١٢/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- قال: علِموا أنّ كل نعيم بعده الموتُ يقطعه، فقالوا: <span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ﴾</span>؟ قيل: لا. قالوا: <span class="qpc-hafs">﴿إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</span>{2}. (١٢/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿الفَوْزُ العَظِيمُ﴾</span> قال: هذا قول أهل الجنة، يقول الله: <span class="qpc-hafs">﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</span>{3}. (١٢/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم انقطع الكلام، ثم أقبل المؤمنُ على أصحابه، فقال: <span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</span> عرف المؤمنُ أنّ كلَّ نعيم معه الموت فليس بتامٍّ، <span class="qpc-hafs">﴿إلّا مَوْتَتَنا الأُولى﴾</span> التي كانت في الدنيا، <span class="qpc-hafs">﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</span> فقيل له: إنّك لا تموت فيها. فقال عند ذلك: <span class="qpc-hafs">﴿إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</span>. ثم انقطع كلام المؤمن، يقول الله ﷿: <span class="qpc-hafs">﴿لِمِثْلِ هَذا﴾</span> النعيم الذي ذُكِر قبل هذه الآية في قوله: <span class="qpc-hafs">﴿أولئِكَ لَهُمْ رِزْقٌ معلوم﴾</span>؛ <span class="qpc-hafs">﴿فَلْيَعْمَلِ العامِلُونَ﴾</span> فليسارع المسارعون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ * إلّا مَوْتَتَنا الأُولى﴾</span> وليس هي إلا موتة واحدة التي كانت في الدنيا، كقوله: <span class="qpc-hafs">﴿وأَنَّهُ أهْلَكَ عادًا الأُولى﴾</span> [النجم:٥٠] ولم يكن عاد قبلها، <span class="qpc-hafs">﴿وما نَحْنُ بِمُعَذَّبِينَ﴾</span> قاله على الاستفهام، وهذا استفهام على سرور، قد أمِن ذلك، <span class="qpc-hafs">﴿إنَّ هَذا لَهُوَ الفَوْزُ العَظِيمُ﴾</span> النجاة العظيمة من النار إلى الجنة، قال الله ﷿: <span class="qpc-hafs">﴿لِمِثْلِ هَذا﴾</span> يعني: ما وُصِف مِمّا فيه أهل الجنة <span class="qpc-hafs">﴿فَلْيَعْمَلِ العامِلُونَ﴾</span>{5}<span class=comment-ref>٥٤٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٨</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٨٩): «قوله تعالى: <span class="qpc-hafs">﴿إن هذا لهو الفوز العظيم﴾</span> إلى قوله: <span class="qpc-hafs">﴿فليعمل العاملون﴾</span> <b>يحتمل</b> أن يكون من خطاب المؤمن لقرينه. وإليه ذهب قتادة. و<b>يحتمل</b> أن يكون من خطاب الله تعالى لمحمد ﷺ وأمته، ويَقْوى هذا؛ لأن قول المؤمن: <span class="qpc-hafs">﴿لمثل هذا فليعمل العاملون﴾</span>، والآخرة ليست بدار عمل يُقْلِقُ إلا على تجوُّز، كأنه يقول: لمثل هذا كان ينبغي أن يعمل العاملون».</div></p><p><h3><span class="qpc-hafs">﴿أَفَمَا نَحۡنُ بِمَیِّتِینَ ۝٥٨ إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝٥٩ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِیمُ ۝٦٠ لِمِثۡلِ هَـٰذَا فَلۡیَعۡمَلِ ٱلۡعَـٰمِلُونَ ۝٦١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٥٢<span class="dash">-</span></span> عن البراء بن عازب، قال: كنتُ أمشي مع رسول الله ﷺ، يدُه في يدي، فرأى جنازة، فأسرع المشي حتى أتى القبر، ثم جثا على ركبتيه، فجعل يبكي حتى بلَّ الثرى، ثم قال: «<b>لمثل هذا فليعمل العاملون</b>»{6}. (١٢/٤١٥)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص٢٠٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٨-٦٠٩.تفسير يحيى بن سلام ٢/٨٣٢-٨٣٣.أخرجه أحمد ٣٠/٥٦٣ (١٨٦٠١)، وابن ماجه ٥/٢٨٦ (٤١٩٥)، بلفظ: «لمثل هذا فأعدوا» عند ابن ماجه، وبلفظ: «لمثل هذا اليوم فأعدوا» عند أحمد، وابن أبي شيبة ٧/٧٩ بلفظ: «لمثل هذا فليعمل العاملون، فأعدوا» من طريق أبي رجاء عبد الله بن واقد الخراساني عن محمد بن مالك عن البراء به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال النووي في المجموع ٥/٩٥: «بإسناد حسن». وقال المنذري في الترغيب والترهيب ٤/١٢٠: «بإسناد حسن». وقال البوصيري في مصباح الزجاجة ٤/٢٣٤: «هذا إسناد ضعيف، فيه مقال، محمد بن مالك قال فيه أبو حاتم: لا بأس به. وذكره ابن حبان في الثقات، وقال: لم يسمع من البراء بن عازب شيئًا، وذكره أيضًا في الضعفاء، وقال: كان يخطىء كثيرًا، لا يجوز الاحتجاج بخبره إذا انفرد».
  37,59,""
  37,60,""
  37,61,""
  37,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَذَ ٰ⁠لِكَ خَیۡرࣱ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ ۝٦٢ إِنَّا جَعَلۡنَـٰهَا فِتۡنَةࣰ لِّلظَّـٰلِمِینَ ۝٦٣ إِنَّهَا شَجَرَةࣱ تَخۡرُجُ فِیۤ أَصۡلِ ٱلۡجَحِیمِ ۝٦٤﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: مرَّ أبو جهلٍ برسول الله ﷺ وهو جالس، فلمّا بعُد قال رسول الله ﷺ: <span class="qpc-hafs">﴿أوْلى لَكَ فَأَوْلى * ثُمَّ أوْلى لَكَ فَأَوْلى﴾</span> [القيامة:٣٤-٣٥]. فسمع أبو جهل، فقال: مَن تُوعِد، يا محمد؟ قال: «<b>إيّاك</b>». فقال: بِمَ تُوعِدُني؟ فقال: «<b>أُوعِدُك بالعزيز الكريم</b>». فقال أبو جهل: أليس أنا العزيز الكريم؟! فأنزل الله: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ * طَعامُ الأَثِيمِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span> [الدخان:٤٣-٤٩]. فلمّا بلغ أبا جهل ما نزل فيه جمَع أصحابه، فأخرج إليهم زبدًا وتمرًا، فقال: تزقَّموا مِن هذا، فواللهِ، ما يتوعدكم محمدًا إلا بهذا. فأنزل الله: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span>. فقال في الشَّوب: إنها تختلط باللبنِ، فتشوبُه به، فإنّ لهم على ما يأكلون <span class="qpc-hafs">﴿لَشَوْبًا مِن حَمِيمٍ﴾</span>{1}. (١٢/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: لَمّا ذَكر اللهُ شجرة الزقوم افتتن بها الظَّلَمة، فقال أبو جهل: يزعم صاحبُكم هذا أنّ في النار شجرةً، والنار تأكل الشجر، وإنّا -واللهِ- ما نعلمُ الزقومَ إلا التَّمر والزبد، فتَزَقّموا. فأنزل اللهُ حين عجِبوا أن يكون في النار شجرة: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ* طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</span>{2}. (١٢/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: لَمّا نزلت: <span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُزُلًا أمْ شَجَرَةُ الزَّقُّومِ﴾</span> قالوا: ما نعرف هذه الشجرة؟ فقال عبد الله بن الزِّبَعْرى: لكني -واللهِ- أعرفها، هي شجرةٌ تكون بإفريقية. فلما نزل: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ * طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</span> قالوا: ما يشبه هذه التي يصف محمدٌ ما قال ابن الزِّبعرى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قال أبو جهل: لَمّا نزلت: <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</span> [الدخان: ٤٣] قال: تعرفونها في كلام العرب؟ أنا آتيكم بها. فدعا جاريةً، فقال: ائتيني بتمر وزبد. فقال: دونكم تزقَّموا، فهذا الزقوم الذي يُخَوِّفكم به محمد. فأنزل الله تفسيرها: <span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُزُلًا أمْ شَجَرَةُ الزَّقُّومِ * إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَذَ ٰ⁠لِكَ خَیۡرࣱ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ ۝٦٢ إِنَّا جَعَلۡنَـٰهَا فِتۡنَةࣰ لِّلظَّـٰلِمِینَ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span>، قال: قول أبي جهل: إنّما الزقوم التمر والزبد أتزقَّمه{5}. (١٢/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فِتْنَةً لِلظّالِمِينَ﴾</span>، قال: زادهم تكذيبًا حين أخبرهم أنّ في النار شجرة، فقال: يخبرهم أنّ في النار شجرة، والنار تحرق الشجر! فأخبرهم أنّ غذاءها مِن النار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٥٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span>، قال: لأبي جهل وأصحابه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿أذلِكَ خَيْرٌ نُزُلًا﴾</span> للمؤمنين أمْ نزل الكافر <span class="qpc-hafs">﴿شَجَرَةُ الزَّقُّومِ﴾</span> وهي النار للذين استكبروا عن «لا إله إلا الله» حين أمرهم النبي ﷺ بها، ثم قال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إنّا جَعَلْناها﴾</span> يعني: الزقوم <span class="qpc-hafs">﴿فِتْنَةً لِلظّالِمِينَ﴾</span> يعني: لمشركي مكة؛ منهم عبد الله بن الزِّبعرى، وأبو جهل بن هشام، والملأ من قريش الذين مشوا إلى أبي طالب، وذلك أنّ ابن الزِّبعرى قال: إنّ الزقوم بكلام اليمن: التمر والزبد. فقال أبو جهل: يا جارية، ابغِنا تمرًا وزبدًا. ثم قال لأصحابه: تزقّموا مِن هذا الذي يُخَوِّفُنا به محمد، يزعم أنّ النار تنبت الشجر، والنار تحرق الشجر! فكان الزقومُ فتنةً لهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ثم قال: <span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُزُلًا أمْ شَجَرَةُ الزَّقُّومِ﴾</span> أي: إنّه خير نُزُلًا مِن شجرة الزقوم، <span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span> للمشركين. بلغني: أنها في الباب السادس، وأنّها تحيا بلهب النار كما يحيا شجرُكم ببرد الماء. قال: فلا بُدَّ لأهل النار مِن أن ينحدروا إليها، يعني: مَن كان فوقها، فيأكلون منها{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهَا شَجَرَةࣱ تَخۡرُجُ فِیۤ أَصۡلِ ٱلۡجَحِیمِ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٦٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ﴾</span>، أصلها في قَعْر جهنم، وأغصانها ترتفع إلى دَركاتها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ فِي أصْلِ الجَحِيمِ﴾</span>، أي: غُذِّيَتْ بالنار، ومنها خُلِقَتْ{11}. (١٢/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأخبر الله ﷿ أنها لا تشبه النخل، ولا طلعها كطلع النخل، فقال تبارك وتعالى: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ﴾</span> تنبت <span class="qpc-hafs">﴿فِي أصْلِ الجَحِيمِ﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهَا شَجَرَةࣱ تَخۡرُجُ فِیۤ أَصۡلِ ٱلۡجَحِیمِ ۝٦٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: لو أنّ قطرةً مِن زقّومِ جهنم أُنزلت إلى الأرض لأفسدتْ على الناس مَعايِشَهم{13}. (١٢/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦٦<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجوني</span>، قال: بلغنا: أنّ ابنَ آدم لا ينهش مِن شجرة الزقوم نهشةً إلا نهشَتْ مِنه مثلَها{14}. (١٢/٤١٦)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/٥٥٢. وعلَّقه يحيى بن سلام ٢/٨٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٣٣.أخرجه ابن جرير ١٩/٥٥٢.تفسير مجاهد (٥٦٨)، وأخرجه ابن جرير ١٩/٥٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٥٠.أخرجه ابن جرير ١٩/٥٥٢.تفسير مقاتل بن سليمان ٣/٦٠٩.تفسير يحيى بن سلام ٢/٨٣٣-٨٣٤.تفسير الثعلبي ٨/١٤٦، وتفسير البغوي ٧/٤٢.أخرجه ابن جرير ١٩/٥٥٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٧ (٧٩)-، وابن أبي شيبة ١٣/١٦١.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤١ (١٨٨)-. وعزاه السيوطي إلى عبد الله بن أحمد بن حنبل في زوائد الزهد، وابن المنذر.
  37,63,""
  37,64,""
  37,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿طَلۡعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّیَـٰطِینِ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦٨<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القرظي</span>: <span class="qpc-hafs">﴿كأنه رؤوس الشياطين﴾</span> هم الشياطين بأعيانهم، شبَّهه بها لقبحها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٦٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، في قوله: <span class="qpc-hafs">﴿طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</span>، قال: شعور الشياطين قائِمَة إلى السماء{2}. (١٢/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</span>، قال: يُشَبِّهها بذلك{3}. (١٢/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿طَلْعُها﴾</span> تمرها <span class="qpc-hafs">﴿كَأَنَّهُ رُؤُسُ الشَّياطِينِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وقوله: <span class="qpc-hafs">﴿طَلْعُها﴾</span> أي: ثمرتها <span class="qpc-hafs">﴿كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</span> يقبِّحها بذلك. وقال بعضهم: رءوس الحيات{5}<span class=comment-ref>٥٤٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٨٩</span> اختُلِف في معنى قوله تعالى: <span class="qpc-hafs">﴿طَلْعُها كَأَنَّهُ رُءُوسُ الشَّياطِينِ﴾</span> على ثلاثة أقوال: <b>الأول</b>: شُبِّهَ طلعها بما استقر في النفوس من كراهة رؤوس الشياطين وقبحها، وإن كانت لم تُرَ. و<b>الثاني</b>: شُبِّهَ طلعها بنوع من الحيّات رؤُوسها بشعة المنظر. و<b>الثالث</b>: شُبِّهَ طلعها بجنس من النبات طلعه في غاية الفحاشة. ذكر الأقوال الثلاثة <u>ابنُ جرير</u> (١٩/٥٥٣)، و<u>ابنُ عطية</u> (٧/٢٩٠-٢٩٢)، وكذلك <u>ابنُ كثير</u> (١٢/٢٦) لكنه <span class="comment-type-2">اسْتَدْرَكَ</span> على القولين الثاني والثالث، بقوله: «وفي هذين الاحتمالين نظر». ثم <span class="comment-type-3">اختار</span>القول الأول، فقال: «والأول أقوى وأولى». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير الثعلبي ٨/١٤٦، وتفسير البغوي ٧/٤٢ وقال عقبه: لأنّ الناس إذا وصفوا شيئًا بغاية القبح قالوا: كأنه شيطان، وإن كانت الشياطين لا ترى؛ لأن قبح صورتها متصور في النفس.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٩. كذا جاء في مطبوعته، ولعلها: ثمرها.تفسير يحيى بن سلام ٢/٨٣٣-٨٣٤.
  37,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنَّهُمۡ لَـَٔاكِلُونَ مِنۡهَا فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ۝٦٦ ثُمَّ إِنَّ لَهُمۡ عَلَیۡهَا لَشَوۡبࣰا مِّنۡ حَمِیمࣲ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span>، قال: لَمَزْجًا{1}. (١٢/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿لَشَوْبًا مِن حَمِيمٍ﴾</span>. قال: يختلط الحميم والغساق. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>تلك المكارم لا قَعْبانِ من لبن شِيبا بماء فعادا بعدً أبوالا{2}؟. (١٢/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span> فقال في الشَّوب: إنها تختلط باللبن فتشوبه به، فإن لهم على ما يأكلون <span class="qpc-hafs">﴿لَشَوْبًا مِن حَمِيمٍ﴾</span>{3}. (١٢/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لَشَوْبًا مِن حَمِيمٍ﴾</span>، قال: يُخلَط طعامُهم، ويُشاب بالحميم{4}. (١٢/٤١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span>: يعني: شُرب الحميم على الزَّقُّوم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span>، قال: مِزاجًا مِن حميم{6}. (١٢/٤١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span>، قال: الشوب: الخلط، وهو المَزْج{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنَّهُمْ لَآكِلُونَ مِنها﴾</span> مِن ثمرتها، <span class="qpc-hafs">﴿فَمالِئُونَ مِنها﴾</span> مِن ثمرها <span class="qpc-hafs">﴿البُطُونَ ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا﴾</span> يعني: لَمِزاجًا <span class="qpc-hafs">﴿مِن حَمِيمٍ﴾</span> يشربون على إثر الزقوم الحميم الحار الذي قد انتهى حرُّه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٨١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span>، قال: حميم يُشاب لهم بغسّاق مما تغسق أعينهم، وصديد مِن قيحهم ودمائهم مما يخرج من أجسادهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿فَإنَّهُمْ لَآكِلُونَ مِنها فَمالِئُونَ مِنها﴾</span> مِن الشجرة <span class="qpc-hafs">﴿البُطُونَ ثُمَّ إنَّ لَهُمْ عَلَيْها لَشَوْبًا﴾</span> لَمِزاجًا <span class="qpc-hafs">﴿مِن حَمِيمٍ﴾</span> وهو الماء الحار فيقطع أمعاءهم، كقوله: <span class="qpc-hafs">﴿وسُقُوا ماءً حَمِيمًا﴾</span> حارًّا <span class="qpc-hafs">﴿فَقَطَّعَ أمْعاءَهُمْ﴾</span> [محمد:١٥]، والحميم: الحارُّ الذي لا يُستطاع من حَرِّه{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٥٥. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي -كما في الإتقان ٢/٧٦-. والقعبان: مثنى قعب، وهو القدح الضخم. اللسان (قعب).عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٥٥٥.أخرجه ابن جرير ١٩/٥٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٥.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن جرير ١٩/٥٥٥.تفسير يحيى بن سلام ٢/٨٣٣-٨٣٤.
  37,67,""
  37,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ إِنَّ مَرۡجِعَهُمۡ لَإِلَى ٱلۡجَحِیمِ ۝٦٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٨٣<span class="dash">-</span></span> عن السُّدِّيّ، قال: قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (ثُمَّ إنَّ مُنقَلَبَهُمْ لَإلى الجَحِيمِ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٤<span class="dash">-</span></span> عن ابن جريج، قال: في قراءة <span class="name-1">ابن مسعود:</span> (ثُمَّ إنَّ مَقِيلَهُمْ لَإلى الجَحِيمِ){2}. (١٢/٤١٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ إِنَّ مَرۡجِعَهُمۡ لَإِلَى ٱلۡجَحِیمِ ۝٦٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السُّدِّيّ- قال: لا ينتصف النهارُ يوم القيامة حتى يقيل هؤلاء، ويقيل هؤلاء؛ أهل الجنة وأهل النار. ثم قرأ: (ثُمَّ إنَّ مَقِيلَهُمْ لَإلى الجَحِيمِ){3}. (١٢/٤١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهُمْ لَإلى الجَحِيمِ﴾</span>، قال: فهم في عَناء وعذاب بين نار وحميم. وتلا هذه الآية: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span> [الرحمن:٤٤]{4}<span class=comment-ref>٥٤٩٠</span>. (١٢/٤١٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٠</span> <span class="comment-type-4">عَلَّقَ</span> <u>ابنُ كثير</u> (١٢/٢٩) على أثر قتادة هذا بقوله: «هكذا تلا قتادة هذه الآية عند هذه الآية، وهو تفسير حَسَنٌ قويٌّ».</div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهُمْ﴾</span> بعد الزقوم وشرب الحميم<span class=comment-ref>٥٤٩١</span> <span class="qpc-hafs">﴿لَإلى الجَحِيمِ﴾</span>، وذلك قوله: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span> [الرحمن:٤٤]{5}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩١</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٩٢): «قوله تعالى: <span class="qpc-hafs">﴿ثم إن مرجعهم﴾</span> <b>يحتمل</b> أن يكون لهم انتقال أجساد في وقت الأكل والشرب، ثم يرجعون إلى معظم الجحيم وكثرته، ذكره الرماني <span class="mustanad">وشبَّهه بقوله تعالى</span>: <span class="qpc-hafs">﴿يطوفون بينها وبين حميم آن﴾</span> [الرحمن:٤٤]. و<b>يحتمل</b> أن يكون الرجوع إنما هو من حال ذلك الأكل المعذب إلى حال الاحتراق دون أكل. وبكل احتمالٍ قيل».</div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهُمْ لَإلى الجَحِيمِ﴾</span>، قال: موتهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهُمْ لَإلى الجَحِيمِ﴾</span>، كقوله: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span> [الرحمن:٤٤] قد انتهى حرُّه{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٥٦.</p><p>وهي قراءة شاذة. انظر: المحرر الوجيز ٤/٤٧٦، والجامع لأحكام القرآن ١٨/٤٥.أخرجه أبو عبيد في فضائل القرآن (١٨٢). وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة. انظر: المحرر الوجيز ٤/٤٧٦.أخرجه ابن جرير ١٧/٤٣٥، ١٩/٥٥٦، وابن أبي حاتم ٨/٢٦٨٠ (١٥٠٧٩). وعزاه السيوطي إلى ابن المنذر. وفي رواية ابن جرير بدل آية الصافات: ثم قال: <span class="qpc-hafs">﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًا وأَحْسَنُ مَقِيلًا﴾</span> [الفرقان:٢٤].أخرجه ابن جرير ١٩/٥٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن جرير ١٩/٥٥٦.تفسير يحيى بن سلام ٢/٨٣٤.
  37,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ أَلۡفَوۡا۟ ءَابَاۤءَهُمۡ ضَاۤلِّینَ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ ألْفَوْا آباءَهُمْ﴾</span>، قال: وجدوا آباءهم ضالين{1}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ ألْفَوْا آباءَهُمْ ضالِّينَ﴾</span>، قال: جاهلين{2}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ ألْفَوْا آباءَهُمْ﴾</span>، قال: وجدوا آباءهم ضالين{3}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُمْ ألْفَوْا وجدوا آباءَهُمْ ضالِّينَ﴾</span> عن الهُدى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إنَّهُمْ ألْفَوْا﴾</span> وجدوا، أدركوا <span class="qpc-hafs">﴿آباءَهُمْ ضالِّينَ﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٥٧، وابن أبي حاتم -كما في الإتقان ٢/٣٩-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦٠٩.تفسير يحيى بن سلام ٢/٨٣٤.
  37,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَهُمۡ عَلَىٰۤ ءَاثَـٰرِهِمۡ یُهۡرَعُونَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٤٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</span>، قال: كهيئة الهرولة{1}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</span>: أي: يُسرِعون إسراعًا في ذلك{2}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿يُهْرَعُونَ﴾</span>، قال: يُسرِعون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</span> يعملون مثل أعمالهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٤٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</span>، يقول: يَسْعَوْن في مثل أعمالِ آبائهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿يُهْرَعُونَ إلَيْهِ﴾</span> [هود:٧٨]، قال: يستعجلون إليه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</span>، والإهراع: الإسراع{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُمۡ عَلَىٰۤ ءَاثَـٰرِهِمۡ یُهۡرَعُونَ ۝٧٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: نرى أنّ الذي ينجو مِن النار: مَن ولدته أمُّه لا يسمع الصوت، والذي يتخبطه الشيطان من المس، والاثنان الآخران ليس لهما عذر: الذي مات قبل الإسلام، ومَن أدركه الإسلام وهو هَرِم قد ذهب عقله، وهو قول الله ﷿: <span class="qpc-hafs">﴿إنَّهُمْ ألْفَوْا آباءَهُمْ ضالِّينَ * فَهُمْ عَلى آثارِهِمْ يُهْرَعُونَ﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد (٥٦٨)، وأخرجه يحيى بن سلام ٢/٨٣٤، وابن جرير ١٩/٥٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٥٥٧، وعبد الرزاق ٢/١٤٩ من طريق معمر مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٥٥٧.تفسير البغوي ٧/٤٣.تفسير مقاتل بن سليمان ٣/٦٠٩.أخرجه ابن جرير ١٩/٥٥٧.تفسير يحيى بن سلام ٢/٨٣٤.تفسير يحيى بن سلام ٢/٦٥٨.
  37,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ضَلَّ قَبۡلَهُمۡ أَكۡثَرُ ٱلۡأَوَّلِینَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٠٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ولَقَدْ ضَلَّ قَبْلَهُمْ أكْثَرُ الأَوَّلِينَ﴾</span>، يعني: غوي قبلَهم أكثرُ الأولين، فكفروا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ ضَلَّ قَبْلَهُمْ﴾</span> قبل أهل مكة <span class="qpc-hafs">﴿أكْثَرُ الأَوَّلِينَ﴾</span> مِن الأُمَم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولَقَدْ ضَلَّ قَبْلَهُمْ﴾</span> قبل مشركي العرب <span class="qpc-hafs">﴿أكْثَرُ الأَوَّلِينَ﴾</span>، كقوله: <span class="qpc-hafs">﴿كانَ أكْثَرُهُمْ مُشْرِكِينَ﴾</span> [الروم:٤٢]{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٨٣٤.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٤-٨٣٥.
  37,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَرۡسَلۡنَا فِیهِم مُّنذِرِینَ ۝٧٢ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُنذَرِینَ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٠٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</span>، قال: كيف عذّب اللهُ قومَ نوح، وقومَ لوط، وقومَ صالح، والأممَ التي عذَّب الله{1}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا فِيهِمْ مُنْذِرِينَ﴾</span> رسلًا يُنذرونهم العذابَ، فكذَّبوا الرسل، فعذَّبهم الله ﷿ في الدنيا، <span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</span> يُحَذِّر كفارَ مكة لِئَلّا يُكَذِّبوا محمدًا ﷺ فينزل بهم العذاب في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا فِيهِمْ﴾</span> في الذين قبلهم <span class="qpc-hafs">﴿مُنْذِرِينَ﴾</span> يعني: الرسل، أي: فكذّبوهم <span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنذَرِينَ﴾</span> الذين أنذرهم الرسل فكذبوهم، عاقبتهم أن دمَّر اللهُ عليهم، ثُمَّ صيَّرهم إلى النار{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٤-٨٣٥.
  37,73,""
  37,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥٠٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، قال: الذين استخلصهم اللهُ{1}. (١٢/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى، فقال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> الموحدين، فإنهم نجوا من العذاب بالتوحيد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span>، استثنى مَن آمن وصدَّق الرُّسُل{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٥٨-٥٥٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٤-٨٣٥.
  37,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ نَادَىٰنَا نُوحࣱ فَلَنِعۡمَ ٱلۡمُجِیبُونَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥١٢<span class="dash">-</span></span> عن عائشة، قالت: كان النبيُّ ﷺ إذا صلّى في بيتي، فمرَّ بهذه الآية: <span class="qpc-hafs">﴿ولَقَدْ نادانا نُوحٌ فَلَنِعْمَ المُجِيبُونَ﴾</span>؛ قال: «<b>صدقتَ، ربَّنا، أنت خيرُ مَن دُعِي، وأقربُ مَن بُغِي، فنِعم المَدْعِيُّ، ونِعْم المُعطي، ونِعْم المسؤول، ونِعْم المولى، وأنت ربُّنا ونِعْم النصير</b>»{1}. (١٢/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَقَدْ نادانا نُوحٌ فَلَنِعْمَ المُجِيبُونَ﴾</span>، قال: أجابه الله تعالى{2}. (١٢/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ نادانا نُوحٌ﴾</span> في «اقتربت»: <span class="qpc-hafs">﴿فَدَعا رَبَّهُ أنِّي مَغْلُوبٌ فانْتَصِرْ﴾</span> [القمر:١٠]، وفي الأنبياء{3}. فأنجاه ربُّه، فغرَّقهم بالماء، فذلك قوله ﷿: <span class="qpc-hafs">﴿فَلَنِعْمَ المُجِيبُونَ﴾</span> يعني الربُّ: نفسَه تعالى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل</span> -من طريق إسحاق بن بشر- قال: <span class="qpc-hafs">﴿ولقد نادنا نوح﴾</span> يعني: انتصرنا، <span class="qpc-hafs">﴿فلنعم﴾</span> ما نصرنا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولَقَدْ نادانا نُوحٌ﴾</span> يعني: حيثُ دعا على قومه، <span class="qpc-hafs">﴿فَلَنِعْمَ المُجِيبُونَ﴾</span> له، أجبناه فأهلكناهم{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن بشران في أماليه ١/٩٧-٩٨ (١٩٣)، من طريق عباد بن أحمد بن عبد الرحمن العرزمي، حدثني عمي، عن أبيه، عن جابر، عن عامر، عن مسروق، عن عائشة به. وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف جدًّا؛ مظلم مسلسل بالضعفاء، فيه عباد بن أحمد العرزمي، قال الذهبي في المغني (٣٠٢٨): «قال الدارقطني: متروك». وعمّه وجدّه محمد بن عبد الرحمن بن محمد العرزمي، قال الدارقطني: «متروك الحديث هو وأبوه وجده». كما في لسان الميزان لابن حجر ٧/٢٩٧. وجابر هو ابن يزيد الجعفي، قال عنه ابن حجر في التقريب (٨٧٨): «ضعيف رافضي».أخرجه ابن جرير ١٩/٥٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.يشير إلى الآية ٧٦ من سورة الأنبياء، وهي: <span class="qpc-hafs">﴿ونوحا إذ نادى من قبل فاستجبنا له فنجيناه وأهله من الكرب العظيم﴾</span>.تفسير مقاتل بن سليمان ٣/٦١٠.أخرجه ابن عساكر في تاريخ دمشق ٦٢/٢٥٧.تفسير يحيى بن سلام ٢/٨٣٥.
  37,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥ مِنَ ٱلۡكَرۡبِ ٱلۡعَظِیمِ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٥١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</span>، قال: مِن غرَقِ الطُّوفان{1}<span class=comment-ref>٥٤٩٢</span>. (١٢/٤٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٩٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٩٣): «ومِن الكرب: تكذيب الكفرة، وركوب الماء وهوله».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ جرير</u> (١٩/٥٥٩)، و<span class="comment-type-4">كذا</span> <u>ابنُ كثير</u> (١٢/٣٠).</div></p><p><div></p><p><p><span class="item-no">٦٥٥١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</span> الهول الشديد، وهو الغرق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٥١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</span> من الغرق{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٥٦٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦١٠.تفسير يحيى بن سلام ٢/٨٣٥.