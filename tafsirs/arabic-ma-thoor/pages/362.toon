  25,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلرَّسُولُ یَـٰرَبِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقال الرسول يا رب ان قومي اتخذوا هذا القرآن مهجورا﴾</span>: هذا قول نبيِّكم ﷺ، يشتكي قومَه إلى ربِّه{1}. (١١/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span> قوله: <span class="qpc-hafs">﴿وقال الرسول﴾</span> محمد ﷺ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ قَوۡمِی ٱتَّخَذُوا۟ هَـٰذَا ٱلۡقُرۡءَانَ مَهۡجُورࣰا ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٢٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- في قوله: <span class="qpc-hafs">﴿اتخذوا هذا القرآن مهجورا﴾</span>، قال: قالوا فيه هجْرًا غير الحقِّ، ألم تر أنّ المريض إذا هذى قيل: هَجَر؟ أي: قال غير الحق{3}. (١١/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿اتخذوا هذا القرآن مهجورا﴾</span>، قال: يهجرون فيه بالقول السيئ، يقولون: هذا سحر{4}. (١١/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: يهجرون بالقول فيه، يقولون: هو كذب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الرسول يا رب إن قومي﴾</span> قريشًا <span class="qpc-hafs">﴿اتخذوا هذا القرآن مهجورا﴾</span>، يقول: تركوا الإيمان بهذا القرآن، فَهُم مُجانِبون له{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿وقال الرسول يا رب إن قومي اتخذوا هذا القرآن مهجورا﴾</span>، قال: <span class="qpc-hafs">﴿مهجورا﴾</span>: لا يُرِيدون أن يسمعوه، وإن دُعُوا إلى الله قالوا: لا. وقرأ: <span class="qpc-hafs">﴿وهم ينهون عنه وينأون عنه﴾</span> [الأنعام:٢٦]، قال: ينهون عنه، ويَبْعُدون عنه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يا رب إن قومي﴾</span> يعني: مَن لم يؤمن به <span class="qpc-hafs">﴿اتخذوا هذا القرءان مهجورا﴾</span> هجروه، فلم يُؤمِنوا به{2}<span class=comment-ref>٤٧٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٢٧</span> اختُلِف في معنى اتخاذهم القرآن مهجورًا؛ <b>فقال بعضهم</b>: كان اتخاذهم ذلك هجرًا: قولهم فيه السيئ مِن القول، وزعمهم أنّه سحر، وأنه شعر. <b>وقال آخرون</b>: بل معنى ذلك: الخبر عن المشركين أنهم هجروا القرآن، وأعرضوا عنه، ولم يسمعوا له.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٤٤٤) <span class="mustanad">مستندًا إلى النظائر</span> القولَ الثاني الذي قاله ابن زيد، فقال: «وهذا القول أولى بتأويل ذلك، وذلك أنّ الله أخبر عنهم أنهم قالوا: <span class="qpc-hafs">﴿لا تسمعوا لهذا القرآن والغوا فيه﴾</span> [فصلت:٢٦]، وذلك هجرهم إيّاه».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٤٣٦) أنّ الجمهور على أنّ قوله تعالى: <span class="qpc-hafs">﴿وقالَ الرَّسُولُ﴾</span> حكاية عن قول رسول الله ﷺ في الدنيا، وتَشَكِّيه ما يلقى مِن قومه. و<span class="comment-type-3">رجحه</span>، فقال: «وهو الظاهر». ولم يذكر مستندًا. ثم ذكر أنّ فرقةً قالت: هو حكاية عن قول ذلك في الآخرة.</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير يحيى بن سلام ١/٤٨٠.أخرجه ابن جرير ١٧/٤٤٣، وابن أبي حاتم ٨/٢٦٨٦. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٤٤٣، وابن أبي حاتم ٨/٢٦٨٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ١/٤٨٠.تفسير مقاتل بن سليمان ٣/٢٣٣.أخرجه ابن جرير ١٧/٤٤٤، وابن أبي حاتم ٨/٢٦٨٨ مختصرًا من طريق أصبغ.تفسير يحيى بن سلام ١/٤٨٠.
  25,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ جَعَلۡنَا لِكُلِّ نَبِیٍّ عَدُوࣰّا مِّنَ ٱلۡمُجۡرِمِینَۗ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span> نزلت في أبي جهل وحده{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ جَعَلۡنَا لِكُلِّ نَبِیٍّ عَدُوࣰّا مِّنَ ٱلۡمُجۡرِمِینَۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span>، قال: يوطن [محمدًا] ﷺ أنّه جاعِل له عدوًّا مِن المجرمين، كما جُعِل لِمَن قبله{2}. (١١/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿من المجرمين﴾</span>، قال: الكُفّار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span>، قال: كان عدوَّ النبي ﷺ أبو جهل، وعدوَّ موسى قارون، وكان قارون ابن عم موسى{4}. (١١/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: قال الله يُعَزِّي نبيَّه ﷺ: <span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span>، يقول: إنّ الرسل قد لَقِيَت هذا مِن قومها قبلك، فلا يَكْبُرَنَّ عليك{5}. (١١/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span>، قال: لم يُبعَث نبيٌّ قطُّ إلا كان المجرمون له أعداء، ولم يُبعَث نبيٌّ قطُّ إلا كان بعض المجرمين أشد عليه مِن بعض، <span class="qpc-hafs">﴿عدوا من المجرمين﴾</span> فكان عدُوًّا للنبي ﷺ مِن قريش: بنو أمية، وبنو المغيرة{3}. (١١/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿ يُعَزِّي نبيه ﷺ: <span class="qpc-hafs">﴿وكذلك﴾</span> يعني: وهكذا <span class="qpc-hafs">﴿جعلنا لكل نبي عدوا من المجرمين﴾</span> أي: فلا يكبُرَنَّ عليك؛ فإنّ الأنبياء قبلك قد لقيت هذا التكذيبَ مِن قومهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله يُعَزِّي نبيَّه: <span class="qpc-hafs">﴿وكذلك جعلنا لكل نبي عدوا من المجرمين﴾</span> من المشركين{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَفَىٰ بِرَبِّكَ هَادِیࣰا وَنَصِیرࣰا ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿وكفي بربك هاديا﴾</span> إلى دينه، <span class="qpc-hafs">﴿ونصيرا﴾</span> يعني: ومانِعًا، فلا أحد أهدى مِن الله ﷿، ولا أمنع مِنه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: يعني: نصيرًا، أي: إن ينصرك الله فلا يضرك خُذلان مَن خَذَلَك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وكفى بربك هاديا﴾</span> إلى دينه، <span class="qpc-hafs">﴿ونصيرا﴾</span> للمؤمنين على أعدائهم{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٣٣.أخرجه ابن جرير ١٧/٤٤٤-٤٤٥.أخرجه ابن أبي حاتم ٨/٢٦٨٨.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٨/٢٦٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٨٨.تفسير مقاتل بن سليمان ٣/٢٣٣. وفي تفسير البغوي ٦/٨٣ بنحوه منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ١/٤٨٠.تفسير مقاتل بن سليمان ٣/٢٣٣.أخرجه ابن أبي حاتم ٨/٢٦٨٨.تفسير يحيى بن سلام ١/٤٨٠.
  25,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلَّذِینَ كَفَرُوا۟ لَوۡلَا نُزِّلَ عَلَیۡهِ ٱلۡقُرۡءَانُ جُمۡلَةࣰ وَ ٰ⁠حِدَةࣰۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: قال المشركون: إن كان محمدٌ كما يزعم نبيًّا فَلِمَ يُعَذِّبه ربُّه، ألا ينزل عليه القرآن جملةً واحدةً؟ ينزل عليه الآية والآيتين والسورة! فأنزل الله على نبيِّه جوابَ ما قالوا: <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة﴾</span> إلى: <span class="qpc-hafs">﴿وأضل سبيلا﴾</span>{1}. (١١/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٣٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>: قلتُ لابن عباس: أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿إنا أنزلناه في ليلة القدر﴾</span> [القدر:١]، و<span class="qpc-hafs">﴿إنا أنزلناه في ليلة مباركة﴾</span> [الدخان:٣]، وعن <span class="qpc-hafs">﴿شهر رمضان الذي أنزل فيه القرآن﴾</span> [البقر:١٨٥] أكله أم بعضه؟ فقال ابن عباس: أنزل الله القرآن جملةً واحدة مِن السماء السابعة إلى سماء الدنيا في ليلة القدر، فجُعِل عند مواقع النجوم: <span class="qpc-hafs">﴿فلا أقسم بمواقع النجوم﴾</span> إلى قوله: <span class="qpc-hafs">﴿المطهرون﴾</span> [الواقعة:٧٥-٧٩] الملائكة، وينزل به جبريلُ ﵇ كلَّما أُتِيَ بمَثَل يلتمس عيْبَه نزل به كتابُ الله ناطقٌ، فقالت اليهود: يا أبا القاسم، لولا أنزل هذا القرآن جملة واحدة، كما أُنزِلَت التوراة على موسى. فأنزل الله: <span class="qpc-hafs">﴿كذلك لنثبت به فؤادك ورتلناه ترتيلا، ولا يأتونك بمثل إلا جئناك بالحق وأحسن تفسيرا﴾</span>. وقرأ: <span class="qpc-hafs">﴿وقرآنا فرقناه لتقرأه على الناس على مكث﴾</span> [الإسراء:١٠٦]{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلَّذِینَ كَفَرُوا۟ لَوۡلَا نُزِّلَ عَلَیۡهِ ٱلۡقُرۡءَانُ جُمۡلَةࣰ وَ ٰ⁠حِدَةࣰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القران جملة واحدة﴾</span>، قال: يقولون: هلّا أُنزل عليه القرآن جملة واحدة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة﴾</span>: يقولون: كما أُنزِل على موسى، وعلى عيسى{4}. (١١/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القران جملة واحدة﴾</span>، قال: هلّا جاء به كما جاء به موسى -صلى الله عليهما-{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل﴾</span> يعني: هلّا نزل <span class="qpc-hafs">﴿عليه القرآن جملة واحدة﴾</span> كما جاء به موسى وعيسى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة﴾</span>: كما أُنزِلَت التوراةُ على موسى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٤<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿لولا نزل عليه القرآن جملة واحدة﴾</span>: قالوا: لأيِّ شيء لا ينزل عليه القرآنُ جملة واحدة، كما أُنزِل على موسى وعيسى؟!{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٥<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وقال الذين كفروا لولا﴾</span>: يعني: هلا <span class="qpc-hafs">﴿أنزل عليه القرآن جملة واحدة﴾</span> كما أنزل على موسى وعلى عيسى. قال الله ﷿: <span class="qpc-hafs">﴿كذلك لنثبت به فؤادك﴾</span>{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ لِنُثَبِّتَ بِهِۦ فُؤَادَكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿كذلك لنثبت به فؤادك﴾</span>، قال: كان الله ينزل عليه الآية، فإذا علِمها نبيُّ الله ﷺ نزلت آيةٌ أخرى؛ ليُعلِّمه الكتاب عن ظهر قلبه، ويُثَبِّتَ به فؤاده{10}. (١١/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿كذلك لنثبت﴾</span>، قال: لنثبت به فؤادَك، يا محمد. يقول: لِنَشْدُد به فؤادَك، ونربط على قلبك، يعني: بوحيه الذي نزل به جبريلُ عليك مِن عند الله، وكذلك يفعل بالمرسلين مِن قبلك{11}. (١١/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿كذلك لنثبت به فؤادك﴾</span>، يعني: لِيُثَبِّت القرآنَ في قلبك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿كذلك لنثبت به فؤادك ورتلناه ترتيلا﴾</span>، قال: كان ينزل عليه القرآنُ جوابًا لقولهم؛ لِيُعْلَم أنّ الله هو يجيب القومَ عمّا يقولون{13}<span class=comment-ref>٤٧٢٨</span>. (١١/١٧٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٢٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٤٣٧) أن قوله: <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يحتمل احتمالين: <b>أحدهما</b>: أن يكون مِن قول الكفار إشارة إلى التوراة والإنجيل. <b>والآخر</b>: أن يكون مستأنفًا مِن كلام الله لا من كلامهم.</p><p>و<span class="comment-type-3">رجَّح</span> الاحتمالَ الثاني، فقال: «وهو أولى، ومعناه: كما نزل أردناه. فالإشارة إلى نزوله متفرقًا». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿وَرَتَّلۡنَـٰهُ تَرۡتِیلࣰا ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قالت قريش: ما لِلقرآن لم ينزل على النبيِّ جُملةً واحدةً؟ قال الله في كتابه: <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة كذلك لنثبت به فؤادك ورتلناه ترتيلا﴾</span>، قال: قليلًا قليلًا ...{14}. (١١/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: رسَّلناه تَرْسِيلًا. يقول: شيئًا بعد شيء{15}. (١١/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: بيَّنّاه بيانًا. والترتيل: التَّبْيِين في تَرَسُّل وتَثَبُّت{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، يقول: نزل مُتَفَرِّقًا{17}. (١١/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٤<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: بعضه على إثْر بعض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٥<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابن طاووس- قال: الترتيل: تبيينه حتى تفهمه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: كان يُنَزِّل عليه الآية والآيتين وآيات، كان ينزل جوابًا لهم؛ إذا سألوا رسول الله ﷺ عن شيء أنزل الله جوابًا لهم ورَدًّا عن النبي ﷺ فيما تكلموا به، وكان بين أوله وآخره نحوٌ مِن عشرين سنةً{20}. (١١/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٧<span class="dash">-</span></span> قال ابن جُرَيْج: قلتُ ل<span class="name-2">عطاء [بن أبي رباح]</span>: ما قوله تعالى: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>؟ قال: الطرح: هو النبذ؛ فإذًا هو لا يُوجِب الترتيل{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: بيَّنّاه تَبْيِينًا{22}. (١١/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٥٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: فرَّقناه تفريقًا، آية بعد آية{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: فَصَّلناه تفصيلًا{24}. (١١/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، يعني: نُرسِله تَرَسُّلًا، آيات ثم آيات، ذلك قوله سبحانه: <span class="qpc-hafs">﴿وقرآنا فرقناه لتقرأه على الناس على مكث ونزلناه تنزيلا﴾</span> [الإسراء:١٠٦]{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: كان بين ما أنزل القرآنُ إلى آخره؛ أُنزِل عليه لأربعين، ومات النبيُّ ﷺ لثنتين أو لثلاث وستين{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ورتلناه ترتيلا﴾</span>، قال: فسَّرناه تفسيرًا. وقرأ: <span class="qpc-hafs">﴿ورتل القرآن ترتيلا﴾</span> [المزمل:٤]{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٤<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- قال: والترتيل والترسيل بعضُها على إثر بعض{28}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى ١٠/٣٤١ (١١٦٢٥)، والحاكم ٢/٢٤٢ (٢٨٧٨)، ٢/٥٧٨ (٣٩٥٨)، وابن أبي حاتم ٨/٢٦٨٩(١٥١٢٦) واللفظ له.</p><p>قال الحاكم: «هذا حديث صحيح، على شرطهما، ولم يخرجاه».أخرجه ابن أبي حاتم ٨/٢٦٨٩ (١٥١٢٧)، من طريق عبد الرحمن بن عمر بن رسته الأصبهاني، ثنا ابن مهدي، ثنا أبو سلمة، عن حكيم بن جبير، عن سعيد بن جبير، عن ابن عباس به.</p><p>إسناده ضعيف؛ فيه حكيم بن جُبَيْر الأسدي الكوفي، قال عنه ابن حجر في التقريب (١٤٦٨): «ضعيف».أخرجه ابن أبي حاتم ٨/٢٦٩٠ (١٥٣٠).أخرجه ابن أبي حاتم ٨/٢٦٨٩. وعلَّقه يحيى بن سلام ١/٤٨٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٩٠.تفسير مقاتل بن سليمان ٣/٢٣٣.أخرجه ابن جرير ١٧/٤٤٦.أخرجه إسحاق البستي في تفسيره ص٥٠٧.تفسير يحيى بن سلام ١/٤٨٠. وقوله: «كما أنزل على موسى وعلى عيسى» أخرجه أبو عمرو الداني في المكتفى ص١٤٨ (٢٠). وجاء في تفسير يحيى بن سلام ١/٤٨٠ منسوبًا إلى قتادة كما تقدم.أخرجه ابن جرير ١٧/٤٤٥، وابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٨/٢٦٩٠. وعزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٣٤.أخرجه ابن جرير ١٧/٤٤٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٨/٢٦٩٠ (١٥١٣٣). وعزاه السيوطي إلى ابن مردويه.تفسير البغوي ٦/٨٣.أخرجه ابن جرير ١٧/٤٤٦، وابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٥٠٧.أخرجه عبد الرزاق ٢/٣٩٢.أخرجه عبد الرزاق ٢/٦٩، وابن جرير ١٧/٤٤٦-٤٤٧، وابن أبي حاتم ٨/٢٦٩٠. وعزاه السيوطي إلى ابن المنذر. وفي تفسير الثعلبي ٧/١٣٢: فرَّقناه تفريقًا آية بعد آية، وشيئًا بعد شيء، وكان بين أوله وآخره نحوٌ من ثلاث وعشرين سنة.أخرجه عبد الرزاق ٢/٣٩٢. كذا ورد فيه بهذا اللفظ عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وقُرْآنًا فَرَقْناهُ لِتَقْرَأَهُ عَلى النّاسِ عَلى مُكْثٍ ونَزَّلْناهُ تَنْزِيلًا﴾</span> [الإسراء:١٠٦].أخرجه ابن أبي حاتم ٨/٢٦٩١. وعلَّقه يحيى بن سلام ١/٤٨٠. وعزاه السيوطي إلى عبد بن حميد. وعقَّب عليه يحيى بن سلام بقوله: نزل في ثلاث وعشرين سنة.تفسير البغوي ٦/٨٣.أخرجه ابن أبي حاتم ٨/٢٦٩١.تفسير مقاتل بن سليمان ٣/٢٣٤.أخرجه ابن جرير ١٧/٤٤٧.أخرجه ابن جرير ١٧/٤٤٧، وابن أبي حاتم ٨/٢٦٩١ من طريق أصبغ.أخرجه إسحاق البستي في تفسيره ص٥٠٨.