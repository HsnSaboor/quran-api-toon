tafsir[10]{c,v,t}:
24,44," <q>﴿یُقَلِّبُ ٱللَّهُ ٱلَّیۡلَ وَٱلنَّهَارَۚ﴾</q> - تفسير ٥٣٧٦٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿يقلب الله الليل والنهار﴾</q>، قال: يأتي بالليل ويذهب بالنهار، ويأتي بالنهار ويذهب بالليل{1}. (١١/٩٣) ٥٣٧٦٦- قال مقاتل بن سليمان: <q>﴿يقلب الله الليل والنهار﴾</q>، يعني بالتقلب: اختلافهما؛ أنه يأتي بالليل ويذهب بالنهار، ثم يأتي بالنهار ويذهب بالليل{2}. (ز) ٥٣٧٦٧- قال يحيى بن سلّام: قوله: <q>﴿يقلب الله الليل والنهار﴾</q> هو أخْذ كلِّ واحد منهما مِن صاحبه، كقوله: <q>﴿يولج الليل في النهار ويولج النهار في الليل﴾</q> [الحديد:٦]{3}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّأُو۟لِی ٱلۡأَبۡصَـٰرِ ۝٤٤﴾</q> - تفسير ٥٣٧٦٨- قال إسماعيل السدي: لَمَعرِفة{4}. (ز) ٥٣٧٦٩- عن الربيع [بن أنس] -من طريق أبي جعفر الرازي- قوله: <q>﴿إن في ذلك لعبرة لأولي الأبصار﴾</q>، يقول: لقد كان في هؤلاء عبرةٌ ومُتَفَكَّر{1}. (ز) ٥٣٧٧٠- قال مقاتل بن سليمان: <q>﴿إن في ذلك لعبرة لأولي الأبصار﴾</q>، يعني: لأهل البصائر في أمر الله ﷿{2}. (ز) ٥٣٧٧١- قال يحيى بن سلّام: <q>﴿إن في ذلك لعبرة﴾</q> لآية <q>﴿لأولي﴾</q> لذوي <q>﴿الأبصار﴾</q> وهم المؤمنون، أبْصَرُوا الهُدى{7}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّأُو۟لِی ٱلۡأَبۡصَـٰرِ ۝٤٤﴾</q> - آثار متعلقة بالآية ٥٣٧٧٢- عن أبي هريرة، قال: قال رسول الله ﷺ: «قال الله ﷿: يُؤذِيني ابنُ آدم؛ يَسُبُّ الدهرَ، وأنا الدهرُ، بيدي الأمر، أُقلِّب الليل والنهار»{8}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦١٩.تفسير مقاتل بن سليمان ٣/٢٠٤.تفسير يحيى بن سلّام ١/٤٥٥.علَّقه يحيى بن سلّام ١/٤٥٦.أخرجه ابن أبي حاتم ٨/٢٦١٩.تفسير مقاتل بن سليمان ٣/٢٠٤.تفسير يحيى بن سلّام ١/٤٥٥-٤٥٦.أخرجه البخاري ٦/١٣٣ (٤٨٢٦)، ٨/٤١ (٦١٨١)، ٩/١٤٣ (٧٤٩١)، ومسلم ٤/١٧٦٢ (٢٢٤٦)، وابن أبي حاتم ١٠/٣٢٩١ (١٨٥٣٧)، ١٠/٣٢٩٢ (١٨٥٣٩)، والثعلبي ٧/١١٢، ٨/٣٦٤.
24,45," <q>﴿وَٱللَّهُ خَلَقَ كُلَّ دَاۤبَّةࣲ مِّن مَّاۤءࣲۖ﴾</q> - قراءات ٥٣٧٧٣- عن عبد الله بن مغفل أنّه قرأ: ‹واللَّهُ خالِقُ كُلِّ دَآبَّةٍ مِّن مّاءٍ›{1}٤٦٨٩. (١١/٩٣) ٤٦٨٩ ذكر ابنُ جرير (١٧/٣٣٩) هذه القراءة، وقراءة من قرأ ذلك <q>﴿خلق﴾</q>، ثم علّق قائلًا: «وهما قراءتان مشهورتان متقاربتا المعنى، وذلك أنّ الإضافة في قراءة من قرأ ذلك ‹خالِقُ› تدل على أنّ معنى ذلك المضي، فبأيتهما قرأ القارئ فمصيب». <q>﴿وَٱللَّهُ خَلَقَ كُلَّ دَاۤبَّةࣲ مِّن مَّاۤءࣲۖ﴾</q> - تفسير الآية ٥٣٧٧٤- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿والله خلق كل دابة من ماء﴾</q>، يعني: النطفة{2}. (ز) ٥٣٧٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق أصْبَغ- <q>﴿والله خلق كل دابة من ماء﴾</q>، قال: الماء: النطفة مِن الفحول{3}. (١١/٩٣) <q>﴿وَٱللَّهُ خَلَقَ كُلَّ دَاۤبَّةࣲ مِّن مَّاۤءࣲۖ﴾</q> - آثار متعلقة بالآية ٥٣٧٧٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «كل شيء خُلِق من الماء». قال يحيى بن سلّام: أُراه يعني: الحيوان. نحو قول السُّدِّيّ{4}. (ز) <q>﴿فَمِنۡهُم مَّن یَمۡشِی عَلَىٰ بَطۡنِهِۦ وَمِنۡهُم مَّن یَمۡشِی عَلَىٰ رِجۡلَیۡنِ وَمِنۡهُم مَّن یَمۡشِی عَلَىٰۤ أَرۡبَعࣲۚ یَخۡلُقُ ٱللَّهُ مَا یَشَاۤءُۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣱ ۝٤٥﴾</q> - تفسير ٥٣٧٧٧- عن عبد الله بن عباس، قال: كل شيء يمشي على أربع، إلا الإنسان{5}. (١١/٩٤) ٥٣٧٧٨- قال مقاتل بن سليمان: <q>﴿والله خلق كل دابة من ماء فمنهم من يمشي على بطنه﴾</q> يعني: الهوام، <q>﴿ومنهم من يمشي على رجلين﴾</q> الإنس، والجن، والطير، <q>﴿ومنهم من يمشي على أربع﴾</q> قوائم، يعني: الدواب، والأنعام، والوحش، والسِّباع، <q>﴿يخلق الله ما يشاء إن الله على كل شيء﴾</q> مِن الخلق <q>﴿قدير﴾</q>{6}. (ز) ٥٣٧٧٩- قال يحيى بن سلّام: <q>﴿فمنهم من يمشي على بطنه﴾</q> الحية، <q>﴿ومنهم من يمشي على رجلين ومنهم من يمشي على أربع﴾</q> أي: ومنهم مَن يمشي على أكثر مِن ذلك. وإنما قال: فمنهم مَن يمشي على كذا، ومنهم مَن يمشي على كذا، ومنهم يمشي على كذا، خَلْقُ اللهِ كثيرٌ. قال: <q>﴿ويخلق ما لا تعلمون﴾</q> [النحل:٨]، قوله: <q>﴿يخلق الله ما يشاء إن الله على كل شيء قدير﴾</q>{7}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <q>﴿واللَّهُ خَلَقَ كُلَّ دابَّةٍ مِن ماءٍ﴾</q> دون ألف، مع فتح اللام. انظر: النشر ٢/٣٣٢، والإتحاف ص٤١٢.علَّقه يحيى بن سلّام ١/٤٥٦.أخرجه ابن أبي حاتم ٨/٢٦٢٠.أخرجه أحمد ١٣/٣١٤ (٧٩٣٢)، ١٤/٤٩ (٨٢٩٥، ٨٢٩٦)، ١٦/٢٥٢-٢٥٣ (١٠٣٩٩)، وابن حبان ٦/٢٩٩ (٢٥٥٩)، والحاكم ٤/١٧٦ (٧٢٧٨)، ويحيى بن سلّام ١/٣٠٩، ٤٥٦ قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن مفلح في الآداب الشرعية ١/٤٢١: «إسناد جيد». وقال الهيثمي في المجمع ٥/١٦ (٧٨٦٥): «رواه أحمد، ورجاله رجال الصحيح، خلا أبي ميمونة، وهو ثقة». وقال ابن حجر في الفتح ٥/٢٩: «إسناده صحيح». وقال البوصيري في إتحاف الخيرة ٥/٤٨١-٤٨٢ (٥٠٥٢): «رواه أبو بكر بن أبي شيبة، ورواته ثقات». وقال الألباني في الضعيفة ٣/٤٩٢: «وهذا إسناد ضعيف».عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠٤.تفسير يحيى بن سلّام ١/٤٥٦.
24,46," <q>﴿لَّقَدۡ أَنزَلۡنَاۤ ءَایَـٰتࣲ مُّبَیِّنَـٰتࣲۚ وَٱللَّهُ یَهۡدِی مَن یَشَاۤءُ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٤٦﴾</q> - تفسير ٥٣٧٨٠- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- في قوله: <q>﴿لقد أنزلنا آيات﴾</q> هو هذا القرآن؛ فيه حلاله وحرامه{1}. (ز) ٥٣٧٨١- قال مقاتل بن سليمان: <q>﴿لقد أنزلنا آيات مبينات﴾</q> لِما فيه مِن أمره ونهيه، <q>﴿والله يهدي من يشاء إلى صراط مستقيم﴾</q> يعني: إلى دين مستقيم، يعني: الإسلام، وغيره من الأديان ليس بمستقيم{2}. (ز) ٥٣٧٨٢- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- قوله: <q>﴿لقد أنزلنا آيات مبينات﴾</q>: يعني: ما فرض عليهم في هذه السورة مِن أوَّلها إلى آخرها{1}. (ز) ٥٣٧٨٣- قال يحيى بن سلّام، في قوله: <q>﴿لقد أنزلنا آيات مبينات﴾</q>: القرآن، ما يُبَيِّن الله فيه، <q>﴿والله يهدي من يشاء إلى صراط مستقيم﴾</q> إلى دين مستقيم. والصراط: الطريق المستقيم إلى الجنة{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير مقاتل بن سليمان ٣/٢٠٤.أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير يحيى بن سلّام ١/٤٥٦.
24,47," <q>﴿وَیَقُولُونَ ءَامَنَّا بِٱللَّهِ وَبِٱلرَّسُولِ وَأَطَعۡنَا ثُمَّ یَتَوَلَّىٰ فَرِیقࣱ مِّنۡهُم مِّنۢ بَعۡدِ ذَ ٰ⁠لِكَۚ وَمَاۤ أُو۟لَـٰۤىِٕكَ بِٱلۡمُؤۡمِنِینَ ۝٤٧﴾</q> - نزول الآية، وتفسيرها ٥٣٧٨٤- عن أبي العالية الرِّياحي -من طريق الربيع بن أنس- قوله: <q>﴿ويقولون آمنا بالله﴾</q>، قال: هؤلاء المنافقين{1}. (ز) ٥٣٧٨٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ويقولون آمنا بالله وبالرسول وأطعنا ثم يتولى فريق منهم من بعد ذلك وما أولئك بالمؤمنين﴾</q>، قال: أُناس مِن المنافقين أظهروا الإيمان والطاعة، وهم في ذلك يَصُدُّون عن سبيل الله وطاعته وجهادٍ مع رسوله{2}. (١١/٩٤) ٥٣٧٨٦- قال مقاتل بن سليمان: <q>﴿ويقولون آمنا بالله﴾</q> يعني: صدَّقنا بتوحيد الله ﷿، <q>﴿وبالرسول﴾</q> يعني: محمدًا ﷺ أنّه مِن الله ﷿، نزلت في بِشْر المنافق، <q>﴿وأطعنا﴾</q> قولَهُما، <q>﴿ثم يتولى فريق منهم﴾</q> يعني: ثم يعرض عن طاعتهما طائفةٌ منهم <q>﴿من بعد ذلك﴾</q> يعني: مِن بعد الإيمان بالله ﷿ ورسولِه ﷺ، <q>﴿وما أولئك بالمؤمنين﴾</q> يعني ﷿: [بِشرًا] المنافق{3}. (ز) ٥٣٧٨٧- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قول الله: <q>﴿وأطعنا﴾</q>، قال: أقرُّوا لله أن يُطيعوه في أمره ونهيه{1}. (ز) ٥٣٧٨٨- قال يحيى بن سلّام: <q>﴿ويقولون آمنا بالله وبالرسول وأطعنا ثم يتولى فريق منهم من بعد ذلك﴾</q> مِن بعد ما قالوا: <q>﴿آمنا بالله وبالرسول وأطعنا﴾</q>، <q>﴿وما أولئك بالمؤمنين (٤٧) وإذا دعوا إلى الله ورسوله ليحكم بينهم إذا فريق منهم معرضون (٤٨)﴾</q> عن الله، وعن رسوله، وكتابه، يعني: المنافقين؛ يظهرون الإيمان، ويُسِرُّون الشرك{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢١.أخرجه ابن أبي حاتم ٨/٢٦٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠٤.أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير يحيى بن سلّام ١/٤٥٦.
24,48," <q>﴿وَإِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ إِذَا فَرِیقࣱ مِّنۡهُم مُّعۡرِضُونَ ۝٤٨﴾</q> - نزول الآية ٥٣٧٨٩- عن الحسن البصري -من طريق المبارك بن فضالة- قال: إنّ الرجل كان يكون بينه وبين الرجل خصومةٌ أو مُنازعةٌ على عهدِ رسول الله ﷺ، فإذا دُعِي إلى النبي ﷺ وهو مُحِقٌّ أذْعَنَ، وعلِم أنّ النبي ﷺ سيقضي له بالحق، وإذا أراد أن يظلم فدُعِي إلى النبي ﷺ أعرض، وقال: انطلِق إلى فلان. فأنزل الله: <q>﴿واذا دعوا إلى الله ورسوله ليحكم بينهم﴾</q> إلى قوله: <q>﴿هم الظالمون﴾</q>. فقال رسول الله ﷺ: «مَن كان بينه وبين أخيه شيءٌ، فدعاه إلى حَكَم مِن حُكّام المسلمين، فلم يُجِب؛ فهو ظالِمٌ لا حقَّ له»{1}. (١١/٩٤) <q>﴿وَإِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ إِذَا فَرِیقࣱ مِّنۡهُم مُّعۡرِضُونَ ۝٤٨﴾</q> - تفسير الآية ٥٣٧٩٠- عن عبد الله بن عباس -من طريق العوفي- قال: <q>﴿وإذا دعوا إلى الله ورسوله ليحكم بينهم﴾</q>، قالوا: بل نُحاكِمكم إلى كعب بن الأشرف{2}. (ز) ٥٣٧٩١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿معرضون﴾</q>، قال: عن كتاب الله{3}. (ز) ٥٣٧٩٢- قال مقاتل بن سليمان: ثم أخبر عنه، فقال تعالى: <q>﴿وإذا دعوا إلى الله ورسوله ليحكم بينهم إذا فريق منهم﴾</q> يعني: مِن المنافقين <q>﴿معرضون﴾</q> عن النبيِّ ﷺ إلى كعب بن الأشرف؛ وذلك أنّ رجلًا مِن اليهود كان بينه وبين بِشر خصومة، وأنّ اليهوديَّ دعا بِشرًا إلى النبيِّ ﷺ، ودعاه بشر إلى كعب، فقال بشر: إنّ محمدًا يحيف علينا{4}. (ز) <q>﴿وَإِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ إِذَا فَرِیقࣱ مِّنۡهُم مُّعۡرِضُونَ ۝٤٨﴾</q> - آثار متعلقة بالآية ٥٣٧٩٣- عن الحسن البصري، عن سمرة، قال: قال رسول الله ﷺ: «مَن دُعِي إلى سُلطان، فلم يُجِب؛ فهو ظالِمٌ لا حَقَّ له»{5}. (١١/٩٥) ٥٣٧٩٤- تفسير عمرو، عن الحسن البصري، قال: كانوا يدعون إلى وثَنٍ كان أهلُ الجاهلية يتحاكمون إليه{6}. (ز) ",footnotes:1:أخرجه سريج بن يونس في كتاب القضاء ص٣٧ (١٦)، ويحيى بن سلّام ١/٤٥٦-٤٥٧، وابن أبي حاتم ٨/٢٦٢٢، ٢٦٢٣ (١٤٧٤٠، ١٤٧٤٢، ١٤٧٤٤). قال ابن كثير في تفسيره ٦/٧٥: «وهذا حديث غريب، وهو مرسَل». وقال الألباني في الضعيفة ١٢/٣٩٤ (٥٦٧٤): «ضعيف».أخرجه ابن أبي حاتم ٨/٢٦٢٢.أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير مقاتل بن سليمان ٣/٢٠٤.أخرجه الطبراني في الكبير ٧/٢٢٥ (٦٩٣٩)، والجصاص في أحكام القرآن ٣/٤٢٥. قال ابن أبي حاتم في علل الحديث ٤/٢٥٩ (١٤٠٧): «قال أبي: هذا حديث منكر». وقال الهيثمي في المجمع ٤/١٩٨ (٧٠٢٢): «رواه الطبراني، في الكبير، وفيه روح بن عطاء؛ وثّقه ابن عدي، وضعّفه الأئمة». وقال الألباني في الضعيفة ١٢/٣٩٤ (٥٦٧٤): «ضعيف».أخرجه يحيى بن سلّام ١/٤٥٧.
24,49," <q>﴿وَإِن یَكُن لَّهُمُ ٱلۡحَقُّ یَأۡتُوۤا۟ إِلَیۡهِ مُذۡعِنِینَ ۝٤٩﴾</q> - تفسير ٥٣٧٩٥- عن مجاهد بن جبر -من طريق ابن جريج- قوله: <q>﴿يأتوا إليه مذعنين﴾</q>، قال: سِراعًا{1}. (ز) ٥٣٧٩٦- عن الحسن البصري -من طريق المبارك بن فضالة- <q>﴿وإن يكن لهم الحق يأتوا إليه مذعنين﴾</q>، يقول: مُطيعين{2}. (ز) ٥٣٧٩٧- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿وإن يكن لهم الحق﴾</q> يعني: [بِشرًا] المنافق؛ <q>﴿يأتوا إليه مذعنين﴾</q> يأتوا إليه طائعين مُسارعين إلى النبي ﷺ{3}. (ز) ٥٣٧٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق أصْبَغ بن الفرج- في قول الله: <q>﴿وإن يكن لهم الحق يأتوا إليه مذعنين﴾</q>، قال: يُسْرِعون إليه{4}. (ز) ",footnotes:1:أخرجه يحيى بن سلّام ١/٤٥٦ من طريق عاصم بن حكيم وابن مجاهد، وابن جرير ١٧/٣٤٢.أخرجه ابن أبي حاتم ٨/٢٦٢٣.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٢.
24,50," <q>﴿أَفِی قُلُوبِهِم مَّرَضٌ أَمِ ٱرۡتَابُوۤا۟﴾</q> - تفسير ٥٣٧٩٩- قول الحسن البصري: في قوله: <q>﴿أفي قلوبهم مرض﴾</q> وهو الشِّرك{1}. (ز) ٥٣٨٠٠- قال قتادة بن دعامة: نِفاق{1}. (ز) ٥٣٨٠١- قال مقاتل بن سليمان: <q>﴿أفي قلوبهم مرض﴾</q> يعني: الكفر، <q>﴿أم ارتابوا﴾</q> أم شَكُّوا في القرآن{3}. (ز) ٥٣٨٠٢- قال يحيى بن سلّام: <q>﴿أم ارتابوا﴾</q> فشَكُّوا في الله وفي رسوله، على الاستفهام، أي: قد فعلوا{4}. (ز) <q>﴿أَمۡ یَخَافُونَ أَن یَحِیفَ ٱللَّهُ عَلَیۡهِمۡ وَرَسُولُهُۥۚ بَلۡ أُو۟لَـٰۤىِٕكَ هُمُ ٱلظَّـٰلِمُونَ ۝٥٠﴾</q> - تفسير ٥٣٨٠٣- قال مقاتل بن سليمان: <q>﴿أم يخافون أن يحيف الله عليهم﴾</q> يعني: أن يَجُور الله ﷿ عليهم <q>﴿ورسوله بل أولئك هم الظالمون﴾</q>{3}. (ز) ٥٣٨٠٤- قال يحيى بن سلّام: <q>﴿أم يخافون أن يحيف الله عليهم ورسوله﴾</q> والحيف: الجور. أي: قد خافوا ذلك، <q>﴿بل أولئك هم الظالمون﴾</q> ظلم النِّفاق والشِّرك{4}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ١/٤٥٧.علَّقه يحيى بن سلّام ١/٤٥٧.تفسير مقاتل بن سليمان ٣/٢٠٥.تفسير يحيى بن سلّام ١/٤٥٧.تفسير مقاتل بن سليمان ٣/٢٠٥.تفسير يحيى بن سلّام ١/٤٥٧.
24,51," <q>﴿إِنَّمَا كَانَ قَوۡلَ ٱلۡمُؤۡمِنِینَ إِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ أَن یَقُولُوا۟ سَمِعۡنَا وَأَطَعۡنَاۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٥١﴾</q> - تفسير ٥٣٨٠٥- عن قتادة بن دعامة -من طريق سعيد- قال الله ﷿: <q>﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله ليحكم بينهم أن يقولوا سمعنا وأطعنا وأولئك هم المفلحون﴾</q>، وقد ذُكِر لنا: أنّ عبادة بن الصامت كان عقبيًا بدريًّا أحد نقباء الأنصار. وذُكِر لنا: أنّه بايع رسولَ الله ﷺ على أن لا يخاف في الله لومةَ لائم، وأنّه لَمّا حضره الموتُ دعا ابنَ اخته جنادة بن أبي أمية، فقال: ألا أنبئك ماذا عليك، وماذا لك؟ قال: بلى. قال: فإنّ عليك السمع والطاعة في عُسرك ويُسرك، ومَنشَطِك ومَكْرَهِك، وأَثَرَةٍ عليك، وعليك أن تُقيم لسانك بالعدل، وأن لا تُنازِع الأمرَ أهله إلا أن يأمروك بمعصية الله بواحًا، فما أُمِرت به مِن شيء يُخالف كتاب الله فاتَّبع كتاب الله. وذُكِر لنا: أنّ أبا الدرداء قال: لا إسلام إلا بطاعة الله، ولا خير إلا في جماعة، والنصيحة لله ولرسوله وللخليفة وللمؤمنين عامة. قال: وقد ذُكِر لنا: أنّ عمر بن الخطاب كان يقول: عروة الإسلام: شهادة أن لا إله إلا الله، وإقام الصلاة، وإيتاء الزكاة، والطاعة لِمَن ولّاه الله أمرَ المسلمين{1}. (ز) ٥٣٨٠٦- قال مقاتل بن سليمان: ثم نعت الصادقين في إيمانهم، فقال سبحانه: <q>﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله﴾</q> يعني: إلى كتابه ورسوله، يعني: أمر رسوله ﷺ <q>﴿ليحكم بينهم أن يقولوا سمعنا﴾</q> قول النبي ﷺ، <q>﴿وأطعنا﴾</q> أمرَه، <q>﴿وأولئك هم المفلحون﴾</q>{2}. (ز) ٥٣٨٠٧- عن مقاتل بن حيّان -من طريق بُكَير بن معروف- قول الله: <q>﴿سمعنا﴾</q> قال: سمعنا للقرآن الذي جاء مِن عند الله، <q>﴿وأطعنا﴾</q> أقرُّوا لله أن يُطيعوه في أمره ونهيه{3}. (ز) ٥٣٨٠٨- قال يحيى بن سلّام: <q>﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله ليحكم بينهم أن يقولوا سمعنا وأطعنا﴾</q>، فهذا قولُ المؤمنين، وذلك القولُ الأول قولُ المنافقين{4}. (ز) <q>﴿إِنَّمَا كَانَ قَوۡلَ ٱلۡمُؤۡمِنِینَ إِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ أَن یَقُولُوا۟ سَمِعۡنَا وَأَطَعۡنَاۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٥١﴾</q> - آثار متعلقة بالآية ٥٣٨٠٩- عن أبي الشعثاء، قال: قعدت إلى ابن مسعود وحذيفة، فقال حذيفة: ذهب النفاقُ، وإنما هو الكفر، فقال عبد الله: أنت أعلم بما تقول. فتلا هذه الآية: <q>﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله﴾</q> حتى بلغ <q>﴿فأولئك هم الفاسقون﴾</q>. قال: فضحك عبد الله، وقال: إنّ الرجل رُبَّما ضحِك من الشيء الذي يعجبه، ومن الشيء الذي لا يعجبه. قال: لا أدري{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢٣.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٤.تفسير يحيى بن سلّام ١/٤٥٧.أخرجه إسحاق البستي في تفسيره ص٤٧٩.
24,52," <q>﴿وَمَن یُطِعِ ٱللَّهَ وَرَسُولَهُۥ وَیَخۡشَ ٱللَّهَ وَیَتَّقۡهِ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡفَاۤىِٕزُونَ ۝٥٢﴾</q> - تفسير ٥٣٨١٠- عن قتادة بن دعامة -من طريق سفيان، عن رجل- <q>﴿ومن يطع الله ورسوله﴾</q> قال: مَن يُطِع الله فيما أمر به، <q>﴿ورسوله﴾</q> قال: فيما أُمِر به، <q>﴿ويخشى الله﴾</q> قال: فيما مضى مِن ذنوبه، <q>﴿ويتقه﴾</q> قال: يخشاه فيما يستقبل{1}. (ز) ٥٣٨١١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿فأولئك هم الفائزون﴾</q> إلى نعيم مقيم{1}. (ز) ٥٣٨١٢- قال مقاتل بن سليمان: <q>﴿ومن يطع الله ورسوله﴾</q> في أمْر الحُكْم، <q>﴿ويخش الله﴾</q> في ذنوبه التي عمِلها. ثم قال تعالى: <q>﴿ويتقه﴾</q> ومَن يتَّق اللهَ تعالى فيما بعدُ فلم يَعْصِه؛ <q>﴿فأولئك هم الفائزون﴾</q> يعني: الناجون من النار{3}. (ز) ٥٣٨١٣- عن إبراهيم بن بشار، قال: سمعت إبراهيم بن أدهم يقول: قال الله ﷿: <q>﴿ومن يطع الله ورسوله ويخشى الله ويتقه فأولئك هم الفائزون﴾</q>، فأعْلَمَكَ أنّ بتقواه تَسْتَوْجِبُ جميلَ الثواب، وينجو المتقون مِن سكرات يوم الحساب، ويؤولون إلى خير باب. ثم قال: صدق الله: <q>﴿إن الله مع الذين اتقوا والذين هم محسنون﴾</q> [النحل:١٢٨]{4}. (ز) ٥٣٨١٤- قال يحيى بن سلّام: قوله: <q>﴿ومن يطع الله ورسوله ويخش الله﴾</q> فيما مضى مِن ذنوبه، <q>﴿ويتقه﴾</q> فيما بقي؛ <q>﴿فأولئك هم الفائزون﴾</q> الناجون من النار إلى الجنة{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢٤.أخرجه ابن أبي حاتم ٨/٢٦٢٤.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه أبو نعيم في حلية الأولياء ٨/٢٤.تفسير يحيى بن سلّام ١/٤٥٧.
24,53," <q>﴿وَأَقۡسَمُوا۟ بِٱللَّهِ جَهۡدَ أَیۡمَـٰنِهِمۡ لَىِٕنۡ أَمَرۡتَهُمۡ لَیَخۡرُجُنَّۖ قُل لَّا تُقۡسِمُوا۟ۖ طَاعَةࣱ مَّعۡرُوفَةٌۚ إِنَّ ٱللَّهَ خَبِیرُۢ بِمَا تَعۡمَلُونَ ۝٥٣﴾</q> - نزول الآية ٥٣٨١٥- عن عبد الله بن عباس، قال: أتى قومٌ النبيَّ ﷺ، فقالوا: يا رسول الله، لو أمرتنا أن نَخْرُج مِن أموالنا لخرجنا. فأنزل الله: <q>﴿وأقسموا بالله جهد أيمانهم﴾</q> الآية{1}. (١١/٩٥) ٥٣٨١٦- قال مقاتل بن سليمان: فلما بيَّن الله ﷿ كراهية المنافقين لحُكْم النبيِّ ﷺ أتَوْه، فقالوا: واللهِ، لو أمرتنا أن نخرج من ديارنا وأموالنا ونسائنا لخرجنا، أفنحن لا نرضى بحكمك؟! فأنزل الله -تبارك وتعالى- فيما حلفوا للنبي ﷺ: <q>﴿وأقسموا بالله جهد أيمانهم لئن أمرتهم ليخرجن قل لا تقسموا طاعة معروفة إن الله خبير بما تعملون﴾</q>{2}. (ز) <q>﴿وَأَقۡسَمُوا۟ بِٱللَّهِ جَهۡدَ أَیۡمَـٰنِهِمۡ لَىِٕنۡ أَمَرۡتَهُمۡ لَیَخۡرُجُنَّۖ﴾</q> - تفسير ٥٣٨١٧- عن زائدة، قال: قرأ سليمان الأعمش، وزعم أنّ يحيى بن وثّاب قرأ: <q>﴿وأَقْسَمُوا بِاللَّهِ جَهْدَ أيْمانِهِمْ﴾</q>، هو الحلف{3}. (ز) ٥٣٨١٨- قال مقاتل بن سليمان: <q>﴿وأقسموا بالله﴾</q> يعني: حلفوا بالله، يعني: المنافقين <q>﴿جهد أيمانهم﴾</q> فإنّه مَن حَلَف بالله ﷿ فقد اجْتَهَدَ في اليمين، <q>﴿لئن أمرتهم﴾</q> يعني: النبيَّ ﷺ <q>﴿ليخرجن﴾</q> مِن الديار والأموال كلها{2}. (ز) ٥٣٨١٩- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- في قوله: <q>﴿وأقسموا بالله جهد أيمانهم لئن أمرتهم ليخرجن﴾</q>، قال: ذلك مِن شأن الجهاد{5}. (١١/٩٥) ٥٣٨٢٠- قال يحيى بن سلّام: قوله: <q>﴿وأقسموا بالله جهد أيمانهم﴾</q> يعني: المنافقين، <q>﴿لئن أمرتهم ليخرجن﴾</q> إلى الجهاد. وأقسموا ولم يستثنوا، وفيهم الضعيفُ، والمريضُ، ومَن يوضع عنه الخروج{6}. (ز) <q>﴿قُل لَّا تُقۡسِمُوا۟ۖ طَاعَةࣱ مَّعۡرُوفَةٌۚ إِنَّ ٱللَّهَ خَبِیرُۢ بِمَا تَعۡمَلُونَ ۝٥٣﴾</q> - تفسير ٥٣٨٢١- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿طاعة معروفة﴾</q>، يقول: قد عُرِفَت طاعتُكم، أي: أنّكم تكذبون به{7}٤٦٩٠. (١١/٩٥) ٤٦٩٠ لم يذكر ابنُ جرير (١٧/٣٤٤) في معنى: <q>﴿قُلْ لا تُقْسِمُوا طاعَةٌ مَعْرُوفَةٌ﴾</q> سوى قول مجاهد. وذكر ابنُ عطية (٦/٤٠٣-٤٠٤) في معنى الآية عدة احتمالات: «أحدها: النهي عن القسم الكاذب، إذ عرف أنّ طاعتهم دَغْلَةٌ رديَّة». ووجَّهه بقوله: «فكأنّه يقول: لا تُغالِطوا؛ فقد عُرِف ما أنتم عليه». «والثاني: أن يكون المعنى: لا تتكلفوا القسم، طاعة عرف متوسطة على قدر الاستطاعة أمْثل وأَجْدى عليكم». ووجَّهه بقوله: «وفي هذا الوجْه إبقاءٌ عليهم». «والثالث: أن يكون المعنى: لا تقنعوا بالقسم، طاعة تُعْرَف منكم وتظهر عليكم هو المطلوب منكم». «والرابع: أن يكون المعنى: لا تقنعوا لأنفسكم بإرضائنا بالقسم، طاعة الله معروفة، وشرعه وجهاد عدُوِّه مهيع لائح». ٥٣٨٢٢- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لهم: <q>﴿لا تقسموا﴾</q> لا تحلفوا، ولكن هذه منكم <q>﴿طاعة معروفة﴾</q> يعني: طاعة حسنة للنبي ﷺ، <q>﴿إن الله خبير بما تعملون﴾</q> مِن الإيمان والشرك{2}. (ز) ٥٣٨٢٣- قال مقاتل بن سليمان، في قوله: <q>﴿طاعة معروفة﴾</q>: لتكن منكم طاعة معروفة{9}. (ز) ٥٣٨٢٤- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- في قوله: <q>﴿قل لا تقسموا﴾</q> قال: يأمرهم ألّا يحلفوا على شيء، <q>﴿طاعة معروفة﴾</q> قال: أمرهم أن يكون منهم طاعة معروفة للنبي ﷺ، مِن غير أن يُقْسِموا{5}. (١١/٩٥) ٥٣٨٢٥- قال يحيى بن سلّام: قوله: <q>﴿قل لا تقسموا﴾</q> أي: لا تحلفوا، ثم استأنف الكلام، فقال: <q>﴿طاعة معروفة﴾</q> خير، وهذا إضمار، أي: خيرٌ مِمّا تُضْمِرون من النفاق، <q>﴿إن الله خبير بما تعملون﴾</q>{6}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٤. وهي قراءة العشرة.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٥.تفسير يحيى بن سلّام ١/٤٥٧-٤٥٨.أخرجه ابن جرير ١٧/٣٤٤. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠٥.تفسير البغوي ٦/٥٧.أخرجه ابن أبي حاتم ٨/٢٦٢٥.تفسير يحيى بن سلّام ١/٤٥٧-٤٥٨.
