quran[10]{c,v,t}:
  24,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُقَلِّبُ ٱللَّهُ ٱلَّیۡلَ وَٱلنَّهَارَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿يقلب الله الليل والنهار﴾</span>، قال: يأتي بالليل ويذهب بالنهار، ويأتي بالنهار ويذهب بالليل{1}. (١١/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يقلب الله الليل والنهار﴾</span>، يعني بالتقلب: اختلافهما؛ أنه يأتي بالليل ويذهب بالنهار، ثم يأتي بالنهار ويذهب بالليل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يقلب الله الليل والنهار﴾</span> هو أخْذ كلِّ واحد منهما مِن صاحبه، كقوله: <span class="qpc-hafs">﴿يولج الليل في النهار ويولج النهار في الليل﴾</span> [الحديد:٦]{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّأُو۟لِی ٱلۡأَبۡصَـٰرِ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٦٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السدي</span>: لَمَعرِفة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦٩<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span> -من طريق أبي جعفر الرازي- قوله: <span class="qpc-hafs">﴿إن في ذلك لعبرة لأولي الأبصار﴾</span>، يقول: لقد كان في هؤلاء عبرةٌ ومُتَفَكَّر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لعبرة لأولي الأبصار﴾</span>، يعني: لأهل البصائر في أمر الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن في ذلك لعبرة﴾</span> لآية <span class="qpc-hafs">﴿لأولي﴾</span> لذوي <span class="qpc-hafs">﴿الأبصار﴾</span> وهم المؤمنون، أبْصَرُوا الهُدى{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّأُو۟لِی ٱلۡأَبۡصَـٰرِ ۝٤٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٧٢<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>قال الله ﷿: يُؤذِيني ابنُ آدم؛ يَسُبُّ الدهرَ، وأنا الدهرُ، بيدي الأمر، أُقلِّب الليل والنهار</b>»{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦١٩.تفسير مقاتل بن سليمان ٣/٢٠٤.تفسير يحيى بن سلّام ١/٤٥٥.علَّقه يحيى بن سلّام ١/٤٥٦.أخرجه ابن أبي حاتم ٨/٢٦١٩.تفسير مقاتل بن سليمان ٣/٢٠٤.تفسير يحيى بن سلّام ١/٤٥٥-٤٥٦.أخرجه البخاري ٦/١٣٣ (٤٨٢٦)، ٨/٤١ (٦١٨١)، ٩/١٤٣ (٧٤٩١)، ومسلم ٤/١٧٦٢ (٢٢٤٦)، وابن أبي حاتم ١٠/٣٢٩١ (١٨٥٣٧)، ١٠/٣٢٩٢ (١٨٥٣٩)، والثعلبي ٧/١١٢، ٨/٣٦٤.
  24,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ خَلَقَ كُلَّ دَاۤبَّةࣲ مِّن مَّاۤءࣲۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مغفل</span> أنّه قرأ: ‹واللَّهُ خالِقُ كُلِّ دَآبَّةٍ مِّن مّاءٍ›{1}<span class=comment-ref>٤٦٨٩</span>. (١١/٩٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٩</span> ذكر <u>ابنُ جرير</u> (١٧/٣٣٩) هذه القراءة، وقراءة من قرأ ذلك <span class="qpc-hafs">﴿خلق﴾</span>، ثم علّق قائلًا: «وهما قراءتان مشهورتان متقاربتا المعنى، وذلك أنّ الإضافة في قراءة من قرأ ذلك ‹خالِقُ› تدل على أنّ معنى ذلك المضي، فبأيتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ خَلَقَ كُلَّ دَاۤبَّةࣲ مِّن مَّاۤءࣲۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٧٤<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿والله خلق كل دابة من ماء﴾</span>، يعني: النطفة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصْبَغ- <span class="qpc-hafs">﴿والله خلق كل دابة من ماء﴾</span>، قال: الماء: النطفة مِن الفحول{3}. (١١/٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ خَلَقَ كُلَّ دَاۤبَّةࣲ مِّن مَّاۤءࣲۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٧٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>كل شيء خُلِق من الماء</b>». قال <span class="name-3">يحيى بن سلّام</span>: أُراه يعني: الحيوان. نحو قول <span class="name-2">السُّدِّيّ</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمِنۡهُم مَّن یَمۡشِی عَلَىٰ بَطۡنِهِۦ وَمِنۡهُم مَّن یَمۡشِی عَلَىٰ رِجۡلَیۡنِ وَمِنۡهُم مَّن یَمۡشِی عَلَىٰۤ أَرۡبَعࣲۚ یَخۡلُقُ ٱللَّهُ مَا یَشَاۤءُۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣱ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كل شيء يمشي على أربع، إلا الإنسان{5}. (١١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والله خلق كل دابة من ماء فمنهم من يمشي على بطنه﴾</span> يعني: الهوام، <span class="qpc-hafs">﴿ومنهم من يمشي على رجلين﴾</span> الإنس، والجن، والطير، <span class="qpc-hafs">﴿ومنهم من يمشي على أربع﴾</span> قوائم، يعني: الدواب، والأنعام، والوحش، والسِّباع، <span class="qpc-hafs">﴿يخلق الله ما يشاء إن الله على كل شيء﴾</span> مِن الخلق <span class="qpc-hafs">﴿قدير﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فمنهم من يمشي على بطنه﴾</span> الحية، <span class="qpc-hafs">﴿ومنهم من يمشي على رجلين ومنهم من يمشي على أربع﴾</span> أي: ومنهم مَن يمشي على أكثر مِن ذلك. وإنما قال: فمنهم مَن يمشي على كذا، ومنهم مَن يمشي على كذا، ومنهم يمشي على كذا، خَلْقُ اللهِ كثيرٌ. قال: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span> [النحل:٨]، قوله: <span class="qpc-hafs">﴿يخلق الله ما يشاء إن الله على كل شيء قدير﴾</span>{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿واللَّهُ خَلَقَ كُلَّ دابَّةٍ مِن ماءٍ﴾</span> دون ألف، مع فتح اللام. انظر: النشر ٢/٣٣٢، والإتحاف ص٤١٢.علَّقه يحيى بن سلّام ١/٤٥٦.أخرجه ابن أبي حاتم ٨/٢٦٢٠.أخرجه أحمد ١٣/٣١٤ (٧٩٣٢)، ١٤/٤٩ (٨٢٩٥، ٨٢٩٦)، ١٦/٢٥٢-٢٥٣ (١٠٣٩٩)، وابن حبان ٦/٢٩٩ (٢٥٥٩)، والحاكم ٤/١٧٦ (٧٢٧٨)، ويحيى بن سلّام ١/٣٠٩، ٤٥٦</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن مفلح في الآداب الشرعية ١/٤٢١: «إسناد جيد». وقال الهيثمي في المجمع ٥/١٦ (٧٨٦٥): «رواه أحمد، ورجاله رجال الصحيح، خلا أبي ميمونة، وهو ثقة». وقال ابن حجر في الفتح ٥/٢٩: «إسناده صحيح». وقال البوصيري في إتحاف الخيرة ٥/٤٨١-٤٨٢ (٥٠٥٢): «رواه أبو بكر بن أبي شيبة، ورواته ثقات». وقال الألباني في الضعيفة ٣/٤٩٢: «وهذا إسناد ضعيف».عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠٤.تفسير يحيى بن سلّام ١/٤٥٦.
  24,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّقَدۡ أَنزَلۡنَاۤ ءَایَـٰتࣲ مُّبَیِّنَـٰتࣲۚ وَٱللَّهُ یَهۡدِی مَن یَشَاۤءُ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- في قوله: <span class="qpc-hafs">﴿لقد أنزلنا آيات﴾</span> هو هذا القرآن؛ فيه حلاله وحرامه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لقد أنزلنا آيات مبينات﴾</span> لِما فيه مِن أمره ونهيه، <span class="qpc-hafs">﴿والله يهدي من يشاء إلى صراط مستقيم﴾</span> يعني: إلى دين مستقيم، يعني: الإسلام، وغيره من الأديان ليس بمستقيم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿لقد أنزلنا آيات مبينات﴾</span>: يعني: ما فرض عليهم في هذه السورة مِن أوَّلها إلى آخرها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿لقد أنزلنا آيات مبينات﴾</span>: القرآن، ما يُبَيِّن الله فيه، <span class="qpc-hafs">﴿والله يهدي من يشاء إلى صراط مستقيم﴾</span> إلى دين مستقيم. والصراط: الطريق المستقيم إلى الجنة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير مقاتل بن سليمان ٣/٢٠٤.أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير يحيى بن سلّام ١/٤٥٦.
  24,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ ءَامَنَّا بِٱللَّهِ وَبِٱلرَّسُولِ وَأَطَعۡنَا ثُمَّ یَتَوَلَّىٰ فَرِیقࣱ مِّنۡهُم مِّنۢ بَعۡدِ ذَ ٰ⁠لِكَۚ وَمَاۤ أُو۟لَـٰۤىِٕكَ بِٱلۡمُؤۡمِنِینَ ۝٤٧﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع بن أنس- قوله: <span class="qpc-hafs">﴿ويقولون آمنا بالله﴾</span>، قال: هؤلاء المنافقين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ويقولون آمنا بالله وبالرسول وأطعنا ثم يتولى فريق منهم من بعد ذلك وما أولئك بالمؤمنين﴾</span>، قال: أُناس مِن المنافقين أظهروا الإيمان والطاعة، وهم في ذلك يَصُدُّون عن سبيل الله وطاعته وجهادٍ مع رسوله{2}. (١١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويقولون آمنا بالله﴾</span> يعني: صدَّقنا بتوحيد الله ﷿، <span class="qpc-hafs">﴿وبالرسول﴾</span> يعني: محمدًا ﷺ أنّه مِن الله ﷿، نزلت في بِشْر المنافق، <span class="qpc-hafs">﴿وأطعنا﴾</span> قولَهُما، <span class="qpc-hafs">﴿ثم يتولى فريق منهم﴾</span> يعني: ثم يعرض عن طاعتهما طائفةٌ منهم <span class="qpc-hafs">﴿من بعد ذلك﴾</span> يعني: مِن بعد الإيمان بالله ﷿ ورسولِه ﷺ، <span class="qpc-hafs">﴿وما أولئك بالمؤمنين﴾</span> يعني ﷿: [بِشرًا] المنافق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قول الله: <span class="qpc-hafs">﴿وأطعنا﴾</span>، قال: أقرُّوا لله أن يُطيعوه في أمره ونهيه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويقولون آمنا بالله وبالرسول وأطعنا ثم يتولى فريق منهم من بعد ذلك﴾</span> مِن بعد ما قالوا: <span class="qpc-hafs">﴿آمنا بالله وبالرسول وأطعنا﴾</span>، <span class="qpc-hafs">﴿وما أولئك بالمؤمنين (٤٧) وإذا دعوا إلى الله ورسوله ليحكم بينهم إذا فريق منهم معرضون (٤٨)﴾</span> عن الله، وعن رسوله، وكتابه، يعني: المنافقين؛ يظهرون الإيمان، ويُسِرُّون الشرك{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢١.أخرجه ابن أبي حاتم ٨/٢٦٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠٤.أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير يحيى بن سلّام ١/٤٥٦.
  24,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ إِذَا فَرِیقࣱ مِّنۡهُم مُّعۡرِضُونَ ۝٤٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فضالة- قال: إنّ الرجل كان يكون بينه وبين الرجل خصومةٌ أو مُنازعةٌ على عهدِ رسول الله ﷺ، فإذا دُعِي إلى النبي ﷺ وهو مُحِقٌّ أذْعَنَ، وعلِم أنّ النبي ﷺ سيقضي له بالحق، وإذا أراد أن يظلم فدُعِي إلى النبي ﷺ أعرض، وقال: انطلِق إلى فلان. فأنزل الله: <span class="qpc-hafs">﴿واذا دعوا إلى الله ورسوله ليحكم بينهم﴾</span> إلى قوله: <span class="qpc-hafs">﴿هم الظالمون﴾</span>. فقال رسول الله ﷺ: «<b>مَن كان بينه وبين أخيه شيءٌ، فدعاه إلى حَكَم مِن حُكّام المسلمين، فلم يُجِب؛ فهو ظالِمٌ لا حقَّ له</b>»{1}. (١١/٩٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ إِذَا فَرِیقࣱ مِّنۡهُم مُّعۡرِضُونَ ۝٤٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: <span class="qpc-hafs">﴿وإذا دعوا إلى الله ورسوله ليحكم بينهم﴾</span>، قالوا: بل نُحاكِمكم إلى كعب بن الأشرف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿معرضون﴾</span>، قال: عن كتاب الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنه، فقال تعالى: <span class="qpc-hafs">﴿وإذا دعوا إلى الله ورسوله ليحكم بينهم إذا فريق منهم﴾</span> يعني: مِن المنافقين <span class="qpc-hafs">﴿معرضون﴾</span> عن النبيِّ ﷺ إلى كعب بن الأشرف؛ وذلك أنّ رجلًا مِن اليهود كان بينه وبين بِشر خصومة، وأنّ اليهوديَّ دعا بِشرًا إلى النبيِّ ﷺ، ودعاه بشر إلى كعب، فقال بشر: إنّ محمدًا يحيف علينا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ إِذَا فَرِیقࣱ مِّنۡهُم مُّعۡرِضُونَ ۝٤٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٩٣<span class="dash">-</span></span> عن الحسن البصري، عن سمرة، قال: قال رسول الله ﷺ: «<b>مَن دُعِي إلى سُلطان، فلم يُجِب؛ فهو ظالِمٌ لا حَقَّ له</b>»{5}. (١١/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٩٤<span class="dash">-</span></span> تفسير عمرو، عن <span class="name-2">الحسن البصري</span>، قال: كانوا يدعون إلى وثَنٍ كان أهلُ الجاهلية يتحاكمون إليه{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه سريج بن يونس في كتاب القضاء ص٣٧ (١٦)، ويحيى بن سلّام ١/٤٥٦-٤٥٧، وابن أبي حاتم ٨/٢٦٢٢، ٢٦٢٣ (١٤٧٤٠، ١٤٧٤٢، ١٤٧٤٤).</p><p>قال ابن كثير في تفسيره ٦/٧٥: «وهذا حديث غريب، وهو مرسَل». وقال الألباني في الضعيفة ١٢/٣٩٤ (٥٦٧٤): «ضعيف».أخرجه ابن أبي حاتم ٨/٢٦٢٢.أخرجه ابن أبي حاتم ٨/٢٦٢١.تفسير مقاتل بن سليمان ٣/٢٠٤.أخرجه الطبراني في الكبير ٧/٢٢٥ (٦٩٣٩)، والجصاص في أحكام القرآن ٣/٤٢٥.</p><p>قال ابن أبي حاتم في علل الحديث ٤/٢٥٩ (١٤٠٧): «قال أبي: هذا حديث منكر». وقال الهيثمي في المجمع ٤/١٩٨ (٧٠٢٢): «رواه الطبراني، في الكبير، وفيه روح بن عطاء؛ وثّقه ابن عدي، وضعّفه الأئمة». وقال الألباني في الضعيفة ١٢/٣٩٤ (٥٦٧٤): «ضعيف».أخرجه يحيى بن سلّام ١/٤٥٧.
  24,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یَكُن لَّهُمُ ٱلۡحَقُّ یَأۡتُوۤا۟ إِلَیۡهِ مُذۡعِنِینَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿يأتوا إليه مذعنين﴾</span>، قال: سِراعًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فضالة- <span class="qpc-hafs">﴿وإن يكن لهم الحق يأتوا إليه مذعنين﴾</span>، يقول: مُطيعين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿وإن يكن لهم الحق﴾</span> يعني: [بِشرًا] المنافق؛ <span class="qpc-hafs">﴿يأتوا إليه مذعنين﴾</span> يأتوا إليه طائعين مُسارعين إلى النبي ﷺ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصْبَغ بن الفرج- في قول الله: <span class="qpc-hafs">﴿وإن يكن لهم الحق يأتوا إليه مذعنين﴾</span>، قال: يُسْرِعون إليه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٤٥٦ من طريق عاصم بن حكيم وابن مجاهد، وابن جرير ١٧/٣٤٢.أخرجه ابن أبي حاتم ٨/٢٦٢٣.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٢.
  24,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفِی قُلُوبِهِم مَّرَضٌ أَمِ ٱرۡتَابُوۤا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٩٩<span class="dash">-</span></span> قول <span class="name-2">الحسن البصري</span>: في قوله: <span class="qpc-hafs">﴿أفي قلوبهم مرض﴾</span> وهو الشِّرك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: نِفاق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفي قلوبهم مرض﴾</span> يعني: الكفر، <span class="qpc-hafs">﴿أم ارتابوا﴾</span> أم شَكُّوا في القرآن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أم ارتابوا﴾</span> فشَكُّوا في الله وفي رسوله، على الاستفهام، أي: قد فعلوا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَمۡ یَخَافُونَ أَن یَحِیفَ ٱللَّهُ عَلَیۡهِمۡ وَرَسُولُهُۥۚ بَلۡ أُو۟لَـٰۤىِٕكَ هُمُ ٱلظَّـٰلِمُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٨٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أم يخافون أن يحيف الله عليهم﴾</span> يعني: أن يَجُور الله ﷿ عليهم <span class="qpc-hafs">﴿ورسوله بل أولئك هم الظالمون﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أم يخافون أن يحيف الله عليهم ورسوله﴾</span> والحيف: الجور. أي: قد خافوا ذلك، <span class="qpc-hafs">﴿بل أولئك هم الظالمون﴾</span> ظلم النِّفاق والشِّرك{4}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٤٥٧.علَّقه يحيى بن سلّام ١/٤٥٧.تفسير مقاتل بن سليمان ٣/٢٠٥.تفسير يحيى بن سلّام ١/٤٥٧.تفسير مقاتل بن سليمان ٣/٢٠٥.تفسير يحيى بن سلّام ١/٤٥٧.
  24,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّمَا كَانَ قَوۡلَ ٱلۡمُؤۡمِنِینَ إِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ أَن یَقُولُوا۟ سَمِعۡنَا وَأَطَعۡنَاۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال الله ﷿: <span class="qpc-hafs">﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله ليحكم بينهم أن يقولوا سمعنا وأطعنا وأولئك هم المفلحون﴾</span>، وقد ذُكِر لنا: أنّ عبادة بن الصامت كان عقبيًا بدريًّا أحد نقباء الأنصار. وذُكِر لنا: أنّه بايع رسولَ الله ﷺ على أن لا يخاف في الله لومةَ لائم، وأنّه لَمّا حضره الموتُ دعا ابنَ اخته جنادة بن أبي أمية، فقال: ألا أنبئك ماذا عليك، وماذا لك؟ قال: بلى. قال: فإنّ عليك السمع والطاعة في عُسرك ويُسرك، ومَنشَطِك ومَكْرَهِك، وأَثَرَةٍ عليك، وعليك أن تُقيم لسانك بالعدل، وأن لا تُنازِع الأمرَ أهله إلا أن يأمروك بمعصية الله بواحًا، فما أُمِرت به مِن شيء يُخالف كتاب الله فاتَّبع كتاب الله. وذُكِر لنا: أنّ أبا الدرداء قال: لا إسلام إلا بطاعة الله، ولا خير إلا في جماعة، والنصيحة لله ولرسوله وللخليفة وللمؤمنين عامة. قال: وقد ذُكِر لنا: أنّ عمر بن الخطاب كان يقول: عروة الإسلام: شهادة أن لا إله إلا الله، وإقام الصلاة، وإيتاء الزكاة، والطاعة لِمَن ولّاه الله أمرَ المسلمين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعت الصادقين في إيمانهم، فقال سبحانه: <span class="qpc-hafs">﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله﴾</span> يعني: إلى كتابه ورسوله، يعني: أمر رسوله ﷺ <span class="qpc-hafs">﴿ليحكم بينهم أن يقولوا سمعنا﴾</span> قول النبي ﷺ، <span class="qpc-hafs">﴿وأطعنا﴾</span> أمرَه، <span class="qpc-hafs">﴿وأولئك هم المفلحون﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَير بن معروف- قول الله: <span class="qpc-hafs">﴿سمعنا﴾</span> قال: سمعنا للقرآن الذي جاء مِن عند الله، <span class="qpc-hafs">﴿وأطعنا﴾</span> أقرُّوا لله أن يُطيعوه في أمره ونهيه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله ليحكم بينهم أن يقولوا سمعنا وأطعنا﴾</span>، فهذا قولُ المؤمنين، وذلك القولُ الأول قولُ المنافقين{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّمَا كَانَ قَوۡلَ ٱلۡمُؤۡمِنِینَ إِذَا دُعُوۤا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِیَحۡكُمَ بَیۡنَهُمۡ أَن یَقُولُوا۟ سَمِعۡنَا وَأَطَعۡنَاۚ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٥١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٨٠٩<span class="dash">-</span></span> عن أبي الشعثاء، قال: قعدت إلى <span class="name-1">ابن مسعود</span> و<span class="name-1">حذيفة</span>، فقال حذيفة: ذهب النفاقُ، وإنما هو الكفر، فقال عبد الله: أنت أعلم بما تقول. فتلا هذه الآية: <span class="qpc-hafs">﴿إنما كان قول المؤمنين إذا دعوا إلى الله ورسوله﴾</span> حتى بلغ <span class="qpc-hafs">﴿فأولئك هم الفاسقون﴾</span>. قال: فضحك عبد الله، وقال: إنّ الرجل رُبَّما ضحِك من الشيء الذي يعجبه، ومن الشيء الذي لا يعجبه. قال: لا أدري{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢٣.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٤.تفسير يحيى بن سلّام ١/٤٥٧.أخرجه إسحاق البستي في تفسيره ص٤٧٩.
  24,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن یُطِعِ ٱللَّهَ وَرَسُولَهُۥ وَیَخۡشَ ٱللَّهَ وَیَتَّقۡهِ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡفَاۤىِٕزُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٨١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سفيان، عن رجل- <span class="qpc-hafs">﴿ومن يطع الله ورسوله﴾</span> قال: مَن يُطِع الله فيما أمر به، <span class="qpc-hafs">﴿ورسوله﴾</span> قال: فيما أُمِر به، <span class="qpc-hafs">﴿ويخشى الله﴾</span> قال: فيما مضى مِن ذنوبه، <span class="qpc-hafs">﴿ويتقه﴾</span> قال: يخشاه فيما يستقبل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فأولئك هم الفائزون﴾</span> إلى نعيم مقيم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يطع الله ورسوله﴾</span> في أمْر الحُكْم، <span class="qpc-hafs">﴿ويخش الله﴾</span> في ذنوبه التي عمِلها. ثم قال تعالى: <span class="qpc-hafs">﴿ويتقه﴾</span> ومَن يتَّق اللهَ تعالى فيما بعدُ فلم يَعْصِه؛ <span class="qpc-hafs">﴿فأولئك هم الفائزون﴾</span> يعني: الناجون من النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١٣<span class="dash">-</span></span> عن إبراهيم بن بشار، قال: سمعت <span class="name-3">إبراهيم بن أدهم</span> يقول: قال الله ﷿: <span class="qpc-hafs">﴿ومن يطع الله ورسوله ويخشى الله ويتقه فأولئك هم الفائزون﴾</span>، فأعْلَمَكَ أنّ بتقواه تَسْتَوْجِبُ جميلَ الثواب، وينجو المتقون مِن سكرات يوم الحساب، ويؤولون إلى خير باب. ثم قال: صدق الله: <span class="qpc-hafs">﴿إن الله مع الذين اتقوا والذين هم محسنون﴾</span> [النحل:١٢٨]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومن يطع الله ورسوله ويخش الله﴾</span> فيما مضى مِن ذنوبه، <span class="qpc-hafs">﴿ويتقه﴾</span> فيما بقي؛ <span class="qpc-hafs">﴿فأولئك هم الفائزون﴾</span> الناجون من النار إلى الجنة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٢٤.أخرجه ابن أبي حاتم ٨/٢٦٢٤.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه أبو نعيم في حلية الأولياء ٨/٢٤.تفسير يحيى بن سلّام ١/٤٥٧.
  24,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَقۡسَمُوا۟ بِٱللَّهِ جَهۡدَ أَیۡمَـٰنِهِمۡ لَىِٕنۡ أَمَرۡتَهُمۡ لَیَخۡرُجُنَّۖ قُل لَّا تُقۡسِمُوا۟ۖ طَاعَةࣱ مَّعۡرُوفَةٌۚ إِنَّ ٱللَّهَ خَبِیرُۢ بِمَا تَعۡمَلُونَ ۝٥٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٨١٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أتى قومٌ النبيَّ ﷺ، فقالوا: يا رسول الله، لو أمرتنا أن نَخْرُج مِن أموالنا لخرجنا. فأنزل الله: <span class="qpc-hafs">﴿وأقسموا بالله جهد أيمانهم﴾</span> الآية{1}. (١١/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١٦<span class="dash">-</span></span> قال مقاتل بن سليمان: فلما بيَّن الله ﷿ كراهية المنافقين لحُكْم النبيِّ ﷺ أتَوْه، فقالوا: واللهِ، لو أمرتنا أن نخرج من ديارنا وأموالنا ونسائنا لخرجنا، أفنحن لا نرضى بحكمك؟! فأنزل الله -تبارك وتعالى- فيما حلفوا للنبي ﷺ: <span class="qpc-hafs">﴿وأقسموا بالله جهد أيمانهم لئن أمرتهم ليخرجن قل لا تقسموا طاعة معروفة إن الله خبير بما تعملون﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقۡسَمُوا۟ بِٱللَّهِ جَهۡدَ أَیۡمَـٰنِهِمۡ لَىِٕنۡ أَمَرۡتَهُمۡ لَیَخۡرُجُنَّۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٨١٧<span class="dash">-</span></span> عن زائدة، قال: قرأ <span class="name-2">سليمان الأعمش</span>، وزعم أنّ <span class="name-2">يحيى بن وثّاب</span> قرأ: <span class="qpc-hafs">﴿وأَقْسَمُوا بِاللَّهِ جَهْدَ أيْمانِهِمْ﴾</span>، هو الحلف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأقسموا بالله﴾</span> يعني: حلفوا بالله، يعني: المنافقين <span class="qpc-hafs">﴿جهد أيمانهم﴾</span> فإنّه مَن حَلَف بالله ﷿ فقد اجْتَهَدَ في اليمين، <span class="qpc-hafs">﴿لئن أمرتهم﴾</span> يعني: النبيَّ ﷺ <span class="qpc-hafs">﴿ليخرجن﴾</span> مِن الديار والأموال كلها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨١٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- في قوله: <span class="qpc-hafs">﴿وأقسموا بالله جهد أيمانهم لئن أمرتهم ليخرجن﴾</span>، قال: ذلك مِن شأن الجهاد{5}. (١١/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأقسموا بالله جهد أيمانهم﴾</span> يعني: المنافقين، <span class="qpc-hafs">﴿لئن أمرتهم ليخرجن﴾</span> إلى الجهاد. وأقسموا ولم يستثنوا، وفيهم الضعيفُ، والمريضُ، ومَن يوضع عنه الخروج{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُل لَّا تُقۡسِمُوا۟ۖ طَاعَةࣱ مَّعۡرُوفَةٌۚ إِنَّ ٱللَّهَ خَبِیرُۢ بِمَا تَعۡمَلُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٨٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿طاعة معروفة﴾</span>، يقول: قد عُرِفَت طاعتُكم، أي: أنّكم تكذبون به{7}<span class=comment-ref>٤٦٩٠</span>. (١١/٩٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٩٠</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٤٤) في معنى: <span class="qpc-hafs">﴿قُلْ لا تُقْسِمُوا طاعَةٌ مَعْرُوفَةٌ﴾</span> سوى قول مجاهد.</p><p>وذكر <u>ابنُ عطية</u> (٦/٤٠٣-٤٠٤) في معنى الآية عدة <b>احتمالات</b>: «<b>أحدها</b>: النهي عن القسم الكاذب، إذ عرف أنّ طاعتهم دَغْلَةٌ رديَّة». و<span class="comment-type-1">وجَّهه</span> بقوله: «فكأنّه يقول: لا تُغالِطوا؛ فقد عُرِف ما أنتم عليه». «<b>والثاني</b>: أن يكون المعنى: لا تتكلفوا القسم، طاعة عرف متوسطة على قدر الاستطاعة أمْثل وأَجْدى عليكم». و<span class="comment-type-1">وجَّهه</span> بقوله: «وفي هذا الوجْه إبقاءٌ عليهم». «<b>والثالث</b>: أن يكون المعنى: لا تقنعوا بالقسم، طاعة تُعْرَف منكم وتظهر عليكم هو المطلوب منكم». «و<b>الرابع</b>: أن يكون المعنى: لا تقنعوا لأنفسكم بإرضائنا بالقسم، طاعة الله معروفة، وشرعه وجهاد عدُوِّه مهيع لائح».</div></p><p><div></p><p><p><span class="item-no">٥٣٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لهم: <span class="qpc-hafs">﴿لا تقسموا﴾</span> لا تحلفوا، ولكن هذه منكم <span class="qpc-hafs">﴿طاعة معروفة﴾</span> يعني: طاعة حسنة للنبي ﷺ، <span class="qpc-hafs">﴿إن الله خبير بما تعملون﴾</span> مِن الإيمان والشرك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله: <span class="qpc-hafs">﴿طاعة معروفة﴾</span>: لتكن منكم طاعة معروفة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٢٤<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قوله: <span class="qpc-hafs">﴿قل لا تقسموا﴾</span> قال: يأمرهم ألّا يحلفوا على شيء، <span class="qpc-hafs">﴿طاعة معروفة﴾</span> قال: أمرهم أن يكون منهم طاعة معروفة للنبي ﷺ، مِن غير أن يُقْسِموا{5}. (١١/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٨٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿قل لا تقسموا﴾</span> أي: لا تحلفوا، ثم استأنف الكلام، فقال: <span class="qpc-hafs">﴿طاعة معروفة﴾</span> خير، وهذا إضمار، أي: خيرٌ مِمّا تُضْمِرون من النفاق، <span class="qpc-hafs">﴿إن الله خبير بما تعملون﴾</span>{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٤.</p><p>وهي قراءة العشرة.تفسير مقاتل بن سليمان ٣/٢٠٥.أخرجه ابن أبي حاتم ٨/٢٦٢٥.تفسير يحيى بن سلّام ١/٤٥٧-٤٥٨.أخرجه ابن جرير ١٧/٣٤٤. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠٥.تفسير البغوي ٦/٥٧.أخرجه ابن أبي حاتم ٨/٢٦٢٥.تفسير يحيى بن سلّام ١/٤٥٧-٤٥٨.