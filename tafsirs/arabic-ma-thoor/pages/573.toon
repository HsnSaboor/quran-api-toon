tafsir[15]{c,v,t}:
72,14," <q>﴿وَأَنَّا مِنَّا ٱلۡمُسۡلِمُونَ وَمِنَّا ٱلۡقَـٰسِطُونَۖ فَمَنۡ أَسۡلَمَ فَأُو۟لَـٰۤىِٕكَ تَحَرَّوۡا۟ رَشَدࣰا ۝١٤ وَأَمَّا ٱلۡقَـٰسِطُونَ فَكَانُوا۟ لِجَهَنَّمَ حَطَبࣰا ۝١٥﴾</q> - تفسير ٧٩٢٠٥- قال عبد الله بن عباس: <q>﴿القاسِطُونَ﴾</q> هم الذين جعلوا لله نِدًّا{1}. (ز) ٧٩٢٠٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿وأَنّا مِنّا المُسْلِمُونَ ومِنّا القاسِطُونَ﴾</q>، قال: العادِلون عن الحق{2}. (ز) ٧٩٢٠٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ومنا القاسِطُونَ﴾</q>، قال: هم الظالمون{3}. (١٥/٢٣) ٧٩٢٠٨- عن عكرمة مولى ابن عباس -من طريق جابر- <q>﴿ومنا القاسِطُونَ﴾</q>، قال: هم الظالمون{4}. (ز) ٧٩٢٠٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومنا القاسِطُونَ﴾</q>، قال: هم الجائرون{5}. (١٥/٢٣) ٧٩٢١٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأما القاسِطُونَ﴾</q>، قال: هم الجبّارون{6}. (ز) ٧٩٢١١- قال مقاتل بن سليمان: <q>﴿وأَنّا مِنّا المُسْلِمُونَ﴾</q> يعني: المُخلصين، هذا قول التسعة، <q>﴿ومنا القاسِطُونَ﴾</q> يعني: العادلين بالله، وهم المَرَدة، <q>﴿فَمَن أسْلَمَ﴾</q> يقول: فمَن أخلص لله ﷿ من كفار الجنّ <q>﴿فَأُولَئِكَ تَحَرَّوْا رَشَدًا﴾</q> يعني: أخلصوا بالرشد، <q>﴿وأما القاسِطُونَ﴾</q> يعني: العادلين بالله <q>﴿فَكانُوا لِجَهَنَّمَ حَطَبًا﴾</q> يعني: وقودًا. فهذا كله قول مؤمني الجنّ التسعة{7}. (ز) ٧٩٢١٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: المُقسط: العادل، والقاسط: الجائر. وذكر بيت شعر: قَسَطنا على الأملاك في عهد تُبَّعٍ ومن قبلِ ما أدرى النفوسَ عقابها{8}. (ز) ",footnotes:1:تفسير البغوي ٨/٢٤١.أخرجه ابن جرير ٢٣/٣٣٣.تفسير مجاهد ص٦٧٧، وأخرجه ابن جرير ٢٣/٣٣٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٧-.أخرجه ابن جرير ٢٣/٣٣٣، كذلك من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٢٢.تفسير مقاتل بن سليمان ٤/٤٦٤.أخرجه ابن جرير ٢٣/٣٣٦.
  72,15,""
72,16," <q>﴿ٱسۡتَقَـٰمُوا۟ عَلَى ٱلطَّرِیقَةِ لَأَسۡقَیۡنَـٰهُم مَّاۤءً غَدَقࣰا ۝١٦ لِّنَفۡتِنَهُمۡ فِیهِۚ﴾</q> - تفسير ٧٩٢١٣- عن عمر بن الخطاب -من طريق السُّدِّيّ- <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q>، قال: حيثُما كان الماءُ كان المالُ، وحيثما كان المالُ كانت الفتنةُ{1}. (١٥/٢٤) ٧٩٢١٤- عن عبد الله بن عباس، في قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> قال: أقاموا ما أُمروا به؛ <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> قال: مَعينًا{2}. (١٥/٢٤) ٧٩٢١٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> يعني بالاستقامة: الطاعة. فأمّا الغَدَق: فالماء الطاهر الكثير؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> يقول: لنَبْتليهم به{3}. (ز) ٧٩٢١٦- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿ماءً غَدَقًا﴾</q>. قال: كثيرًا جاريًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر: تُدني كراديسَ مُلتفًّا حدائقها كالنّبْت جادتْ بها أنهارها غدقا؟{4}. (١٥/٢٤) ٧٩٢١٧- عن سعيد بن جُبَير -من طريق المنهال- في قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> قال: الدين؛ <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> قال: مالًا كثيرًا؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> قال: لنَبْتليهم فيه{5}. (ز) ٧٩٢١٨- عن مجاهد بن جبر -من طريق عبيد الله بن أبي زياد-: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> طريقة الإسلام؛ <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> قال: نافعًا كثيرًا، لأَعطيناهم مالًا كثيرًا؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> حتى يَرجعوا لِما كَتبه عليهم من الشقاء{6}. (ز) ٧٩٢١٩- عن مجاهد بن جبر -من طريق عَلقمة بن مَرْثَد- <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> قال: الإسلام؛ <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> قال: الكثير؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> قال: لنَبْتليهم به{7}. (ز) ٧٩٢٢٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> قال: هذا مَثَلٌ ضربه الله، كقوله: <q>﴿ولَوْ أنَّهُمْ أقامُوا التَّوْراةَ والإنْجِيلَ وما أُنْزِلَ إلَيْهِمْ مِن رَبِّهِمْ لَأَكَلُوا مِن فَوْقِهِمْ ومِن تَحْتِ أرْجُلِهِمْ﴾</q> [المائدة:٦٦]، وقوله تعالى: <q>﴿ولَوْ أنَّ أهْلَ القُرى آمَنُوا واتَّقَوْا لَفَتَحْنا عَلَيْهِمْ بَرَكاتٍ مِنَ السَّماءِ والأَرْضِ﴾</q> [الأعراف:٩٦]. والماء الغَدَق يعني: الماء الكثير؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> لنَبْتليهم فيه{8}. (ز) ٧٩٢٢١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q>، قال: لأَعطيناهم مالًا كثيرًا{9}. (١٥/٢٥) ٧٩٢٢٢- عن أبي مِجْلَز لاحق بن حميد -من طريق عمران بن حُدَيْر- في قوله تعالى: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q>، قال: على طريقة الضّلالة{8}. (ز) ٧٩٢٢٣- عن أبي مالك غَزْوان الغفاري، في قوله: <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q>، قال: كثيرًا، والماء: المال{9}. (١٥/٢٥) ٧٩٢٢٤- عن الحسن البصري، في قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ﴾</q> الآية، يقول: لو استقاموا على طاعة الله وما أُمِروا به لأَكثر الله لهم مِن الأموال حتى يُفتنوا بها{9}. (١٥/٢٤) ٧٩٢٢٥- قال الحسن البصري: <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q>، أي: لأَوسعنا لهم من الرِّزق{13}. (ز) ٧٩٢٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> قال: لو آمنوا كلّهم؛ <q>﴿لَأَسْقَيْناهُمْ﴾</q> لأَوسعنا لهم من الدنيا{14}. (١٥/٢٣) ٧٩٢٢٧- عن زيد بن أسلم = (ز) ٧٩٢٢٨- والربيع بن أنس = (ز) ٧٩٢٢٩- ومحمد بن السّائِب الكلبي: أنّ معناه: وأن لو استقاموا على الضّلالة لأَعطيناهم سَعَةً من الرزق لِنَستدْرِجهم بها{15}. (ز) ٧٩٢٣٠- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿ماءً غَدَقًا﴾</q>، قال: عَيشًا رَغدًا{16}. (١٥/٢٥) ٧٩٢٣١- قال مقاتل بن سليمان: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> يعني: طريقة الهُدى؛ <q>﴿لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q> يعني: كثيرًا من السماء، وهو المطر، بعد ما كان رُفِع عنهم المطر سبع سنين فيَكثر خيرهم؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> يقول: لكي نَبْتليهم فيه بالخصب والخير، كقوله في سورة الأعراف [٩٦]: <q>﴿ولَوْ أنَّ أهْلَ القُرى آمَنُوا﴾</q> يقول: صَدَّقوا <q>﴿واتقوا لَفَتَحْنا عَلَيْهِمْ بَرَكاتٍ مِنَ السَّماءِ﴾</q> يعني: المطر <q>﴿والأَرْضِ﴾</q> يعني به: النبات{17}٦٨٣٦. (ز) ٦٨٣٦ اختُلف في معنى: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ﴾</q> في هذه الآية على قولين: الأول: طريقة الكفر. الثاني: طريقة الهدى. ووجَّه ابنُ عطية (٨/٤٣٣) القول الأول بقوله: «أي: لو كفر مَن أسلم مِن الناس لأَسقيناهم ماءً إملاءً لهم واستدراجًا». ووجَّه القول الثاني بقوله: «والمعنى: على طريقة الإسلام والحق، وهذا المعنى نحو قوله تعالى: <q>﴿ولَوْ أنَّ أهْلَ الكِتابِ آمَنُوا واتَّقَوْا لَكَفَّرْنا عَنْهُمْ سَيِّئاتِهِمْ﴾</q> [المائدة:٦٥]، وقوله تعالى: <q>﴿ولَوْ أنَّهُمْ أقامُوا التَّوْراةَ والإنْجِيلَ وما أُنْزِلَ إلَيْهِمْ مِن رَبِّهِمْ لَأَكَلُوا مِن فَوْقِهِمْ ومِن تَحْتِ أرْجُلِهِمْ﴾</q> [المائدة:٦٦]». ثم رجَّح الثاني -مستندًا إلى اللغة، والعقل- بقوله: «وهذا القول أبْيَن؛ لأنّ استعارة الاستقامة للكفر قلقة». ٧٩٢٣٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَلَّوِ اسْتَقامُوا عَلى الطَّرِيقَةِ لَأَسْقَيْناهُمْ ماءً غَدَقًا﴾</q>، قال: الغَدَق: الكثير؛ ماءً كثيرًا؛ <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q> لنَختَبِرهم فيه{18}. (ز) <q>﴿لِّنَفۡتِنَهُمۡ فِیهِۚ﴾</q> - تفسير ٧٩٢٣٣- قال سعيد بن المسيّب= (ز) ٧٩٢٣٤- وعُبيد بن عُمير= (ز) ٧٩٢٣٥- والحسن البصري= (ز) ٧٩٢٣٦- وعطية بن سعد العَوفيّ= (ز) ٧٩٢٣٧- وعطاء بن أبي رباح= (ز) ٧٩٢٣٨- ومقاتل: <q>﴿لنَفْتِنَهُمْ فِيهِ﴾</q> لنَختَبِرهم كيف شُكرهم فيما خُوّلوا{19}. (ز) ٧٩٢٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q>، قال: لنَبْتليهم حتى يَرجعوا إلى ما كُتب عليهم{20}. (١٥/٢٥) ٧٩٢٤٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q>: لنَبْتليهم فيه{8}. (ز) ٧٩٢٤١- قال مقاتل بن سليمان: <q>﴿لِنَفْتِنَهُمْ فِيهِ﴾</q>، يقول: لكي نَبْتليهم فيه بالخصب والخير{17}. (ز) <q>﴿وَمَن یُعۡرِضۡ عَن ذِكۡرِ رَبِّهِۦ یَسۡلُكۡهُ عَذَابࣰا صَعَدࣰا ۝١٧﴾</q> - قراءات ٧٩٢٤٢- عن عاصم أنه قرأ: <q>﴿يَسْلُكْهُ﴾</q> بالياء{23}. (١٥/٢٦) <q>﴿وَمَن یُعۡرِضۡ عَن ذِكۡرِ رَبِّهِۦ یَسۡلُكۡهُ عَذَابࣰا صَعَدࣰا ۝١٧﴾</q> - تفسير الآية ٧٩٢٤٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ‹ومَن يُعْرِضْ عَن ذِكْرِ رَبِّهِ نَسْلُكْهُ عَذابًا صَعَدًا›، قال: شُقّة من العذاب يَصعد فيها{24}. (١٥/٢٥) ٧٩٢٤٤- عن عبد الله بن عباس -من طريق عكرمة- في قوله: ‹نَسْلُكْهُ عَذابًا صَعَدًا›، قال: جبلًا في جهنم{25}. (١٥/٢٦) ٧٩٢٤٥- عن عبد الله بن عباس، في قوله: <q>﴿عَذابًا صَعَدًا﴾</q>، قال: لا راحة فيه{26}. (١٥/٢٦) ٧٩٢٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عَذابًا صَعَدًا﴾</q>، قال: مَشقّة من العذاب{27}. (١٥/٢٥) ٧٩٢٤٧- عن عكرمة مولى ابن عباس -من طريق جابر- <q>﴿عَذابًا صَعَدًا﴾</q>، قال: مَشقّة من العذاب{28}. (١٥/٢٦) ٧٩٢٤٨- عن الحسن البصري: <q>﴿صَعَدًا﴾</q> لا يزداد إلا شِدّة{29}. (ز) ٧٩٢٤٩- عن الحسن البصري، في قوله: <q>﴿عَذابًا صَعَدًا﴾</q>، قال: عذابًا لا راحة فيه{9}. (١٥/٢٦) ٧٩٢٥٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿عَذابًا صَعَدًا﴾</q>، قال: صَعودًا مِن عذاب الله، لا راحة فيه{31}. (١٥/٢٦) ٧٩٢٥١- عن إسماعيل السُّدِّيّ: <q>﴿صَعَدًا﴾</q> مَشقّة{32}. (ز) ٧٩٢٥٢- قال محمد بن السّائِب الكلبي: يُكلّف الوليد بن المُغيرة أن يَصعد في النار جبلًا مِن صخرة مَلساء، حتى يَبلغ أعلاها، يجذب مِن أمامه بالسلاسل، ويُضرب بمَقامع من حديد حتى يَبلغ أعلاها، ولا يَبلغها في أربعين سنة، فإذا بَلغ أعلاها انحدر إلى أسفلها، ثم يُكلّف أيضًا صُعُودَها، فذلك دأْبه أبدًا، وهو قوله: <q>﴿سَأُرْهِقُهُ صَعُودًا﴾</q> [المدثر:١٧]{32}. (ز) ٧٩٢٥٣- قال مقاتل بن سليمان: <q>﴿ومَن يُعْرِضْ عَنْ ذِكْرِ رَبِّهِ﴾</q> القرآن؛ <q>﴿يَسْلُكْهُ عَذابًا صَعَدًا﴾</q> يعني: شدّة العذاب الذي لا راحة له فيه{17}. (ز) ٧٩٢٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يَسْلُكْهُ عَذابًا صَعَدًا﴾</q>، قال: الصَّعَد: العذاب المُتعِب{35}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٣٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٣/٣٣٥.أخرجه الطستي -كما في الإتقان ٢/٧٧-.أخرجه عبد الرزاق ٢/٣٢٢، وابن جرير ٢٣/٣٣٧.أخرجه ابن جرير ٢٣/٣٣٥-٣٣٦، وبنحوه من طريق أبي سنان، عن غير واحد.أخرجه ابن جرير ٢٣/٣٣٦.أخرجه ابن جرير ٢٣/٣٣٨.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٣٣٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٤٦-.أخرجه عبد الرزاق ٢/٣٢٢، وابن جرير ٢٣/٣٣٧. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٥٣-٥٤، وتفسير البغوي ٨/٢٤١.أخرجه ابن جرير ٢٣/٣٣٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٦٤.أخرجه ابن جرير ٢٣/٣٣٧.تفسير الثعلبي ١٠/٥٣.أخرجه ابن جرير ٢٣/٣٣٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٣٣٨.تفسير مقاتل بن سليمان ٤/٤٦٤.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف، وعاصم، ويعقوب، وقرأ بقية العشرة: ‹نَسْلُكْهُ› بالنون. انظر: النشر ٢/٣٩٢، والإتحاف ص٥٦٦.أخرجه ابن جرير ٢٣/٣٣٥، ٣٣٩.أخرجه ابن جرير ٢٣/٣٣٩، وهناد (٢٧٩)، والحاكم ٢/٥٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن جرير.أخرجه هناد (٢٨٠)، وابن جرير ٢٣/٣٣٩، كذلك من طريق جابر أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه هناد (٢٨٠).تفسير الثعلبي ١٠/٥٤، وتفسير البغوي ٨/٢٤١.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٢٢، وابن جرير ٢٣/٣٣٩، ٣٤٠-كذلك من طريق سعيد أيضًا. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٤٦-. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٥٤.تفسير الثعلبي ١٠/٥٤.تفسير مقاتل بن سليمان ٤/٤٦٤.أخرجه ابن جرير ٢٣/٣٤٠.
