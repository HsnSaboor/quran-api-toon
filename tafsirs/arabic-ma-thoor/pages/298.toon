quran[11]{c,v,t}:
  18,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَدَخَلَ جَنَّتَهُۥ وَهُوَ ظَالِمࣱ لِّنَفۡسِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ودخل جنته وهو ظالم لنفسه﴾</span>، يقول: كفور لنِعمة ربه{1}. (٩/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ودخل﴾</span> الكافرُ <span class="qpc-hafs">﴿جنته﴾</span> وهو بستانه، <span class="qpc-hafs">﴿وهو ظالم لنفسه﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿ودخل جنته وهو ظالم لنفسه﴾</span>، يعني: بشركه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ مَاۤ أَظُنُّ أَن تَبِیدَ هَـٰذِهِۦۤ أَبَدࣰا ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩١٩<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: ليس يعني: أنها لا تفنى فتذهب، ولكنه يعني: أنه يعيش فيه حتى يأكلها حياته. كقوله: <span class="qpc-hafs">﴿يحسب أن ماله أخلده﴾</span> [الهمزة:٣]، أي: يحسب أنه يخلد في ماله حتى يأكله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿قال ما أظن أن تبيد هذه أبدا﴾</span>، يقول: تهلك{5}. (٩/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال ما أظن﴾</span> يعني: ما أحسب <span class="qpc-hafs">﴿أن تبيد﴾</span> يعني: أن تهلك <span class="qpc-hafs">﴿هذه﴾</span> الجنة <span class="qpc-hafs">﴿أبدا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال ما أظن﴾</span> ما أُوقِن <span class="qpc-hafs">﴿أن تبيد هذه أبدا﴾</span> أي: تفنى هذه أبدًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٢٦٣. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٥٨٥.|3:تفسير يحيى بن سلام ١/١٨٦.|4:علقه يحيى بن سلام ١/١٨٦.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٢/٥٨٥.|7:تفسير يحيى بن سلام ١/١٨٦.
  18,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَظُنُّ ٱلسَّاعَةَ قَاۤىِٕمَةࣰ وَلَىِٕن رُّدِدتُّ إِلَىٰ رَبِّی لَأَجِدَنَّ خَیۡرࣰا مِّنۡهَا مُنقَلَبࣰا ۝٣٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تُقرأ على وجه آخر: ‹لَأَجِدَنَّ خَيْرًا مِّنْهُما مُنقَلَبًا›، يعني: الجنتين، وهي في موضع جنة، وفي موضع جنتان. قال: <span class="qpc-hafs">﴿ودَخَلَ جَنَّتَهُ﴾</span>، وقال: <span class="qpc-hafs">﴿جَعَلْنا لِأَحَدِهِما جَنَّتَيْنِ﴾</span>، فهي جنة بينهما نهر؛ فصارت جنتين، وهي جنة، وهي جنتان{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَظُنُّ ٱلسَّاعَةَ قَاۤىِٕمَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span>: مُكَذِّب بلقائه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span>: ولئن كانت قائمة ثم <span class="qpc-hafs">﴿رددت إلى ربي لأجدن خيرا منها منقلبا﴾</span>{3}. (٩/٥٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span>، يعني: القيامة كائنة كما تقول{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span>، قال: شكّ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٢٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span>: وما أُوقِن أنّ الساعة قائمة. يجحد بالبعث{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَىِٕن رُّدِدتُّ إِلَىٰ رَبِّی لَأَجِدَنَّ خَیۡرࣰا مِّنۡهَا مُنقَلَبࣰا ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: مُتَمَنٍّ على الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولئن رددت إلى ربي﴾</span> في الآخرة <span class="qpc-hafs">﴿لأجدن خيرا منها﴾</span> يعني: أفضل منها، من جنتي، <span class="qpc-hafs">﴿منقلبا﴾</span> يعني: مرجعًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: ثم قال: <span class="qpc-hafs">﴿ولئن﴾</span> كان ذلك، ثم <span class="qpc-hafs">﴿رددت إلى ربي لأجدن خيرا منها منقلبا﴾</span>، ما أعطاني هذه إلا ولي عنده خير من ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولئن رددت إلى ربي لأجدن خيرا منها﴾</span> من جنتي <span class="qpc-hafs">﴿منقلبا﴾</span> في الآخرة؛ إن كانت آخرة. كقوله: <span class="qpc-hafs">﴿ولئن رجعت إلى ربي إن لي عنده للحسنى﴾</span> [فصلت:٥٠]: الجنة؛ إن كانت جنة، أي: ولكن ليس جنة ولا مَرَدٌّ{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ١/١٨٦.</p><p>و‹خَيْرًا مِّنْهُما› بزيادة ألف بعد الهاء على التثنية قراءة متواترة، قرأ بها نافع، وابن كثير، وابن عامر، وأبو جعفر، وقرأ بقية العشرة <span class="qpc-hafs">﴿خَيْرًا مِّنْها﴾</span> بغير ميم على الإفراد. انظر: النشر ٢/٣١٠-٣١١، والإتحاف ص٣٦٦.|2:أخرجه ابن جرير ١٥/٢٦٣.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٥٨٥.|5:أخرجه ابن جرير ١٥/٢٦٣.|6:تفسير يحيى بن سلام ١/١٨٦.|7:أخرجه ابن جرير ١٥/٢٦٣.|8:تفسير مقاتل بن سليمان ٢/٥٨٥.|9:أخرجه ابن جرير ١٥/٢٦٣.|10:تفسير يحيى بن سلام ١/١٨٦.
  18,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَهُۥ صَاحِبُهُۥ وَهُوَ یُحَاوِرُهُۥۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فردَّ عليه، <span class="qpc-hafs">﴿قال له صاحبه﴾</span> المؤمن <span class="qpc-hafs">﴿وهو يحاوره﴾</span> يعني: يراجعه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال له صاحبه﴾</span> المؤمن{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَكَفَرۡتَ بِٱلَّذِی خَلَقَكَ مِن تُرَابࣲ ثُمَّ مِن نُّطۡفَةࣲ ثُمَّ سَوَّىٰكَ رَجُلࣰا ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أكفرت بالذي خلقك من تراب﴾</span> يعني: آدم ﵇؛ لأن أول خلقه التراب، ثم قال: <span class="qpc-hafs">﴿ثم من نطفة ثم سواك﴾</span> يعني: خلقك فجعلك <span class="qpc-hafs">﴿رجلا﴾</span>{1}<span class=comment-ref>٤٠١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠١٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٦٠٨) أن معنى: <span class="qpc-hafs">﴿ثُمَّ سَوّاكَ رَجُلًا﴾</span> «كما تقول: سوّاك شخصًا أو حيًّا أو نحو هذا من التأكيدات». ثم ذكر <b>احتمالًا</b> آخر، فقال: «وقد يحتمل أن قصد تخصيص الرجولة على وجه تعديد النعمة في أن لم يكن أنثى ولا خنثى».</div></p><p><div></p><p><p><span class="item-no">٤٤٩٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهو يحاوره أكفرت بالذي خلقك من تراب﴾</span>، يعني: أول خلق الإنسان، يعني: آدم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٨٦.|2:تفسير يحيى بن سلام ١/١٨٦.|3:تفسير مقاتل بن سليمان ٢/٥٨٦.|4:تفسير يحيى بن سلام ١/١٨٦.
  18,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّـٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّی وَلَاۤ أُشۡرِكُ بِرَبِّیۤ أَحَدࣰا ۝٣٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٣٧<span class="dash">-</span></span> عن هارون، قال: في قراءة <span class="name-1">أبي بن كعب</span>: (لَكِنْ أناْ هُوَ اللهُ رَبِّي){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٣٨<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: <span class="qpc-hafs">﴿لَكِنّاْ هُوَ اللهُ رَبِّي﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٣٩<span class="dash">-</span></span> عن عمر، عن <span class="name-2">الحسن</span> أنه كان يقرؤها: (لَكِنْ أناْ هُوَ اللهُ رَبِّي){3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّـٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّی وَلَاۤ أُشۡرِكُ بِرَبِّیۤ أَحَدࣰا ۝٣٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لكنا﴾</span> أقول: <span class="qpc-hafs">﴿هو الله ربي ولا أشرك بربي أحدا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّـٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّی وَلَاۤ أُشۡرِكُ بِرَبِّیۤ أَحَدࣰا ۝٣٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٤١<span class="dash">-</span></span> عن أسماء بنت عميس، قالت: علَّمني رسولُ الله ﷺ كلماتٍ أقولُهُنَّ عند الكرب: «<b>الله الله ربي، لا أشرك به شيئًا</b>»{5}. (٩/٥٤٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن الأنباري في الوقف والابتداء ١/٤٠٩ (١٥٢).</p><p>وهي قراءة شاذة، تروى أيضًا عن الحسن، وقراءة العشرة: <span class="qpc-hafs">﴿لَكِنّاْ هُوَ اللهُ رَبِّي﴾</span>. انظر: المحتسب ٢/٢٩.|2:أخرجه ابن أبي داود في المصاحف ١/٣٢٢.|3:أخرجه ابن الأنباري في الوقف والابتداء ١/٤٠٩ (١٥٢).|4:تفسير مقاتل بن سليمان ٢/٥٨٦.|5:أخرجه أحمد ٤٥/١٥-١٦ (٢٧٠٨٢)، وأبو داود ٢/٦٣٢ (١٥٢٥)، وابن ماجه ٥/٤٦ (٣٨٨٢)، وابن أبي حاتم ٧/٢٣٦٢ (١٢٨١٣).</p><p>قال أبو نعيم في الحلية ٥/٣٦٠: «غريب من حديث عمر». وقال الألباني في صحيح أبي داود ٥/٢٥٥ (١٣٦٤): «إسناده صحيح».
  18,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡلَاۤ إِذۡ دَخَلۡتَ جَنَّتَكَ قُلۡتَ مَا شَاۤءَ ٱللَّهُ لَا قُوَّةَ إِلَّا بِٱللَّهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في «لا حول ولا قوة إلا بالله»، قال: لا حول بنا على العمل بالطاعة إلا بالله، ولا قوة لنا على ترك المعصية إلا بالله{1}. (٩/٥٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٤٣<span class="dash">-</span></span> عن زهير بن محمد، أنّه سُئِل عن تفسير: لا حول ولا قوة إلا بالله. قال: لا تأخذ ما تحب إلا بالله، ولا تمتنع مما تكره إلا بعون الله{1}. (٩/٥٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال المؤمن للكافر: <span class="qpc-hafs">﴿ولولا﴾</span> يعني: هلّا <span class="qpc-hafs">﴿إذ دخلت جنتك﴾</span> يعني: بستانك؛ <span class="qpc-hafs">﴿قلت ما شاء الله لا قوة إلا بالله﴾</span> يعني: فهلّا قلتَ: بمشيئة الله أعطيتها بغير حول مني ولا قوَّة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٤٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولولا﴾</span>: فهلّا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡلَاۤ إِذۡ دَخَلۡتَ جَنَّتَكَ قُلۡتَ مَا شَاۤءَ ٱللَّهُ لَا قُوَّةَ إِلَّا بِٱللَّهِۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٤٦<span class="dash">-</span></span> عن ابن مسعود، عن النبي ﷺ، قال: «<b>أخبرني جبريل أن تفسير «لا حول ولا قوة إلا بالله»: أنّه لا حول عن معصية الله إلا بقوة الله، ولا قوة على طاعة الله إلا بعون الله</b>»{5}. (٩/٥٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٤٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال لي نبي الله ﷺ: «<b>ألا أدلك على كنز من كنوز الجنة تحت العرش</b>». قلت: نعم. قال: «<b>أن تقول:</b> <span class="qpc-hafs">﴿لا قوة إلا بالله﴾</span>». قال عمرو بن ميمون: قلت لأبي هريرة: لا حول ولا قوة إلا بالله؟ فقال: لا، إنها في سورة الكهف: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</span>{6}. (٩/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٤٨<span class="dash">-</span></span> عن عقبة بن عامر، قال: قال رسول الله ﷺ: «<b>مَن أنعم الله عليه نعمةً فأراد بقاءها، فليُكْثِر مِن قول: لا حول ولا قوة إلا بالله</b>». ثم قرأ رسول الله ﷺ: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</span>{7}. (٩/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٤٩<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>ما أنعم الله على عبد نعمة في أهل أو مال أو ولد فيقول: ما شاء الله لا قوة إلا بالله. إلا دفع الله عنه كلَّ آفة حتى تأتيه مَنِيَّتُه</b>». وقرأ: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</span>{8}. (٩/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٠<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، قال: مَن رأى شيئًا مِن ماله فأعجبه فقال: <span class="qpc-hafs">﴿ما شاء الله لا قوة إلا بالله﴾</span>. لم يُصِب ذلك المالَ آفةٌ أبدًا. وقرأ: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك﴾</span> الآية{1}. (٩/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥١<span class="dash">-</span></span> عن أنس بن مالك مرفوعًا{10}. (٩/٥٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٢<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span>: أنّه كان إذا رأى من ماله شيئًا يعجبه، أو دخل حائطًا مِن حيطانه؛ قال: ما شاء الله لا قوة إلا بالله. ويتأول قول الله: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</span>{11}. (٩/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٣<span class="dash">-</span></span> عن حفص بن ميسرة، قال: رأيت على باب <span class="name-2">وهب بن منبه</span> مكتوبًا: <span class="qpc-hafs">﴿ما شاء الله لا قوة إلا بالله﴾</span>. وذلك قول الله: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله﴾</span>{1}. (٩/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٤<span class="dash">-</span></span> عن زياد بن سعد، قال: كان [<span class="name-2">محمد</span>] <span class="name-2">ابن شهاب [الزهري]</span> إذا دخل أمواله قال: ما شاء الله لا قوة إلا بالله. ويتأول قوله: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك﴾</span> الآية{13}. (٩/٥٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٥<span class="dash">-</span></span> عن <span class="name-2">عمرو بن مرة</span> -من طريق أبي سنان- قال: أُدخِل رجل الجنة، فقال: لا حول ولا قوة إلا بالله. فرفع درجة، ثم قال: لا حول ولا قوة إلا بالله. فرفع درجة، فقال الملَك: ألا تستحي كم تسأل ربك؟! قال: وهل سألت ربي شيئًا؟ ثم تلا <span class="name-3">أبو سنان</span> هذه الآية: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٦<span class="dash">-</span></span> عن <span class="name-3">إبراهيم بن أدهم</span>، قال: ما سأل رجلٌ مسألة ألَحّ مِن أن يقول: <span class="qpc-hafs">﴿ما شاء الله﴾</span>{1}. (٩/٥٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٥٧<span class="dash">-</span></span> عن مطرف، قال: كان <span class="name-3">مالك بن أنس</span> إذا دخل بيته قال: <span class="qpc-hafs">﴿ما شاء الله﴾</span>. قلت لمالك: لم تقول هذا ؟ قال: ألا تسمع الله يقول: <span class="qpc-hafs">﴿ولولا إذ دخلت جنتك قلت ما شاء الله﴾</span>؟{1}. (٩/٥٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن تَرَنِ أَنَا۠ أَقَلَّ مِنكَ مَالࣰا وَوَلَدࣰا ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال المؤمن للكافر يرُدُّ عليه: <span class="qpc-hafs">﴿إن ترن أنا أقل منك مالا وولدا﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٥٨٦.|4:تفسير يحيى بن سلام ١/١٨٦.|5:أخرجه البزار ٥/٣٧٤ (٢٠٠٤)، وابن شاهين في الترغيب في فضائل الأعمال ص١٠٦ (٣٥١).</p><p>قال البزار: «وهذا الحديث لم نسمع موصولًا عن القاسم عن أبيه عن عبد الله إلا من هذا الوجه». وقال البيهقي في شعب الإيمان ٢/١٦٣-١٦٤ (٦٥٦): «تفرّد به صالح بن بيان السيرافي، وليس بالقوي، ورُوِي ذلك من وجه آخر ضعيف، عن زر عن عبد الله مرفوعًا». وقال الهيثمي في المجمع ١٠/٩٩ (١٦٩٠٧): «رواه البزار بإسنادين، أحدهما منقطع، وفيه عبد الله بن خراش، والغالب عليه الضعف، والآخر متصل حسن». وقال المناوي في التيسير ١/٣٩٥: «وفي إسناده لين». وقال الألباني في الضعيفة ٧/٣٦٦ (٣٣٥٥): «ضعيف».|6:أخرجه أحمد ١٤/١٤٩-١٥٠ (٨٤٢٦).</p><p>قال الهيثمي في المجمع ١٠/٩٩ (١٦٩١٠): «رواه أحمد، والبزار بنحوه... ورجالهما رجال الصحيح، غير أبي بلج الكبير، وهو ثقة».|7:أخرجه الطبراني في الكبير ١٧/٣١٠ (٨٥٩).</p><p>قال الهيثمي في المجمع ١٠/٩٩ (١٦٩٠٩): «رواه الطبراني، وفيه خالد بن نجيح، وهو كذاب». وقال الألباني في الضعيفة ١٠/٦٨ (٤٥٦٤): «موضوع».|8:أخرجه الطبراني في الأوسط ٤/٣٠١ (٤٢٦١)، ٦/١٢٦ (٥٩٩٥)، والبيهقي في شعب الإيمان ٦/٢١٢-٢١٣ (٤٠٦٠) بدون ذكر الآية، ٦/٢٩٢ (٤٢٠٧).</p><p>قال ابن كثير في تفسيره ٥/١٥٨-١٥٩: «قال الحافظ أبو الفتح الأزدي: عيسى بن عون عن عبد الملك بن زرارة عن أنس، لا يصح حديثه». وقال الهيثمي في المجمع ١٠/١٤٠ (١٧١٥١): «رواه الطبراني في الصغير، والأوسط، وفيه عبد الملك بن زرارة، وهو ضعيف». وقال المناوي في التيسير ٢/٣٤٤: «إسناده ضعيف». وقال الألباني في الضعيفة ٥/٢٥ (٢٠١٢): «ضعيف».|9:عزاه السيوطي إلى ابن أبي حاتم.|10:أخرجه البزار ١٣/٥٠٦ دون ذكر الآية، من طريق أبي بكر الهذلي، عن ثمامة، عن أنس به.</p><p>قال البزّار: «هذا الكلام لا نعلم رواه إلا أنس، ولا نعلم له طريقًا إلا هذا الطريق». وقال الهيثمي في المجمع ٥/١٠٩: «رواه لبزار من رواية أبي بكر الهذلي، وأبو بكر ضعيف جدًّا».|11:أخرجه البيهقي في شعب الإيمان (٢٢٣٠، ١١٢٢٦). وعزاه السيوطي إلى سعيد بن منصور، وابن أبي حاتم.|12:عزاه السيوطي إلى ابن أبي حاتم.|13:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|14:أخرجه أبو نعيم في حلية الأولياء ٥/٩٦.|15:عزاه السيوطي إلى ابن أبي حاتم.|16:عزاه السيوطي إلى ابن أبي حاتم.|17:تفسير مقاتل بن سليمان ٢/٥٨٦.
  18,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَعَسَىٰ رَبِّیۤ أَن یُؤۡتِیَنِ خَیۡرࣰا مِّن جَنَّتِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فعسى ربي أن يؤتين خيرا﴾</span> يعني: أفضل <span class="qpc-hafs">﴿من جنتك﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ثم قال: <span class="qpc-hafs">﴿فعسى ربي أن يؤتين﴾</span> في الآخرة <span class="qpc-hafs">﴿خيرا من جنتك﴾</span>{2}<span class=comment-ref>٤٠٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠٢٠</span> ذكر <u>ابنُ عطية</u> (٥/٦١٠) <b>احتمالًا آخر</b> في هذا التَّرَجِّي بـ«عَسى»: «أن يريد به: في الدنيا».</div></p><p><h3><span class="qpc-hafs">﴿وَیُرۡسِلَ عَلَیۡهَا حُسۡبَانࣰا مِّنَ ٱلسَّمَاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: الحسبان: العذاب{3}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿حسبانا من السماء﴾</span>. قال: نارًا. قال: وهل تعرف العرب ذلك ؟ قال: نعم. أما سمعت حسان بن ثابت وهو يقول:</p><p>بقيةُ معشرٍ صُبَّت عليهم شآبيبٌ من الحُسْبان شُهْبُ؟{4}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿حسبانا من السماء﴾</span>، قال: نارًا{5}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- قال: عذابًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿حسبانا من السماء﴾</span>، قال: عذابًا{7}<span class=comment-ref>٤٠٢١</span>. (٩/٥٤٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٠٢١</span> فسر ابنُ عباس، والضحاك من طريق جويبر، وقتادة، الحسبان المرسَل من السماء بأنه: العذاب، وحكى <u>ابنُ كثير</u> (٩/١٤٠) ذلك عنهم، ثم <span class="comment-type-3">استظهر</span> أن هذا العذاب هو: المطر العظيم. <span class="mustanad">بدلالة ظاهر الآية</span>، فقال بعد إيراد كلامهم: «والظاهر: أنه مطر عظيم مزعج، يقلع زرعها وأشجارها، ولهذا قال: <span class="qpc-hafs">﴿فَتُصْبِحَ صَعِيدًا زَلَقًا﴾</span>، أي: بلقعًا ترابًا أملس، لا يثبت فيه قدم».</div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٦<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السدي</span>: <span class="qpc-hafs">﴿ويرسل عليها حسبانا من السماء﴾</span>: نارًا من السماء، أي: عذابًا من السماء، وهي النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويرسل عليها﴾</span> يعني: على جنتك <span class="qpc-hafs">﴿حسبانا﴾</span> يعني: عذابًا <span class="qpc-hafs">﴿من السماء﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ويرسل عليها حسبانا من السماء﴾</span>، قال: عذابًا. قال: الحسبان: قضاء من الله يقضيه{3}<span class=comment-ref>٤٠٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠٢٢</span> لم يذكر <u>ابنُ جرير</u> (١٥/٢٦٦) في معنى: <span class="qpc-hafs">﴿حُسْبانًا مِنَ السَّماءِ﴾</span> سوى قول ابن عباس، وقتادة، وابن زيد.</div></p><p><h3><span class="qpc-hafs">﴿فَتُصۡبِحَ صَعِیدࣰا زَلَقًا ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فتصبح صعيدا زلقا﴾</span>، قال: مثل الجُرُز{11}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿زلقا﴾</span>، قال: رَمْلًا هائلًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧١<span class="dash">-</span></span> في تفسير <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿فتصبح صعيدا زلقا﴾</span> لا نبات فيها، والصعيد الزلق: التراب الذي لا نبات فيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فتصبح صعيدا زلقا﴾</span>، أي: قد حُصِدَ ما فيها، فلم يُتْرَكْ فيها شيءٌ{14}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿صعيدا زلقا﴾</span>، قال: الصعيد: الأملس. والزلق: التي ليس فيها نبات{15}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتصبح﴾</span> جنتك <span class="qpc-hafs">﴿صعيدا﴾</span>، يعني: مستويًا ليس فيه شيء، <span class="qpc-hafs">﴿زلقا﴾</span> يعني: أملسًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فتصبح صعيدا زلقا﴾</span>، قال: <span class="qpc-hafs">﴿صعيدا زلقا﴾</span> و<span class="qpc-hafs">﴿صعيدا جرزا﴾</span> [الكهف:٨] واحد؛ ليس فيها شيء من النبات{17}<span class=comment-ref>٤٠٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠٢٣</span> لم يذكر <u>ابنُ جرير</u> (١٥/٢٦٦-٢٦٧) في معنى: <span class="qpc-hafs">﴿صَعِيدًا زَلَقًا﴾</span> سوى قول ابن عباس، وقتادة، وابن زيد.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٨٦.|2:تفسير يحيى بن سلام ١/١٨٧.|3:أخرجه ابن جرير ١٥/٢٦٦.|4:أخرجه الطستي -كما في الإتقان ٢/٩٣-.|5:عزاه السيوطي إلى ابن أبي شيبة، وابن أبي حاتم.|6:أخرجه ابن جرير ١٥/٢٦٦.|7:أخرجه عبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٦، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|8:علقه يحيى بن سلام ١/١٨٧.|9:تفسير مقاتل بن سليمان ٢/٥٨٦.|10:أخرجه ابن جرير ١٥/٢٦٦.|11:أخرجه ابن جرير ١٥/٢٦٧. وعزاه السيوطي إلى ابن المنذر.|12:تفسير الثعلبي ٦/١٧١، وتفسير البغوي ٥/١٧٣.|13:علقه يحيى بن سلام ١/١٨٧.|14:أخرجه عبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٦. وعلقه يحيى بن سلام ١/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|15:عزاه السيوطي إلى ابن أبي حاتم.|16:تفسير مقاتل بن سليمان ٢/٥٨٦.|17:أخرجه ابن جرير ١٥/٢٦٧.
  18,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوۡ یُصۡبِحَ مَاۤؤُهَا غَوۡرࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أو يصبح ماؤها غورا﴾</span>، أي: ذاهِبًا قد غار في الأرض{1}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٧<span class="dash">-</span></span> تفسير <span class="name-2">السدي</span>، قال: <span class="qpc-hafs">﴿أو يصبح﴾</span>، يعني: أو يصير{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: والغَوْر: الذي لا تناله الدِّلاء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو يصبح ماؤها غورا﴾</span>، يعني: يغور في الأرض فيذهب{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَن تَسۡتَطِیعَ لَهُۥ طَلَبࣰا ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلن تستطيع له طلبا﴾</span>، يقول: فلن تقدر على الماء. ثم افترقا، فأرسل الله ﷿ على جنته بالليل عذابًا مِن السماء، فاحترقت، وغار ماؤها؛ بقوله: <span class="qpc-hafs">﴿ما أظن أن تبيد هذه أبدا وما أظن الساعة قائمة﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فلن تستطيع له طلبا﴾</span> قد غار في الأرض{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/١٨٧، وعبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:علقه يحيى بن سلام ١/١٨٧.|3:علقه يحيى بن سلام ١/١٨٧.|4:تفسير مقاتل بن سليمان ٢/٥٨٦.|5:تفسير مقاتل بن سليمان ٢/٥٨٦.|6:تفسير يحيى بن سلام ١/١٨٧.
  18,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُحِیطَ بِثَمَرِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٨٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق ابن مجاهد-: <span class="qpc-hafs">﴿وأحيط بثَمَره﴾</span> مثل قوله: <span class="qpc-hafs">﴿وكان له ثَمَر﴾</span>: ذهب وفضة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿وأحيط بثمره﴾</span>، قال: أحاط به أمر الله فهلك{2}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وأحيط بثمره﴾</span>، قال: الثمر من المال كله، يعني: الثمر وغيره من المال كله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿وأحيط بثمره﴾</span>، قال: بثمر الجنتين، فأهلكت{4}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحيط بثمره﴾</span> الهلاك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿وأحيط بثمره﴾</span> من الليل{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحَ یُقَلِّبُ كَفَّیۡهِ عَلَىٰ مَاۤ أَنفَقَ فِیهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٨٨<span class="dash">-</span></span> وقال <span class="name-2">الحسن البصري</span>: يضرب إحداهما على الأخرى ندامةً{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٨٩<span class="dash">-</span></span> في تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يقلب كفيه﴾</span>: يسفِّق كفَّيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فأصبح يقلب كفيه﴾</span> قال: يصفق <span class="qpc-hafs">﴿على ما أنفق فيها﴾</span> مُتَلَهِّفًا على ما فاته{9}. (٩/٥٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٩١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿فأصبح يقلب كفيه﴾</span>، يقول: ندامة عليها{4}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلما أصبح ورأى جنته هالكة ضرب بكفه على الأخرى، ندامة على ما أنفق فيها، فذلك قوله سبحانه: <span class="qpc-hafs">﴿فأصبح يقلب كفيه﴾</span> يعني: يصفق بكفيه ندامة <span class="qpc-hafs">﴿على ما أنفق فيها﴾</span>{5}<span class=comment-ref>٤٠٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠٢٤</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٥/٦١١) تفسير قتادة، ومقاتل: تقليب الكفين بالتصفيق. فقال: «ومن عبَّر بـ»يُصَفِّق«فلم يتقن». <span class="comment-type-3">واختار</span> <span class="mustanad">مستندًا لواقع الحال</span> أن معنى: <span class="qpc-hafs">﴿يُقَلِّبُ كَفَّيْهِ﴾</span> يراد به: «وضع بطن إحداهما على ظهر الأخرى، وكذلك فِعْلُ المُتَلَهِّف المُتَأَسِّف على فائتٍ أو خسارة أو نحوهما».</div></p><p><div></p><p><p><span class="item-no">٤٤٩٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأصبح﴾</span> مِن الغد قائمًا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهِیَ خَاوِیَةٌ عَلَىٰ عُرُوشِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٩٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وهي خاوية على عروشها﴾</span>، عروشها: التراب، قد ذهب ما فيها من النبات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿وهي خاوية على عروشها﴾</span>، قال: قُلِبَ أسفلُها أعلاها{4}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهي خاوية على عروشها﴾</span> يقول: ساقطة من فوقها، <span class="qpc-hafs">﴿ويقول ياليتني لم أشرك بربي أحدا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبعضهم يقول: مقلوبة على رؤوسها{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَقُولُ یَـٰلَیۡتَنِی لَمۡ أُشۡرِكۡ بِرَبِّیۤ أَحَدࣰا ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويقول﴾</span> في الآخرة: <span class="qpc-hafs">﴿يا ليتني لم أشرك بربي﴾</span> في الدنيا أحدًا{16}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ١/١٨٧. وقد رسمت (ثمر) فيه بفتح الثاء والميم في الآيتين، وتقدم هذا التفسير عن مجاهد، وأنه كان يقرؤها: ‹وكانَ لَهُ ثُمُرٌ›.|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه عبد الرزاق ٢/٤٠٤، وابن جرير ١٥/٢٦٠.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٥٨٧.|6:تفسير يحيى بن سلام ١/١٨٧.|7:علقه يحيى بن سلام ١/١٨٧.|8:علقه يحيى بن سلام ١/١٨٧.</p><p>وسفق: لغة في صفق. التاج (سفق).|9:أخرجه عبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٨. وعلَّقه يحيى بن سلام ١/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٥٨٧.|12:تفسير يحيى بن سلام ١/١٨٧.|13:علقه يحيى بن سلام ١/١٨٧.|14:عزاه السيوطي إلى ابن أبي حاتم.|15:تفسير مقاتل بن سليمان ٢/٥٨٧.|16:تفسير يحيى بن سلام ١/١٨٨.|17:تفسير يحيى بن سلام ١/١٨٨.
  18,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمۡ تَكُن لَّهُۥ فِئَةࣱ یَنصُرُونَهُۥ مِن دُونِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٩٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولم تكن له فئة﴾</span>، قال: عشيرة{1}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ولم تكن له فئة﴾</span>، قال: عشيرة{2}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولم تكن له فئة﴾</span>، أي: جند ينصرونه من دون الله{3}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٢<span class="dash">-</span></span> في تفسير <span class="name-2">إسماعيل السدي</span>: <span class="qpc-hafs">﴿ينصرونه من دون الله﴾</span>: يمنعوه من دون الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿ولم تكن له فئة ينصرونه من دون الله﴾</span>، يعني: جندًا يمنعونه من عذاب الله الذى نزل بجنته{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا كَانَ مُنتَصِرًا ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٠٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما كان منتصرا﴾</span>، أي: مُمْتَنِعًا{6}. (٩/٥٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٥<span class="dash">-</span></span> في تفسير <span class="name-2">إسماعيل السدي</span>: <span class="qpc-hafs">﴿وما كان منتصرا﴾</span>: ممتنعًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما كان منتصرا﴾</span>، يعني: ممتنعًا{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام١/١٨٨ من طريق ابن مجاهد، وابن جرير ١٥/٢٦٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن جرير ١٥/٢٦٩، وابن أبي حاتم ٩/٣٠٢٠. وعلق يحيى بن سلام١/١٨٨ نحوه.|4:علقه يحيى بن سلام ١/١٨٨.|5:تفسير مقاتل بن سليمان ٢/٥٨٧.|6:أخرجه ابن جرير ١٥/٢٧٠، وابن أبي حاتم ٩/٣٠٢٠. وعلقه يحيى بن سلام ١/١٨٨.|7:علقه يحيى بن سلام ١/١٨٨.|8:تفسير مقاتل بن سليمان ٢/٥٨٧.
  18,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُنَالِكَ ٱلۡوَلَـٰیَةُ لِلَّهِ ٱلۡحَقِّۚ﴾</span> - قراءات، وتفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٥٠٠٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السدي</span>: يعني: ولاية الدين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span> -تعقيبًا على قول السدي-: هي مفتوحة عنده{2}، وهي تقرأ على وجهين: أحدهما: برفع الحق، والآخر: بجرِّه. فمَن قرأها بالرفع يقول: هناك الولاية الحق لله، فيها تقديم. ومن قرأها بالجر يقول: لله الحق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هنالك الولاية﴾</span> يعني: السلطان، ليس في ذلك اليوم سلطان غيره، مثل قوله ﷿: <span class="qpc-hafs">﴿والأمر يومئذ لله﴾</span> [الانفطار:١٩]، ليس في ذلك اليوم أمر إلا لله ﷿، والأمر أيضًا في الدنيا، لكن جعل في الدنيا ملوكًا يأمرون. ومن قرأها بفتح الواو، جعلها من الموالاة، <span class="qpc-hafs">﴿هنالك الولاية لله﴾</span> يعني: البعث الذى كفر به فرطس، <span class="qpc-hafs">﴿لله الحق﴾</span> وحده، لا يملكه أحد، ولا ينازعه أحد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠١٠<span class="dash">-</span></span> عن <span class="name-3">مبشر بن عبيد</span>، قال: <span class="qpc-hafs">﴿الوَلاية﴾</span>: الدين. و›الوِلايَةُ‹: ما أتولى{5}. (٩/٥٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿هنالك الولاية لله الحق﴾</span> في الآخرة، هنالك يتولى الله كل عبد، لا يبقى أحد يومئذ إلا تولى الله، فلا يقبل ذلك من المشرك. والحق: اسم من أسماء الله{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُوَ خَیۡرࣱ ثَوَابࣰا وَخَیۡرٌ عُقۡبࣰا ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هو خير ثوابا﴾</span> يعني: أفضل ثوابًا، <span class="qpc-hafs">﴿وخير عقبا﴾</span> يعني: أفضل عاقبة لهذا المؤمن مِن عاقبة هذا الكافر الذي جعل مرجعه إلى النار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿هو خير ثوابا﴾</span> خيرُ مَن أثاب، وخير ثوابًا للمؤمنين من الأوثان لمن عبدها، <span class="qpc-hafs">﴿وخير عقبا﴾</span> وخير من أثاب{6}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ١/١٨٨.|2:قرأ جمهور القراء بفتح واو <span class="qpc-hafs">﴿الولاية﴾</span>، وقرأ حمزة والكسائي وخلف بكسرها. انظر: النشر ٢/٢٧٧.|3:تفسير يحيى بن سلام ١/١٨٨.</p><p>والقراءة بخفض <span class="qpc-hafs">﴿الحقِّ﴾</span> هي قراءة الجمهور، وقرأ أبو عمرو والكسائي برفع القاف. انظر: النشر ٢/٣١١.|4:تفسير مقاتل بن سليمان ٢/٥٨٧.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:تفسير يحيى بن سلام ١/١٨٨.|7:تفسير مقاتل بن سليمان ٢/٥٨٧.|8:تفسير يحيى بن سلام ١/١٨٨.
  18,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱضۡرِبۡ لَهُم مَّثَلَ ٱلۡحَیَوٰةِ ٱلدُّنۡیَا كَمَاۤءٍ أَنزَلۡنَـٰهُ مِنَ ٱلسَّمَاۤءِ فَٱخۡتَلَطَ بِهِۦ نَبَاتُ ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٠١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واضرب لهم﴾</span> لكفار مكة <span class="qpc-hafs">﴿مثل﴾</span> يعني: شبه <span class="qpc-hafs">﴿الحياة الدنيا كماء أنزلناه من السماء فاختلط به﴾</span> يعني: بالماء <span class="qpc-hafs">﴿نبات الأرض﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحَ هَشِیمࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٠١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿هشيما﴾</span>، قال: يابِسًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠١٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿هشيما﴾</span>، قال: كسِيرًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأصبح﴾</span> النبتُ <span class="qpc-hafs">﴿هشيما﴾</span> يعني: يابسًا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَذۡرُوهُ ٱلرِّیَـٰحُۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٠١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿تذروه الرياح﴾</span>، قال: تُثِيره الرياح{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تذروه الرياح﴾</span>، يقول سبحانه: مَثَل الدنيا كمَثَل النبت، بينما هو أخضر إذ هو قد يبِس وهلك، فكذلك تهلك الدنيا إذا جاءت الآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأصبح هشيما تذروه الرياح﴾</span>، هشَّمته الرياح فأذهبته، فأخبر أنّ الدنيا ذاهبة زائلة كما ذهب ذلك النبات بعد بهجته وحُسنه{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ مُّقۡتَدِرًا ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٠٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكان الله على كل شيء﴾</span> مِن البعث وغيره <span class="qpc-hafs">﴿مقتدرا﴾</span>{1}<span class=comment-ref>٤٠٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠٢٥</span> ذكر <u>ابنُ عطية</u> (٥/٦١٣) أنّ قوله تعالى: <span class="qpc-hafs">﴿وكانَ الله﴾</span> «عبارة للإنسان عن أن الأمر قبل وجود الإنسان هكذا كان إذ كان، إذ نفسه حاكمة بذلك في حال غفلة. هذا قول سيبويه». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهو معنى صحيح». ثم نقل <b>عن الحسن</b> قوله: «كانَ: إخبارٌ عن الحال قبل إيجاد الموجودات، أي: أن القدرة كانت». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا أيضًا حسن».</div></p><p><div></p><p><p><span class="item-no">٤٥٠٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وكان الله على كل شيء مقتدرا﴾</span>: قديرًا{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٨٧.|2:تفسير الثعلبي ٦/١٧٣، وتفسير البغوي ٥/١٧٤.|3:تفسير الثعلبي ٦/١٧٣، وتفسير البغوي ٥/١٧٤.|4:تفسير مقاتل بن سليمان ٢/٥٨٧.|5:تفسير البغوي ٥/١٧٤.وذكر محققوه أنها في نسخة أخرى: تديره، وهو كذلك في تفسير الثعلبي ٦/١٧٣، وفي طبعة دار التفسير ١٧/١٤٩:تذريه.|6:تفسير مقاتل بن سليمان ٢/٥٨٧.|7:تفسير يحيى بن سلام ١/١٨٨.|8:تفسير مقاتل بن سليمان ٢/٥٨٧.|9:تفسير يحيى بن سلام ١/١٨٨.