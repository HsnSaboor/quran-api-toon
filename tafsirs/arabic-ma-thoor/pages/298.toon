tafsir[11]{c,v,t}:
18,35," <q>﴿وَدَخَلَ جَنَّتَهُۥ وَهُوَ ظَالِمࣱ لِّنَفۡسِهِۦ﴾</q> - تفسير ٤٤٩١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ودخل جنته وهو ظالم لنفسه﴾</q>، يقول: كفور لنِعمة ربه{1}. (٩/٥٤١) ٤٤٩١٧- قال مقاتل بن سليمان: <q>﴿ودخل﴾</q> الكافرُ <q>﴿جنته﴾</q> وهو بستانه، <q>﴿وهو ظالم لنفسه﴾</q>{2}. (ز) ٤٤٩١٨- قال يحيى بن سلّام: قال الله: <q>﴿ودخل جنته وهو ظالم لنفسه﴾</q>، يعني: بشركه{3}. (ز) <q>﴿قَالَ مَاۤ أَظُنُّ أَن تَبِیدَ هَـٰذِهِۦۤ أَبَدࣰا ۝٣٥﴾</q> - تفسير ٤٤٩١٩- تفسير الحسن البصري: ليس يعني: أنها لا تفنى فتذهب، ولكنه يعني: أنه يعيش فيه حتى يأكلها حياته. كقوله: <q>﴿يحسب أن ماله أخلده﴾</q> [الهمزة:٣]، أي: يحسب أنه يخلد في ماله حتى يأكله{4}. (ز) ٤٤٩٢٠- عن إسماعيل السدي، في قوله: <q>﴿قال ما أظن أن تبيد هذه أبدا﴾</q>، يقول: تهلك{5}. (٩/٥٤١) ٤٤٩٢١- قال مقاتل بن سليمان: <q>﴿قال ما أظن﴾</q> يعني: ما أحسب <q>﴿أن تبيد﴾</q> يعني: أن تهلك <q>﴿هذه﴾</q> الجنة <q>﴿أبدا﴾</q>{2}. (ز) ٤٤٩٢٢- قال يحيى بن سلّام: <q>﴿قال ما أظن﴾</q> ما أُوقِن <q>﴿أن تبيد هذه أبدا﴾</q> أي: تفنى هذه أبدًا{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٢٦٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٥.تفسير يحيى بن سلام ١/١٨٦.علقه يحيى بن سلام ١/١٨٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٥.تفسير يحيى بن سلام ١/١٨٦.
18,36," <q>﴿وَمَاۤ أَظُنُّ ٱلسَّاعَةَ قَاۤىِٕمَةࣰ وَلَىِٕن رُّدِدتُّ إِلَىٰ رَبِّی لَأَجِدَنَّ خَیۡرࣰا مِّنۡهَا مُنقَلَبࣰا ۝٣٦﴾</q> - قراءات ٤٤٩٢٣- قال يحيى بن سلّام: وهي تُقرأ على وجه آخر: ‹لَأَجِدَنَّ خَيْرًا مِّنْهُما مُنقَلَبًا›، يعني: الجنتين، وهي في موضع جنة، وفي موضع جنتان. قال: <q>﴿ودَخَلَ جَنَّتَهُ﴾</q>، وقال: <q>﴿جَعَلْنا لِأَحَدِهِما جَنَّتَيْنِ﴾</q>، فهي جنة بينهما نهر؛ فصارت جنتين، وهي جنة، وهي جنتان{1}. (ز) <q>﴿وَمَاۤ أَظُنُّ ٱلسَّاعَةَ قَاۤىِٕمَةࣰ﴾</q> - تفسير ٤٤٩٢٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وما أظن الساعة قائمة﴾</q>: مُكَذِّب بلقائه{2}. (ز) ٤٤٩٢٥- عن إسماعيل السدي، في قوله: <q>﴿وما أظن الساعة قائمة﴾</q>: ولئن كانت قائمة ثم <q>﴿رددت إلى ربي لأجدن خيرا منها منقلبا﴾</q>{3}. (٩/٥٤١) ٤٤٩٢٦- قال مقاتل بن سليمان: <q>﴿وما أظن الساعة قائمة﴾</q>، يعني: القيامة كائنة كما تقول{4}. (ز) ٤٤٩٢٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وما أظن الساعة قائمة﴾</q>، قال: شكّ{2}. (ز) ٤٤٩٢٨- قال يحيى بن سلّام: <q>﴿وما أظن الساعة قائمة﴾</q>: وما أُوقِن أنّ الساعة قائمة. يجحد بالبعث{6}. (ز) <q>﴿وَلَىِٕن رُّدِدتُّ إِلَىٰ رَبِّی لَأَجِدَنَّ خَیۡرࣰا مِّنۡهَا مُنقَلَبࣰا ۝٣٦﴾</q> - تفسير ٤٤٩٢٩- عن قتادة بن دعامة -من طريق سعيد-: مُتَمَنٍّ على الله{2}. (ز) ٤٤٩٣٠- قال مقاتل بن سليمان: <q>﴿ولئن رددت إلى ربي﴾</q> في الآخرة <q>﴿لأجدن خيرا منها﴾</q> يعني: أفضل منها، من جنتي، <q>﴿منقلبا﴾</q> يعني: مرجعًا{4}. (ز) ٤٤٩٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: ثم قال: <q>﴿ولئن﴾</q> كان ذلك، ثم <q>﴿رددت إلى ربي لأجدن خيرا منها منقلبا﴾</q>، ما أعطاني هذه إلا ولي عنده خير من ذلك{2}. (ز) ٤٤٩٣٢- قال يحيى بن سلّام: <q>﴿ولئن رددت إلى ربي لأجدن خيرا منها﴾</q> من جنتي <q>﴿منقلبا﴾</q> في الآخرة؛ إن كانت آخرة. كقوله: <q>﴿ولئن رجعت إلى ربي إن لي عنده للحسنى﴾</q> [فصلت:٥٠]: الجنة؛ إن كانت جنة، أي: ولكن ليس جنة ولا مَرَدٌّ{6}. (ز) ",footnotes:1:تفسير يحيى بن سلام ١/١٨٦. و‹خَيْرًا مِّنْهُما› بزيادة ألف بعد الهاء على التثنية قراءة متواترة، قرأ بها نافع، وابن كثير، وابن عامر، وأبو جعفر، وقرأ بقية العشرة <q>﴿خَيْرًا مِّنْها﴾</q> بغير ميم على الإفراد. انظر: النشر ٢/٣١٠-٣١١، والإتحاف ص٣٦٦.أخرجه ابن جرير ١٥/٢٦٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٥.أخرجه ابن جرير ١٥/٢٦٣.تفسير يحيى بن سلام ١/١٨٦.أخرجه ابن جرير ١٥/٢٦٣.تفسير مقاتل بن سليمان ٢/٥٨٥.أخرجه ابن جرير ١٥/٢٦٣.تفسير يحيى بن سلام ١/١٨٦.
18,37," <q>﴿قَالَ لَهُۥ صَاحِبُهُۥ وَهُوَ یُحَاوِرُهُۥۤ﴾</q> - تفسير ٤٤٩٣٣- قال مقاتل بن سليمان: فردَّ عليه، <q>﴿قال له صاحبه﴾</q> المؤمن <q>﴿وهو يحاوره﴾</q> يعني: يراجعه{1}. (ز) ٤٤٩٣٤- قال يحيى بن سلّام: <q>﴿قال له صاحبه﴾</q> المؤمن{2}. (ز) <q>﴿أَكَفَرۡتَ بِٱلَّذِی خَلَقَكَ مِن تُرَابࣲ ثُمَّ مِن نُّطۡفَةࣲ ثُمَّ سَوَّىٰكَ رَجُلࣰا ۝٣٧﴾</q> - تفسير ٤٤٩٣٥- قال مقاتل بن سليمان: <q>﴿أكفرت بالذي خلقك من تراب﴾</q> يعني: آدم ﵇؛ لأن أول خلقه التراب، ثم قال: <q>﴿ثم من نطفة ثم سواك﴾</q> يعني: خلقك فجعلك <q>﴿رجلا﴾</q>{1}٤٠١٩. (ز) ٤٠١٩ ذكر ابنُ عطية (٥/٦٠٨) أن معنى: <q>﴿ثُمَّ سَوّاكَ رَجُلًا﴾</q> «كما تقول: سوّاك شخصًا أو حيًّا أو نحو هذا من التأكيدات». ثم ذكر احتمالًا آخر، فقال: «وقد يحتمل أن قصد تخصيص الرجولة على وجه تعديد النعمة في أن لم يكن أنثى ولا خنثى». ٤٤٩٣٦- قال يحيى بن سلّام: <q>﴿وهو يحاوره أكفرت بالذي خلقك من تراب﴾</q>، يعني: أول خلق الإنسان، يعني: آدم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٨٦.تفسير يحيى بن سلام ١/١٨٦.تفسير مقاتل بن سليمان ٢/٥٨٦.تفسير يحيى بن سلام ١/١٨٦.
18,38," <q>﴿لَّـٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّی وَلَاۤ أُشۡرِكُ بِرَبِّیۤ أَحَدࣰا ۝٣٨﴾</q> - قراءات ٤٤٩٣٧- عن هارون، قال: في قراءة أبي بن كعب: (لَكِنْ أناْ هُوَ اللهُ رَبِّي){1}. (ز) ٤٤٩٣٨- عن الأعمش: في قراءة عبد الله [بن مسعود]: <q>﴿لَكِنّاْ هُوَ اللهُ رَبِّي﴾</q>{2}. (ز) ٤٤٩٣٩- عن عمر، عن الحسن أنه كان يقرؤها: (لَكِنْ أناْ هُوَ اللهُ رَبِّي){3}. (ز) <q>﴿لَّـٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّی وَلَاۤ أُشۡرِكُ بِرَبِّیۤ أَحَدࣰا ۝٣٨﴾</q> - تفسير الآية ٤٤٩٤٠- قال مقاتل بن سليمان: <q>﴿لكنا﴾</q> أقول: <q>﴿هو الله ربي ولا أشرك بربي أحدا﴾</q>{4}. (ز) <q>﴿لَّـٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّی وَلَاۤ أُشۡرِكُ بِرَبِّیۤ أَحَدࣰا ۝٣٨﴾</q> - آثار متعلقة بالآية ٤٤٩٤١- عن أسماء بنت عميس، قالت: علَّمني رسولُ الله ﷺ كلماتٍ أقولُهُنَّ عند الكرب: «الله الله ربي، لا أشرك به شيئًا»{5}. (٩/٥٤٢) ",footnotes:1:أخرجه ابن الأنباري في الوقف والابتداء ١/٤٠٩ (١٥٢). وهي قراءة شاذة، تروى أيضًا عن الحسن، وقراءة العشرة: <q>﴿لَكِنّاْ هُوَ اللهُ رَبِّي﴾</q>. انظر: المحتسب ٢/٢٩.أخرجه ابن أبي داود في المصاحف ١/٣٢٢.أخرجه ابن الأنباري في الوقف والابتداء ١/٤٠٩ (١٥٢).تفسير مقاتل بن سليمان ٢/٥٨٦.أخرجه أحمد ٤٥/١٥-١٦ (٢٧٠٨٢)، وأبو داود ٢/٦٣٢ (١٥٢٥)، وابن ماجه ٥/٤٦ (٣٨٨٢)، وابن أبي حاتم ٧/٢٣٦٢ (١٢٨١٣). قال أبو نعيم في الحلية ٥/٣٦٠: «غريب من حديث عمر». وقال الألباني في صحيح أبي داود ٥/٢٥٥ (١٣٦٤): «إسناده صحيح».
18,39," <q>﴿وَلَوۡلَاۤ إِذۡ دَخَلۡتَ جَنَّتَكَ قُلۡتَ مَا شَاۤءَ ٱللَّهُ لَا قُوَّةَ إِلَّا بِٱللَّهِۚ﴾</q> - تفسير ٤٤٩٤٢- عن عبد الله بن عباس، في «لا حول ولا قوة إلا بالله»، قال: لا حول بنا على العمل بالطاعة إلا بالله، ولا قوة لنا على ترك المعصية إلا بالله{1}. (٩/٥٤٨) ٤٤٩٤٣- عن زهير بن محمد، أنّه سُئِل عن تفسير: لا حول ولا قوة إلا بالله. قال: لا تأخذ ما تحب إلا بالله، ولا تمتنع مما تكره إلا بعون الله{1}. (٩/٥٤٨) ٤٤٩٤٤- قال مقاتل بن سليمان: ثم قال المؤمن للكافر: <q>﴿ولولا﴾</q> يعني: هلّا <q>﴿إذ دخلت جنتك﴾</q> يعني: بستانك؛ <q>﴿قلت ما شاء الله لا قوة إلا بالله﴾</q> يعني: فهلّا قلتَ: بمشيئة الله أعطيتها بغير حول مني ولا قوَّة{3}. (ز) ٤٤٩٤٥- قال يحيى بن سلّام: <q>﴿ولولا﴾</q>: فهلّا{4}. (ز) <q>﴿وَلَوۡلَاۤ إِذۡ دَخَلۡتَ جَنَّتَكَ قُلۡتَ مَا شَاۤءَ ٱللَّهُ لَا قُوَّةَ إِلَّا بِٱللَّهِۚ﴾</q> - آثار متعلقة بالآية ٤٤٩٤٦- عن ابن مسعود، عن النبي ﷺ، قال: «أخبرني جبريل أن تفسير «لا حول ولا قوة إلا بالله»: أنّه لا حول عن معصية الله إلا بقوة الله، ولا قوة على طاعة الله إلا بعون الله»{5}. (٩/٥٤٦) ٤٤٩٤٧- عن أبي هريرة، قال: قال لي نبي الله ﷺ: «ألا أدلك على كنز من كنوز الجنة تحت العرش». قلت: نعم. قال: «أن تقول: <q>﴿لا قوة إلا بالله﴾</q>». قال عمرو بن ميمون: قلت لأبي هريرة: لا حول ولا قوة إلا بالله؟ فقال: لا، إنها في سورة الكهف: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</q>{6}. (٩/٥٤٤) ٤٤٩٤٨- عن عقبة بن عامر، قال: قال رسول الله ﷺ: «مَن أنعم الله عليه نعمةً فأراد بقاءها، فليُكْثِر مِن قول: لا حول ولا قوة إلا بالله». ثم قرأ رسول الله ﷺ: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</q>{7}. (٩/٥٤٤) ٤٤٩٤٩- عن أنس بن مالك، قال: قال رسول الله ﷺ: «ما أنعم الله على عبد نعمة في أهل أو مال أو ولد فيقول: ما شاء الله لا قوة إلا بالله. إلا دفع الله عنه كلَّ آفة حتى تأتيه مَنِيَّتُه». وقرأ: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</q>{8}. (٩/٥٤٣) ٤٤٩٥٠- عن أنس بن مالك، قال: مَن رأى شيئًا مِن ماله فأعجبه فقال: <q>﴿ما شاء الله لا قوة إلا بالله﴾</q>. لم يُصِب ذلك المالَ آفةٌ أبدًا. وقرأ: <q>﴿ولولا إذ دخلت جنتك﴾</q> الآية{1}. (٩/٥٤٤) ٤٤٩٥١- عن أنس بن مالك مرفوعًا{10}. (٩/٥٤٤) ٤٤٩٥٢- عن عروة بن الزبير: أنّه كان إذا رأى من ماله شيئًا يعجبه، أو دخل حائطًا مِن حيطانه؛ قال: ما شاء الله لا قوة إلا بالله. ويتأول قول الله: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</q>{11}. (٩/٥٤٢) ٤٤٩٥٣- عن حفص بن ميسرة، قال: رأيت على باب وهب بن منبه مكتوبًا: <q>﴿ما شاء الله لا قوة إلا بالله﴾</q>. وذلك قول الله: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله﴾</q>{1}. (٩/٥٤٢) ٤٤٩٥٤- عن زياد بن سعد، قال: كان [محمد] ابن شهاب [الزهري] إذا دخل أمواله قال: ما شاء الله لا قوة إلا بالله. ويتأول قوله: <q>﴿ولولا إذ دخلت جنتك﴾</q> الآية{13}. (٩/٥٤٢) ٤٤٩٥٥- عن عمرو بن مرة -من طريق أبي سنان- قال: أُدخِل رجل الجنة، فقال: لا حول ولا قوة إلا بالله. فرفع درجة، ثم قال: لا حول ولا قوة إلا بالله. فرفع درجة، فقال الملَك: ألا تستحي كم تسأل ربك؟! قال: وهل سألت ربي شيئًا؟ ثم تلا أبو سنان هذه الآية: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله﴾</q>{14}. (ز) ٤٤٩٥٦- عن إبراهيم بن أدهم، قال: ما سأل رجلٌ مسألة ألَحّ مِن أن يقول: <q>﴿ما شاء الله﴾</q>{1}. (٩/٥٤٣) ٤٤٩٥٧- عن مطرف، قال: كان مالك بن أنس إذا دخل بيته قال: <q>﴿ما شاء الله﴾</q>. قلت لمالك: لم تقول هذا ؟ قال: ألا تسمع الله يقول: <q>﴿ولولا إذ دخلت جنتك قلت ما شاء الله﴾</q>؟{1}. (٩/٥٤٢) <q>﴿إِن تَرَنِ أَنَا۠ أَقَلَّ مِنكَ مَالࣰا وَوَلَدࣰا ۝٣٩﴾</q> - تفسير ٤٤٩٥٨- قال مقاتل بن سليمان: ثم قال المؤمن للكافر يرُدُّ عليه: <q>﴿إن ترن أنا أقل منك مالا وولدا﴾</q>{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٦.تفسير يحيى بن سلام ١/١٨٦.أخرجه البزار ٥/٣٧٤ (٢٠٠٤)، وابن شاهين في الترغيب في فضائل الأعمال ص١٠٦ (٣٥١). قال البزار: «وهذا الحديث لم نسمع موصولًا عن القاسم عن أبيه عن عبد الله إلا من هذا الوجه». وقال البيهقي في شعب الإيمان ٢/١٦٣-١٦٤ (٦٥٦): «تفرّد به صالح بن بيان السيرافي، وليس بالقوي، ورُوِي ذلك من وجه آخر ضعيف، عن زر عن عبد الله مرفوعًا». وقال الهيثمي في المجمع ١٠/٩٩ (١٦٩٠٧): «رواه البزار بإسنادين، أحدهما منقطع، وفيه عبد الله بن خراش، والغالب عليه الضعف، والآخر متصل حسن». وقال المناوي في التيسير ١/٣٩٥: «وفي إسناده لين». وقال الألباني في الضعيفة ٧/٣٦٦ (٣٣٥٥): «ضعيف».أخرجه أحمد ١٤/١٤٩-١٥٠ (٨٤٢٦). قال الهيثمي في المجمع ١٠/٩٩ (١٦٩١٠): «رواه أحمد، والبزار بنحوه... ورجالهما رجال الصحيح، غير أبي بلج الكبير، وهو ثقة».أخرجه الطبراني في الكبير ١٧/٣١٠ (٨٥٩). قال الهيثمي في المجمع ١٠/٩٩ (١٦٩٠٩): «رواه الطبراني، وفيه خالد بن نجيح، وهو كذاب». وقال الألباني في الضعيفة ١٠/٦٨ (٤٥٦٤): «موضوع».أخرجه الطبراني في الأوسط ٤/٣٠١ (٤٢٦١)، ٦/١٢٦ (٥٩٩٥)، والبيهقي في شعب الإيمان ٦/٢١٢-٢١٣ (٤٠٦٠) بدون ذكر الآية، ٦/٢٩٢ (٤٢٠٧). قال ابن كثير في تفسيره ٥/١٥٨-١٥٩: «قال الحافظ أبو الفتح الأزدي: عيسى بن عون عن عبد الملك بن زرارة عن أنس، لا يصح حديثه». وقال الهيثمي في المجمع ١٠/١٤٠ (١٧١٥١): «رواه الطبراني في الصغير، والأوسط، وفيه عبد الملك بن زرارة، وهو ضعيف». وقال المناوي في التيسير ٢/٣٤٤: «إسناده ضعيف». وقال الألباني في الضعيفة ٥/٢٥ (٢٠١٢): «ضعيف».عزاه السيوطي إلى ابن أبي حاتم.أخرجه البزار ١٣/٥٠٦ دون ذكر الآية، من طريق أبي بكر الهذلي، عن ثمامة، عن أنس به. قال البزّار: «هذا الكلام لا نعلم رواه إلا أنس، ولا نعلم له طريقًا إلا هذا الطريق». وقال الهيثمي في المجمع ٥/١٠٩: «رواه لبزار من رواية أبي بكر الهذلي، وأبو بكر ضعيف جدًّا».أخرجه البيهقي في شعب الإيمان (٢٢٣٠، ١١٢٢٦). وعزاه السيوطي إلى سعيد بن منصور، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه أبو نعيم في حلية الأولياء ٥/٩٦.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٦.
18,40," <q>﴿فَعَسَىٰ رَبِّیۤ أَن یُؤۡتِیَنِ خَیۡرࣰا مِّن جَنَّتِكَ﴾</q> - تفسير ٤٤٩٥٩- قال مقاتل بن سليمان: <q>﴿فعسى ربي أن يؤتين خيرا﴾</q> يعني: أفضل <q>﴿من جنتك﴾</q>{1}. (ز) ٤٤٩٦٠- قال يحيى بن سلّام: ثم قال: <q>﴿فعسى ربي أن يؤتين﴾</q> في الآخرة <q>﴿خيرا من جنتك﴾</q>{2}٤٠٢٠. (ز) ٤٠٢٠ ذكر ابنُ عطية (٥/٦١٠) احتمالًا آخر في هذا التَّرَجِّي بـ«عَسى»: «أن يريد به: في الدنيا». <q>﴿وَیُرۡسِلَ عَلَیۡهَا حُسۡبَانࣰا مِّنَ ٱلسَّمَاۤءِ﴾</q> - تفسير ٤٤٩٦١- عن عبد الله بن عباس -من طريق العوفي- قال: الحسبان: العذاب{3}. (٩/٥٤٩) ٤٤٩٦٢- عن عبد الله بن عباس: أن نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿حسبانا من السماء﴾</q>. قال: نارًا. قال: وهل تعرف العرب ذلك ؟ قال: نعم. أما سمعت حسان بن ثابت وهو يقول: بقيةُ معشرٍ صُبَّت عليهم شآبيبٌ من الحُسْبان شُهْبُ؟{4}. (٩/٥٤٩) ٤٤٩٦٣- عن الضحاك بن مزاحم، في قوله: <q>﴿حسبانا من السماء﴾</q>، قال: نارًا{5}. (٩/٥٤٩) ٤٤٩٦٤- عن الضحاك بن مزاحم -من طريق جويبر- قال: عذابًا{3}. (ز) ٤٤٩٦٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿حسبانا من السماء﴾</q>، قال: عذابًا{7}٤٠٢١. (٩/٥٤٩) ٤٠٢١ فسر ابنُ عباس، والضحاك من طريق جويبر، وقتادة، الحسبان المرسَل من السماء بأنه: العذاب، وحكى ابنُ كثير (٩/١٤٠) ذلك عنهم، ثم استظهر أن هذا العذاب هو: المطر العظيم. بدلالة ظاهر الآية، فقال بعد إيراد كلامهم: «والظاهر: أنه مطر عظيم مزعج، يقلع زرعها وأشجارها، ولهذا قال: <q>﴿فَتُصْبِحَ صَعِيدًا زَلَقًا﴾</q>، أي: بلقعًا ترابًا أملس، لا يثبت فيه قدم». ٤٤٩٦٦- تفسير إسماعيل السدي: <q>﴿ويرسل عليها حسبانا من السماء﴾</q>: نارًا من السماء، أي: عذابًا من السماء، وهي النار{8}. (ز) ٤٤٩٦٧- قال مقاتل بن سليمان: <q>﴿ويرسل عليها﴾</q> يعني: على جنتك <q>﴿حسبانا﴾</q> يعني: عذابًا <q>﴿من السماء﴾</q>{1}. (ز) ٤٤٩٦٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ويرسل عليها حسبانا من السماء﴾</q>، قال: عذابًا. قال: الحسبان: قضاء من الله يقضيه{3}٤٠٢٢. (ز) ٤٠٢٢ لم يذكر ابنُ جرير (١٥/٢٦٦) في معنى: <q>﴿حُسْبانًا مِنَ السَّماءِ﴾</q> سوى قول ابن عباس، وقتادة، وابن زيد. <q>﴿فَتُصۡبِحَ صَعِیدࣰا زَلَقًا ۝٤٠﴾</q> - تفسير ٤٤٩٦٩- عن عبد الله بن عباس -من طريق ابن جريج- في قوله: <q>﴿فتصبح صعيدا زلقا﴾</q>، قال: مثل الجُرُز{11}. (٩/٥٤٩) ٤٤٩٧٠- عن مجاهد بن جبر، في قوله: <q>﴿زلقا﴾</q>، قال: رَمْلًا هائلًا{12}. (ز) ٤٤٩٧١- في تفسير الحسن البصري، قال: <q>﴿فتصبح صعيدا زلقا﴾</q> لا نبات فيها، والصعيد الزلق: التراب الذي لا نبات فيه{8}. (ز) ٤٤٩٧٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فتصبح صعيدا زلقا﴾</q>، أي: قد حُصِدَ ما فيها، فلم يُتْرَكْ فيها شيءٌ{14}. (٩/٥٤٩) ٤٤٩٧٣- عن إسماعيل السدي، في قوله: <q>﴿صعيدا زلقا﴾</q>، قال: الصعيد: الأملس. والزلق: التي ليس فيها نبات{15}. (٩/٥٥٠) ٤٤٩٧٤- قال مقاتل بن سليمان: <q>﴿فتصبح﴾</q> جنتك <q>﴿صعيدا﴾</q>، يعني: مستويًا ليس فيه شيء، <q>﴿زلقا﴾</q> يعني: أملسًا{1}. (ز) ٤٤٩٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فتصبح صعيدا زلقا﴾</q>، قال: <q>﴿صعيدا زلقا﴾</q> و<q>﴿صعيدا جرزا﴾</q> [الكهف:٨] واحد؛ ليس فيها شيء من النبات{17}٤٠٢٣. (ز) ٤٠٢٣ لم يذكر ابنُ جرير (١٥/٢٦٦-٢٦٧) في معنى: <q>﴿صَعِيدًا زَلَقًا﴾</q> سوى قول ابن عباس، وقتادة، وابن زيد. ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٨٦.تفسير يحيى بن سلام ١/١٨٧.أخرجه ابن جرير ١٥/٢٦٦.أخرجه الطستي -كما في الإتقان ٢/٩٣-.عزاه السيوطي إلى ابن أبي شيبة، وابن أبي حاتم.أخرجه ابن جرير ١٥/٢٦٦.أخرجه عبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٦، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ١/١٨٧.تفسير مقاتل بن سليمان ٢/٥٨٦.أخرجه ابن جرير ١٥/٢٦٦.أخرجه ابن جرير ١٥/٢٦٧. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٦/١٧١، وتفسير البغوي ٥/١٧٣.علقه يحيى بن سلام ١/١٨٧.أخرجه عبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٦. وعلقه يحيى بن سلام ١/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٦.أخرجه ابن جرير ١٥/٢٦٧.
18,41," <q>﴿أَوۡ یُصۡبِحَ مَاۤؤُهَا غَوۡرࣰا﴾</q> - تفسير ٤٤٩٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أو يصبح ماؤها غورا﴾</q>، أي: ذاهِبًا قد غار في الأرض{1}. (٩/٥٤٩) ٤٤٩٧٧- تفسير السدي، قال: <q>﴿أو يصبح﴾</q>، يعني: أو يصير{2}. (ز) ٤٤٩٧٨- قال محمد بن السائب الكلبي: والغَوْر: الذي لا تناله الدِّلاء{2}. (ز) ٤٤٩٧٩- قال مقاتل بن سليمان: <q>﴿أو يصبح ماؤها غورا﴾</q>، يعني: يغور في الأرض فيذهب{4}. (ز) <q>﴿فَلَن تَسۡتَطِیعَ لَهُۥ طَلَبࣰا ۝٤١﴾</q> - تفسير ٤٤٩٨٠- قال مقاتل بن سليمان: <q>﴿فلن تستطيع له طلبا﴾</q>، يقول: فلن تقدر على الماء. ثم افترقا، فأرسل الله ﷿ على جنته بالليل عذابًا مِن السماء، فاحترقت، وغار ماؤها؛ بقوله: <q>﴿ما أظن أن تبيد هذه أبدا وما أظن الساعة قائمة﴾</q>{4}. (ز) ٤٤٩٨١- قال يحيى بن سلّام: <q>﴿فلن تستطيع له طلبا﴾</q> قد غار في الأرض{6}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/١٨٧، وعبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ١/١٨٧.علقه يحيى بن سلام ١/١٨٧.تفسير مقاتل بن سليمان ٢/٥٨٦.تفسير مقاتل بن سليمان ٢/٥٨٦.تفسير يحيى بن سلام ١/١٨٧.
18,42," <q>﴿وَأُحِیطَ بِثَمَرِهِۦ﴾</q> - تفسير ٤٤٩٨٢- قال مجاهد بن جبر -من طريق ابن مجاهد-: <q>﴿وأحيط بثَمَره﴾</q> مثل قوله: <q>﴿وكان له ثَمَر﴾</q>: ذهب وفضة{1}. (ز) ٤٤٩٨٣- عن الضحاك بن مزاحم، في قوله: <q>﴿وأحيط بثمره﴾</q>، قال: أحاط به أمر الله فهلك{2}. (٩/٥٥٠) ٤٤٩٨٤- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وأحيط بثمره﴾</q>، قال: الثمر من المال كله، يعني: الثمر وغيره من المال كله{3}. (ز) ٤٤٩٨٥- عن إسماعيل السدي، في قوله: <q>﴿وأحيط بثمره﴾</q>، قال: بثمر الجنتين، فأهلكت{4}. (٩/٥٥٠) ٤٤٩٨٦- قال مقاتل بن سليمان: <q>﴿وأحيط بثمره﴾</q> الهلاك{5}. (ز) ٤٤٩٨٧- قال يحيى بن سلّام: قال الله: <q>﴿وأحيط بثمره﴾</q> من الليل{6}. (ز) <q>﴿فَأَصۡبَحَ یُقَلِّبُ كَفَّیۡهِ عَلَىٰ مَاۤ أَنفَقَ فِیهَا﴾</q> - تفسير ٤٤٩٨٨- وقال الحسن البصري: يضرب إحداهما على الأخرى ندامةً{7}. (ز) ٤٤٩٨٩- في تفسير الحسن البصري: <q>﴿يقلب كفيه﴾</q>: يسفِّق كفَّيه{8}. (ز) ٤٤٩٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فأصبح يقلب كفيه﴾</q> قال: يصفق <q>﴿على ما أنفق فيها﴾</q> مُتَلَهِّفًا على ما فاته{9}. (٩/٥٤٩) ٤٤٩٩١- عن إسماعيل السدي، في قوله: <q>﴿فأصبح يقلب كفيه﴾</q>، يقول: ندامة عليها{4}. (٩/٥٥٠) ٤٤٩٩٢- قال مقاتل بن سليمان: فلما أصبح ورأى جنته هالكة ضرب بكفه على الأخرى، ندامة على ما أنفق فيها، فذلك قوله سبحانه: <q>﴿فأصبح يقلب كفيه﴾</q> يعني: يصفق بكفيه ندامة <q>﴿على ما أنفق فيها﴾</q>{5}٤٠٢٤. (ز) ٤٠٢٤ انتقد ابنُ عطية (٥/٦١١) تفسير قتادة، ومقاتل: تقليب الكفين بالتصفيق. فقال: «ومن عبَّر بـ»يُصَفِّق«فلم يتقن». واختار مستندًا لواقع الحال أن معنى: <q>﴿يُقَلِّبُ كَفَّيْهِ﴾</q> يراد به: «وضع بطن إحداهما على ظهر الأخرى، وكذلك فِعْلُ المُتَلَهِّف المُتَأَسِّف على فائتٍ أو خسارة أو نحوهما». ٤٤٩٩٣- قال يحيى بن سلّام: <q>﴿فأصبح﴾</q> مِن الغد قائمًا{6}. (ز) <q>﴿وَهِیَ خَاوِیَةٌ عَلَىٰ عُرُوشِهَا﴾</q> - تفسير ٤٤٩٩٤- قال الحسن البصري: <q>﴿وهي خاوية على عروشها﴾</q>، عروشها: التراب، قد ذهب ما فيها من النبات{7}. (ز) ٤٤٩٩٥- عن إسماعيل السدي، في قوله: <q>﴿وهي خاوية على عروشها﴾</q>، قال: قُلِبَ أسفلُها أعلاها{4}. (٩/٥٥٠) ٤٤٩٩٦- قال مقاتل بن سليمان: <q>﴿وهي خاوية على عروشها﴾</q> يقول: ساقطة من فوقها، <q>﴿ويقول ياليتني لم أشرك بربي أحدا﴾</q>{5}. (ز) ٤٤٩٩٧- قال يحيى بن سلّام: وبعضهم يقول: مقلوبة على رؤوسها{16}. (ز) <q>﴿وَیَقُولُ یَـٰلَیۡتَنِی لَمۡ أُشۡرِكۡ بِرَبِّیۤ أَحَدࣰا ۝٤٢﴾</q> - تفسير ٤٤٩٩٨- قال يحيى بن سلّام: <q>﴿ويقول﴾</q> في الآخرة: <q>﴿يا ليتني لم أشرك بربي﴾</q> في الدنيا أحدًا{16}. (ز) ",footnotes:1:علقه يحيى بن سلام ١/١٨٧. وقد رسمت (ثمر) فيه بفتح الثاء والميم في الآيتين، وتقدم هذا التفسير عن مجاهد، وأنه كان يقرؤها: ‹وكانَ لَهُ ثُمُرٌ›.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٤٠٤، وابن جرير ١٥/٢٦٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير يحيى بن سلام ١/١٨٧.علقه يحيى بن سلام ١/١٨٧.علقه يحيى بن سلام ١/١٨٧. وسفق: لغة في صفق. التاج (سفق).أخرجه عبد الرزاق ١/٤٠٤، وابن جرير ١٥/٢٦٨. وعلَّقه يحيى بن سلام ١/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير يحيى بن سلام ١/١٨٧.علقه يحيى بن سلام ١/١٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير يحيى بن سلام ١/١٨٨.تفسير يحيى بن سلام ١/١٨٨.
18,43," <q>﴿وَلَمۡ تَكُن لَّهُۥ فِئَةࣱ یَنصُرُونَهُۥ مِن دُونِ ٱللَّهِ﴾</q> - تفسير ٤٤٩٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولم تكن له فئة﴾</q>، قال: عشيرة{1}. (٩/٥٥٠) ٤٥٠٠٠- عن قتادة بن دعامة، في قوله: <q>﴿ولم تكن له فئة﴾</q>، قال: عشيرة{2}. (٩/٥٥٠) ٤٥٠٠١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولم تكن له فئة﴾</q>، أي: جند ينصرونه من دون الله{3}. (٩/٥٥٠) ٤٥٠٠٢- في تفسير إسماعيل السدي: <q>﴿ينصرونه من دون الله﴾</q>: يمنعوه من دون الله{4}. (ز) ٤٥٠٠٣- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿ولم تكن له فئة ينصرونه من دون الله﴾</q>، يعني: جندًا يمنعونه من عذاب الله الذى نزل بجنته{5}. (ز) <q>﴿وَمَا كَانَ مُنتَصِرًا ۝٤٣﴾</q> - تفسير ٤٥٠٠٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما كان منتصرا﴾</q>، أي: مُمْتَنِعًا{6}. (٩/٥٥٠) ٤٥٠٠٥- في تفسير إسماعيل السدي: <q>﴿وما كان منتصرا﴾</q>: ممتنعًا{4}. (ز) ٤٥٠٠٦- قال مقاتل بن سليمان: <q>﴿وما كان منتصرا﴾</q>، يعني: ممتنعًا{5}. (ز) ",footnotes:1:أخرجه يحيى بن سلام١/١٨٨ من طريق ابن مجاهد، وابن جرير ١٥/٢٦٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٢٦٩، وابن أبي حاتم ٩/٣٠٢٠. وعلق يحيى بن سلام١/١٨٨ نحوه.علقه يحيى بن سلام ١/١٨٨.تفسير مقاتل بن سليمان ٢/٥٨٧.أخرجه ابن جرير ١٥/٢٧٠، وابن أبي حاتم ٩/٣٠٢٠. وعلقه يحيى بن سلام ١/١٨٨.علقه يحيى بن سلام ١/١٨٨.تفسير مقاتل بن سليمان ٢/٥٨٧.
18,44," <q>﴿هُنَالِكَ ٱلۡوَلَـٰیَةُ لِلَّهِ ٱلۡحَقِّۚ﴾</q> - قراءات، وتفسير الآية ٤٥٠٠٧- قال إسماعيل السدي: يعني: ولاية الدين{1}. (ز) ٤٥٠٠٨- قال يحيى بن سلّام -تعقيبًا على قول السدي-: هي مفتوحة عنده{2}، وهي تقرأ على وجهين: أحدهما: برفع الحق، والآخر: بجرِّه. فمَن قرأها بالرفع يقول: هناك الولاية الحق لله، فيها تقديم. ومن قرأها بالجر يقول: لله الحق{3}. (ز) ٤٥٠٠٩- قال مقاتل بن سليمان: <q>﴿هنالك الولاية﴾</q> يعني: السلطان، ليس في ذلك اليوم سلطان غيره، مثل قوله ﷿: <q>﴿والأمر يومئذ لله﴾</q> [الانفطار:١٩]، ليس في ذلك اليوم أمر إلا لله ﷿، والأمر أيضًا في الدنيا، لكن جعل في الدنيا ملوكًا يأمرون. ومن قرأها بفتح الواو، جعلها من الموالاة، <q>﴿هنالك الولاية لله﴾</q> يعني: البعث الذى كفر به فرطس، <q>﴿لله الحق﴾</q> وحده، لا يملكه أحد، ولا ينازعه أحد{4}. (ز) ٤٥٠١٠- عن مبشر بن عبيد، قال: <q>﴿الوَلاية﴾</q>: الدين. و›الوِلايَةُ‹: ما أتولى{5}. (٩/٥٥١) ٤٥٠١١- قال يحيى بن سلّام: قوله: <q>﴿هنالك الولاية لله الحق﴾</q> في الآخرة، هنالك يتولى الله كل عبد، لا يبقى أحد يومئذ إلا تولى الله، فلا يقبل ذلك من المشرك. والحق: اسم من أسماء الله{6}. (ز) <q>﴿هُوَ خَیۡرࣱ ثَوَابࣰا وَخَیۡرٌ عُقۡبࣰا ۝٤٤﴾</q> - تفسير ٤٥٠١٢- قال مقاتل بن سليمان: <q>﴿هو خير ثوابا﴾</q> يعني: أفضل ثوابًا، <q>﴿وخير عقبا﴾</q> يعني: أفضل عاقبة لهذا المؤمن مِن عاقبة هذا الكافر الذي جعل مرجعه إلى النار{4}. (ز) ٤٥٠١٣- قال يحيى بن سلّام: <q>﴿هو خير ثوابا﴾</q> خيرُ مَن أثاب، وخير ثوابًا للمؤمنين من الأوثان لمن عبدها، <q>﴿وخير عقبا﴾</q> وخير من أثاب{6}. (ز) ",footnotes:1:علقه يحيى بن سلام ١/١٨٨.قرأ جمهور القراء بفتح واو <q>﴿الولاية﴾</q>، وقرأ حمزة والكسائي وخلف بكسرها. انظر: النشر ٢/٢٧٧.تفسير يحيى بن سلام ١/١٨٨. والقراءة بخفض <q>﴿الحقِّ﴾</q> هي قراءة الجمهور، وقرأ أبو عمرو والكسائي برفع القاف. انظر: النشر ٢/٣١١.تفسير مقاتل بن سليمان ٢/٥٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/١٨٨.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير يحيى بن سلام ١/١٨٨.
18,45," <q>﴿وَٱضۡرِبۡ لَهُم مَّثَلَ ٱلۡحَیَوٰةِ ٱلدُّنۡیَا كَمَاۤءٍ أَنزَلۡنَـٰهُ مِنَ ٱلسَّمَاۤءِ فَٱخۡتَلَطَ بِهِۦ نَبَاتُ ٱلۡأَرۡضِ﴾</q> - تفسير ٤٥٠١٤- قال مقاتل بن سليمان: <q>﴿واضرب لهم﴾</q> لكفار مكة <q>﴿مثل﴾</q> يعني: شبه <q>﴿الحياة الدنيا كماء أنزلناه من السماء فاختلط به﴾</q> يعني: بالماء <q>﴿نبات الأرض﴾</q>{1}. (ز) <q>﴿فَأَصۡبَحَ هَشِیمࣰا﴾</q> - تفسير ٤٥٠١٥- عن عبد الله بن عباس، في قوله: <q>﴿هشيما﴾</q>، قال: يابِسًا{2}. (ز) ٤٥٠١٦- عن الضحاك بن مزاحم، في قوله: <q>﴿هشيما﴾</q>، قال: كسِيرًا{2}. (ز) ٤٥٠١٧- قال مقاتل بن سليمان: <q>﴿فأصبح﴾</q> النبتُ <q>﴿هشيما﴾</q> يعني: يابسًا{1}. (ز) <q>﴿تَذۡرُوهُ ٱلرِّیَـٰحُۗ﴾</q> - تفسير ٤٥٠١٨- عن عبد الله بن عباس، في قوله: <q>﴿تذروه الرياح﴾</q>، قال: تُثِيره الرياح{5}. (ز) ٤٥٠١٩- قال مقاتل بن سليمان: <q>﴿تذروه الرياح﴾</q>، يقول سبحانه: مَثَل الدنيا كمَثَل النبت، بينما هو أخضر إذ هو قد يبِس وهلك، فكذلك تهلك الدنيا إذا جاءت الآخرة{1}. (ز) ٤٥٠٢٠- قال يحيى بن سلّام: <q>﴿فأصبح هشيما تذروه الرياح﴾</q>، هشَّمته الرياح فأذهبته، فأخبر أنّ الدنيا ذاهبة زائلة كما ذهب ذلك النبات بعد بهجته وحُسنه{7}. (ز) <q>﴿وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ مُّقۡتَدِرًا ۝٤٥﴾</q> - تفسير ٤٥٠٢١- قال مقاتل بن سليمان: <q>﴿وكان الله على كل شيء﴾</q> مِن البعث وغيره <q>﴿مقتدرا﴾</q>{1}٤٠٢٥. (ز) ٤٠٢٥ ذكر ابنُ عطية (٥/٦١٣) أنّ قوله تعالى: <q>﴿وكانَ الله﴾</q> «عبارة للإنسان عن أن الأمر قبل وجود الإنسان هكذا كان إذ كان، إذ نفسه حاكمة بذلك في حال غفلة. هذا قول سيبويه». وعلَّق عليه بقوله: «وهو معنى صحيح». ثم نقل عن الحسن قوله: «كانَ: إخبارٌ عن الحال قبل إيجاد الموجودات، أي: أن القدرة كانت». وعلَّق عليه بقوله: «وهذا أيضًا حسن». ٤٥٠٢٢- قال يحيى بن سلّام: <q>﴿وكان الله على كل شيء مقتدرا﴾</q>: قديرًا{7}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير الثعلبي ٦/١٧٣، وتفسير البغوي ٥/١٧٤.تفسير الثعلبي ٦/١٧٣، وتفسير البغوي ٥/١٧٤.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير البغوي ٥/١٧٤.وذكر محققوه أنها في نسخة أخرى: تديره، وهو كذلك في تفسير الثعلبي ٦/١٧٣، وفي طبعة دار التفسير ١٧/١٤٩:تذريه.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير يحيى بن سلام ١/١٨٨.تفسير مقاتل بن سليمان ٢/٥٨٧.تفسير يحيى بن سلام ١/١٨٨.
