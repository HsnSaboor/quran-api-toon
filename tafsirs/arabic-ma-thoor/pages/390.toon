quran[8]{c,v,t}:
28,36," <q>﴿فَلَمَّا جَاۤءَهُم مُّوسَىٰ بِـَٔایَـٰتِنَا بَیِّنَـٰتࣲ قَالُوا۟ مَا هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّفۡتَرࣰى وَمَا سَمِعۡنَا بِهَـٰذَا فِیۤ ءَابَاۤىِٕنَا ٱلۡأَوَّلِینَ ۝٣٦﴾</q> - تفسير ٥٨٧٤٩- قال مقاتل بن سليمان: <q>﴿فلما جاءهم موسى بآياتنا﴾</q> اليد والعصا <q>﴿بينات﴾</q> يعني: واضحات، التي في «طه» و«الشعراء»، <q>﴿قالوا ما هذا﴾</q> الذي جئت به، يا موسى، <q>﴿إلا سحر مفترى﴾</q> افتريتَه، يا موسى، أنت تَقَوَّلته وهارون <q>﴿و﴾</q>قالوا: <q>﴿ما سمعنا بهذا في آبائنا الأولين﴾</q> يعني: اليد، والعصا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤٥.
28,37," <q>﴿وَقَالَ مُوسَىٰ رَبِّیۤ أَعۡلَمُ بِمَن جَاۤءَ بِٱلۡهُدَىٰ مِنۡ عِندِهِۦ وَمَن تَكُونُ لَهُۥ عَـٰقِبَةُ ٱلدَّارِۚ﴾</q> - تفسير ٥٨٧٥٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿عاقبة الدار﴾</q>: أي: الجنة{1}. (ز) ٥٨٧٥١- قال مقاتل بن سليمان: <q>﴿و﴾</q>لَمّا كذَّبوه بما جاء به؛ <q>﴿قال موسى ربي أعلم بمن جاء بالهدى من عنده﴾</q> فإنِّي جئتُ بالهدى مِن عند الله ﷿، <q>﴿و﴾</q>هو أعلم بـ<q>﴿من تكون له عاقبة الدار﴾</q> يعني: دار الجنة؛ ألنا أو لكم؟{2}. (ز) ٥٨٧٥٢- قال يحيى بن سلّام: قال الله: <q>﴿فلما جاءهم موسى بآياتنا بينات قالوا ما هذا إلا سحر مفترى وما سمعنا بهذا في آبائنا الأولين (٣٦) وقال موسى ربي أعلم بمن جاء بالهدى من عنده﴾</q> أي: أني أنا جئت بالهدى من عنده، <q>﴿ومن تكون له عاقبة الدار﴾</q> دار الآخرة؛ الجنة{3}. (ز) <q>﴿إِنَّهُۥ لَا یُفۡلِحُ ٱلظَّـٰلِمُونَ ۝٣٧﴾</q> - تفسير ٥٨٧٥٣- عن عبد الله بن عباس -من طريق الضحاك- <q>﴿الظالمون﴾</q>: الكافرون{1}. (ز) ٥٨٧٥٤- قال مقاتل بن سليمان: ثم قال: <q>﴿إنه لا يفلح الظالمون﴾</q> في الآخرة، لا يفوز المشركون، يعني: لا يَسْعَدُون{2}. (ز) ٥٨٧٥٥- قال يحيى بن سلّام: <q>﴿إنه لا يفلح الظالمون﴾</q> المشركون، لا يدخلون الجنة، والمفلحون هم أهل الجنة{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٧٨.تفسير مقاتل بن سليمان ٣/٣٤٥.تفسير يحيى بن سلّام ٢/٥٩٣.أخرجه ابن أبي حاتم ٩/٢٩٧٨.تفسير مقاتل بن سليمان ٣/٣٤٥.تفسير يحيى بن سلّام ٢/٥٩٣.
28,38," <q>﴿وَقَالَ فِرۡعَوۡنُ یَـٰۤأَیُّهَا ٱلۡمَلَأُ مَا عَلِمۡتُ لَكُم مِّنۡ إِلَـٰهٍ غَیۡرِی﴾</q> - تفسير ٥٨٧٥٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «كلمتان قالهما فرعون: <q>﴿ما علمت لكم من إله غيري﴾</q>، وقوله: <q>﴿أنا ربكم الأعلى﴾</q>» [النازعات:٢٤]. قال: «كان بينهما أربعون عامًا، <q>﴿فأخذه الله نكال الآخرة والأولى﴾</q>» [النازعات:٢٦]{1}. (١١/٤٦٨) ٥٨٧٥٧- عن عبد الله بن عباس -من طريق الضحاك- قال: لَمّا قال فرعون: <q>﴿يا أيها الملأ ما علمت لكم من إله غيري﴾</q>. قال جبريل: يا ربِّ، طغى عبدُك، فأْذَن لي في هلاكه. قال: يا جبريل، هو عبدي، ولن يسبقني، له أجلٌ قد أجَّلْتُه، حتى يجيء ذلك الأجل. فلما قال: <q>﴿أنا ربكم الأعلى﴾</q> [النازعات:٢٤]؛ قال: يا جبريل، سبقت دعوتُك في عبدي، وقد جاء أوانُ هلاكه{2}. (١١/٤٦٨) ٥٨٧٥٨- تفسير الحسن البصري: قوله ﷿: <q>﴿وقال فرعون يأيها الملأ ما علمت لكم من إله غيري﴾</q>، تَعَمَّد الكذب{3}. (ز) ٥٨٧٥٩- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: لما قال فرعون لقومه: <q>﴿ما علمت لكم من إله غيري﴾</q> نشر جبريلُ أجنحة العذابِ غضبًا لله ﷿، فأوحى الله ﷿ إليه: أن يا جبريل، إنّما يعجِّل بالعقوبة مَن يخاف الفَوْت. قال: فأمهله ﷿ بعد هذه المقالةِ أربعين عامًا، حتى قال: <q>﴿أنا ربكم الأعلى﴾</q> [النازعات:٢٤]. فذلك قوله ﷿: <q>﴿فأخذه الله نكال الآخرة والأولى﴾</q> [النازعات:٢٥]: قوله الأول، وقوله الآخر. ثم أغرقه الله ﷿ وجنوده{4}. (ز) ٥٨٧٦٠- قال مقاتل بن سليمان: <q>﴿وقال فرعون يا أيها الملأ﴾</q> يعني: الأشراف مِن قومه، <q>﴿ما علمت لكم من إله غيري﴾</q> هذا القول مِن فرعون كُفْرٌ{5}. (ز) <q>﴿فَأَوۡقِدۡ لِی یَـٰهَـٰمَـٰنُ عَلَى ٱلطِّینِ﴾</q> - تفسير ٥٨٧٦١- عن سعيد بن جبير، في قوله: <q>﴿فأوقد لي يا هامان على الطين﴾</q>، قال: أوْقِد على الطين حتى يكون آجُرًّا{6}{7}. (١١/٤٦٩) ٥٨٧٦٢- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿فأوقد لي يا هامان على الطين﴾</q>، قال: على المَدَر يكون لَبِنًا مطبوخًا{8}. (١١/٤٦٩) ٥٨٧٦٣- عن مجاهد بن جبر -من طريق سفيان بن عيينة، عن بعضهم- <q>﴿فأوقد لي يا هامان على الطين فاجعل لي صرحا﴾</q>، قال: هو الآجُرُّ{9}. (ز) ٥٨٧٦٤- قال مقاتل بن سليمان: <q>﴿فأوقد لي ياهامان على الطين فاجعل لي صرحا﴾</q>، يقول: أوقِدِ النارَ على الطين حتى يصير اللَّبِنُ آجُرًّا، وكان فرعون أوَّلَ مَن طبخ الآجُرَّ وبناه{5}. (ز) ٥٨٧٦٥- عن عبد الملك ابن جريج -من طريق ابن المبارك- في قوله: <q>﴿فأوقد لي يا هامان على الطين﴾</q>، قال: يعني: على المدر. يقول: اطبخه، يعني: الآجُرَّ{11}. (ز) ٥٨٧٦٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿فأوقد لي يا هامان على الطين﴾</q>، قال: المطبوخ الذي يُوقَد عليه هو مِن طينٍ يبنون به البنيان{12}. (ز) ٥٨٧٦٧- قال يحيى بن سلّام: <q>﴿فأوقد لي يا هامان على الطين﴾</q>، أي: فاطبخ لي آجرًّا فكان أول [من] عمل الآجر {13}. (ز) <q>﴿فَٱجۡعَل لِّی صَرۡحࣰا﴾</q> - تفسير ٥٨٧٦٨- قال مقاتل بن سليمان: <q>﴿فاجعل لي صرحا﴾</q>، يعني: قصرًا طويلًا{5}. (ز) ٥٨٧٦٩- قال يحيى بن سلّام: <q>﴿فاجعل لي صرحا﴾</q>، أي: فابنِ لي صَرْحًا{13}. (ز) <q>﴿فَٱجۡعَل لِّی صَرۡحࣰا﴾</q> - آثار متعلقة بالآية ٥٨٧٧٠- عن إبراهيم النخعي -من طريق منصور- قال: <q>﴿يا هامانُ ابْنِ لِي صَرْحًا﴾</q> [غافر:٣٦]، فكانوا يكرهون أن يبنوا الآجُرَّ، ويجعلوه في القبور{9}. (ز) ٥٨٧٧١- عن قتادة بن دعامة -من طريق سعيد- قال: كان فرعونُ أولَ من طبخ الآجُرَّ، وصُنِع له الصَّرْح{17}. (١١/٤٦٩) ٥٨٧٧٢- عن عبد الملك ابن جريج -من طريق حجاج- قال: فرعون أول مَن أمر بصنعة الآجُرِّ وبنائه{18}. (١١/٤٦٩) ٥٨٧٧٣- عن أسد، عن خالد بن عبد الله، عن مُحَدِّث حدَّثه، قال: كان هامان نَبَطِيًّا{19}. (١١/٤٦٩) <q>﴿لَّعَلِّیۤ أَطَّلِعُ إِلَىٰۤ إِلَـٰهِ مُوسَىٰ وَإِنِّی لَأَظُنُّهُۥ مِنَ ٱلۡكَـٰذِبِینَ ۝٣٨﴾</q> - تفسير ٥٨٧٧٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا بنى له الصرحَ ارتقى فوقه، فأمر بنشابة، فرمى بها نحو السماء، فرُدَّت إليه وهي مُتَلَطِّخَةٌ دمًا، فقال: قتلتُ إلهَ موسى{20}. (١١/٤٦٩) ٥٨٧٧٥- قال مقاتل بن سليمان: <q>﴿لعلي أطلع إلى إله موسى﴾</q>، فبنى، وكان مِلاطُه{21} خَبَث{22} القوارير، فكان الرجلُ لا يستطيع القيامَ عليه مخافة أن تنسفه الريح، ثم قال فرعون: فـــ<q>﴿أطلع إلى إله موسى وإني لأظنه﴾</q> يقول: إني لَأحسبُ موسى <q>﴿من الكاذبين﴾</q> بما يقول: إنّ في السماء إلهًا{5}. (ز) ٥٨٧٧٦- قال يحيى بن سلّام: <q>﴿لعلي أطلع إلى إله موسى وإني لأظنه من الكاذبين﴾</q>، فبنى له صرحًا عاليًا، وقد علِم فرعونُ أنّ موسى رسول الله، وهذا القول منه كذب. قال الله ﷿: <q>﴿وجحدوا بها واستيقنتها أنفسهم ظلما وعلوا﴾</q> [النمل:١٤]. قال قتادة: والجحدُ لا يكون إلا مِن بعد المعرفة{13}. (ز) ",footnotes:1:أخرجه تمام في فوائده ١/٣٤٦ (٨٨٨)، وابن عساكر في تاريخه ٥٢/٢٤٧-٢٤٨. قال الألباني في الضعيفة ٩/١١٧ (٤١١٧): «ضعيف».أخرجه ابن أبي حاتم ٩/٢٩٧٩، ٣٠٦١.علقه يحيى بن سلّام ٢/٥٩٣.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٩٥ (٢٤٤)-.تفسير مقاتل بن سليمان ٣/٣٤٥.الآجُر: الطِّين المطبوخ. اللسان (أجر).عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٥٤، وابن أبي حاتم ٩/٢٩٧٩. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٤٧.تفسير مقاتل بن سليمان ٣/٣٤٥.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٢٩-.أخرجه ابن جرير ١٨/٢٥٥، وابن أبي حاتم ٩/٢٩٧٩ من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.تفسير مقاتل بن سليمان ٣/٣٤٥.تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.أخرجه إسحاق البستي في تفسيره ص٤٧.أخرجه ابن جرير ١٨/٢٥٥ مختصرًا، وابن أبي حاتم ٩/٢٩٧٩، وأخرجه عبد الرزاق ٢/٩١ من طريق معمر بلفظ: بلغني: أنّه أول من طبخ الآجُر. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٢٥٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عبد الحكم في فتوح مصر ص٧.أخرجه ابن جرير ١٨/٢٥٦، وابن أبي حاتم ٩/٢٩٧٩.المِلاط: الطِّين الذي يُجْعَل بين سافَيِ البِناء، يُمْلَط به الحائط: أي يُخْلَط. النهاية (ملط).الخَبَث: ما تلقيه النار مِن الذهب والفضة والحديد وغيرها. النهاية واللسان (خبث).تفسير مقاتل بن سليمان ٣/٣٤٥.تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.
28,39," <q>﴿وَٱسۡتَكۡبَرَ هُوَ وَجُنُودُهُۥ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّ وَظَنُّوۤا۟ أَنَّهُمۡ إِلَیۡنَا لَا یُرۡجَعُونَ ۝٣٩﴾</q> - تفسير ٥٨٧٧٧- عن مجاهد بن جبر -من طريق جابر- قال: ما كان مِن ظنٍّ في القرآن فهو يقين{1}. (ز) ٥٨٧٧٨- قال مقاتل بن سليمان: <q>﴿واستكبر﴾</q> فرعونُ <q>﴿هو وجنوده﴾</q> عن الإيمان <q>﴿في الأرض بغير الحق﴾</q> يعني: بالمعاصي، <q>﴿وظنوا﴾</q> يقول: وحسبوا <q>﴿أنهم إلينا لا يرجعون﴾</q> أحياءً بعد الموت في الآخرة{2}. (ز) ٥٨٧٧٩- قال يحيى بن سلّام: <q>﴿واستكبر هو وجنوده في الأرض بغير الحق وظنوا أنهم إلينا لا يرجعون﴾</q> يوم القيامة{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٨٠. وأورده قبل ذلك ٦/١٩٠٥ في تفسير قوله تعالى: <q>﴿وظَنُّوا أنْ لا مَلْجَأَ مِنَ اللَّهِ إلّا إلَيْهِ﴾</q> [التوبة:١١٨]، وتفسير قوله تعالى: <q>﴿وظَنُّوا أنَّهُمْ أُحِيطَ بِهِمْ﴾</q> [يونس: ٢٢] ٦/١٩٣٨.تفسير مقاتل بن سليمان ٣/٣٤٦.تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.
28,40," <q>﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ فِی ٱلۡیَمِّۖ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلظَّـٰلِمِینَ ۝٤٠﴾</q> - تفسير ٥٨٧٨٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فنبذناهم في اليم﴾</q>، قال: اليم: بحرٌ، يُقال له: إساف، مِن وراء مصر، غرَّقهم الله فيه{1}. (١١/٤٧٠) ٥٨٧٨١- قال مقاتل بن سليمان: <q>﴿فأخذناه وجنوده فنبذناهم في اليم﴾</q> يعني: فقذفناهم في نهر النيل الذى بمصر، <q>﴿فانظر كيف كان عاقبة الظالمين﴾</q> يعني: المشركين أهل مصر، كان عاقبتهم الغرق{2}. (ز) ٥٨٧٨٢- قال يحيى بن سلّام: <q>﴿فأخذناه وجنوده فنبذناهم في اليم﴾</q> في البحر. وقد فسرنا ذلك في غير هذه السورة. قال: <q>﴿فانظر﴾</q> يا محمد <q>﴿كيف كان عاقبة الظالمين﴾</q> أي: دمَّر الله عليهم، ثم صيَّرهم إلى النار{3}٤٩٦٢. (ز) ٤٩٦٢ اختُلِف هل كان إغراقهم في البحر، أم في نيل مصر؟ وذكر ابنُ عطية (٦/٥٩٤) أن القول بأنه بحر القلزم هو قول الأكثرين، وعلَّق بأنّه: «أشهر». ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٨٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٤٦.تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.
28,41," <q>﴿وَجَعَلۡنَـٰهُمۡ أَىِٕمَّةࣰ یَدۡعُونَ إِلَى ٱلنَّارِۖ وَیَوۡمَ ٱلۡقِیَـٰمَةِ لَا یُنصَرُونَ ۝٤١﴾</q> - تفسير ٥٨٧٨٣- عن مجاهد بن جبر -من طريق زيد بن أسلم، والحجاج بن أرطاة- في قوله: <q>﴿وجعلناهم أئمة يدعون إلى النار﴾</q>، قال: جعلهم الله أئِمَّةً يدعون إلى المعاصي{1}. (١١/٤٧٠) ٥٨٧٨٤- قال مقاتل بن سليمان: <q>﴿وجعلناهم أئمة﴾</q> يعني: قادَةً في الشرك <q>﴿يدعون إلى النار﴾</q> يعني: يدعون إلى الشرك، وجعل فرعون والملأ قادة في الشرك، وأتبعناهم أهل مصر، <q>﴿ويوم القيامة لا ينصرون﴾</q> يعني: لا يُمنَعون من العذاب{2}. (ز) ٥٨٧٨٥- قال يحيى بن سلّام: <q>﴿وجعلناهم أئمة يدعون إلى النار﴾</q> يتبعهم مَن بعدهم مِن الكفار{3}. (ز) <q>﴿وَجَعَلۡنَـٰهُمۡ أَىِٕمَّةࣰ یَدۡعُونَ إِلَى ٱلنَّارِۖ وَیَوۡمَ ٱلۡقِیَـٰمَةِ لَا یُنصَرُونَ ۝٤١﴾</q> - آثار متعلقة بالآية ٥٨٧٨٦- عن عبد الله بن عباس -من طريق علي-: ولا تجعلنا أئمةَ ضلالة؛ لأنه قال لأهل السعادة: <q>﴿وجَعَلْناهُمْ أئِمَّةً يَهْدُونَ بِأَمْرِنا﴾</q> [الأنبياء:٧٣]، وقال لأهل الشقاوة: <q>﴿وجعلناهم أئمة يدعون إلى النار﴾</q>{1}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٨٠.تفسير مقاتل بن سليمان ٣/٣٤٦.تفسير يحيى بن سلّام ٢/٥٩٤.أخرجه ابن أبي حاتم ٩/٢٩٨٠.
28,42," <q>﴿وَأَتۡبَعۡنَـٰهُمۡ فِی هَـٰذِهِ ٱلدُّنۡیَا لَعۡنَةࣰۖ وَیَوۡمَ ٱلۡقِیَـٰمَةِ هُم مِّنَ ٱلۡمَقۡبُوحِینَ ۝٤٢﴾</q> - تفسير ٥٨٧٨٧- قال عبد الله بن عباس: مِن المُشَوَّهين بسواد الوجوه، وزُرقَة العيون{1}. (ز) ٥٨٧٨٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأتبعناهم في هذه الدنيا لعنة ويوم القيامة﴾</q>، قال: لُعِنوا في الدنيا والآخرة. هو كقوله: <q>﴿وأتبعوا في هذه لعنة ويوم القيامة، بئس الرفد المرفود﴾</q> [هود:٩٩]{2}. (١١/٤٧٠) ٥٨٧٨٩- عن إسماعيل السُّدِّيّ، قوله: <q>﴿وأتبعناهم في هذه الدنيا لعنة﴾</q>، قال: لم يُبعَث نبيٌّ بعد فرعون إلا لُعِن على لسانه، يوم القيامة ترفد لعنة أخرى في النار{3}. (ز) ٥٨٧٩٠- قال مقاتل بن سليمان: <q>﴿وأتبعناهم في هذه الدنيا لعنة﴾</q> يعني: الغرق، <q>﴿ويوم القيامة﴾</q> في النار <q>﴿هم من المقبوحين﴾</q>{4}. (ز) ٥٨٧٩١- عن عبد الملك ابن جريج -من طريق حجاج- في قوله: <q>﴿وأتبعناهم في هذه الدنيا لعنة ويوم القيامة﴾</q> لعنة أخرى، ثم استقبل فقال: <q>﴿هم من المقبوحين﴾</q>{5}. (١١/٤٧٠) ٥٨٧٩٢- قال يحيى بن سلّام: قال: <q>﴿وأتبعناهم في هذه الدنيا لعنة﴾</q> العذاب الذي عذَّبهم الله به الغرق. قال: <q>﴿ويوم القيامة هم من المقبوحين﴾</q> في النار، وأهل النار مقبوحون مُشَوَّهون؛ سود، زرق، حبن{6}، كأنّ رؤوسهم آجام القصب، كالحون، شَفَةُ أحدهم السفلى ساقطةٌ على صدره، وشفته العليا قالِصَةٌ قد غطَّت وجهه، رأسُ أحدهم مثل الجبل العظيم، وضِرْسُه مثل أحد، وأنيابه كالصياصي -وهي الجبال-، وغلظ جلده سبعون ذراعًا -وبعضهم يقول: أربعون-، يشتد الدُّودُ ما بين جلده ولحمه كما يشتد الوحوش في البرية، وفخذه مسيرة يومين.= (ز) ٥٨٧٩٣- وقال ابن مسعود: وإنِّي أراه يَشْغَلُ مِن جهنم مثلَ ما بيني وبين المدينة. وهو بالكوفة{7}. (ز) ",footnotes:1:تفسير الثعلبي ٧/٢٥١، وتفسير البغوي ٦/٢٠٩.أخرجه ابن جرير ١٨/٢٥٨، وابن أبي حاتم ٩/٢٩٨٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٨٠.تفسير مقاتل بن سليمان ٣/٣٤٦.أخرجه ابن جرير ١٨/٢٥٨. وعزاه السيوطي إلى ابن المنذر.الحبن: الكبير البطن. لسان العرب (حبن).تفسير يحيى بن سلّام ٢/٥٩٤.
28,43," <q>﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ مِنۢ بَعۡدِ مَاۤ أَهۡلَكۡنَا ٱلۡقُرُونَ ٱلۡأُولَىٰ﴾</q> - تفسير ٥٨٧٩٤- عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «ما أهلك الله قومًا، ولا قرنًا، ولا أمة، ولا أهل قرية، بعذاب من السماء منذ أنزل التوراة على وجه الأرض، غير القرية التي مُسِخَتْ قِرَدةً، ألم تر إلى قوله: <q>﴿ولقد آتينا موسى الكتاب من بعد ما أهلكنا القرون الأولى﴾</q>»{1}٤٩٦٣. (١١/٤٧١) ٤٩٦٣ ساق ابنُ عطية (٦/٥٩٥) هذا الحديث، ثم علَّق بقوله: «أي: الذين تعدَّوْا في السبت، وهذا التعذيب مِن سبب شرع موسى؛ فكأنه لا يُنقص فضيلة التوراة برفع العذاب عن الأرض». ٥٨٧٩٥- عن أبي سعيد الخدري -من طريق أبي نضرة-، موقوفًا{2}. (١١/٤٧١) ٥٨٧٩٦- قال مقاتل بن سليمان: <q>﴿ولقد آتينا موسى الكتاب من بعد مآ أهلكنا﴾</q> بالعذاب في الدنيا <q>﴿القرون الأولى﴾</q> يعني: نوحًا، وعادًا، وقوم إبراهيم، وقوم لوط، وقوم شعيب، وغيرهم، كانوا قبل موسى{3}. (ز) ٥٨٧٩٧- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولقد آتينا موسى الكتاب﴾</q> التوراة ... وقوله: <q>﴿من بعد ما أهلكنا القرون الأولى﴾</q> قرنًا مِن بعد قرن. كقوله على مقرأ هذا الحرف: <q>﴿وكذلك أخذ ربك إذا أخذ القرى وهي ظالمة﴾</q> [هود:١٠٢]{4}. (ز) <q>﴿بَصَاۤىِٕرَ لِلنَّاسِ وَهُدࣰى وَرَحۡمَةࣰ لَّعَلَّهُمۡ یَتَذَكَّرُونَ ۝٤٣﴾</q> - تفسير ٥٨٧٩٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بصائر للناس﴾</q>، قال: بيِّنة{5}. (١١/٤٧١) ٥٨٧٩٩- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿بصآئر للناس﴾</q> يقول: في هلاك الأُمَم الخالية بصيرة لبنى إسرائيل، <q>﴿وهدى﴾</q> يعني: التوراة هدًى مِن الضلالة لِمَن عمل بها، <q>﴿ورحمة﴾</q> لِمَن آمن بها مِن العذاب، <q>﴿لعلهم﴾</q> يعني: لكي <q>﴿يتذكرون﴾</q> فيؤمنوا بتوحيد الله ﷿{3}. (ز) ٥٨٨٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ- قال: البصائر: الهدى؛ بصائر ما في قلوبهم لذنوبهم، وليست ببصائر الرؤوس. وقرأ: <q>﴿فَإنَّها لا تَعْمى الأَبْصارُ ولَكِنْ تَعْمى القُلُوبُ الَّتِي فِي الصُّدُورِ﴾</q> [الحج:٤٦]، وقال: هذا الدين بصره وسمعه في هذا القلب{7}. (١١/٤٧١) ٥٨٨٠١- قال يحيى بن سلّام: <q>﴿بصائر للناس وهدى ورحمة لعلهم يتذكرون﴾</q>، يعني: يتفكروا، فكانت التوراة أولَ كتاب نزل فيه الفرائضُ والحدودُ والأحكامُ{4}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٤٤٢ (٣٥٣٤)، وابن جرير ١٨/٢٥٩، وابن أبي حاتم ٩/٢٩٨١ (١٦٩٢٨)، والثعلبي ٧/٢٥١. قال الحاكم: «صحيح على شرط الشيخين، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٨٨ (١١٢٥٣): «رواه البزار موقوفًا ومرفوعًا، ورجالهما رجال الصحيح». وأورده الألباني في الصحيحة ٥/٣٢٧ (٢٢٥٨).أخرجه البزار (٢٢٤٧ - كشف)، وابن جرير ١٨/٢٥٩، وابن أبي حاتم ٩/٢٩٨١ من وجه آخر.تفسير مقاتل بن سليمان ٣/٣٤٦.تفسير يحيى بن سلّام ٢/٥٩٥.أخرجه ابن أبي حاتم ٩/٢٩٨١.تفسير مقاتل بن سليمان ٣/٣٤٦.أخرجه ابن أبي حاتم ٩/٢٩٨١ وفيه بلفظ: ما في قلوبهم لدينهم.تفسير يحيى بن سلّام ٢/٥٩٥.
