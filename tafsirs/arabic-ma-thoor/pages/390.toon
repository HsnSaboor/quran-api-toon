quran[8]{c,v,t}:
  28,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَاۤءَهُم مُّوسَىٰ بِـَٔایَـٰتِنَا بَیِّنَـٰتࣲ قَالُوا۟ مَا هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّفۡتَرࣰى وَمَا سَمِعۡنَا بِهَـٰذَا فِیۤ ءَابَاۤىِٕنَا ٱلۡأَوَّلِینَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما جاءهم موسى بآياتنا﴾</span> اليد والعصا <span class="qpc-hafs">﴿بينات﴾</span> يعني: واضحات، التي في «طه» و«الشعراء»، <span class="qpc-hafs">﴿قالوا ما هذا﴾</span> الذي جئت به، يا موسى، <span class="qpc-hafs">﴿إلا سحر مفترى﴾</span> افتريتَه، يا موسى، أنت تَقَوَّلته وهارون <span class="qpc-hafs">﴿و﴾</span>قالوا: <span class="qpc-hafs">﴿ما سمعنا بهذا في آبائنا الأولين﴾</span> يعني: اليد، والعصا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤٥.
  28,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ مُوسَىٰ رَبِّیۤ أَعۡلَمُ بِمَن جَاۤءَ بِٱلۡهُدَىٰ مِنۡ عِندِهِۦ وَمَن تَكُونُ لَهُۥ عَـٰقِبَةُ ٱلدَّارِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿عاقبة الدار﴾</span>: أي: الجنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>لَمّا كذَّبوه بما جاء به؛ <span class="qpc-hafs">﴿قال موسى ربي أعلم بمن جاء بالهدى من عنده﴾</span> فإنِّي جئتُ بالهدى مِن عند الله ﷿، <span class="qpc-hafs">﴿و﴾</span>هو أعلم بـ<span class="qpc-hafs">﴿من تكون له عاقبة الدار﴾</span> يعني: دار الجنة؛ ألنا أو لكم؟{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿فلما جاءهم موسى بآياتنا بينات قالوا ما هذا إلا سحر مفترى وما سمعنا بهذا في آبائنا الأولين (٣٦) وقال موسى ربي أعلم بمن جاء بالهدى من عنده﴾</span> أي: أني أنا جئت بالهدى من عنده، <span class="qpc-hafs">﴿ومن تكون له عاقبة الدار﴾</span> دار الآخرة؛ الجنة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَا یُفۡلِحُ ٱلظَّـٰلِمُونَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿الظالمون﴾</span>: الكافرون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنه لا يفلح الظالمون﴾</span> في الآخرة، لا يفوز المشركون، يعني: لا يَسْعَدُون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنه لا يفلح الظالمون﴾</span> المشركون، لا يدخلون الجنة، والمفلحون هم أهل الجنة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٧٨.|2:تفسير مقاتل بن سليمان ٣/٣٤٥.|3:تفسير يحيى بن سلّام ٢/٥٩٣.|4:أخرجه ابن أبي حاتم ٩/٢٩٧٨.|5:تفسير مقاتل بن سليمان ٣/٣٤٥.|6:تفسير يحيى بن سلّام ٢/٥٩٣.
  28,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ فِرۡعَوۡنُ یَـٰۤأَیُّهَا ٱلۡمَلَأُ مَا عَلِمۡتُ لَكُم مِّنۡ إِلَـٰهٍ غَیۡرِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٥٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>كلمتان قالهما فرعون: <span class="qpc-hafs">﴿ما علمت لكم من إله غيري﴾</span>، وقوله: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span></b>» [النازعات:٢٤]. قال: «<b>كان بينهما أربعون عامًا، <span class="qpc-hafs">﴿فأخذه الله نكال الآخرة والأولى﴾</span></b>» [النازعات:٢٦]{1}. (١١/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: لَمّا قال فرعون: <span class="qpc-hafs">﴿يا أيها الملأ ما علمت لكم من إله غيري﴾</span>. قال جبريل: يا ربِّ، طغى عبدُك، فأْذَن لي في هلاكه. قال: يا جبريل، هو عبدي، ولن يسبقني، له أجلٌ قد أجَّلْتُه، حتى يجيء ذلك الأجل. فلما قال: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span> [النازعات:٢٤]؛ قال: يا جبريل، سبقت دعوتُك في عبدي، وقد جاء أوانُ هلاكه{2}. (١١/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥٨<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: قوله ﷿: <span class="qpc-hafs">﴿وقال فرعون يأيها الملأ ما علمت لكم من إله غيري﴾</span>، تَعَمَّد الكذب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٥٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- قال: لما قال فرعون لقومه: <span class="qpc-hafs">﴿ما علمت لكم من إله غيري﴾</span> نشر جبريلُ أجنحة العذابِ غضبًا لله ﷿، فأوحى الله ﷿ إليه: أن يا جبريل، إنّما يعجِّل بالعقوبة مَن يخاف الفَوْت. قال: فأمهله ﷿ بعد هذه المقالةِ أربعين عامًا، حتى قال: <span class="qpc-hafs">﴿أنا ربكم الأعلى﴾</span> [النازعات:٢٤]. فذلك قوله ﷿: <span class="qpc-hafs">﴿فأخذه الله نكال الآخرة والأولى﴾</span> [النازعات:٢٥]: قوله الأول، وقوله الآخر. ثم أغرقه الله ﷿ وجنوده{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال فرعون يا أيها الملأ﴾</span> يعني: الأشراف مِن قومه، <span class="qpc-hafs">﴿ما علمت لكم من إله غيري﴾</span> هذا القول مِن فرعون كُفْرٌ{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡقِدۡ لِی یَـٰهَـٰمَـٰنُ عَلَى ٱلطِّینِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين﴾</span>، قال: أوْقِد على الطين حتى يكون آجُرًّا{6}{7}. (١١/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين﴾</span>، قال: على المَدَر يكون لَبِنًا مطبوخًا{8}. (١١/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان بن عيينة، عن بعضهم- <span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين فاجعل لي صرحا﴾</span>، قال: هو الآجُرُّ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأوقد لي ياهامان على الطين فاجعل لي صرحا﴾</span>، يقول: أوقِدِ النارَ على الطين حتى يصير اللَّبِنُ آجُرًّا، وكان فرعون أوَّلَ مَن طبخ الآجُرَّ وبناه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق ابن المبارك- في قوله: <span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين﴾</span>، قال: يعني: على المدر. يقول: اطبخه، يعني: الآجُرَّ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين﴾</span>، قال: المطبوخ الذي يُوقَد عليه هو مِن طينٍ يبنون به البنيان{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين﴾</span>، أي: فاطبخ لي آجرًّا فكان أول [من] عمل الآجر {13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱجۡعَل لِّی صَرۡحࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاجعل لي صرحا﴾</span>، يعني: قصرًا طويلًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٦٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فاجعل لي صرحا﴾</span>، أي: فابنِ لي صَرْحًا{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱجۡعَل لِّی صَرۡحࣰا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٧٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿يا هامانُ ابْنِ لِي صَرْحًا﴾</span> [غافر:٣٦]، فكانوا يكرهون أن يبنوا الآجُرَّ، ويجعلوه في القبور{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: كان فرعونُ أولَ من طبخ الآجُرَّ، وصُنِع له الصَّرْح{17}. (١١/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قال: فرعون أول مَن أمر بصنعة الآجُرِّ وبنائه{18}. (١١/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧٣<span class="dash">-</span></span> عن أسد، عن خالد بن عبد الله، عن مُحَدِّث حدَّثه، قال: كان هامان نَبَطِيًّا{19}. (١١/٤٦٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّعَلِّیۤ أَطَّلِعُ إِلَىٰۤ إِلَـٰهِ مُوسَىٰ وَإِنِّی لَأَظُنُّهُۥ مِنَ ٱلۡكَـٰذِبِینَ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٧٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا بنى له الصرحَ ارتقى فوقه، فأمر بنشابة، فرمى بها نحو السماء، فرُدَّت إليه وهي مُتَلَطِّخَةٌ دمًا، فقال: قتلتُ إلهَ موسى{20}. (١١/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلي أطلع إلى إله موسى﴾</span>، فبنى، وكان مِلاطُه{21} خَبَث{22} القوارير، فكان الرجلُ لا يستطيع القيامَ عليه مخافة أن تنسفه الريح، ثم قال فرعون: فـــ<span class="qpc-hafs">﴿أطلع إلى إله موسى وإني لأظنه﴾</span> يقول: إني لَأحسبُ موسى <span class="qpc-hafs">﴿من الكاذبين﴾</span> بما يقول: إنّ في السماء إلهًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لعلي أطلع إلى إله موسى وإني لأظنه من الكاذبين﴾</span>، فبنى له صرحًا عاليًا، وقد علِم فرعونُ أنّ موسى رسول الله، وهذا القول منه كذب. قال الله ﷿: <span class="qpc-hafs">﴿وجحدوا بها واستيقنتها أنفسهم ظلما وعلوا﴾</span> [النمل:١٤]. قال <span class="name-2">قتادة</span>: والجحدُ لا يكون إلا مِن بعد المعرفة{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه تمام في فوائده ١/٣٤٦ (٨٨٨)، وابن عساكر في تاريخه ٥٢/٢٤٧-٢٤٨.</p><p>قال الألباني في الضعيفة ٩/١١٧ (٤١١٧): «ضعيف».|2:أخرجه ابن أبي حاتم ٩/٢٩٧٩، ٣٠٦١.|3:علقه يحيى بن سلّام ٢/٥٩٣.|4:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٩٥ (٢٤٤)-.|5:تفسير مقاتل بن سليمان ٣/٣٤٥.|6:الآجُر: الطِّين المطبوخ. اللسان (أجر).|7:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:أخرجه ابن جرير ١٨/٢٥٤، وابن أبي حاتم ٩/٢٩٧٩. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه إسحاق البستي في تفسيره ص٤٧.|10:تفسير مقاتل بن سليمان ٣/٣٤٥.|11:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥٢٩-.|12:أخرجه ابن جرير ١٨/٢٥٥، وابن أبي حاتم ٩/٢٩٧٩ من طريق أصبغ.|13:تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.|14:تفسير مقاتل بن سليمان ٣/٣٤٥.|15:تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.|16:أخرجه إسحاق البستي في تفسيره ص٤٧.|17:أخرجه ابن جرير ١٨/٢٥٥ مختصرًا، وابن أبي حاتم ٩/٢٩٧٩، وأخرجه عبد الرزاق ٢/٩١ من طريق معمر بلفظ: بلغني: أنّه أول من طبخ الآجُر. وعزاه السيوطي إلى عبد بن حميد.|18:أخرجه ابن جرير ١٨/٢٥٥. وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن عبد الحكم في فتوح مصر ص٧.|20:أخرجه ابن جرير ١٨/٢٥٦، وابن أبي حاتم ٩/٢٩٧٩.|21:المِلاط: الطِّين الذي يُجْعَل بين سافَيِ البِناء، يُمْلَط به الحائط: أي يُخْلَط. النهاية (ملط).|22:الخَبَث: ما تلقيه النار مِن الذهب والفضة والحديد وغيرها. النهاية واللسان (خبث).|23:تفسير مقاتل بن سليمان ٣/٣٤٥.|24:تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.
  28,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱسۡتَكۡبَرَ هُوَ وَجُنُودُهُۥ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّ وَظَنُّوۤا۟ أَنَّهُمۡ إِلَیۡنَا لَا یُرۡجَعُونَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- قال: ما كان مِن ظنٍّ في القرآن فهو يقين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واستكبر﴾</span> فرعونُ <span class="qpc-hafs">﴿هو وجنوده﴾</span> عن الإيمان <span class="qpc-hafs">﴿في الأرض بغير الحق﴾</span> يعني: بالمعاصي، <span class="qpc-hafs">﴿وظنوا﴾</span> يقول: وحسبوا <span class="qpc-hafs">﴿أنهم إلينا لا يرجعون﴾</span> أحياءً بعد الموت في الآخرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿واستكبر هو وجنوده في الأرض بغير الحق وظنوا أنهم إلينا لا يرجعون﴾</span> يوم القيامة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٨٠. وأورده قبل ذلك ٦/١٩٠٥ في تفسير قوله تعالى: <span class="qpc-hafs">﴿وظَنُّوا أنْ لا مَلْجَأَ مِنَ اللَّهِ إلّا إلَيْهِ﴾</span> [التوبة:١١٨]، وتفسير قوله تعالى: <span class="qpc-hafs">﴿وظَنُّوا أنَّهُمْ أُحِيطَ بِهِمْ﴾</span> [يونس: ٢٢] ٦/١٩٣٨.|2:تفسير مقاتل بن سليمان ٣/٣٤٦.|3:تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.
  28,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُ وَجُنُودَهُۥ فَنَبَذۡنَـٰهُمۡ فِی ٱلۡیَمِّۖ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلظَّـٰلِمِینَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فنبذناهم في اليم﴾</span>، قال: اليم: بحرٌ، يُقال له: إساف، مِن وراء مصر، غرَّقهم الله فيه{1}. (١١/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخذناه وجنوده فنبذناهم في اليم﴾</span> يعني: فقذفناهم في نهر النيل الذى بمصر، <span class="qpc-hafs">﴿فانظر كيف كان عاقبة الظالمين﴾</span> يعني: المشركين أهل مصر، كان عاقبتهم الغرق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأخذناه وجنوده فنبذناهم في اليم﴾</span> في البحر. وقد فسرنا ذلك في غير هذه السورة. قال: <span class="qpc-hafs">﴿فانظر﴾</span> يا محمد <span class="qpc-hafs">﴿كيف كان عاقبة الظالمين﴾</span> أي: دمَّر الله عليهم، ثم صيَّرهم إلى النار{3}<span class=comment-ref>٤٩٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٦٢</span> اختُلِف هل كان إغراقهم في البحر، أم في نيل مصر؟ و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٩٤) أن القول بأنه بحر القلزم هو قول الأكثرين، و<span class="comment-type-4">علَّق</span> بأنّه: «أشهر».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٨٠. وعزاه السيوطي إلى عبد بن حميد.|2:تفسير مقاتل بن سليمان ٣/٣٤٦.|3:تفسير يحيى بن سلّام ٢/٥٩٣-٥٩٤.
  28,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَـٰهُمۡ أَىِٕمَّةࣰ یَدۡعُونَ إِلَى ٱلنَّارِۖ وَیَوۡمَ ٱلۡقِیَـٰمَةِ لَا یُنصَرُونَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق زيد بن أسلم، والحجاج بن أرطاة- في قوله: <span class="qpc-hafs">﴿وجعلناهم أئمة يدعون إلى النار﴾</span>، قال: جعلهم الله أئِمَّةً يدعون إلى المعاصي{1}. (١١/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلناهم أئمة﴾</span> يعني: قادَةً في الشرك <span class="qpc-hafs">﴿يدعون إلى النار﴾</span> يعني: يدعون إلى الشرك، وجعل فرعون والملأ قادة في الشرك، وأتبعناهم أهل مصر، <span class="qpc-hafs">﴿ويوم القيامة لا ينصرون﴾</span> يعني: لا يُمنَعون من العذاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجعلناهم أئمة يدعون إلى النار﴾</span> يتبعهم مَن بعدهم مِن الكفار{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَـٰهُمۡ أَىِٕمَّةࣰ یَدۡعُونَ إِلَى ٱلنَّارِۖ وَیَوۡمَ ٱلۡقِیَـٰمَةِ لَا یُنصَرُونَ ۝٤١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي-: ولا تجعلنا أئمةَ ضلالة؛ لأنه قال لأهل السعادة: <span class="qpc-hafs">﴿وجَعَلْناهُمْ أئِمَّةً يَهْدُونَ بِأَمْرِنا﴾</span> [الأنبياء:٧٣]، وقال لأهل الشقاوة: <span class="qpc-hafs">﴿وجعلناهم أئمة يدعون إلى النار﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٨٠.|2:تفسير مقاتل بن سليمان ٣/٣٤٦.|3:تفسير يحيى بن سلّام ٢/٥٩٤.|4:أخرجه ابن أبي حاتم ٩/٢٩٨٠.
  28,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَتۡبَعۡنَـٰهُمۡ فِی هَـٰذِهِ ٱلدُّنۡیَا لَعۡنَةࣰۖ وَیَوۡمَ ٱلۡقِیَـٰمَةِ هُم مِّنَ ٱلۡمَقۡبُوحِینَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٨٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مِن المُشَوَّهين بسواد الوجوه، وزُرقَة العيون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة ويوم القيامة﴾</span>، قال: لُعِنوا في الدنيا والآخرة. هو كقوله: <span class="qpc-hafs">﴿وأتبعوا في هذه لعنة ويوم القيامة، بئس الرفد المرفود﴾</span> [هود:٩٩]{2}. (١١/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٨٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قوله: <span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة﴾</span>، قال: لم يُبعَث نبيٌّ بعد فرعون إلا لُعِن على لسانه، يوم القيامة ترفد لعنة أخرى في النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة﴾</span> يعني: الغرق، <span class="qpc-hafs">﴿ويوم القيامة﴾</span> في النار <span class="qpc-hafs">﴿هم من المقبوحين﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة ويوم القيامة﴾</span> لعنة أخرى، ثم استقبل فقال: <span class="qpc-hafs">﴿هم من المقبوحين﴾</span>{5}. (١١/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة﴾</span> العذاب الذي عذَّبهم الله به الغرق. قال: <span class="qpc-hafs">﴿ويوم القيامة هم من المقبوحين﴾</span> في النار، وأهل النار مقبوحون مُشَوَّهون؛ سود، زرق، حبن{6}، كأنّ رؤوسهم آجام القصب، كالحون، شَفَةُ أحدهم السفلى ساقطةٌ على صدره، وشفته العليا قالِصَةٌ قد غطَّت وجهه، رأسُ أحدهم مثل الجبل العظيم، وضِرْسُه مثل أحد، وأنيابه كالصياصي -وهي الجبال-، وغلظ جلده سبعون ذراعًا -وبعضهم يقول: أربعون-، يشتد الدُّودُ ما بين جلده ولحمه كما يشتد الوحوش في البرية، وفخذه مسيرة يومين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٣<span class="dash">-</span></span> وقال <span class="name-1">ابن مسعود</span>: وإنِّي أراه يَشْغَلُ مِن جهنم مثلَ ما بيني وبين المدينة. وهو بالكوفة{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/٢٥١، وتفسير البغوي ٦/٢٠٩.|2:أخرجه ابن جرير ١٨/٢٥٨، وابن أبي حاتم ٩/٢٩٨٠. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن أبي حاتم ٩/٢٩٨٠.|4:تفسير مقاتل بن سليمان ٣/٣٤٦.|5:أخرجه ابن جرير ١٨/٢٥٨. وعزاه السيوطي إلى ابن المنذر.|6:الحبن: الكبير البطن. لسان العرب (حبن).|7:تفسير يحيى بن سلّام ٢/٥٩٤.
  28,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ مِنۢ بَعۡدِ مَاۤ أَهۡلَكۡنَا ٱلۡقُرُونَ ٱلۡأُولَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٩٤<span class="dash">-</span></span> عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «<b>ما أهلك الله قومًا، ولا قرنًا، ولا أمة، ولا أهل قرية، بعذاب من السماء منذ أنزل التوراة على وجه الأرض، غير القرية التي مُسِخَتْ قِرَدةً، ألم تر إلى قوله</b>: <span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب من بعد ما أهلكنا القرون الأولى﴾</span>»{1}<span class=comment-ref>٤٩٦٣</span>. (١١/٤٧١)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٦٣</span> ساق <u>ابنُ عطية</u> (٦/٥٩٥) هذا الحديث، ثم <span class="comment-type-4">علَّق</span> بقوله: «أي: الذين تعدَّوْا في السبت، وهذا التعذيب مِن سبب شرع موسى؛ فكأنه لا يُنقص فضيلة التوراة برفع العذاب عن الأرض».</div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٥<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق أبي نضرة-، موقوفًا{2}. (١١/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب من بعد مآ أهلكنا﴾</span> بالعذاب في الدنيا <span class="qpc-hafs">﴿القرون الأولى﴾</span> يعني: نوحًا، وعادًا، وقوم إبراهيم، وقوم لوط، وقوم شعيب، وغيرهم، كانوا قبل موسى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب﴾</span> التوراة ... وقوله: <span class="qpc-hafs">﴿من بعد ما أهلكنا القرون الأولى﴾</span> قرنًا مِن بعد قرن. كقوله على مقرأ هذا الحرف: <span class="qpc-hafs">﴿وكذلك أخذ ربك إذا أخذ القرى وهي ظالمة﴾</span> [هود:١٠٢]{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَصَاۤىِٕرَ لِلنَّاسِ وَهُدࣰى وَرَحۡمَةࣰ لَّعَلَّهُمۡ یَتَذَكَّرُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بصائر للناس﴾</span>، قال: بيِّنة{5}. (١١/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿بصآئر للناس﴾</span> يقول: في هلاك الأُمَم الخالية بصيرة لبنى إسرائيل، <span class="qpc-hafs">﴿وهدى﴾</span> يعني: التوراة هدًى مِن الضلالة لِمَن عمل بها، <span class="qpc-hafs">﴿ورحمة﴾</span> لِمَن آمن بها مِن العذاب، <span class="qpc-hafs">﴿لعلهم﴾</span> يعني: لكي <span class="qpc-hafs">﴿يتذكرون﴾</span> فيؤمنوا بتوحيد الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٨٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ- قال: البصائر: الهدى؛ بصائر ما في قلوبهم لذنوبهم، وليست ببصائر الرؤوس. وقرأ: <span class="qpc-hafs">﴿فَإنَّها لا تَعْمى الأَبْصارُ ولَكِنْ تَعْمى القُلُوبُ الَّتِي فِي الصُّدُورِ﴾</span> [الحج:٤٦]، وقال: هذا الدين بصره وسمعه في هذا القلب{7}. (١١/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٨٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بصائر للناس وهدى ورحمة لعلهم يتذكرون﴾</span>، يعني: يتفكروا، فكانت التوراة أولَ كتاب نزل فيه الفرائضُ والحدودُ والأحكامُ{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٤٤٢ (٣٥٣٤)، وابن جرير ١٨/٢٥٩، وابن أبي حاتم ٩/٢٩٨١ (١٦٩٢٨)، والثعلبي ٧/٢٥١.</p><p>قال الحاكم: «صحيح على شرط الشيخين، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٨٨ (١١٢٥٣): «رواه البزار موقوفًا ومرفوعًا، ورجالهما رجال الصحيح». وأورده الألباني في الصحيحة ٥/٣٢٧ (٢٢٥٨).|2:أخرجه البزار (٢٢٤٧ - كشف)، وابن جرير ١٨/٢٥٩، وابن أبي حاتم ٩/٢٩٨١ من وجه آخر.|3:تفسير مقاتل بن سليمان ٣/٣٤٦.|4:تفسير يحيى بن سلّام ٢/٥٩٥.|5:أخرجه ابن أبي حاتم ٩/٢٩٨١.|6:تفسير مقاتل بن سليمان ٣/٣٤٦.|7:أخرجه ابن أبي حاتم ٩/٢٩٨١ وفيه بلفظ: ما في قلوبهم لدينهم.|8:تفسير يحيى بن سلّام ٢/٥٩٥.