quran[9]{c,v,t}:
  12,87,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰبَنِیَّ ٱذۡهَبُوا۟ فَتَحَسَّسُوا۟ مِن یُوسُفَ وَأَخِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فتحسسوا﴾</span>، قال: معناه: التَمِسُوا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٠<span class="dash">-</span></span> عن <span class="name-3">النَّضْر بن عَرَبِيٍّ</span>، قال: بلغني: أنّ يعقوب ﵇ مكث أربعة وعشرين عامًا لا يدري أحيٌّ يوسف أم ميِّت، حتى تخلَّل له مَلَك الموت، فقال له: مَن أنت؟ قال: أنا مَلَك الموت. قال: أنشدك بإله يعقوب، هل قبضتَ روحَ يوسف؟ قال: لا. فعند ذلك قال: <span class="qpc-hafs">﴿يا بنى اذهبوا فتحسسوا من يوسف وأخيه ولا تيأسوا من روح الله﴾</span>. فخرجوا إلى مصر، فلمّا دخلوا عليه لم يجدوا كلامًا أرَقَّ مِن كلامٍ استقبلوه به، فقالوا: <span class="qpc-hafs">﴿يا أيها العزيز مسنا وأهلنا الضر﴾</span>{2}. (٨/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: لَمّا أخبره ولدُه بسيرة الملِك أحَسَّتْ نفسُ يعقوب، وطمِع، وقال: لعله يوسف. فقال: <span class="qpc-hafs">﴿يا بني اذهبوا فتحسسوا من يوسف وأخيه﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثم قال: <span class="qpc-hafs">﴿يا بنى اذهبوا فتحسسوا من يوسف وأخيه﴾</span> بمصر{4}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا بني اذهبوا فتحسسوا من﴾</span> يعني: فابحثوا عن <span class="qpc-hafs">﴿يوسف وأخيه﴾</span> بنيامين، ... وذلك أنّ يعقوب ﵇ رأى مَلَك الموت في المنام، فقال له: هل قبضتَ روحَ يوسف؟ قال: لا. وبَشَّره، فلمّا أصبح قال:<span class="qpc-hafs">﴿يا بني اذهبوا فتحسسوا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثم إنّ يعقوب قال لبنيه -وهو على حُسْنِ ظنِّه بربه مع الذي هو فيه من الحزن-: <span class="qpc-hafs">﴿يا بني اذهبوا﴾</span> إلى البلاد التي منها جئتم، <span class="qpc-hafs">﴿فتحسسوا من يوسف وأخيه﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَا۟یۡـَٔسُوا۟ مِن رَّوۡحِ ٱللَّهِۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٨٥<span class="dash">-</span></span> قال الحكم بن عمر: بعثني خالد بن عبد الله القَسْرِيِّ وصاحب لي إلى <span class="name-2">قتادة</span> الأعمى؛ ليسأله عن ثمانية عشر مسألة من القرآن، ... قال: وسألناه عن قوله: <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>. قال: لا، ولكن: (مِن رُّوحِ اللهِ){7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَا۟یۡـَٔسُوا۟ مِن رَّوۡحِ ٱللَّهِۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: ذُكِر لنا: أنّ نبي الله يعقوب لم ينزل به بلاء قط إلا أتاه حسنُ ظنه بالله مِن ورائه، وما ساء ظنُّه بالله ساعةً قطُّ مِن ليل أو نهار {8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>، قال: مِن رحمة الله{9}. (٨/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٨٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد-، مثله{10}. (٨/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>، قال: مِن فَرَج الله أن يَرُدَّ يوسف{4}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>، يعني: مِن رحمة الله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>، أي: مِن فَرَجِه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>، قال: مِن فَرَج الله؛ يُفَرِّج عنكم الغمَّ الذي أنتم فيه{14}. (٨/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿ولا تيأسوا من روح الله﴾</span>، قال: مِن فرج الله{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَا یَا۟یۡـَٔسُ مِن رَّوۡحِ ٱللَّهِ إِلَّا ٱلۡقَوۡمُ ٱلۡكَـٰفِرُونَ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه لا ييأس من روح الله﴾</span> يعني: مِن رحمة الله <span class="qpc-hafs">﴿إلا القوم الكافرون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿إنه لا ييأس من روح الله﴾</span> أي: مِن فرجه <span class="qpc-hafs">﴿إلا القوم الكافرون﴾</span>{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَا یَا۟یۡـَٔسُ مِن رَّوۡحِ ٱللَّهِ إِلَّا ٱلۡقَوۡمُ ٱلۡكَـٰفِرُونَ ۝٨٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٩٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق أبي توبة الربيع بن نافع- قال: أكبرُ الكبائر: الشركُ بالله، والقنوط من رحمة الله، واليأس من روح الله، والأمن من مكر الله. ثم تلا: <span class="qpc-hafs">﴿فلا يأمن مكر الله إلا القوم الخاسرون﴾</span> [الأعراف:٩٩]، <span class="qpc-hafs">﴿أنه من يشرك بالله فقد حرم الله عليه الجنة﴾</span> [المائدة:٧٢]، <span class="qpc-hafs">﴿لا ييأس من روح الله إلا القوم الكافرون﴾</span>، <span class="qpc-hafs">﴿ومن يقنط من رحمة ربه إلا الضالون﴾</span> [الحجر:٥٦]{18}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/٢٥٠، وتفسير البغوي ٤/٢٧١.|2:أخرجه ابن أبي حاتم ٧/٢١٨٩.|3:تفسير الثعلبي ٥/٢٥٠، وتفسير البغوي ٤/٢٧٠.|4:أخرجه ابن جرير ١٣/٣١٤. وعزاه السيوطي إلى ابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٣٤٨.|6:أخرجه ابن جرير ١٣/٣١٥، وابن أبي حاتم ٧/٢١٩٠.|7:أخرجه ابن عساكر في تاريخ دمشق ١٥/٣٢-٣٣.</p><p>والقراءة شاذة، وهي قراءة الحسن، وقتادة، وعمر بن عبد العزيز. انظر: المحتسب ٢/٢٠.|8:تفسير الثعلبي ٥/٢٥١.|9:أخرجه عبد الرزاق ١/٣٢٨، وابن جرير ١٣/٣١٤، وابن أبي حاتم ٧/٢١٩٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|10:أخرجه ابن جرير ١٣/٣١٥.|11:أخرجه ابن جرير ١٣/٣١٤. وعزاه السيوطي إلى ابن أبي حاتم.|12:تفسير مقاتل بن سليمان ٢/٣٤٨.|13:أخرجه ابن جرير ١٣/٣١٥، وابن أبي حاتم ٧/٢١٩٠.|14:أخرجه ابن جرير ١٣/٣١٥. وعزاه السيوطي إلى أبي الشيخ.|15:تفسير الثعلبي ٥/٢٥٠.|16:تفسير مقاتل بن سليمان ٢/٣٤٨.|17:أخرجه ابن أبي حاتم ٧/٢١٩٠.|18:أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
  12,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا دَخَلُوا۟ عَلَیۡهِ قَالُوا۟ یَـٰۤأَیُّهَا ٱلۡعَزِیزُ مَسَّنَا وَأَهۡلَنَا ٱلضُّرُّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿يا أيها العزيز مسنا وأهلنا الضر﴾</span>، أي: الضُّرَّ في المعيشة{1}. (٨/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما دخلوا عليه﴾</span> يوسف <span class="qpc-hafs">﴿قالوا يا أيها العزيز مسنا وأهلنا الضر﴾</span> يعني: الشِّدَّة والبلاء مِن الجوع{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: وخرجوا إلى مصر راجعين إليها ببضاعة مزجاة -أي: قليلة-، لا تبلغ ما كانوا يتبايعون به، إلا أن يتجاوز لهم فيها، وقد رأوا ما نزل بأبيهم، وتتابع البلاء عليه في ولده وبصره، حتى قدموا على يوسف، <span class="qpc-hafs">﴿فلما دخلوا عليه قالوا يا أيها العزيز﴾</span> رجاء أن يرحمهم في شأن أخيهم، <span class="qpc-hafs">﴿مسنا وأهلنا الضر﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجِئۡنَا بِبِضَـٰعَةࣲ مُّزۡجَىٰةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وجئنا ببضاعة﴾</span> قال: دراهم <span class="qpc-hafs">﴿مُزجاة﴾</span> قال: كاسِدة غير طائل{4}. (٨/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مليكة- في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: رَثَّةِ المتاع؛ خَلَقُ{5} الحبل، والغِرارَة{6}، والشيء{7}. (٨/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبيد الله بن أبي مليكة</span>: نحوه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: الوَرِقُ الرديئة الزُّيوف، التي لا تَنفُقُ حتى يُوضَع فيها{9}. (٨/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: سَوِيقِ{10} المُقْل{11}{12}. (٨/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٦<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن الحارث</span> -من طريق يزيد بن أبي زياد- في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: متاع الأعراب؛ الصُّوف، والسَّمن{13}. (٨/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بكر الهذلي- <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: الرَّدِيئة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٠٩<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي حصين- في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال أحدُهما: ناقصة. وقال الآخر: فُسُول{15}رديئة{16}. (٨/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق يزيد بن الوليد، ومغيرة- في قوله: <span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة﴾</span>، قال: قليلة، ألا تسمع إلى قوله: (فَأَوْقِر رِّكابَنا)؟ وهم يقرءون كذلك{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مزجاة﴾</span>، قال: قليلة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد، وجُوَيْبِر- في قوله: <span class="qpc-hafs">﴿مزجاة﴾</span>، قال: كاسِدة، غير نافقة{19}. (٨/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٣<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر-: النِّعال، والأُدم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٤<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر-: سَوِيق المُقْل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: قليلة{22}. (٨/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: دراهم زُيُوف{23}. (٨/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: القليلة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٨<span class="dash">-</span></span> عن <span class="name-2">عطية [العوفي]</span> -من طريق ابن إدريس، عن أبيه- قال: دراهم ليست بطائل{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١١٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: الحبَّة الخضراء، وصنوبر، وقطن{26}<span class=comment-ref>٣٤٤٤</span>. (٨/٣١٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٤</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/١٤٢) على قول أبي صالح، فقال: «وقال أبو صالح، وزيد بن أسلم: كانت الصنوبر، والحبة الخضراء. وهي الفستق».</div></p><p><div></p><p><p><span class="item-no">٣٨١٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: ببُعيرات، وبقرات عِجاف{27}. (٨/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة﴾</span>، أي: يسيرة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: دراهم فيها جَوازٌ{29}{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: كانت الحبَّة الخضراء{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة﴾</span>، يعني: دراهم نُفايَةٍ{32}، فجَوِّزها عنّا{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، في قوله: <span class="qpc-hafs">﴿ببضاعة مزجاة﴾</span>، قال: كانت الحبَّة الخضراء{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة﴾</span>، أي: قليلة، لا تبلغ ما كُنّا نشتري به منك، إلا أن تتجاوز لنا فيها{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿بضاعة مزجاة﴾</span>، قال: قليلة؛ سَمْن، وصوف{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة﴾</span>، قال: المزجاة: القليلة{30}<span class=comment-ref>٣٤٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٥</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٣/٣١٦بتصرف): «وعنى بقوله: <span class="qpc-hafs">﴿وجئنا ببضاعة مزجاة﴾</span>: بدراهم أو ثمن لا يجوز في ثمن الطعام، إلا لمن يتجاوز فيها، <span class="mustanad">وأصل الإزجاء</span>: السَّوْق بالدَّفع. وقد اختلف أهل التأويل في البيان عن تأويل ذلك، وإن كانت معاني بيانهم متقاربة». وذكر أقوال السلف على ذلك. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٤٢) إضافةً لِما ورد في أقوال السلف في معنى الآية <b>قولًا منسوبًا للإمام مالك</b> أنّه قال: المزجاة: الجائزة. ثم <span class="comment-type-4">علّق</span> قائلًا: «ولا أعرف لهذا وجهًا، والمعنى يأباه، ويحتمل أن صُحِّف على مالك، وأنّ لفظه بالحاء غير منقوطة وبالراء».</div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡفِ لَنَا ٱلۡكَیۡلَ وَتَصَدَّقۡ عَلَیۡنَاۤۖ إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٨١٢٩<span class="dash">-</span></span> عن إبراهيم النخعي، قال: في مصحف [<span class="name-1">عبد الله</span>] <span class="name-1">بن مسعود</span>: (فَأَوْفِ لَنا الكَيْلَ وأَوْقِر رِّكابَنا){38}. (٨/٣٢٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡفِ لَنَا ٱلۡكَیۡلَ وَتَصَدَّقۡ عَلَیۡنَاۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٣٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بكر- <span class="qpc-hafs">﴿فأوف لنا الكيل وتصدق علينا﴾</span>: لا تنقصنا مِن السعر مِن أجل رَدِيء دراهمِنا{39}. (٨/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٣١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿وتصدق علينا﴾</span>، قال: برَدِّ أخينا إلينا{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: فلمّا رجعوا إليه قالوا: <span class="qpc-hafs">﴿يا أيها العزيز مسنا وأهلنا الضر وجئنا ببضاعة مُزجاة فأوف لنا الكيل﴾</span> بها كما كنت تعطينا بالدراهم الجيِّدة، <span class="qpc-hafs">﴿وتصدق علينا﴾</span> بفضلِ ما بين الجِياد والرَّديئة{41}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأوف﴾</span> يعني: فوَفِّر <span class="qpc-hafs">﴿لنا الكيل﴾</span> بسعر الجِياد، <span class="qpc-hafs">﴿وتصدق علينا﴾</span> يقول: تكون هذه صدقةً منك -يعنون: معروفًا- أن تأخذ النُّفايَةَ، وتكيل لنا الطعام بسعر الجِياد{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿وتصدق علينا﴾</span>، قال: اردُد علينا أخانا{43}<span class=comment-ref>٣٤٤٦</span>. (٨/٣٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٦</span> في قوله: <span class="qpc-hafs">﴿وتصدق علينا﴾</span> قولان: <b>الأول</b>: تفضَّل علينا بما بين الجياد والرديئة. <b>الثاني</b>: تصدَّق علينا برَدِّ أخينا إلينا. وهو قول ابن جريج والضحاك.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٣/٣٢٦) القول الأول، و<span class="comment-type-2">انتقد</span> الثاني <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وهذا القول الذي ذكرناه عن ابن جريج، وإن كان قولًا له وجه، فليس بالقول المختار في تأويل قوله: <span class="qpc-hafs">﴿وتصدق علينا﴾</span>؛ لأنّ الصدقة في المتعارف: إنما هي إعطاء الرجل ذا الحاجة بعضَ أملاكه ابتغاء ثواب الله عليه، وإن كان كل معروف صدقة، فتوجيه تأويل كلام الله إلى الأغلب مِن معناه في كلام من نزل القرآن بلسانه أولى وأحرى».</p><p>وذكر <u>ابنُ عطية</u> (٥/١٤٢-١٤٣) <span class="comment-type-2">قولًا آخر</span> <span class="comment-type-1">ووَجَّهه</span>، فقال: «وقالت فرقة: كانت الصدقة عليهم محرمة، ولكن قالوا هذا تَجَوُّزًا واستعطافًا منهم في المبايعة، كما تقول لمن تساومه في سلعة: هبني مِن ثمنها كذا، وخذ كذا. فلم تقصد أن يهبك، وإنما حسنت له الانفعال حتى يرجع معك إلى سومك».</div></p><p><div></p><p><p><span class="item-no">٣٨١٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿فأوف لنا الكيل﴾</span>، أي: أعطِنا ما كنت تُعطِينا قبلَ ذلك{44}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٣٦<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مُزاحِم</span>: لم يقولوا: إنّ الله يجزيك. لأنّهم لم يعلموا أنّه مُؤْمِن{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الله يجزي المتصدقين﴾</span> لِمَن كان على ديننا، إضمار، ولو علموا أنّه مُسْلِم لقالوا: إنّ الله يجزيك بصدقتك{33}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٨١٣٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بكر- قال: الأنبياء ﵈ لا يأكلون الصدقة، إنما كانت دراهم نُفايةً لا تجوز بينهم، فقالوا: تَجَوَّزْ عَنّا ولا تَنقُصْنا مِن السِّعْر مِن أجل رَدِيء دراهمِنا{47}. (٨/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٣٩<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span> -من طريق ابن وهب- أنّه سُئِل عن أجر الكَيّالِين: أيُؤخَذُ مِنَ المُشْتَرِى؟ قال: الصوابُ والذي يقع في قلبي: أن يكون على البائع، وقد قال إخوة يوسف: <span class="qpc-hafs">﴿فأوفِ لنا الكيل وتصدق علينا﴾</span>. وكان يوسف ﵇ هو الذي يَكِيلُ{44}. (٨/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٠<span class="dash">-</span></span> عن القاسم، قال: يُحكى عن <span class="name-3">سفيان بن عيينة</span> أنّه سُئِل: هل حَرُمَتِ الصدقةُ على أحد من الأنبياء قبلَ النبي ﷺ؟ فقال: ألم تسمع قوله: <span class="qpc-hafs">﴿فأوف لنا الكيل وتصدق علينا إن الله يجزى المتصدقين﴾</span>. قال الحارث: قال القاسم: يذهب ابنُ عيينة إلى أنّهم لم يقولوا ذلك إلا والصدقة لهم حلالٌ وهم أنبياء؛ فإنّ الصدقة إنما حرمت على محمد ﷺ{49}<span class=comment-ref>٣٤٤٧</span>. (٨/٣٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٧</span> أفاد قولُ سفيان بن عيينة أنّ الصدقة كانت غيرَ مُحَرَّمة على أولئك الأنبياء، وإنما حرمت على محمد، و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٥/١٤٢) قوله <span class="mustanad">مستندًا إلى السنة</span> بقوله: «وهذا ضعيف، يرده حديث النبي ﷺ في قوله: «نحن معاشر الأنبياء لا تحل لنا الصدقة»».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٨١٤١<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> -من طريق عبد الرحمن الطويل- أنّ رجلًا قال له: تصدَّق عَلَيَّ تصدَّق اللهُ عليك بالجنة. فقال: ويحك، إنّ الله لا يتصدَّق، ولكن الله يجزى المتصدقين{50}. (٨/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٢<span class="dash">-</span></span> عن عثمان بن الأسود، قال: سمعتُ <span class="name-2">مجاهد بن جبر</span>، وسُئل: هل يُكْرَهُ أن يقول الرجل في دعائه: اللَّهُمَّ تصدق عَلَيَّ؟ فقال: نعم، إنّما الصدقة لِمَن يبتغى الثواب{51}. (٨/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه سمع رجلًا يقول: اللَّهُمَّ، تَصَدَّقْ عَلَيَّ. فقال: إنّ الله لا يَتَصَدَّق، وإنّما يَتَصَدَّق مَن يبغي الثواب، قل: اللَّهُمَّ، أعطِنِي، أو تَفَضَّل عَلَيَّ{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٤<span class="dash">-</span></span> عن <span class="name-2">ثابت بن أسلم البُنانيِّ</span> -من طريق يزيد بن يزيد- قال: قيل لبنى يعقوب: إنّ بمصر رجلًا يُطعِمُ المسكينَ، ويملأ حِجْرَ اليتيم. قالوا: ينبغي أن يكون هذا مِنّا أهل البيت. فنظروا، فإذا هو يوسف بن يعقوب{53}. (٨/٣٢١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٩٠. وعزاه السيوطي إلى أبي الشيخ.|2:تفسير مقاتل بن سليمان ٢/٣٤٨.|3:أخرجه ابن جرير ١٣/٣١٦، وابن أبي حاتم ٧/٢١٩١.|4:أخرجه ابن جرير ١٣/٣١٨، وابن أبي حاتم ٧/٢١٩١.|5:ثوب خَلَقٌ: بالٍ. لسان العرب (خلق).|6:الغِرارة: الجُوالِق، وعاء من الأوعية. لسان العرب (غرر) (جلق).|7:أخرجه عبد الرزاق ١/٣٢٨، وسعيد بن منصور (١١٤١ - تفسير)، وابن جرير ١٣/٣١٨، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|8:تفسير الثعلبي ٥/٢٥١.|9:أخرجه ابن جرير ١٣/٣١٧-٣١٨، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى أبي عبيد، وابن أبي شيبة، وابن المنذر، وأبي الشيخ.|10:السويق: ما يُتخذ من الحنطة والشعير. لسان العرب (سوق).|11:المُقْلُ: ثمر معروف. النهاية (مقل).|12:عزاه السيوطي إلى ابن النجار.|13:أخرجه ابن جرير ١٣/٣١٩، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|14:أخرجه ابن جرير ١٣/٣٢٠.|15:أصله من الفَسْل: وهو الرديء الرَّذِل من كل شيء. النهاية (فسل).|16:أخرجه ابن جرير ١٣/٣١٨-٣١٩، وابن أبي حاتم ٧/٢١٩١-٢١٩٢. وعزاه السيوطي إلى أبي الشيخ.|17:أخرجه ابن جرير ١٣/٣٢٠. وعلَّقه ابن أبي حاتم ٧/٢١٩٢.|18:أخرجه ابن جرير ١٣/٣٢١.|19:أخرجه ابن جرير ١٣/٣٢٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|20:تفسير الثعلبي ٥/٢٥١.|21:تفسير الثعلبي ٥/٢٥١.|22:أخرجه سعيد بن منصور (١١٣٩ - تفسير). وعلَّقه ابن أبي حاتم ٧/٢١٩٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|23:عزاه السيوطي إلى ابن أبي حاتم.|24:أخرجه ابن جرير ١٣/٣٢٠، وابن أبي حاتم ٧/٢١٩٢.|25:أخرجه ابن جرير ١٣/٣٢١، وابن أبي حاتم ٧/٢١٩١.|26:أخرجه ابن جرير ١٣/٣١٩-٣٢٠، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى أبي الشيخ.|27:عزاه السيوطي إلى عبد الرزاق، وابن المنذر.|28:أخرجه عبد الرزاق في تفسيره ٢/٣٢٨ من طريق معمر، وابن جرير ١٣/٣٢٣.|29:جاز الدرهم: قُبِل على ما فيه من خَفِي الدّاخِلَة أو قليلها. لسان العرب (جوز).|30:أخرجه ابن جرير ١٣/٣٢٣.|31:تفسير الثعلبي ٥/٢٥١، وتفسير البغوي ٤/٢٧٢.|32:قال ابن جرير في تفسيره ٨/٣٩٠: ومنه قيل للدراهم الرديئة وغيرها من كل شيء: النُّفايَةُ.|33:تفسير مقاتل بن سليمان ٢/٣٤٩.|34:تفسير الثعلبي ٥/٢٥١، وتفسير البغوي ٤/٢٧٢.|35:أخرجه ابن جرير ١٣/٣٢٣، وابن أبي حاتم ٧/٢١٩٢.|36:تفسير الثوري ص١٤٦.|37:أخرجه ابن جرير ١٣/٣٢٣.|38:أخرجه ابن جرير ١٣/٣٢٠.</p><p>والقراءة شاذة.|39:أخرجه ابن جرير ١٣/٣٢٤.|40:تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٢.|41:أخرجه ابن جرير ١٣/٣٢٤، وابن أبي حاتم ٧/٢١٩٢-٢١٩٣.|42:تفسير مقاتل بن سليمان ٢/٣٤٩.|43:أخرجه ابن جرير ١٣/٣٢٥-٣٢٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|44:أخرجه ابن أبي حاتم ٧/٢١٩٢.|45:تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٢.|46:تفسير مقاتل بن سليمان ٢/٣٤٩.|47:أخرجه ابن أبي حاتم ٧/٢١٩٢-٢١٩٣، وابن جرير ١٣/٣٢٥ بلفظ: قال: ما سأل نبي قط الصدقة، ولكنهم قالوا: <span class="qpc-hafs">﴿جئنا ببضاعة مزجاة فأوف لنا الكيل وتصدق علينا﴾</span> لا تنقصنا مِن السعر.|48:أخرجه ابن أبي حاتم ٧/٢١٩٢.|49:أخرجه ابن جرير ١٣/٣٢٥.|50:أخرجه ابن أبي حاتم ٧/٢١٩٣.|51:أخرجه ابن جرير ١٣/٣٢٦. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.|52:تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٣.|53:أخرجه ابن أبي حاتم ٧/٢١٩٤-٢١٩٤ (١١٩٣٨).
  12,89,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ هَلۡ عَلِمۡتُم مَّا فَعَلۡتُم بِیُوسُفَ وَأَخِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قال لهم يوسف -ورَحِمَهم عند ذلك-: <span class="qpc-hafs">﴿هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</span>{1}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: إنّما قال ذلك حين حكى لإخوته أنّ مالك بن ذعر قال: إنِّي وجدت غلامًا في بئر، مِن حاله كَيْتَ وكَيْت، فابتعته بكذا درهمًا. فقالوا: أيها الملك، نحن بعنا ذلك الغلام. فغاظ يوسفَ ذلك، وأمر بقتلهم، فذهبوا بهم ليقتلوهم، فوَلّى يهوذا وهو يقول: كان يعقوب يحزن ويبكي لِفَقْدِ واحدٍ مِنّا حتى كُفَّ بصرُه، فكيف إذا أتاه قَتْلُ بنيه كلِّهم؟ ثم قالوا له: إن فعلتَ ذلك فابعث بأمتعتنا إلى أبينا، فإنّه بمكان كذا وكذا، فذلك حين رَحِمَهم وبكى، وقال ذلك القول{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا سمِع ما ذكروا مِن الضُّرِّ قال لهم: <span class="qpc-hafs">﴿هل علمتم ما فعلتم بيوسف وأخيه﴾</span> يعني: بي، وبأخي بنيامين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٤٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ذُكر لي: أنّهم لَمّا كلموه بهذا الكلام غلبته نفسُه، فارْفَضَّ دمعُه باكيًا، ثم باح لهم بالذي يَكْتُم منهم، فقال: <span class="qpc-hafs">﴿هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</span>. ولم يعن بذكر أخيه ما صنعه هو فيه حين أخذه، ولكن للتفريق بينه وبين أخيه، إذ صنعوا بيوسف ما صنعوا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ أَنتُمۡ جَـٰهِلُونَ ۝٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٤٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: إذ أنتم صبيان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٥٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: إذ أنتم شباب ومعكم جهلُ الشباب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ أنتم جاهلون﴾</span>، يعني: مُذنِبين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٣٢٧، وابن أبي حاتم ٧/٢١٩٣.|2:تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٣.|3:تفسير مقاتل بن سليمان ٢/٣٤٩.|4:أخرجه ابن جرير ١٣/٣٢٧، وابن أبي حاتم ٧/٢١٩٣.|5:تفسير الثعلبي ٥/٢٥٣.|6:تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٣.|7:تفسير مقاتل بن سليمان ٢/٣٤٩.
  12,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَءِنَّكَ لَأَنتَ یُوسُفُۖ قَالَ أَنَا۠ یُوسُفُ وَهَـٰذَاۤ أَخِیۖ قَدۡ مَنَّ ٱللَّهُ عَلَیۡنَاۤۖ إِنَّهُۥ مَن یَتَّقِ وَیَصۡبِرۡ فَإِنَّ ٱللَّهَ لَا یُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٩٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٨١٥٢<span class="dash">-</span></span> عن الضَّحّاك بن مُزاحِم، قال: في حرف <span class="name-1">عبد الله [بن مسعود]</span>: (قالَ أنا يُوسُفُ وهَذَآ أخِي بَيْنِي وبَيْنَهُ قُرْبى قَدْ مَنَّ اللهُ عَلَيْنا){1}. (٨/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٥٣<span class="dash">-</span></span> عن الأعمش، قال: قرأ <span class="name-2">يحيى بن وثّاب</span>: ‹إنَّكَ لَأَنتَ يُوسُفُ› بهمزة واحدة{2}<span class=comment-ref>٣٤٤٨</span>. (٨/٣٢١)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٨</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (١٣/٣٢٨) هذه القراءة، فقال: «وروي عن ابن محيصن أنه قرأ: ‹إنَّكَ لَأَنتَ يُوسُفُ› على الخبر، لا على الاستفهام».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٥/١٤٤).</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> <span class="mustanad">مستندًا إلى إجماع الحجة من القراء</span> قراءة الاستفهام بقوله: «والصواب من القراءة في ذلك عندنا قراءةُ مَن قرأه بالاستفهام، لإجماع الحجة من القراء عليه».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (٨/٦٩) <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «لأنّ الاستفهام يدل على الاستعظام، أي: أنهم تعجبوا من ذلك أنهم يترددون إليه من سنتين وأكثر، وهم لا يعرفونه، وهو مع هذا يعرفهم ويكتم نفسه، فلهذا قالوا على سبيل الاستفهام: <span class="qpc-hafs">﴿أئنك لأنت يوسف قال أنا يوسف وهذا أخي﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَءِنَّكَ لَأَنتَ یُوسُفُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك-: لَمّا قال هذا القولَ تَبَسَّم يوسفُ، فرأوا ثناياه كاللؤلؤ المنظوم، فشبهوه بيوسف، فقالوا استفهامًا: <span class="qpc-hafs">﴿أإنك لأنت يوسف﴾</span>؟{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء-: إنّ إخوة يوسف لم يعرفوه حتى وضع التاجَ عن رأسه، وكان له في قرنه علامةٌ، وكان ليعقوب مثلها، ولإسحاق مثلها، ولسارة مثلها، شبه الشامة، فعرفوه، فقالوا: أئنك لأنت يوسف؟{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٥٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا قال لهم ذلك -يعني: قوله: <span class="qpc-hafs">﴿هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</span>؟- كشف الغِطاء، فعرفوه، فقالوا: <span class="qpc-hafs">﴿أئنك لأنت يوسف﴾</span> الآية{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ أَنَا۠ یُوسُفُ وَهَـٰذَاۤ أَخِیۖ قَدۡ مَنَّ ٱللَّهُ عَلَیۡنَاۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا أإنك لأنت يوسف قال أنا يوسف وهذا أخي قد من الله علينا﴾</span>، يقول: قد أنعم الله علينا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ مَن یَتَّقِ وَیَصۡبِرۡ فَإِنَّ ٱللَّهَ لَا یُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٩٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٥٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>:يتقي الزِّنا، ويصبر على العزوبة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٥٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿إنه من يتق ويصبر﴾</span>، قال: مَن يَتَّقِ الزِّنا، ويصبر على العُزُوبة{8}<span class=comment-ref>٣٤٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٩</span> ذكر <u>ابنُ عطية</u> (٥/١٤٤) قول مجاهد، وإبراهيم النخعي، ثم قال <span class="comment-type-4">مُعَلِّقًا</span>: «ومقصد اللفظ إنما هو <span class="mustanad">العموم</span> في العظائم، وإنّما قال هذان ما خصصا لأنّها كانت من نوازله، ولو فرضنا نزول غيرها به لاتقى وصبر».</div></p><p><div></p><p><p><span class="item-no">٣٨١٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قوله: <span class="qpc-hafs">﴿إنه من يتق ويصبر﴾</span>، يقول: مَن يَتَّقِ معصية الله، ويصبر على السجن{9}<span class=comment-ref>٣٤٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٠</span> لم يذكر <u>ابنُ جرير</u> (١٣/٣٢٨) غير قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٣٨١٦١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: مكتوب في الكتاب الأول أنّ الحاسدَ لا يَضُرُّ بحسده إلا نفسه، ليس ضارًّا مَن حَسَد، وأنّ الحاسد يَنقُصُه حَسَدُه، وأنّ المحسود إذا صبر نجّاه الله بصبره؛ لأنّ الله يقول: <span class="qpc-hafs">﴿إنه من يتق ويصبر فإن الله لا يضيع أجر المحسنين﴾</span>{10}. (٨/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه من يتق﴾</span> الزِّنا، <span class="qpc-hafs">﴿ويصبر﴾</span> على الأذى؛ <span class="qpc-hafs">﴿فإن الله لا يضيع أجر المحسنين﴾</span> يعني: جزاء مَن أحسن حتى يوفيه جزاءَه{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة شاذة. انظر: تفسير الماوردي ٣/٧٤.|2:عزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وأبو جعفر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿أإنَّكَ﴾</span> بهمزتين على الاستفهام. انظر: الإتحاف ص٣٣٥.|3:تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٣.|4:تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٤.|5:أخرجه ابن جرير ١٣/٣٢٨، وابن أبي حاتم ٧/٢١٩٤.|6:تفسير مقاتل بن سليمان ٢/٣٤٩.|7:تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٤.|8:أخرجه ابن أبي حاتم ٧/٢١٩٤. وذكر السيوطي مثله في الدر ٨/٣٢١، وعزاه إلى أبي الشيخ، ولم يذكر القائل! ولعله سقط من النسخ، فقد يكون إبراهيم النخعي كما في هذه الرواية، وقد يكون تابعًا للرواية التي قبله في الدر، وهي أثر الضحاك السابق في حكاية قراءة ابن مسعود، ويعضده أنه من رواية أبي الشيخ أيضًا.|9:أخرجه ابن جرير ١٣/٣٢٨.|10:أخرجه ابن أبي حاتم ٧/٢١٩٤. وعزاه السيوطي إلى أبي الشيخ.|11:تفسير مقاتل بن سليمان ٢/٣٤٩.
  12,91,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ تَٱللَّهِ لَقَدۡ ءَاثَرَكَ ٱللَّهُ عَلَیۡنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالوا تالله لقد ءاثرك الله علينا﴾</span>: وذلك بعدما عرَّفهم نفسَه، لَقُوا رجلًا حليمًا{1}. (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٦٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قالوا: أءِنك لأنت يوسف قال: أنا يوسف وهذا أخى قد مَنَّ الله علينا﴾</span>. فاعتذروا إليه، وقالوا: <span class="qpc-hafs">﴿تالله لقد آثرك الله علينا وإن كنا لخاطئين﴾</span>{2}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا تالله﴾</span> يعني: واللهِ، <span class="qpc-hafs">﴿لقد آثرك الله علينا﴾</span> يعني: اختارك، -كقوله في طه [٧٢]: <span class="qpc-hafs">﴿لن نؤثرك﴾</span> يعني: لن نختارك- علينا عند يعقوب، وأعطاك ومَلَّكك المُلْك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٦٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿آثرك الله علينا﴾</span>، أي: فَضَّلك اللهُ علينا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن كُنَّا لَخَـٰطِـِٔینَ ۝٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٦٧<span class="dash">-</span></span> قيل <span class="name-1">لعبد الله بن عباس</span>: كيف قالوا: إنّا كُنّا خاطئين وقد تَعَمَّدوا لذلك؟ فقال: أخطأوا الحقَّ وإن تَعَمَّدوا. كلُّ مَن أتى ذنبًا كذلك يخطئ المنهاج الذي عليه مِن الحق حتى يقع في الشُّبْهَة والمعصية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن كنا لخاطئين﴾</span> في أمرِك. فأقَرُّوا بخطيئتهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٦٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿قالوا تالله لقد آثرك الله علينا وإن كنا لخاطئين﴾</span> فيما كُنّا صنَعْنا بك{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٣٣٠، وابن أبي حاتم ٧/٢١٩٤. وعزاه السيوطي إلى أبي الشيخ.|2:أخرجه ابن جرير ١٣/٣٢٩. وعزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٣٤٩.|4:أخرجه ابن أبي حاتم ٧/٢١٩٤.|5:تفسير الثعلبي ٥/٢٥٤.|6:تفسير مقاتل بن سليمان ٢/٣٤٩.|7:أخرجه ابن جرير ١٣/٣٢٩، وابن أبي حاتم ٧/٢١٩٤.
  12,92,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَا تَثۡرِیبَ عَلَیۡكُمُ ٱلۡیَوۡمَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- في قوله: <span class="qpc-hafs">﴿لا تثريب﴾</span>، قال: لا إباء{1}. (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿لا تثريب﴾</span>، قال: لا تَعْيِيرَ{2}. (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: لَقُوا رجلًا حلِيمًا لم يَبُثَّ ولم يُثَرِّبْ عليهم أعمالَهم{3}. (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: اعتذروا إلى يوسف، فقال: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم﴾</span>. يقول: لا أذكر لكم ذنبَكم{4}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال يوسف: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم﴾</span>، يقول: لا تَعْيِير عليكم، لم يُثَرِّب عليهم بفعلهم القبيح{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿قال لا تثريب عليكم اليوم﴾</span>، أي: لا تأنيبَ عليكم اليوم عندي فيما صنعتم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق عبد الله بن الزبير- في قوله: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم﴾</span>، قال: لا تَعْيِير عليكم{7}<span class=comment-ref>٣٤٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥١</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٥/١٤٦) على ما جاء في قول سفيان وغيره، فقال: «وقد عبَّر بعض الناس عن التثريب بالتعيير، <span class="mustanad">ومنه قول النبي ﵇</span>: «إذا زَنَت أمةُ أحدكم فليجلدها، ولا يُثَرِّب»، أي: لا يُعَيِّر».</div></p><p><h3><span class="qpc-hafs">﴿یَغۡفِرُ ٱللَّهُ لَكُمۡۖ وَهُوَ أَرۡحَمُ ٱلرَّ ٰ⁠حِمِینَ ۝٩٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يغفر الله لكم﴾</span> ما فعلتم، <span class="qpc-hafs">﴿وهو أرحم الراحمين﴾</span> مِن غيره{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٧٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿يغفر الله لكم وهو أرحم الراحمين﴾</span> حين اعترفوا بذنبهم{9}<span class=comment-ref>٣٤٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٢</span> ذكر <u>ابنُ عطية</u> (٥/١٤٦-١٤٧) عن بعض القراء أنّه وقف على قوله: <span class="qpc-hafs">﴿عليكم﴾</span>، وابتدأ بقوله: <span class="qpc-hafs">﴿اليوم يغفر الله لكم﴾</span>. وذكر أنّ أكثرهم وقف على قوله: <span class="qpc-hafs">﴿اليَوْمَ﴾</span>، وابتدأ بقوله: <span class="qpc-hafs">﴿يَغْفِرُ اللَّهُ لَكُمْ﴾</span> على جهة الدعاء.</p><p>و<span class="comment-type-3">رجّح</span> الثاني <span class="mustanad">مستندًا إلى اللغة، والدلالة العقلية</span>، فقال: «وهو الصحيح، و<span class="qpc-hafs">﴿اليَوْمَ﴾</span> ظرف، فعلى هذا فالعامل فيه ما يتعلق به <span class="qpc-hafs">﴿عَلَيْكُمُ﴾</span>، تقديره: لا تثريب ثابت أو مستقر عليكم اليوم. وهذا الوقف أرجحُ في المعنى؛ لأنّ الآخَر فيه حكم على مغفرة الله، اللهم إلا أن يكون ذلك بوحي». ثم <span class="comment-type-4">بَيَّن</span> أنّ <span class="mustanad">قوله</span>: <span class="qpc-hafs">﴿اذهبوا بقميصي هذا فألقوه على وجه أبي يأت بصيرا﴾</span> يُقَوِّي «أنّ هذا كله بوحي وإعلام من الله».</div></p><p><h3><span class="qpc-hafs">﴿یَغۡفِرُ ٱللَّهُ لَكُمۡۖ وَهُوَ أَرۡحَمُ ٱلرَّ ٰ⁠حِمِینَ ۝٩٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٨١٧٩<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جدِّه، قال: لَمّا افتتح رسولُ الله ﷺ مكة التفت إلى الناس، فقال: «<b>ماذا تقولون؟ وماذا تظنون؟</b>». قالوا: ابن عم كريم. فقال: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم يغفر الله لكم﴾</span>{10}.(٨/٣٢٢) (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٠<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ لَمّا فتح مكة طاف بالبيت، وصَلّى ركعتين، ثم أتى الكعبة، فأخذ بعِضادَتَي{11} الباب، فقال: «<b>ماذا تقولون؟ وماذا تظنون؟</b>». قالوا: نقول: ابن أخ وابن عم حليم رحيم. فقال: «<b>أقول كما قال يوسف: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم يغفر الله لكم وهو أرحم الراحمين﴾</span></b>». فخرجوا كأنّما نُشِرُوا من القبور، فدخلوا في الإسلام{12}. (٨/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨١<span class="dash">-</span></span> عن عبد الله بن عباس: أنّ رسول الله ﷺ لَمّا فتح مكة صعد المنبر، فحمد الله، وأثنى عليه، ثم قال: «<b>يا أهل مكة، ماذا تظُنُّون؟ ماذا تقولون؟</b>». قالوا: نظنُّ خيرًا، ونقول خيرًا في ابن عم كريم، قد قدرت. قال: «<b>فإنِّي أقول كما قال أخي يوسف: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم يغفر الله لكم وهو أرحم الراحمين﴾</span></b>»{13}. (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٢<span class="dash">-</span></span> عن الزهري، عن بعض آل عمر بن الخطاب: أنّ عمر بن الخطاب لَمّا كان يوم الفتح ورسول الله ﷺ بمكة أرسل إلى صفوان بن أمية بن خلف، وإلى أبي سفيان بن حرب، وإلى الحارث بن هشام، قال عمر: قد أمكن الله منهم، أُعَرِّفهم بما صنعوا. حتى قال رسول الله ﷺ: «<b>مَثَلِي ومَثَلُكم كما قال يوسف لإخوته: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم يغفر الله لكم وهو أرحم الراحمين﴾</span></b>». قال عمر: فانتَضَحْتُ حياءً مِن رسول الله ﷺ؛ كراهيةَ أن يكون بَدَرَ مِنِّي ولقد قال لهم رسولُ الله ما قال{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٣<span class="dash">-</span></span> عن مالك بن دينار، قال: أرسل رجل إلى عشرة مِن أهل البصرة أنا فيهم و<span class="name-2">الحسن</span> [<span class="name-2">البصري</span>]، فسلمنا عليه، ثم إنّ <span class="name-2">الحسن</span> حمِد الله، وأثنى عليه، وذكر ما شاء الله أن يذكر، حتى أتى على ذِكْر يوسف، وما ارتكب منه إخوتُه، فعرَّفهم نفسه، ثم استقبلهم بالعفو عنهم: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم يغفر الله لكم﴾</span>. فرضي الله به منه عملًا، وأثبته في كتابه؛ ليُؤْخَذ به مِن بعدِه، فقال الأمير: لو صار أن أُجَلِّلكُم{15} بِبُرْدي{16} هذا ما أصابكم شيء أبدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجوني</span>، قال: أما -واللهِ- ما سمعنا بعَفْوٍ قطُّ مثل عَفْوِ يوسف{18}. (٨/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق رجاء بن أبي سلمة- قال: طلب الحوائج إلى الشباب أسهلُ منها عند الشيوخ، ألم تر إلى قول يوسف: <span class="qpc-hafs">﴿لا تثريب عليكم اليوم﴾</span>. وقال يعقوب ﵇: <span class="qpc-hafs">﴿سوف أستغفر لكم ربى﴾</span>؟{19}. (٨/٣٢٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٩٥.|2:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|3:أخرجه ابن أبي حاتم ٧/٢١٩٤. وعزاه السيوطي إلى أبي الشيخ. وأخرجه ابن جرير ١٣/٣٣٠ مختصرًا من طريق سعيد بن أبي عروبة.|4:أخرجه ابن جرير ١٣/٣٣١. وعزاه السيوطي إلى ابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٣٤٩.|6:أخرجه ابن جرير ١٣/٣٣١، وابن أبي حاتم ٧/٢١٩٥.|7:أخرجه ابن جرير ١٣/٣٣٠، وابن أبي حاتم ٧/٢١٩٥ من طريق ابن أبي عمر.|8:تفسير مقاتل بن سليمان ٢/٣٤٩.|9:أخرجه ابن جرير ١٣/٣٣١، وابن أبي حاتم ٧/٢١٩٥-٢١٩٦ وفيه عن محمد بن إسماعيل، وهو خطأ.|10:أخرجه البيهقي في دلائل النبوة ٥/٨٦-٨٧، وعزاه السيوطي إلى أبي الشيخ من طريق عمرو بن شعيب، وأخرجه ابن حبان ٧/٥٩٤-٥٩٥ (٥٩٦٤) من طريق آخر عن ابن عمرو مطولًا. وروي بألفاظ متفرقة ومختلفة طولًا وقصرًا بإسناد عمرو بن شعيب.</p><p>وإسناده حسن، وله شواهد ستأتي بعده.|11:عِضادتا الباب: ناحيتاه، وهما الخشبتان المنصوبتان عن يمين الداخل منه وشماله. لسان العرب (عضد).|12:أخرجه النسائي في الكبرى ١٠/١٥٤-١٥٥ (١١٢٣٤) بنحوه مطولًا، والبيهقي في الدلائل ٥/٥٧.</p><p>وقال العراقي في تخريج أحاديث الإحياء ص١٠٨٠: «رواه ابن الجوزي في الوفاء من طريق ابن أبي الدنيا، وفيه ضعف».|13:عزاه السيوطي إلى ابن مردويه. وأورده الثعلبي ٥/٢٥٤ بنحوه.|14:أخرجه ابن سعد في الطبقات الكبرى ٢/١٠٧، وأبو الشيخ في أخلاق النبي ﷺ (٨٢)، وابن زنجويه في كتابه الأموال (٤٥٥)، وابن عساكر في تاريخ دمشق ٣/٣٨٤، ١١/٤٩٥، ٢٤/١١٠-١١١. كلهم من طريق عبد الله بن المبارك، عن معمر، عن الزهري، عن بعض آل عمر به.</p><p>وإسناده صحيح إلى الزهري، لكن الزهري أبهم مَن حدّثه، وهم بعض آل عمر؛ ففي الإسناد جهالة.|15:أي: أغطيكم. لسان العرب (جلل).|16:البُرْد: نوع من الثياب معروف. النهاية (برد).|17:أخرجه ابن أبي حاتم ٧/٢١٩٥.|18:عزاه السيوطي إلى ابن أبي حاتم.|19:أخرجه ابن أبي حاتم ٧/٢١٩٥، وابن أبي الدنيا في كتاب اصطناع المعروف -موسوعة الإمام ابن أبي الدنيا ٨/٥١٧ (١١)- من طريق رجاء بن أبي سلمة. وعزاه السيوطي إلى أبي الشيخ.
  12,93,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱذۡهَبُوا۟ بِقَمِیصِی هَـٰذَا فَأَلۡقُوهُ عَلَىٰ وَجۡهِ أَبِی یَأۡتِ بَصِیرࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٨٦<span class="dash">-</span></span> عن أنس بن مالك، أنّ رسول الله ﷺ قال في قوله: <span class="qpc-hafs">﴿اذهبوا بقميصي هذا﴾</span>: «<b>إنّ نُمرودَ لَمّا ألقى إبراهيم في النار نزل إليه جبريل بقميص من الجنة، وطِنفِسَةٍ</b>{1} <b>مِن الجنة، فألبسه القميصَ، وأقعده على الطِّنْفِسَة، وقعد معه يتحدث، فأوحى الله إلى النار: <span class="qpc-hafs">﴿كونى بردًا وسلامًا﴾</span></b> [الأنبياء:٦٩]. <b>ولولا أنه قال: <span class="qpc-hafs">﴿وسلامًا﴾</span> لآذاه البرد، ولقتله البرد</b>»{2}. (٨/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٧<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رجل للنبي ﷺ: يا خيرَ البشر. فقال: «<b>ذاك يوسف صِدِّيق الله، ابن يعقوب إسرائيل الله، ابن إسحاق ذبيح الله، ابن إبراهيم خليل الله. إنّ الله كسا إبراهيم ثوبًا مِن الجنة، فكساه إبراهيم إسحاق، فكساه إسحاقُ يعقوبَ، فأخذه يعقوبُ فجعله في قَصَبَة حديد، وعلَّقه في عُنُق يوسف، ولو علم إخوتُه إذ ألقوه في الجُبِّ لأخذوه، فلمّا أراد الله أن يَرُدَّ يوسفَ على يعقوب -وكان بين رؤياه وتعبيرها أربعين سنة- أمر البشير أن يُبَشِّره مِن ثمان مراحل، فوجد يعقوبُ ريحه، فقال: <span class="qpc-hafs">﴿إنى لأجد ريح يوسف لولا أن تُفَندُون﴾</span>. فلمّا ألقاه على وجهه ارتدَّ بصيرًا، وليس يقع شيءٌ يقع مِن الجنة على عاهة من عاهات الدنيا إلا أبرأها بإذن الله تعالى</b>»{3}. (٨/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: أمره جبريلُ أن يرسلَ إليه قميصَه، وكان ذلك القميصُ قميصَ إبراهيم ﵇، وذلك أنّه جُرِّد مِن ثيابه وأُلْقِي في النار عُريانًا، فأتاه جبريل بقميص مِن حرير الجنة، فألبسه إيّاه، فكان ذلك القميصُ عند إبراهيم ﵇، فلمّا مات ورِثه إسحاق، فلمّا مات ورثه يعقوب، فلما شَبَّ يوسفُ جعل يعقوبُ ذلك القميصَ في قصبة، وسدَّ رأسها، وعلَّقها في عُنُقه؛ لِما كان يخاف عليه مِن العين، فكان لا يفارقه. فلَمّا أُلْقِي في البئر عريانًا جاءه جبريل ﵇ وعلى يوسف ذلك التعويذ، فأخرج القميص منه، وألبسه إياه، ففي هذا الوقتِ جاء جبريل ﵇ إلى يوسف ﵇، وقال: أرْسِلْ ذلك القميص؛ فإنّ فيه ريحَ الجنة، لا يقع على سقيم ولا مُبْتَلًى إلا عُوفِي. فدفع يوسفُ ذلك القميص إلى إخوته، وقال: ألقوه على وجه أبي يأت بصيرًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٨٩<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: كان ذلك القميصُ مِن نَسْجِ الجنَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لم يعلم أنه يعود بصيرًا إلا بعد أن أعلمه الله ﷿{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: لَمّا كان مِن أمرِ إخوة يوسف ما كان كتب يعقوبُ إلى يوسف وهو لا يعلم أنّه يوسف: بسم الله الرحمن الرحيم، من يعقوب بن إسحاق بن إبراهيم إلى عزيز آل فرعون، سلام عليك، فإنِّي أحمَدُ إليك اللهَ الذي لا إله إلا هو، أما بعد، فإنّا أهل بيت مُولَعٌ بنا أسباب البلاء؛ كان جَدي إبراهيم خليل الله أُلْقِي في النار في طاعة ربه، فجعلها الله عليه بردًا وسلامًا. وأمر الله جَدِّي أن يذبح له أبي، ففداه الله بما فداه به. وكان لي ابنٌ، وكان مِن أحب الناس إلَيَّ، ففقدته، فأذهب حزني عليه نورَ بصري، وكان له أخ مِن أُمَّه، كنتُ إذا ذكرتُه ضممتُه إلى صدري، فأذهب عنِّى بعضَ وجدي، وهو المحبوس عندك في السرقة، وإنِّي أُخبرُك أنِّي لم أسرق ولم ألِد سارقًا. فلمّا قرأ يوسف ﵇ الكتاب بكى، وصاح، وقال: <span class="qpc-hafs">﴿اذهبوا بقميصى هذا فألقوه على وجه أبى يأت بصيرًا﴾</span>{7}. (٨/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩٢<span class="dash">-</span></span> عن <span class="name-2">المطلب بن عبد الله بن حنطب</span> -من طريق الحكم- قال: لَمّا أُلقي إبراهيم في النار كساه الله تعالى قميصًا مِن قُمُصِ الجنة، فكساه إبراهيم إسحاق، وكساه إسحاق يعقوب، وكساه يعقوب يوسف، فطواه، وجعله في قصبة فضة، فجعله في عنقه، وكان في عنقه حين أُلْقِي في الجُبِّ، وحين سُجِن، وحين دخل عليه إخوتُه، وأخرج القميص من القصبة، فقال: <span class="qpc-hafs">﴿اذهبوا بقميصى هذا فألقوه على وجه أبى يأت بصيرًا﴾</span>. فشمَّ يعقوبُ ﵇ ريحَ الجنة وهو بأرض كنعان بفلسطين، فقال: <span class="qpc-hafs">﴿إنى لأجد ريح يوسف﴾</span>{8}<span class=comment-ref>٣٤٥٣</span>. (٨/٣٢٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٣</span> ذكر <u>ابنُ عطية</u> (٥/١٤٧) نحو ما جاء في هذا الأثر وغيره في صفة القميص، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وروي أن هذا القميص كان لإبراهيم، كساه الله إيّاه حين خرج من النار، وكان من ثياب الجنة، وكان بعد لإسحاق، ثم ليعقوب، ثم كان دفعه ليوسف، فكان عنده في حفاظ من قصب. وهذا كله يحتاج إلى سند، والظاهر أنّه قميص يوسف الذي هو منه بمنزلة قميص كل أحد، وهكذا تبين الغرابة في أن وجد ريحه من بعد، ولو كان مِن قمص الجنة لما كان في ذلك غرابة، ولوجده كلُّ أحَد».</div></p><p><div></p><p><p><span class="item-no">٣٨١٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثُمَّ قال: ما فعل أبي بعدي؟ قالوا: لَمّا فاته بنيامين عَمِي مِن الحزن. فقال: <span class="qpc-hafs">﴿اذهبوا بقميصي هذا فألقوه على وجه أبى يأت بصيرًا وأتوني بأهلكم أجمعين﴾</span>{9}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اذهبوا بقميصي هذا فألقوه على وجه أبي يأت بصيرا﴾</span> بعد البياض{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأۡتُونِی بِأَهۡلِكُمۡ أَجۡمَعِینَ ۝٩٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي إسحاق- قال: كان أهلُه حين أُرْسِل إليهم فأتوا مصر ثلاثة وتسعين إنسانًا، رجالهم أنبياء، ونساؤهم صِدِّيقات، واللهِ، ما خرجوا مع موسى ﵇ حتى بلغوا ستمائة ألف وسبعين ألفًا{11}. (٨/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: خرج يعقوبُ ﵇ إلى يوسف ﵇ بمصر في اثنين وسبعين مِن ولده وولد ولده، فخرجوا منها مع موسى ﵇ وهم ستمائة ألف{12}. (٨/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأتوني بأهلكم أجمعين﴾</span>، فلا يَبْقى منكم أحدٌ{10}. (ز)</p></p><p></div></p></div>",footnotes:1:الطِّنْفِسَة: البساط الذي له خمل رقيق. النهاية (طنفس).|2:أخرجه الواحدي في الوسيط ٣/٢٤٤، ومن طريقه ابن عساكر ٦/١٨٨ بنحوه. من حديث أنس بن مالك به، وعزاه السيوطي إلى أبي الشيخ.</p><p>وفي إسناده عباد بن كثير؛ قال البخاري: تركوه. وقال النسائي: متروك، وضعفه غير واحد. فالإسناد ضعيف.|3:عزاه السيوطي إلى أبي الشيخ.|4:تفسير الثعلبي ٥/٢٥٤، وتفسير البغوي ٤/٢٧٥.|5:تفسير الثعلبي ٥/٢٥٤، وتفسير البغوي ٤/٢٧٥.|6:تفسير البغوي ٤/٢٧٥.|7:عزاه السيوطي إلى الحكيم الترمذي، وأبي الشيخ.|8:أخرجه ابن أبي حاتم ٧/٢١٩٦.|9:أخرجه ابن جرير ١٣/٣٣٢، وابن أبي حاتم ٧/٢١٩٦.|10:تفسير مقاتل بن سليمان ٢/٣٤٩.|11:أخرجه ابن أبي حاتم ٧/٢١٩٦. وعزاه السيوطي إلى ابن المنذر.|12:أخرجه ابن أبي حاتم ٧/٢٢٠١ بلفظ: من ولده.|13:تفسير مقاتل بن سليمان ٢/٣٤٩.
  12,94,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا فَصَلَتِ ٱلۡعِیرُ قَالَ أَبُوهُمۡ إِنِّی لَأَجِدُ رِیحَ یُوسُفَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي الهذيل- في قوله: <span class="qpc-hafs">﴿ولما فصلت العير﴾</span> قال: لَمّا خرجت العيرُ هاجَتْ ريحٌ، فجاءت يعقوبَ بريحِ قميصِ يوسف، قال: <span class="qpc-hafs">﴿إنى لأجد ريح يوسف﴾</span>. قال: فوجد ريحَه مِن مسيرة ثمانية أيام{1}. (٨/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿إنى لأجد ريح يوسف﴾</span>، قال: وجد ريحه مِن مسيرة عشرة أيام{2}. (٨/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي الهذيل- أنّه سُئل: مِن كم وجَد يعقوب ﵇ ريح القميص؟ قال: وجده مِن مسيرة ثمانين فرسخًا{3}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: وجد يعقوبُ ﵇ ريح يوسف من مسيرة ستة أيام{4}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق السدي، عن أبيه-: أصاب يعقوبَ ريحُ يوسف مِن مسيرة ثلاثة أيام{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: وجد ريحَ قميصه مِن مسيرة شهر{6}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-: ذُكِر لنا: أنّه كان بينهما يومئذ ثمانون فرسخًا؛ يوسف بأرض مصر، ويعقوب بأرض كنعان، وقد أتى لذلك زمان طويل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، قال: وجَدَ ريحَه مِن مسيرة سبعة أيام{8}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿ولما فصلت العير﴾</span> مِن مصر مُنَطَلِقةً إلى الشام وجد يعقوبُ ريح يوسف، فقال لبَنِي بنيه: <span class="qpc-hafs">﴿إنى لأجد ريح يوسف لولا أن تفندون﴾</span>{9}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿إني لأجد ريح يوسف﴾</span>، قال: بلغنا: أنّه كان بينهم يومئذ ثمانون فرسخًا. وقال: <span class="qpc-hafs">﴿إني لأجد ريح يوسف﴾</span> وكان قد فارقه قبل ذلك سبعًا وسبعين سنة{7}<span class=comment-ref>٣٤٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٤</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٥/١٤٧) على قول ابن جريج بقوله: «وهذا قريب من الأول». يعني: قول ابن عباس من طريق ابن أبي هذيل.</div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولما فصلت العير﴾</span> مِن مصر إلى كنعان ثمانين فرسخًا <span class="qpc-hafs">﴿قال أبوهم﴾</span> يعقوب لبني بنيه: <span class="qpc-hafs">﴿إني لأجد ريح يوسف لولا أن تفندون﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٠٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا فصلتِ العِيرُ مِن مصر اسْتَرْوَحَ يعقوبُ ريحَ يوسف، فقال لِمَن عنده مِن ولده: <span class="qpc-hafs">﴿إني لأجد ريح يوسف لولا أن تفندون﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٠<span class="dash">-</span></span> عن أبي شريح، عن أبي أيوب الهوزني حدَّثه، قال: استأذَنَتِ الريحُ أن تأتي يعقوبَ بريح يوسف حين بعث بالقميص إلى أبيه قبل أن يأتيه البشير، ففعل، قال يعقوب: <span class="qpc-hafs">﴿إني لأجد ريح يوسف لولا أن تفندون﴾</span>{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَوۡلَاۤ أَن تُفَنِّدُونِ ۝٩٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي الهذيل- في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>: تُسَفِّهون{14}. (٨/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، يقول: تُجَهِّلون{15}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، قال: تُكَذِّبون{16}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- <span class="qpc-hafs">﴿لولا أن تفندون،﴾</span>، قال: تُكَذِّبون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٥<span class="dash">-</span></span> قال <span class="name-2">عطاء بن يسار</span>: تُضَعِّفون{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصيف- <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، قال: تُسَفِّهون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٧<span class="dash">-</span></span> قال ابن جُرَيج: بلغني عن <span class="name-2">مجاهد</span>، قال: تُكَذِّبون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، قال: تُهَرِّمون؛ تقولون: قد ذهب عقلُك{21}. (٨/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢١٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد، وجُوَيْبِر- قال: لولا أن تُكَذِّبون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٠<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: تُهَرِّمون، فتقولون: شيخ كبير قد خرف، وذهب عقلُه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: تُهَرِّمون{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، يقول: لولا أن تُسَفِّهون{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، قال: لولا أن تُسَفِّهون؛ تُهَرِّمون{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٤<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق عبد الملك بن أبي سليمان- <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، قال: لولا أن تُكذِّبون؛ لولا أن تُسَفِّهون{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لولا أن تُهَرِّمون، وتُكَذِّبون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span>، في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، قال: لولا أن تُحَمِّقُون{29}. (٨/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، يعني: لولا أن تُجَهِّلون{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿لولا أن تفندون﴾</span>، يقول: لولا أن تُضَعِّفوني{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٢٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في الآية، قال: المُفَنَّد: الذي ليس له عقل. يقولون: لا يعقل. قال: وقال الشاعر:</p><p>مهلًا فإنّ مِن العقول مُفَنَّدا{32}<span class=comment-ref>٣٤٥٥</span>. (٨/٣٢٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٥</span> اختُلِف في قوله تعالى: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span> على أقوال: <b>الأول</b>: تسفهون. <b>الثاني</b>: تكذبون. <b>الثالث</b>: تهرمون.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٣/٣٣٦-٢٤١ بتصرف) <span class="mustanad">العموم</span>، فقال: "وأمّا قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span> فإنه يعني: لولا أن تعنفوني، وتعجزوني، وتلوموني، وتكذبوني، ومنه قول الشاعر:</p><p>يا صاحبي دعا لومي وتفنيدي فليس ما فات من أمري بمردود</p><p>ويقال: أفند فلانًا الدهر، وذلك إذا أفسده«. ثم ذكر اختلاف السلف في هذا، ثم قال <span class="mustanad">مستندًا إلى اللغة</span>:»وقد بَيَّنّا أنّ أصل التفنيد: الإفساد، وإذا كان ذلك كذلك فالضعف والهرم والكذب وذهاب العقل وكل معاني الإفساد تدخل في التفنيد؛ لأنّ أصل ذلك كله الفساد، والفساد في الجسم: الهرم وذهاب العقل، والضعف، وفي الفعل الكذب، واللوم بالباطل، ولذلك قال جرير بن عطية:</p><p>يا عاذلي دعا الملام وأَقْصِرا طال الهوى وأَطَلْتُما التَّفْنِيدا</p><p>يعني: الملامة، فقد تبين إذ كان الأمرُ على ما وصفنا أنّ الأقوال التي قالها مَن ذكرنا قوله في قوله: <span class="qpc-hafs">﴿لولا أن تفندون﴾</span> على اختلاف عباراتهم عن تأويله متقاربة المعاني، محتمل جميعها ظاهر التنزيل، إذ لم يكن في الآية دليل على أنه معني به بعض ذلك دون بعض".</p><p>و<span class="comment-type-4">بنحوه</span> رجح <u>ابنُ عطية</u> (٥/١٤٨-١٤٩)، و<span class="comment-type-4">أضاف</span>: «والتفنيد يقع إما لجهل المُفَنَّد، وإما لِهَوًى غلبه، وإما لكذبه، وإما لضعفه وعجزه لذهاب عقله وهرمه، فلهذا فسّر الناس التفنيد في هذه الآية بهذه المعاني، ومنه قوله ﵇: «أو هرمًا مفندًا»». ثم ذكر أقوال السلف، ثم قال: «والذي يشبه أن تفنيدهم ليعقوب إنما كان لأنهم كانوا يعتقدون أن هواه قد غلبه في جانب يوسف».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ١/٣٢٩، وابن جرير ١٣/٣٣٣، ٣٣٧، وابن أبي حاتم ٧/٢١٩٧. وعزاه السيوطي إلى الفريابى، وأحمد في الزهد، وابن المنذر، وأبي الشيخ، وابن مردويه.|2:أخرجه ابن أبي حاتم ٧/٢١٩٧. وعزاه السيوطي إلى أبي الشيخ.|3:أخرجه ابن أبي حاتم ٧/٢١٩٧.|4:أخرجه ابن أبي حاتم ٧/٢١٩٦.|5:تفسير الثعلبي ٥/٢٥٥، وتفسير البغوي ٤/٢٧٥.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ١٣/٣٣٥.|8:عزاه السيوطي إلى أبي الشيخ.|9:أخرجه ابن أبي حاتم ٧/٢١٩٨. وعزاه السيوطي إلى ابن جرير.|10:أخرجه ابن جرير ١٣/٣٣٥.|11:تفسير مقاتل بن سليمان ٢/٣٥٠.|12:أخرجه ابن جرير ١٣/٣٣٦.|13:أخرجه ابن جرير ١٣/٣٣٢. كما أخرج نحوه ١٣/٣٣٧ من طريق سعيد بن جبير.|14:أخرجه عبد الرزاق ١/٣٢٩، وابن جرير ١٣/٣٣٣، ٣٣٧، وابن أبي حاتم ٧/٢١٩٧ من طريق عبد الله بن أبي الهذيل. وعزاه السيوطي إلى الفريابي، وأحمد في الزهد، وابن المنذر، وأبي الشيخ، وابن مردويه.|15:أخرجه ابن جرير ١٣/٣٣٧. وعزاه السيوطي إلى أبي الشيخ.|16:أخرجه ابن جرير ١٣/٣٤٠ من طريق العوفي، وابن أبي حاتم ٧/٢١٩٨.|17:أخرجه ابن جرير ١٣/٣٣٩.|18:تفسير الثعلبي ٥/٢٥٥.|19:أخرجه الثوري في تفسيره ص١٤٦، وابن جرير ١٣/٣٣٧.|20:أخرجه ابن جرير ١٣/٣٣٩.|21:عزاه السيوطي إلى أبي الشيخ. وأَخرج أوله ابن جرير ١٣/٣٤٠، وابن أبي حاتم ٧/٢١٩٨ من طريق أبي يحيى، كذلك أخرج آخره ابن جرير ١٣/٣٣٨ من طريق ابن أبي نجيح.|22:أخرجه ابن جرير ١٣/٣٣٩.|23:تفسير الثعلبي ٥/٢٥٥، وتفسير البغوي ٤/٢٧٥.|24:أخرجه الثوري في تفسيره ص١٤٦ من طريق أبي مودود، وابن جرير ١٣/٣٤٠.|25:أخرجه ابن جرير ١٣/٣٣٨.|26:أخرجه عبد الرزاق في تفسيره ٢/٣٢٨.|27:أخرجه ابن جرير ١٣/٣٣٧، ٣٤٠. وعلَّقه ابن أبي حاتم ٧/٢١٩٨.|28:أخرجه ابن جرير ١٣/٣٣٩.|29:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|30:تفسير مقاتل بن سليمان ٢/٣٥٠.|31:أخرجه ابن جرير ١٣/٣٣٩.|32:أخرجه ابن جرير ١٣/٣٣٩، وابن أبي حاتم ٧/٢١٩٨ من طريق أصبغ.
  12,95,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ تَٱللَّهِ إِنَّكَ لَفِی ضَلَـٰلِكَ ٱلۡقَدِیمِ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٢٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إنك لفي ضلالك القديم﴾</span>، يقول: خَطَئِك القديم{1}. (٨/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿لفي ضلالك القديم﴾</span>، يقول: جنونك القديم{2}. (٨/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة- في قول الله: <span class="qpc-hafs">﴿تالله إنك لفي ضلالك القديم﴾</span>، قال: عقوقًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قالوا تالله إنك لفي ضلالك القديم﴾</span>، أي: مِن حُبِّ يوسف لا تنساه ولا تَسْلاه. قالوا لوالدهم كلمةً غليظة، لم يكن ينبغي لهم أن يقولوها لوالدهم، ولا لنبيِّ الله ﷺ{4}<span class=comment-ref>٣٤٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٦</span> <span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٥/١٤٩) أنّ الضلال في الآية يُراد به: «الانتكاف والتحير، وليس هو بالضلال الذي هو في العرف ضد الرشاد؛ لأنّ ذلك مِن الجفاء الذي لا يسوغ لهم مواجهته به». ثم <span class="comment-type-4">بيّن</span> أن قتادة وابن عباس تأولاه على معنى الضلال الذي هو ضد الرشاد الذي ردَّه، فقال: «وقد تأول بعض الناس على ذلك، ولهذا قال قتادة ﵀: قالوا لوالدهم كلمة غليظة لم يكن ينبغي لهم أن يقولوها لوالدهم ولا لنبي الله ﵇. وقال ابن عباس: المعنى: لفي خطئك».</div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قال له بنو بنيه: <span class="qpc-hafs">﴿تالله إنك لفي ضلالك القديم﴾</span> في شأن يوسف{5}. (٨/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> بنو بنيه: <span class="qpc-hafs">﴿تالله﴾</span> واللهِ، <span class="qpc-hafs">﴿إنك لفي ضلالك القديم﴾</span> مثل قوله: <span class="qpc-hafs">﴿إنا إذا لفي ضلال وسعر﴾</span> [القمر:٢٤] يقول: في شقاء وعناء. يعني: في شقاء مِن حُبِّ يوسف وذكره فما تنساه، وقد أتى عليه أربعون سنة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿لفي ضلالك القديم﴾</span>، قال: حُبِّك القديم{7}. (٨/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿قالوا تالله إنك لفي ضلالك القديم﴾</span>، أي: إنّك لَمِن ذِكْرِ يوسف في الباطل الذي أنت عليه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿تالله إنك لفي ضلالك القديم﴾</span>، قال: يعنون: حُزْنه القديم على يوسف. و<span class="qpc-hafs">﴿لفي ضلالك القديم﴾</span>: لفي خطئك القديم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢٣٩<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق أبي أحمد- <span class="qpc-hafs">﴿تالله إنك لفي ضلالك القديم﴾</span>، قال: مِن حُبِّك ليوسف{10}<span class=comment-ref>٣٤٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٥٧</span> لم يذكر <u>ابنُ جرير</u> (١٣/٣٤٢-٣٤٣) غير قول سفيان، وعبد الرحمن بن زيد، ومحمد بن إسحاق، وقتادة، وابن عباس.</div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٣٤٢، وابن أبي حاتم ٧/٢١٩٨. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن أبي حاتم ٧/٢١٩٨.|3:أخرجه ابن أبي حاتم ٧/٢١٩٨.|4:أخرجه ابن جرير ١٣/٣٤٢، وابن أبي حاتم ٧/٢١٩٨-٢١٩٩ من طريق سعيد بن بشير.|5:أخرجه ابن جرير ١٣/٣٤٢، وابن أبي حاتم ٧/٢١٩٩.|6:تفسير مقاتل بن سليمان ٢/٣٥٠.|7:أخرجه ابن جرير ١٣/٣٤٣.|8:أخرجه ابن جرير ١٣/٣٤٣، وابن أبي حاتم ٧/٢١٩٩.|9:أخرجه ابن جرير ١٣/٣٤٣.|10:أخرجه ابن جرير ١٣/٣٤٢.