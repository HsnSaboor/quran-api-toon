quran[9]{c,v,t}:
12,87," <q>﴿یَـٰبَنِیَّ ٱذۡهَبُوا۟ فَتَحَسَّسُوا۟ مِن یُوسُفَ وَأَخِیهِ﴾</q> - تفسير ٣٨٠٧٩- عن عبد الله بن عباس، في قوله: <q>﴿فتحسسوا﴾</q>، قال: معناه: التَمِسُوا{1}. (ز) ٣٨٠٨٠- عن النَّضْر بن عَرَبِيٍّ، قال: بلغني: أنّ يعقوب ﵇ مكث أربعة وعشرين عامًا لا يدري أحيٌّ يوسف أم ميِّت، حتى تخلَّل له مَلَك الموت، فقال له: مَن أنت؟ قال: أنا مَلَك الموت. قال: أنشدك بإله يعقوب، هل قبضتَ روحَ يوسف؟ قال: لا. فعند ذلك قال: <q>﴿يا بنى اذهبوا فتحسسوا من يوسف وأخيه ولا تيأسوا من روح الله﴾</q>. فخرجوا إلى مصر، فلمّا دخلوا عليه لم يجدوا كلامًا أرَقَّ مِن كلامٍ استقبلوه به، فقالوا: <q>﴿يا أيها العزيز مسنا وأهلنا الضر﴾</q>{2}. (٨/٣١٦) ٣٨٠٨١- قال إسماعيل السُّدِّيّ: لَمّا أخبره ولدُه بسيرة الملِك أحَسَّتْ نفسُ يعقوب، وطمِع، وقال: لعله يوسف. فقال: <q>﴿يا بني اذهبوا فتحسسوا من يوسف وأخيه﴾</q>{3}. (ز) ٣٨٠٨٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثم قال: <q>﴿يا بنى اذهبوا فتحسسوا من يوسف وأخيه﴾</q> بمصر{4}. (٨/١٩٨) ٣٨٠٨٣- قال مقاتل بن سليمان: <q>﴿يا بني اذهبوا فتحسسوا من﴾</q> يعني: فابحثوا عن <q>﴿يوسف وأخيه﴾</q> بنيامين، ... وذلك أنّ يعقوب ﵇ رأى مَلَك الموت في المنام، فقال له: هل قبضتَ روحَ يوسف؟ قال: لا. وبَشَّره، فلمّا أصبح قال:<q>﴿يا بني اذهبوا فتحسسوا﴾</q>{5}. (ز) ٣٨٠٨٤- عن محمد بن إسحاق -من طريق سلمة- قال: ثم إنّ يعقوب قال لبنيه -وهو على حُسْنِ ظنِّه بربه مع الذي هو فيه من الحزن-: <q>﴿يا بني اذهبوا﴾</q> إلى البلاد التي منها جئتم، <q>﴿فتحسسوا من يوسف وأخيه﴾</q>{6}. (ز) <q>﴿وَلَا تَا۟یۡـَٔسُوا۟ مِن رَّوۡحِ ٱللَّهِۖ﴾</q> - قراءات ٣٨٠٨٥- قال الحكم بن عمر: بعثني خالد بن عبد الله القَسْرِيِّ وصاحب لي إلى قتادة الأعمى؛ ليسأله عن ثمانية عشر مسألة من القرآن، ... قال: وسألناه عن قوله: <q>﴿ولا تيأسوا من روح الله﴾</q>. قال: لا، ولكن: (مِن رُّوحِ اللهِ){7}. (ز) <q>﴿وَلَا تَا۟یۡـَٔسُوا۟ مِن رَّوۡحِ ٱللَّهِۖ﴾</q> - تفسير الآية ٣٨٠٨٦- عن الحسن البصري= (ز) ٣٨٠٨٧- وقتادة بن دعامة: ذُكِر لنا: أنّ نبي الله يعقوب لم ينزل به بلاء قط إلا أتاه حسنُ ظنه بالله مِن ورائه، وما ساء ظنُّه بالله ساعةً قطُّ مِن ليل أو نهار {8}. (ز) ٣٨٠٨٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تيأسوا من روح الله﴾</q>، قال: مِن رحمة الله{9}. (٨/٣١٧) ٣٨٠٨٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد-، مثله{10}. (٨/٣١٧) ٣٨٠٩٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولا تيأسوا من روح الله﴾</q>، قال: مِن فَرَج الله أن يَرُدَّ يوسف{4}. (٨/١٩٨) ٣٨٠٩١- قال مقاتل بن سليمان: <q>﴿ولا تيأسوا من روح الله﴾</q>، يعني: مِن رحمة الله{5}. (ز) ٣٨٠٩٢- عن محمد بن إسحاق -من طريق سلمة- <q>﴿ولا تيأسوا من روح الله﴾</q>، أي: مِن فَرَجِه{6}. (ز) ٣٨٠٩٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تيأسوا من روح الله﴾</q>، قال: مِن فَرَج الله؛ يُفَرِّج عنكم الغمَّ الذي أنتم فيه{14}. (٨/٣١٧) ٣٨٠٩٤- عن عبد الرحمن بن زيد بن أسلم، في قوله: <q>﴿ولا تيأسوا من روح الله﴾</q>، قال: مِن فرج الله{15}. (ز) <q>﴿إِنَّهُۥ لَا یَا۟یۡـَٔسُ مِن رَّوۡحِ ٱللَّهِ إِلَّا ٱلۡقَوۡمُ ٱلۡكَـٰفِرُونَ ۝٨٧﴾</q> - تفسير ٣٨٠٩٥- قال مقاتل بن سليمان: <q>﴿إنه لا ييأس من روح الله﴾</q> يعني: مِن رحمة الله <q>﴿إلا القوم الكافرون﴾</q>{5}. (ز) ٣٨٠٩٦- عن محمد بن إسحاق -من طريق سلمة- <q>﴿إنه لا ييأس من روح الله﴾</q> أي: مِن فرجه <q>﴿إلا القوم الكافرون﴾</q>{17}. (ز) <q>﴿إِنَّهُۥ لَا یَا۟یۡـَٔسُ مِن رَّوۡحِ ٱللَّهِ إِلَّا ٱلۡقَوۡمُ ٱلۡكَـٰفِرُونَ ۝٨٧﴾</q> - آثار متعلقة بالآية ٣٨٠٩٧- عن سفيان بن عيينة -من طريق أبي توبة الربيع بن نافع- قال: أكبرُ الكبائر: الشركُ بالله، والقنوط من رحمة الله، واليأس من روح الله، والأمن من مكر الله. ثم تلا: <q>﴿فلا يأمن مكر الله إلا القوم الخاسرون﴾</q> [الأعراف:٩٩]، <q>﴿أنه من يشرك بالله فقد حرم الله عليه الجنة﴾</q> [المائدة:٧٢]، <q>﴿لا ييأس من روح الله إلا القوم الكافرون﴾</q>، <q>﴿ومن يقنط من رحمة ربه إلا الضالون﴾</q> [الحجر:٥٦]{18}. (ز) ",footnotes:1:تفسير الثعلبي ٥/٢٥٠، وتفسير البغوي ٤/٢٧١.أخرجه ابن أبي حاتم ٧/٢١٨٩.تفسير الثعلبي ٥/٢٥٠، وتفسير البغوي ٤/٢٧٠.أخرجه ابن جرير ١٣/٣١٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن جرير ١٣/٣١٥، وابن أبي حاتم ٧/٢١٩٠.أخرجه ابن عساكر في تاريخ دمشق ١٥/٣٢-٣٣. والقراءة شاذة، وهي قراءة الحسن، وقتادة، وعمر بن عبد العزيز. انظر: المحتسب ٢/٢٠.تفسير الثعلبي ٥/٢٥١.أخرجه عبد الرزاق ١/٣٢٨، وابن جرير ١٣/٣١٤، وابن أبي حاتم ٧/٢١٩٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣١٥.أخرجه ابن جرير ١٣/٣١٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن جرير ١٣/٣١٥، وابن أبي حاتم ٧/٢١٩٠.أخرجه ابن جرير ١٣/٣١٥. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٥٠.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن أبي حاتم ٧/٢١٩٠.أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
12,88," <q>﴿فَلَمَّا دَخَلُوا۟ عَلَیۡهِ قَالُوا۟ یَـٰۤأَیُّهَا ٱلۡعَزِیزُ مَسَّنَا وَأَهۡلَنَا ٱلضُّرُّ﴾</q> - تفسير ٣٨٠٩٨- عن قتادة بن دعامة -من طريق سعيد بن بشير- في قوله: <q>﴿يا أيها العزيز مسنا وأهلنا الضر﴾</q>، أي: الضُّرَّ في المعيشة{1}. (٨/٣١٧) ٣٨٠٩٩- قال مقاتل بن سليمان: <q>﴿فلما دخلوا عليه﴾</q> يوسف <q>﴿قالوا يا أيها العزيز مسنا وأهلنا الضر﴾</q> يعني: الشِّدَّة والبلاء مِن الجوع{2}. (ز) ٣٨١٠٠- عن محمد بن إسحاق -من طريق سلمة- قال: وخرجوا إلى مصر راجعين إليها ببضاعة مزجاة -أي: قليلة-، لا تبلغ ما كانوا يتبايعون به، إلا أن يتجاوز لهم فيها، وقد رأوا ما نزل بأبيهم، وتتابع البلاء عليه في ولده وبصره، حتى قدموا على يوسف، <q>﴿فلما دخلوا عليه قالوا يا أيها العزيز﴾</q> رجاء أن يرحمهم في شأن أخيهم، <q>﴿مسنا وأهلنا الضر﴾</q>{3}. (ز) <q>﴿وَجِئۡنَا بِبِضَـٰعَةࣲ مُّزۡجَىٰةࣲ﴾</q> - تفسير ٣٨١٠١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وجئنا ببضاعة﴾</q> قال: دراهم <q>﴿مُزجاة﴾</q> قال: كاسِدة غير طائل{4}. (٨/٣١٧) ٣٨١٠٢- عن عبد الله بن عباس -من طريق ابن أبي مليكة- في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: رَثَّةِ المتاع؛ خَلَقُ{5} الحبل، والغِرارَة{6}، والشيء{7}. (٨/٣١٧) ٣٨١٠٣- عن عبد الله بن عبيد الله بن أبي مليكة: نحوه{8}. (ز) ٣٨١٠٤- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿ببضاعة مزجاة﴾</q>، قال: الوَرِقُ الرديئة الزُّيوف، التي لا تَنفُقُ حتى يُوضَع فيها{9}. (٨/٣١٨) ٣٨١٠٥- عن عبد الله بن عباس، في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: سَوِيقِ{10} المُقْل{11}{12}. (٨/٣١٩) ٣٨١٠٦- عن عبد الله بن الحارث -من طريق يزيد بن أبي زياد- في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: متاع الأعراب؛ الصُّوف، والسَّمن{13}. (٨/٣١٩) ٣٨١٠٧- عن سعيد بن جبير -من طريق أبي بكر الهذلي- <q>﴿ببضاعة مزجاة﴾</q>، قال: الرَّدِيئة{14}. (ز) ٣٨١٠٨- عن سعيد بن جبير= (ز) ٣٨١٠٩- وعكرمة مولى ابن عباس -من طريق أبي حصين- في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال أحدُهما: ناقصة. وقال الآخر: فُسُول{15}رديئة{16}. (٨/٣١٨) ٣٨١١٠- عن إبراهيم النخعي -من طريق يزيد بن الوليد، ومغيرة- في قوله: <q>﴿وجئنا ببضاعة مزجاة﴾</q>، قال: قليلة، ألا تسمع إلى قوله: (فَأَوْقِر رِّكابَنا)؟ وهم يقرءون كذلك{17}. (ز) ٣٨١١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿مزجاة﴾</q>، قال: قليلة{18}. (ز) ٣٨١١٢- عن الضحاك بن مُزاحِم -من طريق عبيد، وجُوَيْبِر- في قوله: <q>﴿مزجاة﴾</q>، قال: كاسِدة، غير نافقة{19}. (٨/٣١٩) ٣٨١١٣- قال الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر-: النِّعال، والأُدم{8}. (ز) ٣٨١١٤- قال الضحاك بن مُزاحِم -من طريق جُوَيْبِر-: سَوِيق المُقْل{8}. (ز) ٣٨١١٥- عن عكرمة مولى ابن عباس، في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: قليلة{22}. (٨/٣١٨) ٣٨١١٦- عن عكرمة مولى ابن عباس، في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: دراهم زُيُوف{23}. (٨/٣١٨) ٣٨١١٧- عن الحسن البصري -من طريق أبي بكر الهذلي- <q>﴿ببضاعة مزجاة﴾</q>، قال: القليلة{24}. (ز) ٣٨١١٨- عن عطية [العوفي] -من طريق ابن إدريس، عن أبيه- قال: دراهم ليست بطائل{25}. (ز) ٣٨١١٩- عن أبي صالح باذام -من طريق إسماعيل- في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: الحبَّة الخضراء، وصنوبر، وقطن{26}٣٤٤٤. (٨/٣١٩) ٣٤٤٤ علّق ابنُ عطية (٨/١٤٢) على قول أبي صالح، فقال: «وقال أبو صالح، وزيد بن أسلم: كانت الصنوبر، والحبة الخضراء. وهي الفستق». ٣٨١٢٠- عن قتادة بن دعامة، في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: ببُعيرات، وبقرات عِجاف{27}. (٨/٣١٩) ٣٨١٢١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وجئنا ببضاعة مزجاة﴾</q>، أي: يسيرة{28}. (ز) ٣٨١٢٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: دراهم فيها جَوازٌ{29}{30}. (ز) ٣٨١٢٣- عن محمد بن السائب الكلبي، في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: كانت الحبَّة الخضراء{31}. (ز) ٣٨١٢٤- قال مقاتل بن سليمان: <q>﴿وجئنا ببضاعة مزجاة﴾</q>، يعني: دراهم نُفايَةٍ{32}، فجَوِّزها عنّا{33}. (ز) ٣٨١٢٥- عن مقاتل بن حيان، في قوله: <q>﴿ببضاعة مزجاة﴾</q>، قال: كانت الحبَّة الخضراء{31}. (ز) ٣٨١٢٦- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وجئنا ببضاعة مزجاة﴾</q>، أي: قليلة، لا تبلغ ما كُنّا نشتري به منك، إلا أن تتجاوز لنا فيها{35}. (ز) ٣٨١٢٧- عن سفيان الثوري، في قوله: <q>﴿بضاعة مزجاة﴾</q>، قال: قليلة؛ سَمْن، وصوف{36}. (ز) ٣٨١٢٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وجئنا ببضاعة مزجاة﴾</q>، قال: المزجاة: القليلة{30}٣٤٤٥. (ز) ٣٤٤٥ قال ابنُ جرير (١٣/٣١٦بتصرف): «وعنى بقوله: <q>﴿وجئنا ببضاعة مزجاة﴾</q>: بدراهم أو ثمن لا يجوز في ثمن الطعام، إلا لمن يتجاوز فيها، وأصل الإزجاء: السَّوْق بالدَّفع. وقد اختلف أهل التأويل في البيان عن تأويل ذلك، وإن كانت معاني بيانهم متقاربة». وذكر أقوال السلف على ذلك. وذكر ابنُ عطية (٥/١٤٢) إضافةً لِما ورد في أقوال السلف في معنى الآية قولًا منسوبًا للإمام مالك أنّه قال: المزجاة: الجائزة. ثم علّق قائلًا: «ولا أعرف لهذا وجهًا، والمعنى يأباه، ويحتمل أن صُحِّف على مالك، وأنّ لفظه بالحاء غير منقوطة وبالراء». <q>﴿فَأَوۡفِ لَنَا ٱلۡكَیۡلَ وَتَصَدَّقۡ عَلَیۡنَاۤۖ إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</q> - قراءات ٣٨١٢٩- عن إبراهيم النخعي، قال: في مصحف [عبد الله] بن مسعود: (فَأَوْفِ لَنا الكَيْلَ وأَوْقِر رِّكابَنا){38}. (٨/٣٢٠) <q>﴿فَأَوۡفِ لَنَا ٱلۡكَیۡلَ وَتَصَدَّقۡ عَلَیۡنَاۤۖ﴾</q> - تفسير ٣٨١٣٠- عن سعيد بن جبير -من طريق أبي بكر- <q>﴿فأوف لنا الكيل وتصدق علينا﴾</q>: لا تنقصنا مِن السعر مِن أجل رَدِيء دراهمِنا{39}. (٨/٣٢٠) ٣٨١٣١- عن الضحاك بن مزاحم، في قوله: <q>﴿وتصدق علينا﴾</q>، قال: برَدِّ أخينا إلينا{40}. (ز) ٣٨١٣٢- عن إسماعيل السدي -من طريق أسباط- قال: فلمّا رجعوا إليه قالوا: <q>﴿يا أيها العزيز مسنا وأهلنا الضر وجئنا ببضاعة مُزجاة فأوف لنا الكيل﴾</q> بها كما كنت تعطينا بالدراهم الجيِّدة، <q>﴿وتصدق علينا﴾</q> بفضلِ ما بين الجِياد والرَّديئة{41}. (٨/١٩٩) ٣٨١٣٣- قال مقاتل بن سليمان: <q>﴿فأوف﴾</q> يعني: فوَفِّر <q>﴿لنا الكيل﴾</q> بسعر الجِياد، <q>﴿وتصدق علينا﴾</q> يقول: تكون هذه صدقةً منك -يعنون: معروفًا- أن تأخذ النُّفايَةَ، وتكيل لنا الطعام بسعر الجِياد{33}. (ز) ٣٨١٣٤- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿وتصدق علينا﴾</q>، قال: اردُد علينا أخانا{43}٣٤٤٦. (٨/٣٢٠) ٣٤٤٦ في قوله: <q>﴿وتصدق علينا﴾</q> قولان: الأول: تفضَّل علينا بما بين الجياد والرديئة. الثاني: تصدَّق علينا برَدِّ أخينا إلينا. وهو قول ابن جريج والضحاك. وقد رجّح ابنُ جرير (١٣/٣٢٦) القول الأول، وانتقد الثاني مستندًا إلى اللغة، فقال: «وهذا القول الذي ذكرناه عن ابن جريج، وإن كان قولًا له وجه، فليس بالقول المختار في تأويل قوله: <q>﴿وتصدق علينا﴾</q>؛ لأنّ الصدقة في المتعارف: إنما هي إعطاء الرجل ذا الحاجة بعضَ أملاكه ابتغاء ثواب الله عليه، وإن كان كل معروف صدقة، فتوجيه تأويل كلام الله إلى الأغلب مِن معناه في كلام من نزل القرآن بلسانه أولى وأحرى». وذكر ابنُ عطية (٥/١٤٢-١٤٣) قولًا آخر ووَجَّهه، فقال: «وقالت فرقة: كانت الصدقة عليهم محرمة، ولكن قالوا هذا تَجَوُّزًا واستعطافًا منهم في المبايعة، كما تقول لمن تساومه في سلعة: هبني مِن ثمنها كذا، وخذ كذا. فلم تقصد أن يهبك، وإنما حسنت له الانفعال حتى يرجع معك إلى سومك». ٣٨١٣٥- عن محمد بن إسحاق -من طريق سلمة- قوله: <q>﴿فأوف لنا الكيل﴾</q>، أي: أعطِنا ما كنت تُعطِينا قبلَ ذلك{44}. (ز) <q>﴿إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</q> - تفسير ٣٨١٣٦- قال الضحاك بن مُزاحِم: لم يقولوا: إنّ الله يجزيك. لأنّهم لم يعلموا أنّه مُؤْمِن{40}. (ز) ٣٨١٣٧- قال مقاتل بن سليمان: <q>﴿إن الله يجزي المتصدقين﴾</q> لِمَن كان على ديننا، إضمار، ولو علموا أنّه مُسْلِم لقالوا: إنّ الله يجزيك بصدقتك{33}. (ز) <q>﴿إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</q> - أحكام متعلقة بالآية ٣٨١٣٨- عن سعيد بن جبير -من طريق أبي بكر- قال: الأنبياء ﵈ لا يأكلون الصدقة، إنما كانت دراهم نُفايةً لا تجوز بينهم، فقالوا: تَجَوَّزْ عَنّا ولا تَنقُصْنا مِن السِّعْر مِن أجل رَدِيء دراهمِنا{47}. (٨/٣٢٠) ٣٨١٣٩- عن مالك بن أنس -من طريق ابن وهب- أنّه سُئِل عن أجر الكَيّالِين: أيُؤخَذُ مِنَ المُشْتَرِى؟ قال: الصوابُ والذي يقع في قلبي: أن يكون على البائع، وقد قال إخوة يوسف: <q>﴿فأوفِ لنا الكيل وتصدق علينا﴾</q>. وكان يوسف ﵇ هو الذي يَكِيلُ{44}. (٨/٣١٩) ٣٨١٤٠- عن القاسم، قال: يُحكى عن سفيان بن عيينة أنّه سُئِل: هل حَرُمَتِ الصدقةُ على أحد من الأنبياء قبلَ النبي ﷺ؟ فقال: ألم تسمع قوله: <q>﴿فأوف لنا الكيل وتصدق علينا إن الله يجزى المتصدقين﴾</q>. قال الحارث: قال القاسم: يذهب ابنُ عيينة إلى أنّهم لم يقولوا ذلك إلا والصدقة لهم حلالٌ وهم أنبياء؛ فإنّ الصدقة إنما حرمت على محمد ﷺ{49}٣٤٤٧. (٨/٣٢٠) ٣٤٤٧ أفاد قولُ سفيان بن عيينة أنّ الصدقة كانت غيرَ مُحَرَّمة على أولئك الأنبياء، وإنما حرمت على محمد، وانتقد ابنُ عطية (٥/١٤٢) قوله مستندًا إلى السنة بقوله: «وهذا ضعيف، يرده حديث النبي ﷺ في قوله: «نحن معاشر الأنبياء لا تحل لنا الصدقة»». <q>﴿إِنَّ ٱللَّهَ یَجۡزِی ٱلۡمُتَصَدِّقِینَ ۝٨٨﴾</q> - آثار متعلقة بالآية ٣٨١٤١- عن عمر بن عبد العزيز -من طريق عبد الرحمن الطويل- أنّ رجلًا قال له: تصدَّق عَلَيَّ تصدَّق اللهُ عليك بالجنة. فقال: ويحك، إنّ الله لا يتصدَّق، ولكن الله يجزى المتصدقين{50}. (٨/٣٢٠) ٣٨١٤٢- عن عثمان بن الأسود، قال: سمعتُ مجاهد بن جبر، وسُئل: هل يُكْرَهُ أن يقول الرجل في دعائه: اللَّهُمَّ تصدق عَلَيَّ؟ فقال: نعم، إنّما الصدقة لِمَن يبتغى الثواب{51}. (٨/٣٢٠) ٣٨١٤٣- عن الحسن البصري أنّه سمع رجلًا يقول: اللَّهُمَّ، تَصَدَّقْ عَلَيَّ. فقال: إنّ الله لا يَتَصَدَّق، وإنّما يَتَصَدَّق مَن يبغي الثواب، قل: اللَّهُمَّ، أعطِنِي، أو تَفَضَّل عَلَيَّ{52}. (ز) ٣٨١٤٤- عن ثابت بن أسلم البُنانيِّ -من طريق يزيد بن يزيد- قال: قيل لبنى يعقوب: إنّ بمصر رجلًا يُطعِمُ المسكينَ، ويملأ حِجْرَ اليتيم. قالوا: ينبغي أن يكون هذا مِنّا أهل البيت. فنظروا، فإذا هو يوسف بن يعقوب{53}. (٨/٣٢١) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٩٠. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن جرير ١٣/٣١٦، وابن أبي حاتم ٧/٢١٩١.أخرجه ابن جرير ١٣/٣١٨، وابن أبي حاتم ٧/٢١٩١.ثوب خَلَقٌ: بالٍ. لسان العرب (خلق).الغِرارة: الجُوالِق، وعاء من الأوعية. لسان العرب (غرر) (جلق).أخرجه عبد الرزاق ١/٣٢٨، وسعيد بن منصور (١١٤١ - تفسير)، وابن جرير ١٣/٣١٨، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/٢٥١.أخرجه ابن جرير ١٣/٣١٧-٣١٨، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى أبي عبيد، وابن أبي شيبة، وابن المنذر، وأبي الشيخ.السويق: ما يُتخذ من الحنطة والشعير. لسان العرب (سوق).المُقْلُ: ثمر معروف. النهاية (مقل).عزاه السيوطي إلى ابن النجار.أخرجه ابن جرير ١٣/٣١٩، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٢٠.أصله من الفَسْل: وهو الرديء الرَّذِل من كل شيء. النهاية (فسل).أخرجه ابن جرير ١٣/٣١٨-٣١٩، وابن أبي حاتم ٧/٢١٩١-٢١٩٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٣٢٠. وعلَّقه ابن أبي حاتم ٧/٢١٩٢.أخرجه ابن جرير ١٣/٣٢١.أخرجه ابن جرير ١٣/٣٢٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ٥/٢٥١.تفسير الثعلبي ٥/٢٥١.أخرجه سعيد بن منصور (١١٣٩ - تفسير). وعلَّقه ابن أبي حاتم ٧/٢١٩٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٣/٣٢٠، وابن أبي حاتم ٧/٢١٩٢.أخرجه ابن جرير ١٣/٣٢١، وابن أبي حاتم ٧/٢١٩١.أخرجه ابن جرير ١٣/٣١٩-٣٢٠، وابن أبي حاتم ٧/٢١٩١. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى عبد الرزاق، وابن المنذر.أخرجه عبد الرزاق في تفسيره ٢/٣٢٨ من طريق معمر، وابن جرير ١٣/٣٢٣.جاز الدرهم: قُبِل على ما فيه من خَفِي الدّاخِلَة أو قليلها. لسان العرب (جوز).أخرجه ابن جرير ١٣/٣٢٣.تفسير الثعلبي ٥/٢٥١، وتفسير البغوي ٤/٢٧٢.قال ابن جرير في تفسيره ٨/٣٩٠: ومنه قيل للدراهم الرديئة وغيرها من كل شيء: النُّفايَةُ.تفسير مقاتل بن سليمان ٢/٣٤٩.تفسير الثعلبي ٥/٢٥١، وتفسير البغوي ٤/٢٧٢.أخرجه ابن جرير ١٣/٣٢٣، وابن أبي حاتم ٧/٢١٩٢.تفسير الثوري ص١٤٦.أخرجه ابن جرير ١٣/٣٢٣.أخرجه ابن جرير ١٣/٣٢٠. والقراءة شاذة.أخرجه ابن جرير ١٣/٣٢٤.تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٢.أخرجه ابن جرير ١٣/٣٢٤، وابن أبي حاتم ٧/٢١٩٢-٢١٩٣.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن جرير ١٣/٣٢٥-٣٢٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٩٢.تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٢.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن أبي حاتم ٧/٢١٩٢-٢١٩٣، وابن جرير ١٣/٣٢٥ بلفظ: قال: ما سأل نبي قط الصدقة، ولكنهم قالوا: <q>﴿جئنا ببضاعة مزجاة فأوف لنا الكيل وتصدق علينا﴾</q> لا تنقصنا مِن السعر.أخرجه ابن أبي حاتم ٧/٢١٩٢.أخرجه ابن جرير ١٣/٣٢٥.أخرجه ابن أبي حاتم ٧/٢١٩٣.أخرجه ابن جرير ١٣/٣٢٦. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٣.أخرجه ابن أبي حاتم ٧/٢١٩٤-٢١٩٤ (١١٩٣٨).
12,89," <q>﴿قَالَ هَلۡ عَلِمۡتُم مَّا فَعَلۡتُم بِیُوسُفَ وَأَخِیهِ﴾</q> - تفسير ٣٨١٤٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قال لهم يوسف -ورَحِمَهم عند ذلك-: <q>﴿هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</q>{1}. (٨/١٩٩) ٣٨١٤٦- قال محمد بن السائب الكلبي: إنّما قال ذلك حين حكى لإخوته أنّ مالك بن ذعر قال: إنِّي وجدت غلامًا في بئر، مِن حاله كَيْتَ وكَيْت، فابتعته بكذا درهمًا. فقالوا: أيها الملك، نحن بعنا ذلك الغلام. فغاظ يوسفَ ذلك، وأمر بقتلهم، فذهبوا بهم ليقتلوهم، فوَلّى يهوذا وهو يقول: كان يعقوب يحزن ويبكي لِفَقْدِ واحدٍ مِنّا حتى كُفَّ بصرُه، فكيف إذا أتاه قَتْلُ بنيه كلِّهم؟ ثم قالوا له: إن فعلتَ ذلك فابعث بأمتعتنا إلى أبينا، فإنّه بمكان كذا وكذا، فذلك حين رَحِمَهم وبكى، وقال ذلك القول{2}. (ز) ٣٨١٤٧- قال مقاتل بن سليمان: فلمّا سمِع ما ذكروا مِن الضُّرِّ قال لهم: <q>﴿هل علمتم ما فعلتم بيوسف وأخيه﴾</q> يعني: بي، وبأخي بنيامين{3}. (ز) ٣٨١٤٨- عن محمد بن إسحاق -من طريق سلمة- قال: ذُكر لي: أنّهم لَمّا كلموه بهذا الكلام غلبته نفسُه، فارْفَضَّ دمعُه باكيًا، ثم باح لهم بالذي يَكْتُم منهم، فقال: <q>﴿هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</q>. ولم يعن بذكر أخيه ما صنعه هو فيه حين أخذه، ولكن للتفريق بينه وبين أخيه، إذ صنعوا بيوسف ما صنعوا{1}. (ز) <q>﴿إِذۡ أَنتُمۡ جَـٰهِلُونَ ۝٨٩﴾</q> - تفسير ٣٨١٤٩- قال عبد الله بن عباس: إذ أنتم صبيان{5}. (ز) ٣٨١٥٠- قال الحسن البصري: إذ أنتم شباب ومعكم جهلُ الشباب{6}. (ز) ٣٨١٥١- قال مقاتل بن سليمان: <q>﴿إذ أنتم جاهلون﴾</q>، يعني: مُذنِبين{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٣٢٧، وابن أبي حاتم ٧/٢١٩٣.تفسير الثعلبي ٥/٢٥٢، وتفسير البغوي ٤/٢٧٣.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن جرير ١٣/٣٢٧، وابن أبي حاتم ٧/٢١٩٣.تفسير الثعلبي ٥/٢٥٣.تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٣.تفسير مقاتل بن سليمان ٢/٣٤٩.
12,90," <q>﴿قَالُوۤا۟ أَءِنَّكَ لَأَنتَ یُوسُفُۖ قَالَ أَنَا۠ یُوسُفُ وَهَـٰذَاۤ أَخِیۖ قَدۡ مَنَّ ٱللَّهُ عَلَیۡنَاۤۖ إِنَّهُۥ مَن یَتَّقِ وَیَصۡبِرۡ فَإِنَّ ٱللَّهَ لَا یُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٩٠﴾</q> - قراءات ٣٨١٥٢- عن الضَّحّاك بن مُزاحِم، قال: في حرف عبد الله [بن مسعود]: (قالَ أنا يُوسُفُ وهَذَآ أخِي بَيْنِي وبَيْنَهُ قُرْبى قَدْ مَنَّ اللهُ عَلَيْنا){1}. (٨/٣٢١) ٣٨١٥٣- عن الأعمش، قال: قرأ يحيى بن وثّاب: ‹إنَّكَ لَأَنتَ يُوسُفُ› بهمزة واحدة{2}٣٤٤٨. (٨/٣٢١) ٣٤٤٨ وجّه ابنُ جرير (١٣/٣٢٨) هذه القراءة، فقال: «وروي عن ابن محيصن أنه قرأ: ‹إنَّكَ لَأَنتَ يُوسُفُ› على الخبر، لا على الاستفهام». وبنحوه قال ابنُ عطية (٥/١٤٤). ثم رجّح ابنُ جرير مستندًا إلى إجماع الحجة من القراء قراءة الاستفهام بقوله: «والصواب من القراءة في ذلك عندنا قراءةُ مَن قرأه بالاستفهام، لإجماع الحجة من القراء عليه». وبنحوه قال ابنُ كثير (٨/٦٩) مستندًا إلى الدلالة العقلية، فقال: «لأنّ الاستفهام يدل على الاستعظام، أي: أنهم تعجبوا من ذلك أنهم يترددون إليه من سنتين وأكثر، وهم لا يعرفونه، وهو مع هذا يعرفهم ويكتم نفسه، فلهذا قالوا على سبيل الاستفهام: <q>﴿أئنك لأنت يوسف قال أنا يوسف وهذا أخي﴾</q>». <q>﴿قَالُوۤا۟ أَءِنَّكَ لَأَنتَ یُوسُفُۖ﴾</q> - تفسير ٣٨١٥٤- عن عبد الله بن عباس -من طريق الضحاك-: لَمّا قال هذا القولَ تَبَسَّم يوسفُ، فرأوا ثناياه كاللؤلؤ المنظوم، فشبهوه بيوسف، فقالوا استفهامًا: <q>﴿أإنك لأنت يوسف﴾</q>؟{3}. (ز) ٣٨١٥٥- عن عبد الله بن عباس -من طريق عطاء-: إنّ إخوة يوسف لم يعرفوه حتى وضع التاجَ عن رأسه، وكان له في قرنه علامةٌ، وكان ليعقوب مثلها، ولإسحاق مثلها، ولسارة مثلها، شبه الشامة، فعرفوه، فقالوا: أئنك لأنت يوسف؟{4}. (ز) ٣٨١٥٦- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا قال لهم ذلك -يعني: قوله: <q>﴿هل علمتم ما فعلتم بيوسف وأخيه إذ أنتم جاهلون﴾</q>؟- كشف الغِطاء، فعرفوه، فقالوا: <q>﴿أئنك لأنت يوسف﴾</q> الآية{5}. (ز) <q>﴿قَالَ أَنَا۠ یُوسُفُ وَهَـٰذَاۤ أَخِیۖ قَدۡ مَنَّ ٱللَّهُ عَلَیۡنَاۤۖ﴾</q> - تفسير ٣٨١٥٧- قال مقاتل بن سليمان: <q>﴿قالوا أإنك لأنت يوسف قال أنا يوسف وهذا أخي قد من الله علينا﴾</q>، يقول: قد أنعم الله علينا{6}. (ز) <q>﴿إِنَّهُۥ مَن یَتَّقِ وَیَصۡبِرۡ فَإِنَّ ٱللَّهَ لَا یُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٩٠﴾</q> - تفسير ٣٨١٥٨- قال عبد الله بن عباس:يتقي الزِّنا، ويصبر على العزوبة{4}. (ز) ٣٨١٥٩- عن إبراهيم النخعي -من طريق منصور- <q>﴿إنه من يتق ويصبر﴾</q>، قال: مَن يَتَّقِ الزِّنا، ويصبر على العُزُوبة{8}٣٤٤٩. (ز) ٣٤٤٩ ذكر ابنُ عطية (٥/١٤٤) قول مجاهد، وإبراهيم النخعي، ثم قال مُعَلِّقًا: «ومقصد اللفظ إنما هو العموم في العظائم، وإنّما قال هذان ما خصصا لأنّها كانت من نوازله، ولو فرضنا نزول غيرها به لاتقى وصبر». ٣٨١٦٠- عن مجاهد بن جبر -من طريق ليث- قوله: <q>﴿إنه من يتق ويصبر﴾</q>، يقول: مَن يَتَّقِ معصية الله، ويصبر على السجن{9}٣٤٥٠. (ز) ٣٤٥٠ لم يذكر ابنُ جرير (١٣/٣٢٨) غير قول مجاهد. ٣٨١٦١- عن الربيع بن أنس -من طريق أبي جعفر- قال: مكتوب في الكتاب الأول أنّ الحاسدَ لا يَضُرُّ بحسده إلا نفسه، ليس ضارًّا مَن حَسَد، وأنّ الحاسد يَنقُصُه حَسَدُه، وأنّ المحسود إذا صبر نجّاه الله بصبره؛ لأنّ الله يقول: <q>﴿إنه من يتق ويصبر فإن الله لا يضيع أجر المحسنين﴾</q>{10}. (٨/٣٢١) ٣٨١٦٢- قال مقاتل بن سليمان: <q>﴿إنه من يتق﴾</q> الزِّنا، <q>﴿ويصبر﴾</q> على الأذى؛ <q>﴿فإن الله لا يضيع أجر المحسنين﴾</q> يعني: جزاء مَن أحسن حتى يوفيه جزاءَه{6}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ. وهي قراءة شاذة. انظر: تفسير الماوردي ٣/٧٤.عزاه السيوطي إلى أبي الشيخ. وهي قراءة متواترة، قرأ بها ابن كثير، وأبو جعفر، وقرأ بقية العشرة: <q>﴿أإنَّكَ﴾</q> بهمزتين على الاستفهام. انظر: الإتحاف ص٣٣٥.تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٣.تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٤.أخرجه ابن جرير ١٣/٣٢٨، وابن أبي حاتم ٧/٢١٩٤.تفسير مقاتل بن سليمان ٢/٣٤٩.تفسير الثعلبي ٥/٢٥٣، وتفسير البغوي ٤/٢٧٤.أخرجه ابن أبي حاتم ٧/٢١٩٤. وذكر السيوطي مثله في الدر ٨/٣٢١، وعزاه إلى أبي الشيخ، ولم يذكر القائل! ولعله سقط من النسخ، فقد يكون إبراهيم النخعي كما في هذه الرواية، وقد يكون تابعًا للرواية التي قبله في الدر، وهي أثر الضحاك السابق في حكاية قراءة ابن مسعود، ويعضده أنه من رواية أبي الشيخ أيضًا.أخرجه ابن جرير ١٣/٣٢٨.أخرجه ابن أبي حاتم ٧/٢١٩٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٩.
12,91," <q>﴿قَالُوا۟ تَٱللَّهِ لَقَدۡ ءَاثَرَكَ ٱللَّهُ عَلَیۡنَا﴾</q> - تفسير ٣٨١٦٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قالوا تالله لقد ءاثرك الله علينا﴾</q>: وذلك بعدما عرَّفهم نفسَه، لَقُوا رجلًا حليمًا{1}. (٨/٣٢٢) ٣٨١٦٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿قالوا: أءِنك لأنت يوسف قال: أنا يوسف وهذا أخى قد مَنَّ الله علينا﴾</q>. فاعتذروا إليه، وقالوا: <q>﴿تالله لقد آثرك الله علينا وإن كنا لخاطئين﴾</q>{2}. (٨/١٩٩) ٣٨١٦٥- قال مقاتل بن سليمان: <q>﴿قالوا تالله﴾</q> يعني: واللهِ، <q>﴿لقد آثرك الله علينا﴾</q> يعني: اختارك، -كقوله في طه [٧٢]: <q>﴿لن نؤثرك﴾</q> يعني: لن نختارك- علينا عند يعقوب، وأعطاك ومَلَّكك المُلْك{3}. (ز) ٣٨١٦٦- عن محمد بن إسحاق -من طريق سلمة- <q>﴿آثرك الله علينا﴾</q>، أي: فَضَّلك اللهُ علينا{4}. (ز) <q>﴿وَإِن كُنَّا لَخَـٰطِـِٔینَ ۝٩١﴾</q> - تفسير ٣٨١٦٧- قيل لعبد الله بن عباس: كيف قالوا: إنّا كُنّا خاطئين وقد تَعَمَّدوا لذلك؟ فقال: أخطأوا الحقَّ وإن تَعَمَّدوا. كلُّ مَن أتى ذنبًا كذلك يخطئ المنهاج الذي عليه مِن الحق حتى يقع في الشُّبْهَة والمعصية{5}. (ز) ٣٨١٦٨- قال مقاتل بن سليمان: <q>﴿وإن كنا لخاطئين﴾</q> في أمرِك. فأقَرُّوا بخطيئتهم{3}. (ز) ٣٨١٦٩- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿قالوا تالله لقد آثرك الله علينا وإن كنا لخاطئين﴾</q> فيما كُنّا صنَعْنا بك{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٣٣٠، وابن أبي حاتم ٧/٢١٩٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٣٢٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن أبي حاتم ٧/٢١٩٤.تفسير الثعلبي ٥/٢٥٤.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن جرير ١٣/٣٢٩، وابن أبي حاتم ٧/٢١٩٤.
12,92," <q>﴿قَالَ لَا تَثۡرِیبَ عَلَیۡكُمُ ٱلۡیَوۡمَۖ﴾</q> - تفسير ٣٨١٧٠- عن مجاهد بن جبر -من طريق أبي يحيى- في قوله: <q>﴿لا تثريب﴾</q>، قال: لا إباء{1}. (٨/٣٢٢) ٣٨١٧١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿لا تثريب﴾</q>، قال: لا تَعْيِيرَ{2}. (٨/٣٢٢) ٣٨١٧٢- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: لَقُوا رجلًا حلِيمًا لم يَبُثَّ ولم يُثَرِّبْ عليهم أعمالَهم{3}. (٨/٣٢٢) ٣٨١٧٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: اعتذروا إلى يوسف، فقال: <q>﴿لا تثريب عليكم اليوم﴾</q>. يقول: لا أذكر لكم ذنبَكم{4}. (٨/١٩٩) ٣٨١٧٤- قال مقاتل بن سليمان: قال يوسف: <q>﴿لا تثريب عليكم اليوم﴾</q>، يقول: لا تَعْيِير عليكم، لم يُثَرِّب عليهم بفعلهم القبيح{5}. (ز) ٣٨١٧٥- عن محمد بن إسحاق -من طريق سلمة- <q>﴿قال لا تثريب عليكم اليوم﴾</q>، أي: لا تأنيبَ عليكم اليوم عندي فيما صنعتم{6}. (ز) ٣٨١٧٦- عن سفيان بن عيينة -من طريق عبد الله بن الزبير- في قوله: <q>﴿لا تثريب عليكم اليوم﴾</q>، قال: لا تَعْيِير عليكم{7}٣٤٥١. (ز) ٣٤٥١ علّق ابنُ عطية (٥/١٤٦) على ما جاء في قول سفيان وغيره، فقال: «وقد عبَّر بعض الناس عن التثريب بالتعيير، ومنه قول النبي ﵇: «إذا زَنَت أمةُ أحدكم فليجلدها، ولا يُثَرِّب»، أي: لا يُعَيِّر». <q>﴿یَغۡفِرُ ٱللَّهُ لَكُمۡۖ وَهُوَ أَرۡحَمُ ٱلرَّ ٰ⁠حِمِینَ ۝٩٢﴾</q> - تفسير ٣٨١٧٧- قال مقاتل بن سليمان: <q>﴿يغفر الله لكم﴾</q> ما فعلتم، <q>﴿وهو أرحم الراحمين﴾</q> مِن غيره{5}. (ز) ٣٨١٧٨- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿يغفر الله لكم وهو أرحم الراحمين﴾</q> حين اعترفوا بذنبهم{9}٣٤٥٢. (ز) ٣٤٥٢ ذكر ابنُ عطية (٥/١٤٦-١٤٧) عن بعض القراء أنّه وقف على قوله: <q>﴿عليكم﴾</q>، وابتدأ بقوله: <q>﴿اليوم يغفر الله لكم﴾</q>. وذكر أنّ أكثرهم وقف على قوله: <q>﴿اليَوْمَ﴾</q>، وابتدأ بقوله: <q>﴿يَغْفِرُ اللَّهُ لَكُمْ﴾</q> على جهة الدعاء. ورجّح الثاني مستندًا إلى اللغة، والدلالة العقلية، فقال: «وهو الصحيح، و<q>﴿اليَوْمَ﴾</q> ظرف، فعلى هذا فالعامل فيه ما يتعلق به <q>﴿عَلَيْكُمُ﴾</q>، تقديره: لا تثريب ثابت أو مستقر عليكم اليوم. وهذا الوقف أرجحُ في المعنى؛ لأنّ الآخَر فيه حكم على مغفرة الله، اللهم إلا أن يكون ذلك بوحي». ثم بَيَّن أنّ قوله: <q>﴿اذهبوا بقميصي هذا فألقوه على وجه أبي يأت بصيرا﴾</q> يُقَوِّي «أنّ هذا كله بوحي وإعلام من الله». <q>﴿یَغۡفِرُ ٱللَّهُ لَكُمۡۖ وَهُوَ أَرۡحَمُ ٱلرَّ ٰ⁠حِمِینَ ۝٩٢﴾</q> - آثار متعلقة بالآية ٣٨١٧٩- عن عمرو بن شعيب، عن أبيه، عن جدِّه، قال: لَمّا افتتح رسولُ الله ﷺ مكة التفت إلى الناس، فقال: «ماذا تقولون؟ وماذا تظنون؟». قالوا: ابن عم كريم. فقال: <q>﴿لا تثريب عليكم اليوم يغفر الله لكم﴾</q>{10}.(٨/٣٢٢) (٨/٣٢٢) ٣٨١٨٠- عن أبي هريرة، أنّ رسول الله ﷺ لَمّا فتح مكة طاف بالبيت، وصَلّى ركعتين، ثم أتى الكعبة، فأخذ بعِضادَتَي{11} الباب، فقال: «ماذا تقولون؟ وماذا تظنون؟». قالوا: نقول: ابن أخ وابن عم حليم رحيم. فقال: «أقول كما قال يوسف: <q>﴿لا تثريب عليكم اليوم يغفر الله لكم وهو أرحم الراحمين﴾</q>». فخرجوا كأنّما نُشِرُوا من القبور، فدخلوا في الإسلام{12}. (٨/٣٢٣) ٣٨١٨١- عن عبد الله بن عباس: أنّ رسول الله ﷺ لَمّا فتح مكة صعد المنبر، فحمد الله، وأثنى عليه، ثم قال: «يا أهل مكة، ماذا تظُنُّون؟ ماذا تقولون؟». قالوا: نظنُّ خيرًا، ونقول خيرًا في ابن عم كريم، قد قدرت. قال: «فإنِّي أقول كما قال أخي يوسف: <q>﴿لا تثريب عليكم اليوم يغفر الله لكم وهو أرحم الراحمين﴾</q>»{13}. (٨/٣٢٢) ٣٨١٨٢- عن الزهري، عن بعض آل عمر بن الخطاب: أنّ عمر بن الخطاب لَمّا كان يوم الفتح ورسول الله ﷺ بمكة أرسل إلى صفوان بن أمية بن خلف، وإلى أبي سفيان بن حرب، وإلى الحارث بن هشام، قال عمر: قد أمكن الله منهم، أُعَرِّفهم بما صنعوا. حتى قال رسول الله ﷺ: «مَثَلِي ومَثَلُكم كما قال يوسف لإخوته: <q>﴿لا تثريب عليكم اليوم يغفر الله لكم وهو أرحم الراحمين﴾</q>». قال عمر: فانتَضَحْتُ حياءً مِن رسول الله ﷺ؛ كراهيةَ أن يكون بَدَرَ مِنِّي ولقد قال لهم رسولُ الله ما قال{14}. (ز) ٣٨١٨٣- عن مالك بن دينار، قال: أرسل رجل إلى عشرة مِن أهل البصرة أنا فيهم والحسن [البصري]، فسلمنا عليه، ثم إنّ الحسن حمِد الله، وأثنى عليه، وذكر ما شاء الله أن يذكر، حتى أتى على ذِكْر يوسف، وما ارتكب منه إخوتُه، فعرَّفهم نفسه، ثم استقبلهم بالعفو عنهم: <q>﴿لا تثريب عليكم اليوم يغفر الله لكم﴾</q>. فرضي الله به منه عملًا، وأثبته في كتابه؛ ليُؤْخَذ به مِن بعدِه، فقال الأمير: لو صار أن أُجَلِّلكُم{15} بِبُرْدي{16} هذا ما أصابكم شيء أبدًا{1}. (ز) ٣٨١٨٤- عن أبي عمران الجوني، قال: أما -واللهِ- ما سمعنا بعَفْوٍ قطُّ مثل عَفْوِ يوسف{18}. (٨/٣٢٣) ٣٨١٨٥- عن عطاء الخراساني -من طريق رجاء بن أبي سلمة- قال: طلب الحوائج إلى الشباب أسهلُ منها عند الشيوخ، ألم تر إلى قول يوسف: <q>﴿لا تثريب عليكم اليوم﴾</q>. وقال يعقوب ﵇: <q>﴿سوف أستغفر لكم ربى﴾</q>؟{19}. (٨/٣٢٣) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٩٥.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن أبي حاتم ٧/٢١٩٤. وعزاه السيوطي إلى أبي الشيخ. وأخرجه ابن جرير ١٣/٣٣٠ مختصرًا من طريق سعيد بن أبي عروبة.أخرجه ابن جرير ١٣/٣٣١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن جرير ١٣/٣٣١، وابن أبي حاتم ٧/٢١٩٥.أخرجه ابن جرير ١٣/٣٣٠، وابن أبي حاتم ٧/٢١٩٥ من طريق ابن أبي عمر.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن جرير ١٣/٣٣١، وابن أبي حاتم ٧/٢١٩٥-٢١٩٦ وفيه عن محمد بن إسماعيل، وهو خطأ.أخرجه البيهقي في دلائل النبوة ٥/٨٦-٨٧، وعزاه السيوطي إلى أبي الشيخ من طريق عمرو بن شعيب، وأخرجه ابن حبان ٧/٥٩٤-٥٩٥ (٥٩٦٤) من طريق آخر عن ابن عمرو مطولًا. وروي بألفاظ متفرقة ومختلفة طولًا وقصرًا بإسناد عمرو بن شعيب. وإسناده حسن، وله شواهد ستأتي بعده.عِضادتا الباب: ناحيتاه، وهما الخشبتان المنصوبتان عن يمين الداخل منه وشماله. لسان العرب (عضد).أخرجه النسائي في الكبرى ١٠/١٥٤-١٥٥ (١١٢٣٤) بنحوه مطولًا، والبيهقي في الدلائل ٥/٥٧. وقال العراقي في تخريج أحاديث الإحياء ص١٠٨٠: «رواه ابن الجوزي في الوفاء من طريق ابن أبي الدنيا، وفيه ضعف».عزاه السيوطي إلى ابن مردويه. وأورده الثعلبي ٥/٢٥٤ بنحوه.أخرجه ابن سعد في الطبقات الكبرى ٢/١٠٧، وأبو الشيخ في أخلاق النبي ﷺ (٨٢)، وابن زنجويه في كتابه الأموال (٤٥٥)، وابن عساكر في تاريخ دمشق ٣/٣٨٤، ١١/٤٩٥، ٢٤/١١٠-١١١. كلهم من طريق عبد الله بن المبارك، عن معمر، عن الزهري، عن بعض آل عمر به. وإسناده صحيح إلى الزهري، لكن الزهري أبهم مَن حدّثه، وهم بعض آل عمر؛ ففي الإسناد جهالة.أي: أغطيكم. لسان العرب (جلل).البُرْد: نوع من الثياب معروف. النهاية (برد).أخرجه ابن أبي حاتم ٧/٢١٩٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٧/٢١٩٥، وابن أبي الدنيا في كتاب اصطناع المعروف -موسوعة الإمام ابن أبي الدنيا ٨/٥١٧ (١١)- من طريق رجاء بن أبي سلمة. وعزاه السيوطي إلى أبي الشيخ.
12,93," <q>﴿ٱذۡهَبُوا۟ بِقَمِیصِی هَـٰذَا فَأَلۡقُوهُ عَلَىٰ وَجۡهِ أَبِی یَأۡتِ بَصِیرࣰا﴾</q> - تفسير ٣٨١٨٦- عن أنس بن مالك، أنّ رسول الله ﷺ قال في قوله: <q>﴿اذهبوا بقميصي هذا﴾</q>: «إنّ نُمرودَ لَمّا ألقى إبراهيم في النار نزل إليه جبريل بقميص من الجنة، وطِنفِسَةٍ{1} مِن الجنة، فألبسه القميصَ، وأقعده على الطِّنْفِسَة، وقعد معه يتحدث، فأوحى الله إلى النار: <q>﴿كونى بردًا وسلامًا﴾</q> [الأنبياء:٦٩]. ولولا أنه قال: <q>﴿وسلامًا﴾</q> لآذاه البرد، ولقتله البرد»{2}. (٨/٣٢٣) ٣٨١٨٧- عن عبد الله بن عباس، قال: قال رجل للنبي ﷺ: يا خيرَ البشر. فقال: «ذاك يوسف صِدِّيق الله، ابن يعقوب إسرائيل الله، ابن إسحاق ذبيح الله، ابن إبراهيم خليل الله. إنّ الله كسا إبراهيم ثوبًا مِن الجنة، فكساه إبراهيم إسحاق، فكساه إسحاقُ يعقوبَ، فأخذه يعقوبُ فجعله في قَصَبَة حديد، وعلَّقه في عُنُق يوسف، ولو علم إخوتُه إذ ألقوه في الجُبِّ لأخذوه، فلمّا أراد الله أن يَرُدَّ يوسفَ على يعقوب -وكان بين رؤياه وتعبيرها أربعين سنة- أمر البشير أن يُبَشِّره مِن ثمان مراحل، فوجد يعقوبُ ريحه، فقال: <q>﴿إنى لأجد ريح يوسف لولا أن تُفَندُون﴾</q>. فلمّا ألقاه على وجهه ارتدَّ بصيرًا، وليس يقع شيءٌ يقع مِن الجنة على عاهة من عاهات الدنيا إلا أبرأها بإذن الله تعالى»{3}. (٨/٣٢٤) ٣٨١٨٨- قال مجاهد بن جبر: أمره جبريلُ أن يرسلَ إليه قميصَه، وكان ذلك القميصُ قميصَ إبراهيم ﵇، وذلك أنّه جُرِّد مِن ثيابه وأُلْقِي في النار عُريانًا، فأتاه جبريل بقميص مِن حرير الجنة، فألبسه إيّاه، فكان ذلك القميصُ عند إبراهيم ﵇، فلمّا مات ورِثه إسحاق، فلمّا مات ورثه يعقوب، فلما شَبَّ يوسفُ جعل يعقوبُ ذلك القميصَ في قصبة، وسدَّ رأسها، وعلَّقها في عُنُقه؛ لِما كان يخاف عليه مِن العين، فكان لا يفارقه. فلَمّا أُلْقِي في البئر عريانًا جاءه جبريل ﵇ وعلى يوسف ذلك التعويذ، فأخرج القميص منه، وألبسه إياه، ففي هذا الوقتِ جاء جبريل ﵇ إلى يوسف ﵇، وقال: أرْسِلْ ذلك القميص؛ فإنّ فيه ريحَ الجنة، لا يقع على سقيم ولا مُبْتَلًى إلا عُوفِي. فدفع يوسفُ ذلك القميص إلى إخوته، وقال: ألقوه على وجه أبي يأت بصيرًا{4}. (ز) ٣٨١٨٩- قال الضَّحّاك بن مُزاحِم: كان ذلك القميصُ مِن نَسْجِ الجنَّة{4}. (ز) ٣٨١٩٠- قال الحسن البصري: لم يعلم أنه يعود بصيرًا إلا بعد أن أعلمه الله ﷿{6}. (ز) ٣٨١٩١- عن وهب بن مُنَبِّه، قال: لَمّا كان مِن أمرِ إخوة يوسف ما كان كتب يعقوبُ إلى يوسف وهو لا يعلم أنّه يوسف: بسم الله الرحمن الرحيم، من يعقوب بن إسحاق بن إبراهيم إلى عزيز آل فرعون، سلام عليك، فإنِّي أحمَدُ إليك اللهَ الذي لا إله إلا هو، أما بعد، فإنّا أهل بيت مُولَعٌ بنا أسباب البلاء؛ كان جَدي إبراهيم خليل الله أُلْقِي في النار في طاعة ربه، فجعلها الله عليه بردًا وسلامًا. وأمر الله جَدِّي أن يذبح له أبي، ففداه الله بما فداه به. وكان لي ابنٌ، وكان مِن أحب الناس إلَيَّ، ففقدته، فأذهب حزني عليه نورَ بصري، وكان له أخ مِن أُمَّه، كنتُ إذا ذكرتُه ضممتُه إلى صدري، فأذهب عنِّى بعضَ وجدي، وهو المحبوس عندك في السرقة، وإنِّي أُخبرُك أنِّي لم أسرق ولم ألِد سارقًا. فلمّا قرأ يوسف ﵇ الكتاب بكى، وصاح، وقال: <q>﴿اذهبوا بقميصى هذا فألقوه على وجه أبى يأت بصيرًا﴾</q>{7}. (٨/٣٢٢) ٣٨١٩٢- عن المطلب بن عبد الله بن حنطب -من طريق الحكم- قال: لَمّا أُلقي إبراهيم في النار كساه الله تعالى قميصًا مِن قُمُصِ الجنة، فكساه إبراهيم إسحاق، وكساه إسحاق يعقوب، وكساه يعقوب يوسف، فطواه، وجعله في قصبة فضة، فجعله في عنقه، وكان في عنقه حين أُلْقِي في الجُبِّ، وحين سُجِن، وحين دخل عليه إخوتُه، وأخرج القميص من القصبة، فقال: <q>﴿اذهبوا بقميصى هذا فألقوه على وجه أبى يأت بصيرًا﴾</q>. فشمَّ يعقوبُ ﵇ ريحَ الجنة وهو بأرض كنعان بفلسطين، فقال: <q>﴿إنى لأجد ريح يوسف﴾</q>{8}٣٤٥٣. (٨/٣٢٥) ٣٤٥٣ ذكر ابنُ عطية (٥/١٤٧) نحو ما جاء في هذا الأثر وغيره في صفة القميص، وانتقده مستندًا إلى الدلالة العقلية، فقال: «وروي أن هذا القميص كان لإبراهيم، كساه الله إيّاه حين خرج من النار، وكان من ثياب الجنة، وكان بعد لإسحاق، ثم ليعقوب، ثم كان دفعه ليوسف، فكان عنده في حفاظ من قصب. وهذا كله يحتاج إلى سند، والظاهر أنّه قميص يوسف الذي هو منه بمنزلة قميص كل أحد، وهكذا تبين الغرابة في أن وجد ريحه من بعد، ولو كان مِن قمص الجنة لما كان في ذلك غرابة، ولوجده كلُّ أحَد». ٣٨١٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثُمَّ قال: ما فعل أبي بعدي؟ قالوا: لَمّا فاته بنيامين عَمِي مِن الحزن. فقال: <q>﴿اذهبوا بقميصي هذا فألقوه على وجه أبى يأت بصيرًا وأتوني بأهلكم أجمعين﴾</q>{9}. (٨/١٩٩) ٣٨١٩٤- قال مقاتل بن سليمان: <q>﴿اذهبوا بقميصي هذا فألقوه على وجه أبي يأت بصيرا﴾</q> بعد البياض{10}. (ز) <q>﴿وَأۡتُونِی بِأَهۡلِكُمۡ أَجۡمَعِینَ ۝٩٣﴾</q> - تفسير ٣٨١٩٥- عن عبد الله بن مسعود -من طريق أبي إسحاق- قال: كان أهلُه حين أُرْسِل إليهم فأتوا مصر ثلاثة وتسعين إنسانًا، رجالهم أنبياء، ونساؤهم صِدِّيقات، واللهِ، ما خرجوا مع موسى ﵇ حتى بلغوا ستمائة ألف وسبعين ألفًا{11}. (٨/٣٢٥) ٣٨١٩٦- عن الربيع بن أنس -من طريق أبي جعفر- قال: خرج يعقوبُ ﵇ إلى يوسف ﵇ بمصر في اثنين وسبعين مِن ولده وولد ولده، فخرجوا منها مع موسى ﵇ وهم ستمائة ألف{12}. (٨/٣٢٦) ٣٨١٩٧- قال مقاتل بن سليمان: <q>﴿وأتوني بأهلكم أجمعين﴾</q>، فلا يَبْقى منكم أحدٌ{10}. (ز) ",footnotes:1:الطِّنْفِسَة: البساط الذي له خمل رقيق. النهاية (طنفس).أخرجه الواحدي في الوسيط ٣/٢٤٤، ومن طريقه ابن عساكر ٦/١٨٨ بنحوه. من حديث أنس بن مالك به، وعزاه السيوطي إلى أبي الشيخ. وفي إسناده عباد بن كثير؛ قال البخاري: تركوه. وقال النسائي: متروك، وضعفه غير واحد. فالإسناد ضعيف.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٥٤، وتفسير البغوي ٤/٢٧٥.تفسير الثعلبي ٥/٢٥٤، وتفسير البغوي ٤/٢٧٥.تفسير البغوي ٤/٢٧٥.عزاه السيوطي إلى الحكيم الترمذي، وأبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٩٦.أخرجه ابن جرير ١٣/٣٣٢، وابن أبي حاتم ٧/٢١٩٦.تفسير مقاتل بن سليمان ٢/٣٤٩.أخرجه ابن أبي حاتم ٧/٢١٩٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٧/٢٢٠١ بلفظ: من ولده.تفسير مقاتل بن سليمان ٢/٣٤٩.
12,94," <q>﴿وَلَمَّا فَصَلَتِ ٱلۡعِیرُ قَالَ أَبُوهُمۡ إِنِّی لَأَجِدُ رِیحَ یُوسُفَۖ﴾</q> - تفسير ٣٨١٩٨- عن عبد الله بن عباس -من طريق ابن أبي الهذيل- في قوله: <q>﴿ولما فصلت العير﴾</q> قال: لَمّا خرجت العيرُ هاجَتْ ريحٌ، فجاءت يعقوبَ بريحِ قميصِ يوسف، قال: <q>﴿إنى لأجد ريح يوسف﴾</q>. قال: فوجد ريحَه مِن مسيرة ثمانية أيام{1}. (٨/٣٢٦) ٣٨١٩٩- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿إنى لأجد ريح يوسف﴾</q>، قال: وجد ريحه مِن مسيرة عشرة أيام{2}. (٨/٣٢٦) ٣٨٢٠٠- عن عبد الله بن عباس -من طريق ابن أبي الهذيل- أنّه سُئل: مِن كم وجَد يعقوب ﵇ ريح القميص؟ قال: وجده مِن مسيرة ثمانين فرسخًا{3}. (٨/٣٢٧) ٣٨٢٠١- عن عبد الله بن عباس -من طريق مجاهد- قال: وجد يعقوبُ ﵇ ريح يوسف من مسيرة ستة أيام{4}. (٨/٣٢٧) ٣٨٢٠٢- قال مجاهد بن جبر -من طريق السدي، عن أبيه-: أصاب يعقوبَ ريحُ يوسف مِن مسيرة ثلاثة أيام{5}. (ز) ٣٨٢٠٣- عن الحسن البصري، قال: وجد ريحَ قميصه مِن مسيرة شهر{6}. (٨/٣٢٧) ٣٨٢٠٤- عن الحسن البصري -من طريق قتادة-: ذُكِر لنا: أنّه كان بينهما يومئذ ثمانون فرسخًا؛ يوسف بأرض مصر، ويعقوب بأرض كنعان، وقد أتى لذلك زمان طويل{7}. (ز) ٣٨٢٠٥- عن محمد بن كعب القرظي، قال: وجَدَ ريحَه مِن مسيرة سبعة أيام{8}. (٨/٣٢٧) ٣٨٢٠٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿ولما فصلت العير﴾</q> مِن مصر مُنَطَلِقةً إلى الشام وجد يعقوبُ ريح يوسف، فقال لبَنِي بنيه: <q>﴿إنى لأجد ريح يوسف لولا أن تفندون﴾</q>{9}. (٨/١٩٩) ٣٨٢٠٧- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿إني لأجد ريح يوسف﴾</q>، قال: بلغنا: أنّه كان بينهم يومئذ ثمانون فرسخًا. وقال: <q>﴿إني لأجد ريح يوسف﴾</q> وكان قد فارقه قبل ذلك سبعًا وسبعين سنة{7}٣٤٥٤. (ز) ٣٤٥٤ علّق ابنُ عطية (٥/١٤٧) على قول ابن جريج بقوله: «وهذا قريب من الأول». يعني: قول ابن عباس من طريق ابن أبي هذيل. ٣٨٢٠٨- قال مقاتل بن سليمان: <q>﴿ولما فصلت العير﴾</q> مِن مصر إلى كنعان ثمانين فرسخًا <q>﴿قال أبوهم﴾</q> يعقوب لبني بنيه: <q>﴿إني لأجد ريح يوسف لولا أن تفندون﴾</q>{11}. (ز) ٣٨٢٠٩- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا فصلتِ العِيرُ مِن مصر اسْتَرْوَحَ يعقوبُ ريحَ يوسف، فقال لِمَن عنده مِن ولده: <q>﴿إني لأجد ريح يوسف لولا أن تفندون﴾</q>{12}. (ز) ٣٨٢١٠- عن أبي شريح، عن أبي أيوب الهوزني حدَّثه، قال: استأذَنَتِ الريحُ أن تأتي يعقوبَ بريح يوسف حين بعث بالقميص إلى أبيه قبل أن يأتيه البشير، ففعل، قال يعقوب: <q>﴿إني لأجد ريح يوسف لولا أن تفندون﴾</q>{13}. (ز) <q>﴿لَوۡلَاۤ أَن تُفَنِّدُونِ ۝٩٤﴾</q> - تفسير ٣٨٢١١- عن عبد الله بن عباس -من طريق ابن أبي الهذيل- في قوله: <q>﴿لولا أن تفندون﴾</q>: تُسَفِّهون{14}. (٨/٣٢٦) ٣٨٢١٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لولا أن تفندون﴾</q>، يقول: تُجَهِّلون{15}. (٨/٣٢٧) ٣٨٢١٣- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿لولا أن تفندون﴾</q>، قال: تُكَذِّبون{16}. (٨/٣٢٧) ٣٨٢١٤- عن سعيد بن جبير -من طريق سالم- <q>﴿لولا أن تفندون،﴾</q>، قال: تُكَذِّبون{17}. (ز) ٣٨٢١٥- قال عطاء بن يسار: تُضَعِّفون{18}. (ز) ٣٨٢١٦- عن مجاهد بن جبر -من طريق خُصيف- <q>﴿لولا أن تفندون﴾</q>، قال: تُسَفِّهون{19}. (ز) ٣٨٢١٧- قال ابن جُرَيج: بلغني عن مجاهد، قال: تُكَذِّبون{17}. (ز) ٣٨٢١٨- عن مجاهد بن جبر، في قوله: <q>﴿لولا أن تفندون﴾</q>، قال: تُهَرِّمون؛ تقولون: قد ذهب عقلُك{21}. (٨/٣٢٧) ٣٨٢١٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد، وجُوَيْبِر- قال: لولا أن تُكَذِّبون{17}. (ز) ٣٨٢٢٠- قال الضحاك بن مزاحم: تُهَرِّمون، فتقولون: شيخ كبير قد خرف، وذهب عقلُه{5}. (ز) ٣٨٢٢١- عن الحسن البصري -من طريق قتادة- قال: تُهَرِّمون{24}. (ز) ٣٨٢٢٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لولا أن تفندون﴾</q>، يقول: لولا أن تُسَفِّهون{25}. (ز) ٣٨٢٢٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿لولا أن تفندون﴾</q>، قال: لولا أن تُسَفِّهون؛ تُهَرِّمون{26}. (ز) ٣٨٢٢٤- عن عطاء [بن أبي رباح] -من طريق عبد الملك بن أبي سليمان- <q>﴿لولا أن تفندون﴾</q>، قال: لولا أن تُكذِّبون؛ لولا أن تُسَفِّهون{27}. (ز) ٣٨٢٢٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لولا أن تُهَرِّمون، وتُكَذِّبون{17}. (ز) ٣٨٢٢٦- عن الربيع [بن أنس]، في قوله: <q>﴿لولا أن تفندون﴾</q>، قال: لولا أن تُحَمِّقُون{29}. (٨/٣٢٨) ٣٨٢٢٧- قال مقاتل بن سليمان: <q>﴿لولا أن تفندون﴾</q>، يعني: لولا أن تُجَهِّلون{11}. (ز) ٣٨٢٢٨- عن محمد بن إسحاق -من طريق سلمة- <q>﴿لولا أن تفندون﴾</q>، يقول: لولا أن تُضَعِّفوني{17}. (ز) ٣٨٢٢٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في الآية، قال: المُفَنَّد: الذي ليس له عقل. يقولون: لا يعقل. قال: وقال الشاعر: مهلًا فإنّ مِن العقول مُفَنَّدا{32}٣٤٥٥. (٨/٣٢٨) ٣٤٥٥ اختُلِف في قوله تعالى: <q>﴿لولا أن تفندون﴾</q> على أقوال: الأول: تسفهون. الثاني: تكذبون. الثالث: تهرمون. وقد رجّح ابنُ جرير (١٣/٣٣٦-٢٤١ بتصرف) العموم، فقال: "وأمّا قوله: <q>﴿لولا أن تفندون﴾</q> فإنه يعني: لولا أن تعنفوني، وتعجزوني، وتلوموني، وتكذبوني، ومنه قول الشاعر: يا صاحبي دعا لومي وتفنيدي فليس ما فات من أمري بمردود ويقال: أفند فلانًا الدهر، وذلك إذا أفسده«. ثم ذكر اختلاف السلف في هذا، ثم قال مستندًا إلى اللغة:»وقد بَيَّنّا أنّ أصل التفنيد: الإفساد، وإذا كان ذلك كذلك فالضعف والهرم والكذب وذهاب العقل وكل معاني الإفساد تدخل في التفنيد؛ لأنّ أصل ذلك كله الفساد، والفساد في الجسم: الهرم وذهاب العقل، والضعف، وفي الفعل الكذب، واللوم بالباطل، ولذلك قال جرير بن عطية: يا عاذلي دعا الملام وأَقْصِرا طال الهوى وأَطَلْتُما التَّفْنِيدا يعني: الملامة، فقد تبين إذ كان الأمرُ على ما وصفنا أنّ الأقوال التي قالها مَن ذكرنا قوله في قوله: <q>﴿لولا أن تفندون﴾</q> على اختلاف عباراتهم عن تأويله متقاربة المعاني، محتمل جميعها ظاهر التنزيل، إذ لم يكن في الآية دليل على أنه معني به بعض ذلك دون بعض". وبنحوه رجح ابنُ عطية (٥/١٤٨-١٤٩)، وأضاف: «والتفنيد يقع إما لجهل المُفَنَّد، وإما لِهَوًى غلبه، وإما لكذبه، وإما لضعفه وعجزه لذهاب عقله وهرمه، فلهذا فسّر الناس التفنيد في هذه الآية بهذه المعاني، ومنه قوله ﵇: «أو هرمًا مفندًا»». ثم ذكر أقوال السلف، ثم قال: «والذي يشبه أن تفنيدهم ليعقوب إنما كان لأنهم كانوا يعتقدون أن هواه قد غلبه في جانب يوسف». ",footnotes:1:أخرجه عبد الرزاق ١/٣٢٩، وابن جرير ١٣/٣٣٣، ٣٣٧، وابن أبي حاتم ٧/٢١٩٧. وعزاه السيوطي إلى الفريابى، وأحمد في الزهد، وابن المنذر، وأبي الشيخ، وابن مردويه.أخرجه ابن أبي حاتم ٧/٢١٩٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٩٧.أخرجه ابن أبي حاتم ٧/٢١٩٦.تفسير الثعلبي ٥/٢٥٥، وتفسير البغوي ٤/٢٧٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٣٣٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٩٨. وعزاه السيوطي إلى ابن جرير.أخرجه ابن جرير ١٣/٣٣٥.تفسير مقاتل بن سليمان ٢/٣٥٠.أخرجه ابن جرير ١٣/٣٣٦.أخرجه ابن جرير ١٣/٣٣٢. كما أخرج نحوه ١٣/٣٣٧ من طريق سعيد بن جبير.أخرجه عبد الرزاق ١/٣٢٩، وابن جرير ١٣/٣٣٣، ٣٣٧، وابن أبي حاتم ٧/٢١٩٧ من طريق عبد الله بن أبي الهذيل. وعزاه السيوطي إلى الفريابي، وأحمد في الزهد، وابن المنذر، وأبي الشيخ، وابن مردويه.أخرجه ابن جرير ١٣/٣٣٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٣٤٠ من طريق العوفي، وابن أبي حاتم ٧/٢١٩٨.أخرجه ابن جرير ١٣/٣٣٩.تفسير الثعلبي ٥/٢٥٥.أخرجه الثوري في تفسيره ص١٤٦، وابن جرير ١٣/٣٣٧.أخرجه ابن جرير ١٣/٣٣٩.عزاه السيوطي إلى أبي الشيخ. وأَخرج أوله ابن جرير ١٣/٣٤٠، وابن أبي حاتم ٧/٢١٩٨ من طريق أبي يحيى، كذلك أخرج آخره ابن جرير ١٣/٣٣٨ من طريق ابن أبي نجيح.أخرجه ابن جرير ١٣/٣٣٩.تفسير الثعلبي ٥/٢٥٥، وتفسير البغوي ٤/٢٧٥.أخرجه الثوري في تفسيره ص١٤٦ من طريق أبي مودود، وابن جرير ١٣/٣٤٠.أخرجه ابن جرير ١٣/٣٣٨.أخرجه عبد الرزاق في تفسيره ٢/٣٢٨.أخرجه ابن جرير ١٣/٣٣٧، ٣٤٠. وعلَّقه ابن أبي حاتم ٧/٢١٩٨.أخرجه ابن جرير ١٣/٣٣٩.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٢/٣٥٠.أخرجه ابن جرير ١٣/٣٣٩.أخرجه ابن جرير ١٣/٣٣٩، وابن أبي حاتم ٧/٢١٩٨ من طريق أصبغ.
12,95," <q>﴿قَالُوا۟ تَٱللَّهِ إِنَّكَ لَفِی ضَلَـٰلِكَ ٱلۡقَدِیمِ ۝٩٥﴾</q> - تفسير ٣٨٢٣٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنك لفي ضلالك القديم﴾</q>، يقول: خَطَئِك القديم{1}. (٨/٣٢٨) ٣٨٢٣١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿لفي ضلالك القديم﴾</q>، يقول: جنونك القديم{2}. (٨/٣٢٨) ٣٨٢٣٢- عن الحسن البصري -من طريق قُرَّة- في قول الله: <q>﴿تالله إنك لفي ضلالك القديم﴾</q>، قال: عقوقًا{2}. (ز) ٣٨٢٣٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قالوا تالله إنك لفي ضلالك القديم﴾</q>، أي: مِن حُبِّ يوسف لا تنساه ولا تَسْلاه. قالوا لوالدهم كلمةً غليظة، لم يكن ينبغي لهم أن يقولوها لوالدهم، ولا لنبيِّ الله ﷺ{4}٣٤٥٦. (ز) ٣٤٥٦ بيّن ابنُ عطية (٥/١٤٩) أنّ الضلال في الآية يُراد به: «الانتكاف والتحير، وليس هو بالضلال الذي هو في العرف ضد الرشاد؛ لأنّ ذلك مِن الجفاء الذي لا يسوغ لهم مواجهته به». ثم بيّن أن قتادة وابن عباس تأولاه على معنى الضلال الذي هو ضد الرشاد الذي ردَّه، فقال: «وقد تأول بعض الناس على ذلك، ولهذا قال قتادة ﵀: قالوا لوالدهم كلمة غليظة لم يكن ينبغي لهم أن يقولوها لوالدهم ولا لنبي الله ﵇. وقال ابن عباس: المعنى: لفي خطئك». ٣٨٢٣٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قال له بنو بنيه: <q>﴿تالله إنك لفي ضلالك القديم﴾</q> في شأن يوسف{5}. (٨/١٩٩) ٣٨٢٣٥- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> بنو بنيه: <q>﴿تالله﴾</q> واللهِ، <q>﴿إنك لفي ضلالك القديم﴾</q> مثل قوله: <q>﴿إنا إذا لفي ضلال وسعر﴾</q> [القمر:٢٤] يقول: في شقاء وعناء. يعني: في شقاء مِن حُبِّ يوسف وذكره فما تنساه، وقد أتى عليه أربعون سنة{6}. (ز) ٣٨٢٣٦- عن عبد الملك ابن جريج -من طريق حجاج- في قوله: <q>﴿لفي ضلالك القديم﴾</q>، قال: حُبِّك القديم{7}. (٨/٣٢٨) ٣٨٢٣٧- عن محمد بن إسحاق -من طريق سلمة- <q>﴿قالوا تالله إنك لفي ضلالك القديم﴾</q>، أي: إنّك لَمِن ذِكْرِ يوسف في الباطل الذي أنت عليه{8}. (ز) ٣٨٢٣٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تالله إنك لفي ضلالك القديم﴾</q>، قال: يعنون: حُزْنه القديم على يوسف. و<q>﴿لفي ضلالك القديم﴾</q>: لفي خطئك القديم{7}. (ز) ٣٨٢٣٩- عن سفيان -من طريق أبي أحمد- <q>﴿تالله إنك لفي ضلالك القديم﴾</q>، قال: مِن حُبِّك ليوسف{10}٣٤٥٧. (ز) ٣٤٥٧ لم يذكر ابنُ جرير (١٣/٣٤٢-٣٤٣) غير قول سفيان، وعبد الرحمن بن زيد، ومحمد بن إسحاق، وقتادة، وابن عباس. ",footnotes:1:أخرجه ابن جرير ١٣/٣٤٢، وابن أبي حاتم ٧/٢١٩٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٧/٢١٩٨.أخرجه ابن أبي حاتم ٧/٢١٩٨.أخرجه ابن جرير ١٣/٣٤٢، وابن أبي حاتم ٧/٢١٩٨-٢١٩٩ من طريق سعيد بن بشير.أخرجه ابن جرير ١٣/٣٤٢، وابن أبي حاتم ٧/٢١٩٩.تفسير مقاتل بن سليمان ٢/٣٥٠.أخرجه ابن جرير ١٣/٣٤٣.أخرجه ابن جرير ١٣/٣٤٣، وابن أبي حاتم ٧/٢١٩٩.أخرجه ابن جرير ١٣/٣٤٣.أخرجه ابن جرير ١٣/٣٤٢.
