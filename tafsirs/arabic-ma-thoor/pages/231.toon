quran[7]{c,v,t}:
  11,82,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَاۤءَ أَمۡرُنَا جَعَلۡنَا عَـٰلِیَهَا سَافِلَهَا وَأَمۡطَرۡنَا عَلَیۡهَا حِجَارَةࣰ مِّن سِجِّیلࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٠٦<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق قتادة- قال: لَمّا أُرسلت الرُّسُل إلى قوم لوط ليُهْلِكوهم قيل لهم: لا تُهْلِكوا قوم لوط حتى يشهد عليهم لوطٌ ثلاثَ مرات. وكان طريقُهم على إبراهيم خليل الرحمن، قال: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى يجادلنا في قوم لوط﴾</span>. وكانت مجادلتُه إيّاهم قال: أرأيتُم إن كان فيها خمسون مِن المؤمنين أتُهلكونهم؟ قالوا: لا. قال: فأربعون؟ قالوا: لا. حتى انتهى إلى عشرة أو خمسة. قال: فأَتَوْا لوطًا وهو في أرضٍ له يعمل فيها، فحسِبَهم ضيفانًا، فأقبل حتى أمسى إلى أهله، فمشَوا معه، فالتَفَتَ إليهم، فقال: ما ترون ما يصنع هؤلاء؟ قالوا: وما يصنعون؟ قال: ما مِن الناس أحدٌ شرٌّ منهم. فمشَوا معه، حتى قال ذلك ثلاث مرات، فانتهى بهم إلى أهله، فانطلقت عجوزُ السوء امرأتُه، فأتت قومَه، فقالت: لقد تضيَّف لوطٌ الليلةَ قومًا ما رأيت قطُّ أحسنَ ولا أطيبَ ريحًا منهم. فأقبلوا إليه يُهرعون، فدافَعوه بالباب حتى كادوا يغلبون عليه، فقال مَلَكَ بجناحه، فَسفَقه{1} دونهم، وعلا الإجّارَ{2}، وعَلَوا معه، فجعل يقول: <span class="qpc-hafs">﴿هؤلاء بناتي هن أطهر لكم فاتقوا الله﴾</span> إلى قوله: <span class="qpc-hafs">﴿أو ءاوي إلى ركن شديد﴾</span>. فقالوا: <span class="qpc-hafs">﴿إنا رسل ربك لن يصلوا إليك﴾</span>. فذلك حين عَلِم أنّهم رسل الله، وقال مَلَك بجناحه، فما غُشِي تلك الليلةَ بجناحِه إلا عَمِي، فباتوا بشرِّ ليلةٍ عُمْيًا ينتظرون العذاب، فاستأذن جبريل ﵇ في هلاكهم، فأُذِن له، فاحتمل الأرضَ التي كانوا عليها، وأَهْوى بها، حتى سمع أهلُ سماء الدنيا ضُغاءَ كلابهم، وأوقد تحتَهم نارًا، ثم قَلَبَها بهم، فسمعت امرأتُه الوَجْبَةَ{3} وهي معهم، فالتَفَتَتْ، فأصابها العذابُ، وتُبِعت سُفّارُهم{4} بالحجارة{5}. (٨/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٧<span class="dash">-</span></span> عن <span class="name-1">جندب بن سفيان</span> -من طريق الأسود بن قيس- قال: فخَرَجَ مَلَك مِن الملائكة، فقال: كونوا عُمْيًا. حتى إذا أصبحوا حمل أرضَهم على جناحه، فمضى بها، ثُمَّ قَلَبَها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا جاءت رسلُ اللهِ لوطًا ﵇ ظَنَّ أنّهم ضِيفانٌ لقوه، فأدناهم حتى أقعدهم قريبًا، وجاء ببناته، وهُنَّ ثلاثة، فأقْعَدَهُنَّ بين ضيفانه وبين قومه، فجاءه قومه يُهرَعون إليه، فلمّا رآهم قال: <span class="qpc-hafs">﴿هؤلاء بناتي هن أطهر لكم فاتقوا الله ولا تخزون في ضيفي﴾</span>. قالوا: <span class="qpc-hafs">﴿ما لنا في بناتك من حق وإنك لتعلم ما نريد﴾</span>. قال: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>. فالتفت إليه جبريل ﵇، فقال: <span class="qpc-hafs">﴿إنا رسل ربك لن يصلوا إليك﴾</span>. فلمّا دَنَوْا طَمَسَ أعينَهم، فانطلقوا عُميًا يركب بعضهم بعضًا، حتى إذا خرجوا إلى الذين بالباب قالوا: جئناكم مِن عند أسْحَرِ الناس. ثم رُفِعَتْ في جوف الليل، حتى إنّهم لَيَسْمَعون صوت الطير في جوِّ السماء، ثم قُلبت عليهم، فمَن أصابته الائتِفاكة أهلكته، ومَن خرج منها أتبَعَته حيث كان حجرًا فقتلته، فارتحل ببناته، حتى بلغ مكان كذا مِن الشام ماتت ابنتُه الكبرى، فخرجت عندها عينٌ، ثم انطلق حيث شاء الله أن يبلغ فماتت الصغرى، فخرجت عندها عين، فما بقي مِنهُنَّ إلا الوُسْطى{7}. (٨/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: أغْلَقَ لوطٌ على ضيفه الباب، فجاءوا، فكسروا الباب، ودخلوا، فطمس جبريلُ أعينَهم، فذهبت أبصارهم، قالوا: يا لوط، جِئْتَنا بسَحَرَة. فتَوَعَّدوه، فأوجس في نفسه خيفة، قال: يذهب هؤلاء ويَذَرُوني؟ قال جبريل: لا تخف؛ إنّا رُسُل ربك، إن موعدَهم الصبح. قال لوط: الساعةَ. قال جبريل: أليس الصبح بقريب؟! قال: الساعةَ. فرُفِعت حتى سَمِع أهلُ السماء الدنيا نبيح الكلاب، ثم أُقلِبت، ورُمُوا بالحجارة{8}. (٨/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٠<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- <span class="qpc-hafs">﴿وأمطرنا عليها حجارة من سجيل﴾</span>، قال: هي على أهل نواديهم، وعلى دعاتهم، وعلى مسافريهم، فلم ينفلت منهم أحد{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فلما جاء أمرنا جعلنا عاليها سافلها﴾</span>، قال: لَمّا أصبحوا غدا جبريلُ على قريتهم، ففَتَقَها مِن أركانها، ثم أدخل جناحه، ثم حملها على خَوافِي{10} جناحيه بما فيها، ثُمَّ صعد بها إلى السماء حتى سمع أهل السماء نباح كلابهم، ثم قلبها، فكان أول ما سقط منها سُرادِقُها{11}، فلم يُصِب قومًا ما أصابهم؛ إنّ الله طمَس على أعينهم، ثم قلب قريتهم، وأمطر عليهم حجارة مِن سِجِّيل{12}. (٨/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: أنّ جبريل ﵇ اجْتَثَّ مدينةَ قوم لوط مِن الأرض، ثم رفعها بجناحه حتى بلغ بها حيث شاء الله، ثم جعل عاليها سافلها{13}. (٨/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>: أنّ جبريل قَلَعَ الأرض يوم قوم لوط، حتى سمع أهلَ السماء نباح الكلاب، وأصوات الدِّياك، وأمطر اللهُ عليهم الكبريتَ والنارَ{13}. (٨/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٤<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد- قال: ... فمسح أحدهُم أعينَهم بجناحيه، فطَمَس أبصارَهم، فقالوا: سُحِرْنا، انصرِفوا بنا حتى نرجع إليه. فكان مِن أمرهم ما قد قَصَّ اللهُ تعالى في كتابه، فأدخل ميكائيل -وهو صاحب العذاب- جناحَه حتى بلغ أسفل الأرض، فقَلَبَها، ونزلت حجارةٌ من السماء فتَتَبَّعَتْ مَن لم يكن منهم في القرية حيث كانوا، فأهلكهم الله، ونَجّى لوطًا وأهله، إلا امرأته{15}. (٨/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ جبريل ﵇ أخذ بعُرْوَتِها الوسطى، ثم ألْوى بها إلى جَوِّ السماء حتى سمعت الملائكة ضواغي كلابهم، ثم دَمَّر بعضَها على بعض، ثم أتبع شُذّانَ القومِ صخرًا. قال: وهي ثلاث قرى، فيها من العدد ما شاء الله أن يكون من الكثرة، ذُكِر لنا: أنّه كان مِنها أربعة آلاف ألف، وهي سدوم؛ قرية بين المدينة والشام{16}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ جبريل ﵇ أخذ بعُرْوَتها الوسطى، ثم ألْوى بها إلى جَوِّ السماء حتى سمعت الملائكة ضواغي كلابهم، ثم دَمَّر بعضها على بعض، ثم أتبع شُذّانَ القوم صخرًا. قال: وهي ثلاث قرى يُقال لها: سدوم. وهي بين المدينة والشام. قال: وذُكِر لنا: أنّه كان فيها أربعة آلاف ألف. وذُكِر لنا: أنّ إبراهيم ﵇ كان يُشرف، يقول: سدوم؛ يومٌ ما لَكِ!{17}{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: بلغنا: أنّ جبريل ﵇ لَمّا أصبح نَشَر جناحَه، فانتَسَفَ به أرضَهم بما فيها مِن قصورها، ودوابِّها، وحجارتها، وشجرها وجميع ما فيها، فضمَّها في جناحه، فحَواها وطواها في جوف جناحه، ثم صعد بها إلى السماء الدنيا، حتى سمع سكان السماء أصوات الناس والكلاب، وكانوا أربعة آلاف ألف، ثم قلبها فأرسلها إلى الأرض منكوسة، دَمْدَم بعضَها على بعض، فجعل عاليها سافلها، ثم أتبعها حجارة مِن سِجِّيل{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: لَمّا أصبحوا -يعني: قوم لوط- نزل جبريل فاقتلع الأرض مِن سبع أرَضِين، فحملها حتى بلغ السماء الدنيا، حتى سمع أهلُ السماء نباحَ كلابهم وأصوات ديوكهم، ثم قلبها، فقتلهم، فذلك حين يقول: <span class="qpc-hafs">﴿والمؤتفكة أهوى﴾</span> [النجم:٥٣]: المنقلبة حين أهوى بها جبريل الأرض، فاقتلعها بجناحه، فمَن لم يَمُتْ حين أسقط الأرضَ أمطر الله عليه وهو تحت الأرض الحجارة، ومَن كان منهم شاذًّا في الأرض، وهو قول الله ﷿: <span class="qpc-hafs">﴿فجعلنا عاليها سافلها وأمطرنا عليهم حجارة من سجيل﴾</span> [الحجر:٧٤]. ثُمَّ تَتَبَّعهم في القرى، فكان الرجل يأتيه الحجر فيقتله، وذلك قول الله تعالى: <span class="qpc-hafs">﴿وأمطرنا عليها حجارة من سجيل﴾</span>{20}. (٨/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١١٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا أصبحوا نزل جبريل ﵇، فاقتلع الأرض مِن سبع أرَضِين، فحملها حتى بلغ السماء الدنيا، ثم أهوى بها جبريل إلى الأرض{21}. (٨/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله: <span class="qpc-hafs">﴿فَلَمّا جاءَ أمْرُنا﴾</span> يعني: قولنا في نزول العذاب <span class="qpc-hafs">﴿جَعَلْنا عالِيَها سافِلَها﴾</span> يعني: الخسف، <span class="qpc-hafs">﴿وأَمْطَرْنا عَلَيْها﴾</span> يعني: على أهلها مَن كان خارِجًا مِن المدائن الأربع <span class="qpc-hafs">﴿حِجارَةً مِن سِجِّيلٍ﴾</span>{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حِجَارَةࣰ مِّن سِجِّیلࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: هي بالفارسية: سَنك وكِل؛ حجر وطين{23}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: حجارة فيها طين{24}. (٨/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: مِن طين{25}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٤<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن عبد الله بن سابط الجمحي</span>، مثل ذلك{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: فارسية أُعْرِبَت؛ سَنك وكِل{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- قال: <span class="qpc-hafs">﴿سجيل﴾</span> فارسية ونبطية: سج إيل{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن نَجِيح- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: بالفارسية أوَّلها حجارة، وآخرها طين{29}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٨<span class="dash">-</span></span> وروي عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٢٩<span class="dash">-</span></span> و<span class="name-2">مطر الوراق</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٠<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: هي كلمة أعجمية عُرِّبت؛ سِنك وكِل{13}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٢<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: يعني: الآجر{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٤<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قالا: مِن طين منضود{33}. (٨/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٥<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: هو بحر مُعَلَّق في الهواء بين الأرض والسماء، مِنهُ أُنزِل الحجارة{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قال: كان أصلُ الحجارة طينًا، فشُدِّدَت{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٧<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد- قال: <span class="qpc-hafs">﴿سجيل﴾</span> بالفارسية: سِنك وكِل{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٨<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن عبد الله بن سابِط الجمحي</span> -من طريق إسرائيل- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: هي بالفارسية{37}. (٨/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حِجارَةً مِن سِجِّيلٍ﴾</span>، يعني: حجارة خالطها الطِّين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٠<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿سجيل﴾</span>، قال: فيها طين{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قال: السماء الدنيا. والسماء الدنيا اسمها: سِجِّيل{40}<span class=comment-ref>٣٢٦٥</span>. (٨/١٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٥</span> اختلف في معنى: <span class="qpc-hafs">﴿سِجِّيلٍ﴾</span> في هذه الآية على أقوال: <b>الأول:</b> أنها لفظة غير عربية استعملها العرب، ومعناها: طين. <b>الثاني:</b> أنها اسم السماء الدنيا. ونقل <u>ابنُ جرير</u> أقوالًا أخرى عن أهل العربية منها: <b>الثالث:</b> أنّها مِن الحجارة الصلب الشديد. <b>الرابع:</b> أنّها مِن قول القائل: أسْجَلْتُه: أرسلته، أي: مُرسَلَةٌ عليهم. <b>الخامس:</b> أنها مِن سَجَلْتُ له سَجْلًا مِن العطاء، أي: مُنِحوا ذلك البلاء فأُعْطُوه. <b>السادس:</b> أنها مِن السِّجِلِّ؛ لأنّه كان فيها عَلَمٌ كالكتاب. <b>السابع:</b> طينٌ يُطبَخ كما يُطبَخ الآجُرُّ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٥٢٨) القول الأول، وهو قول ابن عباس وما في معناه، فقال: «والصوابُ مِن القول في ذلك عندنا ما قاله المفسرون، وهو أنّها مِن طين، وبذلك وصفها الله ﷿ في كتابه في موضع آخر، وذلك قوله: <span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ * مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span> [الذاريات:٣٣-٣٤]».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٤/٦٢٧) إلّا أنّه بيَّن أن من قال به ذهب إلى أنّ أصله مِن طين، وأن الحجارة التي رُمُوا بها كانت كالآجُرّ المطبوخ، وأن هذا معنى قول الحسن، فقال: «وهذا قول يشبه، وهو الصواب الذي عليه الجمهور». ونقل عن فرقة قولًا ذَكَر أنّه يمكن ردُّه للقول الذي رجحه، وهو أن معنى: <span class="qpc-hafs">﴿سِجِّيلٍ﴾</span>: حَجَر مخلوطٌ بطين، أي: حَجَر وطين.</p><p>ثم <span class="comment-type-4">علَّق</span> (٤/٦٢٧-٦٢٨) عليه بقوله: «لأنّ الآجُرَّ وما جرى مجراه يمكن أن يُقال فيه: حجر وطين؛ لأنّه قد أخذ مِن كل واحد بحظِّه، وهي مِن طين مِن حيث هو أصلها، ومن حجر من حيث صلبت».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٤/٦٢٦) القول الثاني <span class="mustanad">مستندًا إلى دلالة ألفاظ الآية</span> قائلًا: «وهذا ضعيف، ويَرُدُّه وصفه بـ<span class="qpc-hafs">﴿منضود﴾</span>»، و<span class="comment-type-2">انتقد</span> (٤/٦٢٧) القول الرابع والسادس أيضًا.</div></p><p><h3><span class="qpc-hafs">﴿مَّنضُودࣲ ۝٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٤٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿منضود﴾</span>: مُتَتابِع، يتبع بعضها بعضًا{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- <span class="qpc-hafs">﴿منضود﴾</span>: مختّمة{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٥<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قالا: مِن طين منضود، مصفوفة مسوَّمة مُطَوَّقة{43}. (٨/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿منضود﴾</span>، أي: بعضه على بعض{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿منضود﴾</span>، قال: قد نُضِد بعضه على بعض{45}<span class=comment-ref>٣٢٦٦</span>. (٨/١٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٦</span> اختُلِف في معنى: <span class="qpc-hafs">﴿مَنضُودٍ﴾</span> في هذه الآية على ثلاثة أقوال: <b>الأول:</b> يتبع بعضه بعضًا. <b>الثاني:</b> مصفوف. <b>الثالث:</b> نُضِدَ بعضه على بعض.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٥٣٠) <span class="mustanad">مستندًا إلى دلالة اللغة</span> القول الثالث، وهو قول الربيع، وعلَّل ذلك بأن «قوله: <span class="qpc-hafs">﴿مَنضُودٍ﴾</span> من نعت <span class="qpc-hafs">﴿سِجِّيل﴾</span>، لا مِن نعت الحجارة، وإنما أُمْطِر القوم حجارة من طين، صفة ذلك الطين أنه نُضِد بعضه إلى بعض، فصُيِّر حجارة، ولم يُمطَروا الطين، فيكون موصوفًا بأنّه تتابع على القوم بمجيئه. وإنما كان جائزًا أن يكون على ما تأوَّله هذا المتأوِّل لو كان التنزيل بالنصب منضودةً، فيكون من نعت الحجارة حينئذٍ».</div></p><p><div></p><p><p><span class="item-no">٣٦١٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَنضُودٍ﴾</span>، يعني: مُلزق الحجر بالطين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٤٩<span class="dash">-</span></span> عن <span class="name-3">أبي بكر بن عبد الله الهذلي</span> -من طريق حجاج- قال: أمّا قوله: <span class="qpc-hafs">﴿منضود﴾</span> فإنّها في السماء منضودة مُعَدَّة، وهي مِن عِدَةِ الله التي أعَدَّ للظَّلَمَة{47}. (ز)</p></p><p></div></p></div>",footnotes:1:السَّفْق: لغة في الصَّفْق، وسَفَقَ الباب أي أغلقه. لسان العرب (سفق).الإجّار: السطح الذي ليس حواليه ما يرد الساقط عنه. النهاية (أجر).الوجبة: السَّقْطة مع الهَدَّة. النهاية (وجب).قوم سُفّار: ذوو سفر. تاج العروس (سفر).أخرجه عبد الرزاق ١/٣٠٧، وابن جرير ١٢/٤٩٥، ٥١٨، وفي التاريخ ١/٢٨٩، ٢٩٩، ٣٠٣، وابن أبي حاتم ٦/٢٠٦٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/٢٠٦٦.أخرجه ابن أبي حاتم ٦/٢٠٦٤-٢٠٦٥، والحاكم ٢/٣٤٤. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي الدنيا في كتاب العقوبات (١٥٠).أخرجه ابن أبي حاتم ٦/٢٠٦٨.الخوافي: الريش الصغار التي في جناح الطائر، ضد القوادم، واحدتها خافية. النهاية (خفا).السرادق: هو كل ما أحاط بشيء من حائط أو مضرب أو خباء. النهاية (سردق).أخرجه ابن جرير ١٢/٥٣٤-٥٣٥، وفي التاريخ ١/٣٠٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير في تفسيره ١٢/٥٢٠، وفي تاريخه ١/٣٠٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٥٣٥، وابن أبي حاتم ٦/٢٠٦٨. وعزاه السيوطي إلى أبي الشيخ.ذكر محققو تفسير ابن جرير أنها جاءت في تاريخ المصنف: يومًا هالك.أخرجه ابن جرير ١٢/٥٣٥.أخرجه عبد الرزاق ١/٣٠٨ مختصرًا، وابن جرير ١٢/٥٣٦.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٥ (١٥١)-، وابن جرير ١٢/٥٣٦.أخرجه ابن جرير في التفسير ١٢/٥٣٦، وفي التاريخ ١/٣٠٦.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن أبي شيبة ١٠/٤٧٣، وابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٥ (١٥١)-، وابن أبي حاتم ٦/٢٠٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٢/٥٢٧ بلفظ: طين في حجارة. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٦/٢٠٦٨. وعزاه السيوطي إلى أبي الشيخ.علَّقه ابن أبي حاتم ٦/٢٠٦٨.أخرجه ابن جرير ١٢/٥٢٦.أخرجه ابن جرير ١٢/٥٢٨.تفسير مجاهد ص٣٩٠، وأخرجه ابن جرير ١٢/٥٢٦، ٥٣٠، وابن أبي حاتم ٦/٢٠٦٨. وعزاه السيوطي إلى الفريابي، وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٦/٢٠٦٨.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٤/١٩٤.أخرجه عبد الرزاق ١/٣٠٩، ٢/٣٩٦، وابن جرير ١٢/٥٢٦، ٥٢٩. وعزاه السيوطي إلى أبي الشيخ. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢- عن قتادة. وعلَّق ابن أبي حاتم ٦/٢٠٦٨ نحوه عن عكرمة.تفسير الثعلبي ٥/١٨٤. وعزاه السيوطي إلى أبي الشيخ.علقه ابن جرير ١٢/٥٢٩.أخرجه ابن جرير ١٢/٥٢٦.أخرجه ابن أبي شيبة ١٠/٤٧٣.تفسير مقاتل بن سليمان ٢/٢٩٣.تفسير سفيان الثوري ص١٣٢.أخرجه ابن جرير ١٢/٥٢٧، ٢٤/٦٣٥.تفسير الثعلبي ٥/١٨٤، وتفسير البغوي ٤/١٩٤.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٥ (١٥١)-.أخرجه عبد الرزاق ١/٣٠٩، ٢/٣٩٦، وابن جرير ١٢/٥٢٦، ٥٢٩. وعزاه السيوطي إلى أبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٣-.أخرجه ابن جرير ١٢/٥٢٩، وابن أبي حاتم ٦/٢٠٦٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن جرير ١٢/٥٢٩.
  11,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُّسَوَّمَةً عِندَ رَبِّكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿مسومة﴾</span>، قال: التسويم: بياضٌ في حُمْرَة{1}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿مسومة﴾</span>، قال: مُعَلَّمة{2}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مسومة﴾</span>، قال: مُعَلَّمة{3}. (٨/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٤<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿حجارة من سجيل﴾</span>، قالا: مِن طين منضود، مصفوفة، مُسَوَّمة، مُطَوَّقة، بها نَضْحٌ{4} مِن حُمْرَة{5}. (٨/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿مسومة﴾</span>: كانت مختومةً عليها أمثال الخواتيم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿مسومة عند ربك﴾</span>، عليها سِيما أنّها ليست مِن حجارة الدنيا، وأنها من حجارة العذاب. قال: وتلك السِّيما على الحَجَر منها مثل الخاتم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٧<span class="dash">-</span></span> عن <span class="name-2">مطر الورّاق</span> -من طريق ابن شَوْذَب- في قوله: <span class="qpc-hafs">﴿مسومة عند ربك﴾</span>: منطقة{8} بِحُمْرَة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿مسومة﴾</span>، قال: المُسَوَّمة: المُخَتَّمة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٥٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿مسومة﴾</span>، قال: عليها سِيما خطوط غُبْر{11}. (٨/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُسَوَّمَةً﴾</span> يعني: مُعَلَّمة <span class="qpc-hafs">﴿عِنْدَ رَبِّكَ﴾</span> يعني: جاءت مِن عند الله ﷿{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: حجارة مُسَوَّمة لا تُشاكِل حجارةَ الأرض{13}. (٨/١٢٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا هِیَ مِنَ ٱلظَّـٰلِمِینَ بِبَعِیدࣲ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٦٢<span class="dash">-</span></span> قال أنس بن مالك: سأل رسولُ الله ﷺ جبريلَ ﵇ عن قوله تعالى: <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>. قال: يعني بها: ظالمي أمتك، ما مِن ظالم منهم إلا هو يعرض حجر يسقط عليه من ساعة إلى ساعة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- <span class="qpc-hafs">﴿وما هِيَ مِنَ الظّالِمِينَ بِبَعِيدٍ﴾</span>، قال: مِن ظالمي العرب إن لم يُؤْمِنوا بكلام محمد ﵇. قال: والتَفَتَتِ امرأةُ لوط فأصابها حجر، فقتلها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>، قال: يُرهِب بها قُرَيشًا أن يصيبهم ما أصابَ القومُ{16}<span class=comment-ref>٣٢٦٧</span>. (٨/١٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٧</span> اختُلِف في المراد بـ<span class="qpc-hafs">﴿الظالمين﴾</span> في هذه الآية على أقوال: <b>الأول:</b> أنّ المراد به: كفار قريش. <b>الثاني:</b> أنّه عام في كل ظالم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٤/٦٢٨) <span class="mustanad">مستندًا إلى السُّنَّة</span> القول الثاني، فقال: «وهذا هو الأصح؛ لأنّه رُوِي عن النبي ﷺ أنّه قال: «سيكون في أمتي خَسْف، ومَسْخ، وقَذْف بالحجارة». وقد ورد أيضًا حديث: «إنّ هذه الأمة بِمَنجاةٍ من ذلك»».</p><p>وذكر قولين في عود الضمير في <span class="qpc-hafs">﴿وما هِيَ﴾</span>: <b>الأول:</b> أنّه عائد إلى الحجارة. <b>الثاني:</b> أنّه عائد إلى المدن. ثم <span class="comment-type-4">علَّق</span> على الثاني منهما بقوله: «ويكون المعنى: الإعلام بأن هذه البلاد قريبة من مكة». ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأول أبْيَن».</div></p><p><div></p><p><p><span class="item-no">٣٦١٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إسحاق بن بشر- أنّه سُئِل: هل بقي مِن قوم لوطٍ أحدٌ؟ قال: لا، إلا رجلٌ بقي أربعين يومًا، كان تاجرًا بمكة، فجاءه حجرٌ ليصيبه في الحرم، فقامت إليه ملائكةُ الحرم، فقالوا للحجر: ارجِع مِن حيث جئت؛ فإنّ الرجل في حرم الله. فرجع الحجرُ، فوقف خارجًا مِن الحرم أربعين يومًا بين السماء والأرض، حتى قضى الرجلُ تجارته، فلما خرج أصابه الحجرُ خارجًا مِن الحرم. يقول الله: <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>، يعني: مِن ظالمي هذه الأمة ببعيد{17}. (٨/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>: لم يبرأ منها ظالم بعدهم{18}. (٨/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق ابن شَوْذَب- <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>، قال: مِن ظالمي هذه الأُمَّة. ثم يقول: واللهِ، ما أجار اللهُ منها ظالِمًا بعدُ{19}. (٨/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٦٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>، يقول: مِن ظَلَمَةِ العرب؛ إن لم يؤمنوا فيُعذَّبوا بها{20}. (٨/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>، قال: لم يَبْرَأْ منها ظالمٌ بعدَهم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في الآية، قال: كلُّ ظالم -فيما سمِعنا- قد جُعِل بحذائه حجر ينتظر متى يُؤْمَر أن يقع به، فخوَّف الظَّلَمَة، فقال: <span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span>{22}. (٨/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿وما هِيَ مِنَ الظّالِمِينَ بِبَعِيدٍ﴾</span> لأنّها قريب مِن الظالمين، يعني: من مشركي مكة؛ فإنّها تكون قريبًا، يخوفهم منها، وسيكون ذلك في آخر الزمان، يعني: ما هي ببعيد؛ لأنها قريب منهم، والبعيد ما ليس بكائن، فذلك قوله: <span class="qpc-hafs">﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا (٦) ونَراهُ قَرِيبًا﴾</span> [المعارج:٦-٧] يعني: كائِنًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٣<span class="dash">-</span></span> عن <span class="name-3">أبي بكر بن عبد الله الهذلي</span> -من طريق حجاج- قال: يقول: وما هي مِن ظَلَمَةِ أُمَّتِك ببعيد، فلا يأمنها منهم ظالم{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٤<span class="dash">-</span></span> عن أبي خالد الأحمر، قال: أدْرَكْتُ مشيخةً مِن العرب -أُراه قال: مِن بني تميم- إذا رأوا الظالم قالوا: اتَّقِ الحِجارة. تصديقًا لقول الله ﷿: <span class="qpc-hafs">﴿وما هِيَ مِنَ الظّالِمِينَ بِبَعِيدٍ﴾</span>{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا هِیَ مِنَ ٱلظَّـٰلِمِینَ بِبَعِیدࣲ ۝٨٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٦١٧٥<span class="dash">-</span></span> عن محمد بن المنكدر، ويزيد بن حفصة، وصفوان بن سليم: أنّ خالد بن الوليد كتب إلى <span class="name-1">أبي بكر الصديق</span> أنّه قد وجد رجلًا في بعض نواحي العرب يُنكَح كما تُنكَح المرأة، وقامت عليه بذلك البيِّنة. فاستشار أبو بكر أصحاب رسول الله ﷺ، فقال <span class="name-1">علي بن أبي طالب</span>: إنّ هذا ذَنبٌ لم يَعْصِ اللهُ به أُمَّةً مِن الأمم إلا أُمَّةٌ واحدة، فصنع الله بها ما قد علمتم، أرى أن تحرقه بالنار. فاجتمع أصحاب النبيِّ ﷺ على أن يحرقوه بالنار، فكتب أبو بكر إلى خالد: أن احرقه بالنار. ثم حرَقهم ابنُ الزبير في إمارته، ثم حرقهم هشام بن عبد الملك{26}. (٨/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٦<span class="dash">-</span></span> عن عائشة -من طريق عروة- قالت: أول ما اتُّهِم بالأمر القبيح -يعني: عمل قوم لوط- على عهد <span class="name-1">عمر</span> اتُّهِم به رجلٌ، فأمر عمرُ بعض شباب قريشٍ ألّا يُجالِسُوه{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٧<span class="dash">-</span></span> عن <span class="name-2">أبي الجلد جيلان بن فروة</span> -من طريق السدي- قال: رأيتُ امرأةَ لوطٍ قد مُسِخت حَجَرًا، تحيض عند رأس كلِّ شهر{28}. (٨/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: مَن عَمِل عَمَل قومِ لوط رُجِم إن كان مُحْصَنًا، وإن كان بِكْرًا جُلِد مائة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٧٩<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق معمر- قال: يُرْجَم إن كان مُحْصَنًا، ويُجْلَد إن كان بِكْرًا، ويُغَلَّظ عليه في الحبس والنفي{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٨٠<span class="dash">-</span></span> عن <span class="name-2">ربيعة بن أبي عبد الرحمن الرأي</span>، قال: عَذَّب اللهُ قوم لوط فرماهم بحجارة مِن سجيل، فلا تُرفع تلك العقوبة عمَّن عمِل عَمَل قومِ لوط{31}. (٨/١٢٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٦٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي شيبة ١٠/٤٧٣، وابن أبي حاتم ٦/٢٠٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٣٩٠، وأخرجه ابن جرير ١٢/٥٣٠، وابن أبي حاتم ٦/٢٠٦٨. وعزاه السيوطي إلى الفريابي، وابن المنذر، وأبي الشيخ.النضح: ما بقي له أثر. لسان العرب (نضح).أخرجه عبد الرزاق ١/٣٠٩، ٢/٣٩٦، وابن جرير ١٢/٥٢٦، ٥٢٩. وعزاه السيوطي إلى أبي الشيخ. وفي تفسير البغوي ٤/١٩٤ عنهما: عليها خطوط حمر على هيئة الجزع.تفسير الثعلبي ٥/١٨٤ بلفظ: مختومة، وتفسير البغوي ٤/١٩٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٣-.كذا في مطبوعة المصدر.أخرجه ابن أبي حاتم ٦/٢٠٦٩.أخرجه ابن جرير ١٢/٥٣١.أخرجه ابن جرير ١٢/٥٣١، وابن أبي حاتم ٦/٢٠٦٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن جرير ١٢/٥٣٠. وعزاه السيوطي إلى أبي الشيخ.أورده الثعلبي ٥/١٨٤.</p><p>قال الزيلعي في تخريج أحاديث الكشاف ٢/١٤٨ (٦١٤): «غريب، وذكره الثعلبي عن أنس من غير سند». وقال المناوي في الفتح السماوي ٢/٧٢٠ (٦٠٨): «قال الولي العراقي: ذكره الثعلبي بغير إسناد، ولم أقف له على إسناد».أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٥ (١٥١)-.أخرجه ابن جرير ١٢/٥٣٢، وابن أبي حاتم ٦/٢٠٦٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن عساكر ٥٠/٣٢٦. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه عبد الرزاق ١/٣٠٩، ٢/٣٩٦، وابن جرير ١٢/٥٣٢-٥٣٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٥٣٣، وابن أبي حاتم ٦/٢٠٧٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٥٣٣، وابن أبي حاتم ٦/٢٠٧٠.أخرجه ابن أبي حاتم ٦/٢٠٧٠.أخرجه ابن أبي حاتم ٦/٢٠٧٠. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن جرير ١٢/٥٣٣.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٥ (١٥٢)-.أخرجه ابن أبي الدنيا في ذم الملاهي (١٤٥)، والبيهقي في شعب الإيمان (٥٣٨٩)، وفي السنن ٨/٢٣٢. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/٣١٠.أخرجه ابن عدي ١/٢٠٤، وابن عساكر ٥٠/٣٢٦-٣٢٧.أخرجه عبد الرزاق ١/٣٠٩.أخرجه عبد الرزاق ١/٣٠٩.عزاه السيوطي إلى ابن المنذر.
  11,84,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِلَىٰ مَدۡیَنَ أَخَاهُمۡ شُعَیۡبࣰاۚ قَالَ یَـٰقَوۡمِ ٱعۡبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنۡ إِلَـٰهٍ غَیۡرُهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٨١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإلى مدين أخاهم شعيبا﴾</span>، قال: إنّ الله قد بعث شعيبًا إلى مَدْيَن، وإلى أصحاب الأَيْكَة، هي الغَيْضَة{1} مِن الشَّجَر{2}<span class=comment-ref>٣٢٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٨</span> نقل <u>ابنُ عطية</u> (٤/٦٢٨-٦٢٩) قولًا بأنّ مدين: هي بقعة. ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فالتقدير على هذا: وإلى أهل مدين. كما قال: <span class="qpc-hafs">﴿وسْئَلِ القَرْيَةَ﴾</span> [يوسف:٨٢]».</div></p><p><div></p><p><p><span class="item-no">٣٦١٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وإلى مَدْيَنَ﴾</span> وهو ابن إبراهيم خليل الرحمن، وشعيب بن نُوَيْب بن مدين بن إبراهيم، <span class="qpc-hafs">﴿وإلى مَدْيَنَ أخاهُمْ﴾</span> يعني: أرسلنا أخاهم شعيبًا، وليس بأخيهم في الدين، ولكن في النَّسَب، <span class="qpc-hafs">﴿قال يا قوم اعبدوا الله﴾</span> يعني: وحِّدوا الله، <span class="qpc-hafs">﴿ما لكم من إله غيره﴾</span> يقول: ليس لكم ربٌّ غيرُه{3}<span class=comment-ref>٣٢٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٩</span> أفاد قولُ مقاتلٍ أمرين: <b>الأول</b>: أنّ مدين هو ولد إبراهيم الخليل ﵇، وهو ما <span class="comment-type-4">ذكره</span> <u>ابنُ عطية</u> (٤/٦٢٩) عن النقاش، ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهذا بعيد». <b>الثاني</b>: أنّ شعيبًا عربيٌّ إذ هو مِن نسل إبراهيم، وهو ما <span class="comment-type-2">انتقده</span> <u>ابنُ عطية</u> (٤/٦٢٩) <span class="mustanad">مستندًا لدلالة التاريخ</span>، فقال: «فكيف يجتمع هذا وليس للعرب اتصالٌ بإبراهيم إلا مِن جهة إسماعيل فقط؟!».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَنقُصُوا۟ ٱلۡمِكۡیَالَ وَٱلۡمِیزَانَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٨٣<span class="dash">-</span></span> عن <span class="name-3">خلف بن حوشب</span> -من طريق يزيد بن عطاء- قال: هلك قومُ شُعَيْبٍ مِن شعيرة إلى شعيرة؛ كانوا يأخذون بالرَّزينة، ويُعْطُون بالخفيفة{2}. (٨/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَنْقُصُوا المِكْيالَ والمِيزانَ﴾</span> إذا كِلْتُم ووَزَنتُم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنِّیۤ أَرَىٰكُم بِخَیۡرࣲ وَإِنِّیۤ أَخَافُ عَلَیۡكُمۡ عَذَابَ یَوۡمࣲ مُّحِیطࣲ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق زياد بن عمرو- في قوله: <span class="qpc-hafs">﴿إني أراكم بخير﴾</span> قال: رُخْص السِّعر، <span class="qpc-hafs">﴿وإني أخاف عليكم عذاب يوم محيط﴾</span> قال: غَلاء السِّعر{6}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٨٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مُوسِرِين، في نِعْمَة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٨٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: خِصْبٌ وسَعَة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٨٨<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: رَغَد العَيْش، وكثرة المال{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٨٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق أبي عامر الخزاز- <span class="qpc-hafs">﴿إنِّي أراكُمْ بِخَيْرٍ﴾</span>: الغِنى، ورُخْص السِّعْر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قول الله تعالى: <span class="qpc-hafs">﴿إنِّي أراكُمْ بِخَيْرٍ﴾</span> رُخْص الأسعار، <span class="qpc-hafs">﴿وإنِّي أخافُ عَلَيْكُمْ عَذابَ يَوْمٍ مُحِيطٍ﴾</span> قال: جُور السُّلطان{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إني أراكم بخير﴾</span>، قال: يعني: خير الدنيا، وزينتها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إني أراكم بخير﴾</span>: أبْصَر عليهم قِشْرًا مِن قِشْرِ الدنيا وزينتها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنِّي أراكُمْ بِخَيْرٍ﴾</span> يعني: مُوسِرِين في نعمة، <span class="qpc-hafs">﴿وإنِّي أخافُ عَلَيْكُمْ﴾</span> في الدنيا <span class="qpc-hafs">﴿عَذابَ يَوْمٍ مُحِيطٍ﴾</span> يعني: أحاط بهم العذاب، فلم ينجُ منهم أحدٌ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إني أراكم بخير﴾</span>، قال: في دنياكم، كما قال الله تعالى: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span> [البقرة:١٨٠]، سمّاه: خيرًا؛ لأنّ الناس يُسَمُّون المالَ: خيرًا{15}<span class=comment-ref>٣٢٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٠</span> اختُلِف في المراد بـ«الخير» في قوله تعالى: <span class="qpc-hafs">﴿إنِّي أراكُمْ بِخَيْرٍ﴾</span> على قولين: <b>الأول:</b> أنّ ذلك الخير هو رخص الأسعار. <b>الثاني:</b> أنّه المال، وزينة الدنيا.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٥٣٩-٥٤٠) <span class="mustanad">مستندًا إلى دلالة العموم</span> اشتمال معنى الآية على كل معاني الخير، فقال: «وأَوْلى الأقوال في ذلك بالصواب: ما أخبر الله عن شعيب ﵇ أنه قال لقومه، وذلك قوله: <span class="qpc-hafs">﴿إنِّي أراكُمْ بِخَيْرٍ﴾</span> يعني: بخير الدنيا. وقد يدخل في خير الدُّنيا: المال، وزينة الحياة الدنيا، ورُخْصُ السعر، ولا دلالة على أنّه عنى بقِيلِه ذلك بعضَ خيرات الدنيا دون بعض، فذلك على كلِّ معاني خيرات الدنيا التي ذكر أهلُ العلم أنهم كانوا أوتوها».</p><p>ونقل <u>ابنُ عطية</u> (٤/٦٢٩) القول الأول ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وينظر هذا التأويل إلى قول النبي ﷺ: «ما نقص قومٌ المكيالَ والميزانَ إلا ارتفع عنهم الرِّزْقُ»». ونقل قولًا آخر، وهو أنّ قوله: <span class="qpc-hafs">﴿بِخَيْرٍ﴾</span> عامٌّ في جميع نعم الله تعالى، ثم <span class="comment-type-4">علَّق</span> بقوله: «وجميع ما قيل في لفظ»خير«منحصر فيما قلناه».</div></p></div>",footnotes:1:الغيضة: الشجر المُلْتَفّ. لسان العرب (غيض).أخرجه ابن أبي حاتم ٦/٢٠٧٠.تفسير مقاتل بن سليمان ٢/٢٩٣-٢٩٤.أخرجه ابن أبي حاتم ٦/٢٠٧٠.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن جرير ١٢/٥٣٨. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٨٦، وتفسير البغوي ٤/١٩٥.تفسير الثعلبي ٥/١٨٦، وتفسير البغوي ٤/١٩٥.تفسير الثعلبي ٥/١٨٦.تفسير الثعلبي ٥/١٨٦.علَّقه الرافعي في تاريخ قزوين ٢/٢٢٠.أخرجه عبد الرزاق ١/٣١١، وابن جرير ١٢/٥٣٩.أخرجه ابن جرير ١٢/٥٣٩، وابن أبي حاتم ٦/٢٠٧١.تفسير مقاتل بن سليمان ٢/٢٩٤.»أخرجه ابن جرير ١٢/٥٣٩، وابن أبي حاتم ٦/٢٠٧١ من طريق أصبغ بن الفرج.
  11,85,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَـٰقَوۡمِ أَوۡفُوا۟ ٱلۡمِكۡیَالَ وَٱلۡمِیزَانَ بِٱلۡقِسۡطِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿بالقسط﴾</span>، يعني: بالعَدْل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: إنّ الله بعث شُعَيْبًا إلى مدين، فكانوا مع كفرهم يَبْخَسُون الكيل والوزن، فدعاهم، فكَذَّبوه، فقال لهم ما ذكر اللهُ في القرآن، وما رَدُّوا عليه، فلَمّا عَتَوْا وكَذَّبوا سألوه العذاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويا قَوْمِ أوْفُوا المِكْيالَ والمِيزانَ بِالقِسْطِ﴾</span>، يعني: بالعَدْل{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَبۡخَسُوا۟ ٱلنَّاسَ أَشۡیَاۤءَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، قال: لا تظلِموا الناسَ أشياءَهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، يقول: لا تظلِموا الناسَ أشياءَهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠١<span class="dash">-</span></span> عن <span class="name-3">علي بن صالح بن حيّ</span> -من طريق عبد العزيز- قال: بلغني في قوله: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، قال: لا تَنقُصوهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَبْخَسُوا النّاسَ أشْياءَهُمْ﴾</span>، يعني: ولا تَنقُصوا الناسَ حقوقَهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قوله: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، قال: لا تَنقُصوهم؛ يُسَمِّي له شيئًا ثُمَّ يُعطِيه غيرَ ذلك{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span>، يقول: لا تَسْعَوْا في الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي روق- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، يقول: لا تَسْعَوْا في الأرض مُفْسِدين. يعني: نقصان الكيل والميزان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السدي- <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، قال: لا تَمْشُوا بالمعاصي{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، قال: لا تَسِيروا في الأرض{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَعْثَوْا فِي الأَرْضِ مُفْسِدِينَ﴾</span>، يقول: لا تعملوا فيها المعاصي، يعني بالفساد: نُقْصان الكَيل والميزان{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٧١.أخرجه ابن أبي حاتم ٦/٢٠٧٠.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن أبي حاتم ٦/٢٠٧١.علَّقه ابن أبي حاتم ٦/٢٠٧١.أخرجه ابن جرير ١٢/٥٤١. وعلَّقه ابن أبي حاتم ٦/٢٠٧١.أخرجه ابن جرير ١٢/٥٤١.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن أبي حاتم ٦/٢٠٧١.أخرجه ابن أبي حاتم ٦/٢٠٧١.أخرجه ابن جرير ١٢/٥٤١.أخرجه ابن أبي حاتم ٦/٢٠٧٢.أخرجه عبد الرزاق ١/٣١١، وابن جرير ١٢/٥٤١، وابن أبي حاتم ٦/٢٠٧١ من طريق سعيد.تفسير مقاتل بن سليمان ٢/٢٩٤.
  11,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَقِیَّتُ ٱللَّهِ خَیۡرࣱ لَّكُمۡ إِن كُنتُم مُّؤۡمِنِینَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سفيان، عمَّن ذَكَرَه- في قوله: <span class="qpc-hafs">﴿بقيت الله﴾</span>، قال: رِزْق الله{1}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: يعني: ما أبْقى اللهُ لكم مِن الحلال بعد إيفاء الكيل والوَزْنِ خيرٌ مِمّا تأخذونه بالتَّطْفِيف{2}<span class=comment-ref>٣٢٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧١</span> ذكر <u>ابنُ جرير</u> (١٢/٥٤١) هذا المعنى، ونسبه لابن عباس، ولم يذكر له سندًا، وذكر أنه رُوِي عن ابن عباس بإسناد غير مُرْتَضًى عند أهل النقل.</div></p><p><div></p><p><p><span class="item-no">٣٦٢١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بقيت الله﴾</span>، يقول: طاعة الله{3}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿بقيت الله﴾</span> قال: رِزْق الله <span class="qpc-hafs">﴿خير لكم﴾</span> مِن بَخْسِكُم الناسَ{4}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿بقيت الله خير لكم﴾</span>، يقول: حَظُّكم مِن ربِّكم خيرٌ لكم{5}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿بقيت الله﴾</span>، قال: بَقِيَّتُه خير لكم{6}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَقِيَّتُ اللَّهِ﴾</span> يعني: ثواب الله في الآخرة <span class="qpc-hafs">﴿خَيْرٌ لَكُمْ إنْ كُنْتُمْ مُؤْمِنِينَ﴾</span> يعني: لو كنتم مؤمنين بالله ﷿ لَكان ثوابُه [خيرًا] لكم مِن نُقصان الكيل والميزان، كقوله: <span class="qpc-hafs">﴿ما عِنْدَكُمْ يَنْفَدُ وما عِنْدَ اللَّهِ باقٍ﴾</span> [النحل:٩٦]، يعني: ثوابه باقٍ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٦<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: رِزْق الله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٧<span class="dash">-</span></span> عن أبي عبد الرحمن المقرئ، قال: سُئِل <span class="name-3">سفيان</span> عن قوله: <span class="qpc-hafs">﴿بَقِيَّتُ اللَّهِ خَيْرٌ لَكُمْ﴾</span>. قال: طاعة الله خير لكم، ألم تر أنّ الرجل يقول: أيْ فلان، اتقِّ الله، أبْقِ على نفسك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢١٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بقيت الله خير لكم إن كنتم مؤمنين﴾</span>، قال: الهلاك في العذاب، والبَقِيَّة في الرحمة{10}<span class=comment-ref>٣٢٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٢</span> اختُلِف في معنى: <span class="qpc-hafs">﴿بَقِيَّتُ اللَّهِ خَيْرٌ لَكُمْ﴾</span> في هذه الآية على ستة أقوال: <b>الأول:</b> ما أبقى الله لكم مِن الحلال بعد إيفاء الكَيل والوزن خيرٌ مِن البَخْس. <b>الثاني:</b> طاعة الله خير لكم. <b>الثالث:</b> حظُّكم من ربكم خير لكم. <b>الرابع:</b> رزق الله خير لكم. <b>الخامس:</b> رحمة الله خير لكم. <b>السادس:</b> ثواب الله في الآخرة خير لكم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٥٤١) <span class="mustanad">مستندًا إلى دلالة السياق، واللغة</span> القول الأول، وهو قول ابن عباس، وعلَّل (١٢/٥٤٤) ذلك بقوله: «لأنّ الله -تعالى ذِكْرُه- إنّما تقدم إليهم بالنَّهْيِ عن بخس الناس أشياءَهم في المكيال والميزان، وإلى ترك التطفيف في الكيل والبخس في الميزان دعاهم شعيب، فتَعْقِيب ذلك بالخبر عمّا لهم مِن الحظِّ في الوفاء في الدنيا والآخرة أوْلى، مع أنّ قوله: <span class="qpc-hafs">﴿بَقِيَّتُ﴾</span> إنما هي مصدرٌ مِن قول القائل: بَقَّيْتُ بَقِيَّةً مِن كذا، فلا وجْه لتوجيه معنى ذلك إلا إلى: بقيَّةُ الله التي أبقاها لكم مِمّا لكم بعد وفائكم الناس حقوقهم خيرٌ لكم مِن بقيتكم مِن الحرام الذي يبقى لكم مِن ظلمكم الناسَ ببخسكم إيّاهم في الكيل والوزن».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٦٣٠) على القول الأول بقوله: «وهذا تفسير يليق بلفظ الآية». و<span class="comment-type-2">انتقد</span> <span class="mustanad">مستندًا إلى مخالفة دلالة اللفظ</span> القول الثاني، والرابع قائلًا: «وهذا كله لا يعطيه لفظ الآية، وإنما المعنى عندي: إبقاء الله عليكم إن أطعتم».</div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنَا۠ عَلَیۡكُم بِحَفِیظࣲ ۝٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢١٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وما أنا عليكم بحفيظ﴾</span>: أحْفَظُ عليكم أعمالَكم حتى أجازيكم بها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنا عَلَيْكُمْ﴾</span> يعني: على أعمالكم <span class="qpc-hafs">﴿بِحَفِيظٍ﴾</span> يعني: برقيب، واللهُ الحافِظ لأعمالكم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٥٤٣.تفسير الثعلبي ٥/١٨٦، وتفسير البغوي ٤/١٩٥.تفسير مجاهد ص٣٩٠، وأخرجه ابن جرير ١٢/٥٤٢-٥٤٣، وابن أبي حاتم ٦/٢٠٧٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٤-. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٣١١، وابن جرير ١٢/٥٤٣، وابن أبي حاتم ٦/٢٠٧٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٢. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٤.تفسير الثعلبي ٥/١٨٦.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٣٥٩ (١٠٩٩).أخرجه ابن جرير ١٢/٥٤٣، وابن أبي حاتم ٦/٢٠٧٢ من طريق أصبغ بن الفرج.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٤-.تفسير مقاتل بن سليمان ٢/٢٩٤.
  11,87,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰشُعَیۡبُ أَصَلَوٰتُكَ تَأۡمُرُكَ أَن نَّتۡرُكَ مَا یَعۡبُدُ ءَابَاۤؤُنَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٢١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كان شعيب ﵇ كثير الصلاة؛ لذلك قالوا هذا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٢<span class="dash">-</span></span> عن <span class="name-2">الأحنف</span>: أنّ شعيبًا كان أكثر الأنبياءِ صلاة{2}. (٨/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لم يبعث اللهُ ﷿ نبيًّا إلا فَرَض عليه الصلاة والزكاة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن عيينة، عن رجل حدَّثه- في قوله: <span class="qpc-hafs">﴿يا شعيب أصلاتك تأمرك أن نترك ما يعبد آباؤنا﴾</span>، يقول: إي، واللهِ، إنّ صلواتِه لَتَأْمُرُهم أن يتركوا ما كان يعبد آباؤهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٥<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق الثوري- في قوله: <span class="qpc-hafs">﴿أصلاتك تأمرك﴾</span>، قال: أقِراءَتُك{5}. (٨/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا يا شُعَيْبُ أصَلاتُكَ تَأْمُرُكَ أنْ نَتْرُكَ﴾</span> يعني: أن نعتزل <span class="qpc-hafs">﴿ما﴾</span> كان <span class="qpc-hafs">﴿يَعْبُدُ آباؤُنا﴾</span>، وكانوا يعبدون الأوثان{6}<span class=comment-ref>٣٢٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٣</span> اختُلِف في معنى: <span class="qpc-hafs">﴿أصلاتك﴾</span> في هذه الآية على أقوال: <b>الأول:</b> الصلوات المعروفة. <b>الثاني:</b> قراءتك. وزاد <u>ابنُ عطية</u> (٥/٥) قولين آخرين: <b>الأول:</b> أمساجدك. <b>الثاني:</b> أدعواتك.</p><p>ثم <span class="comment-type-4">علَّق</span> على هذه الأقوال الأربعة بقوله: «وأقرب هذه الأقوال الأول، والرابع».</div></p><p><h3><span class="qpc-hafs">﴿أَوۡ أَن نَّفۡعَلَ فِیۤ أَمۡوَ ٰ⁠لِنَا مَا نَشَـٰۤؤُا۟ۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- <span class="qpc-hafs">﴿أو أن نفعل في أموالنا ما نشاء﴾</span>، قال: أي: ما نَشْتَهِي{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- قال: عُذِّب قومُ شعيب في قَطْعِهم الدراهم، وهو قوله: <span class="qpc-hafs">﴿أو أن نفعل في أموالنا ما نشاء﴾</span>{8}. (٨/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٢٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق داود بن قيس- <span class="qpc-hafs">﴿أو أن نفعل في أموالنا ما نشاء﴾</span>، قال: قَرْضُ الدَّراهم، وهو مِن الفساد في الأرض{9}. (٨/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوْ أنْ نَفْعَلَ فِي أمْوالِنا ما نَشاءُ﴾</span>، يعنون: إن شِئْنا نَقَصْنا الكيلَ والميزانَ، وإن شئنا وفَّيْنا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣١<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عيسى بن جعفر- في قوله: <span class="qpc-hafs">﴿أو أن نفعل في أموالنا ما نشاء﴾</span>، قال: الزكاة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا شعيب أصلاتك تأمرك﴾</span> الآية، قال: نهاهم عن قطع هذه الدنانير والدراهم، فقالوا: إنّما هي أموالُنا نفعل فيها ما نشاء؛ إن شئنا قطعناها، وإن شئنا أحرقناها، وإن شئنا طرحناها{12}<span class=comment-ref>٣٢٧٤</span>. (٨/١٢٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٤</span> لم يذكر <u>ابنُ جرير</u> (١٢/٥٤٥-٥٤٦) في معنى: <span class="qpc-hafs">﴿أوْ أنْ نَفْعَلَ فِي أمْوالِنا ما نَشاءُ﴾</span> سوى قول محمد بن كعب، وزيد بن أسلم، وابن زيد.</div></p><p><h3><span class="qpc-hafs">﴿أَوۡ أَن نَّفۡعَلَ فِیۤ أَمۡوَ ٰ⁠لِنَا مَا نَشَـٰۤؤُا۟ۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٣٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span>، قال: قَطْعُ الدراهم والدنانير المثاقيل -التي قد جازَتْ بين الناس وعرَفوها- مِن الفساد في الأرض{13}. (٨/١٢٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّكَ لَأَنتَ ٱلۡحَلِیمُ ٱلرَّشِیدُ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- <span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span>، قال: يقولون: إنّك لست بحليم، ولا رشيد{14}. (٨/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: السَّفِيه، الغاوي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٦<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق أبي المَلِيح- في قول الله: <span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span>، قال: هُزُوًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span>، قال: استهزاءً به{14}. (٨/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّكَ لَأَنْتَ الحَلِيمُ﴾</span> يعنون: السَّفِيه، <span class="qpc-hafs">﴿الرَّشِيدُ﴾</span> يعنون: الضّالّ. قالوا ذلك لشعيب استهزاءً{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span>، قال: يستهزِئُون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٤٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span>: المستهزئون يستهزئون به: <span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span>{19}<span class=comment-ref>٣٢٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٥</span> نقل <u>ابنُ عطية</u> (٥/٦) قولًا ولم ينسبه: أنّ قولهم: <span class="qpc-hafs">﴿إنَّكَ لأَنْتَ الحَلِيمُ الرَّشِيدُ﴾</span> «قالوه على جهة الحقيقة، وأنّه اعتقادهم فيه». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فكأنهم فنَّدوه، أي: أنت حليمٌ رشيدٌ فلا ينبغي لك أن تأمرنا بهذه الأوامر. ويشبه هذا المعنى قولُ اليهود مِن بني قريظة حين قال لهم رسول الله ﷺ: «يا إخوة القِرَدَة»: يا محمد، ما عَلِمناك جهولًا». ثم <span class="comment-type-4">علَّق</span> بقوله: «والشبه بين الأمرين إنما هو بالمناسبة بين كلام شعيب ﵇ وتلطفه، وبين ما بادر به محمد -عليه الصلاة والسّلام- بني قريظة». ونقل قولين آخرين: <b>الأول:</b> إنما كانت ألفاظهم: إنك لأنت الجاهل السفيه. فكنّى الله عن ذلك. <b>والثاني:</b> أنّ المعنى: إنك لأنت الحليم الرشيد عند نفسك. ولم يعلِّق عليهما.</div></p></div>",footnotes:1:تفسير البغوي ٤/١٩٥.عزاه السيوطي إلى ابن عساكر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٥-.أخرجه ابن أبي حاتم ٦/٢٠٧٢.أخرجه عبد الرزاق ١/٣١١، وابن جرير ١٢/٥٤٦-٥٤٧، وابن أبي حاتم ٦/٢٠٧٢. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن أبي حاتم ٦/٢٠٧٣.أخرجه ابن جرير في تفسيره ١٢/٥٤٥، وفي تاريخه ١/٣٢٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير في تفسيره ١٢/٥٤٥-٥٤٦، وفي تاريخه ١/٣٢٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن أبي حاتم ٦/٢٠٧٣.أخرجه ابن جرير ١٢/٥٤٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق (١٤٥٩٥)، وابن سعد ٥/١٣٥، ١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٨٦، وتفسير البغوي ٤/١٩٥.أخرجه ابن أبي حاتم ٦/٢٠٧٣. وعزاه الحافظ ابن حجر في التغليق ٤/٢٧ إليه بنفس السند عن الحسن البصري، وكذا في الفتح ٦/٤٥٠ بلفظ: يستهزئون به. ولعل أبا المليح هنا هو الحسن بن عمر الرقي (ت: ١٨١)، وهو يروي عن ميمون بن مهران دون الحسن. أما أبو المليح بن أسامة الهذلى (ت: ١٠٨) فهو من أقران الحسن وميمون ولا يروي عنهما. ينظر: تهذيب الكمال ٦/ ٢٨٠، ٣٤/٣١٦.أخرجه ابن أبي حاتم ٦/٢٠٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن جرير ١٢/٥٤٨.أخرجه ابن جرير ١٢/٥٤٨.
  11,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَرَءَیۡتُمۡ إِن كُنتُ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٤١<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجوني</span> -من طريق جعفر بن سليمان- قرأ هذه الآية: <span class="qpc-hafs">﴿إني على بينة من ربي﴾</span> [الأنعام:٥٧]، قال: على ثِقَة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرَزَقَنِی مِنۡهُ رِزۡقًا حَسَنࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٤٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿ورزقني منه رزقًا حسنًا﴾</span>، قال: الحلال{1}. (٨/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورَزَقَنِي مِنهُ رِزْقًا حَسَنًا﴾</span>، يعني: الإيمان، وهو الهُدى{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أُرِیدُ أَنۡ أُخَالِفَكُمۡ إِلَىٰ مَاۤ أَنۡهَىٰكُمۡ عَنۡهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- <span class="qpc-hafs">﴿وما أريد أن أخالفكم إلى ما أنهاكم عنه﴾</span>، يقول: لم أكن لِأنهاكم عن أمرٍ وأَرْكَبُه{4}. (٨/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أُرِيدُ أنْ أُخالِفَكُمْ إلى ما أنْهاكُمْ عَنْهُ﴾</span>، يعني: وما أريد أن أنهاكم عن أمرٍ ثُمَّ أركبُه، لقولهم لشعيب في الأعراف [٨٨]: <span class="qpc-hafs">﴿أوْ لَتَعُودُنَّ فِي مِلَّتِنا﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنۡ أُرِیدُ إِلَّا ٱلۡإِصۡلَـٰحَ مَا ٱسۡتَطَعۡتُۚ وَمَا تَوۡفِیقِیۤ إِلَّا بِٱللَّهِۚ عَلَیۡهِ تَوَكَّلۡتُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إن أريد إلا الإصلاح﴾</span> يقول: ما أُرِيد فيما آمرُكم به وأنهاكم عنه إلا إصلاحَكم وإصلاحَ أمرِكم <span class="qpc-hafs">﴿ما استطعت﴾</span> يقول: ما قدرْتُ على إصلاحه؛ لِئَلّا ينالَكم مِن الله عقوبةٌ مُنَكِّلَةٌ بخلافِكم أمرَه، ومعصيتِكم رسولَه، <span class="qpc-hafs">﴿وما توفيقي إلا بالله﴾</span> يقول: وما إصابَتِي الحقَّ في محاولتي إصلاحِكم وإصلاحِ أمركم إلا بالله، فإنّه هو المعين على ذلك، إن لا يُعِنِّي عليه لم أُصِبِ الحقَّ فيه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿إنْ أُرِيدُ﴾</span> يعني: ما أريد <span class="qpc-hafs">﴿إلّا الإصْلاحَ ما اسْتَطَعْتُ وما تَوْفِيقِي﴾</span> في الإصلاح بالخير <span class="qpc-hafs">﴿إلّا بِاللَّهِ عَلَيْهِ تَوَكَّلْتُ﴾</span> يقول: به وثِقْتُ، لقولهم: <span class="qpc-hafs">﴿لَنُخْرِجَنَّكَ يا شُعَيْبُ والَّذِينَ آمَنُوا مَعَكَ مِن قَرْيَتِنا﴾</span> [الأعراف:٨٨]{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِلَیۡهِ أُنِیبُ ۝٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإليه أنيب﴾</span>، قال: أرجِع{8}<span class=comment-ref>٣٢٧٦</span>. (٨/١٢٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٦</span> لم يذكر <u>ابنُ جرير</u> (١٢/٥٤٩-٥٥٠) في معنى: <span class="qpc-hafs">﴿وإلَيْهِ أُنِيبُ﴾</span> سوى قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٣٦٢٤٩<span class="dash">-</span></span> عن <span class="name-2">عُبَيد بن تِعلى</span>{9} -من طريق يحيى بن حسّان- قال: الإنابة: الدُّعاء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإلَيْهِ أُنِيبُ﴾</span>: وإليه المَرْجِع بعد الموت{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِلَیۡهِ أُنِیبُ ۝٨٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٥١<span class="dash">-</span></span> عن عَلِيٍّ، قال: قلتُ: يا رسول الله، أوْصِنِي. قال: «<b>قل: ربي الله. ثُمَّ اسْتَقِم</b>». قلتُ: ربي الله، وما توفيقي إلا بالله، عليه توكلت وإليه أنيب. قال: «<b>لِيَهْنِكَ العلمَ، أبا الحسن، لقد شَرِبْتَ العلمَ شُربًا، ونَهِلتَه نهلًا</b>»{12}. (٨/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٢<span class="dash">-</span></span> عن مسروق: أنّ امرأةً جاءت إلى ابن مسعود، فقالت: أتَنْهى عن الواصِلَة؟ قال: نعم. قالت: فلعلَّه في بعض نسائك. فقال: ما حفِظتِ إذن وصيةَ العبدِ الصالح: <span class="qpc-hafs">﴿وما أريد أن أخالفكم إلى ما أنهاكم عنه﴾</span>{10}. (٨/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٣<span class="dash">-</span></span> عن أبي سليمان الضَّبِّيِّ، قال: كانت تَجِيئُنا كُتُبُ <span class="name-2">عمرَ بن عبد العزيز</span> إلى خراسان، فيها الأمر والنهي، فيكتبُ في آخرها: وما كنتُ في ذلك إلا كما قال العبد الصالح: <span class="qpc-hafs">﴿وما توفيقي إلا بالله عليه توكلت وإليه أنيب﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٤<span class="dash">-</span></span> عن <span class="name-2">مالك بن دينار</span> أنّه قرأ هذه الآية: <span class="qpc-hafs">﴿وما أريد أن أخالفكم إلى ما أنهاكم عنه﴾</span>، قال: بَلَغَني: أنّه يُدْعى يوم القيامة بالمذَكِّرِ الصادق، فيُوضَع على رأسه تاجُ المُلْك، ثم يُؤمَر به إلى الجنة، فيقول: إلهي، إنّ في مقام القيامة أقوامًا قد كانوا يُعِينوني في الدنيا على ما كنتُ عليه. قال: فيُفعَل بهم مثل ما فُعِل به، ثم ينطلق يقودهم إلى الجنة لِكرامته على الله{15}. (٨/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٥<span class="dash">-</span></span> عن <span class="name-3">أبي إسحاق الفزاري</span>، قال: ما أردتُ أمرًا قطُّ فتلوت عنده هذه الآية إلا عُزِم لي على الرشد: <span class="qpc-hafs">﴿إن أريد إلا الإصلاح ما استطعت وما توفيقي إلا بالله عليه توكلت وإليه أنيب﴾</span>{15}. (٨/١٢٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٧٣.أخرجه ابن أبي حاتم ٦/٢٠٧٣.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن جرير ١٢/٥٤٩، وابن أبي حاتم ٦/٢٠٧٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٤.أخرجه ابن جرير ١٢/٥٤٩.تفسير مقاتل بن سليمان ٢/٢٩٥.تفسير مجاهد ص٣٩٠، وأخرجه ابن جرير ١٢/٥٤٩-٥٥٠، وابن أبي حاتم ٦/٢٠٧٤. وعزاه السيوطي إلى أبي الشيخ.في مطبوعة المصدر: عبيد بن يعلى، وهو تصحيف.أخرجه ابن أبي حاتم ٦/٢٠٧٤.تفسير مقاتل بن سليمان ٢/٢٩٤-٢٩٥.أخرجه أبو نعيم في الحلية ١/٦٥، من طريق محمد بن يونس الكديمي، عن عبد الله بن داود الخريبي، عن هرمز بن حوران، عن أبي عون، عن أبي صالح الحنفي، عن علي به.</p><p>قال السيوطي: «في إسناده محمد بن يونس الكديمي». قال ابن حبان في المجروحين ٢/٣١٣(١٠٢٣) في ترجمة الكديمي: «وكان يضع على الثقات الحديث وضعًا، ولعلَّه قد وضع أكثر من ألف حديث». وقال المتقي الهندي في كنز العمال ١٣/١٧٧ (٣٦٥٢٤): «فيه الكديمي».أخرجه ابن أبي حاتم ٦/٢٠٧٤.أخرجه ابن أبي حاتم ٦/٢٠٧٤.عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.