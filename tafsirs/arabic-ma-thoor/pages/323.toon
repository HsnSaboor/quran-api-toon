tafsir[14]{c,v,t}:
21,11," <q>﴿وَكَمۡ قَصَمۡنَا مِن قَرۡیَةࣲ كَانَتۡ ظَالِمَةࣰ وَأَنشَأۡنَا بَعۡدَهَا قَوۡمًا ءَاخَرِینَ ۝١١﴾</q> - تفسير ٤٨٧٦٧- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: بعث الله نبيًّا مِن حِمْيَر يُقال له: شعيب، فوَثَب إليه عبدٌ، فضربه بعصًا، فسار إليهم بُخْتُنَصَّرَ، فقاتلهم، فقتلهم حتى لم يَبْق منهم شيء. وفيهم أنزل الله: <q>﴿وكم قصمنا من قرية كانت ظالمة﴾</q> إلى قوله: <q>﴿خامدين﴾</q>{1}. (١٠/٢٧٣) ٤٨٧٦٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وكم قصمنا من قرية﴾</q>، قال: أهلكناها{2}. (١٠/٢٧٣) ٤٨٧٦٩- عن محمد بن السائب الكلبي -من طريق مَعْمَر- <q>﴿وكم قصمنا من قرية﴾</q>، قال: هي حَضُورُ{3} بني أزد{4}٤٣٣٣. (١٠/٢٧٣) ٤٣٣٣ ساق ابنُ عطية (٦/١٥٦) هذا القول، ثم قال: «ويحتمل أن لا يريد بالآية قريةً بعينها، وأنه واصف حال كل قرية من القرى المعذبة، وأنّ أهل كل قرية كانوا إذا أحسوا العذاب من أي نوع كان أخذوا في الفرار». ٤٨٧٧٠- قال عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿قصمنا من قرية﴾</q>، قال: باليمن، <q>﴿قصمنا﴾</q> بالسيف أُهْلِكوا{5}. (ز) ٤٨٧٧١- قال مقاتل بن سليمان: <q>﴿وكم قصمنا من قرية﴾</q> يعني: أهلكنا مِن قرية بالعذاب في الدنيا قبل أهل مكة <q>﴿كانت ظالمة وأنشأنا بعدها﴾</q> يقول: وجعلنا بعد هلاك الأمم الخالية <q>﴿قوما آخرين﴾</q> يعني: قومًا كانوا باليمن في قرية تسمى: حَضُور، وذلك أنهم قتلوا نبيًّا من الأنبياء ﵈، فسلَّط الله ﷿ جُند بُخْتِ نَصَّر، فقتلوهم، كما سَلَّط بُخْتُ نَصَّرَ والروم على اليهود ببيت المقدس فقتلوهم، وسبوهم حين قتلوا يحيى بن زكريا وغيره من الأنبياء ﵈{6}. (ز) ٤٨٧٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله <q>﴿قصمنا من قرية﴾</q>، قال: قصمها: أهلكها{5}. (ز) ٤٨٧٧٣- قال يحيى بن سلّام، في قوله: <q>﴿وكم قصمنا﴾</q>: أي: أهلكنا <q>﴿من قرية كانت ظالمة﴾</q> يعني: مشركة، يعني: أهلها، <q>﴿وأنشأنا﴾</q> أي: وخلقنا <q>﴿بعدها قوما آخرين﴾</q>{8}. (ز) ",footnotes:1:أخرجه ابن مردويه -كما في فتح الباري ٨/٤٣٦-.أخرجه ابن جرير ١٦/٢٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.حَضُور - ويقال: حضوراء-: بلدة باليمن. ينظر: معجم البلدان ٢/ ٢٧٢.أخرجه عبد الرزاق ٢/٢٢ بلفظ: حصون. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٢٣٣.تفسير مقاتل بن سليمان ٣/٧٢.أخرجه ابن جرير ١٦/٢٣٣.تفسير يحيى بن سلّام ١/٣٠١.
21,12," <q>﴿فَلَمَّاۤ أَحَسُّوا۟ بَأۡسَنَاۤ﴾</q> - تفسير ٤٨٧٧٤- قال مقاتل بن سليمان: فذلك قوله ﷿: <q>﴿فلما أحسوا بأسنا﴾</q>، يقول: فلمّا رأوا عذابنا أهل حَضُور{1}. (ز) ٤٨٧٧٥- قال يحيى بن سلّام، في قوله: <q>﴿فلما أحسوا﴾</q>: رأوا <q>﴿بأسنا﴾</q> يعني: عذابنا، يعني: قبل أن يهلكوا. رجع إلى قصة مَن هلك{2}. (ز) <q>﴿إِذَا هُم مِّنۡهَا یَرۡكُضُونَ ۝١٢﴾</q> - تفسير ٤٨٧٧٦- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿إذا هم منها يركضون﴾</q>، قال: يَفِرُّون{3}. (١٠/٢٧٤) ٤٨٧٧٧- قال مقاتل بن سليمان: قوله ﷿: <q>﴿إذا هم منها يركضون﴾</q>، يقول: إذا هم مِن القرية يهربون{1}. (ز) ٤٨٧٧٨- قال يحيى بن سلّام، في قوله: <q>﴿إذا هم منها﴾</q>: من القرية، <q>﴿يركضون﴾</q> يَفِرّون من العذاب حين جاءهم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢.تفسير يحيى بن سلّام ١/٣٠١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٢.تفسير يحيى بن سلّام ١/٣٠١.
21,13," <q>﴿لَا تَرۡكُضُوا۟﴾</q> - تفسير ٤٨٧٧٩- عن عبد الله بن عباس – من طريق العوفي- في قوله: <q>﴿لا تركضوا وارجعوا إلى ما أترفتم فيه ومساكنكم لعلكم تسألون(١٣)﴾</q>. يعني: مَن نزل به العذاب في الدنيا ممن كان يعصي الله من الأمم{1}. (ز) ٤٨٧٨٠- عن ابن وهب، قال: حدَّثني رجل مِن المحرَّرين{2}، قال: كان باليمن قريتان، يُقال لإحداهما: حَضُوراء، والأخرى: قلاثة، فبَطِرُوا وأُتْرِفُوا حتى ما كانوا يغلقون أبوابهم، فلما أُتْرِفُوا بعث الله إليهم نبيًّا، فدعاهم، فقتلوه، فألقى الله في قلب بُخْتِنَصَّرَ أن يغزوهم، فجهَّز إليهم جيشًا، فقاتلوهم، فهزموا جيشَه، فرجعوا منهزمين إليه، فجهَّز إليهم جيشًا آخر أكثف مِن الأول، فهزموهم أيضًا، فلمّا رأى بُخْتُنَصَّرَ ذلك غزاهم هو بنفسه، فقاتلوه، فهزمهم حتى خرجوا منها يركضون، فسمعوا مناديًا يقول: <q>﴿لا تركضوا وارجعوا إلى ما أترفتم فيه ومساكنكم﴾</q>. فرجعوا، فسمعوا مناديًا يقول: يا لَثارات النبيِّ. فقُتِلُوا بالسيف، فهي التي قال الله: <q>﴿وكم قصمنا من قرية﴾</q> إلى قوله: <q>﴿خامدين﴾</q>{3}. (١٠/٢٧٥) ٤٨٧٨١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لا تركضوا﴾</q>، قال: لا تَفِرُّوا{4}. (١٠/٢٧٤) ٤٨٧٨٢- عن الربيع بن أنس، في الآية، قال: كانوا إذا أحَسُّوا بالعذاب، وذهبت عنهم الرسل مِن بعد ما أنذروهم؛ فكذَّبوهم، فلما فقدوا الرسل وأحسوا بالعذاب أرادوا الرجعة إلى الإيمان، وركضوا هاربين من العذاب، فقيل لهم: <q>﴿لا تركضوا﴾</q>. فعرفوا أنه لا محيصَ لهم{5}. (١٠/٢٧٤) ٤٨٧٨٣- قال مقاتل بن سليمان: قالت لهم الملائكة كهيئة الاستهزاء: <q>﴿لا تركضوا﴾</q>، يقول: لا تهربوا{6}٤٣٣٤. (ز) ٤٣٣٤ ذكر ابنُ عطية (٦/١٥٦) أنّ قوله: <q>﴿لا تَرْكُضُوا...﴾</q> يحتمل أن يكون مِن قول رجال بختنصر، ويكون المعنى أنهم خدعوهم واستهزؤوا بهم بأن قالوا للهاربين منهم: لا تفروا وارجعوا إلى مواضعكم لعلكم تسألون صلحًا أو جزية أو أمرًا يتفق عليه. فلما انصرفوا أمر بختنصر بقتلهم. وذكر أنه يحتمل أن يكون مِن كلام ملائكة العذاب، وأنّ الآيات وصْف قصة كل قرية، وأنه لم يرد تعيين حضورا ولا غيرها، ويكون المعنى: أنّ أهل هذه القرى كانوا باغترارهم يرون أنهم مِن الله تعالى بمكان، وأنّه لو جاءهم عذابٌ أو أمْرٌ لم ينزل بهم حتى يخاصموا أو يسألوا عن وجه تكذيبهم لنبيهم، فيحتجُّون هم عند ذلك بحجج تنفعهم في ظنهم، فلمّا نزل العذاب دون هذا الذي أملوه وركضوا فارين نادتهم الملائكة -على وجْه الهزء بهم-: لا تركضوا وارجعوا لعلكم تسألون كما كنتم تطمعون بسفه رأيكم، ثم يكون قوله: <q>﴿حصيدا﴾</q>، أي: بالعذاب ترُكوا كالحصيد. <q>﴿وَٱرۡجِعُوۤا۟ إِلَىٰ مَاۤ أُتۡرِفۡتُمۡ فِیهِ وَمَسَـٰكِنِكُمۡ﴾</q> - تفسير ٤٨٧٨٤- عن سعيد بن جبير، في قوله: <q>﴿وارجعوا إلى ما أترفتم فيه﴾</q>، قال: ارجعوا إلى دُورِكم، وأموالكم{5}. (١٠/٢٧٤) ٤٨٧٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وارجعوا إلى ما أترفتم فيه﴾</q>، يقول: ارجِعُوا إلى دُنياكم التي أُتْرِفتم فيها{8}. (١٠/٢٧٤) ٤٨٧٨٦- قال مقاتل بن سليمان: <q>﴿وارجعوا إلى ما أترفتم فيه﴾</q> يعني: إلى ما خُوِّلْتُم فيه من الأموال <q>﴿و﴾</q> إلى <q>﴿مساكنكم﴾</q> يعني: قريتكم التي هربتم منها{6}. (ز) ٤٨٧٨٧- قال يحيى بن سلّام: <q>﴿وارجعوا إلى ما أترفتم فيه﴾</q> يعني: نعيمهم الذي كانوا فيه{10}. (ز) <q>﴿لَعَلَّكُمۡ تُسۡـَٔلُونَ ۝١٣﴾</q> - تفسير ٤٨٧٨٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لعلكم تسألون﴾</q>، قال: تفقهون{11}. (١٠/٢٧٤) ٤٨٧٨٩- قال مجاهد بن جبر: <q>﴿لعلكم تُسألون﴾</q>: تفهمون{12}٤٣٣٥. (ز) ٤٣٣٥ انتقد ابنُ عطية (٦/١٥٧) قول مجاهد مستندًا لظاهر لفظ الآية، فقال: «وهذا تفسير لا يعطيه اللفظ». ٤٨٧٩٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لعلكم تسألون﴾</q>: مِن دنياكم شيئًا؛ استهزاء بهم{13}. (١٠/٢٧٤) ٤٨٧٩١- قال مقاتل بن سليمان: <q>﴿لعلكم تسألون﴾</q> كما سُئِلْتُم الإيمان قبل نزول العذاب{6}. (ز) ٤٨٧٩٢- قال يحيى بن سلّام، في قوله: <q>﴿لعلكم تسئلون﴾</q>: أي: لا تقدرون على ذلك، ولا يكون ذلك{15}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٣٤.المحررون: الموالي. النهاية (حرر).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٦٩-٧٠ (١٥٦). وعزاه السيوطي إلى ابن أبي حاتم، وفي الدر: «قلابة» بدل «قلاثة».أخرجه ابن جرير ١٦/٢٣٥. وعلَّقه يحيى بن سلّام ١/٣٠١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٣.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ١/٣٠١، وابن جرير ١٦/٢٣٦. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٣.تفسير يحيى بن سلّام ١/٣٠١.تفسير مجاهد ص٤٦٩، وأخرجه ابن جرير ١٦/٢٣٥.علَّقه البخاري ٤/١٧٦٦. وعزاه السيوطي إليه وإلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم بلفظ: تتفهمون.أخرجه يحيى بن سلّام ١/٣٠١، وابن جرير ١٦/٢٣٥-٢٣٦. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٣.تفسير يحيى بن سلّام ١/٣٠١-٣٠٢.
21,14," <q>﴿قَالُوا۟ یَـٰوَیۡلَنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝١٤﴾</q> - تفسير ٤٨٧٩٣- قال مقاتل بن سليمان: فلمّا رأوا العذاب <q>﴿قالوا يا ويلنا إنا كنا ظالمين﴾</q>{1}. (ز) ٤٨٧٩٤- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿قالوا يا ويلنا إنا كنا ظالمين* فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين﴾</q>، قال: هي قرية مِن قرى اليمن، يُقال لها: حَضُور، قتلوا نبيَّهم، فغزاهم بُخْتُنَصَّرَ حتى أجْهَضَهُم{2} مِن قريتهم حتى أخرجهم منها، فضربت الملائكة وجوههم حتى عادوا إلى مساكنهم، فأُخِذوا، فـ<q>﴿قالوا يا ويلنا إنا كنا ظالمين* فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين﴾</q>{3}. (ز) ٤٨٧٩٥- قال يحيى بن سلّام، في قوله: <q>﴿قالوا يا ويلنا﴾</q> وهذا حين جاءهم العذاب <q>﴿إنا كنا ظالمين﴾</q>{4}. (ز) <q>﴿قَالُوا۟ یَـٰوَیۡلَنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝١٤﴾</q> - آثار متعلقة بالآية ٤٨٧٩٦- عن أبي توبة الربيع بن نافع، قال: سُئِل سفيان بن عيينة عن قوله: «يُوشِك أن يأتي على الناس زمانٌ أفضل عبادتهم التَلاوُمُ، ويقال لهم: النَتْنى»{5}. قال سفيان: ألا ترى أنه يبلغ بهم الكفر؟ إنما قال النتنى ولوم أنفسهم، فإذا كانوا عارفين بالحقِّ فهو خير مِن أن يُزيَّن لهم سوءُ أعمالهم، ولكنهم قوم يعرفون القبيح فلا يرفعون عنه، وليس هذا كقولهم: <q>﴿يا ويلنا إنا كنا ظالمين﴾</q>؛ لأنّ هؤلاء إنما أقروا بالظلم حين رأوا العذاب: <q>﴿فاعترفوا بذنبهم فسحقًا لأصحاب السعير﴾</q> [الملك:١١]، فالظلم شرك{6}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٣.أجْهَضَهم: أزالهم ونحّاهم عنها. النهاية (جهض).أخرجه إسحاق البستي في تفسيره ص٢٩٥.تفسير يحيى بن سلّام ١/٣٠٢.أخرج أبو داود في الزهد ص١٧٦ (١٨٢) بسنده عن مالك بن مِغْوَل، قال: قال عبد الله [بن مسعود]: يأتي على الناس -أو يكون في آخر الناس- زمان أفضل أعمالهم بينهم التلاوم، يسمون: الأنتان.أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
21,15," <q>﴿فَمَا زَالَت تِّلۡكَ دَعۡوَىٰهُمۡ حَتَّىٰ جَعَلۡنَـٰهُمۡ حَصِیدًا خَـٰمِدِینَ ۝١٥﴾</q> - تفسير ٤٨٧٩٧- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿حتى جعلناهم حصيدا﴾</q> قال: الحصاد، <q>﴿خامدين﴾</q> قال: كخمود النار إذا طفئت{1}. (١٠/٢٧٥) ٤٨٧٩٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿خامدين﴾</q>. قال: مَيِّتين. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت لبيد بن ربيعة وهو يقول: خَلُّوا ثيابهم على عوراتهم فهم بأفنيةِ البيوتِ خُمُود؟{2}. (١٠/٢٧٦) ٤٨٧٩٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ما زالت تلك دعواهم﴾</q> قال: هم أهل حَضُور، كانوا قتلوا نبيَّهم، فأرسل الله عليهم بُخْتَنَصَّرَ، فقتلهم. وفي قوله: <q>﴿حتى جعلناهم حصيدا خامدين﴾</q> قال: بالسيف، ضربت الملائكةُ وجوههم حتى رجعوا إلى مساكنهم{3}. (١٠/٢٧٥) ٤٨٨٠٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فما زالت تلك دعواهم﴾</q> قال: لما رأوا العذاب وعاينوه لم يكن لهم هِجِّيرى{4} إلا قولُهم: <q>﴿إنا كنا ظالمين﴾</q>. حتى دمَّر الله عليهم وأهلكهم{5}. (١٠/٢٧٤) ٤٨٨٠١- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿فما زالت تلك دعواهم﴾</q> يقول: فما زال الويلُ قولهم <q>﴿حتى جعلناهم حصيدا خامدين﴾</q> يقول: أطْفَأْناهم بالسيف، فخَمَدُوا مثلَ النار إذا طَفِئت فخَمَدَت{6}. (ز) ٤٨٨٠٢- قال يحيى بن سلّام في قوله: <q>﴿فما زالت تلك دعواهم﴾</q> يعني: قولهم: <q>﴿يا ويلنا إنا كنا ظالمين﴾</q> يعني: فما زال ذلك قولهم، <q>﴿حتى جعلناهم حصيدا خامدين﴾</q> حتى أُهلِكوا{7}. (ز) <q>﴿فَمَا زَالَت تِّلۡكَ دَعۡوَىٰهُمۡ حَتَّىٰ جَعَلۡنَـٰهُمۡ حَصِیدًا خَـٰمِدِینَ ۝١٥﴾</q> - آثار متعلقة بالآية ٤٨٨٠٣- عن عبد الله بن عمر -من طريق مالك بن مِغْوَل، عن رجل- أنّه كان -أراه- يكره أن يسمع الرجل يقول: هلك الناس. قال: فسمع رجلًا يقول: هلك الناس. فقال ابن عمر: هَلَكَت العَجَزَةُ أو الفَجَرَةُ. -الشك من إسحاق- ثم قال: إنّ الله لم يُعَذِّب قومًا حتى يُعْذِروا مِن أنفسهم، وإعذارهم أن يقولوا: هلكنا. ثم قرأ: <q>﴿فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين﴾</q>{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٣٧. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي -كما في الإتقان ٢/٨٩- وفيه: «همود» بدل: «خمود».أخرجه ابن جرير ١٦/٢٣٧ بلفظ: أهل حصون، وأخرج عبد الرزاق ٢/٢٢ آخره مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.الهِجِّيرى: الدَّأب والعادة والدَّيْدَن. النهاية (هجر).أخرجه يحيى بن سلّام ١/٣٠٢، وابن جرير ١٦/٢٣٧، كذلك رواه من طريق معمر بلفظ: فما كان هجيراه إلا الويل حتى هلكوا. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٣.تفسير يحيى بن سلّام ١/٣٠٢.أخرجه إسحاق البستي في تفسيره ص٢٩٦.
21,16," <q>﴿وَمَا خَلَقۡنَا ٱلسَّمَاۤءَ وَٱلۡأَرۡضَ وَمَا بَیۡنَهُمَا لَـٰعِبِینَ ۝١٦﴾</q> - تفسير ٤٨٨٠٤- تفسير مجاهد بن جبر: ما خلقنا من جنَّةٍ، ولا نارٍ، ولا موتٍ، ولا بعثٍ، ولا حسابٍ لاعبين{1}. (ز) ٤٨٨٠٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما خلقنا السماء والأرض وما بينهما لاعبين﴾</q>، يقول: ما خلقناهما عَبَثًا، ولا باطلًا{2}. (١٠/٢٧٦) ٤٨٨٠٦- قال إسماعيل السُّدِّيّ: أي: إنّا لم نخلقهما وما بينهما باطلًا{1}. (ز) ٤٨٨٠٧- قال مقاتل بن سليمان: <q>﴿وما خلقنا السماء والأرض﴾</q> يعني: السموات السبع والأرضين السبع <q>﴿وما بينهما﴾</q> مِن الخلق <q>﴿لاعبين﴾</q> يعني: عابثين لغير شيء، ولكن خلقناهما لأمرٍ هو كائن{4}. (ز) ٤٨٨٠٨- قال يحيى بن سلّام: أي: إنما خلقناهما للبعث والحساب، والجنة والنار{5}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ١/٣٠٢.أخرجه ابن جرير ١٦/٢٣٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٢.تفسير مقاتل بن سليمان ٣/٧٣.تفسير يحيى بن سلّام ١/٣٠٢.
21,17," <q>﴿لَوۡ أَرَدۡنَاۤ أَن نَّتَّخِذَ لَهۡوࣰا﴾</q> - تفسير ٤٨٨٠٩- عن عبد الله بن عباس، في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، قال: لعبًا{1}. (١٠/٢٧٧) ٤٨٨١٠- قال عبد الله بن عباس -من طريق عطاء-: اللهو: المرأة{2}. (ز) ٤٨٨١١- قال عبد الله بن عباس -من طريق الكلبي-: اللهو: الولد{3}. (ز) ٤٨٨١٢- عن إبراهيم النخعي، في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، قال: نساء{4}. (١٠/٢٧٧) ٤٨٨١٣- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، قال: زوجة{5}. (ز) ٤٨٨١٤- عن عكرمة مولى ابن عباس، في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، قال: اللهو: الولد{6}. (١٠/٢٧٦) ٤٨٨١٥- عن الحسن البصري، في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، قال: النساء{7}. (١٠/٢٧٦) ٤٨٨١٦- عن الحسن البصري -من طريق الحسن بن دينار- قال: اللهو بلسان اليمن: المرأة{8}. (١٠/٢٧٦) ٤٨٨١٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، قال: اللهو في بعض لغة أهل اليمن: المرأة{9}. (١٠/٢٧٧) ٤٨٨١٨- قال إسماعيل السُّدِّيّ: <q>﴿لهوًا﴾</q>، يعني: صاحبة وولدًا{10}. (ز) ٤٨٨١٩- قال مقاتل بن سليمان: <q>﴿لو أردنا أن نتخذ لهوا﴾</q>، يعني: ولدًا، وذلك أنّ نصارى نجران -السيد والعاقب، ومن معهما- قالوا: عيسى ابن الله، فقال الله ﷿: <q>﴿لو أردنا أن نتخذ لهوا لاتخذناه من لدنا﴾</q>{11}. (ز) ٤٨٨٢٠- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿لو أردنا أن نتخذ لهوا﴾</q>: نساء وولدًا{5}٤٣٣٦. (ز) ٤٣٣٦ ذكر ابنُ كثير (٩/٣٩٥) أنّ تفسير اللهو بالمرأة والولد فيه تلازم، ثم قال: «وهو كقوله تعالى: <q>﴿لو أراد الله أن يتخذ ولدا لاصطفى مما يخلق ما يشاء سبحانه﴾</q> [الزمر:٤]». وذكر ابنُ تيمية (٤/٣٦٦) أنّ مَن فسروا اللهو بالولد والزوجة قالوا ذلك؛ لأنّ مِن المشركين مَن جعل لله ولدًا وصاحبة، وقالوا: إنه ضاهى الحق، وهم يسمون المرأة لهوًا، والولد لهوًا. <q>﴿لَّٱتَّخَذۡنَـٰهُ مِن لَّدُنَّاۤ﴾</q> - تفسير ٤٨٨٢١- عن إبراهيم النخعي، في قوله: <q>﴿لاتخذناه من لدنا﴾</q>، قال: مِن الحُور العين{4}. (١٠/٢٧٧) ٤٨٨٢٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لاتخذناه من لدنا﴾</q>، قال: مِن عندنا{14}. (١٠/٢٧٧) ٤٨٨٢٣- قال إسماعيل السُّدِّيّ: <q>﴿لاتخذناه من لدنا﴾</q>: مِن عندنا{10}. (ز) ٤٨٨٢٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿لو أردنا أن نتخذ لهوا﴾</q> الآية، يقول: لو أردت أن أتخذ ولدًا لاتخذت مِن الملائكة{4}. (١٠/٢٧٦) ٤٨٨٢٥- قال مقاتل بن سليمان: قال الله ﷿: <q>﴿لاتخذناه من لدنا﴾</q>، يعني: مِن عندنا من الملائكة؛ لأنهم أطيب وأطهر مِن عيسى، ولم نتخذه مِن أهل الأرض{11}. (ز) ٤٨٨٢٦- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قال: قالوا: مريم صاحبته، وعيسى ولده. فقال -تبارك وتعالى-: <q>﴿لو أردنا أن نتخذ لهوا﴾</q> نساء وولدًا؛ <q>﴿لاتخذناه من لدنا﴾</q> مِن عندنا، لاتخذنا نساء وولدًا مِن أهل السماء، وما اتَّخذنا نساء وولدًا مِن أهل الارض{5}. (ز) <q>﴿إِن كُنَّا فَـٰعِلِینَ ۝١٧﴾</q> - تفسير ٤٨٨٢٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿إن كنا فاعلين﴾</q>، أي: ما كنا فاعلين. يقول: وما خلقنا جنة، ولا نارًا، ولا موتًا، ولا بعثًا، ولا حسابًا. وكلُّ شيء في القرآن <q>﴿إن﴾</q> فهو إنكار{19}. (١٠/٢٧٧) ٤٨٨٢٨- عن الحسن البصري -من طريق عمرو، ويونس- <q>﴿إن كنا فاعلين﴾</q>: ما كنا فاعلين، <q>﴿وإن كان مكرهم لتزول منه الجبال﴾</q> [إبراهيم:٤٦]، أي: ما كان مكرهم لتزول منه الجبال، و<q>﴿إن كان للرحمن ولد فأنا أول العابدين﴾</q> [ الزخرف:٨١]، يقول: ما كان للرحمن ولد، وأنا أول الدائنين بأنه لم يكن له ولد، <q>﴿فَإنْ كُنْتَ فِي شَكٍّ مِمّا أنْزَلْنا إلَيْكَ﴾</q> [يونس:٩٤]، يقول: ما كنت في شك مما أنزلنا{20}. (٧/٧٠٦) ٤٨٨٢٩- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿إن كنا فاعلين﴾</q>: أي: ما كُنّا فاعلين{21}. (١٠/٢٧٧) ٤٨٨٣٠- عن قتادة بن دعامة، - من طريق سعيد- في قوله: <q>﴿إن كنا فاعلين﴾</q>: أي: إنّ ذلك لا يكون، ولا ينبغي{22}. (١٠/٢٧٧) ٤٨٨٣١- قال يحيى بن سلّام:قال قتادة= (ز) ٤٨٨٣٢- والسُّدِّيّ: أي: ما كُنّا فاعلين، وذلك أنّ المشركين قالوا: إنّ الملائكة بنات الله. وقد قال في آية أخرى: <q>﴿أنى يكون له ولد ولم تكن له صاحبة﴾</q> [الأنعام:١٠١]{10}. (ز) ٤٨٨٣٣- قال مقاتل: <q>﴿إن﴾</q> للنفي، أي: ما كنا فاعلين{2}. (ز) ٤٨٨٣٤- قال مقاتل بن سليمان: قال الله ﷿: <q>﴿إن كنا فاعلين﴾</q>، يقول: ما كُنّا فاعلين ذلك؛ أن نتخذ ولدًا. مثلها في الزخرف{25}. (ز) ٤٨٨٣٥- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿إن كنا فاعلين﴾</q>، قال: ما كُنّا نفعل{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٣١٣.تفسير البغوي ٥/٣١٣. وهو في تفسير الثعلبي ٦/٢٧٢ دون ذكر الطريق.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٣٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلّام ١/٣٠٢. وعزاه السيوطي إلى ابن أبي حاتم. وأخرج ابن جرير ١٦/٢٣٣ من طريق عقبة بن أبي جَسْرة، قال: شهدت الحسن بمكة، قال: وجاءه طاوس وعطاء ومجاهد، فسألوه عن قول الله -تبارك وتعالى-: <q>﴿لو أردنا أن نتخذ لهوا لاتخذناه﴾</q>. قال الحسن: اللهو: المرأة.أخرجه ابن جرير ١٦/٢٣٩، ومن طريق سعيد نحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٣.تفسير مقاتل بن سليمان ٣/٧٣.أخرجه ابن جرير ١٦/٢٣٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير١٦/٢٤٠، وعلقه يحيى بن سلّام ١/٣٠٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٣.أخرجه ابن جرير ١٦/٢٣٩.أخرجه ابن جرير١٦/٢٤٠ بعضه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٩٧. وعزاه السيوطي إلى ابن الأنباري في المصاحف، وزاد: <q>﴿ولقد مكناهم فيما إن مكناكم فيه﴾</q> [الأحقاف:٢٦]، معناه: في الذي ما مكنّاكم فيه.أخرجه عبد الرزاق ٢/٢٢، وابن جرير ١٦/٢٣٩.أخرجه ابن جرير ١٦/٢٣٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٣.تفسير البغوي ٥/٣١٣.تفسير مقاتل بن سليمان ٣/٧٣. يشير إلى قوله تعالى: <q>﴿قُلْ إنْ كانَ لِلرَّحْمَنِ ولَدٌ فَأَنا أوَّلُ العابِدِينَ﴾</q> [الزخرف:٨١].أخرجه ابن جرير ١٦/٢٣٩.
21,18," <q>﴿بَلۡ نَقۡذِفُ بِٱلۡحَقِّ﴾</q> - تفسير ٤٨٨٣٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بل نقذف بالحق﴾</q>، قال: كتاب الله القرآن{1}. (١٠/٢٧٧) ٤٨٨٣٧- قال مقاتل بن سليمان: <q>﴿بل نقذف﴾</q> بل نرمي <q>﴿بالحق﴾</q> الذي قال الله ﷿: <q>﴿إن كنا فاعلين﴾</q>{2}. (ز) ٤٨٨٣٨- قال يحيى بن سلّام: <q>﴿بل نقذف بالحق﴾</q> بالقرآن{3}. (ز) <q>﴿عَلَى ٱلۡبَـٰطِلِ﴾</q> - تفسير ٤٨٨٣٩- عن قتادة بن دعامة، في قوله: <q>﴿على الباطل﴾</q>، قال: اللَّبْسُ{4}. (١٠/٢٧٧) ٤٨٨٤٠- عن قتادة بن دعامة -من طريق سعيد - قوله: <q>﴿بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق﴾</q>: والحق: كتاب الله القرآن، والباطل إبليس{5}. (ز) ٤٨٨٤١- قال مقاتل بن سليمان: <q>﴿على الباطل﴾</q> الذي قالوا: إنّ لله ﷿ ولدًا{2}. (ز) ٤٨٨٤٢- قال يحيى بن سلّام، في قوله: <q>﴿على الباطل﴾</q>: على باطلهم، يعني: شركهم{3}. (ز) <q>﴿فَیَدۡمَغُهُۥ فَإِذَا هُوَ زَاهِقࣱۚ﴾</q> - تفسير ٤٨٨٤٣- عن عبد الله بن عباس -من طريق عطاء- <q>﴿فيدمغه فإذا هو زاهق﴾</q>: فإذا هو المغلوب{8}. (ز) ٤٨٨٤٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فإذا هو زاهق﴾</q>، قال: هالِك{9}. (١٠/٢٧٧) ٤٨٨٤٥- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿فيدمغه فإذا هو زاهق﴾</q>، أي: ذاهِب{10}. (ز) ٤٨٨٤٦- قال مقاتل بن سليمان: <q>﴿فيدمغه فإذا هو زاهق﴾</q>، يعني: ذاهِب{2}. (ز) <q>﴿وَلَكُمُ ٱلۡوَیۡلُ مِمَّا تَصِفُونَ ۝١٨﴾</q> - تفسير ٤٨٨٤٧- قال مجاهد بن جبر: مما تَكْذِبُون{12}. (ز) ٤٨٨٤٨- عن الحسن البصري -من طريق أيوب- في قوله: <q>﴿ولكم الويل مما تصفون﴾</q>، قال: هي -واللهِ- لكل واصفِ كَذِبٍ إلى يوم القيامة{13}. (١٠/٢٧٧) ٤٨٨٤٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولكم الويل مما تصفون﴾</q>: أي: تكذبون{14}. (ز) ٤٨٨٥٠- قال مقاتل بن سليمان: <q>﴿ولكم الويل مما تصفون﴾</q>، يقول: لكم الويل في الآخرة مما تقولون مِن البهتان بأنّ لله ولدًا{2}. (ز) ٤٨٨٥١- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿ولكم الويل مما تصفون﴾</q>، قال: تُشْرِكون. وقوله: <q>﴿عما يصفون﴾</q> [الأنعام:١٠٠، الأنبياء:٢٢، المؤمنون:٩١، الصافات:١٥٩، ١٨٠، الزخرف:٨٢]، قال: يُشْرِكون. قال: وقال مجاهد <q>﴿سيجزيهم وصفهم﴾</q> [الأنعام:١٣٩]، قال: قولهم الكذب في ذلك{16}. (ز) ٤٨٨٥٢- قال يحيى بن سلّام: <q>﴿ولكم الويل﴾</q> العذاب <q>﴿مما تصفون﴾</q> لقولهم: إنّ الملائكة بنات الله{3}٤٣٣٧. (ز) ٤٣٣٧ اختُلِف في معنى قوله: <q>﴿مما تصفون﴾</q>؛ فقال قوم: تشركون. وقال غيرهم: تكذبون. واختار ابنُ جرير (١٦/٢٤١) تقارب المعنى بينهما لدلالة العقل، فقال: «لأنّ مَن وصف الله بأن له صاحبة فقد كذب في وصْفِه إيّاه بذلك، وأشرك به، ووصفه بغير صفته». وذكر أنّ المعنى: ولكم الويل من وصفكم ربكم بغير صفته، وقيلكم إنه اتخذ زوجة وولدًا، وفريتكم عليه. وساق القولين ثم قال: «غير أن أولى العبارات أن يعبر بها عن معاني القرآن أقربها إلى فهم سامعيه». وذكر ابنُ عطية (٦/١٥٧) قولًا بأنّ المراد بالويل: واد في جهنم، واختاره بقوله: «هو المراد في الآية». ولم يذكر مستندًا. <q>﴿وَلَكُمُ ٱلۡوَیۡلُ مِمَّا تَصِفُونَ ۝١٨﴾</q> - آثار متعلقة بالآية ٤٨٨٥٣- قال عطاء [بن السائب]: كان نافعُ بنُ الأزرق إذا سمع الشيء مِن ابن عباس؛ فإذا وقف{18} يقول ابن عباس: ويحك، سميتك: وقّافًا{19}. قال: فإذا غلبه قال: <q>﴿بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق﴾</q>؛ فإذا هو المغلوب، قـل{20} <q>﴿بل هم قوم خصمون﴾</q>{21}. (ز) ٤٨٨٥٤- قال سفيان: كان الربيع بن خُثَيم إذا قرأ: <q>﴿بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق﴾</q> قال: شجَّةٌ لا يداويها عنك غيرك{22}. (ز) ",footnotes:1:أخرجه يحيى بن سلّام ١/٣٠٣ وزاد: قذفه الله على باطلهم، وابن جرير ١٦/٢٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٤.تفسير يحيى بن سلّام ١/٣٠٣.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤١.تفسير مقاتل بن سليمان ٣/٧٤.تفسير يحيى بن سلّام ١/٣٠٣.أخرجه إسحاق البستي في تفسيره ص٢٩٨.أخرجه عبد الرزاق ٢/٢٣، وابن جرير ١٦/٢٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤١. كما أخرجه يحيى بن سلّام ١/٣٠٣ بلفظ: داحض، وعقَّب عليه بقوله: أي: ذاهب.تفسير مقاتل بن سليمان ٣/٧٤.تفسير الثعلبي ٦/٢٧٢، وتفسير البغوي ٥/٣١٣.أخرجه ابن أبي شيبة ١٣/٥٠٦-٥٠٧، والبيهقي في شعب الإيمان (٤٩٠٧، ٥٠٢٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤١. وعلَّقه يحيى بن سلّام ١/٣٠٣.تفسير مقاتل بن سليمان ٣/٧٤.أخرجه ابن جرير ١٦/٢٤٢.تفسير يحيى بن سلّام ١/٣٠٣.قال محقق المصدر: هكذا في الأصل، ولعل الصواب: كان نافع بن الأزرق يسمع الشيء من ابن عباس؛ فإذا وقف.قال محقق المصدر: ذكر أبو العباس المبرد في مساءلة نافع بن الأزرق لابن عباس عن عناية سليمان ﵇ بالهدهد أنّ ابن الأزرق قال لابن عباس: قف يا وقاف. انظر: الكامل في اللغة والأدب ٢/١٦٦. فالأشبه أن يكون هذا من كلام ابن الأزرق؛ فتكون العبارة: «يقول لابن عباس: ويحك سميتك وقافًا». والله أعلم.قال محقق المصدر: هكذا في الأصل، ولعل الصواب: «فإذا كان هو المغلوب؛ قال».أخرجه إسحاق البستي في تفسيره ص ٢٩٨.أخرجه عبد الله بن أحمد في زوائد الزهد ص٤٠٥.
21,19," <q>﴿وَلَهُۥ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</q> - تفسير ٤٨٨٥٥- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿وله من في السماوات والأرض﴾</q> عبيده وفي ملكه، وعيسى بن مريم، وعزير، والملائكة وغيرهم{1}. (ز) <q>﴿وَمَنۡ عِندَهُۥ﴾</q> - تفسير ٤٨٨٥٦- عن قتادة بن دعامة، في قوله: <q>﴿ومن عنده﴾</q>، قال: الملائكة{2}. (١٠/٢٧٨) ٤٨٨٥٧- قال مقاتل بن سليمان: قال سبحانه: <q>﴿ومن عنده﴾</q> مِن الملائكة{1}. (ز) ٤٨٨٥٨- قال يحيى بن سلّام، في قوله: <q>﴿ومن عنده﴾</q>: يعني: الملائكة{4}. (ز) <q>﴿لَا یَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِهِۦ﴾</q> - تفسير ٤٨٨٥٩- عن عبد الله بن عباس: لا يستنكفون{5}. (ز) ٤٨٨٦٠- قال مقاتل بن سليمان: <q>﴿لا يستكبرون﴾</q> يعني: لا يتكبرون <q>﴿عن عبادته﴾</q>{1}. (ز) <q>﴿وَلَا یَسۡتَحۡسِرُونَ ۝١٩﴾</q> - تفسير ٤٨٨٦١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا يستحسرون﴾</q>، يقول: لا يرجعون{7}. (١٠/٢٧٨) ٤٨٨٦٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ولا يستحسرون﴾</q>، قال: لا يحسِرُون، أي: لا يَعْيَوْن{8}. (١٠/٢٧٨) ٤٨٨٦٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولا يستحسرون﴾</q>، قال: لا يَعْيَوْن{9}. (١٠/٢٧٨) ٤٨٨٦٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولا يستحسرون﴾</q>، قال: لا يفتُرون{10}. (ز) ٤٨٨٦٥- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولا يستحسرون﴾</q>، قال: لا ينقَطِعُون مِن العبادة{2}. (١٠/٢٧٨) ٤٨٨٦٦- قال مقاتل بن سليمان: <q>﴿ولا يستحسرون﴾</q> يعني: ولا يُعيَوْن. كقوله ﷿: <q>﴿وهو حسير﴾</q> [الملك:٤] وهو مُعْيٍ{1}. (ز) ٤٨٨٦٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿لا يستحسرون﴾</q>: لا يملُّون، وذلك الاستحْسار. قال: و<q>﴿لا يَفْتُرُونَ﴾</q> [الأنبياء:٢٠]، و<q>﴿لا يسأمون﴾</q> [فصلت:٣٨]، هذا كله معناه واحد، والكلام فيه مختلف، وهو من قولهم: بَعِير حَسِير: إذا أعيا وقام، ومنه قول علقمة بن عبدة: بها جِيَفُ الحَسْرى فأما عظامها فبيضٌ، وأما جلدها فصَلِيبُ{10}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٤.تفسير يحيى بن سلّام ١/٣٠٣.تفسير الثعلبي ٦/٢٧٢.تفسير مقاتل بن سليمان ٣/٧٤.أخرجه ابن جرير ١٦/٢٤٢. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٤٧٠. وعلَّقه يحيى بن سلّام ١/٣٠٤. وأخرجه ابن جرير ١٦/٢٤٢ دون لفظ: لا يُعيون. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤٣. وعلَّقه يحيى بن سلّام ١/٣٠٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٤.أخرجه ابن جرير ١٦/٢٤٣.
21,20," <q>﴿یُسَبِّحُونَ ٱلَّیۡلَ وَٱلنَّهَارَ لَا یَفۡتُرُونَ ۝٢٠﴾</q> - تفسير ٤٨٨٦٨- عن عبد الله بن عباس -من طريق حميد الطويل، عن رجل- في تفسير قوله: <q>﴿يسبحون الليل والنهار لا يفترون﴾</q>، قال: انظر إلى بصرك هل يَؤودُك؟ -أي: هل يثقل عليك؟-، وانظر إلى سمعك هل يؤودك؟ وانظر إلى نفسك هل يؤودك؟ فكذلك الملائكة{1}. (ز) ٤٨٨٦٩- عن عبد الله بن الحارث بن نوفل، أنّه سأل كعبًا عن قوله: <q>﴿يسبحون الليل والنهار لا يفترون﴾</q>، أما شَغَلَهُم رسالة؟ أما شَغَلَهُم عمل؟ فقال: جعل لهم التسبيح كما جعل لكم النفس؛ ألست تأكل وتشرب وتجيء وتذهب وتتكلم وأنت تتنفس؟ فكذلك جعل لهم التسبيح{2}. (١٠/٢٧٨) ٤٨٨٧٠- عن مجاهد بن جبر -من طريق سفيان الثوري، عن رجل- في قوله: <q>﴿يسبحون الليل والنهار لا يفترون﴾</q>، قال: نَفَسُهم التسبيحُ{3}. (ز) ٤٨٨٧١- عن الحسن البصري -من طريق أبي الأشهب- في قوله: <q>﴿يسبحون الليل والنهار لا يفترون﴾</q>، قال: جعلت أنفاسهم لهم تسبيحًا{4}. (١٠/٢٧٩) ٤٨٨٧٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يسبحون الليل والنهار لا يفترون﴾</q>، يقول: إنّ الملائكة الذين هم عند الرحمن لا يستكبرون عن عبادته، ولا يسأمون فيها. وذُكِر لنا: أنّ نبيَّ الله ﷺ بينما هو جالس مع صحبه إذ قال: «تسمعون ما أسمع؟». قالوا: ما نسمع من شيء، يا نبي الله! قال: «إنِّي لأسمعُ أطيط السماء، وما تُلام أن تَئِطَّ، وليس فيها موضع راحةٍ إلا وفيه ملَك ساجدٌ أو قائمٌ»{5}. (ز) ٤٨٨٧٣- قال مقاتل بن سليمان: ثم قال -تعالى ذِكْرُه-: <q>﴿يسبحون﴾</q> يعني: يذكرون الله ﷿ <q>﴿الليل والنهار لا يفترون﴾</q> يقول: لا يستريحون مِن ذكر الله ﷿؛ ليست لهم فَتْرة ولا سآمة{6}. (ز) <q>﴿یُسَبِّحُونَ ٱلَّیۡلَ وَٱلنَّهَارَ لَا یَفۡتُرُونَ ۝٢٠﴾</q> - آثار متعلقة بالآية ٤٨٨٧٤- عن عبد الله بن عمرو -من طريق نَوْف البِكالِي- قال: إنّ الله خلق الملائكة والجن والإنس، فجَزَّأه عشرة أجزاء: تسعة أجزاء منهم الملائكة، وجزء واحد الجن والإنس. وجَزَّأ الملائكة عشرة أجزاء: تسعة أجزاء منهم الكروبيون الذين يسبحون الليل والنهار لا يفترون، وجزء منهم واحد لرسالته ولخزائنه وما يشاء من أمره. وجَزَّأ الجن والإنس عشرة أجزاء: تسعة أجزاء منهم الجن، والإنس جزء واحد، فلا يولد من الإنس مولود إلا وُلِد من الجن تسعة. وجَزَّأ الإنس عشرة أجزاء: تسعة أجزاء منهم يأجوج ومأجوج، وسائرهم سائر بني آدم{7}. (ز) ٤٨٨٧٥- عن يحيى بن أبي كثير، قال: خلق الله الملائكة صُمْدًا ليس لهم أجواف{8}. (١٠/٢٧٩) ",footnotes:1:أخرجه يحيى بن سلّام ١/٣٠٤.أخرجه ابن جرير ١٦/٢٤٤، وأبو الشيخ في العظمة (٣٢٢)، والبيهقي في شعب الإيمان (١٦١). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير أيضًا بنحوه عن عبد الله بن الحارث أن السائلَ ابنُ عباس.أخرجه الثوري في تفسيره ص١٩٩.أخرجه أبو الشيخ في العظمة (٣٢١).أخرجه ابن جرير ١٦/٢٤٥، وابن أبي حاتم -كما في تفسير ابن كثير ٣/٣٣٦- عن حكيم بن حزام مرفوعًا، وعن قتادة من طريق سعيد مرسلًا. والحديث أخرجه الطبراني (٣١٢٢)، وله شاهد من حديث أبي ذر أخرجه الترمذي في سننه (٢٣١٢)، وقال: «هذا حديث حسن غريب».تفسير مقاتل بن سليمان ٣/٧٤.أخرجه يحيى بن سلّام ٢/٧٧٦-٧٧٧، وابن جرير ١٦/٢٤٤ بنحوه.أخرجه أبو الشيخ (٣١٦).
21,21," <q>﴿أَمِ ٱتَّخَذُوۤا۟ ءَالِهَةࣰ مِّنَ ٱلۡأَرۡضِ﴾</q> - تفسير ٤٨٨٧٦- عن قتادة بن دعامة، في قوله: <q>﴿أم اتخذوا آلهة من الأرض﴾</q>: يعني: مِمّا اتخذوا مِن الحجارة والخشب{1}. (١٠/٢٧٩) <q>﴿هُمۡ یُنشِرُونَ ۝٢١﴾</q> - تفسير ٤٨٨٧٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿أم اتخذوا آلهة من الأرض هم ينشرون﴾</q>، قال: يُحْيُون{2}. (١٠/٢٧٩) ٤٨٨٧٨- قال قتادة بن دعامة: <q>﴿هم ينشرون﴾</q> الموتى، أي: إنهم لا يبعثون الأموات{3}. (ز) ٤٨٨٧٩- قال إسماعيل السُّدِّيّ: <q>﴿هم ينشرون﴾</q>، يعني: هم يبعثون، أي: يبعثون الأموات{3}. (ز) ٤٨٨٨٠- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿أم اتخذوا آلهة من الأرض هم ينشرون﴾</q>، يقول: ينشرون الموتى من الأرض. يقول: يُحْيُونهم مِن قبورهم{5}. (١٠/٢٧٩) ٤٨٨٨١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أم اتخذوا آلهة من الأرض هم ينشرون﴾</q>، يقول: أفي آلهتهم أحد يُحْيي ذلك؛ ينشرون. وقرأ قول الله: <q>﴿قل من يرزقكم من السماء والأرض﴾</q> إلى قوله: <q>﴿فما لكم كيف تحكمون﴾</q> [يونس:٣١-٣٥]{6}. (ز) ٤٨٨٨٢- قال يحيى بن سلّام: على الاستفهام، أي: قد اتخذوا آلهة لا ينشرون، ولا يُحْيُون الموتى{7}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤٦. وعلَّقه يحيى بن سلّام ١/٣٠٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٥.علَّقه يحيى بن سلّام ١/٣٠٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤٦.تفسير يحيى بن سلّام ١/٣٠٥.
21,22," <q>﴿لَوۡ كَانَ فِیهِمَاۤ ءَالِهَةٌ إِلَّا ٱللَّهُ﴾</q> - تفسير ٤٨٨٨٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لو كان فيهما آلهة إلا الله﴾</q>، قال: لو كان معهما آلهة إلا الله لفسدتا{1}. (١٠/٢٧٩) ٤٨٨٨٤- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿إلا الله﴾</q> غير الله{2}. (ز) ٤٨٨٨٥- قال مقاتل بن سليمان: <q>﴿لو كان فيهما آلهة﴾</q> يعني: آلهة كثيرة <q>﴿إلا الله﴾</q> يعني: غير الله ﷿{3}. (ز) ٤٨٨٨٦- قال يحيى بن سلّام، في قوله: <q>﴿لو كان فيهما﴾</q>: يعني: في السموات وفي الأرض{4}. (ز) <q>﴿لَفَسَدَتَاۚ﴾</q> - تفسير ٤٨٨٨٧- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿لفسدتا﴾</q> لهَلَكَتا{2}. (ز) ٤٨٨٨٨- قال مقاتل بن سليمان: <q>﴿لفسدتا﴾</q> يعني: لهَلَكَتا، يعني: السموات والأرض وما يبنهما{3}. (ز) <q>﴿فَسُبۡحَـٰنَ ٱللَّهِ رَبِّ ٱلۡعَرۡشِ عَمَّا یَصِفُونَ ۝٢٢﴾</q> - تفسير ٤٨٨٨٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فسبحان الله رب العرش﴾</q>، قال: يُسَبِّح نفسَه -تبارك وتعالى- إذْ قيل عليه البهتان{1}. (١٠/٢٧٩) ٤٨٨٩٠- قال مقاتل بن سليمان: <q>﴿فسبحان الله رب العرش عما يصفون﴾</q> نزَّه الربُّ نفسه -تبارك وتعالى- عن قولهم بأنّ مع الله ﷿ إلهًا{3}. (ز) ٤٨٨٩١- قال يحيى بن سلّام، في قوله: <q>﴿فسبحان الله رب العرش﴾</q>: يُنَزِّه نفسه عما يقولون، <q>﴿عما يصفون﴾</q> أي: عما يكذبون{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٥.تفسير مقاتل بن سليمان ٣/٧٤.تفسير يحيى بن سلّام ١/٣٠٥.علَّقه يحيى بن سلّام ١/٣٠٥.تفسير مقاتل بن سليمان ٣/٧٤.أخرجه ابن جرير ١٦/٢٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٤.تفسير يحيى بن سلّام ١/٣٠٥.
21,23," <q>﴿لَا یُسۡـَٔلُ عَمَّا یَفۡعَلُ وَهُمۡ یُسۡـَٔلُونَ ۝٢٣﴾</q> - تفسير ٤٨٨٩٢- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿لا يسأل عما يفعل وهم يسألون﴾</q>، قال: لا يُسأل الخالق عما يقضي في خلقه، والخلق مسؤولون عن أعمالهم{1}. (١٠/٢٨٠) ٤٨٨٩٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لا يسأل عما يفعل﴾</q> قال: بعباده، <q>﴿وهم يسألون﴾</q> قال: عن أعمالهم{2}. (١٠/٢٧٩) ٤٨٨٩٤- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿لا يُسأل عما يفعل﴾</q> يقول: لا يُسأل الله تعالى عما فَعَلَه في خلقه، <q>﴿وهم يُسألون﴾</q> يقول سبحانه: يسأل الله الملائكة في الآخرة: <q>﴿أأنتم أضللتم عبادي هؤلاء أم هم ضلوا السبيل﴾</q>؟ [الفرقان:١٧] ويسألهم، ويقول للملائكة: <q>﴿أهؤلاء إياكم كانوا يعبدون﴾</q>؟ [سبأ:٤٠]{3}. (ز) ٤٨٨٩٥- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قال: قوله: <q>﴿لا يسئل عما يفعل وهم يسألون﴾</q>. قال: لا يسئل الخالق عن قضائه في خلقه، وهو يسأل الخلقَ عن عملهم{4}. (ز) <q>﴿لَا یُسۡـَٔلُ عَمَّا یَفۡعَلُ وَهُمۡ یُسۡـَٔلُونَ ۝٢٣﴾</q> - آثار متعلقة بالآية ٤٨٨٩٦- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «إنّ في بعض ما أنزل الله في الكتب: إنِّي أنا الله لا إله إلا أنا، قدَّرت الخيرَ والشر، فطوبى لِمَن قدَّرت على يديه الخير ويسَّرته له، وويل لِمَن قدَّرت على يديه الشر ويَسَّرْتُه له، إنِّي أنا الله لا إله إلا أنا، لا أسأل عما أفعل وهم يسألون، فويل لمن قال:كيف وكيف؟»{5}. (١٠/٢٨٠) ٤٨٨٩٧- عن عبد الله بن عباس، قال: ما في الأرض قومٌ أبغض إلَيَّ من القدرية؛ وما ذلك إلا لأنهم لا يعلمون قدرة الله، قال الله: <q>﴿لا يسأل عما يفعل وهم يسألون﴾</q>{6}. (١٠/٢٨٠) ٤٨٨٩٨- عن عبد الله بن عباس -من طريق ميمون بن مهران- قال: لَمّا بعث اللهُ موسى ﵇ وأنزل عليه التوراة قال: اللهم، إنّك ربٌّ عظيم، ولو شئت أن تُطاع لَأُطِعْتَ، ولو شئت أن لا تُعْصى ما عُصِيتَ، وإنك تُحِبُ أن تُطاع، وأنت في ذلك تُعْصى، فكيف هذا يا رب؟ فأوحى الله إليه: إني لا أسأل عما أفعل وهم يسألون. فانتهى موسى، فلمّا بعث الله عُزَيْرًا، وأنزل عليه التوراة بعد ما كان رفعها عن بني إسرائيل، حتى قال مَن قال: إنه ابن الله. قال: اللهم، إنك رب عظيم، ولو شئت أن تُطاع لأُطِعْتَ، ولو شئت أن لا تُعْصى ما عُصِيتَ، وإنك تحب أن تطاع، وأنت في ذلك تعصى، فكيف يا رب؟ فأوحى الله إليه: إني لا أسأل عما أفعل وهم يسألون. فأبت نفسه حتى سأل أيضًا، فقال: أتستطيع أن تُصِرَّ صُرَّةً مِن الشمس؟ قال: لا. قال: أفتستطيع أن تجيء بمكيال من ريح؟ قال: لا. قال: أفتستطيع أن تجيء بمثقال من نور؟ قال: لا. قال: أفتستطيع أن تجيء بقيراط من نور؟ قال: لا. قال: فهكذا لا تقدر على الذي سألتَ عنه، إني لا أسأل عما أفعل وهم يسألون، أما إني لا أجعل عقوبتك إلا أن أمحو اسمك مِن الأنبياء فلا تذكر فيهم. فمحي اسمه من الأنبياء، فليس يذكر فيهم وهو نبي، فلما بعث الله عيسى ورأى منزلته من ربه، وعلمه الكتاب والحكمة والتوراة والإنجيل، ويبرئ الأكمه والأبرص، ويحيي الموتى، قال: اللهم، إنّك رب عظيم، لو شئت تُطاع لأُطِعْتَ، ولو شئت أن لا تُعْصى ما عُصِيتَ، وأنت تحب أن تطاع، وأنت في ذلك تعصى، فكيف هذا، يا رب؟ فأوحى الله إليه: إنِّي لا أسأل عما أفعل وهم يسألون، وأنت عبدي ورسولي، وكلمتي ألقيتك إلى مريم، وروح مِنِّي، خلقتك من تراب، ثم قلت لك: كن. فكنت، لئن لم تنته لأفعلنَّ بك كما فعلت بصاحبك بين يديك؛ إني لا أسأل عما أفعل وهم يسألون. فجمع عيسى مَن تبعه، وقال: القَدَرُ سِرُّ الله؛ فلا تَكَلَّفوه{7}. (١٠/٢٨١) ٤٨٨٩٩- عن ميمون بن مهران، قال: لَمّا بعث الله موسى فكلَّمه وأنزل عليه التوراة قال: اللهم، إنك رب عظيم، لو شئت أن تطاع لأطعت، ولو شئت ألا تعصى ما عصيت، وأنت تحب أن تطاع، وأنت في ذلك تعصى، فكيف، يا رب؟ فأوحى الله إليه: إني لا أُسْأَل عما أفعل وهم يسألون{8}. (١٠/٢٨١) ",footnotes:1:أخرجه ابن جرير ١٦/٢٤٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤٧. وعلَّقه يحيى بن سلّام ١/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.أخرجه ابن جرير ١٦/٢٤٧.أخرجه أحمد بن منيع -كما في المطالب العالية لابن حجر ١٢/٤٦٨ (٢٩٦١)- مختصرًا، من طريق سالم الخراساني، عن نافع، عن القاسم، عن محمد بن علي، عن جابر به. ووقع سنده في إتحاف الخيرة ١/١٧٣ هكذا: سالم بن سالم الخراساني، عن نافع بن القاسم ... وعزاه السيوطي إلى ابن مردويه. والظاهر أن شيخ أحمد بن منيع هو: سلم بن سالم البلخي، وقد ذكروا في ترجمة البلخي أن أحمد بن منيع يروي عنه. وعليه فالسند ضعيف؛ لأن سلم بن سالم البلخي الزاهد ضعيف، كما في ميزان الاعتدال ٢/١٨٥.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه الطبراني (١٠٦٠٦).عزاه السيوطي إلى ابن أبي حاتم، والبيهقي في الأسماء والصفات، وفي المطبوع منه (٣٦٨) عن عمرو بن ميمون عن ابن عباس.
21,24," <q>﴿أَمِ ٱتَّخَذُوا۟ مِن دُونِهِۦۤ ءَالِهَةࣰۖ﴾</q> - تفسير ٤٨٩٠٠- قال يحيى بن سلّام: قوله: <q>﴿أم اتخذوا من دونه آلهة﴾</q> على الاستفهام، أي: قد اتخذوا من دونه آلهة. وهذا الاستفهام وما أشبهه استفهام على مَعْرِفة{1}. (ز) <q>﴿قُلۡ هَاتُوا۟ بُرۡهَـٰنَكُمۡۖ﴾</q> - تفسير ٤٨٩٠١- قال الحسن البصري: حجتكم على ما تقولون: إنّ الله أمركم أن تتخذوا من دونه آلهة{2}. (ز) ٤٨٩٠٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قل هاتوا برهانكم﴾</q>، يقول: هاتوا بيِّنتَكم على ما تقولون{3}. (١٠/٢٨٣) ٤٨٩٠٣- قال قتادة بن دعامة: أي: ليست عندهم بذلك بيِّنة ولا حُجَّة{2}. (ز) ٤٨٩٠٤- قال إسماعيل السُّدِّيّ: يعني: حجتكم بأن معه آلهة{2}. (ز) ٤٨٩٠٥- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لكفار مكة: <q>﴿هاتوا برهانكم﴾</q> يعني: حجتكم أنّ مع الله ﷿ إلهًا كما زعمتم{6}. (ز) <q>﴿هَـٰذَا ذِكۡرُ مَن مَّعِیَ﴾</q> - تفسير ٤٨٩٠٦- عن عبد الله بن عباس -من طريق عطاء- <q>﴿ذكر من معي﴾</q>: القرآن{7}. (ز) ٤٨٩٠٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هذا ذكر من معي﴾</q>، يقول: هذا القرآن فيه ذِكْرُ الحلال والحرام{8}. (١٠/٢٨٣) ٤٨٩٠٨- قال إسماعيل السُّدِّيّ: <q>﴿هذا ذكر من معي﴾</q>، يقول: خبر مَن معي{2}. (ز) ٤٨٩٠٩- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿هذا ذكر من معي﴾</q>، قال: حديث مَن معي{10}. (ز) ٤٨٩١٠- قال مقاتل بن سليمان: <q>﴿هذا ذكر من معي﴾</q>، يقول: هذا القرآن فيه خبر من معي{6}. (ز) <q>﴿وَذِكۡرُ مَن قَبۡلِیۚ﴾</q> - تفسير ٤٨٩١١- عن عبد الله بن عباس -من طريق عطاء- <q>﴿وذكر من قبلي﴾</q>: التوراة والإنجيل{7}. (ز) ٤٨٩١٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وذكر من قبلي﴾</q>، يقول: فيه ذِكْرُ أعمال الأمم السالفة، وما صنع الله بهم، وإلى ما صاروا{13}. (١٠/٢٨٣) ٤٨٩١٣- قال إسماعيل السُّدِّيّ: <q>﴿وذكر من قبلي﴾</q>، يقول: وخبرُ مَن كان قبلي{2}. (ز) ٤٨٩١٤- قال مقاتل بن سليمان: <q>﴿وذكر من قبلي﴾</q>، يقول: وخبر مَن قبلي مِن الكتب، ليس فيه أنّ مع الله ﷿ إلَهًا كما زعمتم{6}. (ز) ٤٨٩١٥- عن عبد الملك ابن جُرَيْج -من طريق حجّاج-: وحديث مَن قبلي{10}. (ز) ٤٨٩١٦- قال يحيى بن سلّام: <q>﴿وذكر من قبلي﴾</q>، يقول: مِن أخبار الأُمَم السالفة وأعمالهم، يعني: مَن أهلك الله مِن الأمم، ومَن نَجّى مِن المؤمنين، ليس فيه اتخاذ آلهة دون الله{1}٤٣٣٨. (ز) ٤٣٣٨ ذكر ابنُ عطية (٦/١٦٠) أنّ قوله تعالى: <q>﴿هذا ذِكْرُ مَن مَعِيَ وذِكْرُ مَن قَبْلِي﴾</q> يحتمل أمرين: أحدهما: أن يريد بـ<q>﴿هذا﴾</q>: جميع الكتب المنزلة قديمها وحديثها، أي: ليس فيها برهان على اتخاذ آلهة من دون الله، بل فيها ضد ذلك. والآخر: أن يريد بقوله: <q>﴿هذا﴾</q>: القرآن، والمعنى: فيه ذكْر الأولين والآخرين، فذكر الآخرين بالدعوة، وبيان الشرع لهم، وردهم على طريق النجاة، وذكر الأولين بقص أخبارهم، وذكر الغيوب في أمورهم، ثم قال: «ومعنى الكلام -على هذا التأويل- عرض القرآن في معرض البرهان أي: هاتوا برهانكم، فهذا برهاني أنا ظاهر في ذكر من معي، وذكر من قبلي». <q>﴿بَلۡ أَكۡثَرُهُمۡ لَا یَعۡلَمُونَ ٱلۡحَقَّۖ فَهُم مُّعۡرِضُونَ ۝٢٤﴾</q> - تفسير ٤٨٩١٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بل أكثرهم لا يعلمون الحق فهم معرضون﴾</q>: عن كتاب الله{18}. (١٠/٢٨٣) ٤٨٩١٨- قال مقاتل بن سليمان: <q>﴿بل أكثرهم﴾</q> يعني: كُفّار مكة <q>﴿لا يعلمون الحق﴾</q> يعني: التوحيد؛ <q>﴿فهم معرضون﴾</q> عن التوحيد. كقوله ﷿: <q>﴿بل جاء بالحق﴾</q> [الصافات:٣٧] يعني: بالتوحيد{6}. (ز) ٤٨٩١٩- قال يحيى بن سلّام: <q>﴿بل أكثرهم لا يعلمون الحق فهم معرضون﴾</q> يعني بقوله: <q>﴿أكثرهم﴾</q>: جماعتهم، قوله: <q>﴿فهم معرضون﴾</q> يعني: عن القرآن{20}. (ز) ",footnotes:1:تفسير يحيى بن سلّام ١/٣٠٦.علَّقه يحيى بن سلّام ١/٣٠٦.أخرجه ابن جرير ١٦/٢٤٨-٢٥٠. وعلَّقه يحيى بن سلّام ١/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٦.علَّقه يحيى بن سلّام ١/٣٠٦.تفسير مقاتل بن سليمان ٣/٧٥.تفسير البغوي ٥/٣١٤.أخرجه ابن جرير ١٦/٢٤٨. وعلَّقه يحيى بن سلّام ١/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٦.أخرجه ابن جرير ١٦/٢٤٩.تفسير مقاتل بن سليمان ٣/٧٥.تفسير البغوي ٥/٣١٤.أخرجه ابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٣٠٦.تفسير مقاتل بن سليمان ٣/٧٥.أخرجه ابن جرير ١٦/٢٤٩.تفسير يحيى بن سلّام ١/٣٠٦.أخرجه ابن جرير ١٦/٢٤٨-٢٥٠. وعلَّقه يحيى بن سلّام ١/٣٠٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.
