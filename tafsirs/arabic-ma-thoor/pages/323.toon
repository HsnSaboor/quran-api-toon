quran[14]{c,v,t}:
  21,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَمۡ قَصَمۡنَا مِن قَرۡیَةࣲ كَانَتۡ ظَالِمَةࣰ وَأَنشَأۡنَا بَعۡدَهَا قَوۡمًا ءَاخَرِینَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: بعث الله نبيًّا مِن حِمْيَر يُقال له: شعيب، فوَثَب إليه عبدٌ، فضربه بعصًا، فسار إليهم بُخْتُنَصَّرَ، فقاتلهم، فقتلهم حتى لم يَبْق منهم شيء. وفيهم أنزل الله: <span class="qpc-hafs">﴿وكم قصمنا من قرية كانت ظالمة﴾</span> إلى قوله: <span class="qpc-hafs">﴿خامدين﴾</span>{1}. (١٠/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وكم قصمنا من قرية﴾</span>، قال: أهلكناها{2}. (١٠/٢٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٦٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وكم قصمنا من قرية﴾</span>، قال: هي حَضُورُ{3} بني أزد{4}<span class=comment-ref>٤٣٣٣</span>. (١٠/٢٧٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٣</span> ساق <u>ابنُ عطية</u> (٦/١٥٦) هذا القول، ثم قال: «ويحتمل أن لا يريد بالآية قريةً بعينها، وأنه واصف حال كل قرية من القرى المعذبة، وأنّ أهل كل قرية كانوا إذا أحسوا العذاب من أي نوع كان أخذوا في الفرار».</div></p><p><div></p><p><p><span class="item-no">٤٨٧٧٠<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿قصمنا من قرية﴾</span>، قال: باليمن، <span class="qpc-hafs">﴿قصمنا﴾</span> بالسيف أُهْلِكوا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكم قصمنا من قرية﴾</span> يعني: أهلكنا مِن قرية بالعذاب في الدنيا قبل أهل مكة <span class="qpc-hafs">﴿كانت ظالمة وأنشأنا بعدها﴾</span> يقول: وجعلنا بعد هلاك الأمم الخالية <span class="qpc-hafs">﴿قوما آخرين﴾</span> يعني: قومًا كانوا باليمن في قرية تسمى: حَضُور، وذلك أنهم قتلوا نبيًّا من الأنبياء ﵈، فسلَّط الله ﷿ جُند بُخْتِ نَصَّر، فقتلوهم، كما سَلَّط بُخْتُ نَصَّرَ والروم على اليهود ببيت المقدس فقتلوهم، وسبوهم حين قتلوا يحيى بن زكريا وغيره من الأنبياء ﵈{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله <span class="qpc-hafs">﴿قصمنا من قرية﴾</span>، قال: قصمها: أهلكها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٧٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وكم قصمنا﴾</span>: أي: أهلكنا <span class="qpc-hafs">﴿من قرية كانت ظالمة﴾</span> يعني: مشركة، يعني: أهلها، <span class="qpc-hafs">﴿وأنشأنا﴾</span> أي: وخلقنا <span class="qpc-hafs">﴿بعدها قوما آخرين﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن مردويه -كما في فتح الباري ٨/٤٣٦-.|2:أخرجه ابن جرير ١٦/٢٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:حَضُور - ويقال: حضوراء-: بلدة باليمن. ينظر: معجم البلدان ٢/ ٢٧٢.|4:أخرجه عبد الرزاق ٢/٢٢ بلفظ: حصون. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:أخرجه ابن جرير ١٦/٢٣٣.|6:تفسير مقاتل بن سليمان ٣/٧٢.|7:أخرجه ابن جرير ١٦/٢٣٣.|8:تفسير يحيى بن سلّام ١/٣٠١.
  21,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّاۤ أَحَسُّوا۟ بَأۡسَنَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فذلك قوله ﷿: <span class="qpc-hafs">﴿فلما أحسوا بأسنا﴾</span>، يقول: فلمّا رأوا عذابنا أهل حَضُور{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٧٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فلما أحسوا﴾</span>: رأوا <span class="qpc-hafs">﴿بأسنا﴾</span> يعني: عذابنا، يعني: قبل أن يهلكوا. رجع إلى قصة مَن هلك{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا هُم مِّنۡهَا یَرۡكُضُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٧٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿إذا هم منها يركضون﴾</span>، قال: يَفِرُّون{3}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿إذا هم منها يركضون﴾</span>، يقول: إذا هم مِن القرية يهربون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿إذا هم منها﴾</span>: من القرية، <span class="qpc-hafs">﴿يركضون﴾</span> يَفِرّون من العذاب حين جاءهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢.|2:تفسير يحيى بن سلّام ١/٣٠١.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٧٢.|5:تفسير يحيى بن سلّام ١/٣٠١.
  21,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا تَرۡكُضُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٧٩<span class="dash">-</span></span> عن عبد الله بن عباس – من طريق العوفي- في قوله: <span class="qpc-hafs">﴿لا تركضوا وارجعوا إلى ما أترفتم فيه ومساكنكم لعلكم تسألون(١٣)﴾</span>. يعني: مَن نزل به العذاب في الدنيا ممن كان يعصي الله من الأمم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٠<span class="dash">-</span></span> عن ابن وهب، قال: حدَّثني رجل مِن المحرَّرين{2}، قال: كان باليمن قريتان، يُقال لإحداهما: حَضُوراء، والأخرى: قلاثة، فبَطِرُوا وأُتْرِفُوا حتى ما كانوا يغلقون أبوابهم، فلما أُتْرِفُوا بعث الله إليهم نبيًّا، فدعاهم، فقتلوه، فألقى الله في قلب بُخْتِنَصَّرَ أن يغزوهم، فجهَّز إليهم جيشًا، فقاتلوهم، فهزموا جيشَه، فرجعوا منهزمين إليه، فجهَّز إليهم جيشًا آخر أكثف مِن الأول، فهزموهم أيضًا، فلمّا رأى بُخْتُنَصَّرَ ذلك غزاهم هو بنفسه، فقاتلوه، فهزمهم حتى خرجوا منها يركضون، فسمعوا مناديًا يقول: <span class="qpc-hafs">﴿لا تركضوا وارجعوا إلى ما أترفتم فيه ومساكنكم﴾</span>. فرجعوا، فسمعوا مناديًا يقول: يا لَثارات النبيِّ. فقُتِلُوا بالسيف، فهي التي قال الله: <span class="qpc-hafs">﴿وكم قصمنا من قرية﴾</span> إلى قوله: <span class="qpc-hafs">﴿خامدين﴾</span>{3}. (١٠/٢٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لا تركضوا﴾</span>، قال: لا تَفِرُّوا{4}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في الآية، قال: كانوا إذا أحَسُّوا بالعذاب، وذهبت عنهم الرسل مِن بعد ما أنذروهم؛ فكذَّبوهم، فلما فقدوا الرسل وأحسوا بالعذاب أرادوا الرجعة إلى الإيمان، وركضوا هاربين من العذاب، فقيل لهم: <span class="qpc-hafs">﴿لا تركضوا﴾</span>. فعرفوا أنه لا محيصَ لهم{5}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالت لهم الملائكة كهيئة الاستهزاء: <span class="qpc-hafs">﴿لا تركضوا﴾</span>، يقول: لا تهربوا{6}<span class=comment-ref>٤٣٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٥٦) أنّ قوله: <span class="qpc-hafs">﴿لا تَرْكُضُوا...﴾</span> <b>يحتمل</b> أن يكون مِن قول رجال بختنصر، ويكون المعنى أنهم خدعوهم واستهزؤوا بهم بأن قالوا للهاربين منهم: لا تفروا وارجعوا إلى مواضعكم لعلكم تسألون صلحًا أو جزية أو أمرًا يتفق عليه. فلما انصرفوا أمر بختنصر بقتلهم. وذكر أنه <b>يحتمل</b> أن يكون مِن كلام ملائكة العذاب، وأنّ الآيات وصْف قصة كل قرية، وأنه لم يرد تعيين حضورا ولا غيرها، ويكون المعنى: أنّ أهل هذه القرى كانوا باغترارهم يرون أنهم مِن الله تعالى بمكان، وأنّه لو جاءهم عذابٌ أو أمْرٌ لم ينزل بهم حتى يخاصموا أو يسألوا عن وجه تكذيبهم لنبيهم، فيحتجُّون هم عند ذلك بحجج تنفعهم في ظنهم، فلمّا نزل العذاب دون هذا الذي أملوه وركضوا فارين نادتهم الملائكة -على وجْه الهزء بهم-: لا تركضوا وارجعوا لعلكم تسألون كما كنتم تطمعون بسفه رأيكم، ثم يكون قوله: <span class="qpc-hafs">﴿حصيدا﴾</span>، أي: بالعذاب ترُكوا كالحصيد.</div></p><p><h3><span class="qpc-hafs">﴿وَٱرۡجِعُوۤا۟ إِلَىٰ مَاۤ أُتۡرِفۡتُمۡ فِیهِ وَمَسَـٰكِنِكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٨٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وارجعوا إلى ما أترفتم فيه﴾</span>، قال: ارجعوا إلى دُورِكم، وأموالكم{5}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وارجعوا إلى ما أترفتم فيه﴾</span>، يقول: ارجِعُوا إلى دُنياكم التي أُتْرِفتم فيها{8}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وارجعوا إلى ما أترفتم فيه﴾</span> يعني: إلى ما خُوِّلْتُم فيه من الأموال <span class="qpc-hafs">﴿و﴾</span> إلى <span class="qpc-hafs">﴿مساكنكم﴾</span> يعني: قريتكم التي هربتم منها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وارجعوا إلى ما أترفتم فيه﴾</span> يعني: نعيمهم الذي كانوا فيه{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّكُمۡ تُسۡـَٔلُونَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لعلكم تسألون﴾</span>، قال: تفقهون{11}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٨٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿لعلكم تُسألون﴾</span>: تفهمون{12}<span class=comment-ref>٤٣٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٥</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/١٥٧) قول مجاهد <span class="mustanad">مستندًا لظاهر لفظ الآية</span>، فقال: «وهذا تفسير لا يعطيه اللفظ».</div></p><p><div></p><p><p><span class="item-no">٤٨٧٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لعلكم تسألون﴾</span>: مِن دنياكم شيئًا؛ استهزاء بهم{13}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلكم تسألون﴾</span> كما سُئِلْتُم الإيمان قبل نزول العذاب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿لعلكم تسئلون﴾</span>: أي: لا تقدرون على ذلك، ولا يكون ذلك{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٣٤.|2:المحررون: الموالي. النهاية (حرر).|3:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٦٩-٧٠ (١٥٦). وعزاه السيوطي إلى ابن أبي حاتم، وفي الدر: «قلابة» بدل «قلاثة».|4:أخرجه ابن جرير ١٦/٢٣٥. وعلَّقه يحيى بن سلّام ١/٣٠١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٧٣.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:أخرجه يحيى بن سلّام ١/٣٠١، وابن جرير ١٦/٢٣٦. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.|9:تفسير مقاتل بن سليمان ٣/٧٣.|10:تفسير يحيى بن سلّام ١/٣٠١.|11:تفسير مجاهد ص٤٦٩، وأخرجه ابن جرير ١٦/٢٣٥.|12:علَّقه البخاري ٤/١٧٦٦. وعزاه السيوطي إليه وإلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم بلفظ: تتفهمون.|13:أخرجه يحيى بن سلّام ١/٣٠١، وابن جرير ١٦/٢٣٥-٢٣٦. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.|14:تفسير مقاتل بن سليمان ٣/٧٣.|15:تفسير يحيى بن سلّام ١/٣٠١-٣٠٢.
  21,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰوَیۡلَنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا رأوا العذاب <span class="qpc-hafs">﴿قالوا يا ويلنا إنا كنا ظالمين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٩٤<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿قالوا يا ويلنا إنا كنا ظالمين* فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين﴾</span>، قال: هي قرية مِن قرى اليمن، يُقال لها: حَضُور، قتلوا نبيَّهم، فغزاهم بُخْتُنَصَّرَ حتى أجْهَضَهُم{2} مِن قريتهم حتى أخرجهم منها، فضربت الملائكة وجوههم حتى عادوا إلى مساكنهم، فأُخِذوا، فـ<span class="qpc-hafs">﴿قالوا يا ويلنا إنا كنا ظالمين* فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿قالوا يا ويلنا﴾</span> وهذا حين جاءهم العذاب <span class="qpc-hafs">﴿إنا كنا ظالمين﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰوَیۡلَنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٩٦<span class="dash">-</span></span> عن أبي توبة الربيع بن نافع، قال: سُئِل <span class="name-3">سفيان بن عيينة</span> عن قوله: «يُوشِك أن يأتي على الناس زمانٌ أفضل عبادتهم التَلاوُمُ، ويقال لهم: النَتْنى»{5}. قال سفيان: ألا ترى أنه يبلغ بهم الكفر؟ إنما قال النتنى ولوم أنفسهم، فإذا كانوا عارفين بالحقِّ فهو خير مِن أن يُزيَّن لهم سوءُ أعمالهم، ولكنهم قوم يعرفون القبيح فلا يرفعون عنه، وليس هذا كقولهم: <span class="qpc-hafs">﴿يا ويلنا إنا كنا ظالمين﴾</span>؛ لأنّ هؤلاء إنما أقروا بالظلم حين رأوا العذاب: <span class="qpc-hafs">﴿فاعترفوا بذنبهم فسحقًا لأصحاب السعير﴾</span> [الملك:١١]، فالظلم شرك{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٣.|2:أجْهَضَهم: أزالهم ونحّاهم عنها. النهاية (جهض).|3:أخرجه إسحاق البستي في تفسيره ص٢٩٥.|4:تفسير يحيى بن سلّام ١/٣٠٢.|5:أخرج أبو داود في الزهد ص١٧٦ (١٨٢) بسنده عن مالك بن مِغْوَل، قال: قال عبد الله [بن مسعود]: يأتي على الناس -أو يكون في آخر الناس- زمان أفضل أعمالهم بينهم التلاوم، يسمون: الأنتان.|6:أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
  21,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا زَالَت تِّلۡكَ دَعۡوَىٰهُمۡ حَتَّىٰ جَعَلۡنَـٰهُمۡ حَصِیدًا خَـٰمِدِینَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٧٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿حتى جعلناهم حصيدا﴾</span> قال: الحصاد، <span class="qpc-hafs">﴿خامدين﴾</span> قال: كخمود النار إذا طفئت{1}. (١٠/٢٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿خامدين﴾</span>. قال: مَيِّتين. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت لبيد بن ربيعة وهو يقول:</p><p>خَلُّوا ثيابهم على عوراتهم فهم بأفنيةِ البيوتِ خُمُود؟{2}. (١٠/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٧٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ما زالت تلك دعواهم﴾</span> قال: هم أهل حَضُور، كانوا قتلوا نبيَّهم، فأرسل الله عليهم بُخْتَنَصَّرَ، فقتلهم. وفي قوله: <span class="qpc-hafs">﴿حتى جعلناهم حصيدا خامدين﴾</span> قال: بالسيف، ضربت الملائكةُ وجوههم حتى رجعوا إلى مساكنهم{3}. (١٠/٢٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فما زالت تلك دعواهم﴾</span> قال: لما رأوا العذاب وعاينوه لم يكن لهم هِجِّيرى{4} إلا قولُهم: <span class="qpc-hafs">﴿إنا كنا ظالمين﴾</span>. حتى دمَّر الله عليهم وأهلكهم{5}. (١٠/٢٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿فما زالت تلك دعواهم﴾</span> يقول: فما زال الويلُ قولهم <span class="qpc-hafs">﴿حتى جعلناهم حصيدا خامدين﴾</span> يقول: أطْفَأْناهم بالسيف، فخَمَدُوا مثلَ النار إذا طَفِئت فخَمَدَت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span> في قوله: <span class="qpc-hafs">﴿فما زالت تلك دعواهم﴾</span> يعني: قولهم: <span class="qpc-hafs">﴿يا ويلنا إنا كنا ظالمين﴾</span> يعني: فما زال ذلك قولهم، <span class="qpc-hafs">﴿حتى جعلناهم حصيدا خامدين﴾</span> حتى أُهلِكوا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا زَالَت تِّلۡكَ دَعۡوَىٰهُمۡ حَتَّىٰ جَعَلۡنَـٰهُمۡ حَصِیدًا خَـٰمِدِینَ ۝١٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق مالك بن مِغْوَل، عن رجل- أنّه كان -أراه- يكره أن يسمع الرجل يقول: هلك الناس. قال: فسمع رجلًا يقول: هلك الناس. فقال ابن عمر: هَلَكَت العَجَزَةُ أو الفَجَرَةُ. -الشك من إسحاق- ثم قال: إنّ الله لم يُعَذِّب قومًا حتى يُعْذِروا مِن أنفسهم، وإعذارهم أن يقولوا: هلكنا. ثم قرأ: <span class="qpc-hafs">﴿فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٣٧. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه الطستي -كما في الإتقان ٢/٨٩- وفيه: «همود» بدل: «خمود».|3:أخرجه ابن جرير ١٦/٢٣٧ بلفظ: أهل حصون، وأخرج عبد الرزاق ٢/٢٢ آخره مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.|4:الهِجِّيرى: الدَّأب والعادة والدَّيْدَن. النهاية (هجر).|5:أخرجه يحيى بن سلّام ١/٣٠٢، وابن جرير ١٦/٢٣٧، كذلك رواه من طريق معمر بلفظ: فما كان هجيراه إلا الويل حتى هلكوا. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٧٣.|7:تفسير يحيى بن سلّام ١/٣٠٢.|8:أخرجه إسحاق البستي في تفسيره ص٢٩٦.
  21,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا خَلَقۡنَا ٱلسَّمَاۤءَ وَٱلۡأَرۡضَ وَمَا بَیۡنَهُمَا لَـٰعِبِینَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٠٤<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span>: ما خلقنا من جنَّةٍ، ولا نارٍ، ولا موتٍ، ولا بعثٍ، ولا حسابٍ لاعبين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما خلقنا السماء والأرض وما بينهما لاعبين﴾</span>، يقول: ما خلقناهما عَبَثًا، ولا باطلًا{2}. (١٠/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>: أي: إنّا لم نخلقهما وما بينهما باطلًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما خلقنا السماء والأرض﴾</span> يعني: السموات السبع والأرضين السبع <span class="qpc-hafs">﴿وما بينهما﴾</span> مِن الخلق <span class="qpc-hafs">﴿لاعبين﴾</span> يعني: عابثين لغير شيء، ولكن خلقناهما لأمرٍ هو كائن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: أي: إنما خلقناهما للبعث والحساب، والجنة والنار{5}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٣٠٢.|2:أخرجه ابن جرير ١٦/٢٣٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:علَّقه يحيى بن سلّام ١/٣٠٢.|4:تفسير مقاتل بن سليمان ٣/٧٣.|5:تفسير يحيى بن سلّام ١/٣٠٢.
  21,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوۡ أَرَدۡنَاۤ أَن نَّتَّخِذَ لَهۡوࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، قال: لعبًا{1}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء-: اللهو: المرأة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي-: اللهو: الولد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>، في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، قال: نساء{4}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، قال: زوجة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، قال: اللهو: الولد{6}. (١٠/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، قال: النساء{7}. (١٠/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قال: اللهو بلسان اليمن: المرأة{8}. (١٠/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، قال: اللهو في بعض لغة أهل اليمن: المرأة{9}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿لهوًا﴾</span>، يعني: صاحبة وولدًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>، يعني: ولدًا، وذلك أنّ نصارى نجران -السيد والعاقب، ومن معهما- قالوا: عيسى ابن الله، فقال الله ﷿: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا لاتخذناه من لدنا﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span>: نساء وولدًا{5}<span class=comment-ref>٤٣٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٩/٣٩٥) أنّ تفسير اللهو بالمرأة والولد فيه تلازم، ثم قال: «وهو <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿لو أراد الله أن يتخذ ولدا لاصطفى مما يخلق ما يشاء سبحانه﴾</span> [الزمر:٤]».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٤/٣٦٦) أنّ مَن فسروا اللهو بالولد والزوجة قالوا ذلك؛ لأنّ مِن المشركين مَن جعل لله ولدًا وصاحبة، وقالوا: إنه ضاهى الحق، وهم يسمون المرأة لهوًا، والولد لهوًا.</div></p><p><h3><span class="qpc-hafs">﴿لَّٱتَّخَذۡنَـٰهُ مِن لَّدُنَّاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٢١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>، في قوله: <span class="qpc-hafs">﴿لاتخذناه من لدنا﴾</span>، قال: مِن الحُور العين{4}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لاتخذناه من لدنا﴾</span>، قال: مِن عندنا{14}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لاتخذناه من لدنا﴾</span>: مِن عندنا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span> الآية، يقول: لو أردت أن أتخذ ولدًا لاتخذت مِن الملائكة{4}. (١٠/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال الله ﷿: <span class="qpc-hafs">﴿لاتخذناه من لدنا﴾</span>، يعني: مِن عندنا من الملائكة؛ لأنهم أطيب وأطهر مِن عيسى، ولم نتخذه مِن أهل الأرض{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قال: قالوا: مريم صاحبته، وعيسى ولده. فقال -تبارك وتعالى-: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا﴾</span> نساء وولدًا؛ <span class="qpc-hafs">﴿لاتخذناه من لدنا﴾</span> مِن عندنا، لاتخذنا نساء وولدًا مِن أهل السماء، وما اتَّخذنا نساء وولدًا مِن أهل الارض{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن كُنَّا فَـٰعِلِینَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>، أي: ما كنا فاعلين. يقول: وما خلقنا جنة، ولا نارًا، ولا موتًا، ولا بعثًا، ولا حسابًا. وكلُّ شيء في القرآن <span class="qpc-hafs">﴿إن﴾</span> فهو إنكار{19}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو، ويونس- <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>: ما كنا فاعلين، <span class="qpc-hafs">﴿وإن كان مكرهم لتزول منه الجبال﴾</span> [إبراهيم:٤٦]، أي: ما كان مكرهم لتزول منه الجبال، و<span class="qpc-hafs">﴿إن كان للرحمن ولد فأنا أول العابدين﴾</span> [ الزخرف:٨١]، يقول: ما كان للرحمن ولد، وأنا أول الدائنين بأنه لم يكن له ولد، <span class="qpc-hafs">﴿فَإنْ كُنْتَ فِي شَكٍّ مِمّا أنْزَلْنا إلَيْكَ﴾</span> [يونس:٩٤]، يقول: ما كنت في شك مما أنزلنا{20}. (٧/٧٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>: أي: ما كُنّا فاعلين{21}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، - من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>: أي: إنّ ذلك لا يكون، ولا ينبغي{22}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>:قال <span class="name-2">قتادة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٢<span class="dash">-</span></span> و<span class="name-2">السُّدِّيّ</span>: أي: ما كُنّا فاعلين، وذلك أنّ المشركين قالوا: إنّ الملائكة بنات الله. وقد قال في آية أخرى: <span class="qpc-hafs">﴿أنى يكون له ولد ولم تكن له صاحبة﴾</span> [الأنعام:١٠١]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿إن﴾</span> للنفي، أي: ما كنا فاعلين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال الله ﷿: <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>، يقول: ما كُنّا فاعلين ذلك؛ أن نتخذ ولدًا. مثلها في الزخرف{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>، قال: ما كُنّا نفعل{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:تفسير البغوي ٥/٣١٣.|3:تفسير البغوي ٥/٣١٣. وهو في تفسير الثعلبي ٦/٢٧٢ دون ذكر الطريق.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه ابن جرير ١٦/٢٣٩.|6:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:أخرجه يحيى بن سلّام ١/٣٠٢. وعزاه السيوطي إلى ابن أبي حاتم. وأخرج ابن جرير ١٦/٢٣٣ من طريق عقبة بن أبي جَسْرة، قال: شهدت الحسن بمكة، قال: وجاءه طاوس وعطاء ومجاهد، فسألوه عن قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿لو أردنا أن نتخذ لهوا لاتخذناه﴾</span>. قال الحسن: اللهو: المرأة.|9:أخرجه ابن جرير ١٦/٢٣٩، ومن طريق سعيد نحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:علَّقه يحيى بن سلّام ١/٣٠٣.|11:تفسير مقاتل بن سليمان ٣/٧٣.|12:أخرجه ابن جرير ١٦/٢٣٩.|13:عزاه السيوطي إلى ابن أبي حاتم.|14:أخرجه ابن جرير١٦/٢٤٠، وعلقه يحيى بن سلّام ١/٣٠٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|15:علَّقه يحيى بن سلّام ١/٣٠٣.|16:عزاه السيوطي إلى ابن أبي حاتم.|17:تفسير مقاتل بن سليمان ٣/٧٣.|18:أخرجه ابن جرير ١٦/٢٣٩.|19:أخرجه ابن جرير١٦/٢٤٠ بعضه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|20:أخرجه إسحاق البستي في تفسيره ص٢٩٧. وعزاه السيوطي إلى ابن الأنباري في المصاحف، وزاد: <span class="qpc-hafs">﴿ولقد مكناهم فيما إن مكناكم فيه﴾</span> [الأحقاف:٢٦]، معناه: في الذي ما مكنّاكم فيه.|21:أخرجه عبد الرزاق ٢/٢٢، وابن جرير ١٦/٢٣٩.|22:أخرجه ابن جرير ١٦/٢٣٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|23:علَّقه يحيى بن سلّام ١/٣٠٣.|24:تفسير البغوي ٥/٣١٣.|25:تفسير مقاتل بن سليمان ٣/٧٣. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿قُلْ إنْ كانَ لِلرَّحْمَنِ ولَدٌ فَأَنا أوَّلُ العابِدِينَ﴾</span> [الزخرف:٨١].|26:أخرجه ابن جرير ١٦/٢٣٩.
  21,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ نَقۡذِفُ بِٱلۡحَقِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بل نقذف بالحق﴾</span>، قال: كتاب الله القرآن{1}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بل نقذف﴾</span> بل نرمي <span class="qpc-hafs">﴿بالحق﴾</span> الذي قال الله ﷿: <span class="qpc-hafs">﴿إن كنا فاعلين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل نقذف بالحق﴾</span> بالقرآن{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَلَى ٱلۡبَـٰطِلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿على الباطل﴾</span>، قال: اللَّبْسُ{4}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد - قوله: <span class="qpc-hafs">﴿بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق﴾</span>: والحق: كتاب الله القرآن، والباطل إبليس{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿على الباطل﴾</span> الذي قالوا: إنّ لله ﷿ ولدًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿على الباطل﴾</span>: على باطلهم، يعني: شركهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَدۡمَغُهُۥ فَإِذَا هُوَ زَاهِقࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿فيدمغه فإذا هو زاهق﴾</span>: فإذا هو المغلوب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فإذا هو زاهق﴾</span>، قال: هالِك{9}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿فيدمغه فإذا هو زاهق﴾</span>، أي: ذاهِب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فيدمغه فإذا هو زاهق﴾</span>، يعني: ذاهِب{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَكُمُ ٱلۡوَیۡلُ مِمَّا تَصِفُونَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٤٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: مما تَكْذِبُون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أيوب- في قوله: <span class="qpc-hafs">﴿ولكم الويل مما تصفون﴾</span>، قال: هي -واللهِ- لكل واصفِ كَذِبٍ إلى يوم القيامة{13}. (١٠/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولكم الويل مما تصفون﴾</span>: أي: تكذبون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكم الويل مما تصفون﴾</span>، يقول: لكم الويل في الآخرة مما تقولون مِن البهتان بأنّ لله ولدًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ولكم الويل مما تصفون﴾</span>، قال: تُشْرِكون. وقوله: <span class="qpc-hafs">﴿عما يصفون﴾</span> [الأنعام:١٠٠، الأنبياء:٢٢، المؤمنون:٩١، الصافات:١٥٩، ١٨٠، الزخرف:٨٢]، قال: يُشْرِكون. قال: وقال <span class="name-2">مجاهد</span> <span class="qpc-hafs">﴿سيجزيهم وصفهم﴾</span> [الأنعام:١٣٩]، قال: قولهم الكذب في ذلك{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولكم الويل﴾</span> العذاب <span class="qpc-hafs">﴿مما تصفون﴾</span> لقولهم: إنّ الملائكة بنات</p><p>الله{3}<span class=comment-ref>٤٣٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٧</span> اختُلِف في معنى قوله: <span class="qpc-hafs">﴿مما تصفون﴾</span>؛ <b>فقال قوم</b>: تشركون. <b>وقال غيرهم</b>: تكذبون.</p><p>و<span class="comment-type-3">اختار</span> <u>ابنُ جرير</u> (١٦/٢٤١) تقارب المعنى بينهما <span class="mustanad">لدلالة العقل</span>، فقال: «لأنّ مَن وصف الله بأن له صاحبة فقد كذب في وصْفِه إيّاه بذلك، وأشرك به، ووصفه بغير صفته». وذكر أنّ المعنى: ولكم الويل من وصفكم ربكم بغير صفته، وقيلكم إنه اتخذ زوجة وولدًا، وفريتكم عليه. وساق القولين ثم قال: «غير أن أولى العبارات أن يعبر بها عن معاني القرآن أقربها إلى فهم سامعيه».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٥٧) قولًا بأنّ المراد بالويل: واد في جهنم، و<span class="comment-type-3">اختاره</span> بقوله: «هو المراد في الآية». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿وَلَكُمُ ٱلۡوَیۡلُ مِمَّا تَصِفُونَ ۝١٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٥٣<span class="dash">-</span></span> قال عطاء [بن السائب]: كان نافعُ بنُ الأزرق إذا سمع الشيء مِن ابن عباس؛ فإذا وقف{18} يقول <span class="name-1">ابن عباس</span>: ويحك، سميتك: وقّافًا{19}. قال: فإذا غلبه قال: <span class="qpc-hafs">﴿بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق﴾</span>؛ فإذا هو المغلوب، قـل{20} <span class="qpc-hafs">﴿بل هم قوم خصمون﴾</span>{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٥٤<span class="dash">-</span></span> قال سفيان: كان <span class="name-2">الربيع بن خُثَيم</span> إذا قرأ: <span class="qpc-hafs">﴿بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق﴾</span> قال: شجَّةٌ لا يداويها عنك غيرك{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٣٠٣ وزاد: قذفه الله على باطلهم، وابن جرير ١٦/٢٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٧٤.|3:تفسير يحيى بن سلّام ١/٣٠٣.|4:عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:أخرجه ابن جرير ١٦/٢٤١.|6:تفسير مقاتل بن سليمان ٣/٧٤.|7:تفسير يحيى بن سلّام ١/٣٠٣.|8:أخرجه إسحاق البستي في تفسيره ص٢٩٨.|9:أخرجه عبد الرزاق ٢/٢٣، وابن جرير ١٦/٢٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|10:أخرجه ابن جرير ١٦/٢٤١. كما أخرجه يحيى بن سلّام ١/٣٠٣ بلفظ: داحض، وعقَّب عليه بقوله: أي: ذاهب.|11:تفسير مقاتل بن سليمان ٣/٧٤.|12:تفسير الثعلبي ٦/٢٧٢، وتفسير البغوي ٥/٣١٣.|13:أخرجه ابن أبي شيبة ١٣/٥٠٦-٥٠٧، والبيهقي في شعب الإيمان (٤٩٠٧، ٥٠٢٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|14:أخرجه ابن جرير ١٦/٢٤١. وعلَّقه يحيى بن سلّام ١/٣٠٣.|15:تفسير مقاتل بن سليمان ٣/٧٤.|16:أخرجه ابن جرير ١٦/٢٤٢.|17:تفسير يحيى بن سلّام ١/٣٠٣.|18:قال محقق المصدر: هكذا في الأصل، ولعل الصواب: كان نافع بن الأزرق يسمع الشيء من ابن عباس؛ فإذا وقف.|19:قال محقق المصدر: ذكر أبو العباس المبرد في مساءلة نافع بن الأزرق لابن عباس عن عناية سليمان ﵇ بالهدهد أنّ ابن الأزرق قال لابن عباس: قف يا وقاف. انظر: الكامل في اللغة والأدب ٢/١٦٦. فالأشبه أن يكون هذا من كلام ابن الأزرق؛ فتكون العبارة: «يقول لابن عباس: ويحك سميتك وقافًا». والله أعلم.|20:قال محقق المصدر: هكذا في الأصل، ولعل الصواب: «فإذا كان هو المغلوب؛ قال».|21:أخرجه إسحاق البستي في تفسيره ص ٢٩٨.|22:أخرجه عبد الله بن أحمد في زوائد الزهد ص٤٠٥.
  21,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَهُۥ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿وله من في السماوات والأرض﴾</span> عبيده وفي ملكه، وعيسى بن مريم، وعزير، والملائكة وغيرهم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَنۡ عِندَهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ومن عنده﴾</span>، قال: الملائكة{2}. (١٠/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال سبحانه: <span class="qpc-hafs">﴿ومن عنده﴾</span> مِن الملائكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿ومن عنده﴾</span>: يعني: الملائكة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: لا يستنكفون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يستكبرون﴾</span> يعني: لا يتكبرون <span class="qpc-hafs">﴿عن عبادته﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَسۡتَحۡسِرُونَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا يستحسرون﴾</span>، يقول: لا يرجعون{7}. (١٠/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ولا يستحسرون﴾</span>، قال: لا يحسِرُون، أي: لا يَعْيَوْن{8}. (١٠/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولا يستحسرون﴾</span>، قال: لا يَعْيَوْن{9}. (١٠/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولا يستحسرون﴾</span>، قال: لا يفتُرون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ولا يستحسرون﴾</span>، قال: لا ينقَطِعُون مِن العبادة{2}. (١٠/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يستحسرون﴾</span> يعني: ولا يُعيَوْن. كقوله ﷿: <span class="qpc-hafs">﴿وهو حسير﴾</span> [الملك:٤] وهو مُعْيٍ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿لا يستحسرون﴾</span>: لا يملُّون، وذلك الاستحْسار. قال: و<span class="qpc-hafs">﴿لا يَفْتُرُونَ﴾</span> [الأنبياء:٢٠]، و<span class="qpc-hafs">﴿لا يسأمون﴾</span> [فصلت:٣٨]، هذا كله معناه واحد، والكلام فيه مختلف، وهو من قولهم: بَعِير حَسِير: إذا أعيا وقام، ومنه قول علقمة بن عبدة:</p><p>بها جِيَفُ الحَسْرى فأما عظامها فبيضٌ، وأما جلدها فصَلِيبُ{10}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٣/٧٤.|4:تفسير يحيى بن سلّام ١/٣٠٣.|5:تفسير الثعلبي ٦/٢٧٢.|6:تفسير مقاتل بن سليمان ٣/٧٤.|7:أخرجه ابن جرير ١٦/٢٤٢. وعزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مجاهد ص٤٧٠. وعلَّقه يحيى بن سلّام ١/٣٠٤. وأخرجه ابن جرير ١٦/٢٤٢ دون لفظ: لا يُعيون. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:أخرجه ابن جرير ١٦/٢٤٣. وعلَّقه يحيى بن سلّام ١/٣٠٤. وعزاه السيوطي إلى ابن أبي حاتم.|10:أخرجه ابن جرير ١٦/٢٤٣.|11:عزاه السيوطي إلى ابن أبي حاتم.|12:تفسير مقاتل بن سليمان ٣/٧٤.|13:أخرجه ابن جرير ١٦/٢٤٣.
  21,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُسَبِّحُونَ ٱلَّیۡلَ وَٱلنَّهَارَ لَا یَفۡتُرُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق حميد الطويل، عن رجل- في تفسير قوله: <span class="qpc-hafs">﴿يسبحون الليل والنهار لا يفترون﴾</span>، قال: انظر إلى بصرك هل يَؤودُك؟ -أي: هل يثقل عليك؟-، وانظر إلى سمعك هل يؤودك؟ وانظر إلى نفسك هل يؤودك؟ فكذلك الملائكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٦٩<span class="dash">-</span></span> عن عبد الله بن الحارث بن نوفل، أنّه سأل <span class="name-2">كعبًا</span> عن قوله: <span class="qpc-hafs">﴿يسبحون الليل والنهار لا يفترون﴾</span>، أما شَغَلَهُم رسالة؟ أما شَغَلَهُم عمل؟ فقال: جعل لهم التسبيح كما جعل لكم النفس؛ ألست تأكل وتشرب وتجيء وتذهب وتتكلم وأنت تتنفس؟ فكذلك جعل لهم التسبيح{2}. (١٠/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان الثوري، عن رجل- في قوله: <span class="qpc-hafs">﴿يسبحون الليل والنهار لا يفترون﴾</span>، قال: نَفَسُهم التسبيحُ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- في قوله: <span class="qpc-hafs">﴿يسبحون الليل والنهار لا يفترون﴾</span>، قال: جعلت أنفاسهم لهم تسبيحًا{4}. (١٠/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يسبحون الليل والنهار لا يفترون﴾</span>، يقول: إنّ الملائكة الذين هم عند الرحمن لا يستكبرون عن عبادته، ولا يسأمون فيها. وذُكِر لنا: أنّ نبيَّ الله ﷺ بينما هو جالس مع صحبه إذ قال: «<b>تسمعون ما أسمع</b>؟». قالوا: ما نسمع من شيء، يا نبي الله! قال: «<b>إنِّي لأسمعُ أطيط السماء، وما تُلام أن تَئِطَّ، وليس فيها موضع راحةٍ إلا وفيه ملَك ساجدٌ أو قائمٌ</b>»{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿يسبحون﴾</span> يعني: يذكرون الله ﷿ <span class="qpc-hafs">﴿الليل والنهار لا يفترون﴾</span> يقول: لا يستريحون مِن ذكر الله ﷿؛ ليست لهم فَتْرة ولا سآمة{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُسَبِّحُونَ ٱلَّیۡلَ وَٱلنَّهَارَ لَا یَفۡتُرُونَ ۝٢٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق نَوْف البِكالِي- قال: إنّ الله خلق الملائكة والجن والإنس، فجَزَّأه عشرة أجزاء: تسعة أجزاء منهم الملائكة، وجزء واحد الجن والإنس. وجَزَّأ الملائكة عشرة أجزاء: تسعة أجزاء منهم الكروبيون الذين يسبحون الليل والنهار لا يفترون، وجزء منهم واحد لرسالته ولخزائنه وما يشاء من أمره. وجَزَّأ الجن والإنس عشرة أجزاء: تسعة أجزاء منهم الجن، والإنس جزء واحد، فلا يولد من الإنس مولود إلا وُلِد من الجن تسعة. وجَزَّأ الإنس عشرة أجزاء: تسعة أجزاء منهم يأجوج ومأجوج، وسائرهم سائر بني آدم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧٥<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي كثير</span>، قال: خلق الله الملائكة صُمْدًا ليس لهم أجواف{8}. (١٠/٢٧٩)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٣٠٤.|2:أخرجه ابن جرير ١٦/٢٤٤، وأبو الشيخ في العظمة (٣٢٢)، والبيهقي في شعب الإيمان (١٦١). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير أيضًا بنحوه عن عبد الله بن الحارث أن السائلَ ابنُ عباس.|3:أخرجه الثوري في تفسيره ص١٩٩.|4:أخرجه أبو الشيخ في العظمة (٣٢١).|5:أخرجه ابن جرير ١٦/٢٤٥، وابن أبي حاتم -كما في تفسير ابن كثير ٣/٣٣٦- عن حكيم بن حزام مرفوعًا، وعن قتادة من طريق سعيد مرسلًا.</p><p>والحديث أخرجه الطبراني (٣١٢٢)، وله شاهد من حديث أبي ذر أخرجه الترمذي في سننه (٢٣١٢)، وقال: «هذا حديث حسن غريب».|6:تفسير مقاتل بن سليمان ٣/٧٤.|7:أخرجه يحيى بن سلّام ٢/٧٧٦-٧٧٧، وابن جرير ١٦/٢٤٤ بنحوه.|8:أخرجه أبو الشيخ (٣١٦).
  21,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمِ ٱتَّخَذُوۤا۟ ءَالِهَةࣰ مِّنَ ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أم اتخذوا آلهة من الأرض﴾</span>: يعني: مِمّا اتخذوا مِن الحجارة والخشب{1}. (١٠/٢٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُمۡ یُنشِرُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿أم اتخذوا آلهة من الأرض هم ينشرون﴾</span>، قال: يُحْيُون{2}. (١٠/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿هم ينشرون﴾</span> الموتى، أي: إنهم لا يبعثون الأموات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٧٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿هم ينشرون﴾</span>، يعني: هم يبعثون، أي: يبعثون الأموات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿أم اتخذوا آلهة من الأرض هم ينشرون﴾</span>، يقول: ينشرون الموتى من الأرض. يقول: يُحْيُونهم مِن قبورهم{5}. (١٠/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أم اتخذوا آلهة من الأرض هم ينشرون﴾</span>، يقول: أفي آلهتهم أحد يُحْيي ذلك؛ ينشرون. وقرأ قول الله: <span class="qpc-hafs">﴿قل من يرزقكم من السماء والأرض﴾</span> إلى قوله: <span class="qpc-hafs">﴿فما لكم كيف تحكمون﴾</span> [يونس:٣١-٣٥]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: على الاستفهام، أي: قد اتخذوا آلهة لا ينشرون، ولا يُحْيُون الموتى{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٦/٢٤٦. وعلَّقه يحيى بن سلّام ١/٣٠٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:علَّقه يحيى بن سلّام ١/٣٠٥.|4:علَّقه يحيى بن سلّام ١/٣٠٥.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:أخرجه ابن جرير ١٦/٢٤٦.|7:تفسير يحيى بن سلّام ١/٣٠٥.
  21,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوۡ كَانَ فِیهِمَاۤ ءَالِهَةٌ إِلَّا ٱللَّهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لو كان فيهما آلهة إلا الله﴾</span>، قال: لو كان معهما آلهة إلا الله لفسدتا{1}. (١٠/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨٤<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿إلا الله﴾</span> غير الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لو كان فيهما آلهة﴾</span> يعني: آلهة كثيرة <span class="qpc-hafs">﴿إلا الله﴾</span> يعني: غير الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿لو كان فيهما﴾</span>: يعني: في السموات وفي الأرض{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَفَسَدَتَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٨٧<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿لفسدتا﴾</span> لهَلَكَتا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لفسدتا﴾</span> يعني: لهَلَكَتا، يعني: السموات والأرض وما يبنهما{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ رَبِّ ٱلۡعَرۡشِ عَمَّا یَصِفُونَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فسبحان الله رب العرش﴾</span>، قال: يُسَبِّح نفسَه -تبارك وتعالى- إذْ قيل عليه البهتان{1}. (١٠/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فسبحان الله رب العرش عما يصفون﴾</span> نزَّه الربُّ نفسه -تبارك وتعالى- عن قولهم بأنّ مع الله ﷿ إلهًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فسبحان الله رب العرش﴾</span>: يُنَزِّه نفسه عما يقولون، <span class="qpc-hafs">﴿عما يصفون﴾</span> أي: عما يكذبون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:علَّقه يحيى بن سلّام ١/٣٠٥.|3:تفسير مقاتل بن سليمان ٣/٧٤.|4:تفسير يحيى بن سلّام ١/٣٠٥.|5:علَّقه يحيى بن سلّام ١/٣٠٥.|6:تفسير مقاتل بن سليمان ٣/٧٤.|7:أخرجه ابن جرير ١٦/٢٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٣/٧٤.|9:تفسير يحيى بن سلّام ١/٣٠٥.
  21,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یُسۡـَٔلُ عَمَّا یَفۡعَلُ وَهُمۡ یُسۡـَٔلُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٩٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لا يسأل عما يفعل وهم يسألون﴾</span>، قال: لا يُسأل الخالق عما يقضي في خلقه، والخلق مسؤولون عن أعمالهم{1}. (١٠/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لا يسأل عما يفعل﴾</span> قال: بعباده، <span class="qpc-hafs">﴿وهم يسألون﴾</span> قال: عن أعمالهم{2}. (١٠/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿لا يُسأل عما يفعل﴾</span> يقول: لا يُسأل الله تعالى عما فَعَلَه في خلقه، <span class="qpc-hafs">﴿وهم يُسألون﴾</span> يقول سبحانه: يسأل الله الملائكة في الآخرة: <span class="qpc-hafs">﴿أأنتم أضللتم عبادي هؤلاء أم هم ضلوا السبيل﴾</span>؟ [الفرقان:١٧] ويسألهم، ويقول للملائكة: <span class="qpc-hafs">﴿أهؤلاء إياكم كانوا يعبدون﴾</span>؟ [سبأ:٤٠]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قال: قوله: <span class="qpc-hafs">﴿لا يسئل عما يفعل وهم يسألون﴾</span>. قال: لا يسئل الخالق عن قضائه في خلقه، وهو يسأل الخلقَ عن عملهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یُسۡـَٔلُ عَمَّا یَفۡعَلُ وَهُمۡ یُسۡـَٔلُونَ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٨٩٦<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «<b>إنّ في بعض ما أنزل الله في الكتب: إنِّي أنا الله لا إله إلا أنا، قدَّرت الخيرَ والشر، فطوبى لِمَن قدَّرت على يديه الخير ويسَّرته له، وويل لِمَن قدَّرت على يديه الشر ويَسَّرْتُه له، إنِّي أنا الله لا إله إلا أنا، لا أسأل عما أفعل وهم يسألون، فويل لمن قال:كيف وكيف</b>؟»{5}. (١٠/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: ما في الأرض قومٌ أبغض إلَيَّ من القدرية؛ وما ذلك إلا لأنهم لا يعلمون قدرة الله، قال الله: <span class="qpc-hafs">﴿لا يسأل عما يفعل وهم يسألون﴾</span>{6}. (١٠/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ميمون بن مهران- قال: لَمّا بعث اللهُ موسى ﵇ وأنزل عليه التوراة قال: اللهم، إنّك ربٌّ عظيم، ولو شئت أن تُطاع لَأُطِعْتَ، ولو شئت أن لا تُعْصى ما عُصِيتَ، وإنك تُحِبُ أن تُطاع، وأنت في ذلك تُعْصى، فكيف هذا يا رب؟ فأوحى الله إليه: إني لا أسأل عما أفعل وهم يسألون. فانتهى موسى، فلمّا بعث الله عُزَيْرًا، وأنزل عليه التوراة بعد ما كان رفعها عن بني إسرائيل، حتى قال مَن قال: إنه ابن الله. قال: اللهم، إنك رب عظيم، ولو شئت أن تُطاع لأُطِعْتَ، ولو شئت أن لا تُعْصى ما عُصِيتَ، وإنك تحب أن تطاع، وأنت في ذلك تعصى، فكيف يا رب؟ فأوحى الله إليه: إني لا أسأل عما أفعل وهم يسألون. فأبت نفسه حتى سأل أيضًا، فقال: أتستطيع أن تُصِرَّ صُرَّةً مِن الشمس؟ قال: لا. قال: أفتستطيع أن تجيء بمكيال من ريح؟ قال: لا. قال: أفتستطيع أن تجيء بمثقال من نور؟ قال: لا. قال: أفتستطيع أن تجيء بقيراط من نور؟ قال: لا. قال: فهكذا لا تقدر على الذي سألتَ عنه، إني لا أسأل عما أفعل وهم يسألون، أما إني لا أجعل عقوبتك إلا أن أمحو اسمك مِن الأنبياء فلا تذكر فيهم. فمحي اسمه من الأنبياء، فليس يذكر فيهم وهو نبي، فلما بعث الله عيسى ورأى منزلته من ربه، وعلمه الكتاب والحكمة والتوراة والإنجيل، ويبرئ الأكمه والأبرص، ويحيي الموتى، قال: اللهم، إنّك رب عظيم، لو شئت تُطاع لأُطِعْتَ، ولو شئت أن لا تُعْصى ما عُصِيتَ، وأنت تحب أن تطاع، وأنت في ذلك تعصى، فكيف هذا، يا رب؟ فأوحى الله إليه: إنِّي لا أسأل عما أفعل وهم يسألون، وأنت عبدي ورسولي، وكلمتي ألقيتك إلى مريم، وروح مِنِّي، خلقتك من تراب، ثم قلت لك: كن. فكنت، لئن لم تنته لأفعلنَّ بك كما فعلت بصاحبك بين يديك؛ إني لا أسأل عما أفعل وهم يسألون. فجمع عيسى مَن تبعه، وقال: القَدَرُ سِرُّ الله؛ فلا تَكَلَّفوه{7}. (١٠/٢٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٨٩٩<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span>، قال: لَمّا بعث الله موسى فكلَّمه وأنزل عليه التوراة قال: اللهم، إنك رب عظيم، لو شئت أن تطاع لأطعت، ولو شئت ألا تعصى ما عصيت، وأنت تحب أن تطاع، وأنت في ذلك تعصى، فكيف، يا رب؟ فأوحى الله إليه: إني لا أُسْأَل عما أفعل وهم يسألون{8}. (١٠/٢٨١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٤٧. وعزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن جرير ١٦/٢٤٧. وعلَّقه يحيى بن سلّام ١/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٣/٧٥.|4:أخرجه ابن جرير ١٦/٢٤٧.|5:أخرجه أحمد بن منيع -كما في المطالب العالية لابن حجر ١٢/٤٦٨ (٢٩٦١)- مختصرًا، من طريق سالم الخراساني، عن نافع، عن القاسم، عن محمد بن علي، عن جابر به. ووقع سنده في إتحاف الخيرة ١/١٧٣ هكذا: سالم بن سالم الخراساني، عن نافع بن القاسم ... وعزاه السيوطي إلى ابن مردويه.</p><p>والظاهر أن شيخ أحمد بن منيع هو: سلم بن سالم البلخي، وقد ذكروا في ترجمة البلخي أن أحمد بن منيع يروي عنه. وعليه فالسند ضعيف؛ لأن سلم بن سالم البلخي الزاهد ضعيف، كما في ميزان الاعتدال ٢/١٨٥.|6:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|7:أخرجه الطبراني (١٠٦٠٦).|8:عزاه السيوطي إلى ابن أبي حاتم، والبيهقي في الأسماء والصفات، وفي المطبوع منه (٣٦٨) عن عمرو بن ميمون عن ابن عباس.
  21,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمِ ٱتَّخَذُوا۟ مِن دُونِهِۦۤ ءَالِهَةࣰۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أم اتخذوا من دونه آلهة﴾</span> على الاستفهام، أي: قد اتخذوا من دونه آلهة. وهذا الاستفهام وما أشبهه استفهام على مَعْرِفة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ هَاتُوا۟ بُرۡهَـٰنَكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٠١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: حجتكم على ما تقولون: إنّ الله أمركم أن تتخذوا من دونه آلهة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قل هاتوا برهانكم﴾</span>، يقول: هاتوا بيِّنتَكم على ما تقولون{3}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: أي: ليست عندهم بذلك بيِّنة ولا حُجَّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: حجتكم بأن معه آلهة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> لكفار مكة: <span class="qpc-hafs">﴿هاتوا برهانكم﴾</span> يعني: حجتكم أنّ مع الله ﷿ إلهًا كما زعمتم{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هَـٰذَا ذِكۡرُ مَن مَّعِیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿ذكر من معي﴾</span>: القرآن{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿هذا ذكر من معي﴾</span>، يقول: هذا القرآن فيه ذِكْرُ الحلال والحرام{8}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿هذا ذكر من معي﴾</span>، يقول: خبر مَن معي{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿هذا ذكر من معي﴾</span>، قال: حديث مَن معي{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هذا ذكر من معي﴾</span>، يقول: هذا القرآن فيه خبر من معي{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَذِكۡرُ مَن قَبۡلِیۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وذكر من قبلي﴾</span>: التوراة والإنجيل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وذكر من قبلي﴾</span>، يقول: فيه ذِكْرُ أعمال الأمم السالفة، وما صنع الله بهم، وإلى ما صاروا{13}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وذكر من قبلي﴾</span>، يقول: وخبرُ مَن كان قبلي{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وذكر من قبلي﴾</span>، يقول: وخبر مَن قبلي مِن الكتب، ليس فيه أنّ مع الله ﷿ إلَهًا كما زعمتم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج-: وحديث مَن قبلي{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وذكر من قبلي﴾</span>، يقول: مِن أخبار الأُمَم السالفة وأعمالهم، يعني: مَن أهلك الله مِن الأمم، ومَن نَجّى مِن المؤمنين، ليس فيه اتخاذ آلهة دون الله{1}<span class=comment-ref>٤٣٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٦٠) أنّ قوله تعالى: <span class="qpc-hafs">﴿هذا ذِكْرُ مَن مَعِيَ وذِكْرُ مَن قَبْلِي﴾</span> يحتمل أمرين: <b>أحدهما</b>: أن يريد بـ<span class="qpc-hafs">﴿هذا﴾</span>: جميع الكتب المنزلة قديمها وحديثها، أي: ليس فيها برهان على اتخاذ آلهة من دون الله، بل فيها ضد ذلك. <b>والآخر</b>: أن يريد بقوله: <span class="qpc-hafs">﴿هذا﴾</span>: القرآن، والمعنى: فيه ذكْر الأولين والآخرين، فذكر الآخرين بالدعوة، وبيان الشرع لهم، وردهم على طريق النجاة، وذكر الأولين بقص أخبارهم، وذكر الغيوب في أمورهم، ثم قال: «ومعنى الكلام -على هذا التأويل- عرض القرآن في معرض البرهان أي: هاتوا برهانكم، فهذا برهاني أنا ظاهر في ذكر من معي، وذكر من قبلي».</div></p><p><h3><span class="qpc-hafs">﴿بَلۡ أَكۡثَرُهُمۡ لَا یَعۡلَمُونَ ٱلۡحَقَّۖ فَهُم مُّعۡرِضُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بل أكثرهم لا يعلمون الحق فهم معرضون﴾</span>: عن كتاب الله{18}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بل أكثرهم﴾</span> يعني: كُفّار مكة <span class="qpc-hafs">﴿لا يعلمون الحق﴾</span> يعني: التوحيد؛ <span class="qpc-hafs">﴿فهم معرضون﴾</span> عن التوحيد. كقوله ﷿: <span class="qpc-hafs">﴿بل جاء بالحق﴾</span> [الصافات:٣٧] يعني: بالتوحيد{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل أكثرهم لا يعلمون الحق فهم معرضون﴾</span> يعني بقوله: <span class="qpc-hafs">﴿أكثرهم﴾</span>: جماعتهم، قوله: <span class="qpc-hafs">﴿فهم معرضون﴾</span> يعني: عن القرآن{20}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ١/٣٠٦.|2:علَّقه يحيى بن سلّام ١/٣٠٦.|3:أخرجه ابن جرير ١٦/٢٤٨-٢٥٠. وعلَّقه يحيى بن سلّام ١/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:علَّقه يحيى بن سلّام ١/٣٠٦.|5:علَّقه يحيى بن سلّام ١/٣٠٦.|6:تفسير مقاتل بن سليمان ٣/٧٥.|7:تفسير البغوي ٥/٣١٤.|8:أخرجه ابن جرير ١٦/٢٤٨. وعلَّقه يحيى بن سلّام ١/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|9:علَّقه يحيى بن سلّام ١/٣٠٦.|10:أخرجه ابن جرير ١٦/٢٤٩.|11:تفسير مقاتل بن سليمان ٣/٧٥.|12:تفسير البغوي ٥/٣١٤.|13:أخرجه ابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|14:علَّقه يحيى بن سلّام ١/٣٠٦.|15:تفسير مقاتل بن سليمان ٣/٧٥.|16:أخرجه ابن جرير ١٦/٢٤٩.|17:تفسير يحيى بن سلّام ١/٣٠٦.|18:أخرجه ابن جرير ١٦/٢٤٨-٢٥٠. وعلَّقه يحيى بن سلّام ١/٣٠٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|19:تفسير مقاتل بن سليمان ٣/٧٥.|20:تفسير يحيى بن سلّام ١/٣٠٧.