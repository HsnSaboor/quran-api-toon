quran[24]{c,v,t}:
26,160," <q>﴿كَذَّبَتۡ قَوۡمُ لُوطٍ ٱلۡمُرۡسَلِینَ ۝١٦٠﴾</q> - تفسير ٥٦٣٨٠- قال مقاتل بن سليمان: <q>﴿كذبت قوم لوط المرسلين﴾</q>، كذبوا لوطًا وحده. ولوط بن حراز بن آزر، فسارة أخت لوط ﵇{1}. (ز) ٥٦٣٨١- قال يحيى بن سلّام: قوله ﷿: <q>﴿كذبت قوم لوط المرسلين﴾</q>، يعني: لوطًا{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٧.تفسير يحيى بن سلّام ٢/٥١٩.
26,161," <q>﴿إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ لُوطٌ أَلَا تَتَّقُونَ ۝١٦١ إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٦٢ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٦٣ وَمَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٦٤ أَتَأۡتُونَ ٱلذُّكۡرَانَ مِنَ ٱلۡعَـٰلَمِینَ ۝١٦٥﴾</q> - تفسير ٥٦٣٨٢- عن عبد الصمد بن معقل، قال: سمعت وهب بن مُنَبِّه قال: كان أهل سدوم الذين فيهم لوط قوم سوء، قد اسْتَغْنَوا عن النساء بالرجال{1}. (ز) ٥٦٣٨٣- قال مقاتل بن سليمان: <q>﴿إذ قال لهم أخوهم لوط﴾</q> ابن حراز: <q>﴿ألا تتقون﴾</q> يعني: ألا تخشون الله ﷿، <q>﴿إني لكم رسول أمين فاتقوا الله وأطيعون﴾</q> فيما آمركم به مِن النصيحة، <q>﴿وما أسألكم عليه من أجر﴾</q> يعني: ما أسألكم على الإيمان مِن جُعْل، <q>﴿إن أجري﴾</q> يعني: ما جزائي <q>﴿إلا على رب العالمين أتأتون الذكران من العالمين﴾</q> يعني: نكاح الرجال{2}. (ز) ٥٦٣٨٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿إذ قال لهم أخوهم لوط﴾</q> أخوهم في النسب، وليس بأخيهم في الدين: <q>﴿ألا تتقون﴾</q>، يعني: ألا تخشون الله، يأمرهم أن يتقوا الله، <q>﴿إني لكم رسول أمين﴾</q> على ما جئتكم به، <q>﴿فاتقوا الله وأطيعون (١٠٨) وما أسألكم عليه من أجر إن أجري﴾</q> إن ثوابي <q>﴿إلا على رب العالمين﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٨.تفسير مقاتل بن سليمان ٣/٢٧٧. وآخره في تفسير البغوي ٦/١٢٦ عن مقاتل منسوبًا إليه دون تعيينه.تفسير يحيى بن سلّام ٢/٥١٩.
  26,162,""
  26,163,""
  26,164,""
  26,165,""
26,166," <q>﴿وَتَذَرُونَ مَا خَلَقَ لَكُمۡ رَبُّكُم مِّنۡ أَزۡوَ ٰ⁠جِكُمۚ بَلۡ أَنتُمۡ قَوۡمٌ عَادُونَ ۝١٦٦﴾</q> - تفسير ٥٦٣٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</q>، قال: تركتم أقبال النساء إلى أدبار الرجال وأدبار النساء!{1}. (١١/٢٨٩) ٥٦٣٨٦- عن مجاهد بن جبر -من طريق إبراهيم بن مهاجر- <q>﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</q>، قال: ما أصْلَحَ لكم، يعني: القُبُل{2}. (١١/٢٨٩) ٥٦٣٨٧- عن عكرمة مولى ابن عباس، <q>﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</q>، يقول: ترك أقبال النساء إلى أدبار الرجال{3}. (١١/٢٨٩) ٥٦٣٨٨- عن محمد بن كعب القرظي -من طريق محمد بن يزيد بن المهاجر-: أنّه كان لا يرى بأسًا بإتيان النساء في أدبارهن، ويحتج في ذلك بقوله ﷿: <q>﴿أتأتون الذكران من العالمين * وتذرون ما خلق لكم ربكم من أزواجكم بل أنتم قومٌ عادون﴾</q>، أي: من أزواجكم مثل ذلك، إن كنتم تشتهون{4}. (ز) ٥٦٣٨٩- قال إسماعيل السُّدِّيّ: <q>﴿ما خلق لكم ربكم من أزواجكم﴾</q> ما جعل لكم ربكم مِن فروج نسائكم{5}. (ز) ٥٦٣٩٠- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿بل أنتم قوم عادون﴾</q>، قال: مُتَعَدُّون{6}. (١١/٢٨٩) ٥٦٣٩١- قال مقاتل بن سليمان: <q>﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</q> يعني بالأزواج: فروج نسائكم، <q>﴿بل أنتم قوم عادون﴾</q> يعني: مُعْتَدين{7}. (ز) ٥٦٣٩٢- قال يحيى بن سلّام: وهذا على الاستفهام، أي: قد فعلتم، <q>﴿بل أنتم قوم عادون﴾</q> مُجاوِزون لأمر الله{8}. (ز) ",footnotes:1:أخرجه يحيى بن سلّام ٢/٥٢٠ من طريق ابن مجاهد دون ذكر أدبار النساء، وابن جرير ١٧/٦٣٠، وإسحاق البستي في تفسيره ص٥٤٠ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨٠٨. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه الدارمي في سننه ١/٧٢٧ (١١٦٣) بلفظ: هو -واللهِ- القُبُل، وابن أبي حاتم ٩/٢٨٠٨، ويحيى بن سلّام ٢/٥٢٠ من طريق عاصم بن حكيم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الطحاوي في شرح معاني الآثار ٣/٤٥. وتقدمت الأحاديث والآثار الدالة على فساد هذا القول عند تفسير قوله تعالى: <q>﴿نِساؤُكُمْ حَرْثٌ لَكُمْ فَأْتُوا حَرْثَكُمْ أنّى شِئْتُمْ﴾</q> [البقرة:٢٢٣].علقه يحيى بن سلّام ٢/٥٢٠.أخرجه ابن جرير ١٧/٦٣٠. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٧.تفسير يحيى بن سلّام ٢/٥٢٠.
26,167," <q>﴿قَالُوا۟ لَىِٕن لَّمۡ تَنتَهِ یَـٰلُوطُ لَتَكُونَنَّ مِنَ ٱلۡمُخۡرَجِینَ ۝١٦٧ قَالَ إِنِّی لِعَمَلِكُم مِّنَ ٱلۡقَالِینَ ۝١٦٨ رَبِّ نَجِّنِی وَأَهۡلِی مِمَّا یَعۡمَلُونَ ۝١٦٩﴾</q> - تفسير ٥٦٣٩٣- عن إسماعيل السُّدِّيّ، <q>﴿مما يعملون﴾</q>، يقول: ينكحون الرجال{1}. (ز) ٥٦٣٩٤- قال مقاتل بن سليمان: <q>﴿قالوا لئن لم تنته﴾</q> يعني: لئن لم تسكت عنّا <q>﴿يا لوط لتكونن من المخرجين﴾</q> من القرية، <q>﴿قال﴾</q> لوط: <q>﴿إني لعملكم﴾</q> يعني: إتيان الرجال <q>﴿من القالين﴾</q> يعني: الماقتين، <q>﴿رب نجني وأهلي مما يعملون﴾</q> مِن الخبائث{2}. (ز) ٥٦٣٩٥- قال يحيى بن سلّام: <q>﴿بل أنتم قوم عادون﴾</q> مُجاوِزون لأمر الله، <q>﴿قالوا لئن لم تنته يا لوط لتكونن من المخرجين﴾</q> مِن قريتنا، أي: نقتلك، فنخرجك منها قتيلًا، <q>﴿قال إني لعملكم من القالين﴾</q> مِن المُبْغِضين. ثم قال: <q>﴿رب نجني وأهلي مما يعملون﴾</q> وأهله: أُمَّته المؤمنون، <q>﴿فنجيناه وأهله أجمعين﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٨.تفسير مقاتل بن سليمان ٣/٢٧٧.تفسير يحيى بن سلّام ٢/٥٢٠.
  26,168,""
  26,169,""
26,170," <q>﴿فَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥۤ أَجۡمَعِینَ ۝١٧٠﴾</q> - قراءات ٥٦٣٩٦- عن مجاهد، قال: في قراءة عبد الله [بن مسعود]: (وواعَدْناهُ أن نُّوَفِّيَهُ أجْمَعِينَ إلّا عَجُوزًا فِي الغابِرِينَ){1}. (١١/٢٨٩) <q>﴿فَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥۤ أَجۡمَعِینَ ۝١٧٠﴾</q> - تفسير الآية ٥٦٣٩٧- قال مقاتل بن سليمان: <q>﴿فنجيناه وأهله أجمعين﴾</q> ثم استثنى، فقال: <q>﴿إلا عجوزا في الغابرين﴾</q>{2}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر. والظاهر أن المراد من هذه القراءة التفسير، وإن ثبتت قراءة فهي شاذة.تفسير مقاتل بن سليمان ٣/٢٧٧.
26,171," <q>﴿إِلَّا عَجُوزࣰا فِی ٱلۡغَـٰبِرِینَ ۝١٧١﴾</q> - تفسير ٥٦٣٩٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله <q>﴿في الغابرين﴾</q>. قال: في الباقين. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عَبِيد بن الأبرص وهو يقول: ذهبوا وخَلَّفَني المُخَلِّف فيهم فكأنني في الغابرين غريبُ؟{1}. (١١/٢٩٠) ٥٦٣٩٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إلا عجوزا في الغابرين﴾</q> قال: هي امرأة لوط، غبرت في عذاب الله{2}. (١١/٢٩٠) ٥٦٤٠٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿في الغابرين﴾</q>، قال: الباقين في عذاب الله{3}. (ز) ٥٦٤٠١- قال مقاتل بن سليمان: ثم استثنى، فقال: <q>﴿إلا عجوزا في الغابرين﴾</q>، يعني: الباقين في العذاب، يعني: امرأته{4}. (ز) ٥٦٤٠٢- عن أصبغ، قال: سمعت عبد الرحمن بن زيد بن أسلم في قول الله: <q>﴿إلا عجوزا﴾</q>: امرأة لوط المُغْبَرة الشقية <q>﴿في الغابرين﴾</q> الباقين الذين غبروا وأبقوا{3}. (ز) ٥٦٤٠٣- قال يحيى بن سلّام: قال الله: <q>﴿إلا عجوزا في الغابرين﴾</q>، غَبَرَتْ: بقيت في عذاب الله، لم ينجها{6}٤٨٢٠. (ز) ٤٨٢٠ ذكر ابنُ عطية (٦/٥٠٢) أن قوله: <q>﴿فِي الغابِرِينَ﴾</q> معناه: في الباقين. ثم قال: «فإما أن يريد: في الباقين من لِداتها وأهل سنتها. وهذا تأويل أبي عبيدة. وإما أن يريد: في الباقين في العذاب النازل بهم. وهذا تأويل قتادة. والمشهور أنها بمعنى: بقي. وغابر الزمان: مستقبله، ولكن الأعشى قد استعمل»غابر الزمان«بمعنى ماضيه في شعر المنافرة المشهور، وقال الزهراوي: يقال للذاهب: غابر، وللباقي: غابر». ",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٨٣-٨٤-.أخرجه ابن أبي حاتم ٩/٢٨٠٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٠٩.تفسير مقاتل بن سليمان ٣/٢٧٧.أخرجه ابن أبي حاتم ٩/٢٨٠٩.تفسير يحيى بن سلّام ٢/٥٢٠.
26,172," <q>﴿ثُمَّ دَمَّرۡنَا ٱلۡـَٔاخَرِینَ ۝١٧٢ وَأَمۡطَرۡنَا عَلَیۡهِم مَّطَرࣰاۖ فَسَاۤءَ مَطَرُ ٱلۡمُنذَرِینَ ۝١٧٣ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٧٤ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٧٥﴾</q> - تفسير ٥٦٤٠٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: ... فلمّا كان في جوف الليل إذ أدخل جبريل جناحَه تحت القرية، فرفعها، حتى إذا كانت في جو السماء -حتى إنهم ليسمعون أصوات الطير- قَلَبَها، ثم تَتَبَّع الشُّذّاذ ومَن خرج منهم بالحجارة{1}. (ز) ٥٦٤٠٥- عن كعب الأحبار -من طريق عبد الله بن رباح– <q>﴿وامطرنا عليهم مطرا﴾</q>، قال: على أهل بواديهم، وعلى رُعاتهم، وعلى مُسافريهم، فلم ينفلِت منهم أحدٌ{1}. (ز) ٥٦٤٠٦- قال قتادة بن دعامة، في قوله ﷿: <q>﴿وأمطرنا عليهم مطرا﴾</q>: أمطر الله على قرية قوم لوط حجارة{3}. (ز) ٥٦٤٠٧- قال يحيى بن سلّام: قال الله: <q>﴿ثم دمرنا الآخرين﴾</q> قوم لوط وامرأته معهم، وكانت مُنافِقة، تظهر للوط الإيمان، وهي على الشرك.= (ز) ٥٦٤٠٨- قوله ﷿: <q>﴿وأمطرنا عليهم مطرا﴾</q> قال قتادة: أمطر الله على قرية قوم لوط حجارة، <q>﴿فساء مطر المنذرين﴾</q> أي: فبئس مطر المنذرين، أنذرهم لوط فلم يقبلوا. أصاب قريتهم الخسف، وأصابت الحجارة مَن كان خارجًا من القرية، وأهل السَّفر منهم، وأصاب العجوزَ حجرٌ فقتلها{4}. (ز) ٥٦٤٠٩- عن الحكم بن أبان، في قوله: <q>﴿وأمطرنا عليهم مطرا﴾</q>، قال: سمعت وهبًا يقول: الكبريت، والنار{5}. (ز) ٥٦٤١٠- قال مقاتل بن سليمان: <q>﴿ثم دمرنا﴾</q> يعني: أهلكنا <q>﴿الآخرين﴾</q> بالخسف والحصب، فذلك قوله تعالى: <q>﴿وأمطرنا عليهم مطرا﴾</q> يعني: الحجارة، <q>﴿فساء﴾</q> يعني: فبئس <q>﴿مطر المنذرين﴾</q> يعني: الذين أُنذروا بالعذاب، خسف الله بقرى قوم لوط، وأرسل الحجارة على مَن كان خارجًا من القرية، <q>﴿إن في ذلك لآية﴾</q> يعني: إن في هلاكهم بالخسف والحصب لَعِبرة لهذه الأمة، ثم قال تعالى: <q>﴿وما كان أكثرهم مؤمنين﴾</q> لو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا، <q>﴿وإن ربك لهو العزيز﴾</q> في نقمته، <q>﴿الرحيم﴾</q> بالمؤمنين. وذلك قوله تعالى: <q>﴿ولقد أنذرهم بطشتنا﴾</q> [القمر:٣٦]، يعني: عذابنا{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٩.أخرجه ابن أبي حاتم ٩/٢٨٠٩.علَّقه يحيى بن سلّام ٢/٥٢١.تفسير يحيى بن سلّام ٢/٥٢٠.أخرجه ابن أبي حاتم ٩/٢٨١٠.تفسير مقاتل بن سليمان ٣/٢٧٧.
