quran[24]{c,v,t}:
  26,160,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ قَوۡمُ لُوطٍ ٱلۡمُرۡسَلِینَ ۝١٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذبت قوم لوط المرسلين﴾</span>، كذبوا لوطًا وحده. ولوط بن حراز بن آزر، فسارة أخت لوط ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿كذبت قوم لوط المرسلين﴾</span>، يعني: لوطًا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٧.|2:تفسير يحيى بن سلّام ٢/٥١٩.
  26,161,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ لُوطٌ أَلَا تَتَّقُونَ ۝١٦١ إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٦٢ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٦٣ وَمَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٦٤ أَتَأۡتُونَ ٱلذُّكۡرَانَ مِنَ ٱلۡعَـٰلَمِینَ ۝١٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٨٢<span class="dash">-</span></span> عن عبد الصمد بن معقل، قال: سمعت <span class="name-2">وهب بن مُنَبِّه</span> قال: كان أهل سدوم الذين فيهم لوط قوم سوء، قد اسْتَغْنَوا عن النساء بالرجال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ قال لهم أخوهم لوط﴾</span> ابن حراز: <span class="qpc-hafs">﴿ألا تتقون﴾</span> يعني: ألا تخشون الله ﷿، <span class="qpc-hafs">﴿إني لكم رسول أمين فاتقوا الله وأطيعون﴾</span> فيما آمركم به مِن النصيحة، <span class="qpc-hafs">﴿وما أسألكم عليه من أجر﴾</span> يعني: ما أسألكم على الإيمان مِن جُعْل، <span class="qpc-hafs">﴿إن أجري﴾</span> يعني: ما جزائي <span class="qpc-hafs">﴿إلا على رب العالمين أتأتون الذكران من العالمين﴾</span> يعني: نكاح الرجال{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إذ قال لهم أخوهم لوط﴾</span> أخوهم في النسب، وليس بأخيهم في الدين: <span class="qpc-hafs">﴿ألا تتقون﴾</span>، يعني: ألا تخشون الله، يأمرهم أن يتقوا الله، <span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span> على ما جئتكم به، <span class="qpc-hafs">﴿فاتقوا الله وأطيعون (١٠٨) وما أسألكم عليه من أجر إن أجري﴾</span> إن ثوابي <span class="qpc-hafs">﴿إلا على رب العالمين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٨.|2:تفسير مقاتل بن سليمان ٣/٢٧٧. وآخره في تفسير البغوي ٦/١٢٦ عن مقاتل منسوبًا إليه دون تعيينه.|3:تفسير يحيى بن سلّام ٢/٥١٩.
  26,162,""
  26,163,""
  26,164,""
  26,165,""
  26,166,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَذَرُونَ مَا خَلَقَ لَكُمۡ رَبُّكُم مِّنۡ أَزۡوَ ٰ⁠جِكُمۚ بَلۡ أَنتُمۡ قَوۡمٌ عَادُونَ ۝١٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span>، قال: تركتم أقبال النساء إلى أدبار الرجال وأدبار النساء!{1}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن مهاجر- <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span>، قال: ما أصْلَحَ لكم، يعني: القُبُل{2}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span>، يقول: ترك أقبال النساء إلى أدبار الرجال{3}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق محمد بن يزيد بن المهاجر-: أنّه كان لا يرى بأسًا بإتيان النساء في أدبارهن، ويحتج في ذلك بقوله ﷿: <span class="qpc-hafs">﴿أتأتون الذكران من العالمين * وتذرون ما خلق لكم ربكم من أزواجكم بل أنتم قومٌ عادون﴾</span>، أي: من أزواجكم مثل ذلك، إن كنتم تشتهون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٨٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ما خلق لكم ربكم من أزواجكم﴾</span> ما جعل لكم ربكم مِن فروج نسائكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span>، قال: مُتَعَدُّون{6}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتذرون ما خلق لكم ربكم من أزواجكم﴾</span> يعني بالأزواج: فروج نسائكم، <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span> يعني: مُعْتَدين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهذا على الاستفهام، أي: قد فعلتم، <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span> مُجاوِزون لأمر الله{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ٢/٥٢٠ من طريق ابن مجاهد دون ذكر أدبار النساء، وابن جرير ١٧/٦٣٠، وإسحاق البستي في تفسيره ص٥٤٠ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨٠٨. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|2:أخرجه الدارمي في سننه ١/٧٢٧ (١١٦٣) بلفظ: هو -واللهِ- القُبُل، وابن أبي حاتم ٩/٢٨٠٨، ويحيى بن سلّام ٢/٥٢٠ من طريق عاصم بن حكيم.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه الطحاوي في شرح معاني الآثار ٣/٤٥. وتقدمت الأحاديث والآثار الدالة على فساد هذا القول عند تفسير قوله تعالى: <span class="qpc-hafs">﴿نِساؤُكُمْ حَرْثٌ لَكُمْ فَأْتُوا حَرْثَكُمْ أنّى شِئْتُمْ﴾</span> [البقرة:٢٢٣].|5:علقه يحيى بن سلّام ٢/٥٢٠.|6:أخرجه ابن جرير ١٧/٦٣٠. وعزاه السيوطي إلى ابن المنذر.|7:تفسير مقاتل بن سليمان ٣/٢٧٧.|8:تفسير يحيى بن سلّام ٢/٥٢٠.
  26,167,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَىِٕن لَّمۡ تَنتَهِ یَـٰلُوطُ لَتَكُونَنَّ مِنَ ٱلۡمُخۡرَجِینَ ۝١٦٧ قَالَ إِنِّی لِعَمَلِكُم مِّنَ ٱلۡقَالِینَ ۝١٦٨ رَبِّ نَجِّنِی وَأَهۡلِی مِمَّا یَعۡمَلُونَ ۝١٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿مما يعملون﴾</span>، يقول: ينكحون الرجال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا لئن لم تنته﴾</span> يعني: لئن لم تسكت عنّا <span class="qpc-hafs">﴿يا لوط لتكونن من المخرجين﴾</span> من القرية، <span class="qpc-hafs">﴿قال﴾</span> لوط: <span class="qpc-hafs">﴿إني لعملكم﴾</span> يعني: إتيان الرجال <span class="qpc-hafs">﴿من القالين﴾</span> يعني: الماقتين، <span class="qpc-hafs">﴿رب نجني وأهلي مما يعملون﴾</span> مِن الخبائث{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل أنتم قوم عادون﴾</span> مُجاوِزون لأمر الله، <span class="qpc-hafs">﴿قالوا لئن لم تنته يا لوط لتكونن من المخرجين﴾</span> مِن قريتنا، أي: نقتلك، فنخرجك منها قتيلًا، <span class="qpc-hafs">﴿قال إني لعملكم من القالين﴾</span> مِن المُبْغِضين. ثم قال: <span class="qpc-hafs">﴿رب نجني وأهلي مما يعملون﴾</span> وأهله: أُمَّته المؤمنون، <span class="qpc-hafs">﴿فنجيناه وأهله أجمعين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٨.|2:تفسير مقاتل بن سليمان ٣/٢٧٧.|3:تفسير يحيى بن سلّام ٢/٥٢٠.
  26,168,""
  26,169,""
  26,170,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥۤ أَجۡمَعِینَ ۝١٧٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٦<span class="dash">-</span></span> عن مجاهد، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وواعَدْناهُ أن نُّوَفِّيَهُ أجْمَعِينَ إلّا عَجُوزًا فِي الغابِرِينَ){1}. (١١/٢٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَنَجَّیۡنَـٰهُ وَأَهۡلَهُۥۤ أَجۡمَعِینَ ۝١٧٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فنجيناه وأهله أجمعين﴾</span> ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.</p><p>والظاهر أن المراد من هذه القراءة التفسير، وإن ثبتت قراءة فهي شاذة.|2:تفسير مقاتل بن سليمان ٣/٢٧٧.
  26,171,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا عَجُوزࣰا فِی ٱلۡغَـٰبِرِینَ ۝١٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله <span class="qpc-hafs">﴿في الغابرين﴾</span>. قال: في الباقين. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول عَبِيد بن الأبرص وهو يقول:</p><p>ذهبوا وخَلَّفَني المُخَلِّف فيهم فكأنني في الغابرين غريبُ؟{1}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span> قال: هي امرأة لوط، غبرت في عذاب الله{2}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿في الغابرين﴾</span>، قال: الباقين في عذاب الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span>، يعني: الباقين في العذاب، يعني: امرأته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٢<span class="dash">-</span></span> عن أصبغ، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> في قول الله: <span class="qpc-hafs">﴿إلا عجوزا﴾</span>: امرأة لوط المُغْبَرة الشقية <span class="qpc-hafs">﴿في الغابرين﴾</span> الباقين الذين غبروا وأبقوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span>، غَبَرَتْ: بقيت في عذاب الله، لم ينجها{6}<span class=comment-ref>٤٨٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٠٢) أن قوله: <span class="qpc-hafs">﴿فِي الغابِرِينَ﴾</span> معناه: في الباقين. ثم قال: «فإما أن يريد: في الباقين من لِداتها وأهل سنتها. وهذا تأويل أبي عبيدة. وإما أن يريد: في الباقين في العذاب النازل بهم. وهذا تأويل قتادة. والمشهور أنها بمعنى: بقي. وغابر الزمان: مستقبله، ولكن الأعشى قد استعمل»غابر الزمان«بمعنى ماضيه في شعر المنافرة المشهور، وقال الزهراوي: يقال للذاهب: غابر، وللباقي: غابر».</div></p></div>",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٨٣-٨٤-.|2:أخرجه ابن أبي حاتم ٩/٢٨٠٩. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن أبي حاتم ٩/٢٨٠٩.|4:تفسير مقاتل بن سليمان ٣/٢٧٧.|5:أخرجه ابن أبي حاتم ٩/٢٨٠٩.|6:تفسير يحيى بن سلّام ٢/٥٢٠.
  26,172,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ دَمَّرۡنَا ٱلۡـَٔاخَرِینَ ۝١٧٢ وَأَمۡطَرۡنَا عَلَیۡهِم مَّطَرࣰاۖ فَسَاۤءَ مَطَرُ ٱلۡمُنذَرِینَ ۝١٧٣ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٧٤ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: ... فلمّا كان في جوف الليل إذ أدخل جبريل جناحَه تحت القرية، فرفعها، حتى إذا كانت في جو السماء -حتى إنهم ليسمعون أصوات الطير- قَلَبَها، ثم تَتَبَّع الشُّذّاذ ومَن خرج منهم بالحجارة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح– <span class="qpc-hafs">﴿وامطرنا عليهم مطرا﴾</span>، قال: على أهل بواديهم، وعلى رُعاتهم، وعلى مُسافريهم، فلم ينفلِت منهم أحدٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله ﷿: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span>: أمطر الله على قرية قوم لوط حجارة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿ثم دمرنا الآخرين﴾</span> قوم لوط وامرأته معهم، وكانت مُنافِقة، تظهر للوط الإيمان، وهي على الشرك.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٨<span class="dash">-</span></span> قوله ﷿: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span> قال <span class="name-2">قتادة</span>: أمطر الله على قرية قوم لوط حجارة، <span class="qpc-hafs">﴿فساء مطر المنذرين﴾</span> أي: فبئس مطر المنذرين، أنذرهم لوط فلم يقبلوا. أصاب قريتهم الخسف، وأصابت الحجارة مَن كان خارجًا من القرية، وأهل السَّفر منهم، وأصاب العجوزَ حجرٌ فقتلها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٠٩<span class="dash">-</span></span> عن الحكم بن أبان، في قوله: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span>، قال: سمعت <span class="name-2">وهبًا</span> يقول: الكبريت، والنار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم دمرنا﴾</span> يعني: أهلكنا <span class="qpc-hafs">﴿الآخرين﴾</span> بالخسف والحصب، فذلك قوله تعالى: <span class="qpc-hafs">﴿وأمطرنا عليهم مطرا﴾</span> يعني: الحجارة، <span class="qpc-hafs">﴿فساء﴾</span> يعني: فبئس <span class="qpc-hafs">﴿مطر المنذرين﴾</span> يعني: الذين أُنذروا بالعذاب، خسف الله بقرى قوم لوط، وأرسل الحجارة على مَن كان خارجًا من القرية، <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يعني: إن في هلاكهم بالخسف والحصب لَعِبرة لهذه الأمة، ثم قال تعالى: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> لو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين. وذلك قوله تعالى: <span class="qpc-hafs">﴿ولقد أنذرهم بطشتنا﴾</span> [القمر:٣٦]، يعني: عذابنا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٩.|2:أخرجه ابن أبي حاتم ٩/٢٨٠٩.|3:علَّقه يحيى بن سلّام ٢/٥٢١.|4:تفسير يحيى بن سلّام ٢/٥٢٠.|5:أخرجه ابن أبي حاتم ٩/٢٨١٠.|6:تفسير مقاتل بن سليمان ٣/٢٧٧.
  26,173,""
  26,174,""
  26,175,""
  26,176,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَ أَصۡحَـٰبُ لۡـَٔیۡكَةِ ٱلۡمُرۡسَلِینَ ۝١٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤١١<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «<b>إنّ قوم مدين وأصحاب الأيكة أُمَّتان، بعث الله إليهما شعيبًا النبيَّ ﵇</b>»{1}<span class=comment-ref>٤٨٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٢١</span> <span class="comment-type-4">علَّق</span> <u>ابن كثير</u> (١٠/٣٦٧) على هذا الحديث بقوله: «والصحيح أنهم أمة واحدة، وُصِفوا في كل مقام بشيء؛ ولهذا وُعِظ هؤلاء وأمرهم بوفاء المكيال والميزان، كما في قصة مدين سواء بسواء، فدل ذلك على أنهم أمة واحدة».</div></p><p><div></p><p><p><span class="item-no">٥٦٤١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، يقول: أصحاب الغيضة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، مثل ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: الأيكة: مَجْمَع الشجر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: أهل مدين، والأيكة: المُلْتَفُّ مِن الشجر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: كانوا أصحاب غَيْضَة بين ساحل البحر إلى مدين{6}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿لئيكة﴾</span>، قال: الأيكة{7}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- في قول الله: <span class="qpc-hafs">﴿كذب أصحاب الايكة المرسلين﴾</span>، قال: هم قوم شعيب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: أصحاب الأيكة أصحاب شجر، وهم قوم شعيب، وأصحاب الرس أصحاب آبار، وهم قوم شعيب{9}. (١١/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق جرير بن حازم - قال: بُعِث شعيب إلى أمتين: إلى قومه أهل مدين، وإلى أصحاب الأيكة، وكانت الأيكة مِن شجر مُلْتَفّ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: أصحاب الأيكة ومدين هما أُمَّتان، أُرسِل إليها شعيب النبي ﷺ، وعُذِّبا بعذاب شَتّى، أما أهل مدين فأخذتهم الصيحة، وكانوا أهل مدينة، فأصبحوا في دارهم جاثمين، وأما أصحاب الأيكة فكانوا أصحاب شجر مُتَكاوِس{11}، ورَكَوات{12}{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿أصحاب الأيكة﴾</span>، والأيكة: غيضة، بعث الله ﷿ إليهم شعيبًا، فكذبوه ...{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: إنّ شعيبًا أخا مدين أرسل أيضًا إلى أصحاب الأيكة، وهم كانوا [قومًا] من أهل عمور، يتبعون الرعاء والكلأ في زمانه، فإذا يبس الغَوْر{15} رجعوا إلى الغيضة التي كانوا يتقيضون{16}، وهي أجَمَة{17} فيها عين سائحة{18}، وإنّ شعيبًا أنذرهم، فكذبوه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذب أصحاب الأيكة﴾</span> يعني: غيطة الشجر، كان أكثر الشجرة الدَّوْم، وهو المُقْل{20} <span class="qpc-hafs">﴿المرسلين﴾</span> يعني: كذبوا شعيبًا ﵇ وحده، وشعيب بن نويب ابن مدين بن إبراهيم خليل الرحمن{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: كان مِن قصة شعيب وخبرِه وخبرِ قومه ما ذكر الله في القرآن، وكانوا أهل بخس الناس في مكاييلهم وموازينهم، مع كفرهم بالله، وتكذيبهم نبيهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: الأيكة: الشجر. بعث الله شعيبًا إلى قومه مِن أهل مدين، وإلى أهل البادية، قال: وهم أصحاب لَيْكة. ولَيْكة والأَيكة واحد{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span> بُعِث شعيب إلى أُمَّتين. والأيكة: الغَيْضَة{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر -كما في تفسير ابن كثير ٦/١٥٩-، وأورده ابن منظور في مختصر تاريخ دمشق ١٠/٣٠٩.</p><p>قال ابن أبي حاتم في علل الحديث ٥/٣٢-٣٣ (١٧٨٦): «هذا باطل». وأورده الذهبي في ميزان الاعتدال ٤/١٣٨ (٨٦٣٤) في ترجمة معاوية بن هشام. وقال ابن كثير: «وهذا غريب، وفي رفعه نظر، والأشبه أن يكون موقوفًا». وقال في البداية والنهاية ١/٤٣٩: «حديث غريب، وفي رجاله مَن تُكُلِّم فيه، والأشبه أنه من كلام عبد الله بن عمرو مِمّا أصابه يوم اليرموك من تلك الزاملتين من أخبار بني إسرائيل». وقال ابن حجر في تهذيب التهذيب ١٠/٢١٩ عن الحديث أنه: «مِن أوهام معاوية بن هشام».|2:أخرجه ابن جرير ١٧/٦٣٣، وابن أبي حاتم ٩/٢٨١٠.|3:علَّقه ابن أبي حاتم ٩/٢٨١٠.|4:أخرجه ابن جرير ١٧/٦٣٣، وابن أبي حاتم ٩/٢٨١٠.|5:أخرجه ابن جرير ١٧/٦٣٣.|6:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. عزاه السيوطي إلى إسحاق بن بشر.|7:عزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن أبي حاتم ٩/٢٨١٠.|9:عزاه السيوطي إلى ابن المنذر. وأخرج شطره الأول ابن أبي حاتم ٩/٢٨١١ من طريق همام.|10:أخرجه ابن جرير ١٧/٦٣٧.|11:مُتَكاوِس: مُلْتَفّ مُتَراكِب. النهاية (كوس).|12:رَكَوات: جمع رَكْوة: وهو إناءٌ صَغِير مِن جِلد يُشْرَب فيه الماء. اللسان (ركا).|13:أخرجه ابن أبي حاتم ٩/٢٨١٥. وفي تفسير الثعلبي ٧/١٧٩: بعث الله سبحانه شعيبًا إلى أمتين: أصحاب الأيكة وأهل مدين، فأما أصحاب الأيكة فأهلكوا بالظلة، وأما أهل مدين فأخذتهم الصيحة، صاح بهم جبريل صيحة فهلكوا جميعًا.|14:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٧٦ (١٨٣)-.|15:الغَوْر: ما انخفض من الأرض. النهاية (غور).|16:كذا في مطبوعة تفسير ابن أبي حاتم.|17:الأَجَمَة: مَنبت الشَّجَرِ، كالغَيْضة. اللسان (أجم).|18:سائحة: جارية على وجه الأرض. اللسان (سيح).|19:أخرجه ابن أبي حاتم ٩/٢٨١١.|20:الدَّوْمِ: جمع دوْمَة: وهي ضِخامُ الشَّجَر. وقيل: هو شجَرُ المُقْل. وقيل: العِظام من شجر السِّدْر. النهاية واللسان (دوم).|21:تفسير مقاتل بن سليمان ٣/٢٧٨.|22:أخرجه ابن أبي حاتم ٩/٢٨١٠.|23:أخرجه ابن جرير ١٧/٦٣٣، وابن أبي حاتم ٩/٢٨١٠ من طريق أصبغ.|24:تفسير يحيى بن سلّام ٢/٥٢١.
  26,177,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَ لَهُمۡ شُعَیۡبٌ أَلَا تَتَّقُونَ ۝١٧٧ إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٧٨ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٧٩ وَمَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿كذب أصحاب الأيكة المرسلين﴾</span>، قال: كانوا أصحاب غيضة بين ساحل البحر إلى مدين، <span class="qpc-hafs">﴿إذ قال لهم شعيب﴾</span> ولم يقل: أخوهم شعيب. لأنه لم يكن مِن جنسهم: <span class="qpc-hafs">﴿ألا تتقون﴾</span> كيف لا تتقون، وقد علمتم أنِّي رسول أمين؟! لا تعتبرون مِن هلاك مدين، وقد أهلكوا فيما يأتون! وكان أصحابُ الأيكة مع ما كانوا فيه مِن الشرك استنوا سُنَّة أصحاب مدين، فقال لهم شعيب: <span class="qpc-hafs">﴿إني لكم رسول أمين فاتقوا الله وأطيعون﴾</span>، وما أسألكم على ما أدعوكم إليه أجرًا في العاجل في أموالكم، <span class="qpc-hafs">﴿إن أجري إلا على رب العالمين﴾</span>{1}. (١١/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ قال لهم شعيب﴾</span> ولم يكن شعيب مِن نسبهم، فلذلك لم يقل ﷿: أخوهم شعيب. وقد كان أُرسِل إلى أُمَّة غيرهم أيضًا إلى ولد مدين، وشعيب مِن نسلهم، فمِن ثمَّ قال في هذه السورة: <span class="qpc-hafs">﴿إذ قال لهم شعيب﴾</span> ولم يقل: أخوهم. لأنه ليس من نسلهم، <span class="qpc-hafs">﴿ألا تتقون﴾</span> يقول: ألا تخشون الله ﷿؟! <span class="qpc-hafs">﴿إني لكم رسول أمين*فاتقوا الله وأطيعون﴾</span> فيما آمركم به مِن النصيحة، <span class="qpc-hafs">﴿وما أسألكم عليه﴾</span> يعني: على الإيمان <span class="qpc-hafs">﴿من أجر﴾</span> يعني: مِن جُعْل، <span class="qpc-hafs">﴿إن أجري﴾</span> يعني: ما جزائي <span class="qpc-hafs">﴿إلا على رب العالمين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إذ قال لهم شعيب ألا تتقون﴾</span> الله؟! ألا تخشون الله؟! وهي مثل الأولى، يأمرهم أن يتقوا الله، <span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span> على ما جئتكم به، <span class="qpc-hafs">﴿فاتقوا الله وأطيعون (١٠٨) وما أسألكم عليه من أجر﴾</span> على ما جئتكم به، <span class="qpc-hafs">﴿إن أجري﴾</span> إن جزائي، أي: إن ثوابي <span class="qpc-hafs">﴿إلا على رب العالمين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٢٣/٧٥-٧٦ من طريق إسحاق بن بشر عن جويبر عن الضحاك. وعزاه السيوطي إلى إسحاق بن بشر.|2:تفسير مقاتل بن سليمان ٣/٢٧٨.|3:تفسير يحيى بن سلّام ٢/٥٢١.
  26,178,""
  26,179,""
  26,180,""
  26,181,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوۡفُوا۟ ٱلۡكَیۡلَ وَلَا تَكُونُوا۟ مِنَ ٱلۡمُخۡسِرِینَ ۝١٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٣١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿من المخسرين﴾</span>، يعني: مِن الناقصين في الكيل والميزان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوفوا الكيل﴾</span> ولا تُنقِصوه، <span class="qpc-hafs">﴿ولا تكونوا من المخسرين﴾</span> يعني: مِن المُنقِصين للكيل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أوفوا الكيل ولا تكونوا من المخسرين﴾</span>، يعني: مِن المتنقصين الذين ينتقصون الناسَ حقوقَهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡفُوا۟ ٱلۡكَیۡلَ وَلَا تَكُونُوا۟ مِنَ ٱلۡمُخۡسِرِینَ ۝١٨١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٣٤<span class="dash">-</span></span> عن يحيى بن سعيد، قال: كان <span class="name-2">سعيد بن المسيب</span> يقول: إذا كنت بأرضٍ يُوفون المكيال والميزان فلا تعجل بالخروج منها، واذا كنت بأرض لا يُوفون المكيال والميزان فعَجِّل بالخروج منها{4}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ٢/٥٢١.|2:تفسير مقاتل بن سليمان ٣/٢٧٨.|3:تفسير يحيى بن سلّام ٢/٥٢١.|4:أخرجه ابن أبي حاتم ٩/٢٨١١.
  26,182,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَزِنُوا۟ بِٱلۡقِسۡطَاسِ ٱلۡمُسۡتَقِیمِ ۝١٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٣٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وزنوا بالقسطاس المستقيم﴾</span>: يعني: الميزان، وبلغة الروم الميزان: القسطاس{1}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- قال: القسطاس: العدل، بالرُّوميَّة{2}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: القَبّانِ{3}{4}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن ذكوان- <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: القَبّان{5}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٣٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: بالحديد{6}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: العدل{7}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزنوا بالقسطاس المستقيم﴾</span>، يعني: بالميزان المستقيم. والميزان بلغة الروم: القسطاس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وزنوا بالقسطاس المستقيم﴾</span>، والقسطاس: العدل، بالرومية{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه يحيى بن سلّام ٢/٥٢٢، والفريابي -كما في التغليق ٥/٣٨٢-٣٨٣- وابن أبي شيبة ١٠/٤٧١-٤٧٢، وابن جرير ١٤/٥٩٢ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:القَبّان: الميزان ذو الذراع الطويلة المقسمة أقسامًا. الوسيط (قبن).|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٤/٥٩١، وابن أبي حاتم ٩/٢٨١٢ من طريق عمرو. وعزاه السيوطي إلى عبد بن حميد.|6:أخرجه ابن أبي حاتم ٩/٢٨١٢.|7:أخرجه ابن أبي حاتم ٩/٢٨١٢. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.|8:تفسير مقاتل بن سليمان ٣/٢٧٨.|9:تفسير يحيى بن سلّام ١/١٣٥.
  26,183,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَبۡخَسُوا۟ ٱلنَّاسَ أَشۡیَاۤءَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبدالله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿ولا تبخسوا الناس﴾</span>، قال: لا تَظْلِمُوا الناسَ{1}. (٦/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، قال: لا تَظْلموهم{2}. (٦/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، يقول: لا تظلموا الناس أشياءهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، يقول: ولا تنقصوا الناس حقوقهم في الكيل والميزان{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قول الله: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، قال: لا تنقصوهم، تُسَمِّي له شيئًا ثم تُعطيه غير ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، أي: ولا تنقصوا الناس أشياءهم، يعني: الذي لهم، وكانوا أصحاب تطفيف ونقصٍ في الميزان{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَبۡخَسُوا۟ ٱلنَّاسَ أَشۡیَاۤءَهُمۡ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٤٩<span class="dash">-</span></span> قال ابن القاسم: وأخبرني يعقوب بن عبد الرحمن من بني القارة حليف لبني زهرة، عن أبيه: أنّ <span class="name-2">عمر بن عبد العزيز</span> كتب إلى عامل المدينة: أن يضع المكس؛ فإنه ليس بالمكس، ولكنه البخس، قال الله تعالى: <span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم﴾</span>، ومَن أتاك بصدقة فاقبلها منه، ومَن لم يأتك بها فالله حسيبه، والسلام{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝١٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٤٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span>، يقول: لا تَسْعَوا في الأرض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span> -من طريق السُّدِّيّ- قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، يقول: لا تمشوا بالمعاصي{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٢<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: ولا تكونوا في الأرض مفسدين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، يقول: لا تسيروا في الأرض{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٤٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span> يعني: ولا تَسْعَوا في الأرض <span class="qpc-hafs">﴿مفسدين﴾</span> بالمعاصي{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٢٠، ٩/٢٨١٢.|2:أخرجه ابن جرير ١٠/٣١١. وعلَّقه ابن أبي حاتم ٩/٢٨١٢. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.|3:أخرجه ابن جرير ١٠/٣١١. وعلَّقه ابن أبي حاتم ٥/١٥٢٠، ٩/٢٨١٢.|4:تفسير مقاتل بن سليمان ٣/٢٧٨.|5:أخرجه ابن أبي حاتم ٥/١٥٢٠، ٦/٢٠٧١، ٩/٢٨١٢.|6:تفسير يحيى بن سلّام ٢/٥٢٢.|7:المدونة للإمام مالك ١/٣٣١.|8:أخرجه ابن أبي حاتم ٩/٢٨١٢.|9:أخرجه ابن أبي حاتم ٩/٢٨١٣.|10:علَّقه يحيى بن سلّام ٢/٥٢٢.|11:أخرجه ابن أبي حاتم ٩/٢٨١٢. وعلَّقه يحيى بن سلّام ٢/٥٢٢.|12:تفسير مقاتل بن سليمان ٣/٢٧٨.