26,181," <q>﴿أَوۡفُوا۟ ٱلۡكَیۡلَ وَلَا تَكُونُوا۟ مِنَ ٱلۡمُخۡسِرِینَ ۝١٨١﴾</q> - تفسير ٥٦٤٣١- قال إسماعيل السُّدِّيّ: <q>﴿من المخسرين﴾</q>، يعني: مِن الناقصين في الكيل والميزان{1}. (ز) ٥٦٤٣٢- قال مقاتل بن سليمان: <q>﴿أوفوا الكيل﴾</q> ولا تُنقِصوه، <q>﴿ولا تكونوا من المخسرين﴾</q> يعني: مِن المُنقِصين للكيل{2}. (ز) ٥٦٤٣٣- قال يحيى بن سلّام: <q>﴿أوفوا الكيل ولا تكونوا من المخسرين﴾</q>، يعني: مِن المتنقصين الذين ينتقصون الناسَ حقوقَهم{3}. (ز) <q>﴿أَوۡفُوا۟ ٱلۡكَیۡلَ وَلَا تَكُونُوا۟ مِنَ ٱلۡمُخۡسِرِینَ ۝١٨١﴾</q> - آثار متعلقة بالآية ٥٦٤٣٤- عن يحيى بن سعيد، قال: كان سعيد بن المسيب يقول: إذا كنت بأرضٍ يُوفون المكيال والميزان فلا تعجل بالخروج منها، واذا كنت بأرض لا يُوفون المكيال والميزان فعَجِّل بالخروج منها{4}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ٢/٥٢١.تفسير مقاتل بن سليمان ٣/٢٧٨.تفسير يحيى بن سلّام ٢/٥٢١.أخرجه ابن أبي حاتم ٩/٢٨١١.
26,182," <q>﴿وَزِنُوا۟ بِٱلۡقِسۡطَاسِ ٱلۡمُسۡتَقِیمِ ۝١٨٢﴾</q> - تفسير ٥٦٤٣٥- عن سعيد بن جبير، في قوله: <q>﴿وزنوا بالقسطاس المستقيم﴾</q>: يعني: الميزان، وبلغة الروم الميزان: القسطاس{1}. (٩/٣٤٣) ٥٦٤٣٦- عن مجاهد بن جبر -من طريق جابر- قال: القسطاس: العدل، بالرُّوميَّة{2}. (٩/٣٤٤) ٥٦٤٣٧- عن الضَّحّاك بن مُزاحِم، <q>﴿وزنوا بالقسطاس﴾</q>، قال: القَبّانِ{3}{4}. (٩/٣٤٤) ٥٦٤٣٨- عن الحسن البصري -من طريق الحسن بن ذكوان- <q>﴿وزنوا بالقسطاس﴾</q>، قال: القَبّان{5}. (٩/٣٤٤) ٥٦٤٣٩- عن الحسن البصري -من طريق مبارك- <q>﴿وزنوا بالقسطاس﴾</q>، قال: بالحديد{6}. (٩/٣٤٥) ٥٦٤٤٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وزنوا بالقسطاس﴾</q>، قال: العدل{7}. (٩/٣٤٤) ٥٦٤٤١- قال مقاتل بن سليمان: <q>﴿وزنوا بالقسطاس المستقيم﴾</q>، يعني: بالميزان المستقيم. والميزان بلغة الروم: القسطاس{8}. (ز) ٥٦٤٤٢- قال يحيى بن سلّام: قوله: <q>﴿وزنوا بالقسطاس المستقيم﴾</q>، والقسطاس: العدل، بالرومية{9}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٥٢٢، والفريابي -كما في التغليق ٥/٣٨٢-٣٨٣- وابن أبي شيبة ١٠/٤٧١-٤٧٢، وابن جرير ١٤/٥٩٢ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.القَبّان: الميزان ذو الذراع الطويلة المقسمة أقسامًا. الوسيط (قبن).عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٥٩١، وابن أبي حاتم ٩/٢٨١٢ من طريق عمرو. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨١٢.أخرجه ابن أبي حاتم ٩/٢٨١٢. وعلَّقه يحيى بن سلّام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٧٨.تفسير يحيى بن سلّام ١/١٣٥.
26,183," <q>﴿وَلَا تَبۡخَسُوا۟ ٱلنَّاسَ أَشۡیَاۤءَهُمۡ﴾</q> - تفسير ٥٦٤٤٣- عن عبدالله بن عباس -من طريق الضحاك- <q>﴿ولا تبخسوا الناس﴾</q>، قال: لا تَظْلِمُوا الناسَ{1}. (٦/٤٧٨) ٥٦٤٤٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تبخسوا الناس أشياءهم﴾</q>، قال: لا تَظْلموهم{2}. (٦/٤٧٨) ٥٦٤٤٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿ولا تبخسوا الناس أشياءهم﴾</q>، يقول: لا تظلموا الناس أشياءهم{3}. (ز) ٥٦٤٤٦- قال مقاتل بن سليمان: <q>﴿ولا تبخسوا الناس أشياءهم﴾</q>، يقول: ولا تنقصوا الناس حقوقهم في الكيل والميزان{4}. (ز) ٥٦٤٤٧- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قول الله: <q>﴿ولا تبخسوا الناس أشياءهم﴾</q>، قال: لا تنقصوهم، تُسَمِّي له شيئًا ثم تُعطيه غير ذلك{5}. (ز) ٥٦٤٤٨- قال يحيى بن سلّام: <q>﴿ولا تبخسوا الناس أشياءهم﴾</q>، أي: ولا تنقصوا الناس أشياءهم، يعني: الذي لهم، وكانوا أصحاب تطفيف ونقصٍ في الميزان{6}. (ز) <q>﴿وَلَا تَبۡخَسُوا۟ ٱلنَّاسَ أَشۡیَاۤءَهُمۡ﴾</q> - آثار متعلقة بالآية ٥٦٤٤٩- قال ابن القاسم: وأخبرني يعقوب بن عبد الرحمن من بني القارة حليف لبني زهرة، عن أبيه: أنّ عمر بن عبد العزيز كتب إلى عامل المدينة: أن يضع المكس؛ فإنه ليس بالمكس، ولكنه البخس، قال الله تعالى: <q>﴿ولا تبخسوا الناس أشياءهم﴾</q>، ومَن أتاك بصدقة فاقبلها منه، ومَن لم يأتك بها فالله حسيبه، والسلام{7}. (ز) <q>﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝١٨٣﴾</q> - تفسير ٥٦٤٥٠- عن عبد الله بن عباس -من طريق الضحاك- قوله: <q>﴿ولا تعثوا في الأرض﴾</q>، يقول: لا تَسْعَوا في الأرض{8}. (ز) ٥٦٤٥١- عن أبي مالك غَزْوان الغِفارِيِّ -من طريق السُّدِّيّ- قوله: <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>، يقول: لا تمشوا بالمعاصي{9}. (ز) ٥٦٤٥٢- تفسير الحسن البصري: ولا تكونوا في الأرض مفسدين{10}. (ز) ٥٦٤٥٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>، يقول: لا تسيروا في الأرض{11}. (ز) ٥٦٤٥٤- قال مقاتل بن سليمان: <q>﴿ولا تعثوا في الأرض﴾</q> يعني: ولا تَسْعَوا في الأرض <q>﴿مفسدين﴾</q> بالمعاصي{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٢٠، ٩/٢٨١٢.أخرجه ابن جرير ١٠/٣١١. وعلَّقه ابن أبي حاتم ٩/٢٨١٢. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ١٠/٣١١. وعلَّقه ابن أبي حاتم ٥/١٥٢٠، ٩/٢٨١٢.تفسير مقاتل بن سليمان ٣/٢٧٨.أخرجه ابن أبي حاتم ٥/١٥٢٠، ٦/٢٠٧١، ٩/٢٨١٢.تفسير يحيى بن سلّام ٢/٥٢٢.المدونة للإمام مالك ١/٣٣١.أخرجه ابن أبي حاتم ٩/٢٨١٢.أخرجه ابن أبي حاتم ٩/٢٨١٣.علَّقه يحيى بن سلّام ٢/٥٢٢.أخرجه ابن أبي حاتم ٩/٢٨١٢. وعلَّقه يحيى بن سلّام ٢/٥٢٢.تفسير مقاتل بن سليمان ٣/٢٧٨.
