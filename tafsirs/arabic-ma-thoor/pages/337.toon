quran[8]{c,v,t}:
  22,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٤٢<span class="dash">-</span></span> قال يحيى بن سلّام: قوله: <span class="qpc-hafs">﴿أُذِنَ لِلَّذِينَ يُقاتَلُونَ بِأَنَّهُمْ ظُلِمُواْ﴾</span>، وهي قراءة <span class="name-1">أُبَيّ بن كعب</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٣<span class="dash">-</span></span> عن قتادة: في حرف <span class="name-1">ابن مسعود</span>: (أُذِنَ لِلَّذِينَ يُقاتَلُونَ فِي سَبِيلِ اللهِ){2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٤<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (أُذِنَ لِلَّذِينَ قاتَلُواْ بِأَنَّهُمْ ظُلِمُواْ){3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: كان يقرأ: ‹أُذِنَ لِلَّذِينَ يُقاتِلُونَ›{4}<span class=comment-ref>٤٤٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨١</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿أُذِنَ﴾</span> بترك تسمية الفاعل، و<span class="qpc-hafs">﴿يقاتَلون﴾</span> بفتحِ التاء، وقرأ غيرهم: ‹أذِنَ› بفتح الألف، بمعنى: أذن الله، و‹يُقاتِلُونَ› بكسر التاء. و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٦/٥٧٢) أن القراءة الثانية بمعنى: يقاتل المأذون لهم في القتال المشركين. وأن قراءة ‹أذِنَ› بفتح الألف، بمعنى: أذن الله، و‹يُقاتِلُونَ› بكسر التاء، بمعنى: إن الذين أذن الله لهم بالقتال يقاتلون المشركين. ورأى تقارب معنى هذه القراءات، فقال: «وهذه القراءات الثلاث متقاربات المعنى؛ لأن الذين قرءوا <span class="qpc-hafs">﴿أذن﴾</span> على وجه ما لم يسم فاعله، يرجع معناه في التأويل إلى معنى قراءة مَن قرأه على وجه ما سمي فاعله، وأن من قرأ ‹يُقاتِلُونَ› و<span class="qpc-hafs">﴿يقاتلون﴾</span> بالكسر أو الفتح، فقريب معنى أحدهما من معنى الآخر، وذلك أن من قاتل إنسانًا فالذي قاتلَه له مقاتِل، وكل واحد منهما مقاتِل مقاتَل. فإذ كان ذلك كذلك فبأية هذه القراءات قرأ القارئ فمصيب الصواب».</p><p>ثم <span class="comment-type-3">رجَّح</span> (١٦/٥٧٢-٥٧٣) <span class="mustanad">مستندًا إلى السياق</span> قراءة <span class="qpc-hafs">﴿أذن﴾</span> بالفتح، و<span class="qpc-hafs">﴿يقاتِلون﴾</span> بالكسر، فقال: «غير أن أحب ذلك إلي أن أقرأ به: <span class="qpc-hafs">﴿أذَن﴾</span> بفتح الألف، بمعنى: أذن الله -لقرب ذلك من قوله: <span class="qpc-hafs">﴿إن الله لا يحب كل خوان كفور﴾</span>- أذِنَ الله في الذين لا يحبهم للذين يقاتِلونهم بقتالهم، فيُردُّ (أذن) على قوله: <span class="qpc-hafs">﴿إن الله لا يحب﴾</span>، وكذلك أحب القراءات إلَيَّ في: ‹يُقاتِلُونَ› كسر التاء، بمعنى: الذين يقاتلون مَن قد أخبر الله عنهم أنه لا يحبهم، فيكون الكلام متصلًا معنى بعضه ببعض».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٥٢) أنّ صور الإذن تختلف قوتها بحسب القراءات، فمن قرأ: <span class="qpc-hafs">﴿يقاتلون﴾</span> بفتح التاء فالإذن فيها ظاهر أنه في مجازاة، ومن قرأ بالكسر فهو في ابتداء القتال.</div></p><p><h3><span class="qpc-hafs">﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٤٦<span class="dash">-</span></span> عن الزهري، قال: كان أول آية نزلت في القتال كما أخبرني عروة، عن <span class="name-1">عائشة</span>: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا وإن الله على نصرهم لقدير﴾</span> إلى قوله: <span class="qpc-hafs">﴿إن الله لقوي عزيز﴾</span>، ثم أذِن بالقتال في آيٍ كثيرٍ من القرآن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا أُخْرِج النبيُّ ﷺ من مكة قال أبو بكر: أخرجوا نبيَّهم، إنا لله وإنا إليه راجعون، ليَهلِكَنَّ القومُ. فنزلت: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span> الآية. وكان ابن عباس يقرؤها: <span class="qpc-hafs">﴿أُذِنَ﴾</span>. قال أبو بكر: فعلمتُ أنه سيكون قتال. قال ابن عباس: وهي أول آية نزلت في القتال{6}. (١٠/٥١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٨<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span>: أنّ أول آية أنزلت في القتال، حين ابتلى المسلمون بمكة، وسَطَتْ{7} بهم عشائرُهم ليفتنوهم عن الإسلام وأخرجوهم من ديارهم، وتظاهروا عليهم؛ فأنزل الله: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span> الآية، وذلك حين أذن الله لرسوله بالخروج، وأذن لهم بالقتال{8}. (١٠/٥١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: خرج ناس مؤمنون مهاجرين من مكة إلى المدينة، فاتبعهم كفار قريش، فأذن لهم في قتالهم؛ فأنزل الله: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span> الآية. فقاتلوهم{9}<span class=comment-ref>٤٤٨٢</span>. (١٠/٥١٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/٢٥٣) <span class="mustanad">مستندًا إلى السياق</span> هذا القول الذي قاله مجاهد، فقال: «وما بعد هذه الآية يرد هذا القول، لأن هؤلاء مُنعوا الخروج لا أخرجوا».</div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>: أنّ الله إنما قال: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span> بالقتال مِن أجل أنّ أصحاب رسول الله ﷺ كانوا استأذنوا رسول الله ﷺ في قتل الكفار إذا آذَوْهم واشْتَدُّوا عليهم بمكة قبل الهجرة، غيلة سِرًّا؛ فأنزل الله في ذلك: <span class="qpc-hafs">﴿إن الله لا يحب كل خوان كفور﴾</span>. فلما هاجر رسول الله ﷺ وأصحابه إلى المدينة أطلق لهم قتلهم وقتالهم، فقال: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span>، قال: هي أول آية أنزلت في القتال، فأذن لهم أن يقاتلوا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٢<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span>، قال: كانت أول آية نزلت في القتال: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span> الآية{12}. (١٠/٥١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق إسماعيل بن أبي خالد- قال: أول آية أنزلت في القتال: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٤<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق سفيان الثوري- في قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span>، قال: هي أول آية نزلت في القتال{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا وإن الله على نصرهم لقدير﴾</span>: يعني: محمدًا وأصحابه، إذ أخرجوا من مكة إلى المدينة؛ يقول الله: <span class="qpc-hafs">﴿وإن الله على نصرهم لقدير﴾</span>. وقد فعل{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span>، قال: النبي ﷺ وأصحابه، <span class="qpc-hafs">﴿بأنهم ظلموا﴾</span> يعني: ظلمهم أهل مكة حين أخرجوهم من ديارهم{16}. (١٠/٥١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حجّاج، عن ابن جُرَيج- قال: أُذِن للمؤمنين بقتال الكفار، فقاتلوهم. قال <span class="name-3">ابن جُرَيْج</span>: يقول: أول قتال أذن الله به للمؤمنين{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: أذن لهم بالقتال بعد ما أخرجهم المشركون وشُرِّدوا حتى لحق طوائف منهم بالحبشة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا قدموا المدينة أذن الله ﷿ للمؤمنين في القتال بعد النهي بمكة، فقال سبحانه: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span> في سبيل الله <span class="qpc-hafs">﴿بأنهم ظلموا﴾</span> ظلمهم كفار مكة، <span class="qpc-hafs">﴿وإن الله على نصرهم لقدير﴾</span> فنصرهم الله تعالى على كفار مكة بعد النهي{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون﴾</span>، قال: أُذِن لهم في قتالهم بعد ما عُفِي عنهم عشر سنين{20}. (١٠/٥١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span> أُذِن للذين يقاتلون في سبيل الله بأنهم ظلموا، ظلمهم المشركون، وأخرجوهم من ديارهم، يعني: من مكة ... وكان مَن كان يومئذ بمكة مِن المسلمين قد وضع الله عنهم القتال، فهو قوله: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span>{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٦٢<span class="dash">-</span></span> عن محمد بن سيرين، قال: أشرف عليهم <span class="name-1">عثمان</span> مِن القصر، فقال: ائتوني برجلٍ تالٍ كتابَ الله. فأتوه بصَعْصَعَة بن صَوْحان، فتكلم بكلام، فقال: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا وان الله على نصرهم لقدير﴾</span>. فقال له عثمان: كذبت، ليست لك، ولا لأصحابك، ولكنها لي ولأصحابي{22}. (١٠/٥١٤)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٣٨٠.</p><p>و<span class="qpc-hafs">﴿أُذِنَ﴾</span> بضم الهمزة وكسر الذال، قراءة نافع، وأبو جعفر، وأبو عمرو، ويعقوب، وعاصم، ووجه عن إدريس، وقراءة بقية العشرة والوجه الثاني لإدريس ‹أذِنَ› بفتح الهمزة، وكسر الذال. و<span class="qpc-hafs">﴿يُقاتَلُونَ﴾</span> بفتح التاء قراءة متواترة، قرأ بها نافع، وابن عامر، وحفص، وأبو جعفر، وقرأ بقية العشرة: ‹يُقاتِلُونَ› بكسر التاء. انظر: النشر ٢/٣٢٦، والإتحاف ص٣٩٩.|2:أخرجه ابن جرير ١٦/٥٧٦.</p><p>والقراءة شاذة. انظر: المحرر الوجيز ٤/١٢٤.|3:أخرجه ابن أبي داود في المصاحف ١/٤٢٤.</p><p>والقراءة شاذة. انظر: المحرر الوجيز ٤/١٢٤.|4:أخرجه عبد الرزاق ٢/٣٩.|5:أخرجه النسائي في السنن الكبرى ١٠/١٩٢.</p><p>قال الحافظ ابن حجر في الفتح ٧/٢٨٠: «إسناده صحيح».|6:أخرجه أحمد ٣/٣٥٨-٣٥٩ (١٨٦٥)، والترمذي ٥/٣٩٠ (٣٤٤٤)، والنسائي ٦/٢ (٣٠٨٥)، وابن حبان ١١/٨ (٤٧١٠)، والحاكم ٢/٧٦ (٢٣٧٦)، ٢/٢٦٩ (٢٩٦٨)، ٢/٤٢٢ (٣٤٦٩)، وعبد الرزاق ٢/٤٠٨ (١٩٣٧)، وابن جرير ١٦/٥٧٣-٥٧٤.</p><p>قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن القيم في زاد المعاد ٣/٦٤: «إسناده على شرط الصحيحين».|7:أي: قهرتهم وبطشت بهم. انظر: النهاية (سطا).|8:عزاه السيوطي إلى ابن أبي حاتم مرسلًا.|9:أخرجه ابن جرير ١٦/٥٧٥، والبيهقي في الدلائل ٢/٥٧٩ مرسلًا. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. كما أخرجه ابن جرير من طريق ابن جريج بلفظ: ناس من المؤمنين خرجوا مهاجرين من مكة إلى المدينة، وكانوا يمنعون، فأدركهم الكفار، فأذن للمؤمنين بقتال الكفار، فقاتلوهم. وكذا علقه يحيى بن سلام ١/٣٨٠.|10:علقه ابن جرير ١٦/٥٧٦.</p><p>قال ابن جرير: «من وجه غير ثبت».|11:أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٧٠.|12:عزاه السيوطي إلى عبد الرزاق، وابن المنذر.|13:أخرجه البيهقي في دلائل النبوة ٢/٥٨٠.|14:تفسير الثوري ص٢١٤.|15:أخرجه ابن جرير ١٦/٥٧٣.|16:عزاه السيوطي إلى ابن أبي حاتم.|17:أخرجه ابن جرير ١٦/٥٧٦.|18:علقه يحيى بن سلام ١/٣٨٠.|19:تفسير مقاتل بن سليمان ٣/١٢٩.|20:أخرجه ابن جرير ١٦/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.|21:علَّقه يحيى بن سلام ١/٣٨٠.|22:أخرجه ابن أبي شيبة ١٤/٥٩٤، ١٥/٢٠٣.
  22,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ أُخۡرِجُوا۟ مِن دِیَـٰرِهِم بِغَیۡرِ حَقٍّ إِلَّاۤ أَن یَقُولُوا۟ رَبُّنَا ٱللَّهُۗ﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٦٣<span class="dash">-</span></span> عن <span class="name-1">عثمان بن عفان</span>، قال: فينا نزلت هذه الآية: <span class="qpc-hafs">﴿الذين أخرجوا من ديارهم بغير حق﴾</span>، والآية بعدها؛ أخرجنا من ديارنا بغير حق، ثم مُكِّنّا في الأرض، فأقمنا الصلاة، وآتينا الزكاة، وأمرنا بالمعروف، ونهينا عن المنكر، فهي لي ولأصحابي{1}. (١٠/٥١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿الذين أخرجوا من ديارهم﴾</span> أي: من مكة إلى المدينة، <span class="qpc-hafs">﴿بغير حق﴾</span> يعني: محمدًا ﷺ وأصحابه{2}. (١٠/٥١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿الذين أخرجوا من ديارهم بغير حق﴾</span>: يعني: محمدًا ﷺ وأصحابه، أخرجوا من مكة بغير حق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦٦<span class="dash">-</span></span> قال يحيى بن سلام: قال <span class="name-2">الحسن البصري</span>: ما سفكوا لهم مِن دم، ولا أخذوا لهم مِن مال، ولا قطعوا لهم مِن رَحِم، وإنما أخرجوهم لأنهم قالوا: ربنا الله، كقوله: <span class="qpc-hafs">﴿وما نقموا منهم إلا أن يؤمنوا بالله العزيز الحميد﴾</span> [البروج:٨]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: قوله: <span class="qpc-hafs">﴿الذين أخرجوا من ديارهم بغير حق إلا أن يقولوا ربنا الله﴾</span>، لما قال المسلمون: لا إله إلا الله. أنكرها المشركون، وضاقَها{5} إبليس وجنوده{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن ظُلْم كفار مكة، فقال سبحانه: <span class="qpc-hafs">﴿الذين أخرجوا من ديارهم﴾</span> وذلك أنهم عَذَّبوا منهم طائفة، وآذَوْا بعضَهم بالألْسُن، حتى هربوا من مكة إلى المدينة <span class="qpc-hafs">﴿بغير حق إلا أن يقولوا﴾</span> يقول: لم يخرج كفار مكة المؤمنين من ديارهم، إلا أن يقولوا: <span class="qpc-hafs">﴿ربنا الله﴾</span> فعرَفوه ووَحَّدوه{7}<span class=comment-ref>٤٤٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٠/٧٣) أنّ البعض اسْتَدَلَّ بهذه الآية على مدنية السورة.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٢/٢١٦) أنّ هناك من قال بمكية السورة؛ لأن الإذن بالقتال كان بمكة. و<span class="comment-type-2">انتقده</span> (٢/٢١٦-٢١٧) <span class="mustanad">مستندًا إلى الواقع، والسياق، وأحوال النزول</span>، فقال: «وهذا غلط لوجوه: أحدها: أن الله لم يأذن بمكة لهم في القتال، ولا كان لهم شوكة يَتَمَكَّنون بها من القتال بمكة. الثاني: أنّ سياق الآية يدُلُّ على أنّ الإذن بعد الهجرة، وإخراجهم من ديارهم، فإنه قال: <span class="qpc-hafs">﴿الذين أخرجوا من ديارهم بغير حق إلا أن يقولوا ربنا الله﴾</span>، وهؤلاء هم المهاجرون. الثالث: قوله تعالى: <span class="qpc-hafs">﴿هذان خصمان اختصموا في ربهم﴾</span> [الحج:١٩] نزلت في الذين تَبارزوا يوم بدر من الفريقين. الرابع: أنه قد خاطبهم في آخرها بقوله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا﴾</span>، والخطاب بذلك كله مدني، فأما الخطاب بـ<span class="qpc-hafs">﴿يا أيها الناس﴾</span> فمشترك. الخامس: أنه أمر فيها بالجهاد الذي يعم الجهاد باليد وغيره، ولا ريب أنّ الأمر بالجهاد المطلق إنما كان بعد الهجرة، فأما جهاد الحجة فأمر به في مكة بقوله: <span class="qpc-hafs">﴿فلا تطع الكافرين وجاهدهم به﴾</span> [الفرقان:٥٢]، أي: بالقرآن جهادًا كبيرًا، فهذه سورة مكية، والجهاد فيها هو التبليغ وجهاد الحجة، وأما الجهاد المأمور به في سورة الحج فيدخل فيه الجهاد بالسيف. السادس: أن الحاكم روى في مستدركه من حديث الأعمش، عن مسلم البطين، عن سعيد بن جبير، عن ابن عباس، قال: لما خرج رسول الله ﷺ من مكة قال أبو بكر: أخرجوا نبيَّهم، إنا لله وإنا إليه راجعون، ليهلكن. فأنزل الله ﷿: <span class="qpc-hafs">﴿أذن للذين يقاتلون بأنهم ظلموا﴾</span>. وهي أول آية نزلت في القتال. وإسناده على شرط الصحيحين. وسياق السورة يدل على أن فيها المكي والمدني؛ فإن قصة إلقاء الشيطان في أمنية الرسول مكية».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا دَفۡعُ ٱللَّهِ ٱلنَّاسَ بَعۡضَهُم بِبَعۡضࣲ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٦٩<span class="dash">-</span></span> عن <span class="name-2">عاصم [بن أبي النجود]</span> أنّه قرأ: <span class="qpc-hafs">﴿ولَوْلا دَفْعُ اللَّهِ النّاسَ﴾</span> بغير ألف{8}. (١٠/٥١٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا دَفۡعُ ٱللَّهِ ٱلنَّاسَ بَعۡضَهُم بِبَعۡضࣲ﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٧٠<span class="dash">-</span></span> عن ثابت بن عوسجة الحضرمي، قال: حدثني سبعة وعشرون مِن أصحاب عليٍّ وعبد الله؛ منهم لاحق بن الأقمر، والعيزار بن جرول، وعطية القرظي، أنّ <span class="name-1">عليًّا</span> قال: إنما نزلت هذه الآية في أصحاب محمد: <span class="qpc-hafs">﴿ولولا دفع الله الناس﴾</span> الآية. قال: لولا دفاع الله بأصحاب محمد عن التابعين لهدمت صوامع{9}. (١٠/٥١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في الآية، قال: لولا دفع المشركين بالمسلمين{10}. (١٠/٥١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في الآية، قال: منعُ بعضهم ببعض في الشهادة وفي الحقِّ، وفيما يكون مثل هذا. يقول: لولا هذا لهلكت هذه الصوامع، وما ذُكِر معها{11}. (١٠/٥١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: يبتلى المؤمن بالكافر، ويعافى الكافر بالمؤمن{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولولا دفع الله الناس بعضهم ببعض﴾</span>، يقول: لولا أن يدفع الله المشركين بالمسلمين لغلب المشركون، فقتلوا المسلمين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قوله: <span class="qpc-hafs">﴿ولولا دفع الله الناس بعضهم ببعض﴾</span>: دفع المشركين بالمسلمين{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، <span class="qpc-hafs">﴿ولولا دفع الله الناس﴾</span> الآية، قال: لولا القتال والجهاد{15}. (١٠/٥١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿ولولا دفع الله الناس بعضهم ببعض﴾</span> يدفع عن المؤمنين بدينهم، ويدفع عن الكافرين بالمؤمنين{16}<span class=comment-ref>٤٤٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٤</span> اختُلِف في معنى قوله: <span class="qpc-hafs">﴿ولَوْلا دَفْعُ اللَّهِ النّاسَ بَعْضَهُمْ بِبَعْضٍ﴾</span> على أقوال: <b>الأول</b>: ولولا دفع الله المشركين بالمسلمين. <b>الثاني</b>: ولولا الجهاد والقتال في سبيل الله. <b>الثالث</b>: ولولا دفع الله بأصحاب رسول الله ﷺ عن التابعين. <b>الرابع</b>: ولولا دفع الله بشهادة الشهود على الحقوق.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٧٩-٥٨٠) صحَّةَ جميع ذلك <span class="mustanad">للعموم</span>، فقال: "وأَوْلى الأقوال في ذلك بالصواب أن يُقال: إنّ الله</p><p>-تعالى ذِكْرُه- أخبر أنه لولا دفاعه الناس بعضهم ببعض لهُدّم ما ذكر، من دفْعه -تعالى ذكره- بعضهم ببعض، وكفه المشركين بالمسلمين عن ذلك، ومنه كفه ببعضهم التظالم، كالسلطان الذي كف به رعيته عن التظالم بينهم، ومنه كفه لمن أجاز شهادته بينهم ببعضهم عن الذهاب بحق من له قِبَله حق، ونحو ذلك، وكل ذلك دفع منه الناس بعضهم عن بعض، لولا ذلك لتظالموا، فهدم القاهرون صوامع المقهورين وبيعهم، وما سمى -جل ثناؤه-. ولم يضع الله تعالى دلالة في عقل على أنه عنى من ذلك بعضًا دون بعض، ولا جاء بأن ذلك كذلك خبر يجب التسليم له، فذلك على الظاهر والعموم على ما قد بينته قبل؛ لعموم ظاهر ذلك جميع ما ذكرنا".</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٥٤) أنّ الآية تقوية للأمر بالقتال، وذكْر الحجة بالمصلحة فيه، وذكْر أنه متقدم في الأمم، وبه صلحت الشرائع واجتمعت المتعبَّدات، فكأنه قال: أُذن في القتال فليقاتل المؤمنون، ولولا القتال والجهاد لتُغلِّب على الحق في كل أمة.</p><p>و<span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى السياق</span> أنه القتال والجهاد، وهو القول الثاني الذي قاله ابن زيد، فقال: «هذا أصوب تأويلات الآية». وذكر أنه الأليق بمعنى الآية، و<span class="comment-type-1">وجَّه</span> الأقوال الأخرى بخروجها مخرج المثال، فقال: «ما قيل بعد من مُثُل الدفاع تبعٌ للجهاد». ونقل <b>عن فرقة</b> أن المعنى: ولولا دفع الله العذاب بدعاء الفضلاء والأخيار ونحوه، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لمخالفته لظاهر الآية</span>، فقال: «وهذا وما شاكله مُفسِد لمعنى الآية، وذلك أنّ الآية تقتضي ولا بُدَّ مدفوعًا مِن الناس ومدفوعًا عنه. فتأمله».</div></p><p><h3><span class="qpc-hafs">﴿لَّهُدِّمَتۡ صَوَ ٰ⁠مِعُ وَبِیَعࣱ وَصَلَوَ ٰ⁠تࣱ وَمَسَـٰجِدُ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٧٨<span class="dash">-</span></span> عن <span class="name-3">عاصم الجحدري</span> أنّه قرأ: (وصُلُوتٌ). قال: الصُّلُوتُ دون الصوامع. قال: وكيف تهدم الصلاة؟!{17}. (١٠/٥١٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّهُدِّمَتۡ صَوَ ٰ⁠مِعُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لهدمت صوامع﴾</span> الآية، قال: الصوامع التي تكون فيها الرُّهْبان{18}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿لهدمت صوامع﴾</span>، قال: صوامع الرهبان{19}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في الآية، قال: الصوامع{20}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لهدمت صوامع﴾</span>، قال: وهي صوامع الصغار{21} يبنونها{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿لهدمت صوامع﴾</span>: يعني: صوامع الرهبان{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿صوامع﴾</span>، قال: هي للصّابئين{24}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لهدمت﴾</span> يقول: لخربت <span class="qpc-hafs">﴿صوامع﴾</span> الرهبان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لهدمت صوامع﴾</span>، قال: صوامع الرهبان{22}<span class=comment-ref>٤٤٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٥</span> اختُلِف في المراد بالصوامع؛ <b>فقال قوم</b>: هي صوامع الرهبان. <b>وقال آخرون</b>: هي مُصَلّى الصابئين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٨٦) القول الأول الذي قاله مجاهد، وابن زيد، والضحاك، وأبو العالية. وانتقد الثاني <span class="mustanad">مستندًا إلى الأغلب في اللغة</span>، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك؛ لأن ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه مِن القول وإن كان له وجْهٌ فغير مستعمل فيما وجّهه إليه مَن وجَّهه إليه».</div></p><p><h3><span class="qpc-hafs">﴿وَبِیَعࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: والبيع: مساجد اليهود{18}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: البيع: بِيَع النصارى{28}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق داود- قال: البيع: بِيَع النصارى{29}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وبيع﴾</span>: كنائس{30}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- قال: البيع: بيع النصارى{31}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وبيع﴾</span>: للنصارى{32}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبيع﴾</span> النصارى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وبيع﴾</span>، قال: البيع للكنائس{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: <span class="qpc-hafs">﴿وبيع﴾</span> للنصارى، يعني: كنائس النصارى{12}<span class=comment-ref>٤٤٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٦</span> اختُلِف في المراد بالبيع؛ <b>فقال قوم</b>: هي بيع النصارى. <b>وقال آخرون</b>: كنائس اليهود.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٨٦) القول الأول الذي قاله قتادة، والضحاك، وأبو العالية، وابن سلام، ومقاتل، وانتقد الثاني <span class="mustanad">مستندًا إلى الأغلب في اللغة</span>، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك لأن ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه من القول -وإن كان له وجهٌ- فغير مستعمل فيما وجَّهه إليه مَن وجهه إليه».</p><p>وأورد الطبريُّ قول مجاهد تحت القول الثاني، وهو ما <span class="comment-type-2">انتقده</span> <u>ابنُ عطية</u> (٦/٢٥٥)، فقال: «قال الطبري: وقيل: هي كنائس اليهود. ثم أدخل عن مجاهد ما لا يقتضي ذلك».</div></p><p><h3><span class="qpc-hafs">﴿وَصَلَوَ ٰ⁠تࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وصلوات﴾</span>: كنائس النصارى{18}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: <span class="qpc-hafs">﴿وصلوات﴾</span>: كنائس اليهود{28}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span>، قال: الصلوات؛ صُلُوتًا: بِيَعٌ صغار للنصارى{38}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٩٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿وصلوات﴾</span>، قال: مساجد الصابئين، يسمونها بصلوات{39}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في <span class="qpc-hafs">﴿وصلوات﴾</span>: ومساجد لأهل الكتاب، ولأهل الإسلام بالطرق{40}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وصلوات﴾</span>: كنائس اليهود، ويسمون الكنيسة: صُلُوتا{41}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وصلوات﴾</span>: كنائس اليهود{42}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وصلوات﴾</span>، يعني: اليهود{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وصلوات﴾</span>، قال: الصلوات: صلوات أهل الإسلام تنقطع، إذا دخل العدوُّ عليهم انقطعت العبادة، والمساجد تهدم، كما صنع بُخْتُنَصَّر{44}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: <span class="qpc-hafs">﴿وصلوات﴾</span> الصلوات لليهود، يعني: كنائسهم{45}<span class=comment-ref>٤٤٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٧</span> اختُلِف في المراد بقوله: <span class="qpc-hafs">﴿وصَلَواتٌ﴾</span> على أقوال: <b>الأول</b>: كنائس اليهود يسمونها: صُلُوتًا، فعرِّب جمعها، فقيل: صلوات. <b>الثاني</b>: مساجد الصابئين. <b>الثالث</b>: مساجد للمسلمين ولأهل الكتاب بالطُّرق.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٨٦) القول الأول الذي قاله ابن عباس، والضحاك، وقتادة، وابن سلام، وانتقد البقية <span class="mustanad">مستندًا إلى الأغلب في اللغة</span>، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك لأنّ ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه مِن القول -وإن كان له وجه- فغير مستعمل فيما وجّهه إليه مَن وجهه إليه».</div></p><p><h3><span class="qpc-hafs">﴿وَمَسَـٰجِدُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: والمساجد: مساجد المسلمين{18}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿ومساجد﴾</span>: مساجد المسلمين{47}. (١٠/٥١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ومساجد﴾</span>، يقول: في كل هذا يذكر اسم الله كثيرًا، ولم يخص المساجد{41}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ومساجد﴾</span> للمسلمين{49}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومساجد﴾</span> المسلمين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: <span class="qpc-hafs">﴿ومساجد﴾</span> فيها مساجد المسلمين{45}<span class=comment-ref>٤٤٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٨</span> اختُلِف في المساجد؛ <b>فقال قوم</b>: مساجد المسلمين. <b>وقال غيرهم</b>: الصوامع والبيع والصلوات.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٨٦) <span class="mustanad">مستندًا إلى الأغلب في اللغة</span> القولَ الأول الذي قاله قتادة، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك لأنّ ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه من القول -وإن كان له وجه- فغير مستعمل فيما وجهه إليه من وجهه إليه».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٥٦) أن خُصَيْفًا قال بأن هذه الأسماء قصدها تقسيم متعبدات الأمم. و<span class="comment-type-4">علَّق</span> بقوله: «والأظهر أنه قصد بها المبالغة في ذكر المتعبدات».</div></p><p><h3><span class="qpc-hafs">﴿لَّهُدِّمَتۡ صَوَ ٰ⁠مِعُ وَبِیَعࣱ وَصَلَوَ ٰ⁠تࣱ وَمَسَـٰجِدُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩١٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يدفع عن هدم مصليات أهل الذِّمَّة بالمؤمنين{52}<span class=comment-ref>٤٤٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٩</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٢/٢١٨) قول الحسن <span class="mustanad">مستندًا إلى ظاهر لفظ الآية</span>، فقال: «وهذا ظاهر اللفظ، ولا إشكال فيه بوجه، فإنّ الآية دلت على الواقع، لم تدل على كون هذه الأمكنة -غير المساجد- محبوبة مَرْضِيَّة له، لكنه أخبر أنه لولا دفعه الناس بعضهم ببعض لهدمت هذه الأمكنة التي كانت محبوبة له قبل الإسلام، وأقرَّ منها ما أقر بعده، وإن كانت مسخوطة له كما أقر أهل الذمة، وإن كان يبغضهم ويمقتهم ويدفع عنهم بالمسلمين مع بغضه لهم. وهكذا يدفع عن مواضع متعبداتهم بالمسلمين، وإن كان يبغضها، وهو سبحانه يدفع عن متعبداتهم التي أُقِرُّوا عليها شرعًا وقدرًا، فهو يحب الدفع عنها، وإن كان يبغضها، كما يحب الدفع عن أربابها، وإن كان يبغضهم. وهذا القول هو الراجح -إن شاء الله تعالى-، وهو مذهب ابن عباس في الآية».</div></p><p><h3><span class="qpc-hafs">﴿یُذۡكَرُ فِیهَا ٱسۡمُ ٱللَّهِ كَثِیرࣰاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿يذكر فيها اسم الله كثيرا﴾</span>: يعني: في كل ما ذكر من الصوامع والصلوات والمساجد. يقول: في كل هذا يذكر اسم الله كثيرًا، ولم يَخُصّ المساجد{15}<span class=comment-ref>٤٤٩٠</span>. (١٠/٥١٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٩٠</span> ذكر <u>ابنُ تيمية</u> (٤/٤٣٢) أن الضحاك قال: إن الله يحب أن يذكر اسمه، وإن كان يشرك به. و<span class="comment-type-4">علَّق</span> عليه بقوله: «يعني: أن المشرك به خيرٌ مِن المعطل الجاحد الذي لا يذكر اسم الله بحال».</div></p><p><div></p><p><p><span class="item-no">٥٠٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يذكر فيها اسم الله كثيرا﴾</span> كل هؤلاء الملل يذكرون الله كثيرًا في مساجدهم، فدفع الله ﷿ بالمسلمين عنها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يذكر فيها اسم الله كثيرا﴾</span>، يعني: المساجد{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَیَنصُرَنَّ ٱللَّهُ مَن یَنصُرُهُۥۤۚ إِنَّ ٱللَّهَ لَقَوِیٌّ عَزِیزٌ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷾: <span class="qpc-hafs">﴿ولينصرن الله﴾</span> على عَدُوِّه <span class="qpc-hafs">﴿من ينصره﴾</span> يعني: مَن يعينه حتى يُوَحِّد الله ﷿، <span class="qpc-hafs">﴿إن الله لقوي﴾</span> في نصر أوليائه، <span class="qpc-hafs">﴿عزيز﴾</span> يعني: منيع في مُلكه وسلطانه. نظيرها في الحديد [٢٥]: <span class="qpc-hafs">﴿وليعلم الله من ينصره﴾</span>، يعني: مَن يُوَحِّده. وغيرها في الأحزاب، وهود{56}. وهو سبحانه أقوى وأعزُّ مِن خَلْقِه{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولينصرن الله من ينصره﴾</span> يعني: مَن ينصر دينه؛ النصر في الدنيا، والحجة في الآخرة، <span class="qpc-hafs">﴿إن الله لقوي عزيز﴾</span> في نِقْمَتِه{16}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن مردويه.|2:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|3:أخرجه إسحاق البستي في تفسيره ص٣٧٣.|4:علَّقه يحيى بن سلام ١/٣٨٠.|5:في تفسير القرطبي ١٦/١١: ضاق بها. وفي تفسير ابن جرير ٢٠/٤٨٢: فصادمها.|6:علَّقه يحيى بن سلام ١/٣٨٠.|7:تفسير مقاتل بن سليمان ٣/١٢٩.|8:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة ما عدا نافعًا، وأبا جعفر، ويعقوب؛ فإنهم قرؤوا <span class="qpc-hafs">﴿ولَوْلا دِفاعُ﴾</span> بكسر الدال وفتح الفاء وألف بعدها. انظر: النشر ٢/٣٢٧، والإتحاف ص٣٩٩.|9:أخرجه ابن جرير ١٦/٥٧٨-٥٧٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|10:عزاه السيوطي إلى ابن المنذر.|11:أخرجه ابن جرير ١٦/٥٧٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|12:علَّقه يحيى بن سلام ١/٣٨١.|13:تفسير مقاتل بن سليمان ٣/١٢٩.|14:أخرجه ابن جرير ١٦/٥٧٨.|15:عزاه السيوطي إلى ابن أبي حاتم.|16:تفسير يحيى بن سلام ١/٣٨١.|17:عزاه السيوطي إلى ابن أبي حاتم.</p><p>والقراءة شاذة. انظر: مختصر ابن خالويه ص٩٨، والمحتسب ٢/٨٤.|18:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|19:أخرجه ابن جرير ١٦/٥٨٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|20:أخرجه ابن جرير ١٦/٥٨١. وعلَّقه يحيى بن سلام ١/٣٨١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد،</p><p>وابن أبي حاتم.|21:هكذا في الأصل.|22:أخرجه ابن جرير ١٦/٥٨١.|23:تفسير البغوي ٥/٣٨٩.|24:أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨١. وعلَّقه يحيى بن سلام ١/٣٨١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|25:تفسير مقاتل بن سليمان ٣/١٢٩.|26:أخرجه ابن جرير ١٦/٥٨١.|27:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|28:أخرجه ابن جرير ١٦/٥٨٣. وعزاه السيوطي إلى عبد بن حميد.|29:أخرجه ابن جرير ١٦/٥٨٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|30:أخرجه ابن جرير ١٦/٥٨٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.|31:أخرجه ابن جرير ١٦/٥٨٢.|32:أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|33:تفسير مقاتل بن سليمان ٣/١٢٩.|34:أخرجه ابن جرير ١٦/٥٨٣.|35:علَّقه يحيى بن سلام ١/٣٨١.|36:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|37:أخرجه ابن جرير ١٦/٥٨٣. وعزاه السيوطي إلى عبد بن حميد.|38:عزاه السيوطي إلى عبد بن حميد.|39:أخرجه ابن جرير ١٦/٥٨٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|40:أخرجه ابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.|41:أخرجه ابن جرير ١٦/٥٨٦. وعزاه السيوطي إلى ابن أبي حاتم.|42:أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|43:تفسير مقاتل بن سليمان ٣/١٢٩.|44:أخرجه ابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن أبي حاتم.|45:علقه يحيى بن سلام ١/٣٨١.|46:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|47:أخرجه ابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|48:أخرجه ابن جرير ١٦/٥٨٦. وعزاه السيوطي إلى ابن أبي حاتم.|49:أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|50:تفسير مقاتل بن سليمان ٣/١٢٩.|51:علقه يحيى بن سلام ١/٣٨١.|52:تفسير الثعلبي ٧/٢٦.|53:عزاه السيوطي إلى ابن أبي حاتم.|54:تفسير مقاتل بن سليمان ٣/١٢٩.|55:تفسير يحيى بن سلام ١/٣٨١.|56:يشير إلى قوله تعالى في الأحزاب [٢٥]: <span class="qpc-hafs">﴿ورَدَّ اللَّهُ الَّذِينَ كَفَرُوا بِغَيْظِهِمْ لَمْ يَنالُوا خَيْرًا وكَفى اللَّهُ المُؤْمِنِينَ القِتالَ وكانَ اللَّهُ قَوِيًّا عَزِيزًا﴾</span>. وفي هود [٦٦]: <span class="qpc-hafs">﴿فَلَمّا جاءَ أمْرُنا نَجَّيْنا صالِحًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا ومِن خِزْيِ يَوْمِئِذٍ إنَّ رَبَّكَ هُوَ القَوِيُّ العَزِيزُ﴾</span>.|57:تفسير مقاتل بن سليمان ٣/١٣٠.|58:تفسير يحيى بن سلام ١/٣٨١.
  22,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ إِن مَّكَّنَّـٰهُمۡ فِی ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩١٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span>، في قوله: <span class="qpc-hafs">﴿الذين إن مكناهم في الأرض﴾</span>، قال: أصحاب محمد ﷺ{1}. (١٠/٥١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩١٩<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحِيِّ</span>: هذه الأُمَّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٠<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: أهل الصلوات الخمس{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: هم هذه الأُمَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٢<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: هم أصحاب محمد ﷺ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، <span class="qpc-hafs">﴿الذين ان مكناهم في الأرض﴾</span>، قال: هم الوُلاة{1}. (١٠/٥١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الذين إن مكناهم في الأرض﴾</span>، يعني: أرض المدينة، وهم المؤمنون، بعد القهر بمكة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿الذين إن مكناهم في الأرض﴾</span>، يعني: أصحاب النبي ﷺ{8}<span class=comment-ref>٤٤٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٩١</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/٢٥٧) هذا القول على أن <span class="qpc-hafs">﴿الَّذِينَ﴾</span> بدل من قوله: <span class="qpc-hafs">﴿يُقاتَلُونَ﴾</span>، أو على أن <span class="qpc-hafs">﴿الَّذِينَ﴾</span> تابع لـ<span class="qpc-hafs">﴿مَن﴾</span> في قوله: <span class="qpc-hafs">﴿مَن يَنْصُرُهُ﴾</span>.</div></p><p><h3><span class="qpc-hafs">﴿أَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ وَأَمَرُوا۟ بِٱلۡمَعۡرُوفِ وَنَهَوۡا۟ عَنِ ٱلۡمُنكَرِۗ وَلِلَّهِ عَـٰقِبَةُ ٱلۡأُمُورِ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٢٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- في الآية، قال: كان أمرُهم بالمعروف أنهم دَعَوْا إلى الله وحده وعبادته لا شريك له، وكان نهيهم أنهم نهوا عن عبادة الشيطان وعبادة الأوثان. قال: فمَن دعا إلى الله مِن الناس كلهم فقد أمر بالمعروف، ومن نهى عن عبادة الأوثان وعبادة الشيطان فقد نهى عن المنكر{9}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٧<span class="dash">-</span></span> قال حريث بن السائب: قلت <span class="name-2">للحسن البصري</span>: يا أبا سعيد، الأمر بالمعروف والنهي عن المنكر مِن الذي افترض الله على عباده؟ فقال: نعم. وقرأ: <span class="qpc-hafs">﴿الذين إن مكناهم في الأرض أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف ونهوا عن المنكر﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿الذين إن مكناهم في الأرض﴾</span> الآية، قال: هذا شرط الله على هذه الأُمَّة{1}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿الذين إن مكناهم في الأرض﴾</span> قال: أرض المدينة؛ <span class="qpc-hafs">﴿أقاموا الصلاة﴾</span> قال: المكتوبة، <span class="qpc-hafs">﴿وآتوا الزكاة﴾</span> قال: المفروضة، <span class="qpc-hafs">﴿وأمروا بالمعروف﴾</span> قال: بلا إله إلا الله، <span class="qpc-hafs">﴿ونهوا عن المنكر﴾</span> قال: عن الشرك بالله، <span class="qpc-hafs">﴿ولله عاقبة الأمور﴾</span> قال: وعند الله ثواب ما صنعوا{12}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال تعالى: <span class="qpc-hafs">﴿أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف﴾</span> يعني: التوحيد الذي يُعْرَف، <span class="qpc-hafs">﴿ونهوا عن المنكر﴾</span> الذي لا يُعْرَف، وهو الشِّرْك، <span class="qpc-hafs">﴿ولله عاقبة الأمور﴾</span> يعني: عاقبة أمر العباد إليه في الآخرة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف﴾</span> بعبادة الله، <span class="qpc-hafs">﴿ونهوا عن المنكر﴾</span> عن عبادة الأوثان، <span class="qpc-hafs">﴿ولله عاقبة الأمور﴾</span> إليه تصير الأمور، كقوله: <span class="qpc-hafs">﴿إنا نحن نرث الأرض ومن عليها وإلينا يرجعون﴾</span> [مريم:٤٠]{8}<span class=comment-ref>٤٤٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٩٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٥٧) أنّ فرقة قالت: هذه الآية في الخلفاء الأربعة. و<span class="comment-type-1">وجَّهه</span> بقوله: «ومعنى هذا التخصيص: أنّ هؤلاء خاصة مُكِّنوا في الأرض من جملة الذين يقاتَلَون المذكورين في صدر الآية». ثم <span class="comment-type-3">رجَّح</span> العموم، فقال: «والعموم في هذا كله أبين، وبه يتجه الأمر في جميع الناس».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير الثعلبي ٧/٢٦.|3:تفسير الثعلبي ٧/٢٦.|4:تفسير الثعلبي ٧/٢٦، وتفسير البغوي ٥/٣٩٠.|5:تفسير الثعلبي ٧/٢٦، وتفسير البغوي ٥/٣٩٠.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:تفسير مقاتل بن سليمان ٣/١٣٠.|8:تفسير يحيى بن سلام ١/٣٨١.|9:أخرجه ابن جرير ١٦/٥٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|10:أخرجه إسحاق البستي في تفسيره ص٣٧٤.|11:عزاه السيوطي إلى ابن أبي حاتم.|12:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|13:تفسير مقاتل بن سليمان ٣/١٣٠.|14:تفسير يحيى بن سلام ١/٣٨١.
  22,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یُكَذِّبُوكَ فَقَدۡ كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ وَعَادࣱ وَثَمُودُ ۝٤٢ وَقَوۡمُ إِبۡرَ ٰ⁠هِیمَ وَقَوۡمُ لُوطࣲ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن يكذبوك﴾</span> يا محمد، يُعَزِّي نبيَّه ﷺ؛ ليصبر على تكذيبهم إيّاه بالعذاب؛ <span class="qpc-hafs">﴿فقد كذبت قبلهم﴾</span> يعني: قبل أهل مكة <span class="qpc-hafs">﴿قوم نوح وعاد وثمود، وقوم إبراهيم وقوم لوط﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٠.
  22,43,""
  22,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ مَدۡیَنَۖ وَكُذِّبَ مُوسَىٰۖ فَأَمۡلَیۡتُ لِلۡكَـٰفِرِینَ ثُمَّ أَخَذۡتُهُمۡۖ فَكَیۡفَ كَانَ نَكِیرِ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأصحاب مدين﴾</span> يعني: قوم شعيب ﵇، كل هؤلاء كذبوا رسلهم، <span class="qpc-hafs">﴿وكذب موسى﴾</span> يعني: عُصِيَ موسى ﵇؛ لأنه وُلِد فيهم كما وُلِد محمد ﷺ فيهم، <span class="qpc-hafs">﴿فأمليت﴾</span> يعني: فأَمْهَلْتُ <span class="qpc-hafs">﴿للكافرين﴾</span> فلم أعجل عليهم بالعذاب، <span class="qpc-hafs">﴿ثم أخذتهم﴾</span> بعد الإمهال بالعذاب، <span class="qpc-hafs">﴿فكيف كان نكير﴾</span> يعني: تغييري، أليس وجدوه حَقًّا، فكذلك كذب كفار مكة كما كذبت [مُكَذِّبو] الأمم الخالية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأصحاب مدين﴾</span> يعني: الذين بعث الله إليهم شعيبًا، قال: <span class="qpc-hafs">﴿وكذب موسى﴾</span> كذبه فرعون، <span class="qpc-hafs">﴿فأمليت للكافرين﴾</span> يعني: جميع هؤلاء، ثم لم أهلكهم عند تكذيبهم رسلهم حتى جاء الوقت الذي أردت أن أهلكهم فيه، <span class="qpc-hafs">﴿ثم أخذتهم﴾</span> بالعذاب حين جاء الوقت، <span class="qpc-hafs">﴿فكيف كان نكير﴾</span> يعني: عقابي، أي: كان شديدًا. يُحَذِّر بذلك المشركين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٠.|2:تفسير يحيى بن سلام ١/٣٨١.
  22,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَأَیِّن مِّن قَرۡیَةٍ أَهۡلَكۡنَـٰهَا وَهِیَ ظَالِمَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكأين من قرية﴾</span>، يعني: وكم من قرية أهلكناها بالعذاب في الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فكأين من قرية﴾</span> يعني: كم مِن قرية <span class="qpc-hafs">﴿أهلكناها﴾</span> يعني: أهلكها{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهِیَ خَاوِیَةٌ عَلَىٰ عُرُوشِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٣٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿فهي خاوية على عروشها﴾</span>، قال: خَواؤُها: خرابها. وعروشها: سقوفها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿فهي خاوية على عروشها﴾</span>، قال: خَرِبَة ليس فيها أحد{4}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أهلكناها وهي ظالمة فهي خاوية﴾</span> يعني: خربة <span class="qpc-hafs">﴿على عروشها﴾</span> يعني: ساقطة من فوقها، يعني بالعروش: سقوف البيت، أي: ليس فيها مساكن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فهي خاوية﴾</span> فالقرية خاوية <span class="qpc-hafs">﴿على عروشها﴾</span> يعني: على بنيانها. وبعضهم يقول: العروش: السقوف، فصار أعلاها أسفلها{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبِئۡرࣲ مُّعَطَّلَةࣲ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٤١<span class="dash">-</span></span> عن عمر بن شقيق، قال: سمعت <span class="name-3">عاصمًا الجحدري</span> يقرأ: (وبِئْرٍ مُّعْطَلَةٍ) مضمومة الميم غير مشددة{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبِئۡرࣲ مُّعَطَّلَةࣲ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿وبئر معطلة﴾</span>، قال: التي تُرِكَتْ لا أهل لها{8}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وبئر معطلة﴾</span>، قال: لا أهل لها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي روق-: أنّ هذه البئر كانت بحضرموت في بلدة يقال لها: حاضُوراء، وذلك أنّ أربعة آلاف نفر مِمَّن آمن بصالح نَجَوْا مِن العذاب أتَوْا حضرموت، ومعهم صالح، فلمّا حضروه مات صالح، فسمي: حضرموت؛ لأنّ صالحًا لَمّا حضر مات، فبنوا حاضوراء، وقعدوا على هذه البئر، وأمروا عليهم رجلًا، فأقاموا دهرًا، وتناسلوا حتى كثروا، ثم إنهم عبدوا الأصنام، وكفروا، فأرسل الله إليهم نبيًّا يُقال له: حنظلة بن صفوان، كان حَمّالًا فيهم، فقتلوه في السوق، فأهلكهم الله، وعطلت بئرهم، وخربت قصورهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وبئر معطلة﴾</span>، قال: عَطَّلها أهلُها، وتركوها{11}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله ﷿: <span class="qpc-hafs">﴿وبئر معطلة﴾</span>، قال: البئر التي قد تُرِكت{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبئر معطلة﴾</span>، يعني: خالية لا تُسْتَعْمَل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وبئر معطلة﴾</span> قد باد أهلُها فعُطِّلَت{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَصۡرࣲ مَّشِیدٍ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: هو المُجَصَّص{15}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>. قال: شِيدَ بالجصِّ والآجُرِّ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت عدي بن زيد وهو يقول:</p><p>شادَه مرمرًا وجلَّله كِلْسَـ ـًا فللطير في ذُراه وكُورُ؟{16}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق هلال بن خباب- في قوله: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: مُجَصَّص{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: بالقَصَّة، أو الفضة{18}. (١٠/٥١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: طويل{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق هلال بن خباب- في قوله: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: المجصص. والجِصُّ بالمدينة يسمى: الشِّيد{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق هلال بن خباب- في قوله ﷿: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: مُحَصَّنٌ{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: مُجَصَّص{22}. (١٠/٥١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: شيَّدوه وحصنَّوه، فهلكوا وتركوه{23}. (١٠/٥١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>: رفيع طويل{24}<span class=comment-ref>٤٤٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٩٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٢٥٩) على هذا القول الذي قاله قتادة، والضحاك، ومقاتل، فقال: «ومعنى الآية يقتضي أنه كان كذلك قبل خرابه».</div></p><p><div></p><p><p><span class="item-no">٥٠٩٥٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله ﷿: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، قال: الشديد البناء، وشَهِقٌ{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: المشيد: الحصين{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقصر مشيد﴾</span>، يعني: طويلًا في السماء، ليس له أهل{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: <span class="qpc-hafs">﴿وقصر مشيد﴾</span> مبني معطل{2}<span class=comment-ref>٤٤٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٩٤</span> اختُلِف في معنى قوله: <span class="qpc-hafs">﴿وقَصْرٍ مَشِيدٍ﴾</span> على أقوال: <b>الأول</b>: وقصر مجصص. <b>الثاني</b>: وقصر رفيع طويل. <b>الثالث</b>: المشيد: الحصين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٩٤) <span class="mustanad">مستندًا إلى اللغة</span> القول الأول الذي قاله ابن عباس، وعكرمة، ومجاهد، وعطاء، وسعيد بن جبير، فقال: «وذلك أن الشيد في كلام العرب: هو الجصّ بعينه». ثم <span class="comment-type-1">وجَّه</span>، فقال: «وقد يجوز أن يكون معنيًا بالمشيد: المرفوع بناؤه بالشيد. فيكون الذين قالوا: عني بالمشيد: الطويل؛ نَحَوا بذلك إلى هذا التأويل». وذكر (١٦/٥٩٥) أن بعض أهل العلم بلغات العرب فسر المشيد بمعنى: المزيَّن بالشِّيد من: شِدْتُه أشيده: إذا زيَّنته به. و<span class="comment-type-4">علَّق</span> عليه بقوله:«وذلك شبيه بمعنى من قال: مجصص».</p><p>و<span class="comment-type-4">رأى</span> <u>ابنُ كثير</u> (١٠/٧٩) تقارب الأقوال، فقال: «وكل هذه الأقوال متقاربة، ولا منافاة بينها، فإنه لم يَحْمِ أهله شدة بنائه ولا ارتفاعه، ولا إحكامه ولا حصانته، عن حلول بأس الله بهم، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿أيْنَما تَكُونُوا يُدْرِكُكُمُ المَوْتُ ولَوْ كُنْتُمْ فِي بُرُوجٍ مُشَيَّدَةٍ﴾</span> [النساء:٧٨]».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣١.|2:تفسير يحيى بن سلام ١/٣٨٢.|3:أخرجه ابن جرير ١٦/٥٩٠.|4:أخرجه عبد الرزاق ٢/٤٠، وابن جرير ١٦/٥٩٠. وعلَّقه يحيى بن سلام ١/٣٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٣/١٣١.|6:تفسير يحيى بن سلام ١/٣٨٢.|7:أخرجه ابن الأعرابي في معجمه ٣/١١٠١ (٢٣٧١).</p><p>والقراءة شاذة. انظر: مختصر ابن خالويه ص٩٨، والمحتسب ٢/٨٤.|8:أخرجه ابن جرير ١٦/٥٩١، وفيه: «لا أهل لها» من قول غير ابن عباس. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن جرير ١٦/٥٩١.|10:تفسير الثعلبي ٧/٢٧، وتفسير البغوي ٥/٣٩٠.|11:أخرجه عبد الرزاق ٢/٤٠، وابن جرير ١٦/٥٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:أخرجه أبو جعفر الرملي في جزئه ص١١٨ (تفسير عطاء الخراساني).|13:تفسير مقاتل بن سليمان ٣/١٣١.|14:تفسير يحيى بن سلام ١/٣٨٢.|15:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|16:أخرجه الطستي -كما في الإتقان ٢/٧٢-.|17:أخرجه ابن جرير ١٦/٥٩٢، وقال: هكذا هو في كتابي: عن سعيد بن جبير. وعلَّق محققوه: وصوابه عن عكرمة.|18:أخرجه ابن جرير ١٦/٥٩١، وعبد بن حميد -كما في تغليق التعليق ٤/٢٦٠- مقتصرًا على لفظ: بالقَصَّة. وفي لفظ عند ابن جرير: بالقصة، يعني: بالجص. وفي تفسير الثعلبي ٧/٢٧: مجصص.|19:أخرجه ابن جرير ١٦/٥٩٤.|20:أخرجه عبد الرزاق ٢/٣٩ مختصرًا، وابن جرير ١٦/٥٩٢.|21:أخرجه سعيد بن منصور في سننه - التفسير ٦/٣٥١ (١٥٠٣).|22:أخرجه عبد الرزاق ٢/٣٩. وعزاه السيوطي إلى عبد بن حميد.|23:أخرجه عبد الرزاق ٢/٤٠. وابن جرير ١٦/٥٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|24:تفسير البغوي ٥/٣٩٠.|25:أخرجه أبو جعفر الرملي في جزئه ص ١١٨ (تفسير عطاء الخراساني).|26:علقه يحيى بن سلام ١/٣٨٢.|27:تفسير مقاتل بن سليمان ٣/١٣١. وفي تفسير الثعلبي ٧/٢٦، وتفسير البغوي ٥/٣٩٠ بنحوه منسوبًا إلى مقاتل دون تعيينه.|28:تفسير يحيى بن سلام ١/٣٨٢.
  22,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَمۡ یَسِیرُوا۟ فِی ٱلۡأَرۡضِ فَتَكُونَ لَهُمۡ قُلُوبࣱ یَعۡقِلُونَ بِهَاۤ أَوۡ ءَاذَانࣱ یَسۡمَعُونَ بِهَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفلم يسيروا في الأرض﴾</span> يقول: فلو ساروا في الأرض فتَفَكَّروا؛ <span class="qpc-hafs">﴿فتكون لهم قلوب يعقلون بها﴾</span> المواعظ، <span class="qpc-hafs">﴿أو آذان يسمعون بها فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿أفلم يسيروا في الأرض﴾</span> يعني: المشركين؛ <span class="qpc-hafs">﴿فتكون لهم قلوب يعقلون بها﴾</span> أي: لو ساروا فتَفَكَّروا ما نزل بإخوانهم مِن الكفار فيتوبون، لو كانت <span class="qpc-hafs">﴿لهم قلوب يعقلون بها أو آذان يسمعون بها﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّهَا لَا تَعۡمَى ٱلۡأَبۡصَـٰرُ وَلَـٰكِن تَعۡمَى ٱلۡقُلُوبُ ٱلَّتِی فِی ٱلصُّدُورِ ۝٤٦﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٦٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦٦<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: لَمّا نزل: <span class="qpc-hafs">﴿ومن كان في هذه أعمى فهو في الآخرة أعمى﴾</span>، جاء ابن أم مكتوم النبيَّ ﷺ باكيًا، فقال: يا رسول الله، أنا في الدنيا أعمى، أفأكون في الآخرة أعمى؟ فأنزل الله ﷾ هذه الآية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فإنها لا تعمى الأبصار﴾</span>، قال: ذُكِر لنا: أنّها نزلت في عبد الله بن زائدة. يعني: ابن أم مكتوم{4}. (١٠/٥١٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّهَا لَا تَعۡمَى ٱلۡأَبۡصَـٰرُ وَلَـٰكِن تَعۡمَى ٱلۡقُلُوبُ ٱلَّتِی فِی ٱلصُّدُورِ ۝٤٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي بكر- قال: لكل عين -يعني: لكل نفس- أربع أعين: عينان في رأسه لدنياه، وعينان في قلبه لآخرته، فإن عَمِيَتْ عينا رأسه وأبصرت عينا قلبه لم يضره عماه شيئًا، وإن أبصرت عينا رأسه وعميت عينا قلبه لم ينفعه شيئًا، قال الله: <span class="qpc-hafs">﴿فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فإنها لا تعمى الأبصار﴾</span>، قال: أما هذه الأبصار التي في الرؤوس فإنها جعلها الله منفعة وبُلْغَة، وأمّا البصر النافع فهو في القلب{6}. (١٠/٥١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٧٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قال: <span class="qpc-hafs">﴿فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</span>، إنما أُتُوا مِن قِبَل قلوبهم، ولو أنّ رجلًا كان أعمى بعد أن يكون مؤمنًا لم يضره شيئًا، وكان قلبه بصيرًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّهَا لَا تَعۡمَى ٱلۡأَبۡصَـٰرُ وَلَـٰكِن تَعۡمَى ٱلۡقُلُوبُ ٱلَّتِی فِی ٱلصُّدُورِ ۝٤٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٩٧١<span class="dash">-</span></span> عن عبد الله بن جراد، قال: قال رسول الله ﷺ: «<b>ليس العمى مَن يَعْمى بصرُه، ولكن العمى مَن تعمى بصيرته</b>»{8}. (١٠/٥٢٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣١.|2:تفسير يحيى بن سلام ١/٣٨٢.|3:أورده الثعلبيُّ ٧/٢٧.|4:علقه يحيى بن سلام ١/٣٨٢، وعزاه السيوطي إلى ابن أبي حاتم، وهو مرسل.|5:أخرجه يحيى بن سلام ١/٣٨٢.|6:علَّقه يحيى بن سلام ١/٣٨٢، وعزاه السيوطي إلى ابن أبي حاتم.|7:تفسير يحيى بن سلام ١/٣٨٢.|8:أخرجه البيهقي في شعب الإيمان ٢/٤٩٩-٥٠٠ (١٣٠٩)، والخطيب في الزهد والرقائق ص٩٨-٩٩ (٦٨).</p><p>قال المناوي في فيض القدير ٥/٣٥٥ (٧٥٦٩): «فيه يعلى بن الأشدق، أورده الذهبي في الضعفاء، وقال: قال البخاري: لا يكتب حديثه». وقال في التيسير ٢/٣٢٠: «وإسناده ضعيف». وقال الألباني في الضعيفة ٩/٣٧٠ (٤٣٨٢): «ضعيف جدًّا».