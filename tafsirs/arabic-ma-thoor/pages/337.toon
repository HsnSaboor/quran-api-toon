quran[8]{c,v,t}:
22,39," <q>﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</q> - قراءات ٥٠٨٤٢- قال يحيى بن سلّام: قوله: <q>﴿أُذِنَ لِلَّذِينَ يُقاتَلُونَ بِأَنَّهُمْ ظُلِمُواْ﴾</q>، وهي قراءة أُبَيّ بن كعب{1}. (ز) ٥٠٨٤٣- عن قتادة: في حرف ابن مسعود: (أُذِنَ لِلَّذِينَ يُقاتَلُونَ فِي سَبِيلِ اللهِ){2}. (ز) ٥٠٨٤٤- عن الأعمش: في قراءة عبد الله [بن مسعود]: (أُذِنَ لِلَّذِينَ قاتَلُواْ بِأَنَّهُمْ ظُلِمُواْ){3}. (ز) ٥٠٨٤٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: كان يقرأ: ‹أُذِنَ لِلَّذِينَ يُقاتِلُونَ›{4}٤٤٨١. (ز) ٤٤٨١ اختُلِف في قراءة قوله: <q>﴿أذن للذين يقاتلون﴾</q>؛ فقرأ قوم: <q>﴿أُذِنَ﴾</q> بترك تسمية الفاعل، و<q>﴿يقاتَلون﴾</q> بفتحِ التاء، وقرأ غيرهم: ‹أذِنَ› بفتح الألف، بمعنى: أذن الله، و‹يُقاتِلُونَ› بكسر التاء. وذكر ابنُ جرير (١٦/٥٧٢) أن القراءة الثانية بمعنى: يقاتل المأذون لهم في القتال المشركين. وأن قراءة ‹أذِنَ› بفتح الألف، بمعنى: أذن الله، و‹يُقاتِلُونَ› بكسر التاء، بمعنى: إن الذين أذن الله لهم بالقتال يقاتلون المشركين. ورأى تقارب معنى هذه القراءات، فقال: «وهذه القراءات الثلاث متقاربات المعنى؛ لأن الذين قرءوا <q>﴿أذن﴾</q> على وجه ما لم يسم فاعله، يرجع معناه في التأويل إلى معنى قراءة مَن قرأه على وجه ما سمي فاعله، وأن من قرأ ‹يُقاتِلُونَ› و<q>﴿يقاتلون﴾</q> بالكسر أو الفتح، فقريب معنى أحدهما من معنى الآخر، وذلك أن من قاتل إنسانًا فالذي قاتلَه له مقاتِل، وكل واحد منهما مقاتِل مقاتَل. فإذ كان ذلك كذلك فبأية هذه القراءات قرأ القارئ فمصيب الصواب». ثم رجَّح (١٦/٥٧٢-٥٧٣) مستندًا إلى السياق قراءة <q>﴿أذن﴾</q> بالفتح، و<q>﴿يقاتِلون﴾</q> بالكسر، فقال: «غير أن أحب ذلك إلي أن أقرأ به: <q>﴿أذَن﴾</q> بفتح الألف، بمعنى: أذن الله -لقرب ذلك من قوله: <q>﴿إن الله لا يحب كل خوان كفور﴾</q>- أذِنَ الله في الذين لا يحبهم للذين يقاتِلونهم بقتالهم، فيُردُّ (أذن) على قوله: <q>﴿إن الله لا يحب﴾</q>، وكذلك أحب القراءات إلَيَّ في: ‹يُقاتِلُونَ› كسر التاء، بمعنى: الذين يقاتلون مَن قد أخبر الله عنهم أنه لا يحبهم، فيكون الكلام متصلًا معنى بعضه ببعض». وذكر ابنُ عطية (٦/٢٥٢) أنّ صور الإذن تختلف قوتها بحسب القراءات، فمن قرأ: <q>﴿يقاتلون﴾</q> بفتح التاء فالإذن فيها ظاهر أنه في مجازاة، ومن قرأ بالكسر فهو في ابتداء القتال. <q>﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</q> - نزول الآية ٥٠٨٤٦- عن الزهري، قال: كان أول آية نزلت في القتال كما أخبرني عروة، عن عائشة: <q>﴿أذن للذين يقاتلون بأنهم ظلموا وإن الله على نصرهم لقدير﴾</q> إلى قوله: <q>﴿إن الله لقوي عزيز﴾</q>، ثم أذِن بالقتال في آيٍ كثيرٍ من القرآن{5}. (ز) ٥٠٨٤٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لَمّا أُخْرِج النبيُّ ﷺ من مكة قال أبو بكر: أخرجوا نبيَّهم، إنا لله وإنا إليه راجعون، ليَهلِكَنَّ القومُ. فنزلت: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q> الآية. وكان ابن عباس يقرؤها: <q>﴿أُذِنَ﴾</q>. قال أبو بكر: فعلمتُ أنه سيكون قتال. قال ابن عباس: وهي أول آية نزلت في القتال{6}. (١٠/٥١٣) ٥٠٨٤٨- عن عروة بن الزبير: أنّ أول آية أنزلت في القتال، حين ابتلى المسلمون بمكة، وسَطَتْ{7} بهم عشائرُهم ليفتنوهم عن الإسلام وأخرجوهم من ديارهم، وتظاهروا عليهم؛ فأنزل الله: <q>﴿أذن للذين يقاتلون﴾</q> الآية، وذلك حين أذن الله لرسوله بالخروج، وأذن لهم بالقتال{8}. (١٠/٥١٣) ٥٠٨٤٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قال: خرج ناس مؤمنون مهاجرين من مكة إلى المدينة، فاتبعهم كفار قريش، فأذن لهم في قتالهم؛ فأنزل الله: <q>﴿أذن للذين يقاتلون﴾</q> الآية. فقاتلوهم{9}٤٤٨٢. (١٠/٥١٣) ٤٤٨٢ انتقد ابنُ عطية (٦/٢٥٣) مستندًا إلى السياق هذا القول الذي قاله مجاهد، فقال: «وما بعد هذه الآية يرد هذا القول، لأن هؤلاء مُنعوا الخروج لا أخرجوا». ٥٠٨٥٠- عن الضحاك بن مزاحم: أنّ الله إنما قال: <q>﴿أذن للذين يقاتلون﴾</q> بالقتال مِن أجل أنّ أصحاب رسول الله ﷺ كانوا استأذنوا رسول الله ﷺ في قتل الكفار إذا آذَوْهم واشْتَدُّوا عليهم بمكة قبل الهجرة، غيلة سِرًّا؛ فأنزل الله في ذلك: <q>﴿إن الله لا يحب كل خوان كفور﴾</q>. فلما هاجر رسول الله ﷺ وأصحابه إلى المدينة أطلق لهم قتلهم وقتالهم، فقال: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q>{10}. (ز) ٥٠٨٥١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q>، قال: هي أول آية أنزلت في القتال، فأذن لهم أن يقاتلوا{11}. (ز) ٥٠٨٥٢- عن محمد ابن شهاب الزهري، قال: كانت أول آية نزلت في القتال: <q>﴿أذن للذين يقاتلون﴾</q> الآية{12}. (١٠/٥١٣) ٥٠٨٥٣- عن إسماعيل السُّدِّيّ -من طريق إسماعيل بن أبي خالد- قال: أول آية أنزلت في القتال: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q>{13}. (ز) ٥٠٨٥٤- عن سليمان بن مهران الأعمش -من طريق سفيان الثوري- في قوله: <q>﴿أذن للذين يقاتلون﴾</q>، قال: هي أول آية نزلت في القتال{14}. (ز) <q>﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</q> - تفسير الآية ٥٠٨٥٥- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿أذن للذين يقاتلون بأنهم ظلموا وإن الله على نصرهم لقدير﴾</q>: يعني: محمدًا وأصحابه، إذ أخرجوا من مكة إلى المدينة؛ يقول الله: <q>﴿وإن الله على نصرهم لقدير﴾</q>. وقد فعل{15}. (ز) ٥٠٨٥٦- عن سعيد بن جبير، في قوله: <q>﴿أذن للذين يقاتلون﴾</q>، قال: النبي ﷺ وأصحابه، <q>﴿بأنهم ظلموا﴾</q> يعني: ظلمهم أهل مكة حين أخرجوهم من ديارهم{16}. (١٠/٥١٤) ٥٠٨٥٧- عن مجاهد بن جبر -من طريق حجّاج، عن ابن جُرَيج- قال: أُذِن للمؤمنين بقتال الكفار، فقاتلوهم. قال ابن جُرَيْج: يقول: أول قتال أذن الله به للمؤمنين{17}. (ز) ٥٠٨٥٨- قال قتادة بن دعامة: أذن لهم بالقتال بعد ما أخرجهم المشركون وشُرِّدوا حتى لحق طوائف منهم بالحبشة{18}. (ز) ٥٠٨٥٩- قال مقاتل بن سليمان: فلمّا قدموا المدينة أذن الله ﷿ للمؤمنين في القتال بعد النهي بمكة، فقال سبحانه: <q>﴿أذن للذين يقاتلون﴾</q> في سبيل الله <q>﴿بأنهم ظلموا﴾</q> ظلمهم كفار مكة، <q>﴿وإن الله على نصرهم لقدير﴾</q> فنصرهم الله تعالى على كفار مكة بعد النهي{19}. (ز) ٥٠٨٦٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أذن للذين يقاتلون﴾</q>، قال: أُذِن لهم في قتالهم بعد ما عُفِي عنهم عشر سنين{20}. (١٠/٥١٣) ٥٠٨٦١- قال يحيى بن سلّام: قوله: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q> أُذِن للذين يقاتلون في سبيل الله بأنهم ظلموا، ظلمهم المشركون، وأخرجوهم من ديارهم، يعني: من مكة ... وكان مَن كان يومئذ بمكة مِن المسلمين قد وضع الله عنهم القتال، فهو قوله: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q>{21}. (ز) <q>﴿أُذِنَ لِلَّذِینَ یُقَـٰتَلُونَ بِأَنَّهُمۡ ظُلِمُوا۟ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصۡرِهِمۡ لَقَدِیرٌ ۝٣٩﴾</q> - آثار متعلقة بالآية ٥٠٨٦٢- عن محمد بن سيرين، قال: أشرف عليهم عثمان مِن القصر، فقال: ائتوني برجلٍ تالٍ كتابَ الله. فأتوه بصَعْصَعَة بن صَوْحان، فتكلم بكلام، فقال: <q>﴿أذن للذين يقاتلون بأنهم ظلموا وان الله على نصرهم لقدير﴾</q>. فقال له عثمان: كذبت، ليست لك، ولا لأصحابك، ولكنها لي ولأصحابي{22}. (١٠/٥١٤) ",footnotes:1:علَّقه يحيى بن سلام ١/٣٨٠. و<q>﴿أُذِنَ﴾</q> بضم الهمزة وكسر الذال، قراءة نافع، وأبو جعفر، وأبو عمرو، ويعقوب، وعاصم، ووجه عن إدريس، وقراءة بقية العشرة والوجه الثاني لإدريس ‹أذِنَ› بفتح الهمزة، وكسر الذال. و<q>﴿يُقاتَلُونَ﴾</q> بفتح التاء قراءة متواترة، قرأ بها نافع، وابن عامر، وحفص، وأبو جعفر، وقرأ بقية العشرة: ‹يُقاتِلُونَ› بكسر التاء. انظر: النشر ٢/٣٢٦، والإتحاف ص٣٩٩.أخرجه ابن جرير ١٦/٥٧٦. والقراءة شاذة. انظر: المحرر الوجيز ٤/١٢٤.أخرجه ابن أبي داود في المصاحف ١/٤٢٤. والقراءة شاذة. انظر: المحرر الوجيز ٤/١٢٤.أخرجه عبد الرزاق ٢/٣٩.أخرجه النسائي في السنن الكبرى ١٠/١٩٢. قال الحافظ ابن حجر في الفتح ٧/٢٨٠: «إسناده صحيح».أخرجه أحمد ٣/٣٥٨-٣٥٩ (١٨٦٥)، والترمذي ٥/٣٩٠ (٣٤٤٤)، والنسائي ٦/٢ (٣٠٨٥)، وابن حبان ١١/٨ (٤٧١٠)، والحاكم ٢/٧٦ (٢٣٧٦)، ٢/٢٦٩ (٢٩٦٨)، ٢/٤٢٢ (٣٤٦٩)، وعبد الرزاق ٢/٤٠٨ (١٩٣٧)، وابن جرير ١٦/٥٧٣-٥٧٤. قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن القيم في زاد المعاد ٣/٦٤: «إسناده على شرط الصحيحين».أي: قهرتهم وبطشت بهم. انظر: النهاية (سطا).عزاه السيوطي إلى ابن أبي حاتم مرسلًا.أخرجه ابن جرير ١٦/٥٧٥، والبيهقي في الدلائل ٢/٥٧٩ مرسلًا. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. كما أخرجه ابن جرير من طريق ابن جريج بلفظ: ناس من المؤمنين خرجوا مهاجرين من مكة إلى المدينة، وكانوا يمنعون، فأدركهم الكفار، فأذن للمؤمنين بقتال الكفار، فقاتلوهم. وكذا علقه يحيى بن سلام ١/٣٨٠.علقه ابن جرير ١٦/٥٧٦. قال ابن جرير: «من وجه غير ثبت».أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٧٠.عزاه السيوطي إلى عبد الرزاق، وابن المنذر.أخرجه البيهقي في دلائل النبوة ٢/٥٨٠.تفسير الثوري ص٢١٤.أخرجه ابن جرير ١٦/٥٧٣.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٧٦.علقه يحيى بن سلام ١/٣٨٠.تفسير مقاتل بن سليمان ٣/١٢٩.أخرجه ابن جرير ١٦/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٨٠.أخرجه ابن أبي شيبة ١٤/٥٩٤، ١٥/٢٠٣.
22,40," <q>﴿ٱلَّذِینَ أُخۡرِجُوا۟ مِن دِیَـٰرِهِم بِغَیۡرِ حَقٍّ إِلَّاۤ أَن یَقُولُوا۟ رَبُّنَا ٱللَّهُۗ﴾</q> - نزول الآية، وتفسيرها ٥٠٨٦٣- عن عثمان بن عفان، قال: فينا نزلت هذه الآية: <q>﴿الذين أخرجوا من ديارهم بغير حق﴾</q>، والآية بعدها؛ أخرجنا من ديارنا بغير حق، ثم مُكِّنّا في الأرض، فأقمنا الصلاة، وآتينا الزكاة، وأمرنا بالمعروف، ونهينا عن المنكر، فهي لي ولأصحابي{1}. (١٠/٥١٤) ٥٠٨٦٤- عن عبد الله بن عباس: <q>﴿الذين أخرجوا من ديارهم﴾</q> أي: من مكة إلى المدينة، <q>﴿بغير حق﴾</q> يعني: محمدًا ﷺ وأصحابه{2}. (١٠/٥١٤) ٥٠٨٦٥- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿الذين أخرجوا من ديارهم بغير حق﴾</q>: يعني: محمدًا ﷺ وأصحابه، أخرجوا من مكة بغير حق{3}. (ز) ٥٠٨٦٦- قال يحيى بن سلام: قال الحسن البصري: ما سفكوا لهم مِن دم، ولا أخذوا لهم مِن مال، ولا قطعوا لهم مِن رَحِم، وإنما أخرجوهم لأنهم قالوا: ربنا الله، كقوله: <q>﴿وما نقموا منهم إلا أن يؤمنوا بالله العزيز الحميد﴾</q> [البروج:٨]{4}. (ز) ٥٠٨٦٧- قال قتادة بن دعامة: قوله: <q>﴿الذين أخرجوا من ديارهم بغير حق إلا أن يقولوا ربنا الله﴾</q>، لما قال المسلمون: لا إله إلا الله. أنكرها المشركون، وضاقَها{5} إبليس وجنوده{4}. (ز) ٥٠٨٦٨- قال مقاتل بن سليمان: ثم أخبر عن ظُلْم كفار مكة، فقال سبحانه: <q>﴿الذين أخرجوا من ديارهم﴾</q> وذلك أنهم عَذَّبوا منهم طائفة، وآذَوْا بعضَهم بالألْسُن، حتى هربوا من مكة إلى المدينة <q>﴿بغير حق إلا أن يقولوا﴾</q> يقول: لم يخرج كفار مكة المؤمنين من ديارهم، إلا أن يقولوا: <q>﴿ربنا الله﴾</q> فعرَفوه ووَحَّدوه{7}٤٤٨٣. (ز) ٤٤٨٣ ذكر ابنُ كثير (١٠/٧٣) أنّ البعض اسْتَدَلَّ بهذه الآية على مدنية السورة. وذكر ابنُ القيم (٢/٢١٦) أنّ هناك من قال بمكية السورة؛ لأن الإذن بالقتال كان بمكة. وانتقده (٢/٢١٦-٢١٧) مستندًا إلى الواقع، والسياق، وأحوال النزول، فقال: «وهذا غلط لوجوه: أحدها: أن الله لم يأذن بمكة لهم في القتال، ولا كان لهم شوكة يَتَمَكَّنون بها من القتال بمكة. الثاني: أنّ سياق الآية يدُلُّ على أنّ الإذن بعد الهجرة، وإخراجهم من ديارهم، فإنه قال: <q>﴿الذين أخرجوا من ديارهم بغير حق إلا أن يقولوا ربنا الله﴾</q>، وهؤلاء هم المهاجرون. الثالث: قوله تعالى: <q>﴿هذان خصمان اختصموا في ربهم﴾</q> [الحج:١٩] نزلت في الذين تَبارزوا يوم بدر من الفريقين. الرابع: أنه قد خاطبهم في آخرها بقوله: <q>﴿يا أيها الذين آمنوا﴾</q>، والخطاب بذلك كله مدني، فأما الخطاب بـ<q>﴿يا أيها الناس﴾</q> فمشترك. الخامس: أنه أمر فيها بالجهاد الذي يعم الجهاد باليد وغيره، ولا ريب أنّ الأمر بالجهاد المطلق إنما كان بعد الهجرة، فأما جهاد الحجة فأمر به في مكة بقوله: <q>﴿فلا تطع الكافرين وجاهدهم به﴾</q> [الفرقان:٥٢]، أي: بالقرآن جهادًا كبيرًا، فهذه سورة مكية، والجهاد فيها هو التبليغ وجهاد الحجة، وأما الجهاد المأمور به في سورة الحج فيدخل فيه الجهاد بالسيف. السادس: أن الحاكم روى في مستدركه من حديث الأعمش، عن مسلم البطين، عن سعيد بن جبير، عن ابن عباس، قال: لما خرج رسول الله ﷺ من مكة قال أبو بكر: أخرجوا نبيَّهم، إنا لله وإنا إليه راجعون، ليهلكن. فأنزل الله ﷿: <q>﴿أذن للذين يقاتلون بأنهم ظلموا﴾</q>. وهي أول آية نزلت في القتال. وإسناده على شرط الصحيحين. وسياق السورة يدل على أن فيها المكي والمدني؛ فإن قصة إلقاء الشيطان في أمنية الرسول مكية». <q>﴿وَلَوۡلَا دَفۡعُ ٱللَّهِ ٱلنَّاسَ بَعۡضَهُم بِبَعۡضࣲ﴾</q> - قراءات ٥٠٨٦٩- عن عاصم [بن أبي النجود] أنّه قرأ: <q>﴿ولَوْلا دَفْعُ اللَّهِ النّاسَ﴾</q> بغير ألف{8}. (١٠/٥١٥) <q>﴿وَلَوۡلَا دَفۡعُ ٱللَّهِ ٱلنَّاسَ بَعۡضَهُم بِبَعۡضࣲ﴾</q> - نزول الآية، وتفسيرها ٥٠٨٧٠- عن ثابت بن عوسجة الحضرمي، قال: حدثني سبعة وعشرون مِن أصحاب عليٍّ وعبد الله؛ منهم لاحق بن الأقمر، والعيزار بن جرول، وعطية القرظي، أنّ عليًّا قال: إنما نزلت هذه الآية في أصحاب محمد: <q>﴿ولولا دفع الله الناس﴾</q> الآية. قال: لولا دفاع الله بأصحاب محمد عن التابعين لهدمت صوامع{9}. (١٠/٥١٥) ٥٠٨٧١- عن مجاهد بن جبر، في الآية، قال: لولا دفع المشركين بالمسلمين{10}. (١٠/٥١٥) ٥٠٨٧٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في الآية، قال: منعُ بعضهم ببعض في الشهادة وفي الحقِّ، وفيما يكون مثل هذا. يقول: لولا هذا لهلكت هذه الصوامع، وما ذُكِر معها{11}. (١٠/٥١٥) ٥٠٨٧٣- قال قتادة بن دعامة: يبتلى المؤمن بالكافر، ويعافى الكافر بالمؤمن{12}. (ز) ٥٠٨٧٤- قال مقاتل بن سليمان: <q>﴿ولولا دفع الله الناس بعضهم ببعض﴾</q>، يقول: لولا أن يدفع الله المشركين بالمسلمين لغلب المشركون، فقتلوا المسلمين{7}. (ز) ٥٠٨٧٥- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قوله: <q>﴿ولولا دفع الله الناس بعضهم ببعض﴾</q>: دفع المشركين بالمسلمين{14}. (ز) ٥٠٨٧٦- عن عبد الرحمن بن زيد بن أسلم، <q>﴿ولولا دفع الله الناس﴾</q> الآية، قال: لولا القتال والجهاد{15}. (١٠/٥١٥) ٥٠٨٧٧- قال يحيى بن سلّام: قوله: <q>﴿ولولا دفع الله الناس بعضهم ببعض﴾</q> يدفع عن المؤمنين بدينهم، ويدفع عن الكافرين بالمؤمنين{16}٤٤٨٤. (ز) ٤٤٨٤ اختُلِف في معنى قوله: <q>﴿ولَوْلا دَفْعُ اللَّهِ النّاسَ بَعْضَهُمْ بِبَعْضٍ﴾</q> على أقوال: الأول: ولولا دفع الله المشركين بالمسلمين. الثاني: ولولا الجهاد والقتال في سبيل الله. الثالث: ولولا دفع الله بأصحاب رسول الله ﷺ عن التابعين. الرابع: ولولا دفع الله بشهادة الشهود على الحقوق. ورجَّح ابنُ جرير (١٦/٥٧٩-٥٨٠) صحَّةَ جميع ذلك للعموم، فقال: "وأَوْلى الأقوال في ذلك بالصواب أن يُقال: إنّ الله -تعالى ذِكْرُه- أخبر أنه لولا دفاعه الناس بعضهم ببعض لهُدّم ما ذكر، من دفْعه -تعالى ذكره- بعضهم ببعض، وكفه المشركين بالمسلمين عن ذلك، ومنه كفه ببعضهم التظالم، كالسلطان الذي كف به رعيته عن التظالم بينهم، ومنه كفه لمن أجاز شهادته بينهم ببعضهم عن الذهاب بحق من له قِبَله حق، ونحو ذلك، وكل ذلك دفع منه الناس بعضهم عن بعض، لولا ذلك لتظالموا، فهدم القاهرون صوامع المقهورين وبيعهم، وما سمى -جل ثناؤه-. ولم يضع الله تعالى دلالة في عقل على أنه عنى من ذلك بعضًا دون بعض، ولا جاء بأن ذلك كذلك خبر يجب التسليم له، فذلك على الظاهر والعموم على ما قد بينته قبل؛ لعموم ظاهر ذلك جميع ما ذكرنا". وذكر ابنُ عطية (٦/٢٥٤) أنّ الآية تقوية للأمر بالقتال، وذكْر الحجة بالمصلحة فيه، وذكْر أنه متقدم في الأمم، وبه صلحت الشرائع واجتمعت المتعبَّدات، فكأنه قال: أُذن في القتال فليقاتل المؤمنون، ولولا القتال والجهاد لتُغلِّب على الحق في كل أمة. ورجَّح مستندًا إلى السياق أنه القتال والجهاد، وهو القول الثاني الذي قاله ابن زيد، فقال: «هذا أصوب تأويلات الآية». وذكر أنه الأليق بمعنى الآية، ووجَّه الأقوال الأخرى بخروجها مخرج المثال، فقال: «ما قيل بعد من مُثُل الدفاع تبعٌ للجهاد». ونقل عن فرقة أن المعنى: ولولا دفع الله العذاب بدعاء الفضلاء والأخيار ونحوه، وانتقده مستندًا لمخالفته لظاهر الآية، فقال: «وهذا وما شاكله مُفسِد لمعنى الآية، وذلك أنّ الآية تقتضي ولا بُدَّ مدفوعًا مِن الناس ومدفوعًا عنه. فتأمله». <q>﴿لَّهُدِّمَتۡ صَوَ ٰ⁠مِعُ وَبِیَعࣱ وَصَلَوَ ٰ⁠تࣱ وَمَسَـٰجِدُ﴾</q> - قراءات ٥٠٨٧٨- عن عاصم الجحدري أنّه قرأ: (وصُلُوتٌ). قال: الصُّلُوتُ دون الصوامع. قال: وكيف تهدم الصلاة؟!{17}. (١٠/٥١٦) <q>﴿لَّهُدِّمَتۡ صَوَ ٰ⁠مِعُ﴾</q> - تفسير ٥٠٨٧٩- عن عبد الله بن عباس، في قوله: <q>﴿لهدمت صوامع﴾</q> الآية، قال: الصوامع التي تكون فيها الرُّهْبان{18}. (١٠/٥١٦) ٥٠٨٨٠- عن أبي العالية الرِّياحي -من طريق داود- في قوله: <q>﴿لهدمت صوامع﴾</q>، قال: صوامع الرهبان{19}. (١٠/٥١٦) ٥٠٨٨١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في الآية، قال: الصوامع{20}. (١٠/٥١٧) ٥٠٨٨٢- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿لهدمت صوامع﴾</q>، قال: وهي صوامع الصغار{21} يبنونها{22}. (ز) ٥٠٨٨٣- قال الضحاك بن مزاحم، في قوله: <q>﴿لهدمت صوامع﴾</q>: يعني: صوامع الرهبان{23}. (ز) ٥٠٨٨٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿صوامع﴾</q>، قال: هي للصّابئين{24}. (١٠/٥١٧) ٥٠٨٨٥- قال مقاتل بن سليمان: <q>﴿لهدمت﴾</q> يقول: لخربت <q>﴿صوامع﴾</q> الرهبان{7}. (ز) ٥٠٨٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لهدمت صوامع﴾</q>، قال: صوامع الرهبان{22}٤٤٨٥. (ز) ٤٤٨٥ اختُلِف في المراد بالصوامع؛ فقال قوم: هي صوامع الرهبان. وقال آخرون: هي مُصَلّى الصابئين. ورجَّح ابنُ جرير (١٦/٥٨٦) القول الأول الذي قاله مجاهد، وابن زيد، والضحاك، وأبو العالية. وانتقد الثاني مستندًا إلى الأغلب في اللغة، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك؛ لأن ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه مِن القول وإن كان له وجْهٌ فغير مستعمل فيما وجّهه إليه مَن وجَّهه إليه». <q>﴿وَبِیَعࣱ﴾</q> - تفسير ٥٠٨٨٧- عن عبد الله بن عباس، في الآية، قال: والبيع: مساجد اليهود{18}. (١٠/٥١٦) ٥٠٨٨٨- عن عبد الله بن عباس -من طريق العوفي- قال: البيع: بِيَع النصارى{28}. (١٠/٥١٦) ٥٠٨٨٩- عن أبي العالية الرياحي -من طريق داود- قال: البيع: بِيَع النصارى{29}. (١٠/٥١٦) ٥٠٨٩٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وبيع﴾</q>: كنائس{30}. (١٠/٥١٧) ٥٠٨٩١- عن الضحاك بن مزاحم -من طريق عبيد- قال: البيع: بيع النصارى{31}. (١٠/٥١٦) ٥٠٨٩٢- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وبيع﴾</q>: للنصارى{32}. (١٠/٥١٧) ٥٠٨٩٣- قال مقاتل بن سليمان: <q>﴿وبيع﴾</q> النصارى{7}. (ز) ٥٠٨٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وبيع﴾</q>، قال: البيع للكنائس{34}. (ز) ٥٠٨٩٥- قال يحيى بن سلّام: <q>﴿وبيع﴾</q> للنصارى، يعني: كنائس النصارى{12}٤٤٨٦. (ز) ٤٤٨٦ اختُلِف في المراد بالبيع؛ فقال قوم: هي بيع النصارى. وقال آخرون: كنائس اليهود. ورجَّح ابنُ جرير (١٦/٥٨٦) القول الأول الذي قاله قتادة، والضحاك، وأبو العالية، وابن سلام، ومقاتل، وانتقد الثاني مستندًا إلى الأغلب في اللغة، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك لأن ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه من القول -وإن كان له وجهٌ- فغير مستعمل فيما وجَّهه إليه مَن وجهه إليه». وأورد الطبريُّ قول مجاهد تحت القول الثاني، وهو ما انتقده ابنُ عطية (٦/٢٥٥)، فقال: «قال الطبري: وقيل: هي كنائس اليهود. ثم أدخل عن مجاهد ما لا يقتضي ذلك». <q>﴿وَصَلَوَ ٰ⁠تࣱ﴾</q> - تفسير ٥٠٨٩٦- عن عبد الله بن عباس، في قوله: <q>﴿وصلوات﴾</q>: كنائس النصارى{18}. (١٠/٥١٦) ٥٠٨٩٧- عن عبد الله بن عباس -من طريق العوفي- قال: <q>﴿وصلوات﴾</q>: كنائس اليهود{28}. (١٠/٥١٦) ٥٠٨٩٨- عن أبي العالية الرياحي، قال: الصلوات؛ صُلُوتًا: بِيَعٌ صغار للنصارى{38}. (١٠/٥١٦) ٥٠٨٩٩- عن أبي العالية الرِّياحِيِّ -من طريق داود- في قوله: <q>﴿وصلوات﴾</q>، قال: مساجد الصابئين، يسمونها بصلوات{39}. (١٠/٥١٦) ٥٠٩٠٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في <q>﴿وصلوات﴾</q>: ومساجد لأهل الكتاب، ولأهل الإسلام بالطرق{40}. (١٠/٥١٧) ٥٠٩٠١- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وصلوات﴾</q>: كنائس اليهود، ويسمون الكنيسة: صُلُوتا{41}. (١٠/٥١٦) ٥٠٩٠٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وصلوات﴾</q>: كنائس اليهود{42}. (١٠/٥١٧) ٥٠٩٠٣- قال مقاتل بن سليمان: <q>﴿وصلوات﴾</q>، يعني: اليهود{7}. (ز) ٥٠٩٠٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وصلوات﴾</q>، قال: الصلوات: صلوات أهل الإسلام تنقطع، إذا دخل العدوُّ عليهم انقطعت العبادة، والمساجد تهدم، كما صنع بُخْتُنَصَّر{44}. (١٠/٥١٧) ٥٠٩٠٥- قال يحيى بن سلّام: <q>﴿وصلوات﴾</q> الصلوات لليهود، يعني: كنائسهم{45}٤٤٨٧. (ز) ٤٤٨٧ اختُلِف في المراد بقوله: <q>﴿وصَلَواتٌ﴾</q> على أقوال: الأول: كنائس اليهود يسمونها: صُلُوتًا، فعرِّب جمعها، فقيل: صلوات. الثاني: مساجد الصابئين. الثالث: مساجد للمسلمين ولأهل الكتاب بالطُّرق. ورجَّح ابنُ جرير (١٦/٥٨٦) القول الأول الذي قاله ابن عباس، والضحاك، وقتادة، وابن سلام، وانتقد البقية مستندًا إلى الأغلب في اللغة، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك لأنّ ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه مِن القول -وإن كان له وجه- فغير مستعمل فيما وجّهه إليه مَن وجهه إليه». <q>﴿وَمَسَـٰجِدُ﴾</q> - تفسير ٥٠٩٠٦- عن عبد الله بن عباس، في الآية، قال: والمساجد: مساجد المسلمين{18}. (١٠/٥١٦) ٥٠٩٠٧- عن أبي العالية الرِّياحِيِّ -من طريق داود- في قوله: <q>﴿ومساجد﴾</q>: مساجد المسلمين{47}. (١٠/٥١٦) ٥٠٩٠٨- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ومساجد﴾</q>، يقول: في كل هذا يذكر اسم الله كثيرًا، ولم يخص المساجد{41}. (١٠/٥١٧) ٥٠٩٠٩- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ومساجد﴾</q> للمسلمين{49}. (١٠/٥١٧) ٥٠٩١٠- قال مقاتل بن سليمان: <q>﴿ومساجد﴾</q> المسلمين{7}. (ز) ٥٠٩١١- قال يحيى بن سلّام: <q>﴿ومساجد﴾</q> فيها مساجد المسلمين{45}٤٤٨٨. (ز) ٤٤٨٨ اختُلِف في المساجد؛ فقال قوم: مساجد المسلمين. وقال غيرهم: الصوامع والبيع والصلوات. ورجَّح ابنُ جرير (١٦/٥٨٦) مستندًا إلى الأغلب في اللغة القولَ الأول الذي قاله قتادة، فقال: «وإنما قلنا هذا القول أولى بتأويل ذلك لأنّ ذلك هو المعروف في كلام العرب المستفيض فيهم، وما خالفه من القول -وإن كان له وجه- فغير مستعمل فيما وجهه إليه من وجهه إليه». وذكر ابنُ عطية (٦/٢٥٦) أن خُصَيْفًا قال بأن هذه الأسماء قصدها تقسيم متعبدات الأمم. وعلَّق بقوله: «والأظهر أنه قصد بها المبالغة في ذكر المتعبدات». <q>﴿لَّهُدِّمَتۡ صَوَ ٰ⁠مِعُ وَبِیَعࣱ وَصَلَوَ ٰ⁠تࣱ وَمَسَـٰجِدُ﴾</q> - تفسير ٥٠٩١٢- قال الحسن البصري: يدفع عن هدم مصليات أهل الذِّمَّة بالمؤمنين{52}٤٤٨٩. (ز) ٤٤٨٩ رجَّح ابنُ القيم (٢/٢١٨) قول الحسن مستندًا إلى ظاهر لفظ الآية، فقال: «وهذا ظاهر اللفظ، ولا إشكال فيه بوجه، فإنّ الآية دلت على الواقع، لم تدل على كون هذه الأمكنة -غير المساجد- محبوبة مَرْضِيَّة له، لكنه أخبر أنه لولا دفعه الناس بعضهم ببعض لهدمت هذه الأمكنة التي كانت محبوبة له قبل الإسلام، وأقرَّ منها ما أقر بعده، وإن كانت مسخوطة له كما أقر أهل الذمة، وإن كان يبغضهم ويمقتهم ويدفع عنهم بالمسلمين مع بغضه لهم. وهكذا يدفع عن مواضع متعبداتهم بالمسلمين، وإن كان يبغضها، وهو سبحانه يدفع عن متعبداتهم التي أُقِرُّوا عليها شرعًا وقدرًا، فهو يحب الدفع عنها، وإن كان يبغضها، كما يحب الدفع عن أربابها، وإن كان يبغضهم. وهذا القول هو الراجح -إن شاء الله تعالى-، وهو مذهب ابن عباس في الآية». <q>﴿یُذۡكَرُ فِیهَا ٱسۡمُ ٱللَّهِ كَثِیرࣰاۗ﴾</q> - تفسير ٥٠٩١٣- عن الضحاك بن مزاحم، في قوله: <q>﴿يذكر فيها اسم الله كثيرا﴾</q>: يعني: في كل ما ذكر من الصوامع والصلوات والمساجد. يقول: في كل هذا يذكر اسم الله كثيرًا، ولم يَخُصّ المساجد{15}٤٤٩٠. (١٠/٥١٧) ٤٤٩٠ ذكر ابنُ تيمية (٤/٤٣٢) أن الضحاك قال: إن الله يحب أن يذكر اسمه، وإن كان يشرك به. وعلَّق عليه بقوله: «يعني: أن المشرك به خيرٌ مِن المعطل الجاحد الذي لا يذكر اسم الله بحال». ٥٠٩١٤- قال مقاتل بن سليمان: <q>﴿يذكر فيها اسم الله كثيرا﴾</q> كل هؤلاء الملل يذكرون الله كثيرًا في مساجدهم، فدفع الله ﷿ بالمسلمين عنها{7}. (ز) ٥٠٩١٥- قال يحيى بن سلّام: قوله: <q>﴿يذكر فيها اسم الله كثيرا﴾</q>، يعني: المساجد{16}. (ز) <q>﴿وَلَیَنصُرَنَّ ٱللَّهُ مَن یَنصُرُهُۥۤۚ إِنَّ ٱللَّهَ لَقَوِیٌّ عَزِیزٌ ۝٤٠﴾</q> - تفسير ٥٠٩١٦- قال مقاتل بن سليمان: ثم قال ﷾: <q>﴿ولينصرن الله﴾</q> على عَدُوِّه <q>﴿من ينصره﴾</q> يعني: مَن يعينه حتى يُوَحِّد الله ﷿، <q>﴿إن الله لقوي﴾</q> في نصر أوليائه، <q>﴿عزيز﴾</q> يعني: منيع في مُلكه وسلطانه. نظيرها في الحديد [٢٥]: <q>﴿وليعلم الله من ينصره﴾</q>، يعني: مَن يُوَحِّده. وغيرها في الأحزاب، وهود{56}. وهو سبحانه أقوى وأعزُّ مِن خَلْقِه{57}. (ز) ٥٠٩١٧- قال يحيى بن سلّام: قوله: <q>﴿ولينصرن الله من ينصره﴾</q> يعني: مَن ينصر دينه؛ النصر في الدنيا، والحجة في الآخرة، <q>﴿إن الله لقوي عزيز﴾</q> في نِقْمَتِه{16}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه إسحاق البستي في تفسيره ص٣٧٣.علَّقه يحيى بن سلام ١/٣٨٠.في تفسير القرطبي ١٦/١١: ضاق بها. وفي تفسير ابن جرير ٢٠/٤٨٢: فصادمها.علَّقه يحيى بن سلام ١/٣٨٠.تفسير مقاتل بن سليمان ٣/١٢٩.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا نافعًا، وأبا جعفر، ويعقوب؛ فإنهم قرؤوا <q>﴿ولَوْلا دِفاعُ﴾</q> بكسر الدال وفتح الفاء وألف بعدها. انظر: النشر ٢/٣٢٧، والإتحاف ص٣٩٩.أخرجه ابن جرير ١٦/٥٧٨-٥٧٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥٧٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٨١.تفسير مقاتل بن سليمان ٣/١٢٩.أخرجه ابن جرير ١٦/٥٧٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٨١.عزاه السيوطي إلى ابن أبي حاتم. والقراءة شاذة. انظر: مختصر ابن خالويه ص٩٨، والمحتسب ٢/٨٤.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨١. وعلَّقه يحيى بن سلام ١/٣٨١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.هكذا في الأصل.أخرجه ابن جرير ١٦/٥٨١.تفسير البغوي ٥/٣٨٩.أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨١. وعلَّقه يحيى بن سلام ١/٣٨١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.أخرجه ابن جرير ١٦/٥٨١.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٨٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٢.أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.أخرجه ابن جرير ١٦/٥٨٣.علَّقه يحيى بن سلام ١/٣٨١.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٨٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.أخرجه ابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٣٨١.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٨٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٩، وابن جرير ١٦/٥٨٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.علقه يحيى بن سلام ١/٣٨١.تفسير الثعلبي ٧/٢٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.تفسير يحيى بن سلام ١/٣٨١.يشير إلى قوله تعالى في الأحزاب [٢٥]: <q>﴿ورَدَّ اللَّهُ الَّذِينَ كَفَرُوا بِغَيْظِهِمْ لَمْ يَنالُوا خَيْرًا وكَفى اللَّهُ المُؤْمِنِينَ القِتالَ وكانَ اللَّهُ قَوِيًّا عَزِيزًا﴾</q>. وفي هود [٦٦]: <q>﴿فَلَمّا جاءَ أمْرُنا نَجَّيْنا صالِحًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا ومِن خِزْيِ يَوْمِئِذٍ إنَّ رَبَّكَ هُوَ القَوِيُّ العَزِيزُ﴾</q>.تفسير مقاتل بن سليمان ٣/١٣٠.تفسير يحيى بن سلام ١/٣٨١.
22,41," <q>﴿ٱلَّذِینَ إِن مَّكَّنَّـٰهُمۡ فِی ٱلۡأَرۡضِ﴾</q> - تفسير ٥٠٩١٨- عن أبي العالية الرياحي، في قوله: <q>﴿الذين إن مكناهم في الأرض﴾</q>، قال: أصحاب محمد ﷺ{1}. (١٠/٥١٤) ٥٠٩١٩- قال أبو العالية الرِّياحِيِّ: هذه الأُمَّة{2}. (ز) ٥٠٩٢٠- قال عكرمة مولى ابن عباس: أهل الصلوات الخمس{2}. (ز) ٥٠٩٢١- قال الحسن البصري: هم هذه الأُمَّة{4}. (ز) ٥٠٩٢٢- قال قتادة بن دعامة: هم أصحاب محمد ﷺ{4}. (ز) ٥٠٩٢٣- عن محمد بن كعب القرظي، <q>﴿الذين ان مكناهم في الأرض﴾</q>، قال: هم الوُلاة{1}. (١٠/٥١٧) ٥٠٩٢٤- قال مقاتل بن سليمان: <q>﴿الذين إن مكناهم في الأرض﴾</q>، يعني: أرض المدينة، وهم المؤمنون، بعد القهر بمكة{7}. (ز) ٥٠٩٢٥- قال يحيى بن سلّام: قوله: <q>﴿الذين إن مكناهم في الأرض﴾</q>، يعني: أصحاب النبي ﷺ{8}٤٤٩١. (ز) ٤٤٩١ وجَّه ابنُ عطية (٦/٢٥٧) هذا القول على أن <q>﴿الَّذِينَ﴾</q> بدل من قوله: <q>﴿يُقاتَلُونَ﴾</q>، أو على أن <q>﴿الَّذِينَ﴾</q> تابع لـ<q>﴿مَن﴾</q> في قوله: <q>﴿مَن يَنْصُرُهُ﴾</q>. <q>﴿أَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ وَأَمَرُوا۟ بِٱلۡمَعۡرُوفِ وَنَهَوۡا۟ عَنِ ٱلۡمُنكَرِۗ وَلِلَّهِ عَـٰقِبَةُ ٱلۡأُمُورِ ۝٤١﴾</q> - تفسير ٥٠٩٢٦- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- في الآية، قال: كان أمرُهم بالمعروف أنهم دَعَوْا إلى الله وحده وعبادته لا شريك له، وكان نهيهم أنهم نهوا عن عبادة الشيطان وعبادة الأوثان. قال: فمَن دعا إلى الله مِن الناس كلهم فقد أمر بالمعروف، ومن نهى عن عبادة الأوثان وعبادة الشيطان فقد نهى عن المنكر{9}. (١٠/٥١٨) ٥٠٩٢٧- قال حريث بن السائب: قلت للحسن البصري: يا أبا سعيد، الأمر بالمعروف والنهي عن المنكر مِن الذي افترض الله على عباده؟ فقال: نعم. وقرأ: <q>﴿الذين إن مكناهم في الأرض أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف ونهوا عن المنكر﴾</q>{10}. (ز) ٥٠٩٢٨- عن قتادة بن دعامة، في قوله: <q>﴿الذين إن مكناهم في الأرض﴾</q> الآية، قال: هذا شرط الله على هذه الأُمَّة{1}. (١٠/٥١٨) ٥٠٩٢٩- عن زيد بن أسلم، في قوله: <q>﴿الذين إن مكناهم في الأرض﴾</q> قال: أرض المدينة؛ <q>﴿أقاموا الصلاة﴾</q> قال: المكتوبة، <q>﴿وآتوا الزكاة﴾</q> قال: المفروضة، <q>﴿وأمروا بالمعروف﴾</q> قال: بلا إله إلا الله، <q>﴿ونهوا عن المنكر﴾</q> قال: عن الشرك بالله، <q>﴿ولله عاقبة الأمور﴾</q> قال: وعند الله ثواب ما صنعوا{12}. (١٠/٥١٨) ٥٠٩٣٠- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال تعالى: <q>﴿أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف﴾</q> يعني: التوحيد الذي يُعْرَف، <q>﴿ونهوا عن المنكر﴾</q> الذي لا يُعْرَف، وهو الشِّرْك، <q>﴿ولله عاقبة الأمور﴾</q> يعني: عاقبة أمر العباد إليه في الآخرة{7}. (ز) ٥٠٩٣١- قال يحيى بن سلّام: قوله: <q>﴿أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف﴾</q> بعبادة الله، <q>﴿ونهوا عن المنكر﴾</q> عن عبادة الأوثان، <q>﴿ولله عاقبة الأمور﴾</q> إليه تصير الأمور، كقوله: <q>﴿إنا نحن نرث الأرض ومن عليها وإلينا يرجعون﴾</q> [مريم:٤٠]{8}٤٤٩٢. (ز) ٤٤٩٢ ذكر ابنُ عطية (٦/٢٥٧) أنّ فرقة قالت: هذه الآية في الخلفاء الأربعة. ووجَّهه بقوله: «ومعنى هذا التخصيص: أنّ هؤلاء خاصة مُكِّنوا في الأرض من جملة الذين يقاتَلَون المذكورين في صدر الآية». ثم رجَّح العموم، فقال: «والعموم في هذا كله أبين، وبه يتجه الأمر في جميع الناس». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٧/٢٦.تفسير الثعلبي ٧/٢٦.تفسير الثعلبي ٧/٢٦، وتفسير البغوي ٥/٣٩٠.تفسير الثعلبي ٧/٢٦، وتفسير البغوي ٥/٣٩٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٣٠.تفسير يحيى بن سلام ١/٣٨١.أخرجه ابن جرير ١٦/٥٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٣٧٤.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٣٠.تفسير يحيى بن سلام ١/٣٨١.
22,42," <q>﴿وَإِن یُكَذِّبُوكَ فَقَدۡ كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ وَعَادࣱ وَثَمُودُ ۝٤٢ وَقَوۡمُ إِبۡرَ ٰ⁠هِیمَ وَقَوۡمُ لُوطࣲ ۝٤٣﴾</q> - تفسير ٥٠٩٣٢- قال مقاتل بن سليمان: <q>﴿وإن يكذبوك﴾</q> يا محمد، يُعَزِّي نبيَّه ﷺ؛ ليصبر على تكذيبهم إيّاه بالعذاب؛ <q>﴿فقد كذبت قبلهم﴾</q> يعني: قبل أهل مكة <q>﴿قوم نوح وعاد وثمود، وقوم إبراهيم وقوم لوط﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٠.
  22,43,""
22,44," <q>﴿وَأَصۡحَـٰبُ مَدۡیَنَۖ وَكُذِّبَ مُوسَىٰۖ فَأَمۡلَیۡتُ لِلۡكَـٰفِرِینَ ثُمَّ أَخَذۡتُهُمۡۖ فَكَیۡفَ كَانَ نَكِیرِ ۝٤٤﴾</q> - تفسير ٥٠٩٣٣- قال مقاتل بن سليمان: <q>﴿وأصحاب مدين﴾</q> يعني: قوم شعيب ﵇، كل هؤلاء كذبوا رسلهم، <q>﴿وكذب موسى﴾</q> يعني: عُصِيَ موسى ﵇؛ لأنه وُلِد فيهم كما وُلِد محمد ﷺ فيهم، <q>﴿فأمليت﴾</q> يعني: فأَمْهَلْتُ <q>﴿للكافرين﴾</q> فلم أعجل عليهم بالعذاب، <q>﴿ثم أخذتهم﴾</q> بعد الإمهال بالعذاب، <q>﴿فكيف كان نكير﴾</q> يعني: تغييري، أليس وجدوه حَقًّا، فكذلك كذب كفار مكة كما كذبت [مُكَذِّبو] الأمم الخالية{1}. (ز) ٥٠٩٣٤- قال يحيى بن سلّام: قوله: <q>﴿وأصحاب مدين﴾</q> يعني: الذين بعث الله إليهم شعيبًا، قال: <q>﴿وكذب موسى﴾</q> كذبه فرعون، <q>﴿فأمليت للكافرين﴾</q> يعني: جميع هؤلاء، ثم لم أهلكهم عند تكذيبهم رسلهم حتى جاء الوقت الذي أردت أن أهلكهم فيه، <q>﴿ثم أخذتهم﴾</q> بالعذاب حين جاء الوقت، <q>﴿فكيف كان نكير﴾</q> يعني: عقابي، أي: كان شديدًا. يُحَذِّر بذلك المشركين{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٠.تفسير يحيى بن سلام ١/٣٨١.
22,45," <q>﴿فَكَأَیِّن مِّن قَرۡیَةٍ أَهۡلَكۡنَـٰهَا وَهِیَ ظَالِمَةࣱ﴾</q> - تفسير ٥٠٩٣٥- قال مقاتل بن سليمان: <q>﴿فكأين من قرية﴾</q>، يعني: وكم من قرية أهلكناها بالعذاب في الدنيا{1}. (ز) ٥٠٩٣٦- قال يحيى بن سلّام: قوله: <q>﴿فكأين من قرية﴾</q> يعني: كم مِن قرية <q>﴿أهلكناها﴾</q> يعني: أهلكها{2}. (ز) <q>﴿فَهِیَ خَاوِیَةٌ عَلَىٰ عُرُوشِهَا﴾</q> - تفسير ٥٠٩٣٧- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿فهي خاوية على عروشها﴾</q>، قال: خَواؤُها: خرابها. وعروشها: سقوفها{3}. (ز) ٥٠٩٣٨- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿فهي خاوية على عروشها﴾</q>، قال: خَرِبَة ليس فيها أحد{4}. (١٠/٥١٨) ٥٠٩٣٩- قال مقاتل بن سليمان: <q>﴿أهلكناها وهي ظالمة فهي خاوية﴾</q> يعني: خربة <q>﴿على عروشها﴾</q> يعني: ساقطة من فوقها، يعني بالعروش: سقوف البيت، أي: ليس فيها مساكن{1}. (ز) ٥٠٩٤٠- قال يحيى بن سلّام: <q>﴿فهي خاوية﴾</q> فالقرية خاوية <q>﴿على عروشها﴾</q> يعني: على بنيانها. وبعضهم يقول: العروش: السقوف، فصار أعلاها أسفلها{2}. (ز) <q>﴿وَبِئۡرࣲ مُّعَطَّلَةࣲ﴾</q> - قراءات ٥٠٩٤١- عن عمر بن شقيق، قال: سمعت عاصمًا الجحدري يقرأ: (وبِئْرٍ مُّعْطَلَةٍ) مضمومة الميم غير مشددة{7}. (ز) <q>﴿وَبِئۡرࣲ مُّعَطَّلَةࣲ﴾</q> - تفسير الآية ٥٠٩٤٢- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿وبئر معطلة﴾</q>، قال: التي تُرِكَتْ لا أهل لها{8}. (١٠/٥١٨) ٥٠٩٤٣- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وبئر معطلة﴾</q>، قال: لا أهل لها{9}. (ز) ٥٠٩٤٤- عن الضحاك بن مزاحم -من طريق أبي روق-: أنّ هذه البئر كانت بحضرموت في بلدة يقال لها: حاضُوراء، وذلك أنّ أربعة آلاف نفر مِمَّن آمن بصالح نَجَوْا مِن العذاب أتَوْا حضرموت، ومعهم صالح، فلمّا حضروه مات صالح، فسمي: حضرموت؛ لأنّ صالحًا لَمّا حضر مات، فبنوا حاضوراء، وقعدوا على هذه البئر، وأمروا عليهم رجلًا، فأقاموا دهرًا، وتناسلوا حتى كثروا، ثم إنهم عبدوا الأصنام، وكفروا، فأرسل الله إليهم نبيًّا يُقال له: حنظلة بن صفوان، كان حَمّالًا فيهم، فقتلوه في السوق، فأهلكهم الله، وعطلت بئرهم، وخربت قصورهم{10}. (ز) ٥٠٩٤٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿وبئر معطلة﴾</q>، قال: عَطَّلها أهلُها، وتركوها{11}. (١٠/٥١٨) ٥٠٩٤٦- عن عطاء الخراساني -من طريق يونس- في قول الله ﷿: <q>﴿وبئر معطلة﴾</q>، قال: البئر التي قد تُرِكت{12}. (ز) ٥٠٩٤٧- قال مقاتل بن سليمان: <q>﴿وبئر معطلة﴾</q>، يعني: خالية لا تُسْتَعْمَل{1}. (ز) ٥٠٩٤٨- قال يحيى بن سلّام: <q>﴿وبئر معطلة﴾</q> قد باد أهلُها فعُطِّلَت{2}. (ز) <q>﴿وَقَصۡرࣲ مَّشِیدٍ ۝٤٥﴾</q> - تفسير ٥٠٩٤٩- عن عبد الله بن عباس، <q>﴿وقصر مشيد﴾</q>، قال: هو المُجَصَّص{15}. (١٠/٥١٨) ٥٠٩٥٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وقصر مشيد﴾</q>. قال: شِيدَ بالجصِّ والآجُرِّ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت عدي بن زيد وهو يقول: شادَه مرمرًا وجلَّله كِلْسَـ ـًا فللطير في ذُراه وكُورُ؟{16}. (١٠/٥١٨) ٥٠٩٥١- عن سعيد بن جبير -من طريق هلال بن خباب- في قوله: <q>﴿وقصر مشيد﴾</q>، قال: مُجَصَّص{17}. (ز) ٥٠٩٥٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿وقصر مشيد﴾</q>، قال: بالقَصَّة، أو الفضة{18}. (١٠/٥١٩) ٥٠٩٥٣- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وقصر مشيد﴾</q>، قال: طويل{19}. (ز) ٥٠٩٥٤- عن عكرمة مولى ابن عباس -من طريق هلال بن خباب- في قوله: <q>﴿وقصر مشيد﴾</q>، قال: المجصص. والجِصُّ بالمدينة يسمى: الشِّيد{20}. (ز) ٥٠٩٥٥- عن عكرمة مولى ابن عباس -من طريق هلال بن خباب- في قوله ﷿: <q>﴿وقصر مشيد﴾</q>، قال: مُحَصَّنٌ{21}. (ز) ٥٠٩٥٦- عن عطاء [بن أبي رباح] -من طريق ابن جريج- <q>﴿وقصر مشيد﴾</q>، قال: مُجَصَّص{22}. (١٠/٥١٩) ٥٠٩٥٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿وقصر مشيد﴾</q>، قال: شيَّدوه وحصنَّوه، فهلكوا وتركوه{23}. (١٠/٥١٨) ٥٠٩٥٨- قال قتادة بن دعامة، في قوله: <q>﴿وقصر مشيد﴾</q>: رفيع طويل{24}٤٤٩٣. (ز) ٤٤٩٣ علَّق ابنُ عطية (٦/٢٥٩) على هذا القول الذي قاله قتادة، والضحاك، ومقاتل، فقال: «ومعنى الآية يقتضي أنه كان كذلك قبل خرابه». ٥٠٩٥٩- عن عطاء الخراساني -من طريق يونس- في قول الله ﷿: <q>﴿وقصر مشيد﴾</q>، قال: الشديد البناء، وشَهِقٌ{25}. (ز) ٥٠٩٦٠- قال محمد بن السائب الكلبي: المشيد: الحصين{26}. (ز) ٥٠٩٦١- قال مقاتل بن سليمان: <q>﴿وقصر مشيد﴾</q>، يعني: طويلًا في السماء، ليس له أهل{27}. (ز) ٥٠٩٦٢- قال يحيى بن سلّام: <q>﴿وقصر مشيد﴾</q> مبني معطل{2}٤٤٩٤. (ز) ٤٤٩٤ اختُلِف في معنى قوله: <q>﴿وقَصْرٍ مَشِيدٍ﴾</q> على أقوال: الأول: وقصر مجصص. الثاني: وقصر رفيع طويل. الثالث: المشيد: الحصين. ورجَّح ابنُ جرير (١٦/٥٩٤) مستندًا إلى اللغة القول الأول الذي قاله ابن عباس، وعكرمة، ومجاهد، وعطاء، وسعيد بن جبير، فقال: «وذلك أن الشيد في كلام العرب: هو الجصّ بعينه». ثم وجَّه، فقال: «وقد يجوز أن يكون معنيًا بالمشيد: المرفوع بناؤه بالشيد. فيكون الذين قالوا: عني بالمشيد: الطويل؛ نَحَوا بذلك إلى هذا التأويل». وذكر (١٦/٥٩٥) أن بعض أهل العلم بلغات العرب فسر المشيد بمعنى: المزيَّن بالشِّيد من: شِدْتُه أشيده: إذا زيَّنته به. وعلَّق عليه بقوله:«وذلك شبيه بمعنى من قال: مجصص». ورأى ابنُ كثير (١٠/٧٩) تقارب الأقوال، فقال: «وكل هذه الأقوال متقاربة، ولا منافاة بينها، فإنه لم يَحْمِ أهله شدة بنائه ولا ارتفاعه، ولا إحكامه ولا حصانته، عن حلول بأس الله بهم، كما قال تعالى: <q>﴿أيْنَما تَكُونُوا يُدْرِكُكُمُ المَوْتُ ولَوْ كُنْتُمْ فِي بُرُوجٍ مُشَيَّدَةٍ﴾</q> [النساء:٧٨]». ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣١.تفسير يحيى بن سلام ١/٣٨٢.أخرجه ابن جرير ١٦/٥٩٠.أخرجه عبد الرزاق ٢/٤٠، وابن جرير ١٦/٥٩٠. وعلَّقه يحيى بن سلام ١/٣٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/١٣١.تفسير يحيى بن سلام ١/٣٨٢.أخرجه ابن الأعرابي في معجمه ٣/١١٠١ (٢٣٧١). والقراءة شاذة. انظر: مختصر ابن خالويه ص٩٨، والمحتسب ٢/٨٤.أخرجه ابن جرير ١٦/٥٩١، وفيه: «لا أهل لها» من قول غير ابن عباس. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥٩١.تفسير الثعلبي ٧/٢٧، وتفسير البغوي ٥/٣٩٠.أخرجه عبد الرزاق ٢/٤٠، وابن جرير ١٦/٥٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه ص١١٨ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٣١.تفسير يحيى بن سلام ١/٣٨٢.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الطستي -كما في الإتقان ٢/٧٢-.أخرجه ابن جرير ١٦/٥٩٢، وقال: هكذا هو في كتابي: عن سعيد بن جبير. وعلَّق محققوه: وصوابه عن عكرمة.أخرجه ابن جرير ١٦/٥٩١، وعبد بن حميد -كما في تغليق التعليق ٤/٢٦٠- مقتصرًا على لفظ: بالقَصَّة. وفي لفظ عند ابن جرير: بالقصة، يعني: بالجص. وفي تفسير الثعلبي ٧/٢٧: مجصص.أخرجه ابن جرير ١٦/٥٩٤.أخرجه عبد الرزاق ٢/٣٩ مختصرًا، وابن جرير ١٦/٥٩٢.أخرجه سعيد بن منصور في سننه - التفسير ٦/٣٥١ (١٥٠٣).أخرجه عبد الرزاق ٢/٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٤٠. وابن جرير ١٦/٥٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٥/٣٩٠.أخرجه أبو جعفر الرملي في جزئه ص ١١٨ (تفسير عطاء الخراساني).علقه يحيى بن سلام ١/٣٨٢.تفسير مقاتل بن سليمان ٣/١٣١. وفي تفسير الثعلبي ٧/٢٦، وتفسير البغوي ٥/٣٩٠ بنحوه منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ١/٣٨٢.
22,46," <q>﴿أَفَلَمۡ یَسِیرُوا۟ فِی ٱلۡأَرۡضِ فَتَكُونَ لَهُمۡ قُلُوبࣱ یَعۡقِلُونَ بِهَاۤ أَوۡ ءَاذَانࣱ یَسۡمَعُونَ بِهَاۖ﴾</q> - تفسير ٥٠٩٦٣- قال مقاتل بن سليمان: <q>﴿أفلم يسيروا في الأرض﴾</q> يقول: فلو ساروا في الأرض فتَفَكَّروا؛ <q>﴿فتكون لهم قلوب يعقلون بها﴾</q> المواعظ، <q>﴿أو آذان يسمعون بها فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</q>{1}. (ز) ٥٠٩٦٤- قال يحيى بن سلّام: قوله: <q>﴿أفلم يسيروا في الأرض﴾</q> يعني: المشركين؛ <q>﴿فتكون لهم قلوب يعقلون بها﴾</q> أي: لو ساروا فتَفَكَّروا ما نزل بإخوانهم مِن الكفار فيتوبون، لو كانت <q>﴿لهم قلوب يعقلون بها أو آذان يسمعون بها﴾</q>{2}. (ز) <q>﴿فَإِنَّهَا لَا تَعۡمَى ٱلۡأَبۡصَـٰرُ وَلَـٰكِن تَعۡمَى ٱلۡقُلُوبُ ٱلَّتِی فِی ٱلصُّدُورِ ۝٤٦﴾</q> - نزول الآية ٥٠٩٦٥- قال عبد الله بن عباس= (ز) ٥٠٩٦٦- ومقاتل: لَمّا نزل: <q>﴿ومن كان في هذه أعمى فهو في الآخرة أعمى﴾</q>، جاء ابن أم مكتوم النبيَّ ﷺ باكيًا، فقال: يا رسول الله، أنا في الدنيا أعمى، أفأكون في الآخرة أعمى؟ فأنزل الله ﷾ هذه الآية{3}. (ز) ٥٠٩٦٧- عن قتادة بن دعامة، في قوله: <q>﴿فإنها لا تعمى الأبصار﴾</q>، قال: ذُكِر لنا: أنّها نزلت في عبد الله بن زائدة. يعني: ابن أم مكتوم{4}. (١٠/٥١٩) <q>﴿فَإِنَّهَا لَا تَعۡمَى ٱلۡأَبۡصَـٰرُ وَلَـٰكِن تَعۡمَى ٱلۡقُلُوبُ ٱلَّتِی فِی ٱلصُّدُورِ ۝٤٦﴾</q> - تفسير الآية ٥٠٩٦٨- عن مجاهد بن جبر -من طريق أبي بكر- قال: لكل عين -يعني: لكل نفس- أربع أعين: عينان في رأسه لدنياه، وعينان في قلبه لآخرته، فإن عَمِيَتْ عينا رأسه وأبصرت عينا قلبه لم يضره عماه شيئًا، وإن أبصرت عينا رأسه وعميت عينا قلبه لم ينفعه شيئًا، قال الله: <q>﴿فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</q>{5}. (ز) ٥٠٩٦٩- عن قتادة بن دعامة، في قوله: <q>﴿فإنها لا تعمى الأبصار﴾</q>، قال: أما هذه الأبصار التي في الرؤوس فإنها جعلها الله منفعة وبُلْغَة، وأمّا البصر النافع فهو في القلب{6}. (١٠/٥١٩) ٥٠٩٧٠- قال يحيى بن سلّام: قال: <q>﴿فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور﴾</q>، إنما أُتُوا مِن قِبَل قلوبهم، ولو أنّ رجلًا كان أعمى بعد أن يكون مؤمنًا لم يضره شيئًا، وكان قلبه بصيرًا{2}. (ز) <q>﴿فَإِنَّهَا لَا تَعۡمَى ٱلۡأَبۡصَـٰرُ وَلَـٰكِن تَعۡمَى ٱلۡقُلُوبُ ٱلَّتِی فِی ٱلصُّدُورِ ۝٤٦﴾</q> - آثار متعلقة بالآية ٥٠٩٧١- عن عبد الله بن جراد، قال: قال رسول الله ﷺ: «ليس العمى مَن يَعْمى بصرُه، ولكن العمى مَن تعمى بصيرته»{8}. (١٠/٥٢٠) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣١.تفسير يحيى بن سلام ١/٣٨٢.أورده الثعلبيُّ ٧/٢٧.علقه يحيى بن سلام ١/٣٨٢، وعزاه السيوطي إلى ابن أبي حاتم، وهو مرسل.أخرجه يحيى بن سلام ١/٣٨٢.علَّقه يحيى بن سلام ١/٣٨٢، وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٨٢.أخرجه البيهقي في شعب الإيمان ٢/٤٩٩-٥٠٠ (١٣٠٩)، والخطيب في الزهد والرقائق ص٩٨-٩٩ (٦٨). قال المناوي في فيض القدير ٥/٣٥٥ (٧٥٦٩): «فيه يعلى بن الأشدق، أورده الذهبي في الضعفاء، وقال: قال البخاري: لا يكتب حديثه». وقال في التيسير ٢/٣٢٠: «وإسناده ضعيف». وقال الألباني في الضعيفة ٩/٣٧٠ (٤٣٨٢): «ضعيف جدًّا».
