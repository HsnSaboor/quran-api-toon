quran[11]{c,v,t}:
  27,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَرۡسَلۡنَاۤ إِلَىٰ ثَمُودَ أَخَاهُمۡ صَـٰلِحًا أَنِ ٱعۡبُدُوا۟ ٱللَّهَ فَإِذَا هُمۡ فَرِیقَانِ یَخۡتَصِمُونَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فإذا هم فريقان يختصمون﴾</span>، قال: مؤمن وكافر؛ قولهم: صالح مرسل من ربه. وقولهم: ليس بمرسل. ويعني بقوله: <span class="qpc-hafs">﴿يختصمون﴾</span>: يختلفون{1}. (١١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فإذا هم فريقان يختصمون﴾</span>، قال: إذا القوم بين مُصَدِّق ومُكَذِّب؛ مُصَدِّق بالحق ونازل عنده، ومُكَذِّب بالحق تاركه، في ذلك كانت خصومة القوم{2}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أن اعبدوا الله﴾</span>، يعني: وحِّدوا الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد أرسلنا إلى ثمود أخاهم صالحا أن اعبدوا الله﴾</span> يعني: وحِّدوا الله، <span class="qpc-hafs">﴿فإذا هم فريقان يختصمون﴾</span> مؤمنين وكافرين، وكانت خصومتهم الآية التي في الأعراف [٧٥]: <span class="qpc-hafs">﴿قال الملأ الذين استكبروا من قومه للذين استضعفوا لمن آمن منهم أتعلمون أن صالحا مرسل من ربه قالوا إنا بما أرسل به مؤمنون، قال الذين استكبروا إنا بالذي آمنتم به كافرون، فعقروا الناقة...﴾</span>. ووعدهم صالح العذاب، فقالوا: <span class="qpc-hafs">﴿يا صالح ائتنا بما تعدنا إن كنت من المرسلين﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله ﷿: <span class="qpc-hafs">﴿ولقد أرسلنا إلى ثمود أخاهم صالحا﴾</span>: كان أخاهم في النسب، وليس بأخيهم في الدين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٨٦، وإسحاق البستي في تفسيره ص٢٣ من طريق ابن جريج بلفظ: مؤمن وكافر، وابن أبي حاتم ٩/٢٨٩٨. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|2:أخرجه يحيى بن سلام ٢/٥٥٠، وابن أبي حاتم ٩/٢٨٩٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|3:علَّقه يحيى بن سلام ٢/٥٥٠.|4:تفسير مقاتل بن سليمان ٣/٣١٠. وفي تفسير الثعلبي ٧/٢١٥ بنحوه منسوبًا إلى مقاتل دون تعيينه.|5:تفسير يحيى بن سلام ٢/٥٥٠.
  27,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ لِمَ تَسۡتَعۡجِلُونَ بِٱلسَّیِّئَةِ قَبۡلَ ٱلۡحَسَنَةِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لم تستعجلون بالسيئة﴾</span> قال: العذاب <span class="qpc-hafs">﴿قبل الحسنة﴾</span> قال: الرحمة{1}. (١١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بالسيئة﴾</span> يعني: العذاب في الدنيا <span class="qpc-hafs">﴿قبل الحسنة﴾</span>، يعني: قبل العافية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدَّ عليهم صالح: <span class="qpc-hafs">﴿قال يا قوم لم تستعجلون بالسيئة قبل الحسنة﴾</span>، يقول: لم تستعجلون بالعذاب قبل العافية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال يا قوم لم تستعجلون بالسيئة قبل الحسنة﴾</span>، والسيئة: العذاب؛ لقولهم: <span class="qpc-hafs">﴿ائتنا بما تعدنا إن كنت من المرسلين﴾</span> [الأعراف:٧٧]، والحسنة: الرحمة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَوۡلَا تَسۡتَغۡفِرُونَ ٱللَّهَ لَعَلَّكُمۡ تُرۡحَمُونَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٥٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿لعلكم ترحمون﴾</span>: كي ترحموا، ولا تُعَذَّبوا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لولا تستغفرون الله﴾</span>، قال: فهَلّا تستغفرون الله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لولا﴾</span> يعني: هَلّا <span class="qpc-hafs">﴿تستغفرون الله﴾</span> مِن الشرك؛ <span class="qpc-hafs">﴿لعلكم﴾</span> يعني: لكي <span class="qpc-hafs">﴿ترحمون﴾</span> فلا تُعَذَّبوا في الدنيا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٥٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لولا﴾</span> هلّا <span class="qpc-hafs">﴿تستغفرون الله﴾</span> مِن شِرككم{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٨٦، وابن أبي حاتم ٩/٢٨٩٨. وعلقه يحيى بن سلام ٢/٥٥٠. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر. وأخرجه أيضًا ابن جرير ١٨/٨٦، وإسحاق البستي في تفسيره ص٢٣-٢٤، وابن أبي حاتم ٩/٢٨٩٨ من طريق ابن جريج بلفظ: <span class="qpc-hafs">﴿الحسنة﴾</span>: العافية.|2:علَّقه يحيى بن سلام ٢/٥٥٠.|3:تفسير مقاتل بن سليمان ٣/٣١٠.|4:تفسير يحيى بن سلام ٢/٥٥٠.|5:أخرجه ابن أبي حاتم ٩/٢٨٩٩.|6:أخرجه ابن أبي حاتم ٩/٢٨٩٩.|7:تفسير مقاتل بن سليمان ٣/٣١١.|8:تفسير يحيى بن سلام ٢/٥٥٠.
  27,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ ٱطَّیَّرۡنَا بِكَ وَبِمَن مَّعَكَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- وفي قوله: <span class="qpc-hafs">﴿قالوا اطيرنا بك﴾</span>، قال: تشاءَمْنا{1}. (١١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٥٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كان قد أصابهم جوعٌ، فقالوا: بشُؤْمك وبشُؤْم الذين معك أصابنا هذا. وهي الطِّيَرَة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالوا اطيرنا بك﴾</span>، قال: قالوا: ما أصبنا مِن شَرٍّ فإنما هو من قِبلك، ومِن قِبَلِ مَن معك{3}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فـ<span class="qpc-hafs">﴿قالوا يا صالح اطيرنا﴾</span> يعني: تشاءمنا <span class="qpc-hafs">﴿بك وبمن معك﴾</span> على دينك. وذلك أنّه قحط المطر عنهم وجاعوا، فقالوا: أصابنا هذا الشر مِن شُؤمك وشؤم أصحابك{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ طَـٰۤىِٕرُكُمۡ عِندَ ٱللَّهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿طائركم﴾</span>، قال: مصائبكم{5}<span class=comment-ref>٤٨٨٥</span>. (١١/٣٨٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٨٥</span> لم يذكر <u>ابنُ جرير</u> (١٨/٨٨) غير قول ابن عباس من طريق علي.</div></p><p><div></p><p><p><span class="item-no">٥٧٥٥٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: الشؤم أتاكم مِن عند الله لكفركم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿قال طائركم عند الله﴾</span>، يقول: علم أعمالكم عند الله{7}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فـ<span class="qpc-hafs">﴿قال﴾</span> لهم ﵇: <span class="qpc-hafs">﴿إنما طائركم عند الله﴾</span> يقول: الذي أصابكم هو مكتوب في أعناقكم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلۡ أَنتُمۡ قَوۡمࣱ تُفۡتَنُونَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٦٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿بل أنتم قوم تفتنون﴾</span>: تُخْتَبرون بالخير والشر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بل أنتم قوم تفتنون﴾</span>، قال: تُبْتَلون بطاعة الله ومعصيته{10}<span class=comment-ref>٤٨٨٦</span>. (١١/٣٨٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٨٦</span> ذكر <u>ابنُ كثير</u> (١٠/٤١٤-٤١٥) قول قتادة، ثم أردف <span class="comment-type-4">معلقًا</span>: «والظاهر أن المراد بقوله: <span class="qpc-hafs">﴿تفتنون﴾</span>: تستدرجون فيما أنتم فيه من الضلال».</div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٤<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿بل أنتم قوم تفتنون﴾</span>: تُعَذَّبون بذنوبكم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: تفتنون حتى تجهلوا أنه مِن عند الله ﷾{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بل أنتم قوم تفتنون﴾</span>، يعني: تبتلون، وإنما ابتُلِيتُم بذنوبكم{4}<span class=comment-ref>٤٨٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٨٧</span> قال <u>ابنُ عطية</u> (٦/٥٤٥): «وإنما أنتم قوم تختبرون، وهذا أحد وجوه الفتنة. و<b>يحتمل</b> أن يريد: بل أنتم قوم تولعون بشهواتكم. وهذا معنًى قد تُعُورِف استعمال لفظ الفتنة فيه، ومنه قولك: فتن فلان بفلان. وشاهد ذلك كثير».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٩٩. وعزاه السيوطي إلى ابن جرير موصولًا مع الأثر السابق. وعزاه أيضًا إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|2:علَّقه يحيى بن سلام ٢/٥٥١.|3:أخرجه ابن أبي حاتم ٩/٢٨٩٩. وعلقه يحيى بن سلام ٢/٥٥١. وعزاه السيوطي إلى عبد الرزاق موصولًا بما بعده، وعزاه أيضًا إلى عبد بن حميد، وابن المنذر.|4:تفسير مقاتل بن سليمان ٣/٣١١.|5:أخرجه ابن جرير ١٨/٨٨، وابن أبي حاتم ٩/٢٨٩٩. وعلقه البخاري ٤/١٨٠٦. وعزاه السيوطي إلى ابن المنذر.|6:تفسير البغوي ٦/١٦٩.|7:أخرجه عبد الرزاق ٢/٨٢-٨٣، وابن أبي حاتم ٩/٢٨٩٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن جرير ١٨/٨٨ من طريق معمر بلفظ: علمكم عند الله، وأخرجه ابن أبي حاتم ٩/٢٨٩٩ من طريق سعيد بلفظ: عملكم عند الله. وكذا علَّقه يحيى بن سلام ٢/٥٥١.|8:تفسير مقاتل بن سليمان ٣/٣١١.|9:تفسير الثعلبي ٧/٢١٦، وتفسير البغوي ٦/١٦٩.|10:أخرجه ابن أبي حاتم ٩/٢٨٩٩. وعلَّقه يحيى بن سلام ٢/٥٥١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|11:تفسير الثعلبي ٧/٢١٦، وتفسير البغوي ٦/١٦٩.|12:تفسير الثعلبي ٧/٢١٦.|13:تفسير مقاتل بن سليمان ٣/٣١١.
  27,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَانَ فِی ٱلۡمَدِینَةِ تِسۡعَةُ رَهۡطࣲ یُفۡسِدُونَ فِی ٱلۡأَرۡضِ وَلَا یُصۡلِحُونَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط﴾</span>، قال: وهم الذين عَقَروا الناقة{1}. (١١/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك- في قوله: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط﴾</span>، قال: كان أساميهم: رُعمى، ورُعيم، وهُرميٌّ، وهُرَيم، وداب، وصواب، ورئاب، ومِسطح، وقُدار بن سالف عاقر الناقة{2}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط﴾</span>، قال: مِن قوم صالح{3}. (١١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٠<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق يحيى بن ربيعة الصنعاني- <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span>، قال: كانوا يُقرِضون الدراهم{4}<span class=comment-ref>٤٨٨٨</span>. (١١/٣٨٨)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٨٨</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٦/٥٤٥) على قول عطاء، فقال: «وهذا نحو الأثر المروي: قطع الدنانير والدراهم مِن الفساد في الأرض».</div></p><p><div></p><p><p><span class="item-no">٥٧٥٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط﴾</span> مِن قوم صالح{5}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span>، قال: قال صالح لقومه: إنّه سَيُولَد مولود في شهر كذا وكذا، ويكون هلاكُكم على يديه. فَوَلَد فيهم تسعةٌ منهم، فأمرهم صالحٌ أن لا يولَد في ذلك الشهر ولدٌ إلا قُتِل، ففعل ذلك تسعة منهم، وغيَّب واحد منهم ولدَه، فكان ذلك الولد إذا أتت عليه السنة كان كمن أتى عليه ثلاث سنين في سنة، فكان إذا مرَّ على التسعة الذين فعلوا بأولادهم ما فعلوا قالوا: فعل الله بصالح! لو كان ترك لنا أولادَنا كانوا مثل هذا، فجعلوا يتغيَّظون على صالح كلما مرَّ عليهم ذلك الغلام، فقالوا: تعالوا حتى نقتل صالحًا، فاقعدوا. وقال بعضهم لبعض: نُظهِر أنّا نُريد سفرًا، ونتغيب أيامًا، فإذا علم قومنا أنّا قد غبنا جئنا ليلًا حتى نقتل صالحًا في مسجده، ونقتل ولده. حتى أتوا جُرُفًا مِن الأرض، فنزلوا تحته، فألقى الله عليهم ذلك الجبل، فقتلهم، وجلس الغلام الباقي -وقد شبَّ- مع أُناس يشربون شرابًا لهم، فلم يقدروا على ما يمزجون منه شرابهم، وذلك اليوم يوم لبن الناقة، التي تسقيهم فيه، فقال بعضهم لبعض: ما نصنع باللبن؟ وددنا أنّا استرحنا من هذه الناقة، فقال ابن العاشر المولود: أنا أعقرها لكم. فأخذ السيف، وانطلق حتى جلس لها على طريقها، فلمّا نظرت إليه شدَّت عليه، وهرب منها، فقال له أصحابه: اجلس لها خلف شيء. فجلس واستتر، وقال: إذا مرَّت فأعلِموني. فأقبلت حتى إذا انتهت إليه نادَوه، فخرج عليها، فقتلها، فذلك قول الله -جلَّ ذكره-: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكان في المدينة﴾</span> قرية صالح: الحجر <span class="qpc-hafs">﴿تسعة رهط يفسدون في الأرض﴾</span> يعني: يعملون في الأرض بالمعاصي، <span class="qpc-hafs">﴿ولا يصلحون﴾</span> يعني: ولا يطيعون الله ﷿ فيها، منهم: قدار بن سالف بن جدع عاقر الناقة، واسم أمه: قديرة، ومصدع، وداب، ويباب إخوة بني مهرج، وعائذ بن عبيد، وهذيل وذو أعين -وهما أخوان- ابنا عمرو، وهديم، وصواب، فعقروا الناقة ليلة الأربعاء، وأهلكهم الله ﷿ يوم السبت بصيحة جبريل ﵇{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قال التسعة الذين عقروا الناقة: هلُمَّ فلنقتل صالحًا، فإن كان صادقًا -يعني: فيما وعدهم من العذاب بعد الثلاث- عجلناه قبله، وإن كان كاذبًا نكون قد ألحقناه بناقته. فأتوه ليلًا ليبيتوه في أهله، فدمغتهم الملائكة بالحجارة، فلما أبطئوا على أصحابهم أتوا منزل صالح، فوجدوهم مشدوخين قد رُضِخوا بالحجارة، فقالوا لصالح: أنت قتلتهم. ثم همُّوا به، فقامت عشيرته دونه، ولبسوا السلاح، وقالوا لهم: واللهِ، لا تقتلونه أبدًا، وقد وعدكم أنّ العذاب نازل بكم في ثلاث، فإن كان صادقًا لم تزيدوا ربَّكم [إلا]{8} غضبًا، وإن كان كاذبًا فأنتم مِن وراء ما تريدون، انصرفوا عنهم ليلتهم تلك. والنفر الذين رضختهم الملائكة بالحجارة التسعة الذين ذكر الله ﷿ في القرآن، يقول الله: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span>{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٨٩-٩٠، وابن أبي حاتم ٩/٢٩٠٠.|2:أخرجه ابن أبي حاتم ٩/٢٩٠٠.|3:أخرجه ابن جرير ١٨/٨٩، وابن أبي حاتم ٩/٢٨٩٩. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|4:أخرجه عبد الرزاق ٢/٨٣، وإسحاق البستي في تفسيره ص٢٥. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه يحيى بن سلام ٢/٥٥١، وابن أبي حاتم ٩/٢٩٠١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه إسحاق البستي في تفسيره ص٢٤-٢٥.|7:تفسير مقاتل بن سليمان ٣/٣١١.|8:سقطت من المطبوع من تفسير ابن أبي حاتم.|9:أخرجه ابن جرير ١٨/٩٢ مختصرًا، وابن أبي حاتم ٩/٢٩٠٠.
  27,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ تَقَاسَمُوا۟ بِٱللَّهِ لَنُبَیِّتَنَّهُۥ وَأَهۡلَهُۥ ثُمَّ لَنَقُولَنَّ لِوَلِیِّهِۦ مَا شَهِدۡنَا مَهۡلِكَ أَهۡلِهِۦ وَإِنَّا لَصَـٰدِقُونَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿قالُوا تَقاسَمُوا بِاللَّهِ لَنُبَيِّتَنَّهُ وأَهْلَهُ﴾</span>، قال: هم الذين عقروا الناقة، وقالوا حين عقروها: نُبَيِّت صالحًا وأهله فنقتلهم، ثم نقول لأولياء صالح: ما شهدنا من هذا شيئًا، ومالنا به علم. فدمرهم الله أجمعين{1}. (١١/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- وفي قوله: <span class="qpc-hafs">﴿تقاسموا بالله﴾</span>، قال: تحالفوا على هلاكه، فلم يصلوا إليه حتى هلكوا وقومهم أجمعين{2}. (١١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿لنبيتنه وأهله﴾</span>، قال: أهله: أمته الذين على دينه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قالوا تقاسموا بالله لنبيتنه وأهله﴾</span>، قال: توافقوا على أن يأخذوه ليلًا فيقتلوه. قال: ذُكِر لنا: أنّهم بينما هم معانيق إلى صالح -يعني: مسرعين- ليقتلوه؛ بعث الله عليهم صخرةً، فأهْمَدتْهُم{4}، <span class="qpc-hafs">﴿ثم لنقولن لوليه﴾</span> يعنون: رهط صالح{5}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا تقاسموا بالله﴾</span> يعني: تحالفوا بالله ﷿ <span class="qpc-hafs">﴿لنبيتنه وأهله﴾</span> ليلًا بالقتل، يعني: صالحًا وأهله، <span class="qpc-hafs">﴿ثم لنقولن لوليه﴾</span> يعني: ذا رَحِم صالح إن سألوا عنه: <span class="qpc-hafs">﴿ما شهدنا مهلك أهله﴾</span> قالوا: ما ندري مَن قتل صالحًا وأهله، ما نعرف الذين قتلوه، <span class="qpc-hafs">﴿وإنا لصادقون﴾</span> فيما نقول{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿قالوا تقاسموا بالله﴾</span>: يقولُه بعضهم لبعض{7}<span class=comment-ref>٤٨٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٨٩</span> ذكر <u>ابنُ عطية</u> (٦/٥٤٥-٥٤٦) في قوله تعالى: <span class="qpc-hafs">﴿تقاسموا﴾</span> احتمالين، فقال: «وقوله: <span class="qpc-hafs">﴿تَقاسَمُوا﴾</span> حكى الطبري أنه يجوز أن يكون فعلًا ماضيًا في موضع الحال، كأنه قال: متقاسمين، أي: متحالفين بالله، وكأن قولهم <span class="qpc-hafs">﴿لَنُبَيِّتَنَّهُ﴾</span> حلفٌ. ويؤيد هذا التأويل أنّ في قراءة عبد الله: (ولا يُصْلِحُونَ * تَقاسَمُوا) بسقوط: <span class="qpc-hafs">﴿قالُوا﴾</span>. <b>ويحتمل</b> -وهو تأويل الجمهور-: أن يكون <span class="qpc-hafs">﴿تَقاسَمُوا﴾</span> فعل أمر، أشار بعضهم على بعض بأن يتحالفوا على هذا الفعل بصالح، فـ<span class="qpc-hafs">﴿تَقاسَمُوا﴾</span> هو قولهم على هذا التأويل، وهذه الألفاظ الدالة على قسم أو حلف تجاوب باللام، وإن لم يتقدم قسم ظاهر؛ فاللام في <span class="qpc-hafs">﴿لَنُبَيِّتَنَّهُ﴾</span> جواب ذلك».</div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ تَقَاسَمُوا۟ بِٱللَّهِ لَنُبَیِّتَنَّهُۥ وَأَهۡلَهُۥ ثُمَّ لَنَقُولَنَّ لِوَلِیِّهِۦ مَا شَهِدۡنَا مَهۡلِكَ أَهۡلِهِۦ وَإِنَّا لَصَـٰدِقُونَ ۝٤٩﴾</span> - آثار متعلقة بالآيات</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٨١<span class="dash">-</span></span> عن جعفر بن سليمان الضبعي، قال: سمعتُ <span class="name-2">مالك بن دينار</span> يقول: تلا هذه الآية: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span>. قال: فكم اليوم في كل قبيلة مِن الذين يفسدون في الأرض ولا يصلحون!{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٨٩-٩٠، وابن أبي حاتم ٩/٢٩٠٠، ٢٩٠٢.|2:أخرجه ابن جرير ١٨/٨٩، وابن أبي حاتم ٩/٢٨٩٩، وأخرجه يحيى بن سلام ٢/٥٥١ من طريق ابن مجاهد مختصرًا. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|3:علَّقه يحيى بن سلام ٢/٥٥١.|4:أهْمدتْهم: أهْلَكتْهُم. النهاية (همد).|5:أخرجه يحيى بن سلام ٢/٥٥١ مختصرًا، وابن أبي حاتم ٩/٢٩٠١-٢٩٠٢، وأخرجه عبد الرزاق ٢/٨٣ من طريق معمر مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٣/٣١١.|7:تفسير يحيى بن سلام ٢/٥٥١.|8:أخرجه ابن أبي حاتم ٩/٢٩٠٠.
  27,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَكَرُوا۟ مَكۡرࣰا وَمَكَرۡنَا مَكۡرࣰا وَهُمۡ لَا یَشۡعُرُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومكروا مكرا﴾</span> قال: مكرهم الذي أرادوا بصالح، <span class="qpc-hafs">﴿ومكرنا مكرا﴾</span> قال: مكر الله الذي مكر بهم، رماهم بصخرة فأهمدتهم{1}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول ﷿: <span class="qpc-hafs">﴿ومكروا مكرا﴾</span> حين أرادوا قتل صالح ﵇ وأهله، يقول الله تعالى: <span class="qpc-hafs">﴿ومكرنا مكرا﴾</span> حين جَثَم الجبلُ عليهم، <span class="qpc-hafs">﴿وهم لا يشعرون﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٠٢، وأخرجه عبد الرزاق ٢/٨٣، وابن جرير ١٨/٩٤ كلاهما من طريق معمر بنحوه. وعلَّقه يحيى بن سلام ٢/٥٥٢. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٣/٣١٢. وفي تفسير الثعلبي ٧/٢١٧، وتفسير البغوي ٦/١٧٠: قال مقاتل: نزلوا في سفح جبل ينظر بعضهم بعضًا ليأتوا دار صالح، فجثم عليهم الجبل فأهلكهم.
  27,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ مَكۡرِهِمۡ أَنَّا دَمَّرۡنَـٰهُمۡ وَقَوۡمَهُمۡ أَجۡمَعِینَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٨٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أرسل اللهُ الملائكةَ تلك الليلة إلى دار صالح يحرسونه، فأتى التسعةُ دار صالح شاهرين سيوفهم، فرمتهم الملائكة بالحجارة مِن حيث يرون الحجارة ولا يرون الملائكة، فقتلهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فانظر كيف كان عاقبة مكرهم﴾</span>، قال: شرٌّ، واللهِ، كان عاقبة مكرهم أن دمرهم الله وقومهم أجمعين، ثم صيرهم إلى النار{2}. (١١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قالوا تقاسموا بالله لنبيتنه وأهله ثم لنقولن﴾</span> إلى قوله: <span class="qpc-hafs">﴿أجمعين﴾</span>، قال: دمرنا التسعة وقومهم أجمعين، <span class="qpc-hafs">﴿فتلك بيوتهم خاوية بما ظلموا﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فانظر﴾</span> يا محمد <span class="qpc-hafs">﴿كيف كان عاقبة مكرهم﴾</span> يعني: عاقبة عملهم وصنيعهم؛ <span class="qpc-hafs">﴿أنا دمرناهم﴾</span> يعني: التسعة، يعني: أهلكناهم بالجبل حين جثم عليهم، <span class="qpc-hafs">﴿و﴾</span>دمرنا <span class="qpc-hafs">﴿قومهم أجمعين﴾</span> بصيحة جبريل ﵇، فلم نُبقِ منهم أحدًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٨<span class="dash">-</span></span> عن عبيد الله بن سعد، عن عمه، عن أبيه، عن <span class="name-3">محمد بن إسحاق</span>، قال: كانوا عقروا الناقة يوم الأربعاء، فقال لهم صالحٌ حين سألوه عن ذلك: تصبحون غدًا يوم مؤنس -يعني: يوم الخميس- وجوهكم مُصْفَرَّة، وتصبحون يوم العروبة -يعني: الجمعة- وجوهكم محمرّة، ثم تصبحون يوم شيبان -يعني: السبت- ووجوهكم مسودّة، ثم يصبحكم العذاب يوم أول -يعني: يوم الأحد-. فلما قال لهم ذلك قال التسعة الذين عقروا الناقة بعضهم لبعض: هلم حتى نقتل صالحًا؛ فإن كان صادقًا عجلنا قتله، وإن كان كاذبًا ألحقناه بناقته. فأتوه يومًا ليبيتوه في أهله، فدمغتهم الملائكة بالحجارة، فلما أبطئوا على أصحابهم أتوا منزل صالح، فوجدوهم مشدخين قد رُضِخوا بالحجارة، فقالوا لصالح: أنت قتلتهم. وهَمُّوا به، فقامت عشيرتُه، وقالوا: واللهِ، لا تصلون إليه، قد وعدكم أن ينزل بكم العذاب، فإن كان صادقًا فلا تزيدون ربكم عصيانًا عليكم، وإن كان كاذبًا فأنتم مِن وراء ما تريدون. فانصرفوا عنه ليلتهم تلك. والنفر التسعة الذين رضختهم الملائكة بالحجارة -فيما يزعمون- الذين ذكرهم الله في القرآن: <span class="qpc-hafs">﴿وكان في المدينة تسعة رهط يفسدون في الأرض ولا يصلحون﴾</span>، وقرأ إلى قوله: <span class="qpc-hafs">﴿فتلك بيوتهم خاوية بما ظلموا إن في ذلك لآية لقوم يعلمون﴾</span>، فأصبحوا مِن تلك الليلة التي انصرفوا عن صالح وجوههم مصفرة، فأيقنوا بالعذاب، وعلموا أنّ صالحًا صدقهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٨٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومكروا مكرا ومكرنا مكرا﴾</span>، قال: احتالوا لأمرهم، واحتال الله لهم، مكروا بصالح مكرًا، ومكرنا بهم مكرًا وهم لا يشعرون بمكرنا، وشعرنا بمكرهم. قالوا: زعم صالح أنه يفرغ منا إلى ثلاث، فنحن نفرغ منه وأهله قبل ذلك. وكان له مسجد في الحِجْر في شِعْبٍ يصلي فيه، فخرجوا إلى كهف، وقالوا: إذا جاء يصلي قتلناه، ثم رجعنا إذا فرغنا منه إلى أهله، ففرغنا منهم. وقرأ قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿قالوا تقاسموا بالله لنبيتنه وأهله، ثم لنقولن لوليه ما شهدنا مهلك أهله، وإنا لصادقون﴾</span>. فبعث الله صخرة من الهضب حيالهم، فخشوا أن تشدخهم، فبادروا الغار، فطبقت الصخرة عليهم فمَ ذلك الغار، فلا يدري قومهم أين هم؟ ولا يدرون ما فعل بقومهم؟ فعذب الله -تبارك وتعالى- هؤلاء هاهنا، وهؤلاء هنا، وأنجى الله صالحًا ومَن معه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فانظر كيف كان عاقبة مكرهم أنا دمرناهم﴾</span> بالصخرة، <span class="qpc-hafs">﴿وقومهم أجمعين﴾</span> بعد ذلك بالصيحة{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ مَكۡرِهِمۡ أَنَّا دَمَّرۡنَـٰهُمۡ وَقَوۡمَهُمۡ أَجۡمَعِینَ ۝٥١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٩١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق شِمْر بن عطية، عن رجل- قال: المكر غدر، والغدر كفر{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/٢١٧، وتفسير البغوي ٦/١٧٠.|2:أخرجه ابن أبي حاتم ٩/٢٩٠٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه إسحاق البستي في تفسيره ص٢٥. وفي تفسير الثعلبي ٧/٢١٧: خرجوا ليأتوا صالحًا، فنزلوا خرقًا من الأرض يتمكنون فيه؛ فانهار عليهم.|4:تفسير مقاتل بن سليمان ٣/٣١٢.|5:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٠ (١٣٦)-.|6:أخرجه ابن جرير ١٨/٩٣، وابن أبي حاتم ٩/٢٩٠٢-٢٩٠٣ من طريق أصبغ.|7:تفسير يحيى بن سلام ٢/٥٥٢.|8:أخرجه ابن جرير ١٨/٩٣.
  27,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتِلۡكَ بُیُوتُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قول الله: <span class="qpc-hafs">﴿فتلك بيوتهم﴾</span>، قال: فتلك منازلهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فتلك بيوتهم﴾</span>، يعني: بالحِجْر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿خَاوِیَةَۢ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قول الله: <span class="qpc-hafs">﴿خاوية﴾</span>، قال: والخاوية: سقوط أعلاها على أسافلها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٩٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿خاوية﴾</span>، قال: خواؤها: خرابها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتلك بيوتهم خاوية﴾</span>، يعني: خربة ليس بها سكان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿خاوية﴾</span> ليس فيها أحد{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِمَا ظَلَمُوۤا۟ۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٥٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قول الله: <span class="qpc-hafs">﴿بما ظلموا﴾</span>، يقول: بما كفروا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٥٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بما ظلموا﴾</span>، يعني: بما أشركوا{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَعۡلَمُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٦٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يعني: أنّ في هلاكهم لعبرة <span class="qpc-hafs">﴿لقوم يعلمون﴾</span> بتوحيد الله ﷿{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٠٣.|2:تفسير يحيى بن سلام ٢/٥٥٢.|3:أخرجه ابن أبي حاتم ٩/٢٩٠٣.|4:أخرجه ابن أبي حاتم ٩/٢٩٠٣.|5:تفسير مقاتل بن سليمان ٣/٣١٢.|6:تفسير يحيى بن سلام ٢/٥٥٢.|7:أخرجه ابن أبي حاتم ٩/٢٩٠٣.|8:تفسير مقاتل بن سليمان ٣/٣١٢.|9:تفسير مقاتل بن سليمان ٣/٣١٢.
  27,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنجَیۡنَا ٱلَّذِینَ ءَامَنُوا۟ وَكَانُوا۟ یَتَّقُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٦٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنجينا الذين آمنوا﴾</span> يعني: الذين صدقوا مِن العذاب، <span class="qpc-hafs">﴿وكانوا يتقون﴾</span> الشرك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٦٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: خرج أول يوم على أيديهم مثلُ الحُمَّصة أحمر، ثم اصْفَرَّ مِن الغد، ثم اسْوَدَّ اليوم الثالث، ثم تفقأت، وصاح جبريلُ ﵇ في خلال ذلك بهم، فخمدوا، وكانت الفرقة المؤمنة الناجية أربعة آلاف، خرج بهم صالح إلى حضرموت، فلما دخلها صالح مات، فسمي: حضرموت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٦٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وأنجينا الذين آمنوا﴾</span> صالحًا والذين آمنوا معه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٢.|2:تفسير الثعلبي ٧/٢١٧، وقال عقبه: قال الضحاك: ثم بنى الأربعة آلاف مدينة يقال لها: حاضورا.|3:تفسير يحيى بن سلام ٢/٥٥٢.
  27,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلُوطًا إِذۡ قَالَ لِقَوۡمِهِۦۤ أَتَأۡتُونَ ٱلۡفَـٰحِشَةَ وَأَنتُمۡ تُبۡصِرُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٦٠٤<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله ﷿: <span class="qpc-hafs">﴿ولوطا إذ قال لقومه أتأتون الفاحشة﴾</span>، يعني: المعصية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٦٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولوطا إذ قال لقومه أتأتون الفاحشة﴾</span>، يعني: المعاصي. يعني بالمعصية: إتيان الرجال شهوة من دون النساء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٦٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأنتم تبصرون﴾</span> أنّها الفاحشة{3}<span class=comment-ref>٤٨٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٩٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٤٧) هذا القول، ثم <span class="comment-type-4">ذكر</span> أنّ فرقة قالت: تُبصِرون بأبصاركم؛ لأنكم تتكشفون بفعل ذلك، ولا يستتر بعضكم من بعض.</div></p></div>",footnotes:1:علَّقه يحيى بن سلام ٢/٥٥٣.|2:تفسير مقاتل بن سليمان ٣/٣١٢-٣١٣.|3:تفسير يحيى بن سلام ٢/٥٥٣.
  27,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَىِٕنَّكُمۡ لَتَأۡتُونَ ٱلرِّجَالَ شَهۡوَةࣰ مِّن دُونِ ٱلنِّسَاۤءِۚ بَلۡ أَنتُمۡ قَوۡمࣱ تَجۡهَلُونَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٦٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بل أنتم﴾</span> يعني: ولكن أنتم <span class="qpc-hafs">﴿قوم تجهلون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٦٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل أنتم قوم تجهلون﴾</span> بل أنتم قوم جاهلون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٢-٣١٣.|2:تفسير يحيى بن سلام ٢/٥٥٣.