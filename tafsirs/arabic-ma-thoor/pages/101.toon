quran[7]{c,v,t}:
  4,141,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یَتَرَبَّصُونَ بِكُمۡ فَإِن كَانَ لَكُمۡ فَتۡحࣱ مِّنَ ٱللَّهِ قَالُوۤا۟ أَلَمۡ نَكُن مَّعَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿الذين يتربصون بكم﴾</span> هم المنافقون، يتربصون بالمؤمنين، <span class="qpc-hafs">﴿فإن كان لكم فتح من الله﴾</span> إن أصاب المسلمون مِن عدوهم غنيمةً قال المنافقون: ألم نكن قد كنا معكم؟ فأعطُونا من الغنيمة مثل ما تأخذون{1}. (٥/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- يعني: قوله: <span class="qpc-hafs">﴿الذين يتربصون بكم، فإن كان لكم فتح من الله قالوا ألم نكن معكم﴾</span>، قال: هم المنافقون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حَجّاج- قوله: <span class="qpc-hafs">﴿فإن كان لكم فتح من الله﴾</span> قال: المنافقون يتربصون بالمسلمين، <span class="qpc-hafs">﴿فإن كان لكم فتح﴾</span> قال: إن أصاب المسلمون من عدوهم غنيمةً قال المنافقون: <span class="qpc-hafs">﴿ألم نكن معكم﴾</span> قد كُنّا معكم؛ فأعطونا غنيمةً مثل ما تأخذون، <span class="qpc-hafs">﴿وإن كان للكافرين نصيب﴾</span> يصيبونه من المسلمين، قال المنافقون للكافرين: <span class="qpc-hafs">﴿ألم نستحوذ عليكم ونمنعكم من المؤمنين﴾</span> قد كُنّا نُثَبِّطهم عنكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ أخبر سبحانه عن المنافقين، فقال ﷿: <span class="qpc-hafs">﴿الذين يتربصون بكم﴾</span> الدوائر، <span class="qpc-hafs">﴿فإن كان لكم﴾</span> معشر المؤمنين <span class="qpc-hafs">﴿فتح من الله﴾</span> يعني: النصر على العَدُوِّ يوم بدر؛ <span class="qpc-hafs">﴿قالوا ألم نكن معكم﴾</span> على عدُوِّكم؛ فأعطُونا من الغنيمة، فلستم أحقَّ بها، فذلك قوله سبحانه في العنكبوت [١٠]: <span class="qpc-hafs">﴿ولئن جاء نصر من ربك ليقولن إنا كنا معكم﴾</span> على عدُوِّكم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن كَانَ لِلۡكَـٰفِرِینَ نَصِیبࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وإن كان للكافرين نصيب﴾</span> يُصِيبونه من المسلمين{1}. (٥/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٢<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span> -من طريق السُّدِّيِّ- قوله: <span class="qpc-hafs">﴿نصيب﴾</span>، يعني: حظًّا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن كان للكافرين نصيب﴾</span>، يعني: دَوْلَة على المؤمنين يوم أحد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حَجّاج- قوله: <span class="qpc-hafs">﴿وإن كان للكافرين نصيب﴾</span> يصيبونه من المسلمين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَلَمۡ نَسۡتَحۡوِذۡ عَلَیۡكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: ... قال المنافقون للكفار: <span class="qpc-hafs">﴿ألم نستحوذ عليكم﴾</span>: ألم نبين لكم أنّا على ما أنتم عليه؟!{9}. (٥/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ونمنعكم من المؤمنين فالله يحكم بينكم يوم القيامة﴾</span>، قال: هم المنافقون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ألم نستحوذ عليكم﴾</span>، قال: نَغْلِبْ عليكم{11}. (٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- ... قال المنافقون للكافرين: <span class="qpc-hafs">﴿ألم نستحوذ عليكم﴾</span>: ألم نبين لكم أنّا معكم على ما أنتم عليه؟!{3}<span class=comment-ref>١٨٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٩١</span> <span class="comment-type-4">رأى</span> <u>ابنُ جرير</u> (٧/٦٠٨) تقارب ما قاله السدي وابن جُرَيْج، فقال: «وهذان القولان متقاربا المعنى، وذلك أنّ مَن تَأَوَّله بمعنى: ألم نُبَيِّن لكم. إنّما أراد -إن شاء الله-: ألم نغلب عليكم بما كان مِنّا من البيان لكم أنّا معكم؟!».</div></p><p><div></p><p><p><span class="item-no">٢٠٧١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> أي: المنافقون للكفار: <span class="qpc-hafs">﴿ألم نستحوذ عليكم﴾</span> يعني: ألم نَحُطَّ بكم مِن ورائكم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَنَمۡنَعۡكُم مِّنَ ٱلۡمُؤۡمِنِینَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: ... قد كُنّا نُثَبِّطهم عنكم{14}. (٥/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونمنعكم من المؤمنين﴾</span>: ونجادل المؤمنين عنكم، فنحبسهم عنكم، ونخبرهم أنّا معكم. قالوا ذلك جُبْنًا وفَرَقًا منهم، قال الله تعالى: <span class="qpc-hafs">﴿فاللَّهُ يَحْكُمُ بَيْنَكُمْ يَوْمَ القِيامَةِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ونمنعكم من المؤمنين﴾</span>، قال: قد كُنّا نُثَبِّطهم عنكم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱللَّهُ یَحۡكُمُ بَیۡنَكُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِۗ وَلَن یَجۡعَلَ ٱللَّهُ لِلۡكَـٰفِرِینَ عَلَى ٱلۡمُؤۡمِنِینَ سَبِیلًا ۝١٤١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، نزلت في عبد الله بن أُبَيٍّ وأصحابه{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱللَّهُ یَحۡكُمُ بَیۡنَكُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِۗ وَلَن یَجۡعَلَ ٱللَّهُ لِلۡكَـٰفِرِینَ عَلَى ٱلۡمُؤۡمِنِینَ سَبِیلًا ۝١٤١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٢٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق يُسَيْع الحضرمي- أنّه قيل له: أرأيتَ هذه الآية: <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، وهم يُقاتِلونا؛ فيظهَرون، ويَقْتُلون؟ فقال: ادنُهْ، ادنُهْ. ثم قال: <span class="qpc-hafs">﴿فالله يحكم بينكم يوم القيامة ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>{18}. (٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٢٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق يُسَيْع الحضرمي- <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، قال: في الآخرة{19}. (٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٢٦<span class="dash">-</span></span> عن يُسَيْع، قال: جاء رجل إلى <span class="name-1">علي بن أبي طالب</span>، فقال: أرأيتَ قول الله تعالى: <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، قال: الكافرُ يقتلُ المؤمنَ، والمؤمنُ يقتل الكافرَ؟ قال عليٌّ: <span class="qpc-hafs">﴿ولن يجعل الله للكافرين﴾</span> يوم القيامة <span class="qpc-hafs">﴿على المؤمنين سبيلا﴾</span>{20}<span class=comment-ref>١٨٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٩٢</span> أفادت الآثارُ أنّ نفي سبيل الكافرين على المؤمنين إنّما يكون يوم القيامة. ونقل <u>ابنُ جرير</u> (٧/٦٠٩) <span class="mustanad">إجماع أهل التأويل</span> على ذلك، <span class="comment-type-4">وعلَّق</span> <u>ابنُ عطية</u> (٣/٤٩) بقوله: «وبهذا قال <span class="mustanad">جميع أهل التأويل</span>».</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ القيم</u> (١/٣٠٣) عمومَ الآية، وأنّه لو حصل السبيلُ للكافرين في الدنيا فإنّه بمعصية المؤمنين؛ فالمعنى عنده: ما داموا مؤمنين. فقال: «فالآية على عمومها وظاهرها، وإنّما المؤمنون تصدُر منهم مِن المعصية والمخالفة التي تُضادُّ الإيمانَ ما يصير به للكافرين عليهم سبيلٌ بحسب تلك المخالفة، فهم الذين تَسَبَّبوا إلى جعل السبيل عليهم، كما تسببوا إليه يومَ أحد بمعصية الرسول ومخالفته، واللهُ سبحانه لم يجعل للشيطان على العبد سلطانًا، حتى جعل له العبد سبيلًا إليه بطاعته والشرك به، فجعل الله حينئذ له عليه تسلُّطًا وقهرًا، فمَن وجد خيرًا فليحمد الله تعالى، ومَن وجد غير ذلك فلا يَلُومَنَّ إلا نفسَه. وبهذا يزول الإشكالُ الذي يُورِدُه كثيرٌ من الناس على قوله تعالى: <span class="qpc-hafs">﴿ولَنْ يَجْعَلَ اللهُ لِلْكافِرِينَ عَلى المُؤْمِنِينَ سَبِيلًا﴾</span>، ويُجِيب عنه كثيرٌ منهم: بأنّه لن يجعل لهم عليهم سبيلًا في الآخرة. ويجيب آخرون: بأنّه لن يجعل لهم عليهم سبيلًا في الحُجَّة».</p><p>وذكر <u>ابنُ كثير</u> (٤/٣١٦) احتمالًا بأن يكون التَّسَلُّطُ في الدنيا، فقال: «ويحتمل أن يكون المراد: <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، أي: في الدنيا، بأن يُسَلَّطوا عليهم استيلاءَ اسْتِئْصالٍ بالكُلِّيَّة، وإن حصل لهم ظَفَرٌ في بعض الأحيان على بعض الناس، فإنّ العاقبة للمتقين في الدنيا والآخرة، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿إنا لننصر رسلنا والذين آمنوا في الحياة الدنيا ويوم يقوم الأشهاد﴾</span> [غافر:٥١]. وعلى هذا فيكون رَدًّا على المنافقين فيما أمَّلوه وتَرَبَّصوه وانتظروه مِن زوال دولة المؤمنين، وفيما سلكوه مِن مصانعتهم الكافرين خوفًا على أنفسهم منهم إذا هم ظهروا على المؤمنين فاستأصلوهم، كما قال تعالى: <span class="qpc-hafs">﴿فترى الذين في قلوبهم مرض يسارعون فيهم﴾</span> إلى قوله: <span class="qpc-hafs">﴿نادمين﴾</span> [المائدة:٥٢]».</div></p><p><div></p><p><p><span class="item-no">٢٠٧٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، قال: ذاك يوم القيامة{21}. (٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span> -من طريق السدي-، مثله{22}. (٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٢٩<span class="dash">-</span></span> وعن <span class="name-2">عطاء الخراساني</span>، نحو ذلك{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: أي: حُجَّة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين﴾</span> يعني: أصحاب محمد ﷺ <span class="qpc-hafs">﴿سبيلا﴾</span> يعني: ظُهورًا عليهم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿سبيلا﴾</span>، قال: حُجَّةً{26}<span class=comment-ref>١٨٩٣</span>. (٥/٨١)</p></p><p></div></p><p><div><span class=comment-ref>١٨٩٣</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (١/٣٠٣) تفسير السبيل بالحجة بقوله: «قيل: بالحجة والبرهان؛ لأنّ حجتهم عند ربهم داحضة».</div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</span>، يعني: حُجَّةً أبدًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير موقوف على ابن جريج كما سيأتي.أخرجه ابن أبي حاتم ٤/١٠٩٤.أخرجه ابن جرير ٧/٦٠٧.تفسير مقاتل بن سليمان ١/٤١٦.عزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير موقوف على ابن جريج كما سيأتي.أخرجه ابن أبي حاتم ٤/١٠٩٤.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن جرير ٧/٦٠٧.عزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير موقوف على ابن جريج.أخرجه ابن أبي حاتم ٤/١٠٩٤.أخرجه ابن جرير ٧/٦٠٧، وابن أبي حاتم ٤/١٠٩٤.أخرجه ابن جرير ٧/٦٠٧.تفسير مقاتل بن سليمان ١/٤١٦.عزاه السيوطي إلى ابن جرير، وابن المنذر. وعندَ ابنِ جرير موقوف على ابن جريج كما سيأتي.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن جرير ٧/٦٠٧.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه عبد الرزاق ١/١٧٥، وابن جرير ٧/٦٠٩-٦١٠، والحاكم ٢/٣٠٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٧/٦١٠.أخرجه ابن أبي حاتم ٤/١٠٩٥.أخرجه ابن جرير ٧/٦١٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦١٠. وعلَّقه ابن أبي حاتم ٤/١٠٩٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.علَّقه ابن أبي حاتم ٤/١٠٩٥.تفسير الثعلبي ٣/٤٠٤، وتفسير البغوي ٢/٣٠١.تفسير الثعلبي ٣/٤٠٤.أخرجه ابن جرير ٧/٦١١، وابن أبي حاتم ٤/١٠٩٥.تفسير مقاتل بن سليمان ١/٤١٦.
  4,142,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُنَـٰفِقِینَ یُخَـٰدِعُونَ ٱللَّهَ وَهُوَ خَـٰدِعُهُمۡ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجّاج- في الآية، قال: نزلت في عبد الله بن أُبَيٍّ، وأبي عامر بن النعمان{1}. (٥/٨١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُنَـٰفِقِینَ یُخَـٰدِعُونَ ٱللَّهَ وَهُوَ خَـٰدِعُهُمۡ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٣٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن حسين- في الآية، قال: يُلْقى على كل مؤمن ومنافق نورٌ يمشون به يوم القيامة، حتى إذا انتَهَوْا إلى الصراط طَفِئ نورُ المنافقين، ومضى المؤمنون بنورهم، فينادونهم: <span class="qpc-hafs">﴿انْظُرُونا نَقْتَبِسْ مِن نُورِكُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿ولكنكم فتنتم أنفسكم﴾</span> [الحديد:١٣-١٤]. قال الحسن: فتلك خديعة الله إياهم{2}. (٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وهو خادعهم﴾</span>، قال: يعطيهم يوم القيامة نورًا يمشون فيه مع المسلمين، كما كانوا معهم في الدنيا، ثُمَّ يسلبهم ذلك النورَ، فيُطْفِئُه، فيقومون في ظُلْمَتِهم{3}. (٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٧<span class="dash">-</span></span> وعن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٨<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، نحوه{4}. (٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٣٩<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج-: وفي المنافقين: <span class="qpc-hafs">﴿يخادعون الله وهو خادعهم﴾</span>. قال: مثل قوله في البقرة [٩]: ‹يُخادِعُونَ اللهَ والَّذِينَ آمَنُوا وما يُخادِعُونَ إلَّآ أنفُسَهُمْ›{5}. قال: وأما قوله: <span class="qpc-hafs">﴿وهو خادعهم﴾</span> فيقول: في النور الذي يُعْطى المنافقون مع المؤمنين، فيُعْطَوْن النورَ، فإذا بلغوا السور، وما ذكر الله من قوله: <span class="qpc-hafs">﴿انظرونا نقتبس من نوركم﴾</span> [الحديد:١٣] قال: قوله: <span class="qpc-hafs">﴿وهو خادعهم﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن المنافقين يخادعون الله وهو خادعهم﴾</span> حين أظهروا الإيمان، وأسَرُّوا التكذيبَ، <span class="qpc-hafs">﴿وهو خادعهم﴾</span> على الصراط في الآخرة حين يُقال لهم: <span class="qpc-hafs">﴿ارجعوا وراءكم فالتمسوا نورا﴾</span> [الحديد:١٣]، فبقوا في الظُّلْمَة، فهذه خدعة الله ﷿ لهم في الآخرة{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا قَامُوۤا۟ إِلَى ٱلصَّلَوٰةِ قَامُوا۟ كُسَالَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سِماك الحنفي- أنّه كان يكره أن يقول الرجل: إنِّي كسلان. ويتأول هذه الآية{8}. (٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ أخبر عن المنافقين، فقال سبحانه: <span class="qpc-hafs">﴿وإذا قاموا إلى الصلاة قاموا كسالى﴾</span>، يعني: المنافقين متثاقلين، لا يرَوْا أنّها حقٌّ عليهم. نظيرها في براءة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُرَاۤءُونَ ٱلنَّاسَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يراءون الناس﴾</span>، قال: واللهِ، لولا الناسُ ما صَلّى المنافقُ، ولا يُصَلِّي إلا رياءً وسُمْعةً{10}. (٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يراءون الناس﴾</span> بالقيام بالنَّهار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإذا قاموا إلى الصلاة قاموا كسالى يراءون الناس﴾</span>، قال: هم المنافقون، لولا الرياءُ ما صَلَّوْا{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَذۡكُرُونَ ٱللَّهَ إِلَّا قَلِیلࣰا ۝١٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٤٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> في قوله: <span class="qpc-hafs">﴿ولا يذكرون الله إلا قليلا﴾</span>: إنّما قال ذلك لأنّهم يفعلونها رياءً وسمعةً، ولو أرادوا بذلك القليلَ وجهَ الله تعالى لكان كثيرًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- <span class="qpc-hafs">﴿ولا يذكرون الله إلا قليلا﴾</span>، قال: إنَّما قَلَّ لأنّه كان لغير الله{14}. (٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- أنّه قرأ هذه: <span class="qpc-hafs">﴿يراءون الناس ولا يذكرون الله إلا قليلا﴾</span>، قال الحسن: فواللهِ، لو كان ذلك القليلُ منهم لله لَقَبِلَه، ولكن كان ذلك القليلُ منهم رياءً{15}<span class=comment-ref>١٨٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٩٤</span> ذكر <u>ابنُ عطية</u> (٣/٥٠) أنّ تقليل الذِّكْرِ في قوله: <span class="qpc-hafs">﴿لا يذكرون الله إلا قليلا﴾</span> يحتمل وجهين: <b>أحدهما</b>: هذا القول. <b>والآخر</b>: «أنّه قليل بالنسبة إلى خوضهم في الباطل، وقولهم الزور والكفر».</div></p><p><div></p><p><p><span class="item-no">٢٠٧٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا يذكرون الله إلا قليلا﴾</span>، قال: إنّما قلَّ ذِكْرُ المنافقِ لأنّ الله لم يقبله، وكُلُّ ما ردَّ اللهُ قليلٌ، وكلُّ ما قَبِلَ اللهُ كثيرٌ{16}. (٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يذكرون الله﴾</span> يعني: في الصلاة <span class="qpc-hafs">﴿إلا قليلا﴾</span> يعني بالقليل: الرياء، ولا يُصَلُّون في السِّرِّ{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَذۡكُرُونَ ٱللَّهَ إِلَّا قَلِیلࣰا ۝١٤٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٥١<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>مَن حَسَّن الصلاةَ حيث يراه الناسُ، وأساءها حيث يخلو؛ فتلك استهانةٌ استهان بها ربَّه</b>»{18}. (٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٢<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>تلك صلاة المنافق، يجلس يَرْقُبُ الشمسَ، حتى إذا كانت بين قَرْنَي شيطانٍ قام فنَقَرَ أربعًا، لا يذكر اللهَ فيها إلا قليلًا</b>»{19}. (٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، قال: لا يَقِلُّ عَمَلٌ مع تقوى، وكيف يَقِلُّ ما يُتَقَبَّلُ؟!{4}. (٥/٨٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٧/٦١١-٦١٢ مُطَوَّلًا.أخرجه ابن جرير ٧/٦١٢، وابن أبي حاتم ٤/١٠٩٥ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦١١، وابن أبي حاتم ٤/١٠٩٥.عزاه السيوطي إلى ابن المنذر.قال محققو تفسير ابن جرير: كذا في النسخ.</p><p>وهي قراءة متواترة، قرأ بها نافع، وابن كثير، وأبو عمرو، وقرأ بقية العشرة: <span class="qpc-hafs">﴿وما يَخْدَعُونَ﴾</span> بفتح الياء، وسكون الخاء، وفتح الدال من غير ألف. انظر: النشر ٢/٢٠٧، والإتحاف ص١٧٠.أخرجه ابن جرير ٧/٦١٠.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن أبي الدنيا في الصمت (٣٦٥)، وابن أبي حاتم ٤/١٠٩٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٤١٦. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿ولا يَأْتُونَ الصَّلاةَ إلّا وهُمْ كُسالى﴾</span> [التوبة:٥٤].أخرجه ابن جرير ٧/٦١٣، وابن أبي حاتم ٤/١٠٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن جرير ٧/٦١٣.تفسير الثعلبي ٣/٤٠٥، وتفسير البغوي ٢/٣٠٢.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٩٨ (٣٦٤٦٦)، وابن جرير ٧/٦١٤، وابن أبي حاتم ٤/١٠٩٦، والبيهقي في شعب الإيمان (٦٨٦٦). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٤/١٠٩٦.أخرجه ابن جرير ٧/٦١٤، وابن أبي حاتم ٤/١٠٩٦.وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه أبو يعلى في مسنده ٩/٥٤ (٥١١٧)، وعبد الرزاق ٢/٣٦٩ (٣٧٣٨)، وابن أبي حاتم ٤/١٠٦١ (٥٩٣٨).</p><p>قال المنذري في الترغيب والترهيب ١/٣٣ (٤٥): «ورواه من هذه الطرق ابن جرير الطبري مرفوعًا أيضًا، وموقوفًا على ابن مسعود، وهو أشبه». وقال الهيثمي في المجمع ١٠/٢٢١ (١٧٦٥٣): «رواه أبو يعلى، وفيه إبراهيم بن مسلم الهجري، وهو ضعيف». وقال المناوي في فيض القدير ٦/٣٧ (٨٣٣٧): «قال -السيوطي- في المهذب مستدرِكًا على البيهقي: قلتُ: فيه إبراهيم الهجري، ضعيف».أخرجه مسلم ١/٤٣٤ (٦٢٢).عزاه السيوطي إلى ابن المنذر.
  4,143,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُّذَبۡذَبِینَ بَیۡنَ ذَ ٰ⁠لِكَ لَاۤ إِلَىٰ هَـٰۤؤُلَاۤءِ وَلَاۤ إِلَىٰ هَـٰۤؤُلَاۤءِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿مذبذبين بين ذلك﴾</span> قال: هم المنافقون، <span class="qpc-hafs">﴿لا إلى هؤلاء﴾</span> يقول: لا إلى أصحاب محمد ﷺ، <span class="qpc-hafs">﴿ولا إلى هؤلاء﴾</span> اليهود{1}. (٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في الآية: <span class="qpc-hafs">﴿مذبذبين بين ذلك لا إلى هؤلاء ولا إلى هؤلاء﴾</span>، يقول: ليسوا بمؤمنين مُخْلِصِين، ولا مُشْرِكين مُصَرِّحِين بالشرك. قال: وذُكِر لنا: أنّ نبي الله ﷺ كان يضرب مثلًا للمؤمن والمنافق والكافر، كمثل رَهْطٍ ثلاثة دفعوا إلى نهر، فوقع المؤمن فقطع، ثم وقع المنافق حتى إذا كاد يصل إلى المؤمن ناداه الكافر: أن هَلُمَّ إلَيَّ؛ فإنِّي أخشى عليك. وناداه المؤمن: أن هَلُمَّ إلَيَّ؛ فإنّ عندي وعندي. يُحْصِي له ما عنده، فما زال المنافقُ يتردد بينهما حتى أتى عليه الماءُ فغرقه، وإنّ المنافق لم يَزَلْ في شَكٍّ وشُبهةٍ حتى أتى عليه الموتُ وهو كذلك{2}. (٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿مذبذبين بين ذلك لا إلى هؤلاء ولا إلى هؤلاء﴾</span>، يقول: ليسوا بمشركين فيُظهِروا الشرك، وليسوا بمؤمنين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مذبذبين بين ذلك﴾</span> يقول: إنّ المنافقين ليسوا مع اليهود فيُظهِرون ولايتهم، ولا مع المؤمنين في الولاية، <span class="qpc-hafs">﴿لا إلى هؤلاء ولا إلى هؤلاء﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قوله: <span class="qpc-hafs">﴿مذبذبين بين ذلك﴾</span>، قال: لم يُخْلِصوا الإيمانَ فيكونوا مع المؤمنين، وليسوا مع أهل الشرك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٥٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿مذبذبين بين ذلك﴾</span>، قال: بين الإسلام والكفر{5}. (٥/٨٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُضۡلِلِ ٱللَّهُ فَلَن تَجِدَ لَهُۥ سَبِیلࣰا ۝١٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿سبيلا﴾</span>، يقول: حُجَّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يضلل الله﴾</span> عن الهُدى <span class="qpc-hafs">﴿فلن تجد له سبيلا﴾</span> إليه{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُضۡلِلِ ٱللَّهُ فَلَن تَجِدَ لَهُۥ سَبِیلࣰا ۝١٤٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٦٢<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «<b>مَثَلُ المنافقِ مَثَلُ الشاةِ العائرةِ بين الغنمين، تَعِيرُ إلى هذه مرة، وإلى هذه مرة، لا تدري أيها تتبع</b>»{9}. (٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٦٣<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «<b>إنّ مَثَلَ المنافق يوم القيامة كالشاةِ بين الغنمين، إن أتت هؤلاء نطحتها، وإن أتت هؤلاء نطحتها</b>»{10}. (٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: مَثَلُ المؤمن والمنافق والكافر مَثَلُ ثلاثة نفرٍ انتَهَوْا إلى وادٍ، فوقع أحدهم فعبر، ثُمَّ وقع أحدهم حتى أتى على نصف الوادي ناداه الذي على شَفِير الوادي: ويلك، أين تذهب؟ إلى الهلكة؟! ارجع، عَودُك على بَدْئِك. وناداه الذي عبر: هَلُمَّ النجاة. فجعل ينظر إلى هذا مرة، وإلى هذا مرة. قال: فجاءه سَيْلٌ فأغرقه، فالذي عبر المؤمن، والذي غرق المنافق، مُذَبْذَبٌ بين ذلك لا إلى هؤلاء ولا إلى هؤلاء، والذي مَكَث الكافر{11}. (٥/٨٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٧/٦١٦-٦١٧، وابن أبي حاتم ٤/١٠٩٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦١٦. وعزاه السيوطي إلى ابن المنذر. وأخرج ابن أبي حاتم ٤/١٠٩٧ أوله. وكذا ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١٦-.أخرجه ابن جرير ٧/٦١٥، وابن أبي حاتم ٤/١٠٩٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن جرير ٧/٦١٧.أخرجه ابن جرير ٧/٦١٧.أخرجه ابن أبي حاتم ٤/١٠٩٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه مسلم ٤/٢١٤٦ (٢٧٨٤)، وابن جرير ٧/٦١٥. وأورده الثعلبي ٣/٤٠٥.أخرجه أحمد ٩/٢٦٢ (٥٣٥٩) من طريق الهذيل بن بلال، عن عبد الله بن عبيد بن عمير، عن أبيه، عن ابن عمر به.</p><p>إسناده ضعيف؛ فيه الهذيل بن بلال المدائني، قال الذهبي عنه في الميزان ٤/٢٩٤: «ضعّفه النسائي، والدارقطني، وقال يحيى: ليس بشيء. وقال ابن حبان: يقلب الأسانيد، ويرفع المراسيل؛ فصار متروكًا». والحديث رواه مسلم في صحيحه بغير هذا اللفظ كما تقدّم.أخرجه ابن أبي حاتم ٤/١٠٩٦.
  4,144,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ ٱلۡكَـٰفِرِینَ أَوۡلِیَاۤءَ مِن دُونِ ٱلۡمُؤۡمِنِینَۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيها الذين آمنوا لا تتخذوا الكافرين أولياء من دون المؤمنين﴾</span> نزلت في المنافقين، منهم: عبدالله بن أُبَيٍّ، ومالك بن دَخْشَم، وذلك أنّ مواليهما مِن اليهود أصبغ ورافع عيَّروهما بالإسلام، وزيَّنوا لهما ترك دينهما وتوليهما اليهود، فصانعا اليهود{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ ٱلۡكَـٰفِرِینَ أَوۡلِیَاۤءَ مِن دُونِ ٱلۡمُؤۡمِنِینَۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيها الذين آمنوا﴾</span> يُرَغِّبهم، <span class="qpc-hafs">﴿لا تتخذوا الكافرين﴾</span> من اليهود <span class="qpc-hafs">﴿أولياء من دون المؤمنين﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَتُرِیدُونَ أَن تَجۡعَلُوا۟ لِلَّهِ عَلَیۡكُمۡ سُلۡطَـٰنࣰا مُّبِینًا ۝١٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كُلُّ سُلطانٍ في القرآن فهو حُجَّةٌ{3}. (٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٦٨<span class="dash">-</span></span> وعن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٦٩<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، مثل ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿سلطانا مبينا﴾</span>، قال: حُجَّةً{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سفيان، عن رجل- قال: ما كان في القرآن من سُلطان فهو حُجَّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أتريدون أن تجعلوا لله عليكم سلطانا مبينا﴾</span>، قال: إنّ لله السلطانَ على خلقه، ولكنه يقول: عذرًا مُبينًا{7}. (٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أتريدون أن تجعلوا لله عليكم سلطانا مبينا﴾</span>، يعني: حُجَّة بيِّنةً يَحْتَجُّ بها عليكم حين تَوَلَّيتم اليهودَ ونصحتموهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٤١٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه عبد الرزاق ١/٣٩٩، وابن أبي حاتم ٤/١٠٩٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١٦-. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.علَّقه ابن أبي حاتم ٤/١٠٩٧.أخرجه ابن جرير ٧/٦١٩.أخرجه ابن جرير ٧/٦١٩.أخرجه ابن جرير ٧/٦١٨، وابن أبي حاتم ٤/١٠٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٧.
  4,145,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُنَـٰفِقِینَ فِی ٱلدَّرۡكِ ٱلۡأَسۡفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمۡ نَصِیرًا ۝١٤٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٧٤<span class="dash">-</span></span> عن <span class="name-2">الأسود</span> أنّه قرأ في النساء: <span class="qpc-hafs">﴿في الدرك الأسفل﴾</span> مخففة= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٥<span class="dash">-</span></span> و<span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٦<span class="dash">-</span></span> و<span class="name-2">يحيى بن وثاب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٧<span class="dash">-</span></span> و<span class="name-2">سليمان</span>، كذلك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٧٨<span class="dash">-</span></span> وعن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿في الدَرْك﴾</span> مخففة{2}<span class=comment-ref>١٨٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٩٥</span> اختلف في قراءة قوله: <span class="qpc-hafs">﴿في الدرك﴾</span> فقرأ قوم بفتح الراء، وقرأ آخرون بتسكينها.</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٧/٦١٩) صحة كلا القراءتين <span class="mustanad">مستندًا إلى استفاضتهما وشهرتهما</span>، فقال: «وهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب؛ لاتفاق معنى ذلك، واستفاضة القراءة بكل واحدة منهما في قراءة الإسلام». ثم قال (٧/٦١٩-٦٢٠): «غير أنِّي رأيتُ أهلَ العلم بالعربية يذكرون أنّ فتح الراء منه في العرب أشهر من تسكينها، وحكموا سماعًا منهم: أعطني درَكًا أصِلُ به حَبْلي. وذلك إذا سأل ما يَصِل به حَبْله الذي قد عجز عن بلوغ الرَّكِيَّة».</p><p>وذكر <u>ابنُ عطية</u> (٣/٥٢) أنّ فتح الراء وتسكينها لغتان.</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُنَـٰفِقِینَ فِی ٱلدَّرۡكِ ٱلۡأَسۡفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمۡ نَصِیرًا ۝١٤٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق خيثمة- <span class="qpc-hafs">﴿إن المنافقين في الدرك الأسفل﴾</span>، قال: في توابيت مِن حديد، مقفلة عليهم. وفي لفظ: مبهمة عليهم. أي: مقفلة لا يهتدون لمكان فتحها{3}. (٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: أيُّ أهل النار أشدُّ عذابًا؟ قال رجل: المنافقون. قال: صدقتَ، فهل تدري كيف يُعَذَّبون؟ قال: لا. قال: يُجْعَلُون في توابيت من حديد تُصْمَد{4} عليهم، ثم يجعلون في الدرك الأسفل في تَنانِيرَ أضيق من زُجٍّ{5}، يُقال له: جُبُّ الحزن. يُطْبَق على أقوام بأعمالهم آخرَ الأبد{6}. (٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق القاسم بن عبد الرحمن- أنّه سُئِل عن المنافقين؟ فقال: يُجعلون في توابيت من نار، فتطبق عليهم في أسفل النار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٢<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي صالح- <span class="qpc-hafs">﴿إن المنافقين في الدرك الأسفل﴾</span>، قال: الدَّرْكُ الأسفلُ: بيوتٌ مِن حديد، لها أبواب تطبق عليها، فيُوقَد من تحتهم ومن فوقهم{8}. (٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٣<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق ذَكْوان- <span class="qpc-hafs">﴿إن المنافقين في الدرك﴾</span>، قال: في توابيت تُرْتَجُ{9} عليهم{10}. (٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿في الدرك الأسفل﴾</span>، يعني: في أسفل النار{11}. (٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٥<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن كثير</span> -من طريق ابن جُرَيْج- قال: سمعتُ أنّ جهنم أدراك، منازل بعضُها فوق بعض{12}. (٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن المنافقين في الدرك الأسفل من النار﴾</span> يعني: الهاوية، <span class="qpc-hafs">﴿ولن تجد لهم نصيرا﴾</span> يعني: مانعًا من العذاب{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُنَـٰفِقِینَ فِی ٱلدَّرۡكِ ٱلۡأَسۡفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمۡ نَصِیرًا ۝١٤٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق أبي المغيرة القوّاس- قال: إنّ أشدَّ الناس عذابًا يوم القيامة ثُلَّة المنافقون{14}، ومَن كفر مِن أصحاب المائدة، وآل فرعون{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: إنّ أسفلَ أهل النار المنافقون، الذين هم في الدرك الأسفل من النار، قال: فيمكثون فيها ما شاء الله أن يمكثوا، ثم يُقال لأهل النار: لِيَلْعَنَ كلُّ قومٍ آلهتَهم التي كانوا يعبدونها من دون الله. فيلعنُ أهلُ النار ما كانوا يعبدون من دون الله، إلا المنافقين يقولون: لا نستطيع أن نلعن؛ إنّه لم يكن لنا إلهٌ إلا الله على ما كان فينا. قال: فما تكون غيرُها حتى تَزْفُرَ بهم جهنم زَفْرَةً، فترمي بهم في ساحلها، فيدخلون الجنة. قال عبد الله بن يزيد المقرئ: إنما نافقوا بأعمالهم، ولم يُنافِقوا بالإخلاص{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٦.</p><p>المقصود بالتخفيف: إسكان الراء. والخلاف بين القرّاء العشرة في هذا الحرف بين فتح الراء وإسكانها، حيث قرأ عاصم، وحمزة، والكسائي، وخلف العاشر بتسكينها، وقرأ بقية العشرة بفتحها. ينظر: النشر ٢/٢٥٣.ذكره عبد بن حميد كما في قطعة من تفسيره ص١٢٦.أخرجه ابن أبي شيبة ١٣/١٥٣-١٥٤، وهناد (٢٢٣)، وابن أبي الدنيا في صفة النار (١٠٤)، وابن جرير ٧/٦٢٠، وابن أبي حاتم ٤/١٠٩٨، والطبراني (٩٠١٥). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تصمد عليهم: تسد عليهم. اللسان (صمد).الزج: نصل السهم. النهاية (زجج).أخرجه ابن أبي الدنيا في صفة النار (١٠٠).أخرجه ابن أبي حاتم ٤/١٠٩٨.أخرجه ابن أبي حاتم ٤/١٠٩٨. وعزاه السيوطي إلى عبد بن حميد.ترج عليهم: تغلق عليهم. النهاية (رتج).أخرجه ابن جرير ٧/٦٢٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦٢٠-٦٢١، وابن أبي حاتم ٤/١٠٩٨.أخرجه ابن جرير ٧/٦٢١. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٤١٧.هكذا في الأصل.تفسير الثعلبي ٣/٤٠٦.أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٦.
  4,146,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلَّذِینَ تَابُوا۟ وَأَصۡلَحُوا۟ وَٱعۡتَصَمُوا۟ بِٱللَّهِ وَأَخۡلَصُوا۟ دِینَهُمۡ لِلَّهِ فَأُو۟لَـٰۤىِٕكَ مَعَ ٱلۡمُؤۡمِنِینَۖ وَسَوۡفَ یُؤۡتِ ٱللَّهُ ٱلۡمُؤۡمِنِینَ أَجۡرًا عَظِیمࣰا ۝١٤٦﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ولَمّا أخبر بمُسْتَقَرِّ المنافقين قال ناسٌ للنبي ﷺ: فقد كان فلانٌ وفلانٌ منافقين، فتابوا منه، فكيف يفعل الله بهم؟ فأنزل الله جل ذكره: <span class="qpc-hafs">﴿إلا الذين تابوا﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلَّذِینَ تَابُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٩٠<span class="dash">-</span></span> قال <span class="name-1">حذيفة بن اليمان</span> -من طريق إبراهيم-: لَيَدْخُلَنَّ الجنةَ قومٌ كانوا منافقين. فقال عبد الله: وما علمُك بذلك؟ فغضب حذيفة، ثم قام فتَنَحّى، فلما تفرَّقوا مَرَّ به علقمةُ، فدعاه، فقال: أما إنّ صاحبك يعلم الذي قلتَ. ثم قرأ: <span class="qpc-hafs">﴿إلا الذين تابوا وأصلحوا واعتصموا بالله وأخلصوا دينهم لله فأولئك مع المؤمنين وسوف يؤت الله المؤمنين أجرا عظيما﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٩١<span class="dash">-</span></span> عن الأسود، قال: جاءنا <span class="name-1">حذيفةُ بن اليمان</span>، فقام على رءوسنا، فقال: لقد نزل النفاق على مَن هو خيرٌ منكم. قلتُ له: أنّى يكون هذا، والله تعالى يقول: <span class="qpc-hafs">﴿إن المنافقين في الدرك الأسفل من النار﴾</span>؟! قال: فلمّا تفرقوا قال: لم يبق غيري، رماني بحصاة فأتيته، فقال: إنهم لما تابوا كانوا خيرًا منكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال في سورة النساء: <span class="qpc-hafs">﴿إن المنافقين في الدرك الأسفل من النار﴾</span>، ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا الذين تابوا وأصلحوا﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلا الذين تابوا﴾</span> من المنافقين{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَصۡلَحُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٩٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿وأصلحوا﴾</span>، يعني: وأصلح العملَ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق شيبان النحوي- <span class="qpc-hafs">﴿وأصلحوا﴾</span>، قال: أصلحوا ما بينهم وبين الله ورسوله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأصلحوا﴾</span> العمل{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱعۡتَصَمُوا۟ بِٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٩٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق سليمان، يعني: ابن عامر- قوله: <span class="qpc-hafs">﴿واعتصموا بالله﴾</span>، قال: الاعتصام هو الثقةُ بالله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٧٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واعتصموا﴾</span> يعني: احْتَرَزُوا <span class="qpc-hafs">﴿بالله﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَخۡلَصُوا۟ دِینَهُمۡ لِلَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٧٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأخلصوا دينهم﴾</span> الإسلام <span class="qpc-hafs">﴿لله﴾</span> ﷿، ولم يخلِطوا بشرك{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَخۡلَصُوا۟ دِینَهُمۡ لِلَّهِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٨٠٠<span class="dash">-</span></span> عن معاذ بن جبل، أنّه قال لرسول الله ﷺ حين بعثه إلى اليمن: أوْصِني. قال: «<b>أخلِص دينَك؛ يَكْفِكَ القليلُ من العمل</b>»{12}. (٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٨٠١<span class="dash">-</span></span> عن أبي فراس -رجل من أسلم-، قال: قال رسول الله ﷺ: «<b>سلُوني عمّا شئتم</b>». فنادى رجلٌ: يا رسول الله، ما الإسلامُ؟ قال: «<b>إقام الصلاة، وإيتاء الزكاة</b>». قال: فما الإيمان؟ قال: «<b>الإخلاص</b>». قال: فما اليقين؟ قال: «<b>التصديق بالقيامة</b>»{13}. (٥/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٨٠٢<span class="dash">-</span></span> عن زيد بن أرقم، قال: قال رسول الله ﷺ: «<b>مَن قال: لا إله إلا الله مُخْلِصًا دخل الجنة</b>». قيل: يا رسول الله، وما إخلاصُها؟ قال: «<b>أن تحجزه عن المحارم</b>»{14}. (٥/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٨٠٣<span class="dash">-</span></span> عن أبي ثُمامَة، قال: قال الحواريُّون لعيسى ﵇: يا روح الله، مَنِ المُخلص لله؟ قال: الذي يعمل لله لا يُحِبُّ أن يَحْمَدَه الناسُ عليه{15}. (٥/٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأُو۟لَـٰۤىِٕكَ مَعَ ٱلۡمُؤۡمِنِینَۖ وَسَوۡفَ یُؤۡتِ ٱللَّهُ ٱلۡمُؤۡمِنِینَ أَجۡرًا عَظِیمࣰا ۝١٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٨٠٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿فأولئك﴾</span> يعني: الذين فعلوا ما ذكر اللهُ في هذه الآية هم الذين صدقوا، قوله: <span class="qpc-hafs">﴿مع المؤمنين﴾</span> يعني: المصدقين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٨٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأولئك مع المؤمنين﴾</span> في الولاية، <span class="qpc-hafs">﴿وسوف يؤت الله المؤمنين أجرا عظيما﴾</span> يعني: جزاءً وافِرًا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن جرير ٧/٦٢٣.أخرجه ابن أبي حاتم ٤/١٠٩٨.أخرجه ابن أبي حاتم ٤/١٠٩٨.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن أبي حاتم ٤/١٠٩٩.أخرجه ابن أبي حاتم ٤/١٠٩٩.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن أبي حاتم ٤/١٠٩٩.تفسير مقاتل بن سليمان ١/٤١٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه الحاكم ٤/٣٤١ (٧٨٤٤)، وابن أبي حاتم ٤/١٠٩٩ (٦١٦٢).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «غير صحيح». وقال البيهقي في الشعب ٩/١٧٥ (٦٤٤٤): «مرسل». وقال أبو عبد الرحمن الحوت الشافعي في أسنى المطالب في أحاديث مختلفة المراتب ص٣٤: «رواه الديلمي بإسناد منقطع كما قال العراقي». وقال الألباني في الضعيفة ٥/١٨٠ (٢١٦٠): «ضعيف».أخرجه البيهقي (٦٨٥٨). وقال المنذري في الترغيب ١/٥٣: «وهو مرسل».أخرجه الطبراني في الكبير ٥/١٩٧ (٥٠٧٤)، وأبونعيم في الحلية ٩/٢٥٤-٢٥٥.</p><p>قال الطبراني في الأوسط ٢/٥٦ (١٢٣٥): «لم يرو هذا الحديثَ عن أبي إسحاق إلا شريك، تفرد به محمد بن عبد الرحمن». وقال العراقي في تخريج الإحياء ص٥٢١: «بإسناد حسن». وقال الهيثمي في المجمع ١/١٨ (١٨): «رواه الطبراني في الأوسط، والكبير ...، وفي إسناده محمد بن عبد الرحمن بن غزوان، وهو وضّاع». وقال الألباني في الضعيفة ١١/٢٤٨ (٥١٤٨): «موضوع».أخرجه ابن أبي شيبة ١٣/١٩٥، وأحمد في الزهد ص٥٥. وعزاه السيوطي إلى الحكيم الترمذي، وابن أبي حاتم.</p><p><b>وقد أورد السيوطي ٥/٨٨-٩٠ عَقِب هذا آثارًا في فضل الإخلاص لله.</b>أخرجه ابن أبي حاتم ٤/١٠٩٩.تفسير مقاتل بن سليمان ١/٤١٧.
  4,147,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّا یَفۡعَلُ ٱللَّهُ بِعَذَابِكُمۡ إِن شَكَرۡتُمۡ وَءَامَنتُمۡۚ وَكَانَ ٱللَّهُ شَاكِرًا عَلِیمࣰا ۝١٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٨٠٦<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span> -من طريق العلاء بن الحارث- قال: أربعٌ مَن كُنَّ فيه كُنَّ له: ... الشكر، والإيمان، والدعاء، والاستغفار؛ قال الله تعالى: <span class="qpc-hafs">﴿ما يفعل الله بعذابكم إن شكرتم وآمنتم﴾</span> [النساء:١٤٧]، وقال: <span class="qpc-hafs">﴿وما كان الله معذبهم وهم يستغفرون﴾</span> [الأنفال:٣٣]، وقال: <span class="qpc-hafs">﴿ما يعبأ بكم ربي لولا دعاؤكم﴾</span> [الفرقان:٧٧]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٨٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ما يفعل الله بعذابكم إن شكرتم﴾</span> الآية، قال: إنّ الله لا يُعَذِّب شاكرًا، ولا مُؤْمِنًا{2}. (٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما يفعل الله بعذابكم إن شكرتم﴾</span> نعمتَه، <span class="qpc-hafs">﴿وآمنتم﴾</span> يعني: صدَّقتم، فإنه لا يعذب شاكرًا ولا مؤمنًا، <span class="qpc-hafs">﴿وكان الله شاكرا عليما﴾</span> بهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو نعيم في حلية الأولياء ٥/١٨١-١٨٢، وابن عساكر في تاريخه ٦٠/٢٢٥.أخرجه ابن أبي حاتم ٤/١١٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٧.