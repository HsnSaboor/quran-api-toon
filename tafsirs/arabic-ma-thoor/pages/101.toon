quran[7]{c,v,t}:
4,141," <q>﴿ٱلَّذِینَ یَتَرَبَّصُونَ بِكُمۡ فَإِن كَانَ لَكُمۡ فَتۡحࣱ مِّنَ ٱللَّهِ قَالُوۤا۟ أَلَمۡ نَكُن مَّعَكُمۡ﴾</q> - تفسير ٢٠٧٠٧- عن مجاهد بن جبر، قال: <q>﴿الذين يتربصون بكم﴾</q> هم المنافقون، يتربصون بالمؤمنين، <q>﴿فإن كان لكم فتح من الله﴾</q> إن أصاب المسلمون مِن عدوهم غنيمةً قال المنافقون: ألم نكن قد كنا معكم؟ فأعطُونا من الغنيمة مثل ما تأخذون{1}. (٥/٧٩) ٢٠٧٠٨- عن قتادة بن دِعامة -من طريق سعيد- يعني: قوله: <q>﴿الذين يتربصون بكم، فإن كان لكم فتح من الله قالوا ألم نكن معكم﴾</q>، قال: هم المنافقون{2}. (ز) ٢٠٧٠٩- عن عبد الملك ابن جُرَيْج -من طريق حَجّاج- قوله: <q>﴿فإن كان لكم فتح من الله﴾</q> قال: المنافقون يتربصون بالمسلمين، <q>﴿فإن كان لكم فتح﴾</q> قال: إن أصاب المسلمون من عدوهم غنيمةً قال المنافقون: <q>﴿ألم نكن معكم﴾</q> قد كُنّا معكم؛ فأعطونا غنيمةً مثل ما تأخذون، <q>﴿وإن كان للكافرين نصيب﴾</q> يصيبونه من المسلمين، قال المنافقون للكافرين: <q>﴿ألم نستحوذ عليكم ونمنعكم من المؤمنين﴾</q> قد كُنّا نُثَبِّطهم عنكم{3}. (ز) ٢٠٧١٠- قال مقاتل بن سليمان: ثُمَّ أخبر سبحانه عن المنافقين، فقال ﷿: <q>﴿الذين يتربصون بكم﴾</q> الدوائر، <q>﴿فإن كان لكم﴾</q> معشر المؤمنين <q>﴿فتح من الله﴾</q> يعني: النصر على العَدُوِّ يوم بدر؛ <q>﴿قالوا ألم نكن معكم﴾</q> على عدُوِّكم؛ فأعطُونا من الغنيمة، فلستم أحقَّ بها، فذلك قوله سبحانه في العنكبوت [١٠]: <q>﴿ولئن جاء نصر من ربك ليقولن إنا كنا معكم﴾</q> على عدُوِّكم{4}. (ز) <q>﴿وَإِن كَانَ لِلۡكَـٰفِرِینَ نَصِیبࣱ﴾</q> - تفسير ٢٠٧١١- عن مجاهد بن جبر: <q>﴿وإن كان للكافرين نصيب﴾</q> يُصِيبونه من المسلمين{1}. (٥/٧٩) ٢٠٧١٢- عن أبي مالك غَزْوان الغِفارِيِّ -من طريق السُّدِّيِّ- قوله: <q>﴿نصيب﴾</q>، يعني: حظًّا{2}. (ز) ٢٠٧١٣- قال مقاتل بن سليمان: <q>﴿وإن كان للكافرين نصيب﴾</q>، يعني: دَوْلَة على المؤمنين يوم أحد{4}. (ز) ٢٠٧١٤- عن عبد الملك ابن جُرَيْج -من طريق حَجّاج- قوله: <q>﴿وإن كان للكافرين نصيب﴾</q> يصيبونه من المسلمين{3}. (ز) <q>﴿قَالُوۤا۟ أَلَمۡ نَسۡتَحۡوِذۡ عَلَیۡكُمۡ﴾</q> - تفسير ٢٠٧١٥- عن مجاهد بن جبر: ... قال المنافقون للكفار: <q>﴿ألم نستحوذ عليكم﴾</q>: ألم نبين لكم أنّا على ما أنتم عليه؟!{9}. (٥/٧٩) ٢٠٧١٦- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿ونمنعكم من المؤمنين فالله يحكم بينكم يوم القيامة﴾</q>، قال: هم المنافقون{2}. (ز) ٢٠٧١٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ألم نستحوذ عليكم﴾</q>، قال: نَغْلِبْ عليكم{11}. (٥/٨٠) ٢٠٧١٨- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- ... قال المنافقون للكافرين: <q>﴿ألم نستحوذ عليكم﴾</q>: ألم نبين لكم أنّا معكم على ما أنتم عليه؟!{3}١٨٩١. (ز) ١٨٩١ رأى ابنُ جرير (٧/٦٠٨) تقارب ما قاله السدي وابن جُرَيْج، فقال: «وهذان القولان متقاربا المعنى، وذلك أنّ مَن تَأَوَّله بمعنى: ألم نُبَيِّن لكم. إنّما أراد -إن شاء الله-: ألم نغلب عليكم بما كان مِنّا من البيان لكم أنّا معكم؟!». ٢٠٧١٩- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> أي: المنافقون للكفار: <q>﴿ألم نستحوذ عليكم﴾</q> يعني: ألم نَحُطَّ بكم مِن ورائكم{4}. (ز) <q>﴿وَنَمۡنَعۡكُم مِّنَ ٱلۡمُؤۡمِنِینَۚ﴾</q> - تفسير ٢٠٧٢٠- عن مجاهد بن جبر: ... قد كُنّا نُثَبِّطهم عنكم{14}. (٥/٧٩) ٢٠٧٢١- قال مقاتل بن سليمان: <q>﴿ونمنعكم من المؤمنين﴾</q>: ونجادل المؤمنين عنكم، فنحبسهم عنكم، ونخبرهم أنّا معكم. قالوا ذلك جُبْنًا وفَرَقًا منهم، قال الله تعالى: <q>﴿فاللَّهُ يَحْكُمُ بَيْنَكُمْ يَوْمَ القِيامَةِ﴾</q>{4}. (ز) ٢٠٧٢٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿ونمنعكم من المؤمنين﴾</q>، قال: قد كُنّا نُثَبِّطهم عنكم{3}. (ز) <q>﴿فَٱللَّهُ یَحۡكُمُ بَیۡنَكُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِۗ وَلَن یَجۡعَلَ ٱللَّهُ لِلۡكَـٰفِرِینَ عَلَى ٱلۡمُؤۡمِنِینَ سَبِیلًا ۝١٤١﴾</q> - نزول الآية ٢٠٧٢٣- قال مقاتل بن سليمان: <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، نزلت في عبد الله بن أُبَيٍّ وأصحابه{4}. (ز) <q>﴿فَٱللَّهُ یَحۡكُمُ بَیۡنَكُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِۗ وَلَن یَجۡعَلَ ٱللَّهُ لِلۡكَـٰفِرِینَ عَلَى ٱلۡمُؤۡمِنِینَ سَبِیلًا ۝١٤١﴾</q> - تفسير الآية ٢٠٧٢٤- عن علي بن أبي طالب -من طريق يُسَيْع الحضرمي- أنّه قيل له: أرأيتَ هذه الآية: <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، وهم يُقاتِلونا؛ فيظهَرون، ويَقْتُلون؟ فقال: ادنُهْ، ادنُهْ. ثم قال: <q>﴿فالله يحكم بينكم يوم القيامة ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>{18}. (٥/٨٠) ٢٠٧٢٥- عن علي بن أبي طالب -من طريق يُسَيْع الحضرمي- <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، قال: في الآخرة{19}. (٥/٨٠) ٢٠٧٢٦- عن يُسَيْع، قال: جاء رجل إلى علي بن أبي طالب، فقال: أرأيتَ قول الله تعالى: <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، قال: الكافرُ يقتلُ المؤمنَ، والمؤمنُ يقتل الكافرَ؟ قال عليٌّ: <q>﴿ولن يجعل الله للكافرين﴾</q> يوم القيامة <q>﴿على المؤمنين سبيلا﴾</q>{20}١٨٩٢. (ز) ١٨٩٢ أفادت الآثارُ أنّ نفي سبيل الكافرين على المؤمنين إنّما يكون يوم القيامة. ونقل ابنُ جرير (٧/٦٠٩) إجماع أهل التأويل على ذلك، وعلَّق ابنُ عطية (٣/٤٩) بقوله: «وبهذا قال جميع أهل التأويل». ورَجَّح ابنُ القيم (١/٣٠٣) عمومَ الآية، وأنّه لو حصل السبيلُ للكافرين في الدنيا فإنّه بمعصية المؤمنين؛ فالمعنى عنده: ما داموا مؤمنين. فقال: «فالآية على عمومها وظاهرها، وإنّما المؤمنون تصدُر منهم مِن المعصية والمخالفة التي تُضادُّ الإيمانَ ما يصير به للكافرين عليهم سبيلٌ بحسب تلك المخالفة، فهم الذين تَسَبَّبوا إلى جعل السبيل عليهم، كما تسببوا إليه يومَ أحد بمعصية الرسول ومخالفته، واللهُ سبحانه لم يجعل للشيطان على العبد سلطانًا، حتى جعل له العبد سبيلًا إليه بطاعته والشرك به، فجعل الله حينئذ له عليه تسلُّطًا وقهرًا، فمَن وجد خيرًا فليحمد الله تعالى، ومَن وجد غير ذلك فلا يَلُومَنَّ إلا نفسَه. وبهذا يزول الإشكالُ الذي يُورِدُه كثيرٌ من الناس على قوله تعالى: <q>﴿ولَنْ يَجْعَلَ اللهُ لِلْكافِرِينَ عَلى المُؤْمِنِينَ سَبِيلًا﴾</q>، ويُجِيب عنه كثيرٌ منهم: بأنّه لن يجعل لهم عليهم سبيلًا في الآخرة. ويجيب آخرون: بأنّه لن يجعل لهم عليهم سبيلًا في الحُجَّة». وذكر ابنُ كثير (٤/٣١٦) احتمالًا بأن يكون التَّسَلُّطُ في الدنيا، فقال: «ويحتمل أن يكون المراد: <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، أي: في الدنيا، بأن يُسَلَّطوا عليهم استيلاءَ اسْتِئْصالٍ بالكُلِّيَّة، وإن حصل لهم ظَفَرٌ في بعض الأحيان على بعض الناس، فإنّ العاقبة للمتقين في الدنيا والآخرة، كما قال تعالى: <q>﴿إنا لننصر رسلنا والذين آمنوا في الحياة الدنيا ويوم يقوم الأشهاد﴾</q> [غافر:٥١]. وعلى هذا فيكون رَدًّا على المنافقين فيما أمَّلوه وتَرَبَّصوه وانتظروه مِن زوال دولة المؤمنين، وفيما سلكوه مِن مصانعتهم الكافرين خوفًا على أنفسهم منهم إذا هم ظهروا على المؤمنين فاستأصلوهم، كما قال تعالى: <q>﴿فترى الذين في قلوبهم مرض يسارعون فيهم﴾</q> إلى قوله: <q>﴿نادمين﴾</q> [المائدة:٥٢]». ٢٠٧٢٧- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، قال: ذاك يوم القيامة{21}. (٥/٨٠) ٢٠٧٢٨- عن أبي مالك غَزْوان الغِفارِيِّ -من طريق السدي-، مثله{22}. (٥/٨٠) ٢٠٧٢٩- وعن عطاء الخراساني، نحو ذلك{23}. (ز) ٢٠٧٣٠- قال عبد الله بن عباس -من طريق عكرمة-: أي: حُجَّة{24}. (ز) ٢٠٧٣١- قال عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- <q>﴿ولن يجعل الله للكافرين على المؤمنين﴾</q> يعني: أصحاب محمد ﷺ <q>﴿سبيلا﴾</q> يعني: ظُهورًا عليهم{25}. (ز) ٢٠٧٣٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿سبيلا﴾</q>، قال: حُجَّةً{26}١٨٩٣. (٥/٨١) ١٨٩٣ وجَّه ابنُ القيم (١/٣٠٣) تفسير السبيل بالحجة بقوله: «قيل: بالحجة والبرهان؛ لأنّ حجتهم عند ربهم داحضة». ٢٠٧٣٣- قال مقاتل بن سليمان: <q>﴿ولن يجعل الله للكافرين على المؤمنين سبيلا﴾</q>، يعني: حُجَّةً أبدًا{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير موقوف على ابن جريج كما سيأتي.أخرجه ابن أبي حاتم ٤/١٠٩٤.أخرجه ابن جرير ٧/٦٠٧.تفسير مقاتل بن سليمان ١/٤١٦.عزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير موقوف على ابن جريج كما سيأتي.أخرجه ابن أبي حاتم ٤/١٠٩٤.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن جرير ٧/٦٠٧.عزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير موقوف على ابن جريج.أخرجه ابن أبي حاتم ٤/١٠٩٤.أخرجه ابن جرير ٧/٦٠٧، وابن أبي حاتم ٤/١٠٩٤.أخرجه ابن جرير ٧/٦٠٧.تفسير مقاتل بن سليمان ١/٤١٦.عزاه السيوطي إلى ابن جرير، وابن المنذر. وعندَ ابنِ جرير موقوف على ابن جريج كما سيأتي.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن جرير ٧/٦٠٧.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه عبد الرزاق ١/١٧٥، وابن جرير ٧/٦٠٩-٦١٠، والحاكم ٢/٣٠٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٧/٦١٠.أخرجه ابن أبي حاتم ٤/١٠٩٥.أخرجه ابن جرير ٧/٦١٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦١٠. وعلَّقه ابن أبي حاتم ٤/١٠٩٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.علَّقه ابن أبي حاتم ٤/١٠٩٥.تفسير الثعلبي ٣/٤٠٤، وتفسير البغوي ٢/٣٠١.تفسير الثعلبي ٣/٤٠٤.أخرجه ابن جرير ٧/٦١١، وابن أبي حاتم ٤/١٠٩٥.تفسير مقاتل بن سليمان ١/٤١٦.
4,142," <q>﴿إِنَّ ٱلۡمُنَـٰفِقِینَ یُخَـٰدِعُونَ ٱللَّهَ وَهُوَ خَـٰدِعُهُمۡ﴾</q> - نزول الآية ٢٠٧٣٤- عن عبد الملك ابن جريج -من طريق حجّاج- في الآية، قال: نزلت في عبد الله بن أُبَيٍّ، وأبي عامر بن النعمان{1}. (٥/٨١) <q>﴿إِنَّ ٱلۡمُنَـٰفِقِینَ یُخَـٰدِعُونَ ٱللَّهَ وَهُوَ خَـٰدِعُهُمۡ﴾</q> - تفسير الآية ٢٠٧٣٥- عن الحسن البصري -من طريق سفيان بن حسين- في الآية، قال: يُلْقى على كل مؤمن ومنافق نورٌ يمشون به يوم القيامة، حتى إذا انتَهَوْا إلى الصراط طَفِئ نورُ المنافقين، ومضى المؤمنون بنورهم، فينادونهم: <q>﴿انْظُرُونا نَقْتَبِسْ مِن نُورِكُمْ﴾</q> إلى قوله: <q>﴿ولكنكم فتنتم أنفسكم﴾</q> [الحديد:١٣-١٤]. قال الحسن: فتلك خديعة الله إياهم{2}. (٥/٨١) ٢٠٧٣٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وهو خادعهم﴾</q>، قال: يعطيهم يوم القيامة نورًا يمشون فيه مع المسلمين، كما كانوا معهم في الدنيا، ثُمَّ يسلبهم ذلك النورَ، فيُطْفِئُه، فيقومون في ظُلْمَتِهم{3}. (٥/٨١) ٢٠٧٣٧- وعن مجاهد بن جبر= (ز) ٢٠٧٣٨- وسعيد بن جبير، نحوه{4}. (٥/٨١) ٢٠٧٣٩- قال عبد الملك ابن جُرَيْج -من طريق حجّاج-: وفي المنافقين: <q>﴿يخادعون الله وهو خادعهم﴾</q>. قال: مثل قوله في البقرة [٩]: ‹يُخادِعُونَ اللهَ والَّذِينَ آمَنُوا وما يُخادِعُونَ إلَّآ أنفُسَهُمْ›{5}. قال: وأما قوله: <q>﴿وهو خادعهم﴾</q> فيقول: في النور الذي يُعْطى المنافقون مع المؤمنين، فيُعْطَوْن النورَ، فإذا بلغوا السور، وما ذكر الله من قوله: <q>﴿انظرونا نقتبس من نوركم﴾</q> [الحديد:١٣] قال: قوله: <q>﴿وهو خادعهم﴾</q>{6}. (ز) ٢٠٧٤٠- قال مقاتل بن سليمان: <q>﴿إن المنافقين يخادعون الله وهو خادعهم﴾</q> حين أظهروا الإيمان، وأسَرُّوا التكذيبَ، <q>﴿وهو خادعهم﴾</q> على الصراط في الآخرة حين يُقال لهم: <q>﴿ارجعوا وراءكم فالتمسوا نورا﴾</q> [الحديد:١٣]، فبقوا في الظُّلْمَة، فهذه خدعة الله ﷿ لهم في الآخرة{7}. (ز) <q>﴿وَإِذَا قَامُوۤا۟ إِلَى ٱلصَّلَوٰةِ قَامُوا۟ كُسَالَىٰ﴾</q> - تفسير ٢٠٧٤١- عن عبد الله بن عباس -من طريق سِماك الحنفي- أنّه كان يكره أن يقول الرجل: إنِّي كسلان. ويتأول هذه الآية{8}. (٥/٨٢) ٢٠٧٤٢- قال مقاتل بن سليمان: ثُمَّ أخبر عن المنافقين، فقال سبحانه: <q>﴿وإذا قاموا إلى الصلاة قاموا كسالى﴾</q>، يعني: المنافقين متثاقلين، لا يرَوْا أنّها حقٌّ عليهم. نظيرها في براءة{9}. (ز) <q>﴿یُرَاۤءُونَ ٱلنَّاسَ﴾</q> - تفسير ٢٠٧٤٣- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿يراءون الناس﴾</q>، قال: واللهِ، لولا الناسُ ما صَلّى المنافقُ، ولا يُصَلِّي إلا رياءً وسُمْعةً{10}. (٥/٨٢) ٢٠٧٤٤- قال مقاتل بن سليمان: <q>﴿يراءون الناس﴾</q> بالقيام بالنَّهار{7}. (ز) ٢٠٧٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإذا قاموا إلى الصلاة قاموا كسالى يراءون الناس﴾</q>، قال: هم المنافقون، لولا الرياءُ ما صَلَّوْا{12}. (ز) <q>﴿وَلَا یَذۡكُرُونَ ٱللَّهَ إِلَّا قَلِیلࣰا ۝١٤٢﴾</q> - تفسير ٢٠٧٤٦- قال عبد الله بن عباس في قوله: <q>﴿ولا يذكرون الله إلا قليلا﴾</q>: إنّما قال ذلك لأنّهم يفعلونها رياءً وسمعةً، ولو أرادوا بذلك القليلَ وجهَ الله تعالى لكان كثيرًا{13}. (ز) ٢٠٧٤٧- عن الحسن البصري -من طريق أبي الأشهب- <q>﴿ولا يذكرون الله إلا قليلا﴾</q>، قال: إنَّما قَلَّ لأنّه كان لغير الله{14}. (٥/٨٢) ٢٠٧٤٨- عن الحسن البصري -من طريق عوف- أنّه قرأ هذه: <q>﴿يراءون الناس ولا يذكرون الله إلا قليلا﴾</q>، قال الحسن: فواللهِ، لو كان ذلك القليلُ منهم لله لَقَبِلَه، ولكن كان ذلك القليلُ منهم رياءً{15}١٨٩٤. (ز) ١٨٩٤ ذكر ابنُ عطية (٣/٥٠) أنّ تقليل الذِّكْرِ في قوله: <q>﴿لا يذكرون الله إلا قليلا﴾</q> يحتمل وجهين: أحدهما: هذا القول. والآخر: «أنّه قليل بالنسبة إلى خوضهم في الباطل، وقولهم الزور والكفر». ٢٠٧٤٩- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿ولا يذكرون الله إلا قليلا﴾</q>، قال: إنّما قلَّ ذِكْرُ المنافقِ لأنّ الله لم يقبله، وكُلُّ ما ردَّ اللهُ قليلٌ، وكلُّ ما قَبِلَ اللهُ كثيرٌ{16}. (٥/٨٢) ٢٠٧٥٠- قال مقاتل بن سليمان: <q>﴿ولا يذكرون الله﴾</q> يعني: في الصلاة <q>﴿إلا قليلا﴾</q> يعني بالقليل: الرياء، ولا يُصَلُّون في السِّرِّ{7}. (ز) <q>﴿وَلَا یَذۡكُرُونَ ٱللَّهَ إِلَّا قَلِیلࣰا ۝١٤٢﴾</q> - آثار متعلقة بالآية ٢٠٧٥١- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «مَن حَسَّن الصلاةَ حيث يراه الناسُ، وأساءها حيث يخلو؛ فتلك استهانةٌ استهان بها ربَّه»{18}. (٥/٨٢) ٢٠٧٥٢- عن أنس، قال: قال رسول الله ﷺ: «تلك صلاة المنافق، يجلس يَرْقُبُ الشمسَ، حتى إذا كانت بين قَرْنَي شيطانٍ قام فنَقَرَ أربعًا، لا يذكر اللهَ فيها إلا قليلًا»{19}. (٥/٨٣) ٢٠٧٥٣- عن علي بن أبي طالب، قال: لا يَقِلُّ عَمَلٌ مع تقوى، وكيف يَقِلُّ ما يُتَقَبَّلُ؟!{4}. (٥/٨٣) ",footnotes:1:أخرجه ابن جرير ٧/٦١١-٦١٢ مُطَوَّلًا.أخرجه ابن جرير ٧/٦١٢، وابن أبي حاتم ٤/١٠٩٥ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦١١، وابن أبي حاتم ٤/١٠٩٥.عزاه السيوطي إلى ابن المنذر.قال محققو تفسير ابن جرير: كذا في النسخ. وهي قراءة متواترة، قرأ بها نافع، وابن كثير، وأبو عمرو، وقرأ بقية العشرة: <q>﴿وما يَخْدَعُونَ﴾</q> بفتح الياء، وسكون الخاء، وفتح الدال من غير ألف. انظر: النشر ٢/٢٠٧، والإتحاف ص١٧٠.أخرجه ابن جرير ٧/٦١٠.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن أبي الدنيا في الصمت (٣٦٥)، وابن أبي حاتم ٤/١٠٩٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٤١٦. يشير إلى قوله تعالى: <q>﴿ولا يَأْتُونَ الصَّلاةَ إلّا وهُمْ كُسالى﴾</q> [التوبة:٥٤].أخرجه ابن جرير ٧/٦١٣، وابن أبي حاتم ٤/١٠٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه ابن جرير ٧/٦١٣.تفسير الثعلبي ٣/٤٠٥، وتفسير البغوي ٢/٣٠٢.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٩٨ (٣٦٤٦٦)، وابن جرير ٧/٦١٤، وابن أبي حاتم ٤/١٠٩٦، والبيهقي في شعب الإيمان (٦٨٦٦). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٤/١٠٩٦.أخرجه ابن جرير ٧/٦١٤، وابن أبي حاتم ٤/١٠٩٦.وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٦.أخرجه أبو يعلى في مسنده ٩/٥٤ (٥١١٧)، وعبد الرزاق ٢/٣٦٩ (٣٧٣٨)، وابن أبي حاتم ٤/١٠٦١ (٥٩٣٨). قال المنذري في الترغيب والترهيب ١/٣٣ (٤٥): «ورواه من هذه الطرق ابن جرير الطبري مرفوعًا أيضًا، وموقوفًا على ابن مسعود، وهو أشبه». وقال الهيثمي في المجمع ١٠/٢٢١ (١٧٦٥٣): «رواه أبو يعلى، وفيه إبراهيم بن مسلم الهجري، وهو ضعيف». وقال المناوي في فيض القدير ٦/٣٧ (٨٣٣٧): «قال -السيوطي- في المهذب مستدرِكًا على البيهقي: قلتُ: فيه إبراهيم الهجري، ضعيف».أخرجه مسلم ١/٤٣٤ (٦٢٢).عزاه السيوطي إلى ابن المنذر.
4,143," <q>﴿مُّذَبۡذَبِینَ بَیۡنَ ذَ ٰ⁠لِكَ لَاۤ إِلَىٰ هَـٰۤؤُلَاۤءِ وَلَاۤ إِلَىٰ هَـٰۤؤُلَاۤءِۚ﴾</q> - تفسير ٢٠٧٥٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿مذبذبين بين ذلك﴾</q> قال: هم المنافقون، <q>﴿لا إلى هؤلاء﴾</q> يقول: لا إلى أصحاب محمد ﷺ، <q>﴿ولا إلى هؤلاء﴾</q> اليهود{1}. (٥/٨٤) ٢٠٧٥٥- عن قتادة بن دِعامة -من طريق سعيد- في الآية: <q>﴿مذبذبين بين ذلك لا إلى هؤلاء ولا إلى هؤلاء﴾</q>، يقول: ليسوا بمؤمنين مُخْلِصِين، ولا مُشْرِكين مُصَرِّحِين بالشرك. قال: وذُكِر لنا: أنّ نبي الله ﷺ كان يضرب مثلًا للمؤمن والمنافق والكافر، كمثل رَهْطٍ ثلاثة دفعوا إلى نهر، فوقع المؤمن فقطع، ثم وقع المنافق حتى إذا كاد يصل إلى المؤمن ناداه الكافر: أن هَلُمَّ إلَيَّ؛ فإنِّي أخشى عليك. وناداه المؤمن: أن هَلُمَّ إلَيَّ؛ فإنّ عندي وعندي. يُحْصِي له ما عنده، فما زال المنافقُ يتردد بينهما حتى أتى عليه الماءُ فغرقه، وإنّ المنافق لم يَزَلْ في شَكٍّ وشُبهةٍ حتى أتى عليه الموتُ وهو كذلك{2}. (٥/٨٤) ٢٠٧٥٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿مذبذبين بين ذلك لا إلى هؤلاء ولا إلى هؤلاء﴾</q>، يقول: ليسوا بمشركين فيُظهِروا الشرك، وليسوا بمؤمنين{3}. (ز) ٢٠٧٥٧- قال مقاتل بن سليمان: <q>﴿مذبذبين بين ذلك﴾</q> يقول: إنّ المنافقين ليسوا مع اليهود فيُظهِرون ولايتهم، ولا مع المؤمنين في الولاية، <q>﴿لا إلى هؤلاء ولا إلى هؤلاء﴾</q>{4}. (ز) ٢٠٧٥٨- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قوله: <q>﴿مذبذبين بين ذلك﴾</q>، قال: لم يُخْلِصوا الإيمانَ فيكونوا مع المؤمنين، وليسوا مع أهل الشرك{5}. (ز) ٢٠٧٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿مذبذبين بين ذلك﴾</q>، قال: بين الإسلام والكفر{5}. (٥/٨٤) <q>﴿وَمَن یُضۡلِلِ ٱللَّهُ فَلَن تَجِدَ لَهُۥ سَبِیلࣰا ۝١٤٣﴾</q> - تفسير ٢٠٧٦٠- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿سبيلا﴾</q>، يقول: حُجَّة{7}. (ز) ٢٠٧٦١- قال مقاتل بن سليمان: <q>﴿ومن يضلل الله﴾</q> عن الهُدى <q>﴿فلن تجد له سبيلا﴾</q> إليه{4}. (ز) <q>﴿وَمَن یُضۡلِلِ ٱللَّهُ فَلَن تَجِدَ لَهُۥ سَبِیلࣰا ۝١٤٣﴾</q> - آثار متعلقة بالآية ٢٠٧٦٢- عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «مَثَلُ المنافقِ مَثَلُ الشاةِ العائرةِ بين الغنمين، تَعِيرُ إلى هذه مرة، وإلى هذه مرة، لا تدري أيها تتبع»{9}. (٥/٨٤) ٢٠٧٦٣- عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «إنّ مَثَلَ المنافق يوم القيامة كالشاةِ بين الغنمين، إن أتت هؤلاء نطحتها، وإن أتت هؤلاء نطحتها»{10}. (٥/٨٥) ٢٠٧٦٤- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: مَثَلُ المؤمن والمنافق والكافر مَثَلُ ثلاثة نفرٍ انتَهَوْا إلى وادٍ، فوقع أحدهم فعبر، ثُمَّ وقع أحدهم حتى أتى على نصف الوادي ناداه الذي على شَفِير الوادي: ويلك، أين تذهب؟ إلى الهلكة؟! ارجع، عَودُك على بَدْئِك. وناداه الذي عبر: هَلُمَّ النجاة. فجعل ينظر إلى هذا مرة، وإلى هذا مرة. قال: فجاءه سَيْلٌ فأغرقه، فالذي عبر المؤمن، والذي غرق المنافق، مُذَبْذَبٌ بين ذلك لا إلى هؤلاء ولا إلى هؤلاء، والذي مَكَث الكافر{11}. (٥/٨٣) ",footnotes:1:أخرجه ابن جرير ٧/٦١٦-٦١٧، وابن أبي حاتم ٤/١٠٩٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦١٦. وعزاه السيوطي إلى ابن المنذر. وأخرج ابن أبي حاتم ٤/١٠٩٧ أوله. وكذا ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١٦-.أخرجه ابن جرير ٧/٦١٥، وابن أبي حاتم ٤/١٠٩٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن جرير ٧/٦١٧.أخرجه ابن جرير ٧/٦١٧.أخرجه ابن أبي حاتم ٤/١٠٩٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه مسلم ٤/٢١٤٦ (٢٧٨٤)، وابن جرير ٧/٦١٥. وأورده الثعلبي ٣/٤٠٥.أخرجه أحمد ٩/٢٦٢ (٥٣٥٩) من طريق الهذيل بن بلال، عن عبد الله بن عبيد بن عمير، عن أبيه، عن ابن عمر به. إسناده ضعيف؛ فيه الهذيل بن بلال المدائني، قال الذهبي عنه في الميزان ٤/٢٩٤: «ضعّفه النسائي، والدارقطني، وقال يحيى: ليس بشيء. وقال ابن حبان: يقلب الأسانيد، ويرفع المراسيل؛ فصار متروكًا». والحديث رواه مسلم في صحيحه بغير هذا اللفظ كما تقدّم.أخرجه ابن أبي حاتم ٤/١٠٩٦.
4,144," <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ ٱلۡكَـٰفِرِینَ أَوۡلِیَاۤءَ مِن دُونِ ٱلۡمُؤۡمِنِینَۚ﴾</q> - نزول الآية ٢٠٧٦٥- قال مقاتل بن سليمان: <q>﴿يا أيها الذين آمنوا لا تتخذوا الكافرين أولياء من دون المؤمنين﴾</q> نزلت في المنافقين، منهم: عبدالله بن أُبَيٍّ، ومالك بن دَخْشَم، وذلك أنّ مواليهما مِن اليهود أصبغ ورافع عيَّروهما بالإسلام، وزيَّنوا لهما ترك دينهما وتوليهما اليهود، فصانعا اليهود{1}. (ز) <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ ٱلۡكَـٰفِرِینَ أَوۡلِیَاۤءَ مِن دُونِ ٱلۡمُؤۡمِنِینَۚ﴾</q> - تفسير الآية ٢٠٧٦٦- قال مقاتل بن سليمان: <q>﴿يا أيها الذين آمنوا﴾</q> يُرَغِّبهم، <q>﴿لا تتخذوا الكافرين﴾</q> من اليهود <q>﴿أولياء من دون المؤمنين﴾</q>{1}. (ز) <q>﴿أَتُرِیدُونَ أَن تَجۡعَلُوا۟ لِلَّهِ عَلَیۡكُمۡ سُلۡطَـٰنࣰا مُّبِینًا ۝١٤٤﴾</q> - تفسير ٢٠٧٦٧- عن عبد الله بن عباس -من طريق عكرمة- قال: كُلُّ سُلطانٍ في القرآن فهو حُجَّةٌ{3}. (٥/٨٥) ٢٠٧٦٨- وعن مجاهد بن جبر= (ز) ٢٠٧٦٩- وإسماعيل السُّدِّيّ، مثل ذلك{4}. (ز) ٢٠٧٧٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿سلطانا مبينا﴾</q>، قال: حُجَّةً{5}. (ز) ٢٠٧٧١- عن عكرمة مولى ابن عباس -من طريق سفيان، عن رجل- قال: ما كان في القرآن من سُلطان فهو حُجَّة{5}. (ز) ٢٠٧٧٢- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿أتريدون أن تجعلوا لله عليكم سلطانا مبينا﴾</q>، قال: إنّ لله السلطانَ على خلقه، ولكنه يقول: عذرًا مُبينًا{7}. (٥/٨٥) ٢٠٧٧٣- قال مقاتل بن سليمان: <q>﴿أتريدون أن تجعلوا لله عليكم سلطانا مبينا﴾</q>، يعني: حُجَّة بيِّنةً يَحْتَجُّ بها عليكم حين تَوَلَّيتم اليهودَ ونصحتموهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٤١٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه عبد الرزاق ١/٣٩٩، وابن أبي حاتم ٤/١٠٩٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١٦-. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.علَّقه ابن أبي حاتم ٤/١٠٩٧.أخرجه ابن جرير ٧/٦١٩.أخرجه ابن جرير ٧/٦١٩.أخرجه ابن جرير ٧/٦١٨، وابن أبي حاتم ٤/١٠٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٧.
4,145," <q>﴿إِنَّ ٱلۡمُنَـٰفِقِینَ فِی ٱلدَّرۡكِ ٱلۡأَسۡفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمۡ نَصِیرًا ۝١٤٥﴾</q> - قراءات ٢٠٧٧٤- عن الأسود أنّه قرأ في النساء: <q>﴿في الدرك الأسفل﴾</q> مخففة= (ز) ٢٠٧٧٥- وإبراهيم النخعي= (ز) ٢٠٧٧٦- ويحيى بن وثاب= (ز) ٢٠٧٧٧- وسليمان، كذلك{1}. (ز) ٢٠٧٧٨- وعن عاصم بن أبي النجود أنه قرأ: <q>﴿في الدَرْك﴾</q> مخففة{2}١٨٩٥. (ز) ١٨٩٥ اختلف في قراءة قوله: <q>﴿في الدرك﴾</q> فقرأ قوم بفتح الراء، وقرأ آخرون بتسكينها. ورَجَّح ابنُ جرير (٧/٦١٩) صحة كلا القراءتين مستندًا إلى استفاضتهما وشهرتهما، فقال: «وهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب؛ لاتفاق معنى ذلك، واستفاضة القراءة بكل واحدة منهما في قراءة الإسلام». ثم قال (٧/٦١٩-٦٢٠): «غير أنِّي رأيتُ أهلَ العلم بالعربية يذكرون أنّ فتح الراء منه في العرب أشهر من تسكينها، وحكموا سماعًا منهم: أعطني درَكًا أصِلُ به حَبْلي. وذلك إذا سأل ما يَصِل به حَبْله الذي قد عجز عن بلوغ الرَّكِيَّة». وذكر ابنُ عطية (٣/٥٢) أنّ فتح الراء وتسكينها لغتان. <q>﴿إِنَّ ٱلۡمُنَـٰفِقِینَ فِی ٱلدَّرۡكِ ٱلۡأَسۡفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمۡ نَصِیرًا ۝١٤٥﴾</q> - تفسير الآية ٢٠٧٧٩- عن عبد الله بن مسعود -من طريق خيثمة- <q>﴿إن المنافقين في الدرك الأسفل﴾</q>، قال: في توابيت مِن حديد، مقفلة عليهم. وفي لفظ: مبهمة عليهم. أي: مقفلة لا يهتدون لمكان فتحها{3}. (٥/٨٦) ٢٠٧٨٠- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: أيُّ أهل النار أشدُّ عذابًا؟ قال رجل: المنافقون. قال: صدقتَ، فهل تدري كيف يُعَذَّبون؟ قال: لا. قال: يُجْعَلُون في توابيت من حديد تُصْمَد{4} عليهم، ثم يجعلون في الدرك الأسفل في تَنانِيرَ أضيق من زُجٍّ{5}، يُقال له: جُبُّ الحزن. يُطْبَق على أقوام بأعمالهم آخرَ الأبد{6}. (٥/٨٧) ٢٠٧٨١- عن عبد الله بن مسعود -من طريق القاسم بن عبد الرحمن- أنّه سُئِل عن المنافقين؟ فقال: يُجعلون في توابيت من نار، فتطبق عليهم في أسفل النار{7}. (ز) ٢٠٧٨٢- عن أبي هريرة -من طريق أبي صالح- <q>﴿إن المنافقين في الدرك الأسفل﴾</q>، قال: الدَّرْكُ الأسفلُ: بيوتٌ مِن حديد، لها أبواب تطبق عليها، فيُوقَد من تحتهم ومن فوقهم{8}. (٥/٨٦) ٢٠٧٨٣- عن أبي هريرة -من طريق ذَكْوان- <q>﴿إن المنافقين في الدرك﴾</q>، قال: في توابيت تُرْتَجُ{9} عليهم{10}. (٥/٨٦) ٢٠٧٨٤- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿في الدرك الأسفل﴾</q>، يعني: في أسفل النار{11}. (٥/٨٦) ٢٠٧٨٥- عن عبد الله بن كثير -من طريق ابن جُرَيْج- قال: سمعتُ أنّ جهنم أدراك، منازل بعضُها فوق بعض{12}. (٥/٨٧) ٢٠٧٨٦- قال مقاتل بن سليمان: <q>﴿إن المنافقين في الدرك الأسفل من النار﴾</q> يعني: الهاوية، <q>﴿ولن تجد لهم نصيرا﴾</q> يعني: مانعًا من العذاب{13}. (ز) <q>﴿إِنَّ ٱلۡمُنَـٰفِقِینَ فِی ٱلدَّرۡكِ ٱلۡأَسۡفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمۡ نَصِیرًا ۝١٤٥﴾</q> - آثار متعلقة بالآية ٢٠٧٨٧- عن عبد الله بن عمر -من طريق أبي المغيرة القوّاس- قال: إنّ أشدَّ الناس عذابًا يوم القيامة ثُلَّة المنافقون{14}، ومَن كفر مِن أصحاب المائدة، وآل فرعون{15}. (ز) ٢٠٧٨٨- عن عبد الله بن عمر، قال: إنّ أسفلَ أهل النار المنافقون، الذين هم في الدرك الأسفل من النار، قال: فيمكثون فيها ما شاء الله أن يمكثوا، ثم يُقال لأهل النار: لِيَلْعَنَ كلُّ قومٍ آلهتَهم التي كانوا يعبدونها من دون الله. فيلعنُ أهلُ النار ما كانوا يعبدون من دون الله، إلا المنافقين يقولون: لا نستطيع أن نلعن؛ إنّه لم يكن لنا إلهٌ إلا الله على ما كان فينا. قال: فما تكون غيرُها حتى تَزْفُرَ بهم جهنم زَفْرَةً، فترمي بهم في ساحلها، فيدخلون الجنة. قال عبد الله بن يزيد المقرئ: إنما نافقوا بأعمالهم، ولم يُنافِقوا بالإخلاص{16}. (ز) ",footnotes:1:أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٦. المقصود بالتخفيف: إسكان الراء. والخلاف بين القرّاء العشرة في هذا الحرف بين فتح الراء وإسكانها، حيث قرأ عاصم، وحمزة، والكسائي، وخلف العاشر بتسكينها، وقرأ بقية العشرة بفتحها. ينظر: النشر ٢/٢٥٣.ذكره عبد بن حميد كما في قطعة من تفسيره ص١٢٦.أخرجه ابن أبي شيبة ١٣/١٥٣-١٥٤، وهناد (٢٢٣)، وابن أبي الدنيا في صفة النار (١٠٤)، وابن جرير ٧/٦٢٠، وابن أبي حاتم ٤/١٠٩٨، والطبراني (٩٠١٥). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تصمد عليهم: تسد عليهم. اللسان (صمد).الزج: نصل السهم. النهاية (زجج).أخرجه ابن أبي الدنيا في صفة النار (١٠٠).أخرجه ابن أبي حاتم ٤/١٠٩٨.أخرجه ابن أبي حاتم ٤/١٠٩٨. وعزاه السيوطي إلى عبد بن حميد.ترج عليهم: تغلق عليهم. النهاية (رتج).أخرجه ابن جرير ٧/٦٢٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٦٢٠-٦٢١، وابن أبي حاتم ٤/١٠٩٨.أخرجه ابن جرير ٧/٦٢١. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٤١٧.هكذا في الأصل.تفسير الثعلبي ٣/٤٠٦.أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٦.
4,146," <q>﴿إِلَّا ٱلَّذِینَ تَابُوا۟ وَأَصۡلَحُوا۟ وَٱعۡتَصَمُوا۟ بِٱللَّهِ وَأَخۡلَصُوا۟ دِینَهُمۡ لِلَّهِ فَأُو۟لَـٰۤىِٕكَ مَعَ ٱلۡمُؤۡمِنِینَۖ وَسَوۡفَ یُؤۡتِ ٱللَّهُ ٱلۡمُؤۡمِنِینَ أَجۡرًا عَظِیمࣰا ۝١٤٦﴾</q> - نزول الآية ٢٠٧٨٩- قال مقاتل بن سليمان: ولَمّا أخبر بمُسْتَقَرِّ المنافقين قال ناسٌ للنبي ﷺ: فقد كان فلانٌ وفلانٌ منافقين، فتابوا منه، فكيف يفعل الله بهم؟ فأنزل الله جل ذكره: <q>﴿إلا الذين تابوا﴾</q>{1}. (ز) <q>﴿إِلَّا ٱلَّذِینَ تَابُوا۟﴾</q> - تفسير ٢٠٧٩٠- قال حذيفة بن اليمان -من طريق إبراهيم-: لَيَدْخُلَنَّ الجنةَ قومٌ كانوا منافقين. فقال عبد الله: وما علمُك بذلك؟ فغضب حذيفة، ثم قام فتَنَحّى، فلما تفرَّقوا مَرَّ به علقمةُ، فدعاه، فقال: أما إنّ صاحبك يعلم الذي قلتَ. ثم قرأ: <q>﴿إلا الذين تابوا وأصلحوا واعتصموا بالله وأخلصوا دينهم لله فأولئك مع المؤمنين وسوف يؤت الله المؤمنين أجرا عظيما﴾</q>{2}. (ز) ٢٠٧٩١- عن الأسود، قال: جاءنا حذيفةُ بن اليمان، فقام على رءوسنا، فقال: لقد نزل النفاق على مَن هو خيرٌ منكم. قلتُ له: أنّى يكون هذا، والله تعالى يقول: <q>﴿إن المنافقين في الدرك الأسفل من النار﴾</q>؟! قال: فلمّا تفرقوا قال: لم يبق غيري، رماني بحصاة فأتيته، فقال: إنهم لما تابوا كانوا خيرًا منكم{3}. (ز) ٢٠٧٩٢- عن عبد الله بن عباس -من طريق عطاء- قال في سورة النساء: <q>﴿إن المنافقين في الدرك الأسفل من النار﴾</q>، ثم استثنى، فقال: <q>﴿إلا الذين تابوا وأصلحوا﴾</q>{3}. (ز) ٢٠٧٩٣- قال مقاتل بن سليمان: <q>﴿إلا الذين تابوا﴾</q> من المنافقين{1}. (ز) <q>﴿وَأَصۡلَحُوا۟﴾</q> - تفسير ٢٠٧٩٤- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿وأصلحوا﴾</q>، يعني: وأصلح العملَ{6}. (ز) ٢٠٧٩٥- عن قتادة بن دِعامة -من طريق شيبان النحوي- <q>﴿وأصلحوا﴾</q>، قال: أصلحوا ما بينهم وبين الله ورسوله{6}. (ز) ٢٠٧٩٦- قال مقاتل بن سليمان: <q>﴿وأصلحوا﴾</q> العمل{1}. (ز) <q>﴿وَٱعۡتَصَمُوا۟ بِٱللَّهِ﴾</q> - تفسير ٢٠٧٩٧- عن الربيع بن أنس -من طريق سليمان، يعني: ابن عامر- قوله: <q>﴿واعتصموا بالله﴾</q>، قال: الاعتصام هو الثقةُ بالله{6}. (ز) ٢٠٧٩٨- قال مقاتل بن سليمان: <q>﴿واعتصموا﴾</q> يعني: احْتَرَزُوا <q>﴿بالله﴾</q>{1}. (ز) <q>﴿وَأَخۡلَصُوا۟ دِینَهُمۡ لِلَّهِ﴾</q> - تفسير ٢٠٧٩٩- قال مقاتل بن سليمان: <q>﴿وأخلصوا دينهم﴾</q> الإسلام <q>﴿لله﴾</q> ﷿، ولم يخلِطوا بشرك{1}. (ز) <q>﴿وَأَخۡلَصُوا۟ دِینَهُمۡ لِلَّهِ﴾</q> - آثار متعلقة بالآية ٢٠٨٠٠- عن معاذ بن جبل، أنّه قال لرسول الله ﷺ حين بعثه إلى اليمن: أوْصِني. قال: «أخلِص دينَك؛ يَكْفِكَ القليلُ من العمل»{12}. (٥/٨٧) ٢٠٨٠١- عن أبي فراس -رجل من أسلم-، قال: قال رسول الله ﷺ: «سلُوني عمّا شئتم». فنادى رجلٌ: يا رسول الله، ما الإسلامُ؟ قال: «إقام الصلاة، وإيتاء الزكاة». قال: فما الإيمان؟ قال: «الإخلاص». قال: فما اليقين؟ قال: «التصديق بالقيامة»{13}. (٥/٨٨) ٢٠٨٠٢- عن زيد بن أرقم، قال: قال رسول الله ﷺ: «مَن قال: لا إله إلا الله مُخْلِصًا دخل الجنة». قيل: يا رسول الله، وما إخلاصُها؟ قال: «أن تحجزه عن المحارم»{14}. (٥/٨٩) ٢٠٨٠٣- عن أبي ثُمامَة، قال: قال الحواريُّون لعيسى ﵇: يا روح الله، مَنِ المُخلص لله؟ قال: الذي يعمل لله لا يُحِبُّ أن يَحْمَدَه الناسُ عليه{15}. (٥/٨٩) <q>﴿فَأُو۟لَـٰۤىِٕكَ مَعَ ٱلۡمُؤۡمِنِینَۖ وَسَوۡفَ یُؤۡتِ ٱللَّهُ ٱلۡمُؤۡمِنِینَ أَجۡرًا عَظِیمࣰا ۝١٤٦﴾</q> - تفسير ٢٠٨٠٤- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿فأولئك﴾</q> يعني: الذين فعلوا ما ذكر اللهُ في هذه الآية هم الذين صدقوا، قوله: <q>﴿مع المؤمنين﴾</q> يعني: المصدقين{6}. (ز) ٢٠٨٠٥- قال مقاتل بن سليمان: <q>﴿فأولئك مع المؤمنين﴾</q> في الولاية، <q>﴿وسوف يؤت الله المؤمنين أجرا عظيما﴾</q> يعني: جزاءً وافِرًا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن جرير ٧/٦٢٣.أخرجه ابن أبي حاتم ٤/١٠٩٨.أخرجه ابن أبي حاتم ٤/١٠٩٨.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن أبي حاتم ٤/١٠٩٩.أخرجه ابن أبي حاتم ٤/١٠٩٩.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه ابن أبي حاتم ٤/١٠٩٩.تفسير مقاتل بن سليمان ١/٤١٧.تفسير مقاتل بن سليمان ١/٤١٧.أخرجه الحاكم ٤/٣٤١ (٧٨٤٤)، وابن أبي حاتم ٤/١٠٩٩ (٦١٦٢). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «غير صحيح». وقال البيهقي في الشعب ٩/١٧٥ (٦٤٤٤): «مرسل». وقال أبو عبد الرحمن الحوت الشافعي في أسنى المطالب في أحاديث مختلفة المراتب ص٣٤: «رواه الديلمي بإسناد منقطع كما قال العراقي». وقال الألباني في الضعيفة ٥/١٨٠ (٢١٦٠): «ضعيف».أخرجه البيهقي (٦٨٥٨). وقال المنذري في الترغيب ١/٥٣: «وهو مرسل».أخرجه الطبراني في الكبير ٥/١٩٧ (٥٠٧٤)، وأبونعيم في الحلية ٩/٢٥٤-٢٥٥. قال الطبراني في الأوسط ٢/٥٦ (١٢٣٥): «لم يرو هذا الحديثَ عن أبي إسحاق إلا شريك، تفرد به محمد بن عبد الرحمن». وقال العراقي في تخريج الإحياء ص٥٢١: «بإسناد حسن». وقال الهيثمي في المجمع ١/١٨ (١٨): «رواه الطبراني في الأوسط، والكبير ...، وفي إسناده محمد بن عبد الرحمن بن غزوان، وهو وضّاع». وقال الألباني في الضعيفة ١١/٢٤٨ (٥١٤٨): «موضوع».أخرجه ابن أبي شيبة ١٣/١٩٥، وأحمد في الزهد ص٥٥. وعزاه السيوطي إلى الحكيم الترمذي، وابن أبي حاتم. وقد أورد السيوطي ٥/٨٨-٩٠ عَقِب هذا آثارًا في فضل الإخلاص لله.أخرجه ابن أبي حاتم ٤/١٠٩٩.تفسير مقاتل بن سليمان ١/٤١٧.
4,147," <q>﴿مَّا یَفۡعَلُ ٱللَّهُ بِعَذَابِكُمۡ إِن شَكَرۡتُمۡ وَءَامَنتُمۡۚ وَكَانَ ٱللَّهُ شَاكِرًا عَلِیمࣰا ۝١٤٧﴾</q> - تفسير ٢٠٨٠٦- عن مكحول الشامي -من طريق العلاء بن الحارث- قال: أربعٌ مَن كُنَّ فيه كُنَّ له: ... الشكر، والإيمان، والدعاء، والاستغفار؛ قال الله تعالى: <q>﴿ما يفعل الله بعذابكم إن شكرتم وآمنتم﴾</q> [النساء:١٤٧]، وقال: <q>﴿وما كان الله معذبهم وهم يستغفرون﴾</q> [الأنفال:٣٣]، وقال: <q>﴿ما يعبأ بكم ربي لولا دعاؤكم﴾</q> [الفرقان:٧٧]{1}. (ز) ٢٠٨٠٧- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿ما يفعل الله بعذابكم إن شكرتم﴾</q> الآية، قال: إنّ الله لا يُعَذِّب شاكرًا، ولا مُؤْمِنًا{2}. (٥/٩٠) ٢٠٨٠٨- قال مقاتل بن سليمان: <q>﴿ما يفعل الله بعذابكم إن شكرتم﴾</q> نعمتَه، <q>﴿وآمنتم﴾</q> يعني: صدَّقتم، فإنه لا يعذب شاكرًا ولا مؤمنًا، <q>﴿وكان الله شاكرا عليما﴾</q> بهم{3}. (ز) ",footnotes:1:أخرجه أبو نعيم في حلية الأولياء ٥/١٨١-١٨٢، وابن عساكر في تاريخه ٦٠/٢٢٥.أخرجه ابن أبي حاتم ٤/١١٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤١٧.
