quran[11]{c,v,t}:
10,43," <q>﴿وَمِنۡهُم مَّن یَنظُرُ إِلَیۡكَۚ أَفَأَنتَ تَهۡدِی ٱلۡعُمۡیَ وَلَوۡ كَانُوا۟ لَا یُبۡصِرُونَ ۝٤٣﴾</q> - تفسير ٣٤٥٣٧- عن عبد الله بن عباس -من طريق ابن إسحاق بسنده- <q>﴿لا يبصرون﴾</q>، أي: لا يُبْصِرون الحقَّ{1}. (ز) ٣٤٥٣٨- قال مقاتل بن سليمان: <q>﴿ومِنهُمْ مَن يَنْظُرُ إلَيْكَ﴾</q> يا محمد، <q>﴿أفَأَنْتَ تَهْدِي العُمْيَ ولَوْ﴾</q> يعني: إذ <q>﴿كانُوا لا يُبْصِرُونَ﴾</q> الهُدى{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٤.تفسير مقاتل بن سليمان ٢/٢٣٩.
10,44," <q>﴿إِنَّ ٱللَّهَ لَا یَظۡلِمُ ٱلنَّاسَ شَیۡـࣰٔا وَلَـٰكِنَّ ٱلنَّاسَ أَنفُسَهُمۡ یَظۡلِمُونَ ۝٤٤﴾</q> - تفسير ٣٤٥٣٩- عن مكحولٍ الشامي، في قوله: <q>﴿إنَّ اللهَ لا يَظْلِمُ النّاسَ شَيْئًا ولَكِنَّ النّاس أنفُسَهُم يَظلِمُونَ﴾</q>، قال: قال رسول الله ﷺ: «قال الله: يا عبادي، إنِّي حَرَّمْتُ على نفسي الظُّلْمَ، وجعَلتُه بينَكم مُحَرَّمًا، فلا تَظالَموا»{1}. (٧/٦٦٤) ٣٤٥٤٠- قال مقاتل بن سليمان: <q>﴿إنَّ اللَّهَ لا يَظْلِمُ النّاسَ شَيْئًا ولكِنَّ النّاسَ أنْفُسَهُمْ يَظْلِمُونَ﴾</q>، يقول: نصيبَهم، ينقصون بأعمالهم [إذ] حرموا أنفسهم ثواب المؤمنين{2}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٩.
10,45," <q>﴿وَیَوۡمَ یَحۡشُرُهُمۡ كَأَن لَّمۡ یَلۡبَثُوۤا۟ إِلَّا سَاعَةࣰ مِّنَ ٱلنَّهَارِ یَتَعَارَفُونَ بَیۡنَهُمۡۚ قَدۡ خَسِرَ ٱلَّذِینَ كَذَّبُوا۟ بِلِقَاۤءِ ٱللَّهِ وَمَا كَانُوا۟ مُهۡتَدِینَ ۝٤٥﴾</q> - تفسير ٣٤٥٤١- عن عبد الله بن عباس: كأن لم يلبثوا في قبورهم إلا قَدْر ساعةٍ من النهار{1}. (ز) ٣٤٥٤٢- قال الضحاك بن مزاحم: كأن لم يلبثوا في الدنيا إلا ساعة من النهار، قَصُرَت الدنيا في أعينهم مِن هَوْل ما استقبلوا{2}. (ز) ٣٤٥٤٣- عن الحسن البصري -من طريق عمر- في قوله: <q>﴿يَتَعارَفُونَ بَينَهُم﴾</q>، قال: يعرفُ الرجلُ صاحبَه إلى جنبِه، فلا يستطيعُ أن يُكلِّمَه{3}٣١٢٢. (٧/٦٦٤) ٣١٢٢ ذكر ابنُ عطية (٤/٤٨٧) في قوله: <q>﴿يتعارفون﴾</q> احتمالات، فقال: «وأمّا قوله: <q>﴿يتعارفون﴾</q> فيحتمل أن يكون معادلة لقوله: <q>﴿ويوم يحشرهم﴾</q>، كأنّه أخبر أنهم يوم الحشر يتعارفون، وهذا التعارف على جهة التلاوم والخزي من بعضهم لبعض. ويحتمل أن يكون في موضع الحال من الضمير في <q>﴿يحشرهم﴾</q>، ويكون معنى التعارف كالذي قبله. ويحتمل أن يكون حالًا من الضمير في <q>﴿يلبثوا﴾</q>، ويكون التعارف في الدنيا، ويجيء معنى الآية: ويوم نحشرهم للقيامة فتنقطع المعرفة بينهم والأسباب، ويصير تعارفهم في الدنيا كساعةٍ من النهار لا قَدْر لها». ٣٤٥٤٤- قال مقاتل بن سليمان: <q>﴿ويَوْمَ يَحْشُرُهُمْ﴾</q> من قبورهم إلى القيامة <q>﴿كَأَنْ لَمْ يَلْبَثُوا إلّا ساعَةً مِنَ النَّهارِ﴾</q> يعني: يومًا واحِدًا من أيام الدنيا، <q>﴿يَتَعارَفُونَ بَيْنَهُمْ﴾</q> يعني: يعرفون بعضهم بعضًا، وتبيان ذلك في الفصل{4} في «سَأَلَ سائِلٌ»: <q>﴿يُبَصَّرُونَهُمْ﴾</q> [المعارج:١١] يعني: يعرفونهم، <q>﴿قَدْ خَسِرَ الَّذِينَ كَذَّبُوا بِلِقاءِ اللَّهِ﴾</q> يعني: البعث، <q>﴿وما كانُوا مُهْتَدِينَ﴾</q>{5}. (ز) <q>﴿وَیَوۡمَ یَحۡشُرُهُمۡ كَأَن لَّمۡ یَلۡبَثُوۤا۟ إِلَّا سَاعَةࣰ مِّنَ ٱلنَّهَارِ یَتَعَارَفُونَ بَیۡنَهُمۡۚ قَدۡ خَسِرَ ٱلَّذِینَ كَذَّبُوا۟ بِلِقَاۤءِ ٱللَّهِ وَمَا كَانُوا۟ مُهۡتَدِینَ ۝٤٥﴾</q> - آثار متعلقة بالآية ٣٤٥٤٥- قال الحسن البصري: ذُكِر لنا: أنّ النبي ﷺ قال: «ثلاثة مواطن لا يَسْأَلُ فيها أحدٌ أحدًا: إذا وُضِعت الموازين حتى يعلمَ أيثقُل ميزانُه أم يَخِفُّ، وإذا تَطايَرَت الكتبُ حتى يعلم أيأخُذُ كتابَه بيمينه أم بشماله، وعند الصراط حتى يعلم أيَجُوزُ الصراطَ أم لا يَجُوز»{6}. (ز) ",footnotes:1:تفسير الثعلبي ٥/١٣٤، وتفسير البغوي ٤/١٣٥.تفسير الثعلبي ٥/١٣٤ واللفظ له، وتفسير البغوي ٤/١٣٥ مختصرا.أخرجه ابن أبي حاتم ٦/١٩٥٤-١٩٥٥. وعزاه السيوطي إلى أبي الشيخ.كذا في مطبوعة المصدر، ولعلها «المفصل».تفسير مقاتل بن سليمان ٢/٢٣٩-٢٤٠.أورده يحيى بن سلام في تفسيره ١/٤١٦، وابن الجوزي في بستان الواعظين ص٧٠ بنحوه.
10,46," <q>﴿وَإِمَّا نُرِیَنَّكَ بَعۡضَ ٱلَّذِی نَعِدُهُمۡ أَوۡ نَتَوَفَّیَنَّكَ فَإِلَیۡنَا مَرۡجِعُهُمۡ ثُمَّ ٱللَّهُ شَهِیدٌ عَلَىٰ مَا یَفۡعَلُونَ ۝٤٦﴾</q> - تفسير ٣٤٥٤٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وإمّا نُرِيَنَّكَ بَعضَ الَّذِي نَعِدُهُم﴾</q> قال: سوء العذابِ في حياتِك، <q>﴿أو نتوفينك﴾</q> قبلُ؛ <q>﴿فَإلَينا مَرجِعُهُم﴾</q>{1}. (٧/٦٦٤) ٣٤٥٤٧- قال مقاتل بن سليمان: <q>﴿وإمّا نُرِيَنَّكَ بَعْضَ الَّذِي نَعِدُهُمْ﴾</q> يوم بدر، <q>﴿أوْ نَتَوَفَّيَنَّكَ﴾</q> قبل يوم بدر؛ <q>﴿فَإلَيْنا مَرْجِعُهُمْ﴾</q> في الآخرة، فأنتقم منهم، <q>﴿ثُمَّ اللَّهُ شَهِيدٌ عَلى ما يَفْعَلُونَ﴾</q> مِن الكُفْر، والتَّكذيب{2}. (ز) ",footnotes:1:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٨٨، وابن أبي حاتم ٦/١٩٥٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٤٠.
10,47," <q>﴿وَلِكُلِّ أُمَّةࣲ رَّسُولࣱۖ فَإِذَا جَاۤءَ رَسُولُهُمۡ قُضِیَ بَیۡنَهُم بِٱلۡقِسۡطِ وَهُمۡ لَا یُظۡلَمُونَ ۝٤٧﴾</q> - تفسير ٣٤٥٤٨- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿ولِكُلِ أُمَّةٍ رَسُولٌ فَإذا جَآءَ رَسُولُهُم﴾</q>، قال: يومَ القيامةِ{1}. (٧/٦٦٤) ٣٤٥٤٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿قضي بينهم بالقسط﴾</q>، قال: بالعدل{2}٣١٢٣. (ز) ٣١٢٣ أشار ابنُ عطية (٤/٤٨٨) إلى قول مجاهد، ثم ذكر قولًا آخر، فقال: «وقيل: المعنى: فإذا جاء رسولهم في الدنيا وبُعِث صاروا مِن حتم الله بالعذاب لقومٍ، والمغفرة لآخرين لغاياتهم، فذلك قضاء بينهم بالقسط». ٣٤٥٥٠- عن إسماعيل السُّدِّيّ، نحو ذلك{3}٣١٢٤. (ز) ٣١٢٤ ذكر ابنُ عطية (٤/٤٨٨) أنّ بعض المتأولين قرن هذه الآية بقوله: <q>﴿وما كُنّا مُعَذِّبِينَ حَتّى نَبْعَثَ رَسُولًا﴾</q> [الإسراء:١٥]، ووجَّهه بقوله: «وذلك يتفق إمّا بأن نجعل <q>﴿مُعَذِّبِينَ﴾</q> في الآخرة، وإمّا بأن نجعل القضاء بينهم في الدنيا بحيث يصح اشتباه الآيتين». ٣٤٥٥١- قال مقاتل بن سليمان: <q>﴿ولِكُلِّ أُمَّةٍ رَسُولٌ فَإذا جاءَ رَسُولُهُمْ قُضِيَ بَيْنَهُمْ بِالقِسْطِ﴾</q> يعني: بالحقِّ، وهو العدل، <q>﴿وهُمْ لا يُظْلَمُونَ﴾</q>. وذلك أنّ الله بَعَث الرسلَ إلى أُمَمِهم يدعون إلى عبادة الله، وتركِ عبادة الأصنام والأوثان، فمَن أجابهم إلى ذلك أثابَه اللهُ الجنةَ، ومَن أبى جعل ثوابه النار، فذلك قوله: <q>﴿قُضِيَ بَيْنَهُمْ بِالقِسْطِ وهُمْ لا يُظْلَمُونَ﴾</q> وذلك عند وقت العذاب، <q>﴿وهُمْ لا يُظْلَمُونَ﴾</q> يعني: وهم لا يُنقصون مِن محاسنهم، ولا يُزادون على مساوئهم ما لم يعملوها{4}. (ز) ",footnotes:1:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٨٨، وابن أبي حاتم ٦/١٩٥٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٨٩، وابن أبي حاتم ٦/١٩٥٥.علَّقه ابن أبي حاتم ٦/١٩٥٥.تفسير مقاتل بن سليمان ٢/٢٤٠.
10,48," <q>﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤٨﴾</q> - تفسير ٣٤٥٥٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويقولون متى هذا الوعد إن كنتم صادقين﴾</q>: قال أصحابُ رسول الله ﷺ: إنّ لنا يومًا يُوشِك أن نستريح فيه، وننعم فيه. فقال المشركون: <q>﴿متى هذا الوعد إن كنتم صادقين﴾</q>؟ أي: تكذيبًا{1}٣١٢٥. (ز) ٣١٢٥ ذكر ابنُ عطية (٤/٤٨٩) أنّ بعض المفسرين قال: إنّ قولهم هذا على جهة الاستخفاف. وانتَقَدَه لمخالفته ظاهر لفظ الآية، فقال: «وهذا لا يَظْهَرُ مِن اللفظة». ٣٤٥٥٣- قال مقاتل بن سليمان: <q>﴿ويَقُولُونَ﴾</q> يعني: الكفار لنبيهم: <q>﴿مَتى هذا الوَعْدُ إنْ كُنْتُمْ صادِقِينَ﴾</q>. وذلك قوله: <q>﴿ائْتِنا بِعَذابِ اللَّهِ إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</q> [العنكبوت:٢٩]{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٥.تفسير مقاتل بن سليمان ٢/٢٤٠.
10,49," <q>﴿قُل لَّاۤ أَمۡلِكُ لِنَفۡسِی ضَرࣰّا وَلَا نَفۡعًا إِلَّا مَا شَاۤءَ ٱللَّهُۗ لِكُلِّ أُمَّةٍ أَجَلٌۚ إِذَا جَاۤءَ أَجَلُهُمۡ فَلَا یَسۡتَـٔۡخِرُونَ سَاعَةࣰ وَلَا یَسۡتَقۡدِمُونَ ۝٤٩﴾</q> - تفسير ٣٤٥٥٤- قال مقاتل بن سليمان: <q>﴿قُلْ لا أمْلِكُ لِنَفْسِي ضَرًّا﴾</q> يعني: سوءًا، <q>﴿ولا نَفْعًا﴾</q> يعني: في الآخرة، <q>﴿إلّا ما شاءَ اللَّهُ لِكُلِّ أُمَّةٍ أجَلٌ﴾</q> وقت. يقول: لكلِّ أجل وقت؛ لأنّه سبقت الرحمة الغضب، <q>﴿إذا جاءَ أجَلُهُمْ﴾</q> يعني: وقت العذاب؛ <q>﴿فَلا يَسْتَأْخِرُونَ ساعَةً ولا يَسْتَقْدِمُونَ﴾</q> يقول: لا يُؤَخَّر عنهم ساعة، ولا يصيبهم قبلَ الوقت{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤١.
10,50," <q>﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَتَىٰكُمۡ عَذَابُهُۥ بَیَـٰتًا أَوۡ نَهَارࣰا مَّاذَا یَسۡتَعۡجِلُ مِنۡهُ ٱلۡمُجۡرِمُونَ ۝٥٠﴾</q> - تفسير ٣٤٥٥٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قوله: <q>﴿أرأيتم إن أتاكم عذابه﴾</q>، قال: فُجاءَةً آمِنِين{1}. (ز) ٣٤٥٥٦- قال مقاتل بن سليمان: <q>﴿قُلْ أرَأَيْتُمْ إنْ أتاكُمْ عَذابُهُ بَياتًا﴾</q> يعني: صباحًا{2} <q>﴿أوْ نَهارًا ماذا يَسْتَعْجِلُ مِنهُ المُجْرِمُونَ﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٦.كذا في المطبوع، وتقدم تفسيره للفظ في آية (٧) من سورة الأعراف بأنه ليلا، وهو أصح.تفسير مقاتل بن سليمان ٢/٢٤١.
10,51," <q>﴿أَثُمَّ إِذَا مَا وَقَعَ ءَامَنتُم بِهِۦۤۚ ءَاۤلۡـَٔـٰنَ وَقَدۡ كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ ۝٥١﴾</q> - تفسير ٣٤٥٥٧- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿أثم إذا ما وقع﴾</q>: يعني: حتى إذا ما نزل العذاب <q>﴿آمنتم به﴾</q>{1}. (ز) ٣٤٥٥٨- قال مقاتل بن سليمان: <q>﴿أثُمَّ إذا ما وقَعَ﴾</q> يعني: قول القرآن <q>﴿آمَنتُمْ بِهِ آلْآنَ﴾</q> حين لم تنفعكم <q>﴿وقَدْ كُنْتُمْ بِهِ﴾</q> يعني: بالعذاب <q>﴿تَسْتَعْجِلُونَ﴾</q>{2}. (ز) ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٦١-، وأورد عقبه: <q>﴿الآن وقد كنتم به تستعجلون﴾</q> أي: يُقال لهم إذا آمنوا عند نزول العذاب: الآن تؤمنون حين لا ينفعكم الإيمان.تفسير مقاتل بن سليمان ٢/٢٤١.
10,52," <q>﴿ثُمَّ قِیلَ لِلَّذِینَ ظَلَمُوا۟ ذُوقُوا۟ عَذَابَ ٱلۡخُلۡدِ﴾</q> - تفسير ٣٤٥٥٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿ذوقوا﴾</q>، يعني: العقوبة{1}. (ز) ٣٤٥٦٠- قال مقاتل بن سليمان: <q>﴿ثُمَّ قِيلَ لِلَّذِينَ ظَلَمُوا﴾</q> يعني: كفروا <q>﴿ذُوقُوا عَذابَ الخُلْدِ﴾</q>{2}. (ز) <q>﴿هَلۡ تُجۡزَوۡنَ إِلَّا بِمَا كُنتُمۡ تَكۡسِبُونَ ۝٥٢﴾</q> - تفسير ٣٤٥٦١- عن أبي العالية الرِّياحي -من طريق الربيع بن أنس- قوله: <q>﴿تكسبون﴾</q>، يعني: مِن الخطيئة{1}. (ز) ٣٤٥٦٢- قال مقاتل بن سليمان: <q>﴿هَلْ تُجْزَوْنَ إلّا بِما كُنْتُمْ تَكْسِبُونَ﴾</q> مِن الشِّرك. يقول: جزاءُ الشِّرك جهنمُ{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.
10,53," <q>﴿وَیَسۡتَنۢبِـُٔونَكَ أَحَقٌّ هُوَۖ قُلۡ إِی وَرَبِّیۤ إِنَّهُۥ لَحَقࣱّۖ وَمَاۤ أَنتُم بِمُعۡجِزِینَ ۝٥٣﴾</q> - تفسير ٣٤٥٦٣- عن عبد الله بن عباس -من طريق الضَّحّاك- قوله: <q>﴿بمعجزين﴾</q>، قال: بمُسابِقين{1}. (ز) ٣٤٥٦٤- قال مقاتل بن سليمان: <q>﴿ويَسْتَنْبِئُونَكَ﴾</q> يقول: يسألونك <q>﴿أحَقٌّ هُوَ؟﴾</q> يعني: العذاب الذي تَعِدُنا به، ويُقال: القرآن الذي أُنزِل إليك أحقٌّ هو؟ <q>﴿قُلْ إي ورَبِّي﴾</q> يعني: نعم، وإلهي، <q>﴿إنَّهُ﴾</q> يعني: العذاب <q>﴿لَحَقٌّ﴾</q> يعني: لَكائِن، <q>﴿وما أنْتُمْ بِمُعْجِزِينَ﴾</q> يعني: بِسابِقِيَّ بأعمالكم الخبيثة في الدنيا قبل الآخرة{2}٣١٢٦. (ز) ٣١٢٦ ذكر ابنُ عطية (٤/٤٩١) أنّ قوله: <q>﴿أحَقٌّ هُوَ﴾</q> قيل: إنّه الإشارة إلى الشرع والقرآن. وقيل: إنّه إلى الوعيد. ورجَّح الثاني بقوله: «وهو الأظهر». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.
