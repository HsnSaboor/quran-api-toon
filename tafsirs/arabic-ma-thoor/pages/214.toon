quran[11]{c,v,t}:
  10,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡهُم مَّن یَنظُرُ إِلَیۡكَۚ أَفَأَنتَ تَهۡدِی ٱلۡعُمۡیَ وَلَوۡ كَانُوا۟ لَا یُبۡصِرُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- <span class="qpc-hafs">﴿لا يبصرون﴾</span>، أي: لا يُبْصِرون الحقَّ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِنهُمْ مَن يَنْظُرُ إلَيْكَ﴾</span> يا محمد، <span class="qpc-hafs">﴿أفَأَنْتَ تَهْدِي العُمْيَ ولَوْ﴾</span> يعني: إذ <span class="qpc-hafs">﴿كانُوا لا يُبْصِرُونَ﴾</span> الهُدى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٤.تفسير مقاتل بن سليمان ٢/٢٣٩.
  10,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ لَا یَظۡلِمُ ٱلنَّاسَ شَیۡـࣰٔا وَلَـٰكِنَّ ٱلنَّاسَ أَنفُسَهُمۡ یَظۡلِمُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٣٩<span class="dash">-</span></span> عن مكحولٍ الشامي، في قوله: <span class="qpc-hafs">﴿إنَّ اللهَ لا يَظْلِمُ النّاسَ شَيْئًا ولَكِنَّ النّاس أنفُسَهُم يَظلِمُونَ﴾</span>، قال: قال رسول الله ﷺ: «<b>قال الله: يا عبادي، إنِّي حَرَّمْتُ على نفسي الظُّلْمَ، وجعَلتُه بينَكم مُحَرَّمًا، فلا تَظالَموا</b>»{1}. (٧/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ اللَّهَ لا يَظْلِمُ النّاسَ شَيْئًا ولكِنَّ النّاسَ أنْفُسَهُمْ يَظْلِمُونَ﴾</span>، يقول: نصيبَهم، ينقصون بأعمالهم [إذ] حرموا أنفسهم ثواب المؤمنين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٩.
  10,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یَحۡشُرُهُمۡ كَأَن لَّمۡ یَلۡبَثُوۤا۟ إِلَّا سَاعَةࣰ مِّنَ ٱلنَّهَارِ یَتَعَارَفُونَ بَیۡنَهُمۡۚ قَدۡ خَسِرَ ٱلَّذِینَ كَذَّبُوا۟ بِلِقَاۤءِ ٱللَّهِ وَمَا كَانُوا۟ مُهۡتَدِینَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: كأن لم يلبثوا في قبورهم إلا قَدْر ساعةٍ من النهار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٤٢<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: كأن لم يلبثوا في الدنيا إلا ساعة من النهار، قَصُرَت الدنيا في أعينهم مِن هَوْل ما استقبلوا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٤٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمر- في قوله: <span class="qpc-hafs">﴿يَتَعارَفُونَ بَينَهُم﴾</span>، قال: يعرفُ الرجلُ صاحبَه إلى جنبِه، فلا يستطيعُ أن يُكلِّمَه{3}<span class=comment-ref>٣١٢٢</span>. (٧/٦٦٤)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٨٧) في قوله: <span class="qpc-hafs">﴿يتعارفون﴾</span> <b>احتمالات</b>، فقال: «وأمّا قوله: <span class="qpc-hafs">﴿يتعارفون﴾</span> فيحتمل أن يكون معادلة لقوله: <span class="qpc-hafs">﴿ويوم يحشرهم﴾</span>، كأنّه أخبر أنهم يوم الحشر يتعارفون، وهذا التعارف على جهة التلاوم والخزي من بعضهم لبعض. ويحتمل أن يكون في موضع الحال من الضمير في <span class="qpc-hafs">﴿يحشرهم﴾</span>، ويكون معنى التعارف كالذي قبله. ويحتمل أن يكون حالًا من الضمير في <span class="qpc-hafs">﴿يلبثوا﴾</span>، ويكون التعارف في الدنيا، ويجيء معنى الآية: ويوم نحشرهم للقيامة فتنقطع المعرفة بينهم والأسباب، ويصير تعارفهم في الدنيا كساعةٍ من النهار لا قَدْر لها».</div></p><p><div></p><p><p><span class="item-no">٣٤٥٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَوْمَ يَحْشُرُهُمْ﴾</span> من قبورهم إلى القيامة <span class="qpc-hafs">﴿كَأَنْ لَمْ يَلْبَثُوا إلّا ساعَةً مِنَ النَّهارِ﴾</span> يعني: يومًا واحِدًا من أيام الدنيا، <span class="qpc-hafs">﴿يَتَعارَفُونَ بَيْنَهُمْ﴾</span> يعني: يعرفون بعضهم بعضًا، وتبيان ذلك في الفصل{4} في «سَأَلَ سائِلٌ»: <span class="qpc-hafs">﴿يُبَصَّرُونَهُمْ﴾</span> [المعارج:١١] يعني: يعرفونهم، <span class="qpc-hafs">﴿قَدْ خَسِرَ الَّذِينَ كَذَّبُوا بِلِقاءِ اللَّهِ﴾</span> يعني: البعث، <span class="qpc-hafs">﴿وما كانُوا مُهْتَدِينَ﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یَحۡشُرُهُمۡ كَأَن لَّمۡ یَلۡبَثُوۤا۟ إِلَّا سَاعَةࣰ مِّنَ ٱلنَّهَارِ یَتَعَارَفُونَ بَیۡنَهُمۡۚ قَدۡ خَسِرَ ٱلَّذِینَ كَذَّبُوا۟ بِلِقَاۤءِ ٱللَّهِ وَمَا كَانُوا۟ مُهۡتَدِینَ ۝٤٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٤٥<span class="dash">-</span></span> قال الحسن البصري: ذُكِر لنا: أنّ النبي ﷺ قال: «<b>ثلاثة مواطن لا يَسْأَلُ فيها أحدٌ أحدًا: إذا وُضِعت الموازين حتى يعلمَ أيثقُل ميزانُه أم يَخِفُّ، وإذا تَطايَرَت الكتبُ حتى يعلم أيأخُذُ كتابَه بيمينه أم بشماله، وعند الصراط حتى يعلم أيَجُوزُ الصراطَ أم لا يَجُوز</b>»{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٣٤، وتفسير البغوي ٤/١٣٥.تفسير الثعلبي ٥/١٣٤ واللفظ له، وتفسير البغوي ٤/١٣٥ مختصرا.أخرجه ابن أبي حاتم ٦/١٩٥٤-١٩٥٥. وعزاه السيوطي إلى أبي الشيخ.كذا في مطبوعة المصدر، ولعلها «المفصل».تفسير مقاتل بن سليمان ٢/٢٣٩-٢٤٠.أورده يحيى بن سلام في تفسيره ١/٤١٦، وابن الجوزي في بستان الواعظين ص٧٠ بنحوه.
  10,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِمَّا نُرِیَنَّكَ بَعۡضَ ٱلَّذِی نَعِدُهُمۡ أَوۡ نَتَوَفَّیَنَّكَ فَإِلَیۡنَا مَرۡجِعُهُمۡ ثُمَّ ٱللَّهُ شَهِیدٌ عَلَىٰ مَا یَفۡعَلُونَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وإمّا نُرِيَنَّكَ بَعضَ الَّذِي نَعِدُهُم﴾</span> قال: سوء العذابِ في حياتِك، <span class="qpc-hafs">﴿أو نتوفينك﴾</span> قبلُ؛ <span class="qpc-hafs">﴿فَإلَينا مَرجِعُهُم﴾</span>{1}. (٧/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإمّا نُرِيَنَّكَ بَعْضَ الَّذِي نَعِدُهُمْ﴾</span> يوم بدر، <span class="qpc-hafs">﴿أوْ نَتَوَفَّيَنَّكَ﴾</span> قبل يوم بدر؛ <span class="qpc-hafs">﴿فَإلَيْنا مَرْجِعُهُمْ﴾</span> في الآخرة، فأنتقم منهم، <span class="qpc-hafs">﴿ثُمَّ اللَّهُ شَهِيدٌ عَلى ما يَفْعَلُونَ﴾</span> مِن الكُفْر، والتَّكذيب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٨٨، وابن أبي حاتم ٦/١٩٥٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٤٠.
  10,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِكُلِّ أُمَّةࣲ رَّسُولࣱۖ فَإِذَا جَاۤءَ رَسُولُهُمۡ قُضِیَ بَیۡنَهُم بِٱلۡقِسۡطِ وَهُمۡ لَا یُظۡلَمُونَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿ولِكُلِ أُمَّةٍ رَسُولٌ فَإذا جَآءَ رَسُولُهُم﴾</span>، قال: يومَ القيامةِ{1}. (٧/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿قضي بينهم بالقسط﴾</span>، قال: بالعدل{2}<span class=comment-ref>٣١٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٣</span> أشار <u>ابنُ عطية</u> (٤/٤٨٨) إلى قول مجاهد، ثم ذكر <b>قولًا</b> آخر، فقال: «وقيل: المعنى: فإذا جاء رسولهم في الدنيا وبُعِث صاروا مِن حتم الله بالعذاب لقومٍ، والمغفرة لآخرين لغاياتهم، فذلك قضاء بينهم بالقسط».</div></p><p><div></p><p><p><span class="item-no">٣٤٥٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{3}<span class=comment-ref>٣١٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٨٨) أنّ بعض المتأولين قرن هذه الآية بقوله: <span class="qpc-hafs">﴿وما كُنّا مُعَذِّبِينَ حَتّى نَبْعَثَ رَسُولًا﴾</span> [الإسراء:١٥]، و<span class="comment-type-1">وجَّهه</span> بقوله: «وذلك يتفق إمّا بأن نجعل <span class="qpc-hafs">﴿مُعَذِّبِينَ﴾</span> في الآخرة، وإمّا بأن نجعل القضاء بينهم في الدنيا بحيث يصح اشتباه الآيتين».</div></p><p><div></p><p><p><span class="item-no">٣٤٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِكُلِّ أُمَّةٍ رَسُولٌ فَإذا جاءَ رَسُولُهُمْ قُضِيَ بَيْنَهُمْ بِالقِسْطِ﴾</span> يعني: بالحقِّ، وهو العدل، <span class="qpc-hafs">﴿وهُمْ لا يُظْلَمُونَ﴾</span>. وذلك أنّ الله بَعَث الرسلَ إلى أُمَمِهم يدعون إلى عبادة الله، وتركِ عبادة الأصنام والأوثان، فمَن أجابهم إلى ذلك أثابَه اللهُ الجنةَ، ومَن أبى جعل ثوابه النار، فذلك قوله: <span class="qpc-hafs">﴿قُضِيَ بَيْنَهُمْ بِالقِسْطِ وهُمْ لا يُظْلَمُونَ﴾</span> وذلك عند وقت العذاب، <span class="qpc-hafs">﴿وهُمْ لا يُظْلَمُونَ﴾</span> يعني: وهم لا يُنقصون مِن محاسنهم، ولا يُزادون على مساوئهم ما لم يعملوها{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٨٨، وابن أبي حاتم ٦/١٩٥٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٨٩، وابن أبي حاتم ٦/١٩٥٥.علَّقه ابن أبي حاتم ٦/١٩٥٥.تفسير مقاتل بن سليمان ٢/٢٤٠.
  10,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويقولون متى هذا الوعد إن كنتم صادقين﴾</span>: قال أصحابُ رسول الله ﷺ: إنّ لنا يومًا يُوشِك أن نستريح فيه، وننعم فيه. فقال المشركون: <span class="qpc-hafs">﴿متى هذا الوعد إن كنتم صادقين﴾</span>؟ أي: تكذيبًا{1}<span class=comment-ref>٣١٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٨٩) أنّ بعض المفسرين قال: إنّ قولهم هذا على جهة الاستخفاف. و<span class="comment-type-2">انتَقَدَه</span> <span class="mustanad">لمخالفته ظاهر لفظ الآية</span>، فقال: «وهذا لا يَظْهَرُ مِن اللفظة».</div></p><p><div></p><p><p><span class="item-no">٣٤٥٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُونَ﴾</span> يعني: الكفار لنبيهم: <span class="qpc-hafs">﴿مَتى هذا الوَعْدُ إنْ كُنْتُمْ صادِقِينَ﴾</span>. وذلك قوله: <span class="qpc-hafs">﴿ائْتِنا بِعَذابِ اللَّهِ إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span> [العنكبوت:٢٩]{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٥.تفسير مقاتل بن سليمان ٢/٢٤٠.
  10,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل لَّاۤ أَمۡلِكُ لِنَفۡسِی ضَرࣰّا وَلَا نَفۡعًا إِلَّا مَا شَاۤءَ ٱللَّهُۗ لِكُلِّ أُمَّةٍ أَجَلٌۚ إِذَا جَاۤءَ أَجَلُهُمۡ فَلَا یَسۡتَـٔۡخِرُونَ سَاعَةࣰ وَلَا یَسۡتَقۡدِمُونَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ لا أمْلِكُ لِنَفْسِي ضَرًّا﴾</span> يعني: سوءًا، <span class="qpc-hafs">﴿ولا نَفْعًا﴾</span> يعني: في الآخرة، <span class="qpc-hafs">﴿إلّا ما شاءَ اللَّهُ لِكُلِّ أُمَّةٍ أجَلٌ﴾</span> وقت. يقول: لكلِّ أجل وقت؛ لأنّه سبقت الرحمة الغضب، <span class="qpc-hafs">﴿إذا جاءَ أجَلُهُمْ﴾</span> يعني: وقت العذاب؛ <span class="qpc-hafs">﴿فَلا يَسْتَأْخِرُونَ ساعَةً ولا يَسْتَقْدِمُونَ﴾</span> يقول: لا يُؤَخَّر عنهم ساعة، ولا يصيبهم قبلَ الوقت{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٤١.
  10,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَتَىٰكُمۡ عَذَابُهُۥ بَیَـٰتًا أَوۡ نَهَارࣰا مَّاذَا یَسۡتَعۡجِلُ مِنۡهُ ٱلۡمُجۡرِمُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قوله: <span class="qpc-hafs">﴿أرأيتم إن أتاكم عذابه﴾</span>، قال: فُجاءَةً آمِنِين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ أرَأَيْتُمْ إنْ أتاكُمْ عَذابُهُ بَياتًا﴾</span> يعني: صباحًا{2} <span class="qpc-hafs">﴿أوْ نَهارًا ماذا يَسْتَعْجِلُ مِنهُ المُجْرِمُونَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٦.كذا في المطبوع، وتقدم تفسيره للفظ في آية (٧) من سورة الأعراف بأنه ليلا، وهو أصح.تفسير مقاتل بن سليمان ٢/٢٤١.
  10,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَثُمَّ إِذَا مَا وَقَعَ ءَامَنتُم بِهِۦۤۚ ءَاۤلۡـَٔـٰنَ وَقَدۡ كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٥٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿أثم إذا ما وقع﴾</span>: يعني: حتى إذا ما نزل العذاب <span class="qpc-hafs">﴿آمنتم به﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أثُمَّ إذا ما وقَعَ﴾</span> يعني: قول القرآن <span class="qpc-hafs">﴿آمَنتُمْ بِهِ آلْآنَ﴾</span> حين لم تنفعكم <span class="qpc-hafs">﴿وقَدْ كُنْتُمْ بِهِ﴾</span> يعني: بالعذاب <span class="qpc-hafs">﴿تَسْتَعْجِلُونَ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٦١-، وأورد عقبه: <span class="qpc-hafs">﴿الآن وقد كنتم به تستعجلون﴾</span> أي: يُقال لهم إذا آمنوا عند نزول العذاب: الآن تؤمنون حين لا ينفعكم الإيمان.تفسير مقاتل بن سليمان ٢/٢٤١.
  10,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ قِیلَ لِلَّذِینَ ظَلَمُوا۟ ذُوقُوا۟ عَذَابَ ٱلۡخُلۡدِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿ذوقوا﴾</span>، يعني: العقوبة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ قِيلَ لِلَّذِينَ ظَلَمُوا﴾</span> يعني: كفروا <span class="qpc-hafs">﴿ذُوقُوا عَذابَ الخُلْدِ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هَلۡ تُجۡزَوۡنَ إِلَّا بِمَا كُنتُمۡ تَكۡسِبُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٦١<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع بن أنس- قوله: <span class="qpc-hafs">﴿تكسبون﴾</span>، يعني: مِن الخطيئة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ تُجْزَوْنَ إلّا بِما كُنْتُمْ تَكْسِبُونَ﴾</span> مِن الشِّرك. يقول: جزاءُ الشِّرك جهنمُ{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.
  10,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَسۡتَنۢبِـُٔونَكَ أَحَقٌّ هُوَۖ قُلۡ إِی وَرَبِّیۤ إِنَّهُۥ لَحَقࣱّۖ وَمَاۤ أَنتُم بِمُعۡجِزِینَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قوله: <span class="qpc-hafs">﴿بمعجزين﴾</span>، قال: بمُسابِقين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَسْتَنْبِئُونَكَ﴾</span> يقول: يسألونك <span class="qpc-hafs">﴿أحَقٌّ هُوَ؟﴾</span> يعني: العذاب الذي تَعِدُنا به، ويُقال: القرآن الذي أُنزِل إليك أحقٌّ هو؟ <span class="qpc-hafs">﴿قُلْ إي ورَبِّي﴾</span> يعني: نعم، وإلهي، <span class="qpc-hafs">﴿إنَّهُ﴾</span> يعني: العذاب <span class="qpc-hafs">﴿لَحَقٌّ﴾</span> يعني: لَكائِن، <span class="qpc-hafs">﴿وما أنْتُمْ بِمُعْجِزِينَ﴾</span> يعني: بِسابِقِيَّ بأعمالكم الخبيثة في الدنيا قبل الآخرة{2}<span class=comment-ref>٣١٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٢٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٩١) أنّ قوله: <span class="qpc-hafs">﴿أحَقٌّ هُوَ﴾</span> قيل: إنّه الإشارة إلى الشرع والقرآن. وقيل: إنّه إلى الوعيد. و<span class="comment-type-3">رجَّح</span> الثاني بقوله: «وهو الأظهر». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥٦.تفسير مقاتل بن سليمان ٢/٢٤١.