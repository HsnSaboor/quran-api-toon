56,41," <q>﴿وَأَصۡحَـٰبُ ٱلشِّمَالِ مَاۤ أَصۡحَـٰبُ ٱلشِّمَالِ ۝٤١﴾</q> - تفسير ٧٥١١٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</q>: ما لهم، وما أعدّ لهم{1}. (١٤/٢٥٠) ٧٥١١٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</q>، قال: ماذا لهم؟ وماذا أُعِدّ لهم؟{2}. (١٤/٢٠٩) ٧٥١٢٠- قال مقاتل بن سليمان: <q>﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</q>، يقول: ما لأصحاب الشمال من الشرّ، ثم ذكر ما أُعدّ لهم في الآخرة من الشرّ{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٠.
56,42," <q>﴿فِی سَمُومࣲ﴾</q> - تفسير ٧٥١٢١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فِي سَمُومٍ﴾</q>، قال: فَيْح نار جهنم{1}. (١٤/٢٥٠) ٧٥١٢٢- قال مقاتل بن سليمان: <q>﴿فِي سَمُومٍ﴾</q> يعني: ريحًا حارّة تخرج مِن الصخرة التي في جهنم، فتقطّع الوجوه وسائر اللحوم{2}. (ز) <q>﴿وَحَمِیمࣲ ۝٤٢﴾</q> - تفسير ٧٥١٢٣- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <q>﴿وحَمِيمٍ﴾</q> الماء الحارُّ الذي قد انتهى حرُّه، فليس فوقه حرّ{1}. (١٤/٢٥٠) ٧٥١٢٤- قال مقاتل بن سليمان: ثم قال: <q>﴿وحَمِيمٍ﴾</q> يعني: الحار الشديد الذي قد انتهى حرّه{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٠.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٠.
56,43," <q>﴿وَظِلࣲّ مِّن یَحۡمُومࣲ ۝٤٣﴾</q> - تفسير ٧٥١٢٥- عن عبد الله بن عباس -من طريق علي- <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: من دُخان أسود. وفي لفظ: من دُخان جهنم{1}. (١٤/٢٠٩) ٧٥١٢٦- عن عبد الله بن عباس -من طريق يزيد بن الأصمّ- يقول في: <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: هو ظِلّ الدُّخان{2}. (ز) ٧٥١٢٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: مِن دخان جهنم{3}. (١٤/٢٥٠) ٧٥١٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: من دُخان جهنم{4}. (١٤/٢٠٩) ٧٥١٢٩- عن الضَّحّاك بن مُزاحِم، قال: النار سوداء، وأهلها سُود، وكلّ شيء فيها أسود{5}. (١٤/٢١٠) ٧٥١٣٠- عن عكرمة مولى ابن عباس -من طريق سِماك- أنه قال في هذه الآية: <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: الدُّخان{6}. (ز) ٧٥١٣١- عن أبي مالك [الغفاريّ] -من طريق إسماعيل بن أبي خالد- <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: الدُّخان{7}. (١٤/٢١٠) ٧٥١٣٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: من دُخان{8}. (١٤/٢١٠) ٧٥١٣٣- قال مقاتل بن سليمان: <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q> نظيرها في المرسلات، يعني: ظلًّا أسود كهيئة الدُّخان يخرج من جهنم، فيكون فوق رؤوسهم، وهم في السُّرادق ثلاث فِرق، فذلك قوله: <q>﴿انْطَلِقُوا إلى ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</q> [المرسلات:٣٠]، وهي في السُّرادق، وذلك قوله في الكهف [٢٩] أيضًا: <q>﴿أحاطَ بِهِمْ سُرادِقُها﴾</q>، فيَقِيلون تحتها مِن حرّ السُّرادق، فيأخذهم فيها الغثيان، وتقطّع الأمعاء في أجوافهم، والسُّرادق: عنق يخرج من لهب النار، فيدور حول الكفار، ثم يخرج عنق آخر مِن الجانب الآخر، فيصل إلى الآخر، فيحيط بهم السُّرادق، فذلك قوله: <q>﴿أحاطَ بِهِمْ سُرادِقُها﴾</q>، <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q> رؤوسهم ثلاث فِرَق، فيقِيلون فيها قبل دخولهم جهنم، فذلك قوله في الفرقان [٢٤]: <q>﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ﴾</q> في الجنة مع الأزواج <q>﴿خَيْرٌ مُسْتَقَرًّا وأَحْسَنُ مَقِيلًا﴾</q> من مَقيل الكفار في السُّرادق، تحت ظِلٍّ من يحموم{9}. (ز) ٧٥١٣٤- قال عبد الرحمن بن زيد بن أسلم: اليحموم: جبلٌ في جهنم يستغيث إلى ظِلّه أهل النار{10}. (ز) ٧٥١٣٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q>، قال: ظِلّ الدُّخان؛ دُخان جهنم، زعم ذلك بعض أهل العلم{11}٦٤٣٩. (ز) ٦٤٣٩ نقل ابنُ عطية (٨/٢٠١) قولين آخرين في معنى «اليحموم»: الأول: عن ابن عباس أنّ «اليحموم»: «سرادق النار المحيط بأهلها، فإنه يرتفع من كلّ ناحية حتى يُظلّهم». الثاني: عن النقاش، وابن كيسان «أنّ اليحموم: اسم من أسماء جهنم». ",footnotes:1:أخرجه الفريابي وسعيد بن منصور-كما في فتح الباري ٨/٦٢٦-، وابن جرير ٢٢/٣٣٥، كذلك من طريق يزيد وعكرمة، والحاكم ٢/٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٥ (٢١٥٩)، وابن جرير ٢٢/٣٣٤-٣٣٥.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٣، وأخرجه هناد (٢٣٨)، وعبد بن حميد -كما في تغليق التعليق ٤/٣٣٥-، وابن جرير ٢٢/٣٢٦، وبنحوه من طريق منصور، والفريابي -كما في الفتح ٨/٦٢٦-.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٣٥.أخرجه ابن جرير ٢٢/٣٣٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٣٦-٣٣٧ وبنحوه من طريق سعيد بلفظ: ظل الدخان. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٢٠.تفسير الثعلبي ٩/٢١٣ وفيه ابن بريدة، والتصحيح من طبعة دار التفسير ٢٥/٤٨٦، وتفسير القرطبي ١٧/٢١٣.أخرجه ابن جرير ٢٢/٣٣٧.
56,44," <q>﴿لَّا بَارِدࣲ وَلَا كَرِیمٍ ۝٤٤﴾</q> - تفسير ٧٥١٣٦- قال سعيد بن المسيّب: <q>﴿لا بارِدٍ ولا كَرِيمٍ﴾</q> ولا حسن{1}. (ز) ٧٥١٣٧- قال الضحاك بن مزاحم: <q>﴿ولا كَرِيمٍ﴾</q> ولا عَذب{2}. (ز) ٧٥١٣٨- قال مجاهد بن جبر -من طريق رجل- في قول الله: <q>﴿وظِلٍّ مِن يَحْمُومٍ﴾</q> [الواقعة:٤٣]، [...] جهنم، <q>﴿لا بارِدٍ ولا كَرِيمٍ﴾</q> قال: لا بارد المدخل، ولا كريم{3}. (ز) ٧٥١٣٩- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿لا بارِدٍ ولا كَرِيمٍ﴾</q>، قال: كلّ شراب ليس بعَذْبٍ فليس بكريم{4}. (ز) ٧٥١٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لا بارِدٍ ولا كَرِيمٍ﴾</q>، قال: لا بارد المنزل، ولا كريم المنظر{5}. (١٤/٢١٠) ٧٥١٤١- قال مقاتل بن سليمان: ثم نَعتَ الظِّلّ، فقال: <q>﴿لا بارِدٍ﴾</q> المقِيل، <q>﴿ولا كَرِيمٍ﴾</q> يعني: ولا حسن المنزل{6}. (ز) ",footnotes:1:تفسير الثعلبي ٩/٢١٣، وتفسير البغوي ٨/١٨.تفسير الثعلبي ٩/٢١٣.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٥٤ (١٠٥).أخرجه ابن جرير ٢٢/٣٣٧.أخرجه ابن جرير ٢٢/٣٣٧. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٠-٢٢١.
56,45," <q>﴿إِنَّهُمۡ كَانُوا۟ قَبۡلَ ذَ ٰ⁠لِكَ مُتۡرَفِینَ ۝٤٥﴾</q> - تفسير ٧٥١٤٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</q>، قال: مُنَعَّمِين{1}. (١٤/٢١٠) ٧٥١٤٣- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</q>، قال: مشركين جبّارين{2}. (١٤/٢٥٠) ٧٥١٤٤- قال مقاتل بن سليمان: ثم نَعَت أعمالهم التي أوجب الله ﷿ لهم بها ما ذُكر من النار: <q>﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</q>، يعني: مُنَعَّمين في ترْك أمر الله تعالى{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٣٣٨، وابن أبي حاتم -كما في الفتح ٨/٦٢٦، والإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١.
56,46," <q>﴿وَكَانُوا۟ یُصِرُّونَ﴾</q> - تفسير ٧٥١٤٥- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وكانُوا يُصِرُّونَ﴾</q>: يُقيمون{1}. (١٤/٢٥٠) ٧٥١٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وكانُوا يُصِرُّونَ﴾</q>، قال: يُدْمِنون{2}. (١٤/٢١١) ٧٥١٤٧- قال مجاهد بن جبر: <q>﴿يُصِرُّونَ﴾</q> يُديمون{3}. (ز) ٧٥١٤٨- عن الحسن البصري، <q>﴿وكانُوا يُصِرُّونَ﴾</q>، قال: يُدْمنون{4}. (١٤/٢١٠) ٧٥١٤٩- عن إسماعيل السُّدِّيّ، قال: يقيمون{5}. (ز) ٧٥١٥٠- قال مقاتل بن سليمان: <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q> يعني: يُقيمون ...، نظيرها في آل عمران [١٣٥]: <q>﴿ولَمْ يُصِرُّوا عَلى ما فَعَلُوا﴾</q> يعني: ولم يقيموا، وقال في سورة نوح [٧]: <q>﴿وأَصَرُّوا﴾</q> يعني: وأقاموا، وفي سورة الجاثية [٨]: <q>﴿ثُمَّ يُصِرُّ مُسْتَكْبِرًا﴾</q> يعني: ثُمَّ يقيم متكبرًا{6}. (ز) ٧٥١٥١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وكانُوا يُصِرُّونَ﴾</q>، قال: لا يتوبون، ولا يستغفرون، والإصرار عند العرب على الذنب: الإقامة عليه، وترْك الإقلاع عنه{7}. (ز) <q>﴿عَلَى ٱلۡحِنثِ ٱلۡعَظِیمِ ۝٤٦﴾</q> - تفسير ٧٥١٥٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q>، قال: الشِّرك{8}. (١٤/٢١٠) ٧٥١٥٣- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿عَلى الحِنْثِ العَظِيمِ﴾</q>، قال: على الإثم العظيم. قال: هو الشّرك{1}. (١٤/٢٥٠) ٧٥١٥٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عَلى الحِنْثِ﴾</q>، قال: على الذَّنب{10}٦٤٤٠. (١٤/٢١١) ٦٤٤٠ لم يذكر ابنُ جرير (٢٢/٣٣٩-٣٤٠) في معنى: <q>﴿عَلى الحِنْثِ العَظِيمِ﴾</q> سوى قول مجاهد من طريق ابن أبي نجيح، والضَّحّاك، وقتادة، وابن زيد. ٧٥١٥٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿الحِنْثِ العَظِيمِ﴾</q>، قال: الشّرك{11}. (ز) ٧٥١٥٦- عن عامر الشعبي، <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q>، قال: هي الكبائر{4}. (١٤/٢١١) ٧٥١٥٧- قال عامر الشعبي: <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q> اليمين الغَموس{13}. (ز) ٧٥١٥٨- عن الحسن البصري: <q>﴿عَلى الحِنْثِ﴾</q> على الذَّنب{4}. (١٤/٢١٠) ٧٥١٥٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q>، قال: على الذَّنب العظيم{15}. (١٤/٢١١) ٧٥١٦٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q>: هو الشّرك{16}. (ز) ٧٥١٦١- قال مقاتل بن سليمان: <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q>، يعني: يُقيمون على الذَّنب الكبير، وهو الشّرك{6}. (ز) ٧٥١٦٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</q>، قال: الحِنث العظيم: الذَّنب العظيم. قال: وذلك الذَّنب العظيم الشّرك؛ لايتوبون، ولا يستغفرون{11}٦٤٤١. (ز) ٦٤٤١ علَّق ابنُ عطية (٨/٢٠٢) على قول ابن عباس، والضَّحّاك، وقتادة من طريق سعيد، وابن زيد بقوله: «وهذا هو الظاهر». ونقل عن قوم -فيما ذكر مكِّيّ-: «هو الحنث في قَسَمهم الذي يتضمّنه قوله تعالى: <q>﴿وأَقْسَمُوا بِاللَّهِ جَهْدَ أيْمانِهِمْ﴾</q> الآية [النحل:٣٨] في التكذيب بالبعث». ثم علَّق عليه بقوله: «وهذا أيضًا يتضمن الكفر؛ فالقول به على عمومه أولى». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٣، وأخرجه عبد بن حميد -كما في التغليق ٤/٣٣٥-، وابن جرير ٢٢/٣٣٨. وعزاه السيوطي إلى الفريابي، وفي رواية عند ابن جرير من طريق عيسى، عن ابن أبي نجيح: يذهبون أو يُدمنون.علقه البخاري في صحيحه ٤/١٨٤٩. قال الحافظ في الفتح ٨/٦٢٦: «وصله الفريابي لكن لفظه: يُدْمنون -بسكون الدال بعدها ميم ثم نون-». وهي الرواية السابقة.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٦-.تفسير مقاتل بن سليمان ٤/٢٢١.أخرجه ابن جرير ٢٢/٣٣٨.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن جرير، وابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٣، وأخرجه ابن جرير ٢٢/٣٣٩، وعبد بن حميد -كما في التغليق ٤/٣٣٥-. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ٢٢/٣٣٩.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٨.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٠.تفسير مقاتل بن سليمان ٤/٢٢١.أخرجه ابن جرير ٢٢/٣٣٩.
56,47," <q>﴿وَكَانُوا۟ یَقُولُونَ أَىِٕذَا مِتۡنَا وَكُنَّا تُرَابࣰا وَعِظَـٰمًا أَءِنَّا لَمَبۡعُوثُونَ ۝٤٧ أَوَءَابَاۤؤُنَا ٱلۡأَوَّلُونَ ۝٤٨ قُلۡ إِنَّ ٱلۡأَوَّلِینَ وَٱلۡـَٔاخِرِینَ ۝٤٩ لَمَجۡمُوعُونَ إِلَىٰ مِیقَـٰتِ یَوۡمࣲ مَّعۡلُومࣲ ۝٥٠﴾</q> - تفسير ٧٥١٦٣- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وكانُوا يَقُولُونَ أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا﴾</q> إلى قوله: <q>﴿أوَآباؤُنا الأَوَّلُونَ﴾</q>، قال: <q>﴿قُلْ﴾</q> يا محمد: <q>﴿إنَّ الأَوَّلِينَ والآخِرِينَ لَمَجْمُوعُونَ إلى مِيقاتِ يَوْمٍ مَعْلُومٍ﴾</q> قال: يوم القيامة{1}. (١٤/٢٥٠) ٧٥١٦٤- قال مقاتل بن سليمان: <q>﴿وكانُوا﴾</q> مع شِركهم <q>﴿يَقُولُونَ﴾</q> في الدنيا: <q>﴿أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَبْعُوثُونَ﴾</q>، <q>﴿أوَ﴾</q> يُبعث <q>﴿آباؤُنا الأَوَّلُونَ﴾</q> تعجّبًا، يقول الله تعالى: <q>﴿قُلْ﴾</q> لهم يا محمد: <q>﴿إنَّ الأَوَّلِينَ﴾</q> يعني: الأمم الخالية <q>﴿والآخِرِينَ﴾</q> يعني: أُمّة محمد ﷺ <q>﴿لَمَجْمُوعُونَ إلى مِيقاتِ﴾</q> يعني: إلى وقت <q>﴿يَوْمٍ مَعْلُومٍ﴾</q> في الآخرة{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١.
