  56,30,""
  56,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤءࣲ مَّسۡكُوبࣲ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وماءٍ مَسْكُوبٍ﴾</span>، يقول: مصبوب{1}. (١٤/٢٤٩-٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٩٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مَسْكُوبٍ﴾</span>: جارٍ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وماءٍ مَسْكُوبٍ﴾</span>، يعني: مُنصبًّا كثيرًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿وماءٍ مَسْكُوبٍ﴾</span>، قال: جارٍ{4}. (١٤/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٢<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿وماءٍ مَسْكُوبٍ﴾</span>، قال: يجري في غير أخدود{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٤-٥٠٥-.تفسير مقاتل بن سليمان ٤/٢١٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٣١٨.
  56,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفَـٰكِهَةࣲ كَثِیرَةࣲ ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span>، قال: عناقيد الجنة ما بينك وبين صنعاء. وهو بالشام{1}. (١٤/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: سَعَفُ نخل الجنة منها مُقَطّعاتهم{2}، وكِسوتهم{3}. (١٤/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٥<span class="dash">-</span></span> عن يحيى بن صالح، يقول: كُنّا نأتي <span class="name-3">إسماعيل بن عيّاش</span>، فيُكرمنا، ويبرّنا، ويُنزلنا أشرف المنازل، ويُقدّم إلينا من الفواكه ما نتحيّر فيه مِن ألوان التّفاحات والرّمان والسَّفرجل، ويُبَرِّد لنا الماء بالثّلج، ويقول لنا: كُلوا، يا سادتي؛ فإنّ الله تعالى وصف الجنة بصفة الصيف لفواكهها، لا بصفة الشتاء، فقال تعالى: <span class="qpc-hafs">﴿في سدر مخضود وطلح منضود وظل ممدود وماء مسكوب وفاكهة كثيرة لا مقطوعة ولا ممنوعة﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه هناد (١٠٥). وعزاه السيوطي إلى ابن المنذر.المقطعات: الثياب القصار. النهاية (قطع).أخرجه هناد (١٠٢). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر في تاريخ دمشق ٧١/٢٩٢.
  56,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا مَقۡطُوعَةࣲ وَلَا مَمۡنُوعَةࣲ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٠٦<span class="dash">-</span></span> عن أبي هريرة -من طريق أبي صالح- أنه قال: «<b>ما مِن عبد يُسَبِّح لله ﷿ تسبيحة، أو يحمده تحميدة، أو يكبّره تكبيرة، إلا غرس الله ﷿ له بها شجرة في الجنة، أصلها من ذهب، وأعلاها من جوهر، مُكلّلة بالدُّر والياقوت، ثمارها كثدي الأبكار، أليَن مِن الزُّبْد، وأحلى من العسل، كلمّا جنى منها شيئًا عاد مكانه</b>». ثم تلا رسول الله ﷺ هذه الآية: <span class="qpc-hafs">﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</span> لا تنقطع إذا جُنيت، ولا تمتنع من أحد أراد أخْذها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لا مَقْطُوعَةٍ﴾</span> قال: لا تنقطع حينًا وتجيء حينًا مثل فاكهة الدنيا، <span class="qpc-hafs">﴿ولا مَمْنُوعَةٍ﴾</span> كما تُمنع في الدنيا إلا بثمن{3}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي هلال- في قوله: <span class="qpc-hafs">﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</span>، قال: لا يمنعه شوك، ولا بُعْد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</span> لا مقطوعة عنهم أبدًا، هي لهم أبدًا في كلّ حين وساعة، ولا يمنعونها، ليست لها خشونة، أليَن من الزُّبْد، وأحلى من العسل{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في المعجم الأوسط ٣/٢٨٧ (٣١٧١).</p><p>قال الهيثمي في مجمع الزوائد ١٠/٨٩: «رواه الطبراني في الأوسط موقوفًا على أبي هريرة، وفيه سليمان بن أبي كريمة، وهو ضعيف».تفسير البغوي ٨/١٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣١٨.تفسير مقاتل بن سليمان ٤/٢١٩.
  56,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفُرُشࣲ مَّرۡفُوعَةٍ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠١١<span class="dash">-</span></span> عن أبي هريرة، قال: سمعتُ رسول الله ﷺ يقول في هذه الآية: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>، قال: «<b>غِلَظ كل فراش منها كما بين السماء والأرض</b>»{1}. (١٤/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٢<span class="dash">-</span></span> عن أبي سعيد الخدري، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>، قال: «<b>ارتفاعها كما بين السماء والأرض، ومسيرة ما بينهما خمسمائة عام</b>»{2}<span class=comment-ref>٦٤٣١</span>. (١٤/١٩٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/١٩٨) على حديث أبي سعيد الخدري ﵄ بقوله: «وهذا -والله أعلم- لا يثبت، وإن قُدِّر فمتأولٌ خارج عن ظاهره».</div></p><p><div></p><p><p><span class="item-no">٧٥٠١٣<span class="dash">-</span></span> عن عبد الله بن عباس -رفعه- في الفُرُش المرفوعة: «<b>لو طُرِح مِن أعلاها شيءٌ ما بلغ قرارها مائة خريف</b>»{3}. (١٤/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٤<span class="dash">-</span></span> عن أبي أُمامة: سُئل رسول الله ﷺ عن الفُرُش المرفوعة. قال: «<b>لو طُرح فراش من أعلاها لهوى إلى قرارها مائة خريف</b>»{4}. (١٤/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٥<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: مرفوعة على الأسِرّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>، يقول: بعضها فوق بعض{3}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٧<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span> -من طريق القاسم- <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>، قال: لو أنّ أعلاها سقط ما بلغ أسفلها أربعين خريفًا{7}. (١٤/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٨<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق مُطَرّف- قال في قوله: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>، قال: على مسيرة أربعين عامًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> –من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>: بعضها فوق بعض{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي سهل- في قوله: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span>، قال: ارتفاع فراش أهل الجنة مسيرة ثمانين سنة{10}. (١٤/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span> فوق السُّرر، بعضها فوق بعض، على قدر سبعين غرفة من غُرف الدنيا{11}<span class=comment-ref>٦٤٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٢</span> نقل <u>ابنُ عطية</u> (٨/١٩٨) في معنى الآية عن أبي عبيدة: أن المراد بالفُرُش: النساء، و<span class="qpc-hafs">﴿مَرْفُوعَةٍ﴾</span> معناه: في الأقدار والمنازل.</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ القيم</u> (حادي الأرواح ص٢٢٥) <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «ولكن قوله: <span class="qpc-hafs">﴿مَرْفُوعَةٍ﴾</span> يأبى هذا، إلا أن يقال: المراد: رِفعة القدر. وقد تقدم تفسير النبي ﷺ للفُرُش وارتفاعها. فالصواب أنها الفُرُش نفسها، ودلّت على النساء لأنها محلهن غالبًا».</div></p></div>",footnotes:1:أخرجه الخطيب في تاريخه ٦/١٠٩ (١٦٥٢)، وابن الجوزي في الموضوعات ٣/٢٥٤-٢٥٥.</p><p>قال ابن الجوزي: «هذا حديث لا يصح». وقال السيوطي في اللآلئ المصنوعة ٢/٣٧٦: «لا يصح». وقال الشوكاني في الفوائد المجموعة ص٣١٨ (٦٤): «في إسناده وضّاع».أخرجه أحمد ١٨/٢٤٧ (١١٧١٩)، والترمذي ٤/٥٠٧ (٢٧١٥)، ٥/٤٨٧ (٣٥٧٨)، وابن حبان ١٦/٤١٨-٤١٩ (٧٤٠٥)، وابن جرير ٢٢/٣١٩.</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث رشدين بن سعد».عزاه السيوطي إلى ابن مردويه.أخرجه الطبراني في الكبير ٨/٢٤٢ (٧٩٤٧)، وأبو نعيم الأصبهاني في صفة الجنة ٢/١٩٦ (٣٥٦).</p><p>قال الهيثمي في المجمع ٧/١٢٠ (١١٣٩٩): «رواه الطبراني، وفيه جعفر بن الزبير الحنفي، وهو ضعيف». وقال الألباني في الضعيفة ١٢/٨٧٥ (٥٩٤٢): «ضعيف جدًّا».تفسير الثعلبي ٩/٢٠٩.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٣/١٤٠، وهناد (٧٩)، وابن أبي الدنيا في صفة الجنة (١٦١). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٩-.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٠١-٤٠٢ (٣٦٤٨١)، وأبو نعيم في حلية الأولياء ٥/٣٧٩.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٤-٥٠٥-.أخرجه هناد (٧٨).تفسير مقاتل بن سليمان ٤/٢١٩.
  56,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّاۤ أَنشَأۡنَـٰهُنَّ إِنشَاۤءࣰ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٢٢<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ، في قوله: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: «<b>إنّ مِن المنشآت</b>: <b>اللاتي كُنّ في الدنيا عجائز عُمشًا رُمصًا</b>»{1}. (١٤/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٣<span class="dash">-</span></span> عن سلمة بن يزيد الجُعْفي: سمعتُ النبيَّ ﷺ يقول في قوله: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: «<b>الثَّيِّب والأبكار اللاتي كُنّ في الدنيا</b>»{2}. (١٤/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٤<span class="dash">-</span></span> عن جعفر بن محمد، عن أبيه، عن جدّه، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: «<b>أنبَتناهنّ</b>»{3}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span> خلَقهن غير خلْقهن الأول{4}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: هؤلاء نساء أهل الجنة، وهؤلاء العُجُزُ الرُّمْصُ، يقول: خلَقهم خلْقًا{3}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: خلقناهن خلْقًا جديدًا{6}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: خلَقهن خلْقًا غير خلْقهن الأول{6}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: النساء{6}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٠<span class="dash">-</span></span> عن <span class="name-2">صفوان بن مُحْرِز</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا﴾</span>، قال: واللهِ، إنّ منهنّ العُجُزَ الزُّحُفَ، صيَّرهنَّ الله كما تسمعون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: يعني: أزواج القوم{6}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، قال: خلقناهن خلْقًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي هلال- في قوله: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا﴾</span>، قال: إنّ منهنّ لَلعُجُز الرُّجَّف، أنشأهن الله في هذا الخلْق{12}<span class=comment-ref>٦٤٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٣</span> نقل <u>ابنُ عطية</u> (٨/١٩٩) في معنى الآية عن قتادة أنّ «الضمير عائد على الحور العين المذكورات قبل». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">-مستندًا إلى الدلالات العقلية</span>- قائلًا: «وهذا فيه بُعد؛ لأنّ تلك قصة قد انقضت جملة». ثم نقل عن أبي عبيدة قوله: «قد ذكرَهُنَّ في قوله تعالى: <span class="qpc-hafs">﴿وفُرُشٍ مَرْفُوعَةٍ﴾</span> فلذلك ردَّ الضمير وإن لم يتقدم ذكر لدلالة المعنى على المقصد». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وهذا كقوله تعالى: <span class="qpc-hafs">﴿حَتّى تَوارَتْ بِالحِجابِ﴾</span> [ص:٣٢] ونحوه».</div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، يعني: ما ذُكِر مِن الحُور العِين قبل ذلك، فنَعتهنّ في التقديم، يعني: نشأ أهل الدنيا العُجز الشّمط، يقول: خلَقهن في الآخرة خلْقًا بعد الخلق الأول في الدنيا{13}<span class=comment-ref>٦٤٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (٣/١١٠) على قول مقاتل بقوله: «ويؤيد هذا التفسير حديث أنس المرفوع: «<b>هنّ عجائزكم العُمْش الرُّمْص</b>» ... ويؤيده ...». ثم ذكر حديث عائشة الوارد في الآثار المتعلقة بالآية وما في معناهما، ثم نقل عن مقاتل قولًا آخر وأنه اختيار الزجاج «أنهن الحُور العين التي ذكرهن، قيل: أنشأهن الله ﷿ لأوليائه لم يقع عليهن ولادة». ثم <span class="comment-type-3">رجَّح</span> أن «الظاهر أنّ المراد: أنشأهن الله تعالى في الجنة إنشاء. ويدل عليه وجوه: <b>أحدها:</b> أنه قد قال في حقّ السابقين: <span class="qpc-hafs">﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿كَأَمْثالِ اللُؤْلُؤِ المَكْنُونِ﴾</span>، فذكر سُررهم وآنيتهم وشرابهم وفاكهتهم وطعامهم وأزواجهم من الحور العين، ثم ذكر أصحاب الميمنة وطعامهم وشرابهم وفرشهم ونساءهم، والظاهر أنهن مثل نساء من قبلهن خلقهن في الجنة. <b>الثاني:</b> أنه سبحانه قال: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، وهذا ظاهر أنه إنشاء أول لا ثان؛ لأنه سبحانه حيث يريد الإنشاء الثاني يقيّده بذلك، كقوله: <span class="qpc-hafs">﴿وأَنَّ عَلَيْهِ النَّشْأَةَ الأُخْرى﴾</span> [النجم:٤٧]. <b>الثالث:</b> أنّ الخطاب بقوله: <span class="qpc-hafs">﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</span> إلى آخره للذكور والإناث، والنشأة الثانية أيضًا عامة للنوعين، وقوله: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</span>، ظاهره اختصاصهن بهذا الإنشاء، وتأمّل تأكيده بالمصدر، والحديث لا يدل على اختصاص العجائز المذكورات بهذا الوصف، بل يدل على مشاركتهن للحُور العين في هذه الصفات المذكورة، فلا يتوهم انفراد الحور العين عنهن بما ذكر مِن الصفات، بل هي أحقّ به منهن، فالإنشاء واقع على الصنفين».</div></p></div>",footnotes:1:أخرجه الترمذي ٥/٤٨٩ (٣٥٨٠)، وابن جرير ٢٢/٣٢١.</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه مرفوعًا إلا من حديث موسى بن عبيدة، وموسى بن عبيدة ويزيد بن أبان الرّقاشي يضعفان في الحديث». وقال الألباني في الضعيفة ٧/١٨٨ (٣٢٠٤): «ضعيف».أخرجه الطبراني في الكبير ٧/٤٠، وابن قانع في معجم الصحابة ١/٢٧٤، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٣١- واللفظ لهما.</p><p>قال الهيثمي في المجمع ٧/٢٥٦ (١١٣٩٧): «رواه الطبراني، وفيه جابر الجعفي، وهو ضعيف».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٢، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٥٥ (٣٦٣٠٣).عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧١، وابن جرير ٢٢/٣٢٠.أخرجه ابن جرير ٢٢/٣٢٢.تفسير مقاتل بن سليمان ٤/٢١٩.
  56,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهُنَّ أَبۡكَارًا ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٣٥<span class="dash">-</span></span> عن الحسن البصري، قال: أتتْ عجوزٌ، فقالت: يا رسول الله، ادعُ الله أن يُدخلني الجنة. فقال: «<b>يا أُمّ فلان، إنّ الجنة لا يدخلها عجوز</b>». فولّت تبكي، قال: «<b>أخبِروها أنها لا تدخلها وهي عجوز</b>. <b>إنّ الله يقول:</b> <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا﴾</span>{1}. (١٤/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَجَعَلْناهُنَّ أبْكارًا﴾</span>، قال: عذارى{2}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا عُرُبًا أتْرابًا﴾</span>، قال: هُنّ مِن بني آدم، نساءكن في الدنيا يُنشئهن الله أبكارًا عذارى أترابًا عُربًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَجَعَلْناهُنَّ أبْكارًا﴾</span>، يقول: عذارى{4}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول: قوله: <span class="qpc-hafs">﴿أبْكارًا﴾</span>، يقول: عذارى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَجَعَلْناهُنَّ أبْكارًا﴾</span>، قال: عذارى{6}. (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَجَعَلْناهُنَّ أبْكارًا﴾</span> شَوابًّا{7} كلّهن على ميلاد واحد؛ بنات ثلاث وثلاثين سنة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٢<span class="dash">-</span></span> قال <span class="name-3">المسيّب بن شريك</span>: هنّ عجائز الدنيا، أنشأهنّ الله تعالى خلْقًا جديدًا، كلّما أتاهنّ أزواجهنّ وجَدُوهُنَّ أبكارًا. وذكر المسيّب عن غيره: أنهنَّ فُضِّلن على الحُور العين بصلاتهنّ في الدنيا{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهُنَّ أَبۡكَارًا ۝٣٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٤٣<span class="dash">-</span></span> عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «<b>إنّ أهل الجنة إذا جامعوا نساءهم عُدْنَ أبكارًا</b>»{10}. (١٤/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٤<span class="dash">-</span></span> عن عائشة، قالت: دخل النبيُّ ﷺ عَلَيَّ وعندي عجوز، فقال: «<b>مَن هذه؟</b>». قلتُ: إحدى خالاتي. قال: «<b>أما إنه لا يدخل الجنة العُجُز</b>». فدخل العجوزَ مِن ذلك ما شاء الله، فقال النبيُّ ﷺ: «<b>إنّا أنشأناهن خلقًا آخر</b>»{11}. (١٤/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٥<span class="dash">-</span></span> عن عائشة: أنّ النبيَّ ﷺ أتَتْه عجوزٌ من الأنصار، فقالت: يا رسول الله، ادعُ الله أن يُدخلني الجنة. فقال: «<b>إنّ الجنةَ لا يدخلها عجوز</b>». فذهب يصلي، ثم رجع، فقالت عائشة: لقد لَقِيَتْ مِن كلمتك مشقّة، فقال: «<b>إنّ ذلك كذلك؛ إنّ الله إذا أدخلهنّ الجنة حوّلهنّ أبكارًا</b>»{12}. (١٤/١٩٩)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٢-، وعبد بن حميد -كما في تفسير ابن كثير ٨/٩-، والترمذي في الشمائل (٢٣٢)، والبيهقي في البعث (٣٨٢). وعزاه السيوطي إلى ابن المنذر.</p><p>وحسنه الألباني في غاية المرام (٣٧٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٣٢٢.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٢٢.أخرجه عبد الرزاق ٢/٢٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.جمع شابَّة. لسان العرب (شبب).تفسير مقاتل بن سليمان ٤/٢١٩.تفسير البغوي ٨/١٤.أخرجه الطبراني في الصغير ١/١٦٠ (٢٤٩)، والبزار -كما في كشف الأستار ٤/١٩٨-١٩٩ (٣٥٢٧)-، والثعلبي ٨/١٣١.</p><p>قال الطبراني: «لم يروه عن عاصم إلا شريك، تفرّد به معلى بن عبد الرحمن». وقال الهيثمي في المجمع ١٠/٤١٧ (١٨٧٥٣): «رواه البزار، والطبراني في الصغير، وفيه معلى بن عبد الرحمن الواسطي، وهو كذاب».أخرجه البيهقي في البعث والنشور ص٢١٦ (٣٤٣).</p><p>إسناده ضعيف؛ فيه ليث بن أبي سليم، قال عنه ابن حجر في التقريب (٥٦٨٥): «صدوق اختلط جدًّا، ولم يتميز حديثه؛ فتُرِك».أخرجه الطبراني في الأوسط ٥/٣٥٧ (٥٥٤٥)، وأبو نعيم في صفة الجنة ٢/٢٢٣ (٣٩١).</p><p>قال الطبراني: «لم يرو هذا الحديثَ عن قتادة إلا سعيد بن أبي عروبة». وقال الهيثمي في المجمع ١٠/٤١٩ (١٨٧٦٤): «رواه الطبراني في الأوسط، وفيه مسعدة بن اليسع، وهو ضعيف».
  56,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عُرُبًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٤٦<span class="dash">-</span></span> عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿عُرُبًا أتْرابًا﴾</span>. قال: «<b>هنّ اللواتي قُبضن في دار الدنيا عجائز رُمْصًا شُمْطًا، خلقهنّ الله بعد الكِبر، فجعلهنّ عذارى، عُرُبًا، متعشِّقات، مُحبّبات، أترابًا على ميلاد واحد</b>»{1}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٧<span class="dash">-</span></span> عن جعفر بن محمد، عن أبيه، قال: قال رسول الله ﷺ في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: «<b>كلامهن عَرَبِيٌّ</b>»{2}. (١٤/٢٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٨<span class="dash">-</span></span> عن <span class="name-1">بُريْدة بن الحَصيب</span>، في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: هي الشَّكِلَةُ{3}، بلغة مكة، المغْنوجة{4}، بلغة المدينة{5}. (١٤/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿عُرُبًا أتْرابًا﴾</span>. قال: هنّ العاشقات لأزواجهنّ، اللاتي خُلِقن مِن الزّعفران، والأتراب: المستويات. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ نابغة بني ذبيان وهو يقول:</p><p>عهدتُ بها سُعدى وسُعدى غَرِيرَة{6} عَروبٌ تَهادى في جوارٍ خَرائِدِ{7}؟{8} (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: عواشق{9}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: عواشق لأزواجهنّ، وأزواجهنّ لهنّ عاشقون{10}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: العَرُوبُ: المَلقَة{11} لزوجها{12}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قال: العُرب: المُتَحَبِّبات المُتَوَدِّدات إلى أزواجهنّ{13}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: العُرُب: الغَنِجة. وفي قول أهل المدينة: الشَّكِلة{14}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: الناقة التي تشتهي الفَحْل يُقال لها: عَرِبة{15}. (١٤/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿عُرُبًا﴾</span>: والعُرب: الشُّوق{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿عُرُبًا﴾</span>: والعُرُب: المُتحبّبات إلى أزواجهن{17}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٨<span class="dash">-</span></span> عن <span class="name-2">تميم بن حَذْلَم</span> -وكان من أصحاب عبد الله- قال: العَربة: الحسنة التبعُّل، وكانت العرب تقول للمرأة إذا كانت حسنة التبعُّل: إنها العَربة{18}<span class=comment-ref>٦٤٣٥</span>. (١٤/٢٠٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٣/١١٢) قول تميم بن حَذْلم أن العَروب: «الحسنة التبعل» بقوله: «يريد: حُسن مواقعتها وملاطفتها لزوجها عند الجماع».</div></p><p><div></p><p><p><span class="item-no">٧٥٠٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: هُنَّ المُتَغَنِّجات{19}. (١٤/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق غالب أبي الهُذيل- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: يشتهين أزواجهنَّ{20}. (١٤/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم الأفطس- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: العُرُب: المتعشّقات{21}. (١٤/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٢<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن بُريْدة بن الحصيب</span> -من طريق صالح بن حيان- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: هي الشَّكِلة، بلغة مكة، المغْنوجة، بلغة المدينة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: عواشق لأزواجهن{23}. (١٤/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: هي الغَلِمةُ{24}{25}. (١٤/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: مُتَحَبِّبات إلى أزواجهن{26}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول: العُرُب: المتحبِّبات{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: العُرُب: المُتحبِّبات إلى أزواجهنّ{28}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيف- قال: عواشق{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٦٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: المغنوجات، والعَربة هي الغَنِجة{30}. (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: المتعشّقات لبُعولتهنّ{31}. (١٤/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: المتحبّبات إلى الأزواج{32}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قرة- <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: عواشق{33}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبيد بن عمير</span> أنه سُئِل عن قوله تعالى: <span class="qpc-hafs">﴿عُرُبًا﴾</span>. قال: أما سمعت أنّ المُحرِم يُقال له: لا تُعرِبها بكلام تُلذّذها به، وهي مُحرِمة{28}. (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٤<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبيد بن عمير</span> -من طريق عثمان بن الأسود- قال: العَربة: التي تشتهي زوجها، ألا ترى أن الرجل يقول للناقة: إنها لعَربة؟!{35}. (١٤/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٥<span class="dash">-</span></span> عن بلال بن أبي بُردة، أنه قال لجلسائه: ما العَروب مِن النساء؟ فماجوا، وأقبل <span class="name-2">إسحاق بن عبد الله بن الحارث النَّوفَليّ</span>، فقال: قد جاءكم مَن يخبركم عنها. فسألوه، فقال: الخَفِرة{36}، المتبذّلة لزوجها. وأنشد:</p><p>يُعْرِبن عند بُعولهن إذا خَلوا وإذا هم خرجوا فهن خِفار{37}. (١٤/٢٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: عُشَّقًا لأزواجهنّ{38}. (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿عربا أترابا﴾</span>، قال: العُرُب: العواشق، والأتراب: المستويات{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق أسامة- قال: العَرِبة: هي الحسنة الكلام{40}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٧٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، قال: العُرُب: المتعشِّقات{28}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٠<span class="dash">-</span></span> عن عمرو بن أبي سلمة، قال: سُئل الأوزاعي عن <span class="qpc-hafs">﴿عُرُبًا﴾</span>. قال: سمعتُ يحيى يقول: هنّ العواشق{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: العُرُب: الحسنة الكلام{27}<span class=comment-ref>٦٤٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٢٠٠) على قول ابن زيد بقوله: "وقد تجيء العَروب صفة ذمٍّ على غير هذا المعنى، وهي الفاسدة الأخلاق، كأنها عرَّبت، ومنه قول الشاعر:</p><p>وما بَدَلٌ مِن أُمِّ عثمان سَلْفَعٌ منَ السُّود ورْهاءُ العِنانِ عَريب".</div></p><p><h3><span class="qpc-hafs">﴿أَتۡرَابࣰا ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٨٢<span class="dash">-</span></span> عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قوله: <span class="qpc-hafs">﴿عُرُبًا أتْرابًا﴾</span>. قال: «<b>عُرُبًا متعشِّقات مُحبّبات، أترابًا على ميلاد واحد</b>»{44}. (١٤/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿عُرُبًا أتْرابًا﴾</span>. قال: هُنّ العاشقات لأزواجهنّ، اللاتي خُلِقن مِن الزّعفران، والأتراب: المستويات{45}. (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أتْرابًا﴾</span>، يقول: مستويات{46}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- <span class="qpc-hafs">﴿أتْرابًا﴾</span>، قال: في سِنٍّ واحدٍ؛ ثلاثًا وثلاثين سنة{10}. (١٤/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أتْرابًا﴾</span>: المُصطَحبات اللاتي لا تَغَرْن{17}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- في قوله: <span class="qpc-hafs">﴿أتْرابًا﴾</span>، قال: مستويات{49}. (١٤/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أتْرابًا﴾</span>، قال: أمثالًا{50}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٨٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿أتْرابًا﴾</span>، قال: الأتراب: المستويات{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سلمة بن نُبَيْط- قال: <span class="qpc-hafs">﴿أترابا﴾</span> أمثالًا{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: الأتراب: الأشباه المستويات{28}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك- في قوله: <span class="qpc-hafs">﴿عُرُبًا﴾</span>، قال: المتعشّقات لبُعولتهنّ، والأتراب: المستويات في سِنّ واحد{54}. (١٤/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: الأتراب: المستويات{55}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿أتْرابًا﴾</span>، قال: أقرانًا{28}. (١٤/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿أتْرابًا﴾</span>، قال: مستويات سِنًّا واحدًا{57}. (١٤/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- قال: الأتراب: المستويات{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، قال: الأتراب: على سِنٍّ واحد{28}. (١٤/٢٠٥)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥. وعزاه السيوطي إلى ابن مردويه. وتقدم مطولًا مع تخريجه عند تفسير قوله تعالى: <span class="qpc-hafs">﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</span> [الرحمن:٧٠].أخرجه ابن أبي حاتم -كما في الفتح ٦/٣٢٢، وتفسير ابن كثير ٨/١٢-.</p><p>قال ابن حجر: «وهو ضعيف منقطع».الشَكِلة: المرأة ذات الدَّلِّ. النهاية (شكل).الغُنج في الجارية: تكسّر وتدلّل. النهاية (غنج).عزاه السيوطي إلى ابن جرير، وابن المنذر. وفي تفسير ابن جرير عن ابنه كما سيأتي.الغَرِيرة والغِرَّة: الشابة الحديثة السن التي لم تجرب الأمور. لسان العرب (غرر).الخَرِيدَة والخَرِيد والخَرُود من النساء: البكر التي لم تُمْسَسْ قَط. لسان العرب (خرد).عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٢٤١).أخرجه ابن جرير ٢٢/٣٢٣، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.المَلَق: الودّ واللُّطف الشديد. لسان العرب (ملق).أخرجه ابن جرير ٢٢/٣٢٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٣٢٤.عزاه السيوطي إلى هناد في الزهد. وفي المطبوع منه (٣٤): العُرُب في قول أهل المدينة: الشَّكِلة، وفي قول أهل العراق: الغَنجة.عزاه السيوطي إلى سفيان، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٢٨.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٢٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن جرير ٢٢/٣٢٦، وهناد (٣١). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٦. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٢/٣٢٤، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.أخرجه هناد (٣٠)، وابن جرير ٢٢/٣٢٧، والفريابي -كما في الفتح ٦/٣٢٣-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.الغُلْمَة: هيجان شهوة النكاح من المرأة والرجل وغيرهما. النهاية (غَلِمَ).أخرجه عبد الرزاق ٢/٢٧١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٣، وأخرجه ابن جرير ٢٢/٣٢٦-٣٢٧، وسفيان بن عيينة وعبد بن حميد -كما في تغليق التعليق ٣/٥٠٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٣٢٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٥.أخرجه ابن جرير ٢٢/٣٢٤، كذلك أخرجه بنحوه من طريق عمارة، وابن أبي حاتم -كما في الفتح ٦/٣٢٢- بنحوه. وعزاه السيوطي إلى عبد بن حميد. وتفسير الثعلبي ٩/٢٠٩.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٣-، وابن جرير ٢٢/٥٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه هناد (٣٣). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٤. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٦. وعزاه السيوطي إلى ابن المنذر.الخفر: الحياء. النهاية (خفر).أخرجه وكيع في الغرر (وهو أخبار القضاة ٢/٣٥)، وابن عساكر في تاريخه ٨/٢٤٢-٢٤٣.أخرجه عبد الرزاق ٢/٢٧١، وابن جرير ٢٢/٣٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. كما أخرجه ابن جرير ٢٢/٣٢٧ من طريق سعيد، وزاد: يحببن أزواجهن حبًّا شديدًا.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١١.أخرجه ابن جرير ٢٢/٣٢٥، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٧.أخرجه ابن جرير ٢٢/٣٢٧.تقدم الحديث في أول الآية.تقدم الأثر في أول الآية.أخرجه البيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير ٢٢/٣٢٩ من طريق عطية.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.أخرجه هناد (٣٨)، وابن جرير ٢٢/٣٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٣، وأخرجه ابن جرير ٢٢/٣٢٩، وسفيان بن عيينة وعبد بن حميد -كما في تغليق التعليق ٣/٥٠٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٣٢٩.أخرجه هناد في الزهد ١/٦٠.عزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٣-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى هناد، وعبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧١، وابن جرير ٢٢/٣٢٩، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١١.عزاه السيوطي إلى عبد بن حميد.
  56,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّأَصۡحَـٰبِ ٱلۡیَمِینِ ۝٣٨ ثُلَّةࣱ مِّنَ ٱلۡأَوَّلِینَ ۝٣٩ وَثُلَّةࣱ مِّنَ ٱلۡـَٔاخِرِینَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٠٩٨<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: تحدّثنا ذاتَ ليلةٍ عند رسول الله ﷺ حتى أكْدانا الحديث، فلما أصبحنا غدَونا على رسول الله ﷺ، فقال: «<b>عُرِضَت عليَّ الأنبياء بأتباعها مِن أُممها، فإذا النبيُّ معه الثُّلّة مِن أُمّته، وإذا النبيُّ ليس معه أحد، وقد أنبأكم اللهُ عن قوم لوط، فقال: <span class="qpc-hafs">﴿ألَيْسَ مِنكُمْ رَجُلٌ رَشِيدٌ﴾</span></b> [هود:٧٨]. <b>حتى مرّ موسى ﵇ ومَن معه مِن بني إسرائيل، قلتُ: يا ربّ، فأين أُمّتي؟ قال: انظر عن يمينك، فإذا الظِّرابُ</b>{1} <b>ظِراب مكة قد سُدّ مِن وجوه الرجال، قال: أرضيتَ، يا محمد؟ قلتُ: رضيتُ، ربِّ. قال: انظر عن يسارك، فإذا الأُفق قد سُدّ مِن وجوه الرجال. قال: أرضيتَ، يا محمد؟ قلتُ: رضيتُ، ربِّ. قال: فإنّ مع هؤلاء سبعين ألفًا يدخلون الجنة بغير حساب</b>». فأتى عُكّاشة بن مِحْصن الأسديّ، فقال: يا رسول الله، ادعُ الله أن يجعلني منهم. قال: «<b>اللهم، اجعله منهم</b>». ثم قام رجل آخر، فقال: يا رسول الله، ادعُ الله أن يجعلني منهم. فقال: «<b>سبقك بها عُكّاشة</b>». ثم قال لهم النبيُّ ﷺ: «<b>إن استطعتم -بأبي أنتم وأمي- أن تكونوا مِن السبعين فكُونوا، فإن عجزتم وقصّرتم فكُونوا من أصحاب الظِّراب، فإن عجزتم وقصّرتم فكُونوا من أصحاب الأُفق؛ فإنّي قد رأيت أناسًا يَتَهارَشُونَ كثيرًا</b>». ثم قال: «<b>إنّي لَأرجو أن تكونوا شطر أهل الجنة</b>». فكبّر القوم، ثم تلا هذه الآية: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، فتذاكروا بينهم مَن هؤلاء السبعون الألف، فقال رسول الله ﷺ: «<b>هم الذين لا يَسْتَرقُون، ولا يَتطيّرون، وعلى ربهم يتوكلون</b>»{2}. (١٤/٢٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٠٩٩<span class="dash">-</span></span> عن أبي بَكرة، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، قال: «<b>جميعهما مِن هذه الأُمّة</b>»{3}. (١٤/٢٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٠<span class="dash">-</span></span> عن ابن عباس، <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، قال: قال النبي ﷺ: «<b>هما جميعًا من أُمّتي</b>»{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠١<span class="dash">-</span></span> عن <span class="name-1">أبي بَكرة</span> -من طريق عُقبة بن صُهْبان- في قوله: <span class="qpc-hafs">﴿ثلة من الأولين وثلة من الآخرين﴾</span>، قال: كلٌّ مِن هذه الأُمّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، قال: الثلَّتان جميعًا مِن هذه الأُمّة{6}<span class=comment-ref>٦٤٣٧</span>. (١٤/٢٠٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٧</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٢٠١) قول ابن عباس بقوله: «فعلى هذا التابعون بإحسان ومَن جرى مجراهم ثلَّةٌ أولى، وسائر الأمة ثلَّةٌ أخرى في آخر الزمان».</div></p><p><div></p><p><p><span class="item-no">٧٥١٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن علي- قال: إنّ أهل الجنة مائة وعشرون صفًّا؛ فأُمّة محمد ﷺ ثمانون صفًّا، وسائر الأمم أربعون صفًّا، وسابقو الأمم ومقرّبوها أكثر من سابقي هذه الأُمّة ومُقرّبيها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، يقول: طائفة من الأوّلين، وطائفة من الآخرين{8}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٥<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٦<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٧<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٨<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span>، قالوا: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</span> مِن سابقي هذه الأُمّة، <span class="qpc-hafs">﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> مِن آخر هذه الأُمّة في آخر الزمان{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</span>، قال: أُمّة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله تعالى: <span class="qpc-hafs">﴿ثلة من الأولين وثلة من الآخرين﴾</span>، قال: مثل قوله: <span class="qpc-hafs">﴿فمنهم ظالم لنفسه ومنهم مقتصد ومنهم سابق بالخيرات﴾</span> [فاطر:٣٢]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١١<span class="dash">-</span></span> عن عبد الله بن الحارث -من طريق عوف- قال: كلهم في الجنة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق سفيان-: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</span> من الأمم، <span class="qpc-hafs">﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> أُمّة محمد ﷺ{13}<span class=comment-ref>٦٤٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٨</span> ذكر <u>ابنُ عطية</u> (٨/٢٠٠) قول الحسن أنّ «الأوّلين: سالف الأمم، منهم جماعة عظيمة هم أصحاب اليمين، والآخرين: هذه الأُمّة، منهم جماعة عظيمة أهل يمين». ثم <span class="comment-type-4">علَّق</span> بقوله: «بل جميعهم إلا مَن كان من السابقين».</div></p><p><div></p><p><p><span class="item-no">٧٥١١٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق أبي هلال- <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، قال: كانوا يقولون: كلّهم من هذه الأُمّة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٤<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span>، في قوله: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>، قال: كثير من الأوّلين، وكثير من الآخرين{15}. (١٤/٢٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- أنه بلَغه: أنّ النبي ﷺ قال: «<b>أتَرْضَون أن تكونوا ربع أهل الجنة؟</b>». قالوا: نعم. قال: «<b>أتَرْضَون أنْ تكونوا ثلث أهل الجنة؟</b>». قالوا: نعم. قال: «<b>والذي نفسي بيده، إني لأرجو أن تكونوا شطر أهل الجنة</b>». ثم تلا قتادة: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> مِن مؤمني هذه الأمة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> يعني: جَمْع مِن الأوّلين، يعني: الأمم الخالية، <span class="qpc-hafs">﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</span> يعني: أُمّة محمد ﷺ، فإنّ أُمّة محمد أكثر أهل الجنة، وهم سابقو الأمم الخالية ومُقرّبوها{18}. (ز)</p></p><p></div></p></div>",footnotes:1:الظِّراب: الجبال الصِّغار. النهاية (ظرب).أخرجه البزار ٤/٢٧٠-٢٧٢ (١٤٤١)، والحاكم ٤/٦٢١ (٨٧٢١)، وابن حبان ١٤/٣٤١-٣٤٣ (٦٤٣١)، والثعلبي ٩/٢١٢-٢١٣، وابن جرير ٢٢/٣٣١-٣٣٢، جميعهم عن عمران بن حصين، عن عبد الله بن مسعود.</p><p>قال البزار: «هذا الحديث لا نعلمه يُروى عن عبد الله عن النبي ﷺ إلا من هذا الوجه بهذا الإسناد». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه بهذه السياقة». ووافقه الذهبي. وقال الهيثمي في المجمع ١٠/٤٠٦ (١٨٦٩٢): «رواه أحمد بأسانيد، والبزار أتم منه، والطبراني، وأبو يعلى باختصار كثير، وأحد أسانيد أحمد والبزار رجاله رجال الصحيح».أخرجه أبو داود الطيالسي في مسنده ٢/٢٠٩ (٩٢٧)، وابن الأعرابي في معجمه ٣/٩٣٨ (١٩٣٩).</p><p>قال الدارقطني في العلل ٧/١٦٤ (١٢٧٧): «لم يثبت». وقال الهيثمي في المجمع ٧/١١٨-١١٩ (١١٣٩٥): «رواه الطبراني بإسنادين؛ رجال أحدهما رجال الصحيح، غير علي بن زيد، وهو ثقة، سيئ الحفظ».أخرجه ابن بشران في أماليه ٢/٢٩٨ (١٥٤٨)، وبيبي في جزئها ص٤٤ (٣٣)، وابن جرير ٢٢/٣٣٤، والثعلبي ٩/٢١٣.</p><p>قال ابن القيسراني في ذخيرة الحفاظ ٢/١١٩٠ (٢٥٤٢): «رواه أبان بن أبي عيّاش، عن سعيد بن جُبَير، عن ابن عباس في هذه الآية. وأبان متروك الحديث». وقال الزيلعي في تخريج الكشاف ٣/٤٠٤: «ضعّفه الطبري».أخرجه الفسوي في المعرفة والتاريخ ٣/٢٤.عزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن مردويه.أخرجه مقاتل بن سليمان ٤/٢١٩-٢٢٠.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢٠٩، وتفسير البغوي ٨/١٨.تفسير مجاهد ص٦٤٣، وأخرجه عبد بن حميد -كما في تغليق التعليق ٤/٣٣٥-، وابن جرير ٢٢/٣٣٠، والفريابي -كما في الفتح ٨/٦٢٦-.أخرجه أبو جعفر الرملي في جزئه ص٦٢ (تفسير مسلم الزنجي).أخرجه ابن جرير ٢٢/٣٣٣.أخرجه ابن جرير ٢٢/٣٣٠.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٣-.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٦-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧١، والبخاري في الرقاق ٧/١٩٥، ومسلم في الإيمان ١/١٣٩، والترمذي في صفة الجنة ٤/٨٩، وابن جرير ٢٢/٣٣٣.تفسير البغوي ٨/١٦.تفسير مقاتل بن سليمان ٤/٢١٩.
  56,39,""
  56,40,""
  56,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ ٱلشِّمَالِ مَاۤ أَصۡحَـٰبُ ٱلشِّمَالِ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</span>: ما لهم، وما أعدّ لهم{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</span>، قال: ماذا لهم؟ وماذا أُعِدّ لهم؟{2}. (١٤/٢٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</span>، يقول: ما لأصحاب الشمال من الشرّ، ثم ذكر ما أُعدّ لهم في الآخرة من الشرّ{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٠.
  56,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِی سَمُومࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فِي سَمُومٍ﴾</span>، قال: فَيْح نار جهنم{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي سَمُومٍ﴾</span> يعني: ريحًا حارّة تخرج مِن الصخرة التي في جهنم، فتقطّع الوجوه وسائر اللحوم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحَمِیمࣲ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿وحَمِيمٍ﴾</span> الماء الحارُّ الذي قد انتهى حرُّه، فليس فوقه حرّ{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وحَمِيمٍ﴾</span> يعني: الحار الشديد الذي قد انتهى حرّه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٠.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٠.
  56,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَظِلࣲّ مِّن یَحۡمُومࣲ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: من دُخان أسود. وفي لفظ: من دُخان جهنم{1}. (١٤/٢٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يزيد بن الأصمّ- يقول في: <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: هو ظِلّ الدُّخان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: مِن دخان جهنم{3}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: من دُخان جهنم{4}. (١٤/٢٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٢٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، قال: النار سوداء، وأهلها سُود، وكلّ شيء فيها أسود{5}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- أنه قال في هذه الآية: <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: الدُّخان{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [الغفاريّ]</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: الدُّخان{7}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: من دُخان{8}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span> نظيرها في المرسلات، يعني: ظلًّا أسود كهيئة الدُّخان يخرج من جهنم، فيكون فوق رؤوسهم، وهم في السُّرادق ثلاث فِرق، فذلك قوله: <span class="qpc-hafs">﴿انْطَلِقُوا إلى ظِلٍّ ذِي ثَلاثِ شُعَبٍ﴾</span> [المرسلات:٣٠]، وهي في السُّرادق، وذلك قوله في الكهف [٢٩] أيضًا: <span class="qpc-hafs">﴿أحاطَ بِهِمْ سُرادِقُها﴾</span>، فيَقِيلون تحتها مِن حرّ السُّرادق، فيأخذهم فيها الغثيان، وتقطّع الأمعاء في أجوافهم، والسُّرادق: عنق يخرج من لهب النار، فيدور حول الكفار، ثم يخرج عنق آخر مِن الجانب الآخر، فيصل إلى الآخر، فيحيط بهم السُّرادق، فذلك قوله: <span class="qpc-hafs">﴿أحاطَ بِهِمْ سُرادِقُها﴾</span>، <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span> رؤوسهم ثلاث فِرَق، فيقِيلون فيها قبل دخولهم جهنم، فذلك قوله في الفرقان [٢٤]: <span class="qpc-hafs">﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ﴾</span> في الجنة مع الأزواج <span class="qpc-hafs">﴿خَيْرٌ مُسْتَقَرًّا وأَحْسَنُ مَقِيلًا﴾</span> من مَقيل الكفار في السُّرادق، تحت ظِلٍّ من يحموم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: اليحموم: جبلٌ في جهنم يستغيث إلى ظِلّه أهل النار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span>، قال: ظِلّ الدُّخان؛ دُخان جهنم، زعم ذلك بعض أهل العلم{11}<span class=comment-ref>٦٤٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٣٩</span> نقل <u>ابنُ عطية</u> (٨/٢٠١) قولين آخرين في معنى «اليحموم»: <b>الأول:</b> عن ابن عباس أنّ «اليحموم»: «سرادق النار المحيط بأهلها، فإنه يرتفع من كلّ ناحية حتى يُظلّهم». <b>الثاني:</b> عن النقاش، وابن كيسان «أنّ اليحموم: اسم من أسماء جهنم».</div></p></div>",footnotes:1:أخرجه الفريابي وسعيد بن منصور-كما في فتح الباري ٨/٦٢٦-، وابن جرير ٢٢/٣٣٥، كذلك من طريق يزيد وعكرمة، والحاكم ٢/٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٥ (٢١٥٩)، وابن جرير ٢٢/٣٣٤-٣٣٥.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٣، وأخرجه هناد (٢٣٨)، وعبد بن حميد -كما في تغليق التعليق ٤/٣٣٥-، وابن جرير ٢٢/٣٢٦، وبنحوه من طريق منصور، والفريابي -كما في الفتح ٨/٦٢٦-.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٣٥.أخرجه ابن جرير ٢٢/٣٣٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٣٦-٣٣٧ وبنحوه من طريق سعيد بلفظ: ظل الدخان. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٢٠.تفسير الثعلبي ٩/٢١٣ وفيه ابن بريدة، والتصحيح من طبعة دار التفسير ٢٥/٤٨٦، وتفسير القرطبي ١٧/٢١٣.أخرجه ابن جرير ٢٢/٣٣٧.
  56,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا بَارِدࣲ وَلَا كَرِیمٍ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٣٦<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>: <span class="qpc-hafs">﴿لا بارِدٍ ولا كَرِيمٍ﴾</span> ولا حسن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿ولا كَرِيمٍ﴾</span> ولا عَذب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق رجل- في قول الله: <span class="qpc-hafs">﴿وظِلٍّ مِن يَحْمُومٍ﴾</span> [الواقعة:٤٣]، [...] جهنم، <span class="qpc-hafs">﴿لا بارِدٍ ولا كَرِيمٍ﴾</span> قال: لا بارد المدخل، ولا كريم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿لا بارِدٍ ولا كَرِيمٍ﴾</span>، قال: كلّ شراب ليس بعَذْبٍ فليس بكريم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لا بارِدٍ ولا كَرِيمٍ﴾</span>، قال: لا بارد المنزل، ولا كريم المنظر{5}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نَعتَ الظِّلّ، فقال: <span class="qpc-hafs">﴿لا بارِدٍ﴾</span> المقِيل، <span class="qpc-hafs">﴿ولا كَرِيمٍ﴾</span> يعني: ولا حسن المنزل{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/٢١٣، وتفسير البغوي ٨/١٨.تفسير الثعلبي ٩/٢١٣.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٥٤ (١٠٥).أخرجه ابن جرير ٢٢/٣٣٧.أخرجه ابن جرير ٢٢/٣٣٧. وعزاه السيوطي إلى عبد الرزاق، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٠-٢٢١.
  56,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوا۟ قَبۡلَ ذَ ٰ⁠لِكَ مُتۡرَفِینَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</span>، قال: مُنَعَّمِين{1}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</span>، قال: مشركين جبّارين{2}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نَعَت أعمالهم التي أوجب الله ﷿ لهم بها ما ذُكر من النار: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</span>، يعني: مُنَعَّمين في ترْك أمر الله تعالى{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٣٣٨، وابن أبي حاتم -كما في الفتح ٨/٦٢٦، والإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١.
  56,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَانُوا۟ یُصِرُّونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ﴾</span>: يُقيمون{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ﴾</span>، قال: يُدْمِنون{2}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿يُصِرُّونَ﴾</span> يُديمون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ﴾</span>، قال: يُدْمنون{4}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: يقيمون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span> يعني: يُقيمون ...، نظيرها في آل عمران [١٣٥]: <span class="qpc-hafs">﴿ولَمْ يُصِرُّوا عَلى ما فَعَلُوا﴾</span> يعني: ولم يقيموا، وقال في سورة نوح [٧]: <span class="qpc-hafs">﴿وأَصَرُّوا﴾</span> يعني: وأقاموا، وفي سورة الجاثية [٨]: <span class="qpc-hafs">﴿ثُمَّ يُصِرُّ مُسْتَكْبِرًا﴾</span> يعني: ثُمَّ يقيم متكبرًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ﴾</span>، قال: لا يتوبون، ولا يستغفرون، والإصرار عند العرب على الذنب: الإقامة عليه، وترْك الإقلاع عنه{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَلَى ٱلۡحِنثِ ٱلۡعَظِیمِ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span>، قال: الشِّرك{8}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿عَلى الحِنْثِ العَظِيمِ﴾</span>، قال: على الإثم العظيم. قال: هو الشّرك{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عَلى الحِنْثِ﴾</span>، قال: على الذَّنب{10}<span class=comment-ref>٦٤٤٠</span>. (١٤/٢١١)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٠</span> لم يذكر <u>ابنُ جرير</u> (٢٢/٣٣٩-٣٤٠) في معنى: <b><span class="qpc-hafs">﴿عَلى الحِنْثِ العَظِيمِ﴾</span></b> سوى قول مجاهد من طريق ابن أبي نجيح، والضَّحّاك، وقتادة، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٧٥١٥٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿الحِنْثِ العَظِيمِ﴾</span>، قال: الشّرك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span>، قال: هي الكبائر{4}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٧<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span> اليمين الغَموس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿عَلى الحِنْثِ﴾</span> على الذَّنب{4}. (١٤/٢١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span>، قال: على الذَّنب العظيم{15}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span>: هو الشّرك{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span>، يعني: يُقيمون على الذَّنب الكبير، وهو الشّرك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وكانُوا يُصِرُّونَ عَلى الحِنْثِ العَظِيمِ﴾</span>، قال: الحِنث العظيم: الذَّنب العظيم. قال: وذلك الذَّنب العظيم الشّرك؛ لايتوبون، ولا يستغفرون{11}<span class=comment-ref>٦٤٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٢٠٢) على قول ابن عباس، والضَّحّاك، وقتادة من طريق سعيد، وابن زيد بقوله: «وهذا هو الظاهر». ونقل عن قوم -فيما ذكر مكِّيّ-: «هو الحنث في قَسَمهم الذي يتضمّنه قوله تعالى: <b><span class="qpc-hafs">﴿وأَقْسَمُوا بِاللَّهِ جَهْدَ أيْمانِهِمْ﴾</span></b> الآية [النحل:٣٨] في التكذيب بالبعث». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا أيضًا يتضمن الكفر؛ فالقول به على عمومه أولى».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٣، وأخرجه عبد بن حميد -كما في التغليق ٤/٣٣٥-، وابن جرير ٢٢/٣٣٨. وعزاه السيوطي إلى الفريابي، وفي رواية عند ابن جرير من طريق عيسى، عن ابن أبي نجيح: يذهبون أو يُدمنون.علقه البخاري في صحيحه ٤/١٨٤٩. قال الحافظ في الفتح ٨/٦٢٦: «وصله الفريابي لكن لفظه: يُدْمنون -بسكون الدال بعدها ميم ثم نون-». وهي الرواية السابقة.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٦-.تفسير مقاتل بن سليمان ٤/٢٢١.أخرجه ابن جرير ٢٢/٣٣٨.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن جرير، وابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٣، وأخرجه ابن جرير ٢٢/٣٣٩، وعبد بن حميد -كما في التغليق ٤/٣٣٥-. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ٢٢/٣٣٩.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/١٨.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٠.تفسير مقاتل بن سليمان ٤/٢٢١.أخرجه ابن جرير ٢٢/٣٣٩.
  56,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَانُوا۟ یَقُولُونَ أَىِٕذَا مِتۡنَا وَكُنَّا تُرَابࣰا وَعِظَـٰمًا أَءِنَّا لَمَبۡعُوثُونَ ۝٤٧ أَوَءَابَاۤؤُنَا ٱلۡأَوَّلُونَ ۝٤٨ قُلۡ إِنَّ ٱلۡأَوَّلِینَ وَٱلۡـَٔاخِرِینَ ۝٤٩ لَمَجۡمُوعُونَ إِلَىٰ مِیقَـٰتِ یَوۡمࣲ مَّعۡلُومࣲ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وكانُوا يَقُولُونَ أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿أوَآباؤُنا الأَوَّلُونَ﴾</span>، قال: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد: <span class="qpc-hafs">﴿إنَّ الأَوَّلِينَ والآخِرِينَ لَمَجْمُوعُونَ إلى مِيقاتِ يَوْمٍ مَعْلُومٍ﴾</span> قال: يوم القيامة{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكانُوا﴾</span> مع شِركهم <span class="qpc-hafs">﴿يَقُولُونَ﴾</span> في الدنيا: <span class="qpc-hafs">﴿أئِذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَبْعُوثُونَ﴾</span>، <span class="qpc-hafs">﴿أوَ﴾</span> يُبعث <span class="qpc-hafs">﴿آباؤُنا الأَوَّلُونَ﴾</span> تعجّبًا، يقول الله تعالى: <span class="qpc-hafs">﴿قُلْ﴾</span> لهم يا محمد: <span class="qpc-hafs">﴿إنَّ الأَوَّلِينَ﴾</span> يعني: الأمم الخالية <span class="qpc-hafs">﴿والآخِرِينَ﴾</span> يعني: أُمّة محمد ﷺ <span class="qpc-hafs">﴿لَمَجْمُوعُونَ إلى مِيقاتِ﴾</span> يعني: إلى وقت <span class="qpc-hafs">﴿يَوْمٍ مَعْلُومٍ﴾</span> في الآخرة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١.
