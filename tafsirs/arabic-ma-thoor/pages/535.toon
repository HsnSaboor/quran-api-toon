56,31," <q>﴿وَمَاۤءࣲ مَّسۡكُوبࣲ ۝٣١﴾</q> - تفسير ٧٤٩٩٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وماءٍ مَسْكُوبٍ﴾</q>، يقول: مصبوب{1}. (١٤/٢٤٩-٢٥٠) ٧٤٩٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مَسْكُوبٍ﴾</q>: جارٍ{2}. (ز) ٧٥٠٠٠- قال مقاتل بن سليمان: <q>﴿وماءٍ مَسْكُوبٍ﴾</q>، يعني: مُنصبًّا كثيرًا{3}. (ز) ٧٥٠٠١- عن عبد الملك ابن جُرَيْج، <q>﴿وماءٍ مَسْكُوبٍ﴾</q>، قال: جارٍ{4}. (١٤/١٩٦) ٧٥٠٠٢- عن سفيان [الثوري] -من طريق مهران- <q>﴿وماءٍ مَسْكُوبٍ﴾</q>، قال: يجري في غير أخدود{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٤-٥٠٥-.تفسير مقاتل بن سليمان ٤/٢١٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٣١٨.
56,32," <q>﴿وَفَـٰكِهَةࣲ كَثِیرَةࣲ ۝٣٢﴾</q> - آثار متعلقة بالآية ٧٥٠٠٣- عن عبد الله بن عمرو بن العاص، قال: عناقيد الجنة ما بينك وبين صنعاء. وهو بالشام{1}. (١٤/١٩٦) ٧٥٠٠٤- عن عبد الله بن عباس، قال: سَعَفُ نخل الجنة منها مُقَطّعاتهم{2}، وكِسوتهم{3}. (١٤/١٩٦) ٧٥٠٠٥- عن يحيى بن صالح، يقول: كُنّا نأتي إسماعيل بن عيّاش، فيُكرمنا، ويبرّنا، ويُنزلنا أشرف المنازل، ويُقدّم إلينا من الفواكه ما نتحيّر فيه مِن ألوان التّفاحات والرّمان والسَّفرجل، ويُبَرِّد لنا الماء بالثّلج، ويقول لنا: كُلوا، يا سادتي؛ فإنّ الله تعالى وصف الجنة بصفة الصيف لفواكهها، لا بصفة الشتاء، فقال تعالى: <q>﴿في سدر مخضود وطلح منضود وظل ممدود وماء مسكوب وفاكهة كثيرة لا مقطوعة ولا ممنوعة﴾</q>{4}. (ز) ",footnotes:1:أخرجه هناد (١٠٥). وعزاه السيوطي إلى ابن المنذر.المقطعات: الثياب القصار. النهاية (قطع).أخرجه هناد (١٠٢). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر في تاريخ دمشق ٧١/٢٩٢.
56,33," <q>﴿لَّا مَقۡطُوعَةࣲ وَلَا مَمۡنُوعَةࣲ ۝٣٣﴾</q> - تفسير ٧٥٠٠٦- عن أبي هريرة -من طريق أبي صالح- أنه قال: «ما مِن عبد يُسَبِّح لله ﷿ تسبيحة، أو يحمده تحميدة، أو يكبّره تكبيرة، إلا غرس الله ﷿ له بها شجرة في الجنة، أصلها من ذهب، وأعلاها من جوهر، مُكلّلة بالدُّر والياقوت، ثمارها كثدي الأبكار، أليَن مِن الزُّبْد، وأحلى من العسل، كلمّا جنى منها شيئًا عاد مكانه». ثم تلا رسول الله ﷺ هذه الآية: <q>﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</q>{1}. (ز) ٧٥٠٠٧- قال عبد الله بن عباس: <q>﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</q> لا تنقطع إذا جُنيت، ولا تمتنع من أحد أراد أخْذها{2}. (ز) ٧٥٠٠٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿لا مَقْطُوعَةٍ﴾</q> قال: لا تنقطع حينًا وتجيء حينًا مثل فاكهة الدنيا، <q>﴿ولا مَمْنُوعَةٍ﴾</q> كما تُمنع في الدنيا إلا بثمن{3}. (١٤/٢٥٠) ٧٥٠٠٩- عن قتادة بن دعامة -من طريق أبي هلال- في قوله: <q>﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</q>، قال: لا يمنعه شوك، ولا بُعْد{4}. (ز) ٧٥٠١٠- قال مقاتل بن سليمان: <q>﴿لا مَقْطُوعَةٍ ولا مَمْنُوعَةٍ﴾</q> لا مقطوعة عنهم أبدًا، هي لهم أبدًا في كلّ حين وساعة، ولا يمنعونها، ليست لها خشونة، أليَن من الزُّبْد، وأحلى من العسل{5}. (ز) ",footnotes:1:أخرجه الطبراني في المعجم الأوسط ٣/٢٨٧ (٣١٧١). قال الهيثمي في مجمع الزوائد ١٠/٨٩: «رواه الطبراني في الأوسط موقوفًا على أبي هريرة، وفيه سليمان بن أبي كريمة، وهو ضعيف».تفسير البغوي ٨/١٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣١٨.تفسير مقاتل بن سليمان ٤/٢١٩.
56,34," <q>﴿وَفُرُشࣲ مَّرۡفُوعَةٍ ۝٣٤﴾</q> - تفسير ٧٥٠١١- عن أبي هريرة، قال: سمعتُ رسول الله ﷺ يقول في هذه الآية: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>، قال: «غِلَظ كل فراش منها كما بين السماء والأرض»{1}. (١٤/١٩٨) ٧٥٠١٢- عن أبي سعيد الخدري، عن النبيِّ ﷺ، في قوله: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>، قال: «ارتفاعها كما بين السماء والأرض، ومسيرة ما بينهما خمسمائة عام»{2}٦٤٣١. (١٤/١٩٧) ٦٤٣١ علَّق ابنُ عطية (٨/١٩٨) على حديث أبي سعيد الخدري ﵄ بقوله: «وهذا -والله أعلم- لا يثبت، وإن قُدِّر فمتأولٌ خارج عن ظاهره». ٧٥٠١٣- عن عبد الله بن عباس -رفعه- في الفُرُش المرفوعة: «لو طُرِح مِن أعلاها شيءٌ ما بلغ قرارها مائة خريف»{3}. (١٤/١٩٧) ٧٥٠١٤- عن أبي أُمامة: سُئل رسول الله ﷺ عن الفُرُش المرفوعة. قال: «لو طُرح فراش من أعلاها لهوى إلى قرارها مائة خريف»{4}. (١٤/١٩٧) ٧٥٠١٥- قال علي بن أبي طالب: مرفوعة على الأسِرّة{5}. (ز) ٧٥٠١٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>، يقول: بعضها فوق بعض{3}. (١٤/٢٥٠) ٧٥٠١٧- عن أبي أُمامة -من طريق القاسم- <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>، قال: لو أنّ أعلاها سقط ما بلغ أسفلها أربعين خريفًا{7}. (١٤/١٩٧) ٧٥٠١٨- عن كعب الأحبار -من طريق مُطَرّف- قال في قوله: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>، قال: على مسيرة أربعين عامًا{8}. (ز) ٧٥٠١٩- عن مجاهد بن جبر –من طريق ابن أبي نجيح- في قوله: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>: بعضها فوق بعض{9}. (ز) ٧٥٠٢٠- عن الحسن البصري -من طريق أبي سهل- في قوله: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q>، قال: ارتفاع فراش أهل الجنة مسيرة ثمانين سنة{10}. (١٤/١٩٨) ٧٥٠٢١- قال مقاتل بن سليمان: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q> فوق السُّرر، بعضها فوق بعض، على قدر سبعين غرفة من غُرف الدنيا{11}٦٤٣٢. (ز) ٦٤٣٢ نقل ابنُ عطية (٨/١٩٨) في معنى الآية عن أبي عبيدة: أن المراد بالفُرُش: النساء، و<q>﴿مَرْفُوعَةٍ﴾</q> معناه: في الأقدار والمنازل. وانتقده ابنُ القيم (حادي الأرواح ص٢٢٥) مستندًا إلى اللغة، فقال: «ولكن قوله: <q>﴿مَرْفُوعَةٍ﴾</q> يأبى هذا، إلا أن يقال: المراد: رِفعة القدر. وقد تقدم تفسير النبي ﷺ للفُرُش وارتفاعها. فالصواب أنها الفُرُش نفسها، ودلّت على النساء لأنها محلهن غالبًا». ",footnotes:1:أخرجه الخطيب في تاريخه ٦/١٠٩ (١٦٥٢)، وابن الجوزي في الموضوعات ٣/٢٥٤-٢٥٥. قال ابن الجوزي: «هذا حديث لا يصح». وقال السيوطي في اللآلئ المصنوعة ٢/٣٧٦: «لا يصح». وقال الشوكاني في الفوائد المجموعة ص٣١٨ (٦٤): «في إسناده وضّاع».أخرجه أحمد ١٨/٢٤٧ (١١٧١٩)، والترمذي ٤/٥٠٧ (٢٧١٥)، ٥/٤٨٧ (٣٥٧٨)، وابن حبان ١٦/٤١٨-٤١٩ (٧٤٠٥)، وابن جرير ٢٢/٣١٩. قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث رشدين بن سعد».عزاه السيوطي إلى ابن مردويه.أخرجه الطبراني في الكبير ٨/٢٤٢ (٧٩٤٧)، وأبو نعيم الأصبهاني في صفة الجنة ٢/١٩٦ (٣٥٦). قال الهيثمي في المجمع ٧/١٢٠ (١١٣٩٩): «رواه الطبراني، وفيه جعفر بن الزبير الحنفي، وهو ضعيف». وقال الألباني في الضعيفة ١٢/٨٧٥ (٥٩٤٢): «ضعيف جدًّا».تفسير الثعلبي ٩/٢٠٩.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٣/١٤٠، وهناد (٧٩)، وابن أبي الدنيا في صفة الجنة (١٦١). وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٩-.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٠١-٤٠٢ (٣٦٤٨١)، وأبو نعيم في حلية الأولياء ٥/٣٧٩.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٤-٥٠٥-.أخرجه هناد (٧٨).تفسير مقاتل بن سليمان ٤/٢١٩.
56,35," <q>﴿إِنَّاۤ أَنشَأۡنَـٰهُنَّ إِنشَاۤءࣰ ۝٣٥﴾</q> - تفسير ٧٥٠٢٢- عن أنس بن مالك، قال: قال رسول الله ﷺ، في قوله: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: «إنّ مِن المنشآت: اللاتي كُنّ في الدنيا عجائز عُمشًا رُمصًا»{1}. (١٤/١٩٨) ٧٥٠٢٣- عن سلمة بن يزيد الجُعْفي: سمعتُ النبيَّ ﷺ يقول في قوله: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: «الثَّيِّب والأبكار اللاتي كُنّ في الدنيا»{2}. (١٤/١٩٨) ٧٥٠٢٤- عن جعفر بن محمد، عن أبيه، عن جدّه، قال: قال رسول الله ﷺ: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: «أنبَتناهنّ»{3}. (١٤/٢٠٠) ٧٥٠٢٥- عن عبد الله بن عباس: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q> خلَقهن غير خلْقهن الأول{4}. (١٤/٢٠٠) ٧٥٠٢٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: هؤلاء نساء أهل الجنة، وهؤلاء العُجُزُ الرُّمْصُ، يقول: خلَقهم خلْقًا{3}. (١٤/٢٥٠) ٧٥٠٢٧- عن سعيد بن جُبَير، <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: خلقناهن خلْقًا جديدًا{6}. (١٤/٢٠٠) ٧٥٠٢٨- عن مجاهد بن جبر، <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: خلَقهن خلْقًا غير خلْقهن الأول{6}. (١٤/٢٠٠) ٧٥٠٢٩- عن الحسن البصري، <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: النساء{6}. (١٤/٢٠٠) ٧٥٠٣٠- عن صفوان بن مُحْرِز -من طريق قتادة- في قوله: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا﴾</q>، قال: واللهِ، إنّ منهنّ العُجُزَ الزُّحُفَ، صيَّرهنَّ الله كما تسمعون{9}. (ز) ٧٥٠٣١- عن قتادة بن دعامة، <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: يعني: أزواج القوم{6}. (١٤/٢٠٠) ٧٥٠٣٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، قال: خلقناهن خلْقًا{11}. (ز) ٧٥٠٣٣- عن قتادة بن دعامة -من طريق أبي هلال- في قوله: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا﴾</q>، قال: إنّ منهنّ لَلعُجُز الرُّجَّف، أنشأهن الله في هذا الخلْق{12}٦٤٣٣. (ز) ٦٤٣٣ نقل ابنُ عطية (٨/١٩٩) في معنى الآية عن قتادة أنّ «الضمير عائد على الحور العين المذكورات قبل». ثم انتقده -مستندًا إلى الدلالات العقلية- قائلًا: «وهذا فيه بُعد؛ لأنّ تلك قصة قد انقضت جملة». ثم نقل عن أبي عبيدة قوله: «قد ذكرَهُنَّ في قوله تعالى: <q>﴿وفُرُشٍ مَرْفُوعَةٍ﴾</q> فلذلك ردَّ الضمير وإن لم يتقدم ذكر لدلالة المعنى على المقصد». ثم وجَّهه بقوله: «وهذا كقوله تعالى: <q>﴿حَتّى تَوارَتْ بِالحِجابِ﴾</q> [ص:٣٢] ونحوه». ٧٥٠٣٤- قال مقاتل بن سليمان: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، يعني: ما ذُكِر مِن الحُور العِين قبل ذلك، فنَعتهنّ في التقديم، يعني: نشأ أهل الدنيا العُجز الشّمط، يقول: خلَقهن في الآخرة خلْقًا بعد الخلق الأول في الدنيا{13}٦٤٣٤. (ز) ٦٤٣٤ علَّق ابنُ القيم (٣/١١٠) على قول مقاتل بقوله: «ويؤيد هذا التفسير حديث أنس المرفوع: «هنّ عجائزكم العُمْش الرُّمْص» ... ويؤيده ...». ثم ذكر حديث عائشة الوارد في الآثار المتعلقة بالآية وما في معناهما، ثم نقل عن مقاتل قولًا آخر وأنه اختيار الزجاج «أنهن الحُور العين التي ذكرهن، قيل: أنشأهن الله ﷿ لأوليائه لم يقع عليهن ولادة». ثم رجَّح أن «الظاهر أنّ المراد: أنشأهن الله تعالى في الجنة إنشاء. ويدل عليه وجوه: أحدها: أنه قد قال في حقّ السابقين: <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q> إلى قوله: <q>﴿كَأَمْثالِ اللُؤْلُؤِ المَكْنُونِ﴾</q>، فذكر سُررهم وآنيتهم وشرابهم وفاكهتهم وطعامهم وأزواجهم من الحور العين، ثم ذكر أصحاب الميمنة وطعامهم وشرابهم وفرشهم ونساءهم، والظاهر أنهن مثل نساء من قبلهن خلقهن في الجنة. الثاني: أنه سبحانه قال: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، وهذا ظاهر أنه إنشاء أول لا ثان؛ لأنه سبحانه حيث يريد الإنشاء الثاني يقيّده بذلك، كقوله: <q>﴿وأَنَّ عَلَيْهِ النَّشْأَةَ الأُخْرى﴾</q> [النجم:٤٧]. الثالث: أنّ الخطاب بقوله: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q> إلى آخره للذكور والإناث، والنشأة الثانية أيضًا عامة للنوعين، وقوله: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً﴾</q>، ظاهره اختصاصهن بهذا الإنشاء، وتأمّل تأكيده بالمصدر، والحديث لا يدل على اختصاص العجائز المذكورات بهذا الوصف، بل يدل على مشاركتهن للحُور العين في هذه الصفات المذكورة، فلا يتوهم انفراد الحور العين عنهن بما ذكر مِن الصفات، بل هي أحقّ به منهن، فالإنشاء واقع على الصنفين». ",footnotes:1:أخرجه الترمذي ٥/٤٨٩ (٣٥٨٠)، وابن جرير ٢٢/٣٢١. قال الترمذي: «هذا حديث غريب، لا نعرفه مرفوعًا إلا من حديث موسى بن عبيدة، وموسى بن عبيدة ويزيد بن أبان الرّقاشي يضعفان في الحديث». وقال الألباني في الضعيفة ٧/١٨٨ (٣٢٠٤): «ضعيف».أخرجه الطبراني في الكبير ٧/٤٠، وابن قانع في معجم الصحابة ١/٢٧٤، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٣١- واللفظ لهما. قال الهيثمي في المجمع ٧/٢٥٦ (١١٣٩٧): «رواه الطبراني، وفيه جابر الجعفي، وهو ضعيف».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٢، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٥٥ (٣٦٣٠٣).عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧١، وابن جرير ٢٢/٣٢٠.أخرجه ابن جرير ٢٢/٣٢٢.تفسير مقاتل بن سليمان ٤/٢١٩.
56,36," <q>﴿فَجَعَلۡنَـٰهُنَّ أَبۡكَارًا ۝٣٦﴾</q> - تفسير ٧٥٠٣٥- عن الحسن البصري، قال: أتتْ عجوزٌ، فقالت: يا رسول الله، ادعُ الله أن يُدخلني الجنة. فقال: «يا أُمّ فلان، إنّ الجنة لا يدخلها عجوز». فولّت تبكي، قال: «أخبِروها أنها لا تدخلها وهي عجوز. إنّ الله يقول: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا﴾</q>{1}. (١٤/١٩٩) ٧٥٠٣٦- عن عبد الله بن عباس، في قوله: <q>﴿فَجَعَلْناهُنَّ أبْكارًا﴾</q>، قال: عذارى{2}. (١٤/٢٠١) ٧٥٠٣٧- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً فَجَعَلْناهُنَّ أبْكارًا عُرُبًا أتْرابًا﴾</q>، قال: هُنّ مِن بني آدم، نساءكن في الدنيا يُنشئهن الله أبكارًا عذارى أترابًا عُربًا{3}. (ز) ٧٥٠٣٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فَجَعَلْناهُنَّ أبْكارًا﴾</q>، يقول: عذارى{4}. (١٤/٢٥٠) ٧٥٠٣٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول: قوله: <q>﴿أبْكارًا﴾</q>، يقول: عذارى{3}. (ز) ٧٥٠٤٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَجَعَلْناهُنَّ أبْكارًا﴾</q>، قال: عذارى{6}. (١٤/٢٠٣) ٧٥٠٤١- قال مقاتل بن سليمان: <q>﴿فَجَعَلْناهُنَّ أبْكارًا﴾</q> شَوابًّا{7} كلّهن على ميلاد واحد؛ بنات ثلاث وثلاثين سنة{8}. (ز) ٧٥٠٤٢- قال المسيّب بن شريك: هنّ عجائز الدنيا، أنشأهنّ الله تعالى خلْقًا جديدًا، كلّما أتاهنّ أزواجهنّ وجَدُوهُنَّ أبكارًا. وذكر المسيّب عن غيره: أنهنَّ فُضِّلن على الحُور العين بصلاتهنّ في الدنيا{9}. (ز) <q>﴿فَجَعَلۡنَـٰهُنَّ أَبۡكَارًا ۝٣٦﴾</q> - آثار متعلقة بالآية ٧٥٠٤٣- عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «إنّ أهل الجنة إذا جامعوا نساءهم عُدْنَ أبكارًا»{10}. (١٤/٢٠٠) ٧٥٠٤٤- عن عائشة، قالت: دخل النبيُّ ﷺ عَلَيَّ وعندي عجوز، فقال: «مَن هذه؟». قلتُ: إحدى خالاتي. قال: «أما إنه لا يدخل الجنة العُجُز». فدخل العجوزَ مِن ذلك ما شاء الله، فقال النبيُّ ﷺ: «إنّا أنشأناهن خلقًا آخر»{11}. (١٤/١٩٩) ٧٥٠٤٥- عن عائشة: أنّ النبيَّ ﷺ أتَتْه عجوزٌ من الأنصار، فقالت: يا رسول الله، ادعُ الله أن يُدخلني الجنة. فقال: «إنّ الجنةَ لا يدخلها عجوز». فذهب يصلي، ثم رجع، فقالت عائشة: لقد لَقِيَتْ مِن كلمتك مشقّة، فقال: «إنّ ذلك كذلك؛ إنّ الله إذا أدخلهنّ الجنة حوّلهنّ أبكارًا»{12}. (١٤/١٩٩) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٢-، وعبد بن حميد -كما في تفسير ابن كثير ٨/٩-، والترمذي في الشمائل (٢٣٢)، والبيهقي في البعث (٣٨٢). وعزاه السيوطي إلى ابن المنذر. وحسنه الألباني في غاية المرام (٣٧٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٣٢٢.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٢٢.أخرجه عبد الرزاق ٢/٢٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.جمع شابَّة. لسان العرب (شبب).تفسير مقاتل بن سليمان ٤/٢١٩.تفسير البغوي ٨/١٤.أخرجه الطبراني في الصغير ١/١٦٠ (٢٤٩)، والبزار -كما في كشف الأستار ٤/١٩٨-١٩٩ (٣٥٢٧)-، والثعلبي ٨/١٣١. قال الطبراني: «لم يروه عن عاصم إلا شريك، تفرّد به معلى بن عبد الرحمن». وقال الهيثمي في المجمع ١٠/٤١٧ (١٨٧٥٣): «رواه البزار، والطبراني في الصغير، وفيه معلى بن عبد الرحمن الواسطي، وهو كذاب».أخرجه البيهقي في البعث والنشور ص٢١٦ (٣٤٣). إسناده ضعيف؛ فيه ليث بن أبي سليم، قال عنه ابن حجر في التقريب (٥٦٨٥): «صدوق اختلط جدًّا، ولم يتميز حديثه؛ فتُرِك».أخرجه الطبراني في الأوسط ٥/٣٥٧ (٥٥٤٥)، وأبو نعيم في صفة الجنة ٢/٢٢٣ (٣٩١). قال الطبراني: «لم يرو هذا الحديثَ عن قتادة إلا سعيد بن أبي عروبة». وقال الهيثمي في المجمع ١٠/٤١٩ (١٨٧٦٤): «رواه الطبراني في الأوسط، وفيه مسعدة بن اليسع، وهو ضعيف».
56,37," <q>﴿عُرُبًا﴾</q> - تفسير ٧٥٠٤٦- عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قوله: <q>﴿عُرُبًا أتْرابًا﴾</q>. قال: «هنّ اللواتي قُبضن في دار الدنيا عجائز رُمْصًا شُمْطًا، خلقهنّ الله بعد الكِبر، فجعلهنّ عذارى، عُرُبًا، متعشِّقات، مُحبّبات، أترابًا على ميلاد واحد»{1}. (١٤/١٥٩) ٧٥٠٤٧- عن جعفر بن محمد، عن أبيه، قال: قال رسول الله ﷺ في قوله: <q>﴿عُرُبًا﴾</q>، قال: «كلامهن عَرَبِيٌّ»{2}. (١٤/٢٠٦) ٧٥٠٤٨- عن بُريْدة بن الحَصيب، في قوله: <q>﴿عُرُبًا﴾</q>، قال: هي الشَّكِلَةُ{3}، بلغة مكة، المغْنوجة{4}، بلغة المدينة{5}. (١٤/٢٠٢) ٧٥٠٤٩- عن عبد الله بن عباس، أنّ نافع الأزرق قال له: أخبِرني عن قوله: <q>﴿عُرُبًا أتْرابًا﴾</q>. قال: هنّ العاشقات لأزواجهنّ، اللاتي خُلِقن مِن الزّعفران، والأتراب: المستويات. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ نابغة بني ذبيان وهو يقول: عهدتُ بها سُعدى وسُعدى غَرِيرَة{6} عَروبٌ تَهادى في جوارٍ خَرائِدِ{7}؟{8} (١٤/٢٠٣) ٧٥٠٥٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿عُرُبًا﴾</q>، قال: عواشق{9}. (١٤/٢٠١) ٧٥٠٥١- عن عبد الله بن عباس -من طريق الضَّحّاك- <q>﴿عُرُبًا﴾</q>، قال: عواشق لأزواجهنّ، وأزواجهنّ لهنّ عاشقون{10}. (١٤/٢٠١) ٧٥٠٥٢- عن عبد الله بن عباس -من طريق عكرمة- قال: العَرُوبُ: المَلقَة{11} لزوجها{12}. (١٤/٢٠١) ٧٥٠٥٣- عن عبد الله بن عباس -من طريق العَوفيّ- قال: العُرب: المُتَحَبِّبات المُتَوَدِّدات إلى أزواجهنّ{13}. (١٤/٢٠١) ٧٥٠٥٤- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: العُرُب: الغَنِجة. وفي قول أهل المدينة: الشَّكِلة{14}. (١٤/٢٠١) ٧٥٠٥٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿عُرُبًا﴾</q>، قال: الناقة التي تشتهي الفَحْل يُقال لها: عَرِبة{15}. (١٤/٢٠٢) ٧٥٠٥٦- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿عُرُبًا﴾</q>: والعُرب: الشُّوق{16}. (ز) ٧٥٠٥٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿عُرُبًا﴾</q>: والعُرُب: المُتحبّبات إلى أزواجهن{17}. (١٤/٢٥٠) ٧٥٠٥٨- عن تميم بن حَذْلَم -وكان من أصحاب عبد الله- قال: العَربة: الحسنة التبعُّل، وكانت العرب تقول للمرأة إذا كانت حسنة التبعُّل: إنها العَربة{18}٦٤٣٥. (١٤/٢٠٤) ٦٤٣٥ وجَّه ابنُ القيم (٣/١١٢) قول تميم بن حَذْلم أن العَروب: «الحسنة التبعل» بقوله: «يريد: حُسن مواقعتها وملاطفتها لزوجها عند الجماع». ٧٥٠٥٩- عن سعيد بن جُبَير، في قوله: <q>﴿عُرُبًا﴾</q>، قال: هُنَّ المُتَغَنِّجات{19}. (١٤/٢٠٢) ٧٥٠٦٠- عن سعيد بن جُبَير -من طريق غالب أبي الهُذيل- في قوله: <q>﴿عُرُبًا﴾</q>، قال: يشتهين أزواجهنَّ{20}. (١٤/٢٠٤) ٧٥٠٦١- عن سعيد بن جُبَير -من طريق سالم الأفطس- في قوله: <q>﴿عُرُبًا﴾</q>، قال: العُرُب: المتعشّقات{21}. (١٤/٢٠٤) ٧٥٠٦٢- عن عبد الله بن بُريْدة بن الحصيب -من طريق صالح بن حيان- في قوله: <q>﴿عُرُبًا﴾</q>، قال: هي الشَّكِلة، بلغة مكة، المغْنوجة، بلغة المدينة{22}. (ز) ٧٥٠٦٣- عن مجاهد بن جبر -من طريق خُصَيف- في قوله: <q>﴿عُرُبًا﴾</q>، قال: عواشق لأزواجهن{23}. (١٤/٢٠٤) ٧٥٠٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عُرُبًا﴾</q>، قال: هي الغَلِمةُ{24}{25}. (١٤/٢٠٢) ٧٥٠٦٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عُرُبًا﴾</q>، قال: مُتَحَبِّبات إلى أزواجهن{26}. (١٤/٢٠٥) ٧٥٠٦٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول: العُرُب: المتحبِّبات{27}. (ز) ٧٥٠٦٧- عن عكرمة مولى ابن عباس، قال: العُرُب: المُتحبِّبات إلى أزواجهنّ{28}. (١٤/٢٠٥) ٧٥٠٦٨- عن عكرمة مولى ابن عباس -من طريق خُصَيف- قال: عواشق{29}. (ز) ٧٥٠٦٩- عن عكرمة مولى ابن عباس -من طريق سماك- في قوله: <q>﴿عُرُبًا﴾</q>، قال: المغنوجات، والعَربة هي الغَنِجة{30}. (١٤/٢٠٣) ٧٥٠٧٠- عن الحسن البصري -من طريق المبارك- في قوله: <q>﴿عُرُبًا﴾</q>، قال: المتعشّقات لبُعولتهنّ{31}. (١٤/٢٠٤) ٧٥٠٧١- عن الحسن البصري -من طريق أشعث- في قوله: <q>﴿عُرُبًا﴾</q>، قال: المتحبّبات إلى الأزواج{32}. (١٤/٢٠٥) ٧٥٠٧٢- عن الحسن البصري -من طريق قرة- <q>﴿عُرُبًا﴾</q>، قال: عواشق{33}. (١٤/٢٠٥) ٧٥٠٧٣- عن عبد الله بن عبيد بن عمير أنه سُئِل عن قوله تعالى: <q>﴿عُرُبًا﴾</q>. قال: أما سمعت أنّ المُحرِم يُقال له: لا تُعرِبها بكلام تُلذّذها به، وهي مُحرِمة{28}. (١٤/٢٠٣) ٧٥٠٧٤- عن عبد الله بن عبيد بن عمير -من طريق عثمان بن الأسود- قال: العَربة: التي تشتهي زوجها، ألا ترى أن الرجل يقول للناقة: إنها لعَربة؟!{35}. (١٤/٢٠٢) ٧٥٠٧٥- عن بلال بن أبي بُردة، أنه قال لجلسائه: ما العَروب مِن النساء؟ فماجوا، وأقبل إسحاق بن عبد الله بن الحارث النَّوفَليّ، فقال: قد جاءكم مَن يخبركم عنها. فسألوه، فقال: الخَفِرة{36}، المتبذّلة لزوجها. وأنشد: يُعْرِبن عند بُعولهن إذا خَلوا وإذا هم خرجوا فهن خِفار{37}. (١٤/٢٠٦) ٧٥٠٧٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿عُرُبًا﴾</q>، قال: عُشَّقًا لأزواجهنّ{38}. (١٤/٢٠٣) ٧٥٠٧٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿عربا أترابا﴾</q>، قال: العُرُب: العواشق، والأتراب: المستويات{39}. (ز) ٧٥٠٧٨- عن زيد بن أسلم -من طريق أسامة- قال: العَرِبة: هي الحسنة الكلام{40}. (١٤/٢٠٥) ٧٥٠٧٩- عن الربيع بن أنس، قال: العُرُب: المتعشِّقات{28}. (١٤/٢٠٥) ٧٥٠٨٠- عن عمرو بن أبي سلمة، قال: سُئل الأوزاعي عن <q>﴿عُرُبًا﴾</q>. قال: سمعتُ يحيى يقول: هنّ العواشق{27}. (ز) ٧٥٠٨١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿عُرُبًا﴾</q>، قال: العُرُب: الحسنة الكلام{27}٦٤٣٦. (ز) ٦٤٣٦ علَّق ابنُ عطية (٨/٢٠٠) على قول ابن زيد بقوله: "وقد تجيء العَروب صفة ذمٍّ على غير هذا المعنى، وهي الفاسدة الأخلاق، كأنها عرَّبت، ومنه قول الشاعر: وما بَدَلٌ مِن أُمِّ عثمان سَلْفَعٌ منَ السُّود ورْهاءُ العِنانِ عَريب". <q>﴿أَتۡرَابࣰا ۝٣٧﴾</q> - تفسير ٧٥٠٨٢- عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قوله: <q>﴿عُرُبًا أتْرابًا﴾</q>. قال: «عُرُبًا متعشِّقات مُحبّبات، أترابًا على ميلاد واحد»{44}. (١٤/١٥٩) ٧٥٠٨٣- عن عبد الله بن عباس، أنّ نافع الأزرق قال له: أخبِرني عن قوله: <q>﴿عُرُبًا أتْرابًا﴾</q>. قال: هُنّ العاشقات لأزواجهنّ، اللاتي خُلِقن مِن الزّعفران، والأتراب: المستويات{45}. (١٤/٢٠٣) ٧٥٠٨٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أتْرابًا﴾</q>، يقول: مستويات{46}. (١٤/٢٠١) ٧٥٠٨٥- عن عبد الله بن عباس -من طريق الضَّحّاك- <q>﴿أتْرابًا﴾</q>، قال: في سِنٍّ واحدٍ؛ ثلاثًا وثلاثين سنة{10}. (١٤/٢٠١) ٧٥٠٨٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أتْرابًا﴾</q>: المُصطَحبات اللاتي لا تَغَرْن{17}. (١٤/٢٥٠) ٧٥٠٨٧- عن مجاهد بن جبر -من طريق خُصَيف- في قوله: <q>﴿أتْرابًا﴾</q>، قال: مستويات{49}. (١٤/٢٠٤) ٧٥٠٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أتْرابًا﴾</q>، قال: أمثالًا{50}. (١٤/٢٠٥) ٧٥٠٨٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿أتْرابًا﴾</q>، قال: الأتراب: المستويات{51}. (ز) ٧٥٠٩٠- عن الضَّحّاك بن مُزاحِم -من طريق سلمة بن نُبَيْط- قال: <q>﴿أترابا﴾</q> أمثالًا{52}. (ز) ٧٥٠٩١- عن عكرمة مولى ابن عباس: الأتراب: الأشباه المستويات{28}. (١٤/٢٠٥) ٧٥٠٩٢- عن الحسن البصري -من طريق المبارك- في قوله: <q>﴿عُرُبًا﴾</q>، قال: المتعشّقات لبُعولتهنّ، والأتراب: المستويات في سِنّ واحد{54}. (١٤/٢٠٤) ٧٥٠٩٣- عن الحسن البصري، قال: الأتراب: المستويات{55}. (١٤/٢٠٥) ٧٥٠٩٤- عن الحسن البصري، <q>﴿أتْرابًا﴾</q>، قال: أقرانًا{28}. (١٤/٢٠٥) ٧٥٠٩٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿أتْرابًا﴾</q>، قال: مستويات سِنًّا واحدًا{57}. (١٤/٢٠٣) ٧٥٠٩٦- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- قال: الأتراب: المستويات{39}. (ز) ٧٥٠٩٧- عن الربيع بن أنس، قال: الأتراب: على سِنٍّ واحد{28}. (١٤/٢٠٥) ",footnotes:1:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥. وعزاه السيوطي إلى ابن مردويه. وتقدم مطولًا مع تخريجه عند تفسير قوله تعالى: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> [الرحمن:٧٠].أخرجه ابن أبي حاتم -كما في الفتح ٦/٣٢٢، وتفسير ابن كثير ٨/١٢-. قال ابن حجر: «وهو ضعيف منقطع».الشَكِلة: المرأة ذات الدَّلِّ. النهاية (شكل).الغُنج في الجارية: تكسّر وتدلّل. النهاية (غنج).عزاه السيوطي إلى ابن جرير، وابن المنذر. وفي تفسير ابن جرير عن ابنه كما سيأتي.الغَرِيرة والغِرَّة: الشابة الحديثة السن التي لم تجرب الأمور. لسان العرب (غرر).الخَرِيدَة والخَرِيد والخَرُود من النساء: البكر التي لم تُمْسَسْ قَط. لسان العرب (خرد).عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٢٤١).أخرجه ابن جرير ٢٢/٣٢٣، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.المَلَق: الودّ واللُّطف الشديد. لسان العرب (ملق).أخرجه ابن جرير ٢٢/٣٢٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٣٢٤.عزاه السيوطي إلى هناد في الزهد. وفي المطبوع منه (٣٤): العُرُب في قول أهل المدينة: الشَّكِلة، وفي قول أهل العراق: الغَنجة.عزاه السيوطي إلى سفيان، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٢٨.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٢٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن جرير ٢٢/٣٢٦، وهناد (٣١). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٦. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٢/٣٢٤، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.أخرجه هناد (٣٠)، وابن جرير ٢٢/٣٢٧، والفريابي -كما في الفتح ٦/٣٢٣-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.الغُلْمَة: هيجان شهوة النكاح من المرأة والرجل وغيرهما. النهاية (غَلِمَ).أخرجه عبد الرزاق ٢/٢٧١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٣، وأخرجه ابن جرير ٢٢/٣٢٦-٣٢٧، وسفيان بن عيينة وعبد بن حميد -كما في تغليق التعليق ٣/٥٠٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٣٢٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٥.أخرجه ابن جرير ٢٢/٣٢٤، كذلك أخرجه بنحوه من طريق عمارة، وابن أبي حاتم -كما في الفتح ٦/٣٢٢- بنحوه. وعزاه السيوطي إلى عبد بن حميد. وتفسير الثعلبي ٩/٢٠٩.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٣-، وابن جرير ٢٢/٥٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه هناد (٣٣). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٤. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٦. وعزاه السيوطي إلى ابن المنذر.الخفر: الحياء. النهاية (خفر).أخرجه وكيع في الغرر (وهو أخبار القضاة ٢/٣٥)، وابن عساكر في تاريخه ٨/٢٤٢-٢٤٣.أخرجه عبد الرزاق ٢/٢٧١، وابن جرير ٢٢/٣٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. كما أخرجه ابن جرير ٢٢/٣٢٧ من طريق سعيد، وزاد: يحببن أزواجهن حبًّا شديدًا.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١١.أخرجه ابن جرير ٢٢/٣٢٥، وابن أبي حاتم -كما في الفتح ٦/٣٢٢-.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٢٧.أخرجه ابن جرير ٢٢/٣٢٧.تقدم الحديث في أول الآية.تقدم الأثر في أول الآية.أخرجه البيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن جرير، وابن المنذر. وعند ابن جرير ٢٢/٣٢٩ من طريق عطية.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.أخرجه هناد (٣٨)، وابن جرير ٢٢/٣٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٣، وأخرجه ابن جرير ٢٢/٣٢٩، وسفيان بن عيينة وعبد بن حميد -كما في تغليق التعليق ٣/٥٠٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٣٢٩.أخرجه هناد في الزهد ١/٦٠.عزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٣-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى هناد، وعبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧١، وابن جرير ٢٢/٣٢٩، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١١.عزاه السيوطي إلى عبد بن حميد.
56,38," <q>﴿لِّأَصۡحَـٰبِ ٱلۡیَمِینِ ۝٣٨ ثُلَّةࣱ مِّنَ ٱلۡأَوَّلِینَ ۝٣٩ وَثُلَّةࣱ مِّنَ ٱلۡـَٔاخِرِینَ ۝٤٠﴾</q> - تفسير ٧٥٠٩٨- عن عبد الله بن مسعود، قال: تحدّثنا ذاتَ ليلةٍ عند رسول الله ﷺ حتى أكْدانا الحديث، فلما أصبحنا غدَونا على رسول الله ﷺ، فقال: «عُرِضَت عليَّ الأنبياء بأتباعها مِن أُممها، فإذا النبيُّ معه الثُّلّة مِن أُمّته، وإذا النبيُّ ليس معه أحد، وقد أنبأكم اللهُ عن قوم لوط، فقال: <q>﴿ألَيْسَ مِنكُمْ رَجُلٌ رَشِيدٌ﴾</q> [هود:٧٨]. حتى مرّ موسى ﵇ ومَن معه مِن بني إسرائيل، قلتُ: يا ربّ، فأين أُمّتي؟ قال: انظر عن يمينك، فإذا الظِّرابُ{1} ظِراب مكة قد سُدّ مِن وجوه الرجال، قال: أرضيتَ، يا محمد؟ قلتُ: رضيتُ، ربِّ. قال: انظر عن يسارك، فإذا الأُفق قد سُدّ مِن وجوه الرجال. قال: أرضيتَ، يا محمد؟ قلتُ: رضيتُ، ربِّ. قال: فإنّ مع هؤلاء سبعين ألفًا يدخلون الجنة بغير حساب». فأتى عُكّاشة بن مِحْصن الأسديّ، فقال: يا رسول الله، ادعُ الله أن يجعلني منهم. قال: «اللهم، اجعله منهم». ثم قام رجل آخر، فقال: يا رسول الله، ادعُ الله أن يجعلني منهم. فقال: «سبقك بها عُكّاشة». ثم قال لهم النبيُّ ﷺ: «إن استطعتم -بأبي أنتم وأمي- أن تكونوا مِن السبعين فكُونوا، فإن عجزتم وقصّرتم فكُونوا من أصحاب الظِّراب، فإن عجزتم وقصّرتم فكُونوا من أصحاب الأُفق؛ فإنّي قد رأيت أناسًا يَتَهارَشُونَ كثيرًا». ثم قال: «إنّي لَأرجو أن تكونوا شطر أهل الجنة». فكبّر القوم، ثم تلا هذه الآية: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، فتذاكروا بينهم مَن هؤلاء السبعون الألف، فقال رسول الله ﷺ: «هم الذين لا يَسْتَرقُون، ولا يَتطيّرون، وعلى ربهم يتوكلون»{2}. (١٤/٢٠٨) ٧٥٠٩٩- عن أبي بَكرة، عن النبي ﷺ، في قوله: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، قال: «جميعهما مِن هذه الأُمّة»{3}. (١٤/٢٠٧) ٧٥١٠٠- عن ابن عباس، <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، قال: قال النبي ﷺ: «هما جميعًا من أُمّتي»{4}. (ز) ٧٥١٠١- عن أبي بَكرة -من طريق عُقبة بن صُهْبان- في قوله: <q>﴿ثلة من الأولين وثلة من الآخرين﴾</q>، قال: كلٌّ مِن هذه الأُمّة{5}. (ز) ٧٥١٠٢- عن عبد الله بن عباس، <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، قال: الثلَّتان جميعًا مِن هذه الأُمّة{6}٦٤٣٧. (١٤/٢٠٧) ٦٤٣٧ وجَّه ابنُ عطية (٨/٢٠١) قول ابن عباس بقوله: «فعلى هذا التابعون بإحسان ومَن جرى مجراهم ثلَّةٌ أولى، وسائر الأمة ثلَّةٌ أخرى في آخر الزمان». ٧٥١٠٣- عن عبد الله بن عباس -من طريق محمد بن علي- قال: إنّ أهل الجنة مائة وعشرون صفًّا؛ فأُمّة محمد ﷺ ثمانون صفًّا، وسائر الأمم أربعون صفًّا، وسابقو الأمم ومقرّبوها أكثر من سابقي هذه الأُمّة ومُقرّبيها{7}. (ز) ٧٥١٠٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، يقول: طائفة من الأوّلين، وطائفة من الآخرين{8}. (١٤/٢٥٠) ٧٥١٠٥- قال أبو العالية الرِّياحيّ= (ز) ٧٥١٠٦- ومجاهد بن جبر= (ز) ٧٥١٠٧- والضَّحّاك بن مُزاحِم= (ز) ٧٥١٠٨- وعطاء بن أبي رباح، قالوا: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</q> مِن سابقي هذه الأُمّة، <q>﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> مِن آخر هذه الأُمّة في آخر الزمان{9}. (ز) ٧٥١٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</q>، قال: أُمّة{10}. (ز) ٧٥١١٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله تعالى: <q>﴿ثلة من الأولين وثلة من الآخرين﴾</q>، قال: مثل قوله: <q>﴿فمنهم ظالم لنفسه ومنهم مقتصد ومنهم سابق بالخيرات﴾</q> [فاطر:٣٢]{11}. (ز) ٧٥١١١- عن عبد الله بن الحارث -من طريق عوف- قال: كلهم في الجنة{12}. (ز) ٧٥١١٢- قال الحسن البصري -من طريق سفيان-: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ﴾</q> من الأمم، <q>﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> أُمّة محمد ﷺ{13}٦٤٣٨. (ز) ٦٤٣٨ ذكر ابنُ عطية (٨/٢٠٠) قول الحسن أنّ «الأوّلين: سالف الأمم، منهم جماعة عظيمة هم أصحاب اليمين، والآخرين: هذه الأُمّة، منهم جماعة عظيمة أهل يمين». ثم علَّق بقوله: «بل جميعهم إلا مَن كان من السابقين». ٧٥١١٣- عن محمد بن سيرين -من طريق أبي هلال- <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، قال: كانوا يقولون: كلّهم من هذه الأُمّة{14}. (ز) ٧٥١١٤- عن ميمون بن مهران، في قوله: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>، قال: كثير من الأوّلين، وكثير من الآخرين{15}. (١٤/٢٠٧) ٧٥١١٥- عن قتادة بن دعامة -من طريق معمر- أنه بلَغه: أنّ النبي ﷺ قال: «أتَرْضَون أن تكونوا ربع أهل الجنة؟». قالوا: نعم. قال: «أتَرْضَون أنْ تكونوا ثلث أهل الجنة؟». قالوا: نعم. قال: «والذي نفسي بيده، إني لأرجو أن تكونوا شطر أهل الجنة». ثم تلا قتادة: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q>{16}. (ز) ٧٥١١٦- قال مقاتل: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> مِن مؤمني هذه الأمة{17}. (ز) ٧٥١١٧- قال مقاتل بن سليمان: <q>﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> يعني: جَمْع مِن الأوّلين، يعني: الأمم الخالية، <q>﴿وثُلَّةٌ مِنَ الآخِرِينَ﴾</q> يعني: أُمّة محمد ﷺ، فإنّ أُمّة محمد أكثر أهل الجنة، وهم سابقو الأمم الخالية ومُقرّبوها{18}. (ز) ",footnotes:1:الظِّراب: الجبال الصِّغار. النهاية (ظرب).أخرجه البزار ٤/٢٧٠-٢٧٢ (١٤٤١)، والحاكم ٤/٦٢١ (٨٧٢١)، وابن حبان ١٤/٣٤١-٣٤٣ (٦٤٣١)، والثعلبي ٩/٢١٢-٢١٣، وابن جرير ٢٢/٣٣١-٣٣٢، جميعهم عن عمران بن حصين، عن عبد الله بن مسعود. قال البزار: «هذا الحديث لا نعلمه يُروى عن عبد الله عن النبي ﷺ إلا من هذا الوجه بهذا الإسناد». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه بهذه السياقة». ووافقه الذهبي. وقال الهيثمي في المجمع ١٠/٤٠٦ (١٨٦٩٢): «رواه أحمد بأسانيد، والبزار أتم منه، والطبراني، وأبو يعلى باختصار كثير، وأحد أسانيد أحمد والبزار رجاله رجال الصحيح».أخرجه أبو داود الطيالسي في مسنده ٢/٢٠٩ (٩٢٧)، وابن الأعرابي في معجمه ٣/٩٣٨ (١٩٣٩). قال الدارقطني في العلل ٧/١٦٤ (١٢٧٧): «لم يثبت». وقال الهيثمي في المجمع ٧/١١٨-١١٩ (١١٣٩٥): «رواه الطبراني بإسنادين؛ رجال أحدهما رجال الصحيح، غير علي بن زيد، وهو ثقة، سيئ الحفظ».أخرجه ابن بشران في أماليه ٢/٢٩٨ (١٥٤٨)، وبيبي في جزئها ص٤٤ (٣٣)، وابن جرير ٢٢/٣٣٤، والثعلبي ٩/٢١٣. قال ابن القيسراني في ذخيرة الحفاظ ٢/١١٩٠ (٢٥٤٢): «رواه أبان بن أبي عيّاش، عن سعيد بن جُبَير، عن ابن عباس في هذه الآية. وأبان متروك الحديث». وقال الزيلعي في تخريج الكشاف ٣/٤٠٤: «ضعّفه الطبري».أخرجه الفسوي في المعرفة والتاريخ ٣/٢٤.عزاه السيوطي إلى عبد الرزاق، وابن المنذر، وابن مردويه.أخرجه مقاتل بن سليمان ٤/٢١٩-٢٢٠.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢٠٩، وتفسير البغوي ٨/١٨.تفسير مجاهد ص٦٤٣، وأخرجه عبد بن حميد -كما في تغليق التعليق ٤/٣٣٥-، وابن جرير ٢٢/٣٣٠، والفريابي -كما في الفتح ٨/٦٢٦-.أخرجه أبو جعفر الرملي في جزئه ص٦٢ (تفسير مسلم الزنجي).أخرجه ابن جرير ٢٢/٣٣٣.أخرجه ابن جرير ٢٢/٣٣٠.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٣-.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٦-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧١، والبخاري في الرقاق ٧/١٩٥، ومسلم في الإيمان ١/١٣٩، والترمذي في صفة الجنة ٤/٨٩، وابن جرير ٢٢/٣٣٣.تفسير البغوي ٨/١٦.تفسير مقاتل بن سليمان ٤/٢١٩.
