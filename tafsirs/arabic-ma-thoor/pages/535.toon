quran[34]{c,v,t}:
56,17," <q>﴿یَطُوفُ عَلَیۡهِمۡ وِلۡدَ ٰ⁠نࣱ مُّخَلَّدُونَ ۝١٧﴾</q> - تفسير ٧٤٨٦٨- قال علي بن أبي طالب: <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q> هم أولاد أهل الدنيا، لم يكن لهم حسنات فيُثابوا عليها، ولا سيئات فيُعاقبوا عليها؛ لأنّ الجنة لا وِلادة فيها{1}. (ز) ٧٤٨٦٩- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q>، قال: خَلَقهم الله في الجنة كما خَلَق الحُور العِين؛ لا يموتون، لا يَشِيبون، ولا يَهْرمون{2}. (١٤/٢٤٨-٢٤٩) ٧٤٨٧٠- عن سعيد بن جُبَير: مُقَرَّطون{3}. (ز) ٧٤٨٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q>، قال: لا يموتون{4}. (١٤/١٨٤) ٧٤٨٧٢- عن عكرمة مولى ابن عباس: <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q> مُنعّمون{1}. (ز) ٧٤٨٧٣- عن الحسن البصري -من طريق المبارك- <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q>، قال: لم يكن لهم حسنات يُجْزَون بها، ولا سيئات يُعاقبون عليها، فوُضعوا في هذه المواضع{6}. (١٤/١٨٤) ٧٤٨٧٤- قال محمد بن السّائِب الكلبي: <q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ مُخَلَّدُونَ﴾</q> لا يَهْرمون، ولا يَكبُرون، ولا ينقصون، ولا يتغيّرون، وليس كخَدَم الدنيا يتغيّرون مِن حال إلى حال{1}. (ز) ٧٤٨٧٥- قال مقاتل بن سليمان:<q>﴿يَطُوفُ عَلَيْهِمْ وِلْدانٌ﴾</q> يعني: غِلمانٌ لا يَكبُرون <q>﴿مُخَلَّدُونَ﴾</q> لا يموتون{8}٦٤٢٥. (ز) ٦٤٢٥ اختُلف في معنى: <q>﴿مُخَلَّدُونَ﴾</q> في هذه الآية على قولين: الأول: أنهم وِلدان على سنٍّ واحدة، لا يتغيَّرون ولا يموتون. الثاني: مُقَرَّطون مُسَوَّرون. الثالث: مُنَعَّمون. ورجَّح ابنُ جرير (٢٢/٢٩٥) القول الأول مستندًا إلى اللغة، وهو قول مجاهد، ومحمد بن السّائِب، ومقاتل، وعلَّل ذلك بقوله: «لأن ذلك أظهر معنييه، والعرب تقول للرجل إذا كبر ولم يَشْمَط: إنه لَمُخَلَّدٌ». ونحوه قال ابنُ عطية (٨/١٩٤). ",footnotes:1:تفسير الثعلبي ٩/٢٠٤.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢٠٤، وتفسير البغوي ٨/١٠ وعقّب عليه بقوله: يقال: خلَّد جاريته إذا حلاها بالخِلْد، وهو القِرْط.تفسير مجاهد ص٦٤١، وأخرجه ابن جرير ٢٢/٢٩٥، وابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٢٠٤.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤١-. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢٠٤.تفسير مقاتل بن سليمان ٤/٢١٧.
56,18," <q>﴿بِأَكۡوَابࣲ وَأَبَارِیقَ﴾</q> - تفسير ٧٤٨٧٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿بِأَكْوابٍ﴾</q>، قال: الأكواب: الجِرار من الفِضّة{1}. (ز) ٧٤٨٧٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿بِأَكْوابٍ وأَبارِيقَ﴾</q>: والأكواب: التي ليس لها آذان مثل الصّواع. والأباريق: التي لها الخراطيم والأعناق{2}. (١٤/٢٤٩) ٧٤٨٧٨- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿بِأَكْوابٍ وأَبارِيقَ﴾</q>، قال: الأكواب: ليس لها آذان. والأباريق: التي لها آذان{3}. (١٤/١٨٤) ٧٤٨٧٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول: الأكواب: جِرار ليست لها عُرًى، وهي بالنَّبَطية: كوبا{4}. (ز) ٧٤٨٨٠- عن عكرمة مولى ابن عباس، قال: الأكواب: الأقداح{5}. (١٤/١٨٥) ٧٤٨٨١- عن أبي رجاء، قال: سألتُ الحسن [البصري] عن الأكواب، فقال: هي الأباريق التي يُصبّ منها{6}. (١٤/١٨٤) ٧٤٨٨٢- عن ابن إدريس، قال: سمعت أبي، قال: مرَّ أبو صالح صاحب الكلبي، قال: فقال أبي: قال لي الحسن وأنا جالس: سَلْه. فقلتُ: ما الأكواب؟ قال: جرار الفِضّة المستديرة أفواهها. والأباريق: ذوات الخراطيم{7}. (ز) ٧٤٨٨٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بِأَكْوابٍ وأَبارِيقَ﴾</q>، قال: الأكواب التي دون الأباريق ليس لها عُرًى{8}. (ز) ٧٤٨٨٤- قال مقاتل بن سليمان: <q>﴿بِأَكْوابٍ وأَبارِيقَ﴾</q> أكواب يعني: الأكواب العظام من فِضّة، المُدوّرة الرؤوس ليس لها عُرًى ولا خراطيم، وأباريق من فِضّة في صفاء القوارير، فذلك قوله في <q>﴿هَلْ أتى عَلى الإنْسانِ﴾</q>: <q>﴿كانَتْ قَوارِيرا قَوارِيرَ مِن فِضَّةٍ﴾</q> [الإنسان:١٥-١٦]{9}. (ز) <q>﴿وَكَأۡسࣲ مِّن مَّعِینࣲ ۝١٨﴾</q> - تفسير ٧٤٨٨٥- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q>، قال: الخمر{4}. (ز) ٧٤٨٨٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q>، قال: الكأس من الخمر بعينها، ولا يكون كأسٌ حتى يكون فيها الخمر، فإذا لم يكن فيها خمر فإنما هو إناء، والمَعِين يقول: من خمرٍ جارٍ{2}. (١٤/٢٤٩) ٧٤٨٨٧- عن مجاهد بن جبر، في قوله: <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q>، قال: خمر بيضاء{12}. (١٤/١٨٤) ٧٤٨٨٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q>: الكأس: الخمر الجارية{13}. (ز) ٧٤٨٨٩- قال الضَّحّاك بن مُزاحِم -من طريق سفيان، وسلمة-: كلّ كأس في القرآن فهو خمر{13}. (ز) ٧٤٨٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q>، قال: يعني: الخمر، وهي هناك جارية؛ المَعين الجاري{15}. (١٤/١٨٥) ٧٤٨٩١- قال مقاتل بن سليمان: <q>﴿وكَأْسٍ مِن مَعِينٍ﴾</q> يعني: من خمر جارٍ، وكلّ مَعينٍ في القرآن فهو: جارٍ، غير الذي في <q>﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾</q> يعني به: زمزم؛ <q>﴿إنْ أصْبَحَ ماؤُكُمْ غَوْرًا فَمَن يَأْتِيكُمْ بِماءٍ مَعِينٍ﴾</q> [الملك:٣٠] يعني: ظاهرًا تَناله الدِّلاء، وكلّ شيء في القرآن كأس فهو الخمر{16}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/٢٩٥.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٩٦، وابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٩٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٩٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٩٦.أخرجه عبد الرزاق ٢/٢٧٠، وابن جرير ٢٢/٢٩٦-٢٩٧، وبنحوه من طريق سعيد، وعبد بن حميد -كما في الفتح ٦/٣٢٢-.تفسير مقاتل بن سليمان ٤/٢١٧.أخرجه ابن جرير ٢٢/٢٩٧.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣)، وابن جرير ٢٢/٢٩٩-٣٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٩٨.أخرجه ابن جرير ٢٢/٢٩٨.أخرجه ابن جرير ٢٢/٢٩٧ بلفظ: من خمر جارية، ٢٢/٢٩٨ من طريق أبي هلال. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢١٧-٢١٨.
56,19," <q>﴿لَّا یُصَدَّعُونَ عَنۡهَا وَلَا یُنزِفُونَ ۝١٩﴾</q> - تفسير ٧٤٨٩٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <q>﴿لا يُصَدَّعُونَ عَنْها﴾</q> عن الخمر، <q>﴿ولا يُنْزِفُونَ﴾</q> لا تذهب بعقولهم{1}. (١٤/٢٤٩) ٧٤٨٩٣- عن سعيد بن جُبَير -من طريق سالم- في قوله: <q>﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</q>، قال: لا تُصدّع رؤوسهم، ولا تُنزَف عقولهم{2}. (١٤/١٨٥) ٧٤٨٩٤- عن سعيد -من طريق يزيد- في قوله: <q>﴿ولا يُنْزِفُونَ﴾</q>، قال: لا يُغلَب أحدٌ على عقله{3}. (ز) ٧٤٨٩٥- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</q>، قال: لا تُصدّع رؤوسهم، ولا يقيئونها. وفي لفظ: ولا تُنزَف عقولهم{4}. (١٤/١٨٤) ٧٤٨٩٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</q>، قال: لا تُصدّع رؤوسهم، ولا تذهب عقولهم{5}. (١٤/١٨٥) ٧٤٨٩٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</q>، قال: أهل الجنة يأكلون ويشربون، ولا يُنزَفون كما يُنزَف أهل الدنيا إذا أكثروا الطعام والشراب. يقول: لا يَملّوا{6}. (١٤/١٨٥) ٧٤٨٩٨- عن محمد بن كعب القُرَظيّ -من طريق أبي صخر- يقول: <q>﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</q>، قال: لا تُصدّع رؤوسهم، ولا تُنزَف عقولهم{7}. (ز) ٧٤٨٩٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزِفُونَ﴾</q>، قال: ليس فيها وجع الرأس، ولا يُغلَب أحدٌ على عقله{8}. (١٤/١٨٥) ٧٤٩٠٠- قال مقاتل بن سليمان: <q>﴿لا يُصَدَّعُونَ عَنْها﴾</q> فتوجع رؤوسهم، <q>﴿ولا يُنْزِفُونَ﴾</q> بها{9}٦٤٢٦. (ز) ٦٤٢٦ نقل ابنُ عطية (٨/١٩٤) في معنى: <q>﴿لا يُصَدَّعُونَ عَنْها﴾</q> عن قوم أنّ المعنى: «لا يتفرقون عنها». ثم وجَّهه بقوله: «بمعنى: لا تُقطَع عنهم لذتهم بسبب من الأسباب، كما يفرق أهل خمر الدنيا بأنواع من التفريق، وهذا كما قال: «يتصدَّعُ السحاب عن المدينة ...» الحديث». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٩٨-٣٠٠، وابن أبي شيبة ١٣/١٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٠٠.أخرجه ابن جرير ٢٢/٣٠٠، وابن أبي شيبة ١٣/١٣٩، وهناد (٦٩-٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٩٩-٣٠٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥١ (٣٠٧).أخرجه ابن جرير ٢٢/٢٩٧، ٢٩٩، ٣٠١، وبنحوه من طريق أبي هلال. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢١٨.
56,20," <q>﴿وَفَـٰكِهَةࣲ مِّمَّا یَتَخَیَّرُونَ ۝٢٠﴾</q> - تفسير ٧٤٩٠١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وفاكِهَةٍ مِمّا يَتَخَيَّرُونَ﴾</q>، يقول: مما يشتهون{1}. (١٤/٢٤٩) ٧٤٩٠٢- قال مقاتل بن سليمان: <q>﴿وفاكِهَةٍ مِمّا يَتَخَيَّرُونَ﴾</q>، يعني: يختارون مِن ألوان الفاكهة{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢١٨.
56,21," <q>﴿وَلَحۡمِ طَیۡرࣲ مِّمَّا یَشۡتَهُونَ ۝٢١﴾</q> - تفسير ٧٤٩٠٣- قال عبد الله بن عباس: <q>﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</q> يخْطر على قلبه لحمُ الطير، فيصير مُمثّلًا بين يديه على ما اشتهى{1}. (ز) ٧٤٩٠٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</q>، يقول: يجيئهم الطير حتى يقع فيبسط جناحه، فيأكلون منه ما اشتَهوا نضيجًا لم تُنضجه النار، حتى إذا شبعوا منه طار، فذهب كما كان{2}. (١٤/٢٤٩) ٧٤٩٠٥- عن الحسن البصري، في قوله: <q>﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</q>، قال: لا يشتهي منها شيئًا إلا صار بين يديه، فيصيب منه حاجته، ثم يطير فيذهب{3}. (١٤/١٨٦) ٧٤٩٠٦- قال مقاتل بن سليمان: <q>﴿ولَحْمِ طَيْرٍ مِمّا يَشْتَهُونَ﴾</q>، يعني: من لحم الطير؛ إن شاؤوا شواء، وإن شاؤوا قديدًا، كلّ طير يَنعت نفسه لوليّ الله تعالى{4}. (ز) <q>﴿وَلَحۡمِ طَیۡرࣲ مِّمَّا یَشۡتَهُونَ ۝٢١﴾</q> - آثار متعلقة بالآية ٧٤٩٠٧- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «إنّك لَتنظر إلى الطير في الجنة، فتشتهيه، فيَخِرُّ بين يديك مشوِيًّا»{5}. (١٤/١٨٦) ٧٤٩٠٨- عن ميمونة، أنّ النبيَّ ﷺ قال: «إنّ الرجل لَيشتهي الطيرَ في الجنة، فيجيء مثل البُخْتيّ{6} حتى يقع على خِوانه، لم يُصبه دُخان، ولم تمسّه نار، فيأكل منه حتى يشبع، ثم يطير»{7}. (١٤/١٨٧) ٧٤٩٠٩- عن أبي سعيد الخُدري، قال: قال رسول الله ﷺ: «إنّ في الجنة لَطيرًا فيه سبعون ألف ريشة، فيجيء، فيقع على صَحْفة الرجل مِن أهل الجنة، فيَخرُج مِن كلّ ريشة لون أبيض مِن الثّلج، وأليَن مِن الزُّبْد، وأعذب مِن الشّهد، ليس فيه لون يشبه صاحبه، ثم يطير فيذهب»{8}. (١٤/١٨٨) ٧٤٩١٠- عن أنس بن مالك، قال: قال رسول الله ﷺ: «إنّ طير الجنة كأمثال البُخْت، ترعى في شجر الجنة». فقال أبو بكر: يا رسول الله ﷺ، إنّ هذه الطير لَناعمة. فقال: «آكِلُها أنعمُ منها، وإني لأرجو أن تكون ممن يأكل منها»{9}. (١٤/١٨٦) ٧٤٩١١- عن أبي أُمامة، قال: إنّ الرجل مِن أهل الجنة لَيشتهي الطيرَ مِن طيور الجنة، فيقع في يده مقليًّا نضيجًا{10}. (١٤/١٨٧) ",footnotes:1:تفسير البغوي ٨/١٠.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢١٨.أخرجه ابن أبي الدنيا في صفة الجنة ص١٠٢-١٠٣ (١٠٠)، والبزار ٥/٤٠١-٤٠٢ (٢٠٣٢)، وسعيد بن منصور في سننه - التفسير ٥/٤٣٧-٤٣٨ (١١٧١). قال العراقي في تخريج أحاديث الإحياء ص١٩٢٩: «أخرجه البزار بإسناد صحيح». وقال الهيثمي في المجمع ١٠/٤١٤ (١٨٧٣٤): «رواه البزار، وفيه حميد بن عطاء الأعرج، وهو ضعيف». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢٣٥ (٧٨٦٣): «رواه أبو يعلى الموصلي، والبزار، وابن أبي الدنيا، والبيهقي، ومدار أسانيدهم على حميد الأعرج، وهو ضعيف». وقال الألباني في الضعيفة ١٤/٦٤٠-٦٤١ (٦٧٨٤): «ضعيف جدًّا ... ووقع في تخريج الإحياء: أخرجه البزار بإسناد صحيح، فالظاهر أنه خطأ مطبعي».البُخْتي: إبل خُراسانيّة طوال الأعناق. تاج العروس (بخت).أخرجه ابن أبي الدنيا في صفة الجنة ص١١٣ (١١٩). إسناده ضعيف؛ فيه رجل مجهول.أخرجه ابن أبي الدنيا في صفة الجنة ص١٠٤ (١٠٣)، وأبو نعيم الأصبهاني في صفة الجنة ٢/١٨١-١٨٢ (٣٤٠)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٢٣-٥٢٤-، والثعلبي ٩/٢٠٤. قال ابن كثير: «هذا الحديث من رواية ابن أبي حاتم بسنده عن أبيه، عن علي بن محمد الطنافسي، عن أبي معاوية، عن عبيد الله بن الوليد الوصافي، عن عطية العَوفيّ، عن أبي سعيد الخدري ﵄ مرفوعًا، وهذا حديث غريب جدًّا، والوصافي وشيخه ضعيفان». وقال الألباني ١١/٤٥ (٥٠٢٦): «ضعيف».أخرجه أحمد ٢١/٣٤-٣٥ (١٣٣١١). قال المنذري في الترغيب والترهيب ٤/٢٩٢ (٥٦٩٠): «بإسناد جيد». وقال العراقي في تخريج أحاديث الإحياء ص١٩٢٩: «بإسناد صحيح».أخرجه ابن أبي الدنيا في صفة الجنة (١١٢).
56,22," <q>﴿وَحُورٌ عِینࣱ ۝٢٢﴾</q> - تفسير ٧٤٩١٢- عن أم سلمة، قالت: قلتُ: يا رسول الله، أخبِرني عن قول الله ﷿: <q>﴿حُورٌ عِينٌ﴾</q>. قال: «حُور: بِيض، عِين: ضخام العيون، شَفْر الحوراء بمنزلة جَناح النّسور». وفي لفظ ابن مردويه: «شَفر الجُفون بمنزلة جَناح النّسر»{1}. (١٤/١٥٩) ٧٤٩١٣- عن عبد الله بن عباس -من طريق عطاء- قال: الحُور: سُود الحَدَق{2}. (ز) ٧٤٩١٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وحُورٌ عِينٌ﴾</q>، قال: الحُور: البِيض. والعين: العظام الأعين، حِسان{3}. (١٤/٢٤٩) ٧٤٩١٥- عن مجاهد بن جبر -من طريق سفيان، عن رجل- في قوله: <q>﴿وحُورٌ عِينٌ﴾</q>، قال: يَحارُ فيهنّ البصرُ{4}. (١٤/١٨٩) ٧٤٩١٦- عن الضَّحّاك بن مُزاحِم -من طريق سفيان، عن رجل- <q>﴿وحُورٌ﴾</q> قال: بِيض، <q>﴿عِينٌ﴾</q> قال: عِظام الأعين{2}. (ز) ٧٤٩١٧- عن الحسن البصري -من طريق عبادة بن منصور الناجي- يقول: الحُور: صوالح نساء بني آدم{2}. (ز) ٧٤٩١٨- عن الحسن البصري -من طريق عمرو- <q>﴿وحُورٌ عِينٌ﴾</q>، قال: شديدة السّواد؛ سواد العين، شديدة البياض؛ بياض العين{7}. (ز) ٧٤٩١٩- قال مقاتل بن سليمان: <q>﴿وحُورٌ﴾</q> يعني: البيضاء <q>﴿عِينٌ﴾</q> العيناء، حِسان الأعين{8}. (ز) ",footnotes:1:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠)، وفي الأوسط ٣/٢٧٨-٢٧٩ (٣١٤١)، وابن جرير ٢٢/٢٦٣، ٣٠٤، والثعلبي ٩/٢٠٥. وعزاه السيوطي إلى ابن مردويه. وتقدم مطولًا مع تخريجه عند تفسير قوله تعالى: <q>﴿فِيهِنَّ خَيْراتٌ حِسانٌ﴾</q> [الرحمن:٧٠].أخرجه ابن جرير ٢٢/٣٠٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٠٤، وابن أبي شيبة ١٣/٥٦٩.أخرجه ابن جرير ٢٢/٣٠٣.أخرجه ابن جرير ٢٢/٣٠٣.أخرجه ابن جرير ٢٢/٣٠٢.تفسير مقاتل بن سليمان ٤/٢١٨.
56,23," <q>﴿كَأَمۡثَـٰلِ ٱللُّؤۡلُوِٕ ٱلۡمَكۡنُونِ ۝٢٣﴾</q> - تفسير ٧٤٩٢٠- عن أُمّ سلمة، قالت: قلتُ: يارسول الله، أخبِرني عن قول الله: <q>﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</q>. قال: «صفاؤهنّ كصفاء الدُّر الذي في الأصداف الذي لا تمسّه الأيدي»{1}. (ز) ٧٤٩٢١- عن عبد الله بن عباس، في قوله: <q>﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</q>، قال: الذي في الصّدف لم يُجوّز على الأيدي{2}. (١٤/١٨٩) ٧٤٩٢٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿كَأَمْثالِ اللُّؤْلُؤِ﴾</q> قال: كبياض اللؤلؤ التي لم تمسّهن الأيدي ولا الدهر، <q>﴿المَكْنُونِ﴾</q> الذي في الأصداف{3}. (١٤/٢٤٩) ٧٤٩٢٣- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</q>، قال: اللؤلؤ العِظام الذي قد أُكِنّ مِن أن يمسّه شيءٌ{4}. (١٤/١٨٩) ٧٤٩٢٤- قال مقاتل بن سليمان: <q>﴿كَأَمْثالِ اللُّؤْلُؤِ المَكْنُونِ﴾</q> فشبّههم في الكنّ كأمثال اللؤلؤ المكنون في الصّدف المُطبق عليه، لم تمسّه الأيدي، ولم تَره الأعين، ولم يخْطُر على قلب بشر، كأحسن ما يكون{5}. (ز) ",footnotes:1:أخرجه الطبراني في الكبير ٢٣/٣٦٧-٣٦٨ (٨٧٠) مطولًا، وابن جرير ٢٢/٣٠٤. قال الهيثمي في المجمع ٧/١١٩ (١١٣٩٦): «رواه الطبراني، وفيه سليمان بن أبي كريمة، ضعَّفه أبو حاتم، وابن عدي».عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه هناد بن السري (٢٠).تفسير مقاتل بن سليمان ٤/٢١٨.
56,24," <q>﴿جَزَاۤءَۢ بِمَا كَانُوا۟ یَعۡمَلُونَ ۝٢٤﴾</q> - تفسير ٧٤٩٢٥- قال مقاتل بن سليمان: <q>﴿جَزاءً بِما كانُوا يَعْمَلُونَ﴾</q> في الدنيا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٢١٨.
56,25," <q>﴿لَا یَسۡمَعُونَ فِیهَا لَغۡوࣰا وَلَا تَأۡثِیمًا ۝٢٥﴾</q> - تفسير ٧٤٩٢٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</q> قال: باطلًا. وفي قوله: <q>﴿ولا تَأْثِيمًا﴾</q> قال:كذبًا{1}. (١٤/١٨٩) ٧٤٩٢٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</q> قال: اللغو: الحلف؛ لا والله، وبلى والله. <q>﴿ولا تَأْثِيمًا﴾</q> قال: لا يأثمون{2}. (١٤/٢٤٩) ٧٤٩٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</q>: لا يَسْتَبُّون{3}. (ز) ٧٤٩٢٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لغوا﴾</q> باطلًا، <q>﴿تأثيما﴾</q> كذبًا{4}. (ز) ٧٤٩٣٠- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿لا يَسْمَعُونَ فِيها لَغْوًا﴾</q>، قال: الهذْرُ من القول، والتأثيم الكذب{5}. (١٤/١٨٩) ٧٤٩٣١- قال مقاتل بن سليمان: <q>﴿لا يَسْمَعُونَ فِيها﴾</q> يعني: في الجنة، يقول: لا يسمع في الجنة بعضهم من بعض <q>﴿لَغْوًا﴾</q> يعني: الحلف، <q>﴿ولا تَأْثِيمًا﴾</q> يعني: كذِبًا عند الشّراب؛ كفعل أهل الدنيا إذا شربوا الخمر{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤١.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٤-٥٠٥-.أخرجه هناد (٦).تفسير مقاتل بن سليمان ٤/٢١٨.
56,26," <q>﴿إِلَّا قِیلࣰا سَلَـٰمࣰا سَلَـٰمࣰا ۝٢٦﴾</q> - تفسير ٧٤٩٣٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿إلّا قِيلًا سَلامًا سَلامًا﴾</q>، يقول: التسليم منهم وعليهم، بعضهم على بعض، قال: هؤلاء المُقرّبون{1}. (١٤/٢٤٩) ٧٤٩٣٣- قال عطاء: <q>﴿إلّا قِيلًا سَلامًا سَلامًا﴾</q> يُحيي بعضهم بعضًا بالسلام{2}٦٤٢٧. (ز) ٦٤٢٧ ذكر ابنُ عطية (٨/١٩٧) أنّ الاستثناء في قوله تعالى: <q>﴿إلّا قِيلًا سَلامًا سَلامًا﴾</q> استثناء متصل، ثم نقل عن قوم: أنه منقطع، و<q>﴿سَلامًا﴾</q> نعت للقيل. ثم وجَّهه بقوله: «كأنه تعالى قال: إلا قيلًا سالمًا مِن هذه العيوب وغيرها». ونقل عن الزّجّاج: أنّ <q>﴿سَلامًا﴾</q> مصدر، وناصبه <q>﴿قِيلًا﴾</q>. ثم وجَّهه بقوله: «كأنه تعالى ذكر أنهم يقول بعضهم لبعض: سَلامًا سَلامًا». ٧٤٩٣٤- قال مقاتل بن سليمان: <q>﴿إلّا قِيلًا سَلامًا سَلامًا﴾</q>، يعني: كثرة السلام من الملائكة. نظيرها في الرعد [٢٣-٢٤]: <q>﴿والمَلائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِن كُلِّ بابٍ * سَلامٌ عَلَيْكُمْ﴾</q>{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٨/١١.تفسير مقاتل بن سليمان ٤/٢١٨.
56,27," <q>﴿وَأَصۡحَـٰبُ ٱلۡیَمِینِ﴾</q> - تفسير ٧٤٩٣٥- عن علي بن أبي طالب -من طريق زاذان- يقول: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</q>، قال: أصحاب اليمين: أطفال المؤمنين{1}. (ز) ٧٤٩٣٦- عن أبي عبد الرحمن الحُبُليِّ -من طريق عمرو بن لبيد- يقول: إن <q>﴿وأَصْحابُ اليَمِينِ﴾</q> هم الوِلدان{2}. (ز) <q>﴿مَاۤ أَصۡحَـٰبُ ٱلۡیَمِینِ ۝٢٧﴾</q> - تفسير ٧٤٩٣٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</q> وما أعدّ لهم!{3}. (١٤/٢٤٩) ٧٤٩٣٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</q>: أي: ماذا لهم، وماذا أعدّ لهم{4}. (ز) ٧٤٩٣٩- قال مقاتل بن سليمان: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</q>، يقول: ما لأصحاب اليمين من الخير، ثم ذكر ما أعدّ الله لهم مِن الخير في الآخرة{5}. (ز) <q>﴿مَاۤ أَصۡحَـٰبُ ٱلۡیَمِینِ ۝٢٧﴾</q> - آثار متعلقة بالآية ٧٤٩٤٠- عن معاذ بن جبل: أنّ رسول الله ﷺ تلا هذه الآية: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ﴾</q>، <q>﴿وأَصْحابُ الشِّمالِ ما أصْحابُ الشِّمالِ﴾</q>، فقبض بيديه قبضتين، فقال: «هذه في الجنة ولا أبالي، وهذه في النار ولا أبالي»{6}. (١٤/١٩٠) ",footnotes:1:أخرجه ابن جرير ٢٢/٣٠٦، وعبد الرزاق ٢/٢٧٠ بلفظ: أطفال المسلمين.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٩٨ (٢٢٢).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٠٦.تفسير مقاتل بن سليمان ٤/٢١٨.أخرجه أحمد ٣٦/٣٩٥ (٢٢٠٧٧). قال الهيثمي في المجمع ٧/١٢٠ (١١٣٩٨): «وفيه البراء بن عبد الله الغنوي، قال ابن عدي: وهو أقرب عندي إلى الصدق منه إلى الضعف، وبقية رجاله رجال الصحيح، إلا أنّ الحسن لم يسمع من معاذ».
56,28," <q>﴿فِی سِدۡرࣲ مَّخۡضُودࣲ ۝٢٨ وَطَلۡحࣲ مَّنضُودࣲ ۝٢٩ وَظِلࣲّ مَّمۡدُودࣲ ۝٣٠﴾</q> - نزول الآيات ٧٤٩٤١- قال أبو العالية الرِّياحيّ= (ز) ٧٤٩٤٢- والضَّحّاك بن مُزاحِم: نظر المسلمون إلى وجّ -وهو وادٍ مُخصب بالطائف-، فأعجبهم سِدْرها، وقالوا: يا ليت لنا مثل هذا. فأنزل الله تعالى هذه الآية: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>{1}. (ز) ٧٤٩٤٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: كانوا يُعجبون بوَجٍّ وظِلاله؛ مِن طَلْحِه وسِدْرِه؛ فأنزل الله: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ فِي سِدْرٍ مَخْضُودٍ وطَلْحٍ مَنضُودٍ وظِلٍّ مَمْدُودٍ﴾</q>{2}. (١٤/١٩٠) ٧٤٩٤٤- عن عطاء= (ز) ٧٤٩٤٥- ومجاهد بن جبر -من طريق خُصَيف- قالا: لَمّا سأل أهلُ الطائف الوادي يُحمى لهم، وفيه عسل، ففعل، وهو واد مُعجِب، فسمعوا الناس يقولون: في الجنة كذا وكذا. قالوا: يا ليت لنا في الجنة مثل هذا الوادي. فأنزل الله: <q>﴿وأَصْحابُ اليَمِينِ ما أصْحابُ اليَمِينِ فِي سِدْرٍ مَخْضُودٍ﴾</q>{3}. (١٤/١٨٩) <q>﴿فِی سِدۡرࣲ مَّخۡضُودࣲ ۝٢٨﴾</q> - تفسير ٧٤٩٤٦- عن أبي أُمامة، قال: كان أصحاب رسول الله ﷺ يقولون: إنّ الله ينفعنا بالأعراب ومسائلهم. أقبل أعرابيٌّ يومًا، فقال: يا رسول الله، لقد ذكر الله في القرآن شجرةً مُؤذية، وما كنتُ أرى أنّ في الجنة شجرة تؤذي صاحبها! فقال رسول الله ﷺ: «وما هي؟». قال: السِّدر؛ فإنّ لها شوكًا. فقال رسول الله ﷺ: «أليس يقول: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>؟! يُخَضِّد الله شوكه، فيجعل مكان كلّ شوكة ثمرة، فإنها تُنبتُ ثمرًا، تُفْتقُ الثمرة منها عن اثنين وسبعين لونًا من الطعام، ما منها لون يشبه الآخر»{4}. (١٤/١٩٠) ٧٤٩٤٧- عن عُتبة بن عبد الله السّلميّ، قال: كنتُ جالسًا مع النبيِّ ﷺ، فجاء أعرابيٌّ، فقال: يا رسول الله، أسْمَعُكَ تذكرُ في الجنة شجرةً لا أعلم شجرةً أكثر شوكًا منها. يعني: الطّلح، فقال رسول الله ﷺ: «إنّ الله يجعل مكان كلّ شوكة منها ثمرة مثل خُصْية التَّيْس المَلْبُود{5}» يعني: الخصِيّ منها «فيها سبعون لونًا من الطعام لا يشبه لون الآخر»{6}. (١٤/١٩١) ٧٤٩٤٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: خَضَده وِقرُه من الحَمْل{7}. (١٤/١٩١) ٧٤٩٤٩- عن عبد الله بن عباس -من طريق علي- <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: المخضود؛ الذي لا شوك فيه{8}. (١٤/١٩١) ٧٤٩٥٠- عن عبد الله بن عباس، قال: المخضود: المُوقر الذي لا شوك فيه{9}. (١٤/١٩٢) ٧٤٩٥١- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>. قال: الذي ليس له شوك. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول أُميّة بن أبي الصّلت: إنّ الحدائق في الجنان ظَليلة فيها الكواعب سِدرها مخضود؟{10}. (١٤/١٩٢) ٧٤٩٥٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>: والمخضود: المُوقر الذي لا شوك فيه{11}. (١٤/٢٤٩) ٧٤٩٥٣- عن أبي الأَحْوص [عوف بن مالك بن نضلة الأشجعي] -من طريق أبي إسحاق- <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: لا شوك له{12}. (ز) ٧٤٩٥٤- عن قَسامة بن زهير -من طريق عوف- في قوله: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: خُضِد من الشوك، فلا شوك فيه{13}. (ز) ٧٤٩٥٥- عن سعيد بن جُبَير -من طريق عطاء بن السّائِب- <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: ثمرها أعظم من القِلال{14}. (ز) ٧٤٩٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سدر مخضود﴾</q>، قال: المُوقَر حملًا{15}. (١٤/١٩٤) ٧٤٩٥٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿سِدْرٍ مَخْضُودٍ﴾</q>، يقول: مُوقَر{14}. (ز) ٧٤٩٥٨- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿وسدر مخضود﴾</q>، قال: المواقير؛ لا شوك فيه{17}. (ز) ٧٤٩٥٩- عن عكرمة مولى ابن عباس -من طريق حبيب بن أبي ثابت، ومهران- قوله: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: لا شوك فيه{18}. (ز) ٧٤٩٦٠- قال الحسن البصري: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q> لا يعقر الأيدي{19}. (ز) ٧٤٩٦١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿سِدْرٍ مَخْضُودٍ﴾</q>، قال: كثير الحمل، ليس له شوك{20}. (ز) ٧٤٩٦٢- عن يزيد الرّقاشي، <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: نبْقها أعظم من القِلال{21}. (١٤/١٩٢) ٧٤٩٦٣- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿سدر مخضود﴾</q>، قال: ليس فيه شوك{22}. (ز) ٧٤٩٦٤- عن السَّفْر بن نُسَير -من طريق عمر بن عمرو بن عبد الأحموسيّ- في قول الله ﷿: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، قال: خُضِد شوكه؛ فلا شوك فيه{13}. (ز) ٧٤٩٦٥- قال مقاتل بن سليمان: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q>، يعني: الذي لا شوك له كسِدر أهل الدنيا{24}. (ز) ٧٤٩٦٦- قال مقاتل بن حيان: <q>﴿فِي سِدْرٍ مَخْضُودٍ﴾</q> هو المُوقَر حملًا{25}٦٤٢٨. (ز) ٦٤٢٨ اختُلف في معنى «السدر المخضود» على قولين: الأول: هو الذي لا شوك فيه. الثاني: هو الموقَر حَمْلًا. ورجَّح ابنُ عطية (٨/١٩٧) القول الأول، وهو قول ابن عباس من طريق علي بن أبي طلحة وما في معناه، فقال: «وهو الصواب». ولم يذكر مستندًا. وذكر ابنُ القيم (٣/١٠٩) أنّ أصحاب القول الأول احتجوا بحجتين: «أحدهما: أنّ الخَضد في اللغة: القطع، وكلّ رطب قضبته فقد خَضدته، وخضدت الشجر إذا قطعت شوكه، فهو خضيد ومخضود، ومنه الخضد على مثال الثمر، وهو كلّ ما قطع من عود رطب خضد بمعنى: مخضود كقبض وسلب، والخضاد شجر رخو لا شوك له». والثانية: استشهادهم بحديث أبي أمامة، وعتبة بن عبد الله السلمي الواردين في تفسير الآيات، ثم ذكر بأنّ أصحاب القول الثاني أُنكِر عليهم قولهم بأنه «لا يُعرف في اللغة الخضد بمعنى: الحمل». ثم استدرك على إنكارهم بقوله: «ولم يُصب هؤلاء الذين أنكروا هذا القول، بل هو قول صحيح وأربابه ذهبوا إلى أنّ الله لما خضد شوكه وأذهبه، وجعل مكان كلّ شوكة ثمرة أُوقرت بالحمل، والحديثان المذكوران يجمعان القولين. وكذلك قول من قال المخضود: الذي لا يعقر اليد، ولا يرد اليد عنه شوك ولا أذًى فيه. فسّره بلازم المعنى، وهكذا غالب المفسرين يذكرون لازم المعنى المقصود تارة، وفردًا مِن أفراده تارة، ومثالًا من أمثلته، فيحكيها الجمّاعون للغثّ والسمين أقوالًا مختلفة، ولا اختلاف بينها». وعلَّق ابنُ كثير (١٣/٣٦٣) على القولين بقوله: «والظاهر أن المراد هذا وهذا، فإنّ سِدر الدنيا كثير الشوك قليل الثمر، وفي الآخرة على العكس من هذا لا شوك فيه، وفيه الثمر الكثير الذي قد أثقل أصله». <q>﴿وَطَلۡحࣲ مَّنضُودࣲ ۝٢٩﴾</q> - قراءات ٧٤٩٦٧- عن علي بن أبي طالب -من طريق سعد- أنه قرأ: (وطَلْعٍ مَّنضُودٍ){26}٦٤٢٩. (١٤/١٩٣) ٦٤٢٩ وجَّه ابنُ كثير (١٣/٣٦٤) قراءة علي بن أبي طالب ﵄ بقوله: «فعلى هذا يكون هذا من صفة السدر، فكأنه وصفه بأنه مخضود، وهو الذي لا شوك له، وأنّ طلعه منضود، وهو كثرة ثمره». ٧٤٩٦٨- عن قيس بن عباد، قال: قرأتُ على علي: <q>﴿وطَلْحٍ مَّنضُودٍ﴾</q>. فقال علي: ما بال الطّلح؟! أما تقرأ: (وطَلْعٍ)؟! ثم قال: <q>﴿لَها طَلْعٌ نَّضِيدٌ﴾</q> [ق:١٠]. فقيل له: يا أمير المؤمنين، أنحكّها من المصحف؟ فقال: لا يُهاج القرآن اليوم{27}. (١٤/١٩٣) <q>﴿وَطَلۡحࣲ مَّنضُودࣲ ۝٢٩﴾</q> - تفسير الآية ٧٤٩٦٩- عن علي بن أبي طالب -من طريق الحسن بن سعد- في قوله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: هو المَوْز{28}٦٤٣٠. (١٤/١٩٢) ٦٤٣٠ علَّق ابنُ القيم (٣/١١٠) على قول علي بن أبي طالب ﵄ وما في معناه بقوله: «والظاهر أنّ مَن فسّر الطّلح المنضود بالموز إنما أراد التمثيل به؛ لحُسن نضده، وإلا فالطّلح في اللغة: هو الشجر العظام من شجر البوادي». ٧٤٩٧٠- عن أبي هريرة، <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: هو المَوْز{29}. (١٤/١٩٣) ٧٤٩٧١- عن عبد الله بن عباس -من طريق أبي سعيد الرّقاشي- <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: المَوْز{30}. (١٤/١٩٣) ٧٤٩٧٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿منضود﴾</q>، قال: بعضه على بعض{31}. (١٤/١٩٤) ٧٤٩٧٣- عن أبي سعيد الخدري، <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: المَوْز{32}. (١٤/١٩٣) ٧٤٩٧٤- عن قسامة [بن زهير] -من طريق عوف- قال: الطلح المنضود: هو المَوْز{33}. (ز) ٧٤٩٧٥- عن مجاهد بن جبر، في قوله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>: يعني: المَوْز المتراكم{34}. (١٤/١٩٤) ٧٤٩٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: مَوزكم؛ لأنهم كانوا يُعجبون بوجّ؛ وظِلاله مِن طَلْحه وسِدره{35}. (ز) ٧٤٩٧٧- عن الحسن البصري: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: المَوْز {9}. (١٤/١٩٢) ٧٤٩٧٨- قال الحسن البصري: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q> ليس هو مَوزًا، ولكنه شجر له ظِل بارد طيّب{37}. (ز) ٧٤٩٧٩- عن عطاء بن أبي رباح -من طريق ابن أبي نجيح- في قوله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: المَوْز{33}. (ز) ٧٤٩٨٠- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: المَوْز{39}.(١٤/١٩٢) (١٤/١٩٢) ٧٤٩٨١- قال مقاتل بن سليمان: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، يعني: المتراكب بعضه فوق بعض. نظيرها: <q>﴿لَها طَلْعٌ نَضِيدٌ﴾</q> [ق:١٠] يعني: المنضود{24}. (ز) ٧٤٩٨٢- عن ابن وهب، قال: قال لي مالك [بن أنس]، في قول الله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: سمعتُ أنه المَوْز. قال مالك: وأنا أرى أن بعض العرب تُسمّيه: الطّلح{41}. (ز) ٧٤٩٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وطَلْحٍ مَنضُودٍ﴾</q>، قال: الله أعلم، إلا أنّ أهل اليمن يُسمّون المَوْز: الطّلح{31}. (ز) <q>﴿وَظِلࣲّ مَّمۡدُودࣲ ۝٣٠﴾</q> - تفسير ٧٤٩٨٤- عن أبي هريرة، عن النبيّ ﷺ، قال: «إنّ في الجنة شجرة يسير الراكب في ظِلّها مائة عام لا يقطعها، اقرءوا إن شئتم: <q>﴿وظِلٍّ مَمْدُودٍ﴾</q>»{43}. (١٤/١٩٤) ٧٤٩٨٥- عن أبي سعيد الخُدري، قال: قال رسول الله ﷺ: «في الجنة شجرة يسير الراكب في ظِلّها مائة عام لا يقطعها، وذاك الظّل الممدود»{44}. (١٤/١٩٥) ٧٤٩٨٦- عن أنس بن مالك، أنّ النبيَّ ﷺ، قال: «إنّ في الجنة لَشجرة يسير الراكب في ظِلها مائة عام لا يقطعها، وإن شئتم فاقرءوا: <q>﴿وظِلٍّ مَمْدُودٍ*وماءٍ مَسْكُوبٍ﴾</q>»{45}. (١٤/١٩٥) ٧٤٩٨٧- عن أبي هريرة -من طريق زياد مولى بني مخزوم- قال: إنّ في الجنة لَشجرةً يسيرُ الراكبُ في ظلِّها مائة عامٍ لا يقطعها، واقرءوا إن شئتُم: <q>﴿وظلٍ مَّمدود﴾</q>. فبلغ ذلك كعبًا، فقال: صدق، والذي أنزل التوراة على موسى والفرقان على محمدٍ، لو أنّ رجلًا ركب حقَّةً أو جذعةً ثم دار بأصل تلك الشجرة ما بلغها حتى يسقط هَرِمًا، إن الله ﷿ غرسها بيده، ونفخ فيها من روحه، وإنّ أفنانها مِن وراء سُور الجنة، وما في الجنة نهرٌ إلا يخرُجُ من أصل تلك الشجرة{46}. (٨/٤٥٠) ٧٤٩٨٨- عن عبد الله بن عباس -من طريق عكرمة- قال: الظِلّ الممدود: شجرة في الجنة على ساق، ظِلّها قدر ما يسير الراكب في كلّ نواحيها مائة عام، فيخرج إليها أهل الجنة؛ أهل الغُرف وغيرهم، فيتحدّثون في ظِلّها، فيشتهي بعضهم، ويذكر لهو الدنيا، فيُرسل الله ريحًا من الجنة، فتحرَّك تلك الشجرة بكلّ لهو في الدنيا{47}. (١٤/١٩٥) ٧٤٩٨٩- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿وظِلٍّ مَمْدُودٍ﴾</q>، يقول: ظِلّ الجنة لا ينقطع، ممدود عليهم أبدًا{11}. (١٤/٢٤٩) ٧٤٩٩٠- عن عمرو بن ميمون الأَودي -من طريق أبي إسحاق- <q>﴿وظِلٍّ مَمْدُودٍ﴾</q>، قال: مسيرة سبعين ألف سنة{49}. (١٤/١٩٦) ٧٤٩٩١- عن شعيب بن الحَبْحاب، قال: خرجتُ أنا وأبو العالية الرِّياحيّ، فلما كُنّا بالجبال، وذلك قبل طلوع الشمس، قال: نبّئتُ أنّ الجنة هكذا. ثم تلا: <q>﴿وظِلٍّ مَمْدُودٍ﴾</q>{50}. (ز) ٧٤٩٩٢- قال الربيع بن أنس: <q>﴿وظِلٍّ مَمْدُودٍ﴾</q>، يعني: ظِلّ العرش{51}. (ز) ٧٤٩٩٣- قال مقاتل بن سليمان: <q>﴿وظِلٍّ مَمْدُودٍ﴾</q> دائم لا يزول، لا شمس فيه كمثل ما يزول الظِّل في الدنيا{52}. (ز) <q>﴿وَظِلࣲّ مَّمۡدُودࣲ ۝٣٠﴾</q> - آثار متعلقة بالآية ٧٤٩٩٤- عن أبي هريرة، عن النبيِّ ﷺ، قال: «إنّ حائط الجنة لَبِنة من ذهب، ولَبِنة من فِضّة، وقاع الجنة ذهب، ورَضْراضُها{53} اللؤلؤ، وطينها مسك، وتُرابها الزّعفران، وخلال ذلك سِدر مخضود، وطلح منضود، وظِلٍّ ممدود، وماء مسكوب»{11}. (١٤/١٩٤) ٧٤٩٩٥- عن أبي هريرة، يقول: قال رسول الله ﷺ: «إنّ في الجنة لَشجرة يسير الراكب في ظِلّها مائة عام لا يقطعها؛ شجرة الخُلد»{55}. (ز) ٧٤٩٩٦- عن عبد الله بن عباس، قال: في الجنة شجر لا يَحمل يُستظلّ به{56}. (١٤/١٩٦) ٧٤٩٩٧- عن أنس بن مالك -من طريق قتادة- قال: إنّ في الجنة لَشجرة يسير الراكب في ظِلّها مائة عام لا يقطعها{57}. (ز) ",footnotes:1:تفسير الثعلبي ٩/٢٠٦، وتفسير البغوي ٨/١١. وعلقه الواحدي في أسباب النزول (ت: الفحل) ص٦٣٧.أخرجه ابن جرير ٢٢/٣١١-٣١٣، والبيهقي (٣٠٤). وعزاه السيوطي إلى عبد بن حميد.أخرجه البيهقي في البعث (٣٠٣). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه الحاكم ٢/٥١٨ (٣٧٧٨)، من طريق صفوان بن عمرو، عن سليم بن عامر، عن أبي أمامة. قال الحاكم: «صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي. وأخرجه ابن أبي الدنيا في صفة الجنة ٦/٣٤٣ (١٠٨) من مرسل سليم بن عامر.المَلْبُود: المُكْتَنِز اللحم، الذي لزم بعضه بعضًا فتلبّد. النهاية (لبد).أخرجه الطبراني في الكبير ١٧/١٣٠ (٣١٨)، وأبو نعيم الأصبهاني في صفة الجنة ٢/١٨٨-١٨٩ (٣٤٧). قال الهيثمي في المجمع ١٠/٤١٤ (١٨٧٣٠): «رواه الطبراني، ورجاله رجال الصحيح». وأورده الألباني في الصحيحة ٦/٥٢٥ (٢٧٣٤).أخرجه ابن جرير ٢٢/٣٠٧. ونخلة مُوقَرة: إذا كثر حملها، والحمل: ثمر الشجرة. اللسان (وقر، حمل).أخرجه ابن جرير ٢٢/٣٠٧-٣١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه الطستي -كما في الإتقان ٢/٨٨-.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٠٨.أخرجه ابن جرير ٢٢/٣٠٧.أخرجه ابن جرير ٢٢/٣٠٩.تفسير مجاهد ص٦٤١، وأخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٣-، وهناد (١٠٨)، وابن جرير ٢٢/٣٠٨، والبيهقي في البعث (٣٠٤). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٠٩.أخرجه هناد في الزهد ١/٩٣.أخرجه ابن جرير ٢٢/٣٠٧-٣٠٨.تفسير الثعلبي ٩/٢٠٦، وتفسير البغوي ٨/١١.أخرجه عبد الرزاق ٢/٢٧٠، وابن جرير ٢٢/٣٠٨، بنحوه من طريق سعيد، وأبي هلال.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٠.أخرجه ابن جرير ٢٢/٣٠٧.تفسير مقاتل بن سليمان ٤/٢١٨.تفسير الثعلبي ٩/٢٠٦.أخرجه ابن جرير ٢٢/٣٠٩، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤-. وعزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة، وقراءة العشرة: <q>﴿وطَلْحٍ مَّنضُودٍ﴾</q>. انظر: مختصر ابن خالويه ص١٥١.أخرجه ابن جرير ٢٢/٣٠٩-٣١٠، وابن الأنباري في المصاحف -كما في تفسير القرطبي ١٧/٢٠٨-٢٠٩-. وقال ابن الأنباري: «ومعنى هذا أنه رجع إلى ما في المصحف وعلم أنه الصواب، وأبطل الذي كان فرط من قوله». تفسير القرطبي ١٧/٢٠٩.أخرجه عبد الرزاق ٢/٢٧٠، وهناد (١١٢)، وابن جرير ٢٢/٣١١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه هناد (١١١)، والحربي في غريب الحديث ٢/٦٣١، وابن جرير ٢٢/٣١٠-٣١١، ومن طريق أبي بشر أيضًا. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣١٢.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٣١١.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٣-، وهناد (١٠٨)، وابن جرير ٢٢/٣١٣، والبيهقي في البعث (٣٠٤). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٢، وأخرجه ابن جرير ٢٢/٣١١-٣١٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٩-.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢٠٦، وتفسير البغوي ٨/١٢.أخرجه ابن جرير ٢٢/٣١١.أخرجه عبد الرزاق ٢/٢٧٠، وابن جرير ٢٢/٣١٢، وبمثله من طريق سعيد، وأبي هلال. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢١٨.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٣٣ (٢٦٢).أخرجه ابن جرير ٢٢/٣١٢.أخرجه البخاري ٤/١١٩ (٣٢٥٢)، ٦/١٤٦ (٤٨٨١) واللفظ له، ومسلم ٤/٢١٧٥ (٢٨٢٦)، وابن جرير ٢٢/٣١٣.أخرجه الترمذي ٤/٤٩٥ (٢٦٩٣). قال الترمذي: «هذا حديث حسن غريب من حديث أبي سعيد».أخرجه البخاري ٤/١١٩ (٣٢٥١)، والترمذي ٥/٤٨٦-٤٨٧ (٣٥٧٧)، واللفظ له. قال الترمذي: «هذا حديث حسن صحيح».أخرجه ابن جرير ٢٢/٣١٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٦-. وعزاه السيوطي إلى ابن مردويه. قال ابن كثير: «هذا أثر غريب، وإسناده جيد قوي حسن».عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣١٤، وابن أبي الدنيا في صفة الجنة ٦/٣٣٣ (٦٤). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٢-.تفسير الثعلبي ٩/٢٠٧.تفسير مقاتل بن سليمان ٤/٢١٩.الرَّضْراض: الحصى الصغار. النهاية (رَضْرَضَ).عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ١٦/٣٤ (٩٩٥٠)، والدارمي في سننه ٢/٤٣٦ (٢٨٣٩)، وابن جرير ٧/١٦٨، ٢٢/٣١٤-٣١٥. في إسناده أبو الضَّحّاك الراوي عن أبي هريرة، قال أبو حاتم كما في الجرح والتعديل ٩/٣٩٥ (١٨٧٧): «أبو الضَّحّاك هذا لا أعلم روى عنه غير شعبة». قال أحمد شاكر في عمدة التفسير ١/٥٢٦: «أصل الحديث ثابت من أوجه كثيرة دون زيادة شجرة الخلد».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٧-.أخرجه ابن جرير ٢٢/٣١٧.
