55,57," <q>﴿كَأَنَّهُنَّ ٱلۡیَاقُوتُ وَٱلۡمَرۡجَانُ ۝٥٨﴾</q> - تفسير ٧٤٥٠٥- عن عبد الله بن مسعود، عن النبيِّ ﷺ، قال: «إنّ المرأة من نساء أهل الجنة لَيُرى بياضُ ساقها مِن وراء سبعين حُلّة حتى يُرى مُخّها، وذلك أنّ الله يقول: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q>، فأما الياقوت فإنّه حَجرٌ، لو أدخَلتَ فيه سلكًا ثم استَصفيتَه لرأيتَه من ورائه»{1}. (١٤/١٤٧) ٧٤٥٠٦- عن أبي سعيد الخُدري، عن النبيِّ ﷺ، في قوله: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q>، قال: «يَنظر إلى وجهها في خدّها أصفى مِن المرآة، وإنّ أدنى لؤلؤة عليها لَتُضيء ما بين المشرق والمغرب، وإنّه يكون عليها سبعون ثوبًا يَنفُذها بصره، حتى يَرى مُخّ ساقها من وراء ذلك»{2}. (١٤/١٤٦) ٧٤٥٠٧- عن عمرو بن ميمون، قال: أخبرنا عبد الله [بن مسعود]: أن المرأة من أهل الجنة لَتلبس سبعين حُلَّةً مِن حرير، فيرى بياض ساقها وحسنه ومخ ساقها مِن وراء ذلك، وذلك لأنّ الله قال: <q>﴿كأنهن الياقوت والمرجان﴾</q>، ألا ترى أنّ الياقوت حجرٌ، فإذا أدخلتَ فيه سلكًا رأيت السلك من وراء الحجر!{3}. (١٤/١٤٨) ٧٤٥٠٨- عن عبد الله بن الحارث الهاشميّ -من طريق الحر- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> كأنهن اللؤلؤ في الخيط{4}. (١٤/١٤٦) ٧٤٥٠٩- عن مجاهد بن جبر -من طريق سليمان أبي عبيد الله- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> يُرى مخّ سُوقهنّ مِن وراء الثياب؛ كما يُرى الخيط في الياقوتة{5}. (١٤/١٤٧) ٧٤٥١٠- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> ألوانهن كالياقوت واللؤلؤ في صفائه{6}. (١٤/١٤٨) ٧٤٥١١- عن الحسن البصري -من طريق أبي رجاء- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> صفاء الياقوت في بياض المرجان{7}. (١٤/١٤٧) ٧٤٥١٢- عن أبي صالح [باذام] أو السُّدِّيّ -من طريق ابن أبي خالد- في قوله: <q>﴿كأنهن الياقوت والمرجان﴾</q>، قال: بياض اللؤلؤ، وصفاء الياقوت{8}. (ز) ٧٤٥١٣- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> في صفاء الياقوت، وبياض اللؤلؤ{9}. (١٤/١٤٧) ٧٤٥١٤- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> صفاء الياقوت في بياض المرجان. ذُكر لنا: أنّ نبي الله ﷺ قال: «مَن دخل الجنة فله فيها زوجتان؛ يُرى مخُّ سُوقهما مِن وراء ثيابهما»{10}. (ز) ٧٤٥١٥- عن إسماعيل السُّدِّيّ -من طريق المطلب- <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q>، قال: صفاء الياقوت، وحُسن المرجان{11}. (ز) ٧٤٥١٦- قال مقاتل بن سليمان: <q>﴿كَأَنَّهُنَّ﴾</q> في الشّبه في صفاء <q>﴿الياقُوتُ﴾</q> الأحمر، <q>﴿و﴾</q> في بياض <q>﴿المَرْجانُ﴾</q> يعني: الدُّرّ العظام{12}. (ز) ٧٤٥١٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> كأنهن الياقوت في الصفاء، والمرجان في البياض؛ الصفاء صفاء الياقوتة، والبياض بياض اللؤلؤ{11}٦٤٠٣. (ز) ٦٤٠٣ ذكر ابنُ كثير (١٣/٣٣٤) قول ابن زيد، ومثله عن بعض السلف، ووجّهه، فقال: «قوله: <q>﴿كأنهن الياقوت والمرجان﴾</q>، قال مجاهد، والحسن، والسُّدِّيّ، وابن زيد، وغيرهم: في صفاء الياقوت، وبياض المرجان، فجعلوا المرجان هاهنا اللؤلؤ». ٧٤٥١٨- عن إسحاق بن عبد الله، قال: بلَغني: أنه يقول -يعني: الولي- في الجنة: أشتهي العين. فيُقال له: أفإنهنّ حور عين. فيقول: أشتهي البياض. فيقال: إنهنّ كأنهنّ بيضٌ مكنون. فيقول: أخشى أن يكون في وجهها كَلف. فيقال له: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q>. فيقول: أخشى أن تكون خفيفة. فيقال له: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>. فيقول: إني غيور. فيقال: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>. قال: قال ابن عباس: تسنيم، وماء التسنيم يشربها المُقرّبون صرفًا، وتُمزج لأصحاب اليمين{14}. (ز) <q>﴿كَأَنَّهُنَّ ٱلۡیَاقُوتُ وَٱلۡمَرۡجَانُ ۝٥٨﴾</q> - آثار متعلقة بالآية ٧٤٥١٩- عن أبي هريرة، أنّ رسول الله ﷺ قال: «أول زُمرة تدخل الجنة على صورة القمر ليلة البدر، والذين على إثرهم كأشد كوكب إضاءة، قلوبهم على قلب رجل واحد، لا اختلاف بينهم ولا تباغض، لكل امرئ منهم زوجتان، كل واحدة منهما يرى مخ ساقها مِن وراء لحمها مِن الحُسْن، يُسبِّحون اللهَ بُكرةً وعشيًّا، لا يسقمون، ولا يمتخطون، ولا يبصقون، آنيتهم الذهب والفضة، وأمشاطهم الذهب، ووقود مجامرهم الأَلَوَّة -قال أبو اليمان: يعني: العود-، ورشْحُهم المِسْك»{15}. (ز) ٧٤٥٢٠- عن عبد الله بن مسعود -من طريق عمرو بن ميمون- قال: إنّ المرأة مِن الحُور العين لَيُرى مُخُّ ساقها مِن وراء اللحم والعظم، مِن تحت سبعين حُلَّة، كما يُرى الشراب الأحمر في الزجاجة البيضاء{16}. (١٤/١٤٩) ٧٤٥٢١- عن عمرو بن ميمون الأَوْدي -من طريق أبي إسحاق-، مثله{17}. (١٤/١٤٩) ٧٤٥٢٢- عن عبد الله بن الحارث القَيسيّ، قال: إنّه يكون على زوجة الرجل مِن أهل الجنة سبعون حُلّة حمراء، يُرى مُخُّ ساقها مِن خلفهنّ{18}. (١٤/١٤٨) ٧٤٥٢٣- عن أنس بن مالك، قال: إنّ المرأة مِن أزواج المُقرّبين لَتُكسى مائة حُلّة مِن إسْتَبرق وسِقالَة النور، وإنّ مُخّ ساقها لَيُرى مِن وراء ذلك كلّه، وإنّ المرأة مِن أزواج أصحاب اليمين لَتُكسى سبعين حُلّة مِن إسْتَبرق وسِقالة النور، وإنّ مُخّ ذلك لَيُرى مِن وراء ذلك كلّه{18}. (١٤/١٤٨) ٧٤٥٢٤- عن كعب الأحبار، قال: إنّ المرأة مِن الحور العين لَتلبس سبعين حُلّة، لَهي أرقُّ مِن شَفِّكُم{20} هذا الذي تُسمّونه شَفًّا، وإنّ مُخ ساقها ليُرى من وراء اللحم{18}. (١٤/١٤٨) ",footnotes:1:أخرجه الترمذي ٤/٥٠٢ (٢٧٠٥، ٢٧٠٦)، وابن حبان ١٦/٤٠٨ (٧٣٩٦)، وابن جرير ٢٢/٢٤٩، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٠٤-، من طريق عبيدة بن حميد، عن عطاء بن السّائِب، عن عمرو بن ميمون، عن عبد الله بن مسعود به. قال الترمذي: «حدثنا أبو الأحوص، عن عطاء بن السّائِب، عن عمرو بن ميمون، عن عبد الله بن مسعود، نحوه بمعناه ولم يرفعه، وهذا أصح من حديث عبيدة بن حميد، وهكذا روى جرير وغير واحد عن عطاء بن السّائِب ولم يرفعوه».أخرجه أحمد ١٨/٢٤٣-٢٤٤ (١١٧١٥)، وابن حبان ١٦/٤٠٩-٤١٠ (٧٣٩٧)، والحاكم ٢/٥١٦ (٣٧٧٤) واللفظ له، وابن جرير ٢١/٤٥٩، من طريق درّاج، عن أبي الهيثم، عن أبي سعيد الخدري به. قال الحاكم: «صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «درّاج صاحب عجائب». وقال العراقي في تخريج أحاديث الإحياء ص١٩٣٠: «إسناد حسن، ورواه أحمد، وفيه ابن لهيعة». وقال الهيثمي في المجمع ١٠/٤١٩ (١٨٧٦٢): «رواه أحمد، وأبو يعلى، وإسنادهما حسن».أخرجه الترمذي ٤/٥٠٢ (٢٧٠٥)، وابن أبي شيبة ١٣/١٠٧، وهناد (١٠)، وابن جرير ٢٢/٢٥٠ واللفظ له. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ١٣/١٣٠.أخرجه ابن أبي شيبة ١٣/١٣٠-١٣١.أخرجه ابن أبي شيبة ١٣/١٣٠، وهناد (١٨). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٥٠ دون جملة: صفاء الياقوت. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.أخرجه ابن المبارك في الزهد ١/٤٨٧.أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٥١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٥١، وبنحوه من طريق أبي العوام.أخرجه ابن جرير ٢٢/٢٥١.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥١.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٩٢-٣٩٣ (٣٤٧)-.أخرجه البخاري ٤/١١٨ (٣٢٤٥، ٣٢٤٦)، ٤/١١٩ (٣٢٥٤)، ٤/١٣٢ (٣٣٢٧)، ومسلم ٤/٢١٧٩-٢١٨٠ (٢٨٣٤)، وعبد الرزاق ٢/٣٣٣ (١٦٨٢).أخرجه الطبراني (٨٨٦٤)، والبيهقي في البعث (٣٢٩). وعزاه السيوطي إلى عبد بن حميد.أخرجه هناد في الزهد (١٢)، وابن جرير ٢٢/٢٥٠.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.الشَّفُّ والشِّفُّ: الثوب الرقيق. لسان العرب (شفف).عزاه السيوطي إلى عبد بن حميد.
  55,58,""
55,59," <q>﴿هَلۡ جَزَاۤءُ ٱلۡإِحۡسَـٰنِ إِلَّا ٱلۡإِحۡسَـٰنُ ۝٦٠﴾</q> - تفسير ٧٤٥٢٥- عن علي بن أبي طالب، في قوله: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال: قال رسول الله ﷺ: «قال الله ﷿: هل جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة»{1}. (١٤/١٥٠) ٧٤٥٢٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «أنزل اللهُ عَلَيَّ هذه الآية مُسجَلة{2} في سورة الرحمن للكافر والمسلم: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>»{3}. (١٤/١٥١) ٧٤٥٢٧- عن عبد الله بن عباس، في قوله: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال رسول الله ﷺ: «هل جزاء مَن قال: لا إله إلا الله في الدنيا إلا الجنة في الآخرة؟!»{4}. (١٤/١٥٠) ٧٤٥٢٨- عن عبد الله بن عمر، قال: قال رسول الله ﷺ في قوله: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q> قال: «ما جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة»{5}. (١٤/١٤٩) ٧٤٥٢٩- عن جابر بن عبد الله، قال: قال رسول الله ﷺ في هذه الآية: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q> قال: «هل جزاء مَن أنعمنا عليه بالإسلام إلا أن أُدخله الجنة؟!»{6}. (١٤/١٥٠) ٧٤٥٣٠- عن أنس بن مالك، قال: قال رسول الله ﷺ: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، وقال: «هل تدرون ما قال ربكم؟». قالوا: الله ورسوله أعلم. قال: «يقول: هل جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة»{7}. (١٤/١٥٠) ٧٤٥٣١- عن عبد الله بن عباس، قال: نَزَلَتْ هذه الآيةُ في المسلم والكافر: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>{6}. (١٤/١٥١) ٧٤٥٣٢- عن عبد الله بن عباس -من طريق عطاء- <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال: إنّ لله عمودًا أحمر، رأسه مَلويٌّ على قائمة مِن قوائم العرش، وأسفله تحت الأرض السابعة على ظَهْر الحُوت، فإذا قال العبد: لا إله إلا الله. تحرّك الحوت؛ تحرّك العمود؛ تحرّك العرش؛ فيقول الله للعرش: اسكُن. فيقول: لا، وعزّتك، لا أسكُن حتى تغفر لقائلها ما أصاب قبلها من ذنبٍ. فيَغفر الله له{9}. (١٤/١٥٢) ٧٤٥٣٣- عن محمد بن الحنَفيّة -من طريق أبي يعلى- <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال: هي مُسجَلة للبَرِّ والفاجر{10}. (١٤/١٥١) ٧٤٥٣٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول الله ﷿: <q>﴿هل جزاء الإحسان إلا الإحسان﴾</q>، قال: هل جزاء لا إله إلا الله إلاّ الجنة؟!{11}. (ز) ٧٤٥٣٥- عن عكرمة مولى ابن عباس، <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال: هل جزاء مَن قال: لا إله إلا الله؛ إلا الجنة؟!{12}. (١٤/١٥١) ٧٤٥٣٦- عن الحسن البصري، مثله{12}. (١٤/١٥١) ٧٤٥٣٧- قال الحسن البصري: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q> هي مُسجَلة للبَرِّ والفاجر؛ للفاجر في دنياه، وللبَرّ في آخرته{14}. (ز) ٧٤٥٣٨- عن قتادة بن دعامة -من طريق أبي العوام- <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال: عمِلوا خيرًا فجُوزوا خيرًا{15}. (١٤/١٥٢) ٧٤٥٣٩- عن محمد بن المُنكَدِر -من طريق محمد بن جابر اليمامي- <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، قال: هل جزاء مَن أنعمتُ عليه بالإسلام إلّا الجنّة{16}. (ز) ٧٤٥٤٠- قال مقاتل بن سليمان: <q>﴿هَلْ جَزاءُ الإحْسانِ﴾</q> في الدنيا <q>﴿إلّا الإحْسانُ﴾</q> في الآخرة، يعني: هل جزاء أهل التوحيد في الآخرة إلا الجنة؟!{17}. (ز) ٧٤٥٤١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q> ألا تراه ذَكرهم ومنازلهم وأزواجهم، والأنهار التي أعدّها لهم، وقال: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q> حين أحسَنوا في هذه الدنيا أحسَنّا إليهم؛ أدخلناهم الجنة{18}٦٤٠٤. (ز) ٦٤٠٤ قال ابنُ جرير (٢٢/٢٥٢): «وقوله: <q>﴿هل جزاء الإحسان إلا الإحسان﴾</q> يقول -تعالى ذِكْرُه-: هل ثواب خَوف مقام الله ﷿ لِمَن خافه فأحسن في الدنيا عمله، وأطاع ربّه، إلا أن يُحسن إليه في الآخرة ربُّه، بأن يجازيه على إحسانه ذلك في الدنيا ما وصف في هذه الآيات من قوله: <q>﴿ولمن خاف مقام ربه جنتان﴾</q> إلى قوله: <q>﴿كأنهن الياقوت والمرجان﴾</q>، وبنحو الذي قلنا في ذلك قال أهل التأويل، وإن اختلفت ألفاظهم بالعبارة عنه». وذكر على ذلك آثار السلف. ",footnotes:1:عزاه السيوطي إلى ابن النجار في تاريخه.أي: مرسلة مطلقة في الإحسان إلى كل أحد؛ بَرًّا كان أو فاجرًا. النهاية (سجل).أخرجه ابن عدي في الكامل في الضعفاء ٨/٤٠١ بلفظ: مجملة للكافر والمسلم، والبيهقي في شعب الإيمان ١١/٣٩٤-٣٩٥ (٨٧٢٦)، من طريق الهيثم بن عدي، عن عبد الله بن عياش، عن جعفر بن إياس، عن سعيد بن جُبَير، عن ابن عباس به. قال البيهقي: «الهيثم بن عدي الكوفي متروك الحديث».عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه البيهقي في شعب الإيمان ٢/٢٢ (٤٢٥)، من طريق إبراهيم بن محمد بن إسماعيل الكوفي، عن حبيب بن أبي العالية، عن مجاهد، عن ابن عمر به. قال البيهقي: «تفرَّد به إبراهيمُ بن محمد الكوفي، وهو منكر».عزاه السيوطي إلى ابن مردويه.أخرجه أبو نعيم في أخبار أصبهان ١/٢٨٠، والواحدي في التفسير الوسيط ٤/٢٢٧ (١١٥٦)، والثعلبي ٩/١٩٢، من طريق بشر بن الحسين، عن الزبير بن عدي، عن أنس بن مالك به. وسنده ضعيف؛ فيه بشر بن الحسين الأصبهاني، وهو متروك. كما في ميزان الاعتدال ١/٣١٥.عزاه السيوطي إلى ابن مردويه.أخرجه الخطيب في تاريخه ٥/٣٨.أخرجه ابن جرير ٢٢/٢٥٣، والبخاري في الأدب (١٣٠)، والبيهقي في شعب الإيمان (٩١٥٢). وقال: مُسجلة يعني: مُرسلة. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الطبراني في الدعاء ٣/١٥٠٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٩٢.أخرجه ابن جرير ٢٢/٢٥٢.أخرجه الثعلبي ٩/١٩٢.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥٢-٢٥٣.
  55,60,""
55,61," <q>﴿وَمِن دُونِهِمَا جَنَّتَانِ ۝٦٢﴾</q> - تفسير ٧٤٥٤٢- عن عبد الله بن عباس -من طريق سعيد- قال: كان عرش الله على الماء، ثم اتخذ لنفسه جنة، ثم اتخذ دونها جنة أخرى، ثم أطبقهما بلؤلؤة واحدة، قال: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q> وهي التي لا تُعلَم -أو قال- وهما التي <q>﴿لا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ جَزاءً بِما كانُوا يَعْمَلُونَ﴾</q> [السجدة:١٧]، وهي التي لا تَعلَم الخلائق ما فيهما، أو ما فيها، يأتيهم كلَّ يوم منها أو منهما تُحفةٌ{1}. (ز) ٧٤٥٤٣- قال عبد الله بن عباس: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q> من دونهما في الدَّرَج{2}. (ز) ٧٤٥٤٤- قال الضَّحّاك بن مُزاحِم: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q> الجنتان الأُوليان من ذهب وفِضّة، والأُخريان من ياقوت{3}. (ز) ٧٤٥٤٥- عن الحسن البصري: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q> قال: هما دون <q>﴿تَجْرِيانِ﴾</q>{4}. (١٤/١٥٢) ٧٤٥٤٦- قال مقاتل بن سليمان: <q>﴿ومِن دُونِهِما﴾</q> يعني: ومن دون جَنتي المُقرّبين والصِّدّيقين والشهداء في الفضل <q>﴿جَنَّتانِ﴾</q> وهما جنة الفردوس، وجنة المأوى{5}. (ز) ٧٤٥٤٧- قال عبد الملك ابن جُرَيْج: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q> هن أربع: جنتان للمُقرّبين السابقين، فيهما مِن كلّ من فاكهة زوجان، وجنتان لأصحاب اليمين، فيهما فاكهة ونخل ورمان{2}. (ز) ٧٤٥٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q>، قال: هما أدنى مِن هاتين لأصحاب اليمين{7}٦٤٠٥. (ز) ٦٤٠٥ اختُلف في معنى قوله تعالى: <q>﴿ومن دونهما جنتان﴾</q> على قولين: الأول: من دونهما في الفَضل. الثاني: من دونهما في الدَّرَج. وذكر ابنُ عطية (٨/١٨١ بتصرف) أنّ «أكثر الناس على التأويل الأول، وهذه استدلالات ليست بقواطع، وأنه رُوي عن أبي موسى الأشعري ﵄ أنه قال: جنتان للمُقرّبين مِن ذهب، وجنتان لأهل اليمين مِن فِضة مما دون الأولَيَيْن». ورجّح ابنُ القيم (٣/١٠١-١٠٣ بتصرف) -مستندًا إلى الدلالة العقلية، وظاهر اللفظ والسياق- القول الثاني من وجوه، أهمها ما يلي: الأول: قوله: <q>﴿ذَواتا أفْنانٍ﴾</q> وفيه قولان: أحدهما: أنه جمع فَنن، وهو الغُصن. والثاني: أنه جمع فَن، وهو الصنف، أي: ذواتا أصناف شتّى مِن الفواكه وغيرها، ولم يذكر ذلك في اللتين بعدهما. الثاني: قوله: <q>﴿فِيهِما عَيْنانِ تَجْرِيانِ﴾</q>، وفي الأخريين: <q>﴿فيهما عينان نضاختان﴾</q>، والنَّضّاخة هي الفوّارة، والجارية: السارحة، وهي أحسن مِن الفوارة؛ فإنها تضمن الفوران والجريان. الثالث: أنه قال: <q>﴿فيهما من كل فاكهة زوجان﴾</q>، وفي الأخريين: <q>﴿فيهما فاكهة ونخل ورمان﴾</q>، ولا ريب أنّ وصف الأُوليين أكمل. الرابع: أنه قال: <q>﴿متكئين على فرش بطائنها من استبرق﴾</q>، وهذا تنبيه على فضل الظهائر وخطرها، وفي الأخريين قال: <q>﴿متكئين على رفرف خضر وعبقري حسان﴾</q>، وفسّر الرّفرف بالمحابس والبُسط، وفسّر بالفُرش، وفسّر بالمحابس فوقها، وعلى كلّ قول فلم يصفه بما وصف به فُرش الجنتين الأوليين. الخامس: أنه قال: <q>﴿وجنى الجنتين دان﴾</q> أي: قريب وسهل، يتناولونه كيف شاءوا، ولم يذكر ذلك في الأخريين. السادس: أنه قال: <q>﴿فيهن قاصرات الطرف﴾</q> أي: قد قَصَرن طَرفهنَ على أزواجهنّ، فلا يرون غيرهم؛ لرضاهنّ بهم، ومحبتهنّ لهم، وذلك يتضمّن قَصرهنّ أطراف أزواجهنّ عليهنّ، فلا يدعهم حُسنهنّ أن ينظروا إلى غيرهنّ، وقال في الأخريين: <q>﴿حور مقصورات في الخيام﴾</q>، ومَن قَصرت طرفها على زوجها باختيارها أكمل ممن قَصرت بغيرها. السابع: أنه وصفهنّ بشبَه الياقوت والمرجان في صفاء اللون وإشراقه وحُسنه، ولم يذكر ذلك في التي بعدها. الثامن: أنه قال ﷾ في الجنتين الأوليين: <q>﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</q>، وهذا يقتضي أنّ أصحابهما مِن أهل الإحسان المطلق الكامل، فكان جزاؤهم بإحسان كامل. التاسع: أنه بدأ بوصف الجنتين الأوليين، وجعلهما جزءًا لِمَن خاف مقامه، وهذا يدل على أنهما أعلى جزاء الخائف لمقامه، فرتّب الجزاء المذكور على الخوف ترتيب المسبب على سببه، ولما كان الخائفون على نوعين مُقرّبين وأصحاب يمين ذكر جنتي المُقرّبين، ثم ذكر جنتي أصحاب اليمين. وبنحوه قال ابنُ كثير (١٣/٣٣٨-٣٣٩). <q>﴿وَمِن دُونِهِمَا جَنَّتَانِ ۝٦٢﴾</q> - آثار متعلقة بالآية ٧٤٥٤٩- عن أبي موسى الأشعري، عن النبي ﷺ، قال: «جنتان من فِضّة آنِيتهما وما فيهما، وجنتان من ذهب آنِيتهما وما فيهما، وما بين القوم وبين أن يَنظُروا إلى ربهم إلا رِداء الكبرياء على وجهه في جنة عَدن»{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٣٣٣، ٢٢/٢٥٣، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٦١ (٢٠٣)-.تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٦.تفسير البغوي ٧/٤٥٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٢٠٤.تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٦.أخرجه ابن جرير ٢٢/٢٥٤.أخرجه البخاري ٦/١٤٥ (٤٨٧٨) باب قوله: <q>﴿ومن دونهما جنتان﴾</q>، ٩/١٣٢ (٧٤٤٤)، ومسلم ١/١٦٣ (١٨٠)، والثعلبي ٦/٢٠١-٢٠٢.
  55,62,""
55,63," <q>﴿مُدۡهَاۤمَّتَانِ ۝٦٤﴾</q> - تفسير ٧٤٥٥٠- عن أبي أيوب الأنصاري، قال: سألت النبيَّ ﷺ عن قوله: <q>﴿مُدْهامَّتانِ﴾</q>، قال: «خضراوان»{1}. (١٤/١٥٣) ٧٤٥٥١- عن أبي أيوب الأنصاري، قال: <q>﴿مُدْهامَّتانِ﴾</q> هما جنتان خضراوان{2}. (١٤/١٥٣) ٧٤٥٥٢- عن عبد الله بن عباس -من طريق علي- <q>﴿مُدْهامَّتانِ﴾</q>، قال: خضروان{3}. (١٤/١٥٢) ٧٤٥٥٣- عن عبد الله بن عباس -من طريق عطية- قال: <q>﴿مُدْهامَّتانِ﴾</q> قد اسودتا من الخضرة؛ من الرّيّ من الماء{4}. (١٤/١٥٢) ٧٤٥٥٤- عن عبد الله بن الزبير -من طريق جارية- قال: <q>﴿مُدْهامَّتانِ﴾</q> خضراوان من الريّ{5}. (١٤/١٥٣) ٧٤٥٥٥- عن يحيى بن سلمة، عن أبيه، قال: سمعتُ عبد الله بن أبي أوْفى في قوله: <q>﴿مدهامتان﴾</q> قال: خَضْراوان{6}. (ز) ٧٤٥٥٦- عن سعيد بن جُبَير -من طريق عطاء- قال: <q>﴿مُدْهامَّتانِ﴾</q> خَضْراوان{7}. (١٤/١٥٣) ٧٤٥٥٧- عن سعيد بن جُبَير -من طريق سالم- قال: <q>﴿مُدْهامَّتانِ﴾</q> علاهما الرِّيّ من السواد والخُضرة{8}. (ز) ٧٤٥٥٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿مُدْهامَّتانِ﴾</q> مُسْودّتان{9}. (١٤/١٥٤) ٧٤٥٥٩- عن مجاهد بن جبر -من طريق سلمة- قال: <q>﴿مُدْهامَّتانِ﴾</q> خَضْراوان{10}. (١٤/١٥٣) ٧٤٥٦٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح-= (ز) ٧٤٥٦١- وعكرمة مولى ابن عباس، قالا: <q>﴿مُدْهامَّتانِ﴾</q> سَوداوان من الرِّيّ{11}. (١٤/١٥٤) ٧٤٥٦٢- عن عكرمة مولى ابن عباس، قال: <q>﴿مُدْهامَّتانِ﴾</q> خَضْراوان{12}. (١٤/١٥٣) ٧٤٥٦٣- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- قال: <q>﴿مُدْهامَّتانِ﴾</q> سَوداوان من الرِّيّ{13}. (١٤/١٥٤) ٧٤٥٦٤- عن الحسن البصري -من طريق أبي رجاء- قال: <q>﴿مُدْهامَّتانِ﴾</q> ناعمتان{14}. (ز) ٧٤٥٦٥- عن عطية بن سعد العَوفيّ -من طريق إدريس، عن أبيه- قال: <q>﴿مُدْهامَّتانِ﴾</q> خَضْراوان من الرِّيّ{8}. (ز) ٧٤٥٦٦- عن عطاء بن أبي رباح، قال: <q>﴿مُدْهامَّتانِ﴾</q> هما جنتان خَضْراوان{16}. (١٤/١٥٣) ٧٤٥٦٧- عن أبي صالح [باذام] -من طريق إسماعيل بن أبي خالد- قال: <q>﴿مُدْهامَّتانِ﴾</q> خَضْراوان من الرِّيّ، ناعمتان، إذا اشتدّت الخُضْرة ضربت إلى السواد{17}. (١٤/١٥٤) ٧٤٥٦٨- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿مُدْهامَّتانِ﴾</q> خَضْراوان من الرِّيّ، ناعمتان، إذا اشتدّت الخُضْرة ضربت إلى سواد{18}. (ز) ٧٤٥٦٩- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿مدهامتان﴾</q>، قال: كثرة الشجر وخُضرته{19}. (ز) ٧٤٥٧٠- عن أبي سنان [سعيد بن سنان البرجمي] -من طريق مهران- قال: <q>﴿مُدْهامَّتانِ﴾</q> مُسْودَّتان من الرِّيّ{14}. (ز) ٧٤٥٧١- قال مقاتل بن سليمان: ثم نَعَتهما، فقال: <q>﴿مُدْهامَّتانِ﴾</q> سَوداوان مِن الرِّيّ والخُضْرة{21}. (ز) ٧٤٥٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>: جنتا السابقين، فقرأ: <q>﴿ذَواتا أفْنانٍ﴾</q>، فقرأ حتى بلغ: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q>، ثم رجع إلى أصحاب اليمين، فقال: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q>، فذكر فضلهما وما فيهما، قال: <q>﴿مُدْهامَّتانِ﴾</q> من الخُضْرة؛ من شدة خُضْرتهما، حتى كادتا تكونان سَوداوين{22}. (ز) ",footnotes:1:أخرجه ابن عدي في الكامل في الضعفاء ٨/٣٧٢ (٢٠٠٩)، والطبراني في الكبير ٤/١٨٠ (٤٠٧٤)، من طريق سعيد بن مسلمة، عن واصل بن السّائِب، عن أبي سورة، عن أبي أيوب به. قال ابن القيسراني في ذخيرة الحفاظ ٣/١٤٤١ (٣١٥٩): «واصل هذا متروك الحديث». وقال الهيثمي في المجمع ٧/١١٨ (١١٣٩٢): «فيه واصل بن السّائِب، وهو متروك».عزاه السيوطي إلى هناد، وعبد بن حميد.أخرجه ابن جرير ٢٢/٢٥٥-٢٥٦، ومن طريق سعيد بن جُبَير أيضًا، وهناد (٤٢). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٢/٢٥٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٥٥، وابن أبي شيبة ١٣/١٣١، وهناد (٤١). وعزاه السيوطي إلى عبد بن حميد، والفريابي.أخرجه ابن المبارك في الزهد ١/٥٢٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٣٩-، وابن جرير ٢٢/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٥٦.تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ١٣/١٣٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٥- عن مجاهد. وعزاه السيوطي إلى عبد بن حميد.أخرجه الخطيب في المتفق والمفترق (٦٩١).أخرجه هناد (٤٣).أخرجه ابن جرير ٢٢/٢٥٧.أخرجه ابن جرير ٢٢/٢٥٦.أخرجه ابن أبي شيبة ١٣/١٣٢، وهناد (٣٩-٤٠). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٥٦ مقتصرًا على أوله. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٥٧، وبنحوه من طريق سعيد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.أخرجه ابن جرير ٢٢/٢٥٧.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥٧-٢٥٨.
  55,64,""
55,65," <q>﴿فِیهِمَا عَیۡنَانِ نَضَّاخَتَانِ ۝٦٦﴾</q> - تفسير ٧٤٥٧٣- قال عبد الله بن مسعود: <q>﴿نَضّاخَتانِ﴾</q> تَنضَخان بالمِسك والكافور على أولياء الله{1}. (ز) ٧٤٥٧٤- عن عبد الله بن عباس -من طريق علي- <q>﴿نَضّاخَتانِ﴾</q>، قال: فائضتان{2}. (١٤/١٥٤) ٧٤٥٧٥- عن عبد الله بن عباس، قال: <q>﴿نَضّاخَتانِ﴾</q> تَنضَخان بالماء من شدّة الرِّيّ{3}. (١٤/١٥٤) ٧٤٥٧٦- عن عبد الله بن عباس -من طريق عطية- يقول: <q>﴿نَضّاخَتانِ﴾</q> نَضّاخَتان بالخير{4}. (ز) ٧٤٥٧٧- عن البراء بن عازب، قال: العينان اللّتان تَجْريان خير مِن النَّضّاخَتين{5}. (١٤/١٥٤) ٧٤٥٧٨- عن يحيى بن سلمة، عن أبيه، قال: سمعتُ عبد الله بن أبي أوْفى في قوله: <q>﴿نضاختان﴾</q>، قال: نَضّاخَتان بالخير{6}. (ز) ٧٤٥٧٩- عن أنس بن مالك، <q>﴿نَضّاخَتانِ﴾</q>، قال: بالمِسك والعنبر، تَنضَخان على دُور الجنَّة كما يَنضَخ المطر على دُور أهل الدنيا{7}. (١٤/١٥٥) ٧٤٥٨٠- عن سعيد بن جُبَير -من طريق جعفر- قال: <q>﴿نَضّاخَتانِ﴾</q> تَنضَخان بألوان الفاكهة{8}. (١٤/١٥٥) ٧٤٥٨١- عن مجاهد بن جبر -من طريق سلمة- <q>﴿نَضّاخَتانِ﴾</q>، قال: بكلّ خير{9}. (١٤/١٥٥) ٧٤٥٨٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: <q>﴿نَضّاخَتانِ﴾</q> مُمتلئتان لا تنقطعان{10}. (ز) ٧٤٥٨٣- عن عكرمة مولى ابن عباس -من طريق أبي الأحوص، عن سِماك- قال: <q>﴿نَضّاخَتانِ﴾</q> تَنضَخان بالماء هوامش أنهار الجنة{11}. (١٤/١٥٥) ٧٤٥٨٤- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿نَضّاخَتانِ﴾</q> تَنضَخان بالخير{12}. (ز) ٧٤٥٨٥- قال مقاتل بن سليمان: <q>﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾</q> مملوءتان مِن كلّ خير، لا ينتقصان{13}. (ز) ٧٤٥٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿نَضّاخَتانِ﴾</q> تَنضَخان بالماء{14}٦٤٠٦. (ز) ٦٤٠٦ للسلف في قوله: <q>﴿نضاختان﴾</q> أقوال: الأول: تَنضَخان الماء. الثاني: تَنضَخان الماء والفاكهة. الثالث: نَضّاخَتان بألوان الفاكهة. الرابع: نَضّاخَتان بالخير. الخامس: ممتلئتان. وقد رجّح ابنُ جرير (٢٢/٢٦٠) -مستندًا إلى المعروف في اللغة- القول الأول، وعلّل ذلك بقوله: «لأنه المعروف بالعيون إذ كانت عيون ماء». وبيّن ابنُ عطية (٨/١٨١) أنّ <q>﴿نضاختان﴾</q> معناه: «الفوارة: التي يهيج ماؤها». وانتقد القول الثالث بقوله: «وهذا ضعيف». ولم يذكر مستندًا. ",footnotes:1:تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٧.أخرجه ابن جرير ٢٢/٢٥٩، وابن أبي حاتم -كما في تغليق التعليق ٣/٥٠٢ بلفظ: فيّاضتان، وكما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٦٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقال: ولفظ ابن حميد: قال: ما النضاختان بأفضل من اللتين تجريان.أخرجه ابن المبارك في الزهد ١/٥٢٦.أخرجه ابن أبي شيبة ٤/٥١٨، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٣٥ (٧٠)-. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن المبارك في الزهد (١٥٣٥ زيادات الحسين)، وابن جرير ٢٢/٢٥٩، وابن أبي شيبة ١٣/١٣٣، وأبو نعيم في الحلية ٤/٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ١٣/١٣٢. وعزاه السيوطي إلى عبد بن حميد بلفظ: بالخير.أخرجه ابن جرير ٢٢/٢٥٩.أخرجه هناد في الزهد (٩٧)، وابن جرير ٢٢/٢٥٨ مختصرًا بلفظ: فياضتان.أخرجه عبد الرزاق ٢/٢٦٦.تفسير مقاتل بن سليمان ٤/٢٠٤.أخرجه ابن جرير ٢٢/٢٥٨.
  55,66,""
55,67," <q>﴿فِیهِمَا فَـٰكِهَةࣱ وَنَخۡلࣱ وَرُمَّانࣱ ۝٦٨﴾</q> - تفسير ٧٤٥٨٧- عن عبد الله بن عباس، <q>﴿فِيهِما فاكِهَةٌ ونَخْلٌ ورُمّانٌ﴾</q> قال: هي ثَـمَّ؛ <q>﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</q> [الرحمن:٥٢]{1}. (١٤/١٥٥) ٧٤٥٨٨- عن سعيد بن جُبَير -من طريق رجل- <q>﴿فِيهِما فاكِهَةٌ ونَخْلٌ ورُمّانٌ﴾</q>، قال: نخل الجنة جذوعها ذهب، وكَرانِيفَها{2} زُمُرّد. وقال: جذوعها زُمُرّد، وكرانيفها ذهب، وسعَفها كسوة لأهل الجنة، ورُطبها كالدّلاء؛ أشدّ بياضًا مِن اللبن، وأليَن مِن الزُّبْد، وأحلى مِن العسل، ليس له عَجَمٌ{3}{4}. (ز) <q>﴿فِیهِمَا فَـٰكِهَةࣱ وَنَخۡلࣱ وَرُمَّانࣱ ۝٦٨﴾</q> - آثار متعلقة بالآية ٧٤٥٨٩- عن عمر بن الخطاب، قال: جاء ناسٌ مِن اليهود إلى رسول الله ﷺ، فقالوا: يا محمد، أفي الجنة فاكهة؟ قال: «نعم، فيها فاكهة ونَخلٌ ورُمّان». قالوا: أفيأكلون كما يأكلون في الدنيا؟ قال: «نعم، وأضعافه». قالوا: فيَقْضون الحوائج؟ قال: «لا، ولكنهم يَعْرَقون ويَرْشَحون، فيُذهب الله ما في بطونهم مِن أذًى»{5}. (١٤/١٥٦) ٧٤٥٩٠- عن أبي سعيد الخُدري، قال: سُئل رسول الله ﷺ عن نخل الجنة. فقال: «أصوله فِضّة، وجذوعها ذهب، وسَعفه حُلل، وحَمْله الرُّطب، أشدّ بياضًا مِن اللبن، وأليَن من الزُّبْد، وأحلى من الشّهد»{6}. (١٤/١٥٧) ٧٤٥٩١- عن أبي سعيد الخُدري، عن النبيِّ ﷺ، قال: «نظرتُ إلى الجنة، فإذا الرُّمّانة مِن رُمّانها كمثل البعير المُقْتب»{7}. (١٤/١٥٧) ٧٤٥٩٢- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «ما مِن رُمّانة مِن رُمّانكم هذه إلا وهي تُلقَّح بحبّة مِن رُمّان الجنة»{8}. (١٤/١٥٧) ٧٤٥٩٣- عن سلمان الفارسي أنه أخذ عودًا صغيرًا، ثم قال: لو طلبتَ في الجنة مثل هذا العود لم تُبصِره. قيل: فأين النخل والشجر؟ قال: أصولها اللؤلؤ والذهب، وأعلاه الثمر{9}. (١٤/١٥٦) ٧٤٥٩٤- عن عبد الله بن عباس -من طريق سعيد- قال: نخل الجنة؛ جذوعها زُمُرّد أخضر، وكرانيفها ذهب أحمر، وسَعفها كسوة لأهل الجنة، منها مُقطّعاتهم وحُللهم، وثمرها أمثال القِلال، أشدّ بياضًا من اللبن، وأحلى من العسل، وأليَن من الزّبْد، وليس لها عَجَمٌ{10}. (١٤/١٥٦) ٧٤٥٩٥- عن عبد الله بن عباس -من طريق سعيد- قال: إنّ الثمرة مِن ثمر الجنة طولها اثنا عشر ذراعًا، ليس لها عَجَم{11}. (١٤/١٥٧) ٧٤٥٩٦- عن عبد الله بن عباس -من طريق جعفر-: أنه كان يأخذ الحبّة من الرُّمّان فيأكلها، فقيل له: لِمَ تفعل هذا؟ قال: بلغني: أنّه ليس في الأرض رُمّانة تُلقَّح إلا بحبّة مِن الجنة، فلعلّها هذه{12}. (١٤/١٥٧) ٧٤٥٩٧- عن مَسروق بن الأَجْدع الهَمداني -من طريق أبي عبيدة- قال: نخل الجنة طَلْعها نضيد من أصلها إلى فرعها، وثمرها أمثال القِلال، كلمّا نُزِعتْ ثمرةٌ عادت مكانها أخرى، وأنهارها في غير أخدود، والعنقود اثنا عشر ذراعًا{13}. (ز) ٧٤٥٩٨- عن وهب [بن مُنَبِّه] الذّماري -من طريق زيد بن أسلم- قال: بلَغنا: أنّ في الجنة نخلًا جذوعها من ذهب، وكرانيفُها من ذهب، وجَريدها من ذهب، وسَعفها كسوة لأهل الجنة، كأحسن حُلَل رآها الناس قطّ، وشماريخُها من ذهب، وعَراجينُها من ذهب، وثفاريقُها{14} من ذهب، ورُطبها أمثال القِلال، أشدُّ بياضًا مِن اللبن والفِضّة، وأحلى مِن العسل والسُّكر، وأليَن من الزُّبْد والسّمن{15}. (ز) ٧٤٥٩٩- عن زيد بن أسلم -من طريق معمر- قال: بلَغنا: أنّ في الجنة نخلًا عروقها من ذهب، وكَرانيفَها من ذهب، وأقْتادها من ذهب، وسَعفها كسوة لأهل الجنة كأحسن حُللٍ رآها الناس قط، وشماريخُها{16} من ذهب، وعَراجينُها{17} من ذهب، وجَريدها من ذهب، ورُطبها أمثال القِلال؛ أشدّ بياضًا من اللبن، وأحلى من السُّكر والعسل، وأليَن من الزُّبْد والسّمن{18}. (ز) ٧٤٦٠٠- عن سليمان بن مهران الأعمش -من طريق معمر- قال: إنّ في الجنة شجرة لو أنّ غرابًا خرج من عُشّه فطار لَمات هَرمًا قبل أن يقطعها{19}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.الكَرانِيف: أُصول السعَفِ الغِلاظ العِراض، التي إذا يَبِسَتْ صارت أمثال الأَكتاف. لسان العرب (كرنف).العَجَم -بالتَّحريك-: النَّوى. النهاية (عجم).أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٦١.أخرجه عبد بن حميد في المنتخب ص٤٣ (٣٥)، وابن أبي الدنيا في صفة الجنة ص١٠١-١٠٢ (٩٩)، من طريق يحيى بن عبد الحميد، عن حصين بن عمر الأحمسي، عن مخارق، عن طارق بن شهاب، عن عمر به. قال ابن كثير في مسند الفاروق ٢/٦٠٨: «هذا غريب من هذا الوجه؛ لأنّ حصين بن عمر الأحمسي تكلموا فيه، ولكن قد رُوي من غير هذا الوجه». وقال البوصيري في إتحاف الخيرة ٨/٢٣٦ (٧٨٦٥): «رواه عبد بن حميد، والحارث، كلاهما عن يحيى بن عبد الحميد، عن حصين بن عمر الأحمسي، وهو ضعيف». وقال المتقي الهندي في كنز العمال ١٤/٦٤٨ (٣٩٧٧٥): «سنده ضعيف».عزاه السيوطي إلى ابن مردويه.أخرجه الدينوري في المجالسة وجواهر العلم ٣/٤٨٨-٤٩١ (١١٠٢)، وابن عساكر في تاريخه ١٩/٣٧٢ (٤٥٠٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٠٨-، والثعلبي ٩/١٩٤، من طريق حماد بن سلمة، عن أبي هارون العبدي، عن أبي سعيد الخدري به. قال العراقي في المغني عن حمل الأسفار ٢/١٢٦٩: «أبو هارون اسمه عمارة بن جوين، ضعيف جدًّا».أخرجه ابن عدي في الكامل في الضعفاء ٧/٥٤٣، وابن عساكر في تاريخه ٥٦/١٨٦، من طريق روح بن عبد المجيب، عن محمد بن الوليد، عن أبي عاصم، عن ابن جريج، عن ابن عجلان، عن أبيه، عن ابن عباس به. قال ابن عدي: «هذا حديث باطل». وقال ابن الجوزي في الموضوعات ٢/٢٨٥: «هذا حديث لا يصح». وقال الذهبي في لسان الميزان ٥/٤١٧ في ترجمة محمد بن الوليد بن أبان القلانسي (١٣٧٤): «من أباطيله» فذكره. وقال السخاوي في المقاصد الحسنة ص٥٨٧ (٩٨١): «سنده ضعيف». وأورده السيوطي في اللآلئ المصنوعة ٢/١٧٦، والشوكاني في الفوائد المجموعة ص١٥٩ (١٧)، وابن عراق الكناني في تنزيه الشريعة ٢/٢٤٢ (٤٢).أخرجه ابن أبي شيبة ١٣/٣٣٣، وهناد بن السري (٩٨)، والبيهقي (٨١٤٧).أخرجه ابن المبارك (١٤٨٨ زيادات الحسين)، وهناد بن السري (٩٩)، وابن أبي الدنيا في صفة الجنة (٥١)، وأبو الشيخ في العظمة (٥٧٦)، والحاكم ٢/٤٧٥-٤٧٦، والبيهقي في البعث والنشور (٣١١). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي الدنيا في صفة الجنة (١٢٤). وقال محققه: «إسناده ضعيف».أخرجه الطبراني (١٠٦١١)، والبيهقي في شعب الإيمان (٥٩٦٠). وقال الهيثمي في مجمع الزوائد ٥/٤٥: «ورجاله رجال الصحيح».أخرجه عبد الرزاق ٢/٢٦٧، وابن أبي حاتم ٣/٨٤٥.الثَّفارِيق: جمع الثَفْرُوق: وهي الأقماع التي تلزق في البُسْر. النهاية واللسان (ثفرق).أخرجه ابن جرير ٢٢/٢٦١.الشماريخ: جمع شمراخ، وهو غصن العذق. النهاية (شمرخ).العُرْجُون: العِذْقُ عامة. وقيل: هو العِذْقُ إذا يَبس واعْوجَّ. لسان العرب (عرجن).أخرجه عبد الرزاق ٢/٢٦٧.أخرجه عبد الرزاق ٢/٢٦٨.
