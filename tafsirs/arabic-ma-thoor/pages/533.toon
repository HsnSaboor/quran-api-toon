quran[27]{c,v,t}:
  55,41,""
55,42," <q>﴿هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِی یُكَذِّبُ بِهَا ٱلۡمُجۡرِمُونَ ۝٤٣ یَطُوفُونَ بَیۡنَهَا وَبَیۡنَ حَمِیمٍ ءَانࣲ ۝٤٤﴾</q> - تفسير ٧٤٣٩٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿وبَيْنَ حَمِيمٍ آنٍ﴾</q>، قال: الذي انتهى حرُّه. وفي لفظ: غَلْيُه{1}. (١٤/١٣١) ٧٤٣٩٧- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿حَمِيمٍ آنٍ﴾</q>. قال: الآني: الذي انتهى طَبْخه وحرّه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ نابغة بني ذبيان وهو يقول: وتُخضبُ لحية غَدَرتْ وخانَتْ بأحمر من نجيعِ الجَوف آني؟{2}. (١٤/١٣٢) ٧٤٣٩٨- قال كعب الأحبار: <q>﴿آن﴾</q> وادٍ مِن أودية جهنم، يُجمع فيه صديد أهل النار، فيُنطَلق بهم وهم في الأغلال، فيُغمسون في ذلك الوادي حتى تُخلع أوصالهم، ثم يَخرُجون منها وقد أحدث اللهُ سبحانه لهم خلْقًا جديدًا، فيُلقون في النار، فذلك قوله سبحانه: <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q>{3}. (ز) ٧٤٣٩٩- عن سعيد بن جُبَير -من طريق جعفر- قال: <q>﴿وبَيْنَ حَمِيمٍ آنٍ﴾</q> النُّحاس انتهى حرّه{4}. (١٤/١٣٢) ٧٤٤٠٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وبَيْنَ حَمِيمٍ آنٍ﴾</q>، قال: قد بلغ إناه{5}. (١٤/١٣٢) ٧٤٤٠١- عن عكرمة مولى ابن عباس، قال: <q>﴿وبَيْنَ حَمِيمٍ آنٍ﴾</q> نار قد اشتدّ حرّها{6}. (١٤/١٣٢) ٧٤٤٠٢- عن الحسن البصري -من طريق معمر- <q>﴿حَمِيمٍ آنٍ﴾</q>: قد أنى منتهى حرّه{7}. (ز) ٧٤٤٠٣- عن قتادة بن دعامة -من طريق أبي العوام- <q>﴿وبَيْنَ حَمِيمٍ آنٍ﴾</q>، قال: قد أنى طَبْخه منذ خلَق الله السموات والأرض{8}. (١٤/١٣٢) ٧٤٤٠٤- تفسير قتادة بن دعامة، قال: <q>﴿يطوفون بينها وبين حميم آن﴾</q> فهم في ترداد وعناء{9}. (ز) ٧٤٤٠٥- قال مقاتل بن سليمان: <q>﴿هذِهِ جَهَنَّمُ الَّتِي يُكَذِّبُ بِها المُجْرِمُونَ﴾</q> يعني: الكافرين في الدنيا، <q>﴿يَطُوفُونَ بَيْنَها﴾</q> يعني: جهنم شُواظًا <q>﴿وبَيْنَ حَمِيمٍ آنٍ﴾</q> شُواظًا، يعني بالحميم: الماء الحار الذي قد انتهى غليانه، يعني: الذي غلى حتى انتهى حرُّه، لا يستريحون ساعة مِن غَمٍّ، يُطاف عليهم في ألوان عذابهم، فذلك قوله: <q>﴿ثُمَّ إنَّ مَرْجِعَهُمْ﴾</q> من الزَّقوم، والحميم يعني: الشراب <q>﴿لَإلى الجَحِيمِ﴾</q> [الصافات:٦٨] فيُذهب به مرّة إلى الزَّقوم، ثم إلى الجحيم، ثم إلى منازلهم في جهنم، فذلك قوله: <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q>{10}. (ز) ٧٤٤٠٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿حَمِيمٍ آنٍ﴾</q>، قال: قد انتهى حرّه{11}. (ز) ٧٤٤٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q>، قال: يطوفون بينها وبين حميمٍ حاضر، الآني: الحاضر{11}٦٣٩٤. (ز) ٦٣٩٤ بيّن ابنُ جرير (٢٢/٢٣٢) أنّ الحميم الآن: ماء قد أُسخن وأُغلي حتى انتهى حرّه. ثم ذكر أنّ أهل التأويل قالوا بنحو ذلك، وحكى أقوالهم. ثم ذكر قول ابن زيد أنّ الآني: الحاضر، ولم يعلّق عليه. وذكر ابنُ عطية (٨/١٧٦-١٧٧) القولين، ثم قال معلّقًا: «ويحتمل قوله: <q>﴿آن﴾</q> أن يكون من هذا ومن هذا». ثم رجّح -مستندًا إلى النظائر، ولغة العرب- الأول بقوله: «وكونه من الثاني أبين، ومنه قوله تعالى: <q>﴿غير ناظرين إناه﴾</q> [الأحزاب:٥٣]». ثم قال: «ويُشبه أن يكون الأمر في المعنيين قريبًا بعضه من بعض، والأول أعم من الثاني». وبيّن ابنُ كثير (١٣/٣٢٨) كذلك تقارب المعنيين، فقال: «والحاضر لا ينافي ما روي عن القُرَظيّ أولًا أنه الحار، كقوله تعالى: <q>﴿تسقى من عين آنية﴾</q> [الغاشية:٥] أي: حارّة شديدة الحر لا تستطاع. وكقوله: <q>﴿غير ناظرين إناه﴾</q> [الأحزاب:٥٣] يعني: استواءه ونُضجه. فقوله: <q>﴿حميم آن﴾</q> أي: حميمٌ حارّ جدًّا». ",footnotes:1:أخرجه ابن جرير ٢٢/٢٣٣، كذلك من طريق عكرمة بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطستي في مسائل نافع (١٠)، والطبراني (١٠٥٩٧).تفسير الثعلبي ٩/١٨٨، وتفسير البغوي ٧/٤٥٠.أخرجه ابن جرير ٢٢/٢٣٣ بلفظ: الآني الذي قد انتهى حرّه. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٣٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٥-، وابن جرير ٢٢/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٣٤.أخرجه ابن جرير ٢٢/٢٣٤، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ١/٤٨٩.تفسير مقاتل بن سليمان ٤/٢٠٢.أخرجه ابن جرير ٢٢/٢٣٤.أخرجه ابن جرير ٢٢/٢٣٤.
  55,43,""
  55,44,""
55,45," <q>﴿وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ ۝٤٦﴾</q> - قراءات ٧٤٤٠٨- عن الجُرَيريّ، عن أخيه، قال: سمعتُ محمد بن سعد يقرأ هذه الآية: (ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ وإن زَنى وإن سَرَقَ). فقلت: ليس فيه: (وإن زَنى وإن سَرَقَ). قال: سمعتُ أبا الدّرداء يقرؤها كذلك، فقلتُ: ليس فيه: (وإن زَنى وإن سَرَقَ). قال: سمعتُ رسول الله ﷺ يقرؤها كذلك؛ فأنا أقرؤها كذلك حتى أموت{1}. (١٤/١٣٦) <q>﴿وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ﴾</q> - تفسير ٧٤٤٠٩- عن أبي الدّرداء: أن النبيَّ ﷺ قرأ هذه الآية: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>. فقلتُ: وإن زَنى وإن سَرق، يا رسول الله؟ فقال النبيُّ ﷺ الثانية: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>. فقلت: وإن زَنى وإن سَرق؟ فقال الثالثة: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>. فقلت: وإن زَنى وإن سَرق؟ قال: «نعم، وإن رَغِم أنفُ أبي الدّرداء»{2}. (١٤/١٣٥) ٧٤٤١٠- عن أبي هريرة، قال: قال رسول الله ﷺ: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>. فقال أبو الدرداء: وإن زَنى وإن سَرق، يا رسول الله؟ قال: «وإن زَنى وإن سَرق، وإن رَغِم أنفُ أبي الدّرداء». فكان أبو الدّرداء يَقُصّ ويقول: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، وإن رَغِم أنف أبي الدّرداء{3}. (١٤/١٣٥) ٧٤٤١١- عن أبي الدّرداء، قال: قال رسول الله ﷺ: «مَن شهد أن لا إله إلا الله وأني رسول الله دخل الجنة». ثم قرأ: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>{3}. (١٤/١٣٦) ٧٤٤١٢- عن أبي الدّرداء -من طريق سيار- <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> أنه قيل له: يا أبا الدّرداء، وإن زَنى وإن سَرق؟ قال: مَن خاف مقام ربّه لم يزنِ ولم يسرق{5}. (١٤/١٣٧) ٧٤٤١٣- عن عبد الله بن مسعود، قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> لِمَن خافه في الدنيا{6}. (١٤/١٣٤) ٧٤٤١٤- عن عبد الله بن مسعود -من طريق أبي وائل- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، قال: وإن زَنى وإن سَرق{7}. (ز) ٧٤٤١٥- عن أبي موسى الأشعري -من طريق أبي بكر- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> جنتان مِن ذهب للسابقين، وجنتان مِن فِضّة للتابعين{8}. (١٤/١٣٨) ٧٤٤١٦- عن عبد الله بن عباس -من طريق علي- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> وعد الله المؤمنين الذين خافوا مَقامه فأَدّوا فرائضه الجنةَ{9}. (١٤/١٣٣) ٧٤٤١٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، يقول: خاف ثم اتقى، والخائف مَن ركب طاعةَ الله وترك معصيته{9}. (١٤/١٣٣) ٧٤٤١٨- عن إبراهيم النَّخْعي -من طريق منصور- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> إذا أراد أن يُذنِب أمسك مخافة الله{11}. (١٤/١٣٤) ٧٤٤١٩- عن مجاهد بن جبر -من طريق الأعمش- <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، قال: هو الرجل يَهِمّ بالمعصية، فيذكر مقامه، فيَنزِع عنها{12}. (١٤/١٣٣) ٧٤٤٢٠- عن مجاهد بن جبر -من طريق منصور- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> الرجل يريد الذَّنب، فيَذكر الله، فيَدَع الذنب{13}. (١٤/١٣٤) ٧٤٤٢١- قال الضَّحّاك بن مُزاحِم: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> هذا لِمَن راقب اللهَ في السّر والعلانية بعلْمه، ما عرض له مِن مُحرّم تركه مِن خشية الله، وما عمل مِن خير أفضى به إلى الله، لا يحب أن يَطَّلِع عليه أحدٌ{14}. (ز) ٧٤٤٢٢- قال الحسن البصري: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، يعني: الذي يقوم بين يدي ربّه للحساب{15}. (ز) ٧٤٤٢٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، قال: إنّ المؤمنين خافوا ذلك المَقام، فعمِلوا لله، ودَأبُوا ونَصَبوا له بالليل والنهار{16}. (١٤/١٣٤) ٧٤٤٢٤- عن قتادة بن دعامة، قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> مَن خاف مَقام الله عليه{6}. (١٤/١٣٤) ٧٤٤٢٥- عن مجاهد بن جبر، مثله{6}. (١٤/١٣٤) ٧٤٤٢٦- عن قتادة بن دعامة -من طريق أبي العوام- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> إنّ لله مقامًا قد خافه المؤمنون{19}. (ز) ٧٤٤٢٧- عن عطية بن قيس، قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> نَزَلَتْ في الذي قال: أحْرِقوني بالنار لعلّي أُضِلّ الله. قال: تاب يومًا وليلة بعد أن تكلّم بهذا، فقَبل الله منه ذلك، وأدخله الجنة{20}٦٣٩٥. (١٤/١٣٤) ٦٣٩٥ ذكر ابنُ كثير (١٣/٣٢٩) هذا الأثر، ثم رجّح أنّ الآية عامة في كلّ مَن خاف مقام ربّه، وأضاف مستدلًا بعمومها على دخول مَن آمن من الجنّ الجنة، فقال: «وهذه الآية عامة في الإنس والجنّ، فهي مِن أدل دليل على أنّ الجنّ يدخلون الجنة إذا آمنوا واتقوا؛ ولهذا امتنّ الله تعالى على الثقلين بهذا الجزاء، فقال: <q>﴿ولمن خاف مقام ربه جنتان فبأي آلاء ربكما تكذبان﴾</q>». ٧٤٤٢٨- عن محمد بن شهاب الزُّهريّ، قال: كنتُ عند هشام بن عبد الملك، فقال: قال أبو هريرة: قال رسول الله ﷺ: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>. فقال أبو هريرة: وإن زَنى وإن سَرق؟ فقلتُ: إنّما كان ذلك قبل أن تنزل الفرائض، فلمّا نَزَلَت الفرائضُ ذهب هذا{3}. (١٤/١٣٦) ٧٤٤٢٩- قال مقاتل بن سليمان: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ﴾</q> يوم القيامة في الآخرة ...، وهو الرجل يَهِمّ بالمعصية، فيَذكر مقامه بين يدي الله ﷿، فيخاف، فيتركها، فله جنتان{22}. (ز) ٧٤٤٣٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> مقامه حين يقوم العباد يوم القيامة. وقرأ: <q>﴿يَوْمَ يَقُومُ النّاسُ لِرَبِّ العالَمِينَ﴾</q> [المطففين:٦]، وقال: ذاك مقام ربّك{7}. (ز) <q>﴿جَنَّتَانِ ۝٤٦﴾</q> - تفسير ٧٤٤٣١- عن عِياض بن غَنْم: أنه سمع رسولَ الله ﷺ تلا: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، قال: «بستانان، عَرض كلّ واحد منهما مسيرة مائة عام، فيها أشجار، وفرْعها ثابت، وشجرها ثابت، وعَرْصَتُها{24} عريضة، ونعيمها عظيم، وخَيرها دائم، ولذّتها قائمة، وأنهارها جارية، ورِيحها طيّب، وبركتها كثيرة، وحَياتها طويلة، وفاكهتها كثيرة»{3}. (١٤/١٣٨) ٧٤٤٣٢- عن أبي موسى الأشعري، عن النبيِّ ﷺ، في قوله: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q>، وقوله: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q>، قال: «جنتان مِن ذهبٍ للمُقرّبين، وجنتان مِن ورِق لأصحاب اليمين»{26}. (١٤/١٣٧) ٧٤٤٣٣- عن عبد الله بن عباس، عن النبي ﷺ أنه قال: «هل تَدرُون ما الجنتان؟». قالوا: الله ورسوله أعلم. قال: «هما بستانان في رَبَض الجنة، كل واحد منهما مسيرة خمسمائة عام، في وسط كلّ بستان دار في دار مِن نور على نور، ليس منهما بستان إلا يهتزّ بنعمة وخُضرة، قرارها ثابت، وفرعها ثابت، وشجرها نابت»{27}. (ز) ٧٤٤٣٤- قال الحسن البصري: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> هي أربع جنات: جنتان للسابقين، وهم أصحاب الأنبياء، وجنتان للتابعين{28}. (ز) ٧٤٤٣٥- قال مقاتل بن سليمان: <q>﴿جَنَّتانِ﴾</q> يعني: جنة عَدن، وجنة النعيم، وهما للصِّدِّيقين والشهداء والمُقَرّبين والسابقين{22}. (ز) ٧٤٤٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</q> جنتا السابقين. فقرأ: <q>﴿ذَواتا أفْنانٍ﴾</q> فقرأ حتى بلغ: <q>﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</q> [الرحمن:٥٨]، ثم رجع إلى أصحاب اليمين، فقال: <q>﴿ومِن دُونِهِما جَنَّتانِ﴾</q> [الرحمن:٦٢] فذكر فَضلهما، وما فيهما{7}٦٣٩٦. (ز) ٦٣٩٦ قال ابنُ جرير (٢٢/٢٣٥) مستندًا لأقوال السلف: «يقول -تعالى ذكره-: ولمن اتقى الله من عباده، فخاف مقامه بين يديه، فأطاعه بأداء فرائضه، واجتناب معاصيه؛ جنتان، يعني: بُستانين، وبنحو الذي قلنا في ذلك قال أهل التأويل، وإن اختلفتْ ألفاظهم في البيان عن تأويله، غير أنّ معنى جميعهم يقول إلى هذا». وذكر أقوال السلف على هذا. وذكر ابنُ عطية (٨/١٧٧) في قوله: «مَن» احتمالين، فقال: «»مَن«في قوله تعالى: <q>﴿ولمن﴾</q> يحتمل أن تقع على جميع المتصفين بالخوف الزاجر عن معاصي الله تعالى، ويحتمل أن تقع لواحد منهم، وبحسب هذا قال بعض الناس في هذه الآية: إنّ كلّ خائف له جنتان. وقال بعضهم: إن جميع الخائفين لهم جنتان». ونقل ابنُ عطية (٨/١٧٧) عن قوم قولهم: «أراد: جنة واحدة، وثنّى على نحو قوله تعالى: <q>﴿ألْقِيا فِي جَهَنَّمَ كُلَّ كَفّارٍ عَنِيدٍ﴾</q> [ق:٢٤]، وقول الحجاج: يا غلام اضربا عنقه». وانتقد (٥/٢٣٣ دار الكتب العلمية) قولهم -مستندًا إلى القرآن، وإلى اللغة- قائلًا: «وهذا ضعيف؛ لأن معنى التثنية متوجّه، فلا وجه للفرار إلى هذه الشاذة، ويؤيد التثنية قوله: <q>﴿ذَواتا أفْنانٍ﴾</q> وهي تثنية»ذات«على الأصل؛ لأن أصل»ذات«: ذوات». <q>﴿جَنَّتَانِ ۝٤٦﴾</q> - آثار متعلقة بالآية ٧٤٤٣٧- عن أبي موسى الأشعري، أنّ رسول الله ﷺ قال: «جنان الفردوس أربع: جنتان من ذهب حِلْيَتهما وآنِيتهما وما فيهما، وجنتان من فِضّة حِلْيَتهما وآنِيتهما وما فيهما، وما بين القوم وبين أن ينظروا إلى ربهم إلا رِداء الكبرياء على وجهه في جنة عَدن»{31}. (١٤/١٣٧) ٧٤٤٣٨- عن الحسن البصري، قال: كان شابٌّ على عهد عمر بن الخطاب مُلازِم المسجد والعبادة، فعشِقَته جارية، فأتته في خُلْوة، فكلّمته، فحدّث نفسه بذلك، فشهِق شَهقة، فغُشي عليه، فجاء عمٌّ له إلى بيته، فلمّا أفاق، قال: يا عمّ، انطلِق إلى عمر، فأقرِئه مِنِّي السلام، وقل له: ما جزاء مَن خاف مقام ربّه؟ فانطلق عمّه، فأخبر عمر وقد شهِق الفتى شَهقة أخرى فمات منها، فوقف عليه عمر، فقال: لك جنتان، لك جنتان{32}. (١٤/١٣٨) ",footnotes:1:أخرجه النسائي في الكبرى (١١٤٩٧)، وابن خزيمة في كتاب التوحيد ٢/٨١٠-٨١١ كلاهما بنحوه، من طريق سعيد الجريري، عن موسى، عن محمد بن سعد بن أبي وقاص، عن أبي الدرداء به. وعزاه السيوطي إلى الطبراني، وابن مردويه. وسنده ضعيف؛ موسى شيخ الجريري قال عنه ابن حجر في تقريب التهذيب (٧٠٢٨): «مجهول». والقراءة المذكورة قراءة شاذة.أخرجه أحمد ١٤/٣١١-٣١٢ (٨٦٨٣)، وابن جرير ٢٢/٢٣٧، من طريق محمد بن أبي حرملة، عن عطاء بن يسار، عن أبي الدّرداء به. قال الذهبي في ميزان الاعتدال ٣/٧٧: «قال البخاري: هو مرسل». وقال العراقي في تخريج أحاديث الإحياء ص١٩٣٨: «إسناد صحيح». وقال الهيثمي في المجمع ٧/١١٨ (١١٣٩٠): «رجال أحمد رجال الصحيح». وقال ابن حجر في الفتح ١١/٢٦٧: «قد وقع التصريح بسماع عطاء بن يسار له من أبي الدّرداء».عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٣٨. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٣٩.أخرجه ابن أبي شيبة ١٣/٣٨٣، والحاكم ١/٨٤، والبيهقي في البعث (٢٤٠-٢٤١). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٢/٢٣٥.أخرجه ابن جرير ٢٢/٢٣٥.أخرجه ابن جرير ٢٢/٢٣٦-٢٣٧.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٣١-، وعبد الرزاق ٢/٢٥٦، وابن جرير ٢٢/٢٣٥ بنحوه، وابن أبي شيبة ١٣/٥٧٠، وهناد (٨٩٩-٩٠٠)، وابن أبي الدنيا في التوبة (٥٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٣٦، والبيهقي في شعب الإيمان (٧٣٨-٧٣٩). وعزاه السيوطي إلى عبد بن حميد، وابن أبي الدنيا.تفسير البغوي ٧/٤٥١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٢-.أخرجه ابن جرير ٢٢/٢٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٣٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٠٢.أخرجه ابن جرير ٢٢/٢٣٩.العَرْصَة: كلُّ موضِع واسع لا بناء فيه. النهاية (عرص).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٣٨، من طريق علي بن سهل، عن مؤمل، عن حماد بن سلمة، عن ثابت، عن أبي بردة بن أبي موسى، عن أبيه به. قال ابن حجر في الفتح ١٣/٤٣١: «رجاله ثقات».أورده مقاتل بن سليمان في تفسيره ٤/٢٠٢.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.تفسير مقاتل بن سليمان ٤/٢٠٢.أخرجه ابن جرير ٢٢/٢٣٩.أخرجه أحمد ٣٢/٥٠٥ (١٩٧٣١)، وابن جرير ١٥/٤٣٥، والثعلبي ٦/٢٠١-٢٠٢، من طريق أبي قدامة الحارث بن عبيد الإيادي، عن أبي عمران الجَوْني، عن أبي بكر بن عبد الله بن قيس، عن أبيه به. قال الألباني في الضعيفة ٧/٤٦٥ (٣٤٦٥): «ضعيف».أخرجه البيهقي في شعب الإيمان (٧٣٦).
  55,46,""
55,47," <q>﴿ذَوَاتَاۤ أَفۡنَانࣲ ۝٤٨﴾</q> - تفسير ٧٤٤٣٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿ذَواتا أفْنانٍ﴾</q>، قال: ذَواتا ألوان{1}. (١٤/١٣٩) ٧٤٤٤٠- عن عبد الله بن عباس -من طريق عطية- قال: <q>﴿ذَواتا أفْنانٍ﴾</q> غُصونهما يمسّ بعضها بعضًا{2}. (١٤/١٣٩) ٧٤٤٤١- عن عبد الله بن عباس، قال: <q>﴿ذَواتا أفْنانٍ﴾</q> الفَنن: الغُصن{3}. (١٤/١٤٠) ٧٤٤٤٢- عن سعيد بن جُبَير، مثله{4}. (١٤/١٣٩) ٧٤٤٤٣- عن الضَّحّاك بن مُزاحِم -من طريق أبي سنان-، مثله{5}. (١٤/١٣٩) ٧٤٤٤٤- عن مجاهد بن جبر -من طريق سفيان، عن رجل من أهل البصرة- قال: ذَواتا أغصان{6}. (١٤/١٣٩) ٧٤٤٤٥- عن مجاهد بن جبر -من طريق سفيان- <q>﴿ذَواتا أفْنانٍ﴾</q>، قال: ألوان{7}. (ز) ٧٤٤٤٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول: <q>﴿ذَواتا أفْنانٍ﴾</q> ألوان مِن الفواكه{7}. (١٤/١٣٩) ٧٤٤٤٧- عن عكرمة مولى ابن عباس -من طريق عبد الله بن النّعمان- في قول الله: <q>﴿ذَواتا أفْنانٍ﴾</q>، قال: ظِلّ الأغصان على الحيطان، أما سمعت قول الشاعر: ما هاج شَوقك من هَديل حمامة تدعو على فَنَن الغُصون حماما تدعو أبا فَرْخَين صادف طاويًا ذا مِخلبين من الصّقور قَطاما؟{9}. (١٤/١٤٠) ٧٤٤٤٨- قال الحسن البصري: <q>﴿ذَواتا أفْنانٍ﴾</q> أغصان؛ يعني: ظِلال الشجر{10}. (ز) ٧٤٤٤٩- عن عطاء [بن أبي رباح]، قال: <q>﴿ذَواتا أفْنانٍ﴾</q> في كلّ غُصن فنون من الفاكهة{11}. (ز) ٧٤٤٥٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿ذَواتا أفْنانٍ﴾</q>، قال: ذَواتا فَضلٍ على ما سواهما{12}. (١٤/١٤١) ٧٤٤٥١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ذَواتا أفْنانٍ﴾</q>، قال: يعني: فَضلهما وسعتهما على ما سواهما{6}. (١٤/١٤١) ٧٤٤٥٢- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿ذواتا أفنان﴾</q>، قال: ألوان{14}. (ز) ٧٤٤٥٣- قال محمد بن السّائِب الكلبي: <q>﴿ذَواتا أفْنانٍ﴾</q> أفنان: أغصان، واحدها فَنن، وهو الغُصن المستقيم طولًا{11}. (ز) ٧٤٤٥٤- قال مقاتل بن سليمان: ثم نَعتَ الجنتين، فقال: <q>﴿ذَواتا أفْنانٍ﴾</q> يعني: ذَواتا أغصان يتماسّ أطراف شجرها بعضه بعضًا كالمعروشات{16}. (ز) ٧٤٤٥٥- عن أبي سنان [سعيد بن سنان البرجمي] -من طريق مهران- <q>﴿ذَواتا أفْنانٍ﴾</q>، قال: ذواتا ألوان{7}٦٣٩٧. (ز) ٦٣٩٧ اختُلف في قوله: <q>﴿ذواتا أفنان﴾</q> على أقوال: الأول: ذواتا ألوان. الثاني: ذواتا أغصان. الثالث: ذواتا أطراف أغصان الشجر. الرابع: عنى بذلك: فضلهما وسعتهما على ما سواهما. وعلّق ابنُ عطية (٨/٢٣٣) على القول الأول، فقال: «ويحتمل أن يكون جمع فَن، وهو قول ابن عباس، فكأنه مدحها بكثرة أنواع فواكهها ونعيمها». وعلّق على القول الثاني، فقال: «والأفنان يحتمل أن يكون جمع فَنن، وهو فَنن الغصن، وهذا قول مجاهد، فكأنه مدحها بظلالها وتكاثف أغصانها». وقد بين ابنُ جرير أنّ <q>﴿ذواتا أفنان﴾</q> معناه: «ذواتا ألوان». ودلّل على ذلك بأقوال السلف، ثم ذكر بقية هذه الأقوال ولم يعلق عليها. وذكر ابنُ كثير (١٣/٣٣٢) عبارات السلف في هذا، ثم علّق قائلًا: «وكل هذه الأقوال صحيحة، ولا منافاة بينها». ",footnotes:1:أخرجه ابن جرير ٢٢/٢٣٩-٢٤٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/٢٤١ بنحوه. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه هناد في الزهد (٤٣).أخرجه ابن جرير ٢٢/٢٤١.أخرجه ابن جرير ٢٢/٢٤٠.أخرجه ابن جرير ٢٢/٢٤٠.أخرجه ابن جرير ٢٢/٢٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي بكر بن حيان في الغرر، وابن الأنباري في الوقف والابتداء.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.تفسير البغوي ٧/٤٥٢.أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٤١ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.تفسير البغوي ٧/٤٥٢.تفسير مقاتل بن سليمان ٤/٢٠٣.أخرجه ابن جرير ٢٢/٢٤٠.
  55,48,""
55,49," <q>﴿فِیهِمَا عَیۡنَانِ تَجۡرِیَانِ ۝٥٠﴾</q> - تفسير ٧٤٤٥٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ الله اختار مِن الملائكة أربعة: جبريل، وميكائيل، وإسرافيل، وعزرائيل». وذكر الحديث حتى قال: «واختار من العيون أربعة، يقول في محكم كتابه: <q>﴿فيهما عينان تجريان﴾</q>، وقال: <q>﴿فيهما عينان نضاختان﴾</q> [الرحمن:٦٦]، فأما التي تجريان: فعين بَيْسان، وعين سُلْوان، وأما النَّضّاختان: فعين زمزم، وعين عَكا ...»{1}. (ز) ٧٤٤٥٧- قال عبد الله بن عباس: تَجْريان بالزيادة والكرامة مِن الله تعالى على أهل الجنة{2}. (ز) ٧٤٤٥٨- قال الحسن البصري: تجريان بالماء الزّلال، إحداهما التّسنيم، والأخرى السّلسبيل{2}. (ز) ٧٤٤٥٩- قال عطية بن سعد العَوفيّ: إحداهما من ماء غير آسِن، والأخرى من خمرٍ لذّةٍ للشاربين{4}. (ز) ٧٤٤٦٠- قال مقاتل بن سليمان: <q>﴿فِيهِما عَيْنانِ تَجْرِيانِ﴾</q> في [غير]{5}] أخدود، من ماء غير آسِن{6}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخه ١/٢٢١-٢٢٢، من طريق أبي الفضل العباس بن ميمون، عن أبي محمد المراغي، عن قتيبة، عن أبي عوانة، عن الأعمش، عن أبي صالح، عن أبي هريرة به. قال ابن عساكر: «هذا حديث منكر بمرّة، وأبو الفضل والمراغي مجهولان». وأورده الكناني في تنزيه الشريعة ٢/٦٥.تفسير الثعلبي ٩/١٨٩، وتفسير البغوي ٧/٤٥٢.تفسير الثعلبي ٩/١٨٩، وتفسير البغوي ٧/٤٥٢.تفسير الثعلبي ٩/١٩٠، وتفسير البغوي ٧/٤٥٢.[في المطبوع: عين.تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,50,""
55,51," <q>﴿فِیهِمَا مِن كُلِّ فَـٰكِهَةࣲ زَوۡجَانِ ۝٥٢﴾</q> - تفسير ٧٤٤٦١- عن عبد الله بن عمرو -من طريق أبي الهُذيل- قال: العنقود أبعد من صنعاء{1}. (١٤/١٤١) ٧٤٤٦٢- قال عبد الله بن عباس: <q>﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</q> فما في الدنيا ثمرة حُلوة ولا مُرّة إلا وهي في الجنة، حتى الحَنظل{2}. (١٤/١٤١) ٧٤٤٦٣- عن عكرمة مولى ابن عباس، <q>﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</q>، قال: فيهما من كلّ الثمرات{3}. (١٤/١٤١) ٧٤٤٦٤- قال مقاتل بن سليمان: <q>﴿فِيهِما مِن كُلِّ فاكِهَةٍ﴾</q> مِن كلّ لون من ألوان الفاكهة <q>﴿زَوْجانِ﴾</q> يعني: صِنفان{4}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ١٣/٩٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقد أخرج ابن أبي حاتم ٢/٥٢٣ نحوه عن عكرمة من طريق الحكم بن أبان، في تفسير قوله تعالى: <q>﴿لَهُ فِيها مِن كُلِّ الثَّمَراتِ﴾</q> [البقرة:٢٦٦].عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,52,""
55,53," <q>﴿مُتَّكِـِٔینَ عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾</q> - قراءات ٧٤٤٦٥- عن الضَّحّاك، قال: في قراءة عبد الله [بن مسعود]: (مُتَّكِئِينَ عَلى سُرُرٍ وفُرُشٍ بَطَآئِنُها مِن رَّفْرَفٍ مِّنْ إسْتَبْرَقٍ){1}. (١٤/١٤١) <q>﴿مُتَّكِـِٔینَ عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾</q> - تفسير الآية ٧٤٤٦٦- عن عبد الله بن مسعود -من طريق هُبَيرة بن يَرِيم- <q>﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</q>، قال: أُخبرتم بالبَطائن، فكيف بالظّهائر؟!{2}. (١٤/١٤١) ٧٤٤٦٧- قال أبو هريرة: <q>﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</q> هذه البَطائن، فما ظنّكم بالظّواهر؟!{3}. (ز) ٧٤٤٦٨- عن عبد الله بن عباس أنه قيل له: <q>﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</q>، فما الظواهر؟ قال: ذاك مما قال الله: <q>﴿فَلا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ﴾</q> [السجدة:١٧]{4}. (١٤/١٤٢) ٧٤٤٦٩- عن سعيد بن جُبَير-من طريق جعفر- أنه قيل له: البَطائن مِن إسْتَبرق، فما الظواهر؟ قال: هذا مما قال الله سبحانه: <q>﴿فَلا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ﴾</q> [السجدة:١٧]{5}. (ز) ٧٤٤٧٠- عن سعيد بن جُبَير -من طريق سالم- <q>﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</q>، قال: ظواهرها من نور جامد{6}. (١٤/١٤٢) ٧٤٤٧١- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿بطائنها من إستبرق﴾</q>، قال: الديباج. وفي لفظ: والإسْتَبرق لغة فارس، يُسمُّون الدِّيباج الغليظ: الإسْتَبرق{7}. (١٤/١٤١) ٧٤٤٧٢- عن عكرمة مولى ابن عباس -من طريق قتادة- <q>﴿مِن إسْتَبْرَقٍ﴾</q>، قال: الدِّيباج الغليظ{8}. (ز) ٧٤٤٧٣- قال الحسن البصري: <q>﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</q> بَطائنها يعني: ما يلي جلودهم، والإسْتَبرق: الصّفيق من الدِّيباج{9}. (ز) ٧٤٤٧٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿مِن إسْتَبْرَقٍ﴾</q>، قال: هو غليظ الدِّيباج{8}. (ز) ٧٤٤٧٥- عن يحيى بن أبي إسحاق، قال: قال لي سالم بن عبد الله: ما الإسْتَبرق؟ قال: قلتُ: ما غلُظ من الديباج وخشُن منه{8}. (ز) ٧٤٤٧٦- قال مقاتل بن سليمان: <q>﴿مُتَّكِئِينَ عَلى فُرُشٍ بَطائِنُها مِن إسْتَبْرَقٍ﴾</q> يعني: ظاهرها من الدِّيباج الأخضر، فوق الفُرُش الدِّيباج، وهي بلغة فارس، نظيرها في آخر السورة: <q>﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</q> يعني: المحابس الخُضر على الفُرُش{12}٦٣٩٨. (ز) ٦٣٩٨ بيّن ابنُ جرير (٢٢/٢٤٢-٢٤٤) أن قوله: <q>﴿بطائنها من إستبرق﴾</q> معناه: أنّ بطائن هذه الفُرُش من غليظ الدِّيباج، ودلّل على ذلك بآثار السلف. ثم أورد عن بعض أهل اللغة -وهو موافق لما جاء في قول مقاتل، وقول سعيد بن جُبَير في الأثر في تفسير الآية- أنّ البطائن هاهنا بمعنى: الظواهر. ووجّهه، فقال: «وقد زعم أهل العربية أنّ البطانة قد تكون ظهارة، والظهارة تكون بطانة، وذلك أنّ كل واحد منهما قد يكون وجهًا، قال: وتقول العرب: هذا ظهر السماء، وهذا بطن السماء لظاهرها الذي نراه». <q>﴿وَجَنَى ٱلۡجَنَّتَیۡنِ دَانࣲ ۝٥٤﴾</q> - تفسير ٧٤٤٧٧- عن علي بن أبي طالب، أن رسول الله ﷺ قال: «... وفيها ثمار متدلّية، إذا اشتَهَوها انشَعب الغُصن إليهم، فيأكلون مِن أيّ الثمار اشتَهوا؛ إن شاء قائمًا، وإن شاء مُتكئًا، وذلك قول الله ﷿: <q>﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</q>...»{13}. (ز) ٧٤٤٧٨- عن عبد الله بن عباس -من طريق علي- <q>﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</q>، قال: جَناها: ثمرها، والداني: القريب منك، يناله القائم والقاعد{14}. (١٤/١٤٢) ٧٤٤٧٩- عن مجاهد بن جبر: <q>﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</q> ما يُجتنى من قريب{15}. (ز) ٧٤٤٨٠- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</q>، قال: دانٍ ثمارها{16}. (ز) ٧٤٤٨١- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</q> ثمارها دانية، لا يرُدّ أيديهم عنها بُعدٌ ولا شوك. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «والذي نفس محمد بيده، لا يَقْطِف رجلٌ ثمرة من الجنة فتَصل إلى فِيه، حتى يُبدّل الله مكانها خيرًا منها»{17}. (١٤/١٤٢) ٧٤٤٨٢- قال مقاتل بن سليمان: ثم قال: <q>﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</q> يعني: ثمره، وجنى الشجر في الجنتين دانٍ. يقول: ما يُجتنى في الجنتين دانٍ. يقول: طول الشجر لهذا المجتني قريب، يتناوله الرجل إن شاء جالسًا، وإن شاء متكئًا أو قائمًا{12}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة. انظر: روح المعاني ٢٧/١١٨.أخرجه ابن جرير ٢٢/٢٤٣ بنحوه، والحاكم ٢/٤٧٥، والبيهقي في البعث (٣٣٩)، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٥)-. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وعبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم، وابن مردويه.تفسير الثعلبي ٩/١٩٠، وتفسير البغوي ٧/٤٥٣.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٢/٢٤٤.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٦)-، وأبو نعيم في الحلية ٤/٢٨٥-٢٨٦.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٧)-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.أخرجه ابن جرير ٢٢/٢٤٣.أخرجه ابن جرير ٢٢/٢٤٣.تفسير مقاتل بن سليمان ٤/٢٠٣.أخرجه ابن أبي الدنيا في صفة الجنة ص٣٥-٣٧ (٦) مطولًا، من طريق محمد بن عباد بن موسى العكلي، عن الضَّحّاك بن مُزاحِم، عن الحارث، عن علي به. وسنده ضعيف؛ فيه الحارث بن عبد الله الأعور، قال عنه ابن حجر في تقريب التهذيب (١٠٢٩): «في حديثه ضعف».أخرجه ابن جرير ٢٢/٢٤٥ بلفظ: ثمارها دانية، والبيهقي في البعث (٣٠٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير -كما في الفتح ٦/٣٢٣-.أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٤٥ (١١٦)-.أخرجه ابن جرير ٢٢/٢٤٤. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه عبد الرزاق ٢/٢٦٥ من طريق معمر مختصرًا.تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,54,""
55,55," <q>﴿فِیهِنَّ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</q> - تفسير ٧٤٤٨٣- عن علي بن حُسين، عن النبيِّ ﷺ، في قوله: <q>﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</q>، قال: «لا يَنظُرْنَ إلّا إلى أزواجهنّ»{1}. (١٤/١٤٣) ٧٤٤٨٤- عن عبد الله بن عباس، <q>﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</q>، يقول: مِن غير أزواجهنّ{2}. (١٤/١٤٣) ٧٤٤٨٥- عن مجاهد بن جبر -من طريق أبي يحيى- قال: <q>﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</q> قَصَرن طَرْفهنّ عن الرجال؛ فلا يَنظُرن إلا إلى أزواجهنّ{3}. (١٤/١٤٣) ٧٤٤٨٦- عن الحسن البصري، قال: <q>﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</q> قاصرات الطّرف على أزواجهنّ، لا يُردْن غيرهم، واللهِ، ما هُنَّ متبرّجاتٍ ولا مُتطلِّعات{4}. (١٤/١٤٣) ٧٤٤٨٧- عن قتادة بن دعامة -من طريق سعيد-، مثله{5}. (١٤/١٤٣) ٧٤٤٨٨- قال مقاتل بن سليمان: <q>﴿فِيهِنَّ﴾</q> يعني: في هذه الجنان الأربع -في التقديم-: جنة عَدن، وجنة النعيم، وجنة الفِردَوس، وجنة المأوى، ففي هذه الجنان الأربع جنان كثيرة، في الكثرة مثل ورق الشجر ونجوم السماء، يقول: <q>﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</q> يعني: النساء{6}٦٣٩٩. (ز) ٦٣٩٩ ذكر ابنُ عطية (٨/١٧٩) أنّ «الضمير في قوله تعالى: <q>﴿فِيهِنَّ﴾</q> للفُرُش». ثم نقل احتمالًا آخر فقال: «وقيل: للجنات؛ إذ الجنتان جنات في المعنى». ٧٤٤٨٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</q> لا يَنظُرن إلا إلى أزواجهنّ، تقول: وعزّة ربي وجلاله وجماله، إنْ أرى في الجنة شيئًا أحسن منك، فالحمد لله الذي جعلك زوجي، وجعلني زوجك{7}٦٤٠٠. (ز) ٦٤٠٠ أفادت آثار السلف أنّ قوله: <q>﴿قاصرات الطرف﴾</q> أي: على أزواجهنَّ، فلا يُرِدْنَ غيرهم. وقد ذكر ابنُ القيم (٣/٩٩) هذا، وأضاف قولًا آخر، فقال: «وقيل: قَصرن طرف أزواجهنّ عليهن، فلا يدعهم حُسنهنّ وجمالهن أن ينظروا إلى غيرهن». وعلّق عليه بقوله: «وهذا صحيح من جهة المعنى، وأما من جهة اللفظ: فـ<q>﴿قاصرات﴾</q> صفة مضافة إلى الفاعل الحِسان الوجوه، وأصله: قاصر طرفهن، أي: ليس بطامح مُتعدّ». <q>﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾</q> - تفسير ٧٤٤٩٠- عن عِياض بن غَنْم، أنه سمع رسول الله ﷺ تلا: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>، قال: «لم يُصِبْهُنَّ شمسٌ ولا دُخان، لم يُعَذَّبْنَ في البلايا، ولم يُكْلَمْنَ في الرّزايا، ولم تغيّرهن الأحزان، ناعمات لا يبأسن، وخالدات فلا يمُتن، ومُقيمات فلا يَظعنَّ، لهنّ أخبار يَعجِز عن نعتهنّ الأوهام، والجنة أخضرها كالأصفر، وأصفرها كالأخضر، ليس فيها حَجرٌ ولا مَدرٌ ولا كَدرٌ، ولا عود يابس، أُكُلها دائم، وظِلّها قائم»{1}. (١٤/١٤٦) ٧٤٤٩١- عن علي بن أبي طالب -من طريق رجل- <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>، قال: منذ خَلقهنّ{9}. (ز) ٧٤٤٩٢- عن عبد الله بن عباس -من طريق علي- <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q>، قال: لم يَدنُ منهنّ، أو لم يُدْمِهنّ{10}. (١٤/١٤٣) ٧٤٤٩٣- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q>. قال: كذلك نساء الجنة، لم يَدنُ منهن غير أزواجهنّ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول: مَشين إليَّ لم يُطْمثن قبلي وهنّ أصحّ من بَيْض النّعام؟{11}. (١٤/١٤٤) ٧٤٤٩٤- عن أبي العالية الرِّياحيّ -من طريق عاصم- أنه قال له: امرأة طامث. قال: ما طامث؟ فقال رجلٌ: حائض. فقال أبو العالية: حائض؟! أليس يقول الله ﷿: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>{12}. (ز) ٧٤٤٩٥- عن سعيد بن جُبَير، قال: <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q> لم يَطأهنّ{13}. (١٤/١٤٤) ٧٤٤٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q>، قال: لم يَمسّهن{14}. (١٤/١٤٤) ٧٤٤٩٧- عن مجاهد بن جبر -من عثمان بن الأسود- قال: إذا جامع الرجلُ أهلَه ولم يُسَمِّ، انطوى الجانُّ على إحليله، فجامع معه، فذلك قوله: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>{15}. (١٤/١٤٥) ٧٤٤٩٨- عن عامر الشعبي، <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>، قال: هنّ مِن نساء أهل الدنيا، خَلقهنّ اللهُ في الخلْق الآخر، كما قال: <q>﴿إنّا أنْشَأْناهُنَّ إنْشاءً * فَجَعَلْناهُنَّ أبْكارًا﴾</q> [الواقعة:٣٥-٣٦] لم يَطْمثهن حين عُدْنَ في الخلْق الآخر إنس قبلهم ولا جان{16}. (١٤/١٤٥) ٧٤٤٩٩- عن عكرمة مولى ابن عباس -من طريق مُغيرة- قال: <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q>لم يُجامعهنّ{17}. (١٤/١٤٤) ٧٤٥٠٠- عن عكرمة مولى ابن عباس -من طريق مُغيرة- قال: لا تقُلِ المرأة: إني طامث؛ فإن الطّمث هو الجماع، وإنّ الله -جل ثناؤه- يقول: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q>{18}. (١٤/١٤٤) ٧٤٥٠١- عن أرطاة بن المنذر، قال: تَذاكرنا عند ضمرة بن حبيب: أيدخل الجنُّ الجنةَ؟ قال: نعم؛ وتصديق ذلك في كتاب الله: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q> للجنّ الجنّيات، وللإنس الإنسيّات{19}٦٤٠١. (١٤/١٤٥) ٦٤٠١ اختلف السلف في قوله: <q>﴿لم يطمثهن إنس قبلهم ولا جان﴾</q> على قولين: الأول: أنّ الجنّ قد تجامع نساء البشر مع أزواجهن، إذا لم يذكر الزوج الله تعالى. الثاني: أنّ الجنّ لهم قاصرات الطرف من الجنّ نوعهم. ووجَّه ابنُ عطية (٨/١٧٩) القول الأول بقوله: «فتكون الآية على هذا نافية لجميع المجامعات». ووجَّه القول الثاني بقوله: «فنفى في هذه الآية الافتضاض عن البشريّات والجنِّيّات». ثم بيّن احتمال الآية وجهًا آخر، فقال: «ويحتمل اللفظ أن يكون مبالغة وتأكيدًا، كأنه قال: لم يطمثهنّ شيء. أراد العموم التام، لكنه صرح من ذلك بالذي يعقل منه أن يَطمث». ولم يذكر ابنُ جرير (٢٢/٢٤٧-٢٤٨) في معناه غير ما ورد في قول أرطاة وما في معناه. ٧٤٥٠٢- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- <q>﴿لم يطمثهن إنس قبلهم ولا جان﴾</q>، قال: لم يضاجعهم إنسٌ قبلهم، ولا جانٌّ{20}. (ز) ٧٤٥٠٣- قال محمد بن السّائِب الكلبي: <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q> هنّ مِن نساء الدنيا، لم يُمْسَسْنَ منذ أُنشِئن خلقًا{21}. (ز) ٧٤٥٠٤- قال مقاتل بن سليمان: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</q> لأنهنّ خُلِقن في الجنة مع شجر الجنة، يعني: <q>﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ﴾</q> إنس قبل أهل الجنة، <q>﴿ولا جانٌّ﴾</q> يعني: جنّ،... <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q> لم يُدميهنّ{22}٦٤٠٢. (ز) ٦٤٠٢ للسلف في الموصوف بهذه الصفات قولان: الأول: أنهن الحور العين اللواتي أُنشئن في الجنة. الثاني: أنهن من نساء الدنيا. وقد ذكر ابنُ القيم (٣/١٠٠-١٠١) القولين، ثم رجّح -مستندًا إلى ظاهر القرآن، وإلى السياق- الأول، فقال: «ظاهر القرآن أنّ هؤلاء النسوة لسنَ من نساء الدنيا، وإنما هنّ من الحُور حور العين. وأما نساء الدنيا فقد طَمثهن الإنس، ونساء الجنّ قد طَمثهن الجنّ، والآية تدل على ذلك. ويدل على أنهن الحور اللاتي خُلقن في الجنة أنه سبحانه جعلهنّ مما أعده الله في الجنة لأهلها مِن الفاكهة والثمار والأنهار والملابس وغيرها، ويدل عليه أيضًا الآية التي بعدها، وهي قوله تعالى: <q>﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</q>، ثم قال: <q>﴿لَمْ يَطْمِثْهُنَّ إنس قَبْلَهُمْ ولا جانٌّ﴾</q>». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١٣/١٣٠، وابن جرير ٢٢/٢٤٥. وعزاه السيوطي إلى عبد بن حميد. وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤- بلفظ: لا يبغين غير أزواجهن.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٠٣.أخرجه ابن جرير ٢٢/٢٤٦.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٢٤٧.أخرجه ابن جرير ٢٢/٢٤٧، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطستي (٢٥٩).أخرجه ابن جرير ٢٢/٢٤٧-٢٤٨.أخرجه ابن أبي شيبة ١٣/١٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٢٤٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٢٤٨، والحكيم الترمذي في نوادر الأصول ١/٣٨٤.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن أبي شيبة ١٣/١٣١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٤٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/٢٤٨ بنحوه، وأبو الشيخ في العظمة (١١٦٢). وعزاه السيوطي إلى ابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.تفسير البغوي ٧/٤٥٤.تفسير مقاتل بن سليمان ٤/٢٠٣-٢٠٤.
