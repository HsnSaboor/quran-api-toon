quran[27]{c,v,t}:
  55,41,""
  55,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِی یُكَذِّبُ بِهَا ٱلۡمُجۡرِمُونَ ۝٤٣ یَطُوفُونَ بَیۡنَهَا وَبَیۡنَ حَمِیمٍ ءَانࣲ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٣٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وبَيْنَ حَمِيمٍ آنٍ﴾</span>، قال: الذي انتهى حرُّه. وفي لفظ: غَلْيُه{1}. (١٤/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿حَمِيمٍ آنٍ﴾</span>. قال: الآني: الذي انتهى طَبْخه وحرّه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ نابغة بني ذبيان وهو يقول:</p><p>وتُخضبُ لحية غَدَرتْ وخانَتْ بأحمر من نجيعِ الجَوف آني؟{2}. (١٤/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٩٨<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: <span class="qpc-hafs">﴿آن﴾</span> وادٍ مِن أودية جهنم، يُجمع فيه صديد أهل النار، فيُنطَلق بهم وهم في الأغلال، فيُغمسون في ذلك الوادي حتى تُخلع أوصالهم، ثم يَخرُجون منها وقد أحدث اللهُ سبحانه لهم خلْقًا جديدًا، فيُلقون في النار، فذلك قوله سبحانه: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٣٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- قال: <span class="qpc-hafs">﴿وبَيْنَ حَمِيمٍ آنٍ﴾</span> النُّحاس انتهى حرّه{4}. (١٤/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وبَيْنَ حَمِيمٍ آنٍ﴾</span>، قال: قد بلغ إناه{5}. (١٤/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: <span class="qpc-hafs">﴿وبَيْنَ حَمِيمٍ آنٍ﴾</span> نار قد اشتدّ حرّها{6}. (١٤/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿حَمِيمٍ آنٍ﴾</span>: قد أنى منتهى حرّه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- <span class="qpc-hafs">﴿وبَيْنَ حَمِيمٍ آنٍ﴾</span>، قال: قد أنى طَبْخه منذ خلَق الله السموات والأرض{8}. (١٤/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٤<span class="dash">-</span></span> تفسير <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿يطوفون بينها وبين حميم آن﴾</span> فهم في ترداد وعناء{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هذِهِ جَهَنَّمُ الَّتِي يُكَذِّبُ بِها المُجْرِمُونَ﴾</span> يعني: الكافرين في الدنيا، <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها﴾</span> يعني: جهنم شُواظًا <span class="qpc-hafs">﴿وبَيْنَ حَمِيمٍ آنٍ﴾</span> شُواظًا، يعني بالحميم: الماء الحار الذي قد انتهى غليانه، يعني: الذي غلى حتى انتهى حرُّه، لا يستريحون ساعة مِن غَمٍّ، يُطاف عليهم في ألوان عذابهم، فذلك قوله: <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهُمْ﴾</span> من الزَّقوم، والحميم يعني: الشراب <span class="qpc-hafs">﴿لَإلى الجَحِيمِ﴾</span> [الصافات:٦٨] فيُذهب به مرّة إلى الزَّقوم، ثم إلى الجحيم، ثم إلى منازلهم في جهنم، فذلك قوله: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿حَمِيمٍ آنٍ﴾</span>، قال: قد انتهى حرّه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span>، قال: يطوفون بينها وبين حميمٍ حاضر، الآني: الحاضر{11}<span class=comment-ref>٦٣٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٤</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٢/٢٣٢) أنّ الحميم الآن: ماء قد أُسخن وأُغلي حتى انتهى حرّه. ثم ذكر أنّ <span class="mustanad">أهل التأويل قالوا بنحو ذلك</span>، وحكى أقوالهم. ثم ذكر قول ابن زيد أنّ الآني: الحاضر، ولم يعلّق عليه.</p><p>وذكر <u>ابنُ عطية</u> (٨/١٧٦-١٧٧) القولين، ثم قال <span class="comment-type-4">معلّقًا</span>: «و<b>يحتمل</b> قوله: <span class="qpc-hafs">﴿آن﴾</span> أن يكون من هذا ومن هذا». ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">-مستندًا إلى النظائر، ولغة العرب-</span> الأول بقوله: «وكونه من الثاني أبين، ومنه قوله تعالى: <span class="qpc-hafs">﴿غير ناظرين إناه﴾</span> [الأحزاب:٥٣]». ثم قال: «ويُشبه أن يكون الأمر في المعنيين قريبًا بعضه من بعض، والأول أعم من الثاني».</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ كثير</u> (١٣/٣٢٨) كذلك تقارب المعنيين، فقال: «والحاضر لا ينافي ما روي عن القُرَظيّ أولًا أنه الحار، <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿تسقى من عين آنية﴾</span> [الغاشية:٥] أي: حارّة شديدة الحر لا تستطاع. <span class="mustanad">وكقوله</span>: <span class="qpc-hafs">﴿غير ناظرين إناه﴾</span> [الأحزاب:٥٣] يعني: استواءه ونُضجه. فقوله: <span class="qpc-hafs">﴿حميم آن﴾</span> أي: حميمٌ حارّ جدًّا».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٣٣، كذلك من طريق عكرمة بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه الطستي في مسائل نافع (١٠)، والطبراني (١٠٥٩٧).|3:تفسير الثعلبي ٩/١٨٨، وتفسير البغوي ٧/٤٥٠.|4:أخرجه ابن جرير ٢٢/٢٣٣ بلفظ: الآني الذي قد انتهى حرّه. وعزاه السيوطي إلى عبد بن حميد.|5:تفسير مجاهد ص٦٣٨، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٥-، وابن جرير ٢٢/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٣٤.|8:أخرجه ابن جرير ٢٢/٢٣٤، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|9:تفسير يحيى بن سلام ١/٤٨٩.|10:تفسير مقاتل بن سليمان ٤/٢٠٢.|11:أخرجه ابن جرير ٢٢/٢٣٤.|12:أخرجه ابن جرير ٢٢/٢٣٤.
  55,43,""
  55,44,""
  55,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ ۝٤٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٠٨<span class="dash">-</span></span> عن الجُرَيريّ، عن أخيه، قال: سمعتُ محمد بن سعد يقرأ هذه الآية: (ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ وإن زَنى وإن سَرَقَ). فقلت: ليس فيه: (وإن زَنى وإن سَرَقَ). قال: سمعتُ أبا الدّرداء يقرؤها كذلك، فقلتُ: ليس فيه: (وإن زَنى وإن سَرَقَ). قال: سمعتُ رسول الله ﷺ يقرؤها كذلك؛ فأنا أقرؤها كذلك حتى أموت{1}. (١٤/١٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٠٩<span class="dash">-</span></span> عن أبي الدّرداء: أن النبيَّ ﷺ قرأ هذه الآية: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقلتُ: وإن زَنى وإن سَرق، يا رسول الله؟ فقال النبيُّ ﷺ الثانية: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقلت: وإن زَنى وإن سَرق؟ فقال الثالثة: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقلت: وإن زَنى وإن سَرق؟ قال: «<b>نعم، وإن رَغِم أنفُ أبي الدّرداء</b>»{2}. (١٤/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٠<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقال أبو الدرداء: وإن زَنى وإن سَرق، يا رسول الله؟ قال: «<b>وإن زَنى وإن سَرق</b>، <b>وإن رَغِم أنفُ أبي الدّرداء</b>». فكان أبو الدّرداء يَقُصّ ويقول: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، وإن رَغِم أنف أبي الدّرداء{3}. (١٤/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١١<span class="dash">-</span></span> عن أبي الدّرداء، قال: قال رسول الله ﷺ: «<b>مَن شهد أن لا إله إلا الله وأني رسول الله دخل الجنة</b>». ثم قرأ: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>{3}. (١٤/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٢<span class="dash">-</span></span> عن <span class="name-1">أبي الدّرداء</span> -من طريق سيار- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> أنه قيل له: يا أبا الدّرداء، وإن زَنى وإن سَرق؟ قال: مَن خاف مقام ربّه لم يزنِ ولم يسرق{5}. (١٤/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> لِمَن خافه في الدنيا{6}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي وائل- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: وإن زَنى وإن سَرق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٥<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span> -من طريق أبي بكر- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> جنتان مِن ذهب للسابقين، وجنتان مِن فِضّة للتابعين{8}. (١٤/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> وعد الله المؤمنين الذين خافوا مَقامه فأَدّوا فرائضه الجنةَ{9}. (١٤/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، يقول: خاف ثم اتقى، والخائف مَن ركب طاعةَ الله وترك معصيته{9}. (١٤/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> إذا أراد أن يُذنِب أمسك مخافة الله{11}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: هو الرجل يَهِمّ بالمعصية، فيذكر مقامه، فيَنزِع عنها{12}. (١٤/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> الرجل يريد الذَّنب، فيَذكر الله، فيَدَع الذنب{13}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢١<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> هذا لِمَن راقب اللهَ في السّر والعلانية بعلْمه، ما عرض له مِن مُحرّم تركه مِن خشية الله، وما عمل مِن خير أفضى به إلى الله، لا يحب أن يَطَّلِع عليه أحدٌ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، يعني: الذي يقوم بين يدي ربّه للحساب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: إنّ المؤمنين خافوا ذلك المَقام، فعمِلوا لله، ودَأبُوا ونَصَبوا له بالليل والنهار{16}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> مَن خاف مَقام الله عليه{6}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، مثله{6}. (١٤/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> إنّ لله مقامًا قد خافه المؤمنون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٧<span class="dash">-</span></span> عن <span class="name-2">عطية بن قيس</span>، قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> نَزَلَتْ في الذي قال: أحْرِقوني بالنار لعلّي أُضِلّ الله. قال: تاب يومًا وليلة بعد أن تكلّم بهذا، فقَبل الله منه ذلك، وأدخله الجنة{20}<span class=comment-ref>٦٣٩٥</span>. (١٤/١٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٥</span> ذكر <u>ابنُ كثير</u> (١٣/٣٢٩) هذا الأثر، ثم <span class="comment-type-3">رجّح</span> أنّ الآية <span class="mustanad">عامة</span> في كلّ مَن خاف مقام ربّه، وأضاف مستدلًا بعمومها على دخول مَن آمن من الجنّ الجنة، فقال: «وهذه الآية عامة في الإنس والجنّ، فهي مِن أدل دليل على أنّ الجنّ يدخلون الجنة إذا آمنوا واتقوا؛ ولهذا امتنّ الله تعالى على الثقلين بهذا الجزاء، فقال: <span class="qpc-hafs">﴿ولمن خاف مقام ربه جنتان فبأي آلاء ربكما تكذبان﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span>، قال: كنتُ عند هشام بن عبد الملك، فقال: قال أبو هريرة: قال رسول الله ﷺ: <b><span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span></b>. فقال أبو هريرة: وإن زَنى وإن سَرق؟ فقلتُ: إنّما كان ذلك قبل أن تنزل الفرائض، فلمّا نَزَلَت الفرائضُ ذهب هذا{3}. (١٤/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ﴾</span> يوم القيامة في الآخرة ...، وهو الرجل يَهِمّ بالمعصية، فيَذكر مقامه بين يدي الله ﷿، فيخاف، فيتركها، فله جنتان{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> مقامه حين يقوم العباد يوم القيامة. وقرأ: <span class="qpc-hafs">﴿يَوْمَ يَقُومُ النّاسُ لِرَبِّ العالَمِينَ﴾</span> [المطففين:٦]، وقال: ذاك مقام ربّك{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَنَّتَانِ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٣١<span class="dash">-</span></span> عن عِياض بن غَنْم: أنه سمع رسولَ الله ﷺ تلا: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، قال: «<b>بستانان، عَرض كلّ واحد منهما مسيرة مائة عام، فيها أشجار، وفرْعها ثابت، وشجرها ثابت، وعَرْصَتُها{24} عريضة، ونعيمها عظيم، وخَيرها دائم، ولذّتها قائمة، وأنهارها جارية، ورِيحها طيّب، وبركتها كثيرة، وحَياتها طويلة، وفاكهتها كثيرة</b>»{3}. (١٤/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٢<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>، وقوله: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span>، قال: «<b>جنتان مِن ذهبٍ للمُقرّبين، وجنتان مِن ورِق لأصحاب اليمين</b>»{26}. (١٤/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٣<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ أنه قال: «<b>هل تَدرُون ما الجنتان؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>هما بستانان في رَبَض الجنة، كل واحد منهما مسيرة خمسمائة عام، في وسط كلّ بستان دار في دار مِن نور على نور، ليس منهما بستان إلا يهتزّ بنعمة وخُضرة، قرارها ثابت، وفرعها ثابت، وشجرها نابت</b>»{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> هي أربع جنات: جنتان للسابقين، وهم أصحاب الأنبياء، وجنتان للتابعين{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَنَّتانِ﴾</span> يعني: جنة عَدن، وجنة النعيم، وهما للصِّدِّيقين والشهداء والمُقَرّبين والسابقين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span> جنتا السابقين. فقرأ: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> [الرحمن:٥٨]، ثم رجع إلى أصحاب اليمين، فقال: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> [الرحمن:٦٢] فذكر فَضلهما، وما فيهما{7}<span class=comment-ref>٦٣٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٦</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٢/٢٣٥) <span class="mustanad">مستندًا لأقوال السلف:</span> «يقول -تعالى ذكره-: ولمن اتقى الله من عباده، فخاف مقامه بين يديه، فأطاعه بأداء فرائضه، واجتناب معاصيه؛ جنتان، يعني: بُستانين، وبنحو الذي قلنا في ذلك قال أهل التأويل، وإن اختلفتْ ألفاظهم في البيان عن تأويله، غير أنّ معنى جميعهم يقول إلى هذا». وذكر أقوال السلف على هذا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٧٧) في قوله: «مَن» احتمالين، فقال: «»مَن«في قوله تعالى: <span class="qpc-hafs">﴿ولمن﴾</span> <b>يحتمل</b> أن تقع على جميع المتصفين بالخوف الزاجر عن معاصي الله تعالى، و<b>يحتمل</b> أن تقع لواحد منهم، وبحسب هذا قال بعض الناس في هذه الآية: إنّ كلّ خائف له جنتان. وقال بعضهم: إن جميع الخائفين لهم جنتان».</p><p>ونقل <u>ابنُ عطية</u> (٨/١٧٧) عن <b>قوم</b> قولهم: «أراد: جنة واحدة، وثنّى <span class="mustanad">على نحو قوله تعالى</span>: <span class="qpc-hafs">﴿ألْقِيا فِي جَهَنَّمَ كُلَّ كَفّارٍ عَنِيدٍ﴾</span> [ق:٢٤]، <span class="mustanad">وقول الحجاج</span>: يا غلام اضربا عنقه». و<span class="comment-type-2">انتقد</span> (٥/٢٣٣ دار الكتب العلمية) قولهم -<span class="mustanad">مستندًا إلى القرآن، وإلى اللغة-</span> قائلًا: «وهذا ضعيف؛ لأن معنى التثنية متوجّه، فلا وجه للفرار إلى هذه الشاذة، <span class="mustanad">ويؤيد التثنية قوله</span>: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> وهي تثنية»ذات«على الأصل؛ لأن أصل»ذات«: ذوات».</div></p><p><h3><span class="qpc-hafs">﴿جَنَّتَانِ ۝٤٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٣٧<span class="dash">-</span></span> عن أبي موسى الأشعري، أنّ رسول الله ﷺ قال: «<b>جنان الفردوس أربع: جنتان من ذهب حِلْيَتهما وآنِيتهما وما فيهما، وجنتان من فِضّة حِلْيَتهما وآنِيتهما وما فيهما، وما بين القوم وبين أن ينظروا إلى ربهم إلا رِداء الكبرياء على وجهه في جنة عَدن</b>»{31}. (١٤/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٣٨<span class="dash">-</span></span> عن الحسن البصري، قال: كان شابٌّ على عهد عمر بن الخطاب مُلازِم المسجد والعبادة، فعشِقَته جارية، فأتته في خُلْوة، فكلّمته، فحدّث نفسه بذلك، فشهِق شَهقة، فغُشي عليه، فجاء عمٌّ له إلى بيته، فلمّا أفاق، قال: يا عمّ، انطلِق إلى عمر، فأقرِئه مِنِّي السلام، وقل له: ما جزاء مَن خاف مقام ربّه؟ فانطلق عمّه، فأخبر عمر وقد شهِق الفتى شَهقة أخرى فمات منها، فوقف عليه عمر، فقال: لك جنتان، لك جنتان{32}. (١٤/١٣٨)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى (١١٤٩٧)، وابن خزيمة في كتاب التوحيد ٢/٨١٠-٨١١ كلاهما بنحوه، من طريق سعيد الجريري، عن موسى، عن محمد بن سعد بن أبي وقاص، عن أبي الدرداء به. وعزاه السيوطي إلى الطبراني، وابن مردويه.</p><p>وسنده ضعيف؛ موسى شيخ الجريري قال عنه ابن حجر في تقريب التهذيب (٧٠٢٨): «مجهول».</p><p>والقراءة المذكورة قراءة شاذة.|2:أخرجه أحمد ١٤/٣١١-٣١٢ (٨٦٨٣)، وابن جرير ٢٢/٢٣٧، من طريق محمد بن أبي حرملة، عن عطاء بن يسار، عن أبي الدّرداء به.</p><p>قال الذهبي في ميزان الاعتدال ٣/٧٧: «قال البخاري: هو مرسل». وقال العراقي في تخريج أحاديث الإحياء ص١٩٣٨: «إسناد صحيح». وقال الهيثمي في المجمع ٧/١١٨ (١١٣٩٠): «رجال أحمد رجال الصحيح». وقال ابن حجر في الفتح ١١/٢٦٧: «قد وقع التصريح بسماع عطاء بن يسار له من أبي الدّرداء».|3:عزاه السيوطي إلى ابن مردويه.|4:عزاه السيوطي إلى ابن مردويه.|5:أخرجه ابن جرير ٢٢/٢٣٨. وعزاه السيوطي إلى ابن المنذر.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٢/٢٣٩.|8:أخرجه ابن أبي شيبة ١٣/٣٨٣، والحاكم ١/٨٤، والبيهقي في البعث (٢٤٠-٢٤١). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.|9:أخرجه ابن جرير ٢٢/٢٣٥.|10:أخرجه ابن جرير ٢٢/٢٣٥.|11:أخرجه ابن جرير ٢٢/٢٣٦-٢٣٧.|12:أخرجه الفريابي -كما في تغليق التعليق ٤/٣٣١-، وعبد الرزاق ٢/٢٥٦، وابن جرير ٢٢/٢٣٥ بنحوه، وابن أبي شيبة ١٣/٥٧٠، وهناد (٨٩٩-٩٠٠)، وابن أبي الدنيا في التوبة (٥٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|13:أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٣٦، والبيهقي في شعب الإيمان (٧٣٨-٧٣٩). وعزاه السيوطي إلى عبد بن حميد، وابن أبي الدنيا.|14:تفسير البغوي ٧/٤٥١.|15:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٢-.|16:أخرجه ابن جرير ٢٢/٢٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|17:عزاه السيوطي إلى عبد بن حميد.|18:عزاه السيوطي إلى عبد بن حميد.|19:أخرجه ابن جرير ٢٢/٢٣٧.|20:عزاه السيوطي إلى ابن أبي حاتم.|21:عزاه السيوطي إلى ابن مردويه.|22:تفسير مقاتل بن سليمان ٤/٢٠٢.|23:أخرجه ابن جرير ٢٢/٢٣٩.|24:العَرْصَة: كلُّ موضِع واسع لا بناء فيه. النهاية (عرص).|25:عزاه السيوطي إلى ابن مردويه.|26:أخرجه ابن جرير ٢٢/٢٣٨، من طريق علي بن سهل، عن مؤمل، عن حماد بن سلمة، عن ثابت، عن أبي بردة بن أبي موسى، عن أبيه به.</p><p>قال ابن حجر في الفتح ١٣/٤٣١: «رجاله ثقات».|27:أورده مقاتل بن سليمان في تفسيره ٤/٢٠٢.|28:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.|29:تفسير مقاتل بن سليمان ٤/٢٠٢.|30:أخرجه ابن جرير ٢٢/٢٣٩.|31:أخرجه أحمد ٣٢/٥٠٥ (١٩٧٣١)، وابن جرير ١٥/٤٣٥، والثعلبي ٦/٢٠١-٢٠٢، من طريق أبي قدامة الحارث بن عبيد الإيادي، عن أبي عمران الجَوْني، عن أبي بكر بن عبد الله بن قيس، عن أبيه به.</p><p>قال الألباني في الضعيفة ٧/٤٦٥ (٣٤٦٥): «ضعيف».|32:أخرجه البيهقي في شعب الإيمان (٧٣٦).
  55,46,""
  55,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَوَاتَاۤ أَفۡنَانࣲ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، قال: ذَواتا ألوان{1}. (١٤/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> غُصونهما يمسّ بعضها بعضًا{2}. (١٤/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> الفَنن: الغُصن{3}. (١٤/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، مثله{4}. (١٤/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي سنان-، مثله{5}. (١٤/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل من أهل البصرة- قال: ذَواتا أغصان{6}. (١٤/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان- <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، قال: ألوان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> ألوان مِن الفواكه{7}. (١٤/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عبد الله بن النّعمان- في قول الله: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، قال: ظِلّ الأغصان على الحيطان، أما سمعت قول الشاعر:</p><p>ما هاج شَوقك من هَديل حمامة تدعو على فَنَن الغُصون حماما</p><p>تدعو أبا فَرْخَين صادف طاويًا ذا مِخلبين من الصّقور قَطاما؟{9}. (١٤/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> أغصان؛ يعني: ظِلال الشجر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span>، قال: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> في كلّ غُصن فنون من الفاكهة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، قال: ذَواتا فَضلٍ على ما سواهما{12}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، قال: يعني: فَضلهما وسعتهما على ما سواهما{6}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿ذواتا أفنان﴾</span>، قال: ألوان{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> أفنان: أغصان، واحدها فَنن، وهو الغُصن المستقيم طولًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نَعتَ الجنتين، فقال: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> يعني: ذَواتا أغصان يتماسّ أطراف شجرها بعضه بعضًا كالمعروشات{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٥<span class="dash">-</span></span> عن <span class="name-3">أبي سنان [سعيد بن سنان البرجمي]</span> -من طريق مهران- <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، قال: ذواتا ألوان{7}<span class=comment-ref>٦٣٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٧</span> اختُلف في قوله: <span class="qpc-hafs">﴿ذواتا أفنان﴾</span> على أقوال: <b>الأول</b>: ذواتا ألوان. <b>الثاني</b>: ذواتا أغصان. <b>الثالث</b>: ذواتا أطراف أغصان الشجر. <b>الرابع</b>: عنى بذلك: فضلهما وسعتهما على ما سواهما.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٢٣٣) على القول الأول، فقال: «و<b>يحتمل</b> أن يكون جمع فَن، وهو قول ابن عباس، فكأنه مدحها بكثرة أنواع فواكهها ونعيمها». و<span class="comment-type-4">علّق</span> على القول الثاني، فقال: «والأفنان <b>يحتمل</b> أن يكون جمع فَنن، وهو فَنن الغصن، وهذا قول مجاهد، فكأنه مدحها بظلالها وتكاثف أغصانها».</p><p>وقد <span class="comment-type-4">بين</span> <u>ابنُ جرير</u> أنّ <span class="qpc-hafs">﴿ذواتا أفنان﴾</span> معناه: «ذواتا ألوان». <span class="mustanad">ودلّل على ذلك بأقوال السلف</span>، ثم ذكر بقية هذه الأقوال ولم يعلق عليها.</p><p>وذكر <u>ابنُ كثير</u> (١٣/٣٣٢) عبارات السلف في هذا، ثم <span class="comment-type-4">علّق</span> قائلًا: «وكل هذه الأقوال صحيحة، ولا منافاة بينها».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٢٣٩-٢٤٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٢/٢٤١ بنحوه. وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه هناد في الزهد (٤٣).|6:أخرجه ابن جرير ٢٢/٢٤١.|7:أخرجه ابن جرير ٢٢/٢٤٠.|8:أخرجه ابن جرير ٢٢/٢٤٠.|9:أخرجه ابن جرير ٢٢/٢٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي بكر بن حيان في الغرر، وابن الأنباري في الوقف والابتداء.|10:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.|11:تفسير البغوي ٧/٤٥٢.|12:أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٤١ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|13:أخرجه ابن جرير ٢٢/٢٤١.|14:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.|15:تفسير البغوي ٧/٤٥٢.|16:تفسير مقاتل بن سليمان ٤/٢٠٣.|17:أخرجه ابن جرير ٢٢/٢٤٠.
  55,48,""
  55,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا عَیۡنَانِ تَجۡرِیَانِ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٥٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إنّ الله اختار مِن الملائكة أربعة: جبريل، وميكائيل، وإسرافيل، وعزرائيل</b>». وذكر الحديث حتى قال: «<b>واختار من العيون أربعة، يقول في محكم كتابه: <span class="qpc-hafs">﴿فيهما عينان تجريان﴾</span>، وقال: <span class="qpc-hafs">﴿فيهما عينان نضاختان﴾</span></b> [الرحمن:٦٦]، <b>فأما التي تجريان: فعين بَيْسان، وعين سُلْوان، وأما النَّضّاختان: فعين زمزم، وعين عَكا</b> ...»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: تَجْريان بالزيادة والكرامة مِن الله تعالى على أهل الجنة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: تجريان بالماء الزّلال، إحداهما التّسنيم، والأخرى السّلسبيل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٥٩<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العَوفيّ</span>: إحداهما من ماء غير آسِن، والأخرى من خمرٍ لذّةٍ للشاربين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِما عَيْنانِ تَجْرِيانِ﴾</span> في [غير]{5}] أخدود، من ماء غير آسِن{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخه ١/٢٢١-٢٢٢، من طريق أبي الفضل العباس بن ميمون، عن أبي محمد المراغي، عن قتيبة، عن أبي عوانة، عن الأعمش، عن أبي صالح، عن أبي هريرة به.</p><p>قال ابن عساكر: «هذا حديث منكر بمرّة، وأبو الفضل والمراغي مجهولان». وأورده الكناني في تنزيه الشريعة ٢/٦٥.|2:تفسير الثعلبي ٩/١٨٩، وتفسير البغوي ٧/٤٥٢.|3:تفسير الثعلبي ٩/١٨٩، وتفسير البغوي ٧/٤٥٢.|4:تفسير الثعلبي ٩/١٩٠، وتفسير البغوي ٧/٤٥٢.|5:[في المطبوع: عين.|6:تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,50,""
  55,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا مِن كُلِّ فَـٰكِهَةࣲ زَوۡجَانِ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق أبي الهُذيل- قال: العنقود أبعد من صنعاء{1}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span> فما في الدنيا ثمرة حُلوة ولا مُرّة إلا وهي في الجنة، حتى الحَنظل{2}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span>، قال: فيهما من كلّ الثمرات{3}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ﴾</span> مِن كلّ لون من ألوان الفاكهة <span class="qpc-hafs">﴿زَوْجانِ﴾</span> يعني: صِنفان{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٣/٩٧.|2:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقد أخرج ابن أبي حاتم ٢/٥٢٣ نحوه عن عكرمة من طريق الحكم بن أبان، في تفسير قوله تعالى: <span class="qpc-hafs">﴿لَهُ فِيها مِن كُلِّ الثَّمَراتِ﴾</span> [البقرة:٢٦٦].|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,52,""
  55,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٦٥<span class="dash">-</span></span> عن الضَّحّاك، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (مُتَّكِئِينَ عَلى سُرُرٍ وفُرُشٍ بَطَآئِنُها مِن رَّفْرَفٍ مِّنْ إسْتَبْرَقٍ){1}. (١٤/١٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُتَّكِـِٔینَ عَلَىٰ فُرُشِۭ بَطَاۤىِٕنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق هُبَيرة بن يَرِيم- <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span>، قال: أُخبرتم بالبَطائن، فكيف بالظّهائر؟!{2}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٧<span class="dash">-</span></span> قال <span class="name-1">أبو هريرة</span>: <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span> هذه البَطائن، فما ظنّكم بالظّواهر؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنه قيل له: <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span>، فما الظواهر؟ قال: ذاك مما قال الله: <span class="qpc-hafs">﴿فَلا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ﴾</span> [السجدة:١٧]{4}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٦٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>-من طريق جعفر- أنه قيل له: البَطائن مِن إسْتَبرق، فما الظواهر؟ قال: هذا مما قال الله سبحانه: <span class="qpc-hafs">﴿فَلا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ﴾</span> [السجدة:١٧]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span>، قال: ظواهرها من نور جامد{6}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿بطائنها من إستبرق﴾</span>، قال: الديباج. وفي لفظ: والإسْتَبرق لغة فارس، يُسمُّون الدِّيباج الغليظ: الإسْتَبرق{7}. (١٤/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق قتادة- <span class="qpc-hafs">﴿مِن إسْتَبْرَقٍ﴾</span>، قال: الدِّيباج الغليظ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿بَطائِنُها مِن إسْتَبْرَقٍ﴾</span> بَطائنها يعني: ما يلي جلودهم، والإسْتَبرق: الصّفيق من الدِّيباج{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿مِن إسْتَبْرَقٍ﴾</span>، قال: هو غليظ الدِّيباج{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٥<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي إسحاق</span>، قال: قال لي سالم بن عبد الله: ما الإسْتَبرق؟ قال: قلتُ: ما غلُظ من الديباج وخشُن منه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى فُرُشٍ بَطائِنُها مِن إسْتَبْرَقٍ﴾</span> يعني: ظاهرها من الدِّيباج الأخضر، فوق الفُرُش الدِّيباج، وهي بلغة فارس، نظيرها في آخر السورة: <span class="qpc-hafs">﴿مُتَّكِئِينَ عَلى رَفْرَفٍ خُضْرٍ﴾</span> يعني: المحابس الخُضر على الفُرُش{12}<span class=comment-ref>٦٣٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٨</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٢/٢٤٢-٢٤٤) أن قوله: <span class="qpc-hafs">﴿بطائنها من إستبرق﴾</span> معناه: أنّ بطائن هذه الفُرُش من غليظ الدِّيباج، <span class="mustanad">ودلّل على ذلك بآثار السلف</span>. ثم أورد عن بعض أهل اللغة -وهو موافق لما جاء في قول مقاتل، وقول سعيد بن جُبَير في الأثر في تفسير الآية- أنّ البطائن هاهنا بمعنى: الظواهر. و<span class="comment-type-1">وجّهه</span>، فقال: «وقد زعم أهل العربية أنّ البطانة قد تكون ظهارة، والظهارة تكون بطانة، وذلك أنّ كل واحد منهما قد يكون وجهًا، قال: وتقول العرب: هذا ظهر السماء، وهذا بطن السماء لظاهرها الذي نراه».</div></p><p><h3><span class="qpc-hafs">﴿وَجَنَى ٱلۡجَنَّتَیۡنِ دَانࣲ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٧٧<span class="dash">-</span></span> عن علي بن أبي طالب، أن رسول الله ﷺ قال: «<b>... وفيها ثمار متدلّية، إذا اشتَهَوها انشَعب الغُصن إليهم، فيأكلون مِن أيّ الثمار اشتَهوا؛ إن شاء قائمًا، وإن شاء مُتكئًا، وذلك قول الله ﷿: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span>...</b>»{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span>، قال: جَناها: ثمرها، والداني: القريب منك، يناله القائم والقاعد{14}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span> ما يُجتنى من قريب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span>، قال: دانٍ ثمارها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span> ثمارها دانية، لا يرُدّ أيديهم عنها بُعدٌ ولا شوك. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «<b>والذي نفس محمد بيده، لا يَقْطِف رجلٌ ثمرة من الجنة فتَصل إلى فِيه، حتى يُبدّل الله مكانها خيرًا منها</b>»{17}. (١٤/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وجَنى الجَنَّتَيْنِ دانٍ﴾</span> يعني: ثمره، وجنى الشجر في الجنتين دانٍ. يقول: ما يُجتنى في الجنتين دانٍ. يقول: طول الشجر لهذا المجتني قريب، يتناوله الرجل إن شاء جالسًا، وإن شاء متكئًا أو قائمًا{12}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة. انظر: روح المعاني ٢٧/١١٨.|2:أخرجه ابن جرير ٢٢/٢٤٣ بنحوه، والحاكم ٢/٤٧٥، والبيهقي في البعث (٣٣٩)، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٥)-. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وعبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم، وابن مردويه.|3:تفسير الثعلبي ٩/١٩٠، وتفسير البغوي ٧/٤٥٣.|4:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.|5:أخرجه ابن جرير ٢٢/٢٤٤.|6:أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٦)-، وأبو نعيم في الحلية ٤/٢٨٥-٢٨٦.|7:أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٥٢ (١٥٧)-. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٢/٢٤٣.|9:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٣٣-.|10:أخرجه ابن جرير ٢٢/٢٤٣.|11:أخرجه ابن جرير ٢٢/٢٤٣.|12:تفسير مقاتل بن سليمان ٤/٢٠٣.|13:أخرجه ابن أبي الدنيا في صفة الجنة ص٣٥-٣٧ (٦) مطولًا، من طريق محمد بن عباد بن موسى العكلي، عن الضَّحّاك بن مُزاحِم، عن الحارث، عن علي به.</p><p>وسنده ضعيف؛ فيه الحارث بن عبد الله الأعور، قال عنه ابن حجر في تقريب التهذيب (١٠٢٩): «في حديثه ضعف».|14:أخرجه ابن جرير ٢٢/٢٤٥ بلفظ: ثمارها دانية، والبيهقي في البعث (٣٠٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|15:أخرجه ابن جرير -كما في الفتح ٦/٣٢٣-.|16:أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٤٥ (١١٦)-.|17:أخرجه ابن جرير ٢٢/٢٤٤. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه عبد الرزاق ٢/٢٦٥ من طريق معمر مختصرًا.|18:تفسير مقاتل بن سليمان ٤/٢٠٣.
  55,54,""
  55,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِنَّ قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٨٣<span class="dash">-</span></span> عن علي بن حُسين، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span>، قال: «<b>لا يَنظُرْنَ إلّا إلى أزواجهنّ</b>»{1}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span>، يقول: مِن غير أزواجهنّ{2}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> قَصَرن طَرْفهنّ عن الرجال؛ فلا يَنظُرن إلا إلى أزواجهنّ{3}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> قاصرات الطّرف على أزواجهنّ، لا يُردْن غيرهم، واللهِ، ما هُنَّ متبرّجاتٍ ولا مُتطلِّعات{4}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{5}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِنَّ﴾</span> يعني: في هذه الجنان الأربع -في التقديم-: جنة عَدن، وجنة النعيم، وجنة الفِردَوس، وجنة المأوى، ففي هذه الجنان الأربع جنان كثيرة، في الكثرة مثل ورق الشجر ونجوم السماء، يقول: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> يعني: النساء{6}<span class=comment-ref>٦٣٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٩٩</span> ذكر <u>ابنُ عطية</u> (٨/١٧٩) أنّ «الضمير في قوله تعالى: <span class="qpc-hafs">﴿فِيهِنَّ﴾</span> للفُرُش». ثم نقل <b>احتمالًا</b> آخر فقال: «وقيل: للجنات؛ إذ الجنتان جنات في المعنى».</div></p><p><div></p><p><p><span class="item-no">٧٤٤٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿فِيهِنَّ قاصِراتُ الطَّرْفِ﴾</span> لا يَنظُرن إلا إلى أزواجهنّ، تقول: وعزّة ربي وجلاله وجماله، إنْ أرى في الجنة شيئًا أحسن منك، فالحمد لله الذي جعلك زوجي، وجعلني زوجك{7}<span class=comment-ref>٦٤٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٠</span> أفادت آثار السلف أنّ قوله: <span class="qpc-hafs">﴿قاصرات الطرف﴾</span> أي: على أزواجهنَّ، فلا يُرِدْنَ غيرهم.</p><p>وقد ذكر <u>ابنُ القيم</u> (٣/٩٩) هذا، وأضاف <b>قولًا آخر</b>، فقال: «وقيل: قَصرن طرف أزواجهنّ عليهن، فلا يدعهم حُسنهنّ وجمالهن أن ينظروا إلى غيرهن». و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا صحيح من جهة المعنى، وأما <span class="mustanad">من جهة اللفظ</span>: فـ<span class="qpc-hafs">﴿قاصرات﴾</span> صفة مضافة إلى الفاعل الحِسان الوجوه، وأصله: قاصر طرفهن، أي: ليس بطامح مُتعدّ».</div></p><p><h3><span class="qpc-hafs">﴿لَمۡ یَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمۡ وَلَا جَاۤنࣱّ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٤٩٠<span class="dash">-</span></span> عن عِياض بن غَنْم، أنه سمع رسول الله ﷺ تلا: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: «<b>لم يُصِبْهُنَّ شمسٌ ولا دُخان، لم يُعَذَّبْنَ في البلايا، ولم يُكْلَمْنَ في الرّزايا، ولم تغيّرهن الأحزان، ناعمات لا يبأسن، وخالدات فلا يمُتن، ومُقيمات فلا يَظعنَّ، لهنّ أخبار يَعجِز عن نعتهنّ الأوهام، والجنة أخضرها كالأصفر، وأصفرها كالأخضر، ليس فيها حَجرٌ ولا مَدرٌ ولا كَدرٌ، ولا عود يابس، أُكُلها دائم، وظِلّها قائم</b>»{1}. (١٤/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩١<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق رجل- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: منذ خَلقهنّ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>، قال: لم يَدنُ منهنّ، أو لم يُدْمِهنّ{10}. (١٤/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>. قال: كذلك نساء الجنة، لم يَدنُ منهن غير أزواجهنّ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول:</p><p>مَشين إليَّ لم يُطْمثن قبلي وهنّ أصحّ من بَيْض النّعام؟{11}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق عاصم- أنه قال له: امرأة طامث. قال: ما طامث؟ فقال رجلٌ: حائض. فقال أبو العالية: حائض؟! أليس يقول الله ﷿: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span> لم يَطأهنّ{13}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>، قال: لم يَمسّهن{14}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من عثمان بن الأسود- قال: إذا جامع الرجلُ أهلَه ولم يُسَمِّ، انطوى الجانُّ على إحليله، فجامع معه، فذلك قوله: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>{15}. (١٤/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>، قال: هنّ مِن نساء أهل الدنيا، خَلقهنّ اللهُ في الخلْق الآخر، كما قال: <span class="qpc-hafs">﴿إنّا أنْشَأْناهُنَّ إنْشاءً * فَجَعَلْناهُنَّ أبْكارًا﴾</span> [الواقعة:٣٥-٣٦] لم يَطْمثهن حين عُدْنَ في الخلْق الآخر إنس قبلهم ولا جان{16}. (١٤/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٤٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق مُغيرة- قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>لم يُجامعهنّ{17}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق مُغيرة- قال: لا تقُلِ المرأة: إني طامث؛ فإن الطّمث هو الجماع، وإنّ الله -جل ثناؤه- يقول: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>{18}. (١٤/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠١<span class="dash">-</span></span> عن أرطاة بن المنذر، قال: تَذاكرنا عند <span class="name-2">ضمرة بن حبيب</span>: أيدخل الجنُّ الجنةَ؟ قال: نعم؛ وتصديق ذلك في كتاب الله: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span> للجنّ الجنّيات، وللإنس الإنسيّات{19}<span class=comment-ref>٦٤٠١</span>. (١٤/١٤٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠١</span> اختلف السلف في قوله: <span class="qpc-hafs">﴿لم يطمثهن إنس قبلهم ولا جان﴾</span> على قولين: <b>الأول</b>: أنّ الجنّ قد تجامع نساء البشر مع أزواجهن، إذا لم يذكر الزوج الله تعالى. <b>الثاني</b>: أنّ الجنّ لهم قاصرات الطرف من الجنّ نوعهم.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٧٩) القول الأول بقوله: «فتكون الآية على هذا نافية لجميع المجامعات». و<span class="comment-type-1">وجَّه</span> القول الثاني بقوله: «فنفى في هذه الآية الافتضاض عن البشريّات والجنِّيّات». ثم بيّن احتمال الآية <b>وجهًا آخر</b>، فقال: «ويحتمل اللفظ أن يكون مبالغة وتأكيدًا، كأنه قال: لم يطمثهنّ شيء. أراد العموم التام، لكنه صرح من ذلك بالذي يعقل منه أن يَطمث».</p><p>ولم يذكر <u>ابنُ جرير</u> (٢٢/٢٤٧-٢٤٨) في معناه غير ما ورد في قول أرطاة وما في معناه.</div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿لم يطمثهن إنس قبلهم ولا جان﴾</span>، قال: لم يضاجعهم إنسٌ قبلهم، ولا جانٌّ{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span> هنّ مِن نساء الدنيا، لم يُمْسَسْنَ منذ أُنشِئن خلقًا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span> لأنهنّ خُلِقن في الجنة مع شجر الجنة، يعني: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ﴾</span> إنس قبل أهل الجنة، <span class="qpc-hafs">﴿ولا جانٌّ﴾</span> يعني: جنّ،... <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span> لم يُدميهنّ{22}<span class=comment-ref>٦٤٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٢</span> للسلف في الموصوف بهذه الصفات قولان: <b>الأول</b>: أنهن الحور العين اللواتي أُنشئن في الجنة. <b>الثاني</b>: أنهن من نساء الدنيا.</p><p>وقد ذكر <u>ابنُ القيم</u> (٣/١٠٠-١٠١) القولين، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">-مستندًا إلى ظاهر القرآن، وإلى السياق</span>- الأول، فقال: «ظاهر القرآن أنّ هؤلاء النسوة لسنَ من نساء الدنيا، وإنما هنّ من الحُور حور العين. وأما نساء الدنيا فقد طَمثهن الإنس، ونساء الجنّ قد طَمثهن الجنّ، والآية تدل على ذلك. ويدل على أنهن الحور اللاتي خُلقن في الجنة أنه سبحانه جعلهنّ مما أعده الله في الجنة لأهلها مِن الفاكهة والثمار والأنهار والملابس وغيرها، ويدل عليه أيضًا الآية التي بعدها، وهي قوله تعالى: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>، ثم قال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنس قَبْلَهُمْ ولا جانٌّ﴾</span>».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن أبي شيبة ١٣/١٣٠، وابن جرير ٢٢/٢٤٥. وعزاه السيوطي إلى عبد بن حميد. وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٤- بلفظ: لا يبغين غير أزواجهن.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٢/٢٤٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|6:تفسير مقاتل بن سليمان ٤/٢٠٣.|7:أخرجه ابن جرير ٢٢/٢٤٦.|8:عزاه السيوطي إلى ابن مردويه.|9:أخرجه ابن جرير ٢٢/٢٤٧.|10:أخرجه ابن جرير ٢٢/٢٤٧، والبيهقي في البعث (٣٧٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|11:أخرجه الطستي (٢٥٩).|12:أخرجه ابن جرير ٢٢/٢٤٧-٢٤٨.|13:أخرجه ابن أبي شيبة ١٣/١٣١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|14:أخرجه ابن جرير ٢٢/٢٤٧. وعزاه السيوطي إلى عبد بن حميد.|15:أخرجه ابن جرير ٢٢/٢٤٨، والحكيم الترمذي في نوادر الأصول ١/٣٨٤.|16:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|17:أخرجه ابن أبي شيبة ١٣/١٣١. وعزاه السيوطي إلى ابن المنذر.|18:أخرجه ابن جرير ٢٢/٢٤٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن جرير ٢٢/٢٤٨ بنحوه، وأبو الشيخ في العظمة (١١٦٢). وعزاه السيوطي إلى ابن المنذر.|20:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٤.|21:تفسير البغوي ٧/٤٥٤.|22:تفسير مقاتل بن سليمان ٤/٢٠٣-٢٠٤.
  55,56,""
  55,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَنَّهُنَّ ٱلۡیَاقُوتُ وَٱلۡمَرۡجَانُ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٠٥<span class="dash">-</span></span> عن عبد الله بن مسعود، عن النبيِّ ﷺ، قال: «<b>إنّ المرأة من نساء أهل الجنة لَيُرى بياضُ ساقها مِن وراء سبعين حُلّة حتى يُرى مُخّها، وذلك أنّ الله يقول: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span>، فأما الياقوت فإنّه حَجرٌ، لو أدخَلتَ فيه سلكًا ثم استَصفيتَه لرأيتَه من ورائه</b>»{1}. (١٤/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٦<span class="dash">-</span></span> عن أبي سعيد الخُدري، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span>، قال: «<b>يَنظر إلى وجهها في خدّها أصفى مِن المرآة، وإنّ أدنى لؤلؤة عليها لَتُضيء ما بين المشرق والمغرب، وإنّه يكون عليها سبعون ثوبًا يَنفُذها بصره، حتى يَرى مُخّ ساقها من وراء ذلك</b>»{2}. (١٤/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٧<span class="dash">-</span></span> عن عمرو بن ميمون، قال: أخبرنا <span class="name-1">عبد الله [بن مسعود]</span>: أن المرأة من أهل الجنة لَتلبس سبعين حُلَّةً مِن حرير، فيرى بياض ساقها وحسنه ومخ ساقها مِن وراء ذلك، وذلك لأنّ الله قال: <span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span>، ألا ترى أنّ الياقوت حجرٌ، فإذا أدخلتَ فيه سلكًا رأيت السلك من وراء الحجر!{3}. (١٤/١٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن الحارث الهاشميّ</span> -من طريق الحر- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> كأنهن اللؤلؤ في الخيط{4}. (١٤/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سليمان أبي عبيد الله- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> يُرى مخّ سُوقهنّ مِن وراء الثياب؛ كما يُرى الخيط في الياقوتة{5}. (١٤/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> ألوانهن كالياقوت واللؤلؤ في صفائه{6}. (١٤/١٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> صفاء الياقوت في بياض المرجان{7}. (١٤/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> أو <span class="name-2">السُّدِّيّ</span> -من طريق ابن أبي خالد- في قوله: <span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span>، قال: بياض اللؤلؤ، وصفاء الياقوت{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> في صفاء الياقوت، وبياض اللؤلؤ{9}. (١٤/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> صفاء الياقوت في بياض المرجان. ذُكر لنا: أنّ نبي الله ﷺ قال: «<b>مَن دخل الجنة فله فيها زوجتان؛ يُرى مخُّ سُوقهما مِن وراء ثيابهما</b>»{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق المطلب- <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span>، قال: صفاء الياقوت، وحُسن المرجان{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَأَنَّهُنَّ﴾</span> في الشّبه في صفاء <span class="qpc-hafs">﴿الياقُوتُ﴾</span> الأحمر، <span class="qpc-hafs">﴿و﴾</span> في بياض <span class="qpc-hafs">﴿المَرْجانُ﴾</span> يعني: الدُّرّ العظام{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span> كأنهن الياقوت في الصفاء، والمرجان في البياض؛ الصفاء صفاء الياقوتة، والبياض بياض اللؤلؤ{11}<span class=comment-ref>٦٤٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٣</span> ذكر <u>ابنُ كثير</u> (١٣/٣٣٤) قول ابن زيد، ومثله عن بعض السلف، و<span class="comment-type-1">وجّهه</span>، فقال: «قوله: <span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span>، قال مجاهد، والحسن، والسُّدِّيّ، وابن زيد، وغيرهم: في صفاء الياقوت، وبياض المرجان، فجعلوا المرجان هاهنا اللؤلؤ».</div></p><p><div></p><p><p><span class="item-no">٧٤٥١٨<span class="dash">-</span></span> عن إسحاق بن عبد الله، قال: بلَغني: أنه يقول -يعني: الولي- في الجنة: أشتهي العين. فيُقال له: أفإنهنّ حور عين. فيقول: أشتهي البياض. فيقال: إنهنّ كأنهنّ بيضٌ مكنون. فيقول: أخشى أن يكون في وجهها كَلف. فيقال له: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span>. فيقول: أخشى أن تكون خفيفة. فيقال له: <span class="qpc-hafs">﴿حُورٌ مَقْصُوراتٌ فِي الخِيامِ﴾</span>. فيقول: إني غيور. فيقال: <span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ إنْسٌ قَبْلَهُمْ ولا جانٌّ﴾</span>. قال: قال ابن عباس: تسنيم، وماء التسنيم يشربها المُقرّبون صرفًا، وتُمزج لأصحاب اليمين{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَأَنَّهُنَّ ٱلۡیَاقُوتُ وَٱلۡمَرۡجَانُ ۝٥٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٥١٩<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>أول زُمرة تدخل الجنة على صورة القمر ليلة البدر، والذين على إثرهم كأشد كوكب إضاءة، قلوبهم على قلب رجل واحد، لا اختلاف بينهم ولا تباغض، لكل امرئ منهم زوجتان، كل واحدة منهما يرى مخ ساقها مِن وراء لحمها مِن الحُسْن، يُسبِّحون اللهَ بُكرةً وعشيًّا، لا يسقمون، ولا يمتخطون، ولا يبصقون، آنيتهم الذهب والفضة، وأمشاطهم الذهب، ووقود مجامرهم الأَلَوَّة -</b>قال أبو اليمان: يعني: العود<b>-، ورشْحُهم المِسْك</b>»{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عمرو بن ميمون- قال: إنّ المرأة مِن الحُور العين لَيُرى مُخُّ ساقها مِن وراء اللحم والعظم، مِن تحت سبعين حُلَّة، كما يُرى الشراب الأحمر في الزجاجة البيضاء{16}. (١٤/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢١<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون الأَوْدي</span> -من طريق أبي إسحاق-، مثله{17}. (١٤/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الحارث القَيسيّ</span>، قال: إنّه يكون على زوجة الرجل مِن أهل الجنة سبعون حُلّة حمراء، يُرى مُخُّ ساقها مِن خلفهنّ{18}. (١٤/١٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٣<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، قال: إنّ المرأة مِن أزواج المُقرّبين لَتُكسى مائة حُلّة مِن إسْتَبرق وسِقالَة النور، وإنّ مُخّ ساقها لَيُرى مِن وراء ذلك كلّه، وإنّ المرأة مِن أزواج أصحاب اليمين لَتُكسى سبعين حُلّة مِن إسْتَبرق وسِقالة النور، وإنّ مُخّ ذلك لَيُرى مِن وراء ذلك كلّه{18}. (١٤/١٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٤<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، قال: إنّ المرأة مِن الحور العين لَتلبس سبعين حُلّة، لَهي أرقُّ مِن شَفِّكُم{20} هذا الذي تُسمّونه شَفًّا، وإنّ مُخ ساقها ليُرى من وراء اللحم{18}. (١٤/١٤٨)</p></p><p></div></p></div>",footnotes:1:أخرجه الترمذي ٤/٥٠٢ (٢٧٠٥، ٢٧٠٦)، وابن حبان ١٦/٤٠٨ (٧٣٩٦)، وابن جرير ٢٢/٢٤٩، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٠٤-، من طريق عبيدة بن حميد، عن عطاء بن السّائِب، عن عمرو بن ميمون، عن عبد الله بن مسعود به.</p><p>قال الترمذي: «حدثنا أبو الأحوص، عن عطاء بن السّائِب، عن عمرو بن ميمون، عن عبد الله بن مسعود، نحوه بمعناه ولم يرفعه، وهذا أصح من حديث عبيدة بن حميد، وهكذا روى جرير وغير واحد عن عطاء بن السّائِب ولم يرفعوه».|2:أخرجه أحمد ١٨/٢٤٣-٢٤٤ (١١٧١٥)، وابن حبان ١٦/٤٠٩-٤١٠ (٧٣٩٧)، والحاكم ٢/٥١٦ (٣٧٧٤) واللفظ له، وابن جرير ٢١/٤٥٩، من طريق درّاج، عن أبي الهيثم، عن أبي سعيد الخدري به.</p><p>قال الحاكم: «صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «درّاج صاحب عجائب». وقال العراقي في تخريج أحاديث الإحياء ص١٩٣٠: «إسناد حسن، ورواه أحمد، وفيه ابن لهيعة». وقال الهيثمي في المجمع ١٠/٤١٩ (١٨٧٦٢): «رواه أحمد، وأبو يعلى، وإسنادهما حسن».|3:أخرجه الترمذي ٤/٥٠٢ (٢٧٠٥)، وابن أبي شيبة ١٣/١٠٧، وهناد (١٠)، وابن جرير ٢٢/٢٥٠ واللفظ له. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن أبي شيبة ١٣/١٣٠.|5:أخرجه ابن أبي شيبة ١٣/١٣٠-١٣١.|6:أخرجه ابن أبي شيبة ١٣/١٣٠، وهناد (١٨). وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٢/٢٥٠ دون جملة: صفاء الياقوت. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.|8:أخرجه ابن المبارك في الزهد ١/٤٨٧.|9:أخرجه عبد الرزاق ٢/٢٦٥، وابن جرير ٢٢/٢٥١. وعزاه السيوطي إلى عبد بن حميد.|10:أخرجه ابن جرير ٢٢/٢٥١، وبنحوه من طريق أبي العوام.|11:أخرجه ابن جرير ٢٢/٢٥١.|12:تفسير مقاتل بن سليمان ٤/٢٠٤.|13:أخرجه ابن جرير ٢٢/٢٥١.|14:أخرجه ابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٩٢-٣٩٣ (٣٤٧)-.|15:أخرجه البخاري ٤/١١٨ (٣٢٤٥، ٣٢٤٦)، ٤/١١٩ (٣٢٥٤)، ٤/١٣٢ (٣٣٢٧)، ومسلم ٤/٢١٧٩-٢١٨٠ (٢٨٣٤)، وعبد الرزاق ٢/٣٣٣ (١٦٨٢).|16:أخرجه الطبراني (٨٨٦٤)، والبيهقي في البعث (٣٢٩). وعزاه السيوطي إلى عبد بن حميد.|17:أخرجه هناد في الزهد (١٢)، وابن جرير ٢٢/٢٥٠.|18:عزاه السيوطي إلى عبد بن حميد.|19:عزاه السيوطي إلى عبد بن حميد.|20:الشَّفُّ والشِّفُّ: الثوب الرقيق. لسان العرب (شفف).|21:عزاه السيوطي إلى عبد بن حميد.
  55,58,""
  55,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ جَزَاۤءُ ٱلۡإِحۡسَـٰنِ إِلَّا ٱلۡإِحۡسَـٰنُ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٢٥<span class="dash">-</span></span> عن علي بن أبي طالب، في قوله: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: قال رسول الله ﷺ: «<b>قال الله ﷿: هل جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة</b>»{1}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>أنزل اللهُ عَلَيَّ هذه الآية مُسجَلة</b>{2} <b>في سورة الرحمن للكافر والمسلم: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span></b>»{3}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٧<span class="dash">-</span></span> عن عبد الله بن عباس، في قوله: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال رسول الله ﷺ: «<b>هل جزاء مَن قال: لا إله إلا الله في الدنيا إلا الجنة في الآخرة؟!</b>»{4}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٨<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ في قوله: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> قال: «<b>ما جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة</b>»{5}. (١٤/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٢٩<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ في هذه الآية: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> قال: «<b>هل جزاء مَن أنعمنا عليه بالإسلام إلا أن أُدخله الجنة؟!</b>»{6}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٠<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، وقال: «<b>هل تدرون ما قال ربكم؟</b>». قالوا: الله ورسوله أعلم. قال: «<b>يقول: هل جزاء مَن أنعمتُ عليه بالتوحيد إلا الجنة</b>»{7}. (١٤/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: نَزَلَتْ هذه الآيةُ في المسلم والكافر: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>{6}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: إنّ لله عمودًا أحمر، رأسه مَلويٌّ على قائمة مِن قوائم العرش، وأسفله تحت الأرض السابعة على ظَهْر الحُوت، فإذا قال العبد: لا إله إلا الله. تحرّك الحوت؛ تحرّك العمود؛ تحرّك العرش؛ فيقول الله للعرش: اسكُن. فيقول: لا، وعزّتك، لا أسكُن حتى تغفر لقائلها ما أصاب قبلها من ذنبٍ. فيَغفر الله له{9}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن الحنَفيّة</span> -من طريق أبي يعلى- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: هي مُسجَلة للبَرِّ والفاجر{10}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله ﷿: <span class="qpc-hafs">﴿هل جزاء الإحسان إلا الإحسان﴾</span>، قال: هل جزاء لا إله إلا الله إلاّ الجنة؟!{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: هل جزاء مَن قال: لا إله إلا الله؛ إلا الجنة؟!{12}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، مثله{12}. (١٤/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> هي مُسجَلة للبَرِّ والفاجر؛ للفاجر في دنياه، وللبَرّ في آخرته{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: عمِلوا خيرًا فجُوزوا خيرًا{15}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٣٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن المُنكَدِر</span> -من طريق محمد بن جابر اليمامي- <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، قال: هل جزاء مَن أنعمتُ عليه بالإسلام إلّا الجنّة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ﴾</span> في الدنيا <span class="qpc-hafs">﴿إلّا الإحْسانُ﴾</span> في الآخرة، يعني: هل جزاء أهل التوحيد في الآخرة إلا الجنة؟!{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> ألا تراه ذَكرهم ومنازلهم وأزواجهم، والأنهار التي أعدّها لهم، وقال: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span> حين أحسَنوا في هذه الدنيا أحسَنّا إليهم؛ أدخلناهم الجنة{18}<span class=comment-ref>٦٤٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٤</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (٢٢/٢٥٢): «وقوله: <span class="qpc-hafs">﴿هل جزاء الإحسان إلا الإحسان﴾</span> يقول -تعالى ذِكْرُه-: هل ثواب خَوف مقام الله ﷿ لِمَن خافه فأحسن في الدنيا عمله، وأطاع ربّه، إلا أن يُحسن إليه في الآخرة ربُّه، بأن يجازيه على إحسانه ذلك في الدنيا ما وصف في هذه الآيات من قوله: <span class="qpc-hafs">﴿ولمن خاف مقام ربه جنتان﴾</span> إلى قوله: <span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span>، <span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span>، وإن اختلفت ألفاظهم بالعبارة عنه». وذكر على ذلك آثار السلف.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن النجار في تاريخه.|2:أي: مرسلة مطلقة في الإحسان إلى كل أحد؛ بَرًّا كان أو فاجرًا. النهاية (سجل).|3:أخرجه ابن عدي في الكامل في الضعفاء ٨/٤٠١ بلفظ: مجملة للكافر والمسلم، والبيهقي في شعب الإيمان ١١/٣٩٤-٣٩٥ (٨٧٢٦)، من طريق الهيثم بن عدي، عن عبد الله بن عياش، عن جعفر بن إياس، عن سعيد بن جُبَير، عن ابن عباس به.</p><p>قال البيهقي: «الهيثم بن عدي الكوفي متروك الحديث».|4:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.|5:أخرجه البيهقي في شعب الإيمان ٢/٢٢ (٤٢٥)، من طريق إبراهيم بن محمد بن إسماعيل الكوفي، عن حبيب بن أبي العالية، عن مجاهد، عن ابن عمر به.</p><p>قال البيهقي: «تفرَّد به إبراهيمُ بن محمد الكوفي، وهو منكر».|6:عزاه السيوطي إلى ابن مردويه.|7:أخرجه أبو نعيم في أخبار أصبهان ١/٢٨٠، والواحدي في التفسير الوسيط ٤/٢٢٧ (١١٥٦)، والثعلبي ٩/١٩٢، من طريق بشر بن الحسين، عن الزبير بن عدي، عن أنس بن مالك به.</p><p>وسنده ضعيف؛ فيه بشر بن الحسين الأصبهاني، وهو متروك. كما في ميزان الاعتدال ١/٣١٥.|8:عزاه السيوطي إلى ابن مردويه.|9:أخرجه الخطيب في تاريخه ٥/٣٨.|10:أخرجه ابن جرير ٢٢/٢٥٣، والبخاري في الأدب (١٣٠)، والبيهقي في شعب الإيمان (٩١٥٢). وقال: مُسجلة يعني: مُرسلة. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|11:أخرجه الطبراني في الدعاء ٣/١٥٠٨.|12:عزاه السيوطي إلى عبد بن حميد.|13:عزاه السيوطي إلى عبد بن حميد.|14:تفسير الثعلبي ٩/١٩٢.|15:أخرجه ابن جرير ٢٢/٢٥٢.|16:أخرجه الثعلبي ٩/١٩٢.|17:تفسير مقاتل بن سليمان ٤/٢٠٤.|18:أخرجه ابن جرير ٢٢/٢٥٢-٢٥٣.
  55,60,""
  55,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن دُونِهِمَا جَنَّتَانِ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: كان عرش الله على الماء، ثم اتخذ لنفسه جنة، ثم اتخذ دونها جنة أخرى، ثم أطبقهما بلؤلؤة واحدة، قال: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> وهي التي لا تُعلَم -أو قال- وهما التي <span class="qpc-hafs">﴿لا تَعْلَمُ نَفْسٌ ما أُخْفِيَ لَهُمْ مِن قُرَّةِ أعْيُنٍ جَزاءً بِما كانُوا يَعْمَلُونَ﴾</span> [السجدة:١٧]، وهي التي لا تَعلَم الخلائق ما فيهما، أو ما فيها، يأتيهم كلَّ يوم منها أو منهما تُحفةٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> من دونهما في الدَّرَج{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> الجنتان الأُوليان من ذهب وفِضّة، والأُخريان من ياقوت{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> قال: هما دون <span class="qpc-hafs">﴿تَجْرِيانِ﴾</span>{4}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما﴾</span> يعني: ومن دون جَنتي المُقرّبين والصِّدّيقين والشهداء في الفضل <span class="qpc-hafs">﴿جَنَّتانِ﴾</span> وهما جنة الفردوس، وجنة المأوى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٧<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span> هن أربع: جنتان للمُقرّبين السابقين، فيهما مِن كلّ من فاكهة زوجان، وجنتان لأصحاب اليمين، فيهما فاكهة ونخل ورمان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span>، قال: هما أدنى مِن هاتين لأصحاب اليمين{7}<span class=comment-ref>٦٤٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٥</span> اختُلف في معنى قوله تعالى: <span class="qpc-hafs">﴿ومن دونهما جنتان﴾</span> على قولين: <b>الأول</b>: من دونهما في الفَضل. <b>الثاني</b>: من دونهما في الدَّرَج.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٨١ بتصرف) أنّ «أكثر الناس على التأويل الأول، وهذه استدلالات ليست بقواطع، وأنه رُوي عن أبي موسى الأشعري ﵄ أنه قال: جنتان للمُقرّبين مِن ذهب، وجنتان لأهل اليمين مِن فِضة مما دون الأولَيَيْن».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ القيم</u> (٣/١٠١-١٠٣ بتصرف) <span class="mustanad">-مستندًا إلى الدلالة العقلية، وظاهر اللفظ والسياق-</span> القول الثاني من وجوه، أهمها ما يلي: <b>الأول</b>: قوله: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span> وفيه قولان: أحدهما: أنه جمع فَنن، وهو الغُصن. والثاني: أنه جمع فَن، وهو الصنف، أي: ذواتا أصناف شتّى مِن الفواكه وغيرها، ولم يذكر ذلك في اللتين بعدهما. <b>الثاني</b>: قوله: <span class="qpc-hafs">﴿فِيهِما عَيْنانِ تَجْرِيانِ﴾</span>، وفي الأخريين: <span class="qpc-hafs">﴿فيهما عينان نضاختان﴾</span>، والنَّضّاخة هي الفوّارة، والجارية: السارحة، وهي أحسن مِن الفوارة؛ فإنها تضمن الفوران والجريان. <b>الثالث</b>: أنه قال: <span class="qpc-hafs">﴿فيهما من كل فاكهة زوجان﴾</span>، وفي الأخريين: <span class="qpc-hafs">﴿فيهما فاكهة ونخل ورمان﴾</span>، ولا ريب أنّ وصف الأُوليين أكمل. <b>الرابع</b>: أنه قال: <span class="qpc-hafs">﴿متكئين على فرش بطائنها من استبرق﴾</span>، وهذا تنبيه على فضل الظهائر وخطرها، وفي الأخريين قال: <span class="qpc-hafs">﴿متكئين على رفرف خضر وعبقري حسان﴾</span>، وفسّر الرّفرف بالمحابس والبُسط، وفسّر بالفُرش، وفسّر بالمحابس فوقها، وعلى كلّ قول فلم يصفه بما وصف به فُرش الجنتين الأوليين. <b>الخامس</b>: أنه قال: <span class="qpc-hafs">﴿وجنى الجنتين دان﴾</span> أي: قريب وسهل، يتناولونه كيف شاءوا، ولم يذكر ذلك في الأخريين. <b>السادس</b>: أنه قال: <span class="qpc-hafs">﴿فيهن قاصرات الطرف﴾</span> أي: قد قَصَرن طَرفهنَ على أزواجهنّ، فلا يرون غيرهم؛ لرضاهنّ بهم، ومحبتهنّ لهم، وذلك يتضمّن قَصرهنّ أطراف أزواجهنّ عليهنّ، فلا يدعهم حُسنهنّ أن ينظروا إلى غيرهنّ، وقال في الأخريين: <span class="qpc-hafs">﴿حور مقصورات في الخيام﴾</span>، ومَن قَصرت طرفها على زوجها باختيارها أكمل ممن قَصرت بغيرها. <b>السابع</b>: أنه وصفهنّ بشبَه الياقوت والمرجان في صفاء اللون وإشراقه وحُسنه، ولم يذكر ذلك في التي بعدها. <b>الثامن</b>: أنه قال ﷾ في الجنتين الأوليين: <span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ إلّا الإحْسانُ﴾</span>، وهذا يقتضي أنّ أصحابهما مِن أهل الإحسان المطلق الكامل، فكان جزاؤهم بإحسان كامل. <b>التاسع</b>: أنه بدأ بوصف الجنتين الأوليين، وجعلهما جزءًا لِمَن خاف مقامه، وهذا يدل على أنهما أعلى جزاء الخائف لمقامه، فرتّب الجزاء المذكور على الخوف ترتيب المسبب على سببه، ولما كان الخائفون على نوعين مُقرّبين وأصحاب يمين ذكر جنتي المُقرّبين، ثم ذكر جنتي أصحاب اليمين.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٣/٣٣٨-٣٣٩).</div></p><p><h3><span class="qpc-hafs">﴿وَمِن دُونِهِمَا جَنَّتَانِ ۝٦٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٤٩<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النبي ﷺ، قال: «<b>جنتان من فِضّة آنِيتهما وما فيهما، وجنتان من ذهب آنِيتهما وما فيهما، وما بين القوم وبين أن يَنظُروا إلى ربهم إلا رِداء الكبرياء على وجهه في جنة عَدن</b>»{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٣٣٣، ٢٢/٢٥٣، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٦١ (٢٠٣)-.|2:تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٦.|3:تفسير البغوي ٧/٤٥٦.|4:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٢٠٤.|6:تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٦.|7:أخرجه ابن جرير ٢٢/٢٥٤.|8:أخرجه البخاري ٦/١٤٥ (٤٨٧٨) باب قوله: <span class="qpc-hafs">﴿ومن دونهما جنتان﴾</span>، ٩/١٣٢ (٧٤٤٤)، ومسلم ١/١٦٣ (١٨٠)، والثعلبي ٦/٢٠١-٢٠٢.
  55,62,""
  55,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُدۡهَاۤمَّتَانِ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٥٠<span class="dash">-</span></span> عن أبي أيوب الأنصاري، قال: سألت النبيَّ ﷺ عن قوله: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span>، قال: «<b>خضراوان</b>»{1}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥١<span class="dash">-</span></span> عن <span class="name-1">أبي أيوب الأنصاري</span>، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> هما جنتان خضراوان{2}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span>، قال: خضروان{3}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> قد اسودتا من الخضرة؛ من الرّيّ من الماء{4}. (١٤/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزبير</span> -من طريق جارية- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خضراوان من الريّ{5}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٥<span class="dash">-</span></span> عن يحيى بن سلمة، عن أبيه، قال: سمعتُ <span class="name-1">عبد الله بن أبي أوْفى</span> في قوله: <span class="qpc-hafs">﴿مدهامتان﴾</span> قال: خَضْراوان{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان{7}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق سالم- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> علاهما الرِّيّ من السواد والخُضرة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> مُسْودّتان{9}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان{10}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦١<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>، قالا: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> سَوداوان من الرِّيّ{11}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان{12}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> سَوداوان من الرِّيّ{13}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> ناعمتان{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٥<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span> -من طريق إدريس، عن أبيه- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان من الرِّيّ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٦<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span>، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> هما جنتان خَضْراوان{16}. (١٤/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل بن أبي خالد- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان من الرِّيّ، ناعمتان، إذا اشتدّت الخُضْرة ضربت إلى السواد{17}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> خَضْراوان من الرِّيّ، ناعمتان، إذا اشتدّت الخُضْرة ضربت إلى سواد{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٦٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿مدهامتان﴾</span>، قال: كثرة الشجر وخُضرته{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٠<span class="dash">-</span></span> عن <span class="name-3">أبي سنان [سعيد بن سنان البرجمي]</span> -من طريق مهران- قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> مُسْودَّتان من الرِّيّ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نَعَتهما، فقال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> سَوداوان مِن الرِّيّ والخُضْرة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ولِمَن خافَ مَقامَ رَبِّهِ جَنَّتانِ﴾</span>: جنتا السابقين، فقرأ: <span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، فقرأ حتى بلغ: <span class="qpc-hafs">﴿كَأَنَّهُنَّ الياقُوتُ والمَرْجانُ﴾</span>، ثم رجع إلى أصحاب اليمين، فقال: <span class="qpc-hafs">﴿ومِن دُونِهِما جَنَّتانِ﴾</span>، فذكر فضلهما وما فيهما، قال: <span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span> من الخُضْرة؛ من شدة خُضْرتهما، حتى كادتا تكونان سَوداوين{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عدي في الكامل في الضعفاء ٨/٣٧٢ (٢٠٠٩)، والطبراني في الكبير ٤/١٨٠ (٤٠٧٤)، من طريق سعيد بن مسلمة، عن واصل بن السّائِب، عن أبي سورة، عن أبي أيوب به.</p><p>قال ابن القيسراني في ذخيرة الحفاظ ٣/١٤٤١ (٣١٥٩): «واصل هذا متروك الحديث». وقال الهيثمي في المجمع ٧/١١٨ (١١٣٩٢): «فيه واصل بن السّائِب، وهو متروك».|2:عزاه السيوطي إلى هناد، وعبد بن حميد.|3:أخرجه ابن جرير ٢٢/٢٥٥-٢٥٦، ومن طريق سعيد بن جُبَير أيضًا، وهناد (٤٢). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|4:أخرجه ابن جرير ٢٢/٢٥٥. وعزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه ابن جرير ٢٢/٢٥٥، وابن أبي شيبة ١٣/١٣١، وهناد (٤١). وعزاه السيوطي إلى عبد بن حميد، والفريابي.|6:أخرجه ابن المبارك في الزهد ١/٥٢٦.|7:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٣٩-، وابن جرير ٢٢/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٢/٢٥٦.|9:تفسير مجاهد ص٦٣٩، وأخرجه ابن جرير ٢٢/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.|10:أخرجه ابن أبي شيبة ١٣/١٣٢. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه الفريابي -كما في تغليق التعليق ٣/٥٠٥- عن مجاهد. وعزاه السيوطي إلى عبد بن حميد.|12:أخرجه الخطيب في المتفق والمفترق (٦٩١).|13:أخرجه هناد (٤٣).|14:أخرجه ابن جرير ٢٢/٢٥٧.|15:أخرجه ابن جرير ٢٢/٢٥٦.|16:أخرجه ابن أبي شيبة ١٣/١٣٢، وهناد (٣٩-٤٠). وعزاه السيوطي إلى عبد بن حميد.|17:أخرجه ابن جرير ٢٢/٢٥٦ مقتصرًا على أوله. وعزاه السيوطي إلى عبد بن حميد.|18:أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٥٧، وبنحوه من طريق سعيد.|19:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٣.|20:أخرجه ابن جرير ٢٢/٢٥٧.|21:تفسير مقاتل بن سليمان ٤/٢٠٤.|22:أخرجه ابن جرير ٢٢/٢٥٧-٢٥٨.
  55,64,""
  55,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا عَیۡنَانِ نَضَّاخَتَانِ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٧٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالمِسك والكافور على أولياء الله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span>، قال: فائضتان{2}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالماء من شدّة الرِّيّ{3}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- يقول: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> نَضّاخَتان بالخير{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٧<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span>، قال: العينان اللّتان تَجْريان خير مِن النَّضّاخَتين{5}. (١٤/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٨<span class="dash">-</span></span> عن يحيى بن سلمة، عن أبيه، قال: سمعتُ <span class="name-1">عبد الله بن أبي أوْفى</span> في قوله: <span class="qpc-hafs">﴿نضاختان﴾</span>، قال: نَضّاخَتان بالخير{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٧٩<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span>، قال: بالمِسك والعنبر، تَنضَخان على دُور الجنَّة كما يَنضَخ المطر على دُور أهل الدنيا{7}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بألوان الفاكهة{8}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سلمة- <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span>، قال: بكلّ خير{9}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> مُمتلئتان لا تنقطعان{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي الأحوص، عن سِماك- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالماء هوامش أنهار الجنة{11}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالخير{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾</span> مملوءتان مِن كلّ خير، لا ينتقصان{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿نَضّاخَتانِ﴾</span> تَنضَخان بالماء{14}<span class=comment-ref>٦٤٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٠٦</span> للسلف في قوله: <span class="qpc-hafs">﴿نضاختان﴾</span> أقوال: <b>الأول</b>: تَنضَخان الماء. <b>الثاني</b>: تَنضَخان الماء والفاكهة. <b>الثالث</b>: نَضّاخَتان بألوان الفاكهة. <b>الرابع</b>: نَضّاخَتان بالخير. <b>الخامس</b>: ممتلئتان.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/٢٦٠) -<span class="mustanad">مستندًا إلى المعروف في اللغة</span>- القول الأول، وعلّل ذلك بقوله: «لأنه المعروف بالعيون إذ كانت عيون ماء».</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٨/١٨١) أنّ <span class="qpc-hafs">﴿نضاختان﴾</span> معناه: «الفوارة: التي يهيج ماؤها». و<span class="comment-type-2">انتقد</span> القول الثالث بقوله: «وهذا ضعيف». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٩٣، وتفسير البغوي ٧/٤٥٧.|2:أخرجه ابن جرير ٢٢/٢٥٩، وابن أبي حاتم -كما في تغليق التعليق ٣/٥٠٢ بلفظ: فيّاضتان، وكما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|4:أخرجه ابن جرير ٢٢/٢٦٠.|5:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقال: ولفظ ابن حميد: قال: ما النضاختان بأفضل من اللتين تجريان.|6:أخرجه ابن المبارك في الزهد ١/٥٢٦.|7:أخرجه ابن أبي شيبة ٤/٥١٨، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٣٥ (٧٠)-. وعزاه السيوطي إلى ابن أبي حاتم.|8:أخرجه ابن المبارك في الزهد (١٥٣٥ زيادات الحسين)، وابن جرير ٢٢/٢٥٩، وابن أبي شيبة ١٣/١٣٣، وأبو نعيم في الحلية ٤/٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:أخرجه ابن أبي شيبة ١٣/١٣٢. وعزاه السيوطي إلى عبد بن حميد بلفظ: بالخير.|10:أخرجه ابن جرير ٢٢/٢٥٩.|11:أخرجه هناد في الزهد (٩٧)، وابن جرير ٢٢/٢٥٨ مختصرًا بلفظ: فياضتان.|12:أخرجه عبد الرزاق ٢/٢٦٦.|13:تفسير مقاتل بن سليمان ٤/٢٠٤.|14:أخرجه ابن جرير ٢٢/٢٥٨.
  55,66,""
  55,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهِمَا فَـٰكِهَةࣱ وَنَخۡلࣱ وَرُمَّانࣱ ۝٦٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِيهِما فاكِهَةٌ ونَخْلٌ ورُمّانٌ﴾</span> قال: هي ثَـمَّ؛ <span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span> [الرحمن:٥٢]{1}. (١٤/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق رجل- <span class="qpc-hafs">﴿فِيهِما فاكِهَةٌ ونَخْلٌ ورُمّانٌ﴾</span>، قال: نخل الجنة جذوعها ذهب، وكَرانِيفَها{2} زُمُرّد. وقال: جذوعها زُمُرّد، وكرانيفها ذهب، وسعَفها كسوة لأهل الجنة، ورُطبها كالدّلاء؛ أشدّ بياضًا مِن اللبن، وأليَن مِن الزُّبْد، وأحلى مِن العسل، ليس له عَجَمٌ{3}{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِیهِمَا فَـٰكِهَةࣱ وَنَخۡلࣱ وَرُمَّانࣱ ۝٦٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٥٨٩<span class="dash">-</span></span> عن عمر بن الخطاب، قال: جاء ناسٌ مِن اليهود إلى رسول الله ﷺ، فقالوا: يا محمد، أفي الجنة فاكهة؟ قال: «<b>نعم، فيها فاكهة ونَخلٌ ورُمّان</b>». قالوا: أفيأكلون كما يأكلون في الدنيا؟ قال: «<b>نعم، وأضعافه</b>». قالوا: فيَقْضون الحوائج؟ قال: «<b>لا، ولكنهم يَعْرَقون ويَرْشَحون، فيُذهب الله ما في بطونهم مِن أذًى</b>»{5}. (١٤/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٠<span class="dash">-</span></span> عن أبي سعيد الخُدري، قال: سُئل رسول الله ﷺ عن نخل الجنة. فقال: «<b>أصوله فِضّة، وجذوعها ذهب، وسَعفه حُلل، وحَمْله الرُّطب، أشدّ بياضًا مِن اللبن، وأليَن من الزُّبْد، وأحلى من الشّهد</b>»{6}. (١٤/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩١<span class="dash">-</span></span> عن أبي سعيد الخُدري، عن النبيِّ ﷺ، قال: «<b>نظرتُ إلى الجنة، فإذا الرُّمّانة مِن رُمّانها كمثل البعير المُقْتب</b>»{7}. (١٤/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>ما مِن رُمّانة مِن رُمّانكم هذه إلا وهي تُلقَّح بحبّة مِن رُمّان الجنة</b>»{8}. (١٤/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٣<span class="dash">-</span></span> عن <span class="name-1">سلمان الفارسي</span> أنه أخذ عودًا صغيرًا، ثم قال: لو طلبتَ في الجنة مثل هذا العود لم تُبصِره. قيل: فأين النخل والشجر؟ قال: أصولها اللؤلؤ والذهب، وأعلاه الثمر{9}. (١٤/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: نخل الجنة؛ جذوعها زُمُرّد أخضر، وكرانيفها ذهب أحمر، وسَعفها كسوة لأهل الجنة، منها مُقطّعاتهم وحُللهم، وثمرها أمثال القِلال، أشدّ بياضًا من اللبن، وأحلى من العسل، وأليَن من الزّبْد، وليس لها عَجَمٌ{10}. (١٤/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: إنّ الثمرة مِن ثمر الجنة طولها اثنا عشر ذراعًا، ليس لها عَجَم{11}. (١٤/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جعفر-: أنه كان يأخذ الحبّة من الرُّمّان فيأكلها، فقيل له: لِمَ تفعل هذا؟ قال: بلغني: أنّه ليس في الأرض رُمّانة تُلقَّح إلا بحبّة مِن الجنة، فلعلّها هذه{12}. (١٤/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٧<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأَجْدع الهَمداني</span> -من طريق أبي عبيدة- قال: نخل الجنة طَلْعها نضيد من أصلها إلى فرعها، وثمرها أمثال القِلال، كلمّا نُزِعتْ ثمرةٌ عادت مكانها أخرى، وأنهارها في غير أخدود، والعنقود اثنا عشر ذراعًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٨<span class="dash">-</span></span> عن <span class="name-2">وهب [بن مُنَبِّه]</span> <span class="name-2">الذّماري</span> -من طريق زيد بن أسلم- قال: بلَغنا: أنّ في الجنة نخلًا جذوعها من ذهب، وكرانيفُها من ذهب، وجَريدها من ذهب، وسَعفها كسوة لأهل الجنة، كأحسن حُلَل رآها الناس قطّ، وشماريخُها من ذهب، وعَراجينُها من ذهب، وثفاريقُها{14} من ذهب، ورُطبها أمثال القِلال، أشدُّ بياضًا مِن اللبن والفِضّة، وأحلى مِن العسل والسُّكر، وأليَن من الزُّبْد والسّمن{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٥٩٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق معمر- قال: بلَغنا: أنّ في الجنة نخلًا عروقها من ذهب، وكَرانيفَها من ذهب، وأقْتادها من ذهب، وسَعفها كسوة لأهل الجنة كأحسن حُللٍ رآها الناس قط، وشماريخُها{16} من ذهب، وعَراجينُها{17} من ذهب، وجَريدها من ذهب، ورُطبها أمثال القِلال؛ أشدّ بياضًا من اللبن، وأحلى من السُّكر والعسل، وأليَن من الزُّبْد والسّمن{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٦٠٠<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق معمر- قال: إنّ في الجنة شجرة لو أنّ غرابًا خرج من عُشّه فطار لَمات هَرمًا قبل أن يقطعها{19}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|2:الكَرانِيف: أُصول السعَفِ الغِلاظ العِراض، التي إذا يَبِسَتْ صارت أمثال الأَكتاف. لسان العرب (كرنف).|3:العَجَم -بالتَّحريك-: النَّوى. النهاية (عجم).|4:أخرجه عبد الرزاق ٢/٢٦٦، وابن جرير ٢٢/٢٦١.|5:أخرجه عبد بن حميد في المنتخب ص٤٣ (٣٥)، وابن أبي الدنيا في صفة الجنة ص١٠١-١٠٢ (٩٩)، من طريق يحيى بن عبد الحميد، عن حصين بن عمر الأحمسي، عن مخارق، عن طارق بن شهاب، عن عمر به.</p><p>قال ابن كثير في مسند الفاروق ٢/٦٠٨: «هذا غريب من هذا الوجه؛ لأنّ حصين بن عمر الأحمسي تكلموا فيه، ولكن قد رُوي من غير هذا الوجه». وقال البوصيري في إتحاف الخيرة ٨/٢٣٦ (٧٨٦٥): «رواه عبد بن حميد، والحارث، كلاهما عن يحيى بن عبد الحميد، عن حصين بن عمر الأحمسي، وهو ضعيف». وقال المتقي الهندي في كنز العمال ١٤/٦٤٨ (٣٩٧٧٥): «سنده ضعيف».|6:عزاه السيوطي إلى ابن مردويه.|7:أخرجه الدينوري في المجالسة وجواهر العلم ٣/٤٨٨-٤٩١ (١١٠٢)، وابن عساكر في تاريخه ١٩/٣٧٢ (٤٥٠٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٥٠٨-، والثعلبي ٩/١٩٤، من طريق حماد بن سلمة، عن أبي هارون العبدي، عن أبي سعيد الخدري به.</p><p>قال العراقي في المغني عن حمل الأسفار ٢/١٢٦٩: «أبو هارون اسمه عمارة بن جوين، ضعيف جدًّا».|8:أخرجه ابن عدي في الكامل في الضعفاء ٧/٥٤٣، وابن عساكر في تاريخه ٥٦/١٨٦، من طريق روح بن عبد المجيب، عن محمد بن الوليد، عن أبي عاصم، عن ابن جريج، عن ابن عجلان، عن أبيه، عن ابن عباس به.</p><p>قال ابن عدي: «هذا حديث باطل». وقال ابن الجوزي في الموضوعات ٢/٢٨٥: «هذا حديث لا يصح». وقال الذهبي في لسان الميزان ٥/٤١٧ في ترجمة محمد بن الوليد بن أبان القلانسي (١٣٧٤): «من أباطيله» فذكره. وقال السخاوي في المقاصد الحسنة ص٥٨٧ (٩٨١): «سنده ضعيف». وأورده السيوطي في اللآلئ المصنوعة ٢/١٧٦، والشوكاني في الفوائد المجموعة ص١٥٩ (١٧)، وابن عراق الكناني في تنزيه الشريعة ٢/٢٤٢ (٤٢).|9:أخرجه ابن أبي شيبة ١٣/٣٣٣، وهناد بن السري (٩٨)، والبيهقي (٨١٤٧).|10:أخرجه ابن المبارك (١٤٨٨ زيادات الحسين)، وهناد بن السري (٩٩)، وابن أبي الدنيا في صفة الجنة (٥١)، وأبو الشيخ في العظمة (٥٧٦)، والحاكم ٢/٤٧٥-٤٧٦، والبيهقي في البعث والنشور (٣١١). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|11:أخرجه ابن أبي الدنيا في صفة الجنة (١٢٤).</p><p>وقال محققه: «إسناده ضعيف».|12:أخرجه الطبراني (١٠٦١١)، والبيهقي في شعب الإيمان (٥٩٦٠).</p><p>وقال الهيثمي في مجمع الزوائد ٥/٤٥: «ورجاله رجال الصحيح».|13:أخرجه عبد الرزاق ٢/٢٦٧، وابن أبي حاتم ٣/٨٤٥.|14:الثَّفارِيق: جمع الثَفْرُوق: وهي الأقماع التي تلزق في البُسْر. النهاية واللسان (ثفرق).|15:أخرجه ابن جرير ٢٢/٢٦١.|16:الشماريخ: جمع شمراخ، وهو غصن العذق. النهاية (شمرخ).|17:العُرْجُون: العِذْقُ عامة. وقيل: هو العِذْقُ إذا يَبس واعْوجَّ. لسان العرب (عرجن).|18:أخرجه عبد الرزاق ٢/٢٦٧.|19:أخرجه عبد الرزاق ٢/٢٦٨.