tafsir[30]{c,v,t}:
74,18," <q>﴿إِنَّهُۥ فَكَّرَ وَقَدَّرَ ۝١٨ فَقُتِلَ كَیۡفَ قَدَّرَ ۝١٩ ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾</q> - نزول الآيات ٧٩٧٧٢- عن عبد الله بن عباس، قال: لَمّا بُعِث النبيُّ ﷺ جمع الوليد بن المُغيرة قريشًا، فقال: ما تقولون؟ يعني: في هذا الرجل، فقال بعضهم: هو شاعر. وقال بعضهم: هو كاهن. فقال الوليد: سمعتُ قول الشاعر فما هو بشاعر، وسمعتُ قول الكهنة فما هو مثله. قالوا: فما تقول أنتَ؟ قال: فنظر ساعة، ثم فَكّر وقَدّر، <q>﴿فَقُتِلَ كَيْفَ قَدَّرَ﴾</q> إلى قوله: <q>﴿سِحْرٌ يُؤْثَرُ﴾</q>{1}. (١٥/٧٣) ٧٩٧٧٣- قال مجاهد: إنّ الوليد بن المُغيرة كان يَغشى النبيَّ ﷺ وأبا بكر ﵁، حتى حَسبتْ قريش أنه يُسلم، فقال له أبو جهل: إنّ قريشًا تزعم أنك إنما تأتي محمدًا وابن أبي قُحافة تُصيب من طعامهما. فقال الوليد لقريش: إنكم ذوو أحساب وذوو أحلام، وإنكم تزعمون أنّ محمدًا مجنون، وهل رأيتموه يُجَنُّ قطّ؟ قالوا: اللهم، لا. قال: تزعمون أنه كاهن، وهل رأيتموه يتكهّن قطّ؟ قالوا: اللهم، لا. قال: تزعمون أنه شاعر، هل رأيتموه يَنطق بشعرٍ قطّ؟ قالوا: لا. قال: فتزعمون أنه كذّاب، فهل جربتم عليه شيئًا من الكذب؟ قالوا: لا. قالتْ قريش للوليد: فما هو؟ فتفَكّر في نفسه، ثم نَظر، وعبس، فقال: ما هو إلا ساحر، وما يقوله سحرٌ. فذلك قوله: <q>﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</q> إلى قوله تعالى: <q>﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</q>{2}. (ز) ٧٩٧٧٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</q>، قال: ذُكر لنا أنه قال: لقد نظرتُ فيما قال هذا الرجل، فإذا هو ليس بشعرٍ، وإنّ له لَحلاوة، وإن عليه لَطُلاوَةً، وإنه ليَعلو ولا يُعلى، وما أشكّ أنه سحرٌ. فأنزل الله فيه: <q>﴿فَقُتِلَ كَيْفَ قَدَّرَ﴾</q> إلى قوله: <q>﴿وبَسَرَ﴾</q>{3}. (١٥/٧٠) <q>﴿إِنَّهُۥ فَكَّرَ وَقَدَّرَ ۝١٨ فَقُتِلَ كَیۡفَ قَدَّرَ ۝١٩ ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾</q> - تفسير الآية ٧٩٧٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿فَكَّرَ وقَدَّرَ﴾</q>، قال: الوليد بن المُغيرة يوم دار النَّدوة{4}. (ز) ٧٩٧٧٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</q> يعني: الوليد بن المُغيرة، دعاه نبي الله ﷺ إلى الإسلام، فقال: حتى أنظر. ففكّر، <q>﴿ثُمَّ نَظَرَ ثُمَّ عَبَسَ وبَسَرَ ثُمَّ أدْبَرَ واسْتَكْبَرَ فَقالَ إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</q>. فجَعل الله له سَقر{4}. (ز) ٧٩٧٧٧- قال محمد بن شهاب الزُّهريّ: <q>﴿فَقُتِلَ﴾</q> عُذّب{6}. (ز) ٧٩٧٧٨- قال مقاتل بن سليمان: <q>﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</q> ثم قال -يعني: الوليد بن المُغيرة-: <q>﴿إنَّهُ فَكَّرَ﴾</q> في أمْر محمد ﷺ، فزعم أنه ساحر، وقال مثل ما قال في التقديم، <q>﴿وقَدَّرَ﴾</q> في قوله: إنّ محمدًا يُفرّق بين الاثنين. <q>﴿فَقُتِلَ كيف قدر﴾</q> يقول: فلُعِن كيف قدَّر السحر، <q>﴿ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾</q> يعني: ثم لُعِن كيف قدّر السِّحر{7}. (ز) ٧٩٧٧٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿فَقُتِلَ كَيْفَ قَدَّرَ ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾</q>، قال: قُتل كيف قدّر حين قال: ليس بشعرٍ. ثم قُتل كيف قدّر حين قال: ليس بكهانة{4}٦٨٧٧. (ز) ٦٨٧٧ ذكر ابنُ عطية (٨/٤٥٧-٤٥٨) في قوله: <q>﴿فقتل كيف قدر﴾</q> احتمالين: الأول: «أن يكون دعاء عليه على معنى تقبيح حاله». ثم وجّه معنى قوله: <q>﴿ثم نظر﴾</q> على هذا الاحتمال، فقال: «وعلى التأويل الأول أنّ الدعاء عليه دعاء على مُستقبح فعله يجيء قوله: <q>﴿ثُمَّ نَظَرَ﴾</q> معنىً معادًا بعينه؛ لأن <q>﴿فَكَّرَ وقَدَّرَ﴾</q> يقتضيه، لكنه إخبار بترديده النظر في الأمر، وقد رُوي أنّ النبي ﷺ دعا الوليد فقال له: «أنظُرُ وأُفَكِّرُ». فلمّا فَكّر قال ما تقدم». الثاني: «يحتمل أن يكون دعاء مقتضاه استحسان منزعه الأول في مدحه القرآن، وفي نفيه الشعر والكهانة والجنون عنه، فيجري هذا مجرى قول النبي ﷺ لأبي جَندل بن سهيل: «ويل أمه، مسْعَر حرب». ومجرى قول عبد الملك بن مروان: قاتل الله كُثَيِّرًا، كأنه رآنا حين قال كذا. وهذا معنًى مشهور في كلام العرب». ثم وجّه معنى قوله: <q>﴿ثم نظر﴾</q> على هذا الاحتمال، فقال: «وإذا قلنا إنّ ذلك دعاء على مستحسن فعله فيجيء قوله تعالى: <q>﴿ثُمَّ نَظَرَ﴾</q> فيما احتج به للقرآن، فرأى ما فيه من علوِّ مرتبة محمد ﵇، فـ<q>﴿عَبَسَ﴾</q> لذلك، <q>﴿وبَسَرَ﴾</q> أي: قطب، وقبض ما بين عينيه، واربدَّ وجهه حسدًا له». ",footnotes:1:عزاه السيوطي إلى أبي نعيم في الدلائل.علقه الواحدي في أسباب النزول (٧٠١).أخرجه ابن جرير ٢٣/٤٣٠. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٣١.أخرجه ابن جرير ٢٣/٤٣١.تفسير الثعلبي ١٠/٧٣، وتفسير البغوي ٨/٢٦٩.تفسير مقاتل بن سليمان ٤/٤٩٥-٤٩٦.أخرجه ابن جرير ٢٣/٤٣١.
  74,19,""
  74,20,""
74,21," <q>﴿ثُمَّ نَظَرَ ۝٢١ ثُمَّ عَبَسَ وَبَسَرَ ۝٢٢ ثُمَّ أَدۡبَرَ وَٱسۡتَكۡبَرَ ۝٢٣﴾</q> - تفسير ٧٩٧٨٠- عن قتادة بن دعامة <q>﴿وبَسَرَ﴾</q>، قال: كَلَح{1}. (١٥/٧٠) ٧٩٧٨١- عن قتادة بن دعامة، في قوله: <q>﴿عَبَسَ وبَسَرَ﴾</q>، قال: قَبض ما بين عينيه، وكَلَح{2}. (١٥/٧٦) ٧٩٧٨٢- عن محمد بن السّائِب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿عَبَسَ وبَسَرَ﴾</q>، قال: عَبَس، وكَلَح{3}. (ز) ٧٩٧٨٣- قال مقاتل بن سليمان: <q>﴿ثُمَّ نَظَرَ﴾</q> فيما يقول لمحمد ﷺ مِن السِّحر، <q>﴿ثُمَّ عَبَسَ﴾</q> وجهه، يعني: كَلَح. كقوله: <q>﴿عَبَسَ وتَوَلّى﴾</q> [عبس:١]، يعني: كَلَح في وجه ابن أم مكتوم. <q>﴿وبَسَرَ﴾</q> يعني: وتغيّر لون وجهه، يعني: أعرَض عن الإيمان، <q>﴿واسْتَكْبَرَ﴾</q> عنه{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٣٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٣٠.تفسير مقاتل بن سليمان ٤/٤٩٣-٤٩٦.
  74,22,""
  74,23,""
74,24," <q>﴿فَقَالَ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ یُؤۡثَرُ ۝٢٤ إِنۡ هَـٰذَاۤ إِلَّا قَوۡلُ ٱلۡبَشَرِ ۝٢٥﴾</q> - تفسير ٧٩٧٨٤- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل- <q>﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</q>، قال: يَأْثُره عن غيره{1}. (١٥/٧٦) ٧٩٧٨٥- قال الحسن البصري، في قوله: <q>﴿إنْ هَذا إلا قَوْلُ البشر﴾</q>، يَعنون: عَدّاسًا غلام عُتْبَة. كقوله: <q>﴿ولَقَدْ نَعْلَمُ أنَّهُمْ يَقُولُونَ إنَّما يُعَلِّمُهُ بَشَرٌ﴾</q> [النحل:١٠٣] هو عَدّاس{2}. (ز) ٧٩٧٨٦- قال مقاتل بن سليمان: <q>﴿فَقالَ﴾</q> الوليد لقومه: <q>﴿إنْ هَذا﴾</q> الذي يقول محمد <q>﴿إلّا سِحْرٌ يُؤْثَرُ إنْ هَذا إلّا قَوْلُ البَشَرِ﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٤٣٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٧-.تفسير مقاتل بن سليمان ٤/٤٩٣-٤٩٦.
  74,25,""
74,26," <q>﴿سَأُصۡلِیهِ سَقَرَ ۝٢٦ وَمَاۤ أَدۡرَىٰكَ مَا سَقَرُ ۝٢٧﴾</q> - تفسير ٧٩٧٨٧- عن عبد الله بن عباس، قال: <q>﴿سَقَرُ﴾</q> أسفل الجحيم، نابتٌ فيها شجرة الزَّقوم{1}. (١٥/٧٦) ٧٩٧٨٨- قال مقاتل بن سليمان: <q>﴿سَأُصْلِيهِ سَقَرَ﴾</q>، يعني: الباب الخامس من جهنم{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٣-٤٩٦.
  74,27,""
74,28," <q>﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾</q> - تفسير ٧٩٧٨٩- عن عبد الله بن عباس: <q>﴿لا تُبْقِي﴾</q> إذا أخذتْ فيهم لم تُبق منهم شيئًا، وإذا بُدِّلوا خَلْقًا جديدًا لم تَذرْ أن تُعاودهم سبيل العذاب الأول{1}. (١٥/٧٦) ٧٩٧٩٠- عن ابن بُرَيْدة، <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q>، قال: تأكل اللحم، والعظم، والعِرق، والمخ، ولا تَذره على ذلك{1}. (١٥/٧٧) ٧٩٧٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q>، قال: لا تُحْيِي، ولا تميت{3}٦٨٧٨. (١٥/٧٦) ٦٨٧٨ لم يذكر ابنُ جرير (٢٣/٤٣٣) غير قول مجاهد، ومزيدة. ٧٩٧٩٢- عن الضَّحّاك بن مُزاحِم: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q> تأكله كلّه، فإذا تَبدّى خَلْقه لم تَذره حتى تقوم عليه{1}. (١٥/٧٦) ٧٩٧٩٣- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q>: لا تُبقي لهم لحمًا، ولا تَذر لهم عظمًا{5}. (ز) ٧٩٧٩٤- عن مَزِيدة [بن جابر الهجري] -من طريق [محمد بن عبد الرحمن] بن أبي ليلى- في قوله: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q>، قال: لا تُبقي منهم شيئًا أن تأكلهم، فإذا خُلِقوا لها لا تَذرهم حتى تأخذهم فتَأكلهم{6}. (ز) ٧٩٧٩٥- قال مقاتل بن سليمان: <q>﴿لا تُبْقِي ولا تَذَرُ﴾</q> يعني: لا تُبْقِي النار إذا رَأتْهم حتى تأكلهم، ولا تَذرهم إذا حَلَفُوا لها حتى تواقعهم{7}. (ز) <q>﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾</q> - آثار متعلقة بالآية ٧٩٧٩٦- عن أبي هريرة، عن رسول الله ﷺ: «قال موسى لربّه ﷿: أيُّ عبادك أفقرُ؟ قال: صاحب سقر»{8}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٣٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٧٤، وتفسير البغوي ٨/٢٧٠.أخرجه ابن جرير ٢٣/٤٣٣.تفسير مقاتل بن سليمان ٤/٤٩٦.أخرجه الثعلبي ١٠/٧٣.
74,29," <q>﴿لَوَّاحَةࣱ لِّلۡبَشَرِ ۝٢٩﴾</q> - تفسير ٧٩٧٩٧- عن أبي هريرة -من طريق عبد الله بن أبي الهُذيل- في قوله ﷿: <q>﴿لواحة للبشر﴾</q>، قال: تَلقاهم جهنم يوم القيامة، فتَلفحهم لَفحةً، فلا تَترك لحمًا على عظمٍ إلا وضعتْه على العراقيب{1}. (ز) ٧٩٧٩٨- عن عبد الله بن عباس، <q>﴿لَوّاحَةٌ﴾</q>، قال: مُحرِقة{2}. (١٥/٧٧) ٧٩٧٩٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، يقول: مُغَيِّرة{3}. (ز) ٧٩٨٠٠- عن عبد الله بن عباس، <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، قال: تُلوِّح الجلد، فتَحرقه، فيَتغيّر لونه، فيصير أسودَ من الليل{4}. (١٥/٧٧) ٧٩٨٠١- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل بن سُمَيع- <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، قال: تُلَوِّح جلده حتى تَدعه أشدّ سوادًا من الليل. وفي رواية: غيَّرت جلودَهم فاسودَّت{5}. (١٥/٧٧) ٧٩٨٠٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، قال: للجلد{6}. (١٥/٧٧) ٧٩٨٠٣- قال الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، يعني: بَشر الإنسان، يقول: تَحرق بَشره{7}. (ز) ٧٩٨٠٤- قال الحسن البصري: يعني: تَلوح لهم جهنم حتى يَروها عيانًا{8}٦٨٧٩. (ز) ٦٨٧٩ ذكر ابنُ عطية (٨/٤٥٩) قول الحسن، ووجّهه بقوله: «فالمعنى: أنها تظهر للناس -وهم البشر- مِن مسيرة خمسمائة عام، وذلك لعِظَمها وهولها وزفيرها». ٧٩٨٠٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، قال: حرّاقة للجلد{6}. (١٥/٧٧) ٧٩٨٠٦- عن عطاء الخراساني -من طريق يونس بن يزيد- <q>﴿لواحة للبشر﴾</q>، قال: بَشرة الإنسان تُلَوَّح على النار{10}. (ز) ٧٩٨٠٧- عن زيد بن أسلم -من طريق ابن أبي هلال- قال: <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، أي: تُلَوَّح أجسادهم عليها{11}. (ز) ٧٩٨٠٨- قال مقاتل بن سليمان: <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q> مُحرِقة للخَلْق{12}. (ز) ٧٩٨٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لَوّاحَةٌ لِلْبَشَرِ﴾</q>، قال: تُغيّر البشَر، تَحرق البشَر، يقال: قد لاحه استقباله السماء، ثم قال: والنار تُغيّر ألوانهم{7}٦٨٨٠. (ز) ٦٨٨٠ لم يذكر ابنُ جرير (٢٣/٤٣٣-٤٣٥) غير قول عبد الرحمن بن زيد، وقتادة، والضَّحّاك، ومجاهد، وأبي رَزِين، وزيد بن أسلم، وابن عباس من طريق علي. ووجّهه ابنُ عطية (٨/٤٥٨) قائلا: "فالبَشَر: جمع بشَرة، وتقول العرب: لاحت النارُ الشيءَ إذا أحرقَتْه وسَوّدتْه. وقال الشاعر: لاحَهُ الصيفُ والغِيارُ وإشفا ... قٌ على سقبة كقوس الضالِ وأنشد أبو عبيدة: ... يا ابنة عمي لاحَني الهواجرُ". ",footnotes:1:أخرجه البيهقي في البعث والنشور ص٢٨٩.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وعند ابن أبي حاتم -كما في الإتقان ٢/٥٠- بلفظ: مُغَيِّرة، من طريق علي كما في الأثر التالي.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٥٠-، وأخرجه ابن جرير ٢٣/٤٣٥، بلفظ: مُعَرِّضة، ثم قال: وأخشى أن يكون خبر علي بن أبي طلحة، عن ابن عباس هذا، غلطًا، وأن يكون موضع «معرضة»: «مغيرة»، لكن صُحِّف فيه.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي شيبة ١٣/١٥٣، وهناد (٣٠٥)، وابن جرير ٢٣/٤٣٤-٤٣٥.أخرجه ابن جرير ٢٣/٤٣٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٣٥.تفسير الثعلبي ١٠/٧٤، وتفسير البغوي ٨/٢٧٠.أخرجه ابن جرير ٢٣/٤٣٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٥.أخرجه ابن جرير ٢٣/٤٣٤.تفسير مقاتل بن سليمان ٤/٤٩٦.أخرجه ابن جرير ٢٣/٤٣٥.
74,30," <q>﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾</q> - نزول الآية ٧٩٨١٠- عن البراء بن عازب -من طريق عامر-: أنّ رهطًا مِن اليهود سألوا رجلًا مِن أصحاب النبيِّ ﷺ عن خَزنة جهنم. فقال: الله ورسوله أعلم. فجاء، فأخبَر النَّبيّ ﷺ؛ فنَزل عليه ساعتئذ: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q>{1}. (١٥/٧٧) ٧٩٨١١- عن عبد الله بن عباس -من طريق عطية- قال: لَمّا سمع أبو جهل: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> قال لقريش: ثَكِلتْكم أُمّهاتكم، أسمعُ ابنَ أبي كَبْشَة يُخبركم أنّ خَزنة النار تسعة عشر، وأنتم الدَّهْم{2}! أفيَعجز كلُّ عشرة منكم أن يَبطشوا برجلٍ من خَزنة جهنم؟! فأوحى الله إلى نبيّه أن يأتي أبا جهل، فيأخذ بيده في بطحاء مكة، فيقول له: <q>﴿أوْلى لَكَ فَأَوْلى ثُمَّ أوْلى لَكَ فَأَوْلى﴾</q> [القيامة:٣٤-٣٥]{3}. (١٥/٧٨) ٧٩٨١٢- قال الضَّحّاك بن مُزاحِم: لما نزلت هذه الآية <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> قال أبو جهل لقريش: ثَكِلتْكم أُمّهاتكم، أسمع ابن أبي كَبْشَة يُخبِر أنّ خَزنة النار تسعة عشر وأنتم الدَّهْم! -أي: الشّجعان- أفيَعجز كلّ عشرة منكم أن يَبطشوا بواحد من خَزنة جهنم؟! قال أبو الأشَدِّ أُسَيْد بن كَلَدَة بن خَلف الجُمحيّ: أنا أكفيكم منهم سبعة عشر؛ عشرة على ظهري، وسبعة على بطني، فاكفوني أنتم اثنين{4}. (ز) ٧٩٨١٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q>، قال: ذُكر لنا: أنّ أبا جهل حين أُنزِلَتْ هذه الآية قال: يا معشر قريش، ما يستطيع كلّ عشرة منكم أن يغلبوا واحدًا مِن خَزنة النار وأنتم الدَّهْمُ؟!{5}. (١٥/٧٩) <q>﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾</q> - تفسير الآية ٧٩٨١٤- عن جابر بن عبد الله، قال: قال ناس من اليهود لأناس مِن أصحاب النبِيِّ ﷺ: هل يَعلم نبيُّكم عددَ خَزنة جهنم؟ قالوا: لا ندري حتى نسأله. فجاءوا إلى النبي ﷺ، فقالوا: كم عدد خَزنة جهنم؟ قال: «هكذا، وهكذا». في مرّة عشرة، وفي مرّة تسعة{6}. (١٥/٧٨) ٧٩٨١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q>، قال: جُعلوا فتنة. قال: قال أبو الأَشَدَّين الجُمحيّ: لا يَبلغون رَبوتي حتى أُجهِضَهم{7} عن جهنم{8}. (١٥/٧٩) ٧٩٨١٦- قال عمرو بن دينار: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> إنّ واحدًا منهم يَدفع بالدّفعة الواحدة في جهنم أكثر من ربيعة ومُضر{9}. (ز) ٧٩٨١٧- قال مقاتل بن سليمان: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> يقول: في النار من الملائكة تسعة عشر خَزنتها؛ يعني: مالكًا ومَن معه ثمانية عشر مَلكًا، أعينهم كالبَرْق الخاطف، وأنيابهم كالصَّياصيّ -يعني: مثل قرون البقر-، وأشعارهم تمسّ أقدامهم، يَخرج لهب النار مِن أفواههم، ما بين مَنكِبي أحدهم مسيرة سبعين سنة، يَسع كفُّ أحدهم مثل ربيعة ومضر، قد نُزعتْ منهم الرأفة والرحمة غِضابًا، يدفع أحدهم سبعين ألفًا، فيُلقيهم حيث أراد من جهنم، فيَهوي أحدهم في جهنم مسيرة أربعين سنة، لا تَضُرّهم النار؛ لأنّ نورهم أشدّ مِن حرّ النار، ولولا ذلك لم يُطيقوا دخول النار طرْفة عين، فلمّا قال الله: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> قال أبو جهل بن هشام: يا معشر قريش، ما لِمُحمد من الجنود إلا تسعة عشر، ويزعم أنهم خَزنة جهنم، يُخوّفكم بتسعة عشر وأنتم الدَّهْم! أيَعجز كلّ مائة منكم أن تَبطش بواحد منهم، فيَخرجوا منها؟! وقال أبو الأَشَدَّين اسمه أُسَيْد بن كَلَدَة بن خلف الجُمحيّ: أنا أكفيكم سبعة عشر؛ أحمل منهم عشرة على ظهري، وسبعة على صدري، واكفوني منهم اثنين. وكان شديدًا فسُمّي: أبا الأَشَدَّين؛ لشدّته بذلك سُمّي، وكنيته: أبو الأعور{10}. (ز) ٧٩٨١٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q>، قال: خَزنتها تسعة عشر{11}. (ز) ٧٩٨١٩- عن رجل من بني تميم -من طريق الأزرق بن قيس- قال: كُنّا عند أبي العوّام، فقرأ هذه الآية: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q>. فقال: ما تقولون أتسعة عشر مَلكًا، أو تسعة عشر ألفًا؟ قلتُ: لا، بل تسعة عشر مَلكًا. فقال: ومَن أين علمتَ ذلك؟ قلتُ: لأنّ الله يقول: <q>﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</q>. قال: صدقتَ، هم تسعة عشر مَلكًا، بيد كلّ مَلكٍ منهم مِرْزَبّة مِن حديد له شُعبتان، فيَضرب بها الضربة يَهوي بها في جهنم سبعين ألفًا، بين مَنكِبي كلّ مَلكٍ منهم مسيرة كذا وكذا{12}. (١٥/٧٩) ",footnotes:1:أخرجه البيهقي في البعث والنشور ص٢٦٩ (٤٦٢)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٦٨-، من طريق حُريث بن أبي مطر، عن عامر، عن البراء بن عازب به. قال البيهقي: «حديث ابن أبي مطر ليس بالقوي». وقال ابن رجب في التخويف من النار ص٢١٩: «حُريث هو ابن أبي مطر ضعيف». وقال ابن كثير: «هكذا وقع عند ابن أبي حاتم، عن البراء، والمشهور عن جابر بن عبد الله».الدَّهْم: سيأتي معناه في الأثر التالي.أخرجه ابن جرير ٢٣/٤٣٦، من طريق عطية العَوفيّ، عن ابن عباس به. الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.تفسير البغوي ٨/٢٧٠.أخرجه ابن جرير ٢٣/٤٣٦. وعزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه عبد الرزاق ٢/٣٣١ بنحوه من طريق معمر، وكذا ابن جرير ٢٣/٤٣٦.أخرجه الترمذي ٥/٥٢١-٥٢٢ (٣٦١٦) مطولًا، من طريق مجالد، عن الشعبي، عن جابر بن عبد الله به. قال الترمذي: «هذا حديث إنما نعرفه من هذا الوجه من حديث مجالد». وقال ابن رجب في التخويف من النار ص٢٢٠: «وهذا أصح من حديث حُريث المتقدم، قاله البيهقي وغيره».أجهضته عن مكانه: أزلته. والإجهاض: الإزلاق. النهاية (جهض).أخرجه ابن جرير ٢٣/٤٣٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٧٤، وتفسير البغوي ٨/٢٧٠.تفسير مقاتل بن سليمان ٤/٤٩٦-٤٩٧.أخرجه ابن جرير ٢٣/٤٣٧.أخرجه ابن المبارك (٣٤٠- زوائد نعيم)، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٤-، وابن أبي شيبة ١٣/١٧٣-١٧٤، والبيهقي في البعث (٥١١)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٢ (٦١)-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. كما أخرجه يحيى بن سلام ١/٣٦٠ مختصرًا، وذكر الرواية عن: الأزرق بن قيس عن أبي العوام سادن بيت المقدس.
74,31," <q>﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةࣰ لِّلَّذِینَ كَفَرُوا۟﴾</q> - نزول الآية ٧٩٨٢٠- قال عبد الله بن عباس= (ز) ٧٩٨٢١- والضَّحّاك بن مُزاحِم= (ز) ٧٩٨٢٢- وقتادة: لَمّا نزلت هذه الآية: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> قال أبو جهل لقريش: ثَكِلتْكم أُمّهاتكم، أسمع ابن أبي كَبْشَة يُخبركم أنّ خَزنة النار تسعة عشر، وأنتم الدَّهم! -أي: الشّجعان- أفَيعجز كلّ عشرة منكم أن يَبطشوا برجلٍ من خَزنة جهنم؟! فقال أبو الأَشَدَّين كَلَدَة بن خَلف بن أسد الجُمحيّ: أنا أكفيكم منهم سبعة عشر؛ عشرة على ظهري، وسبعة على بطني، واكفوني أنتم اثنين. فأنزل الله ﷾: <q>﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</q>{1}. (ز) ٧٩٨٢٣- عن إسماعيل السُّدِّيّ، قال: لَمّا نزلت: <q>﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</q> قال رجل من قريش -يُدعى: أبا الأَشَدَّين-: يا معشر قريش، لا يَهولنَّكم التسعة عشر، أنا أدفع عنكم بمَنكِبي الأيمن عشرة، وبمَنكِبي الأيسر تسعة. فأنزل الله: <q>﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</q>{2}. (١٥/٧٨) ٧٩٨٢٤- قال مقاتل بن سليمان: <q>﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</q> حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأَنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾</q>. وأَنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: <q>﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾</q> [التحريم:٦]{3}. (ز) ٧٩٨٢٥- عن محمد بن إسحاق -من طريق سلمة-: قال أبو جهل يومًا وهو يهزأُ برسول الله ﷺ، وبما جاء به من الحق: يا معشر قريش، يزعم محمدٌ أنّ جنود الله الذين يعذبونكم في النار ويحبسونكم فيها تسعة عشر، وأنتم أكثر الناس عددًا وكثرة، أفيعجزكم مائةُ رجل منكم عن رجل منهم؟! فأنزل الله ﷿ في ذلك من قوله: <q>﴿وما جعلنا أصحاب النار إلا ملائكة وما جعلنا عدتهم إلا فتنة للذين كفروا﴾</q>{4}. (ز) <q>﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةࣰ لِّلَّذِینَ كَفَرُوا۟﴾</q> - تفسير ٧٩٨٢٦- عن عبد الله بن عباس، في قوله: <q>﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</q>، قال: قال أبو الأَشَدَّين: خَلُّوا بيني وبين خَزنة جهنم، أنا أكفيكم مُؤْنتهم. قال: وحُدِّثت: أنّ النبيَّ ﷺ وصف خُزّان جهنم، فقال: «كأنّ أعينهم البَرْق، وكأن أفواههم الصَّياصِيُّ{5}، يَجُرُّون أشعارهم، لهم مثل قوة الثّقلين، يُقبل أحدهم بالأُمّة مِن الناس يَسوقهم، على رقبته جبل، حتى يَرمي بهم في النار، فيَرمي بالجبل عليهم»{6}. (١٥/٨٠) ٧٩٨٢٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</q>: إلا بلاء{7}. (ز) ٧٩٨٢٨- قال مقاتل بن سليمان: <q>﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</q> يعني: خُزّان النار، <q>﴿وما جَعَلْنا عِدَّتَهُمْ﴾</q> يعني: قِلَّتهم <q>﴿إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</q> حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأَنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾</q> يقول: ما يَعلم كثرتهم أحد إلا الله، وأَنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: <q>﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾</q> [التحريم:٦]، <q>﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</q> يعني: خُزّان النار، <q>﴿وما جَعَلْنا عِدَّتَهُمْ﴾</q> يعني: قِلّتهم <q>﴿إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</q> يعني: أبا جهل، وأبا الأَشَدَّين، والمُستهزئين من قريش{3}. (ز) ٧٩٨٢٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</q>، قال: ما جعلناهم رجالًا، فيأخذ كلُّ رجل رجلًا كما قال هذا{7}. (ز) <q>﴿لِیَسۡتَیۡقِنَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟ إِیمَـٰنࣰا﴾</q> - تفسير ٧٩٨٣٠- عن عبد الله بن عباس -من طريق عطية- قوله: <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</q>، قال: وإنها في التوراة والإنجيل تسعة عشر، فأراد الله أن يَستَيقِن أهلُ الكتاب، ويَزداد الذين آمنوا إيمانًا{10}. (ز) ٧٩٨٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</q>، قال: يَجدونه مكتوبًا عندهم عِدّة خَزنة النار{11}. (١٥/٨٠) ٧٩٨٣٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</q>، قال: عِدّة خَزنة جهنم تسعة عشر في التوراة والإنجيل{12}. (ز) ٧٩٨٣٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</q>، قال: ليَستَيقن أهل الكتاب حين وافق عددُ خَزنة النار ما في كتابهم{13}. (١٥/٨٠) ٧٩٨٣٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</q>، قال: صدّق القرآنُ الكتبَ التي خَلتْ قبله؛ التوراة والإنجيل، أنّ خزنة جهنم تسعة عشر{14}. (١٥/٨١) ٧٩٨٣٥- عن عبد الملك ابن جُرَيْج: <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</q> إنهم يجدون عِدّتهم في كتابهم تسعة عشر، <q>﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</q> فيؤمنوا بما في كتابهم مِن عِدّتهم؛ فيَزدادوا بذلك إيمانًا{15}. (١٥/٨٠) ٧٩٨٣٦- قال مقاتل بن سليمان: <q>﴿لِيَسْتَيْقِنَ﴾</q> لكي يستيقن <q>﴿الَّذِينَ أُوتُوا الكِتابَ﴾</q> يقول: لِيَعلم مؤمنو أهل التوراة أنّ الذي قال محمد ﷺ حقٌّ؛ لأنّ عِدّة خُزّان جهنم في التوراة تسعة عشر، <q>﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</q> يعني: تصديقًا، ولا يشُكُّوا في محمدٍ ﷺ بما جاء به{3}. (ز) ٧٩٨٣٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</q>: أنك رسول الله{12}. (ز) <q>﴿لِیَسۡتَیۡقِنَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟ إِیمَـٰنࣰا﴾</q> - آثار متعلقة بالآية ٧٩٨٣٨- عن الرّبيع بن سليمان، قال: سمعتُ الشافعي يقول: الإيمان قول وعمل، يزيد بالطاعة، ويَنقص بالمعصية. ثم تلا هذه الآية: <q>﴿ويزداد الذين آمنوا إيمانًا﴾</q> الآية{18}. (ز) <q>﴿وَلَا یَرۡتَابَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَٱلۡمُؤۡمِنُونَ﴾</q> - تفسير ٧٩٨٣٩- قال مقاتل بن سليمان: <q>﴿ولا يَرْتابَ﴾</q> يقول: ولكي لا يرتاب، يعني: لكي لا يشكّ، يقول: لئلا يشكّ <q>﴿الَّذِينَ أُوتُوا الكِتابَ﴾</q> يعني: أهل التوراة، <q>﴿و﴾</q>لا يشكّ <q>﴿المُؤْمِنُونَ﴾</q> أنّ خَزنة جهنم تسعة عشر{3}. (ز) <q>﴿وَلِیَقُولَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ وَٱلۡكَـٰفِرُونَ مَاذَاۤ أَرَادَ ٱللَّهُ بِهَـٰذَا مَثَلࣰاۚ﴾</q> - تفسير ٧٩٨٤٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</q>، قال: الذين في قلوبهم النفاق{20}٦٨٨١. (١٥/٨١) ٦٨٨١ لم يذكر ابنُ جرير (٢٣/٤٤٠) غير قول قتادة. ٧٩٨٤١- قال مقاتل بن سليمان: <q>﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</q> يعني: الشكّ، وهم اليهود من أهل المدينة، <q>﴿والكافِرُونَ﴾</q> من أهل مكة، يعني: مشركي العرب: <q>﴿ماذا أرادَ اللَّهُ بِهذا مَثَلًا﴾</q> يعني: ذِكْره عِدّة خَزنة جهنم، يَستَقلُّونهم{3}. (ز) ٧٩٨٤٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ والكافِرُونَ ماذا أرادَ اللَّهُ بِهَذا مَثَلًا﴾</q>: يقولون: حين يُخوِّفنا بهؤلاء التسعة عشر{22}. (ز) <q>﴿كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ﴾</q> - نزول الآية ٧٩٨٤٣- قال مقاتل بن سليمان: حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾</q>، يقول: ما يَعلم كثرتهم أحد إلا الله. وأنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: <q>﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾</q> [التحريم:٦]{3}. (ز) <q>﴿كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ﴾</q> - تفسير الآية ٧٩٨٤٤- عن أبي سعيد الخُدري: أنّ رسول الله ﷺ حدّثهم عن ليلة أُسري به قال: «فصعدتُ أنا وجبريل إلى السماء الدنيا، فإذا أنا بمَلَكٍ يُقال له: إسماعيل، وهو صاحب سماء الدنيا، وبين يديه سبعون ألف مَلَك، مع كلّ مَلَكٍ منهم جنده مائة ألف». وتلا هذه الآية: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</q>{24}. (١٥/٨١) ٧٩٨٤٥- عن الحسن البصري: أنّ سائلًا سأل رسول الله عن خَلْق الملائكة: مِن أي شيء خُلقتْ؟ فقال: «من نور الحُجُب السبعين التي تَلي الرّبّ؛ كلّ حجاب منها مسيرة خمسمائة عام، فليس مَلَك إلا وهو يَدخل في نهر الحياة، فيَغتسل، فيكون مِن كلّ قطرة من ذلك الماء مَلَك، فلا يُحصي أحد ما يكون في يوم واحد». فهو قوله: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</q>{25}. (ز) ٧٩٨٤٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</q>، قال: من كثرتهم{26}. (١٥/٨١) ٧٩٨٤٧- عن عبد الملك ابن جُرَيْج، مثله{15}. (١٥/٨١) ٧٩٨٤٨- قال عطاء: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</q>، يعني: من الملائكة الذين خَلَقهم لتعذيب أهل النار، لا يَعلم عِدّتهم إلا الله{28}. (ز) ٧٩٨٤٩- قال مقاتل بن سليمان: <q>﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</q> مِن الكثرة حين استَقلُّوهم، فقال أبو جهل لقريش: أيَعجز ... مثل ما قال، في التقديم{29}. (ز) <q>﴿وَمَا هِیَ إِلَّا ذِكۡرَىٰ لِلۡبَشَرِ ۝٣١﴾</q> - تفسير ٧٩٨٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وما هِيَ إلّا ذِكْرى لِلْبَشَرِ﴾</q>، قال: النار{30}٦٨٨٢. (١٥/٨٢) ٦٨٨٢ أفاد قول مجاهد أنّ الضمير في <q>﴿هي﴾</q> عائد على النار، وقد ذكر ابنُ عطية (٨/٤٦١) هذا، وزاد قولين آخرين، فقال: «وقال بعض الحُذّاق: قوله تعالى: <q>﴿وما هِيَ﴾</q> يُراد بها الحال والمخاطبة والنذارة، قال الثعلبي: وقيل: <q>﴿وما هِيَ﴾</q> يراد نار الدنيا، أي: إنّ هذه تذكرةٌ للبشر بنار الآخرة». ٧٩٨٥١- عن قتادة بن دعامة -من طريق سعيد-، مثله{26}. (١٥/٨٢) ",footnotes:1:أورده الثعلبي ١٠/٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن أبي حاتم ٨/٢٦٩٨.الصياصي: قرون البقر. النهاية (صيص).عزاه السيوطي إلى ابن مردويه. وأخرج نحوه الثعلبي في تفسيره موقوفًا على ابن جريج ١٠/٧٤.أخرجه ابن جرير ٢٣/٤٣٧.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٣٧.أخرجه ابن جرير ٢٣/٤٣٨.أخرجه ابن جرير ٢٣/٤٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٣٩.أخرجه عبد الرزاق ٢/٣٢٩، وابن جرير ٢٣/٤٣٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٣٩.أخرجه أبو نعيم في حلية الأولياء ٩/١١٥.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٤٠.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه الطبراني في الأوسط ٧/١٣٨ (٧٠٩٧)، وفي الصغير ٢/١٦٢ (٩٥٨)، والبيهقي في دلائل النبوة ٢/٣٩٠-٣٩٦ مطولًا، من طريق راشد أبي محمد الحماني، عن أبي هارون، عن أبي سعيد الخدري به. وقال الهيثمي في المجمع ١/٨٠-٨١ (٢٥٩): «فيه أبو هارون، واسمه عمارة بن جُوين، وهو ضعيف جدًّا». وقال الذهبي في سير أعلام النبلاء ١/٢٢٥-٢٢٦: «هذا حديث غريب عجيب ...، وبسياق مثل هذا الحديث صار أبو هارون متروكًا».أخرجه يحيى بن سلام ٢/٧٧٥ مرسلًا. وينظر: تفسير ابن أبي زمنين ٥/٥٩-٦٠.أخرجه ابن جرير ٢٣/٤٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٨/٢٧١.تفسير مقاتل بن سليمان ٤/٤٩٨.أخرجه ابن جرير ٢٣/٤٤١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.
74,32," <q>﴿كَلَّا وَٱلۡقَمَرِ ۝٣٢﴾</q> - تفسير ٧٩٨٥٢- قال مقاتل بن سليمان: أقسم الرّبُّ مِن أجل سَقر، فقال: <q>﴿كَلّا والقَمَرِ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٨.
74,33," <q>﴿وَٱلَّیۡلِ إِذۡ أَدۡبَرَ ۝٣٣﴾</q> - قراءات ٧٩٨٥٣- عن هارون بن موسى النّحوي، قال: إنها في حرف أُبَيّ= (ز) ٧٩٨٥٤- وابن مسعود: (إذَآ أدْبَرَ) يعني: بألِفين{1}. (١٥/٨٣) ٧٩٨٥٥- عن عبد الله بن عباس، أنه قرأ: ‹واللَّيْلِ إذا دَبَرَ› فجعل الألف مع ‹إذا›{2}. (١٥/٨٢) ٧٩٨٥٦- عن عبد الله بن الزُّبير، أنه كان يقرأ: ‹واللَّيْلِ إذا دَبَرَ›{3}. (١٥/٨٢) ٧٩٨٥٧- عن الحسن البصري، أنه قرأها: ‹إذا دَبَرَ› مثل قراءة عبد الله بن عباس{4}. (١٥/٨٣) ٧٩٨٥٨- عن الحسن البصري، أنه قرأها: <q>﴿واللَّيْلِ إذْ﴾</q> بغير ألف <q>﴿أدْبَرَ﴾</q> بألف{5}٦٨٨٣. (١٥/٨٣) ٦٨٨٣ ذكر ابنُ جرير (٢٣/٤٤٢) القراءتين الواردتين في قوله: <q>﴿إذ أدبر﴾</q>، ثم علّق عليهما بقوله: «والصواب من القول في ذلك عندنا أنهما قراءتان معروفتان صحيحتا المعنى، فبأيّتهما قرأ القارئ فمصيب». ثم ذكر اختلاف أهل اللغة في ذلك، وعلّق بقوله: «والصواب من القول في ذلك عندي: أنهما لغتان بمعنًى، وذلك أنه محكي عن العرب: قبّح الله ما قَبل منه وما دَبر. وأخرى: أنّ أهل التفسير لم يُميّزوا في تفسيرهم بين القراءتين، وذلك دليل على أنهم فعلوا ذلك كذلك؛ لأنهما بمعنًى واحد». <q>﴿وَٱلَّیۡلِ إِذۡ أَدۡبَرَ ۝٣٣﴾</q> - تفسير الآية ٧٩٨٥٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ‹واللَّيْلِ إذا دَبَرَ›، قال: دُبُورُه: ظلامه{6}. (١٥/٨٣) ٧٩٨٦٠- عن مجاهد، قال: سألتُ ابن عباس عن قوله: ‹واللَّيْلِ إذا دَبَرَ›. فسكَتَ عني، حتى إذا كان مِن آخر الليل وسمع الأذان الأول ناداني: يا مجاهد، هذا حين دَبر الليل{7}. (١٥/٨٣) ٧٩٨٦١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿واللَّيْلِ إذْ أدْبَرَ﴾</q>: إذ ولّى{8}. (ز) ٧٩٨٦٢- قال مقاتل بن سليمان: <q>﴿واللَّيْلِ إذْ أدْبَرَ﴾</q>، يعني: إذا ذَهبتْ ظُلمته{9}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر. وهي قراءة شاذة، تروى أيضا عن الأعمش، ويونس بن عبيد، وغيرهما. انظر: البحر المحيط ٨/٣٦٩.عزاه السيوطي إلى أبي عبيد، وسعيد بن منصور، وعبد بن حميد، وابن المنذر. وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، وابن عامر، وشعبة، والكسائي، وأبو جعفر، وقرأ بقية العشرة: <q>﴿واللَّيْلِ إذْ أدْبَرَ﴾</q> بإسكان الذال، وهمزة بعدها. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٢.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.عزاه السيوطي إلى أبي عبيد، وابن المنذر.عزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٤٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه مسدد -كما في المطالب العالية (٤١٧٠)-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٤٢.أخرجه مقاتل بن سليمان ٤/٤٩٨.
74,34," <q>﴿وَٱلصُّبۡحِ إِذَاۤ أَسۡفَرَ ۝٣٤﴾</q> - تفسير ٧٩٨٦٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والصُّبْحِ إذا أسْفَرَ﴾</q>، قال: إذا أضاء{1}. (١٥/٨٣) ٧٩٨٦٤- قال مقاتل بن سليمان: <q>﴿والصُّبْحِ إذا أسْفَرَ﴾</q>، يعني: ضوءه عن ظُلمة الليل{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٠ من طريق معمر، وابن جرير ٢٣/٤٤٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٨.
74,35," <q>﴿إِنَّهَا لَإِحۡدَى ٱلۡكُبَرِ ۝٣٥﴾</q> - تفسير ٧٩٨٦٥- عن عبد الله بن عباس -من طريق عطية-: <q>﴿إنَّها لَإحْدى الكُبَرِ﴾</q>، يعني: جهنم{1}. (ز) ٧٩٨٦٦- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل- <q>﴿إنَّها لَإحْدى الكُبَرِ نَذِيرًا لِلْبَشَرِ﴾</q>، قال: هي جهنم{2}. (١٥/٨٤) ٧٩٨٦٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إنَّها لَإحْدى الكُبَرِ﴾</q>، قال: النار{3}. (١٥/٨٤) ٧٩٨٦٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿إنَّها لَإحْدى الكُبَرِ﴾</q>: يعني: جهنم{1}. (ز) ٧٩٨٦٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿إنَّها لَإحْدى الكُبَرِ﴾</q>: النار{5}. (١٥/٨٣) ٧٩٨٧٠- قال محمد بن السّائِب الكلبي: <q>﴿إنَّها لَإحْدى الكُبَرِ﴾</q> أراد بالكُبَر: دَرَكات جهنم، وهي سبعة: جهنم، ولَظى، والحُطَمة، والسَّعير، وسَقر، والجحيم، والهاوية{6}. (ز) ٧٩٨٧١- قال مقاتل بن سليمان: <q>﴿إنَّها﴾</q> إنّ سَقر <q>﴿لَإحْدى الكُبَرِ﴾</q> مِن أبواب جهنم السبعة: جهنم، ولَظى، والحُطَمة، والسَّعير، وسَقر، والجحيم، والهاوية{7}. (ز) ٧٩٨٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّها لَإحْدى الكُبَرِ﴾</q>، قال: هذه النار{8}٦٨٨٤. (ز) ٦٨٨٤ أفادت الآثار عوْد الضمير من قوله: <q>﴿إنها﴾</q> على جهنم. وقد ذكر ابنُ عطية (٨/٤٦٣) ذلك، ثم بيّن احتمال الآية وجهًا آخر، فقال: «ويحتمل أن يكون الضمير للنّذارة وأمر الآخرة، فهو للحال والقصة». ووجّهه بقوله: «وتكون هذه الآية مثل قوله ﷿: <q>﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ * أنْتُمْ عَنْهُ مُعْرِضُونَ﴾</q> [ص:٦٧، ٦٨]». ",footnotes:1:أخرجه ابن جرير ٢٣/٤٤٥.أخرجه ابن جرير ٢٣/٤٤٤. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٤٥.أخرجه عبد الرزاق ٢/٣٣٠، وابن جرير ٢٣/٤٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير البغوي ٨/٢٧٢.تفسير مقاتل بن سليمان ٤/٤٩٨-٤٩٩.أخرجه ابن جرير ٢٣/٤٤٤.
74,36," <q>﴿نَذِیرࣰا لِّلۡبَشَرِ ۝٣٦﴾</q> - تفسير ٧٩٨٧٣- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل-: <q>﴿نَذِيرًا لِلْبَشَرِ﴾</q>، يقول الله: أنا لكم منها نذير؛ فاتَّقوها{1}. (ز) ٧٩٨٧٤- قال الحسن البصري -من طريق قتادة-: واللهِ، ما أنذر الناسَ بشيء أدهى منها، أو بداهية هي أدهى منها{2}. (ز) ٧٩٨٧٥- قال مقاتل بن سليمان: <q>﴿نَذِيرًا﴾</q> يعني: تَذْكِرة <q>﴿لِلْبَشَرِ﴾</q> يعني: للعالمين{3}. (ز) ٧٩٨٧٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿نَذِيرًا لِلْبَشَرِ﴾</q>، قال: الخَلْق. قال: بنو آدمَ البشرُ. فقيل له: محمد النَّذير؟ قال: نعم، يُنذِرهم{1}٦٨٨٥. (ز) ٦٨٨٥ اختُلف في معنى قوله: <q>﴿نذيرا للبشر﴾</q> على أقوال: الأول: أي: النار. الثاني: أنّ ذلك من صفة الله تعالى، وهو خبر من الله عن نفسه، أنه نذير لخَلْقه. الثالث: ذلك من صفة رسول الله ﷺ. وعلّق ابنُ جرير (٢٣/٤٤٥) على القول الأول، فقال: «فعلى قول هؤلاء: النَّذير نُصب على القطع مِن إحْدى الكُبَر؛ لأن إحْدى الكُبَر مَعْرِفة، وقوله: <q>﴿نذيرا﴾</q> نكرة، والكلام قد يحسن الوقوف عليه دونه». وعلّق عليه ابنُ عطية (٨/٤٦٣)، فقال: «وهذا القول يقتضي أنّ <q>﴿نذيرا﴾</q> حال من الضمير في <q>﴿إنَّها﴾</q>، أو من قوله: <q>﴿لَإحْدى﴾</q>، وكذلك أيضًا على الاحتمال في أن تكون <q>﴿إنَّها﴾</q> يُراد بها: قصة الآخرة وحال المعاد». وعلّق ابنُ جرير على القول الثاني، فقال: «وعلى هذا القول يجب أن يكون نصب قوله: <q>﴿نذيرًا﴾</q> على الخروج مِن جملة الكلام المتقدم، فيكون معنى الكلام: وما جعلنا أصحاب النار إلا ملائكة نذيرًا للبشر، يعني: إنذارًا لهم؛ فيكون قوله: <q>﴿نذيرًا﴾</q> بمعنى: إنذارًا لهم؛ كما قال: <q>﴿كيف نذير﴾</q> [الملك:١٧]، بمعنى: إنذاري، ويكون أيضًا بمعنى: إنها إحْدى الكُبَر صَيّرنا ذلك كذلك نذيرًا، فيكون قوله: <q>﴿إنها لإحدى الكبر﴾</q> مُؤدّيًا عن معنى صيّرنا ذلك كذلك، وهذا المعنى قصد مَن قال ذلك إن شاء الله». وعلّق عليه ابنُ عطية (٥/٣٩٨)، فقال: «فهذا القول يَقتضي أنّ <q>﴿نذيرًا﴾</q> معمول لفعل تقديره: اعبدوا نذيرًا للبشر، أو ادعوا نذيرًا للبشر». وعلّق على القول الثالث، فقال: «فهذا القول يَقتضي أنّ <q>﴿نذيرًا﴾</q> معمول لفعل تقديره: نادِ نذيرًا، أو: بلغ نذيرًا، ونحو هذا». ",footnotes:1:أخرجه ابن جرير ٢٣/٤٤٦.أخرجه ابن جرير ٢٣/٤٤٥.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه ابن جرير ٢٣/٤٤٦.
74,37," <q>﴿لِمَن شَاۤءَ مِنكُمۡ أَن یَتَقَدَّمَ أَوۡ یَتَأَخَّرَ ۝٣٧﴾</q> - تفسير ٧٩٨٧٧- عن حُذيفة بن اليمان -من طريق رجل- قال: ما مِن صباح ولا مساء إلا ومنادٍ ينادي: يا أيها الناس، الرَّحيلَ الرَّحيلَ. وإنّ تصديق ذلك في كتاب الله: <q>﴿إنَّها لَإحْدى الكُبَرِ نَذِيرًا لِلْبَشَرِ لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾</q> قال: في الموت، <q>﴿أوْ يَتَأَخَّرَ﴾</q> قال: في الموت{1}. (١٥/٨٤) ٧٩٨٧٨- عن عبد الله بن عباس -من طريق عطية- <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ أوْ يَتَأَخَّرَ﴾</q>، قال: مَن شاء اتّبع طاعة الله، ومَن شاء تأخّر عنها{2}. (١٥/٨٤) ٧٩٨٧٩- قال الحسن البصري: وهذا وعيد لهم، كقوله: <q>﴿فَمَن شاءَ فَلْيُؤْمِن ومَن شاءَ فَلْيَكْفُرْ﴾</q> [الكهف:٢٩]{3}. (ز) ٧٩٨٨٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾</q> قال: في طاعة الله، <q>﴿أوْ يَتَأَخَّرَ﴾</q> قال: في معصية الله{4}٦٨٨٦. (١٥/٨٤) ٦٨٨٦ لم يذكر ابنُ جرير (٢٣/٤٤٦-٤٤٧) غير قول قتادة، وابن عباس. ٧٩٨٨١- قال مقاتل بن سليمان: <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾</q> في الخير، <q>﴿أوْ يَتَأَخَّرَ﴾</q> منه إلى المعصية، هذا تهديد، كقوله: <q>﴿فَمَن شاءَ فَلْيُؤْمِن ومَن شاءَ فَلْيَكْفُرْ﴾</q> [الكهف:٢٩]، وكقوله: <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q> [فصلت:٤٠]{5}٦٨٨٧. (ز) ٦٨٨٧ ذكر ابنُ عطية (٨/٤٦٤) نحو هذ القول، ثم علّق قائلًا: «هو بيان في النذارة، وإعلام بأنّ كلّ أحد يَسلك طريق الهدى والحق إذا حقّق النظر، أو بعينه يَتأخّر عن هذه الرُّتبة؛ لغفلته وسُوء نظره». ",footnotes:1:أخرجه ابن أبي الدنيا في قِصر الأمل (١٣٥).أخرجه ابن جرير ٢٣/٤٤٧.تفسير الثعلبي ١٠/٧٦.أخرجه ابن جرير ٢٣/٤٤٧. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٩٩.
74,38," <q>﴿كُلُّ نَفۡسِۭ بِمَا كَسَبَتۡ رَهِینَةٌ ۝٣٨﴾</q> - تفسير ٧٩٨٨٢- عن علي بن أبي طالب -من طريق زاذان- <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</q>، قال: مُرتَهنة{1}. (ز) ٧٩٨٨٣- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</q>، قال: مأخوذة بعملها{2}. (١٥/٨٤) ٧٩٨٨٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</q>، قال: كلّ نفس سَبقتْ لها كلمة العذاب يَرتَهنها الله في النار، لا يَرتهن اللهُ أحدًا من أهل الجنة، ألم تَسمع أنه قال: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</q> يقول: ليسوا رهينة، <q>﴿فِي جَنّاتٍ يَتَساءَلُونَ﴾</q>{3}. (ز) ٧٩٨٨٥- قال مقاتل بن سليمان: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</q>، يقول: كلّ كافر مُرتهن بذنوبه في النار{4}. (ز) ٧٩٨٨٦- عن يحيى بن سلّام -من طريق أحمد- في قوله: <q>﴿كل نفس﴾</q> يعني: مِن أهل النار <q>﴿بما كسبت﴾</q> بما عَمِلتْ <q>﴿رهينة﴾</q> في النار{5}. (ز) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٤-.أخرجه ابن جرير ٢٣/٤٤٧-٤٤٨.أخرجه ابن جرير ٢٣/٤٤٨-٤٤٩.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه أبو عمرو الداني في المكتفى ص٢٢٦ (٤٣).
74,39," <q>﴿إِلَّاۤ أَصۡحَـٰبَ ٱلۡیَمِینِ ۝٣٩﴾</q> - تفسير ٧٩٨٨٧- عن علي بن أبي طالب -من طريق زاذان- في قوله: <q>﴿إلّا أصْحابَ اليَمِينِ﴾</q>، قال: هم أطفال المسلمين{1}. (١٥/٨٥) ٧٩٨٨٨- عن عبد الله بن عباس -من طريق أبي ظَبْيان- في هذه الآية: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</q>، قال: هم الملائكة{2}. (ز) ٧٩٨٨٩- عن عبد الله بن عباس، في قوله: <q>﴿إلّا أصْحابَ اليَمِينِ﴾</q>، قال: هم المسلمون{3}. (١٥/٨٥) ٧٩٨٩٠- عن عبد الله بن عمر -من طريق أبي سهل- في قوله: <q>﴿إلّا أصْحابَ اليَمِينِ﴾</q>، قال: هم أطفال المسلمين{4}. (١٥/٨٥) ٧٩٨٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</q>، قال: لا يُحاسَبون{5}. (١٥/٨٥) ٧٩٨٩٢- قال الحسن البصري: <q>﴿إلّا أصْحابَ اليَمِينِ﴾</q> هم المسلمون المُخلصون= (ز) ٧٩٨٩٣- وعن الحسن البصري أيضًا: هم الذين كانوا ميامين على أنفسهم{6}. (ز) ٧٩٨٩٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</q>، قال: علَّق الناسَ كلّهم، إلا أصحاب اليمين{7}. (١٥/٨٤) ٧٩٨٩٥- قال مقاتل بن سليمان: <q>﴿إلّا أصْحابَ اليَمِينِ﴾</q> الذين أُعطوا كُتبهم بأيمانهم، ولا يُرتَهنون بذنوبهم في النار، ثم هم <q>﴿فِي جَنّاتٍ يَتَساءَلُونَ عَنِ المُجْرِمِينَ﴾</q>{8}. (ز) ٧٩٨٩٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</q>: أصحاب اليمين لا يُرتَهنون بذنوبهم، ولكن يَغفرها الله لهم. وقرأ قول الله -جلّ ثناؤه-: <q>﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q> [الصافات:٤٠]، قال: لا يُؤاخذهم الله بسيئ أعمالهم، ولكن يَغفرها الله لهم، ويَتجاوز عنهم كما وعدهم{9}٦٨٨٨. (ز) ٦٨٨٨ اختُلف فيمن عنى الله بقوله: <q>﴿إلا أصحاب اليمين﴾</q> على أقوال: الأول: أنهم المسلمون الصالحون. الثاني: أنهم أطفال المسلمين. الثالث: أنهم الملائكة. ولم يذكر ابنُ جرير (٢٣/٤٥٠) غير القول الثاني والثالث، ثم قال معلقًا عليهما: «وإنما قال مَن قال: أصحاب اليمين في هذا الموضع: هم الولدان وأطفال المسلمين، ومَن قال: هم الملائكة؛ لأنّ هؤلاء لم يكن لهم ذنوب، وقالوا: لم يكونوا ليسألوا المجرمين: <q>﴿ما سلككم في سقر﴾</q>؟ إلا أنهم لم يَقتَرفوا في الدنيا مآثم، ولو كانوا اقترفوها وعرفوها لم يكونوا ليسألوهم عما سلكهم في سَقر؛ لأن كلّ مَن دَخل من بني آدم ممن بلغ التكليف، ولزمه فرض الأمر والنهي، قد عَلم أنّ أحدًا لا يُعاقب إلا على المعصية». وزاد ابنُ عطية (٨/٤٦٤) في الآية قولًا آخر، حكاه عن الضَّحّاك، أنه قال: «هم الذين سَبَقتْ لهم من الله الحُسنى». ٧٩٨٩٧- عن يحيى بن سلّام -من طريق أحمد- في قوله: <q>﴿إلا أصحاب اليمين﴾</q>، قال: هم أصحاب الجنة كلّهم{10}. (ز) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٤-، وعبد الرزاق ٢/٢٧٠، ٣٢٩، ٣٣٠، وابن أبي شيبة ١٣/٢٨٥، وابن جرير ٣٢/٤٥٠، والحاكم ٢/٥٠٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم. وفي لفظ عند ابن جرير ٢٣/٤٥٠: هم الولدان.أخرجه ابن جرير ٢٣/٤٥٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٣٢٥. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٣/٤٤٨. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ١٠/٧٧، وتفسير البغوي ٨/٢٧٣، وعزا القول الثاني إلى مقاتل.أخرجه ابن جرير ٢٣/٤٤٨. وعزاه السيوطي إلى عَبد بن حُمَيد. وعند ابن جرير بلفظ: غَلِق.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه ابن جرير ٢٣/٤٤٨.أخرجه أبو عمرو الداني في المكتفى ص٢٢٦ (٤٣).
74,40," <q>﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾</q> - قراءات ٧٩٨٩٨- عن عمرو بن دينار، عن عبد الله بن الزُّبير، عن عمر أنه قرأ: (يَآ أيُّها المَرْءُ ما سَلَكَكَ فِي سَقَرَ). قال: أقرأنيها عمر، فلم أنسها بعد{1}. (ز) ٧٩٨٩٩- عن عمرو بن دينار -من طريق سفيان بن عُيينة- قال: سمعتُ عبد الله بن الزُّبير يقرأ: (فِي جَنّاتٍ يَتَسَآءَلُونَ عَنِ المُجْرِمِينَ يا فُلان ما سَلَكَكُمْ فِي سَقَرَ).= (ز) ٧٩٩٠٠- قال عمرو: وأخبرني لقيط قال: سمعتُ ابن الزُّبير قال: سمعتُ عمر بن الخطاب يقرؤها كذلك{2}. (١٥/٨٥) ٧٩٩٠١- عن عبد الله بن مسعود -من طريق أبي الزّعراء- أنه قرأ: (يَآ أيُّها الكُفّارُ ما سَلَكَكُمْ فِي سَقَرَ){3}. (١٥/٨٦) <q>﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾</q> - تفسير الآية ٧٩٩٠٢- عن عبد الله بن مسعود -من طريق أبي الزّعراء- في قصة ذكرها في الشفاعة، قال: ثُمَّ تَشفع الملائكة والنَّبيّون والشهداء والصالحون والمؤمنون، ويُشفّعهم الله، فيقول: أنا أرحم الراحمين. فيُخرِج مِن النار أكثرَ مما أخرج مِن جميع الخَلْق مِن النار، ثم يقول: أنا أرحم الراحمين. ثم قرأ عبد الله: (يَآ أيُّها الكُفّارُ ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ}، وعقَد بيده أربعًا، ثم قال: هل تَرون في هؤلاء مِن خير، ألا ما يُترك فيها أحدٌ فيه خير{4}. (ز) ٧٩٩٠٣- قال مقاتل بن سليمان: ... فلمّا أخرج الله أهل التوحيد من النارِ قال المؤمنون لِمَن بقي في النار: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</q>، يعني: ما جعلكم في سَقر؟ يعني: ما حبسكم في النار؟{5}. (ز) <q>﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾</q> - آثار متعلقة بالآية ٧٩٩٠٤- عن معونة بن قُرّة{6} -من طريق سلام- قال: ما يَسُرّني بهذه الآية الدنيا وما فيها؛ قوله ﷿: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</q>، ألا ترى أنه ليس فيهم خير{7}. (ز) ",footnotes:1:أخرجه أبو عبيد في فضائله (ت: الخياطي) ١/١٤١. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٦٥.أخرجه عبد الرزاق ٢/٣٣١، وابن أبي داود ص٥٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وعبد الله بن أحمد في زوائد الزهد، وابن الأنباري معًا في المصاحف، وابن المنذر، وابن أبي حاتم. ومهما يكن فهي قراءة شاذة. انظر: روح المعاني ٢٩/١٦٦.أخرجه أبو عبيد في فضائله ص١٨٧. وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة. انظر: روح المعاني ٢٩/١٦٦.أخرجه ابن جرير ٢٣/٤٥٢.تفسير مقاتل بن سليمان ٤/٤٩٩.كذا في المطبوع، ولعله: معاوية بن قرة، تصحفت.أخرجه ابن أبي الدنيا في كتاب حسن الظن بالله -موسوعة الإمام ابن أبي الدنيا ١/١٢٤ (١٤٩)-.
  74,41,""
  74,42,""
74,43," <q>﴿قَالُوا۟ لَمۡ نَكُ مِنَ ٱلۡمُصَلِّینَ ۝٤٣ وَلَمۡ نَكُ نُطۡعِمُ ٱلۡمِسۡكِینَ ۝٤٤﴾</q> - تفسير ٧٩٩٠٥- قال مقاتل بن سليمان: فأجابهم أهلُ النار عن أنفسهم، فـ<q>﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</q> في الدنيا لله، <q>﴿ولَمْ نَكُ نُطْعِمُ المِسْكِينَ﴾</q> في الدنيا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٩.
  74,44,""
74,45," <q>﴿وَكُنَّا نَخُوضُ مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥ وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾</q> - تفسير ٧٩٩٠٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وكُنّا نَخُوضُ مَعَ الخائِضِينَ﴾</q>، قال: يقولون: أي: كُلّما غوى غاوٍٍ غَوينا معه{1}. (١٥/٨٦) ٧٩٩٠٧- قال مقاتل بن سليمان: <q>﴿وكُنّا نَخُوضُ مَعَ الخائِضِينَ﴾</q> في الدنيا في الباطل والتكذيب كما يَخوض كفار مكة، <q>﴿وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ﴾</q> يعني: بيوم الحساب أنه غير كائن{2}. (ز) <q>﴿وَكُنَّا نَخُوضُ مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥ وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾</q> - آثار متعلقة بالآية ٧٩٩٠٨- قال ابن عون: ما رأيتُ أحدًا كان أعظم رجاء للمُوحِّدين مِن محمد بن سيرين، وكان يتلو هؤلاء الآيات: <q>﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</q> [الصافات:٣٥]، ويتلو: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ﴾</q>، ويتلو: <q>﴿لا يَصْلاها إلّا الأَشْقى الَّذِي كَذَّبَ وتَوَلّى﴾</q> [الليل:١٥-١٦]{3}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٠، وابن جرير ٢٣/٤٥١ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه ابن أبي الدنيا في كتاب حسن الظن بالله -موسوعة الإمام ابن أبي الدنيا ١/٨٣ (٦٧)-، وابن عساكر في تاريخ دمشق ٥٣/٢٠٦، وفيه: «وكان يتأول آيًا من القرآن» بدلًا من «يتلو».
  74,46,""
74,47," <q>﴿حَتَّىٰۤ أَتَىٰنَا ٱلۡیَقِینُ ۝٤٧﴾</q> - تفسير ٧٩٩٠٩- عن عبد الله بن عباس، <q>﴿حَتّى أتانا اليَقِينُ﴾</q>، قال: الموت{1}. (١٥/٨٦) ٧٩٩١٠- عن سالم بن عبد الله بن عمر، في قوله تعالى: <q>﴿حَتّى أتانا اليَقِينُ﴾</q>، قال: اليقين: الموت{1}. (١٥/٨٦) ٧٩٩١١- قال مقاتل بن سليمان: <q>﴿حَتّى أتانا اليَقِينُ﴾</q>، يعني: الموت{3}٦٨٨٩. (ز) ٦٨٨٩ رجّح ابنُ عطية (٨/٤٦٥) أنّ اليقين معناه: «صحة ما كانوا يُكذِّبون به مِن الرجوع إلى الله تعالى والدار الآخرة». ثم انتقد -مستندًا إلى الدلالة العقلية- القول بأنه الموت، فقال: «وقال المفسرون: اليَقِين: الموت. وذلك عندي هنا مُتعقّب؛ لأن نفس الموت يقين عند الكافر وهو حي، فإنما اليَقِين الذي عَنوا في هذه الآية فهو الشيء الذي كانوا يُكذِّبون به وهم أحياء في الدنيا، فتَيقّنوه بعد الموت، وإنما ُيُفَسَّر اليقين بالموت في قوله تعالى: <q>﴿واعْبُدْ رَبَّكَ حَتّى يَأْتِيَكَ اليَقِينُ﴾</q> [الحجر:٩٩]». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه مقاتل بن سليمان ٤/٤٩٩.
