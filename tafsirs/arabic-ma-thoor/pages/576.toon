quran[30]{c,v,t}:
  74,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ فَكَّرَ وَقَدَّرَ ۝١٨ فَقُتِلَ كَیۡفَ قَدَّرَ ۝١٩ ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا بُعِث النبيُّ ﷺ جمع الوليد بن المُغيرة قريشًا، فقال: ما تقولون؟ يعني: في هذا الرجل، فقال بعضهم: هو شاعر. وقال بعضهم: هو كاهن. فقال الوليد: سمعتُ قول الشاعر فما هو بشاعر، وسمعتُ قول الكهنة فما هو مثله. قالوا: فما تقول أنتَ؟ قال: فنظر ساعة، ثم فَكّر وقَدّر، <span class="qpc-hafs">﴿فَقُتِلَ كَيْفَ قَدَّرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿سِحْرٌ يُؤْثَرُ﴾</span>{1}. (١٥/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٧٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد</span>: إنّ الوليد بن المُغيرة كان يَغشى النبيَّ ﷺ وأبا بكر ﵁، حتى حَسبتْ قريش أنه يُسلم، فقال له أبو جهل: إنّ قريشًا تزعم أنك إنما تأتي محمدًا وابن أبي قُحافة تُصيب من طعامهما. فقال الوليد لقريش: إنكم ذوو أحساب وذوو أحلام، وإنكم تزعمون أنّ محمدًا مجنون، وهل رأيتموه يُجَنُّ قطّ؟ قالوا: اللهم، لا. قال: تزعمون أنه كاهن، وهل رأيتموه يتكهّن قطّ؟ قالوا: اللهم، لا. قال: تزعمون أنه شاعر، هل رأيتموه يَنطق بشعرٍ قطّ؟ قالوا: لا. قال: فتزعمون أنه كذّاب، فهل جربتم عليه شيئًا من الكذب؟ قالوا: لا. قالتْ قريش للوليد: فما هو؟ فتفَكّر في نفسه، ثم نَظر، وعبس، فقال: ما هو إلا ساحر، وما يقوله سحرٌ. فذلك قوله: <span class="qpc-hafs">﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</span> إلى قوله تعالى: <span class="qpc-hafs">﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٧٤<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق سعيد- <span class="qpc-hafs">﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</span>، قال: ذُكر لنا أنه قال: لقد نظرتُ فيما قال هذا الرجل، فإذا هو ليس بشعرٍ، وإنّ له لَحلاوة، وإن عليه لَطُلاوَةً، وإنه ليَعلو ولا يُعلى، وما أشكّ أنه سحرٌ. فأنزل الله فيه: <span class="qpc-hafs">﴿فَقُتِلَ كَيْفَ قَدَّرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿وبَسَرَ﴾</span>{3}. (١٥/٧٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ فَكَّرَ وَقَدَّرَ ۝١٨ فَقُتِلَ كَیۡفَ قَدَّرَ ۝١٩ ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿فَكَّرَ وقَدَّرَ﴾</span>، قال: الوليد بن المُغيرة يوم دار النَّدوة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٧٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾</span> يعني: الوليد بن المُغيرة، دعاه نبي الله ﷺ إلى الإسلام، فقال: حتى أنظر. ففكّر، <span class="qpc-hafs">﴿ثُمَّ نَظَرَ ثُمَّ عَبَسَ وبَسَرَ ثُمَّ أدْبَرَ واسْتَكْبَرَ فَقالَ إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</span>. فجَعل الله له سَقر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٧٧<span class="dash">-</span></span> قال <span class="name-2">محمد بن شهاب الزُّهريّ</span>: <span class="qpc-hafs">﴿فَقُتِلَ﴾</span> عُذّب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾</span> ثم قال -يعني: الوليد بن المُغيرة-: <span class="qpc-hafs">﴿إنَّهُ فَكَّرَ﴾</span> في أمْر محمد ﷺ، فزعم أنه ساحر، وقال مثل ما قال في التقديم، <span class="qpc-hafs">﴿وقَدَّرَ﴾</span> في قوله: إنّ محمدًا يُفرّق بين الاثنين. <span class="qpc-hafs">﴿فَقُتِلَ كيف قدر﴾</span> يقول: فلُعِن كيف قدَّر السحر، <span class="qpc-hafs">﴿ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾</span> يعني: ثم لُعِن كيف قدّر السِّحر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿فَقُتِلَ كَيْفَ قَدَّرَ ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾</span>، قال: قُتل كيف قدّر حين قال: ليس بشعرٍ. ثم قُتل كيف قدّر حين قال: ليس بكهانة{4}<span class=comment-ref>٦٨٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٥٧-٤٥٨) في قوله: <span class="qpc-hafs">﴿فقتل كيف قدر﴾</span> احتمالين: <b>الأول</b>: «أن يكون دعاء عليه على معنى تقبيح حاله». ثم <span class="comment-type-1">وجّه</span> معنى قوله: <span class="qpc-hafs">﴿ثم نظر﴾</span> على هذا الاحتمال، فقال: «وعلى التأويل الأول أنّ الدعاء عليه دعاء على مُستقبح فعله يجيء قوله: <span class="qpc-hafs">﴿ثُمَّ نَظَرَ﴾</span> معنىً معادًا بعينه؛ لأن <span class="qpc-hafs">﴿فَكَّرَ وقَدَّرَ﴾</span> يقتضيه، لكنه إخبار بترديده النظر في الأمر، وقد رُوي أنّ النبي ﷺ دعا الوليد فقال له: «<b>أنظُرُ وأُفَكِّرُ</b>». فلمّا فَكّر قال ما تقدم». <b>الثاني</b>: «يحتمل أن يكون دعاء مقتضاه استحسان منزعه الأول في مدحه القرآن، وفي نفيه الشعر والكهانة والجنون عنه، فيجري هذا <span class="mustanad">مجرى قول النبي</span> ﷺ لأبي جَندل بن سهيل: «<b>ويل أمه، مسْعَر حرب</b>». ومجرى قول عبد الملك بن مروان: قاتل الله كُثَيِّرًا، كأنه رآنا حين قال كذا. وهذا معنًى <span class="mustanad">مشهور في كلام العرب</span>». ثم <span class="comment-type-1">وجّه</span> معنى قوله: <span class="qpc-hafs">﴿ثم نظر﴾</span> على هذا الاحتمال، فقال: «وإذا قلنا إنّ ذلك دعاء على مستحسن فعله فيجيء قوله تعالى: <span class="qpc-hafs">﴿ثُمَّ نَظَرَ﴾</span> فيما احتج به للقرآن، فرأى ما فيه من علوِّ مرتبة محمد ﵇، فـ<span class="qpc-hafs">﴿عَبَسَ﴾</span> لذلك، <span class="qpc-hafs">﴿وبَسَرَ﴾</span> أي: قطب، وقبض ما بين عينيه، واربدَّ وجهه حسدًا له».</div></p></div>",footnotes:1:عزاه السيوطي إلى أبي نعيم في الدلائل.علقه الواحدي في أسباب النزول (٧٠١).أخرجه ابن جرير ٢٣/٤٣٠. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٣١.أخرجه ابن جرير ٢٣/٤٣١.تفسير الثعلبي ١٠/٧٣، وتفسير البغوي ٨/٢٦٩.تفسير مقاتل بن سليمان ٤/٤٩٥-٤٩٦.أخرجه ابن جرير ٢٣/٤٣١.
  74,19,""
  74,20,""
  74,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ نَظَرَ ۝٢١ ثُمَّ عَبَسَ وَبَسَرَ ۝٢٢ ثُمَّ أَدۡبَرَ وَٱسۡتَكۡبَرَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> <span class="qpc-hafs">﴿وبَسَرَ﴾</span>، قال: كَلَح{1}. (١٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿عَبَسَ وبَسَرَ﴾</span>، قال: قَبض ما بين عينيه، وكَلَح{2}. (١٥/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٨٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿عَبَسَ وبَسَرَ﴾</span>، قال: عَبَس، وكَلَح{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ نَظَرَ﴾</span> فيما يقول لمحمد ﷺ مِن السِّحر، <span class="qpc-hafs">﴿ثُمَّ عَبَسَ﴾</span> وجهه، يعني: كَلَح. كقوله: <span class="qpc-hafs">﴿عَبَسَ وتَوَلّى﴾</span> [عبس:١]، يعني: كَلَح في وجه ابن أم مكتوم. <span class="qpc-hafs">﴿وبَسَرَ﴾</span> يعني: وتغيّر لون وجهه، يعني: أعرَض عن الإيمان، <span class="qpc-hafs">﴿واسْتَكْبَرَ﴾</span> عنه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٣٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٣٠.تفسير مقاتل بن سليمان ٤/٤٩٣-٤٩٦.
  74,22,""
  74,23,""
  74,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَالَ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ یُؤۡثَرُ ۝٢٤ إِنۡ هَـٰذَاۤ إِلَّا قَوۡلُ ٱلۡبَشَرِ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾</span>، قال: يَأْثُره عن غيره{1}. (١٥/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٨٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إنْ هَذا إلا قَوْلُ البشر﴾</span>، يَعنون: عَدّاسًا غلام عُتْبَة. كقوله: <span class="qpc-hafs">﴿ولَقَدْ نَعْلَمُ أنَّهُمْ يَقُولُونَ إنَّما يُعَلِّمُهُ بَشَرٌ﴾</span> [النحل:١٠٣] هو عَدّاس{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقالَ﴾</span> الوليد لقومه: <span class="qpc-hafs">﴿إنْ هَذا﴾</span> الذي يقول محمد <span class="qpc-hafs">﴿إلّا سِحْرٌ يُؤْثَرُ إنْ هَذا إلّا قَوْلُ البَشَرِ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٣٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٥٧-.تفسير مقاتل بن سليمان ٤/٤٩٣-٤٩٦.
  74,25,""
  74,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَأُصۡلِیهِ سَقَرَ ۝٢٦ وَمَاۤ أَدۡرَىٰكَ مَا سَقَرُ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿سَقَرُ﴾</span> أسفل الجحيم، نابتٌ فيها شجرة الزَّقوم{1}. (١٥/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَأُصْلِيهِ سَقَرَ﴾</span>، يعني: الباب الخامس من جهنم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٣-٤٩٦.
  74,27,""
  74,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا تُبْقِي﴾</span> إذا أخذتْ فيهم لم تُبق منهم شيئًا، وإذا بُدِّلوا خَلْقًا جديدًا لم تَذرْ أن تُعاودهم سبيل العذاب الأول{1}. (١٥/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٠<span class="dash">-</span></span> عن <span class="name-2">ابن بُرَيْدة</span>، <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span>، قال: تأكل اللحم، والعظم، والعِرق، والمخ، ولا تَذره على ذلك{1}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span>، قال: لا تُحْيِي، ولا تميت{3}<span class=comment-ref>٦٨٧٨</span>. (١٥/٧٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٨</span> لم يذكر <u>ابنُ جرير</u> (٢٣/٤٣٣) غير قول مجاهد، ومزيدة.</div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span> تأكله كلّه، فإذا تَبدّى خَلْقه لم تَذره حتى تقوم عليه{1}. (١٥/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span>: لا تُبقي لهم لحمًا، ولا تَذر لهم عظمًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٤<span class="dash">-</span></span> عن <span class="name-3">مَزِيدة [بن جابر الهجري]</span> -من طريق [محمد بن عبد الرحمن] بن أبي ليلى- في قوله: <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span>، قال: لا تُبقي منهم شيئًا أن تأكلهم، فإذا خُلِقوا لها لا تَذرهم حتى تأخذهم فتَأكلهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا تُبْقِي ولا تَذَرُ﴾</span> يعني: لا تُبْقِي النار إذا رَأتْهم حتى تأكلهم، ولا تَذرهم إذا حَلَفُوا لها حتى تواقعهم{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٩٦<span class="dash">-</span></span> عن أبي هريرة، عن رسول الله ﷺ: «<b>قال موسى لربّه ﷿: أيُّ عبادك أفقرُ؟ قال: صاحب سقر</b>»{8}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٣٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٧٤، وتفسير البغوي ٨/٢٧٠.أخرجه ابن جرير ٢٣/٤٣٣.تفسير مقاتل بن سليمان ٤/٤٩٦.أخرجه الثعلبي ١٠/٧٣.
  74,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوَّاحَةࣱ لِّلۡبَشَرِ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٧٩٧<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق عبد الله بن أبي الهُذيل- في قوله ﷿: <span class="qpc-hafs">﴿لواحة للبشر﴾</span>، قال: تَلقاهم جهنم يوم القيامة، فتَلفحهم لَفحةً، فلا تَترك لحمًا على عظمٍ إلا وضعتْه على العراقيب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لَوّاحَةٌ﴾</span>، قال: مُحرِقة{2}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٧٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، يقول: مُغَيِّرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، قال: تُلوِّح الجلد، فتَحرقه، فيَتغيّر لونه، فيصير أسودَ من الليل{4}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠١<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق إسماعيل بن سُمَيع- <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، قال: تُلَوِّح جلده حتى تَدعه أشدّ سوادًا من الليل. وفي رواية: غيَّرت جلودَهم فاسودَّت{5}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، قال: للجلد{6}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٣<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، يعني: بَشر الإنسان، يقول: تَحرق بَشره{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعني: تَلوح لهم جهنم حتى يَروها عيانًا{8}<span class=comment-ref>٦٨٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٧٩</span> ذكر <u>ابنُ عطية</u> (٨/٤٥٩) قول الحسن، و<span class="comment-type-1">وجّهه</span> بقوله: «فالمعنى: أنها تظهر للناس -وهم البشر- مِن مسيرة خمسمائة عام، وذلك لعِظَمها وهولها وزفيرها».</div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، قال: حرّاقة للجلد{6}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- <span class="qpc-hafs">﴿لواحة للبشر﴾</span>، قال: بَشرة الإنسان تُلَوَّح على النار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٧<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابن أبي هلال- قال: <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، أي: تُلَوَّح أجسادهم عليها{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span> مُحرِقة للخَلْق{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لَوّاحَةٌ لِلْبَشَرِ﴾</span>، قال: تُغيّر البشَر، تَحرق البشَر، يقال: قد لاحه استقباله السماء، ثم قال: والنار تُغيّر ألوانهم{7}<span class=comment-ref>٦٨٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٠</span> لم يذكر <u>ابنُ جرير</u> (٢٣/٤٣٣-٤٣٥) غير قول عبد الرحمن بن زيد، وقتادة، والضَّحّاك، ومجاهد، وأبي رَزِين، وزيد بن أسلم، وابن عباس من طريق علي.</p><p>و<span class="comment-type-1">وجّهه</span> <u>ابنُ عطية</u> (٨/٤٥٨) قائلا: "فالبَشَر: جمع بشَرة، <span class="mustanad">وتقول العرب</span>: لاحت النارُ الشيءَ إذا أحرقَتْه وسَوّدتْه. وقال الشاعر:</p><p>لاحَهُ الصيفُ والغِيارُ وإشفا ... قٌ على سقبة كقوس الضالِ</p><p>وأنشد أبو عبيدة:</p><p>... يا ابنة عمي لاحَني الهواجرُ".</div></p></div>",footnotes:1:أخرجه البيهقي في البعث والنشور ص٢٨٩.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وعند ابن أبي حاتم -كما في الإتقان ٢/٥٠- بلفظ: مُغَيِّرة، من طريق علي كما في الأثر التالي.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٥٠-، وأخرجه ابن جرير ٢٣/٤٣٥، بلفظ: مُعَرِّضة، ثم قال: وأخشى أن يكون خبر علي بن أبي طلحة، عن ابن عباس هذا، غلطًا، وأن يكون موضع «معرضة»: «مغيرة»، لكن صُحِّف فيه.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي شيبة ١٣/١٥٣، وهناد (٣٠٥)، وابن جرير ٢٣/٤٣٤-٤٣٥.أخرجه ابن جرير ٢٣/٤٣٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٣٥.تفسير الثعلبي ١٠/٧٤، وتفسير البغوي ٨/٢٧٠.أخرجه ابن جرير ٢٣/٤٣٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٥.أخرجه ابن جرير ٢٣/٤٣٤.تفسير مقاتل بن سليمان ٤/٤٩٦.أخرجه ابن جرير ٢٣/٤٣٥.
  74,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨١٠<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق عامر-: أنّ رهطًا مِن اليهود سألوا رجلًا مِن أصحاب النبيِّ ﷺ عن خَزنة جهنم. فقال: الله ورسوله أعلم. فجاء، فأخبَر النَّبيّ ﷺ؛ فنَزل عليه ساعتئذ: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span>{1}. (١٥/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: لَمّا سمع أبو جهل: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> قال لقريش: ثَكِلتْكم أُمّهاتكم، أسمعُ ابنَ أبي كَبْشَة يُخبركم أنّ خَزنة النار تسعة عشر، وأنتم الدَّهْم{2}! أفيَعجز كلُّ عشرة منكم أن يَبطشوا برجلٍ من خَزنة جهنم؟! فأوحى الله إلى نبيّه أن يأتي أبا جهل، فيأخذ بيده في بطحاء مكة، فيقول له: <span class="qpc-hafs">﴿أوْلى لَكَ فَأَوْلى ثُمَّ أوْلى لَكَ فَأَوْلى﴾</span> [القيامة:٣٤-٣٥]{3}. (١٥/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: لما نزلت هذه الآية <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> قال أبو جهل لقريش: ثَكِلتْكم أُمّهاتكم، أسمع ابن أبي كَبْشَة يُخبِر أنّ خَزنة النار تسعة عشر وأنتم الدَّهْم! -أي: الشّجعان- أفيَعجز كلّ عشرة منكم أن يَبطشوا بواحد من خَزنة جهنم؟! قال أبو الأشَدِّ أُسَيْد بن كَلَدَة بن خَلف الجُمحيّ: أنا أكفيكم منهم سبعة عشر؛ عشرة على ظهري، وسبعة على بطني، فاكفوني أنتم اثنين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٣<span class="dash">-</span></span> عن <span class="name-3">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span>، قال: ذُكر لنا: أنّ أبا جهل حين أُنزِلَتْ هذه الآية قال: يا معشر قريش، ما يستطيع كلّ عشرة منكم أن يغلبوا واحدًا مِن خَزنة النار وأنتم الدَّهْمُ؟!{5}. (١٥/٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨١٤<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال ناس من اليهود لأناس مِن أصحاب النبِيِّ ﷺ: هل يَعلم نبيُّكم عددَ خَزنة جهنم؟ قالوا: لا ندري حتى نسأله. فجاءوا إلى النبي ﷺ، فقالوا: كم عدد خَزنة جهنم؟ قال: «<b>هكذا، وهكذا</b>». في مرّة عشرة، وفي مرّة تسعة{6}. (١٥/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span>، قال: جُعلوا فتنة. قال: قال أبو الأَشَدَّين الجُمحيّ: لا يَبلغون رَبوتي حتى أُجهِضَهم{7} عن جهنم{8}. (١٥/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٦<span class="dash">-</span></span> قال <span class="name-2">عمرو بن دينار</span>: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> إنّ واحدًا منهم يَدفع بالدّفعة الواحدة في جهنم أكثر من ربيعة ومُضر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> يقول: في النار من الملائكة تسعة عشر خَزنتها؛ يعني: مالكًا ومَن معه ثمانية عشر مَلكًا، أعينهم كالبَرْق الخاطف، وأنيابهم كالصَّياصيّ -يعني: مثل قرون البقر-، وأشعارهم تمسّ أقدامهم، يَخرج لهب النار مِن أفواههم، ما بين مَنكِبي أحدهم مسيرة سبعين سنة، يَسع كفُّ أحدهم مثل ربيعة ومضر، قد نُزعتْ منهم الرأفة والرحمة غِضابًا، يدفع أحدهم سبعين ألفًا، فيُلقيهم حيث أراد من جهنم، فيَهوي أحدهم في جهنم مسيرة أربعين سنة، لا تَضُرّهم النار؛ لأنّ نورهم أشدّ مِن حرّ النار، ولولا ذلك لم يُطيقوا دخول النار طرْفة عين، فلمّا قال الله: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> قال أبو جهل بن هشام: يا معشر قريش، ما لِمُحمد من الجنود إلا تسعة عشر، ويزعم أنهم خَزنة جهنم، يُخوّفكم بتسعة عشر وأنتم الدَّهْم! أيَعجز كلّ مائة منكم أن تَبطش بواحد منهم، فيَخرجوا منها؟! وقال أبو الأَشَدَّين اسمه أُسَيْد بن كَلَدَة بن خلف الجُمحيّ: أنا أكفيكم سبعة عشر؛ أحمل منهم عشرة على ظهري، وسبعة على صدري، واكفوني منهم اثنين. وكان شديدًا فسُمّي: أبا الأَشَدَّين؛ لشدّته بذلك سُمّي، وكنيته: أبو الأعور{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span>، قال: خَزنتها تسعة عشر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨١٩<span class="dash">-</span></span> عن رجل من بني تميم -من طريق الأزرق بن قيس- قال: كُنّا عند أبي العوّام، فقرأ هذه الآية: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span>. فقال: ما تقولون أتسعة عشر مَلكًا، أو تسعة عشر ألفًا؟ قلتُ: لا، بل تسعة عشر مَلكًا. فقال: ومَن أين علمتَ ذلك؟ قلتُ: لأنّ الله يقول: <span class="qpc-hafs">﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</span>. قال: صدقتَ، هم تسعة عشر مَلكًا، بيد كلّ مَلكٍ منهم مِرْزَبّة مِن حديد له شُعبتان، فيَضرب بها الضربة يَهوي بها في جهنم سبعين ألفًا، بين مَنكِبي كلّ مَلكٍ منهم مسيرة كذا وكذا{12}. (١٥/٧٩)</p></p><p></div></p></div>",footnotes:1:أخرجه البيهقي في البعث والنشور ص٢٦٩ (٤٦٢)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٦٨-، من طريق حُريث بن أبي مطر، عن عامر، عن البراء بن عازب به.</p><p>قال البيهقي: «حديث ابن أبي مطر ليس بالقوي». وقال ابن رجب في التخويف من النار ص٢١٩: «حُريث هو ابن أبي مطر ضعيف». وقال ابن كثير: «هكذا وقع عند ابن أبي حاتم، عن البراء، والمشهور عن جابر بن عبد الله».الدَّهْم: سيأتي معناه في الأثر التالي.أخرجه ابن جرير ٢٣/٤٣٦، من طريق عطية العَوفيّ، عن ابن عباس به.</p><p>الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.تفسير البغوي ٨/٢٧٠.أخرجه ابن جرير ٢٣/٤٣٦. وعزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه عبد الرزاق ٢/٣٣١ بنحوه من طريق معمر، وكذا ابن جرير ٢٣/٤٣٦.أخرجه الترمذي ٥/٥٢١-٥٢٢ (٣٦١٦) مطولًا، من طريق مجالد، عن الشعبي، عن جابر بن عبد الله به.</p><p>قال الترمذي: «هذا حديث إنما نعرفه من هذا الوجه من حديث مجالد». وقال ابن رجب في التخويف من النار ص٢٢٠: «وهذا أصح من حديث حُريث المتقدم، قاله البيهقي وغيره».أجهضته عن مكانه: أزلته. والإجهاض: الإزلاق. النهاية (جهض).أخرجه ابن جرير ٢٣/٤٣٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/٧٤، وتفسير البغوي ٨/٢٧٠.تفسير مقاتل بن سليمان ٤/٤٩٦-٤٩٧.أخرجه ابن جرير ٢٣/٤٣٧.أخرجه ابن المبارك (٣٤٠- زوائد نعيم)، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٤-، وابن أبي شيبة ١٣/١٧٣-١٧٤، والبيهقي في البعث (٥١١)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٢ (٦١)-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. كما أخرجه يحيى بن سلام ١/٣٦٠ مختصرًا، وذكر الرواية عن: الأزرق بن قيس عن أبي العوام سادن بيت المقدس.
  74,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةࣰ لِّلَّذِینَ كَفَرُوا۟﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٢٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢١<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٢<span class="dash">-</span></span> و<span class="name-3">قتادة</span>: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> قال أبو جهل لقريش: ثَكِلتْكم أُمّهاتكم، أسمع ابن أبي كَبْشَة يُخبركم أنّ خَزنة النار تسعة عشر، وأنتم الدَّهم! -أي: الشّجعان- أفَيعجز كلّ عشرة منكم أن يَبطشوا برجلٍ من خَزنة جهنم؟! فقال أبو الأَشَدَّين كَلَدَة بن خَلف بن أسد الجُمحيّ: أنا أكفيكم منهم سبعة عشر؛ عشرة على ظهري، وسبعة على بطني، واكفوني أنتم اثنين. فأنزل الله ﷾: <span class="qpc-hafs">﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: لَمّا نزلت: <span class="qpc-hafs">﴿عَلَيْها تِسْعَةَ عَشَرَ﴾</span> قال رجل من قريش -يُدعى: أبا الأَشَدَّين-: يا معشر قريش، لا يَهولنَّكم التسعة عشر، أنا أدفع عنكم بمَنكِبي الأيمن عشرة، وبمَنكِبي الأيسر تسعة. فأنزل الله: <span class="qpc-hafs">﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</span>{2}. (١٥/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</span> حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأَنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾</span>. وأَنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: <span class="qpc-hafs">﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾</span> [التحريم:٦]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: قال أبو جهل يومًا وهو يهزأُ برسول الله ﷺ، وبما جاء به من الحق: يا معشر قريش، يزعم محمدٌ أنّ جنود الله الذين يعذبونكم في النار ويحبسونكم فيها تسعة عشر، وأنتم أكثر الناس عددًا وكثرة، أفيعجزكم مائةُ رجل منكم عن رجل منهم؟! فأنزل الله ﷿ في ذلك من قوله: <span class="qpc-hafs">﴿وما جعلنا أصحاب النار إلا ملائكة وما جعلنا عدتهم إلا فتنة للذين كفروا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةࣰ لِّلَّذِینَ كَفَرُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</span>، قال: قال أبو الأَشَدَّين: خَلُّوا بيني وبين خَزنة جهنم، أنا أكفيكم مُؤْنتهم. قال: وحُدِّثت: أنّ النبيَّ ﷺ وصف خُزّان جهنم، فقال: «<b>كأنّ أعينهم البَرْق، وكأن أفواههم الصَّياصِيُّ{5}، يَجُرُّون أشعارهم، لهم مثل قوة الثّقلين، يُقبل أحدهم بالأُمّة مِن الناس يَسوقهم، على رقبته جبل، حتى يَرمي بهم في النار، فيَرمي بالجبل عليهم</b>»{6}. (١٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</span>: إلا بلاء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</span> يعني: خُزّان النار، <span class="qpc-hafs">﴿وما جَعَلْنا عِدَّتَهُمْ﴾</span> يعني: قِلَّتهم <span class="qpc-hafs">﴿إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</span> حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأَنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾</span> يقول: ما يَعلم كثرتهم أحد إلا الله، وأَنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: <span class="qpc-hafs">﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾</span> [التحريم:٦]، <span class="qpc-hafs">﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</span> يعني: خُزّان النار، <span class="qpc-hafs">﴿وما جَعَلْنا عِدَّتَهُمْ﴾</span> يعني: قِلّتهم <span class="qpc-hafs">﴿إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾</span> يعني: أبا جهل، وأبا الأَشَدَّين، والمُستهزئين من قريش{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٢٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾</span>، قال: ما جعلناهم رجالًا، فيأخذ كلُّ رجل رجلًا كما قال هذا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِیَسۡتَیۡقِنَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟ إِیمَـٰنࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</span>، قال: وإنها في التوراة والإنجيل تسعة عشر، فأراد الله أن يَستَيقِن أهلُ الكتاب، ويَزداد الذين آمنوا إيمانًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</span>، قال: يَجدونه مكتوبًا عندهم عِدّة خَزنة النار{11}. (١٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</span>، قال: عِدّة خَزنة جهنم تسعة عشر في التوراة والإنجيل{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</span>، قال: ليَستَيقن أهل الكتاب حين وافق عددُ خَزنة النار ما في كتابهم{13}. (١٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</span>، قال: صدّق القرآنُ الكتبَ التي خَلتْ قبله؛ التوراة والإنجيل، أنّ خزنة جهنم تسعة عشر{14}. (١٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</span> إنهم يجدون عِدّتهم في كتابهم تسعة عشر، <span class="qpc-hafs">﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</span> فيؤمنوا بما في كتابهم مِن عِدّتهم؛ فيَزدادوا بذلك إيمانًا{15}. (١٥/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ﴾</span> لكي يستيقن <span class="qpc-hafs">﴿الَّذِينَ أُوتُوا الكِتابَ﴾</span> يقول: لِيَعلم مؤمنو أهل التوراة أنّ الذي قال محمد ﷺ حقٌّ؛ لأنّ عِدّة خُزّان جهنم في التوراة تسعة عشر، <span class="qpc-hafs">﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾</span> يعني: تصديقًا، ولا يشُكُّوا في محمدٍ ﷺ بما جاء به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾</span>: أنك رسول الله{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِیَسۡتَیۡقِنَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟ إِیمَـٰنࣰا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٣٨<span class="dash">-</span></span> عن الرّبيع بن سليمان، قال: سمعتُ الشافعي يقول: الإيمان قول وعمل، يزيد بالطاعة، ويَنقص بالمعصية. ثم تلا هذه الآية: <span class="qpc-hafs">﴿ويزداد الذين آمنوا إيمانًا﴾</span> الآية{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَرۡتَابَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَٱلۡمُؤۡمِنُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَرْتابَ﴾</span> يقول: ولكي لا يرتاب، يعني: لكي لا يشكّ، يقول: لئلا يشكّ <span class="qpc-hafs">﴿الَّذِينَ أُوتُوا الكِتابَ﴾</span> يعني: أهل التوراة، <span class="qpc-hafs">﴿و﴾</span>لا يشكّ <span class="qpc-hafs">﴿المُؤْمِنُونَ﴾</span> أنّ خَزنة جهنم تسعة عشر{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِیَقُولَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ وَٱلۡكَـٰفِرُونَ مَاذَاۤ أَرَادَ ٱللَّهُ بِهَـٰذَا مَثَلࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</span>، قال: الذين في قلوبهم النفاق{20}<span class=comment-ref>٦٨٨١</span>. (١٥/٨١)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨١</span> لم يذكر <u>ابنُ جرير</u> (٢٣/٤٤٠) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٧٩٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾</span> يعني: الشكّ، وهم اليهود من أهل المدينة، <span class="qpc-hafs">﴿والكافِرُونَ﴾</span> من أهل مكة، يعني: مشركي العرب: <span class="qpc-hafs">﴿ماذا أرادَ اللَّهُ بِهذا مَثَلًا﴾</span> يعني: ذِكْره عِدّة خَزنة جهنم، يَستَقلُّونهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٤٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ والكافِرُونَ ماذا أرادَ اللَّهُ بِهَذا مَثَلًا﴾</span>: يقولون: حين يُخوِّفنا بهؤلاء التسعة عشر{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾</span>، يقول: ما يَعلم كثرتهم أحد إلا الله. وأنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: <span class="qpc-hafs">﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾</span> [التحريم:٦]{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٤٤<span class="dash">-</span></span> عن أبي سعيد الخُدري: أنّ رسول الله ﷺ حدّثهم عن ليلة أُسري به قال: «<b>فصعدتُ أنا وجبريل إلى السماء الدنيا، فإذا أنا بمَلَكٍ يُقال له: إسماعيل، وهو صاحب سماء الدنيا، وبين يديه سبعون ألف مَلَك، مع كلّ مَلَكٍ منهم جنده مائة ألف</b>». وتلا هذه الآية: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</span>{24}. (١٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٤٥<span class="dash">-</span></span> عن الحسن البصري: أنّ سائلًا سأل رسول الله عن خَلْق الملائكة: مِن أي شيء خُلقتْ؟ فقال: «<b>من نور الحُجُب السبعين التي تَلي الرّبّ؛ كلّ حجاب منها مسيرة خمسمائة عام، فليس مَلَك إلا وهو يَدخل في نهر الحياة، فيَغتسل، فيكون مِن كلّ قطرة من ذلك الماء مَلَك، فلا يُحصي أحد ما يكون في يوم واحد</b>». فهو قوله: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</span>، قال: من كثرتهم{26}. (١٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، مثله{15}. (١٥/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٤٨<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</span>، يعني: من الملائكة الذين خَلَقهم لتعذيب أهل النار، لا يَعلم عِدّتهم إلا الله{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾</span> مِن الكثرة حين استَقلُّوهم، فقال أبو جهل لقريش: أيَعجز ... مثل ما قال، في التقديم{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا هِیَ إِلَّا ذِكۡرَىٰ لِلۡبَشَرِ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وما هِيَ إلّا ذِكْرى لِلْبَشَرِ﴾</span>، قال: النار{30}<span class=comment-ref>٦٨٨٢</span>. (١٥/٨٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٢</span> أفاد قول مجاهد أنّ الضمير في <span class="qpc-hafs">﴿هي﴾</span> عائد على النار، وقد <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٦١) هذا، وزاد قولين آخرين، فقال: «وقال بعض الحُذّاق: قوله تعالى: <span class="qpc-hafs">﴿وما هِيَ﴾</span> يُراد بها الحال والمخاطبة والنذارة، قال الثعلبي: وقيل: <span class="qpc-hafs">﴿وما هِيَ﴾</span> يراد نار الدنيا، أي: إنّ هذه تذكرةٌ للبشر بنار الآخرة».</div></p><p><div></p><p><p><span class="item-no">٧٩٨٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{26}. (١٥/٨٢)</p></p><p></div></p></div>",footnotes:1:أورده الثعلبي ١٠/٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن أبي حاتم ٨/٢٦٩٨.الصياصي: قرون البقر. النهاية (صيص).عزاه السيوطي إلى ابن مردويه. وأخرج نحوه الثعلبي في تفسيره موقوفًا على ابن جريج ١٠/٧٤.أخرجه ابن جرير ٢٣/٤٣٧.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٣٧.أخرجه ابن جرير ٢٣/٤٣٨.أخرجه ابن جرير ٢٣/٤٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٣٩.أخرجه عبد الرزاق ٢/٣٢٩، وابن جرير ٢٣/٤٣٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٣٩.أخرجه أبو نعيم في حلية الأولياء ٩/١١٥.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه ابن جرير ٢٣/٤٤٠.تفسير مقاتل بن سليمان ٤/٤٩٧-٤٩٨.أخرجه الطبراني في الأوسط ٧/١٣٨ (٧٠٩٧)، وفي الصغير ٢/١٦٢ (٩٥٨)، والبيهقي في دلائل النبوة ٢/٣٩٠-٣٩٦ مطولًا، من طريق راشد أبي محمد الحماني، عن أبي هارون، عن أبي سعيد الخدري به.</p><p>وقال الهيثمي في المجمع ١/٨٠-٨١ (٢٥٩): «فيه أبو هارون، واسمه عمارة بن جُوين، وهو ضعيف جدًّا». وقال الذهبي في سير أعلام النبلاء ١/٢٢٥-٢٢٦: «هذا حديث غريب عجيب ...، وبسياق مثل هذا الحديث صار أبو هارون متروكًا».أخرجه يحيى بن سلام ٢/٧٧٥ مرسلًا. وينظر: تفسير ابن أبي زمنين ٥/٥٩-٦٠.أخرجه ابن جرير ٢٣/٤٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٨/٢٧١.تفسير مقاتل بن سليمان ٤/٤٩٨.أخرجه ابن جرير ٢٣/٤٤١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.
  74,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّا وَٱلۡقَمَرِ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أقسم الرّبُّ مِن أجل سَقر، فقال: <span class="qpc-hafs">﴿كَلّا والقَمَرِ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٨.
  74,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّیۡلِ إِذۡ أَدۡبَرَ ۝٣٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٥٣<span class="dash">-</span></span> عن هارون بن موسى النّحوي، قال: إنها في حرف <span class="name-1">أُبَيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٥٤<span class="dash">-</span></span> و<span class="name-1">ابن مسعود</span>: (إذَآ أدْبَرَ) يعني: بألِفين{1}. (١٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنه قرأ: ‹واللَّيْلِ إذا دَبَرَ› فجعل الألف مع ‹إذا›{2}. (١٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزُّبير</span>، أنه كان يقرأ: ‹واللَّيْلِ إذا دَبَرَ›{3}. (١٥/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٥٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أنه قرأها: ‹إذا دَبَرَ› مثل قراءة عبد الله بن عباس{4}. (١٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أنه قرأها: <span class="qpc-hafs">﴿واللَّيْلِ إذْ﴾</span> بغير ألف <span class="qpc-hafs">﴿أدْبَرَ﴾</span> بألف{5}<span class=comment-ref>٦٨٨٣</span>. (١٥/٨٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٣</span> ذكر <u>ابنُ جرير</u> (٢٣/٤٤٢) القراءتين الواردتين في قوله: <span class="qpc-hafs">﴿إذ أدبر﴾</span>، ثم <span class="comment-type-4">علّق</span> عليهما بقوله: «والصواب من القول في ذلك عندنا أنهما قراءتان <span class="mustanad">معروفتان صحيحتا المعنى</span>، فبأيّتهما قرأ القارئ فمصيب». ثم ذكر اختلاف أهل اللغة في ذلك، و<span class="comment-type-4">علّق</span> بقوله: «والصواب من القول في ذلك عندي: أنهما <span class="mustanad">لغتان بمعنًى</span>، وذلك أنه محكي عن العرب: قبّح الله ما قَبل منه وما دَبر. وأخرى: أنّ أهل التفسير لم يُميّزوا في تفسيرهم بين القراءتين، وذلك دليل على أنهم فعلوا ذلك كذلك؛ لأنهما بمعنًى واحد».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّیۡلِ إِذۡ أَدۡبَرَ ۝٣٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- ‹واللَّيْلِ إذا دَبَرَ›، قال: دُبُورُه: ظلامه{6}. (١٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٠<span class="dash">-</span></span> عن مجاهد، قال: سألتُ <span class="name-1">ابن عباس</span> عن قوله: ‹واللَّيْلِ إذا دَبَرَ›. فسكَتَ عني، حتى إذا كان مِن آخر الليل وسمع الأذان الأول ناداني: يا مجاهد، هذا حين دَبر الليل{7}. (١٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿واللَّيْلِ إذْ أدْبَرَ﴾</span>: إذ ولّى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّيْلِ إذْ أدْبَرَ﴾</span>، يعني: إذا ذَهبتْ ظُلمته{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضا عن الأعمش، ويونس بن عبيد، وغيرهما. انظر: البحر المحيط ٨/٣٦٩.عزاه السيوطي إلى أبي عبيد، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، وابن عامر، وشعبة، والكسائي، وأبو جعفر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿واللَّيْلِ إذْ أدْبَرَ﴾</span> بإسكان الذال، وهمزة بعدها. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٢.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.عزاه السيوطي إلى أبي عبيد، وابن المنذر.عزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٤٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه مسدد -كما في المطالب العالية (٤١٧٠)-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٤٢.أخرجه مقاتل بن سليمان ٤/٤٩٨.
  74,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلصُّبۡحِ إِذَاۤ أَسۡفَرَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والصُّبْحِ إذا أسْفَرَ﴾</span>، قال: إذا أضاء{1}. (١٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والصُّبْحِ إذا أسْفَرَ﴾</span>، يعني: ضوءه عن ظُلمة الليل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٠ من طريق معمر، وابن جرير ٢٣/٤٤٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٨.
  74,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهَا لَإِحۡدَى ٱلۡكُبَرِ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية-: <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ﴾</span>، يعني: جهنم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٦<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ نَذِيرًا لِلْبَشَرِ﴾</span>، قال: هي جهنم{2}. (١٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ﴾</span>، قال: النار{3}. (١٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ﴾</span>: يعني: جهنم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ﴾</span>: النار{5}. (١٥/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ﴾</span> أراد بالكُبَر: دَرَكات جهنم، وهي سبعة: جهنم، ولَظى، والحُطَمة، والسَّعير، وسَقر، والجحيم، والهاوية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّها﴾</span> إنّ سَقر <span class="qpc-hafs">﴿لَإحْدى الكُبَرِ﴾</span> مِن أبواب جهنم السبعة: جهنم، ولَظى، والحُطَمة، والسَّعير، وسَقر، والجحيم، والهاوية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ﴾</span>، قال: هذه النار{8}<span class=comment-ref>٦٨٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٤</span> أفادت الآثار عوْد الضمير من قوله: <span class="qpc-hafs">﴿إنها﴾</span> على جهنم. وقد <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٦٣) ذلك، ثم بيّن احتمال الآية <b>وجهًا آخر</b>، فقال: «ويحتمل أن يكون الضمير للنّذارة وأمر الآخرة، فهو للحال والقصة». و<span class="comment-type-1">وجّهه</span> بقوله: «وتكون هذه الآية <span class="mustanad">مثل قوله ﷿</span>: <span class="qpc-hafs">﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ * أنْتُمْ عَنْهُ مُعْرِضُونَ﴾</span> [ص:٦٧، ٦٨]».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٤٥.أخرجه ابن جرير ٢٣/٤٤٤. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٤٥.أخرجه عبد الرزاق ٢/٣٣٠، وابن جرير ٢٣/٤٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير البغوي ٨/٢٧٢.تفسير مقاتل بن سليمان ٤/٤٩٨-٤٩٩.أخرجه ابن جرير ٢٣/٤٤٤.
  74,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَذِیرࣰا لِّلۡبَشَرِ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٧٣<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق إسماعيل-: <span class="qpc-hafs">﴿نَذِيرًا لِلْبَشَرِ﴾</span>، يقول الله: أنا لكم منها نذير؛ فاتَّقوها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق قتادة-: واللهِ، ما أنذر الناسَ بشيء أدهى منها، أو بداهية هي أدهى منها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَذِيرًا﴾</span> يعني: تَذْكِرة <span class="qpc-hafs">﴿لِلْبَشَرِ﴾</span> يعني: للعالمين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿نَذِيرًا لِلْبَشَرِ﴾</span>، قال: الخَلْق. قال: بنو آدمَ البشرُ. فقيل له: محمد النَّذير؟ قال: نعم، يُنذِرهم{1}<span class=comment-ref>٦٨٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٥</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿نذيرا للبشر﴾</span> على أقوال: <b>الأول</b>: أي: النار. <b>الثاني</b>: أنّ ذلك من صفة الله تعالى، وهو خبر من الله عن نفسه، أنه نذير لخَلْقه. <b>الثالث</b>: ذلك من صفة رسول الله ﷺ.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (٢٣/٤٤٥) على القول الأول، فقال: «فعلى قول هؤلاء: النَّذير نُصب على القطع مِن إحْدى الكُبَر؛ لأن إحْدى الكُبَر مَعْرِفة، وقوله: <span class="qpc-hafs">﴿نذيرا﴾</span> نكرة، والكلام قد يحسن الوقوف عليه دونه».</p><p>و<span class="comment-type-4">علّق</span> عليه <u>ابنُ عطية</u> (٨/٤٦٣)، فقال: «وهذا القول يقتضي أنّ <span class="qpc-hafs">﴿نذيرا﴾</span> حال من الضمير في <span class="qpc-hafs">﴿إنَّها﴾</span>، أو من قوله: <span class="qpc-hafs">﴿لَإحْدى﴾</span>، وكذلك أيضًا على الاحتمال في أن تكون <span class="qpc-hafs">﴿إنَّها﴾</span> يُراد بها: قصة الآخرة وحال المعاد».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> على القول الثاني، فقال: «وعلى هذا القول يجب أن يكون نصب قوله: <span class="qpc-hafs">﴿نذيرًا﴾</span> على الخروج مِن جملة الكلام المتقدم، فيكون معنى الكلام: وما جعلنا أصحاب النار إلا ملائكة نذيرًا للبشر، يعني: إنذارًا لهم؛ فيكون قوله: <span class="qpc-hafs">﴿نذيرًا﴾</span> بمعنى: إنذارًا لهم؛ كما قال: <span class="qpc-hafs">﴿كيف نذير﴾</span> [الملك:١٧]، بمعنى: إنذاري، ويكون أيضًا بمعنى: إنها إحْدى الكُبَر صَيّرنا ذلك كذلك نذيرًا، فيكون قوله: <span class="qpc-hafs">﴿إنها لإحدى الكبر﴾</span> مُؤدّيًا عن معنى صيّرنا ذلك كذلك، وهذا المعنى قصد مَن قال ذلك إن شاء الله».</p><p>و<span class="comment-type-4">علّق</span> عليه <u>ابنُ عطية</u> (٥/٣٩٨)، فقال: «فهذا القول يَقتضي أنّ <span class="qpc-hafs">﴿نذيرًا﴾</span> معمول لفعل تقديره: اعبدوا نذيرًا للبشر، أو ادعوا نذيرًا للبشر». و<span class="comment-type-4">علّق</span> على القول الثالث، فقال: «فهذا القول يَقتضي أنّ <span class="qpc-hafs">﴿نذيرًا﴾</span> معمول لفعل تقديره: نادِ نذيرًا، أو: بلغ نذيرًا، ونحو هذا».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٤٦.أخرجه ابن جرير ٢٣/٤٤٥.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه ابن جرير ٢٣/٤٤٦.
  74,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِمَن شَاۤءَ مِنكُمۡ أَن یَتَقَدَّمَ أَوۡ یَتَأَخَّرَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٧٧<span class="dash">-</span></span> عن <span class="name-1">حُذيفة بن اليمان</span> -من طريق رجل- قال: ما مِن صباح ولا مساء إلا ومنادٍ ينادي: يا أيها الناس، الرَّحيلَ الرَّحيلَ. وإنّ تصديق ذلك في كتاب الله: <span class="qpc-hafs">﴿إنَّها لَإحْدى الكُبَرِ نَذِيرًا لِلْبَشَرِ لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾</span> قال: في الموت، <span class="qpc-hafs">﴿أوْ يَتَأَخَّرَ﴾</span> قال: في الموت{1}. (١٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ أوْ يَتَأَخَّرَ﴾</span>، قال: مَن شاء اتّبع طاعة الله، ومَن شاء تأخّر عنها{2}. (١٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٧٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: وهذا وعيد لهم، كقوله: <span class="qpc-hafs">﴿فَمَن شاءَ فَلْيُؤْمِن ومَن شاءَ فَلْيَكْفُرْ﴾</span> [الكهف:٢٩]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾</span> قال: في طاعة الله، <span class="qpc-hafs">﴿أوْ يَتَأَخَّرَ﴾</span> قال: في معصية الله{4}<span class=comment-ref>٦٨٨٦</span>. (١٥/٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٦</span> لم يذكر <u>ابنُ جرير</u> (٢٣/٤٤٦-٤٤٧) غير قول قتادة، وابن عباس.</div></p><p><div></p><p><p><span class="item-no">٧٩٨٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾</span> في الخير، <span class="qpc-hafs">﴿أوْ يَتَأَخَّرَ﴾</span> منه إلى المعصية، هذا تهديد، كقوله: <span class="qpc-hafs">﴿فَمَن شاءَ فَلْيُؤْمِن ومَن شاءَ فَلْيَكْفُرْ﴾</span> [الكهف:٢٩]، وكقوله: <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span> [فصلت:٤٠]{5}<span class=comment-ref>٦٨٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٧</span> ذكر ابنُ عطية (٨/٤٦٤) نحو هذ القول، ثم <span class="comment-type-4">علّق</span> قائلًا: «هو بيان في النذارة، وإعلام بأنّ كلّ أحد يَسلك طريق الهدى والحق إذا حقّق النظر، أو بعينه يَتأخّر عن هذه الرُّتبة؛ لغفلته وسُوء نظره».</div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في قِصر الأمل (١٣٥).أخرجه ابن جرير ٢٣/٤٤٧.تفسير الثعلبي ١٠/٧٦.أخرجه ابن جرير ٢٣/٤٤٧. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٤٩٩.
  74,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُّ نَفۡسِۭ بِمَا كَسَبَتۡ رَهِینَةٌ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٨٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق زاذان- <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</span>، قال: مُرتَهنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</span>، قال: مأخوذة بعملها{2}. (١٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</span>، قال: كلّ نفس سَبقتْ لها كلمة العذاب يَرتَهنها الله في النار، لا يَرتهن اللهُ أحدًا من أهل الجنة، ألم تَسمع أنه قال: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</span> يقول: ليسوا رهينة، <span class="qpc-hafs">﴿فِي جَنّاتٍ يَتَساءَلُونَ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾</span>، يقول: كلّ كافر مُرتهن بذنوبه في النار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٦<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿كل نفس﴾</span> يعني: مِن أهل النار <span class="qpc-hafs">﴿بما كسبت﴾</span> بما عَمِلتْ <span class="qpc-hafs">﴿رهينة﴾</span> في النار{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٤-.أخرجه ابن جرير ٢٣/٤٤٧-٤٤٨.أخرجه ابن جرير ٢٣/٤٤٨-٤٤٩.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه أبو عمرو الداني في المكتفى ص٢٢٦ (٤٣).
  74,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّاۤ أَصۡحَـٰبَ ٱلۡیَمِینِ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٨٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق زاذان- في قوله: <span class="qpc-hafs">﴿إلّا أصْحابَ اليَمِينِ﴾</span>، قال: هم أطفال المسلمين{1}. (١٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظَبْيان- في هذه الآية: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</span>، قال: هم الملائكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إلّا أصْحابَ اليَمِينِ﴾</span>، قال: هم المسلمون{3}. (١٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق أبي سهل- في قوله: <span class="qpc-hafs">﴿إلّا أصْحابَ اليَمِينِ﴾</span>، قال: هم أطفال المسلمين{4}. (١٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</span>، قال: لا يُحاسَبون{5}. (١٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إلّا أصْحابَ اليَمِينِ﴾</span> هم المسلمون المُخلصون= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٣<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span> أيضًا: هم الذين كانوا ميامين على أنفسهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</span>، قال: علَّق الناسَ كلّهم، إلا أصحاب اليمين{7}. (١٥/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا أصْحابَ اليَمِينِ﴾</span> الذين أُعطوا كُتبهم بأيمانهم، ولا يُرتَهنون بذنوبهم في النار، ثم هم <span class="qpc-hafs">﴿فِي جَنّاتٍ يَتَساءَلُونَ عَنِ المُجْرِمِينَ﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾</span>: أصحاب اليمين لا يُرتَهنون بذنوبهم، ولكن يَغفرها الله لهم. وقرأ قول الله -جلّ ثناؤه-: <span class="qpc-hafs">﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> [الصافات:٤٠]، قال: لا يُؤاخذهم الله بسيئ أعمالهم، ولكن يَغفرها الله لهم، ويَتجاوز عنهم كما وعدهم{9}<span class=comment-ref>٦٨٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٨</span> اختُلف فيمن عنى الله بقوله: <span class="qpc-hafs">﴿إلا أصحاب اليمين﴾</span> على أقوال: <b>الأول</b>: أنهم المسلمون الصالحون. <b>الثاني</b>: أنهم أطفال المسلمين. <b>الثالث</b>: أنهم الملائكة.</p><p>ولم يذكر <u>ابنُ جرير</u> (٢٣/٤٥٠) غير القول الثاني والثالث، ثم قال <span class="comment-type-4">معلقًا</span> عليهما: «وإنما قال مَن قال: أصحاب اليمين في هذا الموضع: هم الولدان وأطفال المسلمين، ومَن قال: هم الملائكة؛ لأنّ هؤلاء لم يكن لهم ذنوب، وقالوا: لم يكونوا ليسألوا المجرمين: <span class="qpc-hafs">﴿ما سلككم في سقر﴾</span>؟ إلا أنهم لم يَقتَرفوا في الدنيا مآثم، ولو كانوا اقترفوها وعرفوها لم يكونوا ليسألوهم عما سلكهم في سَقر؛ لأن كلّ مَن دَخل من بني آدم ممن بلغ التكليف، ولزمه فرض الأمر والنهي، قد عَلم أنّ أحدًا لا يُعاقب إلا على المعصية».</p><p>وزاد <u>ابنُ عطية</u> (٨/٤٦٤) في الآية <b>قولًا</b> آخر، حكاه عن الضَّحّاك، أنه قال: «هم الذين سَبَقتْ لهم من الله الحُسنى».</div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٧<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿إلا أصحاب اليمين﴾</span>، قال: هم أصحاب الجنة كلّهم{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٤-، وعبد الرزاق ٢/٢٧٠، ٣٢٩، ٣٣٠، وابن أبي شيبة ١٣/٢٨٥، وابن جرير ٣٢/٤٥٠، والحاكم ٢/٥٠٧. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم. وفي لفظ عند ابن جرير ٢٣/٤٥٠: هم الولدان.أخرجه ابن جرير ٢٣/٤٥٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٣٢٥. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٣/٤٤٨. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ١٠/٧٧، وتفسير البغوي ٨/٢٧٣، وعزا القول الثاني إلى مقاتل.أخرجه ابن جرير ٢٣/٤٤٨. وعزاه السيوطي إلى عَبد بن حُمَيد. وعند ابن جرير بلفظ: غَلِق.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه ابن جرير ٢٣/٤٤٨.أخرجه أبو عمرو الداني في المكتفى ص٢٢٦ (٤٣).
  74,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٨٩٨<span class="dash">-</span></span> عن عمرو بن دينار، عن عبد الله بن الزُّبير، عن <span class="name-1">عمر</span> أنه قرأ: (يَآ أيُّها المَرْءُ ما سَلَكَكَ فِي سَقَرَ). قال: أقرأنيها عمر، فلم أنسها بعد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٨٩٩<span class="dash">-</span></span> عن عمرو بن دينار -من طريق سفيان بن عُيينة- قال: سمعتُ <span class="name-1">عبد الله بن الزُّبير</span> يقرأ: (فِي جَنّاتٍ يَتَسَآءَلُونَ عَنِ المُجْرِمِينَ يا فُلان ما سَلَكَكُمْ فِي سَقَرَ).= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٠٠<span class="dash">-</span></span> قال عمرو: وأخبرني لقيط قال: سمعتُ ابن الزُّبير قال: سمعتُ <span class="name-1">عمر بن الخطاب</span> يقرؤها كذلك{2}. (١٥/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الزّعراء- أنه قرأ: (يَآ أيُّها الكُفّارُ ما سَلَكَكُمْ فِي سَقَرَ){3}. (١٥/٨٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الزّعراء- في قصة ذكرها في الشفاعة، قال: ثُمَّ تَشفع الملائكة والنَّبيّون والشهداء والصالحون والمؤمنون، ويُشفّعهم الله، فيقول: أنا أرحم الراحمين. فيُخرِج مِن النار أكثرَ مما أخرج مِن جميع الخَلْق مِن النار، ثم يقول: أنا أرحم الراحمين. ثم قرأ <span class="name-1">عبد الله</span>: (يَآ أيُّها الكُفّارُ ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ}، وعقَد بيده أربعًا، ثم قال: هل تَرون في هؤلاء مِن خير، ألا ما يُترك فيها أحدٌ فيه خير{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فلمّا أخرج الله أهل التوحيد من النارِ قال المؤمنون لِمَن بقي في النار: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span>، يعني: ما جعلكم في سَقر؟ يعني: ما حبسكم في النار؟{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٠٤<span class="dash">-</span></span> عن معونة بن قُرّة{6} -من طريق سلام- قال: ما يَسُرّني بهذه الآية الدنيا وما فيها؛ قوله ﷿: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span>، ألا ترى أنه ليس فيهم خير{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائله (ت: الخياطي) ١/١٤١.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٦٥.أخرجه عبد الرزاق ٢/٣٣١، وابن أبي داود ص٥٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وعبد الله بن أحمد في زوائد الزهد، وابن الأنباري معًا في المصاحف، وابن المنذر، وابن أبي حاتم.</p><p>ومهما يكن فهي قراءة شاذة. انظر: روح المعاني ٢٩/١٦٦.أخرجه أبو عبيد في فضائله ص١٨٧. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة. انظر: روح المعاني ٢٩/١٦٦.أخرجه ابن جرير ٢٣/٤٥٢.تفسير مقاتل بن سليمان ٤/٤٩٩.كذا في المطبوع، ولعله: معاوية بن قرة، تصحفت.أخرجه ابن أبي الدنيا في كتاب حسن الظن بالله -موسوعة الإمام ابن أبي الدنيا ١/١٢٤ (١٤٩)-.
  74,41,""
  74,42,""
  74,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَمۡ نَكُ مِنَ ٱلۡمُصَلِّینَ ۝٤٣ وَلَمۡ نَكُ نُطۡعِمُ ٱلۡمِسۡكِینَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأجابهم أهلُ النار عن أنفسهم، فـ<span class="qpc-hafs">﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</span> في الدنيا لله، <span class="qpc-hafs">﴿ولَمْ نَكُ نُطْعِمُ المِسْكِينَ﴾</span> في الدنيا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٩.
  74,44,""
  74,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُنَّا نَخُوضُ مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥ وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وكُنّا نَخُوضُ مَعَ الخائِضِينَ﴾</span>، قال: يقولون: أي: كُلّما غوى غاوٍٍ غَوينا معه{1}. (١٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكُنّا نَخُوضُ مَعَ الخائِضِينَ﴾</span> في الدنيا في الباطل والتكذيب كما يَخوض كفار مكة، <span class="qpc-hafs">﴿وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ﴾</span> يعني: بيوم الحساب أنه غير كائن{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكُنَّا نَخُوضُ مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥ وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٠٨<span class="dash">-</span></span> قال ابن عون: ما رأيتُ أحدًا كان أعظم رجاء للمُوحِّدين مِن <span class="name-2">محمد بن سيرين</span>، وكان يتلو هؤلاء الآيات: <span class="qpc-hafs">﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾</span> [الصافات:٣٥]، ويتلو: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ﴾</span>، ويتلو: <span class="qpc-hafs">﴿لا يَصْلاها إلّا الأَشْقى الَّذِي كَذَّبَ وتَوَلّى﴾</span> [الليل:١٥-١٦]{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٠، وابن جرير ٢٣/٤٥١ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه ابن أبي الدنيا في كتاب حسن الظن بالله -موسوعة الإمام ابن أبي الدنيا ١/٨٣ (٦٧)-، وابن عساكر في تاريخ دمشق ٥٣/٢٠٦، وفيه: «وكان يتأول آيًا من القرآن» بدلًا من «يتلو».
  74,46,""
  74,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ أَتَىٰنَا ٱلۡیَقِینُ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿حَتّى أتانا اليَقِينُ﴾</span>، قال: الموت{1}. (١٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٠<span class="dash">-</span></span> عن <span class="name-2">سالم بن عبد الله بن عمر</span>، في قوله تعالى: <span class="qpc-hafs">﴿حَتّى أتانا اليَقِينُ﴾</span>، قال: اليقين: الموت{1}. (١٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى أتانا اليَقِينُ﴾</span>، يعني: الموت{3}<span class=comment-ref>٦٨٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٨٩</span> <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٨/٤٦٥) أنّ اليقين معناه: «صحة ما كانوا يُكذِّبون به مِن الرجوع إلى الله تعالى والدار الآخرة». ثم <span class="comment-type-2">انتقد</span> -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- القول بأنه الموت، فقال: «وقال المفسرون: اليَقِين: الموت. وذلك عندي هنا مُتعقّب؛ لأن نفس الموت يقين عند الكافر وهو حي، فإنما اليَقِين الذي عَنوا في هذه الآية فهو الشيء الذي كانوا يُكذِّبون به وهم أحياء في الدنيا، فتَيقّنوه بعد الموت، وإنما ُيُفَسَّر اليقين بالموت في قوله تعالى: <span class="qpc-hafs">﴿واعْبُدْ رَبَّكَ حَتّى يَأْتِيَكَ اليَقِينُ﴾</span> [الحجر:٩٩]».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه مقاتل بن سليمان ٤/٤٩٩.