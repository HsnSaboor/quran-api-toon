tafsir[10]{c,v,t}:
45,33," <q>﴿وَبَدَا لَهُمۡ سَیِّـَٔاتُ مَا عَمِلُوا۟ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٣٣﴾</q> - تفسير ٧٠٣٥٤- قال مقاتل بن سليمان: <q>﴿وبَدا لَهُمْ﴾</q> يقول: وظهر لهم في الآخرة <q>﴿سَيِّئاتُ﴾</q> يعني: الشرك <q>﴿ما عَمِلُوا﴾</q> في الدنيا حين شهدت عليهم الجوارح، <q>﴿وحاقَ﴾</q> يقول: ووجب العذاب <q>﴿بِهِمْ ما كانُوا بِهِ﴾</q> بالعذاب <q>﴿يَسْتَهْزِؤُنَ﴾</q> أنّه غير كائن{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٤٢.
45,34," <q>﴿وَقِیلَ ٱلۡیَوۡمَ نَنسَىٰكُمۡ كَمَا نَسِیتُمۡ لِقَاۤءَ یَوۡمِكُمۡ هَـٰذَا وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٣٤﴾</q> - تفسير ٧٠٣٥٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقِيلَ اليَوْمَ نَنْساكُمْ﴾</q>، قال: نترككم{1}. (١٣/٣٠٧) ٧٠٣٥٦- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿وقِيلَ اليَوْمَ نَنْساكُمْ كَما نَسِيتُمْ لِقاءَ يَوْمِكُمْ هَذا﴾</q>، قال: كما تركتم ذِكري وطاعتي، كذلك أتركُكم في النار{2}. (١٣/٣٠٨) ٧٠٣٥٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿اليَوْمَ نَنْساكُمْ كَما نَسِيتُمْ﴾</q>، قال: اليوم نتركُكم كما تركتم{3}. (ز) ٧٠٣٥٨- قال مقاتل بن سليمان: وقال لهم الخَزَنة في الآخرة: <q>﴿وقِيلَ اليَوْمَ نَنْساكُمْ﴾</q> يقول: نتركُكم في العذاب <q>﴿كَما نَسِيتُمْ لِقاءَ يَوْمِكُمْ هَذا﴾</q> يقول: كما تركتم إيمانًا بهذا اليوم، يعني: البعث، <q>﴿ومَأْواكُمُ النّارُ وما لَكُمْ مِن ناصِرِينَ﴾</q> يعني: مانِعين من النار{4}. (ز) <q>﴿وَقِیلَ ٱلۡیَوۡمَ نَنسَىٰكُمۡ كَمَا نَسِیتُمۡ لِقَاۤءَ یَوۡمِكُمۡ هَـٰذَا وَمَأۡوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّـٰصِرِینَ ۝٣٤﴾</q> - آثار متعلقة بالآية ٧٠٣٥٩- عن كعب الأحبار –من طريق مولى جبلة- قال: إذا كان يوم القيامة يقوم الملائكة فيشفعون، ثم يقوم الأنبياء فيشفعون، ثم يقوم الشهداء فيشفعون، ثم يقوم المؤمنون فيشفعون، حتى انصرمت الشفاعة كلها، فلم يبقَ أحد خرجت الرحمة، فتقول: يا ربِّ، أنا الرحمة، فشفِّعني. فيقول: قد شفَّعتك. فتقول: يا ربِّ، فيمن؟ فيقول: في مَن ذكرني في مقامٍ واحد، وخافني فيه أو رجاني أو دعاني دعوة واحدة خافني أو رجاني؛ فأخرجيه. قال: فيخرجون، فلا يبقى في النار أحد يعبأ الله به شيئًا، ثم يعظم أهلها بها، ثم يأمر بالنار، فتقبض عليهم، فلا يدخل فيها روح أبدًا، ولا يخرج منها غمٌّ أبدًا، <q>﴿وقيل اليَوْمَ نَنْساكُمْ كَما نَسِيتُمْ لِقاءَ يَوْمِكُمْ هَذا﴾</q>{5}. (ز) ٧٠٣٦٠- عن يزيد بن أبي مالك -من طريق سليمان بن عبد الرحمن الدمشقي- قال: إنّ في جهنم لَآبارًا مَن أُلقي فيها ترَدّى سبعين عامًا قبل أن يبلغ القرار. ثم نزع بهذه الآية: فـ<q>﴿اليَوْمَ نَنْساكُمْ كَما نَسِيتُمْ لِقاءَ يَوْمِكُمْ هَذا ومَأْواكُمُ النّارُ وما لَكُمْ مِن ناصِرِينَ﴾</q>{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢١/١٠٨، وابن المنذر -كما في الفتح ٨/٥٧٤-. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢١٤.تفسير مقاتل بن سليمان ٣/٨٤٢.أخرجه الثعلبي ٧/٣٣٠.أخرجه ابن أبي الدنيا في صفة النار ٦/٤١٠ (٤٩).
45,35," <q>﴿ذَ ٰ⁠لِكُم بِأَنَّكُمُ ٱتَّخَذۡتُمۡ ءَایَـٰتِ ٱللَّهِ هُزُوࣰا وَغَرَّتۡكُمُ ٱلۡحَیَوٰةُ ٱلدُّنۡیَاۚ فَٱلۡیَوۡمَ لَا یُخۡرَجُونَ مِنۡهَا وَلَا هُمۡ یُسۡتَعۡتَبُونَ ۝٣٥﴾</q> - تفسير ٧٠٣٦١- قال مقاتل بن سليمان: <q>﴿ذلِكُمْ بِأَنَّكُمُ﴾</q> يقول: إنما نزل بكم العذاب في الآخرة بأنكم <q>﴿اتَّخَذْتُمْ آياتِ اللَّهِ﴾</q> يعني: كلام الله <q>﴿هُزُوًا﴾</q> يعني: استهزاء، حين قالوا: ساحر، وشاعر، وأساطير الأولين، <q>﴿وغَرَّتْكُمُ الحَياةُ الدُّنْيا﴾</q> عن الإسلام، <q>﴿فاليَوْمَ﴾</q> في الآخرة <q>﴿لا يُخْرَجُونَ مِنها ولا هُمْ يُسْتَعْتَبُونَ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٤٢.
45,36," <q>﴿فَلِلَّهِ ٱلۡحَمۡدُ رَبِّ ٱلسَّمَـٰوَ ٰ⁠تِ وَرَبِّ ٱلۡأَرۡضِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٣٦﴾</q> - تفسير ٧٠٣٦٢- قال مقاتل بن سليمان: قوله: <q>﴿فَلِلَّهِ الحَمْدُ﴾</q> يقول: الشكر لله <q>﴿رَبِّ السَّماواتِ ورَبِّ الأَرْضِ رَبِّ العالَمِينَ﴾</q> يعني: القيامة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٤٢.
45,37," <q>﴿وَلَهُ ٱلۡكِبۡرِیَاۤءُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ وَهُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٣٧﴾</q> - تفسير ٧٠٣٦٣- قال مقاتل بن سليمان: <q>﴿ولَهُ الكِبْرِياءُ﴾</q> يعني: العظمة، والسلطان، والقوة، والقدرة <q>﴿فِي السَّماواتِ والأَرْضِ وهُوَ العَزِيزُ﴾</q> في مُلكه، <q>﴿الحَكِيمُ﴾</q> في أمره الذي حكم{1}. (ز) <q>﴿وَلَهُ ٱلۡكِبۡرِیَاۤءُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ وَهُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٣٧﴾</q> - آثار متعلقة بالآية ٧٠٣٦٤- عن أبي هُريرة، قال: قال رسول الله ﷺ: «يقول الله: الكبرياء ردائي، والعَظَمة إزاري، فمَن نازعني واحدًا منهما ألقيتُه في النار»{2}٥٩٥٦. (١٣/٣٠٩) ٥٩٥٦ علَّق ابنُ كثير (١٢/٣٦٨) على هذا الحديث بقوله: «رواه مسلم من حديث الأعمش، عن أبي إسحاق، عن الأغر أبي مسلم، عن أبي هريرة وأبي سعيد، ﵄، عن رسول الله ﷺ، بنحوه». ٧٠٣٦٥- عن أبي هريرة، رفعه: «إنّ الله له ثلاثة أثواب: اتَّزر بالعزة، وتسرْبل بالرحمة، وارتدى بالكبرياء، فمَن تعزَّز بغيرِ ما أعزّه اللهُ فذلك الذي يُقال له: <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q> [الدخان:٤٩]، ومَن رحم الناس رحمه الله، فذلك الذي تسرْبل بِسرْباله الذي ينبغي له، ومَن تكبّر فقد نازع الله رداءَه الذي ينبغي له؛ فإنّه -تبارك وتعالى- يقول: لا ينبغي لِمَن نازعني أن أُدخِله الجنة»{3}. (١٣/٣٠٩) ٧٠٣٦٦- عن عمر بن ذر، عن أبيه، أن رسول الله ﷺ قال: «ما قعد قومٌ يذكرون اللهَ إلا قعد معهم عددهم مِن الملائكة، فإذا حمدوا الله حمدوه، وإنْ سبّحوا الله سبّحوه، وإنْ كبَّروا الله كبّروه، وإنْ استغفروا الله أمَّنوا، ثم عرجوا إلى ربّهم، فسألهم، فقالوا: ربّنا، عبيد لك من أهل الأرض، ذكروك فذكرناك. قال: ويقولون ماذا؟ قالوا: ربّنا حمدوك. فقال: أول مَن عُبد، وآخر مَن حُمد. قالوا: وسبّحوك. قال: مدحي لا ينبغي لأحد غيري. قالوا: ربّنا كبّروك. قال: لي الكبرياء في السماوات والأرض وأنا العزيز الحكيم. قالوا: ربّنا استغفروك. قال: إني أشهدكم أني قد غفرتُ لهم»{4}. (١٣/٣٠٨) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٤٢-٨٤٣.أخرجه أحمد ١٢/٣٣٧ (٧٣٨٢)، ١٤/٤٧٣ (٨٨٩٤)، ١٥/٢١١ (٩٣٥٩)، ١٥/٣١٣ (٩٥٠٨)، ١٥/٤٣٩ (٩٧٠٣)، وابن ماجه ٥/٢٧٢ (٤١٧٤)، وأبو داود ٦/١٨٩ (٤٠٩٠)، وابن حبان ٢/٣٥-٣٦ (٣٢٨)، ١٢/٤٨٦ (٥٦٧١). وأصله عند مسلم ٤/٢٠٢٣ (٢٦٢٠).أخرجه البيهقي في شعب الإيمان ١٠/٤٦٧ (٧٨١٠)، من طريق بكار بن قتيبة القاضي، عن صفوان بن عيسى، عن ابن عجلان، عن سعيد المقبري، عن أبي هريرة به. وسنده ليّن؛ فيه محمد بن عجلان، قال عنه ابن حجر في تقريب التهذيب (٦١٣٦): «صدوق، إلا أنه اختلطت عليه أحاديث أبي هريرة».أخرجه أبو نعيم في الحلية ٥/١١٧-١١٨، وابن عساكر في تاريخه ٢٨/٨٧-٨٨ مرسلًا.
46,1," مقدمة السورة ٧٠٣٦٧- عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (ز) ٧٠٣٦٨- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلت بعد الجاثية{2}. (ز) ٧٠٣٦٩- عن عبد الله بن عباس، قال: نزلت سورة «حم الأحقاف» بمكة{3}. (١٣/٣١٠) ٧٠٣٧٠- عن عبد الله بن الزبير، مثله{3}. (١٣/٣١٠) ٧٠٣٧١- عن عكرمة= (ز) ٧٠٣٧٢- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{5}. (ز) ٧٠٣٧٣- عن قتادة بن دعامة -من طرق-: مكّيّة{6}. (ز) ٧٠٣٧٤- عن محمد بن شهاب الزُّهريّ: مكّيّة، ونزلت بعد الجاثية{7}. (ز) ٧٠٣٧٥- عن علي بن أبي طلحة: مكّيّة{8}. (ز) ٧٠٣٧٦- قال مقاتل بن سليمان: سورة الأحقاف مكّيّة، عددها خمس وثلاثون آية كوفي{9}٥٩٥٧. (ز) ٥٩٥٧ قال ابنُ عطية (٧/٦٠٨): «هذه السورة مكية لم يُختلف منها إلا في آيتين، وهي قوله: <q>﴿قُلْ أرَأَيْتُمْ إنْ كانَ مِن عِنْدِ اللَّهِ وكَفَرْتُمْ بِهِ وشَهِدَ شاهِدٌ مِن بَنِي إسْرائِيلَ عَلى مِثْلِهِ فَآمَنَ واسْتَكْبَرْتُمْ﴾</q> [١٠]، وقوله: <q>﴿فاصْبِرْ كَما صَبَرَ أُولُوا العَزْمِ مِنَ الرُّسُلِ﴾</q> الآية [٣٥]، فقال بعض المفسرين: هاتان آيتان مدنيتان وُضعتا في سورة مكية». ٧٠٣٧٧- عن عبد الله بن مسعود، قال: أقرأني رسول الله ﷺ سورةً من «آل حم» -يعني: الأحقاف-. قال: وكانت السورة إذا كانت أكثر من ثلاثين آية سُمّيت: ثلاثين{10}. (١٣/٣١٠) ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصَيف عن مجاهد.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/١٣.أخرجه أحمد ٧/٨٨ (٣٩٨١). وقال محققو المسند: «إسناده حسن».
46,2," <q>﴿حمۤ ۝١ تَنزِیلُ ٱلۡكِتَـٰبِ مِنَ ٱللَّهِ ٱلۡعَزِیزِ ٱلۡحَكِیمِ ۝٢﴾</q> - تفسير ٧٠٣٧٨- قال مقاتل بن سليمان: <q>﴿تَنْزِيلُ الكِتابِ﴾</q> يقول: قضاء نزول الكتاب، يعني: القرآن <q>﴿مِنَ اللَّهِ العَزِيزِ﴾</q> في مُلكه، <q>﴿الحَكِيمِ﴾</q> في أمره{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٥.
46,3," <q>﴿مَا خَلَقۡنَا ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ وَمَا بَیۡنَهُمَاۤ إِلَّا بِٱلۡحَقِّ وَأَجَلࣲ مُّسَمࣰّىۚ وَٱلَّذِینَ كَفَرُوا۟ عَمَّاۤ أُنذِرُوا۟ مُعۡرِضُونَ ۝٣﴾</q> - تفسير ٧٠٣٧٩- قال مقاتل بن سليمان: <q>﴿ما خَلَقْنا السَّماواتِ والأَرْضَ وما بَيْنَهُما﴾</q> يعني: الشمس، والقمر، والنجوم، والسحاب، والرياح <q>﴿إلّا بِالحَقِّ﴾</q> لم أخلقهما باطلًا عبثًا لغير شيء، خلقتُهما لأمرٍ هو كائن، ثم قال: <q>﴿وأَجَلٍ مُسَمًّى﴾</q> يقول: خلقتُهم لأجل مُسمًّى ينتهي إليه، يعني: يوم القيامة، فهو الأجل المُسمّى، ثم قال: <q>﴿والَّذِينَ كَفَرُوا﴾</q> من أهل مكة <q>﴿عَمّا أُنْذِرُوا﴾</q> في القرآن مِن العذاب <q>﴿مُعْرِضُونَ﴾</q> فلا يتفكرون{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٥.
46,4," <q>﴿قُلۡ أَرَءَیۡتُم مَّا تَدۡعُونَ مِن دُونِ ٱللَّهِ أَرُونِی مَاذَا خَلَقُوا۟ مِنَ ٱلۡأَرۡضِ أَمۡ لَهُمۡ شِرۡكࣱ فِی ٱلسَّمَـٰوَ ٰ⁠تِۖ﴾</q> - تفسير ٧٠٣٨٠- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> يا محمد لأهل مكة: <q>﴿أرَأَيْتُمْ ما تَدْعُونَ﴾</q> يعني: تعبدون <q>﴿مِن دُونِ اللَّهِ﴾</q> مِن الآلهة، يعني: الملائكة؛ <q>﴿أرُونِي ماذا خَلَقُوا مِنَ الأَرْضِ﴾</q> يعني: الأرض، كخلْق الله إن كانوا آلهة، ثم قال: <q>﴿أمْ لَهُمْ﴾</q> يقول: ألهم <q>﴿شِرْكٌ﴾</q> مع الله <q>﴿فِي﴾</q> مُلك <q>﴿السَّماواتِ﴾</q>، كقوله: <q>﴿وما لَهُمْ فِيهِما مِن شِرْكٍ وما لَهُ مِنهُمْ مِن ظَهِيرٍ﴾</q> [سبأ:٢٢] ولا في سلطانه{1}. (ز) <q>﴿ٱئۡتُونِی بِكِتَـٰبࣲ مِّن قَبۡلِ هَـٰذَاۤ أَوۡ أَثَـٰرَةࣲ مِّنۡ عِلۡمٍ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤﴾</q> - قراءات ٧٠٣٨١- عن هارون، قال: كان قتادة يقول: (أثَرَةٍ مِّنْ عِلْمٍ)، يقول: خاصة من علم{2}. (ز) <q>﴿ٱئۡتُونِی بِكِتَـٰبࣲ مِّن قَبۡلِ هَـٰذَاۤ أَوۡ أَثَـٰرَةࣲ مِّنۡ عِلۡمٍ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤﴾</q> - تفسير الآية ٧٠٣٨٢- عن عبد الله بن عباس، عن النبيّ ﷺ: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: «الخَطّ»{3}. (١٣/٣١١) ٧٠٣٨٣- عن أبي سعيد، عن النبي ﷺ، في قوله: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: «حُسن الخَطّ»{4}. (١٣/٣١١) ٧٠٣٨٤- عن عطاء بن يسار، قال: سُئِل رسولُ الله ﷺ عن الخَطّ. فقال: «عَلِمه نبيٌّ، ومَن وافقه عَلِم». قال صفوان: فحدَّثتُ به أبا سلمة بن عبد الرحمن. فقال: سألت ابنُ عباس، فقال: هو أثارة من عِلْم{5}. (١٣/٣١١) ٧٠٣٨٥- عن عبد الله بن عباس -من طريق أبي سلمة- <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: هو الخَطّ{6}. (١٣/٣١١) ٧٠٣٨٦- عن عبد الله بن عباس -من طريق أبي سلمة- في قوله: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: خطٌّ كان يخطّه العرب في الأرض{7}٥٩٥٨. (١٣/٣١٢) ٥٩٥٨ علَّق ابنُ عطية (٧/٦٠٩-٦١٠) على هذا القول الذي قاله ابن عباس، وأبو سلمة من طريق صفوان، وأبو بكر بن عياش، فقال: «وذلك شيء كانت العرب تفعله وتتكهّن به وتزجر، وهذا مِن البقية والأثر، وروي أن النبي ﷺ سئل عن ذلك فقال: «كان نبي من الأنبياء يخطّه، فمن وافق خطَّه فذاك»». وذكر في تأويل الحديث وجهين: الأول: ظاهر الحديث يقوي أمر الخطّ في التراب، وأنه شيء له وجه إذا وفق أحد إليه. وهكذا تأوّله كثير من العلماء. الثاني: أن معناه: الإنكار، أي: أنه كان مِن فعل نبيٍّ قد ذهب، وذهب الوحي إليه والإلهام في ذلك، ثم قال: «فمن وافق خطّه» على جهة الإبعاد، أي: أنّ ذلك لا يمكن مِمَّن ليس بنبي ميسّر لذلك، وهذا كما يسألك أحد فيقول: أيطير الإنسان؟ فتقول: إنما يطير الطائر، فمَن كان له مِن الناس جناحان طار. أي: أن ذلك لا يكون. ٧٠٣٨٧- عن عبد الله بن عباس -من طريق الشعبي- <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: جَوْدة الخَطّ{8}. (١٣/٣١٢) ٧٠٣٨٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، يقول: بيّنة من الأمر{9}. (١٣/٣١٢) ٧٠٣٨٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: أحد يأثِر علمًا{10}٥٩٥٩. (١٣/٣١٢) ٥٩٥٩ ذكر ابنُ كثير (١٣/٦) أن هذا القول على قراءة من قرأ: ‹أثَرَةٍ›. وبنحوه قال ابنُ جرير (٢١/١١٥). ٧٠٣٩٠- قال عكرمة مولى ابن عباس: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q> رواية عن الأنبياء ﵈{11}. (ز) ٧٠٣٩١- قال ميمون بن مهران= (ز) ٧٠٣٩٢- وأبو سلمة بن عبد الرحمن: <q>﴿أثارَةٍ مِن عِلْمٍ﴾</q> خاصّة من علم{11}. (ز) ٧٠٣٩٣- عن أبي سلمة [بن عبد الرحمن] -من طريق صفوان بن سليم- في قوله: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: الخَطّ{13}. (ز) ٧٠٣٩٤- عن الحسن البصري -من طريق معمر، عمَّن سمعه- <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>: شيء يستخرجه فيُثِيره{14}. (ز) ٧٠٣٩٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>، قال: أو خاصّة من علم{15}٥٩٦٠. (١٣/٣١٢) ٥٩٦٠ علَّق ابنُ عطية (٧/٦٠٩) على هذا القول الذي قاله قتادة، وميمون، وأبو سلمة، بقوله: «فاشتقاقها من الأَثرة، كأنها قد آثر الله بها مَن هي عنده». ٧٠٣٩٦- قال محمّد بن كعب القُرَظيّ: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q> الإسناد{11}٥٩٦١. (ز) ٥٩٦١ ساق ابنُ عطية (٧/٦٠٩) قول القرظي، ثم علَّق بقوله: "ومن هذا المعنى قول الأعشى: إن الذي فيه تماريتما بيّن للسامع والآثر أي: وللمسند عن غيره، ومنه قول عمر ﵁: فما خلّفت بها ذاكرًا ولا آثرًا". ٧٠٣٩٧- عن هارون، عن الأعرج= (ز) ٧٠٣٩٨- وأبي عمرو [البصري]: <q>﴿أثارة من علم﴾</q>، والأثارة: البقيَّة مِن العِلم{17}. (ز) ٧٠٣٩٩- عن مَطَر الوَرّاق -من طريق ابن شَوْذَب- في قوله تعالى: <q>﴿أو أثارة من علم﴾</q>، قال: إسناد الحديث{18}. (ز) ٧٠٤٠٠- قال محمد بن السّائِب الكلبي: <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q> بقيّة من عِلم{11}. (ز) ٧٠٤٠١- قال مقاتل بن سليمان: <q>﴿ائْتُونِي بِكِتابٍ مِن قَبْلِ هَذا أوْ أثارَةٍ مِن عِلْمٍ﴾</q> يقول: أو رواية تَعْلمونها مِن الأنبياء قبل هذا القرآن بأنّ له شريكًا؛ <q>﴿إنْ كُنْتُمْ صادِقِينَ﴾</q> يعني: اللّات والعُزّى ومَناة بأنهنّ له شركاء{1}. (ز) ٧٠٤٠٢- قال أبو بكر بن عيّاش -من طريق أبو كريب-: الخطّ: هو العِيافة{7}. (ز) ٧٠٤٠٣- قال أبو كريب: سُئِل أبو بكر -يعني: ابن عيّاش- عن <q>﴿أوْ أثارَةٍ مِن عِلْمٍ﴾</q>. قال: بقيّة من عِلم{22}٥٩٦٢. (ز) ٥٩٦٢ اختُلِف في المراد بقوله: <q>﴿أثارة من علم﴾</q> على أقوال: الأول: الخطّ، ويتضمّن أمرين: حُسن الكتابة، والقيافة في الأرض. الثاني: خاصّة من علم. الثالث: علم تثيرونه فتستخرجونه. الرابع: تأثرون ذلك عِلمًا عن أحد ممن قبلكم. الخامس: بيّنة من الأمر. السادس: الإسناد. السابع: بقيّة من عِلم. ورجَّح ابنُ جرير (٢١/١١٥-١١٦) -مستندًا إلى اللغة- القول الأخير الذي قاله ابن عباس، ومجاهد، والكلبي، وابن عياش، فقال: «لأن ذلك هو المعروف من كلام العرب، وهي مصدر من قول القائل: أثُر الشيء أثارة، مثل سمُج سماجة». ثم قال: «وإذا وُجِّه ذلك إلى ما قلنا فيه مِن أنه بقيّة من عِلم؛ جاز أن تكون تلك البقيّة من عِلم الخطّ، ومِن علمٍ استُثير من كتب الأولين، ومن خاصة علم كانوا أُوثروا به». وذكر ابنُ كثير (١٣/٧-٨) أنّ الأثارة هي الدليل البيّن، ثم قال: «وكل هذه الأقوال متقاربة المعنى، وهي راجعة إلى ما قلنا». ونسب هذا الترجيح لابن جرير. وجمع ابنُ تيمية (٥/٥٤٧) بين تفسير الأثارة بالإسناد والخطّ بقوله: «والأثارة كما قال مَن قال مِن السلف: هي الرواية والإسناد. وقالوا: هي الخطّ أيضًا. إذ الرواية والإسناد يُكتب بالخطّ؛ وذلك لأنّ الأثارة من الأثر، فالعلم الذي يقوله مَن يُقبل قوله يؤثر بالإسناد، ويُقيّد بالخطّ؛ فيكون كل ذلك من آثاره». <q>﴿ٱئۡتُونِی بِكِتَـٰبࣲ مِّن قَبۡلِ هَـٰذَاۤ أَوۡ أَثَـٰرَةࣲ مِّنۡ عِلۡمٍ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤﴾</q> - آثار متعلقة بالآية ٧٠٤٠٤- عن أبي هريرة، قال: قال رسول الله ﷺ: «كان نبيٌّ مِن الأنبياء يَخُطّ، فمَن صادف مِثْل خطّه عَلِم»{23}. (١٣/٣١١) ٧٠٤٠٥- عن عطاء بن يسار، عن معاوية بن الحكم السلمي، قال: قلت: ومِنّا رجال يخطّون. فقال النبي ﷺ: «كان نبيٌّ من الأنبياء يخط، فمَن وافق خطه فذاك»{24}. (ز) ٧٠٤٠٦- عن عطاء بن يسار -من طريق صفوان بن سليم- قال: كان نبي من الأنبياء يَخطُّ، فمَن وافق مِثل خطّه عَلِمه، فهو عِلم{25}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٥.أخرجه إسحاق البستي ص٣٤١. وهي قراءة شاذة، تروى أيضًا عن ابن عباس، وعكرمة، وعمرو بن ميمون، وغيرهم. انظر: مختصر ابن خالويه ص١٤٠، والمحتسب ٢/٢٦٤.أخرجه أحمد ٣/٤٤٩ (١٩٩٢)، والحاكم ٢/٤٩٣ (٣٦٩٤)، والثعلبي ٩/٥-٦، من طريق صفوان بن سليم، عن أبي سلمة بن عبد الرحمن، عن ابن عباس به. قال الحاكم: «حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الهيثمي في المجمع ١/١٩٢ (٩٢٦-٩٢٧)، ٧/١٠٥ (١١٣٣٥): «رجال أحمد رجال الصحيح».عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٢١٥. وذكره العقيلي في الضعفاء ٢/٢٩٣ عن عطاء مرسلًا. وعزاه السيوطي إلى سعيد بن منصور. وأصل الحديث عند مسلم (١٢١) من حديث معاوية بن الحكم السلمي كما سيأتي في الآثار المتعلقة.أخرجه الحاكم ٢/٤٥٤، والخطيب ٤/٣٥٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.أخرجه ابن جرير ٢١/١١٣.أخرجه الطبراني في الأوسط (٤٧٢)، والحاكم ٢/٤٥٤.أخرجه ابن جرير ٢١/١١٥. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٦٠٢، وأخرجه الفريابي في تفسيره -كما في تغليق التعليق ٥/١٩٧-، وابن جرير ٢١/١١٤-١١٥. وعزاه السيوطي إلى ابن أبي حاتم، وعبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٦.تفسير الثعلبي ٩/٦.تفسير سفيان الثوري ص٢٧٦.أخرجه عبد الرزاق ٢/٢١٥، وابن جرير ٢١/١١٤ عن معمر عن الحسن بلفظ: شيء يستخرجونه فطرة.أخرجه عبد الرزاق ٢/٢١٥ من طريق معمر، وابن جرير ٢١/١١٤، ومن طريق الحسين أيضًا. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٦.أخرجه إسحاق البستي ص٣٤١.أخرجه الرافعي في تاريخ قزوين ٤/١٢٩.تفسير الثعلبي ٩/٦.تفسير مقاتل بن سليمان ٤/١٥.أخرجه ابن جرير ٢١/١١٣.أخرجه ابن جرير ٢١/١١٥.أخرجه أحمد ١٥/٥٨ (٩١١٧) بنحوه، والبزار ١٥/٢٢٩ (٨٦٥٦)، من طريق سفيان، عن عبد الله بن أبي لبيد، عن أبي سلمة، عن أبي هريرة به. قال الهيثمي في المجمع ٥/١١٦ (٨٤٧٣): «رجاله رجال الصحيح».أخرجه مسلم ٤/١٧٤٩ (١٢١).أخرجه سفيان الثوري ص٢٧٦.
46,5," <q>﴿وَمَنۡ أَضَلُّ مِمَّن یَدۡعُوا۟ مِن دُونِ ٱللَّهِ مَن لَّا یَسۡتَجِیبُ لَهُۥۤ إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ وَهُمۡ عَن دُعَاۤىِٕهِمۡ غَـٰفِلُونَ ۝٥﴾</q> - تفسير ٧٠٤٠٧- قال مقاتل بن سليمان: <q>﴿ومَن أضَلُّ مِمَّنْ يَدْعُوا﴾</q> يقول: فلا أحد أضلّ ممن يعبد <q>﴿مِن دُونِ اللَّهِ﴾</q> مِن الآلهة <q>﴿مَن لا يَسْتَجِيبُ لَهُ﴾</q> أبدًا إذا دعاه، يقول: لا تجيبهم الآلهة -يعني: الأصنام- بشيء أبدًا <q>﴿إلى يَوْمِ القِيامَةِ﴾</q> ثم قال: <q>﴿وهُمْ عَنْ دُعائِهِمْ غافِلُونَ﴾</q> يعني: الآلهة غافلون عمَّن يعبدها، فأخبر الله عنها في الدنيا{1}٥٩٦٣. (ز) ٥٩٦٣ على هذا القول فالضمير في قوله: <q>﴿عن دعائهم﴾</q> عائد على الأصنام، وهو ما ذكر ابنُ عطية (٧/٦٠٩)، ثم ساق احتمالًا آخر، فقال: «ويحتمل أن يكون الضمير في قوله: <q>﴿عن دعائهم غافلون﴾</q> للكفار، أي: ضلالهم بأنهم يدعون مَن لا يستجيب، فلا يتأملون ما عليهم في دعائهم مَن هذه صفته». ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٥-١٦.
