quran[4]{c,v,t}:
  2,283,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن كُنتُمۡ عَلَىٰ سَفَرࣲ وَلَمۡ تَجِدُوا۟ كَاتِبࣰا فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ فَإِنۡ أَمِنَ بَعۡضُكُم بَعۡضࣰا فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ أَمَـٰنَتَهُۥ وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ وَلَا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ وَمَن یَكۡتُمۡهَا فَإِنَّهُۥۤ ءَاثِمࣱ قَلۡبُهُۥۗ وَٱللَّهُ بِمَا تَعۡمَلُونَ عَلِیمࣱ ۝٢٨٣﴾</span> - نسخ الآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٧١<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق عبد الملك بن أبي نضرة، عن أبيه- أنّه قرأ هذه الآية: <span class="qpc-hafs">﴿یَـٰۤأیُّها ٱلَّذِینَ ءامَنُوۤا۟ إذا تَدایَنتُم بِدَیۡنٍ﴾</span>، حتى إذا بلغ: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span> قال: هذه نَسَخَتْ ما قبلها{1}. (٣/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن أبي خالد- قال: فكانوا يرون أنّ هذه الآية: <span class="qpc-hafs">﴿فإن أمن بعضكم بعضا﴾</span> نَسَخَتْ ما قبلها من الكتابة والشهود، رخصةً ورحمة من الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق أبي بكر- في قوله: <span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>، قال: هي منسوخة، <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span> يعني: نسخه ذلك{3}<span class=comment-ref>١٠٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٧</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٥/٧٩) و<u>ابنُ عطية</u> (٢/١١١) القول بالنسخ <span class="mustanad">استنادًا إلى إمكان الجمع</span>؛ إذ النسخ لا يُصار إليه إلا عند تعذر الجمع بين الآيتين.</p><p><span class="comment-type-4">وجَمَع</span> <u>ابنُ جرير</u> بين الآيتين بكون كتابة الدَّين واجبة، وقوله تعالى: <span class="qpc-hafs">﴿فَإنْ أمِنَ بَعْضُكُمْ بَعْضًا﴾</span> مُرَخِّص في ترك كتابة الدَّين عند التَّعَذُّر.</p><p><span class="comment-type-4">وجَمَع</span> <u>ابنُ عطية</u> بين الآيتين بأنّ الأمر بكتابة الدين للندب والاحتياط، وليس في الآية ما يفيد منع الكتابة عند الائتمان حتى يُصارَ إلى النسخ.</p><p>وينظر توجيه <u>ابن تيمية</u> لمعنى النسخ عند السلف عند قوله تعالى: <span class="qpc-hafs">﴿وإنْ تُبْدُوا ما فِي أنْفُسِكُمْ أوْ تُخْفُوهُ يُحاسِبْكُمْ بِهِ اللَّهُ﴾</span>.</div></p><p><h3><span class="qpc-hafs">﴿وَإِن كُنتُمۡ عَلَىٰ سَفَرࣲ وَلَمۡ تَجِدُوا۟ كَاتِبࣰا﴾</span> - قراءات الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">١١٥٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- أنه قرأ: (ولَمْ تَجِدُوا كِتابًا). وقال: قد يوجد الكاتب، ولا يوجد القلم ولا الدَّواة{4} ولا الصحيفة، والكِتابُ يجمع ذلك كله.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٥<span class="dash">-</span></span> قال: وكذلك كانت قراءة <span class="name-1">أُبَيٍّ</span>{5}. (٣/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنّه كان يقرؤها: (فَإن لَّمْ تَجِدُوا كِتابًا). وقال: الكُتّابُ كثيرٌ، لم يكن حِواءٌ{6} من العرب إلا كان فيهم كاتب؛ ولكن كانوا لا يقدرون على القِرْطاس{7}، والقلم، والدَّواة{8}. (٣ /٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيج، عن أبيه- أنّه قرأ: (فَإن لَّمْ تَجِدُوا كُتّابًا). قال: ربما وجد الرجل الصحيفةَ ولم يجد كاتبًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه كان يقرأ: (ولَمْ تَجِدُوا كُتّابًا) بضم الكاف، وتشديد التاء{10}. (٣/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٧٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق شعيب بن الحبحاب- أنّه كان يقرأ: (فَإن لَّمْ تَجِدُوا كِتابًا). قال: يوجد الكاتب، ولا توجد الدَّواة ولا الصحيفة{11}. (٣/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، مثله{10}. (٣/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق محمد بن يزيد، عن جويبر- قال: ما كان من بيعٍ حاضرٍ أمر اللهُ أن يُشْهِدوا، وما كان مِن بيع إلى أجل مسمى أمر اللهُ أن يكتب ويشهد عليه، وذلك في المقام، فإذا كان في السفر فتبايعوا (ولَمْ يَجِدُوا كُتّابًا)، يعني بالكتاب: إذا وجدوا الصحيفة والكتاب والدواة، فإن لم يجدوا <span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>. يقول: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ أمَـٰنَتَهُۥ﴾</span> وليأمن بعضكم بعضًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ﴾</span></p><p><span class="qpc-hafs">﴿ولَمۡ تَجِدُوا۟ كاتِبࣰا﴾</span>، يعني: لم تقدروا على كتابة الدَّيْن في السَّفَر{14}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- أنّه قرأها: (فَإن لَّمْ تَجِدُوا كِتابًا) قال: مِدادًا{15}. وفي رواية: ربما وُجِد الكُتّاب، ولم تُوجَدِ الصحيفة أو المِداد{16}. (٣/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> أنّه قرأها: (فَإن لَّمْ تَجِدُوا كِتابًا){17}. (٣/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- قوله: <span class="qpc-hafs">﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ ولَمۡ تَجِدُوا۟ كاتِبࣰا﴾</span> يقول: كاتبًا يكتب لكم <span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>{18}<span class=comment-ref>١٠٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٨</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/١٢١) و<u>ابنُ عطية</u> (٢/١٢٦) قراءة <span class="qpc-hafs">﴿كاتبًا﴾</span> لموافقتها خط المصحف.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> قراءة (كِتابًا) فقال: «والقراءة التي لا يجوز غيرها عندنا هي قراءة: <span class="qpc-hafs">﴿ولم تجدوا كاتبًا﴾</span>، بمعنى: من يكتب؛ <span class="mustanad">لأن ذلك كذلك في مصاحف المسلمين</span>، وغير جائز القراءة بغير ما في مصاحف المسلمين مُثْبَتٌ من القراءات».</div></p><p><h3><span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- قال: لا يكون الرهن إلا مقبوضًا، يقبضه الذي له المال. ثم قرأ: <span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>{19}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>، يقول: فلْيَرْتَهِن الذي له الحق من المطلوب{14}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿<b>وإنْ كُنْتُمْ عَلى سَفَرٍ ولَمْ تَجِدُوا كاتِبًا فَرُهُنٌ مَقْبُوضَةٌ</b>﴾</span>، قال: لا يكون الرَّهْن إلا في السفر{21}<span class=comment-ref>١٠٧٩</span>. (٣/٤٠٨)</p></p><p></div></p><p><div><span class=comment-ref>١٠٧٩</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> (٥/١٢٥)، و<u>ابنُ عطية</u> (٢/١٢٥-١٢٦)، و<u>ابنُ كثير</u> (١/٧٢٧) <span class="mustanad">مستندين إلى السُّنَّةِ</span> القولَ بكون الرهن لا يصار إليه إلا عند تعذر الكاتب والشهيد، وأنّ ذلك في السفر لا في الحضر.</p><p>قال <u>ابنُ جرير</u> عَقِب إيراده أثر الضحاك: «إنه قول لا معنى له؛ لصحة الخبر عن رسول الله ﷺ أنه اشترى طعامًا نَساءً، فجائز للرجل أن يرهن ويرتهن، في السفر والحضر؛ لصحة الخبر عن رسول الله ﷺ، ولأنه لم يكن مُتَعَذِّرًا عليه بمدينته في وقت من الأوقات الكاتب والشاهد».</p><p>وبيَّن <u>ابنُ عطية</u> أنّ ذكر السفر في الآية وارد مورد التمثيل للأعذار، لا مورد الحصر لها، فيدخل في الآية كل عذر يحول دون الكتابة.</div></p><p><div></p><p><p><span class="item-no">١١٥٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي زهير، عن جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ﴾</span> الآية، قال: مَن كان على سفر، فبايع بيعًا إلى أجل، فلم يجد كاتبًا؛ فرُخِّص له في الرهان المقبوضة، وليس له إن وجد كاتبًا أن يرتهن{22}. (٣/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩٠<span class="dash">-</span></span> عن خالد بن دينار، قال: سألت <span class="name-2">سالم [بن عبد الله بن عمر]</span> عن الرهن في السلم. فقرأ: <span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>، كأنّه لم ير به بأسًا{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ ولَمۡ تَجِدُوا۟ كاتِبࣰا فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span>، يقول: إذا لم يكن الكاتب والصحيفة حاضِرَيْن فلْيَرْتَهِن الذي عليه الحقُّ مِن المطلوب{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٥٩٢<span class="dash">-</span></span> عن عائشة، قالت: اشترى رسول الله ﷺ طعامًا من يهودي بنسيئة، ورهنه دِرْعًا له من حديد{25}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩٣<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق ابن أبي نَجِيح- أنّه كان لا يرى بأسًا بالرَّهن والقبيل{26} في السَّلَف. وكره ذلك <span class="name-2">مجاهد</span>، وقال: يُكْرَه الرهن إلا في السفر{27}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنۡ أَمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٥٩٤<span class="dash">-</span></span> عن <span class="name-2">سـعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span>، يقول: فإن كان الذي عليه الحقُّ أمينًا عند صـاحب الحق، فلم يرتهن لِثِقَته وحُسْنِ ظنِّه{28}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر-: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span> فمن لم يجد فإنها عزمة أن يكتب ويشهد، ولا يأخذ رهنًا إذا وجد كاتبًا، كما قال في الظِّهار: <span class="qpc-hafs">﴿فَمَن لَّمۡ یَجِدۡ فَصِیامُ شَهۡرَیۡنِ مُتَتابِعَیۡنِ﴾</span> [المجادلة:٤]، وكما قال في موضع آخر: <span class="qpc-hafs">﴿فَما ٱسۡتَیۡسَرَ مِنَ ٱلۡهَدۡیِۖ﴾</span> [البقرة:١٩٦]، فهذا يشبه بعضه بعضًا، وآية الدين حكم حكَمه الله وفصَّله وبيَّنه، فليس لأحد أن يَتَخَيَّر في حكم الله{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق الثوري وابن عيينة، عن ابن شُبْرُمَة- قال: لا بأس إذا أمِنتَهُ أن لا تكتب ولا تشهد؛ لقوله: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span>{30}. (٣/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩٧<span class="dash">-</span></span> عن <span class="name-2">حماد بن أبي سليمان</span> -من طريق أبي سنان- في قوله: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span>، قال: أخلاقٌ دَلَّهُم عليها{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٥٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</span> في السفر، فإن كان الذي عليه الحق أمينًا عند صاحب الحق فلم يرتهن منه لثقته به وحسن ظنه{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ أَمَـٰنَتَهُۥ وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٥٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ﴾</span></p><p><span class="qpc-hafs">﴿أمَـٰنَتَهُۥ﴾</span>، يقول: ليُؤدِّ الحَقَّ الذي عليه إلى صاحبه{14}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿فَلۡیُؤَدِّ ٱلَّذِی﴾</span></p><p><span class="qpc-hafs">﴿ٱؤۡتُمِنَ أمَـٰنَتَهُۥ﴾</span>، قال: صار الأمرُ إلى الأمانة{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠١<span class="dash">-</span></span> عن العلاء بن المسيب: أنه سمع <span class="name-2">الحكم [بن عُتَيْبة]</span> يقول: نَسَخَتْ هذه الشهودَ{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلۡیُؤَدِّ﴾</span> ذلك <span class="qpc-hafs">﴿ٱلَّذِی ٱؤۡتُمِنَ أمَـٰنَتَهُۥ ولۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</span>، يقول: لِيَرُدَّ على صاحب الحقِّ حقَّه حين ائتمنه ولم يَرْتَهِن منه{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٠٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قال: خوَّف اللهُ الذي عليه الحقُّ، فقال: <span class="qpc-hafs">﴿ولۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</span>{14}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوَّفه الله ﷿، فقال: <span class="qpc-hafs">﴿ولۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</span>، يعني: الذي عليه الحق{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٠٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ولا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</span>، يعني: عند الحكام. يقول: مَن أُشْهِد على حقٍّ فلْيُقِمْها على وجهها كيف كانت{14}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿ولا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</span>، قال: فلا يـحِلُّ لأحد أن يكتم شهادة هي عنده، وإن كانت على نفسه والوالدين{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى الشهود، فقال: <span class="qpc-hafs">﴿ولا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</span></p><p>عند الحاكم. يقول: مَن أُشْهِد على حقٍّ فليشهد بها على وجهها كما كانت عند الحاكم، فلا تكتموا الشهادة{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٦٠٨<span class="dash">-</span></span> عن أبي سعيد الخدري، قال: قال رسول الله ﵇: <b>«لا يَمْنَعَنَّ أحَدَكم هَيْبَةُ الناس أن يقول في حقٍّ إذا رآه أو شَهِده أو سَمِعه»</b>{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٠٩<span class="dash">-</span></span> عن مكحول، عن أبي بردة، عن أبيه، عن النبيِّ ﷺ، قال: <b>«مَن كتم الشهادة إذا دُعي كان كمن شهد بالزور»</b>{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن دينار- قال: إذا كانت عندك شهادةٌ، فسألَك عنها؛ فأخْبِرْه بها، ولا تقل: أُخْبِرُ بها عند الأمير. أخْبِرْه بها لعلَّه يراجع أو يرعوي{44}<span class=comment-ref>١٠٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/١٣١) على قول ابن عباس بقوله: «وهذا عندي بحسب قرينة حال الشاهد، والمشهود فيه، والنازلة، لا سيما مع فساد الزمن، وأرذال الناس، ونفاق الحيلة، وأغراض الدنيا عند الحكام، فرُبَّ شهادة إن صرح بها في غير موضع النفوذ كانت سببًا لتخدم باطلًا ينطمس به الحق».</div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَكۡتُمۡهَا فَإِنَّهُۥۤ ءَاثِمࣱ قَلۡبُهُۥۗ وَٱللَّهُ بِمَا تَعۡمَلُونَ عَلِیمࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قال: أكبر الكبائر: الإشراك بالله؛ لأن الله ﷿ يقول: <span class="qpc-hafs">﴿مَن یُشۡرِكۡ بِٱللَّهِ فَقَدۡ حَرَّمَ ٱللَّهُ عَلَیۡهِ ٱلۡجَنَّةَ﴾</span> [المائدة:٧٢]، وشهادة الزور، وكتمان الشهادة؛ لأن الله يقول: <span class="qpc-hafs">﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</span>{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- قال: نزلت في الشهادة: <span class="qpc-hafs">﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</span>{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ومَن یَكۡتُمۡها﴾</span> يعني: الشهادة، ولا يشهدُ بها إذا دُعِيَ لها؛ <span class="qpc-hafs">﴿فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ وٱللَّهُ بِما تَعۡمَلُونَ﴾</span> يعني: من كتمان الشهادة، وإقامتها{14}. (٣/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٤<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق فضيل- <span class="qpc-hafs">﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</span>، قال: بعد ما يشهد{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ءاثِمࣱ قَلۡبُهُۥۗ﴾</span>، قال: فاجِرٌ قلبُه{49}. (٣/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</span>، قال: ومَن كتمها فقد ركب إثمًا عظيمًا{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿ومَن یَكۡتُمۡها﴾</span> ولا يشهد بها عند الحاكم، <span class="qpc-hafs">﴿فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ وٱللَّهُ بِما تَعۡمَلُونَ﴾</span> من كتمان الشهادة وإقامتها <span class="qpc-hafs">﴿عَلِیمࣱ﴾</span>{51}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري في التاريخ الكبير ١/٢٣٢، والنحاس ص٢٦٧-٢٦٨ في ناسخه، وابن ماجه (٢٣٦٥)، وابن جرير ٥/٧٥-٧٦، وابن المنذر (٧٤)، وابن أبي حاتم ٢/٥٧٠ (٣٠٤١)، وأبو نعيم في الحلية ٩/٤٨، والبيهقي في سُنَنه ١٠/١٤٥. وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه سفيان الثوري في تفسيره بنحوه ص٧٣، وابن جرير ٥/٧٤.</p><p>وتقدم في الآية السابقة زيادة بيان ذلك، والراجح في المسألة.أخرجه ابن أبى حاتم ٢/٥٧٠.الدَّواة: المحبرة. مختار الصحاح (دوى).أخرجه أبو عبيد في فضائله ص١٦٧، وسعيد بن منصور في سننه ٤٦٨ - تفسير، وابن جرير ٥/١٢٢، وابن المنذر (١٥٠)، وابن أبي حاتم ٢/٥٦٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن الأنباري في المصاحف.</p><p>وقراءة (كِتابًا) قراءة شاذة، وهي تنسب إلى أُبَيٍّ، وابن عباس، ومجاهد، وعكرمة. انظر: مختصر ابن خالويه ص١٨، والبحر المحيط ٢/٣٥٥.الحِواء: جماعة البيوت المتدانية. لسان العرب (حوى).القِرطاس: الصحيفة يكتب فيها. تاج العروس (قرطس).أخرجه ابن المنذر (١٥٢)، وابن أبي حاتم بنحوه مختصرًا ٢/٥٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٢٢.</p><p>وقراءة ابن عباس، والضحاك، وأبي العالية: (كُتّابًا) شاذة. انظر: البحر المحيط ٢/٣٥٥، وتفسير القرطبي ٣/٤٠٧.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ٥/١٢٣، وابن المنذر (١٥٤). وعلَّقه ابن أبي حاتم ٢/٥٦٩. وينظر: تفسير الثعلبي ٢/٢٩٧. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن المنذر (١٥٧)، وابن أبي حاتم ٢/٥٦٩ مختصرًا من طريق مروان عن جويبر، ولفظه: يعني بذلك: أنه لا يصلح إذا كان بيعًا في سفر إذا وجد كتابًا أن يأخذ رهنًا، ولكن ليكتب حقه إلى أجله.أخرجه ابن أبي حاتم ٢/٥٦٩.المِداد: الحبر. تاج العروس (حبر).أخرجه أبو عبيد في فضائل القرآن ص١٦٧، وابن جرير ٥/١٢٢، وابن المنذر (١٥٣). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن الأنباري.أخرجه أبو عبيد في فضائل القرآن ص١٦٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن الأنباري.أخرجه ابن جرير ٥/١٢١.أخرجه ابن المنذر (١٥٥)، وابن أبي حاتم ٢/٥٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن المنذر (١٥٨)، وابن أبي حاتم ٢/٥٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٢١، وابن المنذر (١٥٦) من طريق محمد بن عبد الله بن يزيد عن جويبر، وابن أبي حاتم ٢/٥٦٩ من طريق مروان عن جويبر، وعندهما بلفظ: يعني بذلك: أنه لا يصلح إذا كان بيعًا في سفر إذا وجد كتابًا أن يأخذ رهنًا، ولكن ليكتب حقه إلى أجله.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٤٩٩ (٢٠٣٩٠).تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه البخاري ٣/٥٦ (٢٠٦٨)، ٣/٦٢ (٢٠٩٦)، ٣/٧٧ (٢٢٠٠)، ٣/٨٦ (٢٢٥١)، ٣/٨٦ (٢٢٥٢)، ٣/١١٥ (٢٣٨٦)، ٣/١٤٢ (٢٥٠٩)، ٣/١٤٣ (٢٥١٣)، ومسلم ٣/١٢٢٦ (١٦٠٣).القبيل: الكفيل. لسان العرب (قبل).أخرجه ابن المنذر (١٥٨).أخرجه ابن أبي حاتم ٢/٥٦٩ (٣٠٣٦).أخرجه ابن المنذر (١٥٦)، وابن أبي حاتم ٢/٥٧٠ (٣٠٤٣).أخرجه عبد الرزاق ١/١١١، وابن جرير ٥/٧٤، وابن المنذر (١٥٩)، وابن أبي حاتم ٢/٥٧٠، والبيهقي -من طريق داود- بنحوه ١٠/١٤٥. وعزاه السيوطي إلى عَبد بن حُمَيد. وزاد عبد الرزاق من طريق ابن عيينة: إلى هذا انتهى <span class="qpc-hafs">﴿فَإنۡ﴾</span> <span class="qpc-hafs">﴿أمِنَ﴾</span> <span class="qpc-hafs">﴿بَعۡضُكُم﴾</span> <span class="qpc-hafs">﴿بَعۡضࣰا﴾</span>. كما أخرج نحوه ابن جرير ٥/٧٤ من طريق عاصم.أخرجه ابن أبي حاتم ٢/٥٧١.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن أبي حاتم ٢/٥٧١.أخرجه ابن المنذر (١٦٠).تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٩.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن جرير ٥/١٢٦، وابن أبي حاتم ٢/٥٧١ بزيادة: أو الأقربين.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه أحمد ١٨/٣١٧ (١١٧٩٣) واللفظ له، والترمذي ٤/٢٦٠ (٢٣٣٦)، وابن ماجه ٥/١٤١ (٤٠٠٧)، وابن حبان ١/٥٠٩ (٢٧٥)، ١/١٢ (٢٧٨)، والحاكم ٤/٥٥١ (٨٥٤٣)، بنحوه.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث تفرَّد بهذه السياقة علي بن زيد بن جدعان القرشي، عن أبي نضرة، والشيخان ﵄ لم يحتجا بعلي بن زيد». وقال الذهبي في التلخيص: «ابن جدعان صالح الحديث». وإسناد أحمد ليس فيه ابن جدعان، وهو صحيح على شرط مسلم، كما قال الألباني في الصحيحة ١/٣٢٢ (١٦٨).أخرجه الطبراني في الأوسط ٤/٢٧٠ (٤١٦٧). وأورده الثعلبي ٢/٢٩٩.</p><p>قال الطبراني: «لم يرو هذا الحديث عن مكحول إلا العلاء، ولا عن العلاء إلا معاوية، ولا عن معاوية إلا عبد الله بن صالح، تفرد به أبو قرة». قال الهيثمي في المجمع ٤/٢٠٠ (٧٠٣٨): «رواه الطبراني في الكبير والأوسط، وفيه عبد الله بن صالح، وثّقه عبد الملك بن شعيب بن الليث، فقال: ثقة مأمون، وضعّفه جماعة». وقال الألباني في الضعيفة ٣/٤٢٨ (١٢٦٧): «ضعيف».أخرجه ابن جرير ٥/١٢٧.أخرجه ابن جرير ٥/١٢٧، وابن أبي حاتم ٢/٥٧١.أخرجه ابن المنذر (١٦١).</p><p>كذا في هذه الرواية الإشارة إلى هذه الآية، وفي رواية أخرى عند ابن جرير وابن المنذر الإشارة إلى قوله تعالى: <span class="qpc-hafs">﴿وإن﴾</span> <span class="qpc-hafs">﴿تُبۡدُوا۟﴾</span> <span class="qpc-hafs">﴿ما﴾</span> <span class="qpc-hafs">﴿فِیۤ﴾</span> <span class="qpc-hafs">﴿أنفُسِكُمۡ﴾</span> الآية، كما أخرج نحوه سعيد بن منصور، وابن جرير، وابن المنذر، وابن أبي حاتم من طريق مجاهد. وسيأتي.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن المنذر (١٦٢).أخرجه ابن جرير ٥/١٢٦، وابن أبي حاتم ٢/٥٧٢.أخرجه ابن جرير ٥/١٢٦.تفسير مقاتل بن سليمان ١/٢٣١.
  2,284,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَإِن تُبۡدُوا۟ مَا فِیۤ أَنفُسِكُمۡ أَوۡ تُخۡفُوهُ یُحَاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٢٨٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٦١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> دخل في قلوبهم شيءٌ منه لم يدخلْ من شيء، فقالوا للنبي ﷺ، فقال: <b>«قولوا: سمعنا، وأطعنا، وسلَّمْنا»</b>. فألقى اللهُ الإيمانَ في قلوبهم؛ فأنزل الله: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ﴾</span> الآية، <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>. قال: قد فعلتُ. <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>. قال: قد فعلتُ. <span class="qpc-hafs">﴿وٱعۡفُ عَنّا وٱغۡفِرۡ لَنا وٱرۡحَمۡناۤۚ﴾</span> الآية، قال: قد فعلتُ{1}. (٣/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا نزلت: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> الآيةَ؛ أتى أبو بكر وعمرُ ومعاذُ بن جبل وسعدُ بن زرارة رسولَ الله ﷺ، فقالوا: ما نزل علينا آيةٌ أشدُّ مِن هذه{2}. (٣/٤١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: نزلت في الشهادة{3}. (٣/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</span> الآية، قال: نزلت في كتمان الشهادة، وإقامتها{4}. (٣/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٢<span class="dash">-</span></span> عن <span class="name-2">مقسم</span>، مثل ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طرق- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، يعني: كتمان الشهادة، وإقامتها على وجهها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق السُّدِّي- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>، قال: في الشهادة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق خالد بن زيد- قال: ما بعث الله من نبي، ولا أرسل من رسول أنزل عليهم الكتاب إلا أنزل عليه هذه الآية: <span class="qpc-hafs">﴿لِّلَّهِ ما فِی ٱلسَّمَـٰو ٰ⁠تِ وما فِی ٱلۡأرۡضِۗ وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشاۤءُ ویُعَذِّبُ مَن یَشاۤءُۗ وٱللَّهُ عَلىٰ كُلِّ شَیۡءࣲ قَدِیرٌ﴾</span>، فكانت الأمم تأبى على أنبيائها ورسلها، ويقولون: نؤاخذ بما نحدث به أنفسنا ولم تعمله جوارحنا؟! فيكفرون، ويَضِلُّون، فلمّا نزلت على النبي ﷺ اشتَدَّ على المسلمين ما اشْتَدَّ على الأمم قبلهم، فقالوا: يا رسول الله، أنؤاخذ بما نُحَدِّث به أنفسنا ولم تعمله جوارحنا؟! قال: <b>«نعم، واسمعوا وأطيعوا، واطلبوا إلى ربكم»</b>. فذلك قوله: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ﴾</span> الآية، فوضع الله عنهم حديث النفس، إلا ما عملت الجوارح{8}. (٣/٤١٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَإِن تُبۡدُوا۟ مَا فِیۤ أَنفُسِكُمۡ أَوۡ تُخۡفُوهُ یُحَاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٢٨٤﴾</span> - ما جاء في أنَّ الآية منسوخة</h3></p><p><div></p><p><p><span class="item-no">١١٦٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الضحاك- في الآية، قال: كانت المحاسبة قبل أن تنزل <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>، فلما نزلت نسخت الآية التي كانت قبلها{9}. (٣/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق السدي- قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> الآية؛ أحزنتنا، قلنا: أيُحَدِّث أحدُنا نفسَه فيحاسب به؟! لا ندري ما يغفر منه، ولا ما يغفر منه؟ فنزلت هذه الآية بعدها، فنَسَخَتْها: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>{10}. (٣/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٨<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: لَمّا نزلت على رسول الله ﷺ: <span class="qpc-hafs">﴿لِّلَّهِ ما فِی ٱلسَّمَـٰو ٰ⁠تِ وما فِی ٱلۡأرۡضِۗ وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشاۤءُ ویُعَذِّبُ مَن یَشاۤءُۗ وٱللَّهُ عَلىٰ كُلِّ شَیۡءࣲ قَدِیرٌ﴾</span>؛ اشْتَدَّ ذلك على أصحاب رسول الله ﷺ، فأتوا رسول الله ﷺ، ثم جثوا على الرُّكَب، فقالوا: يا رسول الله، كُلِّفْنا من الأعمال ما نُطِيق؛ الصلاة، والصيام، والجهاد، والصدقة، وقد أُنزِلت عليك هذه الآية ولا نُطِيقها. فقال رسول الله ﷺ: <b>«أتريدون أن تقولوا كما قال أهلُ الكتابين من قبلكم: سمعنا وعصينا؟! بل قولوا:</b> <span class="qpc-hafs">﴿سَمِعۡنا وأَطَعۡناۖ غُفۡرانَكَ رَبَّنا وإلَیۡكَ ٱلۡمَصِیرُ﴾</span>». فلما اقْتَرَأَها القومُ، وذَلَّت بها ألسنتهم؛ أنزل الله في إثرها: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ﴾</span> الآية، فلما فعلوا ذلك نسخها الله، فأنزل: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span> إلى آخرها{11}. (٣/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٢٩<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> أم المؤمنين -من طريق قتادة- في الآية، قالت: نسخها قوله: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>{12}. (٣/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> نُسِخَت، فقال: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{13}. (٣/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: لَمّا نزلت اشْتَدَّ ذلك على المسلمين وشَقَّ عليهم، فنسخها الله؛ فأنزل: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{14}. (٣/٤١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٢<span class="dash">-</span></span> عن سالم بن عبد الله بن عمر: أنّ أباه قرأ: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، فدمعت عيناه، فبــلغ صنيعُه <span class="name-1">عبدَ الله بن عبـاس</span>، فقال: يرحم الله أبا عبد الرحمن، لقد صنع كما صنع أصحاب رسول الله ﷺ حين أُنزلت، فنسختها الآية التي بعدها: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{15}. (٣/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٣<span class="dash">-</span></span> عن مجاهد، قال: دخلتُ على <span class="name-1">ابن عباس</span>، فقلتُ: كنتُ عند ابن عمر، فقرأ هذه الآية، فبكى. قال: أيةُ آيةٍ؟ قلت: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>. قال ابن عباس: إن هذه الآية حين أُنزلت غمَّتْ أصحابَ رسول الله ﷺ غمًّا شديدًا، وغاظتهم غيظًا شديدًا، وقالوا: يا رسول الله، هلكنا إن كنا نؤاخذ بما تكلمنا وبما نعمل، فأمّا قلوبنا فليست بأيدينا. فقال لهم رسول الله ﷺ: <b>«قولوا: سمعنا وأطعنا».</b> قال: فنسختها هذه الآية: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ﴾</span> إلى <span class="qpc-hafs">﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>، فتُجُوِّزَ لهم عن حديث النفس، وأُخِذُوا بالأعمال{16}. (٣/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٤<span class="dash">-</span></span> عن مروان الأصفر، عن رجل من أصحاب النبي ﷺ أحسـبه <span class="name-1">ابن عمر</span>: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>، قال: نَسَخَتْها الآيةُ التي بعدها{17}. (٣/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٦<span class="dash">-</span></span> <span class="name-2">وعكرمة مولى ابن عباس</span>: أنها منسوخة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٧<span class="dash">-</span></span> عن <span class="name-2">أبي عبيدة بن عبد الله بن مسعود</span> -من طريق الشعبي- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: نســـخت هذه الآيةُ التي بعدها: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب، وآدم بن سليمان- قال: نَسَخَتْ هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>، <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٣٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق آدم بن سليمان- قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>؛ قالوا: أنُؤاخذ بما حَدَّثْنا به أنفسَنا ولم تعمل به جوارحُنا؟! قال: فنزلت هذه الآية: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>. قال: ويقول: قد فعلتُ. <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>. قال: ويقول: فعلتُ. قال: فأعطيت هذه الأمة خواتيم سورة البقرة، لم تُعْطَها الأمم قبلها{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق إبراهيم بن مهاجر- قال: نَسَخَها <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر، وإبراهيم بن مهاجر-: نَسَخَتْ هذه الآيةُ: <span class="qpc-hafs">﴿﴾</span> الآية{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق سَيّار، وغيره- قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشاۤءُ ویُعَذِّبُ مَن یَشاۤءُۗ﴾</span>، قال: فكان فيها شِدَّة، حتى نزلت هذه الآية التي بعدها: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>. قال: فنسخت ما كان قبلها{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٣<span class="dash">-</span></span> عن ابن عون، قال: ذكروا عند <span class="name-2">الشعبي</span>: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>، حتى بلغ: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>. قال: فقال الشعبيُّ: إلى هذا صار، رجعت إلى آخر الآية{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق مغيرة- <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: نَسَخَتْها الآيةُ التي بعدها: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>. وقوله: <span class="qpc-hafs">﴿وإن تبدوا﴾</span> قال: يحاسب بما أبدى مِن سِرٍّ، أو أخفى مِن سِرٍّ، فنسختها التي بعدها{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق حميد- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span> إلى آخر الآية، قال: نَسَخَتْها: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق معمر بن راشد- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: نَسَخَتْها قولُه: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٨<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٤٩<span class="dash">-</span></span> و<span class="name-3">الكلبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٠<span class="dash">-</span></span> و<span class="name-3">موسى بن عبيدة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥١<span class="dash">-</span></span> وشيبة، نحو ذلك{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٢<span class="dash">-</span></span> قال <span class="name-2">محمد ابن شهاب الزهري</span>: قال تعالى: <span class="qpc-hafs">﴿وإن تبدوا ما في أنفسكم أو تخفوه يحاسبكم به الله فيغفر لمن يشاء ويعذب من يشاء﴾</span>، نُسخت بقوله تعالى: <span class="qpc-hafs">﴿لا يكلف الله نفسا إلا وسعها لها ما كسبت وعليها ما اكتسبت﴾</span>، أي: لا يُكتب على أحد إلا ما فعل وما عَمِل{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: يوم نزلت هذه الآية كانوا يؤاخذون بما وسْوَسَتْ به أنفسُهم وما عَمِلوا، فشَكَوا ذلك إلى النبي ﷺ، فقالوا: إن عَمِل أحدُنا وإن لم يَعْمَل أُخِذْنا به؟!، واللهِ، ما نملك الوسوسة. فنسخها اللهُ بهذه الآية التي بعدها بقوله: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، فكان حديثُ النفس مما لم تطيقوا{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلما نزلت هذه الآيةُ قال المسلمون: يا رسول الله، إنّا نُحَدِّثُ أنفسَنا بالشرك والمعصية، أفيحاسبنا اللهُ بها ولا نعملها؟ فأنزل الله ﷿ في قولهم في التقديم: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span> ...، فنسخت هذه الآية قولَه سبحانه: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق عبد الله بن وهب- قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> إلى آخر الآية اشتدت على المسلمين، وشقت مشقة شديدة، فقالوا: يا رسول الله، لو وقع في أنفسنا شيء لم نعمل به وأخذنا الله به؟ قال: <b>«فلعلكم تقولون كما قال بنو إسرائيل لموسى: سمعنا وعصينا</b>؟!». قالوا: بل سمعنا وأطعنا، يا رسول الله. قال: فنزل القرآنُ يُفَرِّجها عنهم: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ وٱلۡمُؤۡمِنُونَۚ كُلٌّ ءامَنَ بِٱللَّهِ ومَلَـٰۤىِٕكَتِهِۦ وكُتُبِهِۦ ورُسُلِهِۦ﴾</span> إلى قوله: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>. قال: فصَيَّره إلى الأعمال، وترك ما يقع في القلوب{33}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَإِن تُبۡدُوا۟ مَا فِیۤ أَنفُسِكُمۡ أَوۡ تُخۡفُوهُ یُحَاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٢٨٤﴾</span> - ما جاء في أن الآية محكمة غير منسوخة</h3></p><p><div></p><p><p><span class="item-no">١١٦٥٦<span class="dash">-</span></span> عن أُمَيَّة: أنها سألت <span class="name-1">عائشةَ</span> عن قول الله تعالى: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، وعن قوله: <span class="qpc-hafs">﴿مَن یَعۡمَلۡ سُوۤءࣰا یُجۡزَ بِهِۦ﴾</span> [النساء:١٢٣]. فقالت: ما سألني عنها أحدٌ منذُ سألتُ رسولَ الله ﷺ، فقال: <b>«هذه معاتبة الله العبدَ</b>{34} <b>فيما يصيبه من الحُمّى والنَّكْبَة، حتى البضاعة يضعها في يد قميصه، فيفقدها، فيفزع لها، ثم يجدها في ضِبْنه</b>{35}، <b>حتى إنّ العبد ليخرج من ذنوبه كما يخرج التِّبْرُ</b>{36} <b>الأحمرُ مِن الكِير</b>{37}»{38}. (٣/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٧<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</span> الآية، قالت: هو الرجل يَهُمُّ بالمعصية ولا يعملها، فيرسل عليه من الغم والحزن بقدر ما كان همَّ به من المعصية، فتلك محاسبته{39}. (٣/٤١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٨<span class="dash">-</span></span> عن يحيى، قال: شهدتُ عمرَو بنَ عبيد ويونسَ بن عبيد يتناظران في المسجد الحرام في قول الله ﷿: <span class="qpc-hafs">﴿وإن تبدوا ما في أنفسكم أو تخفوه يحاسبكم به الله﴾</span>، فقالا: قالتْ <span class="name-1">عائشةُ</span>: كلُّ روعة تَمُرُّ بقلبِ ابن آدم تخوف من شيء لا يحل به فهو كفّارةٌ لكل ذنب هَمَّ به فلم يعمله{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span> فذلك سرُّ أمرك وعلانيتك، <span class="qpc-hafs">﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> فإنها لم تنسخ، ولكن الله إذا جمع الخلائق يوم القيامة يقول: إني أُخبركم بما أخفيتم في أنفسكم مما لم تطَّلع عليه ملائكتي، فأما المؤمنون [فيخبرهم ويغفر لهم ما حَدَّثوا به أنفسهم، وهو قوله: <span class="qpc-hafs">﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>. يقول: يخبركم، وأما أهل الشك والريب]{41} فيخبرهم بما أخفوا من التكذيب، وهو قوله: <span class="qpc-hafs">﴿ولَـٰكِن یُؤاخِذُكُم بِما كَسَبَتۡ قُلُوبُكُمۡۗ﴾</span> [البقرة:٢٢٥] [من الشك والنفاق]{42}]{43}. (٣/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال: فذلك سِرُّ عملِكم وعلانيتُه، يحاسبكم به الله، فليس من عبدٍ مؤمنٍ يُسِرُّ في نفسه خيرًا ليعمل به، فإن عمل به كتبت له به عشر حسنات، وإن هو لم يُقدَّر له أن يعمل به كتبت له به حسنة من أجل أنّه مؤمن، والله يرضى سِرَّ المؤمنين وعلانيتَهم، وإن كان سوءًا حدَّث به نفسه اطَّلع الله عليه وأخبره به يوم تُبْلى السرائر، وإن هو لم يعمل به لم يؤاخذه الله به حتى يعمل به، فإن هو عمل به تجاوز الله عنه، كما قال: <span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ نَتَقَبَّلُ عَنۡهُمۡ أحۡسَنَ ما عَمِلُوا۟ ونَتَجاوَزُ عَن سَیِّـٔاتِهِمۡ﴾</span> [الأحقاف:١٦]{44}. (٣/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في الآية، قال: إنّ الله يقول يوم القيامة: إنّ كُتّابي لم يكتبوا من أعمالكم إلا ما ظهر منها، فأمّا ما أسررتم في أنفسكم فأنا أُحسابكم به اليوم؛ فأغْفِرُ لِمَن شئتُ، وأُعَذِّب مَن شئتُ{45}. (٣/٤١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٢<span class="dash">-</span></span> عن الضحاك، يقول في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>: كان <span class="name-1">ابن عباس</span> يقول: إذا دُعِي الناس للحساب أخبرهم اللهُ بما كانوا يسرون في أنفسهم مِمّا لم يعملوه، فيقول: إنّه كان لا يعزب عَنِّي شيء، وإنِّي مخبركم بما كنتم تُسِرُّون من السوء، ولم تكن حَفَظَتُكُم عليكم يَطَّلِعون عليه. فهذه المحاسبة{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٣<span class="dash">-</span></span> عن سعيد بن مرجانة: أنّه بينما هو جالس مع <span class="name-1">ابن عمر</span> تلا هذه الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span> الآية. قال: واللهِ، لَئِن واخذنا الله بهذا لنهلكن. ثم بكى حتى سُمِع نَشِيجُه.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٤<span class="dash">-</span></span> قال ابن مرجانة: فقمتُ حتى أتيتُ <span class="name-1">ابن عباس</span>، فذكرت له ما قال ابن عمر، وما فعل حين تلاها، فقال ابن عباس: يغفرُ اللهُ لأبي عبد الرحمن، لَعَمْرِي لقد وجد المسلمون منها حين أُنزلت مثل ما وجد عبد الله بن عمر؛ فأنزل الله بعدها: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span> إلى آخر السورة. قال ابن عباس: فكانت هذه الوسوسة مما لا طاقة للمسلمين بها، وصار الأمر إلى أن قضى الله أنّ للنفس ما كسبت، وعليها ما اكتسبت من القول والعمل{47}. (٣/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٥<span class="dash">-</span></span> عن نافع، قال: لَقَلَّما أتى <span class="name-1">ابنُ عمر</span> على هذه الآية إلّا بكى: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span> إلى آخر الآية. ويقول: إنّ هذا لَإحْصاء شديد{48}. (٣/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> <span class="name-2">بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>، قال: من اليقين والشك{49}. (٣/٤١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد- قال: هي مُحْكَمَةٌ، لم تُنسَخ{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span>: أنّها مُحْكَمَة{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٦٩<span class="dash">-</span></span> قال <span class="name-2">محمد بن علي</span>: معنى الآية: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</span> من الأعمال الظاهرة، <span class="qpc-hafs">﴿أوۡ تُخۡفُوهُ﴾</span> من الأحوال الباطنة؛ <span class="qpc-hafs">﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span> العابد على أفعاله، والعارف على أحواله{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- في الآية، قال: هي مُحْكَمَة، لم ينسخها شيء، يُعَرِّفه الله يوم القيامة أنّك أخفيت في صدرك كذا وكذا، ولا يؤاخذه{53}<span class=comment-ref>١٠٨١</span>. (٣/٤١٨)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/١٤٤)، و<u>ابنُ عطية</u> (٢/١٣٤)، و<u>ابنُ تيمية</u> (١/٦١٧، ٦٢٤) أنّ الآية هنا محكمة غير منسوخة <span class="mustanad">استنادًا إلى عدم التعارض، وذلك</span>: أ) أنها خبر، والأخبار لا تُنسخ. ب) إمكان الجمع بينها وبين قوله تعالى: <span class="qpc-hafs">﴿لا يُكَلِّفُ اللَّهُ نَفْسًا إلّا وُسْعَها﴾</span> بأوجه متعددة، منها: ١- أن المحاسبة على ما تخفيه النفس ليس مما في الوسع، وليس مما يُكسب أو يكتسب. ٢- أن المحاسبة لا يلزم منها المعاقبة، بل تكون محاسبة الله للمؤمنين فيما أخفوه إخبارهم به وغفرانه لهم؛ ليرَوا كبير فضل الله عليهم وعظيم إكرامه لهم. ٣- أنه لو لزم من المحاسبة المعاقبة لكانت المحاسبة مخصوصة بالكافرين الذين أخفوا في أنفسهم الشك في الله والكفر به.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> القول بالنسخ، فقال: «النسخ في لسان السلف أعمُّ مما هو في لسان المتأخرين؛ يريدون به: رفع الدلالة مطلقًا، وإن كان تخصيصًا للعامِّ، أو تقييدًا للمطلق، وغير ذلك، ومَن قال مِن السلف: نسخها ما بعدها. فمرادُه: بيان معناها والمراد منها، وذلك يسمى نسخًا في لسان السلف، كما يسمون الاستثناء نسخًا».</div></p><p><div></p><p><p><span class="item-no">١١٦٧١<span class="dash">-</span></span> قال <span class="name-3">جعفر بن محمد</span>: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</span> يعني: الإسلام، <span class="qpc-hafs">﴿أوۡ تُخۡفُوهُ﴾</span> يعني: الإيمان{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِّلَّهِ ما فِی ٱلسَّمَـٰو ٰ⁠تِ وما فِی ٱلۡأرۡضِۗ﴾</span> من الخلق عبيده وفي ملكه، يقضي فيهم ما يريد، <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span> يقول: إن تعلنوا بألسنتكم ما في قلوبكم من ولاية الكفار والنصيحة أو تسروه <span class="qpc-hafs">﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٣<span class="dash">-</span></span> عن <span class="name-3">الواقدي</span>، نحو قول مقاتل في قوله تعالى: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</span>{56}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٧٤<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: <b>«إنّ الله تجاوز لي عن أُمَّتِي ما حَدَّثت به أنفسَها، ما لم تتكلم أو تعمل به»</b>{57}. (٣/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس-: <span class="qpc-hafs">﴿فَیَغۡفِرُ لِمَن یَشاۤءُ﴾</span> الذنبَ العظيمَ، <span class="qpc-hafs">﴿ویُعَذِّبُ مَن یَشاۤءُۗ﴾</span> على الذنبِ الصغير{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قيس بن أبي حازم</span>، قال: إذا كان يومُ القيامة قال اللهُ -تبارك وتعالى- يسمع الخلائق: إنما كان كُتّابي يكتبون عليكم ما ظهر منكم، فأمّا ما أسررتم فلم يكونوا يكتبونه، ولا يعلمونه، أنا الله أعلمُ بذلك كله منكم؛ فأغفر لمن شئت، وأُعَذِّب مَن شئت{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> <span class="name-2">بن جبر</span> -من طريق منصور، أو ليث- في قوله: <span class="qpc-hafs">﴿فَیَغۡفِرُ لِمَن یَشاۤءُ﴾</span> الآية، قال: يغفر لمن يشاء الكبيرَ من الذنوب، <span class="qpc-hafs">﴿ویُعَذِّبُ مَن یَشاۤءُۗ﴾</span> على الصغير{60}. (٣/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، مثل ذلك{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٧٩<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق محمد بن يوسف- في قوله: <span class="qpc-hafs">﴿فَیَغۡفِرُ لِمَن یَشاۤءُ﴾</span> قال: يغفر لمن يشاء بالكبير، <span class="qpc-hafs">﴿ویُعَذِّبُ مَن یَشاۤءُۗ﴾</span> بالصغير{62}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وٱللَّهُ عَلىٰ كُلِّ شَیۡءࣲ﴾</span> من العذاب والمغفرة <span class="qpc-hafs">﴿قَدِیرٌ﴾</span>{63}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه مسلم ١/١١٦ (١٢٦).أخرجه الطبراني في مسند الشاميين ٣/٣٢٧ (٢٤١٥).</p><p>وإسناده ضعيف؛ فيه عطاء بن أبي مسلم الخراساني، قال ابن حجر في التقريب (٤٦٣٣): «صدوق، يهِم كثيرًا، ويُرسِل، ويُدَلِّس». وقد عَنْعَنَ في إسناد هذا الحديث.أخرجه سعيد بن منصور في التفسير من سننه ٣/١٠٠٤ (٤٧٣)، وابن جرير ٥/١٢٩، وابن المنذر ١/٩٣ (١٦١)، وابن أبي حاتم ٢/٥٧٢ (٣٠٥٦).</p><p>وإسناده ضعيف؛ فيه يزيد بن أبي زياد الكوفي، قال ابن حجر في التقريب (٧٧٦٨): «ضعيف، كبر فتغَيَّر، وصار يتلقن».أخرجه القاسم بن سلام في الناسخ والمنسوخ ص٢٧٤ (٥٠١)، وابن جرير ٥/١٣٠، وابن المنذر ١/٩٣ (١٦٣).</p><p>وإسناده ضعيف أيضًا؛ فيه يزيد بن أبي زياد الكوفي، سبق في الحديث الذي قبله.عَلَّقه ابن أبي حاتم ٢/٥٧٢.أخرجه أبو عبيد في ناسخه من طريق حميد ص٢٧٤ (٥٠٣)، وابن جرير من طريق داود وعمرو أبي سعيد وجويبر واللفظ له ٥/١٢٩، ١٣٠، وابن المنذر من طريق داود (١٦٤). وعَلَّقه ابن أبي حاتم ٢/٥٧٢.أخرجه ابن جرير ٥/١٣١. وعلَّقه ابن أبي حاتم ٢/٥٧٢.أخرجه ابن المنذر ١/٩٨-٩٩ (١٧٣) مرسلًا.أخرجه سعيد بن منصور في سننه (٤٨٢)، وابن جرير ٥/١٣٥، والطبراني في الكبير (٩٠٣٠). وأخرجه أبو عبيد في ناسخه ص٢٧٥ (٥٠٦) من طريق قتادة بنحوه.أخرجه الترمذي (٢٩٩٠). وعَلَّقه ابن أبي حاتم ٢/٥٧٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه مسلم ١/١١٥ (١٢٥)، وابن جرير ٥/١٣٠، وابن المنذر ١/٩٦ (١٧٠)، وابن أبي حاتم ٢/٥٧٣ (٣٠٦٠).أخرجه ابن جرير ٥/١٣٨.عزاه السيوطي إلى أبي داود في ناسخه.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٢٤٦-، والطبراني في الكبير (١٢٢٩٦)، والبيهقي في الشعب (٣٢٨).أخرجه ابن أبي شيبة ١٤/٧، وابن جرير ٥/١٣٣-١٣٤، والنحاس في ناسخه ص٢٧٥-٢٧٦، والحاكم ٢/٢٨٧. وعلقه ابن أبي حاتم ٢/٥٧٤.أخرجه عبد الرزاق ١/٣٨١ (٣٧٤)، ومن طريقه أحمد ٥/١٩٤-١٩٥ (٣٠٧٠)، وابن جرير ٥/١٣٣، وابن المنذر ١/٩٦ (١٦٩).</p><p>قال ابن منده في كتاب الإيمان (١٠٦): «إسناده صحيح على رسم الجماعة، إلا البخاري». وصحح إسنادَه ابنُ كثير في تفسيره ١/٧٣٠.أخرجه البخاري ٦/٣٣ (٤٥٤٥-٤٥٤٦).علَّقه ابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٤، وابن المنذر (١٧١)، وابن أبي حاتم ٢/٥٧٨.أخرجه ابن جرير٥/١٣٤. وعلَّقه ابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٤.أخرجه أبو عبيد في ناسخه ص٢٧٧ (٥١١). وعلَّقه ابن المنذر ١/٩٨، وابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٦.أخرجه ابن جرير ٥/١٣٥-١٣٦. وعلَّقه ابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٦.أخرجه ابن جرير ٥/١٣٥.أخرجه ابن جرير ٥/١٣٧. وعلَّقه ابن المنذر ١/٩٨ (عَقِب ١٧١).أخرجه عبد الرزاق ١/١١١، وابن جرير ٥/١٣٧. وعلَّقه ابن المنذر ١/٩٨ (عقِب ١٧١)، وابن أبي حاتم ٢/٥٧٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧١-.تفسير الثعلبي ٢/٣٠٠، وتفسير البغوي ١/٣٥٥، وزاد الثعلبي: عن موسى بن عبيدة، وشيبة.الناسخ والمنسوخ للزهري ص٢١-٢٢.أخرجه ابن جرير ٥/١٣٨ مرسلًا.تفسير مقاتل ١/٢٣١.أخرجه ابن جرير ٥/١٣٧.</p><p>وهذا إسناد معضل؛ عبد الرحمن بن زيد بن أسلم من الطبقة الوسطى من أتباع التابعين، وهو ضعيف كما في التقريب (٣٨٩٠).معاتبة الله العبد: أي: مؤاخذته العبد بما اقترف من الذنب بما يصيبه في الدنيا. قال الطيبي: كأنها فهمت أن هذه المؤاخذة عقاب أخروي، فأجاب بأنها: مؤاخذة عتاب في الدنيا، عناية ورحمة. انظر تحفة الأحوذي ٤/٧٩.عند ابن المنذر: «في بيته».</p><p>والضِّبن: الإبط وما يليه. لسان العرب (ضبن).التِّبر: الذهب. لسان العرب (تبر).الكِير: جلد غليظ يَنفُخُ فيه الحدّادُ. لسان العرب (كير).أخرجه أحمد ٤٣/٢٩ (٢٥٨٣٥)، والترمذي ٥/٢٤٥ (٣٢٣٤)، وابن جرير ٥/١٤٣ بلفظ: «متابعة الله»، وأيضًا ٧/٥٢٤ بلفظ: «مثابة الله»، وابن المنذر ١/٩٥ (١٦٧)، وابن أبي حاتم ٢/٥٧٤ (٣٠٦٢) بلفظ: «مبايعة الله».</p><p>قال الترمذي: «حديث حسن غريب من حديث عائشة، لا نعرفه إلا من حديث حماد بن سلمة». وقال ابن كثير في تفسيره ١/٧٣٣: «علي بن زيد بن جدعان ضعيف، يُغْرِب في رواياته، وهو يروي هذا الحديث عن امرأة أبيه أُمِّ محمد أمية بنت عبد الله، عن عائشة، وليس لها عنها في الكتب سواه». وقال الهيثمي في المجمع ٧/١٢ (١٠٩٥٦): «رواه أحمد، وأمينة لم أعرفها». وقال الألباني في الضعيفة ٦/٤٧٣-٤٧٤: «إسناد ضعيف؛ فإنه مع ضعف ابن جدعان، لا يعرف حال أمية هذه».أخرجه سعيد بن منصور في سننه (٤٨١- تفسير)، وابن جرير ٥/١٤٢- ١٤٣، وفيه بلفظ: فكانت كفارته.أخرجه ابن عدي في الكامل ٦/١٨٤، وابن عساكر في تاريخ دمشق ٦٦/٣٠٤.ما بين المعقوفين ساقط من النسخة المحققة من الدر المنثور، وهو مثبت في تفسير ابن جرير، وابن المنذر، وابن أبي حاتم، كما أنه مثبت في الطبعات السابقة من الدر.[زيادة عند ابن جرير.أخرجه أبو عبيد في ناسخه ص٢٧٨ (٥١٢)، وابن جرير ٥/١٣٩، وابن المنذر (١٦٥)، وابن أبي حاتم ٢/٥٧٢، ٥٧٤، ٥٧٥.أخرجه ابن جرير ٥/١٣٩، وابن أبي حاتم ٢/٥٧٣.أخرجه ابن جرير ٥/١٤٠.أخرجه ابن جرير ٥/١٤٠.أخرجه ابن جرير ٥/١٣١-١٣٢، والطبراني في الكبير (١٠٧٧٠)، والبيهقي في الشعب (٣٢٩). وعزاه السيوطي إلى عبد بن حميد، وأبي داود في ناسخه.أخرجه ابن أبي شيبة في المصنف ١٣/٣٢٦، وأحمد في الزهد ص١٩٢، وابن أبي حاتم ٢/٥٧٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٢٤٧، وأخرجه أبو عبيد في ناسخه ص٢٧٤ (٥٠١)، وابن جرير ٥/١٤١، وابن المنذر (١٦٦)، وابن أبي حاتم ٢/٥٧٣، والنحاس في ناسخه ص٢٧٤. وعزاه السيوطي إلى عبد بن حميد، وأبي داود في ناسخه.أخرجه ابن جرير ٥/١٤١. وعلَّقه ابن أبي حاتم ٢/٥٧٤.عَلَّقه ابن أبي حاتم ٢/٥٧٤. وينظر: تفسير البغوي ١/٣٥٦.تفسير الثعلبي ٢/٣٠٢.أخرجه ابن جرير ٥/١٤٠، ١٤١، وابن أبي حاتم ٢/٥٧٢، ٥٧٤.تفسير الثعلبي ٢/٣٠١.تفسير مقاتل بن سليمان ١/٢٣١. وفي تفسير الثعلبي ٢/٢٩٩ عن مقاتل دون تعيينه.تفسير الثعلبي ٢/٢٩٩.أخرجه البخاري ٣/١٤٥ (٢٥٢٨)، ٧/٤٦ (٥٢٦٩)، ٨/٣٥ (٦٦٦٤)، ومسلم ١/١١٦ (١٢٧).تفسير الثعلبي ٢/٣٠٣، وتفسير البغوي ١/٣٥٦.أخرجه ابن جرير ٥/١٤٠.أخرجه ابن أبي حاتم ٢/٥٧٥.علَّقه ابن أبي حاتم ٢/٥٧٥.أخرجه ابن المنذر (١٧٢).تفسير مقاتل بن سليمان ١/٢٣١.
  2,285,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ءَامَنَ ٱلرَّسُولُ بِمَاۤ أُنزِلَ إِلَیۡهِ مِن رَّبِّهِۦ﴾</span> الآية - قراءات</h3></p><p><div></p><p><p><span class="item-no">١١٦٨١<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمَر</span> -من طريق إسحاق بن سويد-: أنه كان يقرأ: ›لا يُفَرِّقُ بَيْنَ أحَدٍ مِّن رُّسُلِهِ‹، يقول: كلٌّ آمن، وكلٌّ لا يُفَرِّقُ{1}<span class=comment-ref>١٠٨٢</span>. (٣/٤٢٢)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٢</span> ذكر <u>ابنُ جرير</u> (٥/١٥٠) أنّ المعنى على قراءة <span class="qpc-hafs">﴿يُفَرِّقُ﴾</span>: أنّ المؤمنين لا يُفَرِّقون بين الرسل في الإيمان؛ فيؤمنون ببعض ويكفرون ببعض، بل يؤمنون بالجميع.</p><p>و<span class="comment-type-3">رجَّح</span> القراءة بالنون <span class="qpc-hafs">﴿نفرِّق﴾</span>.</p><p>و<span class="comment-type-2">انتَقَد</span> القراءة بـ<span class="qpc-hafs">﴿يُفَرِّقُ﴾</span>، فقال: «والقراءة التي لا نستجيز غيرها في ذلك عندنا بالنون <span class="qpc-hafs">﴿لا نفرق بين أحد من رسله﴾</span>؛ <span class="mustanad">لأنها القراءة التي قامت حجتها بالنقل المستفيض</span>، الذي يمتنع معه التشاعر والتواطؤ والسهو والغلط، بمعنى ما وصفنا مِن: يقولون: لا نفرق بين أحد من رسله. ولا يُعترَض بشاذٍّ من القراءة، على ما جاءت به الحُجَّة نقلًا ووراثة».</div></p><p><h3><span class="qpc-hafs">﴿ءَامَنَ ٱلرَّسُولُ بِمَاۤ أُنزِلَ إِلَیۡهِ مِن رَّبِّهِۦ﴾</span> الآية - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٦٨٢<span class="dash">-</span></span> عن <span class="name-1">أنس</span> -من طريق يحيى بن أبي كثير- قال: لَمّا نزلت هذه الآية على النبي ﷺ: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ﴾</span> قال النبيُّ ﷺ: <b>«وحُقَّ له أن يُؤمن</b>»{2}. (٣/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- قال: ذُكِر: أنّ النبي ﷺ لَمّا نزلت هذه الآية قال: <b>«ويَحِقُّ له أن يُؤمن»</b>{3}. (٣/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٨٤<span class="dash">-</span></span> عن <span class="name-2">حكيم بن جابر</span> -من طريق بيان- قال: لما نزلت <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ﴾</span> الآيةَ؛ قال جبريلُ للنبيِّ ﷺ: إنّ الله قد أحسن الثناء عليكَ، وعلى أُمَّتِك، فسَلْ تُعْطَه. فسأل: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span> حتى ختم السورة بمسألة محمد ﷺ{4}. (٣/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: لَمّا نزلت: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</span> الآيةَ؛ شَقَّ ذلك عليهم، قالوا: يا رسول الله، إنّا لَنُحَدِّث أنفسَنا بشيءٍ ما يَسُرُّنا أن يَطَّلِع عليه أحدٌ من الخلائق وأنّ لنا كذا وكذا. قال: <b>«أوَقَدْ لَقِيُتم هذا؟ ذلك صريح الإيمان</b>». فأنزل الله: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ﴾</span> الآيتين{5}. (٣/٤٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: لما نزلت هذه الآية قال المؤمنون: آمنّا بالله، وملائكته، وكتبه، ورسله{6}. (٣/٤٢٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ءَامَنَ ٱلرَّسُولُ بِمَاۤ أُنزِلَ إِلَیۡهِ مِن رَّبِّهِۦ وَٱلۡمُؤۡمِنُونَۚ كُلٌّ ءَامَنَ بِٱللَّهِ وَمَلَـٰۤىِٕكَتِهِۦ وَكُتُبِهِۦ وَرُسُلِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ﴾</span>، يقول: صدَّق محمدٌ بما أُنزِل إليه مِن ربِّه من القرآن. ثم قال: <span class="qpc-hafs">﴿وٱلۡمُؤۡمِنُونَۚ كُلٌّ ءامَنَ بِٱللَّهِ﴾</span> يقول: كُلٌّ صدَّق بالله بأنّه واحد لا شريك له، <span class="qpc-hafs">﴿<b>و</b>﴾</span> صدَّق بـ<span class="qpc-hafs">﴿<b>ملائكته</b>﴾</span> <span class="qpc-hafs">﴿وكُتُبِهِۦ ورُسُلِهِۦ﴾</span>، يقول: لا يكفر بأحد من رسله، فكل هذه الرسل صدَّق بهم المؤمنون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٨٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ وٱلۡمُؤۡمِنُونَۚ كُلٌّ ءامَنَ بِٱللَّهِ ومَلَـٰۤىِٕكَتِهِۦ وكُتُبِهِۦ﴾</span>: فهذا قولٌ قاله الله، وقولُ النبي ﷺ، وقولُ المؤمنين، فأثنى الله عليهم لما علم من إيمانهم بالله، وملائكته، وكتبه، ورسله{8}. (٣/٤٢٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا نُفَرِّقُ بَیۡنَ أَحَدࣲ مِّن رُّسُلِهِۦۚ وَقَالُوا۟ سَمِعۡنَا وَأَطَعۡنَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا نُفَرِّقُ بَیۡنَ أحَدࣲ مِّن رُّسُلِهِۦۚ﴾</span> كفعل أهل الكتاب، آمنوا ببعض الكتب وببعض الرسل، فذلك التفريق، فأمّا اليهود فآمنوا بموسى وبالتوراة، وكفروا بالإنجيل والقرآن، وأما النصارى فآمنوا بالتوراة والإنجيل وبعيسى ﷺ، وكفروا بمحمد ﷺ وبالقرآن. <span class="qpc-hafs">﴿وقالُوا۟﴾</span> فقال المؤمنون بعد ذلك: <span class="qpc-hafs">﴿سَمِعۡنا﴾</span> قول ربنا في القرآن، <span class="qpc-hafs">﴿وأَطَعۡناۖ﴾</span> أمرَه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٠<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- <span class="qpc-hafs">﴿لا نُفَرِّقُ بَیۡنَ أحَدࣲ مِّن رُّسُلِهِۦۚ﴾</span>: لا نكفر بما جاءت به الرسل، ولا نفرق بين أحد منهم، ولا نكذب به، <span class="qpc-hafs">﴿وقالُوا۟ سَمِعۡنا﴾</span> للقرآن الذي جاء من الله، <span class="qpc-hafs">﴿وأَطَعۡناۖ﴾</span> أقرُّوا أن يطيعوه في أمره ونهيه{10}. (٣/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: <span class="qpc-hafs">﴿لا نُفَرِّقُ بَیۡنَ أحَدࣲ مِّن رُّسُلِهِۦۚ﴾</span> كما صنع القوم –يعني: بني إسرائيل-، قالوا: فلان نبي، وفلان ليس نبيًّا، وفلان نؤمن به، وفلان لا نؤمن به{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿غُفۡرَانَكَ رَبَّنَا وَإِلَیۡكَ ٱلۡمَصِیرُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿غُفۡرانَكَ رَبَّنا﴾</span> قال: قد غفرت لكم، <span class="qpc-hafs">﴿وإلَیۡكَ ٱلۡمَصِیرُ﴾</span> قال: وإليك المرجع والمآب يوم الحساب{12}. (٣/٤٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال لهم بعدما أقرُّوا بالنبيِّ ﷺ والكتب أن <span class="qpc-hafs">﴿غُفۡرانَكَ رَبَّنا﴾</span>، يقول: قولوا: وأعطِنا مغفرةً منك، يا ربَّنا، <span class="qpc-hafs">﴿وإلَیۡكَ ٱلۡمَصِیرُ﴾</span> يقول: المرجع إليك في الآخرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٤<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿غُفۡرانَكَ رَبَّنا وإلَیۡكَ ٱلۡمَصِیرُ﴾</span>: تعليمٌ مِن الله، فهذا دعاءٌ دعا به النبيُّ ﷺ، فاستجاب له{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن المنذر (١٧٤)، وابن أبي حاتم ٢/٥٧٦ (٣٠٧٥).</p><p>والقراءة المذكورة هي قراءة يعقوب من العشرة. انظر: النشر ٢/٢٣٧، وإتحاف فضلاء البشر ص٢١٤.أخرجه الحاكم ٢/٣١٥ (٣١٣٤)، والبيهقي في الشعب ٤/٦٧ (٢١٨٧) واللفظ له.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع». وقال ابن حجر في إتحاف المهرة ٢/٣٨١ (١٩٤٣): «وقال الحاكم: صحيح الإسناد. قلت: بل منقطع». وقال السيوطي: «قال الذهبي: منقطع بين يحيى وأنس».أخرجه ابن جرير ٥/١٤٨، وابن أبي حاتم ٢/٥٧٦ (٣٠٧١) مرسلًا.</p><p>قال السيوطي: «هذا شاهد لحديث أنس».أخرجه بن أبي شيبة ٦/٣٢٤ (٣١٧٧٥)، وسعيد بن منصور في التفسير من سننه ٣/١٠١٥ (٤٧٨)، وابن جرير ٥/١٥٢، وابن أبي حاتم ٢/٥٧٥ (٣٠٧٠) مرسلًا.أخرجه سعيد بن منصور ٣/١٠٠٥ (٤٧٤) مرسلًا.</p><p>وأصل الحديث أخرجه مسلم ١/١١٩ (١٣٢) بدون ذكر الآية عن أبي هريرة، قال: جاء ناس من أصحاب النبي ﷺ، فسألوه: إنا نجد في أنفسنا ما يتعاظم أحدُنا أن يتكلم به. قال: «وقد وجدتموه؟». قالوا: نعم، قال: «ذاك صريح الإيمان».عزاه السيوطي إلى ابن أبي حاتم، وفي المطبوع من تفسيره ٢/٥٧٦ (٣٠٧٢) عن سعيد من طريق عطاء بن السائب بلفظ: كان ما قيل لهم، قولوا: آمنا. وينظر: النسخة المحققة المرقومة بالآلة الكاتبة ٣/١٢١٨.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٧٦، وابن المنذر (١٧٥) من طريق إسحاق عمن حدثه.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٧٦، ٥٧٧، وابن المنذر (١٧٥، ١٧٦) من طريق إسحاق عمن حدثه.أخرجه ابن جرير ٥/١٥٣.أخرجه ابن جرير ٥/١٦٨، وابن المنذر (١٧٧)، وابن أبي حاتم ٢/٥٧٧.تفسير مقاتل بن سليمان ١/٢٣٢.أخرجه ابن المنذر (١٧٩)، وابن أبي حاتم ٢/٥٧٧.
  2,286,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یُكَلِّفُ ٱللَّهُ نَفۡسًا إِلَّا وُسۡعَهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٦٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، قال: هم المؤمنون، وسَّع اللهُ عليهم أمرَ دينهم، فقال: <span class="qpc-hafs">﴿وما جَعَلَ عَلَیۡكُمۡ فِی ٱلدِّینِ مِنۡ حَرَجࣲۚ﴾</span> [الحج:٧٨]، وقال: <span class="qpc-hafs">﴿یُرِیدُ ٱللَّهُ بِكُمُ ٱلۡیُسۡرَ ولا یُرِیدُ بِكُمُ ٱلۡعُسۡرَ﴾</span> [البقرة:١٨٥]، وقال: <span class="qpc-hafs">﴿فَٱتَّقُوا۟ ٱللَّهَ ما ٱسۡتَطَعۡتُمۡ﴾</span> [التغابن:١٦]{1}. (٣/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الزهري- قال: لَمّا نزلت ضَجَّ المؤمنون منها ضَجَّةً، وقالوا: يا رسول الله، هذا نتوبُ مِن عمل اليدِ والرجل واللسان، كيف نتوب مِن الوسوسة؟! كيف نمتنع منها؟! فجاء جبريلُ بهذه الآية: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، إنّكم لا تستطيعون أن تمتنعوا من الوسوسة{2}. (٣/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿إلّا وُسۡعَهاۚ﴾</span>، قال: إلا طاقتها{3}. (٣/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿إلّا وُسۡعَهاۚ﴾</span>، قال: إلا ما تُطِيق{4}. (٣/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٦٩٩<span class="dash">-</span></span> عن <span class="name-2">عامر</span> <span class="name-2">الشعبي</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>: إلا ما عملت لها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق خالد بن زيد- <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، قال: فلم يُكَلَّفوا من العمل ما لم يُطِيقوا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٢<span class="dash">-</span></span> و<span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٣<span class="dash">-</span></span> و<span class="name-2">زيد بن أسلم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٤<span class="dash">-</span></span> <span class="name-3">ومقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٥<span class="dash">-</span></span> عن معمر: أنّ <span class="name-2">عمر بن عبد العزيز</span> كتب: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، مثله.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٦<span class="dash">-</span></span> ومثله عن <span class="name-2">عطاء</span> في الرجل لا يَجِدُ ما ينفق على أهله: ليس لها إلا ما وجَد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>: ووسعها: طاقتها، فكان حديث النفس مما لا يُطِيقون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٨<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، نحوه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، يقول: لا يكلفها من العمل إلا ما أطاقت، ... فنَسَخَتْ هذه الآية قولَه سبحانه: <span class="qpc-hafs">﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</span>، قال النبيُّ ﷺ عند ذلك: <b>«إنّ الله ﷿ تجاوز عن أُمَّتِي ما حَدَّثوا به أنفسَهم؛ ما لم يعملوه، أو يتكلموا به»</b>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق فُضَيْل بن عِياض- في قوله: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، قال: أداء الفرائض{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مِهْران- <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، قال: في شأن النفقة، إلا ما استطاعت{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق عبد الجبّار بن العلاء العطّار- أنّه سُئِل عن قوله تعالى: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>. فقال: إلّا يُسْرَها، لا عسرها، ولم يكلّفها طاقتها، ولو كلّفها طاقتها لبلغ المجهود منها{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یُكَلِّفُ ٱللَّهُ نَفۡسًا إِلَّا وُسۡعَهَاۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٧١٣<span class="dash">-</span></span> عن عمران بن حصين قال: كانتْ بي بواسير، فسألتُ النبيَّ ﷺ عن الصلاة. فقال: <b>«صلِّ قائمًا، فإن لم تستطع فقاعدًا، فإن لم تستطع فعلى جنب»</b>{15}. (٣/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٤<span class="dash">-</span></span> عن همام، قال: سأل رجلٌ <span class="name-2">الحسنَ</span> وأنا أسمع، فقال: رجل جعل على نفسه شيئًا في نذر وهو لا يجده؟ فقال الحسن: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٥<span class="dash">-</span></span> عن ابن جريج، قال: قلت ل<span class="name-2">عطاء [بن أبي رباح]</span>: أيُكْرَه أن يقوم الرجل وحده وراء الصف؟ قال: نعم، والرجلان والثلاثة، إلا في الصفّ، فإنّ فيها فرجًا. قلت لعطاء: أرأيتَ إن وجدتُ الصفَّ مَدْحوسًا{17}، لا أرى فُرْجَةً، أقوم وراءهم؟ قال: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</span>، وأحبُّ إلَيَّ -واللهِ- أن أدخلَ فيه{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَهَا مَا كَسَبَتۡ وَعَلَیۡهَا مَا ٱكۡتَسَبَتۡۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٧١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق قتادة- <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>، قال: ما كسبت مِن خير، وما اكتسبت مِن شَرٍّ{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الزهري، عن سعيد بن مَرْجانة- في قوله: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span>، قال: من العمل{20}. (٣/٤٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span> -من طريق سعيد بن أبي عروبة- قوله: <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ﴾</span> أي: من خير، <span class="qpc-hafs">﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span> أي: مِن شرٍّ. أو قال: مِن سوء{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧١٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق خالد بن زيد- قال: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ﴾</span> من خير، <span class="qpc-hafs">﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span> من شَرٍّ{22}. (٣/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٠<span class="dash">-</span></span> قال <span class="name-2">محمد ابن شهاب الزهري</span>: <span class="qpc-hafs">﴿لها ما كسبت وعليها ما اكتسبت﴾</span>، أي: لا يُكتب على أحدٍ إلا ما فعل وما عمِل{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ﴾</span> يقول: ما عملت من خير، <span class="qpc-hafs">﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span> يقول: وعليها ما عملت من شر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَها ما كَسَبَتۡ﴾</span> من الخير وما عملت أو تَكَلَّمَتْ به، <span class="qpc-hafs">﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</span> من الإثم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق ابن ثور-: لها ما كسبت من الخير، وعليها ما اكتسبت من الشر لنفسها{26}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا لَا تُؤَاخِذۡنَاۤ إِن نَّسِینَاۤ أَوۡ أَخۡطَأۡنَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٧٢٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق العلاء بن عبد الرحمن، عن أبيه- <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>، قال: نعم{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء بن السائب، عن سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>، قال: لا أؤاخذكم{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب-، مثله{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٧<span class="dash">-</span></span> عن أم الدرداء -من طريق أبي بكر الهُذَلِيّ، عن شَهْر-: عن النبي ﷺ: <b>«إنّ الله تجاوز لأمتي عن ثلاث: عن الخطأ، والنسيان، والاستكراه</b>». قال أبو بكر: فذكرت ذلك ل<span class="name-2">لحسن</span>، فقال: أجل، أما تقرأ بذلك قرآنًا: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>{30}. (٣/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- في قوله تعالى: <span class="qpc-hafs">﴿إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>، قال: قال رسول الله ﷺ: «<b>تجوَّز اللهُ لهذه الأمة عن الخطأ، والنسيان، وما أُكْرِهوا عليه</b>»{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٢٩<span class="dash">-</span></span> قال <span class="name-2">عطاء بن أبي رباح</span>: <span class="qpc-hafs">﴿إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>، يعني: إن جهلنا، أو تعمّدنا له{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>، قال: بلغني: أنّ الرسول ﷺ قال: <b>«إنّ الله -تبارك وتعالى- تجاوز لهذه الأمة على نسيانها، وما حدثت به أنفسها»</b>{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق خالد بن زيد- <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>: فوضع عنهم الخطأ، والنسيان{34}. (٣/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: أنّ هذه الآية حين نزلت <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span> قال له جبريل: إنّ الله فعل ذلك، يا محمد{35}. (٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كانت بنو إسرائيل إذا نسوا شيئًا مِمّا أُمروا به وأخطأوا عُجِّلَتْ لهم العقوبة، فيُحَرَّم عليهم شيءٌ من مطعم أو مشرب على حسب ذلك الذنب، فأمر الله تعالى نبيَّه والمؤمنين أن يسألوه تركَ مؤاخذتهم بذلك{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم علَّم جبريلُ النبيَّ ﷺ أن يقول: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>، يقول: إن جهلنا عن شيء، أو أخطأنا، فتَرَكَنْا أمرَك. قال الله ﷿: ذلك لك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span>: إن نسينا شيئًا مما افترضته علينا، أو أخطأنا شيئًا مما حرَّمته علينا {35}<span class=comment-ref>١٠٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٣</span> بيَّن <u>ابنُ جرير</u> (٥/١٥٥-١٥٧) أنّ النسيان في الآية يحتمل معنيين: <b>أحدهما</b>: على وجه التفريط من العبد والتضييع. و<b>الآخر</b>: على وجه العجز عن التَّذَكُّر. وأنّ الخطأ يحتمل معنيين: <b>أحدهما</b>: إتيان العبد ما نُهي عنه بقصد وإرادة. و<b>الآخر</b>: ما كان فعله من العبد على وجه الجهل.</p><p>ثم <span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> المعنى الأول في كلٍّ، مُعَلِّلًا ذلك بأنّ النسيان الناتج عن ضعف العقل والعجز، وكذا الخطأ غير المقصود؛ مِمّا قد وضعه الله عن العبد لخروجه عن مقدوره، فلا وجه لمسألة العبد ربه أن لا يؤاخذه به.</p><p>و<span class="comment-type-2">خالفه</span> <u>ابنُ عطية</u> (٢/١٤٢-١٤٣)، <span class="comment-type-3">فرجح</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> أنّ المراد بالنسيان والخطأ: النسيان الغالب، والخطأ غير المقصود. <span class="mustanad">ونسبَه لكثيرٍ من العلماء</span>، وبيَّن أن قول قتادة والسدي يفيد ظاهرهما ذلك، ثم علَّل ترجيحه بقوله: «وذلك أنّ المؤمنين لما كشف عنهم ما خافوه في قوله تعالى <span class="qpc-hafs">﴿يحاسبكم به الله﴾</span> أُمِرُوا بالدعاء في دفع ذلك النوع الذي ليس من طاقة الإنسان دفعه، وذلك في النسيان والخطأ، والإصر: الثقل، وما لا يطاق على أتم أنواعه. وهذه الآية على هذا القول تقضي بجواز تكليف ما لا يطاق، ولذلك أُمِر المؤمنون بالدعاء في أن لا يقع هذا الجائز الصعب».</div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا لَا تُؤَاخِذۡنَاۤ إِن نَّسِینَاۤ أَوۡ أَخۡطَأۡنَاۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٧٣٦<span class="dash">-</span></span> عن أبي ذرٍّ، قال: قال رسول الله ﷺ: <b>«إنّ الله تجاوز لي عن أُمِّتي الخطأ، والنسيان، وما اسْتُكْرِهوا عليه»</b>{39}. (٣/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: <b>«إنّ الله تجاوز عن أمتي ما وسوست به صُدورُها، ما لم تعمل، أو تَكَلَّم به»</b>{40}. (٣/٤٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٨<span class="dash">-</span></span> عن عقبة بن عامر، قال: قال رسول الله ﷺ: <b>«وضع اللهُ عن أمتي الخطأَ، والنسيانَ، وما استكرهوا عليه»</b>{41}. (٣/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٣٩<span class="dash">-</span></span> عن الحسن، عن النبي ﷺ، قال: <b>«تُجُوِّزَ لهذه الأمة الخطأ، والنسيان، وما استكرهوا عليه»</b>{31}. (٣/٤٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٠<span class="dash">-</span></span> عن الحسن، قال: قال رسول الله ﷺ: «<b>تجاوز اللهُ لابن آدم عمّا أخطأ، وعمّا نسي، وعمّا أُكره، وعمّا غُلب عليه»</b>{43}. (٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤١<span class="dash">-</span></span> عن الشعبي، قال: قال رسول الله ﷺ: «<b>إنّ الله تجاوز لأُمَّتِي عن ثلاث: عن الخطأ، والنسيان، والإكراه</b>»{44}. (٣/٤٢٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا وَلَا تَحۡمِلۡ عَلَیۡنَاۤ إِصۡرࣰا كَمَا حَمَلۡتَهُۥ عَلَى ٱلَّذِینَ مِن قَبۡلِنَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٧٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿إصۡرࣰا﴾</span>، قال: عهدًا{45}. (٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>. قال: عهدًا، كما حملته على اليهود فمَسَخْتَهم قِرَدَةً وخنازير. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أبا طالب وهو يقول:</p><p>أفي كل عام وافدٌ وصحيفةٌ يُشَدُّ بها أمرٌ وثيقٌ وأيْصُرُهْ{46}. (٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٤<span class="dash">-</span></span> عن ابن سيرين، قال: قال: أبو هريرة <span class="name-1">لابن عباس</span>: ما علينا مِن حرج أن نزني أو أن نسرق؟ قال: بلى. ولكن الإصر الذي علي بني إسرائيل وُضِع عنكم{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قول الله ﷿: <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>، قال: لا أحمل عليكم{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، مثله{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> <span class="name-2">بن جبر</span> -من طريق ابن أبي نجيح، وقيس بن الحضرمي- <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span>، قال: عَهْدًا{50}. (٣/٤٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿إصۡرࣰا﴾</span>، قال: المواثيق{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٠<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، قالا: ميثاقًا{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥١<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span>، قال: لا تمسخنا قِرَدَةً وخنازير{53}. (٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>، قال: كم من تشديدٍ كان على الذين من قبلنا، <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span> قال: كم مِن تخفيفٍ ويُسْرٍ وعافيةٍ في هذه الأُمَّة{54}. (٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span> -من طريق معمر بن راشد- في قوله: <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span>، قال: لا تحمل علينا عهدًا وميثاقًا، <span class="qpc-hafs">﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span> يقول: كما غُلِّظ على مَن قبلنا{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق خالد بن زيد- قال: <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span> الآية، قال: فلم يُكَلَّفوا ما لم يُطِيقوا، ولم يحمل عليهم الإصْرَ الذي جعل على الأمم قبلهم، وعفا عنهم، وغفر لهم، ونصرهم{56}. (٣/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>: والإصْرُ: العهود التي كانت على مَن قبلنا مِن اليهود{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٦<span class="dash">-</span></span> وعن <span class="name-2">مجاهد</span> <span class="name-2">بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٧<span class="dash">-</span></span> و<span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٨<span class="dash">-</span></span> و<span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٥٩<span class="dash">-</span></span> و<span class="name-3">محمد بن السائب الكلبي</span>، نحو ذلك{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- في قوله: <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span>، يقول: التشديد الذي شُدِّد به على مَن كان قبلنا من أهل الكتاب{47}. (٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي-: الإصر: العهد، <span class="qpc-hafs">﴿وأَخَذۡتُمۡ عَلىٰ ذَ ٰ⁠لِكُمۡ إصۡرِیۖ﴾</span> قال: عهدي{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span> يعني: عهدًا، <span class="qpc-hafs">﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span> ما كان حُرِّمَ عليهم من لحوم الإبل، وشحوم الغنم، ولحوم كل ذي ظُفُر. يقول: لا تفعل ذلك بأُمَّتِي بذنوبها كما فعلته ببني إسرائيل، فجعلتهم قردة وخنازير. قال الله تعالى: ذلك لك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٣<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>: كما حملته علي اليهود و النصارى فأهلكتهم{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span> قال: عهدًا لا نطيقه ولا نستطيع القيام به، <span class="qpc-hafs">﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span> اليهود والنصارى، فلم يقوموا به، فأهلكتهم{63}. (٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٥<span class="dash">-</span></span> عن <span class="name-3">الفضيل [بن عياض]</span> -من طريق أبي يزيد فَيْض بن إسحاق الرَّقِّيِّ- في قوله: <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span>، قال: كان الرجلُ من بني إسرائيل إذا أذنب قيل له: توبتُك أن تقتل نفسك. فيقتل نفسه، فوُضِعَت الآصارُ عن هذه الأُمَّة{64}. (٣/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٦<span class="dash">-</span></span> عن عبد الله بن وهب، قال: سألت -يعني: <span class="name-3">مالك [بن أنس]</span>- عن قوله: <span class="qpc-hafs">﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</span>. قال: الإصر: الأمر الغليظ{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق عبد الله بن وهْب- في قوله: <span class="qpc-hafs">﴿وأَخَذۡتُمۡ عَلىٰ ذَ ٰ⁠لِكُمۡ إصۡرِیۖ﴾</span> [آل عمران: ٨١]، قال: عهدي{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق عبد الله بن وهْب- في الآية، قال: لا تحمل علينا ذنبًا ليس فيه توبة ولا كفارة{53}<span class=comment-ref>١٠٨٤</span>. (٣/٤٢٨)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٤</span> <span class="comment-type-4">جمع</span> <u>ابنُ عطية</u> (٢/١٤٤) بين أقوال السلف الواردة في معنى الإصر بقوله: «والإصرة في اللغة: الأمر الرابط؛ من ذمام، أو قرابة، أو عهد ونحوه، فهذه العبارات كلها تنحو نحوه».</div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا وَلَا تَحۡمِلۡ عَلَیۡنَاۤ إِصۡرࣰا كَمَا حَمَلۡتَهُۥ عَلَى ٱلَّذِینَ مِن قَبۡلِنَاۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٧٦٩<span class="dash">-</span></span> عن عبد الرحمن بن حسنة، أنّ النبي ﷺ قال: <b>«إنّ بني إسرائيل كانوا إذا أصابهم البول قَرَضُوه</b>{68} <b>بالمَقارِيض</b>{69}»{70}. (٣/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٠<span class="dash">-</span></span> عن <span class="name-1">أبي موسى [الأشعري]</span>، قال: كانت بنو إسرائيل إذا أصاب أحدَهم البولُ يَتْبَعُه بالمِقْراض{71}. (٣/٤٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧١<span class="dash">-</span></span> عن عائشة، قالت: دخلتُ على امرأة من اليهود، فقالتْ: إنّ عذاب القبر من البول. قلتُ: كذبتِ. قالتْ: بلى. قالتْ: إنّه لَيُقْرَضُ منه الجلد والثوب. فأخبرتُ رسولَ الله ﷺ، فقال: «<b>صَدَقَتْ»</b>{72}. (٣/٤٢٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا وَلَا تُحَمِّلۡنَا مَا لَا طَاقَةَ لَنَا بِهِۦۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٧٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، يعني: الوسوسة{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق سفيان الثوري، عن منصور- في قوله تعالى: <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: الحب{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: لا تُحَمِّلْنا من الأعمال ما لا نطيق{66}. (٣/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span> -من طريق سعيد بن أبي عروبة- <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>: تشديد تُشَدِّد به، كما شدَّدت على مَن كان قبلنا{76}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: كم مِن تخفيفٍ ويُسْرٍ وعافية في هذه الأُمَّة{77}. (٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٧<span class="dash">-</span></span> عن <span class="name-2">مكحول</span> -من طريق ابن ثوبان، عن أبيه- <span class="qpc-hafs">﴿ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: الغربة، والغُلْمَة{78}، والإنعاظ{79}<span class=comment-ref>١٠٨٥</span>. (٣/٤٢٩)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٥</span> نقل <u>ابنُ القيم</u> (١/٢١٤) في تفسير <span class="qpc-hafs">﴿ما لا طاقة لنا به﴾</span> قولًا بأن المراد به: العشق، و<span class="comment-type-1">وجَّهه</span> بأنّ المعنى غير مختص به، بل يشمله وغيره، فقال: «فُسِّر ذلك بالعشق، وليس المراد اختصاصه به؛ بل المراد: أن العشق مما لا طاقة للعبد به. وقال مكحول: هو شدة الغُلْمَة. <span class="mustanad">وقال النبي</span> ﷺ: «لا ينبغي للمرء أن يُذِلَّ نفسه». قال الإمام أحمد: تفسيره أن يتعرض من البلاء لما لا يطيق. وهذا مطابق لحال العاشق، فإنه أذلُّ الناس لمعشوقه، ولما يحصل به رضاه، والحب مبناه على الذل والخضوع للمحبوب».</div></p><p><div></p><p><p><span class="item-no">١١٧٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ما لا طاقَةَ لَنا بِهِۦۖ﴾</span> من التغليظ والأغلال التي كانت عليهم من التحريم{80}. (٣/٤٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٧٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قول الله: <span class="qpc-hafs">﴿ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>: مِن العذاب، فتجعلنا كما جعلتهم قردة وخنازير، وتعذبنا كما عذبتهم. فقال جبريل: قد فعل ذلك، واستجيب لكم{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: مسخ القردة والخنازير{82}. (٣/٤٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق عبد الله بن وهْب- في قوله: <span class="qpc-hafs">﴿ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>: لا تَفْتَرِضْ علينا من الدين ما لا طاقة لنا به، فنعجز عنه{83}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> <span class="name-2">بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٣<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، نحوه{84}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٤<span class="dash">-</span></span> عن <b>سلام بن سابور</b>{85} -من طريق محمد بن شعيب- <span class="qpc-hafs">﴿ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: الغُلْمَة{83}. (٣/٤٢٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا وَلَا تُحَمِّلۡنَا مَا لَا طَاقَةَ لَنَا بِهِۦۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٧٨٥<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق العلاء، عن أبيه- <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</span>، قال: نعم{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قول الله -جل وعز-: <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span>، قال: لا أحمِّلكم ما لا طاقة لكم به{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٨<span class="dash">-</span></span> و<span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٨٩<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القرظي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٠<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، قال: يقول الله ﷿: قد فعلت{89}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩١<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: لا أحمله عليكم{89}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱعۡفُ عَنَّا وَٱغۡفِرۡ لَنَا وَٱرۡحَمۡنَاۤۚ أَنتَ مَوۡلَىٰنَا فَٱنصُرۡنَا عَلَى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٧٩٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن سليمان</span>، قال: ثم قال: <span class="qpc-hafs">﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ وٱعۡفُ﴾</span> يقول: واعف عنا من ذلك، <span class="qpc-hafs">﴿وٱغۡفِرۡ لَنا﴾</span> يقول: وتجاوز عنا عن ذنوبنا من ذلك كله واغفر، <span class="qpc-hafs">﴿وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</span> يقول: أنت ولينا، <span class="qpc-hafs">﴿فَٱنصُرۡنا عَلى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</span> يعني: كفار مكة وغيرها إلى يوم القيامة، قال الله تعالى: ذلك لك. فاستجاب الله ﷿ له ذلك فيما سأل، وشَفَّعَه في أمته، وتجاوز لها عن الخطايا والنسيان وما اسْتُكْرِهوا عليه، فلمّا نزلت قرأهنَّ النبيُّ ﷺ على أُمَّتِه، وأعطاه الله ﷿ هذه الخصال كلها في الآخرة، ولم يُعْطِها أحدًا مِن الأمم الخالية{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٣<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، في قوله: <span class="qpc-hafs">﴿وٱعۡفُ عَنّا﴾</span>، يقول: عافِنا من ذلك. ثم دعوا ربهم، فقالوا: <span class="qpc-hafs">﴿وٱغۡفِرۡ لَنا وٱرۡحَمۡناۤۚ﴾</span> الآية. قال جبريل: قد فعل{92}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق عبد الله بن وهب-: <span class="qpc-hafs">﴿وٱعۡفُ عَنّا﴾</span> إن قَصَّرْنا عن شيء مِمّا أمرتنا به، <span class="qpc-hafs">﴿وٱغۡفِرۡ لَنا﴾</span> إن انتهكنا شيئًا مما نهيتنا عنه، <span class="qpc-hafs">﴿وٱرۡحَمۡناۤۚ﴾</span> يقول: لا ننال العمل بما أمرتنا به، ولا ترك ما نهيتنا عنه إلا برحمتك. قال: ولم ينجُ أحد إلا برحمته{93}. (٣/٤٢٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱعۡفُ عَنَّا وَٱغۡفِرۡ لَنَا وَٱرۡحَمۡنَاۤۚ أَنتَ مَوۡلَىٰنَا فَٱنصُرۡنَا عَلَى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٧٩٥<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق عن العلاء بن عبد الرحمن، عن أبيه-: فأنزل الله: <span class="qpc-hafs">﴿وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</span>، قال: نعم{94}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</span> قال: يقول: قد فعلتُ، <span class="qpc-hafs">﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</span> قال: ويقول: قد فعلتُ. فأُعْطِيَت هذه الأمةُ خواتيمَ سورة البقرة، ولم تُعْطَها الأممُ قبلها{95}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قول الله ﷿: <span class="qpc-hafs">﴿وٱعۡفُ عَنّا وٱغۡفِرۡ لَنا وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</span> إلى آخر السورة، قال: قد عفوتُ عنكم، وغفرتُ لكم، ورحمتكم، ونصرتُكم على القوم الكافرين{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٨<span class="dash">-</span></span> <span class="name-1">عن أبي هريرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٧٩٩<span class="dash">-</span></span> و<span class="name-2">محمد بن كعب القرظي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٠<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، نحو ذلك في قوله: <span class="qpc-hafs">﴿وٱعۡفُ عَنّا﴾</span>{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠١<span class="dash">-</span></span> <span class="name-1">عن أبي هريرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٢<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٣<span class="dash">-</span></span> و<span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>ِ= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٤<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك في قوله: <span class="qpc-hafs">﴿وٱغۡفِرۡ لَنا﴾</span>{98}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب-، نحو ذلك في قوله: <span class="qpc-hafs">﴿وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</span>{94}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span> -من طريق أسباط-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٧<span class="dash">-</span></span> و<span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٨<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{100}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٠٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span>، قال: جاء بها جبريل ومعه من الملائكة ما شاء الله: <span class="qpc-hafs">﴿ءامَنَ ٱلرَّسُولُ﴾</span> إلى قوله: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ﴾</span>، قال: ذلك لك. وهكذا عَقِب كلِّ كلمة{101}. (٣/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span>، قال: أقرأ جبريلُ النبيَّ آخرَ سورة البقرة، فلما حفظها قال: اقرأها. فقرأها، فجعل كلما مرَّ بحرف قال: ذلك لك. حتى فرغ منها{102}. (٣/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: هذا دعاءٌ أمر الله به النبيَّ ﷺ والمؤمنين، وقد أخبر اللهُ النبيَّ أنه قد غفر له{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٢<span class="dash">-</span></span> عن <span class="name-1">أبي ذرٍّ</span>، قال: هي للنبي ﷺ خاصة{77}. (٣/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> <span class="name-2">بن مزاحم</span> -من طريق عبيد بن سليمان- في هذه الآيات، قال: فإنّ جبريل ﵇ أقرأها نبيَّ الله ﷺ، فسألها نبيُّ اللهِ ربَّه، فأعطاه إيّاها، فكانت للنبيِّ ﷺ خاصة{105}. (٣/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٤<span class="dash">-</span></span> عن <span class="name-2">أبي ميسرة</span>: أنّ جبريل لَقَّنَ رسول الله ﷺ عند خاتمة البقرة: آمين{106}. (٣/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٥<span class="dash">-</span></span> عن <span class="name-1">معاذ بن جبل</span> -من طريق أبي إسحاق-: أنّه كان إذا فرغ من قراءة هذه السورة: <span class="qpc-hafs">﴿فَٱنصُرۡنا عَلى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</span>، قال: آمين{107}<span class=comment-ref>١٠٨٦</span>. (٣/٤٣١)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/١٤٥) على هذا الأثر بقوله: «هذا يُظَنَّ به أنه <span class="mustanad">رواه عن النبي</span> ﷺ، فإن كان ذلك فكمال، وإن كان <span class="mustanad">بقياس</span> على سورة الحمد من حيث هناك دعاء وهنا دعاء، فحَسَنٌ».</div></p><p><div></p><p><p><span class="item-no">١١٨١٦<span class="dash">-</span></span> عن <span class="name-2">جُبَيْر بن نُفَيْر</span>: أنّه كان إذا قرأ خاتمة البقرة يقول: آمين{108}. (٣/٤٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٧<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span>، قال: لَمّا نزلت هذه الآيات: <span class="qpc-hafs">﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ﴾</span> فكُلَّما قالها جبريلُ للنبي ﷺ قال النبيُّ ﷺ: «<b>آمين، رب العالمين</b>»{44}. (٣/٤٣٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/١٥٣، وابن المنذر (١٨٠)، وابن أبي حاتم ٢/٥٧٧.أخرجه ابن جرير ٥/١٥٣.أخرجه ابن أبي حاتم ٦/٢٦.أخرجه ابن المنذر (١٨١).أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن أبي حاتم ٢/٥٧٨ عن مقاتل، وعلَّقه عن الباقين.أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن جرير ٥/١٥٤. وعلَّقه ابن أبي حاتم ٢/٥٧٨.تفسير الثعلبي ٢/٣٠٦، وتفسير البغوي ١/٣٥٧.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن أبي حاتم ٢/٥٧٧.أخرجه الثعلبي ٢/٣٠٦. وذكره البغوي ١/٣٥٧.أخرجه البخاري ٢/٤٨ (١١١٧).أخرجه ابن أبي حاتم ٢/٥٧٧.أي: ممتلئ. لسان العرب (دحس).أخرجه عبد الرزاق في مصنفه ٢/٥٨-٥٩ (٢٤٨١).أخرجه أبو عبيد في ناسخه ص٢٧٦ (٥٠٦).أخرجه ابن أبي حاتم ٢/٥٧٨-٥٧٩، وعند ابن جرير ٥/١٥٤ من طريق الزهري عن ابن عباس بلفظ: عمل اليد، والرجل، واللِّسان.أخرجه ابن جرير ٥/١٥٤.أخرجه ابن المنذر (١٨٣)، وابن أبي حاتم ٢/٥٧٨-٥٧٩. وعزاه الحافظ ابن حجر في العجاب في بيان الأسباب ١/٥٦٣ والسيوطي إلى الفريابي، وعبد بن حميد.الناسخ والمنسوخ للزهري ص٢١-٢٢.أخرجه ابن جرير ٥/١٥٤. وعلَّقه ابن المنذر ١/١٠٢ (عَقِب ١٨٤).تفسير مقاتل بن سليمان ١/٢٣١-٢٣٢.أخرجه ابن المنذر (١٨٤).أخرجه ابن أبي حاتم ٢/٥٧٩.أخرجه ابن جرير ٥/١٦٨، وابن أبي حاتم ٢/٥٧٩.أخرجه ابن أبي حاتم ٢/٥٧٩.أخرجه ابن أبي حاتم ٢/٥٧٩ (٣٠٩٢).</p><p>قال ابن القيسراني في ذخيرة الحفاظ ١/٥٧٤ (٩٣٣): «رواه (سلمى بن عبد الله) أبو بكر الهذلي: عن شهر بن حوشب، عن أم الدرداء، عن أبي الدرداء. والهذلي هذا متروك الحديث». وقال ابن الملقن في البدر المنير ٤/١٨٢: «رواه الطبراني، وفيه شهر».أخرجه عبد الرزاق في مصنفه ٦/٤٠٩ (١١٤١٦)، وفي تفسيره ١/٣٧٨ (٣٦٧)، وسعيد بن منصور في سننه ١/٣١٧ (١١٤٥).</p><p>نقله ابن الملقن في البدر المنير ٤/١٨٣ بنحوه، وقال: «رواه سعيد بن منصور مرسلًا». وقال المتقي الهندي في كنز العمال ١٢/١٧٤ (٣٤٥٤٢): «عبد الرزاق عن الحسن مرسلًا».تفسير الثعلبي ٢/٣٠٧، وتفسير البغوي ١/٣٥٧.أخرجه عبد الرزاق في تفسيره ١/١٧٩ (٣٦٨)، وابن جرير ٥/١٥٥ مرسلًا.</p><p>وقد ورد ما يشهد له من طُرُق أخرى موصولًا.أخرجه ابن المنذر (١٨٣). وعزاه الحافظ ابن حجر في العجاب في بيان الأسباب ١/٥٦٣ والسيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ٥/١٥٥.تفسير الثعلبي ٢/٣٠٧، وتفسير البغوي ١/٣٥٧.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن جرير ٥/١٥٥.أخرجه ابن ماجه ٣/٢٠٠ (٢٠٤٣).</p><p>قال البوصيري في مصباح الزجاجة ٢/١٢٥ (٧٢٧): «هذا إسناد ضعيف». وقال ابن رجب في جامع العلوم والحكم ٢/٣٦٤: «وأبو بكر الهذلي متروك الحديث». وقال ابن الملقن في البدر المنير ٤/١٨٢: «في إسناده شهر بن حوشب، وقد تركوه؛ أي: طعنوا فيه». وقال ابن حجر في التلخيص الحبير ١/٦٧٣: «ورواه ابن ماجه من حديث أبي ذر، وفيه شهر بن حوشب، وفي الإسناد انقطاع أيضًا. ورواه الطبراني من حديث أبي الدرداء، ومن حديث ثوبان، وفي إسنادهما ضعف ...».أخرجه البخاري ٣/١٤٥ (٢٥٢٨)، ٧/٤٦ (٥٢٦٩)، ٨/١٣٥ (٦٦٦٤)، ومسلم ١/١١٦ (١٢٧).أخرجه الطبراني في الأوسط ٨/١٦١ (٨٢٧٦)، والبيهقي في الكبرى ٧/٥٨٤ (١٥٠٩٦) واللفظ له.</p><p>قال الطبراني: «ولا روى حديث عقبة بن عامر إلا موسى بن وردان، ولا رواه عن موسى إلا ابن لهيعة، تفرد به الوليد». ونقل ابن الملقن في البدر المنير ٤/١٨٠ عن ابن أبي حاتم في العلل عن أبيه أنّه قال: «وحديث الوليد أيضًا عن ابن لهيعة، عن موسى بن وردان، عن عقبة بن عامر مرفوعًا مثله، فقال: هذه أحاديث منكرة كأنها موضوعة». وقال الهيثمي في المجمع ٦/٢٥٠ (١٠٥٠٢): «وفيه ابن لهيعة، وحديثه حسن، وفيه ضعف».أخرجه عبد الرزاق في مصنفه ٦/٤٠٩ (١١٤١٦)، وفي تفسيره ١/٣٧٨ (٣٦٧)، وسعيد بن منصور في سننه ١/٣١٧ (١١٤٥).</p><p>نقله ابن الملقن في البدر المنير ٤/١٨٣ بنحوه، وقال: «رواه سعيد بن منصور مرسلًا». وقال المتقي الهندي في كنز العمال ١٢/١٧٤ (٣٤٥٤٢): «عبد الرزاق عن الحسن مرسلًا».أخرجه سعيد بن منصور في سننه ١/٣١٧ (١١٤٦).عزاه السيوطي إلى عبد بن حميد مرسلًا.أخرجه ابن جرير ٥/١٥٩، وابن المنذر (١٨٧)، وابن أبي حاتم ٢/٥٨٠ من طريق الضحاك.عزاه السيوطي إلى الطَّستيِّ.</p><p>والأيصر: الحبل الصغير الذي يُشد به أسفل الخباء. القاموس المحيط (أصر).أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن جرير ٥/١٦٨، وابن أبي حاتم ٢/٥٧٩.عَلَّقه ابن أبي حاتم ٢/٥٧٩.أخرجه ابن جرير ٥/١٦٨. وعلَّقه ابن أبي حاتم ٢/٥٨٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/١٥٩، وابن المنذر (١٩٠) بلفظ: «من الميثاق ما حملتهم»، وابن أبي حاتم ٢/٥٨٠.أخرجه ابن أبي حاتم ٢/٥٨٠ عن مقاتل، وعلَّقه عن الحسن.أخرجه ابن جرير ٥/١٦٠.عزاه السيوطي إلى عَبد بن حُميد.أخرجه عبد الرزاق ١/١١٢، وابن جرير ٥/١٥٨، وابن المنذر (١٨٨).عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر تبعًا لأول الأثر في أول الآية، ولم نجد هذه التتمة في المطبوع من ابن المنذر، أو فيما نقله الحافظ في العجاب.أخرجه ابن جرير ٥/١٥٩، وابن أبي حاتم ٢/٥٨٠.تفسير الثعلبي ٢/٣٠٧، وتفسير البغوي ١/٣٥٨ دون الضحاك.أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن جرير ٥/١٥٩.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن جرير ٥/١٥٩، وأخرج ابن المنذر (١٩١) الشطر الثاني من طريق ابن ثور.أخرجه ابن أبي حاتم ٢/٥٨٠ (٣١٠١).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٣٤ (٢٦٧)، وابن جرير ٥/١٦١.أخرجه ابن جرير ٥/١٦١.أخرجه ابن جرير ٥/١٦٠.القَرْض: القطع. لسان العرب (قرض).المقاريض: جمع مِقْراض، وهو المقص. المعجم الوسيط (قرض).أخرجه أبو داود ١/١٨ (٢٢)، والنسائي ١/٢٦ (٣٠)، وابن ماجه ١/٢٢٨ (٣٤٦)، والحاكم ١/٢٩٤ (٦٥٧-٦٥٨)، وأحمد ٢٩/٢٩٣ (١٧٧٥٨)، ٢٩/٢٩٤ (١٧٧٦٠) بألفاظ متقاربة.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد». وقال الذهبي في التلخيص: «على شرطهما». وقال الألباني في صحيح أبي داود ١/٥٠ (١٦): «إسناده صحيح على شرط البخاري، وصححه الحاكم والذهبي على شرطهما، وهو كما قالا».أخرجه أحمد ٣٨/٤٢٠ (٢٣٤٢٢) موقوفًا، وأيضًا ٣٢/٣٣٩ (١٩٥٦٨) مرفوعًا، وهو في البخاري ١/٥٥ (٢٢٦)، ومسلم ١/٢٢٨ (٢٧٣) عن أبي موسى بنحوه.أخرجه النسائي ٣/٧٢ (١٣٤٥)، وابن أبي شيبة ١/١١٥ (١٣٠٧)، وأحمد ٤٠/٣٨٠ (٢٤٣٢٤).</p><p>إسناده ضعيف؛ فيه جَسْرَة، وهي بنت دَجاجَة. قال البخاري في التاريخ الكبير ٢/٦٧: «عندها عجائب». وقال الألباني في الإرواء ١/٣١٢: «هذا الحديث في الصحيح، دون قول اليهودية:»إن عذاب القبر من البول«، وقوله ﷺ: «صدقت». فهذا يدل على ضعف جسرة، وصحة حكم البخاري على أحاديثها».ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٢-.أخرجه الثعلبي ٢/٣٠٨. تفسير البغوي ١/٣٥٨.أخرجه ابن جرير ٥/١٦١.أخرجه ابن جرير ٥/١٦١، وعبد الرزاق ١/١٢١ من طريق معمر بمعناه.عزاه السيوطي إلى عَبد بن حُمَيد.الغلمة: شهوة النكاح من الرجال والنساء. جمهرة اللغة (غلم).أخرجه ابن أبي حاتم ٢/٥٨١.أخرجه ابن جرير ٥/١٦٢، وابن المنذر (١٩٣)، وابن أبي حاتم ٢/٥٨١.أخرجه ابن أبي حاتم ٢/٥٨١.أخرجه ابن جرير ٥/١٦٢، وابن المنذر (١٩٤) من طريق ابن ثور. وعلَّقه ابن أبي حاتم ٢/٥٨١.أخرجه ابن جرير ٥/١٦٢.تفسير الثعلبي ٢/٣٠٨.لم نقف على ترجمته.أخرجه ابن جرير ٥/١٦٢.أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن المنذر (١٨٦).علَّقه ابن أبي حاتم ٢/٥٨٠.علَّقه ابن أبي حاتم ٢/٥٨٠.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن المنذر (١٩٥) من طريق إسحاق عمَّن حدثه، وابن أبي حاتم ٢/٥٨١ مختصرًا من طريق بُكَيْر بن معروف.أخرجه ابن جرير ٥/١٦٤-١٦٥.أخرجه ابن أبي حاتم ٢/٥٨٢.أخرجه ابن جرير ٥/١٦٩.أخرجه ابن جرير ٥/١٦٨، وابن المنذر (١٨٦)، وابن أبي حاتم ٢/٥٨١-٥٨٢.علَّقه ابن أبي حاتم ٢/٥٨٢.أخرجه ابن أبي حاتم ٢/٥٨٢ عن مقاتل، وعلَّقه عن الباقين.أخرجه ابن أبي حاتم ٢/٥٨٢.أخرجه ابن أبي حاتم ٢/٥٨٢ عن السُّدِّي ومقاتل، وعلَّقه عن عطاء.أخرجه سعيد بن منصور في سننه (٤٨٣-تفسير)، والبيهقي في شعب الإيمان (٢٤١٠).عزاه السيوطي إلى سفيان بن عيينة، وعَبد بن حُمَيد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٢-.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٦٨-١٦٩.أخرجه أبو عبيد في فضائل القرآن ١/٢٣٣، عن ابن أبي مريم، عن ابن لهيعة، عن يزيد بن أبي حبيب، عن أبي إسحاق، عن أبي ميسرة به مرسلًا.</p><p>وهذا على إرساله ضعيف، أبو ميسرة اسمه عمرو بن شرحبيل الهمداني الكوفي، وهو من كبار التابعين، ثقة عابد مخضرم كما في التقريب (٥٠٨٣). وفي إسناده أيضًا عبد الله بن لهيعة صدوق اختلط بعد احتراق كتبه كما في التقريب (٣٥٨٧). والراوي عنه أبو بكر بن عبد الله بن أبي مريم قال عنه ابن حجر في التقريب (٨٠٣١): «ضعيف، وكان قد سُرِق بيته فاختلط».أخرجه أبو عبيد ص١٢٥، وابن أبي شيبة ٢/٤٢٦، وابن جرير ٥/١٦٩، وابن المنذر (١٩٦). كما أخرجه وكيع -كما في تفسير ابن كثير ١/٧٤٢- من طريق أبي إسحاق، عن رجل.أخرجه أبو عبيد ص١٢٥.عزاه السيوطي إلى عبد بن حميد مرسلًا.