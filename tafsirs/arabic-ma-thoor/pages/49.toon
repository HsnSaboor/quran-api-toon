tafsir[4]{c,v,t}:
2,283," <q>﴿وَإِن كُنتُمۡ عَلَىٰ سَفَرࣲ وَلَمۡ تَجِدُوا۟ كَاتِبࣰا فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ فَإِنۡ أَمِنَ بَعۡضُكُم بَعۡضࣰا فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ أَمَـٰنَتَهُۥ وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ وَلَا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ وَمَن یَكۡتُمۡهَا فَإِنَّهُۥۤ ءَاثِمࣱ قَلۡبُهُۥۗ وَٱللَّهُ بِمَا تَعۡمَلُونَ عَلِیمࣱ ۝٢٨٣﴾</q> - نسخ الآية ١١٥٧١- عن أبي سعيد الخدري -من طريق عبد الملك بن أبي نضرة، عن أبيه- أنّه قرأ هذه الآية: <q>﴿یَـٰۤأیُّها ٱلَّذِینَ ءامَنُوۤا۟ إذا تَدایَنتُم بِدَیۡنٍ﴾</q>، حتى إذا بلغ: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q> قال: هذه نَسَخَتْ ما قبلها{1}. (٣/٤١٠) ١١٥٧٢- عن عامر الشعبي -من طريق إسماعيل بن أبي خالد- قال: فكانوا يرون أنّ هذه الآية: <q>﴿فإن أمن بعضكم بعضا﴾</q> نَسَخَتْ ما قبلها من الكتابة والشهود، رخصةً ورحمة من الله{2}. (ز) ١١٥٧٣- عن عامر الشعبي -من طريق أبي بكر- في قوله: <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>، قال: هي منسوخة، <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q> يعني: نسخه ذلك{3}١٠٧٧. (ز) ١٠٧٧ انتقد ابنُ جرير (٥/٧٩) وابنُ عطية (٢/١١١) القول بالنسخ استنادًا إلى إمكان الجمع؛ إذ النسخ لا يُصار إليه إلا عند تعذر الجمع بين الآيتين. وجَمَع ابنُ جرير بين الآيتين بكون كتابة الدَّين واجبة، وقوله تعالى: <q>﴿فَإنْ أمِنَ بَعْضُكُمْ بَعْضًا﴾</q> مُرَخِّص في ترك كتابة الدَّين عند التَّعَذُّر. وجَمَع ابنُ عطية بين الآيتين بأنّ الأمر بكتابة الدين للندب والاحتياط، وليس في الآية ما يفيد منع الكتابة عند الائتمان حتى يُصارَ إلى النسخ. وينظر توجيه ابن تيمية لمعنى النسخ عند السلف عند قوله تعالى: <q>﴿وإنْ تُبْدُوا ما فِي أنْفُسِكُمْ أوْ تُخْفُوهُ يُحاسِبْكُمْ بِهِ اللَّهُ﴾</q>. <q>﴿وَإِن كُنتُمۡ عَلَىٰ سَفَرࣲ وَلَمۡ تَجِدُوا۟ كَاتِبࣰا﴾</q> - قراءات الآية، وتفسيرها ١١٥٧٤- عن عبد الله بن عباس -من طريق مِقْسَم- أنه قرأ: (ولَمْ تَجِدُوا كِتابًا). وقال: قد يوجد الكاتب، ولا يوجد القلم ولا الدَّواة{4} ولا الصحيفة، والكِتابُ يجمع ذلك كله.= (ز) ١١٥٧٥- قال: وكذلك كانت قراءة أُبَيٍّ{5}. (٣/٤٠٧) ١١٥٧٦- عن عبد الله بن عباس -من طريق عكرمة- أنّه كان يقرؤها: (فَإن لَّمْ تَجِدُوا كِتابًا). وقال: الكُتّابُ كثيرٌ، لم يكن حِواءٌ{6} من العرب إلا كان فيهم كاتب؛ ولكن كانوا لا يقدرون على القِرْطاس{7}، والقلم، والدَّواة{8}. (٣ /٤٠٧) ١١٥٧٧- عن عبد الله بن عباس -من طريق ابن جُرَيج، عن أبيه- أنّه قرأ: (فَإن لَّمْ تَجِدُوا كُتّابًا). قال: ربما وجد الرجل الصحيفةَ ولم يجد كاتبًا{9}. (ز) ١١٥٧٨- عن عبد الله بن عباس أنّه كان يقرأ: (ولَمْ تَجِدُوا كُتّابًا) بضم الكاف، وتشديد التاء{10}. (٣/٤٠٨) ١١٥٧٩- عن أبي العالية -من طريق شعيب بن الحبحاب- أنّه كان يقرأ: (فَإن لَّمْ تَجِدُوا كِتابًا). قال: يوجد الكاتب، ولا توجد الدَّواة ولا الصحيفة{11}. (٣/٤٠٧) ١١٥٨٠- عن الضحاك بن مزاحم، مثله{10}. (٣/٤٠٧) ١١٥٨١- عن الضحاك بن مزاحم -من طريق محمد بن يزيد، عن جويبر- قال: ما كان من بيعٍ حاضرٍ أمر اللهُ أن يُشْهِدوا، وما كان مِن بيع إلى أجل مسمى أمر اللهُ أن يكتب ويشهد عليه، وذلك في المقام، فإذا كان في السفر فتبايعوا (ولَمْ يَجِدُوا كُتّابًا)، يعني بالكتاب: إذا وجدوا الصحيفة والكتاب والدواة، فإن لم يجدوا <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>. يقول: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ أمَـٰنَتَهُۥ﴾</q> وليأمن بعضكم بعضًا{13}. (ز) ١١٥٨٢- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ﴾</q> <q>﴿ولَمۡ تَجِدُوا۟ كاتِبࣰا﴾</q>، يعني: لم تقدروا على كتابة الدَّيْن في السَّفَر{14}. (٣/٤٠٩) ١١٥٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- أنّه قرأها: (فَإن لَّمْ تَجِدُوا كِتابًا) قال: مِدادًا{15}. وفي رواية: ربما وُجِد الكُتّاب، ولم تُوجَدِ الصحيفة أو المِداد{16}. (٣/٤٠٧) ١١٥٨٤- عن عكرمة مولى ابن عباس أنّه قرأها: (فَإن لَّمْ تَجِدُوا كِتابًا){17}. (٣/٤٠٨) ١١٥٨٥- عن الربيع بن أنس -من طريق أبي جعفر الرازي- قوله: <q>﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ ولَمۡ تَجِدُوا۟ كاتِبࣰا﴾</q> يقول: كاتبًا يكتب لكم <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>{18}١٠٧٨. (ز) ١٠٧٨ رجَّح ابنُ جرير (٥/١٢١) وابنُ عطية (٢/١٢٦) قراءة <q>﴿كاتبًا﴾</q> لموافقتها خط المصحف. وانتقد ابنُ جرير قراءة (كِتابًا) فقال: «والقراءة التي لا يجوز غيرها عندنا هي قراءة: <q>﴿ولم تجدوا كاتبًا﴾</q>، بمعنى: من يكتب؛ لأن ذلك كذلك في مصاحف المسلمين، وغير جائز القراءة بغير ما في مصاحف المسلمين مُثْبَتٌ من القراءات». <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q> - تفسير الآية ١١٥٨٦- عن سعيد بن جبير -من طريق سالم الأفطس- قال: لا يكون الرهن إلا مقبوضًا، يقبضه الذي له المال. ثم قرأ: <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>{19}. (٣/٤٠٩) ١١٥٨٧- عن سعيد بن جبير -من طريق عطاء بن دينار- <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>، يقول: فلْيَرْتَهِن الذي له الحق من المطلوب{14}. (٣/٤٠٩) ١١٥٨٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وإنْ كُنْتُمْ عَلى سَفَرٍ ولَمْ تَجِدُوا كاتِبًا فَرُهُنٌ مَقْبُوضَةٌ﴾</q>، قال: لا يكون الرَّهْن إلا في السفر{21}١٠٧٩. (٣/٤٠٨) ١٠٧٩ انتَقَد ابنُ جرير (٥/١٢٥)، وابنُ عطية (٢/١٢٥-١٢٦)، وابنُ كثير (١/٧٢٧) مستندين إلى السُّنَّةِ القولَ بكون الرهن لا يصار إليه إلا عند تعذر الكاتب والشهيد، وأنّ ذلك في السفر لا في الحضر. قال ابنُ جرير عَقِب إيراده أثر الضحاك: «إنه قول لا معنى له؛ لصحة الخبر عن رسول الله ﷺ أنه اشترى طعامًا نَساءً، فجائز للرجل أن يرهن ويرتهن، في السفر والحضر؛ لصحة الخبر عن رسول الله ﷺ، ولأنه لم يكن مُتَعَذِّرًا عليه بمدينته في وقت من الأوقات الكاتب والشاهد». وبيَّن ابنُ عطية أنّ ذكر السفر في الآية وارد مورد التمثيل للأعذار، لا مورد الحصر لها، فيدخل في الآية كل عذر يحول دون الكتابة. ١١٥٨٩- عن الضحاك بن مزاحم -من طريق أبي زهير، عن جُوَيْبِر- في قوله: <q>﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ﴾</q> الآية، قال: مَن كان على سفر، فبايع بيعًا إلى أجل، فلم يجد كاتبًا؛ فرُخِّص له في الرهان المقبوضة، وليس له إن وجد كاتبًا أن يرتهن{22}. (٣/٤٠٨) ١١٥٩٠- عن خالد بن دينار، قال: سألت سالم [بن عبد الله بن عمر] عن الرهن في السلم. فقرأ: <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>، كأنّه لم ير به بأسًا{23}. (ز) ١١٥٩١- قال مقاتل بن سليمان: <q>﴿وإن كُنتُمۡ عَلىٰ سَفَرࣲ ولَمۡ تَجِدُوا۟ كاتِبࣰا فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q>، يقول: إذا لم يكن الكاتب والصحيفة حاضِرَيْن فلْيَرْتَهِن الذي عليه الحقُّ مِن المطلوب{24}. (ز) <q>﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱۖ﴾</q> - آثار متعلقة بالآية ١١٥٩٢- عن عائشة، قالت: اشترى رسول الله ﷺ طعامًا من يهودي بنسيئة، ورهنه دِرْعًا له من حديد{25}. (٣/٤٠٩) ١١٥٩٣- عن عطاء بن أبي رباح -من طريق ابن أبي نَجِيح- أنّه كان لا يرى بأسًا بالرَّهن والقبيل{26} في السَّلَف. وكره ذلك مجاهد، وقال: يُكْرَه الرهن إلا في السفر{27}. (ز) <q>﴿فَإِنۡ أَمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q> - تفسير ١١٥٩٤- عن سـعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q>، يقول: فإن كان الذي عليه الحقُّ أمينًا عند صـاحب الحق، فلم يرتهن لِثِقَته وحُسْنِ ظنِّه{28}. (٣/٤٠٩) ١١٥٩٥- عن الضحاك بن مزاحم -من طريق جويبر-: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q> فمن لم يجد فإنها عزمة أن يكتب ويشهد، ولا يأخذ رهنًا إذا وجد كاتبًا، كما قال في الظِّهار: <q>﴿فَمَن لَّمۡ یَجِدۡ فَصِیامُ شَهۡرَیۡنِ مُتَتابِعَیۡنِ﴾</q> [المجادلة:٤]، وكما قال في موضع آخر: <q>﴿فَما ٱسۡتَیۡسَرَ مِنَ ٱلۡهَدۡیِۖ﴾</q> [البقرة:١٩٦]، فهذا يشبه بعضه بعضًا، وآية الدين حكم حكَمه الله وفصَّله وبيَّنه، فليس لأحد أن يَتَخَيَّر في حكم الله{29}. (ز) ١١٥٩٦- عن عامر الشعبي -من طريق الثوري وابن عيينة، عن ابن شُبْرُمَة- قال: لا بأس إذا أمِنتَهُ أن لا تكتب ولا تشهد؛ لقوله: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q>{30}. (٣/٤١٠) ١١٥٩٧- عن حماد بن أبي سليمان -من طريق أبي سنان- في قوله: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q>، قال: أخلاقٌ دَلَّهُم عليها{31}. (ز) ١١٥٩٨- قال مقاتل بن سليمان: <q>﴿فَإنۡ أمِنَ بَعۡضُكُم بَعۡضࣰا﴾</q> في السفر، فإن كان الذي عليه الحق أمينًا عند صاحب الحق فلم يرتهن منه لثقته به وحسن ظنه{24}. (ز) <q>﴿فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ أَمَـٰنَتَهُۥ وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</q> - تفسير ١١٥٩٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿فَلۡیُؤَدِّ ٱلَّذِی ٱؤۡتُمِنَ﴾</q> <q>﴿أمَـٰنَتَهُۥ﴾</q>، يقول: ليُؤدِّ الحَقَّ الذي عليه إلى صاحبه{14}. (٣/٤٠٩) ١١٦٠٠- عن عامر الشعبي -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿فَلۡیُؤَدِّ ٱلَّذِی﴾</q> <q>﴿ٱؤۡتُمِنَ أمَـٰنَتَهُۥ﴾</q>، قال: صار الأمرُ إلى الأمانة{31}. (ز) ١١٦٠١- عن العلاء بن المسيب: أنه سمع الحكم [بن عُتَيْبة] يقول: نَسَخَتْ هذه الشهودَ{35}. (ز) ١١٦٠٢- عن مقاتل بن سليمان: <q>﴿فَلۡیُؤَدِّ﴾</q> ذلك <q>﴿ٱلَّذِی ٱؤۡتُمِنَ أمَـٰنَتَهُۥ ولۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</q>، يقول: لِيَرُدَّ على صاحب الحقِّ حقَّه حين ائتمنه ولم يَرْتَهِن منه{24}. (ز) <q>﴿وَلۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</q> - تفسير ١١٦٠٣- عن سعيد بن جبير -من طريق عطاء بن دينار- قال: خوَّف اللهُ الذي عليه الحقُّ، فقال: <q>﴿ولۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</q>{14}. (٣/٤٠٩) ١١٦٠٤- قال مقاتل بن سليمان: ثم خوَّفه الله ﷿، فقال: <q>﴿ولۡیَتَّقِ ٱللَّهَ رَبَّهُۥۗ﴾</q>، يعني: الذي عليه الحق{24}. (ز) <q>﴿وَلَا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</q> - تفسير ١١٦٠٥- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿ولا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</q>، يعني: عند الحكام. يقول: مَن أُشْهِد على حقٍّ فلْيُقِمْها على وجهها كيف كانت{14}. (٣/٤٠٩) ١١٦٠٦- عن الربيع بن أنس، في قوله: <q>﴿ولا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</q>، قال: فلا يـحِلُّ لأحد أن يكتم شهادة هي عنده، وإن كانت على نفسه والوالدين{40}. (ز) ١١٦٠٧- قال مقاتل بن سليمان: ثم رجع إلى الشهود، فقال: <q>﴿ولا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</q> عند الحاكم. يقول: مَن أُشْهِد على حقٍّ فليشهد بها على وجهها كما كانت عند الحاكم، فلا تكتموا الشهادة{24}. (ز) <q>﴿وَلَا تَكۡتُمُوا۟ ٱلشَّهَـٰدَةَۚ﴾</q> - آثار متعلقة بالآية ١١٦٠٨- عن أبي سعيد الخدري، قال: قال رسول الله ﵇: «لا يَمْنَعَنَّ أحَدَكم هَيْبَةُ الناس أن يقول في حقٍّ إذا رآه أو شَهِده أو سَمِعه»{42}. (ز) ١١٦٠٩- عن مكحول، عن أبي بردة، عن أبيه، عن النبيِّ ﷺ، قال: «مَن كتم الشهادة إذا دُعي كان كمن شهد بالزور»{43}. (ز) ١١٦١٠- عن عبد الله بن عباس -من طريق عمرو بن دينار- قال: إذا كانت عندك شهادةٌ، فسألَك عنها؛ فأخْبِرْه بها، ولا تقل: أُخْبِرُ بها عند الأمير. أخْبِرْه بها لعلَّه يراجع أو يرعوي{44}١٠٨٠. (ز) ١٠٨٠ علَّق ابنُ عطية (٢/١٣١) على قول ابن عباس بقوله: «وهذا عندي بحسب قرينة حال الشاهد، والمشهود فيه، والنازلة، لا سيما مع فساد الزمن، وأرذال الناس، ونفاق الحيلة، وأغراض الدنيا عند الحكام، فرُبَّ شهادة إن صرح بها في غير موضع النفوذ كانت سببًا لتخدم باطلًا ينطمس به الحق». <q>﴿وَمَن یَكۡتُمۡهَا فَإِنَّهُۥۤ ءَاثِمࣱ قَلۡبُهُۥۗ وَٱللَّهُ بِمَا تَعۡمَلُونَ عَلِیمࣱ﴾</q> - تفسير ١١٦١١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قال: أكبر الكبائر: الإشراك بالله؛ لأن الله ﷿ يقول: <q>﴿مَن یُشۡرِكۡ بِٱللَّهِ فَقَدۡ حَرَّمَ ٱللَّهُ عَلَیۡهِ ٱلۡجَنَّةَ﴾</q> [المائدة:٧٢]، وشهادة الزور، وكتمان الشهادة؛ لأن الله يقول: <q>﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</q>{45}. (ز) ١١٦١٢- عن عبد الله بن عباس -من طريق مِقْسَم- قال: نزلت في الشهادة: <q>﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</q>{46}. (ز) ١١٦١٣- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿ومَن یَكۡتُمۡها﴾</q> يعني: الشهادة، ولا يشهدُ بها إذا دُعِيَ لها؛ <q>﴿فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ وٱللَّهُ بِما تَعۡمَلُونَ﴾</q> يعني: من كتمان الشهادة، وإقامتها{14}. (٣/٤٠٩) ١١٦١٤- عن عطية العوفي -من طريق فضيل- <q>﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</q>، قال: بعد ما يشهد{48}. (ز) ١١٦١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ءاثِمࣱ قَلۡبُهُۥۗ﴾</q>، قال: فاجِرٌ قلبُه{49}. (٣/٤١٠) ١١٦١٦- عن الربيع بن أنس، في قوله: <q>﴿ومَن یَكۡتُمۡها فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ﴾</q>، قال: ومَن كتمها فقد ركب إثمًا عظيمًا{50}. (ز) ١١٦١٧- قال مقاتل بن سليمان: قال: <q>﴿ومَن یَكۡتُمۡها﴾</q> ولا يشهد بها عند الحاكم، <q>﴿فَإنَّهُۥۤ ءاثِمࣱ قَلۡبُهُۥۗ وٱللَّهُ بِما تَعۡمَلُونَ﴾</q> من كتمان الشهادة وإقامتها <q>﴿عَلِیمࣱ﴾</q>{51}. (ز) ",footnotes:1:أخرجه البخاري في التاريخ الكبير ١/٢٣٢، والنحاس ص٢٦٧-٢٦٨ في ناسخه، وابن ماجه (٢٣٦٥)، وابن جرير ٥/٧٥-٧٦، وابن المنذر (٧٤)، وابن أبي حاتم ٢/٥٧٠ (٣٠٤١)، وأبو نعيم في الحلية ٩/٤٨، والبيهقي في سُنَنه ١٠/١٤٥. وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه سفيان الثوري في تفسيره بنحوه ص٧٣، وابن جرير ٥/٧٤. وتقدم في الآية السابقة زيادة بيان ذلك، والراجح في المسألة.أخرجه ابن أبى حاتم ٢/٥٧٠.الدَّواة: المحبرة. مختار الصحاح (دوى).أخرجه أبو عبيد في فضائله ص١٦٧، وسعيد بن منصور في سننه ٤٦٨ - تفسير، وابن جرير ٥/١٢٢، وابن المنذر (١٥٠)، وابن أبي حاتم ٢/٥٦٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن الأنباري في المصاحف. وقراءة (كِتابًا) قراءة شاذة، وهي تنسب إلى أُبَيٍّ، وابن عباس، ومجاهد، وعكرمة. انظر: مختصر ابن خالويه ص١٨، والبحر المحيط ٢/٣٥٥.الحِواء: جماعة البيوت المتدانية. لسان العرب (حوى).القِرطاس: الصحيفة يكتب فيها. تاج العروس (قرطس).أخرجه ابن المنذر (١٥٢)، وابن أبي حاتم بنحوه مختصرًا ٢/٥٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٢٢. وقراءة ابن عباس، والضحاك، وأبي العالية: (كُتّابًا) شاذة. انظر: البحر المحيط ٢/٣٥٥، وتفسير القرطبي ٣/٤٠٧.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ٥/١٢٣، وابن المنذر (١٥٤). وعلَّقه ابن أبي حاتم ٢/٥٦٩. وينظر: تفسير الثعلبي ٢/٢٩٧. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن المنذر (١٥٧)، وابن أبي حاتم ٢/٥٦٩ مختصرًا من طريق مروان عن جويبر، ولفظه: يعني بذلك: أنه لا يصلح إذا كان بيعًا في سفر إذا وجد كتابًا أن يأخذ رهنًا، ولكن ليكتب حقه إلى أجله.أخرجه ابن أبي حاتم ٢/٥٦٩.المِداد: الحبر. تاج العروس (حبر).أخرجه أبو عبيد في فضائل القرآن ص١٦٧، وابن جرير ٥/١٢٢، وابن المنذر (١٥٣). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن الأنباري.أخرجه أبو عبيد في فضائل القرآن ص١٦٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن الأنباري.أخرجه ابن جرير ٥/١٢١.أخرجه ابن المنذر (١٥٥)، وابن أبي حاتم ٢/٥٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن المنذر (١٥٨)، وابن أبي حاتم ٢/٥٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٢١، وابن المنذر (١٥٦) من طريق محمد بن عبد الله بن يزيد عن جويبر، وابن أبي حاتم ٢/٥٦٩ من طريق مروان عن جويبر، وعندهما بلفظ: يعني بذلك: أنه لا يصلح إذا كان بيعًا في سفر إذا وجد كتابًا أن يأخذ رهنًا، ولكن ليكتب حقه إلى أجله.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٤٩٩ (٢٠٣٩٠).تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه البخاري ٣/٥٦ (٢٠٦٨)، ٣/٦٢ (٢٠٩٦)، ٣/٧٧ (٢٢٠٠)، ٣/٨٦ (٢٢٥١)، ٣/٨٦ (٢٢٥٢)، ٣/١١٥ (٢٣٨٦)، ٣/١٤٢ (٢٥٠٩)، ٣/١٤٣ (٢٥١٣)، ومسلم ٣/١٢٢٦ (١٦٠٣).القبيل: الكفيل. لسان العرب (قبل).أخرجه ابن المنذر (١٥٨).أخرجه ابن أبي حاتم ٢/٥٦٩ (٣٠٣٦).أخرجه ابن المنذر (١٥٦)، وابن أبي حاتم ٢/٥٧٠ (٣٠٤٣).أخرجه عبد الرزاق ١/١١١، وابن جرير ٥/٧٤، وابن المنذر (١٥٩)، وابن أبي حاتم ٢/٥٧٠، والبيهقي -من طريق داود- بنحوه ١٠/١٤٥. وعزاه السيوطي إلى عَبد بن حُمَيد. وزاد عبد الرزاق من طريق ابن عيينة: إلى هذا انتهى <q>﴿فَإنۡ﴾</q> <q>﴿أمِنَ﴾</q> <q>﴿بَعۡضُكُم﴾</q> <q>﴿بَعۡضࣰا﴾</q>. كما أخرج نحوه ابن جرير ٥/٧٤ من طريق عاصم.أخرجه ابن أبي حاتم ٢/٥٧١.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن أبي حاتم ٢/٥٧١.أخرجه ابن المنذر (١٦٠).تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٩.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن جرير ٥/١٢٦، وابن أبي حاتم ٢/٥٧١ بزيادة: أو الأقربين.تفسير مقاتل بن سليمان ١/٢٣٠.أخرجه أحمد ١٨/٣١٧ (١١٧٩٣) واللفظ له، والترمذي ٤/٢٦٠ (٢٣٣٦)، وابن ماجه ٥/١٤١ (٤٠٠٧)، وابن حبان ١/٥٠٩ (٢٧٥)، ١/١٢ (٢٧٨)، والحاكم ٤/٥٥١ (٨٥٤٣)، بنحوه. قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث تفرَّد بهذه السياقة علي بن زيد بن جدعان القرشي، عن أبي نضرة، والشيخان ﵄ لم يحتجا بعلي بن زيد». وقال الذهبي في التلخيص: «ابن جدعان صالح الحديث». وإسناد أحمد ليس فيه ابن جدعان، وهو صحيح على شرط مسلم، كما قال الألباني في الصحيحة ١/٣٢٢ (١٦٨).أخرجه الطبراني في الأوسط ٤/٢٧٠ (٤١٦٧). وأورده الثعلبي ٢/٢٩٩. قال الطبراني: «لم يرو هذا الحديث عن مكحول إلا العلاء، ولا عن العلاء إلا معاوية، ولا عن معاوية إلا عبد الله بن صالح، تفرد به أبو قرة». قال الهيثمي في المجمع ٤/٢٠٠ (٧٠٣٨): «رواه الطبراني في الكبير والأوسط، وفيه عبد الله بن صالح، وثّقه عبد الملك بن شعيب بن الليث، فقال: ثقة مأمون، وضعّفه جماعة». وقال الألباني في الضعيفة ٣/٤٢٨ (١٢٦٧): «ضعيف».أخرجه ابن جرير ٥/١٢٧.أخرجه ابن جرير ٥/١٢٧، وابن أبي حاتم ٢/٥٧١.أخرجه ابن المنذر (١٦١). كذا في هذه الرواية الإشارة إلى هذه الآية، وفي رواية أخرى عند ابن جرير وابن المنذر الإشارة إلى قوله تعالى: <q>﴿وإن﴾</q> <q>﴿تُبۡدُوا۟﴾</q> <q>﴿ما﴾</q> <q>﴿فِیۤ﴾</q> <q>﴿أنفُسِكُمۡ﴾</q> الآية، كما أخرج نحوه سعيد بن منصور، وابن جرير، وابن المنذر، وابن أبي حاتم من طريق مجاهد. وسيأتي.أخرجه ابن أبي حاتم ٢/٥٦٩.أخرجه ابن المنذر (١٦٢).أخرجه ابن جرير ٥/١٢٦، وابن أبي حاتم ٢/٥٧٢.أخرجه ابن جرير ٥/١٢٦.تفسير مقاتل بن سليمان ١/٢٣١.
2,284," <q>﴿لِّلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَإِن تُبۡدُوا۟ مَا فِیۤ أَنفُسِكُمۡ أَوۡ تُخۡفُوهُ یُحَاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٢٨٤﴾</q> - نزول الآية ١١٦١٨- عن عبد الله بن عباس، قال: لَمّا نزلت هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> دخل في قلوبهم شيءٌ منه لم يدخلْ من شيء، فقالوا للنبي ﷺ، فقال: «قولوا: سمعنا، وأطعنا، وسلَّمْنا». فألقى اللهُ الإيمانَ في قلوبهم؛ فأنزل الله: <q>﴿ءامَنَ ٱلرَّسُولُ﴾</q> الآية، <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>. قال: قد فعلتُ. <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>. قال: قد فعلتُ. <q>﴿وٱعۡفُ عَنّا وٱغۡفِرۡ لَنا وٱرۡحَمۡناۤۚ﴾</q> الآية، قال: قد فعلتُ{1}. (٣/٤١٢) ١١٦١٩- عن عبد الله بن عباس، قال: لَمّا نزلت: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> الآيةَ؛ أتى أبو بكر وعمرُ ومعاذُ بن جبل وسعدُ بن زرارة رسولَ الله ﷺ، فقالوا: ما نزل علينا آيةٌ أشدُّ مِن هذه{2}. (٣/٤١٨) ١١٦٢٠- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: نزلت في الشهادة{3}. (٣/٤١١) ١١٦٢١- عن عبد الله بن عباس -من طريق مقسم- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</q> الآية، قال: نزلت في كتمان الشهادة، وإقامتها{4}. (٣/٤١١) ١١٦٢٢- عن مقسم، مثل ذلك{5}. (ز) ١١٦٢٣- عن عكرمة مولى ابن عباس -من طرق- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، يعني: كتمان الشهادة، وإقامتها على وجهها{6}. (ز) ١١٦٢٤- عن عامر الشعبي -من طريق السُّدِّي- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>، قال: في الشهادة{7}. (ز) ١١٦٢٥- عن محمد بن كعب القرظي -من طريق خالد بن زيد- قال: ما بعث الله من نبي، ولا أرسل من رسول أنزل عليهم الكتاب إلا أنزل عليه هذه الآية: <q>﴿لِّلَّهِ ما فِی ٱلسَّمَـٰو ٰ⁠تِ وما فِی ٱلۡأرۡضِۗ وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشاۤءُ ویُعَذِّبُ مَن یَشاۤءُۗ وٱللَّهُ عَلىٰ كُلِّ شَیۡءࣲ قَدِیرٌ﴾</q>، فكانت الأمم تأبى على أنبيائها ورسلها، ويقولون: نؤاخذ بما نحدث به أنفسنا ولم تعمله جوارحنا؟! فيكفرون، ويَضِلُّون، فلمّا نزلت على النبي ﷺ اشتَدَّ على المسلمين ما اشْتَدَّ على الأمم قبلهم، فقالوا: يا رسول الله، أنؤاخذ بما نُحَدِّث به أنفسنا ولم تعمله جوارحنا؟! قال: «نعم، واسمعوا وأطيعوا، واطلبوا إلى ربكم». فذلك قوله: <q>﴿ءامَنَ ٱلرَّسُولُ﴾</q> الآية، فوضع الله عنهم حديث النفس، إلا ما عملت الجوارح{8}. (٣/٤١٥) <q>﴿لِّلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَإِن تُبۡدُوا۟ مَا فِیۤ أَنفُسِكُمۡ أَوۡ تُخۡفُوهُ یُحَاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٢٨٤﴾</q> - ما جاء في أنَّ الآية منسوخة ١١٦٢٦- عن عبد الله بن مسعود -من طريق الضحاك- في الآية، قال: كانت المحاسبة قبل أن تنزل <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>، فلما نزلت نسخت الآية التي كانت قبلها{9}. (٣/٤١٤) ١١٦٢٧- عن علي بن أبي طالب -من طريق السدي- قال: لَمّا نزلت هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> الآية؛ أحزنتنا، قلنا: أيُحَدِّث أحدُنا نفسَه فيحاسب به؟! لا ندري ما يغفر منه، ولا ما يغفر منه؟ فنزلت هذه الآية بعدها، فنَسَخَتْها: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>{10}. (٣/٤١٤) ١١٦٢٨- عن أبي هريرة، قال: لَمّا نزلت على رسول الله ﷺ: <q>﴿لِّلَّهِ ما فِی ٱلسَّمَـٰو ٰ⁠تِ وما فِی ٱلۡأرۡضِۗ وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشاۤءُ ویُعَذِّبُ مَن یَشاۤءُۗ وٱللَّهُ عَلىٰ كُلِّ شَیۡءࣲ قَدِیرٌ﴾</q>؛ اشْتَدَّ ذلك على أصحاب رسول الله ﷺ، فأتوا رسول الله ﷺ، ثم جثوا على الرُّكَب، فقالوا: يا رسول الله، كُلِّفْنا من الأعمال ما نُطِيق؛ الصلاة، والصيام، والجهاد، والصدقة، وقد أُنزِلت عليك هذه الآية ولا نُطِيقها. فقال رسول الله ﷺ: «أتريدون أن تقولوا كما قال أهلُ الكتابين من قبلكم: سمعنا وعصينا؟! بل قولوا: <q>﴿سَمِعۡنا وأَطَعۡناۖ غُفۡرانَكَ رَبَّنا وإلَیۡكَ ٱلۡمَصِیرُ﴾</q>». فلما اقْتَرَأَها القومُ، وذَلَّت بها ألسنتهم؛ أنزل الله في إثرها: <q>﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ﴾</q> الآية، فلما فعلوا ذلك نسخها الله، فأنزل: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q> إلى آخرها{11}. (٣/٤١١) ١١٦٢٩- عن عائشة أم المؤمنين -من طريق قتادة- في الآية، قالت: نسخها قوله: <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>{12}. (٣/٤١٥) ١١٦٣٠- عن عبد الله بن عباس، قال: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> نُسِخَت، فقال: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{13}. (٣/٤١٧) ١١٦٣١- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: لَمّا نزلت اشْتَدَّ ذلك على المسلمين وشَقَّ عليهم، فنسخها الله؛ فأنزل: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{14}. (٣/٤١٨) ١١٦٣٢- عن سالم بن عبد الله بن عمر: أنّ أباه قرأ: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، فدمعت عيناه، فبــلغ صنيعُه عبدَ الله بن عبـاس، فقال: يرحم الله أبا عبد الرحمن، لقد صنع كما صنع أصحاب رسول الله ﷺ حين أُنزلت، فنسختها الآية التي بعدها: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{15}. (٣/٤١٣) ١١٦٣٣- عن مجاهد، قال: دخلتُ على ابن عباس، فقلتُ: كنتُ عند ابن عمر، فقرأ هذه الآية، فبكى. قال: أيةُ آيةٍ؟ قلت: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>. قال ابن عباس: إن هذه الآية حين أُنزلت غمَّتْ أصحابَ رسول الله ﷺ غمًّا شديدًا، وغاظتهم غيظًا شديدًا، وقالوا: يا رسول الله، هلكنا إن كنا نؤاخذ بما تكلمنا وبما نعمل، فأمّا قلوبنا فليست بأيدينا. فقال لهم رسول الله ﷺ: «قولوا: سمعنا وأطعنا». قال: فنسختها هذه الآية: <q>﴿ءامَنَ ٱلرَّسُولُ﴾</q> إلى <q>﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>، فتُجُوِّزَ لهم عن حديث النفس، وأُخِذُوا بالأعمال{16}. (٣/٤١٢) ١١٦٣٤- عن مروان الأصفر، عن رجل من أصحاب النبي ﷺ أحسـبه ابن عمر: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>، قال: نَسَخَتْها الآيةُ التي بعدها{17}. (٣/٤١٤) ١١٦٣٥- عن كعب الأحبار= (ز) ١١٦٣٦- وعكرمة مولى ابن عباس: أنها منسوخة{18}. (ز) ١١٦٣٧- عن أبي عبيدة بن عبد الله بن مسعود -من طريق الشعبي- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: نســـخت هذه الآيةُ التي بعدها: <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>{19}. (ز) ١١٦٣٨- عن سعيد بن جبير -من طريق عطاء بن السائب، وآدم بن سليمان- قال: نَسَخَتْ هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>، <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{20}. (ز) ١١٦٣٩- عن سعيد بن جبير -من طريق آدم بن سليمان- قال: لَمّا نزلت هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>؛ قالوا: أنُؤاخذ بما حَدَّثْنا به أنفسَنا ولم تعمل به جوارحُنا؟! قال: فنزلت هذه الآية: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>. قال: ويقول: قد فعلتُ. <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>. قال: ويقول: فعلتُ. قال: فأعطيت هذه الأمة خواتيم سورة البقرة، لم تُعْطَها الأمم قبلها{21}. (ز) ١١٦٤٠- عن إبراهيم النخعي -من طريق إبراهيم بن مهاجر- قال: نَسَخَها <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{22}. (ز) ١١٦٤١- عن مجاهد بن جبر -من طريق جابر، وإبراهيم بن مهاجر-: نَسَخَتْ هذه الآيةُ: <q>﴿﴾</q> الآية{23}. (ز) ١١٦٤٢- عن عامر الشعبي -من طريق سَيّار، وغيره- قال: لَمّا نزلت هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشاۤءُ ویُعَذِّبُ مَن یَشاۤءُۗ﴾</q>، قال: فكان فيها شِدَّة، حتى نزلت هذه الآية التي بعدها: <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>. قال: فنسخت ما كان قبلها{24}. (ز) ١١٦٤٣- عن ابن عون، قال: ذكروا عند الشعبي: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>، حتى بلغ: <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>. قال: فقال الشعبيُّ: إلى هذا صار، رجعت إلى آخر الآية{23}. (ز) ١١٦٤٤- عن عامر الشعبي -من طريق مغيرة- <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: نَسَخَتْها الآيةُ التي بعدها: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>. وقوله: <q>﴿وإن تبدوا﴾</q> قال: يحاسب بما أبدى مِن سِرٍّ، أو أخفى مِن سِرٍّ، فنسختها التي بعدها{26}. (ز) ١١٦٤٥- عن الحسن البصري -من طريق حميد- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q> إلى آخر الآية، قال: نَسَخَتْها: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>{27}. (ز) ١١٦٤٦- عن قتادة -من طريق معمر بن راشد- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: نَسَخَتْها قولُه: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{28}. (ز) ١١٦٤٧- عن محمد بن سيرين= (ز) ١١٦٤٨- ومحمد بن كعب= (ز) ١١٦٤٩- والكلبي= (ز) ١١٦٥٠- وموسى بن عبيدة= (ز) ١١٦٥١- وشيبة، نحو ذلك{29}. (ز) ١١٦٥٢- قال محمد ابن شهاب الزهري: قال تعالى: <q>﴿وإن تبدوا ما في أنفسكم أو تخفوه يحاسبكم به الله فيغفر لمن يشاء ويعذب من يشاء﴾</q>، نُسخت بقوله تعالى: <q>﴿لا يكلف الله نفسا إلا وسعها لها ما كسبت وعليها ما اكتسبت﴾</q>، أي: لا يُكتب على أحد إلا ما فعل وما عَمِل{30}. (ز) ١١٦٥٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: يوم نزلت هذه الآية كانوا يؤاخذون بما وسْوَسَتْ به أنفسُهم وما عَمِلوا، فشَكَوا ذلك إلى النبي ﷺ، فقالوا: إن عَمِل أحدُنا وإن لم يَعْمَل أُخِذْنا به؟!، واللهِ، ما نملك الوسوسة. فنسخها اللهُ بهذه الآية التي بعدها بقوله: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، فكان حديثُ النفس مما لم تطيقوا{31}. (ز) ١١٦٥٤- قال مقاتل بن سليمان: فلما نزلت هذه الآيةُ قال المسلمون: يا رسول الله، إنّا نُحَدِّثُ أنفسَنا بالشرك والمعصية، أفيحاسبنا اللهُ بها ولا نعملها؟ فأنزل الله ﷿ في قولهم في التقديم: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q> ...، فنسخت هذه الآية قولَه سبحانه: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>{32}. (ز) ١١٦٥٥- عن عبد الرحمن بن زيد بن أسلم -من طريق عبد الله بن وهب- قال: لَمّا نزلت هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> إلى آخر الآية اشتدت على المسلمين، وشقت مشقة شديدة، فقالوا: يا رسول الله، لو وقع في أنفسنا شيء لم نعمل به وأخذنا الله به؟ قال: «فلعلكم تقولون كما قال بنو إسرائيل لموسى: سمعنا وعصينا؟!». قالوا: بل سمعنا وأطعنا، يا رسول الله. قال: فنزل القرآنُ يُفَرِّجها عنهم: <q>﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ وٱلۡمُؤۡمِنُونَۚ كُلٌّ ءامَنَ بِٱللَّهِ ومَلَـٰۤىِٕكَتِهِۦ وكُتُبِهِۦ ورُسُلِهِۦ﴾</q> إلى قوله: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>. قال: فصَيَّره إلى الأعمال، وترك ما يقع في القلوب{33}. (ز) <q>﴿لِّلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَإِن تُبۡدُوا۟ مَا فِیۤ أَنفُسِكُمۡ أَوۡ تُخۡفُوهُ یُحَاسِبۡكُم بِهِ ٱللَّهُۖ فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٢٨٤﴾</q> - ما جاء في أن الآية محكمة غير منسوخة ١١٦٥٦- عن أُمَيَّة: أنها سألت عائشةَ عن قول الله تعالى: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، وعن قوله: <q>﴿مَن یَعۡمَلۡ سُوۤءࣰا یُجۡزَ بِهِۦ﴾</q> [النساء:١٢٣]. فقالت: ما سألني عنها أحدٌ منذُ سألتُ رسولَ الله ﷺ، فقال: «هذه معاتبة الله العبدَ{34} فيما يصيبه من الحُمّى والنَّكْبَة، حتى البضاعة يضعها في يد قميصه، فيفقدها، فيفزع لها، ثم يجدها في ضِبْنه{35}، حتى إنّ العبد ليخرج من ذنوبه كما يخرج التِّبْرُ{36} الأحمرُ مِن الكِير{37}»{38}. (٣/٤١٩) ١١٦٥٧- عن عائشة -من طريق الضحاك- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</q> الآية، قالت: هو الرجل يَهُمُّ بالمعصية ولا يعملها، فيرسل عليه من الغم والحزن بقدر ما كان همَّ به من المعصية، فتلك محاسبته{39}. (٣/٤١٩) ١١٦٥٨- عن يحيى، قال: شهدتُ عمرَو بنَ عبيد ويونسَ بن عبيد يتناظران في المسجد الحرام في قول الله ﷿: <q>﴿وإن تبدوا ما في أنفسكم أو تخفوه يحاسبكم به الله﴾</q>، فقالا: قالتْ عائشةُ: كلُّ روعة تَمُرُّ بقلبِ ابن آدم تخوف من شيء لا يحل به فهو كفّارةٌ لكل ذنب هَمَّ به فلم يعمله{40}. (ز) ١١٦٥٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q> فذلك سرُّ أمرك وعلانيتك، <q>﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> فإنها لم تنسخ، ولكن الله إذا جمع الخلائق يوم القيامة يقول: إني أُخبركم بما أخفيتم في أنفسكم مما لم تطَّلع عليه ملائكتي، فأما المؤمنون [فيخبرهم ويغفر لهم ما حَدَّثوا به أنفسهم، وهو قوله: <q>﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>. يقول: يخبركم، وأما أهل الشك والريب]{41} فيخبرهم بما أخفوا من التكذيب، وهو قوله: <q>﴿ولَـٰكِن یُؤاخِذُكُم بِما كَسَبَتۡ قُلُوبُكُمۡۗ﴾</q> [البقرة:٢٢٥] [من الشك والنفاق]{42}]{43}. (٣/٤١٦) ١١٦٦٠- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال: فذلك سِرُّ عملِكم وعلانيتُه، يحاسبكم به الله، فليس من عبدٍ مؤمنٍ يُسِرُّ في نفسه خيرًا ليعمل به، فإن عمل به كتبت له به عشر حسنات، وإن هو لم يُقدَّر له أن يعمل به كتبت له به حسنة من أجل أنّه مؤمن، والله يرضى سِرَّ المؤمنين وعلانيتَهم، وإن كان سوءًا حدَّث به نفسه اطَّلع الله عليه وأخبره به يوم تُبْلى السرائر، وإن هو لم يعمل به لم يؤاخذه الله به حتى يعمل به، فإن هو عمل به تجاوز الله عنه، كما قال: <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ نَتَقَبَّلُ عَنۡهُمۡ أحۡسَنَ ما عَمِلُوا۟ ونَتَجاوَزُ عَن سَیِّـٔاتِهِمۡ﴾</q> [الأحقاف:١٦]{44}. (٣/٤١٧) ١١٦٦١- عن عبد الله بن عباس -من طريق الضحاك- في الآية، قال: إنّ الله يقول يوم القيامة: إنّ كُتّابي لم يكتبوا من أعمالكم إلا ما ظهر منها، فأمّا ما أسررتم في أنفسكم فأنا أُحسابكم به اليوم؛ فأغْفِرُ لِمَن شئتُ، وأُعَذِّب مَن شئتُ{45}. (٣/٤١٨) ١١٦٦٢- عن الضحاك، يقول في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>: كان ابن عباس يقول: إذا دُعِي الناس للحساب أخبرهم اللهُ بما كانوا يسرون في أنفسهم مِمّا لم يعملوه، فيقول: إنّه كان لا يعزب عَنِّي شيء، وإنِّي مخبركم بما كنتم تُسِرُّون من السوء، ولم تكن حَفَظَتُكُم عليكم يَطَّلِعون عليه. فهذه المحاسبة{45}. (ز) ١١٦٦٣- عن سعيد بن مرجانة: أنّه بينما هو جالس مع ابن عمر تلا هذه الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q> الآية. قال: واللهِ، لَئِن واخذنا الله بهذا لنهلكن. ثم بكى حتى سُمِع نَشِيجُه.= (ز) ١١٦٦٤- قال ابن مرجانة: فقمتُ حتى أتيتُ ابن عباس، فذكرت له ما قال ابن عمر، وما فعل حين تلاها، فقال ابن عباس: يغفرُ اللهُ لأبي عبد الرحمن، لَعَمْرِي لقد وجد المسلمون منها حين أُنزلت مثل ما وجد عبد الله بن عمر؛ فأنزل الله بعدها: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q> إلى آخر السورة. قال ابن عباس: فكانت هذه الوسوسة مما لا طاقة للمسلمين بها، وصار الأمر إلى أن قضى الله أنّ للنفس ما كسبت، وعليها ما اكتسبت من القول والعمل{47}. (٣/٤١٣) ١١٦٦٥- عن نافع، قال: لَقَلَّما أتى ابنُ عمر على هذه الآية إلّا بكى: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q> إلى آخر الآية. ويقول: إنّ هذا لَإحْصاء شديد{48}. (٣/٤١٤) ١١٦٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>، قال: من اليقين والشك{49}. (٣/٤١٧) ١١٦٦٧- عن الحسن البصري -من طريق عمرو بن عبيد- قال: هي مُحْكَمَةٌ، لم تُنسَخ{50}. (ز) ١١٦٦٨- عن الضحاك بن مزاحم: أنّها مُحْكَمَة{51}. (ز) ١١٦٦٩- قال محمد بن علي: معنى الآية: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</q> من الأعمال الظاهرة، <q>﴿أوۡ تُخۡفُوهُ﴾</q> من الأحوال الباطنة؛ <q>﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q> العابد على أفعاله، والعارف على أحواله{52}. (ز) ١١٦٧٠- عن الربيع بن أنس -من طريق أبي جعفر الرازي- في الآية، قال: هي مُحْكَمَة، لم ينسخها شيء، يُعَرِّفه الله يوم القيامة أنّك أخفيت في صدرك كذا وكذا، ولا يؤاخذه{53}١٠٨١. (٣/٤١٨) ١٠٨١ رجَّح ابنُ جرير (٥/١٤٤)، وابنُ عطية (٢/١٣٤)، وابنُ تيمية (١/٦١٧، ٦٢٤) أنّ الآية هنا محكمة غير منسوخة استنادًا إلى عدم التعارض، وذلك: أ) أنها خبر، والأخبار لا تُنسخ. ب) إمكان الجمع بينها وبين قوله تعالى: <q>﴿لا يُكَلِّفُ اللَّهُ نَفْسًا إلّا وُسْعَها﴾</q> بأوجه متعددة، منها: ١- أن المحاسبة على ما تخفيه النفس ليس مما في الوسع، وليس مما يُكسب أو يكتسب. ٢- أن المحاسبة لا يلزم منها المعاقبة، بل تكون محاسبة الله للمؤمنين فيما أخفوه إخبارهم به وغفرانه لهم؛ ليرَوا كبير فضل الله عليهم وعظيم إكرامه لهم. ٣- أنه لو لزم من المحاسبة المعاقبة لكانت المحاسبة مخصوصة بالكافرين الذين أخفوا في أنفسهم الشك في الله والكفر به. ووجَّه ابنُ تيمية القول بالنسخ، فقال: «النسخ في لسان السلف أعمُّ مما هو في لسان المتأخرين؛ يريدون به: رفع الدلالة مطلقًا، وإن كان تخصيصًا للعامِّ، أو تقييدًا للمطلق، وغير ذلك، ومَن قال مِن السلف: نسخها ما بعدها. فمرادُه: بيان معناها والمراد منها، وذلك يسمى نسخًا في لسان السلف، كما يسمون الاستثناء نسخًا». ١١٦٧١- قال جعفر بن محمد: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</q> يعني: الإسلام، <q>﴿أوۡ تُخۡفُوهُ﴾</q> يعني: الإيمان{54}. (ز) ١١٦٧٢- قال مقاتل بن سليمان: <q>﴿لِّلَّهِ ما فِی ٱلسَّمَـٰو ٰ⁠تِ وما فِی ٱلۡأرۡضِۗ﴾</q> من الخلق عبيده وفي ملكه، يقضي فيهم ما يريد، <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q> يقول: إن تعلنوا بألسنتكم ما في قلوبكم من ولاية الكفار والنصيحة أو تسروه <q>﴿یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>{55}. (ز) ١١٦٧٣- عن الواقدي، نحو قول مقاتل في قوله تعالى: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ﴾</q>{56}. (ز) <q>﴿فَیَغۡفِرُ لِمَن یَشَاۤءُ وَیُعَذِّبُ مَن یَشَاۤءُۗ﴾</q> - تفسير ١١٦٧٤- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ الله تجاوز لي عن أُمَّتِي ما حَدَّثت به أنفسَها، ما لم تتكلم أو تعمل به»{57}. (٣/٤١٥) ١١٦٧٥- عن عبد الله بن عباس -من طريق طاووس-: <q>﴿فَیَغۡفِرُ لِمَن یَشاۤءُ﴾</q> الذنبَ العظيمَ، <q>﴿ویُعَذِّبُ مَن یَشاۤءُۗ﴾</q> على الذنبِ الصغير{58}. (ز) ١١٦٧٦- عن قيس بن أبي حازم، قال: إذا كان يومُ القيامة قال اللهُ -تبارك وتعالى- يسمع الخلائق: إنما كان كُتّابي يكتبون عليكم ما ظهر منكم، فأمّا ما أسررتم فلم يكونوا يكتبونه، ولا يعلمونه، أنا الله أعلمُ بذلك كله منكم؛ فأغفر لمن شئت، وأُعَذِّب مَن شئت{45}. (ز) ١١٦٧٧- عن مجاهد بن جبر -من طريق منصور، أو ليث- في قوله: <q>﴿فَیَغۡفِرُ لِمَن یَشاۤءُ﴾</q> الآية، قال: يغفر لمن يشاء الكبيرَ من الذنوب، <q>﴿ویُعَذِّبُ مَن یَشاۤءُۗ﴾</q> على الصغير{60}. (٣/٤٢٠) ١١٦٧٨- عن سفيان الثوري، مثل ذلك{61}. (ز) ١١٦٧٩- عن سفيان -من طريق محمد بن يوسف- في قوله: <q>﴿فَیَغۡفِرُ لِمَن یَشاۤءُ﴾</q> قال: يغفر لمن يشاء بالكبير، <q>﴿ویُعَذِّبُ مَن یَشاۤءُۗ﴾</q> بالصغير{62}. (ز) <q>﴿وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ﴾</q> - تفسير ١١٦٨٠- قال مقاتل بن سليمان: <q>﴿وٱللَّهُ عَلىٰ كُلِّ شَیۡءࣲ﴾</q> من العذاب والمغفرة <q>﴿قَدِیرٌ﴾</q>{63}. (ز) ",footnotes:1:أخرجه مسلم ١/١١٦ (١٢٦).أخرجه الطبراني في مسند الشاميين ٣/٣٢٧ (٢٤١٥). وإسناده ضعيف؛ فيه عطاء بن أبي مسلم الخراساني، قال ابن حجر في التقريب (٤٦٣٣): «صدوق، يهِم كثيرًا، ويُرسِل، ويُدَلِّس». وقد عَنْعَنَ في إسناد هذا الحديث.أخرجه سعيد بن منصور في التفسير من سننه ٣/١٠٠٤ (٤٧٣)، وابن جرير ٥/١٢٩، وابن المنذر ١/٩٣ (١٦١)، وابن أبي حاتم ٢/٥٧٢ (٣٠٥٦). وإسناده ضعيف؛ فيه يزيد بن أبي زياد الكوفي، قال ابن حجر في التقريب (٧٧٦٨): «ضعيف، كبر فتغَيَّر، وصار يتلقن».أخرجه القاسم بن سلام في الناسخ والمنسوخ ص٢٧٤ (٥٠١)، وابن جرير ٥/١٣٠، وابن المنذر ١/٩٣ (١٦٣). وإسناده ضعيف أيضًا؛ فيه يزيد بن أبي زياد الكوفي، سبق في الحديث الذي قبله.عَلَّقه ابن أبي حاتم ٢/٥٧٢.أخرجه أبو عبيد في ناسخه من طريق حميد ص٢٧٤ (٥٠٣)، وابن جرير من طريق داود وعمرو أبي سعيد وجويبر واللفظ له ٥/١٢٩، ١٣٠، وابن المنذر من طريق داود (١٦٤). وعَلَّقه ابن أبي حاتم ٢/٥٧٢.أخرجه ابن جرير ٥/١٣١. وعلَّقه ابن أبي حاتم ٢/٥٧٢.أخرجه ابن المنذر ١/٩٨-٩٩ (١٧٣) مرسلًا.أخرجه سعيد بن منصور في سننه (٤٨٢)، وابن جرير ٥/١٣٥، والطبراني في الكبير (٩٠٣٠). وأخرجه أبو عبيد في ناسخه ص٢٧٥ (٥٠٦) من طريق قتادة بنحوه.أخرجه الترمذي (٢٩٩٠). وعَلَّقه ابن أبي حاتم ٢/٥٧٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه مسلم ١/١١٥ (١٢٥)، وابن جرير ٥/١٣٠، وابن المنذر ١/٩٦ (١٧٠)، وابن أبي حاتم ٢/٥٧٣ (٣٠٦٠).أخرجه ابن جرير ٥/١٣٨.عزاه السيوطي إلى أبي داود في ناسخه.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٢٤٦-، والطبراني في الكبير (١٢٢٩٦)، والبيهقي في الشعب (٣٢٨).أخرجه ابن أبي شيبة ١٤/٧، وابن جرير ٥/١٣٣-١٣٤، والنحاس في ناسخه ص٢٧٥-٢٧٦، والحاكم ٢/٢٨٧. وعلقه ابن أبي حاتم ٢/٥٧٤.أخرجه عبد الرزاق ١/٣٨١ (٣٧٤)، ومن طريقه أحمد ٥/١٩٤-١٩٥ (٣٠٧٠)، وابن جرير ٥/١٣٣، وابن المنذر ١/٩٦ (١٦٩). قال ابن منده في كتاب الإيمان (١٠٦): «إسناده صحيح على رسم الجماعة، إلا البخاري». وصحح إسنادَه ابنُ كثير في تفسيره ١/٧٣٠.أخرجه البخاري ٦/٣٣ (٤٥٤٥-٤٥٤٦).علَّقه ابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٤، وابن المنذر (١٧١)، وابن أبي حاتم ٢/٥٧٨.أخرجه ابن جرير٥/١٣٤. وعلَّقه ابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٤.أخرجه أبو عبيد في ناسخه ص٢٧٧ (٥١١). وعلَّقه ابن المنذر ١/٩٨، وابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٦.أخرجه ابن جرير ٥/١٣٥-١٣٦. وعلَّقه ابن أبي حاتم ٢/٥٧٤.أخرجه ابن جرير ٥/١٣٦.أخرجه ابن جرير ٥/١٣٥.أخرجه ابن جرير ٥/١٣٧. وعلَّقه ابن المنذر ١/٩٨ (عَقِب ١٧١).أخرجه عبد الرزاق ١/١١١، وابن جرير ٥/١٣٧. وعلَّقه ابن المنذر ١/٩٨ (عقِب ١٧١)، وابن أبي حاتم ٢/٥٧٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧١-.تفسير الثعلبي ٢/٣٠٠، وتفسير البغوي ١/٣٥٥، وزاد الثعلبي: عن موسى بن عبيدة، وشيبة.الناسخ والمنسوخ للزهري ص٢١-٢٢.أخرجه ابن جرير ٥/١٣٨ مرسلًا.تفسير مقاتل ١/٢٣١.أخرجه ابن جرير ٥/١٣٧. وهذا إسناد معضل؛ عبد الرحمن بن زيد بن أسلم من الطبقة الوسطى من أتباع التابعين، وهو ضعيف كما في التقريب (٣٨٩٠).معاتبة الله العبد: أي: مؤاخذته العبد بما اقترف من الذنب بما يصيبه في الدنيا. قال الطيبي: كأنها فهمت أن هذه المؤاخذة عقاب أخروي، فأجاب بأنها: مؤاخذة عتاب في الدنيا، عناية ورحمة. انظر تحفة الأحوذي ٤/٧٩.عند ابن المنذر: «في بيته». والضِّبن: الإبط وما يليه. لسان العرب (ضبن).التِّبر: الذهب. لسان العرب (تبر).الكِير: جلد غليظ يَنفُخُ فيه الحدّادُ. لسان العرب (كير).أخرجه أحمد ٤٣/٢٩ (٢٥٨٣٥)، والترمذي ٥/٢٤٥ (٣٢٣٤)، وابن جرير ٥/١٤٣ بلفظ: «متابعة الله»، وأيضًا ٧/٥٢٤ بلفظ: «مثابة الله»، وابن المنذر ١/٩٥ (١٦٧)، وابن أبي حاتم ٢/٥٧٤ (٣٠٦٢) بلفظ: «مبايعة الله». قال الترمذي: «حديث حسن غريب من حديث عائشة، لا نعرفه إلا من حديث حماد بن سلمة». وقال ابن كثير في تفسيره ١/٧٣٣: «علي بن زيد بن جدعان ضعيف، يُغْرِب في رواياته، وهو يروي هذا الحديث عن امرأة أبيه أُمِّ محمد أمية بنت عبد الله، عن عائشة، وليس لها عنها في الكتب سواه». وقال الهيثمي في المجمع ٧/١٢ (١٠٩٥٦): «رواه أحمد، وأمينة لم أعرفها». وقال الألباني في الضعيفة ٦/٤٧٣-٤٧٤: «إسناد ضعيف؛ فإنه مع ضعف ابن جدعان، لا يعرف حال أمية هذه».أخرجه سعيد بن منصور في سننه (٤٨١- تفسير)، وابن جرير ٥/١٤٢- ١٤٣، وفيه بلفظ: فكانت كفارته.أخرجه ابن عدي في الكامل ٦/١٨٤، وابن عساكر في تاريخ دمشق ٦٦/٣٠٤.ما بين المعقوفين ساقط من النسخة المحققة من الدر المنثور، وهو مثبت في تفسير ابن جرير، وابن المنذر، وابن أبي حاتم، كما أنه مثبت في الطبعات السابقة من الدر.[زيادة عند ابن جرير.أخرجه أبو عبيد في ناسخه ص٢٧٨ (٥١٢)، وابن جرير ٥/١٣٩، وابن المنذر (١٦٥)، وابن أبي حاتم ٢/٥٧٢، ٥٧٤، ٥٧٥.أخرجه ابن جرير ٥/١٣٩، وابن أبي حاتم ٢/٥٧٣.أخرجه ابن جرير ٥/١٤٠.أخرجه ابن جرير ٥/١٤٠.أخرجه ابن جرير ٥/١٣١-١٣٢، والطبراني في الكبير (١٠٧٧٠)، والبيهقي في الشعب (٣٢٩). وعزاه السيوطي إلى عبد بن حميد، وأبي داود في ناسخه.أخرجه ابن أبي شيبة في المصنف ١٣/٣٢٦، وأحمد في الزهد ص١٩٢، وابن أبي حاتم ٢/٥٧٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٢٤٧، وأخرجه أبو عبيد في ناسخه ص٢٧٤ (٥٠١)، وابن جرير ٥/١٤١، وابن المنذر (١٦٦)، وابن أبي حاتم ٢/٥٧٣، والنحاس في ناسخه ص٢٧٤. وعزاه السيوطي إلى عبد بن حميد، وأبي داود في ناسخه.أخرجه ابن جرير ٥/١٤١. وعلَّقه ابن أبي حاتم ٢/٥٧٤.عَلَّقه ابن أبي حاتم ٢/٥٧٤. وينظر: تفسير البغوي ١/٣٥٦.تفسير الثعلبي ٢/٣٠٢.أخرجه ابن جرير ٥/١٤٠، ١٤١، وابن أبي حاتم ٢/٥٧٢، ٥٧٤.تفسير الثعلبي ٢/٣٠١.تفسير مقاتل بن سليمان ١/٢٣١. وفي تفسير الثعلبي ٢/٢٩٩ عن مقاتل دون تعيينه.تفسير الثعلبي ٢/٢٩٩.أخرجه البخاري ٣/١٤٥ (٢٥٢٨)، ٧/٤٦ (٥٢٦٩)، ٨/٣٥ (٦٦٦٤)، ومسلم ١/١١٦ (١٢٧).تفسير الثعلبي ٢/٣٠٣، وتفسير البغوي ١/٣٥٦.أخرجه ابن جرير ٥/١٤٠.أخرجه ابن أبي حاتم ٢/٥٧٥.علَّقه ابن أبي حاتم ٢/٥٧٥.أخرجه ابن المنذر (١٧٢).تفسير مقاتل بن سليمان ١/٢٣١.
2,285," <q>﴿ءَامَنَ ٱلرَّسُولُ بِمَاۤ أُنزِلَ إِلَیۡهِ مِن رَّبِّهِۦ﴾</q> الآية - قراءات ١١٦٨١- عن يحيى بن يَعْمَر -من طريق إسحاق بن سويد-: أنه كان يقرأ: ›لا يُفَرِّقُ بَيْنَ أحَدٍ مِّن رُّسُلِهِ‹، يقول: كلٌّ آمن، وكلٌّ لا يُفَرِّقُ{1}١٠٨٢. (٣/٤٢٢) ١٠٨٢ ذكر ابنُ جرير (٥/١٥٠) أنّ المعنى على قراءة <q>﴿يُفَرِّقُ﴾</q>: أنّ المؤمنين لا يُفَرِّقون بين الرسل في الإيمان؛ فيؤمنون ببعض ويكفرون ببعض، بل يؤمنون بالجميع. ورجَّح القراءة بالنون <q>﴿نفرِّق﴾</q>. وانتَقَد القراءة بـ<q>﴿يُفَرِّقُ﴾</q>، فقال: «والقراءة التي لا نستجيز غيرها في ذلك عندنا بالنون <q>﴿لا نفرق بين أحد من رسله﴾</q>؛ لأنها القراءة التي قامت حجتها بالنقل المستفيض، الذي يمتنع معه التشاعر والتواطؤ والسهو والغلط، بمعنى ما وصفنا مِن: يقولون: لا نفرق بين أحد من رسله. ولا يُعترَض بشاذٍّ من القراءة، على ما جاءت به الحُجَّة نقلًا ووراثة». <q>﴿ءَامَنَ ٱلرَّسُولُ بِمَاۤ أُنزِلَ إِلَیۡهِ مِن رَّبِّهِۦ﴾</q> الآية - نزول الآية ١١٦٨٢- عن أنس -من طريق يحيى بن أبي كثير- قال: لَمّا نزلت هذه الآية على النبي ﷺ: <q>﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ﴾</q> قال النبيُّ ﷺ: «وحُقَّ له أن يُؤمن»{2}. (٣/٤٢١) ١١٦٨٣- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- قال: ذُكِر: أنّ النبي ﷺ لَمّا نزلت هذه الآية قال: «ويَحِقُّ له أن يُؤمن»{3}. (٣/٤٢١) ١١٦٨٤- عن حكيم بن جابر -من طريق بيان- قال: لما نزلت <q>﴿ءامَنَ ٱلرَّسُولُ﴾</q> الآيةَ؛ قال جبريلُ للنبيِّ ﷺ: إنّ الله قد أحسن الثناء عليكَ، وعلى أُمَّتِك، فسَلْ تُعْطَه. فسأل: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q> حتى ختم السورة بمسألة محمد ﷺ{4}. (٣/٤٢٢) ١١٦٨٥- عن مجاهد بن جبر، قال: لَمّا نزلت: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ﴾</q> الآيةَ؛ شَقَّ ذلك عليهم، قالوا: يا رسول الله، إنّا لَنُحَدِّث أنفسَنا بشيءٍ ما يَسُرُّنا أن يَطَّلِع عليه أحدٌ من الخلائق وأنّ لنا كذا وكذا. قال: «أوَقَدْ لَقِيُتم هذا؟ ذلك صريح الإيمان». فأنزل الله: <q>﴿ءامَنَ ٱلرَّسُولُ﴾</q> الآيتين{5}. (٣/٤٢٠) ١١٦٨٦- عن سعيد بن جبير، قال: لما نزلت هذه الآية قال المؤمنون: آمنّا بالله، وملائكته، وكتبه، ورسله{6}. (٣/٤٢٢) <q>﴿ءَامَنَ ٱلرَّسُولُ بِمَاۤ أُنزِلَ إِلَیۡهِ مِن رَّبِّهِۦ وَٱلۡمُؤۡمِنُونَۚ كُلٌّ ءَامَنَ بِٱللَّهِ وَمَلَـٰۤىِٕكَتِهِۦ وَكُتُبِهِۦ وَرُسُلِهِۦ﴾</q> - تفسير ١١٦٨٧- قال مقاتل بن سليمان: <q>﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ﴾</q>، يقول: صدَّق محمدٌ بما أُنزِل إليه مِن ربِّه من القرآن. ثم قال: <q>﴿وٱلۡمُؤۡمِنُونَۚ كُلٌّ ءامَنَ بِٱللَّهِ﴾</q> يقول: كُلٌّ صدَّق بالله بأنّه واحد لا شريك له، <q>﴿و﴾</q> صدَّق بـ<q>﴿ملائكته﴾</q> <q>﴿وكُتُبِهِۦ ورُسُلِهِۦ﴾</q>، يقول: لا يكفر بأحد من رسله، فكل هذه الرسل صدَّق بهم المؤمنون{7}. (ز) ١١٦٨٨- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قوله: <q>﴿ءامَنَ ٱلرَّسُولُ بِماۤ أُنزِلَ إلَیۡهِ مِن رَّبِّهِۦ وٱلۡمُؤۡمِنُونَۚ كُلٌّ ءامَنَ بِٱللَّهِ ومَلَـٰۤىِٕكَتِهِۦ وكُتُبِهِۦ﴾</q>: فهذا قولٌ قاله الله، وقولُ النبي ﷺ، وقولُ المؤمنين، فأثنى الله عليهم لما علم من إيمانهم بالله، وملائكته، وكتبه، ورسله{8}. (٣/٤٢٢) <q>﴿لَا نُفَرِّقُ بَیۡنَ أَحَدࣲ مِّن رُّسُلِهِۦۚ وَقَالُوا۟ سَمِعۡنَا وَأَطَعۡنَاۖ﴾</q> - تفسير ١١٦٨٩- قال مقاتل بن سليمان: <q>﴿لا نُفَرِّقُ بَیۡنَ أحَدࣲ مِّن رُّسُلِهِۦۚ﴾</q> كفعل أهل الكتاب، آمنوا ببعض الكتب وببعض الرسل، فذلك التفريق، فأمّا اليهود فآمنوا بموسى وبالتوراة، وكفروا بالإنجيل والقرآن، وأما النصارى فآمنوا بالتوراة والإنجيل وبعيسى ﷺ، وكفروا بمحمد ﷺ وبالقرآن. <q>﴿وقالُوا۟﴾</q> فقال المؤمنون بعد ذلك: <q>﴿سَمِعۡنا﴾</q> قول ربنا في القرآن، <q>﴿وأَطَعۡناۖ﴾</q> أمرَه{7}. (ز) ١١٦٩٠- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- <q>﴿لا نُفَرِّقُ بَیۡنَ أحَدࣲ مِّن رُّسُلِهِۦۚ﴾</q>: لا نكفر بما جاءت به الرسل، ولا نفرق بين أحد منهم، ولا نكذب به، <q>﴿وقالُوا۟ سَمِعۡنا﴾</q> للقرآن الذي جاء من الله، <q>﴿وأَطَعۡناۖ﴾</q> أقرُّوا أن يطيعوه في أمره ونهيه{10}. (٣/٤٢٢) ١١٦٩١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: <q>﴿لا نُفَرِّقُ بَیۡنَ أحَدࣲ مِّن رُّسُلِهِۦۚ﴾</q> كما صنع القوم –يعني: بني إسرائيل-، قالوا: فلان نبي، وفلان ليس نبيًّا، وفلان نؤمن به، وفلان لا نؤمن به{11}. (ز) <q>﴿غُفۡرَانَكَ رَبَّنَا وَإِلَیۡكَ ٱلۡمَصِیرُ﴾</q> - تفسير ١١٦٩٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿غُفۡرانَكَ رَبَّنا﴾</q> قال: قد غفرت لكم، <q>﴿وإلَیۡكَ ٱلۡمَصِیرُ﴾</q> قال: وإليك المرجع والمآب يوم الحساب{12}. (٣/٤٢٢) ١١٦٩٣- قال مقاتل بن سليمان: ثم قال لهم بعدما أقرُّوا بالنبيِّ ﷺ والكتب أن <q>﴿غُفۡرانَكَ رَبَّنا﴾</q>، يقول: قولوا: وأعطِنا مغفرةً منك، يا ربَّنا، <q>﴿وإلَیۡكَ ٱلۡمَصِیرُ﴾</q> يقول: المرجع إليك في الآخرة{13}. (ز) ١١٦٩٤- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- في قول الله: <q>﴿غُفۡرانَكَ رَبَّنا وإلَیۡكَ ٱلۡمَصِیرُ﴾</q>: تعليمٌ مِن الله، فهذا دعاءٌ دعا به النبيُّ ﷺ، فاستجاب له{14}. (ز) ",footnotes:1:أخرجه ابن المنذر (١٧٤)، وابن أبي حاتم ٢/٥٧٦ (٣٠٧٥). والقراءة المذكورة هي قراءة يعقوب من العشرة. انظر: النشر ٢/٢٣٧، وإتحاف فضلاء البشر ص٢١٤.أخرجه الحاكم ٢/٣١٥ (٣١٣٤)، والبيهقي في الشعب ٤/٦٧ (٢١٨٧) واللفظ له. قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع». وقال ابن حجر في إتحاف المهرة ٢/٣٨١ (١٩٤٣): «وقال الحاكم: صحيح الإسناد. قلت: بل منقطع». وقال السيوطي: «قال الذهبي: منقطع بين يحيى وأنس».أخرجه ابن جرير ٥/١٤٨، وابن أبي حاتم ٢/٥٧٦ (٣٠٧١) مرسلًا. قال السيوطي: «هذا شاهد لحديث أنس».أخرجه بن أبي شيبة ٦/٣٢٤ (٣١٧٧٥)، وسعيد بن منصور في التفسير من سننه ٣/١٠١٥ (٤٧٨)، وابن جرير ٥/١٥٢، وابن أبي حاتم ٢/٥٧٥ (٣٠٧٠) مرسلًا.أخرجه سعيد بن منصور ٣/١٠٠٥ (٤٧٤) مرسلًا. وأصل الحديث أخرجه مسلم ١/١١٩ (١٣٢) بدون ذكر الآية عن أبي هريرة، قال: جاء ناس من أصحاب النبي ﷺ، فسألوه: إنا نجد في أنفسنا ما يتعاظم أحدُنا أن يتكلم به. قال: «وقد وجدتموه؟». قالوا: نعم، قال: «ذاك صريح الإيمان».عزاه السيوطي إلى ابن أبي حاتم، وفي المطبوع من تفسيره ٢/٥٧٦ (٣٠٧٢) عن سعيد من طريق عطاء بن السائب بلفظ: كان ما قيل لهم، قولوا: آمنا. وينظر: النسخة المحققة المرقومة بالآلة الكاتبة ٣/١٢١٨.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٧٦، وابن المنذر (١٧٥) من طريق إسحاق عمن حدثه.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٧٦، ٥٧٧، وابن المنذر (١٧٥، ١٧٦) من طريق إسحاق عمن حدثه.أخرجه ابن جرير ٥/١٥٣.أخرجه ابن جرير ٥/١٦٨، وابن المنذر (١٧٧)، وابن أبي حاتم ٢/٥٧٧.تفسير مقاتل بن سليمان ١/٢٣٢.أخرجه ابن المنذر (١٧٩)، وابن أبي حاتم ٢/٥٧٧.
2,286," <q>﴿لَا یُكَلِّفُ ٱللَّهُ نَفۡسًا إِلَّا وُسۡعَهَاۚ﴾</q> - تفسير ١١٦٩٥- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، قال: هم المؤمنون، وسَّع اللهُ عليهم أمرَ دينهم، فقال: <q>﴿وما جَعَلَ عَلَیۡكُمۡ فِی ٱلدِّینِ مِنۡ حَرَجࣲۚ﴾</q> [الحج:٧٨]، وقال: <q>﴿یُرِیدُ ٱللَّهُ بِكُمُ ٱلۡیُسۡرَ ولا یُرِیدُ بِكُمُ ٱلۡعُسۡرَ﴾</q> [البقرة:١٨٥]، وقال: <q>﴿فَٱتَّقُوا۟ ٱللَّهَ ما ٱسۡتَطَعۡتُمۡ﴾</q> [التغابن:١٦]{1}. (٣/٤٢٣) ١١٦٩٦- عن عبد الله بن عباس -من طريق الزهري- قال: لَمّا نزلت ضَجَّ المؤمنون منها ضَجَّةً، وقالوا: يا رسول الله، هذا نتوبُ مِن عمل اليدِ والرجل واللسان، كيف نتوب مِن الوسوسة؟! كيف نمتنع منها؟! فجاء جبريلُ بهذه الآية: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، إنّكم لا تستطيعون أن تمتنعوا من الوسوسة{2}. (٣/٤٢٣) ١١٦٩٧- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿إلّا وُسۡعَهاۚ﴾</q>، قال: إلا طاقتها{3}. (٣/٤٢٤) ١١٦٩٨- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿إلّا وُسۡعَهاۚ﴾</q>، قال: إلا ما تُطِيق{4}. (٣/٤٢٤) ١١٦٩٩- عن عامر الشعبي -من طريق إسماعيل بن أبي خالد- <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>: إلا ما عملت لها{5}. (ز) ١١٧٠٠- عن محمد بن كعب القرظي -من طريق خالد بن زيد- <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، قال: فلم يُكَلَّفوا من العمل ما لم يُطِيقوا{5}. (ز) ١١٧٠١- عن أبي مالك= (ز) ١١٧٠٢- وقتادة بن دعامة= (ز) ١١٧٠٣- وزيد بن أسلم= (ز) ١١٧٠٤- ومقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{7}. (ز) ١١٧٠٥- عن معمر: أنّ عمر بن عبد العزيز كتب: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، مثله.= (ز) ١١٧٠٦- ومثله عن عطاء في الرجل لا يَجِدُ ما ينفق على أهله: ليس لها إلا ما وجَد{5}. (ز) ١١٧٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>: ووسعها: طاقتها، فكان حديث النفس مما لا يُطِيقون{9}. (ز) ١١٧٠٨- عن عطاء، نحوه{10}. (ز) ١١٧٠٩- قال مقاتل بن سليمان: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، يقول: لا يكلفها من العمل إلا ما أطاقت، ... فنَسَخَتْ هذه الآية قولَه سبحانه: <q>﴿وإن تُبۡدُوا۟ ما فِیۤ أنفُسِكُمۡ أوۡ تُخۡفُوهُ یُحاسِبۡكُم بِهِ ٱللَّهُۖ﴾</q>، قال النبيُّ ﷺ عند ذلك: «إنّ الله ﷿ تجاوز عن أُمَّتِي ما حَدَّثوا به أنفسَهم؛ ما لم يعملوه، أو يتكلموا به»{11}. (ز) ١١٧١٠- عن سفيان الثوري -من طريق فُضَيْل بن عِياض- في قوله: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، قال: أداء الفرائض{5}. (ز) ١١٧١١- عن سفيان [الثوري] -من طريق مِهْران- <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، قال: في شأن النفقة، إلا ما استطاعت{13}. (ز) ١١٧١٢- عن سفيان بن عيينة -من طريق عبد الجبّار بن العلاء العطّار- أنّه سُئِل عن قوله تعالى: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>. فقال: إلّا يُسْرَها، لا عسرها، ولم يكلّفها طاقتها، ولو كلّفها طاقتها لبلغ المجهود منها{14}. (ز) <q>﴿لَا یُكَلِّفُ ٱللَّهُ نَفۡسًا إِلَّا وُسۡعَهَاۚ﴾</q> - آثار متعلقة بالآية ١١٧١٣- عن عمران بن حصين قال: كانتْ بي بواسير، فسألتُ النبيَّ ﷺ عن الصلاة. فقال: «صلِّ قائمًا، فإن لم تستطع فقاعدًا، فإن لم تستطع فعلى جنب»{15}. (٣/٤٢٣) ١١٧١٤- عن همام، قال: سأل رجلٌ الحسنَ وأنا أسمع، فقال: رجل جعل على نفسه شيئًا في نذر وهو لا يجده؟ فقال الحسن: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>{13}. (ز) ١١٧١٥- عن ابن جريج، قال: قلت لعطاء [بن أبي رباح]: أيُكْرَه أن يقوم الرجل وحده وراء الصف؟ قال: نعم، والرجلان والثلاثة، إلا في الصفّ، فإنّ فيها فرجًا. قلت لعطاء: أرأيتَ إن وجدتُ الصفَّ مَدْحوسًا{17}، لا أرى فُرْجَةً، أقوم وراءهم؟ قال: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ﴾</q>، وأحبُّ إلَيَّ -واللهِ- أن أدخلَ فيه{18}. (ز) <q>﴿لَهَا مَا كَسَبَتۡ وَعَلَیۡهَا مَا ٱكۡتَسَبَتۡۗ﴾</q> - تفسير ١١٧١٦- عن عبد الله بن مسعود -من طريق قتادة- <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>، قال: ما كسبت مِن خير، وما اكتسبت مِن شَرٍّ{19}. (ز) ١١٧١٧- عن عبد الله بن عباس -من طريق الزهري، عن سعيد بن مَرْجانة- في قوله: <q>﴿لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q>، قال: من العمل{20}. (٣/٤٢٣) ١١٧١٨- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- قوله: <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ﴾</q> أي: من خير، <q>﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q> أي: مِن شرٍّ. أو قال: مِن سوء{21}. (ز) ١١٧١٩- عن محمد بن كعب القرظي -من طريق خالد بن زيد- قال: <q>﴿لَها ما كَسَبَتۡ﴾</q> من خير، <q>﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q> من شَرٍّ{22}. (٣/٤١٥) ١١٧٢٠- قال محمد ابن شهاب الزهري: <q>﴿لها ما كسبت وعليها ما اكتسبت﴾</q>، أي: لا يُكتب على أحدٍ إلا ما فعل وما عمِل{23}. (ز) ١١٧٢١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لَها ما كَسَبَتۡ﴾</q> يقول: ما عملت من خير، <q>﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q> يقول: وعليها ما عملت من شر{24}. (ز) ١١٧٢٢- قال مقاتل بن سليمان: <q>﴿لَها ما كَسَبَتۡ﴾</q> من الخير وما عملت أو تَكَلَّمَتْ به، <q>﴿وعَلَیۡها ما ٱكۡتَسَبَتۡۗ﴾</q> من الإثم{25}. (ز) ١١٧٢٣- عن عبد الملك ابن جريج -من طريق ابن ثور-: لها ما كسبت من الخير، وعليها ما اكتسبت من الشر لنفسها{26}. (ز) <q>﴿رَبَّنَا لَا تُؤَاخِذۡنَاۤ إِن نَّسِینَاۤ أَوۡ أَخۡطَأۡنَاۚ﴾</q> - تفسير ١١٧٢٤- عن أبي هريرة -من طريق العلاء بن عبد الرحمن، عن أبيه- <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>، قال: نعم{27}. (ز) ١١٧٢٥- عن عبد الله بن عباس -من طريق عطاء بن السائب، عن سعيد بن جبير- في قوله: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>، قال: لا أؤاخذكم{28}. (ز) ١١٧٢٦- عن سعيد بن جبير -من طريق عطاء بن السائب-، مثله{27}. (ز) ١١٧٢٧- عن أم الدرداء -من طريق أبي بكر الهُذَلِيّ، عن شَهْر-: عن النبي ﷺ: «إنّ الله تجاوز لأمتي عن ثلاث: عن الخطأ، والنسيان، والاستكراه». قال أبو بكر: فذكرت ذلك للحسن، فقال: أجل، أما تقرأ بذلك قرآنًا: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>{30}. (٣/٤٢٤) ١١٧٢٨- عن الحسن البصري -من طريق هشام- في قوله تعالى: <q>﴿إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>، قال: قال رسول الله ﷺ: «تجوَّز اللهُ لهذه الأمة عن الخطأ، والنسيان، وما أُكْرِهوا عليه»{31}. (ز) ١١٧٢٩- قال عطاء بن أبي رباح: <q>﴿إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>، يعني: إن جهلنا، أو تعمّدنا له{32}. (ز) ١١٧٣٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>، قال: بلغني: أنّ الرسول ﷺ قال: «إنّ الله -تبارك وتعالى- تجاوز لهذه الأمة على نسيانها، وما حدثت به أنفسها»{33}. (ز) ١١٧٣١- عن محمد بن كعب القرظي -من طريق خالد بن زيد- <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>: فوضع عنهم الخطأ، والنسيان{34}. (٣/٤١٥) ١١٧٣٢- عن إسماعيل السُّدِّيّ -من طريق أسباط-: أنّ هذه الآية حين نزلت <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q> قال له جبريل: إنّ الله فعل ذلك، يا محمد{35}. (٣/٤٢٦) ١١٧٣٣- قال محمد بن السائب الكلبي: كانت بنو إسرائيل إذا نسوا شيئًا مِمّا أُمروا به وأخطأوا عُجِّلَتْ لهم العقوبة، فيُحَرَّم عليهم شيءٌ من مطعم أو مشرب على حسب ذلك الذنب، فأمر الله تعالى نبيَّه والمؤمنين أن يسألوه تركَ مؤاخذتهم بذلك{32}. (ز) ١١٧٣٤- قال مقاتل بن سليمان: ثم علَّم جبريلُ النبيَّ ﷺ أن يقول: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>، يقول: إن جهلنا عن شيء، أو أخطأنا، فتَرَكَنْا أمرَك. قال الله ﷿: ذلك لك{11}. (ز) ١١٧٣٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q>: إن نسينا شيئًا مما افترضته علينا، أو أخطأنا شيئًا مما حرَّمته علينا {35}١٠٨٣. (ز) ١٠٨٣ بيَّن ابنُ جرير (٥/١٥٥-١٥٧) أنّ النسيان في الآية يحتمل معنيين: أحدهما: على وجه التفريط من العبد والتضييع. والآخر: على وجه العجز عن التَّذَكُّر. وأنّ الخطأ يحتمل معنيين: أحدهما: إتيان العبد ما نُهي عنه بقصد وإرادة. والآخر: ما كان فعله من العبد على وجه الجهل. ثم رجَّح مستندًا إلى الدلالة العقلية المعنى الأول في كلٍّ، مُعَلِّلًا ذلك بأنّ النسيان الناتج عن ضعف العقل والعجز، وكذا الخطأ غير المقصود؛ مِمّا قد وضعه الله عن العبد لخروجه عن مقدوره، فلا وجه لمسألة العبد ربه أن لا يؤاخذه به. وخالفه ابنُ عطية (٢/١٤٢-١٤٣)، فرجح مستندًا إلى الدلالة العقلية أنّ المراد بالنسيان والخطأ: النسيان الغالب، والخطأ غير المقصود. ونسبَه لكثيرٍ من العلماء، وبيَّن أن قول قتادة والسدي يفيد ظاهرهما ذلك، ثم علَّل ترجيحه بقوله: «وذلك أنّ المؤمنين لما كشف عنهم ما خافوه في قوله تعالى <q>﴿يحاسبكم به الله﴾</q> أُمِرُوا بالدعاء في دفع ذلك النوع الذي ليس من طاقة الإنسان دفعه، وذلك في النسيان والخطأ، والإصر: الثقل، وما لا يطاق على أتم أنواعه. وهذه الآية على هذا القول تقضي بجواز تكليف ما لا يطاق، ولذلك أُمِر المؤمنون بالدعاء في أن لا يقع هذا الجائز الصعب». <q>﴿رَبَّنَا لَا تُؤَاخِذۡنَاۤ إِن نَّسِینَاۤ أَوۡ أَخۡطَأۡنَاۚ﴾</q> - آثار متعلقة بالآية ١١٧٣٦- عن أبي ذرٍّ، قال: قال رسول الله ﷺ: «إنّ الله تجاوز لي عن أُمِّتي الخطأ، والنسيان، وما اسْتُكْرِهوا عليه»{39}. (٣/٤٢٤) ١١٧٣٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ الله تجاوز عن أمتي ما وسوست به صُدورُها، ما لم تعمل، أو تَكَلَّم به»{40}. (٣/٤٢٤) ١١٧٣٨- عن عقبة بن عامر، قال: قال رسول الله ﷺ: «وضع اللهُ عن أمتي الخطأَ، والنسيانَ، وما استكرهوا عليه»{41}. (٣/٤٢٥) ١١٧٣٩- عن الحسن، عن النبي ﷺ، قال: «تُجُوِّزَ لهذه الأمة الخطأ، والنسيان، وما استكرهوا عليه»{31}. (٣/٤٢٥) ١١٧٤٠- عن الحسن، قال: قال رسول الله ﷺ: «تجاوز اللهُ لابن آدم عمّا أخطأ، وعمّا نسي، وعمّا أُكره، وعمّا غُلب عليه»{43}. (٣/٤٢٦) ١١٧٤١- عن الشعبي، قال: قال رسول الله ﷺ: «إنّ الله تجاوز لأُمَّتِي عن ثلاث: عن الخطأ، والنسيان، والإكراه»{44}. (٣/٤٢٦) <q>﴿رَبَّنَا وَلَا تَحۡمِلۡ عَلَیۡنَاۤ إِصۡرࣰا كَمَا حَمَلۡتَهُۥ عَلَى ٱلَّذِینَ مِن قَبۡلِنَاۚ﴾</q> - تفسير ١١٧٤٢- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿إصۡرࣰا﴾</q>، قال: عهدًا{45}. (٣/٤٢٦) ١١٧٤٣- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>. قال: عهدًا، كما حملته على اليهود فمَسَخْتَهم قِرَدَةً وخنازير. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أبا طالب وهو يقول: أفي كل عام وافدٌ وصحيفةٌ يُشَدُّ بها أمرٌ وثيقٌ وأيْصُرُهْ{46}. (٣/٤٢٦) ١١٧٤٤- عن ابن سيرين، قال: قال: أبو هريرة لابن عباس: ما علينا مِن حرج أن نزني أو أن نسرق؟ قال: بلى. ولكن الإصر الذي علي بني إسرائيل وُضِع عنكم{47}. (ز) ١١٧٤٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قول الله ﷿: <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>، قال: لا أحمل عليكم{28}. (ز) ١١٧٤٦- عن سعيد بن جبير، مثله{49}. (ز) ١١٧٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وقيس بن الحضرمي- <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q>، قال: عَهْدًا{50}. (٣/٤٢٦) ١١٧٤٨- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿إصۡرࣰا﴾</q>، قال: المواثيق{51}. (ز) ١١٧٤٩- عن الحسن البصري= (ز) ١١٧٥٠- ومقاتل بن حيان -من طريق بُكَيْر بن معروف-، قالا: ميثاقًا{52}. (ز) ١١٧٥١- عن عطاء بن أبي رباح -من طريق ابن جريج- <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q>، قال: لا تمسخنا قِرَدَةً وخنازير{53}. (٣/٤٢٧) ١١٧٥٢- عن قتادة بن دعامة، في قوله: <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>، قال: كم من تشديدٍ كان على الذين من قبلنا، <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q> قال: كم مِن تخفيفٍ ويُسْرٍ وعافيةٍ في هذه الأُمَّة{54}. (٣/٤٢٧) ١١٧٥٣- عن قتادة بن دعامة -من طريق معمر بن راشد- في قوله: <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q>، قال: لا تحمل علينا عهدًا وميثاقًا، <q>﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q> يقول: كما غُلِّظ على مَن قبلنا{55}. (ز) ١١٧٥٤- عن محمد بن كعب القرظي -من طريق خالد بن زيد- قال: <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q> الآية، قال: فلم يُكَلَّفوا ما لم يُطِيقوا، ولم يحمل عليهم الإصْرَ الذي جعل على الأمم قبلهم، وعفا عنهم، وغفر لهم، ونصرهم{56}. (٣/٤١٥) ١١٧٥٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>: والإصْرُ: العهود التي كانت على مَن قبلنا مِن اليهود{57}. (ز) ١١٧٥٦- وعن مجاهد بن جبر= (ز) ١١٧٥٧- والضحاك بن مزاحم= (ز) ١١٧٥٨- وقتادة بن دعامة= (ز) ١١٧٥٩- ومحمد بن السائب الكلبي، نحو ذلك{58}. (ز) ١١٧٦٠- عن الربيع بن أنس -من طريق أبي جعفر الرازي- في قوله: <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q>، يقول: التشديد الذي شُدِّد به على مَن كان قبلنا من أهل الكتاب{47}. (٣/٤٢٧) ١١٧٦١- عن الربيع بن أنس -من طريق أبي جعفر الرازي-: الإصر: العهد، <q>﴿وأَخَذۡتُمۡ عَلىٰ ذَ ٰ⁠لِكُمۡ إصۡرِیۖ﴾</q> قال: عهدي{60}. (ز) ١١٧٦٢- قال مقاتل بن سليمان: ثم قال: <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q> يعني: عهدًا، <q>﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q> ما كان حُرِّمَ عليهم من لحوم الإبل، وشحوم الغنم، ولحوم كل ذي ظُفُر. يقول: لا تفعل ذلك بأُمَّتِي بذنوبها كما فعلته ببني إسرائيل، فجعلتهم قردة وخنازير. قال الله تعالى: ذلك لك{11}. (ز) ١١٧٦٣- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قوله: <q>﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>: كما حملته علي اليهود و النصارى فأهلكتهم{47}. (ز) ١١٧٦٤- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q> قال: عهدًا لا نطيقه ولا نستطيع القيام به، <q>﴿كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q> اليهود والنصارى، فلم يقوموا به، فأهلكتهم{63}. (٣/٤٢٧) ١١٧٦٥- عن الفضيل [بن عياض] -من طريق أبي يزيد فَيْض بن إسحاق الرَّقِّيِّ- في قوله: <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q>، قال: كان الرجلُ من بني إسرائيل إذا أذنب قيل له: توبتُك أن تقتل نفسك. فيقتل نفسه، فوُضِعَت الآصارُ عن هذه الأُمَّة{64}. (٣/٤٢٩) ١١٧٦٦- عن عبد الله بن وهب، قال: سألت -يعني: مالك [بن أنس]- عن قوله: <q>﴿ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا﴾</q>. قال: الإصر: الأمر الغليظ{65}. (ز) ١١٧٦٧- عن عبد الرحمن بن زيد بن أسلم -من طريق عبد الله بن وهْب- في قوله: <q>﴿وأَخَذۡتُمۡ عَلىٰ ذَ ٰ⁠لِكُمۡ إصۡرِیۖ﴾</q> [آل عمران: ٨١]، قال: عهدي{66}. (ز) ١١٧٦٨- عن عبد الرحمن بن زيد بن أسلم -من طريق عبد الله بن وهْب- في الآية، قال: لا تحمل علينا ذنبًا ليس فيه توبة ولا كفارة{53}١٠٨٤. (٣/٤٢٨) ١٠٨٤ جمع ابنُ عطية (٢/١٤٤) بين أقوال السلف الواردة في معنى الإصر بقوله: «والإصرة في اللغة: الأمر الرابط؛ من ذمام، أو قرابة، أو عهد ونحوه، فهذه العبارات كلها تنحو نحوه». <q>﴿رَبَّنَا وَلَا تَحۡمِلۡ عَلَیۡنَاۤ إِصۡرࣰا كَمَا حَمَلۡتَهُۥ عَلَى ٱلَّذِینَ مِن قَبۡلِنَاۚ﴾</q> - آثار متعلقة بالآية ١١٧٦٩- عن عبد الرحمن بن حسنة، أنّ النبي ﷺ قال: «إنّ بني إسرائيل كانوا إذا أصابهم البول قَرَضُوه{68} بالمَقارِيض{69}»{70}. (٣/٤٢٨) ١١٧٧٠- عن أبي موسى [الأشعري]، قال: كانت بنو إسرائيل إذا أصاب أحدَهم البولُ يَتْبَعُه بالمِقْراض{71}. (٣/٤٢٨) ١١٧٧١- عن عائشة، قالت: دخلتُ على امرأة من اليهود، فقالتْ: إنّ عذاب القبر من البول. قلتُ: كذبتِ. قالتْ: بلى. قالتْ: إنّه لَيُقْرَضُ منه الجلد والثوب. فأخبرتُ رسولَ الله ﷺ، فقال: «صَدَقَتْ»{72}. (٣/٤٢٨) <q>﴿رَبَّنَا وَلَا تُحَمِّلۡنَا مَا لَا طَاقَةَ لَنَا بِهِۦۖ﴾</q> - تفسير ١١٧٧٢- عن عبد الله بن عباس: <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، يعني: الوسوسة{73}. (ز) ١١٧٧٣- عن إبراهيم النخعي -من طريق سفيان الثوري، عن منصور- في قوله تعالى: <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: الحب{74}. (ز) ١١٧٧٤- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: لا تُحَمِّلْنا من الأعمال ما لا نطيق{66}. (٣/٤٢٩) ١١٧٧٥- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>: تشديد تُشَدِّد به، كما شدَّدت على مَن كان قبلنا{76}. (ز) ١١٧٧٦- عن قتادة بن دعامة، في قوله: <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: كم مِن تخفيفٍ ويُسْرٍ وعافية في هذه الأُمَّة{77}. (٣/٤٢٧) ١١٧٧٧- عن مكحول -من طريق ابن ثوبان، عن أبيه- <q>﴿ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: الغربة، والغُلْمَة{78}، والإنعاظ{79}١٠٨٥. (٣/٤٢٩) ١٠٨٥ نقل ابنُ القيم (١/٢١٤) في تفسير <q>﴿ما لا طاقة لنا به﴾</q> قولًا بأن المراد به: العشق، ووجَّهه بأنّ المعنى غير مختص به، بل يشمله وغيره، فقال: «فُسِّر ذلك بالعشق، وليس المراد اختصاصه به؛ بل المراد: أن العشق مما لا طاقة للعبد به. وقال مكحول: هو شدة الغُلْمَة. وقال النبي ﷺ: «لا ينبغي للمرء أن يُذِلَّ نفسه». قال الإمام أحمد: تفسيره أن يتعرض من البلاء لما لا يطيق. وهذا مطابق لحال العاشق، فإنه أذلُّ الناس لمعشوقه، ولما يحصل به رضاه، والحب مبناه على الذل والخضوع للمحبوب». ١١٧٧٨- عن إسماعيل السُّدِّيّ: <q>﴿ما لا طاقَةَ لَنا بِهِۦۖ﴾</q> من التغليظ والأغلال التي كانت عليهم من التحريم{80}. (٣/٤٢٩) ١١٧٧٩- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- في قول الله: <q>﴿ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>: مِن العذاب، فتجعلنا كما جعلتهم قردة وخنازير، وتعذبنا كما عذبتهم. فقال جبريل: قد فعل ذلك، واستجيب لكم{79}. (ز) ١١٧٨٠- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: مسخ القردة والخنازير{82}. (٣/٤٢٧) ١١٧٨١- قال عبد الرحمن بن زيد بن أسلم -من طريق عبد الله بن وهْب- في قوله: <q>﴿ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>: لا تَفْتَرِضْ علينا من الدين ما لا طاقة لنا به، فنعجز عنه{83}. (ز) ١١٧٨٢- عن قتادة بن دعامة= (ز) ١١٧٨٣- وإسماعيل السُّدِّيّ، نحوه{84}. (ز) ١١٧٨٤- عن سلام بن سابور{85} -من طريق محمد بن شعيب- <q>﴿ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: الغُلْمَة{83}. (٣/٤٢٩) <q>﴿رَبَّنَا وَلَا تُحَمِّلۡنَا مَا لَا طَاقَةَ لَنَا بِهِۦۖ﴾</q> - آثار متعلقة بالآية ١١٧٨٥- عن أبي هريرة -من طريق العلاء، عن أبيه- <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ﴾</q>، قال: نعم{47}. (ز) ١١٧٨٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قول الله -جل وعز-: <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q>، قال: لا أحمِّلكم ما لا طاقة لكم به{88}. (ز) ١١٧٨٧- عن عبد الله بن عباس= (ز) ١١٧٨٨- والضحاك بن مزاحم= (ز) ١١٧٨٩- ومحمد بن كعب القرظي= (ز) ١١٧٩٠- وإسماعيل السُّدِّيّ، قال: يقول الله ﷿: قد فعلت{89}. (ز) ١١٧٩١- قال سعيد بن جبير: لا أحمله عليكم{89}. (ز) <q>﴿وَٱعۡفُ عَنَّا وَٱغۡفِرۡ لَنَا وَٱرۡحَمۡنَاۤۚ أَنتَ مَوۡلَىٰنَا فَٱنصُرۡنَا عَلَى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</q> - تفسير ١١٧٩٢- عن مقاتل بن سليمان، قال: ثم قال: <q>﴿رَبَّنا ولا تُحَمِّلۡنا ما لا طاقَةَ لَنا بِهِۦۖ وٱعۡفُ﴾</q> يقول: واعف عنا من ذلك، <q>﴿وٱغۡفِرۡ لَنا﴾</q> يقول: وتجاوز عنا عن ذنوبنا من ذلك كله واغفر، <q>﴿وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</q> يقول: أنت ولينا، <q>﴿فَٱنصُرۡنا عَلى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</q> يعني: كفار مكة وغيرها إلى يوم القيامة، قال الله تعالى: ذلك لك. فاستجاب الله ﷿ له ذلك فيما سأل، وشَفَّعَه في أمته، وتجاوز لها عن الخطايا والنسيان وما اسْتُكْرِهوا عليه، فلمّا نزلت قرأهنَّ النبيُّ ﷺ على أُمَّتِه، وأعطاه الله ﷿ هذه الخصال كلها في الآخرة، ولم يُعْطِها أحدًا مِن الأمم الخالية{11}. (ز) ١١٧٩٣- عن مقاتل بن حيان، في قوله: <q>﴿وٱعۡفُ عَنّا﴾</q>، يقول: عافِنا من ذلك. ثم دعوا ربهم، فقالوا: <q>﴿وٱغۡفِرۡ لَنا وٱرۡحَمۡناۤۚ﴾</q> الآية. قال جبريل: قد فعل{92}. (ز) ١١٧٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق عبد الله بن وهب-: <q>﴿وٱعۡفُ عَنّا﴾</q> إن قَصَّرْنا عن شيء مِمّا أمرتنا به، <q>﴿وٱغۡفِرۡ لَنا﴾</q> إن انتهكنا شيئًا مما نهيتنا عنه، <q>﴿وٱرۡحَمۡناۤۚ﴾</q> يقول: لا ننال العمل بما أمرتنا به، ولا ترك ما نهيتنا عنه إلا برحمتك. قال: ولم ينجُ أحد إلا برحمته{93}. (٣/٤٢٩) <q>﴿وَٱعۡفُ عَنَّا وَٱغۡفِرۡ لَنَا وَٱرۡحَمۡنَاۤۚ أَنتَ مَوۡلَىٰنَا فَٱنصُرۡنَا عَلَى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</q> - آثار متعلقة بالآية ١١٧٩٥- عن أبي هريرة -من طريق عن العلاء بن عبد الرحمن، عن أبيه-: فأنزل الله: <q>﴿وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</q>، قال: نعم{94}. (ز) ١١٧٩٦- عن سعيد بن جبير، <q>﴿لا یُكَلِّفُ ٱللَّهُ نَفۡسًا إلّا وُسۡعَهاۚ لَها ما كَسَبَتۡ وعَلَیۡها ما ٱكۡتَسَبَتۡۗ رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ أوۡ أخۡطَأۡناۚ﴾</q> قال: يقول: قد فعلتُ، <q>﴿رَبَّنا ولا تَحۡمِلۡ عَلَیۡناۤ إصۡرࣰا كَما حَمَلۡتَهُۥ عَلى ٱلَّذِینَ مِن قَبۡلِناۚ﴾</q> قال: ويقول: قد فعلتُ. فأُعْطِيَت هذه الأمةُ خواتيمَ سورة البقرة، ولم تُعْطَها الأممُ قبلها{95}. (ز) ١١٧٩٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قول الله ﷿: <q>﴿وٱعۡفُ عَنّا وٱغۡفِرۡ لَنا وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</q> إلى آخر السورة، قال: قد عفوتُ عنكم، وغفرتُ لكم، ورحمتكم، ونصرتُكم على القوم الكافرين{96}. (ز) ١١٧٩٨- عن أبي هريرة= (ز) ١١٧٩٩- ومحمد بن كعب القرظي= (ز) ١١٨٠٠- وسعيد بن جبير، نحو ذلك في قوله: <q>﴿وٱعۡفُ عَنّا﴾</q>{97}. (ز) ١١٨٠١- عن أبي هريرة= (ز) ١١٨٠٢- وسعيد بن جبير= (ز) ١١٨٠٣- وإسماعيل السُّدِّيِّ= (ز) ١١٨٠٤- ومقاتل بن حيّان -من طريق بُكَيْر بن معروف-، نحو ذلك في قوله: <q>﴿وٱغۡفِرۡ لَنا﴾</q>{98}. (ز) ١١٨٠٥- عن سعيد بن جبير -من طريق عطاء بن السائب-، نحو ذلك في قوله: <q>﴿وٱرۡحَمۡناۤۚ أنتَ مَوۡلىٰنا﴾</q>{94}. (ز) ١١٨٠٦- عن إسماعيل السُّدِّيّ -من طريق أسباط-= (ز) ١١٨٠٧- وعطاء الخراساني= (ز) ١١٨٠٨- ومقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{100}. (ز) ١١٨٠٩- عن الضحاك بن مزاحم، قال: جاء بها جبريل ومعه من الملائكة ما شاء الله: <q>﴿ءامَنَ ٱلرَّسُولُ﴾</q> إلى قوله: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ﴾</q>، قال: ذلك لك. وهكذا عَقِب كلِّ كلمة{101}. (٣/٤٣٠) ١١٨١٠- عن الضحاك بن مزاحم، قال: أقرأ جبريلُ النبيَّ آخرَ سورة البقرة، فلما حفظها قال: اقرأها. فقرأها، فجعل كلما مرَّ بحرف قال: ذلك لك. حتى فرغ منها{102}. (٣/٤٣٠) ١١٨١١- قال الحسن البصري: هذا دعاءٌ أمر الله به النبيَّ ﷺ والمؤمنين، وقد أخبر اللهُ النبيَّ أنه قد غفر له{73}. (ز) ١١٨١٢- عن أبي ذرٍّ، قال: هي للنبي ﷺ خاصة{77}. (٣/٤٣٠) ١١٨١٣- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في هذه الآيات، قال: فإنّ جبريل ﵇ أقرأها نبيَّ الله ﷺ، فسألها نبيُّ اللهِ ربَّه، فأعطاه إيّاها، فكانت للنبيِّ ﷺ خاصة{105}. (٣/٤٣٠) ١١٨١٤- عن أبي ميسرة: أنّ جبريل لَقَّنَ رسول الله ﷺ عند خاتمة البقرة: آمين{106}. (٣/٤٣١) ١١٨١٥- عن معاذ بن جبل -من طريق أبي إسحاق-: أنّه كان إذا فرغ من قراءة هذه السورة: <q>﴿فَٱنصُرۡنا عَلى ٱلۡقَوۡمِ ٱلۡكَـٰفِرِینَ﴾</q>، قال: آمين{107}١٠٨٦. (٣/٤٣١) ١٠٨٦ علَّق ابنُ عطية (٢/١٤٥) على هذا الأثر بقوله: «هذا يُظَنَّ به أنه رواه عن النبي ﷺ، فإن كان ذلك فكمال، وإن كان بقياس على سورة الحمد من حيث هناك دعاء وهنا دعاء، فحَسَنٌ». ١١٨١٦- عن جُبَيْر بن نُفَيْر: أنّه كان إذا قرأ خاتمة البقرة يقول: آمين{108}. (٣/٤٣١) ١١٨١٧- عن عطاء بن أبي رباح، قال: لَمّا نزلت هذه الآيات: <q>﴿رَبَّنا لا تُؤاخِذۡناۤ إن نَّسِیناۤ﴾</q> فكُلَّما قالها جبريلُ للنبي ﷺ قال النبيُّ ﷺ: «آمين، رب العالمين»{44}. (٣/٤٣٠) ",footnotes:1:أخرجه ابن جرير ٥/١٥٣، وابن المنذر (١٨٠)، وابن أبي حاتم ٢/٥٧٧.أخرجه ابن جرير ٥/١٥٣.أخرجه ابن أبي حاتم ٦/٢٦.أخرجه ابن المنذر (١٨١).أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن أبي حاتم ٢/٥٧٨ عن مقاتل، وعلَّقه عن الباقين.أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن جرير ٥/١٥٤. وعلَّقه ابن أبي حاتم ٢/٥٧٨.تفسير الثعلبي ٢/٣٠٦، وتفسير البغوي ١/٣٥٧.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٧٨.أخرجه ابن أبي حاتم ٢/٥٧٧.أخرجه الثعلبي ٢/٣٠٦. وذكره البغوي ١/٣٥٧.أخرجه البخاري ٢/٤٨ (١١١٧).أخرجه ابن أبي حاتم ٢/٥٧٧.أي: ممتلئ. لسان العرب (دحس).أخرجه عبد الرزاق في مصنفه ٢/٥٨-٥٩ (٢٤٨١).أخرجه أبو عبيد في ناسخه ص٢٧٦ (٥٠٦).أخرجه ابن أبي حاتم ٢/٥٧٨-٥٧٩، وعند ابن جرير ٥/١٥٤ من طريق الزهري عن ابن عباس بلفظ: عمل اليد، والرجل، واللِّسان.أخرجه ابن جرير ٥/١٥٤.أخرجه ابن المنذر (١٨٣)، وابن أبي حاتم ٢/٥٧٨-٥٧٩. وعزاه الحافظ ابن حجر في العجاب في بيان الأسباب ١/٥٦٣ والسيوطي إلى الفريابي، وعبد بن حميد.الناسخ والمنسوخ للزهري ص٢١-٢٢.أخرجه ابن جرير ٥/١٥٤. وعلَّقه ابن المنذر ١/١٠٢ (عَقِب ١٨٤).تفسير مقاتل بن سليمان ١/٢٣١-٢٣٢.أخرجه ابن المنذر (١٨٤).أخرجه ابن أبي حاتم ٢/٥٧٩.أخرجه ابن جرير ٥/١٦٨، وابن أبي حاتم ٢/٥٧٩.أخرجه ابن أبي حاتم ٢/٥٧٩.أخرجه ابن أبي حاتم ٢/٥٧٩ (٣٠٩٢). قال ابن القيسراني في ذخيرة الحفاظ ١/٥٧٤ (٩٣٣): «رواه (سلمى بن عبد الله) أبو بكر الهذلي: عن شهر بن حوشب، عن أم الدرداء، عن أبي الدرداء. والهذلي هذا متروك الحديث». وقال ابن الملقن في البدر المنير ٤/١٨٢: «رواه الطبراني، وفيه شهر».أخرجه عبد الرزاق في مصنفه ٦/٤٠٩ (١١٤١٦)، وفي تفسيره ١/٣٧٨ (٣٦٧)، وسعيد بن منصور في سننه ١/٣١٧ (١١٤٥). نقله ابن الملقن في البدر المنير ٤/١٨٣ بنحوه، وقال: «رواه سعيد بن منصور مرسلًا». وقال المتقي الهندي في كنز العمال ١٢/١٧٤ (٣٤٥٤٢): «عبد الرزاق عن الحسن مرسلًا».تفسير الثعلبي ٢/٣٠٧، وتفسير البغوي ١/٣٥٧.أخرجه عبد الرزاق في تفسيره ١/١٧٩ (٣٦٨)، وابن جرير ٥/١٥٥ مرسلًا. وقد ورد ما يشهد له من طُرُق أخرى موصولًا.أخرجه ابن المنذر (١٨٣). وعزاه الحافظ ابن حجر في العجاب في بيان الأسباب ١/٥٦٣ والسيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ٥/١٥٥.تفسير الثعلبي ٢/٣٠٧، وتفسير البغوي ١/٣٥٧.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن جرير ٥/١٥٥.أخرجه ابن ماجه ٣/٢٠٠ (٢٠٤٣). قال البوصيري في مصباح الزجاجة ٢/١٢٥ (٧٢٧): «هذا إسناد ضعيف». وقال ابن رجب في جامع العلوم والحكم ٢/٣٦٤: «وأبو بكر الهذلي متروك الحديث». وقال ابن الملقن في البدر المنير ٤/١٨٢: «في إسناده شهر بن حوشب، وقد تركوه؛ أي: طعنوا فيه». وقال ابن حجر في التلخيص الحبير ١/٦٧٣: «ورواه ابن ماجه من حديث أبي ذر، وفيه شهر بن حوشب، وفي الإسناد انقطاع أيضًا. ورواه الطبراني من حديث أبي الدرداء، ومن حديث ثوبان، وفي إسنادهما ضعف ...».أخرجه البخاري ٣/١٤٥ (٢٥٢٨)، ٧/٤٦ (٥٢٦٩)، ٨/١٣٥ (٦٦٦٤)، ومسلم ١/١١٦ (١٢٧).أخرجه الطبراني في الأوسط ٨/١٦١ (٨٢٧٦)، والبيهقي في الكبرى ٧/٥٨٤ (١٥٠٩٦) واللفظ له. قال الطبراني: «ولا روى حديث عقبة بن عامر إلا موسى بن وردان، ولا رواه عن موسى إلا ابن لهيعة، تفرد به الوليد». ونقل ابن الملقن في البدر المنير ٤/١٨٠ عن ابن أبي حاتم في العلل عن أبيه أنّه قال: «وحديث الوليد أيضًا عن ابن لهيعة، عن موسى بن وردان، عن عقبة بن عامر مرفوعًا مثله، فقال: هذه أحاديث منكرة كأنها موضوعة». وقال الهيثمي في المجمع ٦/٢٥٠ (١٠٥٠٢): «وفيه ابن لهيعة، وحديثه حسن، وفيه ضعف».أخرجه عبد الرزاق في مصنفه ٦/٤٠٩ (١١٤١٦)، وفي تفسيره ١/٣٧٨ (٣٦٧)، وسعيد بن منصور في سننه ١/٣١٧ (١١٤٥). نقله ابن الملقن في البدر المنير ٤/١٨٣ بنحوه، وقال: «رواه سعيد بن منصور مرسلًا». وقال المتقي الهندي في كنز العمال ١٢/١٧٤ (٣٤٥٤٢): «عبد الرزاق عن الحسن مرسلًا».أخرجه سعيد بن منصور في سننه ١/٣١٧ (١١٤٦).عزاه السيوطي إلى عبد بن حميد مرسلًا.أخرجه ابن جرير ٥/١٥٩، وابن المنذر (١٨٧)، وابن أبي حاتم ٢/٥٨٠ من طريق الضحاك.عزاه السيوطي إلى الطَّستيِّ. والأيصر: الحبل الصغير الذي يُشد به أسفل الخباء. القاموس المحيط (أصر).أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن جرير ٥/١٦٨، وابن أبي حاتم ٢/٥٧٩.عَلَّقه ابن أبي حاتم ٢/٥٧٩.أخرجه ابن جرير ٥/١٦٨. وعلَّقه ابن أبي حاتم ٢/٥٨٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/١٥٩، وابن المنذر (١٩٠) بلفظ: «من الميثاق ما حملتهم»، وابن أبي حاتم ٢/٥٨٠.أخرجه ابن أبي حاتم ٢/٥٨٠ عن مقاتل، وعلَّقه عن الحسن.أخرجه ابن جرير ٥/١٦٠.عزاه السيوطي إلى عَبد بن حُميد.أخرجه عبد الرزاق ١/١١٢، وابن جرير ٥/١٥٨، وابن المنذر (١٨٨).عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر تبعًا لأول الأثر في أول الآية، ولم نجد هذه التتمة في المطبوع من ابن المنذر، أو فيما نقله الحافظ في العجاب.أخرجه ابن جرير ٥/١٥٩، وابن أبي حاتم ٢/٥٨٠.تفسير الثعلبي ٢/٣٠٧، وتفسير البغوي ١/٣٥٨ دون الضحاك.أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن جرير ٥/١٥٩.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن جرير ٥/١٥٩، وأخرج ابن المنذر (١٩١) الشطر الثاني من طريق ابن ثور.أخرجه ابن أبي حاتم ٢/٥٨٠ (٣١٠١).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٣٤ (٢٦٧)، وابن جرير ٥/١٦١.أخرجه ابن جرير ٥/١٦١.أخرجه ابن جرير ٥/١٦٠.القَرْض: القطع. لسان العرب (قرض).المقاريض: جمع مِقْراض، وهو المقص. المعجم الوسيط (قرض).أخرجه أبو داود ١/١٨ (٢٢)، والنسائي ١/٢٦ (٣٠)، وابن ماجه ١/٢٢٨ (٣٤٦)، والحاكم ١/٢٩٤ (٦٥٧-٦٥٨)، وأحمد ٢٩/٢٩٣ (١٧٧٥٨)، ٢٩/٢٩٤ (١٧٧٦٠) بألفاظ متقاربة. قال الحاكم: «هذا حديث صحيح الإسناد». وقال الذهبي في التلخيص: «على شرطهما». وقال الألباني في صحيح أبي داود ١/٥٠ (١٦): «إسناده صحيح على شرط البخاري، وصححه الحاكم والذهبي على شرطهما، وهو كما قالا».أخرجه أحمد ٣٨/٤٢٠ (٢٣٤٢٢) موقوفًا، وأيضًا ٣٢/٣٣٩ (١٩٥٦٨) مرفوعًا، وهو في البخاري ١/٥٥ (٢٢٦)، ومسلم ١/٢٢٨ (٢٧٣) عن أبي موسى بنحوه.أخرجه النسائي ٣/٧٢ (١٣٤٥)، وابن أبي شيبة ١/١١٥ (١٣٠٧)، وأحمد ٤٠/٣٨٠ (٢٤٣٢٤). إسناده ضعيف؛ فيه جَسْرَة، وهي بنت دَجاجَة. قال البخاري في التاريخ الكبير ٢/٦٧: «عندها عجائب». وقال الألباني في الإرواء ١/٣١٢: «هذا الحديث في الصحيح، دون قول اليهودية:»إن عذاب القبر من البول«، وقوله ﷺ: «صدقت». فهذا يدل على ضعف جسرة، وصحة حكم البخاري على أحاديثها».ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٢-.أخرجه الثعلبي ٢/٣٠٨. تفسير البغوي ١/٣٥٨.أخرجه ابن جرير ٥/١٦١.أخرجه ابن جرير ٥/١٦١، وعبد الرزاق ١/١٢١ من طريق معمر بمعناه.عزاه السيوطي إلى عَبد بن حُمَيد.الغلمة: شهوة النكاح من الرجال والنساء. جمهرة اللغة (غلم).أخرجه ابن أبي حاتم ٢/٥٨١.أخرجه ابن جرير ٥/١٦٢، وابن المنذر (١٩٣)، وابن أبي حاتم ٢/٥٨١.أخرجه ابن أبي حاتم ٢/٥٨١.أخرجه ابن جرير ٥/١٦٢، وابن المنذر (١٩٤) من طريق ابن ثور. وعلَّقه ابن أبي حاتم ٢/٥٨١.أخرجه ابن جرير ٥/١٦٢.تفسير الثعلبي ٢/٣٠٨.لم نقف على ترجمته.أخرجه ابن جرير ٥/١٦٢.أخرجه ابن أبي حاتم ٢/٥٨٠.أخرجه ابن المنذر (١٨٦).علَّقه ابن أبي حاتم ٢/٥٨٠.علَّقه ابن أبي حاتم ٢/٥٨٠.تفسير مقاتل بن سليمان ١/٢٣١.أخرجه ابن المنذر (١٩٥) من طريق إسحاق عمَّن حدثه، وابن أبي حاتم ٢/٥٨١ مختصرًا من طريق بُكَيْر بن معروف.أخرجه ابن جرير ٥/١٦٤-١٦٥.أخرجه ابن أبي حاتم ٢/٥٨٢.أخرجه ابن جرير ٥/١٦٩.أخرجه ابن جرير ٥/١٦٨، وابن المنذر (١٨٦)، وابن أبي حاتم ٢/٥٨١-٥٨٢.علَّقه ابن أبي حاتم ٢/٥٨٢.أخرجه ابن أبي حاتم ٢/٥٨٢ عن مقاتل، وعلَّقه عن الباقين.أخرجه ابن أبي حاتم ٢/٥٨٢.أخرجه ابن أبي حاتم ٢/٥٨٢ عن السُّدِّي ومقاتل، وعلَّقه عن عطاء.أخرجه سعيد بن منصور في سننه (٤٨٣-تفسير)، والبيهقي في شعب الإيمان (٢٤١٠).عزاه السيوطي إلى سفيان بن عيينة، وعَبد بن حُمَيد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٢-.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٦٨-١٦٩.أخرجه أبو عبيد في فضائل القرآن ١/٢٣٣، عن ابن أبي مريم، عن ابن لهيعة، عن يزيد بن أبي حبيب، عن أبي إسحاق، عن أبي ميسرة به مرسلًا. وهذا على إرساله ضعيف، أبو ميسرة اسمه عمرو بن شرحبيل الهمداني الكوفي، وهو من كبار التابعين، ثقة عابد مخضرم كما في التقريب (٥٠٨٣). وفي إسناده أيضًا عبد الله بن لهيعة صدوق اختلط بعد احتراق كتبه كما في التقريب (٣٥٨٧). والراوي عنه أبو بكر بن عبد الله بن أبي مريم قال عنه ابن حجر في التقريب (٨٠٣١): «ضعيف، وكان قد سُرِق بيته فاختلط».أخرجه أبو عبيد ص١٢٥، وابن أبي شيبة ٢/٤٢٦، وابن جرير ٥/١٦٩، وابن المنذر (١٩٦). كما أخرجه وكيع -كما في تفسير ابن كثير ١/٧٤٢- من طريق أبي إسحاق، عن رجل.أخرجه أبو عبيد ص١٢٥.عزاه السيوطي إلى عبد بن حميد مرسلًا.
