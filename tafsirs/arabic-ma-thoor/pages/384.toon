quran[12]{c,v,t}:
  27,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَهُدࣰى وَرَحۡمَةࣱ لِّلۡمُؤۡمِنِینَ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٧٩١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>- من طريق عطاء بن دينار- <span class="qpc-hafs">﴿لَهُدًى﴾</span>: يعني: تِبيانًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٧٩٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق بيان- <span class="qpc-hafs">﴿لَهُدًى﴾</span>، قال: هُدًى مِن الضلالة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٧٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لَهُدًى﴾</span>، قال: نور{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنه لهدى﴾</span> مِن الضلالة، <span class="qpc-hafs">﴿ورحمة﴾</span> مِن العذاب لِمَن آمن به، فذلك قوله ﷿: <span class="qpc-hafs">﴿للمؤمنين﴾</span> بالقرآن أنّه مِن ربك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٧٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإنه لهدى ورحمة للمؤمنين﴾</span> هدًى يهتدون به إلى الجنة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَهُدࣰى وَرَحۡمَةࣱ لِّلۡمُؤۡمِنِینَ ۝٧٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٧٩٦<span class="dash">-</span></span> عن علي بن أبي طالب، قال: قيل لرسول الله ﷺ: إنّ أُمَّتك ستُفْتَتَن مِن بعدك. فسأل رسول الله ﷺ أو سئل: ما المخرج منها؟ فقال: «<b>كتاب الله العزيز، الذي لا يأتيه الباطل مِن بين يديه ولا من خلفه، تنزيل من حكيم حميد، مَن ابتغى العلم في غيره أضلَّه الله، ومَن ولي هذا الأمر فحَكَم بِه عَصَمَه الله، وهو الذِّكر الحكيم، والنور المبين، والصراط المستقيم، فيه خبر مَن قبلكم، ونبأ مَن بعدكم، وحكم ما بينكم، وهو الفصل ليس بالهزل</b>»{6}. (١١/٣٩٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢٠.أخرجه ابن أبي حاتم ٩/٢٩١٩.أخرجه ابن أبي حاتم ٩/٢٩٢٠.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٣.أخرجه الترمذي ٥/١٧١-١٧٢ (٣١٣٠)، والدارمي ٢/٥٢٧ (٣٣٣٢) واللفظ له.</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا مِن هذا الوجه، وإسناده مجهول، وفي الحارث مقال». قال ابن كثير في تفسيره ١/٢١: «وقصارى هذا الحديث أن يكون مِن كلام أمير المؤمنين علي ﵁، وقد وهم بعضهم في رفعه، وهو كلام حسن صحيح؛ على أنه قد روي له شاهد عن عبد الله بن مسعود ﵁ عن النبي ﷺ». وأورده الفتني في تذكرة الموضوعات ص٧٦. وقال الألباني في الضعيفة ١٣/٨٨٣ (٦٣٩٣): «ضعيف».
  27,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ یَقۡضِی بَیۡنَهُم بِحُكۡمِهِۦۚ وَهُوَ ٱلۡعَزِیزُ ٱلۡعَلِیمُ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٧٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن ربك يقضي بينهم﴾</span> يعني: بين بني إسرائيل <span class="qpc-hafs">﴿بحكمه وهو العزيز العليم﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٧٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إن ربك يقضي بينهم بحكمه﴾</span> بين المؤمنين والكافرين في الآخرة، فيدخل المؤمنين الجنة، ويدخل الكافرين النار، <span class="qpc-hafs">﴿وهو العزيز العليم﴾</span> لا أعزَّ منه، ولا أعلم منه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٣-٥٦٤.
  27,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَكَّلۡ عَلَى ٱللَّهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٧٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتوكل على الله﴾</span> يعني: فثِق بالله ﷿، وذلك حين دعا إلى مِلَّة آبائه، فأمره أن يثِق بالله ﷿، ولا يهوله قول أهل مكة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّكَ عَلَى ٱلۡحَقِّ ٱلۡمُبِینِ ۝٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٠٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: الإسلام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنك على الحق المبين﴾</span>، يعني: على الدين البيِّن، وهو الإسلام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إنك على الحق المبين﴾</span> البيِّن{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٦.علَّقه يحيى بن سلام ٢/٥٦٤.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٤.
  27,80,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّكَ لَا تُسۡمِعُ ٱلۡمَوۡتَىٰ وَلَا تُسۡمِعُ ٱلصُّمَّ ٱلدُّعَاۤءَ إِذَا وَلَّوۡا۟ مُدۡبِرِینَ ۝٨٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٠٣<span class="dash">-</span></span> عن إسماعيل بن مسلم، قال: سألتُ <span class="name-2">الحسنَ البصري</span> عن هذا الحرف. فقال: ‹ولا يَسْمَعُ الصُّمُّ الدُّعاءَ إذا ولَّوْاْ مُدْبِرِينَ›{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّكَ لَا تُسۡمِعُ ٱلۡمَوۡتَىٰ وَلَا تُسۡمِعُ ٱلصُّمَّ ٱلدُّعَاۤءَ إِذَا وَلَّوۡا۟ مُدۡبِرِینَ ۝٨٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٠٤<span class="dash">-</span></span> عن عروة بن الزبير، قال: ذُكِر عند <span class="name-1">عائشة</span> أنّ ابن عمر يرفع إلى النبي ﷺ: «<b>إنّ الميت يُعذَّب في قبره ببكاء أهله عليه</b>». فقالت: وهِلَ{2}، إنما قال رسول الله ﷺ: «<b>إنه لَيعذب بخطيئته أو بذنبه، وإن أهله ليبكون عليه الآن</b>». وذاك مثل قوله: إنّ رسول الله ﷺ قام على القليب يوم بدر، وفيه قتلى بدر مِن المشركين، فقال لهم ما قال: «<b>إنهم ليسمعون ما أقول</b>». وقد وهِلَ، إنما قال: «<b>إنهم ليعلمون أن ماكنت أقول لهم حق</b>». ثم قرأت: <span class="qpc-hafs">﴿إنك لا تسمع الموتى﴾</span>، <span class="qpc-hafs">﴿وما أنت بمسمع من في القبور﴾</span> [فاطر:٢٢]، يقول: حين تَبَوَّءُوا مقاعدهم مِن النار{3}<span class=comment-ref>٤٩٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٣</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٥٥٧-٥٥٨ بتصرف): «احتجَّتْ عائشة ﵂ في إنكارها أنّ النبي ﷺ أسمع موتى بدر بهذه الآية، ونظرت هي في الأمر بقياس عقليٍّ، ووقفت مع هذه الآية، وقد صحَّ أن النبيَّ ﷺ قال: «<b>ما أنتم بأسمع منهم</b>». فيشبه أنّ قصة بدر هي خرق عادة لمحمد ﵇ في أن رد الله إليهم إدراكًا سمعوا به مقالة، ولولا إخبار رسول الله ﷺ بسماعهم لحملنا نداءه إياهم على معنى التوبيخ لِمَن بقي من الكفرة، وعلى معنى شفاء صدور المؤمنين منهم. وقد عُورِضت هذه الآية بالسلام على القبور، وبما رُوي في ذلك من أنّ الأرواح تكون على شفير القبور في أوقات، قالوا: فلو لم يسمع الميت لم يسلم عليه. قال القاضي أبو محمد: وهذا كله غير مُعارِض للآية؛ لأن السلام على القبور إنما هو عبادة، وعند الله الثواب عليها، وهو تذكير للنفس بحالة الموت وبحالة الموتى في حياتهم، وإن جوَّزنا مع هذا أنّ الأرواح في وقت على القبور؛ فإن سَمِع فليس الروح بميت، وإنما المراد بقوله: <span class="qpc-hafs">﴿إنك لا تسمع الموتى﴾</span> الأشخاص الموجودة مفارقة لأرواحها، وفيها نقول: خرقت العادة لمحمد ﵇ في أهل القليب. وذلك <span class="mustanad">كنحو قوله</span> ﷺ في الموتى إذا دخل عليهم الملَكان: «<b>إنهم يسمعون خَفْق النِّعال</b>»».</div></p><p><div></p><p><p><span class="item-no">٥٧٨٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنك لا تسمع الموتى﴾</span> قال: هذا مَثَلٌ ضربه الله للكافر، كما لا يسمع الميِّت، كذلك لا يسمع الكافر ولا ينتفع به، <span class="qpc-hafs">﴿ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</span> يقول: لو أنّ أصم ولّى مُدْبِرًا ثم ناديته لم يسمع، كذلك الكافر لا يسمع ولا ينتفع بما يسمع{4}. (١١/٣٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٠٦<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله ﷿: <span class="qpc-hafs">﴿إنك لا تسمع الموتى﴾</span>، يعني: الكفار؛ لأنهم بمنزلة الأموات في سمع الإيمان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ضرب لكفار مكة مثلًا، فقال سبحانه: <span class="qpc-hafs">﴿إنك﴾</span> يا محمد <span class="qpc-hafs">﴿لا تسمع الموتى﴾</span> في النِّداء، فشبَّه كفار مكة بالأموات، كما لا يسمع الميت النداء كذلك لا تسمع الكفار النداء ولا تفقهه، <span class="qpc-hafs">﴿ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</span> يقول: إنّ الأصم إذا ولّى مُدبِرًا ثم ناديته لم يسمع الدعاء، وكذلك الكافر لا يسمع الإيمان إذا دعي إليه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنك لا تسمع الموتى﴾</span> يعني: الذين يلقون الله بكفرهم؛ مَثَلُهم فيما يدعوهم إليه مثل الأموات الذين لا يسمعون، <span class="qpc-hafs">﴿ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</span> يعنيهم. وهي تقرأ على وجه آخر: ‹ولا يَسْمَعُ الصُّمُّ الدُّعاءَ إذا ولَّوْا مُدْبِرِينَ‹، يقول: إنّ الأصم لا يسمع الدعاء إذا ولّى مدبرًا{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ٢/٥٦٥.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وقرأ بقية العشرة: <span class="qpc-hafs">﴿ولا تُسْمِعُ الصُّمَّ﴾</span> بالتاء مضمومة، وكسر الميم، ونصب <span class="qpc-hafs">﴿الصم﴾</span>. انظر: النشر ٢/٣٣٩، والإتحاف ص٤٣١.وهِلَ: سَها وغَلِط وذهب وهْمُه لغير الصّواب. النهاية (وهل).أخرجه البخاري ٥/٧٧ (٣٩٧٨)، ومسلم ٢/٦٤٣ (٩٣٢).أخرجه يحيى بن سلام ٢/٥٦٤، وابن أبي حاتم ٩/٢٩٢١ واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٥٦٤.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٤.
  27,81,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنتَ بِهَـٰدِی ٱلۡعُمۡیِ عَن ضَلَـٰلَتِهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٠٩<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمَر</span> -من طريق يحيى بن عقيل- قوله: <span class="qpc-hafs">﴿وما انت بهادي العمي عن ضلالتهم﴾</span>، أي: ما تفعل ذلك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿ للنبي ﷺ: <span class="qpc-hafs">﴿وما أنت بهادي العمي﴾</span> إلى الإيمان <span class="qpc-hafs">﴿عن ضلالتهم﴾</span> يعني: عن كُفرهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وما أنت بهادي العمي﴾</span> عن الهدى <span class="qpc-hafs">﴿عن ضلالتهم﴾</span> يعني: [الذين] يموتون على كفرهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن تُسۡمِعُ إِلَّا مَن یُؤۡمِنُ بِـَٔایَـٰتِنَا فَهُم مُّسۡلِمُونَ ۝٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن تسمع﴾</span> يقول: ما تسمع الإيمان <span class="qpc-hafs">﴿إلا من يؤمن بآياتنا﴾</span> إلا مَن يُصَدِّق بالقرآن أنّه مِن الله ﷿، <span class="qpc-hafs">﴿فهم مسلمون﴾</span> يقول: فهم مُخلِصون بتوحيد الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن تسمع إلا من يؤمن بآياتنا﴾</span> مَن أراد الله أن يؤمن، <span class="qpc-hafs">﴿فهم مسلمون﴾</span> وهذا سَمْع القَبول، فأمّا الكافر فتَسْمَع أُذُناه، ولا يقبله قلبه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢١.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٥.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٥.
  27,82,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا وَقَعَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم﴾</span>، قال: حق عليهم{1}. (١١/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا وقع القول عليهم﴾</span>، قال: إذا وجَبَ القولُ عليهم{2}. (١١/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله ﷿: <span class="qpc-hafs">﴿وإذا وقع القول عليهم﴾</span>: أي: حق القول عليهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا وَقَعَ ٱلۡقَوۡلُ عَلَیۡهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨١٧<span class="dash">-</span></span> عن أبي سعيد الخدري، قال: سُئِل رسولُ الله ﷺ عن قول الله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span>. قال: «<b>إذا تَركوا الأمرَ بالمعروف، والنهي عن المنكر؛ وجب السُّخْط عليهم</b>»{4}. (١١/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عبد الله بن عتبة- قال: أكثِروا الطوافَ بالبيت قبل أن يُرفَع وينسى الناسُ مكانه، وأكثِروا تلاوة القرآن قبل أن يُرْفَع. قيل: وكيف يُرفَع ما في صدور الرجال؟ قال: يسري عليهم ليلًا، فيُصْبِحون منه قفرًا، وينسون قول: لا إله إلا الله. ويقعون في قول الجاهلية وأشعارهم، فذلك حين يقع القول عليهم{5}. (١١/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨١٩<span class="dash">-</span></span> عن <span class="name-1">حذيفة</span> -من طريق أبي ظبيان- قال: واللهِ، ما تلا عن قوم لوط{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٠<span class="dash">-</span></span> عن حفصة بنت سيرين، قالت: سألتُ <span class="name-2">أبا العالية الرِّياحي</span> عن قوله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، ما وقوع القول عليهم؟ فقال: أوْحى اللهُ إلى نوح أنّه لن يُؤمِن مِن قومك إلا مَن قد آمن. قالت: فكأنّما كشف عن وجهي شيئًا{7}. (١١/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وقع القول عليهم﴾</span>، قال: حق العذاب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٢<span class="dash">-</span></span> عن موسى أبي العلا، أنّ <span class="name-2">الحسن البصري</span> سُئِل عن هذه الآية: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span>. قال: فجاء، فقال: إنّ الله يومئذ على أهل الأرض ساخِط{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا وقع القول عليهم﴾</span>: والقول: الغضب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا وقع القول عليهم﴾</span>، يقول: إذا نزل العذاب بهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق شبيب- في قوله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم﴾</span>، قال: السخط{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٦<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج-: القول: العذاب{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَخۡرَجۡنَا لَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٢٧<span class="dash">-</span></span> عن عبد الله بن عمر، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، قال: «<b>ذاك حين لا يأمرون بمعروف، ولا ينهون عن منكر</b>»{4}. (١١/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، قال: إذا لم يأمروا بالمعروف، ولم ينهوا عن المنكر{15}. (١١/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، مثله{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣٠<span class="dash">-</span></span> عن <span class="name-2">عطية [العوفي]</span> -من طريق شعبة- في قوله: <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، قال: إذا لم يعرِفوا معروفًا، ولم يُنكِروا منكرًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣١<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، قال: إذا لم يأمروا بالمعروف، ولم ينهَوا عن المنكر{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿دَاۤبَّةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٣٢<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «<b>إذا كان الوعدُ الذي قال الله: <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</span>؛ قال: ليس ذلك حديثًا ولا كلامًا، ولكنه سِمَةٌ تَسِم مَن أمرها الله به، فيكون خروجُها مِن الصفا ليلةَ منى، فيصبحون بين رأسها وذنبها، لا يدحض داحض، ولا يخرج خارج، حتى إذا فرغت مِمّا أمرها الله، فهلك مَن هلك، ونجا مَن نجا، كان أول خطوة تضعها بأنطاكية</b>»{19}. (١١/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣٣<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق ابن شوذب- قال: لا تخرج الدابة حتى لا يبقى في الأرض مؤمن، واقرؤوا إن شئتم: <span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</span> الآية{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الدابة التي يخرج الله تعالى <span class="qpc-hafs">﴿من الأرض تكلمهم﴾</span> هو الثعبان الذي كان في جوف الكعبة، فاختطفه العقاب، فألقاه بأصل حراء لِمَخْسَفِ العماليق بقية قوم عاد{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض﴾</span> تخرج مِن الصفا الذي بمكة{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿دَاۤبَّةࣰ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٣٦<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إن بين يدي الساعة: الدجال، والدابة، ويأجوج ومأجوج، والدخان، وطلوع الشمس من مغربها</b>»{23}. (١١/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣٧<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: أول الآيات الروم، ثم الدجال، والثالثة يأجوج ومأجوج، والرابعة عيسى، والخامسة الدخان، والسادسة الدابة{24}. (١١/٤١٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿دَاۤبَّةࣰ﴾</span> - فصل</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٣٨<span class="dash">-</span></span> عن النزال بن سبرة، قال: قيل ل<span class="name-1">علي بن أبي طالب</span>: إنّ ناسًا يزعمون: أنّك دابة الأرض. فقال: واللهِ، إنّ لِدابة الأرض ريشًا وزغبًا، وما لي ريش ولا زغب، وإن لها لَحافرًا، وما لي مِن حافر، وإنها لتخرج حضر الفرس الجواد ثلاثًا، وما خرج ثلثاها{25}. (١١/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٣٩<span class="dash">-</span></span> عن محمد بن كعب القرظي، عن <span class="name-1">علي بن أبي طالب</span>، أنّه كان إذا سُئِل عن الدابة قال: أما –واللهِ- ما لها ذَنَب، وإن لها لِحْيَة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٠<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي مريم- قال: إنّ الدابة فيها مِن كل لون، ما بين قرنيها فرسخ للراكب{25}. (١١/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤١<span class="dash">-</span></span> عن عمر بن الحكم، أنّه سمع <span class="name-1">عبد الله بن عمرو بن العاص</span> يقول: تخرج الدابة مِن شِعب، فيمسُّ رأسُها السحابَ، ورجلاها في الأرض ما خرجتا، فتمرُّ بالإنسان يصلي، فتقول: ما الصلاة من حاجتك. فَتَخْطِمُهُ{28}{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق حماد بن سلمة، عن طلحة بن عبد الله بن كريز- قال: تخرج الدابةُ، فيفزع الناسُ إلى الصلاة، فتأتي الرجلَ وهو يصلي، فتقول: طوِّل ما شئت أن تطول، فواللهِ، لأخْطِمَنَّك{30}. (١١/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span>، قال: الدابة: زغباء، ذات وبَرٍ ورِيش{31}. (١١/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٤<span class="dash">-</span></span> عن قابوس بن أبي ظبيان، أنّ أباه حدَّثه، قال: سألنا <span class="name-1">عبد الله بن عباس</span> عن الدابة. فقال: هي مثل الحربة الضخمة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: الدابة مؤلفة، ذات زَغَب وريش، فيها مِن ألوان الدواب كلها، وفيها مِن كل أمة سيما، وسيماها مِن هذه الأمة أنّها تتكلم بلسان عربي مبين، تكلمهم بكلامهم{33}. (١١/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: الدابة ذات وبَر وريش، مؤلفة فيها مِن كل لون، لها أربع قوائم، تخرج بعقب من الحاج{31}. (١١/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود بن يزيد الأودي- قال: إنّ دابة الأرض ذات وبر، تناغي السماء{35}. (١١/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام-: أنّ موسى ﵇ سأل ربَّه أن يُرِيَه الدابة، فخرجت ثلاثة أيام ولياليهن تذهب في السماء، لا يرى [واحدًا] مِن طرفيها. قال: فرأى منظرًا فظيعًا، فقال: ربِّ، رُدَّها. فرَدَّها{36}. (١١/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٤٩<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: وجهها وجه رجل، وسائر خَلْقها كخَلْق الطير ...{37}<span class=comment-ref>٤٩٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٦٠) أنه رُوي: أنها دابة مبثوث نوعها في الأرض، فهي تخرج في كل بلد وفي كل قوم، ثم <span class="comment-type-4">علَّق</span> بقوله: «فقوله -على هذا التأويل-: <span class="qpc-hafs">﴿دابَّة﴾</span> إنما هو اسم جنس».</div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: هي دابة ذات زغب وريش، ولها أربع قوائم، تخرج مِن بعض أودية تهامة{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥١<span class="dash">-</span></span> عن <span class="name-2">أبي الزبير</span> -من طريق ابن جريج- أنّه وصف الدابة، فقال: رأسها رأس ثور، وعينها عين خنزير، وأذنها أذن فيل، وقرنها قرن أيل، وعنقها عنق نعامة، وصدرها صدر أسد، ولونها لون نمر، وخاصرتها خاصرة هرة، وذنبها ذنب كبش، وقوائمها قوائم بعير، بين كل مفصلين منها اثنا عشر ذراعًا، تخرج معها عصا موسى، وخاتم سليمان، ولا يبقى مؤمن إلا نكتت في مسجده بعصا موسى نكتة بيضاء، فتفشو تلك النكتة حتى يَبْيَضَّ لها وجهه، ولا يبقى كافر إلا نكتت في وجهه نكتة سوداء بخاتم سليمان، فتفشو تلك النكتة حتى يَسْوَدَّ لها وجهه، حتى إن الناس يتبايعون في الأسواق: بكم ذا، يا مؤمن؟ وبكم ذا، يا كافر؟{39}. (١١/٤١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: لها أربع قوائم، وزغب وريش، ولها جناحان، واسمها: أفضى، فإذا خرجت بلغ رأسُها السحابَ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٣<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>تخرج دابة الأرض ومعها عصا موسى، وخاتم سليمان، فتجلو وجْهَ المؤمن بالخاتم، وتخطم أنفَ الكافر بالعصا، حتى يجتمع الناسُ على الخوان، يُعرَف المؤمن من الكافر</b>»{41}. (١١/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٤<span class="dash">-</span></span> عن أبي هريرة، أن رسول الله ﷺ قال: «<b>تخرج الدابة يوم تخرج وهي ذات عَصَب وريش، تُكَلِّم الناس، فتنقط في وجه المؤمن نقطة بيضاء، فيَبْيَضُّ وجهه، وتنقط في وجه الكافر نقطة سوداء، فيَسْوَدُّ وجهه، فيتبايعون في الأسواق بعد ذلك: بِمَ تبيع هذا، يا مؤمن؟ وبم تبيع هذا، يا كافر؟ ثم يخرج الدجال وهو أعور، على عينه ظَفَرة</b>{42} <b>غليظة، مكتوب بين عينيه: «ك ف ر»، يقرأه كلُّ مؤمن وكافر</b>»{4}. (١١/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٥<span class="dash">-</span></span> عن أبي أُمامة، عن النبي ﷺ، قال: «<b>تخرج الدابة، فتَسِمُ الناسَ على خراطيمهم، ثم يغمرون فيكم، حتى يشتري الرجلُ الدابةَ، فيُقال: مِمَّن اشتريت؟ فيقال: مِن الرجل المخطم</b>»{44}. (١١/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٦<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span>، قال: تخرج الدابة مرتين قبل يوم القيامة، حتى يضرب فيها رجال، ثم تخرج الثالثة عند أعظم مساجدكم، فتأتي القوم وهم مجتمعون عند رجل، فتقول: ما يجمعكم عند عدوِّ الله؟ فيبتدرون، فتَسِم المؤمنَ والكافرَ، حتى إنّ الرجلين لَيتبايعان، فيقول هذا: خُذ، يا مؤمن. ويقول هذا: خذ، يا كافر{45}. (١١/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٧<span class="dash">-</span></span> عن محمد بن إسحاق: أنّه بلغه عن <span class="name-1">عبد الله بن عمرو بن العاص</span>، قال: تخرج دابة الأرض ومعها خاتم سليمان وعصا موسى، فأمّا الكافر فتختم بين عينيه بخاتم سليمان، وأما المؤمن فتمسح وجهه بعصا موسى، فيَبْيَضُّ{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق عبد الرحمن بن البيلماني- قال: يبيت الناسُ يسيرون إلى جمع، وتبيت دابة الأرض تسري إليهم، فيصبحون قد جعلتهم بين رأسها وأذنيها، فما مِن مؤمن إلا تمسحه، ولا كافر ولا منافق إلا تخطمه، وإنّ التوبة لَمفتوحة{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق العلاء بن زياد- قال: لا تقوم الساعة حتى يجتمع أهلُ بيت على الإناء الواحد، فيعرفون مؤمنيهم مِن كُفّارهم. قالوا: كيف ذاك؟ قال: إن الدابة تخرج وهي ذامَّةٌ للناس، تمسح كلَّ إنسان على مسجده، فأما المؤمن فتكون نكتة بيضاء، فتفشو في وجهه حتى يبيضَّ لها وجهه، وأما الكافر فتكون نكتة سوداء، فتفشو في وجهه حتى يسوَدّ لها وجهه، حتى إنهم لَيتبايعون في أسواقهم، فيقولون: كيف تبيع هذا، يا مؤمن؟ وكيف تبيع هذا، يا كافر؟ فما يرد بعضهم على بعض{48}. (١١/٤٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق ابن البيلماني- قال: تخرج الدابة ليلةَ جَمْع، والناس يسيرون إلى منى، فتحملهم بين نحرها وذنبها، فلا يبقى منافق إلا خطمته، وتمسح المؤمن، فيصبحون وهم بِشَرٍّ مِن الدجال{49}. (١١/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦١<span class="dash">-</span></span> عن <span class="name-3">صدقة بن يزيد</span> -من طريق ضمرة- قال: تجيء الدابة إلى الرجل وهو قائم يصلي في المسجد، فتكتب بين عينيه: كذاب{50}. (١١/٤١١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنَ ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٦٢<span class="dash">-</span></span> عن حذيفة بن اليمان، قال: ذكر رسول الله ﷺ الدابة، فقال حذيفة: يا رسول الله، مِن أين تخرج؟ قال: «<b>مِن أعظم المساجد حرمةً على الله، بينما عيسى يطوف بالبيت ومعه المسلمون إذ تضطرب الأرض مِن تحتهم، تُحَرِّك القنديل، وتَشُقُّ الصفا مما يلي المسعى، وتخرج الدابة مِن الصفا، أول ما يبدو رأسها، ملمعة ذات وبَر وريش، لن يدركها طالب، ولن يفوتها هارِب، تسم الناس؛ مؤمن وكافر، أمّا المؤمن فيرى وجهه كأنه كوكب دري، وتكتب بين عينيه: مؤمن، وأَمّا الكافر فتنكت بين عينيه نكتة سوداء: كافر</b>»{51}. (١١/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٣<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>بئس الشعب جياد</b>». مرتين أو ثلاثًا، قالوا: وبِم ذاك، يا رسول الله؟ قال: «<b>تخرج منه الدابة، فتصرخ ثلاث صرخات، فيسمعها مَن بين الخافقين</b>»{52}. (١١/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٤<span class="dash">-</span></span> عن أبي هريرة قال: قال رسول الله ﷺ: «<b>تخرج دابة الأرض من جياد، فيبلغ صدرها الركن، ولم يخرج ذنبها بعد</b>». قال: «<b>وهي دابة ذات وبر وقوائم</b>»{53}. (١١/٤٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٥<span class="dash">-</span></span> عن بريدة، قال: ذهب بي رسول الله ﷺ إلى موضع بالبادية، قريب من مكة، فإذا أرض يابسة حولها رمل، فقال رسول الله ﷺ: «<b>تخرج الدابة مِن هذا الموضع</b>». فإذا شبر في شبر{54}. (١١/٤٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٦<span class="dash">-</span></span> عن حذيفة بن أسيد، أُراه رفعه، قال: «<b>تخرج الدابة مِن أعظم المساجد حرمة، فبينما هم قعود بربو الأرض، فبينما هم كذلك، إذ تصدَّعَتْ</b>».= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٧<span class="dash">-</span></span> قال ابن عيينة: تخرج حين يسري الإمام مِن جَمْع، وإنما جعل سابق الحاج ليخبر الناس أنّ الدابة لم تخرج{55}. (١١/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٨<span class="dash">-</span></span> عن عبد الله بن عمر، أنه قال: ألا أريكم المكانَ الذي قال لي رسول الله ﷺ أنّ دابة الأرض تخرج منه! فضرب بعصاه قبل الشق الذي في الصفا{56}. (١١/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٦٩<span class="dash">-</span></span> عن حذيفة بن أسيد الغفاري، قال: ذكر رسول الله ﷺ الدابة، فقال: «<b>لها ثلاث خرجات مِن الدهر، فتخرج خرجة في أقصى البادية، ولا يدخل ذكرها القرية</b> -يعني: مكة-، <b>ثم تكمن زمانًا طويلًا، ثم تخرج خرجة أخرى دون تِلك، فيعلو ذكرُها في أهل البادية، ويدخل ذكرها القرية</b>». يعني: مكة. قال رسول الله ﷺ: «<b>ثم بينما الناس في أعظم المساجد على الله حرمة وأكرمها -المسجد الحرام- لم يرعهم إلا وهي تَرْغو</b>{57} <b>بين الركن والمقام، وتنفض عن رأسها التراب، فارفَضَّ</b>{58} <b>الناس عنها شتى، وتثبت عصابةٌ مِن المؤمنين، ثم عرفوا أنهم لن يعجزوا الله، فبدأت بهم، فجلَّت وجوهَهم حتى جعلتها كأنها الكوكب الدري، وولت في الأرض لا يدركها طالب، ولا ينجو منها هارب، حتى إنّ الرجل ليتعوذ منها بالصلاة، فتأتيه من خلفه، فتقول: يا فلان، الآن تصلي؟! فيُقْبِل عليها، فتَسِمُه في وجهه، ثم تنطلق، ويشترك الناس في الأموال، ويصطحبون في الأمصار، يعرف المؤمن مِن الكافر، حتى إن المؤمن ليقول: يا كافر، اقضِني حقِّي. وحتى إن الكافر ليقول: يا مؤمن، اقضني حقِّي</b>»{59}. (١١/٤٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٠<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>تخرج دابة الأرض، ولها ثلاث خرجات، فأول خرجة منها بأرض البادية، والثانية في أعظم المساجد وأشرفها وأكرمها، ولها عنق مُشْرِف، يراها مَن بالمشرق كما يراها مَن بالمغرب، ولها وجه كوجه إنسان، ومنقار كمنقار الطير، ذات وبر وزغب، معها عصا موسى، وخاتم سليمان بن داود، تنادي بأعلى صوتها</b>: <span class="qpc-hafs">﴿إن الناس كانوا بآياتنا لا يوقنون﴾</span>». ثم بكى رسول الله ﷺ، قيل: يا رسول الله، وما بعدُ؟ قال: «<b>هنات وهنات، ثم خصب وريف حتى الساعة</b>»{60}. (١١/٤٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧١<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق أبي الطفيل- قال: إنّ للدابة ثلاث خرجات، خرجة تخرج في بعض البوادي، ثم تَنكَمِي{61}، وخرجة تخرج في بعض القرى حتى تذكر وحتى تهريق الأمراء فيها الدماء، ثم تنكمي، فبينما الناس عند أشرف المساجد وأفضلها وأعظمها -حتى ظننا أنه يسمي المسجد الحرام، وما سماه- إذ ارتفعت بهم الأرض، فانطلق الناس هِرابًا، فلا يفوتها هارب، وتبقى عصابة من المسلمين، فيقولون: إنّه لا ينجينا مِن أمر الله شيء. فتخرج عليهم الدابة، فتجلو وجوههم مثل الكوكب الدري، ثم تنطلق، فلا يدركها طالِب، ولا يفوتها هارِب، ثم تأتي الرجلَ وهو يصلي، فتقول: أتتعوَّذُ بالصلاة؟! واللهِ، ما كنت مِن أهل الصلاة. فيلتفت إليها، فتخطمه، وتجلو وجه المؤمن، وتخطم الكافر، قال: قلنا: وما الناسُ يومئذ، يا حذيفة؟ قال: جيران في الرباع، وشركاء في الأموال، أصحاب في الأسفار{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق أبي إسحاق- قالت: الدابة تخرج مِن أجياد{63}. (١١/٤٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق صالح مولى التوأمة- قال: تخرج الدابة بأجياد مما يلي الصفا{64}. (١١/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٤<span class="dash">-</span></span> عن عطاء، قال: رأيت <span class="name-1">عبد الله بن عمرو بن العاص</span> -وكان منزله قريبًا مِن الصفا- رفع قدمه وهو قائم، وقال: لو شئتُ لم أضعها حتى أضعها على المكان الذي تخرج منه الدابة{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٥<span class="dash">-</span></span> عن حسان بن حِمَّصَةَ، قال: سمعتُ <span class="name-1">عبد الله بن عمرو بن العاص</span> يقول: لو شئتُ لانتعلت بنعلي هاتين، فلم أمسَّ الأرض قاعدًا حتى أقف على الأحجار التي تخرج الدابة من بينها، ولكأني بها قد خرجت في عَقِب ركب مِن الحاج. قال: فما حججتُ قطُّ إلا خفتُ تخرج بعقبنا{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق عمر بن الحكم بن ثوبان- قال: تخرج الدابة مِن شِعب بالأجياد، رأسها يمس السحاب، وما خرجت رِجلاها من الأرض، تأتي الرجل وهو يصلي، فتقول: ما الصلاة من حاجتك، ما هذا إلا تعوذًا ورياءً! فتخطمه{67}. (١١/٤١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> أنه قال وهو يومئذ بمكة: لو شئت لأخذت سبتيتي هاتين، ثم مشيت حتى أدخل الوادي التي تخرج منه دابة الأرض، فإنها تخرج، وهي آية للناس، فتلقى المؤمن فتسمه في وجهه واكتةً{68}، فيبيض لها وجهه، وتسم الكافر واكتةً، فيسود لها وجهه، وهي دابة ذات زغب وريش، فتقول: <span class="qpc-hafs">﴿أن الناس كانوا بآياتنا لا يوقنون﴾</span>{69}. (١١/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، قال: تخرج الدابة من تحت صخرة بجياد، وتستقبل المشرق، فتصرخ صرخة تنفذه، ثم تستقبل الشام، فتصرخ صرخة تنفذه، ثم تستقبل المغرب، فتصرخ صرخة تنفذه، ثم تستقبل اليمن، فتصرخ صرخة تنفذه، ثم تروح مِن مكة فتصبح بعسفان. قيل: ثم ماذا؟ قال: لا أعلم{70}. (١١/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة-: أنّ دابة الأرض تخرج مِن بعض أودية تهامة، ذات زغب وريش، لها أربع قوائم، فتنكت بين عيني المؤمن نكتة يبيض منها وجهه، وتنكت بين عيني الكافر نكتة سوداء يسود منها وجهه{71}. (١١/٤٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّه قرع الصفا بعصاه وهو محرم، وقال: إنّ الدابة لَتسمع قرع عصاي هذه{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عطية- قال: تخرج الدابة مِن صِدْع في الصفا كجري الفرس ثلاثة أيام، لم يخرج ثلثها{73}. (١١/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: تخرج الدابة من جبل جياد في أيام التشريق، والناس بمنى. قال: فلذلك جاء سابق الحاجِّ بخبر سلامة الناس{74}. (١١/٤١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم [النخعي]</span> -من طريق سماك- قال: تخرج الدابة مِن مكة{75}. (١١/٤٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٤<span class="dash">-</span></span> عن عبد الصمد بن معقل، أنّه سمع عمه <span class="name-2">وهب بن منبه</span> يقول: قال عزير: أتاني الملَك، قلت: أخبِرني: ما بقي مِن الدنيا؟ قال: لا عِلْم لي، ولِمَ تسألني عما لا أعلم؟! قال: أنا أعلم أنّه عند انقضاء الدنيا واقتراب الآخرة، وآية ذلك أن يكثر الكذب، ويقل الصدق، ويظهر الفجور، وينعدم البر، وتعود الأرض عقيمًا مِن الأنهار، وترى الشمس في أثر ذلك من مغربها، وتقطر الشجر دمًا، وتجول الأنواء، وتنطق الحجارة، ويملك من لم يكن برجّالة{76} الملك، وتخبر الطير، وتخرج من تحت سدوم دابة تكلم الناس كل يسمعها ...{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تُكَلِّمُهُمۡ أَنَّ ٱلنَّاسَ كَانُوا۟ بِـَٔایَـٰتِنَا لَا یُوقِنُونَ ۝٨٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٨٥<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (تُكَلِّمُهُم بِأَنَّ النّاسَ){78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٦<span class="dash">-</span></span> قرأ <span class="name-2">أبو زرعة بن عمرو</span>: (تَكْلِمُهُم) بفتح التاء، وتخفيف اللام، بمعنى: تَسِمُهم{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أخْرَجْنا لَهُمْ دَآبَّةً مِّنَ الأَرْضِ تُكَلِّمُهُمْ﴾</span>، قال: وهي في بعض القراءة: (تُحَدِّثُهُمْ أنَّ النّاسَ كانُواْ بِآياتِنا لا يُوقِنُونَ){80}. (١١/٣٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٨<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿دَآبَّةً مِّنَ الأَرْضِ تُكَلِّمُهُمْ﴾</span> مشددة مِن الكلام، <span class="qpc-hafs">﴿أنَّ النّاسَ﴾</span> بنصب الألف{81}. (١١/٤٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٨٩<span class="dash">-</span></span> عن <span class="name-2">عاصم الجحدري</span> -من طريق هارون- (تَكْلِمُهُمْ): تخدشهم{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٠<span class="dash">-</span></span> قال يحيى بن سلّام: وبعضهم يقرأها: (تَكْلِمُهُمْ)، أي: تَسِمُهم{83}<span class=comment-ref>٤٩٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٥</span> اختلف القراء في قراءة قوله تعالى: <span class="qpc-hafs">﴿تكلمهم﴾</span> على وجهين: <b>الأول</b>: بضم التاء وتشديد اللام، هكذا: (تُكَلِّمُهُمْ)، بمعنى: تخبرهم وتحدثهم. وهي قراءة عامة قُرّاء الأمصار. و<b>الثاني</b>: بفتح التاء وتخفيف اللام، هكذا: (تَكْلِمُهُمْ)، بمعنى: تَسِمُهُم. وهي قراءة أبي زرعة بن عمرو.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (١٨/١٢٧) القراءة الأولى، فقال: «القراءة التي لا أستجيز غيرها في ذلك <span class="mustanad">ما عليه قرّاء الأمصار</span>».</p><p>واختلفوا كذلك في قراءة قوله: <span class="qpc-hafs">﴿إن الناس﴾</span> فقرأ قوم:<span class="qpc-hafs">﴿أن الناس﴾</span> بالفتح، وقرأ آخرون بالكسر، و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٦١) أن قراءة عبد الله (تُكَلِّمُهُم بِأَنَّ) تصديق للفتح، <span class="comment-type-4">وبين</span> أنه قوله: <span class="qpc-hafs">﴿إن الناس﴾</span> -على قراءة الفتح- يكون من تمام كلام الدابة. ثم قال: «ويحتمل أن يكون ذلك من كلام الله ﷿».</div></p><p><h3><span class="qpc-hafs">﴿تُكَلِّمُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٨٩١<span class="dash">-</span></span> عن أبي الزعراء: أنّ رجلًا سأل عبد الله عن الدابة، فقال له: سلْ <span class="name-1">عليًّا</span>، فإنه بذلك. فسأل عليًّا، فقال: تأكل الطعام، وتمشي في الأسواق، وتكلم الناس <span class="qpc-hafs">﴿أن الناس كانوا بآياتنا لا يوقنون﴾</span>{50}<span class=comment-ref>٤٩٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٦</span> <span class="comment-type-4">علَّقَ</span> <u>ابن كثير</u> (١٠/ ٤٣٠) على قول عليّ هذا بقوله: «واختاره ابن جرير، وفي هذا نظر لا يخفى».</div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿دابة من الأرض تكلمهم﴾</span>، قال: تُحَدِّثهم{85}. (١١/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿تكلمهم﴾</span>، قال: كلامُها تنبئهم <span class="qpc-hafs">﴿أن الناس كانوا بآياتنا لا يوقنون﴾</span>{86}. (١١/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٤<span class="dash">-</span></span> عن أبي داود نفيع الأعمى، قال: سألت <span class="name-1">عبد الله بن عباس</span> عن قوله: <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</span> أو: (تَكْلِمُهُمْ)؟ قال: كل ذلك –واللهِ- تفعل، تُكَلِّمُ المؤمن، وتَكْلِمُ الكافر؛ تَجْرَحُه{87}<span class=comment-ref>٤٩٠٧</span>. (١١/٤٠١)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٧</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ كثير</u> (١٠/ ٤٣٠) على قول ابن عباس هذا، بقوله: «وهو قول حسن، ولا منافاة».</div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٥<span class="dash">-</span></span> عن المغيرة، عن <span class="name-2">إبراهيم النخعي</span>، قال: قلنا له: <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، أو (تَكْلِمُهُمْ)؟ قال: لا بل تكلِّمهم. يعني: الكلام{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٦<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: ... فتخبر مَن رآها: أنّ أهل مكة كانوا بمحمد والقرآن لا يوقنون{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس بن عبيد- قال: تخرج دابة إذا فسُد الناس، ولهم دابة تكلمهم كلامًا{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٨<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، في قوله <span class="qpc-hafs">﴿كانوا بآياتنا لا يوقنون﴾</span>: تكلمهم بهذا الكلام{91}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٨٩٩<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق شعبة- <span class="qpc-hafs">﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</span>، قال: معها عصا، تمسح وجه المؤمن، وتخطم وجه الكافر{92}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: تكلمهم ببطلان الأديان سوى دين الإسلام{93}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠١<span class="dash">-</span></span> عن <span class="name-3">صدقة بن يزيد</span> -من طريق ضمرة- قال: تجيء الدابةُ إلى الرجل وهو قائم يصلي في المسجد، فتكتب بين عينيه: كذّاب{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تكلمهم﴾</span> بالعربية، تقول: <span class="qpc-hafs">﴿أن الناس كانوا بآياتنا لا يوقنون﴾</span>{95}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنَّ ٱلنَّاسَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله ﷿: <span class="qpc-hafs">﴿تكلمهم أن الناس﴾</span>، قال: يعني: أهل مكة خاصة{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: تقول: <span class="qpc-hafs">﴿أن الناس﴾</span> يعني: كفار مكة{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهم مشركو أهل مكة{98}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَانُوا۟ بِـَٔایَـٰتِنَا لَا یُوقِنُونَ ۝٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كانوا بآياتنا﴾</span> يعني: بخروج الدابة <span class="qpc-hafs">﴿لا يوقنون﴾</span> هذا قول الدابة للناس: إنّ الناس بخروجي لا يوقنون. لأن خروجها آية من آيات الله ﷿، فإذا رآها الناس كلهم عادت إلى مكانها مِن حيث خرجت{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وقال بعضهم: تقول: إنّ الناس كانوا بي لا يوقنون ... <span class="qpc-hafs">﴿أن الناس كانوا بآياتنا لا يوقنون﴾</span> لا يؤمنون{98}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/١١٩. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٨/١١٩. وعزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ٢/٥٦٥.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٩/٢٩٢٢.أخرجه ابن أبي حاتم ٩/٢٩٢٢. ولفظ الأثر كذا وقع في مطبوعة المصدر.أخرجه عبد الرزاق ٢/٨٢ مختصرًا، وابن جرير ١٨/١٢٠ وآخره:... قالت: فكأنما كان على وجهي غطاء فكُشف، وابن أبي حاتم ٩/٢٩٢٢ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١١٩.أخرجه ابن أبي حاتم ٩/٢٩٢٢.أخرجه ابن جرير ١٨/١٢٠. وعلقه يحيى بن سلام ٢/٥٦٥.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه ابن أبي حاتم ٩/٢٩٢٢.أخرجه ابن جرير ١٨/١٢٠.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٨٥، وابن أبي شيبة (ت: محمد عوامة) ١٩/١٩٨ (٣٥٧٩٦)، ونعيم بن حماد في الفتن (١٨٥٤، ١٨٦٧)، وابن أبي الدنيا في كتاب الأمر بالمعروف -موسوعة الإمام ابن أبي الدنيا ٢/٢٠١ (٣٠)-، وابن جرير ١٨/١٢٠-١٢١، وابن أبي حاتم ٩/٢٩٢١، والحاكم ٤/٤٨٥. وعزاه السيوطي إلى ابن المبارك في الزهد، والفريابي، وعبد بن حميد، وابن مردويه.أخرجه ابن جرير ١٨/١٢١.أخرجه ابن جرير ١٨/١٢١.أخرجه إسحاق البستي في تفسيره ص٢٨.أخرجه نعيم بن حماد في كتاب الفتن ٢/٦٦٧، والفاكهي في أخبار مكة ٤/١٨ (٢٣٥٩) بلفظ: لا يدخل داخل، من طريق محمد بن عبد الرحمن بن البيلماني، عن أبيه، عن ابن عمر به. وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف جدًّا؛ فيه محمد بن الرحمن بن البيلماني، قال عنه ابن حجر في التقريب (٦٠٦٧): «ضعيف، وقد اتهمه ابن عدي وابن حبان». وفيه أيضًا أبوه عبد الرحمن بن البيلماني، قال عنه ابن حجر في التقريب (٣٨١٩): «ضعيف».أخرجه نعيم بن حماد في كتاب الفتن ٢/٦٦٤.أخرجه الفاكهي في أخبار مكة ٤/٣٧-٣٨.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه ابن بشران في الأمالي ١/٢٣٣ (٥٣٧)، والطبراني في كتاب الدعاء ص ٦١٦ (٢٢٤٨)، من طرق عن عبد الله بن رجاء، عن عباد بن إسحاق، عن سعيد المقبري، عن أبي هريرة به.</p><p>إسناده حسن.أخرجه نعيم بن حماد (١٤٥٣، ١٤٥٨، ١٨٥٣).أخرجه ابن أبي حاتم ٩/٢٩٢٥.أخرجه ابن أبي حاتم ٩/٢٩٢٤.أخرجه ابن أبي حاتم ٩/٢٩٢٥.فَتَخْطِمُه: تُصيب خَطْمه، أي: أنفه، فتترك أثرًا كأثر خِطام البعير، وهو الكَيّ الذي يكون من أنفه إلى خَدِّه. النهاية (خطم).أخرجه نعيم بن حماد في الفتن (١٨٥٢)، وابن جرير ١٨/١٢٦.أخرجه يحيى بن سلام ٢/٥٦٥. وعزاه السيوطي إلى عبد بن حميد. وزاد يحيى بن سلام: قال عبد الله بن عمرو: ولو أشاء أن أضع قدمي على مكانها الذي تخرج منه لفعلت. وذكر قبله: قال حماد: يومئذ يُعرف المنافق من المؤمن.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٢٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٥٦٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٥٦٥، وابن أبي شيبة ١٥/٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٦/١٨٠.أخرجه ابن جرير ١٨/١٢٦.أخرجه ابن أبي حاتم ٩/٢٩٢٤. وعزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه أحمد ١٣/٣٢١ (٧٩٣٧)، ١٦/٢٣٦ (١٠٣٦١)، والترمذي ٥/٤٠٧-٤٠٨ (٣٤٦٤)، وابن ماجه ٥/١٨٥ (٤٠٦٦)، والحاكم ٤/٥٣٢ (٨٤٩٤)، وابن جرير ١٨/١٢٥، وابن أبي حاتم ٩/٢٩٢٣ (١٦٥٩٢)، والثعلبي ٧/٢٢٤.</p><p>قال الترمذي: «هذا حديث حسن». وقال الألباني في الضعيفة ٣/٢٣٣ (١١٠٨): «منكر».ظَفَرة -بفتح الظاء والفاء-: لَحمة تنبُت عند المَآقِي، وقد تَمْتدُّ إلى السَّواد فتُغَشِّيه. النهاية (ظفر).عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ٣٦/٦٤٦-٦٤٧ (٢٢٣٠٨). وعزاه السيوطي إليه وإلى سمويه وابن مردويه بلفظ: ثم يعمِّرون فيكم -بالعين المهملة-.</p><p>قال الهيثمي في المجمع ٨/٦ (١٢٥٧٣-١٢٥٧٤): «رجاله رجال الصحيح، غير عمر بن عبد الرحمن بن عطية، وهو ثقة». وقال المناوي في التيسير ١/٤٤٦: «بإسناد رجاله ثقات». وقال الألباني في الصحيحة ١/٦٣٩ (٣٢٢): «وهذا إسناد صحيح، رجاله كلهم ثقات معروفون، غير عمر هذا».أخرجه ابن أبي شيبة ١٥/٦٦-٦٧.أخرجه ابن جرير ١٨/١٢٦.أخرجه يحيى بن سلام ٢/٥٦٧.أخرجه يحيى بن سلام ٢/٥٦٧. وعزاه السيوطي إلى عبد بن حميد، واللفظ له.أخرجه ابن أبي شيبة ١٥/١٨٠-١٨١، وابن أبي حاتم ٩/٢٩٢٣-٢٩٢٤.أخرجه ابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن جرير ١٨/١٢٤-١٢٥، والثعلبي ٧/٢٢٥.</p><p>قال ابن كثير في البداية والنهاية ١٩/٢٥٠: «في إسناده نظر».أخرجه الطبراني في الأوسط ٤/٣١٩ (٤٣١٧)، والعقيلي في الضعفاء ٢/٦١.</p><p>قال العقيلي: «لا يحفظ إلا عن رباح». وقال ابن عدي في الكامل في الضعفاء ٤/١٠٩: «ورباح بن عبيد الله ذكر هذا الحديث، وأُنكِر عليه». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١٠٩٢ (٢٣١٨): «أُنكِر على رباح رفعه». وقال الهيثمي في المجمع ٨/٧ (١٢٥٧٧): «فيه رباح بن عبيد الله بن عمر، وهو ضعيف». وقال الألباني في الضعيفة ٧/٣٨٨ (٣٣٧٦): «ضعيف».أخرجه الذهبي في ميزان الاعتدال ٣/٨٤-٨٥، في ترجمة عقبة بن أبي الحسناء (٥٦٨٥)، والثعلبي ٧/٢٢٤.</p><p>قال الألباني في الضعيفة ٣/٢٣٤ (١١٠٩): «ضعيف».أخرجه أحمد ٣٨/١٢٩ (٢٣٠٢٣)، وابن ماجه ٥/١٨٦ (٤٠٦٧)، بلفظ: فتر في شبر، والبخاري في تاريخه ٣/١٦١-١٦٢ (٥٥٤) واللفظ له.</p><p>قال البوصيري في مصباح الزجاجة ٤/١٩٩ (٨٣٤١): «هذا إسناد ضعيف، خالد بن عبيد قال البخاري: في حديثه نظر. وقال ابن حبان والحاكم: حدّث عن أنس بأحاديث موضوعة». وأورده ابن الجوزي في العلل المتناهية ٢/٤٣١ (١٥٢٥).أخرجه الطبراني في الأوسط ٢/١٧٦-١٧٧ (١٦٣٥). وعزاه السيوطي إلى ابن مردويه.</p><p>قال الطبراني: «لم يرو هذا الحديث عن ابن جريج إلا سفيان، تفرد به حمزة بن سعيد».أخرجه أبو يعلى (٥٧٠٣). وعزاه السيوطي إلى ابن مردويه.</p><p>قال محقق أبي يعلى: «إسناده ضعيف».الرُّغاء: صوْتِ الإبِلِ. النهاية (رغا).أي: تفرقوا. اللسان (رفض).أخرجه الحاكم ٤/٥٣٠ (٨٤٩٠)، وابن أبي حاتم ٩/٢٩٢٣ (١٦٥٩٣)، وفيه طلحة بن عمرو الحضرمي.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، وهو أبين حديث في ذكر دابة الأرض، ولم يخرجاه». وقال الذهبي: «طلحة بن عمرو الحضرمي ضعّفوه، وتركه أحمد». وقال ابن كثير في البداية والنهاية ١٩/٢٤٩-٢٥٠: «فيه غرابة». وقال الهيثمي في المجمع ٨/٧ (١٢٥٧٦): «رواه الطبراني، وفيه طلحة بن عمرو، وهو متروك».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٢٠-٢١ للزيلعي-، من طريق محمد بن مسلم الطائفي، عن عمرو بن دينار، عن ابن عباس به.</p><p>إسناده ليّن؛ فيه محمد بن مسلم الطائفي، قال عنه ابن حجر في التقريب (٦٢٩٣): «صدوق، يخطئ من حفظه».تنكَمِي: تستتر. النهاية (كما).أخرجه عبد الرزاق ٢/٨٤.أخرجه ابن أبي شيبة ١٥/١٨١.أخرجه يحيى بن سلام ٢/٥٦٥ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١٢٤.أخرجه ابن جرير ١٨/١٢٤، كما أخرجه ابن أبي شيبة ١٥/٦٧، ١٨١ من طريق عبد الملك بن عمير بنحوه.أخرجه نعيم بن حماد في الفتن (١٨٥٢). وعزاه السيوطي إليه من قول عمرو بن العاصي! ولعل في النسخة سقط.كذا في مطبوعة الدر: واكتة بالألف، على صورة اسم الفاعل من الوكت، وهو الأثر اليسير في الشيء، والوكتة كالنقطة في الشيء من غير لونه. اللسان (وكت).عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، والبيهقي في البعث. وأخرجه الفاكهي في أخبار مكة ٤/٣٩ (٢٣٤٧) عن عبد الله بن عمر، من طريق الحسن البصري، وفيه: «وكتفه» بدل «واكتة»، والظاهر أن «وكتفه» تصحيف.أخرجه ابن أبي حاتم ٩/٢٩٢٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٥٦٥ مختصرًا، ونعيم بن حماد (١٨٦٢)، وابن أبي حاتم ٩/٢٩٢٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، والبيهقي في البعث.تفسير البغوي ٦/١٨٠.أخرجه ابن أبي شيبة ١٥/٦٧، ونعيم بن حماد (١٨٥٩)، وابن جرير ١٨/١٢١-١٢٢، وابن أبي حاتم ٩/٢٩٢٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٥/٦٧، ١٨١، والخطيب في تالي التلخيص (٢٣٢). وعند ابن أبي شيبة في الموضع الأول: عبد الله بن عمرو.أخرجه عبد الرزاق ٢/٨٥، وابن أبي شيبة ١٥/١٨١. وعزاه السيوطي إلى عبد بن حميد.الرَّجّالَة: هم أصحاب رِكاب المَلِك ومَن يتصَرَّف في أُموره. شرح النووي على مسلم ١٢/١٣٢.أخرجه ابن أبي حاتم ٩/٢٩٢٥.أخرجه ابن أبي داود في المصاحف ١/٣٢٧، وإسحاق البستي في تفسيره ص٢٩ من طريق هارون الأعور.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١١٢، والمحتسب ٢/١٤٥.علقه ابن جرير ١٨/١٢٧.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عباس، ومجاهد، وعاصم الجحدري، وغيرهم. انظر: مختصر ابن خالويه ص١١٢، والمحتسب ٢/١٤٤.أخرجه يحيى بن سلام ٢/٥٦٨، وابن جرير ١٨/١٢٧. وعزاه السيوطي إلى عبد بن حميد وابن جرير بلفظ: (تُحَدِّثُهُمْ تَقُولُ لَهُمْ إنَّ الناسَ كانُوا بِآياتِنا لا يُوقِنُونَ). وجاء عند يحيى بن سلام ٢/٥٦٨: وقال بعضهم: (تَقُولُ: إنَّ النّاسَ كانُوا بِي لا يُوقِنُونَ).</p><p>وهي بكل هذه الألفاظ قراءة شاذة. انظر: البحر المحيط ٧/٩١.عزاه السيوطي إلى عبد بن حميد.</p><p>يعني: بفتح همزة <span class="qpc-hafs">﴿أن﴾</span>، وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، ويعقوب، وقرأ بقية العشرة: ‹إنَّ النّاسَ› بكسر الهمزة. انظر: الإتحاف ص٤٣٢.أخرجه إسحاق البستي في تفسيره ص٢٩.تفسير يحيى بن سلام ٢/٥٦٥.أخرجه ابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن جرير ١٨/١٢٧، وابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن جرير ١٨/١٢٧-١٢٨، وابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن أبي حاتم ٩/٢٩٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الفاكهي في أخبار مكة ٤/٤٣ (٢٣٥٦).تفسير البغوي ٦/١٨٠.أخرجه ابن أبي حاتم ٩/٢٩٢٦.علَّقه يحيى بن سلام ٢/٥٦٨.أخرجه الخطيب في تاريخ بغداد ١٦/٦٠٨.تفسير الثعلبي ٧/٢٢٢، وتفسير البغوي ٦/١٧٧.أخرجه ابن أبي حاتم ٩/٢٩٢٦.تفسير مقاتل بن سليمان ٣/٣١٧. وفي تفسير البغوي ٦/١٧٧ بنحوه منسوبًا إلى مقاتل دون تعيينه.علقه يحيى بن سلام ٢/٥٦٧.تفسير مقاتل بن سليمان ٣/٣١٧. وفي تفسير البغوي ٦/١٧٧: قال مقاتل: تخبر الناس أن أهل مكة لم يؤمنوا بالقرآن والبعث.تفسير يحيى بن سلام ٢/٥٦٨.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٨.
  27,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ نَحۡشُرُ مِن كُلِّ أُمَّةࣲ فَوۡجࣰا مِّمَّن یُكَذِّبُ بِـَٔایَـٰتِنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا ممن يكذب بآياتنا فهم يوزعون﴾</span>: يعني: الشيعة عند الحشر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا﴾</span>، قال: زُمْرَة{2}. (١١/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا﴾</span> يعني: زمرًا، <span class="qpc-hafs">﴿ممن يكذب بآياتنا﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا﴾</span>، يعني: كفار كل أمة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُمۡ یُوزَعُونَ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿ممن يكذب بآياتنا فهم يوزعون﴾</span>، قال: يقول: فهم يَدْفَعون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٣<span class="dash">-</span></span> عن <span class="name-2">أبي الأحوص [عوف بن مالك بن نضلة الأشجعي]</span> -من طريق ابن الأقمر- <span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا ممن يكذب بآياتنا فهم يوزعون﴾</span>، قال: يُحبَس الأول على الآخر، حتى إذا تكاملت العِدَّة إذ هم جميعًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: يحبس أولهم على آخرهم{7}. (١١/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: وزَعَةٌ تَرُدُّ أُولاهم على أُخراهم{8}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يوزعون﴾</span>، يعني: يُساقون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، يعني: فهم يُساقون إلى النار{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ- في قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: يُساقون{11}. (١١/٤١٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/١٢٩.أخرجه ابن جرير ١٨/١٢٩، وأخرجه من طريق ابن جريج بلفظ: زمرة زمرة. وأخرجه ابن أبي حاتم ٩/٢٩٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٨.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٩٢٧.أخرجه إسحاق البستي في تفسيره ص٢٩.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٨٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٩٢٧. وعلقه يحيى بن سلام ٢/٥٦٨.علَّقه يحيى بن سلام ٢/٥٦٨.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه ابن أبي حاتم ٩/٢٩٢٧.
  27,84,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَا جَاۤءُو قَالَ أَكَذَّبۡتُم بِـَٔایَـٰتِی وَلَمۡ تُحِیطُوا۟ بِهَا عِلۡمًا أَمَّاذَا كُنتُمۡ تَعۡمَلُونَ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩١٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- في قول الله: <span class="qpc-hafs">﴿بآياتي﴾</span>: يعني: بالقرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حتى إذا جاءوا قال أكذبتم بآياتي﴾</span> يعني: بالساعة، <span class="qpc-hafs">﴿ولم تحيطوا بها علما﴾</span> أنها باطل، <span class="qpc-hafs">﴿أم ماذا كنتم تعملون﴾</span>؟!{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿حتى إذا جاءوا قال﴾</span> الله <span class="qpc-hafs">﴿أكذبتم بآياتي ولم تحيطوا بها علما﴾</span> أي: لم تحيطوا بها علمًا بأنّ ما عبدتم مِن دوني ما خلقوا معي شيئًا، ولا رزقوا معي شيئًا، وأنّ عبادتكم إيّاهم لم تكن منكم بإحاطة علم علمتموه، وإنما كان ذلك منكم على الظن، <span class="qpc-hafs">﴿أماذا كنتم تعملون﴾</span>؟! يستفهمهم، وهو أعلم بذلك منهم، يحتجُّ عليهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢٧.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٦٨.
  27,85,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَقَعَ ٱلۡقَوۡلُ عَلَیۡهِم﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٢٢<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span>: قوله: <span class="qpc-hafs">﴿ووقع القول عليهم﴾</span>، أي: وحق القول عليهم، والقول: الغضب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ووقع القول﴾</span>، قال: وجب القول، والقول: الغضب{2}. (١١/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ووقع القول عليهم﴾</span>، يعني: ونزل العذاب بهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِمَا ظَلَمُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بما ظلموا﴾</span>، يعني: بما أشركوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿بما ظلموا﴾</span> بما أشركوا{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُمۡ لَا یَنطِقُونَ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٢٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فهم لا ينطقون﴾</span>: كيف ينطقون ولا حُجَّة لهم؟!{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فهم لا ينطقون﴾</span>، يعني: لا يتكلمون فيها{3}<span class=comment-ref>٤٩٠٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٨</span> قال <u>ابنُ عطية</u> (٦/٥٦١): «وهذا في موطن من مواطن القيامة، وفي فريق من الناس؛ لأنّ القرآن يقتضي أنهم يتكلمون بحُجَج في غير هذا الموطن».</div></p></div>",footnotes:1:أخرجه يحيى بن سلام ٢/٥٦٩ من طريق ابن مجاهد، وإسحاق البستي في تفسيره ص٣٠ مختصرًا من طريق ابن جريج بلفظ: حق.أخرجه ابن أبي حاتم ٩/٢٩٢٧.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٦٩.تفسير البغوي ٦/١٨١.تفسير مقاتل بن سليمان ٣/٣١٨.
  27,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ یَرَوۡا۟ أَنَّا جَعَلۡنَا ٱلَّیۡلَ لِیَسۡكُنُوا۟ فِیهِ وَٱلنَّهَارَ مُبۡصِرًاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والنهار مبصرا﴾</span>، قال: مُنِيرًا{1}. (١١/٤١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم وعظ كفار مكة ليعتبروا في صُنعه، فيُوَحِّدوه ﷿، فقال تعالى: <span class="qpc-hafs">﴿ألم يروا أنا جعلنا الليل ليسكنوا فيه والنهار مبصرا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ألم يروا أنا جعلنا الليل ليسكنوا فيه والنهار مبصرا﴾</span> منيرًا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآيات﴾</span> يقول: إنّ فيهما لَعبرة <span class="qpc-hafs">﴿لقوم يؤمنون﴾</span> يعني: لقوم يُصَدِّقون بتوحيد الله ﷿{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢٧.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٦٩.تفسير مقاتل بن سليمان ٣/٣١٨.
  27,87,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یُنفَخُ فِی ٱلصُّورِ﴾</span>{1} - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قال: الصور: البوق. قال: هو البوق، صاحبه آخِذٌ به، يقبض قبضتين بكفيه على طرف القرن <span class=comment-ref>٤٩٠٩</span>، بين طرفه وبين فيه قدر قبضة أو نحوها، قد برك على ركبة إحدى رجليه، فأشار، فبرك على ركبة يساره مُقْعِيًا على قدمها، عقبها تحت فخذه وأليته، وأطراف أصابعها في التراب{2}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٠٩</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (٦/٥٦٢) إلى أنّ الصّور: هو القرن، فقال: «هو القرن في قول جمهور الأمة، <span class="mustanad">وهو مقتضى الأحاديث</span>».</div></p><p><div></p><p><p><span class="item-no">٥٧٩٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ويوم ينفخ في الصور﴾</span>: أي: في الخلق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٣٥<span class="dash">-</span></span> تفسير <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: أنّ المنادي -وهو صاحب الصور- يُنادي مِن الصخرة مِن بيت المقدس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٣٦<span class="dash">-</span></span> عن <span class="name-3">أبي بكر بن عبد الله [بن محمد بن أبي سبرة]</span> -من طريق حجاج- قال: الصور كهيئة القرن، قد حَجَنَ{5} إحدى ركبتيه إلى السماء، وخفض الأخرى، لم يُلْقِ جفون عينيه على غُمْضٍ منذ خلق الله السموات، مستعدًا مستجدًا، قد وضع الصور على فيه ينتظر متى يؤمر أن ينفخ فيه{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَفَزِعَ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَن فِی ٱلۡأَرۡضِ إِلَّا مَن شَاۤءَ ٱللَّهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٣٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>لَمّا فرغ اللهُ مِن خلق السماوات والأرض خلق الصور، فأعطاه إسرافيل، فهو واضِعُه على فِيه، شاخِصٌ ببصره إلى العرش، ينتظر متى يُؤمَر</b>». قال أبو هريرة: يا رسول الله، وما الصور؟ قال: «<b>قرن</b>». قال: وكيف هو؟ قال: «<b>قرن عظيم ينفخ فيه ثلاث نفخات؛ الأولى: نفخة الفزع، والثانية: نفخة الصعق، والثالثة: نفخة القيام لرب العالمين؛ يأمر الله ﷿ إسرافيل بالنفخة الأولى، فيقول: انفخ نفخة الفزع. فيفزع أهل السماوات والأرض إلا من شاء الله، ويأمره الله فيديمها ويطولها فلا يفتر، وهي التي يقول الله: <span class="qpc-hafs">﴿ما ينظر هؤلاء إلا صيحة واحدة ما لها من فواق﴾</span></b> [ص:١٥]، <b>فيسير الله الجبال فتكون سرابًا، وترج الأرض بأهلها رجًّا، وهي التي يقول الله: <span class="qpc-hafs">﴿يوم ترجف الراجفة تتبعها الرادفة قلوب يومئذ واجفة﴾</span></b> [النازعات:٦-٧]. <b>فتكون الأرض كالسفينة الموبقة في البحر تضربها الأمواج، تكفأ بأهلها، أو كالقنديل المُعَلَّق بالعرش، ترجحه الأرواح، فيميد الناس على ظهرها، فتُذْهِل المراضع، وتضع الحوامل، وتشيب الولدان، وتطير الشياطين هاربة حتى تأتي الأقطار، فتلقاها الملائكة، فتضرب وجوهها فترجع، ويولي الناس مدبرين، ينادي بعضهم بعضًا، وهو الذي يقول الله: <span class="qpc-hafs">﴿يوم التناد يوم تولون مدبرين ما لكم من الله من عاصم ومن يضلل الله فما له من هاد﴾</span></b> [غافر:٣٢-٣٣]. <b>فبينما هم على ذلك، إذ تصدَّعَتِ الأرضُ مِن قُطر إلى قُطْر، فرأوا أمرًا عظيمًا، وأخذهم لذلك مِن الكرب ما الله أعلم به، ثم نظروا إلى السماء فإذا هي كالمهل، ثم خُسِف شمسها، وخُسِف قمرها، وانتثرت نجومها، ثم كَشَطت عنهم</b>». قال رسول الله ﷺ: «<b>والأموات لا يعلمون بشيء مِن ذلك</b>». فقال أبو هريرة: فمن [ثَمَّ] استثنى الله حين يقول: <span class="qpc-hafs">﴿ففزع من في السموات ومن في الأرض إلا من شاء الله﴾</span>. قال: «<b>أولئك الشهداء، وإنّما يَصِل الفزع إلى الأحياء، أولئك أحياء عند ربهم يرزقون، وقاهم الله فزع ذلك اليوم وآمَنَهم، وهو عذاب الله يبعثه على شِرار خلقه، وهو الذي يقول:</b> <span class="qpc-hafs">﴿يا أيها الناس اتقوا ربكم إن زلزلة الساعة شيء عظيم﴾</span> إلى قوله: <span class="qpc-hafs">﴿ولكن عذاب الله شديد﴾</span>»{7}<span class=comment-ref>٤٩١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩١٠</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (٦/٥٦٢) إلى أنّ المَلَكَ له ثلاث نفخات في الصور، <span class="mustanad">كما ورد في أثر أبي هريرة</span> ﵄، وذكر قولًا آخر، فقال: «قالت فرقة: إنما هما نفختان. كأنهم جعلوا الفزع والصعق في نفخة واحدة، واستدلوا على ذلك بقوله تعالى: <span class="qpc-hafs">﴿ثم نفخ فيه أخرى فإذا هم قيام ينظرون﴾</span> [الزمر:٦٨]، وقالوا:»أخرى«لا تُقال إلا في الثانية». ثم <span class="comment-type-2">انتَقَدَ</span> قولهم، فقال (٦/٥٦٣): «والقول الأول أصح، و»أخرى" تُقال في الثالثة، ومنه قول ربيعة بن مقروم:</p><p>ولقد شفعتهما بآخر ثالث</p><p>ومنه قوله تعالى: <span class="qpc-hafs">﴿ومناة الثالثة الأخرى﴾</span> [النجم:٢٠]".</div></p><p><div></p><p><p><span class="item-no">٥٧٩٣٨<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق العوام، عمَّن حدَّثه- في قوله: <span class="qpc-hafs">﴿ففزع من في السماوات ومن في الأرض إلا من شاء الله﴾</span>، قال: هم الشهداء{8}<span class=comment-ref>٤٩١١</span>. (١١/٤١٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٩١١</span> <span class="comment-type-4">قال</span> <u>ابن عطية</u> (٦/٥٦٤): «تظاهرت الروايات بأن الاستثناء في هذه الآية إنما أريد به الشهداء؛ لأنهم أحياء عند ربهم يرزقون، وهم أهل للفزع؛ لأنهم بشر، لكن فُضِّلوا بالأمن في ذلك اليوم».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ جرير</u> (١٨/١٣٥)، و<span class="comment-type-4">كذا</span> <u>ابنُ كثير</u> (١٠/٤٣٦).</div></p><p><div></p><p><p><span class="item-no">٥٧٩٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير، وعطاء- في قوله: <span class="qpc-hafs">﴿إلا من شاء الله﴾</span>، قال: هم الشهداء؛ لأنهم أحياء عند ربهم، لا يَصِل الفزع إليهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿إلا من شاء الله﴾</span>، قال: هم رضوان، والحور، ومالك، والزبانية{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤١<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إلا من شاء الله﴾</span>، قال: استثنى الله طوائفَ مِن أهل السماء، يموتون بين النفختين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿إلا من شاء الله﴾</span>: يعني: جبريل، وميكائيل، وإسرافيل، وملك الموت، فلا يبقى بعد النفخة إلا هؤلاء الأربعة، ثم يقبض الله روح ميكائيل، ثم روح إسرافيل، ثم روح ملك الموت، ثم روح جبريل، فيكون آخرهم موتًا جبريل ﵇{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويوم ينفخ في الصور ففزع﴾</span> يقول: فمات <span class="qpc-hafs">﴿من في السماوات ومن في الأرض﴾</span> مِن شدة الخوف والفزع، <span class="qpc-hafs">﴿إلا من شاء الله﴾</span> يعني: جبريل، وميكائيل، وإسرافيل، وملك الموت ﵈{13}<span class=comment-ref>٤٩١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩١٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٢٧٢ دار الكتب العلمية) أن مقاتل قال: هي في جبريل ﵇، وميكائيل، وإسرافيل، وملك الموت، وإذا كان الفزع الأكبر لا ينالهم فهم حريون أن لا ينالهم هذا. ثم <span class="comment-type-4">علَّق</span> (٦/٥٦٣) بقوله: «على أن هذا في وقت ترقّب، وذلك في وقت أمْن؛ إذ هو إطباق جهنم على أهلها».</div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿ففزع من في السموات ومن في الأرض إلا من شاء الله﴾</span>: وهذه النفخة الأولى{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكُلٌّ أَتَوۡهُ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٤٥<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: حفِظْتُ عن رسول الله ﷺ في النمل: <span class="qpc-hafs">﴿وكُلٌّ أتَوْهُ داخِرِينَ﴾</span>، على معنى: جاؤوه{15}. (١١/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي جبر، عن أبيه- أنّه قرأ: <span class="qpc-hafs">﴿وكُلٌّ أتَوْهُ داخِرِينَ﴾</span> خفيفة بنصب التاء، على معنى: جاءوه. يعني: بلا مد{16}. (١١/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٧<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> -من طريق أبي بكر- أنّه قرأ: ‹وكُلٌّ آتُوهُ داخِرِينَ› ممدودة، مرفوعة التاء، على معنى: فاعِلوه{17}<span class=comment-ref>٤٩١٣</span>. (١١/٤١٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٩١٣</span> اختلف القراء في قراءة قوله تعالى: <span class="qpc-hafs">﴿وكُلٌّ أتَوْهُ داخِرِينَ﴾</span> على وجهين: <b>الأول</b>: بمدّ الألف مِن <span class="qpc-hafs">﴿أتوه﴾</span> على مثال: فاعِلُوه، هكذا: ‹آتُوهُ›. وهي قراءة عامة قُرّاء الأمصار. و<b>الثاني</b>: بفتح الهمزة بلا مدّ، هكذا <span class="qpc-hafs">﴿أتَوْهُ﴾</span>. وهي قراءة عبد الله بن مسعود ﵄، واتبعه على القراءة به المتأخرون: الأعمش، وحمزة، وحفص، وخلف العاشر.</p><p>و<span class="comment-type-4">بَيَّنَ</span> <u>ابنُ جرير</u> (١٨/١٣٧) أنّ كلتا القراءتين صواب، فقال: «الصواب من القول في ذلك عندي أنهما قراءتان <span class="mustanad">مستفيضتان في قرأَة الأمصار</span>، ومتقاربتا المعنى، فبأيتهما قرأ القارئ فمصيب». و<span class="comment-type-4">بَيَّنَ علّة</span> قراءة الجمهور، فقال: «اعتلَّ الذين قرءوا ذلك على مثال»فاعلوه«بإجماع القراء على قوله:<span class="qpc-hafs">﴿وكلهم آتيه﴾</span> [مريم:٩٥] قالوا: فكذلك قوله: ‹آتُوهُ›، في الجمع»، و<span class="comment-type-1">وجَّهَ</span> قراءة عبد الله بن مسعود، بقوله: «أما الذين قرءوا على قراءة عبد الله، فإنهم ردوه على قوله:<span class="qpc-hafs">﴿ففزع﴾</span>، كأنهم وجهوا معنى الكلام إلى: ويوم ينفخ في الصور ففزع مَن في السماوات ومَن في الأرض، وأتوه كلهم داخرين، كما يقال في الكلام: رآني ففَرَّ، وعاد وهو صاغر».</div></p><p><h3><span class="qpc-hafs">﴿دَ ٰ⁠خِرِینَ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿داخرين﴾</span>، قال: صاغرين{18}. (١١/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{19}. (١١/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٥١<span class="dash">-</span></span> و<span class="name-3">سفيان الثوري</span>، مثل ذلك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكل أتوه داخرين﴾</span> يعني: <span class="qpc-hafs">﴿وكل﴾</span> البَرُّ والفاجر <span class="qpc-hafs">﴿أتوه﴾</span> في الآخرة صاغرين{21}<span class=comment-ref>٤٩١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩١٤</span> قال <u>ابنُ كثير</u> (١٠/٤٣٧): «أي: صاغرين مطيعين، لا يتخلف أحدٌ عن أمره، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿يوم يدعوكم فتستجيبون بحمده﴾</span> [الإسراء:٥٢]، <span class="comment-type-4">وقال</span>: <span class="qpc-hafs">﴿ثم إذا دعاكم دعوة من الأرض إذا أنتم تخرجون﴾</span> [الروم:٢٥]».</div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: الداخر: الصاغِر الراغِم؛ لأنّ المرء إذا فزِع إنّما همته الهرب مِن الأمر الذي فزِع منه، فلما نفخ في الصور فزعوا، فلم يكن لهم من الله منجى{22}. (١١/٤١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وكل أتوه داخرين﴾</span>، يعني: النفخة الآخرة{23}. (ز)</p></p><p></div></p></div>",footnotes:1:تقدمت الآثار مفصلة في معنى الصور عند تفسير قوله تعالى: <span class="qpc-hafs">﴿ولَهُ المُلْكُ يَوْمَ يُنْفَخُ فِي الصُّورِ﴾</span> [الأنعام:٧٣]، وقد ذكر ابن جرير في تفسير آية سورة النمل: <span class="qpc-hafs">﴿ويوم ينفخ في الصور﴾</span> ما لم يذكره في تفسير آية سورة الأنعام، وأحال على تفسير آية سورة الأنعام.أخرجه ابن جرير ١٨/١٣٢، وابن أبي حاتم ٩/٢٩٢٩، وإسحاق البستي في تفسيره ص٣٠ مختصرًا، كما أخرجه يحيى بن سلام ٢/٥٦٩ من طريق ابن مجاهد مختصرًا.أخرجه ابن جرير ١٨/١٣٤، وابن أبي حاتم ٩/٢٩٢٩.أخرجه يحيى بن سلام ٢/٥٧٢.حَجَنَ: عَطَفَ، والحَجَن: اعْوِجاج الشيء. اللسان (حجن).أخرجه ابن جرير ١٨/١٣٢.أخرجه إسحاق بن راهويه في مسنده ١/٨٤ (١٠)، وأبو الشيخ في كتاب العظمة ٣/٨٢١ (٣٨٦) كلاهما مطولًا، وابن جرير ١٥/٤١٩، ١٦/٤٤٧-٤٤٩ واللفظ له، وابن أبي حاتم ٩/٢٩٢٨ (١٦٦٢١)، ٩/٢٩٢٩-٢٩٣٠ (١٦٦٢٧)، من طريق إسماعيل بن رافع المدني، عن يزيد بن أبي زياد، عن رجل، عن محمد بن كعب القرظي، عن رجل من الأنصار، عن أبي هريرة به.</p><p>إسناده ضعيف جدًّا؛ فيه إسماعيل بن رافع المدني، قال عنه ابن حجر في التقريب (٤٤٢): «ضعيف الحفظ». وفيه أيضًا يزيد ابن أبي زياد قال عنه ابن حجر في التقريب (٧٧١٧): «ضعيف، كبر فتغيّر، وصار يتلقن». وفيه جهالة شيخ يزيد، وجهالة الراوي عن أبي هريرة.أخرجه ابن جرير ١٨/١٣٥. وعزاه السيوطي إلى سعيد بن منصور.تفسير البغوي ٦/١٨١.تفسير البغوي ٦/١٨٣.علَّقه يحيى بن سلام ٢/٥٦٩.تفسير البغوي ٦/١٨٢.تفسير مقاتل بن سليمان ٣/٣١٨. وفي تفسير البغوي ٦/١٨٢ نحوه منسوبًا إلى مقاتل دون تعيينه، وفيه زيادة كما في أثر الكلبي السابق.تفسير يحيى بن سلام ٢/٥٦٩.عزاه السيوطي إلى ابن مردويه.</p><p>وهي قراءة متواترة، قرأ بها حفص، وحمزة، وخلف العاشر، وقرأ بقية العشرة: ‹وكُلٌّ آتُوهُ› بالمد، وضم التاء. انظر: الإتحاف ص٤٣٢.أخرجه ابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١٣٦، وابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ٢/٥٧٠، وعبد الرزاق ٢/٨٦ من طريق معمر، وابن جرير ١٨/١٣٦. وعلقه ابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٩/٢٩٣٢.تفسير مقاتل بن سليمان ٣/٣١٨.أخرجه ابن جرير ١٨/١٣٦، وابن أبي حاتم ٩/٢٩٣٢ من طريق أصبغ بلفظ: «الراهب» بدل «الراغم»، وقد عزاه السيوطي إليهما بهذا اللفظ: «الراهب».تفسير يحيى بن سلام ٢/٥٧٠.
  27,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَرَى ٱلۡجِبَالَ تَحۡسَبُهَا جَامِدَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وترى الجبال تحسبها جامدة﴾</span>، قال: قائِمة{1}<span class=comment-ref>٤٩١٥</span>. (١١/٤١٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٩١٥</span> قال <u>ابنُ جرير</u> (١٨/١٣٧) مبيّنًا المعنى <span class="mustanad">استنادًا إلى أثر ابن عباس</span> ﵄: «يقول -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿وترى الجبال﴾</span> يا محمد، <span class="qpc-hafs">﴿تحسبها﴾</span> قائمةً، <span class="qpc-hafs">﴿وهي تمرّ﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿وترى الجبال تحسبها جامدة﴾</span> أي: تحسبها ثابتة في أصولها لا تتحرك، <span class="qpc-hafs">﴿وهي تمر مر السحاب﴾</span>{2}. (١١/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وترى الجبال تحسبها جامدة﴾</span>، يعني: تحسبها مكانها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وترى الجبال تحسبها جامدة﴾</span> ساكنة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهِیَ تَمُرُّ مَرَّ ٱلسَّحَابِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٥٩<span class="dash">-</span></span> عن أبي هريرة أنّه قال: حدَّثنا رسول الله ﷺ، قال: «<b>... يُسَيِّر اللهُ الجبالَ، فتمر مر السحاب، ثم يجعلها سرابًا، وترجُّ الأرضُ بأهلها رجًّا</b> ...»{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهي تمر مر السحاب﴾</span> فتستوي في الأرض{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهي تمر مر السحاب﴾</span> تكون <span class="qpc-hafs">﴿كالعهن المنفوش﴾</span> [القارعة:٥] كالصوف المنفوش، وتكون <span class="qpc-hafs">﴿كثيبا مهيلا﴾</span> [المزمل:١٤]، وتُبَسُّ بسًّا كما يُبَسُّ السويق، وتكون سرابًا، ثم تكون <span class="qpc-hafs">﴿هباء منبثا﴾</span> [الواقعة:٦]، فذلك حين تذهب مِن أصولها فلا يُرى منها شيء، فتصير الأرض كلها مستوية{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿صُنۡعَ ٱللَّهِ ٱلَّذِیۤ أَتۡقَنَ كُلَّ شَیۡءٍۚ إِنَّهُۥ خَبِیرُۢ بِمَا تَفۡعَلُونَ ۝٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٩٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء﴾</span>، قال: أحْكَم كل شيء{8}. (١١/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٤<span class="dash">-</span></span> و<span class="name-3">سفيان الثوري</span>، مثل ذلك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء﴾</span>، يقول: أحسن كل شيء خلقه وأوثقه{10}. (١١/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿الذي أتقن كل شيء﴾</span>، قال: أتْرَص{11} كل شيء، وسوّى{12}. (١١/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أتْقَنَ كُلَّ شَيْءٍ﴾</span>: أحصى كل شيء{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: أحسن كل شيء{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٦٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام بن حسان- <span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء﴾</span>، قال: أحكم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قرة بن خالد- <span class="qpc-hafs">﴿الذي أتقن كل شيء﴾</span>، قال: أوَلَمْ تر إلى كل دابة كيف تتقي على نفسها؟!{16}. (١١/٤١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- <span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء﴾</span>، قال: هدى كل شيء لمنفعته{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء﴾</span>، قال: أحسن كل شيء{18}. (١١/٤١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧٤<span class="dash">-</span></span> و<span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، مثل ذلك{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿صنع الله الذي أتقن﴾</span> يعني: الذي أحكم <span class="qpc-hafs">﴿كل شيء إنه خبير بما تفعلون﴾</span> يعني: إنّه خبير بما فعلتم. نظيرُها في الروم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٩٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله <span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء﴾</span> أحكم كل شيء{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/١٣٧، وابن أبي حاتم ٩/٢٩٣٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩٣٣.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٧٢.أخرجه إسحاق بن راهويه ١/٨٤-٨٥ (١٠) مطولًا، والبيهقي في البعث والنشور ص٣٣٦ (٦٠٩)، وابن جرير ١٦/٤٤٧-٤٤٨مطولًا، وابن أبي حاتم ٩/٢٩٢٩ (١٦٦٢٧) مطولًا، ٩/٢٩٣٣ (١٦٦٣٦) مختصرًا، والثعلبي ٧/٢٢٧ مطولًا.</p><p>وقد تقدم بتمامه مطولًا مع تخريجه في تفسير الآية السابقة.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٧٢.أخرجه ابن جرير ١٨/١٣٨، وابن أبي حاتم ٩/٢٩٣٣. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٩/٢٩٣٣.أخرجه ابن جرير ١٨/١٣٨، وابن أبي حاتم ٩/٢٩٣٤.أترص: أحكم. اللسان (ترص).أخرجه ابن جرير ١٨/١٣٨، وابن أبي حاتم ٩/٢٩٣٣ من طريق ليث، وأخرجه من طريق ابن أبي نجيح بلفظ: أبرم. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ١٨/٥٩٨، وابن أبي حاتم ٩/٢٩٣٣ من طريق أبي يحيى.أخرجه يحيى بن سلام ٢/٥٧٢.أخرجه إسحاق البستي في تفسيره ص٣٤. وعلقه ابن أبي حاتم ٩/٢٩٣٣.أخرجه يحيى بن سلام ١/٢٦٢، ٢/٥٧٢. وعزاه السيوطي إلى عبد بن حميد. وعقّب يحيى بن سلام عليه بقوله: ليس يعني الحسن: أتْقَنَ: تتقي، ولكن مِن الإتقان أن جعل كل دابة تتقي على نفسها.أخرجه ابن أبي حاتم ٩/٢٩٣٤.أخرجه ابن جرير ١٨/١٣٩. وعلَّقه ابن أبي حاتم ٩/٢٩٣٤. وعزاه السيوطي إلى عبد بن حميد.علقه ابن أبي حاتم ٩/٢٩٣٤.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٧٢.