quran[12]{c,v,t}:
27,77," <q>﴿وَإِنَّهُۥ لَهُدࣰى وَرَحۡمَةࣱ لِّلۡمُؤۡمِنِینَ ۝٧٧﴾</q> - تفسير ٥٧٧٩١- عن سعيد بن جبير- من طريق عطاء بن دينار- <q>﴿لَهُدًى﴾</q>: يعني: تِبيانًا{1}. (ز) ٥٧٧٩٢- عن عامر الشعبي -من طريق بيان- <q>﴿لَهُدًى﴾</q>، قال: هُدًى مِن الضلالة{2}. (ز) ٥٧٧٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لَهُدًى﴾</q>، قال: نور{1}. (ز) ٥٧٧٩٤- قال مقاتل بن سليمان: <q>﴿وإنه لهدى﴾</q> مِن الضلالة، <q>﴿ورحمة﴾</q> مِن العذاب لِمَن آمن به، فذلك قوله ﷿: <q>﴿للمؤمنين﴾</q> بالقرآن أنّه مِن ربك{4}. (ز) ٥٧٧٩٥- قال يحيى بن سلّام: <q>﴿وإنه لهدى ورحمة للمؤمنين﴾</q> هدًى يهتدون به إلى الجنة{5}. (ز) <q>﴿وَإِنَّهُۥ لَهُدࣰى وَرَحۡمَةࣱ لِّلۡمُؤۡمِنِینَ ۝٧٧﴾</q> - آثار متعلقة بالآية ٥٧٧٩٦- عن علي بن أبي طالب، قال: قيل لرسول الله ﷺ: إنّ أُمَّتك ستُفْتَتَن مِن بعدك. فسأل رسول الله ﷺ أو سئل: ما المخرج منها؟ فقال: «كتاب الله العزيز، الذي لا يأتيه الباطل مِن بين يديه ولا من خلفه، تنزيل من حكيم حميد، مَن ابتغى العلم في غيره أضلَّه الله، ومَن ولي هذا الأمر فحَكَم بِه عَصَمَه الله، وهو الذِّكر الحكيم، والنور المبين، والصراط المستقيم، فيه خبر مَن قبلكم، ونبأ مَن بعدكم، وحكم ما بينكم، وهو الفصل ليس بالهزل»{6}. (١١/٣٩٨) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢٠.أخرجه ابن أبي حاتم ٩/٢٩١٩.أخرجه ابن أبي حاتم ٩/٢٩٢٠.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٣.أخرجه الترمذي ٥/١٧١-١٧٢ (٣١٣٠)، والدارمي ٢/٥٢٧ (٣٣٣٢) واللفظ له. قال الترمذي: «هذا حديث غريب، لا نعرفه إلا مِن هذا الوجه، وإسناده مجهول، وفي الحارث مقال». قال ابن كثير في تفسيره ١/٢١: «وقصارى هذا الحديث أن يكون مِن كلام أمير المؤمنين علي ﵁، وقد وهم بعضهم في رفعه، وهو كلام حسن صحيح؛ على أنه قد روي له شاهد عن عبد الله بن مسعود ﵁ عن النبي ﷺ». وأورده الفتني في تذكرة الموضوعات ص٧٦. وقال الألباني في الضعيفة ١٣/٨٨٣ (٦٣٩٣): «ضعيف».
27,78," <q>﴿إِنَّ رَبَّكَ یَقۡضِی بَیۡنَهُم بِحُكۡمِهِۦۚ وَهُوَ ٱلۡعَزِیزُ ٱلۡعَلِیمُ ۝٧٨﴾</q> - تفسير ٥٧٧٩٧- قال مقاتل بن سليمان: <q>﴿إن ربك يقضي بينهم﴾</q> يعني: بين بني إسرائيل <q>﴿بحكمه وهو العزيز العليم﴾</q>{1}. (ز) ٥٧٧٩٨- قال يحيى بن سلّام: قوله ﷿: <q>﴿إن ربك يقضي بينهم بحكمه﴾</q> بين المؤمنين والكافرين في الآخرة، فيدخل المؤمنين الجنة، ويدخل الكافرين النار، <q>﴿وهو العزيز العليم﴾</q> لا أعزَّ منه، ولا أعلم منه{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٣-٥٦٤.
27,79," <q>﴿فَتَوَكَّلۡ عَلَى ٱللَّهِۖ﴾</q> - تفسير ٥٧٧٩٩- قال مقاتل بن سليمان: <q>﴿فتوكل على الله﴾</q> يعني: فثِق بالله ﷿، وذلك حين دعا إلى مِلَّة آبائه، فأمره أن يثِق بالله ﷿، ولا يهوله قول أهل مكة{1}. (ز) <q>﴿إِنَّكَ عَلَى ٱلۡحَقِّ ٱلۡمُبِینِ ۝٧٩﴾</q> - تفسير ٥٧٨٠٠- قال إسماعيل السُّدِّيّ: يعني: الإسلام{2}. (ز) ٥٧٨٠١- قال مقاتل بن سليمان: <q>﴿إنك على الحق المبين﴾</q>، يعني: على الدين البيِّن، وهو الإسلام{1}. (ز) ٥٧٨٠٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿إنك على الحق المبين﴾</q> البيِّن{4}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٦.علَّقه يحيى بن سلام ٢/٥٦٤.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٤.
27,80," <q>﴿إِنَّكَ لَا تُسۡمِعُ ٱلۡمَوۡتَىٰ وَلَا تُسۡمِعُ ٱلصُّمَّ ٱلدُّعَاۤءَ إِذَا وَلَّوۡا۟ مُدۡبِرِینَ ۝٨٠﴾</q> - قراءات ٥٧٨٠٣- عن إسماعيل بن مسلم، قال: سألتُ الحسنَ البصري عن هذا الحرف. فقال: ‹ولا يَسْمَعُ الصُّمُّ الدُّعاءَ إذا ولَّوْاْ مُدْبِرِينَ›{1}. (ز) <q>﴿إِنَّكَ لَا تُسۡمِعُ ٱلۡمَوۡتَىٰ وَلَا تُسۡمِعُ ٱلصُّمَّ ٱلدُّعَاۤءَ إِذَا وَلَّوۡا۟ مُدۡبِرِینَ ۝٨٠﴾</q> - تفسير الآية ٥٧٨٠٤- عن عروة بن الزبير، قال: ذُكِر عند عائشة أنّ ابن عمر يرفع إلى النبي ﷺ: «إنّ الميت يُعذَّب في قبره ببكاء أهله عليه». فقالت: وهِلَ{2}، إنما قال رسول الله ﷺ: «إنه لَيعذب بخطيئته أو بذنبه، وإن أهله ليبكون عليه الآن». وذاك مثل قوله: إنّ رسول الله ﷺ قام على القليب يوم بدر، وفيه قتلى بدر مِن المشركين، فقال لهم ما قال: «إنهم ليسمعون ما أقول». وقد وهِلَ، إنما قال: «إنهم ليعلمون أن ماكنت أقول لهم حق». ثم قرأت: <q>﴿إنك لا تسمع الموتى﴾</q>، <q>﴿وما أنت بمسمع من في القبور﴾</q> [فاطر:٢٢]، يقول: حين تَبَوَّءُوا مقاعدهم مِن النار{3}٤٩٠٣. (ز) ٤٩٠٣ قال ابنُ عطية (٦/٥٥٧-٥٥٨ بتصرف): «احتجَّتْ عائشة ﵂ في إنكارها أنّ النبي ﷺ أسمع موتى بدر بهذه الآية، ونظرت هي في الأمر بقياس عقليٍّ، ووقفت مع هذه الآية، وقد صحَّ أن النبيَّ ﷺ قال: «ما أنتم بأسمع منهم». فيشبه أنّ قصة بدر هي خرق عادة لمحمد ﵇ في أن رد الله إليهم إدراكًا سمعوا به مقالة، ولولا إخبار رسول الله ﷺ بسماعهم لحملنا نداءه إياهم على معنى التوبيخ لِمَن بقي من الكفرة، وعلى معنى شفاء صدور المؤمنين منهم. وقد عُورِضت هذه الآية بالسلام على القبور، وبما رُوي في ذلك من أنّ الأرواح تكون على شفير القبور في أوقات، قالوا: فلو لم يسمع الميت لم يسلم عليه. قال القاضي أبو محمد: وهذا كله غير مُعارِض للآية؛ لأن السلام على القبور إنما هو عبادة، وعند الله الثواب عليها، وهو تذكير للنفس بحالة الموت وبحالة الموتى في حياتهم، وإن جوَّزنا مع هذا أنّ الأرواح في وقت على القبور؛ فإن سَمِع فليس الروح بميت، وإنما المراد بقوله: <q>﴿إنك لا تسمع الموتى﴾</q> الأشخاص الموجودة مفارقة لأرواحها، وفيها نقول: خرقت العادة لمحمد ﵇ في أهل القليب. وذلك كنحو قوله ﷺ في الموتى إذا دخل عليهم الملَكان: «إنهم يسمعون خَفْق النِّعال»». ٥٧٨٠٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنك لا تسمع الموتى﴾</q> قال: هذا مَثَلٌ ضربه الله للكافر، كما لا يسمع الميِّت، كذلك لا يسمع الكافر ولا ينتفع به، <q>﴿ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</q> يقول: لو أنّ أصم ولّى مُدْبِرًا ثم ناديته لم يسمع، كذلك الكافر لا يسمع ولا ينتفع بما يسمع{4}. (١١/٣٩٨) ٥٧٨٠٦- تفسير إسماعيل السُّدِّيّ: قوله ﷿: <q>﴿إنك لا تسمع الموتى﴾</q>، يعني: الكفار؛ لأنهم بمنزلة الأموات في سمع الإيمان{5}. (ز) ٥٧٨٠٧- قال مقاتل بن سليمان: ثم ضرب لكفار مكة مثلًا، فقال سبحانه: <q>﴿إنك﴾</q> يا محمد <q>﴿لا تسمع الموتى﴾</q> في النِّداء، فشبَّه كفار مكة بالأموات، كما لا يسمع الميت النداء كذلك لا تسمع الكفار النداء ولا تفقهه، <q>﴿ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</q> يقول: إنّ الأصم إذا ولّى مُدبِرًا ثم ناديته لم يسمع الدعاء، وكذلك الكافر لا يسمع الإيمان إذا دعي إليه{6}. (ز) ٥٧٨٠٨- قال يحيى بن سلّام: <q>﴿إنك لا تسمع الموتى﴾</q> يعني: الذين يلقون الله بكفرهم؛ مَثَلُهم فيما يدعوهم إليه مثل الأموات الذين لا يسمعون، <q>﴿ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</q> يعنيهم. وهي تقرأ على وجه آخر: ‹ولا يَسْمَعُ الصُّمُّ الدُّعاءَ إذا ولَّوْا مُدْبِرِينَ‹، يقول: إنّ الأصم لا يسمع الدعاء إذا ولّى مدبرًا{7}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ٢/٥٦٥. وهي قراءة متواترة، قرأ بها ابن كثير، وقرأ بقية العشرة: <q>﴿ولا تُسْمِعُ الصُّمَّ﴾</q> بالتاء مضمومة، وكسر الميم، ونصب <q>﴿الصم﴾</q>. انظر: النشر ٢/٣٣٩، والإتحاف ص٤٣١.وهِلَ: سَها وغَلِط وذهب وهْمُه لغير الصّواب. النهاية (وهل).أخرجه البخاري ٥/٧٧ (٣٩٧٨)، ومسلم ٢/٦٤٣ (٩٣٢).أخرجه يحيى بن سلام ٢/٥٦٤، وابن أبي حاتم ٩/٢٩٢١ واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٥٦٤.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٤.
27,81," <q>﴿وَمَاۤ أَنتَ بِهَـٰدِی ٱلۡعُمۡیِ عَن ضَلَـٰلَتِهِمۡۖ﴾</q> - تفسير ٥٧٨٠٩- عن يحيى بن يَعْمَر -من طريق يحيى بن عقيل- قوله: <q>﴿وما انت بهادي العمي عن ضلالتهم﴾</q>، أي: ما تفعل ذلك{1}. (ز) ٥٧٨١٠- قال مقاتل بن سليمان: ثم قال ﷿ للنبي ﷺ: <q>﴿وما أنت بهادي العمي﴾</q> إلى الإيمان <q>﴿عن ضلالتهم﴾</q> يعني: عن كُفرهم{2}. (ز) ٥٧٨١١- قال يحيى بن سلّام: قوله ﷿: <q>﴿وما أنت بهادي العمي﴾</q> عن الهدى <q>﴿عن ضلالتهم﴾</q> يعني: [الذين] يموتون على كفرهم{3}. (ز) <q>﴿إِن تُسۡمِعُ إِلَّا مَن یُؤۡمِنُ بِـَٔایَـٰتِنَا فَهُم مُّسۡلِمُونَ ۝٨١﴾</q> - تفسير ٥٧٨١٢- قال مقاتل بن سليمان: <q>﴿إن تسمع﴾</q> يقول: ما تسمع الإيمان <q>﴿إلا من يؤمن بآياتنا﴾</q> إلا مَن يُصَدِّق بالقرآن أنّه مِن الله ﷿، <q>﴿فهم مسلمون﴾</q> يقول: فهم مُخلِصون بتوحيد الله ﷿{2}. (ز) ٥٧٨١٣- قال يحيى بن سلّام: <q>﴿إن تسمع إلا من يؤمن بآياتنا﴾</q> مَن أراد الله أن يؤمن، <q>﴿فهم مسلمون﴾</q> وهذا سَمْع القَبول، فأمّا الكافر فتَسْمَع أُذُناه، ولا يقبله قلبه{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢١.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٥.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٥.
27,82," <q>﴿وَإِذَا وَقَعَ﴾</q> - تفسير ٥٧٨١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإذا وقع القول عليهم﴾</q>، قال: حق عليهم{1}. (١١/٤٠٠) ٥٧٨١٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا وقع القول عليهم﴾</q>، قال: إذا وجَبَ القولُ عليهم{2}. (١١/٣٩٩) ٥٧٨١٦- قال قتادة بن دعامة، في قوله ﷿: <q>﴿وإذا وقع القول عليهم﴾</q>: أي: حق القول عليهم{3}. (ز) <q>﴿وَإِذَا وَقَعَ ٱلۡقَوۡلُ عَلَیۡهِمۡ﴾</q> - تفسير ٥٧٨١٧- عن أبي سعيد الخدري، قال: سُئِل رسولُ الله ﷺ عن قول الله: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q>. قال: «إذا تَركوا الأمرَ بالمعروف، والنهي عن المنكر؛ وجب السُّخْط عليهم»{4}. (١١/٣٩٩) ٥٧٨١٨- عن عبد الله بن مسعود -من طريق عبد الله بن عتبة- قال: أكثِروا الطوافَ بالبيت قبل أن يُرفَع وينسى الناسُ مكانه، وأكثِروا تلاوة القرآن قبل أن يُرْفَع. قيل: وكيف يُرفَع ما في صدور الرجال؟ قال: يسري عليهم ليلًا، فيُصْبِحون منه قفرًا، وينسون قول: لا إله إلا الله. ويقعون في قول الجاهلية وأشعارهم، فذلك حين يقع القول عليهم{5}. (١١/٤٠٠) ٥٧٨١٩- عن حذيفة -من طريق أبي ظبيان- قال: واللهِ، ما تلا عن قوم لوط{6}. (ز) ٥٧٨٢٠- عن حفصة بنت سيرين، قالت: سألتُ أبا العالية الرِّياحي عن قوله: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، ما وقوع القول عليهم؟ فقال: أوْحى اللهُ إلى نوح أنّه لن يُؤمِن مِن قومك إلا مَن قد آمن. قالت: فكأنّما كشف عن وجهي شيئًا{7}. (١١/٣٩٩) ٥٧٨٢١- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿وقع القول عليهم﴾</q>، قال: حق العذاب{8}. (ز) ٥٧٨٢٢- عن موسى أبي العلا، أنّ الحسن البصري سُئِل عن هذه الآية: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q>. قال: فجاء، فقال: إنّ الله يومئذ على أهل الأرض ساخِط{5}. (ز) ٥٧٨٢٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا وقع القول عليهم﴾</q>: والقول: الغضب{10}. (ز) ٥٧٨٢٤- قال مقاتل بن سليمان: <q>﴿وإذا وقع القول عليهم﴾</q>، يقول: إذا نزل العذاب بهم{11}. (ز) ٥٧٨٢٥- عن مقاتل بن حيّان -من طريق شبيب- في قوله: <q>﴿وإذا وقع القول عليهم﴾</q>، قال: السخط{5}. (ز) ٥٧٨٢٦- قال عبد الملك ابن جُرَيج -من طريق حجاج-: القول: العذاب{13}. (ز) <q>﴿أَخۡرَجۡنَا لَهُمۡ﴾</q> - تفسير ٥٧٨٢٧- عن عبد الله بن عمر، عن النبي ﷺ، في قوله: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، قال: «ذاك حين لا يأمرون بمعروف، ولا ينهون عن منكر»{4}. (١١/٣٩٩) ٥٧٨٢٨- عن عبد الله بن عمر -من طريق عطية العوفي- في قوله: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، قال: إذا لم يأمروا بالمعروف، ولم ينهوا عن المنكر{15}. (١١/٣٩٩) ٥٧٨٢٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، مثله{16}. (ز) ٥٧٨٣٠- عن عطية [العوفي] -من طريق شعبة- في قوله: <q>﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، قال: إذا لم يعرِفوا معروفًا، ولم يُنكِروا منكرًا{16}. (ز) ٥٧٨٣١- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، قال: إذا لم يأمروا بالمعروف، ولم ينهَوا عن المنكر{18}. (ز) <q>﴿دَاۤبَّةࣰ﴾</q> - تفسير ٥٧٨٣٢- عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «إذا كان الوعدُ الذي قال الله: <q>﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</q>؛ قال: ليس ذلك حديثًا ولا كلامًا، ولكنه سِمَةٌ تَسِم مَن أمرها الله به، فيكون خروجُها مِن الصفا ليلةَ منى، فيصبحون بين رأسها وذنبها، لا يدحض داحض، ولا يخرج خارج، حتى إذا فرغت مِمّا أمرها الله، فهلك مَن هلك، ونجا مَن نجا، كان أول خطوة تضعها بأنطاكية»{19}. (١١/٤٠١) ٥٧٨٣٣- عن عمر بن الخطاب -من طريق ابن شوذب- قال: لا تخرج الدابة حتى لا يبقى في الأرض مؤمن، واقرؤوا إن شئتم: <q>﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض تكلمهم﴾</q> الآية{20}. (ز) ٥٧٨٣٤- عن عبد الله بن عباس -من طريق عكرمة- قال: الدابة التي يخرج الله تعالى <q>﴿من الأرض تكلمهم﴾</q> هو الثعبان الذي كان في جوف الكعبة، فاختطفه العقاب، فألقاه بأصل حراء لِمَخْسَفِ العماليق بقية قوم عاد{21}. (ز) ٥٧٨٣٥- قال مقاتل بن سليمان: <q>﴿أخرجنا لهم دابة من الأرض﴾</q> تخرج مِن الصفا الذي بمكة{11}. (ز) <q>﴿دَاۤبَّةࣰ﴾</q> - آثار متعلقة بالآية ٥٧٨٣٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «إن بين يدي الساعة: الدجال، والدابة، ويأجوج ومأجوج، والدخان، وطلوع الشمس من مغربها»{23}. (١١/٤٠٥) ٥٧٨٣٧- عن وهب بن مُنَبِّه، قال: أول الآيات الروم، ثم الدجال، والثالثة يأجوج ومأجوج، والرابعة عيسى، والخامسة الدخان، والسادسة الدابة{24}. (١١/٤١٢) <q>﴿دَاۤبَّةࣰ﴾</q> - فصل ٥٧٨٣٨- عن النزال بن سبرة، قال: قيل لعلي بن أبي طالب: إنّ ناسًا يزعمون: أنّك دابة الأرض. فقال: واللهِ، إنّ لِدابة الأرض ريشًا وزغبًا، وما لي ريش ولا زغب، وإن لها لَحافرًا، وما لي مِن حافر، وإنها لتخرج حضر الفرس الجواد ثلاثًا، وما خرج ثلثاها{25}. (١١/٤٠٩) ٥٧٨٣٩- عن محمد بن كعب القرظي، عن علي بن أبي طالب، أنّه كان إذا سُئِل عن الدابة قال: أما –واللهِ- ما لها ذَنَب، وإن لها لِحْيَة{26}. (ز) ٥٧٨٤٠- عن أبي هريرة -من طريق أبي مريم- قال: إنّ الدابة فيها مِن كل لون، ما بين قرنيها فرسخ للراكب{25}. (١١/٤٠٩) ٥٧٨٤١- عن عمر بن الحكم، أنّه سمع عبد الله بن عمرو بن العاص يقول: تخرج الدابة مِن شِعب، فيمسُّ رأسُها السحابَ، ورجلاها في الأرض ما خرجتا، فتمرُّ بالإنسان يصلي، فتقول: ما الصلاة من حاجتك. فَتَخْطِمُهُ{28}{29}. (ز) ٥٧٨٤٢- عن عبد الله بن عمرو بن العاص -من طريق حماد بن سلمة، عن طلحة بن عبد الله بن كريز- قال: تخرج الدابةُ، فيفزع الناسُ إلى الصلاة، فتأتي الرجلَ وهو يصلي، فتقول: طوِّل ما شئت أن تطول، فواللهِ، لأخْطِمَنَّك{30}. (١١/٤٠٣) ٥٧٨٤٣- عن عبد الله بن عمرو بن العاص، قال: الدابة: زغباء، ذات وبَرٍ ورِيش{31}. (١١/٤٠٢) ٥٧٨٤٤- عن قابوس بن أبي ظبيان، أنّ أباه حدَّثه، قال: سألنا عبد الله بن عباس عن الدابة. فقال: هي مثل الحربة الضخمة{26}. (ز) ٥٧٨٤٥- عن عبد الله بن عباس: الدابة مؤلفة، ذات زَغَب وريش، فيها مِن ألوان الدواب كلها، وفيها مِن كل أمة سيما، وسيماها مِن هذه الأمة أنّها تتكلم بلسان عربي مبين، تكلمهم بكلامهم{33}. (١١/٤١١) ٥٧٨٤٦- عن عبد الله بن عباس، قال: الدابة ذات وبَر وريش، مؤلفة فيها مِن كل لون، لها أربع قوائم، تخرج بعقب من الحاج{31}. (١١/٤٠٢) ٥٧٨٤٧- عن عامر الشعبي -من طريق داود بن يزيد الأودي- قال: إنّ دابة الأرض ذات وبر، تناغي السماء{35}. (١١/٤٠٢) ٥٧٨٤٨- عن الحسن البصري -من طريق هشام-: أنّ موسى ﵇ سأل ربَّه أن يُرِيَه الدابة، فخرجت ثلاثة أيام ولياليهن تذهب في السماء، لا يرى [واحدًا] مِن طرفيها. قال: فرأى منظرًا فظيعًا، فقال: ربِّ، رُدَّها. فرَدَّها{36}. (١١/٤٠٢) ٥٧٨٤٩- قال وهب بن مُنَبِّه: وجهها وجه رجل، وسائر خَلْقها كخَلْق الطير ...{37}٤٩٠٤. (ز) ٤٩٠٤ ذكر ابنُ عطية (٦/٥٦٠) أنه رُوي: أنها دابة مبثوث نوعها في الأرض، فهي تخرج في كل بلد وفي كل قوم، ثم علَّق بقوله: «فقوله -على هذا التأويل-: <q>﴿دابَّة﴾</q> إنما هو اسم جنس». ٥٧٨٥٠- عن قتادة بن دعامة -من طريق مَعْمَر- قال: هي دابة ذات زغب وريش، ولها أربع قوائم، تخرج مِن بعض أودية تهامة{38}. (ز) ٥٧٨٥١- عن أبي الزبير -من طريق ابن جريج- أنّه وصف الدابة، فقال: رأسها رأس ثور، وعينها عين خنزير، وأذنها أذن فيل، وقرنها قرن أيل، وعنقها عنق نعامة، وصدرها صدر أسد، ولونها لون نمر، وخاصرتها خاصرة هرة، وذنبها ذنب كبش، وقوائمها قوائم بعير، بين كل مفصلين منها اثنا عشر ذراعًا، تخرج معها عصا موسى، وخاتم سليمان، ولا يبقى مؤمن إلا نكتت في مسجده بعصا موسى نكتة بيضاء، فتفشو تلك النكتة حتى يَبْيَضَّ لها وجهه، ولا يبقى كافر إلا نكتت في وجهه نكتة سوداء بخاتم سليمان، فتفشو تلك النكتة حتى يَسْوَدَّ لها وجهه، حتى إن الناس يتبايعون في الأسواق: بكم ذا، يا مؤمن؟ وبكم ذا، يا كافر؟{39}. (١١/٤١١) ٥٧٨٥٢- قال مقاتل بن سليمان: لها أربع قوائم، وزغب وريش، ولها جناحان، واسمها: أفضى، فإذا خرجت بلغ رأسُها السحابَ{11}. (ز) ٥٧٨٥٣- عن أبي هريرة، قال: قال رسول الله ﷺ: «تخرج دابة الأرض ومعها عصا موسى، وخاتم سليمان، فتجلو وجْهَ المؤمن بالخاتم، وتخطم أنفَ الكافر بالعصا، حتى يجتمع الناسُ على الخوان، يُعرَف المؤمن من الكافر»{41}. (١١/٤٠٦) ٥٧٨٥٤- عن أبي هريرة، أن رسول الله ﷺ قال: «تخرج الدابة يوم تخرج وهي ذات عَصَب وريش، تُكَلِّم الناس، فتنقط في وجه المؤمن نقطة بيضاء، فيَبْيَضُّ وجهه، وتنقط في وجه الكافر نقطة سوداء، فيَسْوَدُّ وجهه، فيتبايعون في الأسواق بعد ذلك: بِمَ تبيع هذا، يا مؤمن؟ وبم تبيع هذا، يا كافر؟ ثم يخرج الدجال وهو أعور، على عينه ظَفَرة{42} غليظة، مكتوب بين عينيه: «ك ف ر»، يقرأه كلُّ مؤمن وكافر»{4}. (١١/٤٠٣) ٥٧٨٥٥- عن أبي أُمامة، عن النبي ﷺ، قال: «تخرج الدابة، فتَسِمُ الناسَ على خراطيمهم، ثم يغمرون فيكم، حتى يشتري الرجلُ الدابةَ، فيُقال: مِمَّن اشتريت؟ فيقال: مِن الرجل المخطم»{44}. (١١/٤٠٤) ٥٧٨٥٦- عن حذيفة بن اليمان، قال: تخرج الدابة مرتين قبل يوم القيامة، حتى يضرب فيها رجال، ثم تخرج الثالثة عند أعظم مساجدكم، فتأتي القوم وهم مجتمعون عند رجل، فتقول: ما يجمعكم عند عدوِّ الله؟ فيبتدرون، فتَسِم المؤمنَ والكافرَ، حتى إنّ الرجلين لَيتبايعان، فيقول هذا: خُذ، يا مؤمن. ويقول هذا: خذ، يا كافر{45}. (١١/٤١٢) ٥٧٨٥٧- عن محمد بن إسحاق: أنّه بلغه عن عبد الله بن عمرو بن العاص، قال: تخرج دابة الأرض ومعها خاتم سليمان وعصا موسى، فأمّا الكافر فتختم بين عينيه بخاتم سليمان، وأما المؤمن فتمسح وجهه بعصا موسى، فيَبْيَضُّ{38}. (ز) ٥٧٨٥٨- عن عبد الله بن عمرو بن العاص -من طريق عبد الرحمن بن البيلماني- قال: يبيت الناسُ يسيرون إلى جمع، وتبيت دابة الأرض تسري إليهم، فيصبحون قد جعلتهم بين رأسها وأذنيها، فما مِن مؤمن إلا تمسحه، ولا كافر ولا منافق إلا تخطمه، وإنّ التوبة لَمفتوحة{47}. (ز) ٥٧٨٥٩- عن عبد الله بن عمرو بن العاص -من طريق العلاء بن زياد- قال: لا تقوم الساعة حتى يجتمع أهلُ بيت على الإناء الواحد، فيعرفون مؤمنيهم مِن كُفّارهم. قالوا: كيف ذاك؟ قال: إن الدابة تخرج وهي ذامَّةٌ للناس، تمسح كلَّ إنسان على مسجده، فأما المؤمن فتكون نكتة بيضاء، فتفشو في وجهه حتى يبيضَّ لها وجهه، وأما الكافر فتكون نكتة سوداء، فتفشو في وجهه حتى يسوَدّ لها وجهه، حتى إنهم لَيتبايعون في أسواقهم، فيقولون: كيف تبيع هذا، يا مؤمن؟ وكيف تبيع هذا، يا كافر؟ فما يرد بعضهم على بعض{48}. (١١/٤٠٢) ٥٧٨٦٠- عن عبد الله بن عمر -من طريق ابن البيلماني- قال: تخرج الدابة ليلةَ جَمْع، والناس يسيرون إلى منى، فتحملهم بين نحرها وذنبها، فلا يبقى منافق إلا خطمته، وتمسح المؤمن، فيصبحون وهم بِشَرٍّ مِن الدجال{49}. (١١/٤٠٩) ٥٧٨٦١- عن صدقة بن يزيد -من طريق ضمرة- قال: تجيء الدابة إلى الرجل وهو قائم يصلي في المسجد، فتكتب بين عينيه: كذاب{50}. (١١/٤١١) <q>﴿مِّنَ ٱلۡأَرۡضِ﴾</q> - تفسير ٥٧٨٦٢- عن حذيفة بن اليمان، قال: ذكر رسول الله ﷺ الدابة، فقال حذيفة: يا رسول الله، مِن أين تخرج؟ قال: «مِن أعظم المساجد حرمةً على الله، بينما عيسى يطوف بالبيت ومعه المسلمون إذ تضطرب الأرض مِن تحتهم، تُحَرِّك القنديل، وتَشُقُّ الصفا مما يلي المسعى، وتخرج الدابة مِن الصفا، أول ما يبدو رأسها، ملمعة ذات وبَر وريش، لن يدركها طالب، ولن يفوتها هارِب، تسم الناس؛ مؤمن وكافر، أمّا المؤمن فيرى وجهه كأنه كوكب دري، وتكتب بين عينيه: مؤمن، وأَمّا الكافر فتنكت بين عينيه نكتة سوداء: كافر»{51}. (١١/٤٠٥) ٥٧٨٦٣- عن أبي هريرة، قال: قال رسول الله ﷺ: «بئس الشعب جياد». مرتين أو ثلاثًا، قالوا: وبِم ذاك، يا رسول الله؟ قال: «تخرج منه الدابة، فتصرخ ثلاث صرخات، فيسمعها مَن بين الخافقين»{52}. (١١/٤٠٨) ٥٧٨٦٤- عن أبي هريرة قال: قال رسول الله ﷺ: «تخرج دابة الأرض من جياد، فيبلغ صدرها الركن، ولم يخرج ذنبها بعد». قال: «وهي دابة ذات وبر وقوائم»{53}. (١١/٤٠٨) ٥٧٨٦٥- عن بريدة، قال: ذهب بي رسول الله ﷺ إلى موضع بالبادية، قريب من مكة، فإذا أرض يابسة حولها رمل، فقال رسول الله ﷺ: «تخرج الدابة مِن هذا الموضع». فإذا شبر في شبر{54}. (١١/٤٠٩) ٥٧٨٦٦- عن حذيفة بن أسيد، أُراه رفعه، قال: «تخرج الدابة مِن أعظم المساجد حرمة، فبينما هم قعود بربو الأرض، فبينما هم كذلك، إذ تصدَّعَتْ».= (ز) ٥٧٨٦٧- قال ابن عيينة: تخرج حين يسري الإمام مِن جَمْع، وإنما جعل سابق الحاج ليخبر الناس أنّ الدابة لم تخرج{55}. (١١/٤٠٤) ٥٧٨٦٨- عن عبد الله بن عمر، أنه قال: ألا أريكم المكانَ الذي قال لي رسول الله ﷺ أنّ دابة الأرض تخرج منه! فضرب بعصاه قبل الشق الذي في الصفا{56}. (١١/٤٠٥) ٥٧٨٦٩- عن حذيفة بن أسيد الغفاري، قال: ذكر رسول الله ﷺ الدابة، فقال: «لها ثلاث خرجات مِن الدهر، فتخرج خرجة في أقصى البادية، ولا يدخل ذكرها القرية -يعني: مكة-، ثم تكمن زمانًا طويلًا، ثم تخرج خرجة أخرى دون تِلك، فيعلو ذكرُها في أهل البادية، ويدخل ذكرها القرية». يعني: مكة. قال رسول الله ﷺ: «ثم بينما الناس في أعظم المساجد على الله حرمة وأكرمها -المسجد الحرام- لم يرعهم إلا وهي تَرْغو{57} بين الركن والمقام، وتنفض عن رأسها التراب، فارفَضَّ{58} الناس عنها شتى، وتثبت عصابةٌ مِن المؤمنين، ثم عرفوا أنهم لن يعجزوا الله، فبدأت بهم، فجلَّت وجوهَهم حتى جعلتها كأنها الكوكب الدري، وولت في الأرض لا يدركها طالب، ولا ينجو منها هارب، حتى إنّ الرجل ليتعوذ منها بالصلاة، فتأتيه من خلفه، فتقول: يا فلان، الآن تصلي؟! فيُقْبِل عليها، فتَسِمُه في وجهه، ثم تنطلق، ويشترك الناس في الأموال، ويصطحبون في الأمصار، يعرف المؤمن مِن الكافر، حتى إن المؤمن ليقول: يا كافر، اقضِني حقِّي. وحتى إن الكافر ليقول: يا مؤمن، اقضني حقِّي»{59}. (١١/٤٠٧) ٥٧٨٧٠- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «تخرج دابة الأرض، ولها ثلاث خرجات، فأول خرجة منها بأرض البادية، والثانية في أعظم المساجد وأشرفها وأكرمها، ولها عنق مُشْرِف، يراها مَن بالمشرق كما يراها مَن بالمغرب، ولها وجه كوجه إنسان، ومنقار كمنقار الطير، ذات وبر وزغب، معها عصا موسى، وخاتم سليمان بن داود، تنادي بأعلى صوتها: <q>﴿إن الناس كانوا بآياتنا لا يوقنون﴾</q>». ثم بكى رسول الله ﷺ، قيل: يا رسول الله، وما بعدُ؟ قال: «هنات وهنات، ثم خصب وريف حتى الساعة»{60}. (١١/٤٠٤) ٥٧٨٧١- عن حذيفة بن اليمان -من طريق أبي الطفيل- قال: إنّ للدابة ثلاث خرجات، خرجة تخرج في بعض البوادي، ثم تَنكَمِي{61}، وخرجة تخرج في بعض القرى حتى تذكر وحتى تهريق الأمراء فيها الدماء، ثم تنكمي، فبينما الناس عند أشرف المساجد وأفضلها وأعظمها -حتى ظننا أنه يسمي المسجد الحرام، وما سماه- إذ ارتفعت بهم الأرض، فانطلق الناس هِرابًا، فلا يفوتها هارب، وتبقى عصابة من المسلمين، فيقولون: إنّه لا ينجينا مِن أمر الله شيء. فتخرج عليهم الدابة، فتجلو وجوههم مثل الكوكب الدري، ثم تنطلق، فلا يدركها طالِب، ولا يفوتها هارِب، ثم تأتي الرجلَ وهو يصلي، فتقول: أتتعوَّذُ بالصلاة؟! واللهِ، ما كنت مِن أهل الصلاة. فيلتفت إليها، فتخطمه، وتجلو وجه المؤمن، وتخطم الكافر، قال: قلنا: وما الناسُ يومئذ، يا حذيفة؟ قال: جيران في الرباع، وشركاء في الأموال، أصحاب في الأسفار{62}. (ز) ٥٧٨٧٢- عن عائشة -من طريق أبي إسحاق- قالت: الدابة تخرج مِن أجياد{63}. (١١/٤٠٥) ٥٧٨٧٣- عن عبد الله بن عمرو بن العاص -من طريق صالح مولى التوأمة- قال: تخرج الدابة بأجياد مما يلي الصفا{64}. (١١/٤٠٣) ٥٧٨٧٤- عن عطاء، قال: رأيت عبد الله بن عمرو بن العاص -وكان منزله قريبًا مِن الصفا- رفع قدمه وهو قائم، وقال: لو شئتُ لم أضعها حتى أضعها على المكان الذي تخرج منه الدابة{65}. (ز) ٥٧٨٧٥- عن حسان بن حِمَّصَةَ، قال: سمعتُ عبد الله بن عمرو بن العاص يقول: لو شئتُ لانتعلت بنعلي هاتين، فلم أمسَّ الأرض قاعدًا حتى أقف على الأحجار التي تخرج الدابة من بينها، ولكأني بها قد خرجت في عَقِب ركب مِن الحاج. قال: فما حججتُ قطُّ إلا خفتُ تخرج بعقبنا{66}. (ز) ٥٧٨٧٦- عن عبد الله بن عمرو بن العاص -من طريق عمر بن الحكم بن ثوبان- قال: تخرج الدابة مِن شِعب بالأجياد، رأسها يمس السحاب، وما خرجت رِجلاها من الأرض، تأتي الرجل وهو يصلي، فتقول: ما الصلاة من حاجتك، ما هذا إلا تعوذًا ورياءً! فتخطمه{67}. (١١/٤١٢) ٥٧٨٧٧- عن عبد الله بن عمرو بن العاص أنه قال وهو يومئذ بمكة: لو شئت لأخذت سبتيتي هاتين، ثم مشيت حتى أدخل الوادي التي تخرج منه دابة الأرض، فإنها تخرج، وهي آية للناس، فتلقى المؤمن فتسمه في وجهه واكتةً{68}، فيبيض لها وجهه، وتسم الكافر واكتةً، فيسود لها وجهه، وهي دابة ذات زغب وريش، فتقول: <q>﴿أن الناس كانوا بآياتنا لا يوقنون﴾</q>{69}. (١١/٤٠٦) ٥٧٨٧٨- عن عبد الله بن عمرو، قال: تخرج الدابة من تحت صخرة بجياد، وتستقبل المشرق، فتصرخ صرخة تنفذه، ثم تستقبل الشام، فتصرخ صرخة تنفذه، ثم تستقبل المغرب، فتصرخ صرخة تنفذه، ثم تستقبل اليمن، فتصرخ صرخة تنفذه، ثم تروح مِن مكة فتصبح بعسفان. قيل: ثم ماذا؟ قال: لا أعلم{70}. (١١/٤١٠) ٥٧٨٧٩- عن عبد الله بن عباس -من طريق قتادة-: أنّ دابة الأرض تخرج مِن بعض أودية تهامة، ذات زغب وريش، لها أربع قوائم، فتنكت بين عيني المؤمن نكتة يبيض منها وجهه، وتنكت بين عيني الكافر نكتة سوداء يسود منها وجهه{71}. (١١/٤٠٦) ٥٧٨٨٠- عن عبد الله بن عباس: أنّه قرع الصفا بعصاه وهو محرم، وقال: إنّ الدابة لَتسمع قرع عصاي هذه{37}. (ز) ٥٧٨٨١- عن عبد الله بن عمر -من طريق عطية- قال: تخرج الدابة مِن صِدْع في الصفا كجري الفرس ثلاثة أيام، لم يخرج ثلثها{73}. (١١/٤١٠) ٥٧٨٨٢- عن عبد الله بن عمر، قال: تخرج الدابة من جبل جياد في أيام التشريق، والناس بمنى. قال: فلذلك جاء سابق الحاجِّ بخبر سلامة الناس{74}. (١١/٤١٠) ٥٧٨٨٣- عن إبراهيم [النخعي] -من طريق سماك- قال: تخرج الدابة مِن مكة{75}. (١١/٤٠٣) ٥٧٨٨٤- عن عبد الصمد بن معقل، أنّه سمع عمه وهب بن منبه يقول: قال عزير: أتاني الملَك، قلت: أخبِرني: ما بقي مِن الدنيا؟ قال: لا عِلْم لي، ولِمَ تسألني عما لا أعلم؟! قال: أنا أعلم أنّه عند انقضاء الدنيا واقتراب الآخرة، وآية ذلك أن يكثر الكذب، ويقل الصدق، ويظهر الفجور، وينعدم البر، وتعود الأرض عقيمًا مِن الأنهار، وترى الشمس في أثر ذلك من مغربها، وتقطر الشجر دمًا، وتجول الأنواء، وتنطق الحجارة، ويملك من لم يكن برجّالة{76} الملك، وتخبر الطير، وتخرج من تحت سدوم دابة تكلم الناس كل يسمعها ...{25}. (ز) <q>﴿تُكَلِّمُهُمۡ أَنَّ ٱلنَّاسَ كَانُوا۟ بِـَٔایَـٰتِنَا لَا یُوقِنُونَ ۝٨٢﴾</q> - قراءات ٥٧٨٨٥- عن الأعمش: في قراءة عبد الله [بن مسعود]: (تُكَلِّمُهُم بِأَنَّ النّاسَ){78}. (ز) ٥٧٨٨٦- قرأ أبو زرعة بن عمرو: (تَكْلِمُهُم) بفتح التاء، وتخفيف اللام، بمعنى: تَسِمُهم{79}. (ز) ٥٧٨٨٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أخْرَجْنا لَهُمْ دَآبَّةً مِّنَ الأَرْضِ تُكَلِّمُهُمْ﴾</q>، قال: وهي في بعض القراءة: (تُحَدِّثُهُمْ أنَّ النّاسَ كانُواْ بِآياتِنا لا يُوقِنُونَ){80}. (١١/٣٩٩) ٥٧٨٨٨- عن عاصم بن أبي النجود أنه قرأ: <q>﴿دَآبَّةً مِّنَ الأَرْضِ تُكَلِّمُهُمْ﴾</q> مشددة مِن الكلام، <q>﴿أنَّ النّاسَ﴾</q> بنصب الألف{81}. (١١/٤٠١) ٥٧٨٨٩- عن عاصم الجحدري -من طريق هارون- (تَكْلِمُهُمْ): تخدشهم{82}. (ز) ٥٧٨٩٠- قال يحيى بن سلّام: وبعضهم يقرأها: (تَكْلِمُهُمْ)، أي: تَسِمُهم{83}٤٩٠٥. (ز) ٤٩٠٥ اختلف القراء في قراءة قوله تعالى: <q>﴿تكلمهم﴾</q> على وجهين: الأول: بضم التاء وتشديد اللام، هكذا: (تُكَلِّمُهُمْ)، بمعنى: تخبرهم وتحدثهم. وهي قراءة عامة قُرّاء الأمصار. والثاني: بفتح التاء وتخفيف اللام، هكذا: (تَكْلِمُهُمْ)، بمعنى: تَسِمُهُم. وهي قراءة أبي زرعة بن عمرو. ورجَّحَ ابنُ جرير (١٨/١٢٧) القراءة الأولى، فقال: «القراءة التي لا أستجيز غيرها في ذلك ما عليه قرّاء الأمصار». واختلفوا كذلك في قراءة قوله: <q>﴿إن الناس﴾</q> فقرأ قوم:<q>﴿أن الناس﴾</q> بالفتح، وقرأ آخرون بالكسر، وذكر ابنُ عطية (٦/٥٦١) أن قراءة عبد الله (تُكَلِّمُهُم بِأَنَّ) تصديق للفتح، وبين أنه قوله: <q>﴿إن الناس﴾</q> -على قراءة الفتح- يكون من تمام كلام الدابة. ثم قال: «ويحتمل أن يكون ذلك من كلام الله ﷿». <q>﴿تُكَلِّمُهُمۡ﴾</q> - تفسير ٥٧٨٩١- عن أبي الزعراء: أنّ رجلًا سأل عبد الله عن الدابة، فقال له: سلْ عليًّا، فإنه بذلك. فسأل عليًّا، فقال: تأكل الطعام، وتمشي في الأسواق، وتكلم الناس <q>﴿أن الناس كانوا بآياتنا لا يوقنون﴾</q>{50}٤٩٠٦. (ز) ٤٩٠٦ علَّقَ ابن كثير (١٠/ ٤٣٠) على قول عليّ هذا بقوله: «واختاره ابن جرير، وفي هذا نظر لا يخفى». ٥٧٨٩٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿دابة من الأرض تكلمهم﴾</q>، قال: تُحَدِّثهم{85}. (١١/٤٠٠) ٥٧٨٩٣- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿تكلمهم﴾</q>، قال: كلامُها تنبئهم <q>﴿أن الناس كانوا بآياتنا لا يوقنون﴾</q>{86}. (١١/٤٠٠) ٥٧٨٩٤- عن أبي داود نفيع الأعمى، قال: سألت عبد الله بن عباس عن قوله: <q>﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</q> أو: (تَكْلِمُهُمْ)؟ قال: كل ذلك –واللهِ- تفعل، تُكَلِّمُ المؤمن، وتَكْلِمُ الكافر؛ تَجْرَحُه{87}٤٩٠٧. (١١/٤٠١) ٤٩٠٧ علَّقَ ابنُ كثير (١٠/ ٤٣٠) على قول ابن عباس هذا، بقوله: «وهو قول حسن، ولا منافاة». ٥٧٨٩٥- عن المغيرة، عن إبراهيم النخعي، قال: قلنا له: <q>﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، أو (تَكْلِمُهُمْ)؟ قال: لا بل تكلِّمهم. يعني: الكلام{88}. (ز) ٥٧٨٩٦- قال وهب بن مُنَبِّه: ... فتخبر مَن رآها: أنّ أهل مكة كانوا بمحمد والقرآن لا يوقنون{37}. (ز) ٥٧٨٩٧- عن الحسن البصري -من طريق يونس بن عبيد- قال: تخرج دابة إذا فسُد الناس، ولهم دابة تكلمهم كلامًا{50}. (ز) ٥٧٨٩٨- تفسير الحسن البصري، في قوله <q>﴿كانوا بآياتنا لا يوقنون﴾</q>: تكلمهم بهذا الكلام{91}. (ز) ٥٧٨٩٩- عن عطية العوفي -من طريق شعبة- <q>﴿أخرجنا لهم دابة من الأرض تكلمهم﴾</q>، قال: معها عصا، تمسح وجه المؤمن، وتخطم وجه الكافر{92}. (ز) ٥٧٩٠٠- قال إسماعيل السُّدِّيّ: تكلمهم ببطلان الأديان سوى دين الإسلام{93}. (ز) ٥٧٩٠١- عن صدقة بن يزيد -من طريق ضمرة- قال: تجيء الدابةُ إلى الرجل وهو قائم يصلي في المسجد، فتكتب بين عينيه: كذّاب{50}. (ز) ٥٧٩٠٢- قال مقاتل بن سليمان: <q>﴿تكلمهم﴾</q> بالعربية، تقول: <q>﴿أن الناس كانوا بآياتنا لا يوقنون﴾</q>{95}. (ز) <q>﴿أَنَّ ٱلنَّاسَ﴾</q> - تفسير ٥٧٩٠٣- عن إسماعيل السُّدِّيّ، في قوله ﷿: <q>﴿تكلمهم أن الناس﴾</q>، قال: يعني: أهل مكة خاصة{96}. (ز) ٥٧٩٠٤- قال مقاتل بن سليمان: تقول: <q>﴿أن الناس﴾</q> يعني: كفار مكة{97}. (ز) ٥٧٩٠٥- قال يحيى بن سلّام: وهم مشركو أهل مكة{98}. (ز) <q>﴿كَانُوا۟ بِـَٔایَـٰتِنَا لَا یُوقِنُونَ ۝٨٢﴾</q> - تفسير ٥٧٩٠٦- قال مقاتل بن سليمان: <q>﴿كانوا بآياتنا﴾</q> يعني: بخروج الدابة <q>﴿لا يوقنون﴾</q> هذا قول الدابة للناس: إنّ الناس بخروجي لا يوقنون. لأن خروجها آية من آيات الله ﷿، فإذا رآها الناس كلهم عادت إلى مكانها مِن حيث خرجت{11}. (ز) ٥٧٩٠٧- قال يحيى بن سلّام: وقال بعضهم: تقول: إنّ الناس كانوا بي لا يوقنون ... <q>﴿أن الناس كانوا بآياتنا لا يوقنون﴾</q> لا يؤمنون{98}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/١١٩. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٨/١١٩. وعزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ٢/٥٦٥.عزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٩/٢٩٢٢.أخرجه ابن أبي حاتم ٩/٢٩٢٢. ولفظ الأثر كذا وقع في مطبوعة المصدر.أخرجه عبد الرزاق ٢/٨٢ مختصرًا، وابن جرير ١٨/١٢٠ وآخره:... قالت: فكأنما كان على وجهي غطاء فكُشف، وابن أبي حاتم ٩/٢٩٢٢ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١١٩.أخرجه ابن أبي حاتم ٩/٢٩٢٢.أخرجه ابن جرير ١٨/١٢٠. وعلقه يحيى بن سلام ٢/٥٦٥.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه ابن أبي حاتم ٩/٢٩٢٢.أخرجه ابن جرير ١٨/١٢٠.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٨٥، وابن أبي شيبة (ت: محمد عوامة) ١٩/١٩٨ (٣٥٧٩٦)، ونعيم بن حماد في الفتن (١٨٥٤، ١٨٦٧)، وابن أبي الدنيا في كتاب الأمر بالمعروف -موسوعة الإمام ابن أبي الدنيا ٢/٢٠١ (٣٠)-، وابن جرير ١٨/١٢٠-١٢١، وابن أبي حاتم ٩/٢٩٢١، والحاكم ٤/٤٨٥. وعزاه السيوطي إلى ابن المبارك في الزهد، والفريابي، وعبد بن حميد، وابن مردويه.أخرجه ابن جرير ١٨/١٢١.أخرجه ابن جرير ١٨/١٢١.أخرجه إسحاق البستي في تفسيره ص٢٨.أخرجه نعيم بن حماد في كتاب الفتن ٢/٦٦٧، والفاكهي في أخبار مكة ٤/١٨ (٢٣٥٩) بلفظ: لا يدخل داخل، من طريق محمد بن عبد الرحمن بن البيلماني، عن أبيه، عن ابن عمر به. وعزاه السيوطي إلى ابن مردويه. إسناده ضعيف جدًّا؛ فيه محمد بن الرحمن بن البيلماني، قال عنه ابن حجر في التقريب (٦٠٦٧): «ضعيف، وقد اتهمه ابن عدي وابن حبان». وفيه أيضًا أبوه عبد الرحمن بن البيلماني، قال عنه ابن حجر في التقريب (٣٨١٩): «ضعيف».أخرجه نعيم بن حماد في كتاب الفتن ٢/٦٦٤.أخرجه الفاكهي في أخبار مكة ٤/٣٧-٣٨.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه ابن بشران في الأمالي ١/٢٣٣ (٥٣٧)، والطبراني في كتاب الدعاء ص ٦١٦ (٢٢٤٨)، من طرق عن عبد الله بن رجاء، عن عباد بن إسحاق، عن سعيد المقبري، عن أبي هريرة به. إسناده حسن.أخرجه نعيم بن حماد (١٤٥٣، ١٤٥٨، ١٨٥٣).أخرجه ابن أبي حاتم ٩/٢٩٢٥.أخرجه ابن أبي حاتم ٩/٢٩٢٤.أخرجه ابن أبي حاتم ٩/٢٩٢٥.فَتَخْطِمُه: تُصيب خَطْمه، أي: أنفه، فتترك أثرًا كأثر خِطام البعير، وهو الكَيّ الذي يكون من أنفه إلى خَدِّه. النهاية (خطم).أخرجه نعيم بن حماد في الفتن (١٨٥٢)، وابن جرير ١٨/١٢٦.أخرجه يحيى بن سلام ٢/٥٦٥. وعزاه السيوطي إلى عبد بن حميد. وزاد يحيى بن سلام: قال عبد الله بن عمرو: ولو أشاء أن أضع قدمي على مكانها الذي تخرج منه لفعلت. وذكر قبله: قال حماد: يومئذ يُعرف المنافق من المؤمن.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٢٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٥٦٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٥٦٥، وابن أبي شيبة ١٥/٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٦/١٨٠.أخرجه ابن جرير ١٨/١٢٦.أخرجه ابن أبي حاتم ٩/٢٩٢٤. وعزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه أحمد ١٣/٣٢١ (٧٩٣٧)، ١٦/٢٣٦ (١٠٣٦١)، والترمذي ٥/٤٠٧-٤٠٨ (٣٤٦٤)، وابن ماجه ٥/١٨٥ (٤٠٦٦)، والحاكم ٤/٥٣٢ (٨٤٩٤)، وابن جرير ١٨/١٢٥، وابن أبي حاتم ٩/٢٩٢٣ (١٦٥٩٢)، والثعلبي ٧/٢٢٤. قال الترمذي: «هذا حديث حسن». وقال الألباني في الضعيفة ٣/٢٣٣ (١١٠٨): «منكر».ظَفَرة -بفتح الظاء والفاء-: لَحمة تنبُت عند المَآقِي، وقد تَمْتدُّ إلى السَّواد فتُغَشِّيه. النهاية (ظفر).عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ٣٦/٦٤٦-٦٤٧ (٢٢٣٠٨). وعزاه السيوطي إليه وإلى سمويه وابن مردويه بلفظ: ثم يعمِّرون فيكم -بالعين المهملة-. قال الهيثمي في المجمع ٨/٦ (١٢٥٧٣-١٢٥٧٤): «رجاله رجال الصحيح، غير عمر بن عبد الرحمن بن عطية، وهو ثقة». وقال المناوي في التيسير ١/٤٤٦: «بإسناد رجاله ثقات». وقال الألباني في الصحيحة ١/٦٣٩ (٣٢٢): «وهذا إسناد صحيح، رجاله كلهم ثقات معروفون، غير عمر هذا».أخرجه ابن أبي شيبة ١٥/٦٦-٦٧.أخرجه ابن جرير ١٨/١٢٦.أخرجه يحيى بن سلام ٢/٥٦٧.أخرجه يحيى بن سلام ٢/٥٦٧. وعزاه السيوطي إلى عبد بن حميد، واللفظ له.أخرجه ابن أبي شيبة ١٥/١٨٠-١٨١، وابن أبي حاتم ٩/٢٩٢٣-٢٩٢٤.أخرجه ابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن جرير ١٨/١٢٤-١٢٥، والثعلبي ٧/٢٢٥. قال ابن كثير في البداية والنهاية ١٩/٢٥٠: «في إسناده نظر».أخرجه الطبراني في الأوسط ٤/٣١٩ (٤٣١٧)، والعقيلي في الضعفاء ٢/٦١. قال العقيلي: «لا يحفظ إلا عن رباح». وقال ابن عدي في الكامل في الضعفاء ٤/١٠٩: «ورباح بن عبيد الله ذكر هذا الحديث، وأُنكِر عليه». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١٠٩٢ (٢٣١٨): «أُنكِر على رباح رفعه». وقال الهيثمي في المجمع ٨/٧ (١٢٥٧٧): «فيه رباح بن عبيد الله بن عمر، وهو ضعيف». وقال الألباني في الضعيفة ٧/٣٨٨ (٣٣٧٦): «ضعيف».أخرجه الذهبي في ميزان الاعتدال ٣/٨٤-٨٥، في ترجمة عقبة بن أبي الحسناء (٥٦٨٥)، والثعلبي ٧/٢٢٤. قال الألباني في الضعيفة ٣/٢٣٤ (١١٠٩): «ضعيف».أخرجه أحمد ٣٨/١٢٩ (٢٣٠٢٣)، وابن ماجه ٥/١٨٦ (٤٠٦٧)، بلفظ: فتر في شبر، والبخاري في تاريخه ٣/١٦١-١٦٢ (٥٥٤) واللفظ له. قال البوصيري في مصباح الزجاجة ٤/١٩٩ (٨٣٤١): «هذا إسناد ضعيف، خالد بن عبيد قال البخاري: في حديثه نظر. وقال ابن حبان والحاكم: حدّث عن أنس بأحاديث موضوعة». وأورده ابن الجوزي في العلل المتناهية ٢/٤٣١ (١٥٢٥).أخرجه الطبراني في الأوسط ٢/١٧٦-١٧٧ (١٦٣٥). وعزاه السيوطي إلى ابن مردويه. قال الطبراني: «لم يرو هذا الحديث عن ابن جريج إلا سفيان، تفرد به حمزة بن سعيد».أخرجه أبو يعلى (٥٧٠٣). وعزاه السيوطي إلى ابن مردويه. قال محقق أبي يعلى: «إسناده ضعيف».الرُّغاء: صوْتِ الإبِلِ. النهاية (رغا).أي: تفرقوا. اللسان (رفض).أخرجه الحاكم ٤/٥٣٠ (٨٤٩٠)، وابن أبي حاتم ٩/٢٩٢٣ (١٦٥٩٣)، وفيه طلحة بن عمرو الحضرمي. قال الحاكم: «هذا حديث صحيح الإسناد، وهو أبين حديث في ذكر دابة الأرض، ولم يخرجاه». وقال الذهبي: «طلحة بن عمرو الحضرمي ضعّفوه، وتركه أحمد». وقال ابن كثير في البداية والنهاية ١٩/٢٤٩-٢٥٠: «فيه غرابة». وقال الهيثمي في المجمع ٨/٧ (١٢٥٧٦): «رواه الطبراني، وفيه طلحة بن عمرو، وهو متروك».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/٢٠-٢١ للزيلعي-، من طريق محمد بن مسلم الطائفي، عن عمرو بن دينار، عن ابن عباس به. إسناده ليّن؛ فيه محمد بن مسلم الطائفي، قال عنه ابن حجر في التقريب (٦٢٩٣): «صدوق، يخطئ من حفظه».تنكَمِي: تستتر. النهاية (كما).أخرجه عبد الرزاق ٢/٨٤.أخرجه ابن أبي شيبة ١٥/١٨١.أخرجه يحيى بن سلام ٢/٥٦٥ مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١٢٤.أخرجه ابن جرير ١٨/١٢٤، كما أخرجه ابن أبي شيبة ١٥/٦٧، ١٨١ من طريق عبد الملك بن عمير بنحوه.أخرجه نعيم بن حماد في الفتن (١٨٥٢). وعزاه السيوطي إليه من قول عمرو بن العاصي! ولعل في النسخة سقط.كذا في مطبوعة الدر: واكتة بالألف، على صورة اسم الفاعل من الوكت، وهو الأثر اليسير في الشيء، والوكتة كالنقطة في الشيء من غير لونه. اللسان (وكت).عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، والبيهقي في البعث. وأخرجه الفاكهي في أخبار مكة ٤/٣٩ (٢٣٤٧) عن عبد الله بن عمر، من طريق الحسن البصري، وفيه: «وكتفه» بدل «واكتة»، والظاهر أن «وكتفه» تصحيف.أخرجه ابن أبي حاتم ٩/٢٩٢٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ٢/٥٦٥ مختصرًا، ونعيم بن حماد (١٨٦٢)، وابن أبي حاتم ٩/٢٩٢٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، والبيهقي في البعث.تفسير البغوي ٦/١٨٠.أخرجه ابن أبي شيبة ١٥/٦٧، ونعيم بن حماد (١٨٥٩)، وابن جرير ١٨/١٢١-١٢٢، وابن أبي حاتم ٩/٢٩٢٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٥/٦٧، ١٨١، والخطيب في تالي التلخيص (٢٣٢). وعند ابن أبي شيبة في الموضع الأول: عبد الله بن عمرو.أخرجه عبد الرزاق ٢/٨٥، وابن أبي شيبة ١٥/١٨١. وعزاه السيوطي إلى عبد بن حميد.الرَّجّالَة: هم أصحاب رِكاب المَلِك ومَن يتصَرَّف في أُموره. شرح النووي على مسلم ١٢/١٣٢.أخرجه ابن أبي حاتم ٩/٢٩٢٥.أخرجه ابن أبي داود في المصاحف ١/٣٢٧، وإسحاق البستي في تفسيره ص٢٩ من طريق هارون الأعور. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١١٢، والمحتسب ٢/١٤٥.علقه ابن جرير ١٨/١٢٧. وهي قراءة شاذة، تروى أيضًا عن ابن عباس، ومجاهد، وعاصم الجحدري، وغيرهم. انظر: مختصر ابن خالويه ص١١٢، والمحتسب ٢/١٤٤.أخرجه يحيى بن سلام ٢/٥٦٨، وابن جرير ١٨/١٢٧. وعزاه السيوطي إلى عبد بن حميد وابن جرير بلفظ: (تُحَدِّثُهُمْ تَقُولُ لَهُمْ إنَّ الناسَ كانُوا بِآياتِنا لا يُوقِنُونَ). وجاء عند يحيى بن سلام ٢/٥٦٨: وقال بعضهم: (تَقُولُ: إنَّ النّاسَ كانُوا بِي لا يُوقِنُونَ). وهي بكل هذه الألفاظ قراءة شاذة. انظر: البحر المحيط ٧/٩١.عزاه السيوطي إلى عبد بن حميد. يعني: بفتح همزة <q>﴿أن﴾</q>، وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، ويعقوب، وقرأ بقية العشرة: ‹إنَّ النّاسَ› بكسر الهمزة. انظر: الإتحاف ص٤٣٢.أخرجه إسحاق البستي في تفسيره ص٢٩.تفسير يحيى بن سلام ٢/٥٦٥.أخرجه ابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن جرير ١٨/١٢٧، وابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن جرير ١٨/١٢٧-١٢٨، وابن أبي حاتم ٩/٢٩٢٦.أخرجه ابن أبي حاتم ٩/٢٩٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الفاكهي في أخبار مكة ٤/٤٣ (٢٣٥٦).تفسير البغوي ٦/١٨٠.أخرجه ابن أبي حاتم ٩/٢٩٢٦.علَّقه يحيى بن سلام ٢/٥٦٨.أخرجه الخطيب في تاريخ بغداد ١٦/٦٠٨.تفسير الثعلبي ٧/٢٢٢، وتفسير البغوي ٦/١٧٧.أخرجه ابن أبي حاتم ٩/٢٩٢٦.تفسير مقاتل بن سليمان ٣/٣١٧. وفي تفسير البغوي ٦/١٧٧ بنحوه منسوبًا إلى مقاتل دون تعيينه.علقه يحيى بن سلام ٢/٥٦٧.تفسير مقاتل بن سليمان ٣/٣١٧. وفي تفسير البغوي ٦/١٧٧: قال مقاتل: تخبر الناس أن أهل مكة لم يؤمنوا بالقرآن والبعث.تفسير يحيى بن سلام ٢/٥٦٨.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٨.
27,83," <q>﴿وَیَوۡمَ نَحۡشُرُ مِن كُلِّ أُمَّةࣲ فَوۡجࣰا مِّمَّن یُكَذِّبُ بِـَٔایَـٰتِنَا﴾</q> - تفسير ٥٧٩٠٨- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿ويوم نحشر من كل أمة فوجا ممن يكذب بآياتنا فهم يوزعون﴾</q>: يعني: الشيعة عند الحشر{1}. (ز) ٥٧٩٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ويوم نحشر من كل أمة فوجا﴾</q>، قال: زُمْرَة{2}. (١١/٤١٣) ٥٧٩١٠- قال مقاتل بن سليمان: <q>﴿ويوم نحشر من كل أمة فوجا﴾</q> يعني: زمرًا، <q>﴿ممن يكذب بآياتنا﴾</q>{3}. (ز) ٥٧٩١١- قال يحيى بن سلّام: قوله ﷿: <q>﴿ويوم نحشر من كل أمة فوجا﴾</q>، يعني: كفار كل أمة{4}. (ز) <q>﴿فَهُمۡ یُوزَعُونَ ۝٨٣﴾</q> - تفسير ٥٧٩١٢- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿ممن يكذب بآياتنا فهم يوزعون﴾</q>، قال: يقول: فهم يَدْفَعون{5}. (ز) ٥٧٩١٣- عن أبي الأحوص [عوف بن مالك بن نضلة الأشجعي] -من طريق ابن الأقمر- <q>﴿ويوم نحشر من كل أمة فوجا ممن يكذب بآياتنا فهم يوزعون﴾</q>، قال: يُحبَس الأول على الآخر، حتى إذا تكاملت العِدَّة إذ هم جميعًا{6}. (ز) ٥٧٩١٤- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿فهم يوزعون﴾</q>، قال: يحبس أولهم على آخرهم{7}. (١١/٤١٣) ٥٧٩١٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فهم يوزعون﴾</q>، قال: وزَعَةٌ تَرُدُّ أُولاهم على أُخراهم{8}. (١١/٣٤٥) ٥٧٩١٦- قال إسماعيل السُّدِّيّ: <q>﴿يوزعون﴾</q>، يعني: يُساقون{9}. (ز) ٥٧٩١٧- قال مقاتل بن سليمان: <q>﴿فهم يوزعون﴾</q>، يعني: فهم يُساقون إلى النار{3}. (ز) ٥٧٩١٨- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ- في قوله: <q>﴿فهم يوزعون﴾</q>، قال: يُساقون{11}. (١١/٤١٣) ",footnotes:1:أخرجه ابن جرير ١٨/١٢٩.أخرجه ابن جرير ١٨/١٢٩، وأخرجه من طريق ابن جريج بلفظ: زمرة زمرة. وأخرجه ابن أبي حاتم ٩/٢٩٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣١٧.تفسير يحيى بن سلام ٢/٥٦٨.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٩٢٧.أخرجه إسحاق البستي في تفسيره ص٢٩.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٨٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٩٢٧. وعلقه يحيى بن سلام ٢/٥٦٨.علَّقه يحيى بن سلام ٢/٥٦٨.تفسير مقاتل بن سليمان ٣/٣١٧.أخرجه ابن أبي حاتم ٩/٢٩٢٧.
27,84," <q>﴿حَتَّىٰۤ إِذَا جَاۤءُو قَالَ أَكَذَّبۡتُم بِـَٔایَـٰتِی وَلَمۡ تُحِیطُوا۟ بِهَا عِلۡمًا أَمَّاذَا كُنتُمۡ تَعۡمَلُونَ ۝٨٤﴾</q> - تفسير ٥٧٩١٩- عن سعيد بن جبير -من طريق عطاء- في قول الله: <q>﴿بآياتي﴾</q>: يعني: بالقرآن{1}. (ز) ٥٧٩٢٠- قال مقاتل بن سليمان: <q>﴿حتى إذا جاءوا قال أكذبتم بآياتي﴾</q> يعني: بالساعة، <q>﴿ولم تحيطوا بها علما﴾</q> أنها باطل، <q>﴿أم ماذا كنتم تعملون﴾</q>؟!{2}. (ز) ٥٧٩٢١- قال يحيى بن سلّام: قوله: <q>﴿حتى إذا جاءوا قال﴾</q> الله <q>﴿أكذبتم بآياتي ولم تحيطوا بها علما﴾</q> أي: لم تحيطوا بها علمًا بأنّ ما عبدتم مِن دوني ما خلقوا معي شيئًا، ولا رزقوا معي شيئًا، وأنّ عبادتكم إيّاهم لم تكن منكم بإحاطة علم علمتموه، وإنما كان ذلك منكم على الظن، <q>﴿أماذا كنتم تعملون﴾</q>؟! يستفهمهم، وهو أعلم بذلك منهم، يحتجُّ عليهم{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢٧.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٦٨.
27,85," <q>﴿وَوَقَعَ ٱلۡقَوۡلُ عَلَیۡهِم﴾</q> - تفسير ٥٧٩٢٢- تفسير مجاهد بن جبر: قوله: <q>﴿ووقع القول عليهم﴾</q>، أي: وحق القول عليهم، والقول: الغضب{1}. (ز) ٥٧٩٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ووقع القول﴾</q>، قال: وجب القول، والقول: الغضب{2}. (١١/٤١٣) ٥٧٩٢٤- قال مقاتل بن سليمان: <q>﴿ووقع القول عليهم﴾</q>، يعني: ونزل العذاب بهم{3}. (ز) <q>﴿بِمَا ظَلَمُوا۟﴾</q> - تفسير ٥٧٩٢٥- قال مقاتل بن سليمان: <q>﴿بما ظلموا﴾</q>، يعني: بما أشركوا{3}. (ز) ٥٧٩٢٦- قال يحيى بن سلّام: قوله: <q>﴿بما ظلموا﴾</q> بما أشركوا{5}. (ز) <q>﴿فَهُمۡ لَا یَنطِقُونَ ۝٨٥﴾</q> - تفسير ٥٧٩٢٧- قال قتادة بن دعامة، في قوله: <q>﴿فهم لا ينطقون﴾</q>: كيف ينطقون ولا حُجَّة لهم؟!{6}. (ز) ٥٧٩٢٨- قال مقاتل بن سليمان: <q>﴿فهم لا ينطقون﴾</q>، يعني: لا يتكلمون فيها{3}٤٩٠٨. (ز) ٤٩٠٨ قال ابنُ عطية (٦/٥٦١): «وهذا في موطن من مواطن القيامة، وفي فريق من الناس؛ لأنّ القرآن يقتضي أنهم يتكلمون بحُجَج في غير هذا الموطن». ",footnotes:1:أخرجه يحيى بن سلام ٢/٥٦٩ من طريق ابن مجاهد، وإسحاق البستي في تفسيره ص٣٠ مختصرًا من طريق ابن جريج بلفظ: حق.أخرجه ابن أبي حاتم ٩/٢٩٢٧.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٦٩.تفسير البغوي ٦/١٨١.تفسير مقاتل بن سليمان ٣/٣١٨.
27,86," <q>﴿أَلَمۡ یَرَوۡا۟ أَنَّا جَعَلۡنَا ٱلَّیۡلَ لِیَسۡكُنُوا۟ فِیهِ وَٱلنَّهَارَ مُبۡصِرًاۚ﴾</q> - تفسير ٥٧٩٢٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والنهار مبصرا﴾</q>، قال: مُنِيرًا{1}. (١١/٤١٣) ٥٧٩٣٠- قال مقاتل بن سليمان: ثم وعظ كفار مكة ليعتبروا في صُنعه، فيُوَحِّدوه ﷿، فقال تعالى: <q>﴿ألم يروا أنا جعلنا الليل ليسكنوا فيه والنهار مبصرا﴾</q>{2}. (ز) ٥٧٩٣١- قال يحيى بن سلّام: قوله ﷿: <q>﴿ألم يروا أنا جعلنا الليل ليسكنوا فيه والنهار مبصرا﴾</q> منيرًا{3}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٨٦﴾</q> - تفسير ٥٧٩٣٢- قال مقاتل بن سليمان: <q>﴿إن في ذلك لآيات﴾</q> يقول: إنّ فيهما لَعبرة <q>﴿لقوم يؤمنون﴾</q> يعني: لقوم يُصَدِّقون بتوحيد الله ﷿{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٢٧.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٦٩.تفسير مقاتل بن سليمان ٣/٣١٨.
27,87," <q>﴿وَیَوۡمَ یُنفَخُ فِی ٱلصُّورِ﴾</q>{1} - تفسير ٥٧٩٣٣- عن مجاهد بن جبر -من طريق ابن جريج- قال: الصور: البوق. قال: هو البوق، صاحبه آخِذٌ به، يقبض قبضتين بكفيه على طرف القرن ٤٩٠٩، بين طرفه وبين فيه قدر قبضة أو نحوها، قد برك على ركبة إحدى رجليه، فأشار، فبرك على ركبة يساره مُقْعِيًا على قدمها، عقبها تحت فخذه وأليته، وأطراف أصابعها في التراب{2}. (ز) ٤٩٠٩ ذَهَبَ ابنُ عطية (٦/٥٦٢) إلى أنّ الصّور: هو القرن، فقال: «هو القرن في قول جمهور الأمة، وهو مقتضى الأحاديث». ٥٧٩٣٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ويوم ينفخ في الصور﴾</q>: أي: في الخلق{3}. (ز) ٥٧٩٣٥- تفسير قتادة بن دعامة -من طريق سعيد-: أنّ المنادي -وهو صاحب الصور- يُنادي مِن الصخرة مِن بيت المقدس{4}. (ز) ٥٧٩٣٦- عن أبي بكر بن عبد الله [بن محمد بن أبي سبرة] -من طريق حجاج- قال: الصور كهيئة القرن، قد حَجَنَ{5} إحدى ركبتيه إلى السماء، وخفض الأخرى، لم يُلْقِ جفون عينيه على غُمْضٍ منذ خلق الله السموات، مستعدًا مستجدًا، قد وضع الصور على فيه ينتظر متى يؤمر أن ينفخ فيه{6}. (ز) <q>﴿فَفَزِعَ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَن فِی ٱلۡأَرۡضِ إِلَّا مَن شَاۤءَ ٱللَّهُۚ﴾</q> - تفسير ٥٧٩٣٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «لَمّا فرغ اللهُ مِن خلق السماوات والأرض خلق الصور، فأعطاه إسرافيل، فهو واضِعُه على فِيه، شاخِصٌ ببصره إلى العرش، ينتظر متى يُؤمَر». قال أبو هريرة: يا رسول الله، وما الصور؟ قال: «قرن». قال: وكيف هو؟ قال: «قرن عظيم ينفخ فيه ثلاث نفخات؛ الأولى: نفخة الفزع، والثانية: نفخة الصعق، والثالثة: نفخة القيام لرب العالمين؛ يأمر الله ﷿ إسرافيل بالنفخة الأولى، فيقول: انفخ نفخة الفزع. فيفزع أهل السماوات والأرض إلا من شاء الله، ويأمره الله فيديمها ويطولها فلا يفتر، وهي التي يقول الله: <q>﴿ما ينظر هؤلاء إلا صيحة واحدة ما لها من فواق﴾</q> [ص:١٥]، فيسير الله الجبال فتكون سرابًا، وترج الأرض بأهلها رجًّا، وهي التي يقول الله: <q>﴿يوم ترجف الراجفة تتبعها الرادفة قلوب يومئذ واجفة﴾</q> [النازعات:٦-٧]. فتكون الأرض كالسفينة الموبقة في البحر تضربها الأمواج، تكفأ بأهلها، أو كالقنديل المُعَلَّق بالعرش، ترجحه الأرواح، فيميد الناس على ظهرها، فتُذْهِل المراضع، وتضع الحوامل، وتشيب الولدان، وتطير الشياطين هاربة حتى تأتي الأقطار، فتلقاها الملائكة، فتضرب وجوهها فترجع، ويولي الناس مدبرين، ينادي بعضهم بعضًا، وهو الذي يقول الله: <q>﴿يوم التناد يوم تولون مدبرين ما لكم من الله من عاصم ومن يضلل الله فما له من هاد﴾</q> [غافر:٣٢-٣٣]. فبينما هم على ذلك، إذ تصدَّعَتِ الأرضُ مِن قُطر إلى قُطْر، فرأوا أمرًا عظيمًا، وأخذهم لذلك مِن الكرب ما الله أعلم به، ثم نظروا إلى السماء فإذا هي كالمهل، ثم خُسِف شمسها، وخُسِف قمرها، وانتثرت نجومها، ثم كَشَطت عنهم». قال رسول الله ﷺ: «والأموات لا يعلمون بشيء مِن ذلك». فقال أبو هريرة: فمن [ثَمَّ] استثنى الله حين يقول: <q>﴿ففزع من في السموات ومن في الأرض إلا من شاء الله﴾</q>. قال: «أولئك الشهداء، وإنّما يَصِل الفزع إلى الأحياء، أولئك أحياء عند ربهم يرزقون، وقاهم الله فزع ذلك اليوم وآمَنَهم، وهو عذاب الله يبعثه على شِرار خلقه، وهو الذي يقول: <q>﴿يا أيها الناس اتقوا ربكم إن زلزلة الساعة شيء عظيم﴾</q> إلى قوله: <q>﴿ولكن عذاب الله شديد﴾</q>»{7}٤٩١٠. (ز) ٤٩١٠ ذَهَبَ ابنُ عطية (٦/٥٦٢) إلى أنّ المَلَكَ له ثلاث نفخات في الصور، كما ورد في أثر أبي هريرة ﵄، وذكر قولًا آخر، فقال: «قالت فرقة: إنما هما نفختان. كأنهم جعلوا الفزع والصعق في نفخة واحدة، واستدلوا على ذلك بقوله تعالى: <q>﴿ثم نفخ فيه أخرى فإذا هم قيام ينظرون﴾</q> [الزمر:٦٨]، وقالوا:»أخرى«لا تُقال إلا في الثانية». ثم انتَقَدَ قولهم، فقال (٦/٥٦٣): «والقول الأول أصح، و»أخرى" تُقال في الثالثة، ومنه قول ربيعة بن مقروم: ولقد شفعتهما بآخر ثالث ومنه قوله تعالى: <q>﴿ومناة الثالثة الأخرى﴾</q> [النجم:٢٠]". ٥٧٩٣٨- عن أبي هريرة -من طريق العوام، عمَّن حدَّثه- في قوله: <q>﴿ففزع من في السماوات ومن في الأرض إلا من شاء الله﴾</q>، قال: هم الشهداء{8}٤٩١١. (١١/٤١٣) ٤٩١١ قال ابن عطية (٦/٥٦٤): «تظاهرت الروايات بأن الاستثناء في هذه الآية إنما أريد به الشهداء؛ لأنهم أحياء عند ربهم يرزقون، وهم أهل للفزع؛ لأنهم بشر، لكن فُضِّلوا بالأمن في ذلك اليوم». وبنحوه ابنُ جرير (١٨/١٣٥)، وكذا ابنُ كثير (١٠/٤٣٦). ٥٧٩٣٩- عن عبد الله بن عباس -من طريق سعيد بن جبير، وعطاء- في قوله: <q>﴿إلا من شاء الله﴾</q>، قال: هم الشهداء؛ لأنهم أحياء عند ربهم، لا يَصِل الفزع إليهم{9}. (ز) ٥٧٩٤٠- عن الضحاك بن مزاحم، في قوله: <q>﴿إلا من شاء الله﴾</q>، قال: هم رضوان، والحور، ومالك، والزبانية{10}. (ز) ٥٧٩٤١- تفسير الحسن البصري، في قوله: <q>﴿إلا من شاء الله﴾</q>، قال: استثنى الله طوائفَ مِن أهل السماء، يموتون بين النفختين{11}. (ز) ٥٧٩٤٢- قال محمد بن السائب الكلبي، في قوله: <q>﴿إلا من شاء الله﴾</q>: يعني: جبريل، وميكائيل، وإسرافيل، وملك الموت، فلا يبقى بعد النفخة إلا هؤلاء الأربعة، ثم يقبض الله روح ميكائيل، ثم روح إسرافيل، ثم روح ملك الموت، ثم روح جبريل، فيكون آخرهم موتًا جبريل ﵇{12}. (ز) ٥٧٩٤٣- قال مقاتل بن سليمان: <q>﴿ويوم ينفخ في الصور ففزع﴾</q> يقول: فمات <q>﴿من في السماوات ومن في الأرض﴾</q> مِن شدة الخوف والفزع، <q>﴿إلا من شاء الله﴾</q> يعني: جبريل، وميكائيل، وإسرافيل، وملك الموت ﵈{13}٤٩١٢. (ز) ٤٩١٢ ذكر ابنُ عطية (٤/٢٧٢ دار الكتب العلمية) أن مقاتل قال: هي في جبريل ﵇، وميكائيل، وإسرافيل، وملك الموت، وإذا كان الفزع الأكبر لا ينالهم فهم حريون أن لا ينالهم هذا. ثم علَّق (٦/٥٦٣) بقوله: «على أن هذا في وقت ترقّب، وذلك في وقت أمْن؛ إذ هو إطباق جهنم على أهلها». ٥٧٩٤٤- قال يحيى بن سلّام، في قوله: <q>﴿ففزع من في السموات ومن في الأرض إلا من شاء الله﴾</q>: وهذه النفخة الأولى{14}. (ز) <q>﴿وَكُلٌّ أَتَوۡهُ﴾</q> - قراءات ٥٧٩٤٥- عن عبد الله بن مسعود، قال: حفِظْتُ عن رسول الله ﷺ في النمل: <q>﴿وكُلٌّ أتَوْهُ داخِرِينَ﴾</q>، على معنى: جاؤوه{15}. (١١/٤١٤) ٥٧٩٤٦- عن عبد الله بن مسعود -من طريق أبي جبر، عن أبيه- أنّه قرأ: <q>﴿وكُلٌّ أتَوْهُ داخِرِينَ﴾</q> خفيفة بنصب التاء، على معنى: جاءوه. يعني: بلا مد{16}. (١١/٤١٤) ٥٧٩٤٧- عن عاصم بن أبي النجود -من طريق أبي بكر- أنّه قرأ: ‹وكُلٌّ آتُوهُ داخِرِينَ› ممدودة، مرفوعة التاء، على معنى: فاعِلوه{17}٤٩١٣. (١١/٤١٣) ٤٩١٣ اختلف القراء في قراءة قوله تعالى: <q>﴿وكُلٌّ أتَوْهُ داخِرِينَ﴾</q> على وجهين: الأول: بمدّ الألف مِن <q>﴿أتوه﴾</q> على مثال: فاعِلُوه، هكذا: ‹آتُوهُ›. وهي قراءة عامة قُرّاء الأمصار. والثاني: بفتح الهمزة بلا مدّ، هكذا <q>﴿أتَوْهُ﴾</q>. وهي قراءة عبد الله بن مسعود ﵄، واتبعه على القراءة به المتأخرون: الأعمش، وحمزة، وحفص، وخلف العاشر. وبَيَّنَ ابنُ جرير (١٨/١٣٧) أنّ كلتا القراءتين صواب، فقال: «الصواب من القول في ذلك عندي أنهما قراءتان مستفيضتان في قرأَة الأمصار، ومتقاربتا المعنى، فبأيتهما قرأ القارئ فمصيب». وبَيَّنَ علّة قراءة الجمهور، فقال: «اعتلَّ الذين قرءوا ذلك على مثال»فاعلوه«بإجماع القراء على قوله:<q>﴿وكلهم آتيه﴾</q> [مريم:٩٥] قالوا: فكذلك قوله: ‹آتُوهُ›، في الجمع»، ووجَّهَ قراءة عبد الله بن مسعود، بقوله: «أما الذين قرءوا على قراءة عبد الله، فإنهم ردوه على قوله:<q>﴿ففزع﴾</q>، كأنهم وجهوا معنى الكلام إلى: ويوم ينفخ في الصور ففزع مَن في السماوات ومَن في الأرض، وأتوه كلهم داخرين، كما يقال في الكلام: رآني ففَرَّ، وعاد وهو صاغر». <q>﴿دَ ٰ⁠خِرِینَ ۝٨٧﴾</q> - تفسير ٥٧٩٤٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿داخرين﴾</q>، قال: صاغرين{18}. (١١/٤١٤) ٥٧٩٤٩- عن قتادة بن دعامة -من طريق سعيد-، مثله{19}. (١١/٤١٤) ٥٧٩٥٠- عن الحسن البصري= (ز) ٥٧٩٥١- وسفيان الثوري، مثل ذلك{20}. (ز) ٥٧٩٥٢- قال مقاتل بن سليمان: <q>﴿وكل أتوه داخرين﴾</q> يعني: <q>﴿وكل﴾</q> البَرُّ والفاجر <q>﴿أتوه﴾</q> في الآخرة صاغرين{21}٤٩١٤. (ز) ٤٩١٤ قال ابنُ كثير (١٠/٤٣٧): «أي: صاغرين مطيعين، لا يتخلف أحدٌ عن أمره، كما قال تعالى: <q>﴿يوم يدعوكم فتستجيبون بحمده﴾</q> [الإسراء:٥٢]، وقال: <q>﴿ثم إذا دعاكم دعوة من الأرض إذا أنتم تخرجون﴾</q> [الروم:٢٥]». ٥٧٩٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: الداخر: الصاغِر الراغِم؛ لأنّ المرء إذا فزِع إنّما همته الهرب مِن الأمر الذي فزِع منه، فلما نفخ في الصور فزعوا، فلم يكن لهم من الله منجى{22}. (١١/٤١٤) ٥٧٩٥٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿وكل أتوه داخرين﴾</q>، يعني: النفخة الآخرة{23}. (ز) ",footnotes:1:تقدمت الآثار مفصلة في معنى الصور عند تفسير قوله تعالى: <q>﴿ولَهُ المُلْكُ يَوْمَ يُنْفَخُ فِي الصُّورِ﴾</q> [الأنعام:٧٣]، وقد ذكر ابن جرير في تفسير آية سورة النمل: <q>﴿ويوم ينفخ في الصور﴾</q> ما لم يذكره في تفسير آية سورة الأنعام، وأحال على تفسير آية سورة الأنعام.أخرجه ابن جرير ١٨/١٣٢، وابن أبي حاتم ٩/٢٩٢٩، وإسحاق البستي في تفسيره ص٣٠ مختصرًا، كما أخرجه يحيى بن سلام ٢/٥٦٩ من طريق ابن مجاهد مختصرًا.أخرجه ابن جرير ١٨/١٣٤، وابن أبي حاتم ٩/٢٩٢٩.أخرجه يحيى بن سلام ٢/٥٧٢.حَجَنَ: عَطَفَ، والحَجَن: اعْوِجاج الشيء. اللسان (حجن).أخرجه ابن جرير ١٨/١٣٢.أخرجه إسحاق بن راهويه في مسنده ١/٨٤ (١٠)، وأبو الشيخ في كتاب العظمة ٣/٨٢١ (٣٨٦) كلاهما مطولًا، وابن جرير ١٥/٤١٩، ١٦/٤٤٧-٤٤٩ واللفظ له، وابن أبي حاتم ٩/٢٩٢٨ (١٦٦٢١)، ٩/٢٩٢٩-٢٩٣٠ (١٦٦٢٧)، من طريق إسماعيل بن رافع المدني، عن يزيد بن أبي زياد، عن رجل، عن محمد بن كعب القرظي، عن رجل من الأنصار، عن أبي هريرة به. إسناده ضعيف جدًّا؛ فيه إسماعيل بن رافع المدني، قال عنه ابن حجر في التقريب (٤٤٢): «ضعيف الحفظ». وفيه أيضًا يزيد ابن أبي زياد قال عنه ابن حجر في التقريب (٧٧١٧): «ضعيف، كبر فتغيّر، وصار يتلقن». وفيه جهالة شيخ يزيد، وجهالة الراوي عن أبي هريرة.أخرجه ابن جرير ١٨/١٣٥. وعزاه السيوطي إلى سعيد بن منصور.تفسير البغوي ٦/١٨١.تفسير البغوي ٦/١٨٣.علَّقه يحيى بن سلام ٢/٥٦٩.تفسير البغوي ٦/١٨٢.تفسير مقاتل بن سليمان ٣/٣١٨. وفي تفسير البغوي ٦/١٨٢ نحوه منسوبًا إلى مقاتل دون تعيينه، وفيه زيادة كما في أثر الكلبي السابق.تفسير يحيى بن سلام ٢/٥٦٩.عزاه السيوطي إلى ابن مردويه. وهي قراءة متواترة، قرأ بها حفص، وحمزة، وخلف العاشر، وقرأ بقية العشرة: ‹وكُلٌّ آتُوهُ› بالمد، وضم التاء. انظر: الإتحاف ص٤٣٢.أخرجه ابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١٣٦، وابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ٢/٥٧٠، وعبد الرزاق ٢/٨٦ من طريق معمر، وابن جرير ١٨/١٣٦. وعلقه ابن أبي حاتم ٩/٢٩٣٢. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٩/٢٩٣٢.تفسير مقاتل بن سليمان ٣/٣١٨.أخرجه ابن جرير ١٨/١٣٦، وابن أبي حاتم ٩/٢٩٣٢ من طريق أصبغ بلفظ: «الراهب» بدل «الراغم»، وقد عزاه السيوطي إليهما بهذا اللفظ: «الراهب».تفسير يحيى بن سلام ٢/٥٧٠.
27,88," <q>﴿وَتَرَى ٱلۡجِبَالَ تَحۡسَبُهَا جَامِدَةࣰ﴾</q> - تفسير ٥٧٩٥٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وترى الجبال تحسبها جامدة﴾</q>، قال: قائِمة{1}٤٩١٥. (١١/٤١٥) ٤٩١٥ قال ابنُ جرير (١٨/١٣٧) مبيّنًا المعنى استنادًا إلى أثر ابن عباس ﵄: «يقول -تعالى ذِكْرُه-: <q>﴿وترى الجبال﴾</q> يا محمد، <q>﴿تحسبها﴾</q> قائمةً، <q>﴿وهي تمرّ﴾</q>». ٥٧٩٥٦- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿وترى الجبال تحسبها جامدة﴾</q> أي: تحسبها ثابتة في أصولها لا تتحرك، <q>﴿وهي تمر مر السحاب﴾</q>{2}. (١١/٤١٥) ٥٧٩٥٧- قال مقاتل بن سليمان: <q>﴿وترى الجبال تحسبها جامدة﴾</q>، يعني: تحسبها مكانها{3}. (ز) ٥٧٩٥٨- قال يحيى بن سلّام: قوله ﷿: <q>﴿وترى الجبال تحسبها جامدة﴾</q> ساكنة{4}. (ز) <q>﴿وَهِیَ تَمُرُّ مَرَّ ٱلسَّحَابِۚ﴾</q> - تفسير ٥٧٩٥٩- عن أبي هريرة أنّه قال: حدَّثنا رسول الله ﷺ، قال: «... يُسَيِّر اللهُ الجبالَ، فتمر مر السحاب، ثم يجعلها سرابًا، وترجُّ الأرضُ بأهلها رجًّا ...»{5}. (ز) ٥٧٩٦٠- قال مقاتل بن سليمان: <q>﴿وهي تمر مر السحاب﴾</q> فتستوي في الأرض{3}. (ز) ٥٧٩٦١- قال يحيى بن سلّام: <q>﴿وهي تمر مر السحاب﴾</q> تكون <q>﴿كالعهن المنفوش﴾</q> [القارعة:٥] كالصوف المنفوش، وتكون <q>﴿كثيبا مهيلا﴾</q> [المزمل:١٤]، وتُبَسُّ بسًّا كما يُبَسُّ السويق، وتكون سرابًا، ثم تكون <q>﴿هباء منبثا﴾</q> [الواقعة:٦]، فذلك حين تذهب مِن أصولها فلا يُرى منها شيء، فتصير الأرض كلها مستوية{4}. (ز) <q>﴿صُنۡعَ ٱللَّهِ ٱلَّذِیۤ أَتۡقَنَ كُلَّ شَیۡءٍۚ إِنَّهُۥ خَبِیرُۢ بِمَا تَفۡعَلُونَ ۝٨٨﴾</q> - تفسير ٥٧٩٦٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿صنع الله الذي أتقن كل شيء﴾</q>، قال: أحْكَم كل شيء{8}. (١١/٤١٥) ٥٧٩٦٣- عن عطاء الخراساني= (ز) ٥٧٩٦٤- وسفيان الثوري، مثل ذلك{9}. (ز) ٥٧٩٦٥- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿صنع الله الذي أتقن كل شيء﴾</q>، يقول: أحسن كل شيء خلقه وأوثقه{10}. (١١/٤١٥) ٥٧٩٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿الذي أتقن كل شيء﴾</q>، قال: أتْرَص{11} كل شيء، وسوّى{12}. (١١/٤١٥) ٥٧٩٦٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أتْقَنَ كُلَّ شَيْءٍ﴾</q>: أحصى كل شيء{13}. (ز) ٥٧٩٦٨- عن مجاهد بن جبر -من طريق أبي يحيى- قال: أحسن كل شيء{14}. (ز) ٥٧٩٦٩- عن الحسن البصري -من طريق هشام بن حسان- <q>﴿صنع الله الذي أتقن كل شيء﴾</q>، قال: أحكم{15}. (ز) ٥٧٩٧٠- عن الحسن البصري -من طريق قرة بن خالد- <q>﴿الذي أتقن كل شيء﴾</q>، قال: أوَلَمْ تر إلى كل دابة كيف تتقي على نفسها؟!{16}. (١١/٤١٦) ٥٧٩٧١- عن الحسن البصري -من طريق أشعث- <q>﴿صنع الله الذي أتقن كل شيء﴾</q>، قال: هدى كل شيء لمنفعته{17}. (ز) ٥٧٩٧٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿صنع الله الذي أتقن كل شيء﴾</q>، قال: أحسن كل شيء{18}. (١١/٤١٥) ٥٧٩٧٣- عن إسماعيل السُّدِّيّ= (ز) ٥٧٩٧٤- وعبد الرحمن بن زيد بن أسلم، مثل ذلك{19}. (ز) ٥٧٩٧٥- قال مقاتل بن سليمان: <q>﴿صنع الله الذي أتقن﴾</q> يعني: الذي أحكم <q>﴿كل شيء إنه خبير بما تفعلون﴾</q> يعني: إنّه خبير بما فعلتم. نظيرُها في الروم{3}. (ز) ٥٧٩٧٦- قال يحيى بن سلّام: قوله <q>﴿صنع الله الذي أتقن كل شيء﴾</q> أحكم كل شيء{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/١٣٧، وابن أبي حاتم ٩/٢٩٣٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩٣٣.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٧٢.أخرجه إسحاق بن راهويه ١/٨٤-٨٥ (١٠) مطولًا، والبيهقي في البعث والنشور ص٣٣٦ (٦٠٩)، وابن جرير ١٦/٤٤٧-٤٤٨مطولًا، وابن أبي حاتم ٩/٢٩٢٩ (١٦٦٢٧) مطولًا، ٩/٢٩٣٣ (١٦٦٣٦) مختصرًا، والثعلبي ٧/٢٢٧ مطولًا. وقد تقدم بتمامه مطولًا مع تخريجه في تفسير الآية السابقة.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٧٢.أخرجه ابن جرير ١٨/١٣٨، وابن أبي حاتم ٩/٢٩٣٣. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٩/٢٩٣٣.أخرجه ابن جرير ١٨/١٣٨، وابن أبي حاتم ٩/٢٩٣٤.أترص: أحكم. اللسان (ترص).أخرجه ابن جرير ١٨/١٣٨، وابن أبي حاتم ٩/٢٩٣٣ من طريق ليث، وأخرجه من طريق ابن أبي نجيح بلفظ: أبرم. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ١٨/٥٩٨، وابن أبي حاتم ٩/٢٩٣٣ من طريق أبي يحيى.أخرجه يحيى بن سلام ٢/٥٧٢.أخرجه إسحاق البستي في تفسيره ص٣٤. وعلقه ابن أبي حاتم ٩/٢٩٣٣.أخرجه يحيى بن سلام ١/٢٦٢، ٢/٥٧٢. وعزاه السيوطي إلى عبد بن حميد. وعقّب يحيى بن سلام عليه بقوله: ليس يعني الحسن: أتْقَنَ: تتقي، ولكن مِن الإتقان أن جعل كل دابة تتقي على نفسها.أخرجه ابن أبي حاتم ٩/٢٩٣٤.أخرجه ابن جرير ١٨/١٣٩. وعلَّقه ابن أبي حاتم ٩/٢٩٣٤. وعزاه السيوطي إلى عبد بن حميد.علقه ابن أبي حاتم ٩/٢٩٣٤.تفسير مقاتل بن سليمان ٣/٣١٨.تفسير يحيى بن سلام ٢/٥٧٢.
