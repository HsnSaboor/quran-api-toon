tafsir[15]{c,v,t}:
19,96," <q>﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ سَیَجۡعَلُ لَهُمُ ٱلرَّحۡمَـٰنُ وُدࣰّا ۝٩٦﴾</q> - نزول الآية ٤٧٢٧٠- عن البراء، قال: قال رسول الله ﷺ لعليٍّ: «قل: اللهم، اجعل لي عندك عهدًا، واجعل لي عندك وُدًّا، واجعل لي في صدور المؤمنين مَوَدَّةً». فأنزل الله: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>. قال: فنزلت في عَلِيٍّ{1}. (١٠/١٤٥) ٤٧٢٧١- عن عبد الرحمن بن عوف: أنّه لما هاجر إلى المدينة وجَدَ في نفسه على فراق أصحابه بمكة؛ منهم شيبة بن ربيعة، وعتبة بن ربيعة، وأمية بن خلف؛ فأنزل الله: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>{2}٤٢٢٦. (١٠/١٤٤) ٤٢٢٦ انتقد ابنُ كثير (٩/٣٠٦) القولَ بنزول الآية في عبد الرحمن بن عوف مستندًا لأحوال النزول، فقال: «وهو خطأ؛ فإنّ هذه السورة بتمامها مَكِيَّة، لم ينزل منها شيء بعد الهجرة، ولم يصِحَّ سندُ ذلك». ٤٧٢٧٢- عن عبد الله بن عباس، قال: نزلت في علي بن أبي طالب: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>. قال: محبةً في قلوب المؤمنين{3}٤٢٢٧. (١٠/١٤٥) ٤٢٢٧ ساق ابنُ عطية (٦/٧٥) الأقوال الواردة في النزول، ثم قال: «ويحتمل أن تكون الآية متصلة بما قبلها في المعنى، أي: إنّ الله تعالى لما أخبر عن إتيان كل مَن فِي السَّماوات والأرض في حال العبودية والانفراد آنس المؤمنين بأنه سيجعل لهم في ذلك اليوم وُدًّا، وهو ما يظهر عليهم مِن كرامته؛ لأنّ محبة الله لعبدٍ إنما هي ما يظهر عليه من نِعَمه وأمارات غفرانه له». وهذا صرف من ابن عطية عفا الله عنه لصفة المحبة إلى لازمها، وهو خلاف مذهب السلف الصالح. <q>﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ سَیَجۡعَلُ لَهُمُ ٱلرَّحۡمَـٰنُ وُدࣰّا ۝٩٦﴾</q> - تفسير الآية ٤٧٢٧٣- عن أبي هريرة، أنّ رسول الله ﷺ قال: «إذا أحبَّ اللهُ عبدًا نادى جبريل: إنِّي قد أحببتُ فلانًا، فأحِبَّه. فيُنادِي في السماء، ثم تنزل له المحبةُ في أهل الأرض؛ فذلك قول الله: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>. وإذا أبغض الله عبدًا نادى جبريل: إنِّي قد أبغضت فلانًا. فينادي في أهل السماء، ثم تنزل له البغضاء في أهل الأرض»{4}٤٢٢٨. (١٠/١٤٦) ٤٢٢٨ علَّق ابنُ كثير (٩/٣٠٤) على هذا الحديث بقوله: «رواه مسلم والترمذي، كلاهما عن قتيبة، عن الدراوردي به. وقال الترمذي: حسن صحيح». ٤٧٢٧٤- عن ثوبان، عن النبي ﷺ، قال: «إنّ العبد لَيلتمس مرضاةَ الله، فلا يزال كذلك، فيقول الله لجبريل: يا جبريل، إنّ عبدي فلانًا يلتمس أن يرضيني، فرضائي عليه. فيقول جبريل: رحمة الله على فلان. ويقوله حملة العرش، ويقول الذين يلونهم، حتى يقول أهل السموات السبع، ثم يهبط إلى الأرض». قال رسول الله ﷺ: «وهي الآيةُ التي أنزل الله في كتابه: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>. وإنّ العبد لَيَلْتَمِسُ سَخَطَ الله، فيقول الله: يا جبريل، إنّ فلانًا يسخطني، ألا وإنّ غضبي عليه؛ فيقول جبريل: غضب الله على فلان، ويقوله حملة العرش، ويقوله مَن دونهم، حتى يقوله أهل السموات السبع، ثم يهبط إلى الأرض»{5}. (١٠/١٤٧) ٤٧٢٧٥- عن علي، قال: سألتُ رسولَ الله ﷺ عن قوله: <q>﴿سيجعل لهم الرحمن ودا﴾</q>، ما هو؟ قال: «المحبةُ في صدور المؤمنين والملائكة المقربين، يا علي، إنّ الله أعطى المؤمن ثلاثًا: المِقَةُ{6} والمحبة، والحلاوة، والمهابة في صدور الصالحين»{7}. (١٠/١٤٥) ٤٧٢٧٦- عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «إنّ الله أعطى المؤمن ثلاثة: المِقَة، والملاحة، والمَوَدَّة والمحبة في صدور المؤمنين». ثم تلا رسولُ الله ﷺ: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>{8}. (١٠/١٤٨) ٤٧٢٧٧- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: محبةً في الناس في الدنيا{9}. (١٠/١٤٥) ٤٧٢٧٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: يُحِبُّهم ويُحَبِّبهم{10}. (١٠/١٤٦) ٤٧٢٧٩- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: الوُدُّ مِن المسلمين في الدنيا، والرزق الحسن، واللسان الصادق{11}. (ز) ٤٧٢٨٠- عن كعب الأحبار، قال: أجِدُ في التوراة أنّه لم تكن محبةٌ لأحد مِن أهل الأرض حتى تكون بَدْؤُها مِن الله تعالى، يُنزِلها على أهل الأرض، ثم قرأت القرآنَ فوجدت فيه: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>{12}. (١٠/١٤٨) ٤٧٢٨١- عن مجاهد بن جبر -من طريق عبيد المُكْتِبِ- في قوله: <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: محبةً في المسلمين في الدنيا{11}. (ز) ٤٧٢٨٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: يحبهم ويحببهم إلى المؤمنين{14}. -ومن طريق القاسم بن أبي بزة بلفظ-: إلى خلقه{15}. (ز) ٤٧٢٨٣- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: محبة في صدور المؤمنين{16}. (١٠/١٤٦) ٤٧٢٨٤- عن قتادة بن دعامة -من طريق عمرو- في قوله: <q>﴿سيجعل لهم الرحمن ودا﴾</q>، قال: ما أقبل عبدٌ إلى الله إلا أقبل اللهُ بقلوب العباد إليه، وزاده مِن عنده{15}. (ز) ٤٧٢٨٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>: إي واللهِ، في قلوب أهل الإيمان. ذُكِر لنا أن هَرِمَ بن حَيّان كان يقول: ما أقبل عبد بقلبه إلى الله إلا أقبل الله بقلوب المؤمنين إليه، حتى يرزقه مودتهم ورحمتهم{18}. (ز) ٤٧٢٨٦- قال إسماعيل السُّدِّيّ: <q>﴿سيجعل لهم الرحمن ودا﴾</q>، يعني: محبة، يحبهم ويحببهم إلى أوليائه{19}. (ز) ٤٧٢٨٧- قال مقاتل بن سليمان: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>، يقول: يجعل محبَّتهم في قلوب المؤمنين فيحبونهم{20}. (ز) ٤٧٢٨٨- عن سفيان بن عيينة -من طريق ابن أبي عمر- <q>﴿إن الذين آمنوا سيجعل لهم الرحمن ودا﴾</q>، قال: يُحِبُّهم ويُحَبِّبهم إلى عباده{21}. (ز) ٤٧٢٨٩- قال يحيى بن سلّام: يقول: المودة{22}٤٢٢٩. (ز) ٤٢٢٩ ذكر ابنُ عطية (٦/٧٤) أنّ القول بأن الود هو القبول الذي يضعه الله لمن يحب من عباده ذهب إليه أكثر المفسرين. <q>﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ سَیَجۡعَلُ لَهُمُ ٱلرَّحۡمَـٰنُ وُدࣰّا ۝٩٦﴾</q> - آثار متعلقة بالآية ٤٧٢٩٠- عن أبي هريرة، قال: قال رسول الله ﷺ: «لكلِّ عبدٍ صِيتٌ{23}، فإن كان صالِحًا وضع في الأرض، وإن كان سَيِّئًا وضع في الأرض»{24}. (١٠/١٤٨) ٤٧٢٩١- عن أبي أُمامة، قال: قال رسول الله ﷺ: «إنّ المِقَة مِن الله، والصِّيتُ من السماء، فإذا أحب الله عبدًا قال لجبريل: إنِّي أُحِبُّ فلانًا. فيُنادي جبريل: إنّ ربكم يُحِبُّ فلانًا فأحِبُّوه. فتنزل له المحبة في الأرض، وإذا أبغض عبدًا قال لجبريل: إنِّي أُبغِض فلانًا فأَبْغِضْه. فيُنادي جبريل: إنّ ربَّكم يُبغِض فلانًا فأبغِضوه. فيُجري له البُغْضَ في الأرض»{25}. (١٠/١٤٩) ٤٧٢٩٢- عن عبد الرحمن بن أبي ليلى، قال: كتب أبو الدرداء إلى مسلمة بن مخلد: سلامٌ عليك، أمّا بعد، فإنّ العبد إذا عمِل بطاعة الله أحَبَّه اللهُ، فإذا أحَبَّه اللهُ حَبَّبه إلى عباده، وإنّ العبد إذا عمِل بمعصية الله أبغضه الله، فإذا أبغضه الله بغَّضه إلى عباده{26}. (١٠/١٤٨) ٤٧٢٩٣- قال قتادة: ذُكِر لنا: أنّ كعبًا كان يقول: إنما تأتي المحبةُ مِن السماء. قال: إنّ الله -تبارك وتعالى- إذا أحبَّ عبدًا قذف حبَّه في قلوب الملائكة، وقذفته الملائكة في قلوب الناس، وإذا أبغض عبدًا فمثل ذلك، لا يملكه بعضُهم لبعض{27}. (ز) ٤٧٢٩٤- عن الحسن البصري -من طريق الربيع بن صَبِيح- قال: قال رجل: واللهِ، لَأَعْبُدَنَّ الله عبادةً أُذكر بها. فكان لا يُرى في حين صلاةٍ إلا قائمًا يصلي، وكان أول داخل إلى المسجد وآخر خارج، فكان لا يعظم، فمكث بذلك سبعة أشهر، وكان لا يَمُرُّ على قومٍ إلا قالوا: انظروا إلى هذا المُرائي. فأقبل على نفسه، فقال: لا أراني أُذكَر إلا بِشَرٍّ، لأجعلنَّ عملي كله لله ﷿. فلم يَزِد على أن قَلَبَ نِيَّتَه، ولم يزِدْ على العمل الذي كان يعمله، فكان يَمُرُّ بعدُ بالقوم فيقولون: رَحِم الله فلانًا الآن. وتلا الحسن: <q>﴿إنَّ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ سَيَجْعَلُ لَهُمُ الرَّحْمَنُ وُدًّا﴾</q>{28}. (ز) ٤٧٢٩٥- عن عبد الرحمن بن زيد بن أسلم، قال: قال ابن المنكدر لأبي حازم: ما أكثر مَن يلقاني فيدعو لي بالخير، ما أعرفهم، وما صنعت إليهم خيرًا قطُّ. فقال أبو حازم: لا تظنَّ أن ذلك مِن قِبَلَك، ولكن انظر إلى الذي جاءك ذلك مِن قِبَلِه فاشكره. وقرأ ابن زيد: <q>﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</q>{29}. (ز) ",footnotes:1:أخرجه ابن المغازلي في مناقب علي ص٣٩٣-٣٩٤ (٣٧٤)، وابن مردويه -كما في تخريج أحاديث الكشاف ٢/٣٤١-٣٤٢ (٧٧٩)-، والثعلبي ٦/٢٣٣، من طريق إسحاق بن بشر، قال: حدثنا خالد بن يزيد، عن حمزة الزيات، عن أبي إسحاق، عن البراء به. وأورده الديلمي في الفردوس ١/٤٧٤ (١٩٣٢). إسناده تالف؛ فيه إسحاق بن بشر، وهو أبو يعقوب الكاهلي، كذّبه أبو بكر بن أبي شيبة وموسى بن هارون وأبو زرعة، وقال الفلاس وغيره: «متروك». وقال الدارقطني: «هو في عِداد مَن يضع الحديث». كما في لسان الميزان لابن حجر ٢/٤٧.أخرجه ابن جرير ١٥/٦٤٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه الطبراني (١٢٦٥٥). وعزاه السيوطي إلى ابن مردويه. وقال الهيثمي في مجمع الزوائد ٧/٥٦: «وفيه بشر بن عمارة وهو ضعيف».أخرجه الترمذي ٥/٣٨١ (٣٤٣١)، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٦٨-. وأصله عند البخاري ٤/١١١ (٣٢٠٩)، ٨/١٤ (٦٠٤٠)، ومسلم ٤/٢٠٣٠ (٢٦٣٧) دون ذكر الآية. قال الترمذي: «هذا حديث حسن صحيح». وصحّحه الألباني في الضعيفة ٥/٢٣٢-٢٣٣ (٢٢٠٨).أخرجه أحمد ٣٧/٨٧ (٢٢٤٠١) دون قوله: «وهي الآية ...»، والطبراني في الأوسط ٢/٥٧-٥٨ (١٢٤٠)، ويحيى بن سلام ١/٢٤٨-٢٥٩. قال الهيثمي في المجمع ١٠/٢٠٢ (١٧٥٣٩): «رجاله رجال الصحيح، غير ميمون بن عجلان، وهو ثقة». وقال في ١٠/٢٧٢ (١٧٩٦٧): «رجاله ثقات».المِقَةُ: المحبَّة. لسان العرب (مقه).أورده الحكيم الترمذي في نوادر الأصول ٢/٢٢٦. وعزاه السيوطي إلى ابن مردويه.أورده الحكيم الترمذي في نوادر الأصول ٢/١٤١. قال السيوطي: «بسند ضعيف».أخرجه عبد الرزاق ٢/١٤ مقتصرًا على لفظ: محبة، وابن جرير ١٥/٦٤٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن أبي شيبة ١٣/٣٧٣، وابن أبي الدنيا في كتاب الأولياء -موسوعة ابن أبي الدنيا ٢/٣٩٥ (٣٢)-، وهناد (٤٧٨)، وابن جرير ١٥/٦٤٣ بلفظ: ويحببهم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٦٤٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٦٤٢.أخرجه ابن جرير ١٥/٦٤٣، وإسحاق البستي في تفسيره ص٢١٨ من طريق ابن جريج، ومن طريق سفيان عن رجل.أخرجه ابن جرير ١٥/٦٤٣.أخرجه هناد (٤٧٩)، وإسحاق البستي في تفسيره ص٢١٩.أخرجه ابن جرير ١٥/٦٤٣.أخرجه يحيى بن سلام ١/٢٤٨ مختصرًا، وابن جرير ١٥/٦٤٣.علقه يحيى بن سلام ١/٢٤٨.تفسير مقاتل بن سليمان ٢/٦٤٠.أخرجه سعيد بن منصور في سننه - التفسير ٦/٢٥٠ (١٤٠٩)، وإسحاق البستي في تفسيره ص٢١٨.تفسير يحيى بن سلام ١/٢٤٨.صِيت: ذِكْر وشُهْرة. لسان العرب (صوت).أخرجه الطبراني في مسند الشاميين ٤/٨٩، وتمام في الفوائد ٢/١١٢، من طريق سعيد بن بشير، عن الأعمش، عن أبي صالح، عن أبي هريرة به. وأورده الحكيم الترمذي ٢/٢٢٦. إسناده ضعيف؛ فيه سعيد بن بشير الأزدي الشامي، قال عنه ابن حجر في التقريب (٢٢٧٦): «ضعيف».أخرجه أحمد ٣٦/٦٠٣-٦٠٤ (٢٢٢٧٠). قال ابن كثير في تفسيره ٥/٢٦٨: «غريب، ولم يُخَرِّجوه». وقال الهيثمي في المجمع ١٠/٢٧١ (١٧٩٦٠): «رواه أحمد، والطبراني في الكبير، والأوسط، ورجاله وُثِّقوا».أخرجه البيهقي في الأسماء والصفات (١٠٤١).علَّقه يحيى بن سلام ١/٢٤٨.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٦٩-.أخرجه ابن أبي الدنيا في كتاب الشكر لله -موسوعة ابن أبي الدنيا ١/٤٩٨ (١٠٧)-، وأبو نعيم في حلية الأولياء ٣/٢٣٣.
19,97," <q>﴿فَإِنَّمَا یَسَّرۡنَـٰهُ بِلِسَانِكَ﴾</q> - تفسير ٤٧٢٩٦- قال الحسن البصري: لولا أنّ الله يسَّره بلسان محمد ﷺ ما كانوا ليقرؤوه، ولا ليفهموه{1}. (ز) ٤٧٢٩٧- تفسير السُّدِّيّ وغيره: قوله: <q>﴿فإنما يسرناه﴾</q> يعني: القرآن، <q>﴿بلسانك﴾</q> يا محمد{1}. (ز) ٤٧٢٩٨- قال مقاتل بن سليمان: <q>﴿فإنما يسرناه بلسانك﴾</q>، يقول: فإنّما بَيَّنّاه على لسانك، يا محمد، يعني: القرآن{3}. (ز) <q>﴿لِتُبَشِّرَ بِهِ ٱلۡمُتَّقِینَ﴾</q> - تفسير ٤٧٢٩٩- قال مقاتل بن سليمان: <q>﴿لتبشر به﴾</q> يعني: بما في القرآن <q>﴿المتقين﴾</q> الشركَ، يعني: الموحدين{3}. (ز) ٤٧٣٠٠- قال يحيى بن سلّام: قوله: <q>﴿لتبشر به﴾</q> بالقرآن <q>﴿المتقين﴾</q> بالجنة، <q>﴿وتنذر به﴾</q> بالقرآن النار{5}. (ز) <q>﴿وَتُنذِرَ بِهِۦ قَوۡمࣰا﴾</q> - تفسير ٤٧٣٠١- عن قتادة بن دعامة، <q>﴿قوما لدا﴾</q>، قال: هم قريش{6}. (١٠/١٥٠) ٤٧٣٠٢- قال مقاتل بن سليمان: <q>﴿وتنذر به﴾</q>، يعني: بما في القرآن مِن الوعيد{3}. (ز) ٤٧٣٠٣- قال يحيى بن سلّام: يعني: قريشًا، وكقوله: <q>﴿إذا قومك منه يصدون﴾</q> إلى قوله: <q>﴿بل هم قوم خصمون﴾</q> [الزخرف:٥٧-٥٨]{5}. (ز) <q>﴿لُّدࣰّا ۝٩٧﴾</q> - تفسير ٤٧٣٠٤- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وتنذر به قوما لدا﴾</q>، قال: ظَلَمَةً{9}. (١٠/١٤٩) ٤٧٣٠٥- قال عبد الله بن عباس: شدادًا في الخصومة{10}. (ز) ٤٧٣٠٦- قال مجاهد بن جبر: <q>﴿لُدًّا﴾</q>: عُوجًا{11}. (ز) ٤٧٣٠٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- <q>﴿لدا﴾</q>، قال: لا يستقيمون{12}. (١٠/١٥٠) ٤٧٣٠٨- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿وتنذر به قوما لدا﴾</q>، قال: فُجّارًا{13}٤٢٣٠. (ز) ٤٢٣٠ علَّق ابنُ عطية (٦/٧٥) على قول مجاهد بقوله: «وهذا عندي فجور الخصومة، ولا يَلدّ إلاّ المبطل. وفي الحديث: «أبغض الرجال إلى الله تعالى الألد الخصم»». ٤٧٣٠٩- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿لدا﴾</q>، قال: خُصَماء{14}. (١٠/١٤٩) ٤٧٣١٠- قال الضَّحّاك بن مُزاحِم: جَدلًا بالباطل{10}. (ز) ٤٧٣١١- عن الحسن البصري -من طريق مهدي بن ميمون- في قوله: <q>﴿لدا﴾</q>، قال: صُمًّا عن الحق{16}. (١٠/١٤٩) ٤٧٣١٢- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿وتنذر به قوما لدا﴾</q>، قال: عُوجًا عن الحق{17}. (ز) ٤٧٣١٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿قوما لدا﴾</q>، قال: جُدُلًا بالباطل{18}. (١٠/١٥٠) ٤٧٣١٤- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿وتنذر به قوما لدا﴾</q>، أي: جُدُلًا بالباطل، ذوي لَدَدٍ وخصومة{19}. (ز) ٤٧٣١٥- قال الربيع: صمُّ آذانِ القلوبِ{10}. (ز) ٤٧٣١٦- قال مقاتل بن سليمان: <q>﴿قوما لدا﴾</q> يعني: جدلاء خصماء بالباطل. نظيرها في البقرة [٢٠٤]: <q>﴿وهو ألد الخصام﴾</q>، يعني: جَدِلًا خَصِمًا بالباطل، الأَخْنَسُ بن شَرِيق{3}. (ز) ٤٧٣١٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وتنذر به قوما لدا﴾</q>، قال: الألَدُّ: الظلوم. وقرأ قول الله: <q>﴿وهو ألد الخصام﴾</q> [البقرة:٢٠٤]{13}٤٢٣١. (ز) ٤٢٣١ ذكر ابنُ عطية (٦/٧٥) أن الألد: هو المخاصم المبالغ في الخصومة. ثم قال ٦/٧٦: «وعبَّر المفسرون عن الّلد: بالفجرة وبالظلمة، وتلخيص معناها ما ذكرناه». <q>﴿لُّدࣰّا ۝٩٧﴾</q> - آثار متعلقة بالآية ٤٧٣١٨- عن عائشة، قالت: سمعتُ رسول الله ﷺ يقول: «أبْغَضُ الرِّجالِ إلى اللَّهِ الأَلَدُّ الخَصِمُ»{23}. (ز) ",footnotes:1:علقه يحيى بن سلام ١/٢٤٩.علقه يحيى بن سلام ١/٢٤٩.تفسير مقاتل بن سليمان ٢/٦٤٠.تفسير مقاتل بن سليمان ٢/٦٤٠.تفسير يحيى بن سلام ١/٢٤٩.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٤٠.تفسير يحيى بن سلام ١/٢٤٩.أخرجه ابن جرير ١٥/٦٤٥. وقد أورده السيوطي بلفظ: فجارًا، وكذا عند ابن كثير ٥/٢٧٠.تفسير الثعلبي ٦/٣٣٤.علقه البخاري (ت: مصطفى البغا) كتاب التفسير، عقب باب تفسير سورة مريم ٤/١٧٥٩. وقال الحافظ في الفتح ١٣/١٨١ في ضبطها: وهو بضم العين وسكون الواو.أخرجه ابن جرير ١٥/٦٤٥ من طريق ابن أبي نجيح وابن جريج، وإسحاق البستي في تفسيره ص٢١٩ من طريق ابن جريج. وعلَّقه يحيى بن سلام ١/٢٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٦/٣٣٤، وتفسير البغوي ٥/٢٥٨ بلفظ: الألد: الظالم الذي لا يستقيم.أخرجه ابن جرير ١٥/٦٤٦.أخرجه إسحاق البستي ص٢١٩ في تفسيره بلفظ: هم الخصوم. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٣٣٤.أخرجه ابن جرير ١٥/٦٤٦. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه ابن أبي حاتم -كما في الفتح ١٣/١٨١- بلفظ: اللد: الخصم.أخرجه الثوري في تفسيره ص١٩٠، وابن أبي حاتم -كما في الفتح ١٣/١٨١-.أخرجه عبد الرزاق ٢/١٤، وابن جرير ١٥/٦٤٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٢٤٩، وابن جرير ١٥/٦٤٥.تفسير الثعلبي ٦/٣٣٤.تفسير مقاتل بن سليمان ٢/٦٤٠.أخرجه ابن جرير ١٥/٦٤٦.أخرجه البخاري ٣/١٣١ (٢٤٥٧)، ٦/٢٨ (٤٥٢٣)، ٩/٧٣ (٧١٨٨)، ومسلم ٤/٢٠٥٤ (٢٦٦٨)، والثعلبي ٦/٢٣٤.
19,98," <q>﴿وَكَمۡ أَهۡلَكۡنَا قَبۡلَهُم مِّن قَرۡنٍ هَلۡ تُحِسُّ مِنۡهُم مِّنۡ أَحَدٍ أَوۡ تَسۡمَعُ لَهُمۡ رِكۡزَۢا ۝٩٨﴾</q> - قراءات ٤٧٣١٩- عن عاصم بن أبي النجود أنّه قرأ <q>﴿هَلْ تُحِسُّ مِنهُمْ﴾</q> برفع التاء، وكسر الحاء، ورفع السين، ولا يدغمُها{1}. (١٠/١٥٠) <q>﴿وَكَمۡ أَهۡلَكۡنَا قَبۡلَهُم مِّن قَرۡنٍ﴾</q> - تفسير ٤٧٣٢٠- قال مقاتل بن سليمان: ثم خوَّف كفار مكة، فقال سبحانه: <q>﴿وكم أهلكنا قبلهم﴾</q> يعني: العذاب في الدنيا، <q>﴿من قرن﴾</q> يعني: قبل كفار مكة مِن أُمَّة{2}. (ز) ٤٧٣٢١- قال يحيى بن سلّام: قوله: <q>﴿وكم أهلكنا قبلهم﴾</q> قبل قومك، يا محمد <q>﴿من قرن﴾</q>{3}. (ز) <q>﴿هَلۡ تُحِسُّ مِنۡهُم مِّنۡ أَحَدٍ أَوۡ تَسۡمَعُ لَهُمۡ رِكۡزَۢا ۝٩٨﴾</q> - تفسير ٤٧٣٢٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ركزا﴾</q>، قال: صوتًا{4}. (١٠/١٥١) ٤٧٣٢٣- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿ركزا﴾</q>. فقال: حِسًّا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر: وقد تَوَجَّسَ رِكْزًا مُقْفِرٌ نَدِسٌ بِنَبْأةِ الصوتِ{5} ما في سمعه كَذِبُ؟{6}. (١٠/١٥١) ٤٧٣٢٤- عن سعيد بن جبير، في قوله: <q>﴿هل تحس منهم من أحد﴾</q>، قال: هل ترى منهم من أحد{7}. (١٠/١٥١) ٤٧٣٢٥- عن الضحاك بن مزاحم -من طريق عبيد- قال في قوله: <q>﴿أو تسمع لهم ركزا﴾</q>: يعني: صوتًا{8}. (ز) ٤٧٣٢٦- عن الحسن البصري -من طريق المبارك بن فَضالة- في الآية، قال: ذهب القومُ؛ فلا صوت، ولا عين{9}. (١٠/١٥٠) ٤٧٣٢٧- عن الحسن البصري -من طريق زياد بن أبي عثمان- في قوله: <q>﴿هل تحس منهم من أحد﴾</q>، قال: هل ترى. قال: ثم قال: ذهب الناس ... ولا مخبر{10}. (ز) ٤٧٣٢٨- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿هل تحس منهم من أحدا أو تسمع لهم ركزا﴾</q>، قال: هل ترى عينًا، أو تسمع صوتًا؟{11}. (١٠/١٥٠) ٤٧٣٢٩- قال إسماعيل السُّدِّيّ: <q>﴿هل تحس منهم من أحد﴾</q>: هل ترى من عين{12}. (ز) ٤٧٣٣٠- قال مقاتل بن سليمان: <q>﴿هل تحس﴾</q> يعني: النبيَّ ﷺ، يقول: هل ترى <q>﴿منهم من أحد أو تسمع لهم ركزا﴾</q> يعني: صوتًا، يحذر بمثل عذاب الأمم الخالية؛ لئلا يُكَذِّبوا محمدًا ﷺ{2}. (ز) ٤٧٣٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أو تسمع لهم ركزا﴾</q>، قال: أو تسمع لهم حِسًّا. قال: والرِكْزُ: الحِسُّ{14}. (ز) ٤٧٣٣٢- قال يحيى بن سلّام: وهو على الاستفهام، أي: أنك لا ترى منهم أحدًا، ولا تسمع لهم صوتًا{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا حمزة، والكسائي، وهشامًا فإنهم يدغمون. انظر: الإتحاف ص٣٨٠.تفسير مقاتل بن سليمان ٢/٦٤١.تفسير يحيى بن سلام ١/٢٥٠.أخرجه ابن جرير ١٥/٦٤٧، وابن أبي حاتم -كما في الإتقان ٢/٢٧-. وعزاه السيوطي إلى ابن المنذر.مُقْفِر: أخو القَفْرة يريد الصائد. ونَدِس: فَطِنُ. بِنَبْأة الصوت: بالصوت الخَفِيّ. لسان العرب (نبأ).أخرجه الطستي -كما في الإتقان ٢/٩٨-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٦٤٨، وإسحاق البستي في تفسيره ص٢١٩ من طريق جويبر وعبيد.عزاه السيوطي إلى عبد بن حميد.أخرجه الثوري في تفسيره ص١٩٠.أخرجه عبد الرزاق ٢/١٤، وابن جرير ١٥/٦٤٨. وعلَّقه يحيى بن سلام ١/٢٥٠. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلام ١/٢٥٠.تفسير مقاتل بن سليمان ٢/٦٤١.أخرجه ابن جرير ١٥/٦٤٨.تفسير يحيى بن سلام ١/٢٥٠.
20,1," مقدمة السورة ٤٧٣٣٣- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة طه بمكة{1}. (١٠/١٥٢) ٤٧٣٣٤- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مَكِّيَّة، ونزلت بعد <q>﴿كهيعص﴾</q>{2}. (ز) ٤٧٣٣٥- عن عبد الله بن الزبير، قال: نزلت سورة طه بمكة{3}. (١٠/١٥٢) ٤٧٣٣٦- عن عكرمة مولى ابن عباس= (ز) ٤٧٣٣٧- والحسن البصري -من طريق يزيد النحوي-: مَكِّيَّة{4}. (ز) ٤٧٣٣٨- عن قتادة بن دعامة -من طرق-: مَكِّيَّة{5}. (ز) ٤٧٣٣٩- عن محمد ابن شهاب الزهري: مَكِّيَّة، ونزلت بعد <q>﴿كهيعص﴾</q>{6}. (ز) ٤٧٣٤٠- عن علي بن أبي طلحة -من طريق معاوية بن صالح-: مَكِّيَّة{7}. (ز) ٤٧٣٤١- قال مقاتل بن سليمان: مَكِّيَّة، وهي خمس وثلاثون ومائة آية كوفي{8}. (ز) ٤٧٣٤٢- قال يحيى بن سلّام: مَكِّيَّة كلها{9}. (ز) ٤٧٣٤٣- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ الله -تبارك وتعالى- قرأ طه ويس قبل أن يخلق السموات والأرض بألفي عام، فلمّا سمعت الملائكةُ القرآنَ قالت: طُوبى لِأُمَّة ينزل عليها هذا، وطوبى لأجواف تحمل هذا، وطوبى لألسنة تتكلم بهذا»{10}. (١٠/١٥٢) ٤٧٣٤٤- عن واهب المَعافِرِي، أن رسول الله ﷺ قال: «مَن أُقْرئه المُصْمَدَةَ؟» فقال رجل: أنا، يا رسول الله. فأقرأه رسولُ الله سورةَ يونس، ثم قال: «مَن أُقرئه المُحَلِّيَةَ». فقال رجل: أنا، يا رسول الله. فأقرأه طه، ثم قال: «مَن أُقْرِئه المُحَبِّرَة». فقال رجل: أنا. فأقرأه: <q>﴿هل أتى على الإنسان حين من الدهر﴾</q>{11}. (ز) ٤٧٣٤٥- عن مجاهد، عن ابن عباس، قال: سألتُ عمر بن الخطاب: لأيِّ شيء سُمِّيتَ: الفاروق؟ قال: أسلم حمزةُ قبلي بثلاثة أيام، وخرجت بعده بثلاثة أيام، فإذا فلان بن فلان المخزومي، قلت له: أرَغِبْتَ عن دين آبائِك، واتَّبَعْتَ دينَ محمد؟ قال: إن فعلتُ فقد فَعَلَه مَن هو أعظمُ حَقًّا مِنِّي عليك. قلتُ: مَن هو؟ قال: خَتَنُك{12} وأختك. قال: فانطلقتُ، فوجدتُ الباب مغلقًا، وسمعت هَمْهَمَةً، قال: ففُتِح لي الباب، فدخلتُ، فقلتُ: ما هذا الذي أسمع عندكم؟ قالوا: ما سمعتَ شيئًا. فما زال الكلامُ بيني وبينهم حتى أخذتُ رأسَ خَتَني، فضربتُه ضربةً، فأَدْمَيْتُه، فقامتْ أُختي، فأخذت برأسي، فقالت: قد كان ذلك على رغم أنفك. قال: فاسْتَحْيَيْتُ حينَ رأيتُ الدِّماء، فجلستُ، وقلتُ: أرُوني هذا الكتابَ. فقالت أختي: إنّه لا يمسه إلا المطهرون، فإن كُنت صادقًا فقُم فاغتسل. قال: فقُمْتُ واغتسلتُ، وجئتُ فجلستُ، فأخرجا إلَيَّ الصحيفةَ فيها: بسم الله الرحمن الرحيم. قلتُ: أمّا ظاهره طَيِّب. <q>﴿طه * ما أنزلنا عليك القرآن لتشقى﴾</q> إلى قوله تعالى: <q>﴿له الأسماء الحسنى﴾</q> [طه:١-٨] وما بعدها، فتعظمت في صدري، وقُلْتُ: مِن هذا فَرَّتْ قريش؟! ثم شرح الله صدري للإسلام، فقلتُ: <q>﴿لا إله إلا هو له الأسماء الحسنى﴾</q>. قال: فما في الأرض نسمَةٌ أحَبُّ إلَيَّ مِن رسول الله ﷺ. قلتُ: أين رسول الله ﷺ؟ قالت: عليك عهدُ اللهِ وميثاقُه أن لا تجبهه بشيءٍ يكرهُه؟ قلت: نعم. قالت: فإنّه في دار أرقم بن أبي أرقم. في دارٍ عند الصفا، فأتيتُ الدارَ وحمزة في أصحابه جلوسٌ في الدار، ورسولُ الله ﷺ في البيت، فضربتُ الباب، فاستجمع القومُ، فقال لهم حمزةُ: ما لكم؟ قالوا: عمر بن الخطاب. قال: افتحوا له البابَ، فإن قَبِلَ قَبِلْنا منه، وإن أدبر قتلناه. فسمع ذلك رسولُ الله ﷺ، فقال: «ما لكم؟». فقالوا: عمر بن الخطاب. قال: فخرج رسول الله ﷺ، فأخذ بمجامع ثيابه، ثم نَتَرَهُ نترةً، فما تمالَك أن وقَع على رُكبتيه على الأرض، قال: «ما أنت بمنتهٍ، يا عُمر؟». قال: قلتُ: أشهدُ أن لا إله إلا الله وحده لا شريك له، وأشهد أن محمدًا عبدُه ورسوله. قال: فكبَّر أهلُ الدار تكبيرةً سمِعها أهلُ المسجد، قلت: يا رسول الله، ألَسْنا على الحقِّ إن مِتْنا وإن حَيِينا؟ قال: «بلى -والذي نفسي بيده- إنّكم لَعلى الحق إن مِتُّم وإن حَيِيتُم». قال: فقلتُ: ففيم الاختفاءُ؟! والذي بعثكَ بالحق لتخرجنَّ. فأخرجناه في صفَّين؛ حمزةُ في أحدهما، وأنا في الآخر، له كَدِيدٌ{13} كَكَدِيدِ الطَّحين حتى دخلنا المسجد، قال: فنَظَرَتْ إلَيَّ قريش وإلى حمزة، فأصابتهم كآبةٌ لم يُصِبْهُم مثلُها، فسَّماني رسول الله ﷺ: الفاروق، وفرَّق الله بين الحق والباطل{14}. (ز) ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٥٠١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خصيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/١٩.تفسير يحيى بن سلّام ١/٢٥١.أخرجه الدارمي ٢/٥٤٧-٥٤٨ (٣٤١٤)، والثعلبي ٦/٢٣٥. قال ابن الجوزي في الموضوعات ١/١١٠: «هذا حديث موضوع». وقال ابن كثير في تفسيره ٥/٢٧١ على رواية ابن خزيمة في التوحيد: «هذا حديث غريب، وفيه نكارة، وإبراهيم بن مهاجر وشيخه تُكُلِّم فيهما». وقال العراقي في تخريج أحاديث الإحياء ص٣٢٣ (٥): «أخرجه الدارمي من حديث أبي هريرة بسند ضعيف». وقال الهيثمي في المجمع ٧/٥٦ (١١١٦٣): «رواه الطبراني في الأوسط، وفيه إبراهيم بن مهاجر بن مسمار، وضعّفه البخاري بهذا الحديث، ووثّقه ابن معين». وقال الألباني في الضعيفة ٣/٤٠٢ (١٢٤٨): «منكر».أخرجه عبد الله بن وهب في الجامع - علوم القرآن ٣/٣٥-٣٦ (٥٧) مرسلًا.الخَتَن -بالتحريك-: الصِّهْر، أو كلُّ مَن كان من قِبَلِ المرأةِ كالأبِ والأخِ. القاموس (ختن).الكَدِيد: التراب الناعم فإذا وُطِئَ ثار غباره؛ أراد أنهم كانوا فِي جماعَة، وأنّ الغبار كان يثور من مَشْيِهِم. لسان العرب (كدد).أخرجه أبو نعيم في الحلية ١/٤٠، وابن عساكر في تاريخه ٤٤/٢٩-٣١ (٩٤٣١). قال الذهبي في تاريخ الإسلام ١/١٧٩: «إسناد ضعيف». وقال الألباني في الضعيفة ١٤/٧٢ (٦٥٣١): «منكر».
20,2," <q>﴿طه ۝١ مَاۤ أَنزَلۡنَا عَلَیۡكَ ٱلۡقُرۡءَانَ لِتَشۡقَىٰۤ ۝٢﴾</q> - نزول الآيات ٤٧٣٤٦- عن علي بن أبي طالب -من طريق يزيد بن بلال- قال: كان النبيُّ ﷺ يُراوِح بين قدميه؛ يقوم على كل رجْلٍ، حتى نزلت: <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>{1}. (١٠/١٥٤) ٤٧٣٤٧- عن علي بن أبي طالب -من طريق محمد بن الحنفية- قال: لَمّا نزل على النبي ﷺ: <q>﴿يا أيها المزمل قم الليل إلا قليلا﴾</q> [المزمل:١-٢]؛ قام الليلَ كُلَّه حتى تَوَرَّمَتْ قدماه، فجعل يرفع رِجلًا ويَضَع رِجلًا، فهبط عليه جبريلُ، فقال: <q>﴿طه﴾</q> يعني: طَأِ الأرضَ بقدميك، يا محمد، <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>. وأنزل: <q>﴿فاقرؤوا ما تيسر من القرآن﴾</q> [المزمل:٢٠]{2}. (١٠/١٥٤) ٤٧٣٤٨- عن عبد الله بن عباس -من طريق ميمون بن مهران-: أنّ النبيَّ ﷺ أول ما أنزل عليه الوحيُ كان يقومُ على صدور قدميه إذا صلّى؛ فأنزل الله: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>{3}. (١٠/١٥٢) ٤٧٣٤٩- عن عبد الله بن عباس -من طريق عطية العوفي- قال: قالوا: لقد شَقِي هذا الرجلُ بِرَبِّه. فأنزل الله: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>{4}. (١٠/١٥٣) ٤٧٣٥٠- عن عبد الله بن عباس -من طريق مجاهد- قال: كان رسولُ الله ﷺ إذا قام مِن الليل يربِطُ نفسه بحبلٍ كي لا ينام؛ فأنزل الله: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>{5}. (١٠/١٥٤) ٤٧٣٥١- عن عبد الله بن عباس، في قوله: <q>﴿طه﴾</q>، قال: إنّ رسول الله ﷺ رُبَّما قرأ القرآنَ إذا صلّى، فقام على رِجل واحدة؛ فأنزل الله: (طَهْ) برِجْلَيْك، <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>{6}. (١٠/١٥٥) ٤٧٣٥٢- عن مجاهد بن جبر، قال: كان النبيُّ ﷺ يربط نفسَه بحبل، ويَضَعُ إحدى رِجلَيه على الأخرى؛ فنزلت: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>{7}. (١٠/١٥٤) ٤٧٣٥٣- عن الضَّحاك بن مُزاحِم -من طريق جُوَيْبِر- قال: لَمّا أنزل اللهُ القرآنَ على النبيِّ ﷺ قام به وأصحابُه، فقال له كُفّار قريش: ما أنزل الله هذا القرآنَ على محمد إلا ليشقى به. فأنزل الله: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>{8}. (١٠/١٥٥) ٤٧٣٥٤- عن الحسن البصري أنّه كان يقول: إنّ المشركين قالوا للنبيِّ ﷺ: إنّه شَقِيٌّ. فأنزل الله -تبارك وتعالى- هذه الآية{9}. (ز) ٤٧٣٥٥- عن الربيع بن أنس، قال: كان النبيُّ ﷺ إذا صلّى قام على رِجل ورَفَع الأخرى، فأنزل الله: (طَهْ) يعني: طأ الأرض، يا محمد، <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>{10}. (١٠/١٥٤) ٤٧٣٥٦- قال محمد بن السائب الكلبي: لَمّا نزل على رسولِ الله ﷺ الوحيَ بمكة اجتهد في العبادة، حتى كان يُراوِحُ بين قدميه في الصلاة لِطُول قيامه، وكان يُصَلِّي الليلَ كُلَّه؛ فأنزل الله هذه الآية، وأمره أن يُخَفِّف على نفسه، فقال: <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>{11}. (ز) ٤٧٣٥٧- قال مقاتل: قال أبو جهل والنَّضْرُ بنُ الحارث للنبي ﷺ: إنّكَ لَشَقِيٌّ بترك ديننا. وذلك لِما رأوا مِن طول عبادته واجتهاده؛ فأنزل الله تعالى هذه الآية{12}. (ز) ٤٧٣٥٨- قال مقاتل بن سليمان: وذلك أنّ أبا جهل، والوليد بن المغيرة، والنضر بن الحارث، والمُطْعِم بن عَدِيٍّ؛ قالوا للنبيِّ ﷺ: إنّك لَتَشْقى حين تركتَ دينَ آبائك، فائْتِنا ببراءةٍ أنّه ليس مع إلهك إله. فقال لهم النبي ﷺ: «بل بُعِثْتُ رحمةً للعالمين». قالوا: بل أنت شَقِيٌّ. فأنزل الله ﷿ في قولهم للنبي ﷺ: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>{13}٤٢٣٢. (ز) ٤٢٣٢ أفادت الآثارُ أنّ في سبب هذه الآية قولين: الأول: أنّ سببها ما كان النبيُّ يعانيه مِن التعب في العبادة والسهر للقيام. الثاني: أنّها جوابٌ للمشركين، إذ قالوا: إنّ محمدًا مع ربه في شقاء. وعلّق ابنُ عطية (٦/٧٩) القول الثاني بقوله: «فهذا التأويل أعمُّ مِن الأول في لفظة الشقاء». ولم يذكر ابن جرير (١٦/٨-٩) في نزول الآية سوى القول الأول. <q>﴿طه ۝١﴾</q> - قراءات ٤٧٣٥٩- عن زِرٍّ، قال: قرأ رجل على عبد الله بن مسعود: <q>﴿طه﴾</q> مفتوحة. فأخذها عليه عبد الله: <q>﴿طه﴾</q>. مكسورة. فقال له الرجل: إنما يعني: ضع رجلك. فقال عبد الله: هكذا قرأها النبي ﷺ، وهكذا أنزلها جبريل{14}. (١٠/١٥٧) ٤٧٣٦٠- عن عبد الله بن عباس، قال: أنزل الله: (طَهْ) برِجْلَيْك، <q>﴿مَآ أنزَلْنا عَلَيْكَ القُرْآنَ لِتَشْقى﴾</q>{15}. (١٠/١٥٥) ٤٧٣٦١- عن الربيع بن أنس، قال: أنزل الله: (طَهْ) يعني: طَأِ الأرضَ، يا محمد، <q>﴿مَآ أنزَلْنا عَلَيْكَ القُرْآنَ لِتَشْقى﴾</q>{16}٤٢٣٣. (١٠/١٥٤) ٤٢٣٣ قال ابنُ عطية (٦/٧٨) مُعَلِّقًا على ما جاء في قول الربيع بن أنس: «فالضمير في (طَهْ) للأرض، وخُفِّفت الهمزة فصارت ألفًا ساكنة، وقُرِئَتْ (طَهْ)، وأصله: طَأْ، فحذفت الهمزة، وأدخلت هاء السكت». <q>﴿طه ۝١﴾</q> - تفسير الآية ٤٧٣٦٢- عن عبد الله بن عباس، في قوله: <q>﴿طه﴾</q>، قال: يا رجل{17}. (١٠/١٥٥) ٤٧٣٦٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: (طَهْ) بالنبطية، أي: طأ، يا رجل{18}. (١٠/١٥٥) ٤٧٣٦٤- عن عبد الله بن عباس، في قوله: (طَهْ)، قال: هو كقولك: افعَلْ{19}. (١٠/١٥٥) ٤٧٣٦٥- عن عبد الله بن عباس -من طريق يزيد النحوي، عن عكرمة- قال: <q>﴿طه﴾</q> بالنبطية: يا رجل{20}. (١٠/١٥٥) ٤٧٣٦٦- عن عبد الله بن عباس -من طريق سلمة بن وهرام، عن عكرمة- قال: <q>﴿طه﴾</q>: يا رجل، بالسريانية{21}. (١٠/١٥٦) ٤٧٣٦٧- عن عبد الله بن عباس -من طريق عمر بن أبي زائدة، عن عكرمة- في قوله: <q>﴿طه﴾</q>، قال: هو كقولك: يا محمد. بلسان الحبش{22}. (١٠/١٥٦) ٤٧٣٦٨- عن عبد الله بن عباس -من طريق علي- قال: <q>﴿طه﴾</q> قَسَمٌ أقسمه الله، وهو مِن أسماء الله{23}. (١٠/١٥٨) ٤٧٣٦٩- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- في قوله: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q>، قال: يا رجل، ما أنزلنا عليك القرآن لتشقى. وكان يقوم الليلَ على رِجْلَيْه، فهي لغة لِعَكٍّ{24}؛ إن قلت لِعَكِّيٍّ: يا رجل. لم يلتفت، وإذا قلتَ: طه. التفت إليك{25}. (١٠/١٥٧) ٤٧٣٧٠- عن سعيد بن جبير -من طريق سالم الأفطس- أنه قال: <q>﴿طه﴾</q>: يا رجل، وهي بالنبطية{26}. (ز) ٤٧٣٧١- عن سعيد بن جبير -من طريق عبد الله بن مسلم، أو يعلى بن مسلم- أنّه قال: <q>﴿طه﴾</q>: يا رجل، بالسريانية{21}. (ز) ٤٧٣٧٢- عن مجاهد بن جبر -من طريق ابن جريج-، نحو ذلك{21}. (ز) ٤٧٣٧٣- قال سعيد بن جبير: الطاء: افتتاح اسمه طاهر وطيب، والهاء: افتتاح اسمه هادي{29}. (ز) ٤٧٣٧٤- عن مجاهد بن جبر، قال: <q>﴿طه﴾</q> فواتح السور{30}. (١٠/١٥٦) ٤٧٣٧٥- عن الضحاك بن مزاحم -من طريق قُرَّة بن خالد- قال: <q>﴿طه﴾</q>: يا رجل. قال: وهي بالنبطية. ثم قال الضحاك: ايطه ايطه{31}. (١٠/١٥٦) ٤٧٣٧٦- عن قُرَّة بن خالد، قال: سمعت الضحاك بن مزاحم وقال رجلٌ مِن بني مازن بن مالك: ما يخفى عَلَيَّ شيءٌ من القرآن. وكان قارِئًا للقرآن شاعرًا، فقال له الضَّحّاك: أنت تقول ذلك؟! أخبِرني ما <q>﴿طه﴾</q>؟ قال: هي مِن أسماء الله الحسنى، نحو: <q>﴿طسم﴾</q>، و<q>﴿حم﴾</q>. فقال الضحاك: إنما هي بالنبطية: يا رجل{32}. (١٠/١٥٧) ٤٧٣٧٧- عن عكرمة مولى ابن عباس -من طريق خُصَيْف- قال: <q>﴿طه﴾</q>: يا رجل، بالنبطية{33}. (١٠/١٥٦) ٤٧٣٧٨- عن عكرمة مولى ابن عباس -من طريق عمر بن أبي زائدة- في قوله: <q>﴿طه﴾</q>، قال: هو كقولك: يا رجل. بلسان الحبشة{34}. (١٠/١٥٦) ٤٧٣٧٩- عن عكرمة مولى ابن عباس -من طريق عبد الله- في قوله: <q>﴿طه﴾</q>، قال: بالنبطية: يا إنسان{21}. (ز) ٤٧٣٨٠- عن الحسن البصري = (ز) ٤٧٣٨١- وقتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿طه﴾</q>، قالا: يا رجل{36}. (ز) ٤٧٣٨٢- عن عطاء، مثله{37}. (ز) ٤٧٣٨٣- عن أبي صالح باذام، في قوله: <q>﴿طه﴾</q>، قال: كلمة عُرِّبَتْ{30}. (١٠/١٥٦) ٤٧٣٨٤- عن محمد بن كعب القرظي: <q>﴿طه﴾</q>، قال: الطاء مِن: ذِي الطَّوْل{30}. (١٠/١٥٦) ٤٧٣٨٥- قال محمد بن كعب القرظي: أقسم اللهُ ﷿ بطَوْلِه وهدايته{40}. (ز) ٤٧٣٨٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿طه﴾</q>، قال: يا رجل{41}. (ز) ٤٧٣٨٧- قال محمد بن السائب الكلبي: هو بلغة عَكٍّ: يا رجل{42}. (ز) ٤٧٣٨٨- قال مقاتل بن حيان: معناه: طأِ الأرضَ بقَدَمَيْك، يريد: في التهجد{43}. (ز) ٤٧٣٨٩- قال مقاتل بن سليمان: <q>﴿طه﴾</q>، يعني: يا رجل، وهو بالسرياني{13}. (ز) ٤٧٣٩٠- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿طه﴾</q>، قال: يا رجل. قال سفيان: في كلام النبط: ايطا، يا رجل. يُسَمُّون الرجل أي: طه{45}. (ز) ٤٧٣٩١- قال يحيى بن سلّام: <q>﴿طه﴾</q> يا رجل، <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>{46}٤٢٣٤. (ز) ٤٢٣٤ في <q>﴿طه﴾</q> خمسة أقوال: الأول: أنّ معناه: يا رجل. الثاني: أنّه اسم من أسماء الله، وقَسَمٌ أقسم الله به. الثالث: أنّه حرف من الحروف المُقَطَّعة التي تفتتح بها السور. الرابع: أن معناه: طأِ الأرضَ بقدمك. الخامس: أن معناه: طهارة أهل بيت النبي ﷺ. وقد رجّح ابن جرير (١٦/٨) مستندًا إلى اللغة وأقوال السلف القولَ الأول، فقال: "والذي هو أولى بالصواب عندي مِن الأقوال فيه: قولُ مَن قال: معناه: يا رجل. لأنّها كلمة معروفة في عكٍّ فيما بلغني، وأن معناها فيهم: يا رجل، أُنشدت لمتمم بن نويرة: هتفت بطه في القتال فلم يجب فخفت عليه أن يكون موائلا وقال آخر: إنّ السفاهة طه مِن خلائقكم لا بارك الله في القوم الملاعين فإذا كان ذلك معروفًا فيهم على ما ذكرنا فالواجب أن يُوَجَّه تأويلُه إلى المعروف فيهم مِن معناه، ولا سيما إذا وافق ذلك تأويلَ أهل العلم من الصحابة والتابعين". <q>﴿طه ۝١﴾</q> - آثار متعلقة بالآية ٤٧٣٩٢- عن أبي الطُّفَيْل، قال: قال رسول الله ﷺ: «إنّ لي عند ربي عشرةُ أسماء». قال أبو الطفيل: حفِظْتُ منها ثمانية: محمد، وأحمد، وأبو القاسم، والفاتح، والخاتم، والماحي، والعاقب، والحاشر. وزعم سيف [بن وهب] أنّ أبا جعفر [الهاشمي] قال: الاسمان الباقيان: طه، ويس{47}. (١٠/١٥٦) ٤٧٣٩٣- عن عائشة، قالت: أوَّلُ سورةٍ تعلمتُها من القرآن: <q>﴿طه﴾</q>، وكنت إذا قلتُ: <q>﴿طه ما أنزلنا عليك القرآن لتشقى﴾</q> قال النبيُّ ﷺ: «لا شَقِيتِ، يا عائشُ»{48}. (١٠/١٥٧) <q>﴿مَاۤ أَنزَلۡنَا عَلَیۡكَ ٱلۡقُرۡءَانَ لِتَشۡقَىٰۤ ۝٢﴾</q> - تفسير ٤٧٣٩٤- عن مجاهد بن جبر -من طريق عاصم بن حكيم- في قوله: <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>، يقول: في الصلاة، هي مثلُ قوله: <q>﴿فاقرؤوا ما تيسر منه﴾</q> [المزمل:٢٠]. قال: وكانوا يُعَلِّقون الحبالَ بصدورهم في الصلاة{49}. (١٠/١٥٨) ٤٧٣٩٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q>، قال: لا، واللهِ، ما جعله اللهُ شقيًّا، ولكن جعله رحمةً ونورًا ودليلًا إلى الجنة{50}. (١٠/١٥٨) ٤٧٣٩٦- قال مقاتل بن سليمان: <q>﴿ما أنزلنا عليك القرآن لتشقى﴾</q> يعني: ما أنزلناه عليك <q>﴿إلا تذكرة لمن يخشى﴾</q>{13}. (ز) ",footnotes:1:أخرجه البزار ٣/١٣٦ (٩٢٦)، وفيه يزيد بن بلال. قال البزار: «وأحاديث يزيد بن بلال عن علي لا نعلم لها طرقًا إلا من حديث كيسان أبي عمر». وقال الهيثمي في المجمع ٧/٥٦ (١١١٦٥): «وفيه يزيد بن بلال، قال البخاري: فيه نظر. وكيسان أبو عمرو وثّقه ابن حِبّان، وضعّفه ابن معين، وبقيّة رجاله رجال الصحيح». وقال السيوطي: «سند حسن». وقال المتقي الهندي في كنز العمال ٢/٤٦٦ (٤٥٠٨): «ضُعّف». وقال الصالحي في سبل الهدى والرشاد ٨/٢٧٢: «سند ضعيف».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٢/٣٤٨-، من طريق محمد بن زكريا الغلابي، حدثنا شعيب بن واقد الصفار، حدثنا قيس بن الربيع، عن فطر بن خليفة، عن منذر الثوري، عن محمد بن الحنفية، عن علي به. إسناده ضعيف جِدًّا؛ فيه محمد بن زكريا الغلابي، قال عنه الدارقطني: «يضع الحديث». كما في اللسان لابن حجر ٧/١٣٩، وفيه أيضًا شعيب بن واقد الصفار، ضرب الفلّاس على حديثه، كما في اللسان لابن حجر ٤/٢٥٤.أخرجه البيهقي في الشعب ٣/٨٣-٨٤ (١٤١٦)، وابن عساكر في تاريخه ٤/١٤٤، من طريق محمد بن زياد اليشكري، حدثنا ميمون بن مهران، عن ابن عباس به. إسناده ضعيف جدًّا؛ فيه محمد بن زياد اليشكري الطحان الأعور، قال عنه ابن حجر في التقريب (٥٨٩٠): «كذّبوه».أخرجه ابن جرير ١٦/٥، من طريق محمد بن سعد العوفي، عن أبيه، قال: حدَّثني عمي الحسين بن الحسن، عن أبيه، عن جدِّه عطية العوفي، عن ابن عباس به. الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه ابن عساكر في تاريخه ٤/١٤٣، من طريق عبد الوهاب بن مجاهد، عن أبيه، عن ابن عباس به. وسنده شديد الضعف؛ فيه عبد الوهاب بن مجاهد، قال عنه ابن حجر في التقريب (٤٢٦٣): «متروك، وقد كذَّبه الثوري».أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٢/٣٤٨-، من طريق نهشل، عن الضحاك، عن ابن عباس به. إسناده ضعيف جِدًّا؛ فيه نهشل بن سعيد القرشي الخراساني، قال عنه ابن حجر في التقريب (٧١٩٨): «متروك، وكذَّبه إسحاق بن راهويه».عزاه السيوطي إلى عبد بن حميد مرسلًا.أخرجه إسحاق البستي في تفسيره ص٢٢٣ مرسلًا. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلّام في تفسيره ١/٢٥٢ مرسلًا.أخرجه عبد بن حميد -كما في الشفا للقاضي عياض ١/٥٦، وتفسير ابن كثير ٥/٢٦٦، وتخريج أحاديث الكشاف ٢/٣٤٧- مرسلًا. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٦/٢٣٧، وتفسير البغوي ٥/٢٦٢، واللفظ له.أسباب النزول للواحدي ص٤٩٧.تفسير مقاتل بن سليمان ٣/٢٠.أخرجه الحاكم ٢/٢٦٨ (٢٩٦٥). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». و<q>﴿طه﴾</q> بفتح الطاء هي قراءة العشرة ما عدا أبا بكر عن عاصم، وحمزة، والكسائي، وخلف العاشر، فإنهم أمالوا. انظر: الإتحاف ص٣٨١. وكسرها قراءة شاذة، تروى عن عمر بن عيسى، والكسائي في رواية، وغيرهما. انظر: مختصر ابن خالويه ص٨٩.تقدم بتمامه مع تخريجه في نزول الآيات. (طَهْ) بفتح الطاء، وإسكان الهاء قراءة شاذة، وتروى عن ابن عباس، والربيع بن أنس، والحسن. انظر: مختصر ابن خالويه ص٨٩.تقدم بتمامه مع تخريجه في نزول الآيات.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٦٦، والطبراني (١٢٢٤٩)-. وعزاه السيوطي إلى ابن مردويه.أخرجه الحارث بن أبي أسامة (٧١٧ - بغية)، وابن أبي حاتم -كما في التغليق ٤/٢٥٣-.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٦/٦.أخرجه الحاكم ٢/٣٧٨.أخرجه ابن جرير ١٦/٧. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.عكّ: قبيلة في اليمن تُنسب إلى عك بن عدنان، أخو معد، وقيل غير ذلك. تاج العروس (عكك).أخرجه البيهقي في الدلائل ١/١٥٨-١٥٩.أخرجه البغوي في الجعديات ٢/١١٧، وابن أبي شيبة في مصنفه ١٠/٤٧١.أخرجه ابن جرير ١٦/٦.أخرجه ابن جرير ١٦/٦.تفسير الثعلبي ٦/٢٣٧، وتفسير البغوي ٥/٢٦٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٥١، وابن أبي شيبة ١٠/٤٧٢ مختصرًا، كما أخرجه إسحاق البستي في تفسيره ص٢٢٢ بلفظ: هي بالنبطية: يا رجل، أي: طاياها.أخرجه عبد بن حميد -كما في فتح الباري ٨/٤٣٢-.أخرجه ابن أبي شيبة ١٠/٤٧٢. وعلَّقه البخاري ٦/٩٥. وأخرجه ابن أبي حاتم -كما في فتح الباري ٨/٤٣٢، وتغليق التغليق ٤/٢٥١- من طريق حصين بن عبد الرحمن، وليس فيه: بالنبطية.أخرجه ابن أبي شيبة ١٠/٤٧٠، وابن أبي حاتم -كما في الإتقان ٢/١٣٦-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٦.أخرجه عبد الرزاق ٢/١٥، ويحيى بن سلّام ١/٢٥١ عن الحسن من طريق الحسن بن دينار، وعن قتادة من طريق سعيد، وابن جرير ١٦/٧، وعبد بن حميد -كما في الفتح ٨/٤٣٢- عن الحسن.أخرجه عبد بن حميد -كما في الفتح ٨/٤٣٢-. وينظر: تفسير الثعلبي ٦/٢٣٦، وتفسير البغوي ٥/٢٦٢.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٣٦، وتفسير البغوي ٥/٢٦٢.أخرجه يحيى بن سلّام ١/٢٥١.تفسير الثعلبي ٦/٢٣٦، وتفسير البغوي ٥/٢٦٢ بلفظ: يا إنسان.تفسير البغوي ٥/٢٦٢.تفسير مقاتل بن سليمان ٣/٢٠.أخرجه إسحاق البستي في تفسيره ص٢٢٢.تفسير يحيى بن سلّام ١/٢٥١.أخرجه الآجري في الشريعة ٣/١٤٨٨ (١٠١٥)، وأبو نعيم في دلائل النبوة ص٦١ (٢٠)، وفي سندهما سيف بن وهب. قال ابن عدي في الكامل ٤/٥٠٩ (٨٥٢): «ولسيف بن وهب غير ما ذكرت قليل، وقد نسبه يحيى القطان وابن حنبل إلى الضعف».أخرجه محمد بن عبد الرحمن البغدادي في المخلصيات ٤/١٣١ (٣١٠٤)، وابن عساكر في تاريخه ١٨/١٢١، ٦٣/٤٠٤، من طريق وهب بن وهب أبي البَخْتَري القاضي، عن هشام بن عروة، عن أبيه، عن عائشة به. إسناده ضعيف جِدًّا؛ فيه وهب بن وهب القرشي المدني أبو البَخْتَري القاضي، قال ابن معين: «كان يكذب عدو الله». وقال عثمان بن أبي شيبة: «أرى أنه يبعث يوم القيامة دجالًا». وقال أحمد: «كان يَضَع الحديث وضعًا في ما يُرى». كما في اللسان لابن حجر ٨/٤٠٠.أخرجه يحيى بن سلّام ١/٢٥١، وإسحاق البستي في تفسيره ص٢٢٣ من طريق ابن جريج مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠.
20,3," <q>﴿إِلَّا تَذۡكِرَةࣰ لِّمَن یَخۡشَىٰ ۝٣﴾</q> - تفسير ٤٧٣٩٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إلا تذكرة لمن يخشى﴾</q>، قال: إنّ الله أنزل كتابَه، وبعث رسلَه، رحمةً رَحِم بها العباد؛ لِيَتَذَكَّر ذاكِرٌ، وينتفع رجلٌ بما يسمع مِن كتاب الله، وهو ذِكْرٌ أنزله اللهُ، فيه حلالُه وحرامُه{1}. (١٠/١٥٨) ٤٧٣٩٨- قال مقاتل بن سليمان: <q>﴿إلا تذكرة لمن يخشى﴾</q> اللهَ{2}. (ز) ٤٧٣٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إلا تذكرة لمن يخشى﴾</q>، قال: الذي أنزلناه عليك تذكرة لمن يخشى{3}. (ز) ٤٧٤٠٠- قال يحيى بن سلّام: قوله: <q>﴿إلا تذكرة لمن يخشى﴾</q>، يقول: وإنّما أنزله الله -تبارك وتعالى- تذكرةً لمن يخشى الله، وأمّا الكافر فلم يَقْبَلِ التذكرةَ{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٠.أخرجه ابن جرير ١٦/١٠.تفسير يحيى بن سلّام ١/٢٥٢.
20,4," <q>﴿تَنزِیلࣰا مِّمَّنۡ خَلَقَ ٱلۡأَرۡضَ وَٱلسَّمَـٰوَ ٰ⁠تِ ٱلۡعُلَى ۝٤﴾</q> - تفسير ٤٧٤٠١- قال مقاتل بن سليمان: <q>﴿تنزيلا ممن خلق الأرض﴾</q> كلَّها، <q>﴿والسماوات﴾</q> السبع <q>﴿العلى﴾</q> يعني: [الرفيعة] مِن الأرض{1}. (ز) ٤٧٤٠٢- قال يحيى بن سلّام: قوله: <q>﴿تنزيلا﴾</q> أنزله الله تنزيلًا <q>﴿ممن خلق الأرض والسموات العلى﴾</q> يعني: نفسه{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٠.تفسير يحيى بن سلّام ١/٢٥٢.
20,5," <q>﴿ٱلرَّحۡمَـٰنُ عَلَى ٱلۡعَرۡشِ ٱسۡتَوَىٰ ۝٥﴾</q> - تفسير ٤٧٤٠٣- عن عمر بن الخطاب، عن النبي ﷺ، في قوله تعالى: <q>﴿على العرش استوى﴾</q>، قال: «حتى يُسْمَعَ أطِيطٌ كأَطِيطِ الرَّحْل»{1}. (ز) ٤٧٤٠٤- قال مقاتل بن سليمان: <q>﴿الرحمن على العرش استوى﴾</q> في التقديم، قبلَ خلق السموات والأرض، يعني: اسْتَقَرَّ{2}. (ز) ",footnotes:1:أخرجه الضياء المقدسي في المختارة ١/٢٦٥ (١٥٤)، وأبو الحسين البزاز في حديث شعبة ص٧٣ (٨٤)، من طريق شعبة، عن أبي إسحاق، عن عبد الله بن خليفة، عن عمر به. قال الهيثمي في المجمع ١٠/١٥٩: «رواه أبو يعلى في الكبير، ورجاله رجال الصحيح، غير عبد الله بن خليفة الهمذاني، وهو ثقة».تفسير مقاتل بن سليمان ٣/٢٠.
20,6," <q>﴿لَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا وَمَا تَحۡتَ ٱلثَّرَىٰ ۝٦﴾</q> - تفسير ٤٧٤٠٥- عن عبد الله بن عباس، قال: الأرض على نُونٍ{1}، والنون على بحر، والبحرُ على صخرةٍ خضراء، فخُضْرَةُ الماءِ مِن تلك الصَّخْرة. قال: والصخرة على قرن ثور، وذلك الثَّوْرُ على الثرى، ولا يعلم ما تحت الثرى إلا الله، فذلك قول الله: <q>﴿لَهُ ما فِي السَّماواتِ وما فِي الأَرْضِ وما بَيْنَهُما وما تَحْتَ الثَّرى﴾</q>{2}. (١١/٦٥٠) ٤٧٤٠٦- عن أبي رجاء العطاردي -من طريق الحسن بن دينار- قال: <q>﴿الثرى﴾</q>: الذي تحت الماء، الذي يستقر عليه الماء، فهو يعلم ما تحت ذلك الثرى الذي مُسْتَقَرُّ الماءِ عليه{3}. (ز) ٤٧٤٠٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: <q>﴿الثَّرى﴾</q>: ما حُفِر من التراب مُبْتَلًّا{4}. (١٠/١٥٩) ٤٧٤٠٨- عن محمد بن كعب القرظي -من طريق محمد بن رِفاعَة- <q>﴿وما تحت الثرى﴾</q>، قال: ما تحت سبع أرضين{4}. (١٠/١٥٨) ٤٧٤٠٩- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿الثَّرى﴾</q>: كُلُّ شيءٍ مُبْتَل{6}. (١٠/١٥٩) ٤٧٤١٠- عن إسماعيل السُّدِّي: <q>﴿وما تحت الثرى﴾</q>، قال: هي الصخرة التي تحت الأرض السابعة، وهي صخرة خضراء، وهو سِجِّينٌ، الذي فيه كِتاب الكُفّار{7}. (١٠/١٥٨) ٤٧٤١١- قال مقاتل بن سليمان: ثُمَّ عظم الرب ﷿ نفسه، فقال سبحانه: <q>﴿له ما في السماوات وما في الأرض وما بينهما وما تحت الثرى﴾</q>، يعني بالثرى: الأرض السفلى، وتحتها الصخرة، والملَك، والثور، والحوت، والماء، والرِّيح تَهُبُّ في الهواء{8}٤٢٣٥. (ز) ٤٢٣٥ قال ابنُ عطية (٦/٧٩): «وفي قوله: <q>﴿ما تَحْتَ الثَّرى﴾</q> قصص في أمر الحوت ونحوه، اختصرته لعدم صحته». <q>﴿لَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا وَمَا تَحۡتَ ٱلثَّرَىٰ ۝٦﴾</q> - آثار متعلقة بالآية ٤٧٤١٢- عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «إنّ الأرَضين بين كل أرض والتي تليها مسيرة خمسمائة عام، والعُلْيا منها على ظهر حوت، قد التقى طرفاه في السماء، والحوتُ على صخرة، والصخرة بيد الملَك، والثانية سجن الريح، والثالثة فيها حجارة جهنم، والرابعة فيها كبريت جهنم، والخامسة فيها حيّات جهنم، والسادسة فيها عقارب جهنم، والسابعة فيها سَقَر، وفيها إبليس مُصَفَّد بالحديد؛ يدٌ أمامَه، ويدٌ خلفه، فإذا أراد الله أن يُطْلِقه لِما يشاء أطلقه»{9}. (ز) ٤٧٤١٣- عن جابر بن عبد الله: أنّ النبيَّ ﷺ سُئِل: ما تحت هذه الأرض؟ قال: «الماء». قيل: فما تحت الماء؟ قال: «ظُلمة». قيل: فما تحت الظلمة؟ قال: «الهواء». قيل: فما تحت الهواء؟ قال: «الثَّرى». قيل: فما تحت الثرى؟ قال: «انقطع عِلْمُ المخلوقين عند علم الخالق»{10}. (١٠/١٥٩) ٤٧٤١٤- عن جابر بن عبد الله، قال: كنتُ مع رسول الله ﷺ في غزوة تبوك، إذ عارَضَنا رجل مُتَرَجَّبٌ -يعني: طويلًا-، فدنا مِن النبيِّ ﷺ، فأخذ بخطام راحلته، فقال: أنت محمد؟ قال: «نعم». قال: إنِّي أُريد أن أسألك عن خِصال لا يعلمها أحدٌ مِن أهل الأرض إلا رجلٌ أو رجلان. فقال: «سلْ عمّا شِئْتَ». قال: يا محمد، ما تحت هذه؟ يعني: الأرض. قال: «خَلْق». قال: فما تحتهم؟ قال: «أرْض». قال: فما تحتها؟ قال: «خَلْق». قال: فما تحتهم؟ قال: «أرض». حتى انتهى إلى السابعة، قال: فما تحت السابعة؟ قال: «صخرة». قال: فما تحت الصخرة؟ قال: «الحوت». قال: فما تحت الحوت؟ قال: «الماء». قال: فما تحت الماء؟ قال: «الظُّلْمة». قال: فما تحت الظُّلْمَة؟ قال: «الهواء». قال: فما تحت الهواء؟ قال: «الثَّرى». قال: فما تحت الثَّرى؟ ففاضت عينا رسولُ الله ﷺ بالبكاء؟ فقال: «انقَطَع عِلْمُ المخلوقين عند علم الخالق. أيُّها السائل، ما المسؤول بأعلم من السائل». قال: صدقتَ، أشهدُ أنّك رسول الله. يا محمد، أما إنّك لو ادَّعَيْتَ تحت الثرى شيئًا لعلمتُ أنّك ساحر كذّاب، أشهدُ أنّك رسول الله. ثم ولّى الرجل، فقال رسول الله ﷺ: «يا أيها الناس، هل تدرون ما هذا؟». قالوا: الله ورسوله أعلم. قال: «هذا جبريل»{2}. (١٠/١٦٠،١٥٩) ٤٧٤١٥- عن الأوزاعي، أنّ يحيى بن أبي كثير حدَّثه: أنّ كعبًا سُئِل، فقيل له: ما تحت هذه الأرض؟ فقال: الماء. قيل: وما تحت الماء؟ قال: الأرض. قيل: وما تحت الأرض؟ قال: الماء. قيل: وما تحت الماء؟ قال: الأرض. قيل: وما تحت الأرض؟ قال: الماء. قيل: وما تحت الماء؟ قال: الأرض. قيل: وما تحت الأرض؟ قال: الماء. قيل: وما تحت الماء؟ قال: الأرض. قيل: وما تحت الأرض؟ قال: صخرة. قيل: وما تحت الصخرة؟ قال: ملَك. قيل: وما تحت الملَك؟ قال: حوتٌ مُعَلَّق طرفاه بالعرش. قيل: وما تحت الحوت؟ قال: الهواء، والظُّلْمَة، وانقطع العِلْمُ{12}. (ز) ",footnotes:1:النُون: الحُوت. النهاية (نون).عزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلّام ١/٢٥٣.أخرجه ابن جرير ١٦/١٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/١٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٥٣، وابن جرير ١٦/١٢. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٢١.أخرجه الحاكم ٤/٦٣٦ (٨٧٥٦)، وابن أبي حاتم ٧/٢٤١٦ (١٣٣٨٥). قال الحاكم: «الحديث صحيح، ولم يخرجاه». وتعقبه الذهبي في التلخيص بقوله: «بل منكر». وقال ابن كثير في تفسيره ٥/٢٧٤: «هذا حديث غريب جِدًّا، ورفعه فيه نظر». وقال الذهبي في الميزان ٢/٢٥: «قال ابن منده: إسناده مشهور».أخرجه أبو يعلى -كما في تفسير ابن كثير ٥/٢٧٤ مطولًا-. ذكر ابنُ كثير ٩/٣١٤ هذا الحديث بطوله، ثم علّق عليه قائلًا: «هذا حديث غريب جِدًّا، وسياق عجيب، تفرَّد به القاسم بن عبد الرحمن هذا، وقد قال فيه يحيى بن معين: ليس يُساوي شيئًا. وضَعَّفه أبو حاتم الرازي، وقال ابن عدي: لا يُعرَف. وقد خلط في هذا الحديث، ودخل عليه شيء في شيء، وحديث في حديث، وقد يحتمل أنه تَعَمَّد ذلك، أو أُدْخِل عليه فيه».عزاه السيوطي إلى ابن مردويه.أورده ابن كثير في تفسيره ٣/٢٧٣.
20,7," <q>﴿وَإِن تَجۡهَرۡ بِٱلۡقَوۡلِ فَإِنَّهُۥ یَعۡلَمُ ٱلسِّرَّ وَأَخۡفَى ۝٧﴾</q> - تفسير ٤٧٤١٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: السِّرُ: ما أسره ابنُ آدم في نفسه. وأخفى: ما أخفى ابنُ آدم مِمّا هو فاعلُه قبل أن يعملَه، فإنه يعلم ذلك كله، فعِلْمُه فيما مضى مِن ذلك وما بقي عِلْمٌ واحد، وجميعُ الخلائق عنده في ذلك كنفس واحدة، وهو كقوله: <q>﴿ما خلقكم ولا بعثكم إلا كنفس واحدة﴾</q> [لقمان:٢٨]{1}. (١٠/١٦٠) ٤٧٤١٧- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿يعلم السر وأخفى﴾</q>، يعني بأخفى: ما لم يعمله، وهو عاملُه. وأما السر فيعني: ما أسرَّ في نفسه{2}. (ز) ٤٧٤١٨- عن عبد الله بن عباس -من طريق ابن جريج، عن سعيد بن جبير-: السِّرُّ: ما أسرَّ الإنسانُ في نفسه. وأخفى: ما لا يعلم الإنسانُ مِمّا هو كائِن{3}. (ز) ٤٧٤١٩- عن عبد الله بن عباس -من طريق عطاء، عن سعيد بن جبير- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: السِّرُّ: ما يكون في نفسك اليوم. وأخفى: ما يكون في غدٍ وبعد غد، لا يعلمه إلا الله{4}. (١٠/١٦١) ٤٧٤٢٠- عن عبد الله بن عباس -من طريق عمرو بن أبي قيس، عن عطاء بن السائب، عن سعيد بن جبير- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: السِّرُّ: ما علمتَه أنت. وأخفى: ما قذف اللهُ في قلبك مِمّا لم تعلمه{5}. (١٠/١٦١) ٤٧٤٢١- عن سعيد بن جبير، في الآية، قال: السِّرُّ: ما تُسِرُّ في نفسك. وأخفى مِن السِّرِّ: ما لم يكن بعدُ وهو كائِنٌ{6}. (١٠/١٦٢) ٤٧٤٢٢- عن سعيد بن جبير -من طريق ابن فضيل، عن عطاء بن السائب- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: السِّرُّ: ما أسررتَ في نفسك. وأخفى من ذلك: ما لم تُحَدِّث به نفسك{7}. (ز) ٤٧٤٢٣- عن سعيد بن جبير -من طريق خالد بن عبد الله، عن عطاء بن السائب- قال: أنت تعلم ما تُسِرُّ اليومَ، ولا تعلم ما تُسِرُّ غدًا، والله يعلمُ ما أسررتَ اليوم، وما تُسِرُّ غدًا{8}. (ز) ٤٧٤٢٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: الوسوسة، والسر: العملُ الذي تُسِرُّون مِن الناس{9}. (١٠/١٦١) ٤٧٤٢٥- عن الضحاك بن مزاحم، في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: السر: ما أسررتَ في نفسك. وأخفى: ما لم تُحَدِّث به نفسَك{10}. (١٠/١٦٢) ٤٧٤٢٦- عن عبيد، قال: سمعتُ الضحاك بن مزاحم يقول: <q>﴿يعلم السر وأخفى﴾</q>؛ أمّا السِّرُّ: فما أسررتَ في نفسك. وأمّا أخفى مِن السِّرِّ: فما لم تَعْلَمه وأنت عاملُه، يعلمُ اللهَ ذلك كله{11}. (ز) ٤٧٤٢٧- عن عكرمة مولى ابن عباس، في الآية، قال: السِّرُّ: ما حدَّث به الرجلُ أهلَه. وأخفى: ما تكلَّمْتَ به في نفسك{6}. (١٠/١٦٢) ٤٧٤٢٨- عن الحسن البصري، قال: السِّرُّ: ما أسرَّ الرجلُ إلى غيره. وأخفى من ذلك: ما أسرَّ في نفسه{6}. (١٠/١٦١) ٤٧٤٢٩- عن يعلى بن مسلم، قال: سمعتُ وهب بن منبه، في قول الله ﷿: <q>﴿يعلم السر وأخفى﴾</q>، قال: السِّرُّ: ما يَتَسارّون به. وأخفى: ما تُكِنُّ القلوب{14}. (ز) ٤٧٤٣٠- عن قتادة بن دعامة -من طريق الحسن بن دينار- قال: السِّرُّ: ما أخفيتَ في نفسك. وأخفى منه: ما علِم الله -تبارك وتعالى- أنّك عامِلٌ{15}. (ز) ٤٧٤٣١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: أخفى من السر: ما حدَّثْتَ به نفسَك، وما لم تُحَدِّث به نفسَك أيضًا مِمّا هو كائِن{16}. (١٠/١٥٢) ٤٧٤٣٢- عن زيد بن أسلم -من طريق حفص بن ميسرة- في قوله ﷿: <q>﴿يعلم السر وأخفى﴾</q>، قال: يعلم أسرار العباد، وأخفى سرَّه فلا يُعلَم{17}٤٢٣٦. (١٠/١٦٢) ٤٢٣٦ وجّه ابن جرير (١٦/١٦) قول زيد وابنه عبد الرحمن، فقال: «وكأنّ الذين وجهوا تأويل ذلك إلى أن السِّرَّ هو: ما حدث به الإنسانُ غيره سِرًّا، وأن أخفى: معناه: ما حدث به نفسه، وجهوا تأويل أخفى إلى الخفي». وانتقد ابنُ عطية (٦/٨٠) هذا القول، فقال: «وقد تُؤُوِّل على بعض السلف أنه جعل <q>﴿وأَخْفى﴾</q> فعلًا ماضيًا، وهذا ضعيف». ٤٧٤٣٣- قال مقاتل بن سليمان: <q>﴿وإن تجهر بالقول﴾</q> يعني: النبيَّ ﷺ، وإن تُعْلِن بالقول <q>﴿فإنه يعلم السر﴾</q> يعني: ما أسرَّ العبدُ في نفسه، <q>﴿و﴾</q>ما <q>﴿أخفى﴾</q> مِن السِّرِّ، ما لا يعلم أنه يعلمه{18}، وهو عامله، فيعلم الله ذلك كلَّه{19}٤٢٣٧. (ز) ٤٢٣٧ قال ابنُ عطية (٦/٨٠): «المخاطبة بـ<q>﴿تَجْهَرْ﴾</q> لمحمد ﷺ، وهي مراد بها جميع الناس؛ إذ هي آية اعتبار». ٤٧٤٣٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يعلم السر وأخفى﴾</q>، قال: يعلم أسرار العباد، وأخفى سِرَّه فلا يُعلَم{20}٤٢٣٨. (ز) ٤٢٣٨ للسلف في تفسير قوله: <q>﴿وأخفى﴾</q> ثلاثة أقوال: الأول: أنه ما حدَّث الإنسان به نفسه ولم يعمله. الثاني: أنه ما علمَ الله مما هو كائن. الثالث: <q>﴿وأخفى﴾</q> فعل ماضٍ، والمعنى: أن الله أخفى سرَّه عن عباده فلا يعلمه أحد منهم. وهو قول ابن زيد. وقد رجّح ابن جرير (١٦/١٦-١٧) مستندًا إلى ظاهر الآية والدلالة العقلية القولَ الثاني، وانتقد قول ابن زيد مستندًا إلى اللغة، فذكر أنّ المعنى أن الله «يعلم السر وأخفى من السر؛ لأن ذلك هو الظاهر من الكلام، ولو كان معنى ذلك ما تأوله ابن زيد لكان الكلام: وأخفى الله سرَّه. لأنّ»أخفى«فعلٌ واقعٌ مُتَعَدِّ، إذ كان بمعنى»فعَل«على ما تأوله ابن زيد، وفي انفراد أخفى من مفعوله، والذي يعمل فيه لو كان بمعنى»فعَل«الدليل الواضح على أنه بمعنى أفعل، وأن تأويل الكلام: فإنه يعلم السر وأخفى منه. فإذ كان ذلك تأويله فالصواب من القول في معنى أخفى من السر أن يُقال: هو ما علم الله مما خفي عن العباد، ولم يعلموه مما هو كائن ولما يكن؛ لأنّ ما ظهر وكان فغير سِرٍّ، وأن ما لم يكن وهو غير كائن فلا شيء، وأن ما لم يكن وهو كائن فهو أخفى من السر، لأن ذلك لا يعلمه إلا الله، ثم مَن أعلمه ذلك من عباده». ",footnotes:1:أخرجه ابن جرير ١٦/١٣، والبيهقي في الأسماء والصفات (٧٣). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٣.أخرجه ابن جرير ١٦/١٤.أخرجه ابن جرير ١٦/١٣ واللفظ له، وأبو الشيخ في العظمة (١٧٢)، والبيهقي في الأسماء والصفات (٢٣٨). وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه الحاكم ٢/٣٧٨-٣٧٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/١٥.أخرجه سعيد بن منصور في سننه - التفسير ٦/٢٥٤ (١٤١٢).أخرجه إسحاق البستي في تفسيره ص٢٢٨ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد. وأخرج ابن أبي حاتم ٨/٢٦٦٤ شطره الأول من طريق أبي روق بلفظ: السر: ما حدثت به نفسك.أخرجه ابن جرير ١٦/١٥، وإسحاق البستي في تفسيره ص٢٢٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو الشيخ في العظمة ٢/٥١٨-٥١٩ (١٧١).أخرجه يحيى بن سلّام ١/٢٥٣.أخرجه يحيى بن سلّام ١/٢٥٣ بلفظ: السر: ما حدّثت به نفسك، وأخفى منه: ما هو كائن مما لم تحدث به نفسك، وعبد الرزاق ٢/١٥ من طريق معمر، وابن جرير ١٦/١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو الشيخ في العظمة ٢/٥١٦ (١٧٠)، وأخرج ابن أبي حاتم ٨/٢٦٦٤ شطره الأول.كذا في المطبوع.تفسير مقاتل بن سليمان ٣/٢١.أخرجه ابن جرير ١٦/١٦.
20,8," <q>﴿ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَۖ لَهُ ٱلۡأَسۡمَاۤءُ ٱلۡحُسۡنَىٰ ۝٨﴾</q> - تفسير ٤٧٤٣٥- قال مقاتل بن سليمان: ثم وحَّد نفسه -تبارك وتعالى-، إذ لم يُوَحِّده كُفّار مكة، فقال سبحانه: <q>﴿الله لا إله إلا هو له الأسماء الحسنى﴾</q>. وهي التي في آخر سورة الحشر ونحوه، لقولهم: ائتنا ببراءةٍ أنّه ليس مع إلهك إله{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٢.
20,9," <q>﴿وَهَلۡ أَتَىٰكَ حَدِیثُ مُوسَىٰۤ ۝٩﴾</q> - تفسير ٤٧٤٣٦- قال إسماعيل السُّدِّي: يقول: قد أتاك حديث موسى{1}. (ز) ٤٧٤٣٧- قال مقاتل بن سليمان: <q>﴿وهل أتاك﴾</q> يقول: وقد جاءك <q>﴿حديث موسى﴾</q>{2}. (ز) ٤٧٤٣٨- قال يحيى بن سلّام: قوله: <q>﴿وهل أتاك حديث موسى﴾</q>، أي: قد أتاك حديث موسى{3}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ١/٢٥٣.تفسير مقاتل بن سليمان ٣/٢٢.تفسير يحيى بن سلّام ١/٢٥٣.
20,10," <q>﴿إِذۡ رَءَا نَارࣰا فَقَالَ لِأَهۡلِهِ ٱمۡكُثُوۤا۟ إِنِّیۤ ءَانَسۡتُ نَارࣰا﴾</q> - تفسير ٤٧٤٣٩- عن عبد الله بن عباس -من طريق السدي، عن أبي مالك، وعن أبي صالح- قال: لَمّا قضى موسى الأجلَ سار بأهله، فَضَلَّ الطريقَ. قال عبد الله بن عباس: كان في الشتاء، ورُفِعَت لهم نارٌ، فلمّا رآها ظنَّ أنّها نارٌ، وكانت مِن نور الله، <q>﴿فقال لأهله امكثوا إني آنست نارا﴾</q>{1}. (ز) ٤٧٤٤٠- قال سعيد بن جبير: هي النارُ بعينها، وهي إحدى حُجُب الله تعالى{2}. (ز) ٤٧٤٤١- عن عكرمة مولى ابن عباس: إنّه نور الربِّ ﷿{3}. (ز) ٤٧٤٤٢- عن وهب بن مُنَبِّه -من طريق ابن إسحاق- قال: لَمّا قضى موسى الأجلَ خرج ومعه غنم له، ومعه زَند له، وعصاه في يده يَهُشُّ بها على غنمه نهارًا، فإذا أمسى اقْتَدَح بزَندِه نارًا، فبات عليها هو وأهله وغنمه، فإذا أصبح غدا بغنمه وأهله يَتَوَكَّأُ على عصاه، فلمّا كانت الليلةُ التي أراد الله بموسى كرامتَه وابتداءَهُ فيها بنُبُوَّته وكلامه؛ أخطأ فيها الطريقَ حتى لا يدري أين يتوجه، فأخرج زَنده لِيَقْتَدِح نارًا لأهله ليبيتوا عليها حتى يصبح، ويعلم وجْهَ سبيله، فأصْلَد زَندُه فلا يُورى له نارًا، فقَدَحَ حتى إذا أعياه لاحَتِ النارُ، فرآها، فقال لأهله: <q>﴿امكثوا إني آنست نارا لعلي آتيكم منها بقبس﴾</q>{4}. (ز) ٤٧٤٤٣- عن قتادة بن دعامة، في قوله: <q>﴿إني آنست نارا﴾</q>: أي: أحْسَسْتُ نارًا{5}. (١٠/١٦٢) ٤٧٤٤٤- تفسير إسماعيل السُّدِّي: <q>﴿فقال لأهله امكثوا إني آنست نارا﴾</q>، يعني: أنّي رأيت نورًا{6}٤٢٣٩. (ز) ٤٢٣٩ قال ابنُ عطية (٦/٨١): «والنار على البعد لا تُحَسُّ إلا بالبصر، ولذلك فسَّر بعضهم اللفظة بـ:»رأيت«، و»آنس«أعمُّ من رَأى؛ لأنك تقول: آنست من فلان خيرًا أو شرًّا». ٤٧٤٤٥- قال مقاتل بن سليمان: <q>﴿إذ رأى نارا﴾</q> ليلة الجمعة في الشتاء بأرض المقدسة؛ <q>﴿فقال لأهله﴾</q> يعني: امرأته، وولده: <q>﴿امكثوا﴾</q> مكانَكم <q>﴿إني آنست نارا﴾</q> يعني: إني رأيت نارًا، وهو نور رب العالمين -تبارك وتعالى-{7}. (ز) ٤٧٤٤٦- قال يحيى بن سلّام: <q>﴿إذ رأى نارا﴾</q>، أي: عند نفسه، وإنما كانت نورًا{8}. (ز) <q>﴿لَّعَلِّیۤ ءَاتِیكُم مِّنۡهَا بِقَبَسٍ﴾</q> - تفسير ٤٧٤٤٧- عن وهب بن منبه -من طريق ابن إسحاق- قال: <q>﴿لعلي آتيكم منها بقبس﴾</q>، قال: بقَبَس تَصْطَلُون{9}. (ز) ٤٧٤٤٨- قال مقاتل بن سليمان: <q>﴿لعلي آتيكم منها بقبس﴾</q>، فأقتبس النارَ لكي تَصْطَلُونَ من البرد{7}. (ز) ٤٧٤٤٩- قال يحيى بن سلّام: <q>﴿لعلي آتيكم منها بقبس﴾</q>، وقال في آية أخرى: <q>﴿سآتيكم منها بخبر أو آتيكم بشهاب قبس لعلكم تصطلون﴾</q> [النمل:٧]، لكي تَصْطَلُوا، وكان شاتيًا. وقال في هذه: <q>﴿لعلي آتيكم منها بقبس﴾</q>{11}. (ز) <q>﴿أَوۡ أَجِدُ عَلَى ٱلنَّارِ هُدࣰى ۝١٠﴾</q> - تفسير ٤٧٤٥٠- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿لعلي آتيكم منها بقبس أو أجد على النار هدى﴾</q>، قال: كانوا ضَلُّوا عن الطريق، فقال: لعلَّني أجِد مَن يَدُلُّني على الطريق، أو آتيكم بقبس لعلكم تَصْطَلُونَ{12}. (ز) ٤٧٤٥١- عن عبد الله بن عباس، في قوله: <q>﴿أو أجد على النار هدى﴾</q>، قال: مَن يهديني إلى الطريق. وكانوا شاتِين، فضلُّوا الطريقَ{13}. (١٠/١٦٢) ٤٧٤٥٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أو أجد على النار هدى﴾</q>، يقول: مَن يَدُلُّ على الطريق{14}. (١٠/١٦٢) ٤٧٤٥٣- عن المعتمر، قال: سمعتُ أبي يُحَدِّث عن قتادة، عن صاحبٍ له، عن حديث عبد الله بن عباس، أنّه زعم: أنها أيْلَة. <q>﴿أو أجد على النار هدى﴾</q>= (ز) ٤٧٤٥٤- وقال أبي: وزعم قتادةُ أنه: هَدْيُ الطريق{15}. (ز) ٤٧٤٥٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿أو أجد على النار هدى﴾</q>، قال: يهديه إلى الطريق{16}. (١٠/١٦٣) ٤٧٤٥٦- عن عكرمة مولى ابن عباس، في قوله: <q>﴿أو أجد على النار هدى﴾</q>، قال: هادٍ يهديني إلى الماء{17}. (١٠/١٦٣) ٤٧٤٥٧- قال الحسن البصري: وكان على غير الطريق، كان يمشي مُتَوَكِّلًا على ربه، مُتَوَجِّهًا بغير علم{18}. (ز) ٤٧٤٥٨- عن وهب بن منبه -من طريق ابن إسحاق- <q>﴿أو أجد على النار هدى﴾</q>، قال: هدى عن عَلَم الطريق الذي أضْلَلْنا؛ بِنَعْتِ مَن خَبَرَ{12}. (ز) ٤٧٤٥٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أو أجد على النار هدى﴾</q>، قال: مَن يهديني الطريقَ{20}. (١٠/١٦٢) ٤٧٤٦٠- قال إسماعيل السُّدِّي: مُرشِدًا للطريق{21}. (ز) ٤٧٤٦١- قال مقاتل بن سليمان: <q>﴿أو أجد على النار هدى﴾</q>، يعني: مَن يرشدني إلى الطريق، وكان موسى ﵇ قد تحيَّر ليلًا، وضلَّ الطريق، فلما انتهى إليها سمِع تسبيح الملائكة، ورأى نورًا عظيمًا، فخاف، وألقى اللهُ ﷿ عليه السكينةَ{7}٤٢٤٠. (ز) ٤٢٤٠ قال ابنُ عطية (٦/٨١): «والهدى، أراد: هدى الطريق، أي: لعلي أجد ذا هُدًى، مرشدًا لي، أو دليلًا، وإن لم يكن فخبرًا. و»الهدى«يعمُّ هذا كله». ",footnotes:1:أخرجه ابن جرير ١٦/١٩.أورده البغوي في تفسيره ٥/٢٦٦، ٦/١٤٥. ووَجَّهه بقوله: يدل عليه ما رُوينا عن أبي موسى الأشعري عن النبي ﷺ قال: «حجابه النار، لو كشفها لأحرقت سبحات وجهه ما انتهى إليه بصرُه من خلقه». والحديث أخرجه مسلم ١/١٦١ (١٧٩).تفسير البغوي ٥/٢٦٥.أخرجه ابن جرير ١٦/١٩. وبنحوه مختصرًا في تفسير الثعلبي ٦/٢٣٩، وفي أوله: استأذن موسى شعيبًا في الرجوع إلى والدته، فأذن له، فخرج بأهله، فولد له ابنٌ في الطريق في ليلة شاتية مثلجة، وقد حاد عن الطريق.أخرجه عبد الرزاق ٢/١٥، وابن أبي حاتم ٩/٢٨٤٢، ٢٩٧٢. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ١/٢٥٣.تفسير مقاتل بن سليمان ٣/٢٢.تفسير يحيى بن سلّام ١/٢٥٣.أخرجه ابن جرير ١٦/٢٠.تفسير مقاتل بن سليمان ٣/٢٢.تفسير يحيى بن سلّام ١/٢٥٤.أخرجه ابن جرير ١٦/٢٢.عزاه السيوطي إلى ابن أبي حاتم، وبنحوه في ٩/٢٩٧٢ من طريق عكرمة.أخرجه ابن جرير ١٦/٢١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٢١.أخرجه ابن جرير ١٦/٢١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلّام ١/٢٥٤.أخرجه ابن جرير ١٦/٢٢.أخرجه يحيى بن سلّام ١/٢٥٤، وابن جرير ١٦/٢١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلّام ١/٢٥٤.تفسير مقاتل بن سليمان ٣/٢٢.
20,11," <q>﴿فَلَمَّاۤ أَتَىٰهَا﴾</q> - تفسير ٤٧٤٦٢- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: لَمّا رأى موسى النارَ انطلق يسير، حتى وقف منها قريبًا، فإذا هو بنار عظيمة، تفور مِن ورق شجرة خضراء شديدة الخضرة، يُقال لها: العُلِّيق{1}. (١٠/١٦٣) ٤٧٤٦٣- قال مقاتل بن سليمان: <q>﴿فلما أتاها﴾</q> انتهى إليها <q>﴿نودي يا موسى﴾</q>{2}. (ز) ٤٧٤٦٤- قال يحيى بن سلّام: قوله: <q>﴿فلما أتاها﴾</q>، يعني: أتى النار التي ظنَّ أنها نار{3}. (ز) <q>﴿نُودِیَ یَـٰمُوسَىٰۤ ۝١١﴾</q> - تفسير ٤٧٤٦٥- عن وهب بن مُنَبِّه -من طريق ابن إسحاق- قال: خرج موسى نحوها -يعني: نحو النار-، فإذا هي في شجر من العُلِّيق، وبعض أهل الكتاب يقول: في عَوْسَجَة{4}، فلمّا دنا اسْتَأْخَرَتْ عنه، فلما رأى اسْتِئْخارها رَجَع عنها، وأوجس في نفسه منها خِيفَةً، فلما أراد الرجعة دَنَتْ منه، ثم كُلِّم مِن الشجرة، فلمّا سمع الصوت اسْتَأنس، وقال اللهُ -تبارك وتعالى-: يا موسى، اخلع نعليك إنك بالواد المقدس طوى. فخلعها، فألقاها{5}. (ز) ٤٧٤٦٦- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: نُودِي من الشجرة، فقيل: يا موسى. فأجاب سريعًا، وما يدري مَن دعاه، وما كان سرعة إجابته إلا استئناسًا بالإنس، فقال: لبَّيْك -مِرارًا-، إني لَأسمعُ صوتَك، وأُحِسُّ حِسَّك، ولا أرى مكانك، فأين أنت؟ قال: أنا فوقك ومعك وخلفك، وأقربُ إليك مِن نفسك. فلمّا سمع هذا موسى عَلِم أنّه لا ينبغي هذا إلا لِرَبِّه، فأيْقَنَ به{6}. (١٠/١٦٤) ",footnotes:1:أخرجه أحمد في الزهد ص٦١-٦٦، وابن أبي حاتم ٩/٢٨٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢.تفسير يحيى بن سلّام ١/٢٥٤.العَوْسَج: شجر من شجر الشوك، وله ثمر أحمر مُدَوَّر كأنه خَرَز العقيق. اللسان (عسج).أخرجه ابن جرير ١٦/٢٢.أخرجه أحمد في الزهد ص٦١-٦٦، وابن أبي حاتم ٩/٢٨٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وينظر: تفسير البغوي ٥/٢٦٦.
20,12," <q>﴿إِنِّیۤ أَنَا۠ رَبُّكَ فَٱخۡلَعۡ نَعۡلَیۡكَ﴾</q> - تفسير ٤٧٤٦٧- عن عبد الله بن مسعود، مرفوعًا، في قوله: <q>﴿فاخلع نعليك﴾</q>، قال: كانتا مِن جِلْد حمار ميِّت{1}. (ز) ٤٧٤٦٨- عن علي بن أبي طالب -من طريق عمير بن سعيد- في قوله: <q>﴿فاخلع نعليك﴾</q>، قال: كانتا مِن جِلْد حمار ميِّت، فقيل له: اخلعهما{2}. (١٠/١٧١) ٤٧٤٦٩- عن أبي عبد الرحمن الحُبُلي، قال: رأيتُ أبا أيوب الأنصاري يُصَلِّي وعليه نعليه، فقلتُ له: إنّ الله يقول لموسى: <q>﴿فاخلع نعليك إنك بالواد المقدس طوى﴾</q>. فقال أبو أيوب: إنّهما كانتا مِن جِلْد حمار ميِّت{3}. (ز) ٤٧٤٧٠- عن كعب الأحبار، في قوله: <q>﴿فاخلع نعليك﴾</q>، قال: كان نَعْلا موسى مِن جِلْدِ حمار ميِّت، فأراد ربُّك أن يمسَّه القُدْسُ كلُّه{4}. (١٠/١٧١) ٤٧٤٧١- عن أبي قِلابة عبد الله بن زيد الجرمي -من طريق عاصم الأحول- قال: تدرون لِمَ قال اللهُ تعالى: <q>﴿فاخلع نعليك إنك بالواد المقدس طوى﴾</q>؟ قال: كانت نعلاه مِن جلد حمار ميت، فأحبَّ أن يباشر القُدْسَ بقدميه{5}. (ز) ٤٧٤٧٢- عن مجاهد بن جبر، قال: كانت نعلا موسى -التي قيل له: اخْلَعْهما- مِن جِلْد خنزير{6}. (١٠/١٧١) ٤٧٤٧٣- قال ابن جُرَيج: وقيل لمجاهد: زعموا: أنّ نعليه كانتا مِن جلد حمار أو ميتة. قال: لا، ولكنَّه أُمِرَ أن يُباشِر بقَدَمَيْه برَكَة الأرض{7}. (ز) ٤٧٤٧٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله تعالى: <q>﴿فاخلع نعليك﴾</q>، قال: طَأ الأرض بقدميك{8}. (ز) ٤٧٤٧٥- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿فاخلع نعليك﴾</q>، قال: كانتا مِن جلد حمار ميِّت{9}. (ز) ٤٧٤٧٦- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فاخلع نعليك﴾</q>، قال: كي تمسَّ راحةُ قدميك الأرضَ الطيِّبة{10}. (١٠/١٧١) ٤٧٤٧٧- عن الحسن البصري، قال: ما بالُ خَلْع النَّعْلَيْن في الصلاة؟! إنّما أُمِرَ موسى أن يخلع نعليه أنّهما كانتا مِن جلد حمار ميت{11}. (١٠/١٧١) ٤٧٤٧٨- قال ابن جريج، قال الحسن البصري: كانتا -يعني: نَعْلي موسى ﵇ مِن بقر، ولكن إنما أراد الله أن يباشر بقدميه بركة الأرض، وكان قد قُدِّس مرتين{12}. (ز) ٤٧٤٧٩- عن قتادة بن دعامة -من طريق معمر- قال: كانتا مِن جلد حمار، فقيل له: اخلعهما{13}. (ز) ٤٧٤٨٠- عن محمد ابن شهاب الزهري، في قوله: <q>﴿فاخلع نعليك﴾</q>، قال: كانتا مِن جِلد حمار أهْلِيٍّ{6}. (١٠/١٧١) ٤٧٤٨١- عن ابن أبي نَجِيح -من طريق ابن عُلَيَّة- في قوله: <q>﴿فاخلع نعليك إنك بالواد المقدس طوى﴾</q>، قال: يقول: أفْضِ بقَدَمَيْك إلى بركة الوادي{12}. (ز) ٤٧٤٨٢- قال مقاتل بن سليمان: <q>﴿إني أنا ربك فاخلع نعليك﴾</q> مِن قَدَمَيْك، وكانتا مِن جلد حمار مَيِّت غير ذَكِيٍّ، فخلعهما موسى ﵇، وألقاهما مِن وراء الوادي{16}٤٢٤١. (ز) ٤٢٤١ اختلف السلف في السبب الذي من أجله أمر الله موسى بخلع نعليه على قولين: الأول: لنجاستهما؛ إذ كانتا من جلد حمار ميت. وقيل: مِن جلد خنزير. الثاني: أنّ الله أراد أن يطأ موسى الأرض بقدميه لينال من بركتها. وقد رجّح ابن جرير (١٦/٢٥) مستندًا إلى السياق القول الثاني، وعلل ذلك بقوله: «وإنما قلنا ذلك أولى التأويلين بالصواب لأنّه لا دلالة في ظاهر التنزيل على أنه أُمِر بخلعهما مِن أجل أنهما من جلد حمار ولا لنجاستهما، ولا خبر بذلك عمَّن تلزم بقوله الحجة، وإن في قوله: <q>﴿إنك بالواد المقدس﴾</q> بعَقِبه دليلًا واضحًا على أنه إنما أمره بخلعهما لما ذكرنا». ثم أورد حديث ابن مسعود المرفوع -الآتي في الآثار المتعلقة بالآية- وقال: «لو كان صحيحًا لم نعدُهُ إلى غيره». ثم انتقده، فقال: «لكنَّ في إسناده نظرًا يجب التثبت فيه». وقد ذكر ابنُ عطية (٦/٨٢) القولين، ثم بيّن أن الآية تحتمل وجهًا ثالثًا، ورجّحه مستندًا إلى الدلالة العقلية، فقال: «وتحتمل الآية معنًى آخر، هو الأليق بها عندي، وذلك أنّ الله تعالى أمره أن يتواضع لِعِظم الحال التي حصل فيها، والعُرْف عند الملوك أن تُخلَع النعلان، ويبلغ الإنسان إلى غاية تواضعه، فكأنّ موسى ﵇ أُمر بذلك على هذا الوجه، ولا نبالي كانت نعلاه من ميتة أو غيرها». <q>﴿إِنِّیۤ أَنَا۠ رَبُّكَ فَٱخۡلَعۡ نَعۡلَیۡكَ﴾</q> - آثار متعلقة بالآية ٤٧٤٨٣- عن عبد الله بن مسعود، عن نبيِّ الله ﷺ، قال: «يوم كلَّم الله موسى كانت عليه جُبَّةُ صوف، وكِساء صوف، وسراويل صوف، ونعلان مِن جلد حمار غير ذَكِيٍّ»{17}. (ز) ٤٧٤٨٤- عن علقمة: أنّ عبد الله بن مسعود أتى أبا موسى الأشعري في منزله، فحضرت الصلاةُ، فقال له أبو موسى: تقدَّم، يا أبا عبد الرحمن؛ فإنّك أقدمُ سِنًّا وأعلم. قال: لا، بل تقدَّم أنت؛ فإنّما أتيناك في منزلك. فتقدم أبو موسى، فخلع نعليه، فلما صلّى قال له ابن مسعود: لِمَ خَلَعْتَ نعليك؟ أبِالواد المقدس أنت؟! لقد رأيتُ رسولَ الله ﷺ يُصَلِّي في الخُفَّين والنَّعْلَيْن{18}. (١٠/١٧٢) <q>﴿إِنَّكَ بِٱلۡوَادِ ٱلۡمُقَدَّسِ﴾</q> - تفسير ٤٧٤٨٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنك بالواد المقدس﴾</q>، قال: المبارك{19}. (١٠/١٧٢) ٤٧٤٨٦- عن مجاهد بن جبر، في قوله: <q>﴿إنك بالواد المقدس﴾</q>، قال: المُبارَك{20}. (١٠/١٧٢) ٤٧٤٨٧- عن مجاهد بن جبر -من طريق ابن جريج- قوله: <q>﴿إنك بالواد المقدس﴾</q>، قال: قُدِّسَ: بُورِكَ مرَّتَيْن{21}. (ز) ٤٧٤٨٨- عن عكرمة مولى ابن عباس، في قوله: <q>﴿بالواد المقدس﴾</q>، قال: الطّاهِر{6}. (١٠/١٧٢) ٤٧٤٨٩- عن الحسن البصري، في قوله: <q>﴿بالواد المقدس﴾</q>، قال: وادٍ بفلسطين قُدِّسَ مرتين{6}. (١٠/١٧٢) ٤٧٤٩٠- عن قتادة بن دعامة -من طريق سعيد- قال: قُدِّسَ مرتين، أي: بُورِك مرتين، واسمه: طُوى{24}. (ز) ٤٧٤٩١- قال مقاتل بن سليمان: <q>﴿إنك بالواد المقدس﴾</q>، يعني: بالوادي المُطَهَّر{25}. (ز) ٤٧٤٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قوله: <q>﴿إنك بالواد المقدس طوى﴾</q>، قال: بالوادي المبارك{21}. (ز) ٤٧٤٩٣- قال يحيى بن سلّام: قوله: <q>﴿إنك بالواد المقدس طوى﴾</q>، والمُقَدَّس: المبارك{27}. (ز) <q>﴿طُوࣰى ۝١٢﴾</q> - قراءات ٤٧٤٩٤- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿طُوًى﴾</q> برفع الطاء، وبنون فيها{28}. (١٠/١٧٢) <q>﴿طُوࣰى ۝١٢﴾</q> - تفسير الآية ٤٧٤٩٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿طوى﴾</q>، قال: اسم الوادي{19}٤٢٤٢. (١٠/١٧٢) ٤٢٤٢ علّق ابنُ كثير (٩/٣١٧) على قول ابن عباس، فقال: «فعلى هذا يكون عطفَ بيان». ٤٧٤٩٦- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿بالواد المقدس طوى﴾</q>: يعني: الأرض المقدسة؛ وذلك أنه مرَّ بواديها ليلًا، فطَواه -يقال: طَوَيْتُ وادي كذا وكذا طُوًى- من الليل، وارتفع إلى أعلى الوادي، وذلك نبيُّ الله موسى{30}٤٢٤٣. (١٠/١٧٢) ٤٢٤٣ علّق ابن جرير (١٦/٢٧) على قول ابن عباس: «فعلى هذا القول مِن قولهم طوى، مصدرٌ أُخرج من غير لفظه، كأنه قيل: طويت الوادي المقدس طوى». ٤٧٤٩٧- عن عبد الله بن عباس -من طريق عكرمة– في قوله: <q>﴿طوى﴾</q>، قال: طأِ الواديَ{31}. (١٠/١٧٣) ٤٧٤٩٨- عن ابن أبي نَجِيح، في قوله: <q>﴿طوى﴾</q>، قال: طأِ الأرضَ حافيًا، كما تدخل الكعبةَ حافيًا. يقول: مِن بركة الوادي. هذا قول سعيد بن جبير= (ز) ٤٧٤٩٩- قال: وكان مجاهدٌ يقول: <q>﴿طوى﴾</q> اسم الوادي{32}. (١٠/١٧٣) ٤٧٥٠٠- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- في قوله: <q>﴿طوى﴾</q>، قال: اسم الوادي{33}. (١٠/١٧٣) ٤٧٥٠١- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿طوى﴾</q>: طأِ الأرض حافيًا{31}. (ز) ٤٧٥٠٢- قال الضحاك بن مزاحم: وادٍ عميقٌ مستديرٌ، مثل الطَّوِيِّ{35} في استدارته{36}. (ز) ٤٧٥٠٣- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿طوى﴾</q>، قال: طأِ الوادي{37}. (ز) ٤٧٥٠٤- عن الحسن البصري-من طريق ابن جريج-: كان قُدِّس مرتين{38}. (ز) ٤٧٥٠٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بالواد المقدس طوى﴾</q>، قال: واد قُدِّس مرتين، واسمه: طوى{39}٤٢٤٤. (١٠/١٧٣) ٤٢٤٤ علّق ابن جرير (١٦/٢٧ بتصرف) على قول قتادة، فقال: «فعلى قول هؤلاء <q>﴿طوى﴾</q> مصدرٌ مِن غير لفظه، وذلك أنّ معناه عندهم: نُودِي: يا موسى، مرتين نداءين». ٤٧٥٠٦- قال مقاتل بن سليمان: <q>﴿طوى﴾</q>، وهو اسم الوادي{25}. (ز) ٤٧٥٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بالواد المقدس طوى﴾</q>، قال: ذاك الوادي هو طوى، حيث كان موسى، وحيث كان إليه مِن الله ما كان. قال: وهو نحو الطور{41}. (ز) ٤٧٥٠٨- عن مُبَشَّر بن عبيد: <q>﴿طوى﴾</q> بغير نون، وادٍ بأيْلَة، زعم أنه طُوِي بالبركة مرتين{6}٤٢٤٥. (١٠/١٧٢) ٤٢٤٥ أفادت الآثار اختلاف السلف في تفسير قوله: <q>﴿طوى﴾</q> على أربعة أقوال: الأول: أنّ معناه: إنّك بالوادي المقدس طويتَه، أي: الذي طواه موسى مشيًا بقدميه. الثاني: أنّ <q>﴿طوى﴾</q> معناه: مرتين، فيكون المعنى، إما: بالوادي المقدس مرتين، أو: ناداه مرتين بالواد المقدس. الثالث: أنه أمرٌ من الله لموسى أن يطأ الوادي بقدمه. الرابع: أنه اسم للوادي. وقد رجّح ابن جرير (١٦/٣٠) القول الرابع بقوله: «وهو عندي اسم الوادي» مستندًا إلى أقوال السلف. وكذا رجّحه ابنُ كثير (٩/٣١٧) مستندًا إلى ظاهر القرآن بقوله عنه: «والأول أصحَّ؛ لقوله: <q>﴿إذ ناداه ربه بالواد المقدس طوى﴾</q> [النازعات: ١٦]». ",footnotes:1:أخرجه الثعلبي ٦/٢٤٠، وأورده البغوي ٥/٢٦٦. وفيه حميد الأعرج الكوفي، منكر الحديث. وينظر تخريج الحديث الأول في الآثار المتعلقة بالآية.أخرجه عبد الرزاق ٢/١٦. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٣٠عزاه السيوطي إلى عبد بن حميد. وأخرجه مالك في الموطأ ٢/٥٠٣ (٢٦٦١) بنحوه من طريق أبي سهيل بن مالك عن أبيه، وعبد الرزاق في تفسيره ٢/١٥ من طريق أبي قلابة، وآخره بلفظ: فأُمِر أن يباشر القدْسَ بقدميه، وبنحوه ابن جرير ١٦/٢٣.أخرجه ابن عساكر في تاريخ دمشق ٦١/٤٩، وأخرجه عبد الرزاق في تفسيره ٢/١٥ عن كعب الأحبار من طريق أبي قلابة.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤. وفي تفسير الثعلبي ٦/٢٤٠، وتفسير البغوي ٥/٢٦٦: أُمر بخلع النعلين ليباشر بقدمه تراب الأرض المقدسة، فيناله بركتها؛ لأنها قُدِّست مرتين.أخرجه أبو جعفر الرملي في جزئه ص٥٤ (تفسير مسلم الزنجي).أخرجه الثوري في تفسيره ص١٩٣ من طريق حصين، وابن جرير ١٦/٢٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٢٤.أخرجه عبد الرزاق ٢/١٥، وابن جرير ١٦/٢٤، وأخرجه يحيى بن سلّام في تفسيره ١/٢٥٤ من طريق سعيد، وقال عَقِبَه: فخلعهما ثم أتى.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٤.تفسير مقاتل بن سليمان ٣/٢٢.أخرجه الترمذي ٣/٥٢٦-٥٢٧ (١٨٣١)، والحاكم ١/٨١ (٧٦)، ٢/٤١١ (٣٤٣١)، وابن جرير ١٦/٢٥، وسعيد بن منصور في التفسير ٥/١٥٣ (٩٦٠). قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث حميد الأعرج، وحميد هو ابن علي الكوفي، منكر الحديث، وحميد بن قيس الأعرج المكي صاحب مجاهد ثقة». وقال ابن جرير: «في إسناده نظر». وقال الحاكم في الموضع الأول: «قد اتفقا جميعًا على الاحتجاج بحديث سعيد بن منصور، وحميد هذا ليس بابن قيس الأعرج، قال البخاري في التاريخ: حميد بن علي الأعرج الكوفي منكر الحديث. وعبد الله بن الحارث النجراني مُحْتَجٌّ به، واحتج مسلم وحده بِخَلَف بن خليفة. وهذا حديث كبير في التصوف والتكلم، ولم يخرجاه، وله شاهد من حديث إسماعيل بن عياش». وتعقّبه الذهبي بقوله: «حميد هذا ليس بابن قيس». وقال الحاكم في الموضع الثاني: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». وتعقّبه الذهبي بقوله: «بل ليس على شرط البخاري». وقال ابن الجوزي في الموضوعات ١/١٩٢-١٩٣: «هذا حديث لا يصِحُّ». وقال الألباني في الضعيفة ٣/٣٨٩ (١٢٤٠): «ضعيف جِدًّا».أخرجه أحمد ٧/٤٠٤-٤٠٥ (٤٣٩٧). قال البوصيري في إتحاف الخيرة ٢/١٢٧ (١١٨٠): «هذا إسناد رجاله ثقات، إلا أنّ أبا إسحاق اختلط بآخرة، وزهير روى عنه بعد الاختلاط، ومع ذلك فيه انقطاع». قال ابن حجر في إتحاف المهرة ١٠/٣٥٦-٣٥٧ (١٢٩٢٧): «قال أحمد: ثنا حسن بن موسى، ثنا زهير، عن أبي إسحاق، عن علقمة، ولم يسمعه منه، به».أخرجه ابن جرير ١٦/٢٦، وابن أبي حاتم -كما في التغليق ٤/٢٥٦، والإتقان ٢/٢٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٢٦.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٥٤.تفسير مقاتل بن سليمان ٣/٢٣.أخرجه ابن جرير ١٦/٢٦.تفسير يحيى بن سلّام ١/٢٥٤.عزاه السيوطي إلى عبد بن حميد. وهي قراءة ابن عامر، وعاصم، وحمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: ‹طُوى› بغير تنوين. انظر: النشر ٢/٨٨، والإتحاف ص٣٨٢.أخرجه ابن جرير ١٦/٢٦، وابن أبي حاتم -كما في التغليق ٤/٢٥٦، والإتقان ٢/٢٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٢٧. وعزاه السيوطي إلى ابن أبي حاتم، بلفظ: «والطاوي من الليل» بدل: «طوى من الليل».أخرجه ابن جرير ١٦/٢٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٧٠٣، وأخرجه ابن جرير ١٦/٢٨. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٩.الطوي: البئر. لسان العرب (طوى).تفسير الثعلبي ٦/٢٤٠.أخرجه يحيى بن سلّام ١/٢٥٤ من طريق عبد الكريم الجزري، وابن جرير ١٦/٢٩.أخرجه ابن جرير ١٦/٢٤، ٢٨. وعلَّقه يحيى بن سلّام ١/٢٥٤ بلفظ: طُوِي بالبركة مرتين.أخرجه يحيى بن سلّام ١/٢٥٤، وعبد الرزاق ٢/١٥ من طريق معمر بنحوه، وابن جرير ١٦/٢٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٣.أخرجه ابن جرير ١٦/٢٨.عزاه السيوطي إلى ابن أبي حاتم.
