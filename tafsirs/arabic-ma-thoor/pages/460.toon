  39,13,""
  39,14,""
39,15," <q>﴿فَٱعۡبُدُوا۟ مَا شِئۡتُم مِّن دُونِهِۦۗ قُلۡ إِنَّ ٱلۡخَـٰسِرِینَ ٱلَّذِینَ خَسِرُوۤا۟ أَنفُسَهُمۡ وَأَهۡلِیهِمۡ یَوۡمَ ٱلۡقِیَـٰمَةِۗ أَلَا ذَ ٰ⁠لِكَ هُوَ ٱلۡخُسۡرَانُ ٱلۡمُبِینُ ۝١٥﴾</q> - تفسير ٦٧٢٣٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿قُلْ إنَّ الخاسِرِينَ الَّذِينَ خَسِرُوا أنْفُسَهُمْ﴾</q> الآية، قال: هم الكُفّار الذين خلقهم الله للنار، وخلق النار لهم، فزالت عنهم الدنيا، وحُرِّمت عليهم الجنة، قال الله: <q>﴿خسر الدنيا والآخرة﴾</q> [الحج:١١]{1}. (١٢/٦٤٠) ٦٧٢٣٩- عن عبد الله بن عباس، في قوله: <q>﴿الَّذِينَ خَسِرُوا أنْفُسَهُمْ وأَهْلِيهِمْ يَوْمَ القِيامَةِ﴾</q>، قال: أهليهم مِن أهل الجنة، كانوا أُعِدُّوا لهم لو عملوا بطاعة الله فغبنوهم{2}٥٦١٦. (١٢/٦٤٠) ٥٦١٦ علَّق ابنُ عطية (٧/٣٨٢) على قول ابن عباس وما في معناه بقوله: «فهذا كما لو قال: خسروا أنفسهم ونعيمهم، أي: الذي كان يكون لهم». ٦٧٢٤٠- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿إنَّ الخاسِرِينَ الَّذِينَ خَسِرُوا أنْفُسَهُمْ﴾</q> قال: غبنوا أنفسهم وأهليهم، <q>﴿خَسِرُوا أنْفُسَهُمْ﴾</q> يخسرونها، فيتحسّرون في النار وهم أحياء، ويخسرون أهليهم، فلا يكون لهم أهل يرجعون إليهم{3}. (١٢/٦٤٠) ٦٧٢٤١- عن قتادة بن دعامة -من طريق معمر- <q>﴿الَّذِينَ خَسِرُوا أنْفُسَهُمْ وأَهْلِيهِمْ يَوْمَ القِيامَةِ﴾</q>، قال: ليس أحدٌ إلا قد أعدَّ اللهُ تعالى له أهلًا في الجنة إن أطاعه{4}. (١٢/٦٤١) ٦٧٢٤٢- عن مجاهد بن جبر -من طريق ابن أبي نجِيح-، مثله{4}. (١٢/٦٤١) ٦٧٢٤٣- قال مقاتل بن سليمان: <q>﴿فاعْبُدُوا﴾</q> أنتم <q>﴿ما شئتم من دونه﴾</q> مِن الآلهة، ... <q>﴿قُلْ﴾</q> يا محمد: <q>﴿إنَّ الخاسِرِينَ الَّذِينَ خَسِرُوا أنْفُسَهُمْ﴾</q> يعني: غبنوا <q>﴿أنْفُسَهُمْ﴾</q> فصاروا إلى النار <q>﴿وأَهْلِيهِمْ﴾</q> يعني: وخسروا أهليهم من الأزواج والخدم <q>﴿يَوْمَ القِيامَةِ ألا ذَلِكَ﴾</q> يعني: هذا <q>﴿هُوَ الخُسْرانُ المُبِينُ﴾</q> يعني: البيِّن، حين لم يوحِّدوا ربهم، يعني <q>﴿وأَهْلِيهِمْ﴾</q> في الدنيا{6}. (ز) ٦٧٢٤٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿قُلْ إنَّ الخاسِرِينَ الَّذِينَ خَسِرُوا أنْفُسَهُمْ وأَهْلِيهِمْ يَوْمَ القِيامَةِ﴾</q>، قال: هؤلاء أهل النار، خسروا أنفسهم في الدنيا، وخسروا الأهلين، فلم يجدوا في النار أهلًا، وقد كان لهم في الدنيا أهل{1}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/١٨١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير بنحوه ٢٠/١٨١-١٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/١٧١. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٧١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦٧٣.أخرجه ابن جرير ٢٠/١٨١.
39,16," <q>﴿لَهُم مِّن فَوۡقِهِمۡ ظُلَلࣱ مِّنَ ٱلنَّارِ وَمِن تَحۡتِهِمۡ ظُلَلࣱۚ ذَ ٰ⁠لِكَ یُخَوِّفُ ٱللَّهُ بِهِۦ عِبَادَهُۥۚ یَـٰعِبَادِ فَٱتَّقُونِ ۝١٦﴾</q> - تفسير ٦٧٢٤٥- عن سُوَيْد بن غَفَلة -من طريق خيثمة- قال: إذا أراد الله أن يَنسى أهلَ النار؛ جعل لكل إنسان منهم تابوتًا مِن نار على قدْره، ثم أقفل عليه بأقفال من نار، فلا يُعرَف منه عِرق إلا وفيه مِسْمار، ثم جعَل ذلك التابوت في تابوت آخر من نار، ثم يُقْفل بأقفال من نار، ثم يُضْرم بينهما نار، فلا يَرى أحدٌ منهم أنّ في النار أحدًا غيرَه، فذلك قوله: <q>﴿لَهُمْ مِن فَوْقِهِمْ ظُلَلٌ مِنَ النّارِ ومِن تَحْتِهِمْ ظُلَلٌ﴾</q>{1}. (١٢/٦٤١) ٦٧٢٤٦- عن مجاهد بن جبر، في قوله: <q>﴿لَهُمْ مِن فَوْقِهِمْ ظُلَلٌ﴾</q> قال: غواشٍ، <q>﴿ومِن تَحْتِهِمْ ظُلَلٌ﴾</q> قال: مهاد{2}. (١٢/٦٤١) ٦٧٢٤٧- قال مقاتل بن سليمان: ثم قال: <q>﴿لَهُمْ مِن فَوْقِهِمْ ظُلَلٌ﴾</q> من النار، يعني: أطباق من النار، فتلهب عليهم، <q>﴿ومِن تَحْتِهِمْ ظُلَلٌ﴾</q> يعني: مهادًا من نار، <q>﴿ذَلِكَ﴾</q> يقول: هذا الذي ذُكر من ظُلل النار <q>﴿يُخَوِّفُ اللَّهُ بِهِ عِبادَهُ﴾</q>، <q>﴿فاتَّقُونِ﴾</q> يعني: فوحِّدون{3}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤٢٣-٤٢٤ (٣٦٥٦٣)، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٣٤ (١٦١)-.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٧٣.
39,17," <q>﴿وَٱلَّذِینَ ٱجۡتَنَبُوا۟ ٱلطَّـٰغُوتَ أَن یَعۡبُدُوهَا وَأَنَابُوۤا۟ إِلَى ٱللَّهِ لَهُمُ ٱلۡبُشۡرَىٰۚ فَبَشِّرۡ عِبَادِ ۝١٧ ٱلَّذِینَ یَسۡتَمِعُونَ ٱلۡقَوۡلَ فَیَتَّبِعُونَ أَحۡسَنَهُۥۤۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَىٰهُمُ ٱللَّهُۖ وَأُو۟لَـٰۤىِٕكَ هُمۡ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝١٨﴾</q> - نزول الآيتين ٦٧٢٤٨- عن عبد الله بن عباس -من طريق عطاء-: أنّ أبا بكر الصِّدِّيق ﵁ آمن بالنبي ﷺ وصَدّقه، فجاء عثمان، وعبد الرحمن بن عوف، وطلحة، والزبير، وسعيد بن زيد، وسعد بن أبي وقاص فسألوه، فأخبرهم بإيمانه، فآمنوا، ونزلت فيهم: <q>﴿فَبَشِّرْ عِبادِ الَّذِينَ يَسْتَمِعُونَ القَوْلَ﴾</q> قال: يريد: مِن أبي بكر، <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>{1}. (ز) ٦٧٢٤٩- عن عبد الله بن عمر، قال: كان سعيدُ بن زيد، وأبو ذر، وسلمان يتَّبعون في الجاهلية أحسنَ القول والكلام؛ لا إله إلا الله، قالوا بها، فأنزل الله تعالى على نبيّه ﷺ: <q>﴿يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> الآية{2}. (١٢/٦٤٢) ٦٧٢٥٠- عن أبي سعيد، قال: لما نزلت: <q>﴿فَبَشِّرْ عِبادِ الَّذِينَ يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> أرسل رسولُ الله ﷺ مناديًا، فنادى: «من مات لا يشرك بالله شيئًا دخل الجنة». فاستقبل عمرُ الرسولَ، فردّه، فقال: يا رسول الله، خشيتُ أن يَتَّكِل الناسُ فلا يعملون. فقال رسول الله ﷺ: «لو يعلمُ الناسُ قَدْر رحمةِ الله لاتّكلوا، ولو يعلمون قدْر سخط الله وعقابه لاستصغروا أعمالهم»{3}. (١٢/٦٤٣) ٦٧٢٥١- عن جابر بن عبد الله، قال: لما نزلت: <q>﴿لَها سَبْعَةُ أبْوابٍ﴾</q> [الحجر:٤٤] أتى رجلٌ مِن الأنصار إلى النبي ﷺ، فقال: يا رسول الله، إنّ لي سبعة مماليك، وإنِّي أعتقتُ لكلِّ باب منها مملوكًا. فنزلت هذه الآية: <q>﴿فَبَشِّرْ عِبادِ الَّذِينَ يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>{4}. (١٢/٦٤٣) ٦٧٢٥٢- عن زيد بن أسلم -من طريق ابنه عبد الرحمن- في قوله: <q>﴿والَّذِينَ اجْتَنَبُوا الطّاغُوتَ أنْ يَعْبُدُوها﴾</q>، قال: نزلت هاتان الآيتان في ثلاثة نفر كانوا في الجاهلية يقولون: لا إله إلا الله. في زيد بن عمرو بن نفيل، وأبي ذر الغفاري، وسلمان الفارسي{5}٥٦١٧. (١٢/٦٤٢) ٥٦١٧ ذكر ابنُ عطية (٧/٣٨٣) قول زيد، ونقل عن ابن إسحاق: أن «الإشارة بها إلى عبد الرحمن بن عوف، وسعد بن أبي وقاص، وسعيد بن زيد، والزبير، وذلك أنه لما أسلم أبو بكر سمعوا ذلك، فجاؤوه، فقالوا: أسلمتَ؟ قال: نعم. وذكَّرهم بالله تعالى، فآمنوا بأجمعهم، فنزلت فيهم هذه الآية». ثم علَّق بقوله: «وهي على كل حالٍ عامَّة في الناس إلى يوم القيامة، يتناولهم حكمها». وذكر ابنُ كثير (١٢/١١٨-١١٩) قول زيد، ثم رجَّح العموم قائلًا: «والصحيح أنها شاملةٌ لهم ولغيرهم، ممن اجتنب عبادة الأوثان، وأناب إلى عبادة الرحمن، فهؤلاء هم الذين لهم البشرى في الحياة الدنيا وفي الآخرة». <q>﴿وَٱلَّذِینَ ٱجۡتَنَبُوا۟ ٱلطَّـٰغُوتَ أَن یَعۡبُدُوهَا﴾</q> - تفسير ٦٧٢٥٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والَّذِينَ اجْتَنَبُوا الطّاغُوتَ﴾</q>، قال: الشيطان{6}. (١٢/٦٤٢) ٦٧٢٥٤- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿والَّذِينَ اجْتَنَبُوا الطّاغُوتَ أنْ يَعْبُدُوها﴾</q>، قال: الشيطان{7}. (ز) ٦٧٢٥٥- قال مقاتل بن سليمان: <q>﴿والَّذِينَ اجْتَنَبُوا الطّاغُوتَ﴾</q>، يعني: الأوثان، وهي مؤنّثة{8}. (ز) ٦٧٢٥٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿الطّاغُوتَ﴾</q> الشيطان، هو هاهنا واحد، وهي جماعة، مثل قوله: <q>﴿يا أيُّها الإنْسانُ ما غَرَّكَ﴾</q> [الانفطار:٦]، قال: هي للناس كلهم، <q>﴿الَّذِينَ قالَ لَهُمُ النّاسُ﴾</q> [آل عمران:١٧٣] إنما هو واحد{9}. (١٢/٦٤٢) ٦٧٢٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: <q>﴿والَّذِينَ اجْتَنَبُوا الطّاغُوتَ أنْ يَعْبُدُوها﴾</q> في جاهليتهم{10}. (ز) <q>﴿وَأَنَابُوۤا۟ إِلَى ٱللَّهِ لَهُمُ ٱلۡبُشۡرَىٰۚ فَبَشِّرۡ عِبَادِ ۝١٧﴾</q> - تفسير ٦٧٢٥٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَنابُوا إلى اللَّهِ لَهُمُ البُشْرى﴾</q>، قال: أقبلوا إلى الله{11}. (١٢/٦٤٢) ٦٧٢٥٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وأَنابُوا إلى اللَّهِ﴾</q>، قال: أجابوا إليه{12}. (ز) ٦٧٢٦٠- قال مقاتل بن سليمان: <q>﴿وأَنابُوا إلى اللَّهِ﴾</q> يعني: ورجعوا مِن عبادة الأوثان إلى عبادة الله ﷿، فقال تعالى: <q>﴿لَهُمُ البُشْرى﴾</q> يعني: الجنة؛ <q>﴿فَبَشِّرْ عِبادِ﴾</q> فبشِّر عبادي بالجنة{8}. (ز) <q>﴿ٱلَّذِینَ یَسۡتَمِعُونَ ٱلۡقَوۡلَ فَیَتَّبِعُونَ أَحۡسَنَهُۥۤۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَىٰهُمُ ٱللَّهُۖ وَأُو۟لَـٰۤىِٕكَ هُمۡ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝١٨﴾</q> - تفسير ٦٧٢٦١- عن عبد الله بن عباس -من طريق عطاء- <q>﴿الَّذِينَ يَسْتَمِعُونَ القَوْلَ﴾</q> قال: يريد مِن أبي بكر، <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>{14}. (ز) ٦٧٢٦٢- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>، قال: ما أمر الله تعالى النبيّين من الطاعة{15}. (١٢/٦٤٢) ٦٧٢٦٣- قال قتادة بن دعامة -من طريق سعيد- <q>﴿أحْسَنَهُ﴾</q>: طاعة الله{16}. (١٢/٦٤٢) ٦٧٢٦٤- قال إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>: أحسن ما يؤمرون، فيعملون به{10}٥٦١٨. (ز) ٥٦١٨ لم يذكر ابنُ جرير (٢٠/١٨٤-١٨٥) في معنى: <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> سوى قول قتادة، والسُّدِّيّ. ٦٧٢٦٥- عن محمد بن السّائِب الكلبي، في قوله: <q>﴿الَّذِينَ يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>، قال: هو الرجل الذي يقعد إلى المحدِّث، فيقوم بأحسن ما سمع{18}. (١٢/٦٤٣) ٦٧٢٦٦- قال مقاتل بن سليمان: ثم نعتهم، فقال: <q>﴿الَّذِينَ يَسْتَمِعُونَ القَوْلَ﴾</q> يعني: القرآن، <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> يعني: أحسن ما في القرآن مِن طاعة الله ﷿، ولا يتّبعون المعاصي. مثل قوله: <q>﴿واتَّبِعُوا أحْسَنَ ما أُنْزِلَ إلَيْكُمْ مِن رَبِّكُمْ﴾</q> [الزمر:٥٥]، أي: مِن طاعته. <q>﴿أُولَئِكَ الَّذِينَ هَداهُمُ اللَّهُ﴾</q> لدينه، <q>﴿وأُولَئِكَ هُمْ أُولُو الأَلْبابِ﴾</q> يعني: أهل اللُّبّ والعقل حين يستمعون، <q>﴿فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> من أمره ونهيه، يعني: أحسن ما فيه مِن أمره ونهيه، ولا يتَّبعون السوء الذي ذكره عن غيرهم{8}٥٦١٩. (ز) ٥٦١٩ اختُلف في معنى: <q>﴿الَّذِينَ يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> على أقوال: الأول: أنه لا إله إلا الله. الثاني: أنه الرجل يجلس مع القوم فيسمع كلامهم، فيعمل بالمحاسن ويحدِّث بها، ويَكُف عن المساوئ ولا يُظهرها. الثالث: أنه طاعة الله. وذكر ابنُ عطية (٧/٣٨٤) قولين آخرين: أنّ أحسن القول كتاب الله تعالى، ثم وجَّهه بقوله: «أي: إذا سمعوا الأقاويل وسمعوا القرآن اتبعوا القرآن». وذكر أيضًا أنّ أحسنه: ما فيه مِن عفو وصفح واحتمال على صبر ونحو ذلك. وذكر (٧/٣٨٣) أن قوله تعالى: <q>﴿الَّذِينَ يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q>: «كلام عامٌّ في جميع الأقوال، وإنما القصد الثناء على هؤلاء في نفوذ بصائرهم، وقوام نَظَرِهِم، حتى أنهم إذا سمعوا قولًا ميَّزوه واتبعوا أحسنه». ثم وجَّه الأقوال الثلاثة الأخيرة بكونها أمثلةً داخلة في المعنى العام الذي ذكره. ٦٧٢٦٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: <q>﴿وأَنابُوا إلى اللَّهِ لَهُمُ البُشْرى فَبَشِّرْ عِبادِ الَّذِينَ يَسْتَمِعُونَ القَوْلَ فَيَتَّبِعُونَ أحْسَنَهُ﴾</q> لا إله إلا الله، <q>﴿أُولَئِكَ الَّذِينَ هَداهُمُ اللَّهُ﴾</q> بغير كتاب ولا نبي، <q>﴿وأُولَئِكَ هُمْ أُولُو الأَلْبابِ﴾</q>{20}. (ز) <q>﴿ٱلَّذِینَ یَسۡتَمِعُونَ ٱلۡقَوۡلَ فَیَتَّبِعُونَ أَحۡسَنَهُۥۤۚ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ هَدَىٰهُمُ ٱللَّهُۖ وَأُو۟لَـٰۤىِٕكَ هُمۡ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝١٨﴾</q> - آثار متعلقة بالآية ٦٧٢٦٨- عن عمر بن الخطاب، قال: لولا ثلاثٌ لَسَرَّني أن أكون قَدْ مِتُّ: لولا أن أضع جبيني لله، وأُجالِسُ قومًا يلتقطون طيّب الكلام كما يلتقطون طيّب الثمر، والسّيْر في سبيل الله{18}. (١٢/٦٤٣) ٦٧٢٦٩- عن أبي الدرداء: لولا ثلاث ما أحببت أن أعيش يومًا واحدًا: الظَّمَأ بالهواجر، والسجود في جوف الليل، ومجالسة أقوام ينتقون مِن خير الكلام كما يُنتقى طيِّب التمر{22}. (ز) ",footnotes:1:أورده الواحدي في أسباب النزول ص٣٦٩، والبغوي ٧/١١٣.عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ١٨/٢٧٤ (١١٧٥١) مختصرًا دون ذكر الآية. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى جويبر.أخرجه ابن جرير ٢٠/١٨٥ بنحوه. وعزاه السيوطي إلى ابن أبى حاتم.تفسير مجاهد ص٥٧٨، وأخرجه ابن جرير ٢٠/١٨٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٨٣.تفسير مقاتل بن سليمان ٣/٦٧٣.أخرجه ابن جرير ٢٠/١٨٣ مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/١٨٥.أخرجه ابن جرير ٢٠/١٨٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٨٤.تفسير مقاتل بن سليمان ٣/٦٧٣.أورده الواحدي في أسباب النزول ص٣٦٩، والبغوي ٧/١١٣. وتقدم في نزول الآية: أن أبا بكر الصديق ﵁ آمَن بالنبي ﷺ وصدّقه، فجاء عثمان، وعبد الرحمن بن عوف، وطلحة، والزبير، وسعيد بن زيد، وسعد بن أبي وقاص فسألوه، فأخبرهم بإيمانه فآمنوا، ونزلت فيهم: <q>﴿فَبَشِّرْ عِبادِ الَّذِينَ يَسْتَمِعُونَ القَوْلَ﴾</q>.علّقه الحكيم الترمذي في نوادر الأصول ٢/٩٩.أخرجه ابن جرير ٢٠/١٨٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/١٨٥.عزاه السيوطي إلى سعيد بن منصور.تفسير مقاتل بن سليمان ٣/٦٧٣.أخرجه ابن جرير ٢٠/١٨٥. وتقدم في نزول الآية عن زيد بن أسلم: أن هاتين الآيتين نزلت في زيد بن عمرو بن نفيل، وأبي ذر الغفاري، وسلمان الفارسي كانوا في الجاهلية يقولون: لا إله إلا الله.عزاه السيوطي إلى سعيد بن منصور.أخرجه الثعلبي ٨/٢٢٧.
  39,18,""
39,19," <q>﴿أَفَمَنۡ حَقَّ عَلَیۡهِ كَلِمَةُ ٱلۡعَذَابِ أَفَأَنتَ تُنقِذُ مَن فِی ٱلنَّارِ ۝١٩﴾</q> - تفسير ٦٧٢٧٠- قال عبد الله بن عباس: <q>﴿أفَمَن حَقَّ عَلَيْهِ كَلِمَةُ العَذابِ﴾</q> مَن سَبق في علم الله أنه من أهل النار، <q>﴿أفَأَنْتَ تُنْقِذُ مَن فِي النّارِ﴾</q> يريد: أبا لهب، وولده{1}. (ز) ٦٧٢٧١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أفَمَن حَقَّ عَلَيْهِ كَلِمَةُ العَذابِ﴾</q>، قال: بكفره، وعمله{2}. (١٢/٦٤٤) ٦٧٢٧٢- قال مقاتل بن سليمان: <q>﴿أفَمَن حَقَّ عَلَيْهِ﴾</q> يعني: وجب عليه كلمة العذاب، يعني: يوم قال لإبليس: <q>﴿لَأَمْلَأَنَّ جَهَنَّمَ مِنَ الجِنَّةِ والنّاسِ أجْمَعِينَ﴾</q> [هود:١١٩، السجدة:١٣]{3}. (ز) ",footnotes:1:تفسير البغوي ٧/١١٣.أخرجه ابن جرير ٢٠/١٨٦ بلفظ: بكفره. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦٧٤.
39,20," <q>﴿لَـٰكِنِ ٱلَّذِینَ ٱتَّقَوۡا۟ رَبَّهُمۡ لَهُمۡ غُرَفࣱ مِّن فَوۡقِهَا غُرَفࣱ مَّبۡنِیَّةࣱ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ وَعۡدَ ٱللَّهِ لَا یُخۡلِفُ ٱللَّهُ ٱلۡمِیعَادَ ۝٢٠﴾</q> - تفسير ٦٧٢٧٣- قال عبد الله بن عباس: <q>﴿لَكِنِ الَّذِينَ اتَّقَوْا رَبَّهُمْ لَهُمْ غُرَفٌ مِن فَوْقِها غُرَفٌ مَبْنِيَّةٌ﴾</q> مِن زَبَرْجد وياقوت{1}. (ز) ٦٧٢٧٤- عن مجاهد بن جبر، في قوله: <q>﴿لَهُمْ غُرَفٌ مِن فَوْقِها غُرَفٌ﴾</q>، قال: علالي{2}. (١٢/٦٤٤) ٦٧٢٧٥- قال مقاتل بن سليمان: <q>﴿لَكِنِ الَّذِينَ اتَّقَوْا رَبَّهُمْ﴾</q> وحَّدوا ربهم <q>﴿لَهُمْ غُرَفٌ مِن فَوْقِها غُرَفٌ﴾</q>، ثم نَعتَ الغُرَف فقال: هي <q>﴿مَبْنِيَّةٌ﴾</q> فيها تقديم، <q>﴿تَجْرِي مِن تَحْتِها الأَنْهارُ﴾</q> تجري العيون مِن تحت الغُرف، يعني: أسفل منها الأنهار، <q>﴿وعْدَ اللَّهِ﴾</q> هذا الخير، <q>﴿لا يُخْلِفُ اللَّهُ المِيعادَ﴾</q> ما وعدهم{3}. (ز) <q>﴿لَـٰكِنِ ٱلَّذِینَ ٱتَّقَوۡا۟ رَبَّهُمۡ لَهُمۡ غُرَفࣱ مِّن فَوۡقِهَا غُرَفࣱ مَّبۡنِیَّةࣱ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۖ وَعۡدَ ٱللَّهِ لَا یُخۡلِفُ ٱللَّهُ ٱلۡمِیعَادَ ۝٢٠﴾</q> - آثار متعلقة بالآية ٦٧٢٧٦- عن أبي سعيد الخدري، عن النبي ﷺ، قال: «إنّ أهل الجنة يتراءَون أهل الغُرف مِن فوقهم، كما يتراءَون الكوكبَ الدُّرِّي الغابِر في الأفق من المشرق أو المغرب، لِتفاضل ما بينهم». قالوا: يا رسول الله، تلك منازل الأنبياء لا يبلغها غيرهم؟ قال: «بلى، والذي نفسي بيده، رجالٌ آمنوا بالله وصدّقوا المرسلين»{4}. (ز) ",footnotes:1:تفسير الثعلبي ٨/٢٢٨.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٦٧٤.أخرجه البخاري ٤/١١٩ (٣٢٥٦)، ومسلم ٤/٢١٧٧ (٢٨٣١)، والثعلبي ٨/٢٢٨.
39,21," <q>﴿أَلَمۡ تَرَ أَنَّ ٱللَّهَ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَسَلَكَهُۥ یَنَـٰبِیعَ فِی ٱلۡأَرۡضِ﴾</q> - تفسير ٦٧٢٧٧- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿ألَمْ تَرَ أنَّ اللَّهَ أنْزَلَ مِنَ السَّماءِ ماءً فَسَلَكَهُ يَنابِيعَ فِي الأَرْضِ﴾</q>، قال: ما في الأرض ماءٌ إلا نزل مِن السماء، ولكن عروق في الأرض تغيِّره، فذلك قوله: <q>﴿فَسَلَكَهُ يَنابِيعَ فِي الأَرْضِ﴾</q>، فمَن سرّه أن يعود المِلح عذبًا فلْيُصَعِّده{1}. (١٢/٦٤٤) ٦٧٢٧٨- قال الضَّحّاك بن مُزاحِم: كل ماء في الأرض فمن السماء نزل، إنما ينزل من السماء إلى الصخرة، ثم يُقسم منها العيون والرَّكايا{2}. (ز) ٦٧٢٧٩- عن عامر الشعبي -من طريق جابر- في قوله: <q>﴿فَسَلَكَهُ يَنابِيعَ فِي الأَرْضِ﴾</q>، قال: كل ماء في الأرض أصله من السماء{3}. (١٢/٦٤٤) ٦٧٢٨٠- عن الحسن بن مسلم بن يَنّاق -من طريق جابر- قال: ثم يُنبت بذلك الماء الذي أنزله من السماء، فجعله في الأرض عيونًا <q>﴿زَرْعًا مُخْتَلِفًا ألْوانُهُ﴾</q>{4}٥٦٢٠. (ز) ٥٦٢٠ ذكر ابنُ عطية (٧/٣٨٥) في تفسير الآية معنى قول الشعبي: «أن كل ماءٍ عذب في الأرض فمن السماء نزل». ومعنى قول الحسن بن يَنّاق: «أن الإشارة إلى العيون، وليست العيون من المطر، ولكن ماؤها نازل من السماء». ثم علَّق عليهما بقوله: «والقولان متقاربان». ٦٧٢٨١- عن محمد بن السّائِب الكلبي، قال: العيون والرَّكايا مما أنزل الله من السماء، <q>﴿فَسَلَكَهُ يَنابِيعَ فِي الأَرْضِ﴾</q>{5}. (١٢/٦٤٥) ٦٧٢٨٢- قال مقاتل بن سليمان: <q>﴿ألَمْ تَرَ أنَّ اللَّهَ أنْزَلَ مِنَ السَّماءِ ماءً فَسَلَكَهُ يَنابِيعَ فِي الأَرْض﴾</q>، يعني: فجعله عيونًا ورَكايا في الأرض{6}. (ز) ٦٧٢٨٣- عن عبد الملك ابن جريج، في قوله: <q>﴿فَسَلَكَهُ يَنابِيعَ فِي الأَرْضِ﴾</q>، قال: عيونًا{7}. (١٢/٦٤٤) <q>﴿ثُمَّ یُخۡرِجُ بِهِۦ زَرۡعࣰا مُّخۡتَلِفًا أَلۡوَ ٰ⁠نُهُۥ ثُمَّ یَهِیجُ فَتَرَىٰهُ مُصۡفَرࣰّا ثُمَّ یَجۡعَلُهُۥ حُطَـٰمًاۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَذِكۡرَىٰ لِأُو۟لِی ٱلۡأَلۡبَـٰبِ ۝٢١﴾</q> - تفسير ٦٧٢٨٤- عن الحسن بن مسلم بن يَنّاق -من طريق جابر- قال: ثم يُنبت بذلك الماء الذي أنزله من السماء، فجعله في الأرض عيونًا <q>﴿زَرْعًا مُخْتَلِفًا ألْوانُهُ﴾</q> يعني: أنواعًا مختلفة؛ من بين حِنطة، وشعير، وسمسم، وأرز، ونحو ذلك من الأنواع المختلفة، <q>﴿ثُمَّ يَهِيجُ فَتَراهُ مُصْفَرًّا﴾</q> يقول: ثم ييبس ذلك الزرع مِن بعد خضرته، يقال للأرض إذا يبس ما فيها من الخَضِرِ وذَوى{8}: هاجت الأرض، وهاج الزرع{4}. (ز) ٦٧٢٨٥- قال مقاتل بن سليمان: <q>﴿ثُمَّ يُخْرِجُ بِهِ﴾</q> بالماء <q>﴿زَرْعًا مُخْتَلِفًا ألْوانُهُ ثُمَّ يَهِيجُ﴾</q> يعني: ييبس، <q>﴿فتراه﴾</q> بعد الخضرة مُصفرًّا، <q>﴿ثُمَّ يَجْعَلُهُ حُطامًا﴾</q> يعني: هالكًا. نظيرها: <q>﴿لا يَحْطِمَنَّكُمْ سُلَيْمانُ وجُنُودُهُ﴾</q> [النمل:١٨]، لا يهلكنكم سليمان. هذا مَثل ضربه الله في الدنيا كمثل النبْت، بينما هو أخضر إذ تغيّر فيبس، ثم هلك، فكذلك تهلك الدنيا بعد بَهْجتها وزينتها، <q>﴿إنَّ فِي ذَلِكَ لَذِكْرى﴾</q> يعني: تفكُّر <q>﴿لِأُولِي الأَلْبابِ﴾</q>{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٨٣-.تفسير الثعلبي ٨/٢٢٩. والرَّكايا: جمع ركِيَّة، وهي البئر. النهاية (ركا).أخرجه ابن جرير ٢٠/١٨٨ بنحوه، وأبو الشيخ في العظمة (٧٣٨). وعزاه السيوطي إلى الخرائطي في مكارم الأخلاق.أخرجه ابن جرير ٢٠/١٨٨.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٦٧٤.عزاه السيوطي إلى ابن المنذر.ذوى: ذَبَل وضَعُف. لسان العرب (ذوي).أخرجه ابن جرير ٢٠/١٨٨.تفسير مقاتل بن سليمان ٣/٦٧٤.
