quran[8]{c,v,t}:
  4,106,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱسۡتَغۡفِرِ ٱللَّهَۖ إِنَّ ٱللَّهَ كَانَ غَفُورࣰا رَّحِیمࣰا ۝١٠٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٠٨٦<span class="dash">-</span></span> عن <span class="name-1">قتادة بن النعمان</span> -من طريق عمر بن قتادة- <span class="qpc-hafs">﴿واستغفر الله﴾</span> أي: مما قلت لقتادة، <span class="qpc-hafs">﴿إن الله كان غفورا رحيما﴾</span>{1}. (٤/٦٧٧-٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿واستغفر الله﴾</span> مما كنت هممت به أن تعذره{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٨٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: واستغفر الله يا محمد مِن هَمِّك باليهوديِّ أن تضربه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿واستغفر الله﴾</span> يا محمد عن جدالك عن طعمة حين كذبت عنه، فأبرأته من السرقة، <span class="qpc-hafs">﴿إن الله كان غفورا رحيما﴾</span>. فاستغفر النبي ﷺ عند ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿واستغفر الله﴾</span> بما قلت لهذا اليهوديِّ، <span class="qpc-hafs">﴿إن الله كان غفورا رحيما﴾</span>{5}<span class=comment-ref>١٨٣٦</span>. (٤/٦٨٤)</p></p><p></div></p><p><div><span class=comment-ref>١٨٣٦</span> ذهب <u>ابنُ جرير</u> (٧/٤٧٥) إلى أنّ معنى قوله: <span class="qpc-hafs">﴿واستغفر الله﴾</span>: استغفر الله من ذنبك في خصامك للخائنين.</p><p>و<span class="comment-type-4">علَّق</span> عليه <u>ابنُ عطية</u> (٣/١٨)، بقوله: «وهذا ليس بذنب؛ لأن النبي ﷺ إنما دافع عن الظاهر، وهو يعتقد براءتهم، والمعنى: استغفر للمذنبين من أمتك والمتخاصمين في الباطل، لا أن تكون ذا جدال عنهم، فهذا حدُّك، ومحلك من الناس أن تسمع من المتداعيين، وتقضي بنحو ما تسمع، وتستغفر للمذنب».</div></p></div>",footnotes:1:أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٠٣-.تفسير الثعلبي ٣/٣٨١.تفسير مقاتل بن سليمان ١/٤٠٥.أخرجه ابن جرير ٧/٤٦٤-٤٦٥.
  4,107,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تُجَـٰدِلۡ عَنِ ٱلَّذِینَ یَخۡتَانُونَ أَنفُسَهُمۡۚ إِنَّ ٱللَّهَ لَا یُحِبُّ مَن كَانَ خَوَّانًا أَثِیمࣰا ۝١٠٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٠٩١<span class="dash">-</span></span> عن <span class="name-1">محمود بن لبيد</span>، قوله: <span class="qpc-hafs">﴿ولا تجادل عن الذين يختانون أنفسهم﴾</span> يعني: أسير بن عروة وأصحابه، <span class="qpc-hafs">﴿إن الله لا يحب من كان خوانا أثيما﴾</span>{1}. (٤/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿ولا تجادل عن الذين يختانون أنفسهم﴾</span>، يعني: طعمة بن أبيرق وقومه{2}. (٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تجادل عن الذين يختانون أنفسهم﴾</span> يعني: طعمة، <span class="qpc-hafs">﴿إن الله لا يحب من كان خوانا﴾</span> في دينه، <span class="qpc-hafs">﴿أثيمًا﴾</span> بربه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن سعد من وجه آخر.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤٠٥.
  4,108,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَسۡتَخۡفُونَ مِنَ ٱلنَّاسِ وَلَا یَسۡتَخۡفُونَ مِنَ ٱللَّهِ وَهُوَ مَعَهُمۡ إِذۡ یُبَیِّتُونَ مَا لَا یَرۡضَىٰ مِنَ ٱلۡقَوۡلِۚ وَكَانَ ٱللَّهُ بِمَا یَعۡمَلُونَ مُحِیطًا ۝١٠٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٠٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص موقوفًا ومرفوعًا- قال: «<b>مَن صلّى صلاة عند الناس لا يُصَلِّي مثلها إذا خلا؛ فهي استهانةٌ، استهان بها ربه</b>». ثم تلا هذه الآية: <span class="qpc-hafs">﴿يستخفون من الناس ولا يستخفون من الله وهو معهم﴾</span>{1}. (٤/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٥<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span>، مثله. وزاد: وألا يستحيي أن يكون الناسُ أعظمَ عنده من الله؟!{2}. (٤/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: ثم قال للذين أتوا رسول الله ﷺ لَيْلًا: <span class="qpc-hafs">﴿يستخفون من الناس﴾</span> إلى قوله: <span class="qpc-hafs">﴿وكيلا﴾</span>، يعني: الذين أتوا رسول الله ﷺ مستخفين يجادلون عن الخائنين{3}. (٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي عن أبي صالح- <span class="qpc-hafs">﴿إذ يبيتون﴾</span>، يعني: يقولون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [الأسدي]</span>-من طريق الأعمش- <span class="qpc-hafs">﴿إذ يبيتون﴾</span>، قال: إذ يُؤَلِّفون ما لا يرضى من القول{5}<span class=comment-ref>١٨٣٧</span>. (٤/٦٩٠)</p></p><p></div></p><p><div><span class=comment-ref>١٨٣٧</span> ذكر <u>ابنُ جرير</u> (٧/٤٧٢-٤٧٣) أنّ التبْييت لغة: كل كلام أو أمر أُصلح ليلًا. ثم ذكر عن بعض الطائيين: أن التبييت في لغتهم: التبديل، وأنشد للأسود بن عامر بن جوين الطائي:</p><p>وبيَّتَّ قولي عند المليك قاتلَك الله عبدًا كنودا</p><p>وساق قولَ أبي رزين، و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا القول شبيه المعنى بالذي قلناه، وذلك أنّ التأليف هو: التسوية والتغيير عما هو به، وتحويله عن معناه إلى غيره».</p><p>وذكر <u>ابنُ عطية</u> (٣/١٩) احتمالًا آخر، فقال: «ويحتمل أن تكون اللفظة مأخوذة من البيت، أي: يَسْتَسِرُّون في تدبيرهم بالجدران».</div></p><p><div></p><p><p><span class="item-no">٢٠٠٩٩<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السُّدِّيّ</span>، مثل ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يستخفون﴾</span> يعني: يستترون بالخيانة <span class="qpc-hafs">﴿من الناس﴾</span> يعني: طعمة، <span class="qpc-hafs">﴿ولا يستخفون من الله﴾</span> ولا يستترون بالخيانة من الله، <span class="qpc-hafs">﴿وهو معهم إذ يبيتون﴾</span> يعني: إذ يُؤَلِّفون <span class="qpc-hafs">﴿ما لا يرضى من القول﴾</span> لقولهم: إنّا نأتي النبي ﷺ فنقول له كذا وكذا. فألقوا قولهم بينهم، يعني: قتادة وأصحابه؛ ليدفعوا عن صاحبهم ما لا يرضى الله من القول، <span class="qpc-hafs">﴿وكان الله بما يعملون محيطا﴾</span> يعني: أحاط علمه بأعمالهم، يعني: قوم الخائن قتادة بن النعمان وأصحابه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَير بن معروف- في قوله: <span class="qpc-hafs">﴿بما يعملون محيطا﴾</span>، يقول: أحاط علمُه بأعمالهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٢<span class="dash">-</span></span> عن <span class="name-3">أبي سعيد الحداد أحمد بن داود</span> -من طريق عباد بن الوليد الغُبَرِيّ- يقول: <span class="qpc-hafs">﴿إذ يبيتون ما لا يرضى من القول وكان الله بما يعملون محيطا﴾</span>، قال: قد أحاط بكلِّ شيء علمًا، ولم يقل مع كل شيء{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٦٩ (٣٧٣٨)، وأبو يعلى في مسنده ٩/٥٤ (٥١١٧) مرفوعًا دون ذكر الآية، وابن أبي حاتم ٤/١٠٦١ (٥٩٣٩) من طريق أبي إسحاق الهجري، عن أبي الأحوص، عن عبد الله به مرفوعًا.</p><p>وأخرجه ابن أبي حاتم ٤/١٠٦١ (٥٩٣٨) واللفظ له، من طريق أبي إسحاق السبيعي، عن أبي الأحوص، عن عبد الله به موقوفًا عليه.</p><p>قال البوصيري في إتحاف الخيرة ١/٢٥٨ (٣٩٥): «حديث حسن». وقال ابن حجر في المطالب العالية ١٣/٤٢٧ (٣٢١٣): «حديث حسن». وقال الهيثمي في المجمع ١٠/٢٢١: «فيه إبراهيم بن مسلم الهجري، وهو ضعيف». وقال المنذري في الترغيب والترهيب ١/٣٣ (٤٥) عن الموقوف: «هو أشبه». وقال الألباني في الضعيفة ١٠/٣٩ (٤٥٣٧): «ضعيف».عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٧/٤٦٣-٤٦٤، وابن أبي حاتم ٤/١٠٥٩-١٠٦٣.تفسير الثعلبي ٣/٣٨٢.أخرجه ابن جرير ٧/٤٧٢-٤٧٣، وابن أبي حاتم ٤/١٠٦١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٤/١٠٦١.تفسير مقاتل بن سليمان ١/٤٠٥.أخرجه ابن أبي حاتم ٤/١٠٦١.أخرجه ابن أبي حاتم ٤/١٠٦٢.
  4,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰۤأَنتُمۡ هَـٰۤؤُلَاۤءِ جَـٰدَلۡتُمۡ عَنۡهُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا فَمَن یُجَـٰدِلُ ٱللَّهَ عَنۡهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ أَم مَّن یَكُونُ عَلَیۡهِمۡ وَكِیلࣰا ۝١٠٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿ها أنتم هؤلاء جادلتم عنهم في الحياة الدنيا فمن يجادل الله عنهم يوم القيامة﴾</span>، يعني: الذين أتوا رسول الله ﷺ مستخفين يجادلون عن الخائن{1}. (٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿ها أنتم هؤلاء جادلتم﴾</span> إلى قوله: <span class="qpc-hafs">﴿يكون عليهم وكيلا﴾</span>، قال: محمد ﷺ، وقوم طعمة{2}. (٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال يعنيهم: <span class="qpc-hafs">﴿ها أنتم هؤلاء﴾</span> قوم الخائن <span class="qpc-hafs">﴿جادلتم عنهم﴾</span> نبيكم <span class="qpc-hafs">﴿في الحياة الدنيا﴾</span> عن طعمة، <span class="qpc-hafs">﴿فمن يجادل الله عنهم يوم القيامة أم من يكون عليهم وكيلا﴾</span> يعني به: قومه. يقول: أم من يكون لطعمة مانعًا في الآخرة{3}<span class=comment-ref>١٨٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٣٨</span> ذكر <u>ابنُ عطية</u> (٣/١٩) أنّ الخطاب بهذه الآية للقوم الذين يتعصبون لأهل الرِيَب والمعاصي، وأنه يشمل بعمومه أهل النازلة.</p><p>ثم <span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى ظاهر لفظ الآية</span> كونه لأهل التعصب في الواقعة، فقال: «وهو الأظهر عندي؛ بحكم التأكيد بـ<span class="qpc-hafs">﴿هؤُلاءِ﴾</span>، وهي إشارة إلى حاضرين».</div></p></div>",footnotes:1:أخرجه ابن جرير ٧/٤٦٣-٤٦٤، وابن أبي حاتم ٤/١٠٦٢.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤٠٥.
  4,110,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن یَعۡمَلۡ سُوۤءًا أَوۡ یَظۡلِمۡ نَفۡسَهُۥ ثُمَّ یَسۡتَغۡفِرِ ٱللَّهَ یَجِدِ ٱللَّهَ غَفُورࣰا رَّحِیمࣰا ۝١١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١٠٦<span class="dash">-</span></span> عن علي بن أبي طالب، قال: سمعت أبا بكر يقول: سمعت رسول الله ﷺ يقول: «<b>ما من عبد أذْنَب، فقام فتوضأ، فأحسن وضوءه، ثم قام فصلّى، واستغفر من ذنبه؛ إلا كان حقًّا على الله أن يغفر له؛ لأنه يقول: <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span></b>»{1}. (٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٧<span class="dash">-</span></span> عن علي بن أبي طالب، قال: كنتُ إذا سمعتُ من رسول الله ﷺ شيئًا نفعني الله بما شاء أن ينفعني منه، وحدثني أبو بكر، وصدق أبو بكر، قال: قال رسول الله ﷺ: «<b>ما مِن مسلم يُذنِب ذَنبًا، ثم يتوضأ فيصلي ركعتين، ثم يستغفر الله لذلك الذنب؛ إلّا غَفَرَ له</b>». وقرأ هاتين الآيتين: <span class="qpc-hafs">﴿ومَن يَعْمَلْ سُوءًا أوْ يَظْلِمْ نَفْسَهُ ثُمَّ يَسْتَغْفِرْ اللَّهَ يَجِدْ اللَّهَ غَفُورًا رَحِيمًا﴾</span>، <span class="qpc-hafs">﴿والَّذِينَ إذا فَعَلُوا فاحِشَةً أوْ ظَلَمُوا أنْفُسَهُمْ﴾</span> [آل عمران:١٣٥]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٨<span class="dash">-</span></span> عن أبي الدرداء، قال: كان رسول الله ﷺ إذا جلس وجلسنا حوله، وكانت له حاجة فقام إليها وأراد الرجوع؛ ترك نعليه في مجلسه، أو بعض ما يكون عليه، وأنه قام فترك نعليه، فأخذت رَكْوَةً من ماء، فاتبعته، فمضى ساعة، ثم رجع ولم يقض حاجته، فقال: «<b>إنه أتاني آتٍ من ربي، فقال: إنه <span class="qpc-hafs">﴿من يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>. فأردت أن أُبَشِّر أصحابي</b>». قال أبو الدرداء: وكانَتْ قد شَقَّت على الناس التي قبلها: <span class="qpc-hafs">﴿من يعمل سوءا يجز به﴾</span>. فقلت: يا رسول الله، وإن زنى وإن سرق، ثم استغفر ربه، غفر الله له؟ قال: «<b>نعم</b>». قلت الثانية، قال: «<b>نعم</b>». قلت الثالثة، قال: «<b>نعم</b>، <b>على رغم أنف عويمر</b>»{3}. (٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠٩<span class="dash">-</span></span> عن <span class="name-1">قتادة بن النعمان</span> -من طريق عمر بن قتادة- <span class="qpc-hafs">﴿ولا تجادل عن الذين يختانون أنفسهم﴾</span> إلى قوله: <span class="qpc-hafs">﴿ثم يستغفر الله يجد الله غفورا رحيما﴾</span>، أي: أنهم لو استغفروا الله لغفر لهم{4}. (٤/٦٧٧-٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>، قال: أخبر الله عباده بحِلمه وعفوه وكرمه وسعة رحمته ومغفرته، فمن أذنب ذنبًا صغيرًا كان أو كبيرًا، ثم استغفر الله؛ يجد الله غفورًا رحيمًا، ولو كانت ذنوبه أعظم من السموات والأرض والجبال{5}. (٤/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>، يعني: الذين أتَوْا رسول الله ﷺ مستخفين بالكذب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿إنا أنزلنا إليك الكتاب بالحق﴾</span> إلى قوله: <span class="qpc-hafs">﴿أم من يكون عليهم وكيلا﴾</span>، قال: فعرض الله بالتوبة لو قبلها{7}. (٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عرض على طعمة التوبة، فقال: <span class="qpc-hafs">﴿ومن يعمل سوءا﴾</span> يعني: إثمًا، <span class="qpc-hafs">﴿أو يظلم نفسه﴾</span> يعني: قذف البريء أبا مليك، <span class="qpc-hafs">﴿ثم يستغفر الله يجد الله غفورا رحيما﴾</span>{8}<span class=comment-ref>١٨٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٣٩</span> اختُلِف فيمن عُنِي بهذه الآية؛ <b>فقال قوم</b>: عني بها الذين وصفهم الله بالخيانة بقوله: <span class="qpc-hafs">﴿ولا تجادل عن الذين يختانون أنفسهم﴾</span>. و<b>قال آخرون</b>: بل عني بها المجادلين عن الخائنين.</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (٧/٤٧٥) بين القولين باندراجهما في العموم، فقال <span class="comment-type-3">مُرَجِّحًا</span> ذلك: «والصواب من القول في ذلك عندنا: أنّه عني بها كل مَن عمل سوءًا أو ظلم نفسه، وإن كانت نزلت في أمر الخائنين والمجادلين عنهم الذين ذكر الله أمرهم في الآيات قبلها».</div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَعۡمَلۡ سُوۤءًا أَوۡ یَظۡلِمۡ نَفۡسَهُۥ ثُمَّ یَسۡتَغۡفِرِ ٱللَّهَ یَجِدِ ٱللَّهَ غَفُورࣰا رَّحِیمࣰا ۝١١٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠١١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي وائل- قال: كان بنو إسرائيل إذا أصاب أحدهم ذنبًا أصبح قد كُتِب كفّارة ذلك الذنب على بابه، وإذا أصاب البول شيئًا منه قرضه بالمقراض، فقال رجل: لقد آتى الله بني إسرائيل خيرًا. فقال ابن مسعود: ما آتاكم الله خيرٌ مما آتاهم، جعل لكم الماء طهورًا، وقال: <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>{9}. (٤/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: مَن قرأ هاتين الآيتين من سورة النساء، ثم استغفر غفر له: <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>، <span class="qpc-hafs">﴿ولو أنهم إذ ظلموا أنفسهم جاؤوك فاستغفروا الله واستغفر لهم الرسول﴾</span> الآية{10}. (٤/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- قال: إنّ في القرآن لآيتين، ما أذنب عبد ذنبًا، ثم تلاهما واستغفر الله؛ إلا غفر له. فسألوه عنهما، فلم يخبرهم، فقال علقمةُ والأسودُ أحدُهما لصاحبه: قم بنا، فقاما إلى المنزل، فأخذا المصحف، فتصفحا البقرة، فقالا: ما رأيناهما، ثم أخذا في النساء حتى انتهيا إلى هذه الآية: <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>، فقالا: هذه واحدة، ثم تصفحا آل عمران حتى انتهينا إلى قوله: <span class="qpc-hafs">﴿والذين إذا فعلوا فاحشة أو ظلموا أنفسهم ذكروا الله فاستغفروا لذنوبهم ومن يغفر الذنوب إلا الله ولم يصروا على ما فعلوا وهم يعلمون (١٣٥)﴾</span>، فقالا: هذه أخرى. ثم أطبقا المصحف، ثم أتيا عبد الله، فقالا: هما هاتان الآيتان؟ فقال عبد الله: نعم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٧<span class="dash">-</span></span> عن حبيب بن أبي ثابت، قال: جاءت امرأة إلى <span class="name-1">عبد الله بن مغفل</span>، فسألته عن امرأة فَجَرَتْ، فحَبَلَتْ، ولَمّا ولدت قتلت ولدها. فقال: ما لها إلا النار. فانصرفت وهي تبكي، فدعاها، ثم قال: ما أرى أمرَكِ إلا أحد أمرين: <span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</span>. فمسحت عينها، ثُمَّ مَضَتْ{5}. (٤/٦٩٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن مردويه في تفسيره -كما في تفسير ابن كثير ٢/٤٠٩- من طريق داود بن مهران الدباغ، عن عمر بن يزيد، عن أبي إسحاق، عن عبد خير، عن علي، عن أبي بكر به.</p><p>وفي سنده عمر بن يزيد، هو أبو حفص الأزدي، ذكره الخطيب البغدادي في تاريخ بغداد ١٣/١١، وقال عنه الذهبي في تاريخ الإسلام ٤/٧٠٠: «لم يضعف». ومثله يتوقف في روايته إلا ما توبع عليه.أخرجه أحمد ١/١٧٩ (٢)، ١/٢١٨-٢١٩ (٤٧)، وابن ماجه (١٣٩٥)، وأبو داود (١٥٢١)، والترمذي (٤٠٦)، وابن حبان (٦٢٣) من طريق عثمان بن المغيرة الثقفي، عن علي بن ربيعة الوالبي، عن أسماء بن الحكم الفزاري، عن علي به.</p><p>حسنه الترمذي، وصححه ابن حبان، والألباني في صحيح أبي داود - الأم ٥/٢٥٢.أخرجه أبو يعلى -كما في إتحاف الخيرة المهرة ٦/١٩٩ (٥٦٧٢)-، والطبراني في الدعاء ص٥٠٥ (١٧٨٦)، وابن مردويه -كما في تفسير ابن كثير ٢/٤٠٩- من طريق مبشر بن إسماعيل الحلبي، عن تمام بن نجيح، عن كعب بن ذهل الأزدي، عن أبي الدرداء به.</p><p>قال البوصيري في إتحاف الخيرة عن إسناد أبي يعلى ٦/١٩٩ (٥٦٧٢): «إسناد ضعيف؛ لجهالة كعب بن ذهل، وضعف تمام بن نجيح». وقال ابن كثير في تفسيره ٢/٤١٠: «هذا حديث غريب جِدًّا من هذا الوجه بهذا السياق، وفي إسناده ضعف». وقال الهيثمي في المجمع ٧/١١ (١٠٩٥٠): «فيه مبشر بن إسماعيل، وثقه ابن معين وغيره، وضعفه البخاري وغيره». وقال ابن حجر في الفتح ١١/٢٦٩: «سنده جيد». وقال الألباني في الضعيفة ١٢/٥٨٧ (٥٧٦٧): «منكر».أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٧/٤٧٦.أخرجه ابن أبي حاتم ٤/١٠٦٢.ذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٠٥- نحوه. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٤٠٦.أخرجه ابن جرير ٧/٤٧٥-٤٧٦، والطبراني (٨٧٩٤)، والبيهقي في شعب الإيمان (٧١٤٣). وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٤/١٣٧١-١٣٧٢ (٦٨٧). وأخرجه ابن أبي الدنيا في كتاب التوبة -موسوعة الإمام ابن أبي الدنيا ٣/٣٩٢ (٢٠)-، والطبراني في الكبير ٩/٢١٢ (٩٠٣٥).أخرجه ابن جرير ٧/٤٧٦.
  4,111,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن یَكۡسِبۡ إِثۡمࣰا فَإِنَّمَا یَكۡسِبُهُۥ عَلَىٰ نَفۡسِهِۦۚ وَكَانَ ٱللَّهُ عَلِیمًا حَكِیمࣰا ۝١١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١١٨<span class="dash">-</span></span> عن <span class="name-1">قتادة بن النعمان</span> -من طريق عمر بن قتادة- <span class="qpc-hafs">﴿ومن يكسب إثما﴾</span> إلى قوله: <span class="qpc-hafs">﴿فقد احتمل بهتانا وإثما مبينا﴾</span> قولهم للبيد{1}. (٤/٦٧٧-٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١٩<span class="dash">-</span></span> عن <span class="name-1">محمود بن لبيد</span>: <span class="qpc-hafs">﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا﴾</span>، يعني: لبيد بن سهل حين رماه بنو أبيرق بالسرقة{2}. (٤/٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يكسب إثما﴾</span> يعني: طعمة <span class="qpc-hafs">﴿فإنما يكسبه على نفسه وكان الله عليما حكيما﴾</span> في أمره{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ومن يكسب إثما فإنما يكسبه على نفسه﴾</span>، قال: فما أدخلكم أنتم أيها الناس على خطيئة هذا تَكَلَّمون دونه؟!{4}. (٤/٦٨٤)</p></p><p></div></p></div>",footnotes:1:أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن سعد.تفسير مقاتل بن سليمان ١/٤٠٤-٤٠٦.أخرجه ابن جرير ٧/٤٦٤-٤٦٥.
  4,112,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن یَكۡسِبۡ خَطِیۤـَٔةً أَوۡ إِثۡمࣰا ثُمَّ یَرۡمِ بِهِۦ بَرِیۤـࣰٔا فَقَدِ ٱحۡتَمَلَ بُهۡتَـٰنࣰا وَإِثۡمࣰا مُّبِینࣰا ۝١١٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠١٢٢<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق فضيل بن مرزوق- أنّ رجلًا يُقال له: طعمة بن أبيرق، سرق درعًا على عهد النبي ﷺ، فرُفِع ذلك إلى النبي ﷺ، فألقاها في بيت رجل، ثم قال لأصحاب له: انطلقوا فاعذروني عند النبي ﷺ، فإنّ الدرع قد وُجِد في بيت فلان. فانطلقوا يعذرونه عند النبي ﷺ؛ فأنزل الله: <span class="qpc-hafs">﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا فقد احتمل بهتانا﴾</span>. قال: بهتانه: قذفه الرجل{1}<span class=comment-ref>١٨٤٠</span>. (٤/٦٨٨)</p></p><p></div></p><p><div><span class=comment-ref>١٨٤٠</span> ذكر <u>ابن عطية</u> (٣/٢١) أنّ لفظ الآية عامٌّ، ويندرج فيه أهل النازلة المذكورة. وذكر أن قوله: <span class="qpc-hafs">﴿لهمّت﴾</span> يدل على أن الألفاظ عامة في غير أهل النازلة، وإلا فأهل التعصب لبني أبيرق قد وقع همهم وثبت.</div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَكۡسِبۡ خَطِیۤـَٔةً أَوۡ إِثۡمࣰا ثُمَّ یَرۡمِ بِهِۦ بَرِیۤـࣰٔا فَقَدِ ٱحۡتَمَلَ بُهۡتَـٰنࣰا وَإِثۡمࣰا مُّبِینࣰا ۝١١٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠١٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿ومن يكسب خطيئة أو إثما﴾</span> عبد الله بن أُبي بن سلول، <span class="qpc-hafs">﴿ثم يرم به بريئا﴾</span> يعني به: عائشة أم المؤمنين حيث كذب عليها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: ثم قال: <span class="qpc-hafs">﴿ومن يكسب خطيئة﴾</span> الآية، يعني: السارق، والذين جادلوا عن السارق{3}. (٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٥<span class="dash">-</span></span> عن <span class="name-1">محمود بن لبيد</span>، قوله: <span class="qpc-hafs">﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا﴾</span>، يعني: لبيد بن سهل، حين رماه بنو أبيرق بالسرقة{4}. (٤/٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿ثم يرم به بريئا﴾</span> يعني: زيد بن السمين <span class="qpc-hafs">﴿فقد احتمل بهتانا﴾</span> طعمة بن أبيرق{5}. (٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق خالد الحذاء- <span class="qpc-hafs">﴿ثم يرم به بريئا﴾</span>، قال: يهوديًّا{6}. (٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ثم يرم به بريئا﴾</span> اليهودي{7}. (٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢٩<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق فضيل بن مرزوق- <span class="qpc-hafs">﴿فقد احتمل بهتانا﴾</span> قال: بهتانه: قذفه الرجل، <span class="qpc-hafs">﴿وإثما مبينا﴾</span> قال: إثمه: سرقته{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يكسب﴾</span> لنفسه <span class="qpc-hafs">﴿خطيئة أو إثما﴾</span> يعني: قذف البريء، <span class="qpc-hafs">﴿ثم يرم به بريئا﴾</span> يعني: أنّه رمى به في دار أبي مليك الأنصاري؛ <span class="qpc-hafs">﴿فقد احتمل بهتانا﴾</span> يعني: قَذْفه البريء بما لم يكن، <span class="qpc-hafs">﴿وإثما مبينا﴾</span> يعني: بيِّنًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا﴾</span> وإن كان مشركًا <span class="qpc-hafs">﴿فقد احتمل بهتانا﴾</span>{10}<span class=comment-ref>١٨٤١</span>. (٤/٦٨٤)</p></p><p></div></p><p><div><span class=comment-ref>١٨٤١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٣/٢١) أنّ بعض الناس ذهب إلى أن قوله: <span class="qpc-hafs">﴿خطيئة أو إثما﴾</span> لفظان بمعنًى، كرر لاختلاف اللفظ.</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٠٦٣.تفسير الثعلبي ٣/٣٨٣.أخرجه ابن جرير ٧/٤٦٣-٤٦٤، وابن أبي حاتم ٤/١٠٥٩-١٠٦٣.عزاه السيوطي إلى ابن سعد.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.أخرجه ابن جرير ٧/٤٧٨، وابن أبي حاتم ٤/١٠٦٣. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٤/١٠٦٣-١٠٦٤.تفسير مقاتل بن سليمان ١/٤٠٦.أخرجه ابن جرير ٧/٤٦٤-٤٦٥.
  4,113,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا فَضۡلُ ٱللَّهِ عَلَیۡكَ وَرَحۡمَتُهُۥ لَهَمَّت طَّاۤىِٕفَةࣱ مِّنۡهُمۡ أَن یُضِلُّوكَ وَمَا یُضِلُّونَ إِلَّاۤ أَنفُسَهُمۡۖ وَمَا یَضُرُّونَكَ مِن شَیۡءࣲۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١٣٢<span class="dash">-</span></span> عن <span class="name-1">قتادة بن النعمان</span> -من طريق عمر بن قتادة- <span class="qpc-hafs">﴿ولولا فضل الله عليك ورحمته لهمت طائفة منهم أن يضلوك﴾</span>، يعني: أسير بن عروة، وأصحابه. إلى قوله: <span class="qpc-hafs">﴿فسوف نؤتيه أجرا عظيما﴾</span>{1}. (٤/٦٧٧-٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- ثم قال: <span class="qpc-hafs">﴿ولو فضل الله عليك ورحمته﴾</span> يعني به: الإسلام، والقرآن <span class="qpc-hafs">﴿لهمت طائفة منهم﴾</span> يعني: من ثقيف <span class="qpc-hafs">﴿أن يضلوك﴾</span> وذلك أنّ وفد ثقيف قدموا على رسول الله ﷺ، فقالوا: يا محمد، قد جئناك نبايعك على أن لا حشر، ولا بعث، ولا نكسر أصنامًا بأيدينا، على أن تُمَتِّعنا بالعُزّى سَنَة. فلم يجبهم إلى ذلك، وعصمه الله بمَنِّه، وأخبره بنعمته عليه أنه في حفظه وكلاءته، فلا يخلص إليه أمر يكرهه. فقال: <span class="qpc-hafs">﴿وما يضلون إلا أنفسهم﴾</span> يعني: وفد ثقيف، <span class="qpc-hafs">﴿وما يضرونك من شىء﴾</span> يعني: لا يستطيعون أن يزيلوا عنك النبوة وقد جعلك الله لها أهلًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿ولولا فضل الله عليك ورحمته﴾</span> لمحمد ﷺ <span class="qpc-hafs">﴿لهمت طائفة﴾</span> قوم طعمة{3}. (٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: ثم قال لنبيه ﷺ: <span class="qpc-hafs">﴿ولولا فضل الله عليك ورحمته﴾</span> إلى قوله: <span class="qpc-hafs">﴿وكان فضل الله عليك عظيما﴾</span>. فأُبْرِئَ اليهوديُّ، وأخبر بصاحب الدرع. قال: قد افتضحت الآن في المسلمين، وعلموا أني صاحب الدرع، ما لي إقامة ببلد. فتراغم، فلحق بالمشركين{4}. (٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ثم قال لنبيه ﵇: <span class="qpc-hafs">﴿ولولا فضل الله عليك ورحمته لهمت طائفة منهم أن يضلوك﴾</span> فيما أرادوا من النبي ﷺ أن يعذر عن صاحبهم، <span class="qpc-hafs">﴿وما يضلون إلا أنفسهم﴾</span> أي: حين جاءوا إليك لتعذره، <span class="qpc-hafs">﴿وما يضرونك﴾</span> ينقصونك من شيء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثم ذكر الأنصار، وإتيانها إيّاه أن ينضح{6} عن صاحبهم، ويجادل عنه، فقال: <span class="qpc-hafs">﴿لهمت طائفة منهم أن يضلوك وما يضلون إلا أنفسهم وما يضرونك من شيء﴾</span>{7}. (٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال لنبيه ﷺ: <span class="qpc-hafs">﴿ولولا فضل الله عليك ورحمته﴾</span> يعني: ونعمته بالقرآن حين بَيَّنَ لك أمر طعمة، فحوَّلك عن تصديق الخائنين بالقرآن؛ <span class="qpc-hafs">﴿لهمت طائفة منهم أن يضلوك﴾</span> يقول: لكادت طائفة من قوم الخائنين أن يستنزلوك عن الحق، <span class="qpc-hafs">﴿وما يضلون﴾</span> يعني: وما يَسْتَنزِلون <span class="qpc-hafs">﴿إلا أنفسهم وما يضرونك من شيء﴾</span> يعني: وما ينقصونك من شيء ليس ذلك بأيديهم، إنما ينقصون أنفسهم{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلَ ٱللَّهُ عَلَیۡكَ ٱلۡكِتَـٰبَ وَٱلۡحِكۡمَةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١٣٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- ثم قال: <span class="qpc-hafs">﴿وأنزل الله عليك الكتاب والحكمة﴾</span>، يعني: الأحكام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وأنزل الله عليك الكتاب والحكمة﴾</span>، يعني: الحلال والحرام{8}<span class=comment-ref>١٨٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٤٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (١/٢٩٥-٢٩٦) أقوالًا للسلف في تفسير الحكمة، وبيَّن أنّ تفسيرها بالسُّنَّة أعمُّ وأشهر، ثم قال: «وأحسن ما قيل في الحكمة: معرفة الحق والعمل به، والإصابة في القول والعمل. وهذا قول مجاهد، ومالك».</div></p><p><h3><span class="qpc-hafs">﴿وَعَلَّمَكَ مَا لَمۡ تَكُن تَعۡلَمُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١٤١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- ثم قال: <span class="qpc-hafs">﴿وعلمك ما لم تكن تعلم﴾</span> من الشرائع{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٤٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- قال: علمه الخير والشر{12}. (٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وعلمك ما لم تكن تعلم﴾</span>، قال: علَّمه الله بيان الدنيا والآخرة، بيَّن حلاله وحرامه ليحتج بذلك على خلقه{12}. (٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعلمك ما لم تكن تعلم﴾</span> من أمر الكتاب، وأمر الدين{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانَ فَضۡلُ ٱللَّهِ عَلَیۡكَ عَظِیمࣰا ۝١١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠١٤٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي عن أبي صالح- ثم قال: <span class="qpc-hafs">﴿وكان فضل الله﴾</span> أي: مَنُّ الله <span class="qpc-hafs">﴿عليك﴾</span> بالنبوة <span class="qpc-hafs">﴿عظيما﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكان فضل الله عليك عظيما﴾</span>، يعني: النبوة، والكتاب{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٣/٣٨٣-٣٨٤.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٠٥-.نضح عنه: ذبَّ ودفع، ونضح الرجل: رَدَّ عنه. لسان العرب (نضح).أخرجه ابن جرير ٧/٤٦٦-٤٦٧، وابن أبي حاتم ٤/١٠٦٤.تفسير مقاتل بن سليمان ١/٤٠٦.تفسير الثعلبي ٣/٣٨٣-٣٨٤.تفسير مقاتل بن سليمان ١/٤٠٦.تفسير الثعلبي ٣/٣٨٣-٣٨٤.أخرجه ابن أبي حاتم ٤/١٠٦٤.أخرجه ابن أبي حاتم ٤/١٠٦٤.تفسير مقاتل بن سليمان ١/٤٠٦.تفسير الثعلبي ٣/٣٨٣-٣٨٤.تفسير مقاتل بن سليمان ١/٤٠٦.