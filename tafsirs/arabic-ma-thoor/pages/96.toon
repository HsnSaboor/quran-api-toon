tafsir[8]{c,v,t}:
4,106," <q>﴿وَٱسۡتَغۡفِرِ ٱللَّهَۖ إِنَّ ٱللَّهَ كَانَ غَفُورࣰا رَّحِیمࣰا ۝١٠٦﴾</q> - تفسير ٢٠٠٨٦- عن قتادة بن النعمان -من طريق عمر بن قتادة- <q>﴿واستغفر الله﴾</q> أي: مما قلت لقتادة، <q>﴿إن الله كان غفورا رحيما﴾</q>{1}. (٤/٦٧٧-٦٨٠) ٢٠٠٨٧- عن الحسن البصري: <q>﴿واستغفر الله﴾</q> مما كنت هممت به أن تعذره{2}. (ز) ٢٠٠٨٨- قال محمد بن السائب الكلبي: واستغفر الله يا محمد مِن هَمِّك باليهوديِّ أن تضربه{3}. (ز) ٢٠٠٨٩- قال مقاتل بن سليمان: ثم قال: <q>﴿واستغفر الله﴾</q> يا محمد عن جدالك عن طعمة حين كذبت عنه، فأبرأته من السرقة، <q>﴿إن الله كان غفورا رحيما﴾</q>. فاستغفر النبي ﷺ عند ذلك{4}. (ز) ٢٠٠٩٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿واستغفر الله﴾</q> بما قلت لهذا اليهوديِّ، <q>﴿إن الله كان غفورا رحيما﴾</q>{5}١٨٣٦. (٤/٦٨٤) ١٨٣٦ ذهب ابنُ جرير (٧/٤٧٥) إلى أنّ معنى قوله: <q>﴿واستغفر الله﴾</q>: استغفر الله من ذنبك في خصامك للخائنين. وعلَّق عليه ابنُ عطية (٣/١٨)، بقوله: «وهذا ليس بذنب؛ لأن النبي ﷺ إنما دافع عن الظاهر، وهو يعتقد براءتهم، والمعنى: استغفر للمذنبين من أمتك والمتخاصمين في الباطل، لا أن تكون ذا جدال عنهم، فهذا حدُّك، ومحلك من الناس أن تسمع من المتداعيين، وتقضي بنحو ما تسمع، وتستغفر للمذنب». ",footnotes:1:أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٠٣-.تفسير الثعلبي ٣/٣٨١.تفسير مقاتل بن سليمان ١/٤٠٥.أخرجه ابن جرير ٧/٤٦٤-٤٦٥.
4,107," <q>﴿وَلَا تُجَـٰدِلۡ عَنِ ٱلَّذِینَ یَخۡتَانُونَ أَنفُسَهُمۡۚ إِنَّ ٱللَّهَ لَا یُحِبُّ مَن كَانَ خَوَّانًا أَثِیمࣰا ۝١٠٧﴾</q> - تفسير ٢٠٠٩١- عن محمود بن لبيد، قوله: <q>﴿ولا تجادل عن الذين يختانون أنفسهم﴾</q> يعني: أسير بن عروة وأصحابه، <q>﴿إن الله لا يحب من كان خوانا أثيما﴾</q>{1}. (٤/٦٨١) ٢٠٠٩٢- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قوله: <q>﴿ولا تجادل عن الذين يختانون أنفسهم﴾</q>، يعني: طعمة بن أبيرق وقومه{2}. (٤/٦٨٧) ٢٠٠٩٣- قال مقاتل بن سليمان: <q>﴿ولا تجادل عن الذين يختانون أنفسهم﴾</q> يعني: طعمة، <q>﴿إن الله لا يحب من كان خوانا﴾</q> في دينه، <q>﴿أثيمًا﴾</q> بربه{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن سعد من وجه آخر.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤٠٥.
4,108," <q>﴿یَسۡتَخۡفُونَ مِنَ ٱلنَّاسِ وَلَا یَسۡتَخۡفُونَ مِنَ ٱللَّهِ وَهُوَ مَعَهُمۡ إِذۡ یُبَیِّتُونَ مَا لَا یَرۡضَىٰ مِنَ ٱلۡقَوۡلِۚ وَكَانَ ٱللَّهُ بِمَا یَعۡمَلُونَ مُحِیطًا ۝١٠٨﴾</q> - تفسير ٢٠٠٩٤- عن عبد الله بن مسعود -من طريق أبي الأحوص موقوفًا ومرفوعًا- قال: «مَن صلّى صلاة عند الناس لا يُصَلِّي مثلها إذا خلا؛ فهي استهانةٌ، استهان بها ربه». ثم تلا هذه الآية: <q>﴿يستخفون من الناس ولا يستخفون من الله وهو معهم﴾</q>{1}. (٤/٦٩٠) ٢٠٠٩٥- عن حذيفة بن اليمان، مثله. وزاد: وألا يستحيي أن يكون الناسُ أعظمَ عنده من الله؟!{2}. (٤/٦٩٠) ٢٠٠٩٦- عن عبد الله بن عباس -من طريق العوفي- قال: ثم قال للذين أتوا رسول الله ﷺ لَيْلًا: <q>﴿يستخفون من الناس﴾</q> إلى قوله: <q>﴿وكيلا﴾</q>، يعني: الذين أتوا رسول الله ﷺ مستخفين يجادلون عن الخائنين{3}. (٤/٦٨٣) ٢٠٠٩٧- عن عبد الله بن عباس -من طريق الكلبي عن أبي صالح- <q>﴿إذ يبيتون﴾</q>، يعني: يقولون{4}. (ز) ٢٠٠٩٨- عن أبي رَزِين [الأسدي]-من طريق الأعمش- <q>﴿إذ يبيتون﴾</q>، قال: إذ يُؤَلِّفون ما لا يرضى من القول{5}١٨٣٧. (٤/٦٩٠) ١٨٣٧ ذكر ابنُ جرير (٧/٤٧٢-٤٧٣) أنّ التبْييت لغة: كل كلام أو أمر أُصلح ليلًا. ثم ذكر عن بعض الطائيين: أن التبييت في لغتهم: التبديل، وأنشد للأسود بن عامر بن جوين الطائي: وبيَّتَّ قولي عند المليك قاتلَك الله عبدًا كنودا وساق قولَ أبي رزين، وعلَّق عليه بقوله: «وهذا القول شبيه المعنى بالذي قلناه، وذلك أنّ التأليف هو: التسوية والتغيير عما هو به، وتحويله عن معناه إلى غيره». وذكر ابنُ عطية (٣/١٩) احتمالًا آخر، فقال: «ويحتمل أن تكون اللفظة مأخوذة من البيت، أي: يَسْتَسِرُّون في تدبيرهم بالجدران». ٢٠٠٩٩- وعن إسماعيل السُّدِّيّ، مثل ذلك{6}. (ز) ٢٠١٠٠- قال مقاتل بن سليمان: <q>﴿يستخفون﴾</q> يعني: يستترون بالخيانة <q>﴿من الناس﴾</q> يعني: طعمة، <q>﴿ولا يستخفون من الله﴾</q> ولا يستترون بالخيانة من الله، <q>﴿وهو معهم إذ يبيتون﴾</q> يعني: إذ يُؤَلِّفون <q>﴿ما لا يرضى من القول﴾</q> لقولهم: إنّا نأتي النبي ﷺ فنقول له كذا وكذا. فألقوا قولهم بينهم، يعني: قتادة وأصحابه؛ ليدفعوا عن صاحبهم ما لا يرضى الله من القول، <q>﴿وكان الله بما يعملون محيطا﴾</q> يعني: أحاط علمه بأعمالهم، يعني: قوم الخائن قتادة بن النعمان وأصحابه{7}. (ز) ٢٠١٠١- عن مقاتل بن حيّان -من طريق بُكَير بن معروف- في قوله: <q>﴿بما يعملون محيطا﴾</q>، يقول: أحاط علمُه بأعمالهم{6}. (ز) ٢٠١٠٢- عن أبي سعيد الحداد أحمد بن داود -من طريق عباد بن الوليد الغُبَرِيّ- يقول: <q>﴿إذ يبيتون ما لا يرضى من القول وكان الله بما يعملون محيطا﴾</q>، قال: قد أحاط بكلِّ شيء علمًا، ولم يقل مع كل شيء{9}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٦٩ (٣٧٣٨)، وأبو يعلى في مسنده ٩/٥٤ (٥١١٧) مرفوعًا دون ذكر الآية، وابن أبي حاتم ٤/١٠٦١ (٥٩٣٩) من طريق أبي إسحاق الهجري، عن أبي الأحوص، عن عبد الله به مرفوعًا. وأخرجه ابن أبي حاتم ٤/١٠٦١ (٥٩٣٨) واللفظ له، من طريق أبي إسحاق السبيعي، عن أبي الأحوص، عن عبد الله به موقوفًا عليه. قال البوصيري في إتحاف الخيرة ١/٢٥٨ (٣٩٥): «حديث حسن». وقال ابن حجر في المطالب العالية ١٣/٤٢٧ (٣٢١٣): «حديث حسن». وقال الهيثمي في المجمع ١٠/٢٢١: «فيه إبراهيم بن مسلم الهجري، وهو ضعيف». وقال المنذري في الترغيب والترهيب ١/٣٣ (٤٥) عن الموقوف: «هو أشبه». وقال الألباني في الضعيفة ١٠/٣٩ (٤٥٣٧): «ضعيف».عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٧/٤٦٣-٤٦٤، وابن أبي حاتم ٤/١٠٥٩-١٠٦٣.تفسير الثعلبي ٣/٣٨٢.أخرجه ابن جرير ٧/٤٧٢-٤٧٣، وابن أبي حاتم ٤/١٠٦١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٤/١٠٦١.تفسير مقاتل بن سليمان ١/٤٠٥.أخرجه ابن أبي حاتم ٤/١٠٦١.أخرجه ابن أبي حاتم ٤/١٠٦٢.
4,109," <q>﴿هَـٰۤأَنتُمۡ هَـٰۤؤُلَاۤءِ جَـٰدَلۡتُمۡ عَنۡهُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا فَمَن یُجَـٰدِلُ ٱللَّهَ عَنۡهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ أَم مَّن یَكُونُ عَلَیۡهِمۡ وَكِیلࣰا ۝١٠٩﴾</q> - تفسير ٢٠١٠٣- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿ها أنتم هؤلاء جادلتم عنهم في الحياة الدنيا فمن يجادل الله عنهم يوم القيامة﴾</q>، يعني: الذين أتوا رسول الله ﷺ مستخفين يجادلون عن الخائن{1}. (٤/٦٨٣) ٢٠١٠٤- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قوله: <q>﴿ها أنتم هؤلاء جادلتم﴾</q> إلى قوله: <q>﴿يكون عليهم وكيلا﴾</q>، قال: محمد ﷺ، وقوم طعمة{2}. (٤/٦٨٧) ٢٠١٠٥- قال مقاتل بن سليمان: ثم قال يعنيهم: <q>﴿ها أنتم هؤلاء﴾</q> قوم الخائن <q>﴿جادلتم عنهم﴾</q> نبيكم <q>﴿في الحياة الدنيا﴾</q> عن طعمة، <q>﴿فمن يجادل الله عنهم يوم القيامة أم من يكون عليهم وكيلا﴾</q> يعني به: قومه. يقول: أم من يكون لطعمة مانعًا في الآخرة{3}١٨٣٨. (ز) ١٨٣٨ ذكر ابنُ عطية (٣/١٩) أنّ الخطاب بهذه الآية للقوم الذين يتعصبون لأهل الرِيَب والمعاصي، وأنه يشمل بعمومه أهل النازلة. ثم رجَّح مستندًا إلى ظاهر لفظ الآية كونه لأهل التعصب في الواقعة، فقال: «وهو الأظهر عندي؛ بحكم التأكيد بـ<q>﴿هؤُلاءِ﴾</q>، وهي إشارة إلى حاضرين». ",footnotes:1:أخرجه ابن جرير ٧/٤٦٣-٤٦٤، وابن أبي حاتم ٤/١٠٦٢.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.تفسير مقاتل بن سليمان ١/٤٠٥.
4,110," <q>﴿وَمَن یَعۡمَلۡ سُوۤءًا أَوۡ یَظۡلِمۡ نَفۡسَهُۥ ثُمَّ یَسۡتَغۡفِرِ ٱللَّهَ یَجِدِ ٱللَّهَ غَفُورࣰا رَّحِیمࣰا ۝١١٠﴾</q> - تفسير ٢٠١٠٦- عن علي بن أبي طالب، قال: سمعت أبا بكر يقول: سمعت رسول الله ﷺ يقول: «ما من عبد أذْنَب، فقام فتوضأ، فأحسن وضوءه، ثم قام فصلّى، واستغفر من ذنبه؛ إلا كان حقًّا على الله أن يغفر له؛ لأنه يقول: <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>»{1}. (٤/٦٩٢) ٢٠١٠٧- عن علي بن أبي طالب، قال: كنتُ إذا سمعتُ من رسول الله ﷺ شيئًا نفعني الله بما شاء أن ينفعني منه، وحدثني أبو بكر، وصدق أبو بكر، قال: قال رسول الله ﷺ: «ما مِن مسلم يُذنِب ذَنبًا، ثم يتوضأ فيصلي ركعتين، ثم يستغفر الله لذلك الذنب؛ إلّا غَفَرَ له». وقرأ هاتين الآيتين: <q>﴿ومَن يَعْمَلْ سُوءًا أوْ يَظْلِمْ نَفْسَهُ ثُمَّ يَسْتَغْفِرْ اللَّهَ يَجِدْ اللَّهَ غَفُورًا رَحِيمًا﴾</q>، <q>﴿والَّذِينَ إذا فَعَلُوا فاحِشَةً أوْ ظَلَمُوا أنْفُسَهُمْ﴾</q> [آل عمران:١٣٥]{2}. (ز) ٢٠١٠٨- عن أبي الدرداء، قال: كان رسول الله ﷺ إذا جلس وجلسنا حوله، وكانت له حاجة فقام إليها وأراد الرجوع؛ ترك نعليه في مجلسه، أو بعض ما يكون عليه، وأنه قام فترك نعليه، فأخذت رَكْوَةً من ماء، فاتبعته، فمضى ساعة، ثم رجع ولم يقض حاجته، فقال: «إنه أتاني آتٍ من ربي، فقال: إنه <q>﴿من يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>. فأردت أن أُبَشِّر أصحابي». قال أبو الدرداء: وكانَتْ قد شَقَّت على الناس التي قبلها: <q>﴿من يعمل سوءا يجز به﴾</q>. فقلت: يا رسول الله، وإن زنى وإن سرق، ثم استغفر ربه، غفر الله له؟ قال: «نعم». قلت الثانية، قال: «نعم». قلت الثالثة، قال: «نعم، على رغم أنف عويمر»{3}. (٤/٦٩٢) ٢٠١٠٩- عن قتادة بن النعمان -من طريق عمر بن قتادة- <q>﴿ولا تجادل عن الذين يختانون أنفسهم﴾</q> إلى قوله: <q>﴿ثم يستغفر الله يجد الله غفورا رحيما﴾</q>، أي: أنهم لو استغفروا الله لغفر لهم{4}. (٤/٦٧٧-٦٨٠) ٢٠١١٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>، قال: أخبر الله عباده بحِلمه وعفوه وكرمه وسعة رحمته ومغفرته، فمن أذنب ذنبًا صغيرًا كان أو كبيرًا، ثم استغفر الله؛ يجد الله غفورًا رحيمًا، ولو كانت ذنوبه أعظم من السموات والأرض والجبال{5}. (٤/٦٩١) ٢٠١١١- عن عبد الله بن عباس -من طريق العوفي- <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>، يعني: الذين أتَوْا رسول الله ﷺ مستخفين بالكذب{6}. (ز) ٢٠١١٢- عن الحسن البصري، <q>﴿إنا أنزلنا إليك الكتاب بالحق﴾</q> إلى قوله: <q>﴿أم من يكون عليهم وكيلا﴾</q>، قال: فعرض الله بالتوبة لو قبلها{7}. (٤/٦٨٥) ٢٠١١٣- قال مقاتل بن سليمان: ثم عرض على طعمة التوبة، فقال: <q>﴿ومن يعمل سوءا﴾</q> يعني: إثمًا، <q>﴿أو يظلم نفسه﴾</q> يعني: قذف البريء أبا مليك، <q>﴿ثم يستغفر الله يجد الله غفورا رحيما﴾</q>{8}١٨٣٩. (ز) ١٨٣٩ اختُلِف فيمن عُنِي بهذه الآية؛ فقال قوم: عني بها الذين وصفهم الله بالخيانة بقوله: <q>﴿ولا تجادل عن الذين يختانون أنفسهم﴾</q>. وقال آخرون: بل عني بها المجادلين عن الخائنين. وجمع ابنُ جرير (٧/٤٧٥) بين القولين باندراجهما في العموم، فقال مُرَجِّحًا ذلك: «والصواب من القول في ذلك عندنا: أنّه عني بها كل مَن عمل سوءًا أو ظلم نفسه، وإن كانت نزلت في أمر الخائنين والمجادلين عنهم الذين ذكر الله أمرهم في الآيات قبلها». <q>﴿وَمَن یَعۡمَلۡ سُوۤءًا أَوۡ یَظۡلِمۡ نَفۡسَهُۥ ثُمَّ یَسۡتَغۡفِرِ ٱللَّهَ یَجِدِ ٱللَّهَ غَفُورࣰا رَّحِیمࣰا ۝١١٠﴾</q> - آثار متعلقة بالآية ٢٠١١٤- عن عبد الله بن مسعود -من طريق أبي وائل- قال: كان بنو إسرائيل إذا أصاب أحدهم ذنبًا أصبح قد كُتِب كفّارة ذلك الذنب على بابه، وإذا أصاب البول شيئًا منه قرضه بالمقراض، فقال رجل: لقد آتى الله بني إسرائيل خيرًا. فقال ابن مسعود: ما آتاكم الله خيرٌ مما آتاهم، جعل لكم الماء طهورًا، وقال: <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>{9}. (٤/٦٩١) ٢٠١١٥- عن عبد الله بن مسعود، قال: مَن قرأ هاتين الآيتين من سورة النساء، ثم استغفر غفر له: <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>، <q>﴿ولو أنهم إذ ظلموا أنفسهم جاؤوك فاستغفروا الله واستغفر لهم الرسول﴾</q> الآية{10}. (٤/٦٩١) ٢٠١١٦- عن عبد الله بن مسعود -من طريق إبراهيم- قال: إنّ في القرآن لآيتين، ما أذنب عبد ذنبًا، ثم تلاهما واستغفر الله؛ إلا غفر له. فسألوه عنهما، فلم يخبرهم، فقال علقمةُ والأسودُ أحدُهما لصاحبه: قم بنا، فقاما إلى المنزل، فأخذا المصحف، فتصفحا البقرة، فقالا: ما رأيناهما، ثم أخذا في النساء حتى انتهيا إلى هذه الآية: <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>، فقالا: هذه واحدة، ثم تصفحا آل عمران حتى انتهينا إلى قوله: <q>﴿والذين إذا فعلوا فاحشة أو ظلموا أنفسهم ذكروا الله فاستغفروا لذنوبهم ومن يغفر الذنوب إلا الله ولم يصروا على ما فعلوا وهم يعلمون (١٣٥)﴾</q>، فقالا: هذه أخرى. ثم أطبقا المصحف، ثم أتيا عبد الله، فقالا: هما هاتان الآيتان؟ فقال عبد الله: نعم{11}. (ز) ٢٠١١٧- عن حبيب بن أبي ثابت، قال: جاءت امرأة إلى عبد الله بن مغفل، فسألته عن امرأة فَجَرَتْ، فحَبَلَتْ، ولَمّا ولدت قتلت ولدها. فقال: ما لها إلا النار. فانصرفت وهي تبكي، فدعاها، ثم قال: ما أرى أمرَكِ إلا أحد أمرين: <q>﴿ومن يعمل سوءا أو يظلم نفسه ثم يستغفر الله يجد الله غفورا رحيما﴾</q>. فمسحت عينها، ثُمَّ مَضَتْ{5}. (٤/٦٩٢) ",footnotes:1:أخرجه ابن مردويه في تفسيره -كما في تفسير ابن كثير ٢/٤٠٩- من طريق داود بن مهران الدباغ، عن عمر بن يزيد، عن أبي إسحاق، عن عبد خير، عن علي، عن أبي بكر به. وفي سنده عمر بن يزيد، هو أبو حفص الأزدي، ذكره الخطيب البغدادي في تاريخ بغداد ١٣/١١، وقال عنه الذهبي في تاريخ الإسلام ٤/٧٠٠: «لم يضعف». ومثله يتوقف في روايته إلا ما توبع عليه.أخرجه أحمد ١/١٧٩ (٢)، ١/٢١٨-٢١٩ (٤٧)، وابن ماجه (١٣٩٥)، وأبو داود (١٥٢١)، والترمذي (٤٠٦)، وابن حبان (٦٢٣) من طريق عثمان بن المغيرة الثقفي، عن علي بن ربيعة الوالبي، عن أسماء بن الحكم الفزاري، عن علي به. حسنه الترمذي، وصححه ابن حبان، والألباني في صحيح أبي داود - الأم ٥/٢٥٢.أخرجه أبو يعلى -كما في إتحاف الخيرة المهرة ٦/١٩٩ (٥٦٧٢)-، والطبراني في الدعاء ص٥٠٥ (١٧٨٦)، وابن مردويه -كما في تفسير ابن كثير ٢/٤٠٩- من طريق مبشر بن إسماعيل الحلبي، عن تمام بن نجيح، عن كعب بن ذهل الأزدي، عن أبي الدرداء به. قال البوصيري في إتحاف الخيرة عن إسناد أبي يعلى ٦/١٩٩ (٥٦٧٢): «إسناد ضعيف؛ لجهالة كعب بن ذهل، وضعف تمام بن نجيح». وقال ابن كثير في تفسيره ٢/٤١٠: «هذا حديث غريب جِدًّا من هذا الوجه بهذا السياق، وفي إسناده ضعف». وقال الهيثمي في المجمع ٧/١١ (١٠٩٥٠): «فيه مبشر بن إسماعيل، وثقه ابن معين وغيره، وضعفه البخاري وغيره». وقال ابن حجر في الفتح ١١/٢٦٩: «سنده جيد». وقال الألباني في الضعيفة ١٢/٥٨٧ (٥٧٦٧): «منكر».أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٧/٤٧٦.أخرجه ابن أبي حاتم ٤/١٠٦٢.ذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٠٥- نحوه. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٤٠٦.أخرجه ابن جرير ٧/٤٧٥-٤٧٦، والطبراني (٨٧٩٤)، والبيهقي في شعب الإيمان (٧١٤٣). وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٤/١٣٧١-١٣٧٢ (٦٨٧). وأخرجه ابن أبي الدنيا في كتاب التوبة -موسوعة الإمام ابن أبي الدنيا ٣/٣٩٢ (٢٠)-، والطبراني في الكبير ٩/٢١٢ (٩٠٣٥).أخرجه ابن جرير ٧/٤٧٦.
4,111," <q>﴿وَمَن یَكۡسِبۡ إِثۡمࣰا فَإِنَّمَا یَكۡسِبُهُۥ عَلَىٰ نَفۡسِهِۦۚ وَكَانَ ٱللَّهُ عَلِیمًا حَكِیمࣰا ۝١١١﴾</q> - تفسير ٢٠١١٨- عن قتادة بن النعمان -من طريق عمر بن قتادة- <q>﴿ومن يكسب إثما﴾</q> إلى قوله: <q>﴿فقد احتمل بهتانا وإثما مبينا﴾</q> قولهم للبيد{1}. (٤/٦٧٧-٦٨٠) ٢٠١١٩- عن محمود بن لبيد: <q>﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا﴾</q>، يعني: لبيد بن سهل حين رماه بنو أبيرق بالسرقة{2}. (٤/٦٨٠) ٢٠١٢٠- قال مقاتل بن سليمان: <q>﴿ومن يكسب إثما﴾</q> يعني: طعمة <q>﴿فإنما يكسبه على نفسه وكان الله عليما حكيما﴾</q> في أمره{3}. (ز) ٢٠١٢١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ومن يكسب إثما فإنما يكسبه على نفسه﴾</q>، قال: فما أدخلكم أنتم أيها الناس على خطيئة هذا تَكَلَّمون دونه؟!{4}. (٤/٦٨٤) ",footnotes:1:أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن سعد.تفسير مقاتل بن سليمان ١/٤٠٤-٤٠٦.أخرجه ابن جرير ٧/٤٦٤-٤٦٥.
4,112," <q>﴿وَمَن یَكۡسِبۡ خَطِیۤـَٔةً أَوۡ إِثۡمࣰا ثُمَّ یَرۡمِ بِهِۦ بَرِیۤـࣰٔا فَقَدِ ٱحۡتَمَلَ بُهۡتَـٰنࣰا وَإِثۡمࣰا مُّبِینࣰا ۝١١٢﴾</q> - نزول الآية ٢٠١٢٢- عن عطية العوفي -من طريق فضيل بن مرزوق- أنّ رجلًا يُقال له: طعمة بن أبيرق، سرق درعًا على عهد النبي ﷺ، فرُفِع ذلك إلى النبي ﷺ، فألقاها في بيت رجل، ثم قال لأصحاب له: انطلقوا فاعذروني عند النبي ﷺ، فإنّ الدرع قد وُجِد في بيت فلان. فانطلقوا يعذرونه عند النبي ﷺ؛ فأنزل الله: <q>﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا فقد احتمل بهتانا﴾</q>. قال: بهتانه: قذفه الرجل{1}١٨٤٠. (٤/٦٨٨) ١٨٤٠ ذكر ابن عطية (٣/٢١) أنّ لفظ الآية عامٌّ، ويندرج فيه أهل النازلة المذكورة. وذكر أن قوله: <q>﴿لهمّت﴾</q> يدل على أن الألفاظ عامة في غير أهل النازلة، وإلا فأهل التعصب لبني أبيرق قد وقع همهم وثبت. <q>﴿وَمَن یَكۡسِبۡ خَطِیۤـَٔةً أَوۡ إِثۡمࣰا ثُمَّ یَرۡمِ بِهِۦ بَرِیۤـࣰٔا فَقَدِ ٱحۡتَمَلَ بُهۡتَـٰنࣰا وَإِثۡمࣰا مُّبِینࣰا ۝١١٢﴾</q> - تفسير الآية ٢٠١٢٣- عن عبد الله بن عباس -من طريق الضحاك- <q>﴿ومن يكسب خطيئة أو إثما﴾</q> عبد الله بن أُبي بن سلول، <q>﴿ثم يرم به بريئا﴾</q> يعني به: عائشة أم المؤمنين حيث كذب عليها{2}. (ز) ٢٠١٢٤- عن عبد الله بن عباس -من طريق العوفي- قال: ثم قال: <q>﴿ومن يكسب خطيئة﴾</q> الآية، يعني: السارق، والذين جادلوا عن السارق{3}. (٤/٦٨٣) ٢٠١٢٥- عن محمود بن لبيد، قوله: <q>﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا﴾</q>، يعني: لبيد بن سهل، حين رماه بنو أبيرق بالسرقة{4}. (٤/٦٨٠) ٢٠١٢٦- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قوله: <q>﴿ثم يرم به بريئا﴾</q> يعني: زيد بن السمين <q>﴿فقد احتمل بهتانا﴾</q> طعمة بن أبيرق{5}. (٤/٦٨٧) ٢٠١٢٧- عن محمد بن سيرين -من طريق خالد الحذاء- <q>﴿ثم يرم به بريئا﴾</q>، قال: يهوديًّا{6}. (٤/٦٩٣) ٢٠١٢٨- عن الحسن البصري: <q>﴿ثم يرم به بريئا﴾</q> اليهودي{7}. (٤/٦٨٥) ٢٠١٢٩- عن عطية العوفي -من طريق فضيل بن مرزوق- <q>﴿فقد احتمل بهتانا﴾</q> قال: بهتانه: قذفه الرجل، <q>﴿وإثما مبينا﴾</q> قال: إثمه: سرقته{8}. (ز) ٢٠١٣٠- قال مقاتل بن سليمان: <q>﴿ومن يكسب﴾</q> لنفسه <q>﴿خطيئة أو إثما﴾</q> يعني: قذف البريء، <q>﴿ثم يرم به بريئا﴾</q> يعني: أنّه رمى به في دار أبي مليك الأنصاري؛ <q>﴿فقد احتمل بهتانا﴾</q> يعني: قَذْفه البريء بما لم يكن، <q>﴿وإثما مبينا﴾</q> يعني: بيِّنًا{9}. (ز) ٢٠١٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ومن يكسب خطيئة أو إثما ثم يرم به بريئا﴾</q> وإن كان مشركًا <q>﴿فقد احتمل بهتانا﴾</q>{10}١٨٤١. (٤/٦٨٤) ١٨٤١ ذكر ابنُ عطية (٣/٢١) أنّ بعض الناس ذهب إلى أن قوله: <q>﴿خطيئة أو إثما﴾</q> لفظان بمعنًى، كرر لاختلاف اللفظ. ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٠٦٣.تفسير الثعلبي ٣/٣٨٣.أخرجه ابن جرير ٧/٤٦٣-٤٦٤، وابن أبي حاتم ٤/١٠٥٩-١٠٦٣.عزاه السيوطي إلى ابن سعد.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.أخرجه ابن جرير ٧/٤٧٨، وابن أبي حاتم ٤/١٠٦٣. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٤/١٠٦٣-١٠٦٤.تفسير مقاتل بن سليمان ١/٤٠٦.أخرجه ابن جرير ٧/٤٦٤-٤٦٥.
4,113," <q>﴿وَلَوۡلَا فَضۡلُ ٱللَّهِ عَلَیۡكَ وَرَحۡمَتُهُۥ لَهَمَّت طَّاۤىِٕفَةࣱ مِّنۡهُمۡ أَن یُضِلُّوكَ وَمَا یُضِلُّونَ إِلَّاۤ أَنفُسَهُمۡۖ وَمَا یَضُرُّونَكَ مِن شَیۡءࣲۚ﴾</q> - تفسير ٢٠١٣٢- عن قتادة بن النعمان -من طريق عمر بن قتادة- <q>﴿ولولا فضل الله عليك ورحمته لهمت طائفة منهم أن يضلوك﴾</q>، يعني: أسير بن عروة، وأصحابه. إلى قوله: <q>﴿فسوف نؤتيه أجرا عظيما﴾</q>{1}. (٤/٦٧٧-٦٨٠) ٢٠١٣٣- قال عبد الله بن عباس -من طريق الضحاك- ثم قال: <q>﴿ولو فضل الله عليك ورحمته﴾</q> يعني به: الإسلام، والقرآن <q>﴿لهمت طائفة منهم﴾</q> يعني: من ثقيف <q>﴿أن يضلوك﴾</q> وذلك أنّ وفد ثقيف قدموا على رسول الله ﷺ، فقالوا: يا محمد، قد جئناك نبايعك على أن لا حشر، ولا بعث، ولا نكسر أصنامًا بأيدينا، على أن تُمَتِّعنا بالعُزّى سَنَة. فلم يجبهم إلى ذلك، وعصمه الله بمَنِّه، وأخبره بنعمته عليه أنه في حفظه وكلاءته، فلا يخلص إليه أمر يكرهه. فقال: <q>﴿وما يضلون إلا أنفسهم﴾</q> يعني: وفد ثقيف، <q>﴿وما يضرونك من شىء﴾</q> يعني: لا يستطيعون أن يزيلوا عنك النبوة وقد جعلك الله لها أهلًا{2}. (ز) ٢٠١٣٤- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قوله: <q>﴿ولولا فضل الله عليك ورحمته﴾</q> لمحمد ﷺ <q>﴿لهمت طائفة﴾</q> قوم طعمة{3}. (٤/٦٨٧) ٢٠١٣٥- عن الحسن البصري: ثم قال لنبيه ﷺ: <q>﴿ولولا فضل الله عليك ورحمته﴾</q> إلى قوله: <q>﴿وكان فضل الله عليك عظيما﴾</q>. فأُبْرِئَ اليهوديُّ، وأخبر بصاحب الدرع. قال: قد افتضحت الآن في المسلمين، وعلموا أني صاحب الدرع، ما لي إقامة ببلد. فتراغم، فلحق بالمشركين{4}. (٤/٦٨٥) ٢٠١٣٦- قال الحسن البصري: ثم قال لنبيه ﵇: <q>﴿ولولا فضل الله عليك ورحمته لهمت طائفة منهم أن يضلوك﴾</q> فيما أرادوا من النبي ﷺ أن يعذر عن صاحبهم، <q>﴿وما يضلون إلا أنفسهم﴾</q> أي: حين جاءوا إليك لتعذره، <q>﴿وما يضرونك﴾</q> ينقصونك من شيء{5}. (ز) ٢٠١٣٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثم ذكر الأنصار، وإتيانها إيّاه أن ينضح{6} عن صاحبهم، ويجادل عنه، فقال: <q>﴿لهمت طائفة منهم أن يضلوك وما يضلون إلا أنفسهم وما يضرونك من شيء﴾</q>{7}. (٤/٦٨٥) ٢٠١٣٨- قال مقاتل بن سليمان: ثم قال لنبيه ﷺ: <q>﴿ولولا فضل الله عليك ورحمته﴾</q> يعني: ونعمته بالقرآن حين بَيَّنَ لك أمر طعمة، فحوَّلك عن تصديق الخائنين بالقرآن؛ <q>﴿لهمت طائفة منهم أن يضلوك﴾</q> يقول: لكادت طائفة من قوم الخائنين أن يستنزلوك عن الحق، <q>﴿وما يضلون﴾</q> يعني: وما يَسْتَنزِلون <q>﴿إلا أنفسهم وما يضرونك من شيء﴾</q> يعني: وما ينقصونك من شيء ليس ذلك بأيديهم، إنما ينقصون أنفسهم{8}. (ز) <q>﴿وَأَنزَلَ ٱللَّهُ عَلَیۡكَ ٱلۡكِتَـٰبَ وَٱلۡحِكۡمَةَ﴾</q> - تفسير ٢٠١٣٩- قال عبد الله بن عباس -من طريق الضحاك- ثم قال: <q>﴿وأنزل الله عليك الكتاب والحكمة﴾</q>، يعني: الأحكام{2}. (ز) ٢٠١٤٠- قال مقاتل بن سليمان: ثم قال: <q>﴿وأنزل الله عليك الكتاب والحكمة﴾</q>، يعني: الحلال والحرام{8}١٨٤٢. (ز) ١٨٤٢ ذكر ابنُ القيم (١/٢٩٥-٢٩٦) أقوالًا للسلف في تفسير الحكمة، وبيَّن أنّ تفسيرها بالسُّنَّة أعمُّ وأشهر، ثم قال: «وأحسن ما قيل في الحكمة: معرفة الحق والعمل به، والإصابة في القول والعمل. وهذا قول مجاهد، ومالك». <q>﴿وَعَلَّمَكَ مَا لَمۡ تَكُن تَعۡلَمُۚ﴾</q> - تفسير ٢٠١٤١- قال عبد الله بن عباس -من طريق الضحاك- ثم قال: <q>﴿وعلمك ما لم تكن تعلم﴾</q> من الشرائع{2}. (ز) ٢٠١٤٢- عن الضحاك بن مزاحم -من طريق جويبر- قال: علمه الخير والشر{12}. (٤/٦٩٣) ٢٠١٤٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وعلمك ما لم تكن تعلم﴾</q>، قال: علَّمه الله بيان الدنيا والآخرة، بيَّن حلاله وحرامه ليحتج بذلك على خلقه{12}. (٤/٦٩٣) ٢٠١٤٤- قال مقاتل بن سليمان: <q>﴿وعلمك ما لم تكن تعلم﴾</q> من أمر الكتاب، وأمر الدين{8}. (ز) <q>﴿وَكَانَ فَضۡلُ ٱللَّهِ عَلَیۡكَ عَظِیمࣰا ۝١١٣﴾</q> - تفسير ٢٠١٤٥- قال عبد الله بن عباس -من طريق الكلبي عن أبي صالح- ثم قال: <q>﴿وكان فضل الله﴾</q> أي: مَنُّ الله <q>﴿عليك﴾</q> بالنبوة <q>﴿عظيما﴾</q>{2}. (ز) ٢٠١٤٦- قال مقاتل بن سليمان: <q>﴿وكان فضل الله عليك عظيما﴾</q>، يعني: النبوة، والكتاب{8}. (ز) ",footnotes:1:أخرجه الترمذي (٣٠٣٧)، وابن جرير ٧/٤٥٨-٤٦٢، وابن أبي حاتم ٤/١٠٥٩-١٠٦٠، والحاكم ٤/٣٨٥-٣٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٣/٣٨٣-٣٨٤.أخرجه ابن جرير ٧/٤٦٨-٤٦٩. وعزاه السيوطي إلى سنيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٠٥-.نضح عنه: ذبَّ ودفع، ونضح الرجل: رَدَّ عنه. لسان العرب (نضح).أخرجه ابن جرير ٧/٤٦٦-٤٦٧، وابن أبي حاتم ٤/١٠٦٤.تفسير مقاتل بن سليمان ١/٤٠٦.تفسير الثعلبي ٣/٣٨٣-٣٨٤.تفسير مقاتل بن سليمان ١/٤٠٦.تفسير الثعلبي ٣/٣٨٣-٣٨٤.أخرجه ابن أبي حاتم ٤/١٠٦٤.أخرجه ابن أبي حاتم ٤/١٠٦٤.تفسير مقاتل بن سليمان ١/٤٠٦.تفسير الثعلبي ٣/٣٨٣-٣٨٤.تفسير مقاتل بن سليمان ١/٤٠٦.
