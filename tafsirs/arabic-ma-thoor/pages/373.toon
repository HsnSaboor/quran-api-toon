quran[23]{c,v,t}:
  26,137,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنۡ هَـٰذَاۤ إِلَّا خُلُقُ ٱلۡأَوَّلِینَ ۝١٣٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق علقمة- أنّه كان يقرأ: ‹إنْ هَذَآ إلّا خَلْقُ الأَوَّلِينَ›...{1}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٦٥<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿إنْ هَذَآ إلّا خُلُقُ الأَوَّلِينَ﴾</span>، مرفوعة الخاء مُثَقَّلة{2}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٦٦<span class="dash">-</span></span> عن إسماعيل بن مسلم، قال: اختلفتُ أنا ومالك بن دينار في هذا الحرف، فقلت أنا: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span>. وقال مالك بن دينار: <span class="qpc-hafs">﴿خُلُقُ الأَوَّلِينَ﴾</span>{3}. فأتيت <span class="name-2">الحسن</span>، فسألته، فقال: ‹إنْ هَذَآ إلّا خَلْقُ الأَوَّلِينَ›، قال: خُلُقهم الكذب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٦٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إلّا خُلُقُ الأَوَّلِينَ﴾</span>، يعني: تخلق الأولين وتَخَرُّصهم للكذب{5}<span class=comment-ref>٤٨١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٥</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿خُلُق﴾</span>. <b>وقرأ آخرون</b>: ‹خَلْقُ›.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٧/٦١٤) أنّ قراءة الضم بمعنى: ما هذا الذي تفعله إلا عادة الأولين مِن قبلنا، وأن الثانية بمعنى: ما هذا الذي جئتنا به إلا كذب الأولين وأحاديثهم.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (١٠/٣٦٠)، و<span class="comment-type-4">كذا</span> <u>ابنُ عطية</u> (٦/٤٩٨-٤٩٩). و<span class="comment-type-4">زاد</span> <u>ابنُ عطية</u> أن قراءة الفتح والتسكين تحتمل أيضًا أن يريدوا: وما هذه البنية التي نحن عليها إلا البنية التي عليها الأولون، حياة وموت، وما ثَمَّ بعث ولا تعذيب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٦١٦-٦١٧ بتصرف) قراءة الضم <span class="mustanad">مستندًا إلى السياق،</span> والقول بأنّ الخلق: العادة؛ الذي قاله ابن عباس من طريق علي، وقتادة، وابن سلام، فقال: «وأولى القراءتين في ذلك بالصواب قراءة مَن قرأ: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span> بضم الخاء واللام ... لأنهم إنما عوتبوا على البنيان الذي كانوا يتخذونه، وبطشهم بالناس بطش الجبابرة، وقلة شكرهم ربهم فيما أنعم عليهم، فأجابوا نبيَّهم بأنهم يفعلون ما يفعلون من ذلك احتذاءً منهم سُنَّة مَن قبلهم مِن الأمم، واقتفاء منهم آثارهم، فقالوا: ما هذا الذي نفعله إلا خلق الأولين، يعنون بالخلق: عادة الأولين. ويزيد ذلك بيانًا وتصحيحًا لما اخترنا مِن القراءة والتأويل قولهم: <span class="qpc-hafs">﴿وما نحن بمعذبين﴾</span>؛ لأنهم لو كانوا لا يُقِرُّون بأنّ لهم ربًّا يقدر على تعذيبهم ما قالوا: <span class="qpc-hafs">﴿وما نحن بمعذبين﴾</span>، بل كانوا يقولون: إن هذا الذي جئتنا به -يا هود- إلا خلْق الأولين، وما لنا مِن معذب يعذبنا، ولكنهم كانوا مُقِرِّين بالصانع، ويعبدون الآلهة، على نحو ما كان مشركو العرب يعبدونها، ويقولون: إنها تُقَرِّبنا إلى الله زُلفى، فلذلك قالوا لهود وهم منكرون نبوته: <span class="qpc-hafs">﴿سواء علينا أوعظت أم لم تكن من الواعظين﴾</span>، ثم قالوا له: ما هذا الذي نفعله إلا عادة مَن قبلنا وأخلاقهم، وما الله مُعَذِّبنا عليه، كما أخبرنا -تعالى ذِكْرُه- عن الأمم الخالية قبلنا أنّهم كانوا يقولون لرسلهم: <span class="qpc-hafs">﴿إنا وجدنا آباءنا على أمة وإنا على آثارهم مقتدون﴾</span> [الزخرف:٢٣]».</div></p><p><h3><span class="qpc-hafs">﴿إِنۡ هَـٰذَاۤ إِلَّا خُلُقُ ٱلۡأَوَّلِینَ ۝١٣٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق علقمة- أنّه كان يقرأ: (إنْ هَذَآ إلّا خَلْقُ الأَوَّلِين). يقول: شيء اختلقوه. وفي لفظ: يقول: اختلاق الأولين{6}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span>، قال: دين الأولين{7}. (١١/٢٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span>، قال: أساطير الأولين{8}. (١١/٢٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧١<span class="dash">-</span></span> عن <span class="name-2">علقمة</span> -من طريق الشعبي- <span class="qpc-hafs">﴿إن هذا إلا خَلْق الأولين﴾</span>، قال: اختِلاقُهم{9}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إن هذا إلا خَلْقُ الأولين﴾</span>، قال: كذبهم{10}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٣<span class="dash">-</span></span> قال يحيى بن سلّام: <span class="qpc-hafs">﴿إن هذا﴾</span>، أي: الذي جئتنا به <span class="qpc-hafs">﴿إلا خلق الأولين﴾</span> في تفسير <span class="name-2">الحسن البصري</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span>، قال: قالوا: هكذا خُلِقت الأوَّلون، وهكذا كان الناس يعيشون ما عاشوا، ثم يموتون، ولا بعث عليهم ولا حساب{12}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق عثمان بن عطاء-: أمّا <span class="qpc-hafs">﴿خلق الأولين﴾</span> فأمْرُ الأولين{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثل ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن هذا إلا خلق الأولين﴾</span> يعني: ما هذا العذابُ الذى يقول هود إلا أحاديث الأولين، <span class="qpc-hafs">﴿وما نحن بمعذبين﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: ‹إنْ هَذَآ إلّا خَلْقُ الأَوَّلِينَ›، قال: إن هذا إلا أمر الأولين، وأساطير الأولين اكتتبها، فهي تملى عليه بكرة وأصيلًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يعنون: أنّ هكذا كان الخلق قبلنا، ونحن مثلهم. وبعضهم يقول: <span class="qpc-hafs">﴿خلق الأولين﴾</span> دين الأولين، يعنون: ما هم عليه مِن شِرك{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦١٦، والطبراني (٨٦٧٦). وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، ويعقوب، وأبو جعفر، والكسائي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿خُلُقُ﴾</span> بضم الخاء واللام. انظر: النشر ٢/٣٣٥، والإتحاف ص٤٢٣.|2:عزاه السيوطي إلى عبد بن حميد.|3:كذا في المطبوع بإثبات نفس القراءة لهما، ويظهر أن أحدهما قرأ كذلك، والآخر قرأ: ‹خَلْقُ الأَوَّلِينَ›.|4:أخرجه يحيى بن سلّام ٢/٥١٥.|5:علَّقه يحيى بن سلّام ٢/٥١٥.|6:أخرجه ابن جرير ١٧/٦١٦، والطبراني (٨٦٧٦). وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ١٧/٦١٤، وابن أبي حاتم ٩/٢٧٩٧. وعزاه السيوطي إلى ابن المنذر.|8:أخرجه ابن جرير ١٧/٦١٥، وابن أبي حاتم ٩/٢٧٩٧.|9:أخرجه ابن جرير ١٧/٦١٦، وابن أبي حاتم ٩/٢٧٩٧.|10:أخرجه ابن جرير ١٧/٦١٥، وابن أبي حاتم ٩/٢٧٩٧. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|11:تفسير يحيى بن سلّام ٢/٥١٥.|12:أخرجه يحيى بن سلّام ٢/٥١٥ من طريق سعيد، وعبد الرزاق ٢/٧٥، وابن جرير ١٧/٦١٥، وابن أبي حاتم ٩/٢٧٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|13:أخرجه ابن أبي حاتم ٩/٢٧٩٧.|14:علَّقه ابن أبي حاتم ٩/٢٧٩٧.|15:تفسير مقاتل بن سليمان ٣/٢٧٤.|16:أخرجه ابن جرير ١٧/٦١٥. وعلَّقه ابن أبي حاتم ٩/٢٧٩٧.|17:تفسير يحيى بن سلّام ٢/٥١٦.
  26,138,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا نَحۡنُ بِمُعَذَّبِینَ ۝١٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما نحن بمعذبين﴾</span>: أي: إنّما نحن مثل الأولين، نعيش كما عاشوا، ثم نموت، ولا حسابَ ولا عذابَ علينا ولا بعثَ{1}. (١١/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وما نحن بمعذبين﴾</span>، أي: لا نُبعَث، ولا نُعَذَّب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٧٩٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.|2:تفسير يحيى بن سلّام ٢/٥١٦.
  26,139,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَذَّبُوهُ فَأَهۡلَكۡنَـٰهُمۡۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٣٩ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكذبوه﴾</span> بالعذاب في الدنيا، <span class="qpc-hafs">﴿فأهلكناهم﴾</span> بالرِّيح، <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يقول: إنّ في هلاكهم بالريح لَعِبرةً لِمَن بعدهم مِن هذه الأمة، فيحذروا مثل عقوبتهم. ثم قال سبحانه: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> ولو كان أكثرهم مؤمنين لم يُعَذَّبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نِقمته مِن أعدائه حين أهلكهم بالريح، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين حين أنجاهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٤.
  26,140,"26:139"
  26,141,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ ثَمُودُ ٱلۡمُرۡسَلِینَ ۝١٤١ إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ صَـٰلِحٌ أَلَا تَتَّقُونَ ۝١٤٢ إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٤٣ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٤٤ وَمَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِیَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير-: أنّ صالحًا بُعِث مِن الحِجْرِ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذبت ثمود المرسلين﴾</span> يعني: صالحًا وحده، <span class="qpc-hafs">﴿إذ قال لهم أخوهم صالح﴾</span> في النسب، وليس بأخيهم في الدين: <span class="qpc-hafs">﴿ألا تتقون﴾</span> يعني: ألا تخشون الله ﷿، <span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span> فيما بينكم وبين الله ﷿، <span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span> فيما آمركم به، <span class="qpc-hafs">﴿ومآ أسألكم عليه﴾</span> يعني: على الإيمان <span class="qpc-hafs">﴿من أجر﴾</span> يعني: جُعْلًا، <span class="qpc-hafs">﴿إن أجري﴾</span> يعني: ما جزائي <span class="qpc-hafs">﴿إلا على رب العالمين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿كذبت ثمود المرسلين﴾</span> يعني: صالحًا، <span class="qpc-hafs">﴿إذ قال لهم أخوهم صالح﴾</span> أخوهم في النسب، وليس بأخيهم في الدين: <span class="qpc-hafs">﴿ألا تتقون﴾</span> الله، وهي مثل الأولى، يأمرهم أن يتقوا الله، <span class="qpc-hafs">﴿إني لكم رسول أمين﴾</span> على ما جئتكم به، <span class="qpc-hafs">﴿فاتقوا الله وأطيعون (١٠٨) وما أسألكم عليه من أجر إن أجري﴾</span> إن ثوابي <span class="qpc-hafs">﴿إلا على رب العالمين (١٤٥)﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠٠.|2:تفسير مقاتل بن سليمان ٣/٢٧٥.|3:تفسير يحيى بن سلّام ٢/٥١٦.
  26,142,"26:141"
  26,143,"26:141"
  26,144,"26:141"
  26,145,"26:141"
  26,146,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَتُتۡرَكُونَ فِی مَا هَـٰهُنَاۤ ءَامِنِینَ ۝١٤٦ فِی جَنَّـٰتࣲ وَعُیُونࣲ ۝١٤٧ وَزُرُوعࣲ وَنَخۡلࣲ طَلۡعُهَا هَضِیمࣱ ۝١٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٢٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: معشب{1}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: أينع وبلغ، فهو هضيم{2}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن أبي عمرو- في قوله: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: إذا رطب واسترخى{3}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿طلعها هضيم﴾</span>. قال: مُنضَمٌّ بعضُه إلى بعض. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول امرئ القيس:</p><p>دارٌ لبيضاء العوارضِ{5} طَفْلةٍ{6} مهضومة{7} الكَشْحَين{8} رَيّا المعصمِ؟{9}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿هضيم﴾</span>، قال: لطيف مادام في كُفُرّاه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٢<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرياحي</span>، في قوله: <span class="qpc-hafs">﴿هضيم﴾</span>: يتهشهش في الفم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء، عن ابن أبي نجيح- <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: يَتَهَشَّم تَهَشُّمًا{12}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مسلم بن خالد، عن ابن أبي نجيح- <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: الطلعة إذا مَسِسْتَها تناثرت{13}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٥<span class="dash">-</span></span> عن ابن جريج، قال: سمعتُ عبد الكريم يقول: سمعتُ <span class="name-2">مجاهدًا</span> يقول في قوله: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: حين تَطْلُعُ؛ يَقْبِض عليه فيَهْضِمُه. قال ابن جريج: قال <span class="name-2">مجاهد</span>: إذا مُسَّ تهشَّم وتفتَّت. قال: هو مِن الرُّطب هضيم؛ تقبض عليه فتهضمه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحم</span>، قال: الهضيم إذا بلغ البُسر في عذوقه، فعظُم، فذلك الهضم{15}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: {16} الطلع حين يتفرق ويخضر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- قال: الهضيم: الرَّطب اللين{18}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٢٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: هو الرَّخْوُ{19}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: ليس فيه نوى{20}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿طلعها هضيم﴾</span>، قال: لَيِّن{21}. (١١/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٢<span class="dash">-</span></span> عن أبي العلاء -من طريق أبي إسحاق- قال: <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: الهضيم: المذنب الرطب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٣<span class="dash">-</span></span> عن <span class="name-2">أبي ميسرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٤<span class="dash">-</span></span> ويزيد بن راشد= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٥<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٦<span class="dash">-</span></span> عن عمر بن إسماعيل الهمداني، قال: حدثني أبي، قال: سألتُ <span class="name-2">عاصم بن بهدلة</span> عن قول الله -جلَّ وعزَّ-: <span class="qpc-hafs">﴿نخل طلعها هضيم﴾</span>. قال: اللّين، ألا ترى قول الشاعر:</p><p>هضيم الحشا لَيِّنُهُ ...؟{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٧<span class="dash">-</span></span> قال <span class="name-2">محمد ابن شهاب الزهري</span>، <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: الهضيم: طلعها{25} اللطيف حين يطلع{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٨<span class="dash">-</span></span> عن <span class="name-3">يزيد بن أبي زياد</span>، <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: هو الرطب. وفي لفظ قال: المذَنَّبُ الذي قد رطب بعضه{27}. (١١/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٠٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مسلم الزنجي- قال: الهضيم: لطيف{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال صالح ﵇: <span class="qpc-hafs">﴿أتتركون في ما هاهنا﴾</span> من الخير <span class="qpc-hafs">﴿آمنين﴾</span> من الموت. ثم أخبر عن الخير، فقال سبحانه: <span class="qpc-hafs">﴿في جنات وعيون * وزروع ونخل طلعها هضيم﴾</span> يعني: طلعها متراكب بعضها على بعض مِن الكثرة{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١١<span class="dash">-</span></span> عن <span class="name-3">أبي صخر [حميد بن زياد الخراط]</span> -من طريق مفضل- <span class="qpc-hafs">﴿ونخل طلعها هضيم﴾</span>، قال: ما رأيت طلع النخل حين ينشقُّ عنه الكُمّ، فترى الطَّلع قد لصق بعضُه ببعض؛ فهو الهضيم!{3}<span class=comment-ref>٤٨١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٦</span> اختُلِف في معنى قوله <span class="qpc-hafs">﴿هضيم﴾</span> على أقوال: <b>الأول</b>: معناه: اليانع النضيج. <b>الثاني</b>: بل هو المتهشم المتفتت. <b>الثالث</b>: هو الرطب اللين. <b>الرابع</b>: هو الراكب بعضه بعضًا.</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (١٧/٦٢٠) بين الأقوال <span class="mustanad">مستندًا للغة</span>، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: الهضيم: هو المنكسر من لينه ورطوبته، وذلك من قولهم: هضم فلان حقه: إذا انتقصه وتحيّفه، فكذلك الهضم في الطلع، إنما هو التنقُّص منه مِن رطوبته ولينه؛ إما بمسِّ الأيدي، وإما بركوب بعضه بعضًا، وأصله»مفعول«صُرِف إلى»فعيل«».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٤٩٩-٥٠٠) القول الأخير الذي قاله الضحاك بقوله: «وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٥٦٣١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أتتركون في ما ههنا آمنين﴾</span> على الاستفهام، أي: لا تُتْرَكون فيه{31}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠١ بلفظ: معشبة. وعزاه السيوطي إلى ابن جرير، وابن المنذر.|2:أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم -كما في الإتقان ٢/٣٤-.|3:أخرجه ابن أبي حاتم ٩/٢٨٠١.|4:علَّقه ابن أبي حاتم ٩/٢٨٠١.|5:العوارض: الثنايا سُميت عَوارِضَ؛ لأَنها فِي عُرْضِ الفَم. اللسان (عرض).|6:طَفْلة: لينة ناعمة. اللسان (طفل).|7:مهضومة: خميصة البطن. التاج (هضم).|8:الكَشْح: ما بين الخاصِرة إلى الضِّلع الخلفي. اللسان (كشح).|9:أخرجه الطستي -كما في الإتقان ٢/٨٨-.|10:تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٤ مختصرًا. والكُفُرّى: -بالضم وتشديد الراء وفتح الفاء وضمها مقصور-: هو وعاء الطلع وقشره الأعلى. النهاية (كفر).|11:تفسير الثعلبي ٧/١٧٦.|12:أخرجه يحيى بن سلّام ٢/٥١٦ من طريق أبي يحيى وابن مجاهد، والفريابي -كما في التغليق ٤/٢٧٢، وفتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦١٩. وعزاه السيوطي إلى عبد بن حميد.|13:أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم ٩/٢٨٠١ واللفظ له. وعلَّقه يحيى بن سلّام ٢/٥١٦. وعزاه السيوطي إلى ابن المنذر.|14:أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم ٩/٢٨٠٢. وعلَّقه البخاري ٤/١٧٨٦ بلفظ: يتفتت إذا مُسَّ. وينظر: فتح الباري لابن حجر ٨/٤٩٧، وتغليق التعليق ٤/٢٧٢.|15:عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٧/٦٢٠ من طريق عبيد ولفظه: إذا كثر حمل النخلة، فركب بعضها بعضًا، حتى نقص بعضها بعضًا، فهو حينئذ هضيم، وكذا أخرجه إسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٨٠٢ من طريقه بنحوه. وعزاه السيوطي إلى عبد بن حميد.|16:أثبت في المصدر هنا: «بطلع» بالباء الموحدة التحتانية، ولعلها: يَطْلُع.|17:أخرجه ابن أبي حاتم ٩/٢٨٠١.|18:أخرجه ابن جرير ١٧/٦٢٠، وابن أبي حاتم ٩/٢٨٠١. وعزاه السيوطي إلى سعيد بن منصور.|19:علَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى ابن أبي حاتم.|20:أخرجه ابن أبي حاتم ٩/٢٨٠١. وعزاه السيوطي إلى ابن المنذر.|21:علَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد.|22:أخرجه ابن أبي حاتم ٩/٢٨٠١.|23:علَّقه ابن أبي حاتم ٩/٢٨٠١.|24:أخرجه ابن أبي الدنيا في كتاب الأشراف -موسوعة الإمام ابن أبي الدنيا ٨/٣١٣ (٤٥١)-.|25:أثبت في المصدر هنا: «الرحمن»، ولعلها: الرخو.|26:أخرجه ابن وهب في الجامع- تفسير القرآن ٢/١٠١ (١٩٨).|27:عزاه السيوطي إلى الفريابي، وعبد بن حميد.|28:أخرجه أبو جعفر الرملي في جزئه ص٥٧ (تفسير مسلم الزنجي). وعلَّقه يحيى بن سلّام ٢/٥١٧ وزاد: وهو الطلع ما لم ينشق.|29:تفسير مقاتل بن سليمان ٣/٢٧٥. وآخره في تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٤ عن مقاتل منسوبًا إليه دون تعيينه، بلفظ: قد ركب بعضه بعضًا حتى هضم بعضه بعضًا.|30:أخرجه ابن أبي حاتم ٩/٢٨٠١.|31:تفسير يحيى بن سلّام ٢/٥١٦.
  26,147,"26:146"
  26,148,"26:146"
  26,149,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتࣰا فَـٰرِهِینَ ۝١٤٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٣١٣<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿وتَنْحِتُونَ﴾</span> بكسر الحاء، <span class="qpc-hafs">﴿مِنَ الجِبالِ بُيُوتًا فارِهِينَ﴾</span> بالألف{1}. (١١/٢٨٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قوله: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا﴾</span>، قال: كانوا يَنقُبُون في الجبال البيوت{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَـٰرِهِینَ ۝١٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذقين{3}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: ‹فَرِهِينَ›، قال: أشِرِين. ويقال: كيِّسِين{4}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٧<span class="dash">-</span></span> عن إسماعيل بن أبي خالد، قال: سألتُ <span class="name-2">عبد الله بن شداد بن الهاد</span> عن قول الله -جلَّ ذِكْرُه-: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فارهين﴾</span>. قال: تتخَيَّرون بيوتًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣١٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد</span> -من طريق إسماعيل بن أبي خالد، وإسماعيل السُّدِّيّ- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: يتجبرون{6}<span class=comment-ref>٤٨١٧</span>. (١١/٢٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥٠٠) على قول ابن شداد بقوله: «وذهب عبد الله بن شداد إلى أنّه بمعنى: مستفرهين، أي: مبالغين في استحازة الفارِهِ مِن كل ما يصنعونه ويشتهونه».</div></p><p><div></p><p><p><span class="item-no">٥٦٣١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول: ‹فَرِهِينَ›، قال: شَرِهِين{7}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٠<span class="dash">-</span></span> عن <span class="name-2">شهر بن حوشب</span>، نحو ذلك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق طلحة اليامي-: أشِرِين، بَطِرين، مَرِحين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذِقين، كيِّسين{10}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: ناعمين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٤<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: مُتَجَبِّرين{12}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٥<span class="dash">-</span></span> قال <span class="name-2">عطية العوفي</span>: مُتَخَيِّرين لمواضع نحتِها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذِقين بنحتها{14}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٧<span class="dash">-</span></span> عن <span class="name-2">معاوية بن قرة</span>، <span class="qpc-hafs">﴿فارهين﴾</span>، قال: حاذقين{12}. (١١/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- ‹فَرِهِينَ›: تفسيرها: آمنين{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: ‹فَرِهِينَ›، قال: مُعجَبين بصُنْعِكم{17}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق الوليد، عن سعيد- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: آمنين{18}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣١<span class="dash">-</span></span> عن <span class="name-2">خُصَيْف بن عبد الرحمن</span>، قال: مُعجَبين{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: مُتجبرين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٣<span class="dash">-</span></span> عن هارون الأعور، قال: وزعم آخرُ عن <span class="name-2">منصور بن المعتمر</span>: <span class="qpc-hafs">﴿فارهين﴾</span> حاذقين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٤<span class="dash">-</span></span> قال <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق هارون الأعور-: مِن قِبَل الفراهة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فارهين﴾</span>، قال: مُعجَبين بصنعكم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٦<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>: حَذِقِين بصنعتها{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فارهين﴾</span>، يعني: حاذقين بنَحْتِها{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٣٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وتنحتون من الجبال بيوتا فرهين﴾</span>، قال: الفَرِهُ: القويّ{26}<span class=comment-ref>٤٨١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٨</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿فارهين﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿فارهين﴾</span>، <b>وقرأ آخرون</b>: ‹فَرِهِينَ›. و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٦٢٣) صحة كلتا القراءتين <span class="mustanad">مستندًا لشهرتهما واستفاضتهما</span>، فقال: «والصواب من القول في ذلك أن يُقال: إن قراءة مَن قرأها: <span class="qpc-hafs">﴿فارهين﴾</span> وقراءة مَن قرأ: ‹فَرِهِينَ› قراءتان معروفتان، مستفيضة القراءة بكل واحدة منهما في علماء القراء، فبأيتهما قرأ القارئ فمصيب». ثم <span class="comment-type-4">علَّق</span> (١٧/٦٢٤) بقوله: «ومعنى قراءة مَن قرأ: <span class="qpc-hafs">﴿فارهين﴾</span>: حاذقين بنحتها، متخيرين لمواضع نحتها، كيسين، مِن الفراهة. ومعنى قراءة من قرأ: ‹فَرِهِينَ›: مرِحين، أشرين. وقد يجوز أن يكون معنى فاره وفره واحدًا».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٠/٣٦٣) قول مَن قال: معناه: حاذقين. ومَن قال: معناه: شرهين أشرين. ثم بيَّن أنه لا منافاة بينهما، فقال: «ولا منافاة بينهما؛ فإنهم كانوا يتخذون تلك البيوت المنحوتة في الجبال أشرًا وبطرًا وعبثًا، مِن غير حاجة إلى سكناها، وكانوا حاذقين متقنين لنحتها ونقشها، كما هو المشاهد من حالهم لِمَن رأى منازلهم؛ ولهذا قال: <span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span> أي: أقبِلوا على عمل ما يعود نفعه عليكم في الدنيا والآخرة، من عبادة ربكم الذي خلقكم ورزقكم؛ لِتُوَحِّدوه، وتعبدوه، وتسبحوه بكرة وأصيلًا».</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>و<span class="qpc-hafs">﴿فارِهِينَ﴾</span> بالألف قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وابن عامر، وقرأ بقية العشرة: ‹فَرِهِينَ› بإسقاط الألف. انظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٣.|2:أخرجه ابن أبي حاتم ٩/٢٨٠٢.|3:أخرجه ابن جرير ١٧/٦٢١، وابن أبي حاتم ٩/٢٨٠٢. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ١٧/٦٢٢، وابن أبي حاتم ٩/٢٨٠٣.|5:أخرجه إسحاق البستي في تفسيره ص٥٣٦. وفي تفسير الثعلبي ٧/١٧٦ بلفظ: متخيرين لمواضع نحتها.|6:أخرجه ابن جرير ١٧/٦٢٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.|7:أخرجه ابن جرير ١٧/٦٢٣، وابن أبي حاتم ٩/٢٨٠٢. وعلَّقه يحيى بن سلّام ٢/٥١٧ وعقّب عليه بقوله: من قِبَل شَرَه النفس. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|8:علَّقه ابن أبي حاتم ٩/٢٨٠٢.|9:أخرجه إسحاق البستي في تفسيره ص٥٣٨.|10:أخرجه ابن جرير ١٧/٦٢٠، وإسحاق البستي في تفسيره ص٥٣٧، وابن أبي حاتم ٩/٢٨٠٣ من طريق جويبر. وعزاه السيوطي إلى عبد بن حميد.|11:تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.|12:عزاه السيوطي إلى عبد بن حميد.|13:تفسير الثعلبي ٧/١٧٦.|14:أخرجه ابن جرير ١٧/٦٢١، وابن أبي حاتم ٩/٢٨٠٢. وعزاه السيوطي إلى الفريابي.|15:عزاه السيوطي إلى عبد بن حميد.|16:أخرجه إسحاق البستي في تفسيره ص٥٣٦. وعلقه يحيى بن سلّام ٢/٥١٧.|17:أخرجه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦٢٣، وإسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٨٠٣ من طريق سعيد. وعلَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|18:أخرجه ابن أبي حاتم ٩/٢٨٠٣. وعزاه السيوطي إلى عبد بن حميد.|19:علَّقه ابن أبي حاتم ٩/٢٨٠٣.|20:تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.|21:أخرجه إسحاق البستي في تفسيره ص٥٣٨.|22:أخرجه إسحاق البستي في تفسيره ص٥٣٨.|23:أخرجه عبد الرزاق ٢/٧٥.|24:علَّقه يحيى بن سلّام ٢/٥١٧.|25:تفسير مقاتل بن سليمان ٣/٢٧٥.|26:أخرجه ابن جرير ١٧/٦٢٣.
  26,150,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٥٠ وَلَا تُطِیعُوۤا۟ أَمۡرَ ٱلۡمُسۡرِفِینَ ۝١٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span>، قال: المشركين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span>، قال: هم المشركون{2}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاتقوا الله وأطيعون﴾</span> فيما آمركم به مِن النصيحة، <span class="qpc-hafs">﴿ولا تطيعوا أمر المسرفين﴾</span> يعني: التسعة الذين عقروا الناقة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/١٢٥.|2:أخرجه عبد الرزاق ٢/٧٥، وابن أبي حاتم ٩/٢٨٠٣. وعلَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٢٧٥. وآخره في تفسير البغوي ٦/١٢٥ عن مقاتل منسوبًا إليه دون تعيينه.
  26,151,"26:150"
  26,152,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یُفۡسِدُونَ فِی ٱلۡأَرۡضِ وَلَا یُصۡلِحُونَ ۝١٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتهم، فقال: <span class="qpc-hafs">﴿الذين يفسدون في الأرض ولا يصلحون﴾</span>، يقول: الذين يعصون في الأرض، ولا يطيعون الله ﷿ فيما أمرهم به{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٥.
  26,153,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٥٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٤٣<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿إنَّمَآ أنتَ مِنَ المُسَحَّرِينَ﴾</span> مثقلة{1}. (١١/٢٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٥٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح- في قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>، قال: من المخلوقين{2}. (١١/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- في قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>، قال: من المخلوقين. ثم أنشد قول لبيد بن ربيعة:</p><p>فإن تسألينا فيم نحن فإننا عصافير مِن هذا الأنام المُسَحَّر{3}. (١١/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- في قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>، قال: من المخلوقين المُعَلَّلين بالطعام والشراب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>، قال: المسحورين{5}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٤٩<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿من المسحرين﴾</span>، قالا: مِن المخدوعين{6}. (١١/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٠<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span>: من المسحورين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>، قال: هم الساحرون{8}. (١١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عبد الرزاق، عن معمر- في قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>، قال: إنما أنت من المسحورين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٣<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span> مثقلة، وقال: المسحر: السوقة الذي ليس بملِك{10}. (١١/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٤<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>: المسحر: الذي ليس له شيء، ولا ملك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٥<span class="dash">-</span></span> قال يحيى بن سلّام: وبعضهم يقول: من المسحورين؛ من المخلوقين{12}<span class=comment-ref>٤٨١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨١٩</span> اختُلِف في معنى قوله: <span class="qpc-hafs">﴿إنما أنت من المسحرين﴾</span>؛ <b>فقال قوم</b>: من المسحورين. <b>وقال آخرون</b>: من المخلوقين.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٠٠) أنّ <b>القول الأول</b> مأخوذ من السِّحر، أي: قد سُحرت؛ فأنت لذلك مخبول، لا تنطق بقويم. <b>والثاني</b> مأخوذ من السَّحر، وهي الرئة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٦٢٥-٦٢٦) <span class="mustanad">مستندًا إلى اللغة</span> القولَ الثاني الذي قاله ابن عباس، فقال: «والصواب من القول في ذلك عندي القول الذي ذكرته عن ابن عباس، أنّ معناه: إنما أنت من المخلوقين الذين يُعَلَّلون بالطعام والشراب مثلنا، ولست ربًّا ولا ملَكًا فنطيعك، ونعلم أنّك صادق فيما تقول. والمسحَّر: المفعَّل من السحرة، وهو الذي له سحْرَة».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٦/٥٠٠) <span class="mustanad">مستندًا إلى السياق</span> القول الثاني، فقال: «وقيل: السَّحر: قصبة الرئة وما يتعلق بها من كبد وغيره، أي: أنت ابن آدم، لا يصح أن تكون رسولًا عن الله. وما بعده في الآية يُقَوِّي هذا التأويل».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٠/٣٦٤) القول الأول، فقال: «والأظهر في هذا قول مجاهد وقتادة: أنهم يقولون: إنما أنت في قولك هذا مسحور لا عقل لك». ولم يذكر مستندًا.</div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.|2:أخرجه ابن جرير ١٧/٦٢٦، والخطيب ١٠/٤٢٣، وابن عساكر ٢٣/٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا، وابن جرير ١٧/٦٢٦، والخطيب ١٠/٤٢٣، وابن عساكر ٢٣/٧١ من طرق. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.|5:أخرجه يحيى بن سلّام ٢/٥١٧ من طريق ابن مجاهد، والفريابي -كما في التغليق ٤/٢٧٣، وفتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦٢٥، وابن أبي حاتم ٩/٢٨٠٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|6:عزاه السيوطي إلى ابن الانباري في الوقف والابتداء.|7:علَّقه يحيى بن سلّام ٢/٥١٧.|8:أخرجه عبد الرزاق ٢/٧٥، وابن أبي حاتم ٩/٢٨٠٣-٢٨٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:أخرجه ابن جرير ١٧/٦٢٥. وعلَّقه ابن أبي حاتم ٩/٢٨٠٤. وفي المطبوع من تفسير عبد الرزاق: الساحرين، وكذا في ابن أبي حاتم كما في الأثر السابق، فلعل في أحدها تصحيفًا. وجاء في تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥: من المسحورين المخدوعين.|10:عزاه السيوطي إلى عبد بن حميد.|11:علَّقه يحيى بن سلّام ٢/٥١٧.|12:تفسير يحيى بن سلّام ٢/٥١٧.
  26,154,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَاۤ أَنتَ إِلَّا بَشَرࣱ مِّثۡلُنَا فَأۡتِ بِـَٔایَةٍ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: إنّ صالحًا بعثه اللهُ إلى قومه، فآمنوا به، ثمَّ إنّه لَمّا مات كفر قومه، ورجعوا عن الإسلام، فأحيا الله لهم صالحًا، وبعثه إليهم، فقال: أنا صالح. فقالوا: قد مات صالح، إن كنت صالحًا فأت بآية إن كنت من الصادقين. فبعث الله الناقة، فعقروها، وكفروا، فأُهلكوا، وعاقِرُها رجلٌ نَسّاجٌ يُقال له: قُدار بن سالف{1}. (١١/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٧<span class="dash">-</span></span> عن <span class="name-1">أبي الطفيل عامر بن واثلة</span> -من طريق عبد العزيز بن رفيع-: قالت ثمود لصالح: ائتنا بآية إن كنت من الصادقين. قال: فقال لهم صالح: اخرجوا إلى هضبة مِن الأرض. فخرجوا، فإذا هي تَمْخَض كما تَمْخَض الحامل، ثم إنّها تفجرت، فخرجت مِن وسطها الناقة، فقال لهم صالح: هذه ناقة الله لكم آية، فذروها تأكل في أرض الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما أنت إلا بشر مثلنا﴾</span> يقول: إنما أنت بشر مثلنا في المنزلة، ولا تفضلنا في شيء، لست بملك، ولا رسول، <span class="qpc-hafs">﴿فأت بآية إن كنت من الصادقين﴾</span> بأنّك رسول الله إلينا. فقال لهم صالح: إنّ الله ﷿ سيُخرِج لكم مِن هذه الصخرة ناقة وبْراء عشراء. يعني: حامل. قال <span class="name-3">مقاتل</span>: كانت الناقة من غير نسل، ثم انشقت عن الناقة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ما أنت إلا بشر مثلنا فأت بآية إن كنت من الصادقين﴾</span> بما جئتنا به. قالوا له: إن كنت صادقًا فأخرِج لنا من هذه الصخرة ناقة. وكانت صخرة يصبون عليها اللبن في سَنَتِهم، فدعا اللهَ، فتصدعت الصخرة، فخرجت منها ناقةٌ عُشَراء، فنتجت فَصِيلًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦٢٧، وابن أبي حاتم ٥/١٥١١. وعزاه السيوطي إلى ابن أبي الدنيا في كتاب من عاش بعد الموت.|2:أخرجه إسحاق البستي في تفسيره ص٥٣٨-٥٣٩، وابن أبي حاتم ٩/٢٨٠٤.|3:تفسير مقاتل بن سليمان ٣/٢٧٦.|4:تفسير يحيى بن سلّام ٢/٥١٧.
  26,155,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ هَـٰذِهِۦ نَاقَةࣱ لَّهَا شِرۡبࣱ وَلَكُمۡ شِرۡبُ یَوۡمࣲ مَّعۡلُومࣲ ۝١٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٦٠<span class="dash">-</span></span> عن أبي الزبير، عن جابر بن عبد الله، قال: لَمّا مرَّ رسول الله ﷺ بالحِجْر قال: «<b>لا تسألوا الآيات، وقد سألها قومُ صالح، فكانت تَرِدُ مِن هذا الفَجِّ، وتَصدر مِن هذا الفَجِّ، فعَتَوْا عن أمر ربهم، فعقروها، فكانت تشرب ماءَهم يومًا، ويشربون لبنها يومًا، فعقروها، فأخذتهم صيحةٌ أهمد الله ﷿ مَن تحت أديم السماء منهم إلا رجلًا واحدًا كان في حَرَم الله ﷿»</b>. قيل: مَن هو، يا رسول الله؟ قال: «<b>هو أبو رِغال، فلما خرج من الحرم أصابه ما أصاب قومه</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شهر بن حوشب- قال: إذا كان يومَها أصْدَرَتْهم{2} لبنًا ما شاءوا{3}. (١١/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿هذه ناقة لها شرب ولكم شرب يوم معلوم﴾</span>، قال: كانت إذا كان يوم شربها شربت ماءهم كله، فإذا كان يوم شربهم كان لأنفسهم ومواشيهم وأرضهم{4}. (١١/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٣<span class="dash">-</span></span> قال يحيى بن سلّام: عن سعيد، عن <span class="name-2">قتادة</span>، قال: كان إذا كان يوم شربها أضرَّت بمواشيهم وزروعهم، ولم تضر شفاههم، في قول <span class="name-2">الحسن</span>، وإذا كان يوم شربهم كان لأنفسهم، ولمواشيهم، وأرضهم، وكان <span class="name-2">قتادة</span> يقول: ما ذكروا لها لبنًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٤<span class="dash">-</span></span> عن <span class="name-2">أبي الخليل</span> -من طريق قتادة-: أنّها كانت تَرِد في شِعْبٍ قد رأيته، قال: قلت: كم هو؟ قال: سبعة وثلاثون ذراعًا، قد ذَرَعْتُه. قال: وكانت تصدر في شِعْب آخر. قال: قلت: كم هو؟ قال: علوه ونصف. وحدَّث: أنّها كانت إذا صدرت أثَّر في الجبل أضلاعها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٥<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق</span> -من طريق المسيب- قال: كانت ناقة صالح ﵇ يُوضَع لها الإناء، فتَدُرُّ فيه اللبَن{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> لهم صالح ﵇: <span class="qpc-hafs">﴿هذه ناقة﴾</span> اللهِ لكم آية بأنِّي رسول الله، <span class="qpc-hafs">﴿لها شرب ولكم شرب يوم معلوم﴾</span> وكان للناقة يوم، ولهم يوم، وإذا كان شرب يوم الناقة مِن المكان كانوا في لبن ما شاءوا، وليس لهم ماء، فإذا كان يومهم لم يكن للناقة ماء، وكان لأهل القرية ولمواشيهم يوم، ولها يوم آخر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال هذه ناقة لها شرب ولكم شرب يوم معلوم﴾</span>، كانت تشرب الماء يومًا، ويشربونه يومًا. وبعضهم يقول: كانوا يحلبونها يوم شربها، فإذا كان يوم شربهم كان اللبن للفصيل. قال: وبلغنا: أنّها كانت تأتي الماء من فَجٍّ، وترجع مِن فَجٍّ آخر، يضيق عليها الفجُّ الأولُ إذا شربت{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٢٢/٦٦ (١٤١٦٠)، وابن حبان ١٤/٧٧ (٦١٩٧)، والحاكم ٢/٣٥١ (٣٢٤٨)، ٢/٣٧١ (٣٣٠٤)، وعبد الرزاق ٢/٨٣ (٩١٥)، وابن جرير ١٠/٢٩٦، وابن أبي حاتم ٥/١٥١٦ (٨٦٨٦)، ٦/٢٠٥٠ (١٠٩٩٠)، ٩/٢٨٠٤ (١٥٨٦٦)، ٩/٢٨٠٦ (١٥٨٧٩).</p><p>قال البزار -كما في الكشف ٢/٣٥٦ (١٨٤٤)-: «لا نعلمه يروى هكذا إلا عن ابن خثيم». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «صحيح، على شرط البخاري ومسلم». وقال في الموضع الثاني: «صحيح». وقال ابن كثير في البداية ١/٣١٧: «وهذا الحديث على شرط مسلم، وليس هو في شيء من الكتب الستة». وقال فيها ٧/١٦٥: «إسناده صحيح، ولم يخرجوه». وقال الهيثمي في المجمع ٦/١٩٤ (١٠٣٢٦): «رواه البزّار، والطبراني في الأوسط، ويأتي لفظه في سورة هود، وأحمد بنحوه، ورجال أحمد رجال الصحيح». وقال الدميري في حياة الحيوان ٢/٤٥٦: «وروى أحمد والطبراني والبزار بإسناد صحيح». وقال الألباني في الضعيفة ٩/٣١٨ (٤٣٣٤): «ضعيف».|2:أصْدَرَتْهم: أعادَتْهم إلى أماكِنِهِم وقد ارْتَووا. اللسان (صدر).|3:أخرجه ابن أبي حاتم ٩/٢٨٠٤.|4:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:أخرجه يحيى بن سلّام ٢/٥١٨.|6:أخرجه ابن أبي حاتم ٩/٢٨٠٥.|7:تفسير مقاتل بن سليمان ٣/٢٨٣.|8:تفسير مقاتل بن سليمان ٣/٢٧٦.|9:تفسير يحيى بن سلّام ٢/٥١٧-٥١٨.
  26,156,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَمَسُّوهَا بِسُوۤءࣲ فَیَأۡخُذَكُمۡ عَذَابُ یَوۡمٍ عَظِیمࣲ ۝١٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿ولا تمسوها بسوء﴾</span>: لا تعقروها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٦٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله ﷿: <span class="qpc-hafs">﴿ولا تمسوها بسوء﴾</span>، يعني: بعَقْر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تمسوها بسواء﴾</span> يعني: ولا تعقروها، <span class="qpc-hafs">﴿فيأخذكم عذاب يوم عظيم﴾</span> في الدنيا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: مَكَثَتِ الناقةُ التي أخرج الله لهم معها سقبها{4} في أرض ثمود ترعى الشجر، وتشرب الماء، فقال لهم صالح: هذه ناقة الله لكم آية، فذروها تأكل في أرض الله، ولا تمسوها بسوء، فيأخذكم عذاب يوم عظيم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: لا تعقروها{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٦٢٨.|2:علَّقه يحيى بن سلّام ٢/٥١٨.|3:تفسير مقاتل بن سليمان ٣/٢٧٦.|4:سقبها: ولدها. لسان العرب (سقب).|5:أخرجه ابن أبي حاتم ٩/٢٨٠٥.|6:تفسير يحيى بن سلّام ٢/٥١٨.
  26,157,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَعَقَرُوهَا فَأَصۡبَحُوا۟ نَـٰدِمِینَ ۝١٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن زَمْعَة</span>، قال: سمعتُ النبي ﷺ، وذكر الذي عَقَر الناقة، قال: «<b>انتدب لها رجلٌ ذو عِزٍّ ومَنَعَةٍ في قومه، كأبي زمعة</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٧٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: وكان ذلك عن رِضًى منهم كلهم. فقال لهم صالح: <span class="qpc-hafs">﴿تمتعوا في داركم ثلاثة أيام﴾</span> [هود:٦٥]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فعقروها﴾</span> يوم الأربعاء، فماتت، <span class="qpc-hafs">﴿فأصبحوا نادمين﴾</span> على عَقْرِها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٣٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فعقروها فأصبحوا نادمين (١٥٧) فأخذهم العذاب﴾</span>: كان أول سبب عقرهم إيّاها أنّها كانت تَضُرُّ بمواشيهم وأرضهم، كانت مواشيهم لا تقر مع الناقة، كانت المواشي إذا رأتها هربت منها، فإذا كان الصيف صافت الناقة بظهر الوادي في برده وخصبه وطيبه، وهبطت مواشيهم إلى بطن الوادي في جدبه وحَرِّه، وإذا كان الشتاء شَتَت الناقة في بطن الوادي في دِفئه وخِصبه، وصعدت مواشيهم إلى ظهر الوادي في جدبه وبرده، حتى إذ أضرَّ ذلك بمواشيهم؛ الأمر الذي أراد الله بهم، فبينما قوم منهم يومًا جلوس يشربون الخمر ففَنِي الماءُ الذي يمزجون به، فبعثوا رجلًا ليأتيهم بالماء، وكان يوم شرب الناقة، فرجع إليهم بغير ماء، وقال: حالَتِ الناقةُ بيني وبين الماء. ثم بعثوا آخر، فقال مثل ذلك، فقال بعضهم لبعض: ما تنظرون؟! قد منعتنا الماء، ومنعت مواشينا الرعي، وأضرَّت بأرضنا. فانبعث أشقاها، فعقرها، فقتلها، فتذامروا بينهم، في تفسير سعيد عن <span class="name-2">قتادة،</span> وقالوا: عليكم الفصيل. وصعد الفصيل إلى القارة، والقارة: الجبل{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٤/١٤٨ (٣٣٧٧)، ٦/١٦٩ (٤٩٤٢)، ومسلم ٤/٢١٩١ (٢٨٥٥)، وابن جرير ٢٤/٤٤٨، وابن أبي حاتم ٥/١٥١٤ (٨٦٧٧)، ٩/٢٨٠٥ (١٥٨٧٥)، والثعلبي ١٠/٢١٤-٢١٥.|2:علَّقه يحيى بن سلّام ٢/٥١٩.|3:تفسير مقاتل بن سليمان ٣/٢٧٦.|4:تفسير يحيى بن سلّام ٢/٥١٨.
  26,158,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذَهُمُ ٱلۡعَذَابُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخذهم العذاب﴾</span> يوم السبت، مِن صيحة جبريل ﵇، فماتوا أجمعين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٦. وقد تقدم بسط القصة في سورة الأعراف.
  26,159,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٥٨ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يعني: في هلاكهم بالصيحة لعبرة لِمَن بعدهم مِن هذه الأمة، يُحَذِّر كفار مكة مثل عذابهم. ثم قال سبحانه: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> يعني: لو كان أكثرهم مؤمنين ما عُذِّبوا في الدنيا، <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نِقمته مِن أعدائه، <span class="qpc-hafs">﴿الرحيم﴾</span> بالمؤمنين. وعاد وثمود ابنا عم، ثمود بن عابر بن أرم بن سام بن نوح، وهود بن شالح{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٥٨ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٥٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٣٧٩<span class="dash">-</span></span> عن أبي إدريس الخَوْلانِيِّ، قال: سمعتُ <span class="name-1">أبا الدرداء</span> يقول: إنّ عادًا ملؤوا ما بين عدن إلى عمان خيلًا ورجالًا وسوامًا، فعصوا الله، فأهلكهم، فمَن يشتري تراثهم بنعلي هاتين؟! ألا إنّ ثمودًا ملؤوا ما بين الشجر والحجر خيلًا ورجالًا وسوامًا، عصوا الله، فأهلكهم، فمن يشتري مِنِّي تراثهم بنعلي هاتين؟ ثم يقول لنفسه: فلا أحد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٦.|2:أخرجه ابن أبي حاتم ٩/٢٨٠٧.