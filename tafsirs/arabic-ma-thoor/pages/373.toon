26,146," <q>﴿أَتُتۡرَكُونَ فِی مَا هَـٰهُنَاۤ ءَامِنِینَ ۝١٤٦ فِی جَنَّـٰتࣲ وَعُیُونࣲ ۝١٤٧ وَزُرُوعࣲ وَنَخۡلࣲ طَلۡعُهَا هَضِیمࣱ ۝١٤٨﴾</q> - تفسير ٥٦٢٨٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ونخل طلعها هضيم﴾</q>، قال: معشب{1}. (١١/٢٨٤) ٥٦٢٨٧- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿طلعها هضيم﴾</q>، قال: أينع وبلغ، فهو هضيم{2}. (١١/٢٨٤) ٥٦٢٨٨- عن عبد الله بن عباس -من طريق عمرو بن أبي عمرو- في قوله: <q>﴿ونخل طلعها هضيم﴾</q>، قال: إذا رطب واسترخى{3}. (١١/٢٨٤) ٥٦٢٨٩- عن أبي صالح [باذام]، نحو ذلك{4}. (ز) ٥٦٢٩٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿طلعها هضيم﴾</q>. قال: مُنضَمٌّ بعضُه إلى بعض. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول امرئ القيس: دارٌ لبيضاء العوارضِ{5} طَفْلةٍ{6} مهضومة{7} الكَشْحَين{8} رَيّا المعصمِ؟{9}. (١١/٢٨٤) ٥٦٢٩١- عن عبد الله بن عباس، في قوله: <q>﴿هضيم﴾</q>، قال: لطيف مادام في كُفُرّاه{10}. (ز) ٥٦٢٩٢- قال أبو العالية الرياحي، في قوله: <q>﴿هضيم﴾</q>: يتهشهش في الفم{11}. (ز) ٥٦٢٩٣- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- <q>﴿طلعها هضيم﴾</q>، قال: يَتَهَشَّم تَهَشُّمًا{12}. (١١/٢٨٥) ٥٦٢٩٤- عن مجاهد بن جبر -من طريق مسلم بن خالد، عن ابن أبي نجيح- <q>﴿طلعها هضيم﴾</q>، قال: الطلعة إذا مَسِسْتَها تناثرت{13}. (١١/٢٨٥) ٥٦٢٩٥- عن ابن جريج، قال: سمعتُ عبد الكريم يقول: سمعتُ مجاهدًا يقول في قوله: <q>﴿ونخل طلعها هضيم﴾</q>، قال: حين تَطْلُعُ؛ يَقْبِض عليه فيَهْضِمُه. قال ابن جريج: قال مجاهد: إذا مُسَّ تهشَّم وتفتَّت. قال: هو مِن الرُّطب هضيم؛ تقبض عليه فتهضمه{14}. (ز) ٥٦٢٩٦- عن الضَّحّاك بن مُزاحم، قال: الهضيم إذا بلغ البُسر في عذوقه، فعظُم، فذلك الهضم{15}. (١١/٢٨٥) ٥٦٢٩٧- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿ونخل طلعها هضيم﴾</q>، قال: {16} الطلع حين يتفرق ويخضر{3}. (ز) ٥٦٢٩٨- عن عكرمة مولى ابن عباس -من طريق سماك- قال: الهضيم: الرَّطب اللين{18}. (١١/٢٨٥) ٥٦٢٩٩- عن الحسن البصري، <q>﴿طلعها هضيم﴾</q>، قال: هو الرَّخْوُ{19}. (١١/٢٨٥) ٥٦٣٠٠- عن الحسن البصري -من طريق إسماعيل- <q>﴿طلعها هضيم﴾</q>، قال: ليس فيه نوى{20}. (١١/٢٨٥) ٥٦٣٠١- عن قتادة بن دعامة، <q>﴿طلعها هضيم﴾</q>، قال: لَيِّن{21}. (١١/٢٨٥) ٥٦٣٠٢- عن أبي العلاء -من طريق أبي إسحاق- قال: <q>﴿ونخل طلعها هضيم﴾</q>، قال: الهضيم: المذنب الرطب{3}. (ز) ٥٦٣٠٣- عن أبي ميسرة= (ز) ٥٦٣٠٤- ويزيد بن راشد= (ز) ٥٦٣٠٥- وسعيد بن جبير، نحو ذلك{4}. (ز) ٥٦٣٠٦- عن عمر بن إسماعيل الهمداني، قال: حدثني أبي، قال: سألتُ عاصم بن بهدلة عن قول الله -جلَّ وعزَّ-: <q>﴿نخل طلعها هضيم﴾</q>. قال: اللّين، ألا ترى قول الشاعر: هضيم الحشا لَيِّنُهُ ...؟{24}. (ز) ٥٦٣٠٧- قال محمد ابن شهاب الزهري، <q>﴿ونخل طلعها هضيم﴾</q>، قال: الهضيم: طلعها{25} اللطيف حين يطلع{26}. (ز) ٥٦٣٠٨- عن يزيد بن أبي زياد، <q>﴿ونخل طلعها هضيم﴾</q>، قال: هو الرطب. وفي لفظ قال: المذَنَّبُ الذي قد رطب بعضه{27}. (١١/٢٨٤) ٥٦٣٠٩- عن محمد بن السائب الكلبي -من طريق مسلم الزنجي- قال: الهضيم: لطيف{28}. (ز) ٥٦٣١٠- قال مقاتل بن سليمان: ثم قال صالح ﵇: <q>﴿أتتركون في ما هاهنا﴾</q> من الخير <q>﴿آمنين﴾</q> من الموت. ثم أخبر عن الخير، فقال سبحانه: <q>﴿في جنات وعيون * وزروع ونخل طلعها هضيم﴾</q> يعني: طلعها متراكب بعضها على بعض مِن الكثرة{29}. (ز) ٥٦٣١١- عن أبي صخر [حميد بن زياد الخراط] -من طريق مفضل- <q>﴿ونخل طلعها هضيم﴾</q>، قال: ما رأيت طلع النخل حين ينشقُّ عنه الكُمّ، فترى الطَّلع قد لصق بعضُه ببعض؛ فهو الهضيم!{3}٤٨١٦. (ز) ٤٨١٦ اختُلِف في معنى قوله <q>﴿هضيم﴾</q> على أقوال: الأول: معناه: اليانع النضيج. الثاني: بل هو المتهشم المتفتت. الثالث: هو الرطب اللين. الرابع: هو الراكب بعضه بعضًا. وجمع ابنُ جرير (١٧/٦٢٠) بين الأقوال مستندًا للغة، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: الهضيم: هو المنكسر من لينه ورطوبته، وذلك من قولهم: هضم فلان حقه: إذا انتقصه وتحيّفه، فكذلك الهضم في الطلع، إنما هو التنقُّص منه مِن رطوبته ولينه؛ إما بمسِّ الأيدي، وإما بركوب بعضه بعضًا، وأصله»مفعول«صُرِف إلى»فعيل«». وانتقد ابنُ عطية (٤٩٩-٥٠٠) القول الأخير الذي قاله الضحاك بقوله: «وهذا ضعيف». ٥٦٣١٢- قال يحيى بن سلّام: <q>﴿أتتركون في ما ههنا آمنين﴾</q> على الاستفهام، أي: لا تُتْرَكون فيه{31}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٠١ بلفظ: معشبة. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم -كما في الإتقان ٢/٣٤-.أخرجه ابن أبي حاتم ٩/٢٨٠١.علَّقه ابن أبي حاتم ٩/٢٨٠١.العوارض: الثنايا سُميت عَوارِضَ؛ لأَنها فِي عُرْضِ الفَم. اللسان (عرض).طَفْلة: لينة ناعمة. اللسان (طفل).مهضومة: خميصة البطن. التاج (هضم).الكَشْح: ما بين الخاصِرة إلى الضِّلع الخلفي. اللسان (كشح).أخرجه الطستي -كما في الإتقان ٢/٨٨-.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٤ مختصرًا. والكُفُرّى: -بالضم وتشديد الراء وفتح الفاء وضمها مقصور-: هو وعاء الطلع وقشره الأعلى. النهاية (كفر).تفسير الثعلبي ٧/١٧٦.أخرجه يحيى بن سلّام ٢/٥١٦ من طريق أبي يحيى وابن مجاهد، والفريابي -كما في التغليق ٤/٢٧٢، وفتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم ٩/٢٨٠١ واللفظ له. وعلَّقه يحيى بن سلّام ٢/٥١٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٦١٩، وابن أبي حاتم ٩/٢٨٠٢. وعلَّقه البخاري ٤/١٧٨٦ بلفظ: يتفتت إذا مُسَّ. وينظر: فتح الباري لابن حجر ٨/٤٩٧، وتغليق التعليق ٤/٢٧٢.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٧/٦٢٠ من طريق عبيد ولفظه: إذا كثر حمل النخلة، فركب بعضها بعضًا، حتى نقص بعضها بعضًا، فهو حينئذ هضيم، وكذا أخرجه إسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٨٠٢ من طريقه بنحوه. وعزاه السيوطي إلى عبد بن حميد.أثبت في المصدر هنا: «بطلع» بالباء الموحدة التحتانية، ولعلها: يَطْلُع.أخرجه ابن أبي حاتم ٩/٢٨٠١.أخرجه ابن جرير ١٧/٦٢٠، وابن أبي حاتم ٩/٢٨٠١. وعزاه السيوطي إلى سعيد بن منصور.علَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٩/٢٨٠١. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٠١.علَّقه ابن أبي حاتم ٩/٢٨٠١.أخرجه ابن أبي الدنيا في كتاب الأشراف -موسوعة الإمام ابن أبي الدنيا ٨/٣١٣ (٤٥١)-.أثبت في المصدر هنا: «الرحمن»، ولعلها: الرخو.أخرجه ابن وهب في الجامع- تفسير القرآن ٢/١٠١ (١٩٨).عزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه أبو جعفر الرملي في جزئه ص٥٧ (تفسير مسلم الزنجي). وعلَّقه يحيى بن سلّام ٢/٥١٧ وزاد: وهو الطلع ما لم ينشق.تفسير مقاتل بن سليمان ٣/٢٧٥. وآخره في تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٤ عن مقاتل منسوبًا إليه دون تعيينه، بلفظ: قد ركب بعضه بعضًا حتى هضم بعضه بعضًا.أخرجه ابن أبي حاتم ٩/٢٨٠١.تفسير يحيى بن سلّام ٢/٥١٦.
  26,147,""
  26,148,""
26,149," <q>﴿وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتࣰا فَـٰرِهِینَ ۝١٤٩﴾</q> - قراءات ٥٦٣١٣- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿وتَنْحِتُونَ﴾</q> بكسر الحاء، <q>﴿مِنَ الجِبالِ بُيُوتًا فارِهِينَ﴾</q> بالألف{1}. (١١/٢٨٦) <q>﴿وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُیُوتࣰا﴾</q> - تفسير ٥٦٣١٤- عن إسماعيل السُّدِّيّ، قوله: <q>﴿وتنحتون من الجبال بيوتا﴾</q>، قال: كانوا يَنقُبُون في الجبال البيوت{2}. (ز) <q>﴿فَـٰرِهِینَ ۝١٤٩﴾</q> - تفسير ٥٦٣١٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فارهين﴾</q>، قال: حاذقين{3}. (١١/٢٨٦) ٥٦٣١٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: ‹فَرِهِينَ›، قال: أشِرِين. ويقال: كيِّسِين{4}. (١١/٢٨٦) ٥٦٣١٧- عن إسماعيل بن أبي خالد، قال: سألتُ عبد الله بن شداد بن الهاد عن قول الله -جلَّ ذِكْرُه-: <q>﴿وتنحتون من الجبال بيوتا فارهين﴾</q>. قال: تتخَيَّرون بيوتًا{5}. (ز) ٥٦٣١٨- عن عبد الله بن شداد -من طريق إسماعيل بن أبي خالد، وإسماعيل السُّدِّيّ- في قوله: <q>﴿فارهين﴾</q>، قال: يتجبرون{6}٤٨١٧. (١١/٢٨٦) ٤٨١٧ علَّق ابنُ عطية (٦/٥٠٠) على قول ابن شداد بقوله: «وذهب عبد الله بن شداد إلى أنّه بمعنى: مستفرهين، أي: مبالغين في استحازة الفارِهِ مِن كل ما يصنعونه ويشتهونه». ٥٦٣١٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول: ‹فَرِهِينَ›، قال: شَرِهِين{7}. (١١/٢٨٦) ٥٦٣٢٠- عن شهر بن حوشب، نحو ذلك{8}. (ز) ٥٦٣٢١- عن مجاهد بن جبر -من طريق طلحة اليامي-: أشِرِين، بَطِرين، مَرِحين{9}. (ز) ٥٦٣٢٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فارهين﴾</q>، قال: حاذِقين، كيِّسين{10}. (١١/٢٨٦) ٥٦٣٢٣- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فارهين﴾</q>، قال: ناعمين{11}. (ز) ٥٦٣٢٤- عن عطية العوفي، في قوله: <q>﴿فارهين﴾</q>، قال: مُتَجَبِّرين{12}. (١١/٢٨٧) ٥٦٣٢٥- قال عطية العوفي: مُتَخَيِّرين لمواضع نحتِها{13}. (ز) ٥٦٣٢٦- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿فارهين﴾</q>، قال: حاذِقين بنحتها{14}. (١١/٢٨٦) ٥٦٣٢٧- عن معاوية بن قرة، <q>﴿فارهين﴾</q>، قال: حاذقين{12}. (١١/٢٨٦) ٥٦٣٢٨- عن الحسن البصري -من طريق عمرو- ‹فَرِهِينَ›: تفسيرها: آمنين{16}. (ز) ٥٦٣٢٩- عن قتادة بن دعامة -من طريق معمر- في قوله: ‹فَرِهِينَ›، قال: مُعجَبين بصُنْعِكم{17}. (١١/٢٨٧) ٥٦٣٣٠- عن قتادة بن دعامة -من طريق الوليد، عن سعيد- في قوله: <q>﴿فارهين﴾</q>، قال: آمنين{18}. (١١/٢٨٧) ٥٦٣٣١- عن خُصَيْف بن عبد الرحمن، قال: مُعجَبين{19}. (ز) ٥٦٣٣٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فارهين﴾</q>، قال: مُتجبرين{11}. (ز) ٥٦٣٣٣- عن هارون الأعور، قال: وزعم آخرُ عن منصور بن المعتمر: <q>﴿فارهين﴾</q> حاذقين{9}. (ز) ٥٦٣٣٤- قال سليمان بن مهران الأعمش -من طريق هارون الأعور-: مِن قِبَل الفراهة{9}. (ز) ٥٦٣٣٥- عن محمد بن السائب الكلبي -من طريق معمر- في قوله: <q>﴿فارهين﴾</q>، قال: مُعجَبين بصنعكم{23}. (ز) ٥٦٣٣٦- تفسير محمد بن السائب الكلبي: حَذِقِين بصنعتها{24}. (ز) ٥٦٣٣٧- قال مقاتل بن سليمان: <q>﴿وتنحتون من الجبال بيوتا فارهين﴾</q>، يعني: حاذقين بنَحْتِها{25}. (ز) ٥٦٣٣٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وتنحتون من الجبال بيوتا فرهين﴾</q>، قال: الفَرِهُ: القويّ{26}٤٨١٨. (ز) ٤٨١٨ اختُلِف في قراءة قوله: <q>﴿فارهين﴾</q>؛ فقرأ قوم: <q>﴿فارهين﴾</q>، وقرأ آخرون: ‹فَرِهِينَ›. ورجَّح ابنُ جرير (١٧/٦٢٣) صحة كلتا القراءتين مستندًا لشهرتهما واستفاضتهما، فقال: «والصواب من القول في ذلك أن يُقال: إن قراءة مَن قرأها: <q>﴿فارهين﴾</q> وقراءة مَن قرأ: ‹فَرِهِينَ› قراءتان معروفتان، مستفيضة القراءة بكل واحدة منهما في علماء القراء، فبأيتهما قرأ القارئ فمصيب». ثم علَّق (١٧/٦٢٤) بقوله: «ومعنى قراءة مَن قرأ: <q>﴿فارهين﴾</q>: حاذقين بنحتها، متخيرين لمواضع نحتها، كيسين، مِن الفراهة. ومعنى قراءة من قرأ: ‹فَرِهِينَ›: مرِحين، أشرين. وقد يجوز أن يكون معنى فاره وفره واحدًا». وذكر ابنُ كثير (١٠/٣٦٣) قول مَن قال: معناه: حاذقين. ومَن قال: معناه: شرهين أشرين. ثم بيَّن أنه لا منافاة بينهما، فقال: «ولا منافاة بينهما؛ فإنهم كانوا يتخذون تلك البيوت المنحوتة في الجبال أشرًا وبطرًا وعبثًا، مِن غير حاجة إلى سكناها، وكانوا حاذقين متقنين لنحتها ونقشها، كما هو المشاهد من حالهم لِمَن رأى منازلهم؛ ولهذا قال: <q>﴿فاتقوا الله وأطيعون﴾</q> أي: أقبِلوا على عمل ما يعود نفعه عليكم في الدنيا والآخرة، من عبادة ربكم الذي خلقكم ورزقكم؛ لِتُوَحِّدوه، وتعبدوه، وتسبحوه بكرة وأصيلًا». ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. و<q>﴿فارِهِينَ﴾</q> بالألف قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وابن عامر، وقرأ بقية العشرة: ‹فَرِهِينَ› بإسقاط الألف. انظر: النشر ٢/٣٣٦، والإتحاف ص٤٢٣.أخرجه ابن أبي حاتم ٩/٢٨٠٢.أخرجه ابن جرير ١٧/٦٢١، وابن أبي حاتم ٩/٢٨٠٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٦٢٢، وابن أبي حاتم ٩/٢٨٠٣.أخرجه إسحاق البستي في تفسيره ص٥٣٦. وفي تفسير الثعلبي ٧/١٧٦ بلفظ: متخيرين لمواضع نحتها.أخرجه ابن جرير ١٧/٦٢٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ١٧/٦٢٣، وابن أبي حاتم ٩/٢٨٠٢. وعلَّقه يحيى بن سلّام ٢/٥١٧ وعقّب عليه بقوله: من قِبَل شَرَه النفس. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.علَّقه ابن أبي حاتم ٩/٢٨٠٢.أخرجه إسحاق البستي في تفسيره ص٥٣٨.أخرجه ابن جرير ١٧/٦٢٠، وإسحاق البستي في تفسيره ص٥٣٧، وابن أبي حاتم ٩/٢٨٠٣ من طريق جويبر. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/١٧٦.أخرجه ابن جرير ١٧/٦٢١، وابن أبي حاتم ٩/٢٨٠٢. وعزاه السيوطي إلى الفريابي.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٥٣٦. وعلقه يحيى بن سلّام ٢/٥١٧.أخرجه عبد الرزاق ٢/٧٥، وابن جرير ١٧/٦٢٣، وإسحاق البستي في تفسيره ص٥٣٦، وابن أبي حاتم ٩/٢٨٠٣ من طريق سعيد. وعلَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٠٣. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٩/٢٨٠٣.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.أخرجه إسحاق البستي في تفسيره ص٥٣٨.أخرجه إسحاق البستي في تفسيره ص٥٣٨.أخرجه عبد الرزاق ٢/٧٥.علَّقه يحيى بن سلّام ٢/٥١٧.تفسير مقاتل بن سليمان ٣/٢٧٥.أخرجه ابن جرير ١٧/٦٢٣.
26,150," <q>﴿فَٱتَّقُوا۟ ٱللَّهَ وَأَطِیعُونِ ۝١٥٠ وَلَا تُطِیعُوۤا۟ أَمۡرَ ٱلۡمُسۡرِفِینَ ۝١٥١﴾</q> - تفسير ٥٦٣٣٩- عن عبد الله بن عباس، في قوله: <q>﴿ولا تطيعوا أمر المسرفين﴾</q>، قال: المشركين{1}. (ز) ٥٦٣٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تطيعوا أمر المسرفين﴾</q>، قال: هم المشركون{2}. (١١/٢٨٧) ٥٦٣٤١- قال مقاتل بن سليمان: <q>﴿فاتقوا الله وأطيعون﴾</q> فيما آمركم به مِن النصيحة، <q>﴿ولا تطيعوا أمر المسرفين﴾</q> يعني: التسعة الذين عقروا الناقة{3}. (ز) ",footnotes:1:تفسير البغوي ٦/١٢٥.أخرجه عبد الرزاق ٢/٧٥، وابن أبي حاتم ٩/٢٨٠٣. وعلَّقه يحيى بن سلّام ٢/٥١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٧٥. وآخره في تفسير البغوي ٦/١٢٥ عن مقاتل منسوبًا إليه دون تعيينه.
  26,151,""
26,152," <q>﴿ٱلَّذِینَ یُفۡسِدُونَ فِی ٱلۡأَرۡضِ وَلَا یُصۡلِحُونَ ۝١٥٢﴾</q> - تفسير ٥٦٣٤٢- قال مقاتل بن سليمان: ثم نعتهم، فقال: <q>﴿الذين يفسدون في الأرض ولا يصلحون﴾</q>، يقول: الذين يعصون في الأرض، ولا يطيعون الله ﷿ فيما أمرهم به{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٥.
26,153," <q>﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٥٣﴾</q> - قراءات ٥٦٣٤٣- عن عاصم بن أبي النجود أنه قرأ: <q>﴿إنَّمَآ أنتَ مِنَ المُسَحَّرِينَ﴾</q> مثقلة{1}. (١١/٢٨٨) <q>﴿قَالُوۤا۟ إِنَّمَاۤ أَنتَ مِنَ ٱلۡمُسَحَّرِینَ ۝١٥٣﴾</q> - تفسير الآية ٥٦٣٤٤- عن عبد الله بن عباس -من طريق أبي صالح- في قوله: <q>﴿إنما أنت من المسحرين﴾</q>، قال: من المخلوقين{2}. (١١/٢٨٨) ٥٦٣٤٥- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- في قوله: <q>﴿إنما أنت من المسحرين﴾</q>، قال: من المخلوقين. ثم أنشد قول لبيد بن ربيعة: فإن تسألينا فيم نحن فإننا عصافير مِن هذا الأنام المُسَحَّر{3}. (١١/٢٨٨) ٥٦٣٤٦- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- في قوله: <q>﴿إنما أنت من المسحرين﴾</q>، قال: من المخلوقين المُعَلَّلين بالطعام والشراب{4}. (ز) ٥٦٣٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنما أنت من المسحرين﴾</q>، قال: المسحورين{5}. (١١/٢٨٧) ٥٦٣٤٨- عن أبي صالح [باذام]= (ز) ٥٦٣٤٩- ومجاهد بن جبر، في قوله: <q>﴿من المسحرين﴾</q>، قالا: مِن المخدوعين{6}. (١١/٢٨٨) ٥٦٣٥٠- تفسير الحسن البصري، في قوله: <q>﴿قالوا إنما أنت من المسحرين﴾</q>: من المسحورين{7}. (ز) ٥٦٣٥١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿إنما أنت من المسحرين﴾</q>، قال: هم الساحرون{8}. (١١/٢٨٧) ٥٦٣٥٢- عن قتادة بن دعامة -من طريق عبد الرزاق، عن معمر- في قوله: <q>﴿إنما أنت من المسحرين﴾</q>، قال: إنما أنت من المسحورين{9}. (ز) ٥٦٣٥٣- عن عاصم بن أبي النجود أنه قرأ: <q>﴿إنما أنت من المسحرين﴾</q> مثقلة، وقال: المسحر: السوقة الذي ليس بملِك{10}. (١١/٢٨٨) ٥٦٣٥٤- تفسير محمد بن السائب الكلبي: المسحر: الذي ليس له شيء، ولا ملك{7}. (ز) ٥٦٣٥٥- قال يحيى بن سلّام: وبعضهم يقول: من المسحورين؛ من المخلوقين{12}٤٨١٩. (ز) ٤٨١٩ اختُلِف في معنى قوله: <q>﴿إنما أنت من المسحرين﴾</q>؛ فقال قوم: من المسحورين. وقال آخرون: من المخلوقين. وذكر ابنُ عطية (٦/٥٠٠) أنّ القول الأول مأخوذ من السِّحر، أي: قد سُحرت؛ فأنت لذلك مخبول، لا تنطق بقويم. والثاني مأخوذ من السَّحر، وهي الرئة. ورجَّح ابنُ جرير (١٧/٦٢٥-٦٢٦) مستندًا إلى اللغة القولَ الثاني الذي قاله ابن عباس، فقال: «والصواب من القول في ذلك عندي القول الذي ذكرته عن ابن عباس، أنّ معناه: إنما أنت من المخلوقين الذين يُعَلَّلون بالطعام والشراب مثلنا، ولست ربًّا ولا ملَكًا فنطيعك، ونعلم أنّك صادق فيما تقول. والمسحَّر: المفعَّل من السحرة، وهو الذي له سحْرَة». ورجَّح ابنُ عطية (٦/٥٠٠) مستندًا إلى السياق القول الثاني، فقال: «وقيل: السَّحر: قصبة الرئة وما يتعلق بها من كبد وغيره، أي: أنت ابن آدم، لا يصح أن تكون رسولًا عن الله. وما بعده في الآية يُقَوِّي هذا التأويل». ورجَّح ابنُ كثير (١٠/٣٦٤) القول الأول، فقال: «والأظهر في هذا قول مجاهد وقتادة: أنهم يقولون: إنما أنت في قولك هذا مسحور لا عقل لك». ولم يذكر مستندًا. ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.أخرجه ابن جرير ١٧/٦٢٦، والخطيب ١٠/٤٢٣، وابن عساكر ٢٣/٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا، وابن جرير ١٧/٦٢٦، والخطيب ١٠/٤٢٣، وابن عساكر ٢٣/٧١ من طرق. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥.أخرجه يحيى بن سلّام ٢/٥١٧ من طريق ابن مجاهد، والفريابي -كما في التغليق ٤/٢٧٣، وفتح الباري ٨/٤٩٧-، وابن جرير ١٧/٦٢٥، وابن أبي حاتم ٩/٢٨٠٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن الانباري في الوقف والابتداء.علَّقه يحيى بن سلّام ٢/٥١٧.أخرجه عبد الرزاق ٢/٧٥، وابن أبي حاتم ٩/٢٨٠٣-٢٨٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٦٢٥. وعلَّقه ابن أبي حاتم ٩/٢٨٠٤. وفي المطبوع من تفسير عبد الرزاق: الساحرين، وكذا في ابن أبي حاتم كما في الأثر السابق، فلعل في أحدها تصحيفًا. وجاء في تفسير الثعلبي ٧/١٧٦، وتفسير البغوي ٦/١٢٥: من المسحورين المخدوعين.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلّام ٢/٥١٧.تفسير يحيى بن سلّام ٢/٥١٧.
26,154," <q>﴿مَاۤ أَنتَ إِلَّا بَشَرࣱ مِّثۡلُنَا فَأۡتِ بِـَٔایَةٍ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٥٤﴾</q> - تفسير ٥٦٣٥٦- عن عبد الله بن عباس -من طريق عكرمة-: إنّ صالحًا بعثه اللهُ إلى قومه، فآمنوا به، ثمَّ إنّه لَمّا مات كفر قومه، ورجعوا عن الإسلام، فأحيا الله لهم صالحًا، وبعثه إليهم، فقال: أنا صالح. فقالوا: قد مات صالح، إن كنت صالحًا فأت بآية إن كنت من الصادقين. فبعث الله الناقة، فعقروها، وكفروا، فأُهلكوا، وعاقِرُها رجلٌ نَسّاجٌ يُقال له: قُدار بن سالف{1}. (١١/٢٨٨) ٥٦٣٥٧- عن أبي الطفيل عامر بن واثلة -من طريق عبد العزيز بن رفيع-: قالت ثمود لصالح: ائتنا بآية إن كنت من الصادقين. قال: فقال لهم صالح: اخرجوا إلى هضبة مِن الأرض. فخرجوا، فإذا هي تَمْخَض كما تَمْخَض الحامل، ثم إنّها تفجرت، فخرجت مِن وسطها الناقة، فقال لهم صالح: هذه ناقة الله لكم آية، فذروها تأكل في أرض الله{2}. (ز) ٥٦٣٥٨- قال مقاتل بن سليمان: <q>﴿ما أنت إلا بشر مثلنا﴾</q> يقول: إنما أنت بشر مثلنا في المنزلة، ولا تفضلنا في شيء، لست بملك، ولا رسول، <q>﴿فأت بآية إن كنت من الصادقين﴾</q> بأنّك رسول الله إلينا. فقال لهم صالح: إنّ الله ﷿ سيُخرِج لكم مِن هذه الصخرة ناقة وبْراء عشراء. يعني: حامل. قال مقاتل: كانت الناقة من غير نسل، ثم انشقت عن الناقة{3}. (ز) ٥٦٣٥٩- قال يحيى بن سلّام: <q>﴿ما أنت إلا بشر مثلنا فأت بآية إن كنت من الصادقين﴾</q> بما جئتنا به. قالوا له: إن كنت صادقًا فأخرِج لنا من هذه الصخرة ناقة. وكانت صخرة يصبون عليها اللبن في سَنَتِهم، فدعا اللهَ، فتصدعت الصخرة، فخرجت منها ناقةٌ عُشَراء، فنتجت فَصِيلًا{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٦٢٧، وابن أبي حاتم ٥/١٥١١. وعزاه السيوطي إلى ابن أبي الدنيا في كتاب من عاش بعد الموت.أخرجه إسحاق البستي في تفسيره ص٥٣٨-٥٣٩، وابن أبي حاتم ٩/٢٨٠٤.تفسير مقاتل بن سليمان ٣/٢٧٦.تفسير يحيى بن سلّام ٢/٥١٧.
26,155," <q>﴿قَالَ هَـٰذِهِۦ نَاقَةࣱ لَّهَا شِرۡبࣱ وَلَكُمۡ شِرۡبُ یَوۡمࣲ مَّعۡلُومࣲ ۝١٥٥﴾</q> - تفسير ٥٦٣٦٠- عن أبي الزبير، عن جابر بن عبد الله، قال: لَمّا مرَّ رسول الله ﷺ بالحِجْر قال: «لا تسألوا الآيات، وقد سألها قومُ صالح، فكانت تَرِدُ مِن هذا الفَجِّ، وتَصدر مِن هذا الفَجِّ، فعَتَوْا عن أمر ربهم، فعقروها، فكانت تشرب ماءَهم يومًا، ويشربون لبنها يومًا، فعقروها، فأخذتهم صيحةٌ أهمد الله ﷿ مَن تحت أديم السماء منهم إلا رجلًا واحدًا كان في حَرَم الله ﷿». قيل: مَن هو، يا رسول الله؟ قال: «هو أبو رِغال، فلما خرج من الحرم أصابه ما أصاب قومه»{1}. (ز) ٥٦٣٦١- عن عبد الله بن عباس -من طريق شهر بن حوشب- قال: إذا كان يومَها أصْدَرَتْهم{2} لبنًا ما شاءوا{3}. (١١/٢٨٩) ٥٦٣٦٢- عن قتادة بن دعامة، قال: <q>﴿هذه ناقة لها شرب ولكم شرب يوم معلوم﴾</q>، قال: كانت إذا كان يوم شربها شربت ماءهم كله، فإذا كان يوم شربهم كان لأنفسهم ومواشيهم وأرضهم{4}. (١١/٢٨٨) ٥٦٣٦٣- قال يحيى بن سلّام: عن سعيد، عن قتادة، قال: كان إذا كان يوم شربها أضرَّت بمواشيهم وزروعهم، ولم تضر شفاههم، في قول الحسن، وإذا كان يوم شربهم كان لأنفسهم، ولمواشيهم، وأرضهم، وكان قتادة يقول: ما ذكروا لها لبنًا{5}. (ز) ٥٦٣٦٤- عن أبي الخليل -من طريق قتادة-: أنّها كانت تَرِد في شِعْبٍ قد رأيته، قال: قلت: كم هو؟ قال: سبعة وثلاثون ذراعًا، قد ذَرَعْتُه. قال: وكانت تصدر في شِعْب آخر. قال: قلت: كم هو؟ قال: علوه ونصف. وحدَّث: أنّها كانت إذا صدرت أثَّر في الجبل أضلاعها{6}. (ز) ٥٦٣٦٥- عن أبي رَوْق -من طريق المسيب- قال: كانت ناقة صالح ﵇ يُوضَع لها الإناء، فتَدُرُّ فيه اللبَن{7}. (ز) ٥٦٣٦٦- قال مقاتل بن سليمان: <q>﴿قال﴾</q> لهم صالح ﵇: <q>﴿هذه ناقة﴾</q> اللهِ لكم آية بأنِّي رسول الله، <q>﴿لها شرب ولكم شرب يوم معلوم﴾</q> وكان للناقة يوم، ولهم يوم، وإذا كان شرب يوم الناقة مِن المكان كانوا في لبن ما شاءوا، وليس لهم ماء، فإذا كان يومهم لم يكن للناقة ماء، وكان لأهل القرية ولمواشيهم يوم، ولها يوم آخر{8}. (ز) ٥٦٣٦٧- قال يحيى بن سلّام: <q>﴿قال هذه ناقة لها شرب ولكم شرب يوم معلوم﴾</q>، كانت تشرب الماء يومًا، ويشربونه يومًا. وبعضهم يقول: كانوا يحلبونها يوم شربها، فإذا كان يوم شربهم كان اللبن للفصيل. قال: وبلغنا: أنّها كانت تأتي الماء من فَجٍّ، وترجع مِن فَجٍّ آخر، يضيق عليها الفجُّ الأولُ إذا شربت{9}. (ز) ",footnotes:1:أخرجه أحمد ٢٢/٦٦ (١٤١٦٠)، وابن حبان ١٤/٧٧ (٦١٩٧)، والحاكم ٢/٣٥١ (٣٢٤٨)، ٢/٣٧١ (٣٣٠٤)، وعبد الرزاق ٢/٨٣ (٩١٥)، وابن جرير ١٠/٢٩٦، وابن أبي حاتم ٥/١٥١٦ (٨٦٨٦)، ٦/٢٠٥٠ (١٠٩٩٠)، ٩/٢٨٠٤ (١٥٨٦٦)، ٩/٢٨٠٦ (١٥٨٧٩). قال البزار -كما في الكشف ٢/٣٥٦ (١٨٤٤)-: «لا نعلمه يروى هكذا إلا عن ابن خثيم». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «صحيح، على شرط البخاري ومسلم». وقال في الموضع الثاني: «صحيح». وقال ابن كثير في البداية ١/٣١٧: «وهذا الحديث على شرط مسلم، وليس هو في شيء من الكتب الستة». وقال فيها ٧/١٦٥: «إسناده صحيح، ولم يخرجوه». وقال الهيثمي في المجمع ٦/١٩٤ (١٠٣٢٦): «رواه البزّار، والطبراني في الأوسط، ويأتي لفظه في سورة هود، وأحمد بنحوه، ورجال أحمد رجال الصحيح». وقال الدميري في حياة الحيوان ٢/٤٥٦: «وروى أحمد والطبراني والبزار بإسناد صحيح». وقال الألباني في الضعيفة ٩/٣١٨ (٤٣٣٤): «ضعيف».أصْدَرَتْهم: أعادَتْهم إلى أماكِنِهِم وقد ارْتَووا. اللسان (صدر).أخرجه ابن أبي حاتم ٩/٢٨٠٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلّام ٢/٥١٨.أخرجه ابن أبي حاتم ٩/٢٨٠٥.تفسير مقاتل بن سليمان ٣/٢٨٣.تفسير مقاتل بن سليمان ٣/٢٧٦.تفسير يحيى بن سلّام ٢/٥١٧-٥١٨.
26,156," <q>﴿وَلَا تَمَسُّوهَا بِسُوۤءࣲ فَیَأۡخُذَكُمۡ عَذَابُ یَوۡمٍ عَظِیمࣲ ۝١٥٦﴾</q> - تفسير ٥٦٣٦٨- عن عبد الملك ابن جُرَيج -من طريق حجاج- في قوله: <q>﴿ولا تمسوها بسوء﴾</q>: لا تعقروها{1}. (ز) ٥٦٣٦٩- تفسير إسماعيل السُّدِّيّ: قوله ﷿: <q>﴿ولا تمسوها بسوء﴾</q>، يعني: بعَقْر{2}. (ز) ٥٦٣٧٠- قال مقاتل بن سليمان: <q>﴿ولا تمسوها بسواء﴾</q> يعني: ولا تعقروها، <q>﴿فيأخذكم عذاب يوم عظيم﴾</q> في الدنيا{3}. (ز) ٥٦٣٧١- عن محمد بن إسحاق -من طريق سلمة- قال: مَكَثَتِ الناقةُ التي أخرج الله لهم معها سقبها{4} في أرض ثمود ترعى الشجر، وتشرب الماء، فقال لهم صالح: هذه ناقة الله لكم آية، فذروها تأكل في أرض الله، ولا تمسوها بسوء، فيأخذكم عذاب يوم عظيم{5}. (ز) ٥٦٣٧٢- قال يحيى بن سلّام: لا تعقروها{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٦٢٨.علَّقه يحيى بن سلّام ٢/٥١٨.تفسير مقاتل بن سليمان ٣/٢٧٦.سقبها: ولدها. لسان العرب (سقب).أخرجه ابن أبي حاتم ٩/٢٨٠٥.تفسير يحيى بن سلّام ٢/٥١٨.
26,157," <q>﴿فَعَقَرُوهَا فَأَصۡبَحُوا۟ نَـٰدِمِینَ ۝١٥٧﴾</q> - تفسير ٥٦٣٧٣- عن عبد الله بن زَمْعَة، قال: سمعتُ النبي ﷺ، وذكر الذي عَقَر الناقة، قال: «انتدب لها رجلٌ ذو عِزٍّ ومَنَعَةٍ في قومه، كأبي زمعة»{1}. (ز) ٥٦٣٧٤- قال الحسن البصري: وكان ذلك عن رِضًى منهم كلهم. فقال لهم صالح: <q>﴿تمتعوا في داركم ثلاثة أيام﴾</q> [هود:٦٥]{2}. (ز) ٥٦٣٧٥- قال مقاتل بن سليمان: <q>﴿فعقروها﴾</q> يوم الأربعاء، فماتت، <q>﴿فأصبحوا نادمين﴾</q> على عَقْرِها{3}. (ز) ٥٦٣٧٦- قال يحيى بن سلّام، في قوله: <q>﴿فعقروها فأصبحوا نادمين (١٥٧) فأخذهم العذاب﴾</q>: كان أول سبب عقرهم إيّاها أنّها كانت تَضُرُّ بمواشيهم وأرضهم، كانت مواشيهم لا تقر مع الناقة، كانت المواشي إذا رأتها هربت منها، فإذا كان الصيف صافت الناقة بظهر الوادي في برده وخصبه وطيبه، وهبطت مواشيهم إلى بطن الوادي في جدبه وحَرِّه، وإذا كان الشتاء شَتَت الناقة في بطن الوادي في دِفئه وخِصبه، وصعدت مواشيهم إلى ظهر الوادي في جدبه وبرده، حتى إذ أضرَّ ذلك بمواشيهم؛ الأمر الذي أراد الله بهم، فبينما قوم منهم يومًا جلوس يشربون الخمر ففَنِي الماءُ الذي يمزجون به، فبعثوا رجلًا ليأتيهم بالماء، وكان يوم شرب الناقة، فرجع إليهم بغير ماء، وقال: حالَتِ الناقةُ بيني وبين الماء. ثم بعثوا آخر، فقال مثل ذلك، فقال بعضهم لبعض: ما تنظرون؟! قد منعتنا الماء، ومنعت مواشينا الرعي، وأضرَّت بأرضنا. فانبعث أشقاها، فعقرها، فقتلها، فتذامروا بينهم، في تفسير سعيد عن قتادة، وقالوا: عليكم الفصيل. وصعد الفصيل إلى القارة، والقارة: الجبل{4}. (ز) ",footnotes:1:أخرجه البخاري ٤/١٤٨ (٣٣٧٧)، ٦/١٦٩ (٤٩٤٢)، ومسلم ٤/٢١٩١ (٢٨٥٥)، وابن جرير ٢٤/٤٤٨، وابن أبي حاتم ٥/١٥١٤ (٨٦٧٧)، ٩/٢٨٠٥ (١٥٨٧٥)، والثعلبي ١٠/٢١٤-٢١٥.علَّقه يحيى بن سلّام ٢/٥١٩.تفسير مقاتل بن سليمان ٣/٢٧٦.تفسير يحيى بن سلّام ٢/٥١٨.
26,158," <q>﴿فَأَخَذَهُمُ ٱلۡعَذَابُۚ﴾</q> - تفسير ٥٦٣٧٧- قال مقاتل بن سليمان: <q>﴿فأخذهم العذاب﴾</q> يوم السبت، مِن صيحة جبريل ﵇، فماتوا أجمعين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٦. وقد تقدم بسط القصة في سورة الأعراف.
26,159," <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٥٨ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٥٩﴾</q> - تفسير ٥٦٣٧٨- قال مقاتل بن سليمان: <q>﴿إن في ذلك لآية﴾</q> يعني: في هلاكهم بالصيحة لعبرة لِمَن بعدهم مِن هذه الأمة، يُحَذِّر كفار مكة مثل عذابهم. ثم قال سبحانه: <q>﴿وما كان أكثرهم مؤمنين﴾</q> يعني: لو كان أكثرهم مؤمنين ما عُذِّبوا في الدنيا، <q>﴿وإن ربك لهو العزيز﴾</q> في نِقمته مِن أعدائه، <q>﴿الرحيم﴾</q> بالمؤمنين. وعاد وثمود ابنا عم، ثمود بن عابر بن أرم بن سام بن نوح، وهود بن شالح{1}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝١٥٨ وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝١٥٩﴾</q> - آثار متعلقة بالآية ٥٦٣٧٩- عن أبي إدريس الخَوْلانِيِّ، قال: سمعتُ أبا الدرداء يقول: إنّ عادًا ملؤوا ما بين عدن إلى عمان خيلًا ورجالًا وسوامًا، فعصوا الله، فأهلكهم، فمَن يشتري تراثهم بنعلي هاتين؟! ألا إنّ ثمودًا ملؤوا ما بين الشجر والحجر خيلًا ورجالًا وسوامًا، عصوا الله، فأهلكهم، فمن يشتري مِنِّي تراثهم بنعلي هاتين؟ ثم يقول لنفسه: فلا أحد{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٧٦.أخرجه ابن أبي حاتم ٩/٢٨٠٧.
