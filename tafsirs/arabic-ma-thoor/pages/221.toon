quran[8]{c,v,t}:
  10,107,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یَمۡسَسۡكَ ٱللَّهُ بِضُرࣲّ فَلَا كَاشِفَ لَهُۥۤ إِلَّا هُوَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٩٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ يَمْسَسْكَ اللَّهُ بِضُرٍّ﴾</span> يعنى: بمرض <span class="qpc-hafs">﴿فَلا كاشِفَ لَهُ﴾</span> لذلك الضُّرِّ <span class="qpc-hafs">﴿إلّا هُوَ﴾</span> يعني: الرَّبّ نفسه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یُرِدۡكَ بِخَیۡرࣲ فَلَا رَاۤدَّ لِفَضۡلِهِۦۚ یُصِیبُ بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۚ وَهُوَ ٱلۡغَفُورُ ٱلرَّحِیمُ ۝١٠٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٩٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وإن يُردك بخيرٍ﴾</span>، يقول: بعافيةٍ{2}. (٧/٧١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ يُرِدْكَ بِخَيْرٍ﴾</span> بعافية وفضل <span class="qpc-hafs">﴿فَلا رادَّ لِفَضْلِهِ﴾</span> يعني: فلا دافع لقضائه، <span class="qpc-hafs">﴿يُصِيبُ بِهِ﴾</span> بذلك الفضل <span class="qpc-hafs">﴿مَن يَشاءُ مِن عِبادِهِ وهُوَ الغَفُورُ الرَّحِيمُ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یُرِدۡكَ بِخَیۡرࣲ فَلَا رَاۤدَّ لِفَضۡلِهِۦۚ یُصِیبُ بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۚ وَهُوَ ٱلۡغَفُورُ ٱلرَّحِیمُ ۝١٠٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٩٩٢<span class="dash">-</span></span> عن أنسٍ، أنّ رسول الله ﷺ قال: «<b>اطلُبوا الخيرَ دهرَكم، وتعرَّضوا لنَفَحات رحمةِ الله، فإنّ لله نفحاتٍ مِن رحمته يُصِيب بها مَن يشاء مِن عباده، وسَلُوه أن يستُر عوْراتِكم، ويُؤَمِّن مِن روعاتِكم</b>»{4}. (٧/٧١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩٩٣<span class="dash">-</span></span> عن <span class="name-1">أبي الدَّرداءِ</span> موقوفًا، مِثلَه سواء{5}. (٧/٧١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩٩٤<span class="dash">-</span></span> عن <span class="name-2">عامر بن قيس</span>، قال: ثلاثُ آياتٍ في كتاب الله اكتفيتُ بِهِنَّ عن جميع الخلائق؛ أوَّلُهن: <span class="qpc-hafs">﴿وإن يمسسك الله بضرٍّ فلا كاشف له إلا هو وإن يردك بخير فلا راد لفضله﴾</span>، والثانيةُ: <span class="qpc-hafs">﴿ما يفتح اللهُ للناس من رحمةٍ فلا ممسك لها وما يُمسك فلا مرسل له من بعدهِ﴾</span> [فاطر:٢]. والثالثةُ: <span class="qpc-hafs">﴿وما من دابةٍ في الأرض إلّا على الله رزقها﴾</span> [هود:٦]{6}. (٧/٧١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: ثلاثُ آياتٍ وجدتُها في كتاب الله تعالى اكتفيتُ بها عن جميع الخلائق؛ قوله: <span class="qpc-hafs">﴿وإن يمسسك الله بضرٍ فلا كاشف له إلا هُوَ وإن يردك بخيرٍ فلا رادَّ لفضله﴾</span>{2}. (٧/٧١٢)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٥١.|2:عزاه السيوطي إلى أبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٢٥١.|4:أخرجه أبو نعيم في الحلية ٣/١٦٢، والبيهقي في شعب الإيمان (١١٢١)، وابن عساكر ٢٤/١٢٣.</p><p>ضعفه المصنف في الجامع الصغير. ينظر: فيض القدير ١/٥٤.|5:أخرجه أبو نعيم في الحلية ٣/١٦٢، والطبراني في الكبير ١/٢٥٠ (٧٢٠).</p><p>قال البغوي في شرح السنة ٥/١٧٩ (١٣٧٨): «هذا حديث غريب». وقال الألباني في الضعيفة ٦/٣١٣ (٢٧٩٨): «ضعيف».|6:أخرجه البيهقي في شعب الإيمان (١٣٢٦).|7:عزاه السيوطي إلى أبي الشيخ.
  10,108,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ یَـٰۤأَیُّهَا ٱلنَّاسُ قَدۡ جَاۤءَكُمُ ٱلۡحَقُّ مِن رَّبِّكُمۡۖ فَمَنِ ٱهۡتَدَىٰ فَإِنَّمَا یَهۡتَدِی لِنَفۡسِهِۦۖ وَمَن ضَلَّ فَإِنَّمَا یَضِلُّ عَلَیۡهَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٩٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿قد جاءكُمُ الحقُّ من رَّبكم﴾</span>، وقوله: <span class="qpc-hafs">﴿وإن يمسسك اللهُ بضرٍ فلا كاشف له إلا هُوَ وإن يردكَ بخيرٍ فلا رادَّ لفضلهِ﴾</span>: هو الحق{1}. (٧/٧١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ يا أيُّها النّاسُ قَدْ جاءَكُمُ الحَقُّ مِن رَبِّكُمْ﴾</span> يعني: القرآن، <span class="qpc-hafs">﴿فَمَنِ اهْتَدى فَإنَّما يَهْتَدِي لِنَفْسِهِ ومَن ضَلَّ﴾</span> عن إيمان بالقرآن <span class="qpc-hafs">﴿فَإنَّما يَضِلُّ عَلَيْها﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩٩٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبد الله بن إدريس- <span class="qpc-hafs">﴿الحق من ربكم﴾</span>، قال: ما جاءك من الخير{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنَا۠ عَلَیۡكُم بِوَكِیلࣲ ۝١٠٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٩٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿عليكم بوكيل﴾</span>، أمّا الوكيل: فالحفيظ{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنَا۠ عَلَیۡكُم بِوَكِیلࣲ ۝١٠٨﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وما أنا عَلَيْكُمْ بِوَكِيلٍ﴾</span>، نَسَخَتْها آيةُ القِتال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنا عَلَيْكُمْ بِوَكِيلٍ﴾</span>، نَسَخَتْها آيةُ السيف{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٩٢. وعزاه السيوطي إلى أبي الشيخ.|2:تفسير مقاتل بن سليمان ٢/٢٥١-٢٥٢.|3:أخرجه ابن أبي حاتم ٦/١٩٩٢.|4:أخرجه ابن أبي حاتم ٦/١٩٩٣.|5:تفسير البغوي ٤/١٥٥.|6:تفسير مقاتل بن سليمان ٢/٢٥١-٢٥٢.
  10,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱتَّبِعۡ مَا یُوحَىٰۤ إِلَیۡكَ وَٱصۡبِرۡ حَتَّىٰ یَحۡكُمَ ٱللَّهُۚ وَهُوَ خَیۡرُ ٱلۡحَـٰكِمِینَ ۝١٠٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٠٢<span class="dash">-</span></span> قال <span class="name-1">أنس</span>: لَمّا نَزَلَت هذه الآيةُ جَمَع رسولُ الله ﷺ الأنصارَ ولم يجمع غيرهم، فقال: «<b>إنّكم ستجدون بعدي أثَرَةً، فاصْبِرُوا حتى تَلْقَوْنِي</b>». قال أنس: فلم نصبر. فأمرهم بالصبر كما أمره الله به{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبِعۡ مَا یُوحَىٰۤ إِلَیۡكَ وَٱصۡبِرۡ حَتَّىٰ یَحۡكُمَ ٱللَّهُۚ وَهُوَ خَیۡرُ ٱلۡحَـٰكِمِینَ ۝١٠٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتَّبِعْ ما يُوحى إلَيْكَ﴾</span> يعني: الحلال والحرام، ثم أوْعَزَ إلى نبيِّه ﵇ ليصبر على تكذيبهم إيّاه وعلى الأذى، فقال: <span class="qpc-hafs">﴿واصْبِرْ﴾</span> يا محمد على الأذى <span class="qpc-hafs">﴿حَتّى يَحْكُمَ اللَّهُ وهُوَ خَيْرُ الحاكِمِينَ﴾</span> فحكم الله عليها بالسَّيْفِ فقتلهم ببَدْر، وعجّل الله أرواحَهم إلى النار{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبِعۡ مَا یُوحَىٰۤ إِلَیۡكَ وَٱصۡبِرۡ حَتَّىٰ یَحۡكُمَ ٱللَّهُۚ وَهُوَ خَیۡرُ ٱلۡحَـٰكِمِینَ ۝١٠٩﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى يَحْكُمَ اللَّهُ وهُوَ خَيْرُ الحاكِمِينَ﴾</span>، فحكم الله عليها بالسَّيف، فقتلهم ببدر، وعجّل الله أرواحهم إلى النار، فصارت منسوخة، نَسَخَتْها آيةُ السيف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿واصبر حتى يحكم اللهُ﴾</span>، قال: هذا منسوخٌ، أمره بجهادهم والغِلْظَة عليهم{4}<span class=comment-ref>٣١٦٨</span>. (٧/٧١٣)</p></p><p></div></p><p><div><span class=comment-ref>٣١٦٨</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (١٢/٣٠٦) إلى أنّ هذا الصبر منسوخ بالقتال <span class="mustanad">مستندًا لقولِ عبد الرحمن بن زيد بن أسلم</span>.</p><p>و<span class="comment-type-4">كذا</span> قال <u>ابنُ عطية</u> (٤/٥٣٥).</div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٥٥.وأصله في البخاري(٤٣٣١) مطولًا دون ذكر نزول الآية.|2:تفسير مقاتل بن سليمان ٢/٢٥٢.|3:تفسير مقاتل بن سليمان ٢/٢٥٢.|4:أخرجه ابن جرير ١٢/٣٠٦، وابن أبي حاتم ٦/١٩٩٣، والناسخ والمنسوخ للنحاس ٢/٤٧١.
  11,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٠٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت سورة هود بمكة{1}. (٨/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٠٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مكية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٠٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد يونس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٠٩<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: نزلت سورة هود بمكة{4}. (٨/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٠<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١١<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٢<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٣<span class="dash">-</span></span> عن محمد ابن شهاب الزهري: مكية، ونزلت بعد يونس{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٤<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٥<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة هود مكية كلها، غير هذه الآيات الثلاث، فإنّهن نَزَلْنَ بالمدينة: فالأولى قوله تعالى: <span class="qpc-hafs">﴿فَلَعَلَّكَ تارِكٌ بَعْضَ ما يُوحى إلَيْكَ﴾</span> [١٢]، وقوله تعالى: <span class="qpc-hafs">﴿أُولئِكَ يُؤْمِنُونَ بِهِ﴾</span> [١٧] نزلت في ابن سلام وأصحابه، وقوله: <span class="qpc-hafs">﴿إنَّ الحَسَناتِ يُذْهِبْنَ السَّيِّئاتِ﴾</span> [١١٤] نزلت في رهبان النصارى. والله أعلم. وهي مائة وثلاث وعشرون آية{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال أبو بكر: يا رسول الله، قد شِبْتَ. قال: «<b>شَيَّبَتْنِي هود، والواقعة، والمرسلات، وعمَّ يتساءلون، وإذا الشمس كُوِّرَت</b>»{10}. (٨/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٧<span class="dash">-</span></span> عن عليٍّ، عن رسول الله ﷺ أنّه قال: «<b>لا يحفظُ منافِقٌ سورة هود، وبراءة، ويس، والدخان، وعم يتساءلون</b>»{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠١٨<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>مَن سَرَّهُ أن يَنظُرَ إلى يوم القيامة كَأَنَّهُ رَأْيُ عَيْنٍ فلْيَقْرَأْ: إذا الشَّمْسُ كُوِّرَتْ، وإذا السَّماءُ انفَطَرَتْ، وإذا السَّماءُ انشَقَّتْ</b>». وأحسب أنه قال: «<b>سورة هود</b>»{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿الۤرۚ كِتَـٰبٌ أُحۡكِمَتۡ ءَایَـٰتُهُۥ ثُمَّ فُصِّلَتۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠١٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أحكمت آياته﴾</span>: لم يُنسَخ بكتاب كما نُسِخَت الكتبُ والشرائعُ به، <span class="qpc-hafs">﴿ثم فصلت﴾</span>: بُيِّنت بالأحكام، والحلال، والحرام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٠<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحِي</span>: أحكمت آياته بالأمر والنهي، ثم فصلت بالوعد والوعيد، والثواب والعقاب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثم فصلت﴾</span>، قال: فُسِّرَت{15}. (٨/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- في قوله: <span class="qpc-hafs">﴿كتاب أحكمت آياته ثم فصلت﴾</span>، قال: أُحْكِمت بالأمر والنهي، وفُصِّلَت بالوعد والوعيد{16}. (٨/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كتاب أُحكمت آياته ثم فصلت﴾</span>، قال: أحكَمَها الله مِن الباطل، ثم فصَّلها بعلمِه، فبيَّن حلاله وحرامه، وطاعته ومعصيته{17}. (٨/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: أحكمها الله؛ فليس فيها اختِلاف، ولا تَناقُض{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- أنّه قرأ: <span class="qpc-hafs">﴿الر كتاب أحكمت آياته﴾</span> قال: هي كلها محكمة. يعني: سورة هود، <span class="qpc-hafs">﴿ثم فصلت﴾</span> قال: ثُمَّ ذكر محمدًا ﷺ، فحَكَم فيها بينه وبين مَن خالفه. وقرأ: <span class="qpc-hafs">﴿مثل الفريقين﴾</span> الآية كلها [هود:٢٤]. ثم ذكر قوم نوح، ثم قوم هود، فكان هذا تفصيل ذلك، وكان أوله مُحْكَمًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٦<span class="dash">-</span></span> قال: وكان أبي يقول ذلك. يعني: <span class="name-2">زيد بن أسلم</span>{19}. (٨/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الر كِتابٌ أُحْكِمَتْ آياتُهُ﴾</span> مِن الباطل، يعني: آيات القرآن، <span class="qpc-hafs">﴿ثُمَّ فُصِّلَتْ﴾</span> يعني: بُيِّنَت: أمره، ونهيه، وحدوده، وأمر ما كان، وما يكون{20}<span class=comment-ref>٣١٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٦٩</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿كتاب فصلت آياته ثم أحكمت﴾</span> على أقوال: <b>الأول</b>: أحكمت آياته بالأمر والنهي، ثم فصلت بالثواب والعقاب. <b>الثاني</b>: أحكمت آياته من الباطل، ثم فصلت فبُيِّن منها الحلال والحرام.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٢/٣١٠) <span class="mustanad">مستندًا إلى دلالة اللغة</span> القول الثاني، فقال: «وأَوْلى القولين في ذلك بالصواب قولُ مَن قال: معناه: أحكم الله آياته من الدخل، والخلل والباطل، ثم فصَّلها بالأمر والنهي. وذلك أنّ إحكام الشيء: إصلاحه وإتقانه، وإحكام آيات القرآن: إحكامها مِن خللٍ يكون فيها، أو باطل يقدر ذو زيغ أن يطعن فيها مِن قِبَله. وأما تفصيل آياته فإنّه تمييز بعضها من بعض بالبيان عمّا فيها من حلال، وحرام، وأمر، ونهي». ثم ذكر <u>ابن جرير</u> تفسير مجاهد قوله: <span class="qpc-hafs">﴿فصلت﴾</span> بـ:فُسِّرَت، و<span class="comment-type-4">علّق</span> عليه بقوله: «وذلك نحو الذي قلنا فيه من القول». و<span class="comment-type-4">ذكر</span> قول قتادة من طريق سعيد، وعلَّق عليه بقوله: «وهو شبيه المعنى بقول مجاهد».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٤/٥٣٧بتصرف): «<span class="qpc-hafs">﴿وأُحْكِمَتْ﴾</span> معناه: أتقنت وأُجيدت شبه ما تحكم من الأمور المتقنة الكاملة، وبهذه الصفة كان القرآن في الأزل، ثم فصل بتقطيعه وتبيين أحكامه وأوامره على محمد ﷺ في أزمنة مختلفة، فـ<span class="qpc-hafs">﴿ثُمَّ﴾</span> على بابها، وهذه طريقة الإحكام والتفصيل، إذ الإحكام صفة ذاتية، والتفصيل إنما هو بحسب مَن يُفصَّل له، والكتاب بأجمعه محكم ومفصل، والإحكام الذي هو ضد النسخ والتفصيل الذي هو خلاف الإجمال إنما يقالان مع ما ذكرناه باشتراك». ثم ذكر <u>ابن عطية</u> القولين الواردين عن السلف في معنى الآية، و<span class="comment-type-4">علّق</span> عليهما بقوله: «وهذا من التخصيص الذي هو صحيح المعنى، ولكن لا يقتضيه اللفظ».</div></p><p><h3><span class="qpc-hafs">﴿مِن لَّدُنۡ حَكِیمٍ خَبِیرٍ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- قوله: <span class="qpc-hafs">﴿حكيم﴾</span>، قال: حكيم في أمره{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿من لدن حكيم﴾</span>، يعني: من عند حكيم{22}. (٨/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿حكيم خبير﴾</span>، قال: خبير بخلقه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٣١<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق محمد بن إسحاق- قوله: <span class="qpc-hafs">﴿حكيم﴾</span>، قال: حكيم في عُذْرِه وحُجَّته إلى عباده{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مِن لَدُنْ حَكِيمٍ﴾</span> يقول: مِن عند حكيم لأمره، <span class="qpc-hafs">﴿خَبِيرٍ﴾</span> بأعمال الخلائق{20}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ، وابن مردويه.|2:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (ت: اللاحم) ٢/٤٧٢.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:عزاه السيوطي إلى ابن مردويه.|5:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|6:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.|7:تنزيل القرآن ص٣٧-٤٢.|8:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|9:تفسير مقاتل بن سليمان ٢/٢٩٦-٢٧٠.|10:أخرجه الترمذي ٥/٤٨٩-٤٩٠ (٣٥٨١)، والحاكم ٢/٣٧٤ (٣٣١٤)، من طريق أبي كريب، عن معاوية بن هشام، عن شيبان، عن أبي إسحاق، عن عكرمة، عن ابن عباس به.</p><p>قال الترمذي: «هذا حديث حسن غريب، لا نعرفه من حديث ابن عباس إلا من هذا الوجه». وقال أبو حاتم الرازي كما في العلل ٥/٨٩ (١٨٢٦): «هذا خطأ؛ ليس فيه ابن عباس». وقال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». ووافقه الذهبي. وقال الألباني في الصحيحة ٢/٦٣٩ (٩٥٥) بعد ذكر كلام الحاكم والذهبي: «وهو كما قالا». وقد توَسَّع الدارقطني في علله ١/١٩٤ في الكلام حول أسانيده، واختلاف طرقه.|11:أخرجه الطبراني في الأوسط ٧/٣٠٥-٣٠٦ (٧٥٧٠)، وأبو نعيم في أخبار أصبهان ٢/٣٢٨، من طريق نهشل بن سعيد، عن سفيان بن باذام، عن قنبر، عن علي به.</p><p>قال الطبراني: «لا يُرْوى هذا الحديث عن قنبر عن علي إلا بهذا الإسناد، تفرَّد به عامر بن إبراهيم». وقال الهيثمي في المجمع ٧/١٥٧-١٥٨ (١١٦٢٢): «رواه الطبراني في الأوسط، وفيه نهشل بن سعيد، وهو متروك». وأورده الكناني في تنزيه الشريعة ١/٢٩٩ (٥٤). وفي إسناده باذام أو باذان، مولى أم هانئ، قال عنه ابن حجر في التقريب (٦٣٤): «ضعيف يرسل». وفيه أيضًا قنبر مولى علي، قال الذهبي: «لم يثبت حديثه». وقال الأزدي: «يُقال: كبر حتى كان لا يدري ما يقول أو يروي». كما في لسان الميزان لابن حجر ٦/٣٩٩.|12:أخرجه أحمد ٨/٤٢٣-٤٢٤ (٤٨٠٦)، ٨/٥٢٨ (٤٩٣٤)، ١٠/٤٢ (٥٧٥٥)، والترمذي ٥/٢٩٠ (٣٣٣٣)، والحاكم ٤/٦٢٠.</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ٧/١٣٤ (١١٤٦٨): «رواه أحمد بإسنادين، ورجالهما ثقات». ونقل الألباني في الصحيحة ٣/٧٠ (١٠٨١) تصحيح الحاكم له، ثم قال: «ووافقه الذهبي، وهو كما قالا، رجاله ثقات».|13:تفسير الثعلبي ٥/١٥٦، وتفسير البغوي ٤/١٥٦.|14:تفسير الثعلبي ٥/١٥٦.|15:أخرجه ابن جرير ١٢/٣١٠، وابن أبى حاتم ٦/١٩٩٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|16:أخرجه ابن جرير ١٢/٣٠٩، وابن أبي حاتم ٦/١٩٩٤-١٩٩٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|17:أخرجه ابن جرير ١٢/٣١٠، وابن أبي حاتم ٦/١٩٩٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|18:تفسير البغوي ٤/١٥٦.|19:أخرجه ابن أبي حاتم ٦/١٩٩٥.|20:تفسير مقاتل بن سليمان ٢/٢٧١.|21:أخرجه ابن أبي حاتم ٦/١٩٩٦.|22:أخرجه ابن جرير ١٢/٣١١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|23:أخرجه ابن أبي حاتم ٦/١٩٩٦.|24:أخرجه ابن أبي حاتم ٦/١٩٩٦.|25:تفسير مقاتل بن سليمان ٢/٢٧١.
  11,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَّا تَعۡبُدُوۤا۟ إِلَّا ٱللَّهَۚ إِنَّنِی لَكُم مِّنۡهُ نَذِیرࣱ وَبَشِیرࣱ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿نذير﴾</span> مِن النار، <span class="qpc-hafs">﴿وبشير﴾</span> قال: مُبَشِّر بالجنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألّا تَعْبُدُوا﴾</span> يعني: ألا تُوَحِّدُوا <span class="qpc-hafs">﴿إلّا اللَّهَ﴾</span>، يعني: كفار مكة، <span class="qpc-hafs">﴿إنَّنِي لَكُمْ مِنهُ﴾</span> يعني: مِن الله <span class="qpc-hafs">﴿نَذِيرٌ﴾</span> مِن عذابه، <span class="qpc-hafs">﴿وبَشِيرٌ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٩٦.|2:تفسير مقاتل بن سليمان ٢/٢٧١.
  11,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنِ ٱسۡتَغۡفِرُوا۟ رَبَّكُمۡ ثُمَّ تُوبُوۤا۟ إِلَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنِ اسْتَغْفِرُوا رَبَّكُمْ﴾</span> مِن الشرك، <span class="qpc-hafs">﴿ثُمَّ تُوبُوا إلَيْهِ﴾</span> منه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُمَتِّعۡكُم مَّتَـٰعًا حَسَنًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السدي، عن مرة الهمداني- <span class="qpc-hafs">﴿يمتعكم متاعا حسنا﴾</span>، قال: يمتعكم في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير، ومن طريق السدي عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿يمتعكم متاعا حسنا﴾</span>، قال: يمتعكم في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يُمتعكم متاعًا حسنًا﴾</span>، قال: فأنتم في ذلك المتاع، فخُذُوه بطاعة الله، ومعرفة حقِّه، فإنّ الله مُنعِمٌ، يُحِبُّ الشاكرين، وأهل الشكر في مزيد من الله، وذلك قضاؤه الذي قضى{4}<span class=comment-ref>٣١٧٠</span>. (٨/١٠)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٠</span> لم يذكر <u>ابنُ جرير</u> (١٢/٣١٣) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٣٥٠٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُمَتِّعْكُمْ مَتاعًا حَسَنًا﴾</span>، يعني: يعيشكم عيشًا حسنًا في الدنيا في عافية، ولا يعاقبكم بالسنين، ولا بغيرها{1}<span class=comment-ref>٣١٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧١</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ عطية</u> (٤/٥٣٨) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> ما أفاده قول مقاتل، فقال: «وأمّا مَن قال بأنّ المتاع الحسن: هو فوائد الدنيا وزينتها. فيضعف بأنّ الكفرة يتشاركون في ذلك أعظم مشاركة». وبيّن <u>ابنُ عطية</u> أنّ وصف المتاع بالحسن «إنما هو لطيب عيش المؤمن برجائه في الله ﷿ وفي ثوابه، وفرحه بالتقرب إليه بمفترضاته، والسرور بمواعيده، والكافر ليس في شيء من هذا».</div></p><p><h3><span class="qpc-hafs">﴿إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿أجل مسمى﴾</span>، قال: أجل الساعة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿أجل مسمى﴾</span>: فهو أجل موت الإنسان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قول الله: <span class="qpc-hafs">﴿أجل مسمى﴾</span>، قال: لا يعلمه إلا الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span>، قال: الموت{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span>، يعني: الموت{10}<span class=comment-ref>٣١٧٢</span>. (٨/١٠)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٢</span> لم يذكر <u>ابنُ جرير</u> (١٢/٣١٣-٣١٤) غير قول قتادة، وقول مجاهد.</p><p>وذكر <u>ابنُ عطية</u> (٤/٥٣٨) في الأجل قولين، <span class="comment-type-3">استظهر</span> الأول منهما، فقال: «والأجل المسمى: هو أجل الموت، معناه: إلى أجَلٍ مُسَمًّى لكل واحد منكم، وهذا ظاهر الآية». و<span class="comment-type-4">علّق</span> عليه بقوله: «واليوم الكبير -على هذا- هو يوم القيامة». ثم ذكر في الآية احتمالًا آخر، فقال: «وتحتمل الآية أن يكون التوعد بتعجيل العذاب إن كفروا، والوعد بتمتيعهم إن آمنوا، فتشبه ما قاله نوح ﵇». و<span class="comment-type-4">علّق</span> عليه بقوله: «واليوم الكبير -على هذا-: يوم بدر ونحوه، والمجهلة في أي الأمرين يكون إنما هي بحسب البشر، والأمر عند الله تعالى معلوم محصل، والأجل واحد».</div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿أجل﴾</span>: مُنتَهى. يقول: أجل حياتك إلى أن تموت، وأجل موتك إلى أن تُبْعَث؛ فأنت بين أجلين مِن الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلى أجَلٍ مُسَمًّى﴾</span>، يعني: إلى مُنتَهى آجالكم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُؤۡتِ كُلَّ ذِی فَضۡلࣲ فَضۡلَهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق سعيد بن جبير - في قوله: <span class="qpc-hafs">﴿ويؤت كل ذي فضل فضله﴾</span>، قال: مَن عمِل سيئة كُتبت عليه سيئة، ومَن عمِل حسنة كُتبت له عشر حسنات، فإن عُوقب بالسيِّئة التي كان عَمِلها في الدنيا بقيت له عشر حسنات، وإن لم يُعاقب بها في الدنيا أُخِذَت مِن الحسنات العشر واحدة، وبَقِيَت له تسعُ حسنات. ثم يقول: هلك مَن غلب آحادُه أعشارَه{13}<span class=comment-ref>٣١٧٣</span>. (٨/١١)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٣٨-٥٣٩) في الآية احتمالين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿ويُؤْتِ كُلَّ ذِي فَضْلٍ فَضْلَهُ﴾</span> أي: كل ذي إحسان بقوله، أو بفعله، أو قوته، أو بماله، أو غير ذلك، مما يمكن أن يتقرب به. و<span class="qpc-hafs">﴿فَضْلَهُ﴾</span> يحتمل أن يعود الضمير فيه على <span class="qpc-hafs">﴿ذي﴾</span> أي: ثواب فضله وجزاءه. ويحتمل أن يعود الضمير فيه على الله ﷿، أي: يؤتي اللهُ فضلَه كل ذي فضل وعمل صالح من المؤمنين، ونحو هذا المعنى ما وعد به تعالى من تضعيف الحسنة بعشر أمثالها، ومن التضعيف غير المحصور لمن شاء، وهذا التأويل تأوَّله ابن مسعود، وقال: ويلٌ لِمَن غلبت آحادُه عشراته. ويحتمل أن يكون قولُ ابن مسعود موافقًا للمعنى الأول».</div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مَن زادت حسناتُه على سيئاتِه دخل الجنة، ومَن زادت سيئاته على حسناته دخل النار، ومَن استوت حسناته وسيئاته كان مِن أصحاب الأعراف، ثم يدخل الجنة بعد{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٤٩<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحِيِّ</span>: مَن كثُرَتْ طاعتُه في الدنيا زادت درجاته في الآخرة في الجنة؛ لأنّ الدرجات تكون بالأعمال{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ويؤت كل ذي فضل فضله﴾</span>، قال: ما احتسب به من ماله، أو عمل بيديه، أو رجلَيه، أو كلامِه، أو ما تطوَّل به مِن أمره كله{16}. (٨/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ويؤت كل ذي فضل فضله﴾</span>، قال: يُؤْتِ كلَّ ذي فضل في الإسلام فضل الدرجات في الآخرة{17}. (٨/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويؤت كل ذي فضل فضله﴾</span>، أي: في الآخرة{18}. (٨/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُؤْتِ﴾</span> في الآخرة <span class="qpc-hafs">﴿كُلَّ ذِي فَضْلٍ﴾</span> في العمل في الدنيا <span class="qpc-hafs">﴿فَضْلَهُ﴾</span> في الدرجات{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن تَوَلَّوۡا۟ فَإِنِّیۤ أَخَافُ عَلَیۡكُمۡ عَذَابَ یَوۡمࣲ كَبِیرٍ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿وإن تولوا﴾</span>، يعني: الكفار، عن النبي ﷺ ...{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ تَوَلَّوْا﴾</span> يعني: تُعْرِضوا عن الإيمان؛ <span class="qpc-hafs">﴿فَإنِّي أخافُ عَلَيْكُمْ عَذابَ يَوْمٍ كَبِيرٍ﴾</span> يعني: عظيم، فلم يتوبوا، فحبس الله عنهم المطر سبع سنين حتى أكلوا العظام، والموتى، والكلاب، والجِيَف{1}<span class=comment-ref>٣١٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٣٩) في قوله: <span class="qpc-hafs">﴿يوم كبير﴾</span> احتمالين، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فَإنِّي أخافُ عَلَيْكُمْ عَذابَ يَوْمٍ كَبِيرٍ﴾</span> توعد بيوم القيامة، ويحتمل أن يريد به يومًا من الدنيا كبدر وغيره». ثم <span class="comment-type-3">قوّى</span> الاحتمال الأول بقوله: «وقوله تعالى: <span class="qpc-hafs">﴿إلى اللَّهِ مَرْجِعُكُمْ﴾</span> توعد، وهو يؤيد أن اليوم الكبير يوم القيامة؛ لأنّه توعد به».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٧١.|2:أخرجه ابن أبي حاتم ٦/١٩٩٦.|3:أخرجه ابن أبي حاتم ٦/١٩٩٦.|4:أخرجه ابن جرير ١٢/٣١٣، وابن أبي حاتم ٦/١٩٩٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|5:تفسير مقاتل بن سليمان ٢/٢٧١.|6:أخرجه ابن أبي حاتم ٦/١٩٩٧. أورده عن ابن عباس وغيره في هذه الآية، كما أورده قبل ذلك في قوله تعالى: <span class="qpc-hafs">﴿هُوَ الَّذِي خَلَقَكُمْ مِن طِينٍ ثُمَّ قَضى أجَلًا وأَجَلٌ مُسَمًّى عِنْدَهُ﴾</span> [الأنعام:٢]، وهو أشبه، لذا لم يذكر هذا القول ابن جرير وابن عطية.|7:أخرجه ابن أبي حاتم ٦/١٩٩٧.|8:أخرجه ابن أبي حاتم ٦/١٩٩٧.|9:أخرجه ابن جرير ١٢/٣١٣.|10:أخرجه ابن جرير ١٢/٣١٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|11:أخرجه ابن أبي حاتم ٦/١٩٩٧.|12:تفسير مقاتل بن سليمان ٢/٢٧١.|13:أخرجه ابن جرير ١٢/٣١٥.|14:تفسير الثعلبي ٥/١٥٧، وتفسير البغوي ٤/١٦٠.|15:تفسير الثعلبي ٥/١٥٧، وتفسير البغوي ٤/١٦٠.|16:تفسير مجاهد ص٣٨٤، وأخرجه ابن جرير ١٢/٣١٤، وابن أبي حاتم ٦/١٩٩٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|17:عزاه السيوطي إلى أبي الشيخ.|18:أخرجه ابن جرير ١٢/٣١٥، وابن أبي حاتم ٦/١٩٩٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|19:تفسير مقاتل بن سليمان ٢/٢٧١.|20:أخرجه ابن أبي حاتم ٦/١٩٩٨.|21:تفسير مقاتل بن سليمان ٢/٢٧١.
  11,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَى ٱللَّهِ مَرۡجِعُكُمۡۖ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٥٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- يعني قوله: <span class="qpc-hafs">﴿إلى الله مرجعكم﴾</span>، قال: يرجعون إليه بعد الحياة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق أبي سنان- في قوله: <span class="qpc-hafs">﴿إلى الله مرجعكم﴾</span>، قال: البَرُّ، والفاجر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلى اللَّهِ مَرْجِعُكُمْ﴾</span> في الآخرة، لا يُغادر منكم أحد، <span class="qpc-hafs">﴿وهُوَ عَلى كُلِّ شَيْءٍ﴾</span> مِن البعث وغيره <span class="qpc-hafs">﴿قَدِيرٌ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٩٨.|2:أخرجه ابن أبي حاتم ٦/١٩٩٨.|3:تفسير مقاتل بن سليمان ٢/٢٧١.
  11,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَاۤ إِنَّهُمۡ یَثۡنُونَ صُدُورَهُمۡ لِیَسۡتَخۡفُوا۟ مِنۡهُۚ أَلَا حِینَ یَسۡتَغۡشُونَ ثِیَابَهُمۡ یَعۡلَمُ مَا یُسِرُّونَ وَمَا یُعۡلِنُونَۚ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٥٩<span class="dash">-</span></span> قرأ <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن عباد بن جعفر-: (ألَآ إنَّهُمْ تَثْنَوْنِي صُدُورُهُمْ){1}. (٨/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٠<span class="dash">-</span></span> قرأ <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الرحمن الأعرج-: (ألَآ إنَّهُمْ تَثْنَوِنُّ صُدُورُهُمْ){2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦١<span class="dash">-</span></span> قرأ <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن دينار-: <span class="qpc-hafs">﴿ألَآ إنَّهُمْ يَثْنُونَ صُدُورَهُمْ﴾</span>{3}<span class=comment-ref>٣١٧٥</span>. (٨/١١)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٥</span> ذكر <u>ابنُ جرير</u> (١٢/٣٢١) في قوله: <span class="qpc-hafs">﴿يثنون﴾</span> قراءتين: <b>الأولى</b>: <span class="qpc-hafs">﴿يثنون﴾</span> على تقدير: يفعلون من الفعل ثنيت، ونسب هذه القراءة إلى عامة قراء الأمصار. <b>الثانية</b>: نسبها <u>ابن جرير</u> لابن عباس أنه قرأ ذلك: <span class="qpc-hafs">﴿تثنوني﴾</span> على وزن: تفعوعل. ثم <span class="comment-type-3">رجّح</span> ابن جرير <span class="mustanad">مستندًا إلى إجماع قراء الأمصار</span> القراءة الأولى، فقال: «والصواب من القراءة في ذلك عندنا ما عليه قراء الأمصار، وهو: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span> على مثال: يفعلون».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٣٩-٥٤٠) في معنى الآية احتمالين: <b>الأول</b>: أنّ ذلك كان من الكفار حين يلقون رسول الله تطامنوا، وثنوا صدورهم كالمستتر، ورَدُّوا إليه ظهورهم، وغشوا وجوههم بثيابهم تباعدًا منه وكراهةً للقائه، وهم يظنون أن ذلك يخفى عليه وعلى الله ﷿. <b>الثاني</b>: أنّ ذلك استعارة للغِلِّ والحِقد الذي كانوا يَنطَوُون عليه ويتكتمون عليه ظنًّا منهم أنه يخفى على الله.</p><p>ثم ذكر قراءة ابن عباس وبيّن أنها تحتمل هذين الاحتمالين من التفسير.</p><p>وذكر <u>ابنُ كثير</u> (٧/٤١٤) قراءة ابن عباس، و<span class="comment-type-4">علّق</span> عليها، فقال: «وقرأ ابن عباس: (ألَآ إنَّهُمْ تَثْنَوْنِي صُدُورُهُمْ)، برفع الصدور على الفاعلية، وهو قريب المعنى».</div></p><p><h3><span class="qpc-hafs">﴿أَلَاۤ إِنَّهُمۡ یَثۡنُونَ صُدُورَهُمۡ لِیَسۡتَخۡفُوا۟ مِنۡهُۚ أَلَا حِینَ یَسۡتَغۡشُونَ ثِیَابَهُمۡ یَعۡلَمُ مَا یُسِرُّونَ وَمَا یُعۡلِنُونَۚ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن عباد بن جعفر- أنّه قرأ: (ألَآ إنَّهُمْ تَثْنَوْنِي صُدُورُهُمْ). وقال: أُناسٌ كانوا يستحيون أن يَتَخَلَّوا فيُفضُوا إلى السماء، وأن يُجامِعوا نساءَهم فيُفضوا إلى السماء؛ فنَزل ذلك فيهم{4}. (٨/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مُليكة- يقول: (ألَآ إنَّهُمْ تَثْنَوْنِي صُدُورُهُمْ). قال: كانوا لا يأتون النساءَ ولا الغائط إلا وقد تَغَشَّوا بثيابهم؛ كراهة أن يُفضُوا بفروجهم إلى السماء{5}. (٨/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>: نزلت في الأخنس بن شَرِيق، وكان رجلًا حلو الكلام حلوَ المنظر، يلقى رسول الله ﷺ بما يُحِبُّ، ويَنطَوِي بقلبه على ما يكره{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٥<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد بن الهاد</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>، قال: كان المنافقون إذا مرَّ أحدُهم بالنبي ﷺ ثنى صدرَه، وتغشّى ثوبه؛ لكيلا يراه؛ فنزلت{7}. (٨/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: نزلت في الأخنس بن شَرِيق، كان يُجالِس النبيَّ ﷺ، يُظْهِر له أمرًا يَسُرُّهُ، ويُضْمِر في قلبه خلافَ ما يُظهِر؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>. يقول: يُكْمِنُون{8} ما في صدورهم مِن العداوة لمحمد ﷺ{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَاۤ إِنَّهُمۡ یَثۡنُونَ صُدُورَهُمۡ لِیَسۡتَخۡفُوا۟ مِنۡهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>، قال: الشكُّ في الله، وعمل السيئات{10}. (٨/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>، يقول: يكتمون ما في قلوبهم{11}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>، قال: يَكُنُّون{12}. (٨/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٠<span class="dash">-</span></span> عن <span class="name-2">أبي رزين [مسعود بن مالك الأسدي]</span> -من طريق منصور- في الآية، قال: كان أحدهم يَحْنِي ظهرَه، ويستغشي بثوبه{13}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يثنون صدورهم﴾</span> قال: تضيق شكًّا وامتراء في الحق؛ <span class="qpc-hafs">﴿ليستخفوا منه﴾</span> قال: مِن الله إن استطاعوا{14}<span class=comment-ref>٣١٧٦</span>. (٨/١٢)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٦</span> ذكر <u>ابنُ عطية</u> (٤/٥٤١-٥٤٢) في عود الضمير من قوله: <span class="qpc-hafs">﴿ليستخفوا منه﴾</span> احتمالين، <span class="comment-type-3">رجّح</span> الأول منهما، فقال: «والضمير في <span class="qpc-hafs">﴿مِنهُ﴾</span> عائد على الله تعالى، هذا هو الأفصح الأجزل في المعنى. وعلى بعض التأويلات يمكن أن يعود على محمد ﷺ».</p><p>و<span class="comment-type-3">رجح</span> الأولَ <u>ابنُ كثير</u> (٤/٤١٤) <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وعود الضمير على الله أولى؛ لقوله: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم يعلم ما يسرون وما يعلنون﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>، يقول: تَثْنَوْنِي صدورُهم{15}<span class=comment-ref>٣١٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٧</span> ذكر <u>ابنُ جرير</u> (١٢/٣٢٢) قول الضحاك بن مزاحم، و<span class="comment-type-4">علّق</span> عليه قائلًا: «وهذا التأويل الذي تَأَوَّله الضحاك على مذهب قراءة ابن عباس، إلا أنّ الذي حدَّثنا هكذا ذكر القراءة في الرواية».</div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يثنون صدورهم﴾</span> على ما هُم عليه من الكفر؛ <span class="qpc-hafs">﴿ليستخفوا منه﴾</span> بذلك، يظنون أنّ الله ﷿ لا يعلم الذي يستخفون به. قال بعضهم: هم المنافقون{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span>، قال: حديث النفس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم ليستخفوا منه﴾</span>: وهو من جهالتهم به{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في الآية، قال: كانوا يَحْنُون صدورهم لكيلا يسمعوا كتاب الله{19}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يثنون﴾</span>، أي: يُعْرِضون بقلوبهم، مِن قولهم: ثنيت عِنانِي{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ليستخفوا منه﴾</span>: لِيَسْتَتِروا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٧٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراساني</span> -من طريق عثمان بن عطاء- في قوله: <span class="qpc-hafs">﴿يثنون صدورهم﴾</span>، يقول: يُطَأْطِئون رءُوسهم، ويحنون ظهورهم{17}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا إنَّهُمْ يَثْنُونَ صُدُورَهُمْ﴾</span> يعني: يَلْوُون، وذلك أنّ كفار مكة كانوا إذا سمعوا القرآن نكسوا رءوسهم على صدورهم؛ كراهية استماع القرآن؛ <span class="qpc-hafs">﴿لِيَسْتَخْفُوا مِنهُ﴾</span> يعني: مِن النبي ﷺ، فاللهُ قد علم ذلك منهم، ثم قال: <span class="qpc-hafs">﴿ألا حِينَ يَسْتَغْشُونَ ثِيابَهُمْ يَعْلَمُ ما يُسِرُّونَ وما يُعْلِنُونَ﴾</span>{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم ليستخفوا منه﴾</span>، قال: هذا حين يناجي بعضُهم بعضًا. وقرأ: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم﴾</span> الآية{24}<span class=comment-ref>٣١٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٨</span> اختلف السلف في تفسير قوله تعالى: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم ليستخفوا منه﴾</span>، وفي السبب الذي من أجله فعلوا ذلك، على أقوال: <b>الأول:</b> ذلك كان مِن فعل بعض المنافقين، كان إذا مر برسول الله ﷺ غطّى وجهَه، وثنى ظهرَه. <b>الثاني</b>: كانوا يفعلون ذلك جهلًا منهم بالله، وظنًّا أنّ الله يخفى عليه ما تُضْمِره صدورُهم إذا فعلوا ذلك. <b>الثالث</b>: إنما كانوا يفعلون ذلك لِئَلّا يسمعوا كلام الله تعالى. <b>الرابع</b>: إخبار من الله نبيه ﷺ عن المنافقين الذين كانوا يُضْمِرُون له العداوة والبغضاء، ويُبْدُون له المحبة والمودة، وأنّهم معه وعلى دينه. <b>الخامس</b>: كانوا يفعلون ذلك إذا ناجى بعضهم بعضًا.</p><p>وقد ذكر <u>ابنُ جرير</u> (١٢/٣٢٢) الخلاف في قراءة ذلك، والخلاف في تأويله، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى السياق</span> القول الثاني، معللًا ذلك بقوله: «وإنما قلنا ذلك أولى التأويلات بالآية لأنّ قوله: <span class="qpc-hafs">﴿ليستخفوا منه﴾</span> بمعنى: ليستخفوا من الله، وأن الهاء في قوله: <span class="qpc-hafs">﴿منه﴾</span> عائدة على اسم الله، ولم يجرِ لمحمد ذِكْرٌ قبلُ فيُجْعَل مِن ذكره ﷺ وهي في سياق الخبر عن الله. فإذا كان ذلك كذلك كانت بأن تكون مِن ذِكْرِ الله أولى. وإذا صح أنّ ذلك كذلك كان معلومًا أنهم لم يحدثوا أنفسهم أنهم يستخفون من الله إلا بجهلهم به، فلما أخبرهم -جل ثناؤه- أنّه لا يخفى عليه سِرُّ أمورهم وعلانيتها على أي حال كانوا».</p><p>وذكر <u>ابنُ عطية</u> (٤/٥٤٠) القول الأول، و<span class="comment-type-4">علّق</span> عليه بقوله: «و<span class="qpc-hafs">﴿صُدُورَهُمْ﴾</span> منصوبة على هذا بـ<span class="qpc-hafs">﴿يَثْنُونَ﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿أَلَا حِینَ یَسۡتَغۡشُونَ ثِیَابَهُمۡ یَعۡلَمُ مَا یُسِرُّونَ وَمَا یُعۡلِنُونَۚ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم يعلم ما﴾</span> عمِلوا بالليل والنهار{25}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم﴾</span> قال: يَكُنُّون، <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم﴾</span> قال: يُغَطُّون رُءوسَهم{26}<span class=comment-ref>٣١٧٩</span>. (٨/١٤)</p></p><p></div></p><p><div><span class=comment-ref>٣١٧٩</span> لم يذكر <u>ابنُ جرير</u> (١٢/٣٢٣) في تفسير قوله: <span class="qpc-hafs">﴿ويستغشون ثيابهم﴾</span> غير قول عبد الله بن عباس.</div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿يستغشون ثيابهم﴾</span>: يستكبر، أو يَسْتَكِنُّ مِن الله، والله يراه؛ <span class="qpc-hafs">﴿يعلم ما يسرون وما يعلنون﴾</span>{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم﴾</span>، قال: يَتَقنَّع به{28}. (٨/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ألا إنهم يثنون صدورهم ليستخفوا منه ألا حين يستغشون ثيابهم﴾</span> قال: من جهالتهم به، قال الله: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم﴾</span> في ظُلْمَة الليل في أجوف بيوتهم <span class="qpc-hafs">﴿يعلم﴾</span> تلك الساعة <span class="qpc-hafs">﴿ما يسرون وما يعلنون إنه عليم بذات الصدور﴾</span>{29}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في الآية، قال: كانوا يحنون صدورهم لكيلا يسمعوا كتاب الله، قال تعالى: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم يعلم ما يسرون﴾</span>. وذلك أخفى ما يكون ابنُ آدم، إذا حنى ظهره، واستغشى بثوبه، وأضمر هَمَّه في نفسه، فإنّ الله لا يخفى ذلك عليه{30}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿ألا حين يستغشون ثيابهم﴾</span>، قال: في ظُلْمَة الليل، وظُلْمَة اللِّحاف{28}. (٨/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٨٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: أمّا <span class="qpc-hafs">﴿يستغشون ثيابهم﴾</span> فيلبسون ثيابهم، اسْتَغْشُوا بها على رءوسهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا حِينَ يَسْتَغْشُونَ ثِيابَهُمْ﴾</span> يعني: يعلم ذلك <span class="qpc-hafs">﴿يَعْلَمُ﴾</span> الله حين يُغَطُّون رءوسهم بالثياب <span class="qpc-hafs">﴿ما يُسِرُّونَ﴾</span> في قلوبهم، وذلك الخفيُّ، <span class="qpc-hafs">﴿وما يُعْلِنُونَ﴾</span> بألسنتهم{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٠٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿إنه عليم بذات الصدور﴾</span>: يعلم تلك الساعة{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُ عَلِيمٌ بِذاتِ الصُّدُورِ﴾</span>، يعني: بما في القلوب مِن الكُفر وغيره{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠٩٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿والله عليم بذات الصدور﴾</span>، أي: لا يخفى عليه ما في صدورهم بما اسْتَخْفَوا به منكم{34}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٦/٧٣ (٤٦٨١، ٤٦٨٢)، وابن جرير ١٢/٣٢٠، وابن أبي حاتم ٦/١٩٩٨ (١٠٦٥٤)، ٦/١٩٩٩ (١٠٦٦٣).</p><p>وهي قراءة شاذة، تروى أيضًا عن مجاهد، ونصر بن عاصم. انظر: مختصر ابن خالويه ص٦٤.|2:أخرجه عبد الله بن وهب في الجامع – تفسير القرآن ٣/٥٢ (١١٠).</p><p>وهي قراءة شاذة. انظر: المحتسب ١/٣١٩.|3:أخرجه البخاري (٤٦٨٣). وعزاه السيوطي إلى ابن مردويه.</p><p>وهي قراءة العشرة.|4:أخرجه البخاري ٦/٧٣ (٤٦٨١، ٤٦٨٢)، وابن جرير ١٢/٣٢٠، وابن أبي حاتم ٦/١٩٩٨ (١٠٦٥٤)، ٦/١٩٩٩ (١٠٦٦٣).|5:أخرجه ابن جرير ١٢/٣٢٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|6:لم نجد من أخرجه، وأورده الثعلبي ٥/١٥٧، والبغوي ٤/١٦٠.|7:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٣٨٤-، وسعيد بن منصور (١٠٧٨ - تفسير)، وابن جرير ١٢/٣١٦، وابن أبي حاتم ٦/١٩٩٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|8:قال المحقق د. ماهر الفحل: في (ب) و(ص): يكتمون.|9:علقه الواحدي في أسباب النزول ص٤٤٣.|10:أخرجه ابن جرير ١٢/٣٢١، وابن أبي حاتم ٦/١٩٩٩.|11:أخرجه ابن جرير ١٢/٣٢١، وابن أبي حاتم ٦/١٩٩٨.|12:أخرجه ابن جرير ١٢/٣٢١، وابن أبي حاتم ٦/٢٠٠٠. وعزاه السيوطي إلى ابن المنذر.|13:أخرجه ابن جرير ١٢/٣١٨، وابن أبي حاتم ٦/٢٠٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|14:تفسير مجاهد ص٣٨٤، وأخرجه ابن جرير ١٢/٣١٨، وابن أبي حاتم ٦/٢٠٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|15:أخرجه ابن جرير ١٢/٣٢٢. وابن أبي حاتم ٦/١٩٩٩ وفيه: تلتوي صدورهم.|16:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٧٨-.|17:أخرجه ابن أبي حاتم ٦/١٩٩٩.|18:أخرجه ابن أبي حاتم ٦/٢٠٠٠.|19:أخرجه ابن جرير ١٢/٣١٩، وابن أبي حاتم ٦/١٩٩٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|20:تفسير الثعلبي ٥/١٥٧، وتفسير البغوي ٤/١٦١.</p><p>والعِنانُ: سَيْرُ اللِّجام. لسان العرب (عنن).|21:أخرجه ابن أبي حاتم ٦/٢٠٠٠.|22:أخرجه ابن أبي حاتم ٦/١٩٩٩.|23:تفسير مقاتل بن سليمان ٢/٢٧١-٢٧٢.|24:أخرجه ابن جرير ١٢/٣٢٠.|25:أخرجه ابن جرير ١٢/٣٢٢، وابن أبي حاتم ٦/١٩٩٨.|26:أخرجه ابن جرير ١٢/٣٢٣، وابن أبي حاتم ٦/٢٠٠٠. وعزاه السيوطي إلى ابن المنذر.|27:أخرجه ابن جرير ١٢/٣٢١.|28:عزاه السيوطي إلى أبي الشيخ.|29:أخرجه ابن جرير ١٢/٣١٨.|30:أخرجه ابن جرير ١٢/٣١٩، وابن أبي حاتم ٦/١٩٩٩-٢٠٠٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|31:عزاه السيوطي إلى أبي الشيخ.|32:أخرجه ابن أبي حاتم ٦/٢٠٠٠.|33:تفسير مقاتل بن سليمان ٢/٢٧١-٢٧٢.|34:أخرجه ابن أبي حاتم ٦/٢٠٠١.|35:تفسير مقاتل بن سليمان ٢/٢٧٢.|36:أخرجه ابن أبي حاتم ٦/٢٠٠١.