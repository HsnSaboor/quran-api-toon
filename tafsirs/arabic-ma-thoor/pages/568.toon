tafsir[28]{c,v,t}:
69,35," <q>﴿فَلَیۡسَ لَهُ ٱلۡیَوۡمَ هَـٰهُنَا حَمِیمࣱ ۝٣٥﴾</q> - تفسير ٧٨٥٩٩- قال مقاتل بن سليمان: <q>﴿فَلَيْسَ لَهُ اليَوْمَ﴾</q> في الآخرة <q>﴿هاهُنا حَمِيمٌ﴾</q> يعني: قريب يَشفع له{1}. (ز) ٧٨٦٠٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَلَيْسَ لَهُ اليَوْمَ هاهُنا حَمِيمٌ﴾</q>: القريب في كلام العرب{2}٦٧٧٢. (ز) ٦٧٧٢ نسب ابنُ عطية (٨/٣٩٥) هذا القول لجمهور المفسرين، ثم قال: «فنفى الله تعالى أن يكون للكافر هنالك مَن يواليه». ثم نقل عن محمد بن المستنير القول بأنّ «الحميم»: الماء السّخن. وعلَّق بقوله: «فكأنه تعالى أخبر أنّ الكافر ليس له ماء، ولا شيء مائع». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٤.أخرجه ابن جرير ٢٣/٢٤٠.
69,36," <q>﴿وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِینࣲ ۝٣٦﴾</q> - تفسير ٧٨٦٠١- عن عبد الله بن عباس -من طريق مجاهد- قال: ما أدري ما الغِسلين، ولكني أظنّه الزّقوم{1}. (١٤/٦٨١) ٧٨٦٠٢- عن عبد الله بن عباس -من طريق مجاهد- قال: لو أنّ قَطرة مِن غِسلِين وقَعتْ في الأرض أفسدتْ على الناس مَعايشهم، ولو أنّ النار أُبرزتْ في صعيد لم يمرّ بها شيء إلا مات{2}. (ز) ٧٨٦٠٣- عن عبد الله بن عباس -من طريق علي- قال: الغِسلين: صَديد أهل النار{3}. (١٤/٦٨١) ٧٨٦٠٤- عن عبد الله بن عباس -من طريق عكرمة- قال: الغِسلين: الدم والماء الذي يَسيل من لحومهم{4}. (١٤/٦٨١) ٧٨٦٠٥- عن عبد الله بن عباس -من طريق ابن جُرَيْج- قال: الغِسلين: اسم طعام مِن أطعمة أهل النار{5}. (١٤/٦٨٢) ٧٨٦٠٦- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿غِسْلِينٍ﴾</q>، قال: هو الضّريع، شجرة يأكل منها أهل النار{6}. (١٤/٦٨٢) ٧٨٦٠٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولا طَعامٌ إلّا مِن غِسْلِينٍ﴾</q> شر الطعام وأَخبثه وأَبشعه{7}. (ز) ٧٨٦٠٨- قال الربيع بن أنس: <q>﴿ولا طَعامٌ إلا مِن غِسْلِينٍ﴾</q> هو شجر يأكله أهل النار{8}. (ز) ٧٨٦٠٩- قال مقاتل بن سليمان: <q>﴿ولا﴾</q> وليس له <q>﴿طَعامٌ إلّا مِن غِسْلِينٍ﴾</q> يعني: الذي يَسيل مِن القَيْح والدم من أهل النار، يعني: فليس له شَراب إلا مِن حميم مِن عَينٍ مِن أصل الجحيم{9}. (ز) ٧٨٦١٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا طَعامٌ إلّا مِن غِسْلِينٍ﴾</q>، قال: الغِسلين والزّقُّومُ لا يَعلم أحدٌ ما هو{7}٦٧٧٣. (ز) ٦٧٧٣ ذكر ابنُ عطية (٨/٣٩٥) أنّ بعض المفسرين قال: الغِسلين: هو شيء يجري من ضريع؛ لأن الله تعالى قد أخبر أنهم ليس لهم طعام إلا من ضريع، وفي أخرى إلا من غِسلين، فهما شيء واحد، أو اثنان مُتداخلان، ثم قال: «ويحتمل أن يكون الإخبار هنا عن طائفة وهناك عن طائفة، ويكون الغِسلين والضّريع مُتباينين، على ما يُفهم منهما في لسان العرب». <q>﴿وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِینࣲ ۝٣٦﴾</q> - آثار متعلقة بالآية ٧٨٦١١- عن أبي سعيد الخُدري، عن النبي ﷺ، قال: «لو أنّ دَلوًا من غِسلين يُهراق في الدنيا لأَنتن أهل الدنيا»{11}. (١٤/٦٨٢) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وأبي القاسم الزجاجي النحوي في أماليه.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٤٦ (٩٩).أخرجه ابن جرير ٢٣/٢٤٠، وابن أبي حاتم -كما في الإتقان ٢/٤٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٤٠ من طريق عطية. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٧ (٨١)، ٦/٤٤١ (١٨٩)-. وعزاه السيوطي إلى ابن المنذر بلفظ: غسلين: شجرة في النار.أخرجه ابن جرير ٢٣/٢٤١.تفسير البغوي ٨/٢١٣، وتفسير الثعلبي ١٠/٣٢.تفسير مقاتل بن سليمان ٤/٤٢٤.أخرجه ابن جرير ٢٣/٢٤١.أخرجه الحاكم ٢/٥٤٤ (٣٨٥٠). وأخرجه بلفظ: «غسّاق» أحمد ١٧/٣٣١ (١١٢٣٠)، ١٨/٣١٠ (١١٧٨٦)، والترمذي ٤/٥٤٠-٥٤١ (٢٧٦٦)، والحاكم ٤/٦٤٤ (٨٧٧٩)، وابن جرير ٢٠/١٣٠، ٢٤/٣١-٣٢. من طريق درّاج، عن أبي الهيثم، عن أبي سعيد به. قال الترمذي: «هذا حديث إنما نعرفه من حديث رشدين بن سعد، وفي رشدين بن سعد مقال، وقد تُكلّم فيه من قِبل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».
69,37," <q>﴿لَّا یَأۡكُلُهُۥۤ إِلَّا ٱلۡخَـٰطِـُٔونَ ۝٣٧﴾</q> - قراءات ٧٨٦١٢- عن عبد الله بن مسعود -من طريق أبي الدِّهْقان- أنه قرأ: <q>﴿لا يَأْكُلُهُ إلّا الخاطِئُونَ﴾</q> مهموزة{1}. (١٤/٦٨٣) ٧٨٦١٣- عن صَعْصَعة بن صُوحان، قال: جاء أعرابيٌّ إلى علي بن أبي طالب، فقال: كيف تقرأ هذا الحرف: ‹لا يَأْكُلُهُ إلّا الخاطُونَ›؟ كلٌّ -واللهِ- يخطو! فتبسّم عليٌّ، وقال: يا أعرابيُّ، <q>﴿لا يَأْكُلُهُ إلّا الخاطِئُونَ﴾</q>. قال: صدقتَ -واللهِ- يا أمير المؤمنين، ما كان الله ليُسلِم عبده. ثم التَفتَ عليٌّ إلى أبي الأسود، فقال: إنّ الأعاجم قد دَخلتْ في الدّين كافة، فضَع للناس شيئًا يَستدلّون به على صلاح ألسنتهم. فرَسم له الرفع، والنصب، والخفض{2}. (١٤/٦٨٢) ٧٨٦١٤- عن عبد الله بن عباس -من طريق أبي الأسود الدؤلي، ويحيى بن يَعْمر- قال: ما (الخاطُونَ)؟! إنما هو: <q>﴿الخاطِئُونَ﴾</q>. ما ‹الصّابُونَ›؟! إنما هو: <q>﴿الصّابِئُونَ﴾</q>{3}. (١٤/٦٨٣) ٧٨٦١٥- عن مجاهد بن جبر أنه كان يقرأ: ‹لا يَأْكُلُهُ إلّا الخاطِيُونَ› لا يَهمز{4}. (١٤/٦٨٣) <q>﴿لَّا یَأۡكُلُهُۥۤ إِلَّا ٱلۡخَـٰطِـُٔونَ ۝٣٧﴾</q> - تفسير الآية ٧٨٦١٦- عن عكرمة، قال: قرأ نافعٌ عند عبد الله بن عباس: <q>﴿لا يأكله إلا الخاطئون﴾</q>. فقال: مَه، كُلّنا نخطئ{5}. (ز) ٧٨٦١٧- قال مقاتل بن سليمان: <q>﴿لا يَأْكُلُهُ إلّا الخاطِئُونَ﴾</q> يعني: المجرمين{6}. (ز) ",footnotes:1:أخرجه البخاري في تاريخه ٤/٢٩٤. وعزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة؛ إلا حمزة عند الوقف فقرأ ‹إلّا الخاطُونَ› بالحذف على وجه، و‹إلّا الخاطِيُونَ› بإبدال الهمز ياء على وجه آخر. انظر: الوافي في شرح الشاطبية ص١٢٠-١٢١.أخرجه البيهقي في شعب الإيمان (١٦٨٤).أخرجه الحاكم ٢/٥٠١. و‹الصّابُونَ› قراءة متواترة، قرأ بها نافع، وأبو جعفر، وقرأ بقية العشرة: <q>﴿الصّابِئُونَ﴾</q> بالهمز. انظر: الإتحاف ص١٨١.عزاه السيوطي إلى سعيد بن منصور.أخرجه الواحدي في الوسيط ٤/٣٤٨.تفسير مقاتل بن سليمان ٤/٤٢٤.
69,38," <q>﴿فَلَاۤ أُقۡسِمُ بِمَا تُبۡصِرُونَ ۝٣٨ وَمَا لَا تُبۡصِرُونَ ۝٣٩﴾</q> - تفسير ٧٨٦١٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فَلا أُقْسِمُ بِما تُبْصِرُونَ وما لا تُبْصِرُونَ﴾</q>، يقول: بما تَرون، وما لا تَرون{1}. (١٤/٦٨٣) ٧٨٦١٩- قال قتادة بن دعامة: <q>﴿بِما تُبْصِرُونَ﴾</q> أقسم بالأشياء كلّها، فيَدخل فيه جميع المخلوقات والموجودات. وقال: أقسم بالدنيا والآخرة{2}٦٧٧٤. (ز) ٦٧٧٤ ذكر ابنُ عطية (٨/٣٩٦) هذا القول، وقولًا آخر وهو أنه أراد بالقَسم: الأجساد والأرواح. وعلَّق عليه بقوله: «وهذا قول حسن عام». ٧٨٦٢٠- قال جعفر الصادق: <q>﴿بِما تُبْصِرُونَ﴾</q> مِن صُنعي في مُلكي، <q>﴿وما لا تُبْصِرُونَ﴾</q> مِن بِرّي بأوليائي{3}. (ز) ٧٨٦٢١- قال مقاتل بن سليمان: <q>﴿فَلا أُقْسِمُ بِما تُبْصِرُونَ﴾</q> مِن الخَلْق، <q>﴿وما لا تُبْصِرُونَ﴾</q> من الخَلْق{4}. (ز) ٧٨٦٢٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَلا أُقْسِمُ بِما تُبْصِرُونَ وما لا تُبْصِرُونَ﴾</q>، قال: أقسم بالأشياء، حتى أقسم بما تُبصرون وما لا تُبصرون{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٢.تفسير البغوي ٨/٢١٤.تفسير الثعلبي ١٠/٣٢.تفسير مقاتل بن سليمان ٤/٤٢٤.أخرجه ابن جرير ٢٣/٢٤١.
  69,39,""
69,40," <q>﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾</q> الآيات - نزول الآيات ٧٨٦٢٣- قال مقاتل بن سليمان: قال الوليد بن المُغيرة: إنّ محمدًا ساحر. فقال أبو جهل بن هشام: بل هو مجنون. فقال عُقبة بن أبي مُعَيْط: بل هو شاعر. وقال النّضر: كاهن. وقال أُبَيّ: كذّاب. فبرّأه الله من قولهم{1}. (ز) <q>﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾</q> - تفسير ٧٨٦٢٤- قال مقاتل بن سليمان: ... فأَقسم الله بالخَلْق <q>﴿إنَّهُ﴾</q> إنّ هذا القرآن <q>﴿لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q> على الله، يعني: جبريل ﵇ عن قول الله تعالى{1}٦٧٧٥. (ز) ٦٧٧٥ ذكر ابنُ عطية (٨/٣٩٦) هذا القول، وذكر قولًا آخر بأنّ «الرسول» هو محمد ﷺ، وأنه أُضيف القول إليه من حيث تلاه وبلغه. ورجَّح ابنُ تيمية (٦/٣٩١-٣٩٢) -مستندًا إلى السياق- أنّ «الرسول» هو محمد ﷺ، فقال: «فهذا محمد كما يدلّ عليه الكلام كلّه، وهذا قول عامة العلماء». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.تفسير مقاتل بن سليمان ٤/٤٢٥.
69,41," <q>﴿وَمَا هُوَ بِقَوۡلِ شَاعِرࣲۚ قَلِیلࣰا مَّا تُؤۡمِنُونَ ۝٤١ وَلَا بِقَوۡلِ كَاهِنࣲۚ قَلِیلࣰا مَّا تَذَكَّرُونَ ۝٤٢﴾</q> - تفسير ٧٨٦٢٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما هُوَ بِقَوْلِ شاعِرٍ﴾</q> قال: طهّره الله وعَصمه، <q>﴿ولا بِقَوْلِ كاهِنٍ﴾</q> قال: طهّره مِن الكهانة وعَصمه منها{1}. (١٤/٦٨٣) ٧٨٦٢٦- قال مقاتل بن سليمان: <q>﴿وما هُوَ بِقَوْلِ شاعِرٍ﴾</q> لقول عُتبة، وقول أبي جهل، <q>﴿قَلِيلًا ما تُؤْمِنُونَ﴾</q> يعني: قليلًا ما تُصدِّقون بالقرآن، يعني بالقليل: أنهم لا يؤمنون، ثم قال: <q>﴿ولا﴾</q> هو، يعني: القرآن <q>﴿بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ﴾</q> فتَعتبرون{2}٦٧٧٦. (ز) ٦٧٧٦ ذكر ابنُ عطية (٨/٣٩٧) أنّ <q>﴿ما﴾</q> في قوله: <q>﴿قليلا ما تؤمنون﴾</q> يحتمل أن تكون نافية فينتفي إيمانهم البتة، ويحتمل أن تكون مصدرية ويَتصف بالقلة إمّا الإيمان وإمّا العدد الذي يؤمنون، ثم قال: «فعلى اتصاف إيمانهم بالقلّة فهو الإيمان اللغوي؛ لأنهم قد صَدّقوا بأشياء يسيرة لا تُغني عنهم شيئًا؛ إذ كانوا يُصدِّقون أنّ الخير والصلة والعفاف الذي كان يأمر به رسول الله ﷺ هو حقٌّ صواب». ",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,42,""
69,43," <q>﴿تَنزِیلࣱ مِّن رَّبِّ ٱلۡعَـٰلَمِینَ ۝٤٣﴾</q> - تفسير ٧٨٦٢٧- قال مقاتل بن سليمان: فأَكذبهم الله، فقال: بل القرآن <q>﴿تَنْزِيلٌ مِن رَبِّ العالَمِينَ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.
69,44," <q>﴿وَلَوۡ تَقَوَّلَ عَلَیۡنَا بَعۡضَ ٱلۡأَقَاوِیلِ ۝٤٤﴾</q> - تفسير ٧٨٦٢٨- عن يزيد بن عامر السّوائي: أنهم بينما هم يطوفون بالطّاغية إذ سمعوا مُتكلّمًا وهو يقول: <q>﴿ولَوْ تَقَوَّلَ عَلَيْنا بَعْضَ الأَقاوِيلِ لَأَخَذْنا مِنهُ بِاليَمِينِ ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</q> [الحاقة:٤٤-٤٦]، ففَزعنا لذلك، وقلنا: ما هذا الكلام الذي لا نَعرفه؟! فنَظرنا، فإذا النبي ﷺ مُنطلقًا{1}. (١٤/٦٨٤) ٧٨٦٢٩- قال مقاتل بن سليمان: <q>﴿ولَوْ تَقَوَّلَ عَلَيْنا﴾</q> محمدٌ شيئًا منه <q>﴿بَعْضَ الأَقاوِيلِ﴾</q> يعني: مِن تلقاء نفسه ما لم نَقُل{2}. (ز) ",footnotes:1:أخرجه الطبراني في الأوسط (٨٩٢٢).تفسير مقاتل بن سليمان ٤/٤٢٥.
69,45," <q>﴿لَأَخَذۡنَا مِنۡهُ بِٱلۡیَمِینِ ۝٤٥﴾</q> - تفسير ٧٨٦٣٠- عن عبد الله بن عباس، في قوله: <q>﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</q>، قال: بقدرة{1}٦٧٧٧. (١٤/٦٨٤) ٦٧٧٧ ساق ابنُ عطية (٨/٣٩٧) قول ابن عباس، ثم علَّق بقوله: «ومعناه: لَنِلنا منه عقابه بقوة منا، أو يكون المعنى: لنَزعنا قوته». ثم ذكر قولًا آخر وهو أنها عبارة عن الهوان، كما يقال لمن يُسجن أو يقام لعقوبة: قد أُخذ بيده وبيمينه. وبنحوه قال ابنُ القيم (٣/١٩٢). ٧٨٦٣١- قال الحسن البصري: <q>﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</q> لقَطعنا يده اليمنى{2}. (ز) ٧٨٦٣٢- عن الحكم [بن عتيبة]، في قوله: <q>﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</q>، قال: بالحق{3}. (١٤/٦٨٤) ٧٨٦٣٣- قال مقاتل بن سليمان: <q>﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</q> يقول: لانتقمنا منه بالحق، كقوله: <q>﴿تَأْتُونَنا عَنِ اليَمِينِ﴾</q> [الصافات:٢٨] يعني: مِن قِبَل الحق، بأنكم على الحق{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٣-.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٢٥.
69,46," <q>﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾</q> - تفسير ٧٨٦٣٤- عن عبد الله بن عباس -من طريق علي- قال: الوتين: عِرْقُ القلب{1}. (١٤/٦٨٤) ٧٨٦٣٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</q>، قال: نِياط القلب{2}. (١٤/٦٨٤) ٧٨٦٣٦- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿الوَتِينَ﴾</q>، قال: هو حَبل القلب الذي في الظهر{3}. (١٤/٦٨٤) ٧٨٦٣٧- عن سعيد بن جُبَير -من طريق عطاء بن السّائِب- في قوله: <q>﴿ثم لقطعنا منه الوتين﴾</q>، قال: نِياطُ القلب{4}. (ز) ٧٨٦٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: الوَتِين: الحَبل الذي في الظهر{5}. (١٤/٦٨٥) ٧٨٦٣٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿لَقَطَعْنا مِنهُ الوَتِينَ﴾</q>: وتِين القلب؛ وهو عِرق يكون في القلب، فإذا قُطع مات الإنسان{6}. (ز) ٧٨٦٤٠- عن عكرمة مولى ابن عباس، قال: الوَتِين: نِياط القلب{7}. (١٤/٦٨٥) ٧٨٦٤١- عن عكرمة مولى ابن عباس، قال: إذا انقطع الوَتِين، لا إن جاع عِرق، ولا إن شَبع عِرق{8}. (١٤/٦٨٥) ٧٨٦٤٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</q>، قال: كُنّا نُحدَّث أنه حَبل القلب{9}. (١٤/٦٨٥) ٧٨٦٤٣- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله: <q>﴿لقطعنا منه الوتين﴾</q>، قال: نِياط القلب{10}. (ز) ٧٨٦٤٤- قال مقاتل بن سليمان: <q>﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</q> يعني: عِرق يكون في القلب، وهو نِياط القلب، وإذا انقطع مات صاحبه{11}. (ز) ٧٨٦٤٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</q>، قال: الوَتِين: نِياط القلب، الذي القلب مُتعلّق به{6}٦٧٧٨. (ز) ٦٧٧٨ ذكر ابنُ القيم (٣/١٩٢) أنّ هذا القول قول جميع أهل اللغة. <q>﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾</q> - آثار متعلقة بالآية ٧٨٦٤٦- قال عبد الله بن عباس -من طريق حُصين-: إذا احتُضر الإنسان أتاه مَلَك الموت، فغَمز وتِينه، فإذا انقطع الوَتِين خرج روحُه، فهناك حين يَشخَص بصرُه، وتَتبعه روحه{13}. (١٤/٦٨٥) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٤. وعزاه السيوطي إلى ابن المنذر.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٤٧، والفتح ٨/٦٦٤-، وابن جرير ٢٣/٢٤٤، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٤٧، والفتح ٨/٦٦٤-، والحاكم ٢/٥٠١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الحاكم ٢/٥٠١، وابن جرير ٢٣/٢٤٤ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٣ (٢٢٩١).أخرجه ابن جرير ٢٣/٢٤٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٤٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٤٢٥.أخرجه ابن جرير ٢٣/٢٤٥.عزاه السيوطي إلى ابن أبي حاتم.
69,47," <q>﴿فَمَا مِنكُم مِّنۡ أَحَدٍ عَنۡهُ حَـٰجِزِینَ ۝٤٧﴾</q> - تفسير ٧٨٦٤٧- قال مقاتل بن سليمان: <q>﴿فَما مِنكُمْ مِن أحَدٍ عَنْهُ حاجِزِينَ﴾</q> ليس أحد منكم يَحجز الرّبّ عن ذلك{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.
69,48," <q>﴿وَإِنَّهُۥ لَتَذۡكِرَةࣱ لِّلۡمُتَّقِینَ ۝٤٨ وَإِنَّا لَنَعۡلَمُ أَنَّ مِنكُم مُّكَذِّبِینَ ۝٤٩ وَإِنَّهُۥ لَحَسۡرَةٌ عَلَى ٱلۡكَـٰفِرِینَ ۝٥٠ وَإِنَّهُۥ لَحَقُّ ٱلۡیَقِینِ ۝٥١﴾</q> - تفسير ٧٨٦٤٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإنَّهُ لَتَذْكِرَةٌ لِلْمُتَّقِينَ﴾</q> يعني: هذا القرآن، <q>﴿وإنَّهُ لَحَسْرَةٌ عَلى الكافِرِينَ﴾</q> قال: ذاكم يوم القيامة{1}٦٧٧٩. (١٤/٦٨٥) ٦٧٧٩ على قول قتادة فالضمير في قوله: <q>﴿وإنه لحسرة﴾</q> عائد على التكذيب. وذكر ابنُ كثير (١٤/١٢٣) احتمالًا آخر بعوْد الضمير على القرآن، أي: وإنّ القرآن والإيمان به لحسرة في نفس الأمر على الكافرين. ثم قال: «كما قال: <q>﴿كذلك سلكناه في قلوب المجرمين لا يؤمنون به﴾</q> [الشعراء:٢٠٠-٢٠١]». ٧٨٦٤٩- قال مقاتل بن سليمان: <q>﴿وإنَّهُ﴾</q> وإنّ هذا القرآن <q>﴿لَتَذْكِرَةٌ لِلْمُتَّقِينَ وإنّا لَنَعْلَمُ﴾</q> يا أهل مكة <q>﴿أنَّ مِنكُمْ مُكَذِّبِينَ وإنَّهُ لَحَسْرَةٌ عَلى الكافِرِينَ﴾</q> يوم القيامة، <q>﴿وإنَّهُ﴾</q> وإنّ هذا القرآن <q>﴿لَحَقُّ اليَقِينِ﴾</q> أنّه مِن الله تعالى{2}. (ز) ٧٨٦٥٠- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وإنَّهُ لَتَذْكِرَةٌ﴾</q>، <q>﴿وإنَّهُ لَحَسْرَةٌ﴾</q>، <q>﴿وإنَّهُ لَحَقُّ اليَقِينِ﴾</q>، قال: القرآن{3}٦٧٨٠. (١٤/٦٨٥) ٦٧٨٠ ذكر ابنُ عطية (٨/٣٩٨) أنّ الضمير في قوله: <q>﴿وإنه لتذكرة﴾</q> قيل بعوْده على القرآن، وقيل بعوْده على النبي محمد ﷺ. ",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢٥-٤٢٦.عزاه السيوطي إلى ابن المنذر.
