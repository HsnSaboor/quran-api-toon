quran[28]{c,v,t}:
  69,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَیۡسَ لَهُ ٱلۡیَوۡمَ هَـٰهُنَا حَمِیمࣱ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَيْسَ لَهُ اليَوْمَ﴾</span> في الآخرة <span class="qpc-hafs">﴿هاهُنا حَمِيمٌ﴾</span> يعني: قريب يَشفع له{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَلَيْسَ لَهُ اليَوْمَ هاهُنا حَمِيمٌ﴾</span>: القريب في كلام العرب{2}<span class=comment-ref>٦٧٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٢</span> نسب <u>ابنُ عطية</u> (٨/٣٩٥) هذا القول لجمهور المفسرين، ثم قال: «فنفى الله تعالى أن يكون للكافر هنالك مَن يواليه». ثم <span class="comment-type-4">نقل</span> عن محمد بن المستنير القول بأنّ «الحميم»: الماء السّخن. و<span class="comment-type-4">علَّق</span> بقوله: «فكأنه تعالى أخبر أنّ الكافر ليس له ماء، ولا شيء مائع».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٤.أخرجه ابن جرير ٢٣/٢٤٠.
  69,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِینࣲ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: ما أدري ما الغِسلين، ولكني أظنّه الزّقوم{1}. (١٤/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: لو أنّ قَطرة مِن غِسلِين وقَعتْ في الأرض أفسدتْ على الناس مَعايشهم، ولو أنّ النار أُبرزتْ في صعيد لم يمرّ بها شيء إلا مات{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الغِسلين: صَديد أهل النار{3}. (١٤/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الغِسلين: الدم والماء الذي يَسيل من لحومهم{4}. (١٤/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- قال: الغِسلين: اسم طعام مِن أطعمة أهل النار{5}. (١٤/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿غِسْلِينٍ﴾</span>، قال: هو الضّريع، شجرة يأكل منها أهل النار{6}. (١٤/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولا طَعامٌ إلّا مِن غِسْلِينٍ﴾</span> شر الطعام وأَخبثه وأَبشعه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٨<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿ولا طَعامٌ إلا مِن غِسْلِينٍ﴾</span> هو شجر يأكله أهل النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا﴾</span> وليس له <span class="qpc-hafs">﴿طَعامٌ إلّا مِن غِسْلِينٍ﴾</span> يعني: الذي يَسيل مِن القَيْح والدم من أهل النار، يعني: فليس له شَراب إلا مِن حميم مِن عَينٍ مِن أصل الجحيم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦١٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا طَعامٌ إلّا مِن غِسْلِينٍ﴾</span>، قال: الغِسلين والزّقُّومُ لا يَعلم أحدٌ ما هو{7}<span class=comment-ref>٦٧٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٥) أنّ بعض المفسرين قال: الغِسلين: هو شيء يجري من ضريع؛ لأن الله تعالى قد أخبر أنهم ليس لهم طعام إلا من ضريع، وفي أخرى إلا من غِسلين، فهما شيء واحد، أو اثنان مُتداخلان، ثم <span class="comment-type-4">قال</span>: «و<b>يحتمل</b> أن يكون الإخبار هنا عن طائفة وهناك عن طائفة، ويكون الغِسلين والضّريع مُتباينين، على ما يُفهم منهما في لسان العرب».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِینࣲ ۝٣٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦١١<span class="dash">-</span></span> عن أبي سعيد الخُدري، عن النبي ﷺ، قال: «<b>لو أنّ دَلوًا من غِسلين يُهراق في الدنيا لأَنتن أهل الدنيا</b>»{11}. (١٤/٦٨٢)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وأبي القاسم الزجاجي النحوي في أماليه.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٤٦ (٩٩).أخرجه ابن جرير ٢٣/٢٤٠، وابن أبي حاتم -كما في الإتقان ٢/٤٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٤٠ من طريق عطية. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١٧ (٨١)، ٦/٤٤١ (١٨٩)-. وعزاه السيوطي إلى ابن المنذر بلفظ: غسلين: شجرة في النار.أخرجه ابن جرير ٢٣/٢٤١.تفسير البغوي ٨/٢١٣، وتفسير الثعلبي ١٠/٣٢.تفسير مقاتل بن سليمان ٤/٤٢٤.أخرجه ابن جرير ٢٣/٢٤١.أخرجه الحاكم ٢/٥٤٤ (٣٨٥٠). وأخرجه بلفظ: «غسّاق» أحمد ١٧/٣٣١ (١١٢٣٠)، ١٨/٣١٠ (١١٧٨٦)، والترمذي ٤/٥٤٠-٥٤١ (٢٧٦٦)، والحاكم ٤/٦٤٤ (٨٧٧٩)، وابن جرير ٢٠/١٣٠، ٢٤/٣١-٣٢. من طريق درّاج، عن أبي الهيثم، عن أبي سعيد به.</p><p>قال الترمذي: «هذا حديث إنما نعرفه من حديث رشدين بن سعد، وفي رشدين بن سعد مقال، وقد تُكلّم فيه من قِبل حفظه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».
  69,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا یَأۡكُلُهُۥۤ إِلَّا ٱلۡخَـٰطِـُٔونَ ۝٣٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٨٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الدِّهْقان- أنه قرأ: <span class="qpc-hafs">﴿لا يَأْكُلُهُ إلّا الخاطِئُونَ﴾</span> مهموزة{1}. (١٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦١٣<span class="dash">-</span></span> عن صَعْصَعة بن صُوحان، قال: جاء أعرابيٌّ إلى <span class="name-1">علي بن أبي طالب</span>، فقال: كيف تقرأ هذا الحرف: ‹لا يَأْكُلُهُ إلّا الخاطُونَ›؟ كلٌّ -واللهِ- يخطو! فتبسّم عليٌّ، وقال: يا أعرابيُّ، <span class="qpc-hafs">﴿لا يَأْكُلُهُ إلّا الخاطِئُونَ﴾</span>. قال: صدقتَ -واللهِ- يا أمير المؤمنين، ما كان الله ليُسلِم عبده. ثم التَفتَ عليٌّ إلى أبي الأسود، فقال: إنّ الأعاجم قد دَخلتْ في الدّين كافة، فضَع للناس شيئًا يَستدلّون به على صلاح ألسنتهم. فرَسم له الرفع، والنصب، والخفض{2}. (١٤/٦٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الأسود الدؤلي، ويحيى بن يَعْمر- قال: ما (الخاطُونَ)؟! إنما هو: <span class="qpc-hafs">﴿الخاطِئُونَ﴾</span>. ما ‹الصّابُونَ›؟! إنما هو: <span class="qpc-hafs">﴿الصّابِئُونَ﴾</span>{3}. (١٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> أنه كان يقرأ: ‹لا يَأْكُلُهُ إلّا الخاطِيُونَ› لا يَهمز{4}. (١٤/٦٨٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّا یَأۡكُلُهُۥۤ إِلَّا ٱلۡخَـٰطِـُٔونَ ۝٣٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦١٦<span class="dash">-</span></span> عن عكرمة، قال: قرأ نافعٌ عند <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا يأكله إلا الخاطئون﴾</span>. فقال: مَه، كُلّنا نخطئ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَأْكُلُهُ إلّا الخاطِئُونَ﴾</span> يعني: المجرمين{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري في تاريخه ٤/٢٩٤. وعزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة؛ إلا حمزة عند الوقف فقرأ ‹إلّا الخاطُونَ› بالحذف على وجه، و‹إلّا الخاطِيُونَ› بإبدال الهمز ياء على وجه آخر. انظر: الوافي في شرح الشاطبية ص١٢٠-١٢١.أخرجه البيهقي في شعب الإيمان (١٦٨٤).أخرجه الحاكم ٢/٥٠١.</p><p>و‹الصّابُونَ› قراءة متواترة، قرأ بها نافع، وأبو جعفر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿الصّابِئُونَ﴾</span> بالهمز. انظر: الإتحاف ص١٨١.عزاه السيوطي إلى سعيد بن منصور.أخرجه الواحدي في الوسيط ٤/٣٤٨.تفسير مقاتل بن سليمان ٤/٤٢٤.
  69,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَاۤ أُقۡسِمُ بِمَا تُبۡصِرُونَ ۝٣٨ وَمَا لَا تُبۡصِرُونَ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِما تُبْصِرُونَ وما لا تُبْصِرُونَ﴾</span>، يقول: بما تَرون، وما لا تَرون{1}. (١٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦١٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿بِما تُبْصِرُونَ﴾</span> أقسم بالأشياء كلّها، فيَدخل فيه جميع المخلوقات والموجودات. وقال: أقسم بالدنيا والآخرة{2}<span class=comment-ref>٦٧٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٦) هذا القول، و<b>قولًا آخر</b> وهو أنه أراد بالقَسم: الأجساد والأرواح. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا قول حسن <span class="mustanad">عام</span>».</div></p><p><div></p><p><p><span class="item-no">٧٨٦٢٠<span class="dash">-</span></span> قال <span class="name-3">جعفر الصادق</span>: <span class="qpc-hafs">﴿بِما تُبْصِرُونَ﴾</span> مِن صُنعي في مُلكي، <span class="qpc-hafs">﴿وما لا تُبْصِرُونَ﴾</span> مِن بِرّي بأوليائي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِما تُبْصِرُونَ﴾</span> مِن الخَلْق، <span class="qpc-hafs">﴿وما لا تُبْصِرُونَ﴾</span> من الخَلْق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٢٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِما تُبْصِرُونَ وما لا تُبْصِرُونَ﴾</span>، قال: أقسم بالأشياء، حتى أقسم بما تُبصرون وما لا تُبصرون{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٢.تفسير البغوي ٨/٢١٤.تفسير الثعلبي ١٠/٣٢.تفسير مقاتل بن سليمان ٤/٤٢٤.أخرجه ابن جرير ٢٣/٢٤١.
  69,39,""
  69,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾</span> الآيات - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال الوليد بن المُغيرة: إنّ محمدًا ساحر. فقال أبو جهل بن هشام: بل هو مجنون. فقال عُقبة بن أبي مُعَيْط: بل هو شاعر. وقال النّضر: كاهن. وقال أُبَيّ: كذّاب. فبرّأه الله من قولهم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فأَقسم الله بالخَلْق <span class="qpc-hafs">﴿إنَّهُ﴾</span> إنّ هذا القرآن <span class="qpc-hafs">﴿لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</span> على الله، يعني: جبريل ﵇ عن قول الله تعالى{1}<span class=comment-ref>٦٧٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٦) هذا القول، و<span class="comment-type-4">ذكر</span> قولًا آخر بأنّ «الرسول» هو محمد ﷺ، وأنه أُضيف القول إليه من حيث تلاه وبلغه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٦/٣٩١-٣٩٢) -<span class="mustanad">مستندًا إلى السياق</span>- أنّ «الرسول» هو محمد ﷺ، فقال: «فهذا محمد كما يدلّ عليه الكلام كلّه، وهذا قول عامة العلماء».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا هُوَ بِقَوۡلِ شَاعِرࣲۚ قَلِیلࣰا مَّا تُؤۡمِنُونَ ۝٤١ وَلَا بِقَوۡلِ كَاهِنࣲۚ قَلِیلࣰا مَّا تَذَكَّرُونَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما هُوَ بِقَوْلِ شاعِرٍ﴾</span> قال: طهّره الله وعَصمه، <span class="qpc-hafs">﴿ولا بِقَوْلِ كاهِنٍ﴾</span> قال: طهّره مِن الكهانة وعَصمه منها{1}. (١٤/٦٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما هُوَ بِقَوْلِ شاعِرٍ﴾</span> لقول عُتبة، وقول أبي جهل، <span class="qpc-hafs">﴿قَلِيلًا ما تُؤْمِنُونَ﴾</span> يعني: قليلًا ما تُصدِّقون بالقرآن، يعني بالقليل: أنهم لا يؤمنون، ثم قال: <span class="qpc-hafs">﴿ولا﴾</span> هو، يعني: القرآن <span class="qpc-hafs">﴿بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ﴾</span> فتَعتبرون{2}<span class=comment-ref>٦٧٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٧) أنّ <span class="qpc-hafs">﴿ما﴾</span> في قوله: <span class="qpc-hafs">﴿قليلا ما تؤمنون﴾</span> <b>يحتمل</b> أن تكون نافية فينتفي إيمانهم البتة، و<b>يحتمل</b> أن تكون مصدرية ويَتصف بالقلة إمّا الإيمان وإمّا العدد الذي يؤمنون، ثم قال: «فعلى اتصاف إيمانهم بالقلّة فهو الإيمان اللغوي؛ لأنهم قد صَدّقوا بأشياء يسيرة لا تُغني عنهم شيئًا؛ إذ كانوا يُصدِّقون أنّ الخير والصلة والعفاف الذي كان يأمر به رسول الله ﷺ هو حقٌّ صواب».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,42,""
  69,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَنزِیلࣱ مِّن رَّبِّ ٱلۡعَـٰلَمِینَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأَكذبهم الله، فقال: بل القرآن <span class="qpc-hafs">﴿تَنْزِيلٌ مِن رَبِّ العالَمِينَ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ تَقَوَّلَ عَلَیۡنَا بَعۡضَ ٱلۡأَقَاوِیلِ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٢٨<span class="dash">-</span></span> عن يزيد بن عامر السّوائي: أنهم بينما هم يطوفون بالطّاغية إذ سمعوا مُتكلّمًا وهو يقول: <span class="qpc-hafs">﴿ولَوْ تَقَوَّلَ عَلَيْنا بَعْضَ الأَقاوِيلِ لَأَخَذْنا مِنهُ بِاليَمِينِ ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span> [الحاقة:٤٤-٤٦]، ففَزعنا لذلك، وقلنا: ما هذا الكلام الذي لا نَعرفه؟! فنَظرنا، فإذا النبي ﷺ مُنطلقًا{1}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ تَقَوَّلَ عَلَيْنا﴾</span> محمدٌ شيئًا منه <span class="qpc-hafs">﴿بَعْضَ الأَقاوِيلِ﴾</span> يعني: مِن تلقاء نفسه ما لم نَقُل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الأوسط (٨٩٢٢).تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَأَخَذۡنَا مِنۡهُ بِٱلۡیَمِینِ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span>، قال: بقدرة{1}<span class=comment-ref>٦٧٧٧</span>. (١٤/٦٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٧</span> ساق <u>ابنُ عطية</u> (٨/٣٩٧) قول ابن عباس، ثم <span class="comment-type-4">علَّق</span> بقوله: «ومعناه: لَنِلنا منه عقابه بقوة منا، أو يكون المعنى: لنَزعنا قوته». ثم <span class="comment-type-4">ذكر</span> قولًا آخر وهو أنها عبارة عن الهوان، كما يقال لمن يُسجن أو يقام لعقوبة: قد أُخذ بيده وبيمينه.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٣/١٩٢).</div></p><p><div></p><p><p><span class="item-no">٧٨٦٣١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span> لقَطعنا يده اليمنى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٢<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span>، في قوله: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span>، قال: بالحق{3}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَأَخَذْنا مِنهُ بِاليَمِينِ﴾</span> يقول: لانتقمنا منه بالحق، كقوله: <span class="qpc-hafs">﴿تَأْتُونَنا عَنِ اليَمِينِ﴾</span> [الصافات:٢٨] يعني: مِن قِبَل الحق، بأنكم على الحق{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٣-.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الوتين: عِرْقُ القلب{1}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>، قال: نِياط القلب{2}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿الوَتِينَ﴾</span>، قال: هو حَبل القلب الذي في الظهر{3}. (١٤/٦٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء بن السّائِب- في قوله: <span class="qpc-hafs">﴿ثم لقطعنا منه الوتين﴾</span>، قال: نِياطُ القلب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: الوَتِين: الحَبل الذي في الظهر{5}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>: وتِين القلب؛ وهو عِرق يكون في القلب، فإذا قُطع مات الإنسان{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الوَتِين: نِياط القلب{7}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: إذا انقطع الوَتِين، لا إن جاع عِرق، ولا إن شَبع عِرق{8}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>، قال: كُنّا نُحدَّث أنه حَبل القلب{9}. (١٤/٦٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله: <span class="qpc-hafs">﴿لقطعنا منه الوتين﴾</span>، قال: نِياط القلب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span> يعني: عِرق يكون في القلب، وهو نِياط القلب، وإذا انقطع مات صاحبه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ﴾</span>، قال: الوَتِين: نِياط القلب، الذي القلب مُتعلّق به{6}<span class=comment-ref>٦٧٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/١٩٢) أنّ هذا القول قول جميع أهل اللغة.</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٤٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق حُصين-: إذا احتُضر الإنسان أتاه مَلَك الموت، فغَمز وتِينه، فإذا انقطع الوَتِين خرج روحُه، فهناك حين يَشخَص بصرُه، وتَتبعه روحه{13}. (١٤/٦٨٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٤. وعزاه السيوطي إلى ابن المنذر.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٤٧، والفتح ٨/٦٦٤-، وابن جرير ٢٣/٢٤٤، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٤٧، والفتح ٨/٦٦٤-، والحاكم ٢/٥٠١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الحاكم ٢/٥٠١، وابن جرير ٢٣/٢٤٤ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٣ (٢٢٩١).أخرجه ابن جرير ٢٣/٢٤٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٤٥.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.تفسير مقاتل بن سليمان ٤/٤٢٥.أخرجه ابن جرير ٢٣/٢٤٥.عزاه السيوطي إلى ابن أبي حاتم.
  69,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا مِنكُم مِّنۡ أَحَدٍ عَنۡهُ حَـٰجِزِینَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما مِنكُمْ مِن أحَدٍ عَنْهُ حاجِزِينَ﴾</span> ليس أحد منكم يَحجز الرّبّ عن ذلك{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٥.
  69,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَتَذۡكِرَةࣱ لِّلۡمُتَّقِینَ ۝٤٨ وَإِنَّا لَنَعۡلَمُ أَنَّ مِنكُم مُّكَذِّبِینَ ۝٤٩ وَإِنَّهُۥ لَحَسۡرَةٌ عَلَى ٱلۡكَـٰفِرِینَ ۝٥٠ وَإِنَّهُۥ لَحَقُّ ٱلۡیَقِینِ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإنَّهُ لَتَذْكِرَةٌ لِلْمُتَّقِينَ﴾</span> يعني: هذا القرآن، <span class="qpc-hafs">﴿وإنَّهُ لَحَسْرَةٌ عَلى الكافِرِينَ﴾</span> قال: ذاكم يوم القيامة{1}<span class=comment-ref>٦٧٧٩</span>. (١٤/٦٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٩</span> على قول قتادة فالضمير في قوله: <span class="qpc-hafs">﴿وإنه لحسرة﴾</span> عائد على التكذيب.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١٢٣) <b>احتمالًا آخر</b> بعوْد الضمير على القرآن، أي: وإنّ القرآن والإيمان به لحسرة في نفس الأمر على الكافرين. ثم قال: «<span class="mustanad">كما قال</span>: <span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين لا يؤمنون به﴾</span> [الشعراء:٢٠٠-٢٠١]».</div></p><p><div></p><p><p><span class="item-no">٧٨٦٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّهُ﴾</span> وإنّ هذا القرآن <span class="qpc-hafs">﴿لَتَذْكِرَةٌ لِلْمُتَّقِينَ وإنّا لَنَعْلَمُ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿أنَّ مِنكُمْ مُكَذِّبِينَ وإنَّهُ لَحَسْرَةٌ عَلى الكافِرِينَ﴾</span> يوم القيامة، <span class="qpc-hafs">﴿وإنَّهُ﴾</span> وإنّ هذا القرآن <span class="qpc-hafs">﴿لَحَقُّ اليَقِينِ﴾</span> أنّه مِن الله تعالى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وإنَّهُ لَتَذْكِرَةٌ﴾</span>، <span class="qpc-hafs">﴿وإنَّهُ لَحَسْرَةٌ﴾</span>، <span class="qpc-hafs">﴿وإنَّهُ لَحَقُّ اليَقِينِ﴾</span>، قال: القرآن{3}<span class=comment-ref>٦٧٨٠</span>. (١٤/٦٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٨) أنّ الضمير في قوله: <span class="qpc-hafs">﴿وإنه لتذكرة﴾</span> <b>قيل</b> بعوْده على القرآن، و<b>قيل</b> بعوْده على النبي محمد ﷺ.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢٥-٤٢٦.عزاه السيوطي إلى ابن المنذر.
  69,49,""
  69,50,""
  69,51,""
  69,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِیمِ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسَبِّحْ﴾</span> يا محمد، يعني: التوحيد <span class="qpc-hafs">﴿بِاسْمِ رَبِّكَ العَظِيمِ﴾</span> يقول: اذكر اسم ربّك، يعني: التوحيد. ثم قال: <span class="qpc-hafs">﴿العَظِيمِ﴾</span> يعني: الرّبّ العظيم، فلا أكبر منه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِیمِ ۝٥٢﴾</span> - آثار متعلقة بالآيات</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق شُريح بن عُبيد- قال: خَرجتُ أتعرّض رسول الله ﷺ قبل أنْ أُسلم، فوجَدتُه قد سبقني إلى المسجد، فقمتُ خَلفه، فاستفتحَ سورة الحاقة، فجَعلتُ أعجب مِن تأليف القرآن، قال: فقلتُ: هذا -واللهِ- شاعرٌ كما قالتْ قريش. قال: فقرأ: <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ وما هُوَ بِقَوْلِ شاعِرٍ قَلِيلًا ما تُؤْمِنُونَ﴾</span>. قال: قلتُ: كاهن. قال: <span class="qpc-hafs">﴿ولا بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ تَنْزِيلٌ مِن رَبِّ العالَمِينَ ولَوْ تَقَوَّلَ عَلَيْنا بَعْضَ الأَقاوِيلِ لَأَخَذْنا مِنهُ بِاليَمِينِ ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ فَما مِنكُمْ مِن أحَدٍ عَنْهُ حاجِزِينَ﴾</span> إلى آخر السورة. قال: فوقع الإسلام في قلبي كلّ موقع{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٦.أخرجه أحمد في مسنده ١/٢٦٢-٢٦٣ (١٠٧).</p><p>وضعّف المحققون إسناده.
  70,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٥٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة <span class="qpc-hafs">﴿سأل﴾</span> بمكة{1}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٤<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{2}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسَمّاها: <span class="qpc-hafs">﴿سأل سائل﴾</span>، ونزلت بعد الحاقة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٦<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٧<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسَمّياها: <span class="qpc-hafs">﴿سأل سائل﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٨<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٥٩<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، وسَمّاها: <span class="qpc-hafs">﴿سأل سائل﴾</span>، ونزلت بعد الحاقة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٠<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦١<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة المعارج مكّيّة، عددها أربع وأربعون آية كوفي{8}<span class=comment-ref>٦٧٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٩): «أنّ هذه السورة مكّيّة <span class="mustanad">بلا خلاف بين الرواة</span>».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ تيمية</u> (٦/٣٩٤).</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٤٩) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٣٣.
  70,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَأَلَ سَاۤىِٕلُۢ بِعَذَابࣲ وَاقِعࣲ ۝١ لِّلۡكَـٰفِرِینَ لَیۡسَ لَهُۥ دَافِعࣱ ۝٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>، قال: هو النَّضر بن الحارث، قال: <span class="qpc-hafs">﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ﴾</span> [الأنفال:٣٢]{1}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، مثله{2}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: نزلت: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</span>، فقال الناس: على مَن يقع العذاب؟ فأنزل الله: (عَلى الكافِرِينَ لَيْسَ لَهُ دافِعٌ){3}. (١٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>، قال: نَزَلَتْ بمكة في النَّضر بن الحارث وقد قال: <span class="qpc-hafs">﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ﴾</span> الآية [الأنفال:٣٢]، وكان عذابه يوم بدر{4}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</span> نزلت في النَّضر بن الحارث بن عَلقمة بن كلدة القُرشي مِن بني عبد الدار بن قُصي، وذلك أنه قال: اللهم إن كان ما يقول محمد هو الحق مِن عندك فأمطر علينا حجارة من السماء أو ائتنا بعذاب أليم. فقُتِل يوم بدر{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سَأَلَ سَاۤىِٕلُۢ بِعَذَابࣲ وَاقِعࣲ ۝١ لِّلۡكَـٰفِرِینَ لَیۡسَ لَهُۥ دَافِعࣱ ۝٢﴾</span> - تفسير الآية، وقراءاتها</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٦٧<span class="dash">-</span></span> قال <span class="name-1">زيد بن ثابت</span>: سال وادٍ مِن أودية جهنم يُقال له: سائل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: ‹سالَ سَآئِلٌ›، قال: سال وادٍ في جهنم{7}. (١٤/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بِعَذابٍ واقِعٍ﴾</span>، قال: كائن{8}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٠<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، مثله{2}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</span>، قال: ذاك سؤال الكفار عن عذاب الله، وهو واقع{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span> قال: دعا داعٍ. وفي قوله: <span class="qpc-hafs">﴿بِعَذابٍ واقِعٍ﴾</span> قال: يقع في الآخرة، وهو قولهم: <span class="qpc-hafs">﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</span> [الأنفال:٣٢]{11}. (١٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿بِعَذابٍ واقِعٍ لِلْكافِرِينَ﴾</span>، يقول: واقع على الكافرين{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: إنّ المشركين قالوا للنبيِّ ﷺ: لِمَن هذا العذابُ الذي تَذكر أنّه يكون في الآخرة؟ فقال الله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ بِعَذابٍ﴾</span> أي: عن عذاب <span class="qpc-hafs">﴿واقِعٍ لِلْكافِرِينَ﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٥<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، قال: قال رجلٌ مِن عبد الدار يُقال له: الحارث بن عَلقمة: <span class="qpc-hafs">﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</span> [الأنفال:٣٢]. فقال الله: <span class="qpc-hafs">﴿وقالُوا رَبَّنا عَجِّلْ لَنا قِطَّنا قَبْلَ يَوْمِ الحِسابِ﴾</span> [ص:١٦]. وقال الله: <span class="qpc-hafs">﴿ولَقَدْ جِئْتُمُونا فُرادى﴾</span> [الأنعام:٩٤]. وقال الله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</span> هو الذي قال: <span class="qpc-hafs">﴿إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ﴾</span>، وهو الذي قال: <span class="qpc-hafs">﴿رَبَّنا عَجِّلْ لَنا قِطَّنا﴾</span>، وهو الذي سأل عذابًا هو واقع به{14}. (١٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ﴾</span>، قال: سأل سائل عن عذاب واقع، فقال الله: <span class="qpc-hafs">﴿لِلْكافِرِينَ لَيْسَ لَهُ دافِعٌ مِنَ اللَّهِ﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>:... هذا العذاب الذي سأل النَّضر بن الحارث في الدنيا هو <span class="qpc-hafs">﴿لِلْكافِرينَ﴾</span> في الآخرة، <span class="qpc-hafs">﴿لَيْسَ لَهُ دافِعٌ* مِنَ اللَّهِ﴾</span> يقول: لا يَدفع عنهم أحدٌ حين يَقع بهم العذاب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿بِعَذابٍ واقِعٍ﴾</span> قال: يقع في الآخرة، قولهم في الدنيا: <span class="qpc-hafs">﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ﴾</span> [الأنفال:٣٢]، هو النَّضر بن الحارث{2}. (١٤/٦٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٧٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</span>، قال: قال بعض أهل العلم: هو وادٍ في جهنم، يُقال له: سائل{18}<span class=comment-ref>٦٧٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٢</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿سأل سائل﴾</span> على قولين: <b>الأول</b>: أنه من السؤال، ومَن قال بهذا قرأ قوله: <span class="qpc-hafs">﴿سأل سائل﴾</span> بالهمز. <b>الثاني</b>: أنه وادٍ في جهنم يقال له: سائل، ومَن قال بهذا قرأ: ‹سالَ سائِلٌ› بدون همز، ووجّهه إلى أنه فعْل من السّيل.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٢٤٨) -<span class="mustanad">مستندًا إلى إجماع القراء، والسلف من أهل التأويل</span>- قراءة الهمز، والقول الأول الذي قاله ابن عباس من طريق العَوفيّ، ومجاهد، والحسن، وعطاء، وقتادة، ومقاتل، وذلك: «لإجماع الحُجّة مِن القراء على ذلك، وأنّ عامة أهل التأويل من السلف بمعنى الهمز تأولوه».</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ كثير</u> (١٤/١٢٥) <span class="mustanad">مستندًا إلى السياق</span>، فقال: «والصحيح الأول؛ لدلالة السياق عليه». و<span class="comment-type-2">انتقد</span> القول الثاني الذي قاله زيد بن ثابت، وابن زيد، فقال: «وهذا القول ضعيف، بعيد عن المراد».</p><p>وساق <u>ابنُ عطية</u> (٨/٤٠١) القول الثاني، ثم <span class="comment-type-4">علَّق</span> بقوله: «ويحتمل -إن لم يصح أمر الوادي- أن يكون الإخبار عن نفوذ القَدَر بذلك العذاب، فاستُعير له لفظ السّيل؛ لِما عُهد من نفوذ السّيل وتصميمه». واختَلَف مَن قرأ بالهمز في المعنى المراد على قولين: <b>الأول</b>: أنّ المعنى: دعا داعٍ. <b>الثاني</b>: استفهم مُستفهم.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٩) أنّ على القول الأول الذي قاله مجاهد فالباء في قوله: <span class="qpc-hafs">﴿بعذاب﴾</span> على عُرفها. وأنه على القول الثاني الذي قاله الحسن، وقتادة، فالباء تُوصّل توصيل «عن»، كأنه تعالى قال: «عن عذاب».</div></p></div>",footnotes:1:أخرجه النسائي في الكبرى ١٠/٣١٢ (١١٥٥٦)، من طريق الأعمش، عن المنهال بن عمرو، عن سعيد بن جُبَير، عن ابن عباس به.</p><p>وسنده حسن.</p><p>وأخرجه ابن أبي حاتم ٥/١٦٩٠ (٩٠١٣)، من طريق الأعمش، عن رجل، عن سعيد بن جُبَير، عن ابن عباس به.</p><p>وسنده ضعيف مِن أجل الرجل المُبهَم فيه، ويحتمل أن يكون هو المنهال بن عمرو.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.</p><p>وقراءة الآية الثانية شاذة، تنسب إلى أبي بن كعب. ينظر: البحر المحيط ٨/٣٣٢.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٣٥.تفسير الثعلبي ١٠/٣٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.</p><p>قرأ بالألف من غير همز نافع وأبو جعفر وابن عامر، وقرأ الباقون بهمزة مفتوحة. ينظر: النشر ٢/٣٩٠.أخرجه النسائي في الكبرى (١١٦٢٠)، وابن أبي حاتم ٥/١٦٩٠، والحاكم ٢/٥٠٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٤٨.أخرجه ابن جرير ٢٣/٢٤٨-٢٤٩، وبنحوه من طريق ليث. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٥٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٤-.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٣/٣٤٤، وابن جرير ٢٣/٢٤٩، ومن طريق سعيد أيضًا.تفسير مقاتل بن سليمان ٤/٤٣٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٤٩.
  70,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مِّنَ ٱللَّهِ ذِی ٱلۡمَعَارِجِ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿مِنَ اللَّهِ ذِي المَعارِجِ﴾</span>، قال: ذي الدَّرجات{1}. (١٤/٦٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ذِي المَعارِجِ﴾</span>، قال: ذي العُلُوِّ والفواضل{2}<span class=comment-ref>٦٧٨٣</span>. (١٤/٦٨٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠١) أنّ المعارج على هذا القول مستعارة في الرُّتَب والصفات.</div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿مِنَ اللهِ ذِي المَعارِجِ﴾</span>، يعني: ذي السماوات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٣<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿ذِي المَعارِجِ﴾</span> ذي الدَّرجات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ذِي المَعارِجِ﴾</span>، قال: معارج السماء{5}. (١٤/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ذِي المَعارِجِ﴾</span>، قال: معارج الملائكة{6}. (١٤/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ذِي المَعارِجِ﴾</span>، قال: ذي الفضائل والنّعم{7}. (١٤/٦٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عظّم الرّبُّ -تبارك وتعالى- نفسه، فقال: <span class="qpc-hafs">﴿مِنَ اللَّهِ ذِي المَعارِجِ﴾</span> يعني: ذا الدرجات، يعني: السموات، والعرش فوقهم، والله تعالى على العرش. كقوله: <span class="qpc-hafs">﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</span> [الزخرف:٣٣]{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٨٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذِي المَعارِجِ﴾</span>، قال: الله ذو المعارج{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنَ ٱللَّهِ ذِی ٱلۡمَعَارِجِ ۝٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٨٩<span class="dash">-</span></span> عن عبد الله بن عباس، قال: آخرُ شيء حُفِظ عن رسول الله ﷺ قوله: «<b>رفيع الدَّرجات ذو المعارج، قد بلّغتُ</b>» ثلاثًا «<b>الصلاةَ، ومِلكَ اليمين</b>». ثلاثًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٠<span class="dash">-</span></span> عن <span class="name-1">سعد بن أبي وقّاص</span>، أنه سمع رجلًا يقول: لبّيك، ذا المعارج. فقال: إنه لذو المعارج، ولكنّا كُنّا مع رسول الله ﷺ لا نقول ذلك{11}. (١٤/٦٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى (١١٦٢٠)، وابن أبي حاتم ٥/١٦٩٠، والحاكم ٢/٥٠٢، وابن جرير ٢٣/٢٥١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٥٠. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٣٥، وتفسير البغوي ٨/٢٢٠.تفسير الثعلبي ١٠/٣٥، وتفسير البغوي ٨/٢٢٠.أخرجه ابن جرير ٢٣/٢٥١، وأبو الشيخ في العظمة (٥٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٥٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٥.أخرجه ابن جرير ٢٣/٢٥١.أخرجه أبو نعيم في أخبار أصبهان ١/٣٥٤.أخرجه أحمد ٣/٧٤ (١٤٧٥). وعلَّقه ابن خزيمة ٤/١٧٢.
  70,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَعۡرُجُ ٱلۡمَلَـٰۤىِٕكَةُ وَٱلرُّوحُ إِلَیۡهِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٩١<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿تَعْرُجُ المَلَآئِكَةُ﴾</span> بالتاء{1}. (١٤/٦٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٢<span class="dash">-</span></span> عن أبي إسحاق، قال: كان <span class="name-1">عبد الله [بن مسعود]</span> يقرأ: ‹يَعْرُجُ الـمَلَآئِكَةُ› بالياء{2}<span class=comment-ref>٦٧٨٤</span>. (١٤/٦٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٤</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿تعرج﴾</span>؛ <b>فقرأ قوم</b> بالتاء، و<b>قرأ آخرون</b> بالياء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٢٥٤) -<span class="mustanad">مستندًا إلى إجماع القراء</span>- قراءة التاء، فقال: «والصوابُ مِن قراءة ذلك عندنا ما عليه قراء الأمصار، وهو بالتاء؛ لإجماع الحُجّة من القُراء عليه».</div></p><p><h3><span class="qpc-hafs">﴿تَعۡرُجُ ٱلۡمَلَـٰۤىِٕكَةُ وَٱلرُّوحُ إِلَیۡهِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَعْرُجُ﴾</span> يعني: تصعد <span class="qpc-hafs">﴿المَلائِكَةُ﴾</span> مِن سماءٍ إلى سماءِ العرش <span class="qpc-hafs">﴿والرُّوحُ﴾</span> يعني: جبريل ﵇ <span class="qpc-hafs">﴿إلَيْهِ﴾</span> في الدنيا برِزق السموات السبع{3}<span class=comment-ref>٦٧٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠١) أنّ <span class="qpc-hafs">﴿الروح﴾</span> هو جبريل عند الجمهور، وأنه خَصّصه بالذكر تشريفًا. و<span class="comment-type-4">ذكر</span> قولين آخرين: <b>الأول</b>: أنّ الروح: ملائكة حفظة للملائكة الحافظين لبني آدم، لا تراهم الملائكة كما لا نرى نحن الملائكة. ونسبه لمجاهد. <b>الثاني</b>: أنه اسم الجنس في أرواح الحيوان. ونسبه لبعض المفسرين.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١٢٥) <b>قولًا ثالثًا</b>، ونسبه لأبي صالح، وهو أنّ الروح خَلْقٌ من خَلْق الله، يُشبِهون الناس، وليسوا أناسًا. ثم <span class="comment-type-4">علَّق</span> بقوله: «و<b>يحتمل</b> أن يكون المراد به جبريل، ويكون من باب عطف الخاص على العام. و<b>يحتمل</b> أن يكون اسم جنس لأرواح بني آدم، فإنها إذا قُبِضتْ يُصعَد بها إلى السماء، كما دلّ عليه حديث البراء».</div></p><p><h3><span class="qpc-hafs">﴿فِی یَوۡمࣲ كَانَ مِقۡدَارُهُۥ خَمۡسِینَ أَلۡفَ سَنَةࣲ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٦٩٤<span class="dash">-</span></span> عن أبي سعيد الخُدري، قال: سُئل رسول الله ﷺ عن: <span class="qpc-hafs">﴿يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span> ما أطول هذا اليوم! فقال: «<b>والذي نفسي بيده، إنه لَيُخفّف على المؤمن حتى يكون أهون عليه مِن صلاة مكتوبة يُصلّيها في الدنيا</b>»{4}<span class=comment-ref>٦٧٨٦</span>. (١٤/٦٩١)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٢) أنه على هذا فاليوم المشار إليه يوم القيامة، والقدْر في الهول والشدّة. ثم قال: «وهذا كما تقول في اليوم العصيب: إنه كسَنَة، ونحو هذا».</div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ليث، عن مجاهد- في قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: مُنتهى أمْره من أسفل الأرضين إلى مُنتهى أمْره مِن فوق سبع سموات مِقدار خمسين ألف سنة، و<span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾</span> [السجدة:٥] يعني بذلك: يَنزل الأمْرُ مِن السماء إلى الأرض ومن الأرض إلى السماء في يوم واحد، فذلك مِقداره ألف سنة؛ لأن ما بين السماء والأرض مسيرة خمسمائة عام{5}<span class=comment-ref>٦٧٨٧</span>. (١٤/٦٨٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٤/١٢٧) على هذا الأثر بقوله: «قد رواه ابن جرير عن ابن حميد، عن حكام بن سلم، عن عمر بن معروف، عن ليث، عن مجاهد قوله، لم يذكر ابن عباس».</div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الوهاب بن مجاهد بن جبر، عن أبيه- قال: غِلظ كلّ أرض خمسمائة عام، وبين كلّ أرض إلى أرض خمسمائة عام، ومن السماء إلى السماء خمسمائة عام، فذلك أربعة عشر ألف عام، وبين السماء السابعة وبين العرش مسيرة ستة وثلاثين ألف عام، فذلك قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>{6}. (١٤/٦٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ مِمّا تَعُدُّونَ﴾</span> [السجدة:٥]، قال: هذا في الدنيا؛ تَعرج الملائكة في يوم كان مِقداره ألف سنة. وفي قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>: فهذا يوم القيامة، جَعله الله على الكافرين مقدار خمسين ألف سنة{7}. (١٤/٦٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: لو قدّرتموه لكان خمسين ألف سنة مِن أيامكم. قال: يعني: يوم القيامة{8}<span class=comment-ref>٦٧٨٨</span>. (١٤/٦٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٤٠٢) على هذا القول بقوله: «وهذا هو <span class="mustanad">ظاهر قول النبي</span> ﷺ: «<b>ما من رجل لا يُؤدّي زكاة ماله إلا جُعل له صفائح من نار يوم القيامة، تُكوى بها جبهته وظهره وجنباه، في يوم كان مقداره ألف سنة</b>»». و<span class="comment-type-4">ذكر</span> أنه قد ورد في يوم القيامة أنه كألف سنة، و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا يشبه أن يكون في طوائف دون طوائف».</div></p><p><div></p><p><p><span class="item-no">٧٨٦٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مُلَيْكَة- أنّ رجلًا سأله عن يوم كان مِقداره ألف سنة. فقال: ما يوم كان مِقداره خمسين ألف سنة؟ قال: إنما سألتُك لتُخبِرني! قال: هما يومان ذكرهما الله في القرآن، الله أعلم بهما. فكَره أن يقول في كتاب الله ما لا يعلم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠١<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، معناه: لو ولي محاسبة العباد في ذلك اليوم غير الله لم يَفرغ منه خمسين ألف سنة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٢<span class="dash">-</span></span> عن عكرمة، قال: سأل رجلٌ <span class="name-1">ابنَ عباس</span>: ما هؤلاء الآيات: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، و<span class="qpc-hafs">﴿يُدَبِّرُ الأَمْرَ مِنَ السَّماءِ إلى الأَرْضِ ثُمَّ يَعْرُجُ إلَيْهِ فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ مِمّا تَعُدُّونَ﴾</span> [السجدة:٥]، <span class="qpc-hafs">﴿ويَسْتَعْجِلُونَكَ بِالعَذابِ ولَنْ يُخْلِفَ اللَّهُ وعْدَهُ وإنَّ يَوْمًا عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾</span> [الحج:٤٧]؟ قال: يوم القيامة حساب خمسين ألف سنة، وخلق الله السماوات والأرض في ستة أيام، كل يوم ألف سنة، و<span class="qpc-hafs">﴿يُدَبِّرُ الأَمْرَ مِنَ السَّماءِ إلى الأَرْضِ ثُمَّ يَعْرُجُ إلَيْهِ فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾</span> [السجدة:٥]، قال: ذلك مقدار المسير{11}. (١٤/٦٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: مِن مُنتهى أمْره مِن أسفل الأرضين إلى مُنتهى أمْره مِن فوق السماوات مقدار خمسين ألف سنة، و<span class="qpc-hafs">﴿يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾</span> [السجدة:٥]، يعني بذلك: نَزل الأمر من السماء إلى الأرض ومن الأرض إلى السماء في يوم واحد، فذلك مِقداره ألف سنة؛ لأن ما بين السماء إلى الأرض مسيرة خمس مائة عام{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٥<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قالا: هي الدنيا أولها إلى آخرها يومٌ مقداره خمسون ألف سنة، لا يدري أحد كم مضى، ولا كم بقي إلا الله{13}<span class=comment-ref>٦٧٨٩</span>. (١٤/٦٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٨٩</span> ساق <u>ابنُ عطية</u> (٨/٤٠٢) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «فالمعنى: تَعرج الملائكة والروح إليه في مدة الدنيا، وبقاء هذه البِنْية». ثم قال: «ويتمكن -على هذا- في <span class="qpc-hafs">﴿الروح﴾</span> أن يكون جنس أرواح الحيوان».</div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك بن حرب- <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: يوم القيامة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك بن حرب- <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: في يوم واحد يَفْرَغ في ذلك اليوم من القضاء، كقدر خمسين ألف سنة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>: يعني: يوم القيامة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٠٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span> هو يوم القيامة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٠<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span> ويَفْرَغ الله منه في مِقدار نصف يوم من أيام الدنيا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١١<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق ابن أبي نجيح- قال: هو ما بين أسفل الأرض إلى العرش{19}<span class=comment-ref>٦٧٩٠</span>. (١٤/٦٩١)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٠</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٤٠٢): «من جعل <span class="qpc-hafs">﴿الروح﴾</span> جبريل أو نوعًا مِن الملائكة قال: المسافة هي مِن قَعْر الأرض السابعة إلى العرش. قاله مجاهد. ومَن جعل <span class="qpc-hafs">﴿الروح﴾</span> جنس الحيوان قال: المسافة من وجه هذه الأرض إلى مُنتهى العرش عُلوًّا. قاله وهْب بن مُنَبِّه».</div></p><p><div></p><p><p><span class="item-no">٧٨٧١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: ذلك يوم القيامة{20}. (١٤/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق محمد بن الفضل- قال: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، يقول: لو ولَّيْتُ حسابَ ذلك اليوم الملائكةَ والجنَ والإنسَ، وطَوَّقْتُهُم محاسبتهم؛ لم يَفْرَغوا منه إلا بعد خمسين ألف سنة، وأنا أفْرغ منها في ساعة واحدة من النهار{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر الله ﷿ عن ذلك العذاب متى يقع بها، فقال: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span> فيها تقديم، وطول ذلك اليوم كأدنى صلاتهم. يقول: لو ولي حسابَ الخلائق وعرْضَهم غيري لم يَفْرَغ منه إلا في مِقدار خمسين ألف سنة، فإذا أخذ الله تعالى في عرْضهم يَفْرَغ الله منه على مِقدار نصف يوم من أيام الدنيا، فلا يَنتصف النهار حتى يستقرّ أهلُ الجنة في الجنة، وأهلُ النار في النار. وهذه الآية نَزَلَتْ فيهم: <span class="qpc-hafs">﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًّا وأَحْسَنُ مَقِيلًا﴾</span> [الفرقان:٢٤]، يقول: ليس مَقِيلهم كمَقِيل أهل النار{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: لو سار بنو آدم مِن الدنيا إلى موضع العرش لَساروا خمسين ألف سنة مِن سِنِي الدنيا{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</span>، قال: هذا يوم القيامة{16}<span class=comment-ref>٦٧٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩١</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿في يوم كان مقداره خمسين ألف سنة﴾</span> على أقوال: <b>الأول</b>: أنّ المراد بذلك: يوم القيامة. <b>الثاني</b>: مدة بقاء الدنيا. <b>الثالث</b>: الحساب.</p><p>وساق <u>ابنُ عطية</u> (٨/٤٠٢-٤٠٣) الأقوال، ثم <span class="comment-type-4">علَّق</span> بقوله: «والعامل في قوله تعالى: <span class="qpc-hafs">﴿يوم﴾</span> -على قول مَن قال: إنه يوم القيامة- قوله: <span class="qpc-hafs">﴿دافع﴾</span>، وعلى سائر الأقوال: <span class="qpc-hafs">﴿تعرج﴾</span>».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١٢٧) أنّ القول الأول وردت فيه أحاديث، وساق الحديث الوارد عن أبي سعيد في تفسير الآية، والوارد عن أبي هريرة في الآثار المتعلقة بالآية. و<span class="comment-type-4">ذكر</span> قولًا آخر وهو أنه اليوم الفاصل بين الدنيا والآخرة. ونسبه لمحمد بن كعب، و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهو قول غريب جدًّا».</div></p><p><h3><span class="qpc-hafs">﴿فِی یَوۡمࣲ كَانَ مِقۡدَارُهُۥ خَمۡسِینَ أَلۡفَ سَنَةࣲ ۝٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٧١٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>ما مِن رجل لا يُؤدّي زكاة ماله إلا جُعِل يوم القيامة صفائح مِن نار يُكوى بها جنبه وجبهته وظهره، في يوم كان مِقداره خمسين ألف سنة</b>»{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٨<span class="dash">-</span></span> عن أبي هريرة مرفوعًا، قال: «<b>ما قدْر طول يوم القيامة على المؤمنين إلا كقدْر ما بين الظهر إلى العصر</b>»{26}. (١٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧١٩<span class="dash">-</span></span> عن الحسن، قال: قال رسول الله ﷺ: «<b>إنّ طول يوم القيامة على المؤمن مثل صلاة صَلّاها في الدنيا فأكمَلها وأحسَنها</b>»{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span>، قال: يَشتدّ كَرْبُ يوم القيامة حتى يُلجم الكافرَ العَرقُ. قيل: فأين المؤمنون يومئذ؟ قال: يُوضع لهم كراسي من ذهب، ويُظلّل عليهم الغَمام، ويُقَصَّر ذلك اليوم عليهم ويُهَوّن، حتى يكون كيوم من أيامكم هذه{2}. (١٤/٦٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: يكون عليهم كصلاة مكتوبة{2}. (١٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم التيميّ</span> -من طريق الثوري- قال: قدْر يوم القيامة على المؤمن قدْر ما بين الظهر إلى العصر{30}. (١٤/٦٩١)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة ما عدا الكسائي؛ فإنه قرأ ‹يَعْرُجُ› بالياء. انظر: النشر ٢/٣٩٠، والإتحاف ص٥٥٦.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٥.أخرجه أحمد ١٨/٢٤٦ (١١٧١٧)، وابن حبان ١٦/٣٢٩ (٧٣٣٤)، وابن جرير ٢٣/٢٥٣-٢٥٤.</p><p>قال المنذري في الترغيب والترهيب ٤/٢١١ (٥٤٤٠): «رواه أحمد، وأبو يعلى، وابن حبان في صحيحه، كلهم من طريق درّاج، عن أبي الهيثم». وقال ابن كثير في تفسيره ٨/٢٢٣: «ورواه ابن جرير، عن يونس، عن ابن وهب، عن عمرو بن الحارث، عن درّاج به، إلا أنّ درّاجًا وشيخه -أبا الهيثم سليمان بن عمرو العُتْوارِيّ- ضعيفان». وقال الهيثمي في المجمع ١٠/٣٣٧ (١٨٣٤٧): «رواه أحمد، وأبو يعلى، وإسناده حسن على ضعف في راويه». وقال المظهري في تفسيره ٧/٢٦٨ عن رواية أبي يعلى وابن حبان والبيهقي: «بسند حسن». وقال العجلوني في كشف الخفاء ٢/٤٧٧: «سند حسن».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤٨-٢٤٩-.أخرجه ابن جرير ٢٣/٢٥٣. وعلقه البيهقي في الشعب ١/٣٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٣-، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤٩-. وعزاه السيوطي إلى البيهقي في البعث.أخرجه ابن جرير ٢٣/٢٥٤.تفسير البغوي ٨/٢٢١.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٢٥٢، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٢)-.أخرجه عبد الرزاق ٢/٣١٦. وعزا السيوطي شطره الأول إلى عبد بن حميد، وفي آخره لفظ: يوم القيامة. كما أخرج شطره الثاني ابن جرير ٢٣/٢٥٣.أخرجه عبد الرزاق ٣/٣٤٤، وابن جرير ٢٣/٢٥٢، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٣)-.أخرجه ابن جرير ٢٣/٢٥٢.أخرجه ابن جرير ٢٣/٢٥٣.تفسير الثعلبي ١٠/٣٦، وتفسير البغوي ٨/٢٢١.تفسير البغوي ٨/٢٢١.أخرجه عبد الرزاق ٢/٣١٥، ٣/٣٤٢، وأبو الشيخ في العظمة (٢٩١). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه البغوي ٨/٢٢١.تفسير مقاتل بن سليمان ٤/٤٣٥-٤٣٦.تفسير الثعلبي ١٠/٣٦، وتفسير البغوي ٨/٢٢٠.أخرجه ابن جرير ٢٣/٢٥٣.أخرجه مسلم ٢/٦٨٠-٦٨٣ (٩٨٧)، وعبد الرزاق ٢/١٤٥ (١٠٨٠)، ٢/١٤٧ (١٠٨١)، ٣/٣٤٥ (٣٣٢٧)، وابن جرير ١١/٤٣١، وابن أبي حاتم ٦/١٧٩٠ (١٠٠٩٠).أخرجه الحاكم ١/١٥٨ (٢٨٣)، وابن أبي حاتم ٩/٣٠٤٩ (١٧٢٤١).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، على شرط الشيخين، إن كان سُويد بن نصر حفظه، على أنه ثقة مأمون». وقال الذهبي في التلخيص: «على شرطهما». وأورده الألباني في الصحيحة ٥/٥٨٤ (٢٤٥٦).أخرجه عبد الرزاق ٣/٣٤٥ مرسلًا.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٦. وعزاه السيوطي إلى عبد بن حميد.
  70,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ صَبۡرࣰا جَمِیلًا ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿صَبْرًا جَمِيلًا﴾</span>، قال: لا تشكو إلى أحد غيري{1}. (١٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاصْبِرْ﴾</span> يا محمد <span class="qpc-hafs">﴿صَبْرًا جَمِيلًا﴾</span> يُعزّي نبيَّه ﷺ؛ صبرًا لا جَزع فيه لتكذيبهم إيّاك بأنّ العذاب غير كائن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢٥<span class="dash">-</span></span> عن عبد الأعلى بن الحجاج، في قوله: <span class="qpc-hafs">﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾</span>، قال: يكون صاحبُ المصيبة في القوم لا يُعرف مَن هو{3}. (١٤/٦٩٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ صَبۡرࣰا جَمِیلًا ۝٥﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٢٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾</span>، قال: هذا حين كان يأمره بالعفو عنهم، لا يُكافئهم، فلمّا أُمِر بالجهاد والغِلْظة عليهم أُمِر بالشدّة والقتل حتى يَتركوا، ونُسخ هذا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾</span>، قال: ... نُسِخ هذا{5}<span class=comment-ref>٦٧٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٢٣/٢٥٥) قول ابن زيد <span class="mustanad">مستندًا إلى عدم الدليل</span>، فقال: «وهذا الذي قاله ابن زيد أنه كان أُمِر بالعفو بهذه الآية، ثم نُسخ ذلك، قول لا وجْه له؛ لأنه لا دلالة على صحة ما قال مِن بعض الأوجه التي تَصحّ منها الدعاوي، وليس في أمْر الله نبيّه ﷺ في الصبر الجميل على أذى المشركين ما يوجب أن يكون ذلك أمرًا منه له به في بعض الأحوال، بل كان ذلك أمرًا مِن الله له به في كل الأحوال؛ لأنّه لم يزل ﷺ من لدن بَعثه الله إلى أن اختَرمه في أذًى منهم، وهو في كلّ ذلك صابر على ما يَلقى منهم مِن أذى قبل أن يأذن الله له بحربهم، وبعد إذنه له بذلك».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٣) أنّ الأمْر بالصبر الجميل محكم في كل حالة.</div></p></div>",footnotes:1:عزاه السيوطي إلى الحكيم الترمذي في نوادر الأصول.تفسير مقاتل بن سليمان ٤/٤٣٦.أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٤٧ (١١٥)-. وعزاه السيوطي إلى الحكيم الترمذي.أخرجه ابن جرير ٢٣/٢٥٥.أخرجه ابن جرير ٢٣/٢٥٥، والنحاس في الناسخ والمنسوخ (٧٤٩-٧٥٠).
  70,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ یَرَوۡنَهُۥ بَعِیدࣰا ۝٦ وَنَرَىٰهُ قَرِیبࣰا ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٢٨<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق سفيان- <span class="qpc-hafs">﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا﴾</span>، قال: الساعة{1}. (١٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنَّهُمْ يَرَوْنَهُ﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿بَعِيدًا﴾</span> يعني: العذاب أنه غير كائن، <span class="qpc-hafs">﴿ونَراهُ قَرِيبًا﴾</span> أنه كائن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا﴾</span> قال: بتكذيبهم، <span class="qpc-hafs">﴿ونَراهُ قَرِيبًا﴾</span> قال: صِدقًا كائنًا{3}. (١٤/٦٩٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٤)-. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٦.عزاه السيوطي إلى ابن المنذر.
  70,7,""
  70,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ تَكُونُ ٱلسَّمَاۤءُ كَٱلۡمُهۡلِ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</span>، قال: كدُرْدِيّ الزَّيْت{1}{2}. (١٤/٦٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</span>. قال: كدُردِيّ الزّيت وسواد العَرق مِن خوف يوم القيامة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر:</p><p>تُبارِي به العِيسُ السمومَ كأنها تبطّنت الأقراب{3} من عَرَق مُهلا؟{4}. (١٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</span>، قال: عكَر الزّيت{5}<span class=comment-ref>٦٧٩٣</span>. (١٤/٦٩٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٤٠٣) على هذا القول بقوله: «فهي لسوادها وانكدار أنوارها تُشبه ذلك».</div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</span> كالفِضّة إذا أُذيبتْ{6}<span class=comment-ref>٦٧٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٤٠٣) على هذا القول بقوله: «فيجيء له ألوان وتميُّع مختلط، والسماء أيضًا -للأهوال التي تُدركها- تصير مثل ذلك».</div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</span>، قال: إنها الآن خضراء، وإنها تُحوّل يوم القيامة لونًا آخر إلى الحُمرة{7}. (١٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٦<span class="dash">-</span></span> قال <span class="name-2">زيد بن</span> <span class="name-2">أسلم</span>: <span class="qpc-hafs">﴿كالمُهْلِ﴾</span> كعَكر الزّيت{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر متى يقع بهم العذاب، فقال: يقع بهم العذاب <span class="qpc-hafs">﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</span> مِن الخوف، يعني: أسود غليظًا كدُردِيّ الزيت بعد الشدّة والقوة{9}. (ز)</p></p><p></div></p></div>",footnotes:1:الدردي: ما يركد في أسفل كل مائع كالأشربة والأدهان. النهاية (درد).أخرجه أحمد ٣/٤١٦ (١٩٤٦)، والخطيب في المتفق والمفترق ١/٦٣٩، والضياء في المختارة (٩)، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٥)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.الأقراب: جمع القرب، وهو الخاصرة. الوسيط (قرب).أخرجه الطستي -كما في الإتقان ٢/٩٥-.أخرجه ابن جرير ٢٣/٢٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/٢٢١.أخرجه ابن جرير ٢٣/٢٥٦. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٥-.تفسير مقاتل بن سليمان ٤/٤٣٦.
  70,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وتَكُونُ الجِبالُ كالعِهْنِ﴾</span>، قال: كالصُّوف{1}. (١٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٣٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿كالعِهْنِ﴾</span> كالصُّوف الأحمر، وهو أضعف الصُّوف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿كالعِهْنِ﴾</span> قال: كالصُّوف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَكُونُ الجِبالُ كالعِهْنِ﴾</span> فشبّهها في اللين والوَهن بالصُّوف المنفوش بعد القوة، وذلك أوهن ما يكون من الصُّوف{4}<span class=comment-ref>٦٧٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٩٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٠٣-٤٠٤) أنّ بعض اللغويين قال: العهن: «هو الصوف المصبوغ ألوانًا». و<span class="comment-type-4">بيّن</span> أنّ مَن قال بهذا استدلّ بقول زُهير:</p><p>كأن فُتات العِهْن في كلّ منزل نَزلْنَ به حَبُّ الفَنا لم يُحَطَّمِ</p><p>ثم قال: «وحب الفنا: هو عِنَب الثعلب. وكذلك هو عند طِيبه وقبل تحطّمه ألوان بعضه أحمر، وبعضه أصفر، وبعضه أخضر؛ لاختلافه في النضج». ثم <span class="comment-type-4">علَّق</span> بقوله: «وتشبه <span class="qpc-hafs">﴿الجبال﴾</span> به -على هذا القول-؛ لأنها جُدَد بِيض وحُمر وسُود، فيجيء التشبيه من وجهين: أحدهما: في الألوان. والثاني: في الانتفاش». و<span class="comment-type-4">بيّن</span> (٨/٤٠٤) أنّ مَن قال: إنّ العهن: الصوف دون تقييد، جَعل التشبيه في الانتفاش وتخلخل الأجزاء فقط.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٣٧، وتفسير البغوي ٨/٢٢١.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٥٧.تفسير مقاتل بن سليمان ٤/٤٣٦.
  70,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا یَسۡـَٔلُ حَمِیمٌ حَمِیمࣰا ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٧٤٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُويبر- <span class="qpc-hafs">﴿ولا يَسْئَلُ حَمِيمٌ حَمِيمًا﴾</span>، قال: يَرى أُمّه وزوجته وحميمه، فلا يَسأل عنه من الخوف{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾</span> لا يَسأل قريبٌ قريبَه أن يَحمل عنه مِن ذنوبه شيئًا؛ كما كان يَحمل بعضهم في الدنيا عن بعض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾</span>، قال: شُغِل كلُّ إنسان بنفسه عن الناس{3}. (١٤/٦٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٧٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَسْئَلُ حَمِيمٌ حَمِيمًا﴾</span> يعني: قريب قريبًا، يقول: لا يَسأل الرجلُ قرابتَه، ولا يُكلّمه مِن شدّة الأهوال{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٣ (١٦٦)-.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٥-.أخرجه ابن جرير ٢٣/٢٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٦.