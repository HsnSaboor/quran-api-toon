69,52," <q>﴿فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِیمِ ۝٥٢﴾</q> - تفسير ٧٨٦٥١- قال مقاتل بن سليمان: <q>﴿فَسَبِّحْ﴾</q> يا محمد، يعني: التوحيد <q>﴿بِاسْمِ رَبِّكَ العَظِيمِ﴾</q> يقول: اذكر اسم ربّك، يعني: التوحيد. ثم قال: <q>﴿العَظِيمِ﴾</q> يعني: الرّبّ العظيم، فلا أكبر منه{1}. (ز) <q>﴿فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِیمِ ۝٥٢﴾</q> - آثار متعلقة بالآيات ٧٨٦٥٢- عن عمر بن الخطاب -من طريق شُريح بن عُبيد- قال: خَرجتُ أتعرّض رسول الله ﷺ قبل أنْ أُسلم، فوجَدتُه قد سبقني إلى المسجد، فقمتُ خَلفه، فاستفتحَ سورة الحاقة، فجَعلتُ أعجب مِن تأليف القرآن، قال: فقلتُ: هذا -واللهِ- شاعرٌ كما قالتْ قريش. قال: فقرأ: <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ وما هُوَ بِقَوْلِ شاعِرٍ قَلِيلًا ما تُؤْمِنُونَ﴾</q>. قال: قلتُ: كاهن. قال: <q>﴿ولا بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ تَنْزِيلٌ مِن رَبِّ العالَمِينَ ولَوْ تَقَوَّلَ عَلَيْنا بَعْضَ الأَقاوِيلِ لَأَخَذْنا مِنهُ بِاليَمِينِ ثُمَّ لَقَطَعْنا مِنهُ الوَتِينَ فَما مِنكُمْ مِن أحَدٍ عَنْهُ حاجِزِينَ﴾</q> إلى آخر السورة. قال: فوقع الإسلام في قلبي كلّ موقع{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٦.أخرجه أحمد في مسنده ١/٢٦٢-٢٦٣ (١٠٧). وضعّف المحققون إسناده.
70,1," مقدمة السورة ٧٨٦٥٣- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة <q>﴿سأل﴾</q> بمكة{1}. (١٤/٦٨٦) ٧٨٦٥٤- عن عبد الله بن الزبير، مثله{2}. (١٤/٦٨٦) ٧٨٦٥٥- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسَمّاها: <q>﴿سأل سائل﴾</q>، ونزلت بعد الحاقة{3}. (ز) ٧٨٦٥٦- عن عكرمة مولى ابن عباس= (ز) ٧٨٦٥٧- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسَمّياها: <q>﴿سأل سائل﴾</q>{4}. (ز) ٧٨٦٥٨- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٧٨٦٥٩- عن محمد بن مسلم الزُّهريّ: مكّيّة، وسَمّاها: <q>﴿سأل سائل﴾</q>، ونزلت بعد الحاقة{6}. (ز) ٧٨٦٦٠- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٧٨٦٦١- قال مقاتل بن سليمان: سورة المعارج مكّيّة، عددها أربع وأربعون آية كوفي{8}٦٧٨١. (ز) ٦٧٨١ ذكر ابنُ عطية (٨/٣٩٩): «أنّ هذه السورة مكّيّة بلا خلاف بين الرواة». وبنحوه قال ابنُ تيمية (٦/٣٩٤). ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ (٧٤٩) من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤٣٣.
70,2," <q>﴿سَأَلَ سَاۤىِٕلُۢ بِعَذَابࣲ وَاقِعࣲ ۝١ لِّلۡكَـٰفِرِینَ لَیۡسَ لَهُۥ دَافِعࣱ ۝٢﴾</q> - نزول الآية ٧٨٦٦٢- عن عبد الله بن عباس -من طريق سعيد- في قوله: <q>﴿سَأَلَ سائِلٌ﴾</q>، قال: هو النَّضر بن الحارث، قال: <q>﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ﴾</q> [الأنفال:٣٢]{1}. (١٤/٦٨٦) ٧٨٦٦٣- عن زيد بن أسلم، مثله{2}. (١٤/٦٨٦) ٧٨٦٦٤- عن الحسن البصري، قال: نزلت: <q>﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</q>، فقال الناس: على مَن يقع العذاب؟ فأنزل الله: (عَلى الكافِرِينَ لَيْسَ لَهُ دافِعٌ){3}. (١٤/٦٨٧) ٧٨٦٦٥- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿سَأَلَ سائِلٌ﴾</q>، قال: نَزَلَتْ بمكة في النَّضر بن الحارث وقد قال: <q>﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ﴾</q> الآية [الأنفال:٣٢]، وكان عذابه يوم بدر{4}. (١٤/٦٨٦) ٧٨٦٦٦- قال مقاتل بن سليمان: <q>﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</q> نزلت في النَّضر بن الحارث بن عَلقمة بن كلدة القُرشي مِن بني عبد الدار بن قُصي، وذلك أنه قال: اللهم إن كان ما يقول محمد هو الحق مِن عندك فأمطر علينا حجارة من السماء أو ائتنا بعذاب أليم. فقُتِل يوم بدر{5}. (ز) <q>﴿سَأَلَ سَاۤىِٕلُۢ بِعَذَابࣲ وَاقِعࣲ ۝١ لِّلۡكَـٰفِرِینَ لَیۡسَ لَهُۥ دَافِعࣱ ۝٢﴾</q> - تفسير الآية، وقراءاتها ٧٨٦٦٧- قال زيد بن ثابت: سال وادٍ مِن أودية جهنم يُقال له: سائل{6}. (ز) ٧٨٦٦٨- عن عبد الله بن عباس، في قوله: ‹سالَ سَآئِلٌ›، قال: سال وادٍ في جهنم{7}. (١٤/٦٨٨) ٧٨٦٦٩- عن عبد الله بن عباس -من طريق سعيد- في قوله: <q>﴿بِعَذابٍ واقِعٍ﴾</q>، قال: كائن{8}. (١٤/٦٨٦) ٧٨٦٧٠- عن زيد بن أسلم، مثله{2}. (١٤/٦٨٦) ٧٨٦٧١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</q>، قال: ذاك سؤال الكفار عن عذاب الله، وهو واقع{10}. (ز) ٧٨٦٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سَأَلَ سائِلٌ﴾</q> قال: دعا داعٍ. وفي قوله: <q>﴿بِعَذابٍ واقِعٍ﴾</q> قال: يقع في الآخرة، وهو قولهم: <q>﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</q> [الأنفال:٣٢]{11}. (١٤/٦٨٧) ٧٨٦٧٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿بِعَذابٍ واقِعٍ لِلْكافِرِينَ﴾</q>، يقول: واقع على الكافرين{12}. (ز) ٧٨٦٧٤- قال الحسن البصري: إنّ المشركين قالوا للنبيِّ ﷺ: لِمَن هذا العذابُ الذي تَذكر أنّه يكون في الآخرة؟ فقال الله: <q>﴿سَأَلَ سائِلٌ بِعَذابٍ﴾</q> أي: عن عذاب <q>﴿واقِعٍ لِلْكافِرِينَ﴾</q>{13}. (ز) ٧٨٦٧٥- عن عطاء، قال: قال رجلٌ مِن عبد الدار يُقال له: الحارث بن عَلقمة: <q>﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</q> [الأنفال:٣٢]. فقال الله: <q>﴿وقالُوا رَبَّنا عَجِّلْ لَنا قِطَّنا قَبْلَ يَوْمِ الحِسابِ﴾</q> [ص:١٦]. وقال الله: <q>﴿ولَقَدْ جِئْتُمُونا فُرادى﴾</q> [الأنعام:٩٤]. وقال الله: <q>﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</q> هو الذي قال: <q>﴿إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ﴾</q>، وهو الذي قال: <q>﴿رَبَّنا عَجِّلْ لَنا قِطَّنا﴾</q>، وهو الذي سأل عذابًا هو واقع به{14}. (١٤/٦٨٧) ٧٨٦٧٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿سَأَلَ سائِلٌ﴾</q>، قال: سأل سائل عن عذاب واقع، فقال الله: <q>﴿لِلْكافِرِينَ لَيْسَ لَهُ دافِعٌ مِنَ اللَّهِ﴾</q>{15}. (ز) ٧٨٦٧٧- قال مقاتل بن سليمان:... هذا العذاب الذي سأل النَّضر بن الحارث في الدنيا هو <q>﴿لِلْكافِرينَ﴾</q> في الآخرة، <q>﴿لَيْسَ لَهُ دافِعٌ* مِنَ اللَّهِ﴾</q> يقول: لا يَدفع عنهم أحدٌ حين يَقع بهم العذاب{5}. (ز) ٧٨٦٧٨- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿بِعَذابٍ واقِعٍ﴾</q> قال: يقع في الآخرة، قولهم في الدنيا: <q>﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ﴾</q> [الأنفال:٣٢]، هو النَّضر بن الحارث{2}. (١٤/٦٨٧) ٧٨٦٧٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾</q>، قال: قال بعض أهل العلم: هو وادٍ في جهنم، يُقال له: سائل{18}٦٧٨٢. (ز) ٦٧٨٢ اختُلف في المراد بقوله: <q>﴿سأل سائل﴾</q> على قولين: الأول: أنه من السؤال، ومَن قال بهذا قرأ قوله: <q>﴿سأل سائل﴾</q> بالهمز. الثاني: أنه وادٍ في جهنم يقال له: سائل، ومَن قال بهذا قرأ: ‹سالَ سائِلٌ› بدون همز، ووجّهه إلى أنه فعْل من السّيل. ورجَّح ابنُ جرير (٢٣/٢٤٨) -مستندًا إلى إجماع القراء، والسلف من أهل التأويل- قراءة الهمز، والقول الأول الذي قاله ابن عباس من طريق العَوفيّ، ومجاهد، والحسن، وعطاء، وقتادة، ومقاتل، وذلك: «لإجماع الحُجّة مِن القراء على ذلك، وأنّ عامة أهل التأويل من السلف بمعنى الهمز تأولوه». ورجَّحه ابنُ كثير (١٤/١٢٥) مستندًا إلى السياق، فقال: «والصحيح الأول؛ لدلالة السياق عليه». وانتقد القول الثاني الذي قاله زيد بن ثابت، وابن زيد، فقال: «وهذا القول ضعيف، بعيد عن المراد». وساق ابنُ عطية (٨/٤٠١) القول الثاني، ثم علَّق بقوله: «ويحتمل -إن لم يصح أمر الوادي- أن يكون الإخبار عن نفوذ القَدَر بذلك العذاب، فاستُعير له لفظ السّيل؛ لِما عُهد من نفوذ السّيل وتصميمه». واختَلَف مَن قرأ بالهمز في المعنى المراد على قولين: الأول: أنّ المعنى: دعا داعٍ. الثاني: استفهم مُستفهم. وذكر ابنُ عطية (٨/٣٩٩) أنّ على القول الأول الذي قاله مجاهد فالباء في قوله: <q>﴿بعذاب﴾</q> على عُرفها. وأنه على القول الثاني الذي قاله الحسن، وقتادة، فالباء تُوصّل توصيل «عن»، كأنه تعالى قال: «عن عذاب». ",footnotes:1:أخرجه النسائي في الكبرى ١٠/٣١٢ (١١٥٥٦)، من طريق الأعمش، عن المنهال بن عمرو، عن سعيد بن جُبَير، عن ابن عباس به. وسنده حسن. وأخرجه ابن أبي حاتم ٥/١٦٩٠ (٩٠١٣)، من طريق الأعمش، عن رجل، عن سعيد بن جُبَير، عن ابن عباس به. وسنده ضعيف مِن أجل الرجل المُبهَم فيه، ويحتمل أن يكون هو المنهال بن عمرو.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر. وقراءة الآية الثانية شاذة، تنسب إلى أبي بن كعب. ينظر: البحر المحيط ٨/٣٣٢.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٤٣٥.تفسير الثعلبي ١٠/٣٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. قرأ بالألف من غير همز نافع وأبو جعفر وابن عامر، وقرأ الباقون بهمزة مفتوحة. ينظر: النشر ٢/٣٩٠.أخرجه النسائي في الكبرى (١١٦٢٠)، وابن أبي حاتم ٥/١٦٩٠، والحاكم ٢/٥٠٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٤٨.أخرجه ابن جرير ٢٣/٢٤٨-٢٤٩، وبنحوه من طريق ليث. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٥٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٤-.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٣/٣٤٤، وابن جرير ٢٣/٢٤٩، ومن طريق سعيد أيضًا.تفسير مقاتل بن سليمان ٤/٤٣٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٤٩.
70,3," <q>﴿مِّنَ ٱللَّهِ ذِی ٱلۡمَعَارِجِ ۝٣﴾</q> - تفسير ٧٨٦٨٠- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿مِنَ اللَّهِ ذِي المَعارِجِ﴾</q>، قال: ذي الدَّرجات{1}. (١٤/٦٨٦) ٧٨٦٨١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ذِي المَعارِجِ﴾</q>، قال: ذي العُلُوِّ والفواضل{2}٦٧٨٣. (١٤/٦٨٨) ٦٧٨٣ ذكر ابنُ عطية (٨/٤٠١) أنّ المعارج على هذا القول مستعارة في الرُّتَب والصفات. ٧٨٦٨٢- قال عبد الله بن عباس: <q>﴿مِنَ اللهِ ذِي المَعارِجِ﴾</q>، يعني: ذي السماوات{3}. (ز) ٧٨٦٨٣- قال سعيد بن جُبَير: <q>﴿ذِي المَعارِجِ﴾</q> ذي الدَّرجات{3}. (ز) ٧٨٦٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ذِي المَعارِجِ﴾</q>، قال: معارج السماء{5}. (١٤/٦٨٨) ٧٨٦٨٥- عن مجاهد بن جبر، في قوله: <q>﴿ذِي المَعارِجِ﴾</q>، قال: معارج الملائكة{6}. (١٤/٦٨٨) ٧٨٦٨٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ذِي المَعارِجِ﴾</q>، قال: ذي الفضائل والنّعم{7}. (١٤/٦٨٨) ٧٨٦٨٧- قال مقاتل بن سليمان: ثم عظّم الرّبُّ -تبارك وتعالى- نفسه، فقال: <q>﴿مِنَ اللَّهِ ذِي المَعارِجِ﴾</q> يعني: ذا الدرجات، يعني: السموات، والعرش فوقهم، والله تعالى على العرش. كقوله: <q>﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</q> [الزخرف:٣٣]{8}. (ز) ٧٨٦٨٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ذِي المَعارِجِ﴾</q>، قال: الله ذو المعارج{9}. (ز) <q>﴿مِّنَ ٱللَّهِ ذِی ٱلۡمَعَارِجِ ۝٣﴾</q> - آثار متعلقة بالآية ٧٨٦٨٩- عن عبد الله بن عباس، قال: آخرُ شيء حُفِظ عن رسول الله ﷺ قوله: «رفيع الدَّرجات ذو المعارج، قد بلّغتُ» ثلاثًا «الصلاةَ، ومِلكَ اليمين». ثلاثًا{10}. (ز) ٧٨٦٩٠- عن سعد بن أبي وقّاص، أنه سمع رجلًا يقول: لبّيك، ذا المعارج. فقال: إنه لذو المعارج، ولكنّا كُنّا مع رسول الله ﷺ لا نقول ذلك{11}. (١٤/٦٨٨) ",footnotes:1:أخرجه النسائي في الكبرى (١١٦٢٠)، وابن أبي حاتم ٥/١٦٩٠، والحاكم ٢/٥٠٢، وابن جرير ٢٣/٢٥١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن مردويه.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٥٠. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٣٥، وتفسير البغوي ٨/٢٢٠.تفسير الثعلبي ١٠/٣٥، وتفسير البغوي ٨/٢٢٠.أخرجه ابن جرير ٢٣/٢٥١، وأبو الشيخ في العظمة (٥٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٥٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٥.أخرجه ابن جرير ٢٣/٢٥١.أخرجه أبو نعيم في أخبار أصبهان ١/٣٥٤.أخرجه أحمد ٣/٧٤ (١٤٧٥). وعلَّقه ابن خزيمة ٤/١٧٢.
70,4," <q>﴿تَعۡرُجُ ٱلۡمَلَـٰۤىِٕكَةُ وَٱلرُّوحُ إِلَیۡهِ﴾</q> - قراءات ٧٨٦٩١- عن عاصم أنه قرأ: <q>﴿تَعْرُجُ المَلَآئِكَةُ﴾</q> بالتاء{1}. (١٤/٦٨٩) ٧٨٦٩٢- عن أبي إسحاق، قال: كان عبد الله [بن مسعود] يقرأ: ‹يَعْرُجُ الـمَلَآئِكَةُ› بالياء{2}٦٧٨٤. (١٤/٦٨٩) ٦٧٨٤ اختُلف في قراءة قوله: <q>﴿تعرج﴾</q>؛ فقرأ قوم بالتاء، وقرأ آخرون بالياء. ورجَّح ابنُ جرير (٢٣/٢٥٤) -مستندًا إلى إجماع القراء- قراءة التاء، فقال: «والصوابُ مِن قراءة ذلك عندنا ما عليه قراء الأمصار، وهو بالتاء؛ لإجماع الحُجّة من القُراء عليه». <q>﴿تَعۡرُجُ ٱلۡمَلَـٰۤىِٕكَةُ وَٱلرُّوحُ إِلَیۡهِ﴾</q> - تفسير الآية ٧٨٦٩٣- قال مقاتل بن سليمان: <q>﴿تَعْرُجُ﴾</q> يعني: تصعد <q>﴿المَلائِكَةُ﴾</q> مِن سماءٍ إلى سماءِ العرش <q>﴿والرُّوحُ﴾</q> يعني: جبريل ﵇ <q>﴿إلَيْهِ﴾</q> في الدنيا برِزق السموات السبع{3}٦٧٨٥. (ز) ٦٧٨٥ ذكر ابنُ عطية (٨/٤٠١) أنّ <q>﴿الروح﴾</q> هو جبريل عند الجمهور، وأنه خَصّصه بالذكر تشريفًا. وذكر قولين آخرين: الأول: أنّ الروح: ملائكة حفظة للملائكة الحافظين لبني آدم، لا تراهم الملائكة كما لا نرى نحن الملائكة. ونسبه لمجاهد. الثاني: أنه اسم الجنس في أرواح الحيوان. ونسبه لبعض المفسرين. وذكر ابنُ كثير (١٤/١٢٥) قولًا ثالثًا، ونسبه لأبي صالح، وهو أنّ الروح خَلْقٌ من خَلْق الله، يُشبِهون الناس، وليسوا أناسًا. ثم علَّق بقوله: «ويحتمل أن يكون المراد به جبريل، ويكون من باب عطف الخاص على العام. ويحتمل أن يكون اسم جنس لأرواح بني آدم، فإنها إذا قُبِضتْ يُصعَد بها إلى السماء، كما دلّ عليه حديث البراء». <q>﴿فِی یَوۡمࣲ كَانَ مِقۡدَارُهُۥ خَمۡسِینَ أَلۡفَ سَنَةࣲ ۝٤﴾</q> - تفسير ٧٨٦٩٤- عن أبي سعيد الخُدري، قال: سُئل رسول الله ﷺ عن: <q>﴿يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q> ما أطول هذا اليوم! فقال: «والذي نفسي بيده، إنه لَيُخفّف على المؤمن حتى يكون أهون عليه مِن صلاة مكتوبة يُصلّيها في الدنيا»{4}٦٧٨٦. (١٤/٦٩١) ٦٧٨٦ ذكر ابنُ عطية (٨/٤٠٢) أنه على هذا فاليوم المشار إليه يوم القيامة، والقدْر في الهول والشدّة. ثم قال: «وهذا كما تقول في اليوم العصيب: إنه كسَنَة، ونحو هذا». ٧٨٦٩٥- عن عبد الله بن عباس -من طريق ليث، عن مجاهد- في قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: مُنتهى أمْره من أسفل الأرضين إلى مُنتهى أمْره مِن فوق سبع سموات مِقدار خمسين ألف سنة، و<q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾</q> [السجدة:٥] يعني بذلك: يَنزل الأمْرُ مِن السماء إلى الأرض ومن الأرض إلى السماء في يوم واحد، فذلك مِقداره ألف سنة؛ لأن ما بين السماء والأرض مسيرة خمسمائة عام{5}٦٧٨٧. (١٤/٦٨٩) ٦٧٨٧ علَّق ابنُ كثير (١٤/١٢٧) على هذا الأثر بقوله: «قد رواه ابن جرير عن ابن حميد، عن حكام بن سلم، عن عمر بن معروف، عن ليث، عن مجاهد قوله، لم يذكر ابن عباس». ٧٨٦٩٦- عن عبد الله بن عباس -من طريق عبد الوهاب بن مجاهد بن جبر، عن أبيه- قال: غِلظ كلّ أرض خمسمائة عام، وبين كلّ أرض إلى أرض خمسمائة عام، ومن السماء إلى السماء خمسمائة عام، فذلك أربعة عشر ألف عام، وبين السماء السابعة وبين العرش مسيرة ستة وثلاثين ألف عام، فذلك قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>{6}. (١٤/٦٨٩) ٧٨٦٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ مِمّا تَعُدُّونَ﴾</q> [السجدة:٥]، قال: هذا في الدنيا؛ تَعرج الملائكة في يوم كان مِقداره ألف سنة. وفي قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>: فهذا يوم القيامة، جَعله الله على الكافرين مقدار خمسين ألف سنة{7}. (١٤/٦٨٩) ٧٨٦٩٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: لو قدّرتموه لكان خمسين ألف سنة مِن أيامكم. قال: يعني: يوم القيامة{8}٦٧٨٨. (١٤/٦٩٠) ٦٧٨٨ علَّق ابنُ عطية (٨/٤٠٢) على هذا القول بقوله: «وهذا هو ظاهر قول النبي ﷺ: «ما من رجل لا يُؤدّي زكاة ماله إلا جُعل له صفائح من نار يوم القيامة، تُكوى بها جبهته وظهره وجنباه، في يوم كان مقداره ألف سنة»». وذكر أنه قد ورد في يوم القيامة أنه كألف سنة، وعلَّق عليه بقوله: «وهذا يشبه أن يكون في طوائف دون طوائف». ٧٨٦٩٩- عن عبد الله بن عباس -من طريق ابن أبي مُلَيْكَة- أنّ رجلًا سأله عن يوم كان مِقداره ألف سنة. فقال: ما يوم كان مِقداره خمسين ألف سنة؟ قال: إنما سألتُك لتُخبِرني! قال: هما يومان ذكرهما الله في القرآن، الله أعلم بهما. فكَره أن يقول في كتاب الله ما لا يعلم{9}. (ز) ٧٨٧٠٠- قال عبد الله بن عباس -من طريق عطاء-= (ز) ٧٨٧٠١- ومقاتل: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، معناه: لو ولي محاسبة العباد في ذلك اليوم غير الله لم يَفرغ منه خمسين ألف سنة{10}. (ز) ٧٨٧٠٢- عن عكرمة، قال: سأل رجلٌ ابنَ عباس: ما هؤلاء الآيات: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، و<q>﴿يُدَبِّرُ الأَمْرَ مِنَ السَّماءِ إلى الأَرْضِ ثُمَّ يَعْرُجُ إلَيْهِ فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ مِمّا تَعُدُّونَ﴾</q> [السجدة:٥]، <q>﴿ويَسْتَعْجِلُونَكَ بِالعَذابِ ولَنْ يُخْلِفَ اللَّهُ وعْدَهُ وإنَّ يَوْمًا عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾</q> [الحج:٤٧]؟ قال: يوم القيامة حساب خمسين ألف سنة، وخلق الله السماوات والأرض في ستة أيام، كل يوم ألف سنة، و<q>﴿يُدَبِّرُ الأَمْرَ مِنَ السَّماءِ إلى الأَرْضِ ثُمَّ يَعْرُجُ إلَيْهِ فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾</q> [السجدة:٥]، قال: ذلك مقدار المسير{11}. (١٤/٦٩٠) ٧٨٧٠٣- عن مجاهد بن جبر -من طريق ليث- <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: مِن مُنتهى أمْره مِن أسفل الأرضين إلى مُنتهى أمْره مِن فوق السماوات مقدار خمسين ألف سنة، و<q>﴿يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾</q> [السجدة:٥]، يعني بذلك: نَزل الأمر من السماء إلى الأرض ومن الأرض إلى السماء في يوم واحد، فذلك مِقداره ألف سنة؛ لأن ما بين السماء إلى الأرض مسيرة خمس مائة عام{12}. (ز) ٧٨٧٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح-= (ز) ٧٨٧٠٥- وعكرمة مولى ابن عباس -من طريق الحكم بن أبان- <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قالا: هي الدنيا أولها إلى آخرها يومٌ مقداره خمسون ألف سنة، لا يدري أحد كم مضى، ولا كم بقي إلا الله{13}٦٧٨٩. (١٤/٦٩٠) ٦٧٨٩ ساق ابنُ عطية (٨/٤٠٢) هذا القول، ثم علَّق بقوله: «فالمعنى: تَعرج الملائكة والروح إليه في مدة الدنيا، وبقاء هذه البِنْية». ثم قال: «ويتمكن -على هذا- في <q>﴿الروح﴾</q> أن يكون جنس أرواح الحيوان». ٧٨٧٠٦- عن عكرمة مولى ابن عباس -من طريق سماك بن حرب- <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: يوم القيامة{14}. (ز) ٧٨٧٠٧- عن عكرمة مولى ابن عباس -من طريق سِماك بن حرب- <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: في يوم واحد يَفْرَغ في ذلك اليوم من القضاء، كقدر خمسين ألف سنة{15}. (ز) ٧٨٧٠٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>: يعني: يوم القيامة{16}. (ز) ٧٨٧٠٩- قال الحسن البصري: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q> هو يوم القيامة{17}. (ز) ٧٨٧١٠- قال عطاء: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q> ويَفْرَغ الله منه في مِقدار نصف يوم من أيام الدنيا{10}. (ز) ٧٨٧١١- عن وهْب بن مُنَبِّه -من طريق ابن أبي نجيح- قال: هو ما بين أسفل الأرض إلى العرش{19}٦٧٩٠. (١٤/٦٩١) ٦٧٩٠ قال ابنُ عطية (٨/٤٠٢): «من جعل <q>﴿الروح﴾</q> جبريل أو نوعًا مِن الملائكة قال: المسافة هي مِن قَعْر الأرض السابعة إلى العرش. قاله مجاهد. ومَن جعل <q>﴿الروح﴾</q> جنس الحيوان قال: المسافة من وجه هذه الأرض إلى مُنتهى العرش عُلوًّا. قاله وهْب بن مُنَبِّه». ٧٨٧١٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: ذلك يوم القيامة{20}. (١٤/٦٩١) ٧٨٧١٣- عن محمد بن السّائِب الكلبي -من طريق محمد بن الفضل- قال: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، يقول: لو ولَّيْتُ حسابَ ذلك اليوم الملائكةَ والجنَ والإنسَ، وطَوَّقْتُهُم محاسبتهم؛ لم يَفْرَغوا منه إلا بعد خمسين ألف سنة، وأنا أفْرغ منها في ساعة واحدة من النهار{21}. (ز) ٧٨٧١٤- قال مقاتل بن سليمان: ثم أخبر الله ﷿ عن ذلك العذاب متى يقع بها، فقال: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q> فيها تقديم، وطول ذلك اليوم كأدنى صلاتهم. يقول: لو ولي حسابَ الخلائق وعرْضَهم غيري لم يَفْرَغ منه إلا في مِقدار خمسين ألف سنة، فإذا أخذ الله تعالى في عرْضهم يَفْرَغ الله منه على مِقدار نصف يوم من أيام الدنيا، فلا يَنتصف النهار حتى يستقرّ أهلُ الجنة في الجنة، وأهلُ النار في النار. وهذه الآية نَزَلَتْ فيهم: <q>﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًّا وأَحْسَنُ مَقِيلًا﴾</q> [الفرقان:٢٤]، يقول: ليس مَقِيلهم كمَقِيل أهل النار{22}. (ز) ٧٨٧١٥- قال محمد بن إسحاق: لو سار بنو آدم مِن الدنيا إلى موضع العرش لَساروا خمسين ألف سنة مِن سِنِي الدنيا{23}. (ز) ٧٨٧١٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾</q>، قال: هذا يوم القيامة{16}٦٧٩١. (ز) ٦٧٩١ اختُلف في المراد بقوله: <q>﴿في يوم كان مقداره خمسين ألف سنة﴾</q> على أقوال: الأول: أنّ المراد بذلك: يوم القيامة. الثاني: مدة بقاء الدنيا. الثالث: الحساب. وساق ابنُ عطية (٨/٤٠٢-٤٠٣) الأقوال، ثم علَّق بقوله: «والعامل في قوله تعالى: <q>﴿يوم﴾</q> -على قول مَن قال: إنه يوم القيامة- قوله: <q>﴿دافع﴾</q>، وعلى سائر الأقوال: <q>﴿تعرج﴾</q>». وذكر ابنُ كثير (١٤/١٢٧) أنّ القول الأول وردت فيه أحاديث، وساق الحديث الوارد عن أبي سعيد في تفسير الآية، والوارد عن أبي هريرة في الآثار المتعلقة بالآية. وذكر قولًا آخر وهو أنه اليوم الفاصل بين الدنيا والآخرة. ونسبه لمحمد بن كعب، وعلَّق عليه بقوله: «وهو قول غريب جدًّا». <q>﴿فِی یَوۡمࣲ كَانَ مِقۡدَارُهُۥ خَمۡسِینَ أَلۡفَ سَنَةࣲ ۝٤﴾</q> - آثار متعلقة بالآية ٧٨٧١٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «ما مِن رجل لا يُؤدّي زكاة ماله إلا جُعِل يوم القيامة صفائح مِن نار يُكوى بها جنبه وجبهته وظهره، في يوم كان مِقداره خمسين ألف سنة»{25}. (ز) ٧٨٧١٨- عن أبي هريرة مرفوعًا، قال: «ما قدْر طول يوم القيامة على المؤمنين إلا كقدْر ما بين الظهر إلى العصر»{26}. (١٤/٦٩٢) ٧٨٧١٩- عن الحسن، قال: قال رسول الله ﷺ: «إنّ طول يوم القيامة على المؤمن مثل صلاة صَلّاها في الدنيا فأكمَلها وأحسَنها»{27}. (ز) ٧٨٧٢٠- عن عبد الله بن عمرو، قال: يَشتدّ كَرْبُ يوم القيامة حتى يُلجم الكافرَ العَرقُ. قيل: فأين المؤمنون يومئذ؟ قال: يُوضع لهم كراسي من ذهب، ويُظلّل عليهم الغَمام، ويُقَصَّر ذلك اليوم عليهم ويُهَوّن، حتى يكون كيوم من أيامكم هذه{2}. (١٤/٦٩١) ٧٨٧٢١- عن الحسن البصري، قال: يكون عليهم كصلاة مكتوبة{2}. (١٤/٦٩٢) ٧٨٧٢٢- عن إبراهيم التيميّ -من طريق الثوري- قال: قدْر يوم القيامة على المؤمن قدْر ما بين الظهر إلى العصر{30}. (١٤/٦٩١) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا الكسائي؛ فإنه قرأ ‹يَعْرُجُ› بالياء. انظر: النشر ٢/٣٩٠، والإتحاف ص٥٥٦.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٥.أخرجه أحمد ١٨/٢٤٦ (١١٧١٧)، وابن حبان ١٦/٣٢٩ (٧٣٣٤)، وابن جرير ٢٣/٢٥٣-٢٥٤. قال المنذري في الترغيب والترهيب ٤/٢١١ (٥٤٤٠): «رواه أحمد، وأبو يعلى، وابن حبان في صحيحه، كلهم من طريق درّاج، عن أبي الهيثم». وقال ابن كثير في تفسيره ٨/٢٢٣: «ورواه ابن جرير، عن يونس، عن ابن وهب، عن عمرو بن الحارث، عن درّاج به، إلا أنّ درّاجًا وشيخه -أبا الهيثم سليمان بن عمرو العُتْوارِيّ- ضعيفان». وقال الهيثمي في المجمع ١٠/٣٣٧ (١٨٣٤٧): «رواه أحمد، وأبو يعلى، وإسناده حسن على ضعف في راويه». وقال المظهري في تفسيره ٧/٢٦٨ عن رواية أبي يعلى وابن حبان والبيهقي: «بسند حسن». وقال العجلوني في كشف الخفاء ٢/٤٧٧: «سند حسن».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤٨-٢٤٩-.أخرجه ابن جرير ٢٣/٢٥٣. وعلقه البيهقي في الشعب ١/٣٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٣-، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤٩-. وعزاه السيوطي إلى البيهقي في البعث.أخرجه ابن جرير ٢٣/٢٥٤.تفسير البغوي ٨/٢٢١.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٢٥٢، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٢)-.أخرجه عبد الرزاق ٢/٣١٦. وعزا السيوطي شطره الأول إلى عبد بن حميد، وفي آخره لفظ: يوم القيامة. كما أخرج شطره الثاني ابن جرير ٢٣/٢٥٣.أخرجه عبد الرزاق ٣/٣٤٤، وابن جرير ٢٣/٢٥٢، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٣)-.أخرجه ابن جرير ٢٣/٢٥٢.أخرجه ابن جرير ٢٣/٢٥٣.تفسير الثعلبي ١٠/٣٦، وتفسير البغوي ٨/٢٢١.تفسير البغوي ٨/٢٢١.أخرجه عبد الرزاق ٢/٣١٥، ٣/٣٤٢، وأبو الشيخ في العظمة (٢٩١). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه البغوي ٨/٢٢١.تفسير مقاتل بن سليمان ٤/٤٣٥-٤٣٦.تفسير الثعلبي ١٠/٣٦، وتفسير البغوي ٨/٢٢٠.أخرجه ابن جرير ٢٣/٢٥٣.أخرجه مسلم ٢/٦٨٠-٦٨٣ (٩٨٧)، وعبد الرزاق ٢/١٤٥ (١٠٨٠)، ٢/١٤٧ (١٠٨١)، ٣/٣٤٥ (٣٣٢٧)، وابن جرير ١١/٤٣١، وابن أبي حاتم ٦/١٧٩٠ (١٠٠٩٠).أخرجه الحاكم ١/١٥٨ (٢٨٣)، وابن أبي حاتم ٩/٣٠٤٩ (١٧٢٤١). قال الحاكم: «هذا حديث صحيح الإسناد، على شرط الشيخين، إن كان سُويد بن نصر حفظه، على أنه ثقة مأمون». وقال الذهبي في التلخيص: «على شرطهما». وأورده الألباني في الصحيحة ٥/٥٨٤ (٢٤٥٦).أخرجه عبد الرزاق ٣/٣٤٥ مرسلًا.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٦. وعزاه السيوطي إلى عبد بن حميد.
70,5," <q>﴿فَٱصۡبِرۡ صَبۡرࣰا جَمِیلًا ۝٥﴾</q> - تفسير ٧٨٧٢٣- عن عبد الله بن عباس، في قوله: <q>﴿صَبْرًا جَمِيلًا﴾</q>، قال: لا تشكو إلى أحد غيري{1}. (١٤/٦٩٢) ٧٨٧٢٤- قال مقاتل بن سليمان: <q>﴿فاصْبِرْ﴾</q> يا محمد <q>﴿صَبْرًا جَمِيلًا﴾</q> يُعزّي نبيَّه ﷺ؛ صبرًا لا جَزع فيه لتكذيبهم إيّاك بأنّ العذاب غير كائن{2}. (ز) ٧٨٧٢٥- عن عبد الأعلى بن الحجاج، في قوله: <q>﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾</q>، قال: يكون صاحبُ المصيبة في القوم لا يُعرف مَن هو{3}. (١٤/٦٩٢) <q>﴿فَٱصۡبِرۡ صَبۡرࣰا جَمِیلًا ۝٥﴾</q> - النسخ في الآية ٧٨٧٢٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾</q>، قال: هذا حين كان يأمره بالعفو عنهم، لا يُكافئهم، فلمّا أُمِر بالجهاد والغِلْظة عليهم أُمِر بالشدّة والقتل حتى يَتركوا، ونُسخ هذا{4}. (ز) ٧٨٧٢٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾</q>، قال: ... نُسِخ هذا{5}٦٧٩٢. (ز) ٦٧٩٢ انتقد ابنُ جرير (٢٣/٢٥٥) قول ابن زيد مستندًا إلى عدم الدليل، فقال: «وهذا الذي قاله ابن زيد أنه كان أُمِر بالعفو بهذه الآية، ثم نُسخ ذلك، قول لا وجْه له؛ لأنه لا دلالة على صحة ما قال مِن بعض الأوجه التي تَصحّ منها الدعاوي، وليس في أمْر الله نبيّه ﷺ في الصبر الجميل على أذى المشركين ما يوجب أن يكون ذلك أمرًا منه له به في بعض الأحوال، بل كان ذلك أمرًا مِن الله له به في كل الأحوال؛ لأنّه لم يزل ﷺ من لدن بَعثه الله إلى أن اختَرمه في أذًى منهم، وهو في كلّ ذلك صابر على ما يَلقى منهم مِن أذى قبل أن يأذن الله له بحربهم، وبعد إذنه له بذلك». وذكر ابنُ عطية (٨/٤٠٣) أنّ الأمْر بالصبر الجميل محكم في كل حالة. ",footnotes:1:عزاه السيوطي إلى الحكيم الترمذي في نوادر الأصول.تفسير مقاتل بن سليمان ٤/٤٣٦.أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٤٧ (١١٥)-. وعزاه السيوطي إلى الحكيم الترمذي.أخرجه ابن جرير ٢٣/٢٥٥.أخرجه ابن جرير ٢٣/٢٥٥، والنحاس في الناسخ والمنسوخ (٧٤٩-٧٥٠).
70,6," <q>﴿إِنَّهُمۡ یَرَوۡنَهُۥ بَعِیدࣰا ۝٦ وَنَرَىٰهُ قَرِیبࣰا ۝٧﴾</q> - تفسير ٧٨٧٢٨- عن سليمان بن مهران الأعمش -من طريق سفيان- <q>﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا﴾</q>، قال: الساعة{1}. (١٤/٦٩٢) ٧٨٧٢٩- قال مقاتل بن سليمان: ثم قال: <q>﴿إنَّهُمْ يَرَوْنَهُ﴾</q> يعني: كفار مكة <q>﴿بَعِيدًا﴾</q> يعني: العذاب أنه غير كائن، <q>﴿ونَراهُ قَرِيبًا﴾</q> أنه كائن{2}. (ز) ٧٨٧٣٠- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا﴾</q> قال: بتكذيبهم، <q>﴿ونَراهُ قَرِيبًا﴾</q> قال: صِدقًا كائنًا{3}. (١٤/٦٩٢) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٤)-. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٦.عزاه السيوطي إلى ابن المنذر.
  70,7,""
70,8," <q>﴿یَوۡمَ تَكُونُ ٱلسَّمَاۤءُ كَٱلۡمُهۡلِ ۝٨﴾</q> - تفسير ٧٨٧٣١- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- في قوله: <q>﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</q>، قال: كدُرْدِيّ الزَّيْت{1}{2}. (١٤/٦٩٢) ٧٨٧٣٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</q>. قال: كدُردِيّ الزّيت وسواد العَرق مِن خوف يوم القيامة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر: تُبارِي به العِيسُ السمومَ كأنها تبطّنت الأقراب{3} من عَرَق مُهلا؟{4}. (١٤/٦٩٣) ٧٨٧٣٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</q>، قال: عكَر الزّيت{5}٦٧٩٣. (١٤/٦٩٣) ٦٧٩٣ علَّق ابنُ عطية (٨/٤٠٣) على هذا القول بقوله: «فهي لسوادها وانكدار أنوارها تُشبه ذلك». ٧٨٧٣٤- قال الحسن البصري: <q>﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</q> كالفِضّة إذا أُذيبتْ{6}٦٧٩٤. (ز) ٦٧٩٤ علَّق ابنُ عطية (٨/٤٠٣) على هذا القول بقوله: «فيجيء له ألوان وتميُّع مختلط، والسماء أيضًا -للأهوال التي تُدركها- تصير مثل ذلك». ٧٨٧٣٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</q>، قال: إنها الآن خضراء، وإنها تُحوّل يوم القيامة لونًا آخر إلى الحُمرة{7}. (١٤/٦٩٣) ٧٨٧٣٦- قال زيد بن أسلم: <q>﴿كالمُهْلِ﴾</q> كعَكر الزّيت{8}. (ز) ٧٨٧٣٧- قال مقاتل بن سليمان: ثم أخبر متى يقع بهم العذاب، فقال: يقع بهم العذاب <q>﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾</q> مِن الخوف، يعني: أسود غليظًا كدُردِيّ الزيت بعد الشدّة والقوة{9}. (ز) ",footnotes:1:الدردي: ما يركد في أسفل كل مائع كالأشربة والأدهان. النهاية (درد).أخرجه أحمد ٣/٤١٦ (١٩٤٦)، والخطيب في المتفق والمفترق ١/٦٣٩، والضياء في المختارة (٩)، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٢ (١٦٥)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.الأقراب: جمع القرب، وهو الخاصرة. الوسيط (قرب).أخرجه الطستي -كما في الإتقان ٢/٩٥-.أخرجه ابن جرير ٢٣/٢٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/٢٢١.أخرجه ابن جرير ٢٣/٢٥٦. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٥-.تفسير مقاتل بن سليمان ٤/٤٣٦.
70,9," <q>﴿وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ۝٩﴾</q> - تفسير ٧٨٧٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وتَكُونُ الجِبالُ كالعِهْنِ﴾</q>، قال: كالصُّوف{1}. (١٤/٦٩٣) ٧٨٧٣٩- قال الحسن البصري: <q>﴿كالعِهْنِ﴾</q> كالصُّوف الأحمر، وهو أضعف الصُّوف{2}. (ز) ٧٨٧٤٠- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿كالعِهْنِ﴾</q> قال: كالصُّوف{3}. (ز) ٧٨٧٤١- قال مقاتل بن سليمان: <q>﴿وتَكُونُ الجِبالُ كالعِهْنِ﴾</q> فشبّهها في اللين والوَهن بالصُّوف المنفوش بعد القوة، وذلك أوهن ما يكون من الصُّوف{4}٦٧٩٥. (ز) ٦٧٩٥ ذكر ابنُ عطية (٨/٤٠٣-٤٠٤) أنّ بعض اللغويين قال: العهن: «هو الصوف المصبوغ ألوانًا». وبيّن أنّ مَن قال بهذا استدلّ بقول زُهير: كأن فُتات العِهْن في كلّ منزل نَزلْنَ به حَبُّ الفَنا لم يُحَطَّمِ ثم قال: «وحب الفنا: هو عِنَب الثعلب. وكذلك هو عند طِيبه وقبل تحطّمه ألوان بعضه أحمر، وبعضه أصفر، وبعضه أخضر؛ لاختلافه في النضج». ثم علَّق بقوله: «وتشبه <q>﴿الجبال﴾</q> به -على هذا القول-؛ لأنها جُدَد بِيض وحُمر وسُود، فيجيء التشبيه من وجهين: أحدهما: في الألوان. والثاني: في الانتفاش». وبيّن (٨/٤٠٤) أنّ مَن قال: إنّ العهن: الصوف دون تقييد، جَعل التشبيه في الانتفاش وتخلخل الأجزاء فقط. ",footnotes:1:أخرجه ابن جرير ٢٣/٢٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٣٧، وتفسير البغوي ٨/٢٢١.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٥٧.تفسير مقاتل بن سليمان ٤/٤٣٦.
70,10," <q>﴿وَلَا یَسۡـَٔلُ حَمِیمٌ حَمِیمࣰا ۝١٠﴾</q> - تفسير ٧٨٧٤٢- عن الضَّحّاك بن مُزاحِم -من طريق جُويبر- <q>﴿ولا يَسْئَلُ حَمِيمٌ حَمِيمًا﴾</q>، قال: يَرى أُمّه وزوجته وحميمه، فلا يَسأل عنه من الخوف{1}. (ز) ٧٨٧٤٣- قال الحسن البصري: <q>﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾</q> لا يَسأل قريبٌ قريبَه أن يَحمل عنه مِن ذنوبه شيئًا؛ كما كان يَحمل بعضهم في الدنيا عن بعض{2}. (ز) ٧٨٧٤٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾</q>، قال: شُغِل كلُّ إنسان بنفسه عن الناس{3}. (١٤/٦٩٣) ٧٨٧٤٥- قال مقاتل بن سليمان: <q>﴿ولا يَسْئَلُ حَمِيمٌ حَمِيمًا﴾</q> يعني: قريب قريبًا، يقول: لا يَسأل الرجلُ قرابتَه، ولا يُكلّمه مِن شدّة الأهوال{4}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٠٣ (١٦٦)-.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٥-.أخرجه ابن جرير ٢٣/٢٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٦.
