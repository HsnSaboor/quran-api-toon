quran[21]{c,v,t}:
  26,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَعَلَّنَا نَتَّبِعُ ٱلسَّحَرَةَ إِن كَانُوا۟ هُمُ ٱلۡغَـٰلِبِینَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فلمّا اجتمعوا في صعيدٍ قال الناسُ بعضهم لبعض: انطلقوا، فلنحضر هذا الأمر، ونتبع السحرة إن كانوا هم الغالبين. يعني بذلك: موسى وهارون -صلى الله عليهما وسلم-؛ استهزاء بهما{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وقيل للناس هل أنتم مجتمعون﴾</span>، قال: كانوا بالإسكندرية. قال: ويُقال: بلغ ذَنَب الحية من وراء البحيرة يومئذ. قال: وهربوا، وأسلموا فرعون، وهمَّت به، فقال: خذها، يا موسى. وكان مما بلي الناس به منه أنّه كان لا يضع على الأرض شيئًا، فأحدث يومئذ تحته، وكان إرساله الحيَّة في القُبَّة الخضراء{2}. (١١/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلنا نتبع السحرة﴾</span> على أمرهم <span class="qpc-hafs">﴿إن كانوا هم الغالبين﴾</span> لموسى وأخيه. واجتمعوا، فقال موسى للساحر الأكبر: تؤمن بي إن غلبتُك؟ قال الساحر: لآتِيَنَّ بسحرٍ لا يغلبه سِحْر، فإن غلبتني لأومنن بك. وفرعون ينظر إليهما، ولا يفهم ما يقولان{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥، ٨/٢٧٦٢.|2:أخرجه ابن جرير ١٧/٥٦٨ وعنده: القبة الحمراء.|3:تفسير مقاتل بن سليمان ٣/٢٦٣.
  26,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَاۤءَ ٱلسَّحَرَةُ قَالُوا۟ لِفِرۡعَوۡنَ أَىِٕنَّ لَنَا لَأَجۡرًا إِن كُنَّا نَحۡنُ ٱلۡغَـٰلِبِینَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- يعني: قوله: <span class="qpc-hafs">﴿فلما جاء السحرة﴾</span>، قالوا: إنّ هذا فعل كذا وكذا. قالوا: هذا ساحر يسحر الناس، ولا يسحر الساحرُ الساحرَ. قال: نعم، <span class="qpc-hafs">﴿وإنكم إذا لمن المقربين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فلمّا أتوْا فرعون قالوا: بِمَ يعمل هذا الساحر؟ قالوا: يعمل بالحيات. قالوا: واللهِ، ما في الأرض قوم يعملون بالسحر والحيات والحبال والعصي أعلم مِنّا، فما أجرنا إن غلبنا؟ فقال لهم: أنتم قرابتي وخاصَّتي، وأنا صانع إليكم كلَّ شيء أحببتم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فلما جاء السحرة قالوا لفرعون ائن لنا اجرا ان كنا نحن الغالبين﴾</span> يقول: عطية تعطينا <span class="qpc-hafs">﴿إن كنا نحن الغالبين﴾</span>. قال: نعم، <span class="qpc-hafs">﴿وإنكم إذًا لمن المقربين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما جاء السحرة قالوا لفرعون أإن لنا لأجرا﴾</span> يعني: جُعْلًا؛ <span class="qpc-hafs">﴿إن كنا نحن الغالبين﴾</span> لموسى وأخيه؟{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فلما جاء السحرة قالوا لفرعون أئن لنا لأجرا﴾</span> على الاستفهام؛ <span class="qpc-hafs">﴿إن كنا نحن الغالبين﴾</span>؟{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٣.|2:أخرجه ابن جرير ١٠/٣٥٣، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٣.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٣.|4:تفسير مقاتل بن سليمان ٣/٢٦٣.|5:تفسير يحيى بن سلام ٢/٥٠٢.
  26,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ نَعَمۡ وَإِنَّكُمۡ إِذࣰا لَّمِنَ ٱلۡمُقَرَّبِینَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨١٠<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿نعم وإنكم إذا لمن المقربين﴾</span> في العَطِيَّة، والقُرْبَة في المنزِلة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: في العطية، والفضيلة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿نعم﴾</span> لكم الجعل، <span class="qpc-hafs">﴿وإنكم إذا لمن المقربين﴾</span> عندي في المنزلة سوى الجُعل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فلما جاء السحرة﴾</span>، قال: فلمّا اجتمعوا إليه أمرهم أمره، وقال لهم: قد جاءنا ساحِرٌ ما رأينا مثلَه قطُّ، وإنكم إن غلبتموه أكرمتُكم، وفضَّلتُكم، وقرَّبتكم على أهل مملكتي. قالوا: وإنّ لنا ذلك إن غلبناه؟ قال: نعم. قالوا: فعِدْهُ لنا مَوْعِدًا نجتمع فيه نحن وهو. وكان رؤوس السحرة التي جمع فرعون لموسى فيما بلغني: أربعة من الذين آمنوا حين رأوا من سلطان الله، فآمنت معهم السحرة جميعًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ٢/٥٠٢.|2:علَّقه يحيى بن سلام ٢/٥٠٢.|3:تفسير مقاتل بن سليمان ٣/٢٦٣.|4:أخرجه ابن جرير ١٠/٣٥٤، وابن أبي حاتم ٨/٢٧٦٣.
  26,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَهُم مُّوسَىٰۤ أَلۡقُوا۟ مَاۤ أَنتُم مُّلۡقُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال لهم موسى ألقوا﴾</span> ما في أيديكم مِن الحبال والعصي <span class="qpc-hafs">﴿مآ أنتم ملقون﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٣.
  26,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَلۡقَوۡا۟ حِبَالَهُمۡ وَعِصِیَّهُمۡ وَقَالُوا۟ بِعِزَّةِ فِرۡعَوۡنَ إِنَّا لَنَحۡنُ ٱلۡغَـٰلِبُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: <span class="qpc-hafs">﴿قالوا يا موسى﴾</span> لقدرتهم بسحرهم: <span class="qpc-hafs">﴿إما أن تلقي وإما أن نكون نحن الملقين﴾</span> قال: ألقوا، <span class="qpc-hafs">﴿فَأَلْقَوْا حِبالَهُمْ وعِصِيَّهُمْ وقالُوا بِعِزَّةِ فِرْعَوْنَ إنّا لَنَحْنُ الغالِبُونَ﴾</span>. فرأى موسى مِن سحرهم ما أوجس في نفسه خِيفة، فأوحى الله ﷿ إليه: أن ألْقِ العصا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وقالوا بعزة فرعون إنا لنحن الغالبون﴾</span>، قال: فوجدوا اللهَ أعَزَّ مِنه{2}. (١١/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١٧<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وقالوا بعزة فرعون﴾</span> بعظمة فرعون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١٨<span class="dash">-</span></span> عن <span class="name-3">بشر بن منصور</span> -من طريق عبد الأعلى بن حماد- قال: بلغني: أنّه لما تكلم ببعض هذا: <span class="qpc-hafs">﴿وقالوا بعزة فرعون﴾</span>. قالت الملائكةُ: قصمه، وربِّ الكعبة. فقال الله: تَأَلَّوْنَ عَلَيَّ! قد أمهلتُه أربعين عامًا{4}. (١١/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فألقوا حبالهم وعصيهم وقالوا بعزة فرعون﴾</span> يعني: بعظمة فرعون، كقولهم لشعيب: <span class="qpc-hafs">﴿وما أنت علينا بعزيز﴾</span> [هود:٩١]، يعني: بعظيم. <span class="qpc-hafs">﴿إنا لنحن الغالبون﴾</span> فإذا هي حيّات في أعين الناس وفي عين موسى وهارون، تسعى إلى موسى وأخيه، وإنّما هي حبال وعصي لا تحرك، فخاف موسى، فقال جبريل لموسى ﵇: ألقِ عصاك. فإذا هي حيَّة عظيمة سَدَّت الأُفُق برأسها، وعلَّقت ذنبَها في قُبَّة لفرعون، طول القبة سبعون ذراعًا في السماء، وذلك في المحرم يوم السبت لثماني ليال خَلَوْن مِن المُحَرَّم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥، ٨/٢٧٦٤.|2:أخرجه ابن أبي حاتم ٨/٢٧٦٤. وعزاه السيوطي إلى عبد بن حميد.|3:علَّقه يحيى بن سلام ٢/٥٠٢.|4:أخرجه ابن أبي حاتم ٨/٢٧٦٤.|5:تفسير مقاتل بن سليمان ٣/٢٦٣.
  26,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَلۡقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فأوحى الله إليه: أن ألقِ العصا. فلمّا ألقاها صارت ثعبانًا عظيمًا فاغرةً فاها. قال: فجعلت العصا بدعوة موسى تلتبس بالحبال، فصارت جَزرًا{1} إلى الثعبان، حتى تدخل فيه، حتى ما بقيت عصًا ولا حبل إلا ابتلعته{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تلقف ما يأفكون﴾</span>، قال: يَكذِبون{3}. (٦/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة بن خالد- في قوله: <span class="qpc-hafs">﴿تلقف ما يأفكون﴾</span>، قال: تَسْتَرِطُ{4} حبالَهم وعِصيَّهم{5}. (٦/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فاذا هي تلقف ما يأفكون﴾</span>: مِن سحرهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم إنّ حيَّة موسى فتحت فاها، فجعلت تَلْقَم تلك الحيات، فلم يبق منها شيءٌ، فذلك قوله ﷿: <span class="qpc-hafs">﴿فألقى موسى عصاه فإذا هي تلقف ما يأفكون﴾</span>، يعني: فإذا هي تلقم ما يكذبون مِن سحرهم، ثم أخذ موسى ﵇ بذَنَبها، فإذا هي عصًا كما كانت، فقال السحرةُ بعضهم لبعض: لو كان هذا سحر لبقيت الحبال والعصي{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿تلقف ما يأفكون﴾</span> تسرط حبالهم وعصيَّهم، لما ألقوا حبالهم وعصيهم خُيِّل إلى موسى أنّ حبالهم وعصيهم حيّات كما كانت عصا موسى، فألقى موسى عصاه فإذا هي أعظم مِن حياتهم، ثم رَقُوا{8}، فازدادت حياتهم وعصيهم عِظَمًا في أعين الناس، وجعلت عصا موسى تعظمهم، وهم يَرْقُون، حتى أنفذوا سحرهم، فلم يبق منه شيء، وعظمت عصا موسى حتى سدَّت الأفق، ثم فتحت فاها فابتلعت ما ألقوا، ثم أخذ موسى عصاه بيده، فإذا حبالهم وعصيهم قد ذهبت، فهو قوله: <span class="qpc-hafs">﴿فألقى موسى عصاه فإذا هي تلقف ما يأفكون﴾</span>{9}. (ز)</p></p><p></div></p></div>",footnotes:1:الجَزَر: الغنم التي تصلح للجَزْرِ، أي: الذَّبْح، ولا يقال إلا في الغنم خاصَّةً. النهاية (جزر).|2:أخرجه ابن أبي حاتم ٥/١٥٣٥، ٨/٢٧٦٥.|3:تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٥٩-٣٦٠، وابن أبي حاتم ٥/١٥٣٦، ٨/٢٧٦٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|4:تَسْتَرِط: تبتلع. اللسان (سرط).|5:أخرجه ابن جرير ١٠/٣٦٠، وابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى أبي الشيخ.|6:أخرجه ابن أبي حاتم ٨/٢٧٦٥.|7:تفسير مقاتل بن سليمان ٣/٢٦٤.|8:رَقُوا: من الرُّقْية. النهاية واللسان (رقى).|9:تفسير يحيى بن سلام ٢/٥٠٢.
  26,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأُلۡقِیَ ٱلسَّحَرَةُ سَـٰجِدِینَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: فألقى عصاه فإذا هي حيَّة جعلت تلقف ما يأفكون، لا تَمُرُّ بشيء من حبالهم وخشبهم التي ألقوها إلا التقمته، فعرفت السحرةُ أنّ هذا أمر من السماء، وليس هذا بسحر، فخرُّوا سُجَّدًا، وقالوا: <span class="qpc-hafs">﴿آمنا برب العالمين رب موسى وهارون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- في قوله: <span class="qpc-hafs">﴿وألقي السحرةُ ساجدين﴾</span>، قال: رأوا منازلَهم تُبنى لهم وهم في سُجودِهم{2}. (٦/٥٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: أوحى الله ﷿ إلى موسى: أن ألقِ ما في يمينك. فألقى عصاه، فأكلت كلَّ حية لهم، فلمّا رأوا ذلك سجدوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فذلك قوله ﷿: <span class="qpc-hafs">﴿فألقي السحرة ساجدين﴾</span> لله ﷿{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٥٨.|2:أخرجه ابن أبي حاتم ٥/١٥٣٦، ٨/٢٧٦٦.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٦. وقد ذكر ﵀ في هذا الموضع آثارًا عديدة عن عدد السحرة. وتقدمت المسألة عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وجاءَ السَّحَرَةُ فِرْعَوْنَ﴾</span> [الأعراف:١١٣].|4:تفسير مقاتل بن سليمان ٣/٢٦٤.
  26,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ ءَامَنَّا بِرَبِّ ٱلۡعَـٰلَمِینَ ۝٤٧ رَبِّ مُوسَىٰ وَهَـٰرُونَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير-: فلمّا عرفت السحرة ذلك قالوا: لو كان هذا سِحرًا لم يبلغ مِن سحرنا كلَّ هذا، ولكن هذا أمرٌ مِن الله، آمنا بالله، وبما جاء به موسى، ونتوب إلى الله مِمّا كُنّا عليه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ السحرة قالوا حين اجتَمَعوا: إن يكُ ما جاء به سِحرًا فلن نُغْلَبَ، وإن يكُ مِن الله فستَرَوْنَ. فلمّا ألقى عصاه أكلتْ ما أفَكوا مِن سحرهم، وعادَت كما كانت؛ علِموا أنّه من الله، فأُلقُوا عندَ ذلك ساجدين، <span class="qpc-hafs">﴿قالوا ءامنا برب العالمين﴾</span>{2}. (٦/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا آمنا برب العالمين﴾</span> لقول موسى: أنا رسول رب العالمين. فقال فرعون: أنا رب العالمين. قالت السحرة: <span class="qpc-hafs">﴿رب موسى وهارون﴾</span>. فبُهِت فرعونُ عند ذلك، وألقى بيديه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: كان مِن رؤوس السحرة الذين جمَعَ فرعون لموسى -فيما بلغني-: سابُورُ، وعاذُورُ، وحَطْحَطُن، ومُصْفى؛ أربعةٌ هم الذين آمَنوا حين رأوا ما رأوا من سلطان الله، فآمَنت معهم السحرةُ جميعًا{4}. (٦/٥٠١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٧، ٨/٢٧٦٦.|2:أخرجه ابن أبي حاتم ٨/٢٧٦٦. وعزاه السيوطي إلى عبد بن حميد.|3:تفسير مقاتل بن سليمان ٣/٢٦٤.|4:أخرجه ابن أبي حاتم ٨/٢٧٦٦.
  26,48,""
  26,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ءَامَنتُمۡ لَهُۥ قَبۡلَ أَنۡ ءَاذَنَ لَكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون للسحرة: <span class="qpc-hafs">﴿آمنتم له﴾</span> يقول: صدَّقتم بموسى <span class="qpc-hafs">﴿قبل أن آذن لكم﴾</span> يقول: مِن قبل أن آمركم بالإيمان به{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قال لهم فرعون وأسف ورأى الغلبة البيِّنة: <span class="qpc-hafs">﴿آمنتم له قبل أن آذن لكم﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: في قوله: <span class="qpc-hafs">﴿قال آمنتم له﴾</span> أصَدَّقتُموه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَكَبِیرُكُمُ ٱلَّذِی عَلَّمَكُمُ ٱلسِّحۡرَ فَلَسَوۡفَ تَعۡلَمُونَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إنه لكبيركم﴾</span>: يعني بكبيرهم: موسى ﷺ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣٨<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إنه لكبيركم﴾</span>، أي: لعالمكم في علم السحر، ولم يكن أكبرهم في السن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال فرعون للسحرة: <span class="qpc-hafs">﴿إنه لكبيركم الذي علمكم السحر﴾</span> إنّ هذا لَمَكْرٌ مكرتموه، يقول: إنّ هذا لَقَوْلٌ قلتموه أنتم -يعني به: السحرة وموسى- في المدينة -يعني: في أهل مدين{6}- لتخرجوا منها أهلها؛ بقول الساحر الأكبر لموسى حين قال: لئن غلبتني [لأؤمننَّ] بك. ثم قال فرعون: <span class="qpc-hafs">﴿فلسوف تعلمون﴾</span>. هذا وعيد، فأخبرهم بالوعيد، فقال: <span class="qpc-hafs">﴿لأقطعن أيديكم وأرجلكم من خلاف﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٤٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿إنه لكبيركم الذي علمكم السحر﴾</span>: أي: إنه لعظيم السُّحّار الذي علَّمكم السحر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَأُقَطِّعَنَّ أَیۡدِیَكُمۡ وَأَرۡجُلَكُم مِّنۡ خِلَـٰفࣲ وَلَأُصَلِّبَنَّكُمۡ أَجۡمَعِینَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لأقطعن أيديكم وأرجلكم من خلاف﴾</span> يعني: اليد اليمنى والرجل اليسرى، <span class="qpc-hafs">﴿ولأصلبنكم أجمعين﴾</span> في جذوع النخل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لأقطعن أيديكم وأرجلكم من خلاف﴾</span> اليد اليمنى والرجل اليسرى، <span class="qpc-hafs">﴿ولأصلبنكم أجمعين﴾</span>{10}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٤.|2:أخرجه ابن أبي حاتم ٨/٢٧٦٧.|3:تفسير يحيى بن سلام ٢/٥٠٢.|4:أخرجه ابن أبي حاتم ٨/٢٧٦٧.|5:علَّقه يحيى بن سلام ٢/٥٠٣.|6:كذا في المصدر.|7:تفسير مقاتل بن سليمان ٣/٢٦٤.|8:أخرجه ابن أبي حاتم ٨/٢٧٦٧.|9:تفسير مقاتل بن سليمان ٣/٢٦٤.|10:تفسير يحيى بن سلام ٢/٥٠٣.
  26,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَا ضَیۡرَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فردَّت عليه السحرةُ حين أوعدهم بالقتل والصلب، <span class="qpc-hafs">﴿قالوا لا ضير﴾</span> ما عسيت تصنع؟! هل هو إلا تقتلنا؟!{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا ضير﴾</span>، قال: يقولون: لا يَضُرُّنا الذي تقول، وإن صنعته بنا وصلبتنا{2}. (١١/٢٤٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّاۤ إِلَىٰ رَبِّنَا مُنقَلِبُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٤٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿إنا إلى ربنا منقلبون﴾</span>: يعني: إنا إلى ربنا راجعون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنا إلى ربنا منقلبون﴾</span>، يعني: لراجعون إلى الآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنا إلى ربنا منقلبون﴾</span>، يقول: إنا إلى ربنا راجعون، وهو مُجازينا بصبرِنا على عقوبتك إيّانا، وثباتنا على توحيده، والبراءة من الكفر به{5}. (١١/٢٤٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٤.|2:أخرجه ابن جرير ١٧/٥٧١، وابن أبي حاتم ٨/٢٧٦٧ من طريق أصبغ.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٧.|4:تفسير مقاتل بن سليمان ٣/٢٦٤.|5:أخرجه ابن جرير ١٧/٥٧١.
  26,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا نَطۡمَعُ أَن یَغۡفِرَ لَنَا رَبُّنَا خَطَـٰیَـٰنَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنا نطمع﴾</span> أي: نرجو <span class="qpc-hafs">﴿أن يغفر لنا ربنا خطايانا﴾</span> يعني: سحرنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنا نطمع أن يغفر لنا ربنا خطايانا﴾</span>، قال: السِّحر والكُفْر الذي كانوا فيه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن كُنَّاۤ أَوَّلَ ٱلۡمُؤۡمِنِینَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ- قال: أصبحوا سَحَرَةً، وأمسَوا شهداء. وفي لفظٍ: كانوا سحرة في أول النهار، وشهداءَ آخر النهار حين قُتِلوا{3}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق خيثمة- قال: أصبحوا كُفّارًا، وأمسوا شهداء{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: كانوا أوَّل النهار سحرةً، وآخره شهداء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أن كنا﴾</span> بأن كُنّا <span class="qpc-hafs">﴿أول المؤمنين﴾</span> أول المُصَدِّقين مِن بني إسرائيل لِما جاء به موسى{5}<span class=comment-ref>٤٧٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٢</span> قال <u>ابنُ عطية</u> (٦/٤٨٢): «وقولهم: <span class="qpc-hafs">﴿أنْ كُنّا أوَّلَ المُؤْمِنِينَ﴾</span> يريدون: مِن القبط وصنيعتهم، وإلا فقد كانت بنو إسرائيل آمنت».</div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن كنا أول المؤمنين﴾</span>، يعني: أول المصدقين بتوحيد الله ﷿ مِن أهل مصر، فقطعهم وصلبهم فرعونُ مِن يومه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أن كنا أول المؤمنين﴾</span>، قال: كانوا كذلك يومئذٍ أولَ مَن آمن بآياته حين رأوها{2}. (١١/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أن كنا﴾</span> يعني: بأن كنا <span class="qpc-hafs">﴿أول المؤمنين﴾</span> مِن السَّحَرَة{9}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٤.|2:أخرجه ابن جرير ١٧/٥٧١، وابن أبي حاتم ٨/٢٧٦٧ من طريق أصبغ.|3:أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٦٤، وابن أبي حاتم ٥/١٥٣٨. وعلَّقه مقاتل بن سليمان في تفسيره ٣/٢٦٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|4:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥١٠-.|5:علَّقه يحيى بن سلام ٢/٥٠٣.|6:علَّقه يحيى بن سلام ٢/٥٠٣.|7:تفسير مقاتل بن سليمان ٣/٢٦٤.|8:أخرجه ابن جرير ١٧/٥٧١، وابن أبي حاتم ٨/٢٧٦٧ من طريق أصبغ.|9:تفسير يحيى بن سلام ٢/٥٠٣.
  26,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَوۡحَیۡنَاۤ إِلَىٰ مُوسَىٰۤ أَنۡ أَسۡرِ بِعِبَادِیۤ إِنَّكُم مُّتَّبَعُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فلمّا طال مُكث موسى لمواعيد فرعون الكاذبة؛ أُمِر موسى بالخروج بقومه، فخرج بهم ليلًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثم إنّ الله أمر موسى أن يخرج ببني إسرائيل، فقال: <span class="qpc-hafs">﴿أسر بعبادي ليلا﴾</span>، فأمر موسى بني إسرائيل أن يخرجوا، وأمرهم أن يستعيروا الحُلِيَّ مِن القِبْط، وأمر أن لا ينادي أحدٌ منهم صاحبَه، وأن يُسْرِجوا في بيوتهم حتى الصبح، وأنّ مَن خرج منهم يلطخ أمام بابه بكفٍّ مِن دم حتى يُعلم أنه قد خرج، وأنّ الله قد أخرج كل ولد زنا في القِبط من بني إسرائيل إلى بني إسرائيل، وأخرج كل ولد زنا في بني إسرائيل من القِبط إلى القِبط حتى أتوا آباءَهم، ثم خرج موسى ببني إسرائيل ليلًا، والقِبْطُ لا يعلمون، وألقي على القبط الموت، فمات كل بِكْرِ رَجُلٍ منهم، فأصبحوا يدفنونهم، فشُغِلوا عن طلبهم حتى طلعت الشمس، وخرج موسى في ستمائة ألف وعشرين ألفًا، لا يَعُدُّون ابنَ عشرين لصِغَره، ولا ابن ستين لكِبَره، وإنما عدُّوا ما بين ذلك سوى الذُّرِّيَّة، وتبعهم فرعون على مقدمه هامان في ألف ألف وسبعمائة ألف حصان فيها ماذِيانة{2}، وذلك حين يقول الله: <span class="qpc-hafs">﴿فأرسل فرعون في المدائن حاشرين إن هؤلاء لشرذمة قليلون﴾</span>{1}. (١١/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأوحينا إلى موسى أن أسر بعبادي﴾</span> بني إسرائيل ليلًا؛ <span class="qpc-hafs">﴿إنكم متبعون﴾</span> يعني: يتبعكم فرعون وقومه، فأمر جبريلُ ﵇ كلَّ أهل أربعة أبيات من بني إسرائيل في بيت، ويُعَلِّم تلك الأبواب بدم الخراف، فإنّ الله ﷿ يبعث الملائكة إلى أهل مصر، فمَن لم يروا على بابه دمًا دخلوا بيته فقتلوا أبكارَهم مِن أنفسهم وأنعامهم، فيشغلهم دفنُهم إذا أصبحوا عن طلب موسى، ففعلوا، واستعاروا حُلِيَّ أهل مصر، فساروا من ليلتهم قبل البحر، هارون على المقدمة، وموسى على الساقة، فأصبح فرعون مِن الغد يوم الأحد وقد قتلت الملائكةُ أبكارهم، فاشتغلوا بدفنهم، ثُمَّ جمع الجموع، فساروا يوم الاثنين في طلب موسى ﵇ وأصحابه، وهامان على مقدمة فرعون في ألفي ألف وخمسمائة، ويقال: ألف ألف مقاتل. فذلك قوله ﷿: <span class="qpc-hafs">﴿فأرسل فرعون في المدائن حاشرين﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وأوحينا إلى موسى أن أسر بعبادي﴾</span> أي: ليلًا. وقد قال في آية أخرى: <span class="qpc-hafs">﴿فأسر بعبادي ليلا﴾</span> [الدخان:٢٣]، <span class="qpc-hafs">﴿إنكم متبعون﴾</span> أي: يتبعكم فرعونُ وقومه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٨.|2:قال محققو الدر المنثور: بعده في الأصل: الماذيانة: الأنثى من الخيل. وينظر: المعجم الذهبي ٥٣٢.|3:أخرجه ابن أبي حاتم ٨/٢٧٦٨.|4:تفسير مقاتل بن سليمان ٣/٢٦٥.|5:تفسير يحيى بن سلام ٢/٥٠٣.
  26,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَرۡسَلَ فِرۡعَوۡنُ فِی ٱلۡمَدَاۤىِٕنِ حَـٰشِرِینَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٦١<span class="dash">-</span></span> عن <span class="name-3">يحيى بن عروة بن الزبير</span> -من طريق ابن إسحاق- قال: إنّ الله أمر موسى أن يسير ببني إسرائيل، وقد كان موسى وعَد بني إسرائيل أن يسير بهم إذا طلع القمر، فدعا اللهَ أن يُؤَخِّر طلوعه حتى يفرُغَ، فلما سار موسى ببني إسرائيل أذَّن فرعونُ في الناس: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>{1}. (١١/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿فأرسل فرعون في المدائن حاشرين﴾</span> يحشرون الناس في طلب موسى ﵇، وهارون ﵇، وبني إسرائيل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٨ (١٥٦٥١). وعزاه السيوطي إلى ابن إسحاق، وابن المنذر.|2:تفسير مقاتل بن سليمان ٣/٢٦٥.
  26,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ هَـٰۤؤُلَاۤءِ لَشِرۡذِمَةࣱ قَلِیلُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٦٣<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>كان أصحاب موسى الذين جاوزوا البحر اثني عشر سِبْطًا، فكان في كلِّ طريق اثنا عشر ألفًا، كلهم ولد يعقوب ﵇</b>»{1}. (١١/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٤<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>كان فرعونُ عدوَّ الله حيث أغرقه الله هو وأصحابه في سبعين قائدًا، مع كل قائدٍ سبعون ألفًا، وكان موسى مع سبعين ألفًا حين عبروا البحر</b>»{2}. (١١/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي إسحاق، عن رجل- قال: دخل بنو إسرائيل مصر وهم ثلاثة وسبعون إنسانًا، وخرجوا منها وهم ستمائة ألف، فقال فرعون: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عبيدة- في قوله: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>، قال: ستمائة ألفٍ وسبعون ألفًا{4}. (١١/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي عبيدة [بن عبد الله بن مسعود]</span> -من طريق أبي إسحاق-، مثله{5}. (١١/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>، قال: كانوا ستمائة ألفٍ{6}. (١١/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شهر بن حوشب- قال: كان مع فرعون يومئذ ألفُ جبّار، كلهم عليه تاج، وكلهم أميرٌ على خَيْل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: أوحى الله إلى موسى: <span class="qpc-hafs">﴿أن أسر بعبادي ليلًا إنكم متبعون﴾</span>، فأسرى موسى ببني إسرائيل ليلًا، فأتبعهم فرعونُ في ألف ألفِ حصانٍ سوى الإناث، وكان موسى في ستمائة ألفٍ، فلمّا عاينهم فرعونُ قال: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون وإنهم لنا لغائظون وإنا لجميع حاذرون﴾</span>{8}. (١١/٢٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق محمد بن كعب، عن عبد الله بن الهاد- قال: اجتمع آلُ يعقوب إلى يوسف، وهم ستةٌ وثمانون إنسانًا؛ ذكرهم وأنثاهم، فخرج بهم موسى يوم خرج وهم ستمائة ألفٍ ونيفٌ، وخرج فرعون على إثرهم يطلبهم على فرس أدهم، على لونه مِن الدُّهْم ثمانمائةُ ألفِ أدْهَمٍ، سوى ألوان الخيل، وجالَتْ الريح الشمال، وتحت جبريلَ فرسٌ ودِيقٌ، وميكائيل يسوقهم، لا يَشُذُّ منهم شاذَّةٌ إلا ضَمَّه، فقال القوم: يا رسول الله، قد كُنّا نلقى مِن التعس والعذاب ما نلقى، فكيف إذ صنعنا ما صنعنا، فأين الملجأ؟ قال: البحر{9}. (١١/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٢<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون الأودي</span>، قال: لَمّا أراد موسى أن يخرج ببني إسرائيل مِن مصر بلغ ذلك فرعون، فقال: أمهِلوهم، حتى إذا صاح الديكُ فأْتوهم. فلم يصِح في تلك الليلة ديكٌ، فخرج موسى ببني إسرائيل، وغدا فرعون، فلما أصبح فرعونُ أمر بشاةٍ، فأُتِي بها، فأمر بها أن تُذبَح، ثم قال: لا يفرغ مِن سلخها حتى يجتمع عندي خمسمائة ألف فارسٍ. فاجتمعوا إليه، فأتبعهم، فلما انتهى موسى إلى البحر قال له وصِيُّه: يا نبيَّ الله، أين أُمِرْت؟ قال: ههنا في البحر{10}. (١١/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شدّاد بن الهاد</span> -من طريق محمد بن كعب القرظي- قال: اجتمع يعقوبُ وولدُه إلى يوسف، وهم اثنان وسبعون، وخرجوا مع موسى وهم ستمائة ألف، فقال فرعون: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>. وخرج فرعون على فرس أدهم؛ حصان على لون فرسه في عسكره ثمانمائة ألف{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿لشرذمة﴾</span>، قال: قِطْعةٌ{12}. (١١/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>، قال: هم يومئذ ستمائة ألفٍ، ولا يُحْصى عددُ أصحاب فرعون{13}<span class=comment-ref>٤٧٩٣</span>. (١١/٢٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٣</span> قال <u>ابنُ عطية</u> (٦/٤٨٢): «رُوِي: أنّ بني إسرائيل كانوا ستمائة ألف وسبعين ألفًا. قاله ابن عباس. واللهُ أعلم بصحته، وإنما اللازم مِن الآية الذي يُقطَع به: أن موسى ﵇ خرج بجَمْعٍ عظيم من بني إسرائيل، وأن فرعون تبعه بأضعاف ذلك العدد».</p><p>وقال <u>ابنُ كثير</u> (١٠/٣٤٧-٣٤٨): «ذكر غيرُ واحد من المفسرين: أنّ فرعون خرج في جَحْفَلٍ عظيم، وجمْعٍ كبير، وهو عبارة عن مملكة الديار المصرية في زمانه، أُولِي الحل والعقد والدول، من الأمراء والوزراء والكبراء والرؤساء والجنود، فأمّا ما ذكره غير واحد من الإسرائيليات من أنه خرج في ألف ألف وستمائة ألف فارس، منها مائة ألف على خيل دهم. وقال كعب الأحبار: فيهم ثمانمائة ألف حصان أدهم. ففي ذلك نظر. والظاهر أنه مِن مُجازفات بني إسرائيل، والله ﷾ أعلم. والذي أخبر به هو النافع، ولم يعين عِدَّتهم؛ إذ لا فائدة تحته، إلا أنهم خرجوا بأجمعهم».</div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿لشرذمة﴾</span>، قال: الفريد مِن الناس{14}. (١١/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ بني إسرائيل الذين قطع بهم موسى البحرَ كانوا ستمائةَ ألفِ مقاتل، بني عشرين سنة فصاعدًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: كان مقدمة فرعون ألف ألف حصان ومائتي ألف ألف حصان{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٧٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، قال: خرج موسى مِن مصر ومعه ستمائة ألفٍ مِن بني إسرائيل، لا يَعُدُّون فيهم أقلَّ مِن ابن عشرين ولا ابن أكثر مِن أربعين سنةً، فقال: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>. وخرج فرعون على فرسٍ حصانٍ أدهم، ومعه ثمانمائة ألفٍ على خيلٍ دُهْمٍ، سوى ألوان الخيل، وكان جبريل ﵇ على فرسٍ أنثى، يسير بين يدي القوم، ويقول: ليس القوم بأحقَّ بالطريق منكم. وفرعون على فرسٍ أدهم حصانٍ، وجبريل على فرسٍ أنثى، فأتبعها فرس فرعون، وكان ميكائيل في آخر القوم يقول: الحقوا، الحقوا أصحابكم. حتى دخل آخرُهم، وأراد أولُهم أن يخرج، فأطبق عليهم البحر{17}. (١١/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>: يعني: بني إسرائيل{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>، يعني: هم قليل في كثير، وكان أصحاب موسى ستمائة ألف، وفرعون وأصحابه ستة آلاف ألف{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: قوله: <span class="qpc-hafs">﴿وأوحينا إلى موسى أن أسر بعبادي إنكم متبعون﴾</span> [الشعراء:٥٢]، قال: أوحى اللهُ إلى موسى: أنِ اجمع بني إسرائيل، كل أربعة أبيات في بيت، ثم اذبحوا أولاد الضأن، فاضربوا بدمائها على الأبواب، فإنِّي سآمُر الملائكةَ أن لا تدخل بيتًا على بابه دم، وسآمرهم بقتل أبكار آل فرعون مِن أنفسهم وأموالهم، ثم اخبزوا خبزًا فطيرًا؛ فإنّه أسرع لكم، ثم أسرِ بعبادي حتى تنتهي للبحر فيأتيك أمري. ففعل، فلمّا أصبحوا قال فرعون: هذا عمل موسى وقومه، قتلوا أبكارَنا مِن أنفسنا وأموالنا. فأرسل في إثرهم ألف ألف وخمسمائة ألف وخمسمائة ملك مسور، مع كل ملك ألف رجل، وخرج فرعون في الكَرِش{20} العظمى، وقال: <span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span>. قال: قطعة، وكانوا ستمائة ألف، مائتا ألف منهم أبناء عشرين سنة إلى أربعين{21}. (١١/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- قال: كانوا ثلاثين ملَِكًا ساقة خلف فرعون، يحسبون أنهم معهم، وجبرائيل أمامهم، يردُّ أوائل الخيل على أواخرها، فأتبعهم حتى انتهى إلى البحر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال فرعون: <span class="qpc-hafs">﴿إن هؤلاء﴾</span> يعني: بني إسرائيل <span class="qpc-hafs">﴿لشرذمة﴾</span> يعني: عصابة<span class=comment-ref>٤٧٩٤</span> <span class="qpc-hafs">﴿قليلون﴾</span> وهم ستمائة ألف{23}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٤</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٧/٥٧٢-٥٧٣ بتصرف): «يعني بالشرذمة: الطائفة، والعصبة الباقية، من عصَب جبيرةً، وشرذمة كلِّ شيء: بقيّته القليلة. <b>وقيل</b>: <span class="qpc-hafs">﴿قليلون﴾</span> لأن كل جماعة منهم كان يلزمها معنى القلة؛ فلما جمَعَ جمْعَ جماعاتهم قيل: قليلون».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٤٨٣): «الشرذمة: الجمع القليل المحتقر. وشرذمة كل شيء: بقيّته الخسيسة».</div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبلغني: أنّ جميع جنوده كانوا أربعين ألف ألف{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد بن حميد كما في المنتخب من مسنده ص٢٠٧ (٦٠٥)، وابن الجوزي في المنتظم ١/٣٤٩.</p><p>قال الشوكاني في فتح القدير ٤/١٢ بعد ذكره لروايات ومنها هذا الحديث: «هذه الروايات المضطربة قد رُوِي عن كثير من السلف ما يماثلها في الاضطراب والاختلاف، ولا يصح منها شيء عن النبي ﷺ».|2:أخرجه ابن مردويه -كما في عمدة القاري للعيني ١٨/٢٨٦-.</p><p>قال السيوطي: «بسند واهٍ». وقال الشوكاني في فتح القدير ٤/١٢ بعد ذكره لروايات ومنها هذه الحديث: «هذه الروايات المضطربة قد روي عن كثير من السلف ما يماثلها في الاضطراب والاختلاف، ولا يصح منها شيء عن النبي ﷺ».|3:ذكره الحافظ في المطالب العالية (إشراف: د. سعد الشثري) ١٥/٨٠ (٣٦٧٥).|4:أخرجه ابن جرير ١٧/٥٧٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:أخرجه ابن أبي شيبة ١٣/٥٤٢، وابن جرير ١٧/٥٧٣.|6:أخرجه ابن أبي حاتم ٨/٢٧٧١.|7:أخرجه ابن جرير ١٧/٥٧٦.|8:أخرجه ابن جرير ١/٦٥٨، وإسحاق البستي في تفسيره ص٥٣٢، وابن أبي حاتم ٨/٢٧٧١.|9:أخرجه ابن أبي حاتم ٨/٢٧٦٩-٢٧٧٠.|10:أخرجه ابن أبي حاتم ١/١٠٦-١٠٧، ٨/٢٧٧١. وفي تفسير الثعلبي ٧/١٦٤: عن عمرو بن ميمون قال: كان أصحاب موسى ستمائة ألف.|11:أخرجه ابن جرير ١٧/٥٧٣، وابن أبي حاتم ٨/٢٧٦٩.|12:أخرجه إسحاق البستي في تفسيره ص٥٣٢. وعزاه السيوطي إلى ابن أبي حاتم. ينظر: فتح الباري ٨/٤٩٧.|13:أخرجه الفريابي -كما في التغليق ٤/٢٧٣-، وابن جرير ١٧/٥٧٥، وإسحاق البستي في تفسيره ص٥٣٢ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.|14:عزاه السيوطي إلى ابن أبي حاتم.|15:أخرجه يحيى بن سلام ٢/٥٠٤، ونقل عقِبَه عن الحسن البصري قوله: سوى الحشم.|16:علَّقه يحيى بن سلام ٢/٥٠٤.|17:عزاه السيوطي إلى ابن المنذر.|18:أخرجه ابن جرير ١٧/٥٧٤-٥٧٥.|19:علَّقه يحيى بن سلام ٢/٥٠٤.|20:الكرش: الجماعة من الناس، والبطانة والمدد، وكرش الرجل كَرَشًا: إذا صار له جيش. التاج (كرش).|21:أخرجه ابن جرير ١٧/٥٧٥. وعزاه السيوطي إلى ابن المنذر.|22:أخرجه ابن جرير ١٧/٥٧٦.|23:تفسير مقاتل بن سليمان ٣/٢٦٥.|24:تفسير يحيى بن سلام ٢/٥٠٤.
  26,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُمۡ لَنَا لَغَاۤىِٕظُونَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿وإنهم لنا لغائظون﴾</span>، يقول: بقتلهم أبكارنا من أنفسنا وأموالنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال فرعون: <span class="qpc-hafs">﴿وإنهم لنا لغائظون﴾</span> لقتلهم أبكارنا، ثم هربوا مِنّا{2}<span class=comment-ref>٤٧٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٥</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٧/٥٧٦): «ذُكِرَ: أن غيظهم إيّاهم كان قَتْل الملائكة مَن قتَلَت مِن أبكارهم... وقد يحتمل أن يكون معناه: وإنهم لنا لغائظون بذهابهم منهم بالعواريّ التي كانوا استعاروها منهم مِن الحليّ. ويحتمل أن يكون ذلك بفراقهم إياهم، وخروجهم من أرضهم بِكُرْهٍ لهم لذلك».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٥٧٦.|2:تفسير مقاتل بن سليمان ٣/٢٦٥.
  26,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَجَمِیعٌ حَـٰذِرُونَ ۝٥٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٨٨<span class="dash">-</span></span> عن عمرو بن دينار، قال: قرأ عبيد: <span class="qpc-hafs">﴿وإنّا لَجَمِيعٌ حاذِرُونَ﴾</span>{1}. (١١/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٨٩<span class="dash">-</span></span> عن <span class="name-2">الأسود بن يزيد النخعي</span> -من طريق أبي إسحاق- أنّه كان يقرؤها: <span class="qpc-hafs">﴿وإنّا لَجَمِيعٌ حاذِرُونَ﴾</span>{2}. (١١/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٠<span class="dash">-</span></span> عن يونس بن إسحاق{3}، عن أبيه، قال: سمعت <span class="name-2">الأسود بن يزيد النخعي</span> يقرأ هذا الحرف: ‹وإنّا لَجَمِيعٌ حَذِرُونَ›{4}<span class=comment-ref>٤٧٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٦</span> اختلف القراء في قراءة قوله تعالى:<span class="qpc-hafs">﴿حاذرون﴾</span>؛ <b>فقرأها بعضهم</b> بإثبات الألف، بمعنى: أنهم مُعدُّون مُؤْدُون، ذوو أداة وقوّة وسلاح. <b>وقرأها البعض</b> بغير الألف، هكذا (حَذِرُون)، جمع حَذِر، وهو المطبوع على الحَذَرِ.</p><p>و<span class="comment-type-4">بَيَّنَ</span> <u>ابنُ جرير</u> (١٧/٥٧٧) أنّ كِلتا القراءتين صواب؛ <span class="mustanad">لاستفاضتهما لدى القراء</span>، فقال: «الصواب مِن القول في ذلك أنهما قراءتان مستفيضتان في قرّاء الأمصار، متقاربتا المعنى، فبأيتهما قرأ القارئ فمصيب الصواب فيه».</div></p><p><div></p><p><p><span class="item-no">٥٥٨٩١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> أنه كان يقرؤها: <span class="qpc-hafs">﴿وإنّا لَجَمِيعٌ حاذِرُونَ﴾</span>{5}. (١١/٢٥٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَجَمِیعٌ حَـٰذِرُونَ ۝٥٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٨٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، قال: مُؤْدُون مُقْوُون في السِّلاح والكُراع{5}. (١١/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رزين- أنه قرأ: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، قال: مُؤْدُون مُقْوُون{7}. (١١/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، ما الحاذرون؟ قال: التّامُّون السلاح، قال فيه النجاشي:</p><p>لعمر أبي أُثالٍ حيث أمسى لقد نادت به أبناء بكر</p><p>حنيفة في كتائب حاذرات يقودهم أبو شبل هزبر{8}. (١١/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٥<span class="dash">-</span></span> عن <span class="name-2">الأسود بن يزيد النخعي</span> -من طريق أبي إسحاق- أنّه كان يقرأها: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، قال: مُؤْدُون مُقْوُون{9}. (١١/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٦<span class="dash">-</span></span> عن <span class="name-2">الأسود بن يزيد النخعي</span> أنّه كان يقرأ: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، يقول: وادُّون مستعدون{5}. (١١/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنه كان يقرأ: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، يقول: مؤدُون في السلاح{11}. (١١/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>: يعني: شاكِين في السلاح{12}. (١١/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٨٩٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي العرجاء- أنه كان يقرأ: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، يقول: مؤدون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن قيس</span> -من طريق أبي معشر- قال: كان مع فرعون ستمائة ألف حصان أدهم، سوى ألوان الخيل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، يقول: حَذِرْنا. قال: جمعنا أمرنا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span>، قال: مُؤْدُون مُعِدُّون في السلاح والكراع{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال فرعون: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span> علينا السلاح{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span> مُتَسَلِّحون ... وسمعت بعضَهم يقول: <span class="qpc-hafs">﴿حاذرون﴾</span> في القوة والسلاح{18}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وابن ذكوان، وقرأ بقية العشرة: ‹حَذِرُونَ› بإسقاط الألف. انظر: النشر ٢/٣٣٥، والإتحاف ص٤٢١.|2:أخرجه ابن جرير ١٧/٥٧٧، وإسحاق البستي في تفسيره ص٥٣٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:كذا في المطبوع، والصحيح: يونس بن أبي إسحاق، كما في الأثر الذي قبله.|4:أخرجه يحيى بن سلام ٢/٥٠٤. كذا ضبطت محققته القراءة ‹حَذِرُونَ›بإسقاط الألف، وضبطت الرواية السابقة بإثبات الألف <span class="qpc-hafs">﴿حاذرون﴾</span>.|5:عزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ١٧/٥٧٨. وعزاه السيوطي إلى ابن أبي حاتم.|8:عزاه السيوطي إلى ابن الأنباري في الوقف.|9:أخرجه ابن جرير ١٧/٥٧٧، وإسحاق البستي في تفسيره ص٥٣٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه يحيى بن سلام ٢/٥٠٤ بلفظ: مقوون.|10:عزاه السيوطي إلى عبد بن حميد.|11:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|12:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|13:أخرجه ابن جرير ١٧/٥٧٨.|14:أخرجه ابن جرير ١٧/٥٧٨.|15:أخرجه ابن جرير ١٧/٥٧٨.|16:أخرجه ابن جرير ١٧/٥٧٨.|17:تفسير مقاتل بن سليمان ٣/٢٦٥.|18:تفسير يحيى بن سلام ٢/٥٠٤.
  26,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخۡرَجۡنَـٰهُم مِّن جَنَّـٰتࣲ وَعُیُونࣲ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٩٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأخرجناهم من جنات وعيون وكنوز ومقام كريم﴾</span>، قال: كانوا في ذلك في الدنيا، فأخرجهم الله مِن ذلك، وأورثها بني إسرائيل{1}. (١١/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿فأخرجناهم﴾</span> مِن مصر، <span class="qpc-hafs">﴿من جنات﴾</span> يعني: البساتين، <span class="qpc-hafs">﴿وعيون﴾</span> يعني: أنهار جارية{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٢٦٥.
  26,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُنُوزࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٩٠٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: سمّاها: كنوزًا؛ لأنّه لم يُعْطِ حقَّ الله منها، وما لم يُعْطَ حقُّ الله منه فهو كنز، وإن كان ظاهرًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿وكنوز﴾</span>، يعني: الأموال الظاهرة مِن الذهب والفضة، وإنما سُمِّي: كنزًا؛ لأنه لم يعط حق الله ﷿ منه، وكل ما لم يعط حق الله تعالى منه فهو كنز، وإن كان ظاهرًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وكنوز﴾</span>، أي: وأموال{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَقَامࣲ كَرِیمࣲ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ومقام كريم﴾</span>، قال: المنابِر{4}. (١١/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١١<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٢<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، مثل ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ومقام كريم﴾</span>، أي: في الدنيا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ومقام كريم﴾</span>، يعني: مَسْكنًا حَسَنًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٥<span class="dash">-</span></span> عن <span class="name-2">عُقَيْل</span> -من طريق ابن لهيعة- قال: سمعت: أنّ المقام الكريم: الفَيُّوم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال سبحانه: <span class="qpc-hafs">﴿ومقام كريم﴾</span>، يعني: المساكن الحسان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ومقام كريم﴾</span>، أي: منزل حسن{10}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/١٦٥، وتفسير البغوي ٦/١١٤.|2:تفسير مقاتل بن سليمان ٣/٢٦٥.|3:تفسير يحيى بن سلام ٢/٥٠٥.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:تفسير البغوي ٦/١١٤.|6:علَّقه يحيى بن سلام ٢/٥٠٥.|7:علَّقه يحيى بن سلام ٢/٥٠٥.|8:أخرجه ابن وهب في الجامع ٢/١٥٢ (٣١٠).|9:تفسير مقاتل بن سليمان ٣/٢٦٥.|10:تفسير يحيى بن سلام ٢/٥٠٥، وأخرجه أبو عمرو الداني في المكتفى ص١٥٠ (٢١) من طريق أحمد.
  26,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَۖ وَأَوۡرَثۡنَـٰهَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٩١٨<span class="dash">-</span></span> قال يحيى بن سلّام: قال: <span class="qpc-hafs">﴿كذلك﴾</span>، أي: كذلك كان الخبر. في تفسير <span class="name-2">الحسن [البصري]</span>. وقال بعضهم: <span class="qpc-hafs">﴿كذلك﴾</span> أي: هكذا، ثم انقطع الكلام، ثم قال: <span class="qpc-hafs">﴿وأورثناها بني إسرائيل﴾</span> رجعوا إلى مصر بعدما أهلك الله فرعون وقومه، في تفسير <span class="name-2">الحسن</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك﴾</span> هكذا فعلنا بهم في الخروج من مصر، وما كانوا فيه من الخير، <span class="qpc-hafs">﴿وأورثناها بني إسرائيل﴾</span> وذلك أنّ الله ﷿ ردَّ بني إسرائيل بعدما أغرق فرعون وقومه إلى مصر{2}<span class=comment-ref>٤٧٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٩٧</span> قال <u>ابنُ عطية</u> (٦/٥٨٤): «توريث بني إسرائيل يحتمل مقصدين: <b>أحدهما</b>: أنه تعالى ورَّثَهم هذه الضفة من أرض الشام. <b>والآخر</b>: أنه ورَّثَهم مصر، ولكن بعد مدة طويلة من الدهر. قاله الحسن. على أن <span class="mustanad">التواريخ</span> لم تتضمن ملك بني إسرائيل في مصر».</div></p><p><div></p><p><p><span class="item-no">٥٥٩٢٠<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- <span class="qpc-hafs">﴿كذلك﴾</span>: أي: [هكذا] كان الخبر{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ٢/٥٠٥.|2:تفسير مقاتل بن سليمان ٣/٢٦٥.|3:أخرجه أبو عمرو الداني في المكتفى ص١٥٠ (٢١). وينظر أثر ابن سلاّم السابق.
  26,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَتۡبَعُوهُم مُّشۡرِقِینَ ۝٦٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٥٩٢١<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (واتَّبَعُوهُم مُّشْرِقِينَ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٢٢<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿فَأَتْبَعُوهُم مُّشْرِقِينَ﴾</span> مهموزة، مقطوعة الألف{2}. (١١/٢٥٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَتۡبَعُوهُم مُّشۡرِقِینَ ۝٦٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٩٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فأتبعوهم مشرقين﴾</span>، قال: خرج موسى ليلًا، فكسف القمر ليلًا، وأظلمت الأرض، فقال أصحابُه: إنّ يوسف كان أخبرنا أنا سَنُنَجّى مِن فرعون، وأخذ علينا العهد لنخرجنَّ بعظامه معنا. فخرج موسى مِن ليلته يسأل عن قبره، فوجد عجوزًا بيتها على قبره، فأخرجته له بحُكْمِها، فكان حكمُها أن قالت له: احملني، فأخرِجني معك. فجعل عظامَ يوسف في كسائه، ثم حمل العجوز على كسائه، فجعله على رقبته، وخيل فرعون في ملء أعنتها حُضرًا{3} في أعينهم ولا تبرح؛ حُبِسَت عن موسى وأصحابه حتى تَوارَوْا{4}. (١١/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فأتبعوهم مشرقين﴾</span>، قال: أتبعهم فرعون وجنوده حين أشرقت الشمس{5}. (١١/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٢٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- قال: لقد ذُكِر لي: أنّ فرعون خرج في طلب موسى على ستمائة ألف مِن الخيل دُهم، كلها وُرْق{6} حصان، سوى ما كان في جنده من سائر الخيل. قال: فخرجوا في طلب موسى كما قال الله: <span class="qpc-hafs">﴿فأتبعوهم مشرقين﴾</span> عند طلوع الشمس{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿فأتبعوهم﴾</span> يقول: فاتبعهم فرعون وقومه <span class="qpc-hafs">﴿مشرقين﴾</span> يعني: ضُحًى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٩٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: رجع إلى أول القصة <span class="qpc-hafs">﴿فأخرجناهم من جنات وعيون﴾</span> حيث اتبعوا بني إسرائيل صبيحة الليلة التي سروا فيها حين أشرقت الشمس{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٦.</p><p>وهي قراءة شاذة.|2:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.|3:حُضْرًا: تعدو عَدْوًا. لسان العرب (حضر).|4:أخرجه يحيى بن سلام ٢/٥٠٣ من طريق ابن مجاهد مختصرًا، وابن جرير ١٧/٥٧٩، ومن طريق ابن جريج أيضًا مختصرًا، وابن أبي حاتم ٨/٢٧٦٨-٢٧٦٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|5:أخرجه ابن أبي حاتم ٨/٢٧٧٠. وعلَّقه يحيى بن سلام ٢/٥٠٥. وعزاه السيوطي إلى عبد بن حميد.|6:وُرْق: سَوادٌ في غُبْرة. وقيل: سَواد وبَياض. اللسان (ورق).|7:أخرجه ابن عساكر في تاريخ دمشق ٦١/٧٦.|8:تفسير مقاتل بن سليمان ٣/٢٦٦.|9:تفسير يحيى بن سلام ٢/٥٠٥.