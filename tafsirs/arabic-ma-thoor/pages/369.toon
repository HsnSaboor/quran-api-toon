quran[21]{c,v,t}:
26,40," <q>﴿لَعَلَّنَا نَتَّبِعُ ٱلسَّحَرَةَ إِن كَانُوا۟ هُمُ ٱلۡغَـٰلِبِینَ ۝٤٠﴾</q> - تفسير ٥٥٨٠٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فلمّا اجتمعوا في صعيدٍ قال الناسُ بعضهم لبعض: انطلقوا، فلنحضر هذا الأمر، ونتبع السحرة إن كانوا هم الغالبين. يعني بذلك: موسى وهارون -صلى الله عليهما وسلم-؛ استهزاء بهما{1}. (ز) ٥٥٨٠٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وقيل للناس هل أنتم مجتمعون﴾</q>، قال: كانوا بالإسكندرية. قال: ويُقال: بلغ ذَنَب الحية من وراء البحيرة يومئذ. قال: وهربوا، وأسلموا فرعون، وهمَّت به، فقال: خذها، يا موسى. وكان مما بلي الناس به منه أنّه كان لا يضع على الأرض شيئًا، فأحدث يومئذ تحته، وكان إرساله الحيَّة في القُبَّة الخضراء{2}. (١١/٢٤٤) ٥٥٨٠٤- قال مقاتل بن سليمان: <q>﴿لعلنا نتبع السحرة﴾</q> على أمرهم <q>﴿إن كانوا هم الغالبين﴾</q> لموسى وأخيه. واجتمعوا، فقال موسى للساحر الأكبر: تؤمن بي إن غلبتُك؟ قال الساحر: لآتِيَنَّ بسحرٍ لا يغلبه سِحْر، فإن غلبتني لأومنن بك. وفرعون ينظر إليهما، ولا يفهم ما يقولان{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥، ٨/٢٧٦٢.أخرجه ابن جرير ١٧/٥٦٨ وعنده: القبة الحمراء.تفسير مقاتل بن سليمان ٣/٢٦٣.
26,41," <q>﴿فَلَمَّا جَاۤءَ ٱلسَّحَرَةُ قَالُوا۟ لِفِرۡعَوۡنَ أَىِٕنَّ لَنَا لَأَجۡرًا إِن كُنَّا نَحۡنُ ٱلۡغَـٰلِبِینَ ۝٤١﴾</q> - تفسير ٥٥٨٠٥- عن عبد الله بن عباس -من طريق مقسم- يعني: قوله: <q>﴿فلما جاء السحرة﴾</q>، قالوا: إنّ هذا فعل كذا وكذا. قالوا: هذا ساحر يسحر الناس، ولا يسحر الساحرُ الساحرَ. قال: نعم، <q>﴿وإنكم إذا لمن المقربين﴾</q>{1}. (ز) ٥٥٨٠٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فلمّا أتوْا فرعون قالوا: بِمَ يعمل هذا الساحر؟ قالوا: يعمل بالحيات. قالوا: واللهِ، ما في الأرض قوم يعملون بالسحر والحيات والحبال والعصي أعلم مِنّا، فما أجرنا إن غلبنا؟ فقال لهم: أنتم قرابتي وخاصَّتي، وأنا صانع إليكم كلَّ شيء أحببتم{2}. (ز) ٥٥٨٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿فلما جاء السحرة قالوا لفرعون ائن لنا اجرا ان كنا نحن الغالبين﴾</q> يقول: عطية تعطينا <q>﴿إن كنا نحن الغالبين﴾</q>. قال: نعم، <q>﴿وإنكم إذًا لمن المقربين﴾</q>{1}. (ز) ٥٥٨٠٨- قال مقاتل بن سليمان: <q>﴿فلما جاء السحرة قالوا لفرعون أإن لنا لأجرا﴾</q> يعني: جُعْلًا؛ <q>﴿إن كنا نحن الغالبين﴾</q> لموسى وأخيه؟{4}. (ز) ٥٥٨٠٩- قال يحيى بن سلّام: <q>﴿فلما جاء السحرة قالوا لفرعون أئن لنا لأجرا﴾</q> على الاستفهام؛ <q>﴿إن كنا نحن الغالبين﴾</q>؟{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٣.أخرجه ابن جرير ١٠/٣٥٣، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٣.أخرجه ابن أبي حاتم ٨/٢٧٦٣.تفسير مقاتل بن سليمان ٣/٢٦٣.تفسير يحيى بن سلام ٢/٥٠٢.
26,42," <q>﴿قَالَ نَعَمۡ وَإِنَّكُمۡ إِذࣰا لَّمِنَ ٱلۡمُقَرَّبِینَ ۝٤٢﴾</q> - تفسير ٥٥٨١٠- تفسير الحسن البصري: قوله: <q>﴿نعم وإنكم إذا لمن المقربين﴾</q> في العَطِيَّة، والقُرْبَة في المنزِلة{1}. (ز) ٥٥٨١١- قال قتادة بن دعامة: في العطية، والفضيلة{1}. (ز) ٥٥٨١٢- قال مقاتل بن سليمان: <q>﴿قال﴾</q> فرعون: <q>﴿نعم﴾</q> لكم الجعل، <q>﴿وإنكم إذا لمن المقربين﴾</q> عندي في المنزلة سوى الجُعل{3}. (ز) ٥٥٨١٣- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فلما جاء السحرة﴾</q>، قال: فلمّا اجتمعوا إليه أمرهم أمره، وقال لهم: قد جاءنا ساحِرٌ ما رأينا مثلَه قطُّ، وإنكم إن غلبتموه أكرمتُكم، وفضَّلتُكم، وقرَّبتكم على أهل مملكتي. قالوا: وإنّ لنا ذلك إن غلبناه؟ قال: نعم. قالوا: فعِدْهُ لنا مَوْعِدًا نجتمع فيه نحن وهو. وكان رؤوس السحرة التي جمع فرعون لموسى فيما بلغني: أربعة من الذين آمنوا حين رأوا من سلطان الله، فآمنت معهم السحرة جميعًا{4}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ٢/٥٠٢.علَّقه يحيى بن سلام ٢/٥٠٢.تفسير مقاتل بن سليمان ٣/٢٦٣.أخرجه ابن جرير ١٠/٣٥٤، وابن أبي حاتم ٨/٢٧٦٣.
26,43," <q>﴿قَالَ لَهُم مُّوسَىٰۤ أَلۡقُوا۟ مَاۤ أَنتُم مُّلۡقُونَ ۝٤٣﴾</q> - تفسير ٥٥٨١٤- قال مقاتل بن سليمان: <q>﴿قال لهم موسى ألقوا﴾</q> ما في أيديكم مِن الحبال والعصي <q>﴿مآ أنتم ملقون﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٣.
26,44," <q>﴿فَأَلۡقَوۡا۟ حِبَالَهُمۡ وَعِصِیَّهُمۡ وَقَالُوا۟ بِعِزَّةِ فِرۡعَوۡنَ إِنَّا لَنَحۡنُ ٱلۡغَـٰلِبُونَ ۝٤٤﴾</q> - تفسير ٥٥٨١٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: <q>﴿قالوا يا موسى﴾</q> لقدرتهم بسحرهم: <q>﴿إما أن تلقي وإما أن نكون نحن الملقين﴾</q> قال: ألقوا، <q>﴿فَأَلْقَوْا حِبالَهُمْ وعِصِيَّهُمْ وقالُوا بِعِزَّةِ فِرْعَوْنَ إنّا لَنَحْنُ الغالِبُونَ﴾</q>. فرأى موسى مِن سحرهم ما أوجس في نفسه خِيفة، فأوحى الله ﷿ إليه: أن ألْقِ العصا{1}. (ز) ٥٥٨١٦- عن قتادة بن دعامة، في قوله: <q>﴿وقالوا بعزة فرعون إنا لنحن الغالبون﴾</q>، قال: فوجدوا اللهَ أعَزَّ مِنه{2}. (١١/٢٤٤) ٥٥٨١٧- تفسير إسماعيل السُّدِّيّ: <q>﴿وقالوا بعزة فرعون﴾</q> بعظمة فرعون{3}. (ز) ٥٥٨١٨- عن بشر بن منصور -من طريق عبد الأعلى بن حماد- قال: بلغني: أنّه لما تكلم ببعض هذا: <q>﴿وقالوا بعزة فرعون﴾</q>. قالت الملائكةُ: قصمه، وربِّ الكعبة. فقال الله: تَأَلَّوْنَ عَلَيَّ! قد أمهلتُه أربعين عامًا{4}. (١١/٢٤٤) ٥٥٨١٩- قال مقاتل بن سليمان: <q>﴿فألقوا حبالهم وعصيهم وقالوا بعزة فرعون﴾</q> يعني: بعظمة فرعون، كقولهم لشعيب: <q>﴿وما أنت علينا بعزيز﴾</q> [هود:٩١]، يعني: بعظيم. <q>﴿إنا لنحن الغالبون﴾</q> فإذا هي حيّات في أعين الناس وفي عين موسى وهارون، تسعى إلى موسى وأخيه، وإنّما هي حبال وعصي لا تحرك، فخاف موسى، فقال جبريل لموسى ﵇: ألقِ عصاك. فإذا هي حيَّة عظيمة سَدَّت الأُفُق برأسها، وعلَّقت ذنبَها في قُبَّة لفرعون، طول القبة سبعون ذراعًا في السماء، وذلك في المحرم يوم السبت لثماني ليال خَلَوْن مِن المُحَرَّم{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥، ٨/٢٧٦٤.أخرجه ابن أبي حاتم ٨/٢٧٦٤. وعزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ٢/٥٠٢.أخرجه ابن أبي حاتم ٨/٢٧٦٤.تفسير مقاتل بن سليمان ٣/٢٦٣.
26,45," <q>﴿فَأَلۡقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ ۝٤٥﴾</q> - تفسير ٥٥٨٢٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فأوحى الله إليه: أن ألقِ العصا. فلمّا ألقاها صارت ثعبانًا عظيمًا فاغرةً فاها. قال: فجعلت العصا بدعوة موسى تلتبس بالحبال، فصارت جَزرًا{1} إلى الثعبان، حتى تدخل فيه، حتى ما بقيت عصًا ولا حبل إلا ابتلعته{2}. (ز) ٥٥٨٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تلقف ما يأفكون﴾</q>، قال: يَكذِبون{3}. (٦/٤٩٩) ٥٥٨٢٢- عن الحسن البصري -من طريق قُرَّة بن خالد- في قوله: <q>﴿تلقف ما يأفكون﴾</q>، قال: تَسْتَرِطُ{4} حبالَهم وعِصيَّهم{5}. (٦/٤٩٩) ٥٥٨٢٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فاذا هي تلقف ما يأفكون﴾</q>: مِن سحرهم{6}. (ز) ٥٥٨٢٤- قال مقاتل بن سليمان: ثم إنّ حيَّة موسى فتحت فاها، فجعلت تَلْقَم تلك الحيات، فلم يبق منها شيءٌ، فذلك قوله ﷿: <q>﴿فألقى موسى عصاه فإذا هي تلقف ما يأفكون﴾</q>، يعني: فإذا هي تلقم ما يكذبون مِن سحرهم، ثم أخذ موسى ﵇ بذَنَبها، فإذا هي عصًا كما كانت، فقال السحرةُ بعضهم لبعض: لو كان هذا سحر لبقيت الحبال والعصي{7}. (ز) ٥٥٨٢٥- قال يحيى بن سلّام: <q>﴿تلقف ما يأفكون﴾</q> تسرط حبالهم وعصيَّهم، لما ألقوا حبالهم وعصيهم خُيِّل إلى موسى أنّ حبالهم وعصيهم حيّات كما كانت عصا موسى، فألقى موسى عصاه فإذا هي أعظم مِن حياتهم، ثم رَقُوا{8}، فازدادت حياتهم وعصيهم عِظَمًا في أعين الناس، وجعلت عصا موسى تعظمهم، وهم يَرْقُون، حتى أنفذوا سحرهم، فلم يبق منه شيء، وعظمت عصا موسى حتى سدَّت الأفق، ثم فتحت فاها فابتلعت ما ألقوا، ثم أخذ موسى عصاه بيده، فإذا حبالهم وعصيهم قد ذهبت، فهو قوله: <q>﴿فألقى موسى عصاه فإذا هي تلقف ما يأفكون﴾</q>{9}. (ز) ",footnotes:1:الجَزَر: الغنم التي تصلح للجَزْرِ، أي: الذَّبْح، ولا يقال إلا في الغنم خاصَّةً. النهاية (جزر).أخرجه ابن أبي حاتم ٥/١٥٣٥، ٨/٢٧٦٥.تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٥٩-٣٦٠، وابن أبي حاتم ٥/١٥٣٦، ٨/٢٧٦٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.تَسْتَرِط: تبتلع. اللسان (سرط).أخرجه ابن جرير ١٠/٣٦٠، وابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٨/٢٧٦٥.تفسير مقاتل بن سليمان ٣/٢٦٤.رَقُوا: من الرُّقْية. النهاية واللسان (رقى).تفسير يحيى بن سلام ٢/٥٠٢.
26,46," <q>﴿فَأُلۡقِیَ ٱلسَّحَرَةُ سَـٰجِدِینَ ۝٤٦﴾</q> - تفسير ٥٥٨٢٦- عن عبد الله بن عباس -من طريق عكرمة-: فألقى عصاه فإذا هي حيَّة جعلت تلقف ما يأفكون، لا تَمُرُّ بشيء من حبالهم وخشبهم التي ألقوها إلا التقمته، فعرفت السحرةُ أنّ هذا أمر من السماء، وليس هذا بسحر، فخرُّوا سُجَّدًا، وقالوا: <q>﴿آمنا برب العالمين رب موسى وهارون﴾</q>{1}. (ز) ٥٥٨٢٧- عن سعيد بن جبير -من طريق سالم الأفطس- في قوله: <q>﴿وألقي السحرةُ ساجدين﴾</q>، قال: رأوا منازلَهم تُبنى لهم وهم في سُجودِهم{2}. (٦/٥٠٠) ٥٥٨٢٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: أوحى الله ﷿ إلى موسى: أن ألقِ ما في يمينك. فألقى عصاه، فأكلت كلَّ حية لهم، فلمّا رأوا ذلك سجدوا{3}. (ز) ٥٥٨٢٩- قال مقاتل بن سليمان: فذلك قوله ﷿: <q>﴿فألقي السحرة ساجدين﴾</q> لله ﷿{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٥٨.أخرجه ابن أبي حاتم ٥/١٥٣٦، ٨/٢٧٦٦.أخرجه ابن أبي حاتم ٨/٢٧٦٦. وقد ذكر ﵀ في هذا الموضع آثارًا عديدة عن عدد السحرة. وتقدمت المسألة عند تفسير قوله تعالى: <q>﴿وجاءَ السَّحَرَةُ فِرْعَوْنَ﴾</q> [الأعراف:١١٣].تفسير مقاتل بن سليمان ٣/٢٦٤.
26,47," <q>﴿قَالُوۤا۟ ءَامَنَّا بِرَبِّ ٱلۡعَـٰلَمِینَ ۝٤٧ رَبِّ مُوسَىٰ وَهَـٰرُونَ ۝٤٨﴾</q> - تفسير ٥٥٨٣٠- عن عبد الله بن عباس -من طريق سعيد بن جبير-: فلمّا عرفت السحرة ذلك قالوا: لو كان هذا سِحرًا لم يبلغ مِن سحرنا كلَّ هذا، ولكن هذا أمرٌ مِن الله، آمنا بالله، وبما جاء به موسى، ونتوب إلى الله مِمّا كُنّا عليه{1}. (ز) ٥٥٨٣١- عن قتادة بن دعامة -من طريق سعيد- قال: ذُكِر لنا: أنّ السحرة قالوا حين اجتَمَعوا: إن يكُ ما جاء به سِحرًا فلن نُغْلَبَ، وإن يكُ مِن الله فستَرَوْنَ. فلمّا ألقى عصاه أكلتْ ما أفَكوا مِن سحرهم، وعادَت كما كانت؛ علِموا أنّه من الله، فأُلقُوا عندَ ذلك ساجدين، <q>﴿قالوا ءامنا برب العالمين﴾</q>{2}. (٦/٤٩٩) ٥٥٨٣٢- قال مقاتل بن سليمان: <q>﴿قالوا آمنا برب العالمين﴾</q> لقول موسى: أنا رسول رب العالمين. فقال فرعون: أنا رب العالمين. قالت السحرة: <q>﴿رب موسى وهارون﴾</q>. فبُهِت فرعونُ عند ذلك، وألقى بيديه{3}. (ز) ٥٥٨٣٣- عن محمد بن إسحاق -من طريق سلمة- قال: كان مِن رؤوس السحرة الذين جمَعَ فرعون لموسى -فيما بلغني-: سابُورُ، وعاذُورُ، وحَطْحَطُن، ومُصْفى؛ أربعةٌ هم الذين آمَنوا حين رأوا ما رأوا من سلطان الله، فآمَنت معهم السحرةُ جميعًا{4}. (٦/٥٠١) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٧، ٨/٢٧٦٦.أخرجه ابن أبي حاتم ٨/٢٧٦٦. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن أبي حاتم ٨/٢٧٦٦.
  26,48,""
26,49," <q>﴿قَالَ ءَامَنتُمۡ لَهُۥ قَبۡلَ أَنۡ ءَاذَنَ لَكُمۡۖ﴾</q> - تفسير ٥٥٨٣٤- قال مقاتل بن سليمان: <q>﴿قال﴾</q> فرعون للسحرة: <q>﴿آمنتم له﴾</q> يقول: صدَّقتم بموسى <q>﴿قبل أن آذن لكم﴾</q> يقول: مِن قبل أن آمركم بالإيمان به{1}. (ز) ٥٥٨٣٥- عن محمد بن إسحاق -من طريق سلمة- قال: قال لهم فرعون وأسف ورأى الغلبة البيِّنة: <q>﴿آمنتم له قبل أن آذن لكم﴾</q>{2}. (ز) ٥٥٨٣٦- قال يحيى بن سلّام: في قوله: <q>﴿قال آمنتم له﴾</q> أصَدَّقتُموه{3}. (ز) <q>﴿إِنَّهُۥ لَكَبِیرُكُمُ ٱلَّذِی عَلَّمَكُمُ ٱلسِّحۡرَ فَلَسَوۡفَ تَعۡلَمُونَۚ﴾</q> - تفسير ٥٥٨٣٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إنه لكبيركم﴾</q>: يعني بكبيرهم: موسى ﷺ{2}. (ز) ٥٥٨٣٨- تفسير إسماعيل السُّدِّيّ: <q>﴿إنه لكبيركم﴾</q>، أي: لعالمكم في علم السحر، ولم يكن أكبرهم في السن{5}. (ز) ٥٥٨٣٩- قال مقاتل بن سليمان: ثم قال فرعون للسحرة: <q>﴿إنه لكبيركم الذي علمكم السحر﴾</q> إنّ هذا لَمَكْرٌ مكرتموه، يقول: إنّ هذا لَقَوْلٌ قلتموه أنتم -يعني به: السحرة وموسى- في المدينة -يعني: في أهل مدين{6}- لتخرجوا منها أهلها؛ بقول الساحر الأكبر لموسى حين قال: لئن غلبتني [لأؤمننَّ] بك. ثم قال فرعون: <q>﴿فلسوف تعلمون﴾</q>. هذا وعيد، فأخبرهم بالوعيد، فقال: <q>﴿لأقطعن أيديكم وأرجلكم من خلاف﴾</q>{1}. (ز) ٥٥٨٤٠- عن محمد بن إسحاق -من طريق سلمة- <q>﴿إنه لكبيركم الذي علمكم السحر﴾</q>: أي: إنه لعظيم السُّحّار الذي علَّمكم السحر{2}. (ز) <q>﴿لَأُقَطِّعَنَّ أَیۡدِیَكُمۡ وَأَرۡجُلَكُم مِّنۡ خِلَـٰفࣲ وَلَأُصَلِّبَنَّكُمۡ أَجۡمَعِینَ ۝٤٩﴾</q> - تفسير ٥٥٨٤١- قال مقاتل بن سليمان: <q>﴿لأقطعن أيديكم وأرجلكم من خلاف﴾</q> يعني: اليد اليمنى والرجل اليسرى، <q>﴿ولأصلبنكم أجمعين﴾</q> في جذوع النخل{1}. (ز) ٥٥٨٤٢- قال يحيى بن سلّام: <q>﴿لأقطعن أيديكم وأرجلكم من خلاف﴾</q> اليد اليمنى والرجل اليسرى، <q>﴿ولأصلبنكم أجمعين﴾</q>{10}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن أبي حاتم ٨/٢٧٦٧.تفسير يحيى بن سلام ٢/٥٠٢.أخرجه ابن أبي حاتم ٨/٢٧٦٧.علَّقه يحيى بن سلام ٢/٥٠٣.كذا في المصدر.تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن أبي حاتم ٨/٢٧٦٧.تفسير مقاتل بن سليمان ٣/٢٦٤.تفسير يحيى بن سلام ٢/٥٠٣.
26,50," <q>﴿قَالُوا۟ لَا ضَیۡرَۖ﴾</q> - تفسير ٥٥٨٤٣- قال مقاتل بن سليمان: فردَّت عليه السحرةُ حين أوعدهم بالقتل والصلب، <q>﴿قالوا لا ضير﴾</q> ما عسيت تصنع؟! هل هو إلا تقتلنا؟!{1}. (ز) ٥٥٨٤٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا ضير﴾</q>، قال: يقولون: لا يَضُرُّنا الذي تقول، وإن صنعته بنا وصلبتنا{2}. (١١/٢٤٥) <q>﴿إِنَّاۤ إِلَىٰ رَبِّنَا مُنقَلِبُونَ ۝٥٠﴾</q> - تفسير ٥٥٨٤٥- عن سعيد بن جبير -من طريق عطاء- <q>﴿إنا إلى ربنا منقلبون﴾</q>: يعني: إنا إلى ربنا راجعون{3}. (ز) ٥٥٨٤٦- قال مقاتل بن سليمان: <q>﴿إنا إلى ربنا منقلبون﴾</q>، يعني: لراجعون إلى الآخرة{1}. (ز) ٥٥٨٤٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنا إلى ربنا منقلبون﴾</q>، يقول: إنا إلى ربنا راجعون، وهو مُجازينا بصبرِنا على عقوبتك إيّانا، وثباتنا على توحيده، والبراءة من الكفر به{5}. (١١/٢٤٥) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن جرير ١٧/٥٧١، وابن أبي حاتم ٨/٢٧٦٧ من طريق أصبغ.أخرجه ابن أبي حاتم ٨/٢٧٦٧.تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن جرير ١٧/٥٧١.
26,51," <q>﴿إِنَّا نَطۡمَعُ أَن یَغۡفِرَ لَنَا رَبُّنَا خَطَـٰیَـٰنَاۤ﴾</q> - تفسير ٥٥٨٤٨- قال مقاتل بن سليمان: <q>﴿إنا نطمع﴾</q> أي: نرجو <q>﴿أن يغفر لنا ربنا خطايانا﴾</q> يعني: سحرنا{1}. (ز) ٥٥٨٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنا نطمع أن يغفر لنا ربنا خطايانا﴾</q>، قال: السِّحر والكُفْر الذي كانوا فيه{2}. (ز) <q>﴿أَن كُنَّاۤ أَوَّلَ ٱلۡمُؤۡمِنِینَ ۝٥١﴾</q> - تفسير ٥٥٨٥٠- عن عبد الله بن عباس -من طريق السُّدِّيّ- قال: أصبحوا سَحَرَةً، وأمسَوا شهداء. وفي لفظٍ: كانوا سحرة في أول النهار، وشهداءَ آخر النهار حين قُتِلوا{3}. (٦/٤٩٦) ٥٥٨٥١- عن كعب الأحبار -من طريق خيثمة- قال: أصبحوا كُفّارًا، وأمسوا شهداء{4}. (ز) ٥٥٨٥٢- عن قتادة بن دعامة -من طريق سعيد- قال: كانوا أوَّل النهار سحرةً، وآخره شهداء{5}. (ز) ٥٥٨٥٣- قال إسماعيل السُّدِّيّ: <q>﴿أن كنا﴾</q> بأن كُنّا <q>﴿أول المؤمنين﴾</q> أول المُصَدِّقين مِن بني إسرائيل لِما جاء به موسى{5}٤٧٩٢. (ز) ٤٧٩٢ قال ابنُ عطية (٦/٤٨٢): «وقولهم: <q>﴿أنْ كُنّا أوَّلَ المُؤْمِنِينَ﴾</q> يريدون: مِن القبط وصنيعتهم، وإلا فقد كانت بنو إسرائيل آمنت». ٥٥٨٥٤- قال مقاتل بن سليمان: <q>﴿أن كنا أول المؤمنين﴾</q>، يعني: أول المصدقين بتوحيد الله ﷿ مِن أهل مصر، فقطعهم وصلبهم فرعونُ مِن يومه{1}. (ز) ٥٥٨٥٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أن كنا أول المؤمنين﴾</q>، قال: كانوا كذلك يومئذٍ أولَ مَن آمن بآياته حين رأوها{2}. (١١/٢٤٥) ٥٥٨٥٦- قال يحيى بن سلّام: <q>﴿أن كنا﴾</q> يعني: بأن كنا <q>﴿أول المؤمنين﴾</q> مِن السَّحَرَة{9}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن جرير ١٧/٥٧١، وابن أبي حاتم ٨/٢٧٦٧ من طريق أصبغ.أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٦٤، وابن أبي حاتم ٥/١٥٣٨. وعلَّقه مقاتل بن سليمان في تفسيره ٣/٢٦٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥١٠-.علَّقه يحيى بن سلام ٢/٥٠٣.علَّقه يحيى بن سلام ٢/٥٠٣.تفسير مقاتل بن سليمان ٣/٢٦٤.أخرجه ابن جرير ١٧/٥٧١، وابن أبي حاتم ٨/٢٧٦٧ من طريق أصبغ.تفسير يحيى بن سلام ٢/٥٠٣.
26,52," <q>﴿وَأَوۡحَیۡنَاۤ إِلَىٰ مُوسَىٰۤ أَنۡ أَسۡرِ بِعِبَادِیۤ إِنَّكُم مُّتَّبَعُونَ ۝٥٢﴾</q> - تفسير ٥٥٨٥٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فلمّا طال مُكث موسى لمواعيد فرعون الكاذبة؛ أُمِر موسى بالخروج بقومه، فخرج بهم ليلًا{1}. (ز) ٥٥٨٥٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثم إنّ الله أمر موسى أن يخرج ببني إسرائيل، فقال: <q>﴿أسر بعبادي ليلا﴾</q>، فأمر موسى بني إسرائيل أن يخرجوا، وأمرهم أن يستعيروا الحُلِيَّ مِن القِبْط، وأمر أن لا ينادي أحدٌ منهم صاحبَه، وأن يُسْرِجوا في بيوتهم حتى الصبح، وأنّ مَن خرج منهم يلطخ أمام بابه بكفٍّ مِن دم حتى يُعلم أنه قد خرج، وأنّ الله قد أخرج كل ولد زنا في القِبط من بني إسرائيل إلى بني إسرائيل، وأخرج كل ولد زنا في بني إسرائيل من القِبط إلى القِبط حتى أتوا آباءَهم، ثم خرج موسى ببني إسرائيل ليلًا، والقِبْطُ لا يعلمون، وألقي على القبط الموت، فمات كل بِكْرِ رَجُلٍ منهم، فأصبحوا يدفنونهم، فشُغِلوا عن طلبهم حتى طلعت الشمس، وخرج موسى في ستمائة ألف وعشرين ألفًا، لا يَعُدُّون ابنَ عشرين لصِغَره، ولا ابن ستين لكِبَره، وإنما عدُّوا ما بين ذلك سوى الذُّرِّيَّة، وتبعهم فرعون على مقدمه هامان في ألف ألف وسبعمائة ألف حصان فيها ماذِيانة{2}، وذلك حين يقول الله: <q>﴿فأرسل فرعون في المدائن حاشرين إن هؤلاء لشرذمة قليلون﴾</q>{1}. (١١/٢٤٦) ٥٥٨٥٩- قال مقاتل بن سليمان: <q>﴿وأوحينا إلى موسى أن أسر بعبادي﴾</q> بني إسرائيل ليلًا؛ <q>﴿إنكم متبعون﴾</q> يعني: يتبعكم فرعون وقومه، فأمر جبريلُ ﵇ كلَّ أهل أربعة أبيات من بني إسرائيل في بيت، ويُعَلِّم تلك الأبواب بدم الخراف، فإنّ الله ﷿ يبعث الملائكة إلى أهل مصر، فمَن لم يروا على بابه دمًا دخلوا بيته فقتلوا أبكارَهم مِن أنفسهم وأنعامهم، فيشغلهم دفنُهم إذا أصبحوا عن طلب موسى، ففعلوا، واستعاروا حُلِيَّ أهل مصر، فساروا من ليلتهم قبل البحر، هارون على المقدمة، وموسى على الساقة، فأصبح فرعون مِن الغد يوم الأحد وقد قتلت الملائكةُ أبكارهم، فاشتغلوا بدفنهم، ثُمَّ جمع الجموع، فساروا يوم الاثنين في طلب موسى ﵇ وأصحابه، وهامان على مقدمة فرعون في ألفي ألف وخمسمائة، ويقال: ألف ألف مقاتل. فذلك قوله ﷿: <q>﴿فأرسل فرعون في المدائن حاشرين﴾</q>{4}. (ز) ٥٥٨٦٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿وأوحينا إلى موسى أن أسر بعبادي﴾</q> أي: ليلًا. وقد قال في آية أخرى: <q>﴿فأسر بعبادي ليلا﴾</q> [الدخان:٢٣]، <q>﴿إنكم متبعون﴾</q> أي: يتبعكم فرعونُ وقومه{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٨.قال محققو الدر المنثور: بعده في الأصل: الماذيانة: الأنثى من الخيل. وينظر: المعجم الذهبي ٥٣٢.أخرجه ابن أبي حاتم ٨/٢٧٦٨.تفسير مقاتل بن سليمان ٣/٢٦٥.تفسير يحيى بن سلام ٢/٥٠٣.
26,53," <q>﴿فَأَرۡسَلَ فِرۡعَوۡنُ فِی ٱلۡمَدَاۤىِٕنِ حَـٰشِرِینَ ۝٥٣﴾</q> - تفسير ٥٥٨٦١- عن يحيى بن عروة بن الزبير -من طريق ابن إسحاق- قال: إنّ الله أمر موسى أن يسير ببني إسرائيل، وقد كان موسى وعَد بني إسرائيل أن يسير بهم إذا طلع القمر، فدعا اللهَ أن يُؤَخِّر طلوعه حتى يفرُغَ، فلما سار موسى ببني إسرائيل أذَّن فرعونُ في الناس: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>{1}. (١١/٢٤٩) ٥٥٨٦٢- قال مقاتل بن سليمان: قوله ﷿: <q>﴿فأرسل فرعون في المدائن حاشرين﴾</q> يحشرون الناس في طلب موسى ﵇، وهارون ﵇، وبني إسرائيل{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٦٨ (١٥٦٥١). وعزاه السيوطي إلى ابن إسحاق، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٦٥.
26,54," <q>﴿إِنَّ هَـٰۤؤُلَاۤءِ لَشِرۡذِمَةࣱ قَلِیلُونَ ۝٥٤﴾</q> - تفسير ٥٥٨٦٣- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «كان أصحاب موسى الذين جاوزوا البحر اثني عشر سِبْطًا، فكان في كلِّ طريق اثنا عشر ألفًا، كلهم ولد يعقوب ﵇»{1}. (١١/٢٤٨) ٥٥٨٦٤- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «كان فرعونُ عدوَّ الله حيث أغرقه الله هو وأصحابه في سبعين قائدًا، مع كل قائدٍ سبعون ألفًا، وكان موسى مع سبعين ألفًا حين عبروا البحر»{2}. (١١/٢٤٩) ٥٥٨٦٥- عن عبد الله بن مسعود -من طريق أبي إسحاق، عن رجل- قال: دخل بنو إسرائيل مصر وهم ثلاثة وسبعون إنسانًا، وخرجوا منها وهم ستمائة ألف، فقال فرعون: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>{3}. (ز) ٥٥٨٦٦- عن عبد الله بن مسعود -من طريق أبي عبيدة- في قوله: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>، قال: ستمائة ألفٍ وسبعون ألفًا{4}. (١١/٢٤٨) ٥٥٨٦٧- عن أبي عبيدة [بن عبد الله بن مسعود] -من طريق أبي إسحاق-، مثله{5}. (١١/٢٤٨) ٥٥٨٦٨- عن عبد الله بن عباس، في قوله: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>، قال: كانوا ستمائة ألفٍ{6}. (١١/٢٤٨) ٥٥٨٦٩- عن عبد الله بن عباس -من طريق شهر بن حوشب- قال: كان مع فرعون يومئذ ألفُ جبّار، كلهم عليه تاج، وكلهم أميرٌ على خَيْل{7}. (ز) ٥٥٨٧٠- عن عبد الله بن عباس -من طريق عكرمة- قال: أوحى الله إلى موسى: <q>﴿أن أسر بعبادي ليلًا إنكم متبعون﴾</q>، فأسرى موسى ببني إسرائيل ليلًا، فأتبعهم فرعونُ في ألف ألفِ حصانٍ سوى الإناث، وكان موسى في ستمائة ألفٍ، فلمّا عاينهم فرعونُ قال: <q>﴿إن هؤلاء لشرذمة قليلون وإنهم لنا لغائظون وإنا لجميع حاذرون﴾</q>{8}. (١١/٢٦٠) ٥٥٨٧١- عن كعب الأحبار -من طريق محمد بن كعب، عن عبد الله بن الهاد- قال: اجتمع آلُ يعقوب إلى يوسف، وهم ستةٌ وثمانون إنسانًا؛ ذكرهم وأنثاهم، فخرج بهم موسى يوم خرج وهم ستمائة ألفٍ ونيفٌ، وخرج فرعون على إثرهم يطلبهم على فرس أدهم، على لونه مِن الدُّهْم ثمانمائةُ ألفِ أدْهَمٍ، سوى ألوان الخيل، وجالَتْ الريح الشمال، وتحت جبريلَ فرسٌ ودِيقٌ، وميكائيل يسوقهم، لا يَشُذُّ منهم شاذَّةٌ إلا ضَمَّه، فقال القوم: يا رسول الله، قد كُنّا نلقى مِن التعس والعذاب ما نلقى، فكيف إذ صنعنا ما صنعنا، فأين الملجأ؟ قال: البحر{9}. (١١/٢٥١) ٥٥٨٧٢- عن عمرو بن ميمون الأودي، قال: لَمّا أراد موسى أن يخرج ببني إسرائيل مِن مصر بلغ ذلك فرعون، فقال: أمهِلوهم، حتى إذا صاح الديكُ فأْتوهم. فلم يصِح في تلك الليلة ديكٌ، فخرج موسى ببني إسرائيل، وغدا فرعون، فلما أصبح فرعونُ أمر بشاةٍ، فأُتِي بها، فأمر بها أن تُذبَح، ثم قال: لا يفرغ مِن سلخها حتى يجتمع عندي خمسمائة ألف فارسٍ. فاجتمعوا إليه، فأتبعهم، فلما انتهى موسى إلى البحر قال له وصِيُّه: يا نبيَّ الله، أين أُمِرْت؟ قال: ههنا في البحر{10}. (١١/٢٥١) ٥٥٨٧٣- عن عبد الله بن شدّاد بن الهاد -من طريق محمد بن كعب القرظي- قال: اجتمع يعقوبُ وولدُه إلى يوسف، وهم اثنان وسبعون، وخرجوا مع موسى وهم ستمائة ألف، فقال فرعون: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>. وخرج فرعون على فرس أدهم؛ حصان على لون فرسه في عسكره ثمانمائة ألف{11}. (ز) ٥٥٨٧٤- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿لشرذمة﴾</q>، قال: قِطْعةٌ{12}. (١١/٢٤٨) ٥٥٨٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>، قال: هم يومئذ ستمائة ألفٍ، ولا يُحْصى عددُ أصحاب فرعون{13}٤٧٩٣. (١١/٢٤٨) ٤٧٩٣ قال ابنُ عطية (٦/٤٨٢): «رُوِي: أنّ بني إسرائيل كانوا ستمائة ألف وسبعين ألفًا. قاله ابن عباس. واللهُ أعلم بصحته، وإنما اللازم مِن الآية الذي يُقطَع به: أن موسى ﵇ خرج بجَمْعٍ عظيم من بني إسرائيل، وأن فرعون تبعه بأضعاف ذلك العدد». وقال ابنُ كثير (١٠/٣٤٧-٣٤٨): «ذكر غيرُ واحد من المفسرين: أنّ فرعون خرج في جَحْفَلٍ عظيم، وجمْعٍ كبير، وهو عبارة عن مملكة الديار المصرية في زمانه، أُولِي الحل والعقد والدول، من الأمراء والوزراء والكبراء والرؤساء والجنود، فأمّا ما ذكره غير واحد من الإسرائيليات من أنه خرج في ألف ألف وستمائة ألف فارس، منها مائة ألف على خيل دهم. وقال كعب الأحبار: فيهم ثمانمائة ألف حصان أدهم. ففي ذلك نظر. والظاهر أنه مِن مُجازفات بني إسرائيل، والله ﷾ أعلم. والذي أخبر به هو النافع، ولم يعين عِدَّتهم؛ إذ لا فائدة تحته، إلا أنهم خرجوا بأجمعهم». ٥٥٨٧٦- عن قتادة بن دعامة، <q>﴿لشرذمة﴾</q>، قال: الفريد مِن الناس{14}. (١١/٢٤٨) ٥٥٨٧٧- عن قتادة بن دعامة -من طريق سعيد- قال: ذُكِر لنا: أنّ بني إسرائيل الذين قطع بهم موسى البحرَ كانوا ستمائةَ ألفِ مقاتل، بني عشرين سنة فصاعدًا{15}. (ز) ٥٥٨٧٨- قال قتادة بن دعامة: كان مقدمة فرعون ألف ألف حصان ومائتي ألف ألف حصان{16}. (ز) ٥٥٨٧٩- عن محمد بن كعب القرظي، قال: خرج موسى مِن مصر ومعه ستمائة ألفٍ مِن بني إسرائيل، لا يَعُدُّون فيهم أقلَّ مِن ابن عشرين ولا ابن أكثر مِن أربعين سنةً، فقال: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>. وخرج فرعون على فرسٍ حصانٍ أدهم، ومعه ثمانمائة ألفٍ على خيلٍ دُهْمٍ، سوى ألوان الخيل، وكان جبريل ﵇ على فرسٍ أنثى، يسير بين يدي القوم، ويقول: ليس القوم بأحقَّ بالطريق منكم. وفرعون على فرسٍ أدهم حصانٍ، وجبريل على فرسٍ أنثى، فأتبعها فرس فرعون، وكان ميكائيل في آخر القوم يقول: الحقوا، الحقوا أصحابكم. حتى دخل آخرُهم، وأراد أولُهم أن يخرج، فأطبق عليهم البحر{17}. (١١/٢٥٠) ٥٥٨٨٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>: يعني: بني إسرائيل{18}. (ز) ٥٥٨٨١- تفسير إسماعيل السُّدِّيّ: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>، يعني: هم قليل في كثير، وكان أصحاب موسى ستمائة ألف، وفرعون وأصحابه ستة آلاف ألف{16}. (ز) ٥٥٨٨٢- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: قوله: <q>﴿وأوحينا إلى موسى أن أسر بعبادي إنكم متبعون﴾</q> [الشعراء:٥٢]، قال: أوحى اللهُ إلى موسى: أنِ اجمع بني إسرائيل، كل أربعة أبيات في بيت، ثم اذبحوا أولاد الضأن، فاضربوا بدمائها على الأبواب، فإنِّي سآمُر الملائكةَ أن لا تدخل بيتًا على بابه دم، وسآمرهم بقتل أبكار آل فرعون مِن أنفسهم وأموالهم، ثم اخبزوا خبزًا فطيرًا؛ فإنّه أسرع لكم، ثم أسرِ بعبادي حتى تنتهي للبحر فيأتيك أمري. ففعل، فلمّا أصبحوا قال فرعون: هذا عمل موسى وقومه، قتلوا أبكارَنا مِن أنفسنا وأموالنا. فأرسل في إثرهم ألف ألف وخمسمائة ألف وخمسمائة ملك مسور، مع كل ملك ألف رجل، وخرج فرعون في الكَرِش{20} العظمى، وقال: <q>﴿إن هؤلاء لشرذمة قليلون﴾</q>. قال: قطعة، وكانوا ستمائة ألف، مائتا ألف منهم أبناء عشرين سنة إلى أربعين{21}. (١١/٢٤٩) ٥٥٨٨٣- عن عبد الملك ابن جُرَيج -من طريق حجاج- قال: كانوا ثلاثين ملَِكًا ساقة خلف فرعون، يحسبون أنهم معهم، وجبرائيل أمامهم، يردُّ أوائل الخيل على أواخرها، فأتبعهم حتى انتهى إلى البحر{7}. (ز) ٥٥٨٨٤- قال مقاتل بن سليمان: ثم قال فرعون: <q>﴿إن هؤلاء﴾</q> يعني: بني إسرائيل <q>﴿لشرذمة﴾</q> يعني: عصابة٤٧٩٤ <q>﴿قليلون﴾</q> وهم ستمائة ألف{23}. (ز) ٤٧٩٤ قال ابنُ جرير (١٧/٥٧٢-٥٧٣ بتصرف): «يعني بالشرذمة: الطائفة، والعصبة الباقية، من عصَب جبيرةً، وشرذمة كلِّ شيء: بقيّته القليلة. وقيل: <q>﴿قليلون﴾</q> لأن كل جماعة منهم كان يلزمها معنى القلة؛ فلما جمَعَ جمْعَ جماعاتهم قيل: قليلون». وقال ابنُ عطية (٦/٤٨٣): «الشرذمة: الجمع القليل المحتقر. وشرذمة كل شيء: بقيّته الخسيسة». ٥٥٨٨٥- قال يحيى بن سلّام: وبلغني: أنّ جميع جنوده كانوا أربعين ألف ألف{24}. (ز) ",footnotes:1:أخرجه عبد بن حميد كما في المنتخب من مسنده ص٢٠٧ (٦٠٥)، وابن الجوزي في المنتظم ١/٣٤٩. قال الشوكاني في فتح القدير ٤/١٢ بعد ذكره لروايات ومنها هذا الحديث: «هذه الروايات المضطربة قد رُوِي عن كثير من السلف ما يماثلها في الاضطراب والاختلاف، ولا يصح منها شيء عن النبي ﷺ».أخرجه ابن مردويه -كما في عمدة القاري للعيني ١٨/٢٨٦-. قال السيوطي: «بسند واهٍ». وقال الشوكاني في فتح القدير ٤/١٢ بعد ذكره لروايات ومنها هذه الحديث: «هذه الروايات المضطربة قد روي عن كثير من السلف ما يماثلها في الاضطراب والاختلاف، ولا يصح منها شيء عن النبي ﷺ».ذكره الحافظ في المطالب العالية (إشراف: د. سعد الشثري) ١٥/٨٠ (٣٦٧٥).أخرجه ابن جرير ١٧/٥٧٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١٣/٥٤٢، وابن جرير ١٧/٥٧٣.أخرجه ابن أبي حاتم ٨/٢٧٧١.أخرجه ابن جرير ١٧/٥٧٦.أخرجه ابن جرير ١/٦٥٨، وإسحاق البستي في تفسيره ص٥٣٢، وابن أبي حاتم ٨/٢٧٧١.أخرجه ابن أبي حاتم ٨/٢٧٦٩-٢٧٧٠.أخرجه ابن أبي حاتم ١/١٠٦-١٠٧، ٨/٢٧٧١. وفي تفسير الثعلبي ٧/١٦٤: عن عمرو بن ميمون قال: كان أصحاب موسى ستمائة ألف.أخرجه ابن جرير ١٧/٥٧٣، وابن أبي حاتم ٨/٢٧٦٩.أخرجه إسحاق البستي في تفسيره ص٥٣٢. وعزاه السيوطي إلى ابن أبي حاتم. ينظر: فتح الباري ٨/٤٩٧.أخرجه الفريابي -كما في التغليق ٤/٢٧٣-، وابن جرير ١٧/٥٧٥، وإسحاق البستي في تفسيره ص٥٣٢ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٥٠٤، ونقل عقِبَه عن الحسن البصري قوله: سوى الحشم.علَّقه يحيى بن سلام ٢/٥٠٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٥٧٤-٥٧٥.علَّقه يحيى بن سلام ٢/٥٠٤.الكرش: الجماعة من الناس، والبطانة والمدد، وكرش الرجل كَرَشًا: إذا صار له جيش. التاج (كرش).أخرجه ابن جرير ١٧/٥٧٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٥٧٦.تفسير مقاتل بن سليمان ٣/٢٦٥.تفسير يحيى بن سلام ٢/٥٠٤.
26,55," <q>﴿وَإِنَّهُمۡ لَنَا لَغَاۤىِٕظُونَ ۝٥٥﴾</q> - تفسير ٥٥٨٨٦- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿وإنهم لنا لغائظون﴾</q>، يقول: بقتلهم أبكارنا من أنفسنا وأموالنا{1}. (ز) ٥٥٨٨٧- قال مقاتل بن سليمان: ثم قال فرعون: <q>﴿وإنهم لنا لغائظون﴾</q> لقتلهم أبكارنا، ثم هربوا مِنّا{2}٤٧٩٥. (ز) ٤٧٩٥ قال ابنُ جرير (١٧/٥٧٦): «ذُكِرَ: أن غيظهم إيّاهم كان قَتْل الملائكة مَن قتَلَت مِن أبكارهم... وقد يحتمل أن يكون معناه: وإنهم لنا لغائظون بذهابهم منهم بالعواريّ التي كانوا استعاروها منهم مِن الحليّ. ويحتمل أن يكون ذلك بفراقهم إياهم، وخروجهم من أرضهم بِكُرْهٍ لهم لذلك». ",footnotes:1:أخرجه ابن جرير ١٧/٥٧٦.تفسير مقاتل بن سليمان ٣/٢٦٥.
26,56," <q>﴿وَإِنَّا لَجَمِیعٌ حَـٰذِرُونَ ۝٥٦﴾</q> - قراءات ٥٥٨٨٨- عن عمرو بن دينار، قال: قرأ عبيد: <q>﴿وإنّا لَجَمِيعٌ حاذِرُونَ﴾</q>{1}. (١١/٢٥٣) ٥٥٨٨٩- عن الأسود بن يزيد النخعي -من طريق أبي إسحاق- أنّه كان يقرؤها: <q>﴿وإنّا لَجَمِيعٌ حاذِرُونَ﴾</q>{2}. (١١/٢٥٢) ٥٥٨٩٠- عن يونس بن إسحاق{3}، عن أبيه، قال: سمعت الأسود بن يزيد النخعي يقرأ هذا الحرف: ‹وإنّا لَجَمِيعٌ حَذِرُونَ›{4}٤٧٩٦. (ز) ٤٧٩٦ اختلف القراء في قراءة قوله تعالى:<q>﴿حاذرون﴾</q>؛ فقرأها بعضهم بإثبات الألف، بمعنى: أنهم مُعدُّون مُؤْدُون، ذوو أداة وقوّة وسلاح. وقرأها البعض بغير الألف، هكذا (حَذِرُون)، جمع حَذِر، وهو المطبوع على الحَذَرِ. وبَيَّنَ ابنُ جرير (١٧/٥٧٧) أنّ كِلتا القراءتين صواب؛ لاستفاضتهما لدى القراء، فقال: «الصواب مِن القول في ذلك أنهما قراءتان مستفيضتان في قرّاء الأمصار، متقاربتا المعنى، فبأيتهما قرأ القارئ فمصيب الصواب فيه». ٥٥٨٩١- عن إبراهيم النخعي أنه كان يقرؤها: <q>﴿وإنّا لَجَمِيعٌ حاذِرُونَ﴾</q>{5}. (١١/٢٥٣) <q>﴿وَإِنَّا لَجَمِیعٌ حَـٰذِرُونَ ۝٥٦﴾</q> - تفسير الآية ٥٥٨٩٢- عن عبد الله بن مسعود، <q>﴿وإنا لجميع حاذرون﴾</q>، قال: مُؤْدُون مُقْوُون في السِّلاح والكُراع{5}. (١١/٢٥٣) ٥٥٨٩٣- عن عبد الله بن عباس -من طريق أبي رزين- أنه قرأ: <q>﴿وإنا لجميع حاذرون﴾</q>، قال: مُؤْدُون مُقْوُون{7}. (١١/٢٥٢) ٥٥٨٩٤- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وإنا لجميع حاذرون﴾</q>، ما الحاذرون؟ قال: التّامُّون السلاح، قال فيه النجاشي: لعمر أبي أُثالٍ حيث أمسى لقد نادت به أبناء بكر حنيفة في كتائب حاذرات يقودهم أبو شبل هزبر{8}. (١١/٢٥٣) ٥٥٨٩٥- عن الأسود بن يزيد النخعي -من طريق أبي إسحاق- أنّه كان يقرأها: <q>﴿وإنا لجميع حاذرون﴾</q>، قال: مُؤْدُون مُقْوُون{9}. (١١/٢٥٢) ٥٥٨٩٦- عن الأسود بن يزيد النخعي أنّه كان يقرأ: <q>﴿وإنا لجميع حاذرون﴾</q>، يقول: وادُّون مستعدون{5}. (١١/٢٥٢) ٥٥٨٩٧- عن سعيد بن جبير أنه كان يقرأ: <q>﴿وإنا لجميع حاذرون﴾</q>، يقول: مؤدُون في السلاح{11}. (١١/٢٥٣) ٥٥٨٩٨- عن الضَّحّاك بن مُزاحِم، <q>﴿وإنا لجميع حاذرون﴾</q>: يعني: شاكِين في السلاح{12}. (١١/٢٥٣) ٥٥٨٩٩- عن الضَّحّاك بن مُزاحِم -من طريق أبي العرجاء- أنه كان يقرأ: <q>﴿وإنا لجميع حاذرون﴾</q>، يقول: مؤدون{13}. (ز) ٥٥٩٠٠- عن محمد بن قيس -من طريق أبي معشر- قال: كان مع فرعون ستمائة ألف حصان أدهم، سوى ألوان الخيل{13}. (ز) ٥٥٩٠١- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وإنا لجميع حاذرون﴾</q>، يقول: حَذِرْنا. قال: جمعنا أمرنا{13}. (ز) ٥٥٩٠٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿وإنا لجميع حاذرون﴾</q>، قال: مُؤْدُون مُعِدُّون في السلاح والكراع{13}. (ز) ٥٥٩٠٣- قال مقاتل بن سليمان: ثم قال فرعون: <q>﴿وإنا لجميع حاذرون﴾</q> علينا السلاح{17}. (ز) ٥٥٩٠٤- قال يحيى بن سلّام: <q>﴿وإنا لجميع حاذرون﴾</q> مُتَسَلِّحون ... وسمعت بعضَهم يقول: <q>﴿حاذرون﴾</q> في القوة والسلاح{18}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وابن ذكوان، وقرأ بقية العشرة: ‹حَذِرُونَ› بإسقاط الألف. انظر: النشر ٢/٣٣٥، والإتحاف ص٤٢١.أخرجه ابن جرير ١٧/٥٧٧، وإسحاق البستي في تفسيره ص٥٣٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.كذا في المطبوع، والصحيح: يونس بن أبي إسحاق، كما في الأثر الذي قبله.أخرجه يحيى بن سلام ٢/٥٠٤. كذا ضبطت محققته القراءة ‹حَذِرُونَ›بإسقاط الألف، وضبطت الرواية السابقة بإثبات الألف <q>﴿حاذرون﴾</q>.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٥٧٨. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن الأنباري في الوقف.أخرجه ابن جرير ١٧/٥٧٧، وإسحاق البستي في تفسيره ص٥٣٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه يحيى بن سلام ٢/٥٠٤ بلفظ: مقوون.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٥٧٨.أخرجه ابن جرير ١٧/٥٧٨.أخرجه ابن جرير ١٧/٥٧٨.أخرجه ابن جرير ١٧/٥٧٨.تفسير مقاتل بن سليمان ٣/٢٦٥.تفسير يحيى بن سلام ٢/٥٠٤.
26,57," <q>﴿فَأَخۡرَجۡنَـٰهُم مِّن جَنَّـٰتࣲ وَعُیُونࣲ ۝٥٧﴾</q> - تفسير ٥٥٩٠٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فأخرجناهم من جنات وعيون وكنوز ومقام كريم﴾</q>، قال: كانوا في ذلك في الدنيا، فأخرجهم الله مِن ذلك، وأورثها بني إسرائيل{1}. (١١/٢٥٤) ٥٥٩٠٦- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿فأخرجناهم﴾</q> مِن مصر، <q>﴿من جنات﴾</q> يعني: البساتين، <q>﴿وعيون﴾</q> يعني: أنهار جارية{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٢٦٥.
26,58," <q>﴿وَكُنُوزࣲ﴾</q> - تفسير ٥٥٩٠٧- قال مجاهد بن جبر: سمّاها: كنوزًا؛ لأنّه لم يُعْطِ حقَّ الله منها، وما لم يُعْطَ حقُّ الله منه فهو كنز، وإن كان ظاهرًا{1}. (ز) ٥٥٩٠٨- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿وكنوز﴾</q>، يعني: الأموال الظاهرة مِن الذهب والفضة، وإنما سُمِّي: كنزًا؛ لأنه لم يعط حق الله ﷿ منه، وكل ما لم يعط حق الله تعالى منه فهو كنز، وإن كان ظاهرًا{2}. (ز) ٥٥٩٠٩- قال يحيى بن سلّام: <q>﴿وكنوز﴾</q>، أي: وأموال{3}. (ز) <q>﴿وَمَقَامࣲ كَرِیمࣲ ۝٥٨﴾</q> - تفسير ٥٥٩١٠- عن عبد الله بن عباس، في قوله: <q>﴿ومقام كريم﴾</q>، قال: المنابِر{4}. (١١/٢٥٤) ٥٥٩١١- وعن سعيد بن جبير= (ز) ٥٥٩١٢- ومجاهد بن جبر، مثل ذلك{5}. (ز) ٥٥٩١٣- قال قتادة بن دعامة: <q>﴿ومقام كريم﴾</q>، أي: في الدنيا{6}. (ز) ٥٥٩١٤- قال إسماعيل السُّدِّيّ: <q>﴿ومقام كريم﴾</q>، يعني: مَسْكنًا حَسَنًا{6}. (ز) ٥٥٩١٥- عن عُقَيْل -من طريق ابن لهيعة- قال: سمعت: أنّ المقام الكريم: الفَيُّوم{8}. (ز) ٥٥٩١٦- قال مقاتل بن سليمان: قال سبحانه: <q>﴿ومقام كريم﴾</q>، يعني: المساكن الحسان{2}. (ز) ٥٥٩١٧- قال يحيى بن سلّام: <q>﴿ومقام كريم﴾</q>، أي: منزل حسن{10}. (ز) ",footnotes:1:تفسير الثعلبي ٧/١٦٥، وتفسير البغوي ٦/١١٤.تفسير مقاتل بن سليمان ٣/٢٦٥.تفسير يحيى بن سلام ٢/٥٠٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٦/١١٤.علَّقه يحيى بن سلام ٢/٥٠٥.علَّقه يحيى بن سلام ٢/٥٠٥.أخرجه ابن وهب في الجامع ٢/١٥٢ (٣١٠).تفسير مقاتل بن سليمان ٣/٢٦٥.تفسير يحيى بن سلام ٢/٥٠٥، وأخرجه أبو عمرو الداني في المكتفى ص١٥٠ (٢١) من طريق أحمد.
26,59," <q>﴿كَذَ ٰ⁠لِكَۖ وَأَوۡرَثۡنَـٰهَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٥٩﴾</q> - تفسير ٥٥٩١٨- قال يحيى بن سلّام: قال: <q>﴿كذلك﴾</q>، أي: كذلك كان الخبر. في تفسير الحسن [البصري]. وقال بعضهم: <q>﴿كذلك﴾</q> أي: هكذا، ثم انقطع الكلام، ثم قال: <q>﴿وأورثناها بني إسرائيل﴾</q> رجعوا إلى مصر بعدما أهلك الله فرعون وقومه، في تفسير الحسن{1}. (ز) ٥٥٩١٩- قال مقاتل بن سليمان: <q>﴿كذلك﴾</q> هكذا فعلنا بهم في الخروج من مصر، وما كانوا فيه من الخير، <q>﴿وأورثناها بني إسرائيل﴾</q> وذلك أنّ الله ﷿ ردَّ بني إسرائيل بعدما أغرق فرعون وقومه إلى مصر{2}٤٧٩٧. (ز) ٤٧٩٧ قال ابنُ عطية (٦/٥٨٤): «توريث بني إسرائيل يحتمل مقصدين: أحدهما: أنه تعالى ورَّثَهم هذه الضفة من أرض الشام. والآخر: أنه ورَّثَهم مصر، ولكن بعد مدة طويلة من الدهر. قاله الحسن. على أن التواريخ لم تتضمن ملك بني إسرائيل في مصر». ٥٥٩٢٠- عن يحيى بن سلّام -من طريق أحمد- <q>﴿كذلك﴾</q>: أي: [هكذا] كان الخبر{3}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ٢/٥٠٥.تفسير مقاتل بن سليمان ٣/٢٦٥.أخرجه أبو عمرو الداني في المكتفى ص١٥٠ (٢١). وينظر أثر ابن سلاّم السابق.
26,60," <q>﴿فَأَتۡبَعُوهُم مُّشۡرِقِینَ ۝٦٠﴾</q> - قراءات ٥٥٩٢١- عن الأعمش: في قراءة عبد الله [بن مسعود]: (واتَّبَعُوهُم مُّشْرِقِينَ){1}. (ز) ٥٥٩٢٢- عن عاصم بن أبي النجود أنه قرأ: <q>﴿فَأَتْبَعُوهُم مُّشْرِقِينَ﴾</q> مهموزة، مقطوعة الألف{2}. (١١/٢٥٤) <q>﴿فَأَتۡبَعُوهُم مُّشۡرِقِینَ ۝٦٠﴾</q> - تفسير الآية ٥٥٩٢٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فأتبعوهم مشرقين﴾</q>، قال: خرج موسى ليلًا، فكسف القمر ليلًا، وأظلمت الأرض، فقال أصحابُه: إنّ يوسف كان أخبرنا أنا سَنُنَجّى مِن فرعون، وأخذ علينا العهد لنخرجنَّ بعظامه معنا. فخرج موسى مِن ليلته يسأل عن قبره، فوجد عجوزًا بيتها على قبره، فأخرجته له بحُكْمِها، فكان حكمُها أن قالت له: احملني، فأخرِجني معك. فجعل عظامَ يوسف في كسائه، ثم حمل العجوز على كسائه، فجعله على رقبته، وخيل فرعون في ملء أعنتها حُضرًا{3} في أعينهم ولا تبرح؛ حُبِسَت عن موسى وأصحابه حتى تَوارَوْا{4}. (١١/٢٥٥) ٥٥٩٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فأتبعوهم مشرقين﴾</q>، قال: أتبعهم فرعون وجنوده حين أشرقت الشمس{5}. (١١/٢٥٤) ٥٥٩٢٥- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: لقد ذُكِر لي: أنّ فرعون خرج في طلب موسى على ستمائة ألف مِن الخيل دُهم، كلها وُرْق{6} حصان، سوى ما كان في جنده من سائر الخيل. قال: فخرجوا في طلب موسى كما قال الله: <q>﴿فأتبعوهم مشرقين﴾</q> عند طلوع الشمس{7}. (ز) ٥٥٩٢٦- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿فأتبعوهم﴾</q> يقول: فاتبعهم فرعون وقومه <q>﴿مشرقين﴾</q> يعني: ضُحًى{8}. (ز) ٥٥٩٢٧- قال يحيى بن سلّام: رجع إلى أول القصة <q>﴿فأخرجناهم من جنات وعيون﴾</q> حيث اتبعوا بني إسرائيل صبيحة الليلة التي سروا فيها حين أشرقت الشمس{9}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٦. وهي قراءة شاذة.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.حُضْرًا: تعدو عَدْوًا. لسان العرب (حضر).أخرجه يحيى بن سلام ٢/٥٠٣ من طريق ابن مجاهد مختصرًا، وابن جرير ١٧/٥٧٩، ومن طريق ابن جريج أيضًا مختصرًا، وابن أبي حاتم ٨/٢٧٦٨-٢٧٦٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٧٠. وعلَّقه يحيى بن سلام ٢/٥٠٥. وعزاه السيوطي إلى عبد بن حميد.وُرْق: سَوادٌ في غُبْرة. وقيل: سَواد وبَياض. اللسان (ورق).أخرجه ابن عساكر في تاريخ دمشق ٦١/٧٦.تفسير مقاتل بن سليمان ٣/٢٦٦.تفسير يحيى بن سلام ٢/٥٠٥.
