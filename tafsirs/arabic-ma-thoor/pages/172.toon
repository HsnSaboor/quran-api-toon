tafsir[7]{c,v,t}:
7,164," <q>﴿وَإِذۡ قَالَتۡ أُمَّةࣱ مِّنۡهُمۡ لِمَ تَعِظُونَ قَوۡمًا ٱللَّهُ مُهۡلِكُهُمۡ أَوۡ مُعَذِّبُهُمۡ عَذَابࣰا شَدِیدࣰاۖ﴾</q> - تفسير ٢٩٢٨٥- عن عبد الله بن عباس -من طريق معمر، عن قتادة- <q>﴿لم تعظون قوما الله مهلكهم﴾</q>، قال: هم ثلاثُ فِرَق: الفِرْقَةُ التي وعَظَتْ، والموعوظة التي وُعِظَت، واللهُ أعلم ما فعلت الفرقة الثالثة، وهم الذين قالوا: <q>﴿لم تعظون قوما الله مهلكهم﴾</q>؟!.= (ز) ٢٩٢٨٦- وقال محمد بن السائب الكلبي-من طريق معمر-: هما فرقتان: الفرقة التي وعَظَتْ، والفرقة التي قالت: <q>﴿لم تعظون قوما الله مهلكهم﴾</q>. قال: هي الموعوظة{1}٢٦٦٥. (ز) ٢٦٦٥ رجَّح ابنُ عطية (٤/٧٢) مستندًا إلى لفظ الآية أنّ بني إسرائيل افترقت ثلاث فرق، مُبَيِّنًا أنّ ما يؤيِّد ذلك «الضمائر في قوله: <q>﴿إلى رَبِّكُمْ ولَعَلَّهُمْ﴾</q>، فهذه المخاطبة تقتضي مخاطِبًا ومخاطَبًا ومَكْنِيًّا عنه». ٢٩٢٨٧- قال مقاتل بن سليمان: <q>﴿وإذْ قالَتْ أُمَّةٌ مِنهُمْ﴾</q> يعني: عصابة منهم، وهي الظَّلَمة للواعِظة: <q>﴿لِمَ تَعِظُونَ قَوْمًا اللَّهُ مُهْلِكُهُمْ أوْ مُعَذِّبُهُمْ عَذابًا شَدِيدًا﴾</q>. وذلك أنّ الواعظة نَهَوْهُم عن الحيتان، وخوَّفوهم، فلم ينتبهوا، فرَدَّت عليهم الواعظة، <q>﴿قالُوا مَعْذِرَةً إلى رَبِّكُمْ ولَعَلَّهُمْ يَتَّقُونَ﴾</q>{2}. (ز) <q>﴿قَالُوا۟ مَعۡذِرَةً إِلَىٰ رَبِّكُمۡ وَلَعَلَّهُمۡ یَتَّقُونَ ۝١٦٤﴾</q> - تفسير ٢٩٢٨٨- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿قالُوا مَعْذِرَةً إلى رَبِّكُمْ﴾</q> لسُخْطنا أعمالهم، <q>﴿ولَعَلَّهُمْ يَتَّقُونَ﴾</q> أي: ينزِعون عمّا هم عليه{3}. (ز) ٢٩٢٨٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولعلهم يتقون﴾</q>، قال: يتركون هذا العملَ الذي هم عليه{4}. (ز) ٢٩٢٩٠- قال مقاتل بن سليمان: <q>﴿قالُوا مَعْذِرَةً إلى رَبِّكُمْ ولَعَلَّهُمْ﴾</q> يعني: ولكي ينتهوا فيُؤَخَّروا، أو يُعَذَّبوا فينجوا، <q>﴿ولَعَلَّهُمْ﴾</q> يعني: ولكي <q>﴿يَتَّقُونَ﴾</q> المعاصيَ{2}. (ز) <q>﴿قَالُوا۟ مَعۡذِرَةً إِلَىٰ رَبِّكُمۡ وَلَعَلَّهُمۡ یَتَّقُونَ ۝١٦٤﴾</q> - آثار متعلقة بالآية ٢٩٢٩١- عن سفيان، قال: قالوا لعبد الله بن عبد العزيز العُمَريِّ العابِدِ في الأمر بالمعروفِ والنهيِ عن المنكر: تَأمُرُ مَن لا يَقبلُ منك؟! قال: يكونُ معذِرةً. وقرأ: <q>﴿قالُوا مَعذِرَةً إلى رَبِكُم﴾</q>{6}. (٦/٦٤٠) ",footnotes:1:أخرجه ابن جرير ١٠/٥٢١.تفسير مقاتل بن سليمان ٢/٧٠.أخرجه ابن جرير ١٠/٥١١.أخرجه ابن جرير ١٠/٥١١، وابن أبي حاتم ٥/١٦٠١ من طريق أصبغ بن الفرج.تفسير مقاتل بن سليمان ٢/٧٠.عزاه السيوطي إلى أبي الشيخ.
7,165," <q>﴿فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦۤ أَنجَیۡنَا ٱلَّذِینَ یَنۡهَوۡنَ عَنِ ٱلسُّوۤءِ وَأَخَذۡنَا ٱلَّذِینَ ظَلَمُوا۟ بِعَذَابِۭ بَـِٔیسِۭ بِمَا كَانُوا۟ یَفۡسُقُونَ ۝١٦٥﴾</q> - قراءات ٢٩٢٩٢- عن أبي بكر بن عيّاشٍ، قال: كان حِفْظي عن عاصم: ‹بِعَذابٍ بَيْئَسٍ› على معنى: فَيْعَل، ثم دخَلني منها شكٌّ، فترَكْتُ روايتَها عن عاصم= (ز) ٢٩٢٩٣- وأخَذْتُها عن الأعمشِ: <q>﴿بِعَذابِ بَئِيسٍ﴾</q>، على معنى: فَعِيل{1}. (٦/٦٣٩) <q>﴿فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦۤ أَنجَیۡنَا ٱلَّذِینَ یَنۡهَوۡنَ عَنِ ٱلسُّوۤءِ﴾</q> - تفسير ٢٩٢٩٤- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿فَلَمّا نَسُوا ما ذُكِّرُوا بِهِ﴾</q>، يعني: تَرَكوا ما ذُكِّروا به{2}. (ز) ٢٩٢٩٥- عن عبد الله بن عباس -من طريق عكرمة- قال: نجا النّاهون، وهلَك الفاعِلُون، ولا أدْرِي ما صُنِعَ بالسّاكتِين{3}. (٦/٦٣٧) ٢٩٢٩٦- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿أنْجَيْنا الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ﴾</q>، قال: يا ليت شعري، ما السوء الذي نَهَوْا عنه{4}. (ز) ٢٩٢٩٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: واللهِ، لَأن أكونَ علِمتُ أنّ القومَ الذين قالوا: لِمَ تعظُون قومًا نَجَوْا مع الذين نَهَوا عن السُّوءِ؛ أحبُّ إلَيَّ ممّا عُدِلَ به -وفي لفظٍ: من حُمْرِ النَّعَمِ-، ولكنِّي أخافُ أن تكونَ العقوبةُ نزَلتْ بهم جميعًا{5}. (٦/٦٣٨) ٢٩٢٩٨- قال قتادة: وبلغنا: أنّه دُخل على عبد الله بن عباس، وبين يديه المصحف، وهو يبكي وقد أتى على هذه الآية: <q>﴿فلما نسوا ما ذكروا به﴾</q>، فقال: قد علمتُ أنّ الله أهلك الذين أخذوا الحيتان، ونجّى الذين نهوهم، ولا أدري ما صنع بالذين لم ينهوا ولم يواقعوا المعصية{6}. (ز) ٢٩٢٩٩- عن عبد الله بن عباس -من طريق عطاء- <q>﴿وإذْ قالَتْ أُمَّةٌ مِنهُمْ لِمَ تَعِظُونَ قَوْمًا اللَّهُ مُهْلِكُهُمْ﴾</q>، قال: أسمعُ اللهَ يقول: <q>﴿أنْجَيْنا الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ وأَخَذْنا الَّذِينَ ظَلَمُوا بِعَذابٍ بَئِيسٍ﴾</q>. فليت شعري، ما فُعِل بهؤلاء الذين قالوا: <q>﴿لِمَ تَعِظُونَ قَوْمًا اللَّهُ مُهْلِكُهُمْ﴾</q>؟{7}. (ز) ٢٩٣٠٠- عن عكرمة، قال: قال عبد الله بن عباس: ما أدْري أنَجا الذين قالوا: <q>﴿لِمَ تَعِظُونَ قَومًا﴾</q> أم لا؟ قال: فما زلتُ أُبَصِّرُه حتى عرَف أنهم قد نجَوا، فكساني حُلَّةً{8}. (٦/٦٣٨) ٢٩٣٠١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة-: فلمّا وقع عليهم غضبٌ الله نَجَتِ الطائفتان اللتان قالوا: <q>﴿لم تعظون قوما الله مهلكهم﴾</q>. والذين قالوا: <q>﴿معذرة إلى ربكم﴾</q>. وأهلك الله أهلَ معصيته الذين أخذوا الحيتان، فجعلهم قردةً وخنازير{9}. (ز) ٢٩٣٠٢- قال الحسن البصري: وأيُّ نهيٍ يكونُ أشَدَّ مِن أنّهم أثبتوا لهم الوعيد، وخوَّفوهم العذاب، فقالوا: <q>﴿لم تعظون قوما الله مهلكهم أو معذبهم عذابا شديدا﴾</q>{6}. (ز) ٢٩٣٠٣- قال الحسن البصري: نَجَتِ الطائفتان؛ الذين قالوا: <q>﴿لم تعظون قوما﴾</q>. والذين قالوا: <q>﴿معذرة إلى ربكم﴾</q>. وأهلك الله الذين أخذوا الحيتان{11}. (ز) ٢٩٣٠٤- عن ليث بن أبي سليم، قال: مُسِخُوا حِجارةً؛ الذين قالوا: <q>﴿لِمَ تَعِظُونَ قَومًا الله مُهْلِكُهُم﴾</q>{12}. (٦/٦٣٨) ٢٩٣٠٥- عن عبد الملك ابن جُرَيْج -من طريق عبد الرازق- في قوله: <q>﴿فلما نسوا ما ذكروا به أنجينا الذين ينهون عن السوء﴾</q>، قال: فلمّا نَسُوا موعظةَ المؤمنين إيّاهم؛ الذين قالوا: <q>﴿لم تعظون قوما﴾</q>{13}. (ز) ٢٩٣٠٦- قال مقاتل بن سليمان: <q>﴿فَلَمّا نَسُوا ما ذُكِّرُوا بِهِ﴾</q> يعني: فلما تَرَكُوا ما وُعِظُوا به مِن أمر الحيتان؛ <q>﴿أنْجَيْنا﴾</q> من العذاب <q>﴿الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ﴾</q> يعني: المعاصي{14}. (ز) ٢٩٣٠٧- قال عبد الرحمن بن زيد بن أسلم: نَجَتِ الناهيةُ، وهلكتِ الفرقتان، وهذه أشدُّ آيةٍ في ترك النهي عن المنكر{11}٢٦٦٦. (ز) ٢٦٦٦ ذكر ابنُ عطية (٤/٧٢) أنّ <q>﴿ما﴾</q> في قوله: <q>﴿ما ذُكِّرُوا بِهِ﴾</q> بمعنى: الذي، وبين أنه يحتمل أن يراد به: الذكر نفسه، ويحتمل أن يراد به: ما كان فيه الذكر. <q>﴿وَأَخَذۡنَا ٱلَّذِینَ ظَلَمُوا۟ بِعَذَابِۭ بَـِٔیسِۭ بِمَا كَانُوا۟ یَفۡسُقُونَ ۝١٦٥﴾</q> - تفسير ٢٩٣٠٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وأَخَذْنا الَّذِينَ ظَلَمُوا بِعَذابٍ بَئِيسٍ﴾</q>، قال: فأصبح الذين نَهَوا عن السوء ذات غَداةٍ في مجالسهم يَتَفَقَّدون الناس، لا يروا منهم، وقد باتوا من ليلتهم وغلقوا عليهم دورهم. قال فجعلوا يقولون: إنّ لِلناس لَشأنًا! فانظروا ما شأنهم. قال: فاطَّلعوا في دورهم، فإذا القوم قد مُسِخوا في دورهم، يعرفون الرجل بعينه، وإنّه لَقِرد، والمرأةَ بعينها، وإنّها لقردة. قال الله تعالى: <q>﴿فَجَعَلْناها نَكالًا لِما بَيْنَ يَدَيْها وما خَلْفَها ومَوْعِظَةً لِلْمُتَّقِينَ﴾</q> [البقرة:٦٦]{16}. (ز) ٢٩٣٠٩- عن عبد الله بن عباس، في قوله: <q>﴿بِعَذابِ بَئِيِس﴾</q>، قال: لا رحمةَ فيه{17}. (٦/٦٣٩) ٢٩٣١٠- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿بِعَذابِ بَئِيِس﴾</q>، قال: أليمٍ وجيعٍ{18}. (٦/٦٣٩) ٢٩٣١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بِعَذابِ بَئِيِس﴾</q>، قال: أليمٍ شديدٍ{19}. (٦/٦٤٠) ٢٩٣١٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿بِعَذابِ بَئِيِس﴾</q>، قال: وجيعٍ{20}. (٦/٦٣٩) ٢٩٣١٣- قال مقاتل بن سليمان: <q>﴿وأَخَذْنا الَّذِينَ ظَلَمُوا﴾</q> يعني: وأصبنا الذين ظلموا <q>﴿بِعَذابٍ﴾</q> يعني: المسخ <q>﴿بَئِيسٍ﴾</q> يعني: شديد؛ <q>﴿بِما كانُوا يَفْسُقُونَ﴾</q> يعني: يعصون{14}. (ز) ٢٩٣١٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿بعذاب بئيس﴾</q>، قال: بعذاب شديد{22}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. ‹بِعَذابٍ بَيْئَسٍ› على وزن «فَيْعَل» قراءة متواترة، قرأ بها أبو بكر عن عاصم بخلف عنه، وقرأ نافع، وأبو جفعر: ‹بِيسٍ› بياء مكسورة، بعدها ياء ساكنة، وقرأ ابن عامر كذلك إلا أنه همز الياء: ‹بِئْسٍ›، وقرأ بقية العشرة بخلف عن أبي بكر عن عاصم: <q>﴿بِعَذابِ بَئِيسٍ﴾</q> على وزن: فَعِيل. انظر: النشر ٢/٢٧٣، والإتحاف ص٢٩١-٢٩٢.أخرجه ابن أبي حاتم ٥/١٦٠١.أخرجه ابن جرير ١٠/٥٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٥٢٥.عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٤٩-.أخرجه ابن جرير ١٠/٥٢١.أخرجه ابن جرير ١٠/٥١٤، ٥١٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٥/١٦٠٢.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٤٩-.تفسير البغوي ٣/٢٩٤.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/٢٤٠، وابن جرير ١٠/٥٢٥، وابن أبي حاتم ٥/١٦٠١.تفسير مقاتل بن سليمان ٢/٧٠-٧١.تفسير البغوي ٣/٢٩٤.أخرجه ابن جرير ١٠/٥٢٠، وابن أبي حاتم ٥/١٦٠٢. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٢٤٢، وابن جرير ١٠/٥٢٨، وابن أبي حاتم ٥/١٦٠٢.تفسير مجاهد ص٣٤٥، وأخرجه ابن جرير ١٠/٥٢٨، وابن أبي حاتم ٥/١٦٠٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/٢٣٩، وابن جرير ١٠/٥٢٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٧٠-٧١.أخرجه ابن جرير ١٠/٥٢٨.
7,166," <q>﴿فَلَمَّا عَتَوۡا۟ عَن مَّا نُهُوا۟ عَنۡهُ﴾</q> - تفسير ٢٩٣١٥- قال عبد الله بن عباس، في قوله تعالى: <q>﴿فلما عتوا عن ما نهوا عنه﴾</q>: أبَوْا أن يرجعوا عن المعصية{1}. (ز) ٢٩٣١٦- عن عكرمة مولى ابن عباس -من طريق يزيد النحوي- قال: العُتُوُّ في كتاب الله: التَّجَبُّر{2}. (ز) ٢٩٣١٧- قال مقاتل بن سليمان: <q>﴿فَلَمّا عَتَوْا﴾</q> يعني: عَصَوْا <q>﴿عَنْ ما نُهُوا عَنْهُ﴾</q> من الحيتان{3}. (ز) <q>﴿قُلۡنَا لَهُمۡ كُونُوا۟ قِرَدَةً خَـٰسِـِٔینَ ۝١٦٦﴾</q> - تفسير ٢٩٣١٨- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿فلما عتوا عن ما، نهوا عنه قلنا لهم كونوا قردة خاسئين﴾</q>: فجعل الله منهم القردة والخنازير. فزعم: أنّ شباب القوم صاروا قِرَدَةً، وأن المشيخة صاروا خنازير{4}. (ز) ٢٩٣١٩- عن عبد الله بن عباس -من طريق مجاهد- قال: إنما كان الذين اعْتَدَوْا في السبت فَجُعِلُوا قِرَدة فَواقًا{5}، ثم هلَكوا، ما كان للمسخِ نسلٌ{6}. (١/٤٠٠) ٢٩٣٢٠- عن ماهانَ الحنفيِّ= (ز) ٢٩٣٢١- وسعيد بن جبير، قالا: لَمّا مُسِخُوا جَعَل الرجلُ يُشْبِهُ الرجلَ وهو قِرْدٌ، فيُقال: أنت فلانٌ؟ فيُومِئُ إلى يديَه؛ بما كسَبت يدايَ{7}. (٦/٦٤٠) ٢٩٣٢٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فلما عتوا عن ما نهوا عنه﴾</q> يقول: لَمّا مَرَد القومُ على المعصية <q>﴿قلنا لهم كونوا قردة خاسئين﴾</q> فصاروا قِرَدَةً لها أذناب تَعاوى، بعد ما كانوا رجالًا ونساءً{8}٢٦٦٧. (ز) ٢٦٦٧ ذكر ابنُ عطية (٤/٧٥) أنّ الزجّاج نقل عن قومٍ أنّهم قالوا: يجوز أن تكون هذه القردة من نسلهم. وعلَّق عليه بقوله: «وتعلق هؤلاء بقول النبي ﷺ: «إنّ أُمَّة من الأُمَم فُقِدَت، وما أراها إلا الفأر، إذا قُرِّب لها لبن لم تشرب». وبقوله ﷺ في الضب». ٢٩٣٢٣- عن عطاء الخراساني -من طريق ابنه عثمان- قال: نُودِيَ الذين اعتَدَوا في السَّبتِ ثلاثةَ أصواتٍ؛ نُودُوا: يا أهلَ القريةِ. فانتبَهت طائفةٌ، ثم نُودُوا: يا أهلَ القريةِ. فانتبَهتْ طائفةٌ أكثرُ من الأولى، ثم نُودوا: يا أهلَ القريةِ. فانتبَه الرجالُ والنساءُ والصِّبيانُ، فقال الله لهم: <q>﴿كُونُوا قِرَدَةً خاسِئِينَ﴾</q>. فجعَلَ الذين نَهَوْهم يدخُلون عليهم، فيقولون: يا فلانُ، ألم ننْهَكم؟ فيقولون برءوسِهم؛ أي: بَلى{9}. (٦/٦٤٠) ٢٩٣٢٤- قال مقاتل بن سليمان: <q>﴿قُلْنا لَهُمْ﴾</q> ليلًا: <q>﴿كُونُوا قِرَدَةً خاسِئِينَ﴾</q> يعني: صاغرين بعد ما أصابوا الحيتان سنين، ثم مُسِخوا قِرَدَةً، فعاشوا سبعة أيام، ثم ماتوا يوم الثامن{3}. (ز) <q>﴿قُلۡنَا لَهُمۡ كُونُوا۟ قِرَدَةً خَـٰسِـِٔینَ ۝١٦٦﴾</q> - آثار متعلقة بالآية ٢٩٣٢٥- عن أبي هريرة، أنّ رسول الله ﷺ قال: «لا ترتكِبوا ما ارْتَكَبَتِ اليهودُ؛ فتَسْتَحِلُّوا محارمَ الله بأدنى الحِيَلِ»{11}. (٦/٦٤٠) ",footnotes:1:تفسير البغوي ٣/٢٩٤.أخرجه ابن أبي حاتم ٥/١٦٠٢.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن جرير ١٠/٥٢٩.الفواق: قدر ما بين الحلبتين من الراحة. لسان العرب (فوق).أخرجه ابن أبي حاتم ١/١٣٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٠/٥٢٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٤٩-.أخرجه ابن أبي حاتم ٥/١٦٠٣.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن بطة في إبطال الحيل ص٤٦-٤٧. قال ابن تيمية في الفتاوى الكبرى ٤/٢٠: «بإسناد حسن ...». وقال أيضًا في الفتاوى الكبرى ٦/٣٣: «هذا إسناد جيد، يُصَحِّح مثلَه الترمذيُّ وغيره تارةً، ويُحَسِّنه تارةً». وقال ابن القيم في إغاثة اللهفان ١/٣٤٨: «وهذا إسناد جيد، يصحح مثله الترمذي». وقال ابن كثير في تفسيره ١/٢٩٣، ٣/٤٩٣: «وهذا إسناد جيد». وقال الألباني في الإرواء ٥/٣٧٥ (١٥٣٥): «وهذا إسناد رجاله كلهم ثقات معروفون من رجال التهذيب، غير أبى الحسن أحمد بن محمد بن مسلم».
7,167," <q>﴿وَإِذۡ تَأَذَّنَ رَبُّكَ﴾</q> - تفسير ٢٩٣٢٦- قال عبد الله بن عباس: <q>﴿تأذن ربك﴾</q>: قال ربُّك{1}. (ز) ٢٩٣٢٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإذ تأذن ربك﴾</q>، يقول: قال ربُّك{2}. (٦/٦٤١) ٢٩٣٢٨- عن سفيان الثوري، مثل ذلك{3}. (ز) ٢٩٣٢٩- عن مجاهد بن جبر -من طريق أبي سعد- <q>﴿وإذ تأذن ربك﴾</q>، قال: أمَرَ ربُّك{4}٢٦٦٨. (ز) ٢٦٦٨ ذكر ابنُ عطية (٤/٧٧) قول مجاهد، ثم ذكر قولًا مفاده أنّ معنى: <q>﴿تأذن﴾</q>: تألّى، ووجّهه بقوله: «وقادهم إلى هذا القول دخولُ اللام في الجواب». وانتَقَدَه لمخالفته ظاهر لفظ الآية بقوله: «وأمّا اللفظةُ فبعيدة عن هذا». ٢٩٣٣٠- قال الحسن البصري: قوله: <q>﴿وإذ تأذن ربك﴾</q>، يعني: أعْلَمَ ربُّك{5}. (ز) ٢٩٣٣١- عن يحي بن سلّام: في تفسير قتادة: <q>﴿وإذ تأذن ربك﴾</q>، يعني: قال ربك= (ز) ٢٩٣٣٢- وقال الحسن: أشعر ربك، قال ربك{6}. (ز) ٢٩٣٣٣- قال عطاء بن أبي رباح: <q>﴿وإذ تأذن ربك﴾</q>: حَكَم ربُّك{7}. (ز) ٢٩٣٣٤- قال مقاتل بن سليمان: <q>﴿وإذ تأذن ربك﴾</q>، يعني: قال ربُّك{8}. (ز) <q>﴿لَیَبۡعَثَنَّ عَلَیۡهِمۡ إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ مَن یَسُومُهُمۡ سُوۤءَ ٱلۡعَذَابِۗ﴾</q> - تفسير ٢٩٣٣٥- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وإذ تأذن ربك﴾</q> الآية، قال: الذين يَسُومونهم سوءَ العذاب محمدٌ ﷺ وأمَّتُه إلى يوم القيامة٢٦٦٩، وسوءُ العذاب الجِزْية{9}. (٦/٦٤١) ٢٦٦٩ رجَّح ابنُ عطية (٤/٧٧) العمومَ في الآية، فقال مُعَلِّقًا على قول ابن عباس: «والصحيحُ أنّها عامَّةٌ في كل مَن حالُ اليهودِ معه هذه الحالُ». ٢٩٣٣٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وإذ تأذن ربك﴾</q> الآية، قال: هم اليهود، بعَث عليهم العرب يَجْبُونهم الخراج، فهو سوءُ العذاب، ولم يكن من نبيٍّ جَبا الخراجَ إلا موسى ﵇، جَباه ثلاثَ عشرة سنة، ثم كفَّ عنه، وإلا النبيّ ﷺ{10}. (٦/٦٤١) ٢٩٣٣٧- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</q>: فهي المسكنة، وأَخْذُ الجزيةِ منهم{4}. (ز) ٢٩٣٣٨- عن عبد الله بن عباس -من طريق ابن جريج- <q>﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</q>، قال: يهود، وما ضرب عليهم من الذِّلَّة والمسكنة{12}. (ز) ٢٩٣٣٩- عن سعيد بن المسيب -من طريق عبد الكريم بن مالك الجزري-: أنّه كان يَسْتَحِبُّ أن يبعث الأنباط في الجزية{13}. (ز) ٢٩٣٤٠- عن سعيد بن جبير -من طريق جعفر- <q>﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</q>، قال: هم أهل الكتاب، بعث الله عليهم العربَ يجبونهم الخراج إلى يوم القيامة، فهو سوء العذاب، ولم يَجْبِ نبيٌّ الخراجَ قطُّ إلا موسى ﷺ ثلاثَ عشرة سنة ثم أمْسَكَ، وإلا النبي ﷺ{14}. (ز) ٢٩٣٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ليبعثن عليهم﴾</q> قال: على اليهود والنصارى <q>﴿إلى يوم القيامة من يسومهم سوء العذاب﴾</q> فبعَث الله عليهم أُمَّةَ محمد ﷺ يأخُذون منهم الجزية وهم صاغِرون{15}. (٦/٦٤١) ٢٩٣٤٢- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿ليبعثن عليهم إلى يوم القيامة من يسومهم﴾</q>، قال: بَعَث عليهم هذا الحيَّ من العرب، فهم في عذاب منهم إلى يوم القيامة.= (ز) ٢٩٣٤٣- وقال عبد الكريم بن مالك الجزري: يستحب أن تبعث الأنباط في الجزية{16}. (ز) ٢٩٣٤٤- عن مطر الورّاق -من طريق ابن شوذب- في قول الله: <q>﴿ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</q>، قال: سلَّط الله عليهم العربَ؛ فهم منهم في عَناء إلى يوم القيامة{17}. (ز) ٢٩٣٤٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</q>، يقول: إنّ ربك يبعث على بني إسرائيل العربَ، فيسومونهم سوء العذاب؛ يأخذون منهم الجزية، ويقتلونهم{18}. (ز) ٢٩٣٤٦- قال مقاتل بن سليمان: قوله: <q>﴿ليبعثن عليهم﴾</q> يعني: بني إسرائيل <q>﴿من يسومهم سوء العذاب﴾</q> فبعث الله المسلمين عليهم إلى يوم القيامة ما دامت الدنيا <q>﴿من يسومهم سوء العذاب﴾</q> يعني: يُعَذِّبهم شِدَّةَ العذاب، يعني: القتل، والجزية{8}. (ز) ٢٩٣٤٧- عن حسن بن صالح -من طريق أبي غسان- في قوله: <q>﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</q> في الذين سكتوا{17}. (ز) ٢٩٣٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة﴾</q>: ليبعثن على يهود{21}. (ز) <q>﴿إِنَّ رَبَّكَ لَسَرِیعُ ٱلۡعِقَابِ وَإِنَّهُۥ لَغَفُورࣱ رَّحِیمࣱ ۝١٦٧﴾</q> - تفسير ٢٩٣٤٩- قال الحسن البصري: قوله: <q>﴿إن ربك لسريع العقاب﴾</q>، إذا أراد الله أن يُعَذِّب قومًا كان عذابُه إيّاهم أسْرَعَ مِن الطَّرْف{5}. (ز) ",footnotes:1:تفسير الثعلبي ٤/٢٩٩.تفسير مجاهد ص٣٤٥، وأخرجه ابن جرير ١٠/٥٣٠، ٥٣٣، وابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٥/١٦٠٣.أخرجه ابن جرير ١٠/٥٣٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-.علَّقه يحيى بن سلام ١/١١٩، ١١٨.تفسير البغوي ٣/٢٩٥. وفي تفسير الثعلبي ٤/٢٩٩ بلفظ: حتم.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن جرير ١٠/٥٣٠، وابن أبي حاتم ٥/١٦٠٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٥/١٦٠٣، ١٦٠٥. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٥٣٠.أخرجه ابن جرير ١٠/٥٣١.أخرجه عبد الرزاق في تفسيره ٢/٩٥، وابن جرير ١٠/٥٣٢.أخرجه ابن جرير ١٠/٥٣٢، وابن أبي حاتم ٥/١٦٠٤ مختصرًا.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد وابن المنذر، وابن جرير، وأبي الشيخ.أخرجه عبد الرزاق في تفسيره ٢/٩٤ بنحوه، وابن جرير ١٠/٥٣١، وله أيضًا من طريق سعيد. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠- بلفظ فيه: فهم منه في عذاب بالجزية والذل.أخرجه ابن أبي حاتم ٥/١٦٠٤.أخرجه ابن جرير ١٠/٥٣٢.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن أبي حاتم ٥/١٦٠٤.أخرجه ابن جرير ١٠/٥٣٣، وابن أبي حاتم ٥/١٦٠٤ من طريق أصبغ بن الفرج.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-.
7,168," <q>﴿وَقَطَّعۡنَـٰهُمۡ فِی ٱلۡأَرۡضِ أُمَمࣰاۖ﴾</q> - تفسير ٢٩٣٥٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرْني عن قول الله: <q>﴿وقطعناهم في الأرض أمما﴾</q>، ما الأُمَم؟ قال: الفِرَق. وقال فيه بشرُ بن أبي خازم: مِن قيسِ عَيلانَ في ذوائِبِها منهم وهم بعدُ قادةُ الأمم{1}. (٦/٦٤٢) ٢٩٣٥١- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وقطعناهم﴾</q> الآية، قال: هم اليهود، بسَطهم الله في الأرض؛ فليس في الأرض بقعةٌ إلا وفيها عصابةٌ منهم وطائفة{2}. (٦/٦٤١) ٢٩٣٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وقطعناهم في الأرض أمما﴾</q>، قال: يهود{3}. (٦/٦٤١) ٢٩٣٥٣- عن سعيد بن جبير، مثل ذلك{4}. (ز) ٢٩٣٥٤- قال مقاتل بن سليمان: قوله: <q>﴿وقطعناهم﴾</q> يعني: وفرَّقناهم في الأرض <q>﴿أمما﴾</q> يعني: فِرَقًا، يعني: بني إسرائيل{5}٢٦٧٠. (ز) ٢٦٧٠ ذَكَرَ ابنُ عطية (٤/٧٧) مستندًا لدلالة العقل أنّ الظاهر في المشار إليهم في هذه الآية أنّهم: الذين بعد سليمان وقت زوال ملكهم، وأنّ هذا كان قبل وقت عيسى ﵇؛ لأنّه لم يكن فيهم صالح بعد كفرهم بعيسى. وبنحوه قال ابنُ جرير (١٠/٥٤٣). <q>﴿مِّنۡهُمُ ٱلصَّـٰلِحُونَ﴾</q> - تفسير ٢٩٣٥٥- قال عبد الله بن عباس= (ز) ٢٩٣٥٦- ومجاهد بن جبر: <q>﴿منهم الصالحون﴾</q>، يريد الذين أدركوا رسولَ الله ﷺ، وآمنوا به{6}. (ز) ٢٩٣٥٧- عن سعيد بن جبير -من طريق جعفر- قوله: <q>﴿منهم الصالحون﴾</q>، قال: مِن أُمَّة محمد ﷺ{7}. (ز) ٢٩٣٥٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿منهم الصالحون﴾</q>: وهم مُسْلِمَةُ أهل الكتاب{8}. (٦/٦٤١) <q>﴿وَمِنۡهُمۡ دُونَ ذَ ٰ⁠لِكَۖ﴾</q> - تفسير ٢٩٣٥٩- قال عبد الله بن عباس= (ز) ٢٩٣٦٠- ومجاهد بن جبر: <q>﴿ومنهم دون ذلك﴾</q>، يعني: الذين بَقَوْا على الكُفر{6}. (ز) ٢٩٣٦١- عن سعيد بن جبير -من طريق جعفر- قوله: <q>﴿ومنهم دون ذلك﴾</q>، قال: مَن لم يُؤْمِن بمحمد ﷺ{10}. (ز) ٢٩٣٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ومنهم دون ذلك﴾</q>، قال: اليهود{8}. (٦/٦٤١) ٢٩٣٦٣- قال مقاتل بن سليمان: قوله: <q>﴿منهم الصالحون﴾</q> يعني: المؤمنين، <q>﴿ومنهم دون ذلك﴾</q> يعني: دون الصالحين؛ فهُمُ الكُفّار{5}. (ز) <q>﴿وَبَلَوۡنَـٰهُم بِٱلۡحَسَنَـٰتِ وَٱلسَّیِّـَٔاتِ﴾</q> - تفسير ٢٩٣٦٤- عن عبد الله بن عباس: <q>﴿وبلوناهم بالحسنات والسيئات﴾</q>، قال: بالخِصْب، والجَدْب{13}. (٦/٦٤٢) ٢٩٣٦٥- عن عبد الله بن عباس -من طريق الضحاك- قوله: <q>﴿والسيئات﴾</q>، قال: البلاء والعقوبة{14}. (ز) ٢٩٣٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وبلوناهم بالحسنات﴾</q> قال: الرَّخاء والعافية، <q>﴿والسيئات﴾</q> قال: البلاء والعقوبة{8}. (٦/٦٤١) ٢٩٣٦٧- عن محمد بن كعب القرظي -من طريق أبي معشر- قال: ابْتُلُوا بالرَّخاء فلم يصبِروا، قال: <q>﴿وقطعناهم في الأرض أمما منهم الصالحون ومنهم دون ذلك وبلوناهم بالحسنات والسيئات لعلهم يرجعون﴾</q>{14}. (ز) ٢٩٣٦٨- قال مقاتل بن سليمان: قوله: <q>﴿وبلوناهم بالحسنات والسيئات﴾</q>، يقول: ابتليناهم بالخِصْب، والشِّدَّة{5}. (ز) <q>﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝١٦٨﴾</q> - تفسير ٢٩٣٦٩- عن الحسن البصري -من طريق أشعث- <q>﴿لعلهم يرجعون﴾</q>: لعلهم يتوبون{14}. (ز) ٢٩٣٧٠- قال مقاتل بن سليمان: قوله: <q>﴿لعلهم﴾</q> يعني: لكي <q>﴿يرجعون﴾</q> إلى التوبة{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن جرير ١٠/٥٣٣، وابن أبي حاتم ٥/١٦٠٣، ١٦٠٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٤٦، وأخرجه ابن جرير ١٠/٥٣٣، وابن أبي حاتم ٥/١٦٠٣-١٦٠٦، وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٥/١٦٠٥.تفسير مقاتل بن سليمان ٢/٧١.تفسير البغوي ٣/٢٩٥.أخرجه ابن أبي حاتم ٥/١٦٠٤.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير، وأبي الشيخ.تفسير البغوي ٣/٢٩٥.أخرجه ابن أبي حاتم ٥/١٦٠٥.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٧١.عزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٦.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٦.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن أبي حاتم ٥/١٦٠٦.تفسير مقاتل بن سليمان ٢/٧١.
7,169," <q>﴿فَخَلَفَ مِنۢ بَعۡدِهِمۡ خَلۡفࣱ وَرِثُوا۟ ٱلۡكِتَـٰبَ﴾</q> - تفسير ٢٩٣٧١- عن أبي سعيد الخدري -من طريق الوليد بن قيس- في هذه الآية: <q>﴿فخلف من بعدهم خلف﴾</q>، قال: الخَلْفُ مِن بعد سِتِّين سنةً{1}. (ز) ٢٩٣٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فخلف من بعدهم خلف﴾</q>، قال: النصارى{2}٢٦٧١. (٦/٦٤٢) ٢٦٧١ علَّق ابنُ كثير (٦/٤٣٠) على قول مجاهد بقوله: «وقد يكون أعمَّ من ذلك». ٢٩٣٧٣- عن مجاهد بن جبر -من طريق إبراهيم بن المهاجر- <q>﴿فخلف من بعدهم خلف﴾</q>، قال: هم هذه الأُمَّة، يَتَرادَفُون{3} في الطُّرُق كما تَرادَفُ الأنعامُ، لا يخافون مَن في السماء، ولا يَسْتَحْيُون مِمَّن في الأرض{1}. (ز) ٢٩٣٧٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فخلف من بعدهم خلف﴾</q>، يعني: اليهود والنصارى{5}. (ز) ٢٩٣٧٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فخلف من بعدهم خلف﴾</q> قال: خَلْفُ سَوْءٍ، <q>﴿ورثوا الكتاب﴾</q> بعدَ أنبيائِهم ورُسلِهم، أورَثَهم اللهُ الكتابَ، وعهِد إليهم{6}. (٦/٦٤٣) ٢٩٣٧٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فخلف من بعدهم خلف ورثوا الكتاب﴾</q>، قال: هم مِن بني إسرائيل، وأشباههم مِن هذه الأمة المُرْجِئَة{5}. (ز) ٢٩٣٧٧- قال مقاتل بن سليمان قوله: <q>﴿فخلف من بعدهم﴾</q> يعني: مِن بعد بني إسرائيل <q>﴿خلف﴾</q> [خَلْفُ] السوء، وهم اليهود، <q>﴿ورثوا الكتاب﴾</q> يعني: ورِثُوا التوراة عن أوائلهم وآبائهم{8}٢٦٧٢. (ز) ٢٦٧٢ أفادتِ الآثارُ الاختلافَ في الخلْف الذين ذكر اللهُ في هذه الآية أنّهم خَلَفوا مَن قبلهم. ورجَّح ابنُ جرير (١٠/٥٣٥) أنّهم اليهود، وهو قول مقاتل، وانتَقَدَ القول بأنّهم النصارى؛ لمخالفته السياق، فقال: «والصوابُ مِن القول في ذلك عندي أن يُقال: إنّ الله -تعالى ذِكْرُه- إنّما وصف أنّه خَلَف القومَ -الذين قصَّ قصصهم في الآيات التي مضت- خَلْف سوءٍ رديء، ولم يذكر لنا أنهم نصارى في كتابه، وقصتهم بقصص اليهود أشبه منها بقصص النصارى. وبعدُ، فإنّ ما قبل ذلك خبرٌ عن بني إسرائيل، وما بعده كذلك؛ فما بينهما بأن يكون خبرًا عنهم أشبه، إذ لم يكن في الآية دليلٌ على صَرْفِ الخبر عنهم إلى غيرهم، ولا جاء بذلك دليلٌ يُوجِبُ صِحَّة القول به». <q>﴿یَأۡخُذُونَ عَرَضَ هَـٰذَا ٱلۡأَدۡنَىٰ وَیَقُولُونَ سَیُغۡفَرُ لَنَا وَإِن یَأۡتِهِمۡ عَرَضࣱ مِّثۡلُهُۥ یَأۡخُذُوهُۚ﴾</q> - تفسير ٢٩٣٧٨- عن عبد الله بن عباس: أنّه سُئِل عن هذه الآية: <q>﴿فخلف من بعدهم خلف ورثوا الكتاب يأخذون عرض هذا الأدنى﴾</q>. قال: أقوامٌ يُقبِلون على الدنيا، فيأكُلونها، ويَتَّبعونُ رُخَصَ القرآن، <q>﴿ويقولون سيغفر لنا﴾</q>. ولا يَعرِضُ لهم شيءٌ من الدنيا إلا أخَذوه، <q>﴿ويقولون: سيُغفَرُ لنا﴾</q>{9}. (٦/٦٤٢) ٢٩٣٧٩- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿فخلف من بعدهم خلف﴾</q> الآية، يقول: يأخُذون ما أصابوا، ويترُكون ما شاءوا؛ مِن حلال أو حرام، <q>﴿ويقولون: سيُغفَرُ لنا﴾</q>{10}. (٦/٦٤٣) ٢٩٣٨٠- عن سعيد بن جبير -من طريق منصور بن المعتمر- في قوله: <q>﴿يأخذون عرض هذا الأدنى ويقولون سيغفر لنا﴾</q>، قال: كانوا يعملون بالذنوب، ويقولون: سيُغفَرُ لنا{11}. (٦/٦٤٣) ٢٩٣٨١- عن سعيد بن جبير -من طريق منصور بن المعتمر- في قوله: <q>﴿فَخَلَفَ مِن بَعْدِهِمْ خَلْفٌ ورِثُوا الكِتابَ يَأْخُذُونَ عَرَضَ هَذا الأَدْنى﴾</q> قال: يعملون الذنوب، <q>﴿وإنْ يَأْتِهِمْ عَرَضٌ مِثْلُهُ يَأْخُذُوهُ﴾</q> قال: الذنوب{10}. (ز) ٢٩٣٨٢- عن إبراهيم النخعي -من طريق سفيان- <q>﴿يأخذون عرض هذا الأدنى﴾</q>، قال: الذنوب{5}. (ز) ٢٩٣٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يأخذون عرض هذا الأدنى﴾</q>، قال: ما أشرَف لهم مِن شيءٍ مِن الدنيا حلالًا أو حرامًا يشتهونه أخَذوه، ويتمنَّوْن المغفرة، وإن يجِدوا الغَدَ مثلَه يَأْخُذوه{14}. (٦/٦٤٢) ٢٩٣٨٤- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿يأخذون عرض هذا الأدنى﴾</q> من الحرام{15}. (ز) ٢٩٣٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يأخذون عرض هذا الأدنى ويقولون سيغفر لنا﴾</q> قال: أمانِيّ تَمَنَّوها على الله، وغِرَّة يغترُّون بها، <q>﴿وإن يأتهم عرض مثله يأخذوه﴾</q> ولا يَشغلُهم شيءٌ عن شيء، ولا ينهاهم شيءٌ عن ذلك، كلمّا أشرَف لهم شيءٌ مِن الدنيا أخَذوه، ولا يُبالون حلالًا كان أو حرامًا{16}. (٦/٦٤٣) ٢٩٣٨٦- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله تعالى: <q>﴿يأخذون عرض هذا الأدنى﴾</q> قال: يأخذونه إن كان حلالًا، وإن كان حرامًا. قال: <q>﴿وإن يأتهم عرض مثله﴾</q> قال: إن جاءهم حلالٌ أو حرامٌ أخذوه{17}. (ز) ٢٩٣٨٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿فخلف من بعدهم خلف﴾</q> إلى قوله: <q>﴿ودرسوا ما فيه﴾</q>، قال: كانت بنو إسرائيل لا يَسْتَقْضُون قاضيًا إلا ارْتَشى في الحُكْم، وإنّ خيارهم اجتمعوا، فأخذ بعضُهم على بعضٍ العهودَ أن لا يفعلوا ولا يرتشوا، فجعل الرجلُ منهم إذا اسْتُقْضِيَ ارْتَشى، فيُقال له: ما شأنك ترتشي في الحُكْم؟ فيقول: سيغفر لي. فيطعن عليه البَقِيَّةُ الآخرون مِن بني إسرائيل فيما صنع، فإذا مات أو نُزِع وجُعِل مكانَه رجلٌ مِمَّن كان يطعن عليه فيرتشي، يقول: وإن يأتِ الآخرين عَرَضُ الدنيا يأخذوه. وأمّا عرض الأدنى: فعَرَضُ الدنيا من المال{18}. (ز) ٢٩٣٨٨- عن عطاء الخراساني -من طريق ابنه عثمان- في قوله: <q>﴿يأخذون عرض هذا الأدنى ويقولون سيغفر لنا﴾</q>، قال: يأخُذون ما عرَض لهم من الدنيا، ويقولون: نستغفرُ الله، ونتوبُ إليه{19}. (٦/٦٤٤) ٢٩٣٨٩- قال مقاتل بن سليمان: قوله: <q>﴿يأخذون عرض هذا الأدنى﴾</q> وهي الدنيا؛ لأنها أدنى من الآخرة، يعني: الرشوة في الحكم، <q>﴿ويقولون سيغفر لنا﴾</q> فكانوا يرشون بالنهار، ويقولون: يغفر لنا. بالليل، <q>﴿وإن يأتهم عرض مثله﴾</q> يعني: رشوة مثله ليلًا يأخذوه، ويقولون: يغفر لنا. بالنهار{8}. (ز) ٢٩٣٩٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يأخذون عرض هذا الأدنى﴾</q> قال: الكتاب الذي كتبوه، ويقولون: <q>﴿سيغفر لنا﴾</q>، لا نشرك بالله شيئًا. <q>﴿وإن يأتهم عرض مثله يأخذوه﴾</q>: يأتهم المُحِقُّ برشوة، فيُخْرِجُوا له كتابَ الله، ثم يحكموا له بالرشوة. وكان الظالم إذا جاءهم برشوة أخرجوا له المَثْناةَ{21}، وهو الكتاب الذي كتبوه، فحكموا له بما في المَثْناةِ بالرشوة، فهو فيها مُحِقٌّ، وهو في التوراة ظالم؛ فقال الله: <q>﴿ألم يؤخذ عليهم ميثاق الكتاب أن لا يقولوا على الله إلا الحق ودرسوا ما فيه﴾</q>{22}٢٦٧٣. (ز) ٢٦٧٣ ذكر ابنُ جرير (١٠/٥٣٦) تفسير الآية مستندًا لأقوال السلف، فقال: «فتبدل من بعدهم بدل سوء، ورثوا كتاب الله، فعلموه، وضيعوا العمل به، فخالفوا حُكمَه، يُرشَون في حكم الله، فيأخذون الرِّشوة فيه مِن عَرَض هذا العاجل الأدنى، يعني بـ<q>﴿الأدنى﴾</q>: الأقرب من الآجل الأبعد، ويقولون إذا فعلوا ذلك: إنّ الله سيغفر لنا ذنوبنا. تمنِّيًا على الله الأباطيل، كما قال -جل ثناؤه- فيهم: <q>﴿فويل للذين يكتبون الكتاب بأيديهم ثم يقولون هذا من عند الله ليشتروا به ثمنا قليلا فويل لهم مما كتبت أيديهم وويل لهم مما يكسبون﴾</q> [البقرة:٧٩]، <q>﴿وإن يأتهم عرض مثله يأخذوه﴾</q>. يقول: وإن شرع لهم ذنبٌ حرامٌ مثله من الرشوة بعد ذلك أخذوه واستحلوه، ولم يرتدعوا عنه. يُخْبِر -جلَّ ثناؤه- عنهم أنّهم أهلُ إصرار على ذنوبهم، وليسوا بأهل إنابة ولا توبة». ثم قال بعد ذلك: «وبنحو الذي قلنا في ذلك قال أهل التأويل، وإن اختلفت عنه عباراتهم». وساق آثارَ السلف. <q>﴿أَلَمۡ یُؤۡخَذۡ عَلَیۡهِم مِّیثَـٰقُ ٱلۡكِتَـٰبِ أَن لَّا یَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّ﴾</q> - تفسير ٢٩٣٩١- عن عبد الله بن عباس -من طريق ابن جُرَيْج-: <q>﴿ألم يؤخذ عليهم ميثاق الكتاب أن لا يقولوا على الله إلا الحق﴾</q> فيما يوجِبون على الله مِن غُفران ذنوبهم التي لا يزالون يَعودُون إليها، ولا يَتوبون منها{23}. (٦/٦٤٤) ٢٩٣٩٢- عن الحسن البصري -من طريق أبي الأشهب- في قوله: <q>﴿ألَمْ يُؤْخَذْ عَلَيْهِمْ مِيثاقُ الكِتابِ أنْ لا يَقُولُوا عَلى اللَّهِ إلّا الحَقَّ﴾</q>، قال: هي لأهل الإيمان منهم{15}. (ز) <q>﴿وَدَرَسُوا۟ مَا فِیهِۗ﴾</q> - تفسير ٢٩٣٩٣- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿ودرسوا ما فيه﴾</q>، قال: علِموا ما فيه{25}. (ز) ٢٩٣٩٤- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿ودرسوا ما فيه﴾</q>، يعني: فأقَرُّوا ما فيه، يعني: مُخَفَّفة{25}. (ز) ٢٩٣٩٥- قال مقاتل بن سليمان: يقول الله: <q>﴿ألم يؤخذ عليهم ميثاق الكتاب﴾</q> يعني: بغير ما يقولون، لقد أخذ عليهم في التوراة أن لا يَسْتَحِلُّوا مُحَرَّمًا، وأن لا يقولوا على الله إلا الحق في التوراة، <q>﴿ودرسوا﴾</q> يعني: وقرءوا <q>﴿ما فيه﴾</q> ما في التوراة{8}. (ز) ٢٩٣٩٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ودرسوا ما فيه﴾</q>، قال: علِمُوا ما في الكتاب؛ لم يَأتُوه بجهالة{28}. (٦/٦٤٥) <q>﴿وَٱلدَّارُ ٱلۡـَٔاخِرَةُ خَیۡرࣱ لِّلَّذِینَ یَتَّقُونَۚ أَفَلَا تَعۡقِلُونَ ۝١٦٩﴾</q> - تفسير ٢٩٣٩٧- عن الحسن البصري -من طريق أبي الأشهب- في قوله: <q>﴿والدار الآخرة خير للذين يتقون أفلا تعقلون﴾</q>، قال: هي لأهل الإيمان منهم{25}. (ز) ٢٩٣٩٨- قال مقاتل بن سليمان: <q>﴿والدار الآخرة﴾</q> يعني: الجنة <q>﴿خير للذين يتقون﴾</q> استحلالَ المحارم، <q>﴿أفلا تعقلون﴾</q>{30}. (ز) <q>﴿وَٱلدَّارُ ٱلۡـَٔاخِرَةُ خَیۡرࣱ لِّلَّذِینَ یَتَّقُونَۚ أَفَلَا تَعۡقِلُونَ ۝١٦٩﴾</q> - آثار متعلقة بالآية ٢٩٣٩٩- عن الحسن البصري، قال: المؤمنُ يعلم أنّ ما قال اللهُ كما قال الله، والمؤمنُ أحسنُ عملًا، وأشدُّ الناسِ خوفًا، لو أنفَق جبلًا مِن مال ما أمِنَ دونَ أن يُعايِنَ، لا يَزْدادُ صلاحًا وبِرًّا وعبادةً إلا ازدادا فَرَقًا، يقول: ألّا أنجُوَ. والمنافق يقول: سواد الناس كثير، وسيُغْفَرُ لي، ولا بَأسَ عَلَيَّ. فيُسِيءُ العمل، ويتمنّى على الله{9}. (٦/٦٤٤) ٢٩٤٠٠- عن أبي الجَلْد جيلان بن فروة، قال: يأتي على الناس زمانٌ تَخْرَبُ صُدورُهم مِن القرآن، وتتهافَتُ وتَبْلى كما تبْلى ثيابُهم، لا يجِدون لهم حلاوةً ولا لذاذةً، إن قصَّروا عما أُمِروا به قالوا: إنّ الله غفورٌ رحيمٌ. وإن عمِلوا بما نُهُوا عنه قالوا: سيُغفَرُ لنا؛ إنّا لا نُشْرِكُ بالله شيئًا. أمرُهم كلُّه طَمَعٌ ليس فيه خوف، لَبِسوا جلودَ الضان على قلوب الذِّئاب، أفضلُهم في نفسه المُدَّهِنُ{32}{9}. (٦/٦٤٤) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٦٠٦.تفسير مجاهد ص٣٤٦، وأخرجه ابن جرير ١٠/٥٣٥، وابن أبي حاتم ٥/١٦٠٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.التَّرادُفُ: كناية عن فعل قبيح. لسان العرب (ردف). وفي القاموس (ردف): تَرادَفا: تناكحا.أخرجه ابن أبي حاتم ٥/١٦٠٦.أخرجه ابن أبي حاتم ٥/١٦٠٧.أخرجه ابن جرير ١٠/٥٣٧، وابن أبي حاتم ٥/١٦٠٧ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٧.تفسير مقاتل بن سليمان ٢/٧١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٥٣٩.أخرجه سعيد بن منصور (٩٦٦ - تفسير)، وعبد الرزاق في تفسيره ٢/٩٥، وابن جرير ١٠/٥٣٧، ٥٣٩، وابن أبي حاتم ٥/١٦٠٨، والبيهقي في شعب الإيمان (٧١٥٨). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٥٣٩.أخرجه ابن أبي حاتم ٥/١٦٠٧.أخرجه ابن جرير ١٠/٥٣٧، وابن أبي حاتم ٥/١٦٠٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥١- بنحوه. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٥/١٦٠٨.أخرجه ابن جرير ١٠/٥٣٨، وابن أبي حاتم ٥/١٦٠٧ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه عبد الرزاق في تفسيره ٢/٩٥، وابن جرير ١٠/٥٣٨.أخرجه ابن جرير ١٠/٥٣٨. وعزاه السيوطي ٦/٦٤٤ لأبي الشيخ بلفظ: كانت بنو إسرائيل لا يستَقْضُون قاضيًا إلا ارتشى في الحكْم، فإذا قيل له، يقول: سيُغفَرُ لي.أخرجه ابن أبي حاتم ٥/١٦٠٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٧١.المَثْناة: هي أنّ أحبار بني إسرائيل بعد موسى ﵇ وضعوا كتابه فيما بينهم على ما أرادوا من غير كتاب الله. النهاية (ثنا).أخرجه ابن جرير ١٠/٥٣٩، وابن أبي حاتم ٥/١٦٠٧.أخرجه ابن جرير ١٠/٥٤٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٨.أخرجه ابن أبي حاتم ٥/١٦٠٩.أخرجه ابن أبي حاتم ٥/١٦٠٩.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن جرير ١٠/٥٤١، وابن أبي حاتم ٥/١٦٠٩ من طريق أصبغ بن الفرج.أخرجه ابن أبي حاتم ٥/١٦٠٩.تفسير مقاتل بن سليمان ٢/٧٢.عزاه السيوطي إلى أبي الشيخ.المداهنة: المصانَعة واللِّين، وقيل: إظهار خلاف ما يُضمر. لسان العرب (دهن).عزاه السيوطي إلى أبي الشيخ.
7,170," <q>﴿وَٱلَّذِینَ یُمَسِّكُونَ بِٱلۡكِتَـٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِیعُ أَجۡرَ ٱلۡمُصۡلِحِینَ ۝١٧٠﴾</q> - قراءات ٢٩٤٠١- عن الأعمش: في قراءة عبد الله: (إنَّ الَّذِينَ اسْتَمْسَكُواْ بِالكِتابِ){1}. (ز) <q>﴿وَٱلَّذِینَ یُمَسِّكُونَ بِٱلۡكِتَـٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِیعُ أَجۡرَ ٱلۡمُصۡلِحِینَ ۝١٧٠﴾</q> - نزول الآية ٢٩٤٠٢- قال مقاتل بن سليمان: قوله: <q>﴿والذين يمسكون بالكتاب وأقاموا الصلاة إنا لا نضيع أجر المصلحين﴾</q> نَزَلَتْ في ابن سلام وأصحابه{2}. (ز) <q>﴿وَٱلَّذِینَ یُمَسِّكُونَ بِٱلۡكِتَـٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِیعُ أَجۡرَ ٱلۡمُصۡلِحِینَ ۝١٧٠﴾</q> - تفسير الآية ٢٩٤٠٣- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿والذين يمسكون بالكتاب﴾</q>، قال: مِن اليهود والنصارى{3}. (٦/٦٤٥) ٢٩٤٠٤- عن الحسن البصري -من طريق أبي الأشهب- في قوله: <q>﴿والذين يمسكون بالكتاب﴾</q> قال: هي لأهل الإيمان منهم، <q>﴿إنا لا نضيع أجر المصلحين﴾</q> قال: هي لأهل الإيمان منهم{4}. (٦/٦٤٥) ٢٩٤٠٥- قال عطاء بن أبي رباح: هم أُمَّةُ محمد ﷺ{5}. (ز) ٢٩٤٠٦- قال مقاتل بن سليمان: ثُمَّ ذَكَر مؤمنيهم، فقال: <q>﴿والذين يمسكون بالكتاب﴾</q>، يعني: يتمسكون بالتوراة، ولا يُحَرِّفونه عن مواضعه، ولا يَسْتَحِلُّون مُحَرَّمًا{2}. (ز) ٢٩٤٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والذين يمسكون بالكتاب﴾</q>، قال: الذي جاء به موسى ﵇{7}. (٦/٦٤٥) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣١٧. وهي قراءة شاذة، تروى أيضًا عن الأعمش. انظر: البحر المحيط ٤/٤١٦.تفسير مقاتل بن سليمان ٢/٧٢.تفسير مجاهد ص٣٤٦، وأخرجه ابن جرير ١٠/٥٤٢، وابن أبي حاتم ٥/١٦٠٩ من طريق ابن أبي نجيح. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥١-. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٨-١٦١٠. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٤/٣٠١، وتفسير البغوي ٣/٢٩٧.تفسير مقاتل بن سليمان ٢/٧٢.أخرجه ابن جرير١٠/٥٤٢، وابن أبي حاتم ٥/١٦٠٩ من طريق أصبغ بن الفرج.
