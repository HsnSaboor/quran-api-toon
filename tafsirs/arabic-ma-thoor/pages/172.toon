quran[7]{c,v,t}:
  7,164,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَتۡ أُمَّةࣱ مِّنۡهُمۡ لِمَ تَعِظُونَ قَوۡمًا ٱللَّهُ مُهۡلِكُهُمۡ أَوۡ مُعَذِّبُهُمۡ عَذَابࣰا شَدِیدࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٢٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق معمر، عن قتادة- <span class="qpc-hafs">﴿لم تعظون قوما الله مهلكهم﴾</span>، قال: هم ثلاثُ فِرَق: الفِرْقَةُ التي وعَظَتْ، والموعوظة التي وُعِظَت، واللهُ أعلم ما فعلت الفرقة الثالثة، وهم الذين قالوا: <span class="qpc-hafs">﴿لم تعظون قوما الله مهلكهم﴾</span>؟!.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٨٦<span class="dash">-</span></span> وقال <span class="name-3">محمد بن السائب الكلبي</span>-من طريق معمر-: هما فرقتان: الفرقة التي وعَظَتْ، والفرقة التي قالت: <span class="qpc-hafs">﴿لم تعظون قوما الله مهلكهم﴾</span>. قال: هي الموعوظة{1}<span class=comment-ref>٢٦٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٦٥</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٤/٧٢) <span class="mustanad">مستندًا إلى لفظ الآية</span> أنّ بني إسرائيل افترقت ثلاث فرق، مُبَيِّنًا أنّ ما يؤيِّد ذلك «الضمائر في قوله: <span class="qpc-hafs">﴿إلى رَبِّكُمْ ولَعَلَّهُمْ﴾</span>، فهذه المخاطبة تقتضي مخاطِبًا ومخاطَبًا ومَكْنِيًّا عنه».</div></p><p><div></p><p><p><span class="item-no">٢٩٢٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذْ قالَتْ أُمَّةٌ مِنهُمْ﴾</span> يعني: عصابة منهم، وهي الظَّلَمة للواعِظة: <span class="qpc-hafs">﴿لِمَ تَعِظُونَ قَوْمًا اللَّهُ مُهْلِكُهُمْ أوْ مُعَذِّبُهُمْ عَذابًا شَدِيدًا﴾</span>. وذلك أنّ الواعظة نَهَوْهُم عن الحيتان، وخوَّفوهم، فلم ينتبهوا، فرَدَّت عليهم الواعظة، <span class="qpc-hafs">﴿قالُوا مَعْذِرَةً إلى رَبِّكُمْ ولَعَلَّهُمْ يَتَّقُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ مَعۡذِرَةً إِلَىٰ رَبِّكُمۡ وَلَعَلَّهُمۡ یَتَّقُونَ ۝١٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٢٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿قالُوا مَعْذِرَةً إلى رَبِّكُمْ﴾</span> لسُخْطنا أعمالهم، <span class="qpc-hafs">﴿ولَعَلَّهُمْ يَتَّقُونَ﴾</span> أي: ينزِعون عمّا هم عليه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٨٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولعلهم يتقون﴾</span>، قال: يتركون هذا العملَ الذي هم عليه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا مَعْذِرَةً إلى رَبِّكُمْ ولَعَلَّهُمْ﴾</span> يعني: ولكي ينتهوا فيُؤَخَّروا، أو يُعَذَّبوا فينجوا، <span class="qpc-hafs">﴿ولَعَلَّهُمْ﴾</span> يعني: ولكي <span class="qpc-hafs">﴿يَتَّقُونَ﴾</span> المعاصيَ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ مَعۡذِرَةً إِلَىٰ رَبِّكُمۡ وَلَعَلَّهُمۡ یَتَّقُونَ ۝١٦٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٩٢٩١<span class="dash">-</span></span> عن سفيان، قال: قالوا <span class="name-3">لعبد الله بن عبد العزيز العُمَريِّ</span> العابِدِ في الأمر بالمعروفِ والنهيِ عن المنكر: تَأمُرُ مَن لا يَقبلُ منك؟! قال: يكونُ معذِرةً. وقرأ: <span class="qpc-hafs">﴿قالُوا مَعذِرَةً إلى رَبِكُم﴾</span>{6}. (٦/٦٤٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٥٢١.تفسير مقاتل بن سليمان ٢/٧٠.أخرجه ابن جرير ١٠/٥١١.أخرجه ابن جرير ١٠/٥١١، وابن أبي حاتم ٥/١٦٠١ من طريق أصبغ بن الفرج.تفسير مقاتل بن سليمان ٢/٧٠.عزاه السيوطي إلى أبي الشيخ.
  7,165,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦۤ أَنجَیۡنَا ٱلَّذِینَ یَنۡهَوۡنَ عَنِ ٱلسُّوۤءِ وَأَخَذۡنَا ٱلَّذِینَ ظَلَمُوا۟ بِعَذَابِۭ بَـِٔیسِۭ بِمَا كَانُوا۟ یَفۡسُقُونَ ۝١٦٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٩٢٩٢<span class="dash">-</span></span> عن أبي بكر بن عيّاشٍ، قال: كان حِفْظي عن <span class="name-2">عاصم</span>: ‹بِعَذابٍ بَيْئَسٍ› على معنى: فَيْعَل، ثم دخَلني منها شكٌّ، فترَكْتُ روايتَها عن عاصم= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٣<span class="dash">-</span></span> وأخَذْتُها عن <span class="name-2">الأعمشِ</span>: <span class="qpc-hafs">﴿بِعَذابِ بَئِيسٍ﴾</span>، على معنى: فَعِيل{1}. (٦/٦٣٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦۤ أَنجَیۡنَا ٱلَّذِینَ یَنۡهَوۡنَ عَنِ ٱلسُّوۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٢٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فَلَمّا نَسُوا ما ذُكِّرُوا بِهِ﴾</span>، يعني: تَرَكوا ما ذُكِّروا به{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: نجا النّاهون، وهلَك الفاعِلُون، ولا أدْرِي ما صُنِعَ بالسّاكتِين{3}. (٦/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿أنْجَيْنا الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ﴾</span>، قال: يا ليت شعري، ما السوء الذي نَهَوْا عنه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: واللهِ، لَأن أكونَ علِمتُ أنّ القومَ الذين قالوا: لِمَ تعظُون قومًا نَجَوْا مع الذين نَهَوا عن السُّوءِ؛ أحبُّ إلَيَّ ممّا عُدِلَ به -وفي لفظٍ: من حُمْرِ النَّعَمِ-، ولكنِّي أخافُ أن تكونَ العقوبةُ نزَلتْ بهم جميعًا{5}. (٦/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٨<span class="dash">-</span></span> قال قتادة: وبلغنا: أنّه دُخل على <span class="name-1">عبد الله بن عباس</span>، وبين يديه المصحف، وهو يبكي وقد أتى على هذه الآية: <span class="qpc-hafs">﴿فلما نسوا ما ذكروا به﴾</span>، فقال: قد علمتُ أنّ الله أهلك الذين أخذوا الحيتان، ونجّى الذين نهوهم، ولا أدري ما صنع بالذين لم ينهوا ولم يواقعوا المعصية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وإذْ قالَتْ أُمَّةٌ مِنهُمْ لِمَ تَعِظُونَ قَوْمًا اللَّهُ مُهْلِكُهُمْ﴾</span>، قال: أسمعُ اللهَ يقول: <span class="qpc-hafs">﴿أنْجَيْنا الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ وأَخَذْنا الَّذِينَ ظَلَمُوا بِعَذابٍ بَئِيسٍ﴾</span>. فليت شعري، ما فُعِل بهؤلاء الذين قالوا: <span class="qpc-hafs">﴿لِمَ تَعِظُونَ قَوْمًا اللَّهُ مُهْلِكُهُمْ﴾</span>؟{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span>، قال: قال <span class="name-1">عبد الله بن عباس</span>: ما أدْري أنَجا الذين قالوا: <span class="qpc-hafs">﴿لِمَ تَعِظُونَ قَومًا﴾</span> أم لا؟ قال: فما زلتُ أُبَصِّرُه حتى عرَف أنهم قد نجَوا، فكساني حُلَّةً{8}. (٦/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة-: فلمّا وقع عليهم غضبٌ الله نَجَتِ الطائفتان اللتان قالوا: <span class="qpc-hafs">﴿لم تعظون قوما الله مهلكهم﴾</span>. والذين قالوا: <span class="qpc-hafs">﴿معذرة إلى ربكم﴾</span>. وأهلك الله أهلَ معصيته الذين أخذوا الحيتان، فجعلهم قردةً وخنازير{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: وأيُّ نهيٍ يكونُ أشَدَّ مِن أنّهم أثبتوا لهم الوعيد، وخوَّفوهم العذاب، فقالوا: <span class="qpc-hafs">﴿لم تعظون قوما الله مهلكهم أو معذبهم عذابا شديدا﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: نَجَتِ الطائفتان؛ الذين قالوا: <span class="qpc-hafs">﴿لم تعظون قوما﴾</span>. والذين قالوا: <span class="qpc-hafs">﴿معذرة إلى ربكم﴾</span>. وأهلك الله الذين أخذوا الحيتان{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٤<span class="dash">-</span></span> عن <span class="name-2">ليث بن أبي سليم</span>، قال: مُسِخُوا حِجارةً؛ الذين قالوا: <span class="qpc-hafs">﴿لِمَ تَعِظُونَ قَومًا الله مُهْلِكُهُم﴾</span>{12}. (٦/٦٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق عبد الرازق- في قوله: <span class="qpc-hafs">﴿فلما نسوا ما ذكروا به أنجينا الذين ينهون عن السوء﴾</span>، قال: فلمّا نَسُوا موعظةَ المؤمنين إيّاهم؛ الذين قالوا: <span class="qpc-hafs">﴿لم تعظون قوما﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا نَسُوا ما ذُكِّرُوا بِهِ﴾</span> يعني: فلما تَرَكُوا ما وُعِظُوا به مِن أمر الحيتان؛ <span class="qpc-hafs">﴿أنْجَيْنا﴾</span> من العذاب <span class="qpc-hafs">﴿الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ﴾</span> يعني: المعاصي{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: نَجَتِ الناهيةُ، وهلكتِ الفرقتان، وهذه أشدُّ آيةٍ في ترك النهي عن المنكر{11}<span class=comment-ref>٢٦٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٦٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٧٢) أنّ <span class="qpc-hafs">﴿ما﴾</span> في قوله: <span class="qpc-hafs">﴿ما ذُكِّرُوا بِهِ﴾</span> بمعنى: الذي، و<span class="comment-type-4">بين</span> أنه يحتمل أن يراد به: الذكر نفسه، ويحتمل أن يراد به: ما كان فيه الذكر.</div></p><p><h3><span class="qpc-hafs">﴿وَأَخَذۡنَا ٱلَّذِینَ ظَلَمُوا۟ بِعَذَابِۭ بَـِٔیسِۭ بِمَا كَانُوا۟ یَفۡسُقُونَ ۝١٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وأَخَذْنا الَّذِينَ ظَلَمُوا بِعَذابٍ بَئِيسٍ﴾</span>، قال: فأصبح الذين نَهَوا عن السوء ذات غَداةٍ في مجالسهم يَتَفَقَّدون الناس، لا يروا منهم، وقد باتوا من ليلتهم وغلقوا عليهم دورهم. قال فجعلوا يقولون: إنّ لِلناس لَشأنًا! فانظروا ما شأنهم. قال: فاطَّلعوا في دورهم، فإذا القوم قد مُسِخوا في دورهم، يعرفون الرجل بعينه، وإنّه لَقِرد، والمرأةَ بعينها، وإنّها لقردة. قال الله تعالى: <span class="qpc-hafs">﴿فَجَعَلْناها نَكالًا لِما بَيْنَ يَدَيْها وما خَلْفَها ومَوْعِظَةً لِلْمُتَّقِينَ﴾</span> [البقرة:٦٦]{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿بِعَذابِ بَئِيِس﴾</span>، قال: لا رحمةَ فيه{17}. (٦/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿بِعَذابِ بَئِيِس﴾</span>، قال: أليمٍ وجيعٍ{18}. (٦/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بِعَذابِ بَئِيِس﴾</span>، قال: أليمٍ شديدٍ{19}. (٦/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿بِعَذابِ بَئِيِس﴾</span>، قال: وجيعٍ{20}. (٦/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَخَذْنا الَّذِينَ ظَلَمُوا﴾</span> يعني: وأصبنا الذين ظلموا <span class="qpc-hafs">﴿بِعَذابٍ﴾</span> يعني: المسخ <span class="qpc-hafs">﴿بَئِيسٍ﴾</span> يعني: شديد؛ <span class="qpc-hafs">﴿بِما كانُوا يَفْسُقُونَ﴾</span> يعني: يعصون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿بعذاب بئيس﴾</span>، قال: بعذاب شديد{22}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>‹بِعَذابٍ بَيْئَسٍ› على وزن «فَيْعَل» قراءة متواترة، قرأ بها أبو بكر عن عاصم بخلف عنه، وقرأ نافع، وأبو جفعر: ‹بِيسٍ› بياء مكسورة، بعدها ياء ساكنة، وقرأ ابن عامر كذلك إلا أنه همز الياء: ‹بِئْسٍ›، وقرأ بقية العشرة بخلف عن أبي بكر عن عاصم: <span class="qpc-hafs">﴿بِعَذابِ بَئِيسٍ﴾</span> على وزن: فَعِيل. انظر: النشر ٢/٢٧٣، والإتحاف ص٢٩١-٢٩٢.أخرجه ابن أبي حاتم ٥/١٦٠١.أخرجه ابن جرير ١٠/٥٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٥٢٥.عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٤٩-.أخرجه ابن جرير ١٠/٥٢١.أخرجه ابن جرير ١٠/٥١٤، ٥١٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٥/١٦٠٢.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٤٩-.تفسير البغوي ٣/٢٩٤.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/٢٤٠، وابن جرير ١٠/٥٢٥، وابن أبي حاتم ٥/١٦٠١.تفسير مقاتل بن سليمان ٢/٧٠-٧١.تفسير البغوي ٣/٢٩٤.أخرجه ابن جرير ١٠/٥٢٠، وابن أبي حاتم ٥/١٦٠٢. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٢٤٢، وابن جرير ١٠/٥٢٨، وابن أبي حاتم ٥/١٦٠٢.تفسير مجاهد ص٣٤٥، وأخرجه ابن جرير ١٠/٥٢٨، وابن أبي حاتم ٥/١٦٠٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/٢٣٩، وابن جرير ١٠/٥٢٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٧٠-٧١.أخرجه ابن جرير ١٠/٥٢٨.
  7,166,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا عَتَوۡا۟ عَن مَّا نُهُوا۟ عَنۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣١٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله تعالى: <span class="qpc-hafs">﴿فلما عتوا عن ما نهوا عنه﴾</span>: أبَوْا أن يرجعوا عن المعصية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- قال: العُتُوُّ في كتاب الله: التَّجَبُّر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا عَتَوْا﴾</span> يعني: عَصَوْا <span class="qpc-hafs">﴿عَنْ ما نُهُوا عَنْهُ﴾</span> من الحيتان{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡنَا لَهُمۡ كُونُوا۟ قِرَدَةً خَـٰسِـِٔینَ ۝١٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿فلما عتوا عن ما، نهوا عنه قلنا لهم كونوا قردة خاسئين﴾</span>: فجعل الله منهم القردة والخنازير. فزعم: أنّ شباب القوم صاروا قِرَدَةً، وأن المشيخة صاروا خنازير{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: إنما كان الذين اعْتَدَوْا في السبت فَجُعِلُوا قِرَدة فَواقًا{5}، ثم هلَكوا، ما كان للمسخِ نسلٌ{6}. (١/٤٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٠<span class="dash">-</span></span> عن <span class="name-2">ماهانَ الحنفيِّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢١<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، قالا: لَمّا مُسِخُوا جَعَل الرجلُ يُشْبِهُ الرجلَ وهو قِرْدٌ، فيُقال: أنت فلانٌ؟ فيُومِئُ إلى يديَه؛ بما كسَبت يدايَ{7}. (٦/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فلما عتوا عن ما نهوا عنه﴾</span> يقول: لَمّا مَرَد القومُ على المعصية <span class="qpc-hafs">﴿قلنا لهم كونوا قردة خاسئين﴾</span> فصاروا قِرَدَةً لها أذناب تَعاوى، بعد ما كانوا رجالًا ونساءً{8}<span class=comment-ref>٢٦٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٦٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٧٥) أنّ الزجّاج نقل عن قومٍ أنّهم قالوا: يجوز أن تكون هذه القردة من نسلهم. و<span class="comment-type-4">علَّق</span> عليه بقوله: «<span class="mustanad">وتعلق هؤلاء بقول النبي</span> ﷺ: «إنّ أُمَّة من الأُمَم فُقِدَت، وما أراها إلا الفأر، إذا قُرِّب لها لبن لم تشرب». <span class="mustanad">وبقوله</span> ﷺ <span class="mustanad">في الضب</span>».</div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- قال: نُودِيَ الذين اعتَدَوا في السَّبتِ ثلاثةَ أصواتٍ؛ نُودُوا: يا أهلَ القريةِ. فانتبَهت طائفةٌ، ثم نُودُوا: يا أهلَ القريةِ. فانتبَهتْ طائفةٌ أكثرُ من الأولى، ثم نُودوا: يا أهلَ القريةِ. فانتبَه الرجالُ والنساءُ والصِّبيانُ، فقال الله لهم: <span class="qpc-hafs">﴿كُونُوا قِرَدَةً خاسِئِينَ﴾</span>. فجعَلَ الذين نَهَوْهم يدخُلون عليهم، فيقولون: يا فلانُ، ألم ننْهَكم؟ فيقولون برءوسِهم؛ أي: بَلى{9}. (٦/٦٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْنا لَهُمْ﴾</span> ليلًا: <span class="qpc-hafs">﴿كُونُوا قِرَدَةً خاسِئِينَ﴾</span> يعني: صاغرين بعد ما أصابوا الحيتان سنين، ثم مُسِخوا قِرَدَةً، فعاشوا سبعة أيام، ثم ماتوا يوم الثامن{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡنَا لَهُمۡ كُونُوا۟ قِرَدَةً خَـٰسِـِٔینَ ۝١٦٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٢٥<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>لا ترتكِبوا ما ارْتَكَبَتِ اليهودُ؛ فتَسْتَحِلُّوا محارمَ الله بأدنى الحِيَلِ</b>»{11}. (٦/٦٤٠)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٣/٢٩٤.أخرجه ابن أبي حاتم ٥/١٦٠٢.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن جرير ١٠/٥٢٩.الفواق: قدر ما بين الحلبتين من الراحة. لسان العرب (فوق).أخرجه ابن أبي حاتم ١/١٣٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٠/٥٢٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٤٩-.أخرجه ابن أبي حاتم ٥/١٦٠٣.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن بطة في إبطال الحيل ص٤٦-٤٧.</p><p>قال ابن تيمية في الفتاوى الكبرى ٤/٢٠: «بإسناد حسن ...». وقال أيضًا في الفتاوى الكبرى ٦/٣٣: «هذا إسناد جيد، يُصَحِّح مثلَه الترمذيُّ وغيره تارةً، ويُحَسِّنه تارةً». وقال ابن القيم في إغاثة اللهفان ١/٣٤٨: «وهذا إسناد جيد، يصحح مثله الترمذي». وقال ابن كثير في تفسيره ١/٢٩٣، ٣/٤٩٣: «وهذا إسناد جيد». وقال الألباني في الإرواء ٥/٣٧٥ (١٥٣٥): «وهذا إسناد رجاله كلهم ثقات معروفون من رجال التهذيب، غير أبى الحسن أحمد بن محمد بن مسلم».
  7,167,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ تَأَذَّنَ رَبُّكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٢٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿تأذن ربك﴾</span>: قال ربُّك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span>، يقول: قال ربُّك{2}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، مثل ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي سعد- <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span>، قال: أمَرَ ربُّك{4}<span class=comment-ref>٢٦٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٦٨</span> ذكر <u>ابنُ عطية</u> (٤/٧٧) قول مجاهد، ثم ذكر قولًا مفاده أنّ معنى: <span class="qpc-hafs">﴿تأذن﴾</span>: تألّى، و<span class="comment-type-1">وجّهه</span> بقوله: «وقادهم إلى هذا القول دخولُ اللام في الجواب». و<span class="comment-type-2">انتَقَدَه</span> <span class="mustanad">لمخالفته ظاهر لفظ الآية</span> بقوله: «وأمّا اللفظةُ فبعيدة عن هذا».</div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span>، يعني: أعْلَمَ ربُّك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣١<span class="dash">-</span></span> عن يحي بن سلّام: في تفسير <span class="name-2">قتادة</span>: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span>، يعني: قال ربك= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٢<span class="dash">-</span></span> وقال <span class="name-2">الحسن</span>: أشعر ربك، قال ربك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٣<span class="dash">-</span></span> قال <span class="name-2">عطاء بن أبي رباح</span>: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span>: حَكَم ربُّك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span>، يعني: قال ربُّك{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَیَبۡعَثَنَّ عَلَیۡهِمۡ إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ مَن یَسُومُهُمۡ سُوۤءَ ٱلۡعَذَابِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span> الآية، قال: الذين يَسُومونهم سوءَ العذاب محمدٌ ﷺ وأمَّتُه إلى يوم القيامة<span class=comment-ref>٢٦٦٩</span>، وسوءُ العذاب الجِزْية{9}. (٦/٦٤١)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٦٩</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٤/٧٧) العمومَ في الآية، فقال <span class="comment-type-4">مُعَلِّقًا</span> على قول ابن عباس: «والصحيحُ أنّها عامَّةٌ في كل مَن حالُ اليهودِ معه هذه الحالُ».</div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك﴾</span> الآية، قال: هم اليهود، بعَث عليهم العرب يَجْبُونهم الخراج، فهو سوءُ العذاب، ولم يكن من نبيٍّ جَبا الخراجَ إلا موسى ﵇، جَباه ثلاثَ عشرة سنة، ثم كفَّ عنه، وإلا النبيّ ﷺ{10}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</span>: فهي المسكنة، وأَخْذُ الجزيةِ منهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</span>، قال: يهود، وما ضرب عليهم من الذِّلَّة والمسكنة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٣٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق عبد الكريم بن مالك الجزري-: أنّه كان يَسْتَحِبُّ أن يبعث الأنباط في الجزية{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- <span class="qpc-hafs">﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</span>، قال: هم أهل الكتاب، بعث الله عليهم العربَ يجبونهم الخراج إلى يوم القيامة، فهو سوء العذاب، ولم يَجْبِ نبيٌّ الخراجَ قطُّ إلا موسى ﷺ ثلاثَ عشرة سنة ثم أمْسَكَ، وإلا النبي ﷺ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ليبعثن عليهم﴾</span> قال: على اليهود والنصارى <span class="qpc-hafs">﴿إلى يوم القيامة من يسومهم سوء العذاب﴾</span> فبعَث الله عليهم أُمَّةَ محمد ﷺ يأخُذون منهم الجزية وهم صاغِرون{15}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿ليبعثن عليهم إلى يوم القيامة من يسومهم﴾</span>، قال: بَعَث عليهم هذا الحيَّ من العرب، فهم في عذاب منهم إلى يوم القيامة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٣<span class="dash">-</span></span> وقال <span class="name-2">عبد الكريم بن مالك الجزري</span>: يستحب أن تبعث الأنباط في الجزية{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٤<span class="dash">-</span></span> عن <span class="name-2">مطر الورّاق</span> -من طريق ابن شوذب- في قول الله: <span class="qpc-hafs">﴿ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</span>، قال: سلَّط الله عليهم العربَ؛ فهم منهم في عَناء إلى يوم القيامة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</span>، يقول: إنّ ربك يبعث على بني إسرائيل العربَ، فيسومونهم سوء العذاب؛ يأخذون منهم الجزية، ويقتلونهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ليبعثن عليهم﴾</span> يعني: بني إسرائيل <span class="qpc-hafs">﴿من يسومهم سوء العذاب﴾</span> فبعث الله المسلمين عليهم إلى يوم القيامة ما دامت الدنيا <span class="qpc-hafs">﴿من يسومهم سوء العذاب﴾</span> يعني: يُعَذِّبهم شِدَّةَ العذاب، يعني: القتل، والجزية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٧<span class="dash">-</span></span> عن <span class="name-3">حسن بن صالح</span> -من طريق أبي غسان- في قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة من يسومهم سوء العذاب﴾</span> في الذين سكتوا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإذ تأذن ربك ليبعثن عليهم إلى يوم القيامة﴾</span>: ليبعثن على يهود{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ لَسَرِیعُ ٱلۡعِقَابِ وَإِنَّهُۥ لَغَفُورࣱ رَّحِیمࣱ ۝١٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٤٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿إن ربك لسريع العقاب﴾</span>، إذا أراد الله أن يُعَذِّب قومًا كان عذابُه إيّاهم أسْرَعَ مِن الطَّرْف{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٤/٢٩٩.تفسير مجاهد ص٣٤٥، وأخرجه ابن جرير ١٠/٥٣٠، ٥٣٣، وابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٥/١٦٠٣.أخرجه ابن جرير ١٠/٥٣٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-.علَّقه يحيى بن سلام ١/١١٩، ١١٨.تفسير البغوي ٣/٢٩٥. وفي تفسير الثعلبي ٤/٢٩٩ بلفظ: حتم.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن جرير ١٠/٥٣٠، وابن أبي حاتم ٥/١٦٠٤. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٥/١٦٠٣، ١٦٠٥. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٥٣٠.أخرجه ابن جرير ١٠/٥٣١.أخرجه عبد الرزاق في تفسيره ٢/٩٥، وابن جرير ١٠/٥٣٢.أخرجه ابن جرير ١٠/٥٣٢، وابن أبي حاتم ٥/١٦٠٤ مختصرًا.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد وابن المنذر، وابن جرير، وأبي الشيخ.أخرجه عبد الرزاق في تفسيره ٢/٩٤ بنحوه، وابن جرير ١٠/٥٣١، وله أيضًا من طريق سعيد. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠- بلفظ فيه: فهم منه في عذاب بالجزية والذل.أخرجه ابن أبي حاتم ٥/١٦٠٤.أخرجه ابن جرير ١٠/٥٣٢.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن أبي حاتم ٥/١٦٠٤.أخرجه ابن جرير ١٠/٥٣٣، وابن أبي حاتم ٥/١٦٠٤ من طريق أصبغ بن الفرج.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-.
  7,168,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَطَّعۡنَـٰهُمۡ فِی ٱلۡأَرۡضِ أُمَمࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرْني عن قول الله: <span class="qpc-hafs">﴿وقطعناهم في الأرض أمما﴾</span>، ما الأُمَم؟ قال: الفِرَق. وقال فيه بشرُ بن أبي خازم:</p><p>مِن قيسِ عَيلانَ في ذوائِبِها منهم وهم بعدُ قادةُ الأمم{1}. (٦/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وقطعناهم﴾</span> الآية، قال: هم اليهود، بسَطهم الله في الأرض؛ فليس في الأرض بقعةٌ إلا وفيها عصابةٌ منهم وطائفة{2}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وقطعناهم في الأرض أمما﴾</span>، قال: يهود{3}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، مثل ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وقطعناهم﴾</span> يعني: وفرَّقناهم في الأرض <span class="qpc-hafs">﴿أمما﴾</span> يعني: فِرَقًا، يعني: بني إسرائيل{5}<span class=comment-ref>٢٦٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٧٠</span> <span class="comment-type-4">ذَكَرَ</span> <u>ابنُ عطية</u> (٤/٧٧) <span class="mustanad">مستندًا لدلالة العقل</span> أنّ الظاهر في المشار إليهم في هذه الآية أنّهم: الذين بعد سليمان وقت زوال ملكهم، وأنّ هذا كان قبل وقت عيسى ﵇؛ لأنّه لم يكن فيهم صالح بعد كفرهم بعيسى.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ جرير</u> (١٠/٥٤٣).</div></p><p><h3><span class="qpc-hafs">﴿مِّنۡهُمُ ٱلصَّـٰلِحُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٥٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥٦<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿منهم الصالحون﴾</span>، يريد الذين أدركوا رسولَ الله ﷺ، وآمنوا به{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قوله: <span class="qpc-hafs">﴿منهم الصالحون﴾</span>، قال: مِن أُمَّة محمد ﷺ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿منهم الصالحون﴾</span>: وهم مُسْلِمَةُ أهل الكتاب{8}. (٦/٦٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡهُمۡ دُونَ ذَ ٰ⁠لِكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٥٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٠<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿ومنهم دون ذلك﴾</span>، يعني: الذين بَقَوْا على الكُفر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قوله: <span class="qpc-hafs">﴿ومنهم دون ذلك﴾</span>، قال: مَن لم يُؤْمِن بمحمد ﷺ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ومنهم دون ذلك﴾</span>، قال: اليهود{8}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿منهم الصالحون﴾</span> يعني: المؤمنين، <span class="qpc-hafs">﴿ومنهم دون ذلك﴾</span> يعني: دون الصالحين؛ فهُمُ الكُفّار{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَلَوۡنَـٰهُم بِٱلۡحَسَنَـٰتِ وَٱلسَّیِّـَٔاتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وبلوناهم بالحسنات والسيئات﴾</span>، قال: بالخِصْب، والجَدْب{13}. (٦/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿والسيئات﴾</span>، قال: البلاء والعقوبة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وبلوناهم بالحسنات﴾</span> قال: الرَّخاء والعافية، <span class="qpc-hafs">﴿والسيئات﴾</span> قال: البلاء والعقوبة{8}. (٦/٦٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر- قال: ابْتُلُوا بالرَّخاء فلم يصبِروا، قال: <span class="qpc-hafs">﴿وقطعناهم في الأرض أمما منهم الصالحون ومنهم دون ذلك وبلوناهم بالحسنات والسيئات لعلهم يرجعون﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وبلوناهم بالحسنات والسيئات﴾</span>، يقول: ابتليناهم بالخِصْب، والشِّدَّة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝١٦٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٦٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- <span class="qpc-hafs">﴿لعلهم يرجعون﴾</span>: لعلهم يتوبون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿لعلهم﴾</span> يعني: لكي <span class="qpc-hafs">﴿يرجعون﴾</span> إلى التوبة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن جرير ١٠/٥٣٣، وابن أبي حاتم ٥/١٦٠٣، ١٦٠٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٤٦، وأخرجه ابن جرير ١٠/٥٣٣، وابن أبي حاتم ٥/١٦٠٣-١٦٠٦، وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٥/١٦٠٥.تفسير مقاتل بن سليمان ٢/٧١.تفسير البغوي ٣/٢٩٥.أخرجه ابن أبي حاتم ٥/١٦٠٤.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير، وأبي الشيخ.تفسير البغوي ٣/٢٩٥.أخرجه ابن أبي حاتم ٥/١٦٠٥.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٧١.عزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٦.أخرجه ابن أبي حاتم ٥/١٦٠٣-١٦٠٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن جرير، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٦.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن أبي حاتم ٥/١٦٠٦.تفسير مقاتل بن سليمان ٢/٧١.
  7,169,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَخَلَفَ مِنۢ بَعۡدِهِمۡ خَلۡفࣱ وَرِثُوا۟ ٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٧١<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق الوليد بن قيس- في هذه الآية: <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span>، قال: الخَلْفُ مِن بعد سِتِّين سنةً{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span>، قال: النصارى{2}<span class=comment-ref>٢٦٧١</span>. (٦/٦٤٢)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٧١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٦/٤٣٠) على قول مجاهد بقوله: «وقد يكون أعمَّ من ذلك».</div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن المهاجر- <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span>، قال: هم هذه الأُمَّة، يَتَرادَفُون{3} في الطُّرُق كما تَرادَفُ الأنعامُ، لا يخافون مَن في السماء، ولا يَسْتَحْيُون مِمَّن في الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span>، يعني: اليهود والنصارى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span> قال: خَلْفُ سَوْءٍ، <span class="qpc-hafs">﴿ورثوا الكتاب﴾</span> بعدَ أنبيائِهم ورُسلِهم، أورَثَهم اللهُ الكتابَ، وعهِد إليهم{6}. (٦/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فخلف من بعدهم خلف ورثوا الكتاب﴾</span>، قال: هم مِن بني إسرائيل، وأشباههم مِن هذه الأمة المُرْجِئَة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> قوله: <span class="qpc-hafs">﴿فخلف من بعدهم﴾</span> يعني: مِن بعد بني إسرائيل <span class="qpc-hafs">﴿خلف﴾</span> [خَلْفُ] السوء، وهم اليهود، <span class="qpc-hafs">﴿ورثوا الكتاب﴾</span> يعني: ورِثُوا التوراة عن أوائلهم وآبائهم{8}<span class=comment-ref>٢٦٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٧٢</span> أفادتِ الآثارُ الاختلافَ في الخلْف الذين ذكر اللهُ في هذه الآية أنّهم خَلَفوا مَن قبلهم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٠/٥٣٥) أنّهم اليهود، وهو قول مقاتل، و<span class="comment-type-2">انتَقَدَ</span> القول بأنّهم النصارى؛ <span class="mustanad">لمخالفته السياق</span>، فقال: «والصوابُ مِن القول في ذلك عندي أن يُقال: إنّ الله -تعالى ذِكْرُه- إنّما وصف أنّه خَلَف القومَ -الذين قصَّ قصصهم في الآيات التي مضت- خَلْف سوءٍ رديء، ولم يذكر لنا أنهم نصارى في كتابه، وقصتهم بقصص اليهود أشبه منها بقصص النصارى. وبعدُ، فإنّ ما قبل ذلك خبرٌ عن بني إسرائيل، وما بعده كذلك؛ فما بينهما بأن يكون خبرًا عنهم أشبه، إذ لم يكن في الآية دليلٌ على صَرْفِ الخبر عنهم إلى غيرهم، ولا جاء بذلك دليلٌ يُوجِبُ صِحَّة القول به».</div></p><p><h3><span class="qpc-hafs">﴿یَأۡخُذُونَ عَرَضَ هَـٰذَا ٱلۡأَدۡنَىٰ وَیَقُولُونَ سَیُغۡفَرُ لَنَا وَإِن یَأۡتِهِمۡ عَرَضࣱ مِّثۡلُهُۥ یَأۡخُذُوهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّه سُئِل عن هذه الآية: <span class="qpc-hafs">﴿فخلف من بعدهم خلف ورثوا الكتاب يأخذون عرض هذا الأدنى﴾</span>. قال: أقوامٌ يُقبِلون على الدنيا، فيأكُلونها، ويَتَّبعونُ رُخَصَ القرآن، <span class="qpc-hafs">﴿ويقولون سيغفر لنا﴾</span>. ولا يَعرِضُ لهم شيءٌ من الدنيا إلا أخَذوه، <span class="qpc-hafs">﴿ويقولون: سيُغفَرُ لنا﴾</span>{9}. (٦/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span> الآية، يقول: يأخُذون ما أصابوا، ويترُكون ما شاءوا؛ مِن حلال أو حرام، <span class="qpc-hafs">﴿ويقولون: سيُغفَرُ لنا﴾</span>{10}. (٦/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق منصور بن المعتمر- في قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى ويقولون سيغفر لنا﴾</span>، قال: كانوا يعملون بالذنوب، ويقولون: سيُغفَرُ لنا{11}. (٦/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق منصور بن المعتمر- في قوله: <span class="qpc-hafs">﴿فَخَلَفَ مِن بَعْدِهِمْ خَلْفٌ ورِثُوا الكِتابَ يَأْخُذُونَ عَرَضَ هَذا الأَدْنى﴾</span> قال: يعملون الذنوب، <span class="qpc-hafs">﴿وإنْ يَأْتِهِمْ عَرَضٌ مِثْلُهُ يَأْخُذُوهُ﴾</span> قال: الذنوب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٢<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق سفيان- <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى﴾</span>، قال: الذنوب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى﴾</span>، قال: ما أشرَف لهم مِن شيءٍ مِن الدنيا حلالًا أو حرامًا يشتهونه أخَذوه، ويتمنَّوْن المغفرة، وإن يجِدوا الغَدَ مثلَه يَأْخُذوه{14}. (٦/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى﴾</span> من الحرام{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى ويقولون سيغفر لنا﴾</span> قال: أمانِيّ تَمَنَّوها على الله، وغِرَّة يغترُّون بها، <span class="qpc-hafs">﴿وإن يأتهم عرض مثله يأخذوه﴾</span> ولا يَشغلُهم شيءٌ عن شيء، ولا ينهاهم شيءٌ عن ذلك، كلمّا أشرَف لهم شيءٌ مِن الدنيا أخَذوه، ولا يُبالون حلالًا كان أو حرامًا{16}. (٦/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى﴾</span> قال: يأخذونه إن كان حلالًا، وإن كان حرامًا. قال: <span class="qpc-hafs">﴿وإن يأتهم عرض مثله﴾</span> قال: إن جاءهم حلالٌ أو حرامٌ أخذوه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فخلف من بعدهم خلف﴾</span> إلى قوله: <span class="qpc-hafs">﴿ودرسوا ما فيه﴾</span>، قال: كانت بنو إسرائيل لا يَسْتَقْضُون قاضيًا إلا ارْتَشى في الحُكْم، وإنّ خيارهم اجتمعوا، فأخذ بعضُهم على بعضٍ العهودَ أن لا يفعلوا ولا يرتشوا، فجعل الرجلُ منهم إذا اسْتُقْضِيَ ارْتَشى، فيُقال له: ما شأنك ترتشي في الحُكْم؟ فيقول: سيغفر لي. فيطعن عليه البَقِيَّةُ الآخرون مِن بني إسرائيل فيما صنع، فإذا مات أو نُزِع وجُعِل مكانَه رجلٌ مِمَّن كان يطعن عليه فيرتشي، يقول: وإن يأتِ الآخرين عَرَضُ الدنيا يأخذوه. وأمّا عرض الأدنى: فعَرَضُ الدنيا من المال{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- في قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى ويقولون سيغفر لنا﴾</span>، قال: يأخُذون ما عرَض لهم من الدنيا، ويقولون: نستغفرُ الله، ونتوبُ إليه{19}. (٦/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى﴾</span> وهي الدنيا؛ لأنها أدنى من الآخرة، يعني: الرشوة في الحكم، <span class="qpc-hafs">﴿ويقولون سيغفر لنا﴾</span> فكانوا يرشون بالنهار، ويقولون: يغفر لنا. بالليل، <span class="qpc-hafs">﴿وإن يأتهم عرض مثله﴾</span> يعني: رشوة مثله ليلًا يأخذوه، ويقولون: يغفر لنا. بالنهار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يأخذون عرض هذا الأدنى﴾</span> قال: الكتاب الذي كتبوه، ويقولون: <span class="qpc-hafs">﴿سيغفر لنا﴾</span>، لا نشرك بالله شيئًا. <span class="qpc-hafs">﴿وإن يأتهم عرض مثله يأخذوه﴾</span>: يأتهم المُحِقُّ برشوة، فيُخْرِجُوا له كتابَ الله، ثم يحكموا له بالرشوة. وكان الظالم إذا جاءهم برشوة أخرجوا له المَثْناةَ{21}، وهو الكتاب الذي كتبوه، فحكموا له بما في المَثْناةِ بالرشوة، فهو فيها مُحِقٌّ، وهو في التوراة ظالم؛ فقال الله: <span class="qpc-hafs">﴿ألم يؤخذ عليهم ميثاق الكتاب أن لا يقولوا على الله إلا الحق ودرسوا ما فيه﴾</span>{22}<span class=comment-ref>٢٦٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٧٣</span> ذكر <u>ابنُ جرير</u> (١٠/٥٣٦) تفسير الآية <span class="mustanad">مستندًا لأقوال السلف</span>، فقال: «فتبدل من بعدهم بدل سوء، ورثوا كتاب الله، فعلموه، وضيعوا العمل به، فخالفوا حُكمَه، يُرشَون في حكم الله، فيأخذون الرِّشوة فيه مِن عَرَض هذا العاجل الأدنى، يعني بـ<span class="qpc-hafs">﴿الأدنى﴾</span>: الأقرب من الآجل الأبعد، ويقولون إذا فعلوا ذلك: إنّ الله سيغفر لنا ذنوبنا. تمنِّيًا على الله الأباطيل، كما قال -جل ثناؤه- فيهم: <span class="qpc-hafs">﴿فويل للذين يكتبون الكتاب بأيديهم ثم يقولون هذا من عند الله ليشتروا به ثمنا قليلا فويل لهم مما كتبت أيديهم وويل لهم مما يكسبون﴾</span> [البقرة:٧٩]، <span class="qpc-hafs">﴿وإن يأتهم عرض مثله يأخذوه﴾</span>. يقول: وإن شرع لهم ذنبٌ حرامٌ مثله من الرشوة بعد ذلك أخذوه واستحلوه، ولم يرتدعوا عنه. يُخْبِر -جلَّ ثناؤه- عنهم أنّهم أهلُ إصرار على ذنوبهم، وليسوا بأهل إنابة ولا توبة». ثم قال بعد ذلك: «وبنحو الذي قلنا في ذلك قال أهل التأويل، وإن اختلفت عنه عباراتهم». وساق آثارَ السلف.</div></p><p><h3><span class="qpc-hafs">﴿أَلَمۡ یُؤۡخَذۡ عَلَیۡهِم مِّیثَـٰقُ ٱلۡكِتَـٰبِ أَن لَّا یَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج-: <span class="qpc-hafs">﴿ألم يؤخذ عليهم ميثاق الكتاب أن لا يقولوا على الله إلا الحق﴾</span> فيما يوجِبون على الله مِن غُفران ذنوبهم التي لا يزالون يَعودُون إليها، ولا يَتوبون منها{23}. (٦/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- في قوله: <span class="qpc-hafs">﴿ألَمْ يُؤْخَذْ عَلَيْهِمْ مِيثاقُ الكِتابِ أنْ لا يَقُولُوا عَلى اللَّهِ إلّا الحَقَّ﴾</span>، قال: هي لأهل الإيمان منهم{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَدَرَسُوا۟ مَا فِیهِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٩٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿ودرسوا ما فيه﴾</span>، قال: علِموا ما فيه{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٩٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿ودرسوا ما فيه﴾</span>، يعني: فأقَرُّوا ما فيه، يعني: مُخَفَّفة{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله: <span class="qpc-hafs">﴿ألم يؤخذ عليهم ميثاق الكتاب﴾</span> يعني: بغير ما يقولون، لقد أخذ عليهم في التوراة أن لا يَسْتَحِلُّوا مُحَرَّمًا، وأن لا يقولوا على الله إلا الحق في التوراة، <span class="qpc-hafs">﴿ودرسوا﴾</span> يعني: وقرءوا <span class="qpc-hafs">﴿ما فيه﴾</span> ما في التوراة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٩٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ودرسوا ما فيه﴾</span>، قال: علِمُوا ما في الكتاب؛ لم يَأتُوه بجهالة{28}. (٦/٦٤٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلدَّارُ ٱلۡـَٔاخِرَةُ خَیۡرࣱ لِّلَّذِینَ یَتَّقُونَۚ أَفَلَا تَعۡقِلُونَ ۝١٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- في قوله: <span class="qpc-hafs">﴿والدار الآخرة خير للذين يتقون أفلا تعقلون﴾</span>، قال: هي لأهل الإيمان منهم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والدار الآخرة﴾</span> يعني: الجنة <span class="qpc-hafs">﴿خير للذين يتقون﴾</span> استحلالَ المحارم، <span class="qpc-hafs">﴿أفلا تعقلون﴾</span>{30}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلدَّارُ ٱلۡـَٔاخِرَةُ خَیۡرࣱ لِّلَّذِینَ یَتَّقُونَۚ أَفَلَا تَعۡقِلُونَ ۝١٦٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٩٣٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: المؤمنُ يعلم أنّ ما قال اللهُ كما قال الله، والمؤمنُ أحسنُ عملًا، وأشدُّ الناسِ خوفًا، لو أنفَق جبلًا مِن مال ما أمِنَ دونَ أن يُعايِنَ، لا يَزْدادُ صلاحًا وبِرًّا وعبادةً إلا ازدادا فَرَقًا، يقول: ألّا أنجُوَ. والمنافق يقول: سواد الناس كثير، وسيُغْفَرُ لي، ولا بَأسَ عَلَيَّ. فيُسِيءُ العمل، ويتمنّى على الله{9}. (٦/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٤٠٠<span class="dash">-</span></span> عن <span class="name-2">أبي الجَلْد جيلان بن فروة</span>، قال: يأتي على الناس زمانٌ تَخْرَبُ صُدورُهم مِن القرآن، وتتهافَتُ وتَبْلى كما تبْلى ثيابُهم، لا يجِدون لهم حلاوةً ولا لذاذةً، إن قصَّروا عما أُمِروا به قالوا: إنّ الله غفورٌ رحيمٌ. وإن عمِلوا بما نُهُوا عنه قالوا: سيُغفَرُ لنا؛ إنّا لا نُشْرِكُ بالله شيئًا. أمرُهم كلُّه طَمَعٌ ليس فيه خوف، لَبِسوا جلودَ الضان على قلوب الذِّئاب، أفضلُهم في نفسه المُدَّهِنُ{32}{9}. (٦/٦٤٤)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٦٠٦.تفسير مجاهد ص٣٤٦، وأخرجه ابن جرير ١٠/٥٣٥، وابن أبي حاتم ٥/١٦٠٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥٠-. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.التَّرادُفُ: كناية عن فعل قبيح. لسان العرب (ردف). وفي القاموس (ردف): تَرادَفا: تناكحا.أخرجه ابن أبي حاتم ٥/١٦٠٦.أخرجه ابن أبي حاتم ٥/١٦٠٧.أخرجه ابن جرير ١٠/٥٣٧، وابن أبي حاتم ٥/١٦٠٧ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٧.تفسير مقاتل بن سليمان ٢/٧١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٥٣٩.أخرجه سعيد بن منصور (٩٦٦ - تفسير)، وعبد الرزاق في تفسيره ٢/٩٥، وابن جرير ١٠/٥٣٧، ٥٣٩، وابن أبي حاتم ٥/١٦٠٨، والبيهقي في شعب الإيمان (٧١٥٨). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٥٣٩.أخرجه ابن أبي حاتم ٥/١٦٠٧.أخرجه ابن جرير ١٠/٥٣٧، وابن أبي حاتم ٥/١٦٠٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥١- بنحوه. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٥/١٦٠٨.أخرجه ابن جرير ١٠/٥٣٨، وابن أبي حاتم ٥/١٦٠٧ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه عبد الرزاق في تفسيره ٢/٩٥، وابن جرير ١٠/٥٣٨.أخرجه ابن جرير ١٠/٥٣٨. وعزاه السيوطي ٦/٦٤٤ لأبي الشيخ بلفظ: كانت بنو إسرائيل لا يستَقْضُون قاضيًا إلا ارتشى في الحكْم، فإذا قيل له، يقول: سيُغفَرُ لي.أخرجه ابن أبي حاتم ٥/١٦٠٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٧١.المَثْناة: هي أنّ أحبار بني إسرائيل بعد موسى ﵇ وضعوا كتابه فيما بينهم على ما أرادوا من غير كتاب الله. النهاية (ثنا).أخرجه ابن جرير ١٠/٥٣٩، وابن أبي حاتم ٥/١٦٠٧.أخرجه ابن جرير ١٠/٥٤٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٨.أخرجه ابن أبي حاتم ٥/١٦٠٩.أخرجه ابن أبي حاتم ٥/١٦٠٩.تفسير مقاتل بن سليمان ٢/٧١.أخرجه ابن جرير ١٠/٥٤١، وابن أبي حاتم ٥/١٦٠٩ من طريق أصبغ بن الفرج.أخرجه ابن أبي حاتم ٥/١٦٠٩.تفسير مقاتل بن سليمان ٢/٧٢.عزاه السيوطي إلى أبي الشيخ.المداهنة: المصانَعة واللِّين، وقيل: إظهار خلاف ما يُضمر. لسان العرب (دهن).عزاه السيوطي إلى أبي الشيخ.
  7,170,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُمَسِّكُونَ بِٱلۡكِتَـٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِیعُ أَجۡرَ ٱلۡمُصۡلِحِینَ ۝١٧٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٩٤٠١<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله</span>: (إنَّ الَّذِينَ اسْتَمْسَكُواْ بِالكِتابِ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُمَسِّكُونَ بِٱلۡكِتَـٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِیعُ أَجۡرَ ٱلۡمُصۡلِحِینَ ۝١٧٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٩٤٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿والذين يمسكون بالكتاب وأقاموا الصلاة إنا لا نضيع أجر المصلحين﴾</span> نَزَلَتْ في ابن سلام وأصحابه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُمَسِّكُونَ بِٱلۡكِتَـٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِیعُ أَجۡرَ ٱلۡمُصۡلِحِینَ ۝١٧٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٩٤٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿والذين يمسكون بالكتاب﴾</span>، قال: مِن اليهود والنصارى{3}. (٦/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٤٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- في قوله: <span class="qpc-hafs">﴿والذين يمسكون بالكتاب﴾</span> قال: هي لأهل الإيمان منهم، <span class="qpc-hafs">﴿إنا لا نضيع أجر المصلحين﴾</span> قال: هي لأهل الإيمان منهم{4}. (٦/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٤٠٥<span class="dash">-</span></span> قال <span class="name-2">عطاء بن أبي رباح</span>: هم أُمَّةُ محمد ﷺ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٤٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ ذَكَر مؤمنيهم، فقال: <span class="qpc-hafs">﴿والذين يمسكون بالكتاب﴾</span>، يعني: يتمسكون بالتوراة، ولا يُحَرِّفونه عن مواضعه، ولا يَسْتَحِلُّون مُحَرَّمًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٤٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والذين يمسكون بالكتاب﴾</span>، قال: الذي جاء به موسى ﵇{7}. (٦/٦٤٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣١٧.</p><p>وهي قراءة شاذة، تروى أيضًا عن الأعمش. انظر: البحر المحيط ٤/٤١٦.تفسير مقاتل بن سليمان ٢/٧٢.تفسير مجاهد ص٣٤٦، وأخرجه ابن جرير ١٠/٥٤٢، وابن أبي حاتم ٥/١٦٠٩ من طريق ابن أبي نجيح. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٥١-. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٦٠٨-١٦١٠. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٤/٣٠١، وتفسير البغوي ٣/٢٩٧.تفسير مقاتل بن سليمان ٢/٧٢.أخرجه ابن جرير١٠/٥٤٢، وابن أبي حاتم ٥/١٦٠٩ من طريق أصبغ بن الفرج.