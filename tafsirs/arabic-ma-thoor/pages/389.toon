quran[7]{c,v,t}:
28,29," <q>﴿فَلَمَّا قَضَىٰ مُوسَى ٱلۡأَجَلَ﴾</q> - تفسير ٥٨٦٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فلما قضى موسى الأجل﴾</q>، قال: عشر سنين، ثم مَكَثَ بعد ذلك عشرًا أخرى{1}٤٩٤٩. (١١/٤٦١) ٤٩٤٩ انتقد ابنُ عطية (٦/٥٨٨) قول مجاهد بقوله: «وهذا ضعيف». وذكر ابنُ كثير (١٠/٤٥٩) أنه لم ير هذا القول لغير مجاهد. ٥٨٦٣١- قال إسماعيل السُّدِّيّ: <q>﴿فلما قضى موسى الأجل﴾</q>، يعني: أتمَّ موسى شرطه{2}. (ز) ٥٨٦٣٢- قال مقاتل بن سليمان: <q>﴿فلما قضى موسى الأجل﴾</q> السنين العشر{3}. (ز) <q>﴿وَسَارَ بِأَهۡلِهِۦۤ﴾</q> - تفسير ٥٨٦٣٣- قال عبد الله بن عباس -من طريق السُّدِّيّ-: لَمّا قضى موسى الأجلَ سار بأهله، فَضَلَّ عن الطريق، وكان في الشتاء، ورُفِعَت له نار، فلمّا رآها ظن أنها نار، وكانت مِن نور الله، فقال لأهله: امكثوا، إني آنست نارًا، لعلِّي آتيكم منها بخبر، فإن لم أجد خبرًا آتيكم بشهاب قبس، لعلكم تصطلون مِن البرد{4}. (١١/٤٦١) ٥٨٦٣٤- قال مقاتل بن سليمان: <q>﴿وسار بأهله﴾</q> ليلة الجمعة{3}. (ز) <q>﴿ءَانَسَ مِن جَانِبِ ٱلطُّورِ نَارࣰاۖ قَالَ لِأَهۡلِهِ ٱمۡكُثُوۤا۟ إِنِّیۤ ءَانَسۡتُ نَارࣰا﴾</q> - تفسير ٥٨٦٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿آنس من جانب الطور نارا﴾</q> قال: أحَسَّ مِن جانب الطور نارًا. وفي قوله: <q>﴿إني آنست نارا﴾</q> قال: أحسستُ نارًا. سار نبيُّ الله ﷺ حين سار وهو شاتٍ{6}. (١١/٤٦١) ٥٨٦٣٦- قال إسماعيل السُّدِّيّ: <q>﴿آنس من جانب الطور نارا﴾</q> رأى مِن جانب الطور نارًا{7}. (ز) ٥٨٦٣٧- قال مقاتل بن سليمان: <q>﴿آنس﴾</q> يعني: رأى <q>﴿من جانب﴾</q> يعني: مِن ناحية <q>﴿الطور﴾</q> يعني: الجبل <q>﴿نارا﴾</q> وهو النور بأرض المقدسة، فـ<q>﴿قال لأهله امكثوا﴾</q> مكانكم، <q>﴿إني آنست نارا﴾</q> يقول: إني رأيت نارًا{3}. (ز) ٥٨٦٣٨- قال يحيى بن سلّام: <q>﴿آنس من جانب الطور﴾</q> والطور: الجبل... أي: رأى نارًا، وإنما كان نورًا، وكانت عند موسى نارًا{9}٤٩٥٠. (ز) ٤٩٥٠ ذكر ابنُ عطية (٦/٥٨٩) أنّ الطُّور جبل معروف في الشام، ثم قال: «والطُّور: كل جبل. وخصَّصه قوم بأنه الذي لا يُنبت». <q>﴿لَّعَلِّیۤ ءَاتِیكُم مِّنۡهَا بِخَبَرٍ﴾</q> - تفسير ٥٨٦٣٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿لعلي آتيكم منها بخبر﴾</q>، قال: لعلي أجد مَن يدلُّني على الطريق، وكانوا قد ضلُّوا الطريقَ، وكانوا شاتين{10}. (١١/٤٦١) ٥٨٦٤٠- قال مقاتل بن سليمان: <q>﴿لعلي آتيكم منها بخبر﴾</q> أين الطريق، وكان قد تحيَّر ليلًا، فإن لم أجد مَن يخبرني، <q>﴿أو جذوة من النار﴾</q>{3}. (ز) ٥٨٦٤١- قال يحيى بن سلّام: <q>﴿لعلي آتيكم منها بخبر﴾</q> الطريق، وكان على غير طريق{12}. (ز) <q>﴿أَوۡ جَذۡوَةࣲ مِّنَ ٱلنَّارِ﴾</q> - قراءات ٥٨٦٤٢- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿أوْ جَذْوَةٍ﴾</q> بنصب الجيم{13}٤٩٥١. (١١/٤٦٢) ٤٩٥١ اختُلِف في قراءة قوله: <q>﴿جذوة﴾</q>؛ فقرأ قوم بكسر الجيم، وقرأ آخرون بفتحها، وقرأ غيرهم بضمها. وذكر ابنُ جرير (١٨/٢٣٩)، وكذا ابنُ عطية (٦/٥٩٠) أنها لغات للعرب. ورجَّح ابنُ جرير قراءة الكسر؛ لأنّها الأشهر، فقال: «وهذه اللغات الثلاث وإن كُنَّ مشهورات في كلام العرب، فالقراءة بأشهرها أعجب إلَيَّ، وإن لم أنكر قراءة مَن قرأ بغير الأشهر منهنَّ». <q>﴿أَوۡ جَذۡوَةࣲ مِّنَ ٱلنَّارِ﴾</q> - تفسير الآية ٥٨٦٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿جذوة﴾</q>، قال: شهاب{14}. (١١/٤٦٢) ٥٨٦٤٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿جذوة﴾</q>، قال: أصل شجرة{15}٤٩٥٢. (١١/٤٦٢) ٤٩٥٢ قال ابنُ عطية (٦/٥٨٩): «وأحسب أنّ أصل الجذوة: أصول الشجر، وأهل البوادي يوقدونها أبدًا، فهي هي الجذوة حقيقة». ٥٨٦٤٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿جذوة﴾</q>، قال: أصل شجرة في طرفها نار{16}. (١١/٤٦٢) ٥٨٦٤٦- قال قتادة بن دعامة: هي العُود الذي قد احترق بعضه{17}. (ز) ٥٨٦٤٧- عن محمد بن السائب الكلبي -من طريق معمر- <q>﴿أو جذوة﴾</q>: أو شُعْلَة مِن نار{18}. (ز) ٥٨٦٤٨- قال مقاتل بن سليمان: <q>﴿أو جذوة﴾</q> يعني: آتيكم بشُعْلَة، وهو عودٌ قد احترق بعضُه <q>﴿من النار﴾</q>{19}. (ز) ٥٨٦٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: الجذوة: عُود مِن حَطَب فيه النار{20}. (١١/٤٦٢) <q>﴿لَعَلَّكُمۡ تَصۡطَلُونَ ۝٢٩﴾</q> - تفسير ٥٨٦٥٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لعلكم تصطلون﴾</q>، قال: مِن البَرْد{21}. (ز) ٥٨٦٥١- قال مقاتل بن سليمان: <q>﴿لعلكم﴾</q> يعني: لكي <q>﴿تصطلون﴾</q> مِن البرد. فترك موسى ﵇ امرأتَه وولدَه في البَرِّيَّة بين مِصر ومدين، ثم استقام، فذهب بالرسالة، فأقامت امرأتُه مكانها ثلاثين سنة في البرية مع ولدها وغنمها، فمرَّ بها راعٍ، فعرفها، وهى حزينةٌ تبكي، فانطلق بها إلى أبيها{3}. (ز) ٥٨٦٥٢- قال يحيى بن سلّام: <q>﴿لعلكم تصطلون﴾</q> لكي تصطلوا. وكان شاتيًا{12}. (ز) <q>﴿لَعَلَّكُمۡ تَصۡطَلُونَ ۝٢٩﴾</q> - آثار متعلقة بالآية ٥٨٦٥٣- عن عائشة -من طريق عروة بن الزبير- قالت: كُن لِما لَمْ ترجُ أرْجى مِنكَ لِما ترجو، فإنّ موسى بن عمران خرج يقتبس نارًا فرجع بالنُّبُوَّة{24}. (١١/٤٦٣) ٥٨٦٥٤- عن أبي المليح، قال: أتيت ميمون بن مهران لأُوَدِّعه عند خروجي في تجارة، فقال: لا تيأس أن تصيب في وجهك هذا في أمر دينك أفضلَ مما ترجو أن تصيب في أمر دنياك، فإنّ صاحبة سبأ خرجت وليس شيءٌ أحبَّ إليها مِن ملكها، فأخرجها الله إلى ما هو خير من ذلك، فهداها إلى الإسلام، وإنّ موسى ﵇ خرج ليقتبس لأهله نارًا، فأخرجه الله إلى ما هو خير من ذلك؛ كلَّمه الله تعالى{25}. (١١/٤٦٣) ",footnotes:1:أخرجه يحيى بن سلّام ٢/٥٨٩، وابن جرير ١٨/٢٣٣٧، وابن أبي حاتم ٩/٢٩٧١، وأخرج نحوه يحيى بن سلّام ٢/٥٨٩ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ٢/٥٨٩.تفسير مقاتل بن سليمان ٣/٣٤٣.أخرجه ابن أبي حاتم ٩/٢٨٤٣، ٢٨٤٩.تفسير مقاتل بن سليمان ٣/٣٤٣.أخرجه ابن أبي حاتم ٩/٢٩٧١-٢٩٧٢، وأخرج ابن جرير ١٨/٢٣٨ الشطر الثاني، كما علق الشطر الأول يحيى بن سلّام ٢/٥٨٩. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ٢/٥٩٠.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٨٩.أخرجه إسحاق البستي في تفسيره ص٤٦، وابن أبي حاتم ٩/٢٩٧٢.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٩٠.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها عاصم، وقرأ حمزة: ‹جُذْوَةٍ› بضم الجيم، وقرأ بقية العشرة: ‹جِذْوَةٍ›بكسرها. انظر: النشر ٢/٣٤١، والإتحاف ص٤٣٥.أخرجه ابن جرير ١٨/٢٣٣٩، وابن أبي حاتم ٩/٢٩٧٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٣٤، وابن أبي حاتم ٩/٢٩٧٢، وإسحاق البستي في تفسيره ص٤٦ من طريق ابن جريج. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٩٠، وابن جرير ١٨/٢٣٤ وزاد: قال: السعف فيه النار. وعلَّقه يحيى بن سلّام ٢/٥٩٠ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٧/٢٤٨، وتفسير البغوي ٦/٢٠٦.أخرجه عبد الرزاق ٢/٩٠، وابن جرير ١٨/٢٣٤٠ مبهمًا بلفظ: قال معمر: وقال غير قتادة.تفسير مقاتل بن سليمان ٣/٣٤٣، ونحوه في تفسير الثعلبي ٧/٢٤٨، وتفسير البغوي ٦/٢٠٦ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٨/٢٥٢، وابن أبي حاتم ٩/٢٩٧٣ من طريق أصبغ.أخرجه ابن أبي حاتم ٩/٢٩٧٣.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٩٠.أخرجه الخطيب ٣/٤٣٤-٤٣٥.أخرجه ابن عساكر ٦٩/٧٧. وعزاه السيوطي إلى أبي عبيد، وابن مردويه.
28,30," <q>﴿فَلَمَّاۤ أَتَىٰهَا نُودِیَ مِن شَـٰطِىِٕ ٱلۡوَادِ ٱلۡأَیۡمَنِ﴾</q> - تفسير ٥٨٦٥٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿نودي من شاطئ الوادي الأيمن﴾</q>، قال: كان النداء مِن السماء الدنيا{1}. (١١/٤٦٣) ٥٨٦٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿من شاطئ الوادي الأيمن﴾</q>، قال: الأيمن عن يمين موسى عند الطور{2}. (١١/٤٦٣) ٥٨٦٥٧- عن أبي صالح باذام -من طريق السُّدِّيّ- في الآية، قال: كان النداء مِن أيمن الشجرة، والنداء من السماء، وذلك في التقديم والتأخير{3}. (١١/٤٦٣) ٥٨٦٥٨- عن قتادة بن دعامة -من طريق سعيد- قال: نُودِي مِن عند الشجرة {4}. (ز) ٥٨٦٥٩- عن قتادة بن دعامة، قال: نودي عن يمين الشجرة{5}. (١١/٤٦٤) ٥٨٦٦٠- عن أبي بكر الثقفي -من طريق أبي سنان- <q>﴿نودي من شاطئ الوادي الأيمن﴾</q>، قال: عن يمين الشجرة{6}. (١١/٤٦٥) ٥٨٦٦١- قال مقاتل بن سليمان: <q>﴿فلما أتاها﴾</q> أتى النار <q>﴿نودي﴾</q> ليلًا <q>﴿من شاطىء﴾</q> يعني: مِن جانب، يعني: مِن الناحية <q>﴿الوادي الأيمن﴾</q> يعني: يمين الجبل{7}. (ز) ٥٨٦٦٢- قال يحيى بن سلّام: <q>﴿فلما أتاها﴾</q> أتى موسى النارَ عند نفسه؛ <q>﴿نودي من شاطئ الوادي الأيمن﴾</q> تفسير ابن مجاهد، عن أبيه: عن يمين موسى، <q>﴿في البقعة المباركة من الشجرة﴾</q> وقال قتادة: نودي عن يمين الشجرة، أي: الأيمن مِن الشجرة{8}٤٩٥٣. (ز) ٤٩٥٣ قال ابنُ عطية (٦/٥٩٠): «قوله: <q>﴿الأَيْمَنِ﴾</q> يحتمل أن يكون من اليُمن صفة للوادي أو للشاطئ، ويحتمل أن يكون معادلًا لليسار فذلك لا يوصف به الشاطئ إلا بالإضافة إلى موسى في استقباله مهبط الوادي، أو يعكس ذلك، وكل ذلك قد قيل». وعلَّق ابنُ تيمية (٥/٧٦) قائلًا: «وإذا كان المنادي هو الله رب العالمين، وقد ناداه مِن موضع معين وقرَّبه إليه؛ دل ذلك على ما قاله السلف مِن قربه ودُنُوِّه من موسى ﵇، مع أن هذا قرب مِمّا دون السماء». <q>﴿فِی ٱلۡبُقۡعَةِ ٱلۡمُبَـٰرَكَةِ مِنَ ٱلشَّجَرَةِ﴾</q> - تفسير ٥٨٦٦٣- قال عطاء: <q>﴿فِيالبُقْعَةِ المُبارَكَةِ﴾</q>، يريد: المقدسة{9}. (ز) ٥٨٦٦٤- قال مقاتل بن سليمان: <q>﴿في البقعة المباركة﴾</q> والمباركة لأنّ الله ﷿ كلَّم موسى ﵇ في تلك البقعة؛ نُودِي{10}. (ز) ٥٨٦٦٥- قال يحيى بن سلّام: وفيهما تقديم: نودي مِن شاطئ الوادي الأيمن مِن الشجرة مِن البقعة المباركة{8}. (ز) <q>﴿مِنَ ٱلشَّجَرَةِ﴾</q> - تفسير ٥٨٦٦٦- عن عبد الله بن مسعود -من طريق أبي عبيدة- قال: رأيتُ الشجرة التي نُودي منها موسى ﵇، شجرة سَمُرةٍ خضراء تَرِفُّ{12}. (ز) ٥٨٦٦٧- عن عبد الله بن عباس: أنها كانت شجرة العناب{13}. (ز) ٥٨٦٦٨- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: شجرة خضراء شديدة الخضرة، يُقال لها: العُلِّيق{14}{15}. (١٠/١٦٣) ٥٨٦٦٩- عن وهب بن منبه -من طريق ابن إسحاق، عن بعض مَن لا يُتَّهم- <q>﴿إني آنست نارا﴾</q>، قال: خرج نحوها، فإذا هي شجرة مِن العُلَّيق. وبعضُ أهل الكتاب يقول: هي عوسجة{16}. (ز) ٥٨٦٧٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿البقعة المباركة من الشجرة﴾</q>، قال: الشجرة: عَوْسَج{4}. (ز) ٥٨٦٧١- عن محمد بن السائب الكلبي -من طريق مَعْمَر- <q>﴿من الشجرة﴾</q>، قال: شجرة العَوْسَج{18}. (١١/٤٦٤) ٥٨٦٧٢- عن عبد الملك ابن جريج، في قوله: <q>﴿من الشجرة﴾</q>، قال: أُخبِرتُ: أنها عوسجة{19}. (١١/٤٦٤) ٥٨٦٧٣- قال مقاتل بن سليمان: <q>﴿من الشجرة﴾</q> وهي عوسجة، وكان حول العوسجة شجر الزيتون{20}. (ز) <q>﴿أَن یَـٰمُوسَىٰۤ إِنِّیۤ أَنَا ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٣٠﴾</q> - تفسير ٥٨٦٧٤- عن نوف البِكالي -من طريق أبي عمران الجوني-: أنّ موسى ﵇ لَمّا نُودِي مِن شاطئ الوادي الأيمن؛ قال: ومَن أنت الذي تنادي؟ قال: أنا ربك الأعلى{21}. (١١/٤٦٤) ٥٨٦٧٥- قال مقاتل بن سليمان:... فنودي: <q>﴿أن يا موسى﴾</q> في التقديم <q>﴿إني أنا الله﴾</q> الذي ناديتُك <q>﴿رب العالمين﴾</q>. هذا كلامه ﷿ لموسى ﵇{10}٤٩٥٤. (ز) ٤٩٥٤ قال ابنُ عطية (٦/٥٩٠): «قوله تعالى: <q>﴿أنْ يا مُوسى﴾</q> يحتمل أن تكون <q>﴿أنْ﴾</q> مفسِّرة، ويحتمل أن تكون في موضع نصب بإسقاط حرف الجر». ٥٨٦٧٦- عن أبي بكر الثقفي -من طريق أبي سنان- قال: أتى موسى الشجرة ليلًا وهي خضراء، والنار تَتَرَدَّد فيها، فذهب يتناول النار، فمالت عنه، فذعر وفزع، فنُودي مِن شاطئ الوادي الأيمن -قال: عن يمين الشجرة-: يا موسى. فاستأنس بالصوت، فقال: أين أنت، أين أنت؟ قِبَل الصوت. أنا فوقك. قال: ربي؟ قال: نعم{6}. (١١/٤٦٥) <q>﴿أَن یَـٰمُوسَىٰۤ إِنِّیۤ أَنَا ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٣٠﴾</q> - آثار متعلقة بالآية ٥٨٦٧٧- عن محمد بن القاسم خادم محمد بن أسلم وصاحبه، قال: سمعتُ محمد بن أسلم يقول: زعمتِ الجهميةُ: أنّ القرآن مخلوقٌ، قد أشركوا في ذلك وهم لا يعلمون؛ لأنّ الله تعالى قد بيَّن أنّ له كلامًا، فقال: <q>﴿يا موسى إني أنا الله رب العالمين﴾</q>. فمَن لم يشهد أنّ هذا كلام الله؛ قوله، تكلَّم به، والله قاله، زعم أنه خلق؛ فقد عظم شركه وافتراؤه على الله؛ لأنّه زعم أنّ خلقًا قال لموسى: <q>﴿يا موسى إني أنا الله رب العالمين﴾</q>. فقد جعل هذا الزّاعِم للعالمين ربًّا غير الله، فأيُّ شِرك أعظم من هذا؟ فتبقى الجهمية في هذه القصة بين كفرين اثنين: إن زعموا أنّ الله لم يكلم موسى فقد ردُّوا كتاب الله وكفروا به. وإن زعموا أن هذا الكلام: <q>﴿يا موسى إني أنا الله رب العالمين﴾</q> خلْقٌ؛ فقد أشركوا بالله. ففي هؤلاء الآيات بيان أنّ القرآن كلام الله تعالى، وفيها بيان شرك مَن زعم أنّ كلام الله خلق، وقول الله خلق، وما أوحى الله إلى أنبيائه خلق{24}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٧٤.أخرجه ابن جرير ١٨/٢٤١، وابن أبي حاتم ٩/٢٩٧٢، وأخرجه يحيى بن سلّام ٢/٥٩٠ من طريق ابن مجاهد. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٤٢.علَّقه يحيى بن سلّام ٢/٥٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٧.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٩٠.تفسير البغوي ٦/٢٠٦.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩٠.أخرجه ابن جرير ١٨/٢٤٣.تفسير البغوي ٥/٢٦٥، ٦/٢٠٦.العلَّيق: نبات معروف، يتعلَّق بالشَّجر ويلتوي عليه، وشَوْكه كثير شديد، وإذا نشب فيه شيء لا يكاد يتخلَّص منه، ولذلك سُمّي العُلَّيق. اللسان (علق).أخرجه أحمد في الزهد ص٦١-٦٦، وابن أبي حاتم ٩/٢٨٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٢٢، ١٨/٢٤٢.أخرجه ابن جرير ١٨/٢٤٢.أخرجه عبد الرزاق ٢/٩١، وابن جرير ١٨/٢٤٢ مبهمًا: قال معمر: وقال غير قتادة. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٣٤٤. وفي تفسير البغوي ٥/٢٦٥، ٦/٢٠٦ بنحوه مختصرًا منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن أبي حاتم ٩/٢٩٧٣.تفسير مقاتل بن سليمان ٣/٣٤٤.أخرجه ابن أبي حاتم ٩/٢٨٤٧.أخرجه أبو نعيم في حلية الأولياء ٩/٢٤٤-٢٤٥.
28,31," <q>﴿وَأَنۡ أَلۡقِ عَصَاكَۚ فَلَمَّا رَءَاهَا تَهۡتَزُّ كَأَنَّهَا جَاۤنࣱّ﴾</q> - تفسير ٥٨٦٧٨- قال مقاتل بن سليمان: <q>﴿وأن ألق عصاك﴾</q> وهي ورق الآس -آس الجنة- مِن يدك، <q>﴿فلما رآها تهتز﴾</q> تَحَرَّك <q>﴿كأنها جآن﴾</q> يقول: كأنّها حية لم تزل{1}. (ز) ٥٨٦٧٩- قال الهذيل بن حبيب، عن غير مقاتل: <q>﴿كأنها جان﴾</q>، يعني: شيطان{1}. (ز) ٥٨٦٨٠- قال يحيى بن سلّام: <q>﴿وأن ألق عصاك﴾</q> فألقاها، <q>﴿فلما رآها تهتز كأنها جان﴾</q> كأنها حية{3}٤٩٥٥. (ز) ٤٩٥٥ ذكر ابنُ عطية (٦/٥٩٠) أن العصا حين ألقاها موسى ﵇ انقلبت حية عظيمة، ولها اضطراب الجانّ، وهو صغير الحيات، فجمعت هول الثعبان ونشاط الجانّ، ثم قال: «وقالت فرقة: بل الجانّ يعم الكبير والصغير، وإنما شبه بالجان جملة العصا لاضطرابها فقط». <q>﴿وَلَّىٰ مُدۡبِرࣰا وَلَمۡ یُعَقِّبۡۚ یَـٰمُوسَىٰۤ أَقۡبِلۡ وَلَا تَخَفۡۖ إِنَّكَ مِنَ ٱلۡـَٔامِنِینَ ۝٣١﴾</q> - تفسير ٥٨٦٨١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولم يعقب﴾</q>، قال: ولم يرجع{4}. (ز) ٥٨٦٨٢- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿ولى مدبرا﴾</q> فارًّا منها، <q>﴿ولم يعقب﴾</q> يقول: ولم يرجع على عَقِبه{5}. (ز) ٥٨٦٨٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولم يعقب﴾</q>، يقول: لم ينتظِر{6}. (ز) ٥٨٦٨٤- قال مقاتل بن سليمان: <q>﴿ولى مدبرا﴾</q> مِن الرَّهَب مِن الحية، يعني: مِن الخوف، فيها تقديم، <q>﴿ولم يعقب﴾</q> يعني: ولم يرجع، قال سبحانه: <q>﴿يا موسى أقبل ولا تخف﴾</q> مِن الحَيَّة، <q>﴿إنك من الآمنين﴾</q> مِن الحيَّة{1}. (ز) ٥٨٦٨٥- عن عبد الملك ابن جريج، في قوله: <q>﴿ولى مدبرا﴾</q>، <q>﴿مِنَ الرَّهْبِ﴾</q> [القصص:٣٢]، قال: هذا مِن تقديم القرآن{8}. (١١/٤٦٥) ٥٨٦٨٦- عن محمد بن إسحاق -من طريق سلمة -: <q>﴿يا موسى أقبل ولا تخف﴾</q> فلما أقبل قال: <q>﴿خذها ولا تخف﴾</q>، أدخِل يدك في فمها. وعلى موسى جُبَّة له مِن صوف، فلفَّ يدَه بكُمِّه، وهو لها هايِب، فنودي: أن ألق كُمَّك عن يديك. فألقاه عنها، ثم أدخل يده بين لحييها، فلما أدخلها قبض عليها، فإذا هي عصاه في يده، ويده بين شعبتيها حيث كان يضعها، ومحجنها فيها بوضعه الذي كان لا يُنكِر منها شيئًا{9}. (ز) ٥٨٦٨٧- قال يحيى بن سلّام: <q>﴿ولى مدبرا﴾</q> هارِبًا منها{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩٠.تفسير مجاهد ص٥٢٨. وعلَّقه يحيى بن سلّام ٢/٥٩١.أخرجه ابن جرير ١٨/٢٤٣-٢٤٤، وابن أبي حاتم ٩/٢٩٧٥. وفي لفظ لابن جرير، وعلقه يحيى بن سلّام ٢/٥٩١: <q>﴿ولم يعقب﴾</q>: أي: لم يلتفت مِن الفَرَق.أخرجه ابن جرير ١٨/٢٤٤، وابن أبي حاتم ٩/٢٨٤٨.تفسير مقاتل بن سليمان ٣/٣٤٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩٧٥.تفسير يحيى بن سلّام ٢/٥٩٠.
28,32," <q>﴿ٱسۡلُكۡ یَدَكَ فِی جَیۡبِكَ﴾</q> - تفسير ٥٨٦٨٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿اسلك يدك في جيبك﴾</q>، قال: في جَيْب قميصك{1}. (١١/٤٦٦) ٥٨٦٨٩- قال مقاتل بن سليمان: <q>﴿اسلك﴾</q> يعني: أدْخِل <q>﴿يدك﴾</q> اليمنى <q>﴿في جيبك﴾</q> فجعلها في جيبه مِن قِبَل الصدر، وهى مدرعة مِن صوف مضربة{2}. (ز) ٥٨٦٩٠- قال يحيى بن سلّام: فقال الله: <q>﴿اسلك يدك﴾</q>، أي: أدْخِل يدَك{3}. (ز) <q>﴿تَخۡرُجۡ بَیۡضَاۤءَ مِنۡ غَیۡرِ سُوۤءࣲ﴾</q> - تفسير ٥٨٦٩١- عن الحسن البصري -من طريق قرة بن خالد- في قوله: <q>﴿اسلك يدك في جيبك تخرج بيضاء من غير سوء﴾</q>، قال: فخرجت كأنها المصباح، فأيقن موسى أنّه لَقِي ربَّه{4}. (ز) ٥٨٦٩٢- عن قتادة بن دعامة، في قوله: <q>﴿تخرج بيضاء من غير سوء﴾</q>، قال: مِن غير بَرَص{5}. (١١/٤٦٦) ٥٨٦٩٣- تفسير إسماعيل السُّدِّيّ: <q>﴿تخرج بيضاء من غير سوء﴾</q>، أي: مِن غير بَرَص{6}. (ز) ٥٨٦٩٤- قال مقاتل بن سليمان: <q>﴿تخرج﴾</q> يدك مِن الجيب <q>﴿بيضاء من غير سوء﴾</q> يعني: مِن غير بَرَص، لها شُعاع كشُعاع الشمس، يغشى البصر{2}. (ز) ٥٨٦٩٥- عن محمد بن إسحاق -من طريق سلمة -: ثم قيل لموسى: <q>﴿وأدخل يدك في جيبك تخرج بيضاء من غير سوء﴾</q>. وكان موسى رجلًا آدم أقنى جَعدًا طوالًا، فأدخل يده في جيبه، ثم أخرجها بيضاء مثل الثلج، ثم ردَّها فخرجت كما كانت على لونه{8}. (ز) <q>﴿وَٱضۡمُمۡ إِلَیۡكَ جَنَاحَكَ﴾</q> - تفسير ٥٨٦٩٦- عن عبد الله بن عباس -من طريق ابن جريج- في قوله: <q>﴿واضمم إليك جناحك﴾</q>، قال: يدك{9}. (١١/٤٦٥) ٥٨٦٩٧- عن مجاهد بن جبر، في قوله: <q>﴿واضمم إليك جناحك﴾</q>، قال: كفَّه تحت عضده{10}. (١١/٤٦٥) ٥٨٦٩٨- عن مجاهد بن جبر -من طريق ليث- <q>﴿واضمم إليك جناحك﴾</q>، قال: وجناحاه: الذراع، والعضد: هو الجناح. والكف: اليد، <q>﴿واضمم يدك إلى جناحك تخرج بيضاء من غير سوء﴾</q> [طه:٢٢]{11}. (ز) ٥٨٦٩٩- قال مقاتل بن سليمان: <q>﴿واضمم إليك جناحك﴾</q> يعني: عضدك مِن يدك <q>﴿من الرهب﴾</q>{2}. (ز) ٥٨٧٠٠- قال يحيى بن سلّام: <q>﴿واضمم إليك جناحك﴾</q>، أي: يدك{3}. (ز) <q>﴿مِنَ ٱلرَّهۡبِۖ﴾</q> - قراءات ٥٨٧٠١- عن عاصم بن أبي النجود أنّه قرأ: ‹مِنَ الرُّهْبِ› مخففة، مرفوعة الراء{14}٤٩٥٦. (١١/٤٦٦) ٤٩٥٦ اختُلِف في قراءة قوله: <q>﴿الرّهب﴾</q>؛ فقرأ قوم: ‹مِنَ الرَّهَبِ› بفتح الراء والهاء. وقرأ آخرون: ‹مِنَ الرُّهْبِ› بضم الراء وتسكين الهاء. ورجَّح ابنُ جرير (١٨/٢٤٦) صحة كلتا القراءتين مستندًا لصحتهما في المعنى، وشهرتهما عند قراء الأمصار، فقال: «والقول في ذلك أنهما قراءتان متفقتا المعنى، مشهورتان في قراء الأمصار؛ فبأيتهما قرأ القارئ فمصيب». <q>﴿مِنَ ٱلرَّهۡبِۖ﴾</q> - تفسير الآية ٥٨٧٠٢- عن عبد الله بن عباس -من طريق عطاء- قال: أمره الله أن يضُمَّ يده إلى صدره، فيذهب عنه ما ناله مِن الخوف عند مُعاينة الحية. وقال: ما مِن خائف بعد موسى إلا إذا وضع يده على صدره زال خوفُه{15}. (ز) ٥٨٧٠٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿من الرهب﴾</q>، قال: مِن الفَرَق{16}. (١١/٤٦٥) ٥٨٧٠٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿واضمم إليك جناحك من الرهب﴾</q>، قال: مِن الرُّعْب{17}. (١١/٤٦٦) ٥٨٧٠٥- عن عبد الملك ابن جريج، في قوله: <q>﴿ولى مدبرا﴾</q>؛ <q>﴿من الرهب﴾</q>، قال: هذا مِن تقديم القرآن{18}. (١١/٤٦٥) ٥٨٧٠٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿من الرهب﴾</q>، قال: مما دخله مِن الفَرَق مِن الحية، والخوف. وقال: ذلك الرهب. وقرأ قول الله: <q>﴿يدعوننا رغبا ورهبا﴾</q> [الأنبياء:٩٠]، قال: خوفًا وطمعًا{19}. (ز) ٥٨٧٠٧- قال يحيى بن سلّام: <q>﴿من الرهب﴾</q> قال قتادة: أي: مِن الرعب. إلى صدرك، فيذهب ما في صدرك من الرعب، وكان قد دخله فزع وفَرَق من آل فرعون، فأذهب الله ذلك{3}٤٩٥٧. (ز) ٤٩٥٧ ذكر ابن كثير (١٠/٤٦٠) هذه الأقوال، ثم قال: «والظاهرُ أنّ المراد أعم من هذا، وهو أنه أُمر ﵇ إذا خاف من شيء أن يضم إليه جناحه من الرهب، وهي يده، فإذا فعل ذلك ذهب عنه ما يجده من الخوف. وربما إذا استعمل أحدٌ ذلك على سبيل الاقتداء فوضع يديه على فؤاده فإنه يزول عنه ما يجد أو يَخاف -إن شاء الله، وبه الثقة-». <q>﴿مِنَ ٱلرَّهۡبِۖ﴾</q> - آثار متعلقة بالآية ٥٨٧٠٨- قال مجاهد بن جبر: كلُّ مَن فزِع فضمَّ جناحيه إليه ذهب عنه الفزع{15}. (ز) <q>﴿فَذَ ٰ⁠نِكَ بُرۡهَـٰنَانِ مِن رَّبِّكَ إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦۤۚ﴾</q> - قراءات ٥٨٧٠٩- عن عبد الله بن كثير، وقيس، أنهما كانا يقرآن: ‹فَذانِّكَ بُرْهانانِ› مثقلة النون{22}. (١١/٤٦٦) ٥٨٧١٠- عن عاصم بن أبي النجود أنه قرأ: <q>﴿فَذانِكَ﴾</q> مخففة{5}. (١١/٤٦٦) <q>﴿فَذَ ٰ⁠نِكَ بُرۡهَـٰنَانِ مِن رَّبِّكَ إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦۤۚ﴾</q> - تفسير الآية ٥٨٧١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فذانك برهانان﴾</q>، قال: العصا، واليد{24}. (١١/٤٦٥) ٥٨٧١٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول الله: <q>﴿فذانك برهانان من ربك﴾</q>: تبيانان مِن ربك{25}. (ز) ٥٨٧١٣- قال يحيى بن سلّام: والبرهان في قول الحسن: الحُجَّة، أي: حُجَّتان مِن ربك{3}. (ز) ٥٨٧١٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فذانك برهانان﴾</q>، قال: آيتان مِن ربك{27}. (١١/٤٦٦) ٥٨٧١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فذانك برهانان من ربك﴾</q>: العصا واليد آيتان{28}. (ز) ٥٨٧١٦- قال مقاتل بن سليمان: <q>﴿فذانك برهانان من ربك﴾</q> يعني: آيتين مِن ربك، يعني: اليد والعصا، <q>﴿إلى فرعون وملئه﴾</q>{2}. (ز) ٥٨٧١٧- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فذانك برهانان من ربك﴾</q>: هذان برهانان{25}. (ز) ٥٨٧١٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فذانك برهانان من ربك﴾</q>، فقرأ: <q>﴿هاتوا برهانكم﴾</q> [الأنبياء:٢٤]: هاتوا على ذلك آيةً نعرفها. وقال: <q>﴿برهانان﴾</q>: آيتان مِن الله{31}. (ز) ٥٨٧١٩- قال يحيى بن سلّام: <q>﴿فذانك برهانان من ربك﴾</q> أي: بيانان من ربك <q>﴿إلى فرعون وملئه﴾</q> أي: وقومه{32}٤٩٥٨. (ز) ٤٩٥٨ قال ابنُ تيمية (٥/٧٧): «والبينة والحجة تتناول آيات الأنبياء التي بعثوا بها، فكل ما دلَّ على نبوة محمد ﷺ فهو برهان». <q>﴿إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٣٢﴾</q> - تفسير ٥٨٧٢٠- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿إنهم كانوا قوما فاسقين﴾</q>: يعني: عاصين{33}. (ز) ٥٨٧٢١- قال مقاتل بن سليمان: <q>﴿إنهم كانوا قوما فاسقين﴾</q>، يعني: عاصين{2}. (ز) ٥٨٧٢٢- قال يحيى بن سلّام: <q>﴿إنهم كانوا قوما فاسقين﴾</q> مشركين{32}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٢٤٤. وعلَّقه يحيى بن سلّام ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩١.أخرجه يحيى بن سلّام ٢/٥٩١، وابن جرير ١٨/٢٤٥، وابن أبي حاتم ٩/٢٨٥٠.عزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ٢/٥٩١.تفسير مقاتل بن سليمان ٣/٣٤٤.أخرجه ابن أبي حاتم ٩/٢٩٧٥.أخرجه ابن جرير ١٨/٢٤٥. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٢٤٥.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩١.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها شعبة عن عاصم، وابن عامر، وحمزة، والكسائي، وخلف العاشر، وقرأ حفص عن عاصم: <q>﴿مِنَ الرَّهْب﴾</q> بفتح الراء وإسكان الهاء، وقرأ بقية العشرة: ‹مِنَ الرَّهَبِ› بفتحهما. انظر: النشر ٢/٣٤١، والإتحاف ص٤٣٦.تفسير البغوي ٦/٢٠٧.أخرجه ابن جرير ١٨/٢٤٥، وابن أبي حاتم ٩/٢٩٧٥. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٤٦، وابن أبي حاتم ٩/٢٩٧٥. وعلَّقه يحيى بن سلّام ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٤٦، وابن أبي حاتم ٩/٢٩٧٦ من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٩١.تفسير البغوي ٦/٢٠٧.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، ورويس، وقرأ بقية العشرة: <q>﴿فَذانِكَ﴾</q> بالتخفيف. انظر: الإتحاف ص٤٣٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٧٦. وعلقه يحيى بن سلّام ٢/٥٩١. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٤٧.تفسير يحيى بن سلّام ٢/٥٩١.أخرجه ابن أبي حاتم ٩/٢٩٧٦ بلفظ: بينتان من ربك. وعلقه يحيى بن سلّام ٢/٥٩١ كلفظ ابن أبي حاتم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٢٤٧. وعلقه يحيى بن سلّام ٢/٥٩٢ بنحوه، وعلقه أيضًا ابن أبي حاتم ٩/٢٩٧٦.تفسير مقاتل بن سليمان ٣/٣٤٤.أخرجه ابن جرير ١٨/٢٤٧.أخرجه ابن جرير ١٨/٢٤٨، وابن أبي حاتم ٩/٢٩٧٦ من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٩٢.أخرجه ابن أبي حاتم ٩/٢٩٧٦.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩٢.
28,33," <q>﴿قَالَ رَبِّ إِنِّی قَتَلۡتُ مِنۡهُمۡ نَفۡسࣰا فَأَخَافُ أَن یَقۡتُلُونِ ۝٣٣﴾</q> - تفسير ٥٨٧٢٣- قال يحيى بن سلّام: <q>﴿قال﴾</q> موسى: <q>﴿رب إني قتلت منهم نفسا﴾</q> يعني: القبطي{1}. (ز) ",footnotes:1:تفسير يحيى بن سلّام ٢/٥٩٢.
28,34," <q>﴿وَأَخِی هَـٰرُونُ هُوَ أَفۡصَحُ مِنِّی لِسَانࣰا فَأَرۡسِلۡهُ مَعِیَ﴾</q> - تفسير ٥٨٧٢٤- عن عبد الله بن عباس -من طريق عكرمة-: حين نُودِي من الشجرة <q>﴿قال رب إني قتلت منهم نفسا فأخاف أن يقتلون* وأخي هارون هو أفصح مني لسانا فأرسله معي ردءا﴾</q>. قال: ونُبِّئ هارون ساعتَئِذٍ حين نُبِّئ موسى ﷺ{1}. (ز) ٥٨٧٢٥- قال يحيى بن سلّام: <q>﴿وأخي هارون هو أفصح مني لسانا﴾</q>، يعني: العُقْدَة التي كانت في لسانه{2}. (ز) <q>﴿رِدۡءࣰا یُصَدِّقُنِیۤۖ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ ۝٣٤﴾</q> - تفسير ٥٨٧٢٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ردءا يصدقني﴾</q>: كي يصدقني{3}. (١١/٤٦٦) ٥٨٧٢٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ردءا﴾</q>، قال: عَوْنًا{4}. (١١/٤٦٥) ٥٨٧٢٨- عن نافع بن أبي نعيم، قال: سألتُ مسلم بن جندب عن قوله: <q>﴿ردءا يصدقني﴾</q>. قال: الردء: الزيادة، أما سمعت قول الشاعر: وأسمر خطِّيًّا كأنّ كعوبه نوى القَصْبِ{5} قد أرْدى ذِراعًا على عشر؟{6}٤٩٥٩. (١١/٤٦٦) ٤٩٥٩ علَّق ابنُ عطية (٦/٥٩٢-٥٩٣) على هذا القول بقوله: «وهذا على ترك الهمز، وأن يكون وزنه: فِعْلًا». ٥٨٧٢٩- في تفسير الحسن: <q>﴿فأرسله معي ردءا﴾</q>، أي: عونًا{7}. (ز) ٥٨٧٣٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فأرسله معي ردءا﴾</q>، قال: عَوْنًا لي{8}. (١١/٤٦٦) ٥٨٧٣١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فأرسله معي ردءا يصدقني﴾</q>، يقول: كيما يصدقني{9}. (ز) ٥٨٧٣٢- قال محمد بن السائب الكلبي: <q>﴿معي ردءا يصدقني﴾</q> كيما يصدقني، ويصدقني يكون معي في الرسالة{10}. (ز) ٥٨٧٣٣- قال مقاتل بن سليمان: <q>﴿وأخي هارون هو أفصح مني لسانا فأرسله معي ردءا﴾</q> يعني: عَوْنًا لكي <q>﴿يصدقني﴾</q>، وهارون يومئذ بمصر لكي يصدقني فرعون، <q>﴿إني أخاف أن يكذبون﴾</q>{11}. (ز) ٥٨٧٣٤- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وأخي هارون هو أفصح مني لسانا، فأرسله معي ردءا يصدقني﴾</q>: أي: يُبِين لهم عَنِّي ما أكلمهم به؛ فإنه يفهم ما لا يفهمون{12}. (ز) ٥٨٧٣٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأرسله معي ردءا يصدقني﴾</q>: لأنّ الاثنين أحرى أن يُصَدَّقا مِن واحد{13}٤٩٦٠. (ز) ٤٩٦٠ اختُلِف في قراءة قوله: <q>﴿يصدقني﴾</q>؛ فقرأ قوم بجزم <q>﴿يصدقني﴾</q>. وقرأ غيرهم بالرفع. وذكر ابنُ جرير (١٨/٢٥١) أنّ من قرأ بالرفع جعله صلة لـ«الردء»، بمعنى: فأرسله معي ردءًا، مِن صفته يصدقني. وأنّ من قرأ بالجزم جعله جوابًا لقوله: <q>﴿فأرسله﴾</q>، بمعنى: فإنك إذا أرسلته صدقني. على وجه الخبر. وبنحوه ابنُ عطية (٦/٥٩٣). وذكر ابنُ عطية أنّ مَن قرأ بالرفع فإنه قد يكون على الحال أيضًا. ورجَّح ابنُ جرير قراءة الرفع مستندًا إلى ظاهر الآية، فقال: «والرفع في ذلك أحبُّ القراءتين إلَيَّ؛ لأنه مسألة من موسى ربه أن يرسل أخاه عونًا له بهذه الصفة». ",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٤٧، وابن أبي حاتم ٩/٢٩٧٧.تفسير يحيى بن سلّام ٢/٥٩٢.أخرجه ابن جرير ١٨/٢٥٠، وابن أبي حاتم ٩/٢٩٧٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٥٠، وابن أبي حاتم ٩/٢٩٧٧. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر. وعلقه يحيى بن سلّام ٢/٥٩٢ من طريق ابن مجاهد بن جبر.في اللسان: القسْب، وقال: القَسْبُ: تَمْرٌ يابسٌ صُلْب النَّوى. اللسان (قسب).أخرجه ابن أبي حاتم ٩/٢٩٧٧ من طريق ابن وهب.علقه يحيى بن سلّام ٢/٥٩٢.أخرجه عبد الرزاق ٢/٩١، وابن جرير ١٨/٢٥٠ من طريق سعيد. وعلَّقه ابن أبي حاتم ٩/٢٩٧٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٢٥٠. وعلَّقه ابن أبي حاتم ٩/٢٩٧٧.علَّقه يحيى بن سلّام ٢/٥٩٢.تفسير مقاتل بن سليمان ٣/٣٤٤. وبعضه في تفسير البغوي ٦/٢٠٨ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٨/٢٤٩، وابن أبي حاتم ٩/٢٩٧٧.أخرجه ابن جرير ١٨/٢٤٩.
28,35," <q>﴿قَالَ سَنَشُدُّ عَضُدَكَ بِأَخِیكَ﴾</q> - تفسير ٥٨٧٣٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿سنشد عضدك بأخيك﴾</q>. قال: العضُد: المعين الناصر. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت قول النابغة: في ذِمَّةٍ مِن أبي قابوس مُنقِذَة للخائفين ومَن ليست له عضد؟{1}. (١١/٤٦٧) ٥٨٧٣٧- قال مقاتل بن سليمان: <q>﴿قال سنشد عضدك بأخيك﴾</q>، يعني: ظهرَك بأخيك هارون{2}. (ز) <q>﴿وَنَجۡعَلُ لَكُمَا سُلۡطَـٰنࣰا﴾</q> - تفسير ٥٨٧٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ونجعل لكما سلطانا﴾</q>، قال: الحُجَّة{3}. (١١/٤٦٥) ٥٨٧٣٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ونجعل لكما سلطانا﴾</q>: والسلطان: الحُجَّة{4}. (ز) ٥٨٧٤٠- قال مقاتل بن سليمان: <q>﴿ونجعل لكما سلطانا﴾</q>، يعني: حُجَّة{2}. (ز) ٥٨٧٤١- قال يحيى بن سلّام: <q>﴿قال﴾</q> الله تعالى: <q>﴿سنشد عضدك بأخيك ونجعل لكما سلطانا﴾</q> حُجَّة، <q>﴿فلا يصلون إليكما بآياتنا أنتما ومن اتبعكما الغالبون﴾</q>{6}. (ز) <q>﴿وَنَجۡعَلُ لَكُمَا سُلۡطَـٰنࣰا فَلَا یَصِلُونَ إِلَیۡكُمَا بِـَٔایَـٰتِنَاۤۚ أَنتُمَا وَمَنِ ٱتَّبَعَكُمَا ٱلۡغَـٰلِبُونَ ۝٣٥﴾</q> - تفسير ٥٨٧٤٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فآتاه الله سُؤْلَه؛ فحل عُقْدَةً من لسانه، [وأوحى] الله إلى هارون، فانطلقا جميعًا إلى فرعون{7}. (ز) ٥٨٧٤٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ونجعل لكما سلطانا﴾</q>: بآياتنا عند أهل الإيمان، ومعذرة عند الناس{8}. (ز) ٥٨٧٤٤- قال مقاتل بن سليمان: <q>﴿ونجعل لكما سلطانا﴾</q> يعني: حجة، <q>﴿بآياتنا﴾</q> يعني: اليد والعصا، فيها تقديم؛ <q>﴿فلا يصلون إليكما﴾</q> بقتل، يعني: فرعون وقومه، لقولهما في طه [٤٥]: <q>﴿إننا نخاف أن يفرط علينا أو أن يطغى﴾</q>، فذلك قوله سبحانه: <q>﴿فلا يصلون إليكما بآياتنا أنتما ومن اتبعكما الغالبون﴾</q>{2}٤٩٦١. (ز) ٤٩٦١ قال ابنُ عطية (٦/٥٩٣): «قوله: <q>﴿بِآياتِنا﴾</q> يحتمل أن تتعلق الباء بقوله: <q>﴿ونَجْعَلُ لَكُما﴾</q>، أو بـ<q>﴿يَصِلُونَ﴾</q>، وتكون باء السبب، ويحتمل أن تتعلق بقوله: <q>﴿الغالِبُونَ﴾</q>، أي: تغلبون بآياتنا». <q>﴿وَنَجۡعَلُ لَكُمَا سُلۡطَـٰنࣰا فَلَا یَصِلُونَ إِلَیۡكُمَا بِـَٔایَـٰتِنَاۤۚ أَنتُمَا وَمَنِ ٱتَّبَعَكُمَا ٱلۡغَـٰلِبُونَ ۝٣٥﴾</q> - آثار متعلقة بالآية ٥٨٧٤٥- عن مجاهد بن جبر -من طريق عبد الله بن مسلم- قال: كان موسى ﵇ قد مُلِئ قلبُه رُعبًا مِن فرعون، فكان إذا رآه قال: اللَّهُمَّ، أدرأُ بك في نحره، وأعوذ بك من شَرِّه. ففرَّغ الله تعالى ما كان في قلب موسى، وجعله في قلب فرعون، فكان إذا رآه بال كما يبول الحمار{8}. (١١/٤٦٧) ٥٨٧٤٦- عن الضحاك بن مُزاحِم -من طريق جويبر- قال: دعاء موسى حين توجَّه إلى فرعون، ودعاء النبيُّ ﵇ يوم حنين، ودعاء كل مكروب:كنت وتكون، وأنت حيٌّ لا تموت، تنام العيون، وتنكدر النجوم، وأنت حيٌّ قيوم، لا تأخذك سنة ولا نوم، يا حي يا قيوم{11}. (١١/٤٦٧) ٥٨٧٤٧- عن عبد الله بن مسلم، عن عبد الله بن عبيد بن عمير، قال: كان يُغلَق دون فرعون ثمانون بابًا، فما يأتي موسى بابًا منها إلا انفَتَح، وكان لا يُكَلِّم أحدًا حتى يقوم بين يديه{12}. (ز) ٥٨٧٤٨- قال يحيى بن سلّام: فانطلق موسى نحو فرعون، وأوحى الله إلى هارون أن يستقبل أخاه، فاستقبله، فأتيا باب فرعون، فقالا للبواب: اذهب، فأخبِر فرعون أنّ بالباب رسولَ رب العالمين. فدخل عليه البوابُ، فقال: إنّ بالباب رجلًا مجنونًا يزعم أنه رسول رب العالمين. فقال له فرعون: أتعرفه؟ قال: لا، ولكن معه هارون. وكان هارون عندهم معروفًا، وكان موسى قد غاب عنهم زمانًا مِن الدهر، قال فرعون: اذهب، فأدخِلْهُ. فدخل عليه، فعرفه. في تفسير الحسن. وقال بعضهم: كأنّه عرف وجهه ولم يثبت مَن هو، فقال: مَن أنت؟ فقال: أنا رسول رب العالمين. فقال: ليس عن هذا أسألك، ولكن مَن أنت، وابن مَن أنت؟ قال: أنا موسى بن عمران. وقد كان ربّاه، وكان في حِجْره حتى صار رجلًا، فقال له فرعون: <q>﴿ألم نربك فينا وليدا ولبثت فينا من عمرك سنين﴾</q> وأنت لا تَدَّعي هذه النبوة، <q>﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</q> [الشعراء:١٨-١٩] بي أنِّي إله. في تفسير الحسن. وبعضهم يقول: مِن الكافرين لنعمتنا، أي: فيما ربَّيناك{6}. (ز) ",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٨٣-. وعزاه السيوطي إلى الطستي في مسائله.تفسير مقاتل بن سليمان ٣/٣٤٥.أخرجه ابن جرير ١٨/٢٥٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٢٥٢. وعلَّقه ابن أبي حاتم ٣/١٠٣٠.تفسير مقاتل بن سليمان ٣/٣٤٥.تفسير يحيى بن سلّام ٢/٥٩٢-٥٩٣.أخرجه ابن أبي حاتم ٩/٢٩٧٥، وهو جزء من حديث الفتون الطويل.أخرجه ابن أبي حاتم ٩/٢٩٧٦.تفسير مقاتل بن سليمان ٣/٣٤٥.أخرجه ابن أبي حاتم ٩/٢٩٧٦.أخرجه البيهقي في الأسماء والصفات (٢١٧).أخرجه ابن أبي حاتم ٩/٢٩٧٨.تفسير يحيى بن سلّام ٢/٥٩٢-٥٩٣.
