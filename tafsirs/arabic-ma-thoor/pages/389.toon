quran[7]{c,v,t}:
  28,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا قَضَىٰ مُوسَى ٱلۡأَجَلَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فلما قضى موسى الأجل﴾</span>، قال: عشر سنين، ثم مَكَثَ بعد ذلك عشرًا أخرى{1}<span class=comment-ref>٤٩٤٩</span>. (١١/٤٦١)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٤٩</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/٥٨٨) قول مجاهد بقوله: «وهذا ضعيف».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٠/٤٥٩) أنه لم ير هذا القول لغير مجاهد.</div></p><p><div></p><p><p><span class="item-no">٥٨٦٣١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فلما قضى موسى الأجل﴾</span>، يعني: أتمَّ موسى شرطه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما قضى موسى الأجل﴾</span> السنين العشر{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَارَ بِأَهۡلِهِۦۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٣٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ-: لَمّا قضى موسى الأجلَ سار بأهله، فَضَلَّ عن الطريق، وكان في الشتاء، ورُفِعَت له نار، فلمّا رآها ظن أنها نار، وكانت مِن نور الله، فقال لأهله: امكثوا، إني آنست نارًا، لعلِّي آتيكم منها بخبر، فإن لم أجد خبرًا آتيكم بشهاب قبس، لعلكم تصطلون مِن البرد{4}. (١١/٤٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وسار بأهله﴾</span> ليلة الجمعة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ءَانَسَ مِن جَانِبِ ٱلطُّورِ نَارࣰاۖ قَالَ لِأَهۡلِهِ ٱمۡكُثُوۤا۟ إِنِّیۤ ءَانَسۡتُ نَارࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿آنس من جانب الطور نارا﴾</span> قال: أحَسَّ مِن جانب الطور نارًا. وفي قوله: <span class="qpc-hafs">﴿إني آنست نارا﴾</span> قال: أحسستُ نارًا. سار نبيُّ الله ﷺ حين سار وهو شاتٍ{6}. (١١/٤٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٣٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿آنس من جانب الطور نارا﴾</span> رأى مِن جانب الطور نارًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿آنس﴾</span> يعني: رأى <span class="qpc-hafs">﴿من جانب﴾</span> يعني: مِن ناحية <span class="qpc-hafs">﴿الطور﴾</span> يعني: الجبل <span class="qpc-hafs">﴿نارا﴾</span> وهو النور بأرض المقدسة، فـ<span class="qpc-hafs">﴿قال لأهله امكثوا﴾</span> مكانكم، <span class="qpc-hafs">﴿إني آنست نارا﴾</span> يقول: إني رأيت نارًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿آنس من جانب الطور﴾</span> والطور: الجبل... أي: رأى نارًا، وإنما كان نورًا، وكانت عند موسى نارًا{9}<span class=comment-ref>٤٩٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٨٩) أنّ الطُّور جبل معروف في الشام، ثم قال: «والطُّور: كل جبل. وخصَّصه قوم بأنه الذي لا يُنبت».</div></p><p><h3><span class="qpc-hafs">﴿لَّعَلِّیۤ ءَاتِیكُم مِّنۡهَا بِخَبَرٍ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿لعلي آتيكم منها بخبر﴾</span>، قال: لعلي أجد مَن يدلُّني على الطريق، وكانوا قد ضلُّوا الطريقَ، وكانوا شاتين{10}. (١١/٤٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلي آتيكم منها بخبر﴾</span> أين الطريق، وكان قد تحيَّر ليلًا، فإن لم أجد مَن يخبرني، <span class="qpc-hafs">﴿أو جذوة من النار﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لعلي آتيكم منها بخبر﴾</span> الطريق، وكان على غير طريق{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ جَذۡوَةࣲ مِّنَ ٱلنَّارِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٤٢<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿أوْ جَذْوَةٍ﴾</span> بنصب الجيم{13}<span class=comment-ref>٤٩٥١</span>. (١١/٤٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥١</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿جذوة﴾</span>؛ <b>فقرأ قوم</b> بكسر الجيم، <b>وقرأ آخرون</b> بفتحها، <b>وقرأ غيرهم</b> بضمها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٨/٢٣٩)، و<span class="comment-type-4">كذا</span> <u>ابنُ عطية</u> (٦/٥٩٠) أنها لغات للعرب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> قراءة الكسر؛ <span class="mustanad">لأنّها الأشهر</span>، فقال: «وهذه اللغات الثلاث وإن كُنَّ مشهورات في كلام العرب، فالقراءة بأشهرها أعجب إلَيَّ، وإن لم أنكر قراءة مَن قرأ بغير الأشهر منهنَّ».</div></p><p><h3><span class="qpc-hafs">﴿أَوۡ جَذۡوَةࣲ مِّنَ ٱلنَّارِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿جذوة﴾</span>، قال: شهاب{14}. (١١/٤٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿جذوة﴾</span>، قال: أصل شجرة{15}<span class=comment-ref>٤٩٥٢</span>. (١١/٤٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٢</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٥٨٩): «وأحسب أنّ أصل الجذوة: أصول الشجر، وأهل البوادي يوقدونها أبدًا، فهي هي الجذوة حقيقة».</div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿جذوة﴾</span>، قال: أصل شجرة في طرفها نار{16}. (١١/٤٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: هي العُود الذي قد احترق بعضه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿أو جذوة﴾</span>: أو شُعْلَة مِن نار{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو جذوة﴾</span> يعني: آتيكم بشُعْلَة، وهو عودٌ قد احترق بعضُه <span class="qpc-hafs">﴿من النار﴾</span>{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: الجذوة: عُود مِن حَطَب فيه النار{20}. (١١/٤٦٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّكُمۡ تَصۡطَلُونَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لعلكم تصطلون﴾</span>، قال: مِن البَرْد{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلكم﴾</span> يعني: لكي <span class="qpc-hafs">﴿تصطلون﴾</span> مِن البرد. فترك موسى ﵇ امرأتَه وولدَه في البَرِّيَّة بين مِصر ومدين، ثم استقام، فذهب بالرسالة، فأقامت امرأتُه مكانها ثلاثين سنة في البرية مع ولدها وغنمها، فمرَّ بها راعٍ، فعرفها، وهى حزينةٌ تبكي، فانطلق بها إلى أبيها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لعلكم تصطلون﴾</span> لكي تصطلوا. وكان شاتيًا{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّكُمۡ تَصۡطَلُونَ ۝٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٥٣<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة بن الزبير- قالت: كُن لِما لَمْ ترجُ أرْجى مِنكَ لِما ترجو، فإنّ موسى بن عمران خرج يقتبس نارًا فرجع بالنُّبُوَّة{24}. (١١/٤٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥٤<span class="dash">-</span></span> عن أبي المليح، قال: أتيت <span class="name-2">ميمون بن مهران</span> لأُوَدِّعه عند خروجي في تجارة، فقال: لا تيأس أن تصيب في وجهك هذا في أمر دينك أفضلَ مما ترجو أن تصيب في أمر دنياك، فإنّ صاحبة سبأ خرجت وليس شيءٌ أحبَّ إليها مِن ملكها، فأخرجها الله إلى ما هو خير من ذلك، فهداها إلى الإسلام، وإنّ موسى ﵇ خرج ليقتبس لأهله نارًا، فأخرجه الله إلى ما هو خير من ذلك؛ كلَّمه الله تعالى{25}. (١١/٤٦٣)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ٢/٥٨٩، وابن جرير ١٨/٢٣٣٧، وابن أبي حاتم ٩/٢٩٧١، وأخرج نحوه يحيى بن سلّام ٢/٥٨٩ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ٢/٥٨٩.تفسير مقاتل بن سليمان ٣/٣٤٣.أخرجه ابن أبي حاتم ٩/٢٨٤٣، ٢٨٤٩.تفسير مقاتل بن سليمان ٣/٣٤٣.أخرجه ابن أبي حاتم ٩/٢٩٧١-٢٩٧٢، وأخرج ابن جرير ١٨/٢٣٨ الشطر الثاني، كما علق الشطر الأول يحيى بن سلّام ٢/٥٨٩. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ٢/٥٩٠.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٨٩.أخرجه إسحاق البستي في تفسيره ص٤٦، وابن أبي حاتم ٩/٢٩٧٢.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٩٠.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها عاصم، وقرأ حمزة: ‹جُذْوَةٍ› بضم الجيم، وقرأ بقية العشرة: ‹جِذْوَةٍ›بكسرها. انظر: النشر ٢/٣٤١، والإتحاف ص٤٣٥.أخرجه ابن جرير ١٨/٢٣٣٩، وابن أبي حاتم ٩/٢٩٧٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٣٤، وابن أبي حاتم ٩/٢٩٧٢، وإسحاق البستي في تفسيره ص٤٦ من طريق ابن جريج. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٩٠، وابن جرير ١٨/٢٣٤ وزاد: قال: السعف فيه النار. وعلَّقه يحيى بن سلّام ٢/٥٩٠ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٧/٢٤٨، وتفسير البغوي ٦/٢٠٦.أخرجه عبد الرزاق ٢/٩٠، وابن جرير ١٨/٢٣٤٠ مبهمًا بلفظ: قال معمر: وقال غير قتادة.تفسير مقاتل بن سليمان ٣/٣٤٣، ونحوه في تفسير الثعلبي ٧/٢٤٨، وتفسير البغوي ٦/٢٠٦ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٨/٢٥٢، وابن أبي حاتم ٩/٢٩٧٣ من طريق أصبغ.أخرجه ابن أبي حاتم ٩/٢٩٧٣.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٩٠.أخرجه الخطيب ٣/٤٣٤-٤٣٥.أخرجه ابن عساكر ٦٩/٧٧. وعزاه السيوطي إلى أبي عبيد، وابن مردويه.
  28,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّاۤ أَتَىٰهَا نُودِیَ مِن شَـٰطِىِٕ ٱلۡوَادِ ٱلۡأَیۡمَنِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿نودي من شاطئ الوادي الأيمن﴾</span>، قال: كان النداء مِن السماء الدنيا{1}. (١١/٤٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿من شاطئ الوادي الأيمن﴾</span>، قال: الأيمن عن يمين موسى عند الطور{2}. (١١/٤٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- في الآية، قال: كان النداء مِن أيمن الشجرة، والنداء من السماء، وذلك في التقديم والتأخير{3}. (١١/٤٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: نُودِي مِن عند الشجرة {4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: نودي عن يمين الشجرة{5}. (١١/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٠<span class="dash">-</span></span> عن أبي بكر الثقفي -من طريق أبي سنان- <span class="qpc-hafs">﴿نودي من شاطئ الوادي الأيمن﴾</span>، قال: عن يمين الشجرة{6}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما أتاها﴾</span> أتى النار <span class="qpc-hafs">﴿نودي﴾</span> ليلًا <span class="qpc-hafs">﴿من شاطىء﴾</span> يعني: مِن جانب، يعني: مِن الناحية <span class="qpc-hafs">﴿الوادي الأيمن﴾</span> يعني: يمين الجبل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فلما أتاها﴾</span> أتى موسى النارَ عند نفسه؛ <span class="qpc-hafs">﴿نودي من شاطئ الوادي الأيمن﴾</span> تفسير ابن مجاهد، عن أبيه: عن يمين موسى، <span class="qpc-hafs">﴿في البقعة المباركة من الشجرة﴾</span> وقال قتادة: نودي عن يمين الشجرة، أي: الأيمن مِن الشجرة{8}<span class=comment-ref>٤٩٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٣</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٥٩٠): «قوله: <span class="qpc-hafs">﴿الأَيْمَنِ﴾</span> يحتمل أن يكون من اليُمن صفة للوادي أو للشاطئ، ويحتمل أن يكون معادلًا لليسار فذلك لا يوصف به الشاطئ إلا بالإضافة إلى موسى في استقباله مهبط الوادي، أو يعكس ذلك، وكل ذلك قد قيل».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٥/٧٦) قائلًا: «وإذا كان المنادي هو الله رب العالمين، وقد ناداه مِن موضع معين وقرَّبه إليه؛ دل ذلك على ما قاله السلف مِن قربه ودُنُوِّه من موسى ﵇، مع أن هذا قرب مِمّا دون السماء».</div></p><p><h3><span class="qpc-hafs">﴿فِی ٱلۡبُقۡعَةِ ٱلۡمُبَـٰرَكَةِ مِنَ ٱلشَّجَرَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٦٣<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿فِيالبُقْعَةِ المُبارَكَةِ﴾</span>، يريد: المقدسة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿في البقعة المباركة﴾</span> والمباركة لأنّ الله ﷿ كلَّم موسى ﵇ في تلك البقعة؛ نُودِي{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وفيهما تقديم: نودي مِن شاطئ الوادي الأيمن مِن الشجرة مِن البقعة المباركة{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِنَ ٱلشَّجَرَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عبيدة- قال: رأيتُ الشجرة التي نُودي منها موسى ﵇، شجرة سَمُرةٍ خضراء تَرِفُّ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنها كانت شجرة العناب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: شجرة خضراء شديدة الخضرة، يُقال لها: العُلِّيق{14}{15}. (١٠/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٦٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق ابن إسحاق، عن بعض مَن لا يُتَّهم- <span class="qpc-hafs">﴿إني آنست نارا﴾</span>، قال: خرج نحوها، فإذا هي شجرة مِن العُلَّيق. وبعضُ أهل الكتاب يقول: هي عوسجة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿البقعة المباركة من الشجرة﴾</span>، قال: الشجرة: عَوْسَج{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿من الشجرة﴾</span>، قال: شجرة العَوْسَج{18}. (١١/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿من الشجرة﴾</span>، قال: أُخبِرتُ: أنها عوسجة{19}. (١١/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من الشجرة﴾</span> وهي عوسجة، وكان حول العوسجة شجر الزيتون{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن یَـٰمُوسَىٰۤ إِنِّیۤ أَنَا ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٧٤<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالي</span> -من طريق أبي عمران الجوني-: أنّ موسى ﵇ لَمّا نُودِي مِن شاطئ الوادي الأيمن؛ قال: ومَن أنت الذي تنادي؟ قال: أنا ربك الأعلى{21}. (١١/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>:... فنودي: <span class="qpc-hafs">﴿أن يا موسى﴾</span> في التقديم <span class="qpc-hafs">﴿إني أنا الله﴾</span> الذي ناديتُك <span class="qpc-hafs">﴿رب العالمين﴾</span>. هذا كلامه ﷿ لموسى ﵇{10}<span class=comment-ref>٤٩٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٥٩٠): «قوله تعالى: <span class="qpc-hafs">﴿أنْ يا مُوسى﴾</span> <b>يحتمل</b> أن تكون <span class="qpc-hafs">﴿أنْ﴾</span> مفسِّرة، و<b>يحتمل</b> أن تكون في موضع نصب بإسقاط حرف الجر».</div></p><p><div></p><p><p><span class="item-no">٥٨٦٧٦<span class="dash">-</span></span> عن أبي بكر الثقفي -من طريق أبي سنان- قال: أتى موسى الشجرة ليلًا وهي خضراء، والنار تَتَرَدَّد فيها، فذهب يتناول النار، فمالت عنه، فذعر وفزع، فنُودي مِن شاطئ الوادي الأيمن -قال: عن يمين الشجرة-: يا موسى. فاستأنس بالصوت، فقال: أين أنت، أين أنت؟ قِبَل الصوت. أنا فوقك. قال: ربي؟ قال: نعم{6}. (١١/٤٦٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن یَـٰمُوسَىٰۤ إِنِّیۤ أَنَا ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٧٧<span class="dash">-</span></span> عن محمد بن القاسم خادم محمد بن أسلم وصاحبه، قال: سمعتُ محمد بن أسلم يقول: زعمتِ الجهميةُ: أنّ القرآن مخلوقٌ، قد أشركوا في ذلك وهم لا يعلمون؛ لأنّ الله تعالى قد بيَّن أنّ له كلامًا، فقال: <span class="qpc-hafs">﴿يا موسى إني أنا الله رب العالمين﴾</span>. فمَن لم يشهد أنّ هذا كلام الله؛ قوله، تكلَّم به، والله قاله، زعم أنه خلق؛ فقد عظم شركه وافتراؤه على الله؛ لأنّه زعم أنّ خلقًا قال لموسى: <span class="qpc-hafs">﴿يا موسى إني أنا الله رب العالمين﴾</span>. فقد جعل هذا الزّاعِم للعالمين ربًّا غير الله، فأيُّ شِرك أعظم من هذا؟ فتبقى الجهمية في هذه القصة بين كفرين اثنين: إن زعموا أنّ الله لم يكلم موسى فقد ردُّوا كتاب الله وكفروا به. وإن زعموا أن هذا الكلام: <span class="qpc-hafs">﴿يا موسى إني أنا الله رب العالمين﴾</span> خلْقٌ؛ فقد أشركوا بالله. ففي هؤلاء الآيات بيان أنّ القرآن كلام الله تعالى، وفيها بيان شرك مَن زعم أنّ كلام الله خلق، وقول الله خلق، وما أوحى الله إلى أنبيائه خلق{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩٧٤.أخرجه ابن جرير ١٨/٢٤١، وابن أبي حاتم ٩/٢٩٧٢، وأخرجه يحيى بن سلّام ٢/٥٩٠ من طريق ابن مجاهد. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٤٢.علَّقه يحيى بن سلّام ٢/٥٩٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٧.تفسير مقاتل بن سليمان ٣/٣٤٣.تفسير يحيى بن سلّام ٢/٥٩٠.تفسير البغوي ٦/٢٠٦.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩٠.أخرجه ابن جرير ١٨/٢٤٣.تفسير البغوي ٥/٢٦٥، ٦/٢٠٦.العلَّيق: نبات معروف، يتعلَّق بالشَّجر ويلتوي عليه، وشَوْكه كثير شديد، وإذا نشب فيه شيء لا يكاد يتخلَّص منه، ولذلك سُمّي العُلَّيق. اللسان (علق).أخرجه أحمد في الزهد ص٦١-٦٦، وابن أبي حاتم ٩/٢٨٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٢٢، ١٨/٢٤٢.أخرجه ابن جرير ١٨/٢٤٢.أخرجه عبد الرزاق ٢/٩١، وابن جرير ١٨/٢٤٢ مبهمًا: قال معمر: وقال غير قتادة. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٣٤٤. وفي تفسير البغوي ٥/٢٦٥، ٦/٢٠٦ بنحوه مختصرًا منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن أبي حاتم ٩/٢٩٧٣.تفسير مقاتل بن سليمان ٣/٣٤٤.أخرجه ابن أبي حاتم ٩/٢٨٤٧.أخرجه أبو نعيم في حلية الأولياء ٩/٢٤٤-٢٤٥.
  28,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنۡ أَلۡقِ عَصَاكَۚ فَلَمَّا رَءَاهَا تَهۡتَزُّ كَأَنَّهَا جَاۤنࣱّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأن ألق عصاك﴾</span> وهي ورق الآس -آس الجنة- مِن يدك، <span class="qpc-hafs">﴿فلما رآها تهتز﴾</span> تَحَرَّك <span class="qpc-hafs">﴿كأنها جآن﴾</span> يقول: كأنّها حية لم تزل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٧٩<span class="dash">-</span></span> قال الهذيل بن حبيب، عن غير مقاتل: <span class="qpc-hafs">﴿كأنها جان﴾</span>، يعني: شيطان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأن ألق عصاك﴾</span> فألقاها، <span class="qpc-hafs">﴿فلما رآها تهتز كأنها جان﴾</span> كأنها حية{3}<span class=comment-ref>٤٩٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٩٠) أن العصا حين ألقاها موسى ﵇ انقلبت حية عظيمة، ولها اضطراب الجانّ، وهو صغير الحيات، فجمعت هول الثعبان ونشاط الجانّ، ثم قال: «وقالت فرقة: بل الجانّ يعم الكبير والصغير، وإنما شبه بالجان جملة العصا لاضطرابها فقط».</div></p><p><h3><span class="qpc-hafs">﴿وَلَّىٰ مُدۡبِرࣰا وَلَمۡ یُعَقِّبۡۚ یَـٰمُوسَىٰۤ أَقۡبِلۡ وَلَا تَخَفۡۖ إِنَّكَ مِنَ ٱلۡـَٔامِنِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولم يعقب﴾</span>، قال: ولم يرجع{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿ولى مدبرا﴾</span> فارًّا منها، <span class="qpc-hafs">﴿ولم يعقب﴾</span> يقول: ولم يرجع على عَقِبه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولم يعقب﴾</span>، يقول: لم ينتظِر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولى مدبرا﴾</span> مِن الرَّهَب مِن الحية، يعني: مِن الخوف، فيها تقديم، <span class="qpc-hafs">﴿ولم يعقب﴾</span> يعني: ولم يرجع، قال سبحانه: <span class="qpc-hafs">﴿يا موسى أقبل ولا تخف﴾</span> مِن الحَيَّة، <span class="qpc-hafs">﴿إنك من الآمنين﴾</span> مِن الحيَّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿ولى مدبرا﴾</span>، <span class="qpc-hafs">﴿مِنَ الرَّهْبِ﴾</span> [القصص:٣٢]، قال: هذا مِن تقديم القرآن{8}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة -: <span class="qpc-hafs">﴿يا موسى أقبل ولا تخف﴾</span> فلما أقبل قال: <span class="qpc-hafs">﴿خذها ولا تخف﴾</span>، أدخِل يدك في فمها. وعلى موسى جُبَّة له مِن صوف، فلفَّ يدَه بكُمِّه، وهو لها هايِب، فنودي: أن ألق كُمَّك عن يديك. فألقاه عنها، ثم أدخل يده بين لحييها، فلما أدخلها قبض عليها، فإذا هي عصاه في يده، ويده بين شعبتيها حيث كان يضعها، ومحجنها فيها بوضعه الذي كان لا يُنكِر منها شيئًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولى مدبرا﴾</span> هارِبًا منها{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩٠.تفسير مجاهد ص٥٢٨. وعلَّقه يحيى بن سلّام ٢/٥٩١.أخرجه ابن جرير ١٨/٢٤٣-٢٤٤، وابن أبي حاتم ٩/٢٩٧٥. وفي لفظ لابن جرير، وعلقه يحيى بن سلّام ٢/٥٩١: <span class="qpc-hafs">﴿ولم يعقب﴾</span>: أي: لم يلتفت مِن الفَرَق.أخرجه ابن جرير ١٨/٢٤٤، وابن أبي حاتم ٩/٢٨٤٨.تفسير مقاتل بن سليمان ٣/٣٤٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩٧٥.تفسير يحيى بن سلّام ٢/٥٩٠.
  28,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱسۡلُكۡ یَدَكَ فِی جَیۡبِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿اسلك يدك في جيبك﴾</span>، قال: في جَيْب قميصك{1}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اسلك﴾</span> يعني: أدْخِل <span class="qpc-hafs">﴿يدك﴾</span> اليمنى <span class="qpc-hafs">﴿في جيبك﴾</span> فجعلها في جيبه مِن قِبَل الصدر، وهى مدرعة مِن صوف مضربة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: فقال الله: <span class="qpc-hafs">﴿اسلك يدك﴾</span>، أي: أدْخِل يدَك{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَخۡرُجۡ بَیۡضَاۤءَ مِنۡ غَیۡرِ سُوۤءࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قرة بن خالد- في قوله: <span class="qpc-hafs">﴿اسلك يدك في جيبك تخرج بيضاء من غير سوء﴾</span>، قال: فخرجت كأنها المصباح، فأيقن موسى أنّه لَقِي ربَّه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿تخرج بيضاء من غير سوء﴾</span>، قال: مِن غير بَرَص{5}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿تخرج بيضاء من غير سوء﴾</span>، أي: مِن غير بَرَص{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تخرج﴾</span> يدك مِن الجيب <span class="qpc-hafs">﴿بيضاء من غير سوء﴾</span> يعني: مِن غير بَرَص، لها شُعاع كشُعاع الشمس، يغشى البصر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة -: ثم قيل لموسى: <span class="qpc-hafs">﴿وأدخل يدك في جيبك تخرج بيضاء من غير سوء﴾</span>. وكان موسى رجلًا آدم أقنى جَعدًا طوالًا، فأدخل يده في جيبه، ثم أخرجها بيضاء مثل الثلج، ثم ردَّها فخرجت كما كانت على لونه{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱضۡمُمۡ إِلَیۡكَ جَنَاحَكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٦٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿واضمم إليك جناحك﴾</span>، قال: يدك{9}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿واضمم إليك جناحك﴾</span>، قال: كفَّه تحت عضده{10}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿واضمم إليك جناحك﴾</span>، قال: وجناحاه: الذراع، والعضد: هو الجناح. والكف: اليد، <span class="qpc-hafs">﴿واضمم يدك إلى جناحك تخرج بيضاء من غير سوء﴾</span> [طه:٢٢]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٦٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واضمم إليك جناحك﴾</span> يعني: عضدك مِن يدك <span class="qpc-hafs">﴿من الرهب﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿واضمم إليك جناحك﴾</span>، أي: يدك{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِنَ ٱلرَّهۡبِۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٠١<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: ‹مِنَ الرُّهْبِ› مخففة، مرفوعة الراء{14}<span class=comment-ref>٤٩٥٦</span>. (١١/٤٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٦</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿الرّهب﴾</span>؛ <b>فقرأ قوم</b>: ‹مِنَ الرَّهَبِ› بفتح الراء والهاء. <b>وقرأ آخرون</b>: ‹مِنَ الرُّهْبِ› بضم الراء وتسكين الهاء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٨/٢٤٦) صحة كلتا القراءتين <span class="mustanad">مستندًا لصحتهما في المعنى، وشهرتهما عند قراء الأمصار</span>، فقال: «والقول في ذلك أنهما قراءتان متفقتا المعنى، مشهورتان في قراء الأمصار؛ فبأيتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿مِنَ ٱلرَّهۡبِۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: أمره الله أن يضُمَّ يده إلى صدره، فيذهب عنه ما ناله مِن الخوف عند مُعاينة الحية. وقال: ما مِن خائف بعد موسى إلا إذا وضع يده على صدره زال خوفُه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿من الرهب﴾</span>، قال: مِن الفَرَق{16}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿واضمم إليك جناحك من الرهب﴾</span>، قال: مِن الرُّعْب{17}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿ولى مدبرا﴾</span>؛ <span class="qpc-hafs">﴿من الرهب﴾</span>، قال: هذا مِن تقديم القرآن{18}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٠٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿من الرهب﴾</span>، قال: مما دخله مِن الفَرَق مِن الحية، والخوف. وقال: ذلك الرهب. وقرأ قول الله: <span class="qpc-hafs">﴿يدعوننا رغبا ورهبا﴾</span> [الأنبياء:٩٠]، قال: خوفًا وطمعًا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿من الرهب﴾</span> قال <span class="name-2">قتادة</span>: أي: مِن الرعب. إلى صدرك، فيذهب ما في صدرك من الرعب، وكان قد دخله فزع وفَرَق من آل فرعون، فأذهب الله ذلك{3}<span class=comment-ref>٤٩٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٧</span> <span class="comment-type-4">ذكر</span> <u>ابن كثير</u> (١٠/٤٦٠) هذه الأقوال، ثم قال: «والظاهرُ أنّ المراد أعم من هذا، وهو أنه أُمر ﵇ إذا خاف من شيء أن يضم إليه جناحه من الرهب، وهي يده، فإذا فعل ذلك ذهب عنه ما يجده من الخوف. وربما إذا استعمل أحدٌ ذلك على سبيل الاقتداء فوضع يديه على فؤاده فإنه يزول عنه ما يجد أو يَخاف -إن شاء الله، وبه الثقة-».</div></p><p><h3><span class="qpc-hafs">﴿مِنَ ٱلرَّهۡبِۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٠٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: كلُّ مَن فزِع فضمَّ جناحيه إليه ذهب عنه الفزع{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَذَ ٰ⁠نِكَ بُرۡهَـٰنَانِ مِن رَّبِّكَ إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦۤۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٠٩<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن كثير</span>، وقيس، أنهما كانا يقرآن: ‹فَذانِّكَ بُرْهانانِ› مثقلة النون{22}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٠<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿فَذانِكَ﴾</span> مخففة{5}. (١١/٤٦٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَذَ ٰ⁠نِكَ بُرۡهَـٰنَانِ مِن رَّبِّكَ إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦۤۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٧١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فذانك برهانان﴾</span>، قال: العصا، واليد{24}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿فذانك برهانان من ربك﴾</span>: تبيانان مِن ربك{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: والبرهان في قول <span class="name-2">الحسن</span>: الحُجَّة، أي: حُجَّتان مِن ربك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فذانك برهانان﴾</span>، قال: آيتان مِن ربك{27}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فذانك برهانان من ربك﴾</span>: العصا واليد آيتان{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فذانك برهانان من ربك﴾</span> يعني: آيتين مِن ربك، يعني: اليد والعصا، <span class="qpc-hafs">﴿إلى فرعون وملئه﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فذانك برهانان من ربك﴾</span>: هذان برهانان{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فذانك برهانان من ربك﴾</span>، فقرأ: <span class="qpc-hafs">﴿هاتوا برهانكم﴾</span> [الأنبياء:٢٤]: هاتوا على ذلك آيةً نعرفها. وقال: <span class="qpc-hafs">﴿برهانان﴾</span>: آيتان مِن الله{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فذانك برهانان من ربك﴾</span> أي: بيانان من ربك <span class="qpc-hafs">﴿إلى فرعون وملئه﴾</span> أي: وقومه{32}<span class=comment-ref>٤٩٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٨</span> قال <u>ابنُ تيمية</u> (٥/٧٧): «والبينة والحجة تتناول آيات الأنبياء التي بعثوا بها، فكل ما دلَّ على نبوة محمد ﷺ فهو برهان».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿إنهم كانوا قوما فاسقين﴾</span>: يعني: عاصين{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنهم كانوا قوما فاسقين﴾</span>، يعني: عاصين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنهم كانوا قوما فاسقين﴾</span> مشركين{32}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٢٤٤. وعلَّقه يحيى بن سلّام ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩١.أخرجه يحيى بن سلّام ٢/٥٩١، وابن جرير ١٨/٢٤٥، وابن أبي حاتم ٩/٢٨٥٠.عزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ٢/٥٩١.تفسير مقاتل بن سليمان ٣/٣٤٤.أخرجه ابن أبي حاتم ٩/٢٩٧٥.أخرجه ابن جرير ١٨/٢٤٥. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٢٤٥.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩١.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها شعبة عن عاصم، وابن عامر، وحمزة، والكسائي، وخلف العاشر، وقرأ حفص عن عاصم: <span class="qpc-hafs">﴿مِنَ الرَّهْب﴾</span> بفتح الراء وإسكان الهاء، وقرأ بقية العشرة: ‹مِنَ الرَّهَبِ› بفتحهما. انظر: النشر ٢/٣٤١، والإتحاف ص٤٣٦.تفسير البغوي ٦/٢٠٧.أخرجه ابن جرير ١٨/٢٤٥، وابن أبي حاتم ٩/٢٩٧٥. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٤٦، وابن أبي حاتم ٩/٢٩٧٥. وعلَّقه يحيى بن سلّام ٢/٥٩١. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٤٦، وابن أبي حاتم ٩/٢٩٧٦ من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٩١.تفسير البغوي ٦/٢٠٧.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، ورويس، وقرأ بقية العشرة: <span class="qpc-hafs">﴿فَذانِكَ﴾</span> بالتخفيف. انظر: الإتحاف ص٤٣٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٩٧٦. وعلقه يحيى بن سلّام ٢/٥٩١. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٢٤٧.تفسير يحيى بن سلّام ٢/٥٩١.أخرجه ابن أبي حاتم ٩/٢٩٧٦ بلفظ: بينتان من ربك. وعلقه يحيى بن سلّام ٢/٥٩١ كلفظ ابن أبي حاتم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٢٤٧. وعلقه يحيى بن سلّام ٢/٥٩٢ بنحوه، وعلقه أيضًا ابن أبي حاتم ٩/٢٩٧٦.تفسير مقاتل بن سليمان ٣/٣٤٤.أخرجه ابن جرير ١٨/٢٤٧.أخرجه ابن جرير ١٨/٢٤٨، وابن أبي حاتم ٩/٢٩٧٦ من طريق أصبغ.تفسير يحيى بن سلّام ٢/٥٩٢.أخرجه ابن أبي حاتم ٩/٢٩٧٦.تفسير مقاتل بن سليمان ٣/٣٤٤.تفسير يحيى بن سلّام ٢/٥٩٢.
  28,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ إِنِّی قَتَلۡتُ مِنۡهُمۡ نَفۡسࣰا فَأَخَافُ أَن یَقۡتُلُونِ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿رب إني قتلت منهم نفسا﴾</span> يعني: القبطي{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ٢/٥٩٢.
  28,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَخِی هَـٰرُونُ هُوَ أَفۡصَحُ مِنِّی لِسَانࣰا فَأَرۡسِلۡهُ مَعِیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة-: حين نُودِي من الشجرة <span class="qpc-hafs">﴿قال رب إني قتلت منهم نفسا فأخاف أن يقتلون* وأخي هارون هو أفصح مني لسانا فأرسله معي ردءا﴾</span>. قال: ونُبِّئ هارون ساعتَئِذٍ حين نُبِّئ موسى ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأخي هارون هو أفصح مني لسانا﴾</span>، يعني: العُقْدَة التي كانت في لسانه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رِدۡءࣰا یُصَدِّقُنِیۤۖ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ردءا يصدقني﴾</span>: كي يصدقني{3}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ردءا﴾</span>، قال: عَوْنًا{4}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٢٨<span class="dash">-</span></span> عن نافع بن أبي نعيم، قال: سألتُ <span class="name-2">مسلم بن جندب</span> عن قوله: <span class="qpc-hafs">﴿ردءا يصدقني﴾</span>. قال: الردء: الزيادة، أما سمعت قول الشاعر:</p><p>وأسمر خطِّيًّا كأنّ كعوبه نوى القَصْبِ{5} قد أرْدى ذِراعًا على عشر؟{6}<span class=comment-ref>٤٩٥٩</span>. (١١/٤٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٥٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥٩٢-٥٩٣) على هذا القول بقوله: «وهذا على ترك الهمز، وأن يكون وزنه: فِعْلًا».</div></p><p><div></p><p><p><span class="item-no">٥٨٧٢٩<span class="dash">-</span></span> في تفسير <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿فأرسله معي ردءا﴾</span>، أي: عونًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فأرسله معي ردءا﴾</span>، قال: عَوْنًا لي{8}. (١١/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فأرسله معي ردءا يصدقني﴾</span>، يقول: كيما يصدقني{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿معي ردءا يصدقني﴾</span> كيما يصدقني، ويصدقني يكون معي في الرسالة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأخي هارون هو أفصح مني لسانا فأرسله معي ردءا﴾</span> يعني: عَوْنًا لكي <span class="qpc-hafs">﴿يصدقني﴾</span>، وهارون يومئذ بمصر لكي يصدقني فرعون، <span class="qpc-hafs">﴿إني أخاف أن يكذبون﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وأخي هارون هو أفصح مني لسانا، فأرسله معي ردءا يصدقني﴾</span>: أي: يُبِين لهم عَنِّي ما أكلمهم به؛ فإنه يفهم ما لا يفهمون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأرسله معي ردءا يصدقني﴾</span>: لأنّ الاثنين أحرى أن يُصَدَّقا مِن واحد{13}<span class=comment-ref>٤٩٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٦٠</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿يصدقني﴾</span>؛ <b>فقرأ قوم</b> بجزم <span class="qpc-hafs">﴿يصدقني﴾</span>. <b>وقرأ غيرهم</b> بالرفع.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٨/٢٥١) أنّ من قرأ بالرفع جعله صلة لـ«الردء»، بمعنى: فأرسله معي ردءًا، مِن صفته يصدقني. وأنّ من قرأ بالجزم جعله جوابًا لقوله: <span class="qpc-hafs">﴿فأرسله﴾</span>، بمعنى: فإنك إذا أرسلته صدقني. على وجه الخبر.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/٥٩٣). و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أنّ مَن قرأ بالرفع فإنه قد يكون على الحال أيضًا.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> قراءة الرفع <span class="mustanad">مستندًا إلى ظاهر الآية</span>، فقال: «والرفع في ذلك أحبُّ القراءتين إلَيَّ؛ لأنه مسألة من موسى ربه أن يرسل أخاه عونًا له بهذه الصفة».</div></p></div>",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٤٧، وابن أبي حاتم ٩/٢٩٧٧.تفسير يحيى بن سلّام ٢/٥٩٢.أخرجه ابن جرير ١٨/٢٥٠، وابن أبي حاتم ٩/٢٩٧٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٥٠، وابن أبي حاتم ٩/٢٩٧٧. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر. وعلقه يحيى بن سلّام ٢/٥٩٢ من طريق ابن مجاهد بن جبر.في اللسان: القسْب، وقال: القَسْبُ: تَمْرٌ يابسٌ صُلْب النَّوى. اللسان (قسب).أخرجه ابن أبي حاتم ٩/٢٩٧٧ من طريق ابن وهب.علقه يحيى بن سلّام ٢/٥٩٢.أخرجه عبد الرزاق ٢/٩١، وابن جرير ١٨/٢٥٠ من طريق سعيد. وعلَّقه ابن أبي حاتم ٩/٢٩٧٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٢٥٠. وعلَّقه ابن أبي حاتم ٩/٢٩٧٧.علَّقه يحيى بن سلّام ٢/٥٩٢.تفسير مقاتل بن سليمان ٣/٣٤٤. وبعضه في تفسير البغوي ٦/٢٠٨ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٨/٢٤٩، وابن أبي حاتم ٩/٢٩٧٧.أخرجه ابن جرير ١٨/٢٤٩.
  28,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ سَنَشُدُّ عَضُدَكَ بِأَخِیكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿سنشد عضدك بأخيك﴾</span>. قال: العضُد: المعين الناصر. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت قول النابغة:</p><p>في ذِمَّةٍ مِن أبي قابوس مُنقِذَة للخائفين ومَن ليست له عضد؟{1}. (١١/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال سنشد عضدك بأخيك﴾</span>، يعني: ظهرَك بأخيك هارون{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَنَجۡعَلُ لَكُمَا سُلۡطَـٰنࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ونجعل لكما سلطانا﴾</span>، قال: الحُجَّة{3}. (١١/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ونجعل لكما سلطانا﴾</span>: والسلطان: الحُجَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونجعل لكما سلطانا﴾</span>، يعني: حُجَّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> الله تعالى: <span class="qpc-hafs">﴿سنشد عضدك بأخيك ونجعل لكما سلطانا﴾</span> حُجَّة، <span class="qpc-hafs">﴿فلا يصلون إليكما بآياتنا أنتما ومن اتبعكما الغالبون﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَنَجۡعَلُ لَكُمَا سُلۡطَـٰنࣰا فَلَا یَصِلُونَ إِلَیۡكُمَا بِـَٔایَـٰتِنَاۤۚ أَنتُمَا وَمَنِ ٱتَّبَعَكُمَا ٱلۡغَـٰلِبُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فآتاه الله سُؤْلَه؛ فحل عُقْدَةً من لسانه، [وأوحى] الله إلى هارون، فانطلقا جميعًا إلى فرعون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ونجعل لكما سلطانا﴾</span>: بآياتنا عند أهل الإيمان، ومعذرة عند الناس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونجعل لكما سلطانا﴾</span> يعني: حجة، <span class="qpc-hafs">﴿بآياتنا﴾</span> يعني: اليد والعصا، فيها تقديم؛ <span class="qpc-hafs">﴿فلا يصلون إليكما﴾</span> بقتل، يعني: فرعون وقومه، لقولهما في طه [٤٥]: <span class="qpc-hafs">﴿إننا نخاف أن يفرط علينا أو أن يطغى﴾</span>، فذلك قوله سبحانه: <span class="qpc-hafs">﴿فلا يصلون إليكما بآياتنا أنتما ومن اتبعكما الغالبون﴾</span>{2}<span class=comment-ref>٤٩٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٦١</span> قال <u>ابنُ عطية</u> (٦/٥٩٣): «قوله: <span class="qpc-hafs">﴿بِآياتِنا﴾</span> يحتمل أن تتعلق الباء بقوله: <span class="qpc-hafs">﴿ونَجْعَلُ لَكُما﴾</span>، أو بـ<span class="qpc-hafs">﴿يَصِلُونَ﴾</span>، وتكون باء السبب، ويحتمل أن تتعلق بقوله: <span class="qpc-hafs">﴿الغالِبُونَ﴾</span>، أي: تغلبون بآياتنا».</div></p><p><h3><span class="qpc-hafs">﴿وَنَجۡعَلُ لَكُمَا سُلۡطَـٰنࣰا فَلَا یَصِلُونَ إِلَیۡكُمَا بِـَٔایَـٰتِنَاۤۚ أَنتُمَا وَمَنِ ٱتَّبَعَكُمَا ٱلۡغَـٰلِبُونَ ۝٣٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٨٧٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الله بن مسلم- قال: كان موسى ﵇ قد مُلِئ قلبُه رُعبًا مِن فرعون، فكان إذا رآه قال: اللَّهُمَّ، أدرأُ بك في نحره، وأعوذ بك من شَرِّه. ففرَّغ الله تعالى ما كان في قلب موسى، وجعله في قلب فرعون، فكان إذا رآه بال كما يبول الحمار{8}. (١١/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جويبر- قال: دعاء موسى حين توجَّه إلى فرعون، ودعاء النبيُّ ﵇ يوم حنين، ودعاء كل مكروب:كنت وتكون، وأنت حيٌّ لا تموت، تنام العيون، وتنكدر النجوم، وأنت حيٌّ قيوم، لا تأخذك سنة ولا نوم، يا حي يا قيوم{11}. (١١/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤٧<span class="dash">-</span></span> عن عبد الله بن مسلم، عن <span class="name-2">عبد الله بن عبيد بن عمير</span>، قال: كان يُغلَق دون فرعون ثمانون بابًا، فما يأتي موسى بابًا منها إلا انفَتَح، وكان لا يُكَلِّم أحدًا حتى يقوم بين يديه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٨٧٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: فانطلق موسى نحو فرعون، وأوحى الله إلى هارون أن يستقبل أخاه، فاستقبله، فأتيا باب فرعون، فقالا للبواب: اذهب، فأخبِر فرعون أنّ بالباب رسولَ رب العالمين. فدخل عليه البوابُ، فقال: إنّ بالباب رجلًا مجنونًا يزعم أنه رسول رب العالمين. فقال له فرعون: أتعرفه؟ قال: لا، ولكن معه هارون. وكان هارون عندهم معروفًا، وكان موسى قد غاب عنهم زمانًا مِن الدهر، قال فرعون: اذهب، فأدخِلْهُ. فدخل عليه، فعرفه. في تفسير <span class="name-2">الحسن</span>. وقال بعضهم: كأنّه عرف وجهه ولم يثبت مَن هو، فقال: مَن أنت؟ فقال: أنا رسول رب العالمين. فقال: ليس عن هذا أسألك، ولكن مَن أنت، وابن مَن أنت؟ قال: أنا موسى بن عمران. وقد كان ربّاه، وكان في حِجْره حتى صار رجلًا، فقال له فرعون: <span class="qpc-hafs">﴿ألم نربك فينا وليدا ولبثت فينا من عمرك سنين﴾</span> وأنت لا تَدَّعي هذه النبوة، <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</span> [الشعراء:١٨-١٩] بي أنِّي إله. في تفسير <span class="name-2">الحسن</span>. وبعضهم يقول: مِن الكافرين لنعمتنا، أي: فيما ربَّيناك{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٨٣-. وعزاه السيوطي إلى الطستي في مسائله.تفسير مقاتل بن سليمان ٣/٣٤٥.أخرجه ابن جرير ١٨/٢٥٢. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٢٥٢. وعلَّقه ابن أبي حاتم ٣/١٠٣٠.تفسير مقاتل بن سليمان ٣/٣٤٥.تفسير يحيى بن سلّام ٢/٥٩٢-٥٩٣.أخرجه ابن أبي حاتم ٩/٢٩٧٥، وهو جزء من حديث الفتون الطويل.أخرجه ابن أبي حاتم ٩/٢٩٧٦.تفسير مقاتل بن سليمان ٣/٣٤٥.أخرجه ابن أبي حاتم ٩/٢٩٧٦.أخرجه البيهقي في الأسماء والصفات (٢١٧).أخرجه ابن أبي حاتم ٩/٢٩٧٨.تفسير يحيى بن سلّام ٢/٥٩٢-٥٩٣.