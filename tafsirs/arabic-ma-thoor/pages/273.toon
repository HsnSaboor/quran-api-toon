quran[10]{c,v,t}:
  16,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِیَكۡفُرُوا۟ بِمَاۤ ءَاتَیۡنَـٰهُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٩٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ليكفروا بما آتيناهم﴾</span>، يعني: لئلا يكفروا بما آتيناهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِيَكْفُرُوا بِما آتَيْناهُمْ﴾</span>، يعني: لئلا يكفروا بالذي أعطيناهم من الخير والخِصب في كشف الضر عنهم، وهو الجوع{2}<span class=comment-ref>٣٦٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٠</span> ذكر <u>ابنُ عطية</u> (٥/٣٧٠) في قوله: <span class="qpc-hafs">﴿ليكفروا﴾</span> احتمالين، فقال: «وقوله: <span class="qpc-hafs">﴿لِيَكْفُرُوا﴾</span> <b>يجوز</b> أن يكون اللام لام الصيرورة، أي: فصار أمرهم ليكفروا، وهم لم يقصدوا بأفعالهم تلك أن يكفروا. <b>ويجوز</b> أن تكون لام أمر على معنى التهديد والوعيد، <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span> [فصلت:٤٠]، والكفر هنا يحتمل أن يكون كفر الجحد بالله والشرك، <span class="mustanad">ويؤيده قوله</span>: <span class="qpc-hafs">﴿بِرَبِّهِمْ يُشْرِكُونَ﴾</span>، ويحتمل أن يكون كفر النعمة». و<span class="comment-type-3">رجّح</span> القول الثاني <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وهو الأظهر؛ لقوله: <span class="qpc-hafs">﴿بِما آتَيْناهُمْ﴾</span>، أي: بما أنعمنا عليهم».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (٨/٣١٨) على الاحتمال بأنّ اللام لام التعليل، فقال: «وقيل: لام التعليل، بمعنى: قيضنا لهم ذلك ليكفروا، أي: يستروا ويجحدوا نعم الله عليهم، وأنه المسدي إليهم النعم، الكاشف عنهم النقم».</div></p><p><h3><span class="qpc-hafs">﴿فَتَمَتَّعُوا۟ فَسَوۡفَ تَعۡلَمُونَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فتمتَّعُوا فسوف تعلمون﴾</span>، قال: وعيد{3}. (٩/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَمَتَّعُوا﴾</span> إلى آجالكم قليلًا، <span class="qpc-hafs">﴿فَسَوْفَ تَعْلَمُونَ﴾</span>، هذا وعيد. نظيرها في الروم، وإبراهيم، والعنكبوت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فتمتعوا﴾</span> في الدنيا، <span class="qpc-hafs">﴿فسوف تعلمون﴾</span>، وهذا وعيد{5}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٦٨.|2:تفسير مقاتل بن سليمان ٢/٤٧٣.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٧٣. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿لِيَكْفُرُوا بِما آتَيْناهُمْ فَتَمَتَّعُوا فَسَوْفَ تَعْلَمُونَ﴾</span> [الروم:٣٤]، وقوله تعالى: <span class="qpc-hafs">﴿وجَعَلُوا لِلَّهِ أنْدادًا لِيُضِلُّوا عَنْ سَبِيلِهِ قُلْ تَمَتَّعُوا فَإنَّ مَصِيرَكُمْ إلى النّارِ﴾</span> [إبراهيم:٣٠]، وقوله تعالى: <span class="qpc-hafs">﴿لِيَكْفُرُوا بِما آتَيْناهُمْ ولِيَتَمَتَّعُوا فَسَوْفَ يَعْلَمُونَ﴾</span> [العنكبوت:٦٦].|5:تفسير يحيى بن سلام ١/٦٩.
  16,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَجۡعَلُونَ لِمَا لَا یَعۡلَمُونَ نَصِیبࣰا مِّمَّا رَزَقۡنَـٰهُمۡۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ويجعلون لما لا يعلمون نصيبًا مما رزقناهم﴾</span>، قال: يعلَمون أنّ الله خلَقهم ويَضُرُّهم وينفعُهم، ثم يجعَلون لما لا يعلَمون أنه يَضُرُّهم ولا ينفعُهم نصيبًا مما رزَقْناهم{1}. (٩/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويجعلون لما لا يعلمون نصيبًا مما رزقناهم﴾</span>، قال: هم مُشْرِكو العرب، جعلوا لأوثانِهم وشياطينهم نصيبًا مما رزَقهم الله، وجزَّؤوا مِن أموالهم جُزءًا، فجعَلوه لأوثانهم وشياطينهم{2}. (٩/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ويجعلون لما لا يعلمون نصيبًا مما رزقناهم﴾</span>: هذا قولُهم: <span class="qpc-hafs">﴿هذا لله بزعمهم وهذا لِشُركائنا﴾</span> [الأنعام:١٣٦]{3}. (٩/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَجْعَلُونَ﴾</span> يعني: ويَصِفُون <span class="qpc-hafs">﴿لِما لا يَعْلَمُونَ﴾</span> من الآلهة أنها آلهة <span class="qpc-hafs">﴿نَصِيبًا مِمّا رَزَقْناهُمْ﴾</span> من الحرث والأنعام{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ويجعلون لما لا يعلمون نصيبا مما رزقناهم﴾</span>، قال: جعلوا لآلهتهم التي ليس لها نصيب ولا شيء؛ جعلوا لها نصيبًا مما قال الله من الحرث والأنعام؛ يُسَمُّون عليها أسماءها، ويذبحون لها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ويجعلون لما لا يعلمون نصيبا مما رزقناهم﴾</span>، يعني: آلهتهم، أي: يجعلون لما لا يعلمون أنه خلق مع الله شيئًا، ولا أمات، ولا أحيا، ولا رزق معه شيئًا نصيبا مما رزقناهم، يعني: قوله: <span class="qpc-hafs">﴿وجعلوا لله مما ذرأ من الحرث والأنعام نصيبا فقالوا هذا لله بزعمهم وهذا لشركائنا﴾</span> [الأنعام:١٣٦]{6}<span class=comment-ref>٣٦٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨١</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٥/٣٧١): «وقوله: <span class="qpc-hafs">﴿لِما لا يَعْلَمُونَ﴾</span> <b>يريد</b> الأصنام، ومعناه: لا يعلمون فيهم حجة ولا برهانًا، <b>ويحتمل</b> أن يريد بقوله: <span class="qpc-hafs">﴿يَعْلَمُونَ﴾</span> الأصنام، أي: يجعلون لجمادات لا تعلم شيئا نَصِيبًا، فالمفعول محذوف، ثم عبر عنهم بعبارة من يعقل بحسب مذهب الكفار الذين يسندون إليها ما يُسند إلى من يعقل، وبحسب أنه إسناد منفي، وهذا الاحتمال كله <span class="comment-type-2">ضعيف</span>».</div></p><p><h3><span class="qpc-hafs">﴿تَٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تاللَّهِ﴾</span> قل لهم يا محمد: والله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿تالله﴾</span> قسم. أقسم بنفسه{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَتُسۡـَٔلُنَّ عَمَّا كُنتُمۡ تَفۡتَرُونَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَتُسْألُنَّ﴾</span> في الآخرة <span class="qpc-hafs">﴿عَمّا كُنْتُمْ تَفْتَرُونَ﴾</span> حين زعمتم أنّ الله أمركم بتحريم الحرث والأنعام{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لتسألن عما كنتم تفترون﴾</span> [أن] الأوثان تقربهم إلى الله. يقوله لهم لِما يقولون: إنّ الأوثان تقربهم إلى الله، وإنّ الله أمرهم بعبادتها{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٥٣.|2:أخرجه يحيى بن سلام ١/٦٩ مختصرًا من طريق سعيد، وابن جرير ١٤/٢٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٧٣.|5:أخرجه ابن جرير ١٤/٢٥٣.|6:تفسير يحيى بن سلام ١/٦٩.|7:تفسير مقاتل بن سليمان ٢/٤٧٣.|8:تفسير يحيى بن سلام ١/٦٩.|9:تفسير مقاتل بن سليمان ٢/٤٧٣.|10:تفسير يحيى بن سلام ١/٦٩.
  16,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَجۡعَلُونَ لِلَّهِ ٱلۡبَنَـٰتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ويجعلون لله البنات﴾</span> الآيات، يقول: تجعَلون له البنات، تَرْضَونَهنَّ لي، ولا تَرْضَونَهن لأنفسِكم! وذلك أنهم كانوا في الجاهلية إذا وُلِد للرجل منهم جاريةٌ أمسَكها على هوانٍ، أو دَسَّها في التراب وهي حَيَّةٌ{1}. (٩/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٠٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ويجعلون لله البنات﴾</span>، يعني: ويَصِفون لله البنات{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: يعنيهم: <span class="qpc-hafs">﴿ويَجْعَلُونَ﴾</span> يعني: ويصفون <span class="qpc-hafs">﴿لِلَّهِ البَناتِ﴾</span> حين زعموا أنّ الملائكة بنات الله تعالى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: كان مشركو العرب يقولون: إنّ الملائكة بنات الله{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سُبْحانَهُ﴾</span> نزَّه نفسّه عن قولهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿سبحانه﴾</span> يُنَزِّه نفسه عن ما قالوا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَهُم مَّا یَشۡتَهُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤١٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿ولهم ما يشتهون﴾</span>، قال: يعني به: البنين{7}. (٩/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَهُمْ ما يَشْتَهُونَ﴾</span> من البنين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولهم ما يشتهون﴾</span>، أي: ويجعلون لأنفسهم ما يشتهون؛ الغلمان{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٥٥-٢٥٦. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|2:علَّقه يحيى بن سلام ١/٦٩.|3:تفسير مقاتل بن سليمان ٢/٤٧٤.|4:تفسير يحيى بن سلام ١/٦٩.|5:تفسير مقاتل بن سليمان ٢/٤٧٤.|6:تفسير يحيى بن سلام ١/٦٩.|7:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٢/٤٧٤.|9:تفسير يحيى بن سلام ١/٦٩.
  16,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا بُشِّرَ أَحَدُهُم بِٱلۡأُنثَىٰ ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإذا بُشر أحدهم بالأنثى ظل وجهه مسودًا وهو كظيم﴾</span>، قال: هذا صنيعُ مُشْرِكي العرب، أخبرهم الله بخُبثِ صنيعِهم، فأما المؤمن فهو حقيقٌ أن يَرضى بما قسَم الله له، وقضاءُ الله خيرٌ مِن قضاءِ المرء لنفسه، ولَعَمْرِي ما يَدْرِي أنه خير، لَرُبَّ جارية خيرٌ لأهلِها مِن غلام، وإنما أخبرَكم اللهُ بصنيعِهم لتَجْتَنِبوه، ولتَنْتَهوا عنه، فكان أحدُهم يَغْذُو كلبَه، ويَئِدُ ابنتَه{1}. (٩/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال سبحانه: <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُمْ بِالأُنْثى﴾</span>، فقيل له: وُلِدت لك ابنة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإذا بشر أحدهم بالأنثى﴾</span> التي جعلها لله، زعم، حيث جعلوا لله البنات، يعنون: الملائكة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٢٠<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ظل وجهه مسودا﴾</span>، أي: أقام وجهه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ظَلَّ وجْهُهُ مُسْوَدًّا﴾</span>، يعني: متغيرًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿مسودا﴾</span> ومغيرًا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ كَظِیمࣱ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وهو كظيم﴾</span>، قال: حزين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك بن مزاحم- أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿وهو كظيم﴾</span>، ما الكظيم؟ قال: الساكِت. قال: وهل كانت العرب تعرف ذلك؟ قال: نعم، أما سمعت بقول زهير بن جذيمة العبسي:</p><p>فإن تك كاظمًا بمصاب شاسٍ فإني اليوم منطلق لساني{8}؟ (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٢٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿وهو كظيم﴾</span>، قال: الكظيم: الكميد{7}<span class=comment-ref>٣٦٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٢</span> لم يذكر <u>ابن جرير</u> (١٤/٢٥٦) في معنى <span class="qpc-hafs">﴿كظيم﴾</span> غير قول ابن عباس من طريق ابن جريج، وقول الضحاك.</div></p><p><div></p><p><p><span class="item-no">٤١٤٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُوَ كَظِيمٌ﴾</span>، يعني: مكروبًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهو كظيم﴾</span>، قد كظم على الغيظ والحزن{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٧٤.|3:تفسير يحيى بن سلام ١/٦٩.|4:علَّقه يحيى بن سلام ١/٦٩.|5:تفسير مقاتل بن سليمان ٢/٤٧٤.|6:تفسير يحيى بن سلام ١/٦٩.|7:أخرجه ابن جرير ١٤/٢٥٦.|8:أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) بطوله.|9:أخرجه ابن جرير ١٤/٢٥٦.|10:تفسير مقاتل بن سليمان ٢/٤٧٤.|11:تفسير يحيى بن سلام ١/٦٩.
  16,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَتَوَ ٰ⁠رَىٰ مِنَ ٱلۡقَوۡمِ مِن سُوۤءِ مَا بُشِّرَ بِهِۦۤۚ أَیُمۡسِكُهُۥ عَلَىٰ هُونٍ أَمۡ یَدُسُّهُۥ فِی ٱلتُّرَابِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: هذا فِعل مشركي العرب، كان يقتل أحدهم ابنته{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٢٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في الآية، قال: كانت العرب يقتُلون ما وُلِد لهم مِن جارية، فيَدُسُّونها في التراب وهي حَيَّةٌ حتى تموت{2}. (٩/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَتَوارى مِنَ القَوْمِ مِن سُوءِ ما بُشِّرَ بِهِ﴾</span>، يعني: لا يريد أن يُسْمِعَ تلك البُشرى أحدًا{3}<span class=comment-ref>٣٦٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٣</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٥/٣٧٢): «وقوله: <span class="qpc-hafs">﴿يَتَوارى مِنَ القَوْمِ﴾</span> الآية، هذا التواري الذي ذكر الله تعالى إنما هو بعد البشارة بالأنثى، وما يحكى أن الرجل منهم كان إذا أصاب امرأته الطلق توارى حتى يخبر بأحد الأمرين فليس المراد في الآية، ويُشبه أن ذلك كان إذا أخبر بسارٍّ خرج، وإن أخبر بسوء بقي على تواريه ولم يحتج إلى إحداثه».</div></p><p><h3><span class="qpc-hafs">﴿عَلَىٰ هُونٍ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿على هُون﴾</span>، أي: هَوانٍ، بلغةِ قريش{2}. (٩/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن صنيعه بولده، فقال سبحانه: <span class="qpc-hafs">﴿أيُمْسِكُهُ عَلى هُونٍ﴾</span>، فأمّا الله فقد علم أنّه صانع أحدهما لا محالة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿على هون﴾</span>: على هوان، يقول: كيف يصنع بما بشر به؟ <span class="qpc-hafs">﴿أيمسكه﴾</span> أيمسك الذي بشر به -الابنة- على هوان؟{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَمۡ یَدُسُّهُۥ فِی ٱلتُّرَابِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ يَدُسُّهُ﴾</span> وهي حية <span class="qpc-hafs">﴿فِي التُّرابِ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿أم يدُسُّهُ في التراب﴾</span>، قال: يَئِدُ ابنتَه{8}. (٩/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أم يدسه في التراب﴾</span>، فيقتل ابنته؛ يدفنها حيَّة حتى تموت مخافة الفاقة، كان أحدهم يقتل ابنته مخافة أن تأكل معه، مخافة الفاقة، ويغذي كلبه. وكانوا يقولون: إن الملائكة بنات الله، فالله صاحبُ بنات؛ فألْحِقُوا البناتِ به{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَا سَاۤءَ مَا یَحۡكُمُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ألا ساء ما يحكمون﴾</span>، قال: بِئْسَ ما حكَموا. يقول: شيءٌ لا يَرْضَونه لأنفسِهم، فكيف يَرْضَونه لي؟!{2}. (٩/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا ساءَ ما يَحْكُمُونَ﴾</span>، يعني: ألا بئس ما يقضون حين يزعمون أنّ لي البنات، وهم يكرهونها لأنفسهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٣٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿ألا ساء ما﴾</span> بئس ما <span class="qpc-hafs">﴿يحكمون﴾</span>، وهذا مثل ضربه الله لهم{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/٧٠.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٤٧٤.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٤٧٤.|6:تفسير يحيى بن سلام ١/٧٠.|7:تفسير مقاتل بن سليمان ٢/٤٧٤.|8:أخرجه ابن جرير ١٤/٢٥٧. وعزاه السيوطي إلى ابن المنذر.|9:تفسير يحيى بن سلام ١/٧٠.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٤٧٤.|12:تفسير يحيى بن سلام ١/٧٠.
  16,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال سبحانه: <span class="qpc-hafs">﴿لِلَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ﴾</span>، يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَثَلُ ٱلسَّوۡءِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٤١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿مثل السوء﴾</span>: النار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَثَلُ السَّوْءِ﴾</span>، يعني: شبه السوء{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ ٱلۡمَثَلُ ٱلۡأَعۡلَىٰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿ولله المثل الأعلى﴾</span>، قال: يقول: ليس كمثلِه شيء{4}. (٩/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٤٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: و<span class="qpc-hafs">﴿المثل الأعلى﴾</span>: شهادة أن لا إله إلا الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولله المثل الأعلى﴾</span>، قال: شهادةُ أن لا إله إلا الله{6}. (٩/٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولله المثل الأعلى﴾</span>، قال: الإخلاص، والتوحيد{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِلَّهِ المَثَلُ الأَعْلى﴾</span> لأنه -تبارك وتعالى- رب واحدٌ، لا شريك له، ولا ولد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ثم قال: <span class="qpc-hafs">﴿ولله المثل الأعلى﴾</span>، إنه لم يتخذ ولدًا، ولم يكن له شريك في الملك}{9}<span class=comment-ref>٣٦٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٤</span> ذكر <u>ابنُ عطية</u> (٥/٣٧٢-٣٧٣) في قوله: <span class="qpc-hafs">﴿مثل﴾</span> <b>قولًا</b>، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لظاهر اللفظ</span>، فقال: «قالت فرقة: <span class="qpc-hafs">﴿مَثَلُ﴾</span> في هذه الآية بمعنى: صفة، أي: لهؤلاء صفة السوء، ولله الوصف الأعلى. وهذا لا نضطر إليه، لأنه خروج عن اللفظ».</p><p>و<span class="comment-type-4">علّق</span> عليه <u>ابنُ القيم</u> (٢/١١٢) بقوله: «وهذا قول صحيح، فالمثل كثيرًا ما يرد بمعنى: الصفة. قاله جماعة من المتقدمين».</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> <span class="mustanad">مستندًا إلى دلالة العقل</span> أن قوله: «<span class="qpc-hafs">﴿مَثَلُ﴾</span> على حاله، وذلك أنهم إذا قالوا: إنّ البنات لله. فقد جعلوا له مثلًا، فالبنات من البشر، وكثرة البنات عندهم مكروه ذميم، فهو مثل السوء الذي أخبر الله تعالى أنه لهم ليس في البنات فقط، لكن لما جعلوه هم في البنات جعله هو لهم على الإطلاق في كل سوء، ولا غاية بعد عذاب النار، وقوله: <span class="qpc-hafs">﴿ولِلَّهِ المَثَلُ الأَعْلى﴾</span> على الإطلاق أيضًا في الكمال المستغني».</p><p>وذكر <u>ابنُ القيم</u> (٢/١١٢-١١٣) عدة أقوال في معنى الآية، ثم <span class="comment-type-4">علّق</span> بقوله: «قلت: المثل الأعلى يتضمن الصفة العليا، وعلم العالمين بها، ووجودها العلمي، والخبر عنها، وذكرها، وعبادة الرب سبحانه بواسطة العلم والمعرفة القائمة بقلوب عابديه وذاكريه، فهاهنا أربعة أمور، <b>الأول</b>: ثبوت الصفات العليا لله سبحانه في نفس الأمر، علمها العباد أو جهلوها، وهذا معنى قول مَن فسره بالصفة. <b>الثاني</b>: وجودها في العلم والتصور، وهذا معنى قول مَن قال من السلف والخلف: إنه ما في قلوب عابديه وذاكريه من معرفته وذكره ومحبته وإجلاله وتعظيمه. وهذا الذي في قلوبهم من المثل الأعلى لا يشترك فيه غيره معه، بل يختص به في قلوبهم، كما اختص في ذاته، وهذا معنى قول مَن قال من المفسرين: أهل السماء يعظمونه ويحبونه ويعبدونه، وأهل الأرض يعظمونه ويجلونه. <b>الثالث</b>: ذكر صفاته والخبر عنها وتنزيهها عن النقائص والعيوب والتمثيل. <b>الرابع</b>: محبة الموصوف بها وتوحيده والإخلاص له والتوكل عليه والإنابة إليه، وكلما كان الإيمان بالصفات أكمل كان هذا الحب والإخلاص أقوى. فعبارات السلف تدور حول هذه المعاني الأربعة لا تتجاوزها».</div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُوَ العَزِيزُ﴾</span> في ملكه جل جلاله، لقولهم: إنّ الله لا يقدر على البعث، <span class="qpc-hafs">﴿الحَكِيمُ﴾</span> في أمره؛ حكم البعث {1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٤.|2:تفسير الثعلبي ٦/٢٣، وتفسير البغوي ٥/٢٥.|3:تفسير مقاتل بن سليمان ٢/٤٧٤.|4:أخرجه ابن جرير ١٤/٤٨٨-٤٨٩ في تفسير قوله تعالى: <span class="qpc-hafs">﴿ولَهُ المَثَلُ الأَعْلى﴾</span> [الروم:٢٧]، والبيهقي في الأسماء والصفات (٦١٠). وعزاه السيوطي إلى ابن أبي حاتم.|5:تفسير الثعلبي ٦/٢٣، وتفسير البغوي ٥/٢٥.|6:أخرجه عبد الرزاق ١/٣٥٧ من طريق معمر، وابن جرير ١٤/٢٥٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|7:أخرجه يحيى بن سلام ١/٧٠، وابن جرير ١٤/٢٥٨.|8:تفسير مقاتل بن سليمان ٢/٤٧٤.|9:تفسير يحيى بن سلام ١/٧٠.|10:تفسير مقاتل بن سليمان ٢/٤٧٤.
  16,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ یُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِظُلۡمِهِم مَّا تَرَكَ عَلَیۡهَا مِن دَاۤبَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: كاد الجُعَلُ{1} أن يُعَذَّبَ في جُحْرِه بذَنبِ ابن آدم. ثم قرأ: <span class="qpc-hafs">﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</span>{2}. (٩/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥١<span class="dash">-</span></span> عن <span class="name-2">أبي الأحوص [عوف بن مالك بن نضلة الأشجعى]</span> -من طريق أبي إسحاق- قال: كاد الجُعَلُ أن يُعَذَّب بذنب بني آدم. وقرأ: <span class="qpc-hafs">﴿لو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</span>{3}<span class=comment-ref>٣٦٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٥</span> <span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٥/٣٧٤) أنّ ما جاء من آثار عن السلف تفيد بموت الجُعل وغيره من الدواب بفعل ابن آدم إنما هو مترتب على أن المراد بالدابة في الآية: كل ما يدب على الأرض. ثم نقل <b>قولًا</b> آخر لم ينسبه لأحد من السلف أن المراد بالدابة: الظَلَمة فقط. و<span class="comment-type-4">علّق</span> عليه، فقال: «وقالت فرقة: قوله: <span class="qpc-hafs">﴿مِن دابَّةٍ﴾</span> يريد: من أولئك الظلمة فقط، ويدل على هذا التخصيص أنّ الله لا يعاقب أحدًا بذنب أحد، <span class="mustanad">واحتجت بقول الله تعالى</span>: <span class="qpc-hafs">﴿ولا تَزِرُ وازِرَةٌ وِزْرَ أُخْرى﴾</span> [الأنعام:١٦٤]». ثم قال <span class="comment-type-4">معلّقًا</span> <span class="mustanad">مستندًا إلى النظائر، ودلالة العقل</span>: «وهذا كله لا حُجَّة فيه، وذلك أنّ الله تعالى لا يجعل العقوبة تقصد أحدًا بسبب إذناب غيره، ولكن إذا أرسل عذابًا على أمة عاصية، لم يمكن البريء التخلص من ذلك العذاب، فأصابه العذاب لا بأنه له مجازاة، ونحو هذا قوله: <span class="qpc-hafs">﴿واتَّقُوا فِتْنَةً لا تُصِيبَنَّ الَّذِينَ ظَلَمُوا مِنكُمْ خاصَّةً﴾</span> [الأنفال:٢٥]، وقيل للنبي ﷺ: أنهلك وفينا الصالحون؟ قال: «نعم، إذا كثر الخبث». ثم لا بد من تَعَلُّق ظلم ما بالأبرياء، وذلك بترك التغيير ومداهنة أهل الظلم ومداومة جوارهم».</div></p><p><div></p><p><p><span class="item-no">٤١٤٥٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ولو يؤاخِذ الله الناسَ بظلمهم ما ترك عليها من دابة﴾</span>، قال: ما سَقاهم المطر{4}. (٩/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</span>، قال: قد فعَل الله ذلك في زمان نوح؛ أهلَك اللهُ ما على ظهرِ الأرض مِن دابة إلا ما حُمِلَ في سفينة نوح{5}. (٩/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في الآية، يقول: إذا قحَط المطر فلم يَبْقَ في الأرض دابةٌ إلا ماتَت{4}. (٩/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿ولَوْ يُؤاخِذُ اللَّهُ النّاسَ﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿بِظُلْمِهِمْ﴾</span> يعني: بما عملوا من الكفر والتكذيب؛ لَعَجَّل لهم العقوبة، <span class="qpc-hafs">﴿ما تَرَكَ عَلَيْها مِن دابَّةٍ﴾</span> يعني: فوق الأرض من دابة، يعني: يقحط المطر؛ فتموت الدواب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</span> لحبس المطر؛ فأهلك حيوان الأرض{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ یُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِظُلۡمِهِم مَّا تَرَكَ عَلَیۡهَا مِن دَاۤبَّةࣲ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٤٥٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>لو أنّ الله يؤاخِذُني وعيسى ابن مريمَ بذُنُوبِنا</b> -وفي لفظ: <b>بما جَنَتْ هاتان</b>. الإبهامُ والتي تَلِيها- <b>لعَذَّبَنا ما يَظْلِمُنا شيئًا</b>»{9}. (٩/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: ذُنُوبُ ابن آدمَ قَتَلَت الجُعَلَ في جُحْرِه. ثم قال: إي، والله، زمنَ غَرِقَ قومُ نوح ﵇{10}. (٩/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٥٩<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي سلمة- أنّه سمِع رجلًا يقول: إنّ الظالِمَ لا يَضُرُّ إلا نفسَه. فقال أبو هريرة: بلى، والله، إنّ الحُبارى لتموتُ هَزْلًا في وكْرِها مِن ظُلْمِ الظالم{11}. (٩/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٦٠<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق إسحاق بن أبي طلحة- قال: كاد الضَّبُّ يموتُ في جُحْرِه هَزْلًا مِن ظُلْمِ ابن آدم{12}. (٩/٦٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِن یُؤَخِّرُهُمۡ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّىۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿ولكِنْ يُؤَخِّرُهُمْ إلى أجَلٍ مُسَمًّى﴾</span> الذي وقَّت لهم في اللوح المحفوظ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولكن يؤخرهم﴾</span> يؤخر المشركين <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span> إلى الساعة؛ لأنّ كفار هذه الأمة أُخِّر عذابها بالاستئصال إلى النفخة الأولى{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا جَاۤءَ أَجَلُهُمۡ لَا یَسۡتَـٔۡخِرُونَ سَاعَةࣰ وَلَا یَسۡتَقۡدِمُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٦٣<span class="dash">-</span></span> عن أبي الدرداء، قال: تذاكرنا زيادةَ العُمُرِ عند رسول الله ﷺ، فقلنا: مَن وصَل رَحِمَه أُنسِئَ في أجلِه. فقال: «<b>إنّه ليس بزائدٍ في عُمُره، قال اللهُ: <span class="qpc-hafs">﴿فإذا جاء أجلهم لا يستأخرون ساعة ولا يستقدمون﴾</span>. ولكنَّ الرجل يكون له الذُّرِّيَّة الصالحةُ، فيدعون الله له من بعده، فيبلُغه ذلك، فذلك الذي يُنسأ في أجله</b>». وفي لفظ: «<b>فيلحقُه دعاؤُهم في قبرِه، فذلك زيادةُ العُمُر</b>»{15}. (٦/٣٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٦٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق معمر- قال الله: <span class="qpc-hafs">﴿فإذا جاء أجلهم لا يستأخرون ساعة ولا يستقدمون﴾</span>، قال: نرى أنّه إذا حضر أجله فلا يؤخر ساعة، ولا يقدم، وما لم يحضر أجلُه فإنّ الله يؤخر ما شاء، ويقدم ما شاء{16}<span class=comment-ref>٣٦٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٦</span> لم يذكر <u>ابن جرير</u> (١٤/٢٦١) غير قول محمد ابن شهاب الزهري.</div></p><p><div></p><p><p><span class="item-no">٤١٤٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا جاءَ أجَلُهُمْ﴾</span> يعني: وقت عذابهم في الدنيا؛ <span class="qpc-hafs">﴿لا يَسْتَأْخِرُونَ ساعَةً ولا يَسْتَقْدِمُونَ﴾</span> يعني: لا يتأخرون عن أجلهم حتى يُعَذَّبوا في الدنيا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فإذا جاء أجلهم﴾</span> بعذاب الله؛ <span class="qpc-hafs">﴿لا يستأخرون﴾</span> عنه؛ عن العذاب <span class="qpc-hafs">﴿ساعة ولا يستقدمون﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:الجعل: حيوان كالخنفساء. النهاية (جعل).|2:أخرجه ابن أبي شيبة ١٣/٣٠١، وابن جرير ١٤/٢٥٩-٢٦٠، والبيهقي في الشعب (٧٤٧٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ١٤/٢٥٩.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه عبد الرزاق ٢/١٣٧، وابن جرير ١٩/٣٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:تفسير مقاتل بن سليمان ٢/٤٧٤.|8:تفسير يحيى بن سلام ١/٧٠.|9:أخرجه ابن حبان ٢/٤٣٢-٤٣٣، ٤٣٥ (٦٥٧، ٦٥٩).</p><p>قال أبو نعيم في الحلية ٨/١٣٢: «غريب من حديث الفضيل وهشام، تفرَّد به عنه الحسين بن علي الجعفي». وقال الألباني في الصحيحة ٧/٦٠٤ (٣٢٠٠) معقبًا على كلام أبي نعيم: «قلت: وهو ثقة من رجال الشيخين، وكذلك مَن فوقه، فالسند صحيح على شرطهما».|10:أخرجه ابن جرير ١٤/٢٦٠ من طريق الزبير بن عدي بلفظ: «<b>خطيئة ابن آدم قتلت الجُعَلَ</b>». وعزاه السيوطي إلى أحمد في الزهد.|11:أخرجه ابن أبي الدنيا (٢٦٩) من طريق الشيباني، وابن جرير ١٤/٢٦٠، والبيهقي في شعب الإيمان (٤٧٧٩). وعزاه السيوطي إلى عبد بن حميد.|12:أخرجه ابن أبي الدنيا في كتاب العقوبات (٢٦٨). وعزاه السيوطي إلى عبد بن حميد.|13:تفسير مقاتل بن سليمان ٢/٤٧٤.|14:تفسير يحيى بن سلام ١/٧٠.|15:أخرجه الخطيب في تالي التلخيص ١/١٢٤ (٤٩)، والطبراني في الأوسط ١/١٥ (٣٤)، وابن أبي حاتم -كما في تفسير ابن كثير ٤/٥٧٩، ٦/٥٣٩-. وتقدم الحديث في تفسير آية الأعراف [٣٤].</p><p>قال الهيثمي في المجمع ٨/١٥٣ (١٣٤٦٨) «رواه الطبراني في الصغير، والأوسط، وليس في إسناده متروك، ولكنهم ضُعِّفوا». وقال الحافظ في الفتح١٠/٤١٦: «أخرج الطبراني في الصغير، بسند ضعيف». وقال الألباني في الضعيفة ١١/٥١٢ (٥٣٢٣): «منكر».|16:أخرجه ابن جرير ١٤/٢٦١.|17:تفسير مقاتل بن سليمان ٢/٤٧٤.|18:تفسير يحيى بن سلام ١/٧٠.
  16,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَجۡعَلُونَ لِلَّهِ مَا یَكۡرَهُونَۚ وَتَصِفُ أَلۡسِنَتُهُمُ ٱلۡكَذِبَ أَنَّ لَهُمُ ٱلۡحُسۡنَىٰۚ لَا جَرَمَ أَنَّ لَهُمُ ٱلنَّارَ وَأَنَّهُم مُّفۡرَطُونَ ۝٦٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤١٤٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبعضهم يقرأ هذا الحرف: ‹وأَنَّهُم مُفَرِّطُونَ›، يعني: أنهم مُفْرِّطُونَ كقولهم: <span class="qpc-hafs">﴿يا حَسْرَتَنا عَلى ما فَرَّطْنا فِيها﴾</span> [الأنعام:٣١]. قال <span class="name-3">يحيى بن سلّام</span>: وكذلك قرأتها عند عمرو{1}<span class=comment-ref>٣٦٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٧</span> ذكر <u>ابنُ جرير</u> (١٤/٢٦٧) هذه القراءة، و<span class="comment-type-4">علّق</span> عليها قائلًا: «وقرأه أبو جعفر القارئ: ‹وأَنَّهُم مُّفَرِّطُونَ› بكسر الراء وتشديدها، بتأويل: أنهم مفرطون في أداء الواجب الذي كان لله عليهم في الدنيا من طاعته وحقوقه، مضيعو ذلك، من قول الله تعالى: <span class="qpc-hafs">﴿يا حسرتا على ما فرطت في جنب الله﴾</span> [الزمر:٥٦]».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٥/٣٧٥).</p><p>ثم ذكر <u>ابنُ جرير</u> قراءة من قرأ ذلك بكسر الراء وتخفيفها، و<span class="comment-type-4">علّق</span> عليها، فقال: «وقرأ نافع بن أبي نعيم: ‹وأَنَّهُم مُّفْرِطُونَ› بكسر الراء وتخفيفها ... بتأويل: أنهم مفرطون في الذنوب والمعاصي، مسرفون على أنفسهم مكثرون منها، من قولهم: أفرط فلان في القول: إذا تجاوز حده، وأسرف فيه».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u> (٣/٣٧٥)، فقال: «وقرأ السبعة سوى نافع <span class="qpc-hafs">﴿مُفْرَطُونَ﴾</span> بفتح الراء وخفتها، ومعناه: مقدمون إلى النار والعذاب. وهي قراءة الحسن، والأعرج، وأصحاب ابن عباس، وقد رويت عن نافع، وهو مأخوذ من فرط الماء، وهم القوم الذين يتقدمون إلى المياه لإصلاح الدلاء والأرشية، <span class="mustanad">ومنه قول النبي ﷺ:</span> «<b>أنا فرطكم على الحوض</b>»».</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> <span class="mustanad">مستندًا إلى لموافقتها لتأويل أهل التأويل</span> قراءة من قرأ ذلك بفتح الراء وتخفيفها، فقال: «والذي هو أولى القراءات في ذلك بالصواب قراءة الذين ذكرنا قراءتهم من أهل العراق؛ لموافقتها تأويل أهل التأويل الذي ذكرنا قبل، وخروج القراءات الأخرى عن تأويلهم».</div></p><p><h3><span class="qpc-hafs">﴿وَیَجۡعَلُونَ لِلَّهِ مَا یَكۡرَهُونَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٦٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿ويجعلون لله ما يكرهون﴾</span>، قال: يقول: تجعَلون لي البنات، وتَكْرَهون ذلك لأنفسِكم{2}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٦٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ويجعلون لله ما يكرهون﴾</span>، قال: وهُنَّ الجَواري{2}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَجْعَلُونَ﴾</span> يعني: ويصفون <span class="qpc-hafs">﴿لِلَّهِ ما يَكْرَهُونَ﴾</span> من البنات؛ يقولون: لله البنات{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ويجعلون لله ما يكرهون﴾</span> يجعلون له البنات، ويكرهونها لأنفسهم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَصِفُ أَلۡسِنَتُهُمُ ٱلۡكَذِبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وتصف ألسنتهم الكذب﴾</span>: تقول ألسنتهم الكذب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿وتصف ألسنتهم الكذب﴾</span>، قال: قولُ كفارِ قريش{7}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وتصف ألسنتهم الكذب﴾</span>، أي: يَتكلَّمون{8}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وتصف ألسنتهم الكذب﴾</span>، أي: يتكلمون به، ويعلنون به{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَصِفُ﴾</span> يعني: وتقول <span class="qpc-hafs">﴿ألْسِنَتُهُمُ الكَذِبَ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنَّ لَهُمُ ٱلۡحُسۡنَىٰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أنّ لهم الحسنى﴾</span>: لنا البنونَ، وللهِ البنات{7}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: في تفسير <span class="name-2">الحسن البصري</span>: أن لهم الجنة. يقولون: أي: إن كانت جنة. كقوله؛ قول الكافر: <span class="qpc-hafs">﴿ولئن رجعت إلى ربي إن لي عنده للحسنى﴾</span> [فصلت:٥٠]، أي: إن رجعت وكانت ثَمَّ جنة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-: بـ<span class="qpc-hafs">﴿أن لهم الحسنى﴾</span>، أي: الغِلْمان{13}<span class=comment-ref>٣٦٨٨</span>. (٩/٦٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٨</span> لم يذكر <u>ابن جرير</u> (١٤/٢٦٢) غير قول قتادة، وقول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٤١٤٨٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: البنين{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: بـ<span class="qpc-hafs">﴿أنَّ لَهُمُ الحُسْنى﴾</span> البنين، وله البنات{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أن لهم الحسنى﴾</span>، أي: الغلمان{16}<span class=comment-ref>٣٦٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٨٩</span> في قوله: <span class="qpc-hafs">﴿الحسنى﴾</span> قولان: <b>الأول</b>: أن المراد به: الذكور من الأولاد. <b>الثاني</b>: أن المراد به: الجنة.</p><p>وقد ذكر <u>ابنُ عطية</u> (٥/٣٧٤-٣٧٥) القول الأول، و<span class="comment-type-4">علّق</span> عليه بقوله: «وهو <span class="mustanad">الأسبق</span> من معنى الآية». و<span class="comment-type-4">علّق</span> على القول الثاني بقوله: «<span class="mustanad">ويؤيد هذا قوله</span>: <span class="qpc-hafs">﴿لا جَرَمَ أنَّ لَهُمُ النّارَ﴾</span>، ومعنى الآية على هذا التأويل: يجعلون لله المكروه، ويدَّعون مع ذلك أنهم يدخلون الجنة. كما تقول لرجل: أنت تعصي الله، وتقول مع ذلك أنت تنجو. أي: هذا بعيد مع هذا».</div></p><p><h3><span class="qpc-hafs">﴿لَا جَرَمَ أَنَّ لَهُمُ ٱلنَّارَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿لا جرم﴾</span>، يقول: بلى{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا جَرَمَ﴾</span> قسمًا حقًّا <span class="qpc-hafs">﴿أنَّ لَهُمُ النّارَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿لا جرم﴾</span>، وهي كلمة وعيد{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَّهُم مُّفۡرَطُونَ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٨٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مَنسِيُّون في النار{20}<span class=comment-ref>٣٦٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٠</span> ذكر <u>ابن كثير</u> (٨/٣٢٢) هذا القول، و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿فاليوم ننساهم كما نسوا لقاء يومهم هذا﴾</span> [الأعراف:٥١]».</div></p><p><div></p><p><p><span class="item-no">٤١٤٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر جعفر بن أبي وحشية- في قوله: <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، قال: مَتْروكون في النار، مَنسيُّون فيها أبدًا{21}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق الربيع، عن أبي بشر- <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، قال: مُخْسَؤون مُبْعَدون{22}<span class=comment-ref>٣٦٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩١</span> ذكر <u>ابنُ عطية</u> (٥/٣٧٥) هذا القول، و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا قريب من الذي قبله». يعني: قول من قال: معناه: منسيون في النار.</div></p><p><div></p><p><p><span class="item-no">٤١٤٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأنهم مُّفرَطُون﴾</span>، قال: مَنسيُّون{23}. (٩/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، قال: مَنسِيّون في النار{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، قال: مُعَجَّلٌ بهم إلى النار{25}. (٩/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق الحسين- <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، يقول: مُضاعون{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، قال: قد فُرِطوا في النار، أي: مُعَجَّلون{27}<span class=comment-ref>٣٦٩٢</span>. (٩/٦٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٢</span> ذكر <u>ابنُ كثير</u> (٨/٣٢٢) قول قتادة، و<span class="comment-type-4">علّق</span> عليه، فقال: «وعن قتادة أيضًا: <span class="qpc-hafs">﴿مفرطون﴾</span> أي: معجلون إلى النار، من الفرط، وهو السابق إلى الورد».</div></p><p><div></p><p><p><span class="item-no">٤١٤٩٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، يعني: وأنهم مسلَّمون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩٥<span class="dash">-</span></span> عن <span class="name-2">داود بن أبي هند</span> -من طريق عَبّاد بن راشد- في قول الله: <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span>، قال: منسيون في النار{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنَّهُمْ مُفْرَطُونَ﴾</span>، يعني: متروكون في النار؛ لقولهم: لله البنات{30}<span class=comment-ref>٣٦٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٣</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿وأنهم مفرطون﴾</span> على أقوال: <b>الأول</b>: أنهم متروكون في النار. <b>الثاني</b>: أنهم معجلون إلى النار مقدمون إليها. <b>الثالث</b>: أنهم مبعدون في النار.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٤/٢٦٥) على القول الثاني، فقال: "وقال آخرون: معنى ذلك: معجلون إلى النار، مقدمون إليها. وذهبوا في ذلك إلى قول العرب: أفرطنا فلانًا في طلب الماء. إذا قدموه لإصلاح الدلاء والأرشية، وتسوية ما يحتاجون إليه عند ورودهم عليه، فهو مفرط، فأما المتقدم نفسه فهو فارط، يقال: قد فرط فلان أصحابه يفرطهم فرطًا وفروطًا: إذا تقدمهم، وجمع فارط فراط، ومنه قول القطامي:</p><p>واستعجلونا وكانوا من صحابتنا ... كما تعجل فراط لوراد</p><p><span class="mustanad">ومنه قول النبي ﷺ</span>: «<b>أنا فرطكم على الحوض</b>». أي: متقدمكم إليه، وسابقكم حتى تردوه".</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٤/٢٦٦) القول الأول، و<span class="comment-type-2">انتقد</span> القول الثاني <span class="mustanad">مستندًا إلى دلالة العقل، واللغة</span>، وعلل ذلك بقوله: «وذلك أن الإفراط الذي هو بمعنى التقديم إنما يقال فيمن قدم مقدمًا لإصلاح ما يقدم إليه إلى وقت ورود من قدمه عليه، وليس بمقدم من قدم إلى النار من أهلها لإصلاح شيء فيها لوارد يرد عليها فيها فيوافقه مصلحًا، وإنما تقدم من قدم إليها لعذاب يعجل له، فإذا كان معنى ذلك الإفراط الذي هو تأويل التعجيل ففسد أن يكون له وجه في الصحة؛ صح المعنى الآخر، وهو الإفراط الذي بمعنى التخليف والترك، وذلك أن يحكى عن العرب: ما أفرطت ورائي أحدًا، أي: ما خلفته، وما فرطته، أي: لم أخلفه».</p><p>وذكر <u>ابنُ كثير</u> (٨/٣٢٢) الأول والثاني، و<span class="comment-type-4">علّق</span> عليهما بقوله: «ولا منافاة؛ لأنهم يعجل بهم يوم القيامة إلى النار، وينسون فيها، أي: يخلدون».</div></p></div>",footnotes:1:تفسير يحيى بن سلام ١/٧١.</p><p>و‹مُّفَرِّطُونَ› بكسر الراء مشددة قراءة متواترة، قرأ بها أبو جعفر، وقرأ نافع: ‹مُّفْرِطُونَ› بكسر الراء مخففة، وقرأ بقية العشرة <span class="qpc-hafs">﴿مُفْرَطُونَ﴾</span> بفتح الراء مخففة. انظر: النشر ٢/٣٠٤، والإتحاف ص٣٥٢.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٧٥.|5:تفسير يحيى بن سلام ١/٧٠.|6:تفسير مجاهد ص٤٢٢.|7:أخرجه ابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|9:أخرجه يحيى بن سلام ١/٧١.|10:تفسير مقاتل بن سليمان ٢/٤٧٥.|11:أخرجه ابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|12:علَّقه يحيى بن سلام ١/٧١.|13:أخرجه عبد الرزاق ١/٣٥٧، وابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|14:علَّقه يحيى بن سلام ١/٧١.|15:تفسير مقاتل بن سليمان ٢/٤٧٥.|16:تفسير يحيى بن سلام ١/٧١.|17:أخرجه ابن جرير ١٤/٢٦٣.|18:تفسير مقاتل بن سليمان ٢/٤٧٥.|19:تفسير يحيى بن سلام ١/٧١.|20:تفسير البغوي ٥/٢٦.|21:أخرجه ابن جرير ١٤/٢٦٤. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم. كما أخرجه يحيى بن سلام ١/٧١، وابن أبي شيبة (ت: محمد عوامة) ١٩/٤٠٧ (٣٦٥٠٢)، وابن جرير ١٤/٢٦٤ بلفظ: مَنسِيُّون مُضَيَّعون.|22:أخرجه ابن جرير ١٤/٢٦٦.|23:أخرجه ابن جرير ١٤/٢٦٤-٢٦٥. وهو في تفسير مجاهد ص٤٢٢ بلفظ: منسيون في النار. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|24:أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٨/٥١٣ (٣٥٣١٦)، وابن جرير ١٤/٢٦٥ بلفظ: متروكون في النار.|25:علَّقه يحيى بن سلام ١/٧١. وعزاه السيوطي إلى ابن أبي حاتم.|26:أخرجه ابن جرير ١٤/٢٦٥.|27:أخرجه عبد الرزاق ١/٣٥٧، وابن جرير ١٤/٢٦٦ من طريق معمر وسعيد. وعزاه السيوطي إلى ابن المنذر.|28:علَّقه يحيى بن سلام ١/٧١.|29:أخرجه ابن جرير ١٤/٢٦٥.|30:تفسير مقاتل بن سليمان ٢/٤٧٥. وفي تفسير الثعلبي ٦/٢٤، وتفسير البغوي ٥/٢٧ بنحوه مختصرًا منسوبًا إلى مقاتل دون تعيينه.
  16,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تاللَّهِ﴾</span>، يعني: والله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿تالله﴾</span> قسم، أقسم الله بنفسه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَقَدۡ أَرۡسَلۡنَاۤ إِلَىٰۤ أُمَمࣲ مِّن قَبۡلِكَ فَزَیَّنَ لَهُمُ ٱلشَّیۡطَـٰنُ أَعۡمَـٰلَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٤٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَقَدْ أرْسَلْنا إلى أُمَمٍ مِن قَبْلِكَ﴾</span> فكذبوهم، <span class="qpc-hafs">﴿فَزَيَّنَ لَهُمُ الشَّيْطانُ أعْمالَهُمْ﴾</span> الكفر والتكذيب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿لقد أرسلنا إلى أمم من قبلك﴾</span> يعني: مَن أُهْلِك بالعذاب من الأمم السالفة، <span class="qpc-hafs">﴿فزين لهم الشيطان أعمالهم﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُوَ وَلِیُّهُمُ ٱلۡیَوۡمَ وَلَهُمۡ عَذَابٌ أَلِیمࣱ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهُوَ ولِيُّهُمُ اليَوْمَ﴾</span> يعني: الشيطان وليهم في الآخرة، <span class="qpc-hafs">﴿ولَهُمْ عَذابٌ ألِيمٌ﴾</span> يعني: وجيع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فهو وليهم اليوم﴾</span> وإلى يوم القيامة، <span class="qpc-hafs">﴿ولهم عذاب أليم﴾</span> في الآخرة{2}<span class=comment-ref>٣٦٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٤</span> ذكر <u>ابنُ عطية</u> (٥/٣٧٦) احتمالين في المراد من <span class="qpc-hafs">﴿اليوم﴾</span>، فقال: «وقوله: <span class="qpc-hafs">﴿اليَوْمَ﴾</span> <b>يحتمل</b> أن يريد: يوم الإخبار بهذه الآية، وهو بعد موت أولئك الأمم المذكورة، أي: لا ولي لهم مذ ماتوا واحتاجوا إلى الغوث إلا الشيطان. و<b>يحتمل</b> أن يريد: يوم القيامة، والألف واللام فيه للعهد، أي: هو وليهم في اليوم المشهود، وهو وقت الحاجة والفصل. و<b>يحتمل</b> أن يريد: فهو وليُّهم مدة حياتهم، ثم انقطعت ولايته بموتهم. وعبر عن ذلك بقوله: <span class="qpc-hafs">﴿اليَوْمَ﴾</span> تمثيلًا للمخاطبين بمدة حياتهم، كما تقول لرجل شاب تحضه على طلب العلم: يا فلان، لا يدرس أحد من الناس إلا اليوم. تريد: في مثل سنك هذه. فكأنه قال لهؤلاء: <span class="qpc-hafs">﴿فَهُوَ ولِيُّهُمُ﴾</span> في مثل حياتكم هذه، وهي التي كانت لهم».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٥.|2:تفسير يحيى بن سلام ١/٧٢.|3:تفسير مقاتل بن سليمان ٢/٤٧٥.|4:تفسير يحيى بن سلام ١/٧٢.|5:تفسير مقاتل بن سليمان ٢/٤٧٥.|6:تفسير يحيى بن سلام ١/٧٢.
  16,64,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنزَلۡنَا عَلَیۡكَ ٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنْزَلْنا عَلَيْكَ﴾</span> يا محمد ﷺ <span class="qpc-hafs">﴿الكِتابَ﴾</span> يعني: القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وما أنزلنا عليك الكتاب﴾</span> القرآن <span class="qpc-hafs">﴿إلا لتبين لهم الذي اختلفوا فيه﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا لِتُبَیِّنَ لَهُمُ ٱلَّذِی ٱخۡتَلَفُوا۟ فِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا لِتُبَيِّنَ لَهُمُ الَّذِي اخْتَلَفُوا فِيهِ﴾</span>، وذلك أنّ أهل مكة اختلفوا في القرآن؛ فآمن به بعضهم، وكفر بعضهم{1}<span class=comment-ref>٣٦٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٩٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٥/٣٧٦): «وقوله <span class="qpc-hafs">﴿الَّذِي اخْتَلَفُوا﴾</span> فِيهِ لفظ عام لأنواع كفر الكفرة؛ من الجحد بالله تعالى، أو بالقيامة، أو بالنبوءات، أو غير ذلك، ولكن الإشارة في هذه الآية إنما هي لجحدهم الربوبية، وتشريكهم الأصنام في الألوهية، <span class="mustanad">يدل على ذلك أخذه بعد هذا</span> في إثبات العبر الدالة على أن الأنعام وسائر الأفعال إنما هي من الله تعالى، لا من الأصنام».</div></p><p><h3><span class="qpc-hafs">﴿وَهُدࣰى وَرَحۡمَةࣰ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٥٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُدىً﴾</span> من الضلالة، <span class="qpc-hafs">﴿ورَحْمَةً﴾</span> من العذاب لِمَن آمن بالقرآن، فذلك قوله: <span class="qpc-hafs">﴿لِقَوْمٍ يُؤْمِنُونَ﴾</span> يعني: يُصَدِّقون بالقرآن أنه جاء من الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وهدى ورحمة﴾</span> يقول: ما فيه هدى ورحمة <span class="qpc-hafs">﴿لقوم يؤمنون﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٥.|2:تفسير يحيى بن سلام ١/٧٢.|3:تفسير مقاتل بن سليمان ٢/٤٧٥.|4:تفسير مقاتل بن سليمان ٢/٤٧٥.|5:تفسير يحيى بن سلام ١/٧٢.