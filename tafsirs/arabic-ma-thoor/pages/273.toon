tafsir[10]{c,v,t}:
16,55," <q>﴿لِیَكۡفُرُوا۟ بِمَاۤ ءَاتَیۡنَـٰهُمۡۚ﴾</q> - تفسير ٤١٣٩٣- تفسير إسماعيل السُّدِّيّ: <q>﴿ليكفروا بما آتيناهم﴾</q>، يعني: لئلا يكفروا بما آتيناهم{1}. (ز) ٤١٣٩٤- قال مقاتل بن سليمان: <q>﴿لِيَكْفُرُوا بِما آتَيْناهُمْ﴾</q>، يعني: لئلا يكفروا بالذي أعطيناهم من الخير والخِصب في كشف الضر عنهم، وهو الجوع{2}٣٦٨٠. (ز) ٣٦٨٠ ذكر ابنُ عطية (٥/٣٧٠) في قوله: <q>﴿ليكفروا﴾</q> احتمالين، فقال: «وقوله: <q>﴿لِيَكْفُرُوا﴾</q> يجوز أن يكون اللام لام الصيرورة، أي: فصار أمرهم ليكفروا، وهم لم يقصدوا بأفعالهم تلك أن يكفروا. ويجوز أن تكون لام أمر على معنى التهديد والوعيد، كقوله: <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q> [فصلت:٤٠]، والكفر هنا يحتمل أن يكون كفر الجحد بالله والشرك، ويؤيده قوله: <q>﴿بِرَبِّهِمْ يُشْرِكُونَ﴾</q>، ويحتمل أن يكون كفر النعمة». ورجّح القول الثاني مستندًا إلى السياق، فقال: «وهو الأظهر؛ لقوله: <q>﴿بِما آتَيْناهُمْ﴾</q>، أي: بما أنعمنا عليهم». وعلّق ابنُ كثير (٨/٣١٨) على الاحتمال بأنّ اللام لام التعليل، فقال: «وقيل: لام التعليل، بمعنى: قيضنا لهم ذلك ليكفروا، أي: يستروا ويجحدوا نعم الله عليهم، وأنه المسدي إليهم النعم، الكاشف عنهم النقم». <q>﴿فَتَمَتَّعُوا۟ فَسَوۡفَ تَعۡلَمُونَ ۝٥٥﴾</q> - تفسير ٤١٣٩٥- عن الحسن البصري، في قوله: <q>﴿فتمتَّعُوا فسوف تعلمون﴾</q>، قال: وعيد{3}. (٩/٦٢) ٤١٣٩٦- قال مقاتل بن سليمان: <q>﴿فَتَمَتَّعُوا﴾</q> إلى آجالكم قليلًا، <q>﴿فَسَوْفَ تَعْلَمُونَ﴾</q>، هذا وعيد. نظيرها في الروم، وإبراهيم، والعنكبوت{4}. (ز) ٤١٣٩٧- قال يحيى بن سلّام: <q>﴿فتمتعوا﴾</q> في الدنيا، <q>﴿فسوف تعلمون﴾</q>، وهذا وعيد{5}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٦٨.تفسير مقاتل بن سليمان ٢/٤٧٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٣. يشير إلى قوله تعالى: <q>﴿لِيَكْفُرُوا بِما آتَيْناهُمْ فَتَمَتَّعُوا فَسَوْفَ تَعْلَمُونَ﴾</q> [الروم:٣٤]، وقوله تعالى: <q>﴿وجَعَلُوا لِلَّهِ أنْدادًا لِيُضِلُّوا عَنْ سَبِيلِهِ قُلْ تَمَتَّعُوا فَإنَّ مَصِيرَكُمْ إلى النّارِ﴾</q> [إبراهيم:٣٠]، وقوله تعالى: <q>﴿لِيَكْفُرُوا بِما آتَيْناهُمْ ولِيَتَمَتَّعُوا فَسَوْفَ يَعْلَمُونَ﴾</q> [العنكبوت:٦٦].تفسير يحيى بن سلام ١/٦٩.
16,56," <q>﴿وَیَجۡعَلُونَ لِمَا لَا یَعۡلَمُونَ نَصِیبࣰا مِّمَّا رَزَقۡنَـٰهُمۡۗ﴾</q> - تفسير ٤١٣٩٨- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿ويجعلون لما لا يعلمون نصيبًا مما رزقناهم﴾</q>، قال: يعلَمون أنّ الله خلَقهم ويَضُرُّهم وينفعُهم، ثم يجعَلون لما لا يعلَمون أنه يَضُرُّهم ولا ينفعُهم نصيبًا مما رزَقْناهم{1}. (٩/٦٢) ٤١٣٩٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويجعلون لما لا يعلمون نصيبًا مما رزقناهم﴾</q>، قال: هم مُشْرِكو العرب، جعلوا لأوثانِهم وشياطينهم نصيبًا مما رزَقهم الله، وجزَّؤوا مِن أموالهم جُزءًا، فجعَلوه لأوثانهم وشياطينهم{2}. (٩/٦٢) ٤١٤٠٠- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ويجعلون لما لا يعلمون نصيبًا مما رزقناهم﴾</q>: هذا قولُهم: <q>﴿هذا لله بزعمهم وهذا لِشُركائنا﴾</q> [الأنعام:١٣٦]{3}. (٩/٦٢) ٤١٤٠١- قال مقاتل بن سليمان: <q>﴿ويَجْعَلُونَ﴾</q> يعني: ويَصِفُون <q>﴿لِما لا يَعْلَمُونَ﴾</q> من الآلهة أنها آلهة <q>﴿نَصِيبًا مِمّا رَزَقْناهُمْ﴾</q> من الحرث والأنعام{4}. (ز) ٤١٤٠٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ويجعلون لما لا يعلمون نصيبا مما رزقناهم﴾</q>، قال: جعلوا لآلهتهم التي ليس لها نصيب ولا شيء؛ جعلوا لها نصيبًا مما قال الله من الحرث والأنعام؛ يُسَمُّون عليها أسماءها، ويذبحون لها{1}. (ز) ٤١٤٠٣- قال يحيى بن سلّام: قوله: <q>﴿ويجعلون لما لا يعلمون نصيبا مما رزقناهم﴾</q>، يعني: آلهتهم، أي: يجعلون لما لا يعلمون أنه خلق مع الله شيئًا، ولا أمات، ولا أحيا، ولا رزق معه شيئًا نصيبا مما رزقناهم، يعني: قوله: <q>﴿وجعلوا لله مما ذرأ من الحرث والأنعام نصيبا فقالوا هذا لله بزعمهم وهذا لشركائنا﴾</q> [الأنعام:١٣٦]{6}٣٦٨١. (ز) ٣٦٨١ قال ابنُ عطية (٥/٣٧١): «وقوله: <q>﴿لِما لا يَعْلَمُونَ﴾</q> يريد الأصنام، ومعناه: لا يعلمون فيهم حجة ولا برهانًا، ويحتمل أن يريد بقوله: <q>﴿يَعْلَمُونَ﴾</q> الأصنام، أي: يجعلون لجمادات لا تعلم شيئا نَصِيبًا، فالمفعول محذوف، ثم عبر عنهم بعبارة من يعقل بحسب مذهب الكفار الذين يسندون إليها ما يُسند إلى من يعقل، وبحسب أنه إسناد منفي، وهذا الاحتمال كله ضعيف». <q>﴿تَٱللَّهِ﴾</q> - تفسير ٤١٤٠٤- قال مقاتل بن سليمان: <q>﴿تاللَّهِ﴾</q> قل لهم يا محمد: والله{4}. (ز) ٤١٤٠٥- قال يحيى بن سلّام: <q>﴿تالله﴾</q> قسم. أقسم بنفسه{6}. (ز) <q>﴿لَتُسۡـَٔلُنَّ عَمَّا كُنتُمۡ تَفۡتَرُونَ ۝٥٦﴾</q> - تفسير ٤١٤٠٦- قال مقاتل بن سليمان: <q>﴿لَتُسْألُنَّ﴾</q> في الآخرة <q>﴿عَمّا كُنْتُمْ تَفْتَرُونَ﴾</q> حين زعمتم أنّ الله أمركم بتحريم الحرث والأنعام{4}. (ز) ٤١٤٠٧- قال يحيى بن سلّام: <q>﴿لتسألن عما كنتم تفترون﴾</q> [أن] الأوثان تقربهم إلى الله. يقوله لهم لِما يقولون: إنّ الأوثان تقربهم إلى الله، وإنّ الله أمرهم بعبادتها{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٥٣.أخرجه يحيى بن سلام ١/٦٩ مختصرًا من طريق سعيد، وابن جرير ١٤/٢٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٣.أخرجه ابن جرير ١٤/٢٥٣.تفسير يحيى بن سلام ١/٦٩.تفسير مقاتل بن سليمان ٢/٤٧٣.تفسير يحيى بن سلام ١/٦٩.تفسير مقاتل بن سليمان ٢/٤٧٣.تفسير يحيى بن سلام ١/٦٩.
16,57," <q>﴿وَیَجۡعَلُونَ لِلَّهِ ٱلۡبَنَـٰتِ﴾</q> - تفسير ٤١٤٠٨- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ويجعلون لله البنات﴾</q> الآيات، يقول: تجعَلون له البنات، تَرْضَونَهنَّ لي، ولا تَرْضَونَهن لأنفسِكم! وذلك أنهم كانوا في الجاهلية إذا وُلِد للرجل منهم جاريةٌ أمسَكها على هوانٍ، أو دَسَّها في التراب وهي حَيَّةٌ{1}. (٩/٦٣) ٤١٤٠٩- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿ويجعلون لله البنات﴾</q>، يعني: ويَصِفون لله البنات{2}. (ز) ٤١٤١٠- قال مقاتل بن سليمان: ثم قال: يعنيهم: <q>﴿ويَجْعَلُونَ﴾</q> يعني: ويصفون <q>﴿لِلَّهِ البَناتِ﴾</q> حين زعموا أنّ الملائكة بنات الله تعالى{3}. (ز) ٤١٤١١- قال يحيى بن سلّام: كان مشركو العرب يقولون: إنّ الملائكة بنات الله{4}. (ز) <q>﴿سُبۡحَـٰنَهُۥ﴾</q> - تفسير ٤١٤١٢- قال مقاتل بن سليمان: <q>﴿سُبْحانَهُ﴾</q> نزَّه نفسّه عن قولهم{3}. (ز) ٤١٤١٣- قال يحيى بن سلّام: قال الله: <q>﴿سبحانه﴾</q> يُنَزِّه نفسه عن ما قالوا{4}. (ز) <q>﴿وَلَهُم مَّا یَشۡتَهُونَ ۝٥٧﴾</q> - تفسير ٤١٤١٤- عن الضحاك بن مزاحم، في قوله: <q>﴿ولهم ما يشتهون﴾</q>، قال: يعني به: البنين{7}. (٩/٦٣) ٤١٤١٥- قال مقاتل بن سليمان: <q>﴿ولَهُمْ ما يَشْتَهُونَ﴾</q> من البنين{3}. (ز) ٤١٤١٦- قال يحيى بن سلّام: <q>﴿ولهم ما يشتهون﴾</q>، أي: ويجعلون لأنفسهم ما يشتهون؛ الغلمان{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٥٥-٢٥٦. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.علَّقه يحيى بن سلام ١/٦٩.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٦٩.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٦٩.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٦٩.
16,58," <q>﴿وَإِذَا بُشِّرَ أَحَدُهُم بِٱلۡأُنثَىٰ ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا﴾</q> - تفسير ٤١٤١٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإذا بُشر أحدهم بالأنثى ظل وجهه مسودًا وهو كظيم﴾</q>، قال: هذا صنيعُ مُشْرِكي العرب، أخبرهم الله بخُبثِ صنيعِهم، فأما المؤمن فهو حقيقٌ أن يَرضى بما قسَم الله له، وقضاءُ الله خيرٌ مِن قضاءِ المرء لنفسه، ولَعَمْرِي ما يَدْرِي أنه خير، لَرُبَّ جارية خيرٌ لأهلِها مِن غلام، وإنما أخبرَكم اللهُ بصنيعِهم لتَجْتَنِبوه، ولتَنْتَهوا عنه، فكان أحدُهم يَغْذُو كلبَه، ويَئِدُ ابنتَه{1}. (٩/٦٣) ٤١٤١٨- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال سبحانه: <q>﴿وإذا بُشِّرَ أحَدُهُمْ بِالأُنْثى﴾</q>، فقيل له: وُلِدت لك ابنة{2}. (ز) ٤١٤١٩- قال يحيى بن سلّام: <q>﴿وإذا بشر أحدهم بالأنثى﴾</q> التي جعلها لله، زعم، حيث جعلوا لله البنات، يعنون: الملائكة{3}. (ز) <q>﴿ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا﴾</q> - تفسير ٤١٤٢٠- تفسير إسماعيل السُّدِّيّ: <q>﴿ظل وجهه مسودا﴾</q>، أي: أقام وجهه{4}. (ز) ٤١٤٢١- قال مقاتل بن سليمان: <q>﴿ظَلَّ وجْهُهُ مُسْوَدًّا﴾</q>، يعني: متغيرًا{2}. (ز) ٤١٤٢٢- قال يحيى بن سلّام: <q>﴿مسودا﴾</q> ومغيرًا{3}. (ز) <q>﴿وَهُوَ كَظِیمࣱ ۝٥٨﴾</q> - تفسير ٤١٤٢٣- عن عبد الله بن عباس -من طريق ابن جريج- <q>﴿وهو كظيم﴾</q>، قال: حزين{7}. (ز) ٤١٤٢٤- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك بن مزاحم- أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله ﷿: <q>﴿وهو كظيم﴾</q>، ما الكظيم؟ قال: الساكِت. قال: وهل كانت العرب تعرف ذلك؟ قال: نعم، أما سمعت بقول زهير بن جذيمة العبسي: فإن تك كاظمًا بمصاب شاسٍ فإني اليوم منطلق لساني{8}؟ (ز) ٤١٤٢٥- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿وهو كظيم﴾</q>، قال: الكظيم: الكميد{7}٣٦٨٢. (ز) ٣٦٨٢ لم يذكر ابن جرير (١٤/٢٥٦) في معنى <q>﴿كظيم﴾</q> غير قول ابن عباس من طريق ابن جريج، وقول الضحاك. ٤١٤٢٦- قال مقاتل بن سليمان: <q>﴿وهُوَ كَظِيمٌ﴾</q>، يعني: مكروبًا{2}. (ز) ٤١٤٢٧- قال يحيى بن سلّام: <q>﴿وهو كظيم﴾</q>، قد كظم على الغيظ والحزن{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٥٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٦٩.علَّقه يحيى بن سلام ١/٦٩.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٦٩.أخرجه ابن جرير ١٤/٢٥٦.أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) بطوله.أخرجه ابن جرير ١٤/٢٥٦.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٦٩.
16,59," <q>﴿یَتَوَ ٰ⁠رَىٰ مِنَ ٱلۡقَوۡمِ مِن سُوۤءِ مَا بُشِّرَ بِهِۦۤۚ أَیُمۡسِكُهُۥ عَلَىٰ هُونٍ أَمۡ یَدُسُّهُۥ فِی ٱلتُّرَابِۗ﴾</q> - تفسير ٤١٤٢٨- عن قتادة بن دعامة -من طريق سعيد- قال: هذا فِعل مشركي العرب، كان يقتل أحدهم ابنته{1}. (ز) ٤١٤٢٩- عن إسماعيل السُّدِّيّ، في الآية، قال: كانت العرب يقتُلون ما وُلِد لهم مِن جارية، فيَدُسُّونها في التراب وهي حَيَّةٌ حتى تموت{2}. (٩/٦٤) ٤١٤٣٠- قال مقاتل بن سليمان: <q>﴿يَتَوارى مِنَ القَوْمِ مِن سُوءِ ما بُشِّرَ بِهِ﴾</q>، يعني: لا يريد أن يُسْمِعَ تلك البُشرى أحدًا{3}٣٦٨٣. (ز) ٣٦٨٣ قال ابنُ عطية (٥/٣٧٢): «وقوله: <q>﴿يَتَوارى مِنَ القَوْمِ﴾</q> الآية، هذا التواري الذي ذكر الله تعالى إنما هو بعد البشارة بالأنثى، وما يحكى أن الرجل منهم كان إذا أصاب امرأته الطلق توارى حتى يخبر بأحد الأمرين فليس المراد في الآية، ويُشبه أن ذلك كان إذا أخبر بسارٍّ خرج، وإن أخبر بسوء بقي على تواريه ولم يحتج إلى إحداثه». <q>﴿عَلَىٰ هُونٍ﴾</q> - تفسير ٤١٤٣١- عن قتادة بن دعامة، في قوله: <q>﴿على هُون﴾</q>، أي: هَوانٍ، بلغةِ قريش{2}. (٩/٦٤) ٤١٤٣٢- قال مقاتل بن سليمان: ثم أخبر عن صنيعه بولده، فقال سبحانه: <q>﴿أيُمْسِكُهُ عَلى هُونٍ﴾</q>، فأمّا الله فقد علم أنّه صانع أحدهما لا محالة{3}. (ز) ٤١٤٣٣- قال يحيى بن سلّام: <q>﴿على هون﴾</q>: على هوان، يقول: كيف يصنع بما بشر به؟ <q>﴿أيمسكه﴾</q> أيمسك الذي بشر به -الابنة- على هوان؟{6}. (ز) <q>﴿أَمۡ یَدُسُّهُۥ فِی ٱلتُّرَابِۗ﴾</q> - تفسير ٤١٤٣٤- قال مقاتل بن سليمان: <q>﴿أمْ يَدُسُّهُ﴾</q> وهي حية <q>﴿فِي التُّرابِ﴾</q>{3}. (ز) ٤١٤٣٥- عن عبد الملك ابن جريج -من طريق حجاج- في قوله: <q>﴿أم يدُسُّهُ في التراب﴾</q>، قال: يَئِدُ ابنتَه{8}. (٩/٦٤) ٤١٤٣٦- قال يحيى بن سلّام: <q>﴿أم يدسه في التراب﴾</q>، فيقتل ابنته؛ يدفنها حيَّة حتى تموت مخافة الفاقة، كان أحدهم يقتل ابنته مخافة أن تأكل معه، مخافة الفاقة، ويغذي كلبه. وكانوا يقولون: إن الملائكة بنات الله، فالله صاحبُ بنات؛ فألْحِقُوا البناتِ به{6}. (ز) <q>﴿أَلَا سَاۤءَ مَا یَحۡكُمُونَ ۝٥٩﴾</q> - تفسير ٤١٤٣٧- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ألا ساء ما يحكمون﴾</q>، قال: بِئْسَ ما حكَموا. يقول: شيءٌ لا يَرْضَونه لأنفسِهم، فكيف يَرْضَونه لي؟!{2}. (٩/٦٤) ٤١٤٣٨- قال مقاتل بن سليمان: <q>﴿ألا ساءَ ما يَحْكُمُونَ﴾</q>، يعني: ألا بئس ما يقضون حين يزعمون أنّ لي البنات، وهم يكرهونها لأنفسهم{3}. (ز) ٤١٤٣٩- قال يحيى بن سلّام: قال الله: <q>﴿ألا ساء ما﴾</q> بئس ما <q>﴿يحكمون﴾</q>، وهذا مثل ضربه الله لهم{6}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/٧٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٧٠.تفسير مقاتل بن سليمان ٢/٤٧٤.أخرجه ابن جرير ١٤/٢٥٧. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٧٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٧٠.
16,60," <q>﴿لِلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ﴾</q> - تفسير ٤١٤٤٠- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال سبحانه: <q>﴿لِلَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ﴾</q>، يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال{1}. (ز) <q>﴿مَثَلُ ٱلسَّوۡءِۖ﴾</q> - تفسير ٤١٤٤١- قال عبد الله بن عباس: <q>﴿مثل السوء﴾</q>: النار{2}. (ز) ٤١٤٤٢- قال مقاتل بن سليمان: <q>﴿مَثَلُ السَّوْءِ﴾</q>، يعني: شبه السوء{1}. (ز) <q>﴿وَلِلَّهِ ٱلۡمَثَلُ ٱلۡأَعۡلَىٰۚ﴾</q> - تفسير ٤١٤٤٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿ولله المثل الأعلى﴾</q>، قال: يقول: ليس كمثلِه شيء{4}. (٩/٦٤) ٤١٤٤٤- قال عبد الله بن عباس: و<q>﴿المثل الأعلى﴾</q>: شهادة أن لا إله إلا الله{2}. (ز) ٤١٤٤٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولله المثل الأعلى﴾</q>، قال: شهادةُ أن لا إله إلا الله{6}. (٩/٦٤) ٤١٤٤٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولله المثل الأعلى﴾</q>، قال: الإخلاص، والتوحيد{7}. (ز) ٤١٤٤٧- قال مقاتل بن سليمان: <q>﴿ولِلَّهِ المَثَلُ الأَعْلى﴾</q> لأنه -تبارك وتعالى- رب واحدٌ، لا شريك له، ولا ولد{1}. (ز) ٤١٤٤٨- قال يحيى بن سلّام: ثم قال: <q>﴿ولله المثل الأعلى﴾</q>، إنه لم يتخذ ولدًا، ولم يكن له شريك في الملك}{9}٣٦٨٤. (ز) ٣٦٨٤ ذكر ابنُ عطية (٥/٣٧٢-٣٧٣) في قوله: <q>﴿مثل﴾</q> قولًا، وانتقده مستندًا لظاهر اللفظ، فقال: «قالت فرقة: <q>﴿مَثَلُ﴾</q> في هذه الآية بمعنى: صفة، أي: لهؤلاء صفة السوء، ولله الوصف الأعلى. وهذا لا نضطر إليه، لأنه خروج عن اللفظ». وعلّق عليه ابنُ القيم (٢/١١٢) بقوله: «وهذا قول صحيح، فالمثل كثيرًا ما يرد بمعنى: الصفة. قاله جماعة من المتقدمين». ثم رجّح ابنُ عطية مستندًا إلى دلالة العقل أن قوله: «<q>﴿مَثَلُ﴾</q> على حاله، وذلك أنهم إذا قالوا: إنّ البنات لله. فقد جعلوا له مثلًا، فالبنات من البشر، وكثرة البنات عندهم مكروه ذميم، فهو مثل السوء الذي أخبر الله تعالى أنه لهم ليس في البنات فقط، لكن لما جعلوه هم في البنات جعله هو لهم على الإطلاق في كل سوء، ولا غاية بعد عذاب النار، وقوله: <q>﴿ولِلَّهِ المَثَلُ الأَعْلى﴾</q> على الإطلاق أيضًا في الكمال المستغني». وذكر ابنُ القيم (٢/١١٢-١١٣) عدة أقوال في معنى الآية، ثم علّق بقوله: «قلت: المثل الأعلى يتضمن الصفة العليا، وعلم العالمين بها، ووجودها العلمي، والخبر عنها، وذكرها، وعبادة الرب سبحانه بواسطة العلم والمعرفة القائمة بقلوب عابديه وذاكريه، فهاهنا أربعة أمور، الأول: ثبوت الصفات العليا لله سبحانه في نفس الأمر، علمها العباد أو جهلوها، وهذا معنى قول مَن فسره بالصفة. الثاني: وجودها في العلم والتصور، وهذا معنى قول مَن قال من السلف والخلف: إنه ما في قلوب عابديه وذاكريه من معرفته وذكره ومحبته وإجلاله وتعظيمه. وهذا الذي في قلوبهم من المثل الأعلى لا يشترك فيه غيره معه، بل يختص به في قلوبهم، كما اختص في ذاته، وهذا معنى قول مَن قال من المفسرين: أهل السماء يعظمونه ويحبونه ويعبدونه، وأهل الأرض يعظمونه ويجلونه. الثالث: ذكر صفاته والخبر عنها وتنزيهها عن النقائص والعيوب والتمثيل. الرابع: محبة الموصوف بها وتوحيده والإخلاص له والتوكل عليه والإنابة إليه، وكلما كان الإيمان بالصفات أكمل كان هذا الحب والإخلاص أقوى. فعبارات السلف تدور حول هذه المعاني الأربعة لا تتجاوزها». <q>﴿وَهُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٦٠﴾</q> - تفسير ٤١٤٤٩- قال مقاتل بن سليمان: <q>﴿وهُوَ العَزِيزُ﴾</q> في ملكه جل جلاله، لقولهم: إنّ الله لا يقدر على البعث، <q>﴿الحَكِيمُ﴾</q> في أمره؛ حكم البعث {1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير الثعلبي ٦/٢٣، وتفسير البغوي ٥/٢٥.تفسير مقاتل بن سليمان ٢/٤٧٤.أخرجه ابن جرير ١٤/٤٨٨-٤٨٩ في تفسير قوله تعالى: <q>﴿ولَهُ المَثَلُ الأَعْلى﴾</q> [الروم:٢٧]، والبيهقي في الأسماء والصفات (٦١٠). وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٣، وتفسير البغوي ٥/٢٥.أخرجه عبد الرزاق ١/٣٥٧ من طريق معمر، وابن جرير ١٤/٢٥٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٧٠، وابن جرير ١٤/٢٥٨.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٧٠.تفسير مقاتل بن سليمان ٢/٤٧٤.
16,61," <q>﴿وَلَوۡ یُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِظُلۡمِهِم مَّا تَرَكَ عَلَیۡهَا مِن دَاۤبَّةࣲ﴾</q> - تفسير ٤١٤٥٠- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: كاد الجُعَلُ{1} أن يُعَذَّبَ في جُحْرِه بذَنبِ ابن آدم. ثم قرأ: <q>﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</q>{2}. (٩/٦٥) ٤١٤٥١- عن أبي الأحوص [عوف بن مالك بن نضلة الأشجعى] -من طريق أبي إسحاق- قال: كاد الجُعَلُ أن يُعَذَّب بذنب بني آدم. وقرأ: <q>﴿لو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</q>{3}٣٦٨٥. (ز) ٣٦٨٥ بيّن ابنُ عطية (٥/٣٧٤) أنّ ما جاء من آثار عن السلف تفيد بموت الجُعل وغيره من الدواب بفعل ابن آدم إنما هو مترتب على أن المراد بالدابة في الآية: كل ما يدب على الأرض. ثم نقل قولًا آخر لم ينسبه لأحد من السلف أن المراد بالدابة: الظَلَمة فقط. وعلّق عليه، فقال: «وقالت فرقة: قوله: <q>﴿مِن دابَّةٍ﴾</q> يريد: من أولئك الظلمة فقط، ويدل على هذا التخصيص أنّ الله لا يعاقب أحدًا بذنب أحد، واحتجت بقول الله تعالى: <q>﴿ولا تَزِرُ وازِرَةٌ وِزْرَ أُخْرى﴾</q> [الأنعام:١٦٤]». ثم قال معلّقًا مستندًا إلى النظائر، ودلالة العقل: «وهذا كله لا حُجَّة فيه، وذلك أنّ الله تعالى لا يجعل العقوبة تقصد أحدًا بسبب إذناب غيره، ولكن إذا أرسل عذابًا على أمة عاصية، لم يمكن البريء التخلص من ذلك العذاب، فأصابه العذاب لا بأنه له مجازاة، ونحو هذا قوله: <q>﴿واتَّقُوا فِتْنَةً لا تُصِيبَنَّ الَّذِينَ ظَلَمُوا مِنكُمْ خاصَّةً﴾</q> [الأنفال:٢٥]، وقيل للنبي ﷺ: أنهلك وفينا الصالحون؟ قال: «نعم، إذا كثر الخبث». ثم لا بد من تَعَلُّق ظلم ما بالأبرياء، وذلك بترك التغيير ومداهنة أهل الظلم ومداومة جوارهم». ٤١٤٥٢- عن سعيد بن جبير، في قوله: <q>﴿ولو يؤاخِذ الله الناسَ بظلمهم ما ترك عليها من دابة﴾</q>، قال: ما سَقاهم المطر{4}. (٩/٦٥) ٤١٤٥٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</q>، قال: قد فعَل الله ذلك في زمان نوح؛ أهلَك اللهُ ما على ظهرِ الأرض مِن دابة إلا ما حُمِلَ في سفينة نوح{5}. (٩/٦٥) ٤١٤٥٤- عن إسماعيل السُّدِّيّ، في الآية، يقول: إذا قحَط المطر فلم يَبْقَ في الأرض دابةٌ إلا ماتَت{4}. (٩/٦٥) ٤١٤٥٥- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿ولَوْ يُؤاخِذُ اللَّهُ النّاسَ﴾</q> يعني: كفار مكة <q>﴿بِظُلْمِهِمْ﴾</q> يعني: بما عملوا من الكفر والتكذيب؛ لَعَجَّل لهم العقوبة، <q>﴿ما تَرَكَ عَلَيْها مِن دابَّةٍ﴾</q> يعني: فوق الأرض من دابة، يعني: يقحط المطر؛ فتموت الدواب{7}. (ز) ٤١٤٥٦- قال يحيى بن سلّام: قوله: <q>﴿ولو يؤاخذ الله الناس بظلمهم ما ترك عليها من دابة﴾</q> لحبس المطر؛ فأهلك حيوان الأرض{8}. (ز) <q>﴿وَلَوۡ یُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِظُلۡمِهِم مَّا تَرَكَ عَلَیۡهَا مِن دَاۤبَّةࣲ﴾</q> - آثار متعلقة بالآية ٤١٤٥٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «لو أنّ الله يؤاخِذُني وعيسى ابن مريمَ بذُنُوبِنا -وفي لفظ: بما جَنَتْ هاتان. الإبهامُ والتي تَلِيها- لعَذَّبَنا ما يَظْلِمُنا شيئًا»{9}. (٩/٦٦) ٤١٤٥٨- عن عبد الله بن مسعود، قال: ذُنُوبُ ابن آدمَ قَتَلَت الجُعَلَ في جُحْرِه. ثم قال: إي، والله، زمنَ غَرِقَ قومُ نوح ﵇{10}. (٩/٦٥) ٤١٤٥٩- عن أبي هريرة -من طريق أبي سلمة- أنّه سمِع رجلًا يقول: إنّ الظالِمَ لا يَضُرُّ إلا نفسَه. فقال أبو هريرة: بلى، والله، إنّ الحُبارى لتموتُ هَزْلًا في وكْرِها مِن ظُلْمِ الظالم{11}. (٩/٦٦) ٤١٤٦٠- عن أنس بن مالك -من طريق إسحاق بن أبي طلحة- قال: كاد الضَّبُّ يموتُ في جُحْرِه هَزْلًا مِن ظُلْمِ ابن آدم{12}. (٩/٦٦) <q>﴿وَلَـٰكِن یُؤَخِّرُهُمۡ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّىۖ﴾</q> - تفسير ٤١٤٦١- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿ولكِنْ يُؤَخِّرُهُمْ إلى أجَلٍ مُسَمًّى﴾</q> الذي وقَّت لهم في اللوح المحفوظ{7}. (ز) ٤١٤٦٢- قال يحيى بن سلّام: قوله: <q>﴿ولكن يؤخرهم﴾</q> يؤخر المشركين <q>﴿إلى أجل مسمى﴾</q> إلى الساعة؛ لأنّ كفار هذه الأمة أُخِّر عذابها بالاستئصال إلى النفخة الأولى{8}. (ز) <q>﴿فَإِذَا جَاۤءَ أَجَلُهُمۡ لَا یَسۡتَـٔۡخِرُونَ سَاعَةࣰ وَلَا یَسۡتَقۡدِمُونَ ۝٦١﴾</q> - تفسير ٤١٤٦٣- عن أبي الدرداء، قال: تذاكرنا زيادةَ العُمُرِ عند رسول الله ﷺ، فقلنا: مَن وصَل رَحِمَه أُنسِئَ في أجلِه. فقال: «إنّه ليس بزائدٍ في عُمُره، قال اللهُ: <q>﴿فإذا جاء أجلهم لا يستأخرون ساعة ولا يستقدمون﴾</q>. ولكنَّ الرجل يكون له الذُّرِّيَّة الصالحةُ، فيدعون الله له من بعده، فيبلُغه ذلك، فذلك الذي يُنسأ في أجله». وفي لفظ: «فيلحقُه دعاؤُهم في قبرِه، فذلك زيادةُ العُمُر»{15}. (٦/٣٧٨) ٤١٤٦٤- عن محمد ابن شهاب الزهري -من طريق معمر- قال الله: <q>﴿فإذا جاء أجلهم لا يستأخرون ساعة ولا يستقدمون﴾</q>، قال: نرى أنّه إذا حضر أجله فلا يؤخر ساعة، ولا يقدم، وما لم يحضر أجلُه فإنّ الله يؤخر ما شاء، ويقدم ما شاء{16}٣٦٨٦. (ز) ٣٦٨٦ لم يذكر ابن جرير (١٤/٢٦١) غير قول محمد ابن شهاب الزهري. ٤١٤٦٥- قال مقاتل بن سليمان: <q>﴿فَإذا جاءَ أجَلُهُمْ﴾</q> يعني: وقت عذابهم في الدنيا؛ <q>﴿لا يَسْتَأْخِرُونَ ساعَةً ولا يَسْتَقْدِمُونَ﴾</q> يعني: لا يتأخرون عن أجلهم حتى يُعَذَّبوا في الدنيا{7}. (ز) ٤١٤٦٦- قال يحيى بن سلّام: قوله: <q>﴿فإذا جاء أجلهم﴾</q> بعذاب الله؛ <q>﴿لا يستأخرون﴾</q> عنه؛ عن العذاب <q>﴿ساعة ولا يستقدمون﴾</q>{8}. (ز) ",footnotes:1:الجعل: حيوان كالخنفساء. النهاية (جعل).أخرجه ابن أبي شيبة ١٣/٣٠١، وابن جرير ١٤/٢٥٩-٢٦٠، والبيهقي في الشعب (٧٤٧٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٥٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٣٧، وابن جرير ١٩/٣٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٧٠.أخرجه ابن حبان ٢/٤٣٢-٤٣٣، ٤٣٥ (٦٥٧، ٦٥٩). قال أبو نعيم في الحلية ٨/١٣٢: «غريب من حديث الفضيل وهشام، تفرَّد به عنه الحسين بن علي الجعفي». وقال الألباني في الصحيحة ٧/٦٠٤ (٣٢٠٠) معقبًا على كلام أبي نعيم: «قلت: وهو ثقة من رجال الشيخين، وكذلك مَن فوقه، فالسند صحيح على شرطهما».أخرجه ابن جرير ١٤/٢٦٠ من طريق الزبير بن عدي بلفظ: «خطيئة ابن آدم قتلت الجُعَلَ». وعزاه السيوطي إلى أحمد في الزهد.أخرجه ابن أبي الدنيا (٢٦٩) من طريق الشيباني، وابن جرير ١٤/٢٦٠، والبيهقي في شعب الإيمان (٤٧٧٩). وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب العقوبات (٢٦٨). وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٧٠.أخرجه الخطيب في تالي التلخيص ١/١٢٤ (٤٩)، والطبراني في الأوسط ١/١٥ (٣٤)، وابن أبي حاتم -كما في تفسير ابن كثير ٤/٥٧٩، ٦/٥٣٩-. وتقدم الحديث في تفسير آية الأعراف [٣٤]. قال الهيثمي في المجمع ٨/١٥٣ (١٣٤٦٨) «رواه الطبراني في الصغير، والأوسط، وليس في إسناده متروك، ولكنهم ضُعِّفوا». وقال الحافظ في الفتح١٠/٤١٦: «أخرج الطبراني في الصغير، بسند ضعيف». وقال الألباني في الضعيفة ١١/٥١٢ (٥٣٢٣): «منكر».أخرجه ابن جرير ١٤/٢٦١.تفسير مقاتل بن سليمان ٢/٤٧٤.تفسير يحيى بن سلام ١/٧٠.
16,62," <q>﴿وَیَجۡعَلُونَ لِلَّهِ مَا یَكۡرَهُونَۚ وَتَصِفُ أَلۡسِنَتُهُمُ ٱلۡكَذِبَ أَنَّ لَهُمُ ٱلۡحُسۡنَىٰۚ لَا جَرَمَ أَنَّ لَهُمُ ٱلنَّارَ وَأَنَّهُم مُّفۡرَطُونَ ۝٦٢﴾</q> - قراءات ٤١٤٦٧- قال يحيى بن سلّام: وبعضهم يقرأ هذا الحرف: ‹وأَنَّهُم مُفَرِّطُونَ›، يعني: أنهم مُفْرِّطُونَ كقولهم: <q>﴿يا حَسْرَتَنا عَلى ما فَرَّطْنا فِيها﴾</q> [الأنعام:٣١]. قال يحيى بن سلّام: وكذلك قرأتها عند عمرو{1}٣٦٨٧. (ز) ٣٦٨٧ ذكر ابنُ جرير (١٤/٢٦٧) هذه القراءة، وعلّق عليها قائلًا: «وقرأه أبو جعفر القارئ: ‹وأَنَّهُم مُّفَرِّطُونَ› بكسر الراء وتشديدها، بتأويل: أنهم مفرطون في أداء الواجب الذي كان لله عليهم في الدنيا من طاعته وحقوقه، مضيعو ذلك، من قول الله تعالى: <q>﴿يا حسرتا على ما فرطت في جنب الله﴾</q> [الزمر:٥٦]». وبنحوه ابنُ عطية (٥/٣٧٥). ثم ذكر ابنُ جرير قراءة من قرأ ذلك بكسر الراء وتخفيفها، وعلّق عليها، فقال: «وقرأ نافع بن أبي نعيم: ‹وأَنَّهُم مُّفْرِطُونَ› بكسر الراء وتخفيفها ... بتأويل: أنهم مفرطون في الذنوب والمعاصي، مسرفون على أنفسهم مكثرون منها، من قولهم: أفرط فلان في القول: إذا تجاوز حده، وأسرف فيه». وعلّق عليها ابنُ عطية (٣/٣٧٥)، فقال: «وقرأ السبعة سوى نافع <q>﴿مُفْرَطُونَ﴾</q> بفتح الراء وخفتها، ومعناه: مقدمون إلى النار والعذاب. وهي قراءة الحسن، والأعرج، وأصحاب ابن عباس، وقد رويت عن نافع، وهو مأخوذ من فرط الماء، وهم القوم الذين يتقدمون إلى المياه لإصلاح الدلاء والأرشية، ومنه قول النبي ﷺ: «أنا فرطكم على الحوض»». ثم رجّح ابنُ جرير مستندًا إلى لموافقتها لتأويل أهل التأويل قراءة من قرأ ذلك بفتح الراء وتخفيفها، فقال: «والذي هو أولى القراءات في ذلك بالصواب قراءة الذين ذكرنا قراءتهم من أهل العراق؛ لموافقتها تأويل أهل التأويل الذي ذكرنا قبل، وخروج القراءات الأخرى عن تأويلهم». <q>﴿وَیَجۡعَلُونَ لِلَّهِ مَا یَكۡرَهُونَۚ﴾</q> - تفسير ٤١٤٦٨- عن الضحاك بن مزاحم، في قوله: <q>﴿ويجعلون لله ما يكرهون﴾</q>، قال: يقول: تجعَلون لي البنات، وتَكْرَهون ذلك لأنفسِكم{2}. (٩/٦٧) ٤١٤٦٩- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ويجعلون لله ما يكرهون﴾</q>، قال: وهُنَّ الجَواري{2}. (٩/٦٧) ٤١٤٧٠- قال مقاتل بن سليمان: <q>﴿ويَجْعَلُونَ﴾</q> يعني: ويصفون <q>﴿لِلَّهِ ما يَكْرَهُونَ﴾</q> من البنات؛ يقولون: لله البنات{4}. (ز) ٤١٤٧١- قال يحيى بن سلّام: قوله: <q>﴿ويجعلون لله ما يكرهون﴾</q> يجعلون له البنات، ويكرهونها لأنفسهم{5}. (ز) <q>﴿وَتَصِفُ أَلۡسِنَتُهُمُ ٱلۡكَذِبَ﴾</q> - تفسير ٤١٤٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وتصف ألسنتهم الكذب﴾</q>: تقول ألسنتهم الكذب{6}. (ز) ٤١٤٧٣- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿وتصف ألسنتهم الكذب﴾</q>، قال: قولُ كفارِ قريش{7}. (٩/٦٧) ٤١٤٧٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وتصف ألسنتهم الكذب﴾</q>، أي: يَتكلَّمون{8}. (٩/٦٧) ٤١٤٧٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وتصف ألسنتهم الكذب﴾</q>، أي: يتكلمون به، ويعلنون به{9}. (ز) ٤١٤٧٦- قال مقاتل بن سليمان: <q>﴿وتَصِفُ﴾</q> يعني: وتقول <q>﴿ألْسِنَتُهُمُ الكَذِبَ﴾</q>{4}. (ز) <q>﴿أَنَّ لَهُمُ ٱلۡحُسۡنَىٰۚ﴾</q> - تفسير ٤١٤٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أنّ لهم الحسنى﴾</q>: لنا البنونَ، وللهِ البنات{7}. (٩/٦٧) ٤١٤٧٨- قال يحيى بن سلّام: في تفسير الحسن البصري: أن لهم الجنة. يقولون: أي: إن كانت جنة. كقوله؛ قول الكافر: <q>﴿ولئن رجعت إلى ربي إن لي عنده للحسنى﴾</q> [فصلت:٥٠]، أي: إن رجعت وكانت ثَمَّ جنة{12}. (ز) ٤١٤٧٩- عن قتادة بن دعامة -من طريق معمر-: بـ<q>﴿أن لهم الحسنى﴾</q>، أي: الغِلْمان{13}٣٦٨٨. (٩/٦٧) ٣٦٨٨ لم يذكر ابن جرير (١٤/٢٦٢) غير قول قتادة، وقول مجاهد. ٤١٤٨٠- قال إسماعيل السُّدِّيّ: البنين{12}. (ز) ٤١٤٨١- قال مقاتل بن سليمان: بـ<q>﴿أنَّ لَهُمُ الحُسْنى﴾</q> البنين، وله البنات{4}. (ز) ٤١٤٨٢- قال يحيى بن سلّام: <q>﴿أن لهم الحسنى﴾</q>، أي: الغلمان{16}٣٦٨٩. (ز) ٣٦٨٩ في قوله: <q>﴿الحسنى﴾</q> قولان: الأول: أن المراد به: الذكور من الأولاد. الثاني: أن المراد به: الجنة. وقد ذكر ابنُ عطية (٥/٣٧٤-٣٧٥) القول الأول، وعلّق عليه بقوله: «وهو الأسبق من معنى الآية». وعلّق على القول الثاني بقوله: «ويؤيد هذا قوله: <q>﴿لا جَرَمَ أنَّ لَهُمُ النّارَ﴾</q>، ومعنى الآية على هذا التأويل: يجعلون لله المكروه، ويدَّعون مع ذلك أنهم يدخلون الجنة. كما تقول لرجل: أنت تعصي الله، وتقول مع ذلك أنت تنجو. أي: هذا بعيد مع هذا». <q>﴿لَا جَرَمَ أَنَّ لَهُمُ ٱلنَّارَ﴾</q> - تفسير ٤١٤٨٣- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿لا جرم﴾</q>، يقول: بلى{17}. (ز) ٤١٤٨٤- قال مقاتل بن سليمان: <q>﴿لا جَرَمَ﴾</q> قسمًا حقًّا <q>﴿أنَّ لَهُمُ النّارَ﴾</q>{4}. (ز) ٤١٤٨٥- قال يحيى بن سلّام: قال الله: <q>﴿لا جرم﴾</q>، وهي كلمة وعيد{16}. (ز) <q>﴿وَأَنَّهُم مُّفۡرَطُونَ ۝٦٢﴾</q> - تفسير ٤١٤٨٦- قال عبد الله بن عباس: مَنسِيُّون في النار{20}٣٦٩٠. (ز) ٣٦٩٠ ذكر ابن كثير (٨/٣٢٢) هذا القول، وعلّق عليه بقوله: «وهذا كقوله تعالى: <q>﴿فاليوم ننساهم كما نسوا لقاء يومهم هذا﴾</q> [الأعراف:٥١]». ٤١٤٨٧- عن سعيد بن جبير -من طريق أبي بشر جعفر بن أبي وحشية- في قوله: <q>﴿وأنهم مفرطون﴾</q>، قال: مَتْروكون في النار، مَنسيُّون فيها أبدًا{21}. (٩/٦٧) ٤١٤٨٨- عن سعيد بن جبير -من طريق الربيع، عن أبي بشر- <q>﴿وأنهم مفرطون﴾</q>، قال: مُخْسَؤون مُبْعَدون{22}٣٦٩١. (ز) ٣٦٩١ ذكر ابنُ عطية (٥/٣٧٥) هذا القول، وعلّق عليه بقوله: «وهذا قريب من الذي قبله». يعني: قول من قال: معناه: منسيون في النار. ٤١٤٨٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأنهم مُّفرَطُون﴾</q>، قال: مَنسيُّون{23}. (٩/٦٧) ٤١٤٩٠- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿وأنهم مفرطون﴾</q>، قال: مَنسِيّون في النار{24}. (ز) ٤١٤٩١- عن الحسن البصري، في قوله: <q>﴿وأنهم مفرطون﴾</q>، قال: مُعَجَّلٌ بهم إلى النار{25}. (٩/٦٨) ٤١٤٩٢- عن قتادة بن دعامة -من طريق الحسين- <q>﴿وأنهم مفرطون﴾</q>، يقول: مُضاعون{26}. (ز) ٤١٤٩٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وأنهم مفرطون﴾</q>، قال: قد فُرِطوا في النار، أي: مُعَجَّلون{27}٣٦٩٢. (٩/٦٨) ٣٦٩٢ ذكر ابنُ كثير (٨/٣٢٢) قول قتادة، وعلّق عليه، فقال: «وعن قتادة أيضًا: <q>﴿مفرطون﴾</q> أي: معجلون إلى النار، من الفرط، وهو السابق إلى الورد». ٤١٤٩٤- قال إسماعيل السُّدِّيّ: <q>﴿وأنهم مفرطون﴾</q>، يعني: وأنهم مسلَّمون{12}. (ز) ٤١٤٩٥- عن داود بن أبي هند -من طريق عَبّاد بن راشد- في قول الله: <q>﴿وأنهم مفرطون﴾</q>، قال: منسيون في النار{26}. (ز) ٤١٤٩٦- قال مقاتل بن سليمان: <q>﴿وأَنَّهُمْ مُفْرَطُونَ﴾</q>، يعني: متروكون في النار؛ لقولهم: لله البنات{30}٣٦٩٣. (ز) ٣٦٩٣ اختلف السلف في تفسير قوله: <q>﴿وأنهم مفرطون﴾</q> على أقوال: الأول: أنهم متروكون في النار. الثاني: أنهم معجلون إلى النار مقدمون إليها. الثالث: أنهم مبعدون في النار. وعلّق ابنُ جرير (١٤/٢٦٥) على القول الثاني، فقال: "وقال آخرون: معنى ذلك: معجلون إلى النار، مقدمون إليها. وذهبوا في ذلك إلى قول العرب: أفرطنا فلانًا في طلب الماء. إذا قدموه لإصلاح الدلاء والأرشية، وتسوية ما يحتاجون إليه عند ورودهم عليه، فهو مفرط، فأما المتقدم نفسه فهو فارط، يقال: قد فرط فلان أصحابه يفرطهم فرطًا وفروطًا: إذا تقدمهم، وجمع فارط فراط، ومنه قول القطامي: واستعجلونا وكانوا من صحابتنا ... كما تعجل فراط لوراد ومنه قول النبي ﷺ: «أنا فرطكم على الحوض». أي: متقدمكم إليه، وسابقكم حتى تردوه". وقد رجّح ابنُ جرير (١٤/٢٦٦) القول الأول، وانتقد القول الثاني مستندًا إلى دلالة العقل، واللغة، وعلل ذلك بقوله: «وذلك أن الإفراط الذي هو بمعنى التقديم إنما يقال فيمن قدم مقدمًا لإصلاح ما يقدم إليه إلى وقت ورود من قدمه عليه، وليس بمقدم من قدم إلى النار من أهلها لإصلاح شيء فيها لوارد يرد عليها فيها فيوافقه مصلحًا، وإنما تقدم من قدم إليها لعذاب يعجل له، فإذا كان معنى ذلك الإفراط الذي هو تأويل التعجيل ففسد أن يكون له وجه في الصحة؛ صح المعنى الآخر، وهو الإفراط الذي بمعنى التخليف والترك، وذلك أن يحكى عن العرب: ما أفرطت ورائي أحدًا، أي: ما خلفته، وما فرطته، أي: لم أخلفه». وذكر ابنُ كثير (٨/٣٢٢) الأول والثاني، وعلّق عليهما بقوله: «ولا منافاة؛ لأنهم يعجل بهم يوم القيامة إلى النار، وينسون فيها، أي: يخلدون». ",footnotes:1:تفسير يحيى بن سلام ١/٧١. و‹مُّفَرِّطُونَ› بكسر الراء مشددة قراءة متواترة، قرأ بها أبو جعفر، وقرأ نافع: ‹مُّفْرِطُونَ› بكسر الراء مخففة، وقرأ بقية العشرة <q>﴿مُفْرَطُونَ﴾</q> بفتح الراء مخففة. انظر: النشر ٢/٣٠٤، والإتحاف ص٣٥٢.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٠.تفسير مجاهد ص٤٢٢.أخرجه ابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٧١.تفسير مقاتل بن سليمان ٢/٤٧٥.أخرجه ابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٧١.أخرجه عبد الرزاق ١/٣٥٧، وابن جرير ١٤/٢٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٧١.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧١.أخرجه ابن جرير ١٤/٢٦٣.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧١.تفسير البغوي ٥/٢٦.أخرجه ابن جرير ١٤/٢٦٤. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم. كما أخرجه يحيى بن سلام ١/٧١، وابن أبي شيبة (ت: محمد عوامة) ١٩/٤٠٧ (٣٦٥٠٢)، وابن جرير ١٤/٢٦٤ بلفظ: مَنسِيُّون مُضَيَّعون.أخرجه ابن جرير ١٤/٢٦٦.أخرجه ابن جرير ١٤/٢٦٤-٢٦٥. وهو في تفسير مجاهد ص٤٢٢ بلفظ: منسيون في النار. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٨/٥١٣ (٣٥٣١٦)، وابن جرير ١٤/٢٦٥ بلفظ: متروكون في النار.علَّقه يحيى بن سلام ١/٧١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٦٥.أخرجه عبد الرزاق ١/٣٥٧، وابن جرير ١٤/٢٦٦ من طريق معمر وسعيد. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ١/٧١.أخرجه ابن جرير ١٤/٢٦٥.تفسير مقاتل بن سليمان ٢/٤٧٥. وفي تفسير الثعلبي ٦/٢٤، وتفسير البغوي ٥/٢٧ بنحوه مختصرًا منسوبًا إلى مقاتل دون تعيينه.
16,63," <q>﴿تَٱللَّهِ﴾</q> - تفسير ٤١٤٩٧- قال مقاتل بن سليمان: <q>﴿تاللَّهِ﴾</q>، يعني: والله{1}. (ز) ٤١٤٩٨- قال يحيى بن سلّام: قوله: <q>﴿تالله﴾</q> قسم، أقسم الله بنفسه{2}. (ز) <q>﴿لَقَدۡ أَرۡسَلۡنَاۤ إِلَىٰۤ أُمَمࣲ مِّن قَبۡلِكَ فَزَیَّنَ لَهُمُ ٱلشَّیۡطَـٰنُ أَعۡمَـٰلَهُمۡ﴾</q> - تفسير ٤١٤٩٩- قال مقاتل بن سليمان: <q>﴿لَقَدْ أرْسَلْنا إلى أُمَمٍ مِن قَبْلِكَ﴾</q> فكذبوهم، <q>﴿فَزَيَّنَ لَهُمُ الشَّيْطانُ أعْمالَهُمْ﴾</q> الكفر والتكذيب{1}. (ز) ٤١٥٠٠- قال يحيى بن سلّام: قوله: <q>﴿لقد أرسلنا إلى أمم من قبلك﴾</q> يعني: مَن أُهْلِك بالعذاب من الأمم السالفة، <q>﴿فزين لهم الشيطان أعمالهم﴾</q>{2}. (ز) <q>﴿فَهُوَ وَلِیُّهُمُ ٱلۡیَوۡمَ وَلَهُمۡ عَذَابٌ أَلِیمࣱ ۝٦٣﴾</q> - تفسير ٤١٥٠١- قال مقاتل بن سليمان: <q>﴿فَهُوَ ولِيُّهُمُ اليَوْمَ﴾</q> يعني: الشيطان وليهم في الآخرة، <q>﴿ولَهُمْ عَذابٌ ألِيمٌ﴾</q> يعني: وجيع{1}. (ز) ٤١٥٠٢- قال يحيى بن سلّام: قوله: <q>﴿فهو وليهم اليوم﴾</q> وإلى يوم القيامة، <q>﴿ولهم عذاب أليم﴾</q> في الآخرة{2}٣٦٩٤. (ز) ٣٦٩٤ ذكر ابنُ عطية (٥/٣٧٦) احتمالين في المراد من <q>﴿اليوم﴾</q>، فقال: «وقوله: <q>﴿اليَوْمَ﴾</q> يحتمل أن يريد: يوم الإخبار بهذه الآية، وهو بعد موت أولئك الأمم المذكورة، أي: لا ولي لهم مذ ماتوا واحتاجوا إلى الغوث إلا الشيطان. ويحتمل أن يريد: يوم القيامة، والألف واللام فيه للعهد، أي: هو وليهم في اليوم المشهود، وهو وقت الحاجة والفصل. ويحتمل أن يريد: فهو وليُّهم مدة حياتهم، ثم انقطعت ولايته بموتهم. وعبر عن ذلك بقوله: <q>﴿اليَوْمَ﴾</q> تمثيلًا للمخاطبين بمدة حياتهم، كما تقول لرجل شاب تحضه على طلب العلم: يا فلان، لا يدرس أحد من الناس إلا اليوم. تريد: في مثل سنك هذه. فكأنه قال لهؤلاء: <q>﴿فَهُوَ ولِيُّهُمُ﴾</q> في مثل حياتكم هذه، وهي التي كانت لهم». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.
16,64," <q>﴿وَمَاۤ أَنزَلۡنَا عَلَیۡكَ ٱلۡكِتَـٰبَ﴾</q> - تفسير ٤١٥٠٣- قال مقاتل بن سليمان: <q>﴿وما أنْزَلْنا عَلَيْكَ﴾</q> يا محمد ﷺ <q>﴿الكِتابَ﴾</q> يعني: القرآن{1}. (ز) ٤١٥٠٤- قال يحيى بن سلّام: قوله: <q>﴿وما أنزلنا عليك الكتاب﴾</q> القرآن <q>﴿إلا لتبين لهم الذي اختلفوا فيه﴾</q>{2}. (ز) <q>﴿إِلَّا لِتُبَیِّنَ لَهُمُ ٱلَّذِی ٱخۡتَلَفُوا۟ فِیهِ﴾</q> - تفسير ٤١٥٠٥- قال مقاتل بن سليمان: <q>﴿إلّا لِتُبَيِّنَ لَهُمُ الَّذِي اخْتَلَفُوا فِيهِ﴾</q>، وذلك أنّ أهل مكة اختلفوا في القرآن؛ فآمن به بعضهم، وكفر بعضهم{1}٣٦٩٥. (ز) ٣٦٩٥ قال ابنُ عطية (٥/٣٧٦): «وقوله <q>﴿الَّذِي اخْتَلَفُوا﴾</q> فِيهِ لفظ عام لأنواع كفر الكفرة؛ من الجحد بالله تعالى، أو بالقيامة، أو بالنبوءات، أو غير ذلك، ولكن الإشارة في هذه الآية إنما هي لجحدهم الربوبية، وتشريكهم الأصنام في الألوهية، يدل على ذلك أخذه بعد هذا في إثبات العبر الدالة على أن الأنعام وسائر الأفعال إنما هي من الله تعالى، لا من الأصنام». <q>﴿وَهُدࣰى وَرَحۡمَةࣰ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٦٤﴾</q> - تفسير ٤١٥٠٦- قال مقاتل بن سليمان: <q>﴿وهُدىً﴾</q> من الضلالة، <q>﴿ورَحْمَةً﴾</q> من العذاب لِمَن آمن بالقرآن، فذلك قوله: <q>﴿لِقَوْمٍ يُؤْمِنُونَ﴾</q> يعني: يُصَدِّقون بالقرآن أنه جاء من الله ﷿{1}. (ز) ٤١٥٠٧- قال يحيى بن سلّام: قوله: <q>﴿وهدى ورحمة﴾</q> يقول: ما فيه هدى ورحمة <q>﴿لقوم يؤمنون﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير مقاتل بن سليمان ٢/٤٧٥.تفسير يحيى بن سلام ١/٧٢.
