٦/١٨٢٣.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم، وأبي الشيخ. ولفظ ابن أبي شيبة وابن أبي حاتم دون: ليس، كما في الرواية السابقة.تفسير مقاتل بن سليمان ٢/١٧٦-١٧٧.أخرجه ابن جرير ١١/٥٢٤.أخرجه ابن أبي شيبة ٣/١٧٩-١٨٠. وعلَّقه ابن جرير ١١/٥٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه أبو عبيد في الأموال (١٧٨٥، ١٩٦٧). وعزاه السيوطي إلى ابن المنذر.أخرجه أبو عبيد في الأموال (١٩٧٢)، وابن أبي شيبة ٣/١٧٩. وعزاه السيوطي إلى ابن المنذر، وأَعْقَبَه بقول أبي عبيد القاسم بن سلام: قولُ ابن عباس أعلى ما جاءنا في هذا الباب، وهو أولى بالاتِّباع، وأعلم بالتأويل، وقد وافقه عليه كثيرٌ من أهلِ العلم.تفسير البغوي ٤/٦٤. وفي تفسير الثعلبي ٥/٦٠ نسبته إلى الليث بن سعد.تفسير الثعلبي ٥/٦١.أخرجه أبو عبيد (١٩٧١). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٥٢٤. وعلَّقه ابن أبي حاتم ٦/١٨٢٣.أخرجه أبو عبيد (١٩٦٨). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/١٨٢٤. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٦١.أخرجه ابن جرير ١١/٥٢٤. وعلَّقه ابن أبي حاتم ٦/١٨٢٣.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٥٣ (١١٥).تفسير مقاتل بن سليمان ٢/١٧٦-١٧٧.أخرجه ابن أبي حاتم ٦/١٨٢٣.تفسير الثعلبي ٥/٦١، وتفسير البغوي ٤/٦٤.أخرجه ابن جرير ١١/٥٢٤.أخرجه مسلم ٢/٧٢٢ (١٠٤٤)، وعبد الرزاق في تفسيره ٢/١٥٥ (١١٠٢)، وابن أبي حاتم ٤/١١٣٤ (٦٣٧٨).أخرجه عبد الرزاق ١/٢٨٠، وابن أبي شيبة ٣/٢٠٧، وابن جرير ١١/٥٢٥، وابن أبي حاتم ٦/١٨٢٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٥٢٧.أخرجه ابن أبي حاتم ٦/١٨٢٤.أخرجه ابن جرير ١١/٥٢٦.أخرجه ابن أبي شيبة ٣/٢٠٧، وابن جرير ١١/٥٢٧، وابن أبي حاتم ٦/١٨٢٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٥٢٦.أخرجه ابن أبي شيبة ٣/٢٠٧، وابن جرير ١١/٥٢٦.أخرجه ابن أبي حاتم ٦/١٨٢٤.علَّقه ابن أبي حاتم ٦/١٨٢٤.تفسير مقاتل بن سليمان ٢/١٧٦-١٧٧.أخرجه ابن جرير ١١/٥٢٦.تفسير الثعلبي ٥/٦١.أخرجه أحمد ١٨/٩٦-٩٧ (١١٥٣٨)، وأبو داود ٣/٧٧ (١٦٣٦)، وابن ماجه ٣/٤٩ (١٨٤١)، وابن خزيمة ٤/١١٨-١١٩ (٢٣٦٨)، ٤/١٢٢ (٢٣٧٤)، والحاكم ١/٥٦٦ (١٤٨٠). وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه؛ لإرسال مالك بن أنس إيّاه عن زيد بن أسلم». وقال الألباني في صحيح سنن أبي داود ٥/٣٣٧ (١٤٤٥): «إسناده صحيح مرسلًا ومسندًا».تفسير مقاتل بن سليمان ٢/١٧٦-١٧٧.علَّقه ابن أبي حاتم ٦/١٨٢٥.أخرجه ابن جرير ١١/٥٢٧-٥٢٨، وابن أبي حاتم ٦/١٨٢٥. وعزاه السيوطي إلى أبي الشيخ.البَكْرُ: الفَتِيُّ من الإبل. النهاية (بكر).أخرجه أحمد ٤٥/٦٧-٧١، ٢٦٠ (٢٧١٠٦، ٢٧١٠٧، ٢٧٢٨٦)، وأبو داود ٢/٢٠٤ (١٩٨٧)، وابن خزيمة ٤/٣٦٠ (٣٠٧٥)، والحاكم في المستدرك ١/٦٥٦، وابن أبي حاتم ٦/١٨٢٥ (١٠٣٩٤). قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه».تفسير البغوي ٤/٦٥.أخرجه ابن أبي حاتم ٦/١٨٢٤.أخرجه ابن أبي حاتم ٦/١٨٢٥ وزاد في أوله: يحمل من الصدقة مَن ليس له حملان. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر دون آخره.تفسير الثعلبي ٥/٦١.تفسير الثعلبي ٥/٦١.أخرجه ابن أبي حاتم ٦/١٨٢٥.أخرجه ابن جرير ١١/٥٢٩.أخرجه ابن أبي شيبة ٣/٢١١، وابن جرير ١١/٥٣٠ بنحوه.أخرجه ابن أبي شيبة ٣/٢٠٧، وابن جرير ١١/٥٢٩، وابن أبي حاتم ٦/١٨٢٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٦/١٨٢٥.أخرجه ابن جرير ١١/٥٣٠.أخرجه ابن أبي حاتم ٦/١٨٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١١/٥٣٠.أخرجه ابن أبي حاتم ٦/١٨٢٥.تفسير مقاتل بن سليمان ٢/١٧٦-١٧٧.تفسير الثعلبي ٥/٦٢.أخرجه ابن جرير ١١/٥٣٠، وابن أبي حاتم ٦/١٨٢٥ مختصرًا من طريق أصبغ. وكذا عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٨٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/١٨٣.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٨٦ (١٨٦).أخرجه النحاس ص٥٠٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/١٧٦-١٧٧.عزاه السيوطي إلى ابن المنذر.أخرجه الطبراني في الكبير ٥/٢٦٢ (٥٢٨٥)، وأبو نعيم في معرفة الصحابة ٣/١٢٠٦-١٢٠٨ (٣٠٤١)، كلاهما مُطَوَّلًا. وقال الهيثمي في المجمع ٥/٢٠٣-٢٠٤ (٩٠٣١): «رواه الطبراني، وفيه عبد الرحمن بن زياد بن أنعم، وهو ضعيف، وقد وثَّقه أحمد بن صالح، وردَّ على مَن تكلم فيه، وبقية رجاله ثقات».أخرجه أبو داود ٣/٧٧ (١٦٣٥)، والحاكم ١/٥٦٦ (١٤٨١)، وابن جرير ١١/٥٢٨ واللفظ له. قال الحاكم: «هذا من شرطي في خطبة الكتاب أنّه صحيح، فقد يُرسِل مالكٌ في الحديث، ويصله، أو يسنده ثقة، والقول فيه قول الثقة الذي يصله ويسنده». وقال الألباني في صحيح سنن أبي داود ٥/٣٣٧ (١٤٤٥): «إسناده صحيح مرسلًا ومسندًا». وتقدم نحوه مسندًا عن أبي سعيد عند تفسير قوله تعالى: <q>﴿وفِي سَبِيلِ اللَّهِ﴾</q>.أخرجه أحمد ٢٧/١٣٩ (١٦٥٩٤)، ٣٨/٢٤٢ (٢٣١٨٣). قال الهيثمي في المجمع ٣/٩٢ (٤٤٩٩): «رواه أحمد، ورجاله رجال الصحيح». وقال الألباني في الإرواء ٣/٣٨١ (٨٧٧): «صحيح».أخرجه أحمد ١١/٨٤ (٦٥٣٠)، ١١/٤٠٣ (٦٧٩٨)، وأبو داود ٣/٧٥-٧٦ (١٦٣٤)، والترمذي ٢/١٩٠-١٩١ (٦٥٨)، والحاكم ١/٥٦٥ (١٤٧٨). قال الترمذي: «حديث حسن». وقال ابن حجر في التلخيص الحبير ٣/٢٣٨: «بسند حسن». وقال الشوكاني في نيل الأوطار ٤/١٨٩: «حسَّنه الترمذيُّ، وذكر أنّ شعبة لم يرفعه، وفي إسناده ريحان بن يزيد، وثَّقه يحيى بن معين. وقال أبو حاتم الرازي: شيخ مجهول. وقال بعضهم: لم يصحَّ إسنادُ هذا الحديث، وإنّما هو موقوف على عبد الله بن عمرو». وقال الألباني في صحيح أبي داود ٥/٣٣٦ (١٤٤٤): «حديث صحيح».أخرجه أحمد ٢٩/٤٨٦-٤٨٧ (١٧٩٧٢، ١٧٩٧٣)، ٣٨/١٦٢ (٢٣٠٦٣)، وأبو داود ٣/٧٥ (١٦٣٣)، والنسائي ٥/٩٩ (٢٥٩٨). قال النووي في تهذيب الأسماء واللغات ١/٣١٣: «رواه أبو داود، والنسائي، وغيرهما بأسانيد صحيحة، والرجلان المبهمان لا تضرُّ جهالةُ أعيانهما؛ لأنهما صحابيان، والصحابة كلهم عدول». وقال ابن كثير في تفسيره ٤/١٦٦: «إسناد جيد قوي». وقال الزيلعي في نصب الراية ٢/٤٠١: «وقال صاحب التنقيح: حديث صحيح، ورواته ثقات، قال الإمام أحمد ﵁: ما أجوده من حديث، هو أحسنها إسنادًا». وقال ابن الملقن في خلاصة البدر المنير ٢/١٦٠: «قال أحمد: هذا إسناد جيد». وقال الهيثمي في المجمع ٣/٩٢ (٤٤٩٧): «رواه الطبراني في الأوسط، ورجاله رجال الصحيح». وقال الألباني في صحيح أبي داود ٥/٣٣٥ (١٤٤٣): «إسناده صحيح، على شرط البخاري، وصحَّحه ابن عبد الهادي، وجوَّده أحمد».الخمش والكدح: بمعنى الخدش، وخَدْشُ الجلد: قَشْرُه بعود أو نحوه. النهاية (خمش)، (كدح)، (خدش).أخرجه أحمد ٦/١٩٤-١٩٥ (٣٦٧٥)، ٧/٢٥٩ (٤٢٠٧)، ٧/٤٣٩ (٤٤٤٠)، وأبو داود ٣/٦٨-٦٩ (١٦٢٦)، والترمذي ٢/١٨٨-١٨٩ (٦٥٦)، والنسائي ٥/٩٧ (٢٥٩٢)، وابن ماجه ٣/٤٨-٤٩ (١٨٤٠)، والحاكم ١/٥٦٥ (١٤٧٩). قال الترمذي: «حديث حسن». وقال النسائي في الكبرى ٣/٧٧ (٢٣٨٤): «لا نعلم أحدًا قال في هذا الحديث: زبيد، غير يحيى بن آدم، ولا نعرف هذا الحديث إلا من حديث حكيم بن جبير، وحكيم ضعيف. وسُئِل شعبة عن حديث حكيم، فقال: أخاف النار. وقد كان روى عنه قديمًا». وقال ابن القيسراني في أطراف الغرائب ٤/٩٠-٩١ (٣٦٨٨): «غريب». وقال الألباني في صحيح أبي داود ٥/٣٢٩ (١٤٣٨): «إسناده صحيح».أخرجه ابن أبي شيبة ٣/١٧٨.
9,61," <q>﴿وَمِنۡهُمُ ٱلَّذِینَ یُؤۡذُونَ ٱلنَّبِیَّ وَیَقُولُونَ هُوَ أُذُنࣱۚ قُلۡ أُذُنُ خَیۡرࣲ لَّكُمۡ یُؤۡمِنُ بِٱللَّهِ وَیُؤۡمِنُ لِلۡمُؤۡمِنِینَ وَرَحۡمَةࣱ لِّلَّذِینَ ءَامَنُوا۟ مِنكُمۡۚ وَٱلَّذِینَ یُؤۡذُونَ رَسُولَ ٱللَّهِ لَهُمۡ عَذَابٌ أَلِیمࣱ ۝٦١﴾</q> - نزول الآية ٣٢٨٧٥- عن عمير بن سعد -من طريق كثير بن مُرَّة- قال: فِيَّ أُنزِلت هذه الآيةُ: <q>﴿ويقُولُون هو أذنٌ﴾</q>. وذلك أنّ عمير بن سعد كان يسمعُ أحاديثَ أهل المدينة، فيأتي النبيَّ ﷺ فيُسارُّه، حتى كانوا يَتَأذَّوْن بعمير بن سعدٍ، وكرهوا مجالسته، وقالوا: هو أُذُنٌ. فأُنزِلت فيه{1}. (٧/٤٢٢) ٣٢٨٧٦- عن عبد الله بن عباس -من طريق ابن إسحاق بسنده- قال: كان نَبْتَلُ بن الحارث يأتي رسولَ الله ﷺ، فيجلسُ إليه، فيسمع منه، ثم ينقلُ حديثه إلى المنافقين، وهو الذي قال لهم: إنّما محمدٌ أُذُنٌ، مَن حدَّثه شيئًا صدَّقه. فأنزل الله فيه:<q>﴿ومنهُمُ الذين يُؤذُون النَّبِيَّ ويقُولُون هو أذنٌ﴾</q> الآية{2}. (٧/٤٢١) ٣٢٨٧٧- عن إسماعيل السُّدِّيِّ -من طريق أسْباط- قال: اجتمع ناسٌ مِن المنافقين؛ فيهم جُلاسُ بنُ سويد بن صامتٍ، ومَخْشِيُّ بن حُمَيِّرٍ، ووديعة بن ثابتٍ، فأرادوا أن يَقَعُوا في النبيِّ ﷺ، فنهى بعضُهم بعضًا، وقالوا: إنّا نخاف أن يبلغ محمدًا، فيقع بكم. وقال بعضهم: إنّما محمدٌ أُذُن، نحلف له فيُصَدِّقنا. فنزل: <q>﴿ومنهُمُ الَّذين يؤذونَ النبيَّ﴾</q> الآية{3}. (٧/٤٢١) ٣٢٨٧٨- عن محمد بن إسحاق -من طريق سلمة- قال: ذكر اللهُ عيبَهم -يعني: المنافقين- وأذاهم للنبي ﷺ، فقال: <q>﴿ومنهم الذين يؤذون النبي ويقولون هو أذن﴾</q> الآية، وكان الذي يقول تلك المقالة -فيما بلغني- نَبْتَلُ بن الحارث، أخو بني عمرو بن عوف، وفيه نزلت هذه الآية، وذلك أنّه قال: إنما محمد أُذُنٌ؛ مَن حدَّثه شيئًا صدَّقه. يقول الله: <q>﴿قل أذن خير لكم﴾</q>. أي: يسمع الخيرَ، ويُصَدِّق به{4}. (ز) ٣٢٨٧٩- قال مقاتل بن سليمان: <q>﴿ومِنهُمُ﴾</q> يعني: من المنافقين <q>﴿الَّذِينَ يُؤْذُونَ النَّبِيَّ﴾</q> ﷺ؛ منهم: الجُلاسُ بن سويد، وشماس بن قيس، والمَخْشِيُّ بن حُمَيِّرٍ، وسماك بن يزيد، وعبيد بن الحارث، ورفاعة بن زيد، ورفاعة بن عبد المنذر، قالوا ما لا ينبغي، فقال رجل منهم: لا تفعلوا؛ فإنّا نخاف أن يبلغ محمدًا، فيقع بنا. فقال الجلاس: نقول ما شِئنا، فإنّما محمدٌ أذنٌ سامِعَةٌ، فنأتيه بما نقول. فنزلت في الجلاس: <q>﴿ويَقُولُونَ هُوَ أُذُنٌ﴾</q>، يعني: النبي ﷺ{5}. (ز) <q>﴿وَمِنۡهُمُ ٱلَّذِینَ یُؤۡذُونَ ٱلنَّبِیَّ وَیَقُولُونَ هُوَ أُذُنࣱۚ﴾</q> - تفسير ٣٢٨٨٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ويقولون هُوَ أذنٌ﴾</q>، يعني: أنّه يسمعُ مِن كلِّ أحدٍ{6}٢٩٨٤. (٧/٤٢١) ٢٩٨٤ علَّق ابنُ عطية (٤/٣٥٠بتصرف) على هذا القول، فقال: «فهذا تَشَكُّكٌ من المنافقين، ووَصْفٌ بأنّه يسوغ عنده الأباطيل والنمائم». ٣٢٨٨١- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قوله:<q>﴿ويقولونَ هو أذُنٌ﴾</q>، أي: يسمعُ ما يُقالُ له{7}. (٧/٤٢٢) ٣٢٨٨٢- قال عبد الله بن عباس: <q>﴿أُذُن﴾</q> يُصَدِّقُ{8}. (ز) ٣٢٨٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ويقولون هُوَ أذنٌ﴾</q>، يقولون: سنقولُ له ما شئنا، ثم نحلفُ له فيُصَدِّقُنا{9}. (٧/٤٢٢) ٣٢٨٨٤- قال الحسن البصري: كانوا يقولون: هذا الرجل أُذُن، مَن شاء صرفه حيث شاء، ليست له عزيمة. فقال الله ﷿ لنبيه: <q>﴿قل أذن خير لكم يؤمن بالله﴾</q>{10}٢٩٨٥. (ز) ٢٩٨٥ علَّق ابنُ عطية (٤/٣٥٠) على هذا القول الذي قاله مجاهد، والحسن، فقال: «فهذا تنقُّصٌ بقِلَّة الحزامة، والانخداع». ٣٢٨٨٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ومنهم الذين يؤذون النبي ويقولون هو أذن﴾</q>، قال: كانوا يقولون: إنّما محمدٌ أُذُن، لا يُحَدَّث عَنّا شيئًا إلا هو أُذُنٌ، يسمع ما يُقال له{11}. (ز) ٣٢٨٨٦- عن عطاء [الخراساني] -من طريق ابنه عثمان- قال: الأذنُ: الذي يسمعُ مِن كل أحدٍ، ويُصَدِّقُه{12}. (٧/٤٢٢) <q>﴿قُلۡ أُذُنُ خَیۡرࣲ لَّكُمۡ یُؤۡمِنُ بِٱللَّهِ وَیُؤۡمِنُ لِلۡمُؤۡمِنِینَ﴾</q> - تفسير ٣٢٨٨٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿قل أذُنُ خيرٍ لكُم يؤمنُ باللهِ ويؤمنُ للمؤمنينَ﴾</q>، يعني: يُصَدِّقُ بالله، ويُصَدِّق المؤمنين{13}. (٧/٤٢١) ٣٢٨٨٨- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله:<q>﴿يؤمنُ بالله﴾</q> قال: يُصَدِّق اللهَ بما أنزل إليه، <q>﴿ويؤمنُ للمؤمنينَ﴾</q> قال: يصدقُ المؤمنين فيما بينهم؛ في شهاداتهم، وأَيْمانِهم، على حقوقهم، وفروجهم، وأموالهم{12}. (٧/٤٢٢) ٣٢٨٨٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿يُؤْمِنُ بِاللَّهِ﴾</q> يقول: يُؤْمِن إذا حُلِف له بالله، <q>﴿ويُؤْمِنُ لِلْمُؤْمِنِينَ﴾</q> ويُصَدِّق المؤمنين{15}. (ز) ٣٢٨٩٠- قال مقاتل بن سليمان: <q>﴿قُلْ أُذُنُ خَيْرٍ لَكُمْ يُؤْمِنُ بِاللَّهِ ويُؤْمِنُ لِلْمُؤْمِنِينَ﴾</q>، يعني: يُصَدِّق بالله، ويُصَدِّق المؤمنين{5}. (ز) ٣٢٨٩١- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿قل أذن خير لكم﴾</q>، أي: يسمع الخيرَ، ويُصَدِّق به{4}. (ز) ٣٢٨٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- يقول في قول الله: <q>﴿يؤمن بالله ويؤمن للمؤمنين﴾</q>، قال: يُصَدِّقكم ويسمعُ كلامَكم خير مِن أن لا يُصَدِّقَكم. قال: فكادوه بكل شيء، فقالوا: لا، واللهِ، ما يعلمه هذا إلا يحنَّس الحداد النصراني. وكان أعجَمِيًّا يعمل الحديد{18}. (ز) <q>﴿وَرَحۡمَةࣱ لِّلَّذِینَ ءَامَنُوا۟ مِنكُمۡۚ وَٱلَّذِینَ یُؤۡذُونَ رَسُولَ ٱللَّهِ لَهُمۡ عَذَابٌ أَلِیمࣱ ۝٦١﴾</q> - تفسير ٣٢٨٩٣- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿ورحمة للذين آمنوا منكم﴾</q>، قال: رحمة لكم{19}. (ز) ٣٢٨٩٤- قال مقاتل بن سليمان: <q>﴿ورَحْمَةٌ لِلَّذِينَ آمَنُوا مِنكُمْ﴾</q> يقول: محمد رحمة للمؤمنين، كقوله: <q>﴿رَؤُفٌ رَحِيمٌ﴾</q> [التوبة:١٢٨] يعني: للمُصَدِّقين بتوحيد الله رءوف رحيم، <q>﴿والَّذِينَ يُؤْذُونَ رَسُولَ اللَّهِ لَهُمْ عَذابٌ ألِيمٌ﴾</q> يعني: وجِيع{5}. (ز) ",footnotes:1:أخرجه الطبراني في مسند الشاميين ٣/٣٨٦ (٢٥٢٣)، ومن طريقه ابن عساكر في تاريخ دمشق ٤٦/٤٨٠، من طريق عمرو بن إسحاق بن إبراهيم بن العلاء بن زبريق الحمصي، نا أبو علقمة نصر بن خزيمة، أنا محفوظ بن علقمة، أن أباه حدثه عن نصر بن علقمة، عن أخيه محفوظ بن علقمة، عن ابن عائذ، قال: قال كثير بن مرة، قال: عمير بن سعد. إسناده ضعيف؛ لجهالة نصر بن خزيمة وأبوه، فلم يذكرهما أحدٌ بجرحٍ أو تعديل، ولهذا الإسناد نسخةٌ كبيرة، رُوِيَت بها أحاديث كثيرة.أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٢١-، وابن أبي حاتم ٦/١٨٢٦. وعزاه السيوطي إلى ابن المنذر. وهو من طريق محمد بن إسحاق، عن محمد بن أبي محمد مولى زيد بن ثابت، عن سعيد بن جبير أو عكرمة، عن ابن عباس. قال السيوطي في الإتقان ٦/٢٣٣٦ عن هذه الطريق: «هي طريق جيدة، وإسنادها حسن، وقد أخرج منها ابن جرير وابن أبي حاتم كثيرًا».أخرجه ابن أبي حاتم ٦/١٨٢٦ مُطَوَّلًا.أخرجه ابن جرير ١١/٥٣٥.تفسير مقاتل بن سليمان ٢/١٧٨.أخرجه ابن جرير ١١/٥٣٦-٥٣٨، وابن أبي حاتم ٦/١٨٢٧. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٦/١٨٢٦.علَّقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التفسير - عقِب باب: <q>﴿براءة من الله ورسوله...﴾</q> ٤/١٧٠٨. قال الحافظ في فتح الباري (٨/٣١٦): وصله ابنُ أبي حاتم من طريق علي بن أبي طلحة عن ابن عباس في قوله: <q>﴿ويقولون هو أذن﴾</q> يعني: أنّه يسمع مِن كل أحد، قال الله: <q>﴿قل أذن خير لكم يؤمن بالله﴾</q> يعني: يُصَدِّق بالله. وظهر أنّ «يصدق» تفسير <q>﴿يؤمن﴾</q>، لا تفسير <q>﴿أذن﴾</q> كما يفهمه صنيعُ المصنف حيث اختصره.تفسير مجاهد ص٣٧١، وأخرجه ابن جرير ١١/٥٣٧، وابن أبي حاتم ٦/١٨٢٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢١٤-.أخرجه ابن جرير ١١/٥٣٧.أخرجه ابن أبي حاتم ٦/١٨٢٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٥٣٨، وابن أبي حاتم ٦/١٨٢٧. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٦/١٨٢٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٨٢٧، وعلَّقه في شطره الثاني.تفسير مقاتل بن سليمان ٢/١٧٨.أخرجه ابن جرير ١١/٥٣٥.أخرجه ابن أبي حاتم ٦/١٨٢٧.أخرجه ابن أبي حاتم ٦/١٨٢٨.تفسير مقاتل بن سليمان ٢/١٧٨.
