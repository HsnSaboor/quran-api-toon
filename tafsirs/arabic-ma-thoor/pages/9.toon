tafsir[4]{c,v,t}:
2,58," <q>﴿وَإِذۡ قُلۡنَا ٱدۡخُلُوا۟ هَـٰذِهِ ٱلۡقَرۡیَةَ﴾</q> - تفسير ١٨٨٦- عن عبد الله بن عباس، قال: هي أريحا، وهي قرية الجبّارين{1}. (ز) ١٨٨٧- عن مجاهد بن جبر: بيت المقدس{1}. (ز) ١٨٨٨- عن الضَّحّاك بن مُزاحِم: هي الرّملة، والأردن، وفلسطين، وتدمر{1}. (ز) ١٨٨٩- عن قتادة بن دِعامة -من طريق مَعْمر- في قوله: <q>﴿ادخلوا هذه القرية﴾</q>، قال: بيت المقدس{4}. (١/٣٧٧) ١٨٩٠- عن إسماعيل السُّدِّي -من طريق أسْباط- <q>﴿وإذْ قُلْنا ادْخُلُوا هَذِهِ القَرْيَةَ﴾</q>، قال: أمّا القرية فبيت المقدس{5}. (ز) ١٨٩١- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وإذْ قُلْنا ادْخُلُوا هَذِهِ القَرْيَةَ﴾</q>، يعني: بيت المقدس{5}. (ز) ١٨٩٢- قال مقاتل بن سليمان: <q>﴿وإذْ قُلْنا ادْخُلُوا هَذِهِ القَرْيَةَ﴾</q>، يعني: إيلْياء، وهم يومئذ من وراء البحر{7}. (ز) ١٨٩٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- قال: هي أريحا، وهي قريبة من بيت المقدس{8}٢٤٠. (ز) ٢٤٠ انتقد ابنُ كثير (١/٤١٧) القول بأنها أريحا، معللًا ذلك بمخالفته للدلالات العقلية، فقال: «وقال آخرون: هي أريحا، ... وهذا بعيد؛ لأنها ليست على طريقهم، وهم قاصدون بيت المقدس لا أريحا، ... والصحيح هو الأول؛ لأنها بيت المقدس». ويلاحظ أن ابنَ جرير (١/٧١٣) ذكر أثر ابن زيد ضمن الآثار التي أوردها لبيان أن القرية التي أُمروا بدخولها بيت المقدس، ولم يجعل قوله مخالفًا لبقية الأقوال كما فعل ابن كثير. <q>﴿فَكُلُوا۟ مِنۡهَا حَیۡثُ شِئۡتُمۡ رَغَدࣰا﴾</q> - تفسير ١٨٩٤- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- <q>﴿رغدا﴾</q>، قال: بلا حساب عليهم{9}. (ز) ١٨٩٥- عن إسماعيل السُّدِّي -من طريق أسْباط- <q>﴿رغدا﴾</q>، قال: الهنيء{10}. (ز) ١٨٩٦- قال مقاتل بن سليمان: <q>﴿فكلوا منها حيث شئتم رغدا﴾</q>، يعني: ما شئتم، وإذ شئتم، وحيث شئتم{11}. (ز) <q>﴿وَٱدۡخُلُوا۟ ٱلۡبَابَ﴾</q> - تفسير ١٨٩٧- عن أبي سعيد الخدري، عن النبي ﷺ: «قال الله لبني إسرائيل: <q>﴿وادخلوا الباب سجدا وقولوا حطة نغفر لكم خطاياكم﴾</q>»{12}. (١/٣٨٠) ١٨٩٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وادْخُلُوا البابَ سجدا﴾</q>، قال: باب صغير{13}. (١/٣٧٧) ١٨٩٩- عن عبد الله بن عباس -من طريق عكرمة- قال: كان الباب قِبَل القبلة{10}. (١/٣٧٩) ١٩٠٠- عن عبد الله بن عباس -من طريق العَوْفي- في قوله: <q>﴿وادخلوا الباب سجدا﴾</q>، قال: هو أحد أبواب بيت المقدس، وهو يُدْعى: باب حِطَّة{15}. (١/٣٧٧) ١٩٠١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قال: باب حِطَّة مِن باب إيلْياء بيت المقدس{16}. (١/٣٧٩) ١٩٠٢- وعن الضَّحّاك بن مُزاحم، نحوه{17}. (ز) ١٩٠٣- عن قتادة بن دِعامة، في قوله: <q>﴿وادخلوا الباب سجدا﴾</q>، قال: كنا نتحدث أنه باب من أبواب بيت المقدس{18}. (١/٣٧٩) ١٩٠٤- عن إسماعيل السُّدِّي -من طريق أسْباط- <q>﴿وادخلوا الباب سجدا﴾</q>، قال: أمّا الباب فباب من أبواب بيت المقدس{19}. (ز) ١٩٠٥- قال مقاتل بن سليمان: <q>﴿وادخلوا الباب سجدا﴾</q>، يعني: باب إيلْياء سُجَّدًا، فدخلوا مُتَحَرِّفِين على شق وجوههم{20}٢٤١. (ز) ٢٤١ نقل ابن عطية (١/٢٢٢) قولين آخرين في معنى الباب؛ فقال: «وقيل: هو باب القبة التي كان يصلي إليها موسى ﵇. وروي عن مجاهد أيضًا: أنّه باب في الجبل الذي كلَّم عليه موسى كالفرضة». <q>﴿سُجَّدࣰا﴾</q> - تفسير ١٩٠٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وادْخُلُوا البابَ سُجَّدًا﴾</q>، قال: أُمِرُوا أن يدخلوا رُكَّعًا من باب صغير، فدخلوا من قِبَل أسْتاهِهِم{21}٢٤٢. (١/٣٧٧) ٢٤٢ وجَّه ابنُ جرير (١/٧١٤-٧١٥ بتصرف) معنى السجود في أثر ابن عباس قائلًا: «وأصل السجود: الانحناء لمن سجد له معظمًا بذلك. فكل مُنْحَنٍ لشيء تعظيمًا له فهو ساجد ... فذلك تأويل ابن عباس قوله: <q>﴿سجدا﴾</q>: ركعًا؛ لأن الراكع منحنٍ، وإن كان الساجد أشد انحناء منه». ووجَّه ابنُ تيمية (١/٢١٤-٢١٦) تفسير السجود بالانحناء أو بالركوع بقوله: «السجود في اللغة: هو الخضوع. وقال غير واحد من المفسرين: أمروا أن يدخلوا رُكَّعًا منحنين، فإنّ الدخول مع وضع الجبهة على الأرض لا يمكن، وقد قال تعالى: <q>﴿ألم تر أن الله يسجد له من في السماوات ومن في الأرض والشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس﴾</q> ...، ومعلوم أنّ سجود كل شيء بحسبه، ليس سجود هذه المخلوقات وضع جباهها على الأرض، وقد قال النبي ﷺ ... لما غربت الشمس: «إنها تذهب فتسجد تحت العرش» ... فعُلِم أنّ السجود اسم جنس، وهو كمال الخضوع لله». وقال أيضًا: «من قال بهذا -كان سجود أحدهم على خده- أو قال بأنهم أمروا بالركوع، فهو يقول دخولهم وهم سجد بالأرض فيه صعوبة، وقد يؤذي أحدهم، ولكن هو ممكن، فإنّ الإنسان يمكنه حال السجود أن يزحف إذا كانت الأرض لا تؤذيه». وانتَقَدَ ابنُ تيمية (١/٢١٧) أيضًا هذا المعنى بقوله: «... وقال: قيل ادخلوا رُكَّعًا، فلو جزمنا أن هذا مأخوذ عن النبي ﷺ لجزمنا بأنّ الله أمرهم بالركوع، لكن ظاهر القرآن هو السجود، والسجود المطلق هو السجود المعروف، وكون الباب جعل صغيرًا إنما يكون لمن يُكره على الدخول منه ليحتاج أن ينحني، وهؤلاء قصدت طاعتهم، فأمروا بالخضوع لله والاستغفار، فدخولهم سُجَّدًا هو خضوع لله». ورجَّح ابنُ عطية (١/٢٢٢) عموم معنى السجود للقولين، فقال: «و<q>﴿سجَّدًا﴾</q> قال ابن عباس ﵄: معناه: ركوعًا. وقيل: متواضعين خضوعًا لا على هيئة معينة. والسجود يعم هذا كله؛ لأنه التواضع». ١٩٠٧- عن عبد الله بن عباس -من طريق عِكْرِمة- <q>﴿وادخلوا الباب سجدا﴾</q>، قال: فدخلوا على شِقٍّ{22}. (ز) ١٩٠٨- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- قال: أمَر موسى قومَه أن يدخلوا المسجد، ويقولوا: حِطَّة، وطُؤْطِئَ لهم الباب ليخفضوا رؤوسهم{23}. (ز) ١٩٠٩- عن عِكْرِمة مولى ابن عباس، في قوله: <q>﴿وادخلوا الباب سجدا﴾</q>، قال: طَأْطِئُوا رؤوسكم{24}. (١/٣٧٩) <q>﴿وَقُولُوا۟ حِطَّةࣱ نَّغۡفِرۡ لَكُمۡ﴾</q> - تفسير ١٩١٠- عن عبد الله بن عباس -من طريق سعيد بن جُبَيْر- في قوله: <q>﴿وقولوا حطة﴾</q>، قال: مغفرة{25}. (١/٣٧٧) ١٩١١- عن عبد الله بن عباس -من طريق عِكْرِمَة- في قوله: <q>﴿وقولوا حطة﴾</q>، قال: لا إله إلا الله{26}. (١/٣٧٩) ١٩١٢- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قوله: <q>﴿وقولوا حطة﴾</q>، قال: قولوا: هذا الأمرَ حقٌّ. كما قيل لكم{27}. (ز) ١٩١٣- عن الأوزاعي، قال: كتب ابن عباس إلى رجل قد سمّاه يسأله عن قوله: <q>﴿وقولوا حطة﴾</q>. فكتب إليه: أن أقِرُّوا بالذنب{22}. (ز) ١٩١٤- عن البراء [بن عازب] -من طريق أبي إسحاق- في قول الله: <q>﴿سيقول السفهاء من الناس﴾</q> [البقرة:١٤٢]، قال: اليهود، قيل لهم: <q>﴿وادخلوا الباب سجدا﴾</q> قال: ركعًا، <q>﴿وقولوا حطة﴾</q>: مغفرة، فدخلوا على أسْتاهِهم، وجعلوا يقولون: حنطة: حبة حمراء فيها شعرة، فذلك قوله تعالى: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{29}. (ز) ١٩١٥- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- قال: باب حِطَّة من باب بيت المقدس، أمر موسى قومه أن يدخلوا ويقولوا: حِطَّة. وطُؤْطِىءَ لهم الباب ليخفضوا رؤوسهم، فلما سجدوا قالوا: حِنطَة{30}. (١/٣٧٩) ١٩١٦- عن عِكْرِمة مولى ابن عباس -من طريق الحَكَمِ بن أبان- في قوله: <q>﴿وقولوا حطة﴾</q>، قال: قولوا: لا إله إلا الله{31}٢٤٣٢٤٤. (١/٣٧٩) ٢٤٣ وجَّه ابنُ جرير (١/٧١٧) أثر عكرمة قائلًا: «كأنهم وجَّهوا تأويله: قولوا الذي يحط عنكم خطاياكم، وهو قول: لا إله إلا الله». ووجهه ابنُ القيم (١/١٢٦) بقوله: «وكأن أصحاب هذا القول اعتبروا الكلمة التي تحط بها الخطايا، وهي كلمة التوحيد». ٢٤٤ بيَّن ابنُ جرير (١/٧١٩) إعراب <q>﴿حطة﴾</q> على قول عكرمة بقوله: «وأما على تأويل قول عكرمة فإنّ الواجب أن تكون القراءة بالنصب في <q>﴿حطة﴾</q>؛ لأن القوم إن كانوا أمروا أن يقولوا: لا إله إلا الله، أو أن يقولوا: نستغفر الله، فقد قيل لهم: قولوا هذا القول، فـ<q>﴿قولوا﴾</q> واقع حينئذ على الحطة؛ لأنّ الحطة على قول عكرمة هي قول: لا إله إلا الله، وإذا كانت هي قول: لا إله إلا الله، فالقول عليها واقع، كما لو أمر رجل رجلًا بقول الخير فقال له: (قل خيرًا) نصبًا، ولم يكن صوابًا أن يقول له: قل خير، إلا على استكراه شديد». ثم انتَقَد ابنُ جرير قول عكرمة معللًا ذلك بمخالفته لإجماع القراء، فقال: «وفي إجماع القَرَأة على رفع الحطة بيان واضح على خلاف الذي قاله عكرمة من التأويل في قوله: <q>﴿وقولوا حطة﴾</q>». وقال ابنُ عطية (١/٢٢٢، ٢٢٣) موجِّهًا: «وقال عكرمة وغيره: أمروا أن يقولوا: لا إله إلا الله، لتحط بها ذنوبهم. وقال ابن عباس: قيل لهم: استغفروا، وقولوا ما يحط ذنوبكم. وقال آخرون: قيل لهم أن يقولوا: هذا الأمر حقٌّ كما أُعْلِمنا. وهذه الأقوال الثلاثة تقتضي النصب». ١٩١٧- عن الحسن البصري= (ز) ١٩١٨- وقتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿وقولوا حطة﴾</q>، أي: احْطُط عنا خطايانا{32}٢٤٥٢٤٦. (١/٣٧٨) ٢٤٥ بيَّن ابنُ جرير (١/٧٢٠ بتصرف) إعراب <q>﴿حطة﴾</q> على قول الحسن وقتادة بقوله: «الواجب على التأويل الذي رويناه عن الحسن وقتادة في قوله: <q>﴿وقولوا حطة﴾</q> أن تكون القراءة في <q>﴿حطة﴾</q> نصبًا؛ لأن من شأن العرب إذا وضعوا المصادر مواضع الأفعال وحذفوا الأفعال أن ينصبوا المصادر، كقول القائل للرجل: سمعًا وطاعة. بمعنى: أسمع سمعًا وأطيع طاعةً، وكما قال جل ثناؤه: <q>﴿معاذ الله﴾</q> [يوسف:٢٣]. بمعنى: نعوذ بالله». ٢٤٦ علَّق ابنُ القيم (١/١٢٦) على قول مَن قال: أُمِروا بكلمة التوحيد. وكذا قول مَن قال: أمُروا بالاستغفار. بقوله (١/١٢٦): «وعلى القولين فيكونون مأمورين بالدخول بالتوحيد والاستغفار، وضُمِن لهم بذلك مغفرة خطاياهم». ١٩١٩- عن ابن جُرَيْجٍ، قال: قال لي عطاء في قوله: <q>﴿وقولوا حطة﴾</q>، قال: سمعنا أنه يحط عنهم خطاياهم{33}. (ز) ١٩٢٠- وقال وهْب بن مُنَبِّه: قيل لهم: ادخلوا الباب، فإذا دخلتموه فاسجدوا شكرًا لله ﷿{1}٢٤٧. (ز) ٢٤٧ وجَّه ابنُ تيمية (١/٢١٦) هذا القول بقوله: «فكأنّ صاحب هذا القول جعل السجود بعد الدخول». ١٩٢١- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وقولوا حطة﴾</q>، قال: تُحَطُّ عنكم خطاياكم{35}. (ز) ١٩٢٢- قال مقاتل بن سليمان: <q>﴿وقولوا حطة﴾</q>، وذلك أنّ بني إسرائيل خرجوا مع يُوشَع بن نُون بن اليشامع بن عميهوذ بن غيران بن شونالخ بن إفْرايِيم بن يوسف ﵇ من أرض التيه إلى العُمْران حِيال أرِيحا، وكانوا أصابوا خطيئة، فأراد الله ﷿ أن يغفر لهم، وكانت الخطيئة أنّ موسى ﵇ كان أمرهم أن يدخلوا أرض أريحا التي فيها الجبارون، فلهذا قال لهم: <q>﴿قولوا حطة﴾</q>، يعني: بحطة حُطَّ عنا خطايانا{20}. (ز) ١٩٢٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهَبْ- قال: <q>﴿وقولوا حطة﴾</q> يحط الله بها عنكم ذنبكم وخطيئتكم{37}٢٤٨. (ز) ٢٤٨ رجَّح ابنُ جرير (١/٧١٩) رفع <q>﴿حطة﴾</q>، وأنّ معناها: احطط عنا خطايانا، مستندًا إلى ظاهر القرآن، وإلى النظائر، فقال: «والذي هو أقرب عندي في ذلك إلى الصواب، وأشبه بظاهر الكتاب: أن يكون رفع <q>﴿حطة﴾</q> بنية خبر محذوف قد دل عليه ظاهر التلاوة، وهو: دخولنا الباب سجدًا حطة. فكفى من تكريره بهذا اللفظ ما دلَّ عليه الظاهر من التنزيل، وهو قوله: <q>﴿وادخلوا الباب سجدا﴾</q>، كما قال -جلَّ ثناؤه-: <q>﴿وإذ قالت أمة منهم لم تعظون قوما الله مهلكهم أو معذبهم عذابا شديدا قالوا معذرة إلى ربكم﴾</q> [الأعراف:١٦٤]، يعني: موعظتنا إياهم معذرة إلى ربكم، فكذلك عندي تأويل قوله: <q>﴿وقولوا حطة﴾</q>، يعني بذلك: وإذ قلنا ادخلوا هذه القرية، وادخلوا الباب سجدًا، وقولوا: دخولنا ذلك سجدًا حطة لذنوبنا. وهذا القول على نحو تأويل الربيع بن أنس، وابن جريج، وابن زيد، الذي ذكرناه آنفًا». <q>﴿نَّغۡفِرۡ لَكُمۡ خَطَـٰیَـٰكُمۡۚ وَسَنَزِیدُ ٱلۡمُحۡسِنِینَ ۝٥٨﴾</q> - تفسير ١٩٢٤- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿وسنزيد المحسنين﴾</q>، قال: مَن كان منكم محسنًا زِيد في إحسانه، ومَن كان مخطئًا نغفر له خطيئته{38}. (١/٣٨٠) ١٩٢٥- عن قتادة بن دِعامة -من طريق سعيد بن بشير- في قوله: <q>﴿وقولوا حطة نغفر لكم خطاياكم وسنزيد المحسنين﴾</q>، قال: مَن كان خاطئًا غُفِرَت له خطيئته، ومَن كان محسنًا زِيد في إحسانه{39}. (١/٣٧٩) ١٩٢٦- قال مقاتل بن سليمان: <q>﴿نغفر لكم خطاياكم وسنزيد المحسنين﴾</q> الذين لم يصيبوا خطيئة، فزادهم الله إحسانًا إلى إحسانهم{20}. (ز) <q>﴿نَّغۡفِرۡ لَكُمۡ خَطَـٰیَـٰكُمۡۚ وَسَنَزِیدُ ٱلۡمُحۡسِنِینَ ۝٥٨﴾</q> - آثار متعلقة بالآية ١٩٢٧- عن أبي سعيد، قال: سرنا مع رسول الله ﷺ، حتى إذا كان من آخر الليل أجَزْنا في ثَنِيَّةٍ{41} يقال لها: ذات الحَنظَل، فقال: «ما مَثَلُ هذه الثَّنِيَّة الليلة إلا كمَثَلِ الباب الذي قال الله لبني إسرائيل: <q>﴿ادخلوا الباب سجدا وقولوا حطة نغفر لكم خطاياكم﴾</q>»{42}. (١/٣٨١) ١٩٢٨- عن علي بن أبي طالب -من طريق عبد الله بن الحارث- قال: إنّما مَثَلُنا في هذه الأمة كسفينة نوح، وكباب حِطَّة في بني إسرائيل{43}. (١/٣٨١) ",footnotes:1:تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.أخرجه عبد الرزاق ١/٤٦، وابن جرير ١/٧١٢، وابن أبي حاتم ١/١١٦، والحاكم ٢/٢٦٢.أخرجه ابن جرير ١/٧١٠، وابن أبي حاتم ١/١١٦.أخرجه ابن جرير ١/٧١٠، وابن أبي حاتم ١/١١٦.تفسير مقاتل بن سليمان ١/١٠٩. وينظر: تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.أخرجه ابن جرير ١/٧١٣.تفسير مجاهد ص٢٠٣، وأخرجه ابن أبي حاتم ١/١١٧. وقد أورده قبل ذلك ١/٦٥ عند قوله تعالى: <q>﴿ويآدم اسكن أنت و زوجك الجنة وكلا منها رغدا﴾</q>. أما السيوطي فاكتفى بإيراده عند هذه الآية.أخرجه ابن أبي حاتم ١/١١٧.تفسير مقاتل بن سليمان ١/١٠٩.أخرجه ابن جرير ٢/٧٢٤، وابن أبي حاتم ١/١١٧ (٥٧٠) بهذا اللفظ. وأخرجه البخاري ٤/١٥٦ (٣٤٠٣)، ومسلم ٤/٢٣١٢ (٣٠١٥) عن أبي هريرة ﵁، أن رسول الله ﷺ قال: «قيل لبني إسرائيل: <q>﴿ادخلوا الباب سجدا وقولوا حطة﴾</q>. فبدلوا، فدخلوا يزحفون على أستاههم، وقالوا: حبة في شعرة».أخرجه ابن جرير ١/٧١٤، وابن أبي حاتم ١/١١٧، والحاكم ٢/٢٦٢. وذكره السيوطي بلفظ: باب ضيِّق، وعزاه إلى من سبق إضافة إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ١/١١٧.أخرجه ابن جرير ١/٧١٤.تفسير مجاهد ص٢٠٣، وأخرجه ابن جرير ١/٧١٤، وابن أبي حاتم ١/١١٧. وعزاه السيوطي إلى عبد حميد.عَلَّقه ابن أبي حاتم ١/١١٧ (عقب ٥٧٤).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١/٧١٠، وابن أبي حاتم ١/١١٧.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧١٤، وابن أبي حاتم ١/١١٧.أخرجه ابن أبي حاتم ١/١١٨.تفسير مجاهد ص٢٠٣، وأخرجه ابن جرير ١/٧٢٧. وعلَّقه ابن أبي حاتم ١/١١٨-١١٩.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.أخرجه ابن جرير ١/٧١٦، وابن أبي حاتم ١/١١٨، والحاكم ٢/٢٦٢. وعزاه السيوطي إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر. وفي لفظ عند ابن جرير ١/٧١٨: أمروا أن يستغفروا.أخرجه البيهقي في الأسماء والصفات (٢٠٥).أخرجه ابن جرير ١/٧١٨، وابن أبي حاتم ١/١١٨.أخرجه ابن أبي حاتم ١/١١٨.أخرجه أبو الشيخ الأصبهاني في طبقات المحدثين بأصبهان ٤/١١. وفي الدر وتفسير ابن أبي حاتم ذِكْر اليهود فقط.أخرجه ابن جرير ١/٧١٤، ٧٢٦، وابن أبي حاتم ١/١١٧ (٥٧٤). وعزاه السيوطي إلى عبد حميد.أخرجه ابن جرير ١/٧١٧، وابن أبي حاتم ١/١١٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبدالرزاق ١/٤٧، وابن جرير ١/٧١٦، وابن أبي حاتم ١/١١٩. وفي تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨ هذا القول عن قتادة، وجاء في آخره: وهو أمرٌ بالاستغفار.أخرجه ابن جرير ١/٧١٧. وعَلَّقه ابن أبي حاتم ١/١١٨.تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.أخرجه ابن جرير ١/٧١٦، ٧٢٨، وابن أبي حاتم ١/١١٨.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧١٦.أخرجه ابن جرير ١/٧٢٢.أخرجه ابن أبي حاتم ١/١١٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/١١٠.الثَّنَيَّة: العقبة، أو طريقها، أو الجبل، أو الطريقة فيه، أو إليه. القاموس المحيط (ثنى).أخرجه البزار كما في كشف الأستار ٢/٣٣٧ (١٨١٢)، والواقدي في المغازي ٢/٥٨٣-٥٨٤. قال الهيثمي ٦/١٤٤ (١٠١٧٧): «ورجاله ثقات».أخرجه ابن أبي شيبة ١٢/٧٧.
2,59," <q>﴿فَبَدَّلَ ٱلَّذِینَ ظَلَمُوا۟ قَوۡلًا غَیۡرَ ٱلَّذِی قِیلَ لَهُمۡ﴾</q> - تفسير ١٩٢٩- عن أبي هريرة، عن النبي ﷺ، قال: «قيل لبني إسرائيل: ادخلوا الباب سجدًا، وقولوا: حطة. فَبَدَّلوا، فدخلوا يزحفون على أسْتاهِهم، وقالوا: حبة في شعرة»{1}٢٤٩. (١/٣٨٠) ٢٤٩ قال ابنُ تيمية (١/٢١٧): «فإنّ الثابت عن النبي ﷺ أنهم دخلوا يزحفون على أستاههم، وفي لفظ: على أوراكهم، والمعنى واحد، وما نُقِل خلاف هذا فإنما أخذ عن أهل الكتاب، وقد كان يؤخذ عنهم الحق والباطل». ١٩٣٠- عن ابن عباس وأبي هريرة، قالا: قال رسول الله ﷺ: «دخلوا الباب الذي أمروا أن يدخلوا فيه سجدًا، يزحفون على أسْتاهِهم، وهم يقولون: حنطة في شعيرة»{2}. (١/٣٨٠) ١٩٣١- عن عبد الله بن مسعود -من طريق أبي الكَنُود- قال: قيل لهم: <q>﴿ادخلوا الباب سجدا﴾</q> فدخلوا مقنعي رؤوسهم، <q>﴿وقولوا حطة﴾</q> فقالوا: حِنطة، حبة حمراء فيها شعيرة، فذلك قوله: <q>﴿فبدل الذين ظلموا﴾</q>{3}٢٥٠. (١/٣٧٨) ٢٥٠ علَّق ابنُ تيمية (١/٢١٧) على قول ابن مسعود بقوله: «وقول ابن مسعود: مقنعي رؤوسهم، لا يناقض الزحف على أستاههم». ١٩٣٢- عن عبد الله بن مسعود -من طريق السُّدِّي، عن مُرَّة الهمداني- أنهم قالوا: هَطِّي سَمْقاثا أزْبَة مزبا. فهي بالعربية: حَبَّةُ حنطةٍ حمراء مثقوبة، فيها شُعَيْرَة سوداء{4}٢٥١. (١/٣٧٨) ٢٥١ وجَّه ابنُ تيمية (١/٢١٦-٢١٧) بقوله: «ثبت عن النبي ﷺ أنهم قالوا: حبة في شعرة. وإذا ثقبت الحبة وأدخلت فيها الشعرة، فإنه يقال: حبة شعرة. ويقال: شعرة في حبة. وهذا معنى ما رواه السدي عن مرة عن ابن مسعود أنه قال: إنهم قالوا هطي سمقاثا أزبه مزبا. وهي بالعربية: حبة حنطة حمراء مثقوبة فيها شعرة سوداء، وهذا موافق لما ثبت عن النبي ﷺ، لكن النبي ﷺ إنما تكلم بالعربية، وهذا اللفظ أخذه ابن مسعود عن أهل الكتاب». ١٩٣٣- قال عبد الله بن مسعود: من التبديل{5}. (ز) ١٩٣٤- عن عبد الله بن عباس -من طريق سعيد بن جُبَيْر- قال: فدخلوا من قبل أستاههم، وقالوا: حنطة -استهزاء-. قال: فذلك قوله ﷿: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{6}٢٥٢. (١/٣٧٧) ٢٥٢ ذكر ابنُ تيمية (١/٢١٧) التوجيه السابق لقول ابن مسعود من طريق السدي عن مرة، ثم قال: «وهذا أصح من قول ابن عباس أنهم قالوا: حنطة، مع أن هذا مروي عن غير واحد ... لكن قد يقال: الحبة هي الحنطة، وهم لم يقولوا بالعربية بل بلسانهم، وهم إذا قالوا بلسانهم ما معناه: حبة حنطة، جاز أن يقال: حنطة، وحديث ابن مسعود وقد ذكر أنهم قالوا: حبة حنطة، فلا يكون في القول خلاف». وبيَّن موافقة قول ابن عباس ﵄ في صفة الدخول لحديث النبي ﷺ فقال: «وابن عباس قال: يزحفون على أستاههم، كالمرفوع». ١٩٣٥- عن يحيى بن رافع= (ز) ١٩٣٦- والضّحاك بن مزاحم، نحوه{7}. (ز) ١٩٣٧- عن عبد الله بن عباس -من طريق العَوْفي- قال: لَمّا دخلوا الباب قالوا: حبة في شعيرة. فَبَدَّلوا قولًا غير الذي قيل لهم{8}. (ز) ١٩٣٨- عن ابن جُرَيج، قال: قال لي عطاء [بن أبي رباح] في قوله: <q>﴿فبدل الذين ظلموا﴾</q>، قال: أمّا تبديلهم فسمعنا أنهم قالوا: حنطة.= (ز) ١٩٣٩- قال ابن جريج: وقال ابن عباس: لَمّا دخلوا قالوا: حبة في شعرة{9}. (ز) ١٩٤٠- عن أبي الكَنُود -من طريق أبي سعد الأَزْدِي- <q>﴿وقولوا حطة﴾</q>، فقالوا: حنطة، حبة حمراء فيها شعرة. فأنزل الله: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{10}. (ز) ١٩٤١- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- قال: أمر موسى قومه أن يدخلوا المسجد ويقولوا: حطة، وطُؤْطِئَ لهم الباب ليخفضوا رؤوسهم، فلم يسجدوا، ودخلوا على أجنبهم إلى الجبل -وهو الجبل الذي تجلى له ربه جل ثناؤه- وقالوا: حنطة. فذلك التبديل الذي قال الله -تعالى ذكره-: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{11}. (ز) ١٩٤٢- عن عكرمة مولى ابن عباس -من طريق النَّضْر بن عَرَبِيٍّ- <q>﴿وادخلوا الباب سجدا﴾</q>، قال: فدخلوا مقنعي رؤوسهم، <q>﴿وقولوا حطة﴾</q> فقالوا: حنطة حمراء فيها شعرة. فذلك قوله: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{12}. (ز) ١٩٤٣- عن الحسن البصري= (ز) ١٩٤٤- وقتادة بن دِعامة -من طريق مَعْمَر- <q>﴿وادخلوا الباب سجدا﴾</q>، قالا: دخلوها على غير الجهة التي أمروا بها، دخلوها مُتَزَحِّفِين على أوْراكِهِم، وبَدَّلوا قولًا غير الذي قيل لهم، فقالوا: حبة في شعيرة{13}. (ز) ١٩٤٥- عن قتادة، في قوله: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>، قال: بيّن لهم أمرًا عَلِمُوه، فخالفوه إلى غيره، جرأة على الله وعتوًّا{14}. (١/٣٧٩) ١٩٤٦- عن إسماعيل السُّدِّيِّ -من طريق أسْباط- قال: دخلوا مُقْنِعِي رؤوسهم{15}. (ز) ١٩٤٧- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وادخلوا الباب سجدا وقولوا حطة﴾</q> قال: فكان سجود أحدهم على خده، و<q>﴿قولوا حطة﴾</q> يحط عنكم خطيئاتكم، فقالوا: حنطة. وقال بعضهم: حبة في شعيرة. <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{16}. (ز) ١٩٤٨- قال [محمد بن السائب] الكلبي: لما فَصَلَت بنو إسرائيل من التِّيه، ودخلوا إلى العُمْران، فكانوا بجبال أريحا من الأُرْدُن؛ قيل لهم: <q>﴿ادخلوا هذه القرية فكلوا منها حيث شئتم رغدا﴾</q>. وكان بنو إسرائيل قد خطئوا خطيئة، فأحب الله أن يستنقذهم منها إن تابوا، وقال لهم: إذا انتهيتم إلى باب القرية فاسجدوا، وقولوا: حطة؛ نحط عنكم خطاياكم، <q>﴿وسنزيد المحسنين﴾</q> الذين لم يكونوا من أهل تلك الخطيئة، إحسانًا إلى إحسانهم. فأما المحسنون فقالوا الذي أمروا به، وأما الذين عصوا فقالوا قولًا غير الذي قيل لهم، قالوا: ...{17} بالسُّرْيانِيَّة، قالوها استهزاءً وتبديلًا لقول الله{18}. (ز) ١٩٤٩- قال مقاتل بن سليمان: ... فلما دخلوا إلى الباب فعل المحسنون ما أمروا به، وقال الآخرون: هطا سقماثا. يعنون: حنطة حمراء. قالوا ذلك استهزاءً وتبديلًا لما أمروا به، فدخلوا مستقلين، فذلك قوله ﷿: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>{19}. (ز) ١٩٥٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب-: <q>﴿وادخلوا الباب سجدا وقولوا حطة﴾</q> يحط الله بها عنكم ذنبكم وخطيئاتكم، قال: فاستهزؤوا به -يعني: بموسى-، وقالوا: ما يشاء موسى أن يلعب بنا إلا لعب بنا، حِطَّةٌ حِطَّةٌ! أيُّ شيء حِطَّةٌ؟! وقال بعضهم لبعض: حنطة{20}٢٥٣. (ز) ٢٥٣ نقل ابن تيمية (١/٢١٦) أقوال السلف في معنى <q>﴿حطة﴾</q> عن ابن الجوزي، ثم جمع بينها بقوله: «الأقوال كلها واحدة، بخلاف صفة الدخول». <q>﴿فَأَنزَلۡنَا عَلَى ٱلَّذِینَ ظَلَمُوا۟ رِجۡزࣰا مِّنَ ٱلسَّمَاۤءِ﴾</q> - تفسير ١٩٥١- عن سعد بن مالك، وأسامة بن زيد، وخُزَيْمَة بن ثابت، قالوا: قال رسول الله ﷺ: «إنّ هذا الطّاعون رِجْزٌ، وبَقِيَّةُ عذاب عُذِّب به أناس من قبلكم، فإذا كان بأرض وأنتم بها فلا تخرجوا منها، وإذا بلغكم أنه بأرض فلا تدخلوها»{21}. (١/٣٨١) ١٩٥٢- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- قال: كل شيء في كتاب الله تعالى من الرجز يعني به: العذاب{22}. (١/٣٨١) ١٩٥٣- عن مجاهد بن جَبْر= (ز) ١٩٥٤- وأبي مالك= (ز) ١٩٥٥- والحسن البصري، نحو ذلك{23}. (ز) ١٩٥٦- عن إسماعيل السُّدِّي -من طريق أسْباط-، نحو ذلك{24}. (ز) ١٩٥٧- عن أبي العالية -من طريق الربيع بن أنس- في الآية، قال: الرجز: الغضب{22}. (١/٣٨٢) ١٩٥٨- عن عامر الشعبي -من طريق مُجالِد- قال: الرِّجز: إما الطاعون، وإما البرد{24}. (ز) ١٩٥٩- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿رجزا﴾</q>، قال: عذابًا{27}. (ز) ١٩٦٠- قال مقاتل بن سليمان: <q>﴿فأنزلنا على الذين ظلموا رجزا﴾</q> يعني: عذابًا <q>﴿من السماء﴾</q> -كقوله في سورة الأعراف [٧١]: <q>﴿قال قد وقع عليكم من ربكم رجس﴾</q> يعني: عذابًا-. ويُقال: الطاعون. ويقال: الظلمة شبه النار. <q>﴿بما كانوا يفسقون﴾</q>، وأهلك منهم سبعون ألفًا في يوم واحد عقوبةً لقولهم: هطا سقماثا. فهذا القول ظلمهم{19}. (ز) ١٩٦١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهَب- قال: الرِّجز: العذاب، وكل شيء في القرآن «رِجز» فهو: عذاب{29}. (ز) ١٩٦٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب-: لَمّا قيل لبني إسرائيل: ادخلوا الباب سجدًا، وقولوا: حطة. فبدل الذين ظلموا منهم قولًا غير الذي قيل لهم؛ بعث الله -جل وعز- عليهم الطاعون، فلم يُبْقِ منهم أحدًا. وقرأ: <q>﴿فأنزلنا على الذين ظلموا رجزا من السماء بما كانوا يفسقون﴾</q>. قال: وبقي الأبناء، ففيهم الفضل، والعبادة التي توصف في بني إسرائيل، والخير، وهلك الآباء كلهم، أهلكهم الطاعون{30}. (ز) ١٩٦٣- قال يحيى بن سَلّام: بلغني: أنّ ذلك العذابَ الطاعونُ، فمات منهم سبعون ألفًا{31}٢٥٤. (ز) ٢٥٤ رجَّح ابن جرير (١/٧٣١) العموم في معنى الرجز، وأنه يشمل كل ما قاله المفسرون، ورأى مع ذلك أنّ تفسيره بالطاعون يكتسب قوة؛ لكونه تفسيرًا مرويًّا عن النبي ﷺ، لكنه بيَّن مع ذلك أنه لا يستطيع القطع بصحته وحده دون ما سواه، فقال: «وقد دللنا على أن تأويل الرجز: العذاب. وعذاب الله أصناف مختلفة، وقد أخبر الله أنه أنزل على الذين وصفنا أمرهم الرجز من السماء، وجائز أن يكون ذلك طاعونًا، وأن يكون غيره، ولا دلالة في ظاهر القرآن ولا في أثر عن الرسول ثابت أي أصناف ذلك كان، فالصواب من القول في ذلك أن يُقال كما قال الله: فأنزلنا عليهم رجزًا من السماء بفسقهم، غير أنّه يغلب على نفسي صحة ما قاله ابن زيد؛ للخبر الذي ذكرت عن رسول الله ﷺ في إخباره عن الطاعون أنه رجز، وأنه عُذِّبَ به قوم قبلنا، وإن كنت لا أقول إنّ ذلك كذلك يقينًا؛ لأن الخبر عن رسول الله ﷺ لا بيان فيه أي أمة عذبت بذلك، وقد يجوز أن يكون الذين عذبوا به كانوا غير الذين وصف الله صفتهم في قوله: <q>﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</q>». وعلَّق ابنُ القيم (١/١٢٦) على قول ابن زيد بقوله: «وعلى هذا فالطاعون بالرصد لمن بدل دين الله قولًا وعملًا». <q>﴿بِمَا كَانُوا۟ یَفۡسُقُونَ ۝٥٩﴾</q> - تفسير ١٩٦٤- عن عبد الله بن عباس –من طريق عكرمة- في قوله: <q>﴿بما كانوا يفسقون﴾</q>، أي: بما تَعَدَّوْا مِن أمري{32}. (ز) ١٩٦٥- عن قتادة بن دِعامة -من طريق سعيد بن بشير- في قوله: <q>﴿بِما كانُوا يَفْسُقُونَ﴾</q>، قال: بما كانوا يعصون{33}. (ز) ١٩٦٦- عن محمد بن إسحاق -من طريق سلمة- <q>﴿بِما كانُوا يَفْسُقُونَ﴾</q>، أي: بما تَعَدَّوْا في أمري{34}. (ز) <q>﴿بِمَا كَانُوا۟ یَفۡسُقُونَ ۝٥٩﴾</q> - آثار متعلقة بالآية ١٩٦٧- عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «يهود أمتي المرجية». ثم قرأ: <q>﴿فبدل الذين ظلموا قولًا غير الذي قيل لهم﴾</q>{35}. (ز) ",footnotes:1:أخرجه البخاري ٤/١٥٦ (٣٤٠٣)، ٦/١٩ (٤٤٧٩)، ٦/٦٠ (٤٦٤١)، ومسلم ٤/٢٣١٢ (٣٠١٥).أخرجه ابن جرير ١/٧٢٤. وأسنده ابن كثير في تفسيره ١/٢٧٦ إلى ابن إسحاق.أخرجه ابن جرير ١/٧٢٥، وابن أبي حاتم ١/١١٨، ١١٩، والطبراني (٩٠٢٧). وعزاه السيوطي إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١/٧٢٥، وابن أبي حاتم ١/١١٩ (٥٨٩)، والطبراني (٩٠٢٧)، والحاكم ٢/٣٢١، ووافقه الذهبي. وعزاه السيوطي إلى أبي الشيخ.عَلَّقه سفيان الثوري ص٤٥ (١٨).أخرجه ابن جرير ١/٧٢٥-٧٢٦، وابن أبي حاتم ١/١١٧، ١١٩، والحاكم ٢/٢٦٢. وعزاه السيوطي إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر. وفي لفظ عند ابن جرير ١/٧٢٧: فدخلوا على أستاههم مقنعي رءوسهم.علَّقه ابن أبي حاتم ١/١١٩.أخرجه ابن جرير ١/٧٢٨.أخرجه ابن جرير ١/٧٢٨. وعلَّق ابن أبي حاتم ١/١١٩ قول عطاء.أخرجه ابن أبي حاتم ١/١١٩.تفسير مجاهد ص٢٠٣، وأخرجه ابن جرير ١/٧٢٧. وعلَّقه ابن أبي حاتم ١/١١٨-١١٩.أخرجه ابن جرير ١/٧٢٧. وعلَّقه ابن أبي حاتم ١/١١٩.أخرجه عبد الرزاق ١/٤٧، وابن جرير ١/٧٢٦. وعلَّقه ابن أبي حاتم ١/١١٩.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/١١٨.أخرجه ابن جرير ١/٧٢٨، وابن أبي حاتم ١/١١٨، ١٢٠.ذكر محققه أن هنا طمس في الأصل. ولعله ما ورد عن ابن مسعود وغيره في رواية سابقة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٢-.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧٢٨. وعلَّقه ابن أبي حاتم ١/١١٩.أخرجه البخاري ٦/٢٥٥٧ (٦٥٧٣)، ومسلم ٤/١٧٣٨ (٢٢١٨) وهذا لفظه، من حديث أسامة.أخرجه ابن جرير ١/٧٣٠، وابن أبي حاتم ١/١٢٠.علَّقه ابن أبي حاتم ١/١٢٠.أخرجه ابن أبي حاتم ١/١٢٠.أخرجه ابن جرير ١/٧٣٠، وابن أبي حاتم ١/١٢٠.أخرجه ابن أبي حاتم ١/١٢٠.أخرجه عبد الرزاق ١/٤٧، وابن جرير ١/٧٣٠. وعلَّقه ابن أبي حاتم ١/١٢٠.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧٣١.أخرجه ابن جرير ١/٧٣٠.تفسير ابن أبي زمنين ١/١٤٣.أخرجه ابن جرير ١/٤٣٥ عند تفسير قوله تعالى: <q>﴿وما يُضِلُّ بِهِ إلّا الفاسِقِينَ﴾</q> [البقرة:٢٦].أخرجه ابن أبي حاتم ١/١٢٠ (٥٩٥).أخرجه ابن أبي حاتم ١/١٢٠ (٥٩٦).أخرجه الرافعي في تاريخ قزوين ٤/١.
2,60," <q>﴿وَإِذِ ٱسۡتَسۡقَىٰ مُوسَىٰ لِقَوۡمِهِۦ فَقُلۡنَا ٱضۡرِب بِّعَصَاكَ ٱلۡحَجَرَۖ فَٱنفَجَرَتۡ مِنۡهُ ٱثۡنَتَا عَشۡرَةَ عَیۡنࣰاۖ قَدۡ عَلِمَ كُلُّ أُنَاسࣲ مَّشۡرَبَهُمۡۖ﴾</q> - تفسير ١٩٦٨- عن عبد الله بن عباس -من طريق سعيد بن جُبَيْر- قال: ذلك في التِّيه؛ ظُلِّل عليهم الغمام، وأُنزل عليهم المن والسلوى، وجعل لهم ثيابًا لا تَبْلى ولا تَتَّسِخ، وجُعل بين ظهرانيهم حجر مُرَبَّع، وأمر موسى فضرب بعصاه الحجر، فانفجرت منه اثنتا عشرة عينًا، في كل ناحية منه ثلاث عيون، لكل سبط عين، ولا يرتحلون مَنقَلَة{1} إلا وجدوا ذلك الحجر منهم بالمكان الذي كان به منهم في المنزل الأول{2}. (١/٣٨٢) ١٩٦٩- عن عبد الله بن عباس -من طريق علي بن الحكم، عن الضحاك- قال: لما كان بنو إسرائيل في التِّيه شق لهم من الحجر أنهارًا{3}. (ز) ١٩٧٠- وقال عبد الله بن عباس: كان حجرًا خفيفًا مُرَبَّعًا على قَدْر رأس الرجل، كان يضعه في مِخْلاته{4}، فإذا احتاجوا إلى الماء وضعه وضربه بعصاه{5}. (ز) ١٩٧١- قال سعيد بن جُبَير: هو الحجر الذي وضع موسى ثوبه عليه ليغتسل، ففر بثوبه، ومر به على ملأ من بني إسرائيل حين رموه بالأُدْرَة{6}، فلما وقف أتاه جبرائيل، فقال: إن الله تعالى يقول: ارفع هذا الحجر، فلي فيه قدرة، ولك فيه معجزة. فرفعه، ووضعه في مِخْلاته{5}. (ز) ١٩٧٢- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- قال: انفجر لهم الحجر بضربة موسى اثنتي عشرة عينًا، كل ذلك كان في تِيهِهم حين تاهُوا{8}. (١/٣٨٢) ١٩٧٣- عن مجاهد بن جَبْر، قال: استسقى موسى لقومه، فقال: اشربوا، يا حمير. فقال الله تعالى له: لا تُسَمِّ عبادي: حميرًا{9}. (١/٣٨٤) ١٩٧٤- عن عَطِيَّة العَوْفِي: وجعل لهم حجرًا مثل رأس الثور، يُحمل على ثور، فإذا نزلوا منزلًا وضعوه، فضربه موسى بعصاه، فانفجرت منه اثنتا عشرة عينًا، فاستمسك الماء{3}. (ز) ١٩٧٥- قال وهْب بن مُنَبِّه: كان موسى ﵇ يقرع لهم أقرب حجر من عرض الحجارة، فيتفجّر لهم عيونًا، لكلّ سبط عين، وكانوا اثني عشر سِبْطًا، ثمّ تسيل كلّ عين في جدول إلى السِّبْط الذي أمر بسقيهم{11}. (ز) ١٩٧٦- وقال عطاء: كان للحجر أربعة وجوه، لكل وجه ثلاثة أعين، لكل سبط عين ...، كان يضربه موسى اثنتي عشرة ضربة، فيظهر على موضع كل ضربة مثل ثدي المرأة، فيعرق، ثم يتفجر الأنهار، ثم تسيل{12}. (ز) ١٩٧٧- عن قتادة بن دِعامة في قوله: <q>﴿وإذ استسقى موسى لقومه﴾</q> الآية، قال: كان هذا في البَرِّيَّة حيث خَشوا الظَّمَأ، استسقى موسى، فأمر بحجر أن يضربه بعصاه، وكان حجرًا طُورانِيًّا من الطُّور يحملونه معهم، حتى إذا نزلوا ضربه موسى بعصاه <q>﴿فانفجرت منه اثنتا عشرة عينا قد علم كل أناس مشاربهم﴾</q>، قال: لكل سبط منهم عين معلومة يستفيد ماءَها{13}. (١/٣٨٢) ١٩٧٨- عن إسماعيل السُّدِّي -من طريق أسْباط- قال: كان ذلك في التِّيه{14}. (ز) ١٩٧٩- عن عطاء الخراساني -من طريق ابنه عثمان- قال: كان لبني إسرائيل حجر، فكان يضعه هارون، ويضربه موسى بعصاه{3}. (ز) ١٩٨٠- عن جُوَيْبِر أنّه سُئِل عن قوله: <q>﴿قد علم كل أناس مشربهم﴾</q>. قال: كان موسى يضع الحجر، ويقوم من كل سِبْط رجل، ويضرب موسى الحجر، فينفجر منه اثنتا عشرة عينًا، فَيَنتَضِحُ{16} من كل عين على رجل، فيدعو ذلك الرجل سِبْطه إلى تلك العين{17}. (١/٣٨٣) ١٩٨١- وقال أبو رَوْق: كان الحجر من الكذان{18}، وكان فيه اثنتا عشرة حفرة، ينبع من كلِّ حفرة عين ماء عذب فُرات فيأخذوه، فإذا فرغوا وأراد موسى حمله ضربه بعصاه، فيذهب الماء، وكان يسقي كل يوم ستمائة ألف{11}. (ز) ١٩٨٢- قال أبو عمرو بن العلاء: انبجست: عرقت وانفجرت، أي: سالت{12}. (ز) ١٩٨٣- قال مقاتل بن سليمان: <q>﴿وإذ استسقى موسى لقومه﴾</q> وهم في التِّيه، قالوا: من أين لنا شراب نشرب؟ فدعا موسى ﵇ ربه أن يسقيهم، فأوحى الله ﷿ إلى موسى ﵇: <q>﴿فقلنا اضرب بعصاك الحجر﴾</q>. وكان الحجر خفيفًا مُرَبَّعًا، فضربه، <q>﴿فانفجرت منه﴾</q> من الحجر <q>﴿اثنتا عشرة عينا﴾</q>، فَرَووا بإذن الله ﷿، وكانوا اثني عشر سبطًا، لكل سبط من بني إسرائيل عين تجري على حِدَة، لا يخالطهم غيرهم، فذلك قوله سبحانه: <q>﴿قد علم كل أناس مشربهم﴾</q>، يعني: كل سبط مشربهم. يقول الله ﷿: <q>﴿كلوا﴾</q> من المن والسلوى، <q>﴿واشربوا﴾</q> من العيون، وهو من رزق الله حلالًا طيبًا، فذلك قوله سبحانه: <q>﴿كلوا من طيبات ما رزقناكم﴾</q> [طه:٨١] ... وكان موسى ﵇ إذا ظَعَنَ{21} حمل الحجر معه، وتنصَبُّ العيون منه، ثم إنهم قالوا: يا موسى، فأين اللباس؟ فجعلت الثياب تطول مع أولادهم، وتبقى على كبارهم، ولا تمزق، ولا تبلى، ولا تدنس، وكان لهم عمود من نور يضيء لهم بالليل إذا ارتحلوا وغاب القمر{22}. (ز) ١٩٨٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- استسقى لهم موسى في التِّيه، فَسُقوا في حجر مثل رأس الشاة، قال: يُلْقُونه في جوانب الجُوالِق{23} إذا ارتحلوا، ويقرعه موسى بالعصا إذا نزل، فتنفجر منه اثنتا عشرة عينًا، لكل سبط منهم عين، فكان بنو إسرائيل يشربون منه، حتى إذا كان الرحيل استمسكت العيون، وقيل به فأُلْقِي في جانب الجوالق، فإذا نزل رُمِي به، فقرعه بالعصا، فتفجرت عين من كل ناحية مثل البحر{14}٢٥٥. (ز) ٢٥٥ ذهب ابنُ جرير (٢/٦) إلى أنّ موسى ﵇ استسقى ربه الماءَ لبني إسرائيل: «في الحال التي تاهوا فيها في التِّيه» مستندًا إلى آثار السلف، ولم يذكر قولًا غيره. <q>﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝٦٠﴾</q> - تفسير ١٩٨٥- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قوله: <q>﴿ولا تعثوا في الأرض﴾</q>، قال: لا تَسْعَوا في الأرض{25}. (١/٣٨٣) ١٩٨٦- عن أبي العالية -من طريق الربيع بن أنس- في قوله: <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>، قال: لا تَسْعَوْا في الأرض فسادًا{26}. (١/٣٨٣) ١٩٨٧- عن أبي مالك غَزْوان الغِفارِي -من طريق السُّدِّي- في قوله: <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>، قال: يعني: ولا تمشوا بالمعاصي{17}. (١/٣٨٣) ١٩٨٨- عن قتادة -من طريق مَعْمَر- في قوله: <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>، قال: لا تسيروا في الأرض مُفْسِدِين{28}. (١/٣٨٤) ١٩٨٩- قال مقاتل بن سليمان: <q>﴿ولا تعثوا في الأرض﴾</q> يقول: لا تَعْلُوا، ولا تَسْعَوْا في الأرض <q>﴿مفسدين﴾</q> يقول: لا تعملوا في الأرض بالمعاصي، فرَفَعُوا من المن والسلوى لِغَدٍ، فذلك قوله سبحانه: <q>﴿ولا تطغوا فيه﴾</q> [طه:٨١]، يقول: لا ترفعوا منه لغد{29}. (ز) ١٩٩٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>: لا تطغوا في الأرض مفسدين. لا تَعْثَ: لا تَطْغَ{30}٢٥٦. (ز) ٢٥٦ جمع ابنُ جرير (٢/١٠) بين تلك الأقوال، فقال: «<q>﴿لا تعثوا﴾</q>: لا تطغوا، ولا تسعوا <q>﴿في الأرض مفسدين﴾</q>». ",footnotes:1:المَنقَلَة: المرحلة من مراحل السفر. لسان العرب (نقل).أخرجه ابن جرير ٢/٦، وابن أبي حاتم ١/١٢١-١٢٢. وقد أورده السيوطي مختصرًا من طريق عكرمة، وعزاه إلى ابن جرير ٢/٧.أخرجه ابن أبي حاتم ١/١٢١.وعاء يوضع فيه الخَلى، وهو الحشيش. تاج العروس (خلى).تفسير الثعلبي ١/٢٠٣، وتفسير البغوي ١/١٠٠.الأُدْرة -بضم الهمزة- نفخة في الخُصْيَة. لسان العرب (أدر).تفسير الثعلبي ١/٢٠٣، وتفسير البغوي ١/١٠٠.أخرجه ابن جرير ٢/٧. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن أبي حاتم ١/١٢١.تفسير الثعلبي ١/٢٠٣.تفسير البغوي ١/١٠٠.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢/٦ من طريق سعيد، وابن أبي حاتم ١/١٢١ مختصرًا من طريق شيبان. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٤- نحوه.أخرجه ابن جرير ٢/٨.أخرجه ابن أبي حاتم ١/١٢١.حمل الماء من النهر أو البئر. المصباح المنير (نضح).أخرجه ابن أبي حاتم ١/١٢٢.الكذان: حجارة رخوة. النهاية (كذن).تفسير الثعلبي ١/٢٠٣.تفسير البغوي ١/١٠٠.أي: ذهب وسار، ويقال لكل من سافر: ظعن. لسان العرب (ظعن).تفسير مقاتل بن سليمان ١/١١٠.الجوالق: بكسر الجيم واللام، وبضم الجيم وفتح اللام وكسرها: وعاء. القاموس المحيط (جوق).أخرجه ابن جرير ٢/٨.أخرجه ابن جرير ٢/١١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢/١٠، وابن أبي حاتم ١/١٢٢.أخرجه ابن أبي حاتم ١/١٢٢.أخرجه عبد الرزاق ٢/٣١١، وابن أبي حاتم ١/١٢٢ من طريق شيبان. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٤-. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/١٠.
2,61," <q>﴿وَإِذۡ قُلۡتُمۡ یَـٰمُوسَىٰ لَن نَّصۡبِرَ عَلَىٰ طَعَامࣲ وَ ٰ⁠حِدࣲ﴾</q> - تفسير ١٩٩١- عن أبي العالية -من طريق الربيع بن أنس- في قوله: <q>﴿وإذ قلتم يا موسى لن نصبر على طعام واحد﴾</q>، قال: كان طعامهم السلوى، وشرابهم المن، فسألوا ما ذكر، فقيل لهم: <q>﴿اهبطوا مصرا فإن لكم ما سألتم﴾</q>{1}. (ز) ١٩٩٢- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وإذ قلتم يا موسى لن نصبر على طعام واحد﴾</q>، قال: المن والسلوى استبدلوا به البَقْلَ وما ذُكِر معه{2}. (١/٣٨٤) ١٩٩٣- عن الحسن البصري -من طريق عَبّاد بن منصور- قال: فبَطِرُوا ذلك، ولم يصبروا عليه، وذكروا عَيْشهم الذي كانوا يعيشون فيه، وكانوا قومًا أهل أعداس وبصل وبقول وفوم، فذكروا عَيْشَهم من ذلك، فقالوا: <q>﴿يا موسى لن نصبر على طعام واحد فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها وعدسها وبصلها﴾</q>{3}. (ز) ١٩٩٤- عن قتادة بن دِعامة -من طريق مَعْمَر- قال: مَلُّوا طعامهم في البَرِّيَّة، وذكروا عَيْشَهم الذي كانوا فيه قبل ذلك، فقالوا: <q>﴿ادع لنا ربك﴾</q> الآية{4}. (١/٣٨٤) ١٩٩٥- عن قتادة بن دِعامة -من طريق أبي جعفر الرازي- قال: إنهم لما قدموا الشام فقدوا أطْعِماتهم التي كانوا يأكلونها، فقالوا: <q>﴿فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها وعدسها وبصلها﴾</q>{5}. (ز) ١٩٩٦- عن إسماعيل السُّدِّيِّ -من طريق أسْباط-: أُعطوا في التِّيهِ ما أُعْطُوا، فأَجِمُوا ذلك، وقالوا: <q>﴿يا موسى لن نصبر على طعام واحد فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها وعدسها وبصلها﴾</q>{6}. (ز) ١٩٩٧- قال مقاتل بن سليمان: فلما طال عليهم المن والسلوى سألوا موسى نبات الأرض، فذلك قوله ﷿: <q>﴿وإذ قلتم يا موسى﴾</q> في التِّيه: <q>﴿لن نصبر على طعام واحد﴾</q> يعني: المَنَّ والسَّلْوى{7}. (ز) ١٩٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- قال: كان طعام بني إسرائيل في التِّيه واحدًا، وشرابهم واحدًا، كان شرابهم عسلًا ينزل لهم من السماء يقال له: المن، وطعامهم طير يقال له: السلوى، يأكلون الطير ويشربون العسل، لم يكونوا يعرفون خبزًا ولا غيره، فقالوا: يا موسى، إنا لن نصبر على طعام واحد، <q>﴿فادع لنا ربك يخرج لنا مما تنبت الأرض﴾</q> فقرأ حتى بلغ: <q>﴿اهبطوا مصرا﴾</q>{8}٢٥٧. (ز) ٢٥٧ ذهب ابنُ جرير (٢/١٢-١٤) مستندًا إلى آثار السلف إلى أنّ سبب مسألتهم موسى ﵇ ذلك أنهم ملُّوا طعامَهم، وذكروا عيشهم الذي كانوا فيه بمصر. ولم يذكر قولًا غيره. <q>﴿فَٱدۡعُ لَنَا رَبَّكَ یُخۡرِجۡ لَنَا مِمَّا تُنۢبِتُ ٱلۡأَرۡضُ مِنۢ بَقۡلِهَا وَقِثَّاۤىِٕهَا وَفُومِهَا وَعَدَسِهَا وَبَصَلِهَاۖ﴾</q> - قراءات ١٩٩٩- عن عبد الله بن مسعود -من طريق سفيان- أنه قرأ: (وثُومِها){9}. (١/٣٨٥) ٢٠٠٠- عن عبد الله بن عباس قال: قراءتي قراءةُ زيد،= (ز) ٢٠٠١- وأنا آخذ ببضعة عشر حرفًا من قراءة ابن مسعود، هذا أحدها: (من بَقْلِها وقِثّائِها وثُومِها){10}٢٥٨. (١/٣٨٦) ٢٥٨ وجَّه ابنُ جرير (٢/١٨-١٩) قراءة ابن مسعود ﵄ بقوله: «فإن كان ذلك صحيحًا فإنه من الحروف المبدلة، كقولهم: وقعوا في عاثور شر، وعافور شر. وكقولهم للأثافي: أثاثي. وللمغافير: مغاثير. وما أشبه ذلك مما تقلب الثاء فاء، والفاء ثاء؛ لتقارب مخرج الفاء من مخرج الثاء». <q>﴿فَٱدۡعُ لَنَا رَبَّكَ یُخۡرِجۡ لَنَا مِمَّا تُنۢبِتُ ٱلۡأَرۡضُ مِنۢ بَقۡلِهَا وَقِثَّاۤىِٕهَا وَفُومِهَا وَعَدَسِهَا وَبَصَلِهَاۖ﴾</q> - تفسير الآية ٢٠٠٢- عن عبد الله بن عباس -من طريق جُوَيْبر، عن الضحاك- أنّ نافع بن الأزرق قال له: أخبرني عن قوله تعالى: <q>﴿وفومها﴾</q>. قال: الحنطة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أُحَيْحَةَ بنَ الجُلاحِ وهو يقول: قد كنت أغنى الناس شخصًا واحدًا ورَد المدينةَ عن زراعةِ فُومِ{11}٢٥٩. (١/٣٨٥) ٢٥٩ رجَّحَ ابنُ عطية (١/٢٢٨) أن يكون المراد بـ(الفوم): الحنطة، لا الثوم. مستندًا إلى قول ابن عباس هذا، وما ورد في لغة العرب. ٢٠٠٣- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبرني عن قوله ﷿: <q>﴿وفومها﴾</q>. قال: الفومُ: الحنطة. قال: وهل تعرف العرب ذلك؟. قال: نعم، أما سمعت أبا مِحْجَنٍ الثَّقَفيَّ وهو يقول: قد كنت أحسبني كأغنى واحد قَدِم المدينة عن زراعةِ فُومِ قال: يا ابن أمِّ الأزرق، ومن قرأها على قراءةِ ابن مسعود، فهو هذا المُنتِن، قال أمية ابن أبي الصَّلْت: كانت منازلهم إذ ذاك ظاهرةً فيها الفراديسُ{12} والفومانُ والبصلُ وقال أميةُ بن الصَّلْتِ أيضًا: أنفي الدِّياسَ{13} من الفومِ الصحيح كما أنفي من الأرض صوب الوابِل{14} البَرَدِ{15}. (١/٣٨٦) ٢٠٠٤- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وفومها﴾</q>، قال: الحنطة والخبز.= (ز) ٢٠٠٥- وفي لفظ -من طريق أبي رَوْق، عن الضحاك-: البر.= (ز) ٢٠٠٦- وفي لفظ-من طريق رِشْدِين بن كُرَيْب، عن أبيه-: الحِنْطَة، بلسان بني هاشم{16}. (١/٣٨٤) ٢٠٠٧- عن عبد الله بن عباس -من طريق الحسن- قال: الفوم: الثوم{17}. (١/٣٨٥) ٢٠٠٨- وعن سعيد بن جبير= (ز) ٢٠٠٩- والضّحاك بن مُزاحِم، نحو ذلك{18}. (ز) ٢٠١٠- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح، وابن جُرَيج- في قوله: <q>﴿وفومها﴾</q>، قال: الخبز{19}. (١/٣٨٥) ٢٠١١- عن مجاهد بن جَبْر -من طريق لَيْث- قال: هو هذا الثوم{20}. (ز) ٢٠١٢- عن الحسن البصري -من طريق يونس-= (ز) ٢٠١٣- وأبي مالك -من طريق حُصَيْن- في قوله: <q>﴿وفومها﴾</q>، قالا: الحنطة{21}. (١/٣٨٥) ٢٠١٤- عن عِكْرِمَة مولى ابن عباس، نحو ذلك{18}. (ز) ٢٠١٥- عن عَطاء بن أبي رَباح -من طريق ابن جُرَيج- في قوله: <q>﴿وفومها﴾</q>، قال: الخبز{23}. (١/٣٨٥) ٢٠١٦- عن الحسن البصري= (ز) ٢٠١٧- وقتادة بن دِعامة -من طريق سعيد، ومَعْمر- قالا: الفوم: الحب الذي يختبز الناس منه{24}. (ز) ٢٠١٨- عن إسماعيل السُّدِّيِّ -من طريق أسْباط- <q>﴿وفومها﴾</q>: الحنطة{25}. (ز) ٢٠١٩- عن الربيع بن أنس -من طريق أبي جعفر- قال: الفوم: الثوم. وفي بعض القراءة: (وثُومِها){26}. (١/٣٨٥) ٢٠٢٠- قال مقاتل بن سليمان: فلما طال عليهم المنُّ والسلوى سألوا موسى نباتَ الأرض، فذلك قوله ﷿: <q>﴿وإذ قلتم يا موسى﴾</q> في التِّيه: <q>﴿لن نصبر على طعام واحد﴾</q> يعني: المَنَّ والسلوى؛ <q>﴿فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها﴾</q> يعني: الثوم، <q>﴿وعدسها وبصلها﴾</q>، فغضب موسى ﵇{7}. (ز) ٢٠٢١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- الفوم: الخبز{28}. (ز) <q>﴿قَالَ أَتَسۡتَبۡدِلُونَ ٱلَّذِی هُوَ أَدۡنَىٰ بِٱلَّذِی هُوَ خَیۡرٌۚ﴾</q> - تفسير ٢٠٢٢- عن مجاهد بن جَبْر -من طريق ابن جُرَيْج- في قوله: <q>﴿أتستبدلون الذي هو أدنى﴾</q>، قال: أرْدَأ{29}. (١/٣٨٦) ٢٠٢٣- عن قتادة بن دِعامة -من طريق سعيد- قال: <q>﴿أتستبدلون الذي هو أدنى بالذي هو خير﴾</q>، يقول: أتستبدلون الذي هو شرٌّ بالذي هو خير{30}. (ز) ٢٠٢٤- قال الكَلْبِيُّ: قال لهم موسى ﵇: <q>﴿أتَسْتَبْدِلُونَ الَّذِي هُوَ أدْنى﴾</q> أخَسُّ وأَرْدى <q>﴿بِالَّذِي هُوَ خَيْرٌ﴾</q> أشرف وأفضل. وجعل الحنطة أدنى في القيمة وإن كان هي خيرًا من المن والسلوى{31}٢٦٠. (ز) ٢٦٠ ذهب ابنُ جرير (٢/١٩-٢٠) إلى أن <q>﴿أدنى﴾</q> في قوله تعالى: <q>﴿الذي هو أدنى﴾</q> بمعنى: أخسّ، وأوضع، وأصغر قدرًا وخطرًا. ٢٠٢٥- قال مقاتل بن سليمان: <q>﴿قال أتستبدلون الذي هو أدنى﴾</q> يقول: الذي هو دون المن والسلوى من نبات الأرض <q>﴿بالذي هو خير﴾</q> يعني: المن والسلوى؟! فقال موسى: <q>﴿اهبطوا مصرا﴾</q>{7}. (ز) <q>﴿ٱهۡبِطُوا۟ مِصۡرࣰا فَإِنَّ لَكُم مَّا سَأَلۡتُمۡۗ﴾</q> - قراءات ٢٠٢٦- في قراءة أُبَيّ بن كعب= (ز) ٢٠٢٧- وعبد الله بن مسعود: (اهْبِطُوا مِصْرَ) بغير ألف{33}. (ز) ٢٠٢٨- عن الأعمش أنّه كان يقرأ: (اهْبِطُوا مِصْرَ) بلا تنوين، ويقول: هي مصر التي عليها صالحُ بن عليٍّ{34}٢٦١. (١/٣٨٧) ٢٦١ علَّقَ ابنُ جرير (٢/٢٢) على هذه القراءة، فقال: «أما الذي لم يُنَوِّن (مصر) فإنه لا شك أنه عنى مصر التي تعرف بهذا الاسم بعينها، دون سائر البلدان غيرها». <q>﴿ٱهۡبِطُوا۟ مِصۡرࣰا فَإِنَّ لَكُم مَّا سَأَلۡتُمۡۗ﴾</q> - تفسير الآية ٢٠٢٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿اهبطوا مصرا﴾</q>، قال: مِصْرًا من الأَمْصار{35}. (١/٣٨٧) ٢٠٣٠- عن أبي العالية -من طريق الربيع بن أنس- في قوله: <q>﴿اهبطوا مصرا﴾</q>، قال: يعني به: مِصْرَ فرعون{36}. (١/٣٨٧) ٢٠٣١- عن مجاهد بن جَبْر -من طريق ابن جُرَيج- <q>﴿اهبطوا مصرا﴾</q>، قال: مِصْرًا من الأمصار، زعموا أنهم لم يرجعوا إلى مصر{37}٢٦٢. (ز) ٢٦٢ بيَّنَ ابنُ جرير (٢/٢٢) أنّ قراءة <q>﴿مصرًا﴾</q> بالتنوين تحتمل أن يكون المراد بها مصر فرعون، ويكون ذلك من باب الاتباع لكتابة المصحف، كما في قوله تعالى: <q>﴿قَوارِيرا * قَوارِيرَ﴾</q> [الإنسان: ١٥-١٦]. وعلَّقَ ابنُ عطية (١/٢٣٠) على هذه القراءة، فقال: «جمهور الناس يقرءُون <q>﴿مصرًا﴾</q> بالتنوين، وهو خط المصحف، إلا ما حكي عن بعض مصاحف عثمان ﵁. وقال مجاهد وغيره ممن صرفها: أراد مصرًا من الأمصار غير معيّن. واستدلوا بما اقتضاه القرآن من أمرهم بدخول القرية، وبما تظاهرت به الرواية أنهم سكنوا الشام بعد التيه. وقالت طائفة ممن صرفها: أراد مصر فرعون بعينها. واستدلوا بما في القرآن من أنّ الله تعالى أورث بني إسرائيل ديار آل فرعون وآثارهم، وأجازوا صرفها». ٢٠٣٢- قال الضَّحّاك بن مُزاحم: هو مِصْر موسى وفرعون{38}. (ز) ٢٠٣٣- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿اهبطوا مصرا﴾</q>، يقول: مِصْرًا من الأمصار{39}. (١/٣٨٧) ٢٠٣٤- عن إسماعيل السُّدِّي -من طريق أسْباط-: <q>﴿اهبطوا مصرا﴾</q> من الأمصار، <q>﴿فإن لكم ما سألتم﴾</q> فلما خرجوا من التِّيه رفع المن والسلوى، وأكلوا البقول{40}. (ز) ٢٠٣٥- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿اهبطوا مصرا﴾</q>، قال: يعني به: مِصْر فرعون{41}. (ز) ٢٠٣٦- عن الربيع بن أنس -من طريق أبي جعفر- قال: مِصْرًا من الأمصار{42}. (ز) ٢٠٣٧- قال الكَلْبِيُّ: (اهْبِطُوا مِصْرَ) بغير ألف، يعني: مصر بعينها{43}. (ز) ٢٠٣٨- قال مقاتل بن سليمان: <q>﴿اهبطوا مصرا﴾</q> من الأمصار <q>﴿فإن لكم ما سألتم﴾</q> من نبات الأرض{7}. (ز) ٢٠٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- <q>﴿اهبطوا مصرا﴾</q>، قال: مِصْرًا من الأمصار –و(مصر) لا تُجْرى في الكلام-. فقالوا: أي مصر؟ قال: الأرض المقدسة، وقرأ قول الله -جل ثناؤه-: <q>﴿ادْخُلُوا الأَرْضَ المُقَدَّسَةَ الَّتِي كَتَبَ اللَّهُ لَكُمْ﴾</q> [المائدة:٢١]{41}٢٦٣. (ز) ٢٦٣ توقَّف ابنُ جرير (٢/٢٢) في تحديد المراد بـ(مصر) في الآية، وجوَّزَ كلا القَولَيْن، وقال: «والذي نقول به في ذلك: إنّه لا دلالة في كتاب الله على الصواب من هذين التأويلين، ولا خبر به عن الرسول ﷺ يقطع مجيئه العذر». وانتقد ابنُ كثير (١/٤٢٨) كلامَ ابن جرير، وتوقّفَه في المراد بـ(مصر) في الآية، فقال: «وهذا الذي قاله فيه نظر، والحق أن المراد مصرًا من الأمصار كما روي عن ابن عباس وغيره، والمعنى على ذلك؛ لأنّ موسى ﵇ يقول لهم: هذا الذي سألتم ليس بأمر عزيز، بل هو كثير في أي بلد دخلتموها وجدتموه، فليس يساوي مع دناءته وكثرته في الأمصار أن أسأل الله فيه. ولهذا قال: <q>﴿أتستبدلون الذي هو أدنى بالذي هو خير اهبطوا مصرا فإن لكم ما سألتم﴾</q> أي: ما طلبتم، ولما كان سؤالهم هذا من باب البطر والأشر ولا ضرورة فيه لم يجابوا إليه». <q>﴿وَضُرِبَتۡ عَلَیۡهِمُ﴾</q> - تفسير ٢٠٤٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</q>، قال: هؤلاء يهود بني إسرائيل. قلت له: هم قِبْطُ مِصْر؟ قال: وما لِقِبْط مصر وهذا؟!، لا والله، ما هم هم، ولكنهم اليهود، يهود بني إسرائيل{46}. (ز) <q>﴿ٱلذِّلَّةُ﴾</q> - تفسير ٢٠٤١- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</q>، قال: هم أصحاب القَبالات، كفروا بالله العظيم{47}. (١/٣٨٧) ٢٠٤٢- عن الضحاك بن مُزاحم -من طريق جُوَيْبِر- قوله: <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ﴾</q>، قال: الذل{48}. (ز) ٢٠٤٣- عن الحسن البصري -من طريق عَوْف- <q>﴿وضربت عليهم الذلة﴾</q>، قال: أدْرَكَتْهُم هذه الأمة وإن المجوس لَتَجْبِيهم الجزية{48}. (ز) ٢٠٤٤- عن عَبّاد بن منصور، قال: سألت الحسن عن قوله: <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ﴾</q>، قال: أذلهم الله فلا مَنَعَة لهم، وجعلهم الله تحت أقدام المسلمين{48}. (ز) ٢٠٤٥- عن الحسن البصري= (ز) ٢٠٤٦- وقتادة بن دِعامة -من طريق مَعْمَر- <q>﴿وضربت عليهم الذلة والمسكنة﴾</q>، قال: يعطون الجزية عن يد وهم صاغرون{51}. (١/٣٨٧) ٢٠٤٧- قال عطاء بن السائب: هو الكُسْتِيج{52}، والزُّنّار{53}، وزِيِّ اليهودية{38}. (ز) ٢٠٤٨- قال مقاتل بن سليمان: <q>﴿وضربت عليهم الذلة﴾</q>، يعني: على اليهود الذِّلَّة، وهي: الجِزْيَة{7}٢٦٤. (ز) ٢٦٤ ذَهَبَ ابنُ جرير (٢/٢٦) مستندًا إلى القرآن الكريم، وآثار السلف إلى أنّ المراد بـ<q>﴿الذلة﴾</q>: الصَّغار الذي ذكره الله تعالى في قوله: <q>﴿حتى يُعطوا الجزية عن يدٍ وهم صاغرون﴾</q> [التوبة ٢٩]. <q>﴿وَٱلۡمَسۡكَنَةُ﴾</q> - تفسير ٢٠٤٩- عن أبي العالية -من طريق الربيع بن أنس- في قوله: <q>﴿والمسكنة﴾</q>، قال: الفاقَة{56}. (١/٣٨٨) ٢٠٥٠- عن الربيع بن أنس -من طريق أبي جعفر-، نحو ذلك{48}. (ز) ٢٠٥١- عن الضَّحّاك بن مُزاحم -من طريق جُوَيْبِر- قوله: <q>﴿والمسكنة﴾</q>: الجزية{48}. (ز) ٢٠٥٢- عن عَطِيَّة العَوْفي -من طريق عُبَيْد بن الطُّفَيل- <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</q>، قال: الخراج{48}. (ز) ٢٠٥٣- عن إسماعيل السُّدِّي -من طريق أسْباط- قوله: <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</q>، قال: الفقر{60}. (ز) ٢٠٥٤- قال مقاتل بن سليمان: <q>﴿والمسكنة﴾</q>، يعني: الفقر{7}٢٦٥. (ز) ٢٦٥ ذَهَبَ ابنُ جرير (٢/٢٦-٢٧) مستندًا في ذلك إلى آثار السلف إلى أنّ المراد بـ(المسكنة) في هذا الموضع: مسكنة الفاقة والحاجة، وهي خشوعها وذلها. <q>﴿وَبَاۤءُو﴾</q> - تفسير ٢٠٥٥- عن قتادة بن دِعامة، في قوله: <q>﴿وباءوا﴾</q>، قال: انقلبوا{62}. (١/٣٨٨) ٢٠٥٦- عن أبي رَوْق: استحقوا{63}. (ز) ٢٠٥٧- قال مقاتل بن سليمان: يعني: اسْتَوْجَبُوا{7}. (ز) ٢٠٥٨- عن الكسائي: رجعوا{63}. (ز) <q>﴿وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِۗ﴾</q> - تفسير ٢٠٥٩- عن سعيد بن جبير -من طريق عَطاء بن دينار- في قول الله: <q>﴿وباءوا بغضب من الله﴾</q>، يقول: اسْتَوْجَبوا سخطًا{48}. (ز) ٢٠٦٠- عن الضَّحّاك بن مُزاحم -من طريق جُوَيْبِر- في قوله: <q>﴿وباءوا بغضب من الله﴾</q>، قال: استحقوا الغضب من الله{67}. (١/٣٨٨) ٢٠٦١- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿وباءوا بغضب من الله﴾</q>، قال: فحَدَثَ عليهم غضبٌ من الله{68}. (ز) ٢٠٦٢- قال مقاتل بن سليمان: يعني: استوجبوا غضب الله ﷿{7}٢٦٦. (ز) ٢٦٦ ذَهَبَ ابنُ جرير (٢/٢٧-٢٨) مستندًا إلى القرآن الكريم، وأقوال السلف إلى أنّ المراد بقوله تعالى: <q>﴿وباءُوا بِغَضَبٍ مِنَ اللَّهِ﴾</q> أي: انصرفوا ورجعوا ...، ثم قال: «فمعنى الكلام إذًا: ورجعوا منصرفين متحملين غضب الله، قد صار عليهم من الله غضب، ووجب عليهم منه سخط». <q>﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلنَّبِیِّـۧنَ بِغَیۡرِ ٱلۡحَقِّۗ﴾</q> - تفسير ٢٠٦٣- عن عبد الله بن مسعود -من طريق أبي مَعْمَر الأزْدِيِّ- قال: كانت بنو إسرائيل في اليوم تقتل ثلاثمائة نبي، ثم يُقيمون سوق بَقْلِهم في آخر النهار{70}. (١/٣٨٨) ٢٠٦٤- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> الذل والمسكنة الذي نزل بهم <q>﴿بأنهم كانوا يكفرون بآيات الله﴾</q> يعني: القرآن، <q>﴿ويقتلون النبيين بغير الحق﴾</q>{7}٢٦٧. (ز) ٢٦٧ ذكر ابنُ عطية (١/٢٣١) أنّ الآيات هنا تحتمل احتمالين: الأول: أن يراد بها التسع وغيرها مما يخرق العادة، وهي علامة لصدق الآتي بها. الثاني: أن يراد: آيات التوراة التي هي كآيات القرآن. <q>﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلنَّبِیِّـۧنَ بِغَیۡرِ ٱلۡحَقِّۗ﴾</q> - آثار متعلقة بالآية ٢٠٦٥- عن ابن مسعود، أنّ رسول الله ﷺ قال: «أشد الناس عذابًا يوم القيامة رجل قتله نبيٌّ، أو قتل نبيًّا، وإمام ضلالة، ومُمَثِّل من المُمَثِّلِين»{72}. (١/٣٨٨) <q>﴿ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝٦١﴾</q> - تفسير ٢٠٦٦- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿ذلك بما عصوا وكانوا يعتدون﴾</q>، قال: اجْتَنِبُوا المعصية والعدوان؛ فإنّ بهما هَلَك مَن هَلَك قبلك من الناس{73}. (ز) ٢٠٦٧- قال مقاتل بن سليمان: <q>﴿ذلك بما عصوا وكانوا يعتدون﴾</q> في أديانهم{7}. (ز) ",footnotes:1:أخرجه ابن جرير ٢/١٢.أخرجه ابن جرير ٢/١٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/١٢٣ (٦١٦).أخرجه عبد الرزاق ١/٤٧، وابن جرير ٢/١٢، وابن أبي حاتم ١/١٢٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٤-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢/١٣، وابن أبي حاتم ١/١٢٣.أخرجه ابن جرير ٢/١٣، وابن أبي حاتم ١/١٢٢. وفي آخره: قال عمرو بن حماد -وهو من رواة الأثر-: أجِموا، يعني: بَشِمُوا. وقال أبو زرعة -وهو أيضًا من رواة الأثر-: فأجِموا، أي: كرهوه.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/١٤. وفي تفسير الثعلبي ١/٢٠٥، وتفسير البغوي ١/١٠١ عنه قوله: كانوا يعجنون المن بالسلوى فيصيران واحدًا.أخرجه سعيد بن منصور (١٩١- تفسير)، وابن أبي داود في المصاحف ص٥٤. وعزاه السيوطي إلى ابن المنذر. والقراءة شاذة. انظر: مختصر ابن خالويه ص٦، والمحتسب ١/١٧١.أخرجه ابن أبي داود ص٥٥.أخرجه الطبراني في الكبير (١٠٥٩٧). وأخرجه ابن جرير ٢/١٨، وابن أبي حاتم ١/١٢٣ كلاهما من طريق نافع بن أبي نُعَيْم، دون ذكر ابن الأزرق.الفراديس: البساتين والكروم. لسان العرب (فردس).الدِّياس: دوس الطعام ودقه ليخرج الحب منه. لسان العرب (دوس).الوابِل: المطر الشديد، الضخم القطر. لسان العرب (وبل).عزاه السيوطي إلى الطستي في مسائله. وفي المعجم الكبير للطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧): أما سمعت قول أبي ذؤيب الهذلي: قد كنت تحسبني كأغنى وافد قدم المدينة عن زراعة فوم.أخرجه ابن جرير ٢/١٧، وابن أبي حاتم ١/١٢٣ من طريق عكرمة بلفظ: الخبز. وقال مرة: البر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ١/١٢٣.علَّقه ابن أبي حاتم ١/١٢٣.تفسير مجاهد من طريق ابن أبي نجيح ص٢٠٤، وأخرجه ابن جرير ٢/١٧. وعزاه السيوطي إلى وكيع، وعبد بن حميد.أخرجه ابن جرير ٢/١٨.أخرجه ابن جرير ٢/١٦. وعلَّقه ابن أبي حاتم ١/١٢٣. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ١/١٢٣.أخرجه سفيان الثوري ص٤٦، وابن جرير ٢/١٧. وعلَّقه ابن أبي حاتم ١/١٢٣. وعزاه السيوطي إلى وكيع، وعبد بن حميد.أخرجه عبد الرزاق ١/٤٧ من طريق مَعْمَر، وابن جرير ٢/١٦. وعلَّقه ابن أبي حاتم ١/١٢٣. وذكره يحيى بن سلام عن قتادة -كما في تفسير ابن أبي زمنين ١/١٤٥-.أخرجه ابن جرير ٢/١٧، وابن أبي حاتم ١/١٢٣.أخرجه ابن جرير ٢/١٨، وابن أبي حاتم ١/١٢٣.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/١٧.أخرجه ابن جرير ٢/٢٠.أخرجه ابن جرير ٢/٢٠، وابن أبي حاتم ١/١٢٤.تفسير الثعلبي ١/٢٠٦، وتفسير البغوي ١/١٠١.تفسير مقاتل بن سليمان ١/١١١.علقه ابن جرير ٢/٢٣. والقراءة شاذة. انظر: البحر المحيط ١/٢٣٤، وتفسير القرطبي ١/٤٢٩.أخرجه ابن أبي داود ص٥٧، وعزاه السيوطي إلى ابن الأنباري في المصاحف. وأخرجه ابن حاتم ١/١٢٤ دون ذكر القراءة من طريق الكسائي، بزيادة: وكان يومئذ عليها. وقراءة الأعمش (مصرَ) دون تنوين ذكرها ابن خالويه في مختصره ص٦.أخرجه ابن أبي حاتم ١/١٢٤ من طريق ابن عيينة. وعزاه السيوطي إلى سفيان بن عينية، وابن جرير.أخرجه ابن جرير ٢/٢٣، وابن أبي حاتم ١/١٢٤.أخرجه ابن جرير ٢/٢٢.تفسير البغوي ١/١٠١.أخرجه ابن جرير ٢/٢٢. وعلَّقه ابن أبي حاتم ١/١٢٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢/٢٢، وابن أبي حاتم ١/١٢٤.أخرجه ابن جرير ٢/٢٣.علَّقه ابن أبي حاتم ١/١٢٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٥-.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/٢٣.أخرجه ابن جرير ٢/٢٧.أخرجه ابن أبي حاتم ١/١٢٤. وقال عَقِبَه: يعني بأصحاب القبالات: أصحاب الجزية.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه عبدالرزاق ١/٤٧، وابن جرير ٢/٢٦، وابن أبي حاتم ١/١٢٥.الكُسْتِيج: خيط غليظ يشده الذِّمِّيُّ فوق ثيابه دون الزُّنّار. القاموس المحيط (كسج).الزُّنّار: هو خيط غليظ بقدر الإصبع من الإبريسم يشد على الوسط، وهو ما يلبسه النصارى والمجوس. لسان العرب (زنر)، والتعريفات ص١٥٣.تفسير البغوي ١/١٠١.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/٢٧، وابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن جرير ٢/٢٨، وابن أبي حاتم ١/١٢٥.تفسير مقاتل بن سليمان ١/١١١.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١/٢٠٦.تفسير مقاتل بن سليمان ١/١١١.تفسير الثعلبي ١/٢٠٦.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن جرير ٢/٢٨. وعلَّقه ابن أبي حاتم ١/١٢٦.أخرجه ابن جرير ٢/٢٨، وابن أبي حاتم ١/١٢٦.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن أبي حاتم ١/١٢٦. وعزاه السيوطي إلى أبي داود، والطيالسي.تفسير مقاتل بن سليمان ١/١١١.أخرجه أحمد ٦/٤١٣ (٣٨٦٨) من طريق أبان، عن عاصم، عن أبي وائل، عن ابن مسعود به. قال البزار في مسنده ٥/١٣٩ (١٧٢٨): «وهذا الحديث لا نعلم أحدًا أسنده عن عاصم عن أبي وائل إلا أبان». وقال الدارقطني في العلل ٥/٣٠٤ (٩٠٠): «والموقوف أصح». وقال الألباني في الصحيحة ١/٥٦٩ (٢٨١): «إسناد جيد». وله طرق أخرى عند الطبراني في المعجم الكبير، قال المنذري في الترغيب ٣/١١٧ (٣٣٠٩) في إحداها: «رواته ثقات إلا ليث بن أبي سليم». وقال الهيثمي في المجمع ٥/٢٣٦: «وفيه ليث بن أبي سليم، وهو مدلس، وبقية رجاله ثقات». وضعّفه الألباني في الضعيفة ٣/١٦١ (١١٥٩) بليث وعبّاد بن كثير. وقال الهيثمي في المجمع ١/١٨١ في الطريق الأخرى: «فيه الحارث الأعور، وهو ضعيف».أخرجه ابن أبي حاتم ١/١٢٦.تفسير مقاتل بن سليمان ١/١١١.
