quran[4]{c,v,t}:
  2,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قُلۡنَا ٱدۡخُلُوا۟ هَـٰذِهِ ٱلۡقَرۡیَةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٨٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: هي أريحا، وهي قرية الجبّارين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: بيت المقدس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٨٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>: هي الرّملة، والأردن، وفلسطين، وتدمر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمر- في قوله: <span class="qpc-hafs">﴿ادخلوا هذه القرية﴾</span>، قال: بيت المقدس{4}. (١/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط- <span class="qpc-hafs">﴿وإذْ قُلْنا ادْخُلُوا هَذِهِ القَرْيَةَ﴾</span>، قال: أمّا القرية فبيت المقدس{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وإذْ قُلْنا ادْخُلُوا هَذِهِ القَرْيَةَ﴾</span>، يعني: بيت المقدس{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذْ قُلْنا ادْخُلُوا هَذِهِ القَرْيَةَ﴾</span>، يعني: إيلْياء، وهم يومئذ من وراء البحر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- قال: هي أريحا، وهي قريبة من بيت المقدس{8}<span class=comment-ref>٢٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٠</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١/٤١٧) القول بأنها أريحا، معللًا ذلك <span class="mustanad">بمخالفته للدلالات العقلية</span>، فقال: «وقال آخرون: هي أريحا، ... وهذا بعيد؛ لأنها ليست على طريقهم، وهم قاصدون بيت المقدس لا أريحا، ... والصحيح هو الأول؛ لأنها بيت المقدس».</p><p>ويلاحظ أن <u>ابنَ جرير</u> (١/٧١٣) ذكر أثر ابن زيد ضمن الآثار التي أوردها لبيان أن القرية التي أُمروا بدخولها بيت المقدس، ولم يجعل قوله مخالفًا لبقية الأقوال كما فعل <u>ابن كثير</u>.</div></p><p><h3><span class="qpc-hafs">﴿فَكُلُوا۟ مِنۡهَا حَیۡثُ شِئۡتُمۡ رَغَدࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٨٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿رغدا﴾</span>، قال: بلا حساب عليهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط- <span class="qpc-hafs">﴿رغدا﴾</span>، قال: الهنيء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكلوا منها حيث شئتم رغدا﴾</span>، يعني: ما شئتم، وإذ شئتم، وحيث شئتم{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱدۡخُلُوا۟ ٱلۡبَابَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٨٩٧<span class="dash">-</span></span> عن أبي سعيد الخدري، عن النبي ﷺ: «<b>قال الله لبني إسرائيل: <span class="qpc-hafs">﴿وادخلوا الباب سجدا وقولوا حطة نغفر لكم خطاياكم﴾</span></b>»{12}. (١/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وادْخُلُوا البابَ سجدا﴾</span>، قال: باب صغير{13}. (١/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٨٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كان الباب قِبَل القبلة{10}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوْفي- في قوله: <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قال: هو أحد أبواب بيت المقدس، وهو يُدْعى: باب حِطَّة{15}. (١/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: باب حِطَّة مِن باب إيلْياء بيت المقدس{16}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٢<span class="dash">-</span></span> وعن <span class="name-2">الضَّحّاك بن مُزاحم</span>، نحوه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، في قوله: <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قال: كنا نتحدث أنه باب من أبواب بيت المقدس{18}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط- <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قال: أمّا الباب فباب من أبواب بيت المقدس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، يعني: باب إيلْياء سُجَّدًا، فدخلوا مُتَحَرِّفِين على شق وجوههم{20}<span class=comment-ref>٢٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤١</span> نقل <u>ابن عطية</u> (١/٢٢٢) <b>قولين</b> آخرين في معنى الباب؛ فقال: «وقيل: هو باب القبة التي كان يصلي إليها موسى ﵇. وروي عن مجاهد أيضًا: أنّه باب في الجبل الذي كلَّم عليه موسى كالفرضة».</div></p><p><h3><span class="qpc-hafs">﴿سُجَّدࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وادْخُلُوا البابَ سُجَّدًا﴾</span>، قال: أُمِرُوا أن يدخلوا رُكَّعًا من باب صغير، فدخلوا من قِبَل أسْتاهِهِم{21}<span class=comment-ref>٢٤٢</span>. (١/٣٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٢</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١/٧١٤-٧١٥ بتصرف) معنى السجود في أثر ابن عباس قائلًا: «وأصل السجود: الانحناء لمن سجد له معظمًا بذلك. فكل مُنْحَنٍ لشيء تعظيمًا له فهو ساجد ... فذلك تأويل ابن عباس قوله: <span class="qpc-hafs">﴿سجدا﴾</span>: ركعًا؛ لأن الراكع منحنٍ، وإن كان الساجد أشد انحناء منه».</p><p><span class="comment-type-1">ووجَّه</span> <u>ابنُ تيمية</u> (١/٢١٤-٢١٦) تفسير السجود بالانحناء أو بالركوع بقوله: «السجود في اللغة: هو الخضوع. وقال غير واحد من المفسرين: أمروا أن يدخلوا رُكَّعًا منحنين، فإنّ الدخول مع وضع الجبهة على الأرض لا يمكن، وقد قال تعالى: <span class="qpc-hafs">﴿ألم تر أن الله يسجد له من في السماوات ومن في الأرض والشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس﴾</span> ...، ومعلوم أنّ سجود كل شيء بحسبه، ليس سجود هذه المخلوقات وضع جباهها على الأرض، وقد قال النبي ﷺ ... لما غربت الشمس: «إنها تذهب فتسجد تحت العرش» ... فعُلِم أنّ السجود اسم جنس، وهو كمال الخضوع لله». وقال أيضًا: «من قال بهذا -كان سجود أحدهم على خده- أو قال بأنهم أمروا بالركوع، فهو يقول دخولهم وهم سجد بالأرض فيه صعوبة، وقد يؤذي أحدهم، ولكن هو ممكن، فإنّ الإنسان يمكنه حال السجود أن يزحف إذا كانت الأرض لا تؤذيه».</p><p>و<span class="comment-type-2">انتَقَدَ</span> <u>ابنُ تيمية</u> (١/٢١٧) أيضًا هذا المعنى بقوله: «... وقال: قيل ادخلوا رُكَّعًا، فلو جزمنا أن هذا مأخوذ عن النبي ﷺ لجزمنا بأنّ الله أمرهم بالركوع، لكن ظاهر القرآن هو السجود، والسجود المطلق هو السجود المعروف، وكون الباب جعل صغيرًا إنما يكون لمن يُكره على الدخول منه ليحتاج أن ينحني، وهؤلاء قصدت طاعتهم، فأمروا بالخضوع لله والاستغفار، فدخولهم سُجَّدًا هو خضوع لله».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (١/٢٢٢) عموم معنى السجود للقولين، فقال: «و<span class="qpc-hafs">﴿سجَّدًا﴾</span> قال ابن عباس ﵄: معناه: ركوعًا. وقيل: متواضعين خضوعًا لا على هيئة معينة. والسجود يعم هذا كله؛ لأنه التواضع».</div></p><p><div></p><p><p><span class="item-no">١٩٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عِكْرِمة- <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قال: فدخلوا على شِقٍّ{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- قال: أمَر موسى قومَه أن يدخلوا المسجد، ويقولوا: حِطَّة، وطُؤْطِئَ لهم الباب ليخفضوا رؤوسهم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٠٩<span class="dash">-</span></span> عن <span class="name-2">عِكْرِمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قال: طَأْطِئُوا رؤوسكم{24}. (١/٣٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُولُوا۟ حِطَّةࣱ نَّغۡفِرۡ لَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَيْر- في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، قال: مغفرة{25}. (١/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عِكْرِمَة- في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، قال: لا إله إلا الله{26}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، قال: قولوا: هذا الأمرَ حقٌّ. كما قيل لكم{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١٣<span class="dash">-</span></span> عن الأوزاعي، قال: كتب <span class="name-1">ابن عباس</span> إلى رجل قد سمّاه يسأله عن قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>. فكتب إليه: أن أقِرُّوا بالذنب{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١٤<span class="dash">-</span></span> عن <span class="name-1">البراء [بن عازب]</span> -من طريق أبي إسحاق- في قول الله: <span class="qpc-hafs">﴿سيقول السفهاء من الناس﴾</span> [البقرة:١٤٢]، قال: اليهود، قيل لهم: <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span> قال: ركعًا، <span class="qpc-hafs">﴿وقولوا حطة﴾</span>: مغفرة، فدخلوا على أسْتاهِهم، وجعلوا يقولون: حنطة: حبة حمراء فيها شعرة، فذلك قوله تعالى: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- قال: باب حِطَّة من باب بيت المقدس، أمر موسى قومه أن يدخلوا ويقولوا: حِطَّة. وطُؤْطِىءَ لهم الباب ليخفضوا رؤوسهم، فلما سجدوا قالوا: حِنطَة{30}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١٦<span class="dash">-</span></span> عن <span class="name-2">عِكْرِمة مولى ابن عباس</span> -من طريق الحَكَمِ بن أبان- في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، قال: قولوا: لا إله إلا الله{31}<span class=comment-ref>٢٤٣</span><span class=comment-ref>٢٤٤</span>. (١/٣٧٩)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٣</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١/٧١٧) أثر عكرمة قائلًا: «كأنهم وجَّهوا تأويله: قولوا الذي يحط عنكم خطاياكم، وهو قول: لا إله إلا الله».</p><p><span class="comment-type-1">ووجهه</span> <u>ابنُ القيم</u> (١/١٢٦) بقوله: «وكأن أصحاب هذا القول اعتبروا الكلمة التي تحط بها الخطايا، وهي كلمة التوحيد».</div></p><p><div><span class=comment-ref>٢٤٤</span> بيَّن <u>ابنُ جرير</u> (١/٧١٩) إعراب <span class="qpc-hafs">﴿حطة﴾</span> على قول عكرمة بقوله: «وأما على تأويل قول عكرمة فإنّ الواجب أن تكون القراءة بالنصب في <span class="qpc-hafs">﴿حطة﴾</span>؛ لأن القوم إن كانوا أمروا أن يقولوا: لا إله إلا الله، أو أن يقولوا: نستغفر الله، فقد قيل لهم: قولوا هذا القول، فـ<span class="qpc-hafs">﴿قولوا﴾</span> واقع حينئذ على الحطة؛ لأنّ الحطة على قول عكرمة هي قول: لا إله إلا الله، وإذا كانت هي قول: لا إله إلا الله، فالقول عليها واقع، كما لو أمر رجل رجلًا بقول الخير فقال له: (قل خيرًا) نصبًا، ولم يكن صوابًا أن يقول له: قل خير، إلا على استكراه شديد».</p><p>ثم <span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> قول عكرمة <span class="mustanad">معللًا ذلك بمخالفته لإجماع القراء،</span> فقال: «وفي إجماع القَرَأة على رفع الحطة بيان واضح على خلاف الذي قاله عكرمة من التأويل في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>».</p><p>وقال <u>ابنُ عطية</u> (١/٢٢٢، ٢٢٣) <span class="comment-type-1">موجِّهًا</span>: «وقال عكرمة وغيره: أمروا أن يقولوا: لا إله إلا الله، لتحط بها ذنوبهم. وقال ابن عباس: قيل لهم: استغفروا، وقولوا ما يحط ذنوبكم. وقال آخرون: قيل لهم أن يقولوا: هذا الأمر حقٌّ كما أُعْلِمنا. وهذه الأقوال الثلاثة تقتضي النصب».</div></p><p><div></p><p><p><span class="item-no">١٩١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩١٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، أي: احْطُط عنا خطايانا{32}<span class=comment-ref>٢٤٥</span><span class=comment-ref>٢٤٦</span>. (١/٣٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٥</span> بيَّن <u>ابنُ جرير</u> (١/٧٢٠ بتصرف) إعراب <span class="qpc-hafs">﴿حطة﴾</span> على قول الحسن وقتادة بقوله: «الواجب على التأويل الذي رويناه عن الحسن وقتادة في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span> أن تكون القراءة في <span class="qpc-hafs">﴿حطة﴾</span> نصبًا؛ لأن من شأن العرب إذا وضعوا المصادر مواضع الأفعال وحذفوا الأفعال أن ينصبوا المصادر، كقول القائل للرجل: سمعًا وطاعة. بمعنى: أسمع سمعًا وأطيع طاعةً، وكما قال جل ثناؤه: <span class="qpc-hafs">﴿معاذ الله﴾</span> [يوسف:٢٣]. بمعنى: نعوذ بالله».</div></p><p><div><span class=comment-ref>٢٤٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (١/١٢٦) على قول مَن قال: أُمِروا بكلمة التوحيد. وكذا قول مَن قال: أمُروا بالاستغفار. بقوله (١/١٢٦): «وعلى القولين فيكونون مأمورين بالدخول بالتوحيد والاستغفار، وضُمِن لهم بذلك مغفرة خطاياهم».</div></p><p><div></p><p><p><span class="item-no">١٩١٩<span class="dash">-</span></span> عن ابن جُرَيْجٍ، قال: قال لي <span class="name-2">عطاء</span> في قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، قال: سمعنا أنه يحط عنهم خطاياهم{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٢٠<span class="dash">-</span></span> وقال <span class="name-2">وهْب بن مُنَبِّه</span>: قيل لهم: ادخلوا الباب، فإذا دخلتموه فاسجدوا شكرًا لله ﷿{1}<span class=comment-ref>٢٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٧</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> (١/٢١٦) هذا القول بقوله: «فكأنّ صاحب هذا القول جعل السجود بعد الدخول».</div></p><p><div></p><p><p><span class="item-no">١٩٢١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، قال: تُحَطُّ عنكم خطاياكم{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، وذلك أنّ بني إسرائيل خرجوا مع يُوشَع بن نُون بن اليشامع بن عميهوذ بن غيران بن شونالخ بن إفْرايِيم بن يوسف ﵇ من أرض التيه إلى العُمْران حِيال أرِيحا، وكانوا أصابوا خطيئة، فأراد الله ﷿ أن يغفر لهم، وكانت الخطيئة أنّ موسى ﵇ كان أمرهم أن يدخلوا أرض أريحا التي فيها الجبارون، فلهذا قال لهم: <span class="qpc-hafs">﴿قولوا حطة﴾</span>، يعني: بحطة حُطَّ عنا خطايانا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٢٣<span class="dash">-</span></span> <span class="name-3">عن عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهَبْ- قال: <span class="qpc-hafs">﴿وقولوا حطة﴾</span> يحط الله بها عنكم ذنبكم وخطيئتكم{37}<span class=comment-ref>٢٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٨</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١/٧١٩) رفع <span class="qpc-hafs">﴿حطة﴾</span>، وأنّ معناها: احطط عنا خطايانا، <span class="mustanad">مستندًا إلى ظاهر القرآن، وإلى النظائر</span>، فقال: «والذي هو أقرب عندي في ذلك إلى الصواب، وأشبه بظاهر الكتاب: أن يكون رفع <span class="qpc-hafs">﴿حطة﴾</span> بنية خبر محذوف قد دل عليه ظاهر التلاوة، وهو: دخولنا الباب سجدًا حطة. فكفى من تكريره بهذا اللفظ ما دلَّ عليه الظاهر من التنزيل، وهو قوله: <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، كما قال -جلَّ ثناؤه-: <span class="qpc-hafs">﴿وإذ قالت أمة منهم لم تعظون قوما الله مهلكهم أو معذبهم عذابا شديدا قالوا معذرة إلى ربكم﴾</span> [الأعراف:١٦٤]، يعني: موعظتنا إياهم معذرة إلى ربكم، فكذلك عندي تأويل قوله: <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، يعني بذلك: وإذ قلنا ادخلوا هذه القرية، وادخلوا الباب سجدًا، وقولوا: دخولنا ذلك سجدًا حطة لذنوبنا. وهذا القول على نحو تأويل الربيع بن أنس، وابن جريج، وابن زيد، الذي ذكرناه آنفًا».</div></p><p><h3><span class="qpc-hafs">﴿نَّغۡفِرۡ لَكُمۡ خَطَـٰیَـٰكُمۡۚ وَسَنَزِیدُ ٱلۡمُحۡسِنِینَ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وسنزيد المحسنين﴾</span>، قال: مَن كان منكم محسنًا زِيد في إحسانه، ومَن كان مخطئًا نغفر له خطيئته{38}. (١/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿وقولوا حطة نغفر لكم خطاياكم وسنزيد المحسنين﴾</span>، قال: مَن كان خاطئًا غُفِرَت له خطيئته، ومَن كان محسنًا زِيد في إحسانه{39}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نغفر لكم خطاياكم وسنزيد المحسنين﴾</span> الذين لم يصيبوا خطيئة، فزادهم الله إحسانًا إلى إحسانهم{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَّغۡفِرۡ لَكُمۡ خَطَـٰیَـٰكُمۡۚ وَسَنَزِیدُ ٱلۡمُحۡسِنِینَ ۝٥٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٩٢٧<span class="dash">-</span></span> عن أبي سعيد، قال: سرنا مع رسول الله ﷺ، حتى إذا كان من آخر الليل أجَزْنا في ثَنِيَّةٍ{41} يقال لها: ذات الحَنظَل، فقال: «<b>ما مَثَلُ هذه الثَّنِيَّة الليلة إلا كمَثَلِ الباب الذي قال الله لبني إسرائيل: <span class="qpc-hafs">﴿ادخلوا الباب سجدا وقولوا حطة نغفر لكم خطاياكم﴾</span></b>»{42}. (١/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٢٨<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق عبد الله بن الحارث- قال: إنّما مَثَلُنا في هذه الأمة كسفينة نوح، وكباب حِطَّة في بني إسرائيل{43}. (١/٣٨١)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.أخرجه عبد الرزاق ١/٤٦، وابن جرير ١/٧١٢، وابن أبي حاتم ١/١١٦، والحاكم ٢/٢٦٢.أخرجه ابن جرير ١/٧١٠، وابن أبي حاتم ١/١١٦.أخرجه ابن جرير ١/٧١٠، وابن أبي حاتم ١/١١٦.تفسير مقاتل بن سليمان ١/١٠٩. وينظر: تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.أخرجه ابن جرير ١/٧١٣.تفسير مجاهد ص٢٠٣، وأخرجه ابن أبي حاتم ١/١١٧. وقد أورده قبل ذلك ١/٦٥ عند قوله تعالى: <span class="qpc-hafs">﴿ويآدم اسكن أنت و زوجك الجنة وكلا منها رغدا﴾</span>. أما السيوطي فاكتفى بإيراده عند هذه الآية.أخرجه ابن أبي حاتم ١/١١٧.تفسير مقاتل بن سليمان ١/١٠٩.أخرجه ابن جرير ٢/٧٢٤، وابن أبي حاتم ١/١١٧ (٥٧٠) بهذا اللفظ. وأخرجه البخاري ٤/١٥٦ (٣٤٠٣)، ومسلم ٤/٢٣١٢ (٣٠١٥) عن أبي هريرة ﵁، أن رسول الله ﷺ قال: «قيل لبني إسرائيل: <span class="qpc-hafs">﴿ادخلوا الباب سجدا وقولوا حطة﴾</span>. فبدلوا، فدخلوا يزحفون على أستاههم، وقالوا: حبة في شعرة».أخرجه ابن جرير ١/٧١٤، وابن أبي حاتم ١/١١٧، والحاكم ٢/٢٦٢. وذكره السيوطي بلفظ: باب ضيِّق، وعزاه إلى من سبق إضافة إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ١/١١٧.أخرجه ابن جرير ١/٧١٤.تفسير مجاهد ص٢٠٣، وأخرجه ابن جرير ١/٧١٤، وابن أبي حاتم ١/١١٧. وعزاه السيوطي إلى عبد حميد.عَلَّقه ابن أبي حاتم ١/١١٧ (عقب ٥٧٤).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١/٧١٠، وابن أبي حاتم ١/١١٧.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧١٤، وابن أبي حاتم ١/١١٧.أخرجه ابن أبي حاتم ١/١١٨.تفسير مجاهد ص٢٠٣، وأخرجه ابن جرير ١/٧٢٧. وعلَّقه ابن أبي حاتم ١/١١٨-١١٩.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.أخرجه ابن جرير ١/٧١٦، وابن أبي حاتم ١/١١٨، والحاكم ٢/٢٦٢. وعزاه السيوطي إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر. وفي لفظ عند ابن جرير ١/٧١٨: أمروا أن يستغفروا.أخرجه البيهقي في الأسماء والصفات (٢٠٥).أخرجه ابن جرير ١/٧١٨، وابن أبي حاتم ١/١١٨.أخرجه ابن أبي حاتم ١/١١٨.أخرجه أبو الشيخ الأصبهاني في طبقات المحدثين بأصبهان ٤/١١. وفي الدر وتفسير ابن أبي حاتم ذِكْر اليهود فقط.أخرجه ابن جرير ١/٧١٤، ٧٢٦، وابن أبي حاتم ١/١١٧ (٥٧٤). وعزاه السيوطي إلى عبد حميد.أخرجه ابن جرير ١/٧١٧، وابن أبي حاتم ١/١١٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبدالرزاق ١/٤٧، وابن جرير ١/٧١٦، وابن أبي حاتم ١/١١٩. وفي تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨ هذا القول عن قتادة، وجاء في آخره: وهو أمرٌ بالاستغفار.أخرجه ابن جرير ١/٧١٧. وعَلَّقه ابن أبي حاتم ١/١١٨.تفسير الثعلبي ١/٢٠١، وتفسير البغوي ١/٩٨.أخرجه ابن جرير ١/٧١٦، ٧٢٨، وابن أبي حاتم ١/١١٨.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧١٦.أخرجه ابن جرير ١/٧٢٢.أخرجه ابن أبي حاتم ١/١١٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/١١٠.الثَّنَيَّة: العقبة، أو طريقها، أو الجبل، أو الطريقة فيه، أو إليه. القاموس المحيط (ثنى).أخرجه البزار كما في كشف الأستار ٢/٣٣٧ (١٨١٢)، والواقدي في المغازي ٢/٥٨٣-٥٨٤.</p><p>قال الهيثمي ٦/١٤٤ (١٠١٧٧): «ورجاله ثقات».أخرجه ابن أبي شيبة ١٢/٧٧.
  2,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَبَدَّلَ ٱلَّذِینَ ظَلَمُوا۟ قَوۡلًا غَیۡرَ ٱلَّذِی قِیلَ لَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٢٩<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>قيل لبني إسرائيل: ادخلوا الباب سجدًا، وقولوا: حطة. فَبَدَّلوا، فدخلوا يزحفون على أسْتاهِهم، وقالوا: حبة في شعرة</b>»{1}<span class=comment-ref>٢٤٩</span>. (١/٣٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٩</span> قال <u>ابنُ تيمية</u> (١/٢١٧): «فإنّ الثابت عن النبي ﷺ أنهم دخلوا يزحفون على أستاههم، وفي لفظ: على أوراكهم، والمعنى واحد، وما نُقِل خلاف هذا فإنما أخذ عن أهل الكتاب، وقد كان يؤخذ عنهم الحق والباطل».</div></p><p><div></p><p><p><span class="item-no">١٩٣٠<span class="dash">-</span></span> عن ابن عباس وأبي هريرة، قالا: قال رسول الله ﷺ: «<b>دخلوا الباب الذي أمروا أن يدخلوا فيه سجدًا، يزحفون على أسْتاهِهم، وهم يقولون: حنطة في شعيرة</b>»{2}. (١/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الكَنُود- قال: قيل لهم: <span class="qpc-hafs">﴿ادخلوا الباب سجدا﴾</span> فدخلوا مقنعي رؤوسهم، <span class="qpc-hafs">﴿وقولوا حطة﴾</span> فقالوا: حِنطة، حبة حمراء فيها شعيرة، فذلك قوله: <span class="qpc-hafs">﴿فبدل الذين ظلموا﴾</span>{3}<span class=comment-ref>٢٥٠</span>. (١/٣٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (١/٢١٧) على قول ابن مسعود بقوله: «وقول ابن مسعود: مقنعي رؤوسهم، لا يناقض الزحف على أستاههم».</div></p><p><div></p><p><p><span class="item-no">١٩٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السُّدِّي، عن مُرَّة الهمداني- أنهم قالوا: هَطِّي سَمْقاثا أزْبَة مزبا. فهي بالعربية: حَبَّةُ حنطةٍ حمراء مثقوبة، فيها شُعَيْرَة سوداء{4}<span class=comment-ref>٢٥١</span>. (١/٣٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٥١</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> (١/٢١٦-٢١٧) بقوله: «ثبت عن النبي ﷺ أنهم قالوا: حبة في شعرة. وإذا ثقبت الحبة وأدخلت فيها الشعرة، فإنه يقال: حبة شعرة. ويقال: شعرة في حبة. وهذا معنى ما رواه السدي عن مرة عن ابن مسعود أنه قال: إنهم قالوا هطي سمقاثا أزبه مزبا. وهي بالعربية: حبة حنطة حمراء مثقوبة فيها شعرة سوداء، وهذا موافق لما ثبت عن النبي ﷺ، لكن النبي ﷺ إنما تكلم بالعربية، وهذا اللفظ أخذه ابن مسعود عن أهل الكتاب».</div></p><p><div></p><p><p><span class="item-no">١٩٣٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: من التبديل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَيْر- قال: فدخلوا من قبل أستاههم، وقالوا: حنطة -استهزاء-. قال: فذلك قوله ﷿: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{6}<span class=comment-ref>٢٥٢</span>. (١/٣٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٢</span> ذكر <u>ابنُ تيمية</u> (١/٢١٧) التوجيه السابق لقول ابن مسعود من طريق السدي عن مرة، ثم قال: «وهذا أصح من قول ابن عباس أنهم قالوا: حنطة، مع أن هذا مروي عن غير واحد ... لكن قد يقال: الحبة هي الحنطة، وهم لم يقولوا بالعربية بل بلسانهم، وهم إذا قالوا بلسانهم ما معناه: حبة حنطة، جاز أن يقال: حنطة، وحديث ابن مسعود وقد ذكر أنهم قالوا: حبة حنطة، فلا يكون في القول خلاف». وبيَّن موافقة قول ابن عباس ﵄ في صفة الدخول لحديث النبي ﷺ فقال: «وابن عباس قال: يزحفون على أستاههم، كالمرفوع».</div></p><p><div></p><p><p><span class="item-no">١٩٣٥<span class="dash">-</span></span> عن <span class="name-2">يحيى بن رافع</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٣٦<span class="dash">-</span></span> و<span class="name-2">الضّحاك بن مزاحم</span>، نحوه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوْفي- قال: لَمّا دخلوا الباب قالوا: حبة في شعيرة. فَبَدَّلوا قولًا غير الذي قيل لهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٣٨<span class="dash">-</span></span> عن ابن جُرَيج، قال: قال لي <span class="name-2">عطاء [بن أبي رباح]</span> في قوله: <span class="qpc-hafs">﴿فبدل الذين ظلموا﴾</span>، قال: أمّا تبديلهم فسمعنا أنهم قالوا: حنطة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٣٩<span class="dash">-</span></span> قال ابن جريج: وقال <span class="name-1">ابن عباس</span>: لَمّا دخلوا قالوا: حبة في شعرة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٠<span class="dash">-</span></span> عن <span class="name-2">أبي الكَنُود</span> -من طريق أبي سعد الأَزْدِي- <span class="qpc-hafs">﴿وقولوا حطة﴾</span>، فقالوا: حنطة، حبة حمراء فيها شعرة. فأنزل الله: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- قال: أمر موسى قومه أن يدخلوا المسجد ويقولوا: حطة، وطُؤْطِئَ لهم الباب ليخفضوا رؤوسهم، فلم يسجدوا، ودخلوا على أجنبهم إلى الجبل -وهو الجبل الذي تجلى له ربه جل ثناؤه- وقالوا: حنطة. فذلك التبديل الذي قال الله -تعالى ذكره-: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النَّضْر بن عَرَبِيٍّ- <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قال: فدخلوا مقنعي رؤوسهم، <span class="qpc-hafs">﴿وقولوا حطة﴾</span> فقالوا: حنطة حمراء فيها شعرة. فذلك قوله: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٤<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وادخلوا الباب سجدا﴾</span>، قالا: دخلوها على غير الجهة التي أمروا بها، دخلوها مُتَزَحِّفِين على أوْراكِهِم، وبَدَّلوا قولًا غير الذي قيل لهم، فقالوا: حبة في شعيرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة</span>، في قوله: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>، قال: بيّن لهم أمرًا عَلِمُوه، فخالفوه إلى غيره، جرأة على الله وعتوًّا{14}. (١/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسْباط- قال: دخلوا مُقْنِعِي رؤوسهم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وادخلوا الباب سجدا وقولوا حطة﴾</span> قال: فكان سجود أحدهم على خده، و<span class="qpc-hafs">﴿قولوا حطة﴾</span> يحط عنكم خطيئاتكم، فقالوا: حنطة. وقال بعضهم: حبة في شعيرة. <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٨<span class="dash">-</span></span> قال [<span class="name-3">محمد بن السائب</span>] <span class="name-3">الكلبي</span>: لما فَصَلَت بنو إسرائيل من التِّيه، ودخلوا إلى العُمْران، فكانوا بجبال أريحا من الأُرْدُن؛ قيل لهم: <span class="qpc-hafs">﴿ادخلوا هذه القرية فكلوا منها حيث شئتم رغدا﴾</span>. وكان بنو إسرائيل قد خطئوا خطيئة، فأحب الله أن يستنقذهم منها إن تابوا، وقال لهم: إذا انتهيتم إلى باب القرية فاسجدوا، وقولوا: حطة؛ نحط عنكم خطاياكم، <span class="qpc-hafs">﴿وسنزيد المحسنين﴾</span> الذين لم يكونوا من أهل تلك الخطيئة، إحسانًا إلى إحسانهم. فأما المحسنون فقالوا الذي أمروا به، وأما الذين عصوا فقالوا قولًا غير الذي قيل لهم، قالوا: ...{17} بالسُّرْيانِيَّة، قالوها استهزاءً وتبديلًا لقول الله{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فلما دخلوا إلى الباب فعل المحسنون ما أمروا به، وقال الآخرون: هطا سقماثا. يعنون: حنطة حمراء. قالوا ذلك استهزاءً وتبديلًا لما أمروا به، فدخلوا مستقلين، فذلك قوله ﷿: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب-: <span class="qpc-hafs">﴿وادخلوا الباب سجدا وقولوا حطة﴾</span> يحط الله بها عنكم ذنبكم وخطيئاتكم، قال: فاستهزؤوا به -يعني: بموسى-، وقالوا: ما يشاء موسى أن يلعب بنا إلا لعب بنا، حِطَّةٌ حِطَّةٌ! أيُّ شيء حِطَّةٌ؟! وقال بعضهم لبعض: حنطة{20}<span class=comment-ref>٢٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٣</span> نقل <u>ابن تيمية</u> (١/٢١٦) أقوال السلف في معنى <span class="qpc-hafs">﴿حطة﴾</span> عن ابن الجوزي، ثم جمع بينها بقوله: «الأقوال كلها واحدة، بخلاف صفة الدخول».</div></p><p><h3><span class="qpc-hafs">﴿فَأَنزَلۡنَا عَلَى ٱلَّذِینَ ظَلَمُوا۟ رِجۡزࣰا مِّنَ ٱلسَّمَاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٥١<span class="dash">-</span></span> عن سعد بن مالك، وأسامة بن زيد، وخُزَيْمَة بن ثابت، قالوا: قال رسول الله ﷺ: «<b>إنّ هذا الطّاعون رِجْزٌ، وبَقِيَّةُ عذاب عُذِّب به أناس من قبلكم، فإذا كان بأرض وأنتم بها فلا تخرجوا منها، وإذا بلغكم أنه بأرض فلا تدخلوها»</b>{21}. (١/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- قال: كل شيء في كتاب الله تعالى من الرجز يعني به: العذاب{22}. (١/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٤<span class="dash">-</span></span> و<span class="name-2">أبي مالك</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٥<span class="dash">-</span></span> وا<span class="name-2">لحسن البصري</span>، نحو ذلك{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط-، نحو ذلك{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في الآية، قال: الرجز: الغضب{22}. (١/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق مُجالِد- قال: الرِّجز: إما الطاعون، وإما البرد{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿رجزا﴾</span>، قال: عذابًا{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأنزلنا على الذين ظلموا رجزا﴾</span> يعني: عذابًا <span class="qpc-hafs">﴿من السماء﴾</span> -كقوله في سورة الأعراف [٧١]: <span class="qpc-hafs">﴿قال قد وقع عليكم من ربكم رجس﴾</span> يعني: عذابًا-. ويُقال: الطاعون. ويقال: الظلمة شبه النار. <span class="qpc-hafs">﴿بما كانوا يفسقون﴾</span>، وأهلك منهم سبعون ألفًا في يوم واحد عقوبةً لقولهم: هطا سقماثا. فهذا القول ظلمهم{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهَب- قال: الرِّجز: العذاب، وكل شيء في القرآن «رِجز» فهو: عذاب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب-: لَمّا قيل لبني إسرائيل: ادخلوا الباب سجدًا، وقولوا: حطة. فبدل الذين ظلموا منهم قولًا غير الذي قيل لهم؛ بعث الله -جل وعز- عليهم الطاعون، فلم يُبْقِ منهم أحدًا. وقرأ: <span class="qpc-hafs">﴿فأنزلنا على الذين ظلموا رجزا من السماء بما كانوا يفسقون﴾</span>. قال: وبقي الأبناء، ففيهم الفضل، والعبادة التي توصف في بني إسرائيل، والخير، وهلك الآباء كلهم، أهلكهم الطاعون{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سَلّام</span>: بلغني: أنّ ذلك العذابَ الطاعونُ، فمات منهم سبعون ألفًا{31}<span class=comment-ref>٢٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٤</span> <span class="comment-type-3">رجَّح</span> ابن جرير (١/٧٣١) العموم في معنى الرجز، وأنه يشمل كل ما قاله المفسرون، ورأى مع ذلك أنّ تفسيره بالطاعون يكتسب قوة؛ لكونه <span class="mustanad">تفسيرًا مرويًّا عن النبي</span> ﷺ، لكنه بيَّن مع ذلك أنه لا يستطيع القطع بصحته وحده دون ما سواه، فقال: «وقد دللنا على أن تأويل الرجز: العذاب. وعذاب الله أصناف مختلفة، وقد أخبر الله أنه أنزل على الذين وصفنا أمرهم الرجز من السماء، وجائز أن يكون ذلك طاعونًا، وأن يكون غيره، ولا دلالة في ظاهر القرآن ولا في أثر عن الرسول ثابت أي أصناف ذلك كان، فالصواب من القول في ذلك أن يُقال كما قال الله: فأنزلنا عليهم رجزًا من السماء بفسقهم، غير أنّه يغلب على نفسي صحة ما قاله ابن زيد؛ للخبر الذي ذكرت عن رسول الله ﷺ في إخباره عن الطاعون أنه رجز، وأنه عُذِّبَ به قوم قبلنا، وإن كنت لا أقول إنّ ذلك كذلك يقينًا؛ لأن الخبر عن رسول الله ﷺ لا بيان فيه أي أمة عذبت بذلك، وقد يجوز أن يكون الذين عذبوا به كانوا غير الذين وصف الله صفتهم في قوله: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولا غير الذي قيل لهم﴾</span>».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (١/١٢٦) على قول ابن زيد بقوله: «وعلى هذا فالطاعون بالرصد لمن بدل دين الله قولًا وعملًا».</div></p><p><h3><span class="qpc-hafs">﴿بِمَا كَانُوا۟ یَفۡسُقُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿بما كانوا يفسقون﴾</span>، أي: بما تَعَدَّوْا مِن أمري{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿بِما كانُوا يَفْسُقُونَ﴾</span>، قال: بما كانوا يعصون{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿بِما كانُوا يَفْسُقُونَ﴾</span>، أي: بما تَعَدَّوْا في أمري{34}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِمَا كَانُوا۟ یَفۡسُقُونَ ۝٥٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٩٦٧<span class="dash">-</span></span> عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «<b>يهود أمتي المرجية</b>». ثم قرأ: <span class="qpc-hafs">﴿فبدل الذين ظلموا قولًا غير الذي قيل لهم﴾</span>{35}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٤/١٥٦ (٣٤٠٣)، ٦/١٩ (٤٤٧٩)، ٦/٦٠ (٤٦٤١)، ومسلم ٤/٢٣١٢ (٣٠١٥).أخرجه ابن جرير ١/٧٢٤. وأسنده ابن كثير في تفسيره ١/٢٧٦ إلى ابن إسحاق.أخرجه ابن جرير ١/٧٢٥، وابن أبي حاتم ١/١١٨، ١١٩، والطبراني (٩٠٢٧). وعزاه السيوطي إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١/٧٢٥، وابن أبي حاتم ١/١١٩ (٥٨٩)، والطبراني (٩٠٢٧)، والحاكم ٢/٣٢١، ووافقه الذهبي. وعزاه السيوطي إلى أبي الشيخ.عَلَّقه سفيان الثوري ص٤٥ (١٨).أخرجه ابن جرير ١/٧٢٥-٧٢٦، وابن أبي حاتم ١/١١٧، ١١٩، والحاكم ٢/٢٦٢. وعزاه السيوطي إلى وكيع، والفريابي، وعبد بن حميد، وابن المنذر. وفي لفظ عند ابن جرير ١/٧٢٧: فدخلوا على أستاههم مقنعي رءوسهم.علَّقه ابن أبي حاتم ١/١١٩.أخرجه ابن جرير ١/٧٢٨.أخرجه ابن جرير ١/٧٢٨. وعلَّق ابن أبي حاتم ١/١١٩ قول عطاء.أخرجه ابن أبي حاتم ١/١١٩.تفسير مجاهد ص٢٠٣، وأخرجه ابن جرير ١/٧٢٧. وعلَّقه ابن أبي حاتم ١/١١٨-١١٩.أخرجه ابن جرير ١/٧٢٧. وعلَّقه ابن أبي حاتم ١/١١٩.أخرجه عبد الرزاق ١/٤٧، وابن جرير ١/٧٢٦. وعلَّقه ابن أبي حاتم ١/١١٩.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/١١٨.أخرجه ابن جرير ١/٧٢٨، وابن أبي حاتم ١/١١٨، ١٢٠.ذكر محققه أن هنا طمس في الأصل. ولعله ما ورد عن ابن مسعود وغيره في رواية سابقة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٢-.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧٢٨. وعلَّقه ابن أبي حاتم ١/١١٩.أخرجه البخاري ٦/٢٥٥٧ (٦٥٧٣)، ومسلم ٤/١٧٣٨ (٢٢١٨) وهذا لفظه، من حديث أسامة.أخرجه ابن جرير ١/٧٣٠، وابن أبي حاتم ١/١٢٠.علَّقه ابن أبي حاتم ١/١٢٠.أخرجه ابن أبي حاتم ١/١٢٠.أخرجه ابن جرير ١/٧٣٠، وابن أبي حاتم ١/١٢٠.أخرجه ابن أبي حاتم ١/١٢٠.أخرجه عبد الرزاق ١/٤٧، وابن جرير ١/٧٣٠. وعلَّقه ابن أبي حاتم ١/١٢٠.تفسير مقاتل بن سليمان ١/١١٠.أخرجه ابن جرير ١/٧٣١.أخرجه ابن جرير ١/٧٣٠.تفسير ابن أبي زمنين ١/١٤٣.أخرجه ابن جرير ١/٤٣٥ عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وما يُضِلُّ بِهِ إلّا الفاسِقِينَ﴾</span> [البقرة:٢٦].أخرجه ابن أبي حاتم ١/١٢٠ (٥٩٥).أخرجه ابن أبي حاتم ١/١٢٠ (٥٩٦).أخرجه الرافعي في تاريخ قزوين ٤/١.
  2,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذِ ٱسۡتَسۡقَىٰ مُوسَىٰ لِقَوۡمِهِۦ فَقُلۡنَا ٱضۡرِب بِّعَصَاكَ ٱلۡحَجَرَۖ فَٱنفَجَرَتۡ مِنۡهُ ٱثۡنَتَا عَشۡرَةَ عَیۡنࣰاۖ قَدۡ عَلِمَ كُلُّ أُنَاسࣲ مَّشۡرَبَهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَيْر- قال: ذلك في التِّيه؛ ظُلِّل عليهم الغمام، وأُنزل عليهم المن والسلوى، وجعل لهم ثيابًا لا تَبْلى ولا تَتَّسِخ، وجُعل بين ظهرانيهم حجر مُرَبَّع، وأمر موسى فضرب بعصاه الحجر، فانفجرت منه اثنتا عشرة عينًا، في كل ناحية منه ثلاث عيون، لكل سبط عين، ولا يرتحلون مَنقَلَة{1} إلا وجدوا ذلك الحجر منهم بالمكان الذي كان به منهم في المنزل الأول{2}. (١/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن الحكم، عن الضحاك- قال: لما كان بنو إسرائيل في التِّيه شق لهم من الحجر أنهارًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٠<span class="dash">-</span></span> وقال <span class="name-1">عبد الله بن عباس</span>: كان حجرًا خفيفًا مُرَبَّعًا على قَدْر رأس الرجل، كان يضعه في مِخْلاته{4}، فإذا احتاجوا إلى الماء وضعه وضربه بعصاه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧١<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: هو الحجر الذي وضع موسى ثوبه عليه ليغتسل، ففر بثوبه، ومر به على ملأ من بني إسرائيل حين رموه بالأُدْرَة{6}، فلما وقف أتاه جبرائيل، فقال: إن الله تعالى يقول: ارفع هذا الحجر، فلي فيه قدرة، ولك فيه معجزة. فرفعه، ووضعه في مِخْلاته{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- قال: انفجر لهم الحجر بضربة موسى اثنتي عشرة عينًا، كل ذلك كان في تِيهِهم حين تاهُوا{8}. (١/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span>، قال: استسقى موسى لقومه، فقال: اشربوا، يا حمير. فقال الله تعالى له: لا تُسَمِّ عبادي: حميرًا{9}. (١/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٤<span class="dash">-</span></span> عن <span class="name-2">عَطِيَّة العَوْفِي</span>: وجعل لهم حجرًا مثل رأس الثور، يُحمل على ثور، فإذا نزلوا منزلًا وضعوه، فضربه موسى بعصاه، فانفجرت منه اثنتا عشرة عينًا، فاستمسك الماء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٥<span class="dash">-</span></span> قال <span class="name-2">وهْب بن مُنَبِّه</span>: كان موسى ﵇ يقرع لهم أقرب حجر من عرض الحجارة، فيتفجّر لهم عيونًا، لكلّ سبط عين، وكانوا اثني عشر سِبْطًا، ثمّ تسيل كلّ عين في جدول إلى السِّبْط الذي أمر بسقيهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٦<span class="dash">-</span></span> وقال <span class="name-2">عطاء</span>: كان للحجر أربعة وجوه، لكل وجه ثلاثة أعين، لكل سبط عين ...، كان يضربه موسى اثنتي عشرة ضربة، فيظهر على موضع كل ضربة مثل ثدي المرأة، فيعرق، ثم يتفجر الأنهار، ثم تسيل{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> في قوله: <span class="qpc-hafs">﴿وإذ استسقى موسى لقومه﴾</span> الآية، قال: كان هذا في البَرِّيَّة حيث خَشوا الظَّمَأ، استسقى موسى، فأمر بحجر أن يضربه بعصاه، وكان حجرًا طُورانِيًّا من الطُّور يحملونه معهم، حتى إذا نزلوا ضربه موسى بعصاه <span class="qpc-hafs">﴿فانفجرت منه اثنتا عشرة عينا قد علم كل أناس مشاربهم﴾</span>، قال: لكل سبط منهم عين معلومة يستفيد ماءَها{13}. (١/٣٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط- قال: كان ذلك في التِّيه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٧٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- قال: كان لبني إسرائيل حجر، فكان يضعه هارون، ويضربه موسى بعصاه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٠<span class="dash">-</span></span> عن <span class="name-2">جُوَيْبِر</span> أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿قد علم كل أناس مشربهم﴾</span>. قال: كان موسى يضع الحجر، ويقوم من كل سِبْط رجل، ويضرب موسى الحجر، فينفجر منه اثنتا عشرة عينًا، فَيَنتَضِحُ{16} من كل عين على رجل، فيدعو ذلك الرجل سِبْطه إلى تلك العين{17}. (١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨١<span class="dash">-</span></span> وقال <span class="name-2">أبو رَوْق</span>: كان الحجر من الكذان{18}، وكان فيه اثنتا عشرة حفرة، ينبع من كلِّ حفرة عين ماء عذب فُرات فيأخذوه، فإذا فرغوا وأراد موسى حمله ضربه بعصاه، فيذهب الماء، وكان يسقي كل يوم ستمائة ألف{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٢<span class="dash">-</span></span> قال <span class="name-2">أبو عمرو بن العلاء</span>: انبجست: عرقت وانفجرت، أي: سالت{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذ استسقى موسى لقومه﴾</span> وهم في التِّيه، قالوا: من أين لنا شراب نشرب؟ فدعا موسى ﵇ ربه أن يسقيهم، فأوحى الله ﷿ إلى موسى ﵇: <span class="qpc-hafs">﴿فقلنا اضرب بعصاك الحجر﴾</span>. وكان الحجر خفيفًا مُرَبَّعًا، فضربه، <span class="qpc-hafs">﴿فانفجرت منه﴾</span> من الحجر <span class="qpc-hafs">﴿اثنتا عشرة عينا﴾</span>، فَرَووا بإذن الله ﷿، وكانوا اثني عشر سبطًا، لكل سبط من بني إسرائيل عين تجري على حِدَة، لا يخالطهم غيرهم، فذلك قوله سبحانه: <span class="qpc-hafs">﴿قد علم كل أناس مشربهم﴾</span>، يعني: كل سبط مشربهم. يقول الله ﷿: <span class="qpc-hafs">﴿كلوا﴾</span> من المن والسلوى، <span class="qpc-hafs">﴿واشربوا﴾</span> من العيون، وهو من رزق الله حلالًا طيبًا، فذلك قوله سبحانه: <span class="qpc-hafs">﴿كلوا من طيبات ما رزقناكم﴾</span> [طه:٨١] ... وكان موسى ﵇ إذا ظَعَنَ{21} حمل الحجر معه، وتنصَبُّ العيون منه، ثم إنهم قالوا: يا موسى، فأين اللباس؟ فجعلت الثياب تطول مع أولادهم، وتبقى على كبارهم، ولا تمزق، ولا تبلى، ولا تدنس، وكان لهم عمود من نور يضيء لهم بالليل إذا ارتحلوا وغاب القمر{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- استسقى لهم موسى في التِّيه، فَسُقوا في حجر مثل رأس الشاة، قال: يُلْقُونه في جوانب الجُوالِق{23} إذا ارتحلوا، ويقرعه موسى بالعصا إذا نزل، فتنفجر منه اثنتا عشرة عينًا، لكل سبط منهم عين، فكان بنو إسرائيل يشربون منه، حتى إذا كان الرحيل استمسكت العيون، وقيل به فأُلْقِي في جانب الجوالق، فإذا نزل رُمِي به، فقرعه بالعصا، فتفجرت عين من كل ناحية مثل البحر{14}<span class=comment-ref>٢٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٥</span> <span class="comment-type-4">ذهب</span> <u>ابنُ جرير</u> (٢/٦) إلى أنّ موسى ﵇ استسقى ربه الماءَ لبني إسرائيل: «في الحال التي تاهوا فيها في التِّيه» <span class="mustanad">مستندًا إلى آثار السلف</span>، ولم يذكر قولًا غيره.</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span>، قال: لا تَسْعَوا في الأرض{25}. (١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، قال: لا تَسْعَوْا في الأرض فسادًا{26}. (١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِي</span> -من طريق السُّدِّي- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، قال: يعني: ولا تمشوا بالمعاصي{17}. (١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، قال: لا تسيروا في الأرض مُفْسِدِين{28}. (١/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span> يقول: لا تَعْلُوا، ولا تَسْعَوْا في الأرض <span class="qpc-hafs">﴿مفسدين﴾</span> يقول: لا تعملوا في الأرض بالمعاصي، فرَفَعُوا من المن والسلوى لِغَدٍ، فذلك قوله سبحانه: <span class="qpc-hafs">﴿ولا تطغوا فيه﴾</span> [طه:٨١]، يقول: لا ترفعوا منه لغد{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>: لا تطغوا في الأرض مفسدين. لا تَعْثَ: لا تَطْغَ{30}<span class=comment-ref>٢٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٦</span> جمع <u>ابنُ جرير</u> (٢/١٠) بين تلك الأقوال، فقال: «<span class="qpc-hafs">﴿لا تعثوا﴾</span>: لا تطغوا، ولا تسعوا <span class="qpc-hafs">﴿في الأرض مفسدين﴾</span>».</div></p></div>",footnotes:1:المَنقَلَة: المرحلة من مراحل السفر. لسان العرب (نقل).أخرجه ابن جرير ٢/٦، وابن أبي حاتم ١/١٢١-١٢٢. وقد أورده السيوطي مختصرًا من طريق عكرمة، وعزاه إلى ابن جرير ٢/٧.أخرجه ابن أبي حاتم ١/١٢١.وعاء يوضع فيه الخَلى، وهو الحشيش. تاج العروس (خلى).تفسير الثعلبي ١/٢٠٣، وتفسير البغوي ١/١٠٠.الأُدْرة -بضم الهمزة- نفخة في الخُصْيَة. لسان العرب (أدر).تفسير الثعلبي ١/٢٠٣، وتفسير البغوي ١/١٠٠.أخرجه ابن جرير ٢/٧. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن أبي حاتم ١/١٢١.تفسير الثعلبي ١/٢٠٣.تفسير البغوي ١/١٠٠.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢/٦ من طريق سعيد، وابن أبي حاتم ١/١٢١ مختصرًا من طريق شيبان. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٤- نحوه.أخرجه ابن جرير ٢/٨.أخرجه ابن أبي حاتم ١/١٢١.حمل الماء من النهر أو البئر. المصباح المنير (نضح).أخرجه ابن أبي حاتم ١/١٢٢.الكذان: حجارة رخوة. النهاية (كذن).تفسير الثعلبي ١/٢٠٣.تفسير البغوي ١/١٠٠.أي: ذهب وسار، ويقال لكل من سافر: ظعن. لسان العرب (ظعن).تفسير مقاتل بن سليمان ١/١١٠.الجوالق: بكسر الجيم واللام، وبضم الجيم وفتح اللام وكسرها: وعاء. القاموس المحيط (جوق).أخرجه ابن جرير ٢/٨.أخرجه ابن جرير ٢/١١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢/١٠، وابن أبي حاتم ١/١٢٢.أخرجه ابن أبي حاتم ١/١٢٢.أخرجه عبد الرزاق ٢/٣١١، وابن أبي حاتم ١/١٢٢ من طريق شيبان. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٤-. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/١٠.
  2,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قُلۡتُمۡ یَـٰمُوسَىٰ لَن نَّصۡبِرَ عَلَىٰ طَعَامࣲ وَ ٰ⁠حِدࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٩٩١<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿وإذ قلتم يا موسى لن نصبر على طعام واحد﴾</span>، قال: كان طعامهم السلوى، وشرابهم المن، فسألوا ما ذكر، فقيل لهم: <span class="qpc-hafs">﴿اهبطوا مصرا فإن لكم ما سألتم﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وإذ قلتم يا موسى لن نصبر على طعام واحد﴾</span>، قال: المن والسلوى استبدلوا به البَقْلَ وما ذُكِر معه{2}. (١/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَبّاد بن منصور- قال: فبَطِرُوا ذلك، ولم يصبروا عليه، وذكروا عَيْشهم الذي كانوا يعيشون فيه، وكانوا قومًا أهل أعداس وبصل وبقول وفوم، فذكروا عَيْشَهم من ذلك، فقالوا: <span class="qpc-hafs">﴿يا موسى لن نصبر على طعام واحد فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها وعدسها وبصلها﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- قال: مَلُّوا طعامهم في البَرِّيَّة، وذكروا عَيْشَهم الذي كانوا فيه قبل ذلك، فقالوا: <span class="qpc-hafs">﴿ادع لنا ربك﴾</span> الآية{4}. (١/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق أبي جعفر الرازي- قال: إنهم لما قدموا الشام فقدوا أطْعِماتهم التي كانوا يأكلونها، فقالوا: <span class="qpc-hafs">﴿فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها وعدسها وبصلها﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسْباط-: أُعطوا في التِّيهِ ما أُعْطُوا، فأَجِمُوا ذلك، وقالوا: <span class="qpc-hafs">﴿يا موسى لن نصبر على طعام واحد فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها وعدسها وبصلها﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلما طال عليهم المن والسلوى سألوا موسى نبات الأرض، فذلك قوله ﷿: <span class="qpc-hafs">﴿وإذ قلتم يا موسى﴾</span> في التِّيه: <span class="qpc-hafs">﴿لن نصبر على طعام واحد﴾</span> يعني: المَنَّ والسَّلْوى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٩٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- قال: كان طعام بني إسرائيل في التِّيه واحدًا، وشرابهم واحدًا، كان شرابهم عسلًا ينزل لهم من السماء يقال له: المن، وطعامهم طير يقال له: السلوى، يأكلون الطير ويشربون العسل، لم يكونوا يعرفون خبزًا ولا غيره، فقالوا: يا موسى، إنا لن نصبر على طعام واحد، <span class="qpc-hafs">﴿فادع لنا ربك يخرج لنا مما تنبت الأرض﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>{8}<span class=comment-ref>٢٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٧</span> <span class="comment-type-4">ذهب</span> <u>ابنُ جرير</u> (٢/١٢-١٤) <span class="mustanad">مستندًا إلى آثار السلف</span> إلى أنّ سبب مسألتهم موسى ﵇ ذلك أنهم ملُّوا طعامَهم، وذكروا عيشهم الذي كانوا فيه بمصر. ولم يذكر قولًا غيره.</div></p><p><h3><span class="qpc-hafs">﴿فَٱدۡعُ لَنَا رَبَّكَ یُخۡرِجۡ لَنَا مِمَّا تُنۢبِتُ ٱلۡأَرۡضُ مِنۢ بَقۡلِهَا وَقِثَّاۤىِٕهَا وَفُومِهَا وَعَدَسِهَا وَبَصَلِهَاۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٩٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق سفيان- أنه قرأ: (وثُومِها){9}. (١/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> قال: قراءتي قراءةُ زيد،= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠١<span class="dash">-</span></span> وأنا آخذ ببضعة عشر حرفًا من قراءة <span class="name-1">ابن مسعود</span>، هذا أحدها: (من بَقْلِها وقِثّائِها وثُومِها){10}<span class=comment-ref>٢٥٨</span>. (١/٣٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٨</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٢/١٨-١٩) قراءة ابن مسعود ﵄ بقوله: «فإن كان ذلك صحيحًا فإنه من الحروف المبدلة، كقولهم: وقعوا في عاثور شر، وعافور شر. وكقولهم للأثافي: أثاثي. وللمغافير: مغاثير. وما أشبه ذلك مما تقلب الثاء فاء، والفاء ثاء؛ لتقارب مخرج الفاء من مخرج الثاء».</div></p><p><h3><span class="qpc-hafs">﴿فَٱدۡعُ لَنَا رَبَّكَ یُخۡرِجۡ لَنَا مِمَّا تُنۢبِتُ ٱلۡأَرۡضُ مِنۢ بَقۡلِهَا وَقِثَّاۤىِٕهَا وَفُومِهَا وَعَدَسِهَا وَبَصَلِهَاۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبر، عن الضحاك- أنّ نافع بن الأزرق قال له: أخبرني عن قوله تعالى: <span class="qpc-hafs">﴿وفومها﴾</span>. قال: الحنطة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أُحَيْحَةَ بنَ الجُلاحِ وهو يقول:</p><p>قد كنت أغنى الناس شخصًا واحدًا ورَد المدينةَ عن زراعةِ فُومِ{11}<span class=comment-ref>٢٥٩</span>. (١/٣٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩</span> <span class="comment-type-3">رجَّحَ</span> <u>ابنُ عطية</u> (١/٢٢٨) أن يكون المراد بـ(الفوم): الحنطة، لا الثوم. <span class="mustanad">مستندًا إلى قول ابن عباس هذا، وما ورد في لغة العرب</span>.</div></p><p><div></p><p><p><span class="item-no">٢٠٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبرني عن قوله ﷿: <span class="qpc-hafs">﴿وفومها﴾</span>. قال: الفومُ: الحنطة. قال: وهل تعرف العرب ذلك؟. قال: نعم، أما سمعت أبا مِحْجَنٍ الثَّقَفيَّ وهو يقول:</p><p>قد كنت أحسبني كأغنى واحد قَدِم المدينة عن زراعةِ فُومِ</p><p>قال: يا ابن أمِّ الأزرق، ومن قرأها على قراءةِ ابن مسعود، فهو هذا المُنتِن، قال أمية ابن أبي الصَّلْت:</p><p>كانت منازلهم إذ ذاك ظاهرةً فيها الفراديسُ{12} والفومانُ والبصلُ</p><p>وقال أميةُ بن الصَّلْتِ أيضًا:</p><p>أنفي الدِّياسَ{13} من الفومِ الصحيح كما أنفي من الأرض صوب الوابِل{14} البَرَدِ{15}. (١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وفومها﴾</span>، قال: الحنطة والخبز.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٥<span class="dash">-</span></span> وفي لفظ -من طريق أبي رَوْق، عن الضحاك-: البر.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٦<span class="dash">-</span></span> وفي لفظ-من طريق رِشْدِين بن كُرَيْب، عن أبيه-: الحِنْطَة، بلسان بني هاشم{16}. (١/٣٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الحسن- قال: الفوم: الثوم{17}. (١/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٨<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٠٩<span class="dash">-</span></span> و<span class="name-2">الضّحاك بن مُزاحِم</span>، نحو ذلك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح، وابن جُرَيج- في قوله: <span class="qpc-hafs">﴿وفومها﴾</span>، قال: الخبز{19}. (١/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق لَيْث- قال: هو هذا الثوم{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٣<span class="dash">-</span></span> و<span class="name-2">أبي مالك</span> -من طريق حُصَيْن- في قوله: <span class="qpc-hafs">﴿وفومها﴾</span>، قالا: الحنطة{21}. (١/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٤<span class="dash">-</span></span> عن <span class="name-2">عِكْرِمَة مولى ابن عباس</span>، نحو ذلك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٥<span class="dash">-</span></span> عن <span class="name-2">عَطاء بن أبي رَباح</span> -من طريق ابن جُرَيج- في قوله: <span class="qpc-hafs">﴿وفومها﴾</span>، قال: الخبز{23}. (١/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد، ومَعْمر- قالا: الفوم: الحب الذي يختبز الناس منه{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسْباط- <span class="qpc-hafs">﴿وفومها﴾</span>: الحنطة{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠١٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: الفوم: الثوم. وفي بعض القراءة: (وثُومِها){26}. (١/٣٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلما طال عليهم المنُّ والسلوى سألوا موسى نباتَ الأرض، فذلك قوله ﷿: <span class="qpc-hafs">﴿وإذ قلتم يا موسى﴾</span> في التِّيه: <span class="qpc-hafs">﴿لن نصبر على طعام واحد﴾</span> يعني: المَنَّ والسلوى؛ <span class="qpc-hafs">﴿فادع لنا ربك يخرج لنا مما تنبت الأرض من بقلها وقثائها وفومها﴾</span> يعني: الثوم، <span class="qpc-hafs">﴿وعدسها وبصلها﴾</span>، فغضب موسى ﵇{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٢١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- الفوم: الخبز{28}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ أَتَسۡتَبۡدِلُونَ ٱلَّذِی هُوَ أَدۡنَىٰ بِٱلَّذِی هُوَ خَیۡرٌۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿أتستبدلون الذي هو أدنى﴾</span>، قال: أرْدَأ{29}. (١/٣٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿أتستبدلون الذي هو أدنى بالذي هو خير﴾</span>، يقول: أتستبدلون الذي هو شرٌّ بالذي هو خير{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٢٤<span class="dash">-</span></span> قال <span class="name-3">الكَلْبِيُّ</span>: قال لهم موسى ﵇: <span class="qpc-hafs">﴿أتَسْتَبْدِلُونَ الَّذِي هُوَ أدْنى﴾</span> أخَسُّ وأَرْدى <span class="qpc-hafs">﴿بِالَّذِي هُوَ خَيْرٌ﴾</span> أشرف وأفضل. وجعل الحنطة أدنى في القيمة وإن كان هي خيرًا من المن والسلوى{31}<span class=comment-ref>٢٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٠</span> <span class="comment-type-4">ذهب</span> <u>ابنُ جرير</u> (٢/١٩-٢٠) إلى أن <span class="qpc-hafs">﴿أدنى﴾</span> في قوله تعالى: <span class="qpc-hafs">﴿الذي هو أدنى﴾</span> بمعنى: أخسّ، وأوضع، وأصغر قدرًا وخطرًا.</div></p><p><div></p><p><p><span class="item-no">٢٠٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال أتستبدلون الذي هو أدنى﴾</span> يقول: الذي هو دون المن والسلوى من نبات الأرض <span class="qpc-hafs">﴿بالذي هو خير﴾</span> يعني: المن والسلوى؟! فقال موسى: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱهۡبِطُوا۟ مِصۡرࣰا فَإِنَّ لَكُم مَّا سَأَلۡتُمۡۗ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٠٢٦<span class="dash">-</span></span> في قراءة <span class="name-1">أُبَيّ بن كعب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٢٧<span class="dash">-</span></span> و<span class="name-1">عبد الله بن مسعود</span>: (اهْبِطُوا مِصْرَ) بغير ألف{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٢٨<span class="dash">-</span></span> عن <span class="name-2">الأعمش</span> أنّه كان يقرأ: (اهْبِطُوا مِصْرَ) بلا تنوين، ويقول: هي مصر التي عليها صالحُ بن عليٍّ{34}<span class=comment-ref>٢٦١</span>. (١/٣٨٧)</p></p><p></div></p><p><div><span class=comment-ref>٢٦١</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (٢/٢٢) على هذه القراءة، فقال: «أما الذي لم يُنَوِّن (مصر) فإنه لا شك أنه عنى مصر التي تعرف بهذا الاسم بعينها، دون سائر البلدان غيرها».</div></p><p><h3><span class="qpc-hafs">﴿ٱهۡبِطُوا۟ مِصۡرࣰا فَإِنَّ لَكُم مَّا سَأَلۡتُمۡۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>، قال: مِصْرًا من الأَمْصار{35}. (١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>، قال: يعني به: مِصْرَ فرعون{36}. (١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن جُرَيج- <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>، قال: مِصْرًا من الأمصار، زعموا أنهم لم يرجعوا إلى مصر{37}<span class=comment-ref>٢٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٢</span> <b>بيَّنَ</b> <u>ابنُ جرير</u> (٢/٢٢) أنّ قراءة <span class="qpc-hafs">﴿مصرًا﴾</span> بالتنوين تحتمل أن يكون المراد بها مصر فرعون، ويكون ذلك من باب الاتباع لكتابة المصحف، كما في قوله تعالى: <span class="qpc-hafs">﴿قَوارِيرا * قَوارِيرَ﴾</span> [الإنسان: ١٥-١٦].</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (١/٢٣٠) على هذه القراءة، فقال: «جمهور الناس يقرءُون <span class="qpc-hafs">﴿مصرًا﴾</span> بالتنوين، وهو خط المصحف، إلا ما حكي عن بعض مصاحف عثمان ﵁. وقال مجاهد وغيره ممن صرفها: أراد مصرًا من الأمصار غير معيّن. <span class="mustanad">واستدلوا بما اقتضاه القرآن</span> من أمرهم بدخول القرية، <span class="mustanad">وبما تظاهرت به الرواية</span> أنهم سكنوا الشام بعد التيه. وقالت طائفة ممن صرفها: أراد مصر فرعون بعينها. <span class="mustanad">واستدلوا بما في القرآن</span> من أنّ الله تعالى أورث بني إسرائيل ديار آل فرعون وآثارهم، وأجازوا صرفها».</div></p><p><div></p><p><p><span class="item-no">٢٠٣٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحم</span>: هو مِصْر موسى وفرعون{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>، يقول: مِصْرًا من الأمصار{39}. (١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط-: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span> من الأمصار، <span class="qpc-hafs">﴿فإن لكم ما سألتم﴾</span> فلما خرجوا من التِّيه رفع المن والسلوى، وأكلوا البقول{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>، قال: يعني به: مِصْر فرعون{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: مِصْرًا من الأمصار{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٧<span class="dash">-</span></span> قال <span class="name-3">الكَلْبِيُّ</span>: (اهْبِطُوا مِصْرَ) بغير ألف، يعني: مصر بعينها{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span> من الأمصار <span class="qpc-hafs">﴿فإن لكم ما سألتم﴾</span> من نبات الأرض{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- <span class="qpc-hafs">﴿اهبطوا مصرا﴾</span>، قال: مِصْرًا من الأمصار –و(مصر) لا تُجْرى في الكلام-. فقالوا: أي مصر؟ قال: الأرض المقدسة، وقرأ قول الله -جل ثناؤه-: <span class="qpc-hafs">﴿ادْخُلُوا الأَرْضَ المُقَدَّسَةَ الَّتِي كَتَبَ اللَّهُ لَكُمْ﴾</span> [المائدة:٢١]{41}<span class=comment-ref>٢٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٣</span> <b>توقَّف</b> <u>ابنُ جرير</u> (٢/٢٢) في تحديد المراد بـ(مصر) في الآية، وجوَّزَ كلا القَولَيْن، وقال: «والذي نقول به في ذلك: إنّه <b>لا دلالة في كتاب الله على الصواب من هذين التأويلين، ولا خبر به عن الرسول ﷺ يقطع مجيئه العذر»</b>.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١/٤٢٨) كلامَ ابن جرير، وتوقّفَه في المراد بـ(مصر) في الآية، فقال: <b>«وهذا الذي قاله فيه نظر، والحق أن المراد مصرًا من الأمصار</b> كما <span class="mustanad">روي عن ابن عباس وغيره</span>، والمعنى على ذلك؛ لأنّ موسى ﵇ يقول لهم: هذا الذي سألتم ليس بأمر عزيز، بل هو كثير في أي بلد دخلتموها وجدتموه، فليس يساوي مع دناءته وكثرته في الأمصار أن أسأل الله فيه. ولهذا قال: <span class="qpc-hafs">﴿أتستبدلون الذي هو أدنى بالذي هو خير اهبطوا مصرا فإن لكم ما سألتم﴾</span> أي: ما طلبتم، ولما كان سؤالهم هذا من باب البطر والأشر ولا ضرورة فيه لم يجابوا إليه».</div></p><p><h3><span class="qpc-hafs">﴿وَضُرِبَتۡ عَلَیۡهِمُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٤٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</span>، قال: هؤلاء يهود بني إسرائيل. قلت له: هم قِبْطُ مِصْر؟ قال: وما لِقِبْط مصر وهذا؟!، لا والله، ما هم هم، ولكنهم اليهود، يهود بني إسرائيل{46}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلذِّلَّةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</span>، قال: هم أصحاب القَبالات، كفروا بالله العظيم{47}. (١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحم</span> -من طريق جُوَيْبِر- قوله: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ﴾</span>، قال: الذل{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَوْف- <span class="qpc-hafs">﴿وضربت عليهم الذلة﴾</span>، قال: أدْرَكَتْهُم هذه الأمة وإن المجوس لَتَجْبِيهم الجزية{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٤<span class="dash">-</span></span> عن عَبّاد بن منصور، قال: سألت <span class="name-2">الحسن</span> عن قوله: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ﴾</span>، قال: أذلهم الله فلا مَنَعَة لهم، وجعلهم الله تحت أقدام المسلمين{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٦<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وضربت عليهم الذلة والمسكنة﴾</span>، قال: يعطون الجزية عن يد وهم صاغرون{51}. (١/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧<span class="dash">-</span></span> قال <span class="name-2">عطاء بن السائب</span>: هو الكُسْتِيج{52}، والزُّنّار{53}، وزِيِّ اليهودية{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضربت عليهم الذلة﴾</span>، يعني: على اليهود الذِّلَّة، وهي: الجِزْيَة{7}<span class=comment-ref>٢٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٤</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢/٢٦) <span class="mustanad">مستندًا إلى القرآن الكريم، وآثار السلف</span> إلى أنّ المراد بـ<span class="qpc-hafs">﴿الذلة﴾</span>: الصَّغار الذي ذكره الله تعالى في قوله: <span class="qpc-hafs">﴿حتى يُعطوا الجزية عن يدٍ وهم صاغرون﴾</span> [التوبة ٢٩].</div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمَسۡكَنَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٤٩<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿والمسكنة﴾</span>، قال: الفاقَة{56}. (١/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-، نحو ذلك{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحم</span> -من طريق جُوَيْبِر- قوله: <span class="qpc-hafs">﴿والمسكنة﴾</span>: الجزية{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢<span class="dash">-</span></span> عن <span class="name-2">عَطِيَّة العَوْفي</span> -من طريق عُبَيْد بن الطُّفَيل- <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</span>، قال: الخراج{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسْباط- قوله: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ﴾</span>، قال: الفقر{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والمسكنة﴾</span>، يعني: الفقر{7}<span class=comment-ref>٢٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٥</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢/٢٦-٢٧) <span class="mustanad">مستندًا في ذلك إلى آثار السلف</span> إلى أنّ المراد بـ(المسكنة) في هذا الموضع: مسكنة الفاقة والحاجة، وهي خشوعها وذلها.</div></p><p><h3><span class="qpc-hafs">﴿وَبَاۤءُو﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، في قوله: <span class="qpc-hafs">﴿وباءوا﴾</span>، قال: انقلبوا{62}. (١/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق</span>: استحقوا{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعني: اسْتَوْجَبُوا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨<span class="dash">-</span></span> عن <span class="name-3">الكسائي</span>: رجعوا{63}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عَطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، يقول: اسْتَوْجَبوا سخطًا{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، قال: استحقوا الغضب من الله{67}. (١/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، قال: فحَدَثَ عليهم غضبٌ من الله{68}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعني: استوجبوا غضب الله ﷿{7}<span class=comment-ref>٢٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٦</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٢/٢٧-٢٨) <span class="mustanad">مستندًا إلى القرآن الكريم، وأقوال السلف</span> إلى أنّ المراد بقوله تعالى: <span class="qpc-hafs">﴿وباءُوا بِغَضَبٍ مِنَ اللَّهِ﴾</span> أي: انصرفوا ورجعوا ...، ثم قال: «فمعنى الكلام إذًا: ورجعوا منصرفين متحملين غضب الله، قد صار عليهم من الله غضب، ووجب عليهم منه سخط».</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلنَّبِیِّـۧنَ بِغَیۡرِ ٱلۡحَقِّۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي مَعْمَر الأزْدِيِّ- قال: كانت بنو إسرائيل في اليوم تقتل ثلاثمائة نبي، ثم يُقيمون سوق بَقْلِهم في آخر النهار{70}. (١/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> الذل والمسكنة الذي نزل بهم <span class="qpc-hafs">﴿بأنهم كانوا يكفرون بآيات الله﴾</span> يعني: القرآن، <span class="qpc-hafs">﴿ويقتلون النبيين بغير الحق﴾</span>{7}<span class=comment-ref>٢٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (١/٢٣١) أنّ الآيات هنا تحتمل احتمالين: <b>الأول</b>: أن يراد بها التسع وغيرها مما يخرق العادة، وهي علامة لصدق الآتي بها. <b>الثاني</b>: أن يراد: آيات التوراة التي هي كآيات القرآن.</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلنَّبِیِّـۧنَ بِغَیۡرِ ٱلۡحَقِّۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٥<span class="dash">-</span></span> عن ابن مسعود، أنّ رسول الله ﷺ قال: «<b>أشد الناس عذابًا يوم القيامة رجل قتله نبيٌّ، أو قتل نبيًّا، وإمام ضلالة، ومُمَثِّل من المُمَثِّلِين»</b>{72}. (١/٣٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ذلك بما عصوا وكانوا يعتدون﴾</span>، قال: اجْتَنِبُوا المعصية والعدوان؛ فإنّ بهما هَلَك مَن هَلَك قبلك من الناس{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك بما عصوا وكانوا يعتدون﴾</span> في أديانهم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢/١٢.أخرجه ابن جرير ٢/١٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/١٢٣ (٦١٦).أخرجه عبد الرزاق ١/٤٧، وابن جرير ٢/١٢، وابن أبي حاتم ١/١٢٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٤-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢/١٣، وابن أبي حاتم ١/١٢٣.أخرجه ابن جرير ٢/١٣، وابن أبي حاتم ١/١٢٢. وفي آخره: قال عمرو بن حماد -وهو من رواة الأثر-: أجِموا، يعني: بَشِمُوا. وقال أبو زرعة -وهو أيضًا من رواة الأثر-: فأجِموا، أي: كرهوه.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/١٤. وفي تفسير الثعلبي ١/٢٠٥، وتفسير البغوي ١/١٠١ عنه قوله: كانوا يعجنون المن بالسلوى فيصيران واحدًا.أخرجه سعيد بن منصور (١٩١- تفسير)، وابن أبي داود في المصاحف ص٥٤. وعزاه السيوطي إلى ابن المنذر.</p><p>والقراءة شاذة. انظر: مختصر ابن خالويه ص٦، والمحتسب ١/١٧١.أخرجه ابن أبي داود ص٥٥.أخرجه الطبراني في الكبير (١٠٥٩٧). وأخرجه ابن جرير ٢/١٨، وابن أبي حاتم ١/١٢٣ كلاهما من طريق نافع بن أبي نُعَيْم، دون ذكر ابن الأزرق.الفراديس: البساتين والكروم. لسان العرب (فردس).الدِّياس: دوس الطعام ودقه ليخرج الحب منه. لسان العرب (دوس).الوابِل: المطر الشديد، الضخم القطر. لسان العرب (وبل).عزاه السيوطي إلى الطستي في مسائله. وفي المعجم الكبير للطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧): أما سمعت قول أبي ذؤيب الهذلي:</p><p>قد كنت تحسبني كأغنى وافد قدم المدينة عن زراعة فوم.أخرجه ابن جرير ٢/١٧، وابن أبي حاتم ١/١٢٣ من طريق عكرمة بلفظ: الخبز. وقال مرة: البر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ١/١٢٣.علَّقه ابن أبي حاتم ١/١٢٣.تفسير مجاهد من طريق ابن أبي نجيح ص٢٠٤، وأخرجه ابن جرير ٢/١٧. وعزاه السيوطي إلى وكيع، وعبد بن حميد.أخرجه ابن جرير ٢/١٨.أخرجه ابن جرير ٢/١٦. وعلَّقه ابن أبي حاتم ١/١٢٣. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ١/١٢٣.أخرجه سفيان الثوري ص٤٦، وابن جرير ٢/١٧. وعلَّقه ابن أبي حاتم ١/١٢٣. وعزاه السيوطي إلى وكيع، وعبد بن حميد.أخرجه عبد الرزاق ١/٤٧ من طريق مَعْمَر، وابن جرير ٢/١٦. وعلَّقه ابن أبي حاتم ١/١٢٣. وذكره يحيى بن سلام عن قتادة -كما في تفسير ابن أبي زمنين ١/١٤٥-.أخرجه ابن جرير ٢/١٧، وابن أبي حاتم ١/١٢٣.أخرجه ابن جرير ٢/١٨، وابن أبي حاتم ١/١٢٣.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/١٧.أخرجه ابن جرير ٢/٢٠.أخرجه ابن جرير ٢/٢٠، وابن أبي حاتم ١/١٢٤.تفسير الثعلبي ١/٢٠٦، وتفسير البغوي ١/١٠١.تفسير مقاتل بن سليمان ١/١١١.علقه ابن جرير ٢/٢٣.</p><p>والقراءة شاذة. انظر: البحر المحيط ١/٢٣٤، وتفسير القرطبي ١/٤٢٩.أخرجه ابن أبي داود ص٥٧، وعزاه السيوطي إلى ابن الأنباري في المصاحف. وأخرجه ابن حاتم ١/١٢٤ دون ذكر القراءة من طريق الكسائي، بزيادة: وكان يومئذ عليها.</p><p>وقراءة الأعمش (مصرَ) دون تنوين ذكرها ابن خالويه في مختصره ص٦.أخرجه ابن أبي حاتم ١/١٢٤ من طريق ابن عيينة. وعزاه السيوطي إلى سفيان بن عينية، وابن جرير.أخرجه ابن جرير ٢/٢٣، وابن أبي حاتم ١/١٢٤.أخرجه ابن جرير ٢/٢٢.تفسير البغوي ١/١٠١.أخرجه ابن جرير ٢/٢٢. وعلَّقه ابن أبي حاتم ١/١٢٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢/٢٢، وابن أبي حاتم ١/١٢٤.أخرجه ابن جرير ٢/٢٣.علَّقه ابن أبي حاتم ١/١٢٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٤٥-.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/٢٣.أخرجه ابن جرير ٢/٢٧.أخرجه ابن أبي حاتم ١/١٢٤. وقال عَقِبَه: يعني بأصحاب القبالات: أصحاب الجزية.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه عبدالرزاق ١/٤٧، وابن جرير ٢/٢٦، وابن أبي حاتم ١/١٢٥.الكُسْتِيج: خيط غليظ يشده الذِّمِّيُّ فوق ثيابه دون الزُّنّار. القاموس المحيط (كسج).الزُّنّار: هو خيط غليظ بقدر الإصبع من الإبريسم يشد على الوسط، وهو ما يلبسه النصارى والمجوس. لسان العرب (زنر)، والتعريفات ص١٥٣.تفسير البغوي ١/١٠١.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن جرير ٢/٢٧، وابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن جرير ٢/٢٨، وابن أبي حاتم ١/١٢٥.تفسير مقاتل بن سليمان ١/١١١.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١/٢٠٦.تفسير مقاتل بن سليمان ١/١١١.تفسير الثعلبي ١/٢٠٦.أخرجه ابن أبي حاتم ١/١٢٥.أخرجه ابن جرير ٢/٢٨. وعلَّقه ابن أبي حاتم ١/١٢٦.أخرجه ابن جرير ٢/٢٨، وابن أبي حاتم ١/١٢٦.تفسير مقاتل بن سليمان ١/١١١.أخرجه ابن أبي حاتم ١/١٢٦. وعزاه السيوطي إلى أبي داود، والطيالسي.تفسير مقاتل بن سليمان ١/١١١.أخرجه أحمد ٦/٤١٣ (٣٨٦٨) من طريق أبان، عن عاصم، عن أبي وائل، عن ابن مسعود به.</p><p>قال البزار في مسنده ٥/١٣٩ (١٧٢٨): «وهذا الحديث لا نعلم أحدًا أسنده عن عاصم عن أبي وائل إلا أبان». وقال الدارقطني في العلل ٥/٣٠٤ (٩٠٠): «والموقوف أصح». وقال الألباني في الصحيحة ١/٥٦٩ (٢٨١): «إسناد جيد».</p><p>وله طرق أخرى عند الطبراني في المعجم الكبير، قال المنذري في الترغيب ٣/١١٧ (٣٣٠٩) في إحداها: «رواته ثقات إلا ليث بن أبي سليم». وقال الهيثمي في المجمع ٥/٢٣٦: «وفيه ليث بن أبي سليم، وهو مدلس، وبقية رجاله ثقات». وضعّفه الألباني في الضعيفة ٣/١٦١ (١١٥٩) بليث وعبّاد بن كثير.</p><p>وقال الهيثمي في المجمع ١/١٨١ في الطريق الأخرى: «فيه الحارث الأعور، وهو ضعيف».أخرجه ابن أبي حاتم ١/١٢٦.تفسير مقاتل بن سليمان ١/١١١.