quran[5]{c,v,t}:
  10,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَاۤ أَذَقۡنَا ٱلنَّاسَ رَحۡمَةࣰ مِّنۢ بَعۡدِ ضَرَّاۤءَ مَسَّتۡهُمۡ إِذَا لَهُم مَّكۡرࣱ فِیۤ ءَایَاتِنَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإذَآ أذَقنا النّاسَ رَحْمَةً مِن بَعْدِ ضَرَّآءَ مَسَّتْهُمْ إذا لَهُم مَّكْرٌ فِي ءاياتِنا﴾</span>، قال: استهزاءٌ، وتكذيبٌ{1}. (٧/٦٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٢<span class="dash">-</span></span> عن مستور بن عباد، قال: سألتُ <span class="name-2">الحسنَ [البصريَّ]</span>: <span class="qpc-hafs">﴿وإذا أذقنا الناس رحمة من بعد ضراء مستهم﴾</span>. قال: ذاك المنافق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إذا لهم مكر في آياتنا﴾</span>، يعني: جحودًا، وتكذيبًا لديننا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: لا يقولون: هذا مِن رزق الله، إنّما يقولون: سُقِينا بنَوْءِ كذا، وهو قوله: <span class="qpc-hafs">﴿وتَجْعَلُونَ رِزْقَكُمْ أنَّكُمْ تُكَذِّبُونَ﴾</span> [الواقعة:٨٢]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا أذَقْنا النّاسَ﴾</span> يعني: آتينا الناس، يعني: كفار مكة <span class="qpc-hafs">﴿رَحْمَةً﴾</span> يعني: المطر <span class="qpc-hafs">﴿مِن بَعْدِ ضَرّاءَ﴾</span> يعني: القحط، وذهاب الثمار <span class="qpc-hafs">﴿مَسَّتْهُمْ﴾</span> يعني: المجاعة سبع سنين؛ <span class="qpc-hafs">﴿إذا لَهُمْ مَكْرٌ فِي آياتِنا﴾</span> يعني: تكذيبًا. يقول: إذا لهم قولٌ في التكذيب بالقرآن، واستِهزاء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإذا أذقنا الناس رحمة من بعد ضراء مستهم﴾</span> إلى آخر الآية، قال: هؤلاء المشركون، يَدْعُون معَ الله ما يَدْعُون، فإذا كان الضُّرُّ لم يدعوا إلا الله، فإذا نجّاهم إذا هم يشركون، <span class="qpc-hafs">﴿لئن أنجيتنا من هذه﴾</span> الشِّدَّة التي نحن فيها <span class="qpc-hafs">﴿لنكونن من الشاكرين﴾</span> لَكَ على نِعَمِك، وتخليصك إيّانا مِمّا نحنُ فيه بإخلاصنا العبادة لك، وإفراد الطاعة دون الآلهة والأنداد{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلِ ٱللَّهُ أَسۡرَعُ مَكۡرًاۚ إِنَّ رُسُلَنَا یَكۡتُبُونَ مَا تَمۡكُرُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٢٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿قل الله أسرع مكرا﴾</span>، يعني: عذابًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلِ اللَّهُ أسْرَعُ مَكْرًا﴾</span> يعني: اللهُ أشد إخْزاءً، <span class="qpc-hafs">﴿إنَّ رُسُلَنا﴾</span> مِن الحَفَظَة <span class="qpc-hafs">﴿يَكْتُبُونَ ما تَمْكُرُونَ﴾</span> يعني: ما [تعملون]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٢٩<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- قال: كلُّ مَكْرٍ في القرآنِ فهو عَمَلٌ{9}. (٧/٦٤٢)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٨٠، وأخرجه ابن جرير ١٢/١٤٥، وابن أبي حاتم ٦/١٩٣٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|2:أخرجه ابن أبي حاتم ٦/١٩٣٧.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٤٩-.|4:تفسير الثعلبي ٥/١٢٦، وتفسير البغوي ٤/١٢٧.|5:تفسير مقاتل بن سليمان ٢/٢٣٤.|6:أخرجه ابن جرير ١٢/١٤٧.|7:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٤٩-.|8:تفسير مقاتل بن سليمان ٢/٢٣٤.|9:أخرجه ابن أبي حاتم ٦/١٩٣٨.
  10,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی یُسَیِّرُكُمۡ فِی ٱلۡبَرِّ وَٱلۡبَحۡرِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- قوله: <span class="qpc-hafs">﴿في البر والبحر﴾</span>، قال: البَرُّ: بادية الأعراب. والبحر: الأمصارُ، والقُرى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُوَ الَّذِي يُسَيِّرُكُمْ فِي البَرِّ﴾</span> على ظهور الدوابِّ والإبل، ويهديكم لِمَسالِك الطُّرُق والسُّبُل، <span class="qpc-hafs">﴿و﴾</span>هُوَ يحملكم في <span class="qpc-hafs">﴿البَحْرِ﴾</span> في السُّفُنِ في الماء، ويَدُلُّكم فيه بالنجوم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی یُسَیِّرُكُمۡ فِی ٱلۡبَرِّ وَٱلۡبَحۡرِۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٢<span class="dash">-</span></span> عن ابن عمر: أنّ تميمًا الدارِيَّ سأل <span class="name-1">عمر بن الخطاب</span> عن ركوبِ البحرِ. فأمَره بتقصيرِ الصلاةِ، قال: يقول الله: <span class="qpc-hafs">﴿هُوَ الَّذِى يُسَيِرُكُمْ فِي البَرِ والبَحْرِ﴾</span>{3}. (٧/٦٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَا كُنتُمۡ فِی ٱلۡفُلۡكِ وَجَرَیۡنَ بِهِم بِرِیحࣲ طَیِّبَةࣲ وَفَرِحُوا۟ بِهَا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٣<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (حَتّى كُنتُمْ فِي الفُلْكِ وجَرَيْنَ بِكُمْ){4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَا كُنتُمۡ فِی ٱلۡفُلۡكِ وَجَرَیۡنَ بِهِم بِرِیحࣲ طَیِّبَةࣲ وَفَرِحُوا۟ بِهَا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى إذا كُنْتُمْ فِي الفُلْكِ﴾</span> يعني: في السُّفُن، <span class="qpc-hafs">﴿وجَرَيْنَ بِهِمْ﴾</span> يعني: بأهلها <span class="qpc-hafs">﴿بِرِيحٍ طَيِّبَةٍ﴾</span> يعني: غيرِ عاصِف، ولا قاصِف، ولا بطيئة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصْبَغ- في قوله: <span class="qpc-hafs">﴿حَتى إذا كُنتُمْ فِي الفُلْكِ وجَرَيْنَ بِهِم﴾</span>، قال: ذكَر هذا، ثم عدّى الحديثَ في حديثٍ آخرَ عنه لغيرِهم، قال: <span class="qpc-hafs">﴿وجَرَيْنَ بِهِم﴾</span>، قال: فعَدّى الحديثَ عنهم، فأوَّلَ شيءٍ كنتم في الفلكِ، وجرَينَ بهؤلاء، لا يَستطيعُ يقولُ: جرين بكم. وهو يُحدِّثُ قومًا آخرين، ثم ذكَر هذا ليجمعَهم وغيرَهم: <span class="qpc-hafs">﴿وجرَين بهم﴾</span> هؤلاء، وغيرِهم من الخلقِ{1}. (٧/٦٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَاۤءَتۡهَا رِیحٌ عَاصِفࣱ وَجَاۤءَهُمُ ٱلۡمَوۡجُ مِن كُلِّ مَكَانࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق عطاء- قال: الرِّياحُ ثمانٍ: أربعٌ منها عذاب، وأربعٌ منها رحمة. فأمّا العذاب منها: فالقاصِف، والعاصِف، والعَقِيم، والصَّرْصَر، قال الله تعالى: <span class="qpc-hafs">﴿ريحا صرصرا في أيام نحسات﴾</span> [فصلت:١٦] قال: مَشْؤومات. وأما رياح الرحمة: فالنّاشِرات، والمُبَشِّرات، والمُرْسَلات، والذّارِيات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جاءَتْها﴾</span> يعني: السفينة <span class="qpc-hafs">﴿رِيحٌ عاصِفٌ﴾</span> قاصِف، يعني: غير ليِّن، يعني: ريحًا شديدة، <span class="qpc-hafs">﴿وجاءَهُمُ المَوْجُ مِن كُلِّ مَكانٍ﴾</span> يعني: مِن بين أيديهم، ومِن خلفهم، ومِن فوقهم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَظَنُّوۤا۟ أَنَّهُمۡ أُحِیطَ بِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وظَنُّواْ﴾</span> يعني: وأَيْقَنوا <span class="qpc-hafs">﴿أنَّهُمْ أُحِيطَ بِهِمْ﴾</span> يعني: أنّهم مُهْلَكون، يعني: مُغْرَقون{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿دَعَوُا۟ ٱللَّهَ مُخۡلِصِینَ لَهُ ٱلدِّینَ لَىِٕنۡ أَنجَیۡتَنَا مِنۡ هَـٰذِهِۦ لَنَكُونَنَّ مِنَ ٱلشَّـٰكِرِینَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي خالد، عن ابن عجلان، عن عباس بن عبد الله بن معبد، عن عكرمة- قال: الإخلاص هكذا. وأشار أبو خالد بإصبعه السَّبّابة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطِيَّة- قال: إذا ضَلَّ الرجلُ الطريقَ دعا اللهَ مخلصًا: لئن أنجيتنا من هذه لَنَكُونَنَّ مِن الشاكرين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿مخلصين له الدين﴾</span>، قال: إذا قلتَ: لا إله إلا الله. فقُل على إثْرِها: الحمد لله رب العالمين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿دعوا الله مخلصين له الدين﴾</span>، قال: إذا مسَّهُم الضُّرُّ في البحر أخلصوا لله الدعاءَ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿دَعَوُا اللَّهَ مُخْلِصِينَ لَهُ الدِّينَ﴾</span> وضلَّتْ عنهم آلهتُهم التي يدعون من دون الله، فذلك قوله: <span class="qpc-hafs">﴿وإذا مَسَّكُمُ الضُّرُّ فِي البَحْرِ ضَلَّ مَن تَدْعُونَ إلّا إيّاهُ﴾</span> [الإسراء:٦٧]. <span class="qpc-hafs">﴿لَئِنْ أنْجَيْتَنا مِن هذِهِ﴾</span> المَرَّة <span class="qpc-hafs">﴿لَنَكُونَنَّ مِنَ الشّاكِرِينَ﴾</span> لا ندعو معك غيرَك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإذا أذقنا الناس رحمة من بعد ضراء مستهم﴾</span> إلى آخر الآية، قال: هؤلاء المشركون يدعون مع الله ما يدعون، فإذا كان الضُّرُّ لم يَدْعوا إلا الله، فإذا نجاهم إذا هم يشركون، <span class="qpc-hafs">﴿لئن أنجيتنا من هذه﴾</span> الشِّدَّة التي نحن فيها <span class="qpc-hafs">﴿لنكونن من الشاكرين﴾</span> لَكَ على نِعَمِك، وتخليصك إيّانا مِمّا نحنُ فيه بإخلاصنا العبادة لك، وإفراد الطاعة دون الآلهة والأنداد{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿دَعَوُا۟ ٱللَّهَ مُخۡلِصِینَ لَهُ ٱلدِّینَ لَىِٕنۡ أَنجَیۡتَنَا مِنۡ هَـٰذِهِۦ لَنَكُونَنَّ مِنَ ٱلشَّـٰكِرِینَ ۝٢٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٤٥<span class="dash">-</span></span> عن سعد بن أبي وقّاصٍ، قال: لَمّا كان يومُ فتحِ مكةَ أمَّن رسولُ الله ﷺ الناسَ، إلا أربعةَ نفرٍ وامرأتين، وقال: «<b>اقتُلوهم وإن وجَدتموهم مُتَعَلِّقين بأستارِ الكعبةِ؛ عكرمة بن أبي جهل، وعبد الله بن خَطَلٍ، ومِقْيَسُ بن ضُبابَةَ، وعبد الله بن سعد بن أبي سَرْحٍ</b>»، فأما عبد الله بن خَطَلٍ فأُدرِكَ وهو مُتَعلِّقٌ بأستارِ الكعبةِ، فاستبَق إليه سعيد بن حُرَيثٍ وعمّارٌ، فسبَق سعيدٌ عمّارًا، وكان أشبَّ الرجلين، فقتَله، وأما مِقْيَسُ بن ضُبابَة فأدرَكه الناسُ في السوقِ فقتَلوه، وأما عكرمةُ فركِب البحرَ فأصابَتْهم عاصفٌ، فقال أصحابُ السفينةِ لأهلِ السفينةِ: أخلِصوا؛ فإنّ آلهتَكم لا تُغْنِي عنكم شيئًا. فقال عكرمة: لئن لم يُنَجَّني في البحرِ إلا الإخلاصُ ما يُنَجِّني في البرِّ غيرُه، اللَّهُمَّ، إنّ لك عهدًا إن أنت عافَيْتَني مِمّا أنا فيه أن آتيَ محمدًا حتى أضعَ يدِي في يدِه، فلأجدَنَّه عَفُوًّا كريمًا. قال: فجاء، فأسلَم. وأما عبدُ الله بن سعد بن أبي سَرْحٍ فإنّه اختَبَأ عند عثمان، فلمّا دعا رسولُ الله ﷺ للبَيْعَةِ جاء به، حتى أوقَفَه على النبيِّ ﷺ، فقال: يا رسولَ الله، بايِعْ عبدَ الله. قال: فرفَع رأسَه، فنظَر إليه ثلاثًا، كلُّ ذلك يأبى، فبايَعَه بعد الثلاثِ، ثم أقبَل على أصحابه، فقال: «<b>أما كان فيكم رجلٌ رشيدٌ يقومُ إلى هذا حيثُ رآني كفَفْتُ يدي عن بيعتِه فيقتُلَه؟</b>». قالوا: وما يُدرينا -يا رسول الله- ما في نفسك؟ ألا أومَأتَ إلينا بعينِك. قال: «<b>إنّه لا ينبغي لنبيٍّ أن تكون له خائنةُ أعْيُن</b>»{16}. (٧/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٦<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span> -من طريق أبي الأسود- قال: فَرَّ عِكرمةُ بن أبي جهل يومَ الفتحِ، فرَكِب البحرَ، فأخَذته الريحُ، فنادى باللّاتِ والعُزّى، فقال أصحابُ السفينةِ: لا يَجوزُ ههنا أحدٌ يدعو شيئًا إلا اللهَ وحدَه مُخلَصًا. فقال عكرمة: واللهِ، لئَنِ كان في البحرِ وحدَه؛ إنّه لَفِي البرُ وحدَه. فرجَع، فأسلَم{17}. (٧/٦٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٧<span class="dash">-</span></span> عن <span class="name-2">ابن أبي مُليكةَ</span>، قال: لَمّا كان يومُ الفتحِ ركِب عكرمةُ بن أبي جهل البحرَ هارِبًا، فخَبَّ{18} بهم البحرُ، فجعَلت الصَّرارِيُّ -أي: الملّاحُ- يدعون الله، ويُوَحِّدونه، فقال: ما هذا؟ قالوا: هذا مكانٌ لا يَنفعُ فيه إلا الله. قال: فهذا إلهُ محمد الذي يدعونا إليه، فارجِعوا بنا. فرجَع، فأسلَمَ{19}. (٧/٦٤٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٣٨.|2:تفسير مقاتل بن سليمان ٢/٢٣٤-٢٣٥.|3:أخرجه البيهقي في سننه ٣/١٥٤.|4:أخرجه ابن أبي داود في المصاحف ١/٣١٨.</p><p>وهذه قراءة شاذة.|5:تفسير مقاتل بن سليمان ٢/٢٣٤.|6:أخرجه ابن أبي حاتم ٦/١٩٣٨.|7:أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -ضمن موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.|8:تفسير مقاتل بن سليمان ٢/٢٣٤.|9:تفسير مقاتل بن سليمان ٢/٢٣٤.|10:أخرجه ابن أبي حاتم ٦/١٩٣٩.|11:أخرجه ابن أبي حاتم ٦/١٩٣٩.|12:أخرجه ابن أبي حاتم ٦/١٩٣٩.|13:أخرجه ابن جرير ١٢/١٤٦-١٤٧، وابن أبي حاتم ٦/١٩٣٩.|14:تفسير مقاتل بن سليمان ٢/٢٣٤-٢٣٥.|15:أخرجه ابن جرير ١٢/١٤٧.|16:أخرجه أبو داود ٤/٣١٨-٣١٩ (٢٦٨٣) مختصرًا، والنسائي ٧/١٠٥ (٤٠٦٧)، والحاكم ٣/٤٧.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن حجر في التلخيص الحبير ٣/١٣٠: «إسناده صالح». وقال ابن الملقّن ٩/١٥٣: «الحديث صحيح». وقال الألباني في الصحيحة ٤/٣٠٠ (١٧٢٣): «صحيح».|17:أخرجه البيهقي في الدلائل ٥/٤٩-٥٠.|18:خَبَّ البحر: اضطرب. النهاية (خبب).|19:عزاه السيوطي إلى ابن سعد.
  10,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّاۤ أَنجَىٰهُمۡ إِذَا هُمۡ یَبۡغُونَ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿يبغون﴾</span>، قال: يلعبون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا أنْجاهُمْ إذا هُمْ يَبْغُونَ فِي الأَرْضِ﴾</span> يعني: يعبدون مع الله غيره <span class="qpc-hafs">﴿بِغَيْرِ الحَقِّ﴾</span> إذ عبدوا مع الله غيره{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّاسُ إِنَّمَا بَغۡیُكُمۡ عَلَىٰۤ أَنفُسِكُمۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- <span class="qpc-hafs">﴿يا أيُّها النّاسُ﴾</span>، أي: الفريقين جميعًا؛ الكفار، والمنافقين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها النّاسُ إنَّما بَغْيُكُمْ عَلى أنْفُسِكُمْ﴾</span> ضررُه في الآخرة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّتَـٰعَ ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿متاع الحياة الدنيا﴾</span>، قال: هي متاع متروكة، أوشكت -واللهِ- الذي لا إله إلا هو أن تَضْمَحِلَّ عن أهلها، فخُذوا مِن هذا المتاعِ طاعةَ الله إن اسْتَطَعْتُم، ولا قوة إلا بالله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٥٣<span class="dash">-</span></span> عن <span class="name-2">سليمان الأعمش</span> -من طريق سفيان الثوري- <span class="qpc-hafs">﴿متاع الحياة الدنيا﴾</span>، قال: مثل زاد الراعي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَتاعَ الحَياةِ الدُّنْيا﴾</span>، تَمَتَّعون فيها قليلًا إلى منتهى آجالكم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ إِلَیۡنَا مَرۡجِعُكُمۡ فَنُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ إلَيْنا مَرْجِعُكُمْ﴾</span> في الآخرة، <span class="qpc-hafs">﴿فنُنَبِّئُكُمْ بِما كُنْتُمْ تَعْمَلُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ إِلَیۡنَا مَرۡجِعُكُمۡ فَنُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٥٦<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>ثلاثٌ هُنَّ رواجِعُ على أهلِها: المكرُ، والنَّكْثُ، والبَغْيُ</b>». ثم تلا رسولُ الله ﷺ: <span class="qpc-hafs">﴿يا أيُها النّاسُ إنّما بَغيُكُم عَلى أنفُسِكُم﴾</span>، <span class="qpc-hafs">﴿ولا يَحيِقُ المَكْرُ السَّيءُ إلا بِأَهلِهِ﴾</span> [فاطر:٤٣]، <span class="qpc-hafs">﴿فَمَن نَكَثَ فَإنَّما يَنكُثُ عَلى نَفسِهِ﴾</span> [الفتح:١٠]{9}. (٧/٦٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٥٧<span class="dash">-</span></span> عن عبد الله بن نُفَيْلٍ الكِنانِيِّ، قال: قال رسولُ الله ﷺ: «<b>ثلاثٌ قد فرَغ اللهُ مِن القضاءِ فيهِنَّ: لا يَبْغِيَنَّ أحدُكم؛ فإنّ الله تعالى يقول: <span class="qpc-hafs">﴿يا أيُّها النّاسُ إنَّما بَغْيُكُم عَلى أنفُسِكُم﴾</span>، ولا يمكُرَنَّ أحدٌ؛ فإنّ الله يقول: <span class="qpc-hafs">﴿ولا يَحِيقُ المَكْرُ السَّئُ إلا بِأَهْلِهِ﴾</span> [فاطر:٤٣]، ولا يَنكُثَنَّ أحدٌ؛ فإنّ الله يقول: <span class="qpc-hafs">﴿فَمَن نَكَثَ فَإنَّما يَنكُثُ عَلى نَفْسِهِ﴾</span> [الفتح:١٠]</b>»{10}. (٧/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٥٨<span class="dash">-</span></span> عن أبي بَكْرَةَ، قال: قال رسولُ الله ﷺ: «<b>لا تَبْغِ، ولا تكن باغِيًا؛ فإنّ الله يقول: <span class="qpc-hafs">﴿إنَّما بَغيُكُمْ عَلى أنفُسِكُم﴾</span></b>»{11}. (٧/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٥٩<span class="dash">-</span></span> عن الزهريِّ، قال: بلَغَنا: أنّ رسول الله ﷺ قال: «<b>لا تَبْغِ، ولا تُعِن باغيًا؛ فإنّ الله يقول: <span class="qpc-hafs">﴿إنَّما بَغيُكُمْ عَلى أنفُسِكُم﴾</span></b>»{12}. (٧/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦٠<span class="dash">-</span></span> عن زيد بن أسلم، قال: قال رسول الله ﷺ: «<b>لا يُؤَخِّرُ اللهُ عقوبةَ البَغْيِ؛ فإنّ الله قال: <span class="qpc-hafs">﴿إنَّما بَغيُكُمْ عَلى أنفُسِكُم﴾</span></b>»{13}. (٧/٦٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦١<span class="dash">-</span></span> عن أبي بَكْرَة، قال: قال رسول الله ﷺ: «<b>ما مِن ذنبٍ أجدرَ أن يُعَجِّلَ اللهُ لصاحبِه العقوبةَ من البَغْيِ، وقطيعةِ الرحمِ</b>»{14}. (٧/٦٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦٢<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span>، قال: ثلاثٌ مَن كُنَّ فيه كُنَّ عليه: المَكرُ، والبَغْيُ، والنَّكْثُ، قال الله: <span class="qpc-hafs">﴿إنَّما بَغيُكُمْ عَلى أنفُسِكُم﴾</span>{15}. (٧/٦٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦٣<span class="dash">-</span></span> عن رجاءِ بن حيْوةَ، أنّه سمِع قاصًّا في مسجد مِنى يقول: ثلاثُ خلالٍ هُنَّ على مَن عمِل بِهِنَّ: البَغْيُ، والمَكْرُ، والنَّكْثُ، قال الله: <span class="qpc-hafs">﴿إنَّما بَغيُكُمْ عَلى أنفُسِكُم﴾</span>، <span class="qpc-hafs">﴿ولا يَحِيقُ المَكْرُ السَّئُ إلا بِأَهْلِهِ﴾</span> [فاطر:٤٣]، <span class="qpc-hafs">﴿فَمَن نَكَثَ فَإنَّما يَنكُثُ عَلى نَفْسِهِ﴾</span> [الفتح:١٠]. ثم قال: ثلاثُ خلالٍ لا يُعَذِّبُكم اللهُ ما عمِلتم بِهِنَّ: الشكرُ، والدعاءُ، والاستغفار. ثم قرأ: <span class="qpc-hafs">﴿مّا يَفْعَلُ الله بِعَذابِكُمْ إن شَكَرْتُمْ وءامَنتُم﴾</span> [النساء:١٤٧]، <span class="qpc-hafs">﴿وما كان الله مُعَذِبَهُمْ وهُمْ يَسْتَغْفِرُونَ﴾</span> [الأنفال:٣٣]{16}. (٧/٦٤٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٣٩.|2:تفسير مقاتل بن سليمان ٢/٢٣٥.|3:أخرجه ابن أبي حاتم ٦/١٩٣٩.|4:تفسير مقاتل بن سليمان ٢/٢٣٥.|5:أخرجه ابن أبي حاتم ٦/١٩٤٠.|6:أخرجه ابن أبي حاتم ٦/١٩٤٠.|7:تفسير مقاتل بن سليمان ٢/٢٣٥.|8:تفسير مقاتل بن سليمان ٢/٢٣٥.|9:أخرجه أبو نعيم في تاريخ أصبهان ٢/٣١، والخطيب في تاريخه ٩/٤٥٩ (٢٩٠٤)، من طريق مروان بن صبيح، حدثنا عبد العزيز بن صهيب، عن أنس به.</p><p>قال الذهبي في ميزان الاعتدال ٤/٩١ (٨٤٢٩) ترجمة مروان بن صبيح: «لا أعرفه، وله خبر منكر». ثم ذكر الحديث، وقال الألباني في الضعيفة ٤/٤٢٠: «ضعيف».|10:أخرجه الطبراني في مسند الشاميين ٢/٢٩٥ (١٣٧٤)، وابن مردويه -كما في الإصابة ٤/٢١٥-.</p><p>قال ابن حجر: «ورجاله ثقات، إلا أنه منقطع بين سليمان والصحابي».|11:أخرجه الحاكم ٢/٣٦٩ (٣٢٩٨).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».|12:أخرجه ابن أبي حاتم ٦/١٩٤٠ (١٠٣٠٦).|13:أخرجه ابن أبي حاتم ٦/١٩٤٠ (١٠٣٠٥).|14:أخرجه أحمد ٣٤/٨-٩ (٢٠٣٧٤)، وأبو داود ٧/٢٦٣ (٤٩٠٢)، والترمذي ٤/٤٨٥-٤٨٦ (٢٦٧٩)، وابن ماجه ٥/٢٩٦ (٤٢١١)، وابن حبان ٢/٢٠٠ (٤٥٥)، والحاكم ٢/٣٨٨ (٣٣٥٩).</p><p>قال الترمذي: «هذا حديث صحيح». وقال الحاكم: «صحيح الإسناد، ولم يخرجاه». وأورده الألباني في الصحيحة ٢/٥٨٨ (٩١٨).|15:عزاه السيوطي إلى أبي الشيخ.|16:أخرجه البيهقي (٦٦٧٤). وعزاه السيوطي إلى ابن المنذر.
  10,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّمَا مَثَلُ ٱلۡحَیَوٰةِ ٱلدُّنۡیَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عَطِيَّة العَوْفِي- قال: ضرب الله مثلًا حَسَنًا، وكلُّ أمثالِه حَسَنٌ، وهو مَثَلٌ خَصَّ به اللهُ المؤمنَ والكافرَ فيما أُوتِيا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَمَاۤءٍ أَنزَلۡنَـٰهُ مِنَ ٱلسَّمَاۤءِ فَٱخۡتَلَطَ بِهِۦ نَبَاتُ ٱلۡأَرۡضِ مِمَّا یَأۡكُلُ ٱلنَّاسُ وَٱلۡأَنۡعَـٰمُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿فاخْتَلَطَ بِهِ نَباتُ الأَرْضِ﴾</span>، قال: اختلَط، فنبَت بالماءِ كلُّ لونٍ مِمّا يأكلُ الناسُ؛ كالحِنطةِ، والشَّعيرِ، وسائرِ حبوبِ الأرضِ، والبُقولِ، والثمارِ، وما تأكلُه الأنعامُ والبهائمُ مِن الحشيشِ، والمراعي{2}. (٧/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- قال: أمّا اختلط به نبات الأرض: فاختلط، فنبت بالماء مِن كلِّ لَوْنٍ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّما مَثَلُ الحَياةِ الدُّنْيا كَماءٍ أنْزَلْناهُ مِنَ السَّماءِ فاخْتَلَطَ بِهِ نَباتُ الأَرْضِ مِمّا يَأْكُلُ النّاسُ والأَنْعامُ﴾</span>، يقول: مَثَلُ الدُّنْيا كمَثَلِ النَّبْتِ، بينا هو أخضرُ إذا هو قد يَبِس، فكذلك الدنيا إذا جاءت الآخرة. يقول: أنزل الماءَ مِن السماء، فأنبت به ألوانَ الثِّمار لبني آدم، وألوان النبات للبهائم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَاۤ أَخَذَتِ ٱلۡأَرۡضُ زُخۡرُفَهَا وَٱزَّیَّنَتۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وازَّيَنَتْ﴾</span>، قال: أنبتَت، وحسُنَتْ{5}. (٧/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى إذا أخَذَتِ الأَرْضُ زُخْرُفَها﴾</span> يعني: حُسْنَها، وزينتها، <span class="qpc-hafs">﴿وازَّيَّنَتْ﴾</span> بالنبات، وحَسُنَتْ{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَظَنَّ أَهۡلُهَاۤ أَنَّهُمۡ قَـٰدِرُونَ عَلَیۡهَاۤ أَتَىٰهَاۤ أَمۡرُنَا لَیۡلًا أَوۡ نَهَارࣰا فَجَعَلۡنَـٰهَا حَصِیدࣰا كَأَن لَّمۡ تَغۡنَ بِٱلۡأَمۡسِۚ كَذَ ٰ⁠لِكَ نُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَتَفَكَّرُونَ ۝٢٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٧٠<span class="dash">-</span></span> عن <span class="name-1">أبي بن كعب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٧١<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٧٢<span class="dash">-</span></span> و<span class="name-2">مروان بن الحكم</span> -من طريق عبد الرحمن بن أبي بكر بن الحارث بن هشام- أنّهم كانوا يقرءون: (وازَّيَّنَتْ وظَنَّ أهْلُهَآ أنَّهُمْ قادِرُونَ عَلَيْها وما كانَ اللهُ لِيُهْلِكَهُمْ إلّا بِذُنُوبِ أهْلِها){7}<span class=comment-ref>٣١٠٨</span>. (٧/٦٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٣١٠٨</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ كثير</u> (٧/٣٥٢) هذه القراءة بقوله: «وهذه قراءة غريبة». ثم <span class="comment-type-1">وجَّهها</span> بقوله: «وكأنّها زيادة للتفسير».</div></p><p><div></p><p><p><span class="item-no">٣٤٣٧٣<span class="dash">-</span></span> عن أبي سلمة بن عبد الرحمن، قال: في قراءة <span class="name-1">أُبَيٍّ</span>: (كَأَن لَّمْ تَغْنَ بِالأَمسِ ومَآ أهْلَكْناهَآ إلّا بِذُنُوبِ أهْلِها كَذَلِكَ نُفَصِّلُ الآياتِ لِقَوْمٍ يَتَفَكَّرُونَ){8}. (٧/٦٤٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَظَنَّ أَهۡلُهَاۤ أَنَّهُمۡ قَـٰدِرُونَ عَلَیۡهَاۤ أَتَىٰهَاۤ أَمۡرُنَا لَیۡلًا أَوۡ نَهَارࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وظن أهلها أنهم قادرون عليها أتاها أمرنا ليلا أو نهارا﴾</span>: إي، واللهِ، لَئِن تَشَبَّث بالدُّنْيا، وحَدِبَ عليها؛ لَتُوشِكَنَّ الدنيا أن تلْفِظَه، وتَقْضِي منه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وظَنَّ أهْلُها﴾</span> يعني: وأَيْقَنَ أهلها <span class="qpc-hafs">﴿أنَّهُمْ قادِرُونَ عَلَيْها﴾</span> في أنفسهم؛ <span class="qpc-hafs">﴿أتاها أمْرُنا﴾</span> يعني: عذابنا <span class="qpc-hafs">﴿لَيْلًا أوْ نَهارًا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهَا حَصِیدࣰا كَأَن لَّمۡ تَغۡنَ بِٱلۡأَمۡسِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَأَن لَّمْ تَغْنَ بِالأَمْسِ﴾</span>، قال: كأن لم تَعِشْ، كأن لم تنعَمْ{5}. (٧/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٧٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿كأن لم تغن بالأمس﴾</span> بزينتها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَجَعَلْناها حَصِيدًا﴾</span> يعني: ذاهِبًا، <span class="qpc-hafs">﴿كَأَنْ لَمْ تَغْنَ بِالأَمْسِ﴾</span> يعني: تَنْعَم بالأمس{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَتَفَكَّرُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- <span class="qpc-hafs">﴿لقوم يتفكرون﴾</span>، قال: هذا مَثَلٌ خَصَّ به اللهُ، فاعقِلوا عن الله أمثاله؛ فإنّ الله يقول: <span class="qpc-hafs">﴿وتلك الأمثال نضربها للناس وما يعقلها إلا العالمون﴾</span> [العنكبوت:٤٣]{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا تجيء الآخرةُ، فتذهبُ الدنيا ونعيمُها، وتنقطعُ عن أهلها <span class="qpc-hafs">﴿نُفَصِّلُ الآياتِ﴾</span> يعني: نُبَيِّن العلاماتِ <span class="qpc-hafs">﴿لِقَوْمٍ يَتَفَكَّرُونَ﴾</span> في عجائب الله، وربوبيته{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَتَفَكَّرُونَ ۝٢٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٨١<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلَزٍ لاحق بن حميد</span>، قال: مكتوبٌ في سورة يونس ﵇ إلى جنبِ هذه الآيةِ: <span class="qpc-hafs">﴿حَتّى إذا أخَذَتِ الأَرْضُ زُخْرُفَها﴾</span> إلى <span class="qpc-hafs">﴿يَتَفَكَّرُونَ﴾</span>: ولو أنّ لابنِ آدم وادِيَين مِن مالٍ لَتَمَنّى وادِيًا ثالثًا، ولا يُشبِعُ نفسَ ابنِ آدمَ إلا الترابُ، ويتوبُ الله على مَن تاب. فمُحِيَتْ{16}. (٧/٦٤٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٤٠.|2:أخرجه ابن جرير ١٢/١٥٠. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن أبي حاتم ٦/١٩٤١.|4:تفسير مقاتل بن سليمان ٢/٢٣٥.|5:أخرجه عبد الرزاق ١/٢٩٣، وابن جرير ١٢/١٥٢، وابن أبي حاتم ٦/١٩٤١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٣٥.|7:أخرجه ابن جرير ١٢/١٥٢.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٥/١٤٦.|8:أخرجه ابن جرير ١٢/١٥٢. وعزاه السيوطي إلى المنذر.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٥/١٤٦.|9:أخرجه ابن جرير ١٢/١٥١، وابن أبي حاتم ٦/١٩٤١.|10:تفسير مقاتل بن سليمان ٢/٢٣٥.|11:أخرجه عبد الرزاق ١/٢٩٣، وابن جرير ١٢/١٥٢، وابن أبي حاتم ٦/١٩٤١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|12:أخرجه ابن أبي حاتم ٦/١٩٤٢.|13:تفسير مقاتل بن سليمان ٢/٢٣٥.|14:أخرجه ابن أبي حاتم ٦/١٩٤٢.|15:تفسير مقاتل بن سليمان ٢/٢٣٥.|16:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.
  10,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ یَدۡعُوۤا۟ إِلَىٰ دَارِ ٱلسَّلَـٰمِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٨٢<span class="dash">-</span></span> عن أبي الدرداء، قال: قال رسول الله ﷺ: «<b>ما مِن يومٍ طَلَعت شمسُه إلا وُكِّل بجَنبَتَيها مَلَكانِ يُنادِيان نِداءً يسمَعُه خلقُ اللهِ كلُّهم إلّا الثَّقَلَيْن: يا أيُّها الناسُ، هلُمُّوا إلى ربِّكم، إنّ ما قلَّ وكَفى خيرٌ مِمّا كثُر وأَلْهى. ولا آبَت شمسُه إلا وُكَّل بجَنبَتَيها مَلَكان يُنادِيان نِداءً يسمَعُه خلقُ الله كلُّهم غيرُ الثَّقَلَيْن: اللَّهُمَّ، أعطِ مُنفِقًا خَلَفًا، وأَعْطِ مُمْسِكًا تَلَفًا. فأنزَل اللهُ في ذلك كلِّه قرآنًا؛ في قول المَلَكَين: يا أيُّها الناسُ، هلُمُّوا إلى ربِّكم: <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ ويَهدِي مَن يَشاءُ إلى صِراطٍ مُستَقِيمٍ﴾</span>. وأنزل في قولهما: اللَّهُمَّ، أعطِ مُنِفقًا خَلَفًا، وأَعْطِ مُمْسِكًا تلَفًا: <span class="qpc-hafs">﴿والَّيلِ إذا يَغشى * والنَّهاِر إذا تَجَلّى﴾</span> إلى قوله: <span class="qpc-hafs">﴿لِلْعُسْرى﴾</span></b>» [الليل:١-١٠]{1}. (٧/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٣<span class="dash">-</span></span> عن سعيد بن أبي هلال: سمِعتُ أبا جعفرٍ محمد بن علي، وتلا هذه الآية: <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ ويَهدِي مَن يَشاءُ إلى صِراطٍ مُستَقِيمٍ﴾</span>، فقال: حدَّثني جابر، قال: خرَج علينا رسولُ الله ﷺ يومًا، فقال: «<b>إنِّي رأيتُ في المنامِ كأنّ جبريلَ عندَ رأسي، وميكائيلَ عندَ رِجْلي، يقول أحدُهما لصاحبِه: اضرِبْ له مثلًا. فقال: اسمَعْ سمِعَتْ أُذُنُك، واعقِلْ عقَلَ قلبُك، إنّما مثَلُك ومثَلُ أُمَّتِك كمَثَلِ مَلِكٍ اتَّخَذ دارًا، ثم بنى فيها بيتًا، ثم جعَل فيها مأدُبَةً، ثم بعَث رسولًا يدعو الناسَ إلى طعامِه، فمنهم مَن أجاب الرسول، ومنهم مَن ترَك، فالله هو الملِكُ، والدارُ الإسلامُ، والبيتُ الجنةُ، وأنت -يا محمد- رسولٌ، فمَن أجابك دخَل الإسلام، ومَن دخَل الإسلام دخَل الجنةَ، ومَن دخَل الجنةَ أكَل منها</b>»{2}. (٧/٦٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٤<span class="dash">-</span></span> عن أبي قِلابة، عن النبي ﷺ، قال: «<b>قيل لي: لِتَنَمْ عينُك، ولِيَعْقِلْ قلبُك، ولِتَسْمَعْ أذنُك. فنامَتْ عيني، وعقل قلبي، وسَمِعَتْ أذُني. ثم قيل: سَيِّدٌ بَنى دارًا، ثُمَّ صَنَعَ مَأْدُبَةً، ثُمَّ أرسل داعِيًا، فمَن أجاب الداعي دخل الدار، وأكل مِن المأدُبة، ورضي عنه السيد، ومَن لم يُجِبِ الداعيَ لم يدخل الدارَ، ولم يأكل مِن المَأْدُبَة، ولم يرضَ عنه السَّيِّدُ، فاللهُ السَّيِّد، والدار الإسلام، والمأدُبة الجنة، والداعي محمد ﷺ</b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٥<span class="dash">-</span></span> عن ابن مسعود، قال: استَقْبَلني النبيُّ ﷺ، فانطلَقْنا حتى أتينا موضِعًا لا نَدْري ما هو، فوضَع رسولُ الله ﷺ رأسَه في حِجْري، ثم إنّ هَنِينًا{4} أتَوا، عليهم ثيابٌ بِيضٌ طوالٌ وقد أغْفى رسولُ الله ﷺ. فقال عبد الله: فأُرْعِبْتُ منهم. فقالوا: لقد أُعطِيَ هذا العبدُ خيرًا، إنّ عينَه نائمةٌ والقلبُ يقظانُ. ثم قال بعضُهم لبعضٍ: هَلُمَّ، فلْنَضْرِبْ له مثلًا. قال بعضُهم لبعضٍ: اضْرِبوا له ونتَأوَّلُ نحن، أو نضرِبُ نحن وتتأوَّلون أنتم. فقال بعضُهم: مثَلُه كمثَلِ سَيِّدٍ اتَّخَذ مَأدُبةً، ثم ابْتَنى بُنْيانًا حَصينًا، ثم أرْسَل إلى الناس، فمَن لم يأتِ طعامَه عذَّبه عذابًا شديدًا. قال الآخرون: أمّا السيِّدُ فهو ربُّ العالمين، وأما البُنيانُ فهو الإسلام، والطعام الجنةُ، وهذا الداعِي، فمَن اتَّبعه كان في الجنةِ، ومن لم يتَّبِعْه عُذِّب عذابًا أليمًا. ثم إن رسول الله ﷺ استيقَظ فقال: «<b>ما رأيتَ، يا ابنَ أمِّ عبد؟</b>». فقلت: رأيتُ كذا وكذا. فقال: «<b>أفَخَفِيَ عَلَيَّ مِمّا قالوا شيءٌ ؟!</b>». وقال رسول الله ﷺ: «<b>هم نَفَرٌ من الملائكة</b>»{5}. (٧/٦٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٦<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>إنّ سَيِّدًا بنى دارًا، واتَّخذ مَأْدُبَةً، وبعَث داعيًا، فمَن أجاب الداعيَ دخَل الدارَ، وأكَل مِن المأْدبةِ، ورَضِي عنه السيد، ألا وإنّ السَّيِّدَ الله، والدارَ الإسلام، والمأْدُبةَ الجنةُ، والداعيَ محمد ﷺ</b>»{6}. (٧/٦٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ﴾</span>، قال: يدعُو إلى عملِ الجنةِ، واللهُ السلامُ، والجنةُ دارُه{7}. (٧/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي الشعثاء جابر بن زيد</span> -من طريق أبي المنيب- في قوله: <span class="qpc-hafs">﴿دار السلام﴾</span>، قال: هو السلام، وهو اسم مِن أسمائه ﷿{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ﴾</span>، قال: السلامُ هو الله، ودارُه الجنةُ{9}. (٧/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> أنّه قال: السلام هو الله -تبارك وتعالى-{10}<span class=comment-ref>٣١٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١٠٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٤٧٢) على هذا القول بقوله: «فالمعنى: يدعو إلى داره التي هي الجنة. وإضافتُها إليه إضافةُ مِلْكٍ إلى مالِك». ثم ساق <b>قولًا</b> آخر، فقال: «وقيل: السلام: بمعنى السلامة، أي: مَن دخلها ظَفِر بالسلامة، وأمِن الفناء والآفات».</div></p><p><div></p><p><p><span class="item-no">٣٤٣٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّهُ يَدْعُوا إلى دارِ السَّلامِ﴾</span>، يعني: دار نفسِه، وهي الجنة، والله هو السلام{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَهۡدِی مَن یَشَاۤءُ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٩٢<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- في قوله: <span class="qpc-hafs">﴿ويَهدٍي مَن يَشَآءُ﴾</span>، قال: يَهديهم للمَخْرَجِ مِن الشُّبُهاتِ، والفِتَنِ، والضَّلالاتِ{8}. (٧/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَهْدِي مَن يَشاءُ﴾</span> يعني: مِن أهل التوحيد <span class="qpc-hafs">﴿إلى صِراطٍ مُسْتَقِيمٍ﴾</span> يعني: دين الإسلام{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَهۡدِی مَن یَشَاۤءُ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٢٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمّار بن عمير- قال: ما مِن ليلةٍ إلا يُنادِي مُنادٍ: يا صاحبَ الخيرِ، هَلُمَّ، ويا صاحب الشرِّ، أقْصِرْ{14}. فقال رجل للحسن: أتجِدُها في كتابِ الله؟ قال: نعم، <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ﴾</span>{8}. (٧/٦٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أنّه كان إذا قرأ: <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ﴾</span> قال: لَبَّيْك -ربَّنا- وسعْدَيك{16}. (٧/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والله يَدعُوا إلى دارِ السَّلامِ﴾</span>، قال: ذُكر لنا: أنّ في التوراة مكتوبًا: يا باغيَ الخيرِ، هَلُمَّ، ويا باغي الشرِّ، انتَهِ{17}. (٧/٦٥٢)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٣٦/٥٢-٥٣ (٢١٧٢١)، والحاكم ٢/٤٨٢ (٣٦٦٢)، والبيهقي في الشعب ٥/٩٠-٩١ (٣١٣٩) واللفظ له، وابن جرير ١٢/١٥٤-١٥٥، وابن أبي حاتم ٦/١٩٤٢-١٩٤٣ (١٠٣٢٦).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».|2:أخرجه الحاكم ٢/٣٦٩ (٣٢٩٩). وأخرجه ابن جرير ١٢/١٥٥ دون ذكر أبي جعفر محمد بن علي.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وأورده الألباني في الصحيحة ٧/١٥٧٦ (٣٥٩٥).|3:أخرجه عبد الرزاق ٢/١٧٤ (١١٥٤)، وابن جرير ١٢/١٥٤.</p><p>قال ابن كثير في تفسيره ٤/٢٦١: «وهذا حديث مرسل».|4:هنين: جمع هن، كأنه أراد الكناية عن أشخاصهم. النهاية (هنن).|5:أخرجه أحمد ٦/٣٣٢-٣٣٤ (٣٧٨٨) بنحوه مطولًا.</p><p>قال الهيثمي في المجمع ٨/٢٦١ (١٣٩٥٩): «ورجاله رجال الصحيح، غير عمرو البكالي، وذكره العجلي في ثقات التابعين، وابن حبان وغيره في الصحابة».|6:أخرجه أبو نعيم في كتاب صفة الجنة ١/٣٢ (٢)، من طريق عبد الصمد بن محمد بن إبراهيم الخطيب الإستراباذي، ثنا أبو نعيم بن عدي، ثنا أحمد بن محمد بن [أبي] الخناجر، ثنا موسى بن داود، ثنا حماد بن سلمة، عن ثابت، عن أنس به.</p><p>إسناده حسن.|7:عزاه السيوطي إلى أبي نعيم، والدِّمياطي في معجمه.|8:أخرجه ابن أبي حاتم ٦/١٩٤٣.|9:أخرجه عبد الرزاق ١/٢٩٣، وابن جرير ١٢/١٥٤. وعلَّق ابن أبي حاتم ٦/١٩٤٣ شطره الأول. وعزاه السيوطي إلى أبي الشيخ.|10:علَّقه ابن أبي حاتم ٦/١٩٤٣.|11:تفسير مقاتل بن سليمان ٢/٢٣٦.|12:أخرجه ابن أبي حاتم ٦/١٩٤٣.|13:تفسير مقاتل بن سليمان ٢/٢٣٦.|14:أقْصَر فلان عن الشيء: إذا كفَّ عنه وانتهى. لسان العرب (قصر).|15:أخرجه ابن أبي حاتم ٦/١٩٤٣.|16:عزاه السيوطي إلى أبي الشيخ.|17:أخرجه ابن جرير ١٢/١٥٤، وابن أبي حاتم ٦/١٩٤٣. وعزاه السيوطي إلى أحمد في الزهد.