20,118," <q>﴿إِنَّ لَكَ أَلَّا تَجُوعَ فِیهَا وَلَا تَعۡرَىٰ ۝١١٨﴾</q> - تفسير ٤٨٤٦٥- قال مقاتل بن سليمان: <q>﴿إن لك﴾</q> يا آدم <q>﴿ألا تجوع فيها ولا تعرى﴾</q>{1}. (ز) ٤٨٤٦٦- قال يحيى بن سلّام: <q>﴿إن لك ألا تجوع فيها﴾</q> في الجنة، <q>﴿ولا تعرى﴾</q> كانا كُسِيا الظُّفُر{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٤.
20,119," <q>﴿وَأَنَّكَ لَا تَظۡمَؤُا۟ فِیهَا﴾</q> - تفسير ٤٨٤٦٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأنك لا تظمأ فيها﴾</q>، قال: لا يصيبك فيها عَطَشٌ {1}. (١٠/٢٥١) ٤٨٤٦٨- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿لا تظمأ﴾</q> قال: لا تعطش {2}. (١٠/٢٥١) ٤٨٤٦٩- عن عكرمة مولى ابن عباس -من طريق خُصَيْف- في قوله: <q>﴿لا تظمؤا فيها﴾</q>، قال: لا تَعْطَش{3}. (ز) ٤٨٤٧٠- قال مقاتل بن سليمان: <q>﴿وأنك لا تظمأ فيها﴾</q>، يعني: لا تَعْطَش في الجنة{4}. (ز) ٤٨٤٧١- قال يحيى بن سلّام: <q>﴿وأنك لا تظمأ فيها﴾</q> لا تعطش فيها{5}. (ز) ٤٨٤٧٢- عن اليزيدي -من طريق أبي خلاد- قال: المعنى: وإنّ لك أن لا تظمأ{6}. (ز) <q>﴿وَلَا تَضۡحَىٰ ۝١١٩﴾</q> - تفسير ٤٨٤٧٣- عن عبد الله بن عباس – من طريق علي – في قوله: <q>﴿وَلَا تَضْحَى﴾</q> قال: لا يصيبك فيها حَرٌّ. {7}.(١٠/٢٥١). (ز) ٤٨٤٧٤- عبد الله بن عباس – من طريق عطية العوفي – في قوله: <q>﴿وَلَا تَضْحَى﴾</q> قال: لا يصيبك فيها حَرٌّ ولا أذى.{8}.(١٠/٢٥١). (ز) ٤٨٤٧٥- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: <q>﴿وأنك لا تظمأ فيها ولا تضحى﴾</q>. قال: لا تَعْرَقُ فيها مِن شِدَّة حَرِّ الشمس. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت الشاعر يقول: رأت رجلًا أمّا إذا الشمس عارضَت فيَضْحى وأمّا بالعشي فيَخْصَرُ؟{9}{10}. (١٠/٢٥١) ٤٨٤٧٦- عن سعيد بن جبير -من طريق خُصَيْف- <q>﴿ولا تضحى﴾</q>، قال: لا تُصِيبُك الشمسُ{11}. (ز) ٤٨٤٧٧- عن عكرمة مولى ابن عباس -من طريق خُصَيْف- في قوله: <q>﴿ولا تضحى﴾</q>، قال: لا تُصِيبُك الشمسُ{12}. (١٠/٢٥١) ٤٨٤٧٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تضحى﴾</q>، قال: لا تصيبك الشمس{13}. (ز) ٤٨٤٧٩- قال مقاتل بن سليمان: <q>﴿ولا تضحى﴾</q>، يقول: لا يُصِيبُك حرُّ الشمس، فيؤذيك، فتفرق{4}. (ز) ٤٨٤٨٠- قال يحيى بن سلّام: <q>﴿ولا تضحى﴾</q>، يعني: لا يصيبك حرُّ شمسٍ{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٠.تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٤.أخرجه أبو عمرو الداني في المكتفى ص١٣١ (١٦).أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتمأخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن أبي حاتمفَيَخْصَرُ: خَصِرَ الرجلُ إذا آلمهُ البردُ في أطرافِهِ. اللسان (خصر).أخرجه الطستي -كما في الإتقان ٢/٧١-.أخرجه ابن جرير ١٦/١٨٨.أخرجه عبد الرزاق ٢/٢٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٨٨. وعلَّقه يحيى بن سلّام ١/٢٨٤.تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٤.
20,120," <q>﴿فَوَسۡوَسَ إِلَیۡهِ ٱلشَّیۡطَـٰنُ قَالَ یَـٰۤـَٔادَمُ هَلۡ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلۡخُلۡدِ﴾</q> - تفسير ٤٨٤٨١- عن أبي هريرة، عن النبي ﷺ، قال: «إنّ في الجنة شجرةٌ يسير الراكبُ في ظِلِّها مائةَ عام لا يقطعها، وهي شجرة الخلد»{1}. (١٠/٢٥٢) ٤٨٤٨٢- عن وهب بن مُنَبِّه -من طريق عمر بن عبد الرحمن بن مُهْرِبٍ- قال: لَمّا أسكن اللهُ آدمَ الجنةَ وزوجتَه، ونهاه عن الشجرة؛ كانت الشجرةُ غصونُها مُتَشَعِّبَةٌ بعضُها على بعض، وكان لها ثمر تأكله الملائكة لخُلْدِهم، وهي الثمرة التي نهى اللهُ آدمَ عنها وزوجته، فلمّا أراد إبليسُ أن يَسْتَزِلَّهما دخل الحيَّة، وكانت الحيَّةُ لها أربعُ قوائم كأنها بُخْتِيَّةٌ{2} مِن أحسن دابَّةٍ خلقها الله، فلما دخلت الحيَّةُ الجنةَ خرج مِن جوفها إبليس، فأخذ مِن الشجرة التي نهى اللهُ آدمَ وزوجتَه عنها، فجاء بها إلى حواء، فقال: انظري إلى هذه الشجرة، ما أطيب ريحها، وأطيب طعمها، وأحسن لونها! فأخذتها حواءُ، فأكلتها، ثم ذهبت بها إلى آدم، فقالت: انظر إلى هذه الشجرة، ما أطيب ريحها، وأطيب طعمها، وأحسن لونها! فأكل منها آدم؛ فبَدَت لهما سوآتهما، فدخل آدمُ في جوف الشجرة، فناداه ربه: أين أنت؟ قال: ها أنا ذا، يا رب. قال: ألا تخرج؟ قال: أستحي منك، يا رب. قال: اهبط إلى الأرض. ثم قال: يا حواء، غَرَرْتِ عبدي؟! فإنّك لا تحملين حَمْلًا إلا كرهًا، فإذا أردت أن تضعي ما في بطنك أشرفتِ على الموتِ مِرارًا. وقال للحيَّة: أنت التي دخل الملعون في جوفك حتى غرَّ عبدي، أنت ملعونة لعنة، تتحول قوائمك في بطنك، ولا يكون لك رِزْقٌ إلا التراب، أنت عدوُّ بني آدم، وهم أعداؤك، أينما لقيتِ أحدًا منهم أخذتِ بعَقِبَيْه، وحيث ما لقيك أحدٌ منهم شَدَخَ رأسَك. قيل لوهب: وهل كانت الملائكة تأكل؟ قال: يفعلُ الله ما يشاء{3}. (١٠/٢٥٣) ٤٨٤٨٣- عن إسماعيل السدي -من طريق أسباط- <q>﴿قال يا آدم هل أدلك على شجرة الخلد وملك لا يبلى﴾</q>، يقول: هل أدلك على شجرةٍ إن أكلتَ منها كنتَ ملِكًا مثل الله، <q>﴿أو تكونا من الخالدين﴾</q> [الأعراف:٢٠] فلا تموتان أبدًا{4}. (ز) ٤٨٤٨٤- قال مقاتل بن سليمان: <q>﴿فوسوس إليه الشيطان﴾</q> يعني: إبليس وحده، فـ<q>﴿قال يا آدم هل أدلك﴾</q> يقول: ألا أدلك <q>﴿على شجرة الخلد﴾</q> مَن أكل منها خَلَدَ في الجنة فلا يموت{5}. (ز) ٤٨٤٨٥- قال يحيى بن سلّام: <q>﴿على شجرة الخلد وملك لا يبلى﴾</q> أي: إنك إن أكلت منها خَلَدتَ في الجنة. وهو قوله: <q>﴿ما نهاكما ربكما عن هذه الشجرة إلا أن تكونا ملكين﴾</q> يقول: أي: لكيلا تكونا ملَكين، <q>﴿أو تكونا من الخالدين﴾</q> [الأعراف:٢٠] يقول: إذا أكلتما من الشجرة تَحَوَّلْتُما مَلَكَيْنِ مِن ملائكة الله، أو كنتما مِن الخالدين{6}. (ز) <q>﴿وَمُلۡكࣲ لَّا یَبۡلَىٰ ۝١٢٠﴾</q> - تفسير ٤٨٤٨٦- قال مقاتل بن سليمان: <q>﴿و﴾</q>على <q>﴿ملك لا يبلى﴾</q> يقول: لا يَفْنى{5}. (ز) <q>﴿وَمُلۡكࣲ لَّا یَبۡلَىٰ ۝١٢٠﴾</q> - آثار متعلقة بالآية ٤٨٤٨٧- عن ابن إسحاق، عن بعض أهل العلم: أنّ آدم حين دخل الجنة، ورأى ما فيها مِن الكرامة، وما أعطاه اللهُ منها؛ قال: لو أنّ خُلْدًا كان. فاغتنمها منه الشيطان لَمّا سَمِعها منه، فأتاه مِن قِبَل الخُلْد{8}. (ز) ",footnotes:1:أخرجه أحمد ١٥/٥٣٧ (٩٨٧٠)، ١٦/٣٤ (٩٩٥٠)، والدارمي ٢/٤٣٦ (٢٨٣٩). وأصله عند البخاري ٤/١١٩ (٣٢٥٢)، ومسلم ٤/٢١٧٦ (٢٨٢٨)، كلاهما دون ذكر: شجرة الخلد.البُخْتِية: الأُنثى من الجِمالِ البُخْتِ، وهي جمالٌ طوالُ الأَعْناق. النهاية واللسان (بخت).أخرجه عبد الرزاق ١/٢٢٦-٢٢٧، والحكيم الترمذي في نوادر الأصول ١/٢٠٣-٢٠٤، وابن جرير ١/٥٦١-٥٦٢ مطولًا، وابن أبي حاتم ١/٨٧، ٥/١٤٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٦/١٨٨. وعلَّقه يحيى بن سلّام في تفسيره ١/٢٨٤ مختصرًا بلفظ: ألا أدلك.تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٤.تفسير مقاتل بن سليمان ٣/٤٤.أخرجه ابن جرير ١/٥٦٤.
20,121," <q>﴿فَأَكَلَا مِنۡهَا فَبَدَتۡ لَهُمَا سَوۡءَ ٰ⁠ تُهُمَا﴾</q> - تفسير ٤٨٤٨٨- عن الحسن، عن أُبَيّ بن كعب، قال: قال رسول الله ﷺ: «إنّ الله خَلَق آدم رجلًا طوالًا كثير شعر الرأس، كأنّه نخلة سَحُوق، فلمّا ذاق الشجرةَ سقط عنه لِباسُه، فأول ما بدا منه عورتُه، فلما نظر إلى عورتِه جعل يَشْتَدُّ في الجنَّة، فأخذتْ شعرَه شجرةٌ، فنازعها، فنادى الرحمن: يا آدم، مِنِّي تَفِرُّ؟! فلمّا سمع كلامَ الرحمن قال: يا ربِّ، لا، ولكن استحياءً، أرأيتَ إن تبتُ ورجعتُ أعائدي إلى الجنة؟ قال: نعم. فذلك قوله: <q>﴿فَتَلَقّى آدَمُ مِن رَبِّهِ كَلِماتٍ فَتابَ عَلَيْهِ﴾</q>»{1}. (ز) ٤٨٤٨٩- قال الحسن البصري: <q>﴿فبدت لهما سوءاتهما﴾</q> لو أنّ حواء بدأت قبل آدم، فبدت سوآتها عند ذلك؛ لكانت له عظة، ولكن لما أكل آدم بدت لهما سوآتهما{2}. (ز) ٤٨٤٩٠- عن وهْب بن مُنَبِّه -من طريق عمرو بن دينار- <q>﴿فبدت لهما سوآتهما﴾</q>، قال: كان عليهما ثوب، يعني: على سوآتهما، لا يُبصِر واحدٌ منهما صاحبَه{3}. (ز) ٤٨٤٩١- عن إسماعيل السُّدِّيّ، قال: إنّما أراد -يعني: إبليس- بقوله: <q>﴿هل أدلك على شجرة الخلد وملك لا يبلى﴾</q> ليبدي لهما ما توارى عنهما مِن سوآتهما، بهتك لباسهما، وكان قد علم أنّ لهما سوأة لِما كان يقرأ مِن كتب الملائكة، ولم يكن آدمُ يعلمُ ذلك، وكان لباسهما الظُّفُرَ، فأبى آدم أن يأكل منها، فتقدمت حواء، فأكلت، ثم قالت: يا آدم، كُلْ؛ فإنِّي قد أكلتُ فلم يضرَّني. فلمّا أكل آدمُ بدت لهما سوآتهما{4}. (ز) ٤٨٤٩٢- تفسير محمد بن السائب الكلبي، قوله: <q>﴿فأكلا منها﴾</q>: فبدأت حواءُ قبل آدم{5}. (ز) ٤٨٤٩٣- قال مقاتل بن سليمان: <q>﴿فأكلا منها فبدت لهما سوءاتهما﴾</q>، يقول: ظهرت لهما عوراتُهما{6}. (ز) <q>﴿وَطَفِقَا یَخۡصِفَانِ عَلَیۡهِمَا مِن وَرَقِ ٱلۡجَنَّةِۚ﴾</q> - قراءات ٤٨٤٩٤- عن محمد ابن شهاب الزهري -من طريق عُقَيْل بن خالد- أنّه كان يقرأ: (يَخصِّفانِ عَلَيْهِما مِن وَّرَقِ الجَنَّةِ){7}. (ز) <q>﴿وَطَفِقَا یَخۡصِفَانِ عَلَیۡهِمَا مِن وَرَقِ ٱلۡجَنَّةِۚ﴾</q> - تفسير الآية ٤٨٤٩٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿وطَفِقا يَخْصِفانِ عَلَيْهِما مِن ورَقِ الجَنَّةِ﴾</q>، قال: ينزعان ورقَ التين، فيجعلانه على سوآتهما{8}. (١/٢٨٧) ٤٨٤٩٦- تفسير مجاهد بن جبر: قوله: <q>﴿وطفقا يخصفان عليهما من ورق الجنة﴾</q>، أي: وجعلا يخصفان عليهما مِن ورق الجنة، يُرَقِّعانه كهيئة الثوب{2}. (ز) ٤٨٤٩٧- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿وطفقا يخصفان عليهما من ورق الجنة﴾</q>، يقول: يُوصِلان عليهما مِن ورق الجنة{10}. (ز) ٤٨٤٩٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وطفقا يخصفان عليهما من ورق الجنة﴾</q>، يقول: أقبلا يُغَطِّيان عليهما بورق التين{10}. (ز) ٤٨٤٩٩- قال مقاتل بن سليمان: <q>﴿وطفقا يخصفان عليهما﴾</q> يقول: وجعلا يخصفان، يقول: يُلْزِقان الورقَ بعضه على بعض <q>﴿من ورق الجنة﴾</q> ورق التين؛ ليستتروا به في الجنة{6}. (ز) <q>﴿وَعَصَىٰۤ ءَادَمُ رَبَّهُۥ فَغَوَىٰ ۝١٢١﴾</q> - تفسير ٤٨٥٠٠- قال مقاتل بن سليمان: <q>﴿وعصى آدم ربه فغوى﴾</q>، يعني: فضَلَّ، وتَوَلّى عن طاعة ربه ﷿{6}. (ز) ٤٨٥٠١- قال يحيى بن سلّام: <q>﴿وعصى آدم ربه فغوى﴾</q>، يعني: المعصية، ولم تبلغ بالمعصية الضلال{14}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في العقوبات ص٦٩-٧٠ (١٠٢)، ويحيى بن سلّام ١/٢٨٥، وابن جرير ١٠/١١١، وابن أبي حاتم ١/٨٧-٨٨ (٣٨٨)، ٥/١٤٥١-١٤٥٢ (٨٢٩٩)، ٥/١٤٥٣ (٨٣٠٨). قال ابن كثير في تفسيره ٥/٣٢١: «وهذا منقطع بين الحسن وأُبَي بن كعب، فلم يسمعه منه، وفي رفعه نظر أيضًا».علَّقه يحيى بن سلّام ١/٢٨٥.أخرجه إسحاق البستي في تفسيره ص٢٨٠.أخرجه ابن جرير ١٦/١٨٩.علَّقه يحيى بن سلّام ١/٢٨٤.تفسير مقاتل بن سليمان ٣/٤٤.أخرجه عبد الله بن وهب في الجامع - علوم القرآن ٣/٤٩-٥٠ (١٠٢). (يَخْصِّفانِ) بإسكان الخاء، أو(يَخِصِّفانِ) بكسر الخاء قراءتان شاذتان، تروى أولاهما عن عبد الله بن بريدة، وثانيهما عن الحسن. انظر: مختصر ابن خالويه ص٩٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٣٢١-، وابن عساكر في تاريخه ٧/٤٠٣. وعزاه السيوطي إلى سفيان بن عيينة، وعبد الرزاق، وابن المنذر.علَّقه يحيى بن سلّام ١/٢٨٥.أخرجه ابن جرير ١٦/١٩٠.أخرجه ابن جرير ١٦/١٩٠.تفسير مقاتل بن سليمان ٣/٤٤.تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٥.
20,122," <q>﴿ثُمَّ ٱجۡتَبَـٰهُ رَبُّهُۥ فَتَابَ عَلَیۡهِ وَهَدَىٰ ۝١٢٢﴾</q> - تفسير ٤٨٥٠٢- قال مقاتل بن سليمان: <q>﴿ثم اجتباه ربه﴾</q> يعني: استخلصه ربُّه ﷿، <q>﴿فتاب عليه﴾</q> مِن ذنبه، <q>﴿وهدى﴾</q> يعني: وهداه للتوبة{1}. (ز) ٤٨٥٠٣- قال يحيى بن سلّام: <q>﴿ثم اجتباه ربه﴾</q>، وهو قوله: <q>﴿فتلقى آدم من ربه كلمات﴾</q> [البقرة:٣٧]، فقالا: <q>﴿ربنا ظلمنا أنفسنا وإن لم تغفر لنا وترحمنا لنكونن من الخاسرين﴾</q> [الأعراف:٢٣]، قال: <q>﴿فتاب عليه﴾</q> مِن ذلك الذنب، <q>﴿وهدى﴾</q> مات على الهُدى{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٥.
20,123," <q>﴿قَالَ ٱهۡبِطَا مِنۡهَا جَمِیعَۢاۖ بَعۡضُكُمۡ لِبَعۡضٍ عَدُوࣱّۖ﴾</q> - تفسير ٤٨٥٠٤- قال مقاتل بن سليمان: <q>﴿قال اهبطا منها جميعا﴾</q> يعني: آدم وإبليس، <q>﴿بعضكم لبعض عدو﴾</q> يقول: إبليس وذُرِّيَّتُه عَدُوٌّ لآدم وذُرِّيَّتِه{1}. (ز) <q>﴿فَإِمَّا یَأۡتِیَنَّكُم مِّنِّی هُدࣰى فَمَنِ ٱتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَلَا یَشۡقَىٰ ۝١٢٣﴾</q> - قراءات ٤٨٥٠٥- عن أبي الطُّفَيل: أنّ النبي ﷺ قرأ: <q>﴿فَمَنِ اتَّبَعَ هُدايَ﴾</q>{2}. (١٠/٢٥٤) <q>﴿فَإِمَّا یَأۡتِیَنَّكُم مِّنِّی هُدࣰى فَمَنِ ٱتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَلَا یَشۡقَىٰ ۝١٢٣﴾</q> - تفسير الآية ٤٨٥٠٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «مَن اتَّبع كتابَ الله هداه الله مِن الضلالة في الدنيا، ووقاه سوء الحساب يوم القيامة؛ وذلك أنّ الله يقول: <q>﴿فمن اتبع هداي فلا يضل ولا يشقى﴾</q>»{3}. (١٠/٢٥٤) ٤٨٥٠٧- عن عبد الله بن عباس -من طريق عكرمة- قال: أجار اللهُ تابعَ القرآن مِن أن يضلَّ في الدنيا، أو يشقى في الآخرة. ثم قرأ: <q>﴿فمن اتبع هداي فلا يضل ولا يشقى﴾</q>. قال: لا يضِلُّ في الدنيا، ولا يشقى في الآخرة{4}. (١٠/٢٥٤) ٤٨٥٠٨- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿فمن اتبع هداي﴾</q>، يعني: رسلي، وكتبي{5}. (ز) ٤٨٥٠٩- قال مقاتل بن سليمان: <q>﴿فإما﴾</q> يعني: فإن <q>﴿يأتينكم﴾</q> يعني: ذرية آدم <q>﴿مني هدى﴾</q> يعني: رسلًا معهم كتب فيها البيان؛ <q>﴿فمن اتبع هداي﴾</q> يعني: رسلي وكتابي <q>﴿فلا يضل﴾</q> في الدنيا، <q>﴿ولا يشقى﴾</q> في الآخرة{6}. (ز) ٤٨٥١٠- قال يحيى بن سلّام: <q>﴿فلا يضل﴾</q> في الدنيا، <q>﴿ولا يشقى﴾</q> في الآخرة{7}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤. وقد تقدم بيان ذلك عند تفسير قوله تعالى: <q>﴿وقُلْنا اهْبِطُوا بَعْضُكُمْ لِبَعْضٍ عَدُوٌّ﴾</q> [البقرة:٣٦] كما قال يحيى بن سلام ١/٢٨٥: وقد فسرناه في سورة البقرة.عزاه السيوطي إلى الطبراني، وابن مردويه، والخطيب بقراءة <q>﴿فَمَنِ اتَّبَعَ هُدايَ﴾</q>. وأخرجه أبو بكر بن خلاد النصيبي في حديثه ص٥٧ (٥٦)، والخطيب في المتفق والمفترق ١/٥٦١ (٣٠٨) بقراءة (فَمَن تَبِعَ هُدايَ)، من طريق إسماعيل المكي، عن أبي الطفيل به. قال ابن أبي حاتم في العلل ٦/٦٣٦-٦٣٧ (٢٨٢٣): «سُئِل أبو زرعة عن حديث أبي الطفيل. فقال: مرسل». وقال الهيثمي في المجمع ٧/٦٧ (١١١٦٩): «رواه الطبراني، وفيه إسماعيل بن مسلم المكي، وهو ضعيف». و<q>﴿فَمَنِ اتَّبَعَ هُدايَ﴾</q> قراءة العشرة.أخرجه الطبراني في الأوسط ٥/٣٣٢ (٥٤٦٦). قال الهيثمي في المجمع ٧/٦٧ (١١١٦٨): «وفيه أبو شيبة، وعمران بن أبي عمران، وكلاهما ضعيف». وقال المناوي في التيسير ٢/٣٨٦: «وإسناده ضعيف». وقال الألباني في الضعيفة ١٠/٣٣ (٤٥٣١): «ضعيف جدًّا».أخرجه ابن أبي شيبة ١٠/٤٦٧، وابن جرير ١٦/١٩١، والحاكم ٢/٣٨١، والبيهقي في شعب الإيمان (٢٠٢٩) من طُرُق. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وسعيد بن منصور، ومحمد بن نصر، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلّام ١/٢٨٥.تفسير مقاتل بن سليمان ٣/٤٤.تفسير يحيى بن سلّام ١/٢٨٥.
20,124," <q>﴿وَمَنۡ أَعۡرَضَ عَن ذِكۡرِی﴾</q> - نزول الآية ٤٨٥١١- قال مقاتل بن سليمان: <q>﴿ومن أعرض عن ذكري﴾</q> نَزَلَتْ في الأسود بن عبد الأسود المخزومي، قتله حمزة بن عبد المطلب يوم بدر على الحوض ...{1}. (ز) <q>﴿وَمَنۡ أَعۡرَضَ عَن ذِكۡرِی﴾</q> - تفسير الآية ٤٨٥١٢- قال مقاتل بن سليمان: <q>﴿ومن أعرض عن ذكري﴾</q>، يعني: عن إيمان بالقرآن{1}. (ز) ٤٨٥١٣- قال يحيى بن سلّام: قوله: <q>﴿ومن أعرض عن ذكري﴾</q> فلم يتبع هداي؛ لم يؤمن{3}. (ز) <q>﴿فَإِنَّ لَهُۥ مَعِیشَةࣰ ضَنكࣰا﴾</q> - تفسير ٤٨٥١٤- عن أبي هريرة، عن النبي ﷺ، قال: «المؤمنُ في قبره في روضة خضراء، ويرحب له قبره سبعين ذراعًا، ويضيء حتى يكون كالقمر ليلة البدر، هل تدرون فيما أنزلت: <q>﴿فإن له معيشة ضنكا﴾</q>؟». قالوا: الله ورسوله أعلم. قال: «عذاب الكافر في قبره؛ يُسَلَّط عليه تسعة وتسعون تِنِّينًا، هل تدرون ما التِّنِّين؟ تسعة وتسعون حيَّة، لكل حيَّة سبعة رؤوس، يخدشونه، ويلسعونه، وينفخون في جسمه إلى يوم يبعثون»{4}. (١٠/٢٥٦) ٤٨٥١٥- عن أبي هريرة، عن النبي ﷺ، في قوله: <q>﴿فإن له معيشة ضنكا﴾</q>، قال: «المعيشة الضنك التي قال الله أنّه يُسَلَّط عليه تسعة وتسعون حيَّة تنهش لحمه حتى تقوم الساعة»{5}. (١٠/٢٥٥) ٤٨٥١٦- عن أبي هريرة، عن النبي ﷺ، في قوله: <q>﴿فإن له معيشة ضنكا﴾</q>، قال: «عذاب القبر»{6}. (١٠/٢٥٦) ٤٨٥١٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «... وأَمّا الكافر فيؤتى في قبره مِن قبَلِ رأسه فلا يوجد شيءٌ، فيؤتى مِن قبَلِ رجليه فلا يوجد شيءٌ، فيجلِس خائفًا مرعوبًا، فيقال له: ما تقول في هذا الرجل الذي كان فيكم وما تشهد به؟ فلا يهتدي لاسمِه، فيقال: محمدٌ ﷺ. فيقولُ: سمعتُ الناسَ يقولون شيئًا، فقلتُ كما قالوا. فيُقالُ له: صدَقتَ، على هذا حَييت، وعليه مِتَّ، وعليه تُبعثُ -إن شاء الله-. ويُضَيَّق عليه قبرُه حتى تختلف أضلاعُه، فذلك قوله تعالى: <q>﴿ومنْ أعرَضَ عن ذكري فإنّ لهُ معيشةً ضنكًا﴾</q>»{7}. (٨/٥٢٨) ٤٨٥١٨- عن أبي سعيد الخدري مرفوعًا، في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: «عذاب القبر»{8}. (١٠/٢٥٥) ٤٨٥١٩- عن عبد الله بن مسعود -من طريق القاسم بن عبد الرحمن- في قوله: <q>﴿فإن له معيشة ضنكا﴾</q>، قال: عذاب القبر{9}. (١٠/٢٥٨) ٤٨٥٢٠- عن عبد الله بن مسعود -من طريق مُخارِق بن سليم- قال: إذا حَدَّثتكم بحديث أنبأتُكم بتصديق ذلك مِن كتاب الله؛ إنّ المؤمن إذا وُضِع في قبره أُجْلِس فيه، فيُقال له: مَن ربُّك؟ وما دينك؟ ومَن نبيُّك؟ فيُثَبِّته الله، فيقول: ربي الله، وديني الإسلام، ونبيي محمد ﷺ. فيُوَسَّع له في قبره، ويروح له فيه. ثم قرأ عبد الله: <q>﴿يثبت الله الذين آمنوا بالقول الثابت في الحياة الدنيا وفي الآخرة﴾</q>. فإذا مات الكافرُ أُجْلِس في قبره، فيُقال له: مَن ربُّك؟ وما دينك؟ ومَن نبيُّك؟ فيقول: لا أدري. قال: فيُضَيَّق عليه قبره، ويعذب فيه. ثم قرأ: <q>﴿ومن أعرض عن ذكري فإن له معيشة ضنكا﴾</q>{10}. (٨/٥٢٦، ١٠/٢٥٧) ٤٨٥٢١- عن أبي هريرة -من طريق أبي سلمة- قال: يُضَيَّق على الكافر قبره حتى تختلف فيه أضلاعه، وهي المعيشة الضنك التي قال الله: <q>﴿معيشة ضنكا ونحشره يوم القيامة أعمى﴾</q>{11}. (ز) ٤٨٥٢٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: الشَّقاء{12}. (١٠/٢٥٧) ٤٨٥٢٣- عن عبد الله بن عباس، في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: شِدَّة عليه في النار{13}. (١٠/٢٥٧) ٤٨٥٢٤- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿معيشة ضنكا﴾</q>. قال: الضَّنك: الشديدُ مِن كل وجه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: والخيلُ قد لحقَت بنا في مأزقٍ ضَنكٍ نواحيه شديد المقْدَمِ؟{14}. (١٠/٢٥٧) ٤٨٥٢٥- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿ومن أعرض عن ذكري، فإن له معيشة ضنكا﴾</q>، يقول: كل مال أعطيته عبدًا مِن عبادي قلَّ أو كَثُر لا يُطِيعُني فيه لا خير فيه، وهو الضنك في المعيشة. ويُقال: إنّ قومًا ضُلّالًا أعرضوا عن الحق، وكانوا أولي سَعَة من الدنيا مُكْثِرِين، فكانت معيشتهم ضَنكًا، وذلك أنّهم كانوا يَرَوْن أنّ الله ﷿ ليس بِمُخْلِفٍ لهم معايشهم مِن سوء ظنهم بالله، والتكذيب به، فإذا كان العبدُ يُكَذِّب بالله، ويُسِيءُ الظن به؛ اشْتَدَّت عليه معيشتُه، فذلك الضنك{15}. (١٠/٢٥٨) ٤٨٥٢٦- عن عبد الله بن عباس -من طريق الثوري، عن رجل، عن سعيد بن جبير- قال: هي بلاء على بلاء{16}. (ز) ٤٨٥٢٧- قال سعيد بن جبير: يسلبه القناعة حتى لا يشبع{17}. (ز) ٤٨٥٢٨- عن قيس بن أبي حازم -من طريق إسماعيل بن أبي خالد- في قول الله: <q>﴿معيشة ضنكا﴾</q>، قال: رِزْقًا في معصيته{18}. (ز) ٤٨٥٢٩- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿معيشة ضنكا﴾</q>: ضيقة؛ يُضَيَّق عليه قبره{19}. (١٠/٢٥٩) ٤٨٥٣٠- عن مجاهد بن جبر، في قوله: <q>﴿فإن له معيشة ضنكا﴾</q>، قال: رِزقًا{20}. (١٠/٢٥٩) ٤٨٥٣١- عن الضحاك بن مزاحم، في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: ضَيِّقة{13}. (١٠/٢٥٨) ٤٨٥٣٢- عن الضحاك بن مزاحم، في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: العمل السَّيِّئ، والرِّزق الخبيث{22}. (١٠/٢٥٨) ٤٨٥٣٣- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: الضنك مِن المعيشة إذا وسَّع الله على عبده: أن يجعلَ معيشتَه من الحرام، فجعله الله عليه ضيقًا في نار جهنم{23}. (١٠/٢٥٨) ٤٨٥٣٤- عن الحسن البصري -من طريق سعيد بن عوف- قال: المعيشة الضنك: جهنم{24}. (١٠/٢٥٨) ٤٨٥٣٥- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: عذاب القبر{25}. (١٠/٢٥٨) ٤٨٥٣٦- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فإن له معيشة ضنكا﴾</q>، قال: الضنك: الضيق، ضنكًا في النار{26}. (ز) ٤٨٥٣٧- عن إسماعيل السُّدِّيّ -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: عذاب القبر{11}. (ز) ٤٨٥٣٨- عن مالك بن دينار، في قوله: <q>﴿معيشة ضنكا﴾</q>، قال: يُحَوِّل اللهُ رزقَه في الحرام، فلا يطعمه إلا حرامًا حتى يموت، فيُعَذِّبه عليه{13}. (١٠/٢٥٨) ٤٨٥٣٩- عن الربيع [بن أنس]، قال: عذاب القبر{29}. (١٠/٢٥٨) ٤٨٥٤٠- قال مقاتل بن سليمان: <q>﴿فإن له معيشة ضنكا﴾</q>، يعني: معيشة سوء؛ لأنّها في معاصي الله ﷿، الضنك والضيق{1}. (ز) ٤٨٥٤١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومن أعرض عن ذكري فإن له معيشة ضنكا﴾</q> فقرأ حتى بلغ: <q>﴿ولم يؤمن بآيات ربه﴾</q>، قال: هؤلاء أهل الكفر. قال: <q>﴿معيشة ضنكا﴾</q> في النار؛ شَوْكٌ من نار، وزَقُّوم، وغِسْلِين، والضَّريع شوك من نار، وليس في القبر، ولا في الدنيا معيشة، ما المعيشة والحياة إلا في الآخرة. وقرأ قول الله ﷿: <q>﴿يا ليتني قدمت لحياتي﴾</q> [الفجر:٢٤]، قال: لمعيشتي. قال: والغسلين والزقوم شيء لا يعرفه أهل الدنيا{31}٤٣١٦. (١٠/٢٥٩) ٤٣١٦ أفادت الآثار اختلاف المفسرين في موضع المعيشة الضنك على أقوال: الأول: أنّ المعيشة الضنك في الدنيا، وفي صفتها قولان: أولهما: أنها بالكسب الحرام. وثانيهما: أن صاحبها ينفق من ماله على تكذيب منه بالخَلَف من الله، فتشتد لذلك عليه معيشته وتضيق. الثاني: أن المعيشة الضنك في البرزخ، وهي عذاب القبر. الثالث: أن المعيشة الضنك في الآخرة في جهنم، بأن جُعِل طعامهم فيها الضريع والزقوم. ورجَّح ابنُ جرير (١٦/١٩٨-١٩٩) مستندًا إلى السنة والسياق القولَ الثاني، وهو قول أبي سعيد الخدري، وابن مسعود، وأبي هريرة، وأبي صالح، والربيع، والسدي، وعلَّل ذلك بحديث أبي هريرة المرفوع الثالث المتقدم في آثار تفسير الآية، وبـ«أن الله -تبارك وتعالى- أتْبَع ذلك قولَه: <q>﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</q>، فكان معلومًا بذلك أنّ المعيشة الضنك التي جعلها الله لهم قبل عذاب الآخرة». وانتقد ابنُ جرير (١٦/١٩٩) القول الثالث بأن «ذلك لو كان في الآخرة لم يكن لقوله: <q>﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</q> معنًى مفهوم؛ لأنّ ذلك إن لم يكن تقَدَّمه عذابٌ لهم قبل الآخرة، حتى يكون الذي في الآخرة أشدَّ منه؛ بطل معنى قوله: <q>﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</q>». وانتقد مستندًا لدلالة العقل القول الأول بأنّ المعيشة الضنك إن «كانت لهم في حياتهم الدنيا فقد يجب أن يكون كل مَن أعْرَض عن ذكر الله مِن الكفار فإنّ معيشته فيها ضنكٌ، وفي وجودنا كثيرًا منهم أوسَع معيشةً من كثيرٍ من المُقْبِلين على ذكر الله -تبارك وتعالى- القابلين له المؤمنين؛ ما يدل على أن ذلك ليس كذلك». ووجَّه ابنُ عطية (٦/١٤٢) القول الثاني بقوله: «وحمل هذه الفرقة على هذا التأويل أنّ لفظ الآية يقتضي أن المعيشة الضنك قبل يوم القيامة بقوله: <q>﴿ونَحْشُرُهُ يَوْمَ القِيامَةِ أعْمى﴾</q>، وبقوله تعالى: <q>﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</q>». <q>﴿وَنَحۡشُرُهُۥ یَوۡمَ ٱلۡقِیَـٰمَةِ أَعۡمَىٰ ۝١٢٤﴾</q> - تفسير ٤٨٥٤٢- قال عبد الله بن عباس: أعمى البصر{17}. (ز) ٤٨٥٤٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ونحشره يوم القيامة أعمى﴾</q>، قال: عن الحُجَّة{33}. (١٠/٢٥٩) ٤٨٥٤٤- عن عكرمة مولى ابن عباس -من طريق جابر- في قوله: <q>﴿ونحشره يوم القيامة أعمى﴾</q>، قال: عَمِيَ عليه كلُّ شيء إلا جهنم. وفي لفظ قال: لا يُبصِر إلا النار{34}. (١٠/٢٥٩) ٤٨٥٤٥- عن أبي صالح باذام، في قوله: <q>﴿ونحشره يوم القيامة أعمى﴾</q>، قال: ليس له حُجَّة{35}. (١٠/٢٥٩) ٤٨٥٤٦- قال مقاتل بن سليمان: <q>﴿ونحشره يوم القيامة أعمى﴾</q> عن حجته{36}. (ز) ٤٨٥٤٧- قال يحيى بن سلّام: قوله: <q>﴿ونحشره يوم القيامة أعمى﴾</q> يعني: عن حُجَّته. كقوله: <q>﴿ومن يدع مع الله إلها آخر لا برهان له به﴾</q> [المؤمنون:١١٧] لا حُجَّة له به{37}٤٣١٧. (ز) ٤٣١٧ أفادت الآثارُ اختلافَ المفسرين في صفة العمى في قوله تعالى: <q>﴿ونَحْشُرُهُ يَوْمَ القِيامَةِ أعْمى﴾</q> على قولين: الأول: أنه عمى البصيرة. وهو قول مجاهد، وأبي صالح، ومقاتل، ويحيى بن سلّام. الثاني: أنه عمى البصر. وهو قول ابن عباس، وعكرمة. ووجَّه ابنُ القيم القول الأول بقوله: «والذين قالوا: المراد به العمى عن الحجة إنما مرادهم: أنهم لا حجة لهم، ولم يريدوا أن لهم حجتهم عُمي عنها، بل هم عُمي عن الهدى، كما كانوا في الدنيا، فإنّ العبد يموت على ما عاش عليه، ويبعث على ما مات عليه». ورجَّح ابنُ جرير (١٦/٢٠١) مستندًا إلى دلالة العموم شمول معنى الآية، بأن الله «يحشره أعمى عن الحجة، ورؤية الأشياء، كما أخبر -جلَّ ثناؤه-، فعَمَّ ولم يَخْصُصْ». ورجَّح ابنُ عطية (٦/١٤٢) القول الثاني، فقال: «وهذا هو الأوجه». ولم يذكر مستندًا، ثم وجَّه -بناءً على هذا المعنى- قول مَن قال في قوله تعالى: <q>﴿ونَحْشُرُ المُجْرِمِينَ يَوْمَئِذٍ زُرْقًا﴾</q> [طه: ١٠٢]، بأنه في العين قائلًا: «وأما قوله: <q>﴿ونَحْشُرُ المُجْرِمِينَ يَوْمَئِذٍ زُرْقًا﴾</q> فمَن رآه في العين فلا بُدَّ أن يتأوَّلها مع هذا؛ إما أنها في طائفتين، وإما في موطنين». وكذا رجَّح ابنُ القيم (٢/١٩٣) مستندًا إلى الدلالة العقلية القولَ الثاني، وعلّل ذلك قائلًا: «فإنّ الكافر يعلم الحق يوم القيامة عيانًا، ويُقِرُّ بما كان يجحده في الدنيا، فليس هو أعمى عن الحق يومئذ». وانتقد ابنُ عطية مستندًا إلى الدلالة العقلية القول الأول قائلًا: «ولو كان هذا لم يُحِسَّ الكافر بذلك؛ لأنه مات أعمى البصيرة، ويُحشَر كذلك». ثم علَّق على كلا القولين بقوله: «مع أن عمى البصيرة حاصِلٌ في الوجهين». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤-٤٥.تفسير مقاتل بن سليمان ٣/٤٤-٤٥.تفسير يحيى بن سلّام ١/٢٨٦.أخرجه ابن حبان ٧/٣٩٢-٣٩٣ (٣١٢٢)، وابن أبي حاتم ٧/٢٤٣٩ (١٣٥٦٤)، وابن جرير ١٦/١٩٨-١٩٩ بنحوه. قال ابن كثير في تفسيره ٥/٣٢٣: «رفعه مُنكَرٌ جِدًّا».أخرجه البزار ١٦/٢٣٨ (٩٤٠٧)، وابن أبي حاتم ٧/٢٤٣٩ (١٣٥٦٢). قال الهيثمي في المجمع ٧/٦٧ (١١١٧٠): «رواه البزار، وفيه مَن لم أعرفه».أخرجه ابن حبان ٧/٣٨٨-٣٨٩ (٣١١٩)، وآدم بن أبي إياس -كما في تفسير مجاهد ص٤٦٧-، وابن أبي حاتم ٧/٢٤٣٩ (١٣٥٦٣)، والثعلبي ٦/٢٦٥. قال ابن كثير في تفسيره ٥/٣٢٤: «إسناد جيد».أخرجه ابن حبان ٧/٣٨٠-٣٨٢ (٣١١٣)، والحاكم ١/٥٣٥ (١٤٠٣،١٤٠٤). وتقدم بتمامه مطولًا في تفسير قوله تعالى: <q>﴿يُثَبِّتُ اللَّهُ الَّذِينَ آمَنُوا بِالقَوْلِ الثّابِتِ فِي الحَياةِ الدُّنْيا وفِي الآخِرَةِ﴾</q> [إبراهيم:٢٧]. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الهيثمي في المجمع ٣/٥٢ (٤٢٦٩): «رواه الطبراني في الأوسط، وإسناده حسن».أخرجه الحاكم ٢/٤١٣ (٣٤٣٩)، ويحيى بن سلّام ١/٢٨٦ وزاد: يلتئم على صاحبه حتى تختلف أضلاعه، وعبد الرزاق ٢/٣٧٩ (١٨٤٤) موقوفًا بلفظ: يضيق عليه قبره حتى تختلف أضلاعه، وابن جرير ١٦/١٩٦، ١٩٨ موقوفًا، وابن أبي حاتم ٧/٢٤٤٠ (١٣٥٧٠) بلفظ: «ضمة القبر». وأخرجه إسحاق البستي في تفسيره ص٢٨٢ مرفوعًا بلفظ: «المعيشة الضنك عذاب القبر، يلتهب على صاحبه، فلا يزال يعذب فيه، حتى يبعثه الله». قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/٣٢٣: «الموقوف أصح».أخرجه يحيى بن سلّام ١/٢٨٦، وهناد (٣٥٢)، وابن جرير ١٦/١٩٨، والطبراني (٩١٤٣)، والبيهقي في عذاب القبر (٧٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الطبراني (٩١٤٥)، والبيهقي في كتاب عذاب القبر (٩). وعزاه السيوطي إلى ابن جرير.أخرجه ابن جرير ١٦/١٩٧.أخرجه ابن جرير ١٦/١٩٣، وابن أبي حاتم -كما في التغليق ٤/٢٥٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الطستي -كما في الإتقان ٢/٩٣-.أخرجه ابن جرير ١٦/١٩٥. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.أخرجه الثوري في تفسيره ص١٩٨، ولم ينص على الآية.تفسير الثعلبي ٦/٢٦٥، وتفسير البغوي ٥/٣٠١.أخرجه ابن جرير ١٦/١٩٥.أخرجه إسحاق البستي في تفسيره ص٢٨٠، والبيهقي في عذاب القبر (٧٨) من طريق ابن أبي نَجِيح.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. وأخرجه ابن جرير ١٦/١٩٥ من طريق هارون بن محمد التيمي بلفظ: العمل الخبيث، والرزق السيئ، وفي رواية: الكسب الخبيث.أخرجه ابن جرير ١٦/١٩٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/١٩٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.أخرجه ابن جرير ١٦/١٩٧، والبيهقي في عذاب القبر (٧٤). وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٩٣-١٩٤.أخرجه ابن جرير ١٦/١٩٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٤٤-٤٥.أخرجه ابن جرير ١٦/١٩٤. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.تفسير الثعلبي ٦/٢٦٥، وتفسير البغوي ٥/٣٠١.أخرجه ابن جرير ١٦/٢٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه هناد (٢٢٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٢١، وابن جرير ١٦/٢٠٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٥.تفسير يحيى بن سلّام ١/٢٨٩.
20,125," <q>﴿قَالَ رَبِّ لِمَ حَشَرۡتَنِیۤ أَعۡمَىٰ﴾</q> - تفسير ٤٨٥٤٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لم حشرتني أعمى﴾</q>، قال: لا حُجَّة لي{1}. (١٠/٢٥٩) ٤٨٥٤٩- تفسير قتادة بن دعامة= (ز) ٤٨٥٥٠- وإسماعيل السُّدِّيّ: قوله: <q>﴿قال رب لم حشرتني أعمى﴾</q> عن الحُجَّة{2}. (ز) ٤٨٥٥١- قال مقاتل بن سليمان: <q>﴿قال رب لم حشرتني أعمى﴾</q> عن حُجَّتي{3}. (ز) ٤٨٥٥٢- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿لم حشرتني أعمى﴾</q>، قال: عن حُجَّتي{4}. (ز) <q>﴿وَقَدۡ كُنتُ بَصِیرࣰا ۝١٢٥﴾</q> - تفسير ٤٨٥٥٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وقد كنت بصيرا﴾</q>، قال: في الدنيا{5}. (١٠/٢٥٩) ٤٨٥٥٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿وقد كنت بصيرا﴾</q>، قال: عالِمًا بحُجَجي{6}. (ز) ٤٨٥٥٥- عن قتادة بن دعامة -من طريق مَعْمَر- قوله: <q>﴿قال رب لم حشرتني أعمى وقد كنت بصيرا﴾</q>، قال: كان بعيد البَصَر، قصير النظر، أعمى عن الحق{7}. (ز) ٤٨٥٥٦- قال مقاتل بن سليمان: <q>﴿وقد كنت بصيرا﴾</q> في الدنيا عليمًا بها، وهذا مثل قوله سبحانه: <q>﴿هلك عني سلطانيه﴾</q> [الحاقة:٢٩]، يعني: ضلَّت عَنِّي حجتي، وهذا قوله حين شهدت عليه الجوارح بالشرك والكفر{3}. (ز) ٤٨٥٥٧- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿وقد كنت﴾</q> بها <q>﴿بصيرا﴾</q> في الدنيا، قال: كانت لي في الدنيا حُجَّة، وكان لي كلام{4}. (ز) ٤٨٥٥٨- قال يحيى بن سلّام: <q>﴿وقد كنت بصيرا﴾</q> في الدنيا، عالِمًا بحُجَّتي في الدنيا، وإنما علمه ذلك عند نفسه في الدنيا، كان يحاجُّ في الدنيا جاحِدًا لِما جاءه مِن الله{10}٤٣١٨. (ز) ٤٣١٨ أفادت الآثارُ اختلافَ المفسرين في معنى: <q>﴿وقَدْ كُنْتُ بَصِيرًا﴾</q>؛ فقيل: وقد كنت بصيرًا بحججي. وقيل: وقد كنت ذا بصرٍ أبصر به الأشياء. ورجَّح ابنُ جرير (١٦/٢٠٢) مستندًا إلى دلالة العموم شمول معنى الآية، بـ«أن الله -جلَّ ثناؤه- عمَّ بالخبر عنه بوصفِه نفسَه بالبصر، ولم يَخْصُصْ منه معنًى دون معنًى، فذلك على ما عمَّه». ",footnotes:1:أخرجه هناد (٢٢٦)، وابن جرير ١٦/٢٠١، وأخرجه الفريابي -كما في الفتح ٨/٤٣٣، والتغليق ٤/٢٥٤- بلفظ: عن حجتي.علَّقه يحيى بن سلّام ١/٢٩٠.تفسير مقاتل بن سليمان ٣/٤٥.أخرجه إسحاق البستي في تفسيره ص٢٨٣.أخرجه ابن جرير ١٦/٢٠١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٤٦٨، وأخرجه ابن جرير ١٦/٢٠١ من طريق ابن جريج.أخرجه ابن جرير ١٦/٢٠١. وعلَّق يحيى بن سلّام ١/٢٩٠ آخره، وعقَّب عليه بقوله: أي: في الدنيا.تفسير مقاتل بن سليمان ٣/٤٥.أخرجه إسحاق البستي في تفسيره ص٢٨٣.تفسير يحيى بن سلّام ١/٢٩٠.
