quran[12]{c,v,t}:
  20,114,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَعَـٰلَى ٱللَّهُ ٱلۡمَلِكُ ٱلۡحَقُّۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتعالى الله﴾</span> يعني: ارتفع الله <span class="qpc-hafs">﴿الملك الحق﴾</span> لأنّ غيرَه ﷿ وما سواه مِن الآلهة باطل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فتعالى الله﴾</span> مِن باب العُلُوِّ: ارتفع <span class="qpc-hafs">﴿الملك الحق﴾</span> والحقُّ اسم من أسماء الله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأ: ‹مِن قَبْلِ أن نَّقْضِيَ إلَيْكَ وحْيَهُ›{3}. (١٠/٤٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٥<span class="dash">-</span></span> عن الحسن البصري، قال: لطَم رجلٌ امرأتَه، فجاءتْ إلى النبيِّ ﷺ تطلب قصاصًا، فجعل النبي ﷺ بينهما القصاص؛ فأنزل الله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه وقل رب زدني علما﴾</span>. فوقف النبي ﷺ حتى نزلت: <span class="qpc-hafs">﴿الرجال قوامون على النساء﴾</span> الآية [النساء:٣٤]{4}. (١٠/٢٤٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤١٦<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، قال: كان النبيُّ ﷺ إذا نزل عليه جبريلُ بالقرآن أتْعَبَ نفسَه في حفظه حتى يَشُقَّ على نفسه؛ يتخوف أن يصعد جبريل ولم يحفظه؛ فينسى ما علَّمَه، فقال الله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه﴾</span>. وقال: <span class="qpc-hafs">﴿لا تحرك به لسانك لتعجل به﴾</span> [القيامة:١٦]{5}. (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه﴾</span>، يقول: لا تعجل حتى نُبَيِّنه لك{6}. (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولا تعجل بالقرآن﴾</span>، قال: لا تَتْلُهُ على أحد حتى نُتِمَّه لك{7}. (١٠/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span>: معناه: لا تُقْرِئه أصحابَك، ولا تُمْلِه عليهم حتى يتبين لك معانيه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: فرائضه، وحدوده، وأحكامه، وحلاله، وحرامه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿من قبل أن يقضى إليك وحيه﴾</span>، قال: تِبيانه{10}. (١٠/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿من قبل أن يقضى إليك وحيه﴾</span>، يعني: لا تعجل بالقرآن مِن قبل أن ينزل إليك جبريلُ بالوحي{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تعجل بالقرآن﴾</span> وذلك أنّ جبريل ﵇ كان إذا أخبر النبيَّ ﷺ بالوحى لم يفرغ جبريل ﵇ من آخر الكلامِ حتى يتكلم النبيُّ ﷺ بأوله؛ فقال الله ﷿: <span class="qpc-hafs">﴿ولا تعجل﴾</span> بقراءة القرآن <span class="qpc-hafs">﴿من قبل أن يقضى إليك وحيه﴾</span> يقول: مِن قبل أن يُتِمَّه لك جبريل ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: كان النبيُّ ﵇ إذا نزل عليه الوحي يقرأه، ويُدْئِبُ فيه نفسَه مخافةَ أن ينسى؛ فأنزل الله: <span class="qpc-hafs">﴿لا تحرك به لسانك لتعجل به﴾</span> [القيامة:١٦] نحن نحفظه عليك فلا تنسى. قال الله: <span class="qpc-hafs">﴿إلا ما شاء الله﴾</span>، وهو قوله: <span class="qpc-hafs">﴿سنقرئك فلا تنسى (٦) إلا ما شاء الله﴾</span> [الأعلى:٦-٧]، وهو قوله: <span class="qpc-hafs">﴿ما ننسخ من آية أو ننسها﴾</span> [البقرة:١٠٦] يُنسِها نبيَّه. قال: <span class="qpc-hafs">﴿فإذا قرأناه فاتبع قرءانه﴾</span> [القيامة:١٨] فرائضه، وحدوده، والعمل به{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ زِدۡنِی عِلۡمࣰا ۝١١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقل رب زدني علما﴾</span>، يعني: قرآنًا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ زِدۡنِی عِلۡمࣰا ۝١١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٢٧<span class="dash">-</span></span> عن أبي هريرة، قال: كان رسولُ الله ﷺ يقول: «<b>اللَّهُمَّ، انفعني بما علَّمْتَني، وعلِّمني ما ينفعني، وزِدْني عِلْمًا، والحمدُ لله على كل حال</b>»{15}. (١٠/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنّه كان يدعو: اللَّهُمَّ، زِدني إيمانًا، وفِقْهًا، ويقينًا، وعِلْمًا{16}. (١٠/٢٤٧)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٣.|2:تفسير يحيى بن سلّام ١/٢٨٢.|3:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مِن قَبْلِ أن يُقْضى إلَيْكَ وحْيُهُ﴾</span> بالياء مضمومة في <span class="qpc-hafs">﴿يقضى﴾</span> ورفع <span class="qpc-hafs">﴿وحيه﴾</span>. انظر: النشر ٢/٣٢٢، والإتحاف ص٣٨٩.|4:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/١٨٩ (٢٨٠٦٤)، وأبو داود في المراسيل ١/٢٢١ مختصرًا، وابن جرير ٦/٦٨٨، وابن المنذر ٢/٦٨٥، وابن أبي حاتم ٣/٩٤٠، كلهم عن الحسن البصري مرسلًا. وعزاه السيوطي إلى الفريابي، وابن مردويه.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:أخرجه ابن جرير ١٦/١٨٠. وعزاه السيوطي إلى ابن مردويه.|7:أخرجه ابن جرير ١٦/١٨٠. وعلَّقه يحيى بن سلّام ١/٢٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|8:تفسير الثعلبي ٦/٢٦٢، وتفسير البغوي ٥/٢٩٧.|9:علَّقه يحيى بن سلّام ١/٢٨٣.|10:أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٨١، ويحيى بن سلّام ١/٢٨٢ من طريق سعيد بلفظ: بيانه. وعزاه السيوطي إلى عبد بن حميد.|11:علقه يحيى بن سلّام ١/٢٨٣.|12:تفسير مقاتل بن سليمان ٣/٤٣.|13:تفسير يحيى بن سلّام ١/٢٨٣.|14:تفسير مقاتل بن سليمان ٣/٤٣.|15:أخرجه الترمذي ٦/١٩٠-١٩١ (٣٩١٦)، وابن ماجه ١/١٦٨-١٦٩ (٢٥١)، ٥/٩ (٣٨٣٣).</p><p>قال الترمذي: «هذا حديث غريب مِن هذا الوجه». وقال البغوي في شرح السنة ٥/١٧٣ (١٣٧٢): «هذا حديث غريب». وقال المناوي في فيض القدير ٢/١٣٤ (١٥٠٦): «وفيه موسى بن عبيدة، عن محمد بن ثابت، عن الزهري، وموسى ضعّفه النسائيُّ وغيرُه، ومحمد بن ثابت لم يروه عنه غير موسى، قال الذهبي: مجهول». وقال ابن حجر في بلوغ المرام ٢/٢٣١ (١٥٦٦): «وإسناده حسن». وقال الألباني في الضعيفة ٧/٤٢٩: «وهذا إسناد ضعيف؛ موسى بن عُبيدة ضعّفه الجمهور».|16:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.
  20,115,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ عَهِدۡنَاۤ إِلَىٰۤ ءَادَمَ مِن قَبۡلُ فَنَسِیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قال: إنّما سمي: الإنسان؛ لأنّه عُهِد إليه فنسي{1}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم﴾</span> قال: ألا يقرب الشجرة، <span class="qpc-hafs">﴿فنسي﴾</span> فترك عهدي{2}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فنسي﴾</span>، قال: فترك{3}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله تعالى: <span class="qpc-hafs">﴿فنسي﴾</span>، قال: تَرَك أمرَ الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فنسي﴾</span>، قال: ترك ما قَدمَ إليه، ولو كان منه نسيانٌ ما كان عليه شيء؛ لأنّ الله قد وضع عن المؤمنين النسيان والخطأ، ولكن آدم ترك ما قَدمَ إليه مِن أكل الشجرة{5}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٤<span class="dash">-</span></span> عن ابن أبي عمر، قال: حدثنا سفيان [بن عيينة]، عن هشام أو غيره، عن <span class="name-2">الحسن [البصري]</span>، قال: حَلَف الحسنُ ما مال إليها أحد -يعني: الدنيا-؛ أصحابُ النبيِّ ﷺ فمَن سواهـ[ـم] إلا سقطوا، ونسوا العهد. ثم قرأ سفيان: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل﴾</span> محمد ﷺ ألّا يأكلَ مِن الشجرة، <span class="qpc-hafs">﴿فنسي﴾</span> يقول: فترك آدمُ العهد. كقوله: <span class="qpc-hafs">﴿وإله موسى فنسي﴾</span> [طه:٨٨]، يقول: ترك، وكقوله سبحانه: <span class="qpc-hafs">﴿إنا نسيناكم﴾</span> [السجدة:١٤]، يقول: تركناكم، وكقوله: <span class="qpc-hafs">﴿فنسوا حظا﴾</span> [المائدة:١٤]، يعني: تركوا. فلمّا نسِي العهدَ سُمي: الإنسان، فأكل منها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي ولم نجد له عزما﴾</span>، قال: قال له: <span class="qpc-hafs">﴿يا آدم إن هذا عدو لك ولزوجك فلا يخرجنكما من الجنة فتشقى﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿لا تظمأ فيها ولا تضحى﴾</span>، وقرأ حتى بلغ: <span class="qpc-hafs">﴿وملك لا يبلى﴾</span>، قال: فنسي ما عَهِد إليه في ذلك. قال: وهذا عَهْد الله إليه. قال: ولو كان له عَزْمٌ ما أطاع عَدُوَّه الذي حَسَدَه، وأبى أن يسجد له مَعَ من سجد له؛ إبليس، وعصى اللهَ الذي كَرَّمه وشَرَّفه، وأمر ملائكته فسجدوا له{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولقد عهدنا إلى آدم من قبل فنسي﴾</span>، يعني: فترك العهد. يقول: فترك ما أمر به ألا يأكل من الشجرة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ نَجِدۡ لَهُۥ عَزۡمࣰا ۝١١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، يريد: صبرًا على أكل الشجرة{10}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، يقول: لم نجعل له عزمًا{3}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: حِفْظًا{12}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤١<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة الباهلي</span> -من طريق لقمان بن عامر- قال: لو أنّ أحلام بني آدم جُمِعَتْ منذ يوم خُلِق آدم إلى أن تقوم الساعة، فوُضِعت في كفة، وحلم آدم في كفة؛ لرجح حلمه بأحلامهم، قال الله: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، قال: حِفظًا{13}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٢<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: عزيمة الصَّبْر{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: حِفْظًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مزاحم</span>: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>: صَرِيمة أمره{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لم نجد له صبرًا عما نُهِي عنه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٦<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق ابن إدريس عن أبيه وعمرو بن قيس- <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: حِفْظًا لِما أُمِر به{18}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٧<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: رَأْيًا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: صَبْرًا{20}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، يعني: صَبْرًا عن أكلِها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فنسي ولم نجد له عزما﴾</span>، قال: حِفْظًا{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، قال: العزم: المحافظة على ما أمر اللهُ ﷿، والتَّمَسُّكُ به{23}<span class=comment-ref>٤٣١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٥</span> أفادت الآثار اختلاف المفسرين في معنى: «العزم»؛ <b>فقيل:</b> معناه: الصبر. <b>وقيل:</b> معناه: الحفظ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/١٨٥) <span class="mustanad">مستندًا إلى لغة العرب</span> أنّ كِلا القولين يَصْدُق عليه لفظ «العزم»، فقال مبيِّنًا ذلك: «وأصل العزم: اعتقاد القلب على الشيء، يُقال مِنه: عزم فلانٌ على كذا: إذا اعتَقَد عليه ونواه. ومِن اعتقاد القلب: حفظُ الشيء، ومنه: الصبرُ على الشيء؛ لأنه لا يَجْزَع جازعٌ إلا مِن خَوَرِ قلبه وضعفه. فإذ كان ذلك كذلك فلا معنى لذلك أبلغ مما بيَّنه الله -تعالى ذِكْره-، وهو قوله: <span class="qpc-hafs">﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</span>، فيكون تأويله: ولم نجد له عزم قلبٍ على الصبر على الوفاء لله بعهده، ولا على حفظ ما عهد إليه».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/١٣٨) على هذين القولين بقوله: «وعبَّر بعضُ المفسرين عن العزم هنا بالصبر والحفظ وغير ذلك مما هو أعمُّ مِن حقيقة العزم».</div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ نَجِدۡ لَهُۥ عَزۡمࣰا ۝١١٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٥٢<span class="dash">-</span></span> عن ابن عباس أنّه قال <span class="name-1">لعمر بن الخطاب</span>: يا أمير المؤمنين، مِمَّ يَذْكُرُ الرجلُ، ومِمَّ ينسى؟ فقال: إن علا القلبَ طَخاءةٌ كطَخاءةِ القمر{24}، فإذا تَغَشَّتِ القلبَ نسي ابنُ آدم ما كان يذكر، فإذا تَجَلَّت ذكر ما نسي{25}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: سألت عمر بن الخطاب عن قول الله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا لا تسألوا عن أشياء أن تبد لكم تسؤكم﴾</span> [المائدة:١٠١]. قال: كان رجال من المهاجرين في أنسابهم شيء، فقالوا يومًا: واللهِ، لوددنا أنّ الله أنزل قرآنًا في نسبنا. فأنزل الله ما قرأت. ثم قال لي: إن صاحبكم هذا -يعني: علي بن أبي طالب- إن وُلِّيَ زَهِدَ، ولكني أخشى عُجْبَه بنفسه أن يذهب به. قلت: يا أمير المؤمنين، إنّ صاحبنا مَن قد علِمت، واللهِ، ما نقول: إنه غيَّر ولا بدَّل، ولا أسخط رسولَ الله ﷺ أيام صحبته. فقال: ولا في بنت أبي جهل، وهو يريد أن يَخْطُبَها على فاطمة؟! قلت: قال الله في معصية آدم: <span class="qpc-hafs">﴿ولم نجد له عزما﴾</span>، وصاحبنا لم يعزم على إسخاط رسول الله ﷺ، ولكنه الخواطر التي لم يقدر على دفعها عن نفسه، وربما كانت مِن الفقيه في دين الله العالم بأمر الله، فإذا نُبِّه عليها رجع وأناب. فقال: يا ابن عباس، مَن ظن أنه يَرِدُ بحورَكم فيغوص فيها حتى يبلغ قَعْرَها فقد ظن عجزًا{26}. (١٠/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك بن مُزاحِم- قال: لا تأكلوا بشمائلكم، ولا تشربوا بشمائلكم؛ فإنّ آدم أكل بشماله فنسي، فأورثه ذلك النسيان{27}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٥<span class="dash">-</span></span> عن <span class="name-2">عُبيد بن عُمير</span>، قال: لم يكن آدمُ مِن أُولِي العَزْم{5}. (١٠/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام بن حسان- قال: كان عقل آدم مثل عقل جميع ولده، قال الله: <span class="qpc-hafs">﴿فنسي ولم نجد له عزما﴾</span>{29}. (١٠/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب</span>، قال: لو وُزِن حِلْمُ آدم بحِلْمِ العالمين لَوَزَنَه{30}. (١٠/٢٤٩)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٨٣، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣١٣-، والطبراني في الصغير ٢/٥٥، وابن منده في التوحيد ١/٢١٠، وفي الرد على الجهمية (١٨)، والحاكم ٢/٣٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:عزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.|3:أخرجه ابن جرير ١٦/١٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٨٢.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:أخرجه إسحاق البستي في تفسيره ص٢٧٨.|7:تفسير مقاتل بن سليمان ٣/٤٣.|8:أخرجه ابن جرير ١٦/١٨٢.|9:تفسير يحيى بن سلّام ١/٢٨٣.|10:أخرجه ابن منده في الرد على الجهمية (٢١) من طريق عبد الغني بن سعيد. وعزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.|11:أخرجه ابن جرير ١٦/١٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|12:أخرجه ابن جرير ١٦/١٨٤، وابن منده في الرد على الجهمية (٢٠).|13:أخرجه ابن جرير ١٦/١٨٥، وابن عساكر ٧/٤٤٤. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|14:أخرجه ابن عساكر في تاريخ دمشق ٧/٤٠٠-٤٠١.|15:أخرجه إسحاق البستي في تفسيره ص٢٧٩.|16:كذا في طبعتي تفسير الثعلبي ٦/٢٦٣، ١٨/٦٨، وفي تفسير القرطبي ١١/٢٥٢: عزيمة أمر.|17:تفسير البغوي ٥/٢٩٧.|18:أخرجه ابن جرير ١٦/١٨٣ من طرق. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|19:تفسير الثعلبي ٦/٢٦٣.|20:أخرجه يحيى بن سلّام ١/٢٨٣، وابن جرير ١٦/١٨٣ من طرق. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|21:تفسير مقاتل بن سليمان ٣/٤٣.|22:أخرجه الثوري في تفسيره ص١٩٧.|23:أخرجه ابن جرير ١٦/١٨٤.|24:طَخاءة القمر: هي كلُّ قطعةٍ مستدِيرةٍ تَسُدُّ ضوءَ القمر وتُغَطِّي نُورَهُ. اللسان (طخا).|25:أخرجه الحكيم الترمذي في نوادر الأصول ١/١٦٩.|26:عزاه السيوطي إلى الزبير بن بكار في الموفقيات.|27:أخرجه ابن أبي شيبة ٨/١٠٤.|28:عزاه السيوطي إلى ابن أبي حاتم.|29:أخرجه أبو الشيخ في العظمة (١٠٣٢).|30:عزاه السيوطي إلى ابن المنذر.
  20,116,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قُلۡنَا لِلۡمَلَـٰۤىِٕكَةِ ٱسۡجُدُوا۟ لِـَٔادَمَ فَسَجَدُوۤا۟ إِلَّاۤ إِبۡلِیسَ أَبَىٰ ۝١١٦ فَقُلۡنَا یَـٰۤـَٔادَمُ إِنَّ هَـٰذَا عَدُوࣱّ لَّكَ وَلِزَوۡجِكَ فَلَا یُخۡرِجَنَّكُمَا مِنَ ٱلۡجَنَّةِ فَتَشۡقَىٰۤ ۝١١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك- في قوله: <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span>، قال: طَلَبُ المَعاشِ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر بن أبي المغيرة- قال: إنّ آدم ﵇ لَمّا أُهْبِط إلى الأرض استقبله ثَوْرٌ أبْلَق، فقيل له: اعمل عليه. فجعل يمسح العرق عن جبينه، ويقول: هذا ما وعدني ربي: <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span>. ثم نادى حواء: حواء، أنتِ عملتِ بي هذا. فليس أحدٌ مِن بني آدم يعمل على ثورٍ إلا قال: حو. دخلت عليهم مِن قِبَل آدم ﵇{2}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عُمارة بن القَعْقاع- في قوله: <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span>، قال: عَنى به شقاء الدنيا، فلا تلقى ابنَ آدم إلا شقِيًّا ناصِبًا{3}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: الحرث، والزرع، والحصيد، والطَّحن، والخبيز{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذ قلنا﴾</span> يعني: وقد قلنا <span class="qpc-hafs">﴿للملائكة اسجدوا لآدم﴾</span> إذ نفخ فيه الروح، <span class="qpc-hafs">﴿فسجدوا﴾</span>، ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا إبليس﴾</span> لم يسجد فـ<span class="qpc-hafs">﴿أبى﴾</span> أن يسجد، <span class="qpc-hafs">﴿فقلنا يا آدم إن هذا عدو لك ولزوجك﴾</span> حواء؛ <span class="qpc-hafs">﴿فلا يخرجنكما من الجنة فتشقى﴾</span> بالعمل بيديك، وكان يأكل مِن الجنة رغدًا مِن غير أن يعمل بيده، فلما أصاب الخطيئة أكل مِن عمل يده، فكان يعمل ويأكل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span>، قال: لم يقل: فتَشْقَيان. لأنها دخلت معه، فوقع المعنى عليهما جميعًا وعلى أولادهما، كقوله: <span class="qpc-hafs">﴿يا أيها النبي إذا طلقتم﴾</span> [الطلاق:١]، و<span class="qpc-hafs">﴿يا أيها النبي لم تحرم ما أحل الله لك﴾</span> ... <span class="qpc-hafs">﴿قد فرض الله لكم تحلة أيمانكم﴾</span> [التحريم:١-٢]، فدخلوا في المعنى معه، وإنما كلَّم النبيَ ﷺ وحدَه{6}. (١٠/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس أبى﴾</span> أن يسجد، <span class="qpc-hafs">﴿فقلنا يا آدم إن هذا عدو لك ولزوجك فلا يخرجنكما من الجنة فتشقى﴾</span> أي: إنكما إذا عصيتما الله أخرجكما مِن الجنة؛ <span class="qpc-hafs">﴿فتشقى﴾</span> في الدنيا، الكدُّ فيها. وقال بعضهم: تأكل مِن عَمَل يديك، وعَرَقِ جبينك{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٧/٤١٢-٤١٣.|2:أخرجه أبو نعيم في الحلية ٤/٢٨٢، وابن عساكر ٧/٤١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن أبي شيبة ١٣/٥٢٨-٥٢٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:تفسير البغوي ٥/٢٩٨.|5:تفسير مقاتل بن سليمان ٣/٤٣.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:تفسير يحيى بن سلّام ١/٢٨٣-٢٨٤.
  20,117,"20:116"
  20,118,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ لَكَ أَلَّا تَجُوعَ فِیهَا وَلَا تَعۡرَىٰ ۝١١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن لك﴾</span> يا آدم <span class="qpc-hafs">﴿ألا تجوع فيها ولا تعرى﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن لك ألا تجوع فيها﴾</span> في الجنة، <span class="qpc-hafs">﴿ولا تعرى﴾</span> كانا كُسِيا الظُّفُر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤.|2:تفسير يحيى بن سلّام ١/٢٨٤.
  20,119,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَنَّكَ لَا تَظۡمَؤُا۟ فِیهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأنك لا تظمأ فيها﴾</span>، قال: لا يصيبك فيها عَطَشٌ {1}. (١٠/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿لا تظمأ﴾</span> قال: لا تعطش {2}. (١٠/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٦٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيْف- في قوله: <span class="qpc-hafs">﴿لا تظمؤا فيها﴾</span>، قال: لا تَعْطَش{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنك لا تظمأ فيها﴾</span>، يعني: لا تَعْطَش في الجنة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأنك لا تظمأ فيها﴾</span> لا تعطش فيها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٢<span class="dash">-</span></span> عن <span class="name-3">اليزيدي</span> -من طريق أبي خلاد- قال: المعنى: وإنّ لك أن لا تظمأ{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَضۡحَىٰ ۝١١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> – من طريق علي – في قوله: <span class="qpc-hafs">﴿وَلَا تَضْحَى﴾</span> قال: لا يصيبك فيها حَرٌّ. {7}.(١٠/٢٥١). (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٤<span class="dash">-</span></span> <span class="name-1">عبد الله بن عباس</span> – من طريق عطية العوفي – في قوله: <span class="qpc-hafs">﴿وَلَا تَضْحَى﴾</span> قال: لا يصيبك فيها حَرٌّ ولا أذى.{8}.(١٠/٢٥١). (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: <span class="qpc-hafs">﴿وأنك لا تظمأ فيها ولا تضحى﴾</span>. قال: لا تَعْرَقُ فيها مِن شِدَّة حَرِّ الشمس. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت الشاعر يقول:</p><p>رأت رجلًا أمّا إذا الشمس عارضَت فيَضْحى وأمّا بالعشي فيَخْصَرُ؟{9}{10}. (١٠/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق خُصَيْف- <span class="qpc-hafs">﴿ولا تضحى﴾</span>، قال: لا تُصِيبُك الشمسُ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيْف- في قوله: <span class="qpc-hafs">﴿ولا تضحى﴾</span>، قال: لا تُصِيبُك الشمسُ{12}. (١٠/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تضحى﴾</span>، قال: لا تصيبك الشمس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تضحى﴾</span>، يقول: لا يُصِيبُك حرُّ الشمس، فيؤذيك، فتفرق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا تضحى﴾</span>، يعني: لا يصيبك حرُّ شمسٍ{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه عبد الرزاق ٢/٢٠.|4:تفسير مقاتل بن سليمان ٣/٤٤.|5:تفسير يحيى بن سلّام ١/٢٨٤.|6:أخرجه أبو عمرو الداني في المكتفى ص١٣١ (١٦).|7:أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم|8:أخرجه ابن جرير ١٦/١٨٨. وعزاه السيوطي إلى ابن أبي حاتم|9:فَيَخْصَرُ: خَصِرَ الرجلُ إذا آلمهُ البردُ في أطرافِهِ. اللسان (خصر).|10:أخرجه الطستي -كما في الإتقان ٢/٧١-.|11:أخرجه ابن جرير ١٦/١٨٨.|12:أخرجه عبد الرزاق ٢/٢٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|13:أخرجه ابن جرير ١٦/١٨٨. وعلَّقه يحيى بن سلّام ١/٢٨٤.|14:تفسير مقاتل بن سليمان ٣/٤٤.|15:تفسير يحيى بن سلّام ١/٢٨٤.
  20,120,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَسۡوَسَ إِلَیۡهِ ٱلشَّیۡطَـٰنُ قَالَ یَـٰۤـَٔادَمُ هَلۡ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلۡخُلۡدِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٨١<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>إنّ في الجنة شجرةٌ يسير الراكبُ في ظِلِّها مائةَ عام لا يقطعها، وهي شجرة الخلد</b>»{1}. (١٠/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٨٢<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عمر بن عبد الرحمن بن مُهْرِبٍ- قال: لَمّا أسكن اللهُ آدمَ الجنةَ وزوجتَه، ونهاه عن الشجرة؛ كانت الشجرةُ غصونُها مُتَشَعِّبَةٌ بعضُها على بعض، وكان لها ثمر تأكله الملائكة لخُلْدِهم، وهي الثمرة التي نهى اللهُ آدمَ عنها وزوجته، فلمّا أراد إبليسُ أن يَسْتَزِلَّهما دخل الحيَّة، وكانت الحيَّةُ لها أربعُ قوائم كأنها بُخْتِيَّةٌ{2} مِن أحسن دابَّةٍ خلقها الله، فلما دخلت الحيَّةُ الجنةَ خرج مِن جوفها إبليس، فأخذ مِن الشجرة التي نهى اللهُ آدمَ وزوجتَه عنها، فجاء بها إلى حواء، فقال: انظري إلى هذه الشجرة، ما أطيب ريحها، وأطيب طعمها، وأحسن لونها! فأخذتها حواءُ، فأكلتها، ثم ذهبت بها إلى آدم، فقالت: انظر إلى هذه الشجرة، ما أطيب ريحها، وأطيب طعمها، وأحسن لونها! فأكل منها آدم؛ فبَدَت لهما سوآتهما، فدخل آدمُ في جوف الشجرة، فناداه ربه: أين أنت؟ قال: ها أنا ذا، يا رب. قال: ألا تخرج؟ قال: أستحي منك، يا رب. قال: اهبط إلى الأرض. ثم قال: يا حواء، غَرَرْتِ عبدي؟! فإنّك لا تحملين حَمْلًا إلا كرهًا، فإذا أردت أن تضعي ما في بطنك أشرفتِ على الموتِ مِرارًا. وقال للحيَّة: أنت التي دخل الملعون في جوفك حتى غرَّ عبدي، أنت ملعونة لعنة، تتحول قوائمك في بطنك، ولا يكون لك رِزْقٌ إلا التراب، أنت عدوُّ بني آدم، وهم أعداؤك، أينما لقيتِ أحدًا منهم أخذتِ بعَقِبَيْه، وحيث ما لقيك أحدٌ منهم شَدَخَ رأسَك. قيل لوهب: وهل كانت الملائكة تأكل؟ قال: يفعلُ الله ما يشاء{3}. (١٠/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿قال يا آدم هل أدلك على شجرة الخلد وملك لا يبلى﴾</span>، يقول: هل أدلك على شجرةٍ إن أكلتَ منها كنتَ ملِكًا مثل الله، <span class="qpc-hafs">﴿أو تكونا من الخالدين﴾</span> [الأعراف:٢٠] فلا تموتان أبدًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فوسوس إليه الشيطان﴾</span> يعني: إبليس وحده، فـ<span class="qpc-hafs">﴿قال يا آدم هل أدلك﴾</span> يقول: ألا أدلك <span class="qpc-hafs">﴿على شجرة الخلد﴾</span> مَن أكل منها خَلَدَ في الجنة فلا يموت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿على شجرة الخلد وملك لا يبلى﴾</span> أي: إنك إن أكلت منها خَلَدتَ في الجنة. وهو قوله: <span class="qpc-hafs">﴿ما نهاكما ربكما عن هذه الشجرة إلا أن تكونا ملكين﴾</span> يقول: أي: لكيلا تكونا ملَكين، <span class="qpc-hafs">﴿أو تكونا من الخالدين﴾</span> [الأعراف:٢٠] يقول: إذا أكلتما من الشجرة تَحَوَّلْتُما مَلَكَيْنِ مِن ملائكة الله، أو كنتما مِن الخالدين{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمُلۡكࣲ لَّا یَبۡلَىٰ ۝١٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>على <span class="qpc-hafs">﴿ملك لا يبلى﴾</span> يقول: لا يَفْنى{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمُلۡكࣲ لَّا یَبۡلَىٰ ۝١٢٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٨٧<span class="dash">-</span></span> عن ابن إسحاق، عن بعض أهل العلم: أنّ آدم حين دخل الجنة، ورأى ما فيها مِن الكرامة، وما أعطاه اللهُ منها؛ قال: لو أنّ خُلْدًا كان. فاغتنمها منه الشيطان لَمّا سَمِعها منه، فأتاه مِن قِبَل الخُلْد{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ١٥/٥٣٧ (٩٨٧٠)، ١٦/٣٤ (٩٩٥٠)، والدارمي ٢/٤٣٦ (٢٨٣٩). وأصله عند البخاري ٤/١١٩ (٣٢٥٢)، ومسلم ٤/٢١٧٦ (٢٨٢٨)، كلاهما دون ذكر: شجرة الخلد.|2:البُخْتِية: الأُنثى من الجِمالِ البُخْتِ، وهي جمالٌ طوالُ الأَعْناق. النهاية واللسان (بخت).|3:أخرجه عبد الرزاق ١/٢٢٦-٢٢٧، والحكيم الترمذي في نوادر الأصول ١/٢٠٣-٢٠٤، وابن جرير ١/٥٦١-٥٦٢ مطولًا، وابن أبي حاتم ١/٨٧، ٥/١٤٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|4:أخرجه ابن جرير ١٦/١٨٨. وعلَّقه يحيى بن سلّام في تفسيره ١/٢٨٤ مختصرًا بلفظ: ألا أدلك.|5:تفسير مقاتل بن سليمان ٣/٤٤.|6:تفسير يحيى بن سلّام ١/٢٨٤.|7:تفسير مقاتل بن سليمان ٣/٤٤.|8:أخرجه ابن جرير ١/٥٦٤.
  20,121,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَكَلَا مِنۡهَا فَبَدَتۡ لَهُمَا سَوۡءَ ٰ⁠ تُهُمَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٨٨<span class="dash">-</span></span> عن الحسن، عن أُبَيّ بن كعب، قال: قال رسول الله ﷺ: «<b>إنّ الله خَلَق آدم رجلًا طوالًا كثير شعر الرأس، كأنّه نخلة سَحُوق، فلمّا ذاق الشجرةَ سقط عنه لِباسُه، فأول ما بدا منه عورتُه، فلما نظر إلى عورتِه جعل يَشْتَدُّ في الجنَّة، فأخذتْ شعرَه شجرةٌ، فنازعها، فنادى الرحمن: يا آدم، مِنِّي تَفِرُّ؟! فلمّا سمع كلامَ الرحمن قال: يا ربِّ، لا، ولكن استحياءً، أرأيتَ إن تبتُ ورجعتُ أعائدي إلى الجنة؟ قال: نعم. فذلك قوله:</b> <span class="qpc-hafs">﴿فَتَلَقّى آدَمُ مِن رَبِّهِ كَلِماتٍ فَتابَ عَلَيْهِ﴾</span>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٨٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فبدت لهما سوءاتهما﴾</span> لو أنّ حواء بدأت قبل آدم، فبدت سوآتها عند ذلك؛ لكانت له عظة، ولكن لما أكل آدم بدت لهما سوآتهما{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٠<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق عمرو بن دينار- <span class="qpc-hafs">﴿فبدت لهما سوآتهما﴾</span>، قال: كان عليهما ثوب، يعني: على سوآتهما، لا يُبصِر واحدٌ منهما صاحبَه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: إنّما أراد -يعني: إبليس- بقوله: <span class="qpc-hafs">﴿هل أدلك على شجرة الخلد وملك لا يبلى﴾</span> ليبدي لهما ما توارى عنهما مِن سوآتهما، بهتك لباسهما، وكان قد علم أنّ لهما سوأة لِما كان يقرأ مِن كتب الملائكة، ولم يكن آدمُ يعلمُ ذلك، وكان لباسهما الظُّفُرَ، فأبى آدم أن يأكل منها، فتقدمت حواء، فأكلت، ثم قالت: يا آدم، كُلْ؛ فإنِّي قد أكلتُ فلم يضرَّني. فلمّا أكل آدمُ بدت لهما سوآتهما{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٢<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>، قوله: <span class="qpc-hafs">﴿فأكلا منها﴾</span>: فبدأت حواءُ قبل آدم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأكلا منها فبدت لهما سوءاتهما﴾</span>، يقول: ظهرت لهما عوراتُهما{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَطَفِقَا یَخۡصِفَانِ عَلَیۡهِمَا مِن وَرَقِ ٱلۡجَنَّةِۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٩٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق عُقَيْل بن خالد- أنّه كان يقرأ: (يَخصِّفانِ عَلَيْهِما مِن وَّرَقِ الجَنَّةِ){7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَطَفِقَا یَخۡصِفَانِ عَلَیۡهِمَا مِن وَرَقِ ٱلۡجَنَّةِۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿وطَفِقا يَخْصِفانِ عَلَيْهِما مِن ورَقِ الجَنَّةِ﴾</span>، قال: ينزعان ورقَ التين، فيجعلانه على سوآتهما{8}. (١/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٦<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span>: قوله: <span class="qpc-hafs">﴿وطفقا يخصفان عليهما من ورق الجنة﴾</span>، أي: وجعلا يخصفان عليهما مِن ورق الجنة، يُرَقِّعانه كهيئة الثوب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وطفقا يخصفان عليهما من ورق الجنة﴾</span>، يقول: يُوصِلان عليهما مِن ورق الجنة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وطفقا يخصفان عليهما من ورق الجنة﴾</span>، يقول: أقبلا يُغَطِّيان عليهما بورق التين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وطفقا يخصفان عليهما﴾</span> يقول: وجعلا يخصفان، يقول: يُلْزِقان الورقَ بعضه على بعض <span class="qpc-hafs">﴿من ورق الجنة﴾</span> ورق التين؛ ليستتروا به في الجنة{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَصَىٰۤ ءَادَمُ رَبَّهُۥ فَغَوَىٰ ۝١٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعصى آدم ربه فغوى﴾</span>، يعني: فضَلَّ، وتَوَلّى عن طاعة ربه ﷿{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وعصى آدم ربه فغوى﴾</span>، يعني: المعصية، ولم تبلغ بالمعصية الضلال{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في العقوبات ص٦٩-٧٠ (١٠٢)، ويحيى بن سلّام ١/٢٨٥، وابن جرير ١٠/١١١، وابن أبي حاتم ١/٨٧-٨٨ (٣٨٨)، ٥/١٤٥١-١٤٥٢ (٨٢٩٩)، ٥/١٤٥٣ (٨٣٠٨).</p><p>قال ابن كثير في تفسيره ٥/٣٢١: «وهذا منقطع بين الحسن وأُبَي بن كعب، فلم يسمعه منه، وفي رفعه نظر أيضًا».|2:علَّقه يحيى بن سلّام ١/٢٨٥.|3:أخرجه إسحاق البستي في تفسيره ص٢٨٠.|4:أخرجه ابن جرير ١٦/١٨٩.|5:علَّقه يحيى بن سلّام ١/٢٨٤.|6:تفسير مقاتل بن سليمان ٣/٤٤.|7:أخرجه عبد الله بن وهب في الجامع - علوم القرآن ٣/٤٩-٥٠ (١٠٢).</p><p>(يَخْصِّفانِ) بإسكان الخاء، أو(يَخِصِّفانِ) بكسر الخاء قراءتان شاذتان، تروى أولاهما عن عبد الله بن بريدة، وثانيهما عن الحسن. انظر: مختصر ابن خالويه ص٩٣.|8:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٣٢١-، وابن عساكر في تاريخه ٧/٤٠٣. وعزاه السيوطي إلى سفيان بن عيينة، وعبد الرزاق، وابن المنذر.|9:علَّقه يحيى بن سلّام ١/٢٨٥.|10:أخرجه ابن جرير ١٦/١٩٠.|11:أخرجه ابن جرير ١٦/١٩٠.|12:تفسير مقاتل بن سليمان ٣/٤٤.|13:تفسير مقاتل بن سليمان ٣/٤٤.|14:تفسير يحيى بن سلّام ١/٢٨٥.
  20,122,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱجۡتَبَـٰهُ رَبُّهُۥ فَتَابَ عَلَیۡهِ وَهَدَىٰ ۝١٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم اجتباه ربه﴾</span> يعني: استخلصه ربُّه ﷿، <span class="qpc-hafs">﴿فتاب عليه﴾</span> مِن ذنبه، <span class="qpc-hafs">﴿وهدى﴾</span> يعني: وهداه للتوبة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ثم اجتباه ربه﴾</span>، وهو قوله: <span class="qpc-hafs">﴿فتلقى آدم من ربه كلمات﴾</span> [البقرة:٣٧]، فقالا: <span class="qpc-hafs">﴿ربنا ظلمنا أنفسنا وإن لم تغفر لنا وترحمنا لنكونن من الخاسرين﴾</span> [الأعراف:٢٣]، قال: <span class="qpc-hafs">﴿فتاب عليه﴾</span> مِن ذلك الذنب، <span class="qpc-hafs">﴿وهدى﴾</span> مات على الهُدى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤.|2:تفسير يحيى بن سلّام ١/٢٨٥.
  20,123,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ٱهۡبِطَا مِنۡهَا جَمِیعَۢاۖ بَعۡضُكُمۡ لِبَعۡضٍ عَدُوࣱّۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال اهبطا منها جميعا﴾</span> يعني: آدم وإبليس، <span class="qpc-hafs">﴿بعضكم لبعض عدو﴾</span> يقول: إبليس وذُرِّيَّتُه عَدُوٌّ لآدم وذُرِّيَّتِه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِمَّا یَأۡتِیَنَّكُم مِّنِّی هُدࣰى فَمَنِ ٱتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَلَا یَشۡقَىٰ ۝١٢٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٠٥<span class="dash">-</span></span> عن أبي الطُّفَيل: أنّ النبي ﷺ قرأ: <span class="qpc-hafs">﴿فَمَنِ اتَّبَعَ هُدايَ﴾</span>{2}. (١٠/٢٥٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِمَّا یَأۡتِیَنَّكُم مِّنِّی هُدࣰى فَمَنِ ٱتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَلَا یَشۡقَىٰ ۝١٢٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٠٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>مَن اتَّبع كتابَ الله هداه الله مِن الضلالة في الدنيا، ووقاه سوء الحساب يوم القيامة؛ وذلك أنّ الله يقول</b>: <span class="qpc-hafs">﴿فمن اتبع هداي فلا يضل ولا يشقى﴾</span>»{3}. (١٠/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: أجار اللهُ تابعَ القرآن مِن أن يضلَّ في الدنيا، أو يشقى في الآخرة. ثم قرأ: <span class="qpc-hafs">﴿فمن اتبع هداي فلا يضل ولا يشقى﴾</span>. قال: لا يضِلُّ في الدنيا، ولا يشقى في الآخرة{4}. (١٠/٢٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٠٨<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿فمن اتبع هداي﴾</span>، يعني: رسلي، وكتبي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإما﴾</span> يعني: فإن <span class="qpc-hafs">﴿يأتينكم﴾</span> يعني: ذرية آدم <span class="qpc-hafs">﴿مني هدى﴾</span> يعني: رسلًا معهم كتب فيها البيان؛ <span class="qpc-hafs">﴿فمن اتبع هداي﴾</span> يعني: رسلي وكتابي <span class="qpc-hafs">﴿فلا يضل﴾</span> في الدنيا، <span class="qpc-hafs">﴿ولا يشقى﴾</span> في الآخرة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فلا يضل﴾</span> في الدنيا، <span class="qpc-hafs">﴿ولا يشقى﴾</span> في الآخرة{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤. وقد تقدم بيان ذلك عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وقُلْنا اهْبِطُوا بَعْضُكُمْ لِبَعْضٍ عَدُوٌّ﴾</span> [البقرة:٣٦] كما قال يحيى بن سلام ١/٢٨٥: وقد فسرناه في سورة البقرة.|2:عزاه السيوطي إلى الطبراني، وابن مردويه، والخطيب بقراءة <span class="qpc-hafs">﴿فَمَنِ اتَّبَعَ هُدايَ﴾</span>. وأخرجه أبو بكر بن خلاد النصيبي في حديثه ص٥٧ (٥٦)، والخطيب في المتفق والمفترق ١/٥٦١ (٣٠٨) بقراءة (فَمَن تَبِعَ هُدايَ)، من طريق إسماعيل المكي، عن أبي الطفيل به.</p><p>قال ابن أبي حاتم في العلل ٦/٦٣٦-٦٣٧ (٢٨٢٣): «سُئِل أبو زرعة عن حديث أبي الطفيل. فقال: مرسل». وقال الهيثمي في المجمع ٧/٦٧ (١١١٦٩): «رواه الطبراني، وفيه إسماعيل بن مسلم المكي، وهو ضعيف».</p><p>و<span class="qpc-hafs">﴿فَمَنِ اتَّبَعَ هُدايَ﴾</span> قراءة العشرة.|3:أخرجه الطبراني في الأوسط ٥/٣٣٢ (٥٤٦٦).</p><p>قال الهيثمي في المجمع ٧/٦٧ (١١١٦٨): «وفيه أبو شيبة، وعمران بن أبي عمران، وكلاهما ضعيف». وقال المناوي في التيسير ٢/٣٨٦: «وإسناده ضعيف». وقال الألباني في الضعيفة ١٠/٣٣ (٤٥٣١): «ضعيف جدًّا».|4:أخرجه ابن أبي شيبة ١٠/٤٦٧، وابن جرير ١٦/١٩١، والحاكم ٢/٣٨١، والبيهقي في شعب الإيمان (٢٠٢٩) من طُرُق. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وسعيد بن منصور، ومحمد بن نصر، وابن المنذر، وابن أبي حاتم.|5:علقه يحيى بن سلّام ١/٢٨٥.|6:تفسير مقاتل بن سليمان ٣/٤٤.|7:تفسير يحيى بن سلّام ١/٢٨٥.
  20,124,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَنۡ أَعۡرَضَ عَن ذِكۡرِی﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٥١١<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿ومن أعرض عن ذكري﴾</span> نَزَلَتْ في الأسود بن عبد الأسود المخزومي، قتله حمزة بن عبد المطلب يوم بدر على الحوض ...{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَنۡ أَعۡرَضَ عَن ذِكۡرِی﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٥١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن أعرض عن ذكري﴾</span>، يعني: عن إيمان بالقرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومن أعرض عن ذكري﴾</span> فلم يتبع هداي؛ لم يؤمن{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّ لَهُۥ مَعِیشَةࣰ ضَنكࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥١٤<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>المؤمنُ في قبره في روضة خضراء، ويرحب له قبره سبعين ذراعًا، ويضيء حتى يكون كالقمر ليلة البدر، هل تدرون فيما أنزلت</b>: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>؟». قالوا: الله ورسوله أعلم. قال: «<b>عذاب الكافر في قبره؛ يُسَلَّط عليه تسعة وتسعون تِنِّينًا، هل تدرون ما التِّنِّين؟ تسعة وتسعون حيَّة، لكل حيَّة سبعة رؤوس، يخدشونه، ويلسعونه، وينفخون في جسمه إلى يوم يبعثون</b>»{4}. (١٠/٢٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٥<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>، قال: «<b>المعيشة الضنك التي قال الله أنّه يُسَلَّط عليه تسعة وتسعون حيَّة تنهش لحمه حتى تقوم الساعة</b>»{5}. (١٠/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٦<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>، قال: «<b>عذاب القبر</b>»{6}. (١٠/٢٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>... وأَمّا الكافر فيؤتى في قبره مِن قبَلِ رأسه فلا يوجد شيءٌ، فيؤتى مِن قبَلِ رجليه فلا يوجد شيءٌ، فيجلِس خائفًا مرعوبًا، فيقال له: ما تقول في هذا الرجل الذي كان فيكم وما تشهد به؟ فلا يهتدي لاسمِه، فيقال: محمدٌ ﷺ. فيقولُ: سمعتُ الناسَ يقولون شيئًا، فقلتُ كما قالوا. فيُقالُ له: صدَقتَ، على هذا حَييت، وعليه مِتَّ، وعليه تُبعثُ -إن شاء الله-. ويُضَيَّق عليه قبرُه حتى تختلف أضلاعُه، فذلك قوله تعالى</b>: <span class="qpc-hafs">﴿ومنْ أعرَضَ عن ذكري فإنّ لهُ معيشةً ضنكًا﴾</span>»{7}. (٨/٥٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٨<span class="dash">-</span></span> عن أبي سعيد الخدري مرفوعًا، في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: «<b>عذاب القبر</b>»{8}. (١٠/٢٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق القاسم بن عبد الرحمن- في قوله: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>، قال: عذاب القبر{9}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُخارِق بن سليم- قال: إذا حَدَّثتكم بحديث أنبأتُكم بتصديق ذلك مِن كتاب الله؛ إنّ المؤمن إذا وُضِع في قبره أُجْلِس فيه، فيُقال له: مَن ربُّك؟ وما دينك؟ ومَن نبيُّك؟ فيُثَبِّته الله، فيقول: ربي الله، وديني الإسلام، ونبيي محمد ﷺ. فيُوَسَّع له في قبره، ويروح له فيه. ثم قرأ عبد الله: <span class="qpc-hafs">﴿يثبت الله الذين آمنوا بالقول الثابت في الحياة الدنيا وفي الآخرة﴾</span>. فإذا مات الكافرُ أُجْلِس في قبره، فيُقال له: مَن ربُّك؟ وما دينك؟ ومَن نبيُّك؟ فيقول: لا أدري. قال: فيُضَيَّق عليه قبره، ويعذب فيه. ثم قرأ: <span class="qpc-hafs">﴿ومن أعرض عن ذكري فإن له معيشة ضنكا﴾</span>{10}. (٨/٥٢٦، ١٠/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢١<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي سلمة- قال: يُضَيَّق على الكافر قبره حتى تختلف فيه أضلاعه، وهي المعيشة الضنك التي قال الله: <span class="qpc-hafs">﴿معيشة ضنكا ونحشره يوم القيامة أعمى﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: الشَّقاء{12}. (١٠/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: شِدَّة عليه في النار{13}. (١٠/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>. قال: الضَّنك: الشديدُ مِن كل وجه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>والخيلُ قد لحقَت بنا في مأزقٍ ضَنكٍ نواحيه شديد المقْدَمِ؟{14}. (١٠/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿ومن أعرض عن ذكري، فإن له معيشة ضنكا﴾</span>، يقول: كل مال أعطيته عبدًا مِن عبادي قلَّ أو كَثُر لا يُطِيعُني فيه لا خير فيه، وهو الضنك في المعيشة. ويُقال: إنّ قومًا ضُلّالًا أعرضوا عن الحق، وكانوا أولي سَعَة من الدنيا مُكْثِرِين، فكانت معيشتهم ضَنكًا، وذلك أنّهم كانوا يَرَوْن أنّ الله ﷿ ليس بِمُخْلِفٍ لهم معايشهم مِن سوء ظنهم بالله، والتكذيب به، فإذا كان العبدُ يُكَذِّب بالله، ويُسِيءُ الظن به؛ اشْتَدَّت عليه معيشتُه، فذلك الضنك{15}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الثوري، عن رجل، عن سعيد بن جبير- قال: هي بلاء على بلاء{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: يسلبه القناعة حتى لا يشبع{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٨<span class="dash">-</span></span> عن <span class="name-2">قيس بن أبي حازم</span> -من طريق إسماعيل بن أبي خالد- في قول الله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: رِزْقًا في معصيته{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>: ضيقة؛ يُضَيَّق عليه قبره{19}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>، قال: رِزقًا{20}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: ضَيِّقة{13}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: العمل السَّيِّئ، والرِّزق الخبيث{22}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: الضنك مِن المعيشة إذا وسَّع الله على عبده: أن يجعلَ معيشتَه من الحرام، فجعله الله عليه ضيقًا في نار جهنم{23}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سعيد بن عوف- قال: المعيشة الضنك: جهنم{24}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: عذاب القبر{25}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>، قال: الضنك: الضيق، ضنكًا في النار{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: عذاب القبر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٨<span class="dash">-</span></span> عن <span class="name-2">مالك بن دينار</span>، في قوله: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span>، قال: يُحَوِّل اللهُ رزقَه في الحرام، فلا يطعمه إلا حرامًا حتى يموت، فيُعَذِّبه عليه{13}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٣٩<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span>، قال: عذاب القبر{29}. (١٠/٢٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن له معيشة ضنكا﴾</span>، يعني: معيشة سوء؛ لأنّها في معاصي الله ﷿، الضنك والضيق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومن أعرض عن ذكري فإن له معيشة ضنكا﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿ولم يؤمن بآيات ربه﴾</span>، قال: هؤلاء أهل الكفر. قال: <span class="qpc-hafs">﴿معيشة ضنكا﴾</span> في النار؛ شَوْكٌ من نار، وزَقُّوم، وغِسْلِين، والضَّريع شوك من نار، وليس في القبر، ولا في الدنيا معيشة، ما المعيشة والحياة إلا في الآخرة. وقرأ قول الله ﷿: <span class="qpc-hafs">﴿يا ليتني قدمت لحياتي﴾</span> [الفجر:٢٤]، قال: لمعيشتي. قال: والغسلين والزقوم شيء لا يعرفه أهل الدنيا{31}<span class=comment-ref>٤٣١٦</span>. (١٠/٢٥٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٦</span> أفادت الآثار اختلاف المفسرين في موضع المعيشة الضنك على أقوال: <b>الأول:</b> أنّ المعيشة الضنك في الدنيا، وفي صفتها قولان: <b>أولهما</b>: أنها بالكسب الحرام. <b>وثانيهما</b>: أن صاحبها ينفق من ماله على تكذيب منه بالخَلَف من الله، فتشتد لذلك عليه معيشته وتضيق. <b>الثاني:</b> أن المعيشة الضنك في البرزخ، وهي عذاب القبر. <b>الثالث:</b> أن المعيشة الضنك في الآخرة في جهنم، بأن جُعِل طعامهم فيها الضريع والزقوم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/١٩٨-١٩٩) <span class="mustanad">مستندًا إلى السنة والسياق</span> القولَ الثاني، وهو قول أبي سعيد الخدري، وابن مسعود، وأبي هريرة، وأبي صالح، والربيع، والسدي، وعلَّل ذلك بحديث أبي هريرة المرفوع الثالث المتقدم في آثار تفسير الآية، وبـ«أن الله -تبارك وتعالى- أتْبَع ذلك قولَه: <span class="qpc-hafs">﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</span>، فكان معلومًا بذلك أنّ المعيشة الضنك التي جعلها الله لهم قبل عذاب الآخرة».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (١٦/١٩٩) القول الثالث بأن «ذلك لو كان في الآخرة لم يكن لقوله: <span class="qpc-hafs">﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</span> معنًى مفهوم؛ لأنّ ذلك إن لم يكن تقَدَّمه عذابٌ لهم قبل الآخرة، حتى يكون الذي في الآخرة أشدَّ منه؛ بطل معنى قوله: <span class="qpc-hafs">﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</span>». و<span class="comment-type-2">انتقد</span> <span class="mustanad">مستندًا لدلالة العقل</span> القول الأول بأنّ المعيشة الضنك إن «كانت لهم في حياتهم الدنيا فقد يجب أن يكون كل مَن أعْرَض عن ذكر الله مِن الكفار فإنّ معيشته فيها ضنكٌ، وفي وجودنا كثيرًا منهم أوسَع معيشةً من كثيرٍ من المُقْبِلين على ذكر الله -تبارك وتعالى- القابلين له المؤمنين؛ ما يدل على أن ذلك ليس كذلك».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/١٤٢) القول الثاني بقوله: «وحمل هذه الفرقة على هذا التأويل أنّ لفظ الآية يقتضي أن المعيشة الضنك قبل يوم القيامة بقوله: <span class="qpc-hafs">﴿ونَحْشُرُهُ يَوْمَ القِيامَةِ أعْمى﴾</span>، وبقوله تعالى: <span class="qpc-hafs">﴿ولَعَذابُ الآخِرَةِ أشَدُّ وأَبْقى﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿وَنَحۡشُرُهُۥ یَوۡمَ ٱلۡقِیَـٰمَةِ أَعۡمَىٰ ۝١٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٤٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أعمى البصر{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ونحشره يوم القيامة أعمى﴾</span>، قال: عن الحُجَّة{33}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿ونحشره يوم القيامة أعمى﴾</span>، قال: عَمِيَ عليه كلُّ شيء إلا جهنم. وفي لفظ قال: لا يُبصِر إلا النار{34}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿ونحشره يوم القيامة أعمى﴾</span>، قال: ليس له حُجَّة{35}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونحشره يوم القيامة أعمى﴾</span> عن حجته{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ونحشره يوم القيامة أعمى﴾</span> يعني: عن حُجَّته. كقوله: <span class="qpc-hafs">﴿ومن يدع مع الله إلها آخر لا برهان له به﴾</span> [المؤمنون:١١٧] لا حُجَّة له به{37}<span class=comment-ref>٤٣١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٧</span> أفادت الآثارُ اختلافَ المفسرين في صفة العمى في قوله تعالى: <span class="qpc-hafs">﴿ونَحْشُرُهُ يَوْمَ القِيامَةِ أعْمى﴾</span> على قولين: <b>الأول:</b> أنه عمى البصيرة. وهو قول مجاهد، وأبي صالح، ومقاتل، ويحيى بن سلّام. <b>الثاني:</b> أنه عمى البصر. وهو قول ابن عباس، وعكرمة.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> القول الأول بقوله: «والذين قالوا: المراد به العمى عن الحجة إنما مرادهم: أنهم لا حجة لهم، ولم يريدوا أن لهم حجتهم عُمي عنها، بل هم عُمي عن الهدى، كما كانوا في الدنيا، فإنّ العبد يموت على ما عاش عليه، ويبعث على ما مات عليه».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٢٠١) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول معنى الآية، بأن الله «يحشره أعمى عن الحجة، ورؤية الأشياء، كما أخبر -جلَّ ثناؤه-، فعَمَّ ولم يَخْصُصْ».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٦/١٤٢) القول الثاني، فقال: «وهذا هو الأوجه». ولم يذكر مستندًا، ثم <span class="comment-type-1">وجَّه</span> -بناءً على هذا المعنى- قول مَن قال في قوله تعالى: <span class="qpc-hafs">﴿ونَحْشُرُ المُجْرِمِينَ يَوْمَئِذٍ زُرْقًا﴾</span> [طه: ١٠٢]، بأنه في العين قائلًا: «وأما قوله: <span class="qpc-hafs">﴿ونَحْشُرُ المُجْرِمِينَ يَوْمَئِذٍ زُرْقًا﴾</span> فمَن رآه في العين فلا بُدَّ أن يتأوَّلها مع هذا؛ إما أنها في طائفتين، وإما في موطنين».</p><p>وكذا <span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٢/١٩٣) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القولَ الثاني، وعلّل ذلك قائلًا: «فإنّ الكافر يعلم الحق يوم القيامة عيانًا، ويُقِرُّ بما كان يجحده في الدنيا، فليس هو أعمى عن الحق يومئذ».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الأول قائلًا: «ولو كان هذا لم يُحِسَّ الكافر بذلك؛ لأنه مات أعمى البصيرة، ويُحشَر كذلك». ثم <span class="comment-type-4">علَّق</span> على كلا القولين بقوله: «مع أن عمى البصيرة حاصِلٌ في الوجهين».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٤-٤٥.|2:تفسير مقاتل بن سليمان ٣/٤٤-٤٥.|3:تفسير يحيى بن سلّام ١/٢٨٦.|4:أخرجه ابن حبان ٧/٣٩٢-٣٩٣ (٣١٢٢)، وابن أبي حاتم ٧/٢٤٣٩ (١٣٥٦٤)، وابن جرير ١٦/١٩٨-١٩٩ بنحوه.</p><p>قال ابن كثير في تفسيره ٥/٣٢٣: «رفعه مُنكَرٌ جِدًّا».|5:أخرجه البزار ١٦/٢٣٨ (٩٤٠٧)، وابن أبي حاتم ٧/٢٤٣٩ (١٣٥٦٢).</p><p>قال الهيثمي في المجمع ٧/٦٧ (١١١٧٠): «رواه البزار، وفيه مَن لم أعرفه».|6:أخرجه ابن حبان ٧/٣٨٨-٣٨٩ (٣١١٩)، وآدم بن أبي إياس -كما في تفسير مجاهد ص٤٦٧-، وابن أبي حاتم ٧/٢٤٣٩ (١٣٥٦٣)، والثعلبي ٦/٢٦٥.</p><p>قال ابن كثير في تفسيره ٥/٣٢٤: «إسناد جيد».|7:أخرجه ابن حبان ٧/٣٨٠-٣٨٢ (٣١١٣)، والحاكم ١/٥٣٥ (١٤٠٣،١٤٠٤). وتقدم بتمامه مطولًا في تفسير قوله تعالى: <span class="qpc-hafs">﴿يُثَبِّتُ اللَّهُ الَّذِينَ آمَنُوا بِالقَوْلِ الثّابِتِ فِي الحَياةِ الدُّنْيا وفِي الآخِرَةِ﴾</span> [إبراهيم:٢٧].</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الهيثمي في المجمع ٣/٥٢ (٤٢٦٩): «رواه الطبراني في الأوسط، وإسناده حسن».|8:أخرجه الحاكم ٢/٤١٣ (٣٤٣٩)، ويحيى بن سلّام ١/٢٨٦ وزاد: يلتئم على صاحبه حتى تختلف أضلاعه، وعبد الرزاق ٢/٣٧٩ (١٨٤٤) موقوفًا بلفظ: يضيق عليه قبره حتى تختلف أضلاعه، وابن جرير ١٦/١٩٦، ١٩٨ موقوفًا، وابن أبي حاتم ٧/٢٤٤٠ (١٣٥٧٠) بلفظ: «<b>ضمة القبر</b>». وأخرجه إسحاق البستي في تفسيره ص٢٨٢ مرفوعًا بلفظ: «<b>المعيشة الضنك عذاب القبر، يلتهب على صاحبه، فلا يزال يعذب فيه، حتى يبعثه الله</b>».</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/٣٢٣: «الموقوف أصح».|9:أخرجه يحيى بن سلّام ١/٢٨٦، وهناد (٣٥٢)، وابن جرير ١٦/١٩٨، والطبراني (٩١٤٣)، والبيهقي في عذاب القبر (٧٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:أخرجه الطبراني (٩١٤٥)، والبيهقي في كتاب عذاب القبر (٩). وعزاه السيوطي إلى ابن جرير.|11:أخرجه ابن جرير ١٦/١٩٧.|12:أخرجه ابن جرير ١٦/١٩٣، وابن أبي حاتم -كما في التغليق ٤/٢٥٦-. وعزاه السيوطي إلى ابن المنذر.|13:عزاه السيوطي إلى ابن أبي حاتم.|14:أخرجه الطستي -كما في الإتقان ٢/٩٣-.|15:أخرجه ابن جرير ١٦/١٩٥. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.|16:أخرجه الثوري في تفسيره ص١٩٨، ولم ينص على الآية.|17:تفسير الثعلبي ٦/٢٦٥، وتفسير البغوي ٥/٣٠١.|18:أخرجه ابن جرير ١٦/١٩٥.|19:أخرجه إسحاق البستي في تفسيره ص٢٨٠، والبيهقي في عذاب القبر (٧٨) من طريق ابن أبي نَجِيح.|20:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|21:عزاه السيوطي إلى ابن أبي حاتم.|22:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. وأخرجه ابن جرير ١٦/١٩٥ من طريق هارون بن محمد التيمي بلفظ: العمل الخبيث، والرزق السيئ، وفي رواية: الكسب الخبيث.|23:أخرجه ابن جرير ١٦/١٩٥. وعزاه السيوطي إلى ابن أبي حاتم.|24:أخرجه ابن جرير ١٦/١٩٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.|25:أخرجه ابن جرير ١٦/١٩٧، والبيهقي في عذاب القبر (٧٤). وعزاه السيوطي إلى عبد بن حميد.|26:أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٩٣-١٩٤.|27:أخرجه ابن جرير ١٦/١٩٧.|28:عزاه السيوطي إلى ابن أبي حاتم.|29:عزاه السيوطي إلى عبد بن حميد.|30:تفسير مقاتل بن سليمان ٣/٤٤-٤٥.|31:أخرجه ابن جرير ١٦/١٩٤. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.|32:تفسير الثعلبي ٦/٢٦٥، وتفسير البغوي ٥/٣٠١.|33:أخرجه ابن جرير ١٦/٢٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|34:أخرجه هناد (٢٢٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|35:أخرجه عبد الرزاق ٢/٢١، وابن جرير ١٦/٢٠٠. وعزاه السيوطي إلى ابن أبي حاتم.|36:تفسير مقاتل بن سليمان ٣/٤٥.|37:تفسير يحيى بن سلّام ١/٢٨٩.
  20,125,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ لِمَ حَشَرۡتَنِیۤ أَعۡمَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لم حشرتني أعمى﴾</span>، قال: لا حُجَّة لي{1}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٤٩<span class="dash">-</span></span> تفسير <span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٠<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿قال رب لم حشرتني أعمى﴾</span> عن الحُجَّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال رب لم حشرتني أعمى﴾</span> عن حُجَّتي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿لم حشرتني أعمى﴾</span>، قال: عن حُجَّتي{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَدۡ كُنتُ بَصِیرࣰا ۝١٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٥٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وقد كنت بصيرا﴾</span>، قال: في الدنيا{5}. (١٠/٢٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿وقد كنت بصيرا﴾</span>، قال: عالِمًا بحُجَجي{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قوله: <span class="qpc-hafs">﴿قال رب لم حشرتني أعمى وقد كنت بصيرا﴾</span>، قال: كان بعيد البَصَر، قصير النظر، أعمى عن الحق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقد كنت بصيرا﴾</span> في الدنيا عليمًا بها، وهذا مثل قوله سبحانه: <span class="qpc-hafs">﴿هلك عني سلطانيه﴾</span> [الحاقة:٢٩]، يعني: ضلَّت عَنِّي حجتي، وهذا قوله حين شهدت عليه الجوارح بالشرك والكفر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وقد كنت﴾</span> بها <span class="qpc-hafs">﴿بصيرا﴾</span> في الدنيا، قال: كانت لي في الدنيا حُجَّة، وكان لي كلام{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٥٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقد كنت بصيرا﴾</span> في الدنيا، عالِمًا بحُجَّتي في الدنيا، وإنما علمه ذلك عند نفسه في الدنيا، كان يحاجُّ في الدنيا جاحِدًا لِما جاءه مِن الله{10}<span class=comment-ref>٤٣١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٨</span> أفادت الآثارُ اختلافَ المفسرين في معنى: <span class="qpc-hafs">﴿وقَدْ كُنْتُ بَصِيرًا﴾</span>؛ <b>فقيل:</b> وقد كنت بصيرًا بحججي. <b>وقيل:</b> وقد كنت ذا بصرٍ أبصر به الأشياء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٢٠٢) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول معنى الآية، بـ«أن الله -جلَّ ثناؤه- عمَّ بالخبر عنه بوصفِه نفسَه بالبصر، ولم يَخْصُصْ منه معنًى دون معنًى، فذلك على ما عمَّه».</div></p></div>",footnotes:1:أخرجه هناد (٢٢٦)، وابن جرير ١٦/٢٠١، وأخرجه الفريابي -كما في الفتح ٨/٤٣٣، والتغليق ٤/٢٥٤- بلفظ: عن حجتي.|2:علَّقه يحيى بن سلّام ١/٢٩٠.|3:تفسير مقاتل بن سليمان ٣/٤٥.|4:أخرجه إسحاق البستي في تفسيره ص٢٨٣.|5:أخرجه ابن جرير ١٦/٢٠١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:تفسير مجاهد ص٤٦٨، وأخرجه ابن جرير ١٦/٢٠١ من طريق ابن جريج.|7:أخرجه ابن جرير ١٦/٢٠١. وعلَّق يحيى بن سلّام ١/٢٩٠ آخره، وعقَّب عليه بقوله: أي: في الدنيا.|8:تفسير مقاتل بن سليمان ٣/٤٥.|9:أخرجه إسحاق البستي في تفسيره ص٢٨٣.|10:تفسير يحيى بن سلّام ١/٢٩٠.