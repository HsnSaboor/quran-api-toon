tafsir[12]{c,v,t}:
20,114," <q>﴿فَتَعَـٰلَى ٱللَّهُ ٱلۡمَلِكُ ٱلۡحَقُّۗ﴾</q> - تفسير ٤٨٤١٢- قال مقاتل بن سليمان: <q>﴿فتعالى الله﴾</q> يعني: ارتفع الله <q>﴿الملك الحق﴾</q> لأنّ غيرَه ﷿ وما سواه مِن الآلهة باطل{1}. (ز) ٤٨٤١٣- قال يحيى بن سلّام: قوله: <q>﴿فتعالى الله﴾</q> مِن باب العُلُوِّ: ارتفع <q>﴿الملك الحق﴾</q> والحقُّ اسم من أسماء الله{2}. (ز) <q>﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</q> - قراءات ٤٨٤١٤- عن الحسن البصري أنه قرأ: ‹مِن قَبْلِ أن نَّقْضِيَ إلَيْكَ وحْيَهُ›{3}. (١٠/٤٦) <q>﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</q> - نزول الآية ٤٨٤١٥- عن الحسن البصري، قال: لطَم رجلٌ امرأتَه، فجاءتْ إلى النبيِّ ﷺ تطلب قصاصًا، فجعل النبي ﷺ بينهما القصاص؛ فأنزل الله: <q>﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه وقل رب زدني علما﴾</q>. فوقف النبي ﷺ حتى نزلت: <q>﴿الرجال قوامون على النساء﴾</q> الآية [النساء:٣٤]{4}. (١٠/٢٤٥) <q>﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ مِن قَبۡلِ أَن یُقۡضَىٰۤ إِلَیۡكَ وَحۡیُهُۥۖ﴾</q> - تفسير الآية ٤٨٤١٦- عن إسماعيل السُّدِّيّ، قال: كان النبيُّ ﷺ إذا نزل عليه جبريلُ بالقرآن أتْعَبَ نفسَه في حفظه حتى يَشُقَّ على نفسه؛ يتخوف أن يصعد جبريل ولم يحفظه؛ فينسى ما علَّمَه، فقال الله: <q>﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه﴾</q>. وقال: <q>﴿لا تحرك به لسانك لتعجل به﴾</q> [القيامة:١٦]{5}. (١٠/٢٤٥) ٤٨٤١٧- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿ولا تعجل بالقرآن من قبل أن يقضى إليك وحيه﴾</q>، يقول: لا تعجل حتى نُبَيِّنه لك{6}. (١٠/٢٤٥) ٤٨٤١٨- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿ولا تعجل بالقرآن﴾</q>، قال: لا تَتْلُهُ على أحد حتى نُتِمَّه لك{7}. (١٠/٢٤٦) ٤٨٤١٩- قال مجاهد بن جبر= (ز) ٤٨٤٢٠- وقتادة بن دِعامة: معناه: لا تُقْرِئه أصحابَك، ولا تُمْلِه عليهم حتى يتبين لك معانيه{8}. (ز) ٤٨٤٢١- قال الحسن البصري: فرائضه، وحدوده، وأحكامه، وحلاله، وحرامه{9}. (ز) ٤٨٤٢٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿من قبل أن يقضى إليك وحيه﴾</q>، قال: تِبيانه{10}. (١٠/٢٤٦) ٤٨٤٢٣- قال إسماعيل السُّدِّيّ: <q>﴿من قبل أن يقضى إليك وحيه﴾</q>، يعني: لا تعجل بالقرآن مِن قبل أن ينزل إليك جبريلُ بالوحي{11}. (ز) ٤٨٤٢٤- قال مقاتل بن سليمان: <q>﴿ولا تعجل بالقرآن﴾</q> وذلك أنّ جبريل ﵇ كان إذا أخبر النبيَّ ﷺ بالوحى لم يفرغ جبريل ﵇ من آخر الكلامِ حتى يتكلم النبيُّ ﷺ بأوله؛ فقال الله ﷿: <q>﴿ولا تعجل﴾</q> بقراءة القرآن <q>﴿من قبل أن يقضى إليك وحيه﴾</q> يقول: مِن قبل أن يُتِمَّه لك جبريل ﵇{1}. (ز) ٤٨٤٢٥- قال يحيى بن سلّام: كان النبيُّ ﵇ إذا نزل عليه الوحي يقرأه، ويُدْئِبُ فيه نفسَه مخافةَ أن ينسى؛ فأنزل الله: <q>﴿لا تحرك به لسانك لتعجل به﴾</q> [القيامة:١٦] نحن نحفظه عليك فلا تنسى. قال الله: <q>﴿إلا ما شاء الله﴾</q>، وهو قوله: <q>﴿سنقرئك فلا تنسى (٦) إلا ما شاء الله﴾</q> [الأعلى:٦-٧]، وهو قوله: <q>﴿ما ننسخ من آية أو ننسها﴾</q> [البقرة:١٠٦] يُنسِها نبيَّه. قال: <q>﴿فإذا قرأناه فاتبع قرءانه﴾</q> [القيامة:١٨] فرائضه، وحدوده، والعمل به{13}. (ز) <q>﴿وَقُل رَّبِّ زِدۡنِی عِلۡمࣰا ۝١١٤﴾</q> - تفسير ٤٨٤٢٦- قال مقاتل بن سليمان: <q>﴿وقل رب زدني علما﴾</q>، يعني: قرآنًا{1}. (ز) <q>﴿وَقُل رَّبِّ زِدۡنِی عِلۡمࣰا ۝١١٤﴾</q> - آثار متعلقة بالآية ٤٨٤٢٧- عن أبي هريرة، قال: كان رسولُ الله ﷺ يقول: «اللَّهُمَّ، انفعني بما علَّمْتَني، وعلِّمني ما ينفعني، وزِدْني عِلْمًا، والحمدُ لله على كل حال»{15}. (١٠/٢٤٦) ٤٨٤٢٨- عن عبد الله بن مسعود أنّه كان يدعو: اللَّهُمَّ، زِدني إيمانًا، وفِقْهًا، ويقينًا، وعِلْمًا{16}. (١٠/٢٤٧) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٣.تفسير يحيى بن سلّام ١/٢٨٢.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد. وهي قراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <q>﴿مِن قَبْلِ أن يُقْضى إلَيْكَ وحْيُهُ﴾</q> بالياء مضمومة في <q>﴿يقضى﴾</q> ورفع <q>﴿وحيه﴾</q>. انظر: النشر ٢/٣٢٢، والإتحاف ص٣٨٩.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/١٨٩ (٢٨٠٦٤)، وأبو داود في المراسيل ١/٢٢١ مختصرًا، وابن جرير ٦/٦٨٨، وابن المنذر ٢/٦٨٥، وابن أبي حاتم ٣/٩٤٠، كلهم عن الحسن البصري مرسلًا. وعزاه السيوطي إلى الفريابي، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/١٨٠. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٦/١٨٠. وعلَّقه يحيى بن سلّام ١/٢٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٢٦٢، وتفسير البغوي ٥/٢٩٧.علَّقه يحيى بن سلّام ١/٢٨٣.أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٨١، ويحيى بن سلّام ١/٢٨٢ من طريق سعيد بلفظ: بيانه. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلّام ١/٢٨٣.تفسير مقاتل بن سليمان ٣/٤٣.تفسير يحيى بن سلّام ١/٢٨٣.تفسير مقاتل بن سليمان ٣/٤٣.أخرجه الترمذي ٦/١٩٠-١٩١ (٣٩١٦)، وابن ماجه ١/١٦٨-١٦٩ (٢٥١)، ٥/٩ (٣٨٣٣). قال الترمذي: «هذا حديث غريب مِن هذا الوجه». وقال البغوي في شرح السنة ٥/١٧٣ (١٣٧٢): «هذا حديث غريب». وقال المناوي في فيض القدير ٢/١٣٤ (١٥٠٦): «وفيه موسى بن عبيدة، عن محمد بن ثابت، عن الزهري، وموسى ضعّفه النسائيُّ وغيرُه، ومحمد بن ثابت لم يروه عنه غير موسى، قال الذهبي: مجهول». وقال ابن حجر في بلوغ المرام ٢/٢٣١ (١٥٦٦): «وإسناده حسن». وقال الألباني في الضعيفة ٧/٤٢٩: «وهذا إسناد ضعيف؛ موسى بن عُبيدة ضعّفه الجمهور».عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.
20,115," <q>﴿وَلَقَدۡ عَهِدۡنَاۤ إِلَىٰۤ ءَادَمَ مِن قَبۡلُ فَنَسِیَ﴾</q> - تفسير ٤٨٤٢٩- عن عبد الله بن عباس -من طريق عطية العوفي- قال: إنّما سمي: الإنسان؛ لأنّه عُهِد إليه فنسي{1}. (١٠/٢٤٧) ٤٨٤٣٠- عن عبد الله بن عباس، <q>﴿ولقد عهدنا إلى آدم﴾</q> قال: ألا يقرب الشجرة، <q>﴿فنسي﴾</q> فترك عهدي{2}. (١٠/٢٤٧) ٤٨٤٣١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فنسي﴾</q>، قال: فترك{3}. (١٠/٢٤٨) ٤٨٤٣٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله تعالى: <q>﴿فنسي﴾</q>، قال: تَرَك أمرَ الله{4}. (ز) ٤٨٤٣٣- عن الحسن البصري، في قوله: <q>﴿فنسي﴾</q>، قال: ترك ما قَدمَ إليه، ولو كان منه نسيانٌ ما كان عليه شيء؛ لأنّ الله قد وضع عن المؤمنين النسيان والخطأ، ولكن آدم ترك ما قَدمَ إليه مِن أكل الشجرة{5}. (١٠/٢٥٠) ٤٨٤٣٤- عن ابن أبي عمر، قال: حدثنا سفيان [بن عيينة]، عن هشام أو غيره، عن الحسن [البصري]، قال: حَلَف الحسنُ ما مال إليها أحد -يعني: الدنيا-؛ أصحابُ النبيِّ ﷺ فمَن سواهـ[ـم] إلا سقطوا، ونسوا العهد. ثم قرأ سفيان: <q>﴿ولقد عهدنا إلى آدم من قبل فنسي﴾</q>{6}. (ز) ٤٨٤٣٥- قال مقاتل بن سليمان: <q>﴿ولقد عهدنا إلى آدم من قبل﴾</q> محمد ﷺ ألّا يأكلَ مِن الشجرة، <q>﴿فنسي﴾</q> يقول: فترك آدمُ العهد. كقوله: <q>﴿وإله موسى فنسي﴾</q> [طه:٨٨]، يقول: ترك، وكقوله سبحانه: <q>﴿إنا نسيناكم﴾</q> [السجدة:١٤]، يقول: تركناكم، وكقوله: <q>﴿فنسوا حظا﴾</q> [المائدة:١٤]، يعني: تركوا. فلمّا نسِي العهدَ سُمي: الإنسان، فأكل منها{7}. (ز) ٤٨٤٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولقد عهدنا إلى آدم من قبل فنسي ولم نجد له عزما﴾</q>، قال: قال له: <q>﴿يا آدم إن هذا عدو لك ولزوجك فلا يخرجنكما من الجنة فتشقى﴾</q> فقرأ حتى بلغ: <q>﴿لا تظمأ فيها ولا تضحى﴾</q>، وقرأ حتى بلغ: <q>﴿وملك لا يبلى﴾</q>، قال: فنسي ما عَهِد إليه في ذلك. قال: وهذا عَهْد الله إليه. قال: ولو كان له عَزْمٌ ما أطاع عَدُوَّه الذي حَسَدَه، وأبى أن يسجد له مَعَ من سجد له؛ إبليس، وعصى اللهَ الذي كَرَّمه وشَرَّفه، وأمر ملائكته فسجدوا له{8}. (ز) ٤٨٤٣٧- قال يحيى بن سلّام: قوله: <q>﴿ولقد عهدنا إلى آدم من قبل فنسي﴾</q>، يعني: فترك العهد. يقول: فترك ما أمر به ألا يأكل من الشجرة{9}. (ز) <q>﴿وَلَمۡ نَجِدۡ لَهُۥ عَزۡمࣰا ۝١١٥﴾</q> - تفسير ٤٨٤٣٨- عن عبد الله بن عباس: <q>﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</q>، يريد: صبرًا على أكل الشجرة{10}. (١٠/٢٤٧) ٤٨٤٣٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</q>، يقول: لم نجعل له عزمًا{3}. (١٠/٢٤٨) ٤٨٤٤٠- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ولم نجد له عزما﴾</q>، قال: حِفْظًا{12}. (١٠/٢٤٨) ٤٨٤٤١- عن أبي أُمامة الباهلي -من طريق لقمان بن عامر- قال: لو أنّ أحلام بني آدم جُمِعَتْ منذ يوم خُلِق آدم إلى أن تقوم الساعة، فوُضِعت في كفة، وحلم آدم في كفة؛ لرجح حلمه بأحلامهم، قال الله: <q>﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</q>، قال: حِفظًا{13}. (١٠/٢٤٠) ٤٨٤٤٢- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- في قوله: <q>﴿ولم نجد له عزما﴾</q>، قال: عزيمة الصَّبْر{14}. (ز) ٤٨٤٤٣- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿ولم نجد له عزما﴾</q>، قال: حِفْظًا{15}. (ز) ٤٨٤٤٤- قال الضَّحّاك بن مزاحم: <q>﴿ولم نجد له عزما﴾</q>: صَرِيمة أمره{16}. (ز) ٤٨٤٤٥- قال الحسن البصري: لم نجد له صبرًا عما نُهِي عنه{17}. (ز) ٤٨٤٤٦- عن عطية العوفي -من طريق ابن إدريس عن أبيه وعمرو بن قيس- <q>﴿ولم نجد له عزما﴾</q>، قال: حِفْظًا لِما أُمِر به{18}. (١٠/٢٤٩) ٤٨٤٤٧- عن عطية العوفي، <q>﴿ولم نجد له عزما﴾</q>، قال: رَأْيًا{19}. (ز) ٤٨٤٤٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولم نجد له عزما﴾</q>، قال: صَبْرًا{20}. (١٠/٢٤٩) ٤٨٤٤٩- قال مقاتل بن سليمان: <q>﴿ولم نجد له عزما﴾</q>، يعني: صَبْرًا عن أكلِها{7}. (ز) ٤٨٤٥٠- عن سفيان الثوري، في قوله: <q>﴿فنسي ولم نجد له عزما﴾</q>، قال: حِفْظًا{22}. (ز) ٤٨٤٥١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولم نجد له عزما﴾</q>، قال: العزم: المحافظة على ما أمر اللهُ ﷿، والتَّمَسُّكُ به{23}٤٣١٥. (ز) ٤٣١٥ أفادت الآثار اختلاف المفسرين في معنى: «العزم»؛ فقيل: معناه: الصبر. وقيل: معناه: الحفظ. ورجَّح ابنُ جرير (١٦/١٨٥) مستندًا إلى لغة العرب أنّ كِلا القولين يَصْدُق عليه لفظ «العزم»، فقال مبيِّنًا ذلك: «وأصل العزم: اعتقاد القلب على الشيء، يُقال مِنه: عزم فلانٌ على كذا: إذا اعتَقَد عليه ونواه. ومِن اعتقاد القلب: حفظُ الشيء، ومنه: الصبرُ على الشيء؛ لأنه لا يَجْزَع جازعٌ إلا مِن خَوَرِ قلبه وضعفه. فإذ كان ذلك كذلك فلا معنى لذلك أبلغ مما بيَّنه الله -تعالى ذِكْره-، وهو قوله: <q>﴿ولَمْ نَجِدْ لَهُ عَزْمًا﴾</q>، فيكون تأويله: ولم نجد له عزم قلبٍ على الصبر على الوفاء لله بعهده، ولا على حفظ ما عهد إليه». وعلَّق ابنُ عطية (٦/١٣٨) على هذين القولين بقوله: «وعبَّر بعضُ المفسرين عن العزم هنا بالصبر والحفظ وغير ذلك مما هو أعمُّ مِن حقيقة العزم». <q>﴿وَلَمۡ نَجِدۡ لَهُۥ عَزۡمࣰا ۝١١٥﴾</q> - آثار متعلقة بالآية ٤٨٤٥٢- عن ابن عباس أنّه قال لعمر بن الخطاب: يا أمير المؤمنين، مِمَّ يَذْكُرُ الرجلُ، ومِمَّ ينسى؟ فقال: إن علا القلبَ طَخاءةٌ كطَخاءةِ القمر{24}، فإذا تَغَشَّتِ القلبَ نسي ابنُ آدم ما كان يذكر، فإذا تَجَلَّت ذكر ما نسي{25}. (١٠/٢٤٩) ٤٨٤٥٣- عن عبد الله بن عباس، قال: سألت عمر بن الخطاب عن قول الله: <q>﴿يا أيها الذين آمنوا لا تسألوا عن أشياء أن تبد لكم تسؤكم﴾</q> [المائدة:١٠١]. قال: كان رجال من المهاجرين في أنسابهم شيء، فقالوا يومًا: واللهِ، لوددنا أنّ الله أنزل قرآنًا في نسبنا. فأنزل الله ما قرأت. ثم قال لي: إن صاحبكم هذا -يعني: علي بن أبي طالب- إن وُلِّيَ زَهِدَ، ولكني أخشى عُجْبَه بنفسه أن يذهب به. قلت: يا أمير المؤمنين، إنّ صاحبنا مَن قد علِمت، واللهِ، ما نقول: إنه غيَّر ولا بدَّل، ولا أسخط رسولَ الله ﷺ أيام صحبته. فقال: ولا في بنت أبي جهل، وهو يريد أن يَخْطُبَها على فاطمة؟! قلت: قال الله في معصية آدم: <q>﴿ولم نجد له عزما﴾</q>، وصاحبنا لم يعزم على إسخاط رسول الله ﷺ، ولكنه الخواطر التي لم يقدر على دفعها عن نفسه، وربما كانت مِن الفقيه في دين الله العالم بأمر الله، فإذا نُبِّه عليها رجع وأناب. فقال: يا ابن عباس، مَن ظن أنه يَرِدُ بحورَكم فيغوص فيها حتى يبلغ قَعْرَها فقد ظن عجزًا{26}. (١٠/٢٤٨) ٤٨٤٥٤- عن عبد الله بن عباس -من طريق الضَّحّاك بن مُزاحِم- قال: لا تأكلوا بشمائلكم، ولا تشربوا بشمائلكم؛ فإنّ آدم أكل بشماله فنسي، فأورثه ذلك النسيان{27}. (١٠/٢٤٩) ٤٨٤٥٥- عن عُبيد بن عُمير، قال: لم يكن آدمُ مِن أُولِي العَزْم{5}. (١٠/٢٤٩) ٤٨٤٥٦- عن الحسن البصري -من طريق هشام بن حسان- قال: كان عقل آدم مثل عقل جميع ولده، قال الله: <q>﴿فنسي ولم نجد له عزما﴾</q>{29}. (١٠/٢٤٧) ٤٨٤٥٧- عن محمد بن كعب، قال: لو وُزِن حِلْمُ آدم بحِلْمِ العالمين لَوَزَنَه{30}. (١٠/٢٤٩) ",footnotes:1:أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٨٣، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣١٣-، والطبراني في الصغير ٢/٥٥، وابن منده في التوحيد ١/٢١٠، وفي الرد على الجهمية (١٨)، والحاكم ٢/٣٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.أخرجه ابن جرير ١٦/١٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٠، وابن جرير ١٦/١٨٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٧٨.تفسير مقاتل بن سليمان ٣/٤٣.أخرجه ابن جرير ١٦/١٨٢.تفسير يحيى بن سلّام ١/٢٨٣.أخرجه ابن منده في الرد على الجهمية (٢١) من طريق عبد الغني بن سعيد. وعزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.أخرجه ابن جرير ١٦/١٨٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٨٤، وابن منده في الرد على الجهمية (٢٠).أخرجه ابن جرير ١٦/١٨٥، وابن عساكر ٧/٤٤٤. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن عساكر في تاريخ دمشق ٧/٤٠٠-٤٠١.أخرجه إسحاق البستي في تفسيره ص٢٧٩.كذا في طبعتي تفسير الثعلبي ٦/٢٦٣، ١٨/٦٨، وفي تفسير القرطبي ١١/٢٥٢: عزيمة أمر.تفسير البغوي ٥/٢٩٧.أخرجه ابن جرير ١٦/١٨٣ من طرق. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٦/٢٦٣.أخرجه يحيى بن سلّام ١/٢٨٣، وابن جرير ١٦/١٨٣ من طرق. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣.أخرجه الثوري في تفسيره ص١٩٧.أخرجه ابن جرير ١٦/١٨٤.طَخاءة القمر: هي كلُّ قطعةٍ مستدِيرةٍ تَسُدُّ ضوءَ القمر وتُغَطِّي نُورَهُ. اللسان (طخا).أخرجه الحكيم الترمذي في نوادر الأصول ١/١٦٩.عزاه السيوطي إلى الزبير بن بكار في الموفقيات.أخرجه ابن أبي شيبة ٨/١٠٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو الشيخ في العظمة (١٠٣٢).عزاه السيوطي إلى ابن المنذر.
20,116," <q>﴿وَإِذۡ قُلۡنَا لِلۡمَلَـٰۤىِٕكَةِ ٱسۡجُدُوا۟ لِـَٔادَمَ فَسَجَدُوۤا۟ إِلَّاۤ إِبۡلِیسَ أَبَىٰ ۝١١٦ فَقُلۡنَا یَـٰۤـَٔادَمُ إِنَّ هَـٰذَا عَدُوࣱّ لَّكَ وَلِزَوۡجِكَ فَلَا یُخۡرِجَنَّكُمَا مِنَ ٱلۡجَنَّةِ فَتَشۡقَىٰۤ ۝١١٧﴾</q> - تفسير ٤٨٤٥٨- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك- في قوله: <q>﴿فلا يخرجنكما من الجنة فتشقى﴾</q>، قال: طَلَبُ المَعاشِ{1}. (ز) ٤٨٤٥٩- عن سعيد بن جبير -من طريق جعفر بن أبي المغيرة- قال: إنّ آدم ﵇ لَمّا أُهْبِط إلى الأرض استقبله ثَوْرٌ أبْلَق، فقيل له: اعمل عليه. فجعل يمسح العرق عن جبينه، ويقول: هذا ما وعدني ربي: <q>﴿فلا يخرجنكما من الجنة فتشقى﴾</q>. ثم نادى حواء: حواء، أنتِ عملتِ بي هذا. فليس أحدٌ مِن بني آدم يعمل على ثورٍ إلا قال: حو. دخلت عليهم مِن قِبَل آدم ﵇{2}. (١٠/٢٥٠) ٤٨٤٦٠- عن الحسن البصري -من طريق عُمارة بن القَعْقاع- في قوله: <q>﴿فلا يخرجنكما من الجنة فتشقى﴾</q>، قال: عَنى به شقاء الدنيا، فلا تلقى ابنَ آدم إلا شقِيًّا ناصِبًا{3}. (١٠/٢٥٠) ٤٨٤٦١- قال إسماعيل السُّدِّيّ: يعني: الحرث، والزرع، والحصيد، والطَّحن، والخبيز{4}. (ز) ٤٨٤٦٢- قال مقاتل بن سليمان: <q>﴿وإذ قلنا﴾</q> يعني: وقد قلنا <q>﴿للملائكة اسجدوا لآدم﴾</q> إذ نفخ فيه الروح، <q>﴿فسجدوا﴾</q>، ثم استثنى، فقال: <q>﴿إلا إبليس﴾</q> لم يسجد فـ<q>﴿أبى﴾</q> أن يسجد، <q>﴿فقلنا يا آدم إن هذا عدو لك ولزوجك﴾</q> حواء؛ <q>﴿فلا يخرجنكما من الجنة فتشقى﴾</q> بالعمل بيديك، وكان يأكل مِن الجنة رغدًا مِن غير أن يعمل بيده، فلما أصاب الخطيئة أكل مِن عمل يده، فكان يعمل ويأكل{5}. (ز) ٤٨٤٦٣- عن سفيان بن عيينة، قال: لم يقل: فتَشْقَيان. لأنها دخلت معه، فوقع المعنى عليهما جميعًا وعلى أولادهما، كقوله: <q>﴿يا أيها النبي إذا طلقتم﴾</q> [الطلاق:١]، و<q>﴿يا أيها النبي لم تحرم ما أحل الله لك﴾</q> ... <q>﴿قد فرض الله لكم تحلة أيمانكم﴾</q> [التحريم:١-٢]، فدخلوا في المعنى معه، وإنما كلَّم النبيَ ﷺ وحدَه{6}. (١٠/٢٥٠) ٤٨٤٦٤- قال يحيى بن سلّام: قوله: <q>﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس أبى﴾</q> أن يسجد، <q>﴿فقلنا يا آدم إن هذا عدو لك ولزوجك فلا يخرجنكما من الجنة فتشقى﴾</q> أي: إنكما إذا عصيتما الله أخرجكما مِن الجنة؛ <q>﴿فتشقى﴾</q> في الدنيا، الكدُّ فيها. وقال بعضهم: تأكل مِن عَمَل يديك، وعَرَقِ جبينك{7}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٧/٤١٢-٤١٣.أخرجه أبو نعيم في الحلية ٤/٢٨٢، وابن عساكر ٧/٤١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١٣/٥٢٨-٥٢٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٢٩٨.تفسير مقاتل بن سليمان ٣/٤٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٨٣-٢٨٤.
