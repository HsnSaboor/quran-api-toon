tafsir[31]{c,v,t}:
  79,16,""
79,17," <q>﴿ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ ۝١٧﴾</q> - تفسير ٨١٢٨٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿اذْهَبْ إلى فِرْعَوْنَ إنَّهُ طَغى﴾</q>، قال: عصى{1}. (١٥/٢٢٩) ٨١٢٨٨- قال مقاتل بن سليمان: يا موسى، <q>﴿اذْهَبْ إلى فِرْعَوْنَ إنَّهُ طَغى﴾</q>. يقول: إنه قد بلغ من طغيانه أنه عُبِد. [وفي قراءة ابن مسعود]{2}: <q>﴿طَغى﴾</q> لأنه لم يَعبد صنمًا قط، ولكنه دعا الناس إلى عبادته، فذلك قوله: <q>﴿إنَّهُ طَغى﴾</q>{3}. (ز) ٨١٢٨٩- عن صخر بن جُويرية -من طريق عبيد الله بن أبي نصر- قال: لَمّا بَعث اللهُ موسى إلى فرعون قال: <q>﴿اذْهَبْ إلى فِرْعَوْنَ إنَّهُ طَغى﴾</q> إلى قوله: <q>﴿وأَهْدِيَكَ إلى رَبِّكَ فَتَخْشى﴾</q>، ولن يَفعله. فقال موسى: يا ربِّ، كيف أذهب إليه وقد عَلِمتَ أنه لا يفعل؟! فأوحى الله إليه: أنِ امضِ إلى ما أُمِرتَ به؛ فإنّ في السماء اثني عشر ألف مَلَكٍ يطلبون عِلم القَدَر، فلم يَبلغوه، ولم يُدركوه{4}. (١٥/٢٣٠) ",footnotes:1:أخرجه الفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.كذا أثبتها المحقق من إحدى النسخ! وأورد أنها جاءت في نسخة أخرى: وفي قوله.تفسير مقاتل بن سليمان ٤/٥٧٦.أخرجه عبد الرزاق ٢/٣٤٦. وعزاه السيوطي إلى ابن المنذر.
79,18," <q>﴿فَقُلۡ هَل لَّكَ إِلَىٰۤ أَن تَزَكَّىٰ ۝١٨﴾</q> - تفسير ٨١٢٩٠- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</q>، قال: إلى أن تقول: لا إله إلا الله{1}. (١٥/٢٣٠) ٨١٢٩١- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- في قوله: <q>﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</q>، قال: هل لك إلى أن تقول: لا إله إلا الله{2}. (١٥/٢٣٠) ٨١٢٩٢- قال مقاتل بن سليمان: <q>﴿فَقُلْ هَلْ لَكَ إلى أنْ تَزَكّى﴾</q>، يقول: هل لك أن تُصلِح ما قد أفسدتَ. يقول: وأدعوك لتوحيد الله{3}. (ز) ٨١٢٩٣- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</q>، قال: إلى أن تُخلِص{4}. (١٥/٢٣١) ٨١٢٩٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿هَلْ لَكَ إلى أنْ تَزَكّى﴾</q>: إلى أن تُسلِم. قال: والتزكي في القرآن كلّه: الإسلام. وقرأ قول الله: <q>﴿وذَلِكَ جَزاءُ مَن تَزَكّى﴾</q> [طه:٧٦]، قال: مَن أسلم. وقرأ: <q>﴿وما يُدْرِيكَ لَعَلَّهُ يَزَّكّى﴾</q> [عبس:٣]، قال: يُسلِم. وقرأ: <q>﴿وما عَلَيْكَ ألّا يَزَّكّى﴾</q> [عبس:٧]: أن لا يُسلِم{5}٧٠٢٣. (ز) ٧٠٢٣ لم يذكر ابنُ جرير (٢٤/٨٠-٨١) غير قول عبد الرحمن بن زيد، وعكرمة من طريق الحكم. ورجّح ابن عطية (٨/٥٣٠) -مستندًا للعموم- أنّ التزكي هو التّطهّر من النقائص والتلبُّس بالفضائل، ثم علّق على قول مَن فسّر ذلك بـ: تُسلِم، ومَن فسّره بـ لا إله إلا الله، فقال: «والتزكي هو التّطهّر من النقائص، والتلبُّس بالفضائل، وفسّر بعضهم: <q>﴿تَزَكّى﴾</q> بتُسلِم وفسّرها بقول: لا إله إلا الله، وهذا تخصيص وما ذكرناه يعمّ جميع هذا». ",footnotes:1:أخرجه البيهقي في الأسماء والصفات (٢٠٥).أخرجه ابن جرير ٢٤/٨١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٦.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٨٠.
79,19," <q>﴿وَأَهۡدِیَكَ إِلَىٰ رَبِّكَ فَتَخۡشَىٰ ۝١٩﴾</q> - تفسير ٨١٢٩٥- قال مقاتل بن سليمان: <q>﴿وأَهْدِيَكَ إلى رَبِّكَ﴾</q> إلى عَظمته، <q>﴿فَتَخْشى﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٦.
79,20," <q>﴿فَأَرَىٰهُ ٱلۡـَٔایَةَ ٱلۡكُبۡرَىٰ ۝٢٠﴾</q> - تفسير ٨١٢٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَأَراهُ الآيَةَ الكُبْرى﴾</q>، قال: عصاه، ويده{1}. (١٥/٢٢٩) ٨١٢٩٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَأَراهُ الآيَةَ الكُبْرى﴾</q>، قال: عصاه، ويده{2}. (١٥/٢٣٠) ٨١٢٩٨- عن الحسن البصري -من طريق سلّام بن مِسْكين- أنه سأله عن قوله: <q>﴿فَأَراهُ الآيَةَ الكُبْرى﴾</q>. قال: عصاه، ويده{3}. (١٥/٢٣٠) ٨١٢٩٩- قال مقاتل بن سليمان: يُخبِر اللَّه ﷿ محمدًا ﷺ بخَبَره، قال له فرعون: وما هي؟ قال: <q>﴿فَأَراهُ الآيَةَ الكُبْرى﴾</q>، وهي اليد والعصا؛ أخرج يده بيضاء لها شعاع كشُعاع الشمس يُغشي البصر، فكانت اليد أعظم وأعجب من العصا، من غير سوء، يعني: مِن غير بَرَص{4}. (ز) ٨١٣٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَأَراهُ الآيَةَ الكُبْرى﴾</q>، قال: العصا، والحيّة{5}. (ز) ",footnotes:1:تفسير مجاهد ص٧٠٣، وأَخرَجه ابن جرير ٢٤/٨٢، والفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٨٢، ومن طريق سعيد أيضًا بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٣-، وابن جرير ٢٤/٨٢ بنحوه من طريق محمد بن سيف. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٦-٥٧٧.أخرجه ابن جرير ٢٤/٨٢.
79,21," <q>﴿فَكَذَّبَ وَعَصَىٰ ۝٢١ ثُمَّ أَدۡبَرَ یَسۡعَىٰ ۝٢٢﴾</q> - تفسير ٨١٣٠١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثُمَّ أدْبَرَ يَسْعى﴾</q>، قال: يَعمل بالفساد{1}٧٠٢٤. (١٥/٢٢٩) ٧٠٢٤ لم يذكر ابنُ جرير (٢٤/٨٣) غير قول مجاهد. ٨١٣٠٢- عن الربيع بن أنس، في قوله: <q>﴿ثُمَّ أدْبَرَ يَسْعى﴾</q>، قال: أدبَر عن الحق، وسعى يَجمع{2}. (١٥/٢٣١) ٨١٣٠٣- قال مقاتل بن سليمان: قال: <q>﴿فَكَذَّبَ وعَصى﴾</q> وزعم أنه ليس مِن الله ﷿، <q>﴿وعَصى﴾</q> فقال: إنه سِحرٌ، وعصى أيضًا، يعني: استعصى عن الإيمان، ثم قال: <q>﴿ثُمَّ أدْبَرَ﴾</q> عن الحقّ، <q>﴿يَسْعى﴾</q> يعني: في جمْع السّحرة، فهو قوله: <q>﴿فَجَمَعَ كَيْدَهُ ثم أتى﴾</q> [طه:٦٠] به{3}. (ز) ٨١٣٠٤- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ثُمَّ أدْبَرَ يَسْعى﴾</q>، قال: ليس بالشدّ، يَعمل بالفساد والمعاصي{2}. (١٥/٢٣١) ٨١٣٠٥- قال مالك بن أنس: وإنما السعي في كتاب الله العمل والفعل، <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نُودِيَ لِلصَّلاةِ مِن يَوْمِ الجُمُعَةِ فاسْعَوْا إلى ذِكْرِ اللَّهِ وذَرُوا البَيْعَ ذَلِكُمْ خَيْرٌ لَكُمْ إنْ كُنْتُمْ تَعْلَمُونَ﴾</q> [الجمعة:٩]، يقول الله -تبارك وتعالى-: <q>﴿وإذا تَوَلّى سَعى فِي الأَرْضِ﴾</q> [البقرة:٢٠٥]، وقال تعالى: <q>﴿وأَمّا مَن جاءَكَ يَسْعى وهُوَ يَخْشى﴾</q> [عبس:٨-٩]، وقال: <q>﴿ثُمَّ أدْبَرَ يَسْعى﴾</q>، وقال: <q>﴿إنَّ سَعْيَكُمْ لَشَتّى﴾</q> [الليل:٤]. قال مالك: فليس السعي الذي ذَكر الله في كتابه بالسعي على الأقدام، ولا الاشتداد، وإنما عَنى: العمل، والفعل{5}٧٠٢٥. (ز) ٧٠٢٥ أفادت آثار السلف أنّ قوله: <q>﴿أدبر يسعى﴾</q> مراد به: الإعراض عن الحق والإيمان. وقد ذكر هذا ابنُ عطية (٨/٥٣١)، وزاد قولًا آخر، فقال: «وقال بعض المفسرين: <q>﴿أدبر يسعى﴾</q> حقيقةً؛ قام من موضعه موليًا فارًّا بنفسه عن مجالسة موسى ﵇». ",footnotes:1:تفسير مجاهد ص٧٠٣ بنحوه، وأخرجه ابن جرير ٢٤/٨٣، والفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٧.عزاه السيوطي إلى ابن المنذر.موطأ مالك (ت: د. بشار عواد) ١/١٦٣ (٢٨٦). وتقدم ذكره في سورتي البقرة والجمعة.
  79,22,""
79,23," <q>﴿فَحَشَرَ فَنَادَىٰ ۝٢٣ فَقَالَ أَنَا۠ رَبُّكُمُ ٱلۡأَعۡلَىٰ ۝٢٤﴾</q> - تفسير ٨١٣٠٦- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «كلمتان قالهما فرعون: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨]، وقوله: <q>﴿أنا ربكم الأعلى﴾</q>». قال: «كان بينهما أربعون عامًا، <q>﴿فأخذه الله نكال الآخرة والأولى﴾</q>»{1}. (١١/٤٦٨) ٨١٣٠٧- عن عبد الله بن عمرو، قال: كان بين كلمتيه أربعون سنة{2}. (١٥/٢٣٢) ٨١٣٠٨- عن عبد الله بن عباس -من طريق الضحاك- قال: لَمّا قال فرعون: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨]؛ قال جبريل: يا ربِّ، طغى عبدُك، فأْذَن لي في هلاكه. قال: يا جبريل، هو عبدي، ولن يسبقني، له أجلٌ قد أجَّلته حتى يجيء ذلك الأجل. فلما قال: <q>﴿أنا ربكم الأعلى﴾</q>؛ قال: يا جبريل، سبقت دعوتُك في عبدي، وقد جاء أوانُ هلاكه{3}. (١١/٤٦٨) ٨١٣٠٩- عن خَيْثمة الجُعْفيّ -من طريق الأعمش- قال: كان بين قول فرعون: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨] وقوله: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q> أربعون سنة{4}. (١٥/٢٣٢) ٨١٣١٠- عن مجاهد بن جبر -من طريق معمر- يقول: كان بين قول فرعون: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> وبين قوله: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q> أربعون سنة{5}. (ز) ٨١٣١١- عن محمد بن كعب القُرَظيّ -من طريق هارون بن موسى- قال: لَمّا قال فرعون لقومه: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨] نَشَر جبريلُ أجنحةَ العذاب غضبًا لله ﷿، فأوحى الله ﷿ إليه: أن يا جبريل، إنّما يُعجِّل بالعقوبة مَن يخاف الفَوْت. قال: فأَمهله ﷿ بعد هذه المقالة أربعين عامًا، حتى قال: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>{6}. (ز) ٨١٣١٢- عن إسماعيل السُّدِّيّ، قال: قال موسى: يا فرعون، هل لك في أنْ أُعطيك شبابك لا تَهرَم، ومُلكك لا يُنزَع منك، وتُرَدّ إليك لذة المناكح والمشارب والمركوب، وإذا مِتّ دخَلتَ الجنة، وتؤمن بي. فوقعتْ في نفسه هذه الكلمات، وهي الليِّنات. قال: كما أنتَ حتى يأتي هامان. فلمّا جاء هامان أخبره، فعجَّزه هامان، وقال: تصير تَعبُد بعد إذ كنتَ ربًّا تُعبد؟! فذلك حين خَرج عليهم، فقال لقومه وجَمْعهم: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>{7}. (١٥/٢٣١) ٨١٣١٣- قال مقاتل بن سليمان: <q>﴿فَحَشَرَ فَنادى﴾</q> يقول: حَشر القِبط، <q>﴿فَقالَ أنا رَبُّكُمُ الأَعْلى﴾</q> وذلك أنّ موسى ﷺ قال لفرعون: لك مُلكك فلا يزول، ولك شبابك فلا تَهرَم، ولك الجنة إذا مِتّ، على أن يقول: ربي الله وأنا أعبده. فقال فرعون: إنك لعاجز، بينا يكون الرجل ربًّا يُعبَد حتى يكون له ربّ. فقال فرعون: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>. يقول: ليس لي ربٌّ فوقي، فذلك الأعلى{8}. (ز) ٨١٣١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَحَشَرَ فَنادى﴾</q>، قال: صَرخ وحَشَر قومه، فنادى فيهم، فلمّا اجتمعوا قال: أنا ربّكم الأعلى، <q>﴿فأخذه الله نكال الآخرة والأولى﴾</q> [النازعات:٢٥]{9}. (ز) ",footnotes:1:أخرجه تمام في فوائده ١/٣٤٦ (٨٨٨)، وابن عساكر في تاريخه ٥٢/٢٤٧-٢٤٨. قال الألباني في الضعيفة ٩/١١٧ (٤١١٧): «ضعيف».عزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.أخرجه ابن أبي حاتم ٩/٢٩٧٩، ٣٠٦١.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٨٥-٨٦.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٩٥ (٢٤٤)-.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٧٧.أخرجه ابن جرير ٢٤/٨٣.
  79,24,""
79,25," <q>﴿فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلۡـَٔاخِرَةِ وَٱلۡأُولَىٰۤ ۝٢٥﴾</q> - تفسير ٨١٣١٥- عن عبد الله بن عباس -من طريق أبي الضُّحى- يقول: أخذه الله بكلمتيه كلتيهما، أمّا كلمته الأولى قوله: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q>، وأما الآخرة: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>{1}. (١٥/٢٣١) ٨١٣١٦- عن عكرمة مولى ابن عباس، مثله{2}. (١٥/٢٣١) ٨١٣١٧- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل بن سُمَيع- <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: الأولى: تكذيبه وعصيانه، والآخرة: قوله: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>. ثم قرأ: <q>﴿فَكَذَّبَ وعَصى ثُمَّ أدْبَرَ يَسْعى فَحَشَرَ فَنادى فَقالَ أنا رَبُّكُمُ الأَعْلى﴾</q> فهي الكلمة الآخرة{3}. (ز) ٨١٣١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: الأولى: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨]، والآخرة: قوله: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>{4}. (١٥/٢٢٩) ٨١٣١٩- عن مجاهد بن جبر -من طريق منصور- <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: أول عَمَلِه وآخره{3}. (ز) ٨١٣٢٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿نَكالَ الآخِرَةِ والأُولى﴾</q> أما الأولى فحين قال فرعون: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q>، وأما الآخرة فحين قال: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>، فأخذه الله بكلمتيه كلتيهما، فأغرقه في اليم{6}. (١٥/٢٣١) ٨١٣٢١- عن عامر الشعبي -من طريق إسماعيل الأسدي- <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: هما كلمتاه؛ الأولى: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨]، والأخرى: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q> وكان بينهما أربعون سنة{7}. (١٥/٢٣٢) ٨١٣٢٢- عن الحسن البصري -من طريق قتادة- <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: عقوبة الدنيا، والآخرة{8}. (١٥/٢٣٠) ٨١٣٢٣- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: لَمّا قال فرعون لقومه: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨]؛ نشر جبريلُ أجنحةَ العذاب غضبًا لله ﷿، فأوحى الله ﷿ إليه: أن يا جبريل، إنما يعجِّل بالعقوبة مَن يخاف الفَوْت. قال: فأمهله ﷿ بعد هذه المقالة أربعين عامًا، حتى قال: <q>﴿أنا ربكم الأعلى﴾</q>، فذلك قوله ﷿: <q>﴿فأخذه الله نكال الآخرة والأولى﴾</q>: قوله الأول، وقوله الآخر. ثم أغرقه الله ﷿ وجنوده{9}. (ز) ٨١٣٢٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: أصابته عقوبة الدنيا والآخرة{10}. (١٥/٢٣٠) ٨١٣٢٥- عن محمد بن السّائِب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: نكال الآخرة من المعصية والأولى{11}. (ز) ٨١٣٢٦- قال مقاتل بن سليمان: <q>﴿فَأَخَذَهُ اللَّهُ﴾</q> بعقوبة قوله: <q>﴿نَكالَ الآخِرَةِ والأُولى﴾</q>، وكان بينهما أربعين سنة؛ الأولى قوله: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q> [القصص:٣٨]، والآخرة قوله: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>{12}. (ز) ٨١٣٢٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَأَخَذَهُ اللَّهُ نَكالَ الآخِرَةِ والأُولى﴾</q>، قال: اختلفوا فيها، فمِنهم مَن قال: نكال الآخرة من كلمتيه، والأولى قوله: <q>﴿ما عَلِمْتُ لَكُمْ مِن إلَهٍ غَيْرِي﴾</q>، وقوله: <q>﴿أنا رَبُّكُمُ الأَعْلى﴾</q>. وقال آخرون: عذاب الدنيا، وعذاب الآخرة، عجَّل الله له الغرق، مع ما أعدّ له من العذاب في الآخرة{13}٧٠٢٦. (ز) ٧٠٢٦ اختُلف في قوله: <q>﴿نكال الآخرة والأولى﴾</q> على أقوال: الأول: عقوبة كلمتيه: قوله: <q>﴿أنا ربكم الأعلى﴾</q> وقوله: <q>﴿ما علمت لكم من إله غيري﴾</q> [القصص:٣٨]. الثاني: عذاب الدنيا وعذاب الآخرة. الثالث: فأخذه الله نكال الدنيا والآخرة. الرابع: أنّ الأولى هي عصيانه ربّه وكفره به، والآخرة قوله: <q>﴿أنا ربكم الأعلى﴾</q>. الخامس: أخذه بأول عَمَلِه وآخره. واختار ابنُ جرير (٢٤/٨٤) -مستندًا إلى القرآن، وأقوال السلف- أنّ المراد عقوبة كلمتيه كما في القول الأول، فقال: «يعني -تعالى ذِكْره- بقوله: <q>﴿فأخذه الله﴾</q> فعاقبه الله <q>﴿نكال الآخرة والأولى﴾</q> يقول: عقوبة الآخرة من كلمتيه، وهي قوله: <q>﴿أنا ربكم الأعلى﴾</q>، والأولى قوله: <q>﴿ما علمت لكم من إله غيري﴾</q> [القصص:٣٨]، وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على هذا، ثم ذكر بقية الأقوال، ولم يعلّق عليها. ورجّح ابنُ كثير (١٤/٢٤٢) -مستندًا إلى القرآن- القول الثاني، وقال: «كَما قال تعالى: <q>﴿وجَعَلْناهُمْ أئِمَّةً يَدْعُونَ إلى النّارِ ويَوْمَ القِيامَةِ لا يُنْصَرُونَ﴾</q> [القصص:٤١]، هذا هو الصحيح في معنى الآية؛ أنّ المراد بقوله: <q>﴿نَكالَ الآخِرَةِ والأولى﴾</q> أي: الدنيا والآخرة، وقيل: المراد بذلك: كَلِمَتاه الأولى والثانية. وقيل: كفْره وعصيانه. والصحيح الذي لا شكَّ فيه الأول». ",footnotes:1:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٧٠٣-، وابن جرير ٢٤/٨٤ وزاد: كان بينهما أربعون سنة. كما أخرجه بنحوه من طريق عطية.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٨٧.تفسير مجاهد ص٧٠٣، وأَخرَجه ابن جرير ٢٤/٨٥، ومن طريق عبد الكريم أيضًا، والفريابي -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٨٧.أخرجه ابن جرير ٢٤/٨٥-٨٦. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٨٥، ومن طريق زكريا أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٨٦-٨٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب العقوبات- موسوعة الإمام ابن أبي الدنيا ٤/٤٩٥ (٢٤٤).أخرجه عبد الرزاق ٢/٣٤٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٨٨ واللفظ له.تفسير مقاتل بن سليمان ٤/٥٧٧.أخرجه ابن جرير ٢٤/٨٦.
79,26," <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّمَن یَخۡشَىٰۤ ۝٢٦﴾</q> - تفسير ٨١٣٢٨- قال الحسن البصري: <q>﴿إنَّ فِي ذَلِكَ لَعِبْرَةً لِمَن يَخْشى﴾</q> لِمَن يَخشى أن يُفعل به ما فُعل بفرعون وقومه فيُؤمن{1}. (ز) ٨١٣٢٩- قال مقاتل بن سليمان: ثم قال: <q>﴿إنَّ فِي ذلِكَ﴾</q> يقول: إنّ في هلاك فرعون وقومه <q>﴿لَعِبْرَةً لِمَن يَخْشى﴾</q> يعني: لِمَن يَذكر الله تعالى، يقول: لِمَن يَخشى عقوبة الله تعالى، مثل ما فُعل بآل فرعون فلا يُشرك، يخوِّف كفار مكة لِئَلّا يُكذّبوا محمدًا ﷺ فيُجازيهم مثل ما حَلّ بقوم فرعون من العذاب{2}. (ز) ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٠-.تفسير مقاتل بن سليمان ٤/٥٧٧.
79,27," <q>﴿ءَأَنتُمۡ أَشَدُّ خَلۡقًا أَمِ ٱلسَّمَاۤءُۚ بَنَىٰهَا ۝٢٧﴾</q> - تفسير ٨١٣٣٠- قال مقاتل بن سليمان: ثم قال: يا معشر العرب، <q>﴿أأَنْتُمْ أشَدُّ خَلْقًا أمِ السَّماءُ بَناها﴾</q>؟ يقول: أنتم أشد قوة من السماء؟ لأنه قال: <q>﴿إذا السَّماءُ انْفَطَرَتْ﴾</q>، <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، يقول: فما حالكم أنتم -يا بني آدم- وأنتم أضعف من السماء؟{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٧-٥٧٨.
79,28," <q>﴿رَفَعَ سَمۡكَهَا فَسَوَّىٰهَا ۝٢٨﴾</q> - تفسير ٨١٣٣١- عن عبد الله بن عباس -من طريق علي، وعطية- في قوله: <q>﴿رَفَعَ سَمْكَها﴾</q>، قال: بناها{1}. (١٥/٢٣٢) ٨١٣٣٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿رَفَعَ سَمْكَها﴾</q>، قال: رفع بنيانها بغير عمد{2}. (١٥/٢٣٢) ٨١٣٣٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿رَفَعَ سَمْكَها﴾</q>، قال: رفع بنيانها{3}. (١٥/٢٣٣) ٨١٣٣٤- قال مقاتل بن سليمان: ثم قال: <q>﴿بَناها رَفَعَ سَمْكَها﴾</q> يعني: طولها مسيرة خمسمائة عام، <q>﴿فَسَوّاها﴾</q> ليس فيها خَلَل{4}٧٠٢٧. (ز) ٧٠٢٧ لم يذكر ابنُ جرير (٢٤/٨٩) غير قول قتادة، ومجاهد، وابن عباس. وذكر ابنُ عطية (٨/٥٣٢) في قوله: <q>﴿فسواها﴾</q> احتمالين، فقال: «وقوله تعالى: <q>﴿فَسَوّاها﴾</q> يحتمل أن يريد: جعلها ملساء مستوية ليس فيها مرتفع ومنخفض، ويحتمل أن يكون عبارة عن إتقان خَلْقها، ولا يقصد معنى إملاس سطحها، والله تعالى أعلم كيف هي». ",footnotes:1:أخرجه ابن جرير ٢٤/٨٩ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٧٠٤، وأخرجه ابن جرير ٢٤/٨٩. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٢٤/٨٩ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٨.
79,29," <q>﴿وَأَغۡطَشَ لَیۡلَهَا﴾</q> - تفسير ٨١٣٣٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: أظلم ليلها{1}. (١٥/٢٣٢) ٨١٣٣٦- عن عبد الله بن عباس، <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: العشاء{2}. (١٥/٢٣٣) ٨١٣٣٧- عن سعيد بن جُبَير، <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: أظلم ليلها{3}. (١٥/٢٣٣) ٨١٣٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: أظلم ليلها{4}. (١٥/٢٣٢) ٨١٣٣٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، يقول: أظلم ليلها{5}. (ز) ٨١٣٤٠- عن عكرمة مولى ابن عباس -من طريق الحكم- <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: أظلم ليلها{6}. (ز) ٨١٣٤١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: أظلم ليلها{7}. (١٥/٢٣٣) ٨١٣٤٢- عن شرحبيل بن سعد -من طريق أبي معشر- في قوله: <q>﴿وأغطش ليلها﴾</q>، قال: أظلم ليلها{8}. (ز) ٨١٣٤٣- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿أغطش ليلها﴾</q>: أظلم ليلها{9}. (ز) ٨١٣٤٤- قال مقاتل بن سليمان: قوله: <q>﴿وأَغْطَشَ﴾</q> يقول: وأَظلم <q>﴿لَيْلَها﴾</q>{10}. (ز) ٨١٣٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَغْطَشَ لَيْلَها﴾</q>، قال: الظُّلمة{11}. (ز) <q>﴿وَأَخۡرَجَ ضُحَىٰهَا ۝٢٩﴾</q> - تفسير ٨١٣٤٦- عن عبد الله بن عباس، <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: الشمس{2}. (١٥/٢٣٣) ٨١٣٤٧- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿وأَخْرَجَ ضُحاها﴾</q>، يقول: أخرج نهارها{13}. (ز) ٨١٣٤٨- عن سعيد بن جُبَير، <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: أخرج نهارها{3}. (١٥/٢٣٣) ٨١٣٤٩- عن مجاهد بن جبر، في قوله: <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: أبرزه{15}. (١٥/٢٣٢) ٨١٣٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: نَوَّرها{16}. (ز) ٨١٣٥١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: نهارها{6}. (ز) ٨١٣٥٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: نور ضوئها{18}. (١٥/٢٣٣) ٨١٣٥٣- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: أنار ضحاها{19}. (ز) ٨١٣٥٤- قال مقاتل بن سليمان: <q>﴿وأَخْرَجَ ضُحاها﴾</q> يعني: وأَبرز، يقول: وأَخرج شمسها، وإنما صارت مُؤنّثة لأنّ ظُلمة الليل في السموات، وظُلمة الليل من السماء تجيء{10}. (ز) ٨١٣٥٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَخْرَجَ ضُحاها﴾</q>، قال: ضوء النهار{21}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٩٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٩٠ بلفظ: «أظلم» فقط. وعزاه السيوطي إلى أبي الشيخ، وعَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٩٠-٩١.أخرجه ابن جرير ٢٤/٩١.أخرجه عبد الرزاق ٢/٣٤٧، وابن جرير ٢٤/٩٠، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٥٥ (٢٣٩٣).أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٩.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩٠.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٤-.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر، وأبي الشيخ.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٤-، وابن جرير ٢٤/٩١.أخرجه ابن جرير ٢٤/٩١.أخرجه ابن جرير ٢٤/٩١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٧.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩١-٩٢.
79,30," <q>﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾</q> - قراءات ٨١٣٥٦- عن مجاهد بن جبر -من طريق الأعمش- أنه قرأ: (والأَرْضَ عِندَ ذَلِكَ دَحاها){1}. (ز) <q>﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾</q> - تفسير الآية ٨١٣٥٧- عن عبد الله بن عمرو -من طريق مجاهد- قال: خَلَق الله البيت قبل الأرض بألفي سنة، ومنه دُحِيت الأرض{2}. (ز) ٨١٣٥٨- عن عبد الله بن عباس، <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q>، قال: مع ذلك{3}. (١٥/٢٣٣) ٨١٣٥٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- أنّ رجلًا قال له: آيتان في كتاب الله تُخالف إحداهما الأخرى؟ فقال: إنما أُتيتَ من قِبَل رأيك، اقرأ. قال: <q>﴿قُلْ أئِنَّكُمْ لَتَكْفُرُونَ بِالَّذِي خَلَقَ الأَرْضَ فِي يَوْمَيْن﴾</q> حتى بلغ: <q>﴿ثُمَّ اسْتَوى إلى السَّماءِ وهِيَ دُخانٌ﴾</q> [فصلت:٩-١١]، وقوله: <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q>. قال: خَلَق الله الأرض قبل أن يَخلُق السماء، ثم خَلَق السماء، ثم دحا بعدما خَلَق السماء، وإنما قوله: دحاها: بسطها{4}. (١٥/٢٣٣) ٨١٣٦٠- عن عبد الله بن عباس، في قوله: <q>﴿دَحاها﴾</q>، قال: دَحيُها: أنْ أخرج منها الماء والمرعى، وشَقَّق فيها الأنهار، وجعل فيها الجبال والرّمال والسُّبل والآكام وما بينهما في يومين{5}. (١٥/٢٣٤) ٨١٣٦١- عن عبد الله بن عباس -من طريق علي-: حيث ذَكر خَلْق الأرض قبل السماء، ثم ذَكر السماء قبل الأرض، وذلك أنّ الله خَلَق الأرض بأقواتها من غير أن يَدْحُوها قبل السماء، ثم استوى إلى السماء فسوّاهنّ سبع سموات، ثم دحا الأرض بعد ذلك، فذلك قوله: <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q>{6}. (ز) ٨١٣٦٢- عن عبد الله بن عباس -من طريق عكرمة- قال: وُضع البيت على الماء على أربعة أركان قبل أن يَخلق الدنيا بألفي عام، ثم دُحِيت الأرض من تحت البيت{2}. (ز) ٨١٣٦٣- عن إبراهيم النَّخْعي، <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q>، قال: دُحِيتْ من مكة{8}. (١٥/٢٣٤) ٨١٣٦٤- عن مجاهد بن جبر -من طريق خُصَيف- في قوله: <q>﴿والأَرْضَ بَعْدَ ذَلِكَ﴾</q> قال: مع ذلك <q>﴿دَحاها﴾</q> قال: بَسَطها{9}. (١٥/٢٣٢) ٨١٣٦٥- عن عطاء، قال: بلَغني: أنّ الأرض دُحِيتْ دَحيًا من تحت الكعبة{10}. (١٥/٢٣٤) ٨١٣٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q>، قال: بَسَطها{11}. (١٥/٢٣٣) ٨١٣٦٧- عن إسماعيل السُّدِّيّ -من طريق أبي حمزة- في قوله: <q>﴿والأَرْضَ بَعْدَ ذَلِكَ دَحاها﴾</q>، قال: مع ذلك دحاها{12}. (ز) ٨١٣٦٨- قال مقاتل بن سليمان: قال: <q>﴿والأَرْضَ بَعْدَ ذلِكَ دَحاها﴾</q>، يقول: بعد بناء السماء، بَسَطها مِن تحت الكعبة مسيرة خمسمائة عام{13}. (ز) ٨١٣٦٩- عن سفيان -من طريق عبد الرحمن- <q>﴿دَحاها﴾</q>: بَسَطها{14}. (ز) ٨١٣٧٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿دَحاها﴾</q>، قال: حَرَثها، شَقَّها. وقال: <q>﴿أخْرَجَ مِنها ماءَها﴾</q>، وقرأ: <q>﴿ثُمَّ شَقَقْنا الأَرْضَ شَقًّا﴾</q> حتى بلغ <q>﴿وفاكِهَةً وأَبًّا﴾</q> [عبس:٢٦-٣١]. وقال: حين شَقَّها أنبتَ هذا منها. وقرأ: <q>﴿والأَرْضِ ذاتِ الصَّدْعِ﴾</q> [الطارق:١٢]{15}٧٠٢٨. (ز) ٧٠٢٨ اختُلف في قوله: <q>﴿بعد ذلك﴾</q> على قولين: الأول: أنّ الأرض دُحِيتْ من بعد خَلْق السماء. الثاني: أنّ معناه: مع ذلك، وقالوا: الأرض خُلِقتْ ودُحِيتْ قبل السماء. وقد رجّح ابنُ جرير (٢٤/٩٤) -مستندًا إلى اللغة- القول الأول، فقال: «والقول الذي ذكرناه عن ابن عباس من أنّ الله تعالى خَلَق الأرض، وقَدّر فيها أقواتها، ولم يَدْحُها، ثم استوى إلى السماء فسوّاهنّ سبع سموات، ثم دحا الأرض بعد ذلك، فأَخرج منها ماءها ومرعاها، وأرسى جبالها؛ أشبه لما دلّ عليه ظاهر التنزيل؛ لأنه -جلّ ثناؤه- قال: <q>﴿والأرض بعد ذلك دحاها﴾</q> والمعروف من معنى»بعد«أنه خلاف معنى»قبل«، وليس في دَحْو الله الأرض بعد تسويته السماوات السبع، وإغطاشه ليلها، وإخراجه ضحاها، ما يوجب أن تكون الأرض خُلِقتْ بعد خَلْق السماوات؛ لأنّ الدَّحْو إنما هو البَسط في كلام العرب، والمدّ يقال منه: دحا يدحُو دَحْوًا، ودحيت أدحي دحيًا لغتان». وقال ابنُ عطية (٨/٥٣٢): «وقوله تعالى: <q>﴿والأَرْضَ بَعْدَ ذلِكَ دَحاها﴾</q> متوجّه على أنّ الله تعالى خَلَق الأرض ولم يَدْحُها، ثم استوى إلى السماء وهي دُخان فخَلَقها وبناها، ثم دحا الأرض بعد ذلك». ثم ذكر اختلاف السلف، وعلّق قائلًا: «والذي قلناه تترتب عليه آيات القرآن كلّها». وبنحوه قال ابنُ كثير (٨/٣١٦). <q>﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾</q> - آثار متعلقة بالآية ٨١٣٧١- عن علي، قال: صَلّى بنا رسول الله ﷺ صلاة الصبح، فلمّا قضى صلاته رفع رأسه إلى السماء، فقال: «تبارك رافعها ومُدبِّرها». ثم رمى ببصره إلى الأرض، فقال: «تبارك داحيها وخالقها»{16}. (١٥/٢٣٤) ",footnotes:1:أخرجه ابن جرير ٢٤/٩٤. وهي قراءة شاذة.أخرجه ابن جرير ٢٤/٩٣.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البخاري في صحيحه مطولًا ٤/١٨١٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣٩-.أخرجه ابن جرير ٢٤/٩٢، ومن طريق عطية بنحوه أيضًا.أخرجه ابن جرير ٢٤/٩٣.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٨٩-٩٤، ومن طريق الأعمش أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٩٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٩٤.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩٥.أخرجه ابن جرير ٢٤/٩٥-٩٦.أخرجه البزار ٢/١٤٥-١٤٦ (٥٠٧) مطولًا، وأبو الشيخ في العظمة ٣/١٠٤٢ (٥٦٠) واللفظ له، من طريق يونس بن أرقم، عن إبراهيم بن عبد الله بن حسن بن حسن، عن زيد بن علي بن الحسين، عن أبيه، عن جده، عن علي بن أبي طالب به. وقال البزار: «وهذا الحديث لا نعلمه يُروى عن النبي ﷺ بهذا اللفظ إلا من هذا الوجه بهذا الإسناد، ويونس بن أرقم كان صدوقًا روى عنه أهل العلم، واحتملوا حديثَه على أنّ فيه شيعية شديدة». وقال الهيثمي في المجمع ٧/٣٢٨ (١٢٤٥٦): «فيه مَن لم أعرفهم». وقال المتقي الهندي في كنز العمال ١٤/٥٥٧ (٣٩٥٩٠): «سنده حسن».
79,31," <q>﴿أَخۡرَجَ مِنۡهَا مَاۤءَهَا وَمَرۡعَىٰهَا ۝٣١﴾</q> - تفسير ٨١٣٧٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿ومَرْعاها﴾</q> ما خَلَق الله فيها من النبات، <q>﴿ماءَها﴾</q> ما فَجّر فيها من الأنهار{1}. (ز) ٨١٣٧٣- قال مقاتل بن سليمان: ثم قال: <q>﴿أخْرَجَ مِنها ماءَها ومَرْعاها﴾</q>، يقول: بحورها ونباتها؛ لأنّ النبات والماء يكونان من الأرض{2}. (ز) ٨١٣٧٤- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿أخْرَجَ مِنها ماءَها﴾</q> قال: فَجّر منها الأنهار، <q>﴿ومَرْعاها﴾</q> قال: ما خَلَق الله مِن نبات أو شيء{3}. (١٥/٢٣٤) ٨١٣٧٥- قال يحيى بن سلّام: وكان بدء خَلْق الأرض -فيما بلَغنا- أنها كانت طينة في موضع بيت المقدس، ثم خَلَق السموات، ثم دحا الأرض، فقال لها: اذهبي أنتِ كذا، واذهبي أنتِ كذا، ومن مكة بُسطت الأرض، ثم جعل فيها جبالها وأنهارها وأشجارها. قال: <q>﴿أخْرَجَ مِنها ماءَها ومَرْعاها﴾</q>{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٩٦.تفسير مقاتل بن سليمان ٤/٥٧٨.عزاه السيوطي إلى ابن المنذر.تفسير ابن أبي زمنين ٥/٩١.
79,32," <q>﴿وَٱلۡجِبَالَ أَرۡسَىٰهَا ۝٣٢﴾</q> - تفسير ٨١٣٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والجِبالَ أرْساها﴾</q>، قال: أثبتها أن تَميد بأهلها{1}. (١٥/٢٣٣) ٨١٣٧٧- قال مقاتل بن سليمان: <q>﴿والجِبالَ أرْساها﴾</q>، يقول: أوْتَدها في الأرض لئلا تزول، فاستقرّتْ بأهلها{2}. (ز) <q>﴿وَٱلۡجِبَالَ أَرۡسَىٰهَا ۝٣٢﴾</q> - آثار متعلقة بالآية ٨١٣٧٨- عن علي بن أبي طالب -من طريق أبي عبد الرحمن السُّلميّ- قال: لَمّا خَلَق اللهُ الأرضَ قَمَصتْ، وقالتْ: تَخْلُق عَلَيَّ آدم وذُرِّيته يُلقون عَلَيَّ نَتنهم، ويَعملون عَلَيَّ بالخطايا. فأرساها الله، فمنها ما تَرون، ومنها ما لا تَرون، فكان أول قرار الأرض كلحم الجَزور إذا نُحر يَختَلج لحمها{3}٧٠٢٩. (ز) ٧٠٢٩ علّق ابنُ كثير (١٤/٢٤٤) على هذا الأثر بقوله: «غريب». ",footnotes:1:أخرجه ابن جرير ٢٤/٩٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن جرير ٢٤/٩٦-٩٧.
79,33," <q>﴿مَتَـٰعࣰا لَّكُمۡ وَلِأَنۡعَـٰمِكُمۡ ۝٣٣﴾</q> - تفسير ٨١٣٧٩- عن عبد الله بن عباس، في قوله: <q>﴿مَتاعًا لَكُمْ﴾</q>، قال: منفعة{1}. (١٥/٢٣٤) ٨١٣٨٠- قال مقاتل بن سليمان: ثم رجع إلى <q>﴿مَرْعاها﴾</q>، فقال فيها: <q>﴿مَتاعًا لَكُمْ ولِأَنْعامِكُمْ﴾</q> يقول: معيشة لكم ولمواشيكم{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٧٨.
79,34," <q>﴿فَإِذَا جَاۤءَتِ ٱلطَّاۤمَّةُ ٱلۡكُبۡرَىٰ ۝٣٤﴾</q> - تفسير ٨١٣٨١- عن عبد الله بن عباس -من طريق علي- <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q>، قال: الطّامَّة مِن أسماء يوم القيامة{1}. (١٥/٢٣٥) ٨١٣٨٢- عن مجاهد بن جبر، في قوله: <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q>، قال: إذا دُفعوا إلى مالك خازن النار{2}. (١٥/٢٣٥) ٨١٣٨٣- عن عمرو بن قيس الكندي -من طريق موسى بن قيس- <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q>، قال: إذا قيل: اذهبوا به إلى النار{3}. (١٥/٢٣٥) ٨١٣٨٤- عن القاسم بن الوليد الهَمذاني -من طريق مالك بن مِغْول- في قوله: <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q>، قال: إذا سيق أهل الجنة إلى الجنة، وأهل النار إلى النار{4}٧٠٣٠. (١٥/٢٣٥) ٧٠٣٠ لم يذكر ابنُ جرير (٢٤/٩٧) غير قول القاسم، وابن عباس. ٨١٣٨٥- قال مقاتل بن سليمان: <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q> يعني: العُظمى، وهي النفخة الآخرة من بيت المقدس، فذلك الطّامَّة الكبرى، وهي يوم القيامة{5}. (ز) ٨١٣٨٦- عن نعيم النحوي -من طريق يحيى بن يحيى- قال: سمعتُ في قوله: <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q>، قال: إذا قيل لهم: قوموا إلى النار{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٩٧. وعزاه السيوطي إلى ابن المنذر، وابن حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ١٣/٥١٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٥٥٨، وابن جرير ٢٤/٩٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٨.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٤٤ (٢٠٦)-.
79,35," <q>﴿یَوۡمَ یَتَذَكَّرُ ٱلۡإِنسَـٰنُ مَا سَعَىٰ ۝٣٥﴾</q> - تفسير ٨١٣٨٧- قال مقاتل بن سليمان: ثم نعتَ الطّامَّة، فقال: <q>﴿يَوْمَ يَتَذَكَّرُ الإنْسانُ ما سَعى﴾</q>، يعني: يَتذكر ما عمل في الدنيا مِن الشَّرِّ، يجزى به في ذلك اليوم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٩.
79,36," <q>﴿وَبُرِّزَتِ ٱلۡجَحِیمُ لِمَن یَرَىٰ ۝٣٦﴾</q> - تفسير ٨١٣٨٨- قال مقاتل بن سليمان: <q>﴿وبُرِّزَتِ الجَحِيمُ لِمَن يَرى﴾</q> لأنّ الخَلْق يومئذ يُبصرونها؛ فمن كان منها أعمى في الدنيا فهو يومئذ يُبصِر{1}. (ز) ٨١٣٨٩- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وبُرِّزَتِ الجَحِيمُ لِمَن يَرى﴾</q>، قال: لِمَن ينظر{2}. (١٥/٢٣٥) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٩.عزاه السيوطي إلى ابن المنذر.
79,37," <q>﴿فَأَمَّا مَن طَغَىٰ ۝٣٧ وَءَاثَرَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝٣٨ فَإِنَّ ٱلۡجَحِیمَ هِیَ ٱلۡمَأۡوَىٰ ۝٣٩﴾</q> - نزول الآية ٨١٣٩٠- قال مقاتل بن سليمان: قال: <q>﴿فَأَمّا مَن طَغى وآثَرَ الحَياةَ الدُّنْيا﴾</q> نزلت هذه الآية في النَّضر بن الحارث بن عَلقمة بن كلدة، وفي حبيب بن عبد ياليل، وأُمَيّة بن خلف الجُمحيّ، وعُتْبة وعُتيبة ابني أبي لهب، فهؤلاء كفار، ومنهم مُصعب وأبو [الروم] ابنا عمير، وذلك أنهم وجدوا جزورًا في البَريّة، ضلَّتْ مِن الأعراب، فنَحروها، وجعلوا يَقتسِمونها بينهم، فأصاب مُصعب وأبو [الروم] سهمين، ثم إنّ مُصعب ذكر مَقامه بين يدي ربّ العالمين، فخاف أن يُحاسبه الله تعالى يوم القيامة، فقال: إنّ سهمي وسهم أخي هو لكم. فقال له عند ذلك أُمَيّة بن خلف: ولِمَ؟ قال: إني أخاف أن يُحاسبني الله به. فقال له أُمَيّة بن خلف: هاته، وأنا أحمل عنك هذا الوزر عند إلهك في الآخرة، وفشَتْ تلك المقالة في قريش في أمْر مُصعب؛ فأَنزَل الله تعالى: <q>﴿فَأَمّا مَن طَغى﴾</q>{1}. (ز) <q>﴿فَأَمَّا مَن طَغَىٰ ۝٣٧ وَءَاثَرَ ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝٣٨ فَإِنَّ ٱلۡجَحِیمَ هِیَ ٱلۡمَأۡوَىٰ ۝٣٩﴾</q> - تفسير الآية ٨١٣٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَأَمّا مَن طَغى﴾</q>، قال: عصى{2}٧٠٣١. (١٥/٢٣٥) ٧٠٣١ لم يذكر ابنُ جرير (٢٤/٩٨) غير قول مجاهد. ٨١٣٩٢- قال مقاتل بن سليمان: <q>﴿فَأَمّا مَن طَغى﴾</q> الثابت على الشّرك، <q>﴿وآثَرَ الحَياةَ الدُّنْيا﴾</q> على الآخرة، ولم يَخفِ الله ولا حسابه؛ فأكل الحرام، <q>﴿فَإنَّ الجَحِيمَ هِيَ المَأْوى﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٧٩-٥٨٠.تفسير مجاهد ص٧٠٤، وأخرجه ابن جرير ٢٤/٩٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٩-٥٨٠.
  79,38,""
  79,39,""
79,40," <q>﴿وَأَمَّا مَنۡ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفۡسَ عَنِ ٱلۡهَوَىٰ ۝٤٠ فَإِنَّ ٱلۡجَنَّةَ هِیَ ٱلۡمَأۡوَىٰ ۝٤١﴾</q> - تفسير ٨١٣٩٣- قال مقاتل بن سليمان: ثم ذكر مُصعب -قُتِل يوم أُحد- وأبا [الروم] ابني عمير بن هشام بن عبد مناف بن عبد الدار بن قُصيّ، فقال: <q>﴿وأَمّا مَن خافَ مَقامَ رَبِّهِ﴾</q> يقول: مَقام ذلك اليوم بين يدي ربّه، <q>﴿ونَهى النَّفْسَ عَنِ الهَوى﴾</q> يقول: قدر على معصيته، فانتهى عنها مخافة حساب ذلك اليوم، <q>﴿فَإنَّ الجَنَّةَ هِيَ المَأْوى﴾</q> نظيرها في النّجم{1}٧٠٣٢. (ز) ٧٠٣٢ أفاد قول مقاتل أنّ قوله: <q>﴿مقام ربه﴾</q> معني به: مقامه بين يديه يوم لقائه. وقد ذكر ذلك ابنُ القيم (٣/٢٥٤)، وعلّق عليه بقوله: «وهو من باب إضافة المصدر إلى المخوف». وذكر قولًا آخر أنّ المراد بالمقام هنا هو «مقام الربّ على عبده بالاطلاع والقدرة والربوبية». وعلّق عليه قائلًا: «فعلى هذا القول يكون من باب إضافة المصدر إلى الفاعل». ورجّح الأول بقوله: «وهو الأليق بالآية». ولم يذكر مستندًا. ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٨٠. يشير إلى قوله تعالى: <q>﴿عِنْدَها جَنَّةُ المَأْوى﴾</q> [النجم:١٥].
  79,41,""
79,42," <q>﴿یَسۡـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَیَّانَ مُرۡسَىٰهَا ۝٤٢﴾</q> - نزول الآية ٨١٣٩٤- عن عبد الله بن عباس، قال: إنّ مشركي أهل مكة سألوا النبيَّ ﷺ، فقالوا: متى الساعة؟ استهزاءً منهم؛ فأَنزَل الله: <q>﴿يَسْأَلُونَكَ عَنِ السّاعَةِ أيّانَ مُرْساها﴾</q> يعني: مجيئها{1}. (١٥/٢٣٦) ٨١٣٩٥- قال مقاتل بن سليمان: ... <q>﴿فَإنَّ الجَنَّةَ هِيَ المَأْوى﴾</q>... فخَرج رسول الله ﷺ عند ذلك، فقرأها عليهم، فقالوا: متى هذا اليوم، يا محمد؟ فأَنزَل الله ﷿: <q>﴿يَسْئَلُونَكَ﴾</q>{2}. (ز) <q>﴿یَسۡـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَیَّانَ مُرۡسَىٰهَا ۝٤٢﴾</q> - تفسير الآية ٨١٣٩٦- عن مجاهد بن جبر، في قوله: <q>﴿يَسْأَلُونَكَ عَنِ السّاعَةِ أيّانَ مُرْساها﴾</q>، قال: حِينها{3}. (١٥/٢٣٥) ٨١٣٩٧- قال مقاتل بن سليمان: <q>﴿يَسْئَلُونَكَ﴾</q> يعني: كفار مكة <q>﴿عَنِ السّاعَةِ أيّانَ مُرْساها﴾</q> فأجاب الله ﷿ النبيَّ ﷺ في النّمل [٦٥]، فقال: <q>﴿قُلْ لا يَعْلَمُ مَن فِي السَّماواتِ والأَرْضِ الغَيْبَ إلّا اللَّهُ﴾</q> يقول: يسألونك عن القيامة متى قيامها{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه. قال السيوطي: «سند ضعيف».تفسير مقاتل بن سليمان ٤/٥٨٠-٥٨١.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٨٠-٥٨١.
79,43," <q>﴿فِیمَ أَنتَ مِن ذِكۡرَىٰهَاۤ ۝٤٣ إِلَىٰ رَبِّكَ مُنتَهَىٰهَاۤ ۝٤٤﴾</q> - نزول الآية ٨١٣٩٨- عن علي بن أبي طالب، قال: كان النبيُّ ﷺ يسأل عن الساعة؛ فنزلت: <q>﴿فِيمَ أنْتَ مِن ذِكْراها﴾</q>{1}. (١٥/٢٣٥) ٨١٣٩٩- عن عائشة -من طريق عُروة- قالت: مازال رسولُ الله ﷺ يسأل عن الساعة حتى أُنزِل عليه: <q>﴿فِيمَ أنْتَ مِن ذِكْراها إلى رَبِّكَ مُنْتَهاها﴾</q> فانتهى، فلم يسأل عنها{2}. (١٥/٢٣٦) ٨١٤٠٠- عن عُروة، مرسلًا{3}. (١٥/٢٣٧) ٨١٤٠١- عن طارق بن شهاب: أنّ النبيَّ ﷺ كان لا يزال يذكر من شأن الساعة حتى نزلت: <q>﴿يَسْأَلُونَكَ عَنِ السّاعَةِ أيّانَ مُرْساها﴾</q> الآية كلها{4}. (ز) ٨١٤٠٢- عن طارق بن شهاب -من طريق إسماعيل- قال: كان رسول الله ﷺ يكثر ذكر الساعة حتى نزلت: <q>﴿فِيمَ أنْتَ مِن ذِكْراها إلى رَبِّكَ مُنْتَهاها﴾</q> فكفّ عنها{5}. (١٥/٢٣٧) <q>﴿فِیمَ أَنتَ مِن ذِكۡرَىٰهَاۤ ۝٤٣ إِلَىٰ رَبِّكَ مُنتَهَىٰهَاۤ ۝٤٤﴾</q> - تفسير الآية ٨١٤٠٣- عن ابن عباس، قال: <q>﴿فِيمَ أنْتَ مِن ذِكْراها﴾</q> يعني: ما أنت مِن عِلْمها، يا محمد! <q>﴿إلى رَبِّكَ مُنْتَهاها﴾</q> يعني: مُنتهى علمها. فقال النبى ﷺ: «يا أهل مكة، إنّ الله احتجب بخمس لم يُطْلِع عليهن مَلَكٌ مُقَرَّب ولا نبي مُرْسَل، فمَن ادعى عِلمهنّ فقد كفر: <q>﴿إنَّ اللَّهَ عِنْدَهُ عِلْمُ السّاعَةِ ويُنَزِّلُ الغَيْثَ﴾</q>» إلى آخر السورة [لقمان:٣٤]{6}. (١٥/٢٣٦) ٨١٤٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فِيمَ أنْتَ مِن ذِكْراها﴾</q>، قال: الساعة{7}. (١٥/٢٣٥) ٨١٤٠٥- قال محمد بن السّائِب الكلبي: <q>﴿فِيمَ أنْتَ مِن ذِكْراها﴾</q> فيم أنت مِن أن تسأل عنها ولم أُخبِرك بها متى تجيء؟{8}. (ز) ٨١٤٠٦- قال مقاتل بن سليمان: فقال: <q>﴿فِيمَ أنْتَ مِن ذِكْراها﴾</q> أي مِن أين تعلم ذلك؟ <q>﴿إلى رَبِّكَ مُنْتَهاها﴾</q> يقول: مُنتهى عِلْم ذلك إلى الله ﷿. نظيرها في الأعراف{9}. (ز) ٨١٤٠٧- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿إلى رَبِّكَ مُنْتَهاها﴾</q>، قال: عِلْمها{10}. (١٥/٢٣٧) <q>﴿فِیمَ أَنتَ مِن ذِكۡرَىٰهَاۤ ۝٤٣ إِلَىٰ رَبِّكَ مُنتَهَىٰهَاۤ ۝٤٤﴾</q> - آثار متعلقة بالآية ٨١٤٠٨- عن هشام، عن أبيه، عن عائشة، قالت: كان رجال مِن الأعراب جفاةً، يأتون النبيَّ ﷺ، فيسألونه: متى الساعة؟ فكان ينظر إلى أصغرهم، فيقول: «إن يعش هذا لا يدركه الهرم حتى تقوم عليكم ساعتكم». قال هشام: يعني: موتهم{11}. (١٥/٢٣٧) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن راهويه ٢/٢٧٠ (٧٧٧)، والحاكم ١/٤٦ (٧)، ٢/٥٥٨ (٣٨٩٥)، وابن مردويه -كما في تخريج أحاديث الكشاف ٤/١٥١-، وابن جرير ٢٤/٩٩ بنحوه، من طريق سفيان، عن الزُّهريّ، عن عروة، عن عائشة به. قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه؛ فإنّ ابن عُيينة كان يُرسله بآخره». وقال الدارقطني في العلل ١٤/١٢٦ (٣٤٧٥): «لعل ابن عيينة وصله مرة، وأرسله أخرى». وقال الهيثمي في المجمع ٧/١٣٣ (١١٤٦٥): «رجاله رجال الصحيح».أخرجه عبد الرزاق ٢/٣٤٧، وسعيد بن منصور، وابن مردويه -كما في تخريج أحاديث الكشاف ٤/١٥١-، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣١ (٦)-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه النسائي في الكبرى ١٠/٣٢٣ (١١٥٨١)، وابن جرير ١٠/٦٠٥، ٢٤/١٠٠. قال ابن جرير (١٠/٦٠٥): «والصواب من القول في ذلك أن يُقال: إنّ قومًا سألوا رسول الله ﷺ عن الساعة؛ فأَنزَل الله هذه الآية، وجائز أن يكون كانوا من قريش، وجائز أن يكونوا كانوا من اليهود، ولا خبر بذلك عندنا يُجَوِّزُ قطع القول على أي ذلك كان». وقال ابن كثير في تفسيره ٣/٥٢٣ عن رواية النسائي: «وهذا إسناد جيد قوي».أخرجه الطبراني في الكبير ٨/٣٢٢ (٨٢١٠)، والضياء في المختارة ٨/١١٤ (١٣٢). وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٨٠٥ (٤١٢٧): «رواه علي بن غراب -وهو ابن أبي الوليد-، عن إسماعيل بن أبي خالد، عن طارق بن شهاب. قال: كان أبو علي هذا ليس بالقوي». وقال الهيثمي في المجمع ٧/١٣٣ (١١٤٦٦): «رواه الطبراني، وفيه مَن لم أعرفه».عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه. قال السيوطي: «بسند ضعيف».أخرجه ابن جرير ٢٤/١٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٢-.تفسير مقاتل بن سليمان ٤/٥٨١. يشير إلى قوله: <q>﴿يَسْأَلُونَكَ عَنِ السّاعَةِ أيّانَ مُرْساها قُلْ إنَّما عِلْمُها عِنْدَ رَبِّي لا يُجَلِّيها لِوَقْتِها إلّا هُوَ﴾</q> [الأعراف:١٨٧].عزاه السيوطي إلى ابن المنذر.أخرجه البخاري ٨/١٠٧ (٦٥١١)، ومسلم ٤/٢٢٦٩ (٢٩٥٢) ولفظ مسلم: كان الأعراب إذا قدموا على رسول الله ﷺ سألوه عن الساعة: متى الساعة؟ فنظر إلى أحدث إنسان منهم، فقال: «إن يعش هذا، لم يُدركه الهَرم، قامتْ عليكم ساعتكم».
  79,44,""
79,45," <q>﴿إِنَّمَاۤ أَنتَ مُنذِرُ مَن یَخۡشَىٰهَا ۝٤٥﴾</q> - تفسير الآية ٨١٤٠٩- عن عبد الله بن عباس، قال: <q>﴿إنَّما أنْتَ مُنْذِرُ مَن يَخْشاها﴾</q> يعني: مَن يخشى القيامة{1}. (١٥/٢٣٦) ٨١٤١٠- قال مقاتل بن سليمان: ثم قال: <q>﴿إنَّما أنْتَ مُنْذِرُ مَن يَخْشاها﴾</q>، يقول: إنما أنت رسول تُنذر بالساعة مَن يخشى ذلك اليوم{2}. (ز) <q>﴿إِنَّمَاۤ أَنتَ مُنذِرُ مَن یَخۡشَىٰهَا ۝٤٥﴾</q> - آثار متعلقة بالآية ٨١٤١١- عن زيد بن أسلم، قال: قال رسول الله ﷺ: «إنما يدخل الجنة مَن يرجوها، وإنما يَجتنب النار مَن يخشاها، وإنما يَرحم الله مَن يَرحم»{3}. (١٥/٢٣٨) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.تفسير مقاتل بن سليمان ٤/٥٨١.أخرجه ابن أبي شيبة ١٣/٢٣٢.
79,46," <q>﴿كَأَنَّهُمۡ یَوۡمَ یَرَوۡنَهَا لَمۡ یَلۡبَثُوۤا۟ إِلَّا عَشِیَّةً أَوۡ ضُحَىٰهَا ۝٤٦﴾</q> - تفسير ٨١٤١٢- عن عبد الله بن عباس، قال: <q>﴿كَأَنَّهُمْ يَوْمَ يَرَوْنَها﴾</q> يعني: يرون القيامة <q>﴿لَمْ يَلْبَثُوا﴾</q> في الدنيا، ولم يَنعموا بشيء مِن نعيمها، <q>﴿إلّا عَشِيَّةً﴾</q> ما بين الظهر إلى غروب الشمس، <q>﴿أوْ ضُحاها﴾</q> ما بين طلوع الشمس إلى نصف النهار{1}. (١٥/٢٣٦) ٨١٤١٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كَأَنَّهُمْ يَوْمَ يَرَوْنَها﴾</q> الآية، قال: تَدِقُّ الدنيا في أنفس القوم حين عاينوا أمر الآخرة{2}. (١٥/٢٣٧) ٨١٤١٤- قال مقاتل بن سليمان: ثم نَعتَ ذلك اليوم، فقال: <q>﴿كَأَنَّهُمْ يَوْمَ يَرَوْنَها﴾</q> الساعةَ يظنّون أنهم <q>﴿لَمْ يَلْبَثُوا﴾</q> في الدنيا ونعيمها، <q>﴿إلّا عَشِيَّةً﴾</q> وهي ما بين صلاة العصر إلى أن تغيب الشمس، <q>﴿أوْ ضُحاها﴾</q> يقول: أو ما بين طلوع الشمس إلى أن ترتفع الشمس على قدْر عَشيّة الدنيا أو ضُحى الدنيا{3}. (ز) ٨١٤١٥- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿إلّا عَشِيَّةً﴾</q> قال: من الدنيا، <q>﴿أوْ ضُحاها﴾</q> قال: العَشِيّة{4}. (١٥/٢٣٧) <q>﴿كَأَنَّهُمۡ یَوۡمَ یَرَوۡنَهَا لَمۡ یَلۡبَثُوۤا۟ إِلَّا عَشِیَّةً أَوۡ ضُحَىٰهَا ۝٤٦﴾</q> - آثار متعلقة بالآية ٨١٤١٦- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال:إذا عَسِر على المرأة ولدها، فيُكتب هاتين الآيتين والكلمات في صَحْفَة، ثم تُغسل، فتُسقى منها: بسم الله الذي لا إله إلا هو الحليم الكريم، سبحان الله ربّ السماوات السبع، وربّ العرش العظيم، <q>﴿كَأَنَّهُمْ يَوْمَ يَرَوْنَها لَمْ يَلْبَثُوا إلّا عَشِيَّةً أوْ ضُحاها﴾</q>، <q>﴿كَأَنَّهُمْ يَوْمَ يَرَوْنَ ما يُوعَدُونَ لَمْ يَلْبَثُوا إلّا ساعَةً مِن نَهارٍ بَلاغٌ فَهَلْ يُهْلَكُ إلّا القَوْمُ الفاسِقُونَ﴾</q> [الأحقاف:٣٥]{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه عبد الرزاق ٢/٣٤٧ من طريق معمر بنحوه، وابن جرير ٢٤/١٠١ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٨١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٥/٣٩ (٢٣٥٠٨) واللفظ له، والبيهقي في الدعوات الكبير ٢/١٩٨ (٥٦٥)، والثعلبي ٩/٢٧، من طريق محمد بن عبد الرحمن بن أبي ليلى، عن الحكم بن عُتيبة، عن سعيد بن جُبَير، عن ابن عباس به. وفي سنده محمد بن عبد الرحمن بن أبي ليلى، قال عنه ابن حجر في التقريب (٦٠٨١): «صدوق سيء الحفظ جدًّا».
