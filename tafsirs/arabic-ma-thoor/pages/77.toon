ابن جرير ٦/٤٠٩، وابن المنذر (١٣٦٨)، وابن أبي حاتم ٣/٨٦٧، والبيهقي في سُنَنِه ٦/٥٩.أخرجه ابن أبي حاتم ٣/٨٦٧.أخرجه ابن جرير ٦/٤١٠.أخرجه عبد بن حميد كما في قطعة من تفسيره ص٧٤، وأخرج عبد الرزاق ١/١٤٦ نحوه، وابن جرير ٦/٤١٠ من طريق معمر.أخرجه ابن جرير ٦/٤١٠. وعلَّقه ابن أبي حاتم ٣/٨٦٧.تفسير مقاتل بن سليمان ١/٣٥٨.أخرجه ابن جرير ٦/٤١٠.أخرجه البخاري ٣/٧٩ (٢٢١٢)، ٤/١٠ (٢٧٦٥)، ٦/٤٣ (٤٥٧٥)، وابن جرير ٦/٤٢٥، وابن المنذر ٢/٥٧٢ (١٣٨٧)، وابن أبي حاتم ٣/٨٦٩ (٤٨١٥، ٤٨٢٣، ٤٨٢٧).علَّقه ابن أبي حاتم ٣/٨٦٩.أورده يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣٤٨-. في إسناده عبد الله بن لهيعة، قال عنه ابن حجر في التقريب (٣٥٨٧): «صدوق، خلط بعد احتراق كتبه، ورواية ابن المبارك وابن وهب عنه أعدل من غيرهما». وليس هذا من روايتهما عنه.أخرجه ابن جرير ٦/٤٢٣.أخرجه ابن المنذر ٢/٥٧٠.أخرجه ابن جرير ٦/٤١١، وابن أبي حاتم ٣/٨٦٨، وابن المنذر ٢/٥٧٦ عن الحكم، والنحاس في ناسخه (٢٩٩)، والحاكم ٢/٣٠٢. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٣/٨٦٨.أخرجه ابن أبي حاتم ٣/٨٦٧.علَّقه ابن أبي حاتم ٣/٨٦٧.أخرجه ابن جرير ٦/٤١١. وعلَّقه ابن أبي حاتم ٣/٨٦٨.أخرجه ابن المنذر ٢/٥٧٠. وعلَّقه ابن أبي حاتم ٣/٨٦٨.أخرجه ابن المنذر ٢/٥٧٠، ٥٧٣.أخرجه ابن أبي حاتم ٣/٨٦٨.أخرجه ابن أبي حاتم ٣/٨٦٨.أخرجه عبد الرزاق ١/١٤٨.تفسير الثعلبي ٣/٢٥٩.تفسير مقاتل بن سليمان ١/٣٥٨.أخرجه ابن جرير ٦/٤٢٦.ولا متأثل: أي: غير جامع. النهاية (أثل).أخرجه أحمد ١١/٣٥٩ (٦٧٤٧)، ١١/٥٩٤ (٧٠٢٢)، وأبو داود ٤/٤٩٥ (٢٨٧٢)، والنسائي ٦/٢٥٦ (٣٦٦٨)، وابن ماجه ٤/٢١ (٢٧١٨). قال ابن حجر في الفتح ٨/٢٤١: «إسناده قوي».أخرجه ابن حبان ١٠/٥٤-٥٥ (٤٢٤٤). قال ابن عدي في الكامل في الضعفاء ٥/١١٢ (٩٢٢): «لا أعرفه إلا من هذا الطريق، وهو غريب، ولا أعلم يرويه عن أبي عامر غير جعفر بن سليمان». وقال أبو نعيم في الحلية ٣/٣٥١: «غريب من حديث عمرو عن جابر، تفرد به الخزاز، واسمه صالح بن رستم، من ثقات أهل البصرة». وقال الهيثمي في المجمع ٨/١٦٣ (١٣٥٢٨): «رواه الطبراني في الصغير، وفيه معلى بن مهدي، وثقه ابن حبان وغيره، وفيه ضعف، وبقية رجاله ثقات».أخرجه ابن أبي شيبة ٤/٣٩١ (٢١٣٧٧)، ٥/٣٤٠ (٢٦٦٨٧)، وسعيد بن منصور في التفسير من سننه ٣/١١٥٩ (٥٧٢)، وابن جرير ٦/٤٢٥. قال البيهقي السنن الكبرى ٦/٦ (١٠٩٩٤): «هذا مرسل». وقال الزيلعي في تخريج أحاديث الكشاف ١/٢٨٦: «مرسلًا». وقال البوصيري في إتحاف الخيرة ٣/٣١ (٢١٠٧): «رواه مسدد، ورجاله ثقات».جزازها: ما اجتزّ من النعجة ونحوها، فلم يخالطه شيء، سواءً كان صوفًا أو غيره. التاج (جزز).الرِّسْل: الهزيلة قليلة الشحم واللحم واللبن. التاج (رسل).عوارضها: جمع عارض، وهي الناقة المريضة، أو التي أصابها كسر. النهاية (عرض).أخرجه ابن منده في معرفة الصحابة ص٣٥٠، وأبو نعيم في معرفة الصحابة ١/٤٧٧-٤٧٨ (١٣٦١)، وابن جرير ٦/٤٢٢. قال ابن الأثير في أسد الغابة ١/٤٤١: «ثابت بن رفاعة الأنصاري له ذكر في حديث رواه قتادة مرسلًا». وقال ابن حجر في الإصابة ١/٥٠٤ (٨٨٤) في ترجمة ثابت بن رفاعة: «هذا مرسل، رجاله ثقات».أخرجه عبد الرزاق (١٠١٢٨، ١٩٢٧٦) من طريق أبي مجلز، وسعيد بن منصور (٧٨٨ - تفسير)، وابن سعد ٣/٢٧٦، وابن أبي شيبة ١٢/٣٢٤، وابن جرير ٦/٤١٢، والنحاس في ناسخه ص٢٩٦، وابن المنذر ٢/٥٧٤، والبيهقي في سُنَنِه ٦/٣٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي الدنيا.أخرجه ابن جرير ٦/٤٢٥.أخرجه ابن جرير ٦/٤١١، وابن أبي حاتم ٣/٨٦٩، وابن المنذر ٢/٥٧٦ عن الحكم، والنحاس في ناسخه (٢٩٩)، والحاكم ٢/٣٠٢. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٣/٨٦٩.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٢٦٧-، وعبد بن حُمَيد كما في قطعة من تفسيره ص٧٦، والبيهقي ٦/٥.أخرجه ابن جرير ٦/٤١٤.أخرجه سعيد بن منصور (٥٧٠ - تفسير)، وابن المنذر ٢/٥٧٢، والبيهقي ٦/٤. وعزاه السيوطي إلى الفريابي.أخرجه ابن أبي حاتم ٣/٨٦٩. وابن جرير ٦/٤١٧ من طريق السدي عن ابن عباس. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٦/٤١٢.أخرجه ابن جرير ٦/٤١٣، وابن أبي حاتم ٣/٨٦٩.أخرجه ابن المنذر ٢/٥٧١-٥٧٢، والطبراني (١٣٠٢٠).هنأ الإبل يهنَأها -مثلث العين-: طلاها بالهِناء، وهو القطران. اللسان (هنأ).لاط الحوض يلوطه ويليطه: أصلحه بالطين. اللسان (لوط).أخرجه سفيان الثوري في تفسيره ص٩١، ومالك ٢/٩٣٤، وسعيد بن منصور (٥٧١ - تفسير)، وابن جرير ٦/٤٢٠، وابن المنذر ٢/٥٧١، والنحاس في ناسخه ص٢٩٨.وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/١٤٨.أخرجه ابن جرير ٦/٤١٢، كما أخرج عبد الرزاق ١/١٤٧ نحوه مختصرًا، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/١٦٣ (٢١٧٩٤). وعلَّقه ابن أبي حاتم ٣/٨٦٩.أخرجه ابن جرير ٦/٤١٦. وعلَّقه ابن أبي حاتم ٣/٨٦٩.أ