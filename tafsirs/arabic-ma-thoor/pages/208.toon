quran[6]{c,v,t}:
  10,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٣٤١١٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيْف، عن مجاهد-: مكية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١١٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو، عن مجاهد- قال: نزلت سورةُ يونس بمكة{2}. (٧/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١١٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد بني إسرائيل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١١٦<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: أُنزِلت يونس بمكة{4}. (٧/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١١٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١١٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية، وذكراها باسم: التاسعة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١١٩<span class="dash">-</span></span> عن قتادة بن دعامة: مكية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٠<span class="dash">-</span></span> عن محمد ابن شهاب الزهري: مكية، ونزلت بعد بني إسرائيل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢١<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٢<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة يونس كلها مكية، غير آيتين؛ وهما قوله تعالى: <span class="qpc-hafs">﴿فَإنْ كُنْتَ فِي شَكٍّ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فَتَكُونَ مِنَ الخاسِرِينَ﴾</span> [٩٤-٩٥]، فإنّهما مدنيتان، وجملتها مائة وتسع آيات في عدد الكوفي{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٣<span class="dash">-</span></span> عن أنس: سمِعتُ رسول الله ﷺ يقول: «<b>إنّ الله أعْطاني الراءات إلى الطَّواسين مكانَ الإنجيل</b>»{10}. (٧/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٤<span class="dash">-</span></span> عن واهب المعافري، أنّ رسول الله ﷺ قال: «<b>مَن أُقْرِئُه المُصْمَدَةَ</b>؟». فقال رجل: أنا، يا رسول الله. فأقرأه رسولُ الله سورة يونس، ثم قال: «<b>مَن أُقْرِئُه المُحَلِّيَةَ؟</b>». فقال رجل: أنا، يا رسول الله. فأقرأه طه، ثم قال: «<b>مَن أقرئه المُحَبِّرَةَ</b>؟». فقال رجل: أنا. فأقرأه: <span class="qpc-hafs">﴿هل أتى على الإنسان حين من الدهر﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٥<span class="dash">-</span></span> عن الأحْنَف، قال: صَلَّيتُ خلفَ <span class="name-1">عمر</span> الغداةَ، فقرأ بيونس، وهود، وغيرِهما{12}. (٧/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span>، قال: كانت سورة يونس تُعَدُّ السابعةَ{13}. (٧/٦٢٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿الۤرۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿الر﴾</span>، قال: فواتِحُ السُّوَرِ أسماءٌ مِن أسماءِ الله{4}. (٧/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الضُّحى- في قوله: <span class="qpc-hafs">﴿الر﴾</span>، قال: أنا اللهُ أرى{15}. (٧/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span>، قال: اسمٌ مُقَطَّعٌ{4}. (٧/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span> حروفُ «الرحمنِ» مُفَرَّقَة{17}. (٧/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿الر﴾</span>، قال: أنا الله أرى{18}. (٧/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- قال: <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span> هو اسم الرحمن{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿الر﴾</span>، قال: هذا فواتِحُ يفتحُ اللهُ بها القرآن. قال: قلتُ: ألم تكن تَقُلِ: اسمًا؟ قال: لا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي رَوْق- في قوله: <span class="qpc-hafs">﴿الر﴾</span>، قال: أنا الله أرى{21}. (٧/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>=<span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span>: حروف «الرحمن» مُقَطَّعة، فإذا وُصِلَت كان: الرحمن{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن سالم- أنّه سُئِل عن <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ص﴾</span>. قال: هي أسماء الله مقطعة بالهجاء، فإذا وصلتها كانت اسمًا من أسماء الله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٧<span class="dash">-</span></span> عن <span class="name-2">سالم بن عبد الله بن عمر</span> -من طريق الحسين بن عثمان- قال: <span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿نون﴾</span>، فقال: اسم «الرحمن» مُقَطَّع، ثم قال: الرحمن{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لا أدري ما تفسير <span class="qpc-hafs">﴿الر﴾</span>، وأشباه ذلك! غير أنّ قومًا من السلف كانوا يقولون: أسماء السور، وفواتحها{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿الر﴾</span>، قال: اسمٌ مِن أسماء القرآن{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤٠<span class="dash">-</span></span> عن <span class="name-2">محمدِ بن كعب القُرَظيِّ</span>، في قوله: <span class="qpc-hafs">﴿الر﴾</span>، قال: ألفٌ، ولامٌ، وراءٌ من: الرحمن{13}. (٧/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤١<span class="dash">-</span></span> قال <span class="name-2">أبو روق عطية بن الحارث الهمداني</span>: فاتحة السورة{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تِلۡكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٤٢<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>: قوله <span class="qpc-hafs">﴿تِلْكَ﴾</span>، يعني: هذه{29}<span class=comment-ref>٣٠٩٣</span>. (٧/٦٢٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٣</span> ساق <u>ابنُ عطية</u> (٤/٤٤٥) هذا القول، ثم <span class="comment-type-4">قال</span>: «وقد يُشْبِه أن يتَّصل المعنى بـ<span class="qpc-hafs">﴿تلك﴾</span> دون أن نقدرها بدل غيرها، والنظر في هذه اللفظة إنّما يتركب على الخلاف في فواتح السور؛ فتَدَبَّره».</div></p><p><h3><span class="qpc-hafs">﴿ءَایَـٰتُ ٱلۡكِتَـٰبِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٤٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان-: <span class="qpc-hafs">﴿تِلْكَ آياتُ الكِتابِ الحَكِيمِ﴾</span>: التوراة، والإنجيل{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر- في هذه الآية: <span class="qpc-hafs">﴿الر تلك آيات الكتاب﴾</span>، قال: التوراة، والزَّبور{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿تِلْكَ ءاياتُ الكِتابِ﴾</span>، قال: الكُتُبُ التي خَلَتْ قبل القرآن{32}. (٧/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤٦<span class="dash">-</span></span> عن <span class="name-2">مطر الوراق</span> -من طريق ابن الحسين بن واقد- قال: <span class="qpc-hafs">﴿تلك آيات﴾</span>، قال: الزَّبور{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الر تِلْكَ آياتُ الكِتابِ الحَكِيمِ﴾</span>، يعني: المحكم، يقال: الألف واللام والراء، فهُنَّ آيات الكتاب، يعني: علامات الكتاب، يعني: القرآن{34}<span class=comment-ref>٣٠٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٤</span> اختُلفِ في المراد بالكتاب؛ فقال قوم: التوراة والإنجيل. و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٢/١٠٥-١٠٦بتصرف) قولًا آخر بأنّه القرآن، ولم ينسبه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> القول الثاني <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وأولى التأويلين في ذلك بالصواب تأويلُ مَن تأوّله: هذه آيات القرآن. ووجّه معنى <span class="qpc-hafs">﴿تلك﴾</span> إلى معنى: هذه؛ لأنّه لم يجيء للْتوراة والإنجيل قبلُ ذكرٌ ولا تلاوةٌ بعدُ، فيوجه إليه الخبر».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٤/٤٤٥) فقال: «وهو الأظهر». ولم يذكر مستندًا.</p><p>و<span class="comment-type-2">انتَقَد</span> <u>ابنُ كثير</u> (٧/٣٣١) القولَ الأول، فقال: «وهذا القولُ لا أعرف وجهَه، ولا معناه».</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡحَكِیمِ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٤٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: حَكَم فيه بالعدل، والإحسان، وإيتاء ذي القربى، وحكم فيه بالنهي عن الفحشاء، والمنكر، والبغي، وحكم فيه بالجنة لمن أطاعه، وبالنار لمن عصاه{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٤٩<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: حكيم بما حَكَم فيه من الأرزاق، والآجال بما شاء{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الحكيم﴾</span>، يعني: المُحْكَم من الباطل، ولا كَذِب فيه، ولا اختلاف{34}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.|2:أخرجه النحاس في ناسخه ص٥٢٩. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:عزاه السيوطي إلى ابن مردويه.|5:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣، وقال: التاسعة يريد بها سورة يونس.|6:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.|7:تنزيل القرآن ص٣٧-٤٢.|8:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|9:تفسير مقاتل بن سليمان ٢/٢٢٤.|10:أخرجه محمد بن نصر المروزي في قيام الليل ص١٧٠. وعزاه السيوطي إلى ابن مردويه.</p><p>قال الألباني في الضعيفة ١٤/١١٨٦ (٧٠٨١): «منكر جدًّا».|11:أخرجه عبد الله بن وهب في الجامع من تفسير القرآن ٣/٣٥-٣٦ (٥٧) مرسلًا.|12:أخرجه ابن أبي شيبة في المصنف ١/٣٥٣.|13:عزاه السيوطي إلى أبي الشيخ.|14:عزاه السيوطي إلى ابن مردويه.|15:أخرجه ابن جرير ١٢/١٠٣، وابن أبي حاتم ٦/١٩٢١، ١٩٩٤، ٧/٢٠٩٨، والبيهقي في الأسماء والصفات (١٦٧)، وابن النجار في تاريخه ١٧/٣-٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|16:عزاه السيوطي إلى ابن مردويه.|17:أخرجه ابن جرير ١٢/١٠٤، وابن أبي حاتم ٦/١٩٢١، ١٩٩٤، ٧/٢٠٩٨. وعزاه السيوطي إلى أبي الشيخ.|18:عزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن جرير ١٢/١٠٤.|20:أخرجه ابن أبي حاتم ٦/١٩٩٤.|21:أخرجه ابن جرير ١٢/١٠٣، وابن حاتم ٦/١٩٢١، ١٩٩٤، ٧/٢٠٩٨.|22:تفسير الثعلبي ٥/١١٦.|23:أخرجه ابن جرير ١٢/١٠٤.|24:أخرجه ابن جرير ١٢/١٠٤. وعلَّقه ابن أبي حاتم ٦/١٩٢١.|25:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٤٣-.|26:أخرجه ابن جرير ١٢/١٠٤، وابن أبي حاتم ٦/١٩٢١.|27:عزاه السيوطي إلى أبي الشيخ.|28:تفسير الثعلبي ٥/١١٦.|29:أخرجه ابن أبي حاتم ٦/١٩٢٢، ٧/٢٠٩٨.|30:أخرجه ابن جرير ١٢/١٠٥.|31:أخرجه ابن أبي حاتم ٦/١٩٢٢.|32:أخرجه ابن جرير ١٢/١٠٥، وابن أبي حاتم ٦/١٩٢٢.|33:أخرجه ابن أبي حاتم ٦/١٩٢٢.|34:تفسير مقاتل بن سليمان ٢/٢٢٥.|35:تفسير الثعلبي ٥/١١٧.|36:تفسير الثعلبي ٥/١١٧، وتفسير البغوي ٤/١١٧.|37:تفسير مقاتل بن سليمان ٢/٢٢٥.
  10,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَكَانَ لِلنَّاسِ عَجَبًا أَنۡ أَوۡحَیۡنَاۤ إِلَىٰ رَجُلࣲ مِّنۡهُمۡ أَنۡ أَنذِرِ ٱلنَّاسَ وَبَشِّرِ ٱلَّذِینَ ءَامَنُوۤا۟ أَنَّ لَهُمۡ قَدَمَ صِدۡقٍ عِندَ رَبِّهِمۡۗ قَالَ ٱلۡكَـٰفِرُونَ إِنَّ هَـٰذَا لَسَـٰحِرࣱ مُّبِینٌ ۝٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٤١٥١<span class="dash">-</span></span> عن زائدة، قال: قرأ <span class="name-2">سليمانُ [الأعمش]</span> في يونس عندَ الآيتَين: (ساحِرٌ مُّبِينٌ){1}. (٧/٦٣٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَكَانَ لِلنَّاسِ عَجَبًا أَنۡ أَوۡحَیۡنَاۤ إِلَىٰ رَجُلࣲ مِّنۡهُمۡ أَنۡ أَنذِرِ ٱلنَّاسَ وَبَشِّرِ ٱلَّذِینَ ءَامَنُوۤا۟ أَنَّ لَهُمۡ قَدَمَ صِدۡقٍ عِندَ رَبِّهِمۡۗ قَالَ ٱلۡكَـٰفِرُونَ إِنَّ هَـٰذَا لَسَـٰحِرࣱ مُّبِینٌ ۝٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: لَمّا بعَث اللهُ محمدًا ﷺ رسولًا أنكَرَتِ العربُ ذلك، أو مَن أنكر منهم، فقالوا: اللهُ أعظمُ مِن أن يكونَ رسولُه بشرًا مثلَ محمدٍ. فأنزل الله: <span class="qpc-hafs">﴿أكانَ لِلنّاسِ عَجَبًا أنْ أوْحَيْنَآ إلى رَجُلٍ مِنهُم﴾</span> الآية، <span class="qpc-hafs">﴿ومَآ أرْسَلْنا قَبْلَكَ إلاَّ رِجالًا﴾</span> الآية [الأنبياء:٧]. فلمّا كَرَّر الله عليهم الحُجَجَ قالوا: وإذا كان بشرًا فغيرُ محمدٍ كان أحقَّ بالرسالةِ، <span class="qpc-hafs">﴿لَوْلا نُزِلَ هَذا القُرْءانُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span> [الزخرف:٣١]، يقول: أشرَفَ مِن محمدٍ، يَعْنون: الوليد بن المغيرة من مكة، ومسعود بن عمرو الثقفيَّ من الطائف؛ فأنزَل الله ردًا عليهم: <span class="qpc-hafs">﴿أهُمْ يَقسِمُونَ رَحْمَتَ رَبِكَ﴾</span> الآية [الزخرف:٣٢]{2}. (٧/٦٢٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَكَانَ لِلنَّاسِ عَجَبًا أَنۡ أَوۡحَیۡنَاۤ إِلَىٰ رَجُلࣲ مِّنۡهُمۡ أَنۡ أَنذِرِ ٱلنَّاسَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج-: عَجِبَتْ قريش أن بُعِث رجلٌ منهم. قال: ومثل ذلك: <span class="qpc-hafs">﴿وإلى عادٍ أخاهُمْ هُودًا﴾</span> [الأعراف:٦٥]، <span class="qpc-hafs">﴿وإلى ثَمُودَ أخاهُمْ صالِحًا﴾</span> [الأعراف:٧٣]، قال الله: <span class="qpc-hafs">﴿أوَعَجِبْتُمْ أنْ جاءَكُمْ ذِكْرٌ مِن رَبِّكُمْ عَلى رَجُلٍ مِنكُمْ﴾</span> [الأعراف:٦٣]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أكانَ لِلنّاسِ عَجَبًا﴾</span> يعني بالناس: كُفّار أهل مكة <span class="qpc-hafs">﴿عجبا أنْ أوْحَيْنا إلى رَجُلٍ مِنهُمْ﴾</span> يعني بالرَّجُل: محمدًا ﷺ، يعرفونه ولا ينكرونه: <span class="qpc-hafs">﴿أنْ أنْذِرِ﴾</span> يعني: حذِّر <span class="qpc-hafs">﴿النّاسَ﴾</span> عقوبةَ الله ﷿ ونِقْمَتَه إذا عَصَوْه{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلَّذِینَ ءَامَنُوۤا۟ أَنَّ لَهُمۡ قَدَمَ صِدۡقٍ عِندَ رَبِّهِمۡۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٥٥<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span> -من طريق أنس- في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: سَلَفَ صدقٍ{5}. (٧/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: القَدَم: هو العملُ الذي قدَّموا؛ قال الله: <span class="qpc-hafs">﴿ونَكْتُبُ ما قَدَّمُوا وءاثَرَهُم﴾</span> [يس:١٢]. والآثارُ: مَمْشاهم. قال: مشى رسول الله ﷺ بين أُسطُوانتين مِن مسجدهم، ثم قال: «<b>هذا أثَرٌ مكتوبٌ</b>»{6}. (٧/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٥٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، في قوله: <span class="qpc-hafs">﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: محمد شفيع لهم{7}. (٧/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٥٨<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدريِّ</span>، في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: محمد ﷺ شفيعُ صدقٍ لهم يومَ القيامةِ{7}. (٧/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وبَشِرِ الَّذِينَ ءامَنُوا أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: ما سَبَق لهم مِن السَّعادة في الذِّكْرِ الأوَّل{9}. (٧/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: أجرًا حسنًا؛ بما قدَّموا من أعمالِهم{10}. (٧/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: خَيْر{11}. (٧/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج -في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: سَلَفَ صِدْقٍ{12}. (٧/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الله بن كثير- <span class="qpc-hafs">﴿أن لهم قدم صدق عند ربهم﴾</span>، قال: الأعمال الصالحة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الوليد بن عبد الله بن أبي مغيث- <span class="qpc-hafs">﴿أن لهم قدم صدق عند ربهم﴾</span>، قال: صلاتهم، وصومهم، وصدقتهم، وتسبيحهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿أن لهم قدم صدق عند ربهم﴾</span>، قال: ثواب صِدْقٍ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أو <span class="name-2">قتادة بن دعامة</span> -من طريق عمرو بن الجَوْن- <span class="qpc-hafs">﴿أن لهم قدم صدق عند ربهم﴾</span>، قال: محمد شفيعٌ لهم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن الجَوْن- في قوله: <span class="qpc-hafs">﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: محمد ﷺ شفيعٌ لهم يومَ القيامة{17}. (٧/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: مصيبتُهم في نبيِّهم ﷺ{12}. (٧/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٦٩<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: مقام صدق لا زوال فيه، ولا بُؤْس، نعيمٌ مقيم، وخلود، وخلودٌ لا موت فيه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، أي: سَلَفَ صِدْقٍ{20}. (٧/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سهل بن عثمان، عن رجل سَمّاه- في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: يَقْدمون عليه عند ربِّهم{12}. (٧/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلمَ</span> -من طريق ابن عُيَيْنَة- في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: محمد ﷺ{22}. (٧/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>، قال: ثواب صدق{23}. (٧/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٤<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span>: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ﴾</span>: سابِقة صِدْق{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبَشِّرِ الَّذِينَ آمَنُوا﴾</span>، يعني: صدَّقوا بمحمد ﷺ، وبما في القرآن من الثواب؛ <span class="qpc-hafs">﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ﴾</span> يعني: سلفَ خير <span class="qpc-hafs">﴿عِنْدَ رَبِّهِمْ﴾</span> يعني: ثواب صدق يقدمون عليه، وهو الجَنَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق خالد بن صبيح البجلي- في قوله: <span class="qpc-hafs">﴿أن لهم قدم صدق عند ربهم﴾</span>، قال: محمد شفيع صدق{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وبشر الذين آمنوا أن لهم قدم صدق﴾</span>، قال: القَدَمُ الصِّدق: ثوابُ الصِّدق؛ بما قدَّموا من الأعمال{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٧٨<span class="dash">-</span></span> عن بَكّاِر بن مالك، في قوله: <span class="qpc-hafs">﴿قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</span>، قال: رسول الله ﷺ{28}<span class=comment-ref>٣٠٩٥</span>. (٧/٦٢٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٥</span> اختُلِف في معنى قوله: <span class="qpc-hafs">﴿قدم صدق﴾</span> على أقوال: <b>الأول</b>: الأعمال الصالحة من العبادات. <b>الثاني</b>: السعادة السابقة لهم في اللوح المحفوظ. <b>الثالث</b>: شفاعة النبي ﷺ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/١١١) <span class="mustanad">مستندًا إلى اللغة</span> القولَ الأول الذي قاله عبد الله بن عباس من طريق العوفي، والضحاك بن مزاحم، ومجاهد بن جبر، والربيع بن أنس، وعبد الرحمن بن زيد بن أسلم، فقال: «وذلك أنّه محكيٌّ عن العرب: هؤلاء أهْلُ القَدَم في الإسلام. أي: هؤلاء الذين قدَّموا فيه خيرًا، فكان لهم فيه تقديم. ويقال: له عندي قدم صِدْق، وقدم سوء، وذلك ما قدَّمت إليه من خير أو شر».</p><p>و<span class="comment-type-4">علَّق</span> عليه <u>ابنُ كثير</u> (٧/٣٣٢) بقوله: «وهذا <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿لِيُنْذِرَ بَأْسًا شَدِيدًا مِن لَدُنْهُ ويُبَشِّرَ المُؤْمِنِينَ الَّذِينَ يَعْمَلُونَ الصّالِحاتِ أنَّ لَهُمْ أجْرًا حَسَنًا ماكِثِينَ فِيهِ أبَدًا﴾</span> [الكهف:٢-٣]».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٤/٤٤٦) القول الثاني الذي قاله عبد الله بن عباس من طريق علي، فقال: «وهو أليق الأقوال بالآية». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٢/٣١بتصرف) أنّه لا يعارض بقية الأقوال، فقال: «فإنّه سبق لهم من الله في الذِّكْر الأوَّلِ السعادةُ بأعمالهم على يد محمد ﷺ، فهو خير تَقَدُّم لهم من الله، ثم قدَّمه لهم على يد رسوله، ثم يقدمهم عليه يوم لقائه».</div></p><p><h3><span class="qpc-hafs">﴿قَالَ ٱلۡكَـٰفِرُونَ إِنَّ هَـٰذَا لَسَـٰحِرࣱ مُّبِینٌ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿قال الكافرون إن هذا لساحر مبين﴾</span>؛ لزادهم ذلك تكذيبًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿قال الكافرون إن هذا لساحر مبين﴾</span>، فنظروا إليه، فلم يُصَدِّقوا به{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ الكافِرُونَ﴾</span> من أهل مكة، يعني: أبا جهل بن هشام، والوليد بن المغيرة، والعاص بن وائل السهمي، وعتبة وشيبة ابنا ربيعة، وأهل مكة <span class="qpc-hafs">﴿قالَ الكافِرُونَ إنَّ هذا لَساحِرٌ﴾</span> يعني: محمدًا ﷺ <span class="qpc-hafs">﴿مُبِينٌ﴾</span> يعني: بيِّن{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.</p><p>والآية الأخرى التي في هذه السورة هي قول قوم فرعون لموسى: <span class="qpc-hafs">﴿إنَّ هَذا لَسِحْرٌ مُّبِينٌ (٧٦)﴾</span>. وقد قرأ: <span class="qpc-hafs">﴿لَساحِرٌ﴾</span> بالألف في الآية الأولى ابن كثير، وعاصم، وحمزة، والكسائي، وخلف، وقرأ بقية العشرة: ‹لَسِحْرٌ› بغير ألف. انظر: النشر ٢/٢٥٦، والإتحاف ص٣٠٩. والآية الثانية ليس فيها خلاف بين العشرة، وما ورد فيها عن الأعمش فهي قراءة شاذة. انظر: المحتسب ١/٣١٦.|2:أخرجه ابن جرير ١٢/١٠٧، ١٤/٢٢٨، ٢٠/٥٨٣-٥٨٤، وابن أبي حاتم ٦/١٩٢٢ (١٠١٩٣)، من طريق بشر بن عمارة، عن أبي روق، عن الضحاك، عن ابن عباس به.</p><p>إسناده ضعيف جِدًّا؛ فيه بشر بن عمارة، قال عنه ابن حجر في التقريب (٦٩٧): «ضعيف». والضحّاك معروف بكثرة الإرسال، ولم يسمع من ابن عباس شيئًا، ولم يَرَه، كما في جامع التحصيل للعلائي ص١٩٩.|3:أخرجه ابن جرير ١٢/١٠٧.|4:تفسير مقاتل بن سليمان ٢/٢٢٥.|5:أخرجه الحاكم ٢/٣٣٨.|6:عزاه السيوطي إلى أبي الشيخ، وابن مردويه.|7:عزاه السيوطي إلى ابن مردويه.|8:عزاه السيوطي إلى ابن مردويه.|9:أخرجه ابن جرير ١٢/١١٠، وابن أبي حاتم ٦/١٩٢٢-١٩٢٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|10:أخرجه ابن جرير ١٢/١٠٨.|11:تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٠٩، وابن أبي حاتم ٦/١٩٢٣.|12:أخرجه ابن أبي حاتم ٦/١٩٢٣. وعزاه السيوطي إلى أبي الشيخ.|13:أخرجه ابن جرير ١٢/١٠٨.|14:أخرجه ابن جرير ١٢/١٠٨.|15:أخرجه ابن جرير ١٢/١٠٨.|16:أخرجه ابن جرير ١٢/١١٠.|17:أخرجه ابن جرير ١٢/١١٠. وعزاه السيوطي إلى أبي الشيخ.|18:أخرجه ابن أبي حاتم ٦/١٩٢٣. وعزاه السيوطي إلى أبي الشيخ.|19:تفسير الثعلبي ٥/١١٧، وتفسير البغوي ٤/١١٧.|20:أخرجه ابن جرير ١٢/١١١. وعزاه السيوطي إلى أبي الشيخ.|21:أخرجه ابن أبي حاتم ٦/١٩٢٣. وعزاه السيوطي إلى أبي الشيخ.|22:أخرجه ابن جرير ١٢/١١١.|23:أخرجه ابن جرير ١٢/١٠٩، وابن أبي حاتم ٦/١٩٢٣-١٩٢٤. وعزاه السيوطي إلى أبي الشيخ.|24:تفسير الثعلبي ٥/١١٧.|25:تفسير مقاتل بن سليمان ٢/٢٢٥.|26:أخرجه ابن أبي حاتم ٦/١٩٢٣.|27:أخرجه ابن جرير ١٢/١٠٩.|28:عزاه السيوطي إلى أبي الشيخ.|29:أخرجه ابن أبي حاتم ٦/١٩٢٤.|30:أخرجه ابن أبي حاتم ٦/١٩٢٤.|31:تفسير مقاتل بن سليمان ٢/٢٢٥.
  10,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكُمُ اللَّهُ الَّذِي خَلَقَ السَّماواتِ﴾</span> يوم الأحد، ويوم الاثنين، <span class="qpc-hafs">﴿و﴾</span> خلق <span class="qpc-hafs">﴿الأَرْضَ﴾</span> يوم الثلاثاء، ويوم الأربعاء، وما بينهما يوم الخميس، ويوم الجمعة؛ <span class="qpc-hafs">﴿فِي سِتَّةِ أيّامٍ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٨٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ابتَدَعَ السماواتِ والأرضَ، ولم يكونا إلّا بقُدْرَتِه، لم يستعن على ذلك بأحد من خلقه، ولم يُشْركه في شيء من أمره، بسلطانه القاهر، وقوله النافذ الذي يقول به لِما أراد أن يكون؛ يقول له: كُن. فيكون، ففرغ من خلق السماوات والأرض في ستة أيام{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی سِتَّةِ أَیَّامࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك بن مُزاحِم- <span class="qpc-hafs">﴿خلق السماوات والأرض في ستة أيام﴾</span>، قال: يوم مقداره ألف سنة{3}<span class=comment-ref>٣٠٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٤٨) أنّ هناك مَن قال بأنّها مِن أيام الآخرة، ثم قال: «وقال الجمهور -وهو الصواب-: بل من أيام الدنيا».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ اسْتَوى عَلى العَرْشِ﴾</span> فيها تقديم؛ ثُمَّ اسْتَوى على العَرْش، ثُمَّ خلق السموات والأرض{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُدَبِّرُ ٱلۡأَمۡرَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يُدَبِرُ الأَمْرَ﴾</span>، قال: يَقْضِيه وحده{5}<span class=comment-ref>٣٠٩٧</span>. (٧/٦٣٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٤٩) أنّ قوله: <span class="qpc-hafs">﴿يدبر الأمر﴾</span> يَصِحُّ أن يريد بـ<span class="qpc-hafs">﴿الأمر﴾</span> اسم الجنس من الأمور، ثم قال: «ويحتمل أن يريد الأمر الذي هو مصدر أمَرَ يأمرُ أمرًا، وتدبيره -لا إله إلا هو- إنّما هو الإنفاذ؛ لأنّه قد أحاط بكل شيء علمًا».</div></p><p><div></p><p><p><span class="item-no">٣٤١٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُدَبِّرُ الأَمْرَ﴾</span>، يقضي القضاء وحده، لا يُدَبِّرُه غيره{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا مِن شَفِیعٍ إِلَّا مِنۢ بَعۡدِ إِذۡنِهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- قال: مَن يتكلم عنده إلا بإذنه؟!{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما مِن شَفِيعٍ﴾</span> من الملائكة لبني آدم <span class="qpc-hafs">﴿إلّا مِن بَعْدِ إذْنِهِ﴾</span> يعني: لا يشفع أحدٌ إلا بإذنه، ولا يشفعون إلا لأهل التوحيد، فذلك قوله: <span class="qpc-hafs">﴿إلّا مِن بَعْدِ أنْ يَأْذَنَ اللَّهُ لِمَن يَشاءُ ويَرْضى﴾</span> [النجم:٢٦]، فرَضِي اللهُ للملائكة أن يشفعوا للمُوَحِّدين{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُمُ ٱللَّهُ رَبُّكُمۡ فَٱعۡبُدُوهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ذلِكُمُ اللَّهُ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿رَبُّكُمْ فاعْبُدُوهُ﴾</span> يعني: فوحِّدوه، ولا تشركوا به شيئًا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَلَا تَذَكَّرُونَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تَذَكَّرُونَ﴾</span> في ربوبيته، ووَحْدانِيَّته{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قوله: <span class="qpc-hafs">﴿تذكرون﴾</span>، قال: أهل الذِّكر هم أهل القرآن{11}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.|2:أخرجه ابن أبي حاتم ٦/١٩٢٤، ٢٠٠٤، ٨/٢٧١٣.|3:أخرجه ابن أبي حاتم ٦/١٩٢٥.|4:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.</p><p><b>وقد تقدم تفسير الآية في سورة الأعراف آية ٥٤ بما يغني عن إعادته.</b>|5:تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١١٤، ١١٦، وابن أبي حاتم ٦/١٩٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.|7:أخرجه ابن أبي حاتم ٦/١٩٢٦. وأخرجه أيضًا ٢/٢٨٨ عند قوله تعالى: <span class="qpc-hafs">﴿من ذا الذي يشفع عنده إلا بإذنه﴾</span> [البقرة:١٥٥].|8:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.|9:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.|10:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.|11:أخرجه ابن أبي حاتم ٦/١٩٢٦.
  10,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَیۡهِ مَرۡجِعُكُمۡ جَمِیعࣰاۖ وَعۡدَ ٱللَّهِ حَقًّاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٩٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي سنان- <span class="qpc-hafs">﴿إليه مرجعكم جميعا﴾</span>، قال: البَرُّ، والفاجر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلَيْهِ مَرْجِعُكُمْ جَمِيعًا﴾</span> بعد الموت، <span class="qpc-hafs">﴿وعْدَ اللَّهِ حَقًّا﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ یَبۡدَؤُا۟ ٱلۡخَلۡقَ ثُمَّ یُعِیدُهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إنَّهُ يَبْدَؤُا الخَلْقَ ثُمَّ يُعِيدُهُ﴾</span>، قال: يُحْيِيه، ثم يُمِيتُه، ثم يُحْيِيه{3}. (٧/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُ يَبْدَؤُا الخَلْقَ ثُمَّ يُعِيدُهُ﴾</span>، ولم يكُ شيئًا، كذلك يعيده من بعد الموت{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِیَجۡزِیَ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ بِٱلۡقِسۡطِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤١٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قوله: <span class="qpc-hafs">﴿بالقسط﴾</span>، قال: بالعَدْل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١٩٩<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، بمثل ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بالقسط﴾</span>: بالعدل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِيَجْزِيَ﴾</span> يعني: لكي يثيب في البعث <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا﴾</span> يعني: صَدَّقوا، <span class="qpc-hafs">﴿وعَمِلُوا الصّالِحاتِ﴾</span> يعني: وأقاموا الفرائض <span class="qpc-hafs">﴿بِالقِسْطِ﴾</span> يعني: بالحقِّ، وبالعدل، وثوابهم الجنة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ كَفَرُوا۟ لَهُمۡ شَرَابࣱ مِّنۡ حَمِیمࣲ وَعَذَابٌ أَلِیمُۢ بِمَا كَانُوا۟ یَكۡفُرُونَ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span> يجزي <span class="qpc-hafs">﴿الَّذِينَ كَفَرُوا﴾</span> بتوحيد الله <span class="qpc-hafs">﴿لَهُمْ شَرابٌ مِن حَمِيمٍ﴾</span> وذلك الشراب قد أُوقِد عليه منذ يوم خلقها الله ﷿ إلى يوم يدخلها أهلها، فقد انتهى حرُّها، <span class="qpc-hafs">﴿وعَذابٌ ألِيمٌ﴾</span> يعني: وجيع. نظيرها في الواقعة: <span class="qpc-hafs">﴿فَنُزُلٌ مِن حَمِيمٍ (٩٣)﴾</span>. <span class="qpc-hafs">﴿بِما كانُوا يَكْفُرُونَ﴾</span> بتوحيد الله ﷿{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٢٦.|2:تفسير مقاتل بن سليمان ٢/٢٢٦.|3:تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١١٦، وابن أبي حاتم ٦/١٩٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|4:تفسير مقاتل بن سليمان ٢/٢٢٦.|5:أخرجه ابن أبي حاتم ٦/١٩٢٧.|6:علَّقه ابن أبي حاتم ٦/١٩٢٧.|7:أخرجه ابن جرير ١٢/١١٧. وعلَّقه ابن أبي حاتم ٦/١٩٢٧.|8:تفسير مقاتل بن سليمان ٢/٢٢٦.|9:تفسير مقاتل بن سليمان ٢/٢٢٦.
  10,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی جَعَلَ ٱلشَّمۡسَ ضِیَاۤءࣰ وَٱلۡقَمَرَ نُورࣰا وَقَدَّرَهُۥ مَنَازِلَ لِتَعۡلَمُوا۟ عَدَدَ ٱلسِّنِینَ وَٱلۡحِسَابَۚ مَا خَلَقَ ٱللَّهُ ذَ ٰ⁠لِكَ إِلَّا بِٱلۡحَقِّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٠٣<span class="dash">-</span></span> عن ابن مسعود: سمِعتُ رسولَ الله ﷺ يقول: «<b>تكَلَّم ربُّنا بكلمتَين، فصارَت إحداهما شمسًا، والأخرى قمرًا، وكانا من النورِ جميعًا، ويَعُودان إلى الجنَّة يومَ القيامة</b>»{1}. (٧/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿هُوَ الَّذِى جَعَلَ الشَّمْسَ ضِيَآءً والقَمَرَ نُورًا﴾</span>، قال: وجوهُهما إلى السمواتِ، وأَقْفِيتُهما إلى الأرض{2}. (٧/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٠٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿جَعَلَ الشَّمْسَ ضِيَآءً والقَمَرَ نُورًا﴾</span>، قال: ولم يجعلِ الشمسَ كهيئةِ القمر؛ لكي يُعْرَفَ الليلُ مِن النهارِ، وهو قوله: <span class="qpc-hafs">﴿فَمَحَوْنَآ ءايَةَ الَّيْلَ﴾</span> الآية [الإسراء:١٢]{3}. (٧/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُوَ الَّذِي جَعَلَ الشَّمْسَ ضِياءً﴾</span> بالنهار لأهل الأرض يستضيئون بها، <span class="qpc-hafs">﴿والقَمَرَ نُورًا﴾</span> بالليل، <span class="qpc-hafs">﴿وقَدَّرَهُ مَنازِلَ﴾</span> يزيد وينقص، يعني: الشمس سراجًا، والقمر نورًا؛ <span class="qpc-hafs">﴿لِتَعْلَمُوا﴾</span> بالليل والنهار <span class="qpc-hafs">﴿عَدَدَ السِّنِينَ والحِسابَ﴾</span>، وقَدَّره منازل؛ لتعلموا بذلك عدد السنين، والحساب، ورمضان، والحج، والطلاق، وما يريدون بين العباد، <span class="qpc-hafs">﴿ما خَلَقَ اللَّهُ ذلِكَ﴾</span> يعني: الشمس والقمر <span class="qpc-hafs">﴿إلّا بِالحَقِّ﴾</span> لم يخلقهما عبثًا، خلقهما لأمر هو كائن{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿يفصل الآيات﴾</span>، أمّا نُفَصِّل: نُبَيِّن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُفَصِّلُ﴾</span>: يبيِّن <span class="qpc-hafs">﴿الآياتِ﴾</span> يعني: العلامات <span class="qpc-hafs">﴿لِقَوْمٍ يَعْلَمُونَ﴾</span> بتوحيد الله ﷿ أنّ الله واحد؛ لِما يَرَوْن من صُنعه{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span>، قال: الشمسُ والقمرُ وجوهُهما إلى العرشِ، وأَقْفِيتُهما إلى الأرض{1}. (٧/٦٣١)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى أبي الشيخ، وابن مردويه.|3:أخرجه ابن أبي حاتم ٦/١٩٢٧. وعزاه السيوطي إلى أبي الشيخ.|4:تفسير مقاتل بن سليمان ٢/٢٢٦-٢٢٧.|5:أخرجه ابن أبي حاتم ٦/١٩٢٨.|6:تفسير مقاتل بن سليمان ٢/٢٢٦-٢٢٧.|7:عزاه السيوطي إلى ابن مردويه.
  10,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ وَمَا خَلَقَ ٱللَّهُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَّقُونَ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ فِي اخْتِلافِ اللَّيْلِ والنَّهارِ﴾</span> عليكم، <span class="qpc-hafs">﴿وما خَلَقَ اللَّهُ فِي السَّماواتِ والأَرْضِ لَآياتٍ لِقَوْمٍ يَتَّقُونَ﴾</span> عقوبةَ الله ﷿{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ وَمَا خَلَقَ ٱللَّهُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَّقُونَ ۝٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢١١<span class="dash">-</span></span> عن خليفةَ العَبْديِّ، قال: لو أنّ الله -تَبارَك وتعالى- لم يُعْبَدْ إلا عن رؤيةٍ ما عبَده أحدٌ، ولكن المؤمنون تفكَّروا في مَجِيء هذا الليلِ إذا جاء، فمَلَأَ كلَّ شيءٍ، وغَطّى كلَّ شيءٍ، وفي مجيءِ سُلطانِ النهارِ إذا جاء، فمحا سُلطانَ الليلِ، وفي السحابِ المُسَخَّرِ بين السماء والأرض، وفي النجوم، وفي الشتاء، والصيف، فواللهِ، ما زال المؤمنون يَتَفَكَّرون فيما خلق ربُّهم -تَبارَك وتعالى- حتى أيْقَنَتْ قلوبُهم بربِّهم ﷿، وكأنّما عبَدُوا الله عن رؤية{2}. (٧/٦٣٢)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٧.|2:أخرجه أبو الشيخ في العظمة (٦٤).