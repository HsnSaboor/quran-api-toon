quran[6]{c,v,t}:
10,1," مقدمة السورة ٣٤١١٣- عن عبد الله بن عباس -من طريق خُصَيْف، عن مجاهد-: مكية{1}. (ز) ٣٤١١٤- عن عبد الله بن عباس -من طريق أبي عمرو، عن مجاهد- قال: نزلت سورةُ يونس بمكة{2}. (٧/٦٢٥) ٣٤١١٥- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد بني إسرائيل{3}. (ز) ٣٤١١٦- عن عبد الله بن الزبير، قال: أُنزِلت يونس بمكة{4}. (٧/٦٢٥) ٣٤١١٧- عن عكرمة مولى ابن عباس= (ز) ٣٤١١٨- والحسن البصري -من طريق يزيد النحوي-: مكية، وذكراها باسم: التاسعة{5}. (ز) ٣٤١١٩- عن قتادة بن دعامة: مكية{6}. (ز) ٣٤١٢٠- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد بني إسرائيل{7}. (ز) ٣٤١٢١- عن علي بن أبي طلحة: مكية{8}. (ز) ٣٤١٢٢- قال مقاتل بن سليمان: سورة يونس كلها مكية، غير آيتين؛ وهما قوله تعالى: <q>﴿فَإنْ كُنْتَ فِي شَكٍّ﴾</q> إلى قوله: <q>﴿فَتَكُونَ مِنَ الخاسِرِينَ﴾</q> [٩٤-٩٥]، فإنّهما مدنيتان، وجملتها مائة وتسع آيات في عدد الكوفي{9}. (ز) ٣٤١٢٣- عن أنس: سمِعتُ رسول الله ﷺ يقول: «إنّ الله أعْطاني الراءات إلى الطَّواسين مكانَ الإنجيل»{10}. (٧/٦٢٥) ٣٤١٢٤- عن واهب المعافري، أنّ رسول الله ﷺ قال: «مَن أُقْرِئُه المُصْمَدَةَ؟». فقال رجل: أنا، يا رسول الله. فأقرأه رسولُ الله سورة يونس، ثم قال: «مَن أُقْرِئُه المُحَلِّيَةَ؟». فقال رجل: أنا، يا رسول الله. فأقرأه طه، ثم قال: «مَن أقرئه المُحَبِّرَةَ؟». فقال رجل: أنا. فأقرأه: <q>﴿هل أتى على الإنسان حين من الدهر﴾</q>{11}. (ز) ٣٤١٢٥- عن الأحْنَف، قال: صَلَّيتُ خلفَ عمر الغداةَ، فقرأ بيونس، وهود، وغيرِهما{12}. (٧/٦٢٥) ٣٤١٢٦- عن محمد بن سيرين، قال: كانت سورة يونس تُعَدُّ السابعةَ{13}. (٧/٦٢٥) <q>﴿الۤرۚ﴾</q> - تفسير ٣٤١٢٧- عن عبد الله بن عباس، في قوله: <q>﴿الر﴾</q>، قال: فواتِحُ السُّوَرِ أسماءٌ مِن أسماءِ الله{4}. (٧/٦٢٥) ٣٤١٢٨- عن عبد الله بن عباس -من طريق أبي الضُّحى- في قوله: <q>﴿الر﴾</q>، قال: أنا اللهُ أرى{15}. (٧/٦٢٥) ٣٤١٢٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ن﴾</q>، قال: اسمٌ مُقَطَّعٌ{4}. (٧/٦٢٦) ٣٤١٣٠- عن عبد الله بن عباس -من طريق عكرمة- قال: <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ن﴾</q> حروفُ «الرحمنِ» مُفَرَّقَة{17}. (٧/٦٢٦) ٣٤١٣١- عن سعيد بن جبير، في قوله: <q>﴿الر﴾</q>، قال: أنا الله أرى{18}. (٧/٦٢٦) ٣٤١٣٢- عن سعيد بن جبير -من طريق عطاء بن السائب- قال: <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ن﴾</q> هو اسم الرحمن{19}. (ز) ٣٤١٣٣- قال مجاهد بن جبر -من طريق ابن جريج- <q>﴿الر﴾</q>، قال: هذا فواتِحُ يفتحُ اللهُ بها القرآن. قال: قلتُ: ألم تكن تَقُلِ: اسمًا؟ قال: لا{20}. (ز) ٣٤١٣٤- عن الضحاك بن مزاحم -من طريق أبي رَوْق- في قوله: <q>﴿الر﴾</q>، قال: أنا الله أرى{21}. (٧/٦٢٦) ٣٤١٣٥- عن عكرمة مولى ابن عباس=<q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ن﴾</q>: حروف «الرحمن» مُقَطَّعة، فإذا وُصِلَت كان: الرحمن{22}. (ز) ٣٤١٣٦- عن عامر الشعبي -من طريق إسماعيل بن سالم- أنّه سُئِل عن <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿ص﴾</q>. قال: هي أسماء الله مقطعة بالهجاء، فإذا وصلتها كانت اسمًا من أسماء الله{19}. (ز) ٣٤١٣٧- عن سالم بن عبد الله بن عمر -من طريق الحسين بن عثمان- قال: <q>﴿الر﴾</q>، و<q>﴿حم﴾</q>، و<q>﴿نون﴾</q>، فقال: اسم «الرحمن» مُقَطَّع، ثم قال: الرحمن{24}. (ز) ٣٤١٣٨- قال الحسن البصري: لا أدري ما تفسير <q>﴿الر﴾</q>، وأشباه ذلك! غير أنّ قومًا من السلف كانوا يقولون: أسماء السور، وفواتحها{25}. (ز) ٣٤١٣٩- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿الر﴾</q>، قال: اسمٌ مِن أسماء القرآن{26}. (ز) ٣٤١٤٠- عن محمدِ بن كعب القُرَظيِّ، في قوله: <q>﴿الر﴾</q>، قال: ألفٌ، ولامٌ، وراءٌ من: الرحمن{13}. (٧/٦٢٦) ٣٤١٤١- قال أبو روق عطية بن الحارث الهمداني: فاتحة السورة{22}. (ز) <q>﴿تِلۡكَ﴾</q> - تفسير ٣٤١٤٢- عن أبي مالك غزوان الغفاري: قوله <q>﴿تِلْكَ﴾</q>، يعني: هذه{29}٣٠٩٣. (٧/٦٢٦) ٣٠٩٣ ساق ابنُ عطية (٤/٤٤٥) هذا القول، ثم قال: «وقد يُشْبِه أن يتَّصل المعنى بـ<q>﴿تلك﴾</q> دون أن نقدرها بدل غيرها، والنظر في هذه اللفظة إنّما يتركب على الخلاف في فواتح السور؛ فتَدَبَّره». <q>﴿ءَایَـٰتُ ٱلۡكِتَـٰبِ﴾</q> - تفسير ٣٤١٤٣- قال مجاهد بن جبر -من طريق سفيان-: <q>﴿تِلْكَ آياتُ الكِتابِ الحَكِيمِ﴾</q>: التوراة، والإنجيل{30}. (ز) ٣٤١٤٤- عن الحسن البصري -من طريق أبي بكر- في هذه الآية: <q>﴿الر تلك آيات الكتاب﴾</q>، قال: التوراة، والزَّبور{31}. (ز) ٣٤١٤٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿تِلْكَ ءاياتُ الكِتابِ﴾</q>، قال: الكُتُبُ التي خَلَتْ قبل القرآن{32}. (٧/٦٢٧) ٣٤١٤٦- عن مطر الوراق -من طريق ابن الحسين بن واقد- قال: <q>﴿تلك آيات﴾</q>، قال: الزَّبور{31}. (ز) ٣٤١٤٧- قال مقاتل بن سليمان: <q>﴿الر تِلْكَ آياتُ الكِتابِ الحَكِيمِ﴾</q>، يعني: المحكم، يقال: الألف واللام والراء، فهُنَّ آيات الكتاب، يعني: علامات الكتاب، يعني: القرآن{34}٣٠٩٤. (ز) ٣٠٩٤ اختُلفِ في المراد بالكتاب؛ فقال قوم: التوراة والإنجيل. وذكر ابنُ جرير (١٢/١٠٥-١٠٦بتصرف) قولًا آخر بأنّه القرآن، ولم ينسبه. ورجَّح ابنُ جرير القول الثاني مستندًا إلى السياق، فقال: «وأولى التأويلين في ذلك بالصواب تأويلُ مَن تأوّله: هذه آيات القرآن. ووجّه معنى <q>﴿تلك﴾</q> إلى معنى: هذه؛ لأنّه لم يجيء للْتوراة والإنجيل قبلُ ذكرٌ ولا تلاوةٌ بعدُ، فيوجه إليه الخبر». وكذا رجَّحه ابنُ عطية (٤/٤٤٥) فقال: «وهو الأظهر». ولم يذكر مستندًا. وانتَقَد ابنُ كثير (٧/٣٣١) القولَ الأول، فقال: «وهذا القولُ لا أعرف وجهَه، ولا معناه». <q>﴿ٱلۡحَكِیمِ ۝١﴾</q> - تفسير ٣٤١٤٨- قال الحسن البصري: حَكَم فيه بالعدل، والإحسان، وإيتاء ذي القربى، وحكم فيه بالنهي عن الفحشاء، والمنكر، والبغي، وحكم فيه بالجنة لمن أطاعه، وبالنار لمن عصاه{35}. (ز) ٣٤١٤٩- قال عطاء: حكيم بما حَكَم فيه من الأرزاق، والآجال بما شاء{36}. (ز) ٣٤١٥٠- قال مقاتل بن سليمان: <q>﴿الحكيم﴾</q>، يعني: المُحْكَم من الباطل، ولا كَذِب فيه، ولا اختلاف{34}. (ز) ",footnotes:1:أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه النحاس في ناسخه ص٥٢٩. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣، وقال: التاسعة يريد بها سورة يونس.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٢/٢٢٤.أخرجه محمد بن نصر المروزي في قيام الليل ص١٧٠. وعزاه السيوطي إلى ابن مردويه. قال الألباني في الضعيفة ١٤/١١٨٦ (٧٠٨١): «منكر جدًّا».أخرجه عبد الله بن وهب في الجامع من تفسير القرآن ٣/٣٥-٣٦ (٥٧) مرسلًا.أخرجه ابن أبي شيبة في المصنف ١/٣٥٣.عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/١٠٣، وابن أبي حاتم ٦/١٩٢١، ١٩٩٤، ٧/٢٠٩٨، والبيهقي في الأسماء والصفات (١٦٧)، وابن النجار في تاريخه ١٧/٣-٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/١٠٤، وابن أبي حاتم ٦/١٩٢١، ١٩٩٤، ٧/٢٠٩٨. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/١٠٤.أخرجه ابن أبي حاتم ٦/١٩٩٤.أخرجه ابن جرير ١٢/١٠٣، وابن حاتم ٦/١٩٢١، ١٩٩٤، ٧/٢٠٩٨.تفسير الثعلبي ٥/١١٦.أخرجه ابن جرير ١٢/١٠٤.أخرجه ابن جرير ١٢/١٠٤. وعلَّقه ابن أبي حاتم ٦/١٩٢١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٤٣-.أخرجه ابن جرير ١٢/١٠٤، وابن أبي حاتم ٦/١٩٢١.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١١٦.أخرجه ابن أبي حاتم ٦/١٩٢٢، ٧/٢٠٩٨.أخرجه ابن جرير ١٢/١٠٥.أخرجه ابن أبي حاتم ٦/١٩٢٢.أخرجه ابن جرير ١٢/١٠٥، وابن أبي حاتم ٦/١٩٢٢.أخرجه ابن أبي حاتم ٦/١٩٢٢.تفسير مقاتل بن سليمان ٢/٢٢٥.تفسير الثعلبي ٥/١١٧.تفسير الثعلبي ٥/١١٧، وتفسير البغوي ٤/١١٧.تفسير مقاتل بن سليمان ٢/٢٢٥.
10,2," <q>﴿أَكَانَ لِلنَّاسِ عَجَبًا أَنۡ أَوۡحَیۡنَاۤ إِلَىٰ رَجُلࣲ مِّنۡهُمۡ أَنۡ أَنذِرِ ٱلنَّاسَ وَبَشِّرِ ٱلَّذِینَ ءَامَنُوۤا۟ أَنَّ لَهُمۡ قَدَمَ صِدۡقٍ عِندَ رَبِّهِمۡۗ قَالَ ٱلۡكَـٰفِرُونَ إِنَّ هَـٰذَا لَسَـٰحِرࣱ مُّبِینٌ ۝٢﴾</q> - قراءات ٣٤١٥١- عن زائدة، قال: قرأ سليمانُ [الأعمش] في يونس عندَ الآيتَين: (ساحِرٌ مُّبِينٌ){1}. (٧/٦٣٠) <q>﴿أَكَانَ لِلنَّاسِ عَجَبًا أَنۡ أَوۡحَیۡنَاۤ إِلَىٰ رَجُلࣲ مِّنۡهُمۡ أَنۡ أَنذِرِ ٱلنَّاسَ وَبَشِّرِ ٱلَّذِینَ ءَامَنُوۤا۟ أَنَّ لَهُمۡ قَدَمَ صِدۡقٍ عِندَ رَبِّهِمۡۗ قَالَ ٱلۡكَـٰفِرُونَ إِنَّ هَـٰذَا لَسَـٰحِرࣱ مُّبِینٌ ۝٢﴾</q> - نزول الآية ٣٤١٥٢- عن عبد الله بن عباس -من طريق الضحاك- قال: لَمّا بعَث اللهُ محمدًا ﷺ رسولًا أنكَرَتِ العربُ ذلك، أو مَن أنكر منهم، فقالوا: اللهُ أعظمُ مِن أن يكونَ رسولُه بشرًا مثلَ محمدٍ. فأنزل الله: <q>﴿أكانَ لِلنّاسِ عَجَبًا أنْ أوْحَيْنَآ إلى رَجُلٍ مِنهُم﴾</q> الآية، <q>﴿ومَآ أرْسَلْنا قَبْلَكَ إلاَّ رِجالًا﴾</q> الآية [الأنبياء:٧]. فلمّا كَرَّر الله عليهم الحُجَجَ قالوا: وإذا كان بشرًا فغيرُ محمدٍ كان أحقَّ بالرسالةِ، <q>﴿لَوْلا نُزِلَ هَذا القُرْءانُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q> [الزخرف:٣١]، يقول: أشرَفَ مِن محمدٍ، يَعْنون: الوليد بن المغيرة من مكة، ومسعود بن عمرو الثقفيَّ من الطائف؛ فأنزَل الله ردًا عليهم: <q>﴿أهُمْ يَقسِمُونَ رَحْمَتَ رَبِكَ﴾</q> الآية [الزخرف:٣٢]{2}. (٧/٦٢٧) <q>﴿أَكَانَ لِلنَّاسِ عَجَبًا أَنۡ أَوۡحَیۡنَاۤ إِلَىٰ رَجُلࣲ مِّنۡهُمۡ أَنۡ أَنذِرِ ٱلنَّاسَ﴾</q> - تفسير ٣٤١٥٣- عن عبد الملك ابن جُرَيْج -من طريق حجّاج-: عَجِبَتْ قريش أن بُعِث رجلٌ منهم. قال: ومثل ذلك: <q>﴿وإلى عادٍ أخاهُمْ هُودًا﴾</q> [الأعراف:٦٥]، <q>﴿وإلى ثَمُودَ أخاهُمْ صالِحًا﴾</q> [الأعراف:٧٣]، قال الله: <q>﴿أوَعَجِبْتُمْ أنْ جاءَكُمْ ذِكْرٌ مِن رَبِّكُمْ عَلى رَجُلٍ مِنكُمْ﴾</q> [الأعراف:٦٣]{3}. (ز) ٣٤١٥٤- قال مقاتل بن سليمان: <q>﴿أكانَ لِلنّاسِ عَجَبًا﴾</q> يعني بالناس: كُفّار أهل مكة <q>﴿عجبا أنْ أوْحَيْنا إلى رَجُلٍ مِنهُمْ﴾</q> يعني بالرَّجُل: محمدًا ﷺ، يعرفونه ولا ينكرونه: <q>﴿أنْ أنْذِرِ﴾</q> يعني: حذِّر <q>﴿النّاسَ﴾</q> عقوبةَ الله ﷿ ونِقْمَتَه إذا عَصَوْه{4}. (ز) <q>﴿وَبَشِّرِ ٱلَّذِینَ ءَامَنُوۤا۟ أَنَّ لَهُمۡ قَدَمَ صِدۡقٍ عِندَ رَبِّهِمۡۗ﴾</q> - تفسير ٣٤١٥٥- عن أُبَيِّ بن كعب -من طريق أنس- في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: سَلَفَ صدقٍ{5}. (٧/٦٢٩) ٣٤١٥٦- عن عبد الله بن مسعود، في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: القَدَم: هو العملُ الذي قدَّموا؛ قال الله: <q>﴿ونَكْتُبُ ما قَدَّمُوا وءاثَرَهُم﴾</q> [يس:١٢]. والآثارُ: مَمْشاهم. قال: مشى رسول الله ﷺ بين أُسطُوانتين مِن مسجدهم، ثم قال: «هذا أثَرٌ مكتوبٌ»{6}. (٧/٦٢٨) ٣٤١٥٧- عن علي بن أبي طالب، في قوله: <q>﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: محمد شفيع لهم{7}. (٧/٦٢٩) ٣٤١٥٨- عن أبي سعيد الخدريِّ، في قوله: <q>﴿قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: محمد ﷺ شفيعُ صدقٍ لهم يومَ القيامةِ{7}. (٧/٦٢٩) ٣٤١٥٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وبَشِرِ الَّذِينَ ءامَنُوا أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: ما سَبَق لهم مِن السَّعادة في الذِّكْرِ الأوَّل{9}. (٧/٦٢٧) ٣٤١٦٠- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: أجرًا حسنًا؛ بما قدَّموا من أعمالِهم{10}. (٧/٦٢٨) ٣٤١٦١- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: خَيْر{11}. (٧/٦٢٨) ٣٤١٦٢- عن مجاهد بن جبر -من طريق ابن جُرَيْج -في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: سَلَفَ صِدْقٍ{12}. (٧/٦٢٨) ٣٤١٦٣- عن مجاهد بن جبر -من طريق عبد الله بن كثير- <q>﴿أن لهم قدم صدق عند ربهم﴾</q>، قال: الأعمال الصالحة{10}. (ز) ٣٤١٦٤- عن مجاهد بن جبر -من طريق الوليد بن عبد الله بن أبي مغيث- <q>﴿أن لهم قدم صدق عند ربهم﴾</q>، قال: صلاتهم، وصومهم، وصدقتهم، وتسبيحهم{10}. (ز) ٣٤١٦٥- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿أن لهم قدم صدق عند ربهم﴾</q>، قال: ثواب صِدْقٍ{10}. (ز) ٣٤١٦٦- عن الحسن البصري، أو قتادة بن دعامة -من طريق عمرو بن الجَوْن- <q>﴿أن لهم قدم صدق عند ربهم﴾</q>، قال: محمد شفيعٌ لهم{16}. (ز) ٣٤١٦٧- عن الحسن البصري -من طريق عمرو بن الجَوْن- في قوله: <q>﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: محمد ﷺ شفيعٌ لهم يومَ القيامة{17}. (٧/٦٢٩) ٣٤١٦٨- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: مصيبتُهم في نبيِّهم ﷺ{12}. (٧/٦٢٩) ٣٤١٦٩- عن عطاء: مقام صدق لا زوال فيه، ولا بُؤْس، نعيمٌ مقيم، وخلود، وخلودٌ لا موت فيه{19}. (ز) ٣٤١٧٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، أي: سَلَفَ صِدْقٍ{20}. (٧/٦٢٩) ٣٤١٧١- عن إسماعيل السُّدِّيّ -من طريق سهل بن عثمان، عن رجل سَمّاه- في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: يَقْدمون عليه عند ربِّهم{12}. (٧/٦٢٨) ٣٤١٧٢- عن زيد بن أسلمَ -من طريق ابن عُيَيْنَة- في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: محمد ﷺ{22}. (٧/٦٣٠) ٣٤١٧٣- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿قَدَمَ صِدْقٍ﴾</q>، قال: ثواب صدق{23}. (٧/٦٢٨) ٣٤١٧٤- عن سليمان بن مهران الأعمش: <q>﴿قَدَمَ صِدْقٍ﴾</q>: سابِقة صِدْق{24}. (ز) ٣٤١٧٥- قال مقاتل بن سليمان: <q>﴿وبَشِّرِ الَّذِينَ آمَنُوا﴾</q>، يعني: صدَّقوا بمحمد ﷺ، وبما في القرآن من الثواب؛ <q>﴿أنَّ لَهُمْ قَدَمَ صِدْقٍ﴾</q> يعني: سلفَ خير <q>﴿عِنْدَ رَبِّهِمْ﴾</q> يعني: ثواب صدق يقدمون عليه، وهو الجَنَّة{4}. (ز) ٣٤١٧٦- عن مقاتل بن حيان -من طريق خالد بن صبيح البجلي- في قوله: <q>﴿أن لهم قدم صدق عند ربهم﴾</q>، قال: محمد شفيع صدق{26}. (ز) ٣٤١٧٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وبشر الذين آمنوا أن لهم قدم صدق﴾</q>، قال: القَدَمُ الصِّدق: ثوابُ الصِّدق؛ بما قدَّموا من الأعمال{27}. (ز) ٣٤١٧٨- عن بَكّاِر بن مالك، في قوله: <q>﴿قَدَمَ صِدْقٍ عِندَ رَبِهِم﴾</q>، قال: رسول الله ﷺ{28}٣٠٩٥. (٧/٦٢٩) ٣٠٩٥ اختُلِف في معنى قوله: <q>﴿قدم صدق﴾</q> على أقوال: الأول: الأعمال الصالحة من العبادات. الثاني: السعادة السابقة لهم في اللوح المحفوظ. الثالث: شفاعة النبي ﷺ. ورجَّح ابنُ جرير (١٢/١١١) مستندًا إلى اللغة القولَ الأول الذي قاله عبد الله بن عباس من طريق العوفي، والضحاك بن مزاحم، ومجاهد بن جبر، والربيع بن أنس، وعبد الرحمن بن زيد بن أسلم، فقال: «وذلك أنّه محكيٌّ عن العرب: هؤلاء أهْلُ القَدَم في الإسلام. أي: هؤلاء الذين قدَّموا فيه خيرًا، فكان لهم فيه تقديم. ويقال: له عندي قدم صِدْق، وقدم سوء، وذلك ما قدَّمت إليه من خير أو شر». وعلَّق عليه ابنُ كثير (٧/٣٣٢) بقوله: «وهذا كقوله تعالى: <q>﴿لِيُنْذِرَ بَأْسًا شَدِيدًا مِن لَدُنْهُ ويُبَشِّرَ المُؤْمِنِينَ الَّذِينَ يَعْمَلُونَ الصّالِحاتِ أنَّ لَهُمْ أجْرًا حَسَنًا ماكِثِينَ فِيهِ أبَدًا﴾</q> [الكهف:٢-٣]». ورجَّح ابنُ عطية (٤/٤٤٦) القول الثاني الذي قاله عبد الله بن عباس من طريق علي، فقال: «وهو أليق الأقوال بالآية». ولم يذكر مستندًا. وذكر ابنُ القيم (٢/٣١بتصرف) أنّه لا يعارض بقية الأقوال، فقال: «فإنّه سبق لهم من الله في الذِّكْر الأوَّلِ السعادةُ بأعمالهم على يد محمد ﷺ، فهو خير تَقَدُّم لهم من الله، ثم قدَّمه لهم على يد رسوله، ثم يقدمهم عليه يوم لقائه». <q>﴿قَالَ ٱلۡكَـٰفِرُونَ إِنَّ هَـٰذَا لَسَـٰحِرࣱ مُّبِینٌ ۝٢﴾</q> - تفسير ٣٤١٧٩- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿قال الكافرون إن هذا لساحر مبين﴾</q>؛ لزادهم ذلك تكذيبًا{29}. (ز) ٣٤١٨٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿قال الكافرون إن هذا لساحر مبين﴾</q>، فنظروا إليه، فلم يُصَدِّقوا به{29}. (ز) ٣٤١٨١- قال مقاتل بن سليمان: <q>﴿قالَ الكافِرُونَ﴾</q> من أهل مكة، يعني: أبا جهل بن هشام، والوليد بن المغيرة، والعاص بن وائل السهمي، وعتبة وشيبة ابنا ربيعة، وأهل مكة <q>﴿قالَ الكافِرُونَ إنَّ هذا لَساحِرٌ﴾</q> يعني: محمدًا ﷺ <q>﴿مُبِينٌ﴾</q> يعني: بيِّن{4}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ. والآية الأخرى التي في هذه السورة هي قول قوم فرعون لموسى: <q>﴿إنَّ هَذا لَسِحْرٌ مُّبِينٌ (٧٦)﴾</q>. وقد قرأ: <q>﴿لَساحِرٌ﴾</q> بالألف في الآية الأولى ابن كثير، وعاصم، وحمزة، والكسائي، وخلف، وقرأ بقية العشرة: ‹لَسِحْرٌ› بغير ألف. انظر: النشر ٢/٢٥٦، والإتحاف ص٣٠٩. والآية الثانية ليس فيها خلاف بين العشرة، وما ورد فيها عن الأعمش فهي قراءة شاذة. انظر: المحتسب ١/٣١٦.أخرجه ابن جرير ١٢/١٠٧، ١٤/٢٢٨، ٢٠/٥٨٣-٥٨٤، وابن أبي حاتم ٦/١٩٢٢ (١٠١٩٣)، من طريق بشر بن عمارة، عن أبي روق، عن الضحاك، عن ابن عباس به. إسناده ضعيف جِدًّا؛ فيه بشر بن عمارة، قال عنه ابن حجر في التقريب (٦٩٧): «ضعيف». والضحّاك معروف بكثرة الإرسال، ولم يسمع من ابن عباس شيئًا، ولم يَرَه، كما في جامع التحصيل للعلائي ص١٩٩.أخرجه ابن جرير ١٢/١٠٧.تفسير مقاتل بن سليمان ٢/٢٢٥.أخرجه الحاكم ٢/٣٣٨.عزاه السيوطي إلى أبي الشيخ، وابن مردويه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/١١٠، وابن أبي حاتم ٦/١٩٢٢-١٩٢٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/١٠٨.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٠٩، وابن أبي حاتم ٦/١٩٢٣.أخرجه ابن أبي حاتم ٦/١٩٢٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/١٠٨.أخرجه ابن جرير ١٢/١٠٨.أخرجه ابن جرير ١٢/١٠٨.أخرجه ابن جرير ١٢/١١٠.أخرجه ابن جرير ١٢/١١٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٣. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١١٧، وتفسير البغوي ٤/١١٧.أخرجه ابن جرير ١٢/١١١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/١١١.أخرجه ابن جرير ١٢/١٠٩، وابن أبي حاتم ٦/١٩٢٣-١٩٢٤. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١١٧.تفسير مقاتل بن سليمان ٢/٢٢٥.أخرجه ابن أبي حاتم ٦/١٩٢٣.أخرجه ابن جرير ١٢/١٠٩.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٤.أخرجه ابن أبي حاتم ٦/١٩٢٤.تفسير مقاتل بن سليمان ٢/٢٢٥.
10,3," <q>﴿إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ﴾</q> - تفسير ٣٤١٨٢- قال مقاتل بن سليمان: <q>﴿إنَّ رَبَّكُمُ اللَّهُ الَّذِي خَلَقَ السَّماواتِ﴾</q> يوم الأحد، ويوم الاثنين، <q>﴿و﴾</q> خلق <q>﴿الأَرْضَ﴾</q> يوم الثلاثاء، ويوم الأربعاء، وما بينهما يوم الخميس، ويوم الجمعة؛ <q>﴿فِي سِتَّةِ أيّامٍ﴾</q>{1}. (ز) ٣٤١٨٣- عن محمد بن إسحاق -من طريق سلمة- قال: ابتَدَعَ السماواتِ والأرضَ، ولم يكونا إلّا بقُدْرَتِه، لم يستعن على ذلك بأحد من خلقه، ولم يُشْركه في شيء من أمره، بسلطانه القاهر، وقوله النافذ الذي يقول به لِما أراد أن يكون؛ يقول له: كُن. فيكون، ففرغ من خلق السماوات والأرض في ستة أيام{2}. (ز) <q>﴿فِی سِتَّةِ أَیَّامࣲ﴾</q> - تفسير ٣٤١٨٤- عن عبد الله بن عباس -من طريق الضَّحّاك بن مُزاحِم- <q>﴿خلق السماوات والأرض في ستة أيام﴾</q>، قال: يوم مقداره ألف سنة{3}٣٠٩٦. (ز) ٣٠٩٦ ذكر ابنُ عطية (٤/٤٤٨) أنّ هناك مَن قال بأنّها مِن أيام الآخرة، ثم قال: «وقال الجمهور -وهو الصواب-: بل من أيام الدنيا». <q>﴿ثُمَّ ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِۖ﴾</q> - تفسير ٣٤١٨٥- قال مقاتل بن سليمان: <q>﴿ثُمَّ اسْتَوى عَلى العَرْشِ﴾</q> فيها تقديم؛ ثُمَّ اسْتَوى على العَرْش، ثُمَّ خلق السموات والأرض{4}. (ز) <q>﴿یُدَبِّرُ ٱلۡأَمۡرَۖ﴾</q> - تفسير ٣٤١٨٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يُدَبِرُ الأَمْرَ﴾</q>، قال: يَقْضِيه وحده{5}٣٠٩٧. (٧/٦٣٠) ٣٠٩٧ ذكر ابنُ عطية (٤/٤٤٩) أنّ قوله: <q>﴿يدبر الأمر﴾</q> يَصِحُّ أن يريد بـ<q>﴿الأمر﴾</q> اسم الجنس من الأمور، ثم قال: «ويحتمل أن يريد الأمر الذي هو مصدر أمَرَ يأمرُ أمرًا، وتدبيره -لا إله إلا هو- إنّما هو الإنفاذ؛ لأنّه قد أحاط بكل شيء علمًا». ٣٤١٨٧- قال مقاتل بن سليمان: <q>﴿يُدَبِّرُ الأَمْرَ﴾</q>، يقضي القضاء وحده، لا يُدَبِّرُه غيره{1}. (ز) <q>﴿مَا مِن شَفِیعٍ إِلَّا مِنۢ بَعۡدِ إِذۡنِهِۦۚ﴾</q> - تفسير ٣٤١٨٨- عن سعيد بن جبير -من طريق سالم- قال: مَن يتكلم عنده إلا بإذنه؟!{7}. (ز) ٣٤١٨٩- قال مقاتل بن سليمان: <q>﴿ما مِن شَفِيعٍ﴾</q> من الملائكة لبني آدم <q>﴿إلّا مِن بَعْدِ إذْنِهِ﴾</q> يعني: لا يشفع أحدٌ إلا بإذنه، ولا يشفعون إلا لأهل التوحيد، فذلك قوله: <q>﴿إلّا مِن بَعْدِ أنْ يَأْذَنَ اللَّهُ لِمَن يَشاءُ ويَرْضى﴾</q> [النجم:٢٦]، فرَضِي اللهُ للملائكة أن يشفعوا للمُوَحِّدين{1}. (ز) <q>﴿ذَ ٰ⁠لِكُمُ ٱللَّهُ رَبُّكُمۡ فَٱعۡبُدُوهُۚ﴾</q> - تفسير ٣٤١٩٠- قال مقاتل بن سليمان: ثم قال: <q>﴿ذلِكُمُ اللَّهُ﴾</q> يعني: هكذا <q>﴿رَبُّكُمْ فاعْبُدُوهُ﴾</q> يعني: فوحِّدوه، ولا تشركوا به شيئًا{1}. (ز) <q>﴿أَفَلَا تَذَكَّرُونَ ۝٣﴾</q> - تفسير ٣٤١٩١- قال مقاتل بن سليمان: <q>﴿أفَلا﴾</q> يعني: فهلّا <q>﴿تَذَكَّرُونَ﴾</q> في ربوبيته، ووَحْدانِيَّته{1}. (ز) ٣٤١٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قوله: <q>﴿تذكرون﴾</q>، قال: أهل الذِّكر هم أهل القرآن{11}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.أخرجه ابن أبي حاتم ٦/١٩٢٤، ٢٠٠٤، ٨/٢٧١٣.أخرجه ابن أبي حاتم ٦/١٩٢٥.تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦. وقد تقدم تفسير الآية في سورة الأعراف آية ٥٤ بما يغني عن إعادته.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١١٤، ١١٦، وابن أبي حاتم ٦/١٩٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.أخرجه ابن أبي حاتم ٦/١٩٢٦. وأخرجه أيضًا ٢/٢٨٨ عند قوله تعالى: <q>﴿من ذا الذي يشفع عنده إلا بإذنه﴾</q> [البقرة:١٥٥].تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.تفسير مقاتل بن سليمان ٢/٢٢٥-٢٢٦.أخرجه ابن أبي حاتم ٦/١٩٢٦.
10,4," <q>﴿إِلَیۡهِ مَرۡجِعُكُمۡ جَمِیعࣰاۖ وَعۡدَ ٱللَّهِ حَقًّاۚ﴾</q> - تفسير ٣٤١٩٣- عن الضحاك بن مزاحم -من طريق أبي سنان- <q>﴿إليه مرجعكم جميعا﴾</q>، قال: البَرُّ، والفاجر{1}. (ز) ٣٤١٩٤- قال مقاتل بن سليمان: <q>﴿إلَيْهِ مَرْجِعُكُمْ جَمِيعًا﴾</q> بعد الموت، <q>﴿وعْدَ اللَّهِ حَقًّا﴾</q>{2}. (ز) <q>﴿إِنَّهُۥ یَبۡدَؤُا۟ ٱلۡخَلۡقَ ثُمَّ یُعِیدُهُۥ﴾</q> - تفسير ٣٤١٩٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إنَّهُ يَبْدَؤُا الخَلْقَ ثُمَّ يُعِيدُهُ﴾</q>، قال: يُحْيِيه، ثم يُمِيتُه، ثم يُحْيِيه{3}. (٧/٦٣٠) ٣٤١٩٦- قال مقاتل بن سليمان: <q>﴿إنَّهُ يَبْدَؤُا الخَلْقَ ثُمَّ يُعِيدُهُ﴾</q>، ولم يكُ شيئًا، كذلك يعيده من بعد الموت{2}. (ز) <q>﴿لِیَجۡزِیَ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ بِٱلۡقِسۡطِۚ﴾</q> - تفسير ٣٤١٩٧- عن عبد الله بن عباس -من طريق الضحاك- قوله: <q>﴿بالقسط﴾</q>، قال: بالعَدْل{5}. (ز) ٣٤١٩٨- عن قتادة بن دعامة= (ز) ٣٤١٩٩- وإسماعيل السُّدِّيّ، بمثل ذلك{6}. (ز) ٣٤٢٠٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بالقسط﴾</q>: بالعدل{7}. (ز) ٣٤٢٠١- قال مقاتل بن سليمان: <q>﴿لِيَجْزِيَ﴾</q> يعني: لكي يثيب في البعث <q>﴿الَّذِينَ آمَنُوا﴾</q> يعني: صَدَّقوا، <q>﴿وعَمِلُوا الصّالِحاتِ﴾</q> يعني: وأقاموا الفرائض <q>﴿بِالقِسْطِ﴾</q> يعني: بالحقِّ، وبالعدل، وثوابهم الجنة{2}. (ز) <q>﴿وَٱلَّذِینَ كَفَرُوا۟ لَهُمۡ شَرَابࣱ مِّنۡ حَمِیمࣲ وَعَذَابٌ أَلِیمُۢ بِمَا كَانُوا۟ یَكۡفُرُونَ ۝٤﴾</q> - تفسير ٣٤٢٠٢- قال مقاتل بن سليمان: <q>﴿و﴾</q> يجزي <q>﴿الَّذِينَ كَفَرُوا﴾</q> بتوحيد الله <q>﴿لَهُمْ شَرابٌ مِن حَمِيمٍ﴾</q> وذلك الشراب قد أُوقِد عليه منذ يوم خلقها الله ﷿ إلى يوم يدخلها أهلها، فقد انتهى حرُّها، <q>﴿وعَذابٌ ألِيمٌ﴾</q> يعني: وجيع. نظيرها في الواقعة: <q>﴿فَنُزُلٌ مِن حَمِيمٍ (٩٣)﴾</q>. <q>﴿بِما كانُوا يَكْفُرُونَ﴾</q> بتوحيد الله ﷿{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٢٦.تفسير مقاتل بن سليمان ٢/٢٢٦.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١١٦، وابن أبي حاتم ٦/١٩٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٢٦.أخرجه ابن أبي حاتم ٦/١٩٢٧.علَّقه ابن أبي حاتم ٦/١٩٢٧.أخرجه ابن جرير ١٢/١١٧. وعلَّقه ابن أبي حاتم ٦/١٩٢٧.تفسير مقاتل بن سليمان ٢/٢٢٦.تفسير مقاتل بن سليمان ٢/٢٢٦.
10,5," <q>﴿هُوَ ٱلَّذِی جَعَلَ ٱلشَّمۡسَ ضِیَاۤءࣰ وَٱلۡقَمَرَ نُورࣰا وَقَدَّرَهُۥ مَنَازِلَ لِتَعۡلَمُوا۟ عَدَدَ ٱلسِّنِینَ وَٱلۡحِسَابَۚ مَا خَلَقَ ٱللَّهُ ذَ ٰ⁠لِكَ إِلَّا بِٱلۡحَقِّۚ﴾</q> - تفسير ٣٤٢٠٣- عن ابن مسعود: سمِعتُ رسولَ الله ﷺ يقول: «تكَلَّم ربُّنا بكلمتَين، فصارَت إحداهما شمسًا، والأخرى قمرًا، وكانا من النورِ جميعًا، ويَعُودان إلى الجنَّة يومَ القيامة»{1}. (٧/٦٣٠) ٣٤٢٠٤- عن عبد الله بن عباس، في قوله: <q>﴿هُوَ الَّذِى جَعَلَ الشَّمْسَ ضِيَآءً والقَمَرَ نُورًا﴾</q>، قال: وجوهُهما إلى السمواتِ، وأَقْفِيتُهما إلى الأرض{2}. (٧/٦٣١) ٣٤٢٠٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿جَعَلَ الشَّمْسَ ضِيَآءً والقَمَرَ نُورًا﴾</q>، قال: ولم يجعلِ الشمسَ كهيئةِ القمر؛ لكي يُعْرَفَ الليلُ مِن النهارِ، وهو قوله: <q>﴿فَمَحَوْنَآ ءايَةَ الَّيْلَ﴾</q> الآية [الإسراء:١٢]{3}. (٧/٦٣١) ٣٤٢٠٦- قال مقاتل بن سليمان: <q>﴿هُوَ الَّذِي جَعَلَ الشَّمْسَ ضِياءً﴾</q> بالنهار لأهل الأرض يستضيئون بها، <q>﴿والقَمَرَ نُورًا﴾</q> بالليل، <q>﴿وقَدَّرَهُ مَنازِلَ﴾</q> يزيد وينقص، يعني: الشمس سراجًا، والقمر نورًا؛ <q>﴿لِتَعْلَمُوا﴾</q> بالليل والنهار <q>﴿عَدَدَ السِّنِينَ والحِسابَ﴾</q>، وقَدَّره منازل؛ لتعلموا بذلك عدد السنين، والحساب، ورمضان، والحج، والطلاق، وما يريدون بين العباد، <q>﴿ما خَلَقَ اللَّهُ ذلِكَ﴾</q> يعني: الشمس والقمر <q>﴿إلّا بِالحَقِّ﴾</q> لم يخلقهما عبثًا، خلقهما لأمر هو كائن{4}. (ز) <q>﴿یُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٥﴾</q> - تفسير ٣٤٢٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿يفصل الآيات﴾</q>، أمّا نُفَصِّل: نُبَيِّن{5}. (ز) ٣٤٢٠٨- قال مقاتل بن سليمان: <q>﴿يُفَصِّلُ﴾</q>: يبيِّن <q>﴿الآياتِ﴾</q> يعني: العلامات <q>﴿لِقَوْمٍ يَعْلَمُونَ﴾</q> بتوحيد الله ﷿ أنّ الله واحد؛ لِما يَرَوْن من صُنعه{4}. (ز) <q>﴿یُفَصِّلُ ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٥﴾</q> - آثار متعلقة بالآية ٣٤٢٠٩- عن عبد الله بن عمرو بن العاص، قال: الشمسُ والقمرُ وجوهُهما إلى العرشِ، وأَقْفِيتُهما إلى الأرض{1}. (٧/٦٣١) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى أبي الشيخ، وابن مردويه.أخرجه ابن أبي حاتم ٦/١٩٢٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٢٦-٢٢٧.أخرجه ابن أبي حاتم ٦/١٩٢٨.تفسير مقاتل بن سليمان ٢/٢٢٦-٢٢٧.عزاه السيوطي إلى ابن مردويه.
10,6," <q>﴿إِنَّ فِی ٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ وَمَا خَلَقَ ٱللَّهُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَّقُونَ ۝٦﴾</q> - تفسير ٣٤٢١٠- قال مقاتل بن سليمان: <q>﴿إنَّ فِي اخْتِلافِ اللَّيْلِ والنَّهارِ﴾</q> عليكم، <q>﴿وما خَلَقَ اللَّهُ فِي السَّماواتِ والأَرْضِ لَآياتٍ لِقَوْمٍ يَتَّقُونَ﴾</q> عقوبةَ الله ﷿{1}. (ز) <q>﴿إِنَّ فِی ٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ وَمَا خَلَقَ ٱللَّهُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَّقُونَ ۝٦﴾</q> - آثار متعلقة بالآية ٣٤٢١١- عن خليفةَ العَبْديِّ، قال: لو أنّ الله -تَبارَك وتعالى- لم يُعْبَدْ إلا عن رؤيةٍ ما عبَده أحدٌ، ولكن المؤمنون تفكَّروا في مَجِيء هذا الليلِ إذا جاء، فمَلَأَ كلَّ شيءٍ، وغَطّى كلَّ شيءٍ، وفي مجيءِ سُلطانِ النهارِ إذا جاء، فمحا سُلطانَ الليلِ، وفي السحابِ المُسَخَّرِ بين السماء والأرض، وفي النجوم، وفي الشتاء، والصيف، فواللهِ، ما زال المؤمنون يَتَفَكَّرون فيما خلق ربُّهم -تَبارَك وتعالى- حتى أيْقَنَتْ قلوبُهم بربِّهم ﷿، وكأنّما عبَدُوا الله عن رؤية{2}. (٧/٦٣٢) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٧.أخرجه أبو الشيخ في العظمة (٦٤).
