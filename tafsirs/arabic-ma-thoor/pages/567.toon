quran[26]{c,v,t}:
  69,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَاۤءَ فِرۡعَوۡنُ وَمَن قَبۡلَهُۥ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٣٠<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿ومَن قَبْلَهُ﴾</span> بنصب القاف{1}<span class=comment-ref>٦٧٥٨</span>. (١٤/٦٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٨</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿من قبله﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿من قبله﴾</span> بفتح القاف وتسكين الباء. <b>وقرأ آخرون</b>: ‹ومَن قِبَلَهُ› بكسر القاف وفتح الباء.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٢١٦) أنّ القراءَة الأولى بمعنى: وجاء من قَبل فرعون من الأمم المُكذّبة بآيات الله كقوم نوح وعاد وثمود وقوم لوط بالخطيئة. وأنّ الثانية بمعنى: وجاء مَن مع فرعون من أهل بلده مصر من القِبْط.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٤/١١٢).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، وصحة معناهما</span>، فقال: «والصواب من القول في ذلك عندي أنهما قراءتان معروفتان صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أنّ مما يؤيد قراءة فتح القاف ذكْره تعالى قصة نوح في طغيان الماء؛ لأن قوله: <span class="qpc-hafs">﴿ومَن قَبْله﴾</span> قد تضمنهم، فحسُن اقتضاب أمرهم بعد ذلك دون تصريح. وأنّ مما يؤيد قراءة الكسر ما جاء في مصحف أُبيّ بن كعب: (وجَآءَ فِرْعَوْنُ ومَن مَّعَهُ)، وفي حرف أبي موسى: (ومَن تِلْقَآءَهُ). وأنّ طلحة بن مُصرّف قرأ: (ومَن حَوْلَهُ).</div></p><p><h3><span class="qpc-hafs">﴿وَجَاۤءَ فِرۡعَوۡنُ وَمَن قَبۡلَهُۥ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، ‹وجَآءَ فِرْعَوْنُ ومَن قِبَلَهُ›، قال: ومَن معه{2}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاءَ فِرْعَوْنُ ومَن قَبْلَهُ﴾</span>، يعني: ومَن معه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمُؤۡتَفِكَـٰتُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وجاءَ فِرْعَوْنُ ومَن قَبْلَهُ والمُؤْتَفِكاتُ بِالخاطِئَةِ﴾</span>: يعني: المُكذّبين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكاتُ﴾</span>، قال: هم قوم لوط ائتَفكَتْ{5} بهم أرضهم{6}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والمُؤْتَفِكاتُ﴾</span> يعني: والمُكذِّبات <span class="qpc-hafs">﴿بِالخاطِئَةِ﴾</span> يعني: قريات لوط الأربعة، واسمها: سَدُومُ، وعامورا، وصابورا، ودامورا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٣٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجاءَ فِرْعَوْنُ ومَن قَبْلَهُ والمُؤْتَفِكاتُ بِالخاطِئَةِ﴾</span>، قال: المُؤتفكات: قوم لوط، ومدينتهم، وزَرْعهم. وفي قوله: <span class="qpc-hafs">﴿والمُؤْتَفِكَةَ أهْوى﴾</span> [النجم:٥٣]، قال: أهواها من السماء؛ رَمى بها من السماء، أوحى الله إلى جبريل ﵇، فاقتَلعها من الأرض؛ رَبَضَها{8}، ومدينتها، ثم هوى بها إلى السماء، ثم قَلبهم إلى الأرض، ثم أتبعهم الصخر حجارة. وقرأ قول الله: <span class="qpc-hafs">﴿حِجارَةً مِن سِجِّيلٍ مَنضُودٍ مُسَوَّمَةً﴾</span> [هود:٨٢-٨٣]، قال: المُسوّمة: المُعدّة للعذاب{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡخَاطِئَةِ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بِالخاطِئَةِ﴾</span>، قال: بالخطايا{10}. (١٤/٦٦٦)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها العشرة ما عدا أبا عمرو، ويعقوب، والكسائي؛ فإنهم قرؤوا: ‹ومَن قِبَلَهُ› بكسر القاف وفتح الباء. انظر: النشر ٢/٣٨٩، والإتحاف ص٥٥٤.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٤٢٢.|4:أخرجه ابن جرير ٢٣/٢١٧.|5:ائتفكت: انقلبت. النهاية ١/٥٦.|6:أخرجه عبد الرزاق ٢/٣١٢، وابن جرير ٢٣/٢١٦-٢١٧، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:تفسير مقاتل بن سليمان ٤/٤٢٢.|8:الرَّبَضُ للمدينة: ما حولها. كما يُستفاد من عبارتي النهاية والمصباح (ربض).|9:أخرجه ابن جرير ٢٣/٢١٦-٢١٧.|10:أخرجه ابن جرير ٢٣/٢١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.
  69,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَعَصَوۡا۟ رَسُولَ رَبِّهِمۡ فَأَخَذَهُمۡ أَخۡذَةࣰ رَّابِیَةً ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿أخْذَةً رابِيَةً﴾</span>، قال: شديدة{1}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أخْذَةً رابِيَةً﴾</span>، قال: شديدة{2}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَعَصَوْا رَسُولَ رَبِّهِمْ﴾</span> يعني: لوطًا، <span class="qpc-hafs">﴿فَأَخَذَهُمْ﴾</span> الله <span class="qpc-hafs">﴿أخْذَةً رابِيَةً﴾</span> يعني: شديدة، رَبتْ عليهم في الشدة؛ أشد مِن معاصيهم التي عَمِلوها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿فَأَخَذَهُمْ أخْذَةً رابِيَةً﴾</span>، قال: كما يكون في الخير رابية، كذلك يكون في الشر رابية. قال: ربا عليهم: زاد عليهم. وقرأ قول الله ﷿: <span class="qpc-hafs">﴿الَّذِينَ كَفَرُوا وصَدُّوا عَنْ سَبِيلِ اللَّهِ زِدْناهُمْ عَذابًا فَوْقَ العَذابِ﴾</span> [النحل:٨٨]. وقرأ قول الله ﷿: <span class="qpc-hafs">﴿والَّذِينَ اهْتَدَوْا زادَهُمْ هُدًى وآتاهُمْ تَقْواهُمْ﴾</span> [محمد:١٧]. يقول: ربا لهؤلاء الخير، ولهؤلاء الشّر{4}<span class=comment-ref>٦٧٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٨) أنّ «الرسول» في قوله تعالى: <span class="qpc-hafs">﴿فعصوا رسول ربهم﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يكون اسم جنس؛ كأنه قال: فعصا هؤلاء الأقوام والفِرق أنبياء الله الذين أرسلهم إليهم. <b>الثاني</b>: أن يكون الرسول بمعنى: الرسالة.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢١٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٣/٢١٨. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٧-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٤٢٢.|4:أخرجه ابن جرير ٢٣/٢١٨-٢١٩.
  69,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا لَمَّا طَغَا ٱلۡمَاۤءُ حَمَلۡنَـٰكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إنّا لَمّا طَغا الماءُ﴾</span>، قال: كثُر{1}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنّا لَمّا طَغا الماءُ﴾</span>، قال: طغى على خُزّانه، فنَزل، ولم ينزل من السماء ماءٌ إلا بمكيال أو ميزان، إلا زمن نوح، فإنه طغى على خُزّانه، فنَزل مِن غير كَيْلٍ ولا وزْن{2}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- قال: لم يَنزِل مِن السماء قَطرةٌ قطُّ إلا بعِلْم الخُزّان، إلا حيث طغى الماء، فإنّه غَضِب لِغَضبِ الله، فطغى على الخُزّان، فخرج ما لا يعلمون ما هو{3}. (١٤/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنّا لَمّا طَغا الماءُ﴾</span>، قال: ظَهَر{4}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لَمّا طَغا الماءُ﴾</span>: كثُر، وارتفع{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿طَغا الماءُ﴾</span>، قال: بلَغني: أنه طغى فوق كلّ شيء خمسة عشر ذراعًا{6}. (١٤/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿طغا الماء﴾</span>، قال: كثرة الماء، وارتفاعه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا لَمّا طَغا الماءُ﴾</span> وارتفع فوق كلّ شيء أربعين ذراعًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٠<span class="dash">-</span></span> عن <span class="name-3">مقاتل [بن سليمان]</span> -من طريق إسحاق بن بشر- قال: ... فأوحى اللهُ إلى الأرض: أنْ أخْرِجي ماءكِ. فأَخرَجتْ بغير كَيْلٍ غضبًا لله، ونَزل من السماء بغير كَيْلٍ، فذلك قوله: <span class="qpc-hafs">﴿إنا لما طغى الماء﴾</span> على الخُزّان ...{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَمَلۡنَـٰكُمۡ فِی ٱلۡجَارِیَةِ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿حَمَلْناكُمْ فِي الجارِيَةِ﴾</span>، قال: السّفينة{10}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿حَمَلْناكُمْ فِي الجارِيَةِ﴾</span>، قال: السّفينة{2}. (١٤/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَمَلْناكُمْ فِي الجارِيَةِ﴾</span> يعني: السّفينة، يقول: حَملنا الآباء وأنتم في أصلابهم في السّفينة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿حَمَلْناكُمْ فِي الجارِيَةِ﴾</span>: والجارية: سفينة نوح التي حُملتم فيها{13}<span class=comment-ref>٦٧٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٨) أنّ المهدوي قال بأنّ المعنى: في السُّفن الجارية.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢١٩-٢٢٠، وبنحوه من طريق عطية، وعلّقه البخاري في صحيحه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|3:أخرجه أبو الشيخ (٧٣٣)، وابن جرير ٢٣/٢١٩. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢٣/٢٢٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وفي لفظ عند ابن جرير: طما.|5:أخرجه ابن جرير ٢٣/٢٢٠.|6:أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢١٩، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٨.|8:تفسير مقاتل بن سليمان ٤/٤٢٢.|9:أخرجه ابن عساكر في تاريخ دمشق ٦٢/٢٥٧.|10:أخرجه ابن جرير ٢٣/٢٢٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|11:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|12:تفسير مقاتل بن سليمان ٤/٤٢٢.|13:أخرجه ابن جرير ٢٣/٢٢١.
  69,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِنَجۡعَلَهَا لَكُمۡ تَذۡكِرَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لِنَجْعَلَها لَكُمْ تَذْكِرَةً﴾</span>، قال: عِبرة وآية، أبقاها الله حتى نَظرتْ إليها هذه الأُمّة، وكم مِن سفينة كانت من بعد سفينة نوح صارت رمادًا!{1}. (١٤/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لِنَجْعَلَها لَكُمْ تَذْكِرَةً﴾</span>: أي: تَذكرون ما صُنِع بهم حيثُ عَصَوْا نوحًا{2}. (١٤/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِنَجْعَلَها لَكُمْ﴾</span> يعني: لكي نَجعلها لكم، يعني: في هلاك قوم نوح لكم، يا معشر الأبناء <span class="qpc-hafs">﴿تَذْكِرَةً﴾</span> يعني: عِظة وتَذْكرة، يعني: وعبرة لكم ولمن بعدكم من الناس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿لِنَجْعَلَها لَكُمْ تَذْكِرَةً﴾</span>، قال: لأُمّة محمد ﷺ، وكم من سفينة قد هَلكتْ، وأثرٍ قد ذَهب! يعني: ما بقي من السفينة حتى أدركتْ أُمّةُ محمد، فرأوه، كانت ألواحها تُرى على الجُوديّ{4}<span class=comment-ref>٦٧٦١</span>. (١٤/٦٦٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٨) أنّ الضمير في قوله: <span class="qpc-hafs">﴿لنجعلها﴾</span> عائد على الفِعلة، ثم قال: «<b>ويحتمل</b> أن يعود على <span class="qpc-hafs">﴿الجارِيَةِ﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿وَتَعِیَهَاۤ أُذُنࣱ وَ ٰ⁠عِیَةࣱ ۝١٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٥٩<span class="dash">-</span></span> عن <span class="name-1">علي</span>، قال: قال رسول الله ﷺ: «<b>يا علي، إنّ الله أمرني أنْ أُدنيك وأُعلّمك لتَعِيَ</b>». فأُنزلت هذه الآية: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>. «<b>فأنتَ أُذُنٌ واعية لعِلْمي</b>»{5}. (١٤/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٠<span class="dash">-</span></span> عن <span class="name-1">بُرَيْدة</span>، قال: قال رسول الله ﷺ لِعلي: «<b>إنّ الله أمرني أنْ أُدنيك، ولا أُقصيك، وأنْ أُعلِّمك، وأن تَعِيَ، وحُقّ لك أن تَعِيَ</b>». فنَزلت هذه الآية: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>{6}<span class=comment-ref>٦٧٦٢</span>. (١٤/٦٦٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٢</span> <span class="comment-type-4">ذكر</span> <u>ابن تيمية</u> (٦/٣٨٥-٣٨٦) أنّ هذا الحديث موضوع باتفاق أهل العلم، ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى دلالة العقل</span>- العموم، فقال: «ومعلوم بالاضطرار أنّ الله تعالى لم يُرد بذلك أنْ لا تَعِيَها إلا أُذُنٌ واعية واحدة من الآذان، ولا أُذُن شخص معين، لكن المقصود النوع فيدخل في ذلك كل أُذُن واعية».</div></p><p><h3><span class="qpc-hafs">﴿وَتَعِیَهَاۤ أُذُنࣱ وَ ٰ⁠عِیَةࣱ ۝١٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٦١<span class="dash">-</span></span> عن علي بن أبي طالب -من طريق مكحول- في قوله: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>، قال: قال لي رسول الله ﷺ: «<b>سألتُ اللهَ أن يَجعلها أُذُنك، يا علي</b>». فقال علي: ما سمعتُ من رسول الله ﷺ شيئًا فنَسِيتُه{7}. (١٤/٦٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٢<span class="dash">-</span></span> عن مكحول، قال: لَمّا نزلت: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span> قال رسول الله ﷺ: «<b>سألتُ ربي أن يَجعلها أُذُنَ علي</b>». فكان علي يقول: ما سمعتُ من رسول الله ﷺ شيئًا فنَسِيتُه{8}. (١٤/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي، وعطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>، قال: حافظة. وفي لفظ: سامعة{9}. (١٤/٦٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>: سَمعتْها أُذُنٌ، ووعتْ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>، قال: سَمعتْ، وعَقلتْ ما سَمعتْ، وأوعتْ{11}. (١٤/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وتَعِيَها﴾</span> يقول: وتحصيها <span class="qpc-hafs">﴿أُذُنٌ واعِيَةٌ﴾</span> يقول: أُذُنٌ حافظة. يعني: حديث السفينة{2}. (١٤/٦٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجَوْنيّ</span> -من طريق جعفر بن سليمان- في قوله: <span class="qpc-hafs">﴿أُذُنٌ واعِيَةٌ﴾</span>، قال: أُذُنٌ عَقلتْ عن الله{13}. (١٤/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>، يعني: حافظة لما سَمعتْ، فانتفعتْ بما سَمعتْ من الموعظة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٦٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾</span>، قال: واعية يَحذرون معاصي الله أن يُعذّبهم الله عليها، كما عَذّب مَن كان قبلهم، تسمعها فَتَعِيها، إنما تَعي القلوب ما تَسمع الآذان مِن الخير والشّر مِن باب الوعي{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٢١. وعزاه السيوطي إلى عبد بن حميد.|2:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٤٢٢.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه أبو نعيم في الحلية ١/٦٧. وأورده الديلمي في الفردوس ٥/٣٢٩ (٨٣٣٨).</p><p>وقال ابن تيمية في منهاج السنة النبوية ٧/١٧١: «هذا موضوع باتفاق أهل العلم».|6:أخرجه الواحدي في أسباب النزول ص٤٤٤، وابن عساكر في تاريخ دمشق ٤٨/٢١٧ (٥٥٧٣)، وابن جرير ٢٣/٢٢٣، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢١١-.</p><p>قال ابن عساكر: «هذا إسناد لا يُعرف، والحديث شاذ». وقال ابن كثير: «لا يصحّ». وقال السيوطي في لباب النقول ص٢٠١: «لا يصحّ».|7:أخرجه أبو نعيم في المعرفة ١/٨٨ (٣٤٥)، وابن عساكر في تاريخ دمشق ٤١/٤٥٥ (٤٨٩٥).</p><p>وقال ابن تيمية في منهاج السنة النبوية ٧/١٧١: «هذا موضوع باتفاق أهل العلم». وأورده الذهبي في ميزان الاعتدال ٤/٥٢٢ (١٠١٧٣) في ترجمة أبي الدنيا الأشج المغربي، وقال عنه: «كذاب طرقي». وقال الفتني في تذكرة الموضوعات ص٨٤: «موضوع».|8:أخرجه ابن جرير ٢٣/٢٢٢-٢٢٣، وسعيد بن منصور -كما في فتح الباري ١٣/٥٢٦-، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٣٨-، وابن مردويه -كما في تخريج أحاديث الكشاف ٤/٨٤-. وعزاه السيوطي إلى ابن المنذر.</p><p>قال ابن كثير: «هكذا رواه ابن جرير، عن علي بن سهل، عن الوليد بن مسلم، عن علي بن حَوْشَب، عن مكحول به، وهو حديث مرسل».|9:أخرجه ابن جرير ٢٣/٢٢٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:أخرجه ابن جرير ٢٣/٢٢٢.|11:أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٢٢ من طريق سعيد، وخالد بن قيس أيضًا. وعزاه السيوطي إلى عبد بن حميد.|12:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|13:أخرجه البزار في البحر الزخار المعروف بمسند البزار ٨/١٧٩ (٣٢١٠). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|14:تفسير مقاتل بن سليمان ٤/٤٢٢.|15:أخرجه ابن جرير ٢٣/٢٢٣.
  69,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا نُفِخَ فِی ٱلصُّورِ نَفۡخَةࣱ وَ ٰ⁠حِدَةࣱ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا نُفِخَ فِي الصُّورِ نَفْخَةٌ واحِدَةٌ﴾</span> لا تُثنّى، يعني: نفخة الآخرة{1}<span class=comment-ref>٦٧٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٩) أنّ النفخة المُشار إليها في هذه الآية هي نفخة القيامة التي للفزع، ومعها يكون الصعق، ثم نفخة البعْث. و<span class="comment-type-4">ذكر</span> أنه قيل: هي نفخات ثلاثة: نفخة الفَزَع، ونفخة الصعق، ثم نفخة البعْث.</p><p>ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى السياق</span>- أنها نفخة الفَزَع، فقال: «والإشارة بآيتنا هذه إلى نفخة الفَزَع؛ لأنّ حَمْل الجبال هو بعدها».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١١٤) أنّ الربيع قال: هي النفخة الأخيرة.</p><p>ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى السياق</span>- أنّ المراد بهذه النفخة: نفخة البعْث، فقال: «والظاهر ما قلناه؛ ولهذا قال هاهنا: <span class="qpc-hafs">﴿وحملت الأرض والجبال فدكتا دكة واحدة﴾</span> أي: فمُدّتْ مَدّ الأديم العكاظي، وتَبدّلت الأرض غير الأرض».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٢.
  69,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَحُمِلَتِ ٱلۡأَرۡضُ وَٱلۡجِبَالُ فَدُكَّتَا دَكَّةࣰ وَ ٰ⁠حِدَةࣰ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٧١<span class="dash">-</span></span> عن <span class="name-1">أُبيّ بن كعب</span> -من طريق أبي العالية- في قوله: <span class="qpc-hafs">﴿وحُمِلَتِ الأَرْضُ والجِبالُ فَدُكَّتا دَكَّةً واحِدَةً﴾</span>، قال: يصيران غَبَرةً على وجوه الكفار، لا على وجوه المؤمنين، وذلك قوله: <span class="qpc-hafs">﴿ووُجُوهٌ يَوْمَئِذٍ عَلَيْها غَبَرَةٌ تَرْهَقُها قَتَرَةٌ﴾</span> [عبس:٤٠-٤١]{1}. (١٤/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿فَدُكَّتا دَكَّةً واحِدَةً﴾</span>. قال: زلزلة شديدة عند النفحة الآخرة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ عديّ بن زيد وهو يقول:</p><p>ملِكٌ يُنفِق الخزائن والذِّمْـ ـمَـة قد رَدَّها وكادتْ تَبُور؟{2}. (١٤/٦٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٧٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزُّهريّ</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَدُكَّتا دَكَّةً واحِدَةً﴾</span>، قال: بلَغني: أنّ النبي ﷺ قال: «<b>يَقبض الله الأرضَ، ويَطوي السماء بيمينه، ثم يقول: لِمَن المُلك؟ أين ملوك الأرض؟</b>»{3}. (١٤/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحُمِلَتِ الأَرْضُ﴾</span> يقول: حُمِل ما على الأرض مِن ماء أو شجر أو شيء <span class="qpc-hafs">﴿و﴾</span>حُمِلت <span class="qpc-hafs">﴿الجِبالُ﴾</span> مِن أماكنها، فضُربت على الأرض، <span class="qpc-hafs">﴿فَدُكَّتا دَكَّةً واحِدَةً﴾</span> يعني: فُكسِرتا كسرة واحدة، فاستوتْ بما عليها، مثل الأديم الممدود{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٧٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وحُمِلَتِ الأَرْضُ والجِبالُ فَدُكَّتا دَكَّةً واحِدَةً﴾</span>، قال: صارت غبارًا{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٥٠٠. وعزاه السيوطي إلى البيهقي في البعث والنشور.|2:عزاه السيوطي إلى الطستي.|3:أخرجه عبد الرزاق ٢/٣١٣. وعزاه السيوطي إلى ابن المنذر. وهو في الصحيحين من رواية الزُّهريّ، عن سعيد بن المسيب، عن أبي هريرة.|4:تفسير مقاتل بن سليمان ٤/٤٢٢.|5:أخرجه ابن جرير ٢٣/٢٢٤.
  69,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَوۡمَىِٕذࣲ وَقَعَتِ ٱلۡوَاقِعَةُ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَيَوْمَئِذٍ وقَعَتِ الواقِعَةُ﴾</span> وقَعت الصيحةُ الآخرة، يعني: النفخة الآخرة{1}<span class=comment-ref>٦٧٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٠) <b>قولًا</b> بأنّ الواقعة: إشارة إلى صخرة بيت المقدس. و<span class="comment-type-2">انتقده</span> بقوله: «وهذا ضعيف».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٢.
  69,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱنشَقَّتِ ٱلسَّمَاۤءُ فَهِیَ یَوۡمَىِٕذࣲ وَاهِیَةࣱ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَهِيَ يَوْمَئِذٍ واهِيَةٌ﴾</span>، قال: مُتَخَرِّقة{1}. (١٤/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وانْشَقَّتِ السَّماءُ فَهِيَ يَوْمَئِذٍ واهِيَةٌ﴾</span>: يعني: مُتَمَزِّقة ضعيفة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٧٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق الأجلح- قال: إذا كان يومُ القيامة أمر اللهُ السماءَ الدنيا بأهلها، ونَزل مَن فيها مِن الملائكة، فأَحاطوا بالأرض ومَن عليها، ثم الثانية، ثم الثالثة، ثم الرابعة، ثم الخامسة، ثم السادسة، ثم السابعة، فصَفُّوا صفًّا دون صف، ثم نَزل المَلَك الأعلى على مُجنّبته اليُسرى جهنم، فإذا رآها أهل الأرض نَدُّوا، فلا يأتون قُطرًا من أقطار الأرض إلا وجدوا سبعة صفوف مِن الملائكة، فيَرجعون إلى المكان الذي كانوا فيه، فذلك قول الله: <span class="qpc-hafs">﴿إنِّي أخافُ عَلَيْكُمْ يَوْمَ التَّنادِ يَوْمَ تُوَلُّونَ مُدْبِرِينَ ما لَكُمْ مِنَ اللَّهِ مِن عاصِمٍ﴾</span> [غافر:٣٢-٣٣]. وذلك قوله: <span class="qpc-hafs">﴿وجاءَ رَبُّكَ والمَلَكُ صَفًّا صَفًّا وجِيءَ يَوْمَئِذٍ بِجَهَنَّمَ﴾</span> [الفجر:٢٢-٢٣]. وقوله: <span class="qpc-hafs">﴿يا مَعْشَرَ الجِنِّ والإنْسِ إنِ اسْتَطَعْتُمْ أنْ تَنْفُذُوا مِن أقْطارِ السَّماواتِ والأَرْضِ فانْفُذُوا لا تَنْفُذُونَ إلّا بِسُلْطانٍ﴾</span> [الرحمن:٣٣]. وذلك قوله: <span class="qpc-hafs">﴿وانْشَقَّتِ السَّماءُ فَهِيَ يَوْمَئِذٍ واهِيَةٌ والمَلَكُ عَلى أرْجائِها﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وانْشَقَّتِ السَّماءُ﴾</span>، قال: ذلك قوله: <span class="qpc-hafs">﴿وفُتِحَتِ السَّماءُ فَكانَتْ أبْوابًا﴾</span> [النبأ:١٩]{4}. (١٤/٦٧٠)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن جرير ٢٣/٢٢٥.|3:أخرجه ابن جرير ٢٣/٢٢٥.|4:عزاه السيوطي إلى ابن المنذر.
  69,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡمَلَكُ عَلَىٰۤ أَرۡجَاۤىِٕهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قال: على حافاتها؛ على ما لَمْ يَهِ منها{1}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، يقول: والمَلَك على حافات السماء حين تَشَقّق. ويقال: على سعة كلّ شيء تَشَقّق عنه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيّب</span> -من طريق عطاء بن السّائِب-: الأرجاء: حافات السماء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قال: على حافات السماء{4}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء بن السّائِب- <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قال: على ما لم يَهِ منها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٧<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قالا: على ما لم ينشقّ منها{6}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قال: الملائكة على أطرافها{7}. (١٤/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٨٩<span class="dash">-</span></span> عن الأجْلح، قال: قلتُ ل<span class="name-2">لضَّحّاك</span>: ما أرجاؤها؟ قال: حافاتها{4}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قالوا: على حافات السماء{9}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿والملك على أرجائها﴾</span>، قال: بلغني: أنه على أقطارها. قال معمر: وقال <span class="name-2">قتادة</span>: على نواحيها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قال: الملائكة على شَقِّها، ينظرون إلى أهل الأرض وما أتاهم مِن الفَزَع{11}. (١٤/٦٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والمَلَكُ﴾</span> يقول: انفَجرت السماءُ لِنُزول الرّبّ -تبارك وتعالى- وما فيها من الملائكة <span class="qpc-hafs">﴿عَلى أرْجائِها﴾</span> يعني: نواحيها وأطرافها، وهي السماء الدنيا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٤<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿والمَلَكُ عَلى أرْجائِها﴾</span>، قال: نواحيها{3}<span class=comment-ref>٦٧٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٣٥٩ ط: دار الكتب العلمية) أنّ جمهور المفسرين على أنّ الضمير في <span class="qpc-hafs">﴿أرجائها﴾</span> عائدٌ على السماء، أي: الملائكة على نواحيها، وما لم يَهِ منها. و<span class="comment-type-4">ذكر</span> أنّ الضَّحّاك، وابن جُبَير قالا بأن الضمير في <span class="qpc-hafs">﴿أرجائها﴾</span> عائد على الأرض. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وإن كان لم يتقدّم لها ذكر قريب؛ لأنّ القصة واللفظ يقتضي إفهام ذلك». و<span class="comment-type-4">ذكر</span> أنهما فسّرا هذه الآية بما جاء في الأثر عن الضحاك في تفسير قوله: <span class="qpc-hafs">﴿وانْشَقَّتِ السَّماءُ فَهِيَ يَوْمَئِذٍ واهِيَةٌ﴾</span>.</div></p><p><h3><span class="qpc-hafs">﴿وَیَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمۡ یَوۡمَىِٕذࣲ ثَمَـٰنِیَةࣱ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٩٥<span class="dash">-</span></span> عن محمد بن إسحاق -من طريق سلمة- قال: بلغنا: أنّ رسول الله ﷺ قال: «<b>هم اليوم أربعة</b> -يعني: حملة العرش-، <b>وإذا كان يوم القيامة أيّدهم الله بأربعة آخرين؛ فكانوا ثمانية، وقد قال الله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span></b>»{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٦<span class="dash">-</span></span> قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: ثمانية أملاك. وقال: قال رسول الله ﷺ: «<b>يَحمله اليوم أربعة، ويوم القيامة ثمانية</b>». وقال رسول الله ﷺ: «<b>إنّ أقدامهم لَفي الأرض السابعة، وإنّ مَناكبهم لَخارجة مِن السماوات، عليها العرش</b>». قال عبد الرحمن بن زيد بن أسلم: الأربعة. قال: بلَغنا: أنّ رسول الله ﷺ قال: «<b>لَمّا خلقهم اللهُ قال: تَدرون لِمَ خَلقتُكم؟ قالوا: خَلقتَنا -ربّنا- لِما تشاء. قال لهم: تَحملون عرشي. ثم قال: سَلوني مِن القوة ما شئتم أجعلها فيكم. فقال واحد منهم: قد كان عرش ربّنا على الماء، فاجعل فِيّ قوة الماء. قال: قد جَعلتُ فيك قوة الماء. وقال آخر: اجعل فِيّ قوة السماوات. قال: قد جَعلتُ فيك قوة السماوات. وقال آخر: اجعل فِيّ قوة الأرض. قال: قد جَعلتُ فيك قوة الأرض والجبال. وقال آخر: اجعل فِيّ قوة الرياح. قال: قد جَعلتُ فيك قوة الرياح. ثم قال: احملوا. فوضَعوا العرشَ على كواهلهم، فلم يَزولوا، قال: فجاء عِلمٌ آخر، وإنما كان علمهم الذي سألوه القوة، فقال لهم: قولوا: لا حول ولا قوة إلا بالله. فقالوا: لا حول ولا قوة إلا بالله. فجعل الله فيهم مِن الحَوْل والقوة ما لم يَبلغه عِلْمهم، فحَملوا</b>»{15}. (١٤/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٧<span class="dash">-</span></span> عن <span class="name-1">العباس بن عبد المطلب</span> -من طريق الأَحْنَف بن قيس- في قوله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: ثمانيةُ أمْلاكٍ على صورة الأَوْعال{16}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: ثمانية صفوف مِن الملائكة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي مالك- في قوله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: ثمانية صفوف من الملائكة، لا يَعلم عِدّتهم إلا الله{18}. (١٤/٦٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: هي الصفوف مِن وراء الصفوف{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عطاء- <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>: أرجُلهم في تخُوم الأرضين السابعة، يَحملون العرش، ما منهم أحدٌ يَرفع طرْفه{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٢<span class="dash">-</span></span> عن <span class="name-2">مَيسرة</span> -من طريق عطاء بن السّائِب- في قوله: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: أرجُلهم في التُّخُوم، ورؤوسهم عند العرش، لا يستطيعون أن يَرفعوا أبصارهم من شعاع النور{21}. (١٤/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٣<span class="dash">-</span></span> عن <span class="name-2">زاذان</span> -من طريق عطاء بن السّائِب، عن مَيسرة-، مثله{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: يقال: ثمانية صفوف مِن الملائكة، لا يَعلم عِدّتهم إلا الله. ويقال: ثمانية أملاك، رؤوسهم عند العرش في السماء السابعة، وأقدامهم في الأرض السُّفلى، ولهم قرونٌ كقرون الوَعِلة، ما بين أصل قرْن أحدهم إلى مُنتهاه خمسمائة عام{23}. (١٤/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٥<span class="dash">-</span></span> عن ابن أبي حسين، عن <span class="name-2">شَهْر بن حَوْشَب</span>، أنه حَدّثه قال: <span class="qpc-hafs">﴿ويحمل عرش ربك فوقهم يومئذ ثمانية﴾</span>، قال: تَحمله الملائكة على كواهلها بأيدٍ، وعزة، وحُسن، وجمال{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٦<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق ابنه عبد الله- في قوله تعالى: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ﴾</span>، قال: أربعة ملائكة يَحملون العرش على أكتافهم، لكلّ واحد منهم أربعة أوجه؛ وجهٌ وجهُ ثَوْر، ووجهٌ وجهُ أسد، ووجهٌ وجهُ نَسْر، ووجهٌ وجهُ إنسان، ولكلّ واحد منهم أربعة أجنحة، أما جناحان فعلى وجهه مِن أن يَنظر إلى العرش فيَصعق، وأما جناحان فيَهفو بهما، ليس لهم كلام إلا أن يقولوا: قَدِّسوا اللهَ القويَّ، ملأتْ عَظمتُه السماواتِ والأرض{25}. (١٤/٦٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿يَوْمَئِذٍ ثَمانِيَةٌ﴾</span> هم اليوم أربعة مِن الملائكة، وهم يومئذ ثمانية{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: ثمانية من الملائكة{27}. (١٤/٦٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٠٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمانِيَةٌ﴾</span>، قال: ثمانية صفوف{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ﴾</span> على رءوسهم <span class="qpc-hafs">﴿يَوْمَئِذٍ ثَمانِيَةٌ﴾</span> أجزاء من الكروبيين لا يَعلم كثرتهم أحدٌ إلا الله ﷿{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمۡ یَوۡمَىِٕذࣲ ثَمَـٰنِیَةࣱ ۝١٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٥١١<span class="dash">-</span></span> قال رسول الله ﷺ: «<b>لكلّ مَلكٍ منهم وجه رَجُل، ووجه أسد، ووجه ثَوْر، ووجه نِسْر</b>»{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٢<span class="dash">-</span></span> عن محمد بن المُنكَدِر، عن جابر بن عبد الله، عن النبي ﷺ، قال: «<b>أُذِن لي أن أُحَدِّث عن مَلَكٍ مِن ملائكة الله مِن حملة العرش: إنّ ما بين شَحْمة أُذُنه إلى عاتقه مسيرة سبعمائة عام</b>»{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٣<span class="dash">-</span></span> عن محمد بن المُنكَدِر، قال: قال رسول الله ﷺ: «<b>أُذِن لي أنْ أُحَدِّث عن مَلكٍ مِن حملة العرش؛ رِجْلاه في الأرض السُّفلى، وعلى قرْنه العرش، وبين شَحْمة أُذُنه إلى عاتقه خَفَقان الطير مسيرة سبعمائة سنة، يقول: سبحانك حيث كنت</b>»{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، قال: لم يُسمّ من حملة العرش إلا إسرافيل، وميكائيل ليس من حملة العرش{33}. (١٤/٦٧٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٢٧. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٣/٢٢٦.|3:أخرجه ابن جرير ٢٣/٢٢٧.|4:أخرجه ابن جرير ٢٣/٢٢٦. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧١-، وابن جرير ٢٣/٢٢٧.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٣/٢٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:أخرجه ابن جرير ٢٣/٢٢٦. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه عبد بن حميد -كما في فتح الباري ٦/٢٩٨-، وابن جرير ٢٣/٢٢٦.|10:أخرجه عبد الرزاق ٢/٣١٣. وأخرجه ابن جرير ٢٣/٢٢٦ من طريق ابن ثور عن معمر من قوله أنه قال: بلغني: أنها أقطارها. ثم أورد قول قتادة الأخير.|11:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:تفسير مقاتل بن سليمان ٤/٤٢٣.|13:أخرجه ابن جرير ٢٣/٢٢٧.|14:أخرجه ابن جرير ٢٣/٢٢٩ مرسلًا.|15:أخرجه ابن جرير معضلًا ٢٣/٢٢٩. وأورده السيوطي مختصرًا.|16:أخرجه الدارمي في الرد على الجهمية (١٩)، وأبو يعلى (٦٧١٢)، وابن خزيمة في كتاب التوحيد (١٤٤)، والحاكم ٢/٥٠٠، والخطيب في تالي التلخيص (٢٩٥). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.|17:أخرجه ابن جرير ٢٣/٢٢٨.|18:أخرجه ابن جرير ٢٣/٢٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|19:أخرجه ابن جرير ٢٣/٢٢٨.|20:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٢-.|21:أخرجه ابن جرير ٢٣/٢٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|22:أخرجه أبو الشيخ في العظمة (٤٦٩).|23:أخرجه ابن جرير ٢٣/٢٢٨. وعزاه السيوطي إلى عبد بن حميد.|24:أخرجه أبو نعيم في حلية الأولياء ٦/٦١-٦٢.|25:أخرجه عبد الرزاق ٢/٣١٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر دون ذكر الآية.|26:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٩-.|27:عزاه السيوطي إلى عبد بن حميد.|28:أخرجه عبد الرزاق ٢/٣١٤.|29:تفسير مقاتل بن سليمان ٤/٤٢٣.|30:أورده الثعلبي ١٠/٢٩، والبغوي ٨/٢١٠ دون بيان سنده أو راويه.|31:أخرجه أبو داود ٧/١٠٩ (٤٧٢٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢١٢- بنحوه، والثعلبي ٨/٢٦٦.</p><p>قال ابن كثير: «هذا إسناد جيد، رجاله ثقات، وقد رواه أبو داود في كتاب السنة مِن سننه». وقال الهيثمي في المجمع ١/٨٠ (٢٥٦): «رجاله رجال الصحيح». وقال ابن حجر في الفتح ٨/٦٦٥: «إسناده على شرط الصحيح». وقال السيوطي: «سند صحيح». وقال المناوي في التيسير ١/١٣٥: «إسناده صحيح». وقال المظهري في تفسيره ٨/٢٤٣: «سند صحيح». وقال الألوسي في روح المعاني ١٢/٢٩٩: «سند صحيح». وأورده الألباني في الصحيحة ١/٢٨٢ (١٥١).|32:أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٩- مرسلًا، وقال عقبه: بلغني: أن اسمه رزوفيل.|33:عزاه السيوطي إلى ابن أبي حاتم.
  69,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَىِٕذࣲ تُعۡرَضُونَ لَا تَخۡفَىٰ مِنكُمۡ خَافِیَةࣱ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥١٥<span class="dash">-</span></span> عن أبي موسى، قال: سمعتُ النبي ﷺ يقول في قوله: <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ لا تَخْفى مِنكُمْ خافِيَةٌ﴾</span>، قال: «<b>عَرْضتان فيهما الخُصومة والجِدال، والعَرْضة الثالثة تَطايُر الصُّحف في أيدي الرجال</b>»{1}. (١٤/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٦<span class="dash">-</span></span> عن أبي موسى، قال: قال رسول الله ﷺ: «<b>يُعرض الناس يوم القيامة ثلاث عَرَضاتٍ؛ فأمّا عَرْضتان فجِدالٌ ومَعاذير، وأمّا الثالثة فعند ذلك تَطايُر الصُّحف في الأيدي؛ فآخذٌ بيمينه، وآخذٌ بشماله</b>»{2}. (١٤/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٧<span class="dash">-</span></span> عن عبد الله بن المِسْوَر، عن <span class="name-1">أبيه</span>، قال: قال النبي صلى الله عليه وآله وسلم: «<b>إذا دخل النور القلبَ انفسَح له وانشرح</b>». قيل: يا رسول الله، هل لذاك مِن علامة يُعرف به؟ قال: «<b>نعم، الإنابة إلى دار الخلود، والتجافي عن دار الغرور، والاستعداد للموت قبل نزول الموت</b>». <b>وتعرَّضوا للعرض الأكبر</b> <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ لا تَخْفى مِنكُمْ خافِيَةٌ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق مالك- أنه قال: حاسِبوا أنفسكم قبل أن تُحاسَبوا؛ فإنه أيسر لحسابكم، وزِنوا أنفسكم قبل أن تُوزَنوا، وتَجهَّزوا للعرض الأكبر: <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ لا تَخْفى مِنكُمْ خافِيَةٌ﴾</span>{4}. (١٤/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي وائل- قال: يُعرض الناس يوم القيامة ثلاث عَرَضاتٍ؛ فأمّا عَرْضتان فجِدالٌ ومَعاذير، وأما العَرْضة الثالثة فتَطايُر الكتب في الأيمان والشمائل{5}. (١٤/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٠<span class="dash">-</span></span> قال <span class="name-1">أبو موسى الأشعري</span> -من طريق الحسن- <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ لا تَخْفى مِنكُمْ خافِيَةٌ﴾</span>: يُعرض الناس ثلاث عَرَضاتٍ؛ فأمّا عَرْضتان فجِدالٌ ومَعاذير، وأما العَرْضة الثالثة فعندها تَطايُر الصُّحف؛ فآخذٌ بيمينه وآخذٌ بشماله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ﴾</span>، قال: تُعرضون ثلاث عَرَضاتٍ؛ فأمّا عَرْضتان ففيهما الخُصومات والمَعاذير، وأمّا الثالثة فتَطايُر الصُّحف في الأيدي{7}. (١٤/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ لا تَخْفى مِنكُمْ خافِيَةٌ﴾</span>، قال: ذُكر لنا: أنّ نبي الله ﷺ كان يقول: «<b>يُعرَض الناس ثلاث عَرَضاتٍ يوم القيامة؛ فأمّا عَرْضتان ففيهما خُصومات ومَعاذير وجِدال، وأمّا العَرْضة الثالثة فتَطير الصُّحف في الأيدي</b>». اللهم، اجعلنا ممن تؤتيه كتابه بيمينه. قال: وكان بعضُ أهل العلم يقول: إنّي وجدتُ أكْيس الناس مَن قال: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span>. قال: ظنّ ظنًّا يقينًا، فنَفعه الله بظنّه. قال: وذُكر لنا: أنّ نبي الله ﷺ كان يقول: «<b>مَن استطاع أن يموت وهو يُحسن الظنّ بالله فليفعل</b>»{8}. (١٤/٦٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿مِنكُمْ خافِيَةٌ﴾</span> لا يخفى على الله منكم شيء{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَوْمَئِذٍ تُعْرَضُونَ﴾</span> على الله، فيحاسبكم بأعمالكم، <span class="qpc-hafs">﴿لا تَخْفى مِنكُمْ خافِيَةٌ﴾</span> يقول: لا يخفى الصالح منكم ولا الطالح إذا عُرضتم{10}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه أحمد ٣٢/٤٨٦ (١٩٧١٥)، وابن ماجه ٥/٣٤٢-٣٤٣ (٤٢٧٧)، والترمذي عقب الحديث ٤/٤٢٣-٤٢٤ (٢٥٩٤).</p><p>وأورده الدارقطني في العلل ٧/٢٥١ (١٣٣١) وقال: «والموقوف هو الصحيح». وقال البوصيري في مصباح الزجاجة ٤/٢٥٤ (١٣٥١): «هذا إسناد رجاله ثقات، إلا أنه منقطع؛ الحسن لم يسمع من أبي موسى. قاله علي بن المديني، وأبو حاتم، وأبو زرعة».|3:أخرجه الشجري في ترتيب الأمالي الخميسية ٢/٤٠٧ (٢٩٢٤)، وأبو الشيخ في طبقات المحدثين ١/٤٥٢-٤٥٣، من طريق ابن عيينة، عن خالد بن أبي كريمة، عن عبد الله بن المِسْوَر، عن أبيه به.</p><p>وسنده شديد الضعف؛ فيه عبد الله بن المِسْوَر بن عون بن جعفر بن أبي طالب، وهو متروك. الميزان ٢/٥٠٤.|4:أخرجه ابن المبارك (٣٠٦).|5:أخرجه ابن جرير ٢٣/٢٣٠-٢٣١. وعزاه السيوطي إلى البيهقي في البعث.|6:أخرجه ابن جرير ٢٣/٢٣٠.|7:أخرجه عبد الرزاق ٢/٣١٤. وعزاه السيوطي إلى ابن المنذر.|8:أخرجه ابن جرير ٢٣/٢٣١ مختصرًا مرسلًا. وعزاه السيوطي إلى عبد بن حميد.|9:تفسير البغوي ٨/٢١١.|10:تفسير مقاتل بن سليمان ٤/٤٢٣.
  69,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِیَمِینِهِۦ فَیَقُولُ هَاۤؤُمُ ٱقۡرَءُوا۟ كِتَـٰبِیَهۡ ۝١٩﴾</span> - نزول الآية وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٢٥<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> أنها ذَكرتِ النار، فبَكَتْ، فقال رسول الله ﷺ: «<b>ما يبكيكِ؟</b>». قالت: ذكرتُ النار، فبكيتُ، فهل تذكرون أهليكم يوم القيامة؟ فقال رسول الله ﷺ: «<b>أمّا في ثلاثة مواطن فلا يَذكر أحدٌ أحدًا: عند الميزان حتى يَعلم أيخفُّ ميزانه أو يَثقُل، وعند الكتاب حين يقال: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</span> حتى يَعلم أين يقع كتابه أفي يمينه، أم في شماله، أم من وراء ظهره؟ وعند الصراط إذا وُضِعَ بين ظهري جهنم</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٦<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> –من طريق أبي العالية الرياحي- قال: يُدعى الخلائقُ يوم القيامة للحساب، فإذا كان الرجلُ في الخير رأسًا يدعو إليه، ويأمر به، ويكثر عليه تبعه؛ دُعي باسمه واسم أبيه، فيقوم، حتى إذا دنا أُخرج له كتابٌ أبيض بخطٍّ أبيض؛ في باطنه السيئات، وفي ظهره الحسنات، فيبدأ بالسيئات، فيقرأها، فيُشفِق ويتغير لونه، فإذا بلغ آخرَ الكتاب وجد فيه: هذه سيئاتك وقد غُفِرت لك. فيفرح، ثم يقلب كتابه، فيقرأ حسناته، فلا يزداد إلا فرحًا، حتى إذا بلغ آخر الكتاب وجد فيه: هذه حسناتك وقد ضُعِّفت لك. فيبيَضُّ وجهه، ويُؤتى بتاجٍ فيُوضع على رأسه، ويُكسى حُلَّتين، ويُحلّى كلُّ مفصل منه، ويطول ستين ذراعًا، وهي قامة آدم، ويُعطى كتابه بيمينه، فيُقال له: انطلق إلى أصحابك، فبشِّرهم، وأخبرهم أن لكل إنسان منهم مثل هذا. فإذا أدبر قال: <span class="qpc-hafs">﴿هاؤم اقرءوا كتابيه * إني ظننت أني ملاق حسابيه﴾</span>. يقول الله: <span class="qpc-hafs">﴿فهو في عيشة راضية * في جنة عالية * قطوفها دانية﴾</span>. فيقول لأصحابه: هل تعرفوني؟ فيقولون: قد غيَّرتك كرامةُ الله، مَن أنت؟ فيقول: أنا فلان بن فلان، ليبشر كلُّ رجل منكم بمثل هذا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق القاسم بن محمد- قال: أول من يُعطى كتابه بيمينه أبو سَلمة بن عبد الأَسد. قال: وهو الذي يقول: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</span>. قال: وكان عبد الله بن عباس يقرؤها: (كُلْ واشْرَبْ يَآ أبا سَلَمَةَ هَنِيئًا بِمَآ أسْلَفْتَ فِي الأَيّامِ الخالِيَةِ){3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٨<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span> -من طريق أبي بردة- قال: يَنشر اللهُ كَنفه يوم القيامة على المؤمنين هكذا، وقال: بيده فوقه، فيقول: يا ابن آدم، هذه حسنةٌ عمِلتَها في مكان كذا وكذا، ساعة كذا وكذا، وقد قبلتُها منك. ثم يَسجد المؤمن، ثم يقول: يا ابن آدم، هذه سيئة عمِلتَها يوم كذا وكذا، وقد غَفرتُها لك. فيَسجد المؤمن، فيقول الخلْق: طُوبى لهذا العبد الذي لا يَرى في كتابه إلا الحسنات. مِن كثرة ما يَسجد، فإذا فَرغ قال: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span> [الحاقة:١٨-١٩] إني أيقنتُ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٢٩<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق إسماعيل بن عبد الرحمن، عن رجل من بني أسد- قال: ... يُدعى المؤمن، فيُعطى كتابه بيمينه، فيَنظر فيه، فحسناته بادياتٌ للناس، وهو يقرأ سيئاته لكي لا يقول: كانت لي حسنات فلم تُذكر. فأحبَّ الله أن يُريه عمله كلّه، حتى إذا استنفذ ما في الكتاب وجد في آخر ذلك كلّه أنه مغفور، وإنك من أهل الجنة، فعند ذلك يُقبِل إلى أصحابه، ثم يقول: <span class="qpc-hafs">﴿هاؤم اقرءوا كتابيه إني ظننت أني ملاق حسابيه﴾</span>. ثم يُدعى الكافر، فيُعطى كتابه بشماله، ثم يُلفّ فيُجعل مِن وراء ظهره ويُلوى عُنُقه، فذلك قوله: <span class="qpc-hafs">﴿وأما من أوتي كتابه وراء ظهره﴾</span> [الانشقاق:١٠] يَنظر في كتابه، فسيئاته بادياتٌ للناس، ويَنظر في حسناته، لكي لا يقول: أفأُثاب على السيئات؟!{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٠<span class="dash">-</span></span> عن <span class="name-2">أبي عثمان النَّهدي</span>، قال: إنّ المؤمن لَيُعطى كتابه في سِترٍ مِن الله، فيَقرأ سيئاته، فيَتغيّر لونه، ثم يقرأ حسناته، فيَرجع إليه لونُه، ثم يَنظر فإذا سيئاته قد بُدِّلت حسنات، فعند ذلك يقول: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</span>{6}. (١٤/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣١<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبد الله بن حَنظلة</span> غَسيل الملائكة -من طريق موسى بن عبيدة- قال: إنّ الله يَقفُ عبدَه يوم القيامة، فيُبدي سيئاتِه في ظهر صحيفته، فيقول له: أنتَ عملتَ هذا؟ فيقول: نعم، أي ربِّ. فيقول له: إني لم أفضحك به، وإني قد غَفرتُ لك. فيقول عند ذلك: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span> حين نجا من فضيحة يوم القيامة{7}. (١٤/٦٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٢<span class="dash">-</span></span> عن عبد الرحمن بن شُريح، أنه سمع أشياخًا يقولون: إنّ العبد يُعطى يوم القيامة كتابه، فيَنظر في بطنه، فإذا فيه مكتوب سيئاته، وفي ظهره حسناته، فهو يقرأ السيئات، فيَتغيّر لها وجهه، ويَشتدّ منها خوفه، ومَن قرأ ما في ظهر كتابه غَبطه على ما فيه مِن حسناته، فيقول: يا ربِّ، قد عملتُ حسناتٍ لم أجدها في هذا الكتاب. فيقال: اقْلب أو حوِّل. فإذا بالحسنات وبُدّلتْ تلك السيئات حسنات، فلما قرأها أسفَر وجهه، ومَن قرأ ما يحول إليهم من كتابه قرؤوها حسنات، فيغبطون عليها، ثم أُمر أن يَقلب أيضًا، فإذا تلك السيئات قد حُوّلتْ حسنات، فعند ذلك يقول الذي قال الله في كتابه: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ﴾</span> يقول: يُعطيه مَلكه الذي كان يكتب عمله في صحيفة بيضاء منشورة. نزلت هذه الآية في أبي سَلمة بن عبد [الأسد] المَخزوميّ، وكان اسم أُمّ أبي سلمة بَرّة بنت عبد المُطَّلب <span class="qpc-hafs">﴿فَيَقُولُ هاؤُمُ﴾</span> يعني: هاكم <span class="qpc-hafs">﴿اقْرَءُوا كِتابِيَهْ﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</span>، قال: تعالوا{10}<span class=comment-ref>٦٧٦٦</span><span class=comment-ref>٦٧٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٢) أنه اختُلف في الفرقة التي ينفذ فيها الوعيد من أهل المعاصي متى تأخذ كتبها، على قولين: <b>الأول</b>: أنها تأخذها مع الناس، وذلك يُؤنسها مدة العذاب. و<span class="comment-type-4">نقل</span> عن الحسن أنه قال: «فإذا أُعطى كتابه بيمينه لم يقرأه حتى يأذن الله تعالى له، فإذا أذِن له قال: <span class="qpc-hafs">﴿هاؤم اقرؤا كتابيه﴾</span>». <b>الثاني</b>: أنه إذا أخرجوا من النار، والإيمان يُؤنسهم وقت العذاب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> القول الثاني <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وهذا ظاهر هذه الآية؛ لأنّ مَن يسير إلى النار فكيف يقول: هاؤم اقرؤوا كتابيه؟».</div></p><p><div><span class=comment-ref>٦٧٦٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١١٧) أن عبد الرحمن بن زيد قال: معنى: <span class="qpc-hafs">﴿هاؤم اقرءوا كتابيه﴾</span> أي: ها اقرؤوا كتابيه، و«ؤم» زائدة.</p><p>و<span class="comment-type-3">رجَّح</span> أنها بمعنى: هاكم، فقال: «والظاهر أنها بمعنى: هاكم». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٩٢) أن البعض قال بأن أصل قوله: <span class="qpc-hafs">﴿هاؤم﴾</span> هاؤموا، ثم نقله التخفيف والاستعمال. وأن آخرين قالوا بأن الميم ضمير الجماعة. و<span class="comment-type-2">انتقد</span> القولين بقوله: «وفي هذا كله نظر». ثم <span class="comment-type-4">علَّق</span> بقوله: «والمعنى على كل وجه: تعالوا، فهو استدعاء للفعل المأمور به».</div></p></div>",footnotes:1:أخرجه أبو داود ٧/١٣٣ (٤٧٥٥)، والحاكم ٤/٦٢٢ (٨٧٢٢)، من طريق الحسن البصري، عن عائشة به.</p><p>قال الحاكم: «هذا حديث صحيح، إسناده على شرط الشيخين لولا إرسال فيه بين الحسن وعائشة». ووافقه الذهبي في التلخيص.|2:تفسير يحيى بن سلام ١/١٢١-١٢٢.|3:أخرجه الضياء المقدسي في المختارة ١٣/٤٦ (٤٩).|4:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٢-.|5:أخرجه ابن المبارك في الزهد ص ٥١٩.|6:أخرجه الخطيب ١٢/٢٥١. وعزاه السيوطي إلى ابن المبارك في الزهد وعبد بن حميد، وابن المنذر.|7:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٤١-.|8:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٣٢ (٣٠٣).|9:تفسير مقاتل بن سليمان ٤/٤٢٣.|10:أخرجه ابن جرير ٢٣/٢٣١.
  69,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنِّی ظَنَنتُ أَنِّی مُلَـٰقٍ حِسَابِیَهۡ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إنِّي ظَنَنْتُ﴾</span> قال: أيقنتُ{1}. (١٤/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- قال: كل ظن في القرآن <span class="qpc-hafs">﴿إنِّي ظَنَنْتُ﴾</span> يقول: أي: عَلمتُ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- في قوله ﷿: <span class="qpc-hafs">﴿هاؤم اقرأوا كتابيه إني ظننت أني ملاق حسابيه﴾</span>، قال: إنّ المؤمن أحسنَ الظنّ بربّه فأحسنَ العمل، وإنّ المنافق أساء الظنّ فأساء العمل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span>، قال: يقول: إنِّي قد عَلمتُ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span>، قال: ما كان مِن ظنّ الآخرة فهو عِلمٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span>: ظنّ ظنًّا يقينًا، فنَفعه الله بظنّه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤١<span class="dash">-</span></span> عن <span class="name-3">عمر بن ذرّ</span>، في قوله: <span class="qpc-hafs">﴿فأما من أوتي كتابه بيمينه فيقول هاؤم اقرءوا كتابيه﴾</span> قال: حَمل -وربّ الكعبة- ظنّه على اليقين، ثم نادى مُسفر وجهه، ثَلِجٌ{7} قلبه، مُطلقة يداه. <span class="qpc-hafs">﴿وأما من أوتي كتابه بشماله فيقول يا ليتني لم أوت كتابيه﴾</span> أخذ ابن ذرّ يقول: صَدَقْتَ، يا كذاب، صدقت، يا كذاب، ينادي مُسْوَدٌّ وجْهُه، كاسفٌ باله، مُغلولة يداه إلى عنقه ...{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span>، قال: إنّ الظن مِن المؤمن يقين، وإنّ «عسى» من الله واجب، <span class="qpc-hafs">﴿فَعَسى أُولَئِكَ أنْ يَكُونُوا مِنَ المُهْتَدِينَ﴾</span> [التوبة:١٨]، و<span class="qpc-hafs">﴿فَعَسى أنْ يَكُونَ مِنَ المُفْلِحِينَ﴾</span> [القصص:٦٧]{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٣٢.|2:أخرجه ابن جرير ٢٣/٢٣٢.|3:أخرجه أبو نعيم في حلية الأولياء ٢/١٤٤.|4:أخرجه عبد الرزاق ٢/٣١٥.|5:أخرجه ابن جرير ٢٣/٢٣٢.|6:أخرجه ابن جرير ٢٣/٢٣٢.|7:يُقال: ثَلِجَتْ نفسي بالأمر تَثْلَجُ ثَلَجًا وثَلَجَتْ ثُلُوجًا: إذا اطمأنّت إليه، وسكنت، وثبت فيها، ووثقت به. النهاية (ثلج).|8:أخرجه أبو نعيم في حلية الأولياء ٥/١١٤-١١٥.|9:أخرجه ابن جرير ٢٣/٢٣٢.
  69,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَهُوَ فِی عِیشَةࣲ رَّاضِیَةࣲ ۝٢١ فِی جَنَّةٍ عَالِیَةࣲ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٤٣<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿عِيشَةٍ راضِيَةٍ﴾</span> يُريدُ: فيها الرضا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهُوَ فِي عِيشَةٍ راضِيَةٍ﴾</span> يقول: في عَيشٍ يرضاه في الجنة، فهو <span class="qpc-hafs">﴿فِي جَنَّةٍ عالِيَةٍ﴾</span> يعني: رفيعة في الغرف{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُوَ فِی عِیشَةࣲ رَّاضِیَةࣲ ۝٢١ فِی جَنَّةٍ عَالِیَةࣲ ۝٢٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٤٥<span class="dash">-</span></span> عن أبي الدّرداء، قال: قال رسول الله ﷺ: «<b>أنا أول مَن يُؤذَن له بالسجود يوم القيامة، وأنا أول مَن يُؤذَن له أن يرفع رأسه، فأنظر إلى بين يدي، فأعرف أُمّتي من بين الأمم، ومِن خلفي مثل ذلك، وعن يميني مثل ذلك، وعن شمالي مثل ذلك</b>». فقال رجل: يا رسول الله، كيف تعرف أُمّتك مِن بين الأمم فيما بين نوح إلى أُمّتك؟ قال: «<b>هم غُرٌّ مُحَجَّلون مِن أثر الوضوء، ليس أحد كذلك غيرهم، وأعرفهم أنهم يُؤتون كُتبهم بأيمانهم، وأعرفهم يسعى بين أيديهم ذُرّيتهم</b>»{3}. (١٤/٦٧٦)</p></p><p></div></p></div>",footnotes:1:علقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التفسير، عقب باب تفسير سورة الحاقة ٤/١٨٧١.|2:تفسير مقاتل بن سليمان ٤/٤٢٣.|3:أخرجه أحمد ٣٦/٦٤ (٢١٧٣٧)، من طريق ابن لهيعة، عن يزيد بن أبي حبيب، عن عبد الرحمن بن جبير، عن أبي الدرداء به.</p><p>قال المنذري في الترغيب والترهيب ١/٩١ (٢٨٦): «في إسناده ابن لهيعة، وهو حديث حسن في المتابعات». وقال العيني في عمدة القاري ٢/٢٤٧: «إسناد فيه ابن لهيعة». وقال الهيثمي في المجمع ١٠/٣٤٤ (١٨٣٦٣): «ورجال أحمد رجال الصحيح، غير ابن لهيعة، وهو ضعيف، وقد وُثّق».</p><p>وأخرجه أحمد ٣٦/٦٦ (٢١٧٣٩)، والحاكم ٢/٥٢٠ (٣٧٨٤)، من طريق الليث بن سعد، عن يزيد بن أبي حبيب، عن عبد الرحمن بن جبير بن نفير، عن أبي ذر، وأبي الدرداء به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».
  69,22,"69:21"
  69,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُطُوفُهَا دَانِیَةࣱ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٤٦<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق الثوري، عن أبي إسحاق- في قوله: <span class="qpc-hafs">﴿قُطُوفُها دانِيَةٌ﴾</span>، قال: قريبة{1}. (١٤/٦٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤٧<span class="dash">-</span></span> عن <span class="name-1">البراء</span> -من طريق إسرائيل، عن أبي إسحاق- في قوله: <span class="qpc-hafs">﴿قُطُوفُها دانِيَةٌ﴾</span>، قال: يتناول الرجل من فواكهها وهو قائم{2}. (١٤/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤٨<span class="dash">-</span></span> عن خُثَيْمٍ، قال: سمعت <span class="name-2">تُبَيْعًا</span> وسُئل عن: <span class="qpc-hafs">﴿قُطُوفُها دانِيَةٌ﴾</span>. فيقول: تَدْنو إليه وهو قائم، فيأخذ من فاكهتها ما أحبّ، ثم تَدْنو إليه وهو قاعد، فيأخذ من فاكهتها ما أحبّ، ثم تَرجع كما كانت{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٤٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> في قوله: <span class="qpc-hafs">﴿قُطُوفُها﴾</span>، قال: ثِمارها{4}. (١٤/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فَضالة- في قوله: <span class="qpc-hafs">﴿قطوفها دانية﴾</span>، قال: تَدْنو منه حتى يتناولها مِن حيثُ شاء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قُطُوفُها دانِيَةٌ﴾</span>، قال: دَنتْ، فلا يَردّ أيديهم عنها بُعدٌ ولا شوك{6}. (١٤/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُطُوفُها دانِيَةٌ﴾</span> يعني: ثمرتها قريبة بعضها مِن بعض، يأخذ منها إن شاء جالسًا، وإن شاء مُتّكئًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قُطُوفُها دانِيَةٌ﴾</span> [الحاقة:٢٣]، قال: الدانية: التي قد دَنتْ عليهم ثمارها{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُطُوفُهَا دَانِیَةࣱ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٥٤<span class="dash">-</span></span> عن سلمان الفارسي، قال: قال رسول الله ﷺ: «<b>لا يدخل الجنةَ أحدٌ إلا بجواز: بسم الله الرحمن الرحيم، هذا كتاب مِن الله لفلان بن فلان، أدخِلوه جنة عالية، قطوفها دانية</b>»{9}. (١٤/٦٧٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٣٢١-. وعزاه السيوطي إلى سعيد بن منصور.|2:أخرجه ابن جرير ٢٣/٢٣٣، وابن أبي شيبة ١٣/١٤٠، وعبد بن حميد -كما في فتح الباري ٦/٣٢١-، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٢٩ (٥٢)-. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٤٣-١٤٤ (٢٩١).|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه أبو حاتم الرازي في الزهد ص٤١.|6:أخرجه ابن جرير ٢٣/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.|7:تفسير مقاتل بن سليمان ٤/٤٢٣.|8:أخرجه ابن جرير ٢٣/٥٥٤.|9:أخرجه الطبراني في الكبير ٦/٢٧٢ (٦١٩١)، والبيهقي في البعث والنشور ص١٧٣ (٢٤٧).</p><p>وقال ابن عدي في الكامل ١/٥٦١: «قال لنا إسحاق بن موسى: كان هذا الحديثُ في آخر الزكاة في الأصل على هذا، وهذا حديث مُنكر بهذا الإسناد». وقال ابن الجوزي في العلل المتناهية ٢/٤٤٦-٤٤٧ (١٥٤٧): «هذا حديث لا يصحّ عن رسول الله ﷺ».
  69,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا بِمَاۤ أَسۡلَفۡتُمۡ فِی ٱلۡأَیَّامِ ٱلۡخَالِیَةِ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿كُلُوا واشْرَبُوا هَنِيئًا بِما أسْلَفْتُمْ فِي الأَيّامِ الخالِيَةِ﴾</span>، قال: أيامكم هذه أيامٌ خاليةٌ فانِيَةٌ، تؤدي إلى أيام باقية، فاعملوا في هذه الأيام، وقدِّموا خيرًا إن استطعتم، ولا قوة إلا بالله{1}. (١٤/٦٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٦<span class="dash">-</span></span> عن <span class="name-2">عبد العزيز بن رفيع</span> -من طريق الحسن صالح- في قوله: <span class="qpc-hafs">﴿بِما أسْلَفْتُمْ فِي الأَيّامِ الخالِيَةِ﴾</span>، قال: الصوم{2}. (١٤/٦٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كُلُوا واشْرَبُوا هَنِيئًا بِما أسْلَفْتُمْ﴾</span> بما عملتم <span class="qpc-hafs">﴿فِي الأَيّامِ الخالِيَةِ﴾</span> في الدنيا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٨<span class="dash">-</span></span> عن <span class="name-3">الحسن بن صالح</span>، <span class="qpc-hafs">﴿بما أسلفتم في الأيام الخالية﴾</span>، قال: سمعنا أنه الصيام{4}<span class=comment-ref>٦٧٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٨</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/٣٩٣) أنّ <span class="mustanad">العموم</span> في الآية أولى، فقال: «وعمومها في كلّ الأعمال أولى وأحسن».</div></p><p><div></p><p><p><span class="item-no">٧٨٥٥٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بِما أسْلَفْتُمْ فِي الأَيّامِ الخالِيَةِ﴾</span>، قال: أيام الدنيا، بما عَمِلوا فيها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٠<span class="dash">-</span></span> عن يوسف بن يعقوب الحنفي، قال: بلَغني: أنه إذا كان يوم القيامة يقول الله: يا أوليائي، طالما نظرتُ إليكم في الدنيا وقد قَلَصَتْ{6} شِفاهكم عن الأشربة، وغارَتْ{7} أعينكم، وجَفّتْ بطونكم، كونوا اليوم في نعيمكم، وكُلوا اليوم <span class="qpc-hafs">﴿واشْرَبُوا هَنِيئًا بِما أسْلَفْتُمْ فِي الأَيّامِ الخالِيَةِ﴾</span>{8}. (١٤/٦٧٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا بِمَاۤ أَسۡلَفۡتُمۡ فِی ٱلۡأَیَّامِ ٱلۡخَالِیَةِ ۝٢٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٦١<span class="dash">-</span></span> عن نافع، قال: خرج ابنُ عمر في بعض نواحي المدينة ومعه أصحابٌ له، ووضعوا سُفْرةً لهم، فمَرّ بهم راعي غنم، فسَلّم، فقال ابن عمر: هَلُمّ، يا راعي، هَلُمّ فأَصِب مِن هذه السُّفْرة. فقال له: إني صائم. فقال ابن عمر: أتصوم في مثل هذا اليوم الحارّ الشديد سَمومه، وأنت في هذه الجبال تَرعى هذه الغنم؟! فقال له: إني -واللهِ- أُبادِر أيامي الخالية. فقال له ابن عمر، وهو يريد يَختبر ورَعه: فهل لك أن تَبيعنا شاة مِن غنمك هذه، فنُعطيك ثمنها، ونُعطيك من لحمها، فتفطر عليه؟ فقال: إنها ليست لي بغنم، إنها غنم سيدي. فقال له ابن عمر: فما عسى سيّدك فاعلًا إذا فَقدها فقلتَ: أكلها الذّئب؟ فوَلّى الراعي عنه، وهو رافع إصبعه إلى السماء وهو يقول: فأين الله؟! قال: فجَعل ابنُ عمر يردّد قولَ الراعي وهو يقول: قال الراعي: فأين الله؟! فلمّا قدِم المدينةَ بعَث إلى مولاه، فاشترى منه الغنم والراعي، فأَعتق الراعي، ووَهب له الغنم{9}. (١٤/٦٧٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٣٤. وعزاه السيوطي إلى عبد بن حميد.|2:أخرجه ابن عدي في الكامل ٢/٧٢٥، والبيهقي في شعب الإيمان (٣٩٤٩)، وابن أبي الدنيا في كتاب الجوع -موسوعة الإمام ابن أبي الدنيا ٤/١٠٤ (١٤٧)-، وأبو عمرو الداني في المكتفى ص٢٢١ (٤٢). وعزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٤٢٣.|4:أخرجه أبو نعيم في حلية الأولياء ٧/٣٣١.|5:أخرجه ابن جرير ٢٣/٢٣٥.|6:قلصت: اجتمعت وانضمت. النهاية ٤/١٠٠.|7:غارت: دخلت في موضعها، وهي كناية عن التعب. اللسان (غور).|8:أخرجه ابن أبي الدنيا في كتاب الجوع -موسوعة الإمام ابن أبي الدنيا ٤/٨٥-٨٦ (٣٨)-. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه البيهقي في شعب الإيمان (٥٢٩١).
  69,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِشِمَالِهِۦ فَیَقُولُ یَـٰلَیۡتَنِی لَمۡ أُوتَ كِتَـٰبِیَهۡ ۝٢٥ وَلَمۡ أَدۡرِ مَا حِسَابِیَهۡ ۝٢٦﴾</span> - نزول الآية وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٦٢<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق أبي العالية الرياحي- قال: ... وإذا كان [الرجلُ] في الشرِّ رأسًا يدعو إليه، ويأمر به، ويكثر عليه تبعه؛ نودي باسمه واسم أبيه، فيتقدّم إلى حسابه، ويُخرج له كتابٌ أسود بخط أسود، في باطنه الحسنات، وفي ظهره السيئات، فيبدأ بالحسنات، فيقرأها، فيفرح، ويظن أنه سينجو، فإذا بلغ آخر الكتاب وجد فيه: هذه حسناتك وقد رُدَّت عليك. فيسوَدُّ وجهه، ويعلوه الحزن، ويقنط من الخير. ثم يقلب كتابه، فيقرأ سيئاته، فلا يزداد إلا حزنًا، ولا يزداد وجهه إلا سوادًا، فإذا بلغ آخر الكتاب وجد فيه: هذه سيئاتك وقد ضُعِّفت عليك. فيعظم للنار حتى إن فخذه لَيكون مسيرة أيام، وجلده مقدار أربعين ذراعًا، وتزرقُّ عيناه، ويسوَدُّ لونه، ويُكسى سرابيل القطران، ثم تُخلع كتفه اليسرى فتُجعل وراء ظهره، ثم يُعطى كتابه بشماله، ويُقال له: انطلق إلى أصحابك، فأخبرهم أنّ لِكلِّ إنسانٍ منهم مثل هذا. فينطلق وهو يقول: <span class="qpc-hafs">﴿يا ليتني لم أوت كتابيه * ولم أدر ما حسابيه * يا ليتها كانت القاضية * ما أغنى عني ماليه * هلك عني سلطانيه﴾</span>. قال الله: <span class="qpc-hafs">﴿خذوه فغلوه * ثم الجحيم صلوه * ثم في سلسلة ذرعها سبعون ذراعا فاسلكوه﴾</span>. فيُسلك فيها سبعون ذراعًا، <span class="qpc-hafs">﴿فاسلكوه﴾</span> كما قال الله، فيُسلك فيها سلكًا تدخل مِن فيه حتى تخرج مِن دبره، فيأتي أصحابه، فيقول: هل تعرفوني؟ فيقولون: ما ندري! ولكن قد نرى ما بك من الخزي، فمن أنت؟ فيقول: أنا فلان ابن فلان، إنّ لكل إنسان منكم مثلَ هذا. ثم ينصب للناس، وتبدو فضائحه حتى يُعيَّر، فيتمنى أن لو قد انطُلِق به إلى النار استحياءً مِمّا يبدو منه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق القاسم بن محمد- قال: أول من يُعطى كتابه بيمينه أبو سَلمة بن عبد الأَسد. قال: وهو الذي يقول: <span class="qpc-hafs">﴿هاؤُمُ اقْرَءُوا كِتابِيَهْ﴾</span>. .... وأما الذي يُعطى كتابه بشماله فأول مَن يُعطاه أخوه سفيان بن عبد الأَسد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَمّا مَن أُوتِيَ كِتابَهُ بِشِمالِهِ﴾</span> يقول: يُعطيه مَلكه الذي كان يَكتب عمَله في الدنيا. نزلت هذه الآيةُ في الأسود بن عبد [الأسد] المَخزوميّ، قَتَلَه حمزةُ بن عبد المُطَّلب على الحوض ببدر، <span class="qpc-hafs">﴿فَيَقُولُ يا لَيْتَنِي﴾</span> فيتمنّى في الآخرة <span class="qpc-hafs">﴿يا لَيْتَنِي لَمْ أُوتَ كِتابِيَهْ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٥<span class="dash">-</span></span> قال ابن السّائِب: <span class="qpc-hafs">﴿وأَمّا مَن أُوتِيَ كِتابَهُ بِشِمالِهِ﴾</span> تُلوى يده اليسرى من صدره خلف ظهره، ثم يُعطى كتابه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ١/١٢١-١٢٢.|2:أخرجه الضياء المقدسي في المختارة ١٣/٤٦ (٤٩).|3:تفسير مقاتل بن سليمان ٤/٤٢٣.|4:تفسير الثعلبي ١٠/٣١، وتفسير البغوي ٨/٢١٢. وجاء في طبعة دار التفسير لتفسير الثعلبي ٢٧/٣١٠ أنه في إحدى النسخ التصريح بأن ابن السائب هنا هو عطاء.
  69,26,"69:25"
  69,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰلَیۡتَهَا كَانَتِ ٱلۡقَاضِیَةَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٦٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿يا لَيْتَها كانَتِ القاضِيَةَ﴾</span>، قال: يا ليتها كانت موتة لا حياة بعدها{1}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يا لَيْتَها كانَتِ القاضِيَةَ﴾</span>، قال: تَمنَّوا الموت، ولم يكن شيءٌ في الدنيا أكره عندهم من الموت{2}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، في قوله: <span class="qpc-hafs">﴿يا لَيْتَها كانَتِ القاضِيَةَ﴾</span>، قال: الموت{3}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا لَيْتَها كانَتِ القاضِيَةَ﴾</span> فيتمنّى الموت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا لَيْتَها كانَتِ القاضِيَةَ﴾</span> الموت{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه هناد (٢٢٤).|2:أخرجه ابن جرير ٢٣/٢٣٥. وعزاه السيوطي إلى عبد بن حميد.|3:عزاه السيوطي إلى سعيد بن منصور.|4:تفسير مقاتل بن سليمان ٤/٤٢٤.|5:أخرجه ابن جرير ٢٣/٢٣٥.
  69,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَاۤ أَغۡنَىٰ عَنِّی مَالِیَهۡۜ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما أغْنى عَنِّي مالِيَهْ﴾</span> من النار{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٤.
  69,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلَكَ عَنِّی سُلۡطَـٰنِیَهۡ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، قال: ضلّتْ عنِّي كلُّ بيِّنةٍ، فلم تُغنِ عنِّي شيئًا{1}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، قال: حُجّتي{2}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، يقول: بيِّنتي ضلّتْ عني{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النّضر بن عربي- <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، قال: يعني: حُجّته{2}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، قال: أما -واللهِ- ما كلُّ مَن دخل النارَ كان أميرَ قريةٍ، ولكن اللهَ خلَقهم، وسلّطهم على أبدانهم، وأمرهم بطاعته، ونهاهم عن معصيته{2}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن</span> <span class="name-2">كعب القُرَظيّ</span>، في قوله: <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، قال: حُجّتي{6}. (١٤/٦٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، يقول: ضلّتْ عنى يومئذ حُجّتي حين شهدتْ عليه الجوارحُ بالشّرك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٧٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span>، قال: سلطان الدنيا{3}<span class=comment-ref>٦٧٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٦٩</span> اختُلف في المراد بـ«السلطان» على قولين: <b>الأول</b>: أنه الحُجّة. <b>الثاني</b>: أنه الملْك.</p><p>وساق <u>ابنُ عطية</u> (٨/٣٩٣) القولين، ثم <span class="comment-type-3">رجّح</span>الثاني -<span class="mustanad">مستندًا للسنّة</span>- بقوله: «والظاهر عندي أنّ سلطان كلّ أحد حاله في الدنيا من عَدَد وعُدد، ومنه قول النبي ﷺ: «<b>لا يُؤمّنّ الرجل في سلطانه، ولا يُجلس على تَكرِمته إلا بإذنه</b>»».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٣٦. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٢- بنحوه.|2:أخرجه ابن جرير ٢٣/٢٣٦. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ٢٣/٢٣٧.|4:أخرجه ابن جرير ٢٣/٢٣٦. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٣/٢٣٦. وعزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى سعيد بن منصور.|7:تفسير مقاتل بن سليمان ٤/٤٢٤.|8:أخرجه ابن جرير ٢٣/٢٣٧.
  69,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خُذُوهُ فَغُلُّوهُ ۝٣٠ ثُمَّ ٱلۡجَحِیمَ صَلُّوهُ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله لخَزنة جهنم: <span class="qpc-hafs">﴿خُذُوهُ فَغُلُّوهُ﴾</span> يعني: غُلّوا يديه إلى عُنُقه، <span class="qpc-hafs">﴿ثُمَّ الجَحِيمَ صَلُّوهُ﴾</span> يعني: الباب السادس مِن جهنم، فصَلّوه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٨١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿خُذُوهُ فَغُلُّوهُ﴾</span>، قال: أُخبرتُ أنه أبو جهل{2}. (١٤/٦٨٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٤.|2:عزاه السيوطي إلى ابن المنذر.
  69,31,"69:30"
  69,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ فِی سِلۡسِلَةࣲ ذَرۡعُهَا سَبۡعُونَ ذِرَاعࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٨٢<span class="dash">-</span></span> قال النبي ﷺ: «<b>كلّ ذراعٍ منها بذراع الرجل الطويل مِن الخَلْق الأول، ولو أنّ حَلقة منها وُضِعَتْ على ذروة جبلٍ لَذابَ كما يذوب الرّصاص، فكيف -يا ابن آدم- وهي عليك وحدك؟!</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٨٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن حَنظلة- قال: إنّ حَلقةً مِن السّلسلة التي ذَكر الله مثل جميع حديد الدنيا{2}. (١٤/٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٨٤<span class="dash">-</span></span> عن <span class="name-2">نَوف الشامي</span> -من طريق نُسَيْر بن ذُعْلُوق- في قوله: <span class="qpc-hafs">﴿ثُمَّ فِي سِلْسِلَةٍ ذَرْعُها سَبْعُونَ ذِراعًا﴾</span>، قال: الذراع سبعون باعًا، والباع ما بينك وبين مكة. وهو يومئذ بالكوفة{3}<span class=comment-ref>٦٧٧٠</span>. (١٤/٦٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧٠</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٨/٣٩٤) على هذا القول بقوله: «وهذا يحتاج إلى سند».</div></p><p><div></p><p><p><span class="item-no">٧٨٥٨٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿سَبْعُونَ ذِراعًا﴾</span> الله أعلم أي ذراع هو{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٨٦<span class="dash">-</span></span> عن حُسين بن رُستم الأيليّ، قال: سمعتُ <span class="name-2">محمد بن المُنكَدِر</span> يقول: لو جُمع حديد الدنيا كلّه ما خلا منها وما بقي ما عَدل حَلقةً مِن حِلق السّلسلة التي ذكرها الله تعالى في كتابه، فقال: <span class="qpc-hafs">﴿في سلسلة ذرعها سبعون ذراعًا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ فِي سِلْسِلَةٍ ذَرْعُها سَبْعُونَ ذِراعًا﴾</span> بالذراع الأول{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٨٨<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: كلّ ذراع من سبعين ذراعًا سبعون ذراعًا{7}<span class=comment-ref>٦٧٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٧١</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/٣٩٤) قولًا بأن الذراع هنا هي الذراع المعروفة، وأننا إنما <span class="mustanad">خوطبنا بما نعرفه ونحصله</span>، ونسبه لحذّاق من المفسرين.</div></p><p><h3><span class="qpc-hafs">﴿فَٱسۡلُكُوهُ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿فاسْلُكُوهُ﴾</span>، قال: تُسلَك في دُبُرِه حتى تخرج من مَنخَريْه، حتى لا يقوم على رجليه{8}. (١٤/٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿فاسْلُكُوهُ﴾</span>: السّلسلة تدخل في اسْته، ثم تَخرج مِن فِيه، ثم يُنظمون فيها كما يُنظَم الجراد في العود ثم يُشوى{9}. (١٤/٦٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- قال: بلَغني: أنّ السّلسلة تَدخل من مَقْعدَته، حتى تَخرج من فِيه، ثم يُوثَق بها بعد، أو مِن فِيه حتى تَخرج من مَقْعدَته{10}. (١٤/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿فاسْلُكُوهُ﴾</span>، قال: السَّلْك: أن تَدخل السّلسلة في فِيه، وتَخرج مِن دُبره{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاسْلُكُوهُ﴾</span> فأدخِلوه فيه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عبد الرزاق- قال: بَلَغَني: أنها تَدخل في دُبره حتى تَخرج من فِيه، أو من رأسه{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱسۡلُكُوهُ ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٩٥<span class="dash">-</span></span> عن عبد الله بن عمرو بن العاص، قال: قال رسول الله ﷺ: «<b>لو أنّ رَصاصة مثل هذه</b> -وأشار إلى جُمجمة- <b>أُرسِلتْ مِن السماء إلى الأرض، وهي مسيرة خمسمائة سنة، لَبَلغت الأرضَ قبل الليل، ولو أنها أُرسِلتْ مِن رأس السّلسلة لَسارت أربعين خريفًا الليل والنهار قبل أنْ تَبلغ قَعرها أو أصلها</b>»{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩٦<span class="dash">-</span></span> عن <span class="name-1">أبي الدّرداء</span>، قال: إنّ لله سلسلةً لم تَزل تَغلي منها مَراجِلُ{15} النارِ منذ خَلَق الله جهنم إلى يوم تُلقى في أعناق الناس، وقد نجّانا الله مِن نصفها بإيماننا بالله العظيم، فحُضّي على طعام المسكين، يا أُمّ الدّرداء{16}. (١٤/٦٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٥٩٧<span class="dash">-</span></span> عن <span class="name-3">سُويد بن نجيح</span> -من طريق المسيّب- قال: بلَغني: أنّ جميع أهل النار في تلك السّلسلة، ولو أنّ حَلقة منها وُضعت على جبل لَذابَ مِن حرِّها{17}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٤، من مرسل مقاتل بن سليمان.|2:أخرجه ابن المبارك (٢٨٩ - زوائد نعيم)، وعبد الرزاق ٢/٣١٢، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٩ (١٣٧)- من طريق ابن أبي مُلَيْكَة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه ابن المبارك (٢٨٨ - زوائد نعيم)، وعبد الرزاق ٢/٣١٥، وهناد (٢٦٦)، وابن جرير ٢٣/٢٣٧-٢٣٨، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤١١-٤١٢ (٥٩)-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:تفسير البغوي ٨/٢١٣.|5:أخرجه أبو نعيم في حلية الأولياء ٣/١٥٣.|6:تفسير مقاتل بن سليمان ٤/٤٢٤.|7:تفسير الثعلبي ١٠/٣١، وتفسير البغوي ٨/٢١٣.|8:أخرجه ابن أبي حاتم -كما في التخويف من النار ص١٣٠-، وابن جرير ٢٣/٢٣٨، والبيهقي في البعث والنشور (٥٩٤).|9:أخرجه ابن أبي حاتم -كما في التخويف من النار ص١٣٠-. وعزاه السيوطي إلى ابن المنذر.|10:عزاه السيوطي إلى ابن المنذر.|11:أخرجه ابن جرير ٢٣/٢٣٩.|12:تفسير مقاتل بن سليمان ٤/٤٢٤.|13:أخرجه عبد الرزاق ٢/٣١٥.|14:أخرجه أحمد ١١/٤٤٣-٤٤٥ (٦٨٥٦، ٦٨٥٧)، والترمذي ٤/٥٤٣-٥٤٤ (٢٧٧٠)، والحاكم ٢/٤٧٦ (٣٦٤٠)، وابن جرير ٢٣/٢٣٨. وأورده الثعلبي ١٠/٣١.</p><p>قال الترمذي: «هذا حديث إسناده حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن رجب في التخويف من النار (ص١٢٦): «غريب، وفي رفعه نظر».|15:مَراجِل: جمع مِرْجَل، وهو الإناء الذي يغلي فيه الماء. النهاية ٤/٣١٥.|16:عزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر.|17:أخرجه الثعلبي ١٠/٣١.
  69,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ كَانَ لَا یُؤۡمِنُ بِٱللَّهِ ٱلۡعَظِیمِ ۝٣٣ وَلَا یَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِینِ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٥٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله تعالى: <span class="qpc-hafs">﴿إنَّهُ كانَ لا يُؤْمِنُ بِاللَّهِ﴾</span> يعني: لا يُصَدِّق بالله <span class="qpc-hafs">﴿العَظِيمِ﴾</span> بأنه واحد لا شريك له، <span class="qpc-hafs">﴿ولا يَحُضُّ﴾</span> نفسه <span class="qpc-hafs">﴿عَلى طَعامِ المِسْكِينِ﴾</span> يقول: كان لا يُطعم المسكين في الدنيا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢٤.
  69,34,"69:33"