quran[13]{c,v,t}:
  36,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ أَنَّا خَلَقۡنَا لَهُم مِّمَّا عَمِلَتۡ أَیۡدِینَاۤ أَنۡعَـٰمࣰا فَهُمۡ لَهَا مَـٰلِكُونَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٦١<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا خَلَقْنا لَهُمْ مِمّا عَمِلَتْ أيْدِينا أنْعامًا﴾</span> أي: بقوتنا. قال <span class="name-3">يحيى بن سلّام</span>: كقوله: <span class="qpc-hafs">﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</span> [الذاريات:٤٧]{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فهم لها مالكون﴾</span>، قال: ضابِطون{2}. (١٢/٣٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فَهُمْ لَها مالِكُونَ﴾</span>، قال: مطيعون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿مِمّا عَمِلَتْ أيْدِينا﴾</span>، قال: مِن صَنْعتنا{4}. (١٢/٣٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مِمّا عَمِلَتْ أيْدِينا﴾</span> مِن فعلنا <span class="qpc-hafs">﴿أنْعامًا﴾</span> الإبل والبقر والغنم، <span class="qpc-hafs">﴿فَهُمْ لَها مالِكُونَ﴾</span> ضابطين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا خَلَقْنا لَهُمْ مِمّا عَمِلَتْ أيْدِينا أنْعامًا فَهُمْ لَها مالِكُونَ﴾</span>، فقيل له: أهي الإبل؟ فقال: نعم. قال: والبقر مِن الأنعام، وليست بداخلة في هذه الآية. قال: والإبل والبقر والغنم مِن الأنعام. وقرأ: <span class="qpc-hafs">﴿ثَمانِيَةَ أزْواجٍ﴾</span> [الأنعام:١٤٣]، قال: والبقر والإبل هي النعم، وليست تدخل الشاء في النعم{6}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٨١٩.أخرجه ابن جرير ١٩/٤٨٢. وعلقه يحيى بن سلام ٢/٨١٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٦.عزاه السيوطي إلى ابن أبي حاتم. وعند يحيى بن سلام في تفسيره ٢/٨١٩ معلقًا بلفظ: مِن فِعْله.تفسير مقاتل بن سليمان ٣/٥٨٤.أخرجه ابن جرير ١٩/٤٨٢.
  36,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَذَلَّلۡنَـٰهَا لَهُمۡ فَمِنۡهَا رَكُوبُهُمۡ وَمِنۡهَا یَأۡكُلُونَ ۝٧٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٦٧<span class="dash">-</span></span> عن عروة بن الزبير، قال: في مصحف <span class="name-1">عائشة</span>: (فَمِنها رَكُوبَتُهُمْ){1}. (١٢/٣٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٨<span class="dash">-</span></span> عن هارون، قال: في حرف <span class="name-1">أبي بن كعب</span>: (فَمِنها رَكُوبَتُهُمْ){2}. (١٢/٣٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٦٩<span class="dash">-</span></span> عن هارون، قال: قراءة <span class="name-2">الحسن</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧٠<span class="dash">-</span></span> و<span class="name-2">الأعرج</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧١<span class="dash">-</span></span> و<span class="name-2">أبي عمرو</span>، والعامة: <span class="qpc-hafs">﴿فَمِنها رَكُوبُهُمْ﴾</span>، يعني: رُكوبهم؛ حمولتهم{3}. (١٢/٣٧٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَذَلَّلۡنَـٰهَا لَهُمۡ فَمِنۡهَا رَكُوبُهُمۡ وَمِنۡهَا یَأۡكُلُونَ ۝٧٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وذَلَّلْناها لَهُمْ فَمِنها رَكُوبُهُمْ﴾</span> يركبونها ويسافرون عليها، <span class="qpc-hafs">﴿ومِنها يَأْكُلُونَ﴾</span> لحومها{4}. (١٢/٣٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وذَلَّلْناها﴾</span> كقوله ﷿: <span class="qpc-hafs">﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</span> [الإنسان:١٤]، <span class="qpc-hafs">﴿وذَلَّلْناها﴾</span> فيحملون عليها ويسوقونها حيث شاءوا ولا تمتنع، <span class="qpc-hafs">﴿فَمِنها رَكُوبُهُمْ﴾</span> حمولتهم الإبل والبقر، <span class="qpc-hafs">﴿ومِنها يَأْكُلُونَ﴾</span> يعني: الغنم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وذَلَّلْناها لَهُمْ﴾</span> يعني: الإبل، والبقر، والغنم، والدواب أيضًا، ذللها لكم: الخيل، والبغال، والحمير؛ <span class="qpc-hafs">﴿فَمِنها رَكُوبُهُمْ﴾</span> الإبل والبقر مِن الأنعام، والدواب: الخيل والبغال والحمير، <span class="qpc-hafs">﴿ومِنها يَأْكُلُونَ﴾</span> من الإبل، والبقر، والغنم، وقد يُرخَّص في الخيل، ... عن جابر بن عبد الله: أنهم كانوا يأكلون لحوم الخيل على عهد رسول الله ﷺ{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائل القرآن (١٨٢). وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن أُبي. انظر: المحتسب ٢/٢١٥، ومختصر ابن خالويه ص١٢٦.أخرجه أبو عبيد (١٨٢). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة العشرة.أخرجه ابن جرير ١٩/٤٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٤-٥٨٥.تفسير يحيى بن سلام ٢/٨١٩.
  36,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَهُمۡ فِیهَا مَنَـٰفِعُ وَمَشَارِبُۚ أَفَلَا یَشۡكُرُونَ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَهُمْ فِيها مَنافِعُ﴾</span> قال: يلبسون أصوافها، <span class="qpc-hafs">﴿ومَشارِبُ﴾</span> يشربون ألبانها{1}. (١٢/٣٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَهُمْ فِيها مَنافِعُ﴾</span> في الأنعام، ومنافع في الركوب عليها، والحمل عليها، وينتفعون بأصوافها، وأوبارها، وأشعارها، ثم قال -جلَّ وعز-: <span class="qpc-hafs">﴿ومَشارِبُ﴾</span> ألبانها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ولَهُمْ فِيها﴾</span> في الأنعام <span class="qpc-hafs">﴿مَنافِعُ﴾</span> في أصوافها، وأوبارها، وأشعارها، ولحومها، <span class="qpc-hafs">﴿ومَشارِبُ﴾</span> يشربون من ألبانها، <span class="qpc-hafs">﴿أفَلا يَشْكُرُون﴾</span> أي: فليشكروا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨١٩-٨٢٠.
  36,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ ءَالِهَةࣰ لَّعَلَّهُمۡ یُنصَرُونَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً﴾</span>، قال: هي الأصنام{1}. (١٢/٣٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿لَعَلَّهُمْ يُنْصَرُونَ﴾</span>، قال: يُمْنَعون{2}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جل وعز-: <span class="qpc-hafs">﴿واتَّخَذُوا﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿مِن دُونِ اللَّهِ آلِهَةً﴾</span> يعني: اللات، والعُزّى، ومناة؛ <span class="qpc-hafs">﴿لَعَلَّهُمْ يُنْصَرُونَ﴾</span> لكي تمنعهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لَعَلَّهُمْ يُنْصَرُونَ﴾</span> يُمنعون، كقوله: <span class="qpc-hafs">﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِيَكُونُوا لَهُمْ عِزًّا﴾</span> [مريم:٨١]{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وأخرج ابن أبي حاتم عن السُدِّيّ في قوله <span class="qpc-hafs">﴿لَعَلَّهُمْ يُنْصَرُونَ﴾</span> أي: يمنعون.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.
  36,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَسۡتَطِیعُونَ نَصۡرَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٨٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</span> لا تقدر الأصنامُ على نصْرهم ومنْعهم من العذاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</span>، قال: نصر الآلهة، ولا تستطيع الآلهة نصْرهم{2}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</span>، قال: لا تستطيع الآلهةُ نصرَهم{3}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</span> لا تقدر الآلهةُ أن تمنعهم مِن العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</span> لا تستطيع آلهتُهم التي يعبدون نصْرهم{5}<span class=comment-ref>٥٤٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٦٦) في عود الضمير من قوله: <span class="qpc-hafs">﴿يستطيعون﴾</span> احتمالين، وصححهما، فقال: «<b>ويحتمل</b> أن يكون الضمير في <span class="qpc-hafs">﴿يَسْتَطِيعُونَ﴾</span> للكفار، وفي <span class="qpc-hafs">﴿نصْرَهم﴾</span> للأصنام، <b>ويحتمل</b> الأمر عكس ذلك؛ <span class="mustanad">لأن الوجهين صحيحان في المعنى</span>».</div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ لَهُمۡ جُندࣱ مُّحۡضَرُونَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span>، قال: عند الحساب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span> قال: هم لهم جند في الدنيا، وهم <span class="qpc-hafs">﴿مُحْضَرُونَ﴾</span> في النار{7}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله:<span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span>، قال: محضرون لآلهتهم التي يعبدون، يدفعون عنهم ويمنعونهم{8}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span>، قال: المشركون يغضبون للآلهة في الدنيا، وهي لا تسوق إليهم خيرًا، ولا تدفع عنهم سوءًا، إنما هي أصنام{9}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>-من طريق معمر-: <span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span> يعكفون حولَهم في الدنيا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span>، يقول: كفار مكة للآلهة حِزْبٌ؛ يغضبون لها، ويحضرونها في الدنيا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span> معهم في النار{5}<span class=comment-ref>٥٤٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٦</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿وهم لهم جند مجضرون﴾</span> على قولين: <b>الأول</b>: أن المعنى: وهم لهم جند محضرون يوم الحساب. <b>الثاني</b>: أن المعنى: وهم لهم جند محضرون في الدنيا، يغضبون لهم ويدافعون عنهم.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٩/٤٨٥) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الثاني، وهو قول الحسن، وقتادة، والكلبي، ومقاتل، وعلَّل ذلك بقوله: «لأن المشركين عند الحساب تتبرأ منهم الأصنام، وما كانوا يعبدونه، فكيف يكونون لها جندًا حينئذ، ولكنهم في الدنيا لهم جند يغضبون لهم، ويقاتلون دونهم».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ كثير</u> (١١/٣٨٣) بقوله: «وهذا القول حسن».</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٧/٢٦٦) المعنى على القول الأول، بأنه: «على معنى التوبيخ والنقمة، وسماهم جندًا في هذا التأويل إذ هم عُدة للنقمة منهم وتوبيخهم». و<span class="comment-type-1">وجّه</span> المعنى على القول الثاني بأنه: «على معنى: وهؤلاء الكفار متجندون متحزبون لهذه الأصنام في الدنيا، لكنهم لا يستطيعون التناصر مع ذلك».</div></p></div>",footnotes:1:تفسير البغوي ٦/٢٨.أخرجه ابن جرير ١٩/٤٨٥ بلفظ:«الألهة». وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٨٤. وعلَّقه البخاري في صحيحه (ت: مصطفى البغا)، كتاب التفسير، باب تفسير سورة يس ٤/١٨٠٥، وذكر ابن حجر في الفتح ٨/٥٤١ أن الفريابي وصله في تفسيره.أخرجه عبد الرزاق ٢/١٤٦. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٨٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٦.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.
  36,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَا یَحۡزُنكَ قَوۡلُهُمۡۘ إِنَّا نَعۡلَمُ مَا یُسِرُّونَ وَمَا یُعۡلِنُونَ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿فَلا يَحْزُنْكَ قَوْلُهُمْ﴾</span> إنّك ساحر، وإنك شاعر، وإنك كاهن، وإنك مجنون، وإنك كاذب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلا يَحْزُنْكَ قَوْلُهُمْ﴾</span> كفار مكة، <span class="qpc-hafs">﴿إنّا نَعْلَمُ ما يُسِرُّونَ﴾</span> من التكذيب، <span class="qpc-hafs">﴿وما يُعْلِنُونَ﴾</span> يُظهِرون مِن القول بألسنتهم حين قالوا للنبي ﷺ: كيف يبعث الله هذا العَظْمَ؟! علانية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنّا نَعْلَمُ ما يُسِرُّونَ﴾</span> مِن عداوتهم لك، <span class="qpc-hafs">﴿وما يُعْلِنُونَ﴾</span> كفْرهم بما جئتهم به، فسنعصمك منهم، ونُذِلُّهم لك، ففعل الله ذلك به{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ٢/٨٢٠.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.
  36,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَ ٱلۡإِنسَـٰنُ أَنَّا خَلَقۡنَـٰهُ مِن نُّطۡفَةࣲ فَإِذَا هُوَ خَصِیمࣱ مُّبِینࣱ ۝٧٧﴾</span> الآيات - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٦٤٩٩٧<span class="dash">-</span></span> عن <span class="name-1">المقدام</span>، أنّ رسول الله ﷺ قال: «<b>أخذ أمية بن خلف عظمًا، ففتّه، ثم قال لصاحب له: أترى الله يحيي هذه وهي رميم. وأُنزلت هذه الآية: <span class="qpc-hafs">﴿مَن يُحْيِ العِظامَ وهِيَ رَمِيمٌ﴾</span>، فلزم الحق بمنكبه</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: جاء العاصي بن وائل إلى رسول الله ﷺ بعظم حائل{2}، ففتَّه بيده، وقال: يا محمد، أيحيي الله هذا بعد ما أرى؟ قال: «<b>نعم، يبعث الله هذا، ثم يميتك، ثم يحييك، ثم يدخلك نار جهنم</b>». فنزلت الآيات من آخر يس: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</span> إلى آخر السورة{3}. (١٢/٣٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٩٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قال: جاء عبد الله بن أُبَيّ وفي يده عظم حائل إلى النبي ﷺ، فكسره بيده، ثم قال: يا محمد، كيف يبعثه الله وهو رميم؟! فقال رسول الله ﷺ: «<b>يبعث الله هذا، ويميتك، ثم يُدخلك جهنم</b>». قال الله: <span class="qpc-hafs">﴿قُلْ يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</span>{4}<span class=comment-ref>٥٤٥٧</span>. (١٢/٣٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٧</span> <span class="comment-type-2">انتقد</span> <u>ابن عطية</u> (٧/٢٦٧) <span class="mustanad">مستندًا إلى أحوال النزول والدلالة العقلية</span> ما أفاده هذا الأثر عن ابن عباس من كون الآية نازلة في عبد الله بن أبي، فقال: «وهو وهمٌ ممن نسبه إلى ابن عباس؛ لأن السورة مكية، والآية مكية بإجماع، ولأن عبد الله بن أبي لم يجاهر قط هذه المجاهرة، واسْمُ أُبي هو الذي خلط على الرواة؛ لأن الصحيح هو ما رواه ابن وهب عن مالك، وقاله ابن إسحاق وغيره: من أن أبي بن خلف أخا أمية بن خلف هو الذي جاء بالعظم الرميم بمكة ففته في وجه النبي ﷺ، وقال: من يحيي هذا، يا محمد؟».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١١/٣٨٤).</div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: جاء أُبَيُّ بن خلف الجمحي إلى رسول الله ﷺ بعظم نَخِر، فقال: أتَعِدُنا -يا محمد- إذا بَلِيَت عظامُنا فكانت رميمًا أنّ الله باعِثُنا خلقًا جديدًا؟! ثم جعل يفُتّ العظم، ويَذُرُّه في الريح، فيقول: يا محمد، مَن يُحْيِي هذا؟ فقال رسول الله ﷺ: «<b>نعم، يميتك الله، ثم يحييك، ويجعلك في جهنم</b>». ونزل على رسول الله ﷺ: <span class="qpc-hafs">﴿وضَرَبَ لَنا مَثَلًا ونَسِيَ خَلْقَهُ﴾</span> الآيتين{5}. (١٢/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: نزلت هذه الآيةُ في أبي جهل بن هشام، جاء بعظم حائِل إلى النبي ﷺ، فذرّاه، فقال: مَن يحيي العظام وهي رميم؟! فقال الله: يا محمد، <span class="qpc-hafs">﴿قل يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</span>{6}. (١٢/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- قال: جاء العاص بن وائل السهمي إلى رسول الله ﷺ بعظم حائل، ففتّه بين يديه، فقال: يا محمد، أيبعث الله هذا حيًّا بعد ما أرم؟! قال: «<b>نعم، يبعث الله هذا، ثم يميتك، ثم يحييك، ثم يدخلك نار جهنم</b>». قال: فنزلت الآيات: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</span> إلى آخر الآية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٣<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span>، قال: لما أنزل الله على رسوله: إن الناس يحاسبون بأعمالهم، ويُبعثون يوم القيامة. أنكروا ذلك إنكارًا شديدًا، فعمد أُبَيّ بن خلف إلى عظم حائل قد نخِر وبلي، ففتّه، ثم ذراه في الريح، ثم قال: يا محمد، إذا بَلِيَتْ عظامُنا إنا لمبعوثون خلقًا جديدًا؟! فوجد رسول الله ﷺ مِن استقباله إيّاه بالتكذيب والأذى في وجهه وجْدًا شديدًا، فأنزل الله على رسوله: <span class="qpc-hafs">﴿قُلْ يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ﴾</span> الآية{8}. (١٢/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وضَرَبَ لَنا مَثَلًا﴾</span>، قال: أُبَيّ بن خلف{9}. (١٢/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: أتى أُبَيّ بن خلف إلى النبي ﷺ بعظمٍ بالٍ، فقال: أيحيي الله هذا وهو رميم؟! قال يحيى: فبلغني: أنّ النبي ﷺ قال له: «<b>يحييك الله بعد موتك، ثم يدخلك النار</b>». فأنزل الله: <span class="qpc-hafs">﴿قُلْ يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</span>{10}. (١٢/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق سفيان بن عيينة-: أتى أُبَيُّ بن خلف الجمحي النبيَّ ﷺ بعظم بالٍ قد أتى عليه حين، ففتَّه بيده، ثم قال: يا محمدُ، أيعيدنا إذا كنا مثل هذا؟! فأنزل الله -تبارك وتعالى-: <span class="qpc-hafs">﴿أولم ير الإنسان أنا خلقناه من نطفة فإذا هو خصيم مبين وضرب لنا مثلا ونسي خلقه قال من يحي العظام وهي رميم قل يحييها الذي أنشأها أول مرة وهو بكل خلق عليم﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: جاء أُبَيّ بن خلف إلى النبي ﷺ وفي يده عظم حائل، فقال: يا محمد، أنّى يحيي الله هذا؟! فأنزل الله: <span class="qpc-hafs">﴿وضرب لنا مثلا ونسي خلقه﴾</span>. فقال له رسول الله ﷺ: «<b>خلْقها قبل أن تكون أعجب من إحيائها، وقد كانت</b>»{8}. (١٢/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك</span>، قال: جاء أُبَيّ بن خلف بعظم نخِرة، فجعل يفتّه بين يدي النبي ﷺ، قال: مَن يحيي العظام وهي رميم؟! فأنزل الله: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</span> إلى قوله: <span class="qpc-hafs">﴿وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</span>{13}. (١٢/٣٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٠٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ﴾</span> هو أمية بن خلف{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وضَرَبَ لَنا مَثَلًا﴾</span>، قال: نزلت في أُبَيّ بن خلف، جاء بعظم نخِر، فجعل يذُرُّه في الريح، فقال: أنّى يُحيي اللهُ هذا؟ قال النبي ﷺ: «<b>نعم، يُحْيِي اللهُ هذا، ويُدخلك النار</b>»{15}. (١٢/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ﴾</span>، قال: نزلت في أُبَيّ بن خلف، أتى النبيَّ ﷺ ومعه عظْم قد بَلي، فجعل يفتُّه بين أصابعه، ويقول: يا محمد، أنت الذي تُحَدِّث أنّ هذا سيَحيا بعد ما قد بَلى؟! فقال رسول الله ﷺ: «<b>نعم، ليُميتن الآخر، ثم ليحيينه، ثم ليدخلنه النار</b>»{8}. (١٢/٣٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في أُبَيّ بن خلف الجمحي في أمر العظم، وكان قد أضحكهم بمقالته، فهذا الذي أعلنوا، وذلك أنّ أبا جهل، والوليد بن المغيرة، وعتبة وشيبة ابني ربيعة، وعقبة، والعاص بن وائل، كانوا جلوسًا، فقال لهم أُبَيّ بن خلف، قال لهم في النفر من قريش: إنّ محمدًا يزعم أن الله يحيي الموتى، وأنا آتيه بعظم، فأسأله: كيف يبعث الله هذا؟ فانطلق أُبَيّ بن خلف، فأخذ عظْمًا باليًا حائلًا نخِرًا، فقال: يا محمد، تزعم أنّ الله يحيى الموتى بعد إذ بَلِيَتْ عظامنا وكنا ترابًا، تزعم أن الله يبعثنا خلقًا جديدًا؟! ثم جعل يفتّ العظم، ثم يذريه في الريح، ويقول: يا محمد، مَن يحيي هذا؟! فقال النبي ﷺ: «<b>يحيي الله ﷿ هذا، ثم يميتك، ثم يبعثك، ثم يدخلك نار جهنم</b>». فأنزل الله ﷿ في أبي بن خلف: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ﴾</span> الآية{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠١٣<span class="dash">-</span></span> عن أبي الأسود -من طريق ابن لهيعة-: أنّ أبيّ بن خلف الذي قال لرسول الله ﷺ: <span class="qpc-hafs">﴿مَن يُحْيِ العِظامَ وهِيَ رَمِيمٌ﴾</span>، [فقتله] النبي بيده ﷺ، ومات من طعنة رسول الله ﷺ ... أن رجع إلى مكة{18}<span class=comment-ref>٥٤٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٥٨</span> ذكر <u>ابنُ كثير</u> (١١/٣٨٤) الاختلاف الوارد في نزول الآية، وفيمن عني بها، ثم قال <span class="comment-type-4">معلّقًا</span>: «وعلى كل تقدير سواء كانت هذه الآيات قد نزلت في أبي بن خلف، أو في العاص بن وائل، أو فيهما، فهي <span class="mustanad">عامة</span> في كل مَن أنكر البعث. والألف واللام في قوله: <span class="qpc-hafs">﴿أولم ير الإنسان﴾</span> للجنس، يعم كل منكر للبعث».</div></p><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَ ٱلۡإِنسَـٰنُ أَنَّا خَلَقۡنَـٰهُ مِن نُّطۡفَةࣲ فَإِذَا هُوَ خَصِیمࣱ مُّبِینࣱ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٠١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوَلَمْ يَرَ الإنْسانُ﴾</span> يعني: أولم يعلم الإنسان <span class="qpc-hafs">﴿أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</span> بَيِّنُ الخصومة فيما يخاصم النبيَّ ﷺ عن البعث{19}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في مسند الشاميين ٣/٣٨٠، من طريق نصر بن خزيمة، أن أباه حدثه، عن نصر بن علقمة، عن أخيه محفوظ، عن ابن عائذ، عن المقدام بن معديكرب به.</p><p>نصر بن خزيمة، وأبوه خزيمة بن عبادة، لم يذكرهما أحد بجرح أوتعديل، وبقيّة رواته ثقات.عظم حائل: متغير، قد غيّره البِلى. النهاية ١/٤٦٣.أخرجه الحاكم ٢/٤٦٦ (٣٦٠٦)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٩٣-.</p><p>قال الحاكم: «هذا حديث صحيح على شرط الشيخين ولم يخرجاه».أخرجه ابن جرير ١٩/٤٨٧، وابن مردويه -كما في تخريج أحاديث الكشاف ٣/١٦٨-.</p><p>قال ابن كثير في تفسيره ٦/٥٩٤: «هذا منكر؛ لأن السورة مكية، وعبد الله ابن أبي إنما كان بالمدينة».عزاه السيوطي إلى ابن مردويه.أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/١٦٨-، من طريق نهشل بن سعيد، عن الضحاك، عن ابن عباس به.</p><p>إسناده ضعيف؛ فيه نهشل بن سعيد بن وردان الورداني، قال عنه ابن حجر في التقريب (٧١٩٨): «متروك، وكذّبه إسحاق بن راهويه».أخرجه ابن جرير ١٩/٤٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٨٦.أخرجه يحيى بن سلام ٢/٨٢٠، وإسحاق البستي ص١٩٥ بنحوه من طريق سفيان بن عيينة. وعزا السيوطي نحوه إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي ص١٩٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في البعث -كما في تخريج أحاديث الكشاف ٣/١٦٧-. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر. كما أخرجه الواحدي بنحوه في أسباب النزول (ت: الفحل) ١/٣٦٥ من طريق حصين.تفسير الثعلبي ٨/١٣٧.أخرجه عبد الرزاق ٢/١٤٦، وابن جرير ١٩/٤٨٦ بلفظ مقارب، وزاد في آخره: فقتله رسول الله ﷺ يوم أحد. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٥.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٥٣ (٣١٣).تفسير مقاتل بن سليمان ٣/٥٨٥-٥٨٦.
  36,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَضَرَبَ لَنَا مَثَلࣰا وَنَسِیَ خَلۡقَهُۥۖ قَالَ مَن یُحۡیِ ٱلۡعِظَـٰمَ وَهِیَ رَمِیمࣱ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٠١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وضَرَبَ لَنا مَثَلًا﴾</span> وصَفَ لنا شبَهًا في أمر العظم، <span class="qpc-hafs">﴿ونَسِيَ خَلْقَهُ﴾</span> وترك المنظر في بدْء خلْق نفسه؛ إذ خُلق من نطفة، ولم يكن قبل ذلك شيئًا، <span class="qpc-hafs">﴿قالَ مَن يُحْيِ العِظامَ وهِيَ رَمِيمٌ﴾</span> يعني: بالية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ونَسِيَ خَلْقَهُ﴾</span> وقد علم أنّا خلقناه، أي: فكما خلقناه فكذلك نعيده، <span class="qpc-hafs">﴿وهِيَ رَمِيمٌ﴾</span> رفات{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٦.تفسير يحيى بن سلام ٢/٨٢٠.
  36,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ یُحۡیِیهَا ٱلَّذِیۤ أَنشَأَهَاۤ أَوَّلَ مَرَّةࣲۖ وَهُوَ بِكُلِّ خَلۡقٍ عَلِیمٌ ۝٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد لأبي: <span class="qpc-hafs">﴿يُحْيِيها﴾</span> يوم القيامة <span class="qpc-hafs">﴿الَّذِي أنْشَأَها﴾</span> خلقها <span class="qpc-hafs">﴿أوَّلَ مَرَّةٍ﴾</span> في الدنيا، ولم تكُ شيئًا، <span class="qpc-hafs">﴿وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</span> عليم بخلْقهم في الدنيا، عليم بخلْقهم في الآخرة بعد الموت خلقًا جديدًا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ یُحۡیِیهَا ٱلَّذِیۤ أَنشَأَهَاۤ أَوَّلَ مَرَّةࣲۖ وَهُوَ بِكُلِّ خَلۡقٍ عَلِیمٌ ۝٧٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٠١٨<span class="dash">-</span></span> عن ابن عباس، عن النبي ﷺ، قال: «<b>قال الله: كذَّبني ابنُ آدم، ولم يكن له ذلك، وشتمني، ولم يكن له ذلك؛ فأمّا تكذيبه إيّاي فزعم أنّي لا أقدر أن أعيده كما كان، وأما شتمه إياي فقوله: لي ولد، فسبحاني أن أتخذ صاحبة أو ولدًا</b>»{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠١٩<span class="dash">-</span></span> عن علي بن أبي طالب، قال: بينما النبي ﷺ في مجلسه يُحَدِّث الناس بالثواب والعقاب، والجنة والنار، والبعث والنشور؛ إذ أقبل أعرابيٌّ مِن بني سُليم بيده اليمنى عظام نخرة، وفي يده اليسرى ضَبّ، فأقبل بالعظام يضعها بين يدي رسول الله ﷺ، ثم عركها برجله، ثم قال: يا محمد، ترى ربَّك يعيدها خلقًا جديدًا؟ فأراد النبيُّ ﷺ جوابه، ثم انتظر الإجابة من السماء، فنزل جبريل على النبي ﷺ: <span class="qpc-hafs">﴿وضرب لنا مثلا ونسي خلقه قال من يحيى العظام وهي رميم * قل يحييها الذي أنشاها أول مرة وهو بكل خلق عليم﴾</span>. فقرأها رسول الله ﷺ علي الأعرابي، فقال: واللات والعُزّى، ما اشتملت أرحامُ النساء وأصلابُ الرجال على ذي لهجة أكذبَ منك، ولا أبغضَ إلَيَّ منك، ولولا أن قومي يدعونني عجولًا لقتلتك، وأفسدت بقتلك الأسود والأبيض مِن بين هاشم. فهَمَّ به علي بن أبي طالب، فقال رسول الله ﷺ: «<b>يا علي، أما علمت أنّ الحليم كاد أن يكون نبيًّا</b>». فقال النبي ﷺ: «<b>يا أعرابي، بئس ما جئتنا به، وسوء ما تستقبلني به، واللهِ، إني لَمحمود في الأرض، أمين في السماء عند الله</b>». فقال الأعرابي -ورمى الضبَّ في حِجر رسول الله ﷺ-، وقال: واللهِ، لا أؤمن بك حتى يؤمن بك هذا الضب. فأخذ رسول الله ﷺ بذَنَبه، ثم قال: «<b>يا ضب</b>». قال: لبيك، يا زين مَن وافى يوم القيامة. قال: «<b>من تعبد</b>؟». قال: أعبد اللهَ الذي في السماء عرشه، وفي الأرض سلطانه، وفي البحر سبيله، وفي الجنة ثوابه، وفي النار عذابه. قال: <b>«مَن أنا</b>؟». قال: أنت محمد بن عبد الله بن عبد المطلب بن هاشم بن عبد مناف بن قصي بن كلاب -حتى نسبه إلى إبراهيم الخليل ﵇، أنت رسول الله، لا يحرم مَن صدَّقك، وخاب مَن كذَّبك. فولى الأعرابيُّ وهو يضحك، فقال رسول الله ﷺ: «<b>أبالله وآياته تستهزئ</b>؟!». فرجع إليه، فقال: بأبي وأمي، ليس الخبر كالمعاينة، أنا أشهد بلحمي ودمي وعظامي أن لا إله إلا الله وأنك رسول الله. فقال النبي ﷺ: «<b>جئتَنا كافرًا، وترجع مؤمنًا، هل لك مِن مال</b>؟». قال: والذي بعثك بالحق رسولًا، ما في بني سُليم أفقر مِنِّي، ولا أقلَّ شيئًا مني. فقام رسولُ الله ﷺ، فقال: «<b>مَن عنده راحلة يحمل أخاه عليها</b>؟». فقام عديُّ بن حاتم الطائي، فقال: يا رسول، الله عندي ناقة وبراء حمراء عشراء، إذا أقبلت دقَّت، وإذا أدبرت زفت، أهداها إلَيَّ أشعثُ بن وائل غداةَ قدمت معك مِن غزوة تبوك. فقال النبي ﷺ: «<b>لك عندي ناقة مِن دُرَّة بيضاء</b>»{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٦.أخرجه البخاري ٦/١٩-٢٠ (٤٤٨٢).أخرجه ابن عساكر في تاريخه ٤/٣٨١.</p><p>قال ابن عساكر: «هذا حديث غريب، وفيه مَن يُجهل حالُه، وإسناده غير متصل».
  36,80,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِی جَعَلَ لَكُم مِّنَ ٱلشَّجَرِ ٱلۡأَخۡضَرِ نَارࣰا فَإِذَاۤ أَنتُم مِّنۡهُ تُوقِدُونَ ۝٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٠٢٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا﴾</span> هما شجرتان، يُقال لأحدهما: المرَخ، وللأخرى: العفار، فمَن أراد منهم النار قطع منهما غصنين مثل السواكين وهما خضراوان يقطر منهما الماء، فيسحَق المرَخ على العفار، فيخرج منها النار -بإذن الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا﴾</span>، يقول: الذي أخرج هذه النار مِن هذا الشجر قادِرٌ أن يبعثه{2}. (١٢/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا فَإذا أنْتُمْ مِنهُ تُوقِدُونَ﴾</span>، فالذي يخرج مِن الشجر الأخضر النارَ فهو قادِرٌ على البعث{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا فَإذا أنْتُمْ مِنهُ تُوقِدُونَ﴾</span> كل عود يزند منه النار فهو مِن شجرة خضراء{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٨/١٣٧، وتفسير البغوي ٦/٢٩.أخرجه ابن جرير ١٩/٤٨٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٦.تفسير يحيى بن سلام ٢/٨٢١.
  36,81,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَیۡسَ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ بِقَـٰدِرٍ عَلَىٰۤ أَن یَخۡلُقَ مِثۡلَهُمۚ بَلَىٰ وَهُوَ ٱلۡخَلَّـٰقُ ٱلۡعَلِیمُ ۝٨١ إِنَّمَاۤ أَمۡرُهُۥۤ إِذَاۤ أَرَادَ شَیۡـًٔا أَن یَقُولَ لَهُۥ كُن فَیَكُونُ ۝٨٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٥٠٢٤<span class="dash">-</span></span> عن النضر، عن هارون، قال أهل مكة: ‹إنَّمَآ أمْرُهُ إذَآ أرادَ شَيْئًا أنْ يَقُولَ لَهُ كُن فَيَكُونَ› نصب، قال النضر: وأهل البصرة يقرءون: <span class="qpc-hafs">﴿فَيَكُونُ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوَلَیۡسَ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ بِقَـٰدِرٍ عَلَىٰۤ أَن یَخۡلُقَ مِثۡلَهُمۚ بَلَىٰ وَهُوَ ٱلۡخَلَّـٰقُ ٱلۡعَلِیمُ ۝٨١ إِنَّمَاۤ أَمۡرُهُۥۤ إِذَاۤ أَرَادَ شَیۡـًٔا أَن یَقُولَ لَهُۥ كُن فَیَكُونُ ۝٨٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٥٠٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أوَلَيْسَ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ بِقادِرٍ﴾</span> الآية، قال: هذا مِثْلُ قوله: <span class="qpc-hafs">﴿إنما إنَّما أمْرُهُ إذا أرادَ شَيْئًا أنْ يَقُولَ لَهُ كُنْ فَيَكُونُ﴾</span>. قال: ليس من كلام العرب أهون ولا أخف من ذلك، فأمْر الله كذلك{2}. (١٢/٣٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٢٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿أوَلَيْسَ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ بِقادِرٍ عَلى أنْ يَخْلُقَ مِثْلَهُمْ﴾</span> في الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر ما هو أعظم خَلْقًا مِن خَلْق الإنسان، فقال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿أوَلَيْسَ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ﴾</span> هذا أعظم خلقًا مِن خلق الإنسان <span class="qpc-hafs">﴿بِقادِرٍ عَلى أنْ يَخْلُقَ﴾</span> في الأرض <span class="qpc-hafs">﴿مِثْلَهُمْ﴾</span> مثل خلْقهم في الدنيا. ثم قال لنفسه تعالى: <span class="qpc-hafs">﴿بَلى﴾</span> قادِرٌ على ذلك، <span class="qpc-hafs">﴿وهُوَ الخَلّاقُ العليم﴾</span> بخلْقهم، في الآخرة العليم ببعْثهم، <span class="qpc-hafs">﴿إنَّما أمْرُهُ إذا أرادَ شَيْئًا﴾</span> أمر البعْث وغيره <span class="qpc-hafs">﴿أنْ يَقُولَ لَهُ﴾</span> مرة واحدة <span class="qpc-hafs">﴿كُنْ فَيَكُونُ﴾</span> لا يثني قوله{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص١٩٦.</p><p>و‹فَيَكُونَ› قراءة متواترة، قرأ بها ابن عامر، والكسائي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿فَيَكُونُ﴾</span> بالرفع. انظر: النشر ٢/٢٢٠، والإتحاف ص٤٧٠.أخرجه ابن جرير ١٩/٤٩٠-٤٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٢١.تفسير مقاتل بن سليمان ٣/٥٨٦-٥٨٧.
  36,82,""
  36,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱلَّذِی بِیَدِهِۦ مَلَكُوتُ كُلِّ شَیۡءࣲ وَإِلَیۡهِ تُرۡجَعُونَ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٥٠٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عظّم نفسه عن قولهم، فقال ﷿: <span class="qpc-hafs">﴿فَسُبْحانَ الَّذِي بِيَدِهِ مَلَكُوتُ﴾</span> خلْق <span class="qpc-hafs">﴿كل شيء﴾</span> مِن البعث وغيره، <span class="qpc-hafs">﴿وإلَيْهِ تُرْجَعُونَ﴾</span> إلى الله ﷿ بعد الموت لتكذيبهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٥٠٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَسُبْحانَ﴾</span> يُنَزِّه نفسه عما قال المشركون <span class="qpc-hafs">﴿الَّذِي بِيَدِهِ مَلَكُوتُ كُلِّ شَيْءٍ وإلَيْهِ تُرْجَعُونَ﴾</span> يوم القيامة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٧.تفسير يحيى بن سلام ٢/٨٢١.