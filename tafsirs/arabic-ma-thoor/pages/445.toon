tafsir[13]{c,v,t}:
36,71," <q>﴿أَوَلَمۡ یَرَوۡا۟ أَنَّا خَلَقۡنَا لَهُم مِّمَّا عَمِلَتۡ أَیۡدِینَاۤ أَنۡعَـٰمࣰا فَهُمۡ لَهَا مَـٰلِكُونَ ۝٧١﴾</q> - تفسير ٦٤٩٦١- تفسير الحسن البصري: <q>﴿أوَلَمْ يَرَوْا أنّا خَلَقْنا لَهُمْ مِمّا عَمِلَتْ أيْدِينا أنْعامًا﴾</q> أي: بقوتنا. قال يحيى بن سلّام: كقوله: <q>﴿والسَّماءَ بَنَيْناها بِأَيْدٍ﴾</q> [الذاريات:٤٧]{1}. (ز) ٦٤٩٦٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فهم لها مالكون﴾</q>، قال: ضابِطون{2}. (١٢/٣٧٥) ٦٤٩٦٣- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿فَهُمْ لَها مالِكُونَ﴾</q>، قال: مطيعون{3}. (ز) ٦٤٩٦٤- عن إسماعيل السُدِّيّ، في قوله: <q>﴿مِمّا عَمِلَتْ أيْدِينا﴾</q>، قال: مِن صَنْعتنا{4}. (١٢/٣٧٥) ٦٤٩٦٥- قال مقاتل بن سليمان: <q>﴿مِمّا عَمِلَتْ أيْدِينا﴾</q> مِن فعلنا <q>﴿أنْعامًا﴾</q> الإبل والبقر والغنم، <q>﴿فَهُمْ لَها مالِكُونَ﴾</q> ضابطين{5}. (ز) ٦٤٩٦٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أوَلَمْ يَرَوْا أنّا خَلَقْنا لَهُمْ مِمّا عَمِلَتْ أيْدِينا أنْعامًا فَهُمْ لَها مالِكُونَ﴾</q>، فقيل له: أهي الإبل؟ فقال: نعم. قال: والبقر مِن الأنعام، وليست بداخلة في هذه الآية. قال: والإبل والبقر والغنم مِن الأنعام. وقرأ: <q>﴿ثَمانِيَةَ أزْواجٍ﴾</q> [الأنعام:١٤٣]، قال: والبقر والإبل هي النعم، وليست تدخل الشاء في النعم{6}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٨١٩.أخرجه ابن جرير ١٩/٤٨٢. وعلقه يحيى بن سلام ٢/٨١٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٦.عزاه السيوطي إلى ابن أبي حاتم. وعند يحيى بن سلام في تفسيره ٢/٨١٩ معلقًا بلفظ: مِن فِعْله.تفسير مقاتل بن سليمان ٣/٥٨٤.أخرجه ابن جرير ١٩/٤٨٢.
36,72," <q>﴿وَذَلَّلۡنَـٰهَا لَهُمۡ فَمِنۡهَا رَكُوبُهُمۡ وَمِنۡهَا یَأۡكُلُونَ ۝٧٢﴾</q> - قراءات ٦٤٩٦٧- عن عروة بن الزبير، قال: في مصحف عائشة: (فَمِنها رَكُوبَتُهُمْ){1}. (١٢/٣٧٦) ٦٤٩٦٨- عن هارون، قال: في حرف أبي بن كعب: (فَمِنها رَكُوبَتُهُمْ){2}. (١٢/٣٧٦) ٦٤٩٦٩- عن هارون، قال: قراءة الحسن= (ز) ٦٤٩٧٠- والأعرج= (ز) ٦٤٩٧١- وأبي عمرو، والعامة: <q>﴿فَمِنها رَكُوبُهُمْ﴾</q>، يعني: رُكوبهم؛ حمولتهم{3}. (١٢/٣٧٦) <q>﴿وَذَلَّلۡنَـٰهَا لَهُمۡ فَمِنۡهَا رَكُوبُهُمۡ وَمِنۡهَا یَأۡكُلُونَ ۝٧٢﴾</q> - تفسير الآية ٦٤٩٧٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وذَلَّلْناها لَهُمْ فَمِنها رَكُوبُهُمْ﴾</q> يركبونها ويسافرون عليها، <q>﴿ومِنها يَأْكُلُونَ﴾</q> لحومها{4}. (١٢/٣٧٦) ٦٤٩٧٣- قال مقاتل بن سليمان: <q>﴿وذَلَّلْناها﴾</q> كقوله ﷿: <q>﴿وذُلِّلَتْ قُطُوفُها تَذْلِيلًا﴾</q> [الإنسان:١٤]، <q>﴿وذَلَّلْناها﴾</q> فيحملون عليها ويسوقونها حيث شاءوا ولا تمتنع، <q>﴿فَمِنها رَكُوبُهُمْ﴾</q> حمولتهم الإبل والبقر، <q>﴿ومِنها يَأْكُلُونَ﴾</q> يعني: الغنم{5}. (ز) ٦٤٩٧٤- قال يحيى بن سلّام: <q>﴿وذَلَّلْناها لَهُمْ﴾</q> يعني: الإبل، والبقر، والغنم، والدواب أيضًا، ذللها لكم: الخيل، والبغال، والحمير؛ <q>﴿فَمِنها رَكُوبُهُمْ﴾</q> الإبل والبقر مِن الأنعام، والدواب: الخيل والبغال والحمير، <q>﴿ومِنها يَأْكُلُونَ﴾</q> من الإبل، والبقر، والغنم، وقد يُرخَّص في الخيل، ... عن جابر بن عبد الله: أنهم كانوا يأكلون لحوم الخيل على عهد رسول الله ﷺ{6}. (ز) ",footnotes:1:أخرجه أبو عبيد في فضائل القرآن (١٨٢). وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة، تروى أيضًا عن أُبي. انظر: المحتسب ٢/٢١٥، ومختصر ابن خالويه ص١٢٦.أخرجه أبو عبيد (١٨٢). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة العشرة.أخرجه ابن جرير ١٩/٤٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٤-٥٨٥.تفسير يحيى بن سلام ٢/٨١٩.
36,73," <q>﴿وَلَهُمۡ فِیهَا مَنَـٰفِعُ وَمَشَارِبُۚ أَفَلَا یَشۡكُرُونَ ۝٧٣﴾</q> - تفسير ٦٤٩٧٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولَهُمْ فِيها مَنافِعُ﴾</q> قال: يلبسون أصوافها، <q>﴿ومَشارِبُ﴾</q> يشربون ألبانها{1}. (١٢/٣٧٦) ٦٤٩٧٦- قال مقاتل بن سليمان: <q>﴿ولَهُمْ فِيها مَنافِعُ﴾</q> في الأنعام، ومنافع في الركوب عليها، والحمل عليها، وينتفعون بأصوافها، وأوبارها، وأشعارها، ثم قال -جلَّ وعز-: <q>﴿ومَشارِبُ﴾</q> ألبانها{2}. (ز) ٦٤٩٧٧- قال يحيى بن سلّام: قال: <q>﴿ولَهُمْ فِيها﴾</q> في الأنعام <q>﴿مَنافِعُ﴾</q> في أصوافها، وأوبارها، وأشعارها، ولحومها، <q>﴿ومَشارِبُ﴾</q> يشربون من ألبانها، <q>﴿أفَلا يَشْكُرُون﴾</q> أي: فليشكروا{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨١٩-٨٢٠.
36,74," <q>﴿وَٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ ءَالِهَةࣰ لَّعَلَّهُمۡ یُنصَرُونَ ۝٧٤﴾</q> - تفسير ٦٤٩٧٨- عن قتادة بن دعامة، في قوله: <q>﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً﴾</q>، قال: هي الأصنام{1}. (١٢/٣٧٦) ٦٤٩٧٩- عن عبد الملك ابن جريج، في قوله: <q>﴿لَعَلَّهُمْ يُنْصَرُونَ﴾</q>، قال: يُمْنَعون{2}. (١٢/٣٧٧) ٦٤٩٨٠- قال مقاتل بن سليمان: ثم قال -جل وعز-: <q>﴿واتَّخَذُوا﴾</q> يعني: كفار مكة <q>﴿مِن دُونِ اللَّهِ آلِهَةً﴾</q> يعني: اللات، والعُزّى، ومناة؛ <q>﴿لَعَلَّهُمْ يُنْصَرُونَ﴾</q> لكي تمنعهم{3}. (ز) ٦٤٩٨١- قال يحيى بن سلّام: قوله ﷿: <q>﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لَعَلَّهُمْ يُنْصَرُونَ﴾</q> يُمنعون، كقوله: <q>﴿واتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِيَكُونُوا لَهُمْ عِزًّا﴾</q> [مريم:٨١]{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وأخرج ابن أبي حاتم عن السُدِّيّ في قوله <q>﴿لَعَلَّهُمْ يُنْصَرُونَ﴾</q> أي: يمنعون.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.
36,75," <q>﴿لَا یَسۡتَطِیعُونَ نَصۡرَهُمۡ﴾</q> - تفسير ٦٤٩٨٢- قال عبد الله بن عباس: <q>﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</q> لا تقدر الأصنامُ على نصْرهم ومنْعهم من العذاب{1}. (ز) ٦٤٩٨٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</q>، قال: نصر الآلهة، ولا تستطيع الآلهة نصْرهم{2}. (١٢/٣٧٧) ٦٤٩٨٤- عن إسماعيل السُدِّيّ، في قوله: <q>﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</q>، قال: لا تستطيع الآلهةُ نصرَهم{3}. (١٢/٣٧٧) ٦٤٩٨٥- قال مقاتل بن سليمان: <q>﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</q> لا تقدر الآلهةُ أن تمنعهم مِن العذاب{4}. (ز) ٦٤٩٨٦- قال يحيى بن سلّام: قال: <q>﴿لا يَسْتَطِيعُونَ نَصْرَهُمْ﴾</q> لا تستطيع آلهتُهم التي يعبدون نصْرهم{5}٥٤٥٥. (ز) ٥٤٥٥ ذكر ابنُ عطية (٧/٢٦٦) في عود الضمير من قوله: <q>﴿يستطيعون﴾</q> احتمالين، وصححهما، فقال: «ويحتمل أن يكون الضمير في <q>﴿يَسْتَطِيعُونَ﴾</q> للكفار، وفي <q>﴿نصْرَهم﴾</q> للأصنام، ويحتمل الأمر عكس ذلك؛ لأن الوجهين صحيحان في المعنى». <q>﴿وَهُمۡ لَهُمۡ جُندࣱ مُّحۡضَرُونَ ۝٧٥﴾</q> - تفسير ٦٤٩٨٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q>، قال: عند الحساب{6}. (ز) ٦٤٩٨٨- عن الحسن البصري -من طريق معمر- <q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q> قال: هم لهم جند في الدنيا، وهم <q>﴿مُحْضَرُونَ﴾</q> في النار{7}. (١٢/٣٧٧) ٦٤٩٨٩- عن الحسن البصري، في قوله:<q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q>، قال: محضرون لآلهتهم التي يعبدون، يدفعون عنهم ويمنعونهم{8}. (١٢/٣٧٧) ٦٤٩٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q>، قال: المشركون يغضبون للآلهة في الدنيا، وهي لا تسوق إليهم خيرًا، ولا تدفع عنهم سوءًا، إنما هي أصنام{9}. (١٢/٣٧٧) ٦٤٩٩١- عن محمد بن السائب الكلبي-من طريق معمر-: <q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q> يعكفون حولَهم في الدنيا{10}. (ز) ٦٤٩٩٢- قال مقاتل بن سليمان: ثم قال -جلَّ وعزَّ-: <q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q>، يقول: كفار مكة للآلهة حِزْبٌ؛ يغضبون لها، ويحضرونها في الدنيا{4}. (ز) ٦٤٩٩٣- قال يحيى بن سلّام: قال: <q>﴿وهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</q> معهم في النار{5}٥٤٥٦. (ز) ٥٤٥٦ اختلف السلف في تفسير قوله: <q>﴿وهم لهم جند مجضرون﴾</q> على قولين: الأول: أن المعنى: وهم لهم جند محضرون يوم الحساب. الثاني: أن المعنى: وهم لهم جند محضرون في الدنيا، يغضبون لهم ويدافعون عنهم. وقد رجّح ابنُ جرير (١٩/٤٨٥) مستندًا إلى الدلالة العقلية القول الثاني، وهو قول الحسن، وقتادة، والكلبي، ومقاتل، وعلَّل ذلك بقوله: «لأن المشركين عند الحساب تتبرأ منهم الأصنام، وما كانوا يعبدونه، فكيف يكونون لها جندًا حينئذ، ولكنهم في الدنيا لهم جند يغضبون لهم، ويقاتلون دونهم». ووافقه ابنُ كثير (١١/٣٨٣) بقوله: «وهذا القول حسن». ووجّه ابنُ عطية (٧/٢٦٦) المعنى على القول الأول، بأنه: «على معنى التوبيخ والنقمة، وسماهم جندًا في هذا التأويل إذ هم عُدة للنقمة منهم وتوبيخهم». ووجّه المعنى على القول الثاني بأنه: «على معنى: وهؤلاء الكفار متجندون متحزبون لهذه الأصنام في الدنيا، لكنهم لا يستطيعون التناصر مع ذلك». ",footnotes:1:تفسير البغوي ٦/٢٨.أخرجه ابن جرير ١٩/٤٨٥ بلفظ:«الألهة». وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٨٤. وعلَّقه البخاري في صحيحه (ت: مصطفى البغا)، كتاب التفسير، باب تفسير سورة يس ٤/١٨٠٥، وذكر ابن حجر في الفتح ٨/٥٤١ أن الفريابي وصله في تفسيره.أخرجه عبد الرزاق ٢/١٤٦. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٨٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٦.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.
36,76," <q>﴿فَلَا یَحۡزُنكَ قَوۡلُهُمۡۘ إِنَّا نَعۡلَمُ مَا یُسِرُّونَ وَمَا یُعۡلِنُونَ ۝٧٦﴾</q> - تفسير ٦٤٩٩٤- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿فَلا يَحْزُنْكَ قَوْلُهُمْ﴾</q> إنّك ساحر، وإنك شاعر، وإنك كاهن، وإنك مجنون، وإنك كاذب{1}. (ز) ٦٤٩٩٥- قال مقاتل بن سليمان: <q>﴿فَلا يَحْزُنْكَ قَوْلُهُمْ﴾</q> كفار مكة، <q>﴿إنّا نَعْلَمُ ما يُسِرُّونَ﴾</q> من التكذيب، <q>﴿وما يُعْلِنُونَ﴾</q> يُظهِرون مِن القول بألسنتهم حين قالوا للنبي ﷺ: كيف يبعث الله هذا العَظْمَ؟! علانية{2}. (ز) ٦٤٩٩٦- قال يحيى بن سلّام: <q>﴿إنّا نَعْلَمُ ما يُسِرُّونَ﴾</q> مِن عداوتهم لك، <q>﴿وما يُعْلِنُونَ﴾</q> كفْرهم بما جئتهم به، فسنعصمك منهم، ونُذِلُّهم لك، ففعل الله ذلك به{3}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ٢/٨٢٠.تفسير مقاتل بن سليمان ٣/٥٨٥.تفسير يحيى بن سلام ٢/٨٢٠.
36,77," <q>﴿أَوَلَمۡ یَرَ ٱلۡإِنسَـٰنُ أَنَّا خَلَقۡنَـٰهُ مِن نُّطۡفَةࣲ فَإِذَا هُوَ خَصِیمࣱ مُّبِینࣱ ۝٧٧﴾</q> الآيات - نزول الآيات ٦٤٩٩٧- عن المقدام، أنّ رسول الله ﷺ قال: «أخذ أمية بن خلف عظمًا، ففتّه، ثم قال لصاحب له: أترى الله يحيي هذه وهي رميم. وأُنزلت هذه الآية: <q>﴿مَن يُحْيِ العِظامَ وهِيَ رَمِيمٌ﴾</q>، فلزم الحق بمنكبه»{1}. (ز) ٦٤٩٩٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: جاء العاصي بن وائل إلى رسول الله ﷺ بعظم حائل{2}، ففتَّه بيده، وقال: يا محمد، أيحيي الله هذا بعد ما أرى؟ قال: «نعم، يبعث الله هذا، ثم يميتك، ثم يحييك، ثم يدخلك نار جهنم». فنزلت الآيات من آخر يس: <q>﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</q> إلى آخر السورة{3}. (١٢/٣٧٧) ٦٤٩٩٩- عن عبد الله بن عباس -من طريق عطية العوفي- قال: جاء عبد الله بن أُبَيّ وفي يده عظم حائل إلى النبي ﷺ، فكسره بيده، ثم قال: يا محمد، كيف يبعثه الله وهو رميم؟! فقال رسول الله ﷺ: «يبعث الله هذا، ويميتك، ثم يُدخلك جهنم». قال الله: <q>﴿قُلْ يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</q>{4}٥٤٥٧. (١٢/٣٧٨) ٥٤٥٧ انتقد ابن عطية (٧/٢٦٧) مستندًا إلى أحوال النزول والدلالة العقلية ما أفاده هذا الأثر عن ابن عباس من كون الآية نازلة في عبد الله بن أبي، فقال: «وهو وهمٌ ممن نسبه إلى ابن عباس؛ لأن السورة مكية، والآية مكية بإجماع، ولأن عبد الله بن أبي لم يجاهر قط هذه المجاهرة، واسْمُ أُبي هو الذي خلط على الرواة؛ لأن الصحيح هو ما رواه ابن وهب عن مالك، وقاله ابن إسحاق وغيره: من أن أبي بن خلف أخا أمية بن خلف هو الذي جاء بالعظم الرميم بمكة ففته في وجه النبي ﷺ، وقال: من يحيي هذا، يا محمد؟». وبنحوه قال ابنُ كثير (١١/٣٨٤). ٦٥٠٠٠- عن عبد الله بن عباس، قال: جاء أُبَيُّ بن خلف الجمحي إلى رسول الله ﷺ بعظم نَخِر، فقال: أتَعِدُنا -يا محمد- إذا بَلِيَت عظامُنا فكانت رميمًا أنّ الله باعِثُنا خلقًا جديدًا؟! ثم جعل يفُتّ العظم، ويَذُرُّه في الريح، فيقول: يا محمد، مَن يُحْيِي هذا؟ فقال رسول الله ﷺ: «نعم، يميتك الله، ثم يحييك، ويجعلك في جهنم». ونزل على رسول الله ﷺ: <q>﴿وضَرَبَ لَنا مَثَلًا ونَسِيَ خَلْقَهُ﴾</q> الآيتين{5}. (١٢/٣٧٩) ٦٥٠٠١- عن عبد الله بن عباس، قال: نزلت هذه الآيةُ في أبي جهل بن هشام، جاء بعظم حائِل إلى النبي ﷺ، فذرّاه، فقال: مَن يحيي العظام وهي رميم؟! فقال الله: يا محمد، <q>﴿قل يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</q>{6}. (١٢/٣٧٩) ٦٥٠٠٢- عن سعيد بن جبير -من طريق أبي بشر- قال: جاء العاص بن وائل السهمي إلى رسول الله ﷺ بعظم حائل، ففتّه بين يديه، فقال: يا محمد، أيبعث الله هذا حيًّا بعد ما أرم؟! قال: «نعم، يبعث الله هذا، ثم يميتك، ثم يحييك، ثم يدخلك نار جهنم». قال: فنزلت الآيات: <q>﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</q> إلى آخر الآية{7}. (ز) ٦٥٠٠٣- عن عروة بن الزبير، قال: لما أنزل الله على رسوله: إن الناس يحاسبون بأعمالهم، ويُبعثون يوم القيامة. أنكروا ذلك إنكارًا شديدًا، فعمد أُبَيّ بن خلف إلى عظم حائل قد نخِر وبلي، ففتّه، ثم ذراه في الريح، ثم قال: يا محمد، إذا بَلِيَتْ عظامُنا إنا لمبعوثون خلقًا جديدًا؟! فوجد رسول الله ﷺ مِن استقباله إيّاه بالتكذيب والأذى في وجهه وجْدًا شديدًا، فأنزل الله على رسوله: <q>﴿قُلْ يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ﴾</q> الآية{8}. (١٢/٣٨١) ٦٥٠٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وضَرَبَ لَنا مَثَلًا﴾</q>، قال: أُبَيّ بن خلف{9}. (١٢/٣٧٩) ٦٥٠٠٥- عن مجاهد بن جبر -من طريق أبي يحيى- قال: أتى أُبَيّ بن خلف إلى النبي ﷺ بعظمٍ بالٍ، فقال: أيحيي الله هذا وهو رميم؟! قال يحيى: فبلغني: أنّ النبي ﷺ قال له: «يحييك الله بعد موتك، ثم يدخلك النار». فأنزل الله: <q>﴿قُلْ يُحْيِيها الَّذِي أنْشَأَها أوَّلَ مَرَّةٍ وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</q>{10}. (١٢/٣٧٩) ٦٥٠٠٦- عن محمد بن السائب الكلبي -من طريق سفيان بن عيينة-: أتى أُبَيُّ بن خلف الجمحي النبيَّ ﷺ بعظم بالٍ قد أتى عليه حين، ففتَّه بيده، ثم قال: يا محمدُ، أيعيدنا إذا كنا مثل هذا؟! فأنزل الله -تبارك وتعالى-: <q>﴿أولم ير الإنسان أنا خلقناه من نطفة فإذا هو خصيم مبين وضرب لنا مثلا ونسي خلقه قال من يحي العظام وهي رميم قل يحييها الذي أنشأها أول مرة وهو بكل خلق عليم﴾</q>{11}. (ز) ٦٥٠٠٧- عن عكرمة مولى ابن عباس، قال: جاء أُبَيّ بن خلف إلى النبي ﷺ وفي يده عظم حائل، فقال: يا محمد، أنّى يحيي الله هذا؟! فأنزل الله: <q>﴿وضرب لنا مثلا ونسي خلقه﴾</q>. فقال له رسول الله ﷺ: «خلْقها قبل أن تكون أعجب من إحيائها، وقد كانت»{8}. (١٢/٣٨٠) ٦٥٠٠٨- عن أبي مالك، قال: جاء أُبَيّ بن خلف بعظم نخِرة، فجعل يفتّه بين يدي النبي ﷺ، قال: مَن يحيي العظام وهي رميم؟! فأنزل الله: <q>﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</q> إلى قوله: <q>﴿وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</q>{13}. (١٢/٣٧٩) ٦٥٠٠٩- قال الحسن البصري: <q>﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ﴾</q> هو أمية بن خلف{14}. (ز) ٦٥٠١٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وضَرَبَ لَنا مَثَلًا﴾</q>، قال: نزلت في أُبَيّ بن خلف، جاء بعظم نخِر، فجعل يذُرُّه في الريح، فقال: أنّى يُحيي اللهُ هذا؟ قال النبي ﷺ: «نعم، يُحْيِي اللهُ هذا، ويُدخلك النار»{15}. (١٢/٣٨٠) ٦٥٠١١- عن إسماعيل السُدِّيّ، في قوله: <q>﴿أوَلَمْ يَرَ الإنْسانُ أنّا خَلَقْناهُ مِن نُطْفَةٍ﴾</q>، قال: نزلت في أُبَيّ بن خلف، أتى النبيَّ ﷺ ومعه عظْم قد بَلي، فجعل يفتُّه بين أصابعه، ويقول: يا محمد، أنت الذي تُحَدِّث أنّ هذا سيَحيا بعد ما قد بَلى؟! فقال رسول الله ﷺ: «نعم، ليُميتن الآخر، ثم ليحيينه، ثم ليدخلنه النار»{8}. (١٢/٣٨٠) ٦٥٠١٢- قال مقاتل بن سليمان: نزلت في أُبَيّ بن خلف الجمحي في أمر العظم، وكان قد أضحكهم بمقالته، فهذا الذي أعلنوا، وذلك أنّ أبا جهل، والوليد بن المغيرة، وعتبة وشيبة ابني ربيعة، وعقبة، والعاص بن وائل، كانوا جلوسًا، فقال لهم أُبَيّ بن خلف، قال لهم في النفر من قريش: إنّ محمدًا يزعم أن الله يحيي الموتى، وأنا آتيه بعظم، فأسأله: كيف يبعث الله هذا؟ فانطلق أُبَيّ بن خلف، فأخذ عظْمًا باليًا حائلًا نخِرًا، فقال: يا محمد، تزعم أنّ الله يحيى الموتى بعد إذ بَلِيَتْ عظامنا وكنا ترابًا، تزعم أن الله يبعثنا خلقًا جديدًا؟! ثم جعل يفتّ العظم، ثم يذريه في الريح، ويقول: يا محمد، مَن يحيي هذا؟! فقال النبي ﷺ: «يحيي الله ﷿ هذا، ثم يميتك، ثم يبعثك، ثم يدخلك نار جهنم». فأنزل الله ﷿ في أبي بن خلف: <q>﴿أوَلَمْ يَرَ الإنْسانُ﴾</q> الآية{17}. (ز) ٦٥٠١٣- عن أبي الأسود -من طريق ابن لهيعة-: أنّ أبيّ بن خلف الذي قال لرسول الله ﷺ: <q>﴿مَن يُحْيِ العِظامَ وهِيَ رَمِيمٌ﴾</q>، [فقتله] النبي بيده ﷺ، ومات من طعنة رسول الله ﷺ ... أن رجع إلى مكة{18}٥٤٥٨. (ز) ٥٤٥٨ ذكر ابنُ كثير (١١/٣٨٤) الاختلاف الوارد في نزول الآية، وفيمن عني بها، ثم قال معلّقًا: «وعلى كل تقدير سواء كانت هذه الآيات قد نزلت في أبي بن خلف، أو في العاص بن وائل، أو فيهما، فهي عامة في كل مَن أنكر البعث. والألف واللام في قوله: <q>﴿أولم ير الإنسان﴾</q> للجنس، يعم كل منكر للبعث». <q>﴿أَوَلَمۡ یَرَ ٱلۡإِنسَـٰنُ أَنَّا خَلَقۡنَـٰهُ مِن نُّطۡفَةࣲ فَإِذَا هُوَ خَصِیمࣱ مُّبِینࣱ ۝٧٧﴾</q> - تفسير ٦٥٠١٤- قال مقاتل بن سليمان: <q>﴿أوَلَمْ يَرَ الإنْسانُ﴾</q> يعني: أولم يعلم الإنسان <q>﴿أنّا خَلَقْناهُ مِن نُطْفَةٍ فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</q> بَيِّنُ الخصومة فيما يخاصم النبيَّ ﷺ عن البعث{19}. (ز) ",footnotes:1:أخرجه الطبراني في مسند الشاميين ٣/٣٨٠، من طريق نصر بن خزيمة، أن أباه حدثه، عن نصر بن علقمة، عن أخيه محفوظ، عن ابن عائذ، عن المقدام بن معديكرب به. نصر بن خزيمة، وأبوه خزيمة بن عبادة، لم يذكرهما أحد بجرح أوتعديل، وبقيّة رواته ثقات.عظم حائل: متغير، قد غيّره البِلى. النهاية ١/٤٦٣.أخرجه الحاكم ٢/٤٦٦ (٣٦٠٦)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٩٣-. قال الحاكم: «هذا حديث صحيح على شرط الشيخين ولم يخرجاه».أخرجه ابن جرير ١٩/٤٨٧، وابن مردويه -كما في تخريج أحاديث الكشاف ٣/١٦٨-. قال ابن كثير في تفسيره ٦/٥٩٤: «هذا منكر؛ لأن السورة مكية، وعبد الله ابن أبي إنما كان بالمدينة».عزاه السيوطي إلى ابن مردويه.أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف ٣/١٦٨-، من طريق نهشل بن سعيد، عن الضحاك، عن ابن عباس به. إسناده ضعيف؛ فيه نهشل بن سعيد بن وردان الورداني، قال عنه ابن حجر في التقريب (٧١٩٨): «متروك، وكذّبه إسحاق بن راهويه».أخرجه ابن جرير ١٩/٤٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد (٥٦١)، وأخرجه ابن جرير ١٩/٤٨٦.أخرجه يحيى بن سلام ٢/٨٢٠، وإسحاق البستي ص١٩٥ بنحوه من طريق سفيان بن عيينة. وعزا السيوطي نحوه إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي ص١٩٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في البعث -كما في تخريج أحاديث الكشاف ٣/١٦٧-. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر. كما أخرجه الواحدي بنحوه في أسباب النزول (ت: الفحل) ١/٣٦٥ من طريق حصين.تفسير الثعلبي ٨/١٣٧.أخرجه عبد الرزاق ٢/١٤٦، وابن جرير ١٩/٤٨٦ بلفظ مقارب، وزاد في آخره: فقتله رسول الله ﷺ يوم أحد. وعزاه السيوطي إلى ابن المنذر، وعبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٥.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٥٣ (٣١٣).تفسير مقاتل بن سليمان ٣/٥٨٥-٥٨٦.
36,78," <q>﴿وَضَرَبَ لَنَا مَثَلࣰا وَنَسِیَ خَلۡقَهُۥۖ قَالَ مَن یُحۡیِ ٱلۡعِظَـٰمَ وَهِیَ رَمِیمࣱ ۝٧٨﴾</q> - تفسير ٦٥٠١٥- قال مقاتل بن سليمان: ثم قال: <q>﴿وضَرَبَ لَنا مَثَلًا﴾</q> وصَفَ لنا شبَهًا في أمر العظم، <q>﴿ونَسِيَ خَلْقَهُ﴾</q> وترك المنظر في بدْء خلْق نفسه؛ إذ خُلق من نطفة، ولم يكن قبل ذلك شيئًا، <q>﴿قالَ مَن يُحْيِ العِظامَ وهِيَ رَمِيمٌ﴾</q> يعني: بالية{1}. (ز) ٦٥٠١٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿ونَسِيَ خَلْقَهُ﴾</q> وقد علم أنّا خلقناه، أي: فكما خلقناه فكذلك نعيده، <q>﴿وهِيَ رَمِيمٌ﴾</q> رفات{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٦.تفسير يحيى بن سلام ٢/٨٢٠.
36,79," <q>﴿قُلۡ یُحۡیِیهَا ٱلَّذِیۤ أَنشَأَهَاۤ أَوَّلَ مَرَّةࣲۖ وَهُوَ بِكُلِّ خَلۡقٍ عَلِیمٌ ۝٧٩﴾</q> - تفسير ٦٥٠١٧- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> يا محمد لأبي: <q>﴿يُحْيِيها﴾</q> يوم القيامة <q>﴿الَّذِي أنْشَأَها﴾</q> خلقها <q>﴿أوَّلَ مَرَّةٍ﴾</q> في الدنيا، ولم تكُ شيئًا، <q>﴿وهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</q> عليم بخلْقهم في الدنيا، عليم بخلْقهم في الآخرة بعد الموت خلقًا جديدًا{1}. (ز) <q>﴿قُلۡ یُحۡیِیهَا ٱلَّذِیۤ أَنشَأَهَاۤ أَوَّلَ مَرَّةࣲۖ وَهُوَ بِكُلِّ خَلۡقٍ عَلِیمٌ ۝٧٩﴾</q> - آثار متعلقة بالآية ٦٥٠١٨- عن ابن عباس، عن النبي ﷺ، قال: «قال الله: كذَّبني ابنُ آدم، ولم يكن له ذلك، وشتمني، ولم يكن له ذلك؛ فأمّا تكذيبه إيّاي فزعم أنّي لا أقدر أن أعيده كما كان، وأما شتمه إياي فقوله: لي ولد، فسبحاني أن أتخذ صاحبة أو ولدًا»{2}. (ز) ٦٥٠١٩- عن علي بن أبي طالب، قال: بينما النبي ﷺ في مجلسه يُحَدِّث الناس بالثواب والعقاب، والجنة والنار، والبعث والنشور؛ إذ أقبل أعرابيٌّ مِن بني سُليم بيده اليمنى عظام نخرة، وفي يده اليسرى ضَبّ، فأقبل بالعظام يضعها بين يدي رسول الله ﷺ، ثم عركها برجله، ثم قال: يا محمد، ترى ربَّك يعيدها خلقًا جديدًا؟ فأراد النبيُّ ﷺ جوابه، ثم انتظر الإجابة من السماء، فنزل جبريل على النبي ﷺ: <q>﴿وضرب لنا مثلا ونسي خلقه قال من يحيى العظام وهي رميم * قل يحييها الذي أنشاها أول مرة وهو بكل خلق عليم﴾</q>. فقرأها رسول الله ﷺ علي الأعرابي، فقال: واللات والعُزّى، ما اشتملت أرحامُ النساء وأصلابُ الرجال على ذي لهجة أكذبَ منك، ولا أبغضَ إلَيَّ منك، ولولا أن قومي يدعونني عجولًا لقتلتك، وأفسدت بقتلك الأسود والأبيض مِن بين هاشم. فهَمَّ به علي بن أبي طالب، فقال رسول الله ﷺ: «يا علي، أما علمت أنّ الحليم كاد أن يكون نبيًّا». فقال النبي ﷺ: «يا أعرابي، بئس ما جئتنا به، وسوء ما تستقبلني به، واللهِ، إني لَمحمود في الأرض، أمين في السماء عند الله». فقال الأعرابي -ورمى الضبَّ في حِجر رسول الله ﷺ-، وقال: واللهِ، لا أؤمن بك حتى يؤمن بك هذا الضب. فأخذ رسول الله ﷺ بذَنَبه، ثم قال: «يا ضب». قال: لبيك، يا زين مَن وافى يوم القيامة. قال: «من تعبد؟». قال: أعبد اللهَ الذي في السماء عرشه، وفي الأرض سلطانه، وفي البحر سبيله، وفي الجنة ثوابه، وفي النار عذابه. قال: «مَن أنا؟». قال: أنت محمد بن عبد الله بن عبد المطلب بن هاشم بن عبد مناف بن قصي بن كلاب -حتى نسبه إلى إبراهيم الخليل ﵇، أنت رسول الله، لا يحرم مَن صدَّقك، وخاب مَن كذَّبك. فولى الأعرابيُّ وهو يضحك، فقال رسول الله ﷺ: «أبالله وآياته تستهزئ؟!». فرجع إليه، فقال: بأبي وأمي، ليس الخبر كالمعاينة، أنا أشهد بلحمي ودمي وعظامي أن لا إله إلا الله وأنك رسول الله. فقال النبي ﷺ: «جئتَنا كافرًا، وترجع مؤمنًا، هل لك مِن مال؟». قال: والذي بعثك بالحق رسولًا، ما في بني سُليم أفقر مِنِّي، ولا أقلَّ شيئًا مني. فقام رسولُ الله ﷺ، فقال: «مَن عنده راحلة يحمل أخاه عليها؟». فقام عديُّ بن حاتم الطائي، فقال: يا رسول، الله عندي ناقة وبراء حمراء عشراء، إذا أقبلت دقَّت، وإذا أدبرت زفت، أهداها إلَيَّ أشعثُ بن وائل غداةَ قدمت معك مِن غزوة تبوك. فقال النبي ﷺ: «لك عندي ناقة مِن دُرَّة بيضاء»{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٦.أخرجه البخاري ٦/١٩-٢٠ (٤٤٨٢).أخرجه ابن عساكر في تاريخه ٤/٣٨١. قال ابن عساكر: «هذا حديث غريب، وفيه مَن يُجهل حالُه، وإسناده غير متصل».
36,80," <q>﴿ٱلَّذِی جَعَلَ لَكُم مِّنَ ٱلشَّجَرِ ٱلۡأَخۡضَرِ نَارࣰا فَإِذَاۤ أَنتُم مِّنۡهُ تُوقِدُونَ ۝٨٠﴾</q> - تفسير ٦٥٠٢٠- قال عبد الله بن عباس: <q>﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا﴾</q> هما شجرتان، يُقال لأحدهما: المرَخ، وللأخرى: العفار، فمَن أراد منهم النار قطع منهما غصنين مثل السواكين وهما خضراوان يقطر منهما الماء، فيسحَق المرَخ على العفار، فيخرج منها النار -بإذن الله ﷿{1}. (ز) ٦٥٠٢١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا﴾</q>، يقول: الذي أخرج هذه النار مِن هذا الشجر قادِرٌ أن يبعثه{2}. (١٢/٣٨١) ٦٥٠٢٢- قال مقاتل بن سليمان: <q>﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا فَإذا أنْتُمْ مِنهُ تُوقِدُونَ﴾</q>، فالذي يخرج مِن الشجر الأخضر النارَ فهو قادِرٌ على البعث{3}. (ز) ٦٥٠٢٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الأَخْضَرِ نارًا فَإذا أنْتُمْ مِنهُ تُوقِدُونَ﴾</q> كل عود يزند منه النار فهو مِن شجرة خضراء{4}. (ز) ",footnotes:1:تفسير الثعلبي ٨/١٣٧، وتفسير البغوي ٦/٢٩.أخرجه ابن جرير ١٩/٤٨٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٦.تفسير يحيى بن سلام ٢/٨٢١.
36,81," <q>﴿أَوَلَیۡسَ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ بِقَـٰدِرٍ عَلَىٰۤ أَن یَخۡلُقَ مِثۡلَهُمۚ بَلَىٰ وَهُوَ ٱلۡخَلَّـٰقُ ٱلۡعَلِیمُ ۝٨١ إِنَّمَاۤ أَمۡرُهُۥۤ إِذَاۤ أَرَادَ شَیۡـًٔا أَن یَقُولَ لَهُۥ كُن فَیَكُونُ ۝٨٢﴾</q> - قراءات ٦٥٠٢٤- عن النضر، عن هارون، قال أهل مكة: ‹إنَّمَآ أمْرُهُ إذَآ أرادَ شَيْئًا أنْ يَقُولَ لَهُ كُن فَيَكُونَ› نصب، قال النضر: وأهل البصرة يقرءون: <q>﴿فَيَكُونُ﴾</q>{1}. (ز) <q>﴿أَوَلَیۡسَ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ بِقَـٰدِرٍ عَلَىٰۤ أَن یَخۡلُقَ مِثۡلَهُمۚ بَلَىٰ وَهُوَ ٱلۡخَلَّـٰقُ ٱلۡعَلِیمُ ۝٨١ إِنَّمَاۤ أَمۡرُهُۥۤ إِذَاۤ أَرَادَ شَیۡـًٔا أَن یَقُولَ لَهُۥ كُن فَیَكُونُ ۝٨٢﴾</q> - تفسير الآية ٦٥٠٢٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أوَلَيْسَ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ بِقادِرٍ﴾</q> الآية، قال: هذا مِثْلُ قوله: <q>﴿إنما إنَّما أمْرُهُ إذا أرادَ شَيْئًا أنْ يَقُولَ لَهُ كُنْ فَيَكُونُ﴾</q>. قال: ليس من كلام العرب أهون ولا أخف من ذلك، فأمْر الله كذلك{2}. (١٢/٣٨١) ٦٥٠٢٦- عن إسماعيل السُدِّيّ: <q>﴿أوَلَيْسَ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ بِقادِرٍ عَلى أنْ يَخْلُقَ مِثْلَهُمْ﴾</q> في الآخرة{3}. (ز) ٦٥٠٢٧- قال مقاتل بن سليمان: ثم ذكر ما هو أعظم خَلْقًا مِن خَلْق الإنسان، فقال -جلَّ وعزَّ-: <q>﴿أوَلَيْسَ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ﴾</q> هذا أعظم خلقًا مِن خلق الإنسان <q>﴿بِقادِرٍ عَلى أنْ يَخْلُقَ﴾</q> في الأرض <q>﴿مِثْلَهُمْ﴾</q> مثل خلْقهم في الدنيا. ثم قال لنفسه تعالى: <q>﴿بَلى﴾</q> قادِرٌ على ذلك، <q>﴿وهُوَ الخَلّاقُ العليم﴾</q> بخلْقهم، في الآخرة العليم ببعْثهم، <q>﴿إنَّما أمْرُهُ إذا أرادَ شَيْئًا﴾</q> أمر البعْث وغيره <q>﴿أنْ يَقُولَ لَهُ﴾</q> مرة واحدة <q>﴿كُنْ فَيَكُونُ﴾</q> لا يثني قوله{4}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص١٩٦. و‹فَيَكُونَ› قراءة متواترة، قرأ بها ابن عامر، والكسائي، وقرأ بقية العشرة: <q>﴿فَيَكُونُ﴾</q> بالرفع. انظر: النشر ٢/٢٢٠، والإتحاف ص٤٧٠.أخرجه ابن جرير ١٩/٤٩٠-٤٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٨٢١.تفسير مقاتل بن سليمان ٣/٥٨٦-٥٨٧.
  36,82,""
36,83," <q>﴿فَسُبۡحَـٰنَ ٱلَّذِی بِیَدِهِۦ مَلَكُوتُ كُلِّ شَیۡءࣲ وَإِلَیۡهِ تُرۡجَعُونَ ۝٨٣﴾</q> - تفسير ٦٥٠٢٨- قال مقاتل بن سليمان: ثم عظّم نفسه عن قولهم، فقال ﷿: <q>﴿فَسُبْحانَ الَّذِي بِيَدِهِ مَلَكُوتُ﴾</q> خلْق <q>﴿كل شيء﴾</q> مِن البعث وغيره، <q>﴿وإلَيْهِ تُرْجَعُونَ﴾</q> إلى الله ﷿ بعد الموت لتكذيبهم{1}. (ز) ٦٥٠٢٩- قال يحيى بن سلّام: <q>﴿فَسُبْحانَ﴾</q> يُنَزِّه نفسه عما قال المشركون <q>﴿الَّذِي بِيَدِهِ مَلَكُوتُ كُلِّ شَيْءٍ وإلَيْهِ تُرْجَعُونَ﴾</q> يوم القيامة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٧.تفسير يحيى بن سلام ٢/٨٢١.
