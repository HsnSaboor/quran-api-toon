tafsir[42]{c,v,t}:
80,1," مقدمة السورة ٨١٤١٧- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة عبس بمكة{1}. (١٥/٢٣٩) ٨١٤١٨- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٢٣٩) ٨١٤١٩- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمى <q>﴿عَبَسَ وتَوَلّى﴾</q>، وأنها نزلت بعد <q>﴿والنَّجْمِ إذا هَوى﴾</q>{3}. (ز) ٨١٤٢٠- عن عكرمة مولى ابن عباس= (ز) ٨١٤٢١- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز) ٨١٤٢٢- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٨١٤٢٣- عن محمد بن مسلم الزّهري: مكّيّة، ونزلت بعد <q>﴿والنَّجْمِ﴾</q>{6}. (ز) ٨١٤٢٤- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٨١٤٢٥- قال مقاتل بن سليمان: سورة الأعمى مكّيّة، عددها أربعون آية كوفي{8}. (ز) ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٨٧.
80,2," <q>﴿عَبَسَ وَتَوَلَّىٰۤ ۝١ أَن جَاۤءَهُ ٱلۡأَعۡمَىٰ ۝٢﴾</q> - نزول الآيات ٨١٤٢٦- عن عائشة، قالت: كان رسول الله ﷺ في مجلس في ناسٍ مِن وجوه قريش، منهم: أبو جهل بن هشام، وعُتبة بن ربيعة، فيقول لهم: «أليس حسنًا أن جئتُ بكذا وكذا؟». فيقولون: بلى، واللهِ. فجاء ابنُ أُمّ مكتوم وهو مشتغل بهم، فسأله، فأعرض عنه؛ فأنزل الله: <q>﴿أمّا مَنِ اسْتَغْنى فَأَنْتَ لَهُ تَصَدّى وما عَلَيْكَ ألّا يَزَّكّى وأَمّا مَن جاءَكَ يَسْعى وهُوَ يَخْشى فَأَنْتَ عَنْهُ تَلَهّى﴾</q> يعني: ابن أُمّ مكتوم{1}. (١٥/٢٤٠) ٨١٤٢٧- عن عائشة -من طريق عروة- قالت: أُنزِلَتْ <q>﴿عَبَسَ وتَوَلّى﴾</q> في ابن أُمّ مكتوم الأعمى؛ أتى رسولَ الله ﷺ، فجعل يقول: يا رسول الله، أرْشِدني. وعند رسول الله ﷺ رجل مِن عظماء المشركين، فجعل رسول الله ﷺ يُعرِض عنه، ويُقبل على الآخر، ويقول: «أترى بما أقول بأسًا؟». فيقول: لا. ففي هذا أُنزِلَتْ{2}. (١٥/٢٤٠) ٨١٤٢٨- عن مسروق، قال: دخلتُ على عائشة وعندها رجل مكفوف تَقطع له الأُترُجّ، وتُطعمه إياه بالعسل، فقلتُ: مَن هذا، يا أُمّ المؤمنين؟! فقالت: هذا ابنُ أُمِّ مكتوم الذي عاتب الله فيه نبيَّه ﷺ. قالت: أتى نبيَّ الله، وعنده عُتبة وشيبة، فأقبل رسول الله ﷺ عليهما؛ فنزلت: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q> ابن أُمّ مكتوم{3}. (١٥/٢٤٣) ٨١٤٢٩- عن عبد الله بن عباس –من طريق العَوفيّ- قال: بينا رسول الله ﷺ يناجي عُتبة بن ربيعة، والعباس بن عبد المطلب، وأبا جهل بن هشام، وكان يتصدّى لهم كثيرًا، وجعل عليهم أن يؤمنوا، فأقبل إليه رجل أعمى يُقال له: عبد الله بن أُمّ مكتوم، يمشي وهو يناجيهم، فجعل عبد الله يستقرئ النبيَّ ﷺ آيةً مِن القرآن، قال: يا رسول الله، علِّمني مِمّا علمك الله. فأعرَض عنه رسول الله ﷺ، وعَبس في وجهه، وتولّى وكَره كلامه، وأقبل على الآخرين، فلما قضى رسول الله ﷺ نجواه، وأخذ ينقلب إلى أهله، أمسك الله ببعض بصره، ثم خفق برأسه، ثم أنزل الله: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>، فلما نزل فيه ما نزل، أكرمه نبي الله وكلّمه؛ يقول له: «ما حاجتك؟ هل تريد من شيء؟»{4}. (١٥/٢٤١) ٨١٤٣٠- عن أنس بن مالك، قال: جاء ابنُ أُمِّ مكتوم إلى النبيِّ ﷺ وهو يُكَلِّم أُبيَّ بن خلف، فأعرَض عنه؛ فأنزل الله: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>، فكان النبي ﷺ بعد ذلك يُكرمه{5}. (١٥/٢٤١) ٨١٤٣١- عن عروة بن الزُّبير -من طريق ابنه هشام- قال: نزلت في ابن أُمّ مكتوم: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>{6}. (ز) ٨١٤٣٢- عن مجاهد بن جبر، قال: كان النبيُّ ﷺ مُستخليًا بصِنديدٍ مِن صناديد قريش وهو يدعوه إلى الله، وهو يرجو أن يُسلم، إذ أقبل عبد الله بن أُمّ مكتوم الأعمى، فلما رآه النبي ﷺ كره مجيئه، وقال في نفسه: «يقول هذا القرشي: إنما أتباعه العميان، والسِّفلة، والعبيد». فعَبس؛ فنزل الوحي: <q>﴿عَبَسَ وتَوَلّى﴾</q> إلى آخر الآية{7}. (١٥/٢٤٤) ٨١٤٣٣- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿عَبَسَ وتَوَلّى﴾</q>، قال: هو رسول الله ﷺ، لقي رجلًا مِن أشراف قريش، فدعاه إلى الإسلام، فأتى عبدُ الله بن أُمّ مكتوم، فجعل يسأله عن أشياء مِن أمر الإسلام، فعَبس في وجهه؛ فعاتبه الله في ذلك، فلما نزلت هذه الآية دعا رسولُ الله ﷺ ابنَ أُمّ مكتوم، فأكرمه، واستخلفه على المدينة مرتين{8}. (١٥/٢٤٣) ٨١٤٣٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿عَبَسَ وتَوَلّى﴾</q>: تصدّى رسول الله ﷺ لرجل مِن مشركي قريش كثير المال، ورجا أن يؤمن، وجاء رجل من الأنصار أعمى، يقال له: عبد الله بن أُمّ مكتوم، فجعل يسأل نبي الله ﷺ، فكرهه نبي الله ﷺ، وتولى عنه، وأقبل على الغني، فوعظ اللهُ نبيَّه، فأكرمه نبيُّ الله ﷺ، واستخلفه على المدينة مرتين في غزوتين غزاهما{9}. (ز) ٨١٤٣٥- عن قتادة بن دعامة -من طريق معمر- قال: جاء ابنُ أُمّ مكتوم إلى النبي ﷺ وهو يُكلّم أُبيّ بن خلف، فأعرَض عنه؛ فأنزل الله عليه: <q>﴿عَبَسَ وتَوَلّى﴾</q>، فكان النبيُّ ﷺ بعد ذلك يُكرمه. قال أنس: فرأيتُه يوم القادسية عليه درع، ومعه راية سوداء{10}. (ز) ٨١٤٣٦- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q> عبد الله بن زائدة، وهو ابن أُمّ مكتوم، وجاءه يستقرئه، وهو يناجي أُمَيّة بن خلف، رجل من عِلية قريش، فأعرَض عنه نبيُّ الله ﷺ؛ فأنزل الله فيه ما تسمعون: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q> إلى قوله: <q>﴿فَأَنْتَ عَنْهُ تَلَهّى﴾</q>. ذُكر لنا: أنّ نبي الله ﷺ استخلفه بعد ذلك مرتين على المدينة، في غزوتين غزاهما يُصلّي بأهلها{11}. (ز) ٨١٤٣٧- عن محمد بن قيس -من طريق أبي مَعشر- قال: كان رسول الله ﷺ جالسًا وعنده عُتبة بن ربيعة، وابن أُمّ مكتوم الأعمى، فقال: يا رسول الله، علِّمني القرآن. فعَبس رسول الله ﷺ في وجهه، وصرفه عنه كراهته أن يزهد إقباله عليه عُتبة في الإسلام، يقول: إنما يتبع هذا العميان والمساكين. فأنزل الله تعالى: <q>﴿عبس وتولى﴾</q> إلى قوله: <q>﴿فأنت له تصدى﴾</q> عُتبة، <q>﴿وأما من جاءك يسعى، وهو يخشى﴾</q> ابن أُمّ مكتوم، فلم يُعذر رسول الله ﷺ بمثل ذلك{12}. (ز) ٨١٤٣٨- قال مقاتل بن سليمان: يقول <q>﴿عَبَسَ﴾</q> ... نزلت في عبد الله بن أبى سَرح{13} الأعمى، وأُمّه أُمّ مكتوم، اسمه: عمرو بن قيس بن زائدة بن رواحة بن الأصم بن حجر بن عبد ود بن بغيض بن عامر بن لؤي بن غالب. وأما أُمّ مكتوم اسمها: عاتكة بنت عامر بن عتكة بن عامر بن مخزوم بن يقظة بن مُرّة بن كعب بن لؤي، وذلك أنه ذات يوم كان جالسًا في المسجد الحرام وحده ليس معه ثانٍ، وكان رجلًا مكفوف البصر، إذ نزل مَلكان من السماء ليُصلّيا في المسجد الحرام، فقالا: مَن هذا الأعمى الذي لا يُبصر في الدنيا ولا في الآخرة؟ قال أحدهما: ولكن أعجبُ مِن أبي طالب يدعو الناس إلى الإسلام! وهو لا يبصرهما، ويسمع ذلك، فقام عبد الله حتى أتى رسول الله ﷺ، وإذا معه أُميّة بن خلف، والعباس بن عبد المطلب، وهما قيام بين يديه يَعرض عليهما الإسلام، فقال عبد الله: يا محمد، قد جئتك تائبًا، فهل لي مِن توبة؟ فأعرَض النبيُّ ﷺ وجهه عنه، وأقبل بوجهه إلى العباس وأُميّة بن خلف، فكَرّر عبد الله كلامه، فأعرَض النبيُّ ﷺ بوجهه وكَلح، فاستحيى عبد الله، وظن أنه ليس له توبة، فرجع إلى منزله؛ فأنزل الله ﷿ فيه: <q>﴿عَبَسَ وتَوَلّى﴾</q> يعني: كَلح النبي ﷺ، <q>﴿وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>{14}. (ز) ٨١٤٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- أنه سأله عن قول الله ﷿: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>. قال: جاء ابن أُمّ مكتوم إلى رسول الله، وقائده يُبصر وهو لا يُبصر. قال: ورسول الله ﷺ يشير إلى قائده يَكُفّ، وابن أُمّ مكتوم يدفعه ولا يُبصر. قال: حتى عَبس رسول الله ﷺ؛ فعاتبه الله في ذلك، فقال: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى وما يُدْرِيكَ لَعَلَّهُ يَزَّكّى﴾</q> إلى قوله: <q>﴿فَأَنْتَ عَنْهُ تَلَهّى﴾</q>{9}. (ز) <q>﴿عَبَسَ وَتَوَلَّىٰۤ ۝١ أَن جَاۤءَهُ ٱلۡأَعۡمَىٰ ۝٢﴾</q> - تفسير الآية ٨١٤٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أنْ جاءَهُ الأَعْمى﴾</q>، قال: رجلٌ مِن بني فهر، اسمه عبد الله بن أُمّ مكتوم{16}. (١٥/٢٤٣) ٨١٤٤١- قال مقاتل بن سليمان: يقول <q>﴿عَبَسَ﴾</q> بوجهه، وأعرَض إلى غيره ... <q>﴿عَبَسَ﴾</q> يعني: كَلح النبيُّ ﷺ، <q>﴿وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>{14}. (ز) <q>﴿عَبَسَ وَتَوَلَّىٰۤ ۝١ أَن جَاۤءَهُ ٱلۡأَعۡمَىٰ ۝٢﴾</q> - آثار متعلقة بالآية ٨١٤٤٢- عن أبي أُمامة، قال: أقبل ابن أُمّ مكتوم الأعمى، وهو الذي نزل فيه: <q>﴿عَبَسَ وتَوَلّى أنْ جاءَهُ الأَعْمى﴾</q>. فقال: يا رسول الله، أنا كما ترى قد كَبِرتْ سِنّي، ورقّ عظمي، وذهب بصري، ولي قائد لا يلائمني قياده إياي؛ فهل تجد لي من رخصة أُصلّي الصلوات في بيتي. قال: «هل تسمع المؤذن؟». قال: نعم. قال: «ما أجد لك مِن رخصة»{18}. (١٥/٢٤٢) ٨١٤٤٣- عن كعب بن عُجرة: إنّ الأعمى الذي أنزل الله فيه: <q>﴿عَبَسَ وتَوَلّى﴾</q> أتى النبيَّ ﷺ، فقال: يا رسول الله، إني أسمع النداء، ولعلّي لا أجد قائدًا. فقال: «إذا سمعتَ النداء فأجب داعي الله»{19}. (١٥/٢٤٣) ٨١٤٤٤- عن الحكم بن عُتيبة، قال: ما رُئِي رسولُ الله ﷺ بعد هذه الآية متصديًّا لِغنيٍّ، ولا مُعرِضًا عن فقير{20}. (١٥/٢٤٢) ٨١٤٤٥- عن عبد الرحمن بن زيد بن أسلم، قال: لو أنّ رسول الله ﷺ كتم شيئًا مِن الوحي كتم هذا عن نفسه{20}. (١٥/٢٤٢) ",footnotes:1:أخرجه المخلص في المخلصيات ٢/١٦٧ (١٢٨٧)، وابن عساكر في معجمه ٢/٦٨٥-٦٨٦ (٨٥٠)، من طريق أبي معاوية الضرير، عن هشام بن عروة، عن أبيه، عن عائشة به. قال ابن عساكر: «حديث حسن صحيح». ورجح الدارقطني في العلل ١٤/١٧٥ أنه من مرسل عروة، ولا يصح مُسندًا عن عائشة.أخرجه الترمذي ٥/٥٢٤ (٣٦٢١)، وابن حبان ٢/٢٩٣-٢٩٤ (٥٣٥)، والحاكم ٢/٥٥٨ (٣٨٩٦)، وابن جرير ٢٤/١٠٢-١٠٣، من طريق هشام بن عروة، عن أبيه، عن عائشة به. قال الترمذي: «حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. ورجح الدارقطني في العلل ١٤/١٧٥ أنه من مرسل عروة، ولا يصح مُسندًا عن عائشة.أخرجه الطبراني في الأوسط ٩/١٥٥ (٩٤٠٤)، والبيهقي في الشعب ١٠/٤٧٧ (٧٨٢٩)، من طريق إسحاق بن موسى، عن أحمد بن بشير، عن أبي البلاد، عن مسلم بن صبيح، عن مسروق، عن عائشة به. وسنده حسن.أخرجه ابن جرير ٢٤/١٠٣، وابن مردويه -كما في تخريج الكشاف ٤/١٥٥-١٥٦- كلاهما بنحوه، من طريق محمد بن سعد، عن أبيه، عن عمه، عن أبيه، عن أبيه، عن ابن عباس به. الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة. وقال ابن كثير في تفسيره ٨/٣٢٠: «فيه غرابة ونكارة، وقد تُكلّم في إسناده».أخرجه أبو يعلى في مسنده ٥/٤٣١ (٣١٢٣)، من طريق محمد بن مهدي، عن عبد الرزاق، عن معمر، عن قتادة، عن أنس به. وسنده صحيح.أخرجه ابن جرير ٢٤/١٠٣-١٠٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن سعد ٤/٢٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٠٥.أخرجه عبد الرزاق ٢/٣٤٨ دون قول أنس، وابن جرير ٢٤/١٠٤.أخرجه ابن جرير ٢٤/١٠٤.أخرجه ابن إسحاق في سيرته ص٢١٤.كذا في المصدر! وعبد الله بن سعد بن أبي سرح العامري غير عبد الله بن أم مكتوم العامري. كما في الإصابة في تمييز الصجابة للحافظ ابن حجر.تفسير مقاتل بن سليمان ٤/٥٨٩-٥٩٠.أخرجه ابن جرير ٢٤/١٠٥.تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١٠٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٨٩-٥٩٠.أخرجه الطبراني في الكبير ٨/٢٢٤ (٧٨٨٦) مطولًا، من طريق علي بن يزيد، عن القاسم، عن أبي أمامة به. قال الهيثمي في المجمع ٢/٤٣ (٢١٦٧): «فيه علي بن يزيد الألهاني عن القاسم، وقد ضعّفهما الجمهور، واختُلف في الاحتجاج بهما».أخرجه الطبراني في الكبير ١٩/١٣٨ (٣٠٤)، والدارقطني ٢/٤٦٢ (١٨٨٠)، من طريق سليمان بن أبي داود الحراني، عن عبد الكريم الجزري، عن زياد بن أبي مريم، عن عبد الله بن معقل، عن كعب بن عُجرة به. وأخرجه الطبراني في الكبير ١٩/١٣٩ (٣٠٥)، من طريق يزيد بن محمد بن سنان الرهاوي، عن أبيه، عن أبيه، عن زيد بن أبي أنيسة، عن عدي بن ثابت، عن عبد الله بن معقل، عن كعب بن عجرة به. قال ابن أبي حاتم في العلل ٢/٣٧٥ (٤٤٩): «قال أبي: هذا حديث منكر». وقال الهيثمي في المجمع ٢/٤٢ (٢١٦٦): «فيه يزيد بن سنان؛ ضعّفه أحمد، وجماعة. وقال أبو حاتم: محله الصدق. وقال البخاري: مقارب الحديث». وقال الألباني في الصحيحة ٣/٣٣٩-٣٤٠ (١٣٥٤): «الحديث صحيح على كل حال؛ فإن له شواهد عديدة من حديث أبي هريرة عند مسلم وأبي عوانة وغيرهما». وأصل الحديث في صحيح مسلم ٢٥٥ - (٦٥٣) دون تعيين اسم الأعمى.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.
80,3," <q>﴿وَمَا یُدۡرِیكَ لَعَلَّهُۥ یَزَّكَّىٰۤ ۝٣ أَوۡ یَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكۡرَىٰۤ ۝٤﴾</q> - تفسير ٨١٤٤٦- قال إسماعيل السُّدِّيّ: <q>﴿وما يُدْرِيكَ لَعَلَّهُ يَزَّكّى أوْ يَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرى﴾</q>، المعنى: لعله يزكى ويذَّكَّر{1}. (ز) ٨١٤٤٧- قال مقاتل بن سليمان: ثم قال: <q>﴿وما يُدْرِيكَ﴾</q> يا محمد <q>﴿لَعَلَّهُ يَزَّكّى﴾</q> أي: لعلّه أن يؤمن؛ فيُصلّي، فيتذكر في القرآن بما قد أفسد، <q>﴿أوْ يَذَّكَّرُ﴾</q> في القرآن، <q>﴿فَتَنْفَعَهُ الذِّكْرى﴾</q> يعني: الموعظة. يقول: أن تَعرض عليه الإسلام، فيؤمن، فتنفعه تلك الذكرى{2}. (ز) ٨١٤٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿لَعَلَّهُ يَزَّكّى﴾</q>: يسلم{3}٧٠٣٣. (ز) ٧٠٣٣ قال ابنُ جرير (٢٤/١٠٥): «وقوله: <q>﴿وما يُدْرِيكَ لَعَلَّهُ يَزَّكّى﴾</q> يقول -تعالى ذِكره- لنبيّه محمد ﷺ: وما يدريك -يا محمد- لعل هذا الأعمى الذي عَبستْ في وجهه يزكى، يقول: يتطهر من ذنوبه». ثم ذكر قول ابن زيد، ولم يعلق عليه. ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٤-.تفسير مقاتل بن سليمان ٤/٥٩٠.أخرجه ابن جرير ٢٤/١٠٦.
  80,4,""
80,5," <q>﴿أَمَّا مَنِ ٱسۡتَغۡنَىٰ ۝٥ فَأَنتَ لَهُۥ تَصَدَّىٰ ۝٦﴾</q> - نزول الآية، وتفسيرها ٨١٤٤٩- قال عبد الله بن عباس: <q>﴿أمّا مَنِ اسْتَغْنى﴾</q> عن الله، وعن الإيمان، بما له مِن المال{1}. (ز) ٨١٤٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أمّا مَنِ اسْتَغْنى﴾</q>، قال: عُتبة بن ربيعة، وشيبة بن ربيعة، وأُميّة بن خلف{2}. (١٥/٢٤٣) ٨١٤٥١- عن أبي مالك غَزْوان الغفاري، في قوله: <q>﴿عَبَسَ وتَوَلّى﴾</q>، قال: جاءه عبد الله بن أُمّ مكتوم، فعَبس في وجهه وتولّى، وكان يتصدّى لأُميّة بن خلف؛ فقال الله: <q>﴿أمّا مَنِ اسْتَغْنى فَأَنْتَ لَهُ تَصَدّى﴾</q>{3}. (١٥/٢٤٢) ٨١٤٥٢- قال مقاتل بن سليمان: فـ<q>﴿أمّا مَنِ اسْتَغْنى﴾</q> عن الله في نفسه، يعني: أُميّة بن خلف، <q>﴿فَأَنْتَ لَهُ تَصَدّى﴾</q> يعني: تدعو، وتُقبل بوجهك{4}. (ز) ٨١٤٥٣- عن سفيان [الثوري] -من طريق مهران- <q>﴿أمّا مَنِ اسْتَغْنى﴾</q>، قال: نزلت في العباس{5}. (ز) ",footnotes:1:تفسير البغوي ٨/٣٣٦.تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٩٢- مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٠.أخرجه ابن جرير ٢٤/١٠٧.
  80,6,""
80,7," <q>﴿وَمَا عَلَیۡكَ أَلَّا یَزَّكَّىٰ ۝٧﴾</q> - تفسير ٨١٤٥٤- قال مقاتل بن سليمان: <q>﴿وما عَلَيْكَ ألّا يَزَّكّى﴾</q> يقول: وما عليك ألا يؤمن ولا يصلح ما قد أفسد هؤلاء النّفر{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٠.
80,8," <q>﴿وَأَمَّا مَن جَاۤءَكَ یَسۡعَىٰ ۝٨﴾</q> - تفسير ٨١٤٥٥- قال مقاتل بن سليمان: <q>﴿وأَمّا مَن جاءَكَ يَسْعى﴾</q> في الحَرّ{1}. (ز) ٨١٤٥٦- قال مالك بن أنس: وإنما السعيُ في كتاب الله العمل والفعل، <q>﴿فَإذا قُضِيَتِ الصَّلاةُ فانْتَشِرُوا فِي الأَرْضِ وابْتَغُوا مِن فَضْلِ اللَّهِ واذْكُرُوا اللَّهَ كَثِيرًا لَعَلَّكُمْ تُفْلِحُونَ﴾</q> [الجمعة:١٠]، يقول الله -تبارك وتعالى-: <q>﴿وإذا تَوَلّى سَعى فِي الأَرْضِ﴾</q> [البقرة:٢٠٥]، وقال تعالى: <q>﴿وأَمّا مَن جاءَكَ يَسْعى وهُوَ يَخْشى﴾</q>، وقال: <q>﴿ثُمَّ أدْبَرَ يَسْعى﴾</q> [النازعات:٢٢]، وقال: <q>﴿إنَّ سَعْيَكُمْ لَشَتّى﴾</q> [الليل:٤]. قال مالك: فليس السعي الذي ذكر الله في كتابه بالسعي على الأقدام، ولا الاشتداد، وإنما عنى: العمل والفعل{2}٧٠٣٤. (ز) ٧٠٣٤ ذكر ابنُ عطية (٨/٥٣٧) أنّ معنى: <q>﴿يسعى﴾</q> في الآية «أي: يمشي، وقيل المعنى: يَسْعى في شؤونه وأمر دينه وتقرّبه منك، وهو يَخْشى الله تعالى». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٠.موطأ مالك (ت: د. بشار عواد) ١/١٦٣ (٢٨٦).
80,9," <q>﴿وَهُوَ یَخۡشَىٰ ۝٩﴾</q> - تفسير ٨١٤٥٧- قال مقاتل بن سليمان: <q>﴿وهُوَ يَخْشى﴾</q> الله، يعني: ابن أُمّ مكتوم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٠.
80,10," <q>﴿فَأَنتَ عَنۡهُ تَلَهَّىٰ ۝١٠﴾</q> - تفسير ٨١٤٥٨- قال مقاتل بن سليمان: <q>﴿فَأَنْتَ عَنْهُ﴾</q> يا محمد <q>﴿تَلَهّى﴾</q> يعني: تُعرض بوجهك عنه. ثم وعظ الله ﷿ النبي ﷺ أن لا يُقبل على مَن استغنى عنه، فقال: لا تُقبل عليه، ولا تُعرض عن مَن جاءك يسعى، ولا تُقبل على مَن استغنى، وتُعرض عن من يخشى ربه، فلما نزلت هذه الآية في ابن أُمّ مكتوم، أكرمه النبيُّ ﷺ، واستخلفه بعد ذلك على المدينة مرتين في غزواته{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٠.
80,11," <q>﴿كَلَّاۤ إِنَّهَا تَذۡكِرَةࣱ ۝١١ فَمَن شَاۤءَ ذَكَرَهُۥ ۝١٢﴾</q> - تفسير ٨١٤٥٩- قال مقاتل بن سليمان: ثم انقطع الكلام، ثم استأنف، فقال: <q>﴿كَلّا إنَّها تَذْكِرَةٌ﴾</q> يعني: آيات القرآن، <q>﴿فَمَن شاءَ ذَكَرَهُ﴾</q> يعني الرّبّ تعالى: نفسه، يقول: مَن شاء الله تعالى فهّمه، يعني: القرآن، يقول: مَن شاء ذَكر أن يفوض الأمر إلى عباده{1}٧٠٣٥. (ز) ٧٠٣٥ ذكر ابنُ عطية (٨/٥٣٨) اختلافًا في عود الضمير في قوله: <q>﴿إنها تذكرة﴾</q> الأول: إنّ هذه السورة. الثاني: إنّ هذه المعتبة تذكرة لك، يا محمد. الثالث: آيات القرآن. كما في قول مقاتل. ثم علّق على القول الثاني: «ففي هذا التأويل إجلال لمحمد ﷺ، وتأنيس له». وذكر أنّ تعلق قوله تعالى: <q>﴿في صحف﴾</q> بقوله: <q>﴿تذكرة﴾</q> يؤيد أنّ التذكرة يراد بها جميع القرآن. ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩١.
  80,12,""
80,13," <q>﴿فِی صُحُفࣲ مُّكَرَّمَةࣲ ۝١٣ مَّرۡفُوعَةࣲ مُّطَهَّرَةِۭ ۝١٤﴾</q> - تفسير ٨١٤٦٠- عن قتادة بن دعامة، <q>﴿فِي صُحُفٍ مُكَرَّمَةٍ مَرْفُوعَةٍ مُطَهَّرَةٍ﴾</q>، قال: هي عند الله{1}. (١٥/٢٤٤) ٨١٤٦١- قال مقاتل بن سليمان: ثم قال: إنّ هذا القرآن <q>﴿فِي صُحُفٍ مُكَرَّمَةٍ﴾</q> يعني: في كتب مُكرّمة، <q>﴿مَرْفُوعَةٍ﴾</q> يعني به: اللوح المحفوظ، مرفوعة فوق السماء الرابعة، نظيرها في الواقعة{2}، عند الله <q>﴿مُطَهَّرَةٍ﴾</q> مِن الشرك والكفر{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.يشير إلى قوله تعالى: <q>﴿إنَّهُ لَقُرْآنٌ كَرِيمٌ (٧٧) فِي كِتابٍ مَكْنُونٍ (٧٨) لا يَمَسُّهُ إلّا المُطَهَّرُونَ﴾</q> [الواقعة:٧٧-٧٩].تفسير مقاتل بن سليمان ٤/٥٩١.
  80,14,""
80,15," <q>﴿بِأَیۡدِی سَفَرَةࣲ ۝١٥ كِرَامِۭ بَرَرَةࣲ ۝١٦﴾</q> - تفسير ٨١٤٦٢- عن عائشة، قالت: قال رسول الله ﷺ: «الذي يقرأ القرآن وهو ماهر به مع السَّفرة الكرام البررة، والذي يقرؤه وهو عليه شاقٌّ له أجران»{1}. (١٥/٢٤٥) ٨١٤٦٣- قال النبي ﷺ: «نزل القرآن في ليلة القدر جميعًا كله من اللوح المحفوظ إلى السّفرة من الملائكة في السماء الدنيا، ثم أخبر به جبريل ﷺ في عشرين شهرًا، ثم أخبر به جبريل النبي صلى الله عليهما وسلم في عشرين سنة»{2}. (ز) ٨١٤٦٤- عن عبد الله بن عباس، <q>﴿سَفَرَةٍ﴾</q>، قال: بالنَّبَطيّة: القُرّاء{3}. (١٥/٢٤٥) ٨١٤٦٥- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: <q>﴿كِرامٍ بَرَرَةٍ﴾</q>، قال: الملائكة{4}. (١٥/٢٤٥) ٨١٤٦٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بِأَيْدِي سَفَرَةٍ﴾</q>، قال: كَتَبة{5}. (١٥/٢٤٥) ٨١٤٦٧- عن عطاء بن أبي رباح، مثله{6}. (١٥/٢٤٥) ٨١٤٦٨- عن مجاهد بن جبر، قال: الكَتَبة: السَّفرة الملائكة{7}. (١٥/٢٤٤) ٨١٤٦٩- عن وهْب بن مُنَبِّه، <q>﴿بِأَيْدِي سَفَرَةٍ كِرامٍ بَرَرَةٍ﴾</q>، قال: هم أصحاب محمد ﷺ{8}. (١٥/٢٤٤) ٨١٤٧٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بِأَيْدِي سَفَرَةٍ﴾</q>، قال: هم القُرّاء{9}. (١٥/٢٤٤) ٨١٤٧١- عن قتادة بن دعامة -من طريق معمر- <q>﴿بِأَيْدِي سَفَرَةٍ﴾</q>، قال: كَتَبة{10}. (١٥/٢٤٤) ٨١٤٧٢- قال مقاتل بن سليمان: <q>﴿بِأَيْدِي سَفَرَةٍ﴾</q> يعني: تلك الصحف بأيدي كَتَبة كرام مسلمين، ثم أثنى على الملائكة الكَتَبة، فقال: <q>﴿كِرامٍ﴾</q> يعني: مسلمين، وهم الملائكة، <q>﴿بَرَرَةٍ﴾</q> يعني: مطيعين لله تعالى، أنقياء أبرار مِن الذنوب، وكان ينزل إليهم مِن اللوح المحفوظ إلى سماء الدنيا في ليلة القدر، إلى الكَتَبة مِن الملائكة، ثم ينزل به جبريل إلى النبي ﷺ، ثم انقطع الكلام{11}. (ز) ٨١٤٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿بِأَيْدِي سَفَرَةٍ﴾</q>، قال: السَّفرة: الذين يُحصون الأعمال{4}٧٠٣٦. (ز) ٧٠٣٦ اختُلف في قوله: <q>﴿بإيدي سفرة﴾</q> على أقوال: الأول: الكَتَبة. الثاني: القرّاء. الثالث: الملائكة. الرابع: أصحاب النبي ﷺ. ووجّه ابنُ عطية (٨/٥٣٨) القول الثالث، فقال: «قال ابن عباس ﵄: هم الملائكة؛ لأنهم كَتبة، يقال: سفرتُ أي: كتبتُ، ومنه السِّفْر». ووجّه القول الرابع، فقال: «وقال وهْب بن مُنَبّه: هم الصحابة؛ لأن بعضهم يسفر إلى بعض في الخير والتعليم والتعلم». وقد رجّح ابنُ جرير (٢٤/١٠٩) القول الثالث مستندًا إلى اللغة، فقال: "وأولى الأقوال في ذلك بالصواب قول مَن قال: هم الملائكة الذين يسفرون بين الله ورسله بالوحي. وسفير القوم: الذي يسعى بينهم بالصلح، يقال: سفرت بين القوم: إذا أصلحت بينهم، ومنه قول الشاعر: وما أدعُ السِّفارة بين قومي وما أمشي بغشٍّ إنْ مشيتُ". ثم بيّن احتمال الآية للوجهين الآخرين، فقال: «وإذا وجّه التأويل إلى ما قلنا احتمل الوجه الذي قاله القائلون: هم الكَتَبة. والذي قاله القائلون: هم القرّاء. لأنّ الملائكة هي التي تقرأ الكتب، وتسفر بين الله وبين رسله». وبنحو ترجيحه رجّح ابنُ عطية، وبيّن أنّ الصُّحف على هذا هي صحف عند الملائكة، أو هي اللوح، وذكر أنّ الصُّحف على القول الثاني هي المصاحف. ",footnotes:1:أخرجه البخاري ٦/١٦٦ (٤٩٣٧)، ومسلم ١/٥٤٩ (٧٩٨)، وأحمد ٤٠/٢٥٦-٢٥٧ (٢٤٢١١) واللفظ له، وسعيد بن منصور في التفسير من سننه ١/٧٠ (١٤).تفسير مقاتل بن سليمان ٤/٥٩٣.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١٠٩.أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٣٦٠-٣٦١-، وابن جرير ٢٤/١٠٨. وعزاه السيوطي إلى ابن المنذر.أخرجه الخطيب في تاريخه ٩/١٨٦-١٨٧.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٠٨-١٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٨، وابن جرير ٢٤/١٠٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٥٩١.أخرجه ابن جرير ٢٤/١٠٩.
  80,16,""
80,17," <q>﴿قُتِلَ ٱلۡإِنسَـٰنُ مَاۤ أَكۡفَرَهُۥ ۝١٧﴾</q> - نزول الآية ٨١٤٧٤- عن عكرمة مولى ابن عباس، في قوله: <q>﴿قُتِلَ الإنْسانُ ما أكْفَرَهُ﴾</q>، قال: نزلت في عُتبة بن أبي لهب؛ حين قال: كفرتُ بربّ النَّجم إذا هوى. فدعا عليه النبيُّ ﷺ؛ فأخذه الأسد بطريق الشام{1}. (١٥/٢٤٥) ٨١٤٧٥- قال مقاتل بن سليمان: فذلك قوله: <q>﴿قُتِلَ الإنْسانُ ما أكْفَرَهُ﴾</q>، نزلت هذه الآية في عُتبة بن أبي لهب بن عبد المُطّلب، وذلك أنه كان غضب على أبيه، فأتى محمدًا ﷺ، فآمن به، فلما رضي أبوه عنه، وصالحه، وجهّزه، وسرَّحه إلى الشام بالتجارات، قال: بلِّغوا محمدًا عن عُتبة أنه قد كفر بالنّجم. فلما سمع بذلك النبيُّ ﷺ، قال: «اللهم، سلِّط عليه كلبك يأكله». فنزل ليلًا في بعض الطريق، فجاء الأسد، فأكله{2}. (ز) <q>﴿قُتِلَ ٱلۡإِنسَـٰنُ مَاۤ أَكۡفَرَهُۥ ۝١٧﴾</q> - تفسير الآية ٨١٤٧٦- عن مجاهد بن جبر -من طريق الأعمش- قال: ما كان في القرآن <q>﴿قُتِلَ الإنْسانُ﴾</q> إنما عَنى به: الكافر{3}. (١٥/٢٤٦) ٨١٤٧٧- قال محمد بن السّائِب الكلبي: <q>﴿ما أكْفَرَهُ﴾</q> ما أشدّ كفرَه!{4}. (ز) ٨١٤٧٨- قال مقاتل بن سليمان: ... فذلك قوله: <q>﴿قُتِلَ الإنْسانُ﴾</q> يعني: لُعن الإنسان <q>﴿ما أكْفَرَهُ﴾</q> يقول: ما الذي أكفره؟{2}٧٠٣٧. (ز) ٧٠٣٧ بيّن ابنُ عطية (٨/٥٣٩) أنّ معنى قوله: <q>﴿قتل﴾</q> أي: «هو أهل أن يُدعى عليه بهذا». ثم ذكر نحو قول مقاتل عن مجاهد، وانتقده، فقال: «وقال مجاهد: <q>﴿قُتِلَ﴾</q> بمعنى: لُعن. وهذا تحكُّم». ٨١٤٧٩- عن عبد الملك ابن جُرَيْج، <q>﴿ما أكْفَرَهُ﴾</q>، قال: ما أشدّ كفره!{1}. (١٥/٢٤٦) ٨١٤٨٠- عن سفيان [الثوري] -من طريق مهران- <q>﴿قُتِلَ الإنْسانُ ما أكْفَرَهُ﴾</q>: بلَغني: أنه الكافر{7}٧٠٣٨. (ز) ٧٠٣٨ ذكر ابنُ جرير (٢٤/١١٠) في قوله: <q>﴿ما أكفره﴾</q> وجهين، فقال: «وفي قوله: <q>﴿أكفره﴾</q> وجهان: أحدهما: التعجب من كفره مع إحسان الله إليه، وأياديه عنده. والآخر: ما الذي أكفره، أي: أي شيء أكفره». وبنحوه قال ابنُ عطية (٨/٥٣٩). ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩١.أخرجه ابن جرير ٢٤/١١٠. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٥-.تفسير مقاتل بن سليمان ٤/٥٩١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١١٠.
80,18," <q>﴿مِنۡ أَیِّ شَیۡءٍ خَلَقَهُۥ ۝١٨ مِن نُّطۡفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ ۝١٩﴾</q> - تفسير ٨١٤٨١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فَقَدَّرَهُ﴾</q>، قال: قدَّره في رَحِم أمه كيف شاء{1}. (١٥/٢٤٦) ٨١٤٨٢- قال محمد بن السّائِب الكلبي: <q>﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾</q> قدَّر خَلْقه: رأسه، وعينيه، ويديه، ورجليه{2}. (ز) ٨١٤٨٣- قال مقاتل بن سليمان: ثم قال وهو يعلم: <q>﴿مِن أيِّ شَيْءٍ خَلَقَهُ﴾</q>؟، فأعلمه كيف خَلَقه ليعتبر في خَلْقه، فقال: <q>﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾</q> في بطن أمه من نُطفة، ثم من عَلقة، ثم من مُضغة، ثم عظمًا، ثم روحًا، فقدّر هذا الخَلْق في بطن أمه، ثم أُخرج من بطن أمه{3}. (ز) ٨١٤٨٤- عن عبد الملك ابن جُرَيْج، <q>﴿فَقَدَّرَهُ﴾</q>، قال: نُطفة، ثم عَلقة، ثم مُضغة، ثم كذا، ثم كذا، ثم انتهى خَلْقه{4}. (١٥/٢٤٦) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/٣٣٧.تفسير مقاتل بن سليمان ٤/٥٩١-٥٩٢.عزاه السيوطي إلى ابن المنذر.
  80,19,""
80,20," <q>﴿ثُمَّ ٱلسَّبِیلَ یَسَّرَهُۥ ۝٢٠﴾</q> - تفسير ٨١٤٨٥- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>: يعني بذلك: خروجه مِن بطن أمه يسّره له{1}. (١٥/٢٤٦) ٨١٤٨٦- عن الضَّحّاك بن مُزاحِم، مثله{2}. (١٥/٢٤٧) ٨١٤٨٧- عن مجاهد بن جبر-من طريق ابن أبي نجيح- <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: هو كقوله: <q>﴿إنّا هَدَيْناهُ السَّبِيلَ إمّا شاكِرًا وإمّا كَفُورًا﴾</q> [الإنسان:٣] الشقاء والسعادة{3}. (١٥/٢٤٧) ٨١٤٨٨- عن عكرمة مولى ابن عباس، <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: خروجه من الرَّحِم{2}. (١٥/٢٤٦) ٨١٤٨٩- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: سبيل الخير{5}. (ز) ٨١٤٩٠- عن أبي صالح [باذام] -من طريق إسماعيل- <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: خروجه مِن الرَّحِم{6}. (١٥/٢٤٧) ٨١٤٩١- عن قتادة بن دعامة -من طريق معمر- <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: خروجه من بطن أمه{7}. (١٥/٢٤٦) ٨١٤٩٢- عن إسماعيل السُّدِّيّ -من طريق سفيان- <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: خروجه من بطن أمه{1}. (ز) ٨١٤٩٣- قال إسماعيل السُّدِّيّ: <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، يعني: طريق الحق والباطل{9}. (ز) ٨١٤٩٤- قال مقاتل بن سليمان: <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، يعني: هوّن طريقه في الخروج مِن بطن أمه، يقول: يسّره للخروج، أفلا يعتبر فيُوَحِّد الله في حُسن خَلْقه فيشكر الله في نِعمه!{10}. (ز) ٨١٤٩٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ثُمَّ السَّبِيلَ يَسَّرَهُ﴾</q>، قال: هداه للإسلام والدين، يسّره له، وأعلمه به، والسبيل سبيل الإسلام{11}٧٠٣٩. (ز) ٧٠٣٩ اختُلف في السبيل الذي يسّره الله لها على قولين: الأول: أنها خروجه من بطن أمه. الثاني: أنها طريق الحق والباطل. وقد رجّح ابنُ جرير (٢٤/١١٣) -مستندًا إلى السياق- القول الأول، وعلل ذلك بقوله: «وإنما قلنا ذلك أولى التأويلين بالصواب لأنه أشبههما بظاهر الآية، وذلك أنّ الخبر من الله قبلها وبعدها عن صفته؛ خَلْقه، وتدبيره جسمه، وتصريفه إياه في الأحوال، فالأولى أن يكون أوسط ذلك نظير ما قبله وما بعده». ورجّح ابنُ كثير (١٤/٢٥٠) القول الثاني بقوله: «وهذا هو الأرجح». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن جرير ٢٤/١١١.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١١٢، وكذلك من طريق منصور أيضًا، وأخرجه عبد الرزاق ٢/٣٤٨ من طريق ابن جُرَيْج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١١٢، كما أخرجه عبد الرزاق ٢/٣٤٨، من طريق معمر، ومثله ابن جرير.أخرجه ابن جرير ٢٤/١١١. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤٨، وابن جرير ٢٤/١١٢، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١١١.تفسير البغوي ٨/٣٣٧.تفسير مقاتل بن سليمان ٤/٥٩٢.أخرجه ابن جرير ٢٤/١١٣.
80,21," <q>﴿ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ ۝٢١﴾</q> - تفسير ٨١٤٩٦- قال مقاتل بن سليمان: <q>﴿ثُمَّ أماتَهُ﴾</q> عند أجَله، <q>﴿فَأَقْبَرَهُ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٢.
80,22," <q>﴿ثُمَّ إِذَا شَاۤءَ أَنشَرَهُۥ ۝٢٢﴾</q> - تفسير ٨١٤٩٧- قال مقاتل بن سليمان: <q>﴿ثُمَّ إذا شاءَ أنْشَرَهُ﴾</q> في الآخرة، يعني: إذا شاء بعثه من بعد موته{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٢.
80,23," <q>﴿كَلَّا لَمَّا یَقۡضِ مَاۤ أَمَرَهُۥ ۝٢٣﴾</q> - تفسير ٨١٤٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لَمّا يَقْضِ ما أمَرَهُ﴾</q>، قال: لا يقضي أحدٌ أبدًا كلَّ ما افتُرِضَ عليه{1}٧٠٤٠. (١٥/٢٤٨) ٧٠٤٠ لم يذكر ابنُ جرير (٢٤/١١٤) غير قول مجاهد. وذكر ابنُ كثير (١٤/٢٥١) قول مجاهد، ونحوه عن الحسن البصري، ثم قال معلقًا: «ولم أجد للمتقدمين فيه كلامًا سوى هذا، والذي يقع لي في معنى ذلك -والله أعلم- أن المعنى: <q>﴿ثم إذا شاء أنشره﴾</q> أي: بعثه، <q>﴿كلا لما يقض ما أمره﴾</q> أي: لا يفعله الآن حتى تنقضي المدة، ويفرغ القدر مِن بني آدم ممن كتب تعالى له أن سيوجد منهم، ويخرج إلى الدنيا، وقد أمر به تعالى كونًا وقدرًا، فإذا تناهى ذلك عند الله أنشر الله الخلائق، وأعادهم كما بدأهم. وقد روى ابن أبي حاتم، عن وهْب بن مُنَبِّه، قال: قال عُزير ﵇: قال المَلك الذي جاءني: فإنّ القبور هي بطن الأرض، وإنّ الأرض هي أُمّ الخلق، فإذا خلق الله ما أراد أن يخلق، وتمت هذه القبور التي مدّ الله لها انقطعت الدنيا، ومات مَن عليها، ولفظت الأرض ما في جوفها، وأخرجت القبور ما فيها، وهذا شبيه بما قلنا من معنى الآية، والله ﷾ أعلم بالصواب». ٨١٤٩٩- قال مقاتل بن سليمان: <q>﴿كَلّا﴾</q> لا يؤمن الإنسان بالنشور، ثم استأنف، فقال: <q>﴿لَمّا يَقْضِ ما أمَرَهُ﴾</q> يعني: ما عهد الله إليه أمر الميثاق الأول، يعني: التوحيد، يعني به: آدم ﵇{2}. (ز) ",footnotes:1:تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١١٤، والفريابي -كما في تغليق التعليق ٤/٣٦٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
80,24," <q>﴿فَلۡیَنظُرِ ٱلۡإِنسَـٰنُ إِلَىٰ طَعَامِهِۦۤ ۝٢٤﴾</q> - تفسير ٨١٥٠٠- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- في قوله: <q>﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</q>، قال: إلى خُرْئِهِ{1}. (١٥/٢٤٩) ٨١٥٠١- عن عبد الله بن الزُّبير، في قوله: <q>﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</q>، قال: إلى مَدخله، ومَخرجه{2}. (١٥/٢٤٨) ٨١٥٠٢- عن مجاهد بن جبر، مثله{3}٧٠٤١. (١٥/٢٤٨) ٧٠٤١ علّق ابنُ عطية (٨/٥٤٠) على ما جاء عن مجاهد، وابن الزُّبير، وابن عباس، والحسن، فقال: «وذهب أُبيّ بن كعب، وابن عباس، والحسن، ومجاهد، وغيرهم إلى أن المراد: <q>﴿إلى طَعامِهِ﴾</q> إذا صار رجيعًا؛ ليتأمل حيث تصير عاقبة الدنيا، وعلى أي شيء يتفانى أهلها، وتستدير رحاها، وهذا نظير ما روي عن ابن عمر: أنّ الإنسان إذا أحدث فإنّ ملكًا يأخذ بناصيته عند فراغه، فيردّ بصره إلى نحوه موقفًا له ومعجبًا، فينفع ذلك مَن له عقل». ٨١٥٠٣- عن مجاهد بن جبر -من طريق منصور- <q>﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</q>، قال: إلى مأكله، ومشربه{4}. (ز) ٨١٥٠٤- عن مجاهد بن جبر-من طريق ابن أبي نجيح- قوله: <q>﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</q>: آية لهم{4}٧٠٤٢. (ز) ٧٠٤٢ لم يذكر ابنُ جرير (٢٤/١١٥) غير قول مجاهد هذا، وقوله من طريق منصور. ٨١٥٠٥- عن الحسن البصري، في قوله: <q>﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</q>، قال: مَلَك يثني رقبة -ابن آدم- إذا جلس على الخلاء؛ لينظر ما يَخرج منه{6}. (١٥/٢٤٩) ٨١٥٠٦- قال مقاتل بن سليمان: ثم استأنف ذِكر ما خُلق عليه، فذكر رِزقه ليعتبر، فقال: <q>﴿فَلْيَنْظُرِ الإنْسانُ﴾</q> يعني: عُتبة بن أبي لهب <q>﴿إلى طَعامِهِ﴾</q> يعني: رِزقه{7}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب التواضع (٢١٣).عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١١٥.أخرجه ابن جرير ٢٤/١١٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٩٢.
80,25," <q>﴿أَنَّا صَبَبۡنَا ٱلۡمَاۤءَ صَبࣰّا ۝٢٥﴾</q> - تفسير ٨١٥٠٧- عن عبد الله بن عباس، <q>﴿أنّا صَبَبْنا الماءَ صَبًّا﴾</q>، قال: المطر{1}. (١٥/٢٤٩) ٨١٥٠٨- قال مقاتل بن سليمان: <q>﴿أنّا صَبَبْنا الماءَ صَبًّا﴾</q> على الأرض، يعني: المطر{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
80,26," <q>﴿ثُمَّ شَقَقۡنَا ٱلۡأَرۡضَ شَقࣰّا ۝٢٦﴾</q> - تفسير ٨١٥٠٩- عن عبد الله بن عباس، <q>﴿ثُمَّ شَقَقْنا الأَرْضَ شَقًّا﴾</q>، قال: عن النبات{1}. (١٥/٢٤٩) ٨١٥١٠- قال مقاتل بن سليمان: <q>﴿ثُمَّ شَقَقْنا الأَرْضَ شَقًّا﴾</q>، يعني: عن النَّبت والشجر{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
80,27," <q>﴿فَأَنۢبَتۡنَا فِیهَا حَبࣰّا ۝٢٧﴾</q> - تفسير ٨١٥١١- قال مقاتل بن سليمان: <q>﴿فَأَنْبَتْنا فِيها حَبًّا﴾</q> يعني: الحبوب كلّها{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٩٢.
80,28," <q>﴿وَعِنَبࣰا وَقَضۡبࣰا ۝٢٨ وَزَیۡتُونࣰا وَنَخۡلࣰا ۝٢٩﴾</q> - تفسير ٨١٥١٢- عن عبد الله بن عباس -من طريق علي- <q>﴿وقَضْبًا﴾</q>، قال: الفِصفِصة، يعني: القَتّ{1}. (١٥/٢٤٩) ٨١٥١٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿وقَضْبًا﴾</q>، قال: يعني: الرَّطْبة{2}. (ز) ٨١٥١٤- عن الحسن البصري -من طريق يونس- قال: <q>﴿وقَضْبًا﴾</q> القَضْب: العلف{2}. (ز) ٨١٥١٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وقَضْبًا﴾</q>، قال: والقَضْب: الفَصافِص{2}. (ز) ٨١٥١٦- قال مقاتل بن سليمان: <q>﴿وعِنَبًا وقَضْبًا﴾</q> يعني به: الرّطاب، <q>﴿وزَيْتُونًا﴾</q> يعني: الرَّطْبة التي يُعصر منها الزيت، <q>﴿ونَخْلًا﴾</q>{5}٧٠٤٣. (ز) ٧٠٤٣ رجّح ابنُ عطية (٨/٥٤١) -مستندًا إلى دلالة العقل- أنّ القَضْب: هو كلّ ما يُقضب ليأكله ابن آدم، فقال: «والذي أقوله إنّ القَضْب هنا: هو كلّ ما يُقضب ليأكله ابن آدم غضًّا من النبات؛ كالبقول والهليون ونحوه، فإنه من المطعوم جزء عظيم، ولا ذِكر له في الآية إلا في هذه اللفظة». وانتقد -مستندًا إلى الدلالة العقلية- القول بأنه الفَصافِص بقوله: «وهذا عندي ضعيف؛ لأن الفَصافِص هي للبهائم، فهي داخلة في الأبّ». ونقل تعليق ثعلب على قول مَن قال: هو الرَّطْبة. فقال: «وقال أبو عبيدة: القَضْب: الرَّطْبة. قال ثعلب: لأنه يُقضب كلّ يوم». ",footnotes:1:أخرجه ابن جرير ٢٤/١١٦، وابن أبي حاتم -كما في فتح الباري ١٣/٢٧١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١١٦.أخرجه ابن جرير ٢٤/١١٦.أخرجه ابن جرير ٢٤/١١٦.تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,29,""
80,30," <q>﴿وَحَدَاۤىِٕقَ غُلۡبࣰا ۝٣٠﴾</q> - قراءات ٨١٥١٧- عن مجاهد بن جبر أنه قرأ: (غُلُبًا) مُثقلة{1}. (١٥/٢٥٢) <q>﴿وَحَدَاۤىِٕقَ غُلۡبࣰا ۝٣٠﴾</q> - تفسير الآية ٨١٥١٨- عن عبد الله بن عباس، قال: الحدائق: كلّ ملتفٍّ. والغُلب: ما غلُظ{2}. (١٥/٢٤٩) ٨١٥١٩- عن عبد الله بن عباس -من طريق عاصم بن كُلَيب، عن أبيه- في قوله: <q>﴿وحَدائِقَ غُلْبًا﴾</q>، قال: الحدائق: ما التفّ واجتمع{3}. (ز) ٨١٥٢٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وحَدائِقَ غُلْبًا﴾</q>، قال: طوال{4}. (١٥/٢٤٩) ٨١٥٢١- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿وحَدائِقَ غُلْبًا﴾</q>، قال: شجر في الجنة، يُستظلّ به، لا يحمل شيئًا{5}. (١٥/٢٥٠) ٨١٥٢٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وحَدائِقَ غُلْبًا﴾</q>، قال: مُلتفّة{6}. (١٥/٢٥٠) ٨١٥٢٣- عن عكرمة مولى ابن عباس، <q>﴿غُلْبًا﴾</q>، قال: غِلاظًا{7}. (١٥/٢٥٠) ٨١٥٢٤- عن عكرمة مولى ابن عباس -من طريق سفيان، عن أبيه- <q>﴿وحَدائِقَ غُلْبًا﴾</q>، قال: عظام الأوساط{8}. (ز) ٨١٥٢٥- عن الحسن البصري، قال: الغُلب: الكِرام من النّخل{7}. (١٥/٢٥٠) ٨١٥٢٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وحَدائِقَ غُلْبًا﴾</q>، قال: النّخل الكِرام{10}. (ز) ٨١٥٢٧- عن إسماعيل السُّدِّيّ، قال: الحدائق: البساتين. والغُلب: ما غلظ من الشجر{11}. (١٥/٢٥٢) ٨١٥٢٨- قال محمد بن السّائِب الكلبي: <q>﴿وحَدائِقَ غُلْبًا﴾</q>، يعني: شجرًا طوالًا عِراضًا{12}. (ز) ٨١٥٢٩- قال مقاتل بن سليمان: <q>﴿وحَدائِقَ غُلْبًا﴾</q> يعني: الشجر المُلتفّ، الشجرة التي يدخل بعضها في جوف بعض{13}. (ز) ٨١٥٣٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وحَدائِقَ غُلْبًا﴾</q>: عظام النّخل العظيمة الجذع. قال: والغُلب من الرجال: العظام الرقاب، يقال: هو أغلب الرقبة: عظيمها{14}. (ز) ٨١٥٣١- عن عاصم، عن أبيه: <q>﴿وحَدائِقَ غُلْبًا﴾</q>: الحدائق نبت الشجر كلّه{3}٧٠٤٤. (ز) ٧٠٤٤ قال ابنُ جرير (٢٤/١١٦): "وقوله: <q>﴿غلبًا﴾</q> يعني: غلاظًا. ويعني بقوله: <q>﴿غلبًا﴾</q>: أشجارًا في بساتين غلاظ. والغُلب: جمع أغلب، وهو الغليظ الرقبة من الرجال؛ ومنه قول الفرزدق: عَوى فأثار أغْلَب ضَيْغَميًّا فويلَ ابن المَراغة ما استثارا؟ وبنحو الذي قلنا في ذلك قال أهل التأويل على اختلاف منهم في البيان عنه". وذكر أقوال السلف على هذا. ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة.أخرجه ابن أبي حاتم -كما في التغليق ٣/٤٩٠، وفتح الباري ٦/٢٩٥-٢٩٦-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١١٧.أخرجه ابن جرير ٢٤/١١٨، وابن أبي حاتم -كما في فتح الباري ١٣/٢٧١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١١٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٧٠٥، وأخرجه ابن جرير ٢٤/١١٧، وعبد بن حميد -كما في التغليق ٣/٤٩٠، وفتح الباري ٦/٢٩٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١١٨-١١٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٨، وابن جرير ٢٤/١١٨، ومن طريق سعيد أيضًا.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٦-.تفسير مقاتل بن سليمان ٤/٥٩٢.أخرجه ابن جرير ٢٤/١١٨.أخرجه ابن جرير ٢٤/١١٧.
80,31," <q>﴿وَفَـٰكِهَةࣰ﴾</q> - تفسير ٨١٥٣٢- عن عبد الله بن عباس -من طريق علي- <q>﴿وفاكِهَةً﴾</q>، قال: الثِّمار الرّطبة{1}. (١٥/٢٤٩) ٨١٥٣٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وفاكِهَةً﴾</q>: وهو ما أكل الناس{2}. (١٥/٢٥٠) ٨١٥٣٤- عن الضَّحّاك بن مُزاحِم، قال: <q>﴿وفاكِهَةً﴾</q> الفاكهة التي يأكلها بنو آدم{3}. (١٥/٢٥٢) ٨١٥٣٥- عن عكرمة مولى ابن عباس، قال: <q>﴿وفاكِهَةً﴾</q> الفاكهة ما تأكل الناس{3}. (١٥/٢٥٢) ٨١٥٣٦- عن الحسن البصري، قال: ما طاب واحْلَوْلى فلَكم{3}. (١٥/٢٥٢) ٨١٥٣٧- عن الحسن البصري -من طريق مبارك- <q>﴿وفاكِهَةً﴾</q>، قال: ما يأكل ابن آدم{6}. (ز) ٨١٥٣٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وفاكِهَةً﴾</q>، قال: أما الفاكهة فلَكم{7}. (ز) <q>﴿وَأَبࣰّا ۝٣١﴾</q> - تفسير ٨١٥٣٩- سُئِل أبو بكر الصِّدِّيق -من طريق إبراهيم التيمي- عن الأبّ، ما هو؟ فقال: أي سماء تُظلّني وأي أرض تُقلّني إذا قلتُ في كتاب الله ما لا أعلم؟!{8}٧٠٤٥. (١٥/٢٥١) ٧٠٤٥ علّق ابنُ كثير (١٤/٢٥٣) على هذا الأثر، فقال: «وهذا منقطع بين إبراهيم التيمي والصديق». ٨١٥٤٠- عن عمر بن الخطاب -من طريق أبي وائل- أنه سأل عن قوله: <q>﴿وأَبًّا﴾</q>، ما الأبّ؟ ثم قال: ما كُلّفنا هذا، أو ما أُمرنا بهذا{9}. (١٥/٢٥٣) ٨١٥٤١- عن عمر بن الخطاب -من طريق أنس- أنه قرأ على المنبر: <q>﴿فَأَنْبَتْنا فِيها حَبًّا وعِنَبًا وقَضْبًا وزَيْتُونًا ونَخْلًا وحَدائِقَ غُلْبًا وفاكِهَةً وأَبًّا﴾</q>، قال: كلّ هذا قد عرفناه، فما الأبّ؟ ثم رفع عصًا كانت في يده، فقال: هذا لَعمر الله هو التكلّف، فما عليك أن لا تدري ما الأبّ، اتبعوا ما بُيِّن لكم من هذا الكتاب فاعملوا به، وما لم تعرفوه فكِلُوه إلى ربّه{10}٧٠٤٦. (١٥/٢٥١) ٧٠٤٦ علّق ابنُ كثير (١٤/٢٥٣) على هذا الأثر، فقال: «إسناد صحيح، وقد رواه غير واحد عن أنس به. وهذا محمول على أنه أراد أن يعرف شكله وجنسه وعينه، وإلا فهو وكل مَن قرأ هذه الآية يعلم أنه مِن نبات الأرض؛ لقوله: <q>﴿فأنبتنا فيها حبًا وعنبًا وقضبًا وزيتونًا ونخلًا وحدائق غلبًا وفاكهة وأبًا﴾</q>». ٨١٥٤٢- عن عبد الرحمن بن زيد بن أسلم: أنّ رجلًا سأل عمر عن قوله: <q>﴿وأَبًّا﴾</q>، فلما رآهم يقولون أقبل عليهم بالدِّرَّةِ{11}. (١٥/٢٥٣) ٨١٥٤٣- عن عبد الله بن عباس -من طريق علي- <q>﴿وأَبًّا﴾</q>، قال: الثّمار الرَّطْبة{12}. (ز) ٨١٥٤٤- عن عبد الله بن عباس -من طريق عاصم بن كُلَيب، عن أبيه- قال: الأبّ: ما أنبت الأرضُ مما يأكله الدوابّ، ولا يأكله الناس{13}. (١٥/٢٤٩) ٨١٥٤٥- عن عبد الله بن عباس -من طريق عاصم بن كُلَيب، عن أبيه- قال: عَدَّ سبعًا، جعل رِزقه في سبعة، وجعله من سبعة، وقال في آخر ذلك: الأبّ ما أنبتت الأرض مما لا يأكل الناس{14}. (ز) ٨١٥٤٦- عن عبد الله بن عباس، قال: الأبّ: الحشيش للبهائم{15}. (١٥/٢٥٠) ٨١٥٤٧- عن عبد الله بن عباس -من طريق العَوفيّ- قال: الأبّ: الكلأ والمرعى{14}. (١٥/٢٥٠) ٨١٥٤٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿وأَبًّا﴾</q>. قال: الأبّ: ما يَعتلف منه الدوابّ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر: ترى به الأبّ واليقطين مختلطًا على الشريعة يجري تحتها الغَرَبُ؟{17}. (١٥/٢٥١) ٨١٥٤٩- عن أبي رَزين [مسعود بن مالك] -من طريق منصور- <q>﴿وأَبًّا﴾</q>، قال: النبات{18}. (١٥/٢٥٣) ٨١٥٥٠- عن سعيد بن جُبَير، <q>﴿وأَبًّا﴾</q>، قال: الكَلَأ{3}. (١٥/٢٥٢) ٨١٥٥١- عن مجاهد بن جبر-من طريق ابن أبي نجيح- <q>﴿وأَبًّا﴾</q>: ما أكلت الأنعام{20}. (١٥/٢٥٠) ٨١٥٥٢- قال مجاهد بن جبر -من طريق سفيان، عن الأعمش أو غيره- <q>﴿وأَبًّا﴾</q>، قال: الأبّ: المرعى{21}. (ز) ٨١٥٥٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: الأبّ: المرعى{22}. (١٥/٢٥٢) ٨١٥٥٤- عن الضَّحّاك بن مُزاحِم، قال: الأبّ: هو التِّبْن{3}. (١٥/٢٥٣) ٨١٥٥٥- عن عكرمة مولى ابن عباس، قال: الأبّ: ما تأكل الدوابُّ{3}. (١٥/٢٥٢) ٨١٥٥٦- عن أبي مالك غزوان الغفاري، قال: الأبّ: الكلأ{3}. (١٥/٢٥٣) ٨١٥٥٧- عن الحسن البصري -من طريق مبارك- قال: الأبّ لأنعامكم{26}. (١٥/٢٥٢) ٨١٥٥٨- عن الحسن البصري -من طريق يونس- قال: الأبّ: العُشب{12}. (ز) ٨١٥٥٩- عن عطاء بن أبي رباح، قال: كلّ شيء يَنبتُ على ظهر الأرض فهو الأبّ{28}. (١٥/٢٥٣) ٨١٥٦٠- عن قتادة بن دعامة -من طريق سعيد-: أما الأبّ فلأنعامكم، نِعمٌ من الله متظاهرة{21}. (ز) ٨١٥٦١- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأَبًّا﴾</q>، قال: هو ما أكلت الدوابُّ{30}. (ز) ٨١٥٦٢- عن إسماعيل السُّدِّيّ، قال: الأبّ: العُشب{31}. (١٥/٢٥٢) ٨١٥٦٣- قال مقاتل بن سليمان: <q>﴿وفاكِهَةً وأَبًّا﴾</q> يعني: المرعى{32}. (ز) ٨١٥٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: الأبّ لأنعامنا. قال: والأبّ: ما ترعى. وقرأ: <q>﴿مَتاعًا لَكُمْ ولِأَنْعامِكُمْ﴾</q>{12}٧٠٤٧. (ز) ٧٠٤٧ بيّن ابنُ جرير (٢٤/١١٩) أنّ الأبّ: هو ما تأكله البهائم من العُشب والنبات. وذكر على ذلك أقوال السلف، ثم ذكر قول مَن قال: هو الثمار الرَّطبة. ولم يعلّق عليه. وذكر ابنُ عطية (٨/٥٤١) أقوال السلف في تفسيره، ثم علّق بقوله: «وفي اللفظة غرابة، وقد توقف في تفسيرها أبو بكر وعمر ﵄». ",footnotes:1:أخرجه ابن جرير ٢٤/١٢٣، وابن أبي حاتم -كما في فتح الباري ١٣/٢٧١-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٧٠٦، وأخرجه ابن جرير ٢٤/١١٩، وعبد بن حميد -كما في التغليق ٣/٤٩٠، وفتح الباري ٦/٢٩٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٦-، وأخرجه ابن جرير ٢٤/١١٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٦-.أخرجه ابن جرير ٢٤/١١٩.أخرجه أبو عبيد في فضائله ص٢٢٧، وعبد بن حميد -كما في تخريج الكشاف ٤/١٥٨، وفتح الباري ١٣/٢٧١-.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٣٤٩ من طريق الزّهري، وابن سعد ٣/٣٢٧، وسعيد بن منصور (٤٣-تفسير)، وعبد بن حميد -كما في فتح الباري ١٣/٢٧١-، وابن جرير ٢٤/١٢٠، ١٢٣، والحاكم ٢/٢٩٠، ٥١٤، وابن مردويه -كما في تخريج الكشاف ٤/١٥٩-، والبيهقي في شعب الإيمان (٢٢٨١). وعزاه السيوطي إلى ابن المنذر، والخطيب.أخرجه عبد بن حميد -كما في فتح الباري ١٣/٢٧١-.أخرجه ابن جرير ٢٤/١٢٣.أخرجه ابن جرير ٢٤/١٢١، ومن طريق سعيد بن جُبَير أيضًا، وابن أبي حاتم -كما في التغليق ٣/٤٩٠، وفتح الباري ٦/٢٩٥-٢٩٦-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٢١.أخرجه ابن أبي حاتم -كما في التغليق ٣/٤٩٠، وفتح الباري ٦/٢٩٦، ١٣/٢٧١-.أخرجه ابن جرير ٢٤/١٢١.أخرجه الطستي -كما في الإتقان ٢/١٠٠-.أخرجه ابن جرير ٢٤/١٢١. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٠٦، وأخرجه ابن جرير ٢٤/١٢٢، وعبد بن حميد -كما في التغليق ٣/٤٩٠، وفتح الباري ٦/٢٩٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٢٢.أخرجه ابن جرير ٢٤/١٢٢. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٦-، وأخرجه ابن جرير ٢٤/١٢٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٦-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٢٣.أخرجه عبد بن حميد -كما في فتح الباري ٦/٢٩٦، ١٣/٢٧١-.أخرجه ابن جرير ٢٤/١٢٢.أخرجه عبد الرزاق ٢/٣٤٩، وابن جرير ٢٤/١٢٢.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.أخرجه ابن جرير ٢٤/١٢٣.
80,32," <q>﴿مَتَـٰعࣰا لَّكُمۡ وَلِأَنۡعَـٰمِكُمۡ ۝٣٣﴾</q> - تفسير ٨١٥٦٥- عن الحسن البصري -من طريق يونس- في قوله: <q>﴿مَتاعًا لَكُمْ ولِأَنْعامِكُمْ﴾</q>، قال: متاعًا لكم الفاكهة، ولأنعامكم العُشب{1}. (ز) ٨١٥٦٦- عن إسماعيل السُّدِّيّ، قال: <q>﴿مَتاعًا لَكُمْ ولِأَنْعامِكُمْ﴾</q>، قال: الفاكهة لكم، والعُشب لأنعامكم{2}. (١٥/٢٥٢) ٨١٥٦٧- قال مقاتل بن سليمان: <q>﴿مَتاعًا لَكُمْ﴾</q> يقول: في هذا كلّه متاعًا لكم، <q>﴿ولِأَنْعامِكُمْ﴾</q> ففي هذا مُعتبر، وقال النبي ﷺ: «خُلقتم مِن سبع، ورُزقتم مِن سبع، وخرجتم على سبع»{3}. (ز) <q>﴿مَتَـٰعࣰا لَّكُمۡ وَلِأَنۡعَـٰمِكُمۡ ۝٣٣﴾</q> - آثار متعلقة بالآية ٨١٥٦٨- عن عبد الله بن عباس -من طريق عكرمة- قال: دعا عمرُ بن الخطاب أصحابَ محمد ﷺ، فسألهم عن ليلة القدر، فأجمعوا أنها في العشر الأواخر. قال عبد الله بن عباس: فقلت لعمر: إني لَأعلم، وإني لَأظن أي ليلة هي. فقال عمر: وأي ليلة هي؟ فقلت: سابعة تمضي، أو سابعة تبقى من العشر الأواخر. فقال عمر: ومِن أين علمتَ ذلك؟ فقال ابن عباس: قلتُ: خلق الله سبع سماوات، وسبع أرضين، وسبعة أيام، وإنّ الشهر يدور في سبع، وخَلق الإنسان من سبع، ويأكل من سبع، ويسجد على سبع، والطواف بالبيت سبع، ورمي الجمار سبع، لأشياء ذكرها. فقال عمر: لقد فطنتَ لأمر ما فطنّا له. وكان قتادة يزيد عن ابن عباس في قوله: ويأكل من سبع. قال: هو قول الله ﷿: <q>﴿فَأَنْبَتْنا فِيها حَبًّا وعِنَبًا وقَضْبًا﴾</q>{4}. (ز) <q>﴿فَإِذَا جَاۤءَتِ ٱلصَّاۤخَّةُ ۝٣٣﴾</q> - تفسير ٨١٥٦٩- عن عبد الله بن عباس -من طريق علي- قال: <q>﴿الصّاخَّةُ﴾</q> هذا مِن أسماء يوم القيامة، عظّمه الله، وحذّره عباده{5}٧٠٤٨. (١٥/٢٥٤) ٧٠٤٨ لم يذكر ابنُ جرير (٢٤/١٢٤) غير قول ابن عباس. وقال ابنُ عطية (٨/٥٤٢): «الصّاخَّةُ: اسم من أسماء القيامة، واللفظة في حقيقتها إنما هي لنفخة الصور التي تصخ الآذان، أي: تصمّها، ويُستعمل هذا اللفظ في الداهية التي يصمّ نبؤها الآذان لصعوبتها، وهذه استعارة، وكذلك في الصيحة المُفرطة التي يصعب وقعها على الأذن». ٨١٥٧٠- قال مقاتل بن سليمان: <q>﴿فَإذا جاءَتِ الصّاخَّةُ﴾</q> يعني: الصيحة؛ صاخت أسماع الخلق بالصّيحة مِن الصائح يسمعها الخَلْق{6}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/١٢٤.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢. والحديث المرفوع لم نقف عليه مسندًا، وأورده كذلك السمرقندي في تفسيره بحر العلوم (٣/ ٥٤٨)، والقرطبي في تفسيره (١٩/ ٢٢٣). وذكره الحسن بن محمد الصغاني، (ت:٦٥٠) في موضوعاته، ٤٧. وسيأتي معنى الحديث في الأثر التالي وأنه من قول ابن عباس.المعجم الكبير ١٠/٢٦٤-٢٦٥ (١٠٦١٨).أخرجه ابن جرير ٢٤/١٢٤. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢.
  80,33,""
80,34," <q>﴿یَوۡمَ یَفِرُّ ٱلۡمَرۡءُ مِنۡ أَخِیهِ ۝٣٤ وَأُمِّهِۦ وَأَبِیهِ ۝٣٥ وَصَـٰحِبَتِهِۦ وَبَنِیهِ ۝٣٦﴾</q> - تفسير ٨١٥٧١- عن الحسن البصري -من طريق قتادة- قال: إنّ أول مَن يفرّ يوم القيامة من أبيه إبراهيم، وأول مَن يفرّ من أُمّه إبراهيم، وأول مَن يفرّ من ابنه نوح، وأول مَن يفرّ مِن أخيه هابيل، وأول مَن يفرّ مِن صاحبته نوح ولوط. وتلا هذه الآية: <q>﴿يَوْمَ يَفِرُّ المَرْءُ مِن أخِيهِ وأُمِّهِ وأَبِيهِ وصاحِبَتِهِ وبَنِيهِ﴾</q>، فيَرَوْن أنّ هذه الآية نزلت فيهم{1}. (١٥/٢٥٦) ٨١٥٧٢- عن قتادة بن دعامة -من طريق خليد بن دعلج- في قوله: <q>﴿يوم يفر المرء من أخيه﴾</q> قال: يفر هابيل من قابيل، <q>﴿وأمه وأبيه﴾</q> يفر النبيُّ ﷺ مِن أُمِّه، وإبراهيم ﵇ مِن أبيه، <q>﴿وصاحبته وبنيه﴾</q> قالوا: لوط ﵇ مِن صاحبته، ونوح ﵇ مِن ابنه{2}. (ز) ٨١٥٧٣- عن قتادة بن دعامة، قال: ليس شيءٌ أشدَّ على الإنسان يوم القيامة مِن أن يرى مَن يعرفه؛ مخافة أن يكون يطلبه بمظلمة. ثم قرأ: <q>﴿يَوْمَ يَفِرُّ المَرْءُ مِن أخِيهِ﴾</q> الآية{3}. (١٥/٢٥٦) ٨١٥٧٤- قال مقاتل بن سليمان: ثم عظّم الرّبّ ﷿ ذلك، فقال: <q>﴿يَوْمَ يَفِرُّ المَرْءُ مِن أخِيهِ﴾</q> يعني: لا يلتفت إليه، <q>﴿وأُمِّهِ وأَبِيهِ وصاحِبَتِهِ﴾</q> يعني: وامرأته، <q>﴿وبَنِيهِ﴾</q>{4}. (ز) ",footnotes:1:أخرجه ابن عساكر ٦٤/٨.أخرجه الثعلبي ١٠/١٣٥، وأبو نعيم في حلية الأولياء ٢/٣٤١.عزاه السيوطي إلى أبي عبيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٩٢-٥٩٣.
