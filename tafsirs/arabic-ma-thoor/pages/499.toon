quran[13]{c,v,t}:
  45,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٠١٩٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد-: مكيّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٩٨<span class="dash">-</span></span> عن عبد الله بن عباس، قال: أُنزلت بمكة سورة <span class="qpc-hafs">﴿حم﴾</span> الجاثية{2}. (١٣/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠١٩٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراساني-: مكيّة، ونزلت بعد الدُّخان{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠٠<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: نزل بمكة سورة الشريعة{2}. (١٣/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠١<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠٢<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠٣<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠٤<span class="dash">-</span></span> عن محمد بن شهاب الزُّهري: مكيّة، ونزلت بعد الدُّخان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠٥<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٠٦<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الجاثية مكيّة، عددها سبع وثلاثون آية كوفي{9}<span class=comment-ref>٥٩٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٨٧) أن هذه السورة مكية <span class="mustanad">بلا خلاف</span>.</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصَيْف عن مجاهد.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:عزاه السيوطي إلى ابن مردويه.|5:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|6:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.|7:تنزيل القرآن ص٣٧-٤٢.|8:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|9:تفسير مقاتل بن سليمان ٣/٨٣٣.
  45,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حمۤ ۝١ تَنزِیلُ ٱلۡكِتَـٰبِ مِنَ ٱللَّهِ ٱلۡعَزِیزِ ٱلۡحَكِیمِ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ﴾</span> في مُلكه، <span class="qpc-hafs">﴿الحَكِيمِ﴾</span> في أمره{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٥.
  45,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ لَـَٔایَـٰتࣲ لِّلۡمُؤۡمِنِینَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ فِي السَّماواتِ والأَرْضِ﴾</span> وهما خَلْقان عظيمان <span class="qpc-hafs">﴿لَآياتٍ لِلْمُؤْمِنِينَ﴾</span> يعني: المُصَدِّقين بتوحيد الله ﷿{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٥.
  45,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفِی خَلۡقِكُمۡ وَمَا یَبُثُّ مِن دَاۤبَّةٍ ءَایَـٰتࣱ لِّقَوۡمࣲ یُوقِنُونَ ۝٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٠٩<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وفِي خَلْقِكُمْ وما يَبُثُّ مِن دَآبَّةٍ لَآياتٍ){1}<span class=comment-ref>٥٩٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٤</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿آيات﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿آيات﴾</span> بالرفع. <b>وقرأ غيرهم</b> بالخفض.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢١/٧٢-٧٣) أن القراءة الأولى جاءت رفعًا على الابتداء، وترك ردّها على قوله: <span class="qpc-hafs">﴿لآيات للمؤمنين﴾</span>. وأن القراءة الثانية جاءت خفضًا بتأويل النصب ردًّا على قوله: <span class="qpc-hafs">﴿لآيات للمؤمنين﴾</span>.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٧/٥٨٧).</p><p>و<span class="comment-type-4">زاد</span> <u>ابنُ عطية</u> أن قراءة الرفع لها وجه آخر، وهو أن يكون قوله: <span class="qpc-hafs">﴿وفي خلقكم وما يبث﴾</span> مستأنفًا، ويكون الكلام جملة معطوفة على جملة، ونقل أن بعض الناس قال: يجوز أن يكون جملة في موضع الحال. و<span class="comment-type-4">علَّق</span> عليه بقوله: «فلا تكون غريبة على هذا».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> أنّ من قرأوا بالخفض اختاروه؛ لأنه في قراءة أبيّ في الآيات الثلاثة (لَآيات) باللام، فجعلوا دخول اللام في ذلك في قراءته دليلًا لهم على صحة قراءة جميعه بالخفض، و<span class="comment-type-2">انتقده</span> فقال: «وليس الذي اعتمدوا عليه من الحجة في ذلك بحجة؛ لأنه لا رواية بذلك عن أبي صحيحة، وأُبي لو صحّت به عنه رواية ثم لم يُعلم كيف كانت قراءته بالخفض أو بالرفع لم يكن الحكم عليه بأنه كان يقرأه خفضًا بأولى من الحكم عليه بأنه كان يقرأه رفعًا، إذ كانت العرب قد تُدخل اللام في خبر المعطوف على جملة كلام تام قد عملت في ابتدائها»إن«، مع ابتدائهم إياه».</p><p>ثم <span class="comment-type-3">رجَّح</span> صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، وصحة معناهما</span>، فقال: «والصواب مِن القول في ذلك إن كان الأمر على ما وصفنا أن يُقال: إنّ الخفض في هذه الأحرف والرفع قراءتان مستفيضتان في قراءة الأمصار، قد قرأ بهما علماء من القراء صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿وَفِی خَلۡقِكُمۡ وَمَا یَبُثُّ مِن دَاۤبَّةٍ ءَایَـٰتࣱ لِّقَوۡمࣲ یُوقِنُونَ ۝٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٢١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِي خَلْقِكُمْ﴾</span> يعني: وفي خلْق أنفسكم إذ كنتم نُطفة، ثم عَلَقة، ثم مُضغة، ثم عظمًا لحمًا{2}، ثم الروح، <span class="qpc-hafs">﴿وما يَبُثُّ مِن دابَّةٍ﴾</span> يقول: وما يخلق مِن دابة <span class="qpc-hafs">﴿آياتٌ لِقَوْمٍ يُوقِنُونَ﴾</span> بتوحيد الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢١١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿وفِي خَلْقِكُمْ﴾</span>، قال: خَلْقِ أنفسكم{4}. (١٣/٢٩٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٥.</p><p>وهي قراءة شاذة، تروى أيضًا عن أُبَيّ. انظر: مختصر ابن خالويه ص١٣٨.|2:كذا في مطبوعة المصدر، ولعل فيه سقطًا.|3:تفسير مقاتل بن سليمان ٣/٨٣٥.|4:عزاه السيوطي إلى ابن المنذر.
  45,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ وَمَاۤ أَنزَلَ ٱللَّهُ مِنَ ٱلسَّمَاۤءِ مِن رِّزۡقࣲ فَأَحۡیَا بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَا وَتَصۡرِیفِ ٱلرِّیَـٰحِ ءَایَـٰتࣱ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٠٢١٢<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وتَصْرِيفِ الرِّياحِ لَآياتٍ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱخۡتِلَـٰفِ ٱلَّیۡلِ وَٱلنَّهَارِ وَمَاۤ أَنزَلَ ٱللَّهُ مِنَ ٱلسَّمَاۤءِ مِن رِّزۡقࣲ فَأَحۡیَا بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَا وَتَصۡرِیفِ ٱلرِّیَـٰحِ ءَایَـٰتࣱ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٠٢١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وتَصْرِيفِ الرِّياحِ﴾</span>، قال: تصريفها؛ إن شاء جعَلَها رحمة، وإن شاء جعَلَها عذابًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وفي <span class="qpc-hafs">﴿اخْتِلافِ اللَّيْلِ والنَّهارِ﴾</span> وهما آيتان، <span class="qpc-hafs">﴿وما أنْزَلَ اللَّهُ مِنَ السَّماءِ مِن رِزْقٍ﴾</span> يعني: المطر؛ <span class="qpc-hafs">﴿فَأَحْيا بِهِ الأَرْضَ بَعْدَ مَوْتِها﴾</span> فأنبَتتْ، <span class="qpc-hafs">﴿وتَصْرِيفِ الرِّياحِ﴾</span> في الرحمة والعذاب <span class="qpc-hafs">﴿آياتٌ لِقَوْمٍ يَعْقِلُونَ﴾</span> بتوحيد الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢١٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿وما أنْزَلَ اللَّهُ مِنَ السَّماءِ مِن رِزْقٍ﴾</span> قال: المطر. وفي قوله: <span class="qpc-hafs">﴿وتَصْرِيفِ الرِّياحِ﴾</span> قال: إذا شاء جعَلَها رحمة، وإذا شاء جعَلَها عذابًا{4}. (١٣/٢٩٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٥.</p><p>وهي قراءة شاذة، تروى أيضًا عن أُبَيّ. انظر: مختصر ابن خالويه ص١٣٨.|2:أخرجه عبد الرزاق ٢/٢١٢، وابن جرير ٢١/٧٤.|3:تفسير مقاتل بن سليمان ٣/٨٣٥.|4:عزاه السيوطي إلى ابن المنذر.
  45,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تِلۡكَ ءَایَـٰتُ ٱللَّهِ نَتۡلُوهَا عَلَیۡكَ بِٱلۡحَقِّۖ فَبِأَیِّ حَدِیثِۭ بَعۡدَ ٱللَّهِ وَءَایَـٰتِهِۦ یُؤۡمِنُونَ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى أول السورة في التقديم، فقال: <span class="qpc-hafs">﴿تِلْكَ آياتُ اللَّهِ﴾</span> يعني: تلك آيات القرآن <span class="qpc-hafs">﴿نَتْلُوها عَلَيْكَ﴾</span> يا محمد <span class="qpc-hafs">﴿بِالحَقِّ﴾</span> فإن لم يؤمنوا بهذا القرآن <span class="qpc-hafs">﴿فَبِأَيِّ حَدِيثٍ بَعْدَ اللَّهِ﴾</span> يعني: بعد توحيد الله <span class="qpc-hafs">﴿و﴾</span>بعد <span class="qpc-hafs">﴿آياتِهِ﴾</span> يعني: بعد آيات القرآن <span class="qpc-hafs">﴿يُؤْمِنُونَ﴾</span> يعني: يُصَدِّقون{1}<span class=comment-ref>٥٩٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٩٠) أن قوله: <span class="qpc-hafs">﴿تلك آيات الله﴾</span> إشارة إلى ما ذكر. وقوله: <span class="qpc-hafs">﴿نتلوها﴾</span> فيه حذف مضاف، أي: يتلو شأنها وتفسيرها وشرح العبرة لها، ثم ساق <b>احتمالًا</b> آخر، فقال: «ويحتمل أن يريد بـ<span class="qpc-hafs">﴿آيات الله﴾</span>: القرآن المنزل في هذه المعاني». و<span class="comment-type-4">علَّق</span> عليه بقوله: «فلا يكون في <span class="qpc-hafs">﴿نتلوها﴾</span> حذف مضاف».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٥.
  45,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیۡلࣱ لِّكُلِّ أَفَّاكٍ أَثِیمࣲ ۝٧﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٠٢١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لِكُلِّ أفّاكٍ أثِيمٍ﴾</span>، قال: المُغيرة بن مخزوم{1}. (١٣/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿لِكُلِّ أفّاكٍ أثِيمٍ﴾</span>، قال: كذّاب{2}. (١٣/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويْلٌ لِكُلِّ أفّاكٍ﴾</span> يعني: كذاب، <span class="qpc-hafs">﴿أثِيمٍ﴾</span> يقول: آثم بربه. وكذِبه أنه قال: إنّ القرآن أساطير الأولين. يعني: حديث رستم وإسفنديار، يعني: النَّضر بن الحارث القرشي من بني عبد الدار{3}<span class=comment-ref>٥٩٣٦</span><span class=comment-ref>٥٩٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٩١) أن «الويل» في كلام العرب: المصائب والحزن، والهمّ والشدة مِن هذه المعاني، وأنها لفظة تُستعمل في الدعاء على الإنسان. ثم قال: «وروي في بعض الآثار أن في جهنم واديًا اسمه: ويل».</div></p><p><div><span class=comment-ref>٥٩٣٧</span> اختُلف فيمن نزلت فيه الآية على أقوال: <b>الأول</b>: المغيرة بن مخزوم. <b>الثاني</b>: النّضر بن الحارث. <b>الثالث</b>: أبو جهل. ذكَره <u>ابنُ عطية</u> (٧/٥٩١).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> <span class="mustanad">العموم</span>، وأن الآية تعمّ كلّ من دخل تحت الأوصاف المذكورة إلى يوم القيامة، وإن كان سببها ما كان يفعله مَن ذُكر.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٨٣٥-٨٣٦.
  45,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَسۡمَعُ ءَایَـٰتِ ٱللَّهِ تُتۡلَىٰ عَلَیۡهِ ثُمَّ یُصِرُّ مُسۡتَكۡبِرࣰا كَأَن لَّمۡ یَسۡمَعۡهَاۖ فَبَشِّرۡهُ بِعَذَابٍ أَلِیمࣲ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَسْمَعُ آياتِ اللَّهِ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿تُتْلى عَلَيْهِ ثُمَّ يُصِرُّ مُسْتَكْبِرًا﴾</span> يعني: يُصرّ: يقيم على الكفر بآيات القرآن، فيُعرض عنها متكبّرًا، يعني: عن الإيمان بآيات القرآن، <span class="qpc-hafs">﴿كَأَنْ لَمْ يَسْمَعْها﴾</span> يعني: آيات القرآن وما فيه، <span class="qpc-hafs">﴿فَبَشِّرْهُ بِعَذابٍ ألِيمٍ﴾</span> يعني: وجيع، فقُتل ببدر{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٦.
  45,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا عَلِمَ مِنۡ ءَایَـٰتِنَا شَیۡـًٔا ٱتَّخَذَهَا هُزُوًاۚ أُو۟لَـٰۤىِٕكَ لَهُمۡ عَذَابࣱ مُّهِینࣱ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن النَّضر بن الحارث، فقال: <span class="qpc-hafs">﴿وإذا عَلِمَ مِن آياتِنا شَيْئًا﴾</span> يقول: إذا سمع مِن آيات القرآن شيئًا <span class="qpc-hafs">﴿اتَّخَذَها هُزُوًا﴾</span> يعني: استهزاء بها، وذلك أنه زعم أنّ حديث القرآن مثل حديث رستم وإسفنديار، <span class="qpc-hafs">﴿أُولئِكَ لَهُمْ﴾</span> يعني: النَّضر بن الحارث وأصحابه، وهم قريش <span class="qpc-hafs">﴿عَذابٌ مُهِينٌ﴾</span> يعني: [القتل]{1} في الدنيا يوم بدر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:في مطبوعة المصدر: القرآن! ولا يستقيم بها السياق، والصواب ما أثبتناه بدليل ما سيأتي في تفسير الآية التالية.|2:تفسير مقاتل بن سليمان ٣/٨٣٦.
  45,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مِّن وَرَاۤىِٕهِمۡ جَهَنَّمُۖ وَلَا یُغۡنِی عَنۡهُم مَّا كَسَبُوا۟ شَیۡـࣰٔا وَلَا مَا ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ أَوۡلِیَاۤءَۖ وَلَهُمۡ عَذَابٌ عَظِیمٌ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مِن ورائِهِمْ جَهَنَّمُ﴾</span> يعني: النَّضر بن الحارث، يقول لهم في الدنيا: القتْل ببدر، ومِن بعده أيضًا لهم جهنم في الآخرة، <span class="qpc-hafs">﴿ولا يُغْنِي عَنْهُمْ ما كَسَبُوا شَيْئًا﴾</span> يقول: لا تغني عنهم أموالهم التي جمعوها مِن جهنم شيئًا، ولا يغني عنهم مِن جهنم <span class="qpc-hafs">﴿ما اتَّخَذُوا مِن دُونِ اللَّهِ أوْلِياءَ﴾</span> يقول: ما عبدوا مِن دون الله مِن الآلهة، <span class="qpc-hafs">﴿ولَهُمْ عَذابٌ عَظِيمٌ﴾</span> يعني: كبير لشدَّته{1}<span class=comment-ref>٥٩٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٩٢) أن بعض المفسرين قال بأن قوله: <span class="qpc-hafs">﴿من ورائهم جهنم﴾</span> معناه: من أمامهم، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا نحو الخلاف الذي في قوله تعالى: <span class="qpc-hafs">﴿وكان وراءهم ملك﴾</span> [الكهف:٧٩] ولحظ قائل هذه المقالة الأمر من حيث تأول أنّ الإنسان كأنه مِن عمره يسير إلى جنة أو نار، فهما أمامه، وليس لفظ الوراء في اللغة كذلك، وإنما هو ما يأتي خلف الإنسان، وإذا اعتبر الأمر بالتقدم أو التأخر في الوجود على أن الزمان كالطريق للأشياء استقام الأمر، فما يأتي بعد الشيء في الزمان فهو وراءه، فكان الملك وأخذْه السفينة وراء ركوب أولئك إياها، وجهنم وإحراقها للكفرة يأتي بعد كفرهم وأفعالهم، وهذا كما تقول: افعل كذا وأنا مِن ورائك عضدًا. وكما تقول ذلك على التهديد: أنا من وراء التقصي عليك، ونحو هذا».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٦.
  45,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا هُدࣰىۖ وَٱلَّذِینَ كَفَرُوا۟ بِـَٔایَـٰتِ رَبِّهِمۡ لَهُمۡ عَذَابࣱ مِّن رِّجۡزٍ أَلِیمٌ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا هُدىً﴾</span> يقول: هذا القرآن بيان يهدي مِن الضَّلالة، <span class="qpc-hafs">﴿والَّذِينَ كَفَرُوا﴾</span> مِن أهل مكة <span class="qpc-hafs">﴿بِآياتِ رَبِّهِمْ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿لَهُمْ عَذابٌ مِن رِجْزٍ ألِيمٌ﴾</span> يقول: لهم عذاب من العذاب الوجيع في جهنم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٦.
  45,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱللَّهُ ٱلَّذِی سَخَّرَ لَكُمُ ٱلۡبَحۡرَ لِتَجۡرِیَ ٱلۡفُلۡكُ فِیهِ بِأَمۡرِهِۦ وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكّرهم النِّعَم، فقال: <span class="qpc-hafs">﴿اللَّهُ الَّذِي سَخَّرَ لَكُمُ البَحْرَ لِتَجْرِيَ الفُلْكُ فِيهِ﴾</span> يقول: لكي تجري السفنُ في البحر <span class="qpc-hafs">﴿بِأَمْرِهِ﴾</span> يعني: بإذنه، <span class="qpc-hafs">﴿ولِتَبْتَغُوا﴾</span> ما في البحر <span class="qpc-hafs">﴿مِن فَضْلِهِ﴾</span> يعني: الرزق، <span class="qpc-hafs">﴿ولَعَلَّكُمْ﴾</span> يعني: ولكي <span class="qpc-hafs">﴿تَشْكُرُونَ﴾</span> اللهَ في هذه النِّعَم فتوحّدوه{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٨٣٦-٨٣٧.
  45,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَسَخَّرَ لَكُم مَّا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِ جَمِیعࣰا مِّنۡهُۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٠٢٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق سفيان- في قوله: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span>، قال: الخلْق من خمسة: مِن نار، ونور، وظُلمة، وماء، وتراب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنّه لم يكن يفسّر أربع آيات: قوله: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span>، والرَّقيم، والغِسلين{2}. (١٣/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٢٧<span class="dash">-</span></span> عن عكرمة، قال: لم يفسّر <span class="name-1">ابن عباس</span> هذه الآية إلا لندبة القارئ: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span>{3}. (١٣/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span>، قال: منه النور، والشمس، والقمر{4}. (١٣/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span>، قال: كلّ شيء هو مِن الله، وذلك الاسم فيه اسم مِن أسمائه، فذلك جميعًا منه، ولا ينازعه فيه المنازعون، واستيقِنْ أنه كذلك{5}. (١٣/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٣٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿جَمِيعًا مِنهُ﴾</span> كلّ ذلك رحمة منه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٠٢٣١<span class="dash">-</span></span> عن طاووس، قال: جاء رجل إلى عبد الله بن عمرو بن العاص، فسأله: مِمَّ خُلِق الخلْق؟ قال: من الماء، والنور، والظلمة، والريح، والتراب. قال: فمِمَّ خُلق هؤلاء؟ قال: لا أدري. ثم أتى الرجل عبدَ الله بن الزبير، فسأله، فقال مثل قول عبد الله بن عمرو، فأتى ابنَ عباس، فسأله: مم خُلق الخلْق؟ قال: مِن الماء، والنور، والظلمة، والريح، والتراب. قال: فمِمَّ خُلق هؤلاء؟ فقرأ <span class="name-1">ابن عباس</span>: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span>. فقال الرجل: ما كان ليأتي بهذا إلا رجلٌ مِن أهل بيت النبيِّ ﷺ{7}<span class=comment-ref>٥٩٣٩</span>. (١٣/٢٩٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٩٣٩</span> قال <u>ابن كثير</u> (٧/٢٥١): «هذا أثرٌ غريب، وفيه نكارة».</div></p><p><div></p><p><p><span class="item-no">٧٠٢٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمْ ما فِي السَّماواتِ وما فِي الأَرْضِ جَمِيعًا مِنهُ﴾</span> يعني: من الله، <span class="qpc-hafs">﴿إنَّ فِي ذلِكَ لَآياتٍ لِقَوْمٍ يَتَفَكَّرُونَ﴾</span> في صُنع الله فيوحّدونه{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه سفيان الثوري ص٢٧٥.|2:أخرجه إسحاق البستي ص٣٣٦ دون ذكر الرقيم والغسلين. وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:أخرجه عبد الرزاق ٢/٢١٣، وأبو الشيخ في العظمة (٦٨٧). وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|5:أخرجه ابن جرير ٢١/٧٩.|6:تفسير البغوي ٧/٢٤٢.|7:أخرجه عبد الرزاق ٢/٢١٣ عن حميد الأعرج، والحاكم ٢/٤٥٢، والبيهقي في الأسماء والصفات (٨٢٩). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:تفسير مقاتل بن سليمان ٣/٨٣٧.