quran[9]{c,v,t}:
  12,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَهَّزَهُم بِجَهَازِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- وفي قوله: <span class="qpc-hafs">﴿فلما جَهَّزَهُم بِجَهازِهِم﴾</span>، قال: لَمّا قَضى حاجتَهم، وكال لهم طعامَهم{1}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا جَهَّزَهُمْ بِجَهازِهِمْ﴾</span>، يقول: فلمّا قضى في أمر الطعام حاجتهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ جَهَّزَهم بجهازهم، وأكرمهم، وأعطاهم، وأوفاهم، وحمل لهم بعيرًا بعيرًا، وحمل لأخيه بعيرًا باسمه كما حمل لهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَعَلَ ٱلسِّقَایَةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿جعل السقاية﴾</span>، قال: هو الصُّواع، وكلُّ شيء يُشْرَب منه فهو صُواع{4}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿جعل السقاية﴾</span>، قال: كانَتْ مِن زَبَرْجَد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٥<span class="dash">-</span></span> عن عبيد بن سليمان، قال: سمعتُ <span class="name-2">الضَّحّاك بن مُزاحِم</span> يقول في قوله: <span class="qpc-hafs">﴿جعل السقاية﴾</span>: هو الإناء الذي كان يَشْرَبُ فيه الملِك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- قال: السقاية: إناؤه الذي يشرب فيه، وكان مِن فِضَّة{7}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- وفي قوله:<span class="qpc-hafs">﴿جعل السقاية﴾</span>، قال: هو إناء المَلِك الذي يشرب مِنه{8}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جَعَلَ السِّقايَةَ﴾</span>، وهي الإناءُ الذي يشرب به الملِكُ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٧٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ أمر بسِقاية الملك، وهو الصُّواع، وزعموا: أنّها كانت مِن فِضَّة{10}<span class=comment-ref>٣٤١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٢٠) أنّ القول -الذي قاله عكرمة، وابن إسحاق- بأنّ الصواع كان من فضة، هو قول الجمهور.</p><p>وذكر <u>ابنُ كثير</u> (٨/٥٨) أنّه قول الأكثرين.</div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: السِّقاية: هو الصُّواع. وكان كأسًا مِن ذَهَب -فيما يذكرون-{11}. (٨/٢٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی رَحۡلِ أَخِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٨١<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: لَمّا قال له يوسف: إني أنا أخوك. قال بنيامين: أنا لا أُفارِقُك. فقال له يوسف: قد عَلِمْت اغتمامَ والدي بي، وإذا حَبَسْتُكَ ازداد غَمُّه، ولا يمكنني هذا إلا بعد أن أُشْهِرَكَ{12} بأمرٍ فظيعٍ، وأَنسِبَك إلى ما لا يُحْمَد. قال: لا أُبالِي؛ فافْعَل ما بَدا لكَ، فإنِّي لا أُفارِقُكَ. قال: فإنِّي أدُسُّ صاعي في رَحْلِك، ثُمَّ أنادي عليكم بالسَّرِقَة، لِيُهَيَّأ لي رَدُّك بعد تسريحك. قال: فافعل. فذلك قوله تعالى: <span class="qpc-hafs">﴿فلما جهزهم بجهازهم جعل السقاية في رحل أخيه﴾</span>{13}<span class=comment-ref>٣٤١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١١</span> على هذا القول فيوسف ﵇ تَعَمَّد هذا الفعلَ ليأخذ أخاه، وهو ما <span class="comment-type-4">علّق</span> عليه <u>ابنُ عطية</u> (٥/١١٩) بقوله: <span class="mustanad">«ويقويه قوله تعالى</span>: <span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span>». و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> قولين آخرين: <b>الأول</b>: أنّه أُوحي إلى يوسف أن يجعل السقاية فقط، ثم إنّ حافظها فقدها، فنادى على ما ظهر إليه. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للسياق</span>، فقال: «وتفتيش الأوعية يَرُدُّ عليه». <b>الثاني</b>: أنهم لما كانوا قد باعوا يوسف استجاز أن يُقال لهم هذا، وإنّه عُوقِب على ذلك بأن قالوا: <span class="qpc-hafs">﴿فقد سرق أخ له من قبل﴾</span>.</div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- وفي قوله: <span class="qpc-hafs">﴿في رحل أخيه﴾</span>، قال: في متاع أخيه{14}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿فلما جَهَّزَهُم بِجَهازِهِم جعل السقاية في رحل أخيه﴾</span>، والأخ لا يَشْعُر{15}<span class=comment-ref>٣٤١٢</span>. (٨/١٩٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٢</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٥/١٢٠) قول السدي بقوله: «وهو الظاهر». ولم يذكر مستندًا.</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ القيم</u> (٢/٧٠) <span class="mustanad">لدلالة العقل، وقول الأكثر</span>، فقال: «هذا خلاف المفهوم من القرآن، وخلاف ما عليه الأكثرون، وفيه تَرْوِيعٌ لِمَن لم يَسْتَوْجِبِ الترويعَ».</div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي رَحْلِ أخِيهِ﴾</span> بنيامين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: فجُعِلَت في رحل أخيه بِنيامين{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ أَذَّنَ مُؤَذِّنٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وأنا به زعيم﴾</span>، قال: الزَّعِيم هو المُؤَذِّن الذي قال: <span class="qpc-hafs">﴿أيتها العير﴾</span>{18}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلمّا ارتحلوا <span class="qpc-hafs">﴿أذن مؤذن﴾</span> قبل أن يَرْتَحِلَ العِير: <span class="qpc-hafs">﴿أيتها العير إنكم لسارقون﴾</span>{15}. (٨/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ أذَّنَ مُؤَذِّنٌ﴾</span> يعني: نادى مُنادٍ، اسمُه: بعرايم بن بربري، مِن فتيان يوسف: <span class="qpc-hafs">﴿أيَّتُها العِيرُ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٨٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ أمْهَلَهم، حتى إذا انطلقوا فأَمْعَنُوا مِن القرية أمَرَ بهم، فأُدرِكوا، فاحْتُبِسُوا، ثم نادى منادٍ: <span class="qpc-hafs">﴿أيتها العير إنكم لسارقون﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَیَّتُهَا ٱلۡعِیرُ إِنَّكُمۡ لَسَـٰرِقُونَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿أيتها العير﴾</span>، قال: كانتِ العِيرُ حميرًا{22}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أيَّتُها العِيرُ﴾</span> يعني: الرِّفْقَة <span class="qpc-hafs">﴿إنَّكُمْ لَسارِقُونَ﴾</span>. فانقَطَعَتْ ظهورُهم، وساء ظَنُّهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ نادى مُنادٍ: <span class="qpc-hafs">﴿أيتها العير إنكم لسارقون﴾</span>، قِفُوا. وانتهى إليهم رسولُه، فقال لهم -فيما يذكرون-: ألم نُكْرِم ضيافتَكم، ونُوَفِّكم كيلَكم، ونُحْسِن منزلتَكم، ونفعل بكم ما لم نفعل بغيركم، وأدخلناكم علينا في بيوتنا ومنازلنا؟ أو كما قال لهم، قالوا: بلى، وما ذاك؟ قال: سِقايَةُ الملِك فَقَدْناها، ولا نَتَّهِمُ عليها غيرَكم. قالوا: <span class="qpc-hafs">﴿تالله لقد علمتم ما جئنا لنفسد في الأرض وما كنا سارقين﴾</span>{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٢٤٤، وابن أبي حاتم ٧/٢١٧٠-٢١٧١ من طريق سعيد بن بشير. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧١.أخرجه ابن أبي حاتم ٧/٢١٧١. وعزاه السيوطي إلى ابن الأنباري في المصاحف.تفسير البغوي ٤/٢٦٠.أخرجه ابن جرير ١٣/٢٤٦.أخرجه ابن أبي حاتم ٧/٢١٧١.أخرجه ابن جرير ١٣/٢٤٥، وابن أبي حاتم ٧/٢١٧٠-٢١٧١. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧.أخرجه ابن جرير ١٣/٢٤٦، وابن أبي حاتم ٧/٢١٧١ من طريق أصبغ.الشُّهْرَةُ: ظهور الشيء في شُنْعة حتى يَشْهَرَهُ الناس. النهاية (شهر).تفسير الثعلبي ٥/٢٣٩، وتفسير البغوي ٤/٢٦٠.أخرجه ابن جرير ١٣/٢٤٢-٢٤٦، وابن أبي حاتم ٧/٢١٧٠-٢١٧١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧٢.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧.أخرجه ابن جرير ١٣/٢٥٣، وابن أبي حاتم ٧/٢١٧٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧٢.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧.أخرجه ابن جرير ١٣/٢٤٨، وابن أبي حاتم ٧/٢١٧٢-٢١٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧٢-٢١٧٣.
  12,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ وَأَقۡبَلُوا۟ عَلَیۡهِم مَّاذَا تَفۡقِدُونَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>-من طريق أسباط- قال: فانقطعت ظهورهم، <span class="qpc-hafs">﴿وأقبلوا عليهم﴾</span> يقولون: <span class="qpc-hafs">﴿ماذا تفقدون﴾</span>{1}. (٨/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فـ<span class="qpc-hafs">﴿قالُوا وأَقْبَلُوا عَلَيْهِمْ﴾</span>، فيها تقديم، يقول: وأقبلوا على المنادي، ثم قالوا: <span class="qpc-hafs">﴿ماذا تَفْقِدُونَ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٤.
  12,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ نَفۡقِدُ صُوَاعَ ٱلۡمَلِكِ وَلِمَن جَاۤءَ بِهِۦ حِمۡلُ بَعِیرࣲ وَأَنَا۠ بِهِۦ زَعِیمࣱ ۝٧٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٧٩٥<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق العبّاس بن عبد الرحمن- أنّه كان يقرأ: (صاعَ المَلِكِ){1}<span class=comment-ref>٣٤١٣</span>. (٨/٢٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٣</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٣/٢٤٩) على هذه القراءةِ بقوله: «كأنّه وجَّهه إلى الصاعِ الذي يُكال به الطعام».</div></p><p><div></p><p><p><span class="item-no">٣٧٧٩٦<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يعمر</span> -من طريق غالب الليثي- أنّه كان يقرؤها: (صُوغَ المَلِكِ) بالغين المعجمة. قال: كان صيغ مِن ذهب أو فضة ...{2}<span class=comment-ref>٣٤١٤</span>. (٨/٢٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٤</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٣/٢٤٩) على قراءة يحيى بن يعمر بقوله: «كأنّه وجَّهه إلى أنّه مصدر مِن قولهم: صاغ يصوغ صوغًا».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u> (٥/١٢١) بقوله: «وهذا على أنّه الشيء المصوغ للملك، على ما روي أنّه كان من ذهب أو مِن فضة، فهو مَصْدَرٌ سُمِّي به».</div></p><p><div></p><p><p><span class="item-no">٣٧٧٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه كان يقرأ: <span class="qpc-hafs">﴿نَفْقِدُ صُواعَ المَلِكِ﴾</span> بضم الصّاد، مع الألف{3}. (٨/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٩٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه كان يقرأ: (صُياعَ المَلِكِ){4}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧٩٩<span class="dash">-</span></span> عن <span class="name-2">أبي رجاء [العُطارِدِيِّ]</span> أنه قرأ: (نَفْقِدُ صَواعَ المَلِكِ) بعين غير معجمة، وصاد مفتوحة{5}. (٨/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عون</span> أنّه كان يقرأ: (صُوعَ المَلِكِ) بصاد مضمومة{6}<span class=comment-ref>٣٤١٥</span>. (٨/٢٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٥</span> ساق <u>ابنُ عطية</u> (٥/١٢١) هذه القراءات، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذه لُغاتٌ في المكيال. قاله أبو الفتحِ وغيره».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٣/٢٤٩) قراءة:<span class="qpc-hafs">﴿صُواع﴾</span> <span class="mustanad">مستندًا إلى إجماع القراء</span>، فقال: «وأمّا الذي عليه قراء الأمصار: فـ<span class="qpc-hafs">﴿صُواع الملك﴾</span>، وهي القراءة التي لا أستجيز القراءةَ بخلافها؛ لإجماع الحُجَّة عليها».</div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ نَفۡقِدُ صُوَاعَ ٱلۡمَلِكِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿صواع الملك﴾</span>، قال: شيءٌ يشبه المَكُّوكَ مِن فِضَّة، كانوا يشربون فيه{7}. (٨/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق صدقة بن عبّاد، عن أبيه- في قوله: <span class="qpc-hafs">﴿صواع الملك﴾</span>، قال: كان مِن نُحاس{8}. (٨/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿صواع الملك﴾</span>. قال: الصُّواع: الكأس الذي يُشْرَب فيه. قال: وهل تعرف العرب ذلك؟ قال: نعم. أما سمعت الأعشى وهو يقول:</p><p>له دَرْمَكٌ في رأسه ومشارِب وقِدر وطبّاخ وصاع ودَيْسَقُ{9}. (٨/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٤<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يعمر</span> -من طريق غالب الليثي- أنّه كان يقرؤها: (صُوغَ الملك) بالغين المعجمة. قال: كان صِيغ مِن ذهب أو فضة، سقايته التي كان يشرب فيها{10}. (٨/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿صواع الملك﴾</span>، قال: هو المَكُّوك الفارسِيُّ الذى يلتقى طرفاه، كانت تشرب فيه الأعاجِم{11}. (٨/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- أنّه قرأ: <span class="qpc-hafs">﴿صُواع الملك﴾</span>، قال: وكان إناءه الذي يشرب فيه، وكان إلى الطول ما هو{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: السِّقاية والصُّواع شيء واحد، يَشْرَب منه يوسفُ{13}. (٨/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قال: إناءُ المَلِك الذي كان يشرب فيه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٠٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- في قوله: <span class="qpc-hafs">﴿صواع الملك﴾</span>، قال: كان مِن فِضَّة{15}. (٨/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- أنّه كان يقول: الصُّواع والسِّقاية سواء، هو الإناء الذي يُشْرَب فيه{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١١<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق أبي بشر الوليد بن محمد، هو الموقري- في قول الله: <span class="qpc-hafs">﴿نفقد صواغ الملك﴾</span>، قال: القَدَح{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> المنادي ومَن معه، لإخوة يوسف: <span class="qpc-hafs">﴿نَفْقِدُ صُواعَ المَلِكِ﴾</span> يعني: إناء المَلِك، وكان يُكال به، كفِعْل أهلِ العساكر{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>: <span class="qpc-hafs">﴿نَفْقِدُ صُواعَ المَلِكِ﴾</span>، قال: إناءُ المَلِك الذي يشرب فيه{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِمَن جَاۤءَ بِهِۦ حِمۡلُ بَعِیرࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولِمَن جاء به حِملُ بعير﴾</span>، قال: حِمْل حمارٍ طَعامٌ، وهي لغة{20}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿حمل بعير﴾</span>، أي: وِقْرُ بعير{21}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِمَن جاءَ بِهِ حِمْلُ بَعِيرٍ﴾</span>، يعني: وِقْر بعير{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَا۠ بِهِۦ زَعِیمࣱ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وأنا به زعيم﴾</span>، ما الزعيم؟ قال: الكَفيل. قال فيه فَروة بن مُسَيْكٍ:</p><p>أكون زعيمَكم في كُلِّ عام بجيش جَحْفَلٍ لَجِبٍ لُهامِ{23}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضَّحّاك بن مُزاحِم-: أنّ نافع بن الأزرق قال له: فأخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿وأنا به زعيم﴾</span>، [قال]: الزعيم: الكفيل. قال: وهل كانت العرب تعرفُ ذلك قبل أن ينزِل الكتابُ على محمد ﷺ؟ قال: نعم، أما سمعت قول امرئ القيس:</p><p>وإنِّي زعيم إن رَجَعْتُ مُمَلَّكًا بسير ترى منه الفرانِقُ أزْوِرا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأنا به زعيم﴾</span>، يقول: كفيل{25}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق ورْقاء بن إياس-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢١<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٢<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر، وعبيد-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٣<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر، وسعيد-، مثله{26}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأنا به زعيم﴾</span>، قال: الزعيم: هو المُؤَذِّن الذي قال: <span class="qpc-hafs">﴿أيتها العير﴾</span>{27}. (٨/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: إنّ فتى يوسف -وهو المُؤَذِّن- قال لهم: إنّ الملِكَ ائْتَمَنَنِي بالصّاع، وأخاف عقوبة الملك، فلي اليوم عنده مَنزِلَةٌ حَسَنَة، فإن لم أجدْه تَخَوَّفْتُ أن تسقط منزلتي، وأفتضح في مصر{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنا بِهِ زَعِيمٌ﴾</span>، يعني: به كفِيل{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال لهم الرسول: إنّه مَن جاءنا به فله حِمْل بعير، وأنا به كفيل بذلك، حتى أُؤدِّيَه إليه{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٢٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>: <span class="qpc-hafs">﴿وأنا به زعيم﴾</span>، قال: كَفِيل{31}<span class=comment-ref>٣٤١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٦</span> ساق <u>ابنُ جرير</u> (١٣/٢٥٥) هذا القول، ثم <span class="comment-type-4">علّق</span> بقوله: "ومِن الزعيم الذي بمعنى الكفيل <span class="mustanad">قولُ الشاعر</span>:</p><p>فلست بآمِرٍ فيها بسِلْمٍ ... ولكنِّي على نفسي زعيم</p><p>وأصل الزعيم <span class="mustanad">في كلام العرب</span>: القائمُ بأمر القوم. وكذلك الكفيل، والحميل، ولذلك قيل: رئيس القوم زعيمهم ومدبرهم، يقال منه: قد زعم فلان زعامة وزعامًا، <span class="mustanad">ومنه قول ليلى الأخْيَلية</span>:</p><p>حتى إذا برز اللواءُ رأيته ... تحت اللواء على الخميس زعيما".</div></p></div>",footnotes:1:أخرجه سعيد بن منصور (١١٣٦ - تفسير). وعزاه السيوطي إلى ابن الأنباري.</p><p>وهي قراءة شاذة، تروى أيضًا عن جماعة. انظر: مختصر ابن خالويه ص٦٩، والمحتسب ١/٣٤٦.أخرجه ابن أبي حاتم ٧/٢١٧٣. وعزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة شاذة، تروى أيضًا عن عبد الله بن عون، وأبي حيوة. انظر: مختصر ابن خالويه ص٦٩.أخرجه ابن جرير ١٣/٢٥٠. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>وهي قراءة العشرة.عزاه السيوطي إلى ابن الأنباري.</p><p>وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١١/٤٠٥.عزاه السيوطي إلى ابن الأنباري.</p><p>وهي قراءة شاذة. انظر: مجمع البيان ٥/٢٥٠.عزاه السيوطي إلى ابن الأنباري.</p><p>وهي قراءة شاذة، تروى أيضًا عن عبد الله بن عون. انظر: المحتسب ١/٣٤٦.أخرجه ابن جرير ١٣/٢٤٩-٢٥٠ وزاد: وكان للعباس منها واحدًا في الجاهلية، وابن أبي حاتم ٧/٢١٧٣، وابن مردويه -كما في فتح الباري ٨/٣٥٩-، والضياء ١٠/٩٥ (٩٣). وعزاه السيوطي إلى ابن منده، وابن المنذر، وابن الأنباري، وأبي الشيخ، وابن منده في غرائب شعبة، وابن مردويه.أخرجه ابن جرير ١٣/٢٥١-٢٥٢. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء، والطستي.أخرجه ابن أبي حاتم ٧/٢١٧٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٥٠، وابن أبي حاتم ٧/٢١٧٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٥٠.أخرجه ابن جرير ١٣/٢٤٥، وابن أبي حاتم ٧/٢١٧١. وعزاه السيوطي إلى ابن المنذر، وابن الأنباري.أخرجه ابن جرير ١٣/٢٥٠-٢٥١، وابن أبي حاتم ٧/٢١٧٣.أخرجه ابن جرير ١٣/٢٥٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٤٥.أخرجه ابن أبي حاتم ٧/٢١٧٣.تفسير مقاتل بن سليمان ٢/٣٤٤.تفسير الثوري ص١٤٤.أخرجه ابن جرير ١٣/٢٥٢، وابن أبي حاتم ٧/٢١٧٣-٢١٧٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٥٢، وابن أبي حاتم ٧/٢١٧٣-٢١٧٤.تفسير مقاتل بن سليمان ٢/٣٤٤.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه ابن جرير ١٣/٢٥٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٢٥٣-٢٥٤.أخرجه ابن جرير ١٣/٢٥٣، وابن أبي حاتم ٧/٢١٧٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ٥/٢٤٠.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٥٥.تفسير الثوري ص١٤٥.
  12,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ تَٱللَّهِ لَقَدۡ عَلِمۡتُم مَّا جِئۡنَا لِنُفۡسِدَ فِی ٱلۡأَرۡضِ وَمَا كُنَّا سَـٰرِقِینَ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٢٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿ما جئنا لنفسد في الأرض﴾</span>، يقول: ما جِئنا لِنَعْصِيَ في الأرض{1}. (٨/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدُّ الإخوة القولَ على المنادي: <span class="qpc-hafs">﴿قالُوا تاللَّهِ لَقَدْ عَلِمْتُمْ ما جِئْنا لِنُفْسِدَ فِي الأَرْضِ﴾</span> يعني: أرض مصر بالمعاصي، <span class="qpc-hafs">﴿وما كُنّا سارِقِينَ﴾</span> وقد رددنا عليكم الدراهمَ التي كانت في أوعيتنا، ولو كُنّا سارقين ما رَدَدْناها عليكم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٢٥٦، وابن أبي حاتم ٧/٢١٧٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.
  12,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ فَمَا جَزَ ٰ⁠ۤؤُهُۥۤ إِن كُنتُمۡ كَـٰذِبِینَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> أي: المُنادي ومَن معه: <span class="qpc-hafs">﴿فَما جَزاؤُهُ﴾</span> أي: السارق؛ <span class="qpc-hafs">﴿إنْ كُنْتُمْ كاذِبِينَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ- في قوله: <span class="qpc-hafs">﴿قالوا فما جزاؤه﴾</span>، قال: عَرَّفوا الحكم في حُكْمِهم{2}. (٨/٢٩٢)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٦٦ من طريق ابن وهب بمعناه، وابن أبي حاتم ٧/٢١٧٤ من طريق أصبغ.
  12,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ جَزَ ٰ⁠ۤؤُهُۥ مَن وُجِدَ فِی رَحۡلِهِۦ فَهُوَ جَزَ ٰ⁠ۤؤُهُۥۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿قالُوا جَزاؤُهُ مَن وُجِدَ فِي رَحْلِهِ فَهُوَ جَزاؤُهُ﴾</span>، قال: كانوا أخبروه بما يُحْكَم في بلادهم أنّه مَن سرق ضُعِّفَ عليه الغُرْم، ولم يُؤْخَذ عبدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قوله: <span class="qpc-hafs">﴿قالوا فما جزاؤه إن كنتم كاذبين*قالوا جزاؤه من وجد في رحله فهو جزاؤه﴾</span>، يقول: تأخذونه؛ فهو لكم{2}. (٨/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- قال: أخبَرُوه بما يُحْكَم في بلادهم؛ أنّه مَن سَرَق أُخِذ عبدًا، فقالوا: <span class="qpc-hafs">﴿جزاؤه من وجد في رحله﴾</span>{3}. (٨/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا جَزاؤُهُ مَن وُجِدَ فِي رَحْلِهِ﴾</span> يعني: في وعائه، يعني: المتاع <span class="qpc-hafs">﴿فَهُوَ جَزاؤُهُ﴾</span> يعني: هو مكان سرقته. وكان الحُكْمُ بأرض مصر أن يُغَرَّم السارِق عبدًا يُسْتَخْدَم على قدر ضِعْفِ ما سرق ويُتْرَك، وكان الحكم بأرض كنعان أن يُتَّخَذ السارِق عبدًا يُسْتَخْدَم على قدر سرقته، ثُمَّ يُخَلّى سبيله، فيَذْهَب حيث شاء. فحكموا بأرضِ مصر بقضاء أرضهم{4}<span class=comment-ref>٣٤١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٧</span> نسب <u>ابنُ عطية</u> (٥/١٢٣) هذا القول للسدي، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للدلالة العقلية</span>، فقال: «وهذا يضعفه رجوع الصواع، فكان ينبغي ألا يؤخذ بنيامين إذ لم يبق فيما يخدم».</div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فهو جزاؤه﴾</span>، أي: سُلِّمَ به{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٨<span class="dash">-</span></span> عن <span class="name-3">مَعْمَر بن راشد</span> -من طريق عبد الرزاق- قال: بلغنا في قوله: <span class="qpc-hafs">﴿قالوا فما جزاؤه إن كنتم كاذبين﴾</span>: أخبروا يوسف بما يُحْكَم في بلادهم؛ أنّه مَن سُرِق أُخِذَ عبدًا، فقالوا: <span class="qpc-hafs">﴿جزاؤه من وجد في رحله فهو جزاؤه﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- فقالوا: <span class="qpc-hafs">﴿جزاؤه من وجد في رحله فهو جزاؤه﴾</span>، وكان الحُكْمُ عند الأنبياء -يعقوب وبنيه ﵈ أن يُؤْخَذ السارِقُ بسرقته عبدًا، يُسْتَرَقُّ{7}<span class=comment-ref>٣٤١٨</span>. (٨/٢٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٢٣) أنّه <b>قيل</b> بأنّ الحُكم باسترقاق السّارق كان في أول الإسلام ثم نُسِخ بالقطع، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لمخالفته الواقع</span>، فقال: «وهذا ضعيف، ما كان قطُّ فيما عَلِمْتُ».</div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نَجۡزِی ٱلظَّـٰلِمِینَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ نَجْزِي الظّالِمِينَ﴾</span>، يعني: هكذا نجزي السارقين. كقوله في المائدة [٣٩]: <span class="qpc-hafs">﴿فَمَن تابَ مِن بَعْدِ ظُلْمِهِ﴾</span>، يعني: بعد سَرِقَته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٤١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿كذلك نجزي الظالمين﴾</span>، أي: كذلك نصنع بِمَن سَرَق مِنّا{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٣٢٦.أخرجه ابن جرير ١٣/٢٥٨، وابن أبي حاتم ٧/٢١٧٤.أخرجه عبد الرزاق ١/٣٢٦، وابن جرير ١٣/٢٥٨ عن معمر قال: بلغنا. ولم يذكر الكلبي. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٥٧، وابن أبي حاتم ٧/٢١٧٤-٢١٧٥.أخرجه ابن جرير ١٣/٢٥٨.أخرجه ابن جرير ١٣/٢٦٦ عند قوله: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، وابن أبي حاتم ٧/٢١٧٤ من طريق أصبغ بلفظ: عرفوا الحكم في حكمهم. وقد سبق.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٥٧، وابن أبي حاتم ٧/٢١٧٥.
  12,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَبَدَأَ بِأَوۡعِیَتِهِمۡ قَبۡلَ وِعَاۤءِ أَخِیهِ ثُمَّ ٱسۡتَخۡرَجَهَا مِن وِعَاۤءِ أَخِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فبدأ بأوعيتهم﴾</span> الآية، قال: ذُكِر لنا: أنّه كان كُلَّما فتح متاعَ رجل استغفر تأثُّمًا مِمّا صَنَعَ، حتى بقي متاعُ الغلام، قال: ما أظُنَّ أنّ هذا أخذ شيئًا. قالوا: بلى، فاستَبْرِه{1}{2}<span class=comment-ref>٣٤١٩</span>. (٨/٢٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٣٤١٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٢٤-١٢٥) أنّ ظاهر كلام قتادة وغيره أنّ المستغفر كان يوسف؛ لأنّه كان يُفَتِّشهم ويعلم أين الصواع، حتى فرغ منهم، وانتهى إلى رحل بنيامين. ثُمَّ بيَّن أنّ هذا التفتيش من يوسف يقتضي أمرين: <b>الأول</b>: أنّ المؤذن إنّما سرقه برأيه. <b>الثاني</b>: أن يُقال: جميع ذلك كان بأمر الله تعالى. و<span class="comment-type-4">علَّق</span> عليه بقوله: <span class="mustanad">«ويُقَوِّي ذلك قوله</span>: <span class="qpc-hafs">﴿كدنا﴾</span>، وكيف لا يكون برأي يوسف وهو مُضطَرٌّ في محاولته إلى أن يلزمهم حكم السرقة؛ لِيَتِمَّ له أخذُ أخيه».</div></p><p><div></p><p><p><span class="item-no">٣٧٨٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>-من طريق أسباط- قال: <span class="qpc-hafs">﴿فبدأ بأوعيتهم قبل وعاء أخيه﴾</span>، فلمّا بقي رَحْلُ الغلام قال: ما كان هذا الغلام ليأخُذَها. قالوا: واللهِ، لا يُتْرَكُ حتى تنظر في رحله؛ ونذهب وقد طابت نفسُك. فأدخل يدَه في رحله، فاستخرَجها مِن رحل أخيه، ... فلمّا استخرجها مِن رحل الغلامِ انقَطَعَتْ ظهورُهم، وهلكوا، وقالوا: ما يزال لنا منكم بلاءٌ يا بني راحيل، متى أخذتَ هذا الصُّواع؟! قال بنيامين: بل بنو راحيل الذين لا يزال لهم منكم بلاء، ذهبتم بأخي فأهلكتموه في البَرِّيَّة، وما وضع هذا الصُّواعَ في رحلي إلا الذي وضع الدراهم في رِحالكم. قالوا: لا تَذْكُرِ الدراهمَ فنُؤْخَذ بها. فوقعوا فيه، وشتموه، فلمّا أدخلوهم على يوسف دعا بالصُّواع، ثُمَّ نَقَر فيه، ثم أدناه مِن أُذُنِه، ثم قال: إنّ صُواعِي هذا لَيُخبِرني أنّكم كنتم اثني عشر أخًا، وأنّكم انطلقتم بأخٍ لكم فبِعْتُمُوه. فلمّا سمعها بنيامين قام فسَجَد ليوسف، وقال: أيُّها المَلِك، سل صُواعَك هذا: أحَيٌّ أخي ذاك أم لا؟ فنقرها يوسف، ثم قال: نعم هو حَيٌّ، وسوف تراه. قال: اصنع بي ما شئت، فإنه إن عَلِم بي اسْتَنقَذَني. فدخل يوسف، فبكى، ثُمَّ تَوَضَّأ، ثم خرج. فقال بنيامين: أيها الملِك، إنِّي أراك تضرب بصواعك فيُخبِرُكَ بالحق، فسَلْه مَن صاحبه؟ فنقر فيه، ثم قال: إن صواعي هذا غضبان، يقول: كيف تسألني مَن صاحبي وقد رأيتَ مَعَ مَن كنتُ؟ وكان بنو يعقوب إذا غضبوا لم يُطاقوا، فغَضِب روبيل، فقام، فقال: أيها الملك، واللهِ، لَتَتْرُكَنّا أو لَأَصِيحَنَّ صيحةً لا تبقى امرأةٌ حامِلٌ بمصر إلا طَرَحَتْ ما في بطنها. وقامتْ كلُّ شَعَرة مِن جسد روبيل، فخرجت مِن ثيابه، فقال يوسف لابنه{3}: مُرَّ إلى جنب روبيل، فمُسَّه. وكان بنو يعقوب إذا غضب أحدهم فمَسَّه الآخَرُ ذَهِب غضبُه، فمَرَّ الغلامُ إلى جانبه، فمَسَّه، فذهب غَضَبُه، فقال روبيل: مَن هذا؟! إنّ في هذه البلاد لَبزْرًا من بَزْرِ{4} يعقوب. قال يوسف: ومَن يعقوب؟ فغضِب روبيل، فقال: يأيُّها المَلِك، لا تَذْكُرَنَّ يعقوب؛ فإنّه سَرِيُّ الله، ابن ذبيح الله، ابن خليل الله. فقال يوسف: أنت إذن إن كنت صادِقًا{5}. (٨/١٩٦-١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: ذُكِر لنا: أنّه كان كُلَّما بَحَثَ متاعَ رجل منهم استغفر ربَّه تَأَثُّمًا، قد علم أين موضع الذي يطلب، حتى إذا بقي أخوه وعلم أنّ بُغْيَتَه فيه قال: لا أرى هذا الغلامَ أخذه، ولا أُبالِي أن لا أبحث متاعَه. قال إخوتُه: إنّه أطيب لنفسك وأنفسنا أن تستبرئ متاعَه أيضًا. فلمّا فتح متاعَه استخرج بُغْيَتَه منه، قال الله:<span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَبَدَأَ﴾</span> المنادي <span class="qpc-hafs">﴿بِأَوْعِيَتِهِمْ﴾</span>، فنظر فيها، فلم يَرَ شيئًا <span class="qpc-hafs">﴿قَبْلَ وِعاءِ أخِيهِ﴾</span> ثم انصرف، ولم ينظر في وِعاء بِنيامين، فقال: ما كان هذا الغلامُ لِيَأْخُذَ الإناءَ. قال إخوته: لا نَدَعُك حتى تنظر في وِعائه؛ فيكون أطيبَ لنفسك. فنظر فإذا هو بالإناء، <span class="qpc-hafs">﴿ثُمَّ اسْتَخْرَجَها مِن وِعاءِ أخِيهِ﴾</span> يعني: مِن متاع أخيه، وهو أخو يوسف لأبيه وأُمِّه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٤٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا قال الرسولُ لهم: <span class="qpc-hafs">﴿ولمن جاء به حمل بعير وأنا به زعيم﴾</span> قالوا: ما نعلمه فينا، ولا معنا. قال: لَسْتُم ببارِحِينَ حتّى أُفَتِّش أمتعتكم، وأُعْذِرَ في طلبها منكم. فبدأ بأوعيتهم وعاءً وعاءً، يُفَتِّشها، وينظر ما فيها، حتى مَرَّ على وعاء أخيه، ففَتَّشه، فاستخرجها منه، فأخذ برقبته، فانصرف به إلى يوسف، يقول الله: <span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span>{6}<span class=comment-ref>٣٤٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٢٥) أنّ الضمير في قوله: <span class="qpc-hafs">﴿استخرجها﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يعود على السِّقاية. <b>الثاني</b>. أن يعود على السرقة.</div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ كِدۡنَا لِیُوسُفَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٤٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿كذلك كدنا﴾</span>، أي: صنعنا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٤٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span>، قال: كذلك صنعنا ليوسف{10}. (٨/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> - ن طريق أسباط- قال: يقول الله: <span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span>. يقول: صَنَعْنا ليوسف{11}. (٨/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٠<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span>، في قوله:<span class="qpc-hafs">﴿كذلك كدنا﴾</span>، قال: ألْهَمْنا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ كِدْنا﴾</span> يعني: هكذا صنعنا <span class="qpc-hafs">﴿لِيُوسُفَ﴾</span> أن يأخذ أخاه خادِمًا بسرقته{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قوله: <span class="qpc-hafs">﴿كذلك كدنا ليوسف﴾</span>، قال: صَنَعْنا{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا كَانَ لِیَأۡخُذَ أَخَاهُ فِی دِینِ ٱلۡمَلِكِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، يقول: في سُلْطان الملك{15}. (٨/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، يقول: في سلطان الملك. قال: كان في دِين ملكهم أنّه مَن سَرَق أُخِذَت منه السرقة، ومثلُها معها مِن ماله، فيعطيه المسروق{16}. (٨/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٥<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: كان الملكُ إذا أُتِي بسارِق كَشَف عن عرقوبيه، وسَمَل عينيه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، قال: لم يكن ذلك في دِين الملك؛ أن يأخذ مَن سَرَق عبدًا{18}. (٨/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿في دين الملك﴾</span>، قال: لم يكن ذلك في دِين الملك. قال: حُكْمه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي مودود المديني- في الآية، قال: دِين الملك لا يُؤْخَذ به مَن سرق أصلًا، ولكن الله كاد لأخيه حتى تكلَّموا بما تكلَّموا به، فأخذهم بقولهم، وليس في قضاء الملك{19}. (٨/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٥٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، يقول: في حُكْم الملك{21}. (٨/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- قال: كان حُكْمُ الملكِ أنّ مَن سرق ضاعف عليه الغُرْم{22}. (٨/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿في دين الملك﴾</span> يعني: في سلطان الملك، فذلك قوله: <span class="qpc-hafs">﴿ما كانَ لِيَأْخُذَ أخاهُ﴾</span> يعني: لِيَحْبِسَ أخاه <span class="qpc-hafs">﴿فِي دِينِ المَلِكِ﴾</span> يعني: حُكْمَ الملك؛ لأنّ حُكْمَ الملكِ أن يُغَرَّم السارقُ ضعفَ ما سرق، ثم يُتْرَك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، أي: بِظُلْم، ولكن اللهَ كاد ليوسف لِيَضُمَّ إليه أخاه{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، قال: في قضاء الملك مَن سَرَقَ اتَّخَذَه عبدًا{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>-من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، قال: ليس في دين الملك أن يُؤْخَذ السارِقُ بسرقته. قال: وكان الحُكْمُ عند الأنبياء -يعقوب وبنيه- أن يُؤْخَذَ السارِق بسرقته عبدًا يُسْتَرَقُّ{26}. (ز) (٨/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٥<span class="dash">-</span></span> عن <span class="name-3">مَعْمَر بن راشد</span> -من طريق عبد الرزاق- قال: بلغه في قوله: <span class="qpc-hafs">﴿ما كان ليأخذ أخاه في دين الملك﴾</span>، قال: كان حُكْمِ الملك أنّ مَن سرق ضُوعِف عليه الغُرْم{27}<span class=comment-ref>٣٤٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢١</span> اختُلِف في المراد بقوله: <span class="qpc-hafs">﴿دين الملك﴾</span> على قولين: <b>الأول</b>: أنّ المعنى: في سلطان الملك. <b>الثاني</b>: في حكمه وقضائه.</p><p>و<span class="comment-type-4">رأى</span> <u>ابنُ جرير</u> (١٣/٢٦٦) تقارب القولين، فقال: «وهذه الأقوال وإن اختلفت ألفاظ قائليها في معنى دين الملك فمُتقارِبة المعاني؛ لأنّ مَن أخذه في سلطان الملك عامَلَه بعَمَله، فيريناه أخذه إذا لم يغيره، وذلك منه حكم عليه، وحكمه عليه قضاؤه، وأصل الدين: الطاعة».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٥/١٢٣).</div></p><p><h3><span class="qpc-hafs">﴿إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إلا أن يشاء الله﴾</span>، قال: إلا بِعِلَّة كادها اللهُ ليوسفَ ﵇ فاعْتلَّ بها{28}. (٨/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿إلا أن يشاء الله﴾</span> ولكن صَنَعْنا له، بأنّهم قالوا: <span class="qpc-hafs">﴿فهو جزاؤه﴾</span>{29}. (٨/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا أنْ يَشاءَ اللَّهُ﴾</span> ذلك ليوسف{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَرۡفَعُ دَرَجَـٰتࣲ مَّن نَّشَاۤءُۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٦٩<span class="dash">-</span></span> عن مالك بن أنس، قال: سمعتُ <span class="name-2">زيدَ بن أسلم</span> يقول في هذه الآية: <span class="qpc-hafs">﴿نرفع درجات من نشاء﴾</span>. قال: بالعلم؛ يرفعُ الله بِهِ مَن يشاء في الدنيا{31}. (٨/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَرْفَعُ دَرَجاتٍ مَن نَشاءُ﴾</span>، يعني: فضائل يوسف حين أخَذَ أخاه{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿نرفع درجات من نشاء﴾</span>، قال: يوسف وإخوته أُوتُوا علمًا، فرفعنا يوسفَ فوقهم في العلم درجة{33}. (٨/٢٩٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَفَوۡقَ كُلِّ ذِی عِلۡمٍ عَلِیمࣱ ۝٧٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٧٢<span class="dash">-</span></span> عن قتادة: وفي قراءة <span class="name-1">عبد الله بن مسعود</span>: (وفَوْقَ كُلِّ عالِمٍ عَلِيمٌ){34}<span class=comment-ref>٣٤٢٢</span>. (٨/٢٩٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٢</span> <span class="comment-type-4">ذَكَرَ</span> <u>ابنُ عطية</u> (٥/١٢٤) أنّه قيل على هذه القراءة: إنّ <span class="qpc-hafs">﴿ذي﴾</span> زائدة. وقيل: (عالِمٍ) مصدر كالباطل.</div></p><p><h3><span class="qpc-hafs">﴿وَفَوۡقَ كُلِّ ذِی عِلۡمٍ عَلِیمࣱ ۝٧٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٧٣<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، قالت: أمَرَنا رسولُ الله ﷺ أن نُنَزِّل الناسَ منازلهم، مع ما نطق به القرآن مِن قول الله تعالى: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٤<span class="dash">-</span></span> عن محمد بن كعب، قال: سأل رجلٌ <span class="name-1">عليًّا</span> عن مسألةٍ، فقال فيها، فقال الرجل: ليس هكذا، ولكن كذا وكذا. قال علي: أصبتَ وأخطأتُ، <span class="qpc-hafs">﴿وفوق كل ذى علم عليم﴾</span>{36}. (٨/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وفوق كل ذى علم عليم﴾</span>، قال: يكون هذا أعلمَ مِن هذا، وهذا أعلم مِن هذا، واللهُ فوقَ كُلِّ عالم{37}. (٨/٢٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٦<span class="dash">-</span></span> عن سعيد بن جبير، قال: كُنّا عند <span class="name-1">ابن عباس</span>، فحدَّث بحديث، فقال رجل: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>. فقال ابنُ عباس: بِئْسَ ما قلتَ، اللهُ العليم الخبير هو فوق كُلِّ عالم{38}<span class=comment-ref>٣٤٢٣</span>. (٨/٢٩٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٣</span> ساق <u>ابنُ عطية</u> (٥/١٢٥) هذا القول، ثم <span class="comment-type-4">علّق</span> بقوله: «فبَيْن هذا وبين قول الحسن فَرْق».</div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عبد الأعلى- <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>، قال: اللهُ أعلمُ مِن كُلِّ أحد{39}. (٨/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>، قال: يعني الله بذلك نفسَه{40}. (٨/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٧٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خالد الحذّاء- في قوله: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>، قال: عِلمُ اللهِ فوق كُلِّ أحد{41}. (٨/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ابن شبرمة- في الآية، قال: ليس عالِمٌ إلا فوقَه عالِمٌ، حتى ينتهي العلمُ إلى الله{42}. (٨/٢٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨١<span class="dash">-</span></span> عن بشير الهُجَيْميِّ، قال: سمعتُ <span class="name-2">الحسن [البصري]</span> قرأ هذه الآية يومًا: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>، ثم وقف، فقال: إنّه -واللهِ- ما أمْسى على ظهر الأرض عالِمٌ إلا فوقه مَن هو أعلمُ منه، حتى يعود العِلْمُ إلى الذي علَّمه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>، قال: هكذا حتى ينتهي العلم إلى الله؛ مِنه بَدَأ، وإليه يعود{44}<span class=comment-ref>٣٤٢٤</span>. (٨/٢٩٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٢٤) أن معنى قوله: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>: أنّ البشر في العلم درجات، فكل عالم فلا بد من أعلم منه؛ فإما مِن البشر، وإما الله ﷿. ثم قال: «وما ذكرناه من المعنى في قوله: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span> هو قول الحسن وقتادة». و<span class="comment-type-4">بيَّنَ</span> أنّ هناك فرقًا بين هذا القول وبين قول ابن عباس من طريق ابن جُبَيْر.</div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٤<span class="dash">-</span></span> و<span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وفوق كل ذي علم عليم﴾</span>، قالا: هو ذلك أيضًا، يوسفُ وإخوتُه هو فوقهم في العلم{45}. (٨/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وفَوْقَ كُلِّ ذِي عِلْمٍ عَلِيمٌ﴾</span> يقول الرب تعالى: عالم، <span class="qpc-hafs">﴿وفَوْقَ كُلِّ ذِي عِلْمٍ عَلِيمٌ﴾</span> يقول: يوسفُ أعْلَمُ إخوتِه{32}. (ز)</p></p><p></div></p></div>",footnotes:1:قال الشيخ شاكر في تحقيقه ١٦/١٨٤: وقوله: استبره، من الاستبراء، سهلت همزتها، وأصله: واستبرئه، والاستبراء: طلب البراءة من الشيء، ما كان تهمة أو عيبًا أو قادحًا.أخرجه عبد الرزاق ١/٣٢٥-٣٢٦ من طريق معمر بلفظ:«فاستَبْرِه»، وابن جرير ١٣/٢٥٩-٢٦٠ بلفظ: «فاستبْرِئْه»، وابن أبي حاتم ٧/٢١٧٥ من طريق سعيد بن بشير. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.كذا في المطبوع. وقال محققو الدر: ليست في الأصل، وبعده في نسخة: «مرة»، ونقلوا عن هامش إحدى النسخ:«لعله لابنه أو لبعض بنيه».البَزْرُ: الأَولاد. لسان العرب (بزر).أخرج أوله ابن جرير ١٣/٢٦٠، وابن أبي حاتم ٧/٢١٧٥، ٧/٢١٧٩ بتمامه.أخرجه ابن جرير ١٣/٢٦٠.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه ابن جرير ١٣/٢٦٠.تفسير الثعلبي ٥/٢٤٢.أخرجه ابن جرير ١٣/٢٦٣-٢٦٤، وابن أبي حاتم ٧/٢١٧٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٢٦٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٥/٢٤٢.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه ابن جرير ١٣/٢٦٣.أخرجه ابن جرير ١٣/٢٦٤، وابن أبي حاتم ٧/٢١٧٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٦٣-٢٦٤ مختصرًا بلفظ: في سلطان الملك، وابن أبي حاتم ٧/٢١٧٦ من طريق أبي روق دون قوله: في سلطان الملك. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير الثعلبي ٥/٢٤٢.أخرجه عبد الرزاق في تفسيره ١/٣٢٦ من طريق مَعْمَر، واللفظ له، وابن جرير ١٣/٢٦٤-٢٦٥، وابن أبي حاتم ٧/٢١٧٦ من طريق سعيد بن بشير. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٦٥.أخرجه ابن جرير ١٣/٢٦٥.أخرجه ابن جرير ١٣/٢٦٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ١/٣٢٦ عن معمر عن الكلبي، وابن جرير ١٣/٢٦٥ عن معمر قال: بلغنا. ولم يذكر الكلبي. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه ابن جرير ١٣/٢٦٥، وابن أبي حاتم ٧/٢١٧٦.تفسير الثوري ص١٤٥.أخرجه ابن جرير ١٣/٢٦٦، وابن أبي حاتم ٧/٢١٧٤ عند قوله: <span class="qpc-hafs">﴿جزاؤه من وجد في رحله﴾</span> من طريق أصبغ بنحوه.أخرجه عبد الرزاق ١/٣٢٦ عن معمر عن الكلبي، وابن جرير ١٣/٢٦٥ ولم يذكر الكلبي.أخرجه ابن جرير ١٣/٢٦٧، وابن أبي حاتم ٧/٢١٧٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٦٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه أحمد ١/٥٠٠ (٤٤٩)، وابن أبي حاتم ٧/٢١٧٦-٢١٧٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٦٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧١.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٦٩، والمحتسب ١/٣٤٦.علَّقه مسلم في مقدمة صحيحه ١/٦، ووصله أبو نعيم في مستخرجه على صحيح مسلم ١/٨٩ (٥٧) بلفظه. وأخرجه أبو داود (٤٨٤٢)، والحاكم في معرفة علوم الحديث ص٤٨ وغيره دون قوله: مع ما نطق به ...، كلهم مِن طريق حبيب بن أبي ثابت، عن ميمون بن أبي شبيب، عن عائشة به.</p><p>قال أبو داود: «ميمون لم يدرك عائشة». وقال الحاكم: «حديث صحيح». وتُعُقِّب في ذلك. وللحديث شواهد يتقوى بها، قال السخاوي: «وبالجملة فحديث عائشة حسن». ينظر: المقاصد الحسنة ص١٦٣-١٦٤ وكشف الخفاء ١/٢٢١-٢٢٢.أخرجه ابن جرير ١٣/٢٦٩.أخرجه ابن جرير ١٣/٢٦٨-٢٦٩، وابن أبي حاتم ٧/٢١٧٧، والبيهقي في الأسماء والصفات (٢٣٦). وعزاه السيوطي إلى الفريابي، وابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/٣٢٦-٣٢٧، وسعيد بن منصور (١١٣٧ - تفسير)، وابن جرير ١٣/٢٦٩، وابن أبي حاتم ٧/٢١٧٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧٠.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٦٩، وابن أبي حاتم ٧/٢١٧٧، والبيهقي في الأسماء والصفات (٢٣٧). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٢٧٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٧٠.أخرجه ابن جرير ١٣/٢٧١ بلفظ: حتى ينتهي العلم إلى الله؛ منه بدأ، وتعلَّمت العلماء، وإليه يعود، وابن أبي حاتم ٧/٢١٧٧ واللفظ له، من طريق سعيد بن بشير.عزاه السيوطي إلى ابن المنذر عن مجاهد، وإلى أبي الشيخ عن ابن جريج.تفسير مقاتل بن سليمان ٢/٣٤٦.
  12,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِن یَسۡرِقۡ فَقَدۡ سَرَقَ أَخࣱ لَّهُۥ مِن قَبۡلُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٨٨٦<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>، قال: «<b>سرق يوسفُ ﵇ صنمًا لِجَدِّه أبي أُمِّه مِن ذهب وفضة، فكسره، وألقاه على الطريق، فعيَّره بذلك إخوتُه</b>»{1}. (٨/٢٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: سرق مُكْحُلَةً لِخالتِه{2}. (٨/٢٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٨<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: كان يوسفُ في المنزل وحدَه، فأتاه سائلٌ، وكان في المنزل [عَناق]، وهي الأُنثى مِن الجَدْيِ، فدفعها إلى السائل مِن غير أمر أبيه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٨٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي حصين- في قوله: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>، قال: سرق يوسف صنمًا لجده أبي أُمِّه من ذهب أو فضة، فكسره، وألقاه في الطريق، فعيَّره بذلك إخوته{4}. (٨/٢٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيج- في قوله: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>، قال: يعنون: يوسف{5}. (٨/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩١<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: إنّ يوسف جاءه سائِلٌ يومًا، فأخذ بَيْضَةً مِن البيت، فناولها للسائل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: كان أوَّل ما دخل على يوسف مِن البلاء -فيما بلغني- أنّ عمته وكانت أكبر ولد إسحاق، وكانت إليها مِنطَقةُ{7} إسحاق، فكانوا يتوارثونها بالكِبَر، وكان يعقوبُ حين وُلِد له يوسف قد حَضَنَتْهُ عمَّتُه، فكان معها وإليها، فلم يُحِبَّ أحدٌ شيئًا مِن الأشياء كحُبِّها إيّاه، حتى إذا تَرَعْرَعَ وقعت نفسُ يعقوب عليه، فأتاها، فقال: يا أُخيَّةُ، سلِّمي إلَيَّ يوسف، فواللهِ، ما أقدر على أن يغيب عَنِّي ساعة. قالت: فواللهِ، ما أنا بتاركته، فدعه عندي أيّامًا أنظر إليه، لعلَّ ذلك يُسَلِّيني عنه. فلمّا خرج يعقوب مِن عندها عَمَدت إلى مِنطَقةِ إسحاق فحَزَمَتْها على يوسف مِن تحت ثيابه، ثم قالت: فقدتُ مِنطَقةَ إسحاق، فانظروا مَن أخذها، ومَن أصابَها. فالتُمِسَت، ثم قالت: اكشفُوا أهلَ البيت. فكشفُوهم، فوجَدُوها مع يوسف، فقالت: واللهِ، إنّه لي لَسَلَمٌ{8}، أصنع فيه ما شِئْتُ. فأتاها يعقوبُ، فأخبرته الخبر، فقال لها: أنتِ وذاك، إن كان فَعَلَ ذلك فهو سَلَمٌ لك، ما أستطيع غير ذلك. فأمْسَكَتْه، فما قَدَرَ عليه حتى ماتت، فهو الذي يقول إخوة يوسف حين صنَع بأخيه ما صنَع: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>{9}. (٨/٢٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مزاحم</span> -من طريق جويبر-، مثله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span>، مثله{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٥<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>، قال: سرق في صِباه مِيلَيْنِ مِن ذهب{12}. (٨/٢٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٦<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق ابن إدريس، عن أبيه- في الآية، قال: كان يوسف ﵇ معهم على الخِوان، فأخذ شيئًا مِن الطعام، فتَصَدَّق به{13}. (٨/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٧<span class="dash">-</span></span> قال <span class="name-2">وهب بن منبه</span>: كان يُخَبِّئُ الطعامَ مِن المائدة للفقراء{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: سَرِقتُه التي عابوه بها: أخَذَ صنمًا كان لأبي أُمِّه، وإنّما أراد بذلك الخيرَ{15}. (٨/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨٩٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق هشام بن سعد- قال: كان يوسف غلامًا صغيرًا مع أُمِّه عند خالٍ له، وهو يلعب مع الغلمان، فدخل كنيسةً لهم، فوجد تمثالًا لهم صغيرًا مِن ذهب، فأخذه. قال: وهو الذي عيَّره إخوتُه به: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>{16}. (٨/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: بَعَثَتْهُ أُمُّه حين أرادت أن ترتحل مِن حَرّان مع يعقوب إلى فلسطين والأردن، أمرته أن يذهب، فأخذ جُونَةً{17} فيها أوثان لأبيها مِن ذهب فيأتيها بها، لكي إذا فقدها أبوها أسلم، فانطلق، فأخذها، وجاء بها إلى أُمِّه. فهذه سَرِقَتُه التي يعنون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في الآية، قال: كانت أمُّ يوسف أمَرت يوسفَ أن يسرق صنمًا لخاله كان يعبده، وكانت مُسْلِمة{19}. (٨/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال إخوة يوسف: <span class="qpc-hafs">﴿قالوا إن يسرق﴾</span> بنيامين <span class="qpc-hafs">﴿فقد سرق أخ له من قبل﴾</span> بنيامين، يعنون: يوسف ﵇. وذلك أنّ جدَّ يوسف أبا أُمِّه كان اسمُه: لاتان، كان يعبد الأصنام، فقالت راحيل لابنها يوسف ﵇: خُذِ الصنم، ففِرَّ به مِن البيت؛ لعله يترك عبادة الأوثان. وكان مِن ذهب، ففعل ذلك يوسف ﵇، فتلك سرقةُ يوسف التي قالوا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن حميد- قال: لَمّا رأى بنو يعقوبَ ما صنع إخوة يوسف، ولم يَشُكُّوا أنّه سرق؛ قالوا أسفًا عليهم لِما دخل عليهم في أنفسهم تأنيبًا له: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>. فلمّا سمعها يوسف قال: <span class="qpc-hafs">﴿أنتم شر مكانا﴾</span>. سِرًّا في نفسه، ولم يُبْدِها لهم، <span class="qpc-hafs">﴿والله أعلم بما تصفون﴾</span>{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>، قال: كان يوسفُ سَرَق آلهتهم{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٥<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span>: أخذ دجاجةً مِن الطير التي كانت في بيت يعقوب، فأعطاها سائلًا{14}<span class=comment-ref>٣٤٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٥</span> ذكر <u>ابنُ عطية</u> (٥/١٢٥) في الآية احتمالين، و<span class="comment-type-1">وجّههما</span>، فقال: «ويحتمل قولهم: <span class="qpc-hafs">﴿إنْ يَسْرِقْ فَقَدْ سَرَقَ أخٌ لَهُ مِن قَبْلُ﴾</span> تأويلين. <b>أحدهما</b>: أنّهم حققوا السرقة في جانب بنيامين ويوسف ﵉، بحسب ظاهر الحكم، فكأنهم قالوا: إن كان قد سرق فغيرُ بِدْعٍ مِن ابْنَيْ راحيل؛ لأنّ أخاه يوسف كان قد سرق. فهذا من الإخوة إنْحاءٌ على ابْنَيْ راحيل: يوسف، وبنيامين. <b>والوجه الآخر</b> الذي يحتمله لفظهم يتضمن أنّ السرقة في جانب يوسف وبنيامين مظنونة، كأنهم قالوا: إن كان هذا الذي رُمِي به بنيامين حقًّا في نفسه فالذي رُمِي به يوسف قبل حقٌّ إذًا. وكأنّ قصة يوسف والظن به قَوِيا عندهم أقوى مِمّا ظهر في جهة بنيامين».</p><p>ثم ذكر عن بعض المفسرين أن تقدير الكلام: «فقد قيل عن يوسف: إنه سرق». و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للفظ الآية</span> قائلًا: «ونحو هذا من الأقوال التي لا ينطبق معناها على لفظ الآية».</div></p><p><h3><span class="qpc-hafs">﴿فَأَسَرَّهَا یُوسُفُ فِی نَفۡسِهِۦ وَلَمۡ یُبۡدِهَا لَهُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فأسرها يوسف في نفسه ولم يبدها لهم﴾</span>، قال: أسرَّ في نفسه قوله: <span class="qpc-hafs">﴿أنتم شر مكانًا والله أعلم بما تصفون﴾</span>{24}. (٨/٢٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأسرها يوسف في نفسه ولم يبدها لهم﴾</span>: أمّا الذي أسرَّ في نفسه فقوله: <span class="qpc-hafs">﴿أنتم شر مكانا، والله أعلم بما تصفون﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فـ﴾</span>لمّا سمع يوسفُ مقالتَهم <span class="qpc-hafs">﴿أسرها يوسف في نفسه ولم يبدها لهم﴾</span>: ولم يُظْهِرها لهم{20}<span class=comment-ref>٣٤٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٦</span> <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٥/١٢٦-١٢٧) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> أنّ قوله: <span class="qpc-hafs">﴿أنتم شر مكانا﴾</span> قاله يوسف ﵇ جهرًا لهم، فقال: «وقوله: <span class="qpc-hafs">﴿أنْتُمْ شَرٌّ مَكانًا﴾</span> الآية، الظاهرُ منه أنّه قالها إفصاحًا، فكأنّه أسرَّ لهم كراهية مقالتهم، ثم تَجَهَّمهم بقوله: <span class="qpc-hafs">﴿أنْتُمْ شَرٌّ مَكانًا﴾</span> أي: لسوء أفعالكم، والله يعلم إن كان ما وصفتموه حقًّا. وفي اللفظ إشارة إلى تكذيبهم، ومما يُقَوِّي هذا عندي أنّهم تركوا الشفاعة بأنفسهم، وعدلوا إلى الشفاعة بالشيخ ﵇».</p><p>و<span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى اللغة، والنظائر</span> أنّ الذي أسره يوسف في نفسه هو: "الحزازة التي حدثت في نفس يوسف من قولهم، والكلام يتضمنها، وهذا كما تضمن الكلام الضمير الذي في قول حاتم:</p><p>لَعَمْرُك ما يُغْنِي الثراء عن الفتى ... إذا حَشْرَجَتْ يومًا وضاق بها الصَّدْرُ</p><p>وهذا كقوله تعالى: <span class="qpc-hafs">﴿ثُمَّ إنَّ رَبَّكَ لِلَّذِينَ هاجَرُوا مِن بَعْدِ ما فُتِنُوا ثُمَّ جاهَدُوا وصَبَرُوا إنَّ رَبَّكَ مِن بَعْدِها لَغَفُورٌ رَحِيمٌ﴾</span> [النحل:١١٠]، فهي مراد بها الحالة المُتَحَصِّلة مِن هذه الأفعال«. ثم ذكر قولين آخرين، فقال:»وقال قوم: أسَرَّ المجازاة. وقال قوم: أسَرَّ الحُجَّة«. ثم قال:»وما قدَّمناه أليق".</div></p><p><h3><span class="qpc-hafs">﴿قَالَ أَنتُمۡ شَرࣱّ مَّكَانࣰاۖ وَٱللَّهُ أَعۡلَمُ بِمَا تَصِفُونَ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿شرٌ مكانا﴾</span> قال: يوسفُ يقوله، <span class="qpc-hafs">﴿والله أعلم بما تصفون﴾</span> قال: تقولون{27}. (٨/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والله أعلم بما تصفون﴾</span>، أي: بما تُكَذِّبون{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال في نفسه: <span class="qpc-hafs">﴿أنتم شر مكانا﴾</span>. ولم يُسْمِعْهم. قال: أنتم أسوأ صنعًا فيما صنعتم بيوسف، <span class="qpc-hafs">﴿والله أعلم بما تصفون﴾</span> يعني: بما تقولون مِن الكذب أنّ يوسف سرق. فعندها قالوا: ما لقينا مِن ابْنَيْ راحيل؛ يوسف وأخيه؟! فقال بنيامين: ما لَقِيَ ابنا راحيل منكم؟! أمّا يوسف فقد فعلتم به ما فعلتم، وأمّا أنا فسَرَّقْتُمُونِي. قالوا: فمَن جَعَل الإناءَ في متاعك؟ قال: جعله في متاعي الذي جعل الدراهمَ في أمتعتكم. فلمّا ذكر الدراهمَ شتموه، وقالوا: لا تَذْكُرِ الدراهمَ. مخافة أن يُؤْخَذُوا بها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩١٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: فلمّا سمعها يوسف قال: <span class="qpc-hafs">﴿أنتم شر مكانا﴾</span>. سِرًّا في نفسه، <span class="qpc-hafs">﴿ولم يبدها لهم﴾</span>{30}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ أَنتُمۡ شَرࣱّ مَّكَانࣰاۖ وَٱللَّهُ أَعۡلَمُ بِمَا تَصِفُونَ ۝٧٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٩١٣<span class="dash">-</span></span> عن ابن عيينة، عن رجل منهم يُقال له: نسيبة، قال: لَمّا لَقِي يوسفُ أخاه قال: هل تَزَوَّجت بعدي؟ قال: نعم. قال: وما شَغَلَك الحزنُ عَلَيَّ؟ قال: إنّ أباك يعقوب قال لي: تَزَوَّج؛ لعل اللهُ أن يَذْرَأَ مِنك ذُرِّيَّةً يُثقِّلون -أو قال: يُسَكِّنُون- الأرض بتسبيحةٍ{31}. (٨/٢٩٩)</p></p><p></div></p></div>",footnotes:1:أورده الديلمي في الفردوس ١/٢٤١ (٩٢٩). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢٤٣.أخرجه ابن جرير ١٣/٢٧٢-٢٧٣، وابن أبي حاتم ٧/٢١٧٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧٢. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢٤٣ من طريق السدي بلفظ: جبة، وتفسير البغوي ٤/٢٦٣.المنطقة: الحزام. مختار الصحاح (نطق).أي: أسير. النهاية (سلم).أخرجه ابن إسحاق -كما في ابن كثير ٤/٣٢٧-، وابن جرير ١٣/٢٧٤، وابن أبي حاتم ٧/٢١٧٩.تفسير الثعلبي ٥/٢٤٣.تفسير البغوي ٤/٢٦٣.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٧٣ عن ابن إدريس عن أبيه ولم يذكر عطية، وابن أبي حاتم ٧/٢١٧٨ من طريق ابن إدريس عن أبيه عن عطية مختصرًا. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٤٣، وتفسير البغوي ٤/٢٦٣.أخرجه عبد الرزاق في تفسيره ٢/٣٢٦ بنحوه من طريق معمر، وابن جرير ١٣/٢٧٣.أخرجه ابن أبي حاتم ٧/٢١٧٨. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر.الجونة -بالضم-: التي يُعد فيها الطيب ويُحْرَز. النهاية (جون).تفسير الثعلبي ٥/٢٤٣.أخرجه ابن جرير ١٣/٢٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٧٤.تفسير الثوري ص١٤٥.تفسير الثعلبي ٥/٢٤٣، وتفسير البغوي ٤/٢٦٣.أخرجه ابن جرير ١٣/٢٧٦، وابن أبي حاتم ٧/٢١٧٩.أخرجه عبد الرزاق في تفسيره ٢/٣٢٦ من طريق معمر، وابن جرير ١٣/٢٧٦.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٧٧، وابن أبي حاتم ٧/٢١٨٠. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧٧.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٧٤، وابن أبي حاتم ٧/٢١٨٠.أخرجه عبد الرزاق (١٠٣٨٩). وعزاه السيوطي إليه، وفيه: عن شيبة.
  12,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰۤأَیُّهَا ٱلۡعَزِیزُ إِنَّ لَهُۥۤ أَبࣰا شَیۡخࣰا كَبِیرࣰا فَخُذۡ أَحَدَنَا مَكَانَهُۥۤۖ إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> أي: إخوةُ يوسف ليوسف: <span class="qpc-hafs">﴿يا أيها العزيز﴾</span> وذلك أنّ أرض مصر صارت إليه، وهو خازن المَلِك، <span class="qpc-hafs">﴿إنّ له﴾</span> يعني: لِبنيامين <span class="qpc-hafs">﴿أبا شيخا كبيرا﴾</span> حزينًا على ابنٍ مفقود؛ <span class="qpc-hafs">﴿فخذ أحدنا مكانه إنا نراك من المحسنين﴾</span> إلينا إن فعلت بنا ذلك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩١٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ قالوا ليوسف: <span class="qpc-hafs">﴿قالُوا يا أيُّها العَزِيزُ إنَّ لَهُ أبًا شَيْخًا كَبِيرًا فَخُذْ أحَدَنا مَكانَهُ إنّا نَراكَ مِنَ المُحْسِنِينَ﴾</span>: إنّا نرى ذلك منك إحسانًا إن فعلتَ{2}<span class=comment-ref>٣٤٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٢٨) في قوله: <span class="qpc-hafs">﴿فخذ أحدنا مكانه﴾</span> احتمالين: <b>أحدهما</b>: «أن يكون مجازًا، وهم يعلمون أنّه لا يصح أخذُ حُرٍّ لِيُسْتَرَقَّ بدلَ مَن أحكمت السنة رقه، وإنما هذا كما تقول لمن تكره فعله: اقتلني ولا تفعل كذا وكذا. وأنت لا تريد أن يقتلك، ولكنك تبالغ في اسْتِنزاله، وعلى هذا يتجه قول يوسف: <span class="qpc-hafs">﴿مَعاذَ اللَّهِ﴾</span>؛ لأنّه تَعَوُّذ مِن غير جائز». <b>والآخر</b>: «أن يكون قولهم: <span class="qpc-hafs">﴿فَخُذْ أحَدَنا مَكانَهُ﴾</span> حقيقة، وبعيد عليهم -وهم أنبياء- أن يريدوا استرقاق حُرٍّ، فلم يبق إلا أن يريدوا بذلك طريق الحمالة، أي: خذ أحدنا حتى ينصرف إليك صاحبك».</p><p>وكذا <span class="comment-type-4">ذكر</span> في قوله: <span class="qpc-hafs">﴿إنا نراك من المحسنين﴾</span> احتمالين، فقال: «وقولهم: <span class="qpc-hafs">﴿إنّا نَراكَ مِنَ المُحْسِنِينَ﴾</span> <b>يحتمل</b> أن يريدوا وصفَه بما رأوه من إحسانه في جميع أفعاله معهم ومع غيرهم. <b>ويحتمل</b> أن يريدوا: إنّا نرى لك إحسانًا علينا في هذه اليد إن أسديتها إلينا. وهذا تأويل ابن إسحاق».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٧٩، وابن أبي حاتم ٧/٢١٨٠.