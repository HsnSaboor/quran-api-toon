tafsir[9]{c,v,t}:
12,70," <q>﴿فَلَمَّا جَهَّزَهُم بِجَهَازِهِمۡ﴾</q> - تفسير ٣٧٧٧٠- عن قتادة بن دعامة -من طريق سعيد- وفي قوله: <q>﴿فلما جَهَّزَهُم بِجَهازِهِم﴾</q>، قال: لَمّا قَضى حاجتَهم، وكال لهم طعامَهم{1}. (٨/٢٨٨) ٣٧٧٧١- قال مقاتل بن سليمان: <q>﴿فَلَمّا جَهَّزَهُمْ بِجَهازِهِمْ﴾</q>، يقول: فلمّا قضى في أمر الطعام حاجتهم{2}. (ز) ٣٧٧٧٢- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ جَهَّزَهم بجهازهم، وأكرمهم، وأعطاهم، وأوفاهم، وحمل لهم بعيرًا بعيرًا، وحمل لأخيه بعيرًا باسمه كما حمل لهم{3}. (ز) <q>﴿جَعَلَ ٱلسِّقَایَةَ﴾</q> - تفسير ٣٧٧٧٣- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <q>﴿جعل السقاية﴾</q>، قال: هو الصُّواع، وكلُّ شيء يُشْرَب منه فهو صُواع{4}. (٨/٢٨٨) ٣٧٧٧٤- عن عبد الله بن عباس، في قوله: <q>﴿جعل السقاية﴾</q>، قال: كانَتْ مِن زَبَرْجَد{5}. (ز) ٣٧٧٧٥- عن عبيد بن سليمان، قال: سمعتُ الضَّحّاك بن مُزاحِم يقول في قوله: <q>﴿جعل السقاية﴾</q>: هو الإناء الذي كان يَشْرَبُ فيه الملِك{6}. (ز) ٣٧٧٧٦- عن عكرمة مولى ابن عباس -من طريق سماك- قال: السقاية: إناؤه الذي يشرب فيه، وكان مِن فِضَّة{7}. (٨/٢٨٨) ٣٧٧٧٧- عن قتادة بن دعامة -من طريق سعيد- وفي قوله:<q>﴿جعل السقاية﴾</q>، قال: هو إناء المَلِك الذي يشرب مِنه{8}. (٨/٢٨٨) ٣٧٧٧٨- قال مقاتل بن سليمان: <q>﴿جَعَلَ السِّقايَةَ﴾</q>، وهي الإناءُ الذي يشرب به الملِكُ{2}. (ز) ٣٧٧٧٩- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ أمر بسِقاية الملك، وهو الصُّواع، وزعموا: أنّها كانت مِن فِضَّة{10}٣٤١٠. (ز) ٣٤١٠ ذكر ابنُ عطية (٥/١٢٠) أنّ القول -الذي قاله عكرمة، وابن إسحاق- بأنّ الصواع كان من فضة، هو قول الجمهور. وذكر ابنُ كثير (٨/٥٨) أنّه قول الأكثرين. ٣٧٧٨٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: السِّقاية: هو الصُّواع. وكان كأسًا مِن ذَهَب -فيما يذكرون-{11}. (٨/٢٨٨) <q>﴿فِی رَحۡلِ أَخِیهِ﴾</q> - تفسير ٣٧٧٨١- قال كعب الأحبار: لَمّا قال له يوسف: إني أنا أخوك. قال بنيامين: أنا لا أُفارِقُك. فقال له يوسف: قد عَلِمْت اغتمامَ والدي بي، وإذا حَبَسْتُكَ ازداد غَمُّه، ولا يمكنني هذا إلا بعد أن أُشْهِرَكَ{12} بأمرٍ فظيعٍ، وأَنسِبَك إلى ما لا يُحْمَد. قال: لا أُبالِي؛ فافْعَل ما بَدا لكَ، فإنِّي لا أُفارِقُكَ. قال: فإنِّي أدُسُّ صاعي في رَحْلِك، ثُمَّ أنادي عليكم بالسَّرِقَة، لِيُهَيَّأ لي رَدُّك بعد تسريحك. قال: فافعل. فذلك قوله تعالى: <q>﴿فلما جهزهم بجهازهم جعل السقاية في رحل أخيه﴾</q>{13}٣٤١١. (ز) ٣٤١١ على هذا القول فيوسف ﵇ تَعَمَّد هذا الفعلَ ليأخذ أخاه، وهو ما علّق عليه ابنُ عطية (٥/١١٩) بقوله: «ويقويه قوله تعالى: <q>﴿كذلك كدنا ليوسف﴾</q>». وذكر ابنُ عطية قولين آخرين: الأول: أنّه أُوحي إلى يوسف أن يجعل السقاية فقط، ثم إنّ حافظها فقدها، فنادى على ما ظهر إليه. وانتقده مستندًا للسياق، فقال: «وتفتيش الأوعية يَرُدُّ عليه». الثاني: أنهم لما كانوا قد باعوا يوسف استجاز أن يُقال لهم هذا، وإنّه عُوقِب على ذلك بأن قالوا: <q>﴿فقد سرق أخ له من قبل﴾</q>. ٣٧٧٨٢- عن قتادة بن دعامة -من طريق سعيد- وفي قوله: <q>﴿في رحل أخيه﴾</q>، قال: في متاع أخيه{14}. (٨/٢٨٨) ٣٧٧٨٣- عن إسماعيل السُّدِّيِّ -من طريق أسباط- قال: <q>﴿فلما جَهَّزَهُم بِجَهازِهِم جعل السقاية في رحل أخيه﴾</q>، والأخ لا يَشْعُر{15}٣٤١٢. (٨/١٩٥) ٣٤١٢ رجَّح ابنُ عطية (٥/١٢٠) قول السدي بقوله: «وهو الظاهر». ولم يذكر مستندًا. وانتقده ابنُ القيم (٢/٧٠) لدلالة العقل، وقول الأكثر، فقال: «هذا خلاف المفهوم من القرآن، وخلاف ما عليه الأكثرون، وفيه تَرْوِيعٌ لِمَن لم يَسْتَوْجِبِ الترويعَ». ٣٧٧٨٤- قال مقاتل بن سليمان: <q>﴿فِي رَحْلِ أخِيهِ﴾</q> بنيامين{2}. (ز) ٣٧٧٨٥- عن محمد بن إسحاق -من طريق سلمة- قال: فجُعِلَت في رحل أخيه بِنيامين{10}. (ز) <q>﴿ثُمَّ أَذَّنَ مُؤَذِّنٌ﴾</q> - تفسير ٣٧٧٨٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وأنا به زعيم﴾</q>، قال: الزَّعِيم هو المُؤَذِّن الذي قال: <q>﴿أيتها العير﴾</q>{18}. (٨/٢٩١) ٣٧٧٨٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فلمّا ارتحلوا <q>﴿أذن مؤذن﴾</q> قبل أن يَرْتَحِلَ العِير: <q>﴿أيتها العير إنكم لسارقون﴾</q>{15}. (٨/١٩٥) ٣٧٧٨٨- قال مقاتل بن سليمان: <q>﴿ثُمَّ أذَّنَ مُؤَذِّنٌ﴾</q> يعني: نادى مُنادٍ، اسمُه: بعرايم بن بربري، مِن فتيان يوسف: <q>﴿أيَّتُها العِيرُ﴾</q>{2}. (ز) ٣٧٧٨٩- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ أمْهَلَهم، حتى إذا انطلقوا فأَمْعَنُوا مِن القرية أمَرَ بهم، فأُدرِكوا، فاحْتُبِسُوا، ثم نادى منادٍ: <q>﴿أيتها العير إنكم لسارقون﴾</q>{10}. (ز) <q>﴿أَیَّتُهَا ٱلۡعِیرُ إِنَّكُمۡ لَسَـٰرِقُونَ ۝٧٠﴾</q> - تفسير ٣٧٧٩٠- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿أيتها العير﴾</q>، قال: كانتِ العِيرُ حميرًا{22}. (٨/٢٨٨) ٣٧٧٩١- قال مقاتل بن سليمان: <q>﴿أيَّتُها العِيرُ﴾</q> يعني: الرِّفْقَة <q>﴿إنَّكُمْ لَسارِقُونَ﴾</q>. فانقَطَعَتْ ظهورُهم، وساء ظَنُّهم{2}. (ز) ٣٧٧٩٢- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ نادى مُنادٍ: <q>﴿أيتها العير إنكم لسارقون﴾</q>، قِفُوا. وانتهى إليهم رسولُه، فقال لهم -فيما يذكرون-: ألم نُكْرِم ضيافتَكم، ونُوَفِّكم كيلَكم، ونُحْسِن منزلتَكم، ونفعل بكم ما لم نفعل بغيركم، وأدخلناكم علينا في بيوتنا ومنازلنا؟ أو كما قال لهم، قالوا: بلى، وما ذاك؟ قال: سِقايَةُ الملِك فَقَدْناها، ولا نَتَّهِمُ عليها غيرَكم. قالوا: <q>﴿تالله لقد علمتم ما جئنا لنفسد في الأرض وما كنا سارقين﴾</q>{24}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٢٤٤، وابن أبي حاتم ٧/٢١٧٠-٢١٧١ من طريق سعيد بن بشير. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧١.أخرجه ابن أبي حاتم ٧/٢١٧١. وعزاه السيوطي إلى ابن الأنباري في المصاحف.تفسير البغوي ٤/٢٦٠.أخرجه ابن جرير ١٣/٢٤٦.أخرجه ابن أبي حاتم ٧/٢١٧١.أخرجه ابن جرير ١٣/٢٤٥، وابن أبي حاتم ٧/٢١٧٠-٢١٧١. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧.أخرجه ابن جرير ١٣/٢٤٦، وابن أبي حاتم ٧/٢١٧١ من طريق أصبغ.الشُّهْرَةُ: ظهور الشيء في شُنْعة حتى يَشْهَرَهُ الناس. النهاية (شهر).تفسير الثعلبي ٥/٢٣٩، وتفسير البغوي ٤/٢٦٠.أخرجه ابن جرير ١٣/٢٤٢-٢٤٦، وابن أبي حاتم ٧/٢١٧٠-٢١٧١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧٢.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧.أخرجه ابن جرير ١٣/٢٥٣، وابن أبي حاتم ٧/٢١٧٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧٢.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧.أخرجه ابن جرير ١٣/٢٤٨، وابن أبي حاتم ٧/٢١٧٢-٢١٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٤٧، وابن أبي حاتم ٧/٢١٧٢-٢١٧٣.
12,71," <q>﴿قَالُوا۟ وَأَقۡبَلُوا۟ عَلَیۡهِم مَّاذَا تَفۡقِدُونَ ۝٧١﴾</q> - تفسير ٣٧٧٩٣- عن إسماعيل السُّدِّيّ-من طريق أسباط- قال: فانقطعت ظهورهم، <q>﴿وأقبلوا عليهم﴾</q> يقولون: <q>﴿ماذا تفقدون﴾</q>{1}. (٨/١٩٥) ٣٧٧٩٤- قال مقاتل بن سليمان: فـ<q>﴿قالُوا وأَقْبَلُوا عَلَيْهِمْ﴾</q>، فيها تقديم، يقول: وأقبلوا على المنادي، ثم قالوا: <q>﴿ماذا تَفْقِدُونَ﴾</q>{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٤.
12,72," <q>﴿قَالُوا۟ نَفۡقِدُ صُوَاعَ ٱلۡمَلِكِ وَلِمَن جَاۤءَ بِهِۦ حِمۡلُ بَعِیرࣲ وَأَنَا۠ بِهِۦ زَعِیمࣱ ۝٧٢﴾</q> - قراءات ٣٧٧٩٥- عن أبي هريرة -من طريق العبّاس بن عبد الرحمن- أنّه كان يقرأ: (صاعَ المَلِكِ){1}٣٤١٣. (٨/٢٩٠) ٣٤١٣ علّق ابنُ جرير (١٣/٢٤٩) على هذه القراءةِ بقوله: «كأنّه وجَّهه إلى الصاعِ الذي يُكال به الطعام». ٣٧٧٩٦- عن يحيى بن يعمر -من طريق غالب الليثي- أنّه كان يقرؤها: (صُوغَ المَلِكِ) بالغين المعجمة. قال: كان صيغ مِن ذهب أو فضة ...{2}٣٤١٤. (٨/٢٩٠) ٣٤١٤ علّق ابنُ جرير (١٣/٢٤٩) على قراءة يحيى بن يعمر بقوله: «كأنّه وجَّهه إلى أنّه مصدر مِن قولهم: صاغ يصوغ صوغًا». وعلّق عليها ابنُ عطية (٥/١٢١) بقوله: «وهذا على أنّه الشيء المصوغ للملك، على ما روي أنّه كان من ذهب أو مِن فضة، فهو مَصْدَرٌ سُمِّي به». ٣٧٧٩٧- عن سعيد بن جبير أنّه كان يقرأ: <q>﴿نَفْقِدُ صُواعَ المَلِكِ﴾</q> بضم الصّاد، مع الألف{3}. (٨/٢٩٠) ٣٧٧٩٨- عن سعيد بن جبير أنّه كان يقرأ: (صُياعَ المَلِكِ){4}. (٨/٢٩١) ٣٧٧٩٩- عن أبي رجاء [العُطارِدِيِّ] أنه قرأ: (نَفْقِدُ صَواعَ المَلِكِ) بعين غير معجمة، وصاد مفتوحة{5}. (٨/٢٩٠) ٣٧٨٠٠- عن عبد الله بن عون أنّه كان يقرأ: (صُوعَ المَلِكِ) بصاد مضمومة{6}٣٤١٥. (٨/٢٩٠) ٣٤١٥ ساق ابنُ عطية (٥/١٢١) هذه القراءات، ثم علَّق بقوله: «وهذه لُغاتٌ في المكيال. قاله أبو الفتحِ وغيره». ورجَّح ابنُ جرير (١٣/٢٤٩) قراءة:<q>﴿صُواع﴾</q> مستندًا إلى إجماع القراء، فقال: «وأمّا الذي عليه قراء الأمصار: فـ<q>﴿صُواع الملك﴾</q>، وهي القراءة التي لا أستجيز القراءةَ بخلافها؛ لإجماع الحُجَّة عليها». <q>﴿قَالُوا۟ نَفۡقِدُ صُوَاعَ ٱلۡمَلِكِ﴾</q> - تفسير ٣٧٨٠١- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿صواع الملك﴾</q>، قال: شيءٌ يشبه المَكُّوكَ مِن فِضَّة، كانوا يشربون فيه{7}. (٨/٢٨٩) ٣٧٨٠٢- عن عبد الله بن عباس -من طريق صدقة بن عبّاد، عن أبيه- في قوله: <q>﴿صواع الملك﴾</q>، قال: كان مِن نُحاس{8}. (٨/٢٩٠) ٣٧٨٠٣- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿صواع الملك﴾</q>. قال: الصُّواع: الكأس الذي يُشْرَب فيه. قال: وهل تعرف العرب ذلك؟ قال: نعم. أما سمعت الأعشى وهو يقول: له دَرْمَكٌ في رأسه ومشارِب وقِدر وطبّاخ وصاع ودَيْسَقُ{9}. (٨/٢٨٩) ٣٧٨٠٤- عن يحيى بن يعمر -من طريق غالب الليثي- أنّه كان يقرؤها: (صُوغَ الملك) بالغين المعجمة. قال: كان صِيغ مِن ذهب أو فضة، سقايته التي كان يشرب فيها{10}. (٨/٢٩٠) ٣٧٨٠٥- عن سعيد بن جبير -من طريق أبي بشر- في قوله: <q>﴿صواع الملك﴾</q>، قال: هو المَكُّوك الفارسِيُّ الذى يلتقى طرفاه، كانت تشرب فيه الأعاجِم{11}. (٨/٢٨٩) ٣٧٨٠٦- عن سعيد بن جبير -من طريق أبي بشر- أنّه قرأ: <q>﴿صُواع الملك﴾</q>، قال: وكان إناءه الذي يشرب فيه، وكان إلى الطول ما هو{12}. (ز) ٣٧٨٠٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: السِّقاية والصُّواع شيء واحد، يَشْرَب منه يوسفُ{13}. (٨/٢٨٨) ٣٧٨٠٨- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- قال: إناءُ المَلِك الذي كان يشرب فيه{14}. (ز) ٣٧٨٠٩- عن عكرمة مولى ابن عباس -من طريق سماك- في قوله: <q>﴿صواع الملك﴾</q>، قال: كان مِن فِضَّة{15}. (٨/٢٨٩) ٣٧٨١٠- عن الحسن البصري -من طريق يونس- أنّه كان يقول: الصُّواع والسِّقاية سواء، هو الإناء الذي يُشْرَب فيه{16}. (ز) ٣٧٨١١- عن محمد ابن شهاب الزهري -من طريق أبي بشر الوليد بن محمد، هو الموقري- في قول الله: <q>﴿نفقد صواغ الملك﴾</q>، قال: القَدَح{17}. (ز) ٣٧٨١٢- قال مقاتل بن سليمان: <q>﴿قالُوا﴾</q> المنادي ومَن معه، لإخوة يوسف: <q>﴿نَفْقِدُ صُواعَ المَلِكِ﴾</q> يعني: إناء المَلِك، وكان يُكال به، كفِعْل أهلِ العساكر{18}. (ز) ٣٧٨١٣- عن سفيان الثوري: <q>﴿نَفْقِدُ صُواعَ المَلِكِ﴾</q>، قال: إناءُ المَلِك الذي يشرب فيه{19}. (ز) <q>﴿وَلِمَن جَاۤءَ بِهِۦ حِمۡلُ بَعِیرࣲ﴾</q> - تفسير ٣٧٨١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولِمَن جاء به حِملُ بعير﴾</q>، قال: حِمْل حمارٍ طَعامٌ، وهي لغة{20}. (٨/٢٩١) ٣٧٨١٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿حمل بعير﴾</q>، أي: وِقْرُ بعير{21}. (٨/٢٩١) ٣٧٨١٦- قال مقاتل بن سليمان: <q>﴿ولِمَن جاءَ بِهِ حِمْلُ بَعِيرٍ﴾</q>، يعني: وِقْر بعير{18}. (ز) <q>﴿وَأَنَا۠ بِهِۦ زَعِیمࣱ ۝٧٢﴾</q> - تفسير ٣٧٨١٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وأنا به زعيم﴾</q>، ما الزعيم؟ قال: الكَفيل. قال فيه فَروة بن مُسَيْكٍ: أكون زعيمَكم في كُلِّ عام بجيش جَحْفَلٍ لَجِبٍ لُهامِ{23}. (٨/٢٩١) ٣٧٨١٨- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضَّحّاك بن مُزاحِم-: أنّ نافع بن الأزرق قال له: فأخبِرني عن قول الله ﷿: <q>﴿وأنا به زعيم﴾</q>، [قال]: الزعيم: الكفيل. قال: وهل كانت العرب تعرفُ ذلك قبل أن ينزِل الكتابُ على محمد ﷺ؟ قال: نعم، أما سمعت قول امرئ القيس: وإنِّي زعيم إن رَجَعْتُ مُمَلَّكًا بسير ترى منه الفرانِقُ أزْوِرا{24}. (ز) ٣٧٨١٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأنا به زعيم﴾</q>، يقول: كفيل{25}. (٨/٢٩١) ٣٧٨٢٠- عن سعيد بن جبير -من طريق ورْقاء بن إياس-= (ز) ٣٧٨٢١- ومجاهد بن جبر -من طريق سفيان، عن رجل-= (ز) ٣٧٨٢٢- والضَّحّاك بن مُزاحِم -من طريق جويبر، وعبيد-= (ز) ٣٧٨٢٣- وقتادة بن دعامة -من طريق معمر، وسعيد-، مثله{26}. (٨/٢٩١) ٣٧٨٢٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأنا به زعيم﴾</q>، قال: الزعيم: هو المُؤَذِّن الذي قال: <q>﴿أيتها العير﴾</q>{27}. (٨/٢٩١) ٣٧٨٢٥- قال محمد بن السائب الكلبي: إنّ فتى يوسف -وهو المُؤَذِّن- قال لهم: إنّ الملِكَ ائْتَمَنَنِي بالصّاع، وأخاف عقوبة الملك، فلي اليوم عنده مَنزِلَةٌ حَسَنَة، فإن لم أجدْه تَخَوَّفْتُ أن تسقط منزلتي، وأفتضح في مصر{28}. (ز) ٣٧٨٢٦- قال مقاتل بن سليمان: <q>﴿وأَنا بِهِ زَعِيمٌ﴾</q>، يعني: به كفِيل{18}. (ز) ٣٧٨٢٧- عن محمد بن إسحاق -من طريق سلمة- قال لهم الرسول: إنّه مَن جاءنا به فله حِمْل بعير، وأنا به كفيل بذلك، حتى أُؤدِّيَه إليه{30}. (ز) ٣٧٨٢٨- عن سفيان الثوري: <q>﴿وأنا به زعيم﴾</q>، قال: كَفِيل{31}٣٤١٦. (ز) ٣٤١٦ ساق ابنُ جرير (١٣/٢٥٥) هذا القول، ثم علّق بقوله: "ومِن الزعيم الذي بمعنى الكفيل قولُ الشاعر: فلست بآمِرٍ فيها بسِلْمٍ ... ولكنِّي على نفسي زعيم وأصل الزعيم في كلام العرب: القائمُ بأمر القوم. وكذلك الكفيل، والحميل، ولذلك قيل: رئيس القوم زعيمهم ومدبرهم، يقال منه: قد زعم فلان زعامة وزعامًا، ومنه قول ليلى الأخْيَلية: حتى إذا برز اللواءُ رأيته ... تحت اللواء على الخميس زعيما". ",footnotes:1:أخرجه سعيد بن منصور (١١٣٦ - تفسير). وعزاه السيوطي إلى ابن الأنباري. وهي قراءة شاذة، تروى أيضًا عن جماعة. انظر: مختصر ابن خالويه ص٦٩، والمحتسب ١/٣٤٦.أخرجه ابن أبي حاتم ٧/٢١٧٣. وعزاه السيوطي إلى أبي الشيخ. وهي قراءة شاذة، تروى أيضًا عن عبد الله بن عون، وأبي حيوة. انظر: مختصر ابن خالويه ص٦٩.أخرجه ابن جرير ١٣/٢٥٠. وعزاه السيوطي إلى أبي عبيد، وابن المنذر. وهي قراءة العشرة.عزاه السيوطي إلى ابن الأنباري. وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١١/٤٠٥.عزاه السيوطي إلى ابن الأنباري. وهي قراءة شاذة. انظر: مجمع البيان ٥/٢٥٠.عزاه السيوطي إلى ابن الأنباري. وهي قراءة شاذة، تروى أيضًا عن عبد الله بن عون. انظر: المحتسب ١/٣٤٦.أخرجه ابن جرير ١٣/٢٤٩-٢٥٠ وزاد: وكان للعباس منها واحدًا في الجاهلية، وابن أبي حاتم ٧/٢١٧٣، وابن مردويه -كما في فتح الباري ٨/٣٥٩-، والضياء ١٠/٩٥ (٩٣). وعزاه السيوطي إلى ابن منده، وابن المنذر، وابن الأنباري، وأبي الشيخ، وابن منده في غرائب شعبة، وابن مردويه.أخرجه ابن جرير ١٣/٢٥١-٢٥٢. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء، والطستي.أخرجه ابن أبي حاتم ٧/٢١٧٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٥٠، وابن أبي حاتم ٧/٢١٧٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٥٠.أخرجه ابن جرير ١٣/٢٤٥، وابن أبي حاتم ٧/٢١٧١. وعزاه السيوطي إلى ابن المنذر، وابن الأنباري.أخرجه ابن جرير ١٣/٢٥٠-٢٥١، وابن أبي حاتم ٧/٢١٧٣.أخرجه ابن جرير ١٣/٢٥٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٤٥.أخرجه ابن أبي حاتم ٧/٢١٧٣.تفسير مقاتل بن سليمان ٢/٣٤٤.تفسير الثوري ص١٤٤.أخرجه ابن جرير ١٣/٢٥٢، وابن أبي حاتم ٧/٢١٧٣-٢١٧٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٥٢، وابن أبي حاتم ٧/٢١٧٣-٢١٧٤.تفسير مقاتل بن سليمان ٢/٣٤٤.عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه الطبراني ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه ابن جرير ١٣/٢٥٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٢٥٣-٢٥٤.أخرجه ابن جرير ١٣/٢٥٣، وابن أبي حاتم ٧/٢١٧٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ٥/٢٤٠.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٥٥.تفسير الثوري ص١٤٥.
12,73," <q>﴿قَالُوا۟ تَٱللَّهِ لَقَدۡ عَلِمۡتُم مَّا جِئۡنَا لِنُفۡسِدَ فِی ٱلۡأَرۡضِ وَمَا كُنَّا سَـٰرِقِینَ ۝٧٣﴾</q> - تفسير ٣٧٨٢٩- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿ما جئنا لنفسد في الأرض﴾</q>، يقول: ما جِئنا لِنَعْصِيَ في الأرض{1}. (٨/٢٩٢) ٣٧٨٣٠- قال مقاتل بن سليمان: فرَدُّ الإخوة القولَ على المنادي: <q>﴿قالُوا تاللَّهِ لَقَدْ عَلِمْتُمْ ما جِئْنا لِنُفْسِدَ فِي الأَرْضِ﴾</q> يعني: أرض مصر بالمعاصي، <q>﴿وما كُنّا سارِقِينَ﴾</q> وقد رددنا عليكم الدراهمَ التي كانت في أوعيتنا، ولو كُنّا سارقين ما رَدَدْناها عليكم{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٢٥٦، وابن أبي حاتم ٧/٢١٧٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٤.
12,74," <q>﴿قَالُوا۟ فَمَا جَزَ ٰ⁠ۤؤُهُۥۤ إِن كُنتُمۡ كَـٰذِبِینَ ۝٧٤﴾</q> - تفسير ٣٧٨٣١- قال مقاتل بن سليمان: <q>﴿قالُوا﴾</q> أي: المُنادي ومَن معه: <q>﴿فَما جَزاؤُهُ﴾</q> أي: السارق؛ <q>﴿إنْ كُنْتُمْ كاذِبِينَ﴾</q>{1}. (ز) ٣٧٨٣٢- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ- في قوله: <q>﴿قالوا فما جزاؤه﴾</q>، قال: عَرَّفوا الحكم في حُكْمِهم{2}. (٨/٢٩٢) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٦٦ من طريق ابن وهب بمعناه، وابن أبي حاتم ٧/٢١٧٤ من طريق أصبغ.
12,75," <q>﴿قَالُوا۟ جَزَ ٰ⁠ۤؤُهُۥ مَن وُجِدَ فِی رَحۡلِهِۦ فَهُوَ جَزَ ٰ⁠ۤؤُهُۥۚ﴾</q> - تفسير ٣٧٨٣٣- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿قالُوا جَزاؤُهُ مَن وُجِدَ فِي رَحْلِهِ فَهُوَ جَزاؤُهُ﴾</q>، قال: كانوا أخبروه بما يُحْكَم في بلادهم أنّه مَن سرق ضُعِّفَ عليه الغُرْم، ولم يُؤْخَذ عبدًا{1}. (ز) ٣٧٨٣٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قوله: <q>﴿قالوا فما جزاؤه إن كنتم كاذبين*قالوا جزاؤه من وجد في رحله فهو جزاؤه﴾</q>، يقول: تأخذونه؛ فهو لكم{2}. (٨/١٩٥) ٣٧٨٣٥- عن محمد بن السائب الكلبي -من طريق مَعْمَر- قال: أخبَرُوه بما يُحْكَم في بلادهم؛ أنّه مَن سَرَق أُخِذ عبدًا، فقالوا: <q>﴿جزاؤه من وجد في رحله﴾</q>{3}. (٨/٢٩٢) ٣٧٨٣٦- قال مقاتل بن سليمان: <q>﴿قالُوا جَزاؤُهُ مَن وُجِدَ فِي رَحْلِهِ﴾</q> يعني: في وعائه، يعني: المتاع <q>﴿فَهُوَ جَزاؤُهُ﴾</q> يعني: هو مكان سرقته. وكان الحُكْمُ بأرض مصر أن يُغَرَّم السارِق عبدًا يُسْتَخْدَم على قدر ضِعْفِ ما سرق ويُتْرَك، وكان الحكم بأرض كنعان أن يُتَّخَذ السارِق عبدًا يُسْتَخْدَم على قدر سرقته، ثُمَّ يُخَلّى سبيله، فيَذْهَب حيث شاء. فحكموا بأرضِ مصر بقضاء أرضهم{4}٣٤١٧. (ز) ٣٤١٧ نسب ابنُ عطية (٥/١٢٣) هذا القول للسدي، وانتقده مستندًا للدلالة العقلية، فقال: «وهذا يضعفه رجوع الصواع، فكان ينبغي ألا يؤخذ بنيامين إذ لم يبق فيما يخدم». ٣٧٨٣٧- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فهو جزاؤه﴾</q>، أي: سُلِّمَ به{5}. (ز) ٣٧٨٣٨- عن مَعْمَر بن راشد -من طريق عبد الرزاق- قال: بلغنا في قوله: <q>﴿قالوا فما جزاؤه إن كنتم كاذبين﴾</q>: أخبروا يوسف بما يُحْكَم في بلادهم؛ أنّه مَن سُرِق أُخِذَ عبدًا، فقالوا: <q>﴿جزاؤه من وجد في رحله فهو جزاؤه﴾</q>{6}. (ز) ٣٧٨٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- فقالوا: <q>﴿جزاؤه من وجد في رحله فهو جزاؤه﴾</q>، وكان الحُكْمُ عند الأنبياء -يعقوب وبنيه ﵈ أن يُؤْخَذ السارِقُ بسرقته عبدًا، يُسْتَرَقُّ{7}٣٤١٨. (٨/٢٩٢) ٣٤١٨ ذكر ابنُ عطية (٥/١٢٣) أنّه قيل بأنّ الحُكم باسترقاق السّارق كان في أول الإسلام ثم نُسِخ بالقطع، وانتقده مستندًا لمخالفته الواقع، فقال: «وهذا ضعيف، ما كان قطُّ فيما عَلِمْتُ». <q>﴿كَذَ ٰ⁠لِكَ نَجۡزِی ٱلظَّـٰلِمِینَ ۝٧٥﴾</q> - تفسير ٣٧٨٤٠- قال مقاتل بن سليمان: <q>﴿كَذلِكَ نَجْزِي الظّالِمِينَ﴾</q>، يعني: هكذا نجزي السارقين. كقوله في المائدة [٣٩]: <q>﴿فَمَن تابَ مِن بَعْدِ ظُلْمِهِ﴾</q>، يعني: بعد سَرِقَته{4}. (ز) ٣٧٨٤١- عن محمد بن إسحاق -من طريق سلمة- <q>﴿كذلك نجزي الظالمين﴾</q>، أي: كذلك نصنع بِمَن سَرَق مِنّا{9}. (ز) ",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٣٢٦.أخرجه ابن جرير ١٣/٢٥٨، وابن أبي حاتم ٧/٢١٧٤.أخرجه عبد الرزاق ١/٣٢٦، وابن جرير ١٣/٢٥٨ عن معمر قال: بلغنا. ولم يذكر الكلبي. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٥٧، وابن أبي حاتم ٧/٢١٧٤-٢١٧٥.أخرجه ابن جرير ١٣/٢٥٨.أخرجه ابن جرير ١٣/٢٦٦ عند قوله: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، وابن أبي حاتم ٧/٢١٧٤ من طريق أصبغ بلفظ: عرفوا الحكم في حكمهم. وقد سبق.تفسير مقاتل بن سليمان ٢/٣٤٤.أخرجه ابن جرير ١٣/٢٥٧، وابن أبي حاتم ٧/٢١٧٥.
12,76," <q>﴿فَبَدَأَ بِأَوۡعِیَتِهِمۡ قَبۡلَ وِعَاۤءِ أَخِیهِ ثُمَّ ٱسۡتَخۡرَجَهَا مِن وِعَاۤءِ أَخِیهِۚ﴾</q> - تفسير ٣٧٨٤٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فبدأ بأوعيتهم﴾</q> الآية، قال: ذُكِر لنا: أنّه كان كُلَّما فتح متاعَ رجل استغفر تأثُّمًا مِمّا صَنَعَ، حتى بقي متاعُ الغلام، قال: ما أظُنَّ أنّ هذا أخذ شيئًا. قالوا: بلى، فاستَبْرِه{1}{2}٣٤١٩. (٨/٢٩٢) ٣٤١٩ ذكر ابنُ عطية (٥/١٢٤-١٢٥) أنّ ظاهر كلام قتادة وغيره أنّ المستغفر كان يوسف؛ لأنّه كان يُفَتِّشهم ويعلم أين الصواع، حتى فرغ منهم، وانتهى إلى رحل بنيامين. ثُمَّ بيَّن أنّ هذا التفتيش من يوسف يقتضي أمرين: الأول: أنّ المؤذن إنّما سرقه برأيه. الثاني: أن يُقال: جميع ذلك كان بأمر الله تعالى. وعلَّق عليه بقوله: «ويُقَوِّي ذلك قوله: <q>﴿كدنا﴾</q>، وكيف لا يكون برأي يوسف وهو مُضطَرٌّ في محاولته إلى أن يلزمهم حكم السرقة؛ لِيَتِمَّ له أخذُ أخيه». ٣٧٨٤٣- عن إسماعيل السُّدِّيّ-من طريق أسباط- قال: <q>﴿فبدأ بأوعيتهم قبل وعاء أخيه﴾</q>، فلمّا بقي رَحْلُ الغلام قال: ما كان هذا الغلام ليأخُذَها. قالوا: واللهِ، لا يُتْرَكُ حتى تنظر في رحله؛ ونذهب وقد طابت نفسُك. فأدخل يدَه في رحله، فاستخرَجها مِن رحل أخيه، ... فلمّا استخرجها مِن رحل الغلامِ انقَطَعَتْ ظهورُهم، وهلكوا، وقالوا: ما يزال لنا منكم بلاءٌ يا بني راحيل، متى أخذتَ هذا الصُّواع؟! قال بنيامين: بل بنو راحيل الذين لا يزال لهم منكم بلاء، ذهبتم بأخي فأهلكتموه في البَرِّيَّة، وما وضع هذا الصُّواعَ في رحلي إلا الذي وضع الدراهم في رِحالكم. قالوا: لا تَذْكُرِ الدراهمَ فنُؤْخَذ بها. فوقعوا فيه، وشتموه، فلمّا أدخلوهم على يوسف دعا بالصُّواع، ثُمَّ نَقَر فيه، ثم أدناه مِن أُذُنِه، ثم قال: إنّ صُواعِي هذا لَيُخبِرني أنّكم كنتم اثني عشر أخًا، وأنّكم انطلقتم بأخٍ لكم فبِعْتُمُوه. فلمّا سمعها بنيامين قام فسَجَد ليوسف، وقال: أيُّها المَلِك، سل صُواعَك هذا: أحَيٌّ أخي ذاك أم لا؟ فنقرها يوسف، ثم قال: نعم هو حَيٌّ، وسوف تراه. قال: اصنع بي ما شئت، فإنه إن عَلِم بي اسْتَنقَذَني. فدخل يوسف، فبكى، ثُمَّ تَوَضَّأ، ثم خرج. فقال بنيامين: أيها الملِك، إنِّي أراك تضرب بصواعك فيُخبِرُكَ بالحق، فسَلْه مَن صاحبه؟ فنقر فيه، ثم قال: إن صواعي هذا غضبان، يقول: كيف تسألني مَن صاحبي وقد رأيتَ مَعَ مَن كنتُ؟ وكان بنو يعقوب إذا غضبوا لم يُطاقوا، فغَضِب روبيل، فقام، فقال: أيها الملك، واللهِ، لَتَتْرُكَنّا أو لَأَصِيحَنَّ صيحةً لا تبقى امرأةٌ حامِلٌ بمصر إلا طَرَحَتْ ما في بطنها. وقامتْ كلُّ شَعَرة مِن جسد روبيل، فخرجت مِن ثيابه، فقال يوسف لابنه{3}: مُرَّ إلى جنب روبيل، فمُسَّه. وكان بنو يعقوب إذا غضب أحدهم فمَسَّه الآخَرُ ذَهِب غضبُه، فمَرَّ الغلامُ إلى جانبه، فمَسَّه، فذهب غَضَبُه، فقال روبيل: مَن هذا؟! إنّ في هذه البلاد لَبزْرًا من بَزْرِ{4} يعقوب. قال يوسف: ومَن يعقوب؟ فغضِب روبيل، فقال: يأيُّها المَلِك، لا تَذْكُرَنَّ يعقوب؛ فإنّه سَرِيُّ الله، ابن ذبيح الله، ابن خليل الله. فقال يوسف: أنت إذن إن كنت صادِقًا{5}. (٨/١٩٦-١٩٧) ٣٧٨٤٤- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: ذُكِر لنا: أنّه كان كُلَّما بَحَثَ متاعَ رجل منهم استغفر ربَّه تَأَثُّمًا، قد علم أين موضع الذي يطلب، حتى إذا بقي أخوه وعلم أنّ بُغْيَتَه فيه قال: لا أرى هذا الغلامَ أخذه، ولا أُبالِي أن لا أبحث متاعَه. قال إخوتُه: إنّه أطيب لنفسك وأنفسنا أن تستبرئ متاعَه أيضًا. فلمّا فتح متاعَه استخرج بُغْيَتَه منه، قال الله:<q>﴿كذلك كدنا ليوسف﴾</q>{6}. (ز) ٣٧٨٤٥- قال مقاتل بن سليمان: <q>﴿فَبَدَأَ﴾</q> المنادي <q>﴿بِأَوْعِيَتِهِمْ﴾</q>، فنظر فيها، فلم يَرَ شيئًا <q>﴿قَبْلَ وِعاءِ أخِيهِ﴾</q> ثم انصرف، ولم ينظر في وِعاء بِنيامين، فقال: ما كان هذا الغلامُ لِيَأْخُذَ الإناءَ. قال إخوته: لا نَدَعُك حتى تنظر في وِعائه؛ فيكون أطيبَ لنفسك. فنظر فإذا هو بالإناء، <q>﴿ثُمَّ اسْتَخْرَجَها مِن وِعاءِ أخِيهِ﴾</q> يعني: مِن متاع أخيه، وهو أخو يوسف لأبيه وأُمِّه{7}. (ز) ٣٧٨٤٦- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا قال الرسولُ لهم: <q>﴿ولمن جاء به حمل بعير وأنا به زعيم﴾</q> قالوا: ما نعلمه فينا، ولا معنا. قال: لَسْتُم ببارِحِينَ حتّى أُفَتِّش أمتعتكم، وأُعْذِرَ في طلبها منكم. فبدأ بأوعيتهم وعاءً وعاءً، يُفَتِّشها، وينظر ما فيها، حتى مَرَّ على وعاء أخيه، ففَتَّشه، فاستخرجها منه، فأخذ برقبته، فانصرف به إلى يوسف، يقول الله: <q>﴿كذلك كدنا ليوسف﴾</q>{6}٣٤٢٠. (ز) ٣٤٢٠ ذكر ابنُ عطية (٥/١٢٥) أنّ الضمير في قوله: <q>﴿استخرجها﴾</q> يحتمل احتمالين: الأول: أن يعود على السِّقاية. الثاني. أن يعود على السرقة. <q>﴿كَذَ ٰ⁠لِكَ كِدۡنَا لِیُوسُفَۖ﴾</q> - تفسير ٣٧٨٤٧- قال عبد الله بن عباس: <q>﴿كذلك كدنا﴾</q>، أي: صنعنا{9}. (ز) ٣٧٨٤٨- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿كذلك كدنا ليوسف﴾</q>، قال: كذلك صنعنا ليوسف{10}. (٨/٢٩٣) ٣٧٨٤٩- عن إسماعيل السُّدِّيّ - ن طريق أسباط- قال: يقول الله: <q>﴿كذلك كدنا ليوسف﴾</q>. يقول: صَنَعْنا ليوسف{11}. (٨/١٩٦) ٣٧٨٥٠- عن الربيع [بن أنس]، في قوله:<q>﴿كذلك كدنا﴾</q>، قال: ألْهَمْنا{9}. (ز) ٣٧٨٥١- قال مقاتل بن سليمان: <q>﴿كَذلِكَ كِدْنا﴾</q> يعني: هكذا صنعنا <q>﴿لِيُوسُفَ﴾</q> أن يأخذ أخاه خادِمًا بسرقته{7}. (ز) ٣٧٨٥٢- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قوله: <q>﴿كذلك كدنا ليوسف﴾</q>، قال: صَنَعْنا{14}. (ز) <q>﴿مَا كَانَ لِیَأۡخُذَ أَخَاهُ فِی دِینِ ٱلۡمَلِكِ﴾</q> - تفسير ٣٧٨٥٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، يقول: في سُلْطان الملك{15}. (٨/٢٩٣) ٣٧٨٥٤- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، يقول: في سلطان الملك. قال: كان في دِين ملكهم أنّه مَن سَرَق أُخِذَت منه السرقة، ومثلُها معها مِن ماله، فيعطيه المسروق{16}. (٨/٢٩٣) ٣٧٨٥٥- قال الضَّحّاك بن مُزاحِم: كان الملكُ إذا أُتِي بسارِق كَشَف عن عرقوبيه، وسَمَل عينيه{9}. (ز) ٣٧٨٥٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، قال: لم يكن ذلك في دِين الملك؛ أن يأخذ مَن سَرَق عبدًا{18}. (٨/٢٩٣) ٣٧٨٥٧- قال قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿في دين الملك﴾</q>، قال: لم يكن ذلك في دِين الملك. قال: حُكْمه{19}. (ز) ٣٧٨٥٨- عن محمد بن كعب القرظي -من طريق أبي مودود المديني- في الآية، قال: دِين الملك لا يُؤْخَذ به مَن سرق أصلًا، ولكن الله كاد لأخيه حتى تكلَّموا بما تكلَّموا به، فأخذهم بقولهم، وليس في قضاء الملك{19}. (٨/٢٩٣) ٣٧٨٥٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، يقول: في حُكْم الملك{21}. (٨/١٩٦) ٣٧٨٦٠- عن محمد بن السائب الكلبي -من طريق مَعْمَر- قال: كان حُكْمُ الملكِ أنّ مَن سرق ضاعف عليه الغُرْم{22}. (٨/٢٩٤) ٣٧٨٦١- قال مقاتل بن سليمان: <q>﴿في دين الملك﴾</q> يعني: في سلطان الملك، فذلك قوله: <q>﴿ما كانَ لِيَأْخُذَ أخاهُ﴾</q> يعني: لِيَحْبِسَ أخاه <q>﴿فِي دِينِ المَلِكِ﴾</q> يعني: حُكْمَ الملك؛ لأنّ حُكْمَ الملكِ أن يُغَرَّم السارقُ ضعفَ ما سرق، ثم يُتْرَك{7}. (ز) ٣٧٨٦٢- عن محمد بن إسحاق -من طريق سلمة- <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، أي: بِظُلْم، ولكن اللهَ كاد ليوسف لِيَضُمَّ إليه أخاه{24}. (ز) ٣٧٨٦٣- عن سفيان الثوري، <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، قال: في قضاء الملك مَن سَرَقَ اتَّخَذَه عبدًا{25}. (ز) ٣٧٨٦٤- عن عبد الرحمن بن زيد بن أسلم-من طريق ابن وهب- في قوله: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، قال: ليس في دين الملك أن يُؤْخَذ السارِقُ بسرقته. قال: وكان الحُكْمُ عند الأنبياء -يعقوب وبنيه- أن يُؤْخَذَ السارِق بسرقته عبدًا يُسْتَرَقُّ{26}. (ز) (٨/٢٩٢) ٣٧٨٦٥- عن مَعْمَر بن راشد -من طريق عبد الرزاق- قال: بلغه في قوله: <q>﴿ما كان ليأخذ أخاه في دين الملك﴾</q>، قال: كان حُكْمِ الملك أنّ مَن سرق ضُوعِف عليه الغُرْم{27}٣٤٢١. (ز) ٣٤٢١ اختُلِف في المراد بقوله: <q>﴿دين الملك﴾</q> على قولين: الأول: أنّ المعنى: في سلطان الملك. الثاني: في حكمه وقضائه. ورأى ابنُ جرير (١٣/٢٦٦) تقارب القولين، فقال: «وهذه الأقوال وإن اختلفت ألفاظ قائليها في معنى دين الملك فمُتقارِبة المعاني؛ لأنّ مَن أخذه في سلطان الملك عامَلَه بعَمَله، فيريناه أخذه إذا لم يغيره، وذلك منه حكم عليه، وحكمه عليه قضاؤه، وأصل الدين: الطاعة». وبنحوه قال ابنُ عطية (٥/١٢٣). <q>﴿إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُۚ﴾</q> - تفسير ٣٧٨٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلا أن يشاء الله﴾</q>، قال: إلا بِعِلَّة كادها اللهُ ليوسفَ ﵇ فاعْتلَّ بها{28}. (٨/٢٩٤) ٣٧٨٦٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿إلا أن يشاء الله﴾</q> ولكن صَنَعْنا له، بأنّهم قالوا: <q>﴿فهو جزاؤه﴾</q>{29}. (٨/١٩٦) ٣٧٨٦٨- قال مقاتل بن سليمان: <q>﴿إلّا أنْ يَشاءَ اللَّهُ﴾</q> ذلك ليوسف{7}. (ز) <q>﴿نَرۡفَعُ دَرَجَـٰتࣲ مَّن نَّشَاۤءُۗ﴾</q> - تفسير ٣٧٨٦٩- عن مالك بن أنس، قال: سمعتُ زيدَ بن أسلم يقول في هذه الآية: <q>﴿نرفع درجات من نشاء﴾</q>. قال: بالعلم؛ يرفعُ الله بِهِ مَن يشاء في الدنيا{31}. (٨/٢٩٤) ٣٧٨٧٠- قال مقاتل بن سليمان: <q>﴿نَرْفَعُ دَرَجاتٍ مَن نَشاءُ﴾</q>، يعني: فضائل يوسف حين أخَذَ أخاه{32}. (ز) ٣٧٨٧١- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿نرفع درجات من نشاء﴾</q>، قال: يوسف وإخوته أُوتُوا علمًا، فرفعنا يوسفَ فوقهم في العلم درجة{33}. (٨/٢٩٤) <q>﴿وَفَوۡقَ كُلِّ ذِی عِلۡمٍ عَلِیمࣱ ۝٧٦﴾</q> - قراءات ٣٧٨٧٢- عن قتادة: وفي قراءة عبد الله بن مسعود: (وفَوْقَ كُلِّ عالِمٍ عَلِيمٌ){34}٣٤٢٢. (٨/٢٩٦) ٣٤٢٢ ذَكَرَ ابنُ عطية (٥/١٢٤) أنّه قيل على هذه القراءة: إنّ <q>﴿ذي﴾</q> زائدة. وقيل: (عالِمٍ) مصدر كالباطل. <q>﴿وَفَوۡقَ كُلِّ ذِی عِلۡمٍ عَلِیمࣱ ۝٧٦﴾</q> - تفسير الآية ٣٧٨٧٣- عن عائشة، قالت: أمَرَنا رسولُ الله ﷺ أن نُنَزِّل الناسَ منازلهم، مع ما نطق به القرآن مِن قول الله تعالى: <q>﴿وفوق كل ذي علم عليم﴾</q>{35}. (ز) ٣٧٨٧٤- عن محمد بن كعب، قال: سأل رجلٌ عليًّا عن مسألةٍ، فقال فيها، فقال الرجل: ليس هكذا، ولكن كذا وكذا. قال علي: أصبتَ وأخطأتُ، <q>﴿وفوق كل ذى علم عليم﴾</q>{36}. (٨/٢٩٥) ٣٧٨٧٥- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وفوق كل ذى علم عليم﴾</q>، قال: يكون هذا أعلمَ مِن هذا، وهذا أعلم مِن هذا، واللهُ فوقَ كُلِّ عالم{37}. (٨/٢٩٤) ٣٧٨٧٦- عن سعيد بن جبير، قال: كُنّا عند ابن عباس، فحدَّث بحديث، فقال رجل: <q>﴿وفوق كل ذي علم عليم﴾</q>. فقال ابنُ عباس: بِئْسَ ما قلتَ، اللهُ العليم الخبير هو فوق كُلِّ عالم{38}٣٤٢٣. (٨/٢٩٥) ٣٤٢٣ ساق ابنُ عطية (٥/١٢٥) هذا القول، ثم علّق بقوله: «فبَيْن هذا وبين قول الحسن فَرْق». ٣٧٨٧٧- عن سعيد بن جبير -من طريق عبد الأعلى- <q>﴿وفوق كل ذي علم عليم﴾</q>، قال: اللهُ أعلمُ مِن كُلِّ أحد{39}. (٨/٢٩٥) ٣٧٨٧٨- عن الضَّحّاك بن مُزاحِم، <q>﴿وفوق كل ذي علم عليم﴾</q>، قال: يعني الله بذلك نفسَه{40}. (٨/٢٩٥) ٣٧٨٧٩- عن عكرمة مولى ابن عباس -من طريق خالد الحذّاء- في قوله: <q>﴿وفوق كل ذي علم عليم﴾</q>، قال: عِلمُ اللهِ فوق كُلِّ أحد{41}. (٨/٢٩٥) ٣٧٨٨٠- عن الحسن البصري -من طريق ابن شبرمة- في الآية، قال: ليس عالِمٌ إلا فوقَه عالِمٌ، حتى ينتهي العلمُ إلى الله{42}. (٨/٢٩٥) ٣٧٨٨١- عن بشير الهُجَيْميِّ، قال: سمعتُ الحسن [البصري] قرأ هذه الآية يومًا: <q>﴿وفوق كل ذي علم عليم﴾</q>، ثم وقف، فقال: إنّه -واللهِ- ما أمْسى على ظهر الأرض عالِمٌ إلا فوقه مَن هو أعلمُ منه، حتى يعود العِلْمُ إلى الذي علَّمه{39}. (ز) ٣٧٨٨٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وفوق كل ذي علم عليم﴾</q>، قال: هكذا حتى ينتهي العلم إلى الله؛ مِنه بَدَأ، وإليه يعود{44}٣٤٢٤. (٨/٢٩٦) ٣٤٢٤ ذكر ابنُ عطية (٥/١٢٤) أن معنى قوله: <q>﴿وفوق كل ذي علم عليم﴾</q>: أنّ البشر في العلم درجات، فكل عالم فلا بد من أعلم منه؛ فإما مِن البشر، وإما الله ﷿. ثم قال: «وما ذكرناه من المعنى في قوله: <q>﴿وفوق كل ذي علم عليم﴾</q> هو قول الحسن وقتادة». وبيَّنَ أنّ هناك فرقًا بين هذا القول وبين قول ابن عباس من طريق ابن جُبَيْر. ٣٧٨٨٣- عن مجاهد بن جبر= (ز) ٣٧٨٨٤- وعبد الملك ابن جُرَيْج، في قوله: <q>﴿وفوق كل ذي علم عليم﴾</q>، قالا: هو ذلك أيضًا، يوسفُ وإخوتُه هو فوقهم في العلم{45}. (٨/٢٩٦) ٣٧٨٨٥- قال مقاتل بن سليمان: ثم قال: <q>﴿وفَوْقَ كُلِّ ذِي عِلْمٍ عَلِيمٌ﴾</q> يقول الرب تعالى: عالم، <q>﴿وفَوْقَ كُلِّ ذِي عِلْمٍ عَلِيمٌ﴾</q> يقول: يوسفُ أعْلَمُ إخوتِه{32}. (ز) ",footnotes:1:قال الشيخ شاكر في تحقيقه ١٦/١٨٤: وقوله: استبره، من الاستبراء، سهلت همزتها، وأصله: واستبرئه، والاستبراء: طلب البراءة من الشيء، ما كان تهمة أو عيبًا أو قادحًا.أخرجه عبد الرزاق ١/٣٢٥-٣٢٦ من طريق معمر بلفظ:«فاستَبْرِه»، وابن جرير ١٣/٢٥٩-٢٦٠ بلفظ: «فاستبْرِئْه»، وابن أبي حاتم ٧/٢١٧٥ من طريق سعيد بن بشير. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.كذا في المطبوع. وقال محققو الدر: ليست في الأصل، وبعده في نسخة: «مرة»، ونقلوا عن هامش إحدى النسخ:«لعله لابنه أو لبعض بنيه».البَزْرُ: الأَولاد. لسان العرب (بزر).أخرج أوله ابن جرير ١٣/٢٦٠، وابن أبي حاتم ٧/٢١٧٥، ٧/٢١٧٩ بتمامه.أخرجه ابن جرير ١٣/٢٦٠.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه ابن جرير ١٣/٢٦٠.تفسير الثعلبي ٥/٢٤٢.أخرجه ابن جرير ١٣/٢٦٣-٢٦٤، وابن أبي حاتم ٧/٢١٧٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٢٦٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٥/٢٤٢.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه ابن جرير ١٣/٢٦٣.أخرجه ابن جرير ١٣/٢٦٤، وابن أبي حاتم ٧/٢١٧٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٦٣-٢٦٤ مختصرًا بلفظ: في سلطان الملك، وابن أبي حاتم ٧/٢١٧٦ من طريق أبي روق دون قوله: في سلطان الملك. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير الثعلبي ٥/٢٤٢.أخرجه عبد الرزاق في تفسيره ١/٣٢٦ من طريق مَعْمَر، واللفظ له، وابن جرير ١٣/٢٦٤-٢٦٥، وابن أبي حاتم ٧/٢١٧٦ من طريق سعيد بن بشير. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٦٥.أخرجه ابن جرير ١٣/٢٦٥.أخرجه ابن جرير ١٣/٢٦٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ١/٣٢٦ عن معمر عن الكلبي، وابن جرير ١٣/٢٦٥ عن معمر قال: بلغنا. ولم يذكر الكلبي. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه ابن جرير ١٣/٢٦٥، وابن أبي حاتم ٧/٢١٧٦.تفسير الثوري ص١٤٥.أخرجه ابن جرير ١٣/٢٦٦، وابن أبي حاتم ٧/٢١٧٤ عند قوله: <q>﴿جزاؤه من وجد في رحله﴾</q> من طريق أصبغ بنحوه.أخرجه عبد الرزاق ١/٣٢٦ عن معمر عن الكلبي، وابن جرير ١٣/٢٦٥ ولم يذكر الكلبي.أخرجه ابن جرير ١٣/٢٦٧، وابن أبي حاتم ٧/٢١٧٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٦٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٥.أخرجه أحمد ١/٥٠٠ (٤٤٩)، وابن أبي حاتم ٧/٢١٧٦-٢١٧٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٦٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧١. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٦٩، والمحتسب ١/٣٤٦.علَّقه مسلم في مقدمة صحيحه ١/٦، ووصله أبو نعيم في مستخرجه على صحيح مسلم ١/٨٩ (٥٧) بلفظه. وأخرجه أبو داود (٤٨٤٢)، والحاكم في معرفة علوم الحديث ص٤٨ وغيره دون قوله: مع ما نطق به ...، كلهم مِن طريق حبيب بن أبي ثابت، عن ميمون بن أبي شبيب، عن عائشة به. قال أبو داود: «ميمون لم يدرك عائشة». وقال الحاكم: «حديث صحيح». وتُعُقِّب في ذلك. وللحديث شواهد يتقوى بها، قال السخاوي: «وبالجملة فحديث عائشة حسن». ينظر: المقاصد الحسنة ص١٦٣-١٦٤ وكشف الخفاء ١/٢٢١-٢٢٢.أخرجه ابن جرير ١٣/٢٦٩.أخرجه ابن جرير ١٣/٢٦٨-٢٦٩، وابن أبي حاتم ٧/٢١٧٧، والبيهقي في الأسماء والصفات (٢٣٦). وعزاه السيوطي إلى الفريابي، وابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/٣٢٦-٣٢٧، وسعيد بن منصور (١١٣٧ - تفسير)، وابن جرير ١٣/٢٦٩، وابن أبي حاتم ٧/٢١٧٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧٠.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٦٩، وابن أبي حاتم ٧/٢١٧٧، والبيهقي في الأسماء والصفات (٢٣٧). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٢٧٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٧٠.أخرجه ابن جرير ١٣/٢٧١ بلفظ: حتى ينتهي العلم إلى الله؛ منه بدأ، وتعلَّمت العلماء، وإليه يعود، وابن أبي حاتم ٧/٢١٧٧ واللفظ له، من طريق سعيد بن بشير.عزاه السيوطي إلى ابن المنذر عن مجاهد، وإلى أبي الشيخ عن ابن جريج.تفسير مقاتل بن سليمان ٢/٣٤٦.
12,77," <q>﴿قَالُوۤا۟ إِن یَسۡرِقۡ فَقَدۡ سَرَقَ أَخࣱ لَّهُۥ مِن قَبۡلُۚ﴾</q> - تفسير ٣٧٨٨٦- عن عبد الله بن عباس، عن النبي ﷺ، في قوله: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>، قال: «سرق يوسفُ ﵇ صنمًا لِجَدِّه أبي أُمِّه مِن ذهب وفضة، فكسره، وألقاه على الطريق، فعيَّره بذلك إخوتُه»{1}. (٨/٢٩٧) ٣٧٨٨٧- عن عبد الله بن عباس، قال: سرق مُكْحُلَةً لِخالتِه{2}. (٨/٢٩٧) ٣٧٨٨٨- قال كعب الأحبار: كان يوسفُ في المنزل وحدَه، فأتاه سائلٌ، وكان في المنزل [عَناق]، وهي الأُنثى مِن الجَدْيِ، فدفعها إلى السائل مِن غير أمر أبيه{3}. (ز) ٣٧٨٨٩- عن سعيد بن جبير -من طريق أبي حصين- في قوله: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>، قال: سرق يوسف صنمًا لجده أبي أُمِّه من ذهب أو فضة، فكسره، وألقاه في الطريق، فعيَّره بذلك إخوته{4}. (٨/٢٩٧) ٣٧٨٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيج- في قوله: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>، قال: يعنون: يوسف{5}. (٨/٢٩٦) ٣٧٨٩١- قال مجاهد بن جبر: إنّ يوسف جاءه سائِلٌ يومًا، فأخذ بَيْضَةً مِن البيت، فناولها للسائل{6}. (ز) ٣٧٨٩٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: كان أوَّل ما دخل على يوسف مِن البلاء -فيما بلغني- أنّ عمته وكانت أكبر ولد إسحاق، وكانت إليها مِنطَقةُ{7} إسحاق، فكانوا يتوارثونها بالكِبَر، وكان يعقوبُ حين وُلِد له يوسف قد حَضَنَتْهُ عمَّتُه، فكان معها وإليها، فلم يُحِبَّ أحدٌ شيئًا مِن الأشياء كحُبِّها إيّاه، حتى إذا تَرَعْرَعَ وقعت نفسُ يعقوب عليه، فأتاها، فقال: يا أُخيَّةُ، سلِّمي إلَيَّ يوسف، فواللهِ، ما أقدر على أن يغيب عَنِّي ساعة. قالت: فواللهِ، ما أنا بتاركته، فدعه عندي أيّامًا أنظر إليه، لعلَّ ذلك يُسَلِّيني عنه. فلمّا خرج يعقوب مِن عندها عَمَدت إلى مِنطَقةِ إسحاق فحَزَمَتْها على يوسف مِن تحت ثيابه، ثم قالت: فقدتُ مِنطَقةَ إسحاق، فانظروا مَن أخذها، ومَن أصابَها. فالتُمِسَت، ثم قالت: اكشفُوا أهلَ البيت. فكشفُوهم، فوجَدُوها مع يوسف، فقالت: واللهِ، إنّه لي لَسَلَمٌ{8}، أصنع فيه ما شِئْتُ. فأتاها يعقوبُ، فأخبرته الخبر، فقال لها: أنتِ وذاك، إن كان فَعَلَ ذلك فهو سَلَمٌ لك، ما أستطيع غير ذلك. فأمْسَكَتْه، فما قَدَرَ عليه حتى ماتت، فهو الذي يقول إخوة يوسف حين صنَع بأخيه ما صنَع: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>{9}. (٨/٢٩٦) ٣٧٨٩٣- عن الضَّحّاك بن مزاحم -من طريق جويبر-، مثله{3}. (ز) ٣٧٨٩٤- عن محمد بن إسحاق، مثله{11}. (ز) ٣٧٨٩٥- عن عطية العوفي، قال: سرق في صِباه مِيلَيْنِ مِن ذهب{12}. (٨/٢٩٧) ٣٧٨٩٦- عن عطية العوفي -من طريق ابن إدريس، عن أبيه- في الآية، قال: كان يوسف ﵇ معهم على الخِوان، فأخذ شيئًا مِن الطعام، فتَصَدَّق به{13}. (٨/٢٩٨) ٣٧٨٩٧- قال وهب بن منبه: كان يُخَبِّئُ الطعامَ مِن المائدة للفقراء{14}. (ز) ٣٧٨٩٨- عن قتادة بن دعامة -من طريق سعيد- قال: سَرِقتُه التي عابوه بها: أخَذَ صنمًا كان لأبي أُمِّه، وإنّما أراد بذلك الخيرَ{15}. (٨/٢٩٨) ٣٧٨٩٩- عن زيد بن أسلم -من طريق هشام بن سعد- قال: كان يوسف غلامًا صغيرًا مع أُمِّه عند خالٍ له، وهو يلعب مع الغلمان، فدخل كنيسةً لهم، فوجد تمثالًا لهم صغيرًا مِن ذهب، فأخذه. قال: وهو الذي عيَّره إخوتُه به: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>{16}. (٨/٢٩٨) ٣٧٩٠٠- قال محمد بن السائب الكلبي: بَعَثَتْهُ أُمُّه حين أرادت أن ترتحل مِن حَرّان مع يعقوب إلى فلسطين والأردن، أمرته أن يذهب، فأخذ جُونَةً{17} فيها أوثان لأبيها مِن ذهب فيأتيها بها، لكي إذا فقدها أبوها أسلم، فانطلق، فأخذها، وجاء بها إلى أُمِّه. فهذه سَرِقَتُه التي يعنون{3}. (ز) ٣٧٩٠١- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في الآية، قال: كانت أمُّ يوسف أمَرت يوسفَ أن يسرق صنمًا لخاله كان يعبده، وكانت مُسْلِمة{19}. (٨/٢٩٨) ٣٧٩٠٢- قال مقاتل بن سليمان: ثم قال إخوة يوسف: <q>﴿قالوا إن يسرق﴾</q> بنيامين <q>﴿فقد سرق أخ له من قبل﴾</q> بنيامين، يعنون: يوسف ﵇. وذلك أنّ جدَّ يوسف أبا أُمِّه كان اسمُه: لاتان، كان يعبد الأصنام، فقالت راحيل لابنها يوسف ﵇: خُذِ الصنم، ففِرَّ به مِن البيت؛ لعله يترك عبادة الأوثان. وكان مِن ذهب، ففعل ذلك يوسف ﵇، فتلك سرقةُ يوسف التي قالوا{20}. (ز) ٣٧٩٠٣- عن محمد بن إسحاق -من طريق ابن حميد- قال: لَمّا رأى بنو يعقوبَ ما صنع إخوة يوسف، ولم يَشُكُّوا أنّه سرق؛ قالوا أسفًا عليهم لِما دخل عليهم في أنفسهم تأنيبًا له: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>. فلمّا سمعها يوسف قال: <q>﴿أنتم شر مكانا﴾</q>. سِرًّا في نفسه، ولم يُبْدِها لهم، <q>﴿والله أعلم بما تصفون﴾</q>{21}. (ز) ٣٧٩٠٤- عن سفيان الثوري، في قوله: <q>﴿إن يسرق فقد سرق أخ له من قبل﴾</q>، قال: كان يوسفُ سَرَق آلهتهم{22}. (ز) ٣٧٩٠٥- قال سفيان بن عيينة: أخذ دجاجةً مِن الطير التي كانت في بيت يعقوب، فأعطاها سائلًا{14}٣٤٢٥. (ز) ٣٤٢٥ ذكر ابنُ عطية (٥/١٢٥) في الآية احتمالين، ووجّههما، فقال: «ويحتمل قولهم: <q>﴿إنْ يَسْرِقْ فَقَدْ سَرَقَ أخٌ لَهُ مِن قَبْلُ﴾</q> تأويلين. أحدهما: أنّهم حققوا السرقة في جانب بنيامين ويوسف ﵉، بحسب ظاهر الحكم، فكأنهم قالوا: إن كان قد سرق فغيرُ بِدْعٍ مِن ابْنَيْ راحيل؛ لأنّ أخاه يوسف كان قد سرق. فهذا من الإخوة إنْحاءٌ على ابْنَيْ راحيل: يوسف، وبنيامين. والوجه الآخر الذي يحتمله لفظهم يتضمن أنّ السرقة في جانب يوسف وبنيامين مظنونة، كأنهم قالوا: إن كان هذا الذي رُمِي به بنيامين حقًّا في نفسه فالذي رُمِي به يوسف قبل حقٌّ إذًا. وكأنّ قصة يوسف والظن به قَوِيا عندهم أقوى مِمّا ظهر في جهة بنيامين». ثم ذكر عن بعض المفسرين أن تقدير الكلام: «فقد قيل عن يوسف: إنه سرق». وانتقده مستندًا للفظ الآية قائلًا: «ونحو هذا من الأقوال التي لا ينطبق معناها على لفظ الآية». <q>﴿فَأَسَرَّهَا یُوسُفُ فِی نَفۡسِهِۦ وَلَمۡ یُبۡدِهَا لَهُمۡۚ﴾</q> - تفسير ٣٧٩٠٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فأسرها يوسف في نفسه ولم يبدها لهم﴾</q>، قال: أسرَّ في نفسه قوله: <q>﴿أنتم شر مكانًا والله أعلم بما تصفون﴾</q>{24}. (٨/٢٩٨) ٣٧٩٠٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فأسرها يوسف في نفسه ولم يبدها لهم﴾</q>: أمّا الذي أسرَّ في نفسه فقوله: <q>﴿أنتم شر مكانا، والله أعلم بما تصفون﴾</q>{25}. (ز) ٣٧٩٠٨- قال مقاتل بن سليمان: <q>﴿فـ﴾</q>لمّا سمع يوسفُ مقالتَهم <q>﴿أسرها يوسف في نفسه ولم يبدها لهم﴾</q>: ولم يُظْهِرها لهم{20}٣٤٢٦. (ز) ٣٤٢٦ رجّح ابنُ عطية (٥/١٢٦-١٢٧) مستندًا إلى الدلالة العقلية أنّ قوله: <q>﴿أنتم شر مكانا﴾</q> قاله يوسف ﵇ جهرًا لهم، فقال: «وقوله: <q>﴿أنْتُمْ شَرٌّ مَكانًا﴾</q> الآية، الظاهرُ منه أنّه قالها إفصاحًا، فكأنّه أسرَّ لهم كراهية مقالتهم، ثم تَجَهَّمهم بقوله: <q>﴿أنْتُمْ شَرٌّ مَكانًا﴾</q> أي: لسوء أفعالكم، والله يعلم إن كان ما وصفتموه حقًّا. وفي اللفظ إشارة إلى تكذيبهم، ومما يُقَوِّي هذا عندي أنّهم تركوا الشفاعة بأنفسهم، وعدلوا إلى الشفاعة بالشيخ ﵇». ورجّح مستندًا إلى اللغة، والنظائر أنّ الذي أسره يوسف في نفسه هو: "الحزازة التي حدثت في نفس يوسف من قولهم، والكلام يتضمنها، وهذا كما تضمن الكلام الضمير الذي في قول حاتم: لَعَمْرُك ما يُغْنِي الثراء عن الفتى ... إذا حَشْرَجَتْ يومًا وضاق بها الصَّدْرُ وهذا كقوله تعالى: <q>﴿ثُمَّ إنَّ رَبَّكَ لِلَّذِينَ هاجَرُوا مِن بَعْدِ ما فُتِنُوا ثُمَّ جاهَدُوا وصَبَرُوا إنَّ رَبَّكَ مِن بَعْدِها لَغَفُورٌ رَحِيمٌ﴾</q> [النحل:١١٠]، فهي مراد بها الحالة المُتَحَصِّلة مِن هذه الأفعال«. ثم ذكر قولين آخرين، فقال:»وقال قوم: أسَرَّ المجازاة. وقال قوم: أسَرَّ الحُجَّة«. ثم قال:»وما قدَّمناه أليق". <q>﴿قَالَ أَنتُمۡ شَرࣱّ مَّكَانࣰاۖ وَٱللَّهُ أَعۡلَمُ بِمَا تَصِفُونَ ۝٧٧﴾</q> - تفسير ٣٧٩٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿شرٌ مكانا﴾</q> قال: يوسفُ يقوله، <q>﴿والله أعلم بما تصفون﴾</q> قال: تقولون{27}. (٨/٢٩٩) ٣٧٩١٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والله أعلم بما تصفون﴾</q>، أي: بما تُكَذِّبون{28}. (ز) ٣٧٩١١- قال مقاتل بن سليمان: قال في نفسه: <q>﴿أنتم شر مكانا﴾</q>. ولم يُسْمِعْهم. قال: أنتم أسوأ صنعًا فيما صنعتم بيوسف، <q>﴿والله أعلم بما تصفون﴾</q> يعني: بما تقولون مِن الكذب أنّ يوسف سرق. فعندها قالوا: ما لقينا مِن ابْنَيْ راحيل؛ يوسف وأخيه؟! فقال بنيامين: ما لَقِيَ ابنا راحيل منكم؟! أمّا يوسف فقد فعلتم به ما فعلتم، وأمّا أنا فسَرَّقْتُمُونِي. قالوا: فمَن جَعَل الإناءَ في متاعك؟ قال: جعله في متاعي الذي جعل الدراهمَ في أمتعتكم. فلمّا ذكر الدراهمَ شتموه، وقالوا: لا تَذْكُرِ الدراهمَ. مخافة أن يُؤْخَذُوا بها{20}. (ز) ٣٧٩١٢- عن محمد بن إسحاق -من طريق سلمة-: فلمّا سمعها يوسف قال: <q>﴿أنتم شر مكانا﴾</q>. سِرًّا في نفسه، <q>﴿ولم يبدها لهم﴾</q>{30}. (ز) <q>﴿قَالَ أَنتُمۡ شَرࣱّ مَّكَانࣰاۖ وَٱللَّهُ أَعۡلَمُ بِمَا تَصِفُونَ ۝٧٧﴾</q> - آثار متعلقة بالآية ٣٧٩١٣- عن ابن عيينة، عن رجل منهم يُقال له: نسيبة، قال: لَمّا لَقِي يوسفُ أخاه قال: هل تَزَوَّجت بعدي؟ قال: نعم. قال: وما شَغَلَك الحزنُ عَلَيَّ؟ قال: إنّ أباك يعقوب قال لي: تَزَوَّج؛ لعل اللهُ أن يَذْرَأَ مِنك ذُرِّيَّةً يُثقِّلون -أو قال: يُسَكِّنُون- الأرض بتسبيحةٍ{31}. (٨/٢٩٩) ",footnotes:1:أورده الديلمي في الفردوس ١/٢٤١ (٩٢٩). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢٤٣.أخرجه ابن جرير ١٣/٢٧٢-٢٧٣، وابن أبي حاتم ٧/٢١٧٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧٢. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢٤٣ من طريق السدي بلفظ: جبة، وتفسير البغوي ٤/٢٦٣.المنطقة: الحزام. مختار الصحاح (نطق).أي: أسير. النهاية (سلم).أخرجه ابن إسحاق -كما في ابن كثير ٤/٣٢٧-، وابن جرير ١٣/٢٧٤، وابن أبي حاتم ٧/٢١٧٩.تفسير الثعلبي ٥/٢٤٣.تفسير البغوي ٤/٢٦٣.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٧٣ عن ابن إدريس عن أبيه ولم يذكر عطية، وابن أبي حاتم ٧/٢١٧٨ من طريق ابن إدريس عن أبيه عن عطية مختصرًا. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٤٣، وتفسير البغوي ٤/٢٦٣.أخرجه عبد الرزاق في تفسيره ٢/٣٢٦ بنحوه من طريق معمر، وابن جرير ١٣/٢٧٣.أخرجه ابن أبي حاتم ٧/٢١٧٨. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر.الجونة -بالضم-: التي يُعد فيها الطيب ويُحْرَز. النهاية (جون).تفسير الثعلبي ٥/٢٤٣.أخرجه ابن جرير ١٣/٢٧٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٧٤.تفسير الثوري ص١٤٥.تفسير الثعلبي ٥/٢٤٣، وتفسير البغوي ٤/٢٦٣.أخرجه ابن جرير ١٣/٢٧٦، وابن أبي حاتم ٧/٢١٧٩.أخرجه عبد الرزاق في تفسيره ٢/٣٢٦ من طريق معمر، وابن جرير ١٣/٢٧٦.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٧٧، وابن أبي حاتم ٧/٢١٨٠. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٧٧.تفسير مقاتل بن سليمان ٢/٣٤٦.أخرجه ابن جرير ١٣/٢٧٤، وابن أبي حاتم ٧/٢١٨٠.أخرجه عبد الرزاق (١٠٣٨٩). وعزاه السيوطي إليه، وفيه: عن شيبة.
12,78," <q>﴿قَالُوا۟ یَـٰۤأَیُّهَا ٱلۡعَزِیزُ إِنَّ لَهُۥۤ أَبࣰا شَیۡخࣰا كَبِیرࣰا فَخُذۡ أَحَدَنَا مَكَانَهُۥۤۖ إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٧٨﴾</q> - تفسير ٣٧٩١٤- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> أي: إخوةُ يوسف ليوسف: <q>﴿يا أيها العزيز﴾</q> وذلك أنّ أرض مصر صارت إليه، وهو خازن المَلِك، <q>﴿إنّ له﴾</q> يعني: لِبنيامين <q>﴿أبا شيخا كبيرا﴾</q> حزينًا على ابنٍ مفقود؛ <q>﴿فخذ أحدنا مكانه إنا نراك من المحسنين﴾</q> إلينا إن فعلت بنا ذلك{1}. (ز) ٣٧٩١٥- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ قالوا ليوسف: <q>﴿قالُوا يا أيُّها العَزِيزُ إنَّ لَهُ أبًا شَيْخًا كَبِيرًا فَخُذْ أحَدَنا مَكانَهُ إنّا نَراكَ مِنَ المُحْسِنِينَ﴾</q>: إنّا نرى ذلك منك إحسانًا إن فعلتَ{2}٣٤٢٧. (ز) ٣٤٢٧ ذكر ابنُ عطية (٥/١٢٨) في قوله: <q>﴿فخذ أحدنا مكانه﴾</q> احتمالين: أحدهما: «أن يكون مجازًا، وهم يعلمون أنّه لا يصح أخذُ حُرٍّ لِيُسْتَرَقَّ بدلَ مَن أحكمت السنة رقه، وإنما هذا كما تقول لمن تكره فعله: اقتلني ولا تفعل كذا وكذا. وأنت لا تريد أن يقتلك، ولكنك تبالغ في اسْتِنزاله، وعلى هذا يتجه قول يوسف: <q>﴿مَعاذَ اللَّهِ﴾</q>؛ لأنّه تَعَوُّذ مِن غير جائز». والآخر: «أن يكون قولهم: <q>﴿فَخُذْ أحَدَنا مَكانَهُ﴾</q> حقيقة، وبعيد عليهم -وهم أنبياء- أن يريدوا استرقاق حُرٍّ، فلم يبق إلا أن يريدوا بذلك طريق الحمالة، أي: خذ أحدنا حتى ينصرف إليك صاحبك». وكذا ذكر في قوله: <q>﴿إنا نراك من المحسنين﴾</q> احتمالين، فقال: «وقولهم: <q>﴿إنّا نَراكَ مِنَ المُحْسِنِينَ﴾</q> يحتمل أن يريدوا وصفَه بما رأوه من إحسانه في جميع أفعاله معهم ومع غيرهم. ويحتمل أن يريدوا: إنّا نرى لك إحسانًا علينا في هذه اليد إن أسديتها إلينا. وهذا تأويل ابن إسحاق». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٧٩، وابن أبي حاتم ٧/٢١٨٠.
