quran[10]{c,v,t}:
32,21," <q>﴿وَلَنُذِیقَنَّهُم مِّنَ ٱلۡعَذَابِ ٱلۡأَدۡنَىٰ دُونَ ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾</q> - تفسير ٦١٤٥٧- عن أبي إدريس الخولاني، قال: سألتُ عبادة بن الصامت عن قول الله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</q>. فقال: سألتُ رسولَ الله ﷺ عنها، فقال: «هي المصائب، والأسقام، والأنصاب، عذاب للمسرف في الدنيا، دون عذاب الآخرة». قلت: يا رسول الله، فما هي لنا؟ قال: «زكاة وطهور»{1}. (١١/٧٠٨) ٦١٤٥٨- عن أُبَيّ بن كعب -من طريق ابن أبي ليلى- في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: مصائب الدنيا، والروم، والبطشة، والدخان{2}. (١١/٧٠٧) ٦١٤٥٩- عن أُبَيّ بن كعب -من طريق مجاهد- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: يوم بدر{3}. (١١/٧٠٨) ٦١٤٦٠- عن عبد الله بن مسعود -من طريق مسروق- في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: يوم بدر{4}. (١١/٧٠٧) ٦١٤٦١- عن عبد الله بن مسعود -من طريق أبي الأحوص- في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: سِنُون أصابتهم{5}. (١١/٧٠٧) ٦١٤٦٢- عن عبد الله بن مسعود -من طريق أبي الأحوص- في قوله: <q>﴿العَذابِ الأَدْنى﴾</q>، قال: سنون أصابت قومًا قبلكم{6}. (ز) ٦١٤٦٣- عن الحسن بن علي -من طريق عوف، عمَّن حدَّثه– أنه قال: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: القتل بالسيف صَبْرًا{3}. (ز) ٦١٤٦٤- عن عبد الله بن عباس -من طريق شبيب، عن عكرمة- في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</q>، قال: الحدود{8}. (١١/٧٠٨) ٦١٤٦٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، يقول: مصائب الدنيا، وأسقامها، وبلاؤها مما يبتلي الله بها العباد حتى يتوبوا{9}. (ز) ٦١٤٦٦- عن عبد الله بن الحارث بن نوفل -من طريق عوف- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: القتل بالسيف، كل شيء وعد الله هذه الأمة مِن العذاب الأدنى إنما هو السيف{10}. (ز) ٦١٤٦٧- عن أبي العالية الرياحي -من طريق الربيع- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: المصائب في الدنيا{11}. (ز) ٦١٤٦٨- عن إبراهيم النخعي -من طريق جرير، عن منصور- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</q>، قال: أشياء يُصابون بها في الدنيا{12}. (١١/٧٠٨) ٦١٤٦٩- عن إبراهيم النخعي -من طريق سفيان، عن منصور- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</q>، قال: سنون أصابتهم{13}. (ز) ٦١٤٧٠- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: عذاب الدنيا، وعذاب القبر{14}. (١١/٧٠٩) ٦١٤٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: القتل والجوع لقريش في الدنيا{15}. (١١/٧٠٩) ٦١٤٧٢- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</q>، قال: المصيبات في دنياهم وأموالهم{11}. (ز) ٦١٤٧٣- عن أبي عبيدة [بن عبد الله بن مسعود]، في قوله: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: عذاب القبر{17}. (١١/٧٠٩) ٦١٤٧٤- عن الحسن البصري -من طريق الحسن بن دينار- قال: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q> العذاب الأدنى بالسيف يوم بدر{18}. (ز) ٦١٤٧٥- عن الحسن البصري -من طريق قتادة- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>: أي: مصيبات الدنيا{19}. (ز) ٦١٤٧٦- قال الحسن -من طريق معمر- <q>﴿العَذابِ الأَدْنى﴾</q>: عقوبات الدنيا{20}. (ز) ٦١٤٧٧- قال قتادة بن دعامة= (ز) ٦١٤٧٨- وإسماعيل السُّدِّيّ: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q> هو القتل بالسيف يوم بدر{21}. (ز) ٦١٤٧٩- قال إسماعيل السُّدِّيّ: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، يعني بالعذاب الأدنى: العذاب الأقرب، وهو الجوع في الدنيا{22}. (ز) ٦١٤٨٠- قال مقاتل بن سليمان: <q>﴿ولَنُذِيقَنَّهُمْ﴾</q> يعني: كفار مكة <q>﴿مِنَ العَذابِ الأَدْنى﴾</q> يعني: الجوع الذي أصابهم في السنين السبع بمكة؛ حين أكلوا العظام، والموتى، والجِيَف، والكلاب؛ عقوبةً بتكذيبهم النبي ﷺ{23}. (ز) ٦١٤٨١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q>، قال: العذاب الأدنى: عذاب الدنيا{24}٥١٧٢. (ز) ٥١٧٢ اختلف في معنى العذاب الأدنى في قوله تعالى: <q>﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</q> في هذه الآية على خمسة أقوال: الأول: أنه مصائب الدنيا في الأنفس والأموال. الثاني: أنه الحدود. الثالث: أنه القتل بالسيف؛ كيوم بدر. الرابع: أنه سنون أصابتهم. الخامس: أنه عذاب القبر. السادس: أنه عذاب الدنيا. ووجَّه ابنُ عطية (٧/٧٩) القول الثالث بقوله: «فيكون -على هذا التأويل- الرّاجعُ غير الذي يذوق، بل الذي يبقى بعده». ووجَّه القولَ الثاني بقوله: «ويتَّجه -على هذا التأويل- أن يكون في فسقة المؤمنين». ووجَّه ابنُ القيم (٢/٣٢٣) القول الخامس بقوله: «وقد احتج بهذه الآية جماعةٌ -منهم: عبد الله بن عباس- على عذاب القبر، وفي الاحتجاج بها شيء؛ لأن هذا عذاب في الدنيا يستدعي به رجوعهم عن الكفر، ولم يكن هذا مما يخفى على حبر الأمة وترجمان القرآن، لكن مِن فقهه في القرآن ودقة فهمه فيه فهم منها عذاب القبر؛ فإنه سبحانه أخبر أن له فيه عذابين أدنى وأكبر، فأخبر أنه يذيقهم بعض الأدنى ليرجعوا، فدلَّ على أنه بقي لهم مِن الأدنى بقية يعذبون بها بعد عذاب الدنيا، ولهذا قال: <q>﴿مِنَ العَذابِ الأَدْنى﴾</q>، ولم يقل: ولنذيقنَّهم العذاب الأدنى. فتأمَّله». ورجَّح ابنُ جرير (١٨/٦٣٢) مستندًا إلى دلالة العموم شمول معنى الآية لكل عذاب وقع للكفار في الدنيا، فقال: «وأولى الأقوال في ذلك أن يُقال: إنّ الله وعد هؤلاء الفسقة المكذبين بوعيده في الدنيا العذاب الأدنى، أن يذيقَهموه دون العذاب الأكبر، والعذاب: هو ما كان في الدنيا من بلاءٍ أصابهم؛ إما شدةٌ من مجاعة، أو قَتْلٌ، أو مصائب يصابون بها، فكلُّ ذلك من العذاب الأدنى، ولم يَخْصُصْ الله -تعالى ذِكْرُه- إذ وعدهم ذلك أن يعذِّبهم بنوعٍ من ذلك دون نوعٍ، وقد عذَّبهم بكلِّ ذلك في الدنيا؛ بالقتل، والجوع، والشدائد، والمصائب في الأموال، فأوفى لهم بما وعدهم». <q>﴿دُونَ ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾</q> - تفسير ٦١٤٨٢- عن عبد الله بن مسعود -من طريق مسروق- في قوله: <q>﴿دُونَ العَذابِ الأَكْبَرِ﴾</q>، قال: يوم القيامة{25}. (١١/٧٠٧) ٦١٤٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: العذاب الأكبر يوم القيامة في الآخرة{26}. (١١/٧٠٩) ٦١٤٨٤- عن الحسن البصري -من طريق قتادة- <q>﴿دُونَ العَذابِ الأَكْبَرِ﴾</q>: يوم القيامة{24}. (ز) ٦١٤٨٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿دُونَ العَذابِ الأَكْبَرِ﴾</q>: يوم القيامة{24}. (ز) ٦١٤٨٦- قال مقاتل بن سليمان: <q>﴿دُونَ العَذابِ الأَكْبَرِ﴾</q>، يعني: القتل ببدر، وهو أعظم من العذاب الذي أصابهم من الجوع{23}. (ز) ٦١٤٨٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿دُونَ العَذابِ الأَكْبَرِ﴾</q>، قال: العذاب الأكبر: عذاب الآخرة{24}. (ز) ٦١٤٨٨- قال يحيى بن سلّام: <q>﴿دُونَ العَذابِ الأَكْبَرِ﴾</q>، يعني: النار في الآخرة، كقوله في سورة النجم: <q>﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</q> [النجم:٩]، يعني: أقرب{31}. (ز) <q>﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٢١﴾</q> - تفسير ٦١٤٨٩- عن عبد الله بن مسعود -من طريق مسروق- في قوله: <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: لعلَّ مَن بقي منهم أن يتوب فيرجع{25}. (١١/٧٠٧) ٦١٤٩٠- عن عبد الله بن مسعود -من طريق مسروق- <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: يتوبون{33}. (١١/٧٠٧) ٦١٤٩١- عن عبد الله بن عباس، <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: يتوبون{34}. (١١/٧٠٨) ٦١٤٩٢- عن أبي العالية الرياحي -من طريق الربيع- <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: يتوبون{35}. (ز) ٦١٤٩٣- عن إبراهيم النخعي -من طريق منصور- <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: يتوبون{36}. (١١/٧٠٨) ٦١٤٩٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: يتوبون{35}. (ز) ٦١٤٩٥- عن الحسن البصري -من طريق قتادة-، مثله{24}. (ز) ٦١٤٩٦- قال مقاتل بن سليمان: <q>﴿لَعَلَّهُمْ﴾</q> يعني: لكي <q>﴿يَرْجِعُونَ﴾</q> مِن الكفر إلى الإيمان{23}. (ز) ٦١٤٩٧- قال يحيى بن سلّام: <q>﴿لَعَلَّهُمْ﴾</q> لعلَّ مَن يبقى منهم <q>﴿يَرْجِعُونَ﴾</q> عن الشرك إلى الإيمان، فعذّبهم بالسيف يوم بدر، ومن بعدهم على مَن شاء الإيمان{31}٥١٧٣. (ز) ٥١٧٣ لم يذكر ابنُ جرير (١٨/٦٣٤) في معنى: <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q> سوى قول ابن مسعود، وأبي العالية، وقتادة. ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه مسلم (٢٧٩٩)، وعبد الله بن أحمد ٣٥/١٠٤ (٢١١٧٣)، وابن جرير ١٨/٦٢٧ بلفظ: مصيبات الدنيا، والحاكم ٤/٤٢٧-٤٢٨، والبيهقي في شعب الإيمان (٩٨٢١). وعزاه السيوطي إلى ابن أبي حاتم، وأبي عوانة في صحيحه، وابن المنذر.أخرجه ابن جرير ١٨/٦٣٠.أخرجه سفيان الثوري في تفسيره (٢٤٠)، ويحيى بن سلام ٢/٦٩٢، وابن جرير ١٨/٦٢٩، والطبراني (٩٠٣٨)، والحاكم ٢/٤١٤. وعزاه السيوطي إلى الفريابي، وابن منيع، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في الدلائل.تفسير مجاهد (٥٤٥)، وأخرجه النسائي (١١٣٩٥)، والحاكم ٤/٢٥٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن مردويه، وابن المنذر.أخرجه آدم بن أبي إياس -تفسير مجاهد (٥٤٥)-.أخرجه ابن جرير ١٨/٦٣٠.أخرجه ابن جرير ١٨/٦٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٦٢٧، وأخرجه أيضًا من طريق عطية العوفي قريبًا منه. وأخرج إسحاق البستي ص١٠٤ نحوه مختصرًا من طريق يزيد عن عكرمة.أخرجه ابن جرير ١٨/٦٣٠. وفي تفسير الثعلبي ٧/٣٣٣ بلفظ: القتل بالسيف يوم بدر.أخرجه ابن جرير ١٨/٦٢٨.أخرجه ابن أبي شيبة ١٣/٥٥٢، وابن جرير ١٨/٦٢٩.أخرجه سفيان الثوري في تفسيره (٢٤٠) عن منصور عن إبراهيم بلفظ: المصائب في الأموال والأولاد، وابن جرير ١٨/٦٣١.أخرجه يحيى بن سلام ٢/٦٩٢-٦٩٣ بنحوه، وابن جرير ١٨/٦٣٠. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.تفسير مجاهد (٥٤٥)، وأخرجه ابن جرير ١٨/٦٣١. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٨/٦٢٨.أخرجه هناد (٣٤٥).أخرجه يحيى بن سلام ٢/٦٩٢.أخرجه ابن جرير ١٨/٦٢٩.أخرجه عبد الرزاق ٢/١١٠.تفسير البغوي ٦/٣٠٨.علقه يحيى بن سلام ٢/٦٩٣.تفسير مقاتل بن سليمان ٣/٤٥٢.أخرجه ابن جرير ١٨/٦٣٣.أخرجه يحيى بن سلام ٢/٦٩٢، وابن جرير ١٨/٦٢٩، والطبراني (٩٠٣٨)، والحاكم ٢/٤١٤. وعزاه السيوطي إلى الفريابي، وابن منيع، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في الدلائل.تفسير مجاهد (٥٤٥)، وأخرجه ابن جرير ١٨/٦٣٣، كما أخرجه من طريق أبي يحيى. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٨/٦٣٣.أخرجه ابن جرير ١٨/٦٣٣.تفسير مقاتل بن سليمان ٣/٤٥٢.أخرجه ابن جرير ١٨/٦٣٣.تفسير يحيى بن سلام ٢/٦٩٣.أخرجه يحيى بن سلام ٢/٦٩٢، وابن جرير ١٨/٦٢٩، والطبراني (٩٠٣٨)، والحاكم ٢/٤١٤. وعزاه السيوطي إلى الفريابي، وابن منيع، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في الدلائل.أخرجه النسائي (١١٣٩٥)، والحاكم ٤/٢٥٣، وابن جرير ١٨/٦٣٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن مردويه.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٦٣٤.أخرجه ابن أبي شيبة ١٣/٥٥٢-٥٥٤. وعزاه السيوطي إلى ابن جرير.أخرجه ابن جرير ١٨/٦٣٤.أخرجه ابن جرير ١٨/٦٣٣.تفسير مقاتل بن سليمان ٣/٤٥٢.تفسير يحيى بن سلام ٢/٦٩٣.
32,22," <q>﴿وَمَنۡ أَظۡلَمُ مِمَّن ذُكِّرَ بِـَٔایَـٰتِ رَبِّهِۦ ثُمَّ أَعۡرَضَ عَنۡهَاۤۚ إِنَّا مِنَ ٱلۡمُجۡرِمِینَ مُنتَقِمُونَ ۝٢٢﴾</q> - نزول الآية ٦١٤٩٨- قال مقاتل بن سليمان: <q>﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</q> يعني: كفار مكة، نزلت في المُطْعِمين{1} والمستهزئين من قريش، انتقم الله ﷿ منهم بالقتل ببدر، وضربت الملائكة الوجوه والأدبار، وتعجيل أرواحهم إلى النار{2}. (ز) <q>﴿وَمَنۡ أَظۡلَمُ مِمَّن ذُكِّرَ بِـَٔایَـٰتِ رَبِّهِۦ ثُمَّ أَعۡرَضَ عَنۡهَاۤۚ إِنَّا مِنَ ٱلۡمُجۡرِمِینَ مُنتَقِمُونَ ۝٢٢﴾</q> - تفسير الآية ٦١٤٩٩- عن معاذ بن جبل، قال: سمعتُ رسول الله ﷺ يقول: «ثلاثٌ مَن فعلهنَّ فقد أجرم: مَن عقد لواءً في غير حق، أو عقَّ والديه، أو مشى مع ظالم لينصره، فقد أجرم، يقول الله: <q>﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</q>»{3}. (١١/٧٠٩) ٦١٥٠٠- قال مقاتل بن سليمان: <q>﴿ومَن أظْلَمُ﴾</q> يقول: فلا أحد أظلم <q>﴿مِمَّنْ ذُكِّرَ بِآياتِ رَبِّهِ﴾</q> يقول: مِمَّن وُعِظ بآيات القرآن <q>﴿ثُمَّ أعْرَضَ عَنْها﴾</q> عن الإيمان، <q>﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</q> يعني: كفار مكة{2}. (ز) ٦١٥٠١- قال يحيى بن سلّام: <q>﴿ومَن أظْلَمُ مِمَّنْ ذُكِّرَ بِآياتِ رَبِّهِ ثُمَّ أعْرَضَ عَنْها﴾</q> لم يؤمن بها، <q>﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</q> والمجرمين -ها هنا-: المشركين{5}. (ز) ٦١٥٠٢- عن يزيد{6} بن رُفَيْع -من طريق مروان بن سُفَيْح- قال: إنّ قول الله في القرآن: <q>﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</q> هم أصحاب القدَر. ثم قرأ: <q>﴿إنَّ المُجْرِمِينَ فِي ضَلالٍ وسُعُرٍ﴾</q> إلى قوله: <q>﴿إنّا كُلَّ شَيْءٍ خَلَقْناهُ بِقَدَرٍ﴾</q> [القمر: ٤٧-٤٩]{7}٥١٧٤. (ز) ٥١٧٤ نقل ابنُ عطية (٧/٨٠) عن ابن جرير أثر يزيد بن رفيع أن المقصود بقوله تعالى: <q>﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</q> أهل القدر، ووجَّهه بقوله: «يريد: القائلين بأن أفعال العبد من قبله». ثم انتقد استدلال يزيد بقوله تعالى: <q>﴿إنَّ المُجْرِمِينَ فِي ضَلالٍ وسُعُرٍ﴾</q> إلى قوله: <q>﴿إنّا كُلَّ شَيْءٍ خَلَقْناهُ بِقَدَرٍ﴾</q> [القمر:٤٧-٤٩] على المعنى الذي ذهب إليه، فقال: «وفي هذا المنزع من البُعْد ما لا خفاء به». ",footnotes:1:يعني: المطعمين يوم بدر من صناديد قريش الذين تعهدوا بإطعام جيش المشركين في مسيرهم، وقد نص عليهم مقاتل عند تفسير قوله تعالى: <q>﴿ويَجْعَلَ الخَبِيثَ بَعْضَهُ عَلى بَعْضٍ فَيَرْكُمَهُ جَمِيعًا فَيَجْعَلَهُ فِي جَهَنَّمَ﴾</q> [الأنفال:٣٧]، وقوله تعالى: <q>﴿الَّذِينَ كَفَرُوا وصَدُّوا عَنْ سَبِيلِ اللَّهِ أضَلَّ أعْمالَهُمْ﴾</q> [محمد:١].تفسير مقاتل بن سليمان ٣/٤٥٢.أخرجه أحمد بن منيع -كما في إتحاف الخيرة ٥/١٦٢ (٤٤٤٤)-، والطبراني في الكبير ٢٠/٦١ (١١٢)، وابن جرير ١٨/٦٣٥، والثعلبي ٧/٣٣٣ من طريق إسماعيل بن عياش، عن عبد العزيز بن عبيد الله، عن عبادة بن نسي، عن جنادة بن أبي أمية، عن معاذ بن جبل به. قال ابن كثير في تفسيره ٦/٣٧١: «وهذا حديث غريب جدًّا». وقال الهيثمي في المجمع ٧/٩٠ (١١٢٦٩): «فيه عبد العزيز بن عبيد الله بن حمزة، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٥/١٦٢ (٤٤٤٤): «هذا إسناد ضعيف؛ لضعف عبد العزيز». وقال السيوطي: «سند ضعيف». وقال الألباني في الضعيفة ٤/٤٢١ (١٩٥١): «ضعيف».تفسير مقاتل بن سليمان ٣/٤٥٢.تفسير يحيى بن سلام ٢/٦٩٣.كذا عند ابن جرير، والذي في التاريخ الكبير للبخاري ٧/٣٧٢ (ترجمة مروان بن سفيح): زيد.أخرجه ابن جرير ١٨/٦٣٥.
32,23," <q>﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ فَلَا تَكُن فِی مِرۡیَةࣲ مِّن لِّقَاۤىِٕهِۦۖ﴾</q> - تفسير ٦١٥٠٣- عن ابن عباس، عن النبي ﷺ، <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> قال: «من لقاء موسى ربه». <q>﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</q>، قال: «جعل موسى هدى لبني إسرائيل»{1}. (١١/٧١٠) ٦١٥٠٤- عن عبد الله بن عباس، قال: قال النبي ﷺ: «رأيت ليلة أسري بي موسى بن عمران رجلًا طوالًا جَعْدًا{2}، كأنه من رجال شَنُوءَة{3}، ورأيت عيسى بن مريم مَرْبوعَ الخلق{4}، إلى الحمرة والبياض، سبط{5} الرأس، ورأيت مالكًا خازن جهنم، والدجال». في آياتٍ أراهنَّ الله إيّاه. قال: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> فكان قتادة يُفَسِّرها أنّ النبي ﷺ قد لقي موسى، <q>﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</q> قال: جعل الله موسى هُدًى لبني إسرائيل{6}٥١٧٥. (١١/٧١٠) ٥١٧٥ لم يذكر ابنُ جرير (١٨/٦٣٦) في معنى: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> سوى حديث ابن عباس ﵄. ٦١٥٠٥- قال عبد الله بن عباس: <q>﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> فلا تكن في شكٍّ مِن لقاء موسى ليلة المعراج{7}. (ز) ٦١٥٠٦- عن أبي العالية الرياحي، في قوله: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q>، قال: من لقاء موسى. قيل: أوَلقي موسى؟ قال: نعم، ألا ترى إلى قوله: <q>﴿واسْأَلْ مَن أرْسَلْنا مِن قَبْلِكَ مِن رُسُلِنا﴾</q>؟! [الزخرف:٤٥]{8}. (١١/٧١٠) ٦١٥٠٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q>، قال: مِن أن تلقى موسى{9}. (١١/٧١٠) ٦١٥٠٨- عن الحسن البصري: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> مِن أن تلقى مِن قومك مِن الأذى ما لقي موسى مِن قومه مِن الأذى{10}. (ز) ٦١٥٠٩- قال إسماعيل السُّدِّيّ: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> مِن تَلَقِّيه كتاب الله تعالى بالرِّضا والقَبول{11}. (ز) ٦١٥١٠- قال محمد بن السائب الكلبي: <q>﴿مِن لِقائِهِ﴾</q>، يعني: ليلة أسري به، فلقيه النبي ﷺ في السماء السادسة ليلة أُسري به{10}. (ز) ٦١٥١١- قال مقاتل بن سليمان: <q>﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ﴾</q> يقول: أعطينا موسى ﷺ التوراة، <q>﴿فَلا تَكُنْ﴾</q> يا محمد <q>﴿فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> يقول: لا تكن في شكٍّ مِن لقاء موسى ﵇ التوراة، فإن الله ﷿ ألقى الكتاب عليه -يعني: التوراة- حقًّا{13}٥١٧٦. (ز) ٥١٧٦ اختلف في معنى قوله تعالى: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> على أقوال: الأول: فلا تكن -يا محمد- في شكٍّ من لقاء موسى ﵇ ربَّه تعالى. الثاني: فلا تكن في شك من لقاء موسى ﵇ ليلة الإسراء. الثالث: فلا تكن في شك من لقاء الأذى كما لقي موسى ﵇ الأذى. الرابع: فلا تكن في شكٍّ من تلقِّي موسى ﵇ الكتاب. ووجَّه ابنُ عطية (٧/٨١) القول الثالث بقوله: «كأنه قال: ولقد آتينا موسى ﵇ هذا العِبْءَ الذي أنت بسبيله، فلا تَمْتَر أنّك تلقى ما لَقِيَ هو من المحنة بالناس، وكأن الآية تسليةٌ لمحمد ﷺ. ونقل عن فرقة: أن الضمير في <q>﴿لقائه﴾</q> عائد على الكتاب، ثم وجَّهه بقوله:»أي: أنه لقي موسى ﵇ حين لقيه موسى ﵇، والمصدر في هذا التأويل يصح أن يكون مضافًا إلى الفاعل، بمعنى: لقي الكتاب موسى، ويصح أن يكون مضافًا إلى المفعول، بمعنى: لقي الكتابَ -بالنصب- موسى ﵇«. ثم نقل عن فرقتين قولَيْن آخرَيْن، الأول: أن المعنى: فلا تك في شك من لقائه في الآخرة. وانتقده قائلًا:»وهذا قولٌ ضعيف«. والثاني: أن الضمير عائد على ملك الموت الذي تقدم ذِكْره، وقوله: <q>﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</q> اعتراضٌ بيْن الكلامَين، وانتقده قائلًا:»وهذا أيضًا ضعيف". ٦١٥١٢- قال يحيى بن سلّام: <q>﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ﴾</q> يعني: التوراة، <q>﴿فَلا تَكُنْ﴾</q> يا محمد <q>﴿فِي مِرْيَةٍ﴾</q> في شك{14}. (ز) <q>﴿وَجَعَلۡنَـٰهُ هُدࣰى لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٢٣﴾</q> - تفسير ٦١٥١٣- عن الحسن البصري: <q>﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</q> وجعلنا موسى هدى لبني إسرائيل{15}. (ز) ٦١٥١٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</q>، قال: جعل الله موسى هدًى لبني إسرائيل{16}٥١٧٧. (ز) ٥١٧٧ لم يذكر ابنُ جرير (١٨/٦٣٧) في معنى: <q>﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</q> سوى قول قتادة. ٦١٥١٥- قال إسماعيل السُّدِّيّ: <q>﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</q>، يعني: التوراة{15}. (ز) ٦١٥١٦- قال مقاتل بن سليمان: <q>﴿وجَعَلْناهُ هُدًى﴾</q> يعني: التوراة هدًى <q>﴿لِبَنِي إسْرائِيلَ﴾</q> مِن الضلالة{13}. (ز) <q>﴿وَجَعَلۡنَـٰهُ هُدࣰى لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٢٣﴾</q> - آثار متعلقة بالآية ٦١٥١٧- عن أنس، قال: قال رسول الله ﷺ: «لَمّا أُسري بي إلى السماء رأيتُ موسى يُصَلِّي في قبره»{19}. (ز) ",footnotes:1:أخرجه الطبراني في الكبير ١٢/١٦٠ (١٢٧٥٨)، وابن عساكر في تاريخه ٦١/١٦٨. قال الهيثمي في المجمع ٧/٩٠ (١١٢٧٠): «رجاله رجال الصحيح». وقال السيوطي: «سند صحيح».الجعد في صفات الرجال يكون مدحًا ويكون ذمًا، فإذا كان مدحًا فله معنيان أحدهما أن يكون معصوب الخلق شديد الأسر، والثاني أن يكون شعره غير سبط؛ لأن السبوطة في شعور العجم، وأما الجعد الذموم فله معنيان أحدهما القصير، والآخر البخيل. صحيح مسلم بشرح النووي ١٠/١٢٨-١٢٩.شنوءة: قبيلة من قبائل اليمن. اللسان (شنأ).مَرْبوع: هو المعتدل الخلقة، لا بالطويل ولا بالقصير. اللسان (ربع).السبط: ممتد الأعضاء تام الخلق، والمنبسط المسترسل من الشعر. النهاية (سبط).أخرجه البخاري ٤/١١٦ (٣٢٣٩)، ومسلم ١/١٥١ (١٦٥)، وابن جرير ١٨/٦٣٦، والبغوي في تفسيره ٦/٣٠٨-٣٠٩.تفسير الثعلبي ٧/٣٣٤، وتفسير البغوي ٦/٣٠٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد (٥٤٥). وعلَّقه يحيى بن سلام ٢/٦٩٣ بلفظ: من لقاء موسى وكُتُبِهِ. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٦٩٣.تفسير الثعلبي ٧/٣٣٤، وتفسير البغوي ٦/٣٠٩.علقه يحيى بن سلام ٢/٦٩٣.تفسير مقاتل بن سليمان ٣/٤٥٢.تفسير يحيى بن سلام ٢/٦٩٣.علقه يحيى بن سلام ٢/٦٩٤.أخرجه ابن جرير ١٨/٦٣٩.علقه يحيى بن سلام ٢/٦٩٤.تفسير مقاتل بن سليمان ٣/٤٥٢.أخرجه مسلم ٤/١٨٤٥ (٢٣٧٥)، والبغوي في تفسيره ٦/٣٠٩ واللفظ له.
32,24," <q>﴿وَجَعَلۡنَا مِنۡهُمۡ أَىِٕمَّةࣰ یَهۡدُونَ بِأَمۡرِنَا﴾</q> - تفسير ٦١٥١٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وجَعَلْنا مِنهُمْ أئِمَّةً﴾</q>، قال: رؤساء في الخير سوى الأنبياء{1}. (١١/٧١١) ٦١٥١٩- قال قتادة بن دعامة: <q>﴿وجَعَلْنا مِنهُمْ أئِمَّةً﴾</q> أتباع الأنبياء{2}. (ز) ٦١٥٢٠- قال مقاتل بن سليمان: <q>﴿وجَعَلْنا مِنهُمْ﴾</q> يعني: مِن بني إسرائيل <q>﴿أئِمَّةً﴾</q> يعني: قادة إلى الخير <q>﴿يَهْدُونَ بِأَمْرِنا﴾</q> يعني: يدعون الناس إلى أمر الله ﷿{3}. (ز) ٦١٥٢١- قال يحيى بن سلّام: <q>﴿وجَعَلْنا مِنهُمْ أئِمَّةً﴾</q> أنبياء يُهتدى بهم <q>﴿يَهْدُونَ بِأَمْرِنا﴾</q> يعني: يدعون بأمرنا{4}. (ز) <q>﴿لَمَّا صَبَرُوا۟ۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یُوقِنُونَ ۝٢٤﴾</q> - قراءات ٦١٥٢٢- عن الأعمش: قرأ ابن مسعود: (بِما صَبَرُواْ){5}. (ز) <q>﴿لَمَّا صَبَرُوا۟ۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یُوقِنُونَ ۝٢٤﴾</q> - تفسير الآية ٦١٥٢٣- عن قتادة بن دعامة، <q>﴿يَهْدُونَ بِأَمْرِنا لَمّا صَبَرُوا﴾</q>، قال: على ترك الدنيا{6}. (١١/٧١١) ٦١٥٢٤- عن إسماعيل السُّدِّيّ: <q>﴿لَمّا صَبَرُوا﴾</q>، يعني: بما صبروا{7}. (ز) ٦١٥٢٥- قال مقاتل بن سليمان: <q>﴿لَمّا صَبَرُوا﴾</q> يعني: لما صبروا على البلاء حين كُلّفوا بمصر ما لم يطيقوا من العمل، فعل ذلك بهم باتِّباعهم موسى على دين الله ﷿، <q>﴿وكانُوا بِآياتِنا﴾</q> يعني: بالآيات التسع <q>﴿يُوقِنُونَ﴾</q> بأنّها من الله ﷿{3}. (ز) ٦١٥٢٦- عن الحسن بن صالح -من طريق يحيى بن آدم- في قوله تعالى: <q>﴿أئمة يهدون بأمرنا لما صبروا﴾</q>، قال: صبروا على الدنيا{9}. (ز) ٦١٥٢٧- عن وكيع [بن الجراح] -من طريق ابن وكيع- قال: سمعنا في: <q>﴿وجَعَلْنا مِنهُمْ أئِمَّةً يَهْدُونَ بِأَمْرِنا لَمّا صَبَرُوا﴾</q>، قال: عن الدنيا{10}. (ز) <q>﴿لَمَّا صَبَرُوا۟ۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یُوقِنُونَ ۝٢٤﴾</q> - آثار متعلقة بالآية ٦١٥٢٨- عن مالك أنّه تلا: <q>﴿وجَعَلْنا مِنهُمْ أئِمَّةً يَهْدُونَ بِأَمْرِنا لَمّا صَبَرُوا﴾</q>، فقال: حدثني الزهري، أنّ عطاء بن يزيد حدثه، عن أبي هريرة، أنه سمع النبي ﷺ يقول: «ما رُزِق عبدٌ خيرًا له ولا أوسع مِن الصبر»{11}. (١١/٧١١) ",footnotes:1:أخرجه ابن جرير ١٨/٦٣٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٦/٣٠٩.تفسير مقاتل بن سليمان ٣/٤٥٢-٤٥٣.تفسير يحيى بن سلام ٢/٦٩٤.أخرجه ابن أبي داود في المصاحف ١/٣٢٩. وعلَّقه ابن جرير ١٨/٦٣٨. وهي قراءة شاذة. انظر: معاني القرآن للفراء ٢/٣٣١، والجامع لأحكام القرآن ١٧/٤٣.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٦٩٤.تفسير مقاتل بن سليمان ٣/٤٥٢-٤٥٣.أخرجه ابن الجعد في مسنده ٢/٨٠٣ (٢١٤٨).أخرجه ابن جرير ١٨/٦٣٨.أخرجه الحاكم ٢/٤٤٩ (٣٥٥٢) من طريق عبد الرحمن بن حمدان الجلاب، عن إسحاق بن أحمد بن مهران الخراز، عن إسحاق بن سليمان الرازي، عن مالك بن أنس، عن الزهري، عن عطاء بن يزيد، عن أبي هريرة به. قال الحاكم: «قد اتفق الشيخان على إخراج هذه اللفظة في آخر حديثه بهذا الإسناد: أن ناسًا من الأنصار سألوا رسول الله ﷺ. الحديث بطوله، وفي آخره هذه اللفظة، ولم يخرجاه بهذه السياقة التي عند إسحاق بن سليمان». وقال الذهبي في التلخيص: «على شرط البخاري ومسلم».
32,25," <q>﴿إِنَّ رَبَّكَ هُوَ یَفۡصِلُ بَیۡنَهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ فِیمَا كَانُوا۟ فِیهِ یَخۡتَلِفُونَ ۝٢٥﴾</q> - تفسير ٦١٥٢٩- قال مقاتل بن سليمان: <q>﴿إنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ﴾</q> يعني: يقضي بينهم، يعني: بني إسرائيل <q>﴿يَوْمَ القِيامَةِ فِيما كانُوا فِيهِ﴾</q> مِن الدين <q>﴿يَخْتَلِفُونَ﴾</q>{1}٥١٧٨. (ز) ٥١٧٨ ذكر ابنُ عطية (٧/٨١) أنّ قوله تعالى: <q>﴿إنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ القِيامَةِ﴾</q> حُكْمٌ يعمُّ جميع الخَلْق. ونقل عن بعض المتأوِّلين أنهم ذهبوا إلى تخصيص الضمير، ثم انتقد ذلك بقوله: «وذلك ضعيف». ٦١٥٣٠- قال يحيى بن سلّام: <q>﴿إنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ القِيامَةِ﴾</q> يقضي بينهم يوم القيامة <q>﴿فِيما كانُوا فِيهِ يَخْتَلِفُونَ﴾</q> يفصل بين المؤمنين والمشركين فيما اختلفوا فيه مِن الإيمان والكفر، فيُدخل المؤمنين الجنة، ويُدخِل المشركين النار{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٥٣.تفسير يحيى بن سلام ٢/٦٩٤.
32,26," <q>﴿أَوَلَمۡ یَهۡدِ لَهُمۡ كَمۡ أَهۡلَكۡنَا مِن قَبۡلِهِم مِّنَ ٱلۡقُرُونِ یَمۡشُونَ فِی مَسَـٰكِنِهِمۡۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتٍۚ أَفَلَا یَسۡمَعُونَ ۝٢٦﴾</q> - تفسير ٦١٥٣١- عن عبد الله بن عباس -من طريق علي- <q>﴿أوَلَمْ يَهْدِ لَهُمْ﴾</q>، يقول: أوَلَم يُبَيِّن لهم{1}. (ز) ٦١٥٣٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أوَلَمْ يَهْدِ لَهُمْ كَمْ أهْلَكْنا مِن قَبْلِهِمْ مِنَ القُرُونِ﴾</q>: عاد وثمود، وأنهم إليهم لا يرجعون{2}. (ز) ٦١٥٣٣- قال إسماعيل السُّدِّيّ: <q>﴿أوَلَمْ يَهْدِ لَهُمْ﴾</q> أي: أوَلَم نُبَيِّن لهم <q>﴿يَمْشُونَ فِي مَساكِنِهِمْ﴾</q> يقول: قد مرَّ أهل مكة على قُراهم{3}. (ز) ٦١٥٣٤- قال مقاتل بن سليمان: <q>﴿أوَلَمْ يَهْدِ لَهُمْ﴾</q> يعني: يبين لهم <q>﴿كَمْ أهْلَكْنا﴾</q> بالعذاب <q>﴿مِن قَبْلِهِمْ مِنَ القُرُونِ﴾</q> يعني: الأمم الخالية <q>﴿يَمْشُونَ فِي مَساكِنِهِمْ﴾</q> يقول: يمُرُّون على قراهم، يعني: قوم لوط وصالح وهود، فيرون هلاكهم، <q>﴿إنَّ فِي ذَلِكَ لَآياتٍ﴾</q> يعني: لعبرة، <q>﴿أفَلا يَسْمَعُونَ﴾</q>{4}. (ز) ٦١٥٣٥- قال يحيى بن سلّام: <q>﴿أوَلَمْ يَهْدِ لَهُمْ﴾</q> أي: أوَلَم يُبَيِّن الله لهم <q>﴿كَمْ أهْلَكْنا مِن قَبْلِهِمْ مِنَ القُرُونِ﴾</q> يعني: ما قصَّ مِمّا أهلك به الأمم السالفة حين كذبوا رسلهم <q>﴿يَمْشُونَ فِي مَساكِنِهِمْ﴾</q> يعني: يمرون فيها، كقوله: <q>﴿وإنَّكُمْ لَتَمُرُّونَ عَلَيْهِمْ مُصْبِحِينَ﴾</q> [الصافات:١٣٧] نهارًا وليلًا، يعني: في مساكنهم التي كانوا فيها، منها ما يُرى ومنها ما لا يُرى، كقوله: <q>﴿مِنها قائِمٌ﴾</q> تراه <q>﴿وحَصِيدٌ﴾</q> [هود:١٠٠] لا تراه، <q>﴿إنَّ فِي ذَلِكَ لَآياتٍ﴾</q> أي: للمؤمنين، <q>﴿أفَلا يَسْمَعُونَ﴾</q> يعني: المشركين{5}٥١٧٩. (ز) ٥١٧٩ ذكر ابنُ عطية (٧/٨٢) في معنى: <q>﴿يَمْشُون﴾</q> احتمالين: الأول: «أن يكون للمخاطبين بالبينة المحتج عليهم». والثاني: «أن يكون للمُهلَكين». ووجَّهه بقوله: «فـ<q>﴿يَمْشُونَ﴾</q> في موضع الحال، أي: أُهلِكوا وهم ماشون في مساكنهم». ",footnotes:1:أخرجه ابن جرير ١٨/٦٣٩.أخرجه ابن جرير ١٨/٦٤٠.علقه يحيى بن سلام ٢/٦٩٥.تفسير مقاتل بن سليمان ٣/٤٥٣.تفسير يحيى بن سلام ٢/٦٩٥.
32,27," <q>﴿أَوَلَمۡ یَرَوۡا۟ أَنَّا نَسُوقُ ٱلۡمَاۤءَ إِلَى ٱلۡأَرۡضِ ٱلۡجُرُزِ فَنُخۡرِجُ بِهِۦ زَرۡعࣰا تَأۡكُلُ مِنۡهُ أَنۡعَـٰمُهُمۡ وَأَنفُسُهُمۡۚ أَفَلَا یُبۡصِرُونَ ۝٢٧﴾</q> - تفسير ٦١٥٣٦- عن عبد الله بن عباس -من طريق ابن أبي نجيح، عن رجل- في قوله: <q>﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</q>، قال: الجُرُز: التي لا تمطر إلا مطرًا لا يغني عنها شيئًا، إلا ما يأتيها من السيول{1}. (١١/٧١١) ٦١٥٣٧- عن عبد الله بن عباس -من طريق عمرو بن دينار- في قوله: <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q>، قال: أرض باليمن{2}. (١١/٧١١) ٦١٥٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q>، قال: هي التي لا تنبت، هي أبْيَن{3} ونحوها من الأرض{4}٥١٨٠. (١١/٧١١) ٥١٨٠ بيَّن ابنُ عطية (٧/٨٢-٨٣) بأن معنى: <q>﴿الجُرُز﴾</q>: الأرض العاطشة التي قد أكلت نباتها مِن العطش والقيظ. ثم انتقد قول من قال: بأنها الأرض التي لا تُنبِت قائلًا: «ومَن عبَّر عنها بأنها الأرض التي لا تُنْبِت فإنها عبارة غير مخلصة». ٦١٥٣٩- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q>: ليس فيها نبت{5}. (ز) ٦١٥٤٠- عن عكرمة مولى ابن عباس، <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q>، قال: الظِّماء{6}. (١١/٧١٢) ٦١٥٤١- عن الحسن البصري، <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q>، قال: قرى فيما بين اليمن والشام{6}٥١٨١. (١١/٧١٢) ٥١٨١ علَّق ابنُ كثير (١١/١٠٧) على قول من قال بأن <q>﴿الأرض الجرز﴾</q> هي: أرض مصر، بقوله: «وليس المراد من قوله: <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q> أرض مصر فقط، بل هي بعض المقصود، وإن مثَّل بها كثير من المفسرين فليست المقصودة وحدها، ولكنَّها مرادةٌ قَطْعًا من هذه الآية، فإنها في نفسها أرض رخوة غليظة، تحتاج من الماء ما لو نزل عليها مطرًا لتهدَّمت أبنيتها، فيسوق الله إليها النيل بما يتحمله من الزيادة الحاصلة من أمطار بلاد الحبشة، وفيه طين أحمر، فيغشى أرض مصر، وهي أرض سبخة مرملة، محتاجة إلى ذلك الماء، وذلك الطين أيضًا؛ ليَنبُتَ الزرع فيه، فيستغلون كل سنة على ماء جديد ممطور في غير بلادهم، وطين جديد من غير أرضهم، فسبحان الحكيم الكريم المنان، المحمود ابتداء». ٦١٥٤٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</q>: المُغْبَرَّة{5}. (ز) ٦١٥٤٣- عن إسماعيل السُّدِّيّ، <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q>، قال: الأرض الميتة{6}. (١١/٧١٢) ٦١٥٤٤- قال مقاتل بن سليمان: <q>﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</q> يعني: الملساء ليس فيها نبت، <q>﴿فَنُخْرِجُ بِهِ﴾</q> بالماء <q>﴿زَرْعًا تَأْكُلُ مِنهُ أنْعامُهُمْ وأَنْفُسُهُمْ أفَلا يُبْصِرُونَ﴾</q> هذه الأعاجيب؛ فيُوَحِّدون ربهم ﷿{10}. (ز) ٦١٥٤٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</q>، قال: الأرض الجرز: التي ليس فيها شيء، ليس فيها نبات. وفي قوله: <q>﴿صَعِيدًا جُرُزًا﴾</q> [الكهف:٨]، قال: ليس عليها شيء، وليس فيها نبات ولا شيء{11}٥١٨٢. (ز) ٥١٨٢ علَّق ابنُ كثير (١١/١٠٨) على قول الضحاك، وعكرمة، وقتادة، والسدي، وابن زيد بقوله: «وهذا كقوله: <q>﴿وآيَةٌ لَهُمُ الأرْضُ المَيْتَةُ أحْيَيْناها وأَخْرَجْنا مِنها حَبًّا فَمِنهُ يَأْكُلُونَ * وجَعَلْنا فِيها جَنّاتٍ مِن نَخِيلٍ وأَعْنابٍ وفَجَّرْنا فِيها مِنَ العُيُونِ * لِيَأْكُلُوا مِن ثَمَرِهِ وما عَمِلَتْهُ أيْدِيهِمْ أفَلا يَشْكُرُونَ﴾</q> [يس:٣٣-٣٥]». ٦١٥٤٦- قال يحيى بن سلّام: <q>﴿أوَلَمْ يَرَوْا﴾</q> يعني: المشركين <q>﴿أنّا نَسُوقُ الماءَ﴾</q> يعني: المطر، تساق السحاب التي فيها الماء -كقوله: <q>﴿سُقْناهُ لِبَلَدٍ مَيِّتٍ﴾</q> [الأعراف:٥٧]- <q>﴿إلى الأَرْضِ الجُرُزِ﴾</q> اليابسة التي ليس فيها نبات، <q>﴿فَنُخْرِجُ بِهِ زَرْعًا تَأْكُلُ مِنهُ أنْعامُهُمْ وأَنْفُسُهُمْ أفَلا يُبْصِرُونَ﴾</q> يعني: المشركين، أي: فالذي أحيا هذه الأرض بعد موتها قادِرٌ على أن يحييهم بعد موتهم{12}. (ز) <q>﴿أَوَلَمۡ یَرَوۡا۟ أَنَّا نَسُوقُ ٱلۡمَاۤءَ إِلَى ٱلۡأَرۡضِ ٱلۡجُرُزِ فَنُخۡرِجُ بِهِۦ زَرۡعࣰا تَأۡكُلُ مِنۡهُ أَنۡعَـٰمُهُمۡ وَأَنفُسُهُمۡۚ أَفَلَا یُبۡصِرُونَ ۝٢٧﴾</q> - آثار متعلقة بالآية ٦١٥٤٧- عن الربيع بن سبرة، قال: الأمثال أقربُ إلى العقول من المعاني، ألم تسمع إلى قوله: <q>﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</q> «ألم تر؟»، «ألم يروا؟»{13}. (١١/٧١٢) ",footnotes:1:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٥٤٥-، وابن جرير ١٨/٦٤١-٦٤٢. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ١٨/٦٤١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أبين هي عدن أبين: جزيرة باليمن. التاج (عدن).أخرجه عبد الرزاق ٢/١١٠، وابن جرير ١٨/٦٣٢ دون قوله: هي التي لا تنبت. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٦٤٢.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٦٤٢.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٥٣.أخرجه ابن جرير ١٨/٦٤٣.تفسير يحيى بن سلام ٢/٦٩٥.عزاه السيوطي إلى أبي بكر بن حيان في الغرر.
32,28," <q>﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡفَتۡحُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٨﴾</q> - نزول الآية ٦١٥٤٨- عن قتادة بن دعامة -من طريق سعيد- قال: قال الصحابة: إنّ لنا يومًا يوشك أن نستريح فيه، ونَتَنَعَّم فيه. فقال المشركون: متى هذا الفتح إن كنتم صادقين}. فنزلت{1}. (١١/٧١٢) <q>﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡفَتۡحُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٨﴾</q> - تفسير الآية ٦١٥٤٩- قال إسماعيل السُّدِّيّ: <q>﴿مَتى هَذا الفَتْحُ﴾</q> متى هذا القضاء{2}. (ز) ٦١٥٥٠- قال مقاتل بن سليمان: <q>﴿ويَقُولُونَ مَتى هَذا الفَتْحُ﴾</q> يعني: القضاء، وهو البعث، <q>﴿إنْ كُنْتُمْ صادِقِينَ﴾</q> وذلك أنّ المؤمنين قالوا: إنّ لنا يومًا نتنعم فيه ونستريح. فقال كفار مكة: <q>﴿مَتى هَذا الفَتْحُ إنْ كُنْتُمْ صادِقِينَ﴾</q>؟ يعنون: النبي ﷺ وحده، تكذيبًا بالبعث بأنه ليس بكائن، فإن كان البعث حقًّا صدَّقنا يومئذ{3}. (ز) ٦١٥٥١- قال يحيى بن سلّام: <q>﴿ويَقُولُونَ﴾</q> يعني: المشركين: <q>﴿مَتى هَذا الفَتْحُ﴾</q> متى هذا القضاء <q>﴿إنْ كُنْتُمْ صادِقِينَ﴾</q> والفتح: القضاء بعذابهم، قالوا ذلك استهزاء وتكذيبًا بأنه لا يكون{4}٥١٨٣. (ز) ٥١٨٣ اختلف في معنى: «الفتح» في هذه الآية على قولين: الأول: الحُكْم. الثاني: عُنِيَ به: فتح مكة. ورجَّح ابنُ جرير (١٨/٦٤٤) مستندًا إلى ظاهر الآيات والدلالة العقلية القول الأول، وهو قول قتادة، ومقاتل، ويحيى بن سلام، وعلَّل ابنُ جرير ذلك، فقال: «يدل على أن ذلك معناه قوله: <q>﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ ولا هُمْ يُنْظَرُونَ﴾</q>، ولا شك أن الكفار قد كان جعل الله لهم التوبة قبل فتح مكة وبعده، ولو كان معنى قوله: <q>﴿مَتى هَذا الفَتْحُ﴾</q> على ما قاله من قال: يعني به: فتح مكة؛ لكان لا توبة لمن أسلم من المشركين بعد فتح مكة، ولا شك أن الله قد تاب على بَشَرٍ كثيرٍ من المشركين بعد فتح مكة، ونفعهم بالإيمان به وبرسوله، فمعلومٌ بذلك صحة ما قلنا من التأويل، وفساد ما خالفه». ورجَّحه ابنُ عطية (٧/٨٣)، فقال: «وهو أقوى الأقوال». ولم يذكر مستندًا. ورجَّح ابنُ كثير (١١/١٠٩) القول الأول، وانتقد القول الثاني مستندًا إلى دلالة التاريخ والنظائر، فقال: «ومَن زعم أنّ المراد من هذا الفتح: فتح مكة؛ فقد أبعد النّجعة، وأخطأ فأفحش، فإن يوم الفتح قد قَبِل رسول الله ﷺ إسلام الطلقاء، وقد كانوا قريبًا من ألفين، ولو كان المراد فتح مكة لما قَبِلَ إسلامهم؛ لقوله: <q>﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ ولا هُمْ يُنْظَرُونَ﴾</q>، وإنما المراد: الفتح الذي هو القضاء والفصل، كقوله تعالى: <q>﴿فافْتَحْ بَيْنِي وبَيْنَهُمْ فَتْحًا ونَجِّنِي ومَن مَعِيَ مِنَ المُؤْمِنِينَ﴾</q> [الشعراء:١١٨]، وكقوله: <q>﴿قُلْ يَجْمَعُ بَيْنَنا رَبُّنا ثُمَّ يَفْتَحُ بَيْنَنا بِالحَقِّ وهُوَ الفَتّاحُ العَلِيمُ﴾</q> [سبأ:٢٦]، وقال تعالى: <q>﴿واسْتَفْتَحُوا وخابَ كُلُّ جَبّارٍ عَنِيدٍ﴾</q> [إبراهيم:١٥]، وقال: <q>﴿وكانُوا مِن قَبْلُ يَسْتَفْتِحُونَ عَلى الَّذِينَ كَفَرُوا﴾</q> [البقرة:٨٩]، وقال: <q>﴿إنْ تَسْتَفْتِحُوا فَقَدْ جاءَكُمُ الفَتْحُ﴾</q> [الأنفال:١٩]». وانتقد ابنُ عطية القول الثاني مستندًا إلى ظاهر الآيات والدلالة العقلية قائلًا: «وهذا ضعيف، يردُّه الإخبار بأن الكفرة لا ينفعهم الإيمان، فلم يَبْقَ أن يكون الفتح إما حُكْمُ الآخرة، وهو قول مجاهد، وإما فَصْل الدنيا كبدر ونحوه». ",footnotes:1:أخرجه ابن جرير ١٨/٦٤٤. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٦٩٥.تفسير مقاتل بن سليمان ٣/٤٥٣.تفسير يحيى بن سلام ٢/٦٩٥.
32,29," <q>﴿قُلۡ یَوۡمَ ٱلۡفَتۡحِ لَا یَنفَعُ ٱلَّذِینَ كَفَرُوۤا۟ إِیمَـٰنُهُمۡ وَلَا هُمۡ یُنظَرُونَ ۝٢٩﴾</q> - تفسير ٦١٥٥٢- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿ويَقُولُونَ مَتى هَذا الفَتْحُ إنْ كُنْتُمْ صادِقِينَ﴾</q>، قال: يوم بدر فُتح للنبي ﷺ، فلم ينفع الذين كفروا إيمانهم بعد الموت{1}. (١١/٧١٣) ٦١٥٥٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿قُلْ يَوْمَ الفَتْحِ﴾</q>، قال: يوم القيامة{2}. (١١/٧١٣) ٦١٥٥٤- عن قتادة بن دعامة، في قوله: <q>﴿قُلْ يَوْمَ الفَتْحِ﴾</q>، قال: يوم القضاء{3}. (١١/٧١٣) ٦١٥٥٥- قال إسماعيل السُّدِّيّ: <q>﴿قُلْ يَوْمَ الفَتْحِ﴾</q>، يعني: يوم بدر؛ لأن أصحاب رسول الله ﷺ كانوا يقولون لهم: إنّ الله ناصرنا ومُظهِرُنا عليكم{4}. (ز) ٦١٥٥٦- قال محمد بن السائب الكلبي: <q>﴿قُلْ يَوْمَ الفَتْحِ﴾</q>، يعني: فتح مكة{4}. (ز) ٦١٥٥٧- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> يا محمد: <q>﴿يَوْمَ الفَتْحِ﴾</q> يعني: القضاء <q>﴿لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</q> بالبعث؛ لقولهم للنبي ﷺ: إن كان البعث الذي تقول حقًّا صدّقنا يومئذ. <q>﴿ولا هُمْ يُنْظَرُونَ﴾</q> يقول: لا يناظر بهم العذاب حتى يقولوا. فلما نزلت هذه الآية أراد النبيُّ ﷺ أن يرسل إليهم فيجزيهم وينبئهم؛ فأنزل الله -تبارك وتعالى- يُعَزِّي نبيَّه ﷺ إلى مدة{6}. (ز) ٦١٥٥٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</q>، قال: يوم الفتح إذا جاء العذاب{7}٥١٨٤. (ز) ٥١٨٤ لم يذكر ابنُ جرير (١٨/٦٤٥) في معنى: <q>﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</q> سوى قول ابن زيد، ومجاهد. ٦١٥٥٩- قال يحيى بن سلّام: <q>﴿قُلْ يَوْمَ الفَتْحِ﴾</q> يعني: يوم القضاء <q>﴿لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</q> ليس أحدٌ مِن المشركين يرى العذاب إلا آمن، ولا يُقبل منهم عند ذلك، <q>﴿ولا هُمْ يُنْظَرُونَ﴾</q> فما يُؤَخَّرون بالعذاب إذا جاء الوقت{8}. (ز) ",footnotes:1:أخرجه الحاكم ٢/١٤١-٤١٥. وعزاه السيوطي إلى البيهقي في الدلائل.أخرجه ابن جرير ١٨/٦٤٥. وعلَّقه يحيى بن سلام ٢/٦٩٥ من طريق عاصم بن حكيم. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن جرير.تفسير الثعلبي ٧/٣٣٥، وتفسير البغوي ٦/٣١٠.تفسير الثعلبي ٧/٣٣٥، وتفسير البغوي ٦/٣١٠.تفسير مقاتل بن سليمان ٣/٤٥٣-٤٥٤.أخرجه ابن جرير ١٨/٦٤٥.تفسير يحيى بن سلام ٢/٦٩٦.
32,30," <q>﴿فَأَعۡرِضۡ عَنۡهُمۡ وَٱنتَظِرۡ إِنَّهُم مُّنتَظِرُونَ ۝٣٠﴾</q> - تفسير الآية ٦١٥٦٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وانْتَظِرْ إنَّهُمْ مُنْتَظِرُونَ﴾</q>: يعني: يوم القيامة{1}٥١٨٥. (١١/٧١٣) ٥١٨٥ لم يذكر ابنُ جرير (١٨/٦٤٦) في معنى: <q>﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ إنَّهُمْ مُنْتَظِرُونَ﴾</q> سوى قول قتادة. ٦١٥٦١- قال مقاتل بن سليمان: <q>﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ﴾</q> بهم العذاب، يعني: القتل ببدر، <q>﴿إنَّهُمْ مُنْتَظِرُونَ﴾</q> العذاب، يعني: القتل ببدر، فقتلهم الله، وضربت الملائكة وجوههم وأدبارهم، وعجّل الله أرواحهم إلى النار{2}. (ز) ٦١٥٦٢- قال يحيى بن سلّام: <q>﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ﴾</q> بهم العذاب{3}. (ز) <q>﴿فَأَعۡرِضۡ عَنۡهُمۡ وَٱنتَظِرۡ إِنَّهُم مُّنتَظِرُونَ ۝٣٠﴾</q> - النسخ في الآية ٦١٥٦٣- قال عبد الله بن عباس -من طريق الضحاك- <q>﴿فَأَعْرِضْ عَنْهُمْ﴾</q>: نسختها آية السيف{4}. (ز) ٦١٥٦٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّهُمْ مُنْتَظِرُونَ﴾</q>: أنها نزلت قبل أن يؤمر بقتالهم، فنسخها القتال في سورة براءة في قوله: <q>﴿فاقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾</q> [التوبة:٥]{5}. (ز) ٦١٥٦٥- قال مقاتل بن سليمان: <q>﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ﴾</q> بهم العذاب، يعني: القتل ببدر، <q>﴿إنَّهُمْ مُنْتَظِرُونَ﴾</q> ثم إن آية السيف نسخت الإعراض{2}. (ز) <q>﴿فَأَعۡرِضۡ عَنۡهُمۡ وَٱنتَظِرۡ إِنَّهُم مُّنتَظِرُونَ ۝٣٠﴾</q> - آثار متعلقة بالآية ٦١٥٦٦- قال الحسن البصري: لم يبعث الله نبيًّا إلا هو يُحَذِّر قومَه عذابَ الدنيا وعذابَ الآخرة{7}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١١٠، وابن جرير ١٨/٦٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٥٤.تفسير يحيى بن سلام ٢/٦٩٦.أخرجه النحاس في الناسخ والمنسوخ (٦٢٢).أخرجه يحيى بن سلام ٢/٦٩٦.تفسير مقاتل بن سليمان ٣/٤٥٤.علقه يحيى بن سلام ٢/٦٩٦.
