quran[10]{c,v,t}:
  32,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَنُذِیقَنَّهُم مِّنَ ٱلۡعَذَابِ ٱلۡأَدۡنَىٰ دُونَ ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٤٥٧<span class="dash">-</span></span> عن أبي إدريس الخولاني، قال: سألتُ عبادة بن الصامت عن قول الله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</span>. فقال: سألتُ رسولَ الله ﷺ عنها، فقال: «<b>هي المصائب، والأسقام، والأنصاب، عذاب للمسرف في الدنيا، دون عذاب الآخرة</b>». قلت: يا رسول الله، فما هي لنا؟ قال: «<b>زكاة وطهور</b>»{1}. (١١/٧٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٥٨<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق ابن أبي ليلى- في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: مصائب الدنيا، والروم، والبطشة، والدخان{2}. (١١/٧٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٥٩<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق مجاهد- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: يوم بدر{3}. (١١/٧٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: يوم بدر{4}. (١١/٧٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: سِنُون أصابتهم{5}. (١١/٧٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- في قوله: <span class="qpc-hafs">﴿العَذابِ الأَدْنى﴾</span>، قال: سنون أصابت قومًا قبلكم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٣<span class="dash">-</span></span> عن <span class="name-1">الحسن بن علي</span> -من طريق عوف، عمَّن حدَّثه– أنه قال: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: القتل بالسيف صَبْرًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شبيب، عن عكرمة- في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</span>، قال: الحدود{8}. (١١/٧٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، يقول: مصائب الدنيا، وأسقامها، وبلاؤها مما يبتلي الله بها العباد حتى يتوبوا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٦<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن الحارث بن نوفل</span> -من طريق عوف- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: القتل بالسيف، كل شيء وعد الله هذه الأمة مِن العذاب الأدنى إنما هو السيف{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: المصائب في الدنيا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق جرير، عن منصور- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</span>، قال: أشياء يُصابون بها في الدنيا{12}. (١١/٧٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٦٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق سفيان، عن منصور- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</span>، قال: سنون أصابتهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: عذاب الدنيا، وعذاب القبر{14}. (١١/٧٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: القتل والجوع لقريش في الدنيا{15}. (١١/٧٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى دُونَ العَذابِ الأَكْبَرِ﴾</span>، قال: المصيبات في دنياهم وأموالهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٣<span class="dash">-</span></span> عن <span class="name-2">أبي عبيدة [بن عبد الله بن مسعود]</span>، في قوله: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: عذاب القبر{17}. (١١/٧٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قال: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span> العذاب الأدنى بالسيف يوم بدر{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>: أي: مصيبات الدنيا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٦<span class="dash">-</span></span> قال <span class="name-2">الحسن</span> -من طريق معمر- <span class="qpc-hafs">﴿العَذابِ الأَدْنى﴾</span>: عقوبات الدنيا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٨<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span> هو القتل بالسيف يوم بدر{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٧٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، يعني بالعذاب الأدنى: العذاب الأقرب، وهو الجوع في الدنيا{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿مِنَ العَذابِ الأَدْنى﴾</span> يعني: الجوع الذي أصابهم في السنين السبع بمكة؛ حين أكلوا العظام، والموتى، والجِيَف، والكلاب؛ عقوبةً بتكذيبهم النبي ﷺ{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span>، قال: العذاب الأدنى: عذاب الدنيا{24}<span class=comment-ref>٥١٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٢</span> اختلف في معنى العذاب الأدنى في قوله تعالى: <span class="qpc-hafs">﴿ولَنُذِيقَنَّهُمْ مِنَ العَذابِ الأَدْنى﴾</span> في هذه الآية على خمسة أقوال: <b>الأول:</b> أنه مصائب الدنيا في الأنفس والأموال. <b>الثاني:</b> أنه الحدود. <b>الثالث:</b> أنه القتل بالسيف؛ كيوم بدر. <b>الرابع:</b> أنه سنون أصابتهم. <b>الخامس:</b> أنه عذاب القبر. <b>السادس:</b> أنه عذاب الدنيا.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٧/٧٩) القول الثالث بقوله: «فيكون -على هذا التأويل- الرّاجعُ غير الذي يذوق، بل الذي يبقى بعده». و<span class="comment-type-1">وجَّه</span> القولَ الثاني بقوله: «ويتَّجه -على هذا التأويل- أن يكون في فسقة المؤمنين».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٢/٣٢٣) القول الخامس بقوله: «وقد احتج بهذه الآية جماعةٌ -منهم: عبد الله بن عباس- على عذاب القبر، وفي الاحتجاج بها شيء؛ لأن هذا عذاب في الدنيا يستدعي به رجوعهم عن الكفر، ولم يكن هذا مما يخفى على حبر الأمة وترجمان القرآن، لكن مِن فقهه في القرآن ودقة فهمه فيه فهم منها عذاب القبر؛ فإنه سبحانه أخبر أن له فيه عذابين أدنى وأكبر، فأخبر أنه يذيقهم بعض الأدنى ليرجعوا، فدلَّ على أنه بقي لهم مِن الأدنى بقية يعذبون بها بعد عذاب الدنيا، ولهذا قال: <span class="qpc-hafs">﴿مِنَ العَذابِ الأَدْنى﴾</span>، ولم يقل: ولنذيقنَّهم العذاب الأدنى. فتأمَّله».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٨/٦٣٢) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول معنى الآية لكل عذاب وقع للكفار في الدنيا، فقال: «وأولى الأقوال في ذلك أن يُقال: إنّ الله وعد هؤلاء الفسقة المكذبين بوعيده في الدنيا العذاب الأدنى، أن يذيقَهموه دون العذاب الأكبر، والعذاب: هو ما كان في الدنيا من بلاءٍ أصابهم؛ إما شدةٌ من مجاعة، أو قَتْلٌ، أو مصائب يصابون بها، فكلُّ ذلك من العذاب الأدنى، ولم يَخْصُصْ الله -تعالى ذِكْرُه- إذ وعدهم ذلك أن يعذِّبهم بنوعٍ من ذلك دون نوعٍ، وقد عذَّبهم بكلِّ ذلك في الدنيا؛ بالقتل، والجوع، والشدائد، والمصائب في الأموال، فأوفى لهم بما وعدهم».</div></p><p><h3><span class="qpc-hafs">﴿دُونَ ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٤٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- في قوله: <span class="qpc-hafs">﴿دُونَ العَذابِ الأَكْبَرِ﴾</span>، قال: يوم القيامة{25}. (١١/٧٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: العذاب الأكبر يوم القيامة في الآخرة{26}. (١١/٧٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿دُونَ العَذابِ الأَكْبَرِ﴾</span>: يوم القيامة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿دُونَ العَذابِ الأَكْبَرِ﴾</span>: يوم القيامة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿دُونَ العَذابِ الأَكْبَرِ﴾</span>، يعني: القتل ببدر، وهو أعظم من العذاب الذي أصابهم من الجوع{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿دُونَ العَذابِ الأَكْبَرِ﴾</span>، قال: العذاب الأكبر: عذاب الآخرة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿دُونَ العَذابِ الأَكْبَرِ﴾</span>، يعني: النار في الآخرة، كقوله في سورة النجم: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span> [النجم:٩]، يعني: أقرب{31}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٤٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- في قوله: <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: لعلَّ مَن بقي منهم أن يتوب فيرجع{25}. (١١/٧٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: يتوبون{33}. (١١/٧٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: يتوبون{34}. (١١/٧٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٢<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع- <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: يتوبون{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: يتوبون{36}. (١١/٧٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: يتوبون{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-، مثله{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> يعني: لكي <span class="qpc-hafs">﴿يَرْجِعُونَ﴾</span> مِن الكفر إلى الإيمان{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٤٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> لعلَّ مَن يبقى منهم <span class="qpc-hafs">﴿يَرْجِعُونَ﴾</span> عن الشرك إلى الإيمان، فعذّبهم بالسيف يوم بدر، ومن بعدهم على مَن شاء الإيمان{31}<span class=comment-ref>٥١٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٣</span> لم يذكر <u>ابنُ جرير</u> (١٨/٦٣٤) في معنى: <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span> سوى قول ابن مسعود، وأبي العالية، وقتادة.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه مسلم (٢٧٩٩)، وعبد الله بن أحمد ٣٥/١٠٤ (٢١١٧٣)، وابن جرير ١٨/٦٢٧ بلفظ: مصيبات الدنيا، والحاكم ٤/٤٢٧-٤٢٨، والبيهقي في شعب الإيمان (٩٨٢١). وعزاه السيوطي إلى ابن أبي حاتم، وأبي عوانة في صحيحه، وابن المنذر.|3:أخرجه ابن جرير ١٨/٦٣٠.|4:أخرجه سفيان الثوري في تفسيره (٢٤٠)، ويحيى بن سلام ٢/٦٩٢، وابن جرير ١٨/٦٢٩، والطبراني (٩٠٣٨)، والحاكم ٢/٤١٤. وعزاه السيوطي إلى الفريابي، وابن منيع، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في الدلائل.|5:تفسير مجاهد (٥٤٥)، وأخرجه النسائي (١١٣٩٥)، والحاكم ٤/٢٥٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن مردويه، وابن المنذر.|6:أخرجه آدم بن أبي إياس -تفسير مجاهد (٥٤٥)-.|7:أخرجه ابن جرير ١٨/٦٣٠.|8:أخرجه ابن جرير ١٨/٦٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:أخرجه ابن جرير ١٨/٦٢٧، وأخرجه أيضًا من طريق عطية العوفي قريبًا منه. وأخرج إسحاق البستي ص١٠٤ نحوه مختصرًا من طريق يزيد عن عكرمة.|10:أخرجه ابن جرير ١٨/٦٣٠. وفي تفسير الثعلبي ٧/٣٣٣ بلفظ: القتل بالسيف يوم بدر.|11:أخرجه ابن جرير ١٨/٦٢٨.|12:أخرجه ابن أبي شيبة ١٣/٥٥٢، وابن جرير ١٨/٦٢٩.|13:أخرجه سفيان الثوري في تفسيره (٢٤٠) عن منصور عن إبراهيم بلفظ: المصائب في الأموال والأولاد، وابن جرير ١٨/٦٣١.|14:أخرجه يحيى بن سلام ٢/٦٩٢-٦٩٣ بنحوه، وابن جرير ١٨/٦٣٠. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.|15:تفسير مجاهد (٥٤٥)، وأخرجه ابن جرير ١٨/٦٣١. وعزاه السيوطي إلى الفريابي.|16:أخرجه ابن جرير ١٨/٦٢٨.|17:أخرجه هناد (٣٤٥).|18:أخرجه يحيى بن سلام ٢/٦٩٢.|19:أخرجه ابن جرير ١٨/٦٢٩.|20:أخرجه عبد الرزاق ٢/١١٠.|21:تفسير البغوي ٦/٣٠٨.|22:علقه يحيى بن سلام ٢/٦٩٣.|23:تفسير مقاتل بن سليمان ٣/٤٥٢.|24:أخرجه ابن جرير ١٨/٦٣٣.|25:أخرجه يحيى بن سلام ٢/٦٩٢، وابن جرير ١٨/٦٢٩، والطبراني (٩٠٣٨)، والحاكم ٢/٤١٤. وعزاه السيوطي إلى الفريابي، وابن منيع، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في الدلائل.|26:تفسير مجاهد (٥٤٥)، وأخرجه ابن جرير ١٨/٦٣٣، كما أخرجه من طريق أبي يحيى. وعزاه السيوطي إلى الفريابي.|27:أخرجه ابن جرير ١٨/٦٣٣.|28:أخرجه ابن جرير ١٨/٦٣٣.|29:تفسير مقاتل بن سليمان ٣/٤٥٢.|30:أخرجه ابن جرير ١٨/٦٣٣.|31:تفسير يحيى بن سلام ٢/٦٩٣.|32:أخرجه يحيى بن سلام ٢/٦٩٢، وابن جرير ١٨/٦٢٩، والطبراني (٩٠٣٨)، والحاكم ٢/٤١٤. وعزاه السيوطي إلى الفريابي، وابن منيع، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في الدلائل.|33:أخرجه النسائي (١١٣٩٥)، والحاكم ٤/٢٥٣، وابن جرير ١٨/٦٣٤. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن مردويه.|34:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.|35:أخرجه ابن جرير ١٨/٦٣٤.|36:أخرجه ابن أبي شيبة ١٣/٥٥٢-٥٥٤. وعزاه السيوطي إلى ابن جرير.|37:أخرجه ابن جرير ١٨/٦٣٤.|38:أخرجه ابن جرير ١٨/٦٣٣.|39:تفسير مقاتل بن سليمان ٣/٤٥٢.|40:تفسير يحيى بن سلام ٢/٦٩٣.
  32,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَنۡ أَظۡلَمُ مِمَّن ذُكِّرَ بِـَٔایَـٰتِ رَبِّهِۦ ثُمَّ أَعۡرَضَ عَنۡهَاۤۚ إِنَّا مِنَ ٱلۡمُجۡرِمِینَ مُنتَقِمُونَ ۝٢٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٤٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</span> يعني: كفار مكة، نزلت في المُطْعِمين{1} والمستهزئين من قريش، انتقم الله ﷿ منهم بالقتل ببدر، وضربت الملائكة الوجوه والأدبار، وتعجيل أرواحهم إلى النار{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَنۡ أَظۡلَمُ مِمَّن ذُكِّرَ بِـَٔایَـٰتِ رَبِّهِۦ ثُمَّ أَعۡرَضَ عَنۡهَاۤۚ إِنَّا مِنَ ٱلۡمُجۡرِمِینَ مُنتَقِمُونَ ۝٢٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٤٩٩<span class="dash">-</span></span> عن معاذ بن جبل، قال: سمعتُ رسول الله ﷺ يقول: «<b>ثلاثٌ مَن فعلهنَّ فقد أجرم: مَن عقد لواءً في غير حق، أو عقَّ والديه، أو مشى مع ظالم لينصره، فقد أجرم، يقول الله: <span class="qpc-hafs">﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</span></b>»{3}. (١١/٧٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَن أظْلَمُ﴾</span> يقول: فلا أحد أظلم <span class="qpc-hafs">﴿مِمَّنْ ذُكِّرَ بِآياتِ رَبِّهِ﴾</span> يقول: مِمَّن وُعِظ بآيات القرآن <span class="qpc-hafs">﴿ثُمَّ أعْرَضَ عَنْها﴾</span> عن الإيمان، <span class="qpc-hafs">﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</span> يعني: كفار مكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ومَن أظْلَمُ مِمَّنْ ذُكِّرَ بِآياتِ رَبِّهِ ثُمَّ أعْرَضَ عَنْها﴾</span> لم يؤمن بها، <span class="qpc-hafs">﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</span> والمجرمين -ها هنا-: المشركين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٢<span class="dash">-</span></span> عن يزيد{6} بن رُفَيْع -من طريق مروان بن سُفَيْح- قال: إنّ قول الله في القرآن: <span class="qpc-hafs">﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</span> هم أصحاب القدَر. ثم قرأ: <span class="qpc-hafs">﴿إنَّ المُجْرِمِينَ فِي ضَلالٍ وسُعُرٍ﴾</span> إلى قوله: <span class="qpc-hafs">﴿إنّا كُلَّ شَيْءٍ خَلَقْناهُ بِقَدَرٍ﴾</span> [القمر: ٤٧-٤٩]{7}<span class=comment-ref>٥١٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٤</span> نقل <u>ابنُ عطية</u> (٧/٨٠) عن <u>ابن جرير</u> أثر يزيد بن رفيع أن المقصود بقوله تعالى: <span class="qpc-hafs">﴿إنّا مِنَ المُجْرِمِينَ مُنْتَقِمُونَ﴾</span> أهل القدر، و<span class="comment-type-1">وجَّهه</span> بقوله: «يريد: القائلين بأن أفعال العبد من قبله». ثم <span class="comment-type-2">انتقد</span> استدلال يزيد بقوله تعالى: <span class="qpc-hafs">﴿إنَّ المُجْرِمِينَ فِي ضَلالٍ وسُعُرٍ﴾</span> إلى قوله: <span class="qpc-hafs">﴿إنّا كُلَّ شَيْءٍ خَلَقْناهُ بِقَدَرٍ﴾</span> [القمر:٤٧-٤٩] على المعنى الذي ذهب إليه، فقال: «وفي هذا المنزع من البُعْد ما لا خفاء به».</div></p></div>",footnotes:1:يعني: المطعمين يوم بدر من صناديد قريش الذين تعهدوا بإطعام جيش المشركين في مسيرهم، وقد نص عليهم مقاتل عند تفسير قوله تعالى: <span class="qpc-hafs">﴿ويَجْعَلَ الخَبِيثَ بَعْضَهُ عَلى بَعْضٍ فَيَرْكُمَهُ جَمِيعًا فَيَجْعَلَهُ فِي جَهَنَّمَ﴾</span> [الأنفال:٣٧]، وقوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ كَفَرُوا وصَدُّوا عَنْ سَبِيلِ اللَّهِ أضَلَّ أعْمالَهُمْ﴾</span> [محمد:١].|2:تفسير مقاتل بن سليمان ٣/٤٥٢.|3:أخرجه أحمد بن منيع -كما في إتحاف الخيرة ٥/١٦٢ (٤٤٤٤)-، والطبراني في الكبير ٢٠/٦١ (١١٢)، وابن جرير ١٨/٦٣٥، والثعلبي ٧/٣٣٣ من طريق إسماعيل بن عياش، عن عبد العزيز بن عبيد الله، عن عبادة بن نسي، عن جنادة بن أبي أمية، عن معاذ بن جبل به.</p><p>قال ابن كثير في تفسيره ٦/٣٧١: «وهذا حديث غريب جدًّا». وقال الهيثمي في المجمع ٧/٩٠ (١١٢٦٩): «فيه عبد العزيز بن عبيد الله بن حمزة، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٥/١٦٢ (٤٤٤٤): «هذا إسناد ضعيف؛ لضعف عبد العزيز». وقال السيوطي: «سند ضعيف». وقال الألباني في الضعيفة ٤/٤٢١ (١٩٥١): «ضعيف».|4:تفسير مقاتل بن سليمان ٣/٤٥٢.|5:تفسير يحيى بن سلام ٢/٦٩٣.|6:كذا عند ابن جرير، والذي في التاريخ الكبير للبخاري ٧/٣٧٢ (ترجمة مروان بن سفيح): زيد.|7:أخرجه ابن جرير ١٨/٦٣٥.
  32,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ فَلَا تَكُن فِی مِرۡیَةࣲ مِّن لِّقَاۤىِٕهِۦۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥٠٣<span class="dash">-</span></span> عن ابن عباس، عن النبي ﷺ، <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> قال: «<b>من لقاء موسى ربه</b>». <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</span>، قال: «<b>جعل موسى هدى لبني إسرائيل</b>»{1}. (١١/٧١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٤<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال النبي ﷺ: «<b>رأيت ليلة أسري بي موسى بن عمران رجلًا طوالًا جَعْدًا</b>{2}، <b>كأنه من رجال شَنُوءَة</b>{3}، <b>ورأيت عيسى بن مريم مَرْبوعَ الخلق</b>{4}، <b>إلى الحمرة والبياض، سبط</b>{5} <b>الرأس، ورأيت مالكًا خازن جهنم، والدجال</b>». في آياتٍ أراهنَّ الله إيّاه. قال: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> فكان <span class="name-2">قتادة</span> يُفَسِّرها أنّ النبي ﷺ قد لقي موسى، <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</span> قال: جعل الله موسى هُدًى لبني إسرائيل{6}<span class=comment-ref>٥١٧٥</span>. (١١/٧١٠)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٥</span> لم يذكر <u>ابنُ جرير</u> (١٨/٦٣٦) في معنى: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> سوى حديث ابن عباس ﵄.</div></p><p><div></p><p><p><span class="item-no">٦١٥٠٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> فلا تكن في شكٍّ مِن لقاء موسى ليلة المعراج{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span>، في قوله: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span>، قال: من لقاء موسى. قيل: أوَلقي موسى؟ قال: نعم، ألا ترى إلى قوله: <span class="qpc-hafs">﴿واسْأَلْ مَن أرْسَلْنا مِن قَبْلِكَ مِن رُسُلِنا﴾</span>؟! [الزخرف:٤٥]{8}. (١١/٧١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span>، قال: مِن أن تلقى موسى{9}. (١١/٧١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> مِن أن تلقى مِن قومك مِن الأذى ما لقي موسى مِن قومه مِن الأذى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٠٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> مِن تَلَقِّيه كتاب الله تعالى بالرِّضا والقَبول{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥١٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿مِن لِقائِهِ﴾</span>، يعني: ليلة أسري به، فلقيه النبي ﷺ في السماء السادسة ليلة أُسري به{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ﴾</span> يقول: أعطينا موسى ﷺ التوراة، <span class="qpc-hafs">﴿فَلا تَكُنْ﴾</span> يا محمد <span class="qpc-hafs">﴿فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> يقول: لا تكن في شكٍّ مِن لقاء موسى ﵇ التوراة، فإن الله ﷿ ألقى الكتاب عليه -يعني: التوراة- حقًّا{13}<span class=comment-ref>٥١٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٦</span> اختلف في معنى قوله تعالى: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> على أقوال: <b>الأول:</b> فلا تكن -يا محمد- في شكٍّ من لقاء موسى ﵇ ربَّه تعالى. <b>الثاني:</b> فلا تكن في شك من لقاء موسى ﵇ ليلة الإسراء. <b>الثالث:</b> فلا تكن في شك من لقاء الأذى كما لقي موسى ﵇ الأذى. <b>الرابع:</b> فلا تكن في شكٍّ من تلقِّي موسى ﵇ الكتاب.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٧/٨١) القول الثالث بقوله: «كأنه قال: ولقد آتينا موسى ﵇ هذا العِبْءَ الذي أنت بسبيله، فلا تَمْتَر أنّك تلقى ما لَقِيَ هو من المحنة بالناس، وكأن الآية تسليةٌ لمحمد ﷺ. <b>ونقل عن فرقة</b>: أن الضمير في <span class="qpc-hafs">﴿لقائه﴾</span> عائد على الكتاب، ثم <span class="comment-type-1">وجَّهه</span> بقوله:»أي: أنه لقي موسى ﵇ حين لقيه موسى ﵇، والمصدر في هذا التأويل يصح أن يكون مضافًا إلى الفاعل، بمعنى: لقي الكتاب موسى، ويصح أن يكون مضافًا إلى المفعول، بمعنى: لقي الكتابَ -بالنصب- موسى ﵇«. ثم نقل عن فرقتين قولَيْن آخرَيْن، <b>الأول</b>: أن المعنى: فلا تك في شك من لقائه في الآخرة. و<span class="comment-type-2">انتقده</span> قائلًا:»وهذا قولٌ ضعيف«. و<b>الثاني</b>: أن الضمير عائد على ملك الموت الذي تقدم ذِكْره، وقوله: <span class="qpc-hafs">﴿فَلا تَكُنْ فِي مِرْيَةٍ مِن لِقائِهِ﴾</span> اعتراضٌ بيْن الكلامَين، و<span class="comment-type-2">انتقده</span> قائلًا:»وهذا أيضًا ضعيف".</div></p><p><div></p><p><p><span class="item-no">٦١٥١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ﴾</span> يعني: التوراة، <span class="qpc-hafs">﴿فَلا تَكُنْ﴾</span> يا محمد <span class="qpc-hafs">﴿فِي مِرْيَةٍ﴾</span> في شك{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَـٰهُ هُدࣰى لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</span> وجعلنا موسى هدى لبني إسرائيل{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</span>، قال: جعل الله موسى هدًى لبني إسرائيل{16}<span class=comment-ref>٥١٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٧</span> لم يذكر <u>ابنُ جرير</u> (١٨/٦٣٧) في معنى: <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</span> سوى قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٦١٥١٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى لِبَنِي إسْرائِيلَ﴾</span>، يعني: التوراة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلْناهُ هُدًى﴾</span> يعني: التوراة هدًى <span class="qpc-hafs">﴿لِبَنِي إسْرائِيلَ﴾</span> مِن الضلالة{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَـٰهُ هُدࣰى لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٢٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥١٧<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>لَمّا أُسري بي إلى السماء رأيتُ موسى يُصَلِّي في قبره</b>»{19}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ١٢/١٦٠ (١٢٧٥٨)، وابن عساكر في تاريخه ٦١/١٦٨.</p><p>قال الهيثمي في المجمع ٧/٩٠ (١١٢٧٠): «رجاله رجال الصحيح». وقال السيوطي: «سند صحيح».|2:الجعد في صفات الرجال يكون مدحًا ويكون ذمًا، فإذا كان مدحًا فله معنيان أحدهما أن يكون معصوب الخلق شديد الأسر، والثاني أن يكون شعره غير سبط؛ لأن السبوطة في شعور العجم، وأما الجعد الذموم فله معنيان أحدهما القصير، والآخر البخيل. صحيح مسلم بشرح النووي ١٠/١٢٨-١٢٩.|3:شنوءة: قبيلة من قبائل اليمن. اللسان (شنأ).|4:مَرْبوع: هو المعتدل الخلقة، لا بالطويل ولا بالقصير. اللسان (ربع).|5:السبط: ممتد الأعضاء تام الخلق، والمنبسط المسترسل من الشعر. النهاية (سبط).|6:أخرجه البخاري ٤/١١٦ (٣٢٣٩)، ومسلم ١/١٥١ (١٦٥)، وابن جرير ١٨/٦٣٦، والبغوي في تفسيره ٦/٣٠٨-٣٠٩.|7:تفسير الثعلبي ٧/٣٣٤، وتفسير البغوي ٦/٣٠٨.|8:عزاه السيوطي إلى ابن أبي حاتم.|9:تفسير مجاهد (٥٤٥). وعلَّقه يحيى بن سلام ٢/٦٩٣ بلفظ: من لقاء موسى وكُتُبِهِ. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|10:علقه يحيى بن سلام ٢/٦٩٣.|11:تفسير الثعلبي ٧/٣٣٤، وتفسير البغوي ٦/٣٠٩.|12:علقه يحيى بن سلام ٢/٦٩٣.|13:تفسير مقاتل بن سليمان ٣/٤٥٢.|14:تفسير يحيى بن سلام ٢/٦٩٣.|15:علقه يحيى بن سلام ٢/٦٩٤.|16:أخرجه ابن جرير ١٨/٦٣٩.|17:علقه يحيى بن سلام ٢/٦٩٤.|18:تفسير مقاتل بن سليمان ٣/٤٥٢.|19:أخرجه مسلم ٤/١٨٤٥ (٢٣٧٥)، والبغوي في تفسيره ٦/٣٠٩ واللفظ له.
  32,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا مِنۡهُمۡ أَىِٕمَّةࣰ یَهۡدُونَ بِأَمۡرِنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وجَعَلْنا مِنهُمْ أئِمَّةً﴾</span>، قال: رؤساء في الخير سوى الأنبياء{1}. (١١/٧١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥١٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وجَعَلْنا مِنهُمْ أئِمَّةً﴾</span> أتباع الأنبياء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلْنا مِنهُمْ﴾</span> يعني: مِن بني إسرائيل <span class="qpc-hafs">﴿أئِمَّةً﴾</span> يعني: قادة إلى الخير <span class="qpc-hafs">﴿يَهْدُونَ بِأَمْرِنا﴾</span> يعني: يدعون الناس إلى أمر الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجَعَلْنا مِنهُمْ أئِمَّةً﴾</span> أنبياء يُهتدى بهم <span class="qpc-hafs">﴿يَهْدُونَ بِأَمْرِنا﴾</span> يعني: يدعون بأمرنا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَمَّا صَبَرُوا۟ۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یُوقِنُونَ ۝٢٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦١٥٢٢<span class="dash">-</span></span> عن الأعمش: قرأ <span class="name-1">ابن مسعود</span>: (بِما صَبَرُواْ){5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَمَّا صَبَرُوا۟ۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یُوقِنُونَ ۝٢٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿يَهْدُونَ بِأَمْرِنا لَمّا صَبَرُوا﴾</span>، قال: على ترك الدنيا{6}. (١١/٧١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لَمّا صَبَرُوا﴾</span>، يعني: بما صبروا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَمّا صَبَرُوا﴾</span> يعني: لما صبروا على البلاء حين كُلّفوا بمصر ما لم يطيقوا من العمل، فعل ذلك بهم باتِّباعهم موسى على دين الله ﷿، <span class="qpc-hafs">﴿وكانُوا بِآياتِنا﴾</span> يعني: بالآيات التسع <span class="qpc-hafs">﴿يُوقِنُونَ﴾</span> بأنّها من الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٢٦<span class="dash">-</span></span> عن <span class="name-3">الحسن بن صالح</span> -من طريق يحيى بن آدم- في قوله تعالى: <span class="qpc-hafs">﴿أئمة يهدون بأمرنا لما صبروا﴾</span>، قال: صبروا على الدنيا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٢٧<span class="dash">-</span></span> عن <span class="name-3">وكيع [بن الجراح]</span> -من طريق ابن وكيع- قال: سمعنا في: <span class="qpc-hafs">﴿وجَعَلْنا مِنهُمْ أئِمَّةً يَهْدُونَ بِأَمْرِنا لَمّا صَبَرُوا﴾</span>، قال: عن الدنيا{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَمَّا صَبَرُوا۟ۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یُوقِنُونَ ۝٢٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٢٨<span class="dash">-</span></span> عن مالك أنّه تلا: <span class="qpc-hafs">﴿وجَعَلْنا مِنهُمْ أئِمَّةً يَهْدُونَ بِأَمْرِنا لَمّا صَبَرُوا﴾</span>، فقال: حدثني الزهري، أنّ عطاء بن يزيد حدثه، عن أبي هريرة، أنه سمع النبي ﷺ يقول: «<b>ما رُزِق عبدٌ خيرًا له ولا أوسع مِن الصبر</b>»{11}. (١١/٧١١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٦٣٧. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير البغوي ٦/٣٠٩.|3:تفسير مقاتل بن سليمان ٣/٤٥٢-٤٥٣.|4:تفسير يحيى بن سلام ٢/٦٩٤.|5:أخرجه ابن أبي داود في المصاحف ١/٣٢٩. وعلَّقه ابن جرير ١٨/٦٣٨.</p><p>وهي قراءة شاذة. انظر: معاني القرآن للفراء ٢/٣٣١، والجامع لأحكام القرآن ١٧/٤٣.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:علقه يحيى بن سلام ٢/٦٩٤.|8:تفسير مقاتل بن سليمان ٣/٤٥٢-٤٥٣.|9:أخرجه ابن الجعد في مسنده ٢/٨٠٣ (٢١٤٨).|10:أخرجه ابن جرير ١٨/٦٣٨.|11:أخرجه الحاكم ٢/٤٤٩ (٣٥٥٢) من طريق عبد الرحمن بن حمدان الجلاب، عن إسحاق بن أحمد بن مهران الخراز، عن إسحاق بن سليمان الرازي، عن مالك بن أنس، عن الزهري، عن عطاء بن يزيد، عن أبي هريرة به.</p><p>قال الحاكم: «قد اتفق الشيخان على إخراج هذه اللفظة في آخر حديثه بهذا الإسناد: أن ناسًا من الأنصار سألوا رسول الله ﷺ. الحديث بطوله، وفي آخره هذه اللفظة، ولم يخرجاه بهذه السياقة التي عند إسحاق بن سليمان». وقال الذهبي في التلخيص: «على شرط البخاري ومسلم».
  32,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ هُوَ یَفۡصِلُ بَیۡنَهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ فِیمَا كَانُوا۟ فِیهِ یَخۡتَلِفُونَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ﴾</span> يعني: يقضي بينهم، يعني: بني إسرائيل <span class="qpc-hafs">﴿يَوْمَ القِيامَةِ فِيما كانُوا فِيهِ﴾</span> مِن الدين <span class="qpc-hafs">﴿يَخْتَلِفُونَ﴾</span>{1}<span class=comment-ref>٥١٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٨</span> ذكر <u>ابنُ عطية</u> (٧/٨١) أنّ قوله تعالى: <span class="qpc-hafs">﴿إنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ القِيامَةِ﴾</span> حُكْمٌ يعمُّ جميع الخَلْق. ونقل عن بعض المتأوِّلين أنهم ذهبوا إلى تخصيص الضمير، ثم <span class="comment-type-2">انتقد</span> ذلك بقوله: «وذلك ضعيف».</div></p><p><div></p><p><p><span class="item-no">٦١٥٣٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ القِيامَةِ﴾</span> يقضي بينهم يوم القيامة <span class="qpc-hafs">﴿فِيما كانُوا فِيهِ يَخْتَلِفُونَ﴾</span> يفصل بين المؤمنين والمشركين فيما اختلفوا فيه مِن الإيمان والكفر، فيُدخل المؤمنين الجنة، ويُدخِل المشركين النار{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٥٣.|2:تفسير يحيى بن سلام ٢/٦٩٤.
  32,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَهۡدِ لَهُمۡ كَمۡ أَهۡلَكۡنَا مِن قَبۡلِهِم مِّنَ ٱلۡقُرُونِ یَمۡشُونَ فِی مَسَـٰكِنِهِمۡۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتٍۚ أَفَلَا یَسۡمَعُونَ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿أوَلَمْ يَهْدِ لَهُمْ﴾</span>، يقول: أوَلَم يُبَيِّن لهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أوَلَمْ يَهْدِ لَهُمْ كَمْ أهْلَكْنا مِن قَبْلِهِمْ مِنَ القُرُونِ﴾</span>: عاد وثمود، وأنهم إليهم لا يرجعون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٣٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أوَلَمْ يَهْدِ لَهُمْ﴾</span> أي: أوَلَم نُبَيِّن لهم <span class="qpc-hafs">﴿يَمْشُونَ فِي مَساكِنِهِمْ﴾</span> يقول: قد مرَّ أهل مكة على قُراهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوَلَمْ يَهْدِ لَهُمْ﴾</span> يعني: يبين لهم <span class="qpc-hafs">﴿كَمْ أهْلَكْنا﴾</span> بالعذاب <span class="qpc-hafs">﴿مِن قَبْلِهِمْ مِنَ القُرُونِ﴾</span> يعني: الأمم الخالية <span class="qpc-hafs">﴿يَمْشُونَ فِي مَساكِنِهِمْ﴾</span> يقول: يمُرُّون على قراهم، يعني: قوم لوط وصالح وهود، فيرون هلاكهم، <span class="qpc-hafs">﴿إنَّ فِي ذَلِكَ لَآياتٍ﴾</span> يعني: لعبرة، <span class="qpc-hafs">﴿أفَلا يَسْمَعُونَ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٣٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أوَلَمْ يَهْدِ لَهُمْ﴾</span> أي: أوَلَم يُبَيِّن الله لهم <span class="qpc-hafs">﴿كَمْ أهْلَكْنا مِن قَبْلِهِمْ مِنَ القُرُونِ﴾</span> يعني: ما قصَّ مِمّا أهلك به الأمم السالفة حين كذبوا رسلهم <span class="qpc-hafs">﴿يَمْشُونَ فِي مَساكِنِهِمْ﴾</span> يعني: يمرون فيها، كقوله: <span class="qpc-hafs">﴿وإنَّكُمْ لَتَمُرُّونَ عَلَيْهِمْ مُصْبِحِينَ﴾</span> [الصافات:١٣٧] نهارًا وليلًا، يعني: في مساكنهم التي كانوا فيها، منها ما يُرى ومنها ما لا يُرى، كقوله: <span class="qpc-hafs">﴿مِنها قائِمٌ﴾</span> تراه <span class="qpc-hafs">﴿وحَصِيدٌ﴾</span> [هود:١٠٠] لا تراه، <span class="qpc-hafs">﴿إنَّ فِي ذَلِكَ لَآياتٍ﴾</span> أي: للمؤمنين، <span class="qpc-hafs">﴿أفَلا يَسْمَعُونَ﴾</span> يعني: المشركين{5}<span class=comment-ref>٥١٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٧٩</span> ذكر <u>ابنُ عطية</u> (٧/٨٢) في معنى: <span class="qpc-hafs">﴿يَمْشُون﴾</span> احتمالين: <b>الأول</b>: «أن يكون للمخاطبين بالبينة المحتج عليهم». <b>والثاني</b>: «أن يكون للمُهلَكين». و<span class="comment-type-1">وجَّهه</span> بقوله: «فـ<span class="qpc-hafs">﴿يَمْشُونَ﴾</span> في موضع الحال، أي: أُهلِكوا وهم ماشون في مساكنهم».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٦٣٩.|2:أخرجه ابن جرير ١٨/٦٤٠.|3:علقه يحيى بن سلام ٢/٦٩٥.|4:تفسير مقاتل بن سليمان ٣/٤٥٣.|5:تفسير يحيى بن سلام ٢/٦٩٥.
  32,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ أَنَّا نَسُوقُ ٱلۡمَاۤءَ إِلَى ٱلۡأَرۡضِ ٱلۡجُرُزِ فَنُخۡرِجُ بِهِۦ زَرۡعࣰا تَأۡكُلُ مِنۡهُ أَنۡعَـٰمُهُمۡ وَأَنفُسُهُمۡۚ أَفَلَا یُبۡصِرُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي نجيح، عن رجل- في قوله: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</span>، قال: الجُرُز: التي لا تمطر إلا مطرًا لا يغني عنها شيئًا، إلا ما يأتيها من السيول{1}. (١١/٧١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن دينار- في قوله: <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span>، قال: أرض باليمن{2}. (١١/٧١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span>، قال: هي التي لا تنبت، هي أبْيَن{3} ونحوها من الأرض{4}<span class=comment-ref>٥١٨٠</span>. (١١/٧١١)</p></p><p></div></p><p><div><span class=comment-ref>٥١٨٠</span> بيَّن <u>ابنُ عطية</u> (٧/٨٢-٨٣) بأن معنى: <span class="qpc-hafs">﴿الجُرُز﴾</span>: الأرض العاطشة التي قد أكلت نباتها مِن العطش والقيظ. ثم <span class="comment-type-2">انتقد</span> قول من قال: بأنها الأرض التي لا تُنبِت قائلًا: «ومَن عبَّر عنها بأنها الأرض التي لا تُنْبِت فإنها عبارة غير مخلصة».</div></p><p><div></p><p><p><span class="item-no">٦١٥٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span>: ليس فيها نبت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span>، قال: الظِّماء{6}. (١١/٧١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٤١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span>، قال: قرى فيما بين اليمن والشام{6}<span class=comment-ref>٥١٨١</span>. (١١/٧١٢)</p></p><p></div></p><p><div><span class=comment-ref>٥١٨١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١١/١٠٧) على قول من قال بأن <span class="qpc-hafs">﴿الأرض الجرز﴾</span> هي: أرض مصر، بقوله: «وليس المراد من قوله: <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span> أرض مصر فقط، بل هي بعض المقصود، وإن مثَّل بها كثير من المفسرين فليست المقصودة وحدها، ولكنَّها مرادةٌ قَطْعًا من هذه الآية، فإنها في نفسها أرض رخوة غليظة، تحتاج من الماء ما لو نزل عليها مطرًا لتهدَّمت أبنيتها، فيسوق الله إليها النيل بما يتحمله من الزيادة الحاصلة من أمطار بلاد الحبشة، وفيه طين أحمر، فيغشى أرض مصر، وهي أرض سبخة مرملة، محتاجة إلى ذلك الماء، وذلك الطين أيضًا؛ ليَنبُتَ الزرع فيه، فيستغلون كل سنة على ماء جديد ممطور في غير بلادهم، وطين جديد من غير أرضهم، فسبحان الحكيم الكريم المنان، المحمود ابتداء».</div></p><p><div></p><p><p><span class="item-no">٦١٥٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</span>: المُغْبَرَّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span>، قال: الأرض الميتة{6}. (١١/٧١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</span> يعني: الملساء ليس فيها نبت، <span class="qpc-hafs">﴿فَنُخْرِجُ بِهِ﴾</span> بالماء <span class="qpc-hafs">﴿زَرْعًا تَأْكُلُ مِنهُ أنْعامُهُمْ وأَنْفُسُهُمْ أفَلا يُبْصِرُونَ﴾</span> هذه الأعاجيب؛ فيُوَحِّدون ربهم ﷿{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٤٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</span>، قال: الأرض الجرز: التي ليس فيها شيء، ليس فيها نبات. وفي قوله: <span class="qpc-hafs">﴿صَعِيدًا جُرُزًا﴾</span> [الكهف:٨]، قال: ليس عليها شيء، وليس فيها نبات ولا شيء{11}<span class=comment-ref>٥١٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٨٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١١/١٠٨) على قول الضحاك، وعكرمة، وقتادة، والسدي، وابن زيد بقوله: «<span class="mustanad">وهذا كقوله</span>: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ الأرْضُ المَيْتَةُ أحْيَيْناها وأَخْرَجْنا مِنها حَبًّا فَمِنهُ يَأْكُلُونَ * وجَعَلْنا فِيها جَنّاتٍ مِن نَخِيلٍ وأَعْنابٍ وفَجَّرْنا فِيها مِنَ العُيُونِ * لِيَأْكُلُوا مِن ثَمَرِهِ وما عَمِلَتْهُ أيْدِيهِمْ أفَلا يَشْكُرُونَ﴾</span> [يس:٣٣-٣٥]».</div></p><p><div></p><p><p><span class="item-no">٦١٥٤٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا﴾</span> يعني: المشركين <span class="qpc-hafs">﴿أنّا نَسُوقُ الماءَ﴾</span> يعني: المطر، تساق السحاب التي فيها الماء -كقوله: <span class="qpc-hafs">﴿سُقْناهُ لِبَلَدٍ مَيِّتٍ﴾</span> [الأعراف:٥٧]- <span class="qpc-hafs">﴿إلى الأَرْضِ الجُرُزِ﴾</span> اليابسة التي ليس فيها نبات، <span class="qpc-hafs">﴿فَنُخْرِجُ بِهِ زَرْعًا تَأْكُلُ مِنهُ أنْعامُهُمْ وأَنْفُسُهُمْ أفَلا يُبْصِرُونَ﴾</span> يعني: المشركين، أي: فالذي أحيا هذه الأرض بعد موتها قادِرٌ على أن يحييهم بعد موتهم{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ أَنَّا نَسُوقُ ٱلۡمَاۤءَ إِلَى ٱلۡأَرۡضِ ٱلۡجُرُزِ فَنُخۡرِجُ بِهِۦ زَرۡعࣰا تَأۡكُلُ مِنۡهُ أَنۡعَـٰمُهُمۡ وَأَنفُسُهُمۡۚ أَفَلَا یُبۡصِرُونَ ۝٢٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٤٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن سبرة</span>، قال: الأمثال أقربُ إلى العقول من المعاني، ألم تسمع إلى قوله: <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا أنّا نَسُوقُ الماءَ إلى الأَرْضِ الجُرُزِ﴾</span> «ألم تر؟»، «ألم يروا؟»{13}. (١١/٧١٢)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٥٤٥-، وابن جرير ١٨/٦٤١-٦٤٢. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.|2:أخرجه ابن جرير ١٨/٦٤١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|3:أبين هي عدن أبين: جزيرة باليمن. التاج (عدن).|4:أخرجه عبد الرزاق ٢/١١٠، وابن جرير ١٨/٦٣٢ دون قوله: هي التي لا تنبت. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|5:أخرجه ابن جرير ١٨/٦٤٢.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:أخرجه ابن جرير ١٨/٦٤٢.|9:عزاه السيوطي إلى ابن أبي حاتم.|10:تفسير مقاتل بن سليمان ٣/٤٥٣.|11:أخرجه ابن جرير ١٨/٦٤٣.|12:تفسير يحيى بن سلام ٢/٦٩٥.|13:عزاه السيوطي إلى أبي بكر بن حيان في الغرر.
  32,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡفَتۡحُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: قال الصحابة: إنّ لنا يومًا يوشك أن نستريح فيه، ونَتَنَعَّم فيه. فقال المشركون: متى هذا الفتح إن كنتم صادقين}. فنزلت{1}. (١١/٧١٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡفَتۡحُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٤٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿مَتى هَذا الفَتْحُ﴾</span> متى هذا القضاء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُونَ مَتى هَذا الفَتْحُ﴾</span> يعني: القضاء، وهو البعث، <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> وذلك أنّ المؤمنين قالوا: إنّ لنا يومًا نتنعم فيه ونستريح. فقال كفار مكة: <span class="qpc-hafs">﴿مَتى هَذا الفَتْحُ إنْ كُنْتُمْ صادِقِينَ﴾</span>؟ يعنون: النبي ﷺ وحده، تكذيبًا بالبعث بأنه ليس بكائن، فإن كان البعث حقًّا صدَّقنا يومئذ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويَقُولُونَ﴾</span> يعني: المشركين: <span class="qpc-hafs">﴿مَتى هَذا الفَتْحُ﴾</span> متى هذا القضاء <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> والفتح: القضاء بعذابهم، قالوا ذلك استهزاء وتكذيبًا بأنه لا يكون{4}<span class=comment-ref>٥١٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٨٣</span> اختلف في معنى: «الفتح» في هذه الآية على قولين: <b>الأول:</b> الحُكْم. <b>الثاني:</b> عُنِيَ به: فتح مكة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٨/٦٤٤) <span class="mustanad">مستندًا إلى ظاهر الآيات والدلالة العقلية</span> القول الأول، وهو قول قتادة، ومقاتل، ويحيى بن سلام، <span class="comment-type-4">وعلَّل</span> <u>ابنُ جرير</u> ذلك، فقال: «يدل على أن ذلك معناه قوله: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ ولا هُمْ يُنْظَرُونَ﴾</span>، ولا شك أن الكفار قد كان جعل الله لهم التوبة قبل فتح مكة وبعده، ولو كان معنى قوله: <span class="qpc-hafs">﴿مَتى هَذا الفَتْحُ﴾</span> على ما قاله من قال: يعني به: فتح مكة؛ لكان لا توبة لمن أسلم من المشركين بعد فتح مكة، ولا شك أن الله قد تاب على بَشَرٍ كثيرٍ من المشركين بعد فتح مكة، ونفعهم بالإيمان به وبرسوله، فمعلومٌ بذلك صحة ما قلنا من التأويل، وفساد ما خالفه».</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٧/٨٣)، فقال: «وهو أقوى الأقوال». ولم يذكر مستندًا.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١١/١٠٩) القول الأول، و<span class="comment-type-2">انتقد</span> القول الثاني <span class="mustanad">مستندًا إلى دلالة التاريخ والنظائر</span>، فقال: «ومَن زعم أنّ المراد من هذا الفتح: فتح مكة؛ فقد أبعد النّجعة، وأخطأ فأفحش، فإن يوم الفتح قد قَبِل رسول الله ﷺ إسلام الطلقاء، وقد كانوا قريبًا من ألفين، ولو كان المراد فتح مكة لما قَبِلَ إسلامهم؛ لقوله: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ ولا هُمْ يُنْظَرُونَ﴾</span>، وإنما المراد: الفتح الذي هو القضاء والفصل، كقوله تعالى: <span class="qpc-hafs">﴿فافْتَحْ بَيْنِي وبَيْنَهُمْ فَتْحًا ونَجِّنِي ومَن مَعِيَ مِنَ المُؤْمِنِينَ﴾</span> [الشعراء:١١٨]، وكقوله: <span class="qpc-hafs">﴿قُلْ يَجْمَعُ بَيْنَنا رَبُّنا ثُمَّ يَفْتَحُ بَيْنَنا بِالحَقِّ وهُوَ الفَتّاحُ العَلِيمُ﴾</span> [سبأ:٢٦]، وقال تعالى: <span class="qpc-hafs">﴿واسْتَفْتَحُوا وخابَ كُلُّ جَبّارٍ عَنِيدٍ﴾</span> [إبراهيم:١٥]، وقال: <span class="qpc-hafs">﴿وكانُوا مِن قَبْلُ يَسْتَفْتِحُونَ عَلى الَّذِينَ كَفَرُوا﴾</span> [البقرة:٨٩]، وقال: <span class="qpc-hafs">﴿إنْ تَسْتَفْتِحُوا فَقَدْ جاءَكُمُ الفَتْحُ﴾</span> [الأنفال:١٩]».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> القول الثاني <span class="mustanad">مستندًا إلى ظاهر الآيات والدلالة العقلية</span> قائلًا: «وهذا ضعيف، يردُّه الإخبار بأن الكفرة لا ينفعهم الإيمان، فلم يَبْقَ أن يكون الفتح إما حُكْمُ الآخرة، وهو قول مجاهد، وإما فَصْل الدنيا كبدر ونحوه».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٦٤٤. وعزاه السيوطي إلى ابن أبي حاتم.|2:علقه يحيى بن سلام ٢/٦٩٥.|3:تفسير مقاتل بن سليمان ٣/٤٥٣.|4:تفسير يحيى بن سلام ٢/٦٩٥.
  32,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ یَوۡمَ ٱلۡفَتۡحِ لَا یَنفَعُ ٱلَّذِینَ كَفَرُوۤا۟ إِیمَـٰنُهُمۡ وَلَا هُمۡ یُنظَرُونَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٥٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿ويَقُولُونَ مَتى هَذا الفَتْحُ إنْ كُنْتُمْ صادِقِينَ﴾</span>، قال: يوم بدر فُتح للنبي ﷺ، فلم ينفع الذين كفروا إيمانهم بعد الموت{1}. (١١/٧١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ﴾</span>، قال: يوم القيامة{2}. (١١/٧١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ﴾</span>، قال: يوم القضاء{3}. (١١/٧١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ﴾</span>، يعني: يوم بدر؛ لأن أصحاب رسول الله ﷺ كانوا يقولون لهم: إنّ الله ناصرنا ومُظهِرُنا عليكم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ﴾</span>، يعني: فتح مكة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> يا محمد: <span class="qpc-hafs">﴿يَوْمَ الفَتْحِ﴾</span> يعني: القضاء <span class="qpc-hafs">﴿لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</span> بالبعث؛ لقولهم للنبي ﷺ: إن كان البعث الذي تقول حقًّا صدّقنا يومئذ. <span class="qpc-hafs">﴿ولا هُمْ يُنْظَرُونَ﴾</span> يقول: لا يناظر بهم العذاب حتى يقولوا. فلما نزلت هذه الآية أراد النبيُّ ﷺ أن يرسل إليهم فيجزيهم وينبئهم؛ فأنزل الله -تبارك وتعالى- يُعَزِّي نبيَّه ﷺ إلى مدة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٥٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</span>، قال: يوم الفتح إذا جاء العذاب{7}<span class=comment-ref>٥١٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٨٤</span> لم يذكر <u>ابنُ جرير</u> (١٨/٦٤٥) في معنى: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</span> سوى قول ابن زيد، ومجاهد.</div></p><p><div></p><p><p><span class="item-no">٦١٥٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قُلْ يَوْمَ الفَتْحِ﴾</span> يعني: يوم القضاء <span class="qpc-hafs">﴿لا يَنْفَعُ الَّذِينَ كَفَرُوا إيمانُهُمْ﴾</span> ليس أحدٌ مِن المشركين يرى العذاب إلا آمن، ولا يُقبل منهم عند ذلك، <span class="qpc-hafs">﴿ولا هُمْ يُنْظَرُونَ﴾</span> فما يُؤَخَّرون بالعذاب إذا جاء الوقت{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/١٤١-٤١٥. وعزاه السيوطي إلى البيهقي في الدلائل.|2:أخرجه ابن جرير ١٨/٦٤٥. وعلَّقه يحيى بن سلام ٢/٦٩٥ من طريق عاصم بن حكيم. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن جرير.|4:تفسير الثعلبي ٧/٣٣٥، وتفسير البغوي ٦/٣١٠.|5:تفسير الثعلبي ٧/٣٣٥، وتفسير البغوي ٦/٣١٠.|6:تفسير مقاتل بن سليمان ٣/٤٥٣-٤٥٤.|7:أخرجه ابن جرير ١٨/٦٤٥.|8:تفسير يحيى بن سلام ٢/٦٩٦.
  32,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَعۡرِضۡ عَنۡهُمۡ وَٱنتَظِرۡ إِنَّهُم مُّنتَظِرُونَ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وانْتَظِرْ إنَّهُمْ مُنْتَظِرُونَ﴾</span>: يعني: يوم القيامة{1}<span class=comment-ref>٥١٨٥</span>. (١١/٧١٣)</p></p><p></div></p><p><div><span class=comment-ref>٥١٨٥</span> لم يذكر <u>ابنُ جرير</u> (١٨/٦٤٦) في معنى: <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ إنَّهُمْ مُنْتَظِرُونَ﴾</span> سوى قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٦١٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ﴾</span> بهم العذاب، يعني: القتل ببدر، <span class="qpc-hafs">﴿إنَّهُمْ مُنْتَظِرُونَ﴾</span> العذاب، يعني: القتل ببدر، فقتلهم الله، وضربت الملائكة وجوههم وأدبارهم، وعجّل الله أرواحهم إلى النار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ﴾</span> بهم العذاب{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَعۡرِضۡ عَنۡهُمۡ وَٱنتَظِرۡ إِنَّهُم مُّنتَظِرُونَ ۝٣٠﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٦٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْهُمْ﴾</span>: نسختها آية السيف{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّهُمْ مُنْتَظِرُونَ﴾</span>: أنها نزلت قبل أن يؤمر بقتالهم، فنسخها القتال في سورة براءة في قوله: <span class="qpc-hafs">﴿فاقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾</span> [التوبة:٥]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٥٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَعْرِضْ عَنْهُمْ وانْتَظِرْ﴾</span> بهم العذاب، يعني: القتل ببدر، <span class="qpc-hafs">﴿إنَّهُمْ مُنْتَظِرُونَ﴾</span> ثم إن آية السيف نسخت الإعراض{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَعۡرِضۡ عَنۡهُمۡ وَٱنتَظِرۡ إِنَّهُم مُّنتَظِرُونَ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٥٦٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لم يبعث الله نبيًّا إلا هو يُحَذِّر قومَه عذابَ الدنيا وعذابَ الآخرة{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١١٠، وابن جرير ١٨/٦٤٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٤٥٤.|3:تفسير يحيى بن سلام ٢/٦٩٦.|4:أخرجه النحاس في الناسخ والمنسوخ (٦٢٢).|5:أخرجه يحيى بن سلام ٢/٦٩٦.|6:تفسير مقاتل بن سليمان ٣/٤٥٤.|7:علقه يحيى بن سلام ٢/٦٩٦.