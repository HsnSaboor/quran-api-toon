tafsir[11]{c,v,t}:
25,33," <q>﴿وَلَا یَأۡتُونَكَ بِمَثَلٍ إِلَّا جِئۡنَـٰكَ بِٱلۡحَقِّ﴾</q> - تفسير ٥٤٧٦٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿ولا يأتونك بمثل إلا جئناك﴾</q>، قال: أي: ينزل به جبريلُ، كُلَّما أُتِيَ بمَثَلٍ يلتمس عَيْبَه نزل به كتابُ اللهِ ناطِقٌ{1}. (ز) ٥٤٧٦٦- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قوله: <q>﴿ولا يأتونك بمثل﴾</q>، يقول: لو أنزلنا عليكَ القرآنَ جملة واحدة ثم سألوك لم يكن عندك ما تجيب، ولكِنّا نُمْسِك عليك، فإذا سألوك أجبتَ{2}. (١١/١٧٢) ٥٤٧٦٧- عن عبد الله بن عباس، قال: قالت قريش: ما لِلقرآن لم ينزل على النبيِّ جملةً واحدةً؟ قال الله في كتابه: <q>﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة كذلك لنثبت به فؤادك ورتلناه ترتيلا﴾</q>. قال: قليلًا قليلًا؛ كيما لا يَجِيئوك بمَثَلٍ إلا أتيناك بما ينقض عليهم، فأنزلناه عليك تنزيلًا قليلًا قليلًا، كلَّما جاؤوا بشيء جئناهم بما هو أحسن منه تفسيرًا{3}. (١١/١٧٢) ٥٤٧٦٨- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿ولا يأتونك بمثل﴾</q> يُخاصِمُونك به، إضمار لقولهم: <q>﴿لولا نزل عليه القرآن جملة واحدة﴾</q> ونحوه في القرآن مِمّا يُخاصِمون به النبيَّ ﷺ، فيرُدُّ الله ﷿ عليهم قولَهم، فذلك قوله ﷿: <q>﴿إلا جئناك بالحق﴾</q> فيما تخصمهم به{4}. (ز) ٥٤٧٦٩- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿ولا يأتونك بمثل إلا جئناك بالحق﴾</q>، قال: لا يأتيك الكُفّار بمَثَل إلا جئناك بما تَرُدُّ به ما جاءوك به مِن الأمثال التي جاءوا بها{5}. (١١/١٧٣) ٥٤٧٧٠- قال يحيى بن سلّام: <q>﴿ولا يأتونك بمثل﴾</q>، يعني: المشركين فيما كانوا يُحاجُّونه به{6}. (ز) <q>﴿وَأَحۡسَنَ تَفۡسِیرًا ۝٣٣﴾</q> - تفسير ٥٤٧٧١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ولا يأتونك بمثل إلا جئناك بالحق وأحسن تفسيرا﴾</q>، يقول: أحسن تَفْصِيلًا{7}. (١١/١٧٢) ٥٤٧٧٢- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿وأحسن تفسيرا﴾</q>، قال: بَيانًا{8}. (١١/١٧٤) ٥٤٧٧٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وأحسن تفسيرا﴾</q>، قال: تفصيلًا{9}. (ز) ٥٤٧٧٤- عن قتادة بن دعامة، <q>﴿ولا يأتونك بمثل إلا جئناك بالحق وأحسن تفسيرا﴾</q>، قال: أحسن تَفْصِيلًا{10}. (١١/١٧١) ٥٤٧٧٥- عن عطاء الخراساني -من طريق ابنه عثمان- في قوله: <q>﴿وأحسن تفسيرا﴾</q>، قال: تفصيلًا{11}. (١١/١٧٣) ٥٤٧٧٦- قال مقاتل بن سليمان: <q>﴿وأحسن تفسيرا﴾</q>، يعني: وأحسن تبيانًا، فتَرُدُّ به خصومتَهم{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩١.أخرجه ابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٣٤.أخرجه ابن جرير ١٧/٤٤٥. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٤٨٠.أخرجه ابن جرير ١٧/٤٤٥. وعلَّقه ابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلام ١/٤٨٠ من طريق عاصم بن حكيم، وابن جرير ١٧/٤٤٨، وابن أبي حاتم ٨/٢٦٩٢.أخرجه ابن جرير ١٧/٤٤٨. وعلَّقه ابن أبي حاتم ٨/٢٦٩١.علَّقه يحيى بن سلام ١/٤٨٠، وابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٩١. وقد نسبه السيوطي إلى عطاء مهملًا دون تمييز، وعزاه إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٢٣٤.
25,34," <q>﴿ٱلَّذِینَ یُحۡشَرُونَ عَلَىٰ وُجُوهِهِمۡ إِلَىٰ جَهَنَّمَ﴾</q> - تفسير ٥٤٧٧٧- عن قتادة، حدَّثنا أنس بن مالك: أنّ رجلًا قال: يا نبيَّ اللهِ، يُحْشَر الكافِر على وجهه يوم القيامة؟! قال: «أليس الذي أمشاه على الرِّجلين في الدنيا قادِرًا على أن يُمْشِيه على وجهه يوم القيامة؟». قال قتادة: بلى، وعِزَّة ربِّنا{1}. (٩/٤٤٨) ٥٤٧٧٨- عن أبي هريرة -من طريق أبي خالد- قال: يُحْشَر الناسُ يوم القيامة على ثلاثة أصناف: صنف على الدواب، وصِنف على أقدامهم، وصِنف على وجوههم. فقيل: كيف يمشون على وجوههم؟! قال: إنّ الذي أمشاهم على أقدامهم قادِرٌ أن يمشيهم على وجوههم{2}. (ز) ٥٤٧٧٩- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿الذين يحشرون على وجوههم إلى جهنم﴾</q>، قال: الذي أمشاهم على أرجلهم قادِرٌ على أن يمشيهم على وجوههم{3}. (ز) ٥٤٧٨٠- قال مقاتل بن سليمان: ثم أخبر الله ﷿ بمُسْتَقَرِّهم في الآخرة، فقال سبحانه: <q>﴿الذين يحشرون على وجوههم إلى جهنم أولئك شر مكانا وأضل سبيلا﴾</q>{4}٤٧٢٩. (ز) ٤٧٢٩ ذكر ابنُ عطية (٦/٤٣٨) أنّ الجمهور على أنّ هذا المشي على الوجوه حقيقة. ونقل عن فِرقة أنها قالت بأنّه استعارة للذلة المفرطة، والهوان، والخزي. <q>﴿ٱلَّذِینَ یُحۡشَرُونَ عَلَىٰ وُجُوهِهِمۡ إِلَىٰ جَهَنَّمَ﴾</q> - آثار متعلقة بالآية ٥٤٧٨١- عن الحسن البصري، قال: لَمّا سير عامر بن عبد قيس إلى الشام، قال: الحمد لله الذي حشرني راكبًا. قال الحسن: قد -واللهِ- علم عامِرٌ أنّ قومًا يُحْشَرون على وجوههم{5}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ شَرࣱّ مَّكَانࣰا وَأَضَلُّ سَبِیلࣰا ۝٣٤﴾</q> - تفسير ٥٤٧٨٢- عن قتادة -من طريق سعيد بن بشير-: ذُكِر لنا: أنّ رجلًا قال: يا نبيَّ الله، كيف يُحْشَر الكافر على وجهه يوم القيامة؟! قال نبيُّ الله ﷺ: «أليس الذي أمشاه على رِجليه قادر على أن يمشيه على وجهه. قال الله ﷿: <q>﴿أولئك شر مكانا وأضل سبيلا﴾</q>»{6}. (ز) ٥٤٧٨٣- عن عبد الله بن عباس -من طريق أبي روق، عن الضحاك- في قوله: <q>﴿وأضل سبيلًا﴾</q>، يقول: وأبعد حُجَّة{5}. (ز) ٥٤٧٨٤- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿أولئك شر مكانا﴾</q> يقول: مِن أهل الجنة، <q>﴿وأضل سبيلا﴾</q> قال: طريقًا{3}. (ز) ٥٤٧٨٥- قال مقاتل بن سليمان: قال سبحانه: <q>﴿أولئك شر مكانا وأضل سبيلا﴾</q>، يعني: وأخطأ طريق الهدى في الدنيا مِن المؤمنين{4}. (ز) ٥٤٧٨٦- عن عبد الملك ابن جُرَيْج، في قوله <q>﴿أولئك شر مكانا﴾</q> يقول: مِن أهل الجنة، <q>﴿وأضل سبيلا﴾</q> قال: طريقًا{10}. (١١/١٧٤) ٥٤٧٨٧- قال يحيى بن سلّام: قوله: <q>﴿الذين يحشرون على وجوههم إلى جهنم أولئك شر مكانا﴾</q> مِن أهل الجنة، <q>﴿وأضل سبيلا﴾</q> طريقًا في الدنيا؛ لأنّ طريقهم إلى النار، وطريق المؤمنين إلى الجنة{11}. (ز) ",footnotes:1:أخرجه البخاري ٦/١٠٩ (٤٧٦٠)، ٨/١٠٩ (٦٥٢٣)، ومسلم ٤/٢١٦١ (٢٨٠٦)، وابن جرير ١٧/٤٤٩، وابن أبي حاتم ٨/٢٦٩٢ (١٥١٤٤) كلاهما دون قول قتادة، وأخرجه يحيى بن سلام ١/٢٤٤، ٤٨١ مرسلًا.أخرجه ابن جرير ١٧/٤٥٠. وتقدم مرفوعًا عند تفسير قوله تعالى: <q>﴿ونَحْشُرُهُمْ يَوْمَ القِيامَةِ عَلى وُجُوهِهِمْ عُمْيًا وبُكْمًا وصُمًّا﴾</q> [الإسراء:٩٧]، كما تقدمت عندها أحاديث وآثار أخرى.أخرجه ابن جرير ١٧/٤٤٩.تفسير مقاتل بن سليمان ٣/٢٣٤.أخرجه ابن أبي حاتم ٨/٢٦٩٢.أخرجه ابن أبي حاتم ٨/٢٦٩٢ (١٥١٤٧).أخرجه ابن أبي حاتم ٨/٢٦٩٢.أخرجه ابن جرير ١٧/٤٤٩.تفسير مقاتل بن سليمان ٣/٢٣٤.عزاه السيوطي إلى ابن جرير، وابن المنذر. وهو عند ابن جرير من رواية ابن جريج عن مجاهد كما تقدم.تفسير يحيى بن سلام ١/٤٨١.
25,35," <q>﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ﴾</q> - تفسير ٥٤٧٨٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿الكتاب﴾</q>، قال: التوراة{1}. (ز) ٥٤٧٨٩- عن زِياد بن أبي مريم -من طريق خُصَيْف- قوله: <q>﴿آتينا﴾</q>، قال: أعْطَيْنا{2}. (ز) ٥٤٧٩٠- قال مقاتل بن سليمان: <q>﴿ولقد آتينا موسى الكتاب﴾</q>، يقول: أعطينا موسى ﵇ التوراةَ{3}. (ز) ٥٤٧٩١- قال يحيى بن سلّام: قوله: <q>﴿ولقد آتينا موسى الكتاب﴾</q> التوراة{4}. (ز) <q>﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ﴾</q> - آثار متعلقة بالآية ٥٤٧٩٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: أُوتِي رسولُ الله ﷺ سبعًا مِن المثاني الطوال، وأُوتي موسى سِتًّا مِن المثاني{5}. (ز) <q>﴿وَجَعَلۡنَا مَعَهُۥۤ أَخَاهُ هَـٰرُونَ وَزِیرࣰا ۝٣٥﴾</q> - تفسير ٥٤٧٩٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وجعلنا معه أخاه هرون وزبرا﴾</q>، قال: عَوْنًا، وعَضُدًا{6}. (١١/١٧٤) ٥٤٧٩٤- قال يحيى بن سلّام: <q>﴿وجعلنا معه أخاه هارون وزيرا﴾</q> أي: عَوِينًا وعضُدًا في تفسير قتادة.= (ز) ٥٤٧٩٥- وتفسير الحسن: شريكًا في الرسالة.= (ز) ٥٤٧٩٦- قال يحيى بن سلّام: وهو واحد، وذلك قبل أن تنزل عليهما التوراة، ثم نزلت عليهما بعد، فقال: <q>﴿ولقد آتينا موسى وهارون الفرقان﴾</q> التوراة. وفرقانها: حلالها وحرامها{4}. (ز) ٥٤٧٩٧- قال مقاتل بن سليمان: <q>﴿وجعلنا معه أخاه هارون وزيرا﴾</q> يعني: مُعِينًا{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩٣.أخرجه ابن أبي حاتم ٨/٢٦٩٢.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٣، ٩/٢٩٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٣. وعلَّقه يحيى بن سلام ١/٤٨١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير يحيى بن سلام ١/٤٨١.تفسير مقاتل بن سليمان ٣/٢٣٤.
25,36," <q>﴿فَقُلۡنَا ٱذۡهَبَاۤ إِلَى ٱلۡقَوۡمِ ٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا﴾</q> - تفسير ٥٤٧٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿بآياتنا﴾</q>: بالبينات{1}. (ز) ٥٤٧٩٩- قال مقاتل بن سليمان: ثم انقطع الكلام، فأخبر اللهُ ﷿ [محمدًا] ﷺ، فقال سبحانه: <q>﴿فقلنا اذهبا إلى القوم﴾</q> يعني: أهل مصر <q>﴿الذين كذبوا بآياتنا﴾</q> يعني: الآيات التِّسع{2}. (ز) ٥٤٨٠٠- قال يحيى بن سلّام: <q>﴿فقلنا اذهبا إلى القوم الذين كذبوا بآياتنا﴾</q>، يعني: فرعون وقومه{3}. (ز) <q>﴿فَدَمَّرۡنَـٰهُمۡ تَدۡمِیرࣰا ۝٣٦﴾</q> - تفسير ٥٤٨٠١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فدمرناهم تدميرا﴾</q>، قال: أهلكناهم بالعذاب{1}. (١١/١٧٤) ٥٤٨٠٢- عن إسماعيل السُّدِّيّ، نحو ذلك{5}. (ز) ٥٤٨٠٣- عن الربيع بن أنس -من طريق أبي جعفر الرازي- في قوله: <q>﴿فدمرناهم تدميرًا﴾</q>، يقول: تبَّرناهم تتبيرًا، يقول: قَطَّعَ الله أنواع العذاب{1}. (ز) ٥٤٨٠٤- قال مقاتل بن سليمان: <q>﴿فدمرناهم تدميرا﴾</q>، يعني: أهلكناهم بالعذاب هلاكًا، يعني: الغَرَق{2}. (ز) ٥٤٨٠٥- قال يحيى بن سلّام: <q>﴿فقلنا اذهبا إلى القوم الذين كذبوا بآياتنا﴾</q> يعني: فرعون وقومه، <q>﴿فدمرناهم تدميرا﴾</q> أي: فكذبوهما، <q>﴿فدمرناهم تدميرا﴾</q> يعني: الغرق الذي أهلكهم به. كقوله: <q>﴿فكذبوهما فكانوا من المهلكين﴾</q> [المؤمنون:٤٨]، مِن المُعَذَّبين بالغرق في الدنيا، ولهم النار في الآخرة{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩٣.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٣.علَّقه ابن أبي حاتم ٨/٢٦٩٣.أخرجه ابن أبي حاتم ٨/٢٦٩٣.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.
25,37," <q>﴿وَقَوۡمَ نُوحࣲ لَّمَّا كَذَّبُوا۟ ٱلرُّسُلَ أَغۡرَقۡنَـٰهُمۡ وَجَعَلۡنَـٰهُمۡ لِلنَّاسِ ءَایَةࣰۖ﴾</q> - تفسير ٥٤٨٠٦- عن الربيع بن أنس -من طريق أبي جعفر الرازي- يعني: قوله: <q>﴿للناس آية﴾</q>، يقول: عِبْرَة، ومُتَفَكَّر{1}. (ز) ٥٤٨٠٧- قال مقاتل بن سليمان: <q>﴿وقوم نوح لما﴾</q> يعني: حين <q>﴿كذبوا الرسل﴾</q> يعني: نوحًا وحده؛ <q>﴿أغرقناهم وجعلناهم للناس آية﴾</q> يعني: عِبْرَة لِمَن بعدهم{2}. (ز) ٥٤٨٠٨- قال يحيى بن سلّام: <q>﴿وقوم نوح﴾</q> أي: وأهلكنا قوم نوح أيضًا بالغرق؛ <q>﴿لما كذبوا الرسل﴾</q> يعني: نوحًا. قال: <q>﴿أغرقناهم وجعلناهم للناس آية﴾</q> لِمَن بعدهم{3}. (ز) <q>﴿وَأَعۡتَدۡنَا لِلظَّـٰلِمِینَ عَذَابًا أَلِیمࣰا ۝٣٧﴾</q> - تفسير ٥٤٨٠٩- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- <q>﴿واعتدنا للظالمين﴾</q> يقول: للكافرين <q>﴿عذابًا اليمًا﴾</q> قال: العذاب: النَّكال{1}. (ز) ٥٤٨١٠- قال مقاتل بن سليمان: <q>﴿وأعتدنا للظالمين عذابا أليما﴾</q>، يعني: وجيعًا{2}. (ز) ٥٤٨١١- قال يحيى بن سلّام: <q>﴿وأعتدنا للظالمين﴾</q> المشركين، يعنيهم <q>﴿عذابا أليما﴾</q> مُوجِعًا في الآخرة{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩٤.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٤.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.
25,38," <q>﴿وَعَادࣰا وَثَمُودَا۟﴾</q> - قراءات ٥٤٨١٢- عن عاصم بن أبي النجود أنّه قرأ: ‹وعادًا وثَمُودًا› يُنَون ثمود{1}. (١١/١٧٤) <q>﴿وَعَادࣰا وَثَمُودَا۟﴾</q> - تفسير الآية ٥٤٨١٣- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿و﴾</q>أهلكنا <q>﴿عادا وثمود﴾</q>{2}. (ز) ٥٤٨١٤- قال يحيى بن سلّام: <q>﴿وعادا وثمود﴾</q>، أي: وأهلكنا عادًا وثمود، تبعًا للكلام الأول{3}. (ز) <q>﴿وَأَصۡحَـٰبَ ٱلرَّسِّ﴾</q> - تفسير ٥٤٨١٥- عن عبد الله بن عباس -من طريق ابن جريج- قال: الرس: قريةٌ مِن ثمود{4}. (١١/١٧٤) ٥٤٨١٦- عن عبد الله بن عباس -من طريق عكرمة- قال: الرس: بئر بأذربيجان{5}. (١١/١٧٥) ٥٤٨١٧- عن عبد الله بن عباس -من طريق العوفي- <q>﴿وأصحاب الرس﴾</q>، قال: هي بئر كانت تُسَمّى: الرس{4}. (ز) ٥٤٨١٨- عن ابن عباس، أنّه سأل كعبًا عن أصحاب الرسِّ، قال: صاحب «يس» الذي قال: <q>﴿يا قوم اتبعوا المرسلين﴾</q> [يس:٢٠]، فَرَسَّهُ{7} قومُه في بئر بالأحجار{8}. (١١/١٧٥) ٥٤٨١٩- عن ابن عباس -من طريق يونس بن يزيد، عمَّن حدَّثه- أنه قال لكعب: أخبِرني عن ستِّ آيات في القرآن لم أكن عَلِمْتُهُنَّ، ولا تخبرني عنهنَّ إلا ما تجد في كتاب الله المنزل: ... ما بال أصحاب الرس ذكرهم الله في الكتاب؟ ... قال كعب:... وأمّا أصحاب الرس فإنّهم كانوا قومًا مؤمنين، يعبدون الله في مُلْكِ جَبّارٍ لا يعبد الله، فخيّرهم في أن يكفروا أو يقتلهم، فاختاروا القتل على الكفر، فقتلهم، ثم رمى بهم في قَلِيب، فبذلك سُمُّوا: أصحاب الرس ...{9}. (ز) ٥٤٨٢٠- قال سعيد بن جبير: كان لهم نبيٌّ يُقال له: حنظلة بن صفوان، فقتلوه، فأهلكهم الله تعالى{10}. (ز) ٥٤٨٢١- عن مجاهد بن جبر -من طريق أبي يحيى- قال: <q>﴿الرس﴾</q>: بِئر كان عليها قومٌ يُقال لهم: أصحاب الرس{11}. (١١/١٧٥) ٥٤٨٢٢- عن الضَّحاك بن مُزاحِم -من طريق عبيد- قال: <q>﴿الرس﴾</q>: بِئر قُتِل فيها صاحب «يس»{12}. (١١/١٧٥) ٥٤٨٢٣- عن عكرمة مولى ابن عباس -من طريق سفيان، عن أبي بكير- قال: أصحاب الرسِّ رسُّوا نبيَّهم في بئرٍ{13}. (١١/١٧٥) ٥٤٨٢٤- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قال: أصحاب الرس بفَلْج هم أصحاب يس{14}. (ز) ٥٤٨٢٥- قال الحسن البصري: واد{15}. (ز) ٥٤٨٢٦- عن وهب بن مُنَبِّه، في قوله: <q>﴿وأصحاب الرس﴾</q>، قال: كانوا أهل بئر قعودًا عليها، وأصحاب مواشي، يعبدون الأصنام، فوَجَّه اللهُ إليهم شعيبًا يدعوهم إلى الإسلام، فتَمادَوْا في طغيانهم، وفي أذى شعيب ﵇، فبينما هم حول البئر في منازلهم انهارت البئر، فخسف بهم وبديارهم ورباعهم، فهلكوا جميعًا{16}. (ز) ٥٤٨٢٧- عن قتادة بن دعامة، في قوله: <q>﴿وأصحاب الرس﴾</q>، قال: قوم شعيب{17}. (١١/١٧٥) ٥٤٨٢٨- عن قتادة بن دعامة -من طريق عمرو بن عبد الله- قال: إنّ أصحاب الأيكة وأصحاب الرس كانتا أُمَّتَيْن، فبعث الله إليهما نبيًّا واحدًا؛ شعيبًا، وعذَّبهما بعذابين{18}. (١١/١٧٦) ٥٤٨٢٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأصحاب الرس﴾</q>، قال: حُدِّثنا: أنّ أصحاب الرس كانوا أهل فَلْج باليمامة، وآبار كانوا عليها{19}. (١١/١٧٥) ٥٤٨٣٠- قال إسماعيل السُّدِّيّ: <q>﴿الرس﴾</q>: بئر بأنطاكية، قتلوا فيها حبيبًا النجّار، وهم الذين ذكرهم الله في سورة «يس»{20}. (ز) ٥٤٨٣١- قال محمد بن السائب الكلبي: <q>﴿الرس﴾</q>: بئر بفَلْج اليمامة، قتلوا نبيَّهم، فأهلكهم الله ﷿{21}. (ز) ٥٤٨٣٢- قال مقاتل بن سليمان: <q>﴿وأصحاب الرس﴾</q>، يعني: البئر التي قُتِل فيها صاحب ياسين بأنطاكية التي بالشام{22}. (ز) ٥٤٨٣٣- قال يحيى بن سلّام: <q>﴿وأصحاب الرس﴾</q>، أي: وأهلكنا أصحاب الرس.= (ز) ٥٤٨٣٤- والرس: بئر في قول كعب ... وبلغني: أنّ الذي أُرْسِل إليهم شعيب، وأنه أرسل إلى أهل مدين وإلى أهل الرس جميعًا، ولم يُبعث نبيٌّ إلى أُمَّتين غيره فيما مضى، وبعث النبي إلى الجن والإنس كلهم{3}٤٧٣٠. (ز) ٤٧٣٠ اختُلِف في أصحاب الرس؛ فقال قوم: هم من ثمود. وقال آخرون: بل هي قرية من اليمامة يُقال لها: الفلج. وقال غيرهم: هم قوم رسُّوا نبيَّهم في بئر. وقال آخرون: هي بئر كانت تُسَمّى: الرس. ورجَّح ابنُ جرير (١٧/٤٥٣) مستندًا إلى اللغة القول الأخير الذي قاله ابن عباس مِن طريق العوفي، ومجاهد من طريق ابن يحيى، فقال: «وذلك أنّ الرَّسَّ في كلام العرب: كل محفور؛ مثل: البئر، والقبر، ونحو ذلك». ثم رجَّح (١٧/٤٥٣-٤٥٤) أنّ المراد بأصحاب الرس: أصحاب الأخدود الذين ذُكروا في سورة البروج؛ مستندًا إلى القرآن، فقال: «ولا أعلم قومًا كانت لهم قصة بسبب حُفْرَةٍ ذكرهم الله في كتابه إلا أصحاب الأخدود، فإن يكونوا هم المَعْنِيِّين بقوله: <q>﴿وأصحاب الرس﴾</q> فإنّا سنذكر خبرهم -إن شاء الله- إذا انتهينا إلى سورة البروج، وإن يكونوا غيرهم فلا نعرف لهم خبرًا، إلا ما جاء من جملة الخبر عنهم أنهم قوم رَسُّوا نبيهم في حفرة، إلا ما حدثنا ابن حميد ...» وساق أثر القرظي التالي. ثم علَّق (١٧/٤٥٤) بقوله: «غير أنّ هؤلاء في هذا الخبر يذكر محمد بن كعب عن النبي ﷺ: أنهم آمنوا بنبيهم، واستخرجوه من حفرته. فلا ينبغي أن يكونوا المعنيين بقوله: <q>﴿وأصحاب الرس﴾</q>؛ لأنّ الله أخبر عن أصحاب الرس أنه دمرهم تدميرًا، إلا أن يكونوا دُمِّروا بأحداث أحدثوها بعد نبيهم الذي استخرجوه من الحفرة وآمنوا به، فيكون ذلك وجهًا». <q>﴿وَأَصۡحَـٰبَ ٱلرَّسِّ﴾</q> - آثار متعلقة بالآية ٥٤٨٣٥- عن محمد بن كعب القرظي، قال: قال رسول الله ﷺ: «إنّ أوَّل الناس يدخل الجنة يوم القيامة العبدُ الأسود، وذلك أنّ الله تعالى بعث نبيًّا إلى أهل قريته، فلم يؤمن به من أهلِها أحدٌ إلا ذلك الأسود، ثم إنّ أهل القرية عَدَوْا على النبيِّ، فحفروا له بئرًا، فألقوه فيها، ثم أطْبَقُوا عليه بحجر ضخم، فكان ذلك العبدُ يذهب فيَحْتَطِب على ظهره، ثم يأتي بحطبه فيبيعه، فيشتري به طعامًا وشرابًا، ثم يأتي به إلى تلك البئر، فيرفع تلك الصخرة، فيُعينه الله عليها، فيُدْلِي طعامَه وشرابَه، ثم يرُدُّها كما كانت، فكان كذلك ما شاء الله أن يكون. ثم إنّه ذهب يومًا يحتطب كما كان يصنع، فجمع حطبه، وحزم حزمته، وفرغ منها، فلما أراد أن يحتملها وجد سِنَةً، فاضطجع، فنام، فضُرِب على أُذُنه سبعَ سنين نائمًا، ثم إنّه هَبَّ، فتَمَطّى، فتحول لشِقِّه الآخر، فاضطجع، فضرب الله على أذنه سبع سنين أخرى، ثم إنّه هَبَّ، فاحتمل حزمته، ولا يحسب إلا أنّه نام ساعة من نهار، فجاء إلى القرية، فباع حزمته، ثم اشترى طعامًا وشرابا ًكما كان يصنع، ثم ذهب إلى الحفرة في موضعها التي كانت فيه، فالتمسه، فلم يجده، وقد كان بدا لقومه بداءٌ، فاستخرجوه، فآمنوا به وصدَّقوه، وكان النبيُّ يسألهم عن ذلك الأسود: ما فعل؟ فيقولون له: ما ندري. حتى قُبِض ذلك النبيُّ، فأهَبَّ اللهُ الأسودَ مِن نومته بعد ذلك. إنّ ذلك الأسود لَأول مَن يدخل الجنة»{24}٤٧٣١. (١١/١٧٧) ٤٧٣١ علَّق ابنُ كثير (١٠/٣٠٧) على هذا الأثر بقوله: «هكذا رواه ابن جرير عن ابن حميد، عن سلمة عن ابن إسحاق، عن محمد بن كعب مرسلًا. وفيه غرابة ونكارة، ولعل فيه إدراجًا». ٥٤٨٣٦- عن جعفر بن محمد بن علي: أنّ امرأتين سألتاه: هل تجد غِشيان المرأةِ المرأةَ مُحَرَّمًا في كتاب الله؟ قال: نعم، هُنَّ اللواتي كُنَّ على عهد تُبَّعٍ، وهُنَّ صَواحِبُ الرَّسِّ، وكل نهر وبئرٍ رَسٌّ. قال: يُقْطَع لهن جِلباب مِن نارٍ، ودرع من نارٍ، ونطاق من نارٍ، وتاج مِن نارٍ، وخُفّان مِن نارٍ، ومن فوق ذلك ثوب غليظٌ جافٌّ جلفٌ مُنتِن مِن نارٍ. قال جعفرٌ: علِّموا هذا نساءَكم{25}. (١١/١٧٦) <q>﴿وَقُرُونَۢا﴾</q> - تفسير ٥٤٨٣٧- عن عبد الله بن بسر المازني، قال: وضع النبيُّ ﷺ يدَه على رأسي، وقال: «سيعيش هذا الغلامُ قرنًا». قلت: يا رسول الله، كم القرن؟ قال: «مائة سنة». قال محمد بن القاسم: ما زلنا نَعُدُّ له حتى تَمَّت مائة سنةٍ، ثم مات{26}. (١١/١٧٩) ٥٤٨٣٨- عن أبي الهيثم بن دهر الأسلمي، قال: قال النبيُّ ﷺ: «القرن: خمسون سنة»{27}. (١١/١٧٩) ٥٤٨٣٩- عن أنس، قال: قال رسول الله ﷺ: «أُمَّتي خمس قرون، القرن: أربعون سنة»{27}. (١١/١٧٩) ٥٤٨٤٠- عن حماد، عن إبراهيم، قال: قال رسول الله ﷺ: «القرن: أربعون سنةً»{29}. (١١/١٧٩) ٥٤٨٤١- عن ابن سيرين، قال: قال رسول الله ﷺ: «القرن: أربعون سنةً»{30}. (١١/١٨٠) ٥٤٨٤٢- عن زُرارَة بن أوْفى -من طريق أبي محمد بن عبد الله بن أبي أوفى- قال: القرن: مائةٌ وعشرون عامًا. قال: فبُعِث رسولُ الله ﷺ في قرنٍ، كان آخره العام الذي مات فيه يزيد بن معاوية{31}. (١١/١٧٨) ٥٤٨٤٣- عن جعفر بن علي بن أبي رافع مولى رسول الله ﷺ، قال: خَلَّفْتُ بالمدينة عَمِّي مِمَّن يُفْتِي على أنّ القرن سبعون سنة. وكان عمه عبيد الله بن أبي رافع كاتِب عَلِيٍّ{32}. (ز) ٥٤٨٤٤- قال أبو سلمة: القرن: مائة سنةٍ{27}. (١١/١٧٩) ٥٤٨٤٥- عن إبراهيم النخعي -من طريق الحكم- قال: القرن: أربعون سنة{34}. (ز) ٥٤٨٤٦- عن الحسن البصري -من طريق أبي عبيدة الناجي- قال: القرن: ستون سنة{35}. (١١/١٨٠) ٥٤٨٤٧- عن مالك بن دينار، قال: سألتُ الحسن [البصريَّ] عن القرن؟ فقال: عشرون سنة{35}. (ز) ٥٤٨٤٨- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿وقرونا بين ذلك كثيرًا﴾</q>، قال: كان يُقال: إنّ القرن: سبعون سنةً{37}. (١١/١٧٨) ٥٤٨٤٩- قال مقاتل بن سليمان: <q>﴿وقرونا﴾</q> يعني: وأهلكنا أُمَمًا{2}. (ز) ٥٤٨٥٠- قال يحيى بن سلّام: <q>﴿وقرونا بين ذلك كثيرا﴾</q> أي: وأهلكنا قرونًا؛ أُمَمًا، أمة بعد أمة <q>﴿بين ذلك كثيرا﴾</q>{3}٤٧٣٢. (ز) ٤٧٣٢ اختُلِف في حدّ القرن، ورجَّح ابنُ كثير (١٠/٣٠٨) مستندًا إلى السنة أنّه: الأُمَّة المتعاصرة في الزمن الواحد، فقال: «والأظهر أنّ القرن: هم الأمة المتعاصرون في الزمن الواحد؛ فإذا ذهبوا وخلفهم جيلٌ آخر فهم قرن ثان، كما ثبت في الصحيحين عن رسول الله ﷺ أنه قال: «خير القرون قرني، ثم الذين يلونهم، ثم الذين يلونهم» الحديث». <q>﴿بَیۡنَ ذَ ٰ⁠لِكَ كَثِیرࣰا ۝٣٨﴾</q> - تفسير ٥٤٨٥١- عن أُمِّ سلمة، قالت: سمعتُ النبيَّ ﷺ يقول: «معد بن عدنان بن أُدَد بن زيد بن البراء بن أعراق الثرى». قالت: ثم قرأ رسول الله ﷺ: «أهلك عادًا، وثمودًا، وأصحاب الرس، وقرونًا بين ذلك كثيرًا لا يعلمهم إلا الله». قالت: وأعراق الثرى: إسماعيل، وزيدٌ: هميسعٌ، وبراءٌ: نَبْتٌ{40}. (١١/١٧٨) ٥٤٨٥٢- عن أبي هريرة، قال: قال النبيُّ ﷺ: «كان بين آدم وبين نوح عشرة قرونٍ، وبين نوحٍ وإبراهيم عشرة قرونٍ». قال أبو سلمة: القرن: مائة سنةٍ{41}. (١١/١٧٩) ٥٤٨٥٣- عن عبد الله بن عباس، قال: كان رسول الله ﷺ إذا انتهى إلى معد بن عدنان أمسك، ثم يقول: «كذب النسّابون، قال الله تعالى: <q>﴿وقرونا بين ذلك كثيرًا﴾</q>»{42}. (١١/١٨٠) ٥٤٨٥٤- عن عروة بن الزبير= (ز) ٥٤٨٥٥- وسليمان بن أبي خيثمة -من طريق أبي الأسود- قال: ما وجدنا في شِعْر شاعر ولا في عِلْم عالم أحدًا يعرِف ما وراء معدّ بن عدنان بحقٍّ؛ لأن الله -تبارك وتعالى- يقول: <q>﴿وقرونا بين ذلك كثيرا﴾</q>، وقد اختلفوا فيما بعد عدنان اختلافًا كثيرًا{43}. (ز) ٥٤٨٥٦- قال مقاتل بن سليمان: <q>﴿بين ذلك﴾</q> ما بين عاد إلى أصحاب الرس <q>﴿كثيرا﴾</q>{2}. (ز) ٥٤٨٥٧- عن محمد بن [عمر] الواقدي -من طريق الحسين بن الفرج- قال: يقول الله ﷿: <q>﴿وقرونا بين ذلك كثيرا﴾</q> فكان بين نوح وآدم عشرة قرون، وبين إبراهيم ونوح عشرة قرون، فوُلِد إبراهيم خليل الرحمن على رأس ألفي سنة مِن خلق آدم{45}. (ز) <q>﴿بَیۡنَ ذَ ٰ⁠لِكَ كَثِیرࣰا ۝٣٨﴾</q> - آثار متعلقة بالآية ٥٤٨٥٨- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: كان بين موسى وعيسى- صلى الله عليهما- أربعمائة سنة، وكان بين عيسى وبين محمد -صلى الله عليهما- ستمائة سنة، وبين نوح وآدم -صلى الله عليهما- ألف دار، وبين نوح وإبراهيم -صلى الله عليهما ألف دار-، وبين إبراهيم وبين موسى -صلى الله عليهما وسلم- ألف دار، يعني: ألف دار: ألف سنة{46}. (ز) ٥٤٨٥٩- عن عطاء الخراساني -من طريق ابنه- قال: بين النبيِّ ﷺ وبين آدم تسعة وأربعون أبًا{46}. (ز) ٥٤٨٦٠- عن سليمان بن مهران الأعمش -من طريق سفيان- قال: كان بين موسى وعيسى ألف نبي{46}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها العشرة ما عدا حفصًا، وحمزة، ويعقوب، فإنهم قرؤوا: <q>﴿وثَمُوداْ﴾</q> بغير تنوين. انظر: الإتحاف ص٤١٧.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٢.أخرجه ابن جرير ١٧/٤٥٢.أخرجه ابن أبي حاتم ٨/٢٦٩٥.أخرجه ابن جرير ١٧/٤٥٢.أي: دَسُّوه فيها حتى مات. اللسان (رسس).عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر. وفي تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤: قال كعب: الرس: بئر بأنطاكية، قتلوا فيها حبيبًا النجّار، وهم الذين ذكرهم الله في سورة «يس».أخرجه ابن وهب في الجامع - تفسير القرآن ١/٢٩ (٦٢).تفسير الثعلبي ٧/١٣٤ مطولًا، وتفسير البغوي ٦/٨٤.أخرجه يحيى بن سلام ١/٤٨٢ بنحوه، وابن جرير ١٧/٤٥٣، وابن أبي حاتم ٨/٢٦٩٥. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ٢١/٤١٥.أخرجه ابن جرير ١٧/٤٥٣، وابن أبي حاتم ٨/٢٦٩٥ من طريق سفيان عن رجل. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٧/٤٥٣.علَّقه يحيى بن سلام ١/٤٨٢.تفسير الثعلبي ٧/١٣٣، وتفسير البغوي ٦/٨٤.عزاه السيوطي إلى ابن عساكر.أخرجه ابن وهب في الجامع - تفسير القرآن ١/١٥٢-١٥٣ (٣٥٦)، وابن جرير ٢١/٤١٥.أخرجه ابن أبي حاتم ٨/٢٦٩٥، وابن جرير ١٧/٤٥٢ من طريق جرير بن حازم بنحوه. وعلَّقه يحيى بن سلام ١/٤٨٢. وعزاه السيوطي إلى عبد بن حميد. وفي تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤: بئر بفَلْج اليمامة، قتلوا نبيَّهم، فأهلكهم الله ﷿.تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤.تفسير البغوي ٦/٨٤.تفسير مقاتل بن سليمان ٣/٢٣٥. وفي تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤: عن مقاتل قال: الرس: بئر بأنطاكية، قتلوا فيها حبيبًا النجار، وهم الذين ذكرهم الله في سورة «يس».تفسير يحيى بن سلام ١/٤٨٢.أخرجه ابن الفاخر الأصبهاني في موجبات الجنة ص٢٣٧-٢٣٩ (٣٥٣)، وابن جرير ١٧/٤٥٤-٤٥٥. وأورده الثعلبي ٧/١٣٤-١٣٥. (ب) علَّق ابنُ كثير (١٠/٣٠٧) على هذا الأثر بقوله: «هكذا رواه ابن جرير عن ابن حميد، عن سلمة عن ابن إسحاق، عن محمد بن كعب مرسلًا. وفيه غرابة ونكارة، ولعل فيه إدراجًا».أخرجه ابن أبي الدنيا في ذم الملاهي (١٤٩)، والبيهقي في الشعب (٥٤٦٣)، وابن عساكر ٥٠/٣٢٠.أخرجه أحمد ٢٩/٢٣٥ (١٧٦٨٩)، والحاكم ٢/٥٩٩(٤٠١٦)، ٤/٥٤٥ (٨٥٢٤، ٨٥٢٥) واللفظ له، وابن جرير ١٤/٥٣٤، وابن أبي حاتم ٨/٢٦٩٥ (١٥١٧٧)، ٩/٢٩٨٢ (١٦٩٣٤). وأورده الثعلبي ٦/٩١. قال البوصيري في إتحاف الخيرة المهرة ٧/٢٨٢ (٦٨٥٧): «رواه أحمد بن حنبل بسند صحيح». وقال ابن حجر في إتحاف المهرة ٦/٥٣٦ (١٦١١٩) عَقِب حديث الحاكم: «لم يتكلم عليه، وهو ضعيف جدًّا، ولكن رواه بإسناد أمثل من هذا». وقال الألباني في الضعيفة ٦/٣٤٣ (٢٦٦٠): «وهذا إسناد لا بأس به في الشواهد، رجاله كلهم ثقات معروفون، غير إبراهيم». وقد تقدم عند تفسير قوله تعالى: <q>﴿وكَمْ أهْلَكْنا مِنَ القُرُونِ مِن بَعْدِ نُوحٍ﴾</q> [الإسراء:١٧]، وذكر ابن جرير ١٤/٥٣٤ المسألة عند تلك الآية.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٥٣٥. وأورده الثعلبي ٦/٩١.أخرجه ابن جرير ١٤/٥٤٣، وابن أبي حاتم ٨/٢٦٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٤٥٥.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٧/٤٥٥، وابن أبي حاتم ٨/٢٦٩٦. وسبق ذكره مرفوعًا من طريق حماد.أخرجه ابن أبي حاتم ٨/٢٦٩٦.أخرجه ابن أبي حاتم ٨/٢٦٩٦.أخرجه ابن أبي حاتم ٨/٢٦٩٦. وعلَّقه يحيى بن سلام ١/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٢.أخرجه الحاكم ٢/٤٣٧ (٣٥١٩)، ٢/٥٠٤ (٣٧٢٩). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه العقيلي في الضعفاء ٤/٢٩٨، من طريق نصر بن عاصم الأنطاكي، قال: حدثنا الوليد بن مسلم، قال: حدثنا أبو عمرو، عن محمد بن أبي كثير، عن أبي سلمة، عن أبي هريرة به. وعزاه السيوطي إلى ابن مردويه. قال العقيلي: «نصر بن عاصم عن الوليد .. لا يُتابَع عليه، ولا يُعرف إلا به». ثم أسند له الحديث السابق، وقال الذهبي في ميزان الاعتدال ٤/٢٥٢: «نصر بن عاصم مُحَدِّث دجّال».أخرجه ابن سعد في الطبقات ١/٥٦، وابن عساكر في تاريخ دمشق ٣/٥٢، ٥٩-٦٠. قال المناوي في التيسير ٢/٢٤١: «إسناد ضعيف». وقال الألباني في الضعيفة ١/٢٢٨ (١١١): «موضوع».أخرجه ابن عساكر ٣/٥٢، وأخرجه ابن أبي حاتم ٨/٢٦٩٧ عن عروة دون ذكر الآية.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن عساكر في تاريخ دمشق ٦/١٧٢، وفيه عن محمد بن محمد الواقدي، وهو تحريف.أخرجه ابن أبي حاتم ٨/٢٦٩٧.أخرجه ابن أبي حاتم ٨/٢٦٩٧.أخرجه ابن أبي حاتم ٨/٢٦٩٧.
25,39," <q>﴿وَكُلࣰّا ضَرَبۡنَا لَهُ ٱلۡأَمۡثَـٰلَۖ﴾</q> - تفسير ٥٤٨٦١- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿وكلا ضربنا له الامثال وكلا تبرنا تتبيرا﴾</q>، قال: كل قد أعذر اللهُ إليه، وبيَّن له، ثم انتقم منه{1}. (١١/١٨٠) ٥٤٨٦٢- قال يحيى بن سلّام: <q>﴿وكلا﴾</q> يعني: مَن ذُكِر مِمَّن مضى <q>﴿ضربنا له الأمثال﴾</q> أي: خوَّفناهم{2}. (ز) <q>﴿وَكُلࣰّا تَبَّرۡنَا تَتۡبِیرࣰا ۝٣٩﴾</q> - تفسير ٥٤٨٦٣- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿تبرنا تتبيرا﴾</q>، قال: تبَّره: إذا أراد كسر الشيء. قال: تبَّره بالنبطية{3}. (ز) (١١/١٨١) ٥٤٨٦٤- عن الحسن البصري -من طريق معمر- في قوله: <q>﴿وكلا تبرنا تتبيرا﴾</q>، قال: تَبَّرَ الله كُلًّا بالعذاب{4}. (١١/١٨٠) ٥٤٨٦٥- قال مقاتل بن سليمان: <q>﴿وكلا ضربنا له الأمثال وكلا تبرنا تتبيرا﴾</q>، وكلًّا دمَّرنا بالعذاب تدميرًا{5}. (ز) ٥٤٨٦٦- قال عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿وكلا تبرنا تتبيرا﴾</q>، قال: بالعذاب{6}. (ز) ٥٤٨٦٧- عن أصبغ، قال: سمعت عبد الرحمن بن زيد بن أسلم في قوله: <q>﴿وكلًا تبرنا تتبيرًا﴾</q>، قال: أضللنا الذين أضلهم، لم ينتفعوا من دينهم بشيء{7}. (ز) ٥٤٨٦٨- قال يحيى بن سلّام: <q>﴿وكلا تبرنا تتبيرا﴾</q> أفسدنا فسادًا، يعني: إهلاكه الأمم السالفة بتكذيبها رسلها{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦، وابن أبي حاتم ٨/٢٦٩٧ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ١/٤٨٢.أخرجه إسحاق البستي في تفسيره ص٥٠٨، وأخرج آخره ابن جرير ١٧/٤٥٦. وكذا عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦، وابن أبي حاتم ٨/٢٦٩٧.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٧.أخرجه ابن أبي حاتم ٨/٢٦٩٧.تفسير يحيى بن سلام ١/٤٨٢.
25,40," <q>﴿وَلَقَدۡ أَتَوۡا۟ عَلَى ٱلۡقَرۡیَةِ ٱلَّتِیۤ أُمۡطِرَتۡ مَطَرَ ٱلسَّوۡءِۚ﴾</q> - تفسير ٥٤٨٦٩- عن عبد الله بن عباس، في قوله: <q>﴿ولقد أتو على القرية﴾</q> قال: هي سدوم، قرية قوم لوطٍ، <q>﴿التي أمطرت مطر السوء﴾</q> قال: الحجارة{1}. (١١/١٨١) ٥٤٨٧٠- عن الحسن البصري -من طريق أبي رجاء- <q>﴿ولقد أتوا على القرية﴾</q>، قال: هي بين الشام والمدينة{2}. (١١/١٨١) ٥٤٨٧١- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿ولقد أتوا على القربة التي أمطرت مطر السوء﴾</q>، قال: قرية لوط{3}. (١١/١٨٠) ٥٤٨٧٢- عن عطاء الخراساني -من طريق ابنه عثمان- <q>﴿ولقد أتوا على القرية﴾</q>، قال: قرية لُوطٍ{4}. (١١/١٨١) ٥٤٨٧٣- قال مقاتل بن سليمان: <q>﴿ولقد أتوا على القرية التي أمطرت﴾</q> بالحجارة <q>﴿مطر السوء﴾</q> يعني: قرية لوط ﵇، كلُّ حجر في العِظَم على قدر كلِّ إنسان{5}. (ز) ٥٤٨٧٤- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿ولقد أتوا على القرية التي أمطرت مطر السوء﴾</q>، قال: حجارة، وهي قرية قوم لوط، واسمها: سَدُوم.= (ز) ٥٤٨٧٥- قال ابن عباس: خمس قريات؛ فأهلك الله أربعة، وبقيت الخامسة، واسمها: صعوة. لم تهلك صعوة، كان أهلُها لا يعملون ذلك العمل، وكانت سدوم أعظمها، وهي التي نزل بها لوط، ومنها بُعِث. وكان إبراهيم ﷺ يُنادي نصيحةً لهم: يا سدوم، يوم لك مِن الله، أنهاكم أن تَعَرَّضوا لعقوبة الله. زعموا: أنّ لوطًا ابنُ أخي إبراهيم -صلوات الله عليهما-{6}. (ز) ٥٤٨٧٦- قال يحيى بن سلّام: قوله: <q>﴿ولقد أتوا﴾</q> يعني: مشركي العرب ... و<q>﴿مطر السوء﴾</q>: الحجارة التي رُمُوا بها من السماء؛ رُمي بها مَن كان خارجًا مِن المدينة، وأهل السفر منهم{7}. (ز) <q>﴿أَفَلَمۡ یَكُونُوا۟ یَرَوۡنَهَاۚ﴾</q> - تفسير ٥٤٨٧٧- قال مقاتل بن سليمان: <q>﴿أفلم يكونوا يرونها﴾</q> فيعتبروا{5}. (ز) ٥٤٨٧٨- قال يحيى بن سلّام: <q>﴿أفلم يكونوا يرونها﴾</q> فيتفكروا، ويحذروا أن ينزل بهم ما نزل بهم، أي: بلى، قد أتوا عليها ورأوها. مثل قوله: <q>﴿وإنكم لتمرون عليهم مصبحين (١٣٧) وبالليل أفلا تعقلون (١٣٨)﴾</q> [الصافات:١٣٧-١٣٨]{7}. (ز) <q>﴿بَلۡ كَانُوا۟ لَا یَرۡجُونَ نُشُورࣰا ۝٤٠﴾</q> - تفسير ٥٤٨٧٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿لا يرجون﴾</q>: أي: لا يخافون{2}. (ز) ٥٤٨٨٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿بل كانوا لا يرجون نشورا﴾</q>، قال: بَعْثًا، ولا حِسابًا{11}. (١١/١٨٠) ٥٤٨٨١- قال مقاتل بن سليمان: <q>﴿بل كانوا لا يرجون نشورا﴾</q>، يقول ﷿: بل كانوا لا يخشون بَعْثًا. نظيرها في تبارك الملك [١٥]: <q>﴿وإليه النشور﴾</q>، يعني: الإحياء{5}. (ز) ٥٤٨٨٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿لا يرجون نشورا﴾</q>، قال: بَعْثًا{13}. (١١/١٨١) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٩٨.أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦. وعلَّقه يحيى بن سلام ١/٤٨٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٩٨. وقد نسبه السيوطي إلى عطاء مُهمَلًا دون تمييز، وعزاه إلى ابن أبي حاتم، وعند ابن أبي حاتم عن عثمان بن عطاء، عن أبيه.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٧.تفسير يحيى بن سلام ١/٤٨٢.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٢.أخرجه ابن أبي حاتم ٨/٢٦٩٨.أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦، وابن أبي حاتم ٨/٢٦٩٨ من طريق سعيد. وعلَّقه يحيى بن سلام ١/٤٨٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٨. وعزاه السيوطي إلى ابن المنذر.
25,41," <q>﴿وَإِذَا رَأَوۡكَ إِن یَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَـٰذَا ٱلَّذِی بَعَثَ ٱللَّهُ رَسُولًا ۝٤١﴾</q> - نزول الآية ٥٤٨٨٣- قال مقاتل بن سليمان: <q>﴿وإذا رأوك إن يتخذونك إلا هزوا أهذا الذي بعث الله رسولا﴾</q> نزلت في أبي جهل -لعنه الله-{1}. (ز) <q>﴿وَإِذَا رَأَوۡكَ إِن یَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَـٰذَا ٱلَّذِی بَعَثَ ٱللَّهُ رَسُولًا ۝٤١﴾</q> - تفسير الآية ٥٤٨٨٤- قال مقاتل بن سليمان: <q>﴿وإذا رأوك﴾</q> يعني: النبيَّ ﷺ <q>﴿إن يتخذونك إلا هزوا أهذا الذي بعث الله رسولا﴾</q> ﷺ{2}. (ز) ٥٤٨٨٥- قال يحيى بن سلّام: <q>﴿وإذا رأوك﴾</q> يعني: الذين كفروا <q>﴿إن يتخذونك إلا هزوا أهذا الذي بعث الله رسولا﴾</q> فيما يزعم. يقوله بعضُهم لبعض{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٣٥. وأخرج ابن أبي حاتم ٨/٢٦٩٨ عند هذه الآية عن محمد بن إسحاق من طريق سلمة: قال أبو جهل يومًا وهو يهزأ برسول الله ﷺ، وبما جاء به من الحق: يا معشر قريش، يزعم محمدٌ أنّ جنود الله الذين يعذبونكم في النار ويحبسونكم فيها تسعة عشر، وأنتم أكثر الناس عددًا وكثرة، أفيعجزكم مائة رجل منكم عن رجل منهم؟! فأنزل الله ﷿ في ذلك مِن قوله: <q>﴿وما جعلنا أصحاب النار إلا ملائكة وما جعلنا عدتهم إلا فتنة للذين كفروا﴾</q> [المدثر:٣١] إلى آخر القصة.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٣.
25,42," <q>﴿إِن كَادَ لَیُضِلُّنَا عَنۡ ءَالِهَتِنَا لَوۡلَاۤ أَن صَبَرۡنَا عَلَیۡهَاۚ﴾</q> - تفسير ٥٤٨٨٦- قال مقاتل بن سليمان: ثم قال أبو جهل: <q>﴿إن كاد ليضلنا عن آلهتنا﴾</q> يعني: لِيَسْتَزِلَّنا عن عبادة آلهتنا، <q>﴿لولا أن صبرنا﴾</q> يعني: تَثَبَّتنا <q>﴿عليها﴾</q>، يعني: على عبادتها؛ ليدخلنا في دينه{1}. (ز) ٥٤٨٨٧- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿لولا ان صبرنا عليها﴾</q>، قال: ثَبَتْنا{2}. (١١/١٨١) ٥٤٨٨٨- قال يحيى بن سلّام: <q>﴿إن كاد ليضلنا عن آلهتنا﴾</q> يعنون: أوثانهم، <q>﴿لولا أن صبرنا عليها﴾</q> على عبادتها{3}. (ز) <q>﴿وَسَوۡفَ یَعۡلَمُونَ حِینَ یَرَوۡنَ ٱلۡعَذَابَ مَنۡ أَضَلُّ سَبِیلًا ۝٤٢﴾</q> - تفسير ٥٤٨٨٩- عن الحسن البصري -من طريق إسماعيل بن مسلم- <q>﴿وسوف يعلمون﴾</q>، قال: وعيد{4}. (ز) ٥٤٨٩٠- قال مقاتل بن سليمان: يقول الله -تبارك وتعالى-: <q>﴿وسوف يعلمون حين يرون العذاب في الآخرة من أضل سبيلا﴾</q>، يعني: مَن أخطأ طريق الهُدى، أهم أم المؤمنون؟{1}. (ز) ٥٤٨٩١- قال يحيى بن سلّام: قال الله: <q>﴿وسوف يعلمون حين يرون العذاب﴾</q> في الآخرة <q>﴿من أضل سبيلا﴾</q> أي: مَن كان أضل سبيلًا في الدنيا. أي: فسوف يعلمون أنّهم كانوا أضلَّ سبيلًا مِن محمد{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٩. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٤٨٣.أخرجه ابن أبي حاتم ٨/٢٦٩٩.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٣.
25,43," <q>﴿أَرَءَیۡتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾</q> - نزول الآية ٥٤٨٩٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿أرأيت من اتخذ الهه هواه﴾</q>، قال: كان الرجل يعبد الحجرَ الأبيض زمانًا مِن الدهر في الجاهلية، فإذا وجد حَجَرًا أحسنَ منه رمى به وعبد الآخر؛ فأنزل الله الآية{1}. (١١/١٨٢) ٥٤٨٩٣- عن أبي رجاء العطاردي، قال: كانوا في الجاهلية يأكلون الدم بالعِلْهِز{2}، ويعبدون الحجر، فإذا وجدوا ما هو أحسنُ منه رَمَوْا به، وعبدوا الآخر، فإذا فقدوا الآخرَ أمروا مُناديًا، فنادى: أيها الناس، إنّ إلهكم قد ضَلَّ، فالتَمِسُوه. فأنزل الله هذه الآية: <q>﴿أرأيت من اتخذ الهه هواه﴾</q>{3}. (١١/١٨٢) ٥٤٨٩٤- قال مقاتل بن سليمان: نزلت <q>﴿أرأيت من اتخذ إلهه هواه﴾</q> وذلك أنّ الحارث بن قيس السهمي هوى شيئًا، فعبده{4}. (ز) <q>﴿أَرَءَیۡتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾</q> - تفسير الآية ٥٤٨٩٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أرأيت من اتخذ إلهه هواه﴾</q>، قال: ذاك الكافر، اتخذ دينه بغير هُدًى مِن الله، ولا بُرهانٍ{5}. (١١/١٨٢) ٥٤٨٩٦- عن سعيد بن جبير -من طريق جعفر- في قوله تعالى: <q>﴿أرأيت من اتخذ إلهه هواه﴾</q>، قال: كان أهل الجاهلية يعبدون الحجر، فإذا رأوا حجرًا أحسن منه أخذوه، وتركوا الأول{6}. (ز) ٥٤٨٩٧- عن الحسن البصري -من طريق مبارك- <q>﴿أرأيت من اتخذ الهه هواه﴾</q>، قال: لا يهوى شيئًا إلا تَبِعَه{7}. (١١/١٨٢) ٥٤٨٩٨- عن الحسن البصري أنّه قيل له: في أهل القبلة شِرْكٌ؟! فقال: نعم، إنّ المنافق مُشْرِكٌ؛ إن المشرك يسجد للشمس والقمر من دون الله، وإنّ المنافق عبد هواه. ثم تلا هذه الآية: <q>﴿أرأيت من اتخذ الهه هواه أفأنت تكون عليه وكيلا﴾</q>{8}. (١١/١٨٣) ٥٤٨٩٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أرأيت من اتخذ الهه هواه﴾</q>، قال: كُلَّما هوي شيئًا ركبه، وكلَّما اشتهى شيئًا أتاه، لا يحجزه عن ذلك ورَعٌ ولا تقوى{9}. (١١/١٨٢) ٥٤٩٠٠- قال يحيى بن سلّام: قوله: <q>﴿اتخذ إلهه هواه﴾</q>، يعني: المشرك{10}. (ز) <q>﴿أَرَءَیۡتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾</q> - آثار متعلقة بالآية ٥٤٩٠١- عن أبي أُمامة، قال: قال رسول الله ﷺ: «ما تحت ظِلِّ السماء مِن إله يُعبد مِن دون الله أعظم عند الله مِن هَوًى مُتَّبَع»{11}. (١١/١٨٣) <q>﴿أَفَأَنتَ تَكُونُ عَلَیۡهِ وَكِیلًا ۝٤٣﴾</q> - تفسير ٥٤٩٠٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وكيلا﴾</q>، قال: ناصرًا{12}. (ز) ٥٤٩٠٣- قال إسماعيل السُّدِّيّ: <q>﴿وكيلا﴾</q>، يعني: مُسَيْطِرًا{13}. (ز) ٥٤٩٠٤- قال مقاتل بن سليمان: <q>﴿أفأنت﴾</q> يا محمد <q>﴿تكون عليه وكيلا﴾</q> يعني: مُسَيْطِرًا، يقول: تريد أن تُبَدِّل المشيئة إلى الهُدى والضلالة{4}. (ز) ٥٤٩٠٥- قال يحيى بن سلّام: قوله: <q>﴿أفأنت تكون عليه﴾</q> على الذي اتخذ إلهه هواه <q>﴿وكيلا﴾</q> حفيظًا، تحفظ عليه عملَه حتى تجازيه به؟! أي: إنّك لست بربٍّ، إنما أنت نذير{10}. (ز) <q>﴿أَفَأَنتَ تَكُونُ عَلَیۡهِ وَكِیلًا ۝٤٣﴾</q> - النسخ في الآية ٥٤٩٠٦- قال محمد بن السائب الكلبي، في قوله: <q>﴿أفأنت تكون عليه وكيلا﴾</q>: نسختها آية القتال{16}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٤٩١ (٣٦٨٩)، وابن أبي حاتم ٨/٢٦٩٩ (١٥١٩٩) واللفظ له. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».العِلْهِز: هو شئ يتخذونه في سِنِي المجاعة، يخلطون الدم بأوبار الإبل، ثم يشوونه بالنار، ويأكلونه. النهاية (علهز).عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن أبي حاتم ٨/٢٧٠٠. وعزاه السيوطي إلى ابن المنذر.أخرجه أبو نعيم في حلية الأولياء ٤/٢٨٨. وعلَّقه ابن أبي حاتم ٨/٢٦٩٩.أخرجه ابن أبي حاتم ٨/٢٧٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه يحيى بن سلام ١/٤٨٣ من طريق المبارك بن فضالة بلفظ: هو المنافق يصيب هواه، كلما هوي شيئًا فعله، وابن أبي حاتم ٨/٢٧٠٠ من طريق المبارك بلفظ: ذلك المنافق نصب هواه فما هوي من شيء ركبه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٧٠٠. وعزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ١/٤٨٣.أخرجه ابن أبي عاصم في السنة ١/٨ (٣)، والطبراني في الكبير ٨/١٠٣ (٧٥٠٢). قال ابن عدي في الكامل ٣/١٢٦: «هذا إن كان البلاء فيه مِن الحسن، وإلا من الخصيب بن جحدر، ولعله أضعف منه». وقال ابن الجوزي في الموضوعات ٣/١٣٩: «هذا حديث موضوع على رسول الله ﷺ، وفيه جماعة ضعاف، والحسن بن دينار والخصيب كذّابان عند علماء النقل». وقال الهيثمي في المجمع ١/١٨٨ (٨٩٥): «رواه الطبراني في الكبير، وفيه الحسن بن دينار، وهو متروك الحديث». وقال السيوطي في اللآلئ المصنوعة ٢/٢٧٢، والشوكاني في الفوائد المجموعة ص٢٣٩ (٦٧)، والألباني في الضعيفة ١٤/٩٠ (٦٥٣٨): «موضوع».أخرجه ابن أبي حاتم ٨/٢٧٠٠. وأورده عند تفسير قوله تعالى: <q>﴿ثُمَّ لا تَجِدُوا لَكُمْ وكِيلًا﴾</q> [الإسراء:٦٨] بلفظ: منعةً ولا ناصرًا -كما عزاه السيوطي-.علَّقه يحيى بن سلام ١/٤٨٣.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٣.تفسير البغوي ٦/٨٦.
