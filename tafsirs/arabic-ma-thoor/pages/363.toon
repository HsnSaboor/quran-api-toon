quran[11]{c,v,t}:
  25,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا یَأۡتُونَكَ بِمَثَلٍ إِلَّا جِئۡنَـٰكَ بِٱلۡحَقِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿ولا يأتونك بمثل إلا جئناك﴾</span>، قال: أي: ينزل به جبريلُ، كُلَّما أُتِيَ بمَثَلٍ يلتمس عَيْبَه نزل به كتابُ اللهِ ناطِقٌ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿ولا يأتونك بمثل﴾</span>، يقول: لو أنزلنا عليكَ القرآنَ جملة واحدة ثم سألوك لم يكن عندك ما تجيب، ولكِنّا نُمْسِك عليك، فإذا سألوك أجبتَ{2}. (١١/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: قالت قريش: ما لِلقرآن لم ينزل على النبيِّ جملةً واحدةً؟ قال الله في كتابه: <span class="qpc-hafs">﴿وقال الذين كفروا لولا نزل عليه القرآن جملة واحدة كذلك لنثبت به فؤادك ورتلناه ترتيلا﴾</span>. قال: قليلًا قليلًا؛ كيما لا يَجِيئوك بمَثَلٍ إلا أتيناك بما ينقض عليهم، فأنزلناه عليك تنزيلًا قليلًا قليلًا، كلَّما جاؤوا بشيء جئناهم بما هو أحسن منه تفسيرًا{3}. (١١/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿ولا يأتونك بمثل﴾</span> يُخاصِمُونك به، إضمار لقولهم: <span class="qpc-hafs">﴿لولا نزل عليه القرآن جملة واحدة﴾</span> ونحوه في القرآن مِمّا يُخاصِمون به النبيَّ ﷺ، فيرُدُّ الله ﷿ عليهم قولَهم، فذلك قوله ﷿: <span class="qpc-hafs">﴿إلا جئناك بالحق﴾</span> فيما تخصمهم به{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿ولا يأتونك بمثل إلا جئناك بالحق﴾</span>، قال: لا يأتيك الكُفّار بمَثَل إلا جئناك بما تَرُدُّ به ما جاءوك به مِن الأمثال التي جاءوا بها{5}. (١١/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا يأتونك بمثل﴾</span>، يعني: المشركين فيما كانوا يُحاجُّونه به{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَحۡسَنَ تَفۡسِیرًا ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ولا يأتونك بمثل إلا جئناك بالحق وأحسن تفسيرا﴾</span>، يقول: أحسن تَفْصِيلًا{7}. (١١/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وأحسن تفسيرا﴾</span>، قال: بَيانًا{8}. (١١/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وأحسن تفسيرا﴾</span>، قال: تفصيلًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿ولا يأتونك بمثل إلا جئناك بالحق وأحسن تفسيرا﴾</span>، قال: أحسن تَفْصِيلًا{10}. (١١/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- في قوله: <span class="qpc-hafs">﴿وأحسن تفسيرا﴾</span>، قال: تفصيلًا{11}. (١١/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحسن تفسيرا﴾</span>، يعني: وأحسن تبيانًا، فتَرُدُّ به خصومتَهم{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩١.أخرجه ابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٣٤.أخرجه ابن جرير ١٧/٤٤٥. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٤٨٠.أخرجه ابن جرير ١٧/٤٤٥. وعلَّقه ابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلام ١/٤٨٠ من طريق عاصم بن حكيم، وابن جرير ١٧/٤٤٨، وابن أبي حاتم ٨/٢٦٩٢.أخرجه ابن جرير ١٧/٤٤٨. وعلَّقه ابن أبي حاتم ٨/٢٦٩١.علَّقه يحيى بن سلام ١/٤٨٠، وابن أبي حاتم ٨/٢٦٩١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٩١. وقد نسبه السيوطي إلى عطاء مهملًا دون تمييز، وعزاه إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٢٣٤.
  25,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یُحۡشَرُونَ عَلَىٰ وُجُوهِهِمۡ إِلَىٰ جَهَنَّمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٧٧<span class="dash">-</span></span> عن قتادة، حدَّثنا أنس بن مالك: أنّ رجلًا قال: يا نبيَّ اللهِ، يُحْشَر الكافِر على وجهه يوم القيامة؟! قال: «<b>أليس الذي أمشاه على الرِّجلين في الدنيا قادِرًا على أن يُمْشِيه على وجهه يوم القيامة؟</b>». قال قتادة: بلى، وعِزَّة ربِّنا{1}. (٩/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٨<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي خالد- قال: يُحْشَر الناسُ يوم القيامة على ثلاثة أصناف: صنف على الدواب، وصِنف على أقدامهم، وصِنف على وجوههم. فقيل: كيف يمشون على وجوههم؟! قال: إنّ الذي أمشاهم على أقدامهم قادِرٌ أن يمشيهم على وجوههم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿الذين يحشرون على وجوههم إلى جهنم﴾</span>، قال: الذي أمشاهم على أرجلهم قادِرٌ على أن يمشيهم على وجوههم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر الله ﷿ بمُسْتَقَرِّهم في الآخرة، فقال سبحانه: <span class="qpc-hafs">﴿الذين يحشرون على وجوههم إلى جهنم أولئك شر مكانا وأضل سبيلا﴾</span>{4}<span class=comment-ref>٤٧٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٢٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٤٣٨) أنّ الجمهور على أنّ هذا المشي على الوجوه حقيقة. ونقل عن فِرقة أنها قالت بأنّه استعارة للذلة المفرطة، والهوان، والخزي.</div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یُحۡشَرُونَ عَلَىٰ وُجُوهِهِمۡ إِلَىٰ جَهَنَّمَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: لَمّا سير عامر بن عبد قيس إلى الشام، قال: الحمد لله الذي حشرني راكبًا. قال <span class="name-2">الحسن</span>: قد -واللهِ- علم عامِرٌ أنّ قومًا يُحْشَرون على وجوههم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ شَرࣱّ مَّكَانࣰا وَأَضَلُّ سَبِیلࣰا ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٨٢<span class="dash">-</span></span> عن قتادة -من طريق سعيد بن بشير-: ذُكِر لنا: أنّ رجلًا قال: يا نبيَّ الله، كيف يُحْشَر الكافر على وجهه يوم القيامة؟! قال نبيُّ الله ﷺ: «<b>أليس الذي أمشاه على رِجليه قادر على أن يمشيه على وجهه. قال الله ﷿</b>: <span class="qpc-hafs">﴿أولئك شر مكانا وأضل سبيلا﴾</span>»{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي روق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿وأضل سبيلًا﴾</span>، يقول: وأبعد حُجَّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿أولئك شر مكانا﴾</span> يقول: مِن أهل الجنة، <span class="qpc-hafs">﴿وأضل سبيلا﴾</span> قال: طريقًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال سبحانه: <span class="qpc-hafs">﴿أولئك شر مكانا وأضل سبيلا﴾</span>، يعني: وأخطأ طريق الهدى في الدنيا مِن المؤمنين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله <span class="qpc-hafs">﴿أولئك شر مكانا﴾</span> يقول: مِن أهل الجنة، <span class="qpc-hafs">﴿وأضل سبيلا﴾</span> قال: طريقًا{10}. (١١/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿الذين يحشرون على وجوههم إلى جهنم أولئك شر مكانا﴾</span> مِن أهل الجنة، <span class="qpc-hafs">﴿وأضل سبيلا﴾</span> طريقًا في الدنيا؛ لأنّ طريقهم إلى النار، وطريق المؤمنين إلى الجنة{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٦/١٠٩ (٤٧٦٠)، ٨/١٠٩ (٦٥٢٣)، ومسلم ٤/٢١٦١ (٢٨٠٦)، وابن جرير ١٧/٤٤٩، وابن أبي حاتم ٨/٢٦٩٢ (١٥١٤٤) كلاهما دون قول قتادة، وأخرجه يحيى بن سلام ١/٢٤٤، ٤٨١ مرسلًا.أخرجه ابن جرير ١٧/٤٥٠. وتقدم مرفوعًا عند تفسير قوله تعالى: <span class="qpc-hafs">﴿ونَحْشُرُهُمْ يَوْمَ القِيامَةِ عَلى وُجُوهِهِمْ عُمْيًا وبُكْمًا وصُمًّا﴾</span> [الإسراء:٩٧]، كما تقدمت عندها أحاديث وآثار أخرى.أخرجه ابن جرير ١٧/٤٤٩.تفسير مقاتل بن سليمان ٣/٢٣٤.أخرجه ابن أبي حاتم ٨/٢٦٩٢.أخرجه ابن أبي حاتم ٨/٢٦٩٢ (١٥١٤٧).أخرجه ابن أبي حاتم ٨/٢٦٩٢.أخرجه ابن جرير ١٧/٤٤٩.تفسير مقاتل بن سليمان ٣/٢٣٤.عزاه السيوطي إلى ابن جرير، وابن المنذر. وهو عند ابن جرير من رواية ابن جريج عن مجاهد كما تقدم.تفسير يحيى بن سلام ١/٤٨١.
  25,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿الكتاب﴾</span>، قال: التوراة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٨٩<span class="dash">-</span></span> عن <span class="name-2">زِياد بن أبي مريم</span> -من طريق خُصَيْف- قوله: <span class="qpc-hafs">﴿آتينا﴾</span>، قال: أعْطَيْنا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب﴾</span>، يقول: أعطينا موسى ﵇ التوراةَ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب﴾</span> التوراة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: أُوتِي رسولُ الله ﷺ سبعًا مِن المثاني الطوال، وأُوتي موسى سِتًّا مِن المثاني{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا مَعَهُۥۤ أَخَاهُ هَـٰرُونَ وَزِیرࣰا ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وجعلنا معه أخاه هرون وزبرا﴾</span>، قال: عَوْنًا، وعَضُدًا{6}. (١١/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩٤<span class="dash">-</span></span> قال يحيى بن سلّام: <span class="qpc-hafs">﴿وجعلنا معه أخاه هارون وزيرا﴾</span> أي: عَوِينًا وعضُدًا في تفسير <span class="name-2">قتادة</span>.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩٥<span class="dash">-</span></span> وتفسير <span class="name-2">الحسن</span>: شريكًا في الرسالة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهو واحد، وذلك قبل أن تنزل عليهما التوراة، ثم نزلت عليهما بعد، فقال: <span class="qpc-hafs">﴿ولقد آتينا موسى وهارون الفرقان﴾</span> التوراة. وفرقانها: حلالها وحرامها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلنا معه أخاه هارون وزيرا﴾</span> يعني: مُعِينًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩٣.أخرجه ابن أبي حاتم ٨/٢٦٩٢.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٣، ٩/٢٩٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٣. وعلَّقه يحيى بن سلام ١/٤٨١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير يحيى بن سلام ١/٤٨١.تفسير مقاتل بن سليمان ٣/٢٣٤.
  25,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقُلۡنَا ٱذۡهَبَاۤ إِلَى ٱلۡقَوۡمِ ٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٧٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿بآياتنا﴾</span>: بالبينات{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٧٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم انقطع الكلام، فأخبر اللهُ ﷿ [محمدًا] ﷺ، فقال سبحانه: <span class="qpc-hafs">﴿فقلنا اذهبا إلى القوم﴾</span> يعني: أهل مصر <span class="qpc-hafs">﴿الذين كذبوا بآياتنا﴾</span> يعني: الآيات التِّسع{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فقلنا اذهبا إلى القوم الذين كذبوا بآياتنا﴾</span>، يعني: فرعون وقومه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَدَمَّرۡنَـٰهُمۡ تَدۡمِیرࣰا ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فدمرناهم تدميرا﴾</span>، قال: أهلكناهم بالعذاب{1}. (١١/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- في قوله: <span class="qpc-hafs">﴿فدمرناهم تدميرًا﴾</span>، يقول: تبَّرناهم تتبيرًا، يقول: قَطَّعَ الله أنواع العذاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فدمرناهم تدميرا﴾</span>، يعني: أهلكناهم بالعذاب هلاكًا، يعني: الغَرَق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فقلنا اذهبا إلى القوم الذين كذبوا بآياتنا﴾</span> يعني: فرعون وقومه، <span class="qpc-hafs">﴿فدمرناهم تدميرا﴾</span> أي: فكذبوهما، <span class="qpc-hafs">﴿فدمرناهم تدميرا﴾</span> يعني: الغرق الذي أهلكهم به. كقوله: <span class="qpc-hafs">﴿فكذبوهما فكانوا من المهلكين﴾</span> [المؤمنون:٤٨]، مِن المُعَذَّبين بالغرق في الدنيا، ولهم النار في الآخرة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩٣.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٣.علَّقه ابن أبي حاتم ٨/٢٦٩٣.أخرجه ابن أبي حاتم ٨/٢٦٩٣.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.
  25,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَوۡمَ نُوحࣲ لَّمَّا كَذَّبُوا۟ ٱلرُّسُلَ أَغۡرَقۡنَـٰهُمۡ وَجَعَلۡنَـٰهُمۡ لِلنَّاسِ ءَایَةࣰۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٠٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- يعني: قوله: <span class="qpc-hafs">﴿للناس آية﴾</span>، يقول: عِبْرَة، ومُتَفَكَّر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقوم نوح لما﴾</span> يعني: حين <span class="qpc-hafs">﴿كذبوا الرسل﴾</span> يعني: نوحًا وحده؛ <span class="qpc-hafs">﴿أغرقناهم وجعلناهم للناس آية﴾</span> يعني: عِبْرَة لِمَن بعدهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقوم نوح﴾</span> أي: وأهلكنا قوم نوح أيضًا بالغرق؛ <span class="qpc-hafs">﴿لما كذبوا الرسل﴾</span> يعني: نوحًا. قال: <span class="qpc-hafs">﴿أغرقناهم وجعلناهم للناس آية﴾</span> لِمَن بعدهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعۡتَدۡنَا لِلظَّـٰلِمِینَ عَذَابًا أَلِیمࣰا ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- <span class="qpc-hafs">﴿واعتدنا للظالمين﴾</span> يقول: للكافرين <span class="qpc-hafs">﴿عذابًا اليمًا﴾</span> قال: العذاب: النَّكال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأعتدنا للظالمين عذابا أليما﴾</span>، يعني: وجيعًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأعتدنا للظالمين﴾</span> المشركين، يعنيهم <span class="qpc-hafs">﴿عذابا أليما﴾</span> مُوجِعًا في الآخرة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٩٤.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.أخرجه ابن أبي حاتم ٨/٢٦٩٤.تفسير مقاتل بن سليمان ٣/٢٣٤.تفسير يحيى بن سلام ١/٤٨١.
  25,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَادࣰا وَثَمُودَا۟﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٤٨١٢<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: ‹وعادًا وثَمُودًا› يُنَون ثمود{1}. (١١/١٧٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَادࣰا وَثَمُودَا۟﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال تعالى: <span class="qpc-hafs">﴿و﴾</span>أهلكنا <span class="qpc-hafs">﴿عادا وثمود﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وعادا وثمود﴾</span>، أي: وأهلكنا عادًا وثمود، تبعًا للكلام الأول{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَصۡحَـٰبَ ٱلرَّسِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- قال: الرس: قريةٌ مِن ثمود{4}. (١١/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: الرس: بئر بأذربيجان{5}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>، قال: هي بئر كانت تُسَمّى: الرس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١٨<span class="dash">-</span></span> عن ابن عباس، أنّه سأل <span class="name-2">كعبًا</span> عن أصحاب الرسِّ، قال: صاحب «يس» الذي قال: <span class="qpc-hafs">﴿يا قوم اتبعوا المرسلين﴾</span> [يس:٢٠]، فَرَسَّهُ{7} قومُه في بئر بالأحجار{8}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨١٩<span class="dash">-</span></span> عن ابن عباس -من طريق يونس بن يزيد، عمَّن حدَّثه- أنه قال ل<span class="name-2">كعب</span>: أخبِرني عن ستِّ آيات في القرآن لم أكن عَلِمْتُهُنَّ، ولا تخبرني عنهنَّ إلا ما تجد في كتاب الله المنزل: ... ما بال أصحاب الرس ذكرهم الله في الكتاب؟ ... قال كعب:... وأمّا أصحاب الرس فإنّهم كانوا قومًا مؤمنين، يعبدون الله في مُلْكِ جَبّارٍ لا يعبد الله، فخيّرهم في أن يكفروا أو يقتلهم، فاختاروا القتل على الكفر، فقتلهم، ثم رمى بهم في قَلِيب، فبذلك سُمُّوا: أصحاب الرس ...{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٠<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: كان لهم نبيٌّ يُقال له: حنظلة بن صفوان، فقتلوه، فأهلكهم الله تعالى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: <span class="qpc-hafs">﴿الرس﴾</span>: بِئر كان عليها قومٌ يُقال لهم: أصحاب الرس{11}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحاك بن مُزاحِم</span> -من طريق عبيد- قال: <span class="qpc-hafs">﴿الرس﴾</span>: بِئر قُتِل فيها صاحب «يس»{12}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سفيان، عن أبي بكير- قال: أصحاب الرسِّ رسُّوا نبيَّهم في بئرٍ{13}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قال: أصحاب الرس بفَلْج هم أصحاب يس{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: واد{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، في قوله: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>، قال: كانوا أهل بئر قعودًا عليها، وأصحاب مواشي، يعبدون الأصنام، فوَجَّه اللهُ إليهم شعيبًا يدعوهم إلى الإسلام، فتَمادَوْا في طغيانهم، وفي أذى شعيب ﵇، فبينما هم حول البئر في منازلهم انهارت البئر، فخسف بهم وبديارهم ورباعهم، فهلكوا جميعًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>، قال: قوم شعيب{17}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عمرو بن عبد الله- قال: إنّ أصحاب الأيكة وأصحاب الرس كانتا أُمَّتَيْن، فبعث الله إليهما نبيًّا واحدًا؛ شعيبًا، وعذَّبهما بعذابين{18}. (١١/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>، قال: حُدِّثنا: أنّ أصحاب الرس كانوا أهل فَلْج باليمامة، وآبار كانوا عليها{19}. (١١/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿الرس﴾</span>: بئر بأنطاكية، قتلوا فيها حبيبًا النجّار، وهم الذين ذكرهم الله في سورة «يس»{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿الرس﴾</span>: بئر بفَلْج اليمامة، قتلوا نبيَّهم، فأهلكهم الله ﷿{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>، يعني: البئر التي قُتِل فيها صاحب ياسين بأنطاكية التي بالشام{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>، أي: وأهلكنا أصحاب الرس.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٤<span class="dash">-</span></span> والرس: بئر في قول <span class="name-2">كعب</span> ... وبلغني: أنّ الذي أُرْسِل إليهم شعيب، وأنه أرسل إلى أهل مدين وإلى أهل الرس جميعًا، ولم يُبعث نبيٌّ إلى أُمَّتين غيره فيما مضى، وبعث النبي إلى الجن والإنس كلهم{3}<span class=comment-ref>٤٧٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٣٠</span> اختُلِف في أصحاب الرس؛ <b>فقال قوم</b>: هم من ثمود. <b>وقال آخرون</b>: بل هي قرية من اليمامة يُقال لها: الفلج. <b>وقال غيرهم</b>: هم قوم رسُّوا نبيَّهم في بئر. <b>وقال آخرون</b>: هي بئر كانت تُسَمّى: الرس.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٧/٤٥٣) <span class="mustanad">مستندًا إلى اللغة</span> القول الأخير الذي قاله ابن عباس مِن طريق العوفي، ومجاهد من طريق ابن يحيى، فقال: «وذلك أنّ الرَّسَّ في كلام العرب: كل محفور؛ مثل: البئر، والقبر، ونحو ذلك». ثم <span class="comment-type-3">رجَّح</span> (١٧/٤٥٣-٤٥٤) أنّ المراد بأصحاب الرس: أصحاب الأخدود الذين ذُكروا في سورة البروج؛ <span class="mustanad">مستندًا إلى القرآن</span>، فقال: «ولا أعلم قومًا كانت لهم قصة بسبب حُفْرَةٍ ذكرهم الله في كتابه إلا أصحاب الأخدود، فإن يكونوا هم المَعْنِيِّين بقوله: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span> فإنّا سنذكر خبرهم -إن شاء الله- إذا انتهينا إلى سورة البروج، وإن يكونوا غيرهم فلا نعرف لهم خبرًا، إلا ما جاء من جملة الخبر عنهم أنهم قوم رَسُّوا نبيهم في حفرة، إلا ما حدثنا ابن حميد ...» وساق أثر القرظي التالي. ثم <span class="comment-type-4">علَّق</span> (١٧/٤٥٤) بقوله: «غير أنّ هؤلاء في هذا الخبر يذكر محمد بن كعب عن النبي ﷺ: أنهم آمنوا بنبيهم، واستخرجوه من حفرته. فلا ينبغي أن يكونوا المعنيين بقوله: <span class="qpc-hafs">﴿وأصحاب الرس﴾</span>؛ لأنّ الله أخبر عن أصحاب الرس أنه دمرهم تدميرًا، إلا أن يكونوا دُمِّروا بأحداث أحدثوها بعد نبيهم الذي استخرجوه من الحفرة وآمنوا به، فيكون ذلك وجهًا».</div></p><p><h3><span class="qpc-hafs">﴿وَأَصۡحَـٰبَ ٱلرَّسِّ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٣٥<span class="dash">-</span></span> عن محمد بن كعب القرظي، قال: قال رسول الله ﷺ: «<b>إنّ أوَّل الناس يدخل الجنة يوم القيامة العبدُ الأسود، وذلك أنّ الله تعالى بعث نبيًّا إلى أهل قريته، فلم يؤمن به من أهلِها أحدٌ إلا ذلك الأسود، ثم إنّ أهل القرية عَدَوْا على النبيِّ، فحفروا له بئرًا، فألقوه فيها، ثم أطْبَقُوا عليه بحجر ضخم، فكان ذلك العبدُ يذهب فيَحْتَطِب على ظهره، ثم يأتي بحطبه فيبيعه، فيشتري به طعامًا وشرابًا، ثم يأتي به إلى تلك البئر، فيرفع تلك الصخرة، فيُعينه الله عليها، فيُدْلِي طعامَه وشرابَه، ثم يرُدُّها كما كانت، فكان كذلك ما شاء الله أن يكون. ثم إنّه ذهب يومًا يحتطب كما كان يصنع، فجمع حطبه، وحزم حزمته، وفرغ منها، فلما أراد أن يحتملها وجد سِنَةً، فاضطجع، فنام، فضُرِب على أُذُنه سبعَ سنين نائمًا، ثم إنّه هَبَّ، فتَمَطّى، فتحول لشِقِّه الآخر، فاضطجع، فضرب الله على أذنه سبع سنين أخرى، ثم إنّه هَبَّ، فاحتمل حزمته، ولا يحسب إلا أنّه نام ساعة من نهار، فجاء إلى القرية، فباع حزمته، ثم اشترى طعامًا وشرابا ًكما كان يصنع، ثم ذهب إلى الحفرة في موضعها التي كانت فيه، فالتمسه، فلم يجده، وقد كان بدا لقومه بداءٌ، فاستخرجوه، فآمنوا به وصدَّقوه، وكان النبيُّ يسألهم عن ذلك الأسود: ما فعل؟ فيقولون له: ما ندري. حتى قُبِض ذلك النبيُّ، فأهَبَّ اللهُ الأسودَ مِن نومته بعد ذلك. إنّ ذلك الأسود لَأول مَن يدخل الجنة</b>»{24}<span class=comment-ref>٤٧٣١</span>. (١١/١٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٣١</span> <span class="comment-type-1">علَّق</span> <span class="comment-type-2">ابنُ كثير</span> (١٠/٣٠٧) على هذا الأثر بقوله: «هكذا رواه ابن جرير عن ابن حميد، عن سلمة عن ابن إسحاق، عن محمد بن كعب مرسلًا. وفيه غرابة ونكارة، ولعل فيه إدراجًا».</div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٦<span class="dash">-</span></span> عن <span class="name-3">جعفر بن محمد بن علي</span>: أنّ امرأتين سألتاه: هل تجد غِشيان المرأةِ المرأةَ مُحَرَّمًا في كتاب الله؟ قال: نعم، هُنَّ اللواتي كُنَّ على عهد تُبَّعٍ، وهُنَّ صَواحِبُ الرَّسِّ، وكل نهر وبئرٍ رَسٌّ. قال: يُقْطَع لهن جِلباب مِن نارٍ، ودرع من نارٍ، ونطاق من نارٍ، وتاج مِن نارٍ، وخُفّان مِن نارٍ، ومن فوق ذلك ثوب غليظٌ جافٌّ جلفٌ مُنتِن مِن نارٍ. قال جعفرٌ: علِّموا هذا نساءَكم{25}. (١١/١٧٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُرُونَۢا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٣٧<span class="dash">-</span></span> عن عبد الله بن بسر المازني، قال: وضع النبيُّ ﷺ يدَه على رأسي، وقال: «<b>سيعيش هذا الغلامُ قرنًا</b>». قلت: يا رسول الله، كم القرن؟ قال: «<b>مائة سنة</b>». قال محمد بن القاسم: ما زلنا نَعُدُّ له حتى تَمَّت مائة سنةٍ، ثم مات{26}. (١١/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٨<span class="dash">-</span></span> عن أبي الهيثم بن دهر الأسلمي، قال: قال النبيُّ ﷺ: «<b>القرن: خمسون سنة</b>»{27}. (١١/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٣٩<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>أُمَّتي خمس قرون، القرن: أربعون سنة</b>»{27}. (١١/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٠<span class="dash">-</span></span> عن حماد، عن إبراهيم، قال: قال رسول الله ﷺ: «<b>القرن</b>: <b>أربعون سنةً</b>»{29}. (١١/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤١<span class="dash">-</span></span> عن ابن سيرين، قال: قال رسول الله ﷺ: «<b>القرن: أربعون سنةً</b>»{30}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٢<span class="dash">-</span></span> عن <span class="name-2">زُرارَة بن أوْفى</span> -من طريق أبي محمد بن عبد الله بن أبي أوفى- قال: القرن: مائةٌ وعشرون عامًا. قال: فبُعِث رسولُ الله ﷺ في قرنٍ، كان آخره العام الذي مات فيه يزيد بن معاوية{31}. (١١/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٣<span class="dash">-</span></span> عن جعفر بن علي بن أبي رافع مولى رسول الله ﷺ، قال: خَلَّفْتُ بالمدينة عَمِّي مِمَّن يُفْتِي على أنّ القرن سبعون سنة. وكان عمه <span class="name-2">عبيد الله بن أبي رافع</span> كاتِب عَلِيٍّ{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٤<span class="dash">-</span></span> قال <span class="name-2">أبو سلمة</span>: القرن: مائة سنةٍ{27}. (١١/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٥<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق الحكم- قال: القرن: أربعون سنة{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي عبيدة الناجي- قال: القرن: ستون سنة{35}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٧<span class="dash">-</span></span> عن مالك بن دينار، قال: سألتُ <span class="name-2">الحسن [البصريَّ]</span> عن القرن؟ فقال: عشرون سنة{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- <span class="qpc-hafs">﴿وقرونا بين ذلك كثيرًا﴾</span>، قال: كان يُقال: إنّ القرن: سبعون سنةً{37}. (١١/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقرونا﴾</span> يعني: وأهلكنا أُمَمًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقرونا بين ذلك كثيرا﴾</span> أي: وأهلكنا قرونًا؛ أُمَمًا، أمة بعد أمة <span class="qpc-hafs">﴿بين ذلك كثيرا﴾</span>{3}<span class=comment-ref>٤٧٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٣٢</span> اختُلِف في حدّ القرن، و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٠/٣٠٨) <span class="mustanad">مستندًا إلى السنة</span> أنّه: الأُمَّة المتعاصرة في الزمن الواحد، فقال: «والأظهر أنّ القرن: هم الأمة المتعاصرون في الزمن الواحد؛ فإذا ذهبوا وخلفهم جيلٌ آخر فهم قرن ثان، كما ثبت في الصحيحين عن رسول الله ﷺ أنه قال: «خير القرون قرني، ثم الذين يلونهم، ثم الذين يلونهم» الحديث».</div></p><p><h3><span class="qpc-hafs">﴿بَیۡنَ ذَ ٰ⁠لِكَ كَثِیرࣰا ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٥١<span class="dash">-</span></span> عن أُمِّ سلمة، قالت: سمعتُ النبيَّ ﷺ يقول: «<b>معد بن عدنان بن أُدَد بن زيد بن البراء بن أعراق الثرى</b>». قالت: ثم قرأ رسول الله ﷺ: «<b>أهلك عادًا، وثمودًا، وأصحاب الرس، وقرونًا بين ذلك كثيرًا لا يعلمهم إلا الله</b>». قالت: وأعراق الثرى: إسماعيل، وزيدٌ: هميسعٌ، وبراءٌ: نَبْتٌ{40}. (١١/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٢<span class="dash">-</span></span> عن أبي هريرة، قال: قال النبيُّ ﷺ: «<b>كان بين آدم وبين نوح عشرة قرونٍ، وبين نوحٍ وإبراهيم عشرة قرونٍ</b>». قال <span class="name-2">أبو سلمة</span>: القرن: مائة سنةٍ{41}. (١١/١٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٣<span class="dash">-</span></span> عن عبد الله بن عباس، قال: كان رسول الله ﷺ إذا انتهى إلى معد بن عدنان أمسك، ثم يقول: «<b>كذب النسّابون، قال الله تعالى</b>: <span class="qpc-hafs">﴿وقرونا بين ذلك كثيرًا﴾</span>»{42}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٤<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٥<span class="dash">-</span></span> و<span class="name-2">سليمان بن أبي خيثمة</span> -من طريق أبي الأسود- قال: ما وجدنا في شِعْر شاعر ولا في عِلْم عالم أحدًا يعرِف ما وراء معدّ بن عدنان بحقٍّ؛ لأن الله -تبارك وتعالى- يقول: <span class="qpc-hafs">﴿وقرونا بين ذلك كثيرا﴾</span>، وقد اختلفوا فيما بعد عدنان اختلافًا كثيرًا{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بين ذلك﴾</span> ما بين عاد إلى أصحاب الرس <span class="qpc-hafs">﴿كثيرا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن [عمر]</span> <span class="name-3">الواقدي</span> -من طريق الحسين بن الفرج- قال: يقول الله ﷿: <span class="qpc-hafs">﴿وقرونا بين ذلك كثيرا﴾</span> فكان بين نوح وآدم عشرة قرون، وبين إبراهيم ونوح عشرة قرون، فوُلِد إبراهيم خليل الرحمن على رأس ألفي سنة مِن خلق آدم{45}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَیۡنَ ذَ ٰ⁠لِكَ كَثِیرࣰا ۝٣٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: كان بين موسى وعيسى- صلى الله عليهما- أربعمائة سنة، وكان بين عيسى وبين محمد -صلى الله عليهما- ستمائة سنة، وبين نوح وآدم -صلى الله عليهما- ألف دار، وبين نوح وإبراهيم -صلى الله عليهما ألف دار-، وبين إبراهيم وبين موسى -صلى الله عليهما وسلم- ألف دار، يعني: ألف دار: ألف سنة{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٥٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه- قال: بين النبيِّ ﷺ وبين آدم تسعة وأربعون أبًا{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٠<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق سفيان- قال: كان بين موسى وعيسى ألف نبي{46}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها العشرة ما عدا حفصًا، وحمزة، ويعقوب، فإنهم قرؤوا: <span class="qpc-hafs">﴿وثَمُوداْ﴾</span> بغير تنوين. انظر: الإتحاف ص٤١٧.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٢.أخرجه ابن جرير ١٧/٤٥٢.أخرجه ابن أبي حاتم ٨/٢٦٩٥.أخرجه ابن جرير ١٧/٤٥٢.أي: دَسُّوه فيها حتى مات. اللسان (رسس).عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر. وفي تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤: قال كعب: الرس: بئر بأنطاكية، قتلوا فيها حبيبًا النجّار، وهم الذين ذكرهم الله في سورة «يس».أخرجه ابن وهب في الجامع - تفسير القرآن ١/٢٩ (٦٢).تفسير الثعلبي ٧/١٣٤ مطولًا، وتفسير البغوي ٦/٨٤.أخرجه يحيى بن سلام ١/٤٨٢ بنحوه، وابن جرير ١٧/٤٥٣، وابن أبي حاتم ٨/٢٦٩٥. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ٢١/٤١٥.أخرجه ابن جرير ١٧/٤٥٣، وابن أبي حاتم ٨/٢٦٩٥ من طريق سفيان عن رجل. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٧/٤٥٣.علَّقه يحيى بن سلام ١/٤٨٢.تفسير الثعلبي ٧/١٣٣، وتفسير البغوي ٦/٨٤.عزاه السيوطي إلى ابن عساكر.أخرجه ابن وهب في الجامع - تفسير القرآن ١/١٥٢-١٥٣ (٣٥٦)، وابن جرير ٢١/٤١٥.أخرجه ابن أبي حاتم ٨/٢٦٩٥، وابن جرير ١٧/٤٥٢ من طريق جرير بن حازم بنحوه. وعلَّقه يحيى بن سلام ١/٤٨٢. وعزاه السيوطي إلى عبد بن حميد. وفي تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤: بئر بفَلْج اليمامة، قتلوا نبيَّهم، فأهلكهم الله ﷿.تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤.تفسير البغوي ٦/٨٤.تفسير مقاتل بن سليمان ٣/٢٣٥. وفي تفسير الثعلبي ٧/١٣٤، وتفسير البغوي ٦/٨٤: عن مقاتل قال: الرس: بئر بأنطاكية، قتلوا فيها حبيبًا النجار، وهم الذين ذكرهم الله في سورة «يس».تفسير يحيى بن سلام ١/٤٨٢.أخرجه ابن الفاخر الأصبهاني في موجبات الجنة ص٢٣٧-٢٣٩ (٣٥٣)، وابن جرير ١٧/٤٥٤-٤٥٥. وأورده الثعلبي ٧/١٣٤-١٣٥.</p><p>(<span class="name-1">ب) علَّق</span> <u>ابنُ كثير</u> (١٠/٣٠٧) على هذا الأثر بقوله: «هكذا رواه ابن جرير عن ابن حميد، عن سلمة عن ابن إسحاق، عن محمد بن كعب مرسلًا. وفيه غرابة ونكارة، ولعل فيه إدراجًا».أخرجه ابن أبي الدنيا في ذم الملاهي (١٤٩)، والبيهقي في الشعب (٥٤٦٣)، وابن عساكر ٥٠/٣٢٠.أخرجه أحمد ٢٩/٢٣٥ (١٧٦٨٩)، والحاكم ٢/٥٩٩(٤٠١٦)، ٤/٥٤٥ (٨٥٢٤، ٨٥٢٥) واللفظ له، وابن جرير ١٤/٥٣٤، وابن أبي حاتم ٨/٢٦٩٥ (١٥١٧٧)، ٩/٢٩٨٢ (١٦٩٣٤). وأورده الثعلبي ٦/٩١.</p><p>قال البوصيري في إتحاف الخيرة المهرة ٧/٢٨٢ (٦٨٥٧): «رواه أحمد بن حنبل بسند صحيح». وقال ابن حجر في إتحاف المهرة ٦/٥٣٦ (١٦١١٩) عَقِب حديث الحاكم: «لم يتكلم عليه، وهو ضعيف جدًّا، ولكن رواه بإسناد أمثل من هذا». وقال الألباني في الضعيفة ٦/٣٤٣ (٢٦٦٠): «وهذا إسناد لا بأس به في الشواهد، رجاله كلهم ثقات معروفون، غير إبراهيم».</p><p>وقد تقدم عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وكَمْ أهْلَكْنا مِنَ القُرُونِ مِن بَعْدِ نُوحٍ﴾</span> [الإسراء:١٧]، وذكر ابن جرير ١٤/٥٣٤ المسألة عند تلك الآية.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٥٣٥. وأورده الثعلبي ٦/٩١.أخرجه ابن جرير ١٤/٥٤٣، وابن أبي حاتم ٨/٢٦٩٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٤٥٥.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٧/٤٥٥، وابن أبي حاتم ٨/٢٦٩٦. وسبق ذكره مرفوعًا من طريق حماد.أخرجه ابن أبي حاتم ٨/٢٦٩٦.أخرجه ابن أبي حاتم ٨/٢٦٩٦.أخرجه ابن أبي حاتم ٨/٢٦٩٦. وعلَّقه يحيى بن سلام ١/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٢.أخرجه الحاكم ٢/٤٣٧ (٣٥١٩)، ٢/٥٠٤ (٣٧٢٩).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه العقيلي في الضعفاء ٤/٢٩٨، من طريق نصر بن عاصم الأنطاكي، قال: حدثنا الوليد بن مسلم، قال: حدثنا أبو عمرو، عن محمد بن أبي كثير، عن أبي سلمة، عن أبي هريرة به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال العقيلي: «نصر بن عاصم عن الوليد .. لا يُتابَع عليه، ولا يُعرف إلا به». ثم أسند له الحديث السابق، وقال الذهبي في ميزان الاعتدال ٤/٢٥٢: «نصر بن عاصم مُحَدِّث دجّال».أخرجه ابن سعد في الطبقات ١/٥٦، وابن عساكر في تاريخ دمشق ٣/٥٢، ٥٩-٦٠.</p><p>قال المناوي في التيسير ٢/٢٤١: «إسناد ضعيف». وقال الألباني في الضعيفة ١/٢٢٨ (١١١): «موضوع».أخرجه ابن عساكر ٣/٥٢، وأخرجه ابن أبي حاتم ٨/٢٦٩٧ عن عروة دون ذكر الآية.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن عساكر في تاريخ دمشق ٦/١٧٢، وفيه عن محمد بن محمد الواقدي، وهو تحريف.أخرجه ابن أبي حاتم ٨/٢٦٩٧.أخرجه ابن أبي حاتم ٨/٢٦٩٧.أخرجه ابن أبي حاتم ٨/٢٦٩٧.
  25,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُلࣰّا ضَرَبۡنَا لَهُ ٱلۡأَمۡثَـٰلَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وكلا ضربنا له الامثال وكلا تبرنا تتبيرا﴾</span>، قال: كل قد أعذر اللهُ إليه، وبيَّن له، ثم انتقم منه{1}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وكلا﴾</span> يعني: مَن ذُكِر مِمَّن مضى <span class="qpc-hafs">﴿ضربنا له الأمثال﴾</span> أي: خوَّفناهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكُلࣰّا تَبَّرۡنَا تَتۡبِیرࣰا ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٦٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿تبرنا تتبيرا﴾</span>، قال: تبَّره: إذا أراد كسر الشيء. قال: تبَّره بالنبطية{3}. (ز) (١١/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وكلا تبرنا تتبيرا﴾</span>، قال: تَبَّرَ الله كُلًّا بالعذاب{4}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكلا ضربنا له الأمثال وكلا تبرنا تتبيرا﴾</span>، وكلًّا دمَّرنا بالعذاب تدميرًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٦<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿وكلا تبرنا تتبيرا﴾</span>، قال: بالعذاب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٧<span class="dash">-</span></span> عن أصبغ، قال: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> في قوله: <span class="qpc-hafs">﴿وكلًا تبرنا تتبيرًا﴾</span>، قال: أضللنا الذين أضلهم، لم ينتفعوا من دينهم بشيء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وكلا تبرنا تتبيرا﴾</span> أفسدنا فسادًا، يعني: إهلاكه الأمم السالفة بتكذيبها رسلها{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦، وابن أبي حاتم ٨/٢٦٩٧ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ١/٤٨٢.أخرجه إسحاق البستي في تفسيره ص٥٠٨، وأخرج آخره ابن جرير ١٧/٤٥٦. وكذا عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦، وابن أبي حاتم ٨/٢٦٩٧.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٧.أخرجه ابن أبي حاتم ٨/٢٦٩٧.تفسير يحيى بن سلام ١/٤٨٢.
  25,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَتَوۡا۟ عَلَى ٱلۡقَرۡیَةِ ٱلَّتِیۤ أُمۡطِرَتۡ مَطَرَ ٱلسَّوۡءِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولقد أتو على القرية﴾</span> قال: هي سدوم، قرية قوم لوطٍ، <span class="qpc-hafs">﴿التي أمطرت مطر السوء﴾</span> قال: الحجارة{1}. (١١/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿ولقد أتوا على القرية﴾</span>، قال: هي بين الشام والمدينة{2}. (١١/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿ولقد أتوا على القربة التي أمطرت مطر السوء﴾</span>، قال: قرية لوط{3}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- <span class="qpc-hafs">﴿ولقد أتوا على القرية﴾</span>، قال: قرية لُوطٍ{4}. (١١/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد أتوا على القرية التي أمطرت﴾</span> بالحجارة <span class="qpc-hafs">﴿مطر السوء﴾</span> يعني: قرية لوط ﵇، كلُّ حجر في العِظَم على قدر كلِّ إنسان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ولقد أتوا على القرية التي أمطرت مطر السوء﴾</span>، قال: حجارة، وهي قرية قوم لوط، واسمها: سَدُوم.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٥<span class="dash">-</span></span> قال <span class="name-1">ابن عباس</span>: خمس قريات؛ فأهلك الله أربعة، وبقيت الخامسة، واسمها: صعوة. لم تهلك صعوة، كان أهلُها لا يعملون ذلك العمل، وكانت سدوم أعظمها، وهي التي نزل بها لوط، ومنها بُعِث. وكان إبراهيم ﷺ يُنادي نصيحةً لهم: يا سدوم، يوم لك مِن الله، أنهاكم أن تَعَرَّضوا لعقوبة الله. زعموا: أنّ لوطًا ابنُ أخي إبراهيم -صلوات الله عليهما-{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولقد أتوا﴾</span> يعني: مشركي العرب ... و<span class="qpc-hafs">﴿مطر السوء﴾</span>: الحجارة التي رُمُوا بها من السماء؛ رُمي بها مَن كان خارجًا مِن المدينة، وأهل السفر منهم{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَلَمۡ یَكُونُوا۟ یَرَوۡنَهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفلم يكونوا يرونها﴾</span> فيعتبروا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أفلم يكونوا يرونها﴾</span> فيتفكروا، ويحذروا أن ينزل بهم ما نزل بهم، أي: بلى، قد أتوا عليها ورأوها. مثل قوله: <span class="qpc-hafs">﴿وإنكم لتمرون عليهم مصبحين (١٣٧) وبالليل أفلا تعقلون (١٣٨)﴾</span> [الصافات:١٣٧-١٣٨]{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلۡ كَانُوا۟ لَا یَرۡجُونَ نُشُورࣰا ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿لا يرجون﴾</span>: أي: لا يخافون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿بل كانوا لا يرجون نشورا﴾</span>، قال: بَعْثًا، ولا حِسابًا{11}. (١١/١٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بل كانوا لا يرجون نشورا﴾</span>، يقول ﷿: بل كانوا لا يخشون بَعْثًا. نظيرها في تبارك الملك [١٥]: <span class="qpc-hafs">﴿وإليه النشور﴾</span>، يعني: الإحياء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿لا يرجون نشورا﴾</span>، قال: بَعْثًا{13}. (١١/١٨١)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٩٨.أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦. وعلَّقه يحيى بن سلام ١/٤٨٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٩٨. وقد نسبه السيوطي إلى عطاء مُهمَلًا دون تمييز، وعزاه إلى ابن أبي حاتم، وعند ابن أبي حاتم عن عثمان بن عطاء، عن أبيه.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٧.تفسير يحيى بن سلام ١/٤٨٢.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٢.أخرجه ابن أبي حاتم ٨/٢٦٩٨.أخرجه عبد الرزاق ٢/٧٠، وابن جرير ١٧/٤٥٦، وابن أبي حاتم ٨/٢٦٩٨ من طريق سعيد. وعلَّقه يحيى بن سلام ١/٤٨٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٨. وعزاه السيوطي إلى ابن المنذر.
  25,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا رَأَوۡكَ إِن یَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَـٰذَا ٱلَّذِی بَعَثَ ٱللَّهُ رَسُولًا ۝٤١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا رأوك إن يتخذونك إلا هزوا أهذا الذي بعث الله رسولا﴾</span> نزلت في أبي جهل -لعنه الله-{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا رَأَوۡكَ إِن یَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَـٰذَا ٱلَّذِی بَعَثَ ٱللَّهُ رَسُولًا ۝٤١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا رأوك﴾</span> يعني: النبيَّ ﷺ <span class="qpc-hafs">﴿إن يتخذونك إلا هزوا أهذا الذي بعث الله رسولا﴾</span> ﷺ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإذا رأوك﴾</span> يعني: الذين كفروا <span class="qpc-hafs">﴿إن يتخذونك إلا هزوا أهذا الذي بعث الله رسولا﴾</span> فيما يزعم. يقوله بعضُهم لبعض{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٣٥. وأخرج ابن أبي حاتم ٨/٢٦٩٨ عند هذه الآية عن محمد بن إسحاق من طريق سلمة: قال أبو جهل يومًا وهو يهزأ برسول الله ﷺ، وبما جاء به من الحق: يا معشر قريش، يزعم محمدٌ أنّ جنود الله الذين يعذبونكم في النار ويحبسونكم فيها تسعة عشر، وأنتم أكثر الناس عددًا وكثرة، أفيعجزكم مائة رجل منكم عن رجل منهم؟! فأنزل الله ﷿ في ذلك مِن قوله: <span class="qpc-hafs">﴿وما جعلنا أصحاب النار إلا ملائكة وما جعلنا عدتهم إلا فتنة للذين كفروا﴾</span> [المدثر:٣١] إلى آخر القصة.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٣.
  25,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن كَادَ لَیُضِلُّنَا عَنۡ ءَالِهَتِنَا لَوۡلَاۤ أَن صَبَرۡنَا عَلَیۡهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال أبو جهل: <span class="qpc-hafs">﴿إن كاد ليضلنا عن آلهتنا﴾</span> يعني: لِيَسْتَزِلَّنا عن عبادة آلهتنا، <span class="qpc-hafs">﴿لولا أن صبرنا﴾</span> يعني: تَثَبَّتنا <span class="qpc-hafs">﴿عليها﴾</span>، يعني: على عبادتها؛ ليدخلنا في دينه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿لولا ان صبرنا عليها﴾</span>، قال: ثَبَتْنا{2}. (١١/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن كاد ليضلنا عن آلهتنا﴾</span> يعنون: أوثانهم، <span class="qpc-hafs">﴿لولا أن صبرنا عليها﴾</span> على عبادتها{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَوۡفَ یَعۡلَمُونَ حِینَ یَرَوۡنَ ٱلۡعَذَابَ مَنۡ أَضَلُّ سَبِیلًا ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل بن مسلم- <span class="qpc-hafs">﴿وسوف يعلمون﴾</span>، قال: وعيد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وسوف يعلمون حين يرون العذاب في الآخرة من أضل سبيلا﴾</span>، يعني: مَن أخطأ طريق الهُدى، أهم أم المؤمنون؟{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿وسوف يعلمون حين يرون العذاب﴾</span> في الآخرة <span class="qpc-hafs">﴿من أضل سبيلا﴾</span> أي: مَن كان أضل سبيلًا في الدنيا. أي: فسوف يعلمون أنّهم كانوا أضلَّ سبيلًا مِن محمد{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن جرير ١٧/٤٥٩. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٤٨٣.أخرجه ابن أبي حاتم ٨/٢٦٩٩.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٣.
  25,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَرَءَیۡتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿أرأيت من اتخذ الهه هواه﴾</span>، قال: كان الرجل يعبد الحجرَ الأبيض زمانًا مِن الدهر في الجاهلية، فإذا وجد حَجَرًا أحسنَ منه رمى به وعبد الآخر؛ فأنزل الله الآية{1}. (١١/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٣<span class="dash">-</span></span> عن <span class="name-2">أبي رجاء العطاردي</span>، قال: كانوا في الجاهلية يأكلون الدم بالعِلْهِز{2}، ويعبدون الحجر، فإذا وجدوا ما هو أحسنُ منه رَمَوْا به، وعبدوا الآخر، فإذا فقدوا الآخرَ أمروا مُناديًا، فنادى: أيها الناس، إنّ إلهكم قد ضَلَّ، فالتَمِسُوه. فأنزل الله هذه الآية: <span class="qpc-hafs">﴿أرأيت من اتخذ الهه هواه﴾</span>{3}. (١١/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت <span class="qpc-hafs">﴿أرأيت من اتخذ إلهه هواه﴾</span> وذلك أنّ الحارث بن قيس السهمي هوى شيئًا، فعبده{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَرَءَیۡتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٨٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أرأيت من اتخذ إلهه هواه﴾</span>، قال: ذاك الكافر، اتخذ دينه بغير هُدًى مِن الله، ولا بُرهانٍ{5}. (١١/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله تعالى: <span class="qpc-hafs">﴿أرأيت من اتخذ إلهه هواه﴾</span>، قال: كان أهل الجاهلية يعبدون الحجر، فإذا رأوا حجرًا أحسن منه أخذوه، وتركوا الأول{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- <span class="qpc-hafs">﴿أرأيت من اتخذ الهه هواه﴾</span>، قال: لا يهوى شيئًا إلا تَبِعَه{7}. (١١/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قيل له: في أهل القبلة شِرْكٌ؟! فقال: نعم، إنّ المنافق مُشْرِكٌ؛ إن المشرك يسجد للشمس والقمر من دون الله، وإنّ المنافق عبد هواه. ثم تلا هذه الآية: <span class="qpc-hafs">﴿أرأيت من اتخذ الهه هواه أفأنت تكون عليه وكيلا﴾</span>{8}. (١١/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٨٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أرأيت من اتخذ الهه هواه﴾</span>، قال: كُلَّما هوي شيئًا ركبه، وكلَّما اشتهى شيئًا أتاه، لا يحجزه عن ذلك ورَعٌ ولا تقوى{9}. (١١/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٩٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿اتخذ إلهه هواه﴾</span>، يعني: المشرك{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَرَءَیۡتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٩٠١<span class="dash">-</span></span> عن أبي أُمامة، قال: قال رسول الله ﷺ: «<b>ما تحت ظِلِّ السماء مِن إله يُعبد مِن دون الله أعظم عند الله مِن هَوًى مُتَّبَع</b>»{11}. (١١/١٨٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَأَنتَ تَكُونُ عَلَیۡهِ وَكِیلًا ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٤٩٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وكيلا﴾</span>، قال: ناصرًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٩٠٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وكيلا﴾</span>، يعني: مُسَيْطِرًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٩٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفأنت﴾</span> يا محمد <span class="qpc-hafs">﴿تكون عليه وكيلا﴾</span> يعني: مُسَيْطِرًا، يقول: تريد أن تُبَدِّل المشيئة إلى الهُدى والضلالة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٤٩٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أفأنت تكون عليه﴾</span> على الذي اتخذ إلهه هواه <span class="qpc-hafs">﴿وكيلا﴾</span> حفيظًا، تحفظ عليه عملَه حتى تجازيه به؟! أي: إنّك لست بربٍّ، إنما أنت نذير{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَأَنتَ تَكُونُ عَلَیۡهِ وَكِیلًا ۝٤٣﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٥٤٩٠٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿أفأنت تكون عليه وكيلا﴾</span>: نسختها آية القتال{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٤٩١ (٣٦٨٩)، وابن أبي حاتم ٨/٢٦٩٩ (١٥١٩٩) واللفظ له.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».العِلْهِز: هو شئ يتخذونه في سِنِي المجاعة، يخلطون الدم بأوبار الإبل، ثم يشوونه بالنار، ويأكلونه. النهاية (علهز).عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٢٣٥.أخرجه ابن أبي حاتم ٨/٢٧٠٠. وعزاه السيوطي إلى ابن المنذر.أخرجه أبو نعيم في حلية الأولياء ٤/٢٨٨. وعلَّقه ابن أبي حاتم ٨/٢٦٩٩.أخرجه ابن أبي حاتم ٨/٢٧٠٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه يحيى بن سلام ١/٤٨٣ من طريق المبارك بن فضالة بلفظ: هو المنافق يصيب هواه، كلما هوي شيئًا فعله، وابن أبي حاتم ٨/٢٧٠٠ من طريق المبارك بلفظ: ذلك المنافق نصب هواه فما هوي من شيء ركبه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٧٠٠. وعزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ١/٤٨٣.أخرجه ابن أبي عاصم في السنة ١/٨ (٣)، والطبراني في الكبير ٨/١٠٣ (٧٥٠٢).</p><p>قال ابن عدي في الكامل ٣/١٢٦: «هذا إن كان البلاء فيه مِن الحسن، وإلا من الخصيب بن جحدر، ولعله أضعف منه». وقال ابن الجوزي في الموضوعات ٣/١٣٩: «هذا حديث موضوع على رسول الله ﷺ، وفيه جماعة ضعاف، والحسن بن دينار والخصيب كذّابان عند علماء النقل». وقال الهيثمي في المجمع ١/١٨٨ (٨٩٥): «رواه الطبراني في الكبير، وفيه الحسن بن دينار، وهو متروك الحديث». وقال السيوطي في اللآلئ المصنوعة ٢/٢٧٢، والشوكاني في الفوائد المجموعة ص٢٣٩ (٦٧)، والألباني في الضعيفة ١٤/٩٠ (٦٥٣٨): «موضوع».أخرجه ابن أبي حاتم ٨/٢٧٠٠. وأورده عند تفسير قوله تعالى: <span class="qpc-hafs">﴿ثُمَّ لا تَجِدُوا لَكُمْ وكِيلًا﴾</span> [الإسراء:٦٨] بلفظ: منعةً ولا ناصرًا -كما عزاه السيوطي-.علَّقه يحيى بن سلام ١/٤٨٣.تفسير مقاتل بن سليمان ٣/٢٣٥.تفسير يحيى بن سلام ١/٤٨٣.تفسير البغوي ٦/٨٦.