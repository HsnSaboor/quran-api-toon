quran[8]{c,v,t}:
  16,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَحۡمِلُ أَثۡقَالَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٢٨<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: أنّها الإبل والبقر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتحمل أثقالكم﴾</span> يعني: الإبل، والبقر <span class="qpc-hafs">﴿إلى بلد﴾</span>{2}<span class=comment-ref>٣٦٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٣٧</span> ذكر <u>ابنُ عطية</u> (٥/٣٢٩) أن «الأثقال: الأمتعة». ونقل <b>احتمالًا</b> آخر أن «المراد هنا الأجسام، <span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿وأَخْرَجَتِ الأَرْضُ أثْقالَها﴾</span> [الزلزلة:٢]، أي: بني آدم». ثم <span class="comment-type-4">علَّق</span> بقوله: «واللفظ يحتمل المعنيين».</div></p><p><h3><span class="qpc-hafs">﴿إِلَىٰ بَلَدࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وتحمِل أثقالكم إلى بلد﴾</span>، قال: يعني: مكة{3}. (٩/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٣١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- <span class="qpc-hafs">﴿إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</span>، قال: البلد: مكة{4}<span class=comment-ref>٣٦٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٣٨</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٥/٣٢٩) على قول ابن عباس وعكرمة بقوله: «وفي الآية -على هذا- حضٌّ مّا على الحج».</div></p><p><div></p><p><p><span class="item-no">٤٠٨٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وتحمل أثقالكم إلى بلد لم تكونوا بالغيه﴾</span> إلى البلد الذي تريدونه{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّمۡ تَكُونُوا۟ بَـٰلِغِیهِ إِلَّا بِشِقِّ ٱلۡأَنفُسِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لم تكونوا بالغيه إلا بِشِقِ الأنفُس﴾</span>، قال: لو تَكَلَّفْتُموه لم تُطيقوه إلا بجهد شديد{3}. (٩/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إلا بِشِقِ الأنفُس﴾</span>، قال: مشقَّة عليكم{7}. (٩/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</span>، قال: لو تُكلَّفونه لم تبلغوه إلا بجهد شديد{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وتحمل أثقالكم إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</span>، يقول: بجهد الأنفس{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لم تكونوا بالغيه إلا بشق الأنفس﴾</span>، يعني: بجهد الأنفس{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إلا بشق الأنفس﴾</span> لولا أنها تحمل أثقالكم لم تكونوا بالغي ذلك البلد إلا بمشقة على أنفسكم{5}<span class=comment-ref>٣٦٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٣٩</span> نقل <u>ابنُ عطية</u> (٥/٣٣٠) عن الفراء أن معنى «<span class="qpc-hafs">﴿بِشِقِّ الأَنْفُس﴾</span> أي: بذهاب نصفها، كأنها قد ذابت تعبًا ونصبًا». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «كما تقول لرجل: لا تقدر على كذا إلا بذهاب جُلِّ نفسك، وبقطعة من كبدك. ونحو هذا من المجاز».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكُمۡ لَرَءُوفࣱ رَّحِیمࣱ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن ربكم لرؤوف﴾</span> يعني: لرفيق <span class="qpc-hafs">﴿رحيم﴾</span> بكم فيما جعل لكم من الأنعام من المنافع{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿إن ربكم لرءوف رحيم﴾</span>، يقول: فبرأفة الله ورحمته سخر لكم هذه الأنعام، وهي للكافر رحمة الدنيا: المعايش، والنعم التي رزقه الله{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكُمۡ لَرَءُوفࣱ رَّحِیمࣱ ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٤١<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>إيّاكم أن تتخذوا ظهور دوابِّكم منابر؛ فإنّ الله تعالى إنما سخَّرها لكم لتبلُغوا إلى بلد لم تكونوا بالغيه إلا بشقِّ الأنفس، وجعل لكم الأرض، فعليها فاقضُوا حاجاتِكم</b>»{14}. (٩/١٢)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٥١.|2:تفسير مقاتل بن سليمان ٢/٤٦٠.|3:عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ١٤/١٧٠.|5:تفسير يحيى بن سلام ١/٥١.|6:عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.|7:أخرجه ابن جرير ١٤/١٧٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٤/١٦٩-١٧٠.|9:أخرجه يحيى بن سلام ١/٥٢، وعبد الرزاق في تفسيره ٢/٣٥٣ من طريق معمر، وابن جرير ١٤/١٧٠.|10:تفسير مقاتل بن سليمان ٢/٤٦٠.|11:تفسير يحيى بن سلام ١/٥١.|12:تفسير مقاتل بن سليمان ٢/٤٦٠.|13:تفسير يحيى بن سلام ١/٥٢.|14:أخرجه أبو داود ٤/٢١٤ (٢٥٦٧)، والبيهقي في الشعب ١٣/٤٢٤ (١٠٥٧٢) واللفظ له.</p><p>قال ابن القطان في بيان الوهم والإيهام ٥/٧٥-٧٦ (٢٣١٩): «وإنما الذي ينظر في أمره من هذا الإسناد أبو مريم؛ وهو مولى أبي هريرة، ولا يعرف له حال...، فما مثل هذا الحديث صُحِّح». وقال ابن مفلح في الآداب الشرعية ٣/٣٥٩: «رواه أبو داود، وهو حديث حسن». وقال المناوي في التيسير ١/٤٠٧ عن إسناد أبي داود: «إسناد ضعيف». وقال الألباني في صحيح أبي داود ٧/٣٢٠ (٢٣١٣): «إسناده صحيح».
  16,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٤٢<span class="dash">-</span></span> عن قتادة، أنّ أبا عياض كان يقرؤها: (والخَيْلَ والبِغالَ والحَمِيرَ لِتَرْكَبُوها زِينَةً). يقول: جعلها زينة{1}. (٩/١٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٤٣<span class="dash">-</span></span> في تفسير قتادة، عن <span class="name-1">عبد الله بن عباس</span>: أنّه خلقها للركوب والزينة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لتركبوها وزينة﴾</span>، قال: جعَلها لتركبوها، وجعَلها زينة لكم{3}. (٩/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكرهم النعم: <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها وزينة﴾</span>، يقول: لكم في ركوبها جمال وزينة، يعني: الشارة الحسنة، كقوله تعالى: <span class="qpc-hafs">﴿فخرج على قومه في زينته﴾</span> [القصص:٧٩]، يعني: في شارته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٤٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿والخيل والبغال﴾</span> وخلق الخيل والبغال، <span class="qpc-hafs">﴿والحمير لتركبوها وزينة﴾</span> في ركوبها{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٤٧<span class="dash">-</span></span> عن دِحْيَةَ الكلبي، قال: قلت: يا رسول الله، أحمِل لك حمارًا على فرس، فيَنتِج لك بغلًا تركبُها؟ قال: «<b>إنما يفعل ذلك الذين لا يعلمون</b>»{6}. (٩/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٤٨<span class="dash">-</span></span> عن خالد بن الوليد، قال: نهى رسول الله ﷺ عن أكل كلِّ ذي نابٍ مِن السباع، وعن لحوم الخيل والبغال والحمير{7}. (٩/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٤٩<span class="dash">-</span></span> عن أسماء بنت أبي بكر، قالت: نحرنا على عهد رسول الله ﷺ فرسًا، فأكلناه{8}. (٩/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٠<span class="dash">-</span></span> عن جابر بن عبد الله -من طريق محمد بن علي- قال: نهى رسول الله ﷺ يوم خيبر عن لحوم الحمر الأهلية، ورخَّص في الخيل{9}. (٩/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥١<span class="dash">-</span></span> عن جابر بن عبد الله -من طريق أبي الزبير-: أنهم ذبحوا يوم خيبر الحمير والبغال والخيل، فنهاهم النَّبي ﷺ عن الحمير والبغال، ولم ينههم عن الخيل{10}. (٩/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٢<span class="dash">-</span></span> عن جابر بن عبد الله -من طريق عطاء- قال: كنا نأكل لحم الخيل على عهد رسول الله ﷺ. قلت: فالبغال؟ قال: أمّا البغال فلا{11}. (٩/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٣<span class="dash">-</span></span> عن جابر بن عبد الله -من طريق عمرو بن دينار- قال: نهانا رسول الله ﷺ عن لحوم الحمر، وأمرنا بلحوم الخيل{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٤<span class="dash">-</span></span> عن سعيد بن جبير، قال: سأل رجل <span class="name-1">عبد الله بن عباس</span> عن أكل لحوم الخيل، فكرهها. وقرأ: <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها وزينة﴾</span>{13}. (٩/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مولى نافع بن علقمة- أنه كان يكره لحوم الخيل، ويقول: قال الله: <span class="qpc-hafs">﴿والأنعام خلقها لكم فيها دفء ومنافع ومنها تأكلون﴾</span> فهذه للأكل، <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها﴾</span> فهذه للركوب{14}. (٩/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٦<span class="dash">-</span></span> عن <span class="name-2">الأسود [النخعي]</span>-من طريق إبراهيم-: أنّه أكل لحم الفرس{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- قال: نحر أصحابنا فرسًا في النَّجْعِ{16}، وأكلوا منه، ولم يروا به بأسًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحكم- أنه سُئِل عن لحوم الخيل. فقال: <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها﴾</span>{18}. (٩/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٥٩<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span> -من طريق عبد الملك بن أبي غَنِيَّة- في قوله: <span class="qpc-hafs">﴿والأنعام خلقها لكم فيها دفء ومنافع ومنها تأكلون﴾</span>: فجعل منه الأكل. ثم قرأ: <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها وزينة﴾</span>، قال: لم يجعل لكم فيها أكلًا. وكان الحكم يقول: الخيل والبغال والحمير حرامٌ في كتاب الله{19}. (٩/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٠<span class="dash">-</span></span> عن ابن جريج، قلت ل<span class="name-2">عطاء [بن أبي رباح]</span>: الحمار يشرب في جفنتي؟ قال: نعم، وتوضأ بفضله. ثم تلا <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها﴾</span>. قلت: فإنه يُنهى عن أكله. قال: ليس أكله مثل أن يتوضأ بفضله، فاسقه بجفنتك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦١<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span>: أنّ أحسن ما سمع في الخيل والبغال والحمير أنها لا تؤكل؛ لأن الله -تبارك وتعالى- قال: <span class="qpc-hafs">﴿والخيل والبغال والحمير لتركبوها وزينة﴾</span>. وقال -تبارك وتعالى- في الأنعام: <span class="qpc-hafs">﴿لتركبوا منها، ومنها تأكلون﴾</span> [غافر:٧٩]. وقال -تبارك وتعالى-: <span class="qpc-hafs">﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</span> [الحج:٣٤]، <span class="qpc-hafs">﴿فكلوا منها وأطعموا القانع والمعتر﴾</span> [الحج:٣٦]. قال: وسمعت مالكًا يقول: أن البائس هو الفقير، وأن المعتر هو الزائر. قال مالك: فذكر الله الخيل والبغال والحمير للركوب والزينة، وذكر الأنعام للركوب والأكل. قال مالك: والقانع هو الفقير أيضًا{21}<span class=comment-ref>٣٦٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٠</span> اختُلِف في الاستدلال بهذه الآية على تحريم أكل لحوم الخيل على قولين: <b>الأول:</b> أن في هذه الآية دلالة على تحريم أكل لحوم الخيل. <b>الثاني:</b> أنها لا تدل على تحريم شيء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/١٧٥-١٧٦) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الثاني، وهو قول إبراهيم النخعي، وقول الأسود، وعلَّل ذلك بأنه «لو كان في قوله -تعالى ذكره-: <span class="qpc-hafs">﴿لِتَرْكَبُوها﴾</span> دلالةٌ على أنها لا تصلح -إذ كانت للركوب- للأكل، لكان في قوله: <span class="qpc-hafs">﴿فِيها دِفْءٌ ومَنافِعُ ومِنها تَأْكُلُونَ﴾</span> دلالة على أنها لا تصلح -إذ كانت للأكل والدِّفْءِ- للركوب، وفي إجماع الجميع على أن ركوب ما قال -تعالى ذِكْره-: <span class="qpc-hafs">﴿ومِنها تَأْكُلُونَ﴾</span> جائزٌ حلالٌ غير حرام، دليلٌ واضحٌ على أن أكل ما قال: <span class="qpc-hafs">﴿لِتَرْكَبُوها﴾</span> جائزٌ حلالٌ غير حرامٍ، إلا بما نصَّ على تحريمه، أو وضَع على تحريمه دلالة من كتابٍ أو وحيٍ إلى رسول الله ﷺ، فأما بهذه الآية فلا يُحَرَّم أكلُ شيءٍ».</p><p>وذكر <u>ابنُ عطية</u> (٥/٣٣٠) احتجاج ابن عباس ومالك بهذه الآية على كراهة لحوم الخيل والبغال والحمير، واحتجاج الحكم بن عيينة بها على حرمة لحوم الخيل والبغال والحمير، ثم <span class="comment-type-2">استدرك</span> قائلًا: «وهذه الحجة غير لازمة عند جماعة من العلماء، قالوا: إنما ذكر الله تعالى عظم منافع الأنعام، وذكر عظم منافع هذه وأهم ما فيها، وليس يقضي ذلك بأن ما ذكره لهذه لا تدخل هذه فيه». ثم ذكر (٥/٣٣١) قول <u>ابن جرير</u> بأن في «إجماعهم على جواز ركوب ما ذكر للأكل دليل على جواز أكل ما ذكر للركوب»، و<span class="comment-type-4">علق</span> قائلًا: «وفي هذا نظر، ولحوم الخيل عند كثير من العلماء حلال، وفي جواز أكلها حديث أسماء بنت أبي بكر، وحديث جابر بن عبد الله: كنا نأكل الخيل في عهد النبي ﷺ. والبغال والحمير مكروهة عند الجمهور، وهو تحقيق مذهب مالك».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كانت الخيل وحشيَّةً، فذلَّلها الله لإسماعيل بن إبراهيم ﵉{22}. (٩/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق زيد بن عطية- قال: بلغني: أنّ الله أراد أن يخلُق الفرس، قال لريح الجنوب: إني خالقٌ منك خلقًا، أجعَلُه عزًّا لأوليائي، ومذلَّةً لأعدائي، وحِمًى لأهل طاعتي. فقبض من الريح قبضة، فخلق منها فرسًا، فقال: سميتك فرسًا، وجعلتُك عربيًّا، الخير معقود بناصيتك، والغنائم مُحازة على ظهرك، والغِنى معك حيث كنت، أرعاك بسعة الرزق على غيرك من الدواب، وجعلتُك لها سيِّدًا، وجعلتُك تطير بلا جناحين، فأنت للطلب، وأنت للهرب، وسأحمل عليك رجالًا يسبِّحوني فتسبِّحُني معهم إذا سبَّحوا، ويهلَّلوني فتهلِّلُني معهم إذا هلَّلُوا، ويكبَّروني فتكبِّرُني معهم إذا كبَّروا. فلما صهل الفرس قال: باركت عليك، أُرهِبُ بصهيلِك المشركين؛ أملأُ منه آذانهم، وأُرعِبُ منه قلوبهم، وأُذِلُّ أعناقهم. فلما عرض الخلق على آدم وسمّاهم قال الله: يا آدم، اختر مِن خلقي من أحببت. فاختار الفرس، فقال الله: اخترت عزَّك وعزَّ ولدك، باقٍ فيهم ما بَقوا، وينتج منه أولادك أولادًا، فبركتي عليك وعليهم. فما من تسبيحة ولا تهليلة ولا تكبيرة تكون من راكب الفرس إلا والفرس يسمَعُها ويجيبُه بمثل قوله{23}. (٩/١٣-١٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَخۡلُقُ مَا لَا تَعۡلَمُونَ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٦٤<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>إن مما خلق الله لأرضًا من لؤلؤة بيضاء مسيرة ألف عام، عليها جبل من ياقوتة حمراء مُحدِقٌ بها، في تلك الأرض ملَك قد ملأ شرقها وغربها، له ستمائة رأس، في كل رأس ستمائة وجه، في كل وجه ستمائة وستون ألف فم، في كل فم ستون ألف لسان، يُثنِي على الله ويقدسه ويهلِّلُه ويكبِّرُه، بكل لسان ستمائة ألف وستين ألف مرة، فإذا كان يوم القيامة نظر إلى عظمة الله، فيقول: وعِزَّتِك، ما عبدتك حق عبادتك. فذلك قوله</b>: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span>»{24}. (٩/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: دخل علينا رسول الله ﷺ ونحن في المسجد حِلقٌ حِلقٌ، فقال لنا: «<b>فيم أنتم؟</b>». قلنا: نتفكر في الشمس كيف طلعت، وكيف غربت؟ قال: «<b>أحسنتم، كونوا هكذا، تفكروا في المخلوق ولا تفكروا في الخالق؛ فإنّ الله خلق ما شاء لما شاء، وتعجبوا من ذلك؛ إنّ من وراء قافٍ سبع بحار، كل بحر خمسمائة عام، ومن وراء ذلك سبع أرضين يضيء نورها لأهلها، ومن وراء ذلك سبعين ألف أمة خلقوا على أمثال الطير، هو وفرخه في الهواء، لا يفترون عن تسبيحة واحدة، ومن وراء ذلك سبعين ألف أُمَّة خلقوا مِن ريح، فطعامهم ريح، وشرابهم ريح، وثيابهم من ريح، وآنيتهم من ريح، ودوابهم من ريح، لا تستقر حوافر دوابهم إلى الأرض إلى قيام الساعة، أعينهم في صدروهم، ينام أحدهم نومة واحدة، ينتبه ورزقه عند رأسه، ومن وراء ذلك سبعين ألف أمة، ومن وراء ذلك ظل العرش، وفي ظل العرش سبعون ألف أمة، ما يعلمون أن الله خلق آدم، ولا ولد آدم، ولا إبليس، ولا ولد إبليس وهو قوله تعالى</b>: <span class="qpc-hafs">﴿ويَخْلُقُ ما لا تَعْلَمُونَ﴾</span>»{25}. (١٤/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٦<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ في قوله: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span>، قال: «<b>البَراذِينُ</b>»{26}. (٩/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span>، قال: السُّوسُ في الثياب{27}<span class=comment-ref>٣٦٤١</span>. (٩/١٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤١</span> ذكر <u>ابن عطية</u> (٥/٣٣٠) رواية «أن الله تعالى خلق ألف نوع من الحيوان، منها في البَرِّ أربعمائة، وبثَّها بأعيانها في البحر، وزاد فيه مائتين ليستا في البَرِّ». ثم <span class="comment-type-4">علَّق</span> عليها بقوله: «وكل من خصَّص في تفسير هذه الآية شيئًا -كقول من قال: سوس الثياب وغير ذلك- فإنما هو على جهة المثال، لا أن ما ذكره هو المقصود في نفسه».</div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق القاسم بن سلمان- قال: إنّ لله عبادًا من وراء الأندلس، كما بيننا وبين الأندلس، ما يرون أنّ الله عصاه مخلوق، رَضراضُهم{28} الدُّرُّ والياقوت، وجبالهم الذهب والفضة، لا يحرُثون ولا يزرعون ولا يعملون عملًا، لهم شجر على أبوابهم لها ثمر هي طعامهم، وشجر لها أوراق عِراض هي لباسهم{29}. (٩/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٦٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، أنه قيل له: أخبرنا من أتى سُفالَةَ الريح{30}، وأنه رأى بها أربع نجوم كأنها أربعة أقمار، فقال وهب: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span>{22}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: يعني: السوس في النبات، والدود في الفواكه{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span> من الخلق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ويخلق ما لا تعلمون﴾</span> من الأشياء كلها مما لم يذكر لكم{34}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٨.|2:أخرجه يحيى بن سلام ١/٥٢.|3:أخرجه عبد الرزاق ١/٣٥٣، وابن جرير ١٤/١٧٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٦٠.|5:تفسير يحيى بن سلام ١/٥٢.|6:أخرجه أحمد ٣١/٩٠ (١٨٧٩٣).</p><p>قال الهيثمي في المجمع ٥/٢٦٥ (٩٣٦٩): «ورجال أحمد رجال الصحيح، خلا عمر بن حسيل من آل حذيفة، ووثقه ابن حبان». وقال الصالحي في سبل الهدى والرشاد ٧/٣٩١ على رجال أحمد: «رجال ثقات».|7:أخرجه أحمد ٢٨/١٨ (١٦٨١٧)، وابن ماجه ٤/٣٥٩، وأبو داود ٥/٦٠٩-٦١٠ (٣٧٩٠)، والنسائي ٧/٢٠٢ (٤٣٣١، ٤٣٣٢). وأورده الثعلبي ٦/٨.</p><p>قال الدارقطني في السنن ٥/٥١٨ (٤٧٧١): «نا أبو سهل بن زياد، قال: سمعت موسى بن هارون، يقول: لا يعرف صالح بن يحيى ولا أبوه إلا بجده، وهذا حديث ضعيف، وزعم الواقدي أن خالد بن الوليد أسلم بعد فتح خيبر».. قال الخطابي في معالم السنن ٤/٢٤٥: «في إسناده نظر، وصالح بن يحيى بن المقدام عن أبيه عن جده لا يعرف سماع بعضهم من بعض». وقال البيهقي في الكبرى ٩/٥٥٠ (١٩٤٤٧): «إسناده مضطرب». وقال ابن عبد البر في التمهيد ١٠/١٢٨: «وهذا حديث لا تقوم به حجة؛ لضعف إسناده». وقال البغوي في شرح السنة ١١/٢٥٥: «وإسناده ضعيف». وقال ابن الجوزي في العلل المتناهية ٢/١٧٠-١٧١ (١٠٩٥): «قال أحمد بن حنبل: هذا حديث منكر». وقال النووي في شرح مسلم ١٣/٩٦: «اتفق العلماء من أئمة الحديث وغيرهم على أنه حديث ضعيف». وقال ابن كثير في تفسيره ٤/٥٥٨: «أخرجه أبو داود والنسائي، وابن ماجه، من حديث صالح بن يحيى بن المقدام -وفيه كلام- به». وقال المناوي في فيض القدير ٦/٣٠٥ (٩٣٤٢): «رمز المصنف -السيوطي- لحسنه، قال أبو داود: منسوخ. وقال البيهقي: إسناده مضطرب. وقال ابن حجر: حديث شاذ منكر». وقال الشوكاني في فتح القدير ٣/١٨١: «في إسناده صالح بن يحيى بن أبي المقدام، وفيه مقال». وقال الألباني في الصحيحة ١/٧٠١: «حديث منكر ضعيف الإسناد».|8:أخرجه البخاري ٧/٩٣ (٥٥١٠، ٥٥١١)، ٧/٩٣-٩٤ (٥٥١٢)، ٧/٩٥ (٥٥١٩)، ومسلم ٣/١٥٤١ (١٩٤٢).|9:أخرجه البخاري ٥/١٣٦ (٤٢١٩)، ٧/٩٥ (٥٥٢٠، ٥٥٢٤)، ومسلم ٣/١٥٤١ (١٩٤١).|10:أخرجه أحمد ٢٣/١٣٦ (١٤٨٤٠)، ٢٣/١٧٧ (١٤٩٠٢)، وأبو داود ٥/٦٠٩ (٣٧٨٩)، وابن حبان ١٢/٧٧-٧٨ (٥٢٧٢)، والحاكم ٤/٢٦٢ (٧٥٨٠)، ويحيى بن سلام ١/٥٢، ٢/٨١٩. وأصله في مسلم ٣/١٥٤١ (١٩٤١).</p><p>وقال الحاكم: «هذا حديث صحيح على شرط مسلم، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٤/٥٥٩: «رواه الإمام أحمد وأبو داود بإسنادين، كل منهما على شرط مسلم». وقال ابن الملقن في البدر المنير ٩/٣٦٠: «هذا الحديث صحيح». وقال الألباني في الإرواء ٨/١٣٨: «وهذا على شرط مسلم، مع أن أبا الزبير مدلس، وقد عنعنه».|11:أخرجه ابن ماجه ٤/٣٥٨ (٣١٩٧)، والنسائي ٧/٢٠١ (٤٣٣٠)، ٧/٢٠٢ (٤٣٣٣)، وابن جرير ١٤/١٧٦ واللفظ له، ويحيى بن سلام ١/٥٢ مختصرًا. وأورده الثعلبي ٦/٨.</p><p>قال ابن عدي في الكامل ٧/٤٣-٤٤: «وهذا عن عطاء هو في جملة ما قال ابن معين أنّ أحاديثه عن عطاء رديئة، ومع هذا فإن الثوري وغيره من الثقات قد حدثوا عنه». وقال ابن القيسراني في ذخيرة الحفاظ ٤/١٨٨٥-١٨٨٦ (٤٣٢٢): «رواه عبد الكريم بن مالك الجزري: عن عطاء، عن جابر. وهذا أيضًا يدخل فيما تكلم به ابن معين أن عبد الكريم عن عطاء أحاديثه رديئة. وأورده في ذكر جابر الجعفي -وزاد فيه: (ونشرب ألبانها)- عن عطاء، عن جابر. وجابر قد تكلموا فيه». وقال الألباني في الصحيحة ١/٧٠٠: «إسناده صحيح».|12:أخرجه عبد الله بن المبارك في مسنده ص١٠٩ (١٨٣)، ويحيى بن سلام ١/٥٢ بنحوه.</p><p>وسنده صحيح.|13:أخرجه ابن أبي شيبة ٨/٧٠، وابن جرير ١٤/١٧٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|14:أخرجه ابن أبي شيبة ٨/٧١، وابن جرير ١٤/١٧٣-١٧٤. وعزاه السيوطي إلى ابن أبي حاتم.|15:أخرجه ابن جرير ١٤/١٧٥.|16:النُّجْعةُ عند العرب: المذهب في طلب الكلأ في موضعه. لسان العرب (نجع).|17:أخرجه ابن جرير ١٤/١٧٥.|18:أخرجه ابن أبي شيبة ٨/٧١.|19:أخرجه ابن جرير ١٤/١٧٤. وعزاه السيوطي إلى ابن المنذر.|20:أخرجه عبد الرزاق ١/١٠٣ (٣٦٢).|21:أخرجه مالك في الموطأ (ت: د. بشار عواد) ١/٦٤١-٦٤٢ (١٤٣٥).|22:عزاه السيوطي إلى ابن أبي حاتم.|23:أخرجه أبو الشيخ في العظمة (١٢٩٤). وعزاه السيوطي إلى ابن أبي حاتم.|24:عزاه السيوطي إلى ابن مردويه.|25:أخرجه أبو الشيخ في العظمة ٤/١٤٨٩-١٤٩١، من طريق أبي الطيب أحمد بن روح، حدثنا علي بن عمرو، عن إبراهيم بن موسى البحراني، عن مقاتل، عن عكرمة، عن ابن عباس به.</p><p>في إسناده من لا يُعرف، وهما: علي بن عمرو، وإبراهيم بن موسى البحراني، لم نجد لهما ترجمة.|26:أخرجه ابن عساكر في تاريخه ٥٥/١٦٥، من طريق الخطيب البغدادي، عن النعيمي، عن عتيق بن عبد الرحمن إمام مسجد أبي عاصم العبّاداني، قال: حدثنا محمد بن محمد بن زكريا اليمامي أبو غانم -قدم علينا-، قال: حدثنا المقدام بن داود، قال: حدثنا عبد الرحمن بن القاسم، عن أشهب، عن مالك، عن الزهري، عن نافع، عن ابن عمر به.</p><p>إسناده ضعيف، قال الخطيب: «سقط بين المقدام وعبد الرحمن سعيد بن بكير عمُّ المقدام». وفيه محمد بن محمد بن زكريا، قال الذهبي في الميزان ٤/٣٠: «ضعَّفه ابنُ عساكر». وانظر: اللسان ٧/٤٨٨.|27:أخرجه ابن عساكر ٥٣/٢١.|28:الرضراض: الحصى الصغار. النهاية (رضرض) ٢/٢٢٩.|29:أخرجه أبو الشيخ في العظمة (٩٥٦)، والبيهقي في الأسماء والصفات (٨٣٠).|30:يقال: قعد في سُفالَة الريح وعُلاوتها. فالعُلاوة من حيث تَهُبُّ، والسُّفالَة ما كان بإزاء ذلك، وقيل: سُفالة كل شيء وعُلاوته أسفله وأعلاه. لسان العرب (سفل).|31:عزاه السيوطي إلى ابن أبي حاتم.|32:تفسير البغوي ٤/١١.|33:تفسير مقاتل بن سليمان ٢/٤٦٠.|34:تفسير يحيى بن سلام ١/٥٣.
  16,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَلَى ٱللَّهِ قَصۡدُ ٱلسَّبِیلِ وَمِنۡهَا جَاۤىِٕرࣱۚ وَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٧٣<span class="dash">-</span></span> عن قتادة ... وفي قراءة <span class="name-1">عبد الله بن مسعود</span>: (ومِنكُمْ جَآئِرٌ){1}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٤<span class="dash">-</span></span> عن <span class="name-1">علي [بن أبي طالب]</span> أنه كان يقرأ هذه الآية: (فَمِنكُمْ جَآئِرٌ){2}. (٩/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٥<span class="dash">-</span></span> عن <span class="name-1">علي [بن أبي طالب]</span> -من طريق عمر- أنه كان يقرأ: (فَمِنكُمْ جَآئِرٌ)، يعني: هذه الأمة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَلَى ٱللَّهِ قَصۡدُ ٱلسَّبِیلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، يقول: البيان{4}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، يقول: على الله أن يبيِّن الهدى والضلالة{5}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٨<span class="dash">-</span></span> قال <span class="name-1">جابر بن عبد الله</span>: <span class="qpc-hafs">﴿قصد السبيل﴾</span>: هو السنة <span class="qpc-hafs">﴿ومنها جائر﴾</span>: يعني بيان الشرائع والفرائض{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، قال: طريق الحق على الله{7}<span class=comment-ref>٣٦٤٢</span>. (٩/١٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٢</span> نقل <u>ابنُ كثير</u> (٨/٢٩٦-٢٩٧) في قوله تعالى: <span class="qpc-hafs">﴿وعَلى اللَّهِ قَصْدُ السَّبِيلِ﴾</span> قول ابن عباس، وقول مجاهد، والضحاك، وقتادة، ونقل عن السدي أن <span class="qpc-hafs">﴿قصد السبيل﴾</span> معناه: الإسلام. ثم <span class="comment-type-4">علَّق</span> بقوله: «وقول مجاهد هاهنا أقوى <span class="mustanad">من حيث السياق</span>؛ لأنه تعالى أخبر أن ثَمَّ طرقًا تسلك إليه، فليس يصل إليه منها إلا طريق الحق، وهي الطريق التي شرعها ورضيها، وما عداها مسدودة، والأعمال فيها مردودة».</div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، قال: إنارتها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، قال: على الله البيان، يبين الهدى من الضلالة، ويبين السبيل التي تفرقت عن سبله، <span class="qpc-hafs">﴿ومنها جائر﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، قال: على الله بيان حلاله وحرامه، وطاعته ومعصيته{10}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال سبحانه: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، يعني: بيان الهدى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٤<span class="dash">-</span></span> قال <span class="name-3">عبد الله بن المبارك</span>: <span class="qpc-hafs">﴿قصد السبيل﴾</span>: السُّنَّة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span>، قال: طريق الهدى{13}<span class=comment-ref>٣٦٤٣</span>. (٩/١٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٣</span> <span class="comment-type-4">بيَّن</span> <u>ابنُ عطية</u> (٥/٣٣١) أن معنى: <span class="qpc-hafs">﴿وعَلى اللَّهِ قَصْدُ السَّبِيلِ﴾</span> «أي: على الله تقويم طريق الهدى وتبيينه، وذلك بنصب الأدلة وبعث الرسل، وإلى هذا ذهب المتأوِّلون». ثم ذكر <b>احتمالًا آخر</b>: «أن يكون المعنى: إن من سلك السبيل القاصد فعلى الله رحمته ونعيمه وطريقه، وإلى ذلك مصيره». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فيكون هذا مثل قوله تعالى: <span class="qpc-hafs">﴿هَذا صِراطٌ مُسْتَقِيمٌ﴾</span> [آل عمران:٥١]، وقول النبي ﷺ:»والشَّرُّ ليس إليك«. أي: لا يُفضي إلى رحمتك».</p><p>ونقل <u>ابنُ تيمية</u> (٤/١٥٢) <b>قولًا</b> ولم ينسبه: أن «معنى قصد السبيل: سيركم ورجوعكم، والسبيل واحدة بمعنى الجمع». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى دلالة اللغة، ولفظ الآية</span> قائلًا: «هذا قول بعض المتأخرين، جعل القصد بمعنى: الإرادة، أي: عليه قصدكم للسبيل في ذهابكم ورجوعكم، وهو كلام مَن لم يفهم الآية، فإنّ السبيل القصد هي السبيل العادلة، أي: عليه السبيل القصد، والسبيل اسم جنس، ولهذا قال: <span class="qpc-hafs">﴿ومِنها جائِرٌ﴾</span>. أي: عليه القصد من السبيل، ومن السبيل جائر، فأضافه إلى اسم الجنس إضافة النوع إلى الجنس، أي: القصد من السبيل، كما تقول: ثوب خز. ولهذا قال: <span class="qpc-hafs">﴿ومِنها جائِرٌ﴾</span>. وأمّا من ظن أن التقدير: قصدكم السبيل. فهذا لا يطابق لفظ الآية ونظمها من وجوه متعددة».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٣٣٢) أن «الألف واللام في <span class="qpc-hafs">﴿السَّبِيلِ﴾</span> للعهد، وهي سبيل الشرع، وليست للجنس، ولو كانت للجنس لم يكن فيها جائر».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابن تيمية</u> (٤/١٥٥) <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وأما قوله: <span class="qpc-hafs">﴿قَصْدُ السَّبِيلِ﴾</span> هي سبيل الشرع، وهي سبيل الهدى، والصراط المستقيم، وأنها لو كانت للجنس لم يكن منها جائر، فهذا أحد الوجهين في دلالة الآية، وهو مرجوح، والصحيح الوجه الآخر: أن السبيل اسم جنس، ولكن الذي على الله: هو القصد منها، وهي سبيل واحدة، ولما كان جنسًا قال: <span class="qpc-hafs">﴿ومِنها جائِرٌ﴾</span>، والضمير يعود على ما ذُكِرَ بلا تكلف. وقوله: لو كان للجنس لم يكن منها جائر. ليس كذلك، فإنها ليست كلها عليه، بل إنما عليه القصد منها، وهي سبيل الهدى، والجائر ليس من القصد، وكأنه ظن أنه إذا كانت للجنس يكون عليه قصد كل سبيل، وليس كذلك، بل إنما عليه سبيل واحدة، وهي الصراط المستقيم، هي التي تدل عليه، وسائرها سبل الشيطان، كما قال: <span class="qpc-hafs">﴿وأَنَّ هَذا صِراطِي مُسْتَقِيمًا فاتَّبِعُوهُ ولا تَتَّبِعُوا السُّبُلَ فَتَفَرَّقَ بِكُمْ عَنْ سَبِيلِهِ﴾</span> [الأنعام:١٥٣]، وقد أحسن في هذا الاحتمال، وفي تمثيله ذلك بقوله: <span class="qpc-hafs">﴿هَذا صِراطٌ عَلَيَّ مُسْتَقِيمٌ﴾</span> [الحجر:٤١]».</div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وعلى الله قصد السبيل﴾</span> والسبيل: قصد الطريق؛ الهدى إلى الجنة، كقوله: <span class="qpc-hafs">﴿إن علينا للهدى﴾</span> [الليل:١٢]، وكقوله: <span class="qpc-hafs">﴿قال هذا صراط علي مستقيم﴾</span> [الحجر:٤١]{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡهَا جَاۤىِٕرࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ومنها جائر﴾</span>، قال: الأهواء المختلفة{4}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ومنها جائر﴾</span>، قال: السُّبُلُ المتفرقة{5}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿ومنها جائر﴾</span>، يعني: السبل التي تفرَّقت عن سبيله{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومنها جائر﴾</span>، قال: مِن السُّبُل ناكِبٌ عن الحق{18}. (٩/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومنها جائر﴾</span>، يقول: ومِن السبيل ما تكون جائرة على الهدى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ومنها جائر﴾</span>: السبل المتفرقة عن سبيله{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٣<span class="dash">-</span></span> قال <span class="name-3">عبد الله بن المبارك</span>: <span class="qpc-hafs">﴿ومنها جائر﴾</span>: الأهواء والبِدَع{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومنها جائر﴾</span>، قال: من السبل جائر عن الحق. وقرأ: <span class="qpc-hafs">﴿ولا تتبعوا السبل فتفرق بكم عن سبيله﴾</span> [الأنعام:١٥٣]{13}. (٩/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومنها جائر﴾</span>: ومن السبيل جائر، أي: عن السبيل جائر، وهو الكافر، جار عن سبيل الهدى. وجار عنها، وجار منها؛ واحِدٌ{14}<span class=comment-ref>٣٦٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٤</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٥/٣٣٢) احتمالين لعود الضمير في قوله تعالى: <span class="qpc-hafs">﴿ومِنها جائِرٌ﴾</span>: <b>الأول:</b> أن يعود الضمير على «السبل» التي يتضمنها معنى الآية، كأنه قال: ومن السبل جائر. ويكون المراد: طريق اليهود والنصارى وغيرهم كعباد الأصنام. <b>الثاني:</b> أن يعود الضمير على سبيل الشرع المذكورة، وتكون «مِن» للتبعيض، ويكون المراد: فرق الضلالة من أمة محمد ﷺ، كأنه قال: ومن بنيات الطريق في هذه السبيل ومن شعبها جاير.</p><p>و<span class="comment-type-2">استدرك</span> عليه <u>ابن تيمية</u> (٤/١٥٥) قائلًا: «سبيل أهل البدع جائرة خارجة عن الصراط المستقيم فيما ابتدعوا فيه، ولا يقال: إن ذلك من السبيل المشروعة».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولو شاء لهداكم أجمعين﴾</span> إلى دينه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولو شاء لهداكم أجمعين﴾</span> لقصد السبيل الذي هو الحق. وقرأ: <span class="qpc-hafs">﴿ولو شاء ربك لآمن من في الأرض كلهم جميعًا﴾</span> [يونس:٩٩]، وقرأ: <span class="qpc-hafs">﴿ولو شئنا لأتينا كل نفس هُداها﴾</span> [السجدة:١٣]{17}. (٩/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ولو شاء لهداكم أجمعين﴾</span> مثل قوله: <span class="qpc-hafs">﴿ولو شاء ربك لآمن من في الأرض كلهم جميعا﴾</span> [يونس:٩٩]، وكقوله: <span class="qpc-hafs">﴿أفلم ييئس الذين آمنوا﴾</span>: أفلم يتبين للذين آمنوا <span class="qpc-hafs">﴿أن لو يشاء الله لهدى الناس جميعا﴾</span> [الرعد:٣١]{14}<span class=comment-ref>٣٦٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٥</span> <span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٥/٣٣٢) عن الزجاج أن قوله تعالى: <span class="qpc-hafs">﴿ولَوْ شاءَ لَهَداكُمْ أجْمَعِينَ﴾</span> «معناه: لو شاء لعرض عليكم آية تضطركم إلى الإيمان والاهتداء». ثم <span class="comment-type-2">انتقده</span> بقوله: «وهذا قول سوءٍ لأهل البدع الذين يرون الله لا يخلق أفعال العباد؛ لم يُحَصِّله الزجاج، ووقع فيه رحمة الله عليه عن غير قصد».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/١٧٩. وعلقه يحيى بن سلام ١/٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.</p><p>(ومِنكُمْ جَآئِرٌ)، و(فَمِنكُمْ جَآئِرٌ) قراءة شاذة. انظر: مختصر ابن خالويه ص٧٦.|2:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن الأنباري في المصاحف.|3:أخرجه ابن الأعرابي في معجمه ٢/٦٤٧ (١٢٨٦).|4:أخرجه ابن جرير ١٤/١٧٧، ١٧٩، ١٨٠، وابن أبي حاتم -كما في الإتقان ٢/٢٣-. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٤/١٧٨-١٧٩. وعزاه السيوطي إلى ابن أبي حاتم.|6:تفسير الثعلبي ٦/٩، وفي تفسير البغوي ٤/١١ بلفظ<span class="qpc-hafs">﴿قصد السبيل﴾</span>: بيان الشرائع والفرائض.|7:أخرجه يحيى بن سلام ١/٥٣ -من طريق ابن مجاهد-، وابن جرير ١٤/١٧٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٤/١٧٩.|9:أخرجه ابن جرير ١٤/١٧٩.|10:أخرجه يحيى بن سلام ١/٥٣، وابن جرير ١٤/١٧٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٤٦٠.|12:تفسير الثعلبي ٦/٩، وتفسير البغوي ٤/١١.|13:أخرجه ابن جرير ١٤/١٧٨، ١٨٠.|14:تفسير يحيى بن سلام ١/٥٣.|15:أخرجه ابن جرير ١٤/١٧٧، ١٧٩، ١٨٠، وابن أبي حاتم -كما في الإتقان ٢/٢٣-. وعزاه السيوطي إلى ابن المنذر.|16:أخرجه ابن جرير ١٤/١٧٨-١٧٩. وعزاه السيوطي إلى ابن أبي حاتم.|17:أخرجه ابن جرير ١٤/١٨٠.|18:أخرجه ابن جرير ١٤/١٧٩ بلفظ: أي: من السبل؛ سبل الشيطان. وعلقه يحيى بن سلام ١/٥٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|19:تفسير مقاتل بن سليمان ٢/٤٦٠.|20:أخرجه ابن جرير ١٤/١٨٠.|21:تفسير الثعلبي ٦/٩، وتفسير البغوي ٤/١١. وجاء فيهما عقبه: دليله قوله تعالى: <span class="qpc-hafs">﴿وأن هذا صراطي مستقيما فاتبعوه ولا تتبعوا السبل﴾</span> [الأنعام:١٥٣].|22:أخرجه ابن جرير ١٤/١٧٨، ١٨٠.|23:تفسير يحيى بن سلام ١/٥٣.|24:تفسير مقاتل بن سليمان ٢/٤٦٠.|25:أخرجه ابن جرير ١٤/١٨٠.|26:تفسير يحيى بن سلام ١/٥٣.
  16,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِیۤ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰۖ لَّكُم مِّنۡهُ شَرَابࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٨٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هو الذي أنزل من السماء ماء لكم منه شراب﴾</span>، يعني: المطر لكم منه شراب{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡهُ شَجَرࣱ فِیهِ تُسِیمُونَ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق خُصيف، عن عكرمة- في قوله: <span class="qpc-hafs">﴿فيه تُسيمون﴾</span>، قال: تُرعُون فيه أنعامكم{2}. (٩/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أن نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿فيه تُسيمون﴾</span>. قال: فيه تُرعُون. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمِعتَ الأعشى وهو يقول:</p><p>ومشى القوم بالعِمادِ إلى الرَّزْحى{3} وأعيا المُسِيمُ{4} أين المَساقُ{5}. (٩/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٢<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبد الرحمن بن أبزى</span> -من طريق طلحة القناد- قال: فيه تُرْعُون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: <span class="qpc-hafs">﴿تسيمون﴾</span>: تُرعُون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر-: فيه تُرعُون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النضر بن عربي- <span class="qpc-hafs">﴿ومنه شجر فيه تسيمون﴾</span>، قال: تُرعُون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿شجر فيه تسيمون﴾</span>، يقول: تُرعُون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿شجر فيه تسيمون﴾</span>، قال: تُرعُون{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومنه شجر فيه تسيمون﴾</span>، يعني: وفيه تُرعُون أنعامكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٠٩<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿ومنه شجر فيه تسيمون﴾</span>، قال: المراعي{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩١٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومنه شجر فيه تسيمون﴾</span>، قال: تُرْعُون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿هو الذي أنزل من السماء ماء لكم منه شراب ومنه شجر فيه تسيمون﴾</span>: تُرعُون أنعامكم؛ تُسَرِّحونها فيه{15}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦١.|2:أخرجه ابن جرير ١٤/١٨٢، وابن أبي حاتم -كما في الإتقان ٢/٣٢، والتغليق ٤/٢٣٦-، وابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٧)-. وعزاه السيوطي إلى ابن المنذر.|3:الرزحي: جمع الرزاح، وهي الإبل الشديدة الهزال التي لا تتحرك، الهالكة هزالًا. اللسان (رزح).|4:المسيم: الراعي. اللسان (سوم).|5:أخرجه الطستي -كما في الإتقان ٢/١٠٠-.|6:أخرجه ابن جرير ١٤/١٨٢.|7:أخرجه يحيى بن سلام ١/٥٤.|8:أخرجه ابن جرير ١٤/١٨٢.|9:أخرجه ابن جرير ١٤/١٨١.|10:أخرجه عبد الرزاق في تفسيره ٢/٣٥٤ من طريق معمر، وابن جرير ١٤/١٨٢.|11:أخرجه أبو جعفر الرملي في جزئه ص٩٦ (تفسير عطاء الخراساني).|12:تفسير مقاتل بن سليمان ٢/٤٦١.|13:تفسير الثوري ص١٦٤.|14:أخرجه ابن جرير ١٤/١٨٣.|15:تفسير يحيى بن سلام ١/٥٣.
  16,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُنۢبِتُ لَكُم بِهِ ٱلزَّرۡعَ وَٱلزَّیۡتُونَ وَٱلنَّخِیلَ وَٱلۡأَعۡنَـٰبَ وَمِن كُلِّ ٱلثَّمَرَ ٰ⁠تِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ينبت لكم به﴾</span> بالمطر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ينبت لكم به﴾</span> بذلك الماء{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩١٤<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span> قال: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span>، يعني: لعبرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩١٥<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span> قال: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span>، يعني: لَعبرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الزرع والزيتون والنخيل والأعناب ومن كل الثمرات إن في ذلك لآية﴾</span> فيما ذُكِر لكم من النبات لَعِبرة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لقوم يتفكرون﴾</span> في توحيد الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لقوم يتفكرون﴾</span> وهم المؤمنون. قال: فالذي ينبت من ذلك الماء الواحد هذه الألوان المختلفة قادرٌ على أن يحيي الأموات{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝١١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٩١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿الزرع والزيتون والنخيل والأعناب ومن كل الثمرات﴾</span>، سمعتُ بعض أشياخنا يذكرُ: أنّ الله أهبط من الجنة إلى الأرض ثلاثين ثمرة؛ عشر يؤكل داخلها ولا يؤكل خارجها، وعشر يؤكل خارجها ولا يؤكل داخلها، وعشر يؤكل داخلها وخارجها{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦١.|2:تفسير يحيى بن سلام ١/٥٤.|3:علَّقه يحيى بن سلام ١/٥٤.|4:علَّقه يحيى بن سلام ١/٥٤.|5:تفسير مقاتل بن سليمان ٢/٤٦١.|6:تفسير مقاتل بن سليمان ٢/٤٦١.|7:تفسير يحيى بن سلام ١/٥٤.|8:تفسير يحيى بن سلام ١/٥٤.
  16,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَسَخَّرَ لَكُمُ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ وَٱلنُّجُومُ مُسَخَّرَ ٰ⁠تُۢ بِأَمۡرِهِۦۤۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝١٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٢٠<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span> مكان <span class="qpc-hafs">﴿والنُّجُومُ مُسَخَّراتٌ﴾</span>: (والرِّياحُ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٢١<span class="dash">-</span></span> قال سفيان الثوري: كان <span class="name-2">أصحاب عبد الله</span> يقرؤونها: <span class="qpc-hafs">﴿وسَخَّرَ لَكُمُ اللَّيْلَ والنَّهارَ والشَّمْسَ والقَمَرَ والنُّجُومُ﴾</span>، ويقرءونها (الرِّياحُ مُسَخَّراتٌ بِأَمْرِهِ){2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَخَّرَ لَكُمُ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ وَٱلنُّجُومُ مُسَخَّرَ ٰ⁠تُۢ بِأَمۡرِهِۦۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وسخر لكم الليل والنهار﴾</span> يختلفان عليكم، <span class="qpc-hafs">﴿والشمس والقمر والنجوم مسخرات﴾</span> تجري <span class="qpc-hafs">﴿بأمره﴾</span>، يُذَكِّر عباده نعمته عليهم{3}<span class=comment-ref>٣٦٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٣/٣٨٢ ط: دار الكتب العلمية) أنّ مِن منافع النجوم أنها هدايات، «ولهذا الوجْه عدت في جملة النعم على بني آدم، ومن النعمة بها ضياؤها أحيانًا». ثم نقل عن الزجاج أن من النعمة بها أيضًا: «علم عدد السنين والحساب بها». ثم <span class="comment-type-4">علق</span> قائلًا: «وفي هذا نظر».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآيات﴾</span> يقول: فيما سخر لكم في هذه الآيات لعبرة <span class="qpc-hafs">﴿لقوم يعقلون﴾</span> في توحيد الله ﷿{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يعقلون﴾</span> وهم المؤمنون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٠.</p><p>وهي قراءة شاذة.|2:تفسير الثوري ص١٦٤.|3:تفسير يحيى بن سلام ١/٥٤.|4:تفسير مقاتل بن سليمان ٢/٤٦١.|5:تفسير يحيى بن سلام ١/٥٤.
  16,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا ذَرَأَ لَكُمۡ فِی ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما ذرأ لكم في الأرض﴾</span>، قال: وما خلق لكم في الأرض{1}. (٩/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما ذرأ لكم﴾</span> يعني: وما خلق لكم <span class="qpc-hafs">﴿في الأرض﴾</span> من الدوابِّ، والطير، والشجر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُخۡتَلِفًا أَلۡوَ ٰ⁠نُهُۥۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٢٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿مختلفا ألوانه﴾</span> من النبات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿مختلفًا﴾</span>: من الدواب، والشجر، والثمار؛ نِعَمٌ من الله متظاهرة، فاشكروها لله{4}<span class=comment-ref>٣٦٤٧</span>. (٩/٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٣٣٦) أن قوله تعالى: <span class="qpc-hafs">﴿ألْوانُهُ﴾</span> «معناه: أصنافه، كما تقول: هذه ألوان من الثَّمر ومن الطعام، ومن حيث كانت هذه المبثوثات في الأرض أصنافًا عُدَّت في النعمة، وظهر الانتفاع بها أنه على وجوه، ولا يظهر ذلك من حيث هي متلونة حُمرة وصُفرة وغير ذلك، ويحتمل أن يكون التنبيه على اختلاف الألوان حمرة وصفرة». ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأول أبْيَن».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَذَّكَّرُونَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك﴾</span> يعني: فيما ذكر من الخلق في الأرض <span class="qpc-hafs">﴿لآية لقوم يذكرون﴾</span> في توحيد الله ﷿، وما ترون من صنعه وعجائبه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٣٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> لعبرة <span class="qpc-hafs">﴿لقوم يذكرون﴾</span> وهم المؤمنون{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/٥٤، وابن جرير ١٤/١٨٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٦١.|3:علَّقه يحيى بن سلام ١/٥٤.|4:أخرجه ابن جرير ١٤/١٨٤. وعلقه يحيى بن سلام ١/٥٤ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٤٦١.|6:تفسير يحيى بن سلام ١/٥٤.
  16,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی سَخَّرَ ٱلۡبَحۡرَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وهو الذي سخر البحر﴾</span>: خلق البحر{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِتَأۡكُلُوا۟ مِنۡهُ لَحۡمࣰا طَرِیࣰّا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وهو الذي سخر البحر لتأكلوا منه لحمًا طريًا﴾</span>، يعني: حيتان البحر{2}. (٩/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٣٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لتأكلوا منه لحمًا طريًا﴾</span>، قال: هو السمك، وما فيه من الدواب{3}. (٩/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهو الذي سخر البحر لتأكلوا منه لحما طريا﴾</span>، وهو السمك ما أصيد{4}، أو ألقاه الماء وهو حي{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِتَأۡكُلُوا۟ مِنۡهُ لَحۡمࣰا طَرِیࣰّا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- أنه سُئِل عن رجل قال لامرأته: إن أكَلتِ لحمًا فأنت طالق. فأكَلَتْ سمكًا. قال: هي طالق؛ قال الله: <span class="qpc-hafs">﴿لتأكلوا منه لحمًا طريًا﴾</span>{6}. (٩/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٣٦<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق ابن جريج- قال: يحنَثُ؛ قال الله: <span class="qpc-hafs">﴿لتأكلوا منه لحمًا طريًا﴾</span>{6}. (٩/٢٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَسۡتَخۡرِجُوا۟ مِنۡهُ حِلۡیَةࣰ تَلۡبَسُونَهَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وتستخرجوا منه حليةً تلبَسُونها﴾</span>، قال: هذا اللؤلؤ{8}. (٩/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتستخرجوا منه حلية تلبسونها﴾</span>، يعني: اللؤلؤ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٣٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وتستخرجوا منه حلية تلبسونها﴾</span> اللؤلؤ{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَسۡتَخۡرِجُوا۟ مِنۡهُ حِلۡیَةࣰ تَلۡبَسُونَهَاۖ﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٤٠<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر [الباقر]</span> -من طريق إسماعيل بن عبد الملك- قال: ليس في الحُلِيِّ زكاة. ثم قرأ: <span class="qpc-hafs">﴿وتستخرجوا منه حليةً تلبسونها﴾</span>{11}. (٩/٢٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَرَى ٱلۡفُلۡكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وترى الفلك﴾</span>، يعني: السفن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وترى الفلك﴾</span> السفن{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَوَاخِرَ فِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وترى الفلك مواخر﴾</span>، قال: جواري{14}. (٩/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: تَمخُرُ السفنُ الرياحَ، ولا تمخر الريحَ من السفنِ إلا الفلكُ العظام{15}. (٩/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: السفينتان تجريان بريح واحدة، كل واحدة مستقبلة الأخرى{16}. (٩/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي مكين- <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: تَشُقُّ الماءَ بصدرها{17}. (٩/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي بكر الأصم- في قوله: <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: ما أُخِذَ عن يمين السفينة وعن يسارها من الماء فهو المواخر{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يزيد بن إبراهيم- <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: مقبلة ومدبرة بريح واحدة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: المواقِرُ{20}{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: تجري فيه متعرضة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد، ومعمر- في قوله: <span class="qpc-hafs">﴿وترى الفلك مواخر فيه﴾</span>، قال: تجري بريح واحدة، مقبلة ومدبرة{23}. (٩/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مواخر فيه﴾</span>، يعني: في البحر مقبلة ومدبرة بريح واحد{5}<span class=comment-ref>٣٦٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٤٨</span> ذكر <u>ابن عطية</u> (٥/٣٣٧) أن «المَخْرَ في اللغة: الصوت الذي يكون من هبوب الرِّيح على شيءٍ يُشَقُّ، أو يصحب في الجملة الماء. فيترتب منه أن يكون»المَخْرَ«من الريح، وأن يكون من السفينة ونحوها، وهو في هذه الآية من السفن. ثم نقل عن»بعض اللغويين أن «المَخْر» في كلام العرب: الشَّقُّ، يقال: مَخَرَ الماء في الأرض«. ثم <span class="comment-type-4">علَّق</span> بقوله:»فهذا بيِّنٌ أن يقال فيه للفلك: مواخر«. ونقل أيضًا قول الضحاك، وقول الحسن من طريق يزيد بن إبراهيم، وقتادة، ومقاتل، أن <span class="qpc-hafs">﴿مَواخِرَ﴾</span> معناه: تجيء وتذهب بريح واحدة، ثم <span class="comment-type-4">علَّق</span> على ما سبق بقوله:»وهذه الأقوال ليست تفسيرًا لِلَّفظة، وإنما أرادوا بها أنها مواخر لهذه الأحوال، فنَصُّوا على هذه الأحوال، إذ هي موضع النعم المعدودة، إذ نَفْس كون الفلك ماخرة لا نعمة فيه، وإنما النعمة في مخرها بهذه الأحوال في التجارات، والسفر فيها، وما يمنح الله فيها من الأرباح والمِنَن".</p><p>وذكر <u>ابنُ كثير</u> (٨/٢٩٩ بتصرف) «أن السفن تمخر البحر، أي: تشقه، وقيل: تمخر الرياح،». ثم <span class="comment-type-4">علَّق</span> عليهما بقوله: «وكلاهما صحيح».</div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿مواخر﴾</span>، قال: تمخر الريحَ{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبعضهم يقول: <span class="qpc-hafs">﴿مواخر فيه﴾</span>، يعني: شقها الماء في وقت جريها{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولتبتغوا من فضله﴾</span>، قال: تجارة البرِّ والبحر{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ولتبتغوا من فضله﴾</span>، قال: هو التجارة{3}. (٩/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولتبتغوا من فضله﴾</span>، يعني: سخَّر لكم الفلك لتبتغوا من فضله{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولعلكم تشكرون﴾</span> ربَّكم في نِعَمه ﷿{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولعلكم تشكرون﴾</span> ولكي تشكروا. هي مثل قوله: <span class="qpc-hafs">﴿لعلكم تسلمون﴾</span> [النحل:٨١]{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٩٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>: أنّه كان يكره ركوب البحر إلا لثلاث: غازٍ، أو حاجٍّ، أو معتمر{32}. (٩/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩٦١<span class="dash">-</span></span> عن <span class="name-2">مطر الوراق</span>: أنه كان لا يرى بركوب البحر بأسًا، وقال: ما ذكره الله في القرآن إلا بخير{3}. (٩/٢٠)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ١/٥٤.|2:أخرجه ابن جرير ١٤/١٨٥-١٨٦. وعلقه يحيى بن سلام ١/٥٤. وعزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:كذا في الأصل.|5:تفسير مقاتل بن سليمان ٢/٤٦١.|6:أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٥٣.|7:أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٥٣.|8:أخرجه ابن جرير ١٤/١٨٥-١٨٦. وعزاه السيوطي إلى ابن أبي حاتم.|9:تفسير مقاتل بن سليمان ٢/٤٦١.|10:تفسير يحيى بن سلام ١/٥٤.|11:أخرجه ابن أبي شيبة ٣/١٥٥، وابن جرير ١٤/١٨٦ بنحوه.|12:تفسير مقاتل بن سليمان ٢/٤٦١.|13:تفسير يحيى بن سلام ١/٥٥.|14:أخرجه ابن جرير ١٩/٣٤٦-٣٤٧، وابن أبي حاتم -كما في الإتقان ٢/٢٣-.|15:أخرجه ابن جرير ١٤/١٨٧. وعلقه يحيى بن سلام ١/٥٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|16:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|17:أخرجه ابن جرير ١٤/١٨٦-١٨٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|18:أخرجه ابن جرير ١٤/١٨٦.|19:أخرجه ابن جرير ١٤/١٨٨.|20:الواو والقاف والراء: أصل يدل على ثِقل في الشيء. معجم مقاييس اللغة (وقر).|21:أخرجه ابن جرير ١٤/١٨٦. وفي تفسير البغوي ٤/١٢ بلفظ: مملوءة.|22:أخرجه ابن جرير ١٤/١٨٧.|23:أخرجه يحيى بن سلام ١/٥٥، وابن جرير ١٤/١٨٧-١٨٨.|24:تفسير مقاتل بن سليمان ٢/٤٦١.|25:أخرجه ابن جرير ١٤/١٨٧.|26:تفسير يحيى بن سلام ١/٥٥.|27:أخرجه ابن جرير ١٤/١٨٨. وعلقه يحيى بن سلام ١/٥٥ بلفظ: طلب التجارة في السفن.|28:عزاه السيوطي إلى ابن أبي حاتم.|29:تفسير مقاتل بن سليمان ٢/٤٦١.|30:تفسير مقاتل بن سليمان ٢/٤٦١.|31:تفسير يحيى بن سلام ١/٥٥.|32:أخرجه عبد الرزاق (٩٦٢٨).|33:عزاه السيوطي إلى ابن أبي حاتم.