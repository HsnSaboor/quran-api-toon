tafsir[8]{c,v,t}:
16,7," <q>﴿وَتَحۡمِلُ أَثۡقَالَكُمۡ﴾</q> - تفسير ٤٠٨٢٨- تفسير الحسن البصري: أنّها الإبل والبقر{1}. (ز) ٤٠٨٢٩- قال مقاتل بن سليمان: <q>﴿وتحمل أثقالكم﴾</q> يعني: الإبل، والبقر <q>﴿إلى بلد﴾</q>{2}٣٦٣٧. (ز) ٣٦٣٧ ذكر ابنُ عطية (٥/٣٢٩) أن «الأثقال: الأمتعة». ونقل احتمالًا آخر أن «المراد هنا الأجسام، كقوله تعالى: <q>﴿وأَخْرَجَتِ الأَرْضُ أثْقالَها﴾</q> [الزلزلة:٢]، أي: بني آدم». ثم علَّق بقوله: «واللفظ يحتمل المعنيين». <q>﴿إِلَىٰ بَلَدࣲ﴾</q> - تفسير ٤٠٨٣٠- عن عبد الله بن عباس، في قوله: <q>﴿وتحمِل أثقالكم إلى بلد﴾</q>، قال: يعني: مكة{3}. (٩/١١) ٤٠٨٣١- عن عكرمة مولى ابن عباس -من طريق سماك- <q>﴿إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</q>، قال: البلد: مكة{4}٣٦٣٨. (ز) ٣٦٣٨ علَّق ابن عطية (٥/٣٢٩) على قول ابن عباس وعكرمة بقوله: «وفي الآية -على هذا- حضٌّ مّا على الحج». ٤٠٨٣٢- قال يحيى بن سلّام: <q>﴿وتحمل أثقالكم إلى بلد لم تكونوا بالغيه﴾</q> إلى البلد الذي تريدونه{5}. (ز) <q>﴿لَّمۡ تَكُونُوا۟ بَـٰلِغِیهِ إِلَّا بِشِقِّ ٱلۡأَنفُسِۚ﴾</q> - تفسير ٤٠٨٣٣- عن عبد الله بن عباس، في قوله: <q>﴿لم تكونوا بالغيه إلا بِشِقِ الأنفُس﴾</q>، قال: لو تَكَلَّفْتُموه لم تُطيقوه إلا بجهد شديد{3}. (٩/١١) ٤٠٨٣٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلا بِشِقِ الأنفُس﴾</q>، قال: مشقَّة عليكم{7}. (٩/١٢) ٤٠٨٣٥- عن عكرمة مولى ابن عباس -من طريق جابر- <q>﴿إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</q>، قال: لو تُكلَّفونه لم تبلغوه إلا بجهد شديد{8}. (ز) ٤٠٨٣٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وتحمل أثقالكم إلى بلد لم تكونوا بالغيه إلا بشق الأنفس﴾</q>، يقول: بجهد الأنفس{9}. (ز) ٤٠٨٣٧- قال مقاتل بن سليمان: <q>﴿لم تكونوا بالغيه إلا بشق الأنفس﴾</q>، يعني: بجهد الأنفس{2}. (ز) ٤٠٨٣٨- قال يحيى بن سلّام: <q>﴿إلا بشق الأنفس﴾</q> لولا أنها تحمل أثقالكم لم تكونوا بالغي ذلك البلد إلا بمشقة على أنفسكم{5}٣٦٣٩. (ز) ٣٦٣٩ نقل ابنُ عطية (٥/٣٣٠) عن الفراء أن معنى «<q>﴿بِشِقِّ الأَنْفُس﴾</q> أي: بذهاب نصفها، كأنها قد ذابت تعبًا ونصبًا». ثم علَّق عليه بقوله: «كما تقول لرجل: لا تقدر على كذا إلا بذهاب جُلِّ نفسك، وبقطعة من كبدك. ونحو هذا من المجاز». <q>﴿إِنَّ رَبَّكُمۡ لَرَءُوفࣱ رَّحِیمࣱ ۝٧﴾</q> - تفسير ٤٠٨٣٩- قال مقاتل بن سليمان: <q>﴿إن ربكم لرؤوف﴾</q> يعني: لرفيق <q>﴿رحيم﴾</q> بكم فيما جعل لكم من الأنعام من المنافع{2}. (ز) ٤٠٨٤٠- قال يحيى بن سلّام: قال: <q>﴿إن ربكم لرءوف رحيم﴾</q>، يقول: فبرأفة الله ورحمته سخر لكم هذه الأنعام، وهي للكافر رحمة الدنيا: المعايش، والنعم التي رزقه الله{13}. (ز) <q>﴿إِنَّ رَبَّكُمۡ لَرَءُوفࣱ رَّحِیمࣱ ۝٧﴾</q> - آثار متعلقة بالآية ٤٠٨٤١- عن أبي هريرة، عن النبي ﷺ، قال: «إيّاكم أن تتخذوا ظهور دوابِّكم منابر؛ فإنّ الله تعالى إنما سخَّرها لكم لتبلُغوا إلى بلد لم تكونوا بالغيه إلا بشقِّ الأنفس، وجعل لكم الأرض، فعليها فاقضُوا حاجاتِكم»{14}. (٩/١٢) ",footnotes:1:علَّقه يحيى بن سلام ١/٥١.تفسير مقاتل بن سليمان ٢/٤٦٠.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/١٧٠.تفسير يحيى بن سلام ١/٥١.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/١٧٠. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/١٦٩-١٧٠.أخرجه يحيى بن سلام ١/٥٢، وعبد الرزاق في تفسيره ٢/٣٥٣ من طريق معمر، وابن جرير ١٤/١٧٠.تفسير مقاتل بن سليمان ٢/٤٦٠.تفسير يحيى بن سلام ١/٥١.تفسير مقاتل بن سليمان ٢/٤٦٠.تفسير يحيى بن سلام ١/٥٢.أخرجه أبو داود ٤/٢١٤ (٢٥٦٧)، والبيهقي في الشعب ١٣/٤٢٤ (١٠٥٧٢) واللفظ له. قال ابن القطان في بيان الوهم والإيهام ٥/٧٥-٧٦ (٢٣١٩): «وإنما الذي ينظر في أمره من هذا الإسناد أبو مريم؛ وهو مولى أبي هريرة، ولا يعرف له حال...، فما مثل هذا الحديث صُحِّح». وقال ابن مفلح في الآداب الشرعية ٣/٣٥٩: «رواه أبو داود، وهو حديث حسن». وقال المناوي في التيسير ١/٤٠٧ عن إسناد أبي داود: «إسناد ضعيف». وقال الألباني في صحيح أبي داود ٧/٣٢٠ (٢٣١٣): «إسناده صحيح».
16,8," <q>﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</q> - قراءات ٤٠٨٤٢- عن قتادة، أنّ أبا عياض كان يقرؤها: (والخَيْلَ والبِغالَ والحَمِيرَ لِتَرْكَبُوها زِينَةً). يقول: جعلها زينة{1}. (٩/١٣) <q>﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</q> - تفسير الآية ٤٠٨٤٣- في تفسير قتادة، عن عبد الله بن عباس: أنّه خلقها للركوب والزينة{2}. (ز) ٤٠٨٤٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لتركبوها وزينة﴾</q>، قال: جعَلها لتركبوها، وجعَلها زينة لكم{3}. (٩/١٣) ٤٠٨٤٥- قال مقاتل بن سليمان: ثم ذكرهم النعم: <q>﴿والخيل والبغال والحمير لتركبوها وزينة﴾</q>، يقول: لكم في ركوبها جمال وزينة، يعني: الشارة الحسنة، كقوله تعالى: <q>﴿فخرج على قومه في زينته﴾</q> [القصص:٧٩]، يعني: في شارته{4}. (ز) ٤٠٨٤٦- قال يحيى بن سلّام: قوله: <q>﴿والخيل والبغال﴾</q> وخلق الخيل والبغال، <q>﴿والحمير لتركبوها وزينة﴾</q> في ركوبها{5}. (ز) <q>﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</q> - من أحكام الآية ٤٠٨٤٧- عن دِحْيَةَ الكلبي، قال: قلت: يا رسول الله، أحمِل لك حمارًا على فرس، فيَنتِج لك بغلًا تركبُها؟ قال: «إنما يفعل ذلك الذين لا يعلمون»{6}. (٩/١٦) ٤٠٨٤٨- عن خالد بن الوليد، قال: نهى رسول الله ﷺ عن أكل كلِّ ذي نابٍ مِن السباع، وعن لحوم الخيل والبغال والحمير{7}. (٩/١٥) ٤٠٨٤٩- عن أسماء بنت أبي بكر، قالت: نحرنا على عهد رسول الله ﷺ فرسًا، فأكلناه{8}. (٩/١٦) ٤٠٨٥٠- عن جابر بن عبد الله -من طريق محمد بن علي- قال: نهى رسول الله ﷺ يوم خيبر عن لحوم الحمر الأهلية، ورخَّص في الخيل{9}. (٩/١٥) ٤٠٨٥١- عن جابر بن عبد الله -من طريق أبي الزبير-: أنهم ذبحوا يوم خيبر الحمير والبغال والخيل، فنهاهم النَّبي ﷺ عن الحمير والبغال، ولم ينههم عن الخيل{10}. (٩/١٦) ٤٠٨٥٢- عن جابر بن عبد الله -من طريق عطاء- قال: كنا نأكل لحم الخيل على عهد رسول الله ﷺ. قلت: فالبغال؟ قال: أمّا البغال فلا{11}. (٩/١٦) ٤٠٨٥٣- عن جابر بن عبد الله -من طريق عمرو بن دينار- قال: نهانا رسول الله ﷺ عن لحوم الحمر، وأمرنا بلحوم الخيل{12}. (ز) ٤٠٨٥٤- عن سعيد بن جبير، قال: سأل رجل عبد الله بن عباس عن أكل لحوم الخيل، فكرهها. وقرأ: <q>﴿والخيل والبغال والحمير لتركبوها وزينة﴾</q>{13}. (٩/١٤) ٤٠٨٥٥- عن عبد الله بن عباس -من طريق مولى نافع بن علقمة- أنه كان يكره لحوم الخيل، ويقول: قال الله: <q>﴿والأنعام خلقها لكم فيها دفء ومنافع ومنها تأكلون﴾</q> فهذه للأكل، <q>﴿والخيل والبغال والحمير لتركبوها﴾</q> فهذه للركوب{14}. (٩/١٤) ٤٠٨٥٦- عن الأسود [النخعي]-من طريق إبراهيم-: أنّه أكل لحم الفرس{15}. (ز) ٤٠٨٥٧- عن إبراهيم النخعي -من طريق منصور- قال: نحر أصحابنا فرسًا في النَّجْعِ{16}، وأكلوا منه، ولم يروا به بأسًا{15}. (ز) ٤٠٨٥٨- عن مجاهد بن جبر -من طريق الحكم- أنه سُئِل عن لحوم الخيل. فقال: <q>﴿والخيل والبغال والحمير لتركبوها﴾</q>{18}. (٩/١٥) ٤٠٨٥٩- عن الحكم [بن عتيبة] -من طريق عبد الملك بن أبي غَنِيَّة- في قوله: <q>﴿والأنعام خلقها لكم فيها دفء ومنافع ومنها تأكلون﴾</q>: فجعل منه الأكل. ثم قرأ: <q>﴿والخيل والبغال والحمير لتركبوها وزينة﴾</q>، قال: لم يجعل لكم فيها أكلًا. وكان الحكم يقول: الخيل والبغال والحمير حرامٌ في كتاب الله{19}. (٩/١٥) ٤٠٨٦٠- عن ابن جريج، قلت لعطاء [بن أبي رباح]: الحمار يشرب في جفنتي؟ قال: نعم، وتوضأ بفضله. ثم تلا <q>﴿والخيل والبغال والحمير لتركبوها﴾</q>. قلت: فإنه يُنهى عن أكله. قال: ليس أكله مثل أن يتوضأ بفضله، فاسقه بجفنتك{20}. (ز) ٤٠٨٦١- عن مالك بن أنس: أنّ أحسن ما سمع في الخيل والبغال والحمير أنها لا تؤكل؛ لأن الله -تبارك وتعالى- قال: <q>﴿والخيل والبغال والحمير لتركبوها وزينة﴾</q>. وقال -تبارك وتعالى- في الأنعام: <q>﴿لتركبوا منها، ومنها تأكلون﴾</q> [غافر:٧٩]. وقال -تبارك وتعالى-: <q>﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</q> [الحج:٣٤]، <q>﴿فكلوا منها وأطعموا القانع والمعتر﴾</q> [الحج:٣٦]. قال: وسمعت مالكًا يقول: أن البائس هو الفقير، وأن المعتر هو الزائر. قال مالك: فذكر الله الخيل والبغال والحمير للركوب والزينة، وذكر الأنعام للركوب والأكل. قال مالك: والقانع هو الفقير أيضًا{21}٣٦٤٠. (ز) ٣٦٤٠ اختُلِف في الاستدلال بهذه الآية على تحريم أكل لحوم الخيل على قولين: الأول: أن في هذه الآية دلالة على تحريم أكل لحوم الخيل. الثاني: أنها لا تدل على تحريم شيء. ورجَّح ابنُ جرير (١٤/١٧٥-١٧٦) مستندًا إلى الدلالة العقلية القول الثاني، وهو قول إبراهيم النخعي، وقول الأسود، وعلَّل ذلك بأنه «لو كان في قوله -تعالى ذكره-: <q>﴿لِتَرْكَبُوها﴾</q> دلالةٌ على أنها لا تصلح -إذ كانت للركوب- للأكل، لكان في قوله: <q>﴿فِيها دِفْءٌ ومَنافِعُ ومِنها تَأْكُلُونَ﴾</q> دلالة على أنها لا تصلح -إذ كانت للأكل والدِّفْءِ- للركوب، وفي إجماع الجميع على أن ركوب ما قال -تعالى ذِكْره-: <q>﴿ومِنها تَأْكُلُونَ﴾</q> جائزٌ حلالٌ غير حرام، دليلٌ واضحٌ على أن أكل ما قال: <q>﴿لِتَرْكَبُوها﴾</q> جائزٌ حلالٌ غير حرامٍ، إلا بما نصَّ على تحريمه، أو وضَع على تحريمه دلالة من كتابٍ أو وحيٍ إلى رسول الله ﷺ، فأما بهذه الآية فلا يُحَرَّم أكلُ شيءٍ». وذكر ابنُ عطية (٥/٣٣٠) احتجاج ابن عباس ومالك بهذه الآية على كراهة لحوم الخيل والبغال والحمير، واحتجاج الحكم بن عيينة بها على حرمة لحوم الخيل والبغال والحمير، ثم استدرك قائلًا: «وهذه الحجة غير لازمة عند جماعة من العلماء، قالوا: إنما ذكر الله تعالى عظم منافع الأنعام، وذكر عظم منافع هذه وأهم ما فيها، وليس يقضي ذلك بأن ما ذكره لهذه لا تدخل هذه فيه». ثم ذكر (٥/٣٣١) قول ابن جرير بأن في «إجماعهم على جواز ركوب ما ذكر للأكل دليل على جواز أكل ما ذكر للركوب»، وعلق قائلًا: «وفي هذا نظر، ولحوم الخيل عند كثير من العلماء حلال، وفي جواز أكلها حديث أسماء بنت أبي بكر، وحديث جابر بن عبد الله: كنا نأكل الخيل في عهد النبي ﷺ. والبغال والحمير مكروهة عند الجمهور، وهو تحقيق مذهب مالك». <q>﴿وَٱلۡخَیۡلَ وَٱلۡبِغَالَ وَٱلۡحَمِیرَ لِتَرۡكَبُوهَا وَزِینَةࣰۚ﴾</q> - آثار متعلقة بالآية ٤٠٨٦٢- عن عبد الله بن عباس، قال: كانت الخيل وحشيَّةً، فذلَّلها الله لإسماعيل بن إبراهيم ﵉{22}. (٩/١٣) ٤٠٨٦٣- عن وهب بن مُنَبِّه -من طريق زيد بن عطية- قال: بلغني: أنّ الله أراد أن يخلُق الفرس، قال لريح الجنوب: إني خالقٌ منك خلقًا، أجعَلُه عزًّا لأوليائي، ومذلَّةً لأعدائي، وحِمًى لأهل طاعتي. فقبض من الريح قبضة، فخلق منها فرسًا، فقال: سميتك فرسًا، وجعلتُك عربيًّا، الخير معقود بناصيتك، والغنائم مُحازة على ظهرك، والغِنى معك حيث كنت، أرعاك بسعة الرزق على غيرك من الدواب، وجعلتُك لها سيِّدًا، وجعلتُك تطير بلا جناحين، فأنت للطلب، وأنت للهرب، وسأحمل عليك رجالًا يسبِّحوني فتسبِّحُني معهم إذا سبَّحوا، ويهلَّلوني فتهلِّلُني معهم إذا هلَّلُوا، ويكبَّروني فتكبِّرُني معهم إذا كبَّروا. فلما صهل الفرس قال: باركت عليك، أُرهِبُ بصهيلِك المشركين؛ أملأُ منه آذانهم، وأُرعِبُ منه قلوبهم، وأُذِلُّ أعناقهم. فلما عرض الخلق على آدم وسمّاهم قال الله: يا آدم، اختر مِن خلقي من أحببت. فاختار الفرس، فقال الله: اخترت عزَّك وعزَّ ولدك، باقٍ فيهم ما بَقوا، وينتج منه أولادك أولادًا، فبركتي عليك وعليهم. فما من تسبيحة ولا تهليلة ولا تكبيرة تكون من راكب الفرس إلا والفرس يسمَعُها ويجيبُه بمثل قوله{23}. (٩/١٣-١٤) <q>﴿وَیَخۡلُقُ مَا لَا تَعۡلَمُونَ ۝٨﴾</q> - تفسير ٤٠٨٦٤- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «إن مما خلق الله لأرضًا من لؤلؤة بيضاء مسيرة ألف عام، عليها جبل من ياقوتة حمراء مُحدِقٌ بها، في تلك الأرض ملَك قد ملأ شرقها وغربها، له ستمائة رأس، في كل رأس ستمائة وجه، في كل وجه ستمائة وستون ألف فم، في كل فم ستون ألف لسان، يُثنِي على الله ويقدسه ويهلِّلُه ويكبِّرُه، بكل لسان ستمائة ألف وستين ألف مرة، فإذا كان يوم القيامة نظر إلى عظمة الله، فيقول: وعِزَّتِك، ما عبدتك حق عبادتك. فذلك قوله: <q>﴿ويخلق ما لا تعلمون﴾</q>»{24}. (٩/١٧) ٤٠٨٦٥- عن عبد الله بن عباس، قال: دخل علينا رسول الله ﷺ ونحن في المسجد حِلقٌ حِلقٌ، فقال لنا: «فيم أنتم؟». قلنا: نتفكر في الشمس كيف طلعت، وكيف غربت؟ قال: «أحسنتم، كونوا هكذا، تفكروا في المخلوق ولا تفكروا في الخالق؛ فإنّ الله خلق ما شاء لما شاء، وتعجبوا من ذلك؛ إنّ من وراء قافٍ سبع بحار، كل بحر خمسمائة عام، ومن وراء ذلك سبع أرضين يضيء نورها لأهلها، ومن وراء ذلك سبعين ألف أمة خلقوا على أمثال الطير، هو وفرخه في الهواء، لا يفترون عن تسبيحة واحدة، ومن وراء ذلك سبعين ألف أُمَّة خلقوا مِن ريح، فطعامهم ريح، وشرابهم ريح، وثيابهم من ريح، وآنيتهم من ريح، ودوابهم من ريح، لا تستقر حوافر دوابهم إلى الأرض إلى قيام الساعة، أعينهم في صدروهم، ينام أحدهم نومة واحدة، ينتبه ورزقه عند رأسه، ومن وراء ذلك سبعين ألف أمة، ومن وراء ذلك ظل العرش، وفي ظل العرش سبعون ألف أمة، ما يعلمون أن الله خلق آدم، ولا ولد آدم، ولا إبليس، ولا ولد إبليس وهو قوله تعالى: <q>﴿ويَخْلُقُ ما لا تَعْلَمُونَ﴾</q>»{25}. (١٤/٥١) ٤٠٨٦٦- عن عبد الله بن عمر، قال: قال رسول الله ﷺ في قوله: <q>﴿ويخلق ما لا تعلمون﴾</q>، قال: «البَراذِينُ»{26}. (٩/١٦) ٤٠٨٦٧- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿ويخلق ما لا تعلمون﴾</q>، قال: السُّوسُ في الثياب{27}٣٦٤١. (٩/١٦) ٣٦٤١ ذكر ابن عطية (٥/٣٣٠) رواية «أن الله تعالى خلق ألف نوع من الحيوان، منها في البَرِّ أربعمائة، وبثَّها بأعيانها في البحر، وزاد فيه مائتين ليستا في البَرِّ». ثم علَّق عليها بقوله: «وكل من خصَّص في تفسير هذه الآية شيئًا -كقول من قال: سوس الثياب وغير ذلك- فإنما هو على جهة المثال، لا أن ما ذكره هو المقصود في نفسه». ٤٠٨٦٨- عن عامر الشعبي -من طريق القاسم بن سلمان- قال: إنّ لله عبادًا من وراء الأندلس، كما بيننا وبين الأندلس، ما يرون أنّ الله عصاه مخلوق، رَضراضُهم{28} الدُّرُّ والياقوت، وجبالهم الذهب والفضة، لا يحرُثون ولا يزرعون ولا يعملون عملًا، لهم شجر على أبوابهم لها ثمر هي طعامهم، وشجر لها أوراق عِراض هي لباسهم{29}. (٩/١٧) ٤٠٨٦٩- عن وهب بن مُنَبِّه، أنه قيل له: أخبرنا من أتى سُفالَةَ الريح{30}، وأنه رأى بها أربع نجوم كأنها أربعة أقمار، فقال وهب: <q>﴿ويخلق ما لا تعلمون﴾</q>{22}. (٩/١٨) ٤٠٨٧٠- قال قتادة بن دعامة: يعني: السوس في النبات، والدود في الفواكه{32}. (ز) ٤٠٨٧١- قال مقاتل بن سليمان: <q>﴿ويخلق ما لا تعلمون﴾</q> من الخلق{4}. (ز) ٤٠٨٧٢- قال يحيى بن سلّام: قال: <q>﴿ويخلق ما لا تعلمون﴾</q> من الأشياء كلها مما لم يذكر لكم{34}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة شاذة. انظر: المحتسب ٢/٨.أخرجه يحيى بن سلام ١/٥٢.أخرجه عبد الرزاق ١/٣٥٣، وابن جرير ١٤/١٧٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٠.تفسير يحيى بن سلام ١/٥٢.أخرجه أحمد ٣١/٩٠ (١٨٧٩٣). قال الهيثمي في المجمع ٥/٢٦٥ (٩٣٦٩): «ورجال أحمد رجال الصحيح، خلا عمر بن حسيل من آل حذيفة، ووثقه ابن حبان». وقال الصالحي في سبل الهدى والرشاد ٧/٣٩١ على رجال أحمد: «رجال ثقات».أخرجه أحمد ٢٨/١٨ (١٦٨١٧)، وابن ماجه ٤/٣٥٩، وأبو داود ٥/٦٠٩-٦١٠ (٣٧٩٠)، والنسائي ٧/٢٠٢ (٤٣٣١، ٤٣٣٢). وأورده الثعلبي ٦/٨. قال الدارقطني في السنن ٥/٥١٨ (٤٧٧١): «نا أبو سهل بن زياد، قال: سمعت موسى بن هارون، يقول: لا يعرف صالح بن يحيى ولا أبوه إلا بجده، وهذا حديث ضعيف، وزعم الواقدي أن خالد بن الوليد أسلم بعد فتح خيبر».. قال الخطابي في معالم السنن ٤/٢٤٥: «في إسناده نظر، وصالح بن يحيى بن المقدام عن أبيه عن جده لا يعرف سماع بعضهم من بعض». وقال البيهقي في الكبرى ٩/٥٥٠ (١٩٤٤٧): «إسناده مضطرب». وقال ابن عبد البر في التمهيد ١٠/١٢٨: «وهذا حديث لا تقوم به حجة؛ لضعف إسناده». وقال البغوي في شرح السنة ١١/٢٥٥: «وإسناده ضعيف». وقال ابن الجوزي في العلل المتناهية ٢/١٧٠-١٧١ (١٠٩٥): «قال أحمد بن حنبل: هذا حديث منكر». وقال النووي في شرح مسلم ١٣/٩٦: «اتفق العلماء من أئمة الحديث وغيرهم على أنه حديث ضعيف». وقال ابن كثير في تفسيره ٤/٥٥٨: «أخرجه أبو داود والنسائي، وابن ماجه، من حديث صالح بن يحيى بن المقدام -وفيه كلام- به». وقال المناوي في فيض القدير ٦/٣٠٥ (٩٣٤٢): «رمز المصنف -السيوطي- لحسنه، قال أبو داود: منسوخ. وقال البيهقي: إسناده مضطرب. وقال ابن حجر: حديث شاذ منكر». وقال الشوكاني في فتح القدير ٣/١٨١: «في إسناده صالح بن يحيى بن أبي المقدام، وفيه مقال». وقال الألباني في الصحيحة ١/٧٠١: «حديث منكر ضعيف الإسناد».أخرجه البخاري ٧/٩٣ (٥٥١٠، ٥٥١١)، ٧/٩٣-٩٤ (٥٥١٢)، ٧/٩٥ (٥٥١٩)، ومسلم ٣/١٥٤١ (١٩٤٢).أخرجه البخاري ٥/١٣٦ (٤٢١٩)، ٧/٩٥ (٥٥٢٠، ٥٥٢٤)، ومسلم ٣/١٥٤١ (١٩٤١).أخرجه أحمد ٢٣/١٣٦ (١٤٨٤٠)، ٢٣/١٧٧ (١٤٩٠٢)، وأبو داود ٥/٦٠٩ (٣٧٨٩)، وابن حبان ١٢/٧٧-٧٨ (٥٢٧٢)، والحاكم ٤/٢٦٢ (٧٥٨٠)، ويحيى بن سلام ١/٥٢، ٢/٨١٩. وأصله في مسلم ٣/١٥٤١ (١٩٤١). وقال الحاكم: «هذا حديث صحيح على شرط مسلم، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٤/٥٥٩: «رواه الإمام أحمد وأبو داود بإسنادين، كل منهما على شرط مسلم». وقال ابن الملقن في البدر المنير ٩/٣٦٠: «هذا الحديث صحيح». وقال الألباني في الإرواء ٨/١٣٨: «وهذا على شرط مسلم، مع أن أبا الزبير مدلس، وقد عنعنه».أخرجه ابن ماجه ٤/٣٥٨ (٣١٩٧)، والنسائي ٧/٢٠١ (٤٣٣٠)، ٧/٢٠٢ (٤٣٣٣)، وابن جرير ١٤/١٧٦ واللفظ له، ويحيى بن سلام ١/٥٢ مختصرًا. وأورده الثعلبي ٦/٨. قال ابن عدي في الكامل ٧/٤٣-٤٤: «وهذا عن عطاء هو في جملة ما قال ابن معين أنّ أحاديثه عن عطاء رديئة، ومع هذا فإن الثوري وغيره من الثقات قد حدثوا عنه». وقال ابن القيسراني في ذخيرة الحفاظ ٤/١٨٨٥-١٨٨٦ (٤٣٢٢): «رواه عبد الكريم بن مالك الجزري: عن عطاء، عن جابر. وهذا أيضًا يدخل فيما تكلم به ابن معين أن عبد الكريم عن عطاء أحاديثه رديئة. وأورده في ذكر جابر الجعفي -وزاد فيه: (ونشرب ألبانها)- عن عطاء، عن جابر. وجابر قد تكلموا فيه». وقال الألباني في الصحيحة ١/٧٠٠: «إسناده صحيح».أخرجه عبد الله بن المبارك في مسنده ص١٠٩ (١٨٣)، ويحيى بن سلام ١/٥٢ بنحوه. وسنده صحيح.أخرجه ابن أبي شيبة ٨/٧٠، وابن جرير ١٤/١٧٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن أبي شيبة ٨/٧١، وابن جرير ١٤/١٧٣-١٧٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/١٧٥.النُّجْعةُ عند العرب: المذهب في طلب الكلأ في موضعه. لسان العرب (نجع).أخرجه ابن جرير ١٤/١٧٥.أخرجه ابن أبي شيبة ٨/٧١.أخرجه ابن جرير ١٤/١٧٤. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/١٠٣ (٣٦٢).أخرجه مالك في الموطأ (ت: د. بشار عواد) ١/٦٤١-٦٤٢ (١٤٣٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو الشيخ في العظمة (١٢٩٤). وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.أخرجه أبو الشيخ في العظمة ٤/١٤٨٩-١٤٩١، من طريق أبي الطيب أحمد بن روح، حدثنا علي بن عمرو، عن إبراهيم بن موسى البحراني، عن مقاتل، عن عكرمة، عن ابن عباس به. في إسناده من لا يُعرف، وهما: علي بن عمرو، وإبراهيم بن موسى البحراني، لم نجد لهما ترجمة.أخرجه ابن عساكر في تاريخه ٥٥/١٦٥، من طريق الخطيب البغدادي، عن النعيمي، عن عتيق بن عبد الرحمن إمام مسجد أبي عاصم العبّاداني، قال: حدثنا محمد بن محمد بن زكريا اليمامي أبو غانم -قدم علينا-، قال: حدثنا المقدام بن داود، قال: حدثنا عبد الرحمن بن القاسم، عن أشهب، عن مالك، عن الزهري، عن نافع، عن ابن عمر به. إسناده ضعيف، قال الخطيب: «سقط بين المقدام وعبد الرحمن سعيد بن بكير عمُّ المقدام». وفيه محمد بن محمد بن زكريا، قال الذهبي في الميزان ٤/٣٠: «ضعَّفه ابنُ عساكر». وانظر: اللسان ٧/٤٨٨.أخرجه ابن عساكر ٥٣/٢١.الرضراض: الحصى الصغار. النهاية (رضرض) ٢/٢٢٩.أخرجه أبو الشيخ في العظمة (٩٥٦)، والبيهقي في الأسماء والصفات (٨٣٠).يقال: قعد في سُفالَة الريح وعُلاوتها. فالعُلاوة من حيث تَهُبُّ، والسُّفالَة ما كان بإزاء ذلك، وقيل: سُفالة كل شيء وعُلاوته أسفله وأعلاه. لسان العرب (سفل).عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٤/١١.تفسير مقاتل بن سليمان ٢/٤٦٠.تفسير يحيى بن سلام ١/٥٣.
16,9," <q>﴿وَعَلَى ٱللَّهِ قَصۡدُ ٱلسَّبِیلِ وَمِنۡهَا جَاۤىِٕرࣱۚ وَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝٩﴾</q> - قراءات ٤٠٨٧٣- عن قتادة ... وفي قراءة عبد الله بن مسعود: (ومِنكُمْ جَآئِرٌ){1}. (٩/١٨) ٤٠٨٧٤- عن علي [بن أبي طالب] أنه كان يقرأ هذه الآية: (فَمِنكُمْ جَآئِرٌ){2}. (٩/١٩) ٤٠٨٧٥- عن علي [بن أبي طالب] -من طريق عمر- أنه كان يقرأ: (فَمِنكُمْ جَآئِرٌ)، يعني: هذه الأمة{3}. (ز) <q>﴿وَعَلَى ٱللَّهِ قَصۡدُ ٱلسَّبِیلِ﴾</q> - تفسير ٤٠٨٧٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وعلى الله قصد السبيل﴾</q>، يقول: البيان{4}. (٩/١٨) ٤٠٨٧٧- عن عبد الله بن عباس -من طريق العوفي- <q>﴿وعلى الله قصد السبيل﴾</q>، يقول: على الله أن يبيِّن الهدى والضلالة{5}. (٩/١٨) ٤٠٨٧٨- قال جابر بن عبد الله: <q>﴿قصد السبيل﴾</q>: هو السنة <q>﴿ومنها جائر﴾</q>: يعني بيان الشرائع والفرائض{6}. (ز) ٤٠٨٧٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وعلى الله قصد السبيل﴾</q>، قال: طريق الحق على الله{7}٣٦٤٢. (٩/١٨) ٣٦٤٢ نقل ابنُ كثير (٨/٢٩٦-٢٩٧) في قوله تعالى: <q>﴿وعَلى اللَّهِ قَصْدُ السَّبِيلِ﴾</q> قول ابن عباس، وقول مجاهد، والضحاك، وقتادة، ونقل عن السدي أن <q>﴿قصد السبيل﴾</q> معناه: الإسلام. ثم علَّق بقوله: «وقول مجاهد هاهنا أقوى من حيث السياق؛ لأنه تعالى أخبر أن ثَمَّ طرقًا تسلك إليه، فليس يصل إليه منها إلا طريق الحق، وهي الطريق التي شرعها ورضيها، وما عداها مسدودة، والأعمال فيها مردودة». ٤٠٨٨٠- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿وعلى الله قصد السبيل﴾</q>، قال: إنارتها{8}. (ز) ٤٠٨٨١- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿وعلى الله قصد السبيل﴾</q>، قال: على الله البيان، يبين الهدى من الضلالة، ويبين السبيل التي تفرقت عن سبله، <q>﴿ومنها جائر﴾</q>{8}. (ز) ٤٠٨٨٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وعلى الله قصد السبيل﴾</q>، قال: على الله بيان حلاله وحرامه، وطاعته ومعصيته{10}. (٩/١٨) ٤٠٨٨٣- قال مقاتل بن سليمان: قال سبحانه: <q>﴿وعلى الله قصد السبيل﴾</q>، يعني: بيان الهدى{11}. (ز) ٤٠٨٨٤- قال عبد الله بن المبارك: <q>﴿قصد السبيل﴾</q>: السُّنَّة{12}. (ز) ٤٠٨٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وعلى الله قصد السبيل﴾</q>، قال: طريق الهدى{13}٣٦٤٣. (٩/١٩) ٣٦٤٣ بيَّن ابنُ عطية (٥/٣٣١) أن معنى: <q>﴿وعَلى اللَّهِ قَصْدُ السَّبِيلِ﴾</q> «أي: على الله تقويم طريق الهدى وتبيينه، وذلك بنصب الأدلة وبعث الرسل، وإلى هذا ذهب المتأوِّلون». ثم ذكر احتمالًا آخر: «أن يكون المعنى: إن من سلك السبيل القاصد فعلى الله رحمته ونعيمه وطريقه، وإلى ذلك مصيره». ثم وجَّهه بقوله: «فيكون هذا مثل قوله تعالى: <q>﴿هَذا صِراطٌ مُسْتَقِيمٌ﴾</q> [آل عمران:٥١]، وقول النبي ﷺ:»والشَّرُّ ليس إليك«. أي: لا يُفضي إلى رحمتك». ونقل ابنُ تيمية (٤/١٥٢) قولًا ولم ينسبه: أن «معنى قصد السبيل: سيركم ورجوعكم، والسبيل واحدة بمعنى الجمع». ثم انتقده مستندًا إلى دلالة اللغة، ولفظ الآية قائلًا: «هذا قول بعض المتأخرين، جعل القصد بمعنى: الإرادة، أي: عليه قصدكم للسبيل في ذهابكم ورجوعكم، وهو كلام مَن لم يفهم الآية، فإنّ السبيل القصد هي السبيل العادلة، أي: عليه السبيل القصد، والسبيل اسم جنس، ولهذا قال: <q>﴿ومِنها جائِرٌ﴾</q>. أي: عليه القصد من السبيل، ومن السبيل جائر، فأضافه إلى اسم الجنس إضافة النوع إلى الجنس، أي: القصد من السبيل، كما تقول: ثوب خز. ولهذا قال: <q>﴿ومِنها جائِرٌ﴾</q>. وأمّا من ظن أن التقدير: قصدكم السبيل. فهذا لا يطابق لفظ الآية ونظمها من وجوه متعددة». وذكر ابنُ عطية (٥/٣٣٢) أن «الألف واللام في <q>﴿السَّبِيلِ﴾</q> للعهد، وهي سبيل الشرع، وليست للجنس، ولو كانت للجنس لم يكن فيها جائر». وانتقده ابن تيمية (٤/١٥٥) مستندًا إلى الدلالة العقلية، فقال: «وأما قوله: <q>﴿قَصْدُ السَّبِيلِ﴾</q> هي سبيل الشرع، وهي سبيل الهدى، والصراط المستقيم، وأنها لو كانت للجنس لم يكن منها جائر، فهذا أحد الوجهين في دلالة الآية، وهو مرجوح، والصحيح الوجه الآخر: أن السبيل اسم جنس، ولكن الذي على الله: هو القصد منها، وهي سبيل واحدة، ولما كان جنسًا قال: <q>﴿ومِنها جائِرٌ﴾</q>، والضمير يعود على ما ذُكِرَ بلا تكلف. وقوله: لو كان للجنس لم يكن منها جائر. ليس كذلك، فإنها ليست كلها عليه، بل إنما عليه القصد منها، وهي سبيل الهدى، والجائر ليس من القصد، وكأنه ظن أنه إذا كانت للجنس يكون عليه قصد كل سبيل، وليس كذلك، بل إنما عليه سبيل واحدة، وهي الصراط المستقيم، هي التي تدل عليه، وسائرها سبل الشيطان، كما قال: <q>﴿وأَنَّ هَذا صِراطِي مُسْتَقِيمًا فاتَّبِعُوهُ ولا تَتَّبِعُوا السُّبُلَ فَتَفَرَّقَ بِكُمْ عَنْ سَبِيلِهِ﴾</q> [الأنعام:١٥٣]، وقد أحسن في هذا الاحتمال، وفي تمثيله ذلك بقوله: <q>﴿هَذا صِراطٌ عَلَيَّ مُسْتَقِيمٌ﴾</q> [الحجر:٤١]». ٤٠٨٨٦- قال يحيى بن سلّام: قوله: <q>﴿وعلى الله قصد السبيل﴾</q> والسبيل: قصد الطريق؛ الهدى إلى الجنة، كقوله: <q>﴿إن علينا للهدى﴾</q> [الليل:١٢]، وكقوله: <q>﴿قال هذا صراط علي مستقيم﴾</q> [الحجر:٤١]{14}. (ز) <q>﴿وَمِنۡهَا جَاۤىِٕرࣱۚ﴾</q> - تفسير ٤٠٨٨٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ومنها جائر﴾</q>، قال: الأهواء المختلفة{4}. (٩/١٨) ٤٠٨٨٨- عن عبد الله بن عباس -من طريق العوفي- <q>﴿ومنها جائر﴾</q>، قال: السُّبُلُ المتفرقة{5}. (٩/١٨) ٤٠٨٨٩- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿ومنها جائر﴾</q>، يعني: السبل التي تفرَّقت عن سبيله{17}. (ز) ٤٠٨٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ومنها جائر﴾</q>، قال: مِن السُّبُل ناكِبٌ عن الحق{18}. (٩/١٨) ٤٠٨٩١- قال مقاتل بن سليمان: <q>﴿ومنها جائر﴾</q>، يقول: ومِن السبيل ما تكون جائرة على الهدى{11}. (ز) ٤٠٨٩٢- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿ومنها جائر﴾</q>: السبل المتفرقة عن سبيله{17}. (ز) ٤٠٨٩٣- قال عبد الله بن المبارك: <q>﴿ومنها جائر﴾</q>: الأهواء والبِدَع{21}. (ز) ٤٠٨٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومنها جائر﴾</q>، قال: من السبل جائر عن الحق. وقرأ: <q>﴿ولا تتبعوا السبل فتفرق بكم عن سبيله﴾</q> [الأنعام:١٥٣]{13}. (٩/١٩) ٤٠٨٩٥- قال يحيى بن سلّام: قوله: <q>﴿ومنها جائر﴾</q>: ومن السبيل جائر، أي: عن السبيل جائر، وهو الكافر، جار عن سبيل الهدى. وجار عنها، وجار منها؛ واحِدٌ{14}٣٦٤٤. (ز) ٣٦٤٤ ذكر ابن عطية (٥/٣٣٢) احتمالين لعود الضمير في قوله تعالى: <q>﴿ومِنها جائِرٌ﴾</q>: الأول: أن يعود الضمير على «السبل» التي يتضمنها معنى الآية، كأنه قال: ومن السبل جائر. ويكون المراد: طريق اليهود والنصارى وغيرهم كعباد الأصنام. الثاني: أن يعود الضمير على سبيل الشرع المذكورة، وتكون «مِن» للتبعيض، ويكون المراد: فرق الضلالة من أمة محمد ﷺ، كأنه قال: ومن بنيات الطريق في هذه السبيل ومن شعبها جاير. واستدرك عليه ابن تيمية (٤/١٥٥) قائلًا: «سبيل أهل البدع جائرة خارجة عن الصراط المستقيم فيما ابتدعوا فيه، ولا يقال: إن ذلك من السبيل المشروعة». <q>﴿وَلَوۡ شَاۤءَ لَهَدَىٰكُمۡ أَجۡمَعِینَ ۝٩﴾</q> - تفسير ٤٠٨٩٦- قال مقاتل بن سليمان: <q>﴿ولو شاء لهداكم أجمعين﴾</q> إلى دينه{11}. (ز) ٤٠٨٩٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولو شاء لهداكم أجمعين﴾</q> لقصد السبيل الذي هو الحق. وقرأ: <q>﴿ولو شاء ربك لآمن من في الأرض كلهم جميعًا﴾</q> [يونس:٩٩]، وقرأ: <q>﴿ولو شئنا لأتينا كل نفس هُداها﴾</q> [السجدة:١٣]{17}. (٩/١٩) ٤٠٨٩٨- قال يحيى بن سلّام: قال: <q>﴿ولو شاء لهداكم أجمعين﴾</q> مثل قوله: <q>﴿ولو شاء ربك لآمن من في الأرض كلهم جميعا﴾</q> [يونس:٩٩]، وكقوله: <q>﴿أفلم ييئس الذين آمنوا﴾</q>: أفلم يتبين للذين آمنوا <q>﴿أن لو يشاء الله لهدى الناس جميعا﴾</q> [الرعد:٣١]{14}٣٦٤٥. (ز) ٣٦٤٥ نقل ابنُ عطية (٥/٣٣٢) عن الزجاج أن قوله تعالى: <q>﴿ولَوْ شاءَ لَهَداكُمْ أجْمَعِينَ﴾</q> «معناه: لو شاء لعرض عليكم آية تضطركم إلى الإيمان والاهتداء». ثم انتقده بقوله: «وهذا قول سوءٍ لأهل البدع الذين يرون الله لا يخلق أفعال العباد؛ لم يُحَصِّله الزجاج، ووقع فيه رحمة الله عليه عن غير قصد». ",footnotes:1:أخرجه ابن جرير ١٤/١٧٩. وعلقه يحيى بن سلام ١/٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. (ومِنكُمْ جَآئِرٌ)، و(فَمِنكُمْ جَآئِرٌ) قراءة شاذة. انظر: مختصر ابن خالويه ص٧٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن الأنباري في المصاحف.أخرجه ابن الأعرابي في معجمه ٢/٦٤٧ (١٢٨٦).أخرجه ابن جرير ١٤/١٧٧، ١٧٩، ١٨٠، وابن أبي حاتم -كما في الإتقان ٢/٢٣-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/١٧٨-١٧٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٩، وفي تفسير البغوي ٤/١١ بلفظ<q>﴿قصد السبيل﴾</q>: بيان الشرائع والفرائض.أخرجه يحيى بن سلام ١/٥٣ -من طريق ابن مجاهد-، وابن جرير ١٤/١٧٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/١٧٩.أخرجه ابن جرير ١٤/١٧٩.أخرجه يحيى بن سلام ١/٥٣، وابن جرير ١٤/١٧٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٠.تفسير الثعلبي ٦/٩، وتفسير البغوي ٤/١١.أخرجه ابن جرير ١٤/١٧٨، ١٨٠.تفسير يحيى بن سلام ١/٥٣.أخرجه ابن جرير ١٤/١٧٧، ١٧٩، ١٨٠، وابن أبي حاتم -كما في الإتقان ٢/٢٣-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/١٧٨-١٧٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/١٨٠.أخرجه ابن جرير ١٤/١٧٩ بلفظ: أي: من السبل؛ سبل الشيطان. وعلقه يحيى بن سلام ١/٥٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦٠.أخرجه ابن جرير ١٤/١٨٠.تفسير الثعلبي ٦/٩، وتفسير البغوي ٤/١١. وجاء فيهما عقبه: دليله قوله تعالى: <q>﴿وأن هذا صراطي مستقيما فاتبعوه ولا تتبعوا السبل﴾</q> [الأنعام:١٥٣].أخرجه ابن جرير ١٤/١٧٨، ١٨٠.تفسير يحيى بن سلام ١/٥٣.تفسير مقاتل بن سليمان ٢/٤٦٠.أخرجه ابن جرير ١٤/١٨٠.تفسير يحيى بن سلام ١/٥٣.
16,10," <q>﴿هُوَ ٱلَّذِیۤ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰۖ لَّكُم مِّنۡهُ شَرَابࣱ﴾</q> - تفسير ٤٠٨٩٩- قال مقاتل بن سليمان: <q>﴿هو الذي أنزل من السماء ماء لكم منه شراب﴾</q>، يعني: المطر لكم منه شراب{1}. (ز) <q>﴿وَمِنۡهُ شَجَرࣱ فِیهِ تُسِیمُونَ ۝١٠﴾</q> - تفسير ٤٠٩٠٠- عن عبد الله بن عباس -من طريق خُصيف، عن عكرمة- في قوله: <q>﴿فيه تُسيمون﴾</q>، قال: تُرعُون فيه أنعامكم{2}. (٩/١٩) ٤٠٩٠١- عن عبد الله بن عباس، أن نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿فيه تُسيمون﴾</q>. قال: فيه تُرعُون. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمِعتَ الأعشى وهو يقول: ومشى القوم بالعِمادِ إلى الرَّزْحى{3} وأعيا المُسِيمُ{4} أين المَساقُ{5}. (٩/١٩) ٤٠٩٠٢- عن عبد الله بن عبد الرحمن بن أبزى -من طريق طلحة القناد- قال: فيه تُرْعُون{6}. (ز) ٤٠٩٠٣- عن مجاهد بن جبر -من طريق أبي يحيى- قال: <q>﴿تسيمون﴾</q>: تُرعُون{7}. (ز) ٤٠٩٠٤- عن الضحاك بن مزاحم -من طريق جويبر-: فيه تُرعُون{6}. (ز) ٤٠٩٠٥- عن عكرمة مولى ابن عباس -من طريق النضر بن عربي- <q>﴿ومنه شجر فيه تسيمون﴾</q>، قال: تُرعُون{9}. (ز) ٤٠٩٠٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿شجر فيه تسيمون﴾</q>، يقول: تُرعُون{10}. (ز) ٤٠٩٠٧- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿شجر فيه تسيمون﴾</q>، قال: تُرعُون{11}. (ز) ٤٠٩٠٨- قال مقاتل بن سليمان: <q>﴿ومنه شجر فيه تسيمون﴾</q>، يعني: وفيه تُرعُون أنعامكم{1}. (ز) ٤٠٩٠٩- عن سفيان الثوري، في قوله: <q>﴿ومنه شجر فيه تسيمون﴾</q>، قال: المراعي{13}. (ز) ٤٠٩١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومنه شجر فيه تسيمون﴾</q>، قال: تُرْعُون{14}. (ز) ٤٠٩١١- قال يحيى بن سلّام: قوله: <q>﴿هو الذي أنزل من السماء ماء لكم منه شراب ومنه شجر فيه تسيمون﴾</q>: تُرعُون أنعامكم؛ تُسَرِّحونها فيه{15}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦١.أخرجه ابن جرير ١٤/١٨٢، وابن أبي حاتم -كما في الإتقان ٢/٣٢، والتغليق ٤/٢٣٦-، وابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٧)-. وعزاه السيوطي إلى ابن المنذر.الرزحي: جمع الرزاح، وهي الإبل الشديدة الهزال التي لا تتحرك، الهالكة هزالًا. اللسان (رزح).المسيم: الراعي. اللسان (سوم).أخرجه الطستي -كما في الإتقان ٢/١٠٠-.أخرجه ابن جرير ١٤/١٨٢.أخرجه يحيى بن سلام ١/٥٤.أخرجه ابن جرير ١٤/١٨٢.أخرجه ابن جرير ١٤/١٨١.أخرجه عبد الرزاق في تفسيره ٢/٣٥٤ من طريق معمر، وابن جرير ١٤/١٨٢.أخرجه أبو جعفر الرملي في جزئه ص٩٦ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٢/٤٦١.تفسير الثوري ص١٦٤.أخرجه ابن جرير ١٤/١٨٣.تفسير يحيى بن سلام ١/٥٣.
16,11," <q>﴿یُنۢبِتُ لَكُم بِهِ ٱلزَّرۡعَ وَٱلزَّیۡتُونَ وَٱلنَّخِیلَ وَٱلۡأَعۡنَـٰبَ وَمِن كُلِّ ٱلثَّمَرَ ٰ⁠تِۚ﴾</q> - تفسير ٤٠٩١٢- قال مقاتل بن سليمان: <q>﴿ينبت لكم به﴾</q> بالمطر{1}. (ز) ٤٠٩١٣- قال يحيى بن سلّام: قوله: <q>﴿ينبت لكم به﴾</q> بذلك الماء{2}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ﴾</q> - تفسير ٤٠٩١٤- تفسير مجاهد بن جبر قال: <q>﴿إن في ذلك لآية﴾</q>، يعني: لعبرة{3}. (ز) ٤٠٩١٥- تفسير إسماعيل السُّدِّيّ قال: <q>﴿إن في ذلك لآية﴾</q>، يعني: لَعبرة{3}. (ز) ٤٠٩١٦- قال مقاتل بن سليمان: <q>﴿الزرع والزيتون والنخيل والأعناب ومن كل الثمرات إن في ذلك لآية﴾</q> فيما ذُكِر لكم من النبات لَعِبرة{1}. (ز) <q>﴿لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝١١﴾</q> - تفسير ٤٠٩١٧- قال مقاتل بن سليمان: <q>﴿لقوم يتفكرون﴾</q> في توحيد الله ﷿{1}. (ز) ٤٠٩١٨- قال يحيى بن سلّام: <q>﴿لقوم يتفكرون﴾</q> وهم المؤمنون. قال: فالذي ينبت من ذلك الماء الواحد هذه الألوان المختلفة قادرٌ على أن يحيي الأموات{2}. (ز) <q>﴿لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝١١﴾</q> - آثار متعلقة بالآية ٤٠٩١٩- قال يحيى بن سلّام: <q>﴿الزرع والزيتون والنخيل والأعناب ومن كل الثمرات﴾</q>، سمعتُ بعض أشياخنا يذكرُ: أنّ الله أهبط من الجنة إلى الأرض ثلاثين ثمرة؛ عشر يؤكل داخلها ولا يؤكل خارجها، وعشر يؤكل خارجها ولا يؤكل داخلها، وعشر يؤكل داخلها وخارجها{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٤.علَّقه يحيى بن سلام ١/٥٤.علَّقه يحيى بن سلام ١/٥٤.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٤.تفسير يحيى بن سلام ١/٥٤.
16,12," <q>﴿وَسَخَّرَ لَكُمُ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ وَٱلنُّجُومُ مُسَخَّرَ ٰ⁠تُۢ بِأَمۡرِهِۦۤۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝١٢﴾</q> - قراءات ٤٠٩٢٠- عن الأعمش: في قراءة عبد الله [بن مسعود] مكان <q>﴿والنُّجُومُ مُسَخَّراتٌ﴾</q>: (والرِّياحُ){1}. (ز) ٤٠٩٢١- قال سفيان الثوري: كان أصحاب عبد الله يقرؤونها: <q>﴿وسَخَّرَ لَكُمُ اللَّيْلَ والنَّهارَ والشَّمْسَ والقَمَرَ والنُّجُومُ﴾</q>، ويقرءونها (الرِّياحُ مُسَخَّراتٌ بِأَمْرِهِ){2}. (ز) <q>﴿وَسَخَّرَ لَكُمُ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ وَٱلنُّجُومُ مُسَخَّرَ ٰ⁠تُۢ بِأَمۡرِهِۦۤۚ﴾</q> - تفسير ٤٠٩٢٢- قال يحيى بن سلّام: قوله: <q>﴿وسخر لكم الليل والنهار﴾</q> يختلفان عليكم، <q>﴿والشمس والقمر والنجوم مسخرات﴾</q> تجري <q>﴿بأمره﴾</q>، يُذَكِّر عباده نعمته عليهم{3}٣٦٤٦. (ز) ٣٦٤٦ ذكر ابنُ عطية (٣/٣٨٢ ط: دار الكتب العلمية) أنّ مِن منافع النجوم أنها هدايات، «ولهذا الوجْه عدت في جملة النعم على بني آدم، ومن النعمة بها ضياؤها أحيانًا». ثم نقل عن الزجاج أن من النعمة بها أيضًا: «علم عدد السنين والحساب بها». ثم علق قائلًا: «وفي هذا نظر». <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝١٢﴾</q> - تفسير ٤٠٩٢٣- قال مقاتل بن سليمان: <q>﴿إن في ذلك لآيات﴾</q> يقول: فيما سخر لكم في هذه الآيات لعبرة <q>﴿لقوم يعقلون﴾</q> في توحيد الله ﷿{4}. (ز) ٤٠٩٢٤- قال يحيى بن سلّام: <q>﴿إن في ذلك لآيات لقوم يعقلون﴾</q> وهم المؤمنون{3}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٠. وهي قراءة شاذة.تفسير الثوري ص١٦٤.تفسير يحيى بن سلام ١/٥٤.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٤.
16,13," <q>﴿وَمَا ذَرَأَ لَكُمۡ فِی ٱلۡأَرۡضِ﴾</q> - تفسير ٤٠٩٢٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما ذرأ لكم في الأرض﴾</q>، قال: وما خلق لكم في الأرض{1}. (٩/٢٠) ٤٠٩٢٦- قال مقاتل بن سليمان: <q>﴿وما ذرأ لكم﴾</q> يعني: وما خلق لكم <q>﴿في الأرض﴾</q> من الدوابِّ، والطير، والشجر{2}. (ز) <q>﴿مُخۡتَلِفًا أَلۡوَ ٰ⁠نُهُۥۤۚ﴾</q> - تفسير ٤٠٩٢٧- قال الحسن البصري: <q>﴿مختلفا ألوانه﴾</q> من النبات{3}. (ز) ٤٠٩٢٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿مختلفًا﴾</q>: من الدواب، والشجر، والثمار؛ نِعَمٌ من الله متظاهرة، فاشكروها لله{4}٣٦٤٧. (٩/٢٠) ٣٦٤٧ ذكر ابنُ عطية (٥/٣٣٦) أن قوله تعالى: <q>﴿ألْوانُهُ﴾</q> «معناه: أصنافه، كما تقول: هذه ألوان من الثَّمر ومن الطعام، ومن حيث كانت هذه المبثوثات في الأرض أصنافًا عُدَّت في النعمة، وظهر الانتفاع بها أنه على وجوه، ولا يظهر ذلك من حيث هي متلونة حُمرة وصُفرة وغير ذلك، ويحتمل أن يكون التنبيه على اختلاف الألوان حمرة وصفرة». ثم رجَّح قائلًا: «والأول أبْيَن». <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّقَوۡمࣲ یَذَّكَّرُونَ ۝١٣﴾</q> - تفسير ٤٠٩٢٩- قال مقاتل بن سليمان: <q>﴿إن في ذلك﴾</q> يعني: فيما ذكر من الخلق في الأرض <q>﴿لآية لقوم يذكرون﴾</q> في توحيد الله ﷿، وما ترون من صنعه وعجائبه{2}. (ز) ٤٠٩٣٠- قال يحيى بن سلّام: قال: <q>﴿إن في ذلك لآية﴾</q> لعبرة <q>﴿لقوم يذكرون﴾</q> وهم المؤمنون{6}. (ز) ",footnotes:1:أخرجه يحيى بن سلام ١/٥٤، وابن جرير ١٤/١٨٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦١.علَّقه يحيى بن سلام ١/٥٤.أخرجه ابن جرير ١٤/١٨٤. وعلقه يحيى بن سلام ١/٥٤ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٤.
16,14," <q>﴿وَهُوَ ٱلَّذِی سَخَّرَ ٱلۡبَحۡرَ﴾</q> - تفسير ٤٠٩٣١- قال يحيى بن سلّام: قوله: <q>﴿وهو الذي سخر البحر﴾</q>: خلق البحر{1}. (ز) <q>﴿لِتَأۡكُلُوا۟ مِنۡهُ لَحۡمࣰا طَرِیࣰّا﴾</q> - تفسير ٤٠٩٣٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وهو الذي سخر البحر لتأكلوا منه لحمًا طريًا﴾</q>، يعني: حيتان البحر{2}. (٩/٢٢) ٤٠٩٣٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿لتأكلوا منه لحمًا طريًا﴾</q>، قال: هو السمك، وما فيه من الدواب{3}. (٩/٢٢) ٤٠٩٣٤- قال مقاتل بن سليمان: <q>﴿وهو الذي سخر البحر لتأكلوا منه لحما طريا﴾</q>، وهو السمك ما أصيد{4}، أو ألقاه الماء وهو حي{5}. (ز) <q>﴿لِتَأۡكُلُوا۟ مِنۡهُ لَحۡمࣰا طَرِیࣰّا﴾</q> - آثار متعلقة بالآية ٤٠٩٣٥- عن قتادة بن دعامة -من طريق سعيد- أنه سُئِل عن رجل قال لامرأته: إن أكَلتِ لحمًا فأنت طالق. فأكَلَتْ سمكًا. قال: هي طالق؛ قال الله: <q>﴿لتأكلوا منه لحمًا طريًا﴾</q>{6}. (٩/٢٢) ٤٠٩٣٦- عن عطاء -من طريق ابن جريج- قال: يحنَثُ؛ قال الله: <q>﴿لتأكلوا منه لحمًا طريًا﴾</q>{6}. (٩/٢٣) <q>﴿وَتَسۡتَخۡرِجُوا۟ مِنۡهُ حِلۡیَةࣰ تَلۡبَسُونَهَاۖ﴾</q> - تفسير ٤٠٩٣٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وتستخرجوا منه حليةً تلبَسُونها﴾</q>، قال: هذا اللؤلؤ{8}. (٩/٢٢) ٤٠٩٣٨- قال مقاتل بن سليمان: <q>﴿وتستخرجوا منه حلية تلبسونها﴾</q>، يعني: اللؤلؤ{5}. (ز) ٤٠٩٣٩- قال يحيى بن سلّام: <q>﴿وتستخرجوا منه حلية تلبسونها﴾</q> اللؤلؤ{1}. (ز) <q>﴿وَتَسۡتَخۡرِجُوا۟ مِنۡهُ حِلۡیَةࣰ تَلۡبَسُونَهَاۖ﴾</q> - أحكام متعلقة بالآية ٤٠٩٤٠- عن أبي جعفر [الباقر] -من طريق إسماعيل بن عبد الملك- قال: ليس في الحُلِيِّ زكاة. ثم قرأ: <q>﴿وتستخرجوا منه حليةً تلبسونها﴾</q>{11}. (٩/٢٣) <q>﴿وَتَرَى ٱلۡفُلۡكَ﴾</q> - تفسير ٤٠٩٤١- قال مقاتل بن سليمان: <q>﴿وترى الفلك﴾</q>، يعني: السفن{5}. (ز) ٤٠٩٤٢- قال يحيى بن سلّام: <q>﴿وترى الفلك﴾</q> السفن{13}. (ز) <q>﴿مَوَاخِرَ فِیهِ﴾</q> - تفسير ٤٠٩٤٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وترى الفلك مواخر﴾</q>، قال: جواري{14}. (٩/٢٣) ٤٠٩٤٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: تَمخُرُ السفنُ الرياحَ، ولا تمخر الريحَ من السفنِ إلا الفلكُ العظام{15}. (٩/٢٣) ٤٠٩٤٥- عن الضحاك بن مزاحم، في قوله: <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: السفينتان تجريان بريح واحدة، كل واحدة مستقبلة الأخرى{16}. (٩/٢٣) ٤٠٩٤٦- عن عكرمة مولى ابن عباس -من طريق أبي مكين- <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: تَشُقُّ الماءَ بصدرها{17}. (٩/٢٣) ٤٠٩٤٧- عن عكرمة مولى ابن عباس -من طريق أبي بكر الأصم- في قوله: <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: ما أُخِذَ عن يمين السفينة وعن يسارها من الماء فهو المواخر{18}. (ز) ٤٠٩٤٨- عن الحسن البصري -من طريق يزيد بن إبراهيم- <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: مقبلة ومدبرة بريح واحدة{19}. (ز) ٤٠٩٤٩- عن الحسن البصري -من طريق يونس- في قوله: <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: المواقِرُ{20}{21}. (ز) ٤٠٩٥٠- عن أبي صالح باذام -من طريق إسماعيل- <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: تجري فيه متعرضة{22}. (ز) ٤٠٩٥١- عن قتادة بن دعامة -من طريق سعيد، ومعمر- في قوله: <q>﴿وترى الفلك مواخر فيه﴾</q>، قال: تجري بريح واحدة، مقبلة ومدبرة{23}. (٩/٢٤) ٤٠٩٥٢- قال مقاتل بن سليمان: <q>﴿مواخر فيه﴾</q>، يعني: في البحر مقبلة ومدبرة بريح واحد{5}٣٦٤٨. (ز) ٣٦٤٨ ذكر ابن عطية (٥/٣٣٧) أن «المَخْرَ في اللغة: الصوت الذي يكون من هبوب الرِّيح على شيءٍ يُشَقُّ، أو يصحب في الجملة الماء. فيترتب منه أن يكون»المَخْرَ«من الريح، وأن يكون من السفينة ونحوها، وهو في هذه الآية من السفن. ثم نقل عن»بعض اللغويين أن «المَخْر» في كلام العرب: الشَّقُّ، يقال: مَخَرَ الماء في الأرض«. ثم علَّق بقوله:»فهذا بيِّنٌ أن يقال فيه للفلك: مواخر«. ونقل أيضًا قول الضحاك، وقول الحسن من طريق يزيد بن إبراهيم، وقتادة، ومقاتل، أن <q>﴿مَواخِرَ﴾</q> معناه: تجيء وتذهب بريح واحدة، ثم علَّق على ما سبق بقوله:»وهذه الأقوال ليست تفسيرًا لِلَّفظة، وإنما أرادوا بها أنها مواخر لهذه الأحوال، فنَصُّوا على هذه الأحوال، إذ هي موضع النعم المعدودة، إذ نَفْس كون الفلك ماخرة لا نعمة فيه، وإنما النعمة في مخرها بهذه الأحوال في التجارات، والسفر فيها، وما يمنح الله فيها من الأرباح والمِنَن". وذكر ابنُ كثير (٨/٢٩٩ بتصرف) «أن السفن تمخر البحر، أي: تشقه، وقيل: تمخر الرياح،». ثم علَّق عليهما بقوله: «وكلاهما صحيح». ٤٠٩٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿مواخر﴾</q>، قال: تمخر الريحَ{22}. (ز) ٤٠٩٥٤- قال يحيى بن سلّام: وبعضهم يقول: <q>﴿مواخر فيه﴾</q>، يعني: شقها الماء في وقت جريها{13}. (ز) <q>﴿وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ﴾</q> - تفسير ٤٠٩٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ولتبتغوا من فضله﴾</q>، قال: تجارة البرِّ والبحر{27}. (ز) ٤٠٩٥٦- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولتبتغوا من فضله﴾</q>، قال: هو التجارة{3}. (٩/٢٤) ٤٠٩٥٧- قال مقاتل بن سليمان: <q>﴿ولتبتغوا من فضله﴾</q>، يعني: سخَّر لكم الفلك لتبتغوا من فضله{5}. (ز) <q>﴿وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝١٤﴾</q> - تفسير ٤٠٩٥٨- قال مقاتل بن سليمان: <q>﴿ولعلكم تشكرون﴾</q> ربَّكم في نِعَمه ﷿{5}. (ز) ٤٠٩٥٩- قال يحيى بن سلّام: <q>﴿ولعلكم تشكرون﴾</q> ولكي تشكروا. هي مثل قوله: <q>﴿لعلكم تسلمون﴾</q> [النحل:٨١]{13}. (ز) <q>﴿وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝١٤﴾</q> - آثار متعلقة بالآية ٤٠٩٦٠- عن عبد الله بن عمر: أنّه كان يكره ركوب البحر إلا لثلاث: غازٍ، أو حاجٍّ، أو معتمر{32}. (٩/٢٠) ٤٠٩٦١- عن مطر الوراق: أنه كان لا يرى بركوب البحر بأسًا، وقال: ما ذكره الله في القرآن إلا بخير{3}. (٩/٢٠) ",footnotes:1:تفسير يحيى بن سلام ١/٥٤.أخرجه ابن جرير ١٤/١٨٥-١٨٦. وعلقه يحيى بن سلام ١/٥٤. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.كذا في الأصل.تفسير مقاتل بن سليمان ٢/٤٦١.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٥٣.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٥٣.أخرجه ابن جرير ١٤/١٨٥-١٨٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٤.أخرجه ابن أبي شيبة ٣/١٥٥، وابن جرير ١٤/١٨٦ بنحوه.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٥.أخرجه ابن جرير ١٩/٣٤٦-٣٤٧، وابن أبي حاتم -كما في الإتقان ٢/٢٣-.أخرجه ابن جرير ١٤/١٨٧. وعلقه يحيى بن سلام ١/٥٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/١٨٦-١٨٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/١٨٦.أخرجه ابن جرير ١٤/١٨٨.الواو والقاف والراء: أصل يدل على ثِقل في الشيء. معجم مقاييس اللغة (وقر).أخرجه ابن جرير ١٤/١٨٦. وفي تفسير البغوي ٤/١٢ بلفظ: مملوءة.أخرجه ابن جرير ١٤/١٨٧.أخرجه يحيى بن سلام ١/٥٥، وابن جرير ١٤/١٨٧-١٨٨.تفسير مقاتل بن سليمان ٢/٤٦١.أخرجه ابن جرير ١٤/١٨٧.تفسير يحيى بن سلام ١/٥٥.أخرجه ابن جرير ١٤/١٨٨. وعلقه يحيى بن سلام ١/٥٥ بلفظ: طلب التجارة في السفن.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير مقاتل بن سليمان ٢/٤٦١.تفسير يحيى بن سلام ١/٥٥.أخرجه عبد الرزاق (٩٦٢٨).عزاه السيوطي إلى ابن أبي حاتم.
