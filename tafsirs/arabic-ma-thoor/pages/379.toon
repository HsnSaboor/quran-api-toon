quran[13]{c,v,t}:
  27,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنِّی وَجَدتُّ ٱمۡرَأَةࣰ تَمۡلِكُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم﴾</span>، قال: كان اسمها: بِلْقِيس بنت أبي شبرة، وكانت هَلْباء{1} شَعْراء{2}. (١١/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قال: كان اسمها: بلقيس بنت أبي شرح، وأمها جِنِّيَةٌ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٢٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- قال: لما قال: <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم﴾</span> أنكر سليمانُ أن يكون لأحد على الأرض سلطانٌ غيره{4}. (١١/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم﴾</span>، قال: هي بلقيس بنت شراحيل، ملكة سبأ{5}. (١١/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: كانت ملكة سبأ اسمها: ليلى، وسبأ مدينة باليمن، وبلقيس حميرية{6}. (١١/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ ملك سبأ كانت امرأة باليمن، كانت في بيت مملكة، يقال لها: بلقيس بنت شراحيل، هلك أهلُ بيتها، فمَلَّكها قومُها{7}. (١١/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قوله: <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم﴾</span>، قال: بلغني: أنّها امرأة تسمى: بلقيس بنت شراحيل، أحد أبويها من الجن، مؤخر إحدى قدميها مثل حافر الدابة، وكانت في بيت مملكة، وكان أولو مشورتها ثلاثمائة واثني عشر رجلًا، كل رجل منهم على عشرة آلاف رجل، وكانت بأرض يُقال لها: مأرب، مِن صنعاء على ثلاثة أيام{8}<span class=comment-ref>٤٨٥٦</span>. (١١/٣٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٠/٤٠١) على هذا القول بقوله: «وهذا القول هو أقرب، على أنه كثير على مملكة اليمن».</div></p><p><div></p><p><p><span class="item-no">٥٧١٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال سليمان: وما ذلك؟ قال الهدهد: <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم﴾</span>. يعني: تملك أهل سبأ ... والمرأة اسمها: بلقيس بنت أبي سرح، وهي من الإنس، وأمها من الجن، اسمها: فازمة بنت الصخر{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق سفيان- قال: بلقيس بنت ذي شرح، وأمها: بلقتة{5}. (١١/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٥<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، مثله{11}. (١١/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٦<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم﴾</span>، قال: هي بلقيس بنت شراحيل بن مالك بن ريان، وأمها: فارعة الجنية{5}. (١١/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- قال: اسم [صاحبة] سبأ: بلقيس{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنِّی وَجَدتُّ ٱمۡرَأَةࣰ تَمۡلِكُهُمۡ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧١٣٨<span class="dash">-</span></span> عن أبي بكرة، قال: قال: لَمّا بلغ رسولَ الله ﷺ أنّ أهل فارس قد ملَّكوا عليهم بنتَ كِسرى؛ قال: «<b>لن يُفلِح قومٌ ولَّوا أمرَهم امرأةً</b>»{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٣٩<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>أحد أبوي بلقيس كان جِنِّيًّا</b>»{15}. (١١/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: صاحبة سبأ كانت أمُّها جنية{2}. (١١/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه سُئِل عن ملكة سبأ، فقالوا: إنّ أحد أبويها جني؟ فقال: الجن لا يتوالدون. أي: أنّ المرأة من الإنس لا تلد مِن الجنِّ{17}. (١١/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤٢<span class="dash">-</span></span> عن <span class="name-2">عثمان بن حاضر</span>، قال: كانت أمُّ بلقيس امرأةً مِن الجن، يُقال لها: بلقمة بنت شيصان{18}. (١١/٣٥٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُوتِیَتۡ مِن كُلِّ شَیۡءࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٤٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي عبيدة الباجي- <span class="qpc-hafs">﴿وأوتيت من كل شيء﴾</span>: يعني: مِن كل أمر الدنيا{19}. (١١/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وأوتيت من كل شيء﴾</span>، قال: من كل شيء في أرضها{20}. (١١/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأوتيت﴾</span> يعني: وأعطيت <span class="qpc-hafs">﴿من كل شيء﴾</span> يكون باليمن، يعني: العلم، والمال، والجنود، والسلطان، والزينة، وأنواع الخير. فهذا كله من كلام الهدهد{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤٦<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق مهران- في قوله: <span class="qpc-hafs">﴿وأوتيت من كل شيء﴾</span>، قال: مِن أنواع الدنيا{20}. (١١/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إني وجدت امرأة تملكهم وأوتيت من كل شيء﴾</span>، أي: مِن كل شيء أوتيت منه{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُوتِیَتۡ مِن كُلِّ شَیۡءࣲ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧١٤٨<span class="dash">-</span></span> عن يحيى بن شبل، قال: كنتُ جالسًا عند <span class="name-3">مقاتل بن سليمان</span>، فجاء شابٌّ، فسأله: ما تقول في قول الله تعالى: <span class="qpc-hafs">﴿كل شيء هالك إلا وجهه﴾</span> [القصص:٨٨]؟ قال: فقال مقاتل: هذا جهمي. قال: ما أدري ما جهم! إن كان عندك علم فيما أقول، وإلاّ فقل: لا أدري. فقال: ويحك، إنّ جهمًا -واللهِ- ما حجَّ هذا البيتَ، ولا جالس العلماء، إنما كان رجلًا أُعْطِي لسانًا، وقوله تعالى: <span class="qpc-hafs">﴿كل شيء هالك إلا وجهه﴾</span> إنما هو شيء في الروح، كما قال ههنا لملكة سبأ: <span class="qpc-hafs">﴿وأوتيت من كل شيء﴾</span> لم تؤت إلا ملك بلادها، وكما قال: <span class="qpc-hafs">﴿وآتيناه من كل شيء سببًا﴾</span> [الكهف:٨٤] لم يؤت إلا ما في يده من الملك. ولم يدع في القرآن <span class="qpc-hafs">﴿كل شيء﴾</span> و<span class="qpc-hafs">﴿كل شيء﴾</span> إلا سَرَدَ علينا{24}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَهَا عَرۡشٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي عبيدة الباجي- قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>: يعني: سرير عظيم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: عرشها: سريرها{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، مثله{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: العرش: السرير{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الرحمن بن زيد بن أسلم- في قول الله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: المجلس{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>: سرير ملكها التي كانت تجلس عليه{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٥<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق مهران- <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>: والعرش: الكرسي{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٦<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد بن موسى- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>: أي: سرير عظيم{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَهَا عَرۡشٌ عَظِیمࣱ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: سرير كريم من ذهب، وقوائمه مِن جوهر ولؤلؤ، حسن الصنعة، غالي الثمن{33}. (١١/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كان عرش بلقيس ثلاثين ذراعًا في ثلاثين ذراعًا، وطوله في السماء ثلاثون ذراعًا{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: قوائمه الجوهر، وخشبه الذهب{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: وعرشها: سريرها، وكان سريرًا حسنًا، كان مِن ذهب، وقوائمه لؤلؤ وجوهر، وكان مُسَتّرًا بالديباج والحرير، وكانت عليه سبعة مَغالِيق، وكانت دونه سبعةُ أبيات بالبيت الذي هو فيه، مغلقة مقفلة{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق أبي بكر الهذلي- <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: خشبه الذهب، وقوائمه الجوهر{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: العرش: السرير. والعظيم: حسن الصنعة، غالي الثمن{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقال الهدهد: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، يعني: ضخم، ثمانون ذراعًا في ثمانين ذراعًا، وارتفاع السرير مِن الأرض أيضًا ثمانون ذراعًا في ثمانين ذراعًا، مُكَلَّل بالجوهر{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>: سرير ملكها التي كانت تجلس عليه، وكان ذهبا مُفَصَّصًا بالياقوت، والزبرجد، واللؤلؤ، فجُعل في سبعة أبيات بعضها في بعض، ثم أُقْفِلت عليه الأبواب، وكانت إنما تخدمها النساء؛ معها ستمائة امرأة يخدِمْنَها{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٥<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قوله: <span class="qpc-hafs">﴿ولها عرش عظيم﴾</span>، قال: سرير من ذهب، وصفحتاه مَرْمُول{41} بالياقوت والزبرجد، طوله ثمانون ذراعًا في عرض أربعين ذراعًا{28}<span class=comment-ref>٤٨٥٧</span>. (١١/٣٥٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٧</span> قال <u>ابنُ عطية</u> (٦/٥٣١) <span class="comment-type-4">معلِّقًا</span> على الخلاف في المرأة المذكورة، وما كان من وصفها، فقال: «وأكثر بعض الناس في قصصها بما رأيت اختصاره لعدم صحته، وإنما اللازم من الآية أنها امرأة ملكة على مدائن اليمن، ذات ملك عظيم، وكانت كافرة من قوم كفار».</div></p></div>",footnotes:1:هَلْباء: كثيرة الشعر، غليظته، في جسمها كله. النهاية واللسان (هلب).|2:أخرجه ابن أبي شيبة ١١/٥٣٩. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه إسحاق البستي في تفسيره ص١٤.|4:أخرجه إسحاق البستي في تفسيره ص١٤، وابن أبي حاتم ٩/٢٨٦٦.|5:أخرجه ابن أبي حاتم ٩/٢٨٦٥.|6:عزاه السيوطي إلى ابن عساكر.|7:أخرجه يحيى بن سلام ٢/٥٤١، وابن أبي حاتم ٩/٢٨٧٠، وابن عساكر ٦٩/٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:أخرجه عبد الرزاق ٢/٨٠ مطولًا، وابن جرير ١٨/٤٧، وابن أبي حاتم ٩/٢٨٦٥. وعزاه السيوطي إلى عبد بن حميد.|9:تفسير مقاتل بن سليمان ٣/٣٠١.|10:أخرجه ابن أبي حاتم ٩/٢٨٦٥.|11:عزاه السيوطي إلى ابن مردويه.|12:أخرجه ابن أبي حاتم ٩/٢٨٦٥.|13:أخرجه إسحاق البستي في تفسيره ص١٤.|14:أخرجه البخاري ٦/٨ (٤٤٢٥)، ٩/٥٥ (٧٠٩٩)، ويحيى بن سلام ٢/٥٤١.|15:أخرجه ابن عدي في الكامل ٤/٤١٦، وأبو الشيخ في العظمة ٥/١٦٥٣-١٦٥٤، وابن جرير ١٨/٨٣، والثعلبي ٧/٢٠٢.</p><p>قال ابن كثير في البداية والنهاية ٢/٣٣١ عن رواية الثعلبي: «هذا حديث غريب، وفي سنده ضعف». وقال الألباني في الضعيفة ٤/٢٩٧ (١٨١٨): «ضعيف». وفي ١٢/٦٠٨ (٥٧٧٨): «منكر».|16:أخرجه ابن أبي شيبة ١١/٥٣٩. وعزاه السيوطي إلى ابن المنذر.|17:أخرجه ابن عساكر ٦٩/٦٧.|18:عزاه السيوطي إلى الحكيم الترمذي، وابن مردويه.|19:أخرجه ابن جرير ١٨/٣٩.|20:أخرجه ابن أبي حاتم ٩/٢٨٦٦.|21:تفسير مقاتل بن سليمان ٣/٣٠١.|22:أخرجه ابن أبي حاتم ٩/٢٨٦٦.|23:تفسير يحيى بن سلام ٢/٥٣٩.|24:أخرجه ابن عساكر في تاريخ دمشق ٦٠/١١٩.|25:أخرجه ابن جرير ١٨/٤٠.|26:أخرجه يحيى بن سلام ٢/٥٤٠، وابن أبي حاتم ٩/٢٨٦٦.|27:علَّقه ابن أبي حاتم ٩/٢٨٦٦.|28:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|29:أخرجه ابن أبي حاتم ٩/٢٨٦٦.|30:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|31:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|32:أخرجه أبو عمرو الداني في المكتفى ص١٥٣ (٢٢).|33:أخرجه ابن جرير ١٨/٤٠ دون لفظة: غالي الثمن. وعزاه السيوطي إلى ابن المنذر.|34:تفسير الثعلبي ٧/٢٠٣، وتفسير البغوي ٦/١٥٦.|35:أخرجه إسحاق البستي في تفسيره ص١٥.|36:أخرجه يحيى بن سلام ٢/٥٤٠.|37:أخرجه إسحاق البستي في تفسيره ص١٥، وابن أبي حاتم ٩/٢٨٦٧.|38:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|39:تفسير مقاتل بن سليمان ٣/٣٠١. وبعضه في تفسير الثعلبي ٧/٢٠٣، وتفسير البغوي ٦/١٥٦ منسوبًا إلى مقاتل دون تعيينه.|40:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|41:مَرْمُول: منسوج ومُزيَّن بالياقوت والزبرجد. النهاية واللسان (رمل).|42:أخرجه ابن أبي حاتم ٩/٢٨٦٧.
  27,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَدتُّهَا وَقَوۡمَهَا یَسۡجُدُونَ لِلشَّمۡسِ مِن دُونِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٦٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كانوا قومًا مجوسًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٧<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق ابن إسحاق- في قوله: <span class="qpc-hafs">﴿وجدتها وقومها يسجدون للشمس﴾</span>، قال: كانت لها كوة في بيتها، إذا طلعت الشمسُ نظرت إليها، فسجدت لها{2}. (١١/٣٥٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزَیَّنَ لَهُمُ ٱلشَّیۡطَـٰنُ أَعۡمَـٰلَهُمۡ فَصَدَّهُمۡ عَنِ ٱلسَّبِیلِ فَهُمۡ لَا یَهۡتَدُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم﴾</span>: وقد زين لهم إبليس أعمالهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٦٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سعيد بن المرزبان- في قوله: <span class="qpc-hafs">﴿لا يهتدون﴾</span>، قال: لا يعرفون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم﴾</span> السيئة، يعني: سجودهم للشمس، <span class="qpc-hafs">﴿فصدهم عن السبيل﴾</span> يعني: عن الهُدى، <span class="qpc-hafs">﴿فهم لا يهتدون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم فصدهم عن السبيل فهم لا يهتدون (٢٤) ألا يسجدوا لله﴾</span> وفيها تقديم، أي: وزين لهم الشيطان أعمالَهم، فصدهم عن السبيل ألا يسجدوا لله، فصدهم عن الطريق بتركهم السجود فهم لا يهتدون. وفي بعض كلام العرب: ألا تسجدوا ألا فاسجدوا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٥٤٠.|2:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|3:أخرجه ابن أبي حاتم ٩/٢٨٦٧.|4:أخرجه ابن أبي حاتم ٩/٢٨٦٨.|5:تفسير مقاتل بن سليمان ٣/٣٠١.|6:تفسير يحيى بن سلام ٢/٥٤٠.
  27,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَّا یَسۡجُدُوا۟ لِلَّهِ ٱلَّذِی یُخۡرِجُ ٱلۡخَبۡءَ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٧١٧٢<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (هَلّا يَسْجُدُوا لِلَّهِ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَّا یَسۡجُدُوا۟ لِلَّهِ ٱلَّذِی یُخۡرِجُ ٱلۡخَبۡءَ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٧١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يخرج الخبء﴾</span>، قال: يعلم كل خَفِيَّة في السماء والأرض{2}<span class=comment-ref>٤٨٥٨</span>. (١١/٣٥٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٣٣) أن <span class="qpc-hafs">﴿الخَبْء﴾</span>: الخفي من الأمور، وهو مِن: خبأت الشيء. وأنّ خبء السماء: مطرها. وخبء الأرض: كنوزها ونباتها. ثم قال: «واللفظة بعد هذا تَعُمُّ كلَّ خفيّ من الأمور، وبه فسر ابن عباس».</div></p><p><div></p><p><p><span class="item-no">٥٧١٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق أبي يزيد التيمي- في قوله: <span class="qpc-hafs">﴿يخرج الخبء﴾</span>، قال: الماء{3}<span class=comment-ref>٤٨٥٩</span>. (١١/٣٥٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٩</span> ساق <u>ابنُ كثير</u> (١٠/٤٠٢) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا مناسب مِن كلام الهدهد، الذي جعل الله فيه من الخاصية ما ذكره ابن عباس وغيره مِن أنه يرى الماء يجري في تخوم الأرض ودواخلها».</div></p><p><div></p><p><p><span class="item-no">٥٧١٧٥<span class="dash">-</span></span> عن <span class="name-2">حكيم بن جابر</span> -من طريق أبي معاوية، عن إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿يخرج الخبء﴾</span>، قال: المطر{4}. (١١/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٧٦<span class="dash">-</span></span> عن <span class="name-2">حكيم بن جابر</span> -من طريق عيسى بن يونس، عن إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿ألا يسجدوا لله الذي يخرج الخبء في السموات والأرض﴾</span>: ويعلم كل خَفِيَّة في السماوات والأرض{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يخرج الخبء﴾</span>، قال: الغَيْث{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يخرج الخبء﴾</span>، قال: الغَيْب{7}. (١١/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٧٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- في قوله: <span class="qpc-hafs">﴿يخرج الخبء﴾</span>، قال: السِّرّ{8}. (١١/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، مثله{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-، مثله{10}. (١١/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٢<span class="dash">-</span></span> قال يحيى بن سلّام: قال <span class="name-2">قتادة</span>: أي: يعلم السِّرَّ في السماوات والأرض، والخبء مِن الخبيئة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٣<span class="dash">-</span></span> وقال <span class="name-2">مجاهد</span>: الخبء: الغيب. قال <span class="name-3">يحيى</span>: وهو واحد{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال الهدهد: <span class="qpc-hafs">﴿ألا يسجدوا لله الذي يخرج الخبء﴾</span>، يعني: الغيث{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الذي يخرج الخبء في السموات والأرض﴾</span>، قال: خبءُ السموات والأرض: ما جعل الله فيهما من الأرزاق؛ والمطر من السماء، والنبات من الأرض، كانتا رتقًا؛ لا تُمْطِر هذه، ولا تنبت هذه، ففتق السماء، وأنزل المطر، وأخرج النبات{13}. (١١/٣٥٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَّا یَسۡجُدُوا۟ لِلَّهِ ٱلَّذِی یُخۡرِجُ ٱلۡخَبۡءَ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧١٨٦<span class="dash">-</span></span> عن معاذ بن عبد الله، قال: رأيتُ ابنَ عباس على بغلةٍ يسأل تُبَّعًا{14} ابن امرأة كعب [الأحبار]: هل سألتَ كعبًا عن البذر؛ تنبتُ الأرضُ العامَ لم يُصَبِ العامَ الآخر؟ قال: سمعت <span class="name-2">كعبًا</span> يقول: البذر ينزل من السماء، ويخرج من الأرض. قال: صدقت{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَعۡلَمُ مَا تُخۡفُونَ وَمَا تُعۡلِنُونَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ويعلم ما تخفون وما تعلنون﴾</span>، قال: يعلم ما عمِلوا بالليل والنهار{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿ويعلم ما تخفون وما تعلنون﴾</span>، قال: في ظُلْمَة الليل، وفي أجواف بيوتهم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويعلم ما تخفون﴾</span> في قلوبكم، <span class="qpc-hafs">﴿وما تعلنون﴾</span> بألسنتكم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ‹ويَعْلَمُ ما يُخْفُونَ› في صدورهم{19}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٧.</p><p>وهي قراءة شاذة، تروى أيضًا عن أُبَي، والأعمش. انظر: مختصر ابن خالويه ص١١٠.|2:أخرجه ابن أبي حاتم ٩/٢٨٦٨. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٢٠ (١٨)-، وابن أبي حاتم ٩/٢٨٦٨.|4:أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٢٠ (١٧)-، وأبو الشيخ في العظمة (٧٤٩). وعلقه ابن أبي حاتم ٩/٢٨٦٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن المنذر.|5:أخرجه ابن جرير ١٨/٤٢.|6:تفسير مجاهد ص٥١٨، وأخرجه ابن جرير ١٨/٤٢ من طريق ابن أبي نجيح وابن جريج، وابن أبي حاتم ٩/٢٨٦٨.|7:أخرجه ابن أبي حاتم ٩/٢٨٦٨. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن جرير.|8:أخرجه ابن أبي حاتم ٩/٢٨٦٨. وعزاه السيوطي إلى عبد بن حميد.|9:علَّقه ابن أبي حاتم ٩/٢٨٦٨.|10:أخرجه عبد الرزاق ٢/٨١. وعلَّقه يحيى بن سلام ٢/٥٤٠، وابن أبي حاتم ٩/٢٨٦٨. وعزاه السيوطي إلى عبد بن حميد.|11:علقه يحيى بن سلام ٢/٥٤٠.|12:تفسير مقاتل بن سليمان ٣/٣٠٢.|13:أخرجه ابن جرير ١٨/٤٢-٤٣، وابن أبي حاتم ٩/٢٨٦٨-٢٨٦٩ من طريق أصبغ.|14:قال ابن جرير ١٨/٤٣ عقب الأثر: إنما هو تبيع، ولكن هكذا قال محمد. يريد: محمد بن عمارة شيخه.|15:أخرجه ابن جرير ١٨/٤٣.|16:أخرجه ابن أبي حاتم ٩/٢٨٦٩.|17:أخرجه ابن أبي حاتم ٩/٢٨٦٩.|18:تفسير مقاتل بن سليمان ٣/٣٠٢.|19:تفسير يحيى بن سلام ٢/٥٤٠.</p><p>وقراءة ‹ويَعْلَمُ ما يُخْفُونَ›بالغيب قراءة غير الكسائي وحفص. انظر: النشر ٢/٣٧٧.
  27,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَ رَبُّ ٱلۡعَرۡشِ ٱلۡعَظِیمِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لا يعلم قَدْرَ العرش إلا الذي خَلَقَه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الله لا إله إلا هو رب العرش العظيم﴾</span>، يعني بالعظيم: العرش{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span> إلى قوله: <span class="qpc-hafs">﴿لا إله إلا هو رب العرش العظيم﴾</span>: هذا كله كلام الهدهد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-، بنحوه{3}<span class=comment-ref>٤٨٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٠</span> على هذا القول الذي قاله ابن زيد، وابن إسحاق، ومقاتل فقوله تعالى: <span class="qpc-hafs">﴿ألا يسجدوا﴾</span> إلى قوله: <span class="qpc-hafs">﴿العرش العظيم﴾</span> من كلام الهدهد، وهو ما <span class="comment-type-2">استدركه</span> <u>ابنُ عطية</u> (٦/٥٣١) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> بقوله: «ويعترض بأنّه غير مخاطب [أي: الهدهد]، فكيف يتكلم في معنى شرْع». ثم <span class="comment-type-4">ذكر</span> أنّ الآيات تحتمل احتمالين: <b>أحدهما</b>: أن تكون من قول سليمان لما أخبره الهدهد عن القوم. <b>والآخر</b>: أن تكون من قول الله تعالى اعتراضًا بين الكلامين. و<span class="comment-type-3">رجح</span> الثاني، فقال: «وهو الثابت مع التأمل». ولم يذكر مستندًا. ثم <span class="comment-type-4">قال</span>: «وقراءة التشديد في <span class="qpc-hafs">﴿ألّا﴾</span> تعطي أن الكلام للهدهد، وقراءة التخفيف تمنعه وتقوي الآخر حسب ما سمع، ويتأمل». و<span class="comment-type-4">بيَّن</span> (٦/٥٣٤) أنّ قراءة ‹ويَعْلَمُ ما يُخْفُونَ› بياء الغائب تُعطي أنّ الآية من كلام الهدهد، وأن قراءتها بتاء المخاطبة تُعْطِي أنه من كلام الله.</div></p></div>",footnotes:1:أخرجه يحيى بن سلام ٢/٥٤٠.|2:تفسير مقاتل بن سليمان ٣/٣٠٢.|3:أخرجه ابن جرير ١٨/٤٤.|4:أخرجه ابن جرير ١٨/٤٤.
  27,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ سَنَنظُرُ أَصَدَقۡتَ أَمۡ كُنتَ مِنَ ٱلۡكَـٰذِبِینَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال <span class="name-2">الحسن [البصري]</span>: فابتلي -أي: فاختبر منه ذلك-، فوجده صادقًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> سليمان للهدهد: دُلَّنا على الماء، <span class="qpc-hafs">﴿سننظر﴾</span> فيما تقول؛ <span class="qpc-hafs">﴿أصدقت﴾</span> في قولك، <span class="qpc-hafs">﴿أم كنت﴾</span> يعني: أم أنت <span class="qpc-hafs">﴿من الكاذبين﴾</span>. مثل قوله ﷿: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> [آل عمران:١١٠]. وكان الهدهد يَدُلُّهم على قُرْبِ الماء من الأرض إذا نزلوا، فدلَّهم على ماء، فنَزلوا، واحتفروا الرَّكايا، وروى الناسُ والدوابُّ، وكانوا قد عطشوا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿سننظر أصدقت أم كنت من الكاذبين﴾</span>، قال: لم يصدقه، ولم يكذبه{3}. (١١/٣٥٧)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ٢/٥٤١.|2:تفسير مقاتل بن سليمان ٣/٣٠٢.|3:عزاه السيوطي إلى ابن المنذر.
  27,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱذۡهَب بِّكِتَـٰبِی هَـٰذَا فَأَلۡقِهۡ إِلَیۡهِمۡ ثُمَّ تَوَلَّ عَنۡهُمۡ فَٱنظُرۡ مَاذَا یَرۡجِعُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿اذهب بكتابي هذا﴾</span> قال: كَتَب معه بكتاب، فقال: <span class="qpc-hafs">﴿اذهب بكتابي هذا فألقه إليهم ثم تول عنهم﴾</span> يقول: كن قريبًا منهم، <span class="qpc-hafs">﴿فانظر ماذا يرجعون﴾</span>. فانطلق بالكتاب، حتى إذا تَوَسَّط عرشَها ألقى الكتاب إليها، فقُرِئ عليها، فإذا فيه: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>{1}. (١١/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عطاء بن السائب- قال: فذكر ما ذكر اللهُ في كتابه، فكتب سليمانُ الكتابَ، فأخذ بمنقاره، فأتى بَهْوَها، فجعل يدور فيه، فقالت: ما رأيتُ حينًا منذ رأيت هذا الطير في بَهْوِي. فألقى الكتابَ إليها، فأخذته، فإذا فيه: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم ألا تعلوا علي وأتوني مسلمين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قوله: <span class="qpc-hafs">﴿اذهب بكتابي هذا فألقه إليهم﴾</span>: فمضى الهدهدُ بالكتاب، حتى إذا حاذى الملكة -وهي على عرشها- ألقى إليها بالكتاب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق محمد بن إسحاق، عن بعض أهل العلم- قوله: <span class="qpc-hafs">﴿فألقه إليهم ثم تول عنهم﴾</span> أي: كن قريبًا، <span class="qpc-hafs">﴿فانظر ماذا يرجعون﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٢<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: كتب سليمان -يعني: مع الهدهد-: بسم الله الرحمن الرحيم، مِن سليمان بن داود، إلى بلقيس بنت ذي شرح وقومها، أما بعد، فلا تعلوا عليَّ وأتوني مسلمين. قال: فأخذ الهدهدُ الكتابَ برجله، فانطلق به حتى أتاها، وكانت لها كوة في بيتها، إذا طلعت الشمس نظرت إليها، فسجدت لها، فأتى الهدهد الكوة، فسدها بجناحيه، حتى ارتفعت الشمس ولم تعلم، ثم ألقى الكتاب مِن الكوة، فوقع عليها في مكانها الذي هي فيه، فأخذته{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: كانت صاحبة سبأ إذا رقدت غَلَّقت الأبواب، وأخذت المفاتيح، فوَضَعَتْها تحت رأسها، فلما غلقت الأبواب وآوت إلى فراشها جاءها الهدهد، حتى دخل من كوة بيتها، فقذف الصحيفة على بطنها وبين ثدييها، فأخذت الصحيفة، فقرأتها، فقالت: <span class="qpc-hafs">﴿يا أيها الملأ إني ألقي إلي كتاب كريم﴾</span>{6}. (١١/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فدعا سليمانُ الهدهدَ، وقال: <span class="qpc-hafs">﴿اذهب بكتابي هذا فألقه إليهم﴾</span> يعني: إلى أهل سبأ، <span class="qpc-hafs">﴿ثم تول﴾</span> يقول: ثم انصرف <span class="qpc-hafs">﴿عنهم فانظر ماذا يرجعون﴾</span> الجواب. فحمل الهدهدُ الكتابَ بمنقاره، فطار حتى وقف على رأس المرأة، فرفرف ساعةً والناس ينظرون، فرفعت المرأةُ رأسها، فألقى الهدهدُ الكتابَ في حِجْرِها، فلما رأت الكتاب ورأت الخاتم رعدت، وخضعت، وخضع مَن معها من الجنود؛ لأنّ مُلْكَ سليمان ﵇ كان في خاتمه، فعرفوا أنّ الذي أرسل هذا الطير أعظم مُلكًا مِن مُلْكها، فقالت: إنّ مَلِكًا رُسُله الطير، إن ذلك الملك لملك عظيم! فقرأت هي الكتاب، وكانت عربية مِن قوم تبع بن أبي شراحيل الحميري، وقومها من قوم تبع، وهم عرب، فأخبرتهم بما في الكتاب، ولم يكن فيه شيء غير: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم ألا تعلوا علي﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٥<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قول الله: <span class="qpc-hafs">﴿فألقه إليهم ثم تول عنهم﴾</span>، يقول: تنَحَّ عنهم ناحية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: فأجابه سليمان، يعني: أجاب الهدهد لما فرغ: <span class="qpc-hafs">﴿قال سننظر أصدقت أم كنت من الكاذبين. اذهب بكتابي هذا فألقه إليهم﴾</span>، وانظر ماذا يرجعون، <span class="qpc-hafs">﴿ثم تول عنهم﴾</span>مُنصَرِفًا إلَيَّ. وقال: وكانت لها كوة مستقبلة الشمس، ساعةَ تطلع الشمس تطلع فيها، فتسجد لها، فجاء الهدهد حتى وقع فيها، فسَدَّها، واسْتَبْطَأَتِ الشمسَ، فقامت تنظر، فرمى بالصحيفة إليها مِن تحت جناحه، وطار حتى قامت تنظر الشمس{9}<span class=comment-ref>٤٨٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦١</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٨/٤٥) على قول ابن زيد، فقال: «فهذا القولُ مِن قول ابن زيد يدلُّ على أنّ الهدهد تولى إلى سليمان راجعًا بعد إلقائه الكتاب، وأن نظره إلى المرأة ما الذي ترجع وتفعل كان قبل إلقائه كتاب سليمان إليها».</div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿اذهب بكتابي هذا فألقه إليهم ثم تول عنهم﴾</span> يقول: ثم انصرف عنهم، <span class="qpc-hafs">﴿فانظر ماذا يرجعون﴾</span>{10}<span class=comment-ref>٤٨٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٢</span> اختلف السلفُ في تفسير قوله: <span class="qpc-hafs">﴿اذهب بكتابي هذا... ثم تولّ عنهم﴾</span> على قولين: <b>الأول</b>: أن معناه: اذهب بكتابي هذا، فألقه إليهم، فانظر ماذا يرجعون، ثم تول عنهم منصرفًا إليَّ. فهو من المؤخر الذي معناه التقديم. <b>الثاني</b>: أن معناه: اذهب بكتابي هذا فألقه إليهم، ثم تول عنهم، فكن قريبًا منهم، وانظر ماذا يرجعون.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٨/٤٦) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الثاني، فقال: «وهذا القول أشبه بتأويل الآية؛ لأن مراجعة المرأة قومها كانت بعد أن ألقي إليها الكتاب، ولم يكن الهدهد لينصرف، وقد أمر بأن ينظر إلى مراجعة القوم بينهم ما يتراجعونه قبل أن يفعل ما أمره به سليمان».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/٥٣٤) <span class="mustanad">مستندًا إلى دلالة العقل</span> حيث قال: «واتِّساق رتبة الكلام أظهر، أي: ألقه، ثم تول. وفي خلال ذلك: فانظر، وإنما أراد أن يكل الأمر إلى حكم ما في الكتاب، دون أن يكون للرسول ملازمة، وبلا إلحاح».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٧٠-٢٨٧١.|2:أخرجه ابن أبي حاتم ٩/٢٨٧٠.|3:أخرجه ابن جرير ١٨/٤٨، وإسحاق البستي في تفسيره ص١٥، وابن أبي حاتم ٩/٢٨٧٠.|4:أخرجه ابن جرير ١٨/٤٦.|5:أخرجه ابن جرير ١٨/٤٦-٤٧.|6:أخرجه عبد الرزاق ٢/٨٠، وابن جرير ١٨/٤٧، كما أخرجه يحيى بن سلام ٢/٥٤١ من طريق سعيد، وكذلك ابن أبي حاتم ٩/٢٨٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:تفسير مقاتل بن سليمان ٣/٣٠٢-٣٠٣. وبعضه في تفسير الثعلبي ٧/٢٠٥، وتفسير البغوي ٦/١٥٨ منسوبًا إلى مقاتل دون تعيينه.|8:أخرجه ابن أبي حاتم ٩/٢٨٧١.|9:أخرجه ابن جرير ١٨/٤٦. وفي تفسير الثعلبي ٧/٢٠٥ قال ابن زيد: في الآية تقديم وتأخير، مجازها: اذهب بكتابي هذا فألقه إليهم، وانظر ماذا يرجعون، ثم تول عنهم، أي: انصرف. وفي تفسير البغوي ٦/١٥٨: فقرأت الكتاب، وتأخر الهدهد غير بعيد، فجاءت حتى قعدت على سرير مملكتها، وجمعت الملأ من قومها، وهم اثنا عشر ألف قائد، مع كل قائد مائة ألف مقاتل.|10:تفسير يحيى بن سلام ٢/٥٤١.
  27,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَتۡ یَـٰۤأَیُّهَا ٱلۡمَلَؤُا۟ إِنِّیۤ أُلۡقِیَ إِلَیَّ كِتَـٰبࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿يا أيها الملأ إني ألقي إلي كتاب كريم﴾</span>، قال: فلمّا ألقى الكتابَ إليها سقط في خَلَدِها{1} أنّه كتاب كريم؛ أشفقت منه، فقالت لملئها: <span class="qpc-hafs">﴿يا أيها الملأ إني ألقي إلي كتاب كريم﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٠٩<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: كانت لها كَوَّة مستقبلة الشمس، تقع الشمس فيها حين تطلع، فإذا نظرت إليها سجدت لها، فجاء الهدهد الكَوَّة، فسَدَّها بجناحيه، فارتفعت الشمس ولم تعلم، فلمّا استبطأت الشمس قامت تنظر، فرمى بالصحيفة إليها، فأخذت بلقيس الكتاب، وكانت قارئة، فلما رأت الخاتمَ أرعدت وخضعت؛ لأنّ ملك سليمان كان في خاتمه، وعرفَتْ أنّ الذي أرسل الكتاب إليها أعظم ملكًا منها، فقرأت الكتاب، وتأخر الهدهد غير بعيد، فجاءت حتى قعدت على سرير مملكتها، وجمعت الملأ مِن قومها، وهم اثنا عشر ألف قائد، مع كل قائد مائة ألف مقاتل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١١<span class="dash">-</span></span> و<span class="name-2">أبو حمزة الثمالي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٢<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: كان أهل مشورتها ثلاثمائة وثلاثة عشر رجلًا، كل رجل منهم على عشرة آلاف، قالوا: فجاؤوا، وأخذوا مجالسهم، فقالت لهم بلقيس: <span class="qpc-hafs">﴿يا أيُّها المَلَأُ إنِّي أُلْقِيَ إلَيَّ كِتابٌ كَرِيمٌ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٣<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق محمد بن إسحاق- <span class="qpc-hafs">﴿اذهب بكتابي هذا فألقه إليهم ثم تول عنهم﴾</span>، قال: فأخذ الهدهدُ الكتابَ برِجله، فانطلق به حتى أتاها، وكانت لها كوة في بيتها، إذا طلعت الشمس نظرت إليها، فسجدت لها، فأتى الهدهد الكوةَ، فسَدَّها بجناحيه، حتى إذا ارتفعت الشمس ولم تعلم ألقى الكتابَ مِن الكوة، فوقع عليها في مكانها الذي هي فيه، فأخذته، وكانت امرأةً لبيبةً أديبةً ببيت لِمَلِك، لم تملك إلا لبقايا ملك مَن مضى مِن أهلها، قد سِيسَت وساسَتْ حتى أحْكَمَها ذلك، وكان دينُها ودينُ قومها -فيما ذُكِر لي- الزِّنديقِيَّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فـ<span class="qpc-hafs">﴿قالت﴾</span> المرأة لهم: <span class="qpc-hafs">﴿يا أيها الملأ﴾</span> يعني: الأشراف، <span class="qpc-hafs">﴿إني ألقي إلي كتاب كريم﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كِتَـٰبࣱ كَرِیمٌ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿إني ألقي إلي كتاب كريم﴾</span>، قال: مختوم{7}. (١١/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كريم﴾</span>: أي: شريف؛ لشرف صاحبه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٨<span class="dash">-</span></span> و<span class="name-2">عطاء</span>: سَمَّته: كريمًا؛ لأنه كان مختومًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- قال: <span class="qpc-hafs">﴿إني ألقي إلي كتاب كريم﴾</span>، تقول: حسن ما فيه{10}. (١١/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿كتاب كريم﴾</span>، قال: مختوم{2}. (١١/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿كتاب كريم﴾</span>، قال: حسن، حسن ما فيه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كتاب كريم﴾</span> يعني: كتاب حسن، <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم* ألا تعلوا علي وأتوني مسلمين﴾</span>. ثم قالت: إن يكن هذا الملِك يُقاتل على الدنيا فإنّا نُمِدُّه بما أراد مِن الدنيا، وإن يكن يُقاتل لربه فإنّه لا يطلب الدنيا، ولا يريدها، ولا يقبل مِنّا شيئًا غير الإسلام{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٣<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قوله: <span class="qpc-hafs">﴿كتاب كريم﴾</span>، قال: أشْفَقَتْ منه، تريد: مختوم، وكذلك الملوك تختم كتبها، لا تجيز بينها كتابًا إلا بخاتم{2}. (١١/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إني ألقي إلي كتاب كريم﴾</span>، قال: هو كتاب سليمان حيث كتب إليها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٥<span class="dash">-</span></span> قال <span class="name-3">أبو صالح [الهذيل بن حبيب الدنداني]</span>: ويقال: مختوم{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كِتَـٰبࣱ كَرِیمٌ ۝٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٢٦<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>إكرامُ الكتاب خَتْمُه</b>»{17}. (ز)</p></p><p></div></p></div>",footnotes:1:الخَلَد: البال والقلب والنفس، يقال: وقع ذلك في خَلَدي، أي: في رُوعي وقلبي. اللسان (خلد).|2:أخرجه ابن أبي حاتم ٩/٢٨٧٢.|3:تفسير الثعلبي ٧/٢٠٥، وتفسير البغوي ٦/١٥٨.|4:تفسير الثعلبي ٧/٢٠٥، وتفسير البغوي ٦/١٥٨.|5:أخرجه ابن أبي حاتم ٩/٢٨٧٠، وأخرج آخره ابن جرير ١٨/٥٤ عن وهب من طريق محمد بن إسحاق عن بعض أهل العلم.|6:تفسير مقاتل بن سليمان ٣/٣٠٣.|7:عزاه السيوطي إلى ابن مردويه.|8:تفسير الثعلبي ٧/٢٠٦، وتفسير البغوي ٦/١٥٩.|9:تفسير الثعلبي ٧/٢٠٥ عن الضحاك، وتفسير البغوي ٦/١٥٩.|10:أخرجه ابن أبي حاتم ٩/٢٨٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.|11:أخرجه ابن أبي حاتم ٩/٢٨٧٢.|12:علَّقه يحيى بن سلام ٢/٥٤٢|13:تفسير مقاتل بن سليمان ٣/٣٠٣.|14:أخرجه ابن أبي حاتم ٩/٢٨٧٢.|15:أخرجه ابن جرير ١٨/٤٨.|16:تفسير مقاتل بن سليمان ٣/٣٠٣.|17:أخرجه القضاعي ١/٥٨ (٣٩)، والطبراني في الأوسط ٤/١٦٢ (٣٨٧٢)، والثعلبي ٧/٢٠٦.</p><p>قال الطبراني: «لم يروِ هذا الحديثَ عن ابن جريج إلا محمد بن مروان، تفرد به يحيى بن طلحة». وقال الهيثمي في المجمع ٨/٩٩ (١٣١٧٦): «رواه الطبراني في الأوسط، وفيه محمد بن مروان السُّدِّيّ الصغير، وهو متروك». وقال الألباني في الضعيفة ٤/٦٩ (١٥٦٧): «موضوع».
  27,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ مِن سُلَیۡمَـٰنَ وَإِنَّهُۥ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ ۝٣٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٢٧<span class="dash">-</span></span> عن ابن <span class="name-1">بريدة</span>، عن <span class="name-1">أبيه</span>، قال: كنت أمشي مع رسول الله ﷺ، فقال: «<b>إنِّي أعلمُ آيةً لم تنزل على نبيٍّ قبلي بعد سليمان بن داود</b>». قال: فقلت: يا رسول الله، أي آية؟ قال: «<b>سأُعَلِّمُكَها قبل أن أخرج من المسجد</b>». قال: فانتهى إلى الباب، فأخرج إحدى قدميه، فقلت: نَسِي. ثم التَفَتَ إلَيَّ، فقال: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود بن أبي هند- قال: كان أهل الجاهلية يكتبون: باسمك اللهم. فكتب النبي ﷺ أول ما كتب: «<b>باسمك اللهم</b>». حتى نزلت: <span class="qpc-hafs">﴿بسم الله مجراها ومرساها﴾</span> [هود:٤١]؛ فكتب: «<b>بسم الله</b>». ثم نزلت: <span class="qpc-hafs">﴿ادعوا الله أو ادعوا الرحمن﴾</span> [الإسراء:١١٠]؛ فكتب: «<b>بسم الله الرحمن</b>». ثم أنزلت الآية التي في «طس»: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>؛ فكتب: «<b>بسم الله الرحمن الرحيم</b>»{2}. (١١/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٢٩<span class="dash">-</span></span> عن الحارث العُكْلِيِّ، قال: قال لي <span class="name-2">عامر الشعبي</span>: كيف كان كتاب النبي ﷺ إليكم؟ قلت: «<b>باسمك اللهم</b>». فقال: ذاك الكتاب الأول، كتب النبي ﷺ: «<b>باسمك اللهم</b>». فجرت بذلك ما شاء الله أن تجري، ثم نزلت: <span class="qpc-hafs">﴿بسم الله مجراها ومرساها﴾</span> [هود:٤١]؛ فكتب: «<b>بسم الله</b>». فجرت بذلك ما شاء الله أن تجري، ثم نزلت: <span class="qpc-hafs">﴿قل ادعوا الله أو ادعوا الرحمن﴾</span> [الإسراء:١١٠]؛ فكتب: «<b>بسم الله الرحمن</b>» فجرت بذلك ما شاء الله أن تجري، ثم نزلت: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>؛ فكتب بذلك{3}. (١١/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك</span>، قال: كان النبي ﷺ يكتب: «<b>باسمك اللهم</b>». فلمّا نزلت: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span> كتب: «<b>بسم الله الرحمن الرحيم</b>»{4}. (١١/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣١<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span>: أنّ النبي ﷺ كان يكتب: «<b>باسمك اللهم</b>». حتى نزلت: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>{5}. (١١/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة</span>، قال: لم يكن الناس يكتبون إلا: باسمك اللهم. حتى نزلت: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>{6}. (١١/٣٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن معبد الزِّمّاني</span> -من طريق ثابت بن عمارة- قال: لم تنزل <span class="qpc-hafs">﴿بسم الله الرحمن الرحيم﴾</span> في شيء من القرآن إلا في سورة النمل: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ مِن سُلَیۡمَـٰنَ وَإِنَّهُۥ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: أنّ سليمان كتب إلى ملكة سبأ: بسم الله الرحمن الرحيم، من عبد الله سليمان بن داود، إلى بلقيس ملكة سبأ، السلام على مَن اتَّبع الهدى، أما بعد، فلا تعلوا عَلَيَّ، وأتوني مسلمين{8}. (١١/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حصين بن عبد الرحمن- قال: لم يكن في كتاب سليمان إلى صاحبة سبأ إلا ما تقرؤون في القرآن: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span>{9}. (١١/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: كتب سليمان -يعني: مع الهدهد-: بسم الله الرحمن الرحيم، من سليمان بن داود، إلى بلقيس بنت ذي شرح وقومها، أما بعد، فلا تعلوا عليَّ، وأتوني مسلمين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿يا أيها الملأ إني ألقي إليَّ كتاب كريم إنه من سليمان وإنه بسم الله الرحمن الرحيم﴾</span> من سليمان بن داود، إلى بلقيس بنت ذي مشرح: <span class="qpc-hafs">﴿أن لا تعلوا عليَّ﴾</span> قال: لا تَجَبَّروا عليَّ، وأتوني مسلمين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٨<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق محمد بن إسحاق- قال: كتب: بسم الله الرحمن الرحيم، من سليمان بن داود، إلى بلقيس بنت ذي شرح وقومها{12}. (١١/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الرحمن الرحيم﴾</span>، قال: لم يزِد -زعموا- على هذا الكتاب على ما قَصَّ اللهُ{13}. (١١/٣٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ مِن سُلَیۡمَـٰنَ وَإِنَّهُۥ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٤٠<span class="dash">-</span></span> عن سعيد بن المسيب، قال: كتب رسول الله ﷺ إلى كسرى وقيصر والنجاشي: «<b>أما بعد، فـ<span class="qpc-hafs">﴿تعالوا إلى كلمة سواء بيننا وبينكم؛ أن لا نعبد إلا الله، ولا نشرك به شيئًا، ولا يتخذ بعضنا بعضا أربابًا من دون الله، فإن تولوا فقولوا: اشهدوا بأنا مسلمون﴾</span></b>» [آل عمران: ٦٤]. فلمّا أتى كتابُ النبيِّ ﷺ إلى قيصر، فقرأه، قال: إنّ هذا الكتاب لم أره بعد سليمان بن داود: بسم الله الرحمن الرحيم{14}. (١١/٣٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤١<span class="dash">-</span></span> عن <span class="name-2">منصور بن المعتمر</span> -من طريق سفيان- قال: كان يُقال: كان سليمان بن داود أبلغ الناس في كتاب، وأقله إملاء. ثم قرأ: <span class="qpc-hafs">﴿إنه من سليمان﴾</span> الآية{15}. (١١/٣٦٠)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو نعيم في أخبار أصبهان ٢/١٥٧، وابن أبي حاتم ٩/٢٨٧٣ (١٦٣٠٦)، والثعلبي ١/١٠٢.</p><p>قال ابن كثير في تفسيره ٦/١٨٩: «هذا حديث غريب، وإسناده ضعيف». وقال الألباني في الضعيفة ١٢/٦١١ (٥٧٧٩): «ضعيف جدًّا».|2:أخرجه عبد الرزاق ٢/٨١، وابن سعد ١/٢٦٣-٢٦٤، وابن أبي شيبة ١٤/١٠٥، وابن أبي حاتم ٩/٢٨٧٣ مرسلًا.|3:أخرجه أبو عبيد في فضائله ص١١٣ مرسلًا.|4:أخرجه أبو داود في كتاب المراسيل ص٩٠ (٣٥).|5:أخرجه ابن أبي حاتم ٩/٢٨٧٣ مرسلًا.|6:أخرجه عبد الرزاق في تفسيره ٢/٨١ مرسلًا. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٦/٥٤٢ (٣٢٥١٧).|8:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:أخرجه ابن أبي حاتم ٩/٢٨٧٣.|10:أخرجه ابن جرير ١٨/٤٦.|11:أخرجه إسحاق البستي في تفسيره ص١٤.|12:أخرجه ابن أبي حاتم ٩/٢٨٧٢-٢٨٧٣.|13:أخرجه ابن جرير ١٨/٤٧ بلفظ: لم يزد سليمان على ما قصَّ الله في كتابه: <span class="qpc-hafs">﴿إنه﴾</span>، <span class="qpc-hafs">﴿وإنه﴾</span>. وعزاه السيوطي إلى ابن المنذر.|14:أخرجه سعيد بن منصور ٢/٢٢٦-٢٢٧ (٢٤٨٠)، وابن أبي شيبة ٧/٣٤٧ (٣٦٦٢٧) مطولًا مرسلًا.|15:أخرجه ابن أبي حاتم ٩/٢٨٧٤. وعزاه السيوطي إلى عبد بن حميد.
  27,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَّا تَعۡلُوا۟ عَلَیَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span>، قال: أي: لا تَتَكَبَّروا عَلَيَّ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم ألا تعلوا علي وأتوني مسلمين﴾</span>، يقول: لا تخالفوا عَلَيَّ، وأتوني مسلمين. قال: وكذلك كانت الأنبياء تكتب جُمَلًا، لا يُطْنِبون ولا يُكْثِرون{2}. (١١/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أن لا تعلوا عليَّ﴾</span> قال: لا تَجَبَّروا عَلَيَّ، <span class="qpc-hafs">﴿وأتوني مسلمين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه من سليمان وإنه بسم الله الرحمن الرحيم ألا تعلوا علي﴾</span> ألا تَعظموا عليَّ، <span class="qpc-hafs">﴿وأتوني مسلمين﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٦<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قول الله: <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span>، يقول: لا تعصوني{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق مهران- <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span>، يقول: لا تأبوا عليَّ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span>: ألا تمتنعوا من الذي دعوتكم إليه، إن امتنعتم جاهدتكم. فقلت لابن زيد: <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span> ألا تتكبروا علي؟ قال: نعم{7}<span class=comment-ref>٤٨٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٣</span> لم يذكر <u>ابنُ جرير</u> (١٨/٤٩) في معنى قوله: <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span> غير قول ابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥٧٢٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿ألا تعلوا علي﴾</span>: أي: لا تمتنعوا عليَّ. وقال بعضهم في الأمر: ألا تَخَلَّفوا عنِّي، <span class="qpc-hafs">﴿وأتوني مسلمين﴾</span> قال: وكذلك كانت تكتبُ الأنبياءُ جُمَلًا؛ لا يُطْنِبون، ولا يُكْثِرون{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأۡتُونِی مُسۡلِمِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿مسلمين﴾</span>، يقول: مُوَحِّدين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥١<span class="dash">-</span></span> تفسير <span class="name-2">قتادة بن دعامة</span>: في قوله: <span class="qpc-hafs">﴿وأتوني مسلمين﴾</span>، يعني: الإسلام{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: تفسير <span class="name-3">الكلبي</span>: وأتوني مُقِرِّين بالطاعة. أي: مستسلمين، ليس يعني: الإسلام{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٣<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد</span> -من طريق الوليد- <span class="qpc-hafs">﴿وأتوني مسلمين﴾</span>، يقول: مخلصين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق مهران - في قوله: <span class="qpc-hafs">﴿وأتوني مسلمين﴾</span>، قال: طائعين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/١٥٩.|2:أخرجه ابن أبي حاتم ٩/٢٨٧٣-٢٨٧٤، وأخرج آخره ابن جرير ١٨/٤٧ من طريق معمر مطولًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه إسحاق البستي في تفسيره ص١٤، وابن أبي حاتم ٩/٢٨٧٤ وفيه: لا تَجَرَّءوا عَلَيَّ.|4:تفسير مقاتل بن سليمان ٣/٣٠٢.|5:أخرجه ابن أبي حاتم ٩/٢٨٧٤.|6:أخرجه ابن أبي حاتم ٩/٢٨٧٤.|7:أخرجه ابن جرير ١٨/٤٩، وابن أبي حاتم ٩/٢٨٧٤ من طريق أصبغ.|8:تفسير يحيى بن سلام ٢/٥٤٢.|9:أخرجه ابن أبي حاتم ٩/٢٨٧٤.|10:علَّقه يحيى بن سلام ٢/٥٤٢.|11:علَّقه يحيى بن سلام ٢/٥٤٢.|12:أخرجه ابن أبي حاتم ٩/٢٨٧٤.|13:أخرجه ابن أبي حاتم ٩/٢٨٧٤.
  27,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَتۡ یَـٰۤأَیُّهَا ٱلۡمَلَؤُا۟ أَفۡتُونِی فِیۤ أَمۡرِی مَا كُنتُ قَاطِعَةً أَمۡرًا حَتَّىٰ تَشۡهَدُونِ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿قالت يا أيها الملأ أفتوني في أمري﴾</span>، قال: جَمَعَتْ رؤوسَ مملكتها، فشاورتهم في أمرها، فاجتمع رأيُهم ورأيُها على أن يغزوه{1}. (١١/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٦<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قوله: <span class="qpc-hafs">﴿أفتوني في أمري﴾</span> تقول: أشيروا عَلَيَّ برأيكم، <span class="qpc-hafs">﴿ما كنت قاطعة أمرا حتى تشهدون﴾</span> تريد: حتى تُشِيرون{1}. (١١/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استشارتهم، فـ<span class="qpc-hafs">﴿قالت يا أيها الملأ﴾</span> يعني: الأشراف، وهم: ثلاثمائة وثلاثة عشر قائدًا، مع كل قائد مائة ألف، وهم أهل مشورتها، فقالت لهم: <span class="qpc-hafs">﴿أفتوني في أمري﴾</span> مِن هذا، <span class="qpc-hafs">﴿ما كنت قاطعة أمرا حتى تشهدون﴾</span> تقول: ما كنت قاضية أمرًا حتى تحضرون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: دَعَتْ قومَها، فشاورتهم: أيها الملأ، <span class="qpc-hafs">﴿أفتوني في أمري ما كنت قاطعة أمرا حتى تشهدون﴾</span>. فقال: في الكلام: ما كنت لأقطع أمرًا دونك، ولا كنت لأقضي أمرًا. فلذلك قالت: <span class="qpc-hafs">﴿ما كنت قاطعة أمرا﴾</span> بمعنى: قاضية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿قالت يا أيها الملأ أفتوني في أمري﴾</span>: استشارتهم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٧٥.|2:أخرجه ابن أبي حاتم ٩/٢٨٧٥.|3:تفسير مقاتل بن سليمان ٣/٣٠٣.|4:أخرجه ابن جرير ١٨/٥٠.|5:تفسير يحيى بن سلام ٢/٥٤٢.
  27,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ نَحۡنُ أُو۟لُوا۟ قُوَّةࣲ وَأُو۟لُوا۟ بَأۡسࣲ شَدِیدࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٦٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كان لصاحبةِ سليمان اثنا عشر ألف قَيْل{1}، تحت كل قَيْل مائة ألف{2}. (١١/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- قال: كان تحت يدي ملكة سبأ اثنا عشر ألف قَيْوِل، تحت يدي كل قَيْوِل مائة ألف مقاتل، وهم الذين قالوا: <span class="qpc-hafs">﴿نحن أولوا قوة وأولو بأس شديد﴾</span>{3}<span class=comment-ref>٤٨٦٤</span>. (١١/٣٦٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٤</span> ذكر <u>ابن عطية</u> (٦/٥٣٦) قول مجاهد، ثم <span class="comment-type-2">انتقده</span> بقوله: «وهذا بعيد، وذكر غيرُه نحوَه، فاختصرته؛ لِبُعد الصِّحَّة عنه».</div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: ذُكِر لنا: أنّه كان أولو مشورتها ثلاثمائة واثني عشر رجلًا، كل رجل منهم على عشرة آلافٍ مِن الرجال{4}. (١١/٣٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالوا نحن أولو قوة﴾</span> يعني: عددًا كثيرًا، في تفسير <span class="name-2">السُّدِّيّ</span>، <span class="qpc-hafs">﴿وأولو بأس شديد﴾</span> يعني: القتال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالت يا أيها الملأ﴾</span> يعني: الأشراف، وهم ثلاثمائة وثلاثة عشر قائدًا، مع كل قائد مائة ألف، وهم أهل مشورتها ... <span class="qpc-hafs">﴿قالوا﴾</span> لها: <span class="qpc-hafs">﴿نحن أولوا قوة﴾</span> يعني: عِدَّة كثيرة في الرجال. كقوله: <span class="qpc-hafs">﴿فَأَعِينُونِي بِقُوَّةٍ﴾</span> [الكهف:٩٥]، يعني: بالرجال. <span class="qpc-hafs">﴿وأولوا بأس شديد﴾</span> في الحرب، يعني: الشجاعة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٥<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قول الله: <span class="qpc-hafs">﴿نحن أولوا قوة﴾</span>، قالوا: نحن اثنا عشر ألف ملِك، مع كل ملِك اثنا عشر ألف مستلم في السلاح{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿قالوا نحن أولو قوة وأولو بأس شديد﴾</span>: عَرَضوا لها القتال، يُقاتِلون لها، والأمرُ إليكِ بعد هذا، فانظري ماذا تأمرين{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٧<span class="dash">-</span></span> عن العباس بن <span class="name-3">الوليد [بن مزيد البيروتي]</span>، عن <span class="name-3">أبيه</span>، قال: بلغني في قول الله: <span class="qpc-hafs">﴿قالوا نحن أولو قوة وأولو بأس شديد﴾</span>: نحن اثنا عشر ألف أسوار، مع كل واحد من الأسوار اثنا عشر ألف مستلم. والمستلم: صاحب السلاح، فمَن يحصي جيش هؤلاء كم كانوا؟ قال العباس: فذهبت أحصي كم كانوا، فإذا هم ألف ألف ومائتي ألف{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡأَمۡرُ إِلَیۡكِ فَٱنظُرِی مَاذَا تَأۡمُرِینَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٦٨<span class="dash">-</span></span> عن أيوب، قال: سمعت <span class="name-2">الحسن البصري</span> يقول، وسُئِل عن هذه الآية: <span class="qpc-hafs">﴿والأَمْرُ إلَيْكِ فانْظُرِي ماذا تَأْمُرِينَ﴾</span>، قال: ولَّوا أمرهم عِلْجَةً تضطرب ثدياها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والأمر إليك﴾</span> يقول: قد أخبرناكِ بما عندنا، وما نُجاوز ما تقولين، <span class="qpc-hafs">﴿فانظري ماذا تأمرين﴾</span> يعني: ماذا تشيرين علينا. كقول فرعون لقومه: <span class="qpc-hafs">﴿فَماذا تَأْمُرُونَ﴾</span> [الأعراف:١١٠، والشعراء:٣٥]، يعني: ماذا تُشيرون عَلَيَّ{11}. (ز)</p></p><p></div></p></div>",footnotes:1:قَيْل: هو أحد ملوك حِمْيَر، دونَ المَلِكِ الأَعْظم. اللسان (قيل).|2:عزاه السيوطي إلى ابن أبي حاتم بهذا اللفظ. وفي المطبوع من تفسير ابن أبي حاتم ٩/٢٨٧١ من طريق مجاهد بلفظ: كان تحتها ألف قيل، كل قيل على مائة ألف، وأخرجه ابن جرير ١٨/٥١ من طريق مجاهد بلفظ: كان مع بلقيس مائة ألف قيل، مع كل قيل مائة ألف.|3:أخرجه ابن جرير ١٨/٥٠-٥١، وابن أبي حاتم ٩/٢٨٦٦، ٢٨٧٥، وذكر ابن جرير في إحدى الروايات عن أحد رواتها قوله: والقَيْوِل بلسانهم: الملك. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|4:أخرجه عبد الرزاق ٢/٨٠، وابن جرير ١٨/٤٧، وابن أبي حاتم ٩/٢٨٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه يحيى بن سلام ٢/٥٤٢ من طريق سعيد بلفظ: ثلاثمائة وثلاثة عشر ... إلخ. ثم عقَّب عليه بقوله: فجميعهم ثلاثة آلاف ألف ومائة ألف وثلاثون ألفًا.|5:تفسير يحيى بن سلام ٢/٥٤٢.|6:تفسير مقاتل بن سليمان ٣/٣٠٤. ونحوه في تفسير البغوي ٦/١٥٩ منسوبًا إلى مقاتل دون تعيينه، لكن فيه ٦/١٥٨: كان أهل مشورتها ثلاثمائة وثلاثة عشر رجلًا، كل رجل منهم على عشرة آلاف.|7:أخرجه ابن أبي حاتم ٩/٢٨٧٥.|8:أخرجه ابن جرير ١٨/٥٠، وابن أبي حاتم ٩/٢٨٧٥ مختصرًا، من طريق أصبغ.|9:أخرجه ابن أبي حاتم ٩/٢٨٧٦.|10:أخرجه ابن أبي حاتم ٩/٢٨٧٦.|11:تفسير مقاتل بن سليمان ٣/٣٠٤.
  27,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَتۡ إِنَّ ٱلۡمُلُوكَ إِذَا دَخَلُوا۟ قَرۡیَةً أَفۡسَدُوهَا وَجَعَلُوۤا۟ أَعِزَّةَ أَهۡلِهَاۤ أَذِلَّةࣰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مسلم- في قوله: <span class="qpc-hafs">﴿إن الملوك إذا دخلوا قرية أفسدوها﴾</span>، قال: إذا أخذوها عُنْوَةً أخربوها{1}. (١١/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: في قوله: <span class="qpc-hafs">﴿قالت إن الملوك إذا دخلوا قرية أفسدوها﴾</span>، يعني: خَرَّبوها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٢<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق محمد بن إسحاق- <span class="qpc-hafs">﴿قالت إن الملوك إذا دخلوا قرية أفسدوها﴾</span>: أي: عنوة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالت إن الملوك إذا دخلوا قرية أفسدوها﴾</span> يعني: أهلكوها. كقوله ﷿: <span class="qpc-hafs">﴿لَفَسَدَتِ السَّماواتُ والأَرْضُ﴾</span> [المؤمنون:٧١]، يعني: لهلكتا{4} ومَن فيهن. ثم قال ﷿: <span class="qpc-hafs">﴿وجعلوا أعزة أهلها أذلة﴾</span> يعني: أهانوا أشرافَها وكبراءَها؛ لكي يستقيم لهم الأمر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٤<span class="dash">-</span></span> عن <span class="name-3">زهير بن محمد التميمي العنبري</span> -من طريق الوليد- في قوله: <span class="qpc-hafs">﴿وجعلوا أعزة أهلها أذلة﴾</span>، قال: بالسيف{3}. (١١/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إن الملوك إذا دخلوا قرية أفسدوها﴾</span> الآية: وقالت: إنّ هذا الرجل إن كان إنّما هِمَّتُه الدنيا فسنُرضيه، وإن كان إنما يريد الدين فلن يقبل غيرَه، <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية فناظرة بم يرجع المرسلون﴾</span>؟{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجعلوا أعزة أهلها﴾</span> عظماءها في الشرف <span class="qpc-hafs">﴿أذلة﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٧<span class="dash">-</span></span> عن أبي بكر{9} -من طريق أبي كريب- في قوله: <span class="qpc-hafs">﴿وجعلوا أعزة أهلها أذلة﴾</span>، قال: هذا عُنْوَة{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ یَفۡعَلُونَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: قالت بلقيس: <span class="qpc-hafs">﴿إن الملوك إذا دخلوا قرية أفسدوها وجعلوا أعزة أهلها أذلة﴾</span>. قال: يقول الرب -تبارك وتعالى-: <span class="qpc-hafs">﴿وكذلك يفعلون﴾</span>{11}. (١١/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿وكذلك يفعلون﴾</span> كما قالتْ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿وكذلك يفعلون﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨١<span class="dash">-</span></span> عن مجاهد عن ابن إسماعيل، قال: ثلاث آيات [لا يُعْلَمْنَ] بالرأي، ولا يَعْلَمُهُنَّ أحدٌ إلا بالرِّواية: قوله: <span class="qpc-hafs">﴿إن الملوك إذا دخلوا قرية أفسدوها وجعلوا أعزة أهلها أذلة﴾</span>، قال الله: <span class="qpc-hafs">﴿وكذلك يفعلون﴾</span>. وقوله: <span class="qpc-hafs">﴿ذلك ليعلم أني لم أخنه بالغيب وأن الله لا يهدي كيد الخائنين﴾</span> [يوسف:٥٢]. قال: قال له الملَك: اذكر همَّك. فقال: <span class="qpc-hafs">﴿وما أبرئ نفسي إن النفس لأمارة بالسوء﴾</span> [يوسف:٥٣]. وقول الله -جل جلاله-: <span class="qpc-hafs">﴿إلا امرأتك إنه مصيبها ما أصابهم إن موعدهم الصبح﴾</span> قال: قال لوط: الساعة. قال الملَك: <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span> [هود:٨١]. فلما أصبح حملها جبريل ﵇ من وسطها، حتى سمع نُباح كلابهم، ثم قلبها{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٥٢ بنحوه، وابن أبي حاتم ٩/٢٨٧٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|2:علَّقه يحيى بن سلام ٢/٥٤٢.|3:أخرجه ابن أبي حاتم ٩/٢٨٧٦.|4:في المصدر: لهلكتها.|5:تفسير مقاتل بن سليمان ٣/٣٠٤.|6:أخرجه ابن أبي حاتم ٩/٢٨٧٦.|7:أخرجه ابن جرير ١٨/٥٤.|8:تفسير يحيى بن سلام ٢/٥٤٢.|9:لعله: أبو بكر بن عياش المقرئ (ت١٩٤ﻫ).|10:أخرجه ابن جرير ١٨/٥٢.|11:أخرجه ابن أبي حاتم ٩/٢٨٧٧، كما أخرج نحوه ابن جرير ١٨/٥٢ من طريق ابن جريج.|12:تفسير مقاتل بن سليمان ٣/٣٠٤.|13:تفسير يحيى بن سلام ٢/٥٤٣.|14:أخرجه إسحاق البستي في تفسيره ص١٧.
  27,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنِّی مُرۡسِلَةٌ إِلَیۡهِم بِهَدِیَّةࣲ فَنَاظِرَةُۢ بِمَ یَرۡجِعُ ٱلۡمُرۡسَلُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٢٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span>، قال: أرسلتْ بلَبِنَة مِن ذهب، فلمّا قدموا إذا حيطان المدينة مِن ذهب، فذلك قوله: <span class="qpc-hafs">﴿أتمدونن بمال﴾</span> الآية{1}. (١١/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قالت: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية فناظرة بم يرجع المرسلون﴾</span>، قال: وبَعَثَتْ إليه بوَصائِف ووُصَفاء، وألبستْهم لباسًا واحدًا؛ حتى لا يُعرف ذكرٌ مِن أنثى، فقالت: إن زيَّل بينهم حتى يعرف الذكر مِن الأنثى، ثم ردَّ الهدية؛ فإنه نبيٌّ، وينبغي لنا أن نترك ملكنا، ونَتَّبع دينه، ونلحق به. فرد سليمان الهديةَ، وزيَّل بينهم، فقال: هؤلاء غلمان، وهؤلاء جَوارٍ. قال: <span class="qpc-hafs">﴿أتمدونن بمال فما آتاني الله خير مما آتاكم بل أنتم بهديتكم تفرحون﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: أمر سليمانُ الشياطين، فموَّهوا له ألف قصر مِن ذهب وفضة، فلمّا رأت رسلُها ذلك قالوا: ما يصنع هذا بهديتنا؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مائة وصيف، ومائة وصيفة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق يعلى بن مسلم- قال: أرسلتْ بثمانين مِن وصيف ووصيفة، وحلقت رؤوسهم كلهم، وقالت: إن عرف الغِلمان مِن الجواري فهو نبيٌّ، وإن لم يعرف الغلمان من الجواري فليس بنبي. فدعا بوضوء، فقال: توضَّؤوا. فجعل الغلامُ يأخذ مِن مرفقيه إلى كفيه، وجعلت الجاريةُ تأخذ مِن كفها إلى مرفقيها، فقال: هؤلاء جواري، وهؤلاء غلمان{5}. (١١/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- قال: كانت الهدية جَوْهَرًا{6}. (١١/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٨<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: أرسلت إليه بلبِنة مِن ذهب في حرير ودِيباج{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span>، قال: بجَوارٍ لباسُهُنَّ لباسُ الغلمان، وغلمانٍ لِباسُهُنَّ لِباسُ الجواري{8}<span class=comment-ref>٤٨٦٥</span>. (١١/٣٦٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٥</span> ذكر <u>ابنُ عطية</u> (٦/٥٣٧) على قول مجاهد هذا، فقال: «ذكر مجاهد أنها بعثت في هديتها بعدد كثير من العبيد بين غلام وجارية، وجعلت زيهم واحدًا، وجربته في التفريق بينهم». ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «وهذا ليس بتجربة في مثل هذا الأمر الخطر».</div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٠<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: مائتا غلام، ومائتا جارية{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩١<span class="dash">-</span></span> عن عبيد، قال: سمعت <span class="name-2">الضحاك بن مزاحم</span> يقول في قوله: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span>: بَعَثَتْ بوَصائِف ووُصَفاء، لباسهم لباس واحد، فقالت: إن زيَّل بينهم حتى يعرف الذكر من الأنثى، ثم رد الهدية؛ فهو نبيٌّ، وينبغي لنا أن نَتَّبِعَه، وندخل في دينه. فزيَّل سليمان بين الغلمان والجواري، وردَّ الهدية، فقال: <span class="qpc-hafs">﴿أتمدونن بمال، فما آتاني الله خير مما آتاكم﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: كانت هديةُ بلقيس لسليمان مائتي فرس، على كل فرس غلام وجارية، الغلمان والجواري على هيئة واحدة، لا يعرف الجواري مِن الغلمان، ولا الغلمان من الجواري، على كل فرس لونٌ ليس على الآخر، وكانت أول هديتهم عند سليمان وآخرها عندها{11}. (١١/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- قال: الهدية وصفان ووصائف، ولَبِنة مِن ذهب{6}. (١١/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- قال: <span class="qpc-hafs">﴿إني مرسلة إليهم بهدية﴾</span>، قال: كانت الهدية جَوْهرًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span>، قال: أرسلت بلَبِنَة مِن ذهب، وقالت: إن كان يريد الدنيا عَلِمْتُه، وإن كان يريد الآخرة عَلِمْتُه{14}<span class=comment-ref>٤٨٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٦</span> <span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٠/٤٠٥) أنّ ملكة سبأ أرسلت إلى سليمان ﵇ بآنية من ذهب، فقال: «ذكر غير واحد من المفسرين من السلف وغيرهم: أنها بعثت إليه بهدية عظيمة مِن ذهب وجواهر ولآلئ وغير ذلك. وقال بعضهم: أرسلت إليه بلبنة من ذهب. والصحيح أنها أرسلت إليه بآنية من ذهب». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: كانت بلقيسُ امرأةً لبيبة أديبة، في بيت ملك، لم تملِك إلا لبقايا مَن مضى مِن أهلها، إنّه قد سِيسَتْ وساست حتى أحكمها ذلك، وكان دينُها ودينُ قومها -فيما ذُكر- الزِّنديقية، فلما قرأت الكتاب سمعت كتابًا ليس من كتب الملوك التي كانت قبلها، فبعثت إلى المَقاوِلَة{15} من أهل اليمن، فقالت لهم: <span class="qpc-hafs">﴿يا أيها الملأ إني ألقي إلي كتاب كريم إنه من سليمان، وإنه بسم الله الرحمن الرحيم. ألا تعلوا علي وأتوني مسلمين﴾</span> إلى قوله: <span class="qpc-hafs">﴿بم يرجع المرسلون﴾</span>. ثم قالت: إنّه قد جاءني كتاب لم يأتني مثله مِن مَلِك مِن الملوك قبله، فإن يكن الرجل نبيًّا مُرسَلًا فلا طاقة لنا به ولا قُوَّة، وإن يكن الرجل مَلِكًا يُكاثر فليس بأَعَزَّ مِنّا ولا أعدَّ. فهيأت هدايا مما يُهْدى للملوك مِمّا يَضِنُّونَ به، فقالت: إن يكن ملِكًا فسيقبل الهدية، ويرغب في المال، وإن يكن نبيًّا فليس له في الدنيا حاجة، وليس إيّاها يريد، إنما يريد أن ندخل معه في دينه، ونتبعه على أمره. أو كما قالت{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٧<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق محمد بن إسحاق- مثل قوله: ثم قالت ... إلخ{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد [بن أبي عروبة]- قال: قالت: إنِّي باعثة إليهم بهدية، فمصانعتهم بها عن مُلكي؛ إن كانوا أهل دنيا. فبعثت إليهم بلَبِنَة من ذهب في حرير وديباج، فبلغ ذلك سليمان، فأمر بلَبِنَة مِن ذهب، فصُنِعت، ثم قُذِفَت تحت أرجل الدوابِّ على طريقهم تبول عليها وتروث، فلما جاء رسلها واللبنة تحت أرجل الدواب صغُر في أعينهم الذي جاؤوا به{18}. (١١/٣٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٢٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: إنّ الهدية لَمّا جاءت سليمان ميَّز بين الغلمان والجواري؛ امتحنهم بالوضوء، فغسل الغلمان ظُهُورَ السَّواعِد قبل بطونها، وغسلت الجواري بطون السَّواعِد قبل ظهورها{6}. (١١/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خالد بن قيس- في قوله: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span>، قال: رحمها الله إن كانت لَعاقِلة في إسلامها وشِركها، قد علمت أنّ الهدية تقع موقِعًا مِن الناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠١<span class="dash">-</span></span> عن <span class="name-2">ثابت بن أسلم البُناني</span> -من طريق معمر- قال: أهدت له صفائح الذهب في أوعية الديباج، فلما بلغ ذلك سليمان أمر الجنَّ، فموّهوا له الآجُرَّ بالذهب، ثم أمر به، فأُلقِي في الطريق، فلمّا جاؤوا ورأوه مُلْقًى في الطريق وفي كل مكان قالوا: جئنا نحمل شيئًا نراه ههنا مُلقًى في الطريق ما يُلْتَفَتُ إليه!. فصغر في أعينهم ما جاؤوا به{21}. (١١/٣٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قالت: إن هو قَبِلَ الهديةَ فهو ملِك؛ فقاتِلوه دون مُلْكِكم، وإن لم يقبل الهدية فهو نبيٌّ لا طاقة لكم بقتاله. فبعثت إليه بهدية؛ غلمان في هيئة الجواري وحليهم، وجواري في هيئة الغلمان ولباسهم، وبعثت إليه بلَبِناتٍ مِن ذهب، وبِخَرَزَةٍ مثقوبة مختلفة، وبَعَثَتْ إليه بقدح، وبعثت إليه بكلمة، فلما جاء سليمان الهدية أمر الشياطين، فمَوَّهوا لبِن المدينة وحيطانها ذهبًا وفضة، فلمّا رأى ذلك رسلُها قالوا: أين نذهب باللبِنات في أرضِ هؤلاء وحيطانهم ذهب وفضة؟! فحبسوا اللَّبِنات، وأدخلوا عليه ما سوى ذلك، وقالوا: أخرج لنا الغلمان من الجواري. فأمرهم فتوضئوا، فأخرَج الغلمان من الجواري؛ أما الجارية فأفرغت على يدها، وأما الغلام فاغترف، وقالوا: أدخل لنا في هذه الخرزة خيطًا. فدعا بالدَّسّاس{22}، فربط فيه خيطًا، فأدخله فيها، فجال فيها واضطرب حتى خرج من الجانب الآخر. وقالوا: املأ لنا هذا القَدَح بماء ليس من الأرض ولا من السماء. فأمر بالخيل، فأجريت، حتى إذا أزبدت مسح عرقها، فجعلوه فيه حتى ملأه. فلما رجعت رسلها فأخبروها أنّ سليمان رد الهدية وفَدَت إليه، وأمرت بعرشها فجُعِل في سبعة أبيات، وغَلَّقت عليها، فأخذت المفاتيح، فلما بلغ سليمان ما صنعت بعرشها <span class="qpc-hafs">﴿قال يا أيها الملأ أيكم يأتيني بعرشها قبل أن يأتوني مسلمين﴾</span>{23}. (١١/٣٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٣<span class="dash">-</span></span> قال عبد الرحمن بن <span class="name-2">زيد بن أسلم</span> -من طريق ابن وهب-: كان في الهدايا التي بعثت بها وصائف ووُصفاء يختلفون في ثيابهم؛ ليمِيزَ الغلمان من الجواري. قال: فدعا بماء، فجعل الجواري يتوضأن من المرفق إلى أسفل، وجعل الغلمان يتوضؤون من المرفق إلى فوق. قال: وكان <span class="name-2">أبي</span> يحدثنا هذا الحديث{24}<span class=comment-ref>٤٨٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٧</span> ذكر <u>ابنُ كثير</u> (١٠/٤٠٥-٤٠٦) ما جاء في هذا القول، وقول مَن قال: جعلت الجارية تغسل باطن زندها قبل ظاهره، والغلام العكس. وقول مَن قال: جعلت الجارية تفرغ على يدها، والغلام يغترف من الماء. وقول من قال: إنها أرسلت الغلمان في زي الجواري، والجواري في زي الغلمان. ثم <span class="comment-type-4">علّق</span> بقوله: «ولا منافاة بين ذلك كله».</div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: عشرة غِلْمان، وعشر جواري{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قالت المرأة لأهل مشورتها: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span> أُصانِعهم على مُلكي؛ إن كانوا أهل دنيا، <span class="qpc-hafs">﴿فناظرة بم يرجع المرسلون﴾</span> مِن عِندِه بالجواب. فأرسلت بالهدية مع الوفد، عليهم المنذر بن عمرو، الهدية مائة وصيف ومائة وصيفة، وجعلت للجارية قُصَّة{26} أمامها، وقُصَّة مؤخرها، وجعلت للغلام قُصَّة أمامه، وذؤابة{27} وسط رأسه، وألبستهم لباسًا واحدًا، وبعثت بحُقَّةٍ{28} فيها جوهرتان؛ إحداهما مثقوبة، والأخرى غير مثقوبة. وقالت للوفد: إن كان نبيًّا فسيُمَيِّز بين الجواري والغلمان، ويخبر بما في الحُقَّة، ويرُدُّ الهدية فلا يقبلها، وإن كان مَلِكًا فسيقبل الهدية، ولا يعلم ما في الحُقَّة. فلما انتهت الهدية إلى سليمان ﵇ ميَّز بين الوصفاء والوصائف مِن قِبَل الوضوء، وذلك أنّه أمرهم بالوضوء، فكانت الجارية تَصُبُّ الماءَ على بطن ساعِدها، والغلام على ظهر ساعده، فميَّز بين الوصفاء والوصائف، وحرَّك الحُقَّة، وجاء جبريل ﵇ فأخبره بما فيها، فقيل له: أدخِل في المثقوبة خيطًا مِن غير حيلة إنس ولا جانٍّ، واثقب الأخرى مِن غير حيلة إنس ولا جانٍّ. وكانت الجوهرة المثقوبة معوجة، فأتته دودةٌ تكون في الفصفصة{29} -وهي الرطبة-، فربط في مُؤَخَّرها خيطًا، فدخلت الجوهرة حتى أنفذت الخيط إلى الجانب الآخر، فجعل رزقها في الفصفصة، وجاءت الأرَضَةُ، فقالت لسليمان: اجعل رزقي في الخشب والسقوف والبيوت. قال: نعم. فثقبت الجوهرةَ، فهذه حيلةٌ مِن غير إنس ولا جان، وسألوه ماءً لم ينزل من السماء، ولم يخرج من الأرض، فأمر بالخيل فأجريت حتى عرقت، فجمع العرق في شيء حتى صفا، وجعله في قداح الزجاج، فعجب الوفد مِن علمه، وجاء جبريل ﵇، فأخبره بما في الحُقَّة، فأخبرهم سليمان بما فيها، ثم رد سليمان الهدية، <span class="qpc-hafs">﴿فلما جاء سليمان﴾</span> قال للوفد: <span class="qpc-hafs">﴿أتمدونن بمال فما آتاني الله خير مما آتاكم﴾</span>{30}<span class=comment-ref>٤٨٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٨</span> ذكر <u>ابنُ كثير</u> (١٠/٤٠٦) ما جاء في هذا القول من أنّ بلقيس أرسلت إلى سليمان قدحًا ليملأه ماء، لا من الأرض ولا من السماء، فأجرى الخيل حتى عرقت، ثم جمع العرق ... إلخ، ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «والله أعلم أكان ذلك أم لا، وأكثره مأخوذ من الإسرائيليات».</div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: قولها: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية﴾</span>، قال: مائتي غلام، ومائتي جارية{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٧<span class="dash">-</span></span> قال ابن أبي عمر: سُئِل <span class="name-3">سفيان بن عيينة</span> -وأنا أسمع- عن الهدية التي بَعَثَتْ بها بلقيسُ إلى سليمان. قال: بعثت بغلمان ألبستهم لبسة الجواري، وجواري ألبستهم لبسة الغلمان{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٣٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله ﷿: <span class="qpc-hafs">﴿وإني مرسلة إليهم بهدية فناظرة بم يرجع المرسلون﴾</span>: أي: رسلي، إن قَبِل هديتنا فهو مِن الملوك، وليس مِن أهل النبوة كما يَنتَحِل{33}<span class=comment-ref>٤٨٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٦٩</span> اختُلف في الهدية التي بعثت بها بلقيس إلى سليمان على ما ورد في الآثار، وقد <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١٠/٤٠٦) على ذلك قائلًا: «أكثره مأخوذ من الاسرائيليات، والظاهر أن سليمان ﵇ لم ينظر إلى ما جاءوا به بالكلية، بل أعرض عنه، وقال منكرًا عليهم: <span class="qpc-hafs">﴿أتمدونن بمال﴾</span>».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٥٣٧): «فبعثت إليه بِهَدِيَّةٍ عظيمة، أكثر بعض الناس في تفصيلها، فرأيت اختصار ذلك لعدم صحته».</div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١١/٥٤٠، وابن أبي حاتم ٩/٢٨٧٩ بلفظ أطول، وسيأتي قريبًا بطوله. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ١٨/٥٣ مختصرًا، وابن أبي حاتم ٩/٢٨٨٠.|3:ذكره ابن كثير في تفسيره ٦/١٩٢ مسندًا عن الأعمش، عن المنهال بن عمرو، عن سعيد بن جبير.|4:تفسير البغوي ٦/١٦٠.|5:أخرجه ابن أبي حاتم ٩/٣٦٦. وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن أبي حاتم ٩/٢٨٧٨.|7:تفسير البغوي ٦/١٦٠.|8:أخرجه ابن جرير ١٨/٥٣، وابن أبي حاتم ٩/٢٨٧٧، وعند ابن جرير من طريق ابن جريج فيه: قالت: فإن خلَّص الجواري من الغلمان ورد الهدية فإنه نبي، وينبغي لنا أن نَتَّبِعَه، فخلَّص سليمان بعضهم من بعض، ولم يقبل هديتها. وعلَّقه يحيى بن سلام ٢/٥٤٣. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|9:تفسير الثعلبي ٧/٢٠٧، وتفسير البغوي ٦/١٦٠.|10:أخرجه ابن جرير ١٨/٥٥، وإسحاق البستي في تفسيره ص١٨.|11:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:أخرجه ابن أبي حاتم ٩/٢٨٧٨.|13:أخرجه إسحاق البستي في تفسيره ص١٩.|14:أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٦/٥٤٣ (٣٢٥١٩) مختصرًا، وابن جرير ١٨/٥٥، وإسحاق البستي في تفسيره ص١٧، وابن أبي حاتم ٩/٢٨٧٩.|15:المَقاوِلة: جمع الأقيال، وقد تقدم. تهذيب اللغة للأزهري (باب القاف واللام).|16:أخرجه ابن جرير ١٨/٥٤.|17:أخرجه ابن أبي حاتم ٩/٢٨٧٩.|18:أخرجه يحيى بن سلام ٢/٥٤٣، وابن أبي حاتم ٩/٢٨٧٧ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|19:أخرجه ابن أبي حاتم ٩/٢٨٧٨.|20:أخرجه ابن أبي حاتم ٩/٢٨٧٩.|21:أخرجه عبد الرزاق ٢/٨١، وابن جرير ١٨/٥٤، وابن أبي حاتم ٩/٢٨٧٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|22:دود يكون في الثمر، كما سيأتي في تفسير مقاتل.|23:أخرجه إسحاق البستي في تفسيره ص١٨ مختصرًا، وابن أبي حاتم ٩/٢٨٧٨، ٢٨٨٣ واللفظ له.|24:أخرجه ابن جرير ١٨/٥٥.|25:تفسير الثعلبي ٧/٢٠٧.|26:قُصَّة: خصلة من الشعر. النهاية (قصص).|27:ذؤابة: شعر مضفور. النهاية (ذأب).|28:حُقَّة: وعاء. ينظر: لسان العرب (قعب)؛ وقد فُسرت بها القعبة، وفسر القعب بالقدح الضخم.|29:في المصدر المطبوع - في الموضعين- بالضاد المعجمة: الفضفضة، وهو تصحيف. والصحيح بالصاد المهملة. وفي اللسان ٥/٣٥٢٤: الفِصْفِصةُ وهي الرَّطْبةُ من عَلَف الدَّواب.|30:تفسير مقاتل بن سليمان ٣/٣٠٤-٣٠٦. وجاء في تفسير الثعلبي ٧/٢٠٧ بلفظ: مائة وصيف، ومائة وصيفة. وفي تفسير البغوي ٦/١٦٠: مائتي غلام، ومائتي جارية. منسوبًا إلى مقاتل دون تعيينه.|31:أخرجه ابن جرير ١٨/٥٣. وذكره الثعلبي ٧/٢٠٧، والبغوي ٦/١٦٠ من قول مجاهد كما سبق.|32:أخرجه إسحاق البستي في تفسيره ص١٨-١٩.|33:تفسير يحيى بن سلام ٢/٥٤٣.