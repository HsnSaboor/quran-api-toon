quran[5]{c,v,t}:
  42,11,"<div class=ar lang=ar><p>فاطر:</p><p>1- بالرفع، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بالجر، صفة لقوله «إلى الله» الآية: 10، وهى قراءة زيد بن على.</p></div>"
  42,12,"<div class=ar lang=ar></div>"
  42,13,"42:12"
  42,14,"<div class=ar lang=ar><p>أورثوا:</p><p>وقرئ:</p><p>ورثوا، مبنيا للمفعول، مشدد الراء، وهى قراءة زيد بن على.</p></div>"
  42,15,"<div class=ar lang=ar></div>"