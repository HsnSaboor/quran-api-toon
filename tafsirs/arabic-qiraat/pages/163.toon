quran[9]{c,v,t}:
  7,96,"<div class=ar lang=ar><p>لفتحنا:</p><p>وقرئ:</p><p>لفتحنا، بتشديد التاء، وهى قراءة ابن عامر، وعيسى الثقفي، وأبى عبد الرحمن.</p></div>"
  7,97,""
  7,98,"<div class=ar lang=ar><p>أو أمن:</p><p>وقرئ:</p><p>أو أمن، بسكون الواو، وجعل «أو» عاطفة، وهى قراءة نافع، والابنين.</p></div>"
