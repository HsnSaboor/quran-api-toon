quran[5]{c,v,t}:
  4,171,"<div class=ar lang=ar><p>المسيح:</p><p>وقرئ:</p><p>على وزن السكيت، وهى قراءة جعفر بن محمد أن يكون:</p><p>وقرئ:</p><p>بكسر الهمزة وضم النون من «يكون» ، على أن «أن» ناقصة، أي: ما يكون له ولد، وهى قراءة الحسن.</p></div>"
  4,172,"<div class=ar lang=ar><p>عبد الله:</p><p>وقرئ:</p><p>عبيد الله، على التصغير.</p><p>فسيحشرهم:</p><p>وقرئ:</p><p>فسنحشرهم، بالنون، وهى قراءة الحسن.</p></div>"
  4,173,"<div class=ar lang=ar></div>"
  4,174,"4:173"
  4,175,"4:173"