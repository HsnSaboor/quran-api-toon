quran[7]{c,v,t}:
  11,6,""
  11,7,"<div class=ar lang=ar><p>إنكم:</p><p>وقرئ:</p><p>أنكم، بفتح الهمزة.</p><p>سحر:</p><p>وقرئ:</p><p>ساحر، وهى قراءة فرقة.</p></div>"
  11,8,""
  11,9,""
  11,10,"<div class=ar lang=ar><p>لفرح:</p><p>1- بكسر الراء، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بضم الراء، وهى قراءة فرقة.</p></div>"
  11,11,""
  11,12,""