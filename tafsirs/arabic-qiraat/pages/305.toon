quran[11]{c,v,t}:
  19,1,"<div class=ar lang=ar><p>كهيعص:</p><p>قرئ:</p><p>1- بكسر الهاء والياء، وهى قراءة على، ويحيى.</p><p>2- بين الفتح والكسر، وإلى الفتح أقرب، وهى قراءة نافع.</p><p>3- بكسر الهاء وفتح الياء، وهى قراءة أبى عمرو.</p><p>4- بفتح الهاء وكسر الياء، وهى قراءة حمزة.</p><p>5- بضمهما، وهى قراءة الحسن.</p><p>6- بفتحهما، وهى قراءة غيرهم.</p></div>"
  19,2,""
  19,3,"19:2"
  19,4,"19:2"
  19,5,"<div class=ar lang=ar><p>من ورائي:</p><p>وقرئ:</p><p>من وراى، بالقصر، وهى قراءة ابن كثير.</p></div>"
  19,6,""
  19,7,"19:6"
  19,8,"<div class=ar lang=ar><p>عتيا:</p><p>قرئ:</p><p>1- بكسر العين، وهى قراءة ابن وثاب، وحمزة، والكسائي.</p><p>2- بفتحها، وهى قراءة ابن مسعود.</p><p>3- عسيا، وهى قراءة أبى، ومجاهد.</p></div>"
  19,9,"<div class=ar lang=ar><p>خلقتك:</p><p>وقرئ:</p><p>خلقناك، وهى قراءة الأعمش، والكسائي، وابن وثاب.</p></div>"
  19,10,""
  19,11,"19:10"