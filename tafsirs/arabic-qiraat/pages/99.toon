quran[7]{c,v,t}:
  4,128,"<div class=ar lang=ar><p>الشح:</p><p>وقرئ:</p><p>الشح، بكسر الشين، وهى لغة، وهى قراءة العدوى.</p></div>"
  4,129,"<div class=ar lang=ar><p>فتذروها كالمعلقة:</p><p>وقرئ:</p><p>1- فتذروها كالمسجونة، وهى قراءة أبى.</p><p>2- فتذروها كأنها معلقة، وهى قراءة عبد الله.</p></div>"
  4,130,"<div class=ar lang=ar></div>"
  4,131,"4:130"
