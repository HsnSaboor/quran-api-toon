quran[7]{c,v,t}:
  60,12,"<div class=ar lang=ar></div>"
  60,13,"<div class=ar lang=ar><p>الكفار:</p><p>1- على الجمع، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- الكافر، على الإفراد.</p></div>"
  61,1,"<div class=ar lang=ar></div>"
  61,2,"61:1"
  61,3,"61:1"
  61,4,"<div class=ar lang=ar><p>يقاتلون:</p><p>وقرئ:</p><p>بفتح التاء، على البناء للمفعول، وهى قراءة زيد بن على.</p></div>"
  61,5,"<div class=ar lang=ar></div>"