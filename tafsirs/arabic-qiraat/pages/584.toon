quran[31]{c,v,t}:
  79,16,""
  79,17,""
79,18," تزكى: وقرئ: 1- بشد الزاى، وهى قراءة الحرميين، وأبى عمرو، بخلاف. 2- بخفها، وهى قراءة باقى السبعة. "
79,19," "
  79,20,""
  79,21,""
  79,22,""
  79,23,""
  79,24,""
  79,25,""
  79,26,""
  79,27,""
  79,28,""
  79,29,""
79,30," والأرض: 1- بالنصب، وهى قراءة الجمهور. وقرئ: 2- برفعها، وهى قراءة الحسن، وأبى حيوة، وعمرو بن عبيد، وابن أبى عبلة، وأبى السمال. "
79,31," "
79,32," والجبال: 1- بالنصب، وهى قراءة الجمهور. وقرئ: 2- برفعها، وهى قراءة الحسن، وأبى حيوة، وعمرو بن عبيد، وابن أبى عبلة، وأبى السمال. "
