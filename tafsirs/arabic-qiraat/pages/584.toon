quran[31]{c,v,t}:
  79,16,""
  79,17,""
  79,18,"<div class=ar lang=ar><p>تزكى:</p><p>وقرئ:</p><p>1- بشد الزاى، وهى قراءة الحرميين، وأبى عمرو، بخلاف.</p><p>2- بخفها، وهى قراءة باقى السبعة.</p></div>"
  79,19,"<div class=ar lang=ar></div>"
  79,20,""
  79,21,""
  79,22,""
  79,23,""
  79,24,""
  79,25,""
  79,26,""
  79,27,""
  79,28,""
  79,29,""
  79,30,"<div class=ar lang=ar><p>والأرض:</p><p>1- بالنصب، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- برفعها، وهى قراءة الحسن، وأبى حيوة، وعمرو بن عبيد، وابن أبى عبلة، وأبى السمال.</p></div>"
  79,31,"<div class=ar lang=ar></div>"
  79,32,"<div class=ar lang=ar><p>والجبال:</p><p>1- بالنصب، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- برفعها، وهى قراءة الحسن، وأبى حيوة، وعمرو بن عبيد، وابن أبى عبلة، وأبى السمال.</p></div>"
  79,33,"<div class=ar lang=ar></div>"
  79,34,""
  79,35,""
  79,36,""
  79,37,""
  79,38,""
