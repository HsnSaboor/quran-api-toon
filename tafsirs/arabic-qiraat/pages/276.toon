quran[8]{c,v,t}:
  16,80,"<div class=ar lang=ar><p>ظعنكم:</p><p>وقرئ:</p><p>1- بفتح العين، وهى قراءة الحرميين، وأبى عمرو.</p><p>2- بسكونها، وهى قراءة باقى السبعة.</p></div>"
  16,81,"<div class=ar lang=ar><p>يتم:</p><p>وقرئ:</p><p>تتم، بتاء مفتوحة، و «نعمة» بالرفع، وهى قراءة ابن عباس.</p><p>تسلمون:</p><p>وقرئ:</p><p>تسلمون، بفتح التاء واللام، من السلامة، وهى قراءة ابن عباس.</p></div>"
  16,82,""
  16,83,"16:82"
