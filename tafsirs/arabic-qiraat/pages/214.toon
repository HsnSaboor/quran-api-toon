quran[11]{c,v,t}:
  10,43,""
  10,44,""
  10,45,""
  10,46,"<div class=ar lang=ar><p>ثم:</p><p>وقرئ:</p><p>بفتح الثاء أي: هنا لك، وهى قراءة ابن أبى عبلة.</p></div>"
  10,47,""
  10,48,""
  10,49,""
  10,50,""
  10,51,"<div class=ar lang=ar><p>أثم:</p><p>وقرئ:</p><p>بفتح الثاء، وهى قراءة طلحة بن مصرف.</p><p>الآن:</p><p>1- على الاستفهام بالمد، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بهمزة الاستفهام بغير مد، وهى قراءة طلحة، والأعرج.</p></div>"
  10,52,""
  10,53,"<div class=ar lang=ar><p>لحق:</p><p>وقرئ:</p><p>الحق، وهى قراءة الأعمش.</p></div>"