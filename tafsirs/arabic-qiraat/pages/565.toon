quran[27]{c,v,t}:
  68,16,"<div class=ar lang=ar></div>"
  68,17,"68:16"
  68,18,"68:16"
  68,19,"<div class=ar lang=ar><p>طائف:</p><p>قرئ:</p><p>طيف، وهى قراءة النخعي.</p></div>"
  68,20,"<div class=ar lang=ar></div>"
  68,21,"68:20"
