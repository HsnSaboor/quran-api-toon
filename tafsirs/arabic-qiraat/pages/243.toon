quran[6]{c,v,t}:
  12,64,"<div class=ar lang=ar><p>خير حافظا:</p><p>وقرئ:</p><p>1- خير حفظا.</p><p>2- خير حافظ، على الإضافة، وهى قراءة الأعمش.</p><p>3- خير الحافظين، وهى قراءة أبى هريرة.</p></div>"
  12,65,"<div class=ar lang=ar><p>ما نبغى:</p><p>وقرئ:</p><p>ما تبغى، بالتاء، على خطاب «يعقوب» ، وهى قراءة عبد الله، وأبى حيوة.</p><p>ونمير:</p><p>وقرئ:</p><p>بضم النون، وهى قراءة أبى عبد الرحمن السلمى.</p></div>"
  12,66,"<div class=ar lang=ar></div>"
  12,67,"12:66"
  12,68,"12:66"
  12,69,"12:66"