quran[25]{c,v,t}:
  26,112,"<div class=ar lang=ar></div>"
  26,113,"<div class=ar lang=ar><p>تشعرون:</p><p>1- بتاء الخطاب، وهى قراءة الجمهور.</p><p>وقرئ:</p><p>2- بياء الغيبة، وهى قراءة الأعرج، وأبى زرعة، وعيسى بن عمر الهمداني.</p></div>"
  26,114,"<div class=ar lang=ar></div>"
  26,115,"26:114"
  26,116,"26:114"
