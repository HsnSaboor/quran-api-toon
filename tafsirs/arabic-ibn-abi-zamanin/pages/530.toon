quran[22]{c,v,t}:
  54,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَبِّئْهُمْ أَنَّ الْمَاءَ قِسْمَةٌ بَيْنَهُمْ﴾</span> وَهَذَا بعد مَا جَاءَتْهُم النَّاقة <span class="qpc-hafs">﴿كل شرب محتضر﴾</span> تشرب النَّاقة المَاء يَوْمًا ويشربونه يَوْمًا.</p><p>قَالَ محمدٌ: معنى <span class="qpc-hafs">﴿مُحْتَضَرٌ﴾</span> يحضر القومُ الشِّرْبَ يَوْمًا، وتحضره النَّاقة يَوْمًا.</p></div>"
  54,29,"<div class=ar lang=ar></div>"
  54,30,"54:29"
  54,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا أَرْسَلْنَا عَلَيْهِمْ صَيْحَةً وَاحِدَةً﴾</span> والصيحة: الْعَذَاب <span class="qpc-hafs">﴿فَكَانُوا كَهَشِيمِ الْمُحْتَظِرِ﴾</span> وَهُوَ النَّبَات إِذا هاج فَذَرَتْهُ الرياحُ فَصَارَ حظائر، تَفْسِير من قَرَأَ (المحتظِر) بكسْر الظَّاء، وَمن قَرَأَهَا (المحتظَر) بِفَتْح الظَّاء فَالْمَعْنى جعل حظائر.</p><p>قَالَ مُحَمَّد: وَقيل: الهشيم: مَا يبس من الْوَرق وتكسر وتحطم، أَي: فَكَانُوا كالهشيم الَّذِي يجمعه صَاحب الحظيرة فِي تَفْسِير من قَرَأَهُ (المحتظر) بِكَسْر الظَّاء يَقُول: احتظر حَظِيرَة، وَمن قَرَأَ (المحتظر) بِفَتْح الظَّاء فَهُوَ اسْم للحظيرة.</p></div>"
  54,32,"<div class=ar lang=ar></div>"
  54,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذبت قوم لوط بِالنذرِ﴾</span> بالرسل يَعْنِي لوطا</p></div>"
  54,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا أرسلنَا عَلَيْهِم حاصبا﴾</span> يَعْنِي: الْحِجَارَةَ الَّتِي رُمِيَ بِهَا من كَانَ مِنْهُم خَارِجا من الْمَدِينَة وَأهل السّفر مِنْهُم، وَأصَاب مدينتهم الخسفُ <span class="qpc-hafs">﴿إِلا آلَ لُوطٍ﴾</span> يَعْنِي من آمن <span class="qpc-hafs">﴿نَّجَّيْنَاهُم﴾</span></p></div>"
  54,35,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿من شكر﴾</span> يَعْنِي: من آمن.</p><p>قَالَ محمدٌ: تَقول: أتيتُ فلَانا سَحَرًا أَي: سحرًا من الأسحار، وَإِذا أردْت سحر يَوْمك قلت: أَتَيْته بِسَحَرٍ، وأتيته سَحَرَ، ونصْبه على الظّرْف.</p><p><span class="qpc-hafs">﴿نِعْمَةً من عندنَا﴾</span> بِمَعْنى: نجيناهم بالإنعام عَلَيْهِم.</p></div>"
  54,36,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَلَقَد أَنْذرهُمْ بطشتنا﴾</span> أَي: عذابنا <span class="qpc-hafs">﴿فتماروا بِالنذرِ﴾</span> كذبُوا بِمَا قَالَ لَهُم لوطٌ</p></div>"
  54,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ رَاوَدُوهُ عَنْ ضَيْفِهِ فَطَمَسْنَا﴾</span> وَقد مضى تَفْسِير كَيفَ أهلكوا فِي سُورَة هود</p></div>"
  54,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ صَبَّحَهُمْ بُكْرَةً عَذَابٌ مُسْتَقِرٌّ﴾</span> استقرَّ بهم الْعَذَاب.</p><p>قَالَ محمدٌ: (بكرَة) هَا هُنَا نكرَة، وَإِذا أردْت بكرَة يَوْمك لم تَصْرِفْها وَكَذَلِكَ (غدْوَة) فِي مثل هَذَا.</p></div>"
  54,39,"<div class=ar lang=ar></div>"
  54,40,"54:39"
  54,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ جَاءَ آلَ فِرْعَوْنَ النُّذُرُ﴾</span> يَعْنِي مُوسَى وَهَارُون</p></div>"
  54,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذبُوا بِآيَاتِنَا كلهَا﴾</span> يَعْنِي التسع آيَات، وَقد مضى ذِكْرُها <span class="qpc-hafs">﴿فَأَخَذْنَاهُمْ أَخْذَ عَزِيزٍ مُقْتَدِرٍ﴾</span> على خلقه، عذبهم بِالْغَرَقِ</p></div>"
  54,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أكفاركم﴾</span> يَعْنِي أهل مَكَّة <span class="qpc-hafs">﴿خَيْرٌ مِنْ أولئكم﴾</span> يَعْنِي: مِنْ أُهْلِكَ مِنَ الْأُمَمِ السالفة، أَي: لَيْسُوا بِخَير مِنْهُم، يَعْنِي: كَانُوا أَشد مِنْهُم قُوَّة وَأكْثر أَمْوَالًا وأولادًا <span class="qpc-hafs">﴿أَمْ لَكُمْ بَرَاءَة﴾</span> أَي: من الْعَذَاب <span class="qpc-hafs">﴿فِي الزُّبُرِ﴾</span> فِي الْكتب</p></div>"
  54,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحن جَمِيع منتصر أم يَقُولُونَ﴾</span> بل يَقُولُونَ</p></div>"
  54,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيهْزمُ الْجمع وَيُوَلُّونَ الدبر﴾</span> يَعْنِي: يَوْم بدر</p></div>"
  54,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل السَّاعَة موعدهم﴾</span> أَي: بِعَذَاب الاستئصال، يَعْنِي: كفار آخر هَذِه الْأمة؛ فِي تَفْسِير الْحسن <span class="qpc-hafs">﴿والساعة أدهى﴾</span> من تِلْكَ الأخذات الَّتِي أهلك بهَا الْأُمَم السالفة <span class="qpc-hafs">﴿وَأمر﴾</span> أَي: وَأَشد.</p></div>"
  54,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن الْمُجْرمين﴾</span> الْمُشْركين <span class="qpc-hafs">﴿فِي ضلال﴾</span> عَن الْهدى <span class="qpc-hafs">﴿وسعر﴾</span> أَي: شقاء فِي تَفْسِير مُجَاهِد</p></div>"
  54,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ يُسْحَبُونَ فِي النَّارِ عَلَى وُجُوههم﴾</span> تسحبهم الْمَلَائِكَة أَي: تجرهم <span class="qpc-hafs">﴿ذُوقُوا مس﴾</span> يُقَال لَهُم فِي النَّار: ذوقوا مسَّ سَقر، وسقر اسمٌ من أَسمَاء جَهَنَّم.</p></div>"
  54,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا كُلَّ شَيْءٍ خَلَقْنَاهُ بِقَدَرٍ﴾</span> تَفْسِير سعيد بْن جُبَير عَن عَليّ قَالَ: كل شَيْء بِقدر حَتَّى هَذِه، وَوضع إصبعه السبابَة على طرف لِسَانه، ثمَّ وَضعهَا على ظهر إبهامه الْيُسْرَى.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿كُلُّ شَيْءٍ﴾</span> منصوبٌ بِفعل مُضْمر، الْمَعْنى: إِنَّا خلقنَا كلَّ شيءٍ خلقناه بِقدر.</p></div>"