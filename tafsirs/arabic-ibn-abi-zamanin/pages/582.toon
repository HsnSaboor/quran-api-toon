quran[30]{c,v,t}:
  78,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ عَمَّ يَتَسَاءَلُونَ وَهِيَ مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيم تَفْسِير سُورَة النبأ من آيَة (١ - ١٦)</p><p>قَوْله: <span class="qpc-hafs">﴿عَم يتساءلون﴾</span> يَعْنِي: الْمُشْرِكِينَ؛ أَيْ: مَا الَّذِي يتساءلون عَنهُ.</p></div>"
  78,2,"<div class=ar lang=ar><p>ثُمَّ قَالَ: <span class="qpc-hafs">﴿عَنِ النَّبَإِ الْعَظِيمِ الَّذِي هم فِيهِ مُخْتَلفُونَ﴾</span> يَعْنِي: الْبَعْثَ، اخْتَلَفَ فِيهِ الْمُشْرِكُونَ وَالْمُؤْمِنُونَ؛ فَآمَنَ بِهِ الْمُؤْمِنُونَ، وَكَفَرَ بِهِ الْمُشْركُونَ</p></div>"
  78,3,"<div class=ar lang=ar></div>"
  78,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا سَيَعْلَمُونَ ثُمَّ كَلَّا سَيَعْلَمُونَ﴾</span> وَعِيد بعد وَعِيد</p></div>"
  78,5,"<div class=ar lang=ar></div>"
  78,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألم نجْعَل الأَرْض مهادا﴾</span> بساطًا</p></div>"
  78,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْجِبَال أوتادا﴾</span> للْأَرْض</p></div>"
  78,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وخلقناكم أَزْوَاجًا﴾</span> ذكرا وَأُنْثَى</p></div>"
  78,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلنَا نومكم سباتا﴾</span> يَعْنِي: نُعَاسًا.</p><p>قَالَ مُحَمَّدٌ: أصلُ السَّبتِ: انْقِطَاعُ الْحَرَكَةِ؛ يُقَالُ: رجلٌ سبُوتٌ وَقد سُبت.</p></div>"
  78,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلنَا اللَّيْل لباسا﴾</span> سِتْرًا يُغَطِّي الْخَلْقَ فَيَسْكُنُونَ فِيهِ</p></div>"
  78,11,"<div class=ar lang=ar><p>(وَجَعَلنَا النَّهَار معاشًا} يجلبون فِيهِ مَعَايشهمْ</p></div>"
  78,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وبنينا فَوْقكُم سبعا شدادًا﴾</span> {السَّمَاوَات</p></div>"
  78,13,"<div class=ar lang=ar><p>٢ - ! (وَجَعَلنَا سِرَاجًا وهاجًا) <span class="qpc-hafs">﴿ل ٣٨٤﴾</span> فِي تَفْسِيرِ الْكَلْبِيِّ؛ يَعْنِي: الشَّمْسَ</p></div>"
  78,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأنزلنا من المعصرات﴾</span> الرِّيَاحِ فِي تَفْسِيرِ مُجَاهِدٍ، وَبَعْضُهُمْ يَقُول: السَّحَاب <span class="qpc-hafs">﴿مَاء ثجاجًا﴾</span> منصَبٌّ ابعضه على بعض</p></div>"
  78,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لنخرج بِهِ حبًّا﴾</span> البُرَّ وَالشعِير. <span class="qpc-hafs">﴿ونباتًا﴾</span> من كل شَيْء</p></div>"
  78,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وجنات ألفافًا﴾</span>.</p><p>قَالَ مُحَمَّدٌ: يَعْنِي: بَسَاتِينَ مُلْتَفَّةٌ، وَمِنْ كَلامِهِمْ: امرأةٌ لَفَّاءُ إِذَا كَانَت عَظِيمَة الفخذين.</p></div>"
  78,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَوْم الْفَصْل﴾</span> الْقَضَاء <span class="qpc-hafs">﴿كَانَ ميقاتًا﴾</span> يوافونه كلهم</p></div>"
  78,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم ينْفخ فِي الصُّور﴾</span>.</p><p>قَالَ مُحَمَّد: (يَوْم ينْفخ) بدلٌ من (يَوْم الْفَصْل).</p><p><span class="qpc-hafs">﴿فَتَأْتُونَ أَفْوَاجًا﴾</span> أمة أمة</p></div>"
  78,19,"<div class=ar lang=ar></div>"
  78,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وسيرت الْجبَال فَكَانَت سَرَابًا﴾</span> مِثْلُ هَذَا السَّرَابِ تَرَاهُ، لَيْسَ بِشَيْء</p></div>"
  78,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن جَهَنَّم كَانَت مرصادًا﴾</span> أَيْ: تَرْصُدُ مَنْ حَقَّ عَلَيْهِ الْعَذَابُ، وَالصِّرَاطُ عَلَيْهَا، فَمَنْ كَانَ مِنْ أَهْلِهَا هَوَى فِيهَا، وَمَنْ لَمْ يَكُنْ مِنْ أَهْلِهَا حَادَ عَنْهَا إِلَى الْجنَّة</p></div>"
  78,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿للطاغين﴾</span> الْمُشْركين <span class="qpc-hafs">﴿مآبا﴾</span> مرجعًا.</p></div>"
  78,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لابثين فِيهَا أحقابا﴾</span> أَيْ: تَأْتِي عَلَيْهِمُ الأحقابُ لَا تَنْقَطِعُ أَبَدًا والحُقْبُ: ثَمَانُونَ عَامًا، والسَّنة: ثَلَاثمِائَة وَسِتُّونَ يَوْمًا، كُلُّ يَوْمٍ أَلْفُ يَوْم من أَيَّام الدُّنْيَا</p></div>"
  78,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يذوقون فِيهَا بردا﴾</span> هِيَ مِثْلُ قَوْلِهِ: <span class="qpc-hafs">﴿لَا بَارِدٍ وَلَا كريم﴾</span> وَقَالَ بَعْضُهُمْ: الْبَرْدُ النَّوْمُ.</p><p>قَالَ مُحَمَّدٌ: سُمِّيَ بِذَلِكَ؛ لِأَنَّهُ يَبْرُدُ فِيهِ عَطَشُ الْإِنْسَانِ.</p><p><span class="qpc-hafs">﴿وَلا شَرَابًا﴾</span></p></div>"
  78,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا حميما وغساقا﴾</span> الْحَمِيمُ: الَّذِي لَا يُسْتَطَاعُ مِنْ حَرِّهِ، والغسَّاق: القيحُ الْغَلِيظُ المنتنُ، وَبَعْضُهُمْ يَقُولُ: الْغَسَّاقُ الَّذِي لَا يُسْتَطَاعُ مِنْ شِدَّةِ بَرْدِهِ، وَهُو الزَّمْهَرِير.</p></div>"
  78,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَزَاء وفَاقا﴾</span> أَيْ: وَافَقَ أَعْمَالَهُمُ الْخَبِيثَةَ.</p><p>قَالَ مُحَمَّد: (وفَاقا) من: وَافقه مُوَافقَة.</p></div>"
  78,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهُم كَانُوا لَا يرجون﴾</span> لَا يخَافُونَ <span class="qpc-hafs">﴿حسابا﴾</span> لَا يقرونَ بِالْبَعْثِ</p></div>"
  78,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وكذبوا بِآيَاتِنَا كذابا﴾</span> تَكْذِيبًا</p></div>"
  78,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وكل شَيْء أحصييناه كتابا﴾</span> أحصتِ الْمَلائِكَةُ عَلَى الْعِبَادِ أَعْمَالَهُمْ، وَهِيَ عِنْدَ اللَّهِ مُحْصَاةٌ فِي أُمِّ الْكِتَابِ.</p><p>قَالَ مُحَمَّدٌ: (كُلَّ) مَنْصُوبٌ بِمَعْنَى: وَأَحْصَيْنَا كُلَّ شَيْءٍ أحصيناه، و (كتابا) تَوْكِيدًا لِأَحْصَيْنَاهُ، الْمَعْنَى: كَتَبْنَاهُ كِتَابًا.</p></div>"
  78,30,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿فَذُوقُوا فَلَنْ نَزِيدَكُمْ إِلا عذَابا﴾</span> قَالَ عبد الله بْن عَمرو: «مَا نَزَلَ عَلَى أَهْلِ النَّارِ آيَةٌ هِيَ أشدُّ مِنْهَا، فَهُمْ فِي زِيَادَةٍ من الْعَذَاب أبدا» تَفْسِير سُورَة النبأ من آيَة (٣١ - ٤٠)</p></div>"