quran[18]{c,v,t}:
  98,8,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿رَضِيَ اللَّهُ عَنْهُمْ وَرَضُوا عَنهُ﴾</span> أَيْ: وَرَضُوا ثَوَابَهُ <span class="qpc-hafs">﴿ذَلِكَ لِمَنْ خشِي ربه﴾</span>.</p></div>"
  99,1,"<div class=ar lang=ar><p>تَفْسِيرُ إِذَا زُلْزِلَتِ وَهِيَ مَدَنِيَّةٌ كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿إِذَا زُلْزِلَتِ الأَرْضُ زِلْزَالَهَا﴾</span> يَعْنِي: تَحَرَّكَتْ مِنْ نَواحِيهَا كُلِّهَا؛ وَذَلِكَ يَوْم الْقِيَامَة</p></div>"
  99,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأخرجت الأَرْض أثقالها﴾</span> أَلْقَتْ مَا فِيهَا مِنَ الْأَمْوَاتِ</p></div>"
  99,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالَ الْإِنْسَان﴾</span> الْمُشرك: <span class="qpc-hafs">﴿مَا لَهَا﴾</span> تحركت؟!</p></div>"
  99,4,"<div class=ar lang=ar><p>قَالَ اللَّهُ: <span class="qpc-hafs">﴿يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا﴾</span> بِمَا أَلْقَتْ مِمَّا كَانَ فِي بَطنهَا من الْأَمْوَات</p></div>"
  99,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَن رَبك أوحى لَهَا﴾</span> أَيْ: أَمَرَهَا - فِي تَفْسِيرِ مُجَاهِدٍ - أَنْ تُلْقِيَ مَا فِي بَطْنِهَا.</p></div>"
  99,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمئِذٍ يصدر النَّاس أشتاتا﴾</span> من بَين يَدي الله؛ أَي: مُخْتَلِفِينَ بَعْضُهُمْ إِلَى الْجَنَّةِ وَبَعْضُهُمْ إِلَى النَّار <span class="qpc-hafs">﴿ليروا أَعْمَالهم﴾</span></p></div>"
  99,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يره﴾</span> وزن ذرة</p></div>"
  99,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يره﴾</span> فِي عَمَلِ الآخِرَةِ.</p></div>"
  100,1,"<div class=ar lang=ar><p>تَفْسِيرُ الْعَادِيَاتِ وَهِيَ مَكِّيَّةٌ كُلُّهَا وَقِيلَ: إِنَّهَا مَدَنِيَّةٌ</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿وَالْعَادِيات ضَبْحًا﴾</span> تَفْسِيرُ ابْنُ عَبَّاسٍ: هِيَ الْخَيْلُ، وضبحها: أنفاسها إِذا جرت</p></div>"
  100,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فالموريات قدحا﴾</span> تُصِيبُ الْحِجَارَةَ بِحَوَافِرِهَا فَتَخْرُجُ مِنْهَا النَّارُ.</p><p>قَالَ مُحَمَّدٌ: وَقَدْ قِيلَ: إِنَّ ضَبْحَهَا صَوْتُ أَجْوَافِهَا إِذَا عدت.</p></div>"
  100,3,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿فالمغيرات صبحا﴾</span> قَالَ الْحَسَنُ: هِيَ الْخَيْلُ تُغِيرُ عَلَى الْعَدُوِّ إِذَا أَصْبَحَتْ.</p><p>قَالَ أَنَسُ بْنُ مَالِكٍ: ((إِنَّ قَوْمًا كَانَ بَينهم وَبَين النَّبي ﷺ عَهْدٌ فَنَقَضُوهُ - وَهُمْ أَهْلُ فَدَكٍ - فَبَعَثَ إِلَيْهِمْ رَسُولُ اللَّهِ خَيْلَهُ فَصَبَّحُوهُمْ، وَهُمُ الَّذِينَ أَنْزَلَ اللَّهُ فِيهِمْ: <span class="qpc-hafs">﴿وَالْعَادِيَاتِ ضَبْحًا﴾</span>.</p></div>"
  100,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فأثرن بِهِ نقعا﴾</span> تُثِيرُ التُّرَابَ بِحَوَافِرِهَا؛ فِي تَفْسِيرِ الْحسن.</p><p>قَالَ مُحَمَّد: النَّقْع: حَقِيقَة فِي اللُّغَةِ الْغُبَارُ. وَقَالَ: (بِهِ) وَلَمْ يَتَقَدَّمْ ذِكْرُ الْمَكَانِ؛ إِذْ فِي الْكَلَام دَلِيل عَلَيْهِ.</p></div>"
  100,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فوسطن بِهِ جمعا﴾</span> أَيْ: جَمْعًا مِنَ النَّاسِ أَغَارَتْ عَلَيْهِ؛ يَعْنِي: مِنَ الْعَدُوِّ.</p><p>قَالَ مُحَمَّد: معنى (وسطن): تَوَسَّطْنَ.</p><p>قَالَ يَحْيَى: وَهَذَا كُلُّهُ قسم</p></div>"
  100,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن الْإِنْسَان لرَبه لكنود﴾</span> وَهُوَ الْكَفُورُ فِي تَفْسِيرِ الْعَامَّةِ</p></div>"
  100,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّهُ على ذَلِك لشهيد﴾</span> يَعْنِي: عَلَى كُفْرِهِ يَوْمَ الْقِيَامَةِ</p></div>"
  100,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّهُ لحب الْخَيْر﴾</span> المَال <span class="qpc-hafs">﴿لشديد﴾</span> لبخيل</p></div>"
  100,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَلا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُور﴾</span> أُخْرِجَ مَا فِيهَا مِنَ الْأَمْوَاتِ</p></div>"