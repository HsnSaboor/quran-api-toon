quran[29]{c,v,t}:
  91,1,"<div class=ar lang=ar><p>تَفْسِيرُ وَالشَّمْسِ وَضُحَاهَا وَهِيَ مَكِّيَّةٌ كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</p><p>قَوْله: <span class="qpc-hafs">﴿وَالشَّمْس وَضُحَاهَا﴾</span> أَي: وضوئها</p></div>"
  91,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْقَمَر إِذا تَلَاهَا﴾</span> إِذا تبعها لَيْلَة الْهلَال</p></div>"
  91,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالنَّهَار إِذا جلاها﴾</span> يَعْنِي " ظلمَة اللَّيْل فأذهبها</p></div>"
  91,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاللَّيْل إِذا يَغْشَاهَا﴾</span> إِذا غشي الشَّمْس فأذهبها</p></div>"
  91,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالسَّمَاء وَمَا بناها﴾</span> أَيْ: وَالَّذِي بَنَاهَا، أَقْسَمَ بِالسَّمَاءِ وبنفسه</p></div>"
  91,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْأَرْض وَمَا طحاها﴾</span> أَيْ: وَالَّذِي بَسَطَهَا، يَعْنِي: نَفْسَهُ</p></div>"
  91,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَفس وَمَا سواهَا﴾</span> أَيْ: وَالَّذِي سَوَّاهَا، يَعْنِي: نَفْسَهُ</p></div>"
  91,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فألهمها فجورها وتقواها﴾</span> بَيَّنَ اللَّهُ لَهَا الْفُجُورَ وَالتَّقْوَى</p></div>"
  91,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قد أَفْلح من زكاها﴾</span> يَعْنِي: مَنْ زَكَّى اللَّهُ نَفْسَهُ فهداها</p></div>"
  91,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقد خَابَ من دساها﴾</span> أَيْ: مَنْ دَسَّى اللَّهُ نَفْسَهُ، أَيْ: أَشْقَاهَا.</p><p>قَالَ مُحَمَّدٌ: <span class="qpc-hafs">﴿دَسَّاهَا﴾</span> أَصْلُ الْكَلِمَةِ (دَسَّسَهَا) فَقُلِبَتِ السِّينُ الْوَاحِدَةُ يَاءً، الْمَعْنَى: جَعَلَهَا قَلِيلَةً خَسِيسَةً.</p><p>قَالَ يَحْيَى: هَذَا كُلُّهُ قَسَمٌ مِنْ أَوَّلِ السُّورَةِ إِلَى هَذَا الْموضع.</p></div>"
  91,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذبت ثَمُود بطغواها﴾</span> أَيْ: بِطُغْيَانِهَا؛ وَعَلَى هَذَا وَقَعَ الْقسم</p></div>"
  91,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ انْبَعَثَ أشقاها﴾</span> وَهُوَ أَحْمَرُ ثَمُودَ الَّذِي عَقَرَ النَّاقَةَ، وَقَدْ مَضَى تَفْسِيرُهَا فِي سُورَة هود</p></div>"
  91,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَالَ لَهُم رَسُول الله﴾</span> صَالِحٌ عَلَيْهِ السَّلامُ: <span class="qpc-hafs">﴿نَاقَةَ اللَّهِ وسقياها﴾</span> أَيْ: اتَّقُوا نَاقَةَ اللَّهِ لَا تمسوها بِسوء وَاتَّقوا (سقياها) شربهَا لَا تمنعوها مِنْهُ</p></div>"
  91,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُمْ﴾</span> أهلكهم <span class="qpc-hafs">﴿فسواها﴾</span> بالعقوبة</p></div>"
  91,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يخَاف عقباها﴾</span> أَيْ: لَا يَخَافُ اللَّهُ أَنْ يُتَّبَعَ بِذَلِكَ</p></div>"
  92,1,"<div class=ar lang=ar><p>تَفْسِيرُ وَاللَّيْلِ إِذَا يَغْشَى وَهِيَ مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿وَاللَّيْل إِذا يغشى﴾</span> إِذَا غَشِيَ النَّهَارَ، فَأَذْهَبَ ضَوْءَهُ</p></div>"
  92,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالنَّهَار إِذا تجلى﴾</span> ظهر</p></div>"
  92,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا خلق الذّكر﴾</span> أَيْ: وَالَّذِي خَلَقَ الذَّكَرَ وَالْأُنْثَى - يَعْنِي: نَفْسَهُ - وَهَذَا كُلُّهُ قَسَمٌ</p></div>"
  92,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن سعيكم لشتى﴾</span> يَعْنِي: سَعْيَ الْمُؤْمِنِ وَسَعْيَ الْكَافِرِ وَهُوَ عَمَلُهُمَا.</p><p><span class="qpc-hafs">﴿فَأَمَّا مَنْ أَعْطَى وَاتَّقَى﴾</span></p></div>"
  92,5,"<div class=ar lang=ar></div>"
  92,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصدق بِالْحُسْنَى﴾</span> بالثواب وَهُوَ الْجنَّة</p></div>"
  92,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فسنيسره لليسرى﴾</span> لعمل الْجنَّة.</p></div>"
  92,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأما من بخل﴾</span> بِمَا عِنْدَهُ أَنْ يَتَقَرَّبَ بِهِ إِلَى ربه <span class="qpc-hafs">﴿وَاسْتغْنى﴾</span> عَن ربه</p></div>"
  92,9,"<div class=ar lang=ar></div>"
  92,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فسنيسره للعسرى﴾</span> لعمل النَّار</p></div>"
  92,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تردى﴾</span> تَفْسِيرُ بَعْضِهِمْ: إِذَا تَرَدَّى فِي النَّار، وَقيل: تردى: مَاتَ.</p></div>"
  92,12,"<div class=ar lang=ar><p>(إِن علينا للهدى} أَيْ: نُبَيِّنُ لَكُمْ سَبِيلَ الْهُدَى وسبيل الضَّلَالَة.</p></div>"
  92,13,"<div class=ar lang=ar></div>"
  92,14,"92:13"