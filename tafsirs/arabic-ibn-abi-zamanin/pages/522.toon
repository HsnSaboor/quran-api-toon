quran[21]{c,v,t}:
  51,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ فَمَا خطبكم﴾</span> فَمَا أَمركُم؟!</p></div>"
  51,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا إِنَّا أُرْسِلْنَا إِلَى قَوْمٍ مجرمين﴾</span> مُشْرِكين؛ يعنون: قوم لوط</p></div>"
  51,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجَارَةً مِنْ طِينٍ﴾</span> قَالَ هَا هُنَا: <span class="qpc-hafs">﴿من طين﴾</span> وَقَالَ فِي آيَة أُخْرَى: <span class="qpc-hafs">﴿مِنْ سجيل﴾</span>.</p><p>قَالَ محمدٌ: تَفْسِير ابْن عَبَّاس <span class="qpc-hafs">﴿من سجيل﴾</span>: من آجُر}.</p></div>"
  51,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مسومة﴾</span> أَي: مُعْلَمَة أَنَّهَا من حِجَارَة الْعَذَاب، كَانَ فِي كل حجر مِنْهَا مثل الطابع.</p></div>"
  51,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فأخرجنا﴾</span> فأنجينا <span class="qpc-hafs">﴿من كَانَ فِيهَا﴾</span> فِي قَرْيَة لوطٍ <span class="qpc-hafs">﴿مِنَ الْمُؤْمِنِينَ﴾</span>.</p></div>"
  51,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا وَجَدْنَا فِيهَا غَيْرَ بَيْتٍ من الْمُسلمين﴾</span> يَعْنِي: أهل بَيت لوط فِي الْقَرَابَة، وَمن كَانَ مَعَه من الْمُؤمنِينَ.</p></div>"
  51,37,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿وَتَركنَا فِيهَا﴾</span> أَي: فِي إهلاكنا إِيَّاهَا <span class="qpc-hafs">﴿آيَةً للَّذين يخَافُونَ الْعَذَاب الْأَلِيم﴾</span> فيحذرون أَن ينزل بهم مَا نزل بهم</p></div>"
  51,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفِي مُوسَى﴾</span> أَي: وَتَركنَا فِي أمْر مُوسَى <span class="qpc-hafs">﴿إِذْ أَرْسَلْنَاهُ إِلَى فِرْعَوْنَ بِسُلْطَانٍ مُبين﴾</span> بَين</p></div>"
  51,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلّى بركنه﴾</span> قَالَ الكَلْبي: يَعْنِي: بجُنُوده <span class="qpc-hafs">﴿وَقَالَ سَاحر أَو مَجْنُون﴾</span> يَعْنِي: مُوسَى.</p><p>قَالَ محمدٌ: الْمَعْنى: هَذَا سَاحر أَو مَجْنُون.</p></div>"
  51,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فنبذناهم فِي اليم﴾</span> فِي الْبَحْر <span class="qpc-hafs">﴿وَهُوَ مليم﴾</span> مُذْنِبٌ، وذنبه: الشّرك.</p><p>قَالَ محمدٌ: يُقَال: ألامَ الرجُلُ إِذا أَتَى بذنب يلام عَلَيْهِ.</p></div>"
  51,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفِي عَاد﴾</span> أَي: وَتَركنَا فِي عادٍ أَيْضا آيَة، وَهِي مثل الأولى <span class="qpc-hafs">﴿إِذْ أرسلنَا عَلَيْهِم الرّيح الْعَقِيم﴾</span> الَّتِي لَا تدع سحابًا وَلَا شَجرا وَهِي الدبور</p></div>"
  51,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تَذَرُ مِن شَيْءٍ أَتَتْ عَلَيْهِ﴾</span> <span class="qpc-hafs">﴿ل ٢٣٩﴾</span> مِمَّا مرّت بِهِ، وَهُوَ الْإِنْسَان <span class="qpc-hafs">﴿إِلَّا جعلته كالرميم﴾</span> كرميم الشّجر.</p></div>"
  51,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفِي ثَمُود﴾</span> وَهِي مثل الأولى <span class="qpc-hafs">﴿إِذْ قِيلَ لَهُم تمَتَّعُوا حَتَّى حِين﴾</span> إِلَى آجالكم بِغَيْر عَذَاب إِن آمنتم، وَإِن عصيتم عذبتم <span class="qpc-hafs">﴿فَعَتَوْا عَن أَمر رَبهم﴾</span> تركُوا أمره <span class="qpc-hafs">﴿فَأَخَذتهم الصاعقة﴾</span> الْعَذَاب <span class="qpc-hafs">﴿وهم ينظرُونَ﴾</span> إِلَى الْعَذَاب</p></div>"
  51,44,"<div class=ar lang=ar></div>"
  51,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا اسْتَطَاعُوا من قيام﴾</span> تَفْسِير السُّدي: فَمَا أطاقوا أَن يقومُوا للعذاب <span class="qpc-hafs">﴿وَمَا كَانُوا مُنْتَصِرِينَ﴾</span> ممتنعين.</p></div>"
  51,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقوم نوح﴾</span> الْآيَة.</p><p>قَالَ محمدٌ: من قَرَأَ <span class="qpc-hafs">﴿قوم نوح﴾</span> بِالنّصب فعلى معنى: فأخذناه وَجُنُوده، وأخذنا قوم نوح.</p></div>"
  51,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالسَّمَاء بنيناها بأيد﴾</span> بِقُوَّة.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿وَالسَّمَاء بنيناها﴾</span> الْمَعْنى: بنينَا السَّمَاء بنيناها.</p><p><span class="qpc-hafs">﴿وَإِنَّا لموسعون﴾</span> فِي الرزق</p></div>"
  51,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْأَرْض فرشناها﴾</span> أَي: وفرشناها كَقَوْلِه: <span class="qpc-hafs">﴿جَعَلَ لَكُمُ الأَرْض فراشا﴾</span> و <span class="qpc-hafs">﴿بساطا﴾</span> و <span class="qpc-hafs">﴿مهادا﴾</span> <span class="qpc-hafs">﴿فَنعم الماهدون﴾</span>.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿وَالْأَرْض فرشناها﴾</span> أَي: وفرشنا الأَرْض فرشناها، قَوْله: <span class="qpc-hafs">﴿فَنعم الماهدون﴾</span> أَي: فَنعم الماهدون نَحن.</p></div>"
  51,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِن كُلِّ شَيْءٍ خَلَقْنَا زَوْجَيْنِ﴾</span> تَفْسِير الْكَلْبِيّ: هُوَ كَقَوْلِه <span class="qpc-hafs">﴿وَأَنَّهُ خلق الزَّوْجَيْنِ الذّكر وَالْأُنْثَى﴾</span> الذّكر زوجٌ، وَالْأُنْثَى زوجٌ <span class="qpc-hafs">﴿لَعَلَّكُمْ تذكرُونَ﴾</span> لكَي تذّكَّروا فتعلموا أَن الَّذِي خلق هَذِه الْأَشْيَاء واحدٌ صَمَدٌ، جعلهَا لكم آيَة فتعتبروا</p></div>"
  51,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَفرُّوا إِلَى الله﴾</span> إِلَى دين اللَّه، أَمر اللَّه النَّبي ﷺ أَن يَقُوله لَهُم:</p><p><span class="qpc-hafs">﴿إِنِّي لَكُمْ مِنْهُ نَذِيرٌ مُبِينٌ﴾</span>.</p></div>"
  51,51,"<div class=ar lang=ar></div>"