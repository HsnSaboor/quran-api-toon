quran[28]{c,v,t}:
  69,35,"<div class=ar lang=ar><p>قَالَ اللَّهُ: <span class="qpc-hafs">﴿فَلَيْسَ لَهُ الْيَوْمَ هَا هُنَا حميم﴾</span> أَي: شفيقُ يَنْفَعهُ</p></div>"
  69,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا طَعَامٌ إِلا مِنْ غِسْلِينٍ﴾</span> يَعْنِي: غُسَالَةُ أَهْلِ النَّارِ: القيْح والدّمُ</p></div>"
  69,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَأْكُلهُ إِلَّا الخاطئون﴾</span> الْمُشْرِكُونَ.</p><p>قَالَ محمدٌ: الِاخْتِيَارُ أَنْ يُوقَفَ عَلَى الْهَاءَاتِ الَّتِي مَضَتْ فِي قَوْله <span class="qpc-hafs">﴿كِتَابيه﴾</span> <span class="qpc-hafs">﴿حسابيه﴾</span> و <span class="qpc-hafs">﴿ماليه﴾</span> و <span class="qpc-hafs">﴿سلطانيه﴾</span> وَتُوصَلُ، وَقَدْ حَذَفَهَا قومٌ فِي الوصْل؛ وَهُوَ خِلافُ الْمُصْحَفِ ذَكَرَهُ الزَّجَّاج.</p></div>"
  69,38,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَا تُبْصِرُونَ وَمَا لَا تبصرون﴾</span> أُقْسِمُ بِكُلِّ شَيْءٍ أَنَّ الْقُرْآنَ</p></div>"
  69,39,"<div class=ar lang=ar></div>"
  69,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لقَوْل رَسُول كريم﴾</span> على الله؛ يَعْنِي: مُحَمَّد ﷺ.</p></div>"
  69,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا هُوَ﴾</span> مَا الْقُرْآنُ <span class="qpc-hafs">﴿بِقَوْلِ شَاعِرٍ قَلِيلا مَا تؤمنون﴾</span> أقلكم من يُؤمن</p></div>"
  69,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا بِقَوْلِ كَاهِنٍ قَلِيلا مَا تذكرُونَ﴾</span> أَقَلُّكُمْ مَنْ يَتَذَكَّرُ أَيْ: يُؤْمِنُ</p></div>"
  69,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنْزِيل﴾</span> يَعْنِي: الْقُرْآنَ <span class="qpc-hafs">﴿مِنْ رَبِّ الْعَالَمِينَ﴾</span>.</p></div>"
  69,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَو تَقول علينا﴾</span> يَعْنِي: مُحَمَّدًا <span class="qpc-hafs">﴿بعض الْأَقَاوِيل﴾</span> فَزَادَ فِي الْوَحْيِ أَوْ نَقَصَ مِنْهُ</p></div>"
  69,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لأخذنا مِنْهُ بِالْيَمِينِ﴾</span> أَيْ: بِالْحَقِّ عُقُوبَةٌ، وَتَفْسِيرُ الْحَسَنِ: يَقُول: لقطعنا يَده الْيُمْنَى</p></div>"
  69,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثمَّ لقطعنا مِنْهُ الوتين﴾</span> وَهُوَ الْعِرْقُ الَّذِي الْقَلْبُ مُعَلَّقٌ بِهِ فَإِذَا انْقَطَعَ مَاتَ الْإِنْسَانُ</p></div>"
  69,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا مِنْكُمْ مِنْ أَحَدٍ عَنْهُ حاجزين﴾</span>.</p><p>قَالَ محمدٌ: (حاجزين) من نعت (أحد)، و (أحدٌ) فِي مَعْنَى جَمِيعٍ؛ الْمَعْنَى فَمَا مِنْكُم قوم يحجزون عَنهُ.</p></div>"
  69,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّهُ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿لتذكرة لِلْمُتقين﴾</span> هم الَّذين يقبلُونَ التَّذْكِرَة</p></div>"
  69,49,"<div class=ar lang=ar></div>"
  69,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّهُ﴾</span> يَعْنِي: الْقُرْآنَ <span class="qpc-hafs">﴿لَحَسْرَةٌ عَلَى الْكَافِرِينَ﴾</span> يَوْمَ الْقِيَامَةِ، إِذْ لَمْ يُؤْمِنُوا بِهِ فِي الدُّنْيَا</p></div>"
  69,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّهُ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿لحق الْيَقِين﴾</span> أَنه من عِنْد الله</p></div>"
  69,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فسبح باسم رَبك الْعَظِيم﴾</span>.</p><p>قَالَ مُحَمَّدٌ: التَّسْبِيحُ مَعْنَاهُ: تَنْزِيهُ اللَّهِ مِنَ السُّوءِ وَتَبْرِئَتُهُ تَبَارَكَ وَتَعَالَى.</p></div>"
  70,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ سَأَلَ سَائِلٌ وَهِيَ مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيم تَفْسِير سُورَة المعارج من آيه (١ - ٩)</p><p>قَوْله: <span class="qpc-hafs">﴿سَأَلَ سَائل﴾</span> الْعَامَّةُ يَهْمِزُونَهَا مِنْ بَابِ السُّؤَالِ، قَالَ الْحَسَنُ: إِنَّ الْمُشْرِكِينَ قَالُوا للنَّبِي ﷺ لِمَنْ هَذَا الْعَذَابُ الَّذِي تَذْكُرُ أَنَّهُ يَكُونُ فِي الْآخِرَةِ؟ فَقَالَ الله: <span class="qpc-hafs">﴿سَأَلَ سَائل بِعَذَاب﴾</span> أَيْ: عَنْ عَذَابٍ <span class="qpc-hafs">﴿وَاقِعٌ لِلْكَافِرِينَ﴾</span> وَكَانَ بَعْضُهُمْ يَقْرَؤُهَا: (سَالَ سَيْلٌ) بِغَيْرِ همزٍ مِنْ بَابِ السَّيْل، وَقَالَ هُوَ وَادٍ مِنْ نارٍ يسيل، <span class="qpc-hafs">﴿بِعَذَاب وَاقع﴾</span> للْكَافِرِينَ</p></div>"
  70,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيْسَ لَهُ دَافع﴾</span> يَدْفَعهُ</p></div>"
  70,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿من الله ذِي المعارج﴾</span> ذِي الْمَرَاقِي إِلَى السَّمَاءِ</p></div>"
  70,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَعْرُجُ الْمَلائِكَةُ وَالرُّوحُ إِلَيْهِ فِي يَوْم﴾</span> يَعْنِي: يَوْمَ الْقِيَامَةِ <span class="qpc-hafs">﴿كَانَ مِقْدَارُهُ خمسين ألف سنة﴾</span> يَقُولُ هَذَا كَانَ مِقْدَارُهُ [لَوْ وَلِيَ] غَيْرُ اللَّهِ حِسَابَ الْخَلائِقِ، وَاللَّهُ تَعَالَى يَفْرَغُ مِنْهُمْ فِي مِقْدَار (ل ٣٧٣) نِصْفِ يَوْمٍ مِنْ أَيَّامِ الدُّنْيَا وَهُوَ قَوْلُهُ: <span class="qpc-hafs">﴿وَهُوَ أَسْرَعُ الْحَاسِبِينَ﴾</span></p></div>"
  70,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاصبر صبرا جميلا﴾</span> لَيْسَ فِيهِ (جَزَعٌ) عَلَى تَكْذِيبِ الْمُشْركين لَك</p></div>"
  70,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهُم يرونه بَعيدا﴾</span> يَعْنِي: يَوْمَ الْقِيَامَةِ، يَقُولُونَ: لَيْسَ بكائنٍ</p></div>"
  70,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ونراه قَرِيبا﴾</span> جَائِيًا وَكُلُّ مَا هُوَ آتٍ قريب.</p></div>"
  70,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم تكون السَّمَاء﴾</span> أَيْ: ذَلِكَ يَوْمَ تَكُونُ السَّمَاءُ <span class="qpc-hafs">﴿كَالْمهْلِ﴾</span> كَعَكرِ الزَّيْت؛ فِي تَفْسِير زيد بن أسلم</p></div>"
  70,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَكون الْجبَال كالعهن﴾</span> كَالصُّوفِ الْأَحْمَرِ وَهُوَ أَضْعَفُ الصُّوفِ، وَهِي فِي حرف ابْن مَسْعُود (كالصوف الْأَحْمَر المنفوش)</p></div>"
  70,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يسْأَل حميم حميما﴾</span> تَفْسِيرُ الْحَسَنِ: لَا يَسْأَلُ قريبٌ قَرِيبَهُ أَنْ يَحْمِلَ عَنْهُ مِنْ ذُنُوبِهِ شَيْئًا؛ كَمَا كَانَ يَحْمِلُ بعضُهم فِي الدُّنْيَا عَنْ بَعْضٍ.</p><p>قَالَ محمدٌ: الْحَمِيمُ: الْقَرِيبُ، وَالْحَمِيمُ أَيْضا: المَاء الشَّديد الْحر.</p></div>"