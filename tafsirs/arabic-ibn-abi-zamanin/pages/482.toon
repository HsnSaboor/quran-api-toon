quran[8]{c,v,t}:
  41,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَيْهِ يُرَدُّ عِلْمُ السَّاعَةِ وَمَا تَخْرُجُ مِنْ ثَمَرَاتٍ مِنْ أَكْمَامِهَا﴾</span> تَفْسِير الْحسن هَذَا فِي النّخل خَاصَّة حِين (ل ٣٠٩) يطلع لَا يعلم أحدٌ كَيفَ يُخرجهُ الله <span class="qpc-hafs">﴿وَمَا تَحْمِلُ مِنْ أُنْثَى وَلا تَضَعُ إِلا بِعِلْمِهِ﴾</span> (يَقُول: لَا يعلم وَقت قيام السَّاعَة , وَمَا تَخْرُجُ مِنْ ثَمَرَاتٍ مِنْ أَكْمَامِهَا , وَمَا تَحْمِلُ مِنْ أُنْثَى وَلَا تضع؛ إِلَّا هُوَ لَا إِلَهَ إِلا هُوَ).</p><p>قَالَ مُحَمَّدٌ: الِاخْتِيَار فِي الْقِرَاءَة " وَمَا يخرج " بِالْيَاءِ؛ لِأَن مَا ذكر مُذَكّر , الْمَعْنى: وَالَّذِي يخرج.</p><p>قَوْله: <span class="qpc-hafs">﴿مِنْ أكمامها﴾</span> يَعْنِي: الْمَوَاضِع الَّتِي كَانَت فِيهِ مستترة , وغلاف كل شَيْء كُمُّه , وَمن هَذَا قيل: كم الْقَمِيص.</p><p><span class="qpc-hafs">﴿وَيَوْم يناديهم﴾</span> يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿أَيْنَ شُرَكَائِي الَّذين زعمتم﴾</span> أَنهم شركائي <span class="qpc-hafs">﴿قَالُوا آذَنَّاكَ﴾</span> سمعناك <span class="qpc-hafs">﴿مَا مِنَّا مِنْ شَهِيدٍ﴾</span> يشْهد الْيَوْم أَن مَعَك آلِهَة.</p></div>"
  41,48,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿وَضَلَّ عَنْهُمْ مَا كَانُوا يدعونَ من قبل﴾</span> فِي الدُّنْيَا؛ ضلت عَنْهُم أوثانهم الَّتِي كَانُوا يعْبدُونَ , فَلَنْ تَسْتَجِيب لَهُم.</p><p>قَالَ مُحَمَّد: (آذناك) حَقِيقَته فِي اللُّغَة: أعلمناك.</p><p><span class="qpc-hafs">﴿وَظَنُّوا﴾</span> علمُوا <span class="qpc-hafs">﴿مَا لَهُمْ مِنْ مَحِيصٍ﴾</span> من ملْجأ.</p></div>"
  41,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسْأَمُ الإِنْسَانُ مِنْ دُعَاءِ الْخَيْر﴾</span> أَي: لَا يملُّ <span class="qpc-hafs">﴿وَإِن مَّسَّهُ الشَّرُّ فَيَئُوسٌ قَنُوطٌ﴾</span> فالخير عِنْد الْمُشرك: الدُّنْيَا وَالصِّحَّة فِيهَا والرخاء <span class="qpc-hafs">﴿وَإِنْ مَسَّهُ الشَّرُّ﴾</span> فِي ذهَاب مالٍ، أَو مرضٍ لم تكن لَهُ حِسْبة , وَلم يرجُ ثَوابًا فِي الْآخِرَة , وَلَا أَن يرجع إِلَى مَا كَانَ فِيهِ من الرخَاء</p></div>"
  41,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَئِن أذقناه رَحْمَة﴾</span> يَعْنِي: رخاء وعافية <span class="qpc-hafs">﴿مِنْ بَعْدِ ضراء﴾</span> أَي: شدَّة <span class="qpc-hafs">﴿مسته﴾</span> فِي ذهَاب مالٍ , أَو مرضٍ <span class="qpc-hafs">﴿ليَقُولن هَذَا لي﴾</span> أَي: بعلمي , وَأَنا محقوق بِهَذَا! <span class="qpc-hafs">﴿وَمَا أَظن السَّاعَة قَائِمَة﴾</span> أَي: لَيست بقائمة <span class="qpc-hafs">﴿وَلَئِنْ رُجِعْتُ إِلَى رَبِّي﴾</span> كَمَا يَقُولُونَ <span class="qpc-hafs">﴿إِنَّ لِي عِنْدَهُ للحسنى﴾</span> للجنة؛ إِن كَانَت جنَّة.</p></div>"
  41,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذَا أَنْعَمْنَا عَلَى الإِنْسَانِ أَعْرَضَ ونأى بجانبه﴾</span> أَي: تبَاعد <span class="qpc-hafs">﴿وَإِذَا مَسَّهُ الشَّرُّ﴾</span> الضّر <span class="qpc-hafs">﴿فذو دُعَاء عريض﴾</span> أَي: كَبِير.</p></div>"
  41,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلْ أَرَأَيْتُمْ إِنْ كَانَ مِنْ عِنْد الله﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿ثُمَّ كَفَرْتُمْ بِهِ مَنْ أَضَلُّ مِمَّنْ هُوَ فِي شقَاق﴾</span> فِي فِرَاق للنَّبِي وَمَا جَاءَ بِهِ <span class="qpc-hafs">﴿بعيد﴾</span> من الْحق , أَي: لَا أحد أضلّ مِنْهُ.</p></div>"
  41,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنُرِيهِمْ آيَاتِنَا فِي الآفَاقِ وَفِي أنفسهم﴾</span> قَالَ الْحسن: يَعْنِي: مَا أهلك بِهِ الْأُمَم السالفة فِي الْبلدَانِ , فقد رَأَوْا آثَار ذَلِك <span class="qpc-hafs">﴿وَفِي أَنْفُسِهِمْ﴾</span> أخبر بِأَنَّهُم تصيبهم البلايا , فَكَانَ ذَلِك كَمَا قَالَ فأظهره الله عَلَيْهِم , وابتلاهم بِمَا ابْتَلَاهُم بِهِ.</p><p>قَالَ يحيى: يَعْنِي: من الْجُوع بِمَكَّة , وَالسيف يَوْم بدر.</p><p><span class="qpc-hafs">﴿حَتَّى يتَبَيَّن لَهُم أَنه الْحق﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿أَوَ لَمْ يَكْفِ بِرَبِّكَ أَنَّهُ عَلَى كُلِّ شَيْءٍ شَهِيدٌ﴾</span> أَي: شاهدٌ على كفرهم وأعمالهم , أَي: بلَى كفى بِهِ شَهِيدا عَلَيْهِم.</p><p>قَالَ مُحَمَّد: الْمَعْنى: أَو لم يكف [بِرَبِّك].</p></div>"
  41,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلا إِنَّهُم فِي مرية﴾</span> فِي شكٍّ <span class="qpc-hafs">﴿مِنْ لِقَاءِ رَبِّهِمْ﴾</span> يَقُولُونَ: لَا نبعث وَلَا نلقى الله <span class="qpc-hafs">﴿أَلاَ إِنَّهُ بِكُلِّ شَيْءٍ مُّحِيطٌ﴾</span> أحَاط علمه بِكُل شيءٍ.</p></div>"