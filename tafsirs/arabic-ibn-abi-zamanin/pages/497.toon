quran[21]{c,v,t}:
  44,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنْ لَا تَعْلُوا عَلَى اللَّهِ﴾</span> أَي: لَا تستكبروا عَن عبَادَة الله <span class="qpc-hafs">﴿إِنِّي آتيكم﴾</span> أَي: قد أتيتكم <span class="qpc-hafs">﴿بِسُلْطَانٍ مُبِينٍ﴾</span> بِحجَّة بَيِّنَة</p></div>"
  44,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنِّي عُذْتُ بِرَبِّي وَرَبِّكُمْ أَنْ ترجمون﴾</span> يَعْنِي: الْقَتْل بِالْحِجَارَةِ</p></div>"
  44,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن لم تؤمنوا لي﴾</span> تصدقوني <span class="qpc-hafs">﴿فاعتزلون﴾</span> حَتَّى يحكم الله بيني وَبَيْنكُم.</p><p>قَالَ محمدٌ: قيل: الْمَعْنى: فَإِن لم تؤمنوا لي؛ فَلَا تَكُونُوا عَليّ وَلَا معي.</p></div>"
  44,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَدَعَا رَبَّهُ أَنَّ هَؤُلاءِ قَوْمٌ مجرمون﴾</span> مشركون.</p><p>قَالَ مُحَمَّد: من قَرَأَ (إِن) بالكَسْرِ فعلى معنى: قَالَ: إِن هَؤُلَاءِ، وَيجوز الْفَتْح بِمَعْنى: بِأَن هَؤُلَاءِ.</p></div>"
  44,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَسْرِ بِعِبَادِي لَيْلا إِنَّكُمْ مُتَّبَعُونَ﴾</span> أَي: يتبعكم فِرْعَوْن وَجُنُوده</p></div>"
  44,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واترك الْبَحْر رهوا﴾</span> قَالَ مُجَاهِد: يَعْنِي: سَاكِنا بعد أَن ضربه مُوسَى بعصاه.</p></div>"
  44,25,"<div class=ar lang=ar></div>"
  44,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ومقام كريم﴾</span> أَي: منزل حسن</p></div>"
  44,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ونعمة كَانُوا فِيهَا فاكهين﴾</span> أَي: مسرورين.</p></div>"
  44,28,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿كَذَلِك﴾</span> أَي: هَكَذَا كَانَ الْخَبَر <span class="qpc-hafs">﴿وَأَوْرَثْنَاهَا قوما آخَرين﴾</span> يَعْنِي: بني إِسْرَائِيل</p></div>"
  44,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا بَكَتْ عَلَيْهِمُ السَّمَاءُ وَالأَرْضُ﴾</span>.</p><p>يَحْيَى: عَنْ حَمَّادٍ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: " لِلْمُؤْمِنِ بَابَانِ فِي السَّمَاءِ، أَحَدُهُمَا يَصْعَدُ مِنْهُ عَمَلُهُ، وَالآخَرُ يَنْزِلُ مِنْهُ رِزْقُهُ، فَإِذَا مَاتَ بَكَيَا عَلَيْهِ ".</p><p>قَالَ أبان الْعَطَّار: بَلغنِي أَنَّهُمَا يَبْكِيَانِ عَلَيْهِ أَرْبَعِينَ صباحا.</p><p><span class="qpc-hafs">﴿وَمَا كَانُوا منظرين﴾</span> من الْعَذَاب يَعْنِي: الْغَرق.</p><p>(ل ٣٢٠) <span class="qpc-hafs">﴿وَلَقَدْ نَجَّيْنَا بَنِي إِسْرَائِيلَ مِنَ الْعَذَاب المهين﴾</span></p></div>"
  44,30,"<div class=ar lang=ar></div>"
  44,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنْ فِرْعَوْنَ إِنَّهُ كَانَ عَالِيًا من المسرفين﴾</span> أَي: المتكبرين</p></div>"
  44,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدِ اخْتَرْنَاهُمْ عَلَى عِلْمٍ عَلَى الْعَالمين﴾</span> على عَالم زمانهم الَّذِي كَانُوا فِيهِ</p></div>"
  44,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وآتيناهم﴾</span> يَعْنِي: أعطيناهم <span class="qpc-hafs">﴿مِنَ الآيَاتِ مَا فِيهِ بلَاء مُبين﴾</span> نعْمَة بَيِّنَة.</p></div>"
  44,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن هَؤُلَاءِ ليقولون﴾</span> يَعْنِي: مُشْركي الْعَرَب</p></div>"
  44,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنْ هِيَ إِلا مَوْتَتُنَا الأُولَى وَمَا نَحن بمنشرين﴾</span> بمبعوثين.</p><p>قَالَ محمدٌ: يُقَال: أَنْشَرَ الله الْمَوْتَى؛ فنشروا.</p></div>"
  44,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأْتُوا بِآبَائِنَا إِنْ كُنْتُمْ صَادِقِينَ﴾</span> أَي: فأحيوا لنا آبَاءَنَا، حَتَّى نصدقكم بمقالتكم أنَّ الله يحيي الْمَوْتَى.</p></div>"
  44,37,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿أَهُمْ خَيْرٌ أَمْ قَوْمُ تُبَّعٍ وَالَّذِينَ مِنْ قَبْلِهِمْ﴾</span> من الْكفَّار أَي: أَنهم لَيْسُوا بِخَير مِنْهُم؛ يخوفهم بِالْعَذَابِ.</p></div>"
  44,38,"<div class=ar lang=ar></div>"
  44,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا خلقناهما إِلَّا بِالْحَقِّ﴾</span> للبعث وللحساب، وللجنة وَالنَّار <span class="qpc-hafs">﴿وَلَكِنَّ أَكْثَرهم﴾</span> جمَاعَة الْمُشْركين <span class="qpc-hafs">﴿لَا يعلمُونَ﴾</span> أَنهم مبعوثون ومحاسبون ومجازون.</p></div>"