quran[15]{c,v,t}:
  72,14,"<div class=ar lang=ar></div>"
  72,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأما القاسطون﴾</span> الْجَائِرُونَ عَنِ الْهُدَى. قَالَ محمدٌ: يُقَالُ: قَسَطَ إِذَا جَارَ، وأقْسَط إِذَا عَدل. <span class="qpc-hafs">﴿فَأُولَئِكَ تَحَرَّوْا رَشَدًا﴾</span> أَصَابُوا الرُّشْدَ.</p></div>"
  72,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وألَّوا استقاموا على الطَّرِيقَة﴾</span> عَلَى الْإِيمَانِ <span class="qpc-hafs">﴿لأَسْقَيْنَاهُمْ مَاءً غَدَقًا﴾</span> أَيْ: لَأَوْسَعْنَا لَهُمْ مِنَ الرِّزْقِ؛ فِي تَفْسِير الْحسن</p></div>"
  72,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لنفتنهم فِيهِ﴾</span> لِنَخْتَبِرَهُمْ فِيهِ فَنَعْلَمَ كَيْفَ شُكْرُهُمْ.</p><p>قَالَ محمدٌ: قَالُوا: غَدِقَت الْأَرْضُ وأَغْدقت إِذَا ابتلّتْ، وَقَالُوا: مطرٌ غَيْداق؛ أَيْ: كَثِيرٌ، وَسَنَةٌ غَيْدَاق إِذَا أَخْصَبَتْ.</p><p><span class="qpc-hafs">﴿نَسْلُكُهُ﴾</span> نُدْخِلُهُ <span class="qpc-hafs">﴿عَذَابًا صعدا﴾</span> تَفْسِيرُ قَتَادَةَ: لَا رَاحَةَ فِيهِ.</p><p>قَالَ محمدٌ: يُقَالُ: تصعَّدني الْأَمْرُ إِذا شقَّ عليَّ.</p></div>"
  72,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَن الْمَسَاجِد لله﴾</span></p><p>قَالَ محمدٌ: الْمَعْنَى: وَلِأَنَّ الْمَسَاجِدَ لِلَّهِ. <span class="qpc-hafs">﴿فَلا تَدْعُوا مَعَ اللَّهِ أحدا﴾</span> تَفْسِيرُ الْحَسَنِ: قَالَ: يَقُولُ: لَيْسَ مِنْ قَوْمٍ غَيْرَ الْمُسْلِمِينَ يَقُومُونَ فِي مَسَاجِدِهِمْ إِلَّا وَهُمْ يُشْرِكُونَ بِاللَّه فِيهَا، فأخلصُوا لله.</p></div>"
  72,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّهُ لَمَّا قَامَ عَبْدُ اللَّهِ﴾</span> <span class="qpc-hafs">﴿يَدعُوهُ﴾</span> يَدْعُو الله <span class="qpc-hafs">﴿كَادُوا﴾</span> كَادَ الْمُشْرِكُونَ <span class="qpc-hafs">﴿يَكُونُونَ عَلَيْهِ لِبَدًا﴾</span> تَفْسِيرُ مِنَ الْحَرْدِ عَلَيْهِ.</p><p>قَالَ محمدٌ: كُلُّ شيءٍ أَلْصَقْتَهُ بشيءٍ إلصاقًا شَدِيدا [فقد لبّدته].</p></div>"
  72,20,"<div class=ar lang=ar></div>"
  72,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلْ إِنِّي لَا أَمْلِكُ لَكُمْ ضرا﴾</span> أَنْ أُدْخِلَكُمْ فِي الْكُفْرِ <span class="qpc-hafs">﴿وَلا رشدا﴾</span> أَن أكرهكم على الْهدى</p></div>"
  72,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلْ إِنِّي لَنْ يُجِيرَنِي مِنَ اللَّهِ أَحَدٌ﴾</span> <span class="qpc-hafs">﴿وَلَنْ أَجِدَ مِنْ دونه ملتحدا﴾</span> ملْجأ ألجأ إِلَيْهِ (ل ٣٧٦)</p></div>"
  72,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا بَلاغًا مِنَ اللَّهِ﴾</span>.</p></div>"
  72,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فسيعلمون من أَضْعَف ناصرا﴾</span> أَيْ: أَنَّكُمْ أَيُّهَا الْمُشْرِكُونَ لَا نَاصِر لكم <span class="qpc-hafs">﴿وَأَقل عددا﴾</span> أَيْ: يُفْرَدُ كُلُّ إِنْسَانٍ بِعَمَلِهِ.</p></div>"
  72,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلْ إِنْ أَدْرِي أَقَرِيبٌ مَا توعدون﴾</span> أَيُّهَا الْمُشْرِكُونَ مِنْ مَجِيءِ السَّاعَةِ <span class="qpc-hafs">﴿أَمْ يَجْعَلُ لَهُ رَبِّي أَمَدًا﴾</span></p></div>"
  72,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَالم الْغَيْب﴾</span> والغيب هَا هُنَا فِي تَفْسِيرِ قَتَادَةَ: الْوَحْيُ (فَلا يظْهر على غيبه أحدا}</p></div>"
  72,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا مَنِ ارْتَضَى مِنْ رَسُولٍ فَإِنَّهُ يَسْلُكُ مِنْ بَيْنِ يَدَيْهِ وَمن خَلفه رصدًا﴾</span> مِنَ الْمَلائِكَةِ يَحْفَظُونَهُ حَتَّى يُبَلِّغَ عَن الله الرسَالَة</p></div>"
  72,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَعْلَمَ أَنْ قَدْ أَبْلَغُوا رِسَالاتِ رَبهم﴾</span> لِيَعْلَمَ ذَلِكَ الرَّسُولُ أَنَّ الرُّسُلَ قَبْلَهُ قَدْ بلَّغوا رِسَالاتِ رَبِّهِمْ <span class="qpc-hafs">﴿وأحاط﴾</span> <span class="qpc-hafs">﴿الله﴾</span> (بِمَا لديهم} يَعْنِي: مَا أُرْسِلُوا بِهِ فَلا يُوصَلُ إِلَيْهِمْ؛ حَتَّى يُبَلِّغُوا عَنِ اللَّهِ الرِّسَالَةَ <span class="qpc-hafs">﴿وَأَحْصَى كُلَّ شَيْءٍ﴾</span> <span class="qpc-hafs">﴿من خلقه﴾</span> (عددا}.</p><p>قَالَ محمدٌ: (عددا) حَالٌ؛ الْمَعْنَى: وأَحْصَى كُلَّ شَيْءٍ فِي حَالِ الْعَدَدِ.</p></div>"