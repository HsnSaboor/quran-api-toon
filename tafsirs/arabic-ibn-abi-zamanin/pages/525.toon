quran[18]{c,v,t}:
  52,32,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿أَمْ تَأْمُرُهُمْ أَحْلامُهُمْ بِهَذَا﴾</span> بالتكذيب، أَي: لَيست لَهُم أحلامٌ <span class="qpc-hafs">﴿أم هم قوم طاغون﴾</span> أَي: بل هُمْ قومٌ طاغون يَقُول: إِن الطغيانَ - وَهُوَ الشّرك - يَأْمُرهُم بِهَذَا</p></div>"
  52,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم يَقُولُونَ تَقوله﴾</span> محمدٌ، يَعْنِي: الْقُرْآن؛ أَي: قد قَالُوهُ</p></div>"
  52,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فليأتوا بِحَدِيث مثله﴾</span> مثل الْقُرْآن <span class="qpc-hafs">﴿إِنْ كَانُوا صَادِقِينَ﴾</span> أَي: لَا يأْتونَ بِمثلِهِ، وَلَيْسَ ذَلِك عِنْدهم</p></div>"
  52,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمْ خُلِقُوا مِنْ غَيْرِ شَيْءٍ﴾</span> أَي: لمْ يخلقوا من غير شَيْء خلقناهم من نُطْفَة وَأول ذَلِك من ترابٍ <span class="qpc-hafs">﴿أَمْ هُمُ الْخَالِقُونَ﴾</span> أَي: لَيْسُوا بالخالقين وهم مخلوقون</p></div>"
  52,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم خلقُوا السَّمَاوَات وَالْأَرْض﴾</span> أَي: لمْ يخلقوها <span class="qpc-hafs">﴿بَلْ لَا يوقنون﴾</span> بِالْبَعْثِ</p></div>"
  52,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم عِنْدهم خَزَائِن رَبك﴾</span> يَعْنِي: علمَ الْغَيْب <span class="qpc-hafs">﴿أَمْ هُمُ المصيطرون﴾</span> يَعْنِي: الأرباب، أَي: إنّ اللَّه هُوَ الرَّبُّ - تبَارك اسْمُه.</p><p>قَالَ محمدٌ: يُقَال: تَصيطرتَ عليَّ، أَي: اتخذتّني خَوَلًا. وَيكْتب بِالسِّين وَالصَّاد، والأصْلُ السِّين وكل سين بعْدهَا طاءٌ يجوز أَن تقلب صادًا.</p></div>"
  52,38,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿أم لَهُم سلم﴾</span> درج <span class="qpc-hafs">﴿يَسْتَمِعُون فِيهِ﴾</span> إِلَى السَّمَاء، والسُّلّمُ أَيْضا السَّبَب وَقَوله (فِيهِ) بِمَعْنى: عَلَيْه <span class="qpc-hafs">﴿فَلْيَأْتِ مُسْتَمِعُهُمْ بِسُلْطَانٍ مُبين﴾</span> بِحجَّة بيّنة بِمَا همْ عَلَيْهِ من الشّرك، أَي: لَيْسَ عِنْدهم بذلك حجَّة</p></div>"
  52,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمْ لَهُ الْبَنَاتُ وَلَكُمُ الْبَنُونَ﴾</span> وَذَلِكَ لقَولهم: أَن الْمَلَائِكَة بَنَات الله. وَجعلُوا لأَنْفُسِهِمْ الغلمان</p></div>"
  52,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم تَسْأَلهُمْ أجرا﴾</span> على الْقُرْآن <span class="qpc-hafs">﴿فَهُمْ مِنْ مَغْرَمٍ مثقلون﴾</span> فقد أثقلهم الغُرْمُ، أَي: إِنَّك لَا تَسْأَلهُمْ أجرا</p></div>"
  52,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم عِنْدهم الْغَيْب﴾</span> يَعْنِي: علم غَيْب الْآخِرَة <span class="qpc-hafs">﴿فَهُمْ يَكْتُبُونَ﴾</span> لأَنْفُسِهِمْ مَا يتخيّرون؛ لقَوْل الْكَافِر: <span class="qpc-hafs">﴿وَلَئِنْ رُجِعْتُ إِلَى رَبِّي إِنَّ لي عِنْده للحسنى﴾</span> يَعْنِي للجنة إِن كَانَت جنَّة، أَي: لَيْسَ عِنْدهم علم غيب الْآخِرَة</p></div>"
  52,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم يُرِيدُونَ كيدا﴾</span> بِالنَّبِيِّ، أَي: قد أرادوه</p><p><span class="qpc-hafs">﴿فَالَّذِينَ كَفَرُوا هم المكيدون﴾</span> كَقَوْلِه: <span class="qpc-hafs">﴿إِنَّهُمْ يَكِيدُونَ كَيْدًا وَأَكِيدُ كيدا﴾</span> لأريهم جَزَاء كيدهم وَهُوَ الْعَذَاب</p></div>"
  52,43,"<div class=ar lang=ar><p>قَالَ <span class="qpc-hafs">﴿أَمْ لَهُمْ إِلَهٌ غَيْرُ الله﴾</span> أَي (ل ٣٤٢) <span class="qpc-hafs">﴿شَاعِر نتربص بِهِ﴾</span> إِلَى هَذَا الْموضع كالاستفهام وكذبهم بِهِ كُله.</p></div>"
  52,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنْ يَرَوْا كِسْفًا مِنَ السَّمَاءِ﴾</span> والكِسْفُ: القطْعة <span class="qpc-hafs">﴿سَاقِطًا يَقُولُوا سَحَابٌ مركوم﴾</span> بعضُه على بعض، وَذَلِكَ أَنه قَالَ فِي سُورَة سبأ: <span class="qpc-hafs">﴿إِنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ أَوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا من السَّمَاء﴾</span> فَقَالُوا للنَّبِي: لن نؤمن لَك حَتَّى تُسْقِطَ السَّمَاءَ كَمَا زَعَمْتَ عَلَيْنَا كسفاً؛ فَأنْزل اللَّه: <span class="qpc-hafs">﴿وَإِنْ يَرَوْا كِسْفًا مِنَ السَّمَاءِ سَاقِطًا يَقُولُوا سَحَابٌ مركوم﴾</span> أَي: وَلم يُؤمنُوا.</p></div>"
  52,45,"<div class=ar lang=ar><p>قَالَ اللَّه: <span class="qpc-hafs">﴿فَذَرْهُمْ حَتَّى يُلاقُوا يومهم الَّذِي فِيهِ يصعقون﴾</span> أَي: يموتون، وَهِي النفخة الأولى؛ فِي تَفْسِير الْحسن، يَعْنِي: كفار آخر هَذِه الْأمة الَّذين يكون هلاكهم بِقِيَام السَّاعَة.</p></div>"
  52,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ لَا يُغْنِي عَنْهُمْ كَيْدُهُمْ شَيْئا﴾</span> لَا تغني عَنْهُم عبَادَة الْأَوْثَان وَلَا مَا كَادُوا للنَّبِي شَيْئا <span class="qpc-hafs">﴿وَلَا هم ينْصرُونَ﴾</span> إِذا جَاءَهُم الْعَذَاب.</p></div>"
  52,47,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿وَإِن للَّذين ظلمُوا﴾</span> أشركوا <span class="qpc-hafs">﴿عذَابا دون ذَلِك﴾</span> بِالسَّيْفِ؛ يَعْنِي: من أُهلك يَوْم بدر؛ فِي تَفْسِير الْحسن <span class="qpc-hafs">﴿وَلَكِنَّ أَكْثَرهم﴾</span> أَي: جَمَاعَتهمْ <span class="qpc-hafs">﴿لَا يعلمُونَ﴾</span> يَعْنِي: من لَا يُؤمن بِهِ.</p></div>"
  52,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واصبر لحكم رَبك﴾</span> أَي: لما حكم اللَّه عَلَيْك، فَأمره بقتالهم <span class="qpc-hafs">﴿فَإنَّك بأعيننا﴾</span> أَي: نرى مَا تصنع وَمَا يصنع بك، فسنجزيك ونجزيهم.</p><p><span class="qpc-hafs">﴿وَسَبِّحْ بِحَمْد رَبك حِين تقوم﴾</span> من مقامك، يَعْنِي: صَلَاة الصُّبْح؛ فِي تَفْسِير الْحسن.</p></div>"
  52,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمن اللَّيْل فسبحه﴾</span> يَعْنِي: صَلاةَ الْمَغْرِبِ وَصَلاةَ الْعِشَاءِ <span class="qpc-hafs">﴿وإدبار النُّجُوم﴾</span>.</p><p>يَحْيَى: عَنْ عُثْمَانَ، عَنْ أَبِي إِسْحَاقَ الْهَمْدَانِيِّ، عَنِ الْحَارِثِ، عَنْ عَلِيٍّ قَالَ: " سُئِلَ رَسُولُ اللَّهِ ﷺ عَنِ قَوْله: <span class="qpc-hafs">﴿وإدبار النُّجُوم﴾</span>. فَقَالَ: هُمَا الرَّكْعَتَانِ قَبْلَ صَلاةِ الصُّبْح ".</p></div>"