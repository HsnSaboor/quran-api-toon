quran[27]{c,v,t}:
  68,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سنسمه على الخرطوم﴾</span> عَلَى أَنْفِهِ بِسُوَادٍ يَوْمَ الْقِيَامَةِ يعرف بِهِ.</p></div>"
  68,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا بلوناهم﴾</span> يَعْنِي: أَهْلَ مَكَّةَ ابْتُلُوا بِالْجُوعِ حِينَ كذَّبوا النَّبِيَّ <span class="qpc-hafs">﴿كَمَا بَلَوْنَا أَصْحَاب الْجنَّة﴾</span> تَفْسِيرُ الْكَلْبِيِّ: أَنَّهُمْ كَانُوا أَبْنَاءَ قَوْمٍ صَالِحِينَ، وَأَنَّ آبَاءَهُمْ كَانُوا جَعَلُوا مِنْ جَنَّتِهِمْ حَظًّا لِلْمَسَاكِينِ وَأَبْنَاءِ السَّبِيلِ، فَخَلَفَ مِنْ بَعْدِهِمْ أَبْنَاؤُهُمْ، فَقَالُوا: كَبُرْنَا وَكَثُرَ عِيَالُنَا، فَلَيْسَ لِلْمَسَاكِينِ عِنْدَنَا شيءٌ فَتَقَاسَمُوا <span class="qpc-hafs">﴿ليصرمنها﴾</span> ليجذُّنّها (١) <span class="qpc-hafs">﴿مصبحين﴾</span> أَي: صبحًا</p></div>"
  68,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يستثنون﴾</span> أَيْ: وَلَمْ يَقُولُوا إِنْ شَاءَ الله</p></div>"
  68,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَافَ عَلَيْهَا طائف﴾</span> عذابٌ <span class="qpc-hafs">﴿مِنْ رَبِّكَ وَهُمْ نَائِمُونَ﴾</span></p></div>"
  68,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَصْبَحت كالصريم﴾</span> الصَّرِيمُ بِمَعْنَى الْمَصْرُومِ، وَهُوَ الْهَالِكُ الذَّاهِب.</p></div>"
  68,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنَادَوْا مصبحين﴾</span> حِين أَصْبحُوا</p></div>"
  68,22,"<div class=ar lang=ar></div>"
  68,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وهم يتخافتون﴾</span> يتسارُّون بَينهم</p></div>"
  68,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلا يدخلنها الْيَوْم عَلَيْكُم مِسْكين﴾</span> أَيْ: أَلَّا تُطْعِمُوا الْيَوْمَ مِسْكِينًا</p></div>"
  68,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وغدوا على حرد قَادِرين﴾</span> عَلَى جدٍّ مِنْ أَمْرِهِمْ <span class="qpc-hafs">﴿قَادِرِينَ﴾</span> عَلَى جَنَّتِهِمْ فِي أَنْفُسِهِمْ.</p><p>قَالَ مُحَمَّدٌ: وَالْحَرْدُ أَيْضًا فِي اللُّغَةِ الْمَنْعُ، يُقَالُ مِنْهُ حَارَدَتِ السَّنَةُ إِذَا لَمْ يَكُنْ فِيهَا مَطَرٌ، وَحَارَدَتِ النَّاقَةُ إِذَا لَمْ يَكُنْ فِيهَا لبن (٢).</p></div>"
  68,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَمَّا رأوها﴾</span> [خَرَابًا] (٣) سَوْدَاءَ، وَعَهْدُهُمْ بِهَا بِالْأَمْسِ عامرة <span class="qpc-hafs">﴿قَالُوا إِنَّا لضالون﴾</span> أَيْ: ضَلَلْنَا الطَّرِيقَ، ظَنُّوا أَنَّهَا لَيْسَتْ جَنَّتَهُمْ ثُمَّ أَيْقَنُوا أَنَّهَا جنتهم.</p></div>"
  68,27,"<div class=ar lang=ar><p>فَقَالُوا: <span class="qpc-hafs">﴿بل نَحن محرومون﴾</span> حُرِمْنا خير جنتنا</p></div>"
  68,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ أوسطهم﴾</span> أَعْدَلُهُمْ <span class="qpc-hafs">﴿أَلَمْ أَقُلْ لَكُمْ لَوْلا﴾</span> هلا <span class="qpc-hafs">﴿تسبحون﴾</span> تستثنون</p></div>"
  68,29,"<div class=ar lang=ar></div>"
  68,30,"68:29"
  68,31,"68:29"
  68,32,"68:29"
  68,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَلِك الْعَذَاب﴾</span> أَيْ: هَكَذَا كَانَ الْعَذَابُ؛ كَمَا قَصَصْتُهُ عَلَيْكُمْ يَعْنِي: مَا عَذَّبَهُمْ بِهِ مِنْ إِهْلاكِ جَنَّتِهِمْ <span class="qpc-hafs">﴿وَلَعَذَابُ الْآخِرَةِ أَكْبَرُ﴾</span> مِنْ عَذَابِ الدُّنْيَا <span class="qpc-hafs">﴿لَو كَانُوا يعلمُونَ﴾</span> يَعْنِي: قُرَيْشًا، رَجَعَ إِلَى قَوْلِهِ: <span class="qpc-hafs">﴿إِنَّا بلوناهم﴾</span> يَعْنِي: قُرَيْشًا <span class="qpc-hafs">﴿لَوْ كَانُوا يَعْلَمُونَ﴾</span> لعلموا أَن عَذَاب الْآخِرَة أكبر من عَذَاب الدُّنْيَا.</p></div>"
  68,34,"<div class=ar lang=ar></div>"
  68,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أفنجعل الْمُسلمين كالمجرمين﴾</span> كالمشركين؛ أَي: لَا نَفْعل،</p></div>"
  68,36,"<div class=ar lang=ar><p>ثُمَّ قَالَ لِلْمُشْرِكِينَ: <span class="qpc-hafs">﴿مَا لَكُمْ كَيفَ تحكمون﴾</span> أَيْ: لَيْسَ حُكْمُنَا أَنْ نَجْعَلَ الْمُسلمين فِي الْآخِرَة كالمشركين</p></div>"
  68,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ام لكم﴾</span> يَقُولُهُ لِلْمُشْرِكِينَ <span class="qpc-hafs">﴿كِتَابٌ فِيهِ تَدْرُسُونَ﴾</span> تقرءون</p></div>"
  68,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ان لكم فِيهِ﴾</span> فِي ذَلِكَ الْكِتَابِ <span class="qpc-hafs">﴿لَمَا تَخَيَّرُونَ﴾</span> أَيْ: مَا تَخَيَّرَونَ وَاللَّامُ صِلَةٌ؛ أَيْ: لَيْسَ عِنْدَكُمْ كتابٌ تَقْرَءُونَ فِيهِ إِنَّ لَكُمْ لَمَا تَخَيَّرُونَ</p></div>"
  68,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمْ لَكُمْ أَيْمَانٌ عَلَيْنَا بَالِغَةٌ إِلَى يَوْمِ الْقِيَامَةِ إِنَّ لَكُمْ لما تحكمون﴾</span> أَيْ: مَا تَحْكُمُونَ، يَقُولُ: أَمْ حَلَفْنَا لَكُمْ بِأَنَّ لَكُمْ مَا تَحْكُمُونَ بِهِ. أَيْ: لَمْ نَفْعَلْ</p></div>"
  68,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سلهم أَيهمْ بذلك زعيم﴾</span> حَمِيلٌ يَحْمِلُ عَنَّا لَهُمْ بِأَنَّ لَهُمْ مَا يَحْكُمُونَ يَوْمَ الْقِيَامَةِ لِأَنْفُسِهِمْ؛ هَذَا لِقَوْلِ أَحَدِهِمْ: <span class="qpc-hafs">﴿وَلَئِنْ رُجِعْتُ إِلَى رَبِّي إِنَّ لِي عِنْده للحسنى﴾</span> (١) للجنّة إِن كَانَت جنَّة</p></div>"
  68,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم لَهُم شُرَكَاء﴾</span> خَلَقُوا مَعَ اللَّهِ شَيْئًا أَيْ: قَدْ أَشْرَكُوا بِاللَّهِ آلِهَةً لَمْ يخلقوا مَعَه شَيْئا</p></div>"
  68,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم يكْشف عَن سَاق﴾</span> قَالَ قَبْلَ هَذَا <span class="qpc-hafs">﴿أَمْ لَكُمْ أَيْمَانٌ عَلَيْنَا بَالِغَةٌ إِلَى يَوْمِ الْقِيَامَة﴾</span> يَعْنِي: بِبَالِغَةٍ يَوْمَ الْقِيَامَةِ.</p><p><span class="qpc-hafs">﴿يَوْمَ يكْشف عَن سَاق﴾</span> قَالَ مُجَاهد: كُلُّ كَرْب أَوْ شدَّة فَهُوَ ساقٌ (٢) وَمِنْهُ قَوْله <span class="qpc-hafs">﴿والتفت السَّاق بالساق﴾</span> (١) أَيْ: كَرْبُ الدُّنْيَا بِكَرْبِ الْآخِرَةِ (٢).</p><p><span class="qpc-hafs">﴿وَيُدْعَوْنَ إِلَى السُّجُودِ فَلا يَسْتَطِيعُونَ﴾</span></p></div>"