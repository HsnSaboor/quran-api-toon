quran[29]{c,v,t}:
  70,11,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿يبصرونهم﴾</span> يُبْصُرُ الرَّجُلُ قَرَابَتَهُ؛ أَيْ: يَعْرِفُهُمْ فِي بَعْضِ الْمَوَاطِنِ، وَفِي بَعْضِهَا لَا يَعْرِفُ بَعْضُهُمْ بَعْضًا <span class="qpc-hafs">﴿يَوَدُّ المجرم﴾</span> يَعْنِي: الْمُشرك،</p></div>"
  70,12,"<div class=ar lang=ar></div>"
  70,13,"<div class=ar lang=ar><p>وَمعنى (فصيلته): عشيرته، وَمعنى (تؤويه): تنصره فِي الدُّنْيَا</p></div>"
  70,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنْ فِي الأَرْضِ جَمِيعًا ثُمَّ ينجيه﴾</span> ذَلِكَ مِنْ عَذَابِ اللَّهِ. <span class="qpc-hafs">﴿كَلَّا إِنَّهَا لظى﴾</span></p></div>"
  70,15,"<div class=ar lang=ar></div>"
  70,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نزاعة﴾</span> يَعْنِي: أكالة <span class="qpc-hafs">﴿للشوى﴾</span> يَعْنِي: الْهَامَّ فِي تَفْسِيرِ الْحَسَنِ</p></div>"
  70,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَدْعُو من أدبر﴾</span> عَن الْإِيمَان <span class="qpc-hafs">﴿وَتَوَلَّى﴾</span> عَن طَاعَة الله</p></div>"
  70,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجمع فأوعى﴾</span> يَعْنِي: جمع المَال فأوعاه.</p></div>"
  70,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن الْإِنْسَان﴾</span> يَعْنِي الْمُشرك <span class="qpc-hafs">﴿خلق هلوعا﴾</span> يَعْنِي: ضَجِرًا</p></div>"
  70,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذا مَسّه الشَّرّ﴾</span> يَعْنِي: الشدَّة <span class="qpc-hafs">﴿جزوعا﴾</span> لَمْ يَصْبِرْ لَيْسَتْ لَهُ فِيهَا حسبةٌ</p></div>"
  70,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا مَسّه الْخَيْر﴾</span> يَعْنِي: إِذَا أُعْطِيَ الْمَالَ <span class="qpc-hafs">﴿مَنُوعًا﴾</span> أَيْ: يَمْنَعُ حَقَّ اللَّهِ فِيهِ.</p></div>"
  70,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا الْمُصَلِّين﴾</span> يَعْنِي: الْمُسلمين</p></div>"
  70,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِينَ هُمْ عَلَى صَلاتِهِمْ دَائِمُونَ﴾</span> يَدُومُونَ عَلَيْهَا فِي تَفْسِيرِ الْحَسَنِ</p></div>"
  70,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِينَ فِي أَمْوَالِهِمْ حَقٌّ مَعْلُومٌ﴾</span> وَهِي الزَّكَاة الْمَفْرُوضَة</p></div>"
  70,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿للسَّائِل والمحروم﴾</span> تَفْسِيرُ الْحَسَنِ: السَّائِلُ: الْمِسْكِينُ الَّذِي يَسْأَلُ عِنْدَ الْحَاجَةِ , وَالْمَحْرُومُ: الْفَقِيرُ الَّذِي لَا يَسْأَلُ عَلَى حَالٍ فحُرم أَنْ يُعْطى عَنِ الْمَسْأَلَةِ؛ كَمَا يُعْطى السَّائِلُ، وَإِنْ أُعطي شَيْئا قَبِل</p></div>"
  70,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذين يصدقون بِيَوْم الدّين﴾</span> بِيَوْم الْحساب</p></div>"
  70,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِينَ هُمْ مِنْ عَذَابِ رَبِّهِمْ مشفقون﴾</span> خائفون.</p></div>"
  70,28,"<div class=ar lang=ar></div>"
  70,29,"70:28"
  70,30,"70:28"
  70,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمن ابْتغى وَرَاء ذَلِك﴾</span> وَرَاءَ أَزْوَاجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَانهم <span class="qpc-hafs">﴿فَأُولَئِك هم العادون﴾</span> الزُّناة تعدَّوْا الْحَلالَ إِلَى الْحَرَامِ</p></div>"
  70,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذين هم لِأَمَانَاتِهِمْ﴾</span> يَعْنِي: مَا افْترض اللَّه عَلَيْهِم، وَالْأَمَانَاتُ فِيمَا بَيْنَهُمْ وَبَيْنَ النَّاسِ <span class="qpc-hafs">﴿وَعَهْدهمْ﴾</span> مَا عَاهَدُوا عَلَيْهِ <span class="qpc-hafs">﴿رَاعُونَ﴾</span> حَافِظُونَ؛ يَعْنِي: يُؤَدُّونَ الْأَمَانَاتِ، وَيُوفُونَ بِالْعَهْدِ فِيمَا بَيْنَهُمْ وَبَيْنَ النَّاسِ فِيمَا وَافق الْحق</p></div>"
  70,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذين هم بشهاداتهم قائمون﴾</span> وَهِيَ شَهَادَاتٌ فِيمَا بَيْنَ النَّاسِ يقومُونَ بهَا إِذا كَانَت عِنْدهم</p></div>"
  70,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِينَ هُمْ عَلَى صَلاتِهِمْ يُحَافِظُونَ﴾</span> عَلَى وضوئها ومواقيتها وركوعها وسجودها.</p></div>"
  70,35,"<div class=ar lang=ar></div>"
  70,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</span> يَعْنِي: مُنْطَلِقِينَ يَأْخُذُونَ يَمِينًا وَشِمَالًا، يَقُولُونَ: مَا يَقُولُ هَذَا الرَّجُلُ؟:</p></div>"
  70,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عزين﴾</span> أَيْ: مُتَفَرِّقِينَ - فِي تَفْسِيرِ الْحَسَنِ - عَنِ النَّبِيِّ يُكَذِّبُونَ بِمَا جَاءَ بِهِ.</p><p>قَالَ محمدٌ (مُهْطِعِينَ) مَنْصُوبٌ عَلَى الْحَال، و (عزين) جمع عزَة والعِزَةُ: الْجَمَاعَة.</p></div>"
  70,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَطْمَعُ كُلُّ امْرِئٍ مِنْهُمْ أَنْ يدْخل جنَّة نعيم﴾</span> لقَوْل أحدهم: <span class="qpc-hafs">﴿وَلَئِنْ رُجِعْتُ إِلَى رَبِّي إِنَّ لِي عِنْدَهُ لَلْحُسْنَى﴾</span> لَلْجَنَّةَ إِنْ كَانَتْ جَنَّةٌ كَمَا يَقُولُونَ،</p></div>"
  70,39,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿كلا﴾</span> لَيْسُوا مِنْ أَهْلِ الْجَنَّةِ، ثُمَّ قَالَ: <span class="qpc-hafs">﴿إِنَّا خَلَقْنَاهُمْ مِمَّا يَعْلَمُونَ﴾</span> يَعْنِي: من النُّطَفِ.</p></div>"