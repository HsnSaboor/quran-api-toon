quran[9]{c,v,t}:
  6,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذين آمنُوا وَلم يلبسوا﴾</span> يَعْنِي: يخلطوا <span class="qpc-hafs">﴿إِيمَانهم بظُلْم﴾</span> بشرك <span class="qpc-hafs">﴿أُولَئِكَ لَهُم الْأَمْن﴾</span> يَوْم الْقِيَامَة <span class="qpc-hafs">﴿وهم مهتدون﴾</span> فِي الدُّنْيَا.</p></div>"
  6,83,"<div class=ar lang=ar></div>"
  6,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوَهَبْنَا لَهُ إِسْحَاقَ وَيَعْقُوبَ﴾</span> إِلَى قَوْلِهِ: <span class="qpc-hafs">﴿وَكُلًّا فَضَّلْنَا عَلَى الْعَالَمِينَ﴾</span> يَعْنِي: عالمي زمانهم</p></div>"
  6,85,"<div class=ar lang=ar></div>"
  6,86,"6:85"
  6,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واجتبيناهم﴾</span> (استخلصناهم) للنبوة.</p></div>"
  6,88,"<div class=ar lang=ar></div>"
  6,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ آتَيْنَاهُمُ الْكِتَابَ وَالْحُكْمَ﴾</span> يَعْنِي: الْفَهْمَ وَالْعَقْلَ <span class="qpc-hafs">﴿وَالنُّبُوَّةَ فَإِنْ يكفر بهَا هَؤُلَاءِ﴾</span> قَالَ الْحَسَنُ: يَعْنِي: الْمُشْرِكِينَ <span class="qpc-hafs">﴿فَقَدْ وكلنَا بهَا﴾</span> بِالنُّبُوَّةِ <span class="qpc-hafs">﴿قَوْمًا لَيْسُوا بِهَا بِكَافِرِينَ﴾</span> يَعْنِي: النَّبِيِّينَ الَّذِينَ ذَكَرَ: دَاوُدَ وَسُلَيْمَانَ وَغَيْرَهُمْ مِنَ الْأَنْبِيَاءِ الْمَذْكُورِينَ فِي الْآيَة.</p></div>"
  6,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُولَئِكَ الَّذين هدى الله﴾</span> يَعْنِي: النَّبِيِّينَ الَّذِينَ قَصَّ.</p><p>(فَبِهُدَاهُمُ اقتده} يَقُوله لمُحَمد ﷺ.</p></div>"