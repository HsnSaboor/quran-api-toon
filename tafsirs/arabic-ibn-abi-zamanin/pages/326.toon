quran[13]{c,v,t}:
  21,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل إِنَّمَا أنذركم بِالْوَحْي﴾</span> بِالْقُرْآنِ، أُنْذِرُكُمْ بِهِ عَذَابَ الدُّنْيَا وَعَذَابَ الْآخِرَةِ يَعْنِي: الْمُشْرِكِينَ <span class="qpc-hafs">﴿وَلا يسمع الصم الدُّعَاء﴾</span> يَعْنِي: النِّدَاءَ <span class="qpc-hafs">﴿إِذَا مَا يُنْذَرُونَ﴾</span> والصم هَاهُنَا: الْكفَّار؛ صموا عَن الْهدى</p></div>"
  21,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَئِنْ مَسَّتْهُمْ نَفْحَةٌ مِنْ عَذَابِ رَبك﴾</span> قَالَ قَتَادَةُ: يَعْنِي: عُقُوبَةً.</p><p>قَالَ يَحْيَى: يَعْنِي: النَّفْخَةَ الْأُولَى الَّتِي يُهَلْكُ بِهَا كُفَّارُ آخِرِ هَذِهِ الْأمة.</p></div>"
  21,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَضَع الموازين الْقسْط﴾</span> (يَعْنِي: الْعَدْلَ) <span class="qpc-hafs">﴿لِيَوْمِ الْقِيَامَةِ فَلا تظلم نفس شَيْئا﴾</span> لَا تُنْقَصُ مِنْ ثَوَابِ عَمَلِهَا <span class="qpc-hafs">﴿وَإِن كَانَ مِثْقَال حَبَّة﴾</span> أَيْ: وَزْنَ حَبَّةٍ <span class="qpc-hafs">﴿مِنْ خَرْدَلٍ أَتَيْنَا بِهَا وَكَفَى بِنَا حَاسِبِينَ﴾</span> قَالَ الْحَسَنُ: لَا يَعْلَمُ حِسَابَ مَثَاقِيلِ الذَّرِّ وَالْخَرْدَلِ إِلَّا اللَّهُ، وَلَا يُحَاسِبُ الْعِبَادَ إِلَّا هُوَ.</p></div>"
  21,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ آتَيْنَا مُوسَى وَهَارُونَ الْفُرْقَانَ﴾</span> يَعْنِي: التَّوْرَاةَ، وفُرْقَانُهَا أَنَّهُ فَرَّقَ فِيهَا حلالها وحرامها.</p></div>"
  21,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذين يَخْشونَ رَبهم بِالْغَيْبِ﴾</span> أَيْ: يَذْكَرُ الرَّجُلُ مِنْهُمْ ذَنْبَهُ فِي الْخَلَاءِ؛ فَيَسْتَغْفِرِ اللَّهَ مِنْهُ. <span class="qpc-hafs">﴿وَهُمْ مِنَ السَّاعَة مشفقون﴾</span> خَائِفُونَ مِنْ شَرِّ ذَلِكَ الْيَوْمَ وهم الْمُؤْمِنُونَ.</p></div>"
  21,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَذَا ذكر مبارك﴾</span> يَعْنِي: الْقُرْآنَ. <span class="qpc-hafs">﴿أَفَأَنْتُمْ لَهُ مُنْكِرُونَ﴾</span> يَعْنِي: الْمُشْرِكِينَ عَلَى الِاسْتِفْهَامِ؛ يَعْنِي: قد أنكرتموه.</p></div>"
  21,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ آتَيْنَا إِبْرَاهِيمَ رُشْدَهُ مِنْ قبل﴾</span> يَعْنِي: النُّبُوَّةَ <span class="qpc-hafs">﴿وَكُنَّا بِهِ عَالِمِينَ﴾</span> أَنَّهُ سَيُبَلِّغُ عَنِ اللَّهِ الرِّسَالَةَ.</p></div>"
  21,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا هَذِه التماثيل﴾</span> يَعْنِي: الْأَصْنَامَ <span class="qpc-hafs">﴿الَّتِي أَنْتُمْ لَهَا عاكفون﴾</span> (ل ٢١٦) مقيمون على عبادتها.</p></div>"
  21,53,"<div class=ar lang=ar></div>"
  21,54,"21:53"
  21,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا أَجِئْتَنَا بِالْحَقِّ أَمْ أَنْتَ من اللاعبين﴾</span> يَعْنِي: الْمُسْتَهْزِئِينَ.</p></div>"
  21,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي فطرهن﴾</span> خَلَقَهُنَّ <span class="qpc-hafs">﴿وَأَنَا عَلَى ذَلِكُمْ مِنَ الشَّاهِدين﴾</span> أَنه ربكُم</p></div>"
  21,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وتالله لأكيدن أصنامكم﴾</span> الْآيَةُ.</p><p>قَالَ قَتَادَةُ: [نَرَى] أَنَّهُ قَالَ ذَلِكَ حَيْثُ لَا يَسْمَعُونَ اسْتَدْعَاهُ قَوْمُهُ إِلَى عِيدٍ لَهُمْ؛ فَأبى وَقَالَ: <span class="qpc-hafs">﴿إِنِّي سقيم﴾</span> اعْتَلَّ لَهُمْ بِذَلِكَ، ثُمَّ قَالَ لما ولوا: <span class="qpc-hafs">﴿تالله لأكيدن أصنامكم﴾</span> الْآيَة.</p></div>"