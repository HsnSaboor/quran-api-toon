quran[8]{c,v,t}:
  29,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلما أَن جَاءَت رسلنَا﴾</span> يَعْنِي: الْمَلَائِكَة <span class="qpc-hafs">﴿إِبْرَاهِيم بالبشرى﴾</span> بِإِسْحَاقَ <span class="qpc-hafs">﴿قَالُوا إِنَّا مُهْلِكُو أَهْلِ هَذِه الْقرْيَة﴾</span> يَعْنُونَ: قَرْيَةَ لُوْطٍ <span class="qpc-hafs">﴿إِنَّ أَهْلَهَا كَانُوا ظالمين﴾</span> مُشْرِكين</p></div>"
  29,32,"<div class=ar lang=ar></div>"
  29,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمَّا أَنْ جَاءَتْ رُسُلُنَا لُوطًا سِيءَ بِهِمْ وَضَاقَ بِهِمْ ذَرْعًا﴾</span> لِمَا تَخَوَّفَهُ عَلَيْهِمْ مِنْ فِعْلِ قَوْمِهِ، وَهُوَ يَظُنُّ أَنَّهُمْ آدَمِيُّونَ. <span class="qpc-hafs">﴿وَقَالُوا لَا تَخَفْ وَلا تَحْزَنْ﴾</span> الْمَلَائِكَة قالته للوط</p></div>"
  29,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا مُنْزِلُونَ عَلَى أَهْلِ هَذِهِ الْقَرْيَةِ رِجْزًا مِنَ السَّمَاءِ بِمَا كَانُوا يفسقون﴾</span> يشركُونَ</p></div>"
  29,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَد تركنَا مِنْهَا آيَة (ل ٢٦٠﴾</span> بَيِّنَة} أَي: [عِبْرَة] <span class="qpc-hafs">﴿لقوم يعْقلُونَ﴾</span> وَهُمُ الْمُؤْمِنُونَ، وَقَدْ مَضَى تَفْسِيرُ قصَّة قوم لوط.</p></div>"
  29,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِلَى مَدين﴾</span> أَيْ: وَأَرْسَلْنَا إِلَى مَدْيَنَ <span class="qpc-hafs">﴿أَخَاهُمْ شعيبا﴾</span> أَخُوهُمْ فِي النَّسَبِ، وَلَيْسَ بِأَخِيهِمْ فِي الدِّينِ <span class="qpc-hafs">﴿فَقَالَ يَا قَوْمِ اعْبُدُوا اللَّهَ وَارْجُوا الْيَوْمَ الآخِرَ﴾</span> أَي: صدقُوا بِهِ</p></div>"
  29,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَذبُوهُ فَأَخَذتهم الرجفة﴾</span> الْعَذَابُ؛ فِي تَفْسِيرِ الْحَسَنِ <span class="qpc-hafs">﴿فَأَصْبَحُوا فِي دَارهم جاثمين﴾</span> أَي: هالكين.</p></div>"
  29,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وعادا وثمودا﴾</span> أَي: وأهلكنا عادا وثمودا <span class="qpc-hafs">﴿وَقَدْ تَبَيَّنَ لَكُمْ مِنْ مَسَاكِنِهِمْ﴾</span> يَعْنِي: مَا رَأَوْا مِنْ آثَارِهِمْ <span class="qpc-hafs">﴿وَكَانُوا مستبصرين﴾</span> فِي الضَّلَالَة.</p></div>"