quran[21]{c,v,t}:
  54,7,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿خشعا أَبْصَارهم﴾</span> يَقُول: فتولَّ عَنْهُم فستراهم يَوْم الْقِيَامَة ذليلة أَبْصَارهم، وَكَانَ هَذَا قبل أَن يُؤمر بِالْقِتَالِ <span class="qpc-hafs">﴿يَخْرُجُونَ من الأجداث﴾</span> من الْقُبُور <span class="qpc-hafs">﴿كَأَنَّهُمْ جَرَادٌ مُنْتَشِرٌ﴾</span> تَفْسِير الْحسن شبَّههم بالجراد إِذا أدْركهُ اللَّيْل لزم الأَرْض، فَإِذا أصبح وطلع عَلَيْهِ الشَّمْس انْتَشَر</p></div>"
  54,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مهطعين﴾</span> مُسْرِعين <span class="qpc-hafs">﴿إِلَى الداع﴾</span> صَاحِبِ الصُّورِ إِلَى بَيْتِ الْمَقْدِسِ <span class="qpc-hafs">﴿يَقُول الْكَافِرُونَ﴾</span> يَوْمئِذٍ <span class="qpc-hafs">﴿هَذَا يَوْم عسر﴾</span> يعلم الْكَافِرُونَ يومئذٍ أَن عسر ذَلِك الْيَوْم عَلَيْهِم، وَلَيْسَ لَهُم من يسره شَيْء.</p></div>"
  54,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالُوا مَجْنُون وازدجر﴾</span> تُهُدِّدَ بِالْقَتْلِ فِي تَفْسِير الْحسن</p></div>"
  54,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَدَعَا رَبَّهُ أَنِّي مَغْلُوبٌ فَانْتَصِرْ﴾</span> أَي: فانتقم لي من قومِي.</p><p>قَالَ محمدٌ: من قَرَأَ <span class="qpc-hafs">﴿أَنِّي﴾</span> بِالْفَتْح للألف - وَهُوَ الأجود - وَالْمعْنَى: دَعَا ربه بِأَنِّي مغلوب.</p></div>"
  54,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَفَتَحْنَا أَبْوَابَ السَّمَاءِ بِمَاءٍ مُنْهَمِرٍ﴾</span> بعضه على بعض وَلَيْسَ بمطر.</p><p>قَالَ محمدٌ: يُقَال: همَر الرجُلُ إِذا أَكثر من الْكَلَام وأسرع.</p></div>"
  54,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَجَّرْنَا الأَرْضَ عُيُونًا فَالْتَقَى الْمَاءُ﴾</span> مَاء السَّمَاء وَمَاء الأَرْض <span class="qpc-hafs">﴿عَلَى أَمر قد قدر﴾</span> على هَلَاك قوم نوح</p></div>"
  54,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وحملناه﴾</span> يَعْنِي: نوحًا <span class="qpc-hafs">﴿عَلَى ذَاتِ أَلْوَاحٍ﴾</span> يَعْنِي: السَّفِينَة <span class="qpc-hafs">﴿ودسر﴾</span> الدُّسُر: المسامير؛ فِي تَفْسِير قَتَادَة.</p><p>قَالَ محمدٌ: وَاحِدهَا دِسارٌ، مثل حمَار وحمر.</p></div>"
  54,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تجْرِي بأعيننا﴾</span> كَقَوْلِه: <span class="qpc-hafs">﴿إِنَّنِي مَعَكُمَا أَسْمَعُ وَأَرَى﴾</span>.</p><p><span class="qpc-hafs">﴿جَزَاء لمن كَانَ كفر﴾</span> جَزَاء لنوحٍ كفره قوْمُه، وجحدوا مَا جَاءَ بِهِ إنجاء اللَّه إِيَّاه فِي السَّفِينَة</p></div>"
  54,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَد تركناها آيَة﴾</span> لمن بعدهمْ، يَعْنِي: السَّفِينَة.</p><p>قَالَ محمدٌ: قَوْله: (آيَة) يَعْنِي: عَلامَة؛ ليعتبر بهَا.</p><p><span class="qpc-hafs">﴿فَهَلْ مِنْ مُدَّكِرٍ﴾</span> أَي: متفكر، يَأْمُرهُم أَن يعتبروا وَيَحْذَرُوا أَنْ يَنْزِلَ بِهِمْ مَا نزل بهم.</p><p>قَالَ محمدٌ: مُدَّكِر أَصله مذتكر مفتَعِل من الذِّكْرِ، فأدغمت الذَّال فِي التَّاء ثمَّ قلبت دَالا مشدودة.</p></div>"
  54,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكيف كَانَ عَذَابي وَنذر﴾</span> إنذاري أَي كَانَ شَدِيدا</p></div>"
  54,17,"<div class=ar lang=ar><p>(وَلَقَدْ يَسَّرْنَا الْقُرْآنَ لِلذِّكْرِ} لِيذكرُوا اللَّه <span class="qpc-hafs">﴿فَهَلْ مِن مُّدَّكِرٍ﴾</span> وَهِي مثل الأولى.</p></div>"
  54,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَّبَتْ عَادٌ﴾</span> أَي: فأهلكتهم <span class="qpc-hafs">﴿فَكَيْفَ كَانَ عَذَابِي وَنُذُرِ﴾</span> أَي: كَانَ شَدِيدا</p></div>"
  54,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا أَرْسَلْنَا عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</span> والصرصر: الْبَارِدَة الشَّدِيدَة الْبرد، وَهِي ريح الدَّبور <span class="qpc-hafs">﴿فِي يَوْمِ نَحْسٍ﴾</span> أَي: مشئوم <span class="qpc-hafs">﴿مُّسْتَمِرّ﴾</span> اسْتمرّ بِالْعَذَابِ، وَكَانَ ذَلِك من يَوْم الْأَرْبَعَاء إِلَى يَوْم الْأَرْبَعَاء.</p></div>"
  54,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَنَّهُمْ أَعْجَازُ نَخْلٍ مُّنقَعِرٍ﴾</span> شبّههم فِي طولهم وعظمتهم بالأعجاز، وَهِي النّخل الَّذِي قد انقلعت من أُصُولهَا فَسَقَطت على الأَرْض.</p><p>قَالَ مُحَمَّد: قَوْله: <span class="qpc-hafs">﴿منقعر﴾</span> قَالُوا: قعرتُ النَّخْلَة أَقْعَرُها - بِفَتْح الْعين - إِذا قطعتَها قَعْرًا. وقعَرْتُ الْبِئْر أَقْعِرُها - بكسْر الْعين - إِذا بلغت قعرها بنزول أَو حفر. وَالنَّخْل تذكر وتؤنث؛ يُقَال: هَذَا نخل وَهَذِه نخل، فمنقعر على من قَالَ: هَذَا نخلٌ، وَمن قَالَ هَذِه نخل مثل قَوْله. <span class="qpc-hafs">﴿كَأَنَّهُمْ أعجاز نخل خاوية﴾</span>.</p></div>"
  54,21,"<div class=ar lang=ar></div>"
  54,22,"<div class=ar lang=ar><p>وَمعنى <span class="qpc-hafs">﴿يَسَّرْنَا﴾</span> أَي: سهلنا، وَرُوِيَ أَن كتب أهل الْأَدْيَان نَحْو التَّوْرَاة وَالْإِنْجِيل إِنَّمَا يتلوها أَهلهَا (نظرا) وَلَا يكادون يحفظونها من أوَّلها إِلَى آخرهَا؛ كَمَا يحفظ القرآنُ.</p></div>"
  54,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذبت ثَمُود بِالنذرِ﴾</span> بالرسل</p></div>"
  54,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَالُوا أَبَشَرًا مِنَّا وَاحِدًا نَتَّبِعُهُ﴾</span> أَي: أنتَّبع بشرا منا وَاحِدًا <span class="qpc-hafs">﴿إِنَّا إِذا لفي ضلال﴾</span> فَلَا (نهتدي) (ل ٣٤٦) <span class="qpc-hafs">﴿وسعر﴾</span> أَي: وشقاء؛ فِي تَفْسِير مُجَاهِد.</p><p>قَالَ مُحَمَّد: قَوْله: (وسعر) أصل الْكَلِمَة من [سعرت] النَّار إِذا التهبت.</p><p><span class="qpc-hafs">﴿أَأُلْقِيَ عَلَيْهِ الذِّكْرُ مِن بَيْنِنَا﴾</span> على الِاسْتِفْهَام مِنْهُم، وَهَذَا الِاسْتِفْهَام على إِنْكَار أَي: لمْ ينزل الذّكر عَلَيْهِ من بَيْننَا يجحدون مَا جَاءَ بِهِ صَالح <span class="qpc-hafs">﴿بَلْ هُوَ كَذَّاب أشر﴾</span> من بَاب الأشر</p></div>"
  54,25,"<div class=ar lang=ar></div>"
  54,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سيعلمون غَدا﴾</span> يَعْنِي: يَوْم الْقِيَامَة <span class="qpc-hafs">﴿مَنِ الْكَذَّابُ الأشر﴾</span>.</p><p>قَالَ محمدٌ: الأَشِرُ فِي اللُّغَة: البَطِر المتكبر، يُقَال: أَشِرَ يأشَرُ أَشَرًا فَهُوَ أَشِر، وَقَالُوا أَيْضا: أَشْرَان وَامْرَأَة أشرى.</p></div>"
  54,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا مُرْسِلُوا النَّاقَةِ﴾</span> أَي: مخرجوها <span class="qpc-hafs">﴿فتْنَة لَهُم﴾</span> أَي: بلية <span class="qpc-hafs">﴿فارتقبهم﴾</span> أَي: انظرْ مَاذَا يصنعون <span class="qpc-hafs">﴿وَاصْطَبِرْ﴾</span> على مَا يصنعون وعَلى مَا يَقُولُونَ، أَي: إِذا جَاءَت النَّاقة. وَقد مضى تَفْسِير أَمر النَّاقة فِي سُورَة الشُّعَرَاء</p></div>"