quran[31]{c,v,t}:
  77,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمْ نَخْلُقْكُمْ مِنْ مَاءٍ مَهِينٍ﴾</span> ضَعِيف؛ يَعْنِي: النُّطْفَة</p></div>"
  77,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فجعلناه فِي قَرَار مكين﴾</span> الرَّحِم.</p></div>"
  77,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَى قدر مَعْلُوم﴾</span> الْيَوْمَ الَّذِي يُولَدُ فِيهِ الْمَخْلُوقُ</p></div>"
  77,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فقدرنا﴾</span> مَنْ قَرَأَهَا بِالتَّثْقِيلِ فَهِيَ مِنْ بَابِ التَّقْدِيرِ، وَمَنْ قَرَأَهَا مُخَفَّفَةً فَمِنْ بَابِ الْقُدْرَةِ <span class="qpc-hafs">﴿فَنِعْمَ الْقَادِرُونَ﴾</span></p></div>"
  77,24,"<div class=ar lang=ar></div>"
  77,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألم نجْعَل الأَرْض كفاتا﴾</span> تَكْفِتُهُمْ، أَيْ: تَضُمُّهُمْ، والكفتُ: الضمُّ وَالْجمع</p></div>"
  77,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحيَاء وأمواتا﴾</span> أَيْ: يَكُونُونَ عَلَى ظَهْرِهَا أَحْيَاءً، وَيَكُونُونَ فِي بَطْنِهَا أَمْوَاتًا.</p><p>قَالَ مُحَمَّدٌ: تَقُولُ: كَفَتُّ الشَّيْءَ أَكْفِتُه وَتَقُولُ: أَكْفِتْ إِلَيْكَ كَذَا، أَيْ: ضُمَّه، وَكَانُوا يُسَمُّونَ الْمَقْبُرَةَ كَفْتَةً؛ لِأَنَّهَا تضمُّ الْمَوْتَى.</p></div>"
  77,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلنَا فِيهَا رواسي شامخات﴾</span> يَعْنِي: الْجِبَالَ الْمُرْتَفِعَةَ <span class="qpc-hafs">﴿وَأَسْقَيْنَاكُمْ مَاءً فراتا﴾</span> عذبًا</p></div>"
  77,28,"<div class=ar lang=ar></div>"
  77,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿انْطَلِقُوا إِلَى مَا كُنْتُمْ بِهِ تكذبون﴾</span> يُقَالُ لَهُمْ يَوْمَ الْقِيَامَةِ: انْطَلِقُوا إِلَى مَا كُنْتُمْ بِهِ تُكَذِّبُونَ فِي الدُّنْيَا من الْعَذَاب.</p></div>"
  77,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿انْطَلِقُوا إِلَى ظِلٍّ ذِي ثَلاثِ شعب﴾</span> يَخْرُجُ مِنَ النَّارِ لِسَانَانِ قَبْلَ أَنْ يَدْخُلُوا النَّارَ فَيُحِيطُ بِالْمُشْرِكِينَ، ثُمَّ يَسْطَعُ مِنَ النَّارِ دخانٌ أَسْوَدٌ، ثُمَّ يَصِيرُ ثَلاثَ فِرَقٍ؛ فَيَلْجَئُونَ إِلَيْهِ يَرْجُونَ أَنْ يُظِلَّهُمْ مِنْ شِدَّةِ حَرِّ النَّارِ، فَلا يُظِلُّهُمْ وَيَجِدُونَ مِنْهُ مِنَ الْحَرِّ مِثْلَ مَا وَجَدُوا قَبْلَ أَنْ يلجئوا إِلَيْهِ</p></div>"
  77,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا ظَلِيلٍ وَلا يُغْنِي مِنَ اللهب﴾</span> أَيْ: لَا بَارِدٍ فِي الظِّلِ وَلَا كريم فِي الْمنزل</p></div>"
  77,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهَا ترمي﴾</span> يَعْنِي: النَّار <span class="qpc-hafs">﴿بشرر كالقصر﴾</span> يَعْنِي: قصْرًا مِنَ الْقُصُورِ فِي قِرَاءَةِ مَنْ قَرَأَهَا بِجَزْمِ الصَّادِ</p></div>"
  77,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَنَّهُ جِمَالاتٌ صُفْرٌ﴾</span> يَعْنِي: النُّوقَ السُّودَ فِي قِرَاءَةِ مَنْ قَرَأَهَا بِكَسْرِ الْجِيمِ.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ لِلْإِبِلِ الَّتِي هِيَ سودٌ تَضْرِبُ إِلَى الصُّفرة: إِبِلٌ صُفْرٌ وجمالاتٌ بِكَسْر الْجِيم جمع جمال.</p></div>"
  77,34,"<div class=ar lang=ar></div>"
  77,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذَا يَوْم لَا ينطقون﴾</span> بحُجّة</p></div>"
  77,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُؤذن لَهُم فيعتذرون﴾</span> وَقَدْ يُؤْذَنُ لَهُمْ فِي الْكَلامِ فِي بعض المواطن، ولايؤذن لَهُمْ فِي بَعْضٍ؛ فَإِذَا أُذِنَ لَهُمْ فِي الْكَلامِ لَمْ يَعْتَذِرُوا بِعُذْرٍ.</p><p>قَالَ مُحَمَّدٌ: يُقْرَأُ (يومُ) بِالرَّفْعِ والنَّصْبِ؛ فَمَنْ نَصَبَ جَعَلَهُ ظَرْفًا بِمَعْنَى: هَذَا الْوَعِيدُ يَوْمًا، وَمَنْ رَفَعَ جَعَلَ هَذَا لِلْيَوْمِ؛ كَمَا تَقول هَذَا يَوْمك.</p></div>"
  77,37,"<div class=ar lang=ar></div>"
  77,38,"77:37"
  77,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِن كَانَ لكم كيد﴾</span> تَنْجُوْنَ بِهِ مِنْ عَذَابِ اللَّهِ <span class="qpc-hafs">﴿فكيدون﴾</span> أَيْ: أَنَّكُمْ لَا تَقْدِرُونَ عَلَى ذَلِك.</p></div>"
  77,40,"<div class=ar lang=ar></div>"
  77,41,"77:40"
  77,42,"77:40"
  77,43,"77:40"
  77,44,"77:40"
  77,45,"77:40"
  77,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كلوا وتمتعوا﴾</span> الْآيَةُ يَقُولُهُ لِلْمُشْرِكِينَ وَعِيدًا لَهُمْ، وَانْقَطَعَتِ القَّصة الْأُولَى مِنْ أَمْرِ أهل النَّار.</p></div>"
  77,47,"<div class=ar lang=ar></div>"
  77,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا قيل لَهُم ارْكَعُوا﴾</span> أَيْ: صلُّوا <span class="qpc-hafs">﴿لَا يَرْكَعُونَ﴾</span></p></div>"
  77,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأَيِّ حَدِيثٍ بعده﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿يُؤمنُونَ﴾</span>.</p><p>يَحْيَى: عَنْ إِبْرَاهِيمَ، عَنْ إِسْمَاعِيلَ بْنِ أُمَيَّةَ، عَنْ أَبِي الْيَسَعِ، عَنْ أَبِي هُرَيْرَةَ قَالَ: «إِذَا خَتَمَ أَحَدُكُمْ وَالْمُرْسَلاتِ فَلَيَقُلْ: آمَنَتُ بِاللَّهِ وَبِمَا أَنْزَلَ» مِنْ حَدِيثِ يَحْيَى بْنِ مُحَمَّدٍ.</p></div>"
  77,50,"<div class=ar lang=ar></div>"