quran[24]{c,v,t}:
  37,1,"<div class=ar lang=ar><p>تَفْسِير سُورَة الصافات وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿وَالصَّافَّات صفا﴾</span> قَالَ قَتَادَة: يَعْنِي: صُفُوف الْمَلَائِكَة.</p><p>يَحْيَى: عَنْ إِبْرَاهِيمَ بْنِ مُحَمَّدٍ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ قَالَ: قَالَ رَسُولُ اللَّهِ ﷺ: " أَطَّتِ السَّمَاءُ وَحُقَّ لَهَا أَنْ تَئِطَّ، لَيْسَ فِيهَا مَوْضِعُ شِبْرٍ إِلا وَعَلَيْهَا مَلَكٌ قَائِمٌ أَوْ رَاكِعٌ أَوْ سَاجِدٌ ".</p><p>قَالَ مُحَمَّد: الأطيط: الصَّوْت.</p></div>"
  37,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فالزاجرات زجرا﴾</span> يَعْنِي: الْمَلَائِكَة، وَمِنْهُم الرَّعْد الْملك الَّذِي يزجُر السَّحَاب؛ وَقَالَ فِي آيَة أُخْرَى: <span class="qpc-hafs">﴿فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَة﴾</span> يَعْنِي: النفخة الْآخِرَة ينفخها صَاحب الصُّور</p></div>"
  37,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فالتاليات ذكرا﴾</span> الْمَلَائِكَة تتلو الْوَحْي الَّذِي تَأتي بِهِ الْأَنْبِيَاء؛ أقسم بِهَذَا كُله</p></div>"
  37,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن إِلَهكُم لوَاحِد رب السَّمَاوَات وَالأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ الْمَشَارِقِ﴾</span> تَفْسِير قَتَادَة قَالَ: هِيَ ثَلَاثمِائَة وَسِتُّونَ مشرقاً، وثلاثمائة وَسِتُّونَ مغرباً.</p></div>"
  37,5,"<div class=ar lang=ar></div>"
  37,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا زَيَّنَّا السَّمَاءَ الدُّنْيَا بِزِينَةٍ الْكَوَاكِب وحفظا﴾</span> أَي: وجعلناها يَعْنِي: الْكَوَاكِب حِفْظًا للسماء</p></div>"
  37,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿من كل شَيْطَان مارد﴾</span> أَي: مجترئ على الْمعْصِيَة</p></div>"
  37,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يسمعُونَ﴾</span> أَي: لِئَلَّا يسمعُونَ <span class="qpc-hafs">﴿إِلَى الْمَلإِ الْأَعْلَى﴾</span> يَعْنِي: الْمَلَائِكَة فِي السَّمَاء، وَكَانُوا يسمعُونَ قبل أَن يُبْعث النَّبِيّ ﷺ أَخْبَارًا مِنْ أَخْبَارِ السَّمَاءِ، فَأَمَّا الْوَحْيُ فَلَمْ يَكُونُوا يَقْدِرُونَ عَلَى أَنْ يسمعوه <span class="qpc-hafs">﴿ويقذفون﴾</span> أَي: يُرْمَوْن <span class="qpc-hafs">﴿مِنْ كُلِّ جَانِبٍ﴾</span></p></div>"
  37,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دحورا﴾</span> أَي: طَرْدًا <span class="qpc-hafs">﴿وَلَهُمْ عَذَابٌ وَاصِبٌ﴾</span> أَي: دَائِم</p></div>"
  37,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا مَنْ خَطِفَ الْخَطْفَةَ فَأَتْبَعَهُ﴾</span> أَي: لحقه <span class="qpc-hafs">﴿شهَاب ثاقب﴾</span> مضيء، رَجَعَ إِلَى أول الْكَلَام <span class="qpc-hafs">﴿وَحِفْظًا مِنْ كُلِّ شَيْطَانٍ مَارِدٍ لَا يَسَّمَّعُونَ إِلَى الْمَلإِ الأَعْلَى﴾</span>.</p><p><span class="qpc-hafs">﴿إِلَّا من خطف الْخَطفَة﴾</span> يَعْنِي: اسْتمع الاستماعة.</p><p>قَالَ ابْن عَبَّاس: إِذا رَأَيْتُمْ الْكَوْكَب قد رُمِيَ بِهِ فتوارى؛ فَإِنَّهُ يَحْرق مَا أصَاب وَلَا يقتل.</p></div>"
  37,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاستفتهم﴾</span> يَعْنِي: الْمُشْركين، أَي: فاسألهم عَلَى الِاسْتِفْهَام؛ يُحاجُّهم بذلك <span class="qpc-hafs">﴿أَهُمْ أَشَدُّ خلقا أم من خلقنَا﴾</span> أم السَّمَاء أَي: أَنَّهَا أَشد خلقا مِنْهُم <span class="qpc-hafs">﴿إِنَّا خَلَقْنَاهُمْ مِنْ طين لازب﴾</span> واللازبُ: الَّذِي يلصقُ بِالْيَدِ؛ يَعْنِي: خلق آدم.</p><p>قَالَ محمدٌ: يُقَال: لازب ولازم، بِمَعْنى وَاحِد.</p></div>"
  37,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل عجبت﴾</span> يَا محمدُ أَن أَعْطَيْت هَذَا الْقُرْآن <span class="qpc-hafs">﴿ويسخرون﴾</span> يَعْنِي: الْمُشْركين</p></div>"
  37,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا ذكرُوا﴾</span> بِالْقُرْآنِ <span class="qpc-hafs">﴿لَا يذكرُونَ﴾</span> (ل ٢٨٧)</p></div>"
  37,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا رَأَوْا آيَة﴾</span> إِذا تليت عَلَيْهِم آيَة <span class="qpc-hafs">﴿يَسْتَسْخِرُونَ﴾</span> من السخرية</p></div>"
  37,15,"<div class=ar lang=ar></div>"
  37,16,"37:15"
  37,17,"37:15"
  37,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل نعم وَأَنْتُم داخرون﴾</span> أَي: صاغرون</p></div>"
  37,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّمَا هِيَ زَجْرَة وَاحِدَة﴾</span> النفخة الْآخِرَة <span class="qpc-hafs">﴿فَإِذَا هُمْ يَنْظُرُونَ﴾</span> أَي: خَرجُوا من قُبُورهم [ينظرُونَ].</p></div>"
  37,20,"<div class=ar lang=ar></div>"
  37,21,"37:20"
  37,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿احشروا﴾</span> أَي: سوقوا <span class="qpc-hafs">﴿الَّذين ظلمُوا﴾</span> أشركوا <span class="qpc-hafs">﴿وَأَزْوَاجَهُمْ﴾</span> قَالَ الْحَسَنُ: يَعْنِي: الشَّيَاطِينَ الَّذِينَ دَعَوْا إِلَى عبَادَة الْأَوْثَان.</p><p>قَالَ محمدٌ: تَقُولُ الْعَرَب: زوّجْتُ إبلي إِذا قرنت وَاحِدًا بآخر.</p></div>"
  37,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاهدوهم﴾</span> أَي: ادعوهُمْ <span class="qpc-hafs">﴿إِلَى صِرَاط﴾</span> طَرِيق <span class="qpc-hafs">﴿الْجَحِيم﴾</span> والجحيم اسْم من أَسمَاء جهنّم</p></div>"
  37,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وقفوهم﴾</span> أَي: احبسوهم، وَهَذَا قبل أَن يدخلُوا النَّار <span class="qpc-hafs">﴿إِنَّهُم مَّسْئُولُونَ﴾</span> عَن لَا إِلَه إِلَّا اللَّه.</p><p>قَالَ محمدٌ: يُقَال: وقفت الدَّابَّة وَقْفًا ووقُوفًا، وَمن هَذَا الْمَعْنى قَوْله: <span class="qpc-hafs">﴿وقفوهم﴾</span> وَيُقَال: أوقفتُ الرجل عَلَى الْأَمر إيقافاً.</p></div>"