quran[14]{c,v,t}:
  23,105,"<div class=ar lang=ar></div>"
  23,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا رَبَّنَا غَلَبَتْ عَلَيْنَا شِقْوَتُنَا﴾</span> الَّتِي كتبت علينا</p></div>"
  23,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَبَّنَا أَخْرِجْنَا مِنْهَا فَإِنْ عُدْنَا فَإنَّا ظَالِمُونَ﴾</span> فَيَسْكُتْ عَنْهُمْ قَدْرَ عُمُرِ الدُّنْيَا مرَّتَيْنِ،</p></div>"
  23,108,"<div class=ar lang=ar><p>ثُمَّ يَرُدُّ عَلَيْهِمْ <span class="qpc-hafs">﴿اخْسَئُوا فِيهَا وَلَا تكَلمُون﴾</span> أَيْ: اصْغَرُوا؛ فِي تَفْسِيرِ الْحَسَنِ. قَالَ: فَوَاللَّهِ مَا تَكَلَّمَ الْقَوْمُ بَعْدَهَا بِكَلِمَةٍ، وَمَا هُوَ إِلَّا الزَّفِيرُ وَالشَّهِيقُ.</p><p>قَالَ مُحَمَّدٌ: مَعْنَى <span class="qpc-hafs">﴿اخْسَئُوا﴾</span> فِي اللُّغَةِ: تَبَاعَدُوا، وَيُقَالُ: خَسَأْتُ الْكَلْبَ أَخْسَؤُهُ؛ إِذَا زَجَرْتُهُ لِيَتَبَاعَدَ.</p></div>"
  23,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنت خير الرَّاحِمِينَ﴾</span> يَعْنِي: أَفْضَلُ مَنْ رَحِمْ، وَقَدْ يَجْعَلُ اللَّهُ الرَّحْمَةَ فِي قَلْبِ مَنْ يَشَاءُ؛ وَذَلِكَ مِنْ رَحْمَةِ الله.</p></div>"
  23,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاتخذتموهم سخريا﴾</span> كَانُوا يَسْخَرُونَ بِأَصْحَابِ الْأَنْبِيَاءِ، وَيَضْحَكُونَ مِنْهُمْ.</p><p>قَالَ مُحَمَّدٌ: الْأَجْوَدُ فِي قِرَاءَةِ (اتَّخَذْتُمُوهُمْ) إْدَغْامُ الذَّالِ فِي التَّاءِ؛ لِقُرْبِ الْمَخْرَجَيْنِ فِي الذَّالِ وَالتَّاءِ، وَإِنْ شِئْتَ أَظْهَرْتَ. وَتُقْرَأُ (سُخْرِيًّا) بِالضَّمِّ وَالْكَسْرِ فِي مَعْنَى الِاسْتِهْزَاءِ، وَقَدْ قَالَ بَعْضُ أَهْلِ اللُّغَةِ: مَا كَانَ مِنَ الِاسْتِهْزَاءِ فَهُوَ بِالْكَسْرِ، وَمَا كَانَ مِنْ جِهَةِ التَّسْخِيرِ فَهُوَ بِالضَّمِّ. <span class="qpc-hafs">﴿حَتَّى أَنْسَوْكُمْ ذِكْرِي﴾</span> لَيْسَ يَعْنِي: أَنَّ أَصْحَابِ الْأَنْبِيَاءِ أَنْسَوْهُمْ ذَكَرَ اللَّهِ؛ فَأَمَرُوهُمْ أَلَّا يذكروه، وَلَكِن جحودهم واستهزاؤهم، وَضَحِكُهُمْ مِنْهُمْ هُوَ الَّذِي أَنْسَاهُمْ ذكر الله.</p></div>"
  23,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنِّي جَزَيْتُهُمُ الْيَوْمَ بِمَا صَبَرُوا﴾</span> فِي الدُّنْيَا <span class="qpc-hafs">﴿إِنَّهُم﴾</span> بِأَنَّهُم <span class="qpc-hafs">﴿هم الفائزون﴾</span> النَّاجُونَ مِنَ النَّارِ، وَتُقْرَأُ بِالْكَسْرِ <span class="qpc-hafs">﴿إِنَّهُمْ﴾</span>.</p><p>قَالَ مُحَمَّدٌ: وَمَنْ كَسَرَ فَالْمَعْنَى: أَنِّي جَزَيْتُهُمْ بِمَا صَبَرُوا، ثمَّ أخبر فَقَالَ: إِنَّهُم هُوَ الفائزون.</p></div>"
  23,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ كم لبثتم﴾</span> يَقُولُهُ لَهُمْ فِي الْآخِرَةِ <span class="qpc-hafs">﴿فِي الأَرْض عدد سِنِين﴾</span> أَيْ: كَمْ عَدَدَ السِّنِينَ الَّتِي لَبِثْتُمْ فِي الْأَرْضِ [يُرِيدُ بِذَلِكَ أَن يعلمهُمْ قلَّة] (ل ٢٣٠) بَقَائِهِمْ فِي الدُّنْيَا [فَتَصَاغَرَتِ الدُّنْيَا] عِنْدهم</p></div>"
  23,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا لَبِثْنَا يَوْمًا أَوْ بَعْضَ يَوْم﴾</span> وَذَلِكَ لِتَصَاغُرِ الدُّنْيَا عِنْدَهُمْ <span class="qpc-hafs">﴿فَاسْأَلِ العادين﴾</span> قَالَ قَتَادَةُ: يَعْنِي: الْحُسَّابَ الَّذِينَ كَانُوا يَحْسِبُونَ آجَالَنَا. مِثْلَ قَوْلِهِ: <span class="qpc-hafs">﴿إِنَّمَا نعد لَهُم عدا﴾</span> وَهِي آجالهم</p></div>"
  23,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ إِنْ لَبِثْتُمْ إِلا قَلِيلا﴾</span> أَيْ: إِنَّ لُبْثَكُمْ فِي الدُّنْيَا فِي طُولِ مَا أَنْتُمْ لَابِثُونَ فِي النَّارِ كَانَ قَلِيلًا <span class="qpc-hafs">﴿لَوْ أَنَّكُمْ كُنْتُم تعلمُونَ﴾</span> يَقُولُ: لَوْ أَنَّكُمْ كُنْتُمْ عُلَمَاءَ لَمْ تَدْخُلُوا النَّارَ.</p><p>قَالَ مُحَمَّدٌ: (عدد) مَنْصُوبٌ بِكَمْ، وَقَوْلُهُ: <span class="qpc-hafs">﴿إِنْ لَبِثْتُمْ﴾</span> مَعْنَاهُ: مَا لبثتم.</p></div>"
  23,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أفحسبتم أَنما خَلَقْنَاكُمْ عَبَثا﴾</span> أَيْ: لِغَيْرِ بَعْثٍ وَلَا حِسَابٍ <span class="qpc-hafs">﴿وأنكم إِلَيْنَا لَا ترجعون﴾</span> وَهُوَ عَلَى الِاسْتِفْهَامِ؛ أَيْ: قَدْ حَسِبْتُمْ ذَلِكَ؛ وَلَمْ نَخْلُقْكُمْ عَبَثًا، إِنَّمَا خَلَقْنَاكُمْ للبعث والحساب</p></div>"
  23,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَعَالَى اللَّهُ الْمَلِكُ الْحَقُّ لَا إِلَهَ إِلا هُوَ رَبُّ الْعَرْشِ الْكَرِيم﴾</span> عَلَى اللَّهِ. وَبَعْضُهُمْ يَقْرَؤُهَا بِالرَّفْعِ يَقُول: الله الْكَرِيم.</p></div>"
  23,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنْ يَدْعُ مَعَ اللَّهِ إِلَهًا آخَرَ لَا بُرْهَانَ لَهُ بِهِ﴾</span> أَيْ: لَا حُجَّةَ لَهُ بِذَلِكَ <span class="qpc-hafs">﴿فَإِنَّمَا حسابه عِنْد ربه﴾</span> يَعْنِي: فَإِنَّمَا جَزَاؤُهُ عِنْدَ رَبِّهِ <span class="qpc-hafs">﴿إِنَّه لَا يفلح الْكَافِرُونَ﴾</span> وَهِي تقْرَأ: (إِنَّه) بِالْكَسْرِ عَلَى مَعْنَى: فَإِنَّمَا حِسَابُهُ عِنْدَ رَبَّهِ أَنْ يُدْخِلَهُ النَّارَ، ثُمَّ قَالَ: <span class="qpc-hafs">﴿إِنَّهُ لَا يُفْلِحُ الْكَافِرُونَ﴾</span>.</p><p>قَالَ مُحَمَّدٌ: وَمَنْ قَرَأَهَا بِالْفَتْحِ، فَالْمَعْنى: بِأَنَّهُ.</p></div>"
  23,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقُلْ رَبِّ اغْفِرْ وَارْحَمْ وَأَنْتَ خير الرَّاحِمِينَ﴾</span> يَعْنِي: وَأَنْتَ أَفْضَلُ مَنْ يَرْحَمُ؛ أَمر الله النَّبِي عَلَيْهِ السَّلَام بَهَذَا الدُّعَاءِ.</p></div>"