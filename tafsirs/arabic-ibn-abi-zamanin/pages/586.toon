quran[29]{c,v,t}:
  81,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ إِذَا الشَّمْسُ كُوِّرت وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿إِذا الشَّمْس كورت﴾</span> تَفْسِيرُ الْحَسَنِ يَعْنِي: ذَهَبَ ضَوْؤُها. قَالَ محمدٌ: (كُوِّرت) حقيقتُه: جُمِعَ ضَوْؤها، وَمِنْ كَلامِهِمْ: كُرْتُ الْعِمَامَةُ عَلَى رَأْسِي أكورُها وكَوَّرْتُها أُكَوِّرُها إِذَا لَفَفْتها وَهُوَ الَّذِي أَرَادَ الْحسن</p></div>"
  81,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا النُّجُوم انكدرت﴾</span> انتثرت</p></div>"
  81,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الْجبَال سيرت﴾</span> تَذْهَبُ تَصِيرُ فِي حَالاتٍ أَمَّا أَوَّلُ مَا تُحوَّلُ عَنْ مَنْزِلَةِ الْحِجَارَةِ، فَتَكُونُ كَثِيبًا، وَتَكُونُ كَالْعِهْنِ الْمَنْفُوشِ، وَتَكُونُ هَبَاءً مُنْبَثًّا، وَتَكُونُ سَرَابًا؛ مِثْلُ هَذَا السَّرَابِ تَرَاهُ وَلَيْسَ بِشَيْء.</p></div>"
  81,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا العشار عطلت﴾</span> وَهِيَ النُّوقُ عطَّلها أَهْلُهَا فَلَمْ تُحْلَب من الشُّغل بِأَنْفسِهِم.</p><p>(ل ٣٨٧) قَالَ مُحَمَّدٌ: (العِشارُ) مِنَ الْإِبِلِ: الْحَوَامِلُ، وَاحِدُهَا: عشَراءُ، وَهِيَ الَّتِي أَتَى عَلَيْهَا فِي الْحَبَلِ عَشْرَةُ أَشْهُرٍ، ثُمَّ يَزَالُ ذَلِكَ اسْمُهَا حَتَّى تضع وَبَعْدَمَا تضع.</p></div>"
  81,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الوحوش حشرت﴾</span> جُمِعَتْ؛ لِيَقْتَصَّ لِبَعْضِهَا مِنْ بَعْضٍ ثُمَّ يُقَالُ لَهَا: كُونِي تُرَابًا</p></div>"
  81,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الْبحار سجرت﴾</span> قَالَ الْحَسَنُ: يَعْنِي: فَاضَتْ.</p><p>قَالَ مُحَمَّدٌ: سُجِّرت حَقِيقَتُهُ: مُلِئَت، فَيُفْضِي بَعْضُهَا إِلَى بَعْضٍ فَتَصِيرُ شَيْئًا وَاحِدًا؛ وَهُوَ مَعْنَى قَوْلِ الْحَسَنِ.</p></div>"
  81,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا النُّفُوس زوجت﴾</span> تَفْسِيرُ الْحَسَنِ: أَيْ: تَلْحَقُ كُلُّ شِيعَةٍ بِشِيعَتِهَا: الْيَهُودُ بِالْيَهُودِ، وَالنَّصَارَى بِالنَّصَارَى، وَالْمَجُوسُ بِالْمَجُوسِ، وَكُلُّ مَنْ كَانَ يَعْبُدُ مِنْ دُونِ اللَهِ شَيْئا بضهم ببعضهم، والمنافقون بالمنافقات، والمؤمنون بالمؤمنات.</p></div>"
  81,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الموءدة سُئلت﴾</span> وَهِيَ بَنَاتُ أَهْلِ الْجَاهِلِيَّةِ كَانُوا يدفنونهنَّ أَحْيَاءً، لِخَصْلَتَيْنِ: أَمَّا إِحْدَاهُمَا فَكَانُوا يَقُولُونَ: إِنَّ الْمَلائِكَةَ بناتُ اللَّهِ، فَأَلْحِقُوا الْبَنَاتِ بِهِ فَهُوَ أحقُّ بِهِنَّ، وَأَمَّا الْخَصْلَةُ الأُخْرَى: فمخافة الْحَاجة.</p></div>"
  81,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَيّ ذَنْب قتلت﴾</span> قَالَ الْحَسَنُ: أَرَادَ اللَّهُ أَنْ يوبِّخ قَاتِلَهَا؛ لِأَنَّهَا قُتِلت بِغَيْرِ ذَنْبٍ فسُئلتْ فَلَمْ يُوجَدْ لَهَا ذَنْب، وَبَعْضهمْ يقْرَأ: (وَإِذا الموءدةُ سَأَلَتْ بِأَيِّ ذَنْبٍ قُتِلَتْ)؛ فَتَتَعَلَّقُ الْجَارِيَةُ بِأَبِيهَا، فَتَقُولُ: بِأَيِّ ذَنْبٍ قَتَلْتَنِي؟! قَالَ مُحَمَّدٌ: يُقَالُ وأدتُ المولودَ إِذَا دَفَنْتُهُ حَيًّا، فَأَنَا وائدٌ، والمصدر إدَةً.</p></div>"
  81,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الصُّحُف نشرت﴾</span> لِلْحِسَابِ وَهُوَ مَا كَتَبَتِ الْمَلائِكَةُ على الْعباد من أعماهم</p></div>"
  81,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا السَّمَاء كشطت﴾</span> أَيْ: طُوِيَتْ وَقَالَ مُجَاهِدٌ: يَعْنِي: اجتبذت. قَالَ مُحَمَّدٌ: يُقَالُ كَشَطْتُ السَّقْفَ أَيْ: قَلَعْتُهُ، فَكَأَنَّ الْمَعْنَى: قُلِعَت فطُويت.</p></div>"
  81,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الْجَحِيم سعرت﴾</span> أُوقِدَتْ، وَهِيَ تُوقَدُ مُنْذُ خُلِقَتْ السَّمَوَات وَالْأَرْض فِي السِّتَّة الْأَيَّام</p></div>"
  81,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الْجنَّة أزلفت﴾</span> أدنيتْ</p></div>"
  81,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿علمت نفس مَا أحضرت﴾</span> من عَملهَا.</p></div>"
  81,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا أقسم﴾</span> الْمَعْنى: فأقسم «وَلَا» صلَة <span class="qpc-hafs">﴿بالخنس﴾</span> تَفْسِيرُ الْحَسَنِ: هِيَ النُّجُومُ تخنِسُ؛ بِالنَّهَارِ أَيْ: تَتَوَارَى، وَهِيَ فِي ذَلِك جَارِيَة</p></div>"
  81,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الْجَوَارِي﴾</span> يَعْنِي: جَرْيَهَا فِي السَّمَاءِ <span class="qpc-hafs">﴿الْكُنَّسِ﴾</span> تَفْسِيرُ الْكَلْبِيِّ: يَعْنِي: أَنَّهَا تُكْنَسُ بِالنَّهَارِ كَمَا تَتَوَارَى الظِّبَاءُ فِي كِنَاسِها</p></div>"
  81,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاللَّيْل إِذا عسعس﴾</span> تَفْسِيرُ الْحَسَنِ: إِذَا أَظْلَمَ.</p><p>قَالَ مُحَمَّدٌ ": قَالَ قَوْمٌ: عَسْعَسَ اللَّيْل إِذَا أَظْلَمَ، وَقِيلَ: عَسْعَسَ أَدْبَرَ، وَأَنْشَدَ بَعْضُهُمْ:</p><p>(حَتَّى إِذَا الصُّبْحُ لَهَا تَنَفَّسَا ... وَانْجَابَ عَنْهَا لَيْلُهَا وعسعسا)</p></div>"
  81,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الصُّبْح إِذا تنفس﴾</span> إِذَا أَضَاءَ أَقْسَمَ بِهَذَا كُلِّهِ</p></div>"
  81,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّه لقَوْل رَسُول كريم﴾</span> يَعْنِي: جِبْرِيلَ يُرْسِلُهُ اللَّهُ إِلَى النَّبِيين</p></div>"
  81,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِي قُوَّةٍ عِنْدَ ذِي الْعَرْشِ مكين﴾</span> فِي الْمنزلَة والقربة</p></div>"
  81,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُطَاع ثمَّ﴾</span> يَعْنِي: فِي السَّمَاءِ. قَالَ الْحَسَنُ أَمَرَ اللَّهُ أَهْلَ السَّمَاءِ بِطَاعَةِ جِبْرِيلَ، كَمَا أَمَرَ أَهْلَ الْأَرْضِ أَن يطيعوا مُحَمَّدًا <span class="qpc-hafs">﴿امين﴾</span> عِنْد الله وَعند الْمَلَائِكَة.</p></div>"
  81,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا صَاحبكُم بمجنون﴾</span> يَعْنِي: مُحَمَّدا ﷺ وَذَلِكَ لِقَوْلِ الْمُشْرِكِينَ إِنَّهُ مَجْنُونٌ</p></div>"
  81,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَد رَآهُ بالأفق الْمُبين﴾</span> يَعْنِي: الْمَشْرِقَ الَّذِي مِنْهُ مَطَالِعُ النُّجُومِ وَالشَّمْسِ وَالْقَمَرِ، يَعْنِي أَنَّ مُحَمَّدًا رَأَى جِبْرِيلَ فِي صُورَتِهِ مَعَ الْأُفُقِ فَسَدَّ مَا بَيْنَ السَّمَاء وَالْأَرْض</p></div>"
  81,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا هُوَ على الْغَيْب﴾</span> الْوَحْي <span class="qpc-hafs">﴿بضنين﴾</span> بِبَخِيلٍ يَبْخَلُ عَلَيْكُمْ بِهِ، وَبَعْضُهُمْ يقْرَأ (بظنين) أَي: بمتهم</p></div>"
  81,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا هُوَ﴾</span> يَعْنِي: الْقُرْآنَ <span class="qpc-hafs">﴿بِقَوْلِ شَيْطَانٍ رَجِيمٍ﴾</span> مَلْعُون</p></div>"
  81,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَيْنَ تذهبون﴾</span> تعدلون عَنهُ يَقُوله للْمُشْرِكين</p></div>"
  81,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ان هُوَ﴾</span> يَعْنِي: مَا هُوَ، أَيْ: مَا الْقُرْآن <span class="qpc-hafs">﴿إِلَّا ذكر للْعَالمين﴾</span> يَعْنِي: مَنْ آمَنَ بِهِ يَذْكُرُونَ بِهِ الْآخِرَة</p></div>"
  81,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَنْ شَاءَ مِنْكُمْ أَنْ يَسْتَقِيمَ﴾</span> على أَمر الله والتذكرة</p></div>"
  81,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تَشَاءُونَ إِلا أَنْ يَشَاءَ الله رب الْعَالمين﴾</span>.</p></div>"