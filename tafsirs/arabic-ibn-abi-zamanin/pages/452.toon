quran[29]{c,v,t}:
  37,154,"<div class=ar lang=ar><p>[<span class="qpc-hafs">﴿مَا لكم كَيفَ تحكمون﴾</span> يُرِيد: هَكَذَا تحكمون؟! تَجْعَلُونَ لأنفسكم الْبَنِينَ، وتجعلون لله الْبَنَات</p></div>"
  37,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفلا تذكرُونَ﴾</span> يُرِيد: تتعظون] <span class="qpc-hafs">﴿أَمْ لَكُمْ سُلْطَانٌ مُبين﴾</span> حجَّة بَيِّنَة.</p></div>"
  37,156,"<div class=ar lang=ar></div>"
  37,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأتوا بِكِتَابِكُمْ﴾</span> الَّذِي فِيهِ حجتكم <span class="qpc-hafs">﴿إِنْ كُنْتُمْ صَادِقين﴾</span> إِنَّ الْمَلَائِكَةَ بَنَاتُ اللَّهِ؛ أَيْ: لَيْسَ لكم بذلك حجَّة</p></div>"
  37,158,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلُوا بَيْنَهُ وَبَيْنَ الْجِنَّةِ نَسَبًا﴾</span> تَفْسِير بَعضهم: يَقُولُ: قَالَ مشركو الْعَرَب: إِنَّه صاهر إِلَى الْجِنّ، وَالْجِنّ صنف من الْمَلَائِكَة، فَكَانَت لَهُ مِنْهُم بَنَات <span class="qpc-hafs">﴿وَلَقَدْ عَلِمَتِ الْجنَّة إِنَّهُم لمحضرون﴾</span> [يُرِيد: لمعذبهم عَلَى هَذَا]؛ أَي: مدخلون فِي النَّار</p></div>"
  37,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبْحَانَ الله﴾</span> ينزه نَفسه <span class="qpc-hafs">﴿عَمَّا يصفونَ﴾</span> [عَمَّا يَقُولُونَ من الْكَذِب] (إِلاَ عِبَادَ اللَّهِ الْمُخْلَصِينَ. وَهَذَا من مقاديم الْكَلَام وَلَقَدْ علمت الْجنَّة إِنَّهُم لَمُحْضَرُونَ إِلا عِبَادَ اللَّهِ الْمُخْلَصِينَ، سُبْحَانَ اللَّهِ عَمَّا يَصِفُونَ</p></div>"
  37,160,"<div class=ar lang=ar><p>[<span class="qpc-hafs">﴿إِلَّا عباد الله المخلصين﴾</span> يُرِيد: الْمُوَحِّدين، يُرِيد: أَصْحَاب النَّبِيّ ﷺ وَمن آمن مثلهم].</p></div>"
  37,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّكُمْ وَمَا تَعْبُدُونَ﴾</span> <span class="qpc-hafs">﴿ل ٢٩١﴾</span> الْآيَة، يَقُول: <span class="qpc-hafs">﴿فَإِنَّكُم﴾</span> يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿وَمَا تَعْبدُونَ﴾</span> يَعْنِي: مَا عبدُوا [يُرِيد: فَإِنَّكُم وآلهتكم الَّتِي تَعْبدُونَ من دون الله]</p></div>"
  37,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا أَنتُمْ عَلَيْهِ﴾</span> على مَا تَعْبدُونَ [<span class="qpc-hafs">﴿بِفَاتِنِينَ﴾</span> يُرِيد: مَا تقدرون لَا أَنْتُم، وَلَا من تَعْبدُونَ أَن تضلوا أحدا من عبَادي إِلَّا من كَانَ فِي سَابق علمي وقضائي وقدرتي]</p></div>"
  37,163,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلاَ مَنْ هُوَ صَالِ الْجَحِيمِ﴾</span> [يُرِيد: أَنَّهُ قد كَانَ فِي سَابق علمي أَنَّهُ يصلى الْجَحِيم].</p><p>قَالَ محمدٌ: الْقِرَاءَة فِي (صَالِ الْجَحِيم) بِكَسْر اللَّام عَلَى معنى: صالي - بِالْيَاءِ - وَالْيَاء محذوفة فِي الْمُصحف.</p></div>"
  37,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا مِنَّا إِلا لَهُ مَقَامٌ مَعْلُوم﴾</span> [يُرِيد: مُنْذُ خلقُوا إِلَى النفخة الأولى، يسبحون اللَّه ويهللونه، ويحمدونه، ويسجدون لَهُ، لَا يعْرفُونَ من يداني عِبَادَتهم وَقَالَت الْمَلَائِكَة: <span class="qpc-hafs">﴿وَمَا مِنَّا إِلا لَهُ مَقَامٌ مَعْلُومٌ﴾</span> أَي: إِلَّا لَهُ مَكَان يعبد اللَّه فِيهِ. هَذَا قَول الْمَلَائِكَة؛ أَي: ينزهون اللَّه، حَيْثُ جعلُوا بَيْنَهُ وَبَيْنَ الْجِنَّةِ نَسَبًا</p></div>"
  37,165,"<div class=ar lang=ar><p>[<span class="qpc-hafs">﴿وَإِنَّا لَنَحْنُ الصافون﴾</span> فِي التَّسْبِيح والتهليل وَالتَّكْبِير</p></div>"
  37,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّا لنَحْنُ المسبحون﴾</span> يُرِيد: أَصْحَاب التَّسْبِيح]</p></div>"
  37,167,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن كَانُوا ليقولون﴾</span> يَعْنِي [وَإِن كَانَ أهل مَكَّة ليقولون قبل أَن يبْعَث محمدٌ ﷺ</p></div>"
  37,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوْ أَنَّ عِنْدَنَا ذِكْرًا مِنَ الْأَوَّلين﴾</span> [يُرِيد: قُرْآنًا من لدن إِبْرَاهِيم وَإِسْمَاعِيل] أَي: كتابا مثل كتاب مُوسَى وَعِيسَى</p></div>"
  37,169,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكنا عباد الله المخلصين﴾</span> الْمُؤمنِينَ [يُرِيد: التَّوْحِيد]</p></div>"
  37,170,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿فَكَفرُوا بِهِ﴾</span> بِالْقُرْآنِ؛ [يُرِيد: بِمَا جَاءَ مُحَمَّد ﷺ <span class="qpc-hafs">﴿فَسَوْفَ يعلمُونَ﴾</span> [تهديدًا].</p><p>قَالَ محمدٌ: ذكر قطرب أَن بعض الْقُرَّاء قَرَأَ (مخلِصين) كل مَا فِي الْقُرْآن بِكَسْر اللَّام. قَالَ: وَقَرَأَ بَعضهم كل مَا فِي الْقُرْآن <span class="qpc-hafs">﴿مخلَصين﴾</span> <span class="qpc-hafs">﴿إِنَّه كَانَ مخلَصًا﴾</span> كل ذَلكَ بِالْفَتْح إِلَّا <span class="qpc-hafs">﴿مُخلصين لَهُ الدّين﴾</span> حَيْثُ [وَقع] فَإِنَّهُ مكسور.</p><p>تَفْسِير الْآيَات من ١٧١ وَحَتَّى ١٨٢ من سُورَة الصافات</p></div>"
  37,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا الْمُرْسَلِينَ إِنَّهُم لَهُم المنصورون﴾</span> فِي الدُّنْيَا، وبالحجة فِي الْآخِرَة. تَفْسِير الْحَسَن: لمْ يُقْتَلْ من الرُّسُل من أَصْحَاب الشَّرَائِع أحدٌ قطّ.</p></div>"
  37,172,"<div class=ar lang=ar></div>"
  37,173,"<div class=ar lang=ar><p>[<span class="qpc-hafs">﴿وَإِن جندنا لَهُم الغالبون﴾</span> يُرِيد: حزبه، مِثْلَمَا قَالَ فِي (قد سمع الله): <span class="qpc-hafs">﴿أُولَئِكَ حِزْبُ اللَّهِ أَلا إِنَّ حزب الله هم المفلحون﴾</span>].</p></div>"
  37,174,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فتول عَنْهُم حَتَّى حِين﴾</span> نسختها آيَة الْقِتَال [يُرِيد: الْقَتْل ببدرٍ، وَهُوَ مَنْسُوخ بِآيَة السَّيْف]</p></div>"
  37,175,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأبصرهم فَسَوف يبصرون﴾</span> أَي: فَسَوف يرَوْنَ الْعَذَاب [أَيْضا يَقُولُوا: أنْتَظر بهم]</p></div>"
  37,176,"<div class=ar lang=ar></div>"
  37,177,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِذا نزل بِسَاحَتِهِمْ﴾</span> [أَي: نزل بدارهم] <span class="qpc-hafs">﴿فَسَاءَ صَبَاحُ الْمُنْذرين﴾</span> [يُرِيد: قُرَيْظَة وَالنضير] تَفْسِير الْحَسَن: يَعْنِي: النفخة الأولى؛ بهَا يهْلك اللَّه كفار آخر هَذِه الْأمة</p></div>"
  37,178,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وتول عَنْهُم﴾</span> [يَا مُحَمَّد] <span class="qpc-hafs">﴿حَتَّى حِين﴾</span> إِلَى آجالهم؛ [يُرِيد: يَوْم بدر]، وَهَذَا مَنْسُوخ نسخه الْقِتَال</p></div>"
  37,179,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأبْصر﴾</span> انْتظر <span class="qpc-hafs">﴿فَسَوف يبصرون﴾</span> [وعيدًا من اللَّه وتهديدًا، أَي: فَسَوف] يرَوْنَ الْعَذَاب.</p></div>"
  37,180,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبْحَانَ رَبك﴾</span> ينزِّه نَفسه <span class="qpc-hafs">﴿رَبِّ الْعِزَّةِ عَمَّا يصفونَ﴾</span> يكذبُون يَا مُحَمَّد، إِنَّه سيعزك وَأَصْحَابك [يُرِيد: من اتِّخَاذ الْبَنَات وَالنِّسَاء]</p></div>"
  37,181,"<div class=ar lang=ar><p>(وَسَلاَمٌ عَلَى الْمُرْسَلِينَ} [الَّذين يبلغون رسالتي وَقَامُوا بديني وحجتي]</p></div>"
  37,182,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ﴾</span> [يُرِيد: وَالْحَمْد لله، وَأَنا رب الْعَالمين، يُرِيد الْأَوَّلين والآخرين].</p><p>يَحْيَى: عَنِ الْحَسَنِ بْنِ دِينَارٍ، عَنِ أَبِي هَارُونَ الْعَبْدِيِّ قَالَ: " سَأَلْتُ أَبَا سَعِيدٍ الْخُدْرِيَّ: بِمَ كَانَ رَسُولَ اللَّهِ ﷺ يَخْتِمُ صَلاتَهُ؟ فَقَالَ: بِهَذِهِ الآيَةِ: <span class="qpc-hafs">﴿سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ وَسَلامٌ عَلَى الْمُرْسَلِينَ وَالْحَمْد لله رب الْعَالمين﴾</span>.</p></div>"