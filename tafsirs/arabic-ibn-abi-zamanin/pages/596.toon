quran[26]{c,v,t}:
  92,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يصلاها إِلَّا الأشقى﴾</span> لَا يخلدها</p></div>"
  92,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي كذب وَتَوَلَّى﴾</span> كَذَّبَ بِكِتَابِ اللَّهِ، وَتَوَلَّى عَنْ طَاعَة الله</p></div>"
  92,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وسيجنبها الأتقى﴾</span> يجنب النَّار</p></div>"
  92,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي يُؤْتِي مَاله يتزكى﴾</span> يَتَقَرَّبُ بِهِ إِلَى رَبِّهِ؛ تَفْسِيرُ الْحسن: إِن هَذَا تطوع</p></div>"
  92,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لأَحَدٍ عِنْدَهُ مِنْ نِعْمَةٍ تجزى﴾</span> أَيْ: لَيْسَ يَفْعَلُ ذَلِكَ لِنِعْمَةٍ (ل ٣٩٥) يجزى بهَا أحدا</p></div>"
  92,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا ابْتِغَاء﴾</span> أَيْ: لَيْسَ يَفْعَلُ ذَلِكَ إِلَّا ابْتِغَاءَ <span class="qpc-hafs">﴿وَجْهِ رَبِّهِ الأَعْلَى وَلَسَوْفَ يرضى﴾</span> الثَّوَابَ فِي الْجَنَّةِ، وَيُقَالُ: إِنَّهَا نَزَلَتْ فِي أَبِي بَكْرٍ الصِّدِّيقِ حِينَ أَعْتَقَ بِلالًا وَسِتَّةً مَعَهُ.</p></div>"
  92,21,"<div class=ar lang=ar></div>"
  93,1,"<div class=ar lang=ar><p>تَفْسِيرُ وَالضُّحَى وَهِيَ مَكِّيَّةٌ كُلُّهَا</p><p>بِسم الله الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿وَالضُّحَى﴾</span> يَعْنِي: ضُحَى النَّهَارِ وَهُوَ ضَوْؤُهُ</p></div>"
  93,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاللَّيْل إِذا سجى﴾</span> إِذَا أَظْلَمَ.</p><p>قَالَ مُحَمَّدٌ: وَقِيلَ: سَجَى: سَكَنَ؛ وَذَلِكَ عِنْدَ تَنَاهِي ظَلامِهُ وَرُكُودِهُ.</p><p>قَالَ يَحْيَى: وَهَذَا قسم.</p></div>"
  93,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى﴾</span> وَهِيَ تُقْرَأُ عَلَى وَجْهَيْنِ <span class="qpc-hafs">﴿وَدَّعَكَ﴾</span> مُثَقَّلَةٌ، وَ <span class="qpc-hafs">﴿وَدَعَكَ﴾</span> خَفِيفَةٌ؛ فَمَنْ قَرَأَهَا بِالتَّثْقِيلِ يَقُولُ: لَمْ يُوَدِّعْكَ فَيَكُونُ آخِرُ الْفَرَاغِ مِنَ الْوَحْيِ، وَمَنْ قَرَأَهَا بِالتَّخْفِيفِ يَقُولُ: مَا تَرَكَكَ رَبُّكَ مِنْ أَنْ يَنْزِلَ عَلَيْكَ الْوَحْيُ، وَذَلِكَ أَنَّ جِبْرِيلَ أَبْطَأَ عَنِ النَّبِيِّ ﷺ بِالْوَحْيِ، فَقَالَ الْمُشْرِكُونَ: قَدْ وَدَّعَهُ رَبُّهُ وَأَبْغَضَهُ!</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿وَمَا قَلَى﴾</span> أَي: وَمَا أبغضك</p></div>"
  93,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَلآخِرَةُ خَيْرٌ لَكَ مِنَ الأُولَى﴾</span> يَعْنِي: من الدُّنْيَا</p></div>"
  93,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولسوف يعطيك رَبك﴾</span> فِي الْجَنَّةِ <span class="qpc-hafs">﴿فَتَرْضَى﴾</span></p></div>"
  93,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألم يجدك يَتِيما فآوى﴾</span></p><p>قَالَ مُحَمَّدٌ: قَالَ ابْنُ عَبَّاسٍ: يَقُولُ: وَجَدَكَ يَتِيمًا عِنْدَ أَبِي طَالب فآواك إِلَى خَدِيجَة.</p></div>"
  93,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ووجدك ضَالًّا فهدى﴾</span> كَقَوْلِهِ: <span class="qpc-hafs">﴿وَكَذَلِكَ أَوْحَيْنَا إِلَيْكَ رُوحًا من أمرنَا﴾</span> يَعْنِي: الْقُرْآنَ <span class="qpc-hafs">﴿مَا كُنْتَ تَدْرِي مَا الْكتاب وَلَا الْإِيمَان﴾</span></p></div>"
  93,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ووجدك عائلا﴾</span> أَي فَقِيرا: <span class="qpc-hafs">﴿فأغنى﴾</span></p><p>قَالَ مُحَمَّد: جَاءَ عَنِ ابْن عَبَّاس فِي قَوْله: <span class="qpc-hafs">﴿فأغنى﴾</span> أَيْ: فَرَضَّاكَ بِمَا أَعْطَاكَ مِنَ الرِّزْقِ ذَهَبَ إِلَى غِنَى النَّفْسِ. وَيُقَالُ: عَالَ الرَّجُلُ إِذَا افْتَقَرَ، وأعال إِذْ كثر عِيَاله.</p></div>"
  93,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَما الْيَتِيم فَلَا تقهر﴾</span> لَا تَقْهَرْهُ فَتَمْنَعْهُ حَقَّهُ الَّذِي أَمر الله بِهِ</p></div>"
  93,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأما السَّائِل فَلَا تنهر﴾</span> أَيْ: لَا تَنْهَرْهُ: إِمَّا أَعْطَيْتَهُ، وَإِمَّا رَددته ردا لينًا.</p></div>"
  93,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأما بِنِعْمَة رَبك﴾</span> بِالْقُرْآنِ <span class="qpc-hafs">﴿فَحدث﴾</span></p><p>قَالَ مُحَمَّدٌ: يَقُولُ: بَلِّغْ مَا أُرْسِلْتَ بِهِ وَحَدِّثْ بِالنُّبُوَّةِ وَهِيَ أَجَلُّ وَهُوَ مَعْنَى قَوْلِ يَحْيَى.</p></div>"
  94,1,"<div class=ar lang=ar><p>تَفْسِيرُ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ﴾</span> يَعْنِي: بِالْإِيمَانِ؛ فِي تَفْسِيرِ الْحَسَنِ</p></div>"
  94,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ووضعنا عَنْك وزرك﴾</span> الْوِزْرُ: الْحِمْلُ، وَهِيَ الذُّنُوبُ الَّتِي كَانَت عَلَيْهِ فِي الْجَاهِلِيَّة</p></div>"
  94,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي أنقض ظهرك﴾</span> أَي: أثقله</p></div>"
  94,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ورفعنا لَك ذكرك﴾</span> بِالنُّبُوَّةِ.</p></div>"
  94,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّ مَعَ الْعُسْرِ يُسْرًا إِنَّ مَعَ الْعسر يسرا﴾</span> بلغنَا عَنِ النَّبِيِّ ﷺ وَعَنْ بَعْضِ أَصْحَابِهِ أَنَّهُ قَالَ «لن يغلب عسر يسرين».</p></div>"
  94,6,"<div class=ar lang=ar></div>"
  94,7,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿فَإِذا فرغت فانصب﴾</span> تَفْسِيرُ الْكَلْبِيِّ: فَإِذَا فَرَغْتَ مِنَ الصَّلَاة فانصب فِي الدُّعَاء</p></div>"
  94,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِلَى رَبك فارغب﴾</span> تَضَرَّعْ.</p><p>قَالَ مُحَمَّدٌ: قَوْلُهُ: <span class="qpc-hafs">﴿فَإِنَّ مَعَ الْعسر يسرا﴾</span> فَذَكَرَ الْعُسْرَ مَعَ الْأَلِفِ وَاللَّامِ، ثُمَّ ثَنَّى ذِكْرَهُ، فَصَارَ الْمَعْنَى: إِنَّ مَعَ الْعُسْرِ يُسْرَيْنِ.</p></div>"