quran[27]{c,v,t}:
  95,1,"<div class=ar lang=ar><p>تَفْسِيرُ وَالتِّينِ وَالزَّيْتُونِ وَهِيَ مَكِّيَّةٌ كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</p><p>قَوْله: <span class="qpc-hafs">﴿والتين وَالزَّيْتُون﴾</span> تَفْسِيرُ قَتَادَةَ: التِّينُ: جَبَلُ دِمَشْقَ، وَالزَّيْتُون: جبل بَيت الْمُقَدّس</p></div>"
  95,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وطور سِنِين﴾</span> الطُّورُ: الْجَبَلُ، وَسِنِينَ: الْحَسَنُ؛ وَهُوَ الْجَبَلُ الَّذِي نَادَى اللَّهُ مِنْهُ مُوسَى؛ فِي تَفْسِير الْحسن.</p></div>"
  95,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَذَا الْبَلَد الْأمين﴾</span> يَعْنِي: الْآمِنَ يُرِيدُ مَكَّةَ؛ يَقُولُ: إِنَّكُمْ تَأْمَنُونَ فِيهِ مِنَ الْقَتْلِ والسِّبَاءِ، وَالْعَرَبُ تَقْتُلُ بَعْضُهَا بَعْضًا، وَتَسْبِي بَعْضُهَا بَعْضًا، وَكَانَ هَذَا قبل أَن يُؤمر بِالْقِتَالِ</p></div>"
  95,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَقَدْ خَلَقْنَا الإِنْسَانَ فِي أَحْسَنِ تَقْوِيم﴾</span> فِي أَحْسَنِ صُورَةٍ، أَقْسَمَ بِهَذَا كُلِّهِ مِنْ أَوَّلِ السُّورَةِ إِلَى هَذَا الْموضع</p></div>"
  95,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثمَّ رددناه أَسْفَل سافلين﴾</span> تَفْسِيرُ الْحَسَنِ: يَعْنِي: بِالْإِنْسَانِ هَاهُنَا الْمُشرك و (أَسْفَل سافلين} يُرِيدُ جَهَنَّمَ.</p><p>قَالَ مُحَمَّدٌ: قِيلَ: الْمَعْنَى: رَدَدْنَاهُ إِلَى أَمَاكِنَ سَافِلَةٍ، يُقَالُ: سَفُلَ الرَّجُلَ فَهُوَ سَافِلٌ إِذا كَانَ ذليلاً.</p></div>"
  95,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ﴾</span> اسْتَثْنَى مَنْ آمَنَ <span class="qpc-hafs">﴿فَلَهُمْ أَجْرٌ﴾</span> أَي: ثَوَاب <span class="qpc-hafs">﴿غير ممنون﴾</span> قَالَ الْحَسَنُ: غَيْرُ مَمْنُونٍ عَلَيْهِمْ من أَذَى</p></div>"
  95,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا يكذبك بعد بِالدّينِ﴾</span> تَفْسِيرُ الْكَلْبِيِّ: قَالَ: يَقُولُ لِلْمُشْرِكِ: فَمَا يُكَذِّبُكَ أَيُّهَا الْإِنْسَانُ بَعْدُ بِالْحِسَابِ يَوْم الْقِيَامَة،</p></div>"
  95,8,"<div class=ar lang=ar><p>ثُمَّ قَالَ: <span class="qpc-hafs">﴿أَلَيْسَ اللَّهُ بِأَحْكَمِ الْحَاكِمين﴾</span> أَيْ: بَلَى هُوَ أَحْكَمُ الْحَاكِمِينَ</p></div>"
  96,1,"<div class=ar lang=ar><p>تَفْسِيرُ اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ وَهِيَ مَكِّيَّةٌ كُلُّهَا</p><p>بِسْمِ الله الرَّحْمَن الرَّحِيم</p><p>(ل ٣٩٦)</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خلق﴾</span> ((أَوَّلُ مَا كَلَّمَ جِبْرِيلُ النَّبِيَّ ﷺ حِينَ تَبَدَّى لَهُ قَالَ لَهُ: <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾</span> إِلَى قَوْلِهِ: <span class="qpc-hafs">﴿إِنَّ إِلَى رَبِّكَ الرُّجْعَى﴾</span>.</p></div>"
  96,2,"<div class=ar lang=ar></div>"
  96,3,"96:2"
  96,4,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿الَّذِي علم بالقلم﴾</span> وَهُوَ الْكتاب بالقلم.</p></div>"
  96,5,"<div class=ar lang=ar></div>"
  96,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كلا﴾</span> قَالَ الْحَسَنُ: مَعْنَاهَا حَقًا <span class="qpc-hafs">﴿إِنَّ الإِنْسَانَ لَيَطْغَى أَنْ رَآهُ اسْتَغْنَى﴾</span> تَفْسِيرُ الْكَلْبِيِّ: يَعْنِي: يَرْتَفِعُ مِنْ مَنْزِلَةٍ إِلَى مَنْزِلَةٍ قَالَ بَعْضُهُمْ: نزلت فِي أبي</p></div>"
  96,7,"<div class=ar lang=ar></div>"
  96,8,"<div class=ar lang=ar><p>جَهْلٍ <span class="qpc-hafs">﴿إِنَّ إِلَى رَبِّكَ الرُّجْعَى﴾</span> الْمرجع يَوْم الْقِيَامَة</p></div>"
  96,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَأَيْتَ الَّذِي يَنْهَى عَبْدًا إِذَا صلى﴾</span> كَانَ أَبُو جَهْلٍ يَنْهَى النَّبِيَّ ﷺ عَنِ الصَّلَاة</p></div>"
  96,10,"<div class=ar lang=ar></div>"
  96,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَأَيْتَ إِنْ كَانَ عَلَى الْهُدَى أَو أَمر بالتقوى﴾</span> وَهُوَ مُحَمَّدٌ، كَانَ عَلَى الْهُدَى وَأمر الْعباد بِطَاعَة الله.</p></div>"
  96,12,"<div class=ar lang=ar></div>"
  96,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَأَيْت إِن كذب وَتَوَلَّى﴾</span> يَعْنِي: أَبَا جَهْلٍ كَذَّبَ بِكِتَابِ اللَّهِ وَتَوَلَّى عَنْ طَاعَةِ اللَّهِ</p></div>"
  96,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمْ يَعْلَمْ بِأَنَّ اللَّهَ يَرَى﴾</span> عمله</p></div>"
  96,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كلا لَئِن لم ينْتَه﴾</span> أَبُو جهل عَن كفره وتكذبيه <span class="qpc-hafs">﴿لنسفعن بالناصية﴾</span> لَنَأْخُذَنَّ بِنَاصِيَتِهِ تَجُرُّهُ الْمَلائِكَةُ بِنَاصِيتَهِ فَتُلْقِيهِ فِي النَّارِ.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ: سَفَعَتَ بِالشَّيْءِ إِذَا قَبَضْتَ عَلَيْهِ وجبذته جبذاً شَدِيدا.</p></div>"
  96,16,"<div class=ar lang=ar></div>"
  96,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَليدع نَادِيه سَنَدع الزَّبَانِيَة﴾</span> فَلْيَدْعُ أَبُو جَهْلٍ إِذَا دَعَوْنَا بالزبانية خَزَنَةَ النَّارِ فَجَرُّوا بِنَاصِيَتِهِ إِلَى النَّارِ فَلْيَدْعُ حِينَئِذٍ نَادِيَهُ؛ يَعْنِي: عَشِيرَتَهُ وَجُلَسَاءَهُ فَلْيَمْنَعُوهُ مِنْ ذَلِكَ.</p><p>قَالَ مُحَمَّدٌ: وَاحِدُ الزَّبَانِيَةِ: زِبْنِيَةٌ مَأْخُوذٌ مِنَ الزَّبْنِ، وَالزَّبْنُ: الدَّفْعُ؛ كَأَنَّهُمْ يَدْفَعُونَ أَهْلَ النَّارِ إِلَيْهَا.</p></div>"
  96,18,"<div class=ar lang=ar></div>"
  96,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كلا لَا تطعه﴾</span> لَا تُطِعْ أَبَا جَهْلٍ فِيمَا؛ يَأْمُرك بِهِ يَقُولُهُ لِلنَّبِيِّ ﷺ <span class="qpc-hafs">﴿واسجد﴾</span> أَي: وصل لِرَبِّك <span class="qpc-hafs">﴿واقترب﴾</span> وَهُوَ الدُّنُوُّ أَقْرَبُ مَا يَكُونُ الْعَبْدُ إِلَى اللَّهِ إِذَا كَانَ سَاجِدًا.</p></div>"