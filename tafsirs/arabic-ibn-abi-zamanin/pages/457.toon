quran[22]{c,v,t}:
  38,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالُوا مَا لَنَا لَا نَرَى رجَالًا﴾</span> لما دخلُوا النَّار لمْ يَرْوهم مَعَهم فِيهَا فَقَالُوا: <span class="qpc-hafs">﴿مَا لَنَا لَا نَرَى رِجَالا كُنَّا نَعُدُّهُمْ من الأشرار﴾</span> فِي الدُّنْيَا</p></div>"
  38,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أتخذناهم سخريا﴾</span> فأخطأنا <span class="qpc-hafs">﴿أَمْ زَاغَتْ عَنْهُمُ الأَبْصَارُ﴾</span> أَي: أم هُمْ فِيهَا وَلَا نراهُم؟ هَذَا تَفْسِير مُجَاهِد. قَالَ: علمُوا بعد أَنهم لَيْسُوا مَعَهم فِيهَا.</p><p>قَالَ محمدٌ: تقْرَأ (سخريًّا) بِضَم السِّين وَكسرهَا بِمَعْنى واحدٍ من الهُزْء. وَقد قِيلَ: من ضمَّ أَوله جعله من السُّخرة , وَمن كسر جعله من الهُزْءِ. وَقَرَأَ نَافِع <span class="qpc-hafs">﴿أتخذناهم﴾</span> بِأَلف الِاسْتِفْهَام</p></div>"
  38,64,"<div class=ar lang=ar><p>قَالَ اللَّه: <span class="qpc-hafs">﴿إِنَّ ذَلِكَ لَحَقٌّ تخاصم أهل النَّار﴾</span> يَعْنِي: قَول بَعضهم لبعضٍ فِي الْآيَة الأولى</p></div>"
  38,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل إِنَّمَا أَنا مُنْذر﴾</span> من النَّار <span class="qpc-hafs">﴿وَمَا مِنْ إِلَهٍ إِلَّا الله الْوَاحِد القهار﴾</span> قهر الْعباد بِالْمَوْتِ , وَبِمَا شَاءَ من أمره</p></div>"
  38,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رب السَّمَاوَات وَالأَرْضِ وَمَا بَيْنَهُمَا الْعَزِيزُ الْغَفَّارُ﴾</span> لمن آمن.</p></div>"
  38,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل هُوَ نبأ عَظِيم﴾</span> يَعْنِي: الْقُرْآن</p></div>"
  38,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنْتُم عَنهُ معرضون﴾</span> يَعْنِي: الْمُشْركين</p></div>"
  38,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا كَانَ لِي مِنْ عِلْمٍ بالملإ الْأَعْلَى﴾</span> يَعْنِي: الْمَلَائِكَة <span class="qpc-hafs">﴿إِذْ يختصمون﴾</span> تَفْسِير الْحَسَن: اخْتَصَمُوا فِي خلق آدم؛ قَالُوا فِيمَا بَينهم: مَا اللَّه خالقٌ خَلْقًا هُوَ أكْرم عَلَيْهِ منا.</p></div>"
  38,70,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿إِنْ يُوحَى إِلَيَّ إِلا أَنما أَنا نَذِير مُبين﴾</span> كَقَوْلِه: <span class="qpc-hafs">﴿إِنَّمَا أَنْتَ مُنْذِرٌ وَلِكُلِّ قوم هاد﴾</span> النَّبِي الْمُنْذر , وَالله الْهَادِي.</p><p>تَفْسِير الْآيَات من ٧١ وَحَتَّى ٨٥ من سُورَة ص.</p></div>"
  38,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ قَالَ رَبُّكَ لِلْمَلائِكَةِ إِنِّي خَالِقٌ بَشَرًا مِنْ طِينٍ﴾</span> إِلَى قَوْله: <span class="qpc-hafs">﴿وَكَانَ من الْكَافرين﴾</span> قَدْ مَضَى تَفْسِيرُهُ فِي سُورَةِ الْبَقَرَة</p></div>"
  38,72,"<div class=ar lang=ar></div>"
  38,73,"38:72"
  38,74,"38:72"
  38,75,"<div class=ar lang=ar><p>(قَالَ يَا إِبْلِيسُ مَا مَنَعَكَ أَن تَسْجُدَ لِمَا خَلَقْتُ بِيَدَيَّ} قَالَ قَتَادَةُ: إِنَّ كَعْبًا قَالَ: إِنَّ اللَّهَ لَمْ يَخْلُقْ بِيَدِهِ إِلَّا ثَلَاثَة: خلق آدم بِيَدِهِ , وَكَتَبَ التَّوْرَاةَ بِيَدِهِ , وَغَرَسَ الْجَنَّةَ بِيَدِهِ <span class="qpc-hafs">﴿أَسْتَكْبَرْتَ﴾</span> يَعْنِي: تكبّرت.</p><p>قَالَ محمدٌ: الِاخْتِيَار فِي الْقِرَاءَة (أستكبرت) بِفَتْح الْألف على الِاسْتِفْهَام.</p></div>"
  38,76,"<div class=ar lang=ar></div>"
  38,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاخْرُجْ مِنْهَا﴾</span> <span class="qpc-hafs">﴿من السَّمَاء﴾</span> (فَإِنَّكَ رَجِيمٌ} أَي: مَلْعُون (رجم باللعنة)</p></div>"
  38,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّ عَلَيْكَ لَعْنَتِي إِلَى يَوْمِ الدِّينِ﴾</span> وأبدا فِي مَلْعُون</p></div>"
  38,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ رَبِّ فَأَنظِرْنِي﴾</span> أَي: أخرْني <span class="qpc-hafs">﴿إِلَى يَوْمِ يُبْعَثُونَ قَالَ فَإِنَّكَ مِنَ الْمُنظَرِينَ﴾</span>.</p></div>"
  38,80,"<div class=ar lang=ar></div>"
  38,81,"<div class=ar lang=ar><p>قَالَ محمدٌ: <span class="qpc-hafs">﴿إِلَى يَوْمِ الْوَقْتِ الْمَعْلُومِ﴾</span> يَعْنِي: النفخة الأولى , وَأَرَادَ عَدو اللَّه أَن يُؤَخر إِلَى النفخة الْآخِرَة.</p></div>"
  38,82,"<div class=ar lang=ar></div>"
  38,83,"<div class=ar lang=ar><p>(إِلاَ عِبَادَكَ مِنْهُمُ الْمُخْلَصِينَ.</p><p>قَالَ محمدٌ: من قَرَأَ <span class="qpc-hafs">﴿المخلصين﴾</span> بِكَسْر اللَّام أَرَادَ: الَّذين أَخْلصُوا دينهم لله , وَمن قَرَأَ بِالْفَتْح؛ فَالْمَعْنى: الَّذين أخلصهم الله لعبادته.</p></div>"