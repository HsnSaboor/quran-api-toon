quran[18]{c,v,t}:
  44,1,"<div class=ar lang=ar><p>تفسيرسورة الدُّخان وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللهِ الرَّحْمَنِ الرَّحِيمِ</p></div>"
  44,2,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَالْكتاب الْمُبين﴾</span> قسم أقسم بِالْقُرْآنِ</p></div>"
  44,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا أَنزَلْنَاهُ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿فِي لَيْلَةٍ مُبَارَكَةٍ﴾</span> يَعْنِي: لَيْلَة الْقدر.</p><p>يَحْيَى: عَنْ هَمَّامِ بْنِ يَحْيَى، عَنِ الْكَلْبِيِّ، عَنْ أَبِي صَالحٍ [عَنِ] ابْنِ عَبَّاسٍ قَالَ: " نَزَلَ الْقُرْآنُ لَيْلَةَ الْقَدْرِ إِلَى السَّمَاءِ الدُّنْيَا جُمْلَةً وَاحِدَةً، ثُمَّ جَعَلَ بَعْدَ ذَلِكَ يَنْزِلُ نُجُومًا ثَلاثَ آيَاتٍ وَأَرْبَعَ آيَاتٍ وَخَمْسَ آيَاتٍ وَأَقَلَّ مِنْ ذَلِكَ وَأَكْثَرَ. ثُمَّ تَلا هَذِهِ الآيَةَ <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَوَاقِعِ النُّجُومِ﴾</span> ".</p><p><span class="qpc-hafs">﴿إِنَّا كُنَّا منذرين﴾</span> الْعباد من النَّار</p></div>"
  44,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهَا﴾</span> يَعْنِي: لَيْلَة الْقدر <span class="qpc-hafs">﴿يُفْرَقُ كُلُّ أَمر حَكِيم﴾</span> أَي: يفصل، قَالَ الْحسن: مَا يُرِيد الله أَن ينزل من الْوَحْي وَينفذ من الْأُمُور فِي سمائه وأرضه وخلقه تِلْكَ السّنة، ينزله فِي لَيْلَة الْقدر إِلَى سمائه، ثمَّ ينزله فِي الْأَيَّام والليالي على قَدَرٍ حَتَّى يحول الْحول من تِلْكَ اللَّيْلَة.</p></div>"
  44,5,"<div class=ar lang=ar></div>"
  44,6,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿أَمْرًا مِنْ عِنْدِنَا إِنَّا كُنَّا مرسلين﴾</span> الرُّسُل إِلَى الْعباد</p></div>"
  44,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَحْمَة من رَبك﴾</span> الْآيَة.</p><p>قَالَ محمدٌ: قَوْله: <span class="qpc-hafs">﴿أَمْرًا﴾</span> مَنْصُور على الْحَال؛ الْمَعْنى: إِنَّا أَنزَلْنَاهُ آمرين أمرا. وَقَوله: <span class="qpc-hafs">﴿رَحْمَةً مِنْ رَبك﴾</span> أَي: أَنزَلْنَاهُ رَحْمَة.</p></div>"
  44,8,"<div class=ar lang=ar></div>"
  44,9,"44:8"
  44,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَارْتَقِبْ﴾</span> أَي: فانتظر <span class="qpc-hafs">﴿يَوْمَ تَأْتِي السَّمَاءُ بِدُخَان مُبين﴾</span> بَين</p></div>"
  44,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يغشى النَّاس﴾</span> تَفْسِير مُجَاهِد: يَعْنِي: الجدب وإمساك الْمَطَر عَن [كفار قُرَيْش].</p></div>"
  44,12,"<div class=ar lang=ar><p>يَقُولُونَ: <span class="qpc-hafs">﴿رَبَّنَا اكْشِفْ عَنَّا الْعَذَابَ﴾</span>.</p></div>"
  44,13,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿أَنَّى لَهُمُ الذِّكْرَى﴾</span> أَي: كَيفَ لَهُم الذكرى؟ (ل ٣١٩) يَعْنِي: الْإِيمَان بعد وُقُوع هَذَا الْبلَاء <span class="qpc-hafs">﴿وَقَدْ جَاءَهُمْ رَسُولٌ مُبِينٌ﴾</span></p></div>"
  44,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ تَوَلَّوْا عَنْهُ وَقَالُوا مُعَلَّمٌ مَجْنُون﴾</span> يُعلمهُ عبد [لنَبِيّ] الْحَضْرَمِيّ، وَكَانَ كَاهِنًا؛ فِي تَفْسِير الْحسن. وَقَالَ بَعضهم: عداس غُلَام عتبَة بن ربيعَة؛ كَانَ يقْرَأ الْكتب،</p></div>"
  44,15,"<div class=ar lang=ar><p>قَالَ الله: <span class="qpc-hafs">﴿إِنَّا كَاشِفُو الْعَذَابِ قَلِيلا﴾</span>.</p></div>"
  44,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم نبطش البطشة الْكُبْرَى﴾</span>.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿يَوْم نبطش﴾</span> منصوبٌ بِمَعْنى: وَاذْكُر يَوْم نبطش، وَيُقَال: يبطُش بِالرَّفْع أَيْضا، مثل: عَكَفَ يَعْكُفُ ويَعْكِفُ، وَمثل هَذَا كثير.</p><p>يَحْيَى: عَنِ الْمُعَلَّى، عَنِ الْأَعْمَشِ، عَنْ أَبِي وَائِلٍ، عَنْ أَبِي الضُّحَى، عَنْ مَسْرُوقٍ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ أَنَّهُ قِيلَ لَهُ: " هَا هُنَا رَجُلٌ يَزْعُمُ أَنَّهُ يَأْتِي دُخَانٌ قَبْلَ يَوْمِ الْقِيَامَةِ فَيَأْخُذُ بِأَسْمَاعِ الْمُنَافِقِينَ وَأَبْصَارِهِمْ، وَيَأْخُذُ الْمُؤْمِنِينَ مِنْهُ كَهَيْئَةِ الزُّكَامِ، وَكَانَ مُتَّكِئًا فَغَضِبَ؛ فَجَلَسَ فَقَالَ: يَا أَيهَا النَّاسُ مَنْ عَلِمَ عِلْمًا فَلْيَقُلْ بِهِ، وَمَنْ لَمْ يَعْلَمْ فَلْيَقُلْ: اللَّهُ أَعْلَمُ؛ فَإِنَّ مِنَ الْعِلْمِ أَنْ يَقُولَ الْعَبْدُ لِمَا لَا يَعْلَمُ: اللَّهُ أَعْلَمُ، وَقَدْ قَالَ اللَّهُ لِنَبِيِّهِ: <span class="qpc-hafs">﴿قُلْ مَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ وَمَا أَنَا من المتكلفين﴾</span> وَسَأُخْبِرُكُمْ عَنِ الدُّخَانِ: إِنَّ قُرَيْشًا لَمَّا أَبْطَئُوا عَنِ الإِسْلامِ، دَعَا عَلَيْهِم رَسُول الله؛ فَقَالَ: اللَّهُمَّ أَعِنِّي عَلَيْهِمْ بِسَبْعٍ كَسَبْعِ يُوسُفَ. فَأَصَابَهُمُ الْجُوعُ؛ حَتَّى أَكَلُوا الْمَيْتَةَ وَالْعِظَامَ، حَتَّى كَانَ أَحَدُهُمْ يَرَى مَا بَيْنَهُ وَبَيْنَ السَّمَاءِ دُخَانًا مِنَ الْجَهْدِ، فَذَلِكَ قَوْلُهُ: <span class="qpc-hafs">﴿فَارْتَقِبْ يَوْمَ تَأْتِي السَّمَاءُ بِدُخَان مُبين﴾</span> إِلَى قَوْله <span class="qpc-hafs">﴿إِنَّا مُؤمنُونَ﴾</span> فَسَأَلُوا أَنْ يُكْشَفَ عَنْهُمُ الْعَذَابُ فَيُؤْمِنُوا، قَالَ اللَّهُ: <span class="qpc-hafs">﴿أَنَّى لَهُمُ الذِّكْرَى وَقَدْ جَاءَهُمْ رَسُولٌ مُبِينٌ﴾</span> إِلَى قَوْله: <span class="qpc-hafs">﴿منتقمون﴾</span> فَكُشِفَ عَنْهُمْ فَعَادُوا فِي كُفْرِهِمْ؛ فَأَخَذَهُمْ يَوْمَ بَدْرٍ، فَهُوَ قَوْلُهُ: <span class="qpc-hafs">﴿يَوْم نبطش البطشة الْكُبْرَى﴾</span> فَكَانَ عَبْدُ اللَّهِ بْنُ مَسْعُودٍ يَقُولُ: قَدْ مَضَتِ الْبَطْشَةُ وَالدُّخَانُ وَاللِّزَامُ وَالرُّومُ وَالْقَمَرُ ".</p><p>قَالَ محمدٌ: قيل للجوع: دُخان، لِيَبَس الأَرْض فِي سنة الجَدْب، وَانْقِطَاع النَّبَات وارتفاع الْغُبَار، فَشبه مَا يرْتَفع مِنْهُ بالدخان، وَمن كَلَامهم: جوعٌ أغْبَرُ وَسنة غبراء لسنة المجاعة.</p></div>"
  44,17,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَلَقَد فتنا قبلهم﴾</span> أَي: اختبرنا قبلهم <span class="qpc-hafs">﴿قَوْمَ فِرْعَوْنَ﴾</span> بِالدّينِ؛ كَقَوْلِه: <span class="qpc-hafs">﴿وَإِنْ كُنَّا لَمُبْتَلِينَ﴾</span> لمختبرين بِالدّينِ.</p><p><span class="qpc-hafs">﴿وجاءهم رَسُول كريم﴾</span> على الله؛ يَعْنِي: مُوسَى</p></div>"
  44,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنْ أَدُّوا إِلَيَّ عِبَادَ اللَّهِ﴾</span> أرْسلُوا معي بني إِسْرَائِيل؛ فِي تَفْسِير مُجَاهِد <span class="qpc-hafs">﴿إِنِّي لَكُمْ رَسُولٌ أَمِين﴾</span> على مَا أَتَانِي من الله، لَا أَزِيد فِيهِ شَيْئا وَلَا أنقص مِنْهُ شَيْئا.</p></div>"