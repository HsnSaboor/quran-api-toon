quran[15]{c,v,t}:
  50,1,"<div class=ar lang=ar><p>تَفْسِير سُورَة ق وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ الله الرَّحْمَن الرَّحِيم</p><p>تَفْسِير الْآيَات من ١ وَحَتَّى ١١ من سُورَة ق.</p><p>قَوْله <span class="qpc-hafs">﴿ق﴾</span> تَفْسِير بَعضهم: هُوَ جبل مُحِيط بالدنيا.</p><p>قَالَ محمدٌ: وَرُوِيَ عَن ابْن عَبَّاس أَنه قَالَ: هُوَ جبل أَخْضَر من زمرد، خضرَة السَّمَاء مِنْهُ. وَذكر قطرب أَن قِرَاءَة الْحسن <span class="qpc-hafs">﴿ق﴾</span> بِالْجَزْمِ.</p><p>قَالَ يحيى: وبَعْضُهم يجر قَاف وَالْقُرْآن الْمجِيد؛ يَجعله على الْقسم، وَمعنى (الْمجِيد): الْكَرِيم على اللَّه، وَمن جزم جعل الْقسم من (وَالْقُرْآن الْمجِيد).</p><p>قَالَ الْحسن: وَقع الْقسم على تعجْب الْمُشْركين مِمَّا جَاءَ بِهِ مُحَمَّد.</p></div>"
  50,2,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿بل عجبوا﴾</span> أَي: لقد عجبوا؛ يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿أَن جَاءَهُم مُنْذر مِنْهُم﴾</span> يَعْنِي: النَّبي ﷺ مِنْهُم فِي النّسَب ينذر من عَذَاب اللَّه <span class="qpc-hafs">﴿فَقَالَ الْكَافِرُونَ هَذَا شَيْءٌ عَجِيبٌ﴾</span> أَي: عجب</p></div>"
  50,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أئذا متْنا وَكُنَّا تُرَابا﴾</span> على الِاسْتِفْهَام <span class="qpc-hafs">﴿ذَلِكَ رَجْعٌ بَعِيدٌ﴾</span> يُنكرُونَ الْبَعْث؛ أَي: إِنَّه لَيْسَ بكائن،</p></div>"
  50,4,"<div class=ar lang=ar><p>قَالَ اللَّه: <span class="qpc-hafs">﴿قَدْ عَلِمْنَا مَا تنقص الأَرْض مِنْهُم﴾</span> مَا تَأْكُل الأَرْض مِنْهُم إِذا مَاتُوا، تَأْكُل كل شيءٍ إِلَّا عَجْبَ الذَّنَب <span class="qpc-hafs">﴿وَعِنْدَنَا كِتَابٌ حَفِيظٌ﴾</span> تَفْسِير بَعضهم: يَقُول: هُوَ اللَّوْح الْمَحْفُوظ</p></div>"
  50,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فهم فِي أَمر مريج﴾</span> مُلْتبسٍ؛ يَعْنِي: فِي شّكٍ من الْبَعْث.</p></div>"
  50,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيفَ بنيناها وزيناها﴾</span> يَعْنِي: بالكواكب <span class="qpc-hafs">﴿وَمَا لَهَا من فروج﴾</span> من شقوق.</p></div>"
  50,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وألقينا فِيهَا رواسي﴾</span> الرواسِي: الْجبَال أَثْبَتَ بهَا الأرضَ <span class="qpc-hafs">﴿وَأَنْبَتْنَا فِيهَا مِنْ كُلِّ زَوْجٍ بهيج﴾</span> حسن، وكل مَا ينْبت فِي الأَرْض فالواحد مِنْهُ زوج</p></div>"
  50,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تبصرة﴾</span> أَي: يتفكر فِيهِ الْمُؤمن، فَيعلم أَن الَّذِي خلق هَذَا قادرٌ عَلَى أَنْ يُحْيِيَ الْمَوْتَى، وَأَنْ مَا وعد اللَّه من الْآخِرَة حق.</p><p>قَالَ مُحَمَّد: (تبصرة) منصوبٌ بِمَعْنى: فصَّلنا ذَلِك للتبصرة، وليدل على الْقُدْرَة.</p><p><span class="qpc-hafs">﴿وَذِكْرَى لِكُلِّ عبد منيب﴾</span> مقبل إِلَى اللَّه بإخلاص لَهُ</p></div>"
  50,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنْبَتْنَا بِهِ جَنَّاتٍ وَحَبَّ الْحَصِيدِ﴾</span> وَهُوَ كل مَا يحصد؛ فِي تَفْسِير الْحسن.</p><p>قَالَ محمدٌ: (حب الحصيد) الْمَعْنى: الْحبّ الحصيد، فأضاف الْحبّ إِلَى الحصيد؛ كَمَا يُقَال: صَلَاة الأولى؛ يُرَاد الصَّلَاة الأولى، وَمَسْجِد الْجَامِع؛ يُرَاد المسجدُ الْجَامِع.</p></div>"
  50,10,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَالنَّخْل باسقات﴾</span> يَعْنِي: طوَالًا.</p><p>قَالَ محمدٌ: يُقَال: بسق الشَّيْء بُسُوقًا إِذا طَال.</p><p><span class="qpc-hafs">﴿لَهَا طلع نضيد﴾</span> أَي: منضودٌ بعْضُه فَوق بعض</p></div>"
  50,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رزقا للعباد﴾</span> أَي: أنبتناه رزقا للعباد <span class="qpc-hafs">﴿وَأَحْيَيْنَا بِهِ﴾</span> بالمطر <span class="qpc-hafs">﴿بَلْدَة مَيتا﴾</span> يابسة لَيْسَ فِيهَا نَبَات فأنبتت <span class="qpc-hafs">﴿كَذَلِك الْخُرُوج﴾</span> الْبَعْثَ. يُرْسِلُ اللَّهُ مَطَرًا مَنِيًّا كمني الرِّجَال ينْبت بِهِ جسمانهم ولحمانهم، كَمَا ينْبت الأَرْض الثرى.</p><p>تَفْسِير الْآيَات من ١٢ وَحَتَّى ١٥ من سُورَة ق.</p></div>"
  50,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذبت قبلهم﴾</span> قبل يَوْمك يَا محمدُ <span class="qpc-hafs">﴿قَوْمُ نُوحٍ وَأَصْحَابُ الرس﴾</span> الرس: بِئْر كَانَ (ل ٣٣٥) عَلَيْهَا قوم فنسبوا إِلَيْهَا.</p></div>"
  50,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وإخوان لوط﴾</span> إخْوَان فِي النّسَب لَا فِي الدّين <span class="qpc-hafs">﴿وَأَصْحَاب الأيكة﴾</span> الغيضة وَقد فسرنا أَمرهم فِي سُورَة الشُّعَرَاء</p></div>"
  50,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَوْمُ تُبَّعٍ كُلٌّ كَذَّبَ الرُّسُلَ فَحق وَعِيد﴾</span> يَقُول: جَاءَتْهُم الرُّسُل يَدعُونَهُمْ إِلَى الْإِيمَان، ويحذرونهم الْعَذَاب، فكذبوهم فَجَاءَهُمْ الْعَذَاب، يحذر بِهَذَا مُشْركي الْعَرَب</p></div>"
  50,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أفعيينا بالخلق الأول﴾</span> تَفْسِير الْحسن: يَعْنِي: خلق آدمَ، أَي: لم يعي بِهِ <span class="qpc-hafs">﴿بَلْ هم فِي لبس﴾</span> فِي شكٍّ <span class="qpc-hafs">﴿مِنْ خَلْقٍ جَدِيدٍ﴾</span> يَعْنِي: الْبَعْث.</p><p>قَالَ محمدٌ: الْمَعْنى: لم يعي بالخلق الأول، وَكَذَلِكَ لَا يعيى بالخلق الثَّانِي وَهُوَ الْبَعْث، وَهُوَ الَّذِي أَرَادَ الْحسن، وَيُقَال: عَيِيَ بأَمْره يَعْيَى عَيَاءً، وأعيا فِي الْمَشْي إعياء.</p><p>تَفْسِير الْآيَات من ١٦ وَحَتَّى ٢٢ من سُورَة ق.</p></div>"