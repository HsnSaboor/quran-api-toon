quran[28]{c,v,t}:
  74,48,"<div class=ar lang=ar><p>قَالَ اللَّهُ: <span class="qpc-hafs">﴿فَمَا تَنْفَعُهُمْ شَفَاعَةُ الشافعين﴾</span> أَيْ: لَا يَشْفَعُ لَهُمُ الشَّافِعُونَ.</p><p>يَحْيَى: عَنْ أَبِي أُمَيَّةَ، عَنْ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ قَالَ: قَالَ رَسُولُ اللَّهِ ﷺ «إِذَا كَانَ يَوْمُ الْقِيَامَةِ شَفَعَ النَّبِيُّ لِأُمَّتِهِ، وَالشَّهِيدُ لِأَهْلِ بَيْتِهِ، وَالْمُؤْمِنُ لِأَهْلِ بَيْتِهِ، وَتَبْقَى شَفَاعَةُ الرَّحْمَنِ يُخْرِجُ اللَّهُ أَقْوَامًا مِنَ النَّارِ قَدِ احْتَرَقُوا وَصَارُوا فَحْمًا فَيُؤْمَرُ بِهِمْ إِلَى نَهْرٍ فِي الْجَنَّةِ - يُقَالُ لَهُ: الْحَيَاةُ - فَيَنْبُتُونَ كَمَا يَنْبُتُ الْغُثَاءُ فِي بَطْنِ الْمَسِيلِ، ثُمَّ يَقُومُونَ فَيَدْخُلُونَ الْجَنَّةَ فَهُمْ آخِرُ أَهْلِ الْجَنَّةِ دُخُولًا وأدناهم منزلَة».</p></div>"
  74,49,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿فَمَا لَهُمْ عَنِ التَّذْكِرَةِ معرضين﴾</span> عَن الْقُرْآن</p></div>"
  74,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَنَّهُمْ حمر مستنفرة﴾</span> أَي: حمر وَحش</p></div>"
  74,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فرت من قسورة﴾</span> تَفْسِيرُ بَعْضِهِمُ الْقَسْوَرَةُ: الأسدُ.</p><p>قَالَ محمدٌ: (معرضين) مَنْصُوبٌ عَلَى الْحَالِ، وَمَعْنَى مُسْتَنْفِرَةٌ مَذْعُورَة استُنفرتْ فنفرت، قيل: إِنَّ اشْتِقَاقِ قَسْوَرَةٍ مِنَ القسْر وَهُوَ الْقَهْرِ؛ لأَنَّ الْأَسَدَ يَقْهَرُ السبَاع.</p></div>"
  74,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنْهُمْ﴾</span> يَعْنِي: مُشْرِكِي قُرَيْشٍ <span class="qpc-hafs">﴿أَنْ يُؤْتَى صحفا منشرة﴾</span> إِلَى كُلِّ إنسانٍ بِاسْمِهِ أَنْ آمِنْ بمحمدٍ قَالَ اللَّهُ <span class="qpc-hafs">﴿كَلَّا﴾</span> أَنْتُمْ أَهْوَنُ عَلَى اللَّهِ مِنْ ذَلِك</p></div>"
  74,53,"<div class=ar lang=ar><p>ثمَّ قَالَ <span class="qpc-hafs">﴿بل لَا تخافون الْآخِرَة﴾</span> لَا يُؤمنُونَ بهَا</p></div>"
  74,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كلا إِنَّه تذكرة﴾</span> يَعْنِي: الْقُرْآنَ <span class="qpc-hafs">﴿فَمَنْ شَاءَ ذَكَرَهُ﴾</span>.</p></div>"
  74,55,"<div class=ar lang=ar></div>"
  74,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ أهل التَّقْوَى﴾</span> أَيْ: أَهْلُ أَنْ يُتَّقَى <span class="qpc-hafs">﴿وَأَهْلُ الْمَغْفِرَة﴾</span> أَهْلُ أَنْ يَغْفِرَ، وَلا يَغْفِرُ إِلَّا لِلْمُؤْمِنِينَ.</p></div>"
  75,1,"<div class=ar lang=ar><p>تَفْسِيرِ لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم تَفْسِير سُورَة الْقِيَامَة من آيَة (١ - ١٩)</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ﴾</span> الْمَعْنى: أقسم و «لَا» صلَة،</p></div>"
  75,2,"<div class=ar lang=ar><p>وَكَذَلِكَ قَوْلُهُ <span class="qpc-hafs">﴿وَلا أُقْسِمُ بِالنَّفْسِ اللوامة﴾</span> مَعْنَاهُ أقسم. قَالَ الْحسن: وَهُوَ نفسُ الْمُؤْمِنِ، إِنَّ الْمُؤْمِنَ لَا تَلْقَاهُ إِلَّا وَهُوَ يَلُومُ نَفْسَهُ، يَقُولُ: مَا أَرَدْتُ بِكَلامِي، مَا أَرَدْتُ بِكَذَا، مَا أَرَدْتُ بِكَذَا، يَنْدَمُ عَلَى مَا فَاتَ، وَيَلُومُ نَفسه</p></div>"
  75,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أيحسب الْإِنْسَان﴾</span> وَهُوَ الْمُشْرِكُ <span class="qpc-hafs">﴿أَنْ لَنْ نَجْمَعَ عِظَامه﴾</span> أَي: أَن لن نبعثه</p></div>"
  75,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلَى قَادِرِينَ عَلَى أَنْ نُسَوِّيَ بنانه﴾</span> يَعْنِي: مَفَاصِلَهُ.</p><p>قَالَ مُحَمَّدٌ: (قَادِرِينَ) حَالٌ بِمَعْنَى: بَلَى نَجْمَعُهَا قَادِرِينَ.</p></div>"
  75,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلْ يُرِيدُ الإِنْسَانُ لِيَفْجُرَ أَمَامَهُ﴾</span> وَهُوَ الْمُشْرِكُ؛ يَعْنِي: أَنَّهُ يَمْضِي عَلَى فُجُورِهِ لَا يُعَاتِبُ نَفْسَهُ حَتَّى يلقى ربه</p></div>"
  75,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يسْأَل أَيَّانَ يَوْم الْقِيَامَة﴾</span> مَتَى يَوْمُ الْقِيَامَةِ؛ أَيْ: لَيست بجائية يكذب بهَا.</p></div>"
  75,7,"<div class=ar lang=ar><p>قَالَ اللَّهُ: <span class="qpc-hafs">﴿فَإِذَا بَرِقَ الْبَصَرُ﴾</span> يَعْنِي: يَوْمَ الْقِيَامَةِ؛ أَيْ: شَخُصَ لِإِجَابَةِ الدَّاعِي كَقَوْلِهِ: <span class="qpc-hafs">﴿لَا يَرْتَدُّ إِلَيْهِم طرفهم﴾</span> هَذَا تَفْسِيرُ الْحَسَنِ.</p><p>قَالَ محمدٌ: مَنْ قَرَأَ (برَق الْبَصَرُ) بِفَتْحِ الرَّاءِ أَرَادَ: بَرِيقَه إِذَا شَخُصَ، يُقَالُ: بَرَقَ يَبْرُق، وَمَنْ قَرَأَ بَرِقَ - بِكَسْرِ الرَّاءِ - فَمَعْنَاهُ: فَزِعَ وتحَّير. يُقَالُ مِنْهُ: بَرِقَ يَبْرَقُ.</p></div>"
  75,8,"<div class=ar lang=ar></div>"
  75,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجمع الشَّمْس وَالْقَمَر﴾</span> أَيْ: جَمَعَهُمَا جَمِيعًا؛ فِي تَفْسِيرِ الْحسن.</p></div>"
  75,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُولُ الإِنْسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ﴾</span> قَالَ:</p></div>"
  75,11,"<div class=ar lang=ar></div>"
  75,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَى رَبك يَوْمئِذٍ المستقر﴾</span> الْمرجع</p></div>"
  75,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنَبَّأُ الإِنْسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ﴾</span></p></div>"
  75,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلِ الإِنْسَانُ عَلَى نَفْسِهِ بَصِيرَةٌ﴾</span> شَاهِدٌ عَلَى نَفْسِهِ أَنَّهُ كَافِرٌ لَمْ يُقْبَلْ مِنْهُ.</p><p>قَالَ محمدٌ: وَقِيلَ: إِنَّ الْمَعَاذِيرَ السُّتُورُ بِلُغَةِ.</p></div>"
  75,15,"<div class=ar lang=ar></div>"
  75,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تحرّك بهَا لسَانك لتعجل بِهِ﴾</span> تفسيرالحسن: كَانَ رَسُول الله إِذا (ل ٣٨٠) نَزَلَ عَلَيْهِ الْقُرْآنُ يُدْئِبُ نَفْسَهُ فِي قَرَاءَتِهِ، مَخَافَةَ أَنْ يَنْسَاهُ، فَأَنْزَلَ اللَّهُ: <span class="qpc-hafs">﴿لَا تُحَرِّكْ بِهِ لسَانك لتعجل بِهِ﴾</span></p></div>"
  75,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا علينا جمعه وقرآنه﴾</span> أَيْ: نَحْنُ نَحْفَظُهُ عَلَيْكَ فَلا تنساه</p></div>"
  75,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِذا قرأناه﴾</span> نَحن <span class="qpc-hafs">﴿فَاتبع﴾</span> أَنْت <span class="qpc-hafs">﴿قرآنه﴾</span> يَعْنِي: فَرَائِضَهُ وَحُدُودَهُ وَالْعَمَلَ بِهِ</p></div>"
  75,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثمَّ إِن علينا بَيَانه﴾</span> تَفْسِيرُ بَعْضِهِمْ: نَحْنُ نبيَّنه لَكَ.</p></div>"