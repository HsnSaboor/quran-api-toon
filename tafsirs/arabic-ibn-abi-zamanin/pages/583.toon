quran[25]{c,v,t}:
  78,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن لِلْمُتقين مفازا﴾</span> نجاة مِمَّا أعدّ للْكَافِرِينَ</p></div>"
  78,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حدائق﴾</span> جنَّات <span class="qpc-hafs">﴿وأعنابا﴾</span> أَي: فِيهَا أعنابٌ</p></div>"
  78,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وكواعب أَتْرَابًا﴾</span> عَلَى سنٍّ وَاحِدَة بَنَات ثَلَاث وَثَلَاثِينَ سنة</p></div>"
  78,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وكأسا دهاقا﴾</span> أَي: ممتلئة</p></div>"
  78,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يسمعُونَ فِيهَا لَغوا﴾</span> اللَّغْو: الْبَاطِل <span class="qpc-hafs">﴿وَلَا كذابا﴾</span> تَفْسِيرُ الْحَسَنِ يَقُولُ: لَا يَكْذِبُ بَعْضُهُمْ بَعْضًا.</p><p>قَالَ مُحَمَّدٌ: مَنْ قَرَأَ (كذَّابًا) مثقَّلة، فَمِنْ قَوْلِهِمْ: كَذَّابٌ كَذَّبَ بِمَعْنى وَاحِد.</p></div>"
  78,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَزَاءً مِنْ رَبِّكَ عَطَاءً حِسَابًا﴾</span> تَفْسِيرُ مُجَاهِدٍ: يَعْنِي: عَلَى قَدْرِ أَعْمَالِهِمْ؛ وَذَلِكَ أَنَّهُمْ يُعْطَوْنَ الْمَنَازِلَ عَلَى قَدْرِ أَعْمَالِهِمْ، ثُمَّ يُرْزَقُونَ فِيهَا بِغَيْرِ حِسَابٍ قَالَ مُحَمَّد: (جزاءٌ) مَنْصُوب بِمَعْنى: جزاهم جزاءًا.</p></div>"
  78,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رب السَّمَوَات وَالْأَرْض﴾</span> <span class="qpc-hafs">﴿ربُّ﴾</span> بِالرَّفْعِ كَلامٌ مُسْتَقْبَلٌ فِي قِرَاءَةِ مَنْ قَرَأَهَا بِالرَّفْعِ <span class="qpc-hafs">﴿وَمَا بَيْنَهُمَا الرَّحْمَنِ لَا يَمْلِكُونَ مِنْهُ خِطَابًا﴾</span> تَفْسِيرُ الْحَسَنِ: لَا يَسْتَطِيعُونَ مُخَاطَبَتَهُ، كَقَوْلِهِ: <span class="qpc-hafs">﴿يَوْمَ يَأْتِ لَا تَكَلَّمُ نفسٌ إِلَّا بِإِذْنِهِ﴾</span> قَوْله:</p></div>"
  78,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم يقوم الرّوح﴾</span> تَفْسِيرُ الْحَسَنِ: يَقُومُ رُوحُ كُلِّ شَيْءٍ فِي جَسَدِهِ <span class="qpc-hafs">﴿وَالْمَلائِكَةُ صَفًّا لَا يَتَكَلَّمُونَ﴾</span> لَا يَشْفَعُونَ <span class="qpc-hafs">﴿إِلا مَنْ أَذِنَ لَهُ الرَّحْمَن وَقَالَ صَوَابا﴾</span> فِي الدُّنْيَا لَا إِلَهَ إِلَّا الله.</p></div>"
  78,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَنْ شَاءَ اتخذ إِلَى ربه مآبا﴾</span> مَرْجِعًا بِعَمَلٍ صَالِحٍ، وَقَالَ فِي آيَةٍ أُخْرَى: <span class="qpc-hafs">﴿وَمَا تَشَاءُونَ إِلا أَن يَشَاء الله﴾</span>.</p></div>"
  78,40,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿إِنَّا أَنْذَرْنَاكُمْ عَذَابًا قَرِيبًا﴾</span>.</p><p>يَحْيَى: عَنِ الْمُبَارَكِ، عَنِ الْحَسَنِ قَالَ: قَالَ رَسُولُ اللَّهِ ﷺ: «إِنَّمَا مَثَلِي وَمَثَلُ السَّاعَةِ كَهَاتَيْنِ، فَمَا فَضَّلَ إِحْدَاهُمْا عَلَى الأُخْرَى. وَجَمَعَ بَيْنَ أَصْبَعَيْهِ الْوُسْطَى وَالَّذِي يَقُولُ النَّاسُ السَّبَّابَةُ».</p><p><span class="qpc-hafs">﴿يَوْمَ يَنْظُرُ الْمَرْءُ مَا قدمت يَدَاهُ﴾</span> الْآيَةُ</p><p>يَحْيَى: عَنِ الصَّلْتِ بْنِ دِينَارٍ عَنْ عَلْقَمَةَ بْنِ قَالَ: قَالَ رَسُولُ اللَّهِ ﷺ «أول مَنْ يُدْعَى يَوْمَ الْقِيَامَةِ إِلَى الْحِسَابِ الْبَهَائِمُ، فتُجْعَل الْقَرْنَاءُ جَمَّاءَ، وَالْجَمَّاءُ قَرْنَاءَ، فَيَقْتَصُّ لِبَعْضِهَا مِنْ بَعْضٍ؛ حَتَّى تَقْتَصَّ الْجَمَّاءُ مِنَ الْقَرْنَاءِ، ثُمَّ يُقَالُ لَهَا: كُونِي تُرَابًا. فَعِنْدَ ذَلِكَ يَقُولُ الْكَافِرُ: <span class="qpc-hafs">﴿يَا لَيْتَني كنت تُرَابا﴾</span>»</p></div>"
  79,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ النَّازِعَاتِ وَهِيَ مَكِّيَّةٌ كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ تَفْسِير سُورَة النازعات من آيَة (١ - ١٤) قَوْله: <span class="qpc-hafs">﴿والنازعات غرقا﴾</span> تَفْسِيرُ الْحَسَنِ: هِيَ النُّجُومُ تُنْزَعُ مِنَ الْمَشْرِقِ، وَتَغْرِقُ فِي الْمَغْرِبِ</p></div>"
  79,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والناشطات نشطا﴾</span> (ل ٣٨٥) قَالَ الْحَسَنُ: هِيَ النُّجُومُ تَنْشَطُ من مشارقها إِلَى مغاربها</p></div>"
  79,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والسابحات سبحا﴾</span> النُّجُومُ لِقَوْلِهِ: <span class="qpc-hafs">﴿كُلٌّ فِي فَلَكٍ يسبحون﴾</span> يدورون</p></div>"
  79,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فالسابقات سبقا﴾</span> تَفْسِيرُ الْحَسَنِ: هِيَ الْمَلائِكَةُ سَبَقُوا إِلَى طَاعَة الله</p></div>"
  79,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فالمدبرات أمرا﴾</span> الْمَلائِكَةُ يُدَبِّرُ اللَّهُ بِهِمْ مَا أَرَادَ.</p><p>قَالَ مُحَمَّدٌ: قِيلَ: إِنَّ جَوَاب (والنازعات) محذوفٌ، الْمَعْنَى - وَاللَّهُ أَعْلَمُ -: كَأَنَّهُ أَقْسَمَ فَقَالَ: وَهَذِهِ الْأَشْيَاءِ لتُبْعَثُنّ.</p></div>"
  79,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم ترجف الراجفة﴾</span> النفخة الأولى</p></div>"
  79,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تتبعها الرادفة﴾</span> النفخة الْأُخْرَى.</p></div>"
  79,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلُوب يَوْمئِذٍ واجفة﴾</span> مضطربة شَدِيدَة الِاضْطِرَاب</p></div>"
  79,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أبصارها﴾</span> أبصار تِلْكَ الْقُلُوب <span class="qpc-hafs">﴿خاشعة﴾</span> ذليلة</p></div>"
  79,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُولُونَ﴾</span> يَقُولُ الْمُشْرِكُونَ فِي الدُّنْيَا: (أَئِنَّا لمردودون فِي الحافرة} أَي: فِي أول خلقنَا</p></div>"
  79,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذا كُنَّا عظامًا نخرة﴾</span> بَالِيَةً يُنْكِرُونَ الْبَعْثَ.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ: رَجَعَ فُلانٌ فِي حَافِرَتِهِ إِذَا رَجَعَ فِي الطَّرِيقِ الَّذِي جَاءَ فِيهِ</p></div>"
  79,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تِلْكَ إِذا كرة خاسرة﴾</span> كَاذِبَةٌ؛ أَيْ: لَيْسَتْ بِكَائِنَةٍ.</p><p>قَالَ مُحَمَّدٌ: وَقِيلَ: الْمَعْنَى: تِلْكَ إِذًا رجعةٌ يخسر فِيهَا،</p></div>"
  79,13,"<div class=ar lang=ar><p>قَالَ اللَّهُ <span class="qpc-hafs">﴿فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَة﴾</span> أَي: نفخة</p></div>"
  79,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِذا هم بالساهرة﴾</span> أَيْ: بِالْأَرْضِ قَدْ خَرَجُوا مِنْ بَطْنِهَا.</p><p>قَالَ مُحَمَّدٌ: السَّاهِرَةُ عِنْدَ أَهْلِ اللُّغَةِ: وَجْهُ الْأَرْضِ، وَهُوَ معنى قَول يحيى.</p></div>"
  79,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَل أَتَاك حَدِيث مُوسَى﴾</span> أَي: قد أَتَاك</p></div>"