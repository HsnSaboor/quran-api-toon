quran[24]{c,v,t}:
  53,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّهُ خَلَقَ الزَّوْجَيْنِ الذَّكَرَ وَالأُنْثَى﴾</span> الْوَاحِد مِنْهُمَا: زوج</p></div>"
  53,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿من نُطْفَة إِذا تمنى﴾</span> إِذا يمنيها الذّكر <span class="qpc-hafs">﴿وَأَنَّ عَلَيْهِ النشأة الْأُخْرَى﴾</span></p></div>"
  53,47,"<div class=ar lang=ar></div>"
  53,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنه هُوَ أغْنى وأقنى﴾</span> أغْنى عَبده، وأقناه من قِبَل القِنْيَة.</p><p>قَالَ محمدٌ: تَقول: أَقْنَيْتُ كَذَا أَي: عملتُ على أَنه يكون عِنْدِي لَا أخرجه من يَدي؛ فَكَأَن معنى (أقنى) جعل الْغنى أصلا لصَاحبه ثَابتا.</p></div>"
  53,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنه هُوَ رب الشعرى﴾</span> الْكَوْكَب الَّذِي خلف الجوزاء كَانَ يَعْبُدهَا قوم</p></div>"
  53,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنه أهلك عادا الأولى﴾</span> وَهِي عادٌ وَاحِدَة، لمْ يكن قبلهَا عَاد قَالَ:</p></div>"
  53,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَثَمُودًا فَمَا أَبْقَى﴾</span> أهلكهم فَلم يبقهم</p></div>"
  53,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقوم نوح﴾</span> أَي: وَأهْلك قوم نوحٍ <span class="qpc-hafs">﴿مِنْ قَبْلُ إِنَّهُمْ كَانُوا هُمْ أَظْلَمَ وأطغى﴾</span> كَانُوا أول من كذب الرُّسُل.</p></div>"
  53,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والمؤتفكة أَهْوى﴾</span> يَعْنِي قرى قوم لوط رَفعهَا جِبْرِيل بجناحه، حَتَّى سمع أهْل سَمَاء الدُّنْيَا ضواغي كلابهم ثمَّ قَلبهَا، والمؤتفكة: المنقلبة.</p><p>قَالَ محمدٌ: أَهْوى: أسْقط. يُقَال: هوى وأهواه الله: أسْقطه.</p></div>"
  53,54,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿فغشاها مَا غشى﴾</span> يَعْنِي: الْحِجَارَةَ الَّتِي رُمِيَ بِهَا من كَانَ مِنْهُم خَارِجا من الْمَدِينَة وَأهل السّفر مِنْهُم.</p></div>"
  53,55,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿فَبِأَي آلَاء﴾</span> يَعْنِي نعماء <span class="qpc-hafs">﴿رَبك تتمارى﴾</span> تشك أَي: إِنَّك لَا تشك</p></div>"
  53,56,"<div class=ar lang=ar><p>ثمَّ قَالَ للنَّاس: <span class="qpc-hafs">﴿هَذَا نَذِيرٌ﴾</span> يَعْنِي: مُحَمَّدًا <span class="qpc-hafs">﴿مِنَ النُّذُرِ الأُولَى﴾</span> أَي: جَاءَ بِمَا جَاءَت بِهِ الرُّسُل الأولى</p></div>"
  53,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أزفت الآزفة﴾</span> أَي: دنت الْقِيَامَة</p></div>"
  53,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيْسَ لَهَا مِنْ دُونِ اللَّهِ كاشفة﴾</span> كَأَن الْمَعْنى: لَيْسَ لَهَا وقعةٌ كاشفةٌ، وَالله أعلم <span class="qpc-hafs">﴿أَفَمِنْ هَذَا الحَدِيث تعْجبُونَ﴾</span></p></div>"
  53,59,"<div class=ar lang=ar></div>"
  53,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَضْحَكُونَ﴾</span> يَعْنِي: الْمُشْركين، أَي: قد فَعلْتُمْ <span class="qpc-hafs">﴿وَلَا تَبْكُونَ﴾</span> أَي: يَنْبَغِي لكم أَن تبكوا</p></div>"
  53,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنْتُم سامدون﴾</span> قَالَ: غافلون</p></div>"
  53,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاسجدوا لله﴾</span> فصلوا لله <span class="qpc-hafs">﴿واعبدوا﴾</span> أَي: واعبدوه وَلَا تُشْرِكُوا بِهِ شَيْئا.</p><p>قَالَ محمدٌ: سامدون مَعْنَاهُ لاهون وَهِي لُغَة الْيمن.</p></div>"
  54,1,"<div class=ar lang=ar><p>تَفْسِير سُورَة اقْتَرَبت السَّاعَة</p><p>وَهِي مَكِّيَّة كلهَا</p><p>بِسم الله الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿اقْتَرَبت السَّاعَة﴾</span> أَي دنت. يحيى: عَن أبي الأَشْهَبِ، عَنِ الْحَسَنِ قَالَ: قَالَ رَسُولَ اللَّهِ ﷺ: " إِنَّمَا مَثَلِي وَمَثَلُ السَّاعَةِ كَهَاتَيْنِ، فَمَا فَضَّلَ إِحْدَاهُمْا عَلَى الأُخْرَى، وَجَمَعَ بَيْنَ أُصْبُعَيْهِ الْوُسْطَى وَالَّتِي يَقُول النَّاس السَّبَّابة ".</p><p><span class="qpc-hafs">﴿وَانْشَقَّ الْقَمَر﴾</span> قَالَ ابْن مَسْعُود: " انْشَقَّ الْقَمَر شقين حَتَّى رَأَيْت أَبَا قبيس بَينهمَا "</p></div>"
  54,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن يرَوا آيَة﴾</span> يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿يُعْرِضُوا وَيَقُولُوا سِحْرٌ مُسْتَمر﴾</span> ٌ ذَاهِب</p></div>"
  54,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكُلُّ أَمْرٍ مُسْتَقر﴾</span> لأَهله من الْخَيْر وَالشَّر.</p><p>قَالَ محمدٌ: يَقُول: يسْتَقرّ لأهل الْجنَّة عَمَلهم، وَلأَهل النَّار عَمَلهم. وَالِاخْتِيَار لِأَنَّهُ ابْتِدَاء.</p></div>"
  54,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَد جَاءَهُم من الأنباء﴾</span> يَعْنِي: أَخْبَار الْأُمَم (ل ٣٤٥) فأهلكهم اللَّه <span class="qpc-hafs">﴿مَا فِيهِ مُزْدَجَرٌ﴾</span> عَمَّا هم عَلَيْهِ من الشّرك</p></div>"
  54,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِكْمَة بَالِغَة﴾</span> يَعْنِي: الْقُرْآن.</p><p>قَالَ محمدٌ: (حِكْمَةٌ بَالِغَة) بِالرَّفْع على معنى: فَهُوَ حِكْمَة بَالِغَة.</p><p><span class="qpc-hafs">﴿فَمَا تغن النّذر﴾</span> عَمَّن لَا يُؤمن</p></div>"
  54,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ يَوْمَ يَدْعُ الدَّاعِي إِلَى شَيْءٍ نُّكُرٍ﴾</span> عَظِيم، والداع هُوَ صَاحب الصُّور.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿يدع﴾</span> كتب بِحَذْف الْوَاو على مَا يجْرِي فِي اللَّفْظ لالتقاء الساكنين الْوَاو من (يَدْعُو) وَاللَّام من (الداع) وَقَوله: (نكر) بِضَم الْكَاف وإسكانها، والنكر وَالْمُنكر واحدٌ.</p><p>قَالَ النَّابِغَة:</p><p>(أَبَى اللَّهُ إِلَّا عَدْلَهُ ووَفَاءَهُ ... فَلَا النُّكْرُ مَعْروفٌ وَلَا الْعرف ضائع)</p></div>"