quran[23]{c,v,t}:
  26,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَمَّا ترَاءى الْجَمْعَانِ﴾</span> جَمْعُ مُوسَى وَجَمْعُ فِرْعَوْنَ <span class="qpc-hafs">﴿قَالَ أَصْحَابُ مُوسَى إِنَّا لَمُدْرَكُونَ﴾</span></p></div>"
  26,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ﴾</span> مُوسَى <span class="qpc-hafs">﴿كَلَّا إِنَّ مَعِيَ رَبِّي سيهدين﴾</span> إِلَى الطَّرِيق</p></div>"
  26,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَوْحَيْنَا إِلَى مُوسَى أَنِ اضْرِبْ بعصاك الْبَحْر﴾</span> جَاءَهُ جِبْرِيلُ عَلَى فَرَسٍ، فَأَمَرَهُ أَنْ يَضْرِبَ الْبَحْرَ بِعَصَاهُ؛ فَضَرَبَهُ <span class="qpc-hafs">﴿فانفلق﴾</span> الْبَحْرُ <span class="qpc-hafs">﴿فَكَانَ كُلُّ فِرْقٍ كَالطَّوْدِ الْعَظِيم﴾</span> وَالطَّوْدُ: الْجَبَلُ.</p><p>قَالَ قَتَادَةُ: صَارَ اثْنَى عَشْرَ طَرِيقًا لِكُلِّ سِبْطٍ طَرِيقٌ، وَصَارَ مَا بَيْنَ كُلِّ طَرِيقَيْنِ مِنْهُ مِثْلُ الْقَنَاطِيرِ يَنْظُرُ بَعضهم إِلَى بعض</p></div>"
  26,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأزلفنا ثمَّ الآخرين﴾</span> قَالَ قَتَادَةُ: يَقُولُ: أَدْنَيْنَا فِرْعَوْنَ وَجُنُودَهُ إِلَى الْبَحْرِ. قَالَ قَتَادَةُ: يُقَالُ: أَزْلَفَنِي كَذَا؛ أَيْ: أَدْنَانِي مِنْهُ</p></div>"
  26,65,"<div class=ar lang=ar></div>"
  26,66,"26:65"
  26,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن فِي ذَلِك لآيَة﴾</span> لَعِبْرَةً لِمَنِ اعْتَبَرَ وَحَذِرَ أَنْ يَنْزِلَ بِهِ مَا نَزَلَ بِهِمْ.</p></div>"
  26,68,"<div class=ar lang=ar></div>"
  26,69,"26:68"
  26,70,"26:68"
  26,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنَظَلُّ لَهَا عاكفين﴾</span> أَيْ: نَصِيرُ مُقِيمِينَ عَلَى عِبَادَتِهَا.</p></div>"
  26,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ هَلْ يَسْمَعُونَكُمْ إِذْ تَدْعُونَ أَو ينفعونكم أَو يضرون﴾</span> أَي: أَنَّهَا لَا تسمع ولاتنفع وَلَا تضر</p></div>"
  26,73,"<div class=ar lang=ar></div>"
  26,74,"26:73"
  26,75,"26:73"
  26,76,"26:73"
  26,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّهُمْ عَدُوٌّ لِي إِلا رَبَّ الْعَالمين﴾</span> أَيْ: إِلَّا مَنْ عَبَدَ رَبَّ الْعَالَمِينَ مِنْ آبَائِكُمُ الْأَوَّلِينَ؛ فَإِنَّهُ لَيْسَ لِي بِعَدُوٍ؛ هَذَا تَفْسِيرُ الْحسن</p></div>"
  26,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي خلقني فَهُوَ يهدين﴾</span> يَعْنِي: الَّذِي خلقني وهداني</p></div>"
  26,79,"<div class=ar lang=ar></div>"
  26,80,"26:79"
  26,81,"26:79"
  26,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِي أطمع﴾</span> وَهَذَا طَمَعُ يَقِينٍ <span class="qpc-hafs">﴿أَنْ يَغْفِرَ لي خطيئتي﴾</span> يَعْنِي: قَوْله: <span class="qpc-hafs">﴿إِنِّي سقيم﴾</span> وَقَوْلَهُ: <span class="qpc-hafs">﴿بَلْ فَعَلَهُ كَبِيرُهُمْ هَذَا﴾</span> وَقَوْلَهُ لِسَارَّةَ: إِنْ سَأَلُوكِ فَقُولِي أَنَّك أُخْتِي <span class="qpc-hafs">﴿يَوْم الدّين﴾</span> يُرِيدُ: يَدِينُ اللَّهُ النَّاسَ فِيهِ بأعمالهم (ل ٢٤٤) أَي: يجازيهم</p></div>"
  26,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رب هَب لي حكما﴾</span> أَيْ: ثَبِّتْنِي عَلَى النُّبُوَّةِ <span class="qpc-hafs">﴿وَأَلْحِقْنِي بالصالحين﴾</span> يَعْنِي أهل الْجنَّة.</p></div>"