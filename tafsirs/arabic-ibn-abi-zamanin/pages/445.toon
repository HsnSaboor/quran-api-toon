quran[13]{c,v,t}:
  36,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَلَمْ يَرَوْا أَنَّا خَلَقْنَا لَهُمْ مِمَّا عَمِلَتْ أَيْدِينَا﴾</span> <span class="qpc-hafs">﴿ل ٢٨٦﴾</span> أَي: قوتنا فِي تَفْسِير الْحَسَن كَقَوْلِه: <span class="qpc-hafs">﴿وَالسَّمَاء بنيناها بأيد﴾</span> [أَي: بِقُوَّة]</p></div>"
  36,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وذللناها لَهُم فَمِنْهَا ركوبهم﴾</span> أَي: مَا يركبون.</p><p>قَالَ محمدٌ: (الرَّكُوب) بِفَتْح الرَّاء اسْمُ مَا يركب، والرُّكوب المصدرُ، وَيُقَال: مكانٌ ركُوب، يُرِيدُونَ الِاسْم.</p></div>"
  36,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَهُم فِيهَا مَنَافِع﴾</span> فِي أصوافها، وأوبارها، وَأَشْعَارهَا، ولحومها <span class="qpc-hafs">﴿ومشارب﴾</span> يشربون من أَلْبَانهَا <span class="qpc-hafs">﴿أَفَلا يَشْكُرُونَ﴾</span> أَي: فليشكروا</p></div>"
  36,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاتَّخَذُوا مِنْ دُونِ اللَّهِ آلِهَةً لَعَلَّهُم ينْصرُونَ﴾</span> يمْنَعُونَ</p></div>"
  36,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَسْتَطِيعُونَ نَصرهم﴾</span> لَا تَسْتَطِيع آلِهَتهم الَّتِي يعْبدُونَ نَصْرَهُمْ <span class="qpc-hafs">﴿وَهُمْ لَهُمْ جُنْدٌ مُحْضَرُونَ﴾</span> مَعَهم فِي النَّار؛ فِي تَفْسِير قَتَادَة</p></div>"
  36,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا يحزنك قَوْلهم﴾</span> إِنَّكَ سَاحِرٌ، وَإِنَّكَ شَاعِرٌ [وَإِنَّكَ كَاهِنٌ] وَأَنَّكَ مَجْنُونٌ، وَأَنَّكَ كَاذِبٌ <span class="qpc-hafs">﴿إِنَّا نعلم مَا يسرون﴾</span> من عداوتهم لَك <span class="qpc-hafs">﴿وَمَا يُعْلِنُونَ﴾</span> فيعصمك اللَّه مِنْهُم ويذلهم لَك، فَفعل الله ذَلِك بِهِ.</p></div>"
  36,77,"<div class=ar lang=ar></div>"
  36,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَرَبَ لَنَا مَثَلا وَنَسِيَ خَلْقَهُ﴾</span> أَي: وَقد علم أَنَا خلقناه؛ أَي: فَكَمَا خلقناه كَذَلِك نعيده <span class="qpc-hafs">﴿قَالَ مَنْ يُحْيِي الْعِظَامَ وَهِيَ رَمِيم﴾</span> أَي: رُفات.</p><p>قَالَ محمدٌ: يُقَال: رمّ العظْمُ فَهُوَ رَمِيم ورِمَامٌ.</p><p>قَالَ مُجَاهِد: " أَتَى أُبيُّ بْن خلف إِلَى النَّبِيّ ﷺ بعظْمٍ نَخِرٍ ففتَّه بِيَدِهِ؛ فَقَالَ: يَا محمدُ، أَيُحْيِي اللَّه هَذَا وَهُوَ رَمِيم؟! ".</p><p>قَالَ يَحْيَى: فبلغني أَن النَّبِيّ ﷺ قَالَ لَهُ: " نعم يُحْيِيك اللَّه بعد موتك، ثمَّ يدْخلك النَّار "؟ فَأنْزل اللَّه <span class="qpc-hafs">﴿قُلْ يُحْيِيهَا الَّذِي أَنْشَأَهَا﴾</span> خلقهَا <span class="qpc-hafs">﴿أَوَّلَ مَرَّةٍ وَهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ﴾</span>.</p></div>"
  36,79,"<div class=ar lang=ar></div>"
  36,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمْ مِنَ الشَّجَرِ الْأَخْضَر نَارا﴾</span> يَعْنِي: كُلّ عودٍ تزند مِنْهُ النَّار، فَهُوَ من شَجَرَة خضراء</p></div>"
  36,81,"<div class=ar lang=ar></div>"
  36,82,"36:81"
  36,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِي بِيَدِهِ ملكوت﴾</span> (أَي: ملك) <span class="qpc-hafs">﴿كُلِّ شَيْءٍ وَإِلَيْهِ تُرْجَعُونَ﴾</span> يَوْم الْقِيَامَة.</p></div>"