quran[27]{c,v,t}:
  55,68,"55:67"
  55,69,"55:67"
  55,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِنَّ خيرات حسان﴾</span> يَعْنِي: النِّسَاء، الْوَاحِدَة مِنْهُنَّ: خيرة.</p><p>قَالَ مُحَمَّد: (خيرات) أصْلُه فِي اللُّغَة: خيراتٌ مخفف كَمَا يُقَال: هيْنٌ ليْنٌ الْمَعْنى: أَنَّهُنَّ حسان الْخلق.</p></div>"
  55,71,"<div class=ar lang=ar></div>"
  55,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حور﴾</span> أَي: بيض <span class="qpc-hafs">﴿مقصورات﴾</span> محبوسات <span class="qpc-hafs">﴿فِي الْخيام﴾</span> قَالَ ابْن عَبَّاس: الخيْمة: درّة مجوَّفة فَرسَخ فِي فَرسَخ، لَهَا أَرْبَعَة آلَاف مصراع.</p></div>"
  55,73,"<div class=ar lang=ar></div>"
  55,74,"55:73"
  55,75,"55:73"
  55,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿متكئين على رَفْرَف خضر﴾</span> قَالَ قَتَادَة: يَعْنِي: المحابس <span class="qpc-hafs">﴿وَعَبْقَرِيٍّ حسان﴾</span> قَالَ ابْن عَبَّاس: يَعْنِي: الوسائد.</p><p>قَالَ يحيى: الْوَاحِدَة: عبقرة.</p></div>"
  55,77,"<div class=ar lang=ar></div>"
  55,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تبَارك اسْم رَبك﴾</span> تقدَّس اسْم رَبك <span class="qpc-hafs">﴿ذِي الْجَلالِ﴾</span> العظمة <span class="qpc-hafs">﴿وَالْإِكْرَام﴾</span> لأهل طَاعَته.</p></div>"
  56,1,"<div class=ar lang=ar><p>تَفْسِير سُورَة الْوَاقِعَة وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ الله الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿إِذا وَقعت الْوَاقِعَة﴾</span> الْقِيَامَة</p></div>"
  56,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيْسَ لوقعتها كَاذِبَة﴾</span> أَي: هِيَ كَاذِبَة.</p><p>قَالَ محمدٌ: الْمَعْنى: لَيْسَ لوقعتها وقْعَة كَاذِبَة.</p></div>"
  56,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خافضة رَافِعَة﴾</span> خفضت وَالله أَقْوَامًا إِلَى النَّار، وَرفعت أَقْوَامًا إِلَى الْجنَّة</p></div>"
  56,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذا رجت الأَرْض رجا﴾</span> زلزلت زلزالا</p></div>"
  56,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وبست الْجبَال بسا﴾</span> فتت فتاة</p></div>"
  56,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَانَت هباء منبثا﴾</span> قَالَ الْحسن: يَعْنِي: غبارًا ذَا هباء</p></div>"
  56,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وكنتم أَزْوَاجًا ثَلَاثَة﴾</span> أصنافا</p></div>"
  56,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَصْحَابُ الْمَيْمَنَةِ مَا أَصْحَابُ الْمَيْمَنَةِ﴾</span> وهم الميامين على أنفسهم</p></div>"
  56,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصْحَابُ الْمَشْئَمَةِ مَا أَصْحَابُ الْمَشْئَمَةِ﴾</span> وهم المشائيم على أنفسهم.</p><p>قَالَ محمدٌ: قَوْله: <span class="qpc-hafs">﴿مَا أَصْحَابُ الْمَيْمَنَةِ﴾</span> هَذَا اللَّفْظ فِي الْعَرَبيَّة مجْرَاه مجْرى التَّعَجُّب، كَأَنَّهُ قَالَ: أَي شَيْء هُمْ؟ يُقَال فِي الْكَلَام: فلانٌ مَا فلانٌ، وَمَجْرَاهُ من اللَّه - عز وجلّ - فِي مُخَاطبَة الْعباد مَجْرى مَا يُعَظمُ بِهِ الشَّأْن عندهُمْ، وَكَذَلِكَ هَذَا فِي قَوْله: <span class="qpc-hafs">﴿مَا أَصْحَاب المشأمة﴾</span> أَي: أيّ شَيْء هم؟! وَيَقُول: يَمَنَ فلَان على الْقَوْم ويَمُن وَهُوَ ميمونٌ، وشأم الْقَوْم وشُئمَ عَلَيْهِم فَهُوَ مشئوم.</p></div>"
  56,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالسَّابِقُونَ السَّابِقُونَ﴾</span> تَفْسِير الْحسن: السَّابِقُونَ أَصْحَاب النَّبِي ﷺ وأصحابُ الْأَنْبِيَاء</p></div>"
  56,11,"<div class=ar lang=ar></div>"
  56,12,"56:11"
  56,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثلة من الْأَوَّلين﴾</span> والثلة: الطَّائِفَة</p></div>"
  56,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَلِيل من الآخرين﴾</span> يَعْنِي: أَن سابقي جَمِيع الْأُمَم أَكثر من سابقي أمة محمدٍ</p></div>"
  56,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿على سرر موضونة﴾</span> (ل ٣٥٠) مَرْمولة، ورَمَلها نسجها بالياقوت واللُّؤْلؤ</p></div>"
  56,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿متكئين عَلَيْهَا مُتَقَابلين﴾</span> لَا ينظر بعضُهم إِلَى قَفَا بعضٍ.</p><p>قَالَ يحيى: بَلغنِي أَن ذَلِك إِذا تزاوروا</p></div>"