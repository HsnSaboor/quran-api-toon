quran[25]{c,v,t}:
  20,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنا اخْتَرْتُك﴾</span> أَيْ: لِرِسَالَتِي وَلِكَلَامِي <span class="qpc-hafs">﴿فَاسْتَمِعْ لِمَا يُوحى﴾</span> إِلَيْك</p></div>"
  20,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأقم الصَّلَاة لذكري﴾</span> فِي تَفْسِيرِ مُجَاهِدٍ: إِذَا صَلَّى العَبْد ذكر الله</p></div>"
  20,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن السَّاعَة﴾</span> يَعْنِي: الْقِيَامَةَ <span class="qpc-hafs">﴿آتِيَةٌ أَكَادُ أُخْفِيهَا﴾</span> قَالَ قَتَادَةُ: هِيَ فِي قِرَاءَةِ أُبَيِّ: (أَكَادُ أُخْفِيهَا مِنْ نَفْسِي) <span class="qpc-hafs">﴿لِتُجْزَى كُلُّ نَفْسٍ بِمَا تَسْعَى﴾</span> يَقُولُ: إِنَّمَا تَجِيءُ السَّاعَةُ لِتُجْزَى كل نفس بِمَا تعْمل.</p></div>"
  20,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا يصدنك عَنْهَا﴾</span> أَيْ: عَنِ الْإِيمَانِ بِهَا <span class="qpc-hafs">﴿مَنْ لَا يُؤمن بهَا﴾</span>. <span class="qpc-hafs">﴿فتردى﴾</span> أَي: تهْلك.</p></div>"
  20,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تِلْكَ بِيَمِينِكَ يَا مُوسَى﴾</span> سَأَلَهُ عَنِ الْعَصَا الَّتِي فِي يَدِهِ الْيُمْنَى، وَهُوَ أَعْلَمُ بِهَا.</p></div>"
  20,18,"<div class=ar lang=ar><p>قَالَ مُوسَى: <span class="qpc-hafs">﴿هِيَ عَصَايَ أَتَوَكَّأُ عَلَيْهَا وَأَهُشُّ بِهَا عَلَى غَنَمِي﴾</span> قَالَ قَتَادَةُ: كَانَ يَخْبِطُ بِهَا وَرَقَ الشَّجَرِ. <span class="qpc-hafs">﴿وَلِيَ فِيهَا مَآرِبُ أُخْرَى﴾</span> قَالَ قَتَادَةُ: يَعْنِي: حَوَائِجَ قَالَ مُحَمَّدٌ: وَاحِدُ الْمَآرِبِ: مَأْرُبَةٌ، ومأربة أَيْضا.</p></div>"
  20,19,"<div class=ar lang=ar></div>"
  20,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَلْقَاهَا فَإِذَا هِيَ حَيَّةٌ تَسْعَى﴾</span> أَيْ: تَزْحَفُ عَلَى بَطْنِهَا بِسُرْعَةٍ.</p></div>"
  20,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سنعيدها سيرتها الأولى﴾</span> أَيْ: هَيْئَتَهَا الْأُولَى؛ يَعْنِي: عَصًا</p></div>"
  20,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واضمم يدك إِلَى جناحك﴾</span> قَالَ مُجَاهِدٌ: أَمَرَهُ أَنْ يُدْخِلَ كَفه تَحت عضده (ل ٢٠٧) <span class="qpc-hafs">﴿تَخْرُجْ بَيْضَاءَ مِنْ غَيْرِ سُوءٍ﴾</span> قَالَ قَتَادَةُ: يَعْنِي: مِنْ غَيْرِ بَرَصٍ.</p><p>قَالَ الْحَسَنُ: أَخْرَجَهَا وَاللَّهِ كَأَنَّهَا مِصْبَاحٌ، فَعَلِمَ مُوسَى أَنْ قَدْ لَقِيَ رَبَّهُ. <span class="qpc-hafs">﴿آيَةً أُخْرَى لنريك من آيَاتنَا الْكُبْرَى﴾</span> كَانَتِ الْيَدُ أَكْبَرُ مِنَ الْعَصَا.</p><p>قَالَ مُحَمَّد: (آيَة) بِالنَّصْبِ عَلَى مَعْنَى: نُرِيَكَ آيَةً أُخْرَى.</p></div>"
  20,23,"<div class=ar lang=ar></div>"
  20,24,"20:23"
  20,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ﴾</span> مُوسَى <span class="qpc-hafs">﴿رَبِّ اشْرَحْ لِي صَدْرِي﴾</span> دَعَا أَنْ يَشْرَحَ صَدْرَهُ لِلْإِيمَانِ.</p></div>"
  20,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسِّرْ لِي أَمْرِي وَاحْلُلْ عُقْدَةً من لساني يفقهوا قولي﴾</span> فَفَعَلَ اللَّهُ بِهِ ذَلِكَ، وَكَانَتِ الْعُقْدَةُ الَّتِي فِي لِسَانِهِ أَنَّهُ تَنَاوَلَ لِحْيَةَ فِرْعَوْنَ وَهُوَ صَغِيرٌ فَهَمَّ بِقَتْلِهِ، وَقَالَ: هَذَا عَدُوٌّ لِي! فَقَالَتْ لَهُ امْرَأَتُهُ: إِنَّ هَذَا صَغِيرٌ لَا يَعْقِلُ؛ فَإِنْ أَرَدْتَ أَنْ تَعْلَمَ ذَلِكَ، فَادْعُ بِتَمْرَةٍ وَجَمْرَةٍ، فَاعْرِضْهُمَا عَلَيْهِ، فَأُتِيَ بِتَمْرَةٍ وَجَمْرَةٍ فَعَرَضَهُمَا عَلَيْهِ، فَتَنَاوَلَ الْجَمْرَةَ فَأَلْقَاهَا فِي فِيهِ، فَمِنْهَا كَانَتْ [تِلْكَ] الْعُقْدَةُ فِي لِسَانِهِ.</p><p>قَالَ مُحَمَّدٌ: يَعْنِي بالعقدة: رتة.</p></div>"
  20,27,"<div class=ar lang=ar></div>"
  20,28,"20:27"
  20,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاجْعَلْ لِي وَزِيرًا مِنْ أَهْلِي﴾</span> أَي: عوينا من أَهلِي</p></div>"
  20,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَارُونَ أَخِي اشْدُدْ بِهِ أَزْرِي﴾</span> أَيْ: ظَهْرِي.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ: أَزَرْتُ فُلَانًا عَلَى الْأَمْرِ؛ أَيْ: قَوَّيْتُهُ عَلَيْهِ، فَأَمَّا وَازَرْتُهُ: فَصِرْتُ لَهُ وزيرا.</p></div>"
  20,31,"<div class=ar lang=ar></div>"
  20,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأشركه فِي أَمْرِي﴾</span> دَعَاءٌ مِنْ مُوسَى لِرَبِّهِ أَنْ يشركهُ فِي أمره.</p></div>"
  20,33,"<div class=ar lang=ar></div>"
  20,34,"20:33"
  20,35,"20:33"
  20,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ قد أُوتيت سؤلك﴾</span> أَيْ: مَا سَأَلْتَ <span class="qpc-hafs">﴿يَا مُوسَى﴾</span>.</p></div>"
  20,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ مَنَنَّا عَلَيْكَ مَرَّةً أُخْرَى﴾</span> فَذِكْرُهُ النِّعْمَةَ الْأُولَى يَعْنِي: قَوْلَهُ: <span class="qpc-hafs">﴿إِذْ أَوْحَيْنَا إِلَى أُمِّكَ مَا يُوحى﴾</span> شَيْءٍ قُذِفَ فِي قَلْبِهَا أُلْهِمَتْهُ، وَلَيْسَ بِوَحْي نبوة</p></div>"