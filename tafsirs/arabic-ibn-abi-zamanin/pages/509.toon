quran[10]{c,v,t}:
  47,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَقُول الَّذين آمنُوا لَوْلَا﴾</span> هلا <span class="qpc-hafs">﴿نُزِّلَتْ سُورَةٌ﴾</span> <span class="qpc-hafs">﴿محكمَة﴾</span> أَي: مفروضٌ فِيهَا الْقِتَال.</p><p><span class="qpc-hafs">﴿رَأَيْتَ الَّذين فِي قُلُوبهم مرض﴾</span> يَعْنِي: الْمُنَافِقين <span class="qpc-hafs">﴿يَنْظُرُونَ إِلَيْكَ نَظَرَ المغشي عَلَيْهِ من الْمَوْت﴾</span> خوفًا وكراهية لِلْقِتَالِ <span class="qpc-hafs">﴿فَأَوْلَى لَهُمْ﴾</span> هَذَا وعيدٌ من اللَّه لَهُم، ثمَّ انْقَطع الْكَلَام.</p></div>"
  47,21,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿طَاعَة﴾</span> أَي: طاعةٌ لله وَرَسُوله <span class="qpc-hafs">﴿وَقَوْلٌ مَعْرُوف﴾</span> خير مِمَّا أضمروا من النِّفَاق <span class="qpc-hafs">﴿فَإِذَا عَزَمَ الأَمْرُ﴾</span> بِالْجِهَادِ فِي سَبِيل اللَّه <span class="qpc-hafs">﴿فَلَوْ صدقُوا الله﴾</span> فَكَانَ بَاطِن أَمرهم وَظَاهره صدقا <span class="qpc-hafs">﴿لَكَانَ خيرا لَهُم﴾</span> يَعْنِي: بِهِ الْمُنَافِقين.</p></div>"
  47,22,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿فَهَلْ عَسَيْتُمْ إِنْ تَوَلَّيْتُمْ﴾</span> عَمَّا فِي قُلُوبكُمْ من النِّفَاق حَتَّى تظهروه شركا <span class="qpc-hafs">﴿أَنْ تُفْسِدُوا فِي الأَرْض وتقطعوا أَرْحَامكُم﴾</span> أَي: تقتلُوا قرابتكم.</p><p>قَالَ محمدٌ: قَرَأَ نَافِع <span class="qpc-hafs">﴿عَسِيتُمْ﴾</span> بكَسْر السِّين، وَقَرَأَ غير وَاحِد من الْقُرَّاء بِالْفَتْح، وَهِي أَعلَى اللغتين وأفصحهما؛ ذكره أَبُو عبيد.</p></div>"
  47,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ لَعَنَهُمُ اللَّهُ فَأَصَمَّهُمْ﴾</span> عَن الْهدى (وَأَعْمَى أَبْصَارَهُمْ عَنهُ</p></div>"
  47,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَلاَ يَتَدَبَّرُونَ الْقُرْآنَ أَمْ عَلَى قُلُوبٍ أَقْفَالُهَا﴾</span> أَي: أَن على قُلُوبهم أقفالها؛ وَهُوَ الطَّبْع.</p></div>"
  47,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ الَّذِينَ ارْتَدُّوا عَلَى أَدْبَارِهِم مِّن بَعْدِ مَا تَبَيَّنَ لَهُمُ الْهُدَى﴾</span> من بعد مَا أعْطوا الْإِيمَان، وَقَامَت عَلَيْهِم الْحجَّة بِالنَّبِيِّ وَالْقُرْآن، يَعْنِي: الْمُنَافِقين <span class="qpc-hafs">﴿الشَّيْطَانُ سَوَّلَ لَهُمْ﴾</span> <span class="qpc-hafs">﴿زين لَهُم﴾</span> (وَأَمْلَى لَهُمْ} قَالَ الْحسن: يَعْنِي: وسوس إِلَيْهِم أَنكُمْ تعيشون فِي الدُّنْيَا بِغَيْر عَذَاب، ثمَّ تموتون فتصيرون إِلَى غير عَذَاب</p></div>"
  47,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَلِكَ بِأَنَّهُمْ قَالُوا لِلَّذِينَ كَرِهُوا مَا نَزَّلَ اللَّهُ سَنُطِيعُكُمْ فِي بعض الْأَمر﴾</span> أَي: فِي الشّرك وافقوهم على الشّرك؛ فِي السِّرِّ <span class="qpc-hafs">﴿وَاللَّهُ يَعْلَمُ إسرارهم﴾</span>.</p><p>قَالَ مُحَمَّد: من قَرَأَ بِفَتْح الْألف فَهُوَ جمع (سر).</p></div>"
  47,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَيْفَ إِذَا تَوَفَّتْهُمُ الْمَلائِكَةُ يَضْرِبُونَ وُجُوههم وأدبارهم﴾</span> تَفْسِير الْحسن: <span class="qpc-hafs">﴿توفتهم الْمَلَائِكَة﴾</span> حشرتهم إِلَى النَّار <span class="qpc-hafs">﴿يَضْرِبُونَ وُجُوهَهُمْ وأدبارهم﴾</span> فِي النَّار.</p><p>قَالَ محمدٌ: الْمَعْنى: فَكيف تكون حالُهم إِذا فعلت الْمَلَائِكَة هَذَا بهم؟!</p></div>"
  47,28,"<div class=ar lang=ar></div>"
  47,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مرض﴾</span> وهم المُنَافِقُونَ <span class="qpc-hafs">﴿أَنْ لَنْ يُخْرِجَ الله أضغانهم﴾</span> يَعْنِي: مَا يكنون فِي صُدُورهمْ من الشّرك.</p></div>"