quran[19]{c,v,t}:
  67,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَمَّا رَأَوْهُ﴾</span> يَعْنِي: الْعَذَاب <span class="qpc-hafs">﴿زلفة﴾</span> قَرِيبًا <span class="qpc-hafs">﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾</span> سَاءَ الْعَذَاب وُجُوههم <span class="qpc-hafs">﴿وَقيل﴾</span> لَهُمْ عِنْدَ ذَلِكَ <span class="qpc-hafs">﴿هَذَا الَّذِي كُنْتُم بِهِ تدعون﴾</span> لقَولهم: <span class="qpc-hafs">﴿ائتنا بِعَذَاب الله﴾</span> (١) اسْتِهْزَاءً وَتَكْذِيبًا.</p><p>قَالَ محمدٌ: ذَكَرَ أَبُو عُبَيد أَنَّ مُنَ الْقُرَّاءِ مَنْ قَرَأَ: (الَّذِي كُنْتُمْ بِهِ تَدْعون) خَفِيفَةً (٢)؛ لِأَنَّهُمْ كَانُوا يَدْعُونَ بِالْعَذَابِ فِي قَوْلِهِ: <span class="qpc-hafs">﴿اللَّهُمَّ إِنْ كَانَ هَذَا هُوَ الْحَقَّ مِنْ عنْدك فَأمْطر علينا حِجَارَة﴾</span> (٣) الْآيَةُ، قَالَ: وَقَرَأَ أَكْثَرُهُمْ (تدَّعون) بِالتَّشْدِيدِ (٤)، قَالَ: وَهِيَ الْقِرَاءَةُ عِنْدَنَا، وَالتَّشْدِيدُ مَأْخُوذٌ مِنَ التَّخْفِيفِ (تَدْعون) تفْعَلون، و (تدَّعون) تفتعلون مُشْتَقَّة مِنْهُ (٥).</p></div>"
  67,28,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿قل﴾</span> يَا مُحَمَّدُ <span class="qpc-hafs">﴿أَرَأَيْتُمْ إِنْ أَهْلَكَنِيَ الله وَمن معي﴾</span> مِنَ الْمُؤْمِنِينَ <span class="qpc-hafs">﴿أَوْ رَحِمَنَا فَمَنْ يجير﴾</span> أَي: يمْنَع <span class="qpc-hafs">﴿الْكَافرين﴾</span> أَيْ: لَيْسَ لَهُمْ مُجيرٌ يَمْنَعُهُمْ من عَذَاب الله</p></div>"
  67,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فستعلمون﴾</span> يَوْمَ الْقِيَامَةِ <span class="qpc-hafs">﴿مَنْ هُوَ فِي ضلال مُبين﴾</span> أَيْ: أَنَّكُمْ أَيُّهَا الْمُشْرِكُونَ فِي ضلال مُبين.</p></div>"
  67,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن أصبح ماؤكم غورا﴾</span> أَيْ: قَدْ غَارَ فِي الْأَرْضِ فَذَهَبَ، وَالْغَوْرُ الَّذِي لَا يُقْدَرُ عَلَيْهِ وَلا تُدْرِكُهُ الدِّلاء <span class="qpc-hafs">﴿فَمَنْ يأتيكم بِمَاء معِين﴾</span> جَاءَ عَنْ عِكْرِمَةَ: الْمَعِينُ الظَّاهِرُ. قَالَ الْحَسَنُ: الْمَعِينُ: الَّذِي أَصْلُهُ مِنَ الْعُيُونِ (٦).</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿غورا﴾</span> مصْدَرٌ موْصُوفٌ بِهِ؛ تَقُولُ: ماءٌ غَوْرٌ وَمَاءَانِ غورٌ ومياهٌ غَوْرٌ كَمَا تَقُولُ: هَذَا عدلٌ، وَهَذَانِ عدلٌ، وَهَؤُلاءِ عدلٌ (١).</p></div>"
  68,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةُ «ن» وَهِيَ مَكِّيَةٌ كلهَا</p><p>بِسم اله الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿ن والقلم﴾</span> تَفْسِيرُ الْحَسَنِ: يَعْنِي: الدَّوَاةَ وَالْقَلَمَ هَذَا الْقَلَمُ الَّذِي يُكْتَبُ بِهِ , وَبَعْضُهُمْ يَقُولُ: هُوَ الْحُوتُ الَّذِي عَلَيْهِ قَرَارُ الْأَرْضِ (١). <span class="qpc-hafs">﴿وَمَا يَسْطُرُونَ﴾</span> يَكْتُبُونَ؛ يَعْنِي: الْمَلَائِكَة</p></div>"
  68,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا أَنْتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ﴾</span> (٢) بِهَذَا لِلنَّبِيِّ لِقَوْلِ الْمُشْرِكِينَ لَهُ: إِنَّهُ لَمَجْنُونٌ، وَمَقْرَأُ الْعَامَّةِ بِالْوَقْفِ وَالْإِسْكَانِ (٣) وَوَقَعَ الْقَسَمُ عَلَى الْقَلَمِ <span class="qpc-hafs">﴿وَمَا يسطرون﴾</span>.</p><p>قَالَ مُحَمَّدٌ: قِرَاءَةُ نَافِعٍ (نونٌ) ظَاهِرَةٌ فِي رِوَايَةِ قَالُونَ عَنْهُ، وروى غَيره عَنهُ أَنَّهُ أخفاها؛ ذكره ابْن مُجَاهِد (١).</p></div>"
  68,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن لَك لأجرا﴾</span> يَعْنِي: الْجنَّة <span class="qpc-hafs">﴿غير ممنون﴾</span> بِهِ أَيْ: لَا يُمَنُّ عَلَيْكَ بِهِ مِنْ أَذًى، فِي تَفْسِيرِ الْحَسَنِ.</p><p>قَالَ مُحَمَّدٌ: وَقِيلَ: مَعْنَى <span class="qpc-hafs">﴿غير ممنون﴾</span>: غَيْرُ مَقْطُوعٍ، يُقَالُ: مَنَنْتَ الحبلَ إِذا قطعته (٢).</p></div>"
  68,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّك لعلى خلق عَظِيم﴾</span> يَعْنِي: دين الْإِسْلَام</p></div>"
  68,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فستبصر﴾</span> يَوْم الْقِيَامَة <span class="qpc-hafs">﴿ويبصرون﴾</span> يَعْنِي: الْمُشْرِكِينَ، أَيْ: سَيُبْصِرُونَ أَنَّكَ كنت الْمُهْتَدي، وَأَنَّهُمْ الضُّلالُ</p></div>"
  68,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بأيكم الْمفْتُون﴾</span> يَعْنِي: أَيِّكُمُ الضُّلال؛ فِي تَفْسِيرِ الْحسن بِجعْل الْبَاء صلَة (٣).</p></div>"
  68,7,"<div class=ar lang=ar></div>"
  68,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تُطِع المكذبين﴾</span> كَانُوا يُرِيدُونَ أَنْ يَتْرُكَ النَّبِيُّ ﷺ مَا جَاءَ بِهِ.</p></div>"
  68,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ودوا لَو تدهن فيدهنون﴾</span> تَفْسِيرُ بَعْضِهِمْ: يَقُولُ: لَوْ تُدَاهِنُ فِي دِينِكَ فَيُدَاهِنُونَ فِي أَدْيَانِهِمْ، (٤) (ل ٣٦٩) فِي الْخَيْر</p></div>"
  68,10,"<div class=ar lang=ar></div>"
  68,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هماز﴾</span> أَيْ: يَهْمِزُ النَّاسَ، أَيْ يَغْتَابُهُمْ <span class="qpc-hafs">﴿مشاء بنميم﴾</span> يفْسد ذَات البَيْن</p></div>"
  68,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مناع للخير﴾</span> يَمْنَعُ حقَّ اللَّهِ عَلَيْهِ <span class="qpc-hafs">﴿مُعْتَدٍ﴾</span> أَي: ظَالِم <span class="qpc-hafs">﴿أثيم﴾</span> أيْ: آثم</p></div>"
  68,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عتل بعد ذَلِك﴾</span> أَيْ: مَعَ ذَلِكَ، والعتلُّ: الْفَاحِشُ <span class="qpc-hafs">﴿زنيم﴾</span> تَفْسِيرُ الْحَسَنِ الزنيمُ: اللَّيِّنُ الضَّرِيبَةِ؛ يَعْنِي الطَّبِيعَةِ.</p><p>قَالَ مُحَمَّدٌ: وَقِيلَ: الزنيمُ: الْمَعْرُوفُ بالشَّر؛ كَمَا تُعْرَفُ الشَّاةُ بِزَنِمَتِهَا؛ يُقَالُ: شَاةٌ زنِمةُ، وَهُوَ مَا تعلَّق عِنْدَ حُلوق المِعْزَى (١)، وَالْعُتُلُّ عِنْدَ أَهْلِ اللُّغَةِ: الْغَلِيظُ الْجَافِي (٢). وَالله أعلمُ.</p></div>"
  68,14,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿إِن كَانَ﴾</span> بِأَنْ كَانَ <span class="qpc-hafs">﴿ذَا مَالٍ وَبَنِينَ﴾</span>.</p></div>"
  68,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أساطير الْأَوَّلين﴾</span> يَعْنِي: كذب الْأَوَّلين وباطلهم</p></div>"