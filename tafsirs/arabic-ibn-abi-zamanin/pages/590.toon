quran[22]{c,v,t}:
  85,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ وَالسَّمَاءِ ذَاتِ الْبُرُوجِ وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿وَالسَّمَاءِ ذَاتِ الْبُرُوجِ﴾</span> تَفْسِيرُ ابْنُ عَبَّاسٍ: ذَاتُ النُّجُومِ</p></div>"
  85,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْيَوْم الْمَوْعُود﴾</span> يَعْنِي: يَوْم الْقِيَامَة</p></div>"
  85,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَاهد﴾</span> يَعْنِي: يَوْم الْجُمُعَة <span class="qpc-hafs">﴿ومشهود﴾</span> يَعْنِي: يَوْمَ عَرَفَةَ، هَذَا تَفْسِيرُ الْحسن، وَرَوَاهُ عَنِ النَّبِيِّ ﷺ. قَوْله:</p></div>"
  85,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قتل﴾</span> لعن <span class="qpc-hafs">﴿أَصْحَابُ الأُخْدُودِ﴾</span> <span class="qpc-hafs">﴿النَّارِ ذَاتِ الْوَقُودِ﴾</span> إِلَى قَوْله <span class="qpc-hafs">﴿شُهُود﴾</span> الْأُخْدُودُ: الشِّقُّ فِي الْأَرْضِ، وَجَمْعُهُ: أَخَادِيدُ. قَالَ الْحَسَنُ: كَانَ أَصْحَابُ الْأُخْدُودِ ثَمَانِينَ بَيْنَ رَجُلٍ وَامْرَأَةٍ، فَأَخذهُم الْمُشْركُونَ، فَخُذُوا لَهُمْ أُخْدُودًا فِي الْأَرْضِ، ثُمَّ أَوْقَدُوا لَهُمْ نَارًا ضَخْمَةً ثُمَّ (ل ٣٩٠) فَجَعَلُوا يَقُولُونَ لِلرَّجُلِ وَلِلْمَرْأَةِ مِنْهُمْ: إِمَّا أَنْ تَتْرُكَ دِينَكَ وَإِمَّا أَنْ نَقْذِفَكَ فِي النَّارِ. فَيَقُولُ: مَا أَنَا بِتَارِكِ دِينِي لِشَيْءٍ! فَيُقْذَفُ فِيهَا فَيَحْتَرِقُ حَتَّى أَتَوْا عَلَيْهِمْ، فَبَقِيَتِ امْرَأَةٌ وَمَعَهَا صَبِيٌّ فَتَهَيَّبَتْ، فَقَالَ لَهَا الصَّبِيُّ: امْضِي وَلا تُنَافِقِي، فَمَضَتْ فَاحْتَرَقَتْ.</p><p>قَالَ يَحْيَى: كَانَ صَغِيرًا لَمْ يَتَكَلَّمْ قَبْلَ ذَلِكَ، وَقَالَ مُجَاهِد: وَذَلِكَ بِنَجْرَان.</p></div>"
  85,5,"<div class=ar lang=ar></div>"
  85,6,"85:5"
  85,7,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿وَهُمْ عَلَى مَا يَفْعَلُونَ بِالْمُؤْمِنِينَ شُهُود﴾</span> من تحريقهم إيَّاهُم بالنَّار</p></div>"
  85,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا نقموا مِنْهُم﴾</span> مَا كَرِهُوا مِنْهُمْ <span class="qpc-hafs">﴿إِلا أَنْ يُؤمنُوا بِاللَّه الْعَزِيز الحميد﴾</span> مَا سَفَكُوا لَهُمْ دِمَاءً، وَلا أخذُوا لَهُم مَالا</p></div>"
  85,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاللَّهُ عَلَى كُلِّ شَيْءٍ شَهِيدٌ﴾</span> شَاهِدٌ عَلَى كُلِّ نَفْسٍ بِعَمَلِهَا.</p></div>"
  85,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ الَّذِينَ فَتَنُوا الْمُؤْمِنِينَ وَالْمُؤْمِنَاتِ﴾</span> يَعْنِي: أحرقهم بوالنار، فِي تَفْسِيرِ السُّدِّيِّ.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ فَتَنْتُ الشَّيْءَ أَحْرَقْتُهُ، وَالْفَتِينُ حِجَارَة سود كَأَنَّهَا محرقة.</p></div>"
  85,11,"<div class=ar lang=ar></div>"
  85,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن بَطش رَبك﴾</span> عُقُوبَة رَبك <span class="qpc-hafs">﴿لشديد﴾</span>.</p><p>قَالَ مُحَمَّدٌ: (إِنَّ بَطْشَ رَبِّكَ لشديد) هُوَ جَوَابُ الْقَسَمِ (وَالسَّمَاءِ ذَاتِ الْبُرُوجِ).</p></div>"
  85,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّه هُوَ يبدئ﴾</span> أَي: يخلق <span class="qpc-hafs">﴿وَيُعِيد﴾</span> أَي: يبْعَث يَوْم الْقِيَامَة</p></div>"
  85,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُوَ الغفور﴾</span> لِلذُّنُوبِ، وَلا يَغْفِرُ إِلَّا لِمَنْ آمن <span class="qpc-hafs">﴿الْوَدُود﴾</span> تَفْسِيرُ الْحَسَنِ: يَتَوَدَّدُ إِلَى خَلْقِهِ بِمَا يُعْطِيهِمْ مِنَ النِّعَمِ فِي وَأَرْزَاقِهِمْ، وَمَا يَغْفِرُ لَهُمْ مِنَ الذُّنُوب</p></div>"
  85,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُو الْعَرْش﴾</span> رب الْعَرْش <span class="qpc-hafs">﴿الْمجِيد﴾</span> يقْرَأ (الْمجِيد) بِالرَّفْعِ وَالْجَرِّ، فَمَنْ قَرَأَ بِالرَّفْعِ رَجَعَ إِلَى قَوْلِهِ: <span class="qpc-hafs">﴿وَهُوَ الْغَفُورُ الْوَدُود﴾</span> الْمَجِيدُ ذُو الْعَرْشِ، وَمَنْ قَرَأَهَا بِالْجَرِّ جَعَلَهُ مِنْ صِفَةِ (الْعَرْشِ) وَتَفْسِير الْمجِيد: الْكَرِيم.</p></div>"
  85,16,"<div class=ar lang=ar></div>"
  85,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَل أَتَاك﴾</span> أَيْ: قَدْ أَتَاكَ <span class="qpc-hafs">﴿حَدِيثُ الْجُنُودِ فِرْعَوْن وَثَمُود﴾</span> كَيْفَ أَهْلَكَهُمُ اللَّهُ حِينَ كَذَّبُوا رسلهم.</p></div>"
  85,18,"<div class=ar lang=ar></div>"
  85,19,"85:18"
  85,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالله من ورائهم مُحِيط﴾</span> حَتَّى يَجْزِيَهُمْ بِأَعْمَالِهِمْ.</p><p>قَالَ مُحَمَّدٌ: الْمَعْنَى: إِنَّ قُدْرَتَهُ مُشْتَمِلَةٌ عَلَيْهِمْ لَا يُعْجِزُهُ مِنْهُمْ أَحَدٌ، وَهُوَ الَّذِي أَرَادَ يحيى.</p></div>"
  85,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل هُوَ قُرْآن مجيد﴾</span> كريم على الله</p></div>"
  85,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي لوح مَحْفُوظ﴾</span> وَهُوَ أُمُّ الْكِتَابِ قَالَ مُحَمَّدٌ: قَالَ وأَبُو عُبَيْدٍ: قَرَأَ نَافِعٌ: (مَحْفُوظٌ) بِالرَّفْع، وقرأه غَيره (مَحْفُوظ) بِالْخَفْضِ وَالْخَفْضُ فِي هَذَا أَحَبُّ إِلَيَّ لِيَكُونَ مِنْ نَعْتِ (اللَّوْحِ).</p></div>"