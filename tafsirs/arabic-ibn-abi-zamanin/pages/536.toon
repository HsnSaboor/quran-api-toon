quran[26]{c,v,t}:
  56,51,"56:48"
  56,52,"56:48"
  56,53,"56:48"
  56,54,"56:48"
  56,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فشاربون شرب الهيم﴾</span> يَعْنِي: الْإِبِل العطاش؛ فِي تَفْسِير الْكَلْبِيّ.</p><p>قَالَ محمدٌ: بعيرٌ أهْيَمُ وناقة هيماء.</p></div>"
  56,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذَا نزلهم يَوْم الدّين﴾</span> يَوْم الْحساب.</p><p>قَالَ محمدٌ: نزلهم أَي: رزقهم وطعامهم.</p></div>"
  56,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحن خَلَقْنَاكُمْ﴾</span> يَقُوله للْمُشْرِكين <span class="qpc-hafs">﴿فلولا﴾</span> فَهَلا <span class="qpc-hafs">﴿تصدقُونَ﴾</span> بِالْبَعْثِ</p></div>"
  56,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَرَأَيْتُم مَا تمنون﴾</span> يَعْنِي: النُّطْفَة</p></div>"
  56,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَأَنْتُمْ تَخْلُقُونَهُ أَمْ نَحْنُ الْخَالِقُونَ﴾</span> على الِاسْتِفْهَام أَي: لَسْتُم الَّذين تخلقونه (ل ٣٥١)</p></div>"
  56,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحن قَدرنَا بَيْنكُم الْمَوْت﴾</span> لكل عبد وَقت لَا يعدوه <span class="qpc-hafs">﴿وَمَا نَحن بمسبوقين﴾</span> بمغلوبين</p></div>"
  56,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿على أَن نبدل أمثالكم﴾</span> آدميين خيرا مِنْكُم يَقُوله للْمُشْرِكين <span class="qpc-hafs">﴿وننشئكم﴾</span> نخلقكم (فِيمَا لاَ تَعْلَمُونَ} قَالَ مُجَاهِد: يَعْنِي فِي أَي خلق شِئْنَا <span class="qpc-hafs">﴿وَلَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولَى﴾</span> خلق آدم وَذريته بعده <span class="qpc-hafs">﴿فَلَوْلاَ﴾</span> فَهَلا <span class="qpc-hafs">﴿تَذكَّرُونَ﴾</span> فتؤمنوا بِالْبَعْثِ.</p></div>"
  56,62,"<div class=ar lang=ar></div>"
  56,63,"56:62"
  56,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَأَنتُمْ تَزْرَعُونَهُ﴾</span> أَي تنبتونه يَقُوله لَهُم على الِاسْتِفْهَام <span class="qpc-hafs">﴿أَمْ نَحْنُ الزَّارِعُونَ﴾</span> أَي: لَسْتُم الَّذين تزرعونه، وَلَكِن نَحن الزارعون المنبتون</p></div>"
  56,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوْ نَشَاء لَجَعَلْنَاهُ﴾</span> يَعْنِي: الزَّرْع <span class="qpc-hafs">﴿حُطَامًا فَظَلَلْتُمْ تَفَكَّهُونَ﴾</span> تَفْسِير بَعضهم: تعْجبُونَ، الْمَعْنى: يعْجبُونَ لهلاكه بعد خضرته</p></div>"
  56,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا لَمُغْرَمُونَ﴾</span> أَي: مهلكون</p></div>"
  56,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> حرمنا الزَّرْع.</p></div>"
  56,68,"<div class=ar lang=ar></div>"
  56,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَأَنتُمْ أَنزَلْتُمُوهُ مِنَ الْمُزْنِ﴾</span> من السَّحَاب.</p><p>قَالَ محمدٌ: وَاحِدهَا مزنة.</p></div>"
  56,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوْ نَشَاء جَعَلْنَاهُ أُجَاجًا﴾</span> <span class="qpc-hafs">﴿مرا﴾</span> (فَلَوْلاَ تَشْكُرُونَ} هلا تؤمنون؛ يَقُوله للْمُشْرِكين</p></div>"
  56,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَرَأَيْتُمُ النَّارَ الَّتِي تُورُونَ﴾</span> أَي: تستخرجون من الزنود</p></div>"
  56,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَا﴾</span> الَّتِي تخرج مِنْهَا <span class="qpc-hafs">﴿أَمْ نَحْنُ الْمُنشِئُونَ﴾</span>.</p><p>قَالَ محمدٌ: تَقول: أوْرَيْتُ النَّار إيراءً، ولغة أُخْرَى: وَرَيْتُها وَرْيًا إِذا قَدَحْتَها، وَوَرَتْ هِيَ إِذا ظهرتْ، وَمن كَلَامهم: وَرِيَتْ بك زنادي.</p></div>"
  56,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحن جعلناها تذكرة﴾</span> للنار الْكُبْرَى <span class="qpc-hafs">﴿ومتاعا للمقوين﴾</span> للمسافرين يَنْتَفِعُونَ بهَا؛ فِي تَفْسِير الْحسن.</p><p>قَالَ محمدٌ: المقوي: الَّذِي ينزل بالقَوَاء، وَهِي الأَرْض القفر.</p></div>"
  56,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فسبح باسم رَبك الْعَظِيم﴾</span> يَقُوله لنَبيه، فنزِّه اللَّهَ مِمَّا يَقُولُونَ.</p><p>قَالَ يحيى: وَبَلغنِي أَنَّهَا لما نزلت قَالَ رَسُول الله ﷺ: " اجْعَلُوهَا فِي ركوعكم. وَلما نزلت: <span class="qpc-hafs">﴿سَبِّحِ اسْم رَبك الْأَعْلَى﴾</span> قَالَ: اجْعَلُوهَا فِي سُجُودكُمْ ".</p></div>"
  56,75,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿فَلَا أقسم﴾</span> أَي: أقسم، و (لَا) زَائِدَة <span class="qpc-hafs">﴿بمواقع النُّجُوم﴾</span> نُجُوم الْقُرْآن إِذْ نزل جِبْرِيل على النَّبِي</p></div>"
  56,76,"<div class=ar lang=ar></div>"