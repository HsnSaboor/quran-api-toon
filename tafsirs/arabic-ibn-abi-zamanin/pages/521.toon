quran[24]{c,v,t}:
  51,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالسَّمَاء ذَات الحبك﴾</span> تَفْسِير ابْن عَبَّاس: يَعْنِي: استواءها. وَتَفْسِير غَيره مثل حُبُك المَاء إِذا هَاجَتْ الرّيح، وَمثل حبك الزَّرْع إِذا أَصَابَته الرّيح.</p><p>قَالَ مُحَمَّد: الحبك عِنْد أهل اللُّغَة: الطرائق (الْإِنَاء الْقَائِم) إِذا ضَربته الرّيح فَصَارَت فِيهِ طرائق لَهُ حُبُك، وَكَذَلِكَ الرمل إِذا هبَّتْ عَلَيْهِ الرّيح فرأيتَ فِيهِ الطرائق فَذَلِك حُبُكه، وَاحِدهَا: حِبَاكٌ مثل مِثَال ومُثُل، وَيكون واحدُها أَيْضا: حبيكة مثل: طَريقَة وطرق.</p></div>"
  51,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّكُم لفي قَول مُخْتَلف﴾</span> أَي: لفي اخْتِلَاف من الْبَعْث</p></div>"
  51,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يؤفك عَنهُ من أفك﴾</span> يُصَدُّ عَنهُ من صُدَّ عَن الْإِيمَان بِهِ</p></div>"
  51,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قتل﴾</span> أَي: لعن <span class="qpc-hafs">﴿الخراصون﴾</span> الَّذين يكذبُون بِالْبَعْثِ وَذَلِكَ مِنْهُم تخرص</p></div>"
  51,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذين هم فِي غمرة﴾</span> أَي: فِي غَفلَة. وَقيل: فِي حيرة <span class="qpc-hafs">﴿ساهون﴾</span> أَي: لاهون لَا يُحِقُّونه.</p><p>قَالَ محمدٌ: تَقول: تخرص على فلَان الْبَاطِل إِذا كذب، وَيجوز أَن يكون الخراصون الَّذين يتظنَّوْن الشَّيْء لَا يُحِقُّونه؛ فيعملون بِمَا لَا يَدْرُونَ صِحَّته.</p></div>"
  51,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يسْأَلُون أَيَّانَ يَوْم الدّين﴾</span> أَي: مَتى يَوْم الدّين؟ وَذَلِكَ مِنْهُم استهزاء وَتَكْذيب، أَي: لَا يكون.</p></div>"
  51,13,"<div class=ar lang=ar><p>قَالَ اللَّه: <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلَى النَّار يفتنون﴾</span> يحرقون بهَا.</p><p>قَالَ محمدٌ: (يَوْم) مَنْصُوب بِمَعْنى: يَقع الْجَزَاء <span class="qpc-hafs">﴿يَوْمَ هُمْ عَلَى النَّارِ يُفْتَنُونَ﴾</span>.</p></div>"
  51,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذوقوا فتنتكم﴾</span> حريقكم <span class="qpc-hafs">﴿هَذَا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُون﴾</span> فِي الدُّنْيَا، لما كَانُوا يستعجلون بِالْعَذَابِ فِي الدُّنْيَا استهزاءً وتكذيبًا.</p><p>قَالَ محمدٌ: يُقَال للحجارة السود الَّتِي يحرق بهَا قد احترقت بالنَّار الفتين.</p></div>"
  51,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَعُيُونٍ﴾</span> وَهِي الْأَنْهَار</p></div>"
  51,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿آخذين مَا آتَاهُم﴾</span> أَعْطَاهُم <span class="qpc-hafs">﴿رَبهم﴾</span> فِي الْجنَّة.</p><p>قَالَ محمدٌ: (آخذين) نصبٌ على الْحَال الْمَعْنى: فِي جناتٍ وعيون فِي حَال أَخذهم مَا آتَاهُم (ل ٨٣٣) رَبهم.</p></div>"
  51,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَانُوا قَلِيلا مِنَ اللَّيْلِ مَا يهجعون﴾</span> تَفْسِير الْحسن: يَقُول: كَانُوا لَا ينامون مِنْهُ إِلَّا قَلِيلا.</p></div>"
  51,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وبالأسحار هم يَسْتَغْفِرُونَ﴾</span>.</p><p>يَحْيَى: عَنْ خَالِدٍ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: قَالَ رَسُولُ اللَّهِ: " قَالَ الله: إِن من أَحَبَّ أَحِبَّائِي إِلَيَّ الْمَشَّائِينَ إِلَى الْمَسَاجِدِ الْمُسْتَغْفِرِينَ بِالأَسْحَارِ الْمُتَحَابِّينَ فِيَّ، أُولَئِكَ الَّذِينَ إِذَا أَرَدْتُ أَهْلَ الأَرْضِ بِسُوءٍ فَذَكَرْتُهُمْ صَرَفْتُهُ عَنْهُمْ بِهِمْ ".</p><p>قَالَ محمدٌ: قَوْله: <span class="qpc-hafs">﴿وَمَا يهجعون﴾</span> جَائِز أَن تكون (مَا) مُؤَكدَة صلَة، وَجَائِز أَن يكون مَا بعْدهَا مصدرا، الْمَعْنى: كَانُوا قَلِيلا من اللَّيْل هُجُوعُهم.</p><p><span class="qpc-hafs">﴿وَفِي أَمْوَالِهِمْ حق للسَّائِل والمحروم﴾</span> السَّائِل: الَّذِي يسْأَل، والمحروم فِي تَفْسِير الْحسن: المتعفِّف الْقَاعِد فِي بَيته الَّذِي لَا يسْأَل.</p></div>"
  51,19,"<div class=ar lang=ar></div>"
  51,20,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَفِي الأَرْض آيَات﴾</span> أَي: فِيمَا خلق اللَّه فِيهَا آياتٌ <span class="qpc-hafs">﴿لِلْمُوقِنِينَ﴾</span>.</p></div>"
  51,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفِي أَنفسكُم﴾</span> أَي: فِي بَدْء خَلْقكم من ترابٍ؛ يَعْنِي: آدم ثمَّ خلق نَسْله من نُطْفَة <span class="qpc-hafs">﴿أَفَلا تُبْصِرُونَ﴾</span> يَقُوله للْمُشْرِكين</p></div>"
  51,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفِي السَّمَاء رزقكم﴾</span> الْمَطَر فِيهِ أرزاقُ الخَلْقِ <span class="qpc-hafs">﴿وَمَا توعدون﴾</span> تَفْسِير بَعضهم يَعْنِي: من الْوَعْد والوعيد من السَّمَاء</p></div>"
  51,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَرَبِّ السَّمَاء وَالْأَرْض إِنَّه﴾</span> أقسم بنفْسه إِن هَذَا الْقُرْآن <span class="qpc-hafs">﴿لَحَقٌّ مِثْلَ مَا أَنَّكُمْ تَنْطِقُونَ﴾</span>.</p><p>قَالَ محمدٌ: من نصب (مِثْلَ) فجائزٌ أَن يكون على التوكيد بِمَعْنى: إِنَّه لحقٌ حقًّا مثل نطقكم.</p></div>"
  51,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَل أَتَاك﴾</span> أَي: قد أَتَاك <span class="qpc-hafs">﴿حَدِيثُ ضَيْفِ إِبْرَاهِيم الْمُكرمين﴾</span> عِنْد اللَّه بالمنزلة والقربة؛ يَعْنِي: الْمَلَائِكَة الَّذين نزلُوا بِهِ فبشروه بِإسْحَاق، وَجَاءُوا بِعَذَاب قوم لوط</p></div>"
  51,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ دخلُوا عَلَيْهِ﴾</span> فِي صُورَة الْآدَمِيّين <span class="qpc-hafs">﴿فَقَالُوا سَلامًا﴾</span> أَي: سلمُوا عَلَيْهِ <span class="qpc-hafs">﴿قَالَ سَلامٌ﴾</span> رد عَلَيْهِم <span class="qpc-hafs">﴿قوم منكرون﴾</span> أنكرهم حِين لمْ يَأْكُلُوا من طَعَامه.</p><p>قَالَ محمدٌ: <span class="qpc-hafs">﴿قَالُوا سَلامًا﴾</span> منصوبٌ [بِتَقْدِير]. سلّمنا عَلَيْك سَلاما.</p><p>وَقَوله: <span class="qpc-hafs">﴿قَالَ سَلام﴾</span> مَرْفُوع بِمَعْنى: قَالَ: سلامٌ عَلَيْكُم، وَيَجُوزُ أَنْ يَكُونَ عَلَى مَعْنَى: أمرنَا سَلام.</p></div>"
  51,26,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿فرَاغ﴾</span> فَمَال <span class="qpc-hafs">﴿إِلَى أَهْلِهِ فَجَاءَ بِعِجْلٍ سمين﴾</span> فَلم يَأْكُلُوا.</p><p>قَالَ محمدٌ: معنى (راغ). عدل إِلَيْهِم فِي خُفْيَةٍ، قَالُوا: وَلَا يكون الرَّوَاغُ إِلَّا أَن تخفي مجيئك وذهابك.</p><p><span class="qpc-hafs">﴿قَالَ أَلا تَأْكُلُونَ﴾</span></p></div>"
  51,27,"<div class=ar lang=ar></div>"
  51,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَوْجَسَ مِنْهُمْ خِيفَةً قَالُوا لَا تخف وبشروه بِغُلَام عليم﴾</span> إِسْحَاق.</p><p>قَالَ مُحَمَّد: (أوجس) مَعْنَاهُ: أضمر.</p></div>"
  51,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَقْبَلت امْرَأَته فِي صرةٍ﴾</span> صَيْحَة <span class="qpc-hafs">﴿فصكت وَجههَا﴾</span> جبينها <span class="qpc-hafs">﴿وَقَالَت عَجُوز عقيم﴾</span> قَالَت ذَلِك تعجُّبًا؛ أَي: كَيفَ تلدُ وَهِي عجوزٌ؟!</p><p>وَقَالَ محمدٌ: (عَجُوز) مَرْفُوع بِمَعْنى: أَنا عجوزٌ، وَيُقَال: عَقُمتِ المرأةُ عُقْمًا وعَقَمًا فَهِيَ بيِّنةُ العُقُومة، ورجلٌ عقيم أَيْضا.</p></div>"
  51,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا كَذَلِك قَالَ رَبك﴾</span> أَي: تلدي غُلَاما اسْمُه: إِسْحَاق.</p></div>"