quran[9]{c,v,t}:
  6,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُوَ عَلَى كُلِّ شيءٍ وَكِيلٌ﴾</span> أَي: حفيظ لأعمال الْعباد</p></div>"
  6,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تُدْرِكهُ الْأَبْصَار﴾</span> يَعْنِي: فِي الدُّنْيَا.</p><p><span class="qpc-hafs">﴿وَهُوَ يُدْرِكُ الْأَبْصَار وَهُوَ اللَّطِيف﴾</span> بخلقه فِيمَا أَعْطَاهُم <span class="qpc-hafs">﴿الْخَبِير﴾</span> بأعمالهم.</p></div>"
  6,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدْ جَاءَكُمْ بَصَائِرُ مِنْ رَبِّكُمْ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿فَمن أبْصر﴾</span> [اهْتَدَى] <span class="qpc-hafs">﴿فلنفسه وَمن عمي﴾</span> عَن الْهدى <span class="qpc-hafs">﴿فعلَيْهَا﴾</span> فَعَلَى نَفْسِهِ <span class="qpc-hafs">﴿وَمَا أَنَا عَلَيْكُمْ بحفيظ﴾</span> أَحْفَظُ أَعْمَالَكُمْ حَتَّى أُجَازِيَكُمْ بِهَا</p></div>"
  6,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَلِكَ نُصَرِّفُ الآيَاتِ وَلِيَقُولُوا دَرَسْتَ﴾</span> أَيْ: قَرَأْتَ وَتَعَلَّمْتَ، وَبَعْضُهُمْ يَقْرَؤُهَا (دَارَسْتَ)؛ أَيْ: قَارَأْتَ أَهْلَ الْكِتَابَيْنِ.</p></div>"
  6,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿اتَّبِعْ مَا أُوحِيَ إِلَيْكَ مِنْ رَبك﴾</span> (يَقُولُ: ادْعُهُمْ إِلَى) لَا إِلَهَ إِلَّا اللَّهُ <span class="qpc-hafs">﴿وَأَعْرِضْ عَنِ الْمُشْرِكِينَ﴾</span> وَهِي مَنْسُوخَة، نسختها الْقِتَال</p></div>"
  6,107,"<div class=ar lang=ar></div>"
  6,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا تَسُبُّوا الَّذِينَ يَدْعُونَ مِنْ دُونِ اللَّهِ فَيَسُبُّوا اللَّهَ عَدْوًا بِغَيْر علم﴾</span>.</p><p>قَالَ يحيى: وَهِيَ تُقْرَأُ <span class="qpc-hafs">﴿عَدْوًا﴾</span> وَ <span class="qpc-hafs">﴿عُدُوَّا﴾</span> وَهُوَ مِنَ الْعُدْوَانِ، وَالْعُدْوَانُ: الظُّلْمُ.</p><p><span class="qpc-hafs">﴿كَذَلِكَ زَيَّنَّا لِكُلِّ أمة﴾</span> أَيْ: لِأَهْلِ كُلِّ ملةٍ <span class="qpc-hafs">﴿عَمَلَهُمْ﴾</span>.</p><p>قَالَ الْكَلْبِيُّ:</p><p>قَالَ الْمُشْرِكُونَ: وَاللِّهِ لَيَنْتَهِيَنَّ محمدٌ عَنْ سَبِّ آلِهَتِنَا، أَوْ لَنَسُبَنَّ رَبَّهُ؛ فَنَزَلَتْ هَذِهِ الْآيَة.</p></div>"
  6,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأقسموا بِاللَّه جهد أَيْمَانهم﴾</span> [بِمَبْلَغِ أَيْمَانِهِمْ] <span class="qpc-hafs">﴿لَئِنْ جَاءَتْهُمْ آيَةٌ ليُؤْمِنن بهَا﴾</span> قَالَ الله لنَبيه: <span class="qpc-hafs">﴿قَالَ إِنَّمَا الآيَاتُ عِنْدَ اللَّهِ وَمَا يشعركم﴾</span> أَيْ: مَا يَدْرِيكُمْ <span class="qpc-hafs">﴿أَنَّهَا إِذَا جَاءَت لَا يُؤمنُونَ﴾</span>.</p><p>قَالَ محمدٌ: تُقْرَأُ (إِنَّهَا) بِكَسْرِ الْأَلِفِ؛ عَلَى الِابْتِدَاءِ، وَتُقْرَأُ (أَنَّهَا) بِالْفَتْحِ؛ بِمَعْنَى: لَعَلَّهُمْ، ذَكَرَهُ أَبُو عبيد.</p></div>"
  6,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ونقلب أفئدتهم وأبصارهم﴾</span> أَيْ: نَطْبَعُ عَلَيْهَا <span class="qpc-hafs">﴿كَمَا لَمْ يُؤمنُوا بِهِ أول مرّة﴾</span> يَقُولُ: لَوْ جَاءَتْهُمُ الْآيَةُ لَمْ يُؤْمِنُوا؛ كَمَا لَمْ يُؤْمِنُوا قَبْلَ أَنْ يَجِيئَهُمُ الْعَذَابُ <span class="qpc-hafs">﴿وَنَذَرُهُمْ فِي طغيانهم يعمهون﴾</span> أَي: يَتَرَدَّدُونَ.</p></div>"