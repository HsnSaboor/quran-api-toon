quran[23]{c,v,t}:
  51,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَلِكَ مَا أَتَى الَّذِينَ مِنْ قبلهم﴾</span> من قبل قَوْمك يَا مُحَمَّد، أَي: هَكَذَا مَا أَتَى الَّذين مِنْ قَبْلِهِمْ <span class="qpc-hafs">﴿مِنْ رَسُولٍ إِلا قَالُوا سَاحر أَو مَجْنُون﴾</span>.</p><p>قَالَ محمدٌ: الْمَعْنى: إِلَّا قَالُوا: هَذَا سَاحر أَو مَجْنُون.</p></div>"
  51,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أتواصوا بِهِ﴾</span> على الِاسْتِفْهَام، أَي: لمْ يتواصَوْا بِهِ؛ لأنّ الأمَّة الأولى لم تدْرك الْأمة الْأُخْرَى، قَالَ: <span class="qpc-hafs">﴿بَلْ هم قوم طاغون﴾</span> مشركون.</p></div>"
  51,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فتول عَنْهُم﴾</span> أَي: فَأَعْرض عَنْهُم، وَهَذَا قبل أَن يُؤمر بقتالهم <span class="qpc-hafs">﴿فَمَا أَنْتَ بملوم﴾</span> فِي الحجَّةِ؛ فقد أقمتها عَلَيْهِم</p></div>"
  51,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَذَكِّرْ فَإِنَّ الذِّكْرَى تَنْفَعُ الْمُؤْمِنِينَ﴾</span> إِنَّمَا يقبل التَّذْكِرَة الْمُؤْمِنُونَ</p></div>"
  51,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا خَلَقْتُ الْجِنَّ وَالإِنْسَ إِلا ليعبدون﴾</span> أَي: ليقروا لي بالعبودية فِي تَفْسِير ابْن عَبَّاس.</p><p>قَالَ يحيى: كَقَوْلِه: <span class="qpc-hafs">﴿وَلَئِنْ سَأَلْتَهُمْ مَنْ خَلَقَهُمْ ليَقُولن الله﴾</span></p></div>"
  51,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا أُرِيدُ مِنْهُمْ مِنْ رِزْقٍ﴾</span> أَي: يرزقوا أنفسهم <span class="qpc-hafs">﴿وَمَا أُرِيدُ أَن يطْعمُون﴾</span> أَي: يطعموا أحدا</p></div>"
  51,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ اللَّهَ هُوَ الرَّزَّاقُ ذُو الْقُوَّة المتين﴾</span> الَّذِي لَا تضعف قوته</p></div>"
  51,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِن للَّذين ظلمُوا﴾</span> أشركوا <span class="qpc-hafs">﴿ذَنُوبًا مِثْلَ ذَنُوبِ أَصْحَابِهِمْ﴾</span> يَعْنِي: من مضى قبلهم من الْمُشْركين، تَفْسِير سعيد بْن جُبَير: الذَّنُوبُ: السَّجْلُ.</p><p>قَالَ يحيى: والسَّجْلُ: الدَّلْوُ.</p><p>يَحْيَى: عَنْ تَمَّامِ بْنِ نَجِيحٍ، عَنِ الْحَسَنِ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: قَالَ رَسُولِ اللَّهِ ﷺ: " لَوْ أَنَّ غَرْبًا مِنْ جَهَنَّمَ وُضِعَ بِالأَرْضِ لآذَى حَرُّهُ مَا بَيْنَ الْمَشْرِقِ وَالْمَغْرِبِ ". قَالَ تَمَّامٌ: وَالْغَرْبُ: الدَّلْوُ الْعَظِيمُ.</p><p>قَالَ محمدٌ: الذَّنُوب فِي اللُّغَة: الحظُّ والنصيبُ، وَأَصله: الدَّلْوُ الْعَظِيمَة، وَكَانُوا يستقون فَيكون لكل واحدٍ ذَنُوبٌ، فَجُعِل الذَّنوب مَكَان الْحَظ والنصيب، قَالَ أَبُو ذُؤَيْبٍ:</p><p>(لَعَمْرُكَ وَالمَنَايَا غَالِبَاتٌ ... لكُلِّ بَنِي أَبٍ مِنْهَا ذَنُوبُ)</p><p>قَوْله: <span class="qpc-hafs">﴿فَلا يَسْتَعْجِلُونِ﴾</span> أَي: فَلَا يستعجلون بِالْعَذَابِ لما كَانُوا يستعجلون بِهِ من الْعَذَاب استهزاء وتكذيباً</p></div>"
  51,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فويل للَّذين كفرُوا﴾</span> فِي النَّار <span class="qpc-hafs">﴿مِنْ يَوْمِهِمُ الَّذِي يوعدون﴾</span> فِي الدُّنْيَا.</p></div>"
  52,1,"<div class=ar lang=ar><p>تَفْسِير سُورَة الطّور وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ الله الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿وَالطور﴾</span> الطُّور: الْجَبَل.</p><p>قَالَ محمدٌ: رُوِيَ عَن الْحسن أَنه قَالَ: كل جبل يدعى طوراً.</p></div>"
  52,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكتاب مسطور﴾</span> مَكْتُوب</p></div>"
  52,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي رق منشور﴾</span> تَفْسِير الْحسن: الْقُرْآن فِي أَيدي السفرة</p></div>"
  52,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْبَيْت الْمَعْمُور﴾</span> تَفْسِير ابْن عَبَّاس قَالَ: الْبَيْت الْمَعْمُور: بَيت فِي السَّمَاء حِيَال الْكَعْبَة، يَحُجُّه كلَّ يَوْم سَبْعُونَ أَلْفَ مَلَكٍ لَا يَعُودُونَ إِلَيْهِ [ ... ].</p><p>قَالَ قَتَادَة: قَالَ اللَّه - عز وَجل - لآدَم: [أهبط مَعَك] (ل ٣٤٠) بَيْتِي يُطَاف حوله؛ كَمَا يُطَاف حول عَرْشِي، فحجه آدم وَمَا بعده من الْمُؤمنِينَ، فَلَمَّا كَانَ زمَان الطوفان رَفعه اللَّه وطهرَّه من أَن تصيبه عُقُوبَة أهل الأَرْض؛ فَصَارَ معمور السَّمَاء، فتتبع إِبْرَاهِيم الأساس فبناه على أساس قديم كَانَ قبله.</p></div>"
  52,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿والسقف الْمَرْفُوع﴾</span> يَعْنِي: السَّمَاء بَينهَا وَبَين الأَرْض مسيرَة خَمْسمِائَة عَام</p></div>"
  52,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْبَحْر الْمَسْجُور﴾</span> تَفْسِير عَليّ بْن أبي طَالب: الْبَحْر الْمَسْجُور فِي السَّمَاء.</p><p>قَالَ محمدٌ: الْمَسْجُور مَعْنَاهُ فِي اللُّغَة: المَمْلُوء، قَالَ النَّمِر يصف وَعلًا:</p><p>(إذَا شَاءَ طَالَعَ مَسْجُورةً ... تَرَى حَوْلَهَا النَّبْعَ والسَّاسَما)</p><p>أَي: عينا مَمْلُوءَة. أقسم بِهَذَا كُله.</p></div>"
  52,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن عَذَاب رَبك لوَاقِع﴾</span> بالمشركين</p></div>"
  52,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا لَهُ﴾</span> مَا للعذاب <span class="qpc-hafs">﴿من دَافع﴾</span> يَدْفَعهُ من الله</p></div>"
  52,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم تمور السَّمَاء مورا﴾</span> فِيهَا تَقْدِيم: إِن عَذَاب رَبك لوَاقِع بهم <span class="qpc-hafs">﴿يَوْمَ تَمُورُ السَّمَاءُ مورا﴾</span> أَي: تحرّك تحركاً</p></div>"
  52,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وتسير الْجبَال سيرا﴾</span> كَقَوْلِه: <span class="qpc-hafs">﴿وَإِذا الْجبَال سيرت﴾</span>.</p><p>قَالَ محمدٌ: الْمَعْنى: أَنَّهَا تسير عَن وَجه الأَرْض، وَهُوَ الَّذِي أَرَادَ يحيى.</p><p><span class="qpc-hafs">﴿فَوَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</span></p></div>"
  52,11,"<div class=ar lang=ar></div>"
  52,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِينَ هُمْ فِي خَوْضٍ يَلْعَبُونَ﴾</span> وخوضهم التَّكْذِيب.</p><p>قَالَ محمدٌ: (الويلُ) كلمةٌ تَقُولهَا الْعَرَب فِي كل من وَقع فِي هلكة.</p></div>"
  52,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم يدعونَ﴾</span> يُدْفَعُون <span class="qpc-hafs">﴿إِلَى نَارِ جَهَنَّمَ دَعًّا﴾</span> دفعا</p></div>"
  52,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذِه النَّار﴾</span> يُقَال لَهُم:</p><p>هَذِه النَّار <span class="qpc-hafs">﴿الَّتِي كُنْتُم بهَا تكذبون﴾</span> فِي الدُّنْيَا أَنَّهَا لَا تكون.</p></div>"