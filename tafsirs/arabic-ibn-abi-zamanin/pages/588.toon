quran[28]{c,v,t}:
  83,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كلا إِن كتاب الْفجار﴾</span> الْمُشْركين <span class="qpc-hafs">﴿لفي سِجِّين﴾</span> تَفْسِيرُ ابْنُ عَبَّاسٍ قَالَ: سَأَلْتُ كَعْبًا عَنْ قَوْلِهِ: <span class="qpc-hafs">﴿إِنَّ كِتَابَ الْفجار لفي سِجِّين﴾</span> فَقَالَ: حَجَرٌ أَسْوَدُ تَحْتَ الْأَرْضِ السَّابِعَةِ تُكْتَبُ فِيهِ أَرْوَاحُ الْكُفَّارِ.</p></div>"
  83,8,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿وَمَا أَدْرَاكَ مَا سِجِّينٌ﴾</span> أَيْ: لَيْسَ ذَلِكَ مِمَّا كُنْتَ تعلمه أَنْت وَلَا قَوْمك،</p></div>"
  83,9,"<div class=ar lang=ar><p>ثُمَّ فَسَّرَهُ فَقَالَ: <span class="qpc-hafs">﴿كِتَابٌ مَرْقُومٌ﴾</span> أَي: مَكْتُوب.</p></div>"
  83,10,"<div class=ar lang=ar></div>"
  83,11,"83:10"
  83,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُكَذِّبُ بِهِ إِلا كُلُّ مُعْتَد﴾</span> أَي: ظَالِم <span class="qpc-hafs">﴿أثيم﴾</span> آثم، وَهُوَ الْمُشرك</p></div>"
  83,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذَا تُتْلَى عَلَيْهِ آيَاتُنَا قَالَ أَسَاطِيرُ الأَوَّلِينَ﴾</span> كَذِبِ الأَوَّلِينَ وَبَاطِلِهِمْ</p></div>"
  83,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا بَلْ رَانَ عَلَى قُلُوبِهِمْ﴾</span> قَالَ الْكَلِّبِيُّ: يَعْنِي: طُبِعَ عَلَى قُلُوبهم <span class="qpc-hafs">﴿مَا كَانُوا يَكْسِبُونَ﴾</span>،</p><p>قَالَ مُحَمَّدٌ: وَاحِدُ (الْأَسَاطِيرِ): أُسْطُورَةٌ، مِثْلُ: أُحْدُوثَةٍ وَأَحَادِيثٍ، وَمَعْنَى (كَلَّا) عِنْدَ أَهْلِ اللُّغَةِ رَدْعٌ وَتَنْبِيهٌ، و (ران) بِمَعْنَى غَطَّى، يُقَالُ: رَانَ عَلَى قلبه الذَّنب يرين رينا.</p></div>"
  83,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا إِنَّهُمْ عَنْ رَبِّهِمْ يَوْمَئِذٍ لمحجوبون﴾</span> يَحْتَجِبُ اللَّهُ عَنِ الْمُشْرِكِينَ فَلا يَرَوْنَهُ، وَأَمَّا الْمُؤْمِنُونَ فَيَرَوْنَهُ فِي كُلِّ جُمُعَةٍ فَيَتَجَلَّى لَهُمْ، حَتَّى ينْظرُوا إِلَيْهِ.</p></div>"
  83,16,"<div class=ar lang=ar></div>"
  83,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذَا الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</span> فِي الدُّنْيَا يُقَالُ ذَلِكَ لِلمْشُرْكِينَ وهم فِي النَّار.</p></div>"
  83,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا إِنَّ كِتَابَ الأَبْرَارِ لَفِي عليين﴾</span> تَفْسِيرُ مُجَاهِدٍ: عِلِّيُّونَ فِي السَّمَاءِ السَّابِعَة</p></div>"
  83,19,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿وَمَا أَدْرَاكَ مَا عِلِّيُّونَ﴾</span> أَيْ: أَنَّكَ لَمْ تَدْرِ مَا عليون؟ حَتَّى أعلمتك</p></div>"
  83,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كتاب مرقوم﴾</span> مَكْتُوب، يكْتب فِي عليين</p></div>"
  83,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يشهده المقربون﴾</span> مُقَرَّبُو أَهْلِ كُلِّ سَمَاءٍ يَشْهَدُونَ كِتَابَ عَمَلِ الْمُؤْمِنِ حَيْثُ يُكْتَبُ فِيهِ، وَيَشْهَدُونَ عَلَيْهِمْ يَوْمَ الْقِيَامَةِ أَنَّهَا أَعْمَالهم.</p></div>"
  83,22,"<div class=ar lang=ar></div>"
  83,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿على الأرائك ينظرُونَ﴾</span> الْأَرَائِكُ السُّرُرُ فِي الْحِجَالِ، قَالَ مُجَاهِدٌ: وَهِيَ سُرُرٌ مِنْ لُؤْلُؤٍ وَيَاقُوت.</p></div>"
  83,24,"<div class=ar lang=ar></div>"
  83,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يسقون من رحيق مختوم﴾</span> يَعْنِي: الشَّرَاب، وَهِي الْخمر</p></div>"
  83,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ختامه مسك﴾</span> قَالَ مُجَاهِدٌ: يُخْتَمُ بِهِ آخِرُ جَرْعَةٍ.</p><p>قَالَ مُحَمَّدٌ: يَعْنِي: أَنَّهُمْ إِذا شربوا هَذَا الرَّحِيق فقني مَا فِي الْكَأْسِ وَانْقَطَعَ الشُّرْبُ، انْخَتَمَ ذَلِكَ بِطَعْمِ الْمِسْكِ وَرَائِحَتِهِ.</p><p>قَالَ: <span class="qpc-hafs">﴿وَفِي ذَلِكَ فَلْيَتَنَافَسِ الْمُتَنَافِسُونَ﴾</span> فِي الدُّنْيَا بِالْأَعْمَالِ الصَّالِحَة</p></div>"
  83,27,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿ومزاجه من تسنيم﴾</span> ومزاج ذَلِك الشَّارِب من تسنيم</p></div>"
  83,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عينا يشرب بهَا المقربون﴾</span> قَالَ قَتَادَةُ: يَشْرَبُ بِهَا الْمُقَرَّبُونَ صِرْفًا، وَتُمْزَجُ لِسَائِرِ أَهْلِ الْجَنَّةِ.</p><p>و (تسنيم) أَشْرَفُ شَرَابٍ فِي الْجَنَّةِ.</p><p>قَالَ: وَنصب (عينا) لِأَنَّ الْمَعْنَى مِنْ عَيْنٍ، كَمَا قَالَ: <span class="qpc-hafs">﴿أَأَسْجُدُ لِمَنْ خَلَقْتَ طِينًا﴾</span> أَي: من طين.</p></div>"
  83,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن الَّذين أجرموا﴾</span> أَشْرَكُوا <span class="qpc-hafs">﴿كَانُوا مِنَ الَّذِينَ آمَنُوا يَضْحَكُونَ﴾</span> فِي الدُّنْيَا، أَيْ: يَسْخَرُونَ بِهِمْ</p></div>"
  83,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذَا مَرُّوا بِهِمْ يَتَغَامَزُونَ﴾</span> كَانَ الْمُشْرِكُونَ إِذَا مَرَّ عَلَيْهِمُ النَّبي ﷺ وَأَصْحَابُهُ يَقُولُ بَعْضُهُمْ لِبَعْضٍ: انْظُرُوا إِلَى هَؤُلاءِ الَّذِينَ تَرَكُوا شَهَوَاتِهِمْ فِي الدُّنْيَا (ل ٣٨٩) يَطْلُبُونَ بِذَلِكَ - زَعَمُوا - نَعِيمَ الْآخِرَةِ</p></div>"
  83,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا انقلبوا﴾</span> يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿إِلَى أهلهم﴾</span> فِي الدُّنْيَا <span class="qpc-hafs">﴿انقلبوا فاكهين﴾</span> أَي: مسرورين</p></div>"
  83,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا رَأَوْهُمْ﴾</span> رَأَوْا أَصْحَابَ النَّبِيِّ ﷺ <span class="qpc-hafs">﴿قَالُوا إِن هَؤُلَاءِ لضالون﴾</span> يتركون شهواتهم فِي الدُّنْيَا.</p></div>"
  83,33,"<div class=ar lang=ar><p>قَالَ اللَّهُ: <span class="qpc-hafs">﴿وَمَا أُرْسِلُوا عَلَيْهِمْ حافظين﴾</span> يحفظون أَعْمَالهم يَعْنِي: الْمُشْركين</p></div>"
  83,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَالْيَوْمَ الَّذِينَ آمَنُوا مِنَ الْكُفَّارِ يَضْحَكُونَ﴾</span> تَفْسِيرُ الْحَسَنِ: هَذِهِ وَاللَّهِ الدَّوْلَةُ الْكَرِيمَةُ الَّتِي أَدَالَ اللَّهُ الْمُؤْمِنِينَ عَلَى الْمُشْرِكِينَ فِي الْآخِرَةِ، فَهُمْ يَضْحَكُونَ مِنْهُمْ، وَهُمْ مُتَّكِئُونَ عَلَى فُرُشِهِمْ يَنْظُرُونَ كَيْفَ يُعَذَّبُونَ، كَمَا كَانَ الْكُفَّارُ يَضْحَكُونَ مِنْهُمْ فِي الدُّنْيَا وَالْجَنَّةُ فِي السَّمَاءِ.</p><p>قَالَ الْحَسَنُ: قَالَ رَسُولُ اللَّهِ ﷺ: " يجاء بالمستهزئين يَوْمَ الْقِيَامَةِ فَيُفْتَحُ لَهُمْ بَابٌ إِلَى الْجَنَّةِ، فَيُقَالُ لَهُمْ: ادْخُلُوا، فَإِذَا جَاءُوا أُغْلِقَ دُونَهُمْ فَيَرْجِعُونَ، ثُمَّ يُدْعَوْنَ فَإِذَا جَاءُوا أُغْلِقَ دُونَهُمْ فَيَرْجِعُونَ، فَيُدْعَوْنَ لِيَدْخُلُوا فَإِذَا جَاءُوا أُغْلِقَ دُونَهُمْ حَتَّى إِنَّهُمْ يُدْعَوْنَ فَمَا يجيئون من الْيَأْس ".</p></div>"