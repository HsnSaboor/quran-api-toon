quran[13]{c,v,t}:
  72,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ الْجَنِّ وَهِيَ [مَكِّيَّةٌ]</p><p>بِسم الله الرَّحْمَن الرَّحِيم تَفْسِير سُورَة الْجِنّ من آيَة (١ - ٧)</p><p>قَوْلُهُ: <span class="qpc-hafs">﴿قُلْ أُوحِيَ إِلَيَّ أَنَّهُ اسْتمع نفر من الْجِنّ﴾</span> وهم (ل ٣٧٥) <span class="qpc-hafs">﴿فَقَالُوا إِنَّا سمعنَا قُرْآنًا عجبا﴾</span></p></div>"
  72,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يهدي إِلَى الرشد﴾</span> أَيْ: يُبَيِّنُ سَبِيلَ الْهُدَى <span class="qpc-hafs">﴿فَآمَنَّا بِهِ﴾</span> وَكَانُوا قَبْلَ ذَلِكَ فِيمَا ذُكِرَ على الْيَهُودِيَّة.</p></div>"
  72,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنه تَعَالَى﴾</span> ارْتَفع <span class="qpc-hafs">﴿جد رَبنَا﴾</span> عَظمته وكبرياؤه</p></div>"
  72,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنه كَانَ يَقُول سفيهنا﴾</span> وَهُوَ الْمُشْرِكُ مِنْهُمْ <span class="qpc-hafs">﴿عَلَى اللَّهِ شططا﴾</span> أَي: جورًا وكذبًا</p></div>"
  72,5,"<div class=ar lang=ar></div>"
  72,6,"<div class=ar lang=ar><p>قَالَ اللَّهُ: <span class="qpc-hafs">﴿وَأَنَّهُ كَانَ رِجَالٌ مِنَ الإِنْسِ يَعُوذُونَ بِرِجَالٍ مِنَ الْجِنّ فزادوهم رهقا﴾</span> تَفْسِيرُ الْكَلْبِيِّ: أَنَّ رِجَالًا مِنَ الْإِنْسِ كَانَ أَحَدُهُمْ فِي الْجَاهِلِيَّةِ إِذَا كَانَ مُسَافِرًا، فَأَمْسَى فِي الْأَرْضِ الْقَفْرِ نَادَى: أَعُوذُ بَسَيِّدِ هَذَا الْوَادِي مِنْ سُفَهَاءِ قَوْمِهِ، فَيَبِيتُ فِي مَنَعةٍ مِنْهُ حَتَّى يصبح <span class="qpc-hafs">﴿فزادوهم رهقا﴾</span> زَادَتِ الْجِنُّ لتعوُّذهم بِهِمْ إِثْمًا.</p></div>"
  72,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّهُمْ ظنُّوا﴾</span> ظَنَّ الْمُشْرِكُونَ مِنَ الْجِنِّ <span class="qpc-hafs">﴿كَمَا ظننتم﴾</span> يَقُولُهُ لِلْمُشْرِكِينَ مِنَ الْإِنْسِ <span class="qpc-hafs">﴿أَنْ لن يبْعَث الله أحدا﴾</span> يجحدون الْبَعْث.</p></div>"
  72,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّا لَمَسْنَا السَّمَاءَ فَوَجَدْنَاهَا مُلِئَتْ حرسا شَدِيدا وشهبا﴾</span> هَذَا قَوْلُ الْجِنِّ مَنْ كَانَ يفعل ذَلِك مِنْهُم</p></div>"
  72,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنا كُنَّا نقعد مِنْهَا﴾</span> مِنَ السَّمَاءِ <span class="qpc-hafs">﴿مَقَاعِدَ لِلسَّمْعِ فَمَنْ يَسْتَمِعِ الآنَ يَجِدْ لَهُ شِهَابًا رصدا﴾</span> أَيْ: حَفَظة تَمْنَعُ مِنَ الِاسْتِمَاعِ.</p><p>قَالَ محمدٌ: (الشهَاب الرَّصد): أَي: قد أُرصِدَ بِهِ للرَّجْم، و (شُهُبًا) جَمْعُ شِهَابٍ.</p><p>قَالَ يَحْيَى: وَكَانُوا يَسْتَمِعُونَ أَخْبَارًا مِنْ أَخْبَارِ السَّمَاءِ، وأمَّا الْوَحْيُ فَلَمْ يَكُونُوا يَقْدِرُونَ عَلَى أَنْ يَسْتَمِعُوهُ.</p><p>يَحْيَى: عَنْ عُبَيْدِ الصَّمَدِ قَالَ: سَمِعْتُ أَبَا رجاءٍ العُطَاردي يَقُولُ: «كُنَّا قَبْلَ أَنْ يُبعث النَّبِيُّ مَا نَرَى نَجْمًا يَرْمَى بِهِ؛ فَبَيْنَمَا نَحْنُ ذَاتَ لَيْلَةٍ إِذَا النُّجُومُ قَدْ رُمِيَ بِهَا فَقُلْنَا: مَا هَذَا؟ إِنْ هَذَا إِلَّا أمرٌ حَدَثٌ. فجاءنا أَنَّ النَّبِيَّ ﷺ بُعِثَ».</p></div>"
  72,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّا لَا نَدْرِي أَشَرٌّ أُرِيدَ بِمَنْ فِي الأَرْضِ أَمْ أَرَادَ بهم رَبهم رشدا﴾</span> تَفْسِيرُ الْحَسَنِ: أَنَّهُمْ قَالُوا: هَذَا أمرٌ حَدَثٌ حِينَ رُمِيَ بِالنُّجُومِ، فَلا نَدْرِي أشرٌّ أَرَادَ اللَّهُ بِأَهْلِ الْأَرْضِ أَنْ يُهْلِكَهُمْ أَمْ أَرَادَ بِهِمْ رَبُّهُمْ رَشَدًا، أَمْ أَحْدَثَ لَهُم مِنْهُ نعْمَة وكرامة؟:</p></div>"
  72,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنا منا الصالحون﴾</span> الْمُؤْمِنُونَ <span class="qpc-hafs">﴿وَمنا دون ذَلِك﴾</span> يَعْنُونَ: الْمُشْرِكِينَ <span class="qpc-hafs">﴿كُنَّا طَرَائِقَ قِدَدًا﴾</span> وَفِي الْجِنِّ مَؤْمِنُونَ ويهودٌ وَنَصَارَى ومجوسٌ وَعَبَدَةُ الْأَوْثَانِ.</p><p>قَالَ محمدٌ: (طَرَائِقُ) أَيْ: كُنَّا فِرَقًا، والقِدَدُ: جَمْعُ قِدّة، وَهِيَ بِمَنْزِلَةِ قِطْعَةٍ وقطعٍ.</p></div>"
  72,12,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَأَنا ظننا﴾</span> عَلِمْنَا <span class="qpc-hafs">﴿أَنْ لَنْ نُعْجِزَ اللَّهَ﴾</span> أَنْ نَسْبِقَ اللَّهَ حَتَّى لَا يَقْدِرُ عَلَيْنَا؛ فَيَبْعَثَنَا يَوْمَ الْقِيَامَةِ.</p></div>"
  72,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنا لما سمعنَا الْهدى﴾</span> الْقُرْآن <span class="qpc-hafs">﴿آمنا بِهِ﴾</span> صَدَّقْنَا بِهِ. <span class="qpc-hafs">﴿فَلا يَخَافُ بَخْسًا﴾</span> يَعْنِي: أَنْ يُنْقَصَ مِنْ عَمَلِهِ <span class="qpc-hafs">﴿وَلَا رهقا﴾</span> ظُلْمًا أَنْ يُزَادَ عَلَيْهِ مَا لَمْ يَعْمَلْ.</p><p>قَالَ محمدٌ: أَصْلُ (الرَّهَق) فِي اللُّغَةِ العيْبُ وَالظُّلْمُ؛ يُقَالُ: رَهَقَ وَتَرَهَّقَ فِي دِينِهِ إِذا ظلم.</p></div>"