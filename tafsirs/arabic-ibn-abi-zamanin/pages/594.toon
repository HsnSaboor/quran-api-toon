quran[27]{c,v,t}:
  89,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُول يَا لَيْتَني قدمت﴾</span> فِي الدُّنْيَا <span class="qpc-hafs">﴿لحياتي﴾</span> بَعْدَ الْمَوْتِ، يَتَمَنَّى لَوْ آمَنَ فِي الدُّنْيَا فَيَحْيَا فِي الْجَنَّةِ</p></div>"
  89,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَيَوْمَئِذٍ لَا يُعَذِّبُ عَذَابَهُ أَحَدٌ وَلَا يوثق وثَاقه أحد﴾</span> يَقُولُ: لَا يُعَذِّبُ عَذَابَ اللَّهِ أحد، ويوثق وثاق الله أحد.</p></div>"
  89,26,"<div class=ar lang=ar></div>"
  89,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَا أيتها النَّفس المطمئنة﴾</span> وَهُوَ الْمُؤْمِنُ نَفْسُهُ مُطْمَئِنَّةٌ آمِنَةٌ</p></div>"
  89,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ارجعي إِلَى رَبك راضية﴾</span> قد رضيت الثَّوَاب <span class="qpc-hafs">﴿مرضية﴾</span> قد رَضِي عَنْك</p></div>"
  89,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فادخلي فِي عبَادي﴾</span> تَفْسِيرُ السُّدِّيِّ مَعَ عِبَادِي <span class="qpc-hafs">﴿وَادْخُلِي جنتي﴾</span>.</p></div>"
  89,30,"<div class=ar lang=ar></div>"
  90,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ لَا أُقْسِمُ بِهَذَا الْبَلَدِ وَهِيَ مَكِّيَّةٌ كُلُّهَا</p><p>(بِسْمِ الله الرَّحْمَن الرَّحِيم)</p><p>قَوْله: <span class="qpc-hafs">﴿لَا أقسم﴾</span> أَي: أقسم <span class="qpc-hafs">﴿بِهَذَا الْبَلَد﴾</span> يَعْنِي: مَكَّة</p></div>"
  90,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنت حل بِهَذَا الْبَلَد﴾</span> وَهَذَا حِينَ أُحِلَّتْ لَهُ مَكَّةُ سَاعَةً مِنَ النَّهَارِ يَوْمَ الْفَتْحِ.</p><p>تَفْسِيرُ مُجَاهِدٍ: يَقُولُ: لَا تُؤَاخَذُ بِمَا فَعَلْتَ فِيهِ، وَلَيْسَ عَلَيْك فِيهِ مَا على الماس</p></div>"
  90,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ووالد﴾</span> يَعْنِي: آدم <span class="qpc-hafs">﴿وَمَا ولد﴾</span> وَهَذَا كُله قسم.</p></div>"
  90,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَقَدْ خَلَقْنَا الإِنْسَانَ فِي كَبَدٍ﴾</span> تَفْسِيرُ قَتَادَةَ: يُكَابِدُ عَمَلَ الدُّنْيَا، وَإِذَا كَانَ مُؤْمِنًا كَابَدَ أَيْضًا عمل الْآخِرَة.</p></div>"
  90,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحْسَبُ أَنْ لَنْ يَقْدِرَ عَلَيْهِ أحد﴾</span> يَعْنِي: أَلَّا يَقْدِرَ اللَّهُ عَلَيْهِ، وَهَذَا الْمُشْرِكُ يَحْسَبُ أَنْ لَنْ يَبْعَثهُ الله بِعْ الْمَوْت</p></div>"
  90,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُول أهلكت مَالا لبدا﴾</span> كَثِيرًا، أَيْ: أَكَلْتُ وَأْتَلَفْتُ، فَمَنْ ذَا الَّذِي يُحَاسِبُنِي؟! فِي تَفْسِيرِ مُجَاهِدٍ.</p><p>قَالَ مُحَمَّد: (لبدا) هُوَ مِنَ التَّلْبِيدِ، كَأَنَّ بَعْضَهُ على بعض.</p></div>"
  90,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحْسَبُ أَنْ لَمْ يَرَهُ أَحَدٌ﴾</span> أَيْ: لَمْ يَرَهُ اللَّهُ حِينَ أَهْلَكَ ذَلِكَ الْمَالَ، أَيْ: بَلَى قد رَآهُ الله.</p></div>"
  90,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمْ نَجْعَلْ لَهُ عَيْنَيْنِ وَلِسَانًا وشفتين﴾</span> فَالَّذِي جَعَلَ ذَلِكَ قَادِرٌ عَلَى أَن يَبْعَثهُ فيحاسبه</p></div>"
  90,9,"<div class=ar lang=ar></div>"
  90,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وهديناه النجدين﴾</span> أَيْ: بَصَّرْنَاهُ السَّبِيلَيْنِ: سَبِيلَ الْهُدَى، وسبيل الضَّلَالَة</p></div>"
  90,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا اقتحم الْعقبَة﴾</span> أَيْ: لَمْ يَقْتَحِمِ الْعَقَبَةَ، وَهَذَا خَبَرٌ، أَيْ: أَنَّهُ لَمْ يَفْعَلْ.</p><p>قَالَ مُحَمَّدٌ: الْعَرَبُ تَقُولُ: لَا فعل بِمَعْنى لم يفعل.</p></div>"
  90,12,"<div class=ar lang=ar><p>قَالَ: <span class="qpc-hafs">﴿وَمَا أَدْرَاكَ مَا الْعَقَبَةُ﴾</span> يَقُوله (ل ٣٩٤) للنَّبِي ﷺ أَيْ: أَنَّكَ لَمْ تَكُنْ تَدْرِي حَتَّى أعلمتك مَا الْعقبَة</p></div>"
  90,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فك رَقَبَة﴾</span> أَيْ: عِتْقُ رَقَبَةٍ مِنَ الرِّقِّ</p></div>"
  90,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مسغبة﴾</span> مجاعَة</p></div>"
  90,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتِيما ذَا مقربة﴾</span> قرَابَة</p></div>"
  90,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَو مِسْكينا ذَا مَتْرَبَة﴾</span> يَعْنِي: اللَّاصِقَ بِالتُّرَابِ مِنَ الْحَاجَةِ، فِي تَفْسِير الحَسَن. قَالَ مُحَمَّد: من قَرَأَ <span class="qpc-hafs">﴿فك رَقَبَة﴾</span> فَالْمَعْنَى: اقْتِحَامُ الْعَقَبَةِ فَكُّ رَقَبَةٍ أَوْ إِطْعَامٌ، وَهُوَ مَعْنَى قَوْلِ يَحْيَى. وَقَالُوا: تَرَبَ الرَّجُلُ تَرْبًا بِإِسْكَانِ الرَّاءِ إِذَا لَصِقَ بِالتُّرَابِ وَتَرَبَ تَرَبًا بِفَتْحِ الرَّاءِ إِذَا افْتَقَرَ وَأَتْرَبَ إِتْرَابًا إِذَا اسْتَغْنَى. قَالَ الْحَسَنُ: وَقَدْ عَلِمَ اللَّهُ - عَزَّ وَجَلَّ - أَنَّ قَوْمًا يَفْعَلُونَ هَذَا الَّذِي ذَكَرَ لَا يُرِيدُونَ الله بِهِ لَيْسُوا بمؤمنين،</p></div>"
  90,17,"<div class=ar lang=ar><p>فَاشْترط فَقَالَ: <span class="qpc-hafs">﴿ثمَّ كَانَ﴾</span> (الَّذِي فَعَلَ) هَذَا <span class="qpc-hafs">﴿مِنَ الَّذِينَ آمنُوا وَتَوَاصَوْا بِالصبرِ﴾</span> عَلَى مَا أَمَرَهُمُ اللَّهُ بِهِ وَعَمَّا نَهَاهُمْ عَنْهُ <span class="qpc-hafs">﴿وَتَوَاصَوْا بِالْمَرْحَمَةِ﴾</span> بِالتَّرَاحُمِ فِيمَا بَيْنَهُمْ.</p><p>قَالَ مُحَمَّدٌ: (ثمَّ) هَاهُنَا فِي معنى الْوَاو.</p></div>"
  90,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُولَئِكَ أَصْحَاب الميمنة﴾</span> يَعْنِي: الميامين عَلَى أَنْفُسِهِمْ، وَهُمْ أَهْلُ الْجَنَّةِ.</p><p>يَحْيَى: عَنِ الْمُبَارَكِ بْنِ فَضَالَةَ، عَنِ الْحَسَنِ قَالَ: قَالَ رَسُولُ اللَّهِ ﷺ: " مَنْ أَعْتَقَ رَقَبَةً مُؤْمِنَةً فَهِيَ فِكَاكُهُ مِنَ النَّارِ ".</p><p>يَحْيَى: عَنِ الْجَارُودِ، عَنْ عَطِيَّةَ الْعَوْفِيِّ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ قَالَ: قَالَ رَسُولَ اللَّهِ ﷺ: " أَيُّمَا مُسْلِمٍ أَطْعَمَ مُسْلِمًا عَلَى جُوعٍ أَطْعَمَهُ اللَّهُ يَوْمَ الْقِيَامَةِ من ثمار الْجنَّة ".</p></div>"
  90,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِينَ كَفَرُوا بِآيَاتِنَا هُمْ أَصْحَابُ المشئمة﴾</span> أَصْحَابُ الشُّؤْمِ عَلَى أَنْفُسِهِمْ، وَهُمْ أَهْلُ النَّارِ <span class="qpc-hafs">﴿عَلَيْهِمْ نَارٌ مُؤْصَدَةٌ﴾</span></p></div>"
  90,20,"<div class=ar lang=ar></div>"