quran[25]{c,v,t}:
  26,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ وَمَا عِلْمِي بِمَا كَانُوا يعْملُونَ﴾</span> أَيْ: بِمَا يَعْمَلُونَ، إِنَّمَا نَقْبَلُ مِنْهُمُ الظَّاهِرَ، وَلَيْسَ لِي بِبَاطِنِ أَمرهم علم.</p></div>"
  26,113,"<div class=ar lang=ar></div>"
  26,114,"26:113"
  26,115,"26:113"
  26,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا لَئِنْ لَمْ تَنْتَهِ يَا نُوحُ لَتَكُونَنَّ مِنَ الْمَرْجُومِينَ﴾</span> قَالَ قَتَادَةُ: يَعْنِي: بِالْحِجَارَةِ فَلَنَقْتُلَنَّكَ بِهَا</p></div>"
  26,117,"<div class=ar lang=ar></div>"
  26,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فافتح بيني وَبينهمْ فتحا﴾</span> أَيْ: اقْضِ بَيْنِي وَبَيْنَهُمْ قَضَاءً؛ وَهَذَا حِينَ أُمِرَ بِالدُّعَاءِ عَلَيْهِمْ، فاستجيب لَهُ فأهلكهم الله.</p></div>"
  26,119,"<div class=ar lang=ar></div>"
  26,120,"26:119"
  26,121,"26:119"
  26,122,"26:119"
  26,123,"26:119"
  26,124,"26:119"
