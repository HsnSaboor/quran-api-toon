quran[12]{c,v,t}:
  42,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَلِكَ أَوْحَيْنَا إِلَيْكَ رُوحًا﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿مِّنْ أَمْرِنَا﴾</span>.</p><p>قَالَ مُحَمَّد: معنى <span class="qpc-hafs">﴿روحا﴾</span> أَي: مَا يَهْتَدِي بِهِ الخَلْق؛ فَيكون حَيَاة [من الضلال].</p><p><span class="qpc-hafs">﴿مَا كُنتَ تَدْرِي﴾</span> قبل أَن نوحيه إِلَيْك <span class="qpc-hafs">﴿مَا الْكِتَابُ وَلاَ الإِيمَانُ وَلَكِن جَعَلْنَاهُ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿نُورًا﴾</span> أَي: ضِيَاء من الظُّلْمة <span class="qpc-hafs">﴿وَإِنَّكَ لَتَهْدِي﴾</span> <span class="qpc-hafs">﴿لتدعو﴾</span> (إِلَى صِرَاطٍ) <span class="qpc-hafs">﴿طَرِيق﴾</span> <span class="qpc-hafs">﴿مُّسْتَقِيم ٍ﴾</span></p></div>"
  42,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَاطِ اللَّهِ﴾</span> طَرِيق الله <span class="qpc-hafs">﴿أَلاَ إِلَى اللَّهِ تَصِيرُ الأُمُورُ﴾</span> يَعْنِي: أُمُور الْخَلَائق.</p></div>"
  43,1,"<div class=ar lang=ar><p>تَفْسِير سُورَة الزخرف وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ الله الرَّحْمَن الرَّحِيم</p></div>"
  43,2,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَالْكتاب الْمُبين﴾</span> الْبَين وَهَذَا قسم</p></div>"
  43,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا جَعَلْنَاهُ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿قُرْآنًا عَرَبيا لَعَلَّكُمْ تعقلون﴾</span> لكَي تعقلوا</p></div>"
  43,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّهُ﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿فِي أُمِّ الْكِتَابِ لدينا﴾</span> عندنَا <span class="qpc-hafs">﴿لعَلي﴾</span> رفيع <span class="qpc-hafs">﴿حَكِيم﴾</span> مُحكم , و <span class="qpc-hafs">﴿أم الْكتاب﴾</span>: (ل ٣١٣) اللَّوْحَ الْمَحْفُوظَ , وَتَفْسِيرُ أُمِّ الْكِتَابِ: جملَة الْكتاب وَأَصله.</p><p>قَالَ محمدٌ: وَمعنى <span class="qpc-hafs">﴿جَعَلْنَاهُ﴾</span> بَيناهُ , كَذَلِك قَالَ غير يحيى.</p></div>"
  43,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أفنضرب عَنْكُم الذّكر﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿صفحا﴾</span> تَفْسِير الْكَلْبِيّ يَقُول: أَنَذَرُ الذّكْرَ من أجلكم؟! <span class="qpc-hafs">﴿أَنْ كُنْتُمْ قَوْمًا مسرفين﴾</span> مُشْرِكين أَي: لَا نَذَرُه.</p><p>قَالَ مُحَمَّد: تقْرَأ <span class="qpc-hafs">﴿إِن كُنْتُم﴾</span> بِالْفَتْح وبالكسر , فَمن فتح فَالْمَعْنى: لِأَن كُنْتُم وَمن كسر فعلى الِاسْتِقْبَال؛ الْمَعْنى: إِن تَكُونُوا مسرفين نضرب عَنْكُم الذّكر.</p><p>وَيُقَال: ضربْتُ عَنهُ الذّكر وأضْربتُ بِمَعْنى وَاحِد إِذا امسكت. وَقَوله: <span class="qpc-hafs">﴿صفحا﴾</span> أَي: إعْرَاضًا يُقَال: صفحت عَن فلانٍ أَي: أَعرَضت عَنهُ , وَالْأَصْل فِي ذَلِك أَنَّك توليه صفحة عُنُقك.</p></div>"
  43,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَمْ أَرْسَلْنَا مِنْ نَبِيٍّ فِي الْأَوَّلين﴾</span> أَي: كثيرا</p></div>"
  43,7,"<div class=ar lang=ar></div>"
  43,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فأهلكنا أَشد مِنْهُم بطشا﴾</span> يَعْنِي: أشدّ من مُشْركي الْعَرَب قُوَّة <span class="qpc-hafs">﴿وَمضى مثل الْأَوَّلين﴾</span> يَعْنِي: وقائعه فِي الْأُمَم السَّالفة بتكذيبهم رسلهم</p></div>"
  43,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَئِن سَأَلتهمْ﴾</span> يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿من خلق السَّمَاوَات وَالأَرْضَ لَيَقُولُنَّ خَلَقَهُنَّ الْعَزِيزُ الْعَلِيمُ﴾</span></p></div>"
  43,10,"<div class=ar lang=ar><p>ثمَّ قَالَ: <span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمُ الأَرْضَ مهادًا﴾</span> أَي: بساطًا وفراشًا <span class="qpc-hafs">﴿وَجَعَلَ لَكُمْ فِيهَا سبلا﴾</span> طرقا <span class="qpc-hafs">﴿لَعَلَّكُمْ تهتدون﴾</span> لكَي تهتدوا الطّرق.</p></div>"