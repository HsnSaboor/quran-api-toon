quran[8]{c,v,t}:
  7,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وبوأكم فِي الأَرْض﴾</span> أسكنكم.</p><p><span class="qpc-hafs">﴿وَلَا تعثوا﴾</span> قَدْ مَضَى تَفْسِيرُهُ فِي سُورَةِ الْبَقَرَة.</p></div>"
  7,75,"<div class=ar lang=ar></div>"
  7,76,"7:75"
  7,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُوا النَّاقَةَ وَعَتَوْا عَنْ أَمْرِ رَبهم﴾</span> يَعْنِي: استكبروا.</p></div>"
  7,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَخَذتهم الرجفة﴾</span> قَالَ الْحَسَنُ: تَحَرَّكَتْ بِهِمُ الْأَرْضُ <span class="qpc-hafs">﴿فأصحبوا فِي دَارهم جاثمين﴾</span> أَيْ: قَدْ هَلَكُوا.</p><p>قَالَ محمدٌ: الْجُثُومُ أَصْلُهُ فِي كَلَامِ الْعَرَبِ: البروك على الركب.</p></div>"
  7,79,"<div class=ar lang=ar></div>"
  7,80,"7:79"
  7,81,"7:79"