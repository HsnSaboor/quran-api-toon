quran[26]{c,v,t}:
  37,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلنَا ذُريَّته هم البَاقِينَ﴾</span> فَالنَّاس كلهم ولد سَام وَحَام وَيَافث</p></div>"
  37,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَركنَا عَلَيْهِ فِي الآخرين﴾</span> يَعْنِي: أبقينا لَهُ الثّناءَ الْحَسَن</p></div>"
  37,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلامٌ عَلَى نُوحٍ فِي الْعَالَمِينَ﴾</span> يَعْنِي: مَا كَانَ بعد نوحٍ.</p></div>"
  37,80,"<div class=ar lang=ar></div>"
  37,81,"37:80"
  37,82,"37:80"
  37,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن من شيعته لإِبْرَاهِيم﴾</span> تَفْسِير مُجَاهِد: عَلَى منهاجه وسُنَّته</p></div>"
  37,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ جَاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ﴾</span> من الشّرك</p></div>"
  37,85,"<div class=ar lang=ar></div>"
  37,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أئفكا﴾</span> كذبا <span class="qpc-hafs">﴿آلِهَةً دُونَ اللَّهِ تُرِيدُونَ﴾</span> عَلَى الاسْتِفْهَامِ أَيْ قَدْ فَعَلْتُمْ؛ فعبدتموهم دونه</p></div>"
  37,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا ظنكم بِرَبّ الْعَالمين﴾</span> أَي: مُعَذِّبكُمْ</p></div>"
  37,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنظر نظرة فِي النُّجُوم﴾</span> فِي الْكَوَاكِب</p></div>"
  37,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَالَ إِنِّي سقيم﴾</span> أَي: مطعون</p></div>"
  37,90,"<div class=ar lang=ar></div>"
  37,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فتولوا عَنهُ مُدبرين﴾</span> إِلَى عيدهم؛ وَذَلِكَ أَنهم استتبعوه لعيدهم - فِي تَفْسِير الْكَلْبِيّ - فعصب رَأسه، وَقَالَ: إِنِّي رأيتُ اللَّيْلَة فِي النُّجُوم أَنِّي سأطعن غَدا! وَكَانُوا ينظرُونَ فِي النُّجُوم، فَقَالَ لَهُم هَذَا كَرَاهِيَة مِنْهُ للذهاب مَعَهم، وَلما أَرَادَ أَن يفعل بآلهتهم كادهم بذلك</p></div>"
  37,92,"<div class=ar lang=ar></div>"
  37,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فرَاغ عَلَيْهِم﴾</span> أَي: مَال عَلَى آلِهَتهم <span class="qpc-hafs">﴿ضَرْبًا بِالْيَمِينِ﴾</span> فَكَسرهَا إِلَّا كَبِيرهمْ، وَقد مضى تَفْسِيره فِي سُورَة الْأَنْبِيَاء</p></div>"
  37,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَقْبَلُوا إِلَيْهِ﴾</span> إِلَى إِبْرَاهِيم <span class="qpc-hafs">﴿يزفون﴾</span> أَي يبتدرونه.</p><p>قَالَ محمدٌ: من قَرَأَ (يزفون) بِفَتْح الْيَاء وَتَشْديد الْفَاء فَالْمَعْنى: يسرعون وَأَصله من: زَفِيفِ النَّعَام، يُقَال: زفَّت النعامُ تَزِفُّ زفيفًا، وَفِيه لُغَة أُخْرَى: أزفت زفافا.</p></div>"
  37,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ﴾</span> لَهُم إِبْرَاهِيم <span class="qpc-hafs">﴿أَتَعْبُدُونَ مَا تَنْحِتُونَ﴾</span> يَعْنِي: أصنامهم</p></div>"
  37,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالله خَلقكُم وَمَا تَعْمَلُونَ﴾</span> أَي: خَلقكُم وَخلق ذَلكَ الَّذِي تنحتون بِأَيْدِيكُمْ</p></div>"
  37,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا ابْنُوا لَهُ بنيانا﴾</span> يَقُوله بعضُهم لبَعض <span class="qpc-hafs">﴿فَأَلْقُوهُ فِي الْجَحِيم﴾</span> أَي: فِي النَّار؛ فَجمعُوا الْحَطب زَمَانًا، ثُمَّ جَاءُوا بِإِبْرَاهِيمَ، فَأَلْقَوْهُ فِي تِلْكَ النَّار</p></div>"
  37,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فأرادوا بِهِ كيدا﴾</span> بحرقهم إِيَّاه <span class="qpc-hafs">﴿فجعلناهم الأسفلين﴾</span> فِي النَّار</p></div>"
  37,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالَ إِنِّي ذَاهِبٌ إِلَى رَبِّي سيهدين﴾</span> يَعْنِي: سيهديني الطَّرِيق، هَاجر من أَرْضِ الْعِرَاقِ إِلَى أَرْضِ الشَّامِ</p></div>"
  37,100,"<div class=ar lang=ar><p>[<span class="qpc-hafs">﴿رَبِّ هَبْ لِي مِنَ الصَّالِحِينَ﴾</span> يُرِيد: ولدا تقيا صَالحا</p></div>"
  37,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فبشرناه بِغُلَام حَلِيم﴾</span> يُرِيد إِسْمَاعِيل]</p></div>"
  37,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَمَّا بلغ مَعَه السَّعْي﴾</span> [يُرِيد الْعَمَل لله - تَعَالَى - وَهُوَ الِاحْتِلَام]، تَفْسِير الْحَسَن يَعْنِي: سعي الْعَمَل وَقيام الْحجَّة.</p><p>[<span class="qpc-hafs">﴿قَالَ﴾</span> إِسْمَاعِيل <span class="qpc-hafs">﴿يَا أَبَتِ افْعَلْ مَا تُؤمر﴾</span> يُرِيد مَا أوحى إِلَيْك رَبك <span class="qpc-hafs">﴿سَتَجِدُنِي إِنْ شَاءَ اللَّهُ مِنَ الصابرين﴾</span> على بلَاء الله.</p></div>"