quran[20]{c,v,t}:
  44,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَوْم الْفَصْل﴾</span> يَعْنِي: الْقَضَاء <span class="qpc-hafs">﴿ميقاتهم أَجْمَعِينَ﴾</span> أَي: مِيقَات بَعثهمْ <span class="qpc-hafs">﴿يَوْمَ لَا يُغْنِي مَوْلًى عَنْ مولى﴾</span> ولي عَن ولي <span class="qpc-hafs">﴿شَيْئا﴾</span> أَي: لَا يحمل من ذنوبهم شَيْئا <span class="qpc-hafs">﴿وَلَا هم ينْصرُونَ﴾</span> يمْنَعُونَ من الْعَذَاب</p></div>"
  44,41,"<div class=ar lang=ar></div>"
  44,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا من رحم الله﴾</span> قَالَ الْحسن: يَعْنِي: من الْمُؤمنِينَ يشفع بعضُهم لبَعض؛ فينفعهم ذَلِك عِنْد الله.</p></div>"
  44,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن شَجَرَة الزقوم﴾</span></p></div>"
  44,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَعَام الأثيم﴾</span> الْمُشرك</p></div>"
  44,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَالْمهْلِ﴾</span> الْمهل: مَا كَانَ ذائبًا من الْفضة والنحاس وَمَا أشبه ذَلِك.</p><p>قَالَ محمدٌ: وَقيل: الْمهل: عكر الزَّيْت الشَّديد السوَاد.</p><p><span class="qpc-hafs">﴿تَغْلِي فِي الْبُطُونِ﴾</span></p></div>"
  44,46,"<div class=ar lang=ar></div>"
  44,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَغَلْيِ الْحَمِيمِ﴾</span> يَعْنِي: المَاء الشَّديد الْحر <span class="qpc-hafs">﴿خذوه فاعتلوه﴾</span> قَالَ الْحسن: يَعْنِي: فجرُّوه <span class="qpc-hafs">﴿إِلَى سَوَاء الْجَحِيم﴾</span> وسط الْجَحِيم.</p><p>قَالَ محمدٌ: العَتْلُ فِي اللُّغَة أَن يُمْضَى بِهِ بعنْفٍ وَشدَّة، يُقَال مِنْهُ: عتَلَ يَعْتُلُ، وَفِيه لُغَة أُخْرَى: يَعْتِلُ.</p></div>"
  44,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِنْ عَذَاب الْحَمِيم﴾</span> كَقَوْلِه <span class="qpc-hafs">﴿يُصَبُّ مِنْ فَوْقِ رُءُوسِهِمُ الْحَمِيمُ يُصْهَرُ بِهِ مَا فِي بُطُونِهِمْ وَالْجُلُودُ وَلَهُمْ مَقَامِعُ مِنْ حَدِيد﴾</span> يُقْمَعُ بالمقمعة، فتخرقُ رأسَهُ، فيُصَبُّ على رَأسه الْحَمِيم، فَيدْخل فِي فِيهِ حَتَّى يصل إِلَى جَوْفه.</p></div>"
  44,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُقْ إِنَّكَ أَنْتَ الْعَزِيزُ الْكَرِيمُ﴾</span> يَعْنِي: المنيع الْكَرِيم عِنْد نَفسك، إِذْ كنت فِي الدُّنْيَا وَلست كَذَلِك، قَالَ بَعضهم: نزلت فِي أبي جهل كَانَ يَقُول: أَنا أعز قُرَيْش وَأَكْرمهَا</p></div>"
  44,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن هَذَا﴾</span> يَعْنِي: (الْعَذَاب) <span class="qpc-hafs">﴿مَا كُنْتُمْ بِهِ تمترون﴾</span> تشكون فِي الدُّنْيَا أَنه كَائِن.</p></div>"
  44,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن الْمُتَّقِينَ فِي مقَام﴾</span> فِي منزل <span class="qpc-hafs">﴿امين﴾</span> أَي: هم آمنون فِيهِ من الغِيَرِ.</p><p>قَالَ محمدٌ: من قَرَأَ <span class="qpc-hafs">﴿مُقامٍ﴾</span> بِرَفْع الْمِيم فَهُوَ من قَوْلهم: أَقَام مُقَامًا، وَمن قَرَأَ بِفَتْح الْمِيم فَهُوَ من قَوْلهم: قَامَ يقوم.</p></div>"
  44,52,"<div class=ar lang=ar></div>"
  44,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يلبسُونَ من سندس وإستبرق﴾</span> تَفْسِير الْحسن: هما جَمِيعًا حَرِير.</p><p>قَالَ محمدٌ: قيل الاسْتَبْرَقُ: الدِّيبَاجُ الصَّفِيقُ الكثيف، والسُّنْدس: الرَّقِيق.</p><p>قَالَ كَعْب: فِي الْجنَّة شجر تُنْبِت الاستبرق وَالْحَرِير؛ مِنْهُ يكون لِبَاس أهل الْجنَّة. قَوْله: <span class="qpc-hafs">﴿مُتَقَابِلِينَ﴾</span> لَا ينظر بعضُهم إِلَى قَفَا بعضٍ إِذا تزاوروا؛ فِي تَفْسِير بَعضهم.</p></div>"
  44,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَلِك وزوجناهم بحور عين﴾</span> تَفْسِير الْحسن، أَي: كَذَلِك حكم الله لأهل الْجنَّة بِهَذَا؛ والحُور: البيضُ؛ فِي تَفْسِير قَتَادَة، والعِينُ: عظامُ الْعُيُون.</p><p>قَالَ محمدٌ: قَوْله <span class="qpc-hafs">﴿وزوجناهم﴾</span> أَي: قرناهم بِهن.</p></div>"
  44,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يدعونَ فِيهَا بِكُل فَاكِهَة﴾</span> أَي: يَأْتِيهم مَا يشتهون فِيهَا <span class="qpc-hafs">﴿أمنين﴾</span> من الْمَوْت</p></div>"
  44,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَذُوقُونَ فِيهَا الْمَوْتَ إِلا الموتة الأولى﴾</span> وَلَيْسَ ثَمَّ موتَة، إِنَّمَا هِيَ هَذِه الموتة الْوَاحِدَة فِي الدُّنْيَا.</p><p><span class="qpc-hafs">﴿فَضْلا مِنْ رَبِّكَ ذَلِكَ هُوَ الْفَوْز الْعَظِيم﴾</span> النجَاة الْعَظِيمَة من النَّار إِلَى الْجنَّة.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿فضلا﴾</span> منصوبٌ بِمَعْنى: وَذَلِكَ بفضلٍ من الله، أَي: فعل ذَلِك مِنْهُ فضلا.</p></div>"
  44,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّمَا يسرناه﴾</span> يَعْنِي: الْقُرْآن <span class="qpc-hafs">﴿بلسانك﴾</span> يَعْنِي: النَّبِي، لَوْلَا أَن الله يسره بِلِسَان محمدٍ مَا كَانُوا ليقرءوه وَلَا يفقهوه <span class="qpc-hafs">﴿لَعَلَّهُم يتذكرون﴾</span> لكَي يتذكروا</p></div>"
  44,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَارْتَقِبْ﴾</span> فانتظر الْعَذَاب، فَإِنَّهُ واقعٌ بهم <span class="qpc-hafs">﴿إِنَّهُم مرتقبون﴾</span> منتظرون.</p></div>"
  44,59,"<div class=ar lang=ar></div>"