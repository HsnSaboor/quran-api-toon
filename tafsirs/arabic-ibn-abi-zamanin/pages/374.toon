quran[24]{c,v,t}:
  26,160,"26:156"
  26,161,"26:156"
  26,162,"26:156"
  26,163,"26:156"
  26,164,"26:156"
  26,165,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿وَتَذَرُونَ مَا خَلَقَ لَكُمْ ربكُم من أزواجكم﴾</span> يَعْنِي: أَقْبَالُ النِّسَاءِ <span class="qpc-hafs">﴿بَلْ أَنْتُمْ قوم عادون﴾</span> أَي: مجاوزون لأمر الله</p></div>"
  26,166,"<div class=ar lang=ar></div>"
  26,167,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا لَئِنْ لَمْ تَنْتَهِ يَا لوط لتكونن من المخرجين﴾</span> من قريتنا؛ أَي: نقتلك</p></div>"
  26,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالَ إِنِّي لِعَمَلِكُمْ مِنَ الْقَالِينَ﴾</span> يَعْنِي: المبغضين</p></div>"
  26,169,"<div class=ar lang=ar></div>"
  26,170,"26:169"
  26,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا عجوزا فِي الغابرين﴾</span> يَعْنِي: الْبَاقِينَ فِي عَذَابِ اللَّهِ.</p></div>"
  26,172,"<div class=ar lang=ar></div>"
  26,173,"26:172"
  26,174,"26:172"
  26,175,"26:172"
  26,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذب أَصْحَاب ليكة الْمُرْسلين﴾</span> وَالْأَيْكَةُ: الْغَيْضَةُ.</p><p>قَالَ مُحَمَّدٌ: قَرَاءَةُ أَهْلِ الْمَدْيِنَةِ فِي هَذِهِ السُّورَةِ، وَهِي سُورَةِ " ص " بِغَيْرِ أَلِفٍ، وَقَدْ ذَكَرْتُ مَا قَالَهُ أَبُو عُبَيْدٍ فِي الْفَرْقِ، بَيْنَ لَيْكَةِ وَالْأَيْكَةِ فِي سُورَة الْحجر.</p></div>"
  26,177,"<div class=ar lang=ar></div>"
  26,178,"26:177"
  26,179,"26:177"
  26,180,"26:177"
  26,181,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوْفُوا الْكَيْلَ وَلا تَكُونُوا مِنَ المخسرين﴾</span> يَعْنِي: المنتقصين لحقوق النَّاس</p></div>"
  26,182,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وزنوا بالقسطاس الْمُسْتَقيم﴾</span> يَعْنِي: الْعدْل</p></div>"
  26,183,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تبخسوا النَّاس أشياءهم﴾</span> أَيْ: لَا تَنْقُصُوهُمُ الَّذِي لَهُمْ، وَكَانُوا أَصْحَابَ نُقْصَانٍ فِي الْمِيزَانِ <span class="qpc-hafs">﴿وَلا تَعْثَوْا فِي الأَرْضِ مُفْسِدِينَ﴾</span> قد مضى تَفْسِيره.</p></div>"