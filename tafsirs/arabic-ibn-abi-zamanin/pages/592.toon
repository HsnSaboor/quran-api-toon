quran[30]{c,v,t}:
  87,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل تؤثرون الْحَيَاة الدُّنْيَا﴾</span> يَقُولُهُ لِلْمُشْرِكِينَ، أَيْ: يَزْعُمُونَ أَنَّ الدُّنْيَا بَاقِيَةٌ، وَأَنَّ الْآخِرَةَ لَا تكون</p></div>"
  87,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْآخِرَة خير﴾</span> من الدُّنْيَا <span class="qpc-hafs">﴿وَأبقى﴾</span> أَيْ: وَأَنَّ الدُّنْيَا لَا تَبْقَى، وَأَنَّ الْآخِرَةَ بَاقِيَةٌ، يَعْنِي: بِهَذَا الْجنَّة</p></div>"
  87,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ هَذَا لَفِي الصُّحُفِ الأُولَى صحف إِبْرَاهِيم ومُوسَى﴾</span> تَفْسِيرُ بَعْضِهِمْ: يَقُولُ فِيهَا: إِنَّ الْآخِرَةَ خَيْرٌ مِنَ الدُّنْيَا وَأَبْقَى.</p></div>"
  87,19,"<div class=ar lang=ar></div>"
  88,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ وَهِيَ مَكِّيَّةٌ كُلُّهَا</p><p>بِسْمِ الله الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿هَل أَتَاك﴾</span> قد أَتَاك <span class="qpc-hafs">﴿حَدِيث الغاشية﴾</span> يَعْنِي: الْقِيَامَةَ - فِي تَفْسِيرِ الْحَسَنِ - تَغْشَى النَّاسَ بِعَذَابِهَا وَعِقَابِهَا</p></div>"
  88,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوه يَوْمئِذٍ خاشعة﴾</span> ذَلِيلَةٌ، يَعْنِي: وُجُوهَ أَهْلِ النَّارِ</p></div>"
  88,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عاملة ناصبة﴾</span> كَفَرَتْ بِاللَّهِ فِي الدُّنْيَا، فَأَعْمَلَهَا وأنصبها فِي النَّار</p></div>"
  88,4,"<div class=ar lang=ar></div>"
  88,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تسقى من عين آنِية﴾</span> حارة قد انْتهى حرهَا</p></div>"
  88,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيْسَ لَهُمْ طَعَامٌ إِلا مِنْ ضَرِيع﴾</span> قَالَ الْكَلْبِيُّ: نَبْتٌ يَنْبُتُ فِي الرَّبِيعِ، فَإِذَا كَانَ فِي الصَّيْفِ يَبِسَ فَاسْمُهُ إِذَا كَانَ عَلَيْهِ وَرَقُهُ: [شِبْرَقٌ] وَإِذَا تَسَاقَطَ وَرَقُهُ فَهُوَ الضَّرِيعُ، فَالْإِبِلُ تَأْكُلُهُ أَخْضَرَ، فَإِذا يبس لم تذقه.</p></div>"
  88,7,"<div class=ar lang=ar></div>"
  88,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُجُوه يَوْمئِذٍ ناعمة﴾</span> وهم أهل الْجنَّة</p></div>"
  88,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لسعيها﴾</span> لثواب عَملهَا <span class="qpc-hafs">﴿راضية﴾</span></p></div>"
  88,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي جنَّة عالية﴾</span> {فِي السَّمَاء</p></div>"
  88,11,"<div class=ar lang=ar><p>٢ - ! (لَا تسمع فِيهَا لاغية} يَعْنِي: اللَّغْو</p></div>"
  88,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهَا عين جَارِيَة﴾</span> يَعْنِي: جَمَاعَةَ الْعُيُونِ، وَهِيَ الْأَنْهَارُ</p></div>"
  88,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهَا سرر مَرْفُوعَة﴾</span> عالية</p></div>"
  88,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأكواب مَوْضُوعَة﴾</span> وَاحِدُهَا كُوبٌ، وَهُوَ الْمُدَوَّرُ الْقَصِيرُ الْعُنُق الْقصير العروة</p></div>"
  88,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ونمارق مصفوفة﴾</span> وَهِي الوسائد</p></div>"
  88,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وزرابي﴾</span> وَهِي الْبسط <span class="qpc-hafs">﴿مبثوثة﴾</span> مَبْسُوطَةٌ بَلَغَنَا أَنَّهَا مَنْسُوجَةٌ بِالدُّرِّ والياقوت.</p></div>"
  88,17,"<div class=ar lang=ar><p>وَقَوْلُهُ: <span class="qpc-hafs">﴿أَفَلا يَنْظُرُونَ إِلَى الإِبِلِ كَيفَ خلقت﴾</span>.</p><p>قَالَ مُحَمَّدٌ: قِيلَ: أَرَادَ أَنَّهَا تَنْهَضُ بِأَحْمَالِهَا وَهِيَ بَارِكَةٌ، وَلَيْسَ يَفْعَلُ ذَلِكَ غَيْرُهَا مِنَ الدَّوَابِ.</p></div>"
  88,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وإلي السَّمَاء كَيفَ رفعت﴾</span> بَيْنكُم وَبَينهَا مسيرَة خَمْسمِائَة عَام</p></div>"
  88,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِلَى الْجبَال كَيفَ نصبت﴾</span> مثبتة</p></div>"
  88,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِلَى الأَرْض كَيفَ سطحت﴾</span> يَقُولُ: أَفَلا يَنْظُرُونَ إِلَى هَذَا، فَيَعْلَمُونَ أَنَّ الَّذِي خَلَقَ هَذِهِ الْأَشْيَاءَ قَادِرٌ عَلَى أَنْ يَبْعَثَهُمْ يَوْم الْقِيَامَة</p></div>"
  88,21,"<div class=ar lang=ar></div>"
  88,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لست عَلَيْهِم بمصيطر﴾</span> أَيْ (بِمُسَلِّطٍ) تُكْرِهُهُمْ عَلَى الْإِيمَانِ</p></div>"
  88,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا من تولى وَكفر﴾</span> أَيْ: فَكِلْهُ إِلَى اللَّهِ، وَكَانَ هَذَا قبل أَن يُؤمر بقتالهم</p></div>"
  88,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فيعذبه الله الْعَذَاب الْأَكْبَر﴾</span> جَهَنَّم</p></div>"
  88,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن إِلَيْنَا إيابهم﴾</span> رجوعهم</p></div>"
  88,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثمَّ إِن علينا حسابهم﴾</span> يَعْنِي: جَزَاءَهُمْ فِي تَفْسِيرِ السُّدِّيِّ.</p></div>"