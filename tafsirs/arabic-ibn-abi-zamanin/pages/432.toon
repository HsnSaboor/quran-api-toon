quran[8]{c,v,t}:
  34,32,"<div class=ar lang=ar></div>"
  34,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل مكر اللَّيْل وَالنَّهَار﴾</span> أَي: بل قَوْلكُم لنا بِاللَّيْلِ وَالنَّهَارِ <span class="qpc-hafs">﴿إِذْ تَأْمُرُونَنَا أَنْ نَكْفُرَ بِاللَّه ونجعل لَهُ أندادا﴾</span> يَعْنِي: أوثانهم عدلوها بِاللَّه فعبدوها دونه</p></div>"
  34,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا أَرْسَلْنَا فِي قَرْيَةٍ مِنْ نَذِير إِلَّا قَالَ مترفوها﴾</span> يَعْنِي: أهل السعَة وَالنعْمَة</p></div>"
  34,35,"<div class=ar lang=ar></div>"
  34,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلْ إِنَّ رَبِّي يَبْسُطُ الرِّزْقَ لمن يَشَاء وَيقدر﴾</span> أَي: يقتر <span class="qpc-hafs">﴿وَلَكِنَّ أَكْثَرَ النَّاسِ﴾</span> يَعْنِي: جمَاعَة الْمُشْركين <span class="qpc-hafs">﴿لَا يعلمُونَ﴾</span>.</p></div>"
  34,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا أَمْوَالُكُمْ وَلا أَوْلادُكُمْ بِالَّتِي تقربكم عندنَا زلفى﴾</span> الزلفى: الْقرْبَة <span class="qpc-hafs">﴿إِلا مَنْ آمَنَ﴾</span> أَي: لَيْسَ الْقرْبَة عندنَا إِلَّا لمن آمن وَعمل صَالحا <span class="qpc-hafs">﴿فَأُولَئِكَ لَهُم جَزَاء الضعْف﴾</span> يَعْنِي: تَضْعِيف الْحَسَنَات؛ كَقَوْلِه <span class="qpc-hafs">﴿مَنْ جَاءَ بِالْحَسَنَةِ فَلَهُ عَشْرُ أَمْثَالِهَا﴾</span> ثمَّ نزل بعد ذَلكَ بِالْمَدِينَةِ: <span class="qpc-hafs">﴿مَثَلُ الَّذِينَ يُنْفِقُونَ أَمْوَالَهُمْ فِي سَبِيلِ اللَّهِ كَمَثَلِ حَبَّةٍ أَنْبَتَتْ سبع سنابل﴾</span> الْآيَة.</p><p><span class="qpc-hafs">﴿وَالَّذين يسعون﴾</span> يعْملُونَ <span class="qpc-hafs">﴿فِي آيَاتنَا معاجزين﴾</span> أيْ: يظنون أَنهم يسْبقوننا حَتَّى لَا نقدر عَلَيْهِم فنعذبهم <span class="qpc-hafs">﴿أُولَئِكَ فِي الْعَذَاب محضرون﴾</span> مدخلون</p></div>"
  34,38,"<div class=ar lang=ar></div>"
  34,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا أَنفَقْتُم مِّن شَيْءٍ﴾</span> أَي: فِي طَاعَة اللَّه <span class="qpc-hafs">﴿فَهُوَ يخلفه﴾</span> تَفْسِير السّديّ: <span class="qpc-hafs">﴿فَهُوَ يخلفه﴾</span>؛ يَعْنِي: فِي الْآخِرَة؛ أَي: يعوضهم بِهِ الْجنَّة.</p></div>"