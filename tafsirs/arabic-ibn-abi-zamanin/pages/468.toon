quran[9]{c,v,t}:
  40,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَن صَلَحَ﴾</span> أَي: من آمن <span class="qpc-hafs">﴿مِنْ آبَائِهِمْ وَأَزْوَاجِهِمْ وَذُرِّيَّاتِهِمْ﴾</span>.</p></div>"
  40,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وقهم السَّيِّئَات﴾</span> يَعْنِي: جَهَنَّم هِيَ جَزَاء الشّرك <span class="qpc-hafs">﴿وَمن تق السَّيِّئَات﴾</span> أَي: تصرف عَنهُ</p></div>"
  40,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن الَّذين كفرُوا ينادون﴾</span> وهم فِي النَّار: <span class="qpc-hafs">﴿لَمَقْتُ اللَّهِ أكبر من مقتكم أَنفسكُم﴾</span> أَي: لمقت اللَّه إيَّاهُم فِي مَعْصِيَته أكبر من مقتهم أنفسهم فِي النَّار، وَذَلِكَ أَن أحدهم يمقت نَفسه <span class="qpc-hafs">﴿إِذْ تُدْعَوْنَ إِلَى الْإِيمَان﴾</span> فِي الدُّنْيَا <span class="qpc-hafs">﴿فَتَكْفُرُونَ﴾</span></p></div>"
  40,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا رَبَّنَا أَمَتَّنَا اثْنَتَيْنِ وَأَحْيَيْتَنَا اثْنَتَيْنِ﴾</span> وَهُوَ قَوْله فِي سُورَة الْبَقَرَة: <span class="qpc-hafs">﴿كَيْفَ تَكْفُرُونَ بِاللَّهِ وَكُنْتُمْ أَمْوَاتًا فَأَحْيَاكُمْ ثُمَّ يُمِيتُكُمْ ثُمَّ يُحْيِيكُمْ﴾</span>.</p><p>يَقُولُ: كُنْتُم أَمْوَاتًا فِي أصلبة آبائكم نطفاً <span class="qpc-hafs">﴿فأحياكم﴾</span> يَعْنِي: هَذِه الْحَيَاة الدُّنْيَا <span class="qpc-hafs">﴿ثُمَّ يميتكم﴾</span> يَعْنِي: مَوْتهمْ <span class="qpc-hafs">﴿ثمَّ يُحْيِيكُمْ﴾</span> يَعْنِي: الْبَعْث.</p><p><span class="qpc-hafs">﴿فَهَلْ إِلَى خُرُوجٍ من سَبِيل﴾</span> تَفْسِير الْحَسَن: فِيهَا إِضْمَار (قَالَ الله: لَا)</p></div>"
  40,12,"<div class=ar lang=ar><p>ثمَّ قَالَ: <span class="qpc-hafs">﴿ذَلِكُمْ بِأَنَّهُ إِذَا دُعِيَ اللَّهُ وَحْدَهُ كَفَرْتُمْ وَإِنْ يُشْرك بِهِ تؤمنوا﴾</span> تصدقوا بِعبَادة الْأَوْثَان.</p></div>"
  40,13,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿هُوَ الَّذِي يُرِيكُمْ آيَاتِهِ﴾</span> مَا أرَاهُ العبادَ من قدرته <span class="qpc-hafs">﴿وَيُنَزِّلُ لَكُمْ مِنَ السَّمَاءِ رِزْقًا﴾</span> الْمَطَر؛ يَعْنِي: فِيهِ أرزاق الْعباد <span class="qpc-hafs">﴿وَمَا يَتَذَكَّرُ إِلا مَنْ يُنِيبُ﴾</span> يخلص لله</p></div>"
  40,14,"<div class=ar lang=ar></div>"
  40,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رفيع الدَّرَجَات﴾</span> هُوَ رفيع الدَّرَجَات دَرَجَات الْمُؤمنِينَ فِي الْجنَّة <span class="qpc-hafs">﴿ذُو الْعَرْش﴾</span> رب الْعَرْش <span class="qpc-hafs">﴿يلقِي الرّوح﴾</span> ينزل الْوَحْي <span class="qpc-hafs">﴿لِيُنْذِرَ يَوْمَ التَّلاقِ﴾</span> [يَوْم الْقِيَامَة] يَوْم يلتقي فِيهِ الْخَلَائق: أهل السَّمَاء وَأهل الأَرْض عِنْد اللَّه.</p><p>قَالَ مُحَمَّد: الِاخْتِيَار فِي الْقِرَاءَة بِالْيَاءِ , وَقَرَأَ نَافِع بِغَيْر يَاء.</p></div>"
  40,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ هُم بَارِزُونَ لاَ يَخْفَى عَلَى اللَّهِ مِنْهُمْ شَيْءٌ لِّمَنِ الْمُلْكُ الْيَوْمَ﴾</span> يَقُول: لمن الْملك الْيَوْم؟ يسْأَل الْخَلَائق فَلَا يجِيبه أحد , فَيرد عَلَى نَفسه فَيَقُول: <span class="qpc-hafs">﴿لِلَّهِ الْوَاحِدِ القهار﴾</span> قهر الْعباد بِالْمَوْتِ , وَبِمَا شَاءَ من أمره قَالَ بَعضهم: هَذَا بَين النفختين حِين لَا يبْقى أحد غَيره.</p></div>"