quran[11]{c,v,t}:
  40,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ الَّذِي خَلَقَكُمْ مِنْ تُرَابٍ﴾</span> يَعْنِي: خلق آدم <span class="qpc-hafs">﴿ثُمَّ مِنْ نُطْفَة﴾</span> نسل آدم <span class="qpc-hafs">﴿ثُمَّ لِتَبْلُغُوا أَشُدَّكُمْ﴾</span> الِاحْتِلَام <span class="qpc-hafs">﴿ثمَّ لِتَكُونُوا شُيُوخًا﴾</span> يَعْنِي: من يبلغ حَتَّى يكون شَيخا <span class="qpc-hafs">﴿وَمِنْكُمْ مَنْ يُتَوَفَّى﴾</span> مِنْ قَبْلُ أَن يكون شَيخا <span class="qpc-hafs">﴿وَلِتَبْلُغُوا أَجَلا مُسَمّى﴾</span> الْمَوْت <span class="qpc-hafs">﴿ولعلكم تعقلون﴾</span> لكَي تعقلوا.</p></div>"
  40,68,"<div class=ar lang=ar></div>"
  40,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمْ تَرَ إِلَى الَّذِينَ يُجَادِلُونَ فِي آيَات الله﴾</span> يَعْنِي: يجحدون بآيَات اللَّه <span class="qpc-hafs">﴿أَنَّى يصرفون﴾</span> كَيفَ يصرفون عَنْهَا؟! <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span></p></div>"
  40,70,"<div class=ar lang=ar></div>"
  40,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذِ الأَغْلالُ فِي أَعْنَاقِهِمْ وَالسَّلاسِلُ يسْحَبُونَ﴾</span> تسحبهم الْمَلَائِكَة؛ أَي: تجرُّهم عَلَى وُجُوههم</p></div>"
  40,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي الْحَمِيمِ ثُمَّ فِي النَّارِ يسجرون﴾</span> أَي: توقد بهم النَّار.</p></div>"
  40,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيْنَ مَا كُنْتُمْ تُشْرِكُونَ مِنْ دُونِ اللَّهِ﴾</span> كَقَوْلِه: <span class="qpc-hafs">﴿أَيْنَ مَا كُنْتُمْ تَعْبُدُونَ من دون الله﴾</span></p></div>"
  40,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا ضَلُّوا عَنَّا بل لم نَكُنْ ندعوا من قبل شَيْئا﴾</span> ينفعنا وَلَا يضرنا , قَالَ اللَّه: <span class="qpc-hafs">﴿كَذَلِكَ يُضِلُّ اللَّهُ الْكَافِرِينَ﴾</span></p></div>"
  40,75,"<div class=ar lang=ar><p>ثمَّ رَجَعَ إِلَى قصَّتهم فَقَالَ: <span class="qpc-hafs">﴿ذَلِكُمْ بِمَا كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ بِغَيْرِ الْحَقِّ وَبِمَا كُنْتُمْ تمرحون﴾</span> الْفَرح والمرح وَاحِد؛ أَي: بِمَا كُنْتُم بطرين أشرين</p></div>"
  40,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فبئس مثوى﴾</span> منزل <span class="qpc-hafs">﴿المتكبرين﴾</span>.</p></div>"
  40,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِمَّا نُرِيَنَّكَ بَعْضَ الَّذِي نَعِدُهُمْ﴾</span> من الْعَذَاب <span class="qpc-hafs">﴿أَو نتوفينك﴾</span> فَيكون بعد وفاتك <span class="qpc-hafs">﴿فَإِلَيْنَا يُرْجَعُونَ﴾</span> يَوْم الْقِيَامَة.</p></div>"