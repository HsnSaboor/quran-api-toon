quran[13]{c,v,t}:
  42,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنْ آيَاتِهِ الْجَوَارِ﴾</span> السفن <span class="qpc-hafs">﴿فِي الْبَحْرِ كَالأَعْلاَمِ﴾</span> كالجبال. قَالَ محمدٌ: ذكر ابْن مُجَاهِد أَن نَافِعًا قَرَأَ <span class="qpc-hafs">﴿الْجَوَارِي﴾</span> بياء فِي الْوَصْل وَبِغير يَاء فِي الْوَقْف.</p></div>"
  42,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَشَأْ يُسْكِنِ الرِّياحَ فَيَظْلَلْنَ﴾</span> يَعْنِي: السفن <span class="qpc-hafs">﴿رواكد﴾</span> سواكن <span class="qpc-hafs">﴿على ظَهره﴾</span> على ظهر الْبَحْر <span class="qpc-hafs">﴿إِنَّ فِي ذَلِكَ لآيَاتٍ لِكُلِّ صَبَّارٍ شَكُورٍ﴾</span> أَي: لكل مُؤمن</p></div>"
  42,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَو يوبقهن﴾</span> يغرقْهُن؛ يَعْنِي: السفن <span class="qpc-hafs">﴿بِمَا كَسَبُوا﴾</span> عمِلُوا؛ يَعْنِي: أهل السفن.</p></div>"
  42,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَعْلَمَ الَّذِينَ يُجَادِلُونَ فِي آيَاتِنَا﴾</span> يجحدونها <span class="qpc-hafs">﴿مَا لَهُمْ مِنْ مَحِيصٍ﴾</span> أَي: ملْجأ يلجئون إِلَيْهِ من عَذَاب الله.</p><p>قَالَ محمدٌ: يُقَال: حَاص عَن الشَّيْء؛ أَي: تنحى عَنهُ , وتقرأ: <span class="qpc-hafs">﴿ويعلمُ﴾</span> بِرَفْع الْمِيم , وتقرأ بالنصْب , وَقِرَاءَة نَافِع بِالرَّفْع.</p></div>"
  42,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا أُوتِيتُم مِّن شَيْءٍ﴾</span> يَعْنِي: الْمُشْركين <span class="qpc-hafs">﴿فَمَتَاعُ الْحَيَاةِ الدُّنْيَا﴾</span> ينْفد وَيذْهب <span class="qpc-hafs">﴿وَمَا عِنْدَ اللَّهِ خير وَأبقى﴾</span> يَعْنِي: الْجنَّة.</p></div>"
  42,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِينَ يَجْتَنِبُونَ كَبَائِرَ الإِثْمِ وَالْفَوَاحِشَ﴾</span> أَي: ويجتنبون الْفَوَاحِش <span class="qpc-hafs">﴿وَإِذَا مَا غضبوا هم يغفرون﴾</span> يَعْنِي: يغفرون للْمُشْرِكين , وَهُوَ مَنْسُوخ نسخه الْقِتَال , وَصَارَ ذَلِك الْعَفو بَين الْمُؤمنِينَ.</p></div>"
  42,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذين اسْتَجَابُوا لرَبهم﴾</span> أَي: آمنُوا <span class="qpc-hafs">﴿وَأَقَامُوا الصَّلَاة﴾</span> كَانَت الصَّلَاة يَوْم نزلت هَذِه الْآيَة رَكْعَتَيْنِ غدْوَة , وَرَكْعَتَيْنِ عَشِيَّة قَبْلَ أَنْ تُفْرَضَ الصَّلَوَاتُ الْخَمْسُ <span class="qpc-hafs">﴿وَأمرهمْ شُورَى بَينهم﴾</span> تَفْسِير الْحسن أَي: يتشاورون فِي <span class="qpc-hafs">﴿وَمِمَّا رَزَقْنَاهُمْ يُنْفقُونَ﴾</span> وَلم يكن يومئذٍ شَيْء مؤقتًا. (ل ٣١٢)</p></div>"
  42,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذين إِذا أَصَابَهُم الْبَغي﴾</span> إِذا بغى عَلَيْهِم الْمُشْركُونَ فظلموهم <span class="qpc-hafs">﴿هم ينتصرون﴾</span> بألسنتهم لم يَكُونُوا أمروا بقتالهم يَوْمئِذٍ.</p></div>"
  42,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَزَاء سَيِّئَة سَيِّئَة مثلهَا﴾</span> يَعْنِي: مَا يسيء إِلَيْهِم الْمُشْركُونَ أَن يَفْعَلُوا بهم مَا يَفْعَلُونَ هم.</p><p>قَالَ محمدٌ: قَوْله: <span class="qpc-hafs">﴿وَجَزَاءُ سَيِّئَة سَيِّئَة مثلهَا﴾</span> فَالْأولى سَيِّئَة فِي اللَّفْظ وَالْمعْنَى , وَالثَّانيَِة سَيِّئَة فِي اللَّفْظ وعاملها لَيْسَ بمسيء وَلكنهَا سميت سَيِّئَة؛ لِأَنَّهَا مجازاة لسوء على مَذْهَب الْعَرَب فِي تَسْمِيَة الشَّيْء باسم الشَّيْء إِذا كَانَ من سَببه.</p><p><span class="qpc-hafs">﴿فَمن عَفا وَأصْلح﴾</span> يَقُول: فَمن ترك مظلمته <span class="qpc-hafs">﴿فَأَجْرُهُ﴾</span> ثَوَابه <span class="qpc-hafs">﴿عَلَى اللَّهِ إِنَّهُ لَا يحب الظَّالِمين﴾</span> الْمُشْركين</p></div>"
  42,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلمن انتصر بعد ظلمه﴾</span> بعد مَا ظُلِمَ <span class="qpc-hafs">﴿فَأُولَئِكَ مَا عَلَيْهِم من سَبِيل﴾</span> أَي: من حجَّة.</p></div>"
  42,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّمَا السَّبِيل﴾</span> الْحجَّة <span class="qpc-hafs">﴿عَلَى الَّذِينَ يَظْلِمُونَ النَّاسَ وَيَبْغُونَ فِي الأَرْضِ بِغَيْرِ الْحَقِّ﴾</span> يَعْنِي: بكفرهم وتكذيبهم <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ عَذَاب أَلِيم﴾</span> موجع</p></div>"
  42,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمَنْ صَبَرَ وَغَفَرَ إِنَّ ذَلِكَ لمن عزم الْأُمُور﴾</span> وَهَذَا كُله منسوخٌ فِيمَا بَينهم وَبَين الْمُشْركين نسخه الْقِتَال.</p></div>"
  42,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا لَهُ من ولي من بعده﴾</span> من بعد الله يمنعهُم من عَذَاب الله <span class="qpc-hafs">﴿وَترى الظَّالِمين﴾</span> الْمُشْركين <span class="qpc-hafs">﴿لَمَّا رَأَوُا الْعَذَابَ يَقُولُونَ هَل إِلَى مرد﴾</span> إِلَى الدُّنْيَا <span class="qpc-hafs">﴿من سَبِيل﴾</span> فنؤمن.</p></div>"