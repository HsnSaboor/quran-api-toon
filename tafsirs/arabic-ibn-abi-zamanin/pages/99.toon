quran[7]{c,v,t}:
  4,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن امْرَأَة خَافت﴾</span> يَعْنِي: علمت <span class="qpc-hafs">﴿من بَعْلهَا﴾</span> يَعْنِي: زَوجهَا <span class="qpc-hafs">﴿نُشُوزًا﴾</span> يَعْنِي: بغضا <span class="qpc-hafs">﴿أَوْ إِعْرَاضًا فَلا جنَاح﴾</span> لَا حرج. <span class="qpc-hafs">﴿عَلَيْهِمَا أَن يصالحا بَينهمَا صلحا وَالصُّلْح خير﴾</span> الْآيَة، قَالَ بَعضهم: هِيَ الْمَرْأَة تكون عِنْد الرجل فتكبر فَلَا تَلد، فيريد أَن يتَزَوَّج عَلَيْهَا أشب مِنْهَا، ويؤثرها على الْكَبِيرَة، فَيَقُول لَهَا: إِن رضيت أَن أوثرها عَلَيْك وَإِلَّا طَلقتك، أَو يُعْطِيهَا من مَاله على أَن ترْضى أَن يُؤثر عَلَيْهَا الشَّابَّة.</p><p>وقولُه: <span class="qpc-hafs">﴿وأحضرت الْأَنْفس الشُّح﴾</span> أَي: شحت بنصيبها من زَوجهَا لِلْأُخْرَى؛ فَلم ترض. <span class="qpc-hafs">﴿وَإِنْ تُحْسِنُوا﴾</span> [الْفِعْل] <span class="qpc-hafs">﴿وتتقوا﴾</span> الْميل والجور فِيهِنَّ <span class="qpc-hafs">﴿فَإِنَّ اللَّهَ كَانَ بِمَا تَعْمَلُونَ خَبِيرًا﴾</span>.</p></div>"
  4,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَنْ تَسْتَطِيعُوا أَنْ تَعْدِلُوا بَيْنَ النِّسَاء﴾</span> فِي الْحبّ <span class="qpc-hafs">﴿وَلَوْ حَرَصْتُمْ فَلَا تميلوا كل الْميل﴾</span> قَالَ الحَسَن: فتأتي وَاحِدَة، وَتَدَع الْأُخْرَى <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span> قَالَ الحَسَن: لَا أيم، وَلَا ذَات بعل. <span class="qpc-hafs">﴿وَإِن تصلحوا﴾</span> الْفِعْل فِي أمرهن <span class="qpc-hafs">﴿وتتقوا﴾</span> الْميل والجور فِيهِنَّ <span class="qpc-hafs">﴿فَإِنَّ اللَّهَ كَانَ غَفُورًا رحِيما﴾</span>.</p></div>"
  4,130,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَكَانَ اللَّهُ وَاسِعًا حَكِيمًا﴾</span> أَي: وَاسِعًا لَهما فِي الرزق (ل ٧٥) حكيماً فِي أمره.</p></div>"
  4,131,"<div class=ar lang=ar></div>"
  4,132,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وَكفى بِاللَّه وَكيلا﴾</span> لمن توكل عَلَيْهِ.</p></div>"
  4,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنْ يَشَأْ يُذْهِبْكُمْ أَيُّهَا النَّاسُ﴾</span> [أَي: يذهبكم] بِعَذَاب الاستئصال. <span class="qpc-hafs">﴿وَيَأْتِي بِآخَرين﴾</span> [بِقوم] يطيعونه.</p></div>"
  4,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنْ كَانَ يُرِيدُ ثَوَابَ الدُّنْيَا فَعِنْدَ اللَّهِ ثَوَابُ الدُّنْيَا وَالآخِرَةِ﴾</span> يَعْنِي: ثَوَاب الْآخِرَة لمن أَرَادَ الْآخِرَة.</p><p>هُوَ كَقَوْلِه: <span class="qpc-hafs">﴿مَنْ كَانَ يُرِيدُ الْعَاجِلَةَ عَجَّلْنَا لَهُ فِيهَا مَا نَشَاءُ لِمَنْ نُرِيدُ﴾</span> إِلَى قَوْله: <span class="qpc-hafs">﴿كَانَ سَعْيهمْ مشكورا﴾</span>.</p></div>"