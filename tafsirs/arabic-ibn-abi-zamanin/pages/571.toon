quran[18]{c,v,t}:
  71,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُرْسل السَّمَاء عَلَيْكُم مدرارا﴾</span> أَي: تدرُّ عَلَيْكُم بالمطر</p></div>"
  71,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَجْعَلْ لَكُمْ جنَّات وَيجْعَل لكم أَنهَارًا﴾</span>.</p><p>قَالَ مُحَمَّد: ٌ <span class="qpc-hafs">﴿جنَّات﴾</span> بساتين، وَقيل: إِنَّهُم كَانُوا قدأجدبوا فَأَعْلَمَهُمْ أَنَّ إِيَمَانَهِمْ بِاللَّهِ يَجْمَعُ لَهُمْ مَعَ الْحَظِّ الْوَافِرِ فِي الْآخِرَةِ الْخِصْبُ وَالْغِنَى فِي الدُّنْيَا.</p></div>"
  71,13,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿مَا لَكُمْ لَا تَرْجُونَ لله وقارا﴾</span> أَيْ: لَا تَخَافُونَ لِلَّهِ عَظَمَةً</p></div>"
  71,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقد خَلقكُم أطوارا﴾</span> تَفْسِيرُ قَتَادَةَ: يَعْنِي: نُطْفَةً ثُمَّ عَلَقَةً ثُمَّ مُضْغَةً ثُمَّ عَظْمًا ثُمَّ لَحْمًا.</p><p>قَالَ محمدٌ: (أَطْوَارًا) أَيْ: طَوْرًا بَعْدَ طَوْرٍ، نَقَلَكُمْ مِنْ حَالٍ إِلَى حَالٍ، وَهُوَ مَعْنَى قَوْلِ قَتَادَةَ. وَقَوْلُهُ: <span class="qpc-hafs">﴿تَرْجُونَ﴾</span> تَخَافُونَ، وَمِثْلُهُ قَوْلُ الشَّاعِرِ:</p><p>(مَحِلَّتُهُمْ ذَاتُ الْإِلَهِ وَدِينُهُمْ ... قويمٌ فَمَا يَرْجُونَ غَيْرَ الْعَوَاقِبِ)</p><p>أَيْ: مَا يخَافُونَ إِلَّا خَوَاتِم الْأَعْمَال.</p></div>"
  71,15,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿سبع سماوات طباقا﴾</span> يَعْنِي: بَعْضَهَا فَوْقَ بَعْضٍ.</p><p>قَالَ محمدٌ: (طباقًا) من نعت (سبع)؛ أَيْ: خَلَقَ سَبْعًا ذَاتَ أَطْبَاقٍ.</p><p><span class="qpc-hafs">﴿وَجعل الْقَمَر فِيهِنَّ نورٌ ا﴾</span> أَيْ: مَعَهِنَّ ضِيَاءٌ لِأَهْلِ الْأَرْضِ؛ فِي تَفْسِير الْكَلْبِيّ.</p></div>"
  71,16,"<div class=ar lang=ar></div>"
  71,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاللَّهُ أَنْبَتَكُمْ مِنَ الأَرْضِ نَبَاتًا﴾</span> خَلَقَكُمْ مِنَ الْأَرْضِ خَلْقًا؛ يَعْنِي: خَلَقَ آدَمَ.</p><p>قَالَ محمدٌ: (نَبَاتًا) مَحْمُولٌ فِي الْمَصْدَرِ عَلَى الْمَعْنَى؛ لِأَن معنى (أنبتكم): جعلكُمْ تنبتون نباتًا.</p></div>"
  71,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُخْرِجُكُمْ إِخْرَاجًا﴾</span> مِنْهَا يَوْم الْقِيَامَة</p></div>"
  71,19,"<div class=ar lang=ar></div>"
  71,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لتسلكوا مِنْهَا سبلا فجاجا﴾</span> تَفْسِيرُ قَتَادَةَ: يَعْنِي: طُرُقًا بَيِّنَةً.</p></div>"
  71,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاتبعُوا﴾</span> اتَّبَعَ بَعْضُهُمْ بَعْضًا عَلَى التَّكْذِيبِ <span class="qpc-hafs">﴿مَنْ لَمْ يَزِدْهُ مَالُهُ وَوَلَدُهُ إِلَّا خسارا﴾</span> عِنْد الله باتبَاعهمْ إِيَّاه</p></div>"
  71,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ومكروا مكرا كبارًا﴾</span> عَظِيمًا وَهُوَ الشِّرْكُ.</p><p>قَالَ محمدٌ: يُقَالُ: مكرٌ كبيرٌ وكُبّارٌ فِي معنى وَاحِد.</p></div>"
  71,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالُوا لَا تذرن آلِهَتكُم﴾</span> إِلَى قَوْله: <span class="qpc-hafs">﴿ونسرا﴾</span> وَهِيَ أَسْمَاءُ آلِهَتِهِمْ؛ أَيْ: لَا تدَعُوا عبادتها.</p></div>"
  71,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقد أَضَلُّوا كثيرا﴾</span> تَفْسِيرُ الْحَسَنِ: يَعْنِي: الْأَصْنَامَ؛ أَيْ: ضَلَّ كَثِيرٌ مِنَ النَّاسِ بِعِبَادَتِهِمْ إِيَّاهَا مِنْ غَيْرِ أَنْ تَكُونَ الْأَصْنَامُ دَعَتْ إِلَى عِبَادَتِهَا <span class="qpc-hafs">﴿وَلا تزد الظَّالِمين﴾</span> الْمُشْركين <span class="qpc-hafs">﴿إِلَّا ضلالا﴾</span> هَذَا دُعَاءُ نُوحٍ عَلَى قَوْمِهِ حِينَ أَذِنَ اللَّهُ لَهُ بِالدُّعَاءِ عَلَيْهِم</p></div>"
  71,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِمَّا خطيئاتهم﴾</span> أَيْ: بِخَطَايَاهُمْ <span class="qpc-hafs">﴿أُغْرِقُوا فَأُدْخِلُوا نَارًا﴾</span> أَيْ: وَجَبَتْ لَهُمُ النَّارُ.</p><p>قَالَ محمدٌ: (مِمَّا خطيئاتهم) قِيلَ: إِنَّ الْمَعْنَى: مِنْ خَطِيئَاتِهِمْ، و (مَا) زَائِدَة.</p></div>"
  71,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تذرعلى الأَرْض من الْكَافرين ديارًا﴾</span> أَيْ: أَحَدًا وَهَذَا حَيْثُ أَذِنَ الله لَهُ بِالدُّعَاءِ عَلَيْهِم</p></div>"
  71,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا يَلِدُوا إِلا فَاجِرًا كَفَّارًا﴾</span> أَيْ: أَنَّهُمْ إِنْ وَلَدُوا وَلِيدًا فأدْرك كفَرَ وَهُوَ شَيْءٌ عَلِمَهُ نُوحٌ مِنْ قِبَل اللَّهِ وَهُوَ قَوْلُهُ: <span class="qpc-hafs">﴿وَأُوحِيَ إِلَى نُوحٍ أَنَّهُ لَنْ يُؤْمِنَ مِنْ قَوْمِكَ إِلا من قد آمن﴾</span></p></div>"
  71,28,"<div class=ar lang=ar><p>قَالَ نُوحٌ: <span class="qpc-hafs">﴿رَبِّ اغْفِرْ لِي ولوالدي﴾</span> قَالَ الْحَسَنُ: كَانَا مُؤْمِنَيْنِ <span class="qpc-hafs">﴿وَلِمَنْ دخل بَيْتِي مُؤمنا﴾</span> تَفْسِيرُ بَعْضِهِمْ: يَعْنِي: دَخَلَ</p><p>قَالَ محمدٌ: إِسْكَانُ الْيَاءِ مِنْ (بَيْتِي) وَفَتْحِهَا جَائِزٌ.</p><p><span class="qpc-hafs">﴿وَلِلْمُؤْمِنِينَ وَالْمُؤْمِنَاتِ وَلا تزد الظَّالِمين إِلَّا تبارا﴾</span></p></div>"