quran[15]{c,v,t}:
  20,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَلِكَ نَقُصُّ عَلَيْكَ مِنْ أَنْبَاءِ مَا قد سبق﴾</span> أَيْ: مِنْ أَخْبَارِ مَا قَدْ مضى <span class="qpc-hafs">﴿وَقد آتيناك﴾</span> أعطيناك <span class="qpc-hafs">﴿من لدنا﴾</span> من عندنَا <span class="qpc-hafs">﴿ذكرا﴾</span> يَعْنِي: الْقُرْآن</p></div>"
  20,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿من أعرض عَنهُ﴾</span> عَنِ الْقُرْآنِ لَمْ يُؤْمِنْ بِهِ <span class="qpc-hafs">﴿فَإِنَّهُ يَحْمِلُ يَوْمَ الْقِيَامَةِ وِزْرًا﴾</span> ثقلا؛ يَعْنِي: الْإِثْم</p></div>"
  20,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَالِدين فِيهِ﴾</span> أَيْ: فِي ثَوَابِ ذَلِكَ الْوِزْرِ؛ وَهِي النَّار <span class="qpc-hafs">﴿وساء لَهُم﴾</span> أَيْ: وَبِئْسَ لَهُمْ <span class="qpc-hafs">﴿يَوْمَ الْقِيَامَةِ حملا﴾</span> يَعْنِي: مَا يَحْمِلُونَ عَلَى ظُهُورِهِمْ مِنَ الْوِزْرِ.</p><p>قَالَ مُحَمَّدٌ: (حِمْلا) مَنْصُوبٌ عَلَى التَّمْيِيزِ؛ الْمَعْنَى: سَاءَ الْوِزْرُ لَهُمْ يَوْمَ الْقِيَامَةِ حِمْلًا، وَسُمِّيَ (الْوِزْرُ حِمْلًا)؛ لِأَنَّ صَاحِبَهُ يحمل بِهِ ثقلا.</p></div>"
  20,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْم ينْفخ فِي الصُّور﴾</span> وَالصُّورِ: قَرْنٌ يَنْفُخُ فِيهِ صَاحِبُ الصُّورِ؛ فَيَنْطَلِقُ كُلَّ رُوحٍ إِلَى جَسَدِهِ، تُجْعَلُ الْأَرْوَاحُ كُلُّهَا فِي الصُّورِ؛ فَإِذَا نُفِخَ فِيهِ خَرَجَتِ الْأَرْوَاحُ مِثْلَ النَّحْلِ كُلُّ رُوحٍ إِلَى جسده <span class="qpc-hafs">﴿ونحشر الْمُجْرمين﴾</span> الْمُشْرِكِينَ؛ هَذَا حَشْرٌ إِلَى النَّارِ <span class="qpc-hafs">﴿يَوْمئِذٍ زرقا﴾</span> أَي: مسودة وُجُوههم</p></div>"
  20,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يتخافتون بَينهم﴾</span> أَي: يتسارون <span class="qpc-hafs">﴿إِن لبثتم﴾</span> فِي الدُّنْيَا <span class="qpc-hafs">﴿إِلَّا عشرا﴾</span> يُقَلِّلُونَ لَبْثَهُمْ فِي الدُّنْيَا.</p><p>قَالَ مُحَمَّدٌ: الْخُفُوتُ أَصْلُهُ فِي اللُّغَةِ: السُّكُونُ؛ يُقَالُ: خَفَتَ الْكَلَامُ وَخَفَتَ الدُّعَاء؛ إِذا سكن.</p></div>"
  20,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ يَقُول أمثلهم طَريقَة﴾</span> أَيْ: أَعْقَلُهُمْ.</p><p>قَالَ مُحَمَّدٌ: يَعْنِي: أَعْقَلَهُمْ عِنْدَ نَفْسِهِ، وَأَعْلَمَهُمْ بِمَا يَقُول. <span class="qpc-hafs">﴿إِن لبثتم﴾</span> أَيْ: مَا لَبِثْتُمْ <span class="qpc-hafs">﴿إِلا يَوْمًا﴾</span> قَالَ قَتَادَةُ: هِيَ مَوَاطِنُ، قَالُوا إِلَّا عَشْرًا، وَإِلَّا يَوْمًا، وَقَالُوا: <span class="qpc-hafs">﴿لَبِثْنَا يَوْمًا أَوْ بَعْضَ يَوْمٍ﴾</span> وَقَالَ: <span class="qpc-hafs">﴿وَيَوْمَ تَقُومُ السَّاعَةُ يُقْسِمُ المجرمون﴾</span> يَحْلِفُ الْمُجْرِمُونَ <span class="qpc-hafs">﴿مَا لَبِثُوا غَيْرَ سَاعَة﴾</span> أَيْ: فِي الدُّنْيَا، وَذَلِكَ لِتَصَاغُرِ الدُّنْيَا عِنْدَهُمْ، وَقَلِّتِهَا فِي طُولِ الْآخِرَة.</p></div>"
  20,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسْأَلُونَكَ عَنِ الْجِبَالِ فَقُلْ يَنْسِفُهَا رَبِّي نسفا﴾</span> أَيْ: يَذْرِيهَا تَذْرِيَةً مِنْ أُصُولِهَا، تَصِيرُ الْجِبَالُ كَالْهَبَاءِ الْمَنْثُورِ.</p></div>"
  20,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فيذرها﴾</span> يَعْنِي: الأَرْض <span class="qpc-hafs">﴿قاعا صفصفا﴾</span> الْقَاعُ: الَّذِي لَا أَثَرَ عَلَيْهِ، وَالصَّفْصَفُ: الْمُسْتَوِيَةُ الَّتِي لَيْسَ عَلَيْهَا نَبَات</p></div>"
  20,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا ترى فِيهَا عوجا﴾</span> قَالَ ابْنُ عَبَّاسٍ: الْعِوَجُ: الْوَادِي <span class="qpc-hafs">﴿وَلَا أمتا﴾</span> قَالَ مُجَاهِد: يَعْنِي: ارتفاعا</p></div>"
  20,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمئِذٍ يتبعُون الدَّاعِي﴾</span> صَاحِبَ الصُّورِ؛ أَيْ: يُسْرِعُونَ إِلَيْهِ حِينَ يَخْرُجُونَ مِنْ قُبُورِهِمْ <span class="qpc-hafs">﴿لَا عوج لَهُ﴾</span> أَيْ: لَا يَتَعَوَّجُونَ عَنْ إِجَابَتِهِ يَمِينًا وَلَا شِمَالًا <span class="qpc-hafs">﴿وَخَشَعَتِ الأَصْوَاتُ للرحمن﴾</span> أَيْ: سَكَنَتْ <span class="qpc-hafs">﴿فَلا تَسْمَعُ إِلا همسا﴾</span> قَالَ الْحَسَنُ: يَعْنِي صَوْتَ الْأَقْدَامِ.</p><p>قَالَ مُحَمَّدٌ: الْهَمْسُ فِي اللُّغَةِ: الشَّيْء الْخَفي.</p></div>"
  20,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَئِذٍ لَا تَنْفَعُ الشَّفَاعَةُ إِلا مَنْ أَذِنَ لَهُ الرَّحْمَنُ وَرَضِيَ لَهُ قولا﴾</span> يَعْنِي: التَّوْحِيد.</p></div>"
  20,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يعلم مَا بَين أَيْديهم﴾</span> مِنْ أَمْرِ الْآخِرَةِ <span class="qpc-hafs">﴿وَمَا خَلْفَهُمْ﴾</span> من أَمر الدُّنْيَا؛ أَي: إِذْ صَارُوا فِي الْآخِرَةِ <span class="qpc-hafs">﴿وَلا يُحِيطُونَ بِهِ علما﴾</span> أَيْ: وَيَعْلَمُ مَا لَا يُحِيطُونَ بِهِ عِلْمًا؛ أَيْ: مَا لَا يعلمُونَ</p></div>"
  20,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وعنت الْوُجُوه للحي القيوم﴾</span> أَيْ: ذَلَّتْ، وَالْقَيُّومُ: الْقَائِمُ عَلَى كُلِّ نَفْسٍ.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ: عَنَا يَعْنُو؛ إِذَا خَضَعَ. <span class="qpc-hafs">﴿وَقَدْ خَابَ من حمل ظلما﴾</span> أَي: شركا.</p></div>"
  20,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنْ يَعْمَلْ مِنَ الصَّالِحَاتِ وَهُوَ مُؤمن فَلَا يخَاف ظلما﴾</span> يَعْنِي: أَنْ يُزَادَ عَلَيْهِ فِي سيئاته <span class="qpc-hafs">﴿وَلَا هضما﴾</span> أَن ينقص من حَسَنَاته.</p></div>"
  20,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وصرفنا فِيهِ من الْوَعيد﴾</span> أَيْ: بَيَّنَّا؛ مِنْ يَعْمَلْ كَذَا فَلَهُ كَذَا <span class="qpc-hafs">﴿لَعَلَّهُمْ يَتَّقُونَ أَوْ يحدث لَهُم ذكرا﴾</span> تَفْسِيرُ السُّدِّيِّ: الْمَعْنَى: لَعَلَّهُمْ يَتَّقُونَ، وَيُحْدِثُ لَهُمْ ذِكْرًا؛ الْأَلِفُ هَا هُنَا صلَة.</p></div>"