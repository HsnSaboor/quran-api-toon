quran[27]{c,v,t}:
  83,35,"<div class=ar lang=ar></div>"
  83,36,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿هَل ثوب الْكفَّار﴾</span> هَلْ جُوزِيَ الْكُفَّارُ؟ <span class="qpc-hafs">﴿مَا كَانُوا يَفْعَلُونَ﴾</span> أَيْ: قَدْ جُوزُوا شَرَّ الْجَزَاءِ.</p></div>"
  84,1,"<div class=ar lang=ar><p>تَفْسِيرُ سُورَةِ إِذَا السَّمَاءِ انْشَقَّتْ وَهِي مَكِّيَّة كلهَا</p><p>بِسْمِ اللَّهِ الرَّحْمَن الرَّحِيم</p><p>قَوْله: <span class="qpc-hafs">﴿إِذا السَّمَاء انشقت﴾</span> وَذَلِكَ يَوْم الْقِيَامَة</p></div>"
  84,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأذنت لِرَبِّهَا﴾</span> سَمِعت وأطاعت <span class="qpc-hafs">﴿وحقت﴾</span> وَحقّ لَهَا أَن تفعل</p></div>"
  84,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا الأَرْض مدت﴾</span> تُمَدُّ مَدَّ الْأَدِيمِ، وَهَذَا إِذَا بُدِّلَتْ بِأَرْضٍ بَيْضَاءَ، كَأَنَّهَا فِضَّةٌ لم يعْمل عَلَيْهَا خَطِيئَة</p></div>"
  84,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَلْقَتْ﴾</span> أخرجت <span class="qpc-hafs">﴿مأ فِيهَا﴾</span> يَعْنِي: الْأَمْوَات <span class="qpc-hafs">﴿وتخلت﴾</span> إِلَى اللَّهِ مِنْهُمْ، فَصَارُوا عَلَى</p></div>"
  84,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأذنت لِرَبِّهَا وحقت﴾</span> هِيَ مِثْلُ الْأُولَى.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ: أَذِنْتُ لِلشَّيْءِ آذَنُ أَذَنًا إِذَا اسْتَمْعَتُ. قَالَ الشَّاعِرُ</p><p>(صُمٌّ إِذَا سَمِعُوا خَيْرًا ذُكِرْتُ بِهِ ... وَإِنْ ذُكِرْتُ بِسُوءٍ عِنْدَهُمْ أَذِنُوا)</p></div>"
  84,6,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿يَا أَيهَا الإِنْسَانُ إِنَّكَ كَادِحٌ إِلَى رَبِّكَ كدحا﴾</span> أَيْ: عَامِلٌ إِلَى رَبِّكَ عَمَلًا <span class="qpc-hafs">﴿فملاقيه﴾</span> فَمُلاقٍ ثَوَابَ ذَلِكَ الْعَمَلِ، إِنْ خَيْرًا فَخَيْرٌ، وَإِنْ شَرًّا فَشَرٌّ.</p><p>قَالَ مُحَمَّدٌ: الْكَدْحُ فِي اللُّغَةِ: السَّعْيُ وَالدُّءُوبُ فِي الْعَمَلِ فِي بَابِ الدُّنْيَا وَفِي بَابِ الْآخِرَةِ. وَجَوَابُ (إِذَا) يَدُلُّ عَلَيْهِ فَمُلاقِيهِ، الْمَعْنَى: إِذَا كَانَ يَوْمُ الْقِيَامَةِ لَقِي الْإِنْسَان عمله.</p></div>"
  84,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ﴾</span> الْآيَة " سَأَلت عَائِشَة النَّبِي ﷺ عَنِ الَّذِي يُحاسَبُ حِسَابًا يَسِيرًا فَقَالَ: يُعَرَّفُ بِعَمَلِهِ، ثُمَّ يَتَجَاوَزُ الله عَنهُ "</p></div>"
  84,8,"<div class=ar lang=ar></div>"
  84,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وينقلب إِلَى أَهله﴾</span> إِلَى أَزْوَاجِهِ مِنَ الْحُورِ الْعِينِ <span class="qpc-hafs">﴿مَسْرُورًا﴾</span></p></div>"
  84,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ وَرَاءَ ظَهره﴾</span> تُخْلَعُ كَتِفُهُ الْيُسْرَى فَتُجْعَلُ خَلْفَهُ فَيَأْخُذ بهَا كِتَابه</p></div>"
  84,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَوف يَدْعُو ثبورا﴾</span> فِي النَّارِ يَقُولُ: يَا وَيْلاهُ <span class="qpc-hafs">﴿وَيَا ثبوراه﴾</span></p></div>"
  84,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيصلى سعيرا﴾</span> أَيْ: يَكْثُرُ عَذَابُهُ، وَيُشْوَى فِي النَّار</p></div>"
  84,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّه كَانَ فِي أَهله﴾</span> فِي الدُّنْيَا <span class="qpc-hafs">﴿مَسْرُورا﴾</span> لَا يُؤمن بِالْبَعْثِ</p></div>"
  84,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّه ظن﴾</span> حسب <span class="qpc-hafs">﴿أَن لن يحور﴾</span> أَيْ: يَرْجِعَ إِلَى رَبِّهِ.</p><p>قَالَ مُحَمَّدٌ: حَارَ يَحُورُ حَوْرًا وَحُئُورًا، أَيْ: رَجَعَ، وَقَالَ لَبِيدٌ: (وَمَا الْمَرْءُ إِلَّا كَالشِّهَابِ وَضَوْئِهِ ... يَحُورُ رَمَادًا بَعْدَ إِذْ هُوَ سَاطِع)</p></div>"
  84,15,"<div class=ar lang=ar><p>قَوْلُهُ: <span class="qpc-hafs">﴿بَلَى إِنَّ رَبَّهُ كَانَ بِهِ بَصيرًا﴾</span> أَي: أَنه سيبعثه. تَفْسِير سور الانشقاق من آيَة ١٦ - ٢٥</p></div>"
  84,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا أقسم بالشفق﴾</span> يَعْنِي: الْحُمْرَةَ إِذَا غَابَتِ الشَّمْسُ مَا بَين الْمغرب وَالْعشَاء</p></div>"
  84,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاللَّيْل وَمَا وسق﴾</span> وَمَا جَمَعَ مِمَّا عَمِلَ فِيهِ الْخَلْقُ مِنْ خَيْرٍ أَوْ شَرٍّ</p></div>"
  84,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالْقَمَر إِذا اتسق﴾</span> إِذَا اسْتَوَى فَاسْتَدَارَ، وَهَذَا قَسَمٌ مِنْ قَوْلِهِ: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِالشَّفَقِ﴾</span> إِلَى هَذَا الْمَوْضِعِ أَقْسَمَ بِهَذَا كُله</p></div>"
  84,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لتركبن طبقًا عَن طبق﴾</span> أَيْ: حَالًا بَعْدَ حَالٍ، فِي تَفْسِير الْحسن.</p></div>"
  84,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا لَهُم لَا يُؤمنُونَ﴾</span> يَعْنِي: الْمُشْركين</p></div>"
  84,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِذا قرئَ عَلَيْهِم الْقُرْآن لَا يَسْجُدُونَ﴾</span> لَا يصلونَ</p></div>"
  84,22,"<div class=ar lang=ar></div>"
  84,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالله أعلم بِمَا يوعون﴾</span> أَي: يخفون فِي صُدُورهمْ.</p></div>"
  84,24,"<div class=ar lang=ar></div>"
  84,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ لَهُم أجر﴾</span> ثَوَابٌ وَهِيَ الْجَنَّةُ <span class="qpc-hafs">﴿غَيْرُ مَمْنُونٍ﴾</span> تَفْسِيرُ الْحَسَنِ: غَيْرُ مَمْنُونٍ عَلَيْهِمْ مَنَّ أَذًى.</p></div>"