quran[34]{c,v,t}:
  56,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يطوف عَلَيْهِم ولدان مخلدون﴾</span> لَا يموتون وَلَا يشيبون على منَازِل الوُصَفاء، خُلِدوا على تِلْكَ الْحَال لَا يتحولون عَنْهَا</p></div>"
  56,18,"<div class=ar lang=ar></div>"
  56,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يصدعون عَنْهَا﴾</span> لَا يصيبهم عَلَيْهَا صُدَاعٌ <span class="qpc-hafs">﴿وَلا ينزفون﴾</span> لَا تذْهب عُقُولهمْ أَي: لَا يسكرون</p></div>"
  56,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَاكِهَة مِمَّا يتخيرون﴾</span> إِذا اشْتهوا الشعْبَ من الشَّجَرَة انقض إِلَيْهِم فَأَكَلُوا مِنْهُ أيَّ الثِّمَار شَاءُوا؛ إِن شَاءُوا قيَاما، وَإِن شَاءُوا مستلقين.</p></div>"
  56,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلحم طير مِمَّا يشتهون﴾</span> قَالَ سَعِيد بْن رَاشد: بَلغنِي أَن الطير تُصَفُّ بَين يَدي الرجل؛ فَإِذا اشْتهى أَحدهَا اضْطربَ ثمَّ صَار بَين يَدَيْهِ نَضِيجًا</p></div>"
  56,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وحور عين﴾</span> أَي: بيضٌ، عينٌ أَي: عِظَام الْعُيُون، الْوَاحِدَة مِنْهُنَّ عَيْنَاء.</p><p>وَقَالَ مُحَمَّد: <span class="qpc-hafs">﴿وحور عين﴾</span> مَرْفوعٌ بِمَعْنى: ولهُمْ حورٌ عين.</p></div>"
  56,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كأمثال اللُّؤْلُؤ الْمكنون﴾</span> يَعْنِي: صفاء ألوانهن، والمكنون الَّذِي فِي أصدافه</p></div>"
  56,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَزَاء بِمَا كَانُوا يعْملُونَ﴾</span>.</p><p>قَالَ مُحَمَّد: <span class="qpc-hafs">﴿جَزَاء﴾</span> مصدرٌ، الْمَعْنى: يجازون بأعمالهم جَزَاء.</p></div>"
  56,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يسمعُونَ فِيهَا لَغوا﴾</span> أَي: بَاطِلا <span class="qpc-hafs">﴿وَلَا تأثيما﴾</span> لَا يؤثم بَعضهم بَعْضًا</p></div>"
  56,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا قيلا سَلاما سَلاما﴾</span> تَفْسِير بَعضهم: إِلَّا خيرا خيرا.</p><p>قَالَ مُحَمَّدٌ: الْمَعْنَى عَلَى هَذَا التَّفْسِير: لَا يسمعُونَ فِيهَا إِلَّا قيلًا يُسْلَمُ فِيهِ من اللَّغْو وَالْإِثْم.</p></div>"
  56,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصْحَابُ الْيَمِينِ مَا أَصْحَابُ الْيَمِينِ﴾</span> يَعْنِي: أهل الْجنَّة من غير السَّابِقين، وَأهل الْجنَّة كلهم أَصْحَاب الْيَمين</p></div>"
  56,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي سدر مخضود﴾</span> المخضودُ: الَّذِي لَا شوك لَهُ</p></div>"
  56,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وطلح منضود﴾</span> أَي: بعضه على بعضٍ يَعْنِي بالطلح: الشّجر الَّذِي بطرِيق مَكَّة. قَالَ مُجَاهِد: كَانُوا يعْجبُونَ من وَج وظلاله من طَلْحٍ وسِدْرٍ، فَخُوطِبُوا ووعدوا بِمَا يحبونَ مثله.</p></div>"
  56,30,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿وظل مَمْدُود﴾</span> أَي: مُتَّصِل دَائِم أبدا</p></div>"
  56,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَاء مسكوب﴾</span> ينسكب بعضُه على بعض، وَلَيْسَ بالمطر</p></div>"
  56,32,"<div class=ar lang=ar></div>"
  56,33,"56:32"
  56,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وفرش مَرْفُوعَة﴾</span> قَالَ أَبُو أُمَامَة: ارتفاعها من الأَرْض قدر مائَة سنة</p></div>"
  56,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا أَنْشَأْنَاهُنَّ إنْشَاء﴾</span> خلَقْناهُنّ؛ يَعْنِي: نسَاء أهل الْجنَّة</p></div>"
  56,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فجعلناهن أَبْكَارًا﴾</span> عذارى</p></div>"
  56,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عربا﴾</span> يَعْنِي: متحبِّبات إِلَى أَزوَاجهنَّ <span class="qpc-hafs">﴿أَتْرَابًا﴾</span> أَي: على سنٍّ وَاحِدَة بَنَات ثَلَاث وَثَلَاثِينَ سنة.</p><p>قَالَ محمدٌ: <span class="qpc-hafs">﴿عربا﴾</span> جمع عَرُوبٍ، وأصل الْكَلِمَة: المُعَارَبة؛ وَهِي المداعَبة وَقَالَ: <span class="qpc-hafs">﴿إِنَّا أَنْشَأْنَاهُنَّ إنْشَاء﴾</span> وَلم يذكر النِّسَاء قبل ذَلِك؛ لِأَن الْفرش مَحل النِّسَاء، فَاكْتفى بِذكر الفُرش، الْمَعْنى: أنشأنا الصبية والعجوز إنْشَاء جَدِيدا.</p></div>"
  56,38,"<div class=ar lang=ar></div>"
  56,39,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿ثُلَّةٌ مِنَ الأَوَّلِينَ وَثُلَّةٌ من الآخرين﴾</span> الثلَّة: الطَّائِفَة.</p></div>"
  56,40,"<div class=ar lang=ar></div>"
  56,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصْحَابُ الشِّمَالِ مَا أَصْحَابُ الشِّمَالِ﴾</span> وهم أهلُ النَّار.</p><p>يَحْيَى: عَنْ فِطْرٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ، عَنْ أَبِي بَكْرٍ الصِّدِّيقِ قَالَ: " خَلَقَ اللَّهُ الْخَلْقَ فَكَانُوا قَبْضَتَهُ، فَقَالَ لِمَنْ فِي يَمِينِهِ: ادْخُلُوا الْجَنَّةَ بِسَلامٍ. وَقَالَ لِمَنْ فِي يَدِهِ الأُخْرَى: ادْخُلُوا النَّارَ وَلا أُبَالِي. فَذَهَبَتْ إِلَى يَوْمِ الْقِيَامَةِ ".</p><p>قَالَ يحيى: وَبَلغنِي أَنه قَوْله: <span class="qpc-hafs">﴿وَأَصْحَابُ الْيَمِينِ مَا أَصْحَابُ الْيَمين﴾</span> <span class="qpc-hafs">﴿وَأَصْحَابُ الشِّمَالِ مَا أَصْحَابُ الشِّمَالِ﴾</span>.</p></div>"
  56,42,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿فِي سموم وحميم﴾</span> فِي نَار وحميم؛ يَعْنِي: الشَّرَاب الشَّديد الْحر</p></div>"
  56,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وظل من يحموم﴾</span> اليحموم: الدُّخان الشَّديد السوَاد</p></div>"
  56,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا بَارِدٍ﴾</span> فِي الظِّلِ <span class="qpc-hafs">﴿وَلا كريم﴾</span> فِي الْمنزل، والكريم: الْحسن</p></div>"
  56,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهُمْ كَانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ﴾</span> والمترفون أهل السَّعَة وَالنعْمَة فِي الدُّنْيَا</p></div>"
  56,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَانُوا يصرون﴾</span> يُقِيمُونَ <span class="qpc-hafs">﴿على الْحِنْث﴾</span> يَعْنِي: الذَّنب <span class="qpc-hafs">﴿الْعَظِيم﴾</span> وَهُوَ الشّرك</p></div>"
  56,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَانُوا يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا﴾</span> الْآيَة لَا نبعث نَحن وَلَا آبَاؤُنَا</p></div>"
  56,48,"<div class=ar lang=ar></div>"
  56,49,"56:48"
  56,50,"56:48"