quran[28]{c,v,t}:
  26,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاجْعَلْ لِي لِسَانَ صِدْقٍ فِي الآخرين﴾</span> فَلَيْسَ مِنْ أَهْلِ دِينٍ إِلا وهم يتولونه وَيُحِبُّونَهُ</p></div>"
  26,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاجْعَلْنِي مِنْ وَرَثَةِ جَنَّةِ النَّعِيمِ﴾</span> وَهُوَ اسْمٌ مِنْ أَسْمَاءِ الْجَنَّةِ.</p></div>"
  26,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَاغْفِرْ لأَبِي إِنَّهُ كَانَ مِنَ الضَّالّين﴾</span> قَالَ هَذَا فِي حَيَاةِ أَبِيهِ، وَكَانَ فِي طَمَعٍ مِنْ أَنْ يُؤْمِنَ، فَلَمَّا تَبَيَّنَ لَهُ أَنَّهُ مِنْ أَهْلِ النَّارِ لَمْ يَدْعُ لَهُ</p></div>"
  26,87,"<div class=ar lang=ar></div>"
  26,88,"26:87"
  26,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا مَنْ أَتَى اللَّهَ بِقَلْبٍ سليم﴾</span> من الشّرك.</p></div>"
  26,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وأزلفت الْجنَّة﴾</span> أَي: أدنيت</p></div>"
  26,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وبرزت الْجَحِيم﴾</span> أظهرت <span class="qpc-hafs">﴿للغاوين﴾</span> للْمُشْرِكين.</p></div>"
  26,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِيلَ لَهُمْ أَيْنَ مَا كُنْتُمْ تَعْبدُونَ من دون الله﴾</span> يَعْنِي: الشَّيَاطِينَ الَّذِينَ دَعَوْهُمْ إِلَى عِبَادَةِ مِنْ عَبَدُوا مِنْ دُونِ الله</p></div>"
  26,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلْ يَنْصُرُونَكُمْ﴾</span> يَعْنِي: هَلْ يَمْنَعُونَكُمْ مِنْ عَذَابِ الله؟ <span class="qpc-hafs">﴿أَو ينتصرون﴾</span> يمتنعون.</p></div>"
  26,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فكبكبوا فِيهَا﴾</span> أَيْ: قُذِفُوا فِيهَا؛ يَعْنِي: الْمُشْرِكِينَ <span class="qpc-hafs">﴿هم والغاوون﴾</span> يَعْنِي: الشَّيَاطِينَ.</p><p>قَالَ مُحَمَّدٌ: <span class="qpc-hafs">﴿فَكُبْكِبُوا﴾</span> أَصْلُهُ: كُبِّبُوا؛ مِنْ قَوْلِكَ: كَبَبْتُ الْإِنَاءَ، فَأُبْدِلَ مِنَ الْبَاءِ الْوُسْطَى كَافًا؛ اسْتِثْقَالًا لِاجْتِمَاعِ ثَلَاثِ بَاءَاتٍ.</p></div>"
  26,95,"<div class=ar lang=ar></div>"
  26,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا﴾</span> قَالَ الْمُشْرِكُونَ لِلشَّيَاطِينِ <span class="qpc-hafs">﴿وَهُمْ فِيهَا يختصمون﴾</span> وَخُصُومَتُهُمْ تَبَرُّؤُ بَعْضِهِمْ مِنْ بَعْضٍ، وَلعن بَعضهم بَعْضًا</p></div>"
  26,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تالله إِن كُنَّا﴾</span> فِي الدُّنْيَا. أَيْ: لَقَدْ كُنَّا فِي الدُّنْيَا <span class="qpc-hafs">﴿لَفِي ضَلالٍ مُبِينٍ﴾</span> بَين.</p></div>"
  26,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ نسويكم بِرَبّ الْعَالمين﴾</span> أَي: نتخذكم آلِهَة</p></div>"
  26,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا أضلنا إِلَّا المجرمون﴾</span> يَعْنِي: الشَّيَاطِين</p></div>"
  26,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا لنا من شافعين﴾</span> يَشْفَعُونَ لَنَا الْيَوْمَ عِنْدَ اللَّهِ</p></div>"
  26,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا صديق حميم﴾</span> قَرِيبِ الْقَرَابَةِ، فَيَحْمِلَ عَنَّا؛ كَمَا كَانَ يَحْمِلُ الْحَمِيمُ عَنْ حَمِيمِهِ فِي الدُّنْيَا؛ قَالُوا هَذَا حِينَ شُفِعَ لِلْمُذْنِبِينَ مِنَ الْمُؤْمِنِينَ؛ فَأُخْرِجُوا مِنْهَا</p></div>"
  26,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَو أَن لنا كرة﴾</span> رَجْعَةً إِلَى الدُّنْيَا <span class="qpc-hafs">﴿فَنَكُونَ مِنَ الْمُؤمنِينَ﴾</span>.</p></div>"
  26,103,"<div class=ar lang=ar></div>"
  26,104,"26:103"
  26,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كذبت قوم نوح الْمُرْسلين﴾</span> يَعْنِي: نوحًا</p></div>"
  26,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ﴾</span> أَخُوهُمْ فِي النَّسَبِ، وَلَيْسَ بِأَخِيهِمْ فِي الدّين.</p></div>"
  26,107,"<div class=ar lang=ar></div>"
  26,108,"26:107"
  26,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا أَسأَلكُم عَلَيْهِ﴾</span> عَلَى مَا جِئْتُكُمْ بِهِ مِنْ الْهدى <span class="qpc-hafs">﴿أجرا﴾</span>. <span class="qpc-hafs">﴿إِن أجري﴾</span> ثَوَابِي <span class="qpc-hafs">﴿إِلا عَلَى رَبِّ الْعَالَمِينَ﴾</span>.</p></div>"
  26,110,"<div class=ar lang=ar></div>"
  26,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا أَنُؤْمِنُ لَكَ وَاتَّبَعَكَ الأَرْذَلُونَ﴾</span> يَعْنِي: السفلة</p></div>"