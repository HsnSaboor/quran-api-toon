quran[14]{c,v,t}:
  67,13,"<div class=ar lang=ar></div>"
  67,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلا يعلم من خلق﴾</span> عَلَى الاسْتِفْهَامِ؛ أَيْ: هُوَ خَلَقَكُمْ، فَكَيْفَ لَا يَعْلَمُ سِرَّكُمْ وَعَلانِيَتَكُمْ؟! <span class="qpc-hafs">﴿وَهُوَ اللَّطِيف﴾</span> بِلُطْفه خلق الْخلق <span class="qpc-hafs">﴿الْخَبِير﴾</span> بأعمال الْعباد.</p></div>"
  67,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ الَّذِي جَعَلَ لَكُمُ الأَرْضَ ذلولا﴾</span> أَيْ: سهَّل لَكُمُ السُّلوك فِيهَا وذلَّلها لكم <span class="qpc-hafs">﴿فامشوا﴾</span> فامضوا <span class="qpc-hafs">﴿فِي مناكبها﴾</span> طُرُقِهَا؛ وَهُوَ تَفْسِيرُ الْحَسَنِ وَمُجَاهِدٍ <span class="qpc-hafs">﴿وكلوا من رزقه﴾</span> الَّذِي أحلَّ لَكُمْ <span class="qpc-hafs">﴿وَإِلَيْهِ النُّشُورُ﴾</span> الْبَعْث.</p></div>"
  67,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أأمنتم من فِي السَّمَاء﴾</span> عَلَى الِاسْتِفْهَامِ؛ يَعْنِي: نَفْسَهُ <span class="qpc-hafs">﴿أَنْ يخسف بكم الأَرْض﴾</span> أَيْ: أَنَّكُمْ تَأْمَنُونَ ذَلِكَ، قَالَ: <span class="qpc-hafs">﴿فَإِذا هِيَ﴾</span> قَبْلَ أَنْ تُخْسَفَ بِكُمْ <span class="qpc-hafs">﴿تَمُورُ﴾</span> تحرّك حَتَّى يخسف بكم</p></div>"
  67,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم أمنتم﴾</span> أَي: أأ منتم؟ <span class="qpc-hafs">﴿من فِي السَّمَاء﴾</span> يَعْنِي: نَفسه؛ أَي تَأْمَنُونَ <span class="qpc-hafs">﴿أَنْ يُرْسِلَ عَلَيْكُمْ حَاصِبًا﴾</span> كَمَا حَصَبَ قَوْمَ لُوطٍ؛ يَعْنِي: الْحِجَارَة الَّتِي أمطرها عَلَيْهِم (١)</p><p>(ل ٣٦٨)</p></div>"
  67,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ كَذَّبَ الَّذِينَ مِنْ قَبْلِهِمْ﴾</span> قَبْلَ قَوْمِكَ يَا مُحَمَّدُ <span class="qpc-hafs">﴿فَكَيْفَ كَانَ نَكِير﴾</span> عَلَى الِاسْتِفْهَامِ؛ أَيْ: كَانَ شَدِيدًا؛ وَنَكِيرِي: عُقُوبَتِي.</p><p>قَالَ مُحَمَّدٌ: ذَكَرَ ابْنُ مُجَاهِدٍ (٢) أَنَّ وَرْشًا رَوَى عَنْ نَافِعٍ: <span class="qpc-hafs">﴿نَذِيرِي﴾</span> وَ <span class="qpc-hafs">﴿نَكِيرِي﴾</span> بياء فِي الْوَصْلِ. قَالَ: وَقَرَأَ الْبَاقُونَ بِكَسْرِ الرَّاءِ مِنْ غَيْرِ يَاءٍ فِي وصل وَلَا وقف (٣).</p></div>"
  67,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَلَمْ يَرَوْا إِلَى الطَّيْرِ فَوْقَهُمْ صافات﴾</span> بِأَجْنِحَتِهَا؛ أَيْ: قَدْ رَأَوْهَا. <span class="qpc-hafs">﴿وَيَقْبِضْنَ﴾</span> يَعْنِي: إِذَا وَقَفَ الطَّائِرُ صَافًّا بِجَنَاحَيْهِ لَا يَزُولُ؛ فِي تَفْسِيرِ بَعضهم.</p></div>"
  67,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمَّنْ هَذَا الَّذِي هُوَ جندٌ لَكُمْ يَنْصُرُكُمْ مِنْ دُونِ الرَّحْمَنِ﴾</span> عَلَى الِاسْتِفْهَامِ إِنْ أَرَادَ عَذَابَكُمْ، أَيْ: لَيْسَ أحدٌ يَنْصَرُكُمْ مِنْ دونه <span class="qpc-hafs">﴿إِن الْكَافِرُونَ﴾</span> مَا الْكَافِرُونَ <span class="qpc-hafs">﴿إِلا فِي غُرُورٍ﴾</span> يَعْنِي: فِي غرور الشَّيْطَان</p></div>"
  67,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل لجوا فِي عتو﴾</span> وَهُوَ الشّرك <span class="qpc-hafs">﴿ونفور﴾</span> عَن الْإِيمَان.</p></div>"
  67,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَمَنْ يَمْشِي مُكِبًّا عَلَى وَجْهِهِ﴾</span> لَا يُبْصِرُ مَوْضِعَ قَدَمَيْهِ؛ وَهَذَا مثلٌ لِلْكَافِرِ <span class="qpc-hafs">﴿أَهْدَى أَمَّنْ يَمْشِي سويًّا﴾</span> عَدْلاً يُبْصِرُ حَيْثُ يَسْلُكُ، وَهَذَا مَثَلُ الْمُؤْمِنِ؛ أَيْ: أَنَّ الْمُؤْمِنَ أَهْدَى مِنَ الْكَافِرِ.</p><p>قَالَ مُحَمَّدٌ: يُقَالُ: أكبَّ عَلَى وَجْهِهِ بِالْأَلِفِ، وكبَّه الله بِغَيْر ألفٍ (١).</p></div>"
  67,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَلِيلا مَا تشكرون﴾</span> أَي: أقلكم من يُؤمن.</p></div>"
  67,24,"<div class=ar lang=ar></div>"
  67,25,"67:24"
  67,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلْ إِنَّمَا الْعِلْمُ عِنْدَ اللَّهِ﴾</span> يَعْنِي عِلْمُ السَّاعَةِ لَا يَعْلَمُ قِيَامَهَا إِلَّا هُوَ <span class="qpc-hafs">﴿وَإِنَّمَا أَنَا نَذِير﴾</span> أنذركم عَذَاب الله <span class="qpc-hafs">﴿مُبين﴾</span> أبين لكم عَن الله</p></div>"