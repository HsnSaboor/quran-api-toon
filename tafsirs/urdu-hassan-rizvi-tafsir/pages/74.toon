  74,1,آیت نمبر۱:شانِ نزول:(۱) مشرکینِ مکّہ نے مل کر طے کیا کہ رسول صلی اللہ علیہ و آلہ وسلم کو کس طرح بدنام کریں ؟ کسی نے کہا کہ کاہن مشہور کر دو۔ کسی نے کہا : مجنون مشہور کر دو۔ کسی نے کہا: شاعر کہہ کر بدنام کر دو۔ سب سے آخر میں سب کے سب اس نتیجے پر پہنچے کہ رسول صلی اللہ علیہ و آلہ وسلم کو جادو گر کہہ کر بد نام کر دو۔ کیوں کہ جادوگر لوگ بیوی اور شوہر،باپ اور بیٹے اور عزیزوں کے درمیان جدائی ڈال دیتے ہیں ،اور محمّد صلی اللہ علیہ و آلہ وسلم بھی یہی کام کرہے ہیں (معاذ اللہ)۔ جب یہ بات پیغمبر صلی اللہ علیہ و آلہ وسلم نے سنی تو سخت صدمہ ہوا۔ غمگین ہوکر واپس ہوئے اور بستر پر لیٹ گئے ۔ اس وقت یہ آیات اتریں ۔!!(۲) دوسری روایت جناب جابر بن عبداللہ انصاریؓ سے ہے کہ:}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  میں غارِ حرا میں تھا کہ ایک آواز بلند ہوئی: اے محمّدؐ! تم خدا کے رسول صلی اللہ علیہ و آلہ وسلم ہو۔میں نے دائیں بائیں دیکھا ،کوئی چیز نظر نہ آئی،جب اوپر دیکھا تو ایک فرشتے کو عرش پر آسمان اور زمین کے درمیان دیکھا۔ میں خدیجہؓ کی طرف لوٹ آیا،اور کہا مجھ پر کپڑا ڈال دو۔ ٹھنڈا پانی مجھ پر ڈال دو ۔ اُس وقت جبریل علیہ السلام اترے اور یہ آیات لے کر آئے۔(۳) پیغمبر اکرم صلی اللہ علیہ و آلہ وسلم سورہے تھے،چادر اوڑھے ہوئے تھے کہ جبریل علیہ السلام نے آپ صلی اللہ علیہ و آلہ وسلم کو اٹھایا اور یہ آیات سنائیں {{ (۴)کپڑے سے مراد ظاہر کپڑے نہیں ہیں بلکہ لباسّ نبوت و رسالت ہے ۔ جیسے لباس التقویٰ تقوٰے کا لباس کہا جاتا ہے۔(۵) مدّثّر سے مراد علیحدگی اور تنہائی میں چادر اوڑھ کر لیٹنے والے۔ مطلب یہ ہے کہ گوشہ نشینی چھوڑ دو اور دین کی تبلیغ کرو۔&&(تفسیر مجمع البیان ۔ نورالثقلین)]]&&نکل کر خانقاہوں سے ادا کر رسمِ شبیریؐ[[&&(اقبال)&&
  74,3,آیت نمبر۳:}}خداوندِ عالم کا یہ فرمان ہے کہ :اپنے پالنے والے مالک کی بڑائی کا اعلان کیجئے{{اس کا مطلب یہ ہے کہ جو لوگ بتوں کو پوج رہے ہیں ،انھیں بتائیے کہ ان بتوں میں کوئی بڑائی نہیں ہے ساری بڑائیاں خداوندِ عالم کے لیے ہیں ۔ تمہارے ذہنوں میں کسی کے لیے جو بڑائی کا تصور ہے ،اس تصور سے بھی کہیں بلند اور بڑی ذات خداوندِعالم کی ہے۔یہاں پر خدا نے یہ نہیں فرمایاکہ خدا فلاں فلاں سے بڑا ہے ۔ اگر ایسا فرماتا تو اس کی عظمت محدود ہوجاتی۔&&(فصل الخطاب)&&!!ہر نبی کا اولین کام:یہ ہوتا ہے کہ وہ اپنے پالنے اولے مالک یعنی اللہ کی بڑائی کو بیان کرتا ہے انسانی ترقی کا ہر سلسلہ اسی معرفتِ الہٰی سے ہوتا ہے ۔ جب انسان خدا کو پہچانتا ہے تو سب سے پہلی اور آخری بات وہ یہی سمجھتا ہے کہ خدا کی بڑائی کی کوئی حد و انتہاء نہیں۔ لوگ جن کو بڑا مان رہے ہیں وہ سب چھوٹے ہیں ۔ بڑائی صرف اور صرف اللہ کے لیے ہے۔ اسی لیے نماز شروع بھی اَللہ اکبر سے ہوتی ہے ۔ (اور ختم بھی اللہ اکبر پر ہوتی ہے) ہر نبی صلی اللہ علیہ و آلہ وسلم نے اپنا کام اسی نعرہ اللہ اکبر سے شروع کیا ۔&&(تفہیم ۔تفسیر کبیر) &&]]اگرچہ بُت ہیں جماعت کی آستینوں میں ۔۔۔۔مجھے حکمِ اذاں لَآ اِلٰہَ اِلَّا اللہ۔۔۔۔یہ نغمہ فصلِ گل لالہ کانہیں پابند۔۔۔۔بہار ہو کہ خزاں لَآ اِلٰہَ اِلَّا اللہ[[۔&&(اقبال)&& اللہ کی بڑائی کے بیان کرنے میں یہ پیغام بھی دے دیاکہ اے رسولؐ! تم جس قوم کے خلاف کھڑے ہورہے ہو،ان کی طاقت کی پرواہ نہ کرو ،سب سے بڑی طاقت اور ذات اللہ کی ہے جو تمھارے ساتھ ہے۔ [[ دشمن اگر قوی است نگہباں قوی تر است]]یعنی : اگر دشمن طاقتور ہے تو بچانے والا اس ے کہیں زیادہ طاقت والا ہے۔&&(مولف)&&<<کَبِّرْ >> سے صرف اللہ اَکْبَرْ کہنا مراد نہیں ،بلکہ اس سے مراد یہ ہے کہ دل و دماغ اور اپنے وجود میں خدا کو سب سے بڑا سمجھو ،ہر بات میں اس کی بڑائی کا لحاظ رکھّو ،اس کو ہر وصف و کمال سے متصف اور ہر عیب و نقص سے پاک جانو۔ بلکہ اس کو اتنا بڑا سمجھو کہ اس کی تعریف کرنا ہی ناممکن سمجھو۔&&(تفسیرنمونہ) }}&&جناب امیر المومنین علیہ السلام نے فرمایا:  تمام حمد اس اللہ کے لیے ہے جس کی مدح تک بولنے والوں کی رسائی نہیں ،جس کی نعمتوں کو گننے والے گن نہیں سکتے،نہ کوشش کرنے والے اس کا حق ادا کرسکتے ہیں ،نہ بلند پرواز ہمتیں اس اسے پاسکتی ہیں ،نہ عقل و فہم کی گہرائیاں اس کی تہ تک پہنچ سکتی ہیں اس کی کمالِ ذات کی کوئی حد معیّن نہیں ،نہ اس کے لیے توصیفی الفاظ ہیں ،نہ اس کی ابتدا،کے لیے کوئی وقت ہے جسے شمار میں لایا جاسکے،نہ اس کی کوئی مدت ہے جو کہیں پر ختم ہوجائے۔۔۔۔۔ کمالِ معرفت اس کی تصدیق ہے،کمالِ تصدیق،توحید ہے ،کمالِ توحید،اخلاص ہے اور کمالِ اخلاص یہ ہے کہ اس کی ذات سے صفتوں کی نفی کی جائے ۔ کیوں کہ ہر صفت اپنے موصوف کی غیرہوتی ہے۔&&(نہج البلاغہ خطبہ نمبر۱) &&]]{{اے برتر از قیاس و گمان و خیال و وہم ۔۔۔۔وزہرچہ گفتہ ایم و شنیدہ ایم و خٰواندہ ایم &&[[(سعدیؒ)]]&&اے خدا تجھ کو ہی زیبا ہے بڑائی تیری۔۔۔۔بے نیازی تو کسی نے بھی نہ پائی تیری[[۔&&(انیسؒ)&&اللہ کی بڑائی یہ ہے کہ وہ ہمارے قیاس و گمان تک سے بلند ہے ۔!! << تکبّر<<کا لفظ تسبیح سے بھی زیادہ وسعت رکھتا ہے۔ اللہ کی آیات ،احسانات ،مخلوقات پر جس قدر غور کروگے خدا کی بڑائی ذہن میں آے گی اور اس کا اظہار اَللہ اَکْبَرْ کی تسبیح سے پڑھ کر ،کرنا چاہیے۔&&(مولف)&&
  74,4,آیت نمبر۴:{{خداوندِ عالم کا جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے فرمانا کہ: اپنے کپڑے پاک رکھئیے۔عربی محاورے میں کپڑے پاک رکھنے کا مطلب یہ ہوتا ہے کہ اپنے دامن کو ہر قسم کی برائی کے داغ سے صاف رکھئیے۔ &&(ابنِ کثیر۔ روح المعانی۔ جصّاص ،مدارک ،معالم ۔ تفسیر کبیر)&&اور اردو محاورے میں بھی یہی معانی آتے ہیں بقولِ شاعر[[ اتنی نہ بڑھا پاکی ِ داماں کی حکایت۔دامن کو ذرا دیکھ ،ذرا بندِ قبا دیکھ]] پاک باز عورتوں کو پاک دامن عورت کہا جاتا ہے۔&&(مولف)&& }}فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ: خدا وندِ عالم کا یہ فرمانا کہ :  اپنے کپڑوں کو پاک رکھیے{{ اس کا مطلب یہ بھی ہے کہ کپڑوں کو (زمین سے )اٹھائے رکھو ان کو زمین پر گھسیٹ کر نہ چلو۔&&(تفسیر صافی بحوالہ کافی) && !!فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام موسیٰ کاظم علیہ السلام نے فرمایا: اس کا مطلب یہ بھی ہے کہ: تم اپنے کپڑوں کے دامن کو کم کر دو۔ (یعنی اتنا لمبا نہ رکھو کہ زمین پر گھسٹنے لگے اور نجس ہوجائے)&&(مجمع البیان) &&}}جناب امیر المومنین علیہ السلام نے فرمایا:  کپڑوں کا دھونا وہم اور غم کو دور کرتا ہے اور یہ نماز کے لیے پاک صاف کرنے والا کام ہے۔ کپڑوں کو پاک رکھنے کا مطلب دامن کو اٹھائے رکھنا ہے۔&&(تفسیر مجمع البیان،تفسیر قمی) &&{{، کپڑے پاک رکھو کے معنی ہوسکتے ہیں (۱) جسم اور لباس کی پاکیزگی سے روح اور عقل کی پاکیزگی کا گہرا تعلق ہے۔ {{جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  طہارت نصفِ ایمان ہے ۔&&(الحدیث) &&}}یہ طہارت آج کی مہذب قوموں کو نصیب نہیں ۔ فقہ کی کتابوں کا آغاز << کتاب الطہارت << سے ہوتا ہے۔(۲) دوسرے معنی یہ ہیں کہ تم اپنا لباس سنوار رکھو۔اس میں تصّوف کے غلط تصّورات کو دور کردیا گیا کہ  مقدس لوگوں کا معیار گندہ لباس ہوتا تھا،اُجلے لباس کا مطلب دنیا داری تھا۔یہاں بتایا گیا کہ اللہ والوں کے لیے ضروری ہے کہ ان کو ظاہری حالت بھی پاکیزہ اور نفیس ہونی چاہیے تاکہ لوگ اس کو عزت کی نگاہ سے دیکھیں ،اس سے دور نہ بھاگیں ۔(۳) لباس کو اخلاقی عیوب سے پاک رکھو۔ غرور تکبّر والا لباس نہ پہنو،شان شوکت کا شائبہ نہ ہو۔ لباس کو دیکھ کر انسان کے بارے میں پہلا اندازہ ہوتا ہے۔ رئیسوں ،نوابوں ،سرداروں کے لباس الگ ہوتے ہیں ،چھچورے ،کم ظرف لوگ بھی اپنے لباس سے پہچانے جاتے ہیں ۔ (انگریزی لباس الگ ہوتا ہے اور اسلامی لباس الگ ہوتا ہے۔ جیسے پادری،پوپ کا لباس الگ ہوتا ہے۔ اور مسلمان عالمِ دین کا لباس مختلف)۔&&(تفسیر کبیر۔ بتفہیم ۔ مجمع البیان۔ تفسیر نمونہ) &&(۴)پاک لباس سے پاکدامن بھی مراد ہے کہ اپنے دامن کو برے کاموں سے داغدار نہ بناو۔ عرب جب کہتے ہیں کہ فلاں <<طاھر الثیاب<< (یعنی ) فلاں کے کپڑے پاک ہیں ۔ یعنی وہ پاکدامن ،پاکیزہ کردار انسان ہے۔ اور جب کہتے ہیں کہ << فلاں دنس الدیاب<<فلاں کے کپڑے گندے ہیں یعنی فلاں بد معاملہ ،ناقابلِ اعتبار آدمی ہے۔&&(مفردات امام راغب) && (۵) لباس سے مراد انسان کا اپنا عمل بھی ہوسکتا ہے۔ کیوں کہ ہر شخص کے اعمال مثل اس کے لباس کے ہیں کہ اس کے ظاہر و باطن کو بتاتے ہیں۔(۶) بعض نے کہا لباس سے مراد دل ،دماغ،روح اور جان ہے ۔ ان کو پاک رکھّو ۔ مگر اس میں ظاہری لباس بھی شامل ہے۔ صاف لباس ہی کے اندر صاف دل و دماغ ،صاف روح اور صاف جان ہوتی ہے۔ &&(تفسیر نمونہ)&& !!فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا: <<فَطَھِّرْ>> کے معنی <<فَقَصِّرْ>>یعنی:  اپنے لباس کو چھوٹا رکھو ۔ (تاکہ پاک صاف رہے اور غرور و تکبر قریب نہ آئے کیو ں کہ عرب لوگ اپنے لباس کو زمین پر لٹکا کر کھینچتے ہوئے تکبر سے چلتے تھے)&&(تفسیر مجمع البیان جلد ۱۰)&&
  74,5,آیت نمبر۵:<<رُجز >>سے مراد ہر قسم کی گندگی اور نجاست ہے جس میں بت پر ستی اور شرک کرنا اولین معنی ہیں گندگی ہیں ۔&&(قابوس ۔ لسان) <<&&رُجز <<کے معنی اضطراب اور تزلزل کہ بھی ہوتے ہیں ۔ &&(مفردات امام راغب)&&اس میں ہر قسم کا گناہ ،جیسے شرک ۔ کفر ۔ بُت پرستی ،شیطانی خیالات اور عذابِ الہٰی تک شامل ہیں ۔ جو انسان کے اضطراب اور تباہی کا سبب بنتے ہیں ۔ اس لیے بعض مفسرین نے << رُجز <<کا ترجمہ عذاب کی ہے۔ &&(تفسیر المیزان۔ فی ظلال القرآن) &&قرآن میں بھی <<رجز<<کا لفظ عذاب کے لیے آیا ہے مثلاً: <<وَلَمَّا وَقَعَ عَلَيْہِمُ الرِّجْزُ>>  @@اور جب ان پر عذاب آیا@@۔&&(سورۃ ۷ الاعراف آیت ۱۳۵ پارہ ۹)فَلَمَّا كَشَفْنَا عَنْہُمُ الرِّجْزَ یعنی پس جب ہم نے ان پر عذاب کوٹال دیا۔&&( سورہ اعراف آیت ۱۳۵پارہ۹)عربی ادب میں << رجز<<اور رجس گندگی کے معنی میں آتے ہیں ۔&&(تفسیر کبیر امام رازی)&&ہمارے رسول صلی اللہ علیہ و آلہ وسلم رسالت کے اعلان سے پہلے بھی گندگی ،شرک ،کفر ،شیطانی اعمال و خیالات سے دور ہی رہتے تھے جو تاریخ سے متفقہ طور پر ثابت ہے۔ اب جو حکم دیا جا رہا ہے وہ امت کے لیے ہے۔ رسول صلی اللہ علیہ و آلہ وسلم کو ذریعہ بنایا گیا ہے۔ (اور یہ بتانے کے لیے خداوندِ عالم خود بھی پاکیزگی اور صفائی کو پسند فرماتا ہے۔)&&(تفسیر نمونہ)&&
  74,6,آیت نمبر۶:<< لَا تَمْنُنْ <<>> مَنْت <<کے مادے سے ہے۔ یعنی احسان جتانا ۔ اپنی عطا کو بڑی چیز سمجھنا اپنی خدمتوں کو بڑا سمجھ کر اجر طلب کرنا۔ جب انسان اپنی خدمات یا کاموں یا عطاوں کو بڑا سمجھتا ہے تو بڑے اجر و انعام کی توقعات باندھتا ہے۔ اور یہ عمل خدا کے سامنے بندے کو ذلیل کردیتا ہے۔ بندگی کی شان یہ ہے کہ رسولِ صلی اللہ علیہ و آلہ وسلم اکرم جیسا عبادت گذار انسان یہ کہتا رہا(ماعبدناک حق عبادتک) مالک! ہم آپ کی عبادت کا حق ادا ہی نہیں کرسکے۔&&(تفسیر نمونہ)&&{{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ جناب رسولِ خدا  صلی اللہ علیہ و آلہ وسلم نے فرمایا: جو اچھّا کام تم اللہ کے لیے کرتے ہو،اس کو ہرگز زیادہ نہ سمجھو۔&&(تفسیر نورالثقلین جلد ۵ ۔ تفسیر برہان جلد ۴)&&نیز }}آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایاکہ:  میں ہر روز سو دفعہ خدا سے معافیاں طلب کرتا ہوں ۔&&(الحدیث) &&{{ظاہر ہے کہ رسولِ اکرم صلی اللہ علیہ و آلہ وسلم کون سا گناہ کرتے تھے؟ آپ صلی اللہ علیہ و آلہ وسلم کا استغفار یہ تھا کہ آپ صلی اللہ علیہ و آلہ وسلم ایک طرف تو خدا کی عطاوں کو دیکھتے تھے ،دوسری طرف اپنی عبادتوں کی کمی کو محسوس فرماتے ہیں ۔ اس لیے اس احساسِ کمی پر معافیاں طلب فرماتے تھے کہ میں ویسی خدمت نہ کرسکا جیسی عظیم عطائیں اور بخششیں تو نے مجھ پر فرمائیں ۔&&(فصل الخطاب)&&!!دوسری تفسیر :یہاں یہ بھی بتایا گیا کہ صرف ظاہری کپڑوں کی طہارت کافی نہیں وہتی ہے،یہ تو طہارت کی ابتداء ہے اصل طہارت نفس ،قلب ،دل و نگاہ ،نیتوں اور اعمال کی طہارت ہوتی ہے کیوں کہ اس کے لیے کافی زحمتیں برداشت کرنی پڑتی ہیں ۔ اسی لیے اگلی آیت میں صبرو برداشت سے کام لینے کا حکم دیا۔ ]]زُباں سے کہہ بھی دیا لَآ اِلٰہَ اِلَّا اللہ تو کیا حاصل۔۔۔۔دل و نگاہ مسلماں نہیں تو کچھ بھی نہیں[[ &&(اقبال)&&پھریہاں صبر کا حکم دینے سے معلوم ہوا کہ صبر کے معنی گردن جھکانا نہیں ہوتے بلکہ ثباتِ قدم کے ساتھ حق پر قائم رہنا صبر ہوتا ہے۔ &&(تفسیر ماجدی)&&!!وفاداری بشرطِ استواری ،اصلِ ایماں ہے۔ حاصلِ کلام یہ ہے کہ راہِ حق میں اللہ کی رضامندی حاصل کرنے کے لیے صبر و برداشت سے کام لیجئے اور حق پر قائم رہیے۔&&(معالم ۔ ابنِ کثیر)&&!!ہر نبی کو جو ابتدائی ہدایات:دی جاتی ہیں وہ ان مذکورہ چھ آیتوں میں بیان ہوئی ہیں ، دین کی تبلیغ میں اس سے بہتر کوئی ہدایات نہیں ہوسکتیں : مختصر اور جامع:(۱) <<قُم<<@@کھڑے ہوہمت کرو @@ <<فَاَنْذِوْ <<لوگوں کو برے انجام سے ڈراو۔(۲) << وَرَبَّکَ فَکَبِّرْ <<@@اللہ کی بڑائی کو بیان کرو اور ثابت کرو ،دوسرے جھوٹے خدائی کے دعویداروں کی بڑائی کے دعووں کو ٹھکرا دو@@۔(۳) <<وَرَبَّکَ فَکَبِّرْ>>نیت خیالات ،اقوال ،اعمال،لباس پاک صاف رکھو۔(۴)<<وَالرُّجْزَفَاھْجُرْ>> ہر قسم کے نجاستوں سے خود کو دور کھو۔(۵) <<وَلَاتَمْنُنْ تَسْتَکْثِرُ>>اور ذاتی فائدوں کے لیے دوسروں پر احسان نہ کرو،اور احسان صرف اللہ کو خوش کرنے کے لیے کرو،اور اپنے احسانات کو بہت بڑا نہ سمجھو۔(۶) <<وَلِرَبِّکَ فَاصْبِرْ>>اور اپنے رب کی خاطر صبر کرو۔ مشکلات کا مقابلہ کرو&&(تفسیر کبیر ۔ تفہیم۔ تفسیر نمونہ)&&
  74,7,آیت نمبر۷:تبلیغ دین میں صبر و برداشت:مطلب یہ ہے کہ : اے رسولؐ! یہ پیامِ توحید کی تبلیغ کا کام جو تمھارے صلی اللہ علیہ و آلہ وسلم سپرد کیاجارہا ہے اس کے پہنچانے میں تمھیں سخت مشکلات اور مخالفتوں کا مقابلہ کرنا پڑے گا سارا عرب تمھارے مقابلہ پر اٹھ کھڑا ہوگا۔ ا س لیے آپ صلی اللہ علیہ و آلہ وسلم کو اپنے مالک کی خاطر صبر سے کام لینا ہوگا۔]]گفتارِ صدق مایہ آزادی شود۔چوں حرفِ حق بلند شود دار می شود[[۔&&(عرفی)]]عرفی تو میاندیش زغوغائے رقیباں ۔آوازِ سگاں کم نکند رزقِ گدارا۔[[&&(عرفی)&&خوف ،دوستی،دشمنی ،محبت ،رشتہ داریاں ،ہر چیز تمھارے راستے میں حائل ہوگی ،مگر تمھیں صلی اللہ علیہ و آلہ وسلم اپنے موقف پر مضبوطی سے قائم رہنا ہوگا۔وفاداری بشرطِ استواری اصلِ ایماں ہے }}امیر المومنین حضرت امام علی علیہ السلام سے روایت ہے کہ جناب رسولِ خداؐ نے فرمایا: صبر کی ایمان کے ساتھ وہی حیثیت ہے جو سر کی حیثیت جسم کے ساتھ ہوتی ہے۔&&(نہج البلاغہ کلماتِ قصاد نمبر ۸۲) &&{{گویا صبر کرنا،ایمان کا سر ہے ۔ یعنی ایمان کی چوٹی بھی ہے ،اور لازمی شرط بھی ۔ کیوں کہ ایمان لانا حقیقتوں کو ماننا ہے،صداقتوں کی تصدیق کرنا ہے۔ اور یہ کلام بلاوں کو دعوت دیتا ہے۔ نیز }}جناب امیر المومنین علیہ السلام نے فرمایا: صبر کے چار شعبے ہیں ۔ شوق ،خوف،زُہد ،انتظار۔شوق:یعنی جس کو جنت کا شوق ہے و ہ سرکش خواہشات سے کنارہ کش رہتاہے ۔ خوف: یعنی جو آتشِ دوزخ سے خوف رکھتا ہے ،وہ گناہوں ،حرامکاریوں سے بچتا ہے۔زُہد: یعنی جو دنیا سے زُہد و پرہیز کرتا ہے وہ مصیبتوں کو آسان اور ہلکا سمجھتا ہے۔انتظار : یعنی جو موت کا انتظار کرتا ہے ،وہ نیک کاموں میں جلدی کرتا ہے۔&&(نہج البلاغہ کلماتِ قصار){{&&!!حدیثِ قُدسی:}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: کہ خداوندِ عالم نے اپنی حدیث میں  میں جس وقت اپنے کسی بندے پر اس کے بدن ،مال یا اولاد پر مصیبت ڈالتا ہوں ،اور وہ اس پر صبر ِجمیل سے قائم اور اس کا مقابلہ (پامردی سے ) کرتا ہے تو مجھے شرم آتی ہے کہ قیامت کے روز اس کے اعمال تولنے کے لیے (عدل کی) ترازو نصب کروں یا اس کا نامہ اعمال کھولوں ۔&&(تفسیر روح المعانی جلد ۲۹) &&{{نیز }}حضورِ اکرم صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:  روزِ قیامت خداوندِ عالم کی جانب سے ایک ندا آئے گی کہ کہاں ہیں وہ لوگ جو صبر کرتے تھے۔اس آواز کو سن کر ایک گروہ آئے گا جس کے استقبال کے لیے فرشتے آگے بڑھیں گے اور ان لوگوں سے سوال کریں گے: تم نے کس چیز پر صبر کیا تھا؟ وہ کہیں گے: ہم نے خدا کی اطاعت پر صبر کیا ،ترکِ گناہ پر صبر کیا،اور مصائب کی مشقت برداشت کی ان سب چیزوں پر صبر کیا۔تب اللہ تعالیٰ کی طرف سے ایک فرشتہ ندادے گا کہ یہ بندگانِ خدا سچ کہتے ہیں انھیں بے حساب کتاب میری بہشت میں جانے دو۔&&(روح الحیات ص ۶۳۹ علاّمہ مجلسیؒ)&&{{ {{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے منقول ہے کہ : اگر کوئی مومن مصیبت و بلا میں گرفتار ہو اور وہ اس پر صبر کرے تو خدا وندِعالم اس کو ہزار شہیدوں کا ثواب بخشے گا۔&&(روح الحیات ص ۶۳۹ علامہ مجلسیؒ){{&&
  74,8,آیت نمبر۸:<< نُقِرَ فِی النَّاقُوْرِ << ( جب صور میں پھونک ماری جائے گی)یعنی: امام ِغائب علیہ السلام کے کانوں میں ندا پہنچے گی۔ اور ایک روایت میں ہے کہ ناقور کے معنی نِدا کے ہیں ۔اور ظہورِ امامِ قائم علیہ السلام کے دن حضرت جبریل علیہ السلام آسمان سے نِدا دیں گے۔ پس وہ دن حضرت امام علی ابنِ ابی طالب علیہ السلام کی ولایت کا انکار کرنے والوں کے لے نہایت سخت دن ہوگا۔&&(تفسیر بُرہان۔ تفسیر انوار النجف)&&
  74,9,آیت نمبر ۹ کا مطلب یہ ہے کہ:  (اے کافرو،مشرکو!) تم جو یہ بدمعاشیاں کررہے ہو،کرلو،اگر دنیا میں تمہارا کام بن بھی گیا،مگر تم اس برے دن کے انجام سے کیسے بچ سکو گے ،جب صور پھونکا جائے گا،اور اعمال کی جزاء و سزاد ی جائے گی۔&&(تفسیر کبیر ۔ تفہیم)&&
  74,10,آیت نمبر ۱۰ سے محققین نے یہ نتیجہ نکالا کہ:قیامت کا دن ایمان والوں کے لیے ہلکا اور حق کے منکروں کیلیے سخت ہوگا۔ یہ سختی منکروں کے لیے مستقل ہوگی،ایسی سختی جو کبھی نرمی میں نہ بدلے گی۔&&(تفسیر کبیر۔ مجمع البیان۔ تفہیم۔ تفسیر نمونہ) &&
  74,11,آیت نمبر۱۱:<< وَحِیْدًا >>(یعنی مراد ولید بن مغیرہ ہے) مگر یہ خطاب حضور اکرم صلی اللہ علیہ و آلہ وسلم سے ہے۔ مطلب یہ ہے کہ :  اے نبیؐ! مکے کے کافروں کی کانفرنس میں جس شخص ( ولید بن مغیرہ) نے تمھیں صلی اللہ علیہ و آلہ وسلم بدنام کرنے کے لیے یہ مشورہ دیا تھا کہ تمام عرب س آنے والے حاجیوں میں تمھیں جادو گر مشہور کردیا جائے اس کا معاملہ تم مجھ پر چھوڑ دو ۔ اس سے نمٹنا اب تمھار نہیں ،میرا کام ،تمھیں اس کی فکر کی ضرورت نہیں ۔ میں نے جب اس کو پیدا کیا تھا ،تو نہ اس کے پاس مال تھا نہ اولاد۔دوسرا مطلب یہ ہے کہ میں نے اکیلا اس کو پیدا کیا تھا ،جن خداوں کا وہ کلمہ پڑھ رہا ہے وہ اس کے پیدا کرنے میں میرے شریک نہ تھے۔ اب کیو ں کہ میں نے ہی اکیلا اس کوپیدا کیا تھا ،اس لیے میں اکیلا ہیں اس سے نمٹ لوں گا۔&&(تفسیر کبیر۔ کشاف۔ مراغی) &&!!ولید اور وحید: ولید خود کووحید کہا کرتا تھا: یعنی میں بےمثل ،لاجواب ہوں ،عربوں میں میرا کوئی جوڑ نہیں ہے۔ وہ احمق اپنے لیے کہاکرتاتھا<<اناالوحی ابن الوحٰد لیس لی فی العرب نظیر>> یعنی : میں وحید عصر ہوں ، وحید عصر کابیٹاہوں ، عرب میں کوئی نہ میر مثل ونظیر ہے نہ میرےباپ کا۔&&(تفسیر کبیر ،کشاف ،مراغی) &&اس لیے خداوندِ عالم نے بھی اُس کے لیے وحید کا لفظ طنزاَ استعمال فرمایا:&&(تفسیر نمونہ)&& <<خَلَقْتُ وَحَیْدًا <<اس کے ایک معنی تو یہ ہیں کہ:  میں نے تنہائی اس کو پیدا کیا ہے۔دوسرے معنی یہ بھی ہوسکتے ہیں کہ : جب وہ پیدا ہوا تو تنہا تھا۔ اور یہ ولید بن مغیرہ کے متعلق ہے۔ اور}} صادقین (امام محّمد باقر اور امام جعفر صادق) علیہما السَّلام سے مری ہے کہ : آیت میں : <<وحید<<کے معنی<<ولَد الزّنا <<: کے ہیں ۔ چنانچہ ہشام بن ولید بن مغیرہ کی اولاد میں سے ایک شخص نے فخریہ کہا کہ میں وحید کی اولاد ہوں ۔، اس پر }}امام محمد باقر علیہ السلام نے فرمایا:  اگر اس کو <<وحید<<کے معنی کا پتہ ہوتا تو اس پر فخر نہ کرتا۔راوی نے پوچھا کہ : << وحید<<کے معنی کیا ہیں ؟ آپ نے فرمایا:<< وحید<<اس کو کہتے ہیں جس کے باپ کا پتہ نہ ہو۔&&(انوارلنجف){{اور تفسیر برہان میں ہے کہ اس کی وجہ تسمیہ وحید اس لیے ہوئی کہ اس نے تمام قریشیوں سے غلافِ بیت اللہ کے متعلق کہا تھا کہ ایک سال تم سب ملکر اس کا غلاف دیا کرو،اور ایک سال میں <<وحید<<۔ یعنی اکیلا اس پر غلاف چڑھاوں گا۔ اور اس (وحید) کے مالدار ہونے کا قرآن نے خود ذکر فرمایا:<<وَّجَعَلْتُ لَہٗ مَالًا مَّمْدُوْدًا۱۲>>  (اور ہم اس کو زیادہ مال دیا) اور ایک روایت میں <<وحید<<سے مراد (ومعنی) شیطان کے ہیں ۔ کیوں کہ شیطان بھی ماں اور باپ کے بغیر ہی پیدا ہوا ہے۔&&(تفسیربُرہان۔ تفسیر انوارالنجف) &&
  74,13,آیت نمبر ۱۳: ولید بن مغیرہ کے دس بارہ لڑکے تھےجن میں سے ایک خالد بن ولید تاریخ میں مشہور ہوا اس کے تمام بیٹے اس کے سامنے حاضر رہتے تھے۔ کیو ں کہ وہ بہت دولتمند تھا بیٹوں کو کام کاج کی ضرورت نہ تھی۔ دوسرا مطلب یہ بھی ہوسکتا ہے کہ اُس کے بیٹے بااثر تھے جو محفلوں میں اس کے ساتھ اُٹھتے بیٹھتے تھے۔&&(تفہیم۔تفسیر کبیر) &&
  74,15,آیت نمبر ۱۵ میں <<یَطْمَحْ <<کا مطلب یہ ہے کہ  اتنا کچھ مال و دولت ہوتے ہوئے بھی اس کی حرص و طمع ختم نہیں ہوئی۔ اب بھی وہ اور مال حاصل کرنے کے چکر میں لگا رہتا ہے۔حسن بصری نے دوسرا مطلب بیان کیا کہ: وہ کہا کرتا تھا کہ اگر محمّد صلی اللہ علیہ و آلہ وسلم کی بات سچ ہے کہ دوسری زندگی بھی ہے اور وہاں جنت ہے ،تو ہو جنت بھی میرے ہی لیے بنائی گئی ہے۔&&( تفسیر کبیر۔ تفہیم۔ تفسیر نمونہ)&&
  74,17,آیت نمبر ۱۷ میں <<صَعُوْدًا >>کے معنی: کیوں کہ بلند چوٹیوں پر جانا مشکل کام ہوتا ہے اس لیے (۱) ہر مشکل کام کو بھی صعود کہتے ہیں اور (۲) عذاب الہٰی کو بھی کہتے ہیں کہ اس کا جھیلنا سخت ترین مشکل کام ہے۔ (۳) ایک روایت میں ہے کہ<<صعود<<جہنم میں آگ کے ایک پہاڑ کا نام ہے ۔ جہنمیوں کو مجبور کیا جائے گا کہ اس پر چڑھیں۔ جہنمی چڑھے گا تو بار بار نیچے آ گرے گا۔(۴)ایک تفسیر یہ ہے کہ اس میں ولید کی دنیوی مشکلات اور عذاب کی طرف اشارہ ہے ،اس لیے کہ آخری عمر میں وہ اپنے مال و اولاد سے ہاتھ دھو بھیٹا تھا اور اس کا دیوالیہ نکل گیا تھا۔&&(تفسیر نمونہ۔تفسیر کبیر) &&!!ولید بن مغیرہ کا حشر نشر: منقول ہے کہ جہنم میں ایک صاف پتھر کی چٹان ہوگی جس پر ولید کو چڑھنے کا حکم ہوگا کچھ فرشتے لوہے کی زنجیروں سے باندھ کر اس کو اوپر کھینچیں گے اور کچھ فرشتے لوہے کے گزروں سے اس کو پیچھے سے ماریں گے،جب اس حالت میں اوپر چوٹی پر پہنچے گا تو چھوڑ دیں گے اور وہ دھڑم سے جہنم کی تہ پر جاگرے گا۔ فرشتے پھر اس کو اسی صورت سے مارتے پیٹتے ۔ کھینچ کھینچ کر اوپر لے جائیں گے ،پھر وہاں سے اسے چھوڑ دیں گے اور وہ پھر جہنم کی تہ پر دھڑم سے جاگرے گا۔ اور یہ چڑھائی چالیس برس کی چڑھائی ہوگی۔ پس وہ اسی عذاب میں مبتلا رہے گا۔ (العیاذَ اباللہ)]]حذر اے چیرہ دستاں سخت ہیں قدرت کی تعزیریں[[&&( تفسیر انوار النجف) &&
  74,18,آیت نمبر۱۸: ولید اور ابوجہل کا مکالمہ:ولید بند مغیرہ قرآن سن کر اس کے کلامِ الہٰی ہونے کا قائل ہوچکا تھا ،اس لیے کہ جب عربوں نے اس کے سامنے کہا کہ محمّد صلی اللہ علیہ و آلہ وسلم کاہن ہیں ۔ یہ سن کر ولید نے کہا تھا کہ : نہیں ،خدا کی قسم وہ کاہن نہیں ۔ ہم نے کاہنوں کو دیکھا ہے جیسی باتیں وہ گنگناتے ہیں اور جس طرح کے فقرے وہ جوڑتے ہیں ،قرآن کا ان سے دور کا بھی کوئی تعلق نہیں ہے۔پھر لوگوں نے مشورہ کیا کہ  محمّد صلی اللہ علیہ و آلہ وسلم کو مجنون مشہور کردیتے ہیں ۔ولید بولا:  وہ مجنون نہیں ہیں ۔ قرآن میں ایسی کوئی بات نہیں ہے۔اس پر لوگوں نے کہا : اچھا پھر ہم محمّد صلی اللہ علیہ و آلہ وسلم کو شاعر مشہور کیے دیتے ہیں ۔ولید نے کہا: ہم شعر کی تمام قسموں سے واقف ہیں ،قرآن پر شاعری کا ہرگز اطلاق نہیں ہوتااس پر لوگو ں نے کہا:  اچھا ہم محمّد صلی اللہ علیہ و آلہ وسلم کو جادوگر مشہور کیے دیتے ہیں ولید نے کہا: محمدّ صلی اللہ علیہ و آلہ وسلم پر یہ بات بھی چسپاں نہیں ہوتی،جادوگروں کے جنتروں منتروں کو ہم خوب جانتے ہیں ، وہ بے معنی ،بے موزوں کلام ہوتا ہے جبکہ قرآن میں بڑی حلاوت ہے ،اس کی جڑ بہت گہری،اس کی ڈالیاں ثمر دار ہیں ۔یہ سن کر ابوجہل ولید کے سر ہوگیا اور بولا کہ : تیری قوم تجھ سے راضی نہ ہوگی جب تک کہ تو محمّد صلی اللہ علیہ و آلہ وسلم کے واسطے کوئی بری بات نہ کہے گا۔اس پر ولید نے کہا: مجھے سوچ لینے دو۔پھر اس نے لوگوں کی طرف دیکھا۔ لوگوں نے تیور دیکھ کر پیشانی سکیڑی ،پھر منہ بنایا،دماغ پر زور دیا،پھر پلٹا اور تکبّر کے عالم میں بولا: یہ قرآن کچھ نہیں ہے،بس ایک جادو ہے جو سرچڑھ کر بول رہا ہے بس تم عربوں سے یہی کہو کہ یہ شخص جادوگر ہے ،اس لیے کہ یہ ایسا کلام پیش کررہا ہے جو آدمی کو اس کے ماں باپ،بھائی بہن،بیوی بچوں ،دوستوں خانداں والوں سے جُدا کردیتا ہے۔ولید کی اس بات کو سب نے قبول کر لیا۔ اور یہ منصوبہ بنالیا کہ اب جو حاجی بھی آئے گا قریش ہر ایک وفود کو یہی سمجھائیں گے کہ محمّد صلی اللہ علیہ و آلہ وسلم جادوگر ہیں ،انھوں نے بھائی بھائی سے جدا کردیا ہے لہٰذا اس سے بچ کر رہنا۔&&(ابنِ جریر بردایت عکرمہ۔ تفسیر کبیر۔ مجمع البیان تفسیر نمونہ۔ انوارالنجف ،قرطبی،مراغی،المیزان فی ظلال القرآن) &&!!شانِ نزول:آیت کے الفاظ کسی خاص آدمی کی طرف اشارہ اور نشاندہی کررہے ہیں ۔ علامہ طِبرسی ؒ نے لکھا:  قریش دارالندوۃ (مشاورتی چوپال ) میں جمع ہوئے اور مسئلہ یہ درپیش تھا کہ حج کا زمانہ آرہا ہے،تمام قبائل کے لوگ مکہ آئیں گے ،اب کیا کیا جائے کہ محمدّ صلی اللہ علیہ و آلہ وسلم کو جادوگر کہا کریں گے ولید نے پوچھا: کیوں ؟ ، لوگوں نے کہا اس لیے کہ وہ دوستوں کو دشمن بنا دیتا ہے ،عزیزوں کو عزیزوں سے چھڑا دیتا ہے اور یہ کام جادوگر ہی کیا کرتے ہیں ۔ولید بولا: ٹھیک ہے ۔ اب اس کو جادوگر مشہور کر دو۔اب جو بھی رسولِ اکرم صلی اللہ علیہ و آلہ وسلم سے ملتا ،جادو گر کہہ کر خطاب کرتا ۔ اسی پر یہ آیات نازل ہوئیں ۔&&(تفسیر مجمع البیان ۔ سیرت ابنِ ہشام) &&
  74,27,آیت نمبر۲۷ـ:جہنم کی صفت:جہنم کی ایک صفت یہ بھی ہے کہ وہ رحم نہیں کرتی کیوں کہ وہ غضبِ الٰھی کی مظھر ہے۔ اس لیے وہ جہنمیوں کو طرح طرح کی اذیتیں ،اور سزائیں دئیے بغیر نہیں چھوڑتی،نہ وہ زندہ ہی رہنے دیتی ہے نہ مرنے ہی دیتی ہے۔ (الحفیظ الامان) &&(تفسیر مجمع البیان)&& اِسی بات کوقرآن میں دوسری جگہ یوں فرمایا:<<ثُمَّ لَا يَمُوْتُ فِيْہَا وَلَا يَحْيٰي>> &&( سورۃ۸۷ الاعلیٰ آیت ۱۳ پارہ ۳۰) &&یعنی: @@ پھر نہ وہ جہنم میں مرے گا،اور نہ زندہ رہے گا۔@@ ایک مطلب یہ بھی ہوسکتا ہے کہ : وہ کسی جہنمی عذاب کے مستحق کو باقی نہ چھوڑے گی۔ کوئی ظالم،جابر جہنم کے غداب سے بچ نہ سکے گا جسے خدا عذاب دینا چاہے گا وہ جہنم کی پکڑے نہ بچے گا۔&&( تفسیر کبیر۔تفہیم۔ مجمع البیان)&&@@
  74,29,آیت نمبر ۲۹ کی تشریح:یہ کہنے کے بعد کہ جہنم جلائے بغیر نہ چھوڑے گی ،پھر یہ فرمانا کہ جہنم کھال جَھلسا دینے والی ہے ۔ بظاہر یہ بیان غیر ضروری سا معلوم ہوتا ہے لیکن سزا کا یہ خاص بیان اس لیے کیا گیا ہے کہ آدمی کی شخصیت کو نکھار دینے والی چیز اس چہرے اور جسم کی کھال ہوا کرتی ہے۔ اگر چہرے کی کھال جل جائے تو حَسین ترین آدمی انتہائی بد شکل ہوجاتا ہے،جلی ہوئی کھال دیکھ کر ہر شخص اس سے گِھن کھاتا ہے۔ بتایا جا رہا ہے کہ تم آج اپنی شخصیت پر پھولے پھر رہے ہو،جب ولید بند مغیرہ جیسے طرّم خانوں کے منہ جہنم سے جھلسا دئیے جائیں گیں تب ان کا لوگوں کے سامنے کیا حشر نشر ہوگا؟ ساری اکڑ مکڑ نکل جائے گی،اور ساری طُرّم خانی نالی میں بہ جائے گی۔بُرے کام کا بُرا انجام ۔&&( تفسیر کبیر۔ مجمع البیان۔تفسیر نمونہ۔ تفہیم) &&
  74,30,آیت نمبر۳۰:جب جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے یہ آیت پڑھی کہ جہنم کے کارکنوں (فرشتوں ) کی تعداد صرف انیس ہوگی تو کفار نے مذاق اڑانا شروع کردیا۔ کہنے لگے کہ ایک طرف تو یہ کہا جاتا ہے کہ آدم علیہ السلام سے لے کر قیامت تک کے ظالم و جابر کافر ،مشرک،بڑے بڑے گنہگار جہنم میں ہوں گے،اور دوسری طرف یہ کہا جارہا ہے کہ اتنی بڑی تعداد کو سنبھالنے والے صرف ۱۹ کارکن ہوں گے۔اس پر قریش کے سرداروں نے برے زور کا قہقہہ مارا۔ ابوجہل بولا بھائیو! کیا تم اتنے گئے گذرے ہوکہ تم میں سے دس دس ملکر بھی ایک جہنم کے کارکن سے نہ نمٹ سکو گے؟ایک پہلوان صاحب بولے :  ۱۹ سے تو میں اکیلا ہی نمٹ لوں گا،باقی دو کو تم سب ملکر سنبھال لینا۔اس کا جواب اگلی آیت میں دیا گیا ہے کہ : اے احمقو! وہ ۱۹ فرشتے ہوں گے ،تم ان کا قیاس انسانی قوتوں پر کررہے ہو۔ تمھیں پتہ نہیں کہ اللہ نے کیسی کیسی زبردست طاقت والے فرشتے پیدا کیے ہیں ۔&&( تفسیر کبیر۔تفہیم) &&اُنیس سے مراد: بعض نے لکھا : یہ فرشتوں کے ۱۹ گروہوں کی طرف اشارہ ہے جو عذاب پر مامور ہیں  نہ کہ ۱۹ فرشتوں کی طرف۔ کیوں کہ بعد میں فرمایا:  اللہ کے لشکروں کی تعداد کوئی نہیں جانتا۔بعض نے لکھا کہ ۱۹ کا عدد اس لیے انتخاب فرمایا کہ ۱۹ کا عدد اکائیوں میں سے بڑا عدد ہے &&(۹ کا عدد) &&اور دہائیوں میں سب سے چھوٹا عدد ۱۰ کا عدد ہے۔بعض نے لکھا کہ تمام برے اخلاق کی جڑیں ۱۹ بنیادی صفات کی طرف لوٹتی ہیں اس لیے کہ جہنم کے ۱۹ طبقے ہیں ۔ اصل بات یہ ہے کہ ہم اس کی حقیقت کو نہیں سمجھ سکتے۔&&( تفسیرنمونہ۔ تفسیر کبیر) &&
  74,31,آیت نمبر۳۱:{{خداوندِ عالم کا یہ فرمانا کہ :  تاکہ اہل کتاب کو یقین آجائے۔ {{یہ اس لیے فرمایا کہ اہل کتابِ جانتے تھے کہ خداوند ِ عالم نے جہنم پر ۱۹ سپاہی مقرر فرمائے ہیں ۔ اور {{خداوندِ عالم کا یہ فرمانا کہ : تاکہ ایمان لانے والوں کا ایمان بڑھے۔ {{کیوں کہ جس قدر قرآن کی آیتیں اُتری ہیں ،وہ صاحبانِ ایمان کو بڑھاتی ہیں اور جس قدر مومن آزمائشوں سے گذرتا جاتا ہے اس کا اللہ اور رسول صلی اللہ علیہ و آلہ وسلم پر ایمان اور بڑھتا جاتا ہے۔&&(تفسیر کبیر ۔ مجمع البیان۔ تفہیم۔ تفسیر نمونہ) &&]]تندی بادِ مخالف سُنے گھبرا اے عقاب!یہ جو چلتی ہے تجھے اونچا اُڑانے کے لیے[[&&( اقبال) &&دل کے بیماروں سے مراد منافق اور شکی لوگ ہوتے ہیں ۔ یہی لوگ اللہ کے کلام پر اعتراضات جڑتے رہتے ہیں ،اور اللہ کے کلام کو اپنی تنگ عقلی کے خلاف ثابت کرنے کی ناکام کوششیں کرتے ر ہتے ہیں ۔ اگر وہ خدا کی قدرت کو سمجھ لیں تو ان کی سمجھ میں یہ بات آجائے گی کہ ۔(۱) خدا کے لیے یہ کوئی مشکل کام نہیں ہے کہ وہ ہم کو مرنے کے بعد دوبارہ زندہ کرلے۔(۲) سب کا بالکل ٹھیک ٹھیک حساب لے کر جزاء سزاء دے سکے۔(۳) اور صرف ۱۹اپنے فرشتوں کے ذریعہ پوری جہنم کو کنٹرول کرسکے۔&&(مولف)&& خدا اپنے بندوں کا امتحان اس طرح بھی لیتا ہے کہ جو کوئی بات بیان کرتا ہے تو جو لوگ صحیح عقل اور صحیح مذاق کے مالک ہوتے ہیں اور مثبت سوچ رکھتے ہیں ،وہ بات کو سمجھنے کی کوشش کرتے ہیں ،اور ہدایت پا جاتے ہیں ۔رہے ،شکی ،منافق،ہٹ دھرم ،حق دشمن،کج فہم،متکبر،مفاد پرست قسم کے لوگ تو خدا کا کلام سن کر اس پر (۱) اعتراضات جڑتے ہیں (۲) اس کے ٹیڑھے مطلب نکالتے ہیں ،اور اس طر ح حق سے بھاگنے کا ایک نیا بہانہ تراش لیتے ہیں ۔ لیکن حق پرست لوگ خدا کے کلام سے ہدایت پاتے ہیں اور خدا اُن کی توفیقات میں اور اضافے فرماتا ہے۔ کیوں کہ وہ حق پسند اور واقعات پر غورو فکر کرنے والے ہوتے ہیں ۔اور دوسرے قسم کے لوگ جو خدا کے کلام کو اپنی مرضی سے اُلٹا سُلٹا مطلب پہناتے ہیں اور اس طرح خود ہدایت کے راستے پرچلنا نہیں چاہتے،تو پھر خدا بھی ان کو ان کے غلط راستوں پر جانے دیتا ہے،کیوں کہ اللہ گمراہ پسندوں کو غلط راستوں پر بضد ہوکر جانے والوں کو زبردستی حق کا راستہ نہیں دکھاتا۔ کیو ں کہ اگر خدا ایسا کرے تو دینا میں کسی کا امتحان نہ ہوسکے۔ دنیا میں خدا کا اصول یہی ہے کہ جو حق پسند ہوگا،خدا اس کو حق کا راستہ دکھادے گا،اور جو حق پسند نہیں ہوگا،خدا اس کو گمرائیوں کے راستے پر جانے کے لیے چھوڑ دیتا ہے۔ &&(تفسیر کبیر ۔ مجمع البیان۔ تفہیم)&& بعض نے لکھا کہ : یہودیوں نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے اصحاب سے جہنم کے خازنین کی تعداد پوچھی۔ انھوں نے جواباً فرمایا کہ خدا اور اس کا رسول صلی اللہ علیہ و آلہ وسلم جانتے ہیں ۔ اس پر یہ آیت اُتری کہ جہنم پر ۱۹ (گروہ) مقرر کیے گئے ہیں ۔&&(بیہقی۔ ابنِ حاتم۔ ابنِ مردویہ۔ مراغی جلد ۶۹) &&کیوں کہ ۱۹ کا ذکر آیا تو دھوکہ ہوسکتا تھا اس لیے بعد میں فرمادیا کہ اللہ کے لشکر بے حد بےحساب ہیں ۔ ان کی تعداد تمھارے مالک کے سوا کوئی نہیں جانتا۔ بعض روایات میں آیا ہے کہ زمین اور آسمانوں کو خدا نے اپنے لشکروں فرشتوں) سے بھررکھا ہے،یہاں تک کہ تمام عالمِ ہستی میں کہاں پاوں رکھنے کی بھی جگہ نہیں ہے مگر وہاں خدا کا ایک فرشتہ تسبیح میں مشغول ہے۔خدا کا یہ فرمانا کہ  یہ انسان کے لیے تذکرہ (نصیحت) ہے تو اس سے مراد (۱) جہنم کے خازن بھی ہیں (۲) خود جہنم بھی ہے (۳) خدا کے لشکر بھی ہیں (۴)قرآن بھی مراد ہے۔&&( تفسیر نمونہ) !!&&اللہ کا شکر: }}جناب امیر المومنین ، ابو الائمۃ حضرت امام علی ابنِ ابی طالب علیہ السلام نے فرمایا:  خدا وندِ تعالیٰ نے آسمانوں کو ایک دوسرے سے الگ الگ کیا اور ان کو مختلف قسم کے فرشتوں سے بھر دیا،ان فرشتوں کا ایک گروہ ہمیشہ سجدوں ہی میں رہتا ہےرکوع نہیں کرتا۔ایک گروہ رکوع ہی میں رکوع میں رہتا ہے اور سر نہیں اٹھاتا۔ ایک گروہ ہمیشہ کھڑے رہ کر عبادت الٰہی میں مصروف رہتاہے، ،اور اپنی جگہ نہیں بدلتا،ایک گروہ ہر وقت تسبیح الہٰی ہی کرتا رہتا ہے ،اور کبھی نہیں تھکتا،نہ ان پر کبھی نیند غالب آتی ہے ،اور نہ بھول چوک انکی عقل پر غالب آسکتی ہے ،ان کے جسم کبھی سُستی کی طرف مائل نہیں ہوتے۔پھر اُن کا ایک دوسرا بڑا گروہ جو اللہ جَلَّ جَلالہٗ کی وحی کا امین ہے جو اللہ کے پیغمبروں کی طرف اللہ کی زُبان ہے۔ یہ گروہ مسلسل اللہ عزاسمہ،کے فرامین لے لے کر اس کا پیغام پہنچانے والوں کے پاں آتا جاتا رہتا ہے۔کچھ فرشتے ایسے ہیں جو بندوں کے محافظ اور جنت کے دروازوں کے نگہباں و پاسبان ہیں ،کچھ ان میں ایسے بھی جن کے قدم زمین کی تہ (تحت الثریٰ ) میں جمے ہوئے ہیں ،اُن کے پہلو اطرافِ عالم سے بھی آگے ،اِدھر اُدھر بڑھ گئے ہیں ،اوران کے شانے عرش کے پایوں سے ملے ہوئے ہیں ۔ عرش کے سامنے ان کی نظریں جھکی ہوئی ہیں اور اس کے نیچے اپنے پروں میں لپٹے ہوئے ہیں اور ان میں اور دوسری مخلوق میں عزت کے حجاب اور قدرت کے سراپردے حائل ہیں ۔ وہ شکل و صورت کے ساتھ اپنے رب کا تصور تک نہیں کرتے ،نہ اس پر مخلوق کی صفتیں طاری کرتے ہیں ،نہ اشباہ و نظائر سے اس کی طرف اشارہ کرتے ہیں ۔&&(نہج البلاغہ خطبہ اول)&&
  74,32,آیت نمبر۳۲: <<کَلَّا>> :کیوں کہ ذکر جہنم کا ہو رہا تھا اور یہ لوگ جہنم کا مذاق اُڑارہے تھے ،اس لیے : {{خداوندِ عالم کایہ فرمانا کہ: ہر گز نہیں {{اسکا تعلق اس مذاق کے ساتھ ہے یعنی جہنم کا مذاق اُڑانا ہرگز نہیں چاہیے پھر فرمایا کہ:  یہ <<جہنم<<بہت بڑی چیز ہے۔اس سے جہنم کی شدت کی طرف اشارہ ہے ۔ مطلب یہ ہے کہ جہنم کوئی ایسی چیز نہیں ہے کہ جس کو مذاق کرکے ٹال دیا جائے۔&&(تفسیر ماجدی۔ فصل الخطاب)&&
  74,33,آیت ۳۳۔ ۳۴:رات کو تمام حقیقتیں چھپی رہتی ہیں اور دن میں حقیقتیں ظاہر ہوجاتی ہیں ۔ اس لیے رات سے مراد دنیا کی زندگی ہے اور دنیا کا ختم ہوجانا ،اور آخرت کا ظاہر ہونا صبح نمودار ہونے کی طرح ہے۔&&(تفسیر ماجدی)&&
  74,35,آیت ۳۵ کی تشریح:مطلب یہ ہے کہ جس طرح ،چاند ،سورج،رات ،دن خداوندِ عالم کی قدرت کی عظیم علامتیں ،نشانیاں اور دلیلیں ہیں ،بالکل اسی طرح جہنم بھی اللہ کی قدرت کی ایک عظیم نشانی ہے۔ اگر خدا چاند کو پیدا کرسکتا ہے۔ اب اگر مثلاً؛چاند،سورج تم نے نہ دیکھے ہوتے،اور کوئی کہتا کہ خدا نے چاند سورج پیدا کردئیے ہیں تو کیا یہ سن کر تم اسی طرح ٹھٹھے مارتے جس طرح یہ سن کر ٹھٹے مارتے ہوکہ خدا نے جہنم پیدا کی ہے ۔ جو خدا ساری کائنات بناسکتا ے ،وہ جہنم کو کیوں نہیں بناسکتا؟ جو تم جیسوں کو بناسکتا ہے ،وہ تم جیسوں کا ٹھکانا کیوں نہیں بناسکتا؟ جہاں خدا نے لاکھوں ،کروڑوں ،اربوں ،کھربوں ستارے ،سیارے پیدا کردئیے ہیں ،وہاں جہنم بھی خدا کی ایک مخلوق ہے ،جو خدا کی قدرت اور ہیبت کی ایک علامت اور دلیل ہے۔&&(تفسیر کبیر ۔ تفہیم ۔ مجمع البیان)&&
  74,37,آیت نمبر۳۷:<<لِمَنْ شَآ ئَ مِنْکُمْ>>: اس آیت نے انسان کے ارادے اور اختیار کو واضح طور پر ثابت کر دیا ہے علمائے اہلِسنّت نے لکھا کہ اہلِ سنت ارادہ عبد کی نفی نہیں کرتے بلکہ اس کا عین اثبات کرتے ہیں ۔ کیوں کہ انسان اپنے ارادے کا خالق ہے۔&&(تفسیر ماجدی)&& جب خدا کے عذاب سے ڈرایا جاچکا تو اب اختیار دے دیا گیا کہ چاہو تو آگے بڑھ کر حق کو مان لو اور چاہو تو حق سے ہٹ کر پیچھے رہ جاو۔ یہ اجازت بھی ہے اور اختیار بھی ہے ۔&&(مولف)&& !!رہا یہ کہنا کہ یہ جہنم والوں کے لیے ہے ۔یہ اس لیے غلط ہے کہ بھلا جہنم میں یہ اختیار کہاں مل سکتا ہے کہ کوئی آگے پیچھے ہوسکے۔ بلکہ اس اختیار کا تعلق دنیا میں ایمان لانے یا نہ لانے ،خدا کی اطاعت کرنے یا معصیت کرنے سے ہے جس کی وجہ سے جنت یا جہنم ملتی ہے۔اصل میں یہ بتانا مقصود ہے کہ یہ بات انسان کے خود اپنے اختیار ہی میں ہے کہ وہ چاہے تو اطاعت کی طرف آگے بڑھے اور چاہے تو اطاعت نہ کرے اور پیچھے رہ جائے۔&&(فصل الخطاب)&&]]ترا جہاں ہے وہی جس کو تو کرے پیدا۔۔۔۔نہ سنگ و خشت و شحر ، جو تری نگاہ میں ہیں ۔۔۔۔۔عمل سے زندگی بنتی ہے جنت بھی جہنم بھی ۔۔۔۔یہ خاکی اپنی فطرت میں ،نہ نوری ہے نہ ناری ہے[[۔&&(اقبال)&& !!آیت کاآخری مطلب یہ ہے کہ  ہم نے تمھیں تمھارے برے کاموں کے برے انجام سے ڈرایا اب جس کا جی چاہے اس برے انجام سے ڈر کر بھلائی کے راستے پر چلے اور جس کا جی چاہے حق کے راستے سے پیچھے ہٹ جائے۔ ۔۔۔۔۔۔۔۔۔۔۔۔ (چاہے جنتی بن جائے چاہے جہنم کو پسند کرلے)&&( تفہیم)&&{{فرزندِ رسولِؐخدا حصرت امام موسیٰ کاظم علیہ السلام سے منقول ہے کہ :  جو شخص بھی ھماری ولایت کی طرف بڑھ جائے گا،وہ جہنم سے ہٹ جائے گا ۔ اور جو شخص بھی ہماری ولایت سے پیچھے ہٹے گا،وہ جہنم کی طر ف بڑھ جائے گا۔&&(تفسیر انوار النجف) &&اور جو خدا کا فرماں بردار ہے وہ ہمارا دوست ہے ،جو خدا کا نافرمان ہے وہ ہمارا دشمن ہے اورہماری ولایت اطاعتِ خدا اور ورع و پرہیز گاری میں ہے ۔&&(از امام محمد باق علیہ السلام اصول کافی)&&}}
  74,38,آیت نمبر۳۸: ہر آدمی اپنے اعمال کا گروی ہے یعنی اپنے اعمال کا گروی ہے یعنی اپنے اعمال میں پھنسا ہوا ہے جس طرح کوئی زیور قرض کے عوض دینے والے کے پاس گروی رکھدیا جاتاہے ،تو ہو زیور پھنس جاتاہے جب تک قرضہ واپس نہ کیا جائے ،وہ زیور آزاد نہیں ہوتا،بالکل اس طرح آدمی اپنے گناہوں میں پھنسا ہوا ہے ،یا تو اس کے گناہ خدا معاف کردے ،تب وہ آزاد ہوجاتا ہے ،ورنہ اپنے گناہوں کی سزا پاکر آزاد ہوتاہے۔اسی طرح انسان یا تو توبہ کرکے اپنی اصلاح کرلے توخدا اس کے گناہ معاف کردیتا ہے اور وہ اپنے گناہوں کے چنگل سے آزاد ہو جاتا ہے، ورنہ اپنے گناہوں کی سزا پا کر آزاد ہوتا ہے۔&&(مولف)&& بعض ماہرین نے رہن کے معنی ساتھ ساتھ رہنے کے لکھے ہیں یعنی ہر انسان اپنے کیے ہوئے اعمال کے ساتھ ساتھ رہتا ہے۔&&(لسان العرب)]]&&سرِعرش کانپ اُٹّھا دلِ عصمتِ ملائک۔ جو میں ساتھ لے کے پہنچا حشمِ گناہگاری[[&&(جوش)&&
  74,39,آیت نمبر۳۹: جن لوگوں کو ان کا نامہ اعمال داھنے ہاتھ میں دیا جائے گا ،وہ اصحاب یمین ہوں گے۔ ان کے نیک اعمال ان کے برے اعمال پر غالب تھے،اس لئے ان کے نیک کاموں نے دہن  کی زنجیروں کو توڑ دیا ۔ اس لیے وہ اپنے گناہوں کے قیدی نہ ہوں گے بلکہ بےحساب جنت میں داخل ہوں گے۔&&(مجمع البیان ۔ روح البین ،تفسیر کبیر)&&!!دائیں طرف والے لوگوں کے بارے میں خود قرآن نے مختلف مقامات پر ذکر فرمایا ہے۔>>فَاَمَّا مَنْ ثَــقُلَتْ مَوَازِيْنُہٗ۶ۙ فَہُوَفِيْ عِيْشَۃٍ رَّاضِيَۃٍ۷>> @@(یعنی جس کی نیکیوں کا پلہ بھاری ہوگا ،وہ اپنی من بھاتی زندگی میں ہوگا،ایسی زندگی میں جس سے وہ راضی ہوگا۔)@@ &&( سورۃ ۱۰۱ القارعۃ آیت ۶۔۷ پارہ ۳۰) &&اور جن لوگوں کی نیکیاں وزنی ہوں گی ،ان کی برائیاں از خود ختم ہوجائیں گی: }}خداوندِ عالم نے فرمایا:<<اِنَّ الْحَسَنٰتِ يُذْہِبْنَ السَّـيِّاٰتِ>> &&( سورۃ ۱۱ ھود آیت ۱۱۴ پارہ ۲۱)&& یعنی: @@یقینا نیکیاں ،برائیوں کو ختم کردیتی ہیں @@۔جس طرح روشنی اندھیروں کو ختم کردیتی ہے ،اس طرح غالب نیکیاں برائیوں کو ختم کردیں گی ۔ دوسری جگہ فرمایا:<<فَاَمَّا مَنْ اُوْتِيَ كِتٰبَہٗ بِيَمِيْنِہٖ فَسَوْفَ يُحَاسَبُ حِسَابًا يَّسِيْرًا>> &&(سورۃ ۸۴ انشقاق آیت ۷۔۸ پارہ ۳۰)یعنی :@@پس وہ شخص جس کا نامہ اعمال اس کے دائیں ہاتھ دیا جائے گا اس کا حساب آسمان ہوگا۔@@مشہور سنی مفسر قرطبی نے امام محمّد باقر علیہ السلام سے اس آیت کی تفسیر لکھی کہ}} امام محمّدباقر علیہ السلام نے فرمایا: ہم اور ھمارے شیعہ (پیروکار) اصحابِ یمین ( دائیں طرف والے) ہیں اور جو شخص ہم اہلِ بیت رسول علیہم السلام سے دشمنی رکتا ہے ،وہ اپنے اعمال کی قید میں ہے۔&&(تفسیر قرطبی جلد ۱۰ ،تفسیر مجمع البیان،نورالثقلین ص۶۸۷۸) }}&&جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: <<احب اللہ من احب حسینًا>>یعنی: خدا اس سے خود محبت کرتا ہے جو حسین علیہ السلام سے محبت کرتا ہے۔&&(ترمذی شریف) {{&&
  74,43,آیت ۴۳ میں ہے کہ ہم نماز گذاروں میں سے نہ تھے:!! }}حضرت امام علی ابنِ ابی طالب علیہ السلام نے فرمایا:  نماز کو بہت زیادہ اہمیت دو ،اس کی پوری حفاظت کرو۔ اس کو کثرت سے ادا کرو ۔ نماز کے ذریعہ خدا کے قریب (یعنی خدا کی رضامندی کے قریب) ہوتے چلے جاو۔ نماز کو اس کے مقررہ اوقات پر ادا کرنا مومنوں پر واجب ہے ۔ کیا تم نے دوزخیوں کا یہ جواب نہیں سنا (جب ان کو جہنم میں داخل کیاجارہا تھا تو ) ان سے جتنی لوگوں نے پوچھا: تمھیں کیا چیز جہنم کی طرف گئی؟انھوں نے جواب دیا کہ :<<لم نک من المصلین>>ہم نماز پڑھنے والوں میں سے نہ تھے۔&&(نہج البلاغہ) &&{{!!جہنمیوں کے کہنے کا مطلب یہ ہے کہ افسوس ہم ان لوگوں میں سے دنیا میں نہ تھے جنہوں نے دنیا کی زندگی میں خدا اور کتابِ خدا کو مان کر خدا ،رسول صلی اللہ علیہ و آلہ وسلم اور خدا کی مخلوق کا حق ادا کیا ۔یاد رہے کہ پانچوں وقت کی نمازیں کوئی شخص اس وقت تک پابندی سے پڑھ ہی نہیں سکتا جب تک وہ واقعاً دل سے خدا ،رسول صلی اللہ علیہ و آلہ وسلم اور آخرت کو نہ مانتا ہو۔اسی لیے نماز کو ایمان کی دلیل اور علامت قرار دیا ،اور نماز نہ پڑھنے کو جہنم میں جانے کی علامت اور دلیل قرارا دیا۔ اور یہ بھی ثابت ہوگیا کہ ظاہری زُبانی ،کلامی ایمان لاکر آدمی جہنم سے نہیں بچ سکتا،جب تک وہ باقاعدگی سے نماز نہ پڑھتا ہو۔&&(تفسیر کبیر ۔ تفہیم)&& !!}}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: (۱) نماز دین کا ستون ہے ،جو شخص اسے چھوڑ دے گا، وہ اپنے دین کو گرانے والا ہے۔(۲) جو شخص جان بوجھ کر نماز چھوڑے گا وہ اسی۸۰ حقب جہنم میں رہے گااور ایک حقب اسی۸۰ سال کا ہوتا ہے۔(۳) حضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا:  (اے مسلمانو!) تم یہودیوں اور نصارٰی پر سلام کرلینا لیکن میری امت کے یہودیوں پر سلام بھی نہ کرنا۔ لوگوں نے پوچھا:  یا رسول اللہ ! آپ صلی اللہ علیہ و آلہ وسلم کی امت کے یہودی کون ہیں ؟فرمایا: جو لوگ اذان اور اقامت سن کر نمازِ جماعت میں شامل نہ ہوں ۔(۴)آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا: جو بے نمازی کی ایک لقمہ کھانے اور ایک گھونٹ پانی سے اعانت کریگا تو گویا،وہ سب انبیاء کا قاتل ہے کہ پہلے ان میں سے حضرت آدم علیہ السلام اور آخری محمّد صلی اللہ علیہ و آلہ وسلم ہیں ۔(۵) آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا:  جو شخص نمازِ پنجگانہ کو وقت پر پڑھے گا تو اس کے لیے پروانہ بروزِ قیامت اور نور،اور دلیل عطا ہوتی ہے ،اور جو حفاظت سے نہ پڑھے ،اس کے لیے نہ ہی نجات نہ نور،نہ برہان اور نہ ہی قیامت کے دن ایمان ہوگا۔(۶) نیز فرمایا:  جو شخص نمازِ صبح پڑھ کر طلوع آفتاب تک تعصیبات میں بیٹھا رہے تو خداوندِعالم فردوس میں اس کو ستر محل سونے یا چاندی کے عطا فرمائے گا۔&&(از حدیث قدسی و چہل حدیث){{&&(۷) نیز }}فرمایا:  نماز مومن کی معراج ہے۔&&(الحدیث)&&{{(۸) نیز }}فرمایا: روزِ قیامت سب سے پہلے نماز کے بارے میں پوچھا جائے گا۔ &&(الحدیث)&&{{(۹) }}اگر نماز قبول ہوگئی تو سارے نیک اعمال قبول ہوں گے،اور اگر نماز رد کردی گئی تو اس کے سوا (سارے اعمال صالح) در کر دئیے جائیں گے۔&&(الحدیث) {{&&
  74,44,آیت ۴۴ : <<وَلَمْ نَکُ نُطْعِمُ الْمِسْکِیْنَ >>اِس سے معلوم ہوا کہ کسی کو بھوکا دیکھ کر قدرت رکھتے ہوئے،کھانا کھلانا ،جہنمیوں کی واضح علامت ہے اور یہی واحد گناہ انسان کو جہنم میں لے جانے کے لیے بہت کافی ہے ۔ کیوں کہ ایسا آدمی ذرہ برابر خدا کا خوف نہیں رکھتا،نہ خدا کے حقوق کا خیال کرتا ہے ،وہ ننگِ انسانیت ہے ،خدا کا انتہائی نا شکرا اور مخلوق پر انتہائی بے رحم اور ظالم ہے ۔&&(مولف)&&
  74,45,آیت نمبر ۴۵: <<وَكُنَّا نَخُوْضُ مَعَ الْخَاۗىِٕضِيْنَ>>مطلب یہ ہے کہ@@ہم دنیا میں بیہودہ ،فضول ،گندی باتوں میں لگے رہتے تھے ،سارا زور انہی غلط کاموں میں صرف کرتے تھے۔@@&&(لغات القرآن نعمانی جلد ۲)&& <<نَخُوْضُ>>یعنی بیہودہ باتوں میں گُھسنا <<۔ اصل <<خَوض <<کے معنی پانی میں گُھسنے کے ہوتے ہیں ۔ مگر بطور استعارہ سب کاموں میں پوری طرح (دلچسپی سے ) گُھسنے کے معنی میں استعمال ہوتاہے۔&&(لغات القرآن نعمانی جلد۲) &&
  74,47,آیت ۴۷: <<حَتّٰی اَتٰنَا الْیَقَیْنُ <<یعنی: مرتے دم تک ہم اسی حق دشمنی پر قائم رہے ۔ حق کے خلاف باتیں بناتے رہے ،اور روز ِ جزا کو جھٹلاتے رہے ،یہاں تک کہ ہمیں موت آگئی۔ اور وہ چیز ہمارے سامنے آگئی جس کے آنے کا ہمیں یقین نہ تھا۔ حالاں کہ اس کا آنا یقینی ہے اور وہ موت ہے اور آخرت کی دوسری زندگی ہے۔ جب موت آتی ہے تو توبہ قبول نہیں ہوتی ۔&&(تفسیر کبیر ۔ تفہیم)&&
  74,48,آیت نمبر۴۸: اِس آیت سے مومنین کے حق میں شفاعت کا ہونا ثابت ہوگیا۔&&(تفسیر کبیر امام رازی ]]&&لیں شفاعت نے مری برھ کے بلائیں کیا کیا۔۔۔۔عَرَقِ شرم سے ڈوبا گنہگار آیا[[۔&&(اقبال)&& !!اس آیت سے یہ واضح طور پر ثابت ہوگیا کہ جو مجرم نہ ہوں گے (یعنی) (۱) نمازیں پابندی وقت کے ساتھ پڑھتے ہوں گے ۔(۲) غریبوں ،مسکینوں کو کھانا کھلایا کرتے ہوں گے (۳) حق کے خلاف بیہودہ باتیں نہ بناتے ہوں گے ۔ (۴)بدلہ کے دن کو حقیقت اور سچ مانتے ہوں گے ان کو شفاعت کرنے والوں کی شفاعت فائدہ پہنچائے گی۔&&(مولف)&& !!شفاعت کے معنی:شفاعت ،شفع کے مادے سے ہے جس کے معنی ایک دوسری چیز سے ملا دینا ہوتے ہیں ۔ مطلب یہ ہوتا ہے کہ جس کی شفاعت کی جارہی ہے اس نے کچھ راستہ تو خود اپنے قدموں سے طئے کیا ،مگر جب سخت نشیب و فراز آئے تو آگے نہ چل سکا،تو اب شفاعت کرنے والے نے ہاتھ تھاما،اور بقیہ راستہ طے کرادیا۔&&(امفردات امام راغت) &&!!شفاعت کا لفظ :<<شفع>>سے بنا ہے پرانے زمانے میں ترازو کے دو پلڑے اگر برابر نہ ہوتے تھے،تو پتھر کا ایک ٹکڑا ہلکے پلڑے کی طرف باندھ دیا کرتے ،تاکہ اس کا وزن بڑھ کر برابر ہوجائے۔ اس پتھر کے ٹکڑے یا پرانے سکُوں کو ،جو پلڑے کے ساتھ باندھے جاتے تھے <<شفع<<کہتے ہیں ۔ اس لیے شفاعت یہ ہے کہ اگر نیکیوں کے پلڑے میں کچھ کمی رہ گئی ہے تو اس کمی کو شفاعت کرنے والے اپنی نیکیاں دے کر پورا کریں گے۔&& (آغا پویاؒ) &&شفاعت کون کرے گا؟}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  جنت کے بارے میں سب سے پہلا شفاعت کرنے والے میں ہوگا۔&&(صحیح مسلم جلد ۲) && ]] {{کی محّمد (صلی اللہ علیہ و آلہ وسلم) سے وفا تو نے تو ہم تیرے ہیں ۔۔۔۔یہ جہاں چیز ہے کیا لوح و قلم تیرے ہیں[[ &&(اقبال)!!(۲) تمام انبیاء کرام علیہم السلام اپنی اپنی امتوں کی شفاعت کریں گے۔ }}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: انبیاء کرام علیہم السلام تمام ان لوگوں کے بارے میں شفاعت کریں گے جو سچے دل سے خدا کی یکتائی کی گواہی دے چکے ہوں گے۔ انبیاء ان کو جہنم سے باہر نکال لیں گے۔&&(مُسند احمد جلد۲)&&{{(۳)!!فرشتے بھی مومنین کی شفاعت کریں گے ۔}}جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: قیامت کے دن ملائکہ ،انبیاء اورشہداء شفاعت کریں گے۔&&(مُسند احمد جلد۲)}}(۴)!!آئمہ اہلِ بیت علیہم السلام  اپنے پیروکاروں کی شفاعت کریں گے۔{{حضرت امیر المومنین علیہ السلام نے فرمایا:  لنا شفاعتہ ،لاھل مودتنا شفاعۃ  (یعنی) ہمارے پاس حق شفاعت ہے بلکہ ہمارے دوستوں کے پاس بھی شفاعت کرنے کا حق ہے۔&&(خصال شیخ صدوق ؒ ۶۲۴) &&{{ !!(۵) علمائے حق اور شہدائے راہِ حق بھی شفاعت کریں گے۔ }}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:<<یشفع یوم القیامۃ الانبیاء ثم العلماء ،ثم الشھدآء>>یعنی: قیامت کے دن سب سے پہلے انبیاء شفاعت کریں گے،پھر علماء اور ان کے بعد شہداء شفاعت کریں گے۔&&(سنن ابنِ ماجہ جلد ۲ ص ۱۴۴۲) }}&&}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  شہید کی شفاعت اس کے خاندان کے ستر افراد تک قبول ہوگی&&(سُنن ابو داود) &&{{یہ تو کم سے کم ہے ،ورنہ {{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ:  شہداء کی شفاعت ستر ہزار افراد تک کے لیے قابلِ قبول ہوگی۔&&(بحارلانوار جلد ۱۰۰){{&&(۶) خود قرآن بھی روزِ قیامت اپنے پڑھنے والوں کی شفاعت کرے گا۔}}حضرت امام علی ابنِ ابی طالب علیہ السلام نے فرمایا: تمہیں معلوم ہونا چاہیے کہ قرآن ایسا شفاعت کرنے والا ہے جس کی شفاعت مقبول اور ایسا کلام کرنے والا ہے ( جس کی ہر بات ) تصدیق شدہ ہے ۔ قیامت کے دن جس کی یہ شفاعت کرے گا،اور جس کے عیوب بتائے گا تو اس کے بارے میں بھی اس کے قول کی تصدیق کی جائے گی&&(نہج البلاغہ ،خطبہ ۱۷۶) && (۱) جن لوگوں نے قرآن کی خدمت کی ہوگی (۲) اس کو سمجھ کر پڑھا ہوگا(۳) اور اس پر عمل کرنے کی کوشش کی ہوگی،قرآن ان کی شفاعت کرے گا۔(۷) جن لوگو نے اسلام میں طویل عمر گذاری ہوگی ،وہ بھی شفاعت کریں گے۔}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  جب انسان نوے سال کا ہوجاتا ہے (جبکہ ایمان کے راستے پر قائم رہا ہوتا ہے) تو خدا وندِ کریم اس کے اگلے پچھلے سارے گناہ معاف کردیتا ہے ،اور اس کے گھر والوں کیلئے اس کی شفاعت بھی قبول کی جائے گی۔&&(مُسند احمد ۔ جلد ۲)&&}}(۸) روزہ دار بھی شفاعت کریں گے:۔ }}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: روزہ دار اور قرآن قیامت کے دن شفاعت کریں گے۔&&(مُسند احمدجلد ۲)&&{{(۹) بعض نیک اعمال بھی شفاعت کریں گے : ۔ مثلاً جن لوگوں نے امانتوں کی حفاظت کی ہوگی ،امانتیں بھی ان کی شفاعت کریں گی۔&&(مناقب ابنِ شہر آشوب جلد ۲)&&(۱۰) آخر میں خداوندِ کریم و رحیم بھی مومنین کی شفاعت فرمائیں گے:۔}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: قیامت کے دن انبیاء علیھم السلام ،فرشتے ،مومنین جب شفاعت کرچکیں گے تو خداوندِ کریم فرمائے گا: اب خود میری شفاعت باقی رہ گئی ہے۔ (چناں چہ خدا بھی کریگا) ]]لیں شفاعت نے مری بڑھ کے بلائیں کیا کیا۔عَرَقِ شرم سے ڈوبا جو گنہگار آیا[[&&(اقبال)&&
  74,51,آیت نمبر ۵۱ : << فَرَّتْ مِنْ قَسْوَرَۃِ <<ایسے حق دشمنوں کو جو حق کے نام سے ڈر کر بِدکتے ہوں،وحشی ،جنگلی گدھا کہنا ،کتنا فصیح ہے ۔ اس لیے کہ جنگلی گدھے ذرا سی آہٹ پر بِدکتے اور بھاگنے لگتے ہیں ۔ اب ایسے گدھے جب شیر کو دیکھ لیں گے تو ان کی بدحواسی کا کیا حال ہوگا؟ اس کا اندازہ اس مذکورہ بالا تشبیہ سے لگایا جاسکتا ہے ۔ مقصد یہ ہے کہ وہ لوگ حق کے نام سے بری طرح متنفر ہیں۔&&(معالم۔ ابنِ کثیر بقول ابنِ عبّاس و زید بن مسلم و عبدالرحمن) &&اہِل عرب بے تحاشا ،بدحواس ہوکر بھاگنے والے کو جنگلی گدھوں سے تشبیہ دیتے ہیں جو شر کی بو سے یا آہٹ سنکر ہی بدحواس ہوکر بھاگ کھڑے ہوتی ہیں۔)&&تفسیر کبیر ۔ تفہیم ۔ مفردات(&&
  74,52,آیت نمبر ۵۲: <<صُحْفًا مُّنَشَّرَۃً >>قریش کا ہر سردار اس قدر متکبر تھا کہ ہر ایک یہ چاہتا تھا کہ خدا ہم میں سے ہر ہر شیخ کے نام الگ الگ خط لکھے کہ میں نے محّمد صلی اللہ علیہ و آلہ وسلم کو اپنا رسول صلی اللہ علیہ و آلہ وسلم بناکر تمھارے پاس بھیجا ہے تم ان کی اطاعت کرو گے۔ اور وہ خط ایسے ہوں کہ ان کو دیکھ کر یقین بھی آجائے کہ وہ خداوندِ عالم ہی کے بھیجے ہوئے خطوط ہیں ۔ دوسری جگہ قرآن نے بتایا کہ مکہ کاایک ایک سردار اس قدر متکبر ہے کہ وہ کہتا ہے کہ:<<وَاِذَا جَاۗءَتْھُمْ اٰيَۃٌ قَالُوْا لَنْ نُّؤْمِنَ حَتّٰي نُؤْتٰى مِثْلَ مَآ اُوْتِيَ رُسُلُ اللہِ>> یعنی:@@ جب ان کے پاس کوئی آیت ،نشانی آتی تو وہ کہتے ہیکہ ہم اس وقت تک محمّد صلی اللہ علیہ و آلہ وسلم کو نہ مانیں گے جب تک کہ وہی چیز جو رسولوں کو دی گئی ہے،ہمیں نہ دی جائے۔@@&&(سورۃ ۶ الانعام آیت ۳۴ پارہ ۸) &&دوسری جگہ ان کا یہ مطالبہ بھی تھا کہ جس کو قرآن نے بیان فرمایا کہ :َ<<وَلَنْ نُّؤْمِنَ لِرُقِيِّكَ حَتّٰى تُنَزِّلَ عَلَيْنَا كِتٰبًا نَّقْرَؤُہٗ>> یعنی: @@اے رسولؐ! آپ صلی اللہ علیہ و آلہ وسلم ہمارے سامنے آسمان پر چڑھیں ،پھر بھی ہم آپ صلی اللہ علیہ و آلہ وسلم کے چڑھنے کو ہرگز نہ مانیں گے جب تک کہ آپ صلی اللہ علیہ و آلہ وسلم ایک تحریری نوشتہ (کتاب) ہم پر نہ نازل کردیں ،جسے ہم پڑھ سکیں ۔&&(سورہ ۱۷ بنی اسرائیل آیت ۹۳ پارہ ۱۵)&&(تفسیر کبیر ۔ تفہیم)&&
  74,53,آیت نمبر ۵۳ : << لَا تَخَافُوْنَ الْاٰخِرَۃَ >>اس آیت میں حق کے منکروں کا اصل عیب بتایا جارہا ہے ۔ پہلے یہ بتایا گیا کہ ان کی ساری باتیں جو وہ حق کے خلاف بنارہے ہیں صرف ایک بہانہ ہے حق نہ ماننے۔ ان کا اصل عیب یہ ہے کہ وہ اتنی چھوٹی عقل والے ہیں کہ اس مادی دنیا کی زندگی سے آگے کسی دوسری زندگی کا تصّور تک نہیں کرسکتے۔ یہی وجہ ہے کہ وہ آخرت کی دوسری زندگی کو نہیں مانتے۔ اسی لیے وہ کسی حق بات کو سننے ،سمجھنے،غوروفکر کرنے تک کو تیار نہیں ہیں ۔ اور یہی وجہ ہے کہ وہ لوگ دنیا کے مال ،دولت ،اولاد،قبیلے،قوّت و طاقت پر اکڑتے ،تکّبر کرتے ہیں ۔&&(تفسیر ماجدی،فصل الخطاب)&&
  74,54,آیت نمبر۵۴:<< کَلَّا << یعنی ہرگز ہرگز نہیں ۔ یعنی حق کے منکروں کی خواہشیں کبھی ہرگز پوری نہ ہوں گی۔ مطلب یہ ہے کہ ان حق دشمنوں کے لایعنی مطالبات کو پورا کرنا {{خداوندِ عالم کا کام نہیں ہے،اس لیے کہ یہ ساری فرمائشیں اور مطالبات صرف حق کو نہ ماننے کے بہانے ہیں ۔ اب کیوں کہ اتمامِ حجت ہوچکی یعنی جو بات پہچاننی اور سمجھانی تھی،وہ پوری پوری طرح پہچانی گئی،جو کچھ نصیحت کی جانی چاہیے تھی ،کی جاچکی۔ اب چاہیں یہ حق کو مانیں ،چاہیں نہ مانیں ۔ اب تو بس جزاء سزا کا مرحلہ ہوگا۔ کیو ں کہ اتمامِ حجت کے بعد جزاء سزا ہی ہوا کرتی ہے۔ احمقانہ مطالبات پورے نہیں کیے جاتے ۔بس ہوچکی نماز مصلّٰی اُٹھائیے&&(فصل الخطاب)&& <<کَلَّا <<یعنی۔ نہیں نہیں ۔ ہرگز نہیں ۔ تمھارے ایسے احمقانہ مطالبات کبھی پورے نہیں کیے جئیں گے۔&&(تفسیر کبیر۔ تفہیم)&&<<کَلَّا>>یعنی۔ ان کی منشاء ہرگز پوری نہیں ہوسکتی،اور خدا ان کی خواہشات کا پابند نہیں ہے جب حقیقت ان کے سامنے کھل چکی ہے تو ان کا انکار کرنا ،اور الگ کتاب مانگنا یہ سب بہانے ہیں ۔&&(تفسیر انوارالنجف)&&
  74,55,آیت ۵۵ : متکلمین نے اس آیت سے انسان کے اختیار کو ثابت کیا ہے ۔&&(تفسیر ماجدی۔ فصل الخطاب)&&
  74,56,آیت نمبر۵۶: حدیث ِقدسی میں }}خداوندِعالم فرماتا ہے : میں ہی اس قابل ہوں کہ میرا بندہ مجھ سے ڈرے (یعنی میرا ناراضگی اور میری سزاوں سے ڈرتا ہے ) اور میرے ساتھ کسی کو شریک نہ کرے۔ پھر جب میرا بندہ مجھ سے ڈرتا ہے (میری عظمت کو جان کر) توپھر میری شان یہ ہے کہ میں اس کے گناہوں کو معاف کرکے اس کو اپنی رحمتوں میں ڈھک لیا کرتاہوں ۔&&(حدیثِ قدسی ،تفسیر صافی){{ &&{{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ خداوندِ کریم حدیثِ قدسی میں ارشاد فرماتا کہ  میں اپنی عزت و جلا ل کی قسم کھاتا ہوں کہ میں اپنے کسی بندے کو نہ دو خوف دوں گا،اور نہ دو امن دوں گا۔ اگر و دنیا میں مجھ سے ڈرے گا،تو اس کو آخرت میں خوف خوف نہ دوں گا۔ (امن ہی امن دونگا) اور اگر دنیا میں مجھ سے بےخوف رہے گا تو آخرت میں خوف دلاوں گا&&(اصول کافی)&& {{نیز }}امام علیہ السلام سے ہی روایت ہے کہ خداوندِ کریم حدیثِ قدسی میں یہ بھی فرماتا ہے: میں اپنی عزّت و جلال کی قسم کھاتا ہوں کہ جن لوگوں نے میری توحید کا دل سے اقرار کرلیا،میں ان کو جہنم کی آگ سے کبھی عذاب نہ دوں گا۔&&(تفسیر صافی بحوالہ التوحید صدوق ؒ) &&!!نتائج و تعلیمات: محققین نے نتیجہ نکالا کہ (۱) نصیحت حاصل کرنا خود آدمی کے اپنے اختیار میں ہے ،مگر یہ کام صرف اس کی اپنی قوت یا مرضی سے نہیں ہوسکتا،جب بندہ نصیحت حاصل کرنا چاہتا ہے ،اور اس کے لیے وہ کوشش بھی کرے توپھر خداوندِ عالم کا فضل و کرم اس کا ہاتھ تھام لیتا ہے۔ پر خدائے کریم کی توفیقات اس کے شامل حال ہوجاتی ہیں۔ پھروہ نصیحت قبول کرکے اپنی اصلاح کرلیتا ہے۔(۲) آخری مطلب یہ نکلا کہ کوئی نیک کام بھی ہم صرف اپنی قوت کے بل پر نہیں کرسکتے۔ صرف بندے کی مرضی کافی نہیں ہوتی۔ ہر کام صرف اسی وقت مکمل ہوتا ہے جب خدا کی مرضی ہماری مرضی کے ساتھ مل جائے۔ !!اگر دنیا میں ہر شخص کو خدا یہ قدرت دے دیتا ہے  کہ وہ جو کچھ کرنا چاہیے کر گذرے ، تو ساری دنیا کا نظام درہم و برہم ہوجاتا۔ کائنات کا نظم اسی لیے چل رہاہے کہ اللہ کی مشیّت (مرضی و ارادہ) ساری مشینوں پر غالب اور حاوی ہے۔ انسان اسی وقت کچھ کرسکتا ہے جب خدا چاہے اور اس کو اجازت دے۔!!یہی معاملہ ہدایت پانے اور گمراہ ہونے کابھی ہے۔ انسان اگر خود ہدایت حاصل کرنا چاہے تو نہیں پاسکتا۔ انسان کو ہدایت اس وقت ملتی ہے جب خدا اُس کی خواہش کو پورا کرنے کی اجازت دیتا ہے(۴)اسی طرح گمراہیوں میں بھی انسان اُسی وقت جاپھنستا ہے جب خدا اسے گمراہیوں میں چھوڑ دیا کرتا ہے مگر خدا کی شان یہ ہے کہ وہ ہر اس شخص کو جو ہدایت پر چلنا چاہتا ہے ،ہدایت پر چلنے کی توفیقات عطافرماتا ہے ،اور جو غلط راستوں پر چلنے پر مُصِر رہتا ہے،پھر خدا بھی اس کو اس کی اپنائی ہوئی گمراہیوں میں چھوڑدیتا ہے۔!!(۵) آخر میں {{خداوندِ عالم کا یہ فرمانا کہ : خدا اس بات کا حقدار ہے کہ اس (کی ناراضگی) سے ڈرا جائے .مطلب یہ ہے کہ اللہ کو اس بات کی کوئی ضرورت نہیں پڑی ہے کہ تم اس کی ناراضگی سے ڈرو۔ مگر انسان کی بندگی کا تقاضا اور فائدہ اسی میں ہے کہ وہ حق کی ناراضگی سے ڈرے۔ اس کی رضامندی حاصل کرنے کی کوشش کرے،اور اس کی مرضی کے خلاف نہ چلے۔&&(تفسیر کبیر۔ تفہیم۔ مجمع البیان۔ تفسیر نمونہ) &&!!}}حضرت امام علی ابنِ ابی طالب علیہ السلام نے اپنے مالک کی بارگاہ میں عرض کی: مالک! میں تیری عبادت ،نہ تو جنت کی لالچ میں کرتا ہوں ،نہ دوزخ کے خوف سے کرتا ہوں ،بلکہ اس لیے کرتا ہوں کہ انت اھل للعبادۃ تو اہل ہے ،یا لائق ہے اس بات کا ،کہ تیری غلامی کی جائے۔یعنی: تجھے غلامی کرنے کا مستحق (اہل) سمجھتا ہوں &&(نہج البلاغہ) && ]]{{ سوداگری نہیں ،یہ عبادت خدا کی ہے۔۔۔۔اے بے خبر! جزاء کی تمنا بھی چھوڑدے[[&&(اقبال)&& مطلب یہ ہے کہ اگر تم خدا کی ناراضگی سے نہ بچو گے تو خدا کا کوئی نقصان نہ کروگے،اللہ کو تمھاری اطاعت کی کوئی ضرورت نہیں ہے ،نہ تمھاری معصیت خدا کا کوئی نقصان کرسکتی ہے۔ تمھیں نصیحت اس وجہ سے کی جارہی ہے کہ اللہ کایہ حق ہے کہ اس کی غلامی یعنی عاجزانہ،غیرمشروط اطاعت کی جائے اور اس کی مرضی کے خلاف نہ چلا جائے۔اور آخر میں {{خداوندِ عالم کا خودکو یہ فرمانا کہ :  وہ اس بات کا اہل ہے کہ معاف کرے ،اپنی غلطیاں مان کر اپنی اصلاح کرلیتا ہے تو خدا اس کو اپنے دامنِ رحمت میں لے لیا کرتا ہے کیوں کہ خدا کو اپنے بندوں سے کوئی دشمنی نہیں ہے ،نہ وہاں جذبہ انتقام کام کررہا ہے ،اس لیے وہ ہر وقت اپنے بندوں کے گناہ معاف کرنے کو تیار ہے۔&&(تفسیر کبیر۔ تفہیم)&&]]{{ہم تو مائل بہ کرم ہیں کوئی سائل ہی نہیں ۔۔۔۔راہ دکھلائیں کسے ؟ رہ رَو منزل ہی نہیں ۔تربیت عام تو ہے جوہری قابل ہی نہیں ۔۔۔۔جس سے تعمیر ہو آدم علیہ السلام کی یہ وہ گِل ہی نہیں [[۔ !!{{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ خداوندِ عالم نے حدیثِ قدسی میں فرمایا: میں اس لائق ہوں کہ مجھ سے ڈرا جائے اور میں اس لائق ہوں کہ اگر میرا بندہ کسی کو میرا شریک نہ قرار دے ،تو میں اس کو جنت میں داخل کردوں ۔&&(تفسیر برہان جلد ۲ ص ۴۵) &&{{{{فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام علی رضا علیہ السلام نے اپنے آبائے طاہرین علیہم السلام کے حوالوں سے روایت فرمایا ہے کہ خدافرماتا ہے <<لاالہ الاالہ حصنی فمن قالھادخل فی حصنی ومن دخل فی حصنی امن من عذابپھر فرمایا:بشرطھاو شروطھا وانامن شروطھا>> یعنی لَآ اِلٰہَ اِلَّا اللہ میرا قلعہ ہے پس جو یہ کہ گا وہ میرے قلعے میں داخل ہوگیا،اور جو میرے قلعے ہوگیا وہ میرے عذاب سے امن میں ہوگا۔ پھر امام علیہ السلام نے فرمایا۔ یہ فرمان شرائط کے ساتھ ہے،اور ان شرائط میں سے ایک میں ہوں یعنی میری امامت کا قائل ہوتو عذابِ خدا سے امان میں رہے گا۔&&(عیون الاخبار الرضا علیہ السلام ) &&یعنی!!: توحید کا یہ تقاضا ہے کہ خدائے بزرگ وبرتر کی اطاعت کی جائے اور خدا کی اطاعت حضورِ اکرم صلی اللہ علیہ و آلہ وسلم کو ماننے کے بعد اور آئمہ اہلِ بیت علیہم السلام کو مانے بغیر نہیں ہوسکتی،اس لیے کہ آئمہ اہلِ بیت علیہم السلام ہی سے رسولِ خدا صلی اللہ علیہ و آلہ وسلم کا علم اور احکامات ٹھیک ٹھیک ہمیں مل سکتے ہیں ۔&&(مولف)&&!!اگرچہ تقویٰ یہاں مفعول کے معنی میں آیا ہے۔ یعنی: خدا اس کا اہل ہے کہ ہم اس کی ناراضگی سے بچیں ۔مگر یہ احتمال بھی ہے کہ تقویٰ فاعل کے معنی میں ہو۔ یعنی خدا اہلِ تقویٰ ہے یعنی : خدا ہر قسم کے ظلم اور غلط کام سے بچتا ہے۔ مگر یہ احتمال بھی ہے کہ تقویٰ فاعل کے معنی میں ہو۔ یعنی خدااہل تقویٰ ہے ۔یعنی :خداہر قسم کے ظلم اور غلط کام سے بچتاہے۔حقیقت میں یہی تقویٰ کا عالیٰ ترین مقام خدا کے لیے ہے۔ تقویٰ سب سے بڑی خوبی ہے اور خدا تمام خوبیوں کا سرچشمہ ہے ۔ اور بندوں میں جو تقویٰ ، (یعنی برائیوں سے بچنا) ہے وہ غیر منتہاہی تقویٰ کی ایک ہلکی سی جھلک ہے۔البتہ خداوندِ عالم کے بار ے میں تقویٰ اسمِ فاعل کی حیثیت سے بہت کم استعمال ہوا ہے ۔&&(تفسیر نمونہ)&& قرآن مجید ہدایت ( کا ذریعہ) ہے متّقین کے لیے۔
