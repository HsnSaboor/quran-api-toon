tafsir[8]{c,v,t}:
  6,111,آیت نمبر۱۱۱:اللہ تعالیٰ ایمان لانے پر مجبور نہیں    کرتا:خداوندِ عالم کے ارشاد کا مطلب یہ ہے کہ ’’ اگر اللہ یہ بات طے کر لیتا کہ جبری طور پر سب کو اللہ کا دین قبول ہوگا تو اپنی قوتِ قاہر ہ سے سب کو جبراً ایمان کے راستے پر لگا دیتا اور لوگ جوق درجق ایمان لے  آتے‘‘۔ &&(جلالین ، تفسیر علی ابن ابراہیم) && مگر یہ بات خدا کی حکمتِ کاملہ اور انسان کے امتیازی جوہر، فاعلِ مختار ہونے کے تقاضوں    کے خلاف ہوتی انسان کی قوتِ فیصلہ ختم ہو جاتی اور کسی کا ایمان اختیاری نہ رہتا، بلکہ اضطراری ہوتا۔حق دشمنی کی انتہا:کیونکہ اللہ کی حکمت کے تقاضوں    کے یہ خلاف بات ہے کہ انسان کو بے اختیار کرکے مجبوراً جِبلـی طور پر حق پرست بنا دیا جائے، اس لیے تمھارایہ توقع کرنا بالکل فضول ہے کہ اللہ براہِ راست اپنی تکوینی مداخلت کے ذریعے سے اُن کو مومن بنادے گا۔&&(تفہیم )&& طلبِ حق نہ ہونے کا انجام:محقـّقین نے نتیجے نکالے کہ (۱) جس شخص میں   طلبِ حق ہی نہ ہو ، وہ کبھی سچ کو قبول نہیں   کرتا، ہمیشہ اُلٹی سیدھی تاویلیں  کرکے بات کو ہوا میں   اُڑانے کی کوشش کرتا ہے۔ دوسرا نتیجہ یہ نکالا کہ معجزے دیکھنے سےکچھ فائدہ نہیں    ہوتا، اگر حق کی تلاش کا جذبہ ہی دل میں   موجود نہ ہو۔ [[ بیان میں   نکتہ ، توحید آتوسکتا ہے،ترے دماغ میں   بُت خانہ ہوتو کیا کیجے،جہاں  میں   بندۂ حق کے مشاہدات ہیں  کیا،تیری نگاہ غلامانہ ہو تو کیا کیجٸیے]](اقبال)امام فخر الدّین رازی کی تحقیق :امام رازی نے لکھا کہ :’’ کوئی ایک معجزہ تو ضروری ہوتا ہے تاکہ لوگ سچّے نبی اور جھوٹے نبی میں   فرق کر سکیں  (جیسے ہمارے نبیؐ کا معجزہ قرّآن آج بھی موجود ہے۔)لیکن اُس معجزے کے بعد پھر اور معجزوں    کی فرمائش کرتے رہنا کہ ایک کے بعد دوسرا، اوردوسرے کے بعد تیسرا، تو یہ سلسلہ کبھی ختم ہی نہ ہوگا ۔&& (تفسیر کبیر) &&انسان کی اصل غلطی:پھر یہ کہ یہ عقل اور اپنے ضمیر سے کام نہ لینے پر اصرار ہے کہ ہم غور نہیں   کریں    گے، بس تماشے دیکھتے رہیں  گے۔ تو نبیؐ کا کام (معاذاللہ) تماشے دکھانا نہیں    ہوتا ۔ یہ کام تو بندر نچانے والوں  کا ہوتا ہے۔(۲)دوسرا نتیجہ:۔  یہ نکالا کہ اصل جہالت طلبِ حق نہ ہونا ہے ۔ خود کو عقلِ کُل سمجھ لینا ہے۔ کسی بھی نئی بات کو قبول نہ کرنا ہے۔ اسی لیے آخر میں   خد ا نے ایسے لوگوں  کو جاہل فرمایا ۔ جاہل وہ نہیں    جو نہیں    جانتا، بلکہ اصل جاہل وہ ہوتا ہے جو جاننا ہی نہیں    چاہتا۔ جو اپنے دل و دماغ اور شعور کے دروازے بند کر لیتا ہے۔ ایسے جاہلوں  کی کمی نہیں ، ایک ڈھونڈو ہزار ملتے ہیں ۔ [[پھرتی ہیں  جہالتیں  نہ معلوم کتنی:کاندھوں    پہ عبائے علم وحکمت ڈالے۔]]
  6,112,آیت نمبر۱۱۲:شیطان کی تعریف:شیطان کے معنی سرکش ، شریر، بدمعاش، خواہ وہ انسان ہو یا جِنّ یا جانور۔&& (لغات القرآن نعمانی جلد۳ص۳۰۵ و تفسیر ابن جریر جلدنمبر ۱ وتفیسر کبیر ازابنِ عباسؒ) && حضرت امام جعفر صادق علیہ السَّلام سے روایت ہے کہ {{ جناب رسولِ خداؐ نے فرمایا: ’’ جس شخص کو اللہ نے اچھّی صفات کا اہل نہیں    پایا وہی جِنّوں    اور انسانوں  کا شیطان ہے }}۔ && (تفسیر صافی ص۱۶۴ بحوالہ کافی)&& حضرت امام محمد باقر علیہ السَّلام سے روایت ہے کہ {{ جناب رسولِ خدا صہ نے فرمایا : ’’ تمام انسان تین قسم کے ہیں  (۱) ایک وہ ہیں  جو قیامت کے دن عرشِ الہٰی کے سائے میں   جگہ پائیں  گے، جس دن سواء عرشِ الہٰی کے اور کوئی سایہ نہ ہوگا۔ (۲) دوسری قسم کے لوگ وہ ہوں    گے جو حساب دیں  گے اور سزا بھُگتیں  گے، اور (٣)تیسری قسم کے لوگ وہ ہیں  کہ جن کی شکل و صورت تو آدمیوں    جیسی ہے مگر سیرت شیطانوں  کی سی ‘‘ (یہ جہنم میں   ہوں   گے) }} &&(الخصال) && انبیاؑء سے انسانوں    یاجنوں  کی دشمنی انسان کے اختیارات کو غلط استعمال کا نتیجہ ہوتی ہے۔ ورنہ انبیاؑء کرام تو بے پناہ محبت کے مستحق ہوتے ہیں ۔ مگر کیونکہ یہ دشمنی تکوینی اعتبار سے اس لیے پیدا ہوتی ہے کہ خدا نے انبیاؑء کو بھیجا ہوتا ہے، اور لوگوں   کو حق دشمنی کی اجازت دے دی ہوتی ہے، اس لیے اس دشمنی کی اجازت دینے کی نسبت خدا کی طرف دی گئی ہے۔ && (فصل الخطاب) && شیاطین کے کام:شیاطینِ جِنّ وانس ایکدوسرے کو (۱) دھوکہ دینے کے لیے (۲) ایمان سےدوررکھنے کے لیے جھوٹی بنائوٹی باتوں  کو دلوں   میں   ڈالتے رہتے ہیں ۔&&(مجمع البیان ، شاہ ولی اللہ) && اور یہ بات بتائی گئ کہ اللہ چاہتاتو وہ ایسا نہ کرسکتے۔ یعنی اگر خدا اپنی قوّتِ قاہرہ سے اُن کو روکنا چاہتا تو اُن کو رُکنا ہی پڑتا۔ مگر جبر کرنا خدا کی مصلحت نہیں    ۔ کیونکہ تخلیق کا اصل مقصد عقل وعمل کا امتحان لینا ہے، جو اختیار ردِیے بغیر ممکن ہی نہیں   ۔ &&(تفسیر تبیان) && مردِ مومن کی قوّت اور شیطانوں  کی کوششیں :آیت کا پیغام یہ ہے کہ ’’  اگر جِنّ اور انسانوں    کے شیاطین متفق ہو کرتمھارے خلاف زور لگا رہے ہیں ، تو بھی گھبرانے کی ضرورت نہیں   ۔ ہر زمانے میں  ایسا ہی ہوتا آیا ہے۔ہوتا آیا ہے کہ اچھّوں    کو بُرا کہتے ہیں “ جب بھی کوئی ہادی،پیغمبر عہ یا مُصلح دُنیا میں   آیا ، تو تمام شیطانی طاقتیں  اُس کے خلاف صفت بستہ ہو گئیں  شکوک و شبہات پیدا کیئے جانے لگے، الزامات تراشےجانے لگے۔ اُن کے سب کاموں   کو فریب یا دھوکہ کہا گیا۔ کیونکہ اُن کی چالیں  جو وہ حق کے خلاف کرتے ہیں  سب اُن ہی کے خلاف پڑتی ہیں ۔ اس لیے اُن کے ہتھیار اور اُن کی چالیں  سِوادھوکے کے کچھ نہیں   ۔&& (تفہیم) && خدا کی مشیّت اور رضا کا فرق:یادرہے کہ چوری ، قتل ، ڈاکہ ، شرک ، کفر ، غرض کوئی جُرم خدا کی مشیّت (اجازت ) کے بغیر نہیں    کیا جاسکتا، اور کوئی مومنِ صالح بھی خدا کی مشیّت کے بغیر مومنِ صالح نہیں    بن سکتا۔ مگر پہلی قسم کے واقعات سے خدا راضی نہیں   ، جبکہ ایمان اورعملِ صالح کو خدا پسند کرتا ہے۔اگرچہ آخر کار کسی خیرعظیم ہی کے لیے خدا کی مشیّت کام کر رہی ہے، مگر اُس خیرعظیم کا ظہور کا راستہ ، نوروظلمت، خیر و شر ، دونوں    کو اپنا اپنا کام کرنے کی اجازت دیدی ہے۔ اور انسان کو شعور اور اختیار بھی عطا کیا ہے۔ مگر اللہ کی رضا اور پسندیدگی صرف اور صرف ’’ خیر‘‘ ہی کے لیے مخصوص ہے اللہ یہی چاہتا ہے کہ اُس کے بندے اپنی آزادی ، اختیار، انتخاب اور عقل سے فائدہ اُٹھا کر خیر کو اختیار کریں   ۔ نہ کہ ’’شر‘‘ کو ۔ یہ اس لیے کہ :مومن کا کام :مومنین کا کام فرشتوں    جیسانہیں   ، جو بغیر کسی مزاحمت کے خدا کی اطاعت کررہے ہیں ۔ مومن کا کام شریروں    ، بدمعاشوں    اور باغیوں    کے مقابلے میں   اللہ کا پسندیدہ آئین غالب کرنے کی جدوجہد کرنا ہے۔ خدا خیر اور شر دونوں    کے لیے کام کرنے والوں    کوآزادی اورموقع دے رہاہے مگرپسند صرف انہی لوگوں      کوکرتاہے جو، خیر کے لیے کام کرتے ہیں ۔ اب جب یہ قانون سمجھ گئے تو پھر یہ تو قّع رکھنا بالکل فضول ہے کہ خدا ان شیاطین جِنّ واِنس کو زبردستی تمھارے راستے سے ہٹا دے گا۔ تمھیں  ان کامقابلہ کرکے ہی ’’ خیر ‘‘ کو پھیلانا ہوگا، اِسی کو ـ’’جہاد ‘‘ کہتے ہیں ۔ &&(تفہیم)&& ]] گریز کشمکشِ زندگی سے مردوں    کی،اگر شکست نہیں    ہے تو اور کیا ہے شکست ]] (اقبالؔ)بیہودہ قول کی تشریح:آج اہل باطل کے جتنے نظریات میں   جتنی تھیوریز قرآنی تعلیمات کے خلاف ہیں ، وہ سب <<’’زُخْرُفَ الْقَوْلِ‘‘>> یعنی دھوکہ دینے کے لیے کوئی نظام ’’ism ‘‘ یہ دعوٰی کرتا ہے کہ ہم روٹی، کپڑے اور مکان کا مسئلہ حل کر دیں  گے۔ جبکہ روس مرحوم کا حشر سب نے دیکھ لیا۔ کوئی کہتا ہے کہ ہم سرمایہ دار بنادیں  گے، تو سرمایہ داری کا انجام بڑی حد تک ظاہر ہو چکا ہے۔مفکرِّ مشرق نے اسی نظام سے تنگ آکر کہا: [[جس کھیت سے دہقاں  کو میسّر نہ ہو روزی ،اُس کھیت کے ہر خوشہ گندم کو جَلا دوغرض]] ، یہ سب جھوٹے نظریات دعویدار ہیں ۔ ان کے سارے وعدے سبز باغ ہیں ، اور دھوکے کی ٹٹیّ کے سوِا کچھ نہیں   ۔&&(ماجدی)&& نتیجہ:محقّقین نے نتیجہ نکالا کہ ’’ ہردَور میں   جِنّوں    اور انسانوں    میں   شیاطین ہوتے رہے ہیں ، جو لوگوں   کو دھوکہ دے کر طرح طرح سے گمراہ کرتے رہتے ہیں ۔&&(تفسیر کبیر)&&
  6,113,آیت نمبر۱۱۳:شیطانوں   کی اصل غرض:شیطانوں   کی بدمعاشیوں    کا بیان اوپر (قبل ازیں ) آچکا۔ اب شیطانوں   کی اصل غرض اور مقصد کوبتایا جارہا ہے۔ ان کا اصل نشانہ عقیدٔہ آخرت ہوتا ہے ۔کیونکہ یہ عقیدہ انسان کو بناسنواردیتا ہے۔ اس لیے شیطانوں    کےفریب سے بچنے کا واحد طریقہ آخرت کو یاد کرتے رہنا ہے۔ قبرستان جاتے رہنا، گذرے ہوئے لوگوں     سے عبرت حاصل کرتے رہنااورخاص طورپرقرآن کوسمجھ کر پڑھتے رہنا بہترین طریقہ ہے آخرت کو یادرکھنے کا ۔ شیطان سب سے پہلے (۱) دلوں    کو اپنی طرف مائل کرتا ہے۔ یعنی اُن خواہشوں    کو بھڑکاتا ہے جو دلوں    میں   کہیں دفن ہوتی ہیں ۔ (۲) پھر وہ غلط باتوں    کو دل کی پسند بنادیتاہے۔&&(ماجدی) && پھر انسان کا حشر یہ ہوتاہے:[[؎جانتا ہوں    ثوابِ طاعت و زُہد،پر طبیعت اِدھر نہیں    آتی]](۳)   پھر عملاً گناہوں    میں   مبتلا کردیا کرتا ہے ۔ گویاآخر میں   بحرِ گناہ میں   ڈوبے ہوئے سر پر ہاتھ مار کر بالکل ہی گناہوں    میں   غرق کردیا کرتا ہے، اور یہی اُس کی کامیابی ہے۔ اور اسی بات کی شیطان نے اللہ تعالیٰ سے مہلت حاصل کی ہے کہ : ’’ میں   قیامت تک تیرے بتائے ہوئے سیدھے راستے پر بیٹھ جائوں    گااورلوگوں   کو ہرچہارطرف سے بہکاتارہوں   گا، اور پھر اکثر لوگ تیری ناشکرگذاری میں   مبتلا ہوں    گے۔
  6,114,آیت نمبر۱۱۴:اہلِ کتاب کی ہٹ دھرمی:اگر چہ بظاہر خطاب جناب رسولِ خدا صہ  سے ہے کہ ’’  آپؐ ہرگز شک کرنے والوں    میں   سے نہ ہو جائیے گا‘‘۔ لیکن یہ خطاب عرب کے محاورے کے عین مطابق ہے کہ عرب بات کسی اور سے کہاکرتے تھے اور سُناناکسی اور کو مقصود ہوتا تھا۔ یہاں     بظاہر خطاب جناب رسولِ خداؐ سے ہے مگر سُنانا اُمّت کو مقصود ہے۔ (اس طرز بیان سے ناگواری بات کو گوارہ بنانا مقصودہوتا ہے۔)&&(تفسیر صافی ص۱۶۲) && محقّقین نے نتیجہ نکالا کہ ’’ قرآن میں   تخاطب ہمیشہ رسولِ اکر مؐ سے نہیں    ہوا کرتا۔ خدا کبھی اُمّت سےاور کبھی مشرکوں    ، کافروں    ،ملحدوں   ، منافقوں    تک سے خطاب فرماتا ہے۔ یہ بات قرآنِ مجید میں   باربار بتلائی گئی ہے کہ پچھلی کتابوں    میں   حضور اکرمؐ کی علامات اتنی واضح بیان کی گئی ہیں  کہ اہلِ کتاب حضور اکرمؐ کو بھی خوب اچھی طرح پہچانتے تھے، اور قرآن کی حقّانیت کو بھی جانتے تھے، مگر جان بوجھ کر نہیں    مانتے ۔ اسی جان بوجھ کر نہ ماننے کو<< ’’ کفرِ جحودی‘‘>> کہتے ہیں ۔&&(الخطاب)&& ظاہر ہے کہ یہ بات جاننے والے اُن کے علماء تھے۔ عوام تو ویسے بھی کچھ نہیں    جانتے۔&&(تفسیر البیان)&& آیت کا مفہوم اور پیغام یہ ہے کہ : ’’ اے رسولؐ ! آپ صہ یہ فرمادیں  کہ جب اللہ نے اپنی کتاب میں  صاف صاف تمام حقیقتیں  بیان فرما دیں  اور یہ قطعی فیصلہ بھی سُنا دیا کہ مافوق الفطری مداخلت کے بغیر حق پرستون کو فطری طریقوں    ہی سے حق کے غلبے کے لیے جدوجہد کرنی پڑے گی، تو کیا اب بھی اللہ کے سِوا کوئی اور صاحبِ حکومت تلاش کروں    جو اللہ کے اس فیصلے پر نظرِ ثانی کرکے، اور ایسا کوئی معجزہ بھیجے جس کی وجہ سے کافر ایمان لانے پر مجبور ہو جائیں قرآنی تعلیم کو ئی نئی تعلیم نہیں   ؟:دوسری بات آیت میں  یہ سمجھائی گئی کہ قرآن کے پیغامات اور تعلیمات کوئی نئی باتیں  نہیں    ہیں ۔ تمام وہ لوگ جوآسمانی کتابوں    کا علم رکھتے ہیں ، اس بات کی گواہی دیں  گے کہ جو کچھ بھی قرآن میں   بیان کیا گیا ہے وہ ازلی اور ابدی حقیقتیں  ہیں  جن میں  کبھی سرمو کوئی فرق نہ آیا ہے، نہ آئیگا۔&&(تفہیم)&& پرانی کتابوں    میں   رسولِ اکرمؐ کا ذکر:یاد رہے کہ اہل کتاب کے علما حق کو خوب اچھی طرح سے جانتے تھے اور آخری نبیؐ کو خوب پہنچانتے تھے۔&& (قرطبی روح)&& کیونکہ ان کی کتابوں   میں   سب کچھ لکھا تھا۔ مثلاً ’’ اوستا‘‘ میں   زرتشت (جسے بہت لوگ نبی مانتے ہیں  اور ہمارے رسولؐ سے بہت پہلے ایران میں   گذرے ہیں ) فرماتے ہیں :’’ میں   نے دین کو مکمل نہیں  کیا ۔ میرے بعد ایک اور نبیؐ آئے گا جو اس کی تکمیل کرے گا۔ اُس کا نام عالمین کی رحمت ہوگا۔‘‘ یعنی ساری کائنات کے لیے رحمت ہو گا۔&&(اوستا)&& ہندئوں    کی کتاب جسے شاید قرآن نے ’’ زُبُر الاوّلین‘‘ یعنی ’’پُرانی کتابیں ‘‘ کہا ہے۔ اور عجیب بات یہ ہے کہ اُن کی کتاب کا نام ’’ پران‘‘ (پرانی) ہے۔ اور یہ دس ’’پران‘‘ ہیں ۔ ان میں   ایک پران میں   لکھا ہے ’’ آخری زمانے میں   ایک شخص ریگستان کے علاقے میں   پیدا ہوگا ۔ اُس کی ماں  کا نام قابلِ اعتماد‘‘ (آمنہ) اور باپ کا نام ’’ اللہ کا غلام‘‘ (عبداللہ) ہو گا۔ وہ اپنے وطن سے شمال کی طرف جاکربسنے پر مجبور ہوگا۔ اور پھر وہ اپنے وطن کو دس ہزار آدمیوں  کی مدد سے فتح کریں    گا۔ جنگ میں   اس کارتھ اونٹ کھینچیں  گے اور وہ اونٹ اس قدر تیز رفتار ہوں   گے کہ آسمان تک پہنچ جائیں  گے۔ ‘‘ (غالباً یہ معراج کی طرف اشارہ ہے)۔&&(پران)&& کہ قرآن نے سچ کہا تھا کہ:  <<  ’’ وَاِنَّہ‘ لَفِیْ زُبُرِ الْاَوَّلِیْنَ‘‘>> && (سورہ  نمبر ۲۶ الشعراء آیت نمبر ۱۹۶) && اور بلاشبہ وہی پُرانے لوگوں کی  کتابوں  میں  بھی موجود ہے۔
  6,115,آیت نمبر۱۱۵:<< تَمَّتْ کَلِمَتُ رَبِّکَ صِدْقًا وَّعَدْلاً>> :حضرت امام جعفر صادق علیہ السَّلام سے روایت ہے کہ {{جناب رسولِ خدا صہ  نے فرمایا : ’’ امام ماں  کے پیٹ میں  لوگوں   سے باتیں  کرتا ہے اور لوگوں  کی باتیں  سُنتا ہے۔ اور امامؑ جس وقت پیدا ہوتا ہے تو اُس کے دونوں    شانوں    کے درمیان (دوسری روایت کے مطابق داہنے بازو پر بھی) یہی آیت لکھی ہوتی ہے ۔ پھر جب امامت اُس کے سُپر د کی جاتی ہے تو خدااُس کے لیے نورکا ایک ستون قائم کردیتا ہے جس کے ذریعے سے وہ اپنی رعایا کے سارے اعمال دیکھتاہے۔}} &&(تفسیر صافی ص۱۶۲ بحوالہ کافی)&& نتیجہ نمبر ۱:   محقّقین نے نتیجے نکالے (۱) کسی میں   یہ طاقت نہیں    کی خدا کے کلام میں  کاٹ چھانٹ یا کسی قسم کی کوئی تبدیلی کر سکے۔&& (تفسیر کبیر۔ قرطبی)&& نتیجہ نمبر ۲:   امام رازی نے دوسرا نتیجہ یہ نکالاکہ ’’ قرآن کے دلائل اتنے مضبوط ہیں  کہ منکروں    کے شکوک و شبہات ان میں   کوئی رخنہ پیدا نہیں    کرسکتے۔&&(تفسیر کبیر)&& نتیجہ نمبر ۳:  تیسرا نتیجہ یہ نکالا کہ قرآن <<’’ صدق‘‘>> ہےاس لیے کہ قرآن میں   جتنے پُرانے واقعات بیان کیے گئے وہ ہمیشہ تحقیقات سے سچ ثابت ہوتے جائیں  گے اورقرآن << ’’ عدل‘‘>> ہے اس لیے قرآنی تعلیمات افراط و تفریط سے پاک ہیں  یعنی متوازن ہیں ۔&&(روح المعانی)&& نتیجہ نمبر ۴:چوتھا نتیجہ یہ نکالا کہ ’’ تصریحاتِ قرآنی کی طرح دلالاتِ قرآنی بھی واجب الاتّباع ہیں ۔ &&(قرطبی)&&
  6,116,آیت نمبر۱۱۶:اکثریّت کا طرز عمل گمراہی ہے:محقّقین نے آیت سےنتیجہ نکالا کہ ’’ اکثریت کا کسی بات کو مان لینا حق کا معیار نہیں    ہوتا۔ کیونکہ اکثریت عام طور پر جاہل عوام کی ہوتی ہے۔ اور عوام کالا نعام ۔ عوام بھیڑ چال چلتے ہیں  ۔عوام اکثر توہمّات اور بے بنیاد عقیدوں    کی پیروی کیا کرتے ہیں ‘‘۔ &&(مجمع البیان)&& کیونکہ اکثرلوگ علم کے بجائے قیاس اور گمان کی پیروی کیاکرتے ہیں ، اُن کے سارے فلسفے انداز و قوانین سب قیاس آرائیوں    پر مبنی ہوتے ہیں ۔ اس کے بر خلاف اللہ کا راستہ، یعنی زندگی بسر کرنے کا وہ طریقہ جو اللہ کی رضا مندی کے مطابق ہو، اس حقیقی علم کے مطابق ہوتا ہے جو علم خود خدا نے ہمیں   عطا فرمایا ہے ۔ اس لیے طالبِ حق کو یہ کبھی نہ دیکھنا چاہیے کہ دُنیا کے اکثر لوگ کس راستے پر چل رہے بلکہ اس کو اللہ کے بتائے ہوئے راستے پر چلنا چاہیے۔ چاہے اس راستے پر چلنے کے لیے وہ پوری دُنیا میں   اکیلا ہی کیوں    نہ رہ جائے۔&&(تفہیم ۔ مولانا مودودی) && ڈاکٹر اقبالؔ نے  کہا:۔[[عقلِ بے مایہ امامت کی سزاوار نہیں   ـ: راہبر ہوں    ظن وتخمیں  تو زبوں  کارِ حیات:جمہوریت اِک طرزِ حکومت ہے کہ جس میں  ،بندوں    کو گِنا کرتے ہیں ، تولا نہیں    کرتے:گُریز ازطرزِ جمہوری ‘ غلام پُختہ کارے شو:کہ ازفکرِ دو صد خر، فکرِانسانی نمی آید ]](اقبالؔ)(یعنی ، دو سو گدھے ملکر بھی ایک انسا ن کی فکر نہیں    پیدا کرسکتے) اِسی طرح کروڑوں    انسان ملکر خدا کے لامحدود علم کے مقابلے پر قانون نہیں    لا سکتے۔اِسی لیے اہلِ حق اور عُرفا ء کے نزدیک ایک حقیقی امامؑ وہی ہوگا جسے خدا امام مقرّر فرمائے ، لوگوں    کے ووٹوں  سے لیڈر بن سکتے ہیں  ، امام اور ہادی نہیں    بن سکتے۔ لیڈر لوگوں  کی رضا مند ی اُن کی نبض دیکھ کر پہچان لیتا ہے، اور اِسی بات کو زور زور سے کہتا ہے۔ اس طرح لیڈر بن جاتا ہے مگر امام تو ہادی ہوتا ہے۔ وہ خدا کی مرضی کا ترجمان ہوتا ہے، اس لیے وہ اکثر لوگوں      کی خواہشات کے خلاف ہدایت دیتا ہے۔ اسی لیے ہادی کو اکثریت قبول نہیں  کرتی، لیڈروں  کو اکثریّت قبول کرتی ہے ۔ کیونکہ وہ اُن کا چُناہوا ہوتا ہے تو اُن کے دل کی آواز ہوتا ہے۔ اور امام ’’ہادی‘‘ خدا کا چُناہوا ہوتا ہے تو وہ خدا کی مرضی سے بولتا ہے اور اُس کی آواز ہوتا ہے۔آیتِ مجیدہ صاف نشاندھی کر رہی ہے کہ لوگوں    کا سوادِ اعظم عموماً گمراہی پر ہوا کرتا ہے اور تھوڑے ہی لوگ حق پر ہوا کرتے ہیں ۔ اسی بناء پر ارشاد فرمایا کہ ’’ اگر آپؐ اکثریّت کے پیچھے جائیں  گے تو وہ آپؐ کو راہِ راست سے بھٹکا دیں  گے۔ یعنی قلّت یا کثرت صداقت کا معیار نہیں    ہے۔ حق والوں   کو اپنی قلّت سے گھبرانا نہیں   چاہیےاور باطل پرستوں  کو اپنی کثرت پر اِترانا نہیں    چاہیے۔&&(تفسیر انوار النجف جلد نمبر ۵ص۲۴۹)&& جناب امیر المومنینؑ نے پیغمبر اکرمؐ کی حدیث :<< اَنْتَ مِنِّیْ بِمَنْزِ لَۃِ ھَارُونَ مِنَّ مُوْ سٰی عی “>>  یعنی  (اے علیؑ ! تم کو مجھ سے وہی نسبت و منزل ت ہے جو ہارون عہ کو موسٰی سے تھی کے بارے میں   فرمایا :<< کما ھارون من موسیٰ اخوہ:کَذٰلک اَنَا اَخُوہ و ذٰک اسمِیٖ:لذٰلک اقامنی لھم امامًا:واخبر ھم بہ بغدیر خُمِ >> یعنی: جس طرح ہارون عہ موسٰی کے بھائی تھے، اِسی طرح میں   آنحضرتؐ کا بھائی ہوں    اور یہی میرا نام ہے اِسی لیے آنحضرتؐ نے مجھ کو لوگوں   کا امام بنایا، اور اس بات کی آپؐ نے لوگوں      کو غدیر خُم میں   خبر دی ہے۔
  6,117,آیت نمبر۱۱۷:خدا کا علم:؎۱خدا سے بہتر جاننے والا کون ہو سکتا ہے‘ اِس لیے کہ خدا نہ صرف ظاہر باتوں  کو جانتا ہے، بلکہ دل کے ارادوں    کو بھی جانتا ہے۔ حال کو بھی جانتا ہے مستقبل کو بھی جانتا ہے۔ جبکہ لوگ صرف ظاہری اعمال کو دیکھ سکتے ہیں ۔ &&(تفسیر تبیان)&& حضرت امام جعفر صادق علیہ السَّلام نے فرمایا: {{’’ اگر انسان اتنی بات سمجھ لے کہ وہ جو کچھ بو ل رہا  ہے اور جو کچھ کر رہا ہے اُس کو ایک دن بہت بڑے مجمع میں   سُنا یا جائے گا تو وہ اپنی اصلاح کرلے گا‘‘}}۔ &&(الحدیث)&&
  6,118,آیت نمبر۱۱۸:ذبیحہ پر اللہ کا نام لینا ضروری ہے۔؎۲’’جس پر اللہ کا نام لیا گیا ہو‘‘ اس سے مراد وہ ذبیحہ ہے جس پر ذبح کرتے وقت اللہ کا نام لیا گیا ہو۔&& (مجمع البیان) && آیت میں   اس بات کی اجازت دی گئی ہے کہ ہر حلال چیز کھائو اور جن چیزوں  کو مشرکین نے ازخود خواہ مخواہ حرام کر رکھا ہے، اُن سے پرہیز نہ کرو۔ اُن کی لگائی ہوئی پابندیاں  غلط ہیں ۔ اگر ذبح کرتے وقت حلال جانور پر اللہ کا نام لے لیا گیا ہے تو پھر اُس کو کھائو۔ اُس سے بچنے کی کوئی ضرورت نہیں   ۔&&(فصل الخطاب) &&آیت کا پیغام یہ ہے کہ اگر تم اللہ کو اپنا حکمراں  مان چکے ہوتو اُن تمام اوہام اور من گھڑت خیالات اور پابندیوں  کو توڑڈالو جو خدا نے نہیں    لگائیں ، بلکہ لوگوں  کو پابندیوں    میں   جکڑدیا ہے ۔ حلال اور حرام صرف خدا کی طرف سے ہے ۔&&(تفہیم)&&
