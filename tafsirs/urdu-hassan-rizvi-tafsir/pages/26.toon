  26,1,آیت نمبر۱:{{فرزندِ رسول خداؐ حضرت امام جعفر صادق علیہ السلام سے منقول ہے کہ جمیع مقطعات اللہ تعالیٰ کے اسم اعظم پر مشتمل ہیں جس کو نبیؐ یاامامؑ ہی ترتیب دے سکتے ہیں ۔  اور اسی کے ذریعہ سے اُن کی دعائیں مستجاب ہوتی ہیں ۔ &&(تفسیر برہان، تفسیر انوارالنجف)&&}}{{فرزندِ رسول خداؐ حضرت امام محمد باقر علیہ السلام سے منقول ہے کہ:’’ میرے پاس حروف مقطعات قرآنیہ کاایک بہت بڑا ذخیرہ موجود ہے۔ &&(تفسیر صافی بحوالہ عیاشی، انوارالنجف)&&}}!!حروفِ مقطعات کی تفسیر اپنی رائے سے کرنا قطعی حرام ہے۔ اگرچہ فریقین کے علماٰء نے ان کی توجیہات کی ہیں ۔ &&(حاشیہ قرانی الحکم مولنا فرمان علی)&& تفسیر کبیر میں ہے کہ عرفا کرام نے لکھا کہ:’’ط‘‘ سے مراد عرفاء کے دلوں کا’’طرب‘‘’’سین‘‘سے مراد’’سرور محتیں ‘‘ یعنی خدا سے محبت کرنے والوں کے لطف وسرور کی کیفیت مراد ہے  اور ’’میم‘‘سے مومنین  اور مریدین (جو خدا کی محبت کاارادہ کرتے ہیں ) اُن کی مناجاتیں ۔&&(تفسیر کبیر امام رازی)&&
  26,2,آیت نمبر۲:اس آیت میں قرآن مجید کو <<’’مبین‘‘ >> فرمایا گیا ہے۔<<’’مبین‘‘>> کالفظ بیان کے مادے سے نکلا ہے۔ جس کے معنی روشن ہونے کے ہوتے ہیں ۔ مطلب ہے کہ:قرآن کے مضامین بالکل واضح ، روشن  اور آسانی سے سمجھ میں آجانے والے ہیں ۔ پھرجتنا انسان ، قرآن پر غوروفکر کرتا چلا جاتا ہے اُتنے ہی قرآن کے مطالب کھلتے چلے جاتے ہیں ۔ قرآن مجید کو اس لیے بھی مبین فرمایا کہ قرآن مجید بالکل واضح طور پر حق وباطل ، کامیابی  اور ناکامیابی، سعادت  اور شقاوت کو بیان کردیتا ہے۔ نجات کے راستے کو گمراہی کے راستے سے واضح طور پر الگ کرکے روشن کردیتا ہے۔&&(تفسیر نمونہ)&&خداوندِ عالم نے قرآن مجید کو>>’’کتاب مبین‘‘<< اس لیے فرمایا ہے کہ اس کی آیات اپنا مقصد بالکل صاف صاف بیان فرماتی ہیں ۔ ہر شخص قرآن مجید کو پڑھ کر یہ سمجھ سکتا ہے کہ قرآن ہم کو کس طرح بلا رہا ہے ؟ اور کس چیز سے روک رہا ہے۔ اس لیے جو شخص سمجھ کر پڑھ رہا ہے، وہ ہرگز یہ نہیں کہہ سکتا کہ میری سمجھ میں کچھ نہیں آتا کہ یہ کتاب کیا کہہ رہی ہے۔ غرض قرآن کی زبان، بیان، حقائق، دقائق، مضامین بالکل واضح ہیں ۔ &&(تفہیم القرآن )&&البتہ قرآن مجید کی متشابہ آیات کے بارے میں خود قرآن نے یہ فرمادیا کہ :’’اُن کاعلم صرف اُن لوگوں کے پاس ہے جو علم میں راسخ ہیں ۔‘‘ جیسا کہ سورہ واقعہ میں فرمایا:<<’’لایمسہٗ الا المطھرون‘‘>> (قرآن کی حقیقت کو مس نہیں کرسکتے مگر پاک لوگ) ‘‘  اور ’’مطھرون‘‘پاک لوگ، وہی ہیں جن کی پاکیزگی کی گواہی خود قرآن نے آیہ <<’’تطھیر‘‘>>کے ذریعہ دی ہے کہ’’حقیقتاً اللہ نے یہ ارادہ کرلیا ہے کہ اے اہل بیتؑ تم کو ہر قسم کی نجاست سے پاک رکھے جیسا کہ پاکیزگی کاحق ہے۔‘‘&&(القرآن آیہ تطہیر)&&
  26,3,آیت نمبر۳:آنحضرت صلی اللہ علیہ و آلہ وسلم کو تسلی دی جارہی ہے:قرآن مجید کی عظمت کو سمجھانے کے بعد اب رسولِ خداؐ کو تسلی دی جارہی ہے ۔ اس لیے کہ دنیا پرست کفار ، قرآن مجید کی عظمت کو کسی طرح ماننے کو تیار نہ تھے۔ کیوں کہ اگر وہ قرآن مجید کی عظمت کو مان لیتے تو اُن کے تمام غلط مہمل عقیدوں پر پانی پھر جاتا۔ اس سے حضور اکرمؐ کوسخت کوفت ہوتی تھی کہ اتنے عظیم  اور واضح دلائل کو یہ احمق سننے کو بھی تیار نہیں ہیں ۔ اس لیے اب رسول خداؐ کو تسلی دی جارہی ہے ، کہ آپؐ ان کے ایمان نہ لانے پر غم نہ کھائیں  اور اپنی جان نہ گنوائیں ۔ وہ لوگ ایمان نہیں لاتے تو نہ لائیں ۔اس سے آپؐ پر یا قرآن مجید کی عظمت پر ذرہ برابر فرق نہیں پڑتا۔ اگر کوئی شخص دن کو دن نہ مانے تو اُس سے دن کی روشنی میں کوئی کمی نہیں ہوسکتی۔ (سورج چمکتا رہے گا اور دن روشن رہے گا) &&(تفسیرنمونہ)&&<<’’باخع‘‘>>کالفظ<<’’بخع‘‘>>کے مادے سے ہے۔ جس کے معنی ہیں ’’شدتِ غم سے اپنے آپ کو مارڈالنا۔ &&(مفردات القرآن امام راغب)&&نتیجہ:اس آیت سے یہ نتیجہ نکلتا ہے کہ جناب رسولِ خداؐ کو انسانیت سے کتنی شدید محبت تھی کہ اُن کی تباہی پر اس قدر افسوس فرماتے تھے۔ &&(تفسیر نمونہ)&&[[خدا کے بندے تو ہیں ہزاروں بنوں میں پھرتے ہیں مارے مارے میں اُس کابندہ بنوں گا جس کو خدا کے بندوں سے پیار ہوگا]]&&(اقبال)&&
  26,4,آیت نمبر۴:مطلب یہ ہے کہ خدا وندعالم کے لیے یہ کوئی مشکل کام نہیں ہے کہ وہ کوئی ایسی نشانی اُتار دے کہ تمام کفار ایمان لے آئیں ۔ مگر خدا کو اس قسم کاجبری ایمان قبول نہیں ہے۔ خدا تو یہ چاہتا ہے کہ لوگ اپنی عقل سے کام لے کر، خدا کی نشانیوں پر غور وفکرکرکے کے حق کو پہچانیں  اور باطل کو اپنے اختیار سے چھوڑیں ۔ کیوں کہ خدا کامقصد ہماری عقل  اور اختیار کاامتحان لینا ہے۔ جیسا کہ ’’سورۃ الملک ‘‘میں فرمایا۔<<’’الَّذِيْ خَلَقَ الْمَوْتَ وَالْحَيٰوۃَ لِيَبْلُوَكُمْ اَيُّكُمْ اَحْسَنُ عَمَلًا۰ وَہُوَالْعَزِيْزُ الْغَفُوْرُ‘‘>>&&(سورۃ الملک آیت۲)&& یعنی :وہ خدا جس نے موت  اور زندگی کو پیداکیا، تاکہ تمہارا امتحان لے کہ تم میں کون بہترین عمل کرنے والا ہے۔‘‘{{حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ:’’جب ہمارے قائم (امام مھدیؑ) ظاہر ہوں گے تو بنی اُمیہ (مراد تمام ظالمین) کی گردنیں (ان کے سامنے) جھُک جائیں گی ۔ کیوں کہ آسمان سے ایک سخت گرجدار آواز آئے گی جو امام مھدیؑ کا نام لے کر پکارے گی،  اور سب کے سب (اپنی اپنی زبانوں میں ) اُس آواز کو سنیں گے۔‘‘&&(تفسیر صافی ص ۳۶۶, اصول کافی، تفسیر قمی)&&}}{{حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ:’’ عنقریب خداوندعالم بنی اُمیہ  اور اُن کے ماننے والوں کی گردنیں جھُکادے گا۔‘‘ کسی نے امامؑ سے دریافت کیا کہ’’ظہورامام مھدیؑ کی نشانی کیا ہوگی؟‘‘امام علیہ السلام نے فرمایا:’’سورج وقتِ زوال سے لے کر وقت عصر تک اپنی جگہ رُکا رہے گا، پھر سورج کے اندر سے ایک چہرہ  اور سینہ دکھائی دے گا۔ جو امام مھدیؑ کانام نسب کے ساتھ لیکر اُن کی پہچان کرائے گا۔‘‘ &&(الارشاد۔شیخ مفیدؒ)&&}}نتیجہ:صوفیاء کرام نے اس آیت سے نیتجہ نکالا کہ:’’تصّرفِ باطنی میں بھی جبر اور زبردستی کی شان ہوتی ہے ، اس لیے کہ مشائخ محققین ، سلوک وارشاد میں تصرف باطنی کو پسند نہیں کرتے۔‘‘&&(مرشد تھانوی)&&تکذیب کے درجات:خدا کی نشانیوں کامذاق اُڑانا تکذیب کاآخری درجہ ہے تکذیب کاپہلادرجہ :اعتراض‘‘ ہے (۲) دوسرادرجہ ’’انکار‘‘ اور اُن کو جھوٹا سمجھنا ہے۔ (۳) تیسرا’’درجہ‘‘ <<استہزا>> ‘‘ ہے یعنی خدا کی آیتوں ، پیغمبروںؐ  اور اماموں کامذاق اُڑانا۔یہ تذلیل کاپہلو ہے یہاں اس آیت میں تینوں درجے بیان کیے گئے ہیں ۔ &&(تفسیر کبیر امام رازی)&&!!محققین نے نتیجہ نکالا کہ موت کے وقت مذاق اڑانے والے جہنم کی آگ کواپنے سامنے بھڑکتا، دہکتا، چنگھاڑتا دیکھتے ہیں ۔ &&(الامان۔ الحفیظ)&&&&(تفسیر ماجدی)&&{{امیر المومنین حضرت امام علی ابن ابی طالبؑ علیہ السلام نے ارشاد فرمایا:’’انبیاءؑ کو بھیجتے وقت اگر خدا وند عالم چاہتا تو خزانوں ،  اور سونے کی کانوں کے منہ کھول دیتا، سرسبز وشاداب باغات انبیاءؑ کرام کے ساتھ ساتھ چلتے ۔۔۔لیکن اس طرح امتحان  اور آزمائش بالکل ختم ہوجاتی ،  اور سزاوجزاء کاتصور قطعاً باطل ہوجاتا۔ &&(نہج البلاغۃ خطبہ قاطعہ)&& }}حاصلِ مطلب:یہ ہے کہ خدا فرمارہا ہے کہ@@’’ہم اتنی قدرت رکھتے ہیں کہ اُن پر ایسا معجزہ اتاردیں کہ اُن کی آنکھیں خیرہ ہوجائیں ۔ یہ سٹ پٹا کر سر تسلیم خم کردیں مگر ہمیں ایسا ایمان منظور ہی نہیں ہے۔ @@&&(تفسیر نمونہ)&&
  26,5,آیت نمبر۵:قرآن مجید کو<<’’ذکر‘‘>> اس لیے فرمایا گیا ہے کہ قرآن کی ہر آیت بیدار کردینے والی، چونکا دینے والی، آگاہ کردینے والی  اور نصیحت کرنے والی ہوتی ہے ۔ بشرطیکہ اُس کو سمجھ کر پڑھاجائے۔  اور خدا وندعالم نے قرآن مجید کو رحمٰن کی طرف سے آنے والا اس لیے فرمایا ہے کہ قرآن کی ہرہرآیت خدا کی عام رحمت ہے ۔ کیوں کہ قرآن کی ہرآیت تمام عالمِ انسانیت کو سعادت  اور کامیابی کی دعوت دیتی ہے۔ سب کے فائدے بناتی ہے۔ &&(تفسیر نمونہ)&&جیسے:دریا، سمندر، سورج وغیرہ سب کے لیے ہیں ، مگر اب کوئی اُن سے فائدہ حاصل ہی نہ کرے، تو اس سے اُن کے رحمت ہونے پر کوئی فرق نہیں پڑتا۔&&(مولف)&&قرآن مجید کو>>’’محدث‘‘<< یعنی ‘‘تروتازہ‘‘اس لیے فرمایا گیا ہے کہ ہر آیت ایک نیا مضمون ہدایتی پیرایہ بیان لیے ہوئے ہوتی ہے بُرا ہو کافروں کے تعصب  اور تنگ نظری کاکہ وہ اس پر غور ہ نہیں کرتے، اس لیے ہٹ دھرمی سے اپنی جہالت  اور گمراہی پر ڈٹے رہتے ہیں ۔اسی لیے سورہ مومنون میں فرمایا:@@آیا وہ اس بات پر غور کیوں نہیں کرتے یا کیا اُن کے پاس کوئی ایسی بات آئی ہے جو اُں سے پہلے اُن کے بزرگوں کے پا س نہیں آتی تھی۔‘‘@@ &&(سورۃ المومنون آیت پ۱۸)&&مگر وہ احمق ہر نئی بات سن کر فقط منہ ہی نہیں پھیر لیتے، بلکہ اُن کی تکذیب بھی کرتے ہیں  اور مذاق بھی اُڑاتے ہیں ۔&&(تفسیر نمونہ)&&
  26,6,آیت نمبر۶کی تشریح: مطلب یہ ہے کہ خدا کے عذاب کامذاق اُڑانے والے اسی عذاب کومجسم طور پر اپنی دونوں آنکھوں کے سامنے دہکتا،بھڑکتا، گرجتا دیکھ رہے ہوں گے۔ &&(فصل الخطاب)&&<<’’انبائَ‘‘نبا‘‘>> کی جمع ہے جس کے معنی اہم خبر کے ہوتے ہیں ۔ مگر یہاں ایسی سخت سزا بھی مراد ہے جو اُنہیں دنیا میں بھی ملے گی  اور آخرت میں بھی۔&&(تفسیر نمونہ)&&مگر شیخ طوسیؒ نے اس کو صرف آخرت کی سزا قرار دیا ہے۔ &&(تفسیر تبیان)&&لیکن زیادہ ترمفسرین اس کو مطلق سزا سمجھتے ہیں خواہ وہ دنیا میں ہو یاآخرت کی۔ &&(تفسیر کبیرامام رازی)&&
  26,7,آیت ۷ کی تشریح:<<’’زوج کریم‘‘>> یعنی زمین پرہم نے انسانوں کے فائدے کے لیے ہر جنس کاجوڑا جوڑا اُگایا ہے ۔کریم سے مراد قابل قدر  اور قابل شکر۔&&(تفسیر انوارالنجف)&& <<’’کریم‘‘>> کے معنی قیمتی چیز کے ہوتے ہیں  اور <<’’کریم‘‘>> سے یہاں مراد نباتات کامفید ہونا ہے۔ &&(مولف)&& <<’’زوج‘‘>> کے معنی صنف  اور جوڑے۔ &&(نمونہ)&&
  26,8,آیت نمبر۸:خداوندِعالم کی قدرت وحکمت کی یہ زبردست دلیل ہے کہ بے شمار قسم قسم کی چیزیں زمین سے اُگی چلی جارہتی ہیں جو ہماری ان گنت ضرورتوں کو پورا کررہی ہیں ۔ یعنی ان چیزوں  اور ہماری ضرورتوں میں زبردست مطابقت  اور مناسبت پائی جاتی ہے، جوچیزیں ہمارے لیے ضروری ہیں وہی چیزیں اُگ رہی ہیں ۔ بلا ضرورت کوئی چیز نہیں اُگتی ان ساری چیزوں کو دیکھ کر کوئی احمق ہی ہوگا جو یہ سمجھے گا کہ یہ سب کچھ اتفاقاً ہورہا ہے۔  اور یہ کسی قدرت ، حکمت ، رحمت  اور منصوبہ بندی کانتیجہ نہیں ہے ہر صاحب عقل وفکر اس منظر کو دیکھ کر بے ساختہ پکاراُٹھے گا کہ یقیناً کوئی قادرِ مطلق ہے جو اپنی قدرت  اور رحمت کے بے شمار کرشمے دکھارہا ہے ۔&&(تفہیم القرآن )&& منکرینِ حق کی اکثریت بے ایمان ہوتی ہے۔ اسی لیے وہ قرآن کے مطلب پرغوروفکر نہیں کرتے کہ کہیں حق کو ماننے پر مجبور نہ ہوجائیں ۔ جبکہ کائنات کے ذرّے ذرّے میں خدا کی قدرت حکمت عظمت، رحمت کی نشانیوں کے انبار لگے ہوئے ہیں ۔&&(تفسیر نمونہ)&&[[ ہررنگ میں جلوہ ہے تیری قدرت کا،جس پھول کو سونگھتا ہوں بوتیری ہے]]&&(انیس)&&[[مگر منکرین حق کا یہ حال ہے کہ۔ کیا ہے تجھ کو کتابوں نے کورِ ذوق ایسا۔کہ بوئے گل سے بھی تجھ کو ملانہ گل کا سُراغ]]۔&&(اقبال)&&
  26,9,آیت نمبر۹:صاحبان فکر کے لیے خدا کی نشانیاں ہیں :حقیقت یہ ہے کہ خدا کی رحمت دنیا میں کافروں سے بھی متعلق رہتی ہے۔ اس لیے باوجود انتقام یاسزا کے خدا اُن کو سنبھلنے کی مہلتوں پر مہلتیں دیے چلا جاتا ہے۔ &&(موضح القرآن )&&جبکہ خدا کی صفت عزیز (ہرچیز پر خود اپنی قوت کے بل پر غالب رہنا) کاتقاضا تو یہ تھا کہ خدا سارے منکرینِ حق کو فوراً اپنی سزا میں گرفتار کرلیتا۔ مگر، کیوں کہ خدا>>’’رحیم‘‘<<بھی ہے اس لیے اُن کو اصلاحِ حال کی مہلتوں پر مہلتیں دیے چلا جارہا ہے۔ &&(تفسیر کبیر امام رازی)&&خدا وندعالم<<’’عزیز‘‘ >>ہے۔ یعنی اُس کی قدرت ایسی زبردست ہے کہ جب چاہے، جسے چاہے اپنی سزا میں فوراً گرفتار کرسکتا ہے۔ مگر وہ اپنے رحم وکرم کی وجہ سے سزا دینے میں جلدی نہیں کرتا۔سوچنے سمجھنے  اور سنبھلنے کی مہلت پرمہلت دیے جارہاہے۔ پھر یہ کہ عمر بھر کی نافرمانیوں کو دل سے معافی مانگنے  اور اپنی اصلاح کرلینے پر معاف کرنے کو تیار ہے۔ (سبحان اللہ) &&(تفہیم القرآن )&&خداوندِ عالم نے خود کو پہلے <<’’عزیز‘‘>> فرمایا پھر<<’’رحیم‘‘>> فرمایا تاکہ کسی کوکسی طرح بھی خداوندعالم کی کمزوری کااحساس نہ ہو<<’’عزیز‘‘>> پہلے اس لیے فرمایا کہ یہ بات بالکل واضح ہوجائے کہ وہ اپنی انتہائی قدرت کے باوجود ازخود رحم فرماتا ہے  اور نہایت مہربان ہے۔ &&(تفسیر نمونہ)&&
  26,10,آیت ۱۰:غورفرمائیں کہ فرعون کی قوم کی سب سے بڑی برائی ظلم کو بیان کیاگیا ہے ظلم کامفہوم بہت وسیع ہے۔ہر قسم کانامناسب کام ظلم میں شامل ہے۔ شرک  اور کفر بھی ظلم میں شامل ہے۔ &&(تفسیر نمونہ)&&
  26,13,آیت ۱۳:خداوندکریم اپنے حبیب کی دلجوئی کے لیے  حضرت موسٰی علیہ السلام  کاقصہ بیان کررہا ہے تاکہ آپؐ غمزدہ نہ ہوں ۔&&(تفسیر انوار النجف)&& حضرت موسٰی علیہ السلام  کاواقعہ ہمارے رسول اکرمؐ کو اس لیے سنایا جارہا ہے کہ آپؐ کو تسلی  اور سکون حاصل ہو۔ اس لیے کہ  حضرت موسٰی علیہ السلام  ہمارے رسولِ اکرمؐ سے کہیں زیادہ سخت حالات کامقابلہ کررہے تھے۔ (۱) اوّل تو یہ کہ  حضرت موسٰی علیہ السلام  اُس قوم کے فرد تھے جو فرعون کی غلام تھی۔ (۲)  حضرت موسٰی علیہ السلام  خود فرعون کے محل میں پرورش پاچکے تھے۔ (۳)  حضرت موسٰی علیہ السلام  کے ہاتھوں فرعون کی قوم کاایک آدمی قتل ہوگیا تھا، اگرچہ وہ قتلِ عمد نہ تھا، جبکہ جناب رسول خداؐ پر(معاذ اللہ) ایسا کوئی الزام نہ تھا۔ ( یعنی بے قصور دشمنی تھی) (۴) پھر یہ کہ فرعون کی سلطنت اُس وقت دنیا کی سب سے بڑی طاقت تھی۔ جبکہ قریش فرعون کے مقابلے پر بہت کم طاقتور تھے۔ ان تمام باتوں کے باوجود فرعون  حضرت موسٰی علیہ السلام  کاکچھ نہ بگاڑ سکا۔ اس طرح خداوندعالم ایک طرف توجناب رسول خداؐ کو تسلی دے رہا ہے۔ دوسری طرف عربوں کو یہ بتارہا ہے کہ تم کس کھیت کی مولی ہو، کہ جس کی پشت پناہی اللہ کررہا ہو، اُس کے مقابلے پر تمہاری کوئی حیثیت نہیں ہے۔ &&(تفہیم القرآن )&&!!آیت کی تشریح:اصل میں حضرت موسٰی‘‘فرعون کی ہدایت’’جیسے بڑے مشن پر اکیلے جانے سے گھبرارہے تھے۔ یہ بات خود یہ الفاظِ دعاء بتلارہے ہیں کہ’’میرا سینہ گھٹتا ہے، میری زبان نہیں چلتی‘‘ دوسرے یہ کہ  حضرت موسٰی علیہ السلام  کو یہ بھی اندازہ تھا کہ وہ روانی کے ساتھ تقریر نہیں کرسکتے جبکہ حضرت ہارونؑ زبردست زبان آور &&(فصیح)&& تھے۔ بائیبل کابیان ہے کہ  حضرت موسٰی علیہ السلام  نے اپنی زبان کند ہونے کی وجہ سے منصب نبوت کو قبول کرنے سے بالکل انکار کردیا تھا۔ اور عرض کیاتھا کہ:اے خداوند!یہ پیغام تو کسی  اور کے ہاتھ سے بھیج جسے تو چاہے۔
  26,14,آیت نمبر۱۴:محققین نے نتیجہ نکالا کہ  حضرت موسٰی علیہ السلام  کایہ فرمانا کہ:’’اُن کا مجھ پر ایک الزام قتل بھی ہے۔‘‘یہ بتاتا ہے کہ  حضرت موسٰی علیہ السلام  نے قتل عمداً نہیں کیاتھا۔اصل میں اُنہوں نے اُس قُبطی کو جوظالم تھا  اور ایک کمزور اسرائیلی کو قتل کرنا چاہتا تھا، اُس اسرائیلی کو بچانے کے لیے صرف ایک گھونسا مارا تھا، مگر وہ اُن کے گھونسے کی تاب نہ لاسکا  اور مرگیا  اور یہ امر اتفاقاً ہوا۔ اسی لیے  حضرت موسٰی علیہ السلام  نے اس بات کو صرف الزام فرمایا، نہ کہ جرم فرمایا۔ &&(تفسیر مجمع البیان ۔تفسیر تبیان)&&یہ اشارہ اُس واقعہ کی طرف ہے جو سورہ قصص میں بیان ہوا ہے۔  حضرت موسٰی علیہ السلام  نے ایک اسرائیلی پر ایک قبطی کو ظلم کرتے دیکھا، اُس اسرائیلی نے  حضرت موسٰی علیہ السلام  کو اپنی مدد کے لیے بلایا۔  حضرت موسٰی علیہ السلام  نے قبطی کو ایک مکاماردیا۔ قبطی فوراً مرگیا۔ اسی وجہ سے  حضرت موسٰی علیہ السلام  ملک چھوڑکر مدین چلے گئے۔ آٹھ دس سال کی روپوشی کے بعد یکایک حکم ہوا کہ فرعون کے دربار میں جاکھڑے ہو حضرت موسٰی علیہ السلام  کو خطرہ ہوا کہ پیغام سنانے سے پہلے ہی فرعون مجھے قتل کے الزام میں قتل ہی نہ کردے۔ &&(تفہیم القرآن )&& اصل میں  حضرت موسٰی علیہ السلام  کو فرعون کے مقابلے پر جانے میں تین دقتیں محسوس ہورہی تھیں ۔ (۱) اُن کوفرعون کے تکبّر کاپورا اندازہ تھا، اس لیے یقین تھا کہ وہ میری تکذیب کرے گا۔ (۲) اُن کی زبان میں لکنت تھی، اسی لیے اُن کو خوف تھا کہ وہ میری بات کو ہنسی ٹھٹھے میں اڑادے گا۔ (۳) کیوں کہ اُن کے ہاتھ سے ایک فرعونی قبطی شخص قتل بھی ہوچکا تھا، جواگرچہ قتل عمدنہ تھا مگر قتل بہرحال قتل ہے۔ حضرت موسٰی علیہ السلام  نے سوچا کہ جب میں فرعون کی جھوٹی خدائی کو للکار کر باطل قرادوں گا،  اور اپنے سچے خدا کی خدائی کاعلم اُس کے دربار میں بلند کروں گا، تو مجھ پر قتل کامقدمہ قائم کرکے مجھے قتل کرادے گا، اس طرح اصل مقصد فوت ہوجائے گا۔ &&(تفسیر نمونہ)&&اسی لیے  حضرت موسٰی علیہ السلام  نے جب یہ دیکھا کہ خداوند عالم کا اصرار ہے کہ تم فرعون کے دربار میں جائو  اور ہمارا پیغام اُس تک پہنچا کر اتمام حجت کرو، تو اللہ تعالیٰ کی بارگاہ میں یہ دعاء مانگی<<۔قَالَ رَبِّ اشْرَحْ لِيْ صَدْرِيْ۲۵ۙ وَيَسِّرْ لِيْٓ اَمْرِيْ۲۶ۙ وَاحْلُلْ عُقْدَۃً مِّنْ لِّسَانِيْ۲۷ۙ يَفْقَـــہُوْا قَوْلِيْ۲۸۠ وَاجْعَلْ لِّيْ وَزِيْرًا مِّنْ اَہْلِيْ۲۹ۙ ہٰرُوْنَ اَخِي۳۰ۙ اشْدُدْ بِہٖٓ اَزْرِيْ۳۱ۙ وَاَشْرِكْہُ فِيْٓ اَمْرِيْ۳۲ۙ كَيْ نُسَبِّحَكَ كَثِيْرًا۳۳ۙ وَّنَذْكُرَكَ كَثِيْرًا۳۴ۭ >>&&(سورہ طٰہٰ آیت ۲۵ تا۳۴)&&’’@@موسیٰؑ نے دعا مانگی ، میرے پالنے والے مالک!میرے سینے کو کشادہ کردے،  اور میرے کام کو میرے لیے آسان کردے،  اور میری زبان کی گرہ کو کھول دے ، (تاکہ) وہ لوگ (فرعون  اور اُس کے ساتھی) میرےکلام کوسمجھ سکیں ،  اور میرےلیے میرے ہی خاندان سے میرے بھائی ہارونؑ کو میرا وزیر بنادے، اُس کے ذریعہ سے میری کمر کو مضبوط کردے،  اور اُسے میرے کام (رسالت) میں میراشریک بنادے، تاکہ ہم کثرت سے تیری تسبیح کریں ،  اور تجھے خوب یاد کریں@@ ۔{{‘‘جناب رسول خداؐ نے فرمایا: اے علیؑ تم میرے نزدیک وہی مقام رکھتے ہو جو موسٰی کے پاس ہارون کا تھاسوا اس کے کہ میرے بعد کوئی نبی نہ ہوگا۔‘‘&&(صحیح بخاری شریف)&&}}تاریخ گواہ ہے حضرت اما م علی ابن ابی طالبؑ علیہ السلام  اور اُن حضرت کی اولاؑد طاہرہ نے جناب رسولؐ خدا  اور اُن حضرتؐ کے پیغام کی اُس سے بھی زیادہ حفاظت فرمائی۔ جوکام حضرت ہارونؑ نے  حضرت موسٰی علیہ السلام   اور اُن کی رسالت کے لیے انجام دیا۔ &&(مولف)&&
  26,15,آیت نمبر۱۵:’’کلا‘‘ (ہرگز نہیں ) یعنی فرعون کی یہ مجال نہیں کہ وہ تم کو قتل کرسکے۔&&(تفسیر کبیر)&&’’نشانیوں ‘‘سے مراد  حضرت موسٰی علیہ السلام  کاڈنڈا، چمکتا ہوا ہاتھ  اور دوسرے معجزات۔&&(تفہیم القرآن )&&
  26,16,آیت ۱۶۔ حضرت موسٰی علیہ السلام  یہ بتلانا چاہتے ہیں کہ میں سارے جہانوں کے پالنے والے مالک کی طرف سے نبی بن کر آیا ہوں ۔ &&(تفسیر ماجدی)&&
  26,17,آیت۱۷۔ حضرت موسٰی علیہ السلام  کی دعوت (پیغام) کے دوجزو تھے۔ (۱) فرعون کو خدا کی بندگی کی طرف متوجہ کرنا۔ (۲) بنی اسرائیل کو فرعون کی غلامی سے آزاد کرانا۔&&(تفہیم)&&
  26,18,آیت نمبر۱۸:{{تفسیر برہان میں حضرت امام جعفر صادق علیہ السلام سے منقول ہے کہ فرعون نے حضرت موسیٰ کو اپنے پاس آنے کی اجازت نہ دی  اور اپنے محل کے دروازے بند کرادیے لیکن  حضرت موسٰی علیہ السلام  نے اپناعصا مارا تو سب دروازے کھل گئے ۔ پس آپؑ سیدھے تختِ فرعون کے سامنے جاپہنچے  اور بے دھڑک پیغامِ خداوندی سنا دیا۔ فرعون نے جواب میں کہا کہ’’اے موسٰی!ہم نے تم کوبچپنے میں پالا ہے  اور کئی سال &&(ابن عباس سے ۱۸سال منقول ہیں )&&}}تم نے ہمارے ہاں گذارے پھر تم نے ہمارے سب احسانات کو فراموش کرکے (ہمارے ہی آدمی کو) قتل بھی کردیا۔  حضرت موسٰی علیہ السلام  نے فرمایا:’’وہ قتل مجھ سے غیرارادی طور پر ہوا ہے۔  اور یہ کہ کام مجھ سے اُس وقت ہوا جب میں اپنے راستے سے بھٹک کر اُس طرف جانکلا۔&&(تفسیر انوارالنجف)&&یہودی روایات میں اختلاف ہے کہ  حضرت موسٰی علیہ السلام  فرعون کے پاس ۱۸سال رہے یا بیس سال ہے۔
  26,20,آیت نمبر۲۰:یہاں پر<<’’ضالین‘‘>> کے معنی گمراہی کے نہیں ہیں بلکہ نادانی ،  اور بھولے ہوں میں سے ہونے کے ہیں ۔ اس لیے اس کاترجمہ نادانستہ عمل بجا لانے کاہوتا ہے کیوں کہ  حضرت موسٰی علیہ السلام  نے قتل کاارادہ نہیں کیاتھا۔اُن کو یہ معلوم نہ تھا کہ ایک گھونسا کھا کر وہ قبطی چل بسے گا۔ اس لیے اُن کا یہ عمل بھول چوک ، نادانی  اور نادانستہ تھا ۔گمراہی یاگناہ نہ تھا۔ عربی لعنت میں <<’’ضالین‘‘>> کے معنی بھولے ہوئوں کے بھی آتے ہیں ۔ جونادانستہ کوئی عمل کربیٹھتے ہیں ۔ &&(تفسیر ماجدی)&&فرزندِ رسول خداؐ {{حضرت امام علی رِضا علیہ السلام سے کسی نے دریافت کیا کہ:’’جبکہ انبیاء کرامؑ معصوم ہوتے ہیں تو حضرت موسیٰ علیہ السلام نے خود کو<<’’ضالین‘‘>> میں سے کیوں فرمایا؟‘‘ حضرت امام علیہ السلام نے فرمایا کہ:’’حضرت موسیٰؑ نے تو یہ فرمایا تھا کہ’’میں تمہارے محلے میں راستہ بھول کر آگیا تھا۔‘‘ &&(تفسیر نورالثقلین)&&}}محققین نے نتیجہ نکالا کہ ہر جگہ <<’’ضالین‘‘>> سے مراد گمراہ نہیں ہواکرتا۔ انجانے میں کسی کام کا ہوجانا بھی ضالین کے معنی میں آتا ہے ۔&&(ترجمان القرآن مولانا مودودیؒ، القرآن المبین مولانا امداد علی کاظمی)&&
  26,21,آیت ۲۱ کی تشریح:<<’’حکما‘‘>> اس کایہ مطلب نہیں کہ اُس وقت نبی بنائے گئے، بلکہ نبوت  اور اُس کی استعداد پہلے سے تھی ،  اور اسی بناءپر اُن کو خدا نے فرعون کے شر (قتل)  اور دیگر خطرناک مقامات سے محفوظ رکھا  اور دوسری دایہ عورتوں کادودھ اُن پرحرام قرار دیا۔ وغیرہ پس اب گویا اعلان نبوت کامجھے حکم ملا ہے  اور رسول ہوکر تیرے پاس آگیا ہوں ۔ &&(تفسیر انوارالنجف)&&اصل میں حکمت کے کئی بلند درجات ہیں ۔  حضرت موسٰی علیہ السلام  ظاہری نبوت کے حصول سے پہلے بھی نبوت وحکمت کے حامل تھے مگر جب نبوت ورسالت کے عہدے پر فائز ہوئے تو حکمت کے اعلیٰ ترین مدارج کو بھی حاصل کرلیا۔ &&(تفسیرنمونہ)&&
  26,22,آیت ۲۲کی تشریح:مطلب یہ ہے کہ اے فرعون!میں تیرے گھر میں پرورش پانے کے لیے کیوں آتا، اگر تُو نے بنی اسرائیل پر ظلم نہ ڈھایا ہوتا۔ اُن کو زبردستی اپنا غلام نہ بنائے رکھا ہوتا، اُن کے بچوں کو قتل نہ کرتا، اسی تیرے ظلم کے خوف سے میری ماں نے مجھے ٹوکری (صندوق) میں ڈال کردریامیں بہا دیا تھا۔  اور اس طرح میں تیرے محل میں پہنچ گیا تھا۔ ورنہ کیا میری پرورش کے لیے میراگھر موجود نہ تھا؟ میری ماں موجود نہ تھی ؟اس لیے تجھے یہ زیب نہیں دیتا کہ میری پرروش کااحسان جتا ئے۔ &&(تفہیم القرآن )&&  حضرت موسٰی علیہ السلام  کے فرمانے کامقصد یہ تھا کہ ’’یہ ٹھیک ہے کہ حوادثِ زمانہ نے مجھے تیرے گھر بچپنے میں پہنچا دیا،  اور تم نے میری پرورش کی ۔ مگر یہ تو سوچو کہ ایسا کیوں ہوا؟ کیاتو نے بنی اسرائیل کو غلامی کی زنجیروں میں نہیں کس رکھاتھا؟ کیا تو نے یہ قانون نہیں بنایا تھا کہ بنی اسرائیل کے گھر جولڑکا پیدا ہوا سے فوراً قتل کردیا جائے؟ اسی وجہ سے مجبوراً میری ماں نے مجھے صندوق میں ڈال کر دریا میں بہادیا تھا۔  اور میرا صندوق تیرے محل سے ٹکراکر رُکا۔تُو نے صندوق سے مجھے نکالا،  اور اس طرح میں اپنے پاکیزہ گھر سے محروم ہوکر تیرے نجس محل میں پہنچا۔  اور اگر تمہارا یہ مجھے پالنا، پرورش کرنا کسی حد تک نعمت ہی تھی، تو بھی تمہارے مظالم کے مقابلے میں ایسی تھی کہ جیسے سمندر کے مقابلے میں ایک قطرہ ۔تو جسے نعمت بک رہا ہے وہ تیرے مظالم کے مقابلے میں کوئی حقیقت نہیں رکھتی ، نہ تو نے ایسے ظلم ڈھائے ہوتے نہ میں تیری گود میں پہنچتا۔ پھر یہ کہ تیرا یہ کہنا کہ تو نے مجھے نعمتیں دیں ، تو وہ نعمتیں بھی میری ہی قوم کے افراد نے تجھے فراہم کی تھیں جبکہ تو اُن کوغلام بنا کر کام لیتاتھا۔ وہ سب نعمتیں میری قوم والے کما کرتجھے دیا کرتے تھے۔ اب میری قوم کی کمائی کامجھ پراحسان جتا رہا ہے۔ (یہ احسان تو مجھے جتانا چاہیے تھا) &&(تفسیر نمونہ)&&
  26,24,آیت نمبر۲۴:مشرکوں کاعقیدہ ہے کہ موجودات عالم میں ہر چیز کارب الگ ہوتا ہے۔ وہ کائنات کو مختلف نظاموں کامجموعہ سمجھتے تھے۔  حضرت موسٰی علیہ السلام  نے واضح فرمادیا کہ پوری کائنات پر صرف ایک ذات  اور اُس کاصرف ایک نظام حکمرانی کررہا ہے جو اس بات کی واضح دلیل ہے کہ پوری کائنات کاصرف ایک ربّ ہے۔  حضرت موسٰی علیہ السلام  کایہ فرمانا کہ <<’’ ان کنتم موقنین‘>>‘اگر تم یقین کرنے والے ہو۔‘‘کامطلب یہ تھا کہ میں خوب جانتا ہوں کہ تمہارے سوالوں کااصل مقصد حقیقتوں کو جاننا، سمجھنا  اور مان لینا نہیں ہے۔ اگر تمہیں حقیقت کی تلاش ہوئی تو تم عقل وشعور سے کام لیتے، اگر تم حقیقت کوماننا چاہتے ہوتے تو آنکھیں کھول کر کائنات عالم کو دیکھتے، پھرتمہیں یہ حقیقت واضح دکھائی دے جاتی کہ ساری کائنات کامالک ایک ہی ذات ہے۔[[ حقیقت ایک ہے ہر شے کی، نوری ہوکہ ناری ہو۔لہوخورشید کاٹپکے ،اگر ذرّے کادل چیریں]] &&(اقبال)&&
  26,25,آیت نمبر۲۵:فرعون نے حضرت موسیٰ علیہ السلام کاجواب سن کر اپنے درباریوں سے کہا:’’تم نے موسٰی کاجواب سنا میں نے تو موسٰی سے خدا کی حقیقت دریافت کی تھی ،  اور موسٰی نے خدا کے افعال کو بیان کرنا شروع کردیا۔ &&(تفسیر صافی ص۳۲۴)&&محققین نے نتیجہ نکالا کہ:خدا کی ذات کوہم نہیں پہچان سکتے۔ ہم خدا کوصر ف اُس کے افعال  اور صفات ہی سے پہچان سکتے ہیں ۔ اسی لیے ہمیں یہ حکم دیاگیا ہے کہ ہم خدا کی صفات افعال  اور تخلیقات پرغور وفکر کریں ۔ اُس کی ذات ہماری عقلوں کے لیے ناقابل فہم ہے۔ &&(تفسیرنور الثقلین بقول حضرت امام جعفر صادقؑ)&& مگر کیوں کہ فرعون حقیقتوں کو سمجھنا چاہتا ہی نہ تھا، حق بات ماننے پر آمادہ ہی نہ تھا، اُس میں طلبِ حق نام کو بھی نہ تھی، ا س لیے اُس نے بجائے غوروفکر کرنے کے طنز وطعن، غرور نخوت سے کام لیا۔اپنے چمچوں کودیکھا  اور مذاقاً کہا کہ:’’تم سُن رہے ہو‘‘&&(کہ موسٰی کیا کہہ رہے ہیں )&& ظاہر ہے کہ فرعون کے پاس اُسی جیسے بیٹھے ہوں گے۔ جیسی روح ویسے ہی فرشتے ۔  اور سب نے  حضرت موسٰی علیہ السلام  کی بات کو مذاق میں اُڑانے کی کوشش&&( اور فرعون کی دلجوئی)&&کی۔ &&(تفسیر نمونہ)&&{{حضرت ابن عباسؓ فرماتے ہیں کہ:’’اُس وقت فرعون کے اردگرد اُس کے پانچ سوخوشامدی ٹٹو موجود تھے۔ جو فرعون کے خاص الخاص مصاحب یا درباری تھے۔ &&(تفسیر ابوالفتوح رازی،تفسیر ابن عباسؓ)&&}}
  26,26,آیت نمبر۲۶:اصل میں حضرت موسیٰ علیہ السلام کا یہ خطاب فرعون کے درباریوں سے تھا۔ کیوں کہ فرعون نے پہلے کہا تھا کہ’’سنتے ہو‘‘ اس پر  حضرت موسٰی علیہ السلام  نے فرمایا کہ میں چھوٹے چھوٹے من گھڑت تمہارے جھوٹے خدائوں کانمائندہ نہیں ہوں ۔ میں صرف اُس مالک کانمائندہ ہوں  اور اُس کو ماننے والا ہوں ۔ جو تمام جہانوں کامالک  اور پالنے والا ہے۔ جوفرعون کابھی مالک ہے  اور تمہارا بھی ،  اور تمہارے گذرے ہوئے باپ دادائوں کا بھی۔ &&(تفہیم القرآن )&& حضرت موسیٰ علیہ السلام نے بلاخوف وخطر فرمایا:’’وہ تمہارا بھی پالنے والا مالک ہے  اور تمہارے پہلے کے گزرے ہوئے آباءواجداد کابھی مالک ہے‘‘ گویا  حضرت موسٰی علیہ السلام  نے پہلے آفاق کے ذریعہ سے خدا کو پہنچوایا، پھر ’’نفس‘‘ کے ذریعہ سے انسانی روح  اور جسم کے حوالے سے خداوندعالم کی ربوبیت کے آثار دکھائے۔ تاکہ یہ مغرور  اور متکبر لوگ (جوفرعون کی حاشیہ برداری کررہے تھے) کم ازکم خود اپنے بارے میں ہی سوچ لیں کہ اُن کوکس نے نوازرکھا ہے۔ &&(تفسیر نمونہ)&& (لیکن جب انسان میں غرور  اور تکبر پیدا ہوجاتا ہے تو اس میں غور فکر  اور سوچ سمجھ کا مادّہ ہی ختم ہوجاتا ہے ۔ پھر وہ کیسے غوروفکر کرتے جن کوفرعون نے نوازا ہو)
  26,27,آیت ۲۷کی تشریح:مگر فرعون اپنی ہٹ دھرمی پر اڑارہا، بلکہ اب مذاق پر اترآیا،  حضرت موسٰی علیہ السلام  جو عین عقل کے مطابق استدلال فرمارہے تھے، اُن کودیوانہ، مجنون بکنے لگا۔ یہی وہ تہمت ہے جو ہر زمانے کے بڑے بڑے لوگ انبیاءؑ پر ہمیشہ لگاتے آئے ہیں ۔ قریش کے سردار بھی رسول خداؐ پریہی بہتان جڑتے رہے۔ فرعون نے  حضرت موسٰی علیہ السلام  کو’’ہمارا رسول‘‘تک کہنا گوارا نہ کیا، بلکہ کہا:تمہارا پیغمبر‘‘  اور تمہاری طرف بھیجا ہوا‘‘ اس طرح اُس نے تکبر  اور غرور بھی ظاہر کیا۔  اور اس نے  حضرت موسٰی علیہ السلام  کو پاگل اس لیے کہا کہ کہیں لوگ اُن کے زبردست دلائل سے متاثر نہ ہوجائیں غرور کے ساتھ سیاست سے کام لیا۔ &&(تفسیر نمونہ)&&
  26,28,آیت۲۸کی تشریح: حضرت موسٰی علیہ السلام  کے فرمانے کامطلب یہ تھا کہ اگرچہ تیرے پاس یہ چھوٹی سی حکومت ہے، مگر اس کی کوئی حیثیت نہیں ہے۔ کیوں کہ میرے مالک کی حکومت تو مشرق ومغرب پر پھیلی ہوئی ہے،  اور اس کے آثار تمام کائنات کی پیشانی پر چمک رہے ہیں ۔ اگر تم عقل سے کام لیتے تو حقیقت تم پر واضح ہوجاتی ۔ &&(تفسیر نمونہ)&&
  26,29,آیت نمبر۲۹:فرعون کے غصے کااصل سبب یہ تھا کہ  حضرت موسٰی علیہ السلام  نے خدا وندعالم کی حاکمیت  اور بالادستی کو منوانے کی کوشش کی تھی۔ تمام حکمرانوں کو ہمیشہ انبیاء کرامؑ ( اور اُن کے اوصیاء) سے اسی لیے سخت نفرت ہوتی ہے کہ وہ اُن کی حاکمیت کے بجائے خدا کی حاکمیت  اور بالادستی کومنواتے ہیں ، اسی لیے تمام حکام جور (ظالم حکمراں ) انبیاءؑ کو اپنا باغی  اور سب سے بڑا مجرم سمجھتے ہیں ۔اس سے معلوم ہوا کہ  حضرت موسٰی علیہ السلام  صرف یہ نہیں فرمارہے تھے کہ بتوں کو چھوڑ کر خدا کی پوجا پاٹ شروع کردو۔ بلکہ وہ خدا کی حکمرانی ماننے کو ہرگز تیار نہ تھا۔ نہ وہ یہ برداشت کرسکتاتھا کہ اُس کی رعایا میں سے کوئی شخص کسی  اور ذات یافرد کی حکمرانی  اور بالادستی کو قبول کرلے کیوں کہ اس طرح اُس کو اپنا سیاسی اقتدار جاتا ہوا دکھائی دے رہاتھا۔ اسی لیے آگے بڑھ کر فرعون نے صاف صاف  حضرت موسٰی علیہ السلام  کو دھمکی دی کہ اگر تم نے میرے اقتدار اعلیٰ کے سوا کسی  اور اقتدارِ اعلیٰ یاحاکمیت کانام بھی لیا تو میں تم کو جیل کی ہوا کھلائوں گا۔ &&(تفہیم القرآن )&& فرعون نے<<’’المسجونین‘‘>> کہا جس کے معنی ایک خاص قیدخانہ جہاں سے کوئی واپس نہیں آتا۔ &&(تفسیر المیزان ۔ تفسیر کبیر امام رازی، تفسیر روح المعانی)&&
  26,30,آیت نمبر۳۰:جب فرعون عقلی دلیل سے  حضرت موسٰی علیہ السلام  کی بات ردنہ کرسکا تو غنڈہ گردی پراُترآیا،  اور اپنی طاقت سے اُن کو ڈرانے دھمکانے لگا۔ مگر حضرت موسٰی علیہ السلام  نے اپنے کلام  اور استدلال سے اُس کے منہ میں اس طرح لگام دیدی کہ اُس کا سارا طنطنہ شاہی دھیما،بلکہ ڈھیلا پڑ گیا۔  اور اس کو مجبوراً کہنا پڑا کہ اچھا جو کچھ کہتے ہو اُس کو پیش کرو۔ فرعون کایہ کہنا از خود بتاتا ہے کہ اُسے اپنے موقف پر پورا یقین نہ تھا۔ اس لیے اُسے یہ کہنا پڑا کہ اگر تم سچے ہو تو ثابت کرو۔میں مان لوں گا۔ مگر معجزہ دیکھ کر بھی نہ مانا۔ &&(فصل الخطاب)&& حضرت موسٰی علیہ السلام  کامطلب یہ تھا کہ کیا تم اس صورت میں بھی میری بات ماننے سے انکار کرو گے ،  اور مجھے جیل بھیجو گے جبکہ میں تمہارے سامنے ایک بالکل واضح علامت پیش کردوں کہ میں واقعی اُسی خدا کا بھیجا ہوا ہوں جو تمام جہانوں ، تمام زمین وآسمانوں کامشرق ومغرب کامالک  اور پالنے والا ہے۔ &&(تفہیم القرآن )&&حضرت موسیٰ کو خدا کی طاقت پربھروسہ تھا، اسی لیے فرعون کی آنکھوں میں آنکھیں ڈال کرفرمایا۔ اگرمیں اپنی رسالت کی واضح دلیل لے آئوں ، تو بھی مجھے قید خانے بھیجے گا؟اس سوال پر فرعون سٹ پٹا گیا کیوں کہ  حضرت موسٰی علیہ السلام  کے اس جملے پر سارا مجمع اُن کی طرف بغور متوجہ ہوگیا او ران کے استدلال کاقائل ہوگیا۔اب اگر فرعون  حضرت موسٰی علیہ السلام  کوٹالنا چاہتا تو سارے حاضرین اعتراض کرتے،  اور سب جان لیتے کہ فرعون موسٰی کامقابلہ نہیں کرسکتا۔ اس لیے فرعون کو زچ ہوکر مجبوراً یہ کہنا پڑا’’اگر تم سچے ہو تو دلیل لے آئو۔‘‘&&(تفسیر نمونہ)&&
  26,31,آیت۳۱کی تشریح:فرعون کاجواب بتارہا ہے کہ وہ قدیم وجدید زمانے کی تمام مشرکوں کی خداوندعالم کو تمام خدائوں  اور دیوتائوں کاخدا مانتا تھا۔  اور یہ بھی مانتا تھا کہ وہ جو تمام خدائوں کاخدا ہے وہ تمام دیوتائوں سے بڑا ہے۔ اسی لیے  حضرت موسٰی علیہ السلام  نے یہ نہیں فرمایا کہ میں خدائوں کے خدا کے وجود کاثبوت پیش کروں ، بلکہ یہ فرمایا کہ’’میں ایسی واضح نشانیاں پیش کردوں جس سے یہ واضح ہوجائے کہ میں اسی سب سے بڑے خدا کابھیجا ہوا ہوں ۔‘‘  اور فرعون نے جواب دیا کہ:’’اچھا اگر تم اس دعوٰے میں سچے ہو تو کوئی نشانی پیش کرو۔‘‘اگر فرعون سب سے بڑے خدا کو سرے سے مانتا ہی نہ ہوتا، تو اس کی نشانی کی بات ہی نہ کرتا۔ بحث صرف اسی نکتہ پر تھی کہ حضرت موسیٰ ؑ اُس تمام دیوتائوں کے بڑے خدا کی طرف سے بھیجے ہوئے ہیں یا نہیں ؟&&(تفہیم القرآن )&&
  26,32,آیت ۳۲کی تشریح: عربی زبان میں <<’’حیۃ‘‘>> ہر قسم کے سانپ کو کہتے ہیں جبکہ <<’’ثعبان‘‘ >> اژدہے یعنی بڑے سانپ کو کہتے ہیں جو بڑی تیزی سے بھاگتا  اور حملے کرتا ہے۔ &&(تفسیر کبیر امام رازی)&& جب فرعون نے  حضرت موسٰی علیہ السلام  سے اُن کی صداقت کی نشانی مانگی تب آپؑ نے دو معجزے دکھائے۔ (۱) عصا کو زمین پر پھینکا تو وہ اژدہا بن گیا،  اور ہاتھ کو آستین سے باہر نکالا تو وہ یدبیضا (چمکتا ہوا ہاتھ) ہوگیا۔{{ بروایت تفسیر قمی’’اژدہے کے خوف سے فرعون کے حاشیہ نشین ادھر اُدھر دوڑگئے  اور خود فرعون بھی ڈرکے مارے آپے میں نہ رہا۔ پس موسیٰؑ کو ان کے اللہ  اور بچپنے کی تربیت کاواسطہ دیا تو  حضرت موسٰی علیہ السلام  نے عصا کو اُٹھالیا۔ تب فرعون کاہوش ٹھکانے آیا پس ایمان لانے کا ارادہ کیا۔ لیکن ہامان، جوفرعون کاوزیر تھا، کہنے لگا کہ اے فرعون !ذرا شرم کر۔ اب تک تو معبود بنا بیٹھا تھا،  اور اب تو کسی  اور کاعبد بننا چاہتا ہے۔ &&(تفسیر انوارالنجف)&&}}بعض مفسرین نے یہودی روایات سے متاثر ہوکر <<’’بیضائَ‘‘>> کے معنی سفید لکھ دیے ہیں جس کامطلب یہ نکلتا ہے کہ  حضرت موسٰی علیہ السلام  نے جب بغل میں سے ہاتھ نکالا تو وہ برص کے مرض کی طرح سفید ہوگیا۔ جبکہ تمام بڑے مفسرین نے اس بات پر اتفاق فرمایا ہے کہ یہاں پر<<’’بیضائَ‘‘>> کے معنی سفید نہیں ہیں ، بلکہ روشن ، چمکدار (سرچ لائٹ کی طرح روشن) کے ہیں ۔ &&(تفہیم القرآن )&&  حضرت موسٰی علیہ السلام  نے دومعجزے دکھادئیے۔ ایک خوف کامظہر تھا  اور دوسرا اُمید کا۔ پہلے انذار کاپہلو تھا۔ دوسرے میں بشارت کا۔ ایک معجزہ خدا کے عذاب کی علامت تھا۔ دوسرا معجزہ خدا کی رحمت  اور نور کی علامت تھا۔ معلوم ہوا کہ معجزے انبیاء کرامؑ کی دعوت  اور پیغام کے مطابق ہوا کرتے ہیں ۔ &&(تفسیر نمونہ)&& <<’’ثعبان‘‘ >> کے معنی بڑے سانپ یعنی اژدہے کے ہوتے ہیں ۔ ثعبان۔ ثعب کے مادّے سے ہے جس کے معنی پانی کے بہنے کے ہوتے ہیں ۔ اژدہا بھی پانی کی طرح بل کھاکرچلتا ہے اس لیے عرب اُس کو<<’’ثعبان‘‘ >>  کہتے ہیں ۔ &&(مفردات امام راغب)&&
  26,36,آیت نمبر۳۶:ابھی کچھ دیر پہلے تو فرعون کسی کی کوئی بات سننے کو تیار نہ تھا۔  اور اب ایسا بوکھلایا کہ اپنے ہی چمچوں سے پوچھ رہا ہے کہ : بتائو تمہارا کیا حکم ہے؟‘‘&&(تفسیر نمونہ)&&<<’’ارجہ‘‘>> کالفظ<< ارجاء>>کے مادے سے ہے جس کے معنی ہیں فیصلے میں تاخیر کرنا۔ &&(مفردات امام راغب)&&
  26,38,آیت نمبر۳۸:جادوگردوزخی ہے:لیکن مصری تمدّن میں جادو اُس وقت کی سائنیس کے اعلےٰ ترین علوم میں شمار کیاجاتا تھا۔ اِسی لیے جادوگروں کامرتبہ بہت بلند تھا، وہی مرتبہ تھا جو آج بڑے بڑے سائینس دانوں کو دیا جاتا ہے۔ &&(تفسیر ماجدی)&&{{جناب امیرالمومنین حضرت امام علی ابنِ ابی طالبؑ نے ارشاد فرمایا:’’منجمّ (ستارہ شناس) مثل کاہن کے ہے، کاہن مثل ساحر (جادوگر) کے ہے  اور جادوگر مثل کافرکے ہے،  اور کافر جہنم کاایندھن ہے۔ &&(نہج البلاغۃ)&&}}آیت کامطلب یہ ہے کہ صرف اعلان پر اکتفاءنہیں کیاگیا، بلکہ بہت سے آدمی اس غرض سے ملک میں چھوڑے گئے کہ وہ لوگوں کو اُکسااُکسا کر مقابلہ دیکھنے کے لیے لائیں ۔ تاکہ تمام لوگ جو دربار میں حضرت موسیٰ کے معجزے دیکھ کر متاثر ہوچکے ہیں ۔وہ  اور دوسرے تمام عوام النّاس جادوگروں کے مقابلے پر حضرت موسٰی علیہ السلام  کی شکست دیکھ لیں ،  اور اُن کویقین ہوجائے موسٰی کے معجزات جادو کے سوا کچھ نہیں ۔ &&(تفہیم القرآن )&& فرعون نے لوگوں کو اس لیے جمع کرنا چاہا تھا کہ وہ ضرور فرعون کی طرفداری کریں گے جس سے جادوگروں کے حوصلے بلند ہوں گے،  اور وہ تماشائی جادوگروں کی ذراسی کامیابی پر خوب تالیاں بجائیں گے،  اور نعرے لگائیں گے۔ اس سے موسٰی کی آواز  اور کامیابی متاثر ہوکر دب جائے گی ، ممکن ہے موسٰی نعرے سن کر ڈر جائیں وغیرہ۔&&(تفسیر نمونہ)&&
  26,40,آیت نمبر۴۰:<<’’نتبع السحرۃ‘‘>> یعنی ہم جادوگروں کی بات کو مانیں گے۔مقصد یہ ہے کہ  حضرت موسٰی علیہ السلام  کے دین کی اتباع سے چھٹکارا ملے۔ ورنہ جادوگروں کی پیروی و اطاعت وہ کیسے کرتا جو اپنے اوپر خالق کی اطاعت کو برداشت نہیں کرسکتا تھا۔ تفسیر برہان میں ہے کہ ایک ہزار جادوگر جمع ہوئے تھے۔ تفسیرصافی میں ان کی تعداد سترہزار منقول ہے۔ پھراُن میں سے ایک سوجادوگروں کا انتخاب ہوا۔  اور اُن میں سے اسی جادوگروں کو  حضرت موسٰی علیہ السلام  کے مقابلے کے لیے چُنا گیا۔ پھراُنہوں نے فرعون سے کہا کہ تجھےمعلوم ہونا چاہیے کہ اس روئے زمین پرہم سے زیادہ بڑا جادو گر کوئی نہیں ہے پس اگر ہم موسٰی کے مقابلے پر جیت گئے تو ہمیں کیا انعام ملے گا؟فرعون نے جواب دیا کہ اگر تم میدان جیت گئے تو میں تم کو اپنے ملکی معاملات میں اپنا مقرب بنالوں گا۔ اُنہوں نے کہا کہ اگر موسٰی غالب آگئے تو ہم ایمان لے آئیں گے ۔فرعون نے کہا:میں بھی اس کی تصدیق کروں گا۔&&(تفسیر انوار النجف)&&دیکھئے ایسے ہوتے ہیں باطل کے طرفدار اور حامیانِ دین مشرکین جو اپنے باطل دین کو بچانے کے لیے سرکار سے انعام کی صورت میں بھیک مانگ رہے ہیں ۔ یہ ہیں اُن کے پاک جذبات اپنے دین کو بچانے کے لیے ۔&&(تفہیم القرآن )&& دین اسلام کے بعض خدّام ایسے ہی ہوتے ہیں :{{حضرت امام جعفر صادق علیہ السلام نے فرمایا:دین اسلام کے بھی بعض خدّام ایسے ہی ہوئے ہیں جن کو احادیث میں علماٰءء سو (بُرے عالم) فرمایاگیا ہے۔ جو ’’دین کو دنیا بنانے  اور دنیا کمانے کاذریعہ بنالیتے ہیں ‘‘&&(بحوالہ کافی)&&}}<<’’ولاتشترئوابایٰتی ثمناًقلیلاً وَ ایای فاتقونِ۵>>&&(سورۃ البقرہ آیت ۴۱)&& یعنی :  اور میری آیتوں کو تھوڑی سی قیمت پر نہ بیچو،  اور بس مجھ ہی سے ڈرتے رہو[[۔یہی شیخ حرم ہے جو چراکربیچ کھاتا ہے۔گلیم بوذر و دلق اویس و چادر زہراءؑ]]۔&&(اقبال)&&۔ہمارے بعض ذاکرین بھی دنیوی انعام طے کرکرکے یامانگ مانگ کر ذکر حسین فرماتے ہیں ۔موسم ماہِ محرم عید ہے تیرے لیےخونِ حسینؑ سے لقمے کو تر کرتا ہے تو (جوش) بس یہی فرق ہے سچے  اور جھوٹے علماٰء  اور خدامِ دین میں کہ سچے خدامِ دین کبھی مالی انعامات کا مطالبہ نہیں فرماتے ، البتہ کوئی تحفتاً (ھدیتاً) کچھ از خود دے دے تو اُس کو قبول فرمالیتے ہیں کہ یہ نبی کریمؐ کی سنت ہے۔ &&(مولف)&&جابر بادشاہوں کی حکومت میں سب سے بُری چیز بادشاہوں کے درباری (حاشیہ نشین) بن جانا ہوا کرتا ہے۔ پھر مال ودولت ہر چیز مل جاتی ہے۔ &&(تفسیر نمونہ)&&دولت کے بھوکے نشے میں چُور۔
  26,41,آیت نمبر۴۱:دنیا پرست علماٰء کا سب سے بڑا انعام یہی ہوتا ہے کہ وہ ظالم وجابر بادشاہ کے دربار میں جائیں ( اور حاشیہ نشین بن جائیں ) یہ اُن کی معراج ہوتی ہے۔ یہی فرق ہوتا ہے نبی  اور دنیوی علماٰء میں ، سچےّ  اور جھوٹے علماٰء دین میں ۔{{اسی لیے جناب رسول خداؐ نے ارشاد فرمایا:’’بدترین علماٰءء وہ ہیں جو حکمرانوں کے دروازوں پر بھٹکتے رہتے ہیں ۔  اور بہترین حکمراں وہ ہیں جو علماٰءء کے دروازوں پر آتے ہیں ۔‘‘ &&(الحدیث)&&}}{{امیر المومنین حضرت امام علی ابنِ ابی طالبؑ نے فرمایا:جب کسی عالم کو بادشاہ کے دروازے پر دیکھو تو سمجھ لو کہ اب فقراء وغرباء کے حقوق پر ڈاکہ پڑنے والا ہے۔‘‘&&(نہج البلاغہ)&&}}کسی نبی نے کبھی یہ تمنا ظاہر نہیں کی کہ مجھے اتفاقاً بادشاہ کے دربار میں کرسی مل جائے۔ وہ ہمیشہ خدا کاقُرب حاصل کرنے کی دعائیں  اور تمنائیں کیاکرتے تھے۔ یاپھر اپنی قوم کے لیے  حضرت موسٰی علیہ السلام  کی طرح آزادی کامطالبہ کرتے تھے تاکہ قوم کوآزاد ماحول حاصل ہوسکے۔ &&(مولف)&&
  26,43,آیت نمبر۴۳:جادوگروں نے نظر بندی کرکے اپنی رسیوں  اور چھڑیوں کو زمین پر پھینک دیا تو وہ سانپ بن کر لہرانے لگیں ۔ ادھر  حضرت موسٰی علیہ السلام  نے بحکم خدا اپنے عصا کو زمین پر پھینکا۔ تفسیربرہان میں ہے کہ عصازمین پر پہنچا  اور تانبے کی طرح پگھل کر اژدہا بن گیا جس کااوپر کاہونٹ فرعون کے تخت کے اوپری حصے پر  اور دوسرا ہونٹ تخت کے نیچے کی طرف تھا پس اُس نے دیکھتے ہی دیکھتے جادوگروں کے تمام مصنوعی سانپوں کو ہڑپ کرلیا۔ لوگوں پر اس قدر دہشت طاری ہوئی کہ اُس بے تحاشا بھیڑ میں بھگدڑ پڑ گئی جس سے ہزاروں عورتیں  اور بچے کچل گئے۔ فرعون وہامان کاڈر کے مارے پائخانہ نکل پڑا  اور ایکدم بال سفید ہوگئے  اور بیہوش ہوکر گر پڑے۔ &&(تفسیر انوارالنجف)&&
  26,46,آیت نمبر۴۶:اصل میں جادوگر حضرت موسٰی علیہ السلام  سے پہلے ہی سے متاثر تھے کیوں کہ اُن کو یہ بتادیاگیاتھا کہ  حضرت موسٰی علیہ السلام  جب سوجاتے ہیں ، تو وہ اژدہا اُن کی حفاظت کیاکرتا ہے۔ چنانچہ اُنہوں نے فرعون سے یہ فرمائش کی ، کہ ہم موسیٰ کو بستر خواب پر دیکھنا چاہتےہیں ۔ فرعون نے اُن کو وہ موقع فراہم کیا۔ جب جادوگروں نے دیکھا کہ  حضرت موسٰی علیہ السلام  بستر خواب پر آرام سے سورہے ہیں  اور اژدہا اُن کی حفاظت میں پہرہ دے رہا ہے۔ تب اُن کو یقین ہوگیا کہ یہ جادو نہیں بلکہ معجزہ ہے کیونکہ کہ جادو سونے کے بعد بے اثر  اور باطل ہوجایا کرتا ہے۔ لیکن اس کے باوجود فرعون نے اُن کو مقابلے کے لیے مجبور کیا جس کا بعد میں اُنہوں نے اظہار کیا۔ اسی وجہ سے جادوگروں نے بھرے جمع میں ایمان لانے کانعرہ بلند کیا تھا۔ &&(ملخص)&&&&(تفسیر انوارالنجف جلد۹ص ۱۸۹۔۱۹۰)&&جادوگروں کاسجدے میں گرجانا، اس لیے تھا کہ وہ خود جادو کاحق خوب جانتے تھے۔ وہ فوراً سمجھ گئے کہ  حضرت موسٰی علیہ السلام  نے جوکچھ کیا ہے وہ جادو کے ذریعہ سے نہیں کیاجاسکتا۔اسی لیے اُن کے دل اُن کے قابو میں نہ رہے۔  اور وہ سب کے سب منہ کے بل سجدوں میں گر پڑے۔ &&(تفسیر صافی ۳۶۴)&&جادوگروں کاسجدہ کرنا صرف اعترافِ شکست نہ تھا، بلکہ  حضرت موسٰی علیہ السلام  کی صداقت  اور نبوت کی گواہی تھی کہ(۱) موسٰی بھی سچے ہیں (۲) اُن کاپیغام بھی سچا ہے(۳) اُن کاخدا بھی سچا ہے۔  اور (۴)اُن کاخدا عالمین کاپالنے والا ہے۔ (۵) موسٰی جادوگرنہیں الہٰی طاقت کے نمائندے ہیں ۔&&(تفہیم القرآ ن )&& آیت ۴۶میں اُلقی کالفظ استعمال ہوا ہے جس کے معنی از خود گرادینے کے ہیں ۔ (اس سے معلوم ہوتا ہے سوفیصد یہ سمجھ چکے تھے کہ یہ جادوگری نہیں ہے۔ معجزہ ہے اسی لیے صرف سجدے میں نہیں گرے بلکہ پکاراُٹھے کہ ’’ہم عالمین کے مالک کو مان گئے۔ پھر فرعون کی غلط فہمی کو بھی دور کردیا یہ کہہ کر کہ:’’ ہم موسٰی  اور ہارونؑ کے رب کو مان گئے۔ (ایمان لے آئے )(اس طرح اُنہوں نے فرعون کی ناک بالکل ہی رگڑدی) &&(تفسیر نمونہ)&& جادوگروں میں یہ عجیب وغریب تبدیلی اتنی زبردست تھی کہ وہ یکایک کفر وشرک ، جہالت و معصیت کی تاریکی سے نکل کر ایمان وعمل کی روشنی میں آگئے۔ اپنے سارے مفادات ترک کردیے حتیٰ کہ اپنی جانوں کے نذارنے تک پیش کردیے۔ یہ سب کچھ اُنہوں نے اپنے علم وفن کی حقیقت کے سمجھنے کے بعد ہی کیا۔ یہ سب اُنہوں نے عقل وفکر سے طے کیا۔ &&(تفسیر نمونہ)&&{{جناب رسول خداؐ نے ارشاد فرمایا: ہر دل خداکے ہاتھ میں ہوتا ہے جب خدا چاہتا ہے اُس کے دل کو سیدھے راستے پر لگادیا کرتا ہے‘‘&&(تفسیر فی ظلال القرآن جلد۲)&&}}
  26,48,آیت ۴۸کی تشریح :محققین نے نتیجہ نکالا کہ کسی نبیؐ پر ایمان لانے کاطریقہ یہ ہوتا ہے کہ پہلے اُس کے حقیقی مالک پر ایمان لایا جائے۔ جس طرح جادوگرایمان لائے  اور کہا:<<اٰمنا برب العلمین‘‘>> ہم عالمین کے رب پر ایمان لائے،  اور ہم کہتے ہیں <<لاالہ الا اللہ>>۔ اس کے بعد نبیؐ پر ایمان لایاجائے کیوں کہ جادوگروں نے کہا:رب موسیٰ‘‘ہم کہتے ہیں محمد رسول اللہ۔ اس کے بعد نبیؑ کے وصی پر جادوگرایمان لائے  اور کہا۔>>وھرون<<‘‘ہارون کے رب پر ایمان لائے ہم کہتے ہیں<< ’’وصی رسول اللہ‘‘>>رسول اللہ کے وصی پر ایمان لائے۔ گویا ایمان کی تکمیل کی شرط نبیؑ کے وصی پر ایمان لانا بھی ہے۔ &&(مولف)&&
  26,49,آیت نمبر۴۹:فرعون کی ہٹ دھرمی :ضد اور حق دشمنی کاآخری انجام دیکھیئے کہ فرعون سارے معجزات دیکھ کر بھی، جادوگروں کی گواہی سن کر بھی  حضرت موسٰی علیہ السلام  کوجادوگر ہی کہہ رہا ہے۔  اور سورہ اعراف میں خداوندعالم نے ارشاد فرمایا: کہ@@ فرعون نے موسٰی کو سیاسی چالباز قرار دیا  اور کہا۔ ’’یہ ایک سازش ہے جو تم لوگوں نے مل کر اس شہر میں تیار کی ہے۔ تاکہ تم یہاں کے مالکوں کواقتدار سے نکال پھینکو۔‘‘@@ &&(سورۃ الاعراف آیت ۱۲۳)&&اس طرح فرعون عوام کو دھوکہ دے رہا ہے کہ جادوگروں کاایمان لانا حقیقی ایمان نہیں ہے، بلکہ ایک سازش، ملی بھگت  اور مکاری ہے موسٰی  اور جادوگرپہلے ہی سے طے کرچکے تھے کہ ہم جادوگر ہارجائیں گے سجدے کرلیں گے  اور اس طرح اقتدار پر ہمارا قبضہ ہوجائے گا۔ &&(تفہیم القرآن )&& کیوں کہ فرعون سالہاسال سے حکمرانی کررہاتھا لہٰذا اُسے قطعاً یہ اُمید نہ تھی کہ اُس کی اجازت کے بغیر کوئی بھی تنکا ہل سکتا ہے اس لیے پہلے تو اس بات پر بگڑا کہ جادوگر میری اجازت کے بغیر کیسے ایمان لے آئے ؟ پھر غنڈہ گردی پر اُتر آیا۔ اور جادوگروں کو قتل کرنے کی دھمکیاں دینے لگا، وہ بھی سخت اذیت دے دے کر۔ہر دور کے جابر وظالم حکام یہی طریقہ انبیاءؑ اوصیاء  اور مومنین کے ساتھ اختیار کرتے رہے۔ عقلی دلائل اُن کے پاس مفقود تھے۔ جب کوئی دلیل اُن کے پاس نہ ہوتی تھی تو وہ اپنی مادّی طاقت استعمال کرکے اُن کو قتل کرادیتے تھے۔ &&(تفسیر نمونہ)&&گفتارِ صدق مایہ آزار می شود۔چوں حرفِ حق بلند شود دار می شود &&(عرفی)&& یعنی : (حق بات کہنا ہمیشہ مصیبتوں کو دعوت دیتی ہے۔ جب حق با ت بلند ہوتی تو وہ پھانسی کاپھندہ بن جایا کرتی ہے) ۔فرعون کامطلب یہ تھا کہ: اے جادوگرو!تم لوگوں نے موسٰی کے ساتھ ساز باز کررکھی ہے  اور یہ کہ موسٰی نے کچھ کرتب تم کو سکھادئیے تھے۔  اور کچھ نہیں سکھایاتھا۔اس لیے موسٰی تم پر غالب آگیا ہے۔ &&(تفسیر ماجدی)&&فرعون کااصل مقصد یہ تھا کہ اُس کی قوم شک میں پڑ جائے۔  اور جادوگروں کی طرح موسٰی پر ایمان نہ لے آئے۔ (ورنہ اُس کااقتدار جاتا رہے گا۔  اور موسٰی حکمران بن جائیں گے) &&(تفسیر صافی ص ۳۶۴)&&
  26,51,آیت نمبر۵۱:اعترافِ گناہ  اور اُمید واثق:پھر جادوگروں نے سلسلہ کلام کو آگے بڑھاکر اعتراف کیا کہ ہم ماضی میں بہت گناہ کرچکے ہیں کہ ہم خدا کے رسول  حضرت موسٰی علیہ السلام  کے مقابلے پر آکھڑے ہوئے، ہم نے فرعون جیسے بدمعاش کاساتھ دیا۔ حق سے جنگ کی ، گمراہی میں اپنی زندگی گذاری ، مگر ہمیں اپنے قتل ہوجانے  اور ایمان لانے سے اُمید ہے کہ ہمارا مالک ہمارے گناہ معاف کردے گا۔ کیوں کہ ہم سب سے پہلے اُس پرایمان لائے ہیں ۔ اس لیے ہم تمہاری دھمکیوں سے نہیں ڈرتے ۔سب سے پہلے ایمان لانے کے معنی(۱) اس میدان میں ہم سب سے پہلے ایمان لائے ہیں (۲) یافرعون کے حامیوں میں ہم سب سے پہلے ایمان لائے ہیں ۔(۳) یا شربتِ شھادت پی کر ہم سب سے پہلے ایمان لائے ہیں ۔ اس سے یہ بھی معلوم ہوتا ہے کہ شاید اُس وقت تک کوئی  اور  حضرت موسٰی علیہ السلام  پر بظاہر ایمان نہ لایا تھا۔ &&(تفسیر نمونہ)&&فرعون کی قوم میں سب سے پہے ایمان لانے والے یہی جادوگر تھے۔ ورنہ بنی اسرائیل ان سے پہلے ایمان لاچکے تھے۔ ( اور مومن آلِ فرعون بھی ان سے پہلے ایمان لاچکا تھا) &&(تفسیر انوارالنجف)&&
  26,52,آیت نمبر۵۲:جب  حضرت موسٰی علیہ السلام  اتمام حجت کرکے حق کو باطل سے الگ کرچکے  اور مومن، کافر الگ الگ ہوگئے تب  حضرت موسٰی علیہ السلام  نے بحکم خدا بنی اسرائیل کو رات کے وقت سفر کرنے کاحکم دیا، تاکہ فرعونیوں کو فوراً علم نہ ہوسکے۔ &&(تفسیر نمونہ)&&ظاہر ہے کہ جب اتنی بڑی تعداد میں لوگ سفر کریں گے تو یہ بات زیادہ دیر تک چھپی نہیں رہ سکتی تھی۔ جاسوسوں نے فرعون کو اطلاع دے دی،  اور فرعون نے مختلف شہروں سے لشکر جمع کرنے شروع کردیے۔ &&(تفسیر نمونہ)&&ساتھ ہی لوگوں کے حوصلے بلند رکھنے کے لیے نفسیاتی طریقہ بھی اختیار کیا،  اور یہ اعلان کیا کہ بنی اسرائیل ایک چھوٹا سا گروہ ہے، وہ بھی کمزور ، غیر مسلح، اس لیے گھبرانے کی کوئی ضرورت نہیں ۔ فتح بہرحال ہماری ہوگی۔&&(تفسیر نمونہ)&&
  26,54,آیت نمبر۵۴:<<’’شرذمۃ‘‘>> چھوٹے سے گروہ کو کہتے ہیں ۔ یاکسی چیز سے کچھ بچ رہنے کو کہتے ہیں  اور کٹے پھٹے لباس کو بھی کہتے ہیں ۔ گویا بنی اسرائیل پراگنداہ سی قوم ہے۔ یعنی تعداد میں بھی ہم سے کم ہیں ، اس لیے جلدہی ہم اُن کو قابومیں لے آئیں گے ۔&&(مفردات القرآن امام راغب)&&
  26,55,آیت ۵۵کی تشریح: فرعون کامطلب یہ تھا کہ بنی اسرائیل کی حرکتوں کوہم کہاں تک برداشت کریں ؟ ان سرکش غلاموں کے ساتھ کب تک نرمی برتیں ؟انہوں نے ہمیں غصہ دلایا ہے آخر مصر کے کھیت اب کون جوتے گا؟ہمارے گھر کون بنائے گا؟ہمارے کام  اور ہماری نوکری اب کون کرے گا؟ پھر یہ کہ ہمیں اُن لوگوں سے خطرہ بھی ہے، کہیں کل وہ ہم سے مقابلہ کرنے نہ آجائیں ۔ &&(تفسیر نمونہ)&&
  26,56,آیت ۵۶کی تشریح: فرعون کی یہ باتیں اُس کے چھپے ہوئے خوف کو ظاہر کررہی ہیں ۔ ایک طرف تو فوجیں جمع کررہا ہے جو اس بات کاثبوت ہے کہ وہ  حضرت موسٰی علیہ السلام  سے خوفزدہ ہے۔ دوسری طرف اپنے خوف  اور خفت کوچھپانا بھی چاہتا ہے کہ بھلا غلام ، کمزور قوم سے کیا ڈرنا۔ اس لیے وہ اپنا پیغام اس اندازسے بھیج رہا ہے کہ یہ بنی اسرائیل چیز ہی کیا ہیں ۔ یہ ہمارا بال بیکا نہیں کرسکتے۔ اصل میں اُنہوں نے کچھ ایسی حرکتیں کی ہیں جن کی ہم اُن کو سزا دینا چاہتے ہیں ہم کسی خوف کی وجہ سے فوجیں جمع نہیں کررہے ہیں ، بلکہ احتیاطی تدابیر کررہے ہیں ۔ &&(تفہیم القرآن )&&
  26,57,آیت نمبر۵۷:<<’’فاخرجنھم‘‘>> یعنی ہم نے فرعون  اور اس کی جماعت کو مصر سے اس ترکیب سے نکالا  اور بنی اسرائیل کو فرعون  اور اس کے لشکر کی غرقابی کے بعد تسلط عطا کیا۔ باقی قرآنی آیات  اور تفاسیر،  اور کتبِ سیر سے پتہ چلتا ہے کہ بنی اسرائیل مصر واپس نہیں گئے، لیکن یہاں اُن کامصر پرتسلط ظاہر ہے توشاید پہلے مصر پر قبضہ کرکے دوبارہ آمادہ سفر ہوئے ہوں  اور فلسطین کی طرف جاکر آباد ہوئے ہوں ، تیہ کے جنگل میں سرگردانی کاواقعہ بھی شاید اس کے بعد کا ہے _(واللہ علم) &&(تفسیر انوارالنجف)&&
  26,58,آیت نمبر۵۸:<<’’مقامِ کریم‘‘>> محلات  اور قیمتی عمارتوں کو کہتے ہیں ۔ لیکن بعض مفسرین نے عیش ونشاط کی محفلیں مراد لی ہیں ۔  اور بعض مفسرین نے منبر کے لکھے ہیں جس پر بیٹھ کر حکام احکامات صادر کرتے ہیں یا خطباءخطبے دیتے ہیں ۔ &&(تفسیر نمونہ)&& ( قیمتی محلات میں تمام چیزیں آجاتی ہیں ) &&(مولف)&&
  26,59,آیت ۵۹ کی تشریح: مطلب یہ ہے کہ فرعون کی چھوڑی ہوئی چیزیں بنی اسرائیل کو حضرت دائودؑ  اور حضرت سلیمانؑ کے زمانے میں ملیں ۔البتہ بعض مفسرین نے یہ بھی لکھا ہے کہ فرعون کے غرق ہونے کے بعد کچھ بنی اسرائیل مصر واپس آگئے تھے۔ &&(تفسیر مجمع البیان)&&یہ بھی ممکن ہے کہ بنی اسرائیل کے کچھ بوڑھے ، بچے معذور لوگ  حضرت موسٰی علیہ السلام  کے ساتھ ہجرت ہی نہ کرسکے ہوں  اور مصر میں رہ گئے ہوں ،  اور فرعونیوں کے غرق ہونے کے بعد اُن کے محلوں ، باغوں پر قابض ہوگئے ہوں ۔ &&(فصل الخطاب)&&یہ بھی ممکن ہے کہ بنی اسرائیل کو ہم نے وہی باغ چشمے  اور محلات نہیں بخشے جوفرعون کے لوگ چھوڑ گئے تھے، بلکہ مطلب یہ ہے کہ ہم نے ایک طرف فرعونیوں کو اُن نعمتوں سے محروم کیا  اور دوسری طرف بنی اسرائیل کو یہی نعمتیں فلسطین کی زمین پر عطا کیں ۔ اس طرح بنی اسرائیل فلسطین کی زمین پر باغوں ، چشموں ، مکانوں  اور خزانوں کے مالک بنادیے گئے۔ &&(تفہیم القرآن )&& اسی بات کو سورۃ الاعراف میں یوں ارشاد فرمایا:@@’’تب ہم نے فرعونیوں سے انتقام لیا  اور اُنہیں سمندر میں غرق کرڈالا، کیوں کہ اُنہوں نے ہمارے دلائل  اور نشانیوں کو جھٹلایا تھا،  اور وہ اُن سے بے پرواہ ہوگئے تھے ۔پھر اُن کی بجائے ہم نے اُن لوگوں کو جو کمزور بنا کررکھے گئے تھے اُس ملک کے مشارق ومغارب کاوارث (مالک) بنادیا، جسے ہم نے برکتوں سے مالا مال کیاتھا۔‘‘@@&&(سورۃ الاعراف آیت ۱۳۷،۱۳۶)&&یہ برکتوں والی زمین فلسطین کی زمین تھی۔ قرآن میں جب بھی برکتوں والی زمین کاذکر آتا ہے اُس سے مراد فلسطین لیاگیا ہے۔ &&(تفسیر کبیر)&&
  26,60,آیت نمبر۶۰:<<’’مشرقین‘‘>>کے معنی صبح سویرے کے بھی آتے ہیں ۔ یعنی فرعون نے بنی اسرائیل کا تعاقب کیا،  اور صبح ہوتے ہی اُن کو جاپکڑا۔لیکن بعض مفسرین نے <<’’مشرقین‘‘>>سے مراد مشرق کی جانب لیا ہے۔ کیوں کہ بنی اسرائیل مشرق کی جانب ہجرت کرکے گئے تھے۔ بیت المقدس کی زمین مصر سے مشرق کی جانب ہے۔ &&(تفسیر نمونہ)&&بنی اسرائیل نے فرعون کے لشکرکو پیچھے آتے دیکھا،  اور اُن کے سامنے دریا موجیں ماررہاتھا، خوفزدہ ہوکر کہنے لگے بس اب ہم پکڑے جائیں گے ۔۔&&(تفسیر نمونہ)&&لیکن  حضرت موسٰی علیہ السلام  پرذرّہ برابرخوف طاری نہ ہوا کیوں کہ وہ جانتے تھے کہ خدا ہمارے ساتھ ہے اسی لیے فرمایا: تم گھبراتے کیوں ہو ہمارے ساتھ ہمارا خدا ہے وہی ہماری ہدایت فرمائے گا۔
  26,63,آیت نمبر۶۳:سمندر کاپانی پہاڑ بن گیا:فوراً موسٰی کووحی ہوئی کہ اس اپنے عصاءکو جس سے تم فرعون کے سامنے عذاب لائے تھے۔ سمندر پر دے مارو، اب یہی عصاءبنی اسرائیل کے لیے رحمت بن جائے گا۔ عصاءمارتے ہی یکایک عجیب منظر بنی اسرائیل کی آنکھوں کے سامنے نظر آنے لگا۔ سمندر پھٹ گیا، پانی کے کئی کئی ٹکڑے ہوگئے ،  اور ہرٹکڑا ایک عظیم پہاڑ بن گیا۔ &&(تفسیر نمونہ)&&<<’’انفلق‘‘>><<’’فلق‘‘>>کے مادّے سے ہے۔ جس کے معنی پھٹ جانے کےہوتے ہیں ، جدا جدا ہوجانےکے ہوتے ہیں ۔ (بروزن حلق) فلق  اور فرق کے درمیان یہ فرق ہوتا ہے کہ فلق کے معنی پھٹ جانا،  اور فرق کے معنی جدا ہونے کے ہوتے ہیں ۔  اور <<’’طود‘‘>>کے معنی بہت بڑا پہاڑ۔&&(مفردات القرآن امام راغب)&&مفسرین نے اس میں اختلاف کیا ہے کہ وہ دریائے نیل تھا یابحر قلزم ۔بنی اسرائیل مصر سے سینا کی طرف آرہے تھے اُس راستہ میں دریائے نیل حائل نہیں ہوتا۔ دریائے قلزم ہی زیادہ قرین قیاس ہے۔ &&(تفسیر انوارالنجف)&&
  26,66,آیت نمبر۶۶:ٹھیک اُس وقت جب بنی اسرائیل کاآخری آدمی سمندرسے نکل رہا تھا، فرعون کے لشکر کا آخری آدمی سمندر میں داخل ہورہا تھا، خدا نے پانی کوحکم دیا کہ اپنی حالت پرلوٹ آ۔ اچانک سمندر کی موجیں ٹھاٹھیں مارنے لگیں ، فرعون  اور اُس کالشکر گھاس پھوس کی طرح پانی میں غوطے کھانے لگے۔&&(تفسیر نمونہ)&&کیوں کہ  حضرت موسٰی علیہ السلام  کے معجزات کو دیکھ کر صرف چندلوگ فرعونیوں میں سے ایمان لائے تھے، مثلاً فرعون کی بیوی ایمان لائی تھی،  اور وہ جسے قرآن نے مومنِ آلِ فرعون کہا ہے۔ ( یعنی حزقیل مومنِ آل فرعون جو اپنے ایمان کو لوگوں  اور خود فرعون سے چھپائے ہوئے تھا)
  26,68,آیت نمبر۶۸:آخر میں خدا کاخود کو <<’’عزیز‘‘>> یعنی غالب طاقت والا فرمانا اس لیے ہے کہ وہی پانی جو فرعونیوں کی زندگی کاسامان تھا، اُسی پانی سے اُن کو تباہ کردیاگیا۔خداوندعالم کو ظالموں کو سزا دینے کے لیے آسمان سے فرشتے اُتارنے نہیں پڑے، بلکہ خدا نے فرعونیوں کو دریائے نیل میں غرق کردیا۔ دریا ہی کو اُن کاقبر ستان بنادیا۔ &&(اللہ اکبر)&& خداوندعالم نے یہاں پر خود کو رحیم شاید اس لیے بھی فرمایا کہ اُس نے فرعونیوں کو باوجود اُن کی سرکشی کے مہلتوں پر مہلتیں دیں ، اُس کایہی قانون سب کے لیے ہوا کرتا ہے۔ &&(تفسیر نمونہ)&&خدا کی یہ صفت<<’’عزیز‘‘>> کے معنی عزت ، غلبہ ، طاقت خود اپنی قوت کے بل پر کام کرنے والے کے ہوتے ہیں ۔ اس صفت کاتقاضا یہ ہے کہ خدا جب چاہے، جہاں چاہے اپنے مجرموں ، دشمنوں کو سزادے سکتا ہے مگر اُس کی صفت رحیمی کاتقاضا یہ ہے کہ وہ فوراً گرفت نہ فرمائے، بلکہ اصلاحِ حال کی مہلت عطا فرمائے۔ (تفسیر کبیر امام <<’’عزیز‘‘>> کے ایک معنی دشمن سے بدلہ لینے والے کے بھی ہوتے ہیں )۔ &&(تفسیر صافی ص۳۶۵)&&
  26,71,آیت نمبر۷۱:عربی ادب میں <<’’اب‘‘ >>کالفظ باپ  اور چچا دونوں کے لیے بولا جاتا ہے۔ یہاں <<’’اب‘‘>> سے مراد چچا ہے۔ حضرت ابراہیمؑ کابُتوں کو<<’’ما‘‘>>&&(کیاچیز)&& کہنا تحقیر کے لیے ہے۔&&(تفسیر نمونہ)&&بت پرستوں نے بت پرستی کے لیے<<’’نظل‘‘>> کالفظ استعمال کیا جو ایسے کاموں کے لیے بولا جاتا ہے جو دن کے وقت انجام دیے جائیں ،  اور جب یہ لفظ مضارع کے صیغے میں آتا ہے تو اس میں استمرار، دوام یعنی مستقل عمل کرنے کے معنی پیدا ہوجاتے ہیں ۔ &&(مفردات القرآن امام راغب)&&<<’’عاکف‘‘>><<’’عکوف‘‘ >>کے مادُے سے ہے جس کے معنی کسی چیز کی طرف بہت زیادہ توجہ کرنے کے ہیں ،وہ بھی ادب  اور احترام کے ساتھ۔&&(تفسیر نمونہ)&&
  26,72,آیت نمبر۷۲:محققین نے نتیجہ نکالا کہ معبود وہ ہوتا ہے جو اپنی عبادت کرنے والوں کی دعائیں فریادیں سن سکے، اُن کی مدد کرسکے، اُن کو فائدہ یانقصان پہنچانے یامصیبت میں کام آنے پر مکمل قدرت رکھتا ہو۔ جبکہ بتوں میں ان میں سے کوئی ایک بھی نہیں پائی جاتی۔ &&(تفسیر نمونہ)&&
  26,77,آیت نمبر۷۷:حضرت ابراہیمؑ نے بتوں کو اپنا دشمن اس لیے فرمایا کہ خداوندعالم نے سورہ مریم میں ارشاد فرمایا ہے۔@@’’ان مشرکوں نے خدا کے سوا دوسروں معبود (خدا) بنارکھے ہیں تاکہ وہ اُن کے لیے عزت کاذریعہ ہوں ۔ہرگز نہیں ۔ عنقریب وہ وقت آئے گا جبکہ وہ اُن کی عبادت کاانکار کردیں گے ،  اور اُلٹے اُن کے مخالف ہوجائیں گے۔‘‘@@&&(سورۃ مریم آیت ۸۷۔۸۳)&&پھر ملاحظہ فرمائیں کہ حضرت ابراہیمؑ علیہ السلام نے یہ نہیں فرمایا کہ یہ بت تمہارے دشمن ہیں ، بلکہ فرمایا کہ ’’یہ میرے دشمن ہیں ‘‘ اگر یہ فرماتے کہ یہ بت تمہارے دشمن ہیں تو وہ احمق ضد میں مبتلا ہوجاتے  اور کہتے کہ بتائو یہ کیسے ہمارے دشمن ہو گئے؟ جب کہا کہ میرے دشمن ہیں تو اب انہیں سوچنے پر مجبورکردیا کہ اپنے بھلے بُرے کی فکر کریں جس طرح حضرت ابرہیمؑ اپنے بھلے بُرے کی فکر رہے ہیں ۔ اس طرح حضرت ابراہیمؑ نے ہر شخص کی فطرت کو للکارا۔کیوں کہ ہر شخص اپنا بھلا ضرور چاہتا ہے،  اور جان بوجھ کر کبھی اپنا نقصان نہیں چاہتا۔ اس طرح اُنہیں سوچنے پر مجبور کردیا۔ نیز یہ بتادیا کہ تمام معبودوں میں صرف  اور صرف ایک اللہ ہی تو ہے جو عالمین کامالک  اور پالنے والا ہے اُس کی عبادت کرنا، دشمن کی عبادت کرنا نہیں ہے، بلکہ اصلی مالک  اور پالنے والے کی عبادت کرنا ہے۔ غرض حضرت ابراہیمؑ نے بتادیا کہ تمہارے پاس بتوں کی عبادت کے لیے باپ دادائوں کے طریقےپر چلنے کے سوا کوئی دلیل نہیں ہے جبکہ میرے پاس تو ایک اللہ کی عبادت کے جواز کے لیے بہت سی دلیلیں ہیں ۔ جو اگلی آیتوں میں بیان ہوں گی یہاں پر دلیل دی گئی ہے کہ۔ وہ ہمارا خالق ہے مخلوق کو اپنے ہی خالق کی بندگی کرنی چاہیے غیر مخلوق کی بندگی کرنے کاکوئی جواز ہی نہیں ۔ (بلکہ بے عقلی ہے) اس لیے تمام باطل معبودوں میں جن کی دنیا والے عبادت کررہے ہیں ، صرف ایک اللہ نے جس کی بندگی میں کرتا ہوں ، مجھے بھلائی دکھائی دی ہے۔کیوں کہ صرف وہی عبادت کامستحق ہے۔ اس لیے وہ عالمین کامالک  اور پالنے والا ہے۔ تمام مشرک بھی یہ مانتے تھے کہ تمام موجودات اللہ ہی کی مخلوق ہیں ۔ اسی لیے میں صرف اُس کی عبادت کرنے کو درست سمجھتا ہوں جس نے مجھے بھی پیدا کیاہے۔ دوسرا کوئی بھی اس بات کامستحق نہیں ہے کہ اُس کی عبادت کی جائے، کیوں کہ اُس کامیری پیدائش میں کوئی حصہ نہیں ۔ &&(تفہیم)&&<<’’فانھم‘‘>>ضمیر غائب ذوی العقول کے لیے لائی گئی ہے۔حالانکہ جن کی وہ عبادت کرتے تھے بُت غیر ذوی العقول تھے۔ گویا مطلب یہ ہے کہ تمہارے معبود  اور تم  اور تمہارے بُت پرست آباءسب کے سب میرے دشمن ہیں ، سوائے ایک معبود کے جو تمام جہانوں کا پالنے والا ہے، وہی خالق ہے،  اور اچھائی کی طرف رہبری کرنے والا ہے، وہی رزاق ہے جو طعام  اور پانی عطا فرماتا ہے ،  اور بیماری شفاءبھی وہی عطا فرماتا ہے  اور وہی موت وحیات کامالک ہے،  اور اُسی سے ہماری اُمیدیں وابستہ ہیں ۔ کہ وہ قیامت کے روز ہماری لغزشوں سے معافی دے دے۔ &&(تفسیر انوارالنجف)&&
  26,79,آیت نمبر۷۹:ربوبیت کے پہلے ہی مرحلے میں تخلیق  اور ہدایت کے بعد مادی نعمتوں کاذکر فرماتے ہیں کہ وہی خدا تو ہے جو مجھے کھلاتا پلاتا ہے۔گویا میں ساری نعمتیں خدا ہی کی دین سمجھتا ہوں ۔&&(تفسیر نمونہ)&&محققین نے لکھا کہ حضرت ابراہیم علیہ السلام نے اپنے بیمار ہونے کی نسبت اللہ کی طرف نہیں دی، بلکہ یوں فرمایا: جب میں بیمار ہوتا ہوں ۔‘‘ کیوں کہ انسان اپنی ہی غلطیوں سے، کھانے پینے یا دوسری عادتوں کی افراط وتفریط کے سبب بیمار ہوتا ہے۔اسی لیے اللہ نے فرمایا:’’جو مصیبت تم پر آتی ہے وہ (اکثر) تمہارے ہی کرتوت کی وجہ سے آتی ہے۔‘‘&&(القرآن )&& سورۃ الشوریٰ آیت ۳۰)&&اللہ تعالیٰ کی بندگی کی ایک دلیل یہ بھی ہے کہ اُس نے صرف پیدا ہی نہیں کیا، بلکہ ہماری رہنمائی بھی کی، ہرضرورت کی چیز فراہم فرمائی۔ پھر ان تمام سامانوں سے فائدہ اُٹھانے کے لیے جس جس طاقت  اور صلاحیت کی ضرورت تھی وہ بھی عطا فرمائی۔
  26,80,آیت نمبر۸۰ـ پھر بیماریوں کے دفاع کے لیے اُس نے ہمارے جسم میں دفاعی نظام قائم فرمایا، پھر ہر مرض کی دوا پیدا کی۔&&(تفہیم القرآن )&& اب حضرت ابراہیمؑ فرمارہے کہ موت وزندگی بھی خدا کی تخلیق ہے وہی مجھے مارے گا،  اور وہی پھر مجھے زندہ کرے گا جی ہاں !میری موت بھی اُسی کی طرف سے ہوگی،  اور میری نئی زندگی بھی اُسی کی عطا سے ہوگی۔&&(تفسیر نمونہ)&&جوکچھ ہوا، ہوا کرم سے تیرے۔جو کچھ ہوگا تیرے کرم سے ہوگاپھر جب میں میدانِ حشر میں قدم رکھوں گا، تو میرا وہی خدا ہے جس سے مجھے یہ اُمید ہے کہ وہ قیامت کے دن میرے گناہ معاف کردے گا۔ ظاہرہے کہ انبیاء کرامؑ معصوم ہوتے ہیں ، مگراللہ اُن کی انتہائی انکساری کے سبب سے اُن کو اپنی رحمت میں جگہ دے گا۔ کیوں کہ وہ اپنی نیکیوں کو بھی اپنے گناہ سمجھتے تھے۔ کیوں کہ وہ اپنی نیکیوں کو خدا کی عظمت کے مقابلے پر بالکل حقیر اور خدا کے انعامات کے مقابلے پر بالکل ناچیز سمجھتے ہیں ۔ ممکن ہے گناہوں سے مراد اُن کے ترک اولیٰ ہوں ۔یاپھر خدا کی نعمتوں کے سامنے اپنی نیکیوں کو اس قابل ہی نہیں سمجھتے کہ وہ قابل قبول ہوں ۔ محققین نے نتیجہ نکالا کہ خدا کی معرفت اُس کی خالقیت سے ہوتی ہے یا پھر ربوبیت سے۔&&(تفسیر نمونہ)&&<<’’غفر‘‘>>کے لفظ کے معنی لباس پہنا دینے، کے ہوتے ہیں ۔ایسا لباس جو ہر قسم کے میل  اور گندگی سے بچاسکے،  اور خوب اچھی طرح سے ڈھانپ لے۔ یہاں آیت ۸۳میں ’’یغفرلی‘‘کے یہی معنی ہیں کہ’’خدا سے مجھے یہی اُمید ہے کہ وہ مجھے اپنی رحمت (کے لباس) سے اچھی طرح ڈھانپ لے گا۔‘‘اس لیے اس آیت سے یہ نتیجہ نکالنا غلط ہے کہ انبیاء کرامؑ سے بھی غلطیاں ہوتی ہیں ۔ بلکہ اُن کی دعائے مغفرت کامطلب یہ ہوتا ہے کہ اے خدا!ہمیں اپنی رحمتوں سے ڈھانپ لے۔ (یا) اگر <<’’غفر‘‘>>کے دوسرے معنی غلطیاں معاف کرنا، لیاجائے، تو پھر اُس کی حقیقت یہ ہے کہ انبیاءؑ کے دلوں میں خدا کی عظمت یابڑائی کااحساس بہت زبردست ہوتا ہے۔ جس کاسبب اُن کی وہ معرفت ہوتی ہے جو وہ خدا کے لیے رکھے ہیں اسی عظمت کے احساس کی وجہ سے اُن کو اپنی تمام ترنیکیاں بہت قلیل  اور کم لگتی ہیں ۔  اور خدا کے احسانات بہت زیادہ لگتے ہیں ۔ اسی کمی کے احساس کی وجہ سے وہ خدا سے معافیاں طلب کرتے ہیں جبکہ وہ گناہوں سے بری  اور معصوم ہوتے ہیں ۔ ان کایہ استغفار کمالِ بندگی ، کمال معرفت ، کمال عجز، کمالِ انکساری  اور کمالِ علم کانتیجہ ہوتا ہے۔ &&(فصل الخطاب)&&<<’’یغفرلی‘‘>>یہاں سوال یہ پیدا ہوتا ہے کہ جب انبیاء معصوم ہوتے ہیں تو حضرت ابراہیمؑ نے اپنی لغزشوں کی بخشش کی اُمید کیوں ظاہر کی ہے؟‘‘ جواب اس کایہ ہے کہ اس سے مراد اُمت کی لغزشیں ہیں جن کے آپؑ شفیع ہوں گے  اور چوں کہ معافی کے لیے شفاعت آپؑ کریں گے، اس لیے نسبت اپنی طرف دے دی جس طرح سورہ فتح میں <<لیغفرلک اللہ>> حضوراکرمؐ کو کہا گیا ہے۔ نسبت حضورؑ کی طرف  اور مراد اُمت کے گناہ ہیں جن کی آپؐ شفاعت فرمائیں گے۔&& ( تفسیرانوار النجف)&&
  26,83,آیت نمبر۸۳:اب خدا کی معرفت کے بعد خدا سے دعائوں کاسلسلہ شروع ہوجاتا ہے۔ معلوم ہوا کہ خدا کی نعمتوں کے اعتراف کے بعد خدا سے دعائیں مانگنی چاہئیں ۔حضرت ابراہیمؑ کی سب سے پہلی دعاء علم ودانش کی طلب ہے۔  اور پھر(۲) نیک لوگوں سے ملحق ہونے کی دعاء ہے (معلوم ہوا کہ نیک لوگوں سے ملحق ہونے کے لیے سب سے پہلے طلب علم ضروری ہے) &&(تفسیر نمونہ)&&حکم  اور حکمت کی بنیاد ایک ہی ہے۔حکمت کے معنی علم  اور معرفت کے ذریعہ حق تک پہنچنا ہوتا ہے۔ گویا حکمت موجودات عالم کی حقیقت  اور نیک اعمال کی معرفت حاصل کرنے کو کہتے ہیں ۔ گویا حکمت وہ صلاحیت ہے کہ جس سے انسان حق کوحق  اور باطل کو باطل جان سکے۔ یہی حکمت حضرت لقمانؑ کو خدا سے عطا ہوئی تھی۔ حکمت ایک ایسا صحیح فیصلہ ہے جس میں غلطی کاامکان نہ ہو۔ حضرت ابراہیمؑ نے سب سے پہلے صلاحیت کاسوال کیا ہے۔ &&(تفسیر نمونہ)&&یہاں ’’حکم‘‘ سے مراد نبوت نہیں ۔ اس لیے کہ حضرت ابراہیمؑ خود نبی ہیں  اور نبوت کاعہدہ مانگنے سے نہیں ملاکرتا۔ اس لیے یہاں <<’’حکم‘‘>> سے مراد حکمت، علم، فہم، صحیح قوتِ فیصلہ کے ہیں ۔ ایسی ہی دعاء جناب رسول خداؐ نے بھی مانگی تھی۔<<’’ ارنا الاشآءکما ھی‘‘>> یعنی @@(اے خدا ہم کو اس قابل بنادے کہ ہم ہر چیز کو ویسا ہی دیکھیں جیسی کہ وہ واقعاً ہے‘‘@@&&(تفہیم القرآن)&&ہر پاکیزہ روح کی یہی تمنا ہوتی ہے کہ خدا اُس کو بداخلاق  اور فاسق سوسائٹی سے بچائے رکھے  اور نیک لوگوں کے ساتھ زندگی گزارنے کاموقع عطافرمائے۔ اس لیے کہ انسان کے بننے  اور بگڑنے کا گہرا تعلق تخم کی تاثیر کے بعد ماحول کے اثر سے مرتب ہوتا ہے ۔&&(مولف)&&سوال:یہ ہے کہ حضرت ابراہیمؑ <<’’حکم‘‘>>حکمت  اور نبوت کی منزلت پر فائزتھے،  اور صالحین میں بھی شامل تھے، پھر یہ دعاء کیوں مانگی؟جواب:یہ ہے کہ علم وحکمت کی کوئی حد نہیں ہوا کرتی۔حضرت ابراہیمؑ کا مطلب یہ ہے کہ ’’مجھے علم کی بلندیاں  اور عطا فرما۔ علم کی انتہاءدیکھئے کہ اولوالعزم پیغمبر ہوتے ہوئے بھی علم کے اضافے کی دعاء مانگ رہے ہیں ۔ &&(تفسیر نمونہ)&&علم وحکمت:{{جناب امیرالمومنین علیہ السلام نے ارشاد فرمایا:<<’’العلم ینجدوالحکمۃ ترشد‘‘>> یعنی :علم تم کو بلند مقام پر پہنچائے گا  اور حکمت تم کو صحیح راستہ کی نشاندہی کرے گی۔‘‘پھر ارشاد فرمایا:<< خذالحکمۃ انی کانت فان الحکمۃ تکون فی صدر المنافق فتلجلج فی صدرہٖ حتی تخرج فتسکن الی صواحبھا فی صدرِ المومن‘‘>> یعنی حکمت کی بات جہاں کہیں ہو، اُسے حاصل کرلو۔کیوں کہ حکمت منافق کے سینے میں بھی ہوتی ہے لیکن جب تک اُس (کی زبان) سے نکل کرمومن کے سینے میں پہنچ کردوسری حکمتوں کے ساتھ بہل نہیں جاتی تڑپتی رہتی ہے‘‘ مزید فرمایا ’’حکمت مومن کی ہی گمشدہ چیز ہے اسے حاصل کرو، اگرچہ منافق سے لینا پڑے۔‘‘&&(نہج البلاغۃ ص ۸۲۷)&&}}
  26,84,آیت نمبر۸۴:پھرحضرت ابراہیمؑ یہ دعاء فرماتے ہیں کہ’’آنے والی قوموں میں میرے لیے ذکر خیر اچھی شہرت جاری فرما۔مجھے اُن کے لیے نمونہ عمل بنا دے۔ &&(تفسیر نمونہ)&&{{امیر المومنین حضرت امام علی ابن ابی طالبؑ سے روایت ہے کہ: ’’خداوند عالم کسی کو اگر سچائی کی زبان ( یعنی ) اچھی شہرت یانیک نامی عطا فرمائے تو وہ اُس مال سے بہتر ہے جسے وہ خود کھائے  اور گھر والوں کے لیے چھوڑ جائے۔‘‘آیت کامطلب یہ ہے کہ’’اے خدا!میری اولاد میں سے ایک ایسے سچے انسان کو پیدا فرما جو میرے لائے ہوئے دین کی تجدید کرے۔  اور لوگوں کواُسی دین کی طرف بلائے جس کی طرف میں بلارہا ہوں ۔‘‘اس طرح حضرت ابراہیم ؑکی اس دعاء کے حقیقی مصداق حضرت محمد مصطفےٰصلی اللہ علیہ و آلہ وسلم ،  اور آپؑ کے بعد {{حضرت امام علی مرتضےٰ علیہ السلام  اور پھر اُن کی اولاد سے ائمہ طاہرین ہیں ۔&&(تفسیر صافی ۳۶۶بحوالہ کافی وتفسیر قمی)&&}}حقیقت بھی یہی ہے کہ اوّلین معنی میں سچائی کی زبان وہی شخص ہوسکتے ہیں رسول خداؐ کی سب سے پہلے تصدیق فرمائیں ۔ ہر سخت سے سخت ترین موقع پر رسولؐ کے مددگار ثابت ہوں جن کو خود خدا نے رسولؐ کا شاہد، قرار دیا ہو۔ جن کی وجہ سے رسولؐ کی جان محفوظ رہی ہو اور اس طرح حضرت ابراہیمؑ کی دعاء پایہ تکمیل کو پہنچی ہو۔ ( اور وہ شخص صرف حضرت علیؑ ہیں ) &&(فصل الخطاب)&&
  26,85,آیت نمبر۸۵:حضرت ابراہیمؑ کایہ فرمانا کہ’’مجھے جنت کاوارث بنا دے۔‘‘<< ’’ارث‘‘>>کے معنی کسی نعمت کو بغیر کسی تکلیف کے حاصل کرلینا ہوتا ہے۔یہ لفظ اس لیے استعمال فرمایا کہ ہم جنت کے حاصل کرنے کے لیے کتنی بھی تکلیفیں برداشت کریں ، پھر بھی وہ جنت کی ابدی وراثتی نعمتوں کے مقابلے پر بالکل کمتر ناچیز ہیں ۔ جنت  اور دوزخ کے گھروں کی وراثت:یاپھر یہ لفظ اس لیے استعمال ہوا ہے کہ حدیث میں آیا ہے کہ: ہر انسان کاایک گھر جنت میں ہوتا ہے  اور ایک جہنم میں ۔ اگر وہ جہنم میں چلا جاتا ہے تو اُس کے جنت والے گھر کے وارث دوسرے جنتی بن جاتے ہیں ۔  اور اگر وہ جنت میں چلا جاتا ہے تو اُس کے جہنم کے گھر کے وارث جہنمی ہوتے ہیں ۔ &&(تفسیر نمونہ)&&حضرت ابن عباسؒ سے روایت ہے کہ حضرت ابراہیمؑ نے اپنے چچا آذر کے لیے دعائے مغفرت کی ، لیکن جب وہ کافر مرا  اور ا س کی حق دشمنی مسلم ہوگئی ، تب آپؑ نے اُس کے لیے استغفار کرنا چھوڑ دیا۔ (تفسیر ابن اہل سنت کے بعض مفسرین نے لکھا:کہ حضرت ابراہیم علیہ السلام کے والد ٭)( بعض روایات کے لحاظ سے چچا) گمراہ مشرک تھے۔ اس لیے حضرت ابراہیم علیہ السلام کامغفرت کی دعاء کرنا اصل میں اس بات کی دعا کرنا تھا کہ خدا اُن کو اسلام لانے کی توفیق عطا فرمائے۔ مگر قرآن مجید کی دوسری آیتوں کو سامنے رکھا جائے تو یہ توجیہ مناسب معلوم نہیں ہوتی۔ کیوں کہ قرآن مجید یہ بھی ارشاد فرماتاہے کہ حضرت ابراہیمؑ اپنے والد (یاچچا) کے ظلم سے تنگ آکر جب گھر سے نکلے تو اُنہوں نے رخصت ہوتے ہوئے فرمایا'<<قَالَ سَلٰمٌ عَلَيْكَ۰ۚ سَاَسْتَغْفِرُ لَكَ رَبِّيْ۰ۭ اِنَّہٗ كَانَ بِيْ حَفِيًّا>>۴۷ &&(سورۃ المریم آیت ۴۷)&& یعنی : @@ابراہیمؑ نے کہا: آپ کو خدا حافظ (یاسلام ہو) میں اپنے مالک سے آپ کے لیے معافی کی دعاء کروں گا۔ وہ یقیناًمجھ پر بڑا مہربان ہے۔@@‘‘دوسری جگہ قرآن مجید میں آپؑ نے یہ دعاء مانگی:<<’’رَبَّنَا اغْفِرْلِيْ وَلِوَالِدَيَّ‘‘>> یعنی :@@اے ہمارے مالک!مجھے اپنی رحمتوں سے ڈھک لے  اور میرے والدین کو بھی۔@@‘‘&&(سورۃ ابراہیم آیت ۴۱)&& مگر بعد میں حضرت ابراہیمؑ کو یہ احساس ہوگیا کہ یہ میرا باپ (یاچچا) مغفرت کی دعاء کامستحق نہیں ہے اس لیے سورہ توبہ میں فرمایا:<< وَمَا كَانَ اسْتِغْفَارُ اِبْرٰہِيْمَ لِاَبِيْہِ اِلَّا عَنْ مَّوْعِدَۃٍ وَّعَدَھَآ اِيَّاہُ۰ۚ فَلَمَّا تَـبَيَّنَ لَہٗٓ اَنَّہٗ عَدُوٌّ لِّلہِ تَبَرَّاَ مِنْہُ۰ۭ ‘‘>> یعنی :@@ابراہیمؑ کااپنے باپ کے لیے دعائے مغفرت کرنا تو صرف اُس وعدے کی وجہ سے تھا جو اُنہوں نے اُس سے کیاتھا، مگر جب یہ بات اُن پر کھل گئی کہ وہ خدا کادشمن ہے، تو اُنہوں نے اُس سے تبرا کیا۔@@‘‘&&(تفہیم القرآن )&& &&(سورۃ التوبہ آیت ۱۱۴پ۱۱)&&ائمہ اہل بیتؑ کی روایات کے اعتبار سے ان آیات کاتعلق حضرت ابراہیمؑ کے چچا آذر سے ہے۔ جبکہ حضرت ابراہیمؑ کے والد کانام تارُخ تھا، جو مومن تھے۔&&(روح المعانی)&&
  26,87,آیت نمبر۸۷: یعنی قیامت کے دن مجھے یہ رسوائی نہ دکھانا کہ میدانِ حشر میں تمام اوّلین وآخرین کے سامنے ابراہیمؑ کاباپ&&(شیعہ روایات کے مطابق چچا آذر)&& سزا پارہا ہو اور ابراہیمؑ کھڑا دیکھ رہا ہو۔&&(تفہیم القرآن )&& <<’’تخزنی‘‘>><<’’خزی‘‘>>کے مادّے سے ہے جس کے معنی روح کی شکست یعنی بیحدشرم۔&&(امام راغب)&&حضرت ابراہیمؑ کی یہ دعاء دوسروں کے لیے درسِ عبرت اُسوئہ حسنہ  اور اپنی ذمّے داریوں کا زبردست احساس پیدا کرتا ہے۔&&(تفسیر نمونہ)&&
  26,88,آیت ۸۸کی تشریح : اکثر مفسرین کے نزدیک یہ آیات حضرت ابراہیمؑ کی دعا کانتیجہ ہیں ۔ لیکن بعض مفسرین نے لکھا ہے کہ یہ آیات خداوندعالم کاجواب ہے مگر یہ خیال کمزور معلوم ہوتا ہے۔ دنیاکی زندگی کے سب سے اہم سرمائے دو ہوتے ہیں ۔ مال  اور اولاد ۔جب یہ بھی وہاں آخرت میں کام نہ آسکیں تو باقی چیزیں کس کھیت کی مولی ہیں کہ کام آسکیں گی لیکن یہاں مال  اور اولاد سے مراد وہ مال  اور اولاد نہیں ہیں جن کے ذریعہ سے خدا کی اطاعت کی جائے جن کی تربیت خدا کی اطاعت کے لیے کی جائے کیوں کہ جب مال  اور اولاد کو خدا کی مرضی کے مطابق استعمال کیاجاتا ہے تو پھر وہ مادی سرمایہ نہیں ، بلکہ اُخروی  اور روحانی سرمایہ بن جاتی ہیں ۔ پھر وہ خدا کے رنگ میں رنگ جاتی ہیں ۔ پھر وہ باقیات الصالحات بن جاتی ہیں ۔ &&(تفسیر نمونہ)&&!!قلبِ سلیم:اس آیت سے معلوم ہوا کہ اصل ذریعہ نجات، قلب سلیم ہے۔ یعنی ایسا دل دماغ جس میں خالص ایمان، پاک نیت، جذبہ اطاعت الٰہی پاک کاموں  اور پاک لوگوں سے محبت ہو۔ &&(تفسیر نمونہ)&&قلب سلیم کالفظ سلامت کے مادّے سے بنا ہے یعنی وہ دل جو ہر قسم کی بیماری ، خواہ وہ اخلاقی ہویااعتقادی ، سے پاک ہو۔ &&(تفسیر نمونہ)&&!!خداوندعالم نے منافقوں کے بارے میں ارشاد فرمایا: <<’’فِىْ قُلُوْبِہِمْ مَّرَضٌ۰ۙ ‘‘>>&&(بقرہ آیت ۱۰)&& یعنی (اُن کے دلوں میں مرض ہے) {{فرزندرسولِ خداؐ حضرت امام جعفر صادق علیہ السلام نے اپنے آبائے طاہرین علہیم السلام کے حوالوں سے روایت فرمائی ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’ہر وہ دل جس میں شرک یاشک ہو ، وہ ساقط  اور بے قدر وقیمت ہوتا ہے۔‘‘(۲) نیز امیرالمومنین حضرت امام علی ابن ابی طالبؑ نے فرمایا کہ جناب رسولِ صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: <<’’حب الدنیا راسُ کل خطیئۃ‘‘ >>( یعنی ) دنیا کی محبت ساری غلطیوں کی جڑ ہے۔‘‘اس لیے جس دل میں دنیا کی محبت آخرت کی محبت سے زیادہ ہوگی، وہ قلب سلیم نہ ہوگا۔&&(بحارالانوارجلد۷۰وتفسیر صافی)&&}}(۳) خداوندعالم نے ارشاد فرمایا:<< وَمَا تَفْعَلُوْا مِنْ خَيْرٍ يَّعْلَمْہُ اللہُ۰ۭؔ وَتَزَوَّدُوْا فَاِنَّ خَيْرَ الزَّادِ التَّقْوٰى۰ۡوَاتَّقُوْنِ يٰٓاُولِي الْاَلْبَابِ۱۹۷>>&&(سورۃ البقرہ آیت ۱۹۷پ۲)&& یعنی :’’@@ اور جو بھی نیکی تم کرتے ہو اللہ اُسے (اچھی طرح) جانتا ہے، تو تقویٰ وپرہیزگاری ( یعنی ) خدا کی ناراضگی سے بچنا) ہے،  اور اے عقل والو! (اے بصیرت رکھنے والو!) مجھ ہی سے ڈرتے رہو۔‘‘@@معلوم ہوا، وہ دل سالم دل ہے جس میں خدا کی عظمت کااحساس بیدار ہو  اور خدا کے عذاب  اور اُس کی ناراضگی کاخوف جاگزیں ہو۔&&(مولف)&&{{ فرزندِ رسولؐ حضرت امام جعفر صادق علیہ السلام نے فرمایا:’’قلب سلیم اُس دل کو کہتے ہیں جو خدا سے ملاقات اس طرح کرے کہ اُس کے دل میں خد اکے سوا کوئی  اور نہ ہو۔‘‘&&(تفسیر صافی، اصولِ کافی)&&معلوم ہوا کہ قلب سلیم وہ ہے جس کاسب سے گہرا تعلق صرف اللہ سے ہو۔ صوفیا کرام کے نزدیک یہ مقام فنا ہے یعنی لاموجود الاللہ۔یہ وہ مقام ہے جب انسان کی نگاہ میں خدا کے سوا کسی چیز کی کوئی وقعت باقی نہیں رہتی ۔&&(مولف)&& }}
  26,90,آیت نمبر۹۰:مطلب یہ ہے کہ متقی پاک صاف لوگ جنتوں میں داخل ہونے سے پہلے ہی یہ دیکھ رہے ہوں گے کہ کیسی کیسی نعمتوں سے بھرپور جگہ ہے جہاں اللہ کے فضل وکرم کی وجہ سے ہم جانے ہی والے ہیں ۔ اسی طرح گمراہ لوگ میدانِ حشر میں سے ہی جہنم کاہولناک منظر دیکھ کر خوفزدہ ہوجائیں گے۔ &&(تفہیم القرآن )&& یہ وہ وقت ہوگا جب جنتی (متقین)  اور جہنمی (گمراہ) جنت یاجہنم میں داخل نہ ہوئے ہوں گے، بلکہ دونوں اپنے اپنے ٹھکانوں کوبڑےقریب سے دیکھ رہے ہوں گے۔ اس وقت مومنین (متقین) تو جنت میں جانے کے لیے بیقرار ہوکر بیحد مسرت وانبساط کے عالم میں اللہ کی کبریائی کانعرہ (نعرۃ تکبیر اللہ اکبر) بلند کررہے ہوں گے)  اور جہنمی سخت مبہوت ہوکر خوف کے عالم میں کانپ کانپ رہے ہوں گے۔ یہ اُن کی سزا کی ابتدا ہوگی۔ &&(تفسیر نمونہ)&&اللہ تعالیٰ کی نظر میں متقین کی شان  اور عظمت یہ ہوگی کہ جنت کو متقین کے قریب کردیا جائے گا۔ یعنی اُنہیں جنت کے لیے چلنے کی زحمت بھی نہ دی جائے گی۔ ( یعنی ایک قدم محشر کے میدان میں ہوگا  اور دوسرا قدم بابِ جنت میں ) <<سبحان اللہ وبحمدہ‏>>
  26,93,آیت ۹۳کی تشریح:معبود انِ باطل کی انتہائی بے بسی  اور بے چارگی کابیان ہے کہ وہ بے چارے دوسروں کی تو کیامدد کریں گے ، وہ تو خود کو خدا کے عذاب سے نہ بچا سکیں گے۔&&(تفسیر ماجدی)&&
  26,94,آیت ۹۴کی تشریح:<<کبکُوا>>‘‘کااصل مطلب بار بار اوندھے منہ گراناہوتا ہے۔مطلب یہ ہوا کہ جسے جہنم میں ڈالا جائے گا وہ بار بار اوندھے منہ گرتا چلا جائے گا، یہاں تک کہ وہ جہنم کی تہ تک پہنچ جائے گا۔ اُس کے تصور سے بھی انسان کے رونگٹے کھڑے ہوجاتے ہیں &&(الامان ۔الحفیظ)&& && (تفسیر صافی ص ۳۶۶)&&لفظ<<’’کبکبوا‘‘>>اصل میں ’’کب‘‘کے مادّے سے ہے جس کے معنی ہیں کسی چیز کو گڑھے میں منہ کے بل اوندھا پھینک دیتا۔‘‘جہنمیوں کو اسی طرح واصل جہنم کیا جائے گا۔ &&(مفردات القرآن اما م راغب)&& معلوم ہوا کہ دوزخیوں کو کسی اُونچے مقام سے نیچے جہنم میں اُلٹا پھینکا جائے گا۔ اسی طرح گرتے گرتے وہ جہنم میں پہنچیں گے۔ پھر جہنم کے اندر گرتے گرتے جہنم کی تہ میں جاپہنچیں گے۔&&(الامان ۔الحفیظ)&&تفسیر نمونہ<<’’فکبکبوا‘‘>> یعنی اوندھے منہ  اور ایک دوسرے کے اوپر جہنم میں پھینک دیے جائیں گے ۔  اور روایات اہل بیتؑ میں ہے کہ وہ لوگ ہوں گے جو زبان سے عدل بیان کرتے تھے لیکن مقام عمل میں عدل کے تقاضوں کو بھول جاتے تھے۔ &&(تفسیر انوارالنجف)&& قرآن مجید میں باربار یہ عبرتناک نقشہ کھینچا گیا ہے تاکہ اندھی تقلید کرنے والے آنکھیں کھولیں ۔ سورۃ الاحزاب میں فرمایا:@@’’ اور وہ کہیں گے اے ہمارے مالک!بیشک ہم نے سرداروں  اور اکابرین کی اطاعت کی،  اور اُنہوں نے ہمیں سیدھے راستے سے بھٹکا دیا۔ اے ہمارے مالک !اُن کو دوگنی سزا دے  اور اُن پر سخت لعنت کر۔‘‘@@&&(سورۃ الاحزاب آیت ۶۷۔۶۸پ۲۲)&& پھر دوسری جگہ فرمایا: @@’’ اور کافراُس وقت کہیں گے کہ اے ہمارے مالک !جنوں  اور انسانوں میں سے اُن کو ہمارے سامنے لے آ جنہوں نے ہمیں گمراہ کیا تھاتاکہ ہم اُنہیں اپنے پائوں کے تلے ڈال کر روند ڈالیں تاکہ وہ خوب ذلیل ہوں ۔‘‘@@&&(سورۃ ۴۱خم السجدہ آیت ۲۹پ۲۴)&&
  26,101,آیت ۱۰۱کی تشریح:<<’’حمیمٍ‘‘>>سخت گرم پانی کو کہتے ہیں ،  اور اسی لیے اُس دوست کو بھی حمیم کہتے ہیں جو دوست کی حمایت میں سرگرم رہتا ہے۔ &&(لغات القرآن نعمانی جلد۳)&& یعنی جہنمی کہیں گے کہ آج کوئی بھی ایسا نہیں ہے جو ہمارا غم خوار ہو، ہماری حالت پر کڑھنے والا ہو محققین نے نتیجہ نکالا کہ آخرت میں دوستیاں صرف اہل ایمان کی باقی رہ جائیں گی۔ سارے کافر گمراہ وہاں ایک دوسرے کے سخت دشمن ہوں گے  اور اُن میں کافر ایک دوسرے کو زیادہ سے زیادہ سزا دلوانے کی کوشش کرے گا۔ اسی لیے خداوندعالم نے ارشاد فرمایا:<< الاخلآئُ یومئِذ بعضھم لبعض عَدوّ الا المتقین۔‘‘>>&&(سورۃ الزخرف آیت ۶۷ پ۲۵)&& @@یعنی اُس دن دوست ایک دوسرے کے دشمن ہوں گے، مگر متقین کی دوستیاں قائم رہیں گے۔@@‘‘غور طلب بات یہ ہے کہ پچھلی آیت میں <<’’شافعین‘‘>> جمع کے صیغے میں ہے  اور ا س آیت میں ’’صدیق‘‘مفرد ہے۔ شاید اس لیے کہ مومنین کی شفاعت کرنے والے بہت سے ہوں گے ۔ خود جناب رسولِ خداؐ ہوں گے ، ائمہ اہل بیتؑ، شہدائَ، علماٰء،صدیقین  اور صالحین ہوں گے ملائکہ مقربین ہوں گے ۔ جہنمی یہ منظر دیکھ کر آرزو کرتے ہوں گے کہ کاش ہمارا بھی کوئی دوست ایسا ہوتا۔ &&(تفسیر نمونہ)&&[[نیاز اندر قیامت بے سروساماں نہ خواہی شد۔کہ ازحب وتو لاّئے علیؑ داری تو سامانے]]&&(نیاز بریلویؒ)&&[[لیں شفاعت نے مری بڑھ کے بلائیں کیاکیا۔عرق شرم سے ڈوبا جو گنہگار آیا]]&&(اقبال)&&
  26,102,آیت ۱۰۲کی تشریح:غرض کافروں کو بہت جلد پتہ چل جائے گا کہ اب رونے پیٹنے، چیخنے چلانے، دُہائیاں مچانے کاکوئی فائدہ نہیں ہوگا۔ لہٰذا پھروہ دنیا میں دوبارہ آنے کی آرزو کریں گے، تاکہ مومنوں میں شامل ہوجائیں ۔ مگر وہاں ایمان لانا کوئی کام نہ آئے گا۔ اس لیے کہ امتحان کامقام دنیا تھی (  اور کمرہ امتحان سے پرچہ حل کرنے کے بعد نکل جاتے ہیں تو دوبارہ کمرہ امتحان میں پرچہ صحیح صورت سے حل کرنے کی اجازت نہیں دی جاتی ) کیوں کہ اب جو کچھ غیب میں تھا ، وہ شہود بن گیا۔ امتحانِ عقل ختم ہوچکا ۔ اب ایمان لانا کسی کام کا نہیں ، بے سود، بے فائدہ ہے،  اور خدا کاقانون کسی کوآخرت سے دنیا کی طرف پلٹنے کی اجازت نہیں دیتا۔ وہ کافرخود اس بات کو سمجھ رہے ہوں گے۔ اسی لیے کلمہ <<’’لو‘‘>>کہہ رہے ہیں ۔ یہ حرفِ شرط ہے جو عام طور پر وہاں بولا جاتا ہے جہاں شرط محال ہو۔&&(تفسیر نمونہ)&&{{فرزندِ رسول خداؐ حضرت امام جعفر صادق علیہ السلام نے فرمایا:’’شفاعت کرنے والے ائمہ اہل بیتؑ ہیں  اور صدیق مومنین ہیں ۔‘‘&&(محاسن برقی۔ تفسیر انوارالثقلین )&&نیز فرمایا:’’مومن اپنے قرابتداروں ، دوستوں حتیٰ کہ اپنے خادم کی بھی شفاعت کرےگا۔  اور ایک مومن کم ازکم تیس آدمیوں کی شفاعت کرے گا۔ &&(ملخصاً از تفسیر انوار النجف مولاناحسین بخش جاڑہ)&&}}بعض جنتی لوگ کہیں گے۔ہمارے دوست کاکیا بنا؟جبکہ اُن کے دوست جہنم میں ہوں گے۔ خداوندِ عالم اُس مومن کے دل کو خوش کرنے کے لیے حکم دے گا کہ اس کے دوستوں کو جہنم سے نکال کر جنت میں بھیج دیا جائے۔ ایسے موقع پر جہنمی کہیں گے۔ ہائے افسوس ! نہ تو ہماری کوئی شفاعت کرنے والا ہے۔  اور نہ کوئی ہمارا مہربان حمایتی دوست ہے۔ &&(تفسیر مجمع البیان)&&
  26,103,آیت ۱۰۳کی تشریح: اس قسم کے جملوں کوبار بار اس لیے قرآن میں دہرایا گیا ہے تاکہ مسلمانوں کو  اور جناب رسولؐ کوتسلی ہو کر اگرچہ وہ کم ہیں ۔ لیکن ہمیشہ حق کے طرفدار کم ہی ہوا کرتے ہیں ، اکثریت کبھی حق کی دلیل نہیں ہواکرتی ۔ <<قلیل من عبادی الشکور>> ( یعنی )&& @@میرے کم بندے شکر ادا کرتے ہیں@@ ۔ &&(القرآن )&& اس میں گمراہوں کے لیے تنبیہ بھی ہے کہ انہیں کچھ ڈھیل دی جارہی ہے ، تو اس لیے نہیں کہ خدا (معاذ اللہ) کمزور ہے ، بلکہ اس لیے کہ وہ ’’رحیم‘‘ہے۔ &&(تفسیر نمونہ)&&حضرت ابراہیمؑ کے اس واقعے میں دونشانیاں ہیں ۔ پہلی نشانی تو یہ ہے کہ عرب  اور خاص کر قریش حضرت ابراہیمؑ سے اپنے تعلق پر فخر کرتے ہیں ۔ مگر دوسری طرف شرک میں بھی مبتلاءہیں جس کے خلاف جہاد کرتے کرتے حضرت ابراہیمؑ کی ساری عمر بسر ہوئی۔ دوسرے یہ کہ آج کے مشرک ، حضرت ابراہیمؑ کے پیغام کو لانے والے نبی ؐ آخر کے ساتھ وہی کچھ سلوک کررہے ہیں جو اُس وقت مشرکوں نے حضرت ابراہیمؑ کے ساتھ کیاتھا۔ دوسری نشانی یہ ہے کہ حضرت ابراہیمؑ کی قوم  اور اُن کے منکردنیا سے مٹ گئے ، تو اے کفار عرب اسی طرح تم بھی مٹ جائو گے ۔ &&(تفہیم القرآن )&&
  26,105,آیت نمبر۱۰۵:ایک نبیؑ کو جھٹلانا، تمام انبیاءکو جھٹلانا ہے:محققین نے اس آیت سے نتیجہ نکالا کہ جس نے بھی کسی ایک پیغمبرؑ کو جھوٹا سمجھا، گویا اس نے تمام انبیاءؑ ومرسلین ؑ کو جھوٹا سمجھا۔ کیوں کہ تمام انبیاء کرام کاپیغام بنیادی اعتبار سے ایک ہی ہوتا ہے۔ &&(تفسیر تبیان، تفہیم القرآن )&& !!حقیقت بھی یہی ہے کہ جب کوئی قوم کسی بھی نبیؑ کاانکار کرتی ہے ، تو وہ اصل میں نبیؑ کاانکار نہیں کرتی، بلکہ نبیؑ کے لائے ہوئے پیغام کاانکار کرتی ہے۔ اس طرح کسی بھی ایک نبی ؑ کا انکار اصل میں عقیدئہ توحید، نبوت  اور قیامت کاانکار ہوتا ہے۔ &&(تفسیر ماجدی)&&{{اسی لیے فرزند رسول خداؐ حضرت امام محمد باقرعلیہ السلام سے روایت ہے کہ:’’یہاں تکذیب سے مراد اُن تمام انبیاءؑ کو ماننے سے انکار کرنا ہے، جو حضرت آدم علیہ السلام  اور حضرت نوح علیہ السلام کے درمیان ہوئے تھے۔‘‘&&(تفسیر مجمع البیان)&&}}<<’’کذَّبَتْ‘‘>>مؤنث کاصیغہ ہے،  اور مؤنث اس لیے لایا گیا ہے کہ ’’قوم‘‘ مؤنث لفظی ہے۔ &&(تفسیرانوارالنجف)&&بعض ماہرین کے نزدیک ’’قوم‘‘مؤنث ذاتی ہے ۔&&(تفسیرمجمع البیان، بحر، روح المعانی)&&
  26,106,آیت نمبر۱۰۶:<<’’اخو‘‘ >>کا لفظ صرف حضرت نوح علیہ السلام ہی کے لیے نہیں آیا ہے دوسرے انبیاء کرامؑ کو بھی اُن کی قوم کابھائی کہا گیا ہے ۔ اس سے نتیجہ نکلتا ہے کہ ہدایت کرنے والوں کو انتہائی محبت  اور دلی جذبے کے ساتھ ہدایت کاکام کرنا چاہیے۔ ہر قسم کی قومیت کااحساس دل سے نکال دینا چاہیے۔ تاکہ ہدایت کرنے والا دلوں کوAppealکرسکے۔&&(تفسیر نمونہ)&&دل سے جو بات نکلتی ہے، اثر رکھتی ہے’’اخوھم‘‘حضرت نوح علیہ السلام اُن کی قوم کے آدمی تھے  اور سلسلہ نسب میں اُن کے رشتہ داروں میں سے تھے۔ اس لیے اُن کے قومی بھائی تھے، نہ کہ دینی بھائی۔ &&(تفسیر انواراالنجف)&&
  26,107,آیت۱۰۷کی تشریح:ایک مطلب تو یہ نکلتا ہے کہ’’میں خدا کی بات کو اپنی طرف سے کم یازیادہ کرکے بیان نہیں کرتا، بلکہ جو پیغام خدا کے پاس سے جیسا میرے پاس آتا ہے، جوں کاتوں بلاکسی زیادتی یاکمی کے تم تک پہنچا دیتا ہوں ۔‘‘دوسرے معنی یہ نکلتے ہیں کہ ’’میں ایسا انسان ہوں کہ جسے تم پہلے سے ،بلکہ ہمیشہ سے ایک امانتدار  اور سچا آدمی ہونے کی حیثیت سے جانتے پہچانتے ہو۔ جب میں بندوں کے معاملات میں کبھی خیانت نہیں کرتا تو اپنے مالک کی باتوں میں کس طرح کمی بیشی کرسکتا ہوں ؟&&(تفہیم القرآن )&&
  26,108,آیت۱۰۸کی تشریح:مطلب یہ ہے کہ رسولؐ کاحق صرف اتنا ہی نہیں ہوتا کہ لوگ اُس کی سچائی کو  اور خدا کاپیغام لانے والا مان لیں ، بلکہ اُس کی اطاعت کرنا بھی لازمی ہوتا ہے اُس کے لائے ہوئے قانون کو چھوڑ کر کسی  اور قانون کو نہیں مانا جاسکتا، ورنہ بغاوت ہوگی۔ اسی لیے ایمان  اور اطاعت کے مطالبے سے پہلے ’’اللہ سے ڈرو‘‘فرماکر تنبیہ کردی۔ &&(تفہیم القرآن )&&تقویٰ کو اطاعت پر مقدم اس لیے کیا کہ اللہ کی ذات پر ایمان نہ ہوا اور دل میں اُس کی ناراضگی یاسزاکاخوف نہ ہوتو پیغمبرؐ کی اطاعت ممکن نہیں ۔&&(تفسیر نمونہ)&&[[یہی ہے رختِ سفر میرکارواں کے لیے]]&&( اقبال)&&
  26,109,آیت ۱۰۹کی تشریح:حضرت نوحؑ نے اپنی سچائی کی دوسری دلیل یہ دی کہ میں ہدایت کاکام اپنے کسی ذاتی فائدے کے لیے نہیں کررہا ہوں ۔ بلکہ میں تو بالکل مخلص، ایمانداری کے ساتھ جس چیز کو حق سمجھتا ہوں اس کی طرف خلقِ خدا کو بلاتا ہوں ،  اور تمہاری اصلاح وفلاح کو دیکھ رہا ہوں ۔کسی ذاتی فائدہ کے لیے یہ کام نہیں کررہا ہوں ۔ &&(تفہیم القرآن )&& میرااجر اور فائدہ تو صرف اللہ کے پاس ہے۔ اسی لیے اللہ سے ڈرو  اور میری بات مان لو، اسی میں تمہارافائدہ ہے۔
  26,111,آیت نمبر۱۱۱:ذہنیت کی پستی:یہ اُن لوگوں کی پست ذہنیت بول رہی ہے جوپیشے سے آدمی کی ذات پات  اور مقام کو معین کرتے ہیں ۔ اسی لیے &&(اگلی آیت میں )&& حضرت نوحؑ نے جواباً فرمایا:’’مجھے بھلا اس سے کیا مطلب کہ وہ (میری پیروی کرنے والے) کیا پیشہ اختیار کیے ہوئے ہیں ۔ &&(میرا کام تو اللہ کے دین کی طرف بلانا ہے، اب جو بھی لبیک کہہ کر قبول کرلے وہی بہترین انسان ہے) &&(تفسیر تبیان)&&حضرت نوحؑ کامطلب یہ تھا کہ میرا کام تو بس اللہ کی طرف بلانا ہے، اب جو بھی میری اس دعوت کو قبول کرے گا وہ مومنین کی جماعت میں داخل ہوجائے گا،  اور سر بلندوکامیاب رہے گا۔ رہا پیشہ تو وہ نہ کسی کو بلند کرتا ہے نہ پست میں کسی کو اُس کے پیشے یاغربت کی وجہ سے اپنے پاس سے ہٹا نہیں سکتا۔&&(تفسیر ماجدی)&&اصل میں اُن لوگوں کاطرزِ فکریہ تھا کہ سچ  اور حق صرف وہ ہوتا ہے جس کو قوم کے بڑے (رئیس) لوگ مان لیں ، کیوں کہ صرف بڑے لوگ ہی عقل  اور سمجھ رکھتے ہیں ۔رہے چھوٹے غریب لوگ، تو وہ اگر کسی بات کو مان لیں ، تو اُس کاکوئی وزن نہیں ہوتا، اسی لیے کافر کہتے تھے کہ پیغمبر معمولی لوگوں میں سے نہیں ہوسکتا بلکہ کسی رئیس گھرانے کا آدمی ہونا چاہیے۔اسی لیے کفار کہاکرتے تھے کہ:’’یہ قرآن ہمارے دونوں شہروں (مکہ  اور طائف) کے کسی بڑے آدمی پر کیوں نہ اُتاراگیا۔‘‘&&(سورۃ الزخرف آیت ۳۱ پ۲۵)&& &&(تفہیم القرآن )&&<<’’الارذلون‘‘>> یعنی گھٹیا قسم کے  اور ذیل پیشہ لوگ چوں کہ تمہارے ساتھ ہیں جو تم پر ایمان لاچکے ہیں ، لہٰذا اس زُمرے میں شامل ہونا ہم اپنی توہین سمجھتے ہیں ۔‘‘حضرت نوح علیہ السلام نے ارشاد فرمایا کہ مجھے کسی کے پیشے سے مطلب نہیں ،  اور نہ تمہاری بڑائی سے کوئی واسطہ ہے، بلکہ میں تو اپنا فریضہ  اور اللہ کاپیغام پہنچانے آیا ہوں ،  اور وہ ہر ایک کے لیے یکساں ہے۔ لہٰذا تمہارے کہنے سے میں غریب طبقے کے لوگوں کو دھکیل کر نکال دینا پسند نہیں کرتا۔بہرکیف جناب رسولِ خداؐ کو تسلی دی گئی ہے کہ ہر دور میں انبیاءؑ کی اُمتیں اپنے رسولوں ؑ کے ساتھ اسی قسم کاسلوک کرتی رہی ہیں پس قریش مکہ  اور دیگر اکابر، اگر غرباءطبقے کے ایمان لانے پر اعتراض کرتے ہیں تو آپؐ اُن کی پرواہ کیے بغیر اپنا کام جاری رکھیں ،  اور بڑے بڑوں کے ایمان لانے کی طمع میں غریبوں کو اپنے دربار سے ہرگز نہ نکالیں ۔ &&(تفسیر انوارالنجف)&& خداوندِ عالم نے سورۃ الکہف میں ارشاد فرمایا:<<’’وَاصْبِرْ نَفْسَكَ مَعَ الَّذِيْنَ يَدْعُوْنَ رَبَّہُمْ بِالْغَدٰوۃِ وَالْعَشِيِّ يُرِيْدُوْنَ وَجْہَہٗ وَلَا تَعْدُ عَيْنٰكَ عَنْہُمْ۰ۚ تُرِيْدُ زِيْنَۃَ الْحَيٰوۃِ الدُّنْيَا۰ۚ وَلَا تُطِعْ مَنْ اَغْفَلْنَا قَلْبَہٗ عَنْ ذِكْرِنَا وَاتَّبَعَ ہَوٰىہُ وَكَانَ اَمْرُہٗ فُرُطًا۲۸ >>&&(سورۃ الکہف آیت ۲۸ پ۱۵)&& یعنی :@@ اور تم اُن لوگوں کے ساتھ صبروسکون سے رہو جو اپنے پالنے والے مالک کو صبح وشام پکارتے ہیں ، ( اور صرف خدا ہی سے محبت کرتے رہو)  اور تم اپنی نظروں کو حیاتِ دنیا کی زینت کی خاطر کبھی اُن سے نہ پھیرو،  اور اُن لوگوں کی اطاعت نہ کرو (بات نہ مانو) جن کے دلوں کو ہم نے اپنی یاد سے غافل کردیا ہے۔ یہی وہ لوگ ہیں جنہوں نے اپنے نفس (ہویٰ وہوس) کی اطاعت کی ہے،  اور اُن کے کام (اعمال) حد سے بڑھے ہوئے ہیں ۔‘‘@@&&(سورۃ الکہف۲۸)&&
  26,112,آیت نمبر۱۱۲:خداوندِ عالم نے ہمارے رسولؐ کے حوالے سے ہمیں بھی یہی حکم دیا ہے۔ سورۃ الانعام میں ارشاد فرمایا@@’’اُن لوگوں کو دور نہ پھینک دوجودن رات اپنے پالنے والے مالک کو پکارتے رہتے ہیں ۔ وہ بھی صرف خدا کی خوشی حاصل کرنے کے لیے ، اُن کاکوئی حساب تمہارے ذمے نہیں ،  اور تمہارا کوئی حساب اُن کے ذمّے نہیں ۔ اس پر بھی اگر تم اُنہیں اپنے سے دور پھینک دو گے تو ظالموں میں شمار کیے جائو گے۔‘‘@@&&(سورۃ الانعام آیت ۵۲پ۷)&&
  26,116,آیت:۱۱۶کی تشریح: اس آیت کے عربی محاور ے کے لحاظ سے دومعنی ہوسکتے ہیں (۱) رجم کیا جائے گا، یعنی پتھر مار مار کرقتل کردیا جائے گا۔ (۲) تم پر گالیوں کی ہر طرف سے بوچھاڑ کی جائے گی ۔&&(راغب اصفہانی)&&<<’’رِجم‘‘>> اصل میں <<’’رجام‘‘>>کے مادّے سے ہے، جو رحمۃ (بروزن لقمۃ) کی جمع ہے، جو پتھر کے اُس ٹکڑے کو کہتے ہیں جسے قبر کے اوپر رکھّا جاتا ہے، جس کے گردبُت پرست چکرّ لگاتے ہیں ۔ نیز رجم کے معنی پتھر مار مار کر قتل کردینا ہوتے ہیں ۔ &&(تفسیر نمونہ)&&
  26,117,آیت ۱۱۷کی تشریح:سورہ عنکبوت میں خداوندِ عالم نے ارشاد فرمایا کہ:’’نوحؑ اور اُن کی قوم میں کشمکش بحث ومباحثہ ساڑھے نو سو سال تک جاری رہا۔&&(آیت۱۴)&&آخر کار جب حضرت نوحؑ نے یہ خوب اچھی طرح سمجھ لیا کہ اس قوم میں حق کو قبول کرنے کے اثرات نظر نہیں آتے، بلکہ یہ بھی اندازہ ہوگیا کہ اُن کی نسلیں بھی شریفانہ زندگی قبول نہ کریں گی تب حضرت نوحؑ نے اُن کے لیے بددعاء کی (اے مالک) اگر تو نے اب بھی اُنہیں چھوڑ دیا تو یہ تیرے دوسرے بندوں کو بھی گمرا ہ کریں گے  اور اُن کی نسل سے جو بھی پیدا ہوگا وہ سخت منکر حق ہوگا۔ &&(سورۃ نوح آیت ۲۷)&&آخر کار خود اللہ نے بھی حضرت نوحؑ کی رائے کی تائید فرمائی@@:'' (اے نوحؑ!) تمہاری قوم میں سے جو ایمان لاچکے پس وہ لاچکے ، اب کوئی ایمان لانے والا نہیں ہے۔ لہٰذا اب ان بدمعاشوں پر غم کھانا چھوڑ دو۔‘‘@@&&(سورۃ ہود آیت ۳۶ پ۱۲)&&
  26,118,آیت۱۱۸کی تشریح: قابل توجہ بات یہ ہے کہ حضرت نوح علیہ السلام اپنی ذات پر کیئے جانے والے مظالم کاقطعاً کوئی ذکر نہیں فرماتے۔اُنہیں صرف اس بات کاغم ہے کہ لوگوں نے حق بات کو نہیں تسلیم کیا،  اور خداوندعالم کاپیغام قبول نہ کیا۔ اب کیوں کہ اُن لوگوں میں ہدایت قبول کرنے کی صلاحیت تک ختم ہوچکی ہے اس لیے اب اُن میں  اور مجھ میں جدائی ڈال دے،  اور ہمارے درمیان اے خدا!تو خود ہی فیصلہ فرما دے۔ &&(تفسیر نمونہ)&&’’فتح‘‘کالفظ کھولنے یا تعلقات توڑنے کے معنی میں استعمال ہوتا ہے۔  اور کبھی اس کے معنی فیصلہ کرنا  اور لڑائی جھگڑا ختم کرنا ہوتا ہے۔یہاں اس معنی میں یہ لفظ استعمال ہوا ہے۔&&(مفردات امام راغب)&&عرفاءنے نتیجہ نکلا کہ’’جوشخص دین کونقصان پہنچائے، اُس کے لیے بددعاء کرنا صبروحلم کے منافی نہیں ہوتا۔&&(تفسیر ماجدی)&&
  26,119,آیت۱۱۹کی تشریح: بھری ہوئی کشتی سے مراد حضرت نوحؑ پر ایمان لانے والے مومنین  اور تمام جانوروں کے جوڑے  اور کھانے پینے کاسازوسامان وغیرہ&&(تفہیم القرآن )&& ’’مشحون‘‘شمن‘‘کے مادّے سے ہے جس کے معنی اُس دشمنی کے ہیں جوتمام وجود میں بھرجائے۔ یعنی کشتی تمام وسائل سے بھری ہوئی تھی جب وہ بالکل تیار ہوگئی تب خدا نے عذاب بھیجا۔&&(تفسیر نمونہ)&&
  26,121,آیت۱۲۱کی تشریح: حضرت نوحؑ کے واقعے میں خدا کی نشانیاں یہ ہیں (۱) حضرت نوحؑ نے کسی قدر محنت سے اپنی قوم کو ۹۵۰سال تک نصیحتیں فرمائیں (۲) کس قدر مدلل دلائل دئیے(۳) کس قدر تکالیف برداشت کیں (۴) مگر وہ احمق ٹس سے مس نہ ہوئے۔ اپنے باپ دادائوں کی اندھی تقلید پر جمے رہے۔ (۵) بالآخر بددعا فرمائی معلوم ہوا کہ حق کو نہ ماننے کاانجام عذاب الٰہی ہوتا ہے۔  اور آخر کار وہ سب غرق ہوگئے۔ یہ سب ہمارے لیے اسباق ہیں ۔ &&(مولف)&&
  26,122,آیت۱۲۲ کی تشریح: خدا کارحیم ہونا اس بات کامتقاضی ہے کہ گناہگاروں کو مہلتیں عطا فرماتا رہے تاکہ اتمام حجت ہوجائے۔  اور خداوندعالم کا<<’’عزیز‘‘>> یعنی ناقابل شکست ہونا، اس بات کامتقاضی ہے کہ انبیاءؑ  اور اُن کے ماننے والوں کو نجات  اور اُن کے دشمنوں کو شکستِ فاش سے دوچار کرے۔ &&(تفسیر نمونہ)&&
  26,123,آیت ۱۲۳کی تشریح: اگرچہ قوم عاد نے صرف حضرت ھودؑ کی تکذیب کی تھی، مگر فرمایاگیا کہ اُنہوں نے مرسلینؑ ، پیغمبروںؑ کی تکذیب کی۔‘‘یہ اس لیے کہ حضرت ھودؑ کاپیغام بھی تمام انبیاءؑ کرام کاپیغام تھا۔ اس لیے کسی ایک نبی‘‘کاانکار تمام انبیاءؑ کاانکار ہوتا ہے۔ قوم عاد کی خصوصیات:قوم نوحؑ کی تباہی کے بعد جس قوم کو عروج ملا وہ قوم عاد تھی جیسا کہ خود خداوندعالم نے ارشاد فرمایا:@@’’ اور یاد کرو اللہ کے اُس فضل وکرم کو نوحؑ کی قوم کے بعد اُس نے تم کو اُن کاخلیفہ (جانشین )بنایا۔‘‘@@&&(سورہ الاعراف آیت ۲۹پ۸)&&آیت کاآخری حصہ ہے ’’ اور تمہیں تمہاری خلقتِ جسمانی میں خوب طاقتور بنایا پس اللہ کی نعمتوں کو یاد کرو تاکہ فلاح پائو۔‘‘سورۃ الفجر میں فرمایا:@@کیا تو نے نہیں دیکھا کہ تیرے مالک نے کیا (حشر) کیا’’ستونوں والے‘‘ >>عاد<< >>ارم<< کے ساتھ‘‘@@ &&(سورۃ الفجرآیت ۶۔۷)&&معلوم ہوا کہ یہ لوگ ستونوں والی بڑی بڑی عمارتیں بناتے، ترقی یافتہ کہلاتے تھے، اس لیے متکبر ہوگئے۔ فرمایا’’ رہے قوم عاد ، تو اُنہوں نے زمین میں ناحق تکبر کیا،  اور کہنے لگے ہم سے زیادہ طاقتور کون ہے؟‘‘&&(سورہ حمٰ السجدہ آیت ۱۵)&&تکبرّ ازروئے جہالت ہی ہوتا ہے۔سورۃ الاعراف میں فرمایا:’’اُنہوں نے ھودؑ سے کہا’’کیا تو ہمارے پاس اس لیے آیا ہے کہ ہم صرف ایک اللہ کی بندگی کریں  اور اُن (خدائوں ) کو چھوڑ دیں جن کی عبادت ہمارے باپ دادا کیا کرتے تھے؟‘‘&&(الاعرف آیت۷۰)&&
  26,127,آیت ۱۲۷کی تشریح:’’حضرت ہودؑ نے اپنی قوم سے فرمایا کہ میں اس تبلیغ کی تم سے کوئی اجرت طلب نہیں کررہا ہوں ۔میرا اجر ومعاوضہ تو خدا کے پاس محفوظ ہے۔ &&(تفسیر نمونہ۔ملخص)&&
  26,128,آیت نمبر۱۲۸:اونچی اونچی  اور غیرضروری عمارات بنانے کی مذمت:{{جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’جوبھی عمارت بنائی جائے گی وہ قیامت کے دن اپنے بنانے والے پر وَبال ہوگی، سوا اُس کے جو واقعاً بنانے والے کی ضرورت(پوری کرنے کے لیے ) ہو۔‘‘&&(تفسیر صافی ص ۳۱۷)&&محققین نے نتیجہ نکالا کہ ایسی عمارتیں بنانا جو شان وشوکت دکھانے کے لیے ہوں  اور جن کی کوئی واقعی ضرورت نہ ہو، وہ کام خدا کی مرضی کے خلاف ہے۔ &&(تفسیر ماجدی)&&آیت ۱۲۸ میں <<’’ریح‘‘>>کالفظ استعمال ہوا ہے۔ اس کے معنی بلند جگہ کے ہوتے ہیں ۔  اور <<’’تعلبثون‘‘>> کالفظ <<’’عبث‘‘>> کے مادّے سے بنا ہے جس کے معنی بے مقصد یا بے فائدہ کام ۔&&(مفردات امام راغب)&&<<’’اٰیَۃ‘‘>> یعنی ’’نشانی‘‘ کے لفظ سے ظاہر ہوتا ہے کہ عاد کی قوم بڑی مالدار تھی اس لیے دوسروں پر اپنی بڑائی جتانے کے لیے اونچے ٹیلوں  اور پہاڑوں کی چوٹیوں پر ٹ اور یا بُرج قسم کی عمارتیں بنا دیا کرتے تھے تاکہ لوگ اُن کی بڑائی  اور شان کو دیکھیں  اور مان لیں کہ وہ بڑی مالدار قوم کے لوگ ہیں ۔ &&(تفسیر نمونہ)&&<<’’ریحٍ‘‘>>کے معنی بلند مکان۔اُن لوگوں کادستور تھا کہ ضرورت سے زائد آبادی سے باہر کسی بلند جگہ یا راستہ کے قریب مکان بنالیتے تھے۔  اور آیت سے مراد یہاں مکان ہے۔ حضرت ہودؑ نے ان کو اس کام سے منع فرمایا کہ لہوولعب کے لیے فالتو مکان نہ بنایا کرو۔ {{’’تفسیر مجمع البیان‘‘میں مروی ہے کہ ایک دفعہ جناب رسالت مآبؐ شہر سے باہر تشریف لے گئے تو ایک بلند مکان پر آپؐ کی نگاہ پڑی۔ دریافت فرمایا: یہ کس کامکان ہے؟‘‘ لوگوں نے عرض کی :’’فلاں انصاری کا‘‘۔ پس آپؐ وہاں کھڑے ہوگئے۔ اتنے میں وہ انصاری بھی آگیا  اور اُس نے آنحضرتؐ کو سلام عرض کیا۔ آپؐ نے منہ پھر لیا۔ اُس نے چند بار ایسا ہی کیا۔ جو اب سلام نہ ملا تو سمجھ گیا کہ حضورؐ ناراض ہیں جب ساتھیوں سے وجہ دریافت کی، تو انہوں نے کہا کہ حضورؐ نے تمہارے مکان کے بارے میں دریافت فرمایاتھا کہ یہ بلند مکان کس کا ہے؟ یہ سن کر وہ انصاری ، وہاں سے اُٹھا،  اور اپنے مکان کو گرادیا۔ پھر جب دوبارہ آنحضرتؐ کاگذر اس طرف سے ہوا تو دریافت فرمایا۔ وہ مکان کہاں گیا؟عرض کی انصاری نے گرادیا۔ پھر ارشاد فرمایا:’’ہر مکان روزِ محشر اپنے مالک کے لیے وبالِ جان ہوگا، سوائے اس کے جس کے بغیر چارہ نہ ہو۔‘‘( یعنی بقدر ضرورت) &&(تفسیرانوارالنجف)&&}}
  26,129,آیت ۱۲۹کی تشریح:<<’’مصانع‘‘ >> مصنع کی جمع ہے۔جس کے معنی پختہ مکان ۔ موجود اصطلاح کے مطابق شاندار کوٹھیاں ۔ &&(تفسیر انوارالنجف)&& &&(مفردات امام راغب)&&ملاحظہ فرمائیے کہ حضرت ہودؑ ، اس بات پر اعتراض نہیں فرمارہے ہیں کہ تمہارے اچھے اچھے گھر کیوں ہیں ؟ وہ اس بات پر اعتراض کررہے ہیں کہ بڑے بڑےمضبوط محلات  اور قلعے کیوں بنارہے ہو جن کی تم کو ضرورت ہی نہیں ہے؟&&(ملخص ۔تفسیر نمونہ)&&
  26,130,آیت۱۳۰:کی تشریح: مطلب یہ ہے کہ وہ لوگ اتنے غصّے والے لوگ تھے کہ لوگوں کو ناحق ذرا سے غصّے پر قتل کردیا کرتے تھے۔ &&(تفسیر صافی ۳۶۷)&&غصّہ دیوانگی ہے:{{جناب امیر المومنین حضرت امام علی ابن ابی طالبؑ نے فرمایا:<<’’الحدۃ ضربٌ من الجنون لان صاحبھا یندم فان لم یندم فجنونہٗ مستحکمٌ‘‘>>&&(از نہج البلاغۃ قل ۲۵۵)&&}} یعنی :غصّہ ایک قسم کی دیوانگی ہے کیوں کہ غصہّ کرنے والا بعد میں پشیمان ضرورہوتا ہے  اور اگر پشیمان نہیں ہوتا تو اُس کی دیوانگی پختہ ومستحکم ہے۔‘‘ (مکمل پاگل ہے)گویا قومِ عاد کی دوسری خصوصیات اُن کاظلم وتشدد تھا۔ ایسی گرفت کرنا جس میں رحم کانام ونشان تک نہ ہو، نہ مقصد اصلاح کرنا ہو  اور نہ انجام کی فکر ہو۔ ایسی گرفت ، جس کامقصد اصلاح ہو،  اور جوواقعاً ضروری بھی ہو، وہ اخلاق کے منافی نہیں ہوتی۔ &&(تھانوی)&&مادّہ پرست، دولت مند ظالم قوموں کامعیار زندگی تو بہت بلند ہوتا ہے، مگر معیارِ انسانیت بہت پست ہوتا ہے۔ کمزوروں کے لیے اُن کے دلوں میں کوئی رحم نہیں ہوتا، غریب طبقہ ظلم کی چکی میں پستا ہے۔ (یہ ہمیشہ سے ہوتا رہا ہے) کمزور قوم اُن کے ظلم وتشدد سے بچ نہیں سکی۔‘‘&&(تفہیم القرآن )&&[[ناوک نے تیرے صید نہ چھوڑا زمانے میں ۔تڑپے ہے مرغِ قبلہ نما آشیانے میں ]]
  26,133,آیت ۱۳۳کی تشریح: اب حضرت ہودخدا کی نعمتوں کو بیان فرمارہے ہیں ، تاکہ اس طرح اُن کی قوم میں احساسِ شکر بیدار ہو اور خدا کی نعمتوں کو یاد کرکے وہ خدا کی طرف پلٹ آئیں ۔فرمارہے ہیں ’’خدا نے ایک طرف تو تمہیں مادّی نعمتوں سے نوازا ہے کہ تمہیں چوپائے عطا فرمائے ہیں ، دوسری طرف تمہیں افرادی قوت عطا فرمائی ہے جو تمہارے سرمائے کی حفاظت کرسکتی ہے۔ لہٰذا اب تو خدا کی نعمتوں  اور احسانات کو یاد کرکے خدا کوماننے والے  اور اطاعت گذار بن جائو۔ &&(تفسیر نمونہ)&&خدانے فرمایا:@@’’ اور ہم نے اموال  اور اولاد کے ذریعہ تمہاری مدد کی  اور تمہاری تعداد بہت زیادہ کردی۔‘‘@@&&(سورۃ بنی اسرائیل آیت ۶)&& مگر تم تو ایسے احمق نکلے کہ اتنی نعمتیں عطا کرنے والے مالک کو بھلا دیا  اور ظلم وستم کو اپنا شعار بنالیا۔&&(مولف)&&
  26,134,آیت ۱۳۴کی تشریح:مطلب یہ ہے کہ تمہیں جو اپنی کثرتِ تعداد، طاقت  اور باغوں  اور سبزہ زاروں پر ناز ہے، تو یہ سب بھی تو خدا کی عطائیں  اور بخششیں ہیں ، تمہاری اپنی بنائی ہوئی تو نہیں ہیں ۔ نہ تمہارے دیوتا ایسے باغ اُگاسکتے ہیں اس طرح قرآن میں تو توحید پر استدلال غربت کے حوالہ سے بھی کیاگیا ہے،  اور مال ودولت ، قوّت وطاقت کے حوالے سے بھی کیا گیا ہے۔ یہ دونوں باتیں خدا کی قدرت کی دلیلیں ہیں ۔ یاد رہے کہ قومِ عاد، عرب کے سرسبز وشاداب  اور زرخیز زمینوں پر آباد تھی۔ یعنی یمن، حضرموت، عراق  اور خلیج فارس کے ساحلی علاقوں پر۔&&(تفسیر ماجدی)&&
  26,135,آیت ۱۳۵کی تشریح:حضرت ہودؑ نے قوم کو بھیانک انجام سے ڈرایا:اب حضرت ہودؑ اپنی تقریر کے آخری حصّے پر پہنچتے ہی قوم کو ڈراتے دھمکاتے ہیں اگر اب بھی تم خداوندِ عالم کی نعمتوں  اور احسانات کاانکار پر انکار کرو گے تو پھر مجھے تمہارے سروں پر بہت بڑے دن کے عذاب کاخطرہ منڈلاتا دکھائی دے رہا ہے۔ اُس دن تم اپنے تکبر،ظلم وستم، ہواوہوس، دنیاپرستی  اور خدا سے دوری کابھیانک انجام خود اپنی آنکھوں سے دیکھو گے &&(تفسیر نمونہ)&&قرآن مجید میں <<’’یومٍ عظیم‘‘>>بہت بڑا دن ۔قیامت کے دن کو کہاگیا ہے لیکن یہ لفظ قرآن مجید میں اُن دنوں کے لیے بھی کہا ہے، جن دنوں میں بدمعاش قوموں کو ان کی بدمعاشی کی سخت سزا دی جاتی ہے۔ &&(مفردات امام راغب)&&[[حدزاے چیرہ دستاں ، سخت ہیں قدرت کی تعزیریں]] &&(اقبال)&&
  26,137,آیت ۱۳۷کی تشریح: <<’’خُلُقْ‘‘>>کے معنی عادت، روش، اور اخلاق واطوار کے ہوتے ہیں ۔یہ لفظ اُس قوم کے اعمال کی طرف اشارہ کررہا ہے۔ &&(مفردات امام راغب)&&قومِ ہود کے اخلاق میں (۱) بت پرستی(۲) تکبر(۳) مضبوط محلات بنانا(۴) بے مقصد اونچے اونچے مقامات پر اپنی بلندی وبرتری کی نشانیاں بنانا(۵) سزا دینے میں حد سے زیادہ بڑھ جانا(۶) باپ، دادا، پردادائوں کی اندھی تقلید(۷) اناپرستی تھا۔ &&(تفسیر نمونہ)&&
  26,138,آیت ۱۳۸کی تشریح: اس کے دومعنی ہوسکتے ہیں ۔ ایک یہ کہ جو کچھ بھی ہم کررہے ہیں وہ آج کوئی نئی چیز نہیں ہے۔ صدیوں سے ہمارے باپ دادا یہی کچھ کرتے چلے آئے ہیں ۔ پھر بھلا اُن پر کونسی آفت ٹوٹی تھی کہ ہم پر عذاب آجائے گا۔ ہمارے طرز زندگی میں کوئی خرابی ہوتی تو خدا کاعذاب پہلے ہی ہم پر آچکا ہوتا۔ دوسرے معنی یہ بھی ہوسکتے ہیں کہ جو باتیں تم کررہے ہو، ایسی باتیں پہلے بھی بہت سے مذہبی خبطی کرچکے ہیں اخلاق کے سبق پڑھا چکے ہیں ، مگر دنیا کی گاڑی جیسے پہلے چل رہی تھی ، آج بھی چل رہی ہے۔ اگر تم جیسے لوگ سچے ہوتے تو یہ زندگی کی گاڑی کب کی اُلٹ چکی ہوتی۔ &&(تفہیم القرآن )&&
  26,139,آیت ۱۳۹کی تشریح:اس قوم کی ہلاکت کانقشہ قرآن نے یوں کھینچا ہے کہ اچانک زوردار آندھی اُٹھی، یہ احمق سمجھے کہ گھٹا چھارہی ہے۔خوشیاں منانے  اور گیت گانے لگے۔ مگر آٹھ راتوں تک ایسی طوفانی ہوا چلی کہ جس نے ہر چیز کو تباہ وبرباد کرڈالا۔ آدمیوں ، درختوں  اور اُونٹوں کو اٹھا اٹھا کر پھینک دیا۔ &&(تفسیرنمونہ)&&خدا کی نشانیاں :(۱) حق کی تکذیب کاانجام عذاب الٰہی کابھگتنا ہوتا ہے۔ (۲) عذاب الٰہی بھی خدا کی نشانی ہوتا ہے۔(۳) حق تلخ ہوتا ہے۔ (۴) خداوندعالم ہر قوم کو پہلے مہلت عمل دیاکرتا ہے (۵) انبیاءؑ کے ذریعے حقیقت کو سمجھانے کی روشن دلیل فرمایا (۹) نہ سمجھنے پر عذاب خدا آیا،  اور اُس سے کوئی بچانہ سکا ۔
  26,140,آیت ۱۴۰کی تشریح: خداوند عالم قہروغلبے والا،  اور عزت والا ہے۔ قوم نوحؑ کو ہلاک وبرباد کرنے میں ،  اور بیحد مسلسل رحم کرنے والا ہے نوح  اور اُن کے ماننے والوں کو نجات دینے میں ۔&&(تفسیر مجمع البیان)&&اسی لیے آخر میں خدا نے اپنی زبردست طاقت، عزّت  اور رحم کاحوالہ دیا ہے۔ &&(تفسیر ماجدی)&&
  26,141,آیت ۱۴۱کی تشریح:قوم ثمود نے قوم عاد کے بعد مزید ترقی کی ، معیارِ زندگی بلند سے بلند تر  اور معیارِ آدمیت پست سے پست تر ہوتا چلاگیا۔ قومِ عاد نے بڑے بڑے محلات میدانوں میں تعمیر کیے  اور قومِ ثمود نے پہاڑوں کے جگرتراش تراش کر ایلورا اور اجنٹا جیسے غاروں میں آرام دہ مکانات بنالئے تھے۔ دوسری طرف اُن کے اُمراِ  اور حکام بڑے ظالم وفاسد لوگ تھے، تکبر  اور دولت کے نشے میں اُنہوں نے بھی حق کو ماننے سے انکار کردیا۔ &&(تفہیم القرآن )&& قوم ثمود <<’’وادی القریٰ‘‘>>میں رہتے تھے۔ یہ وادی مدینہ  اور شام کے درمیان واقع ہے۔بڑی خوشحال قوم تھی، مگر اپنی سرکشی کی وجہ سے حرفِ غلط کی طرح مٹا دی گئی۔ اُن لوگوں کاانجام قومِ نوحؑ  اور قومِ عاد کی طرح ہوا۔ تاریخ واقعاً خود کو دہراتی ہے۔ &&(تفسیر نمونہ)&&کل کاتقابل آج سے:قومِ عاد ثمود  اور قومِ لوط  اور دیگر اقوام جوگذر گئیں وہ’’کل‘‘ کی قومیں تھیں ہم اُن کاتقابل آج کی اقوام سے عبرت کے لیے پیش کرتے ہیں ۔ (تاریخی  اور مشاہداتی جائزہ) کل کی قوموں نے کلمہ توحید نہیں پڑھا،  اور بت پرستی پر جمے رہے۔ آج کی قوموں نے کلمہ توحید پڑھا، لیکن نفس پرستی میں مبتلا ہوگئے ۔جنہوں نے کلمہ توحید سے بغاوت کی، وہ اہل توحید  اور کل کی اقوام سے تخریب کاری میں بہت آگے (ایڈوانس) نظرآتے ہیں ۔ کل کی قوموں نے انبیاء کرام کے قتل میں کمی باقی نہ چھوڑی۔بنی اسرائیل نے ایک ایک دن میں سوسو انبیاء کو قتل کیا۔ (تاریخی جائزہ) آج کی اقوام نے علماٰءئِ دین ، صلحائَ، فقہاء اور دیندار لوگوں کو بے دریغ قتل کرکے شقاوت میں کل کی اقوام کو بہت پیچھے چھوڑ دیا۔ عبادت گاہوں تک میں قتل سے گریز نہ کیا۔ کل کی اقوام جسمانی طور پر بڑی طاقتور، تلوار کی دھنی  اور مال واولاد میں بڑی مستحکم  اور انجام سے بیخبر تھیں آج کی اقوام جسمانی طور پر مقابلۃًکمزور لیکن بارودی طاقت  اور مال واولاد میں اُن سے زیادہ مستحکم انجام سے بیخبرکل کی قوموں نے پہاڑوں کوتراش کو محلات  اور میدانوں میں اونچی اونچی عمارتیں تعیشات کے لیے تعمیر کیں ۔ آج کی اقوام نے پہاڑوں ، دریائوں ، سمندروں ، میدانوں ، شاہراہوں ،  اور خلائوں میں بلند ترین عمارات تعمیر کیں ۔کل کی قوموں نے عورتوں کو چھوڑ کر لڑکوں  اور مردوں سے بداخلاقی کی۔ آج کی اقوام نے اس بداخلاقی میں کمی نہیں کی۔کل کی قوموں نے راگ، رنگ، کی محفلوں میں غیر عورتوں ،  اور کنیزوں کو تعیشات کے لیے مخصوص کیا۔ آج کی اقوام نے راگ ورنگ  اور بداخلاق شاعری کی محفلیں ایسی جمائیں کہ گھر گھر میں راگ، رنگ  اور موسیقی کی محفلیں زور شور انداز میں نظر آتی ہیں ۔ کنیزوں  اور غیر عورتوں کی بجائے شریف گھرانے کی عورتیں بہو،بیٹیاں ، مائیں بہنیں  اور بیویاں کھل کر غیروں کو دادِ عیش دیتی نظر آتی ہیں ۔شوہر اپنی بیوی کو، باپ اپنی بیٹی کو ،بھائی اپنی بہنوں کو،  اور اہل خاندان اپنی مائوں ، بہنوں ، بیٹیوں کو راگ ، رنگ ، ناچ ، گانوں نیم عریان لباس میں (غیر ملفوف) اندا زمیں ڈراموں ، سینمائوں  اور مہمانانِ خصوصی کی دلجوئی کے لیے اسٹیجوں پر رقص وسرود کی سرگرم محفلوں میں دیکھ دیکھ کر بیحد مسرور ہی نہیں ہوتے بلکہ فخر کرتے ہیں کہ شریف زادیوں  اور اعلیٰ خاندان کی بہن بیٹیوں نے کتنا زبردست کردار ادا کیا۔ جن کی اداکاری  اور گلوگاری پر بڑے بڑے انعامات دیے جاتے ہیں ۔ وغیرہ وغیرہ  اور وغیرہکل کی اقوام پر،مہلتوں پر مہلتیں دینے کے بعدعذابِ الٰہی آیا، اُن پر نام بہ نام پتھر برسائے گئے اُن کی بستیوں کو زمین سے اُکھاڑ کر آسمان کے قریب لے جاکر اُلٹا کرکے زمین میں دھنسا دیا۔ اُن کو غاروں سے نکال نکال کر تیز وتندآندھیوں نے اُٹھا اُٹھاکرزمین پر دے مارا۔ اُن کو عرق آب کردیا۔ اُن پر بادلوں سے پانی کی بجائے آگ برسائی۔ اور ہلاک کرڈالا۔ اُن کا تو وجودی نام ونشان نہ رہا سوائے فرعون کے البتہ اُن کے برباد شدہ محلات اب بھی قابل عبرت ہیں ۔مگر کس کے لیے ؟۔۔۔جبکہ آج کی قومیں ، کل کی قوموں سے بہت ہی ایڈوانس  اور مغفّل نظر آرہی ہیں ۔گذشتہ تمام انبیاء کرامؑ کی بدکردار اقوام ایک طرف اور دوسری طرف سرکارِ دوعالم ، سردارِ انبیاء کی امت اُن اقوام سے کہیں زیادہ ایڈوانس نظر آتی ہے  اور مغفل بھی ۔&&(مولف)&&
  26,143,آیت ۱۴۳کی تشریح:حضرت صالحؑ کی امانت، دیانت، شرافت  اور قابلیت کو تو اُن کی قوم نے خود مانا تھا۔ اس لیے کہ اُنہوں نے کہاتھا:’’اے صالحؑ!اس (اعلانِ نبوت) سے پہلے تو تم ہمارے درمیان ایسے آدمی تھے جس سے ہماری بڑی اُمیدیں وابستہ تھیں ۔‘‘ &&(سورۃ ہود آیت ۶۶ پ۱۴)&&
  26,146,آیت۱۴۶ کی تشریح: مطلب یہ تھا کہ کیا تمہارا یہ خیال ہے کہ تمہارا یہ عیش دائمی وابدی ہمیشہ ہمیشہ رہے گا؟ کیا تم سے کبھی ان نعمتوں کاحساب نہیں لیا جائے گا؟ اور کبھی ان کاموں کے بارے میں تم سے حساب کتاب، سوال وجواب نہ ہوگا، جو بدمعاشیاں تم کررہے ہو؟ &&(تفہیم القرآن )&&
  26,148,آیت ۱۴۸ کی تشریح:آیت میں لفظ<<’’ھضیم‘‘>> استعمال ہوا ہے جس کے معنی کھجور کے ایسے گھچے ہیں جو کھجوروں سے لدلد کر جھُک گئے ہوں ،  اور جن کے پھل پکنے کی وجہ سے پھٹے پڑتے ہوں ۔&&(مفردات القرآن امام راغب)&&
  26,149,آیت ۱۴۹کی تشریح: یادرہے کہ قومِ ثمود عربستان کےشمالی  اور مغربی علاقوں میں آباد تھی، جو بہت سرسبز وشاداب علاقے ہیں ۔ &&(تفسیر ماجدی)&& یعنی یہ سب کچھ اپنی بڑائی ، اپنی دولت  اور قوت اور فن کاکمال دکھانے کے لیے تھا۔ کوئی حقیقی ضرورت اُن محلات کے بنانے کی نہ تھی۔ ایک بگڑے ہوئے معاشرے کی یہی شان ہوا کرتیہے کہ ایک طرف غریبوں کو سرچھپانے کی جگہ نہیں ملتی،  اور دوسری طرف اہل دولت بلاضرورت محل (فلیٹس، پلازے، ٹاور ، بینگلوز)  اور عمارتیں بناتے چلے جاتے ہیں ،  اور نمائشی یادگاریں تعمیر کرتے ہی چلے جاتے ہیں ۔ &&(تفہیم القرآن )&& ایک شاعر نے تاج محل کے لیے کیا خوب کہا ہے کہ:{{اک شہنشاہ نے دولت کاسہارا لے کرہم غریبوں کی محبت کااڑایاہے مذاق }}قوم ثمود کی عمارتیں ابھی تک باقی ہیں ۔مدینہ  اور تبوک کے درمیان العلا کامقام ہے جسے وادی القریٰ  اور مدائن صالح کہتے ہیں ۔&&(تفہیم)&&
  26,152,آیت۱۵۲کی تشریح:فساد فی الارض:قرآن مجید کی رو سے ہر گناہ، ہر تجاویز، ہرخرابی فساد ہے۔ اصل میں یہ کائنات ، نظم وصلاح پر قائم ہے۔ اگر کسی وقت بھی عالم کے نظم وصلاح، ملاپ  اور ہم آہنگی میں ذرا سا فرق آجائے،  اور کائنات کاکوئی ایک جزو (کرہّ) اپنے مقررہ راستے سے ذرا ساہٹ جائے تو پورا نظام درہم وبرہم ہوجائے گا۔ &&(تفسیر المیزان)&&بالکل اسی طرح انسان بھی اس کائنات عالم کاایک جزو ہے ۔ وہ بھی اس عمومی قانون سے الگ نہیں رہ سکتا۔اگر قانون الٰہی کے مطابق چلتا رہے تو اپنے مقصد تک پہنچ جاتا ہے لیکن اگر حدوں سے تجاوز کرتا ہے، خدا کے مقرر کیے ہوئے راستے سے ہٹ جائے تو فساد فی الارض کرنے لگتا ہے۔ &&(تفسیر نمونہ)&&آخر کارخدا سخت حوادث کے ذریعہ سے اُس کو متنبہ فرماتا ہے۔ خدا نے ارشاد فرمایا کہ:<<ظَہَرَ الْفَسَادُ فِي الْبَرِّ وَالْبَحْرِ بِمَا كَسَبَتْ اَيْدِي النَّاسِ لِيُذِيْقَہُمْ بَعْضَ الَّذِيْ عَمِلُوْا لَعَلَّہُمْ يَرْجِعُوْنَ۴۱ >>&&(سورہ روم آیت ۴۱)&& یعنی @@’’لوگوں کے اعمال کی وجہ سے خشکی  اور تری (جنگلوں  اور سمندروں ) میں فساد برپا ہوگیا (خدا چاہتا ہے ) کہ لوگوں کو اُن کے بُرے اعمال کاذائقہ چکھائے تاکہ وہ سیدھے راستے کی طرف پلٹ آئیں ۔‘‘@@&&(سورۃ روم ۴۱)&&<<فساد فی الارض>>: یعنی زمین پر خرابیاں پھیلانا۔تمام خرابیاں خد اکے قانون کو نہ ماننے کی وجہ سے پیدا ہوتی ہیں ۔ فساد میں قتل، غارتگری ، فحاشی ، بدکاری ، ظلم، خیانت، رشوت، غصب ، ایذارسانی، جھوٹ بے ایمانی، بدمعاشی سب شامل ہیں ۔ قرآن ان سب کو فساد فی الارض کانام دیتا ہے ۔&&(ماجدی)&& یہ آیت متکبرین، روساء اور حکامِ جور  اور اُن کے پیرکاروں کے بارے میں ہے وہ حدودِ خدا سے تجاوز کرتے ہیں ۔&&(تفہیم)&&
  26,153,آیت ۱۵۳کی تشریح: <<’’مسحرین‘‘>>کے معنی’’بار بار جادو یاآسیب میں مبتلا ہونے والے کے ہوتے ہیں ۔&&(تفسیر تبیان)&&دوسرے معنی دھوکہ باز، یادھوکہ کھایا ہوا کے بھی ہوتے ہیں ۔ &&(تفسیر مجمع البیان)&&<<’’مسحور‘‘>> سحرزدہ یعنی دیوانہ ، پاگل، مجنون جس کی عقل ماری گئی ہو، وہ بھی جادو کے اثر سے غرض مسحور سے اصل مراد مجنون ، پاگل ہوتا ہے۔ &&(مفردات القرآن امام راغب)&&
  26,155,آیت نمبر۱۵۵:حضرت صالح ؑکی اونٹنی:حضرت صالح ؑکی قوم نے آپؑ سے فرمائش کی کہ اگر تم سچے پیغمبر خدا ہو تو اس پتھر سے دس ماہ کی حاملہ سرخ رنگ کی اونٹنی پیدا کرو۔ چنانچہ حضرت صالحؑ نے خدا سے دعاء کی ، اُونٹنی پیدا ہوئی۔پھراُنہوں نے کہا کہ ہمارے سامنے اس اونٹنی سے بچہ پیداہو۔ آپؑ کی دعاء سے بچہ پیدا ہوا جواپنی ماں کی قدوقامت سے طویل وعریض تھا۔ غریبوں کاایک طبقہ یہ معجزہ دیکھ کر مومن ہوگیا لیکن متکبرین کاطبقہ اپنے کفر پر ہی ڈٹا رہا بہرحال حضرت صالحؑ نے قوم سے کہا کہ چشمے (یاحوض) کاپانی ایک دن اس اُونٹنی کے لیے ہوگا،  اور دوسرے دن تمہارے مویشی وغیرہ اس سے پانی پئیں گے ۔قوم کے کچھ بدمعاش حضرت صالحؑ کے مخالف ہوگئے تھے۔ اس لیے اُن مخصوص مردوزن نے اُونٹنی کو قتل کرنے کی ٹھان لی،  اور قدار  اور مصدع نامی دوبدمعاشوں کوخوبصورت عورتوں سے شادی کا لالچ دلا کر اونٹنی کے قتل پر تیار کرلیا۔ چنانچہ ایک دن جب اُونٹنی چشمے سے پانی پی کر واپس ہوئی تو مصدع نے اس کے پیر میں تیر مارا  اور قدار نے پچھلے پیروں کے پٹھے ( یعنی کونچیں ) کاٹ ڈالیں ۔قدار کی محبوبہ قطام نامی خوبصورت عورت تھی، وہ بھی موقع پرموجود تھی، اُس نے قدار کو مزید اُکسایا  اور قدار نے ایک تیراُونٹنی کے پیٹ پر مارا اونٹنی چیختی چلاتی ہوئی زمین پر گر پڑئی تمام شہر کے لوگوں نے اُس کاتکابوٹی کرکے گوشت تقسیم کرلیا  اور خوب کھایا۔اُونٹنی کے بچے نے یہ دیکھا تو دوڑ کر پہاڑ پر چڑھ گیا  اور آسمان کی طرف منہ کرکے تین بار اتنے زور سے چیخا کہ لوگوں کے دل تھرتھرانے لگے لوگ حضرت صالحؑ سے معذرت کے لیے آئے۔ اللہ نے وحی فرمائی کہ اے صالحؑ!ان سے کہہ دو کہ اگر یہ واقعی توبہ کرلیں تو میں اب بھی توبہ کوقبول کرلوں گا، ورنہ ان پر عذاب آئے گا۔ اس قوم کے لوگ  اور زیادہ سرکشی پر اُترآئے  اور بجائے توبہ کے کہنے لگے: لے آ وہ عذاب جس کی تو ہمیں دھمکی دیتا ہے۔‘‘ آپؑ نے فرمایا:اے قوم والو!تم نے عذاب مانگا ہے تو سنو’’کل تمہارے منہ زرد ہوجائیں گے ، پرسوں سرخ ہوں گے  اور تیسرے دن تمہارے منہ سیاہ ہوں گے‘‘پس پہلے دن اُن کے چہرے زرد، دوسرے دن سرخ  اور تیسرے دن سیاہ ہوگئے۔ اُن لوگوں کو عذاب کا یقین ہوگیا تو اُنہوں نے کفن پہن لیے  اور رحنوط کرلیا۔ پھر آدھی رات کو جبرئیلؑ نے <<’’صیحہ ‘‘ >> یعنی سخت چیخ ماری جس سے اُن کے کان  اور دل وجگر پھٹ گئے  اور سب کے سب گر کر مر گئے۔ صبح کو آسمان سے آگ نازل ہوئی جس نے اُن کی لاشوں کو جلا کر خاکستر کردیا۔ &&(از تفسیر انوار النجف جلد۶)&&&&(ملخص)&&{{شقی ترین دو آدمی تھے:ثعلبی سے منقول ہے کہ جناب رسالت مآبؐ نے فرمایا: ’’اے علیؑ ‘‘ تم جانتے ہو کہ اوّلین میں سے شقی ترین کون تھا؟‘‘ عرض کی : اللہ  اور اُس کا رسولؐ بہتر جانتے ہیں (۱) پس آنحضرتؐ نے فرمایا: وہ ، وہ شخص تھا جس نے ناقہ صالحؑک و پے(قتل) کیاتھا‘‘ پھر فرمایا: آخرین میں شقی ترین کون ہوگا؟‘‘ عرض کی:اللہ  اور اُس کا رسولؐ بہتر جانتے ہیں ۔‘‘(۲) پس آنحضرتؐ نے فرمایا:’’وہ وہ ہوگا جو اے علیؑ تم کو قتل کرے گا۔ حضورؐ نے حضرت علیؑ کے سر  اور ریش مبارک کی طرف اشارہ کرکے فرمایا: <<من یخصب ھذہٖ من ھٰذِہٖ‘‘>>’’ یعنی ‘‘جو داڑھی کو سر کے خون سے خضاب ورنگین کرے گا۔‘‘&&(تفسیر انوارالنجف جلد۶ص ۵۵)&& }}
  26,156,آیت نمبر۱۵۶:<<’’سُوئٌ‘‘>>کے معنی تکلیف، بُرائی ، آفت، گناہ کے ہوتے ہیں ۔ ہر بُرے کام یا عیب کو بھی <<’’سُوئٌ‘‘>>کہتے ہیں ۔&&(تفسیر ماجدی)&&علامہ سید مرتضیٰ زبیری نے لکھا کہ یہ لفظ تمام آفتوں  اور بیماریوں کاجامع ہے۔ &&(تاج العروس)&&معجزے کے مطالبے پر اُس اونٹنی کو پیش کرنا بتا رہا ہے کہ وہ عام اُونٹنی نہ تھی، بلکہ اُس کی پیدائش  اور اُس کاقدوقامت سب معجزانہ تھا۔ &&( یعنی محیرالعقول، جو عقول کوحیرت واستعجاب میں ڈال دے)&& &&(تفہیم القرآن )&& اس لیے خدا نے فرمایا:@@ یہ اللہ کی اُونٹنی ہے جو تمہارے لیے خدا کی نشانی (یا) معجزہ ہے۔‘‘@@ &&(سورہ ہود)&&
  26,157,آیت ۱۵۷کی تشریح:ناقہ صالحؑ کو قتل کرنے والوں کی شرمندگی اس لیے کام نہ آئی کہ اُنہوں نے اپنے گناہ کی تلافی ایمان لانے سے نہ کی۔ اسی لیے عرفاءنے نتیجہ نکالا کہ توبہ کے لیے صرف طبعی شرمندگی کافی نہیں ہوتی، بلکہ عقلی ندامت  اور اصلاحِ عمل میں بھی ضروری ہے۔ &&(تفسیر روح المعانی)&&آیت کایہ مطلب نہیں ہے کہ جیسے ہی لوگوں نے حضرت صالحؑ کی تقریر سنی، وہ فوراً ہی اُس اُونٹنی پر پل پڑے  اور اُسے قتل کرڈالا۔ بلکہ اصل بات یہ ہے وہ اُونٹنی کافی عرصے قوم کے درمیان (چلتی پھرتی، چشمے کا پانی پیتی  اور چراگاہ کی گھاس  اور چارہ چرتی) رہی۔ مگر بدمعاشوں میں آپس میں اُس کے خلاف مشورے ہوتے رہے۔ آخر کار ایک منچلے بدبخت  اور شقی سردار نے فیصلہ کرلیا کہ وہ اپنی قوم کو اس اُونٹنی سے نجات دلائے گا۔&&(تفہیم القرآن )&& روئےزمین پر پانی کاپہلا چشمہ:جناب امیر المومنین علیہ السلام سے منقول ہے کہ روئے زمین پر پانی کاپہلاچشمہ وہی ہے جو حضرت صالح علیہ السلام کے لیے ظاہر کیا گیاجس کاپانی ایک دن اُن کی اونٹنی پیتی تھی،  اور دوسرے دن لوگوں کے لیے معین ہوا لیکن اُن بدبختیوں نے اُس ناقے ( اونٹنی ) کو پے کرکے عذاب الٰہی کو پسند کیا پس تباہ کردیے گئے۔ &&(تفسیر مجمع البیان، تفسیر انوارالنجف مولانا حسین بخشؒ سورۃ القمر:میں ارشاد فرمایا:<<اِنَّا مُرْسِلُوا النَّاقَۃِ فِتْنَۃً لَّہُمْ فَارْتَقِبْہُمْ وَاصْطَبِرْ۲۷ۡ وَنَبِّئْہُمْ اَنَّ الْمَاۗءَ قِسْمَۃٌۢ بَيْنَہُمْ۰ۚ كُلُّ شِرْبٍ مُّحْتَضَرٌ۲۸ فَنَادَوْا صَاحِبَہُمْ فَتَعَاطٰى فَعَقَرَ۲۹ فَكَيْفَ كَانَ عَذَابِيْ وَنُذُرِ۳۰ اِنَّآ اَرْسَلْنَا عَلَيْہِمْ صَيْحَۃً وَّاحِدَۃً فَكَانُوْا كَہَشِيْمِ الْمُحْتَظِرِ۳۱>> &&(سورۃ القمرآیت ۲۷تا۳۱)&& یعنی@@ :ہم اُن کی آزمائش کے لیے ایک اونٹنی بھیجنے والے ہیں پس تم ذرا صبر کرو اُنہیں دیکھتے رہو(منتظر رہو)  اور اُن کو یہ خبر دے دو کہ چشمے کاپانی اُن کے مابین تقسیم کردیاگیا ہے ہر فریق اپنی باری پر پانی پینے کے لیے حاضر ہو۔ پھر اُنہوں نے (یہ برداشت نہ کیا  اور )اپنے ایک (بدبخت) ساتھی کو بلایا، جس نے یہ کام اپنے ذمےّ لے کراُونٹنی کی کونچیں کاٹ ڈالیں پس اُن پر میرا عذاب (وارد ہوا تو) میراڈرانا کیسا رہا؟ بیشک ہم نے اُن پر ایک چنگھاڑ بھیجی ۔  اور سوکھی ہوئی باڑھ کی مانند ہوگئے۔‘‘سورۃ الشمس میں فرمایا:@@’’قوم ثمود نے اپنی سرکشی کے سبب حق کوجھٹلادیا، جبکہ اُنہوں نے اپنے میں سے ایک بدترین شقی القلب شخص(قدار) کو اُونٹنی کے قتل پر مامور کیا۔ حالانکہ اللہ کے رسول نے تواُن سے کہہ دیا تھا کہ یہ اللہ کی اُونٹنی ہے اسے پانی پینے دو۔ مگر اُنہوں نے اُسے جھٹلادیا  اور اونٹنی کی کونچیں کاٹ ڈالیں تو اُن کے گناہوں پر اللہ اُن پر عضبناک ہو اور اُن کو پیوندزمین کردیا۔ @@
  26,160,آیت ۱۶۰کی تشریح: <<کَذَّبَتُ>>: خداوند عالم نے ہرنبی کی دعوت کی حکایت ایک ہی لفظ سے فرمائی  اور تمام کاکلمہ ایک ہی ذکر کیا۔ اس سے معلوم ہواکہ تمام انبیاء کی دعوت کامحوری ومرکزی نقطہ ایک تھا اور وہ ہے توحید کی معرفت  اور اللہ کاتقویٰ ۔چنانچہ سب نبی معرفت کادرس اوّلہ وبراہین  اور اس کی نعمات کے ذکر سے دیتے رہے۔&&(تفسیر انوارالنجف)&&
  26,165,آیت۱۶۵کی تشریح:اس کامطلب یہ ہے کہ ساری مخلوق میں صرف ایک تم لوگ ہوجو مردوں سے اپنی جنسی خواہش کو پورا کرتے ہو۔ جبکہ دنیا میں بکثرت عورتیں موجود ہیں ۔&&(تفہیم القرآن )&& سورہ عنکبوت میں ارشاد فرمایا:<<’’انّکم لتاتون الفاحشۃز ماسبقکم بھامن احَد من العٰلمین۔ >> &&(سورۃ العنکبوت آیت )&& یعنی@@ بیشک تم تو بے حیائی کاوہ کام کرتے ہو جوتم سے پہلے جہانوں کی مخلوق میں کسی نے نہیں کیا‘‘@@ سورۃ الاعراف میں قومِ لوط سے کہاگیا:@@ یقیناً تم عورتوں کی بجائے مردوں سے شہوت رانی پر مائل ہوئے ہو۔ تم اسراف کرنے والے (بھی)ہو،  اور حدوں سے آگے بڑھ جانے والے لوگ ہو۔‘‘&&(سورۃ الاعراف آیت ۸۱)&& سورۃ الانبیاء میں ارشاد فرمایا:<<’’وَلُوْطًا اٰتَيْنٰہُ حُكْمًا وَّعلماٰء وَّنَجَّيْنٰہُ مِنَ الْقَرْيَۃِ الَّتِيْ كَانَتْ تَّعْمَلُ الْخَـبٰۗىِٕثَ۰ۭ اِنَّہُمْ كَانُوْا قَوْمَ سَوْءٍ فٰسِقِيْنَ۷۴ۙ >>&&(سورۃ الانبیاء آیت۷۴)&& یعنی :@@’’ اور لوطؑ کو ہم نے حکمت  اور علم عطا کیا  اور اُن کو اُس بستی والوں سے نجات دلائی جو بہت ہی بُرے (خبیث)کام کرتے تھے۔ یقیناًوہ ایک بہت ہی بُری  اور بدکار قوم تھی۔‘‘@@اسی طرح سورۃ النمل میں ارشاد فرمایا:<<’’وَلُوْطًا اِذْ قَالَ لِقَوْمِہٖٓ اَتَاْتُوْنَ الْفَاحِشَۃَ وَاَنْتُمْ تُبْصِرُوْنَ۵۴ اَىِٕنَّكُمْ لَتَاْتُوْنَ الرِّجَالَ شَہْوَۃً مِّنْ دُوْنِ النِّسَاۗءِ۰ۭ بَلْ اَنْتُمْ قَوْمٌ تَجْـہَلُوْنَ۵۵>> &&(سورہ النمل آیت ۵۴۔۵۵)&& یعنی :@@’’ اور جب لوطؑ نے اپنی قوم ہے کہا:’’کیا تم دیکھتے بھالتے ہوئے(جان بوجھ کر) بھی فحش  اور بدکاری کی طرف رغبت کرتے ہو؟کیا تم عورتوں کی بجائے مردوں سے اپنی شہوت پوری کرتے ہو۔یقیناً تم تو ایک جاہل  اور کج فہم قوم ہو۔‘‘@@’’فسق‘‘کے معنی خداکی اطاعت کے دائرے کو توڑ کر باہر نکل جانا’’جہل‘‘کے معنی خطرناک نتائج کونہ جاننے کی وجہ سے خطرناک کام کرنا۔{{ لوطؑ کی قوم کاسب سے بڑا جرم ہم جنس پرستی تھا۔جناب رسولؐ نے فرمایا: جس نے لواطت کی وہ جنت کی خوشبو بھی نہ سونگھے گا&&(بحارالانوار طبع جدید)&&}}{{ (۱) آپؐ ہی نے فرمایا: جو کوئی اپنی عورت(زوجہ) سے دُبر کی راہ سے نزدیکی (دخول)کرے اللہ تعالیٰ اُس کو اوندھا کرکے آتش جہنم میں ڈالے گا۔‘‘(۲) جوکوئی اپنی بیوی سے دُبر میں دخول کامرتکب ہواللہ اُس کو قیامت کے دن ایسی حالت میں اُٹھائے گا کہ وہ مردار سے زیادہ بدبودار ہوگا  اور اللہ اُس پر لعنت کرے گا۔ &&(کوکب دری ص۵۲۹)&&}}{{فرزندِ رسول خداؐ حضرت امام علی رضا علیہ السلام نے فرمایا: ’’مردوں سے جنسی عمل خدا وندعالم کی بنائی ہوئی فطرت کے خلاف ہے  اور یہ اس لیے بھی حرام ہے کہ اگر مرد، مردوں سے  اور عورتیں ، عورتوں سے جنسی ملاپ کرنے لگیں گی تو نسل انسانی منقطع ہوجائے گی ۔ اور دنیا تباہ ہوجائے گی،  اور اجتماعی زندگی کی تمام تدابیریں برباد ہوجائیں گی۔&&(بحارالانوار جلد۷۹ طبع جدید)&& }}
  26,166,آیت ۱۶۶کی تشریح:آج بھی دنیا کی بہت سی مہذب قومیں ہم جنس پرستی کی بدفعلیوں میں مبتلا ہیں ( اور قوم لوطِ کے شانہ بہ شانہ چل کر اپنے کردار کو مسخ کرچکی ہیں ) خداوندعالم کاایسے لوگوں کو قوم عادون( یعنی )@@‘‘ حد سے گذر جانے والے لوگ ’’@@کہنا، بتانا ہے کہ اُن کی بدفعلیوں کا اصل سبب فطری یاطبعی جنسی خواہش نہ تھی، بلکہ یہ حد سے بڑھ جانے کی شکل ہے۔ ا س لیے اس کو صرف نفس کی خباثت  اور طبیعت کاشیطانی میلان کہہ سکتے ہیں جس کی وجہ سے اُنہوں نے فطری حدوں کو توڑ کر غیر فطری طریقہ اختیار کیا اس لیے یہ فعل مجرمانہ  اور مسخ ذہنیت کاثبوت ہے۔ &&(تفسیر ماجدی)&&آیت کامفہوم یہ ہے کہ :’’اے قوم!تمہارا جرم صرف یہی نہیں ہے کہ تم ہم جنس پرستی میں مبتلا ہو، بلکہ تم لوگ زندگی کے ہر معاملے میں حد سے آگے نکل جانے والے لوگ ہو۔‘‘&&(تفہیم القرآن )&& {{جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’جوشخص کسی لڑکے کاشہوت کے ساتھ بوسہ لے گا تو خدا قیامت کے دن اُس کے منہ میں آگ کی لگام چڑھا دے گا۔ &&(بحارالانوار جلد۷۹)&& }}سورہ عنکبوت میں فرمایا:@@’’کیا تمہارا یہ حال ہوچکا ہے کہ تم (کھلم کھلا) مردوں کی طرف مائل ہوتے ہو  اور ڈاکے ڈالتے ہو، اپنی محفلوں میں بیحیائی کے(بُرے بُرے کاموں کے )مرتکب ہوتے ہو؟‘‘@@&&(سورۃ العنکبوت آیت ۲۹)&&@@’’اے عقل وبصیرت رکھنے والو!عبرت حاصل کرو قومِ لوط کے انجام سے‘‘@@
  26,167,آیت ۱۶۷کی تشریح:لوطؑ کو قوم والے پاک دامن لوگوں کو بہت بُری طرح ذلیل کرکے جلاوطن کیاکرتے تھے۔ &&(تفسیر کبیر امام رازی۔ تفسیر روح المعانی)&&مگر حضرت لوطؑ نے اُن کی دھمکیوں کی کوئی پرواہ نہ کی ۔ &&(تفسیر نمونہ)&&حضرت لوطؑ نے اپنی قوم کو سمجھانے کی کوشش کی  اور کہا کہ تم لوگ اس بُری عادت کو ترک کردو  اور حلال طریقے سے اپنی بیویوں سے خواہش نفسانی کی پیاس بجھائو۔‘‘پس جھوٹے  اور لاجواب انسانوں کی طرح دھمکی پراُترآئے کہ ہم تم کو نکال باہر کریں گے ۔ (اصل میں جب کسی کے پاس کوئی معقول دلیل نہیں ہوتی تو وہ طاقت استعمال کرتا ہے جیسے نمردو، جب حضرت ابراہیمؑ کے سامنے لاجواب ہوگیا تو اُس نے اپنی مادّی طاقت استعمال کی، فرعون جب  حضرت موسٰی علیہ السلام  کے سامنے کوئی دلیل نہ لاسکا تو اُس نے بھی طاقت کی دھمکی دی۔ اسی طرح یزید ملعون جب امام حسینؑ سے بیعت نہ لے سکا تو اُس نے بھی اپنی مادی طاقت استعمال کرکے نواسئہ رسول خداؐ، جگر گوشہ بتولؑ کے اہل بیعتؑ کو  اور خاندانِ رسولؐ کو تاراج کردیا) &&(تفسیر انوارالنجف)&& نتیجہ:مگر حضرت لوطؑ نے ان کو دھمکیوں کی کوئی پرواہ نہ کی۔ &&(تفسیر نمونہ)&&
  26,168,آیت ۱۶۸کی تشریح: قابل توجہ بات یہ ہے کہ حضرت لوطؑ نے یہ فرمایا کہ:’’میں تمہارے اعمال کادشمن ہوں ‘‘ یعنی :مجھے تم سے کوئی ذاتی دشمنی نہیں ہے۔ مجھے تمہاری بے حیائی کے کاموں سے نفرت ہے، اگر تم ان بُرے کاموں کو چھوڑ دو گے تو میں تمہارا بہترین دوست ہوں ۔ نتیجہ:دشمنی برائی سے ہونی چاہیے، بُرے آدمی سے دشمنی برائی کی وجہ سے ہوتی ہے نہ کہ آدمی سے۔
  26,169,آیت۱۶۹ کی تشریح: اس دعاء کے دومطالب ہوسکتے ہیں ۔(۱) یعنی : اے خدا ہمیں اس بُری قوم کے بُرے اعمال کے بُرے انجام سےبچانا(۲) دوسرا مطلب یہ بھی ہوسکتا ہے کہ اس بدکردار بستی میں جوگندگی پھیلی ہوئی ہے اس سے ہماری آل والاد کوبچائے رکھنا کہ کہیں وہ نہ بگڑجائیں اس لیے اے مالک!ہمیں اسی ہروقت کے عذاب سے نجات عطا فرما جو اس گندے معاشرے میں زندگی بسر کرنے کی وجہ سے ہم پر گزر رہا ہے ۔&&(تفہیم القرآن )&& حضرت لوطؑ کی اپنے خاندان والوں کے لیے دعاء کرنا خاندان کی محبت کی وجہ سے نہیں تھی بلکہ اُن کے ایمان لانے کی وجہ سے تھی۔&&(تفسیر نمونہ)&& اسی لیے اُن کی بیوی کے بارے میں اُن کی دعاء قبول نہ ہوئی۔&&(مولف)&&
  26,171,آیت ۱۷۱کی تشریح:’’بڑھیا‘‘سے مراد حضرت لوطؑ کی بیوی ہے۔&&(تفسیر جلالین)&&’’سورۃ التحریم‘‘میں ارشاد ہوا:<<’’ضَرَبَ اللہُ مَثَلًا لِّلَّذِيْنَ كَفَرُوا امْرَاَتَ نُوْحٍ وَّامْرَاَتَ لُوْطٍ۰ۭ كَانَتَا تَحْتَ عَبْدَيْنِ مِنْ عِبَادِنَا صَالِحَيْنِ فَخَانَتٰہُمَا فَلَمْ يُغْنِيَا عَنْہُمَا مِنَ اللہِ شَيْــــًٔا وَّقِيْلَ ادْخُلَا النَّارَ مَعَ الدّٰخِلِيْنَ>>۱۰ &&(سورہ التحریم آیت۱۰)&& یعنی :@@جن لوگوں نے کفراختیار کیا،اللہ اُن کے لیے نوحؑ  اور لوطؑ کی بیویوں کی مثال بیان کرتاہے وہ دونوں (عورتیں ) ہمارے دوصالح بندں کے ماتحت تھیں پس اُن دونوں (عورتوں ) نے دونوں (شوہروں نوحؑ  اور لوطؑ) سے خیانت کی پس دونوں (صالح) بندے اللہ کے مقابلے میں اُن کے ذرا بھی کام نہ آسکے(اُنہیں عذاب سے بچا نہ سکے)  اور اُن دونوں عورتوں سے کہا گیا کہ تم دونوں جہنمیوں کے ساتھ جہنم کی آگ میں داخل ہوجائو۔‘@@‘سورۃ ہود میں ارشاد فرمایا:@@’’پس (اے لوطؑ) تم کچھ رات باقی رہنے پر اپنے اہل وعیال کو ساتھ لے کر چلے جانا،  اور تم میں سے کوئی بھی پیچھے مڑ کر نہ دیکھے، مگر تمہاری بیوی (پیچھے مڑکر ضرور دیکھے گی) کیوں کہ اُس پر وہی کچھ گذرے گی جو اُن(بدمعاش) لوگوں پر گذرے گی۔ @@&&(سورہ ہود آیت ۸۱)&&
  26,173,آیت نمبر۱۷۳:حضرت لوطؑ کی قوم پر عذاب کاذکر:حضرت لوطؑ نے جب اپنی قوم کے معذب ہونے کی خبر سُنی تو دریافت کیا کہ عذاب کب آئے گا؟جبرئیلؑ نے جواب دیا۔اُن پر عذاب کامقررہ وقت صبح کاوقت ہے۔‘‘قوم لوطؑ پر دوقسم کے عذاب آئے۔ ایک اُن کے طبقہ زمین کو اُلٹ دیاگیا۔  اور دوسرا یہ کہ اُن پر پتھروں کی بارش ہوئی۔ پس ممکن ہے کہ پہلے اُن پر پتھروں کی بارش ہوئی ہو۔ یایہ کہ اُن لوگوں کے دوگروہ ہوں ۔ ایک گروہ پر ایک عذاب،  اور دوسرے گروہ پر دوسرا عذاب نازل کیاگیا ہو(واللہ اعلم) مروی ہے کہ قوم لوطؑ کاایک آدمی اُن دنوں حرم کی حدود میں داخل تھا، اُس کے نام کاپتھر آسمان  اور زمین کے درمیان معلق رہا، جب وہ حرم سے باہر آیاتو پتھر گرا اور وہ وہیں ڈھیر ہوگیا۔ عذاب میں گرفتار ہونے والوں کی کل تعداد چالیس لاکھ تھی ۔ &&(مجمع البیان)&& (ہر آدمی کے نام کا پتھر الگ تھا) مروی ہے کہ جبرئلؑ نے اپنے پرکی نوک سے اُن لوگوں کی بستیوں کے طبقے کو زمین سے اُکھاڑا  اور اس قدر بلند کیا کہ اُن کے مرغوں کی اذانوں ،  اور کتوں کے بھونکنے کی آوازیں اہل آسمان نے سُنیں پس جبریلؑ نے اتنی بلندی سے اُن بستیوں کے طبقے کو اُلٹا کرکے پھینک دیا۔ جیسا کہ قرآن نے سورہ ہود میں فرمایا:<<’’فَلَمَّا جَاۗءَ اَمْرُنَا جَعَلْنَا عَالِيَہَا سَافِلَہَا وَاَمْطَرْنَا عَلَيْہَا حِجَارَۃً مِّنْ سِجِّيْلٍ۰ۥۙ مَّنْضُوْدٍ۸۲ۙ مُّسَوَّمَۃً عِنْدَ رَبِّكَ۰ۭ>> &&(سورۃ ہود آیت ۸۲۔۸۳)&& یعنی :@@’’پس جب ہمارا امر آیا تو ہم نے اُن کے (طبقوں کے) اوپر کے حصوں کونیچے (اُلٹا) کو دیا‘ اور اُن پر(کھڑنجے دار) پتھر پے درپے برسادیے جو اللہ کے نزدیک (لوگوں کے نام سے) معین تھے۔‘@@‘مروی ہے کہ یہ چار بستیاں تھیں جن کو موتفکات بھی کہاگیا ہے۔’’سدوم‘‘ عامورا‘ دوما،  اور صبوایم۔ اور اُن کابڑا شہر سدوم تھا۔ حضرت لوطؑ کی رہائش اسی شہر میں تھی۔خدا نے اُن کے سروں پر ایک بادل بھیج دیا جس سے اولوں کی طرح اُن پر پتھروں کی بارش برسادی گئی جو موسلادھار بارش تھی۔  اور <<’’مسوّمہ‘‘>> کے معنی’’علامت دار‘‘ یعنی ہرایک پتھر پراُس آدمی کانام لکھا ہوا تھا جس کے لیے وہ معین تھا۔ &&(از تفسیر انوارالنجف جلد۶ ص ۲۳۰)&& بڑی ہولناک بارش سے مراد خاص قسم کے پتھروں کی بارش ہے جو قومِ لوطؑ پربرسائی گئی۔ &&(تفسیر مجمع البیان)&&آج بھی بحرمردار (Dead sea) کاجنوب مشرق کاعلاقہ انتہائی ویران حالت میں پڑا ہوا ہے جہاں بکثرت کھنڈرات پائے جاتے ہیں جس سے معلوم ہوتا ہے کہ وہاں بہت گھنی  اور گنجان آبادیاں تھیں ۔ماہرین کا اندازہ ہے کہ اُس علاقے کی آبادیوں کا خوشحالی کادور ۲۳۰۰؁قبل مسیح سے ۱۹۰۰؁ قبل مسیح تک رہا۔ &&(تفہیم القرآن )&& حضرت لوطؑ اپنے گھروالوں کو لے کر صبح سویرے تک آبادی سے نکل گئے۔ پھر قوم لوطؑ پر عذاب آیا پہلے اُن پر پتھروں کی بارش برسائی گئی۔ بارش ایسی تیز تھی کہ اُن لوگوں کے محلات کھنڈربن گئے جو دکھائی تک نہ دیتے تھے پھر اُن کے شہروں کو اٹھا کر اُلٹا کردیاگیا۔ بعض مفسرین نے لکھا ہے کہ یہ خاموش آتش فشاں پہاڑ تھے جو بحکم خدا الاوا اُگلنے لگے  اور آگ کے پتھر برسنے لگے ہوسکتا ہے کہ وہ پتھر طوفانی ہوا کی وجہ سے بیابانوں سے اُڑ اُڑ کر یاآسمانی فضا سے اُتر کر برسنے لگے ہوں (واللہ عالم ) &&(تفسیر نمونہ)&&
  26,176,آیت۱۷۶کی تشریح:<<’’ایکہ‘‘>> گھنے درختوں والی گھاٹی کو کہتے ہیں ۔گویا یہ لوگ ایسے مقام پر آباد تھے جہاں بکثرت درخت تھے بعضوں نے اسے مدین کیا ہے  اور بعض کہتے ہیں کہ مدین  اور ایکہ دوالگ الگ مقام ہیں حضرت شعیبؑ دونوں کے لیے پیغمبرمبعوث ہوئے۔ تحقیق سے معلوم ہوتا ہے کہ اصحاب ایکہ  اور اصحاب مدین الگ الگ قومیں تھیں ، مگر یہ لوگ ایک ہی نسل کی دوشاخیں تھیں حضرت ابراہیمؑ کی جو اولاد اُن کی کنیز قطور اکے بطن سے تھی، وہ تاریخ عرب میں قطورا کہلائی۔ اُن کاایک قبیلہ سب سے زیادہ مشہور ہوا۔ مدیان ابن ابراہیمؑ کی نسبت سے مدیانی یااصحابِ مدین کہلائے۔ اُن کی آبادی شمالی حجاز سے فلسطین کے جنوب تک پھیلی اُن کاصدر مقام مدین تھا۔ اصحاب مدین  اور اصحابِ ایکہ میں ایک ہی نبیؑ آئے۔ دونوں قبیلوں کی ایک ہی زبان تھی، ایک ہی نسل سے تھے، ایک دوسرے سے متصل رہتے تھے، بعض جگہ دونوں قبیلے ایک ساتھ آباد تھے۔ &&(تفہیم القرآن )&&
  26,179,آیت ۱۷۹کی تشریح:<<’’تقویٰ‘‘>> یعنی خدا کی ناراضگی سے ڈرنے کی دعوت ہرنبیؐ نے دی ہے  اور اپنی دیانت  اور طہارت کردار کا ہر نبیؑ نے حوالہ دیا ہے ۔اس سے معلوم ہوا کہ انبیاءؑ کاپیغام روحانی ہوتا ہے کسی مادّی فائدے کے لیے نہیں ہواکرتا۔ دوسری بات یہ معلوم ہوئی کہ ہر خوشحال قوم کی سب سے بڑی خرابی اخلاقی بدکرداری ، غروروتکبر، اندھی تقلید، اقتصادی  اور معاشی بے ایمانی، کھلم کھلا ظلم  اور زیادتی ، حق کشی ، لوٹ کھسوٹ  اور جنسی بدکاری ہوا کرتی ہے۔ (جب خدا کاپیغمبرؑ ان تمام باتوں سے اُن کو روکتاہے تو قوم کے بڑے بڑے لوگ اپنی چودہراہٹ ختم ہوتے دیکھ کر پیغمبر خدا کی مخالفت کرتے ہیں ۔ آج بھی ایسا ہی ہورہا ہے) ۔&&(تفسیر نمونہ)&&
  26,181,آیت نمبر۱۸۱:حضرت شعیبؑ پیغمبر نے اپنی قوم کو پانچ حکم دیے۔ (۱) ناپ تول میں کمی نہ کرو(۲) لوگوں کو نقصان نہ پہنچائو(۳) سیدھے ترازو سے تولو۔(۴) لوگوں کاحق نہ مارو۔ (۵) زمین پر خرابیاں نہ پھیلائو۔غور سے دیکھا جائے تو یہ پانچ الگ الگ احکامات ہیں ۔ اگرچہ بعض مفسرین کایہ خیال ہے کہ یہ پانچوں حکم ایک دوسرے کی تاکید کے طور پر آئے ہیں ۔ اصل میں حضرت شعیبؑ کی قوم تجارتی راستے پر رہتی تھی جہاں سے حجاز  اور شام کے تجارتی قافلے گذرتے تھے۔ اس لیے یہ لوگ مسافروں کو لوٹتے کھسوٹتے تھے۔ اُن کامال اُن کو مجبور کرکے کم قیمت پر خرید لیتے تھے  اور اپنی چیزیں زیادہ قیمت پر بیچتے۔ جب اُن کامال خرید نے تو اُس میں ہزاروں عیب نکالتے  اور اپنے مال کی ہزاروں جھوٹی تعریفیں کرتے۔ پھر تولنے میں ڈنڈی مارتے،  اور قافلے والوں کو اس ناانصافی کو قبول کرنے پر مجبور کرتے۔ غریبوں کے ساتھ سخت ناروا سلوک کرتے۔ قیمتیں امیر لوگ اپنی مرضی سے معین کرنے کم تول کردیتے اور زیادہ تول کرلیتے۔ &&(تفسیر نمونہ)&&!!<<’’تبخس‘‘>> کے معنی ظالمانہ طریقوں سے کسی کاحق کم دینا۔ نیز یہ لفظ دھوکہ دینے کے لیے بھی آتا ہے غرض لین دین میں ہر قسم کی بے ایمانی اس میں شامل ہے۔ &&(مفردات القرآن امام راغب)&&<<’’مخسر‘‘>> کے معنی ایسا شخص جو کسی کو نقصان پہنچاتا ہے ۔ یعنی :خریدوفروخت میں مال لینے والے کو کم دیتا ہے ۔ غرض اس لفظ میں ہر قسم کی ناجائزمنافع خوری ظلم وستم ، دھوکہ بازی ، دوسروں کو نقصان پہنچانے کی ہر ممکن کوشش شامل ہے۔ &&(مفردات القرآن امام راغب)&&
  26,182,آیت ۱۸۲کی تشریح: یعنی ڈنڈی نہ ماراکرو،  اور تولنے کے باٹوں میں گڑبڑ بھی نہ کیا کرو۔ اصل میں یہ زراعت پیشہ  اور تجارت پیشہ قوم تھی جو کاروباری بددیانتی میں بہت آگے بڑھ چکی تھی۔ اس لیے ان کو تجارتی دیانتداری کی تعلیم دی جارہی ہے۔ کیوں کہ کاروبار میں خیانت رزق کو حرام  اور معاشرے کو تباہ وبرباد کردیاکرتی ہے۔ یہ بھی ظلم  اور قتل کی ایک قسم ہے۔ &&(تفسیر صافی ص۳۹۸،تفسیر قمی)&&
  26,183,آیت ۱۸۳کی تشریح: کیوں کہ اقتصادی  اور معاشی بے ایمانی او ر ناہمواری پورے اجتماعی نظام کو درہم وبرہم کردیتی ہے اس لیے ایسے تمام اعمال کو فساد یعنی خرابی  اور معاشرے کی تباہی فرمایا ہے یہ احکام ہر دور کے لیے ہیں ۔ &&(تفسیر نمونہ)&&
  26,184,آیت ۱۸۴کی تشریح:آخر میں بتایا جارہا ہے کہ صرف تم ہی ایک ایسی قوم نہیں ہو جس نے زمین پر قدم رکھا ہے بلکہ تم سے پہلے دوسری قومیں بھی آچکی ہیں اُن کے انجام کو نہ بھولو۔ &&(تفسیر نمونہ)&&آج کے دور میں اُمت محمدیؐ میں مذکور بالا تمام عیوب موجود ہیں ۔ مزید برآں دوائوں میں ملاوٹ ، غذائوں میں ملاوٹ پانی میں ملاوٹ ، ہوائوں میں ملاوٹ، دین میں ملاوٹ  اور تباہی وبربادی ، قتل وغارت اپنے عروج پر ہے&&(یاصاحب الزمان ادرکنی)&&
  26,187,آیت ۱۸۷کی تشریح: حضرت شعیبؑ کے اس جواب میں کفارِ قریش کے لیے بھی واضح تنبیہ تھی۔قریش بھی رسولِ خداؐ سے یہی مطالبہ کیاکرتے تھے کہ:@@’’ یا پھر گرادے ہم پر آسمان کاکوئی ٹکڑا جیسا کہ تیرا دعویٰ ہے‘‘@@&&(سورۃ بنی اسرائیل آیت ۹۲)&& اس لیے اُن کو سنایا جارہا ہے کہ ایسا ہی مطالبہ اصحابِ ایکہ نے اپنے پیغمبرؑ سے کیاتھا۔وہی جواب تمہارے لیے بھی ہے۔
  26,188,آیت ۱۸۸:عذاب نازل کرنا میرا کام نہیں ہے، یہ تو اللہ رب العالمین کے اختیار میں ہے۔ وہ تمہارے کرتوت دیکھ رہا ہے عذاب نازل کرے گا۔ &&(تفہیم)&&
  26,189,آیت نمبر۱۸۹:اُس سخت دن سے مراد گرم ترین ہوا چلنے کے دن ہیں ۔ &&(تفسیر صافی، تفسیر قمی)&&’’چھتری‘‘کی تشریح یوں کی گئی ہے کہ:ابرنمودار ہوا جوچھتری جیسا تھا۔ لوگ گرمی سے بچنے کے لیے اُس کے نیچے جمع ہوگئے۔ جب سب آگئے تو پانی کی بجائے اُس میں سے آگ برسنے لگی جس نے اُن سب کو زندہ جلاڈالا۔&&(تفسیر جلالین)&&اسی لیے فرمایا:وہ سخت دن تھا‘‘&&(تفسیر تبیان)&&>>’’ظلہ‘‘<< بادل کے اُس ٹکڑے کو کہتے ہیں جو سایہ کرتا ہے۔ &&(مفردات القرآن امام راغب)&&تمام مفسرین نے لکھا کہ: شعیبؑ کی قوم پر سات دن سخت گرم ہواچلی، پھر آسمان پر بادل ظاہر ہوا۔  اور ٹھنڈی ٹھنڈی ہوا چلنے لگی۔ پوری احمق قوم گھروں سے خوش خوش باہر نکل آئی،  اور بادل کے سائے میں جمع ہوگئی۔ اچانک بادل میں سے بارش کی بجائے ایسی سخت کڑک سنائی دی کہ اُن سب کے کان پھٹ گئے۔ اُس کے فوراً بعد بادل سے آگ برسنے لگی۔ اس طرح پوری قوم بڑی دردناک  اور خوفناک موت سے ایک دوسرے کے سامنے (جل جل کر تڑپ تڑپ کر واصل جہنم ہوئے) &&(تفسیر کبیر، تفسیر نمونہ)&&امام رازی  اور قرطبی کاخیال ہے کہ اصحاب اَیکہ  اور اصحابِ مدین دو مختلف قومیں تھیں ۔ اُن پر الگ الگ عذاب آیا۔ &&(تفسیر کبیر۔ تفسیر قرطبی)&&
  26,190,آیت نمبر۱۹۰:اسباق، نتائج وتعلیمات:ان واقعات میں درجِ ذیل اسباق (نشانیاں ) پائی جاتی ہیں ۔ (۱) تمام انبیاء کرام کاپیغامِ توحید بنیادی اعتبار سے بالکل یکساں ہوتا ہے۔(۲)ایک نبی کی تکذیب یاانکار تمام انبیاء کی تکذیب  اور انکار قرار پاتا ہے۔ (۳) تمام انبیاء کرامؐ کے پیغام کابنیادی نکتہ یاخلاصہ تقویٰ کی زندگی ہے ۔ یعنی ایسی زندگی جس میں خدا کی ناراضگی کاخوف ہر لمحہ شامل حال ہو،  اور جس کاعملی نتیجہ فرائض الٰہی کاپابندی کے ساتھ ادا کرتے رہنا  اور محرماتِ الٰہی سے بچے رہنا ہوتا ہے۔ (۴) تمام دولت مند، مغرور قومیں حق کی آواز کو ٹھکرادیا کرتی ہیں  اور بالآخر خدا کے عذاب سے ہمکنار  اور دوچار ہوجاتی ہیں ۔(۵) خود سری، خودنمائی، خود کو بڑا سمجھنا قوموں کی تباہی کاراز ہے  اور خدا شناسی  اور تقویٰ قوموں کی کامیابی کاراز ہے۔ (۶) آخر نتیجہ یہ نکلا کہ لوگوں کی اکثریت حق بات کو ہرگز نہیں مانتی۔ گذشتہ اُمتوں میں یہی بات پائی جاتی تھی، (۷)  اور آج بھی یہی بات مشاہدے میں ہے کہ ہرگروہ  اور ہر قوم کے اکثر لوگ نافرمان، فاسق  اور حق سے گریزاں نظر آرہے ہیں ۔ اللہ کےچند بندے ہیں جو حق کے سامنے سرتسلیم خم کرتے ہیں ۔
  26,191,آیت نمبر۱۹۱:خدا کی زبردست طاقت  اور رحمت کاذکر: (۸) آخر میں خدا، غلبے، طاقت  اور رحمت کاذکر خوف ورجاء، بیم و امیداکاذکر دونوں کیفیات پیداکرنے کیلئے ہے۔ یعنی انسان کوخداکے عذاب سے ڈرے سہمے رہنا بھی ضروری ہے۔ اور اس کی رحمت ومغفرت کی آس لگائے رہنا بھی ضروری ہے۔ (۹) جنسی  اور معاشرتی انحراف قوموں کی تباہی کاسبب ہوا کرتا ہے۔ (۱۰) ان تمام واقعات اور داستانوں سے مومنین کے دلوں کو ڈھارس، تسلی  اور اطمینان حاصل ہوتا ہے کہ وہ گمراہوں کی اکثریت ، قوت  اور دولت سے کبھی مرعوب نہ ہوں ،  اور اپنے پالنے والے مالک سے ہی لولگائے رکھیں ،  اور انجام بخیر کی توقعات وابستہ رکھیں ۔ !!{{حضرت امام زین العابدین علیہ السلام کی دعاء میں ہے کہ: اے میرے مولا وآقا!جب میری نظر اپنے گناہوں پر جاتی ہے۔ تو خائف وترساں ہوجاتا ہوں  اور جب تیری رحمت وبخشش پر نظر جاتی ہے تو اُمیدوار ہوجاتا ہوں ۔‘‘&&(روح الحیات ص ۲۳۶)&&}} (۱۱) ان داستانوں میں ظالم وجابر، متکبر دولتمندقوموں کے لیے سخت تنبیہ ہے۔ (۱۲) برائی کاانجام ہمیشہ بُرا ہوتا ہے۔ (۱۳) انسان خدا کے عذاب کے سامنے بے بس ہے۔ (۱۴) شرک ساری برائیوں کی جڑ ہے۔  اور برائیاں انسان کو عذابِ خدا کی طرف لے جاتی ہیں ۔&&(مولف)&&
  26,192,آیت ۱۹۲کی تشریح: <<’’اِنَّہٗ لَتَنْزِيْلُ رَبِّ الْعٰلَمِيْنَ‘‘>>بلاشبہ یہ قرآن رب العالمین کی طرف سے نازل ہوا ہے۔‘‘ ظاہری مصداق کے لحاظ سے اس سے مراد قرآن مجید ہے  اور باطنی تاویل کے لحاظ سے اس سے مراد ولایت حضرت امام علی ابن ابی طالبؑ ہے۔ چنانچہ روایات اہل بیتؑ میں تواتر سے منقول ہے،  اور صحفِ انبیاءؐ میں بھی اس کاذکر موجود ہے۔ {{چنانچہ بروایت’’کافی‘‘ حضرت امام موسیٰ کاظم علیہ السلام سے مروی ہے کہ ولایت حضرت امام علیؑ تمام انبیاء کی کتابوں میں درج ہے<<’’ولم یبعث اللہ رسولاً الا بنبوۃِ محمد وولایۃ وصیہٖ علی ابن ابی طالب‘‘>> یعنی : اور خد انے کسی کو رسول بنا کر مبعوث نہیں فرمایا، مگر حضرت محمدؐ کی نبوت  اور حضرت علی ابن ابی طالب علیہ السلام کی ولایت کے ساتھ۔‘‘&&(تفسیر برہان، تفسیر انوارالنجف)&&}}
  26,193,آیت ۱۹۳کی تشریح: <<’’روح الامین‘‘>> سے مراد جبرئل امین ہیں ۔ اور امین کے معنی امانتدار۔&&(تفسیر صافی۔تفسیر مجمع البیان)&&یہ بات قرآن کی صداقت کی واضح دلیل ہے کہ:۔(۱) گذشتہ انبیاء کرام کے واقعات کوکتنے پاک صاف  اور مفید انداز سے بیان کرتا ہے۔ نہ اس میں کسی قسم کے خرافات ہیں نہ مجملات نہ جھوٹے افسانے ہیں ، نہ مبالغہ آرائیاں ۔ جبکہ وہ ماحول بھی قصہ خوانیوں کاتھا۔ شعروشاعری ، خیالی پلائو پکانا، لغو اور فضولیات کی بکواس اُن کی زندگی تھی۔(۲) پھر یہ کہ تمام واقعات قرآنی زبان میں وہ انسان بیان کررہا ہے جس نے کسی سے کوئی سبق بھی نہیں پڑھا۔ اگر اس قرآن کو خدا تعالیٰ کی طرف سے روح الامین نہ لاتے تو یہ کلام اس قدر روشن تابناک  اور مفید نہ ہوتا۔ پھر ملاحظہ فرمائیں کہ قرآن لانے والے فرشتے کی یہاں دوصفات بیان کوبیان کیاگیا ہے۔ (۱) روح(۲) امین اس لیے فرمایا کہ قرآن ، زندگی کاسرچشمہ ، حیاتِ ابدی وسرمدی کی کامرانیوں کانسخہ کیمیا ہے۔ ’’امین‘‘اس لیے فرمایا کہ قرآن جیسا بھیجا گیا ہے ، ویسا ہی اُترا ہے اس میں ذرہ برابر ترمیم نہیں ہوئی ہے۔ پھر اُترا بھی رسولؐ امین کے قلب امین پر ہے۔ ’’نورٌ علی نور رسولؐ کے قلب سے مراد رسول اکرمؐ کی پاک وپاکیزہ روح ہے گویا رسول اکرمؐ نے اپنے پورے وجود  اور روح کے ساتھ قرآن کو روح الامین سے قبول فرمایا ہے غرض قرآن آسمانی معجزہ عظیم ہے جس کامرکز قلب رسولؐ ہے۔ &&(تفسیر نمونہ)&&
  26,194,آیت ۱۹۴ کی تشریح: قرآن کے آنے کامقصد یہ ہے کہ لوگوں کو بُرائی کے بُرے انجام سے ڈرا کر اچھائی کے اچھے انجام کی خوشخبری سنائی جائے۔  اور لوگوں کو وہ تباہ کن انجام دکھایا جائے جو توحید سے منحرف ہونے کاہوتا ہے۔  اور ہوا ہے۔ اس طرح لوگوں کے اندر احساسِ ذمے داری ،نظم وضبط DISCIFLINEکو بیدار کیاجائے غرض قرآن مجید کااصل مدّعا یہ ہے کہ انسانیت کی صحیح تربیت  اور نشوونما کی جائے۔ اس طرح انسان بنادیاجائے۔ &&(تفسیر نمونہ)&&
  26,195,آیت ۱۹۵کی تشریح: قرآن کو واضح عربی زبان میں اس لیے اُتاراگیا کہ مخاطب اوّل عرب تھے۔ نیز یہ کہ ایسی عربی زبان میں اُتارا گیا کہ جس میں ہر بات بالکل صاف  اور واضح ہو، کسی قسم کاابہام نہ باقی رہے۔ تاکہ اس کااثر دل ودماغ پر براہ راست اتنا گہرا پڑے کہ انسان بیدار ہوجائے۔ عربی زبان دنیا کی کامل ترین زبان ہے جو انتہائی فنی ادبیات کی حامل ہے۔ دوسرے معنی :عربی کے دوسرے معنی فصاحت  اور بلاغت کے بھی ہیں ۔ اس طرح اس آیت کے معنی یہ ہوں گے کہ: قرآن کو فصیح وبلیغ انداز میں اُتارا گیا ہے۔ امام راغب نے لکھا’’عربی کا لفظ فصیح  اور واضح گفتگو کو کہتے ہیں ۔ &&(مفردات امام راغب ولسان العرب)&&اس صورت میں آیت کامفہوم یہ ہوگا کہ قرآن اپنے مقصد کو بالکل واضح  اور صاف صاف بیان کرتا ہے۔ اس کی آیتیں بھی اسی طرح مطلب کی تائید کرتی ہیں ۔ کیوں کہ سورہ حٰم السجدہ میں فرمایا<<:وَلَوْجَعَلْنٰہُ قُرْاٰناً اَعْجَمِیّاً لَّقَالُوْالَوْلَافُصِّلَتْ اٰیٰتُہٗ ط>>&&(سورہ حٰم السجدہ آیت ۴۴)&& یعنی : @@اگر ہم (اس) قرآن (کی آیتوں ) کو عجمی (گونگا اور مبہم، غیرعرب) بناتے (اُتارتے) تو یہ لوگ کہتے کہ قرآن کی آیتیں واضح  اور روشن ، صاف صاف کیوں نہیں بیان کی گئیں ؟‘‘@@&&(القرآن )&&{{ فرزندِ رسول خداؐ حضرت امام جعفر صادق علیہ السلام سے تفسیر صافی میں بروایت علل الشرائع منقول ہے کہ:’’خداوندِ عالم نے کوئی کتاب  اور وحی عربی زبان کے علاوہ کسی  اور زبان میں نہیں بھیجی۔ لیکن اُسے ہر نبیؑ اپنی قوم کی زبان میں سنتا تھا۔  اور حضرت رسالت مآب صلی اللہ علیہ و آلہ وسلم کے کانوں میں وحی اپنی قوم کی زبان عربی میں آتی تھی۔ پس جب آنحضرتؐ اپنی قوم سے باتیں کرتے تھے تو عربی زبان کو استعمال کرتے تھے۔ لیکن جب کوئی آدمی حضوراکرمؐ سے کسی دوسری زبان میں باتیں کرتا تھا تو آنحضرتؐ کے کانوں میں وہ عربی بن کر پہنچتا تھا۔ کیوں کہ خداوندِ عالم نے جناب جبرئیلؑ کو فریضہ ترجمانی ادا کرنے کے لیے آپؐ کے ساتھ مقرر فرمایاتھا۔‘‘&&(تفسیر انوارالنجف تفسیر نورالثقلین بروایت امام محمد باقرؑ)&&}}مطلب یہ ہے کہ خدائی پیغام  اور تعلیمات کسی مردہ یاجناتی زبان میں نہیں آتی ہیں  اور نہ خدا کی تعلیمات میں ابہام ، معمے ہیں ، نہ گنجلک زبان ہے، بلکہ خدائی تعلیمات بڑی واضح  اور فصیح زبان میں اُتری ہیں جسے ہرعربی جاننے والا بے تکلف سمجھ سکتا ہے ، بشرطیکہ طلب حق رکھتا ہو۔ &&(تفہیم)&&
  26,196,آیت ۱۹۶کی تشریح:قرآن مجید نے بیان فرمایا کہ:@@یہ سب (قرآن ) اوّلین (پہلی۔ گذشتہ ) کتابوں میں موجود ہے@@۔ اس سے محققین نے نتیجہ نکالا کہ کیوں کہ گذشتہ کتابوں میں قرآن عربی زبان میں تونہ تھا جبکہ قرآن اس کوبھی قرآن فرمارہا ہے۔ اس لیے لفظ قرآن کااطلاق غیر عربی، یعنی قرآن کے ترجمہ پر بھی صادق آتا ہے۔ &&(حصّاص۔ مدارک)&&شاید اسی لیے امام ابوحنیفہ نے فتویٰ دیاتھا کہ نماز میں قرآن فارسی ترجمہ پڑھنا جائز ہے۔ لیکن بعد میں اُنہوں نے اپنا یہ فتویٰ واپس لے لیاتھا۔ >>’’زُبُر‘‘<< زبور کی جمع ہے جس کے اصل معنی ہیں ’’لکھنا‘‘&&(مفردات القرآن امام راغب)&&&&(روح المعانی)&&
  26,197,آیت نمبر۱۹۷:قرآن مجید اپنی صداقت پر دوسری دلیل یہ بیان فرمارہا ہے کہ بنی اسرائیل کے علماٰءءنے قرآن کی صداقت کو تسلیم کیا ہے۔ ظاہر ہے کہ اگر یہ بات سچی نہ ہوتی تو یہودی’عیسائی بلاکاغل مچاتے  اور قرآن اس طرح ڈنکے کی چوٹ پر یہ بات نہ کہہ سکتا۔ یہودی عیسائی اس قدر شور مچاتے کہ تاریخ اس کو ریکارڈ کرتی۔ مگر اُن کی خاموشی بتارہی ہے کہ قرآن کے نازل ہوتے وقت یہ بات تمام لوگوں کے نزدیک بالکل مسلم تھی کہ بنی اسرائیل کے علماٰءء قرآن کی حقانیت کو خوب پہچانتے ہیں اسی لیے اس آیت کاکوئی انکار نہ کرسکا۔ &&(تفسیر نمونہ)&&خود قرآن دوسری جگہ ارشاد فرماتا ہے۔ <<وَلَمَّا جَاۗءَھُمْ كِتٰبٌ مِّنْ عِنْدِ اللہِ مُصَدِّقٌ لِّمَا مَعَھُمْ۰ۙ وَكَانُوْا مِنْ قَبْلُ يَسْتَفْتِحُوْنَ عَلَي الَّذِيْنَ كَفَرُوْا۰ۚۖ فَلَمَّا جَاۗءَھُمْ مَّا عَرَفُوْا كَفَرُوْا بِہٖ۰ۡفَلَعْنَۃُ اللہِ عَلَي الْكٰفِرِيْنَ۸۹ >>&&(سورۃ البقرہ آیت۸۹)&& یعنی :@@’’ اور جب اُن کے پاس اللہ کی طرف سے کتاب آگئی ، جو اُس کی تصدیق کررہی تھی جو (کتاب) اُن کے پاس موجود ہے،  اور اس سے قبل وہ اُس کے ذریعہ سے کفار کے خلاف فتح کی دعاء کیا کرتے تھے، پس جب اُن کے پاس وہ (حق) آگیا جس کو وہ خوب پہچانتے تھے، تو اُنہوں نے اُس (کتاب  اور پیغمبر اسلامؐ دونوں ) کاانکار کردیا۔ پس اُن منکروں ، کافروں پر اللہ کی لعنت ہے۔‘‘@@اصل میں علماٰءء یہودیہ جانتے تھے کہ اگر ہم نے رسولِ خداؐ  اور قرآن کو مان لیا تو ہماری چودھراہٹ ملیامیٹ ہوجائے گی اس لیے انکار کردیا&&(مولف)&&
  26,198,آیت نمبر۱۹۸:ہٹ دھرمی کی انتہا:شاہ عبدالقادر صاحب نے لکھا کہ’’کافر کہتے تھے کہ قرآن آیا ہے عربی میں  اور اس نبیؐ کی زبان بھی عربی ہے۔ اگر غیر عربی زبان والے پر یہ قرآن آتا توہم مان لیتے۔ فرمایا’’دھوکے والے (جھوٹے انسان) کادل کبھی نہیں ٹھہرتا۔ اگر عربی میں قرآن نہ آتا تو یہ شبہ نکالتے کہ ضرور کوئی ہے جو یہ مضامین سکھاجاتا ہے۔ &&(موضح القرآن )&& غیر عربیوں کی فضیلت:{{فرزندِ رسولؐ حضرت امام جعفر صادق علیہ السلام نے اپنے آبائے طاہرین علہیم السلام سے روایت فرمائی ہے کہ: اگر قرآن غیر عرب (عجمی) پر اُترتا، تو عرب اُسے کبھی ہرگز نہ مانتے،اُن کی ہٹ دھرمی  اور حق دشمنی کی انتہاء دیکھیۓ کہ اب جبکہ قرآن ایک خالص عرب، جو اصلی عربوں کے اعلیٰ ترین خاندان کافرد ہے  اور جس کے بارے میں پہلی آسمانی کتابیں بھی تصدیق فرمارہی ہیں ،  اور جس کی شرافت کردار سوفیصد مسلم ہے، جب اُس کو بھی یہ لوگ ماننے کو تیار نہیں ہیں ، تو بھلا غیر عرب کو کیسے مان سکتے تھے۔دوسرے معنی: اگر عرب کے معنی فصیح او رواضح زبان کے لیے جائیں تو اس کامطلب یہ ہوگا۔ کہ جب یہ قرآن اس قدر فصیح وبلیغ، روشن  اور واضح ہے، پھر بھی یہ حق دشمن اس کو نہیں مان رہے ہیں ، تواگر یہ غیرفصیح یامبہم ہوتا، غیر واضح  اور غیرروشن ہوتا، تو بھلا یہ اُسے کیسے مان سکتے تھے۔ &&(تفسیر نمونہ)&&}}!!تعصب کی مذمت:{{جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’جس کسی شخص کے دل میں رائی کے دانے کے برابر بھی (قومی یالسانی) تعصب ہوگا، قیامت کے دن خداوندِ عالم اُسے زمانہ جاہلیت کے اعراب (جنگلی عربوں ) کے ساتھ محشور فرمائے گا۔ ‘‘&&(اصول کافی جلد۲)&&}}{{فرزندِ رسول خداؐ حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ: ’’جس شخص نے تعصب برتا، اُس نے ایمان کے حلقے کو اپنی گردن سے اُتارپھینکا‘‘&&(اصول کافی جلد۲)&& }}{{جناب امیر المومنین حضرت امام علی ابن ابی طالبؑ علیہ السلام خداوند عالم چھ قسم کے لوگوں کو چھ صفات کی وجہ سے عذاب کرے گا۔ (۱) عربوں کو اُن کی عصبیت (تعصب) کی وجہ سے(۲) جاگیرداروں کوان کے تکبرکی وجہ سے۔(۳)حکمرانوں کوان کے ظلم وستم کی وجہ سے(۴) فقہاء (علماٰء) کو اُن کے حسد کی وجہ سے (۵) تاجروں کواُن کی خیانت کی وجہ سے، (۶)  اور دیہاتیوں کو اُن کی جہالت کی وجہ سے سزادی جائے گی۔‘‘جناب رسول خداؐ روزانہ خداوندعالم سے چھ چیزوں سے پناہ طلب کرتے تھے(۱) شک (۲) شرک (۳) تعصب (۴) غیظ وغضب(۵) ظلم&&(۶) حسد (بحارالانوار جلد۷۳)&&}} اسی عصبیت کو حمیت بیجا کہتے ہیں ۔ قرآن نے فرمایا:<< اذجعل الذین کفروافی قلوبھم الحمیۃ حمیۃ الجاھلیۃ>> @@(جب زمانہ جاہلیت کی حمیت (غرور ونحوت) نے کفار کے دلوں میں گھر بنالیا@@&&(سورۃ الفتح آیت ۶۶)&&!!{{جناب امیر المومنین علیہ السلام نے خطبہ قاصعہ میں ارشاد فرمایا: ’’ابلیس نے حضرت آدمؑ کے مقابلے میں گھمنڈ کیا  اور اپنی اصل کی وجہ سےاُن کے سامنے اکڑ گیا۔ چنانچہ یہ خدا کادشمن عصبیت برتنے والوں کاسرغنہ  اور سرکشوں کاپیشرو ہے جس نے تعصب کی بنیاد رکھی۔ اللہ سے اُس کی روائے کبریائی وعظمت کو چھیننے کاتصور کیا ، تکبر وسرکشی کالباس پہن لیا، عجزوانکساری کی نقاب اُتار پھینکی پھر تم دیکھتے ہو کہ اللہ نے اُسے بڑا بننے کی وجہ سے کس طرح چھوٹا  اور کمتر بنا دیا‘‘۔پھر آپؑ نے فرمایا: ’’اب اگر تمہیں فخر ہی کرنا ہے تو اُس پاکیزگی اخلاق، بلند کردار  اور حسنِ سیرت پر فخر کرو کہ جس میں عرب کے گھرانوں کے باعظمت وبلند ہمت سردارانِ قوم اپنی خوش اطواریوں ، بلندپایہ دانائیوں ، اعلی مرتبوں  اور پسندیدہ کارناموں کی وجہ سے ایک دوسرے پر برتری ثابت کرتے تھے، تم بھی ان قابلِ ستائش خصلتوں کی طرفداری کرو جیسےہمسایوں کے حقوق کی حفاظت کرنا، عہدوپیمان کو نبہنا، نیکیوں کی اطاعت  اور سرکشوں کی مخالفت کرنا، حسنِ سلوک کی پابندی  اور ظلم وتعّدی سے کنارہ کش رہنا، خلقِ خدا سے عدل وانصاف برتنا، غصہ کو پی جانا۔ ۔۔الخ&&(نہج البلاغۃ خطبہ قاصعہ نمبر۱۹)&&}} !!{{حضرت امام زین العابدین علیہ السلام نے اپنے آباءطاہرین علہیم السلام کے حوالوں سے روایت فرمائی ہے کہ: ’’جناب رسول صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’تعصب کی وجہ سے انسان گنہگار ہوجاتا ہے کیوں کہ تعصب کی وجہ سے وہ اپنی قوم کے بُرے لوگوں کو دوسری قوموں کے اچھے  اور اہل لوگوں سے بہتر سمجھتا ہے۔ اگر کوئی شخص اپنی قوم وقبیلے ، زبان سے محبت کرتا ہے تو یہ تعصب نہیں ہے۔ تعصب یہ ہے کہ انسان اپنے قبیلے یاہم قوم لوگوں کی اُس بات میں مدد کرے کہ وہ دوسروں پرظلم کریں ‘‘ ( یعنی دوسروں کی حق تلفی کرنا تعصب ہے) &&(اصول کافی باب العصیۃ جلد۲)&&}}!!{{ حدیث قدسی میں اللہ نے ارشاد فرمایا ہے:’’اے آدمؑ کے بیٹے!جب بادشاہ ظلم کرنے کی وجہ سے ، عرب والے اپنے بیجاتعصب کی وجہ سے ، عالم حسد کی وجہ سے ، محتاج لوگ جھوٹ کی وجہ سے ، تاجرخیانت کی وجہ سے، کسان جہالت کی وجہ سے ، عابد ریا کی وجہ سے غنی مالدار لوگ تکبر کی وجہ سے ، قاری غفلت کی وجہ سے ، ملاوٹ کرنے والے ملاوٹ کی وجہ سے، مالدارزکوٰۃ روکنے کی وجہ سے جہنم میں جائیں گے تو میری جنت کاطالب کون ہوگا؟ &&(ملخص از حدیث قدسی ۲۸ ص ۵۶)&& }}
  26,200,آیت ۲۰۰کی تشریح:مفسرین نے آیت کایہ مطلب لکھا کہ عربوں کے اسی تعصب کی وجہ سے ہم نے قرآن کو اُن کے دلوں میں اترناناگوار بنادیا ہے یعنی قرآن اُن سے ہضم نہیں ہوتا، حلق سے نہیں اُترتا، گویا اُن کے دلوں پر مہر لگادی ہے۔ اسی لیے وہ کسی طرح قرآن کو مان کر نہیں دیتے۔&&(تفسیر نمونہ)&&مطلب یہ ہے کہ قرآن حق کے طلب گاروں کے دلوں کی تسکین  اور روح کی شفا ہے ،  اور حق کے دشمنوں کے دل میں یہ قرآن لوہے کی گرم سلاخ بن کر اس طرح گذرتا ہے کہ اُن کے دل کباب ہوجاتے ہیں &&(تفہیم)&&
  26,201,آیت ۲۰۱کی تشریح: مطلب یہ ہے کہ کافروں ، منکروں کو قرآن کی حقانیت کااحساس ہے جو ہمارے ہی دیے ہوئے ضمیر کافطری ، منطقی نتیجہ ہے، مگر یہ لوگ سب کچھ جانتے ہوئے ماننے کو تیار نہیں ۔&&(تفسیر تبیان)&&یہ مطلب بھی لکھا گیا ہے کہ:’’ہم قرآن کو اُن کے دلوں میں سے گذارتے ہیں ، مگر کیوں کہ وہ حق کو ماننا ہی نہیں چاہتے اس لیے قرآن اُن کو سخت ناگوار ہوتا ہے۔ اس لیے وہ قرآن کو ماننے پر کسی طرح بھی تیارنہیں ہوتے۔ &&(تفسیر مجمع البیان)&& (ناگوار کو جوکرتا ہے گوارا انساں زہر کھا کرکے مزہ شیر وشکر پاتا ہے)
  26,202,آیت ۲۰۲تشریح:اُسی تنگ نظری کی وجہ سے وہ لوگ قرآن کو اُس وقت تک نہ مانیں گے جب تک خدا کےعذاب کو اپنے اوپر آتا نہیں دیکھ لیں گے ۔مگر اُس وقت قرآن کو ماننا اُن کے کسی کام نہ آئے گا۔ پھر اُن کے لیے اپنے شرمناک ماضی پر پچھتانے  اور اپنے ہولناک مستقبل پر خوف کھانے کے سواکچھ چارئہ کارنہ ہوگا۔ &&(تفسیرنمونہ)&&
  26,203,آیت ۲۰۳کی تشریح: دنیا میں واپس جانے کی آرزو  اور مہلت کاذکر قرآن میں کئی جگہ آیا ہے۔ سورہ الانعام میں ہے کہ<<:وَلَوْ تَرٰٓي اِذْ وُقِفُوْا عَلَي النَّارِ فَقَالُوْا يٰلَيْتَنَا نُرَدُّ وَلَا نُكَذِّبَ بِاٰيٰتِ رَبِّنَا وَنَكُوْنَ مِنَ الْمُؤْمِنِيْنَ۲۷ >>&&(سورہ الانعام آیت ۲۷)&& یعنی :@@ اور اگر تم اُن کو دیکھوجب وہ جہنم کے دہانے پر کھڑے کیے جائیں گے تو کہیں گے (ہائے افسوس) کاش کہ ہم (دنیامیں ) لوٹا دیے جاتے تو اپنے رب کی آیات کی تکذیب نہ کرتے،  اور ایمان والوں میں سے ہوجاتے۔‘‘@@سورۃ المومنون میں ہے۔’’<<حَتّٰٓي اِذَا جَاۗءَ اَحَدَہُمُ الْمَوْتُ قَالَ رَبِّ ارْجِعُوْنِ۹۹ۙ>> &&(آیت۹۹)&& یعنی :@@حتیٰ کہ جب اُن میں سے کسی کو موت آجاتی ہے تو کہتا ہے کہ اے میرے رب مجھے ( دنیا میں ) لوٹا دے۔@@‘‘لیکن اب پچھتانے سے اُن کوکوئی فائدہ نہ پہنچ سکے گا کیوں کہ مہلت کاوقت ختم ہوچکا ہے۔
  26,204,آیت ۲۰۴کی تشریح:جب مجرم لوگوں کوموت آچکی ہوگی تو وہ دوبارہ دنیا میں پلٹ آنے کی تمنا کریں گے۔ تاکہ گناہوں کی تلافی کرسکیں ۔ اُس وقت اُن کو یہ جواب دیا جائے گا کہ ’’تم تو اس عذاب کے جلدی سے جلدی آنے کا تقاضے کرتے تھے اب جب یہ عذاب آگیا تو اس سے چھٹکارے کی درخواستیں کررہے ہو۔ دنیا میں تو تم عذاب کومذاق سمجھتے تھے۔ &&(تفسیر نمونہ)&& کافر عذاب کی جلدی صرف اس لیے مچاتے تھے کہ ان کو یقین تھا کہ عذاب کوئی چیز ہی نہیں ہے۔ وہ احمق سمجھتے تھے کہ ہم ہمیشہ چین سے رہیں گے ۔ اس پر فرمایا جارہا ہےکہ اگر ابھی تم پر عذاب نہیں آیا ہے تو یہ خدا کی مہلت اصلاح ہے مگر جلد یادیر سے عذاب آجائے گا تو دنیا کی زندگی کے یہ چند سال کے عیش کس کام آئیں گے؟&&(تفہیم)&&
  26,208,آیت۲۰۸کی تشریح: خداوندِ عالم کااٹل قانون یہ ہے کہ وہ جب تک کسی قوم کو عمل  اور اصلاح کی مہلت نہیں دے دیتا  اور اس طرح اتمام حجت نہیں کرلیتا، کسی قوم کو عذاب میں مبتلاءنہیں کیاکرتا۔ لیکن مہلت عمل  اور مہلت اصلاح مل جانے کے بعد جب قوم اپنی اصلاح نہیں کرتی، پھر جب اُسے سزامیں پکڑ لیا جاتا ہے ، پھر اُسے چھٹکارا بھی نہیں ملاکرتا۔ یعنی اتمام حجت کے بعد مہلت نہیں ملا کرتی۔ &&(تفسیر نمونہ)&&کیوں کہ اگر خدا اُنہیں مہلت دیے بغیر سزا دے دیتا تو یہ ظلم ہوتا، اسی لیے اللہ نے اپنے قانون کو واضح طور پر یوں بیان فرمایا ہے کہ:<<’’وَمَا كُنَّا مُعَذِّبِيْنَ حَتّٰى نَبْعَثَ رَسُوْلًا>>۱۵ ‘‘ یعنی@@ ’’ اور ہم (کسی قوم کو اُس وقت تک) عذاب نہیں دیتے جب تک کہ اُن میں اپنے کسی رسول کو نہ بھیج دیں ۔‘‘ جو اُنہیں اچھی طرح حقائق سے آگاہ نہ کردے۔ @@&&(سورۃ بنی اسرائیل آیت ۱۵)&&
  26,209,آیت ۲۰۹کی تشریح: یعنی جب اُنہوں نے ہمارے بھیجے ہوئے خبردار کرنے والے نبیؑ کی تنبیہ  اور نصیحتوں کو قبول ہی نہ کیا، ہماری دی ہوئی مہلت سے کوئی فائدہ ہی نہیں اُٹھایا، تو ہم نے اُن کو ہلاک کردیا۔ تو ظاہر ہے کہ یہ ہماری طرف سے اُن پر کوئی ظلم نہ تھا۔ ظلم تو اُس وقت ہوتا جب ہلاک کرنے سے پہلے اُن کو ہم سمجھانے کی کوشش نہ کرتے۔ &&(تفہیم )&&
  26,210,آیت ۲۱۰تا۲۱۱کی تشریح: مشرک کہتے تھے کہ یہ قرآن جنوں  اور شیطانوں نے رسولؐ پر اُتارا ہے۔ اس کاجواب دیا جارہا ہے کہ :بھلا جن  اور شیطاطین ایسی اعلیٰ اخلاقی باتیں  اور قوانین بیان کرسکتے ہیں ؟ یعنی قرآن کے مضامین تو اخلاقی پاکیزگی ، عدالت، تقویٰ ،  اور ہر قسم کے شرک وکفر کی نفی کرتے ہیں ،  اور شیاطین  اور جنوں کاکام تو فساد پھیلانا ہوتا ہے جبکہ قرآن اصلاحِ عمل  اور پاکیزگی نفس کادرس دیتا ہے ۔ پھر یہ کہ اگر قرآن جیسی کتاب شیاطین نازل کرسکتے ہوتے تو قرآن کے مقابلے پر ایک سورہ تو ضرور بنالاتے، تاکہ قرآن کا چیلنج توڑ سکیں ۔&&(تفسیر نمونہ)&&
  26,212,&&(آیت ۲۱۲)&& اس کے علاوہ کاہنوں نے اس بات کاازخود اعتراف کرلیا تھا کہ جناب رسول خداؐ کی ولادت کے بعد شیاطین کو آسمانوں پر جانے سے روک دیا گیا ہے۔ اب وہ آسمانی خبریں نہیں لاسکتے۔ &&(تفسیر نمونہ)&&سورۃ الملک میں فرمایا:  اور یقیناً ہم نے دنیا کے آسمان کو چراغوں (ستاروں سے ) مزین کیا  اور انہیں شیاطین کو ماربھگانے کاذریعہ قرار دیا۔ &&(سورۃ الملک آیت ۵)&&
  26,213,آیت ۲۱۳کی تشریح:<<’’فَلَاتَدْعُ‘‘>>آیت میں خطاب حضور اکرمؐ سے ہے لیکن مراد ساری اُمت ہے۔ &&(تفسیر انوارالنجف)&&کیوں کہ جناب رسولِ خداؐتوخود بالکل واضح طور پر توحید کے علمبردار تھے ہی، اس لیے آپؐ کے بارے میں توحید کے عقیدے سے انحراف کاتو کوئی تصّور ہی نہیں ہوسکتا۔ (ازخویشتن گم است کجارہبری کُند) یعنی : جو خود ہی گمراہ ہو وہ رہبری کیسے کرسکتا ہے۔ مگر توحید کے عقیدے کی اہمیت کو بیان کیاجارہا ہے کہ یہ عقیدہ بنیادی طور پر اس قدر اہم ہے کہ اگر بالغرض (معاذ اللہ) تم بھی ایسا کرو گے۔‘‘تو سزا پانے والوں میں شامل ہوجائو گے۔‘‘پھردوسرے اپنا حساب خود لگالیں کہ اگر وہ توحید کے عقیدے سے ہٹ جائیں گے تو اُن کا کیا حشر نشر ہوگا۔ &&(تفسیرنمونہ)&&
  26,214,آیت ۲۱۴ کی وضاحت:اس آیت میں جناب رسولؐ کو حکم دیا جار ہا ہے کہ آپؑ اپنے قریب ترین رشتے داروں سے یہ (تبلیغی) کام شروع فرمائیں ۔ کیوں کہ وہ آنحضرتؐ کے پاکیزہ کردار کو  اور وں سے کہیں زیادہ جانتے ہیں ۔ ’’عشیرۃ‘‘عشرہ سے نکلا ہے جس کے معنی دس کے ہوتے ہیں ۔کیوں کہ اس کاعدد ایک مکمل عدد ہے۔ اس لیے بہت قریبی رشتہ داروں کو عشیرہ کہتے ہیں ، اس لیے کہ بہت قریبی لوگ عام طور پر دس ہی ہوا کرتے ہیں ۔ غرض یہ ایک کامل مجموعہ ہوتا ہے۔ &&(مفردات القرآن امام راغب)&&دعوتِ ذوالعشیرۃ:{{اس آیت کے اُترنے کے بعد آنحضرتؐ نے اپنے اعلان نبوت کے تیسرے سال اپنے عزیزوں ، قریبی رشتہ داروں کو دعوت پر بلایا۔ اُس وقت بہت ہی کم لوگ اسلام لائے تھے۔ جناب رسول خداؐ نے حضرت ابوطالبؑ کے گھر پر دعوت دی۔ چالیس افراد شریک ہوئے آپؐ کے چچائوں میں سے حضرت ابوطالبؑ، حضرت حمزہؑ  اور ابولہب بھی شریک ہوئے۔ کھانا کھانے کے بعد جب رسولِ خداؐ نے تقریر کرنی چاہی تو ابولہب نے سب کو وہاں سے بھگا دیا۔  اور آپؐ کو تقریر کرنے نہ دی۔ آپؑ نے دوسرے دن پھر کھانے پر بلایا  اور کھاناکھلانے کے بعد فرمایا:’’اے عبدالمطلب کے بیٹو‘‘ پوری قوم میں مجھے کوئی ایسا شخص دکھائی نہیں دیتا جو اپنی قوم کے لیے مجھ سے بہتر چیز لایا ہو۔ میں تمہارے لیے دنیا وآخرت کی بھلائی لایا ہوں ۔ کیوں کہ خداوندعالم نے مجھے حکم دیا ہے کہ تمہیں دین اسلام کی طرف بلائوں ۔ تم میں سے کون ہے جو اس کام میں میرا ہاتھ بٹائے تاکہ وہ میرا بھائی ، میراوصی، میراخلیفہ ہو‘‘؟&&(سیرت ابنِ ہشام جلداص۱۸۰)&&سب لوگ خاموش رہے سوائے علیؑ ابن ابی طالبؑ کے، جو سب سے کمسن تھے۔ علیؑ اُٹھے  اور عرض کی: اے اللہ کے رسولؐ!اس راہ میں ، میں ہی آپ کامدد گار ہوں گا۔‘‘یہ سن کر جناب رسول خداؐ نے اپنا ہاتھ حضرت علیؑ کی گردن پررکھا  اور فرمایا:<<’’ان ھذااَحی ووصی وخلیفتی فیکم فاسمعوا لہ واطیعوہ‘‘>> یعنی : یقیناً یہ (علیؑ) تمہارے درمیان میرا بھائی ، میراوصی ، میراخلیفہ (جانشین) ہے پس تم اس کی باتوں کو سنو  اور اس کی اطاعت کیا کرو۔‘‘&&(سیرت ابن ہشام جلدص۲۰۰، ابن جریمہ، ابن ابی حاتم ، ابنِ مردویہ، ابونعیم )&&}}بیہقی، ثعلبی، طبری، مورّخ ابن اثیر، تاریخ کامل، ابوالفداء اور عام مورخین)&&اس روایت سے یہ بھی معلوم ہوگیا کہ قریش، ابوطالبؑ کوجناب رسول خداؐ کاماننے والا مانتے تھے۔ دوسرے یہ بھی معلوم ہوگیا کہ جناب رسولِ خداؐ نے اپنے پہلے ہی اعلان میں حضرت علی ابن ابی طالبؑ کی وصایت، خلافت  اور بھائی ہونے کااعلان فرمادیا تھا۔ اب یہ کیسے ممکن ہے کہ جناب رسولِ خداؐ جیسا سچا (صادق) انسان اپنے پہلے ہی اعلان کو بھلا دے۔ ’’وصی اب بھی جو نہ سمجھے تو پھر اُس کو خدا سمجھے‘‘&&(مولف)&&{{اس کے بعد جناب رسول خداؐ نے قریش کے ہر ہر قبیلے کو نام لے لے کر بلایا  اور اُنہیں جہنم کے عذاب سے ڈرایا، فرمایا: اے بنی کعب !خود کو جہنم سے بچائو۔ اے بنی عبدشمس، خود کو جہنم سے بچائو۔ اے بنی عبدِ مناف!خود کو جہنم سے بچائو۔ اے بنی ہاشم!خود کو جہنم سے بچائو۔ اے بنی عبدالمطلبؑ!خود کو جہنم سے بچائو۔ اس لیے کہ اگر تم کافر مرے تو میں تمہارا دفاع نہیں کرسکوں گا۔‘‘&&(تفسیر قرطبی جلد۷)&& }}
  26,215,آیت۲۱۵کی تشریح:اس آیت میں آنحضرت صلی اللہ علیہ و آلہ وسلم کوایسی تواضع کاحکم دیاجارہا ہے جس میں بہت ہی نرمی  اور محبت ہو جس طرح کہ پرندے اپنے بچوں سے محبت کااظہار کرتے ہیں تو اپنے بال وپرکھول کر اپنے بچوں کو اپنے پروں کے اندر چھپالیتے ہیں ۔اس طرح وہ بچوں سے محبت کااظہار بھی کرتے ہیں  اور اُن کی حفاظت بھی۔ اسی طرح جناب رسولِ خداؐ کو حکم دیا جارہا ہے کہ سچے مومنین کو اپنے بازئوں کے نیچے لے &&(کردشمن سے چھپا)&& لیں ۔ اُن سے اتنی ہی محبت فرمائیں (جتنی اپنے بچوں سے) &&(تفسیر نمونہ)&&
  26,216,آیت ۲۱۶کی تشریح: جناب رسول خداؐ کو حکم دیا جارہا ہے کہ اگر آپؐ کے قبیلے والے آپؑ کے پیغام کو قبول نہ کریں  اور دشمنی پراُترآئیں تو گھبرانے کی ضرورت نہیں بس اُن سے اتنا فرمادیں کہ میں تمہارے اس عمل سے بیزار ہوں ۔ اس طرح اپنا لائحہ عمل آشکار فرمادیں ۔ ‘‘قرآن کی یہ پیشگوئی حرف بہ حرف درست ثابت ہوئی قریش نے آپؐ کی بھرپور مخالفت کی، سوائے حضرت علیؑ کے بظاہر کسی نے دعوتِ اسلام قبول نہ کی، کچھ لوگوں نے خاموشی اختیارکرلی، کچھ نے تقیہ فرمایا جیسے جناب ابوطالبؑ ۔ لیکن اکثریت نے کھل کر مخالفت کی  اور مذاق اڑایا۔
  26,217,آیت ۲۱۷کی تشریح: آخر کار خداوندِ عالم نے جناب رسول خداؐ کو حکم دیا کہ آپؐ خدا پر بھروسہ کریں ۔مخالفوں کو خاطر میں نہ لائیں ۔ کیوں کہ آپؐ کی پناہ گاہ خداوندعالم ہے جسے کوئی شکست نہیں دے سکتا۔ پھر وہ رحیم بھی ہے  اور مہربان بھی۔ وہ خدا جس نے لامحدود قوت  اور طاقت سے فرعون ونمرود  اور اُن کے لشکروں کو غرق کرکے تباہ وبرباد کردیا۔ جس نے نوحؑ کی قوم کو،  اور عاد وثمود جیسی سرکش قوموں کو  اور شدّاد وارم والی قوموں کو آناً فاٰناً تباہ کردیا۔بس اُسی بے پناہ طاقت والے زبردست خدا پربھروسہ کیجئے۔ &&(تفسیر نمونہ)&&مطلب یہ ہے کہ اے رسولؐ!تم دنیا کی کسی بڑی سے بڑی طاقت کی بھی پرواہ نہ کرو،  اور خدا کی ذات پر بھروسہ کرو۔ اور اپنا کام کرتے رہو۔ خداوندِ عالم کا’’عزیز‘‘ یعنی زبردست، غالب، طاقت ور ہونا، اس بات کی علامت ہے کہ جس کی پشت پر خدا کی طاقتیں ہوں اُسے کوئی زیر نہیں کرسکتا۔  اور خدا کا’’رحیم‘‘ ہونا اس اطمینان کے لیے بہت کافی ہے کہ جوشخص خدائے رحیم کی خاطر کام کرے گا اُس کی کوششوں کو خدا کبھی برباد نہ ہونے دے گا۔ &&(تفہیم القرآن )&&
  26,219,آیت۲۱۹کی تشریح: اس آیت کاظاہری مفہوم تو یہی ہے کہ جب آپؐ کھڑے ہوتے ہیں تب بھی خداوندِ عالم آپؐ کو دیکھتا ہے۔جب آپؐ سجدہ کرنے والوں میں نقل وحرکت فرماتے ہیں تب بھی خدا آپ کو دیکھتا ہے ، کھڑے ہونے سے مراد فراد نماز میں کھڑا ہونا بھی ہے  اور جماعت کی نماز میں کھڑا ہونا بھی مراد ہے۔ مطلب یہ ہے کہ اے رسولؐ!آپؐ کے تمام حالات پر خدا خود گواہ ہے۔ &&(تفسیر نمونہ)&&باطنی تفسیر:سجدہ کرنے والوں میں حرکت’’کامطلب یہ ہے کہ حضرت آدمؑ سے لے کر حضرت رسولِ خداؐ کے والد ماجد جناب عبداللہ تک آنحضرتؐ کانور پاک وپاکیزہ صلبوں میں منتقل ہوتا ہوا آیا ہے۔ یعنی آپؐ کانور ہمیشہ ہمیشہ اُن لوگوں کے اصلاب میں منتقل ہوتا رہا جو سجدہ کرنے والے موحد تھے۔ &&(تفسیر علی ابن ابراہیمؑ)&&{{فرزندِ رسول خداؐ حضرت امام محمد باقر علیہ السلام نے فرمایا کہ:جناب رسول خداؐ کانور انبیاء کرام کی صلبوں میں منتقل ہوتا ہو اآیا ہے۔ یعنی آپؐ کانور ہمیشہ ہمیشہ اُن لوگوں کے اصلاب میں منتقل ہوتا رہا جو سجدہ کرنے والے موحد تھے۔ &&(تفسیر علی ابن ابراہیمؑ)&&}}{{ فرزند رسولِ خداؐ حضرت امام محمدباقر علیہ السلام نے فرمایا کہ:جناب رسول خداؐ کانور انبیاء کرامؐ کی صلبوں میں رکھاگیا۔پھر ایک پیغمبر سے دوسرے پیغمبرؑ کی صلب میں منتقل ہوتا رہا، یہاں تک کہ آپؐ کو آپؐ کے والد ماجد کی صلب سے خدا نے باہر نکالا۔ اس طرح خداوندِ عالم نے ہمیشہ پاکیزہ نکاح کے ساتھ آپؐ کو ایک صلب سے دوسری صلب میں منتقل فرمایا، اور ہر طرح کی نجاست  اور ر جس وگندگی سے دور رکھا۔ &&(تفسیر مجمع البیان)&&}}{{تفسیر بُرہان میں ابن بابویہؒ سے بسند متصل جناب جابرؒ ابن عبداللہ انصاری سے مروی ہے۔ حضرت رسالت مآب صلی اللہ علیہ و آلہ وسلم سے دریافت کیاگیا’’جب حضرت آدم علیہ السلام جنت میں تھے تو آپؐ کہاں تھے؟‘‘آنحضرتؐ نے ارشاد فرمایا: میں اُنؑ کی صلب میں تھا، جب وہ زمین پر تشریف لائے تو میں اُن کی صُلب میں تھا۔ جب حضرت نوح علیہ السلام کشتی میں سوار ہوئے تو میں اُن کی صلب میں تھا جب حضرت ابراہیمؑ آگ میں ڈالے گئے تو میں ؑ اُن کی صلب میں تھا۔ میرے آبائی سلسلے میں کبھی زنا نہیں ہوا۔  اور خداوندِ عالم ، مجھےؑ اصلابِ طاہرہ سے ارحامِ طیبہ کی طرف منتقل فرماتا رہا درآنحالیکہ میں ھادی ومھدی رہا ہوں ، مجھؐ سے خداوندقدیر نے نبوت واسلام کاعہد ومیثاق لیا ہے۔ اور اُس نے میریؐ ہر صفت کو واضح فرمایا ہے۔ تو رات وانجیل میں میرا ذکر فرمایا ہے،  اور مجھے آسمانوں میں بلند فرمایاہے،  اور میرانام اُس نے اپنے ناموں سے مشتق فرمایا ہے۔ میری اُمت حماد ہے۔ وہ محمود ہے میں محمدؐ ہوں ۔ (ابن بابویہ فرماتے ہیں کہ یہ روایت طرقِ کثیرہ سے وارد ہوئی ہے) &&(برہان)&&}}{{حضرت ابوذرؓ سے مروی ہے کہ میں نے بگوش ہوش جناب رسالت مآب صلی اللہ علیہ و آلہ وسلم سے سنا ہے کہ آنحضرتؐ نے ارشاد فرمایا: <<’’خلقت انا وعلی ابن ابی طالب من نورواحد‘‘>> یعنی میںؐ  اور علیؑ ابن ابی طالب ایک ہی نور سے پیدا کیے گئے ہیں ۔‘‘چنانچہ ہم حضرت آدم علیہ السلام کی پیدائش سے دوہزار سال پہلے عرشِ خداوندی کے پاس تسبیح کرتے رہے۔ جب حضرت آدم علیہ السلام کو پیدا کیاگیا تو ہمارا نور اُن کی صلب میں ودیعت ہوا، جب وہ جنت میں تھے تو اُن کی صلب میں تھے۔ زمین پرآئے تو ہم اُن کی صلب میں تھے جب حضرت نوحؑ کشتی میں سوار ہوئے تو ہم اُن کی صلب میں تھے جب حضرت ابراہیمؑ کو آگ میں ڈالا گیا تو ہم اُن کی صلب میں تھے پس اللہ ہمیں پاک صلبوں سے پاک رحموں میں منتقل فرماتا رہا یہاں تک کہ حضرت عبدالمطلب تک پہنچاپھر میرا نور جناب عبداللہ کی صلب میں  اور علیؑ کانور ابوطالبؑ کی صلب میں منتقل ہوا مجھے نبوت وبرکت عطا ہوئی  اور علیؑ کو فصاحت  اور شجاہت عطا ہوئی۔ ہمارے نام اپنے ناموں سے مشتق وہ محمود ہے  اور میں محمدؐ  اور اللہاعلیٰ ہے  اور یہ علی ؑہے۔ &&(تفسیر انوارالنجف)&& }}
  26,221,آیت ۲۲۱کی تشریح: کفار قریش چونکہ کہتے تھے کہ محمدؐ پر شیطان القاءکرتے ہیں ۔ خدا نے اُن کاجواب دیا ہے کہ ہم بتاتے ہیں شیاطین کیسے لوگوں پراُترتے ہیں ۔ وہ ہر جھوٹے، فاسق، بدکارگنہگار انسان پر اُترتے ہیں ۔ لہٰذا کہہ دیجئے کہ مجھ پر شیاطین نہیں اُترتے کیوں کہ میں نہ جھوٹا ہوں ، نہ فاسق، بلکہ مجھ پر فرشتے اُترتے ہیں ۔
  26,223,آیت ۲۲۳کی تشریح: یعنی شیطان سنی سنائی باتیں کاہنوں  اور جھوٹے لوگوں پر القاءکرتے ہیں ۔ &&(تفسیر انوارالنجف)&&اس سے مراد، وہ کاہن، نجومی، جیوتشی، فال نکالنے والے، رمال ، عامل قسم کے لوگ ہیں جو غیب دانی کاڈھونگ رچا کر لچھے دار باتیں سنا کر بزعم خود لوگوں کی قسمتیں بنانے بگاڑنے کاکاروبار کرتے ، جھوٹے دعوے کرتے،  اور جنوں  اور روحوں  اور موکلوں پر قابو رکھنے کا جھوٹا دعویٰ کرکے لوگوں کو لوٹتے ہیں ۔ &&(تفہیم )&&{{ حضرت عائشہؓ سے روایت ہے کہ: بعض لوگوں نے آنحضرتؐ سے سوال کیا کاہنوں کے بارے میں ‘‘ آپؐ نے فرمایا‘‘ وہ کچھ نہیں ہیں ‘‘ اُنہوں نے عرض کی۔حضورؐ!کبھی کبھی تو وہ ٹھیک بات بتادیتے ہیں ‘‘آپؐ نے فرمایا‘‘وہ ٹھیک بات کبھی کبھار جن اپنے دوست کاہن کے کان میں پھونکتے ہیں ، پھر وہ کاہن اپنی طرف سے جھوٹی باتیں ملا کر ایک داستان بنالیتے ہیں ۔&&(بخاری شریف)&&}}
  26,224,آیت ۲۲۴:کی تشریح:کفار ہمارے رسولؐ پر الزام لگاتے تھے کہ یہ شاعری کرتے ہیں ۔ اسی لیے وہ آپؐ کو شاعر  اور مجنون‘‘کہہ کر پکاراکرتے تھے۔ قرآن میں اللہ نے اس بات کو نقل فرمایا: <<’’وَيَقُوْلُوْنَ اَىِٕنَّا لَتَارِكُوْٓا اٰلِـہَتِنَا لِشَاعِرٍ مَّجْــنُوْنٍ۳۶ۭ ‘‘>>&&(سورۃ الصٰفٰت آیت ۳۶)&& یعنی ’’@@ اور وہ کہا کرتے تھے کہ کیا ہم ایک دیوانے شاعر کے لیے اپنے معبودوں کوہی چھوڑ دیں@@ ؟‘‘لیکن خداوندِ عالم یہاں شاعر کی مذمت میں فرماتا ہے کہ(۱) شعراءتو تخیلاتی  اور تصوراتی دنیا میں کھوئے رہتے ہیں ۔ (۲) شعراءعیش وعشرت ، شراب وکباب کے طالب، خوبصورت معشوق کے بالوں میں گالوں  اور رُخسارکے تِلوں کی تعریف میں ہی اُلجھے ہوئے ، ویرانوں  اور خرابوں میں دیوانہ وار پھرتے رہتے ہیں ۔ اسی لیے فرمایا کہ شعراءکی پیروی (اُنہی جیسے ) گمراہ لوگ کرتے ہیں جبکہ قرآن میں اس قسم کی بکواس موجود ہی نہیں ہے۔ (قرآن  اور اللہ کارسولؐ تو دعوتِ حق دیتا ہے) تفسیر نمونہ  دونوں گروہوں یعنی انبیاء کرامؑ  اور شاعروں میں واضح فرق نظر آتا ہے (لیکن صاحبانِ عقل کے لیے، بے عقلوں  اور سفلوں کے لیے نہیں ) ایک طرف انبیاء کرامؑ میں انتہائی سجیدگی ، تہذیب، شرافت، صداقت  اور خوفِ خدا کارنگ، ہر بات میں احساسِ ذمہ داری ، حقوق کالحاظ ، معاملات میں دیانت وامانت، گفتگو میں خیر ہی خیر ہوتا ہے رات دن مقصد زندگی کے امور میں مصروف ومشغول ۔ دوسری طرف کاہنوں ، جادوگروں ، شاعروں کاحال یہ ہے کہ کہیں عشق بازی  اور شراب نوشی کے مضامین بیان ہورہے ہیں ،  اور حاضرین اُچھل اُچھل کراُن کو داد تحسین دے رہے ہیں ۔ کہیں کسی زنِ بازاری یاکسی گھر کی بہو، بیٹی کاحسن ، گلوکاری ، اداکاری ، فن کاری موضوعِ سخن ہے،  اور سننے والے مزے لے رہے ہیں ، کہیں جنسی ملاپ کی حکایت اشاروں ، کنایوں میں بیان ہورہی ہے  اور پورے مجمع پر شہوانیت کابھوت مسلط ہے۔ کہیں کسی شریف آدمی کوٹوپی اچھالی جارہی ہے تو کہیں کسی رذیل وذلیل کی تعریف میں زمین وآسمان کے قلابے ملائے جارہے ہیں جھوٹ بولنے میں کمال حاصل ہے۔
  26,225,آیت ۲۲۵کی تشریح: شاعروں کاحال تو یہ ہوتا ہے کہ کبھی ایک لہر اُٹھی تو حکمت  اور عظمت کی باتیں ہونے لگیں کبھی دوسری لہر آگئی تو اُسی زبان سے انتہائی گندے  اور سفلے جذبات آنے لگے کسی سے بگڑ گئے تو اُسے تحت الثریٰ میں اُتاردیا،  اور کسی سے خوش ہوئے تو ساتویں آسمان پربٹھا دیا۔ وغیرہ وغیرہ &&(تفہیم)&& ’’تفسیر مجمع البیان‘‘میں ابن عباسؒ سے مروی ہے کہ : ان سے مشرکین کے شعراءمراد ہیں جنہوں نے آنحضرتؐ کی ہجو اور ناشائستہ کلمات کو اپنے اشعار میں نظم کیا۔  اور جاہلوں سے دادِ تحسین حاصل کی۔ {{حضرت امام جعفر صادق علیہ السلام سے منقول ہے کہ اس سے وہ لوگ مراد ہیں جو علم وفہم سے کورے ہونے کے باوجود علم کالباس پہنے بیٹھے ہیں ، عوام اُن کو عالم سمجھ کر اُن کی پیروی کرنے لگے۔ وہ خود تو گمراہ تھے ہی ، عوام کو بھی گمراہ کردیا۔  اور تفسیر برہان میں حضرت امام جعفر صادق علیہ السلام سے مروی ہے کہ: اس سے مراد وہ فقیہ لوگ ہیں جو لوگوں کے دلوں میں باطل کابیج بوتے ہیں ۔الخ&&(تفسیر انوارالنجف)&&}} ان شعراء کی تین علامتیں بناتی ہیں :غرض قرآن نے شعراءکی تین علامتیں بتائی ہیں ۔ (۱) ان کی پیروی گمراہ لوگ کرتے ہیں  اور وہ خیالی دنیا میں مست ومگن رہتے ہیں ۔ حقائق سے بھاگتے ہیں ۔ جبکہ قرآن کی پیروی صرف نیک لوگ کرتے ہیں ،  اور قرآن ٹھوس حقیقتوں کو بیان کرنا ہے۔ قرآن ہمیں خیالی دنیا میں مست ومگن رہنے کی تعلیم نہیں دیتا۔ (۲) شعراءکی دوسری خاصیت یہ ہوتی ہے کہ اُن کاکوئی خاص اعلیٰ مقصد نہیں ہواکرتا۔ اُن کی فکر ہمیشہ بدلتی رہتی ہے ۔ جیسا موڈ (مزاج) ہواویسے ہی اشعار بکنے لگتے ہیں ۔ جب کہ قرآن کانقطہ نظر شروع سے آخر تک ایک ہی ہے اس میں کہیں کوئی تضاد یا اختلاف نہیں پایا جاتا۔ راہ حق کی ہدایت ہی ہدایت ہے۔ (۳) شاعروں کی تیسری علامت یہ ہے کہ وہ باتیں تو بڑی اچھی اچھی کرتے ہیں ، مگر خود اُن پر عمل نہیں کرتے۔ ڈاکٹر اقبال نے خود اس عیب کااعتراف کیا ہے: کہتے ہیں ۔[[ اقبال بڑا اُپدیشک ہے، من باتوں میں موہ لیتا ہےگفتار کا غازی تو وہ بنا،کردار کا غازی بن نہ سکا۔]]&&(اقبال)&&آپ خود ملاحظہ فرمالیں کہ جناب رسولِ خداؐ میں ان تینوں علامتوں میں سے کوئی ایک علامت بھی ذرّہ برابر موجود نہ تھی۔ آپؐ تو از سرتاپا، عمل ہی عمل تھے۔ تاریخ گواہ ہے کہ شاعروں نے اکثروبیشتر جابر بادشاہوں کی تعریف کی ہے۔ جبکہ قرآن میں یا حدیث میں اُن کی کوئی تعریف تو کیا بلکہ سخت مذمت ملتی ہے۔ پھر یہ کہ شاعر بے حیائی کے ذکر پر خوب جھومتے  اور دادِ تحسین کے خواہاں ہوتے ہیں ، جذبات بھڑکاتے ہیں جبکہ قرآن اصلاح،  اور امن وآشتی کاعلمبردار ہے  اور بےحیائی کی سخت مذّمت کرتا ہے۔ &&(تفسیر نمونہ)&&
  26,227,آیت نمبر۲۲۷:شعراء کی تعریف بزبانِ رسالتؐ مآب:{{تفسیرمجمع البیان میں ہے کہ: کعب بن مالک نے حضوررسالت مآبؐ سے عرض کی: ’’حضورؐ!آپؐ شعراءکے متعلق کیافرماتے ہیں ۔ آپؐ نے فرمایا: مومن تلوار کے ذریعے سے جہاد کرتا ہے اور قسم ہے اُس ذات کی جس کے قبضہ قدرت میں میری جان ہے، شاعر لوگ (جودین کی ترجمانی  اور مدح میں شعر لکھیں ) اُن کو تیرمارتے ہیں ۔آپؐ نے حسانؓ بن ثابت سے فرمایا تھا کہ’’تم اُن ( دین اسلام کے دشمنوں ) کی ہجو میں شعر کہاکرو، روح القدس تمہارے ساتھ ہوں گے ۔&&(تفسیر انوارالنجف)&&}} اچھی  اور بامقصد شاعری کو الگ کرکے مستثنیٰ کردیاگیا ہے۔ جناب رسول خداؐ کو بھی اچھے اشعار پسند آتے تھے،  اور آپؐ اُن کی داد بھی دیا کرتے تھے۔ آپؐ کاارشاد ہے’’ان من الشعرالحکمۃ‘‘ یعنی :یقیناً بعض شعر حکیمانہ ہوتے ہیں ۔‘‘اُمیہ بن ابی لصلت کاکلام سُن کرآپؐ نے فرمایا تھا:’’اس کاشعر تو مومن ہے مگر اُس کا دل کافر ہے ۔ایک صحابی نے ایک مرتبہ آپؐ کو سو عمدہ اشعار سنائے، آپؐ یہی فرماتے گئے’’ اور سنائو۔‘‘ &&(تفہیم القرآن )&&{{ فرزند رسول خداؐ حضرت امام جعفر صادق علیہ السلام نے فرمایا۔’’جوشخص ہم اہل بیتؑ کی مدح میں ایک شعر کہے گا، خدا اُس کاگھر جنت میں بنائے گا۔‘‘&&(الغدیر جلد۲)&&}} تاریخ گواہ ہے کہ بنی اُمیہ  اور بنی عباس کے دورِ ظلم وجور میں ایسے شاعر بھی تھے جو اُن کےجھوٹ فریب  اور ظلم کا پردہ چاکردیتے تھے مظلوموں کی حمایت کرتے تھے آل محمدؐ کی مدح اُن ظالموں کے سامنے کیاکرتے تھے۔ (مثلاً فرزدق:جنہوں نے فرزندِ رسول خداؐ {{حضرت امام زین العابدین علیہ السلام کی مدح میں حج بیت اللہ کے طواف کے موقع پر ہشام بن عبدالملک کے سامنے چالیس اشعار فی البدیہ کہہ سنائے تھے) یہ آیت ۲۲۷ایسے ہی شعراء پر صادق آتی ہے۔ &&(تفسیر نمونہ)&&{{ فرزند رسولِ خداؐ حضرت امام علی رضا علیہ السلام نے فرمایا:’’جوشاعر ہماری مدح میں شعر کہتا ہے تو روح القدس اُس کی مدد کرتا ہے ‘‘&&(عیون الاخیارالرضاؑ)&& }}{{فرزندِ رسول خداؐ حضرت امام جعفر صادق علیہ السلام اپنے دوستوں کو حکم دیا کرتے تھے کہ ’’اپنی اولاد کو عبدی کے اشعار تعلیم دو۔کیوں کہ وہ خدا کے دین پر تھا۔‘‘&&(تفسیر نورالثقلین )&&}} عبدی کے کچھ اشعار کاترجمہ ملاحظہ فرمائیں ۔ (۱) لوگوں نے کہا کہ رسول خداؐ نے اپنے بعد کسی کو امام نہیں بنایا۔ ہم خود اپنا امام بنائیں گے۔ (۲) ہم تو ایسے امام کاانتخاب کریں گے کہ اگر وہ سیدھا چلے گا تو ہم اُس کی اطاعت کریں گے،  اور وہ ٹیڑھا چلے گا تو ہم خود ہی اُسے سیدھا کردیں گے ۔ (۳) ہم نے اُن سے کہا کہ پھر تم خو داپنے امام کیوں نہیں بن جاتے، بحمد اللہ تم تو خوب سرگرداں پھر رہے ہو لیکن ہم سرگرداں نہیں کیوں کہ:(۴) ہم نے اُن کو اپنا امام تسلیم کرلیا ہے، جنہیں غدیر خم کے دن رسولِ خداؐ نے ہمارے لیے ہمارا امام بنایاتھا۔ ہم اس سے ذّرہ برابر بھی انحراف نہیں کریں گے۔(۵) ہم اللہ کے واضح نور پر ہیں ۔ اے ہمارے مالک!تو ہمارے اس نور میں  اور اضافہ فرما،  اور ہمیں ثابت قدم رکھ۔&&(الکی والالقاب جلد۲)&& ذکرِ کثیر سے مراد{{:فرزندِ رسول خداؐ حضرت امام جعفر صادق علیہ السلام نے فرمایا: ’’یہاں <<‘‘ذکراًکثیراً‘‘ذکر کثیر‘‘>>سے مراد (اولین معنی ہیں ) تسبیح فاطمہ زہرائَؐ ہے۔‘‘ حضرت امام علیہ السلام نے اپنے اصحاب سے فرمایا:’’وہ سخت او اہم کام جسے خداوندعالم نے اپنی مخلوق پر فرض کیا ہے، خدا کاذکر کثیر‘‘ ہے میری مراد یہ نہیں ہے کہ لوگ’’سبحان اللہِ والحمدللہ ولاالہ الاللہ واللہ اکبر‘‘پڑھتے رہیں ۔ اگرچہ یہ بھی خدا ہی کاذکر ہے ، لیکن میرا مقصد (سب سے افضل ذکر ہے،  اور وہ یہ ہے کہ جب) انسان حلال  اور حرام پر قادر ہوتا ہے، اُس وقت خدا کو یاد کرے۔  اور اس وقت خدا کو یاد کرنا یہ ہے کہ اگر وہ کام خدا کی اطاعت سے ہے تو اُسے انجام دے  اور اگر وہ کام خدا کی معصیت یانافرمانی سے ہے تو اُس کو چھوڑ دے۔‘‘&&(اصول کافی)&&}} آخر میں دعاء ہے کہ خداوندِ عالم ہم سب کو یہ توفیق عطا فرمائے کہ ہم حلا ل  اور واجب پر عمل کریں یعنی جوچیز خدا کو پسند ہے اس کو اپنائیں ،  اور جو خدا کو ناپسند ہے  اور اُس کو ناراض کرتی ہے، اس کو چھوڑ دیں ۔ &&(مولف)&& <<’’وسیعلم الذین ظلموا‘‘>> ( اور عنقریب ظالموں کو معلوم ہوجائے گا) {{ تفسیر بُرہان میں قمی سے منقول ہے کہ : یہ اُن لوگوں کے لیے جنہوں نے آلِ محمدؐ پر ظلم ڈھائے رکھنا چاہیے،  اور میری کشتی نجات پر سوار (ہو کر جہنم کے عذابوں سے نجات حاصل کرنا) چاہے، وہ علی ابن ابی طالبؑ کی اقتداءوپیروی کرے۔  اور اس کے دشمن سے دشمنی کرے، اس کے دوست سے دوستی رکھے، اور علیؑ ابن ابی طالب ؑ میرا وصی ہے،  اور میر ی اُمت پر میرا خلیفہ ہے میری زندگی میں بھی،  اور میری وفات کے بعد بھی۔ وہ ہرمسلم ومومن کامیرے بعد امیر ہے۔ اُس کاحکم، میراحکم ہے  اور اُس کی نہیں میری نہیں، اُس کی اتباع کرنے والا، میری اتباع کرنے والا ہے،  اور اُس کاناصر ومددگار میرا ناصر ومددگار ہے پس جس نے اُس کو چھوڑ دیا ، اس نے مجھے چھوڑ دیا۔ پھر فرمایا: جس نے علیؑ ابن ابی طالبؑ کوچھوڑا، قیامت کے دن ، نہ وہ مجھے دیکھے گا،  اور نہ میں اُسے دیکھناپسند کروں گا۔  اور جو علیؑ ابن ابی طالبؑ کامخالف ہوگا، اللہ تعالیٰ نے اُس پر جنت کو حرام کیا ہے  اور دوزخ اُس کاٹھکانہ ہے،  اور جوعلیؑ ابن ابی طالبؑ کی مدد کو ترک کردے گا خدا اُس کی کوئی بات نہ سُنے گا جب وہ اُس کے پیش حاضر ہوگا۔  اور جو علیؑ ابن ابی طالبؑ کی مدد کرے گا خدا اُس کی مدد کرے گا۔  اور یوم جزاء اُس کو اپنی حجت تسلیم کرے گا۔ &&(تفسیر برہان بروایت تفسیر قمی )&& پھرفرمایا: حسنؑ وحسینؑ اپنے باپ کے بعد لوگوں کے امام ہوں گے،  اور یہ دونوں جوانانِ جنت کے سردار ہیں ،  اور اُن کی ماں عالمین کی عورتوں کی سردار ہیں ،  اور اُن دونوں کے باپ تمام اوصیا کے سردار ہیں ۔  اور امام حسینؑ کی اولاد میں سے نوامام ہوں گے جن کانواں قائم مھدیؑ ہوگا۔ اُن سب کی اطاعت میری اطاعت ہے میں اللہ کی طرف اُن لوگوں کی شکایت کرتاہوں جو اُن کی فضیلت کاانکار کریں گے  اور میرے بعد اُن کے حق کو ضائع کریں گے اللہ ولی ہے میری عترت کا اور میری اُمت کے ائمہ کا  اور وہ انتقام لے گا اُن سے جو اُن کے حق کاانکار کریں گے ۔پھر آپؐ نے یہی آیت پڑھی۔ &&(تفسیر انوارالنجف)&&}}
