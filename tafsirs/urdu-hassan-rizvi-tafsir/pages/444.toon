tafsir[10]{c,v,t}:
  36,55,آیت ۵۵: شغل عربی میں ہردل پسند کام کوکہتے ہیں جس کے انجام دینے میں لطف آئے ۔&&(راغب)&& اب خدا جنت والوں کے سکون قلب کوبیان فرمایا ہے ۔انکی راحت و آرام کی کیفیت کا نقشہ کھینچا ہے۔&&(تفسیرنمونہ)&&
  36,56,آیت ۵۶ کہ جنتیوں کے سات اعضاء سات قسم کی لذتوں سے بیک ووقت لذت حاصل کریں گے۔(۱)قدموں سے جنت میں داخل ہونے کی لذت <<ادخلوھابسلم امنین >>&&(القرآن)&&@@ امن وسلامتی کے ساتھ جنت میں داخل ہوجائو@@۔ (۲)ہاتھوں سے جام شراب اور ماکولات حور و غلمان کے ہاتھوں سے لینے کی لذت۔(۳)جنت کی حسین ترین حوروں سےطویل مدت تک ہمبستری کی لذت۔(۴)پیٹ کوکھانے پینے کی لذت۔(۵)زبان کوپروردگار کی حمد وشکر کی لذت۔(۶)کانوں سے اپنے گناہوں سےبخشش سننے اور جنت کی مختلف قسم کی سریلی آواز اور اللہ کی طرف سے سلام سننے کی لذت۔(۷)آنکھوں سے جنت کے حسین ترین مناظر دیکھنے کی لذت نصیب ہوں گی۔&&(تفسیر مجمع البیان ،تفسیرانوار النجف، تفسیر نورالثقلین)&&
  36,58,آیت نمبر۵۸:{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ جس وقت جن کے رہنےوالے جنت میں خدا کی نعمتوں سے لطف انداوز ہورہے ہوں گے اس وقت ایک نور ان کے سروں پر ظاہر ہوگا یہ لطف خدا کا نورہوگا، اس میں سے آواز آئے گی <<’’سلٰام،،>> ہوتم پراے جنت میں رہنے والو!،،یہ سلٰام سن کرجنتیوں کواس قدر والہانہ خوشی ہوگی کہ وہ خداکی نعمتوں اور لذتوں کے سوا ہرچیز سے بالکل غافل ہوجائیں گے یہی وہ موقع ہوگا کہ فرشتے کے محلات کے ہرہر دروازے سے داخل ہوکراس جنتی کومبارکباد پیش کریں گے۔&&( تفسیرروح المعانی جلد۲۳)&&}}اصل ملیں یہ دیدار الٰہی کاجلوہ ہوگا جوان پرظاہر ہوگا ۔ یہ دیداراس قدر پر لطف ہوگا کہ اس کی لذت ان کوہرچیز کی لذت سے غافل کردے گی۔&&(تفسیر نمونہ)&&{{جناب المومنین نے فرمایا:’’ اگرمیں ایک لمحہ کیلئے بھی اپنے خداکے دیدار سے محروم ہوجائوں توجان دےدوں ۔،، &&(تفسیرروح البیان ج۷ص۴۱۶)&&}}آنکھیں کھلم کھلا اللہ کا دیدار نہیں کرسکتیں :{{دغلب یمنی نے سوال کیا یا امیرالمومنین علیہ السلام !کیا آپ نے اپنے پروردگار کودیکھاہے؟آپ علیہ السلام نے فرمایا: کہامیں اس اللہ کی عبادت کرتاہوں جسے میں نے دیکھاتک نہیں ؟دغلب نے عرض کی: آپ علیہ السلام کیوں کردیکھتے ہیں اپنے اللہ کو؟ جناب امیرالمومنین علیہ السلام نے ارشاد فرمایا:’’آنکھیں اللہ کوکھلم کھلا نہیں دیکھتیں ،بلکہ دل ایمان حقیقتوں سے اللہ کو خوب اچھی طرح پہچانتے اور درک کرتے ہیں اللہ ہرچیز سےقریب ہیں لیکن جسمانی اتصال کے طورپر نہیں ، اللہ ہرچیز سے دور ہیں لیکن الگ بھی نہیں ، اللہ بغیر غوروفکر کیے کلام کرتے ہیں اور بغیر آمادگی کے قصد و اردہ کرتے ہی، اور بغیر اعضا کی مدد لیےبنانےوالے ہیں …اللہ لطیف ہیں لیکن پوشیدگی سےانہیں متصف نہیں کیاجاسکتا…اللہ بزرگ وبرتر ہیں مگرتندخوئی وبدخلقی کی صفت ان میں نہیں …اللہ دیکھنےوالے ہیں مگرحواس سے انہیں موصوف نہیں کیاسکتا…اللہ رحم کرنےوالےہیں مگراس صفت کوان کے لیے رحم دلی سےتعبیر نہیں کیاجاسکتا۔ چہرے اللہ کے عظمت کے آگے ذلیل وخوار اور دل ان کے خوف سے لزراں وہرساں ہیں ۔،،&&(نہج البلاغہ خطبہ۱۷۷)&&اہل جنت کیلئے سب سے بڑااعزاز یہ ہوگاکہ خداوند عالم خود ان پر سلام فرمائےگا۔&&( سبحان اللہ)&& &&(تفسیرصافی ص۴۲۴)&&فرماں برداروں کیلئے جنت میں اہتمام:اللہ تعالیٰ نے حدیث قدسی میں ارشادفرمایا: ’’اے لوگو! تم دنیامیں اتنی دلچسپی کیوں لیتے ہو، یقیناً یہ دنیا فانی اور اس کی نعمات ختم ہوجانے والی ہیں ،اور زندگی بھی فنا ہوجائے گی۔ پس بتحقیق میرے پاس فرماں برداروں کیلئے جنت ہے کہ اجس کے آٹھ دروازے ہوں گے اور ہرجنت میں سترہزار زعفرانی باغ اور ہرباغ میں سترہزار ہونگے اور موتیوں کے شہر ہیں اور ہرشہر میں یاقوت کے ستر ہزار محل اور ہرمحل میں سترہزار زبرجد کے گھراور ہرگھر میں ستر ہزارسونے کے مکان ،اور ہرمکان میں چاندی کے ستر ہزار دکان(کمرے)ہردکان میں سترہزار سترخوان اور ہرایک دسترخوان پرسترہزار جوہری کشتیاں (ڈونگے ،ڈشیں ) اور ہرایک کشتی میں ستر ہزار قسم کے طعام اور ہردکان کے گرد ستر ہزار سرخ سونے کے تحت ،اور ہرتخت پر ریشمی بچھونے (گدے) سترہزار اور ہرتخت کے گرستر ہزارآب حیات کی نہریں دود، شرب اور خالص شہد کی نہریں ،اور ہرنہر میں سترہزار رنگ وقسم کے پھل ،اور اسی طرح ہرمکان میں ارغوانی رنگ کے سترہزار خیمے اور ہرخیمے میں ستر ہزار قالیچے اور اعلیٰ بچھونے اور ہر ایک بچھونے پرستر ہزار حور العین میں سے حوریں ہوں گی اور ہرایک حور ے سامنے ستر ہزر کنیزیں مثل اندے کے سفید ،اور ہرقصرکے سرپر ستر ہزار کافور کےقبے اور ہرقبے میں خدائے بزرگو برتر کی طرف تحفے ہوں گے جن کونہ کسی آنکھ نےدیکھا،نہ کان نے سناہوگا، نہ کسی آدمی کےدل میں خیال تک ہوگا اور لوگوں کے پسندیدہ میوے اور پرندوں کے لذیدگوشت ان کوخواہش کے مطابق ،اور حوریں مثل موتیوں کے چمکتی ہوں گی ،جو ان کواعمال خیربجالانے کے بدلے میں ملیں گی ،اور جنتی لوگ وہاں نہ مریں گے ،نہ روئیں گے ،نہ رنج کریں گے، نہ بوڑھے ہوں گی نہ عبادت کریں گے نہ روزہ رکھیں گے نہ نمازپڑھیں گے ،نہ مریض ہوں گے، نہ پیشاب پائخانہ کریں گے، نہ غمناک ہوں گے ، نہ وہاں سے کبھی نکالے جائیں گے۔ پس جوشخص میرے معزز گھر اور پڑوس کوچاہتاہے ،توصدقے دینے کے ذریعہ سے اور دنیا کومعمولی سمجھنے سے اور کم رزق پرقناعت کرنے سے میری جنت اور وہاں کی ابدی نعمات کو طلب کرے ۔ میرے ذات شاہد ہے ، میرے ذات کیلئے کوئی معبود بر حق سوائے میرے نہیں ،اور عیسیٰ علیہ السلام اور عزیر علیہ السلام میرے ہی بندوں میں سے دو بندے ہیں اور میرے برگزیدہ رسولوں میں سے رسول ہیں ۔&&(حدیث قدسی ۵۱تا۵۴)&&
  36,60,آیت ۶۰ کی تشریح:خداوندعالم کافرمان کہ :<<’’ لَّا تَعْبُدُوا الشَّيْطٰنَ۰ۚ ،،>>@@(شیطان کی عبادت نہ کرو۔)@@ یہاں عباد ت کے معنی رکوع وسجود کرنا نہیں ، بلکہ عبادت کے معنی اطاعت کرناہے۔اس لیے کہ کوئی شخص شیطان کے سامنے رکوع وجود نہیں کرتا۔ اس سے ثابت ہواکہ عبادت کی حقیقت اطاعت کرنا ہے(فقط رکوع وسجود نہیں ہے۔) &&(تفسیرنمونہ)&&یاد رہے کہ خداوندعالم نے شروع دن ہی اولاد آدم کوبتادیاتھاکہ:<<يٰبَنِيْٓ اٰدَمَ لَا يَفْتِنَنَّكُمُ الشَّيْطٰنُ كَـمَآ اَخْرَجَ اَبَوَيْكُمْ مِّنَ الْجَنَّۃِ يَنْزِعُ عَنْہُمَا لِبَاسَہُمَا لِيُرِيَہُمَا سَوْاٰتِہِمَا۰ۭ اِنَّہٗ يَرٰىكُمْ ہُوَوَقَبِيْلُہٗ مِنْ حَيْثُ لَا تَرَوْنَہُمْ۰ۭ اِنَّا جَعَلْنَا الشَّيٰطِيْنَ اَوْلِيَاۗءَ لِلَّذِيْنَ لَا يُؤْمِنُوْنَ۲۷>> &&(سورہ اعراف آیت ۲۷ پارہ۸)&&@@ یعنی اے آدم علیہ السلام کی اولادو! شیطان تمہیں دھوکہ نہ دیدے جس طرح اس نے تمہارے والدین کو جنت سے نکال چھوڑا تھاان کے کپڑے تک بدن سے اتروا دیے تھے تاکہ ان کی شرمگاہوں کوان پرظاہر کردے ۔اب وہی شیطان اور ان کا قبیلہ تمہیں دیکھتے ہیں جہاں سے تم انہیں نہیں دیکھ سکتے ۔یقیناً ہم نے شیطان کوانہی لوگوں کودوست یا ساتھی قراردیا ہے جو خدا و رسول کودل سے نہیں مانتے@@۔پھرسورۃ الزخرف میں بھی اسی طرح متنبہ فرمایا: (Narningyدی)<<’’وَلَا يَصُدَّنَّكُمُ الشَّيْطٰنُ۰ۚ اِنَّہٗ لَكُمْ عَدُوٌّ مُّبِيْنٌ۶۲ ،،>>&&( سورۃ الزخرف آیت ۶۴، پارہ۲۵)&&@@ یعنی اور (دیکھو کہیں ) شیطان تمہیں ( حق کے راستے سے) نہ روک دے کیوں کہ یقیناً وہ تمہارا کھلا ہوا دشمن ہے۔@@ شیطان کی عبادت یااطاعت کامطلب یہ بھی ہے کہ علماء دین کی پیروی آنکھیں بند کرکے کی جائے اور یہ نہ دیکھاجائے کہ وہ واقعی حق کہہ رہے ہیں یااپنے مفادات کے پیش نظر دھوکہ دے رہے ہیں اس لیے کہ علماء میں علماء سوء ( برے علماء)بھی حدیث رسول سے ثابت ہیں ۔ فرمایا:<< الفقھاء امناء الرسل مالم یدخلوفی الدنیا قیل یارسو اللہ وما دخولھم فی الدنیا؟ قال : اتباع السطان فاذافعلو ذٰل فاحذروھم علٰ ی دینکم>>&&( کنزاالعمال الحدیث ۲۷۹۵۲، اصول کافی جلد۱ ص۵۶ بحوالہ گفتار دلنشین ص۱۴)&& یعنی : {{آں حضرت نے فرمایا:فقہاء رسولوں کے اسوقت تک امین میں ( مورد اطمینان ہیں ) جب تک کہ وہ امور دینا میں داخل نہ ہوں ۔ آپ سے لوگوں نے دریافت کیا ،اے خداکے رسول ؐ! امور دینا میں داخل ہونے کا کیا مطلب ہے؟ آنحضرت صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: دنیاوی امور میں داخل ہونے کامطلب ظالم بادشاد ( حاکم طاغوت) کی پیروی کرنے لگیں جب یہ علماء سلطان (جابر) کی پیروی کرنےلگیں تواپنے دین ( کی حفاظت) میں سے پرہیز کرتے رہنا۔خود آقرآن میں خداوندعالم نے قسم کھاکرفرمایا:خدا کی قسم! یہودی ،عیسائی ، (علماء ) نے لوگوں کواپنی عبادت کی طرف نہیں بلایا، اگروہ (علماء) اپنی عبادت کاحکم دیتے تویہودی ،عیسائی کبھی ان کی بات نہ مانتے ،لیکن ان (علماء) نےحرام کوحلال اور حلال کوحرام کردیا، اور انہوں نے (ان کو مان کر) لاشعوری طور پر ان کی عبادت کی۔&&( القرآن)&&}}{{اس آیت پرحضرت امام جعفرصادق علیہ السلام نے فرمایا:جس شخص نے کسی انسان کی اطاعت گناہ کرنے میں کی، تواس نے گویااس کی عبادت کی۔&&( وسائل الشیعہ جلد۱۸)&&یہاں تک کہ امام علیہ السلام نے فرمایاکہ :جب کوئی آدمی کسی بھی بولنےوالے کی بات کان لگاکرسنتا ( دلچسپی سے سنتا) ہے ،توگویا اسنے اس آدمی کی عبادت کی ۔ اگربولنےوالا حکم خدا کے مطابق بیان کررہاہے تواس نے خداکی عبادت کی ،اور اگر بولنے والا شیطانی بات کررہاہے توس نے گویا شیطان کی عبادت کی۔&&( وسائل الشیعہ جلد۱۸)&&}}{{ امیرالمومنین حضرت امام علی ابن ابی طالب علیہ السلام نے فرمایا:اے خدا کے بندو! خدا کے دشمن شیطان سے ڈرتے رہو کہیں ایسا نہ ہوکہ وہ تمہیں اپنی بیماری ( یعنی : حرص وتکبر) میں مبتلاء کردے اور آواز دے کہ تمہیں بلالے اور حرکت میں لے آئے اور تمہیں بھی اپنے لشکرسوار اور پیادوں میں شامل کرلے۔ مجھے اپنے جان کی قسم!اس نے تمہیں شکارکرنے کیلئے ایک خطرناک تیرکمان رکھا ہوا ہے جسےوہ اپنی پوری طاقت سے کھینچتا ہے اور بہت ہی قریب سےتمہیں نشانہ بناتا ہے۔ اس نے یہ اعلان بھی کررھاہے جسےاللہ نے اس کی زبانی فرمایاہے کہ:’’ اے میرے پانے والے! چونکہ تونے مجھے بہکادیاہے اب میں بھی اولاد آدم کے سامنے دنیاکی زرق وبرق چیزوں اور ٹھاٹھ باٹھ سے ان کی آنکھوں کوچکا چوند کردوں گا اور انسے کوگمراہ کردوں ، اب کتنا عجیب ہوگا کہ ہم ایسے جانی دشمن کواپنادوست سمجھ لیں ۔دیکھو! اپنے ان سرداروں اور بڑوں کااتباع کرنے سے ڈڑتے رہو کہ جواپنی جاہ وحشمت پر اکڑتے اور اپنے نسب کی بلندیوں پرغرور سےدھوکہ کھاتےہیں اور بدنماچیزوں کواللہ کے ذمے ڈال دیتے ہیں اور اس کی قضاوقدر سے ٹکڑ لیتے ہیں اور اس کی نعمتوں پر غلبہ پانے کیلئےاس کےاحسانات سے یکسر انکار کردیتے ہوں ۔یہی لوگ توعصبیت کی عمارت کی گہری بنیاد ،فتنہ کے محل دیوان کے ستون اور جاہلیت کے نسبی تفاخر کی تلوار ہیں ۔ لہٰذا اللہ سے ڈرتے رہو اواس کی عطا کردہ نعمتوں کے دشمن نہ ہو، اور نہ اس کے فضل وکرم کے دشمن بنو جوتم پراس نے کیاہے، اور نہ حاسدبنو، اور دیکھو! جھوٹے مدعیان اسلام کی پیروی کرنےسےبچتے ہی رہو جن کاگندہ پانی تم اپنے صاف پانی میں ملاکرپیتے ہو۔&&(ماخوذ از نہج البلاغۃ خطبہ۱۹۲)&&}}
  36,64,آیت نمبر۶۴:<<’’اِصْلَوْ،،>> کا لفظ صلٰی کے مادہ سے ہے۔ اس کے معنی آگ میں جلانا اور بھوننا ( یا) آگ میں داخل کرنا اور اسی کولازمی کرلینا۔&&( مفردات امام راغب)&&مطلب یہ ہے کہ اے جہنمیو! تم پر افسوس ہے کہ تمہیں اس قدر صاف صاف سمجھایاگیا تھا کہ شیطان کی بات نہ ماننا وہ تمہارا کھلادشمن ہے ،مگر پھر بھی تم کوعقل نہ آئی ، اور آخرکار شیطان کامیاب ہوا اور اس نے اتنی بڑی مخلوق کوگمراہ کرکے ہی چھوڑا اور تم ایسے احمق ثابت ہوئے کہ اپنے نفع ونقصان کونہ سمجھ سکے اور اپنے دشمن کونہ پہچان سکے&&( شیخ الاسلام عثمانی)&&
  36,65,آیت نمبر۶۵:روزِ قیامت انسان کے ہاتھ اللہ سے ساری زندگی کی روداد بیان کریں دے:{{جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’روز قیامت ہرانسان کواس کا نامہ اعمال دیاجائے گا تو گنہگار لوگ اپنی بدمعاشیوں سے انکار کریں گے اور کہیں گے کہ ہم نے ایسے کام نہیں کیے توسب سے پہلے فرشتے ان کے خلاف گواہی دیں گے اس پر وہ بدمعاش مجرم قسمیں کھانے لگیں گے ۔ ان کی اس حرکت پران کے منہ پرمہر لگادی جائےگی، اور ان کے اعضاء کوگواہی دینے کاحکم ہوگا پس یہ حکم ملتے ہی ان کےہاتھ پیر اور تمام اعضاان کی بدمعاشیوں کوبیان کریں گےاور گواہی دیں گے۔&&(تفسیر برہان ،تفسیر صافی ،تفسیر انوار النجف)&&}}{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ : اعضاء کی گواہی صرف ان لوگوں کے خلاف لی جائی گی جن کوحتمی طورپر جہنم میں جانے کاحکم ہوگا لیکن مومن کواس کے داہنے ہاتھ میں نامہ اعمال دے کرجنت کی طرف بھیج دیاجائےگا۔&&( الکافی، تفسیر انوارالنجف ،تفسیرنورالثقلین)&&}}شاید اس لیے کہ مومن اپنے گناہوں کے انکار کی بجائے سخت شرمسار بھی ہوگا۔ اور گناہوں کا معترف بھی ۔بقول میرانیسؔ:[[رحمت کا تیری امیدوار آیا ہوں ۔منہ ڈھانپے کفن سے شرمسار آیا ہوں ۔چلنےنہ دیا بارگناہ نے پیدل،اس واسطے کاندھوں پہ سوار آیا ہوں]] !!نتائج:(۱)اس آیت سے ثابت ہوگیا کہ قیامت کے دن ہمارے اعضا ہماری مرضی کے تابع نہ ہوں گے ،بلکہ خدا کے حکم کے تابع فرمان ہوں گے۔ (۲)خدا کی عدالت کتنی بڑی اور سچی عدالت ہوگی کہ وہاں انسان کے اعمال کے گواہ خواد کے اپنے اعضا وجوار ہوں گے۔&&( تفسیر نمونہ)&&{{جناب امیرالمومنین علیہ السلام نے فرمایا: <<ان اللہ سبحانہ وتعالیٰ لایخفی علیہ مالاعباد مقترفون فی لیالیھم ونھارھم لطف بہ خبر و احاط بہ علما اعضاؤ کم شھودہ وجوراھم کنودہ وضآئر کم عیونہ وخلواتم عیانہ>>&&(نہج البلاغۃ ازخطبہ۱۹۷)&&}} یعنی : یہ بندگان خدا رات کے پردوں اور دن کے اجالوں میں جوگناہ کرتے ہیں وہ اللہ سبحانہ وتعالیٰ سے چھپے ہوئے نہیں ہوتے ، وہ توہر چھوٹی سے چھوٹی چیز سے آگاہ اور ہرشے پراس کاعلم محیط ہے، تمہارے ہی اعضا اس کے سامنے گواہ بن کر پیش ہوں گے اور تمہاری ہی ہاتھ پائوں کے لشکر اور تمہارے ہی قلب وضمیر اس کے جاسوس ہیں اور تمہاری تنہائیاں اس کی نظرکے سامنے ہیں ۔
  36,66,آیت نمبر۶۶:<<’’طَمَسْنَا،،>> کا لفظ، <<طمس>> ( بروزن شمس) کے مادے سے ہے جس کے معنی کسی چیز کواس طرح مٹادینا کہ اس کے آثار و نشانات تک ختم ہوجائیں ۔ &&( مفردات امام راغب)&&’’مکان،،کے معنی ٹھرنے کی جگہ ، گویا خدا سخت مجرموں کوخود ان کی جائے قیام پرہی انسانی شکل سے محروم کردے گا، اور وہ بالکل بے روح مجسموں کی طرف مسخ ہوجائیں گے ، یہ اس لیے ہوگا کہ وہ سیدھے راستے سے بہت دورنکل گئے تھے۔ سیدھے راستےکواپنے پیچھے چھوڑ دیا تھا۔ ایسی چالاکیاں بدمعاشیاں کی تھیں کہ راہ حق سے بہت دور بھٹک گئے تھے یعنی بالکل گمراہ ہوگئے تھے۔ &&( لسان العرب ، قسط المحیط ،المنجد)&&
  36,68,آیت نمبر۶۸:دہریوں کیلئے دعوت غور وفکر:دہریوں اور بےدینوں کا تصوریہ ہے کہ مادے کے اجزاء کے ملنے کی وجہ سے اتفاقاً یہ پوری کائنات ایک حادثہ کی وجہ سے پیدا ہوگئی یہی فلسفہ ڈارون کا بھی ہے۔سوال یہ ہے کہ اگرمادہ کی فطرت صرف ارتقا کرنا ہے درجہ بدرجہ ترقی کرتے رہنا ہی ہے توپھر انسان کی جوانی کے بعد بڑھاپا اور زوال کیسے ہوگیا؟اس سے نتیجہ نکلا کہ ارتقا کرنا مادے کا اپنا ذاتی ،فطری فعل نہیں ہے بلکہ کسی کا فیضان اور عطا ہے۔ اسی خدا نے مادہ کے اندر ارتقائی صلاحیت عطا فرمائی ہے، پھر وہی خدا جب چاہتا ہے مادے سے ارتقا کی صلاحیت کوسلب کرلیتاہے پھرجوان اور طاقتور ترین انسان کی جوانی بڑھاپے، اور کمزوری میں تبدیل ہوکر رہ جاتی ہے اور انسان ہاتھ ملتا رہ جاتاہے۔&&(فصل الخطاب)&&[[پیری میں خم کمر میں نہیں صعف سے قمر۔میں جھک کے ڈھونڈتاہوں جوان کدھر گئی]] &&(قمرجلالوی)&&!!حاصل مطلب:یہ ہے کہ قوی ہیکل صحتمند اور طاقتور ترین جوان انسان کوبوڑھا ہوکرکمزور ہوجانا، اس بات کاثبوت ہے کہ خدا کی قدرت کس قدر عظیم ہے کہ جو خدا ایک جوان طاقتور کی جوانی کونومولود بچے کی طرف پلٹاسکتا ہے تووہ خدا انسان کوموت کے بعد دوسری زندگی کی طرف کیوں نہیں پلٹا سکتا؟جب انسان بوڑھا ہوتا ہے تواس کی روح توترقی کرتی رہتی ہے مگراس کاجسم پیچھے بچپنے کی طرف پلٹنا شروع کردیتاہے اور عقل بھی تنزیل کاشکار ہوجاتی ہے، اور بالآخر بوڑھا انسان بچوں جیسی حرکتیں کرنے لگتا ہے اور جسمانی کمزوریاں بھی بچے جیسا بنا دیتی ہیں ، جبکہ بچوں کی بچگانہ حرکتیں اچھی لگتی ہیں ،مگر بوڑھوں کی بچگانہ حرکتیں بری لگتی ہیں ، اس وقت کی تکلیف کا احساس کرنا بہت مشکل ہے۔ قرآن نے خود اس کا نقشہ اسطرح کھینچا ہے:<<وَمِنْكُمْ مَّنْ يُّرَدُّ اِلٰٓى اَرْذَلِ الْعُمُرِ لِكَيْلَا يَعْلَمَ مِنْۢ بَعْدِ عِلْمٍ شَـيْــــًٔا>> یعنی@@ اور تم میں سےکچھ عمررسیدہ ہوکر بدترین زندگی کی طرف لوٹ دیے جاتے ہیں ان کی یہ حالت ہوجاتی ہے کہ علم انہوں نے حاصل کیا تھا وہ تک یاد نہیں رہتا@@&&( سورہ حج آیت۵ پارہ ۱۷)&&شاید اسی لیے بوڑھے انسان کوحدیثوں میں<< اسیر اللہ فی الارض>> ( زمین میں خاککا قیدی) کہاجاتا ہے۔&&(تفسیرکبیر)&&آخر میں خداوندعالم کافرمانا<<’’اَفَلَا يَعْقِلُوْنَ،،>>@@( پھر وہ عقل سے کام کیوں نہیں لیتے )@@ کہ اتنا نہیں سمجھتے کہ:(۱)جوقوت تم رکھتے ہو یہ وقتی وعارضی ہے۔(۲)یہ کس نے عطاکی ہے۔(۳)جوخدا یہ قوتیں دے سکتاہے وہ اس قدر طاقتور بھی ہے کہ ان قوتوں کوتم سے چھین لینے پرقادر بھی (۴)یہ دنیا ہمیشہ رہنے کی جگہ نہیں ہے۔(۵)ہمیں خداکی طرف پلٹنا ہے۔(۶)اس لیے ہمیں خدا سے ملاقات کی تیاری کرنی چاہیے۔ یعنی خداکی ملاقات کیلئے انیک اعمال کاسامان جمع کرناچاہیے&&( تفسیر نمونہ ،تفسیر کبیر، امام رازی)&&{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ابوذرؓ سے وصیت فرمائی تھی کہ :پانچ چیزوں کوپانچ چیز سے پہلے غنیمت جانو۔(۱)اپنی جوانی کواپنے بڑھاپے سے پہلے۔ (۲)اپنی صحت کواپنی بیماری سےپہلے(۳)اپنی خوشحالی کواپنی بدحالی سے پہلے(۴)اپنی فراغت کواپنی مشغولیت سے پہلے اور (۵)اپنی زندگی کواپنی موت سے پہلے۔ (غنیمت سمجھو) قرآن نے اس حقیقت کو یوں فرمایا:@@’’ جس شخص کوبھی یہ امید یا خوف ہے کہ اس کواپنے مالک کی طرف پلٹناہے اس کے لیے ضروری ہے کہ وہ نیک اعمال بجالائے اور یہ کہ اپنے مالک کی غلامی اور عبادت میں کسی کو شریک نہ کرے۔،، @@&&(سورہ کہف ۔آخری آیت ۱۱۰پارہ۱۶)&&آیت کاپیغام:یہ ہے کہ اے لوگو! تمہاری صورتوں کومسخ کردیناہمارے لیے کوئی بڑی مشکل بات نہیں ہے تم دیکھتے نہیں کہ ہم ایک تندرست ،طاقتور انسان کوبوڑھا بناکر دیکھنے ،بولنے ،چلنے پھرنے سےمعذور بنادیتے ہیں ۔گویا بچوں کی طرح کمزوراور دوسروں کامحتاج ہوجاتاہے ۔ جوخدا بڑھاپے میں ساری طاقتیں سلب کرسکتا ہے وہ جوانی میں بھی تمہیں مسخ کرکے پوٹلی بناکرسکتاہے۔&&( شیخ الاسلام عثمانی)&&{{
  36,69,آیت نمبر۶۹:آیت کامطلب یہ ہے کہ:ہم نے اپنے رسول صلی اللہ علیہ و آلہ وسلم کوشاعری نہیں سکھائی اس لیے کہ اگرہم ان کوشاعری کاملکہ عطاکردیتے تو تم کو شک ہوجاتاہےکہ اپنے اسی صلاحیت کے زور پر انہوں نےقرآن لکھ لیا ہے اور یہ وہی شاعری کی صلاحیت ہے جوقرآن کی شکل میں بول رہی ہے۔&&( تفسیر تبیان۔ تفسیر کبیر)&&لیکن یہ بات بھی ثابت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کبھی کبھی اشعار سن لیاکرتے تھے اور اشعار کہنے کی ترغیب بھی دیاکرتے تھے۔ اس لیے اس آیت سے فن شعر کی نتقیص یاتذلیل مقصود نہیں ہے۔ بس مقصد صرف اور صرف یہ ہے کہ کیونکہ قرآن کی فصاحت وبلاغت نا قابل تصور حدتک بلند ترین کمال پرتھی۔ اسلیے لوگوں کو کہیں یہ شبہ نہ ہوجاتا کہ قرآن جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کے ملکہ شاعری کا نتیجہ ہے۔ اس لیے فرمایا کہ ہم نے رسول کوشاعری کاملکہ عطا نہیں فرمایا۔&&(تفسیر مجمع البیان تبیان،فصل الخطاب،تفسیر کبیر)&&نیز یہ کہ شعرسے یہاں مراد عرب کی شاعری ہے جوجھوٹی ،خیالی ، جنسی ،جذبات اور فحش خیالات کی ترجمانی تھی، جس میں حقیقت کاعنصر نہ تھا بلکہ حقیقت سے بہت دورکی منصوبہ بندیاں خیالی پلائو اور شیخ چلی کے منصوبے ،جھوٹی کہانیاں ، زبردست مبالغہ آرائی، تشبیہات اور استعاروں کی بھرمار تھی۔&&(امام راغب ،تفسیر روح المعانی)&&اچھی اور اخلاقی ،بامعنی بلند شاعری کی بہرحال تذلیل ہرگز مقصود نہیں ہے۔&&( مولف)&& !!وحی اور شعر کا فرق:(۱)عام طورپر شعر تخیلات،تصورات اور جذبات کا نتیجہ ہوتے ہیں ،جبکہ وحی خدا کی طرف سے پیغام کی شکل میں بھیجی جاتی ہے۔ (۲)شاعر ہمیشہ ’’ تغیر،، کے عالم میں ہوتا ہے، جبکہ وحی ثابت شدہ حقائق کوبیان کرتی ہے۔(۳)شعر کالطف مبالغہ آرائی پرمنحصر ہوتاہے اور اسی لیے عربی کامحاورہ ہے۔<<اَحْسَنُ الشِّعْرِاَکْذِبُہٗ>> یعنی :سب سے اچھا شعر وہ ہوتاہے جس میں سب سےزیادہ جھوٹ بولاجائے۔ جبکہ وحی صداقت اور سچائی کے سواکچھ نہیں ہوتی۔(۴)شاعر الفاظ کے حسن کی خاطر مجبور ہوتا ہےکہ خود کوالفاظ کے حوالے کردے ،یا الفاظ کے پیچھے پیچھے چلے ، جبکہ وحی الفاظ کے سامنے لاچار نہیں ہوتی۔ (۵)شعر، شاعر کی آرزوں کامجموعہ ہوتاہے جبکہ وحی خدا کی مرضی کی ترجمان ہوتی ہے۔ البتہ اوہ اشعار مستثنیٰ ہیں جومقدس ہستیوں یااعلیٰ مقاصد کیلئے کہے جاتے ہیں ۔(۶)شعراء کی پیروی گمراہ لوگ کرتے ہیں جیساکہ سورۃ الشعراء میں فرمایا:<<وَالشُّعَرَاۗءُ يَتَّبِعُہُمُ الْغَاوٗنَ۲۲۴ۭ اَلَمْ تَرَ اَنَّہُمْ فِيْ كُلِّ وَادٍ يَّہِيْمُوْنَ۲۲۵ۙ وَاَنَّہُمْ يَقُوْلُوْنَ مَا لَا يَفْعَلُوْنَ۲۲۶ۙ>>&&(سورۃ الشعراء آیت ۲۲۴تا۲۲۷پارہ ۱۹)&& یعنی : @@اور گمراہ لوگ شعراءکی پیروی کرتے ہیں کیا تم نہیں دیکھتے کہ وہ ہر وادی میں بہکے ہوئے سرگراں بدحواس پھراکرتے ہیں اور وہ ایسی باتیں کہتے ہیں جووہ کرتے نہیں ( یعنی بدعمل ہیں ) سوائے ان (شعراء) کےجو ایمان لائے اور اعمال صالح بجالائے اور کثرت سے اللہ کی یاد کرنے والے ہوتے ہیں @@۔ جبکہ وحی الٰہی کی پیروی نیک اور صالح لوگ کرتے ہیں ۔(۷)شاعری کا مزہ غفلت اور حقائق کوفراموش کردینے میں ہے۔[[مئے سے غرض نشاط ہے کس روسیاہ کو۔اک گونہ بے خودی مجھے دن رات چاہیے۔]]جبکہ قرآن اور وحی سائے بیداری مغز اور ہوشیاری کے کچھ نہیں ۔&&(تفسیرنمونہ)&& جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کی طبیعت کوشاعری سے کوئی منابست نہ تھی۔ آپ صلی اللہ علیہ و آلہ وسلم نے پوری عمر میں کوئی شعر نہ کہا ۔ کبھی رجز کے موقع پر اگر زبان مبارک سے کئی مقفہ عبارت بے ساختہ جاری ہوتی تواسے شاعر ی نہیں کہ سکتے۔ آپ شاعروں کے اشعار تک نہیں پڑھتے تھے ،اگرکسی اچھے شعر کا حوالہ بھی دیتے تو اس کونثر میں ادا فرماتے۔آنحضرت صلی اللہ علیہ و آلہ وسلم خیالی وجذباتی باتوں کے نہیں بلکہ حقیقتوں اور وحی الٰہی کے ترجمان تھے شاعری دل پر اثر کرتی ہے اور قرآن بھی دل پراثر انداز ہوتاہے ۔صرف اتنی سے بات پرقرآن و حدیث کو شاعری کہہ دینا سراسر غلط اور بے انصافی ہے۔ اصل میں قرآن کے بے پناہ اثرکودیکھ کربڑے بڑے فصیح وبلیغ شاعر دنگ رہ گئے تھے۔ اسی بناپر حق دشمن عرب قرآن کوشاعری اور جادوگری کہنےلگےجبکہ جادو اور شاعری سے آج تک انسانی تاریخ میں کبھی کوئی انقلاب برپا نہیں ہوسکا۔ یہ کام شاعروں کا نہیں ہوتا بلکہ پیغمبران خدا کا ہوا کرتا ہے۔&&(شیخ الاسلام عثمانی)&&[[پرواز ہے دونوں کی اسی ایک فضا میں ۔کر گس کاجہاں اور ہے شاہیں کاجہاں اور ]] ۔&&(اقبال)&&
  36,70,آیت نمبر۷۰:{{جناب امیرالمومنین علیہ السلام سے روایت ہے کہ اس آیت میں زندہ آدمی سے مراد عقل سے کام لینے والا انسان ہے۔&&(تفسیرصافی ص۴۲۵، تفسیر مجمع البیان، تفسیر نورالثقلین)&&}}اس لیے زندہ آدمی کے حقیقی مراد سچا مومن ہے جسکا دل ایمان سے لبریزہو۔ اس لیے کہ ایمان دل میں اسی وقت داخل ہوسکتا ہے جب انسان کائنات پر یعنی خداکی آیات پرغوروفکر کرے۔ جب انسان غوروفکر کرتاہے تواس کادل ایمان کے ذریعے سے زندہ ہوجاتا ہے۔ &&(تفسیر قمی ، تفسیر کبیر)&&]]دل بینا بھی کر خدا سے طلب۔آنکھ کا نور دل کا نور نہیں [[۔علامہ اقبال کی دعاء ملاحظہ فرمائیں :]]اگر شایاں نیم تیغ علی را۔نگاہم دہ چوں شمشیرعلی تیز[[۔جولوگ عقل سےکام نہیں لیتے اور کتابیں رٹے ، پڑھتے چلے جاتے ہیں ان کے بارے میں ڈاکٹر اقبال نے جواب فرمایاہے:[[کیا ہے تجھ کو کتابوں نے کور ذوق ایسا۔کہ بوئے گل سے بھی تجھ کو ملا نہ گل کاسراغ۔]]&&(اقبال)&& یعنی : کتاب میں رٹ کرتواس طرح عقل کھوبیٹھا کہ تخلیقات کائنات کودیکھ کربھی اسے انسان تجھ اسے کے خالق کاسراغ نہ مل سکا۔&&( مولف)&&[[کس کے تابع ہے یہ ہرروز ابھرتا سورج دور کی چاند سے کس ذات نے تاریکی شب ۔کون شبنم سے دھلاتا ہے رخ گل ہر روز۔ بے خطا نظم کاہے اور یہاں کون سبب۔]]&&(حامد حسین کاظمی)&&غرض قرآن ، ایمان کوزندگی ،اور مومنین کوزندہ انسان سمجھتا ہے ۔بے ایمان کومردہ سمجھتا ہے ۔ یہ زندگی ظاہری زندگی سے بہت اعلیٰ چیز ہے اگرزندگی سانس لینے ،کھانے،پینے ،سونے جاگنے ،چلنے پھرنے کاہی نام ہے تویہ زندگی جانوروں کوبھی حاصل ہے۔ یہ انسانی حیات نہیں ہے ۔ انسان کی اصل زندگی عقل سے کام لینا ،اعلیٰ صلاحیتوں کوبیدار کرنا، تقویٰ ایثار ،فداکاری ،خداکی اطاعت، نفس پر قابورکھنا، اور اخلاقی خصلتیں حاصل کرناہے۔&&(تفسیر نمونہ)&&[[دل مردہ دل نہیں ہے اس زندہ کر دوبارہ ۔کہ یہی ہے امتوں کے مرض کہن کاچارہ۔]]&&(اقبال)&&بندگی حق کی دلا دیتی ہے انسان کونجات۔ان تواہم سے جودھڑکن میں بسے رہتے ہیں جز خدا کی بھی انساں کابھی خواہ نہیں ۔اس کے احکام سے وابستہ ہے انسان کی نجات۔]]&&(حامد حسین کاظمی)&&!!حقیقی زندگی حاصل کرنے کاطریقہ:ـ{{حضرت امام علی ابن ابی طالب نے فرمایا:(۱)قرآن کے مطالب پرغوروفکر کرو، کیونکہ اس میں دلوں کوزندگی بخشنے والی بہار ہے۔ &&( نہج البلاغہ، خطبہ ۱۱۰)&&(۲)}}عقل سے کام لینا دل کی زندگی ہے۔ حکمت اور عقل سے کام لینا مردہ دلوں کوزندہ کردیاکرتاہے۔&&(نہج البلاغۃ خطبہ۱۳۳) && نیزفرمایا: بدن کی بیماری سے دل کی بیماری بدتر ہے۔&&(نہج البلاغۃ کلمات قصار ۲۷۷)&&(۳)!!برے کاموں سے بچنا اور خداکے مقررکیے ہوئے فرائض کوادا کرناحقیقی زندگی ہے۔ {{حضرت امام علی ابن ابی طالب نے فرمایا: جس میں تقویٰ کی روح کم ہوجائے اس کادل مرجاتا ہے۔&&(نہج البلاغۃ کلمات قصار۲۴۹)&&}}{{حضرت امام حسین علیہ السلام ابن امام علی علیہ السلام نے فرمایا:<<طول اتجارب زیادۃ فی العقل والشرف فی التقویٰ والقنوع راحۃ الابدان احبک من نھاک>> یعنی : طولانی تجربے عقل کی زیادتی کا باعث ہیں اور شرف کاانحصار تقویٰ میں ہے اور قناعت سے بدن کی راحت ہے جوتم کومحبوب رکھے گاوہ تم کوبرائی سے روکے گا۔&&(بلاغت الحسین علیہ السلام )&&}}خداوندعالم نے فرمایا:<<’’ اِنَّمَا يَسْتَجِيْبُ الَّذِيْنَ يَسْمَعُوْنَۭ وَالْمَوْتٰى يَبْعَثُہُمُ اللہُ ثُمَّ اِلَيْہِ يُرْجَعُوْنَ۳۶۬ ،،>>&&(سورہ انعام آیت ۳۶پارہ۷)&&@@ صرف ( زندہ لوگ ہی) سننےوالے کان رکھتے ہیں اور ( اے رسولؐ!) تمہار پیغام کوقبول بھی کرتے ہیں رہے مردے توانہیں توخداخودقیامت کے دن اٹھائے گا پھروہ خداکی طرف پلٹ جائیں گے۔@@
