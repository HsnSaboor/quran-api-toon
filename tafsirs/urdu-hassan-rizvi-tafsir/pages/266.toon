tafsir[12]{c,v,t}:
  15,71,آیت نمبر۷۱:فہم جنس پرستی باعث عذاب ہے:امت کی بیٹیاں بھی ہرنبی کیلئے اپنی بیٹیوں ہی کی طرح ہوتی ہیں ۔ اس لئے کہ ہر نبی امت کے باپ کی حیثیت رکھتاہے۔ ظاہرہے کہ حضرت لوطؑ کی مراد اپنی طبعی بیٹیاں توہوہی نہیں سکتیں اس لئے کہ وہ زیادہ سے زیادہ چار مذکور ہوئی ہیں جبکہ دوسری طرف سار اشہر گھر پر دھاوا بول رہاتھا۔ &&(ماجدی)&&حضرت لوطؑ کے فرمانےکامقصد یہ تھاکہ اگرتم کواپنی جنسی تسکین کی خاطر کچھ کرناہی ہے تواس کوجائز طریقے سے تسکین دو۔ حرام کام کیوں کرتے ہو؟ اللہ نے عورتوں کو مردوں کی جنسی تسکین کیلئے پیدافرمایا ہے۔ ( جس سے نسل کی افزائش بھی ہے۔) لڑکوں سے یہ کام لینا جائز نہیں بلکہ غیر فطری ہے۔ &&(روح البیان)&& نتیجے:بعض مفسرین کایہ خیال ہے کہ حضرت لوطؑ نے اپنی قوم کے دولیڈروں کواپنی بیٹیوں سے شادی کی پیش کش فرمائی تھی اور اس پیش کش سے محققین نے یہ نتیجہ نکالاکہ :’’ہر مومن کوبرائی کوروکنے کیلئے ہرممکن امکانی کوشش کرنی چاہیے۔(۲)جنسی تسکین عورتوں کے ذریعے حاصل کرنی چاہیے ،لڑکوں کے ذریعے حاصل کرنا حرام ہے۔ (۳)ہم جنس پرستی اکبرالکبائر گناہوں میں سے ہے۔ &&(بقول حضرت امام علی رضا)&&
  15,72,آیت نمبر۷۲:شاہ عبدالقادر صاحب نے لکھاکہ:’’ خداوندمتعال یہ فرمارہا ہے کہ اے رسول صلی اللہ علیہ و آلہ وسلم !تیری جان کی قسم!قوم لوطؑ اس قدر مست اور دیوانہ ہورہی تھی کہ حضرت لوطؑ کی بات تک سننے کوتیارنہ تھی۔ ‘‘&&(موضح القرآن)&&شاہ ولی اللہ صاحب نے لکھاکہ:’’قصہ کے درمیان اس جملے کاآنا،اصل ہیں مکہ والوں کوتنبیہ کرنا مقصود تھا کہ اے مشرکین مکہ !تمہارابھی وہی حال ہے جوقوم لوط کاتھا۔ (وہ جنسی بدکاری کی مستی ہیں تھے اور تم تکبر کے نشے میں رسول اکرم صلی اللہ علیہ و آلہ وسلم کی بات سننے کوتیارنہیں ہو۔)&&(شاہ ولی اللہ)&&حضور اکرم صلی اللہ علیہ و آلہ وسلم کی فضیلت:حضرت ابن عباس نے فرمایاکہ: ’’خداوندمتعال کوحضور اکرم صلی اللہ علیہ و آلہ وسلم کی جان سے زیادہ کوئی جان عزیز نہیں ہے۔ اسی لئے شاید خداوندمتعال نے سواہماری رسول صلی اللہ علیہ و آلہ وسلم کے کسی کی جان کی قسم نہیں کھائی۔&&(روح البیان)&&!!قسم کھانے کافلسفہ:عرب ادب میں قسم کھانے کاایک مقصد بات کوموکد کرنا بھی ہوتاہے ۔ یعنی : جوبات کہی جارہی ہے وہ بہت اہم ہے۔ (اس لئے یہاں پر حضوراکرم صلی اللہ علیہ و آلہ وسلم کی قسم کھاکر یہ بتایا گیا ہے کہ یہ بات بہت اہم ہے کہ لوط کی قوم والے ہم جنس پرستی میں بدمست ہورہے تھے اور تم لوگ اپنے تکبر کی مستی کی بے راہ روی سے تباہی کے راستے پرجارہے ہو۔ اور حضور صلی اللہ علیہ و آلہ وسلم کی جان کی قسم کھاکریہ بتایا کہ خداوندمتعال کے نزدیک حضور صلی اللہ علیہ و آلہ وسلم کی جان سب جانوں سے زیادہ عزیز ہے) &&(روح البیان)&&
  15,74,آیت نمبر۷۴:’’پکی ہوئی مٹی کے پتھر‘‘ممکن ہے کہ شہاب ثاقب ہوں یاآتش فشاں کی آگ کے پتھرہوں جوزمین سے نکل کراڑے ہوں اور پھران پربارش کی طرح برسے ہوں ۔ممکن ہے کہ سخت تیزآندھی نے ان پریہ پتھرائو کیاہو۔&&(تفہیم)&& موجودہ نشانات بھی اس تباہی کے گواہ ہیں ۔ تورات میں ہے کہ :’’تب خداوندمتعال نے سدوم اور عمورہ ( کے شہروں ) پرگندھک اور آگ آسمان پر سے برسائی۔ اور اس نے ان شہروں بلکہ اس سارے میدان کواور اس کوجوزمین سےاُگا تھا نیست ونابود کردیا۔ (خس کم جہاں پاک) &&(پیدائش ۱۹:۲۴،۲۵)&&<<’’سِجِّيْلٍ‘‘>>بعض نے کہاہے کہ یہ لفظ فارسی سے عربی میں منتقل ہواہے۔ پس سنگ سے <<’’سِجِّيْلٍ‘‘>> بنالیاگیا ۔بعض نے کہا: <<’’سِجِّيْلٍ‘‘>> سے مراد آسمان اول ہے۔ مقصد یہ ہے کہ خداوندمتعال نے ان کے سروں پر ایک بادل بھیج دیاجس سے اولوں کی طرح ان پرپتھروں کی بارش ہوئی۔&&( انوار النجف)&&
  15,75,آیت نمبر۷۵:<<’’مُتَوَسِّمِيْنَ‘‘>>کے معنی ہیں@@ ‘‘بڑے سمجھ دار‘‘@@ اور فراست رکھنے والے ۔یعنی ایسے لوگ جونشانیاں دیکھ کر حقیقت کوپہچان لیتے ہیں ۔ &&(تفسیر صافی ص۲۷۳)&&{{حضرت امام محمد علیہ السلام  سے روایت ہے کہ حضرت علی نے فرمایا:’’ آنحضرت صلی اللہ علیہ و آلہ وسلم متوسم(یعنی حقیقی اور اولین معنی میں صاحب فراست انسان) تھے۔ اور آپ صلی اللہ علیہ و آلہ وسلم کے بعد میں <<متوسم>>ہوں ۔اور میرے بعد ائمہ اہل بیتؑ علیہم السلامجومیری اولاد میں ہوں گے۔ وہ <<متوسم>> ہوں گے ۔}}&&(الکافی۔ تفسیرعیاشی)&&{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:<<اَتَّقُوْافَرِاسَۃُ الْمُؤْمِنِ فَاِنَّہٗ یَیْظُرُبِنُوْرِاللہِیعنی >>:’’مومن کی فہم وفراست سے ڈرو!کیونکہ وہ نور خداوندمتعال کے ذریعہ سے دیکھتا ہے۔‘‘ (اور خداوندمتعال کی توفیق سے بولتاہے)} &&(تفسیر عیاشی ۔تفسیر روح البیان)&&{{حضور اکرم صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’علماء کی فراست سے بچو!کہ اگر کہیں انہوں نے تمہارے جرائم کی گواہی دے دی توپھرتم جہنم میں اوندھے ڈالے جائوگے۔ خداوندمتعال کی قسم ’’فراست ‘‘حقیقت ہے جوخداوندمتعال اپنے خاص بندوں کے دلوں میں ڈالتا ہے۔ یا (چھپے ہوئے حقائق کو) ان کی آنکھوں کے سامنے کردیتا ہے۔ }}&&(الحدیث۔&&(روح البیا)&&<<فَرَاسَۃٌ>> کے معنی : کسی چیز پرظاہری نظرکرکے اس کے باطن کاحال معلوم کرنا۔ &&(المنجد)&&}}خط کامضموں بھانپ لیتے ہیں لفافہ دیکھ کر{{۔
  15,76,آیت نمبر۷۶:مطلب یہ ہے کہ حجاز سے شام اور عراق سے مصرجاتے ہوئے لوط کی قوم کی تباہ حال بستیاں اور ان کے آثار قافلے والے دیکھتے رہتے ہیں ۔ یہ علاقہ بحرلوط (بحیرہ مردارDead Sea) کے مشرق اور جنوب میں واقع ہے اور جغرافیہ والوں کابیان ہے کہ یہاں اس درجہ ویرانی پائی جاتی ہے جس کی مثال دنیاکے کسی دوسرے حصے میں نہیں ملتی &&(تفہیم)&&<<’’اَیْکَۃِ‘‘>>کے معنی @@’’ایسا جنگل جس میں درخت بہت گھنے ہوں ،@@ اور @@’’اَصْحٰبُ الْاَيْكَۃِ‘‘ @@سے مراد حضرت شعیبؑ کی قوم کے لوگ ہیں ۔جوگھنے جنگلوں میں رہتے تھے لیکن انہوں نے حضرت شعیبؑ کوجھٹلایا۔اس لئے ان پراللہ کاعذاب سائبان (چھت) کی شکل میں اترا اور اسی سے وہ سب ہلاک ہوئے۔ &&(تفسیر صافی ص۲۷۳)&& <<’’ایکہ‘‘>> کے بڑے شہرکانام<<’’مَدْیَنْ‘‘>> تھا۔<<’’ایکہ‘‘>> تبوک کاپرانا نام ہے ۔&&(تفہیم)&&
  15,79,آیت نمبر۷۹:’’قوم لوط ‘‘اور >>اصحاب ایکہ<<’’قوم لوط ‘‘اور ’’اصحاب ایکہ‘‘دونوں قوموں کے شہرعام گزرگاہ پرواقع ہیں ۔ جس سے مشرکین مکہ باربار شام جاتے آتے گزرتے تھے۔ مگر یہ لوگ ان تباہیوں کواپنی آنکھوں سے دیکھ کر بھی سبق حاصل نہیں کرتے تھے۔&&(جلالین)&&’’ایکہ‘‘ کے رہنے والے حضرت شعیبؑ کی قوم تھےاور >>مَدْیَنْ<<میں رہتے تھے ان کے شہرکے پاس درختوں کابڑاجنگل تھا۔ &&(موضح القرآن۔ جلالین، تفسیر علی ابن ابراہیم)&&ایک خیال یہ بھی ہے کہ حضرت شعیب دوقوموں کی طرف بھیجے گئے تھے۔ ایک اہل مدین جوآسمانی چیخ سے ہلاک ہوئے اور دوسرے ایکہ کے رہنے والے ،جوآگ کے بگولے سے ہلاک ہوئے۔&&(تفسیر غرض مدین والوں کو صیحہ (چیخ یاگرج)&& اور ’’ایکہ‘‘ والوں کو آگ کے سزا سے ماراگیا۔ ایکہ والوں پر سات دن مسلسل سخت گرم ہواچلتی رہی۔ اس گرمی سے تنگ آگر وہ لوگ گھروں سے نکل کھڑے ہوئے اور جنگل کے درختوں کے نیچے پناہ لی۔اس پرخداوندمتعال نے آگ کی ہوابھیجی جس سے وہ سب کے سب جل کر راکھ ہوگئے۔ (خس کم جہاں پاک)( تبیان ،روح البیان)&&
  15,80,آیت نمبر۸۰:<<’’حِـجْرِ‘‘>>ایک وادی کانام ہے جومدینے اور شام کے درمیان واقع ہے۔ اور << ’’اصحاب حجر’‘>>سے مراد قوم ثمود ہے جواسی وادی میں رہتی تھی۔ اور انہوں نے حضرت صالح علیہ السلام کو جھٹلایاتھا۔&&(تفسیرصافی ۔ص۲۷۳)&&<<’’حِـجْرِ‘‘>>قوم ثمود کامرکزی شہرتھا۔ اس کے کھنڈر مدینہ منورہ کے شمال مغرب میں موجود شہر <<’’العلاء‘‘ >>سے چندمیل کے فاصلے پرواقع ہیں ۔ مدینہ سے تبوک جاتے ہوئے یہ مقام شہراہ عام پرملتا ہے اور قافلے والے اس وادی میں قیام نہیں کرتے۔ کیونکہ حضور اکرم صلی اللہ علیہ و آلہ وسلم نے یہاں قیام کرنے سے منع فرمایاتھا۔ آٹھویں صدی کاسیاح ابن بطوطہ جب یہاں پہنچاتووہ لکھتا ہےکہ:’’یہاں سرخ رنگ کے پہاڑوں میں قوم ثمود کی عمارتیں موجود ہیں ۔انہوں نے چٹانوں کوتراش کر ان کے اندرعمارتیں بنائی تھیں، ان کے نقش ونگار آج بھی ایسے تازہ ہیں جیسے آج ہی بنائے گئے ہوں ، ان کے مکانوں میں آج بھی سڑی گلی انسانی ہڈیاں پڑی ہوئی ملتی ہیں ۔ &&(سفر نامہ ابن بطوطہ)&&غرض<<’’حِـجْرِ‘‘>> والوں سے قوم ثمود مرادہے اور <<’’حِـجْرِ‘‘>>اس جگہ کانام ہے جہاں وہ آباد تھے &&(جلالین)&&اس قوم کے بارے میں کہاجا رہا ہے کہ ’’حجروالوں نے پیغمبروں کوجھٹلایا‘‘ اس سے معلوم ہوتا ہے کہ صرف حضرت صالح علیہ السلام ہی نہیں بلکہ ان کے پاس برابر پیغمبرآتے رہے ہوں گے جن کو وہ جھٹلاتے رہے ہوں گے۔ آخری پیغمبر جن کو انھوں نے جھٹلایا، وہ حضرت صالح تھے۔ یہ بھی ممکن ہے کہ صرف حضرت صالح ہی کو جھٹلایا ہواور خداوندمتعال وندِ عالم نے اس بات کو یوں فرما یا ہوکہ انہوں نے پیغمبروں کو جھٹلایا، کیونکہ تمام پیغمبر ایک ہی پیغام لائے ہیں اور اس لیے ایک پیغمبر کو جھٹلانا تمام پیغمبروں کو جھٹلانے کے مترادف ہوتا ہے۔جناب جابر انصاری سے مروی ہے کہ آنحضرت صلی اللہ علیہ و آلہ وسلم نے جب ہم غزوہ تبوک کے لیے جارہے تھے، اور راہ میں حجر کے مقام سے گزر نے لگے تو فرمایا: ان کافروں کے گھروں سے روتے ہوئے گزرو، اس خطرے سے کہ کہیں تم بھی انکی طرح خداوندمتعال کی سزا میں گرفتار نہ ہوجائے۔ پھر حضور نے اپنی سواری کو تیز کردیا۔ &&(روح البیان)&&نتیجہ :ایسے مقامات کو آباد نہ کیا جائے خالی رکھا جائے ،تاکہ لوگ عبرت حاصل کریں &&(روح ابیان)&&
  15,85,آیت نمبر۸۵:پچھلی آیتوں سے ربط:(۱) یہ بات حضور اکرم کو تسلی دینے کے لیے فرمائی گئی ہے کہ بظاہر باطل کا جو غلبہ تم دیکھ رہے ہو اور جن سخت مشکلات کا تم مقابلہ کررہے ہو، اس سے گھبرائو مت۔ یہ ایک عارضی کیفیت ہے۔ اس لیے کہ زمین وآسمان کا یہ پورا نظام حق پر تعمیر ہواہے نہ کہ باطل پر۔ کائنات کی فطرت حق کے ساتھ مناسبت رکھتی ہے، نہ کہ باطل کے ساتھ لہٰذا یہاں اگر قیام و دوام ہے تو حق کے لیے ہے، نہ کہ باطل کے لیے۔ &&(تفہیم)&&(۲) قوم لوط قوم شعیب، اور قوم صالح کی بداعمالیوں کو بیان کرنے کے فوراً بعد توحید کی حقیقت اس لیے بیان کی جارہی ہے کہ ان قوموں کی تمام خرابیوں کی جڑ عقیدہ توحید کا نہ ہوتا تھا۔ اگر عقیدہ توحید صحیح معنی میں انسان کے دل و دماغ میں اُتر جائے تو پھر خداوندمتعال کی عظمت کا احساس اور خداوندمتعال کے سامنے جوا بدی کا عقیدہ اس کو ہر برائی سے روک دیتا ہے۔ پھر نہ تو وہ جنسی بدکاری، بے حیائی اور بے شرمی کے کام کرتا ہے، اور نہ تجارتی اور معاملاتی بے ایمانی کی جرات کرسکتا ہے، اسی لیے شاید توحید کے ساتھ ساتھ قیامت کے آنے کاذکر فرمایا تاکہ احساس ذمے داری بیدار ہوسکے۔توحید کے بعد قیامت کا ذکر اس لیے بھی فرمایا، تاکہ معلوم ہوسکے کہ یہ دنیا کی دکھ بھری زندگی بے مقصد نہیں ، بے معنی یا عبث نہیں ۔ بلکہ یہ دنیا کی زندگی نہایت اعلیٰ مقاصد اور ہداف رکھتی ہے۔ اس لئے زمین وآسمان کا ہونا ہی بتارہا ہے کہ قیامت آنے والی ہے ،حساب کتاب ضرور ہونا ہے، جزا سزا لازماً ملنی ہے۔ وگرنہ زمین وآسمان کی تخلیق بے مقصد ، فضول اور بے معنی ہوجائے گی۔اصل پیغام:ان عظیم حقیقتوں کو بیان کرنے کے بعد خداوندمتعال اپنے رسول کو حکم دے رہا ہے کہ منکریں حق کے تعصب انکار تکذیب، مخالفت اور بدمعاشیوں سے آپ متاثر نہ ہوں ۔ اپنا دل نہ توڑیں، انھیں معاف کردیں، وہ بھی نہایت خوبصورتی کے ساتھ۔ کیونکہ آپ کے پاس اپنے پیغام کو پہنچانے کی مستحکم دلیلیں موجود ہیں ، جواد پر بیان ہوئیں۔لہٰذاآپ کو سختی کرنے، غصہ فرمانے یا جھنجلانے کی کوئی ضرورت نہیں ہے عقل اور منطق آپ کے ساتھ ہے، مستحکم دلیل اور حجت آپ رکھتے ہیں ۔ پھر اگر یہ جاہل نہیں مانتے تو نہ مانیں۔ آپ ان کی کوئی پرواہ ہی نہ کریں بس ان کو اچھی طرح سے معاف فرمادیں۔ &&(تفسیر نمونہ)&&صفح جمیل:{{حضرت امام علی رضا علیہ اسلام نے فرمایا کہ: (صفح جمیل) یعنی اچھی طرح سے معاف کرنے کے معنی اس طرح معاف کرنا کہ (۱) نہ ان کا موا خدہ فرمائیں اور (۲) نہ انہیں برا بھلا کہیں ۔ <<(اَلْعَفْوَ بِغَیْرِ عَتَابٍ)>> &&(تفسیر نور الثقلین جلد۳)&&‘‘
  15,86,آیت نمبر۸۶:آیت کا پیغام:مطلب یہ ہے کہ خداوندمتعال خالق کی حیثیت سے اپنی ساری مخلوقت پر مکمل کنڑول رکھتا ہے، اور ان کے تمام حالات سے پوری طرح واقف بھی ہے۔ جو کچھ بھی تم ان کی اصلاح کے لیے کام کرہے ہو، اسے خوب اچھی طرح سے جانتا ہے۔ اور جن ہتھکنڈوں کے ذریعہ سے یہ لوگ تمہاری تبلیغ اور اصلاح کے کاموں کو خراب اور ناکام بنانے کی کوششیں کررہے ہیں ، ان کو بھی خوب جانتا ہے ۔ لہذا تمہیں گھبرانے اور بے صبر ہونے کی کوئی ضرورت نہیں ہے وقت آنے پر ٹھیک ٹھیک جزا اور سزا کا فیصلہ سنا دیا جائے گا۔ &&(تفہیم)&&آیت کا حاصل:آیت کا حاصل یہ ہے کہ (۱) ان بدمعاشوں کی شرارتوں کی سزادینا ہم پر چھوڑ دیجیے۔ (۲) پھر دعوت فکردی کہ یہ کائنات کا عظیم نظام جس کے ذرہ ذرہ میں حکمت اور رحمت بھری ہوئی ہے، بے مقصد بھی نہیں ہوسکتا اور از خود بھی پیدا نہیں ہوسکتا۔ کیونکہ ہم دیکھ رہے ہیں کہ ساری کائنات ایک حکیمانہ جچے تلے نظام کے تحت متعین مقصد کی طرف جارہی ہے۔ اور وہ منزل آخرت کی منزل ہے۔ یہاں ہر چیز کو اس ٹیکنیک سے پیدا کیا گیا ہے کہ وہ فنا پذیر ہے اس لیے آخرت یا روز حساب کا آنا صاف دکھائی دے رہا ہے۔ جہاں سب کو اپنے کیے کا حساب دینا ہوگا۔ اس لیے اے رسول صلی اللہ علیہ و آلہ وسلم : آپ ان لوگوں کی بدمعاشیوں پر زیادہ غم نہ فرمائیں، کیونکہ بالآخر ہر شخص کو اپنے کیے کا پورا پورا بدلہ مل جائے گا۔ &&(ماجدی)&&
  15,87,آیت نمبر۸۷:رسول اکرم صلی اللہ علیہ و آلہ وسلم پر خداوندمتعال کااحسان عظیم ــ:ان آیتوں میں جناب رسول خداصلی اللہ علیہ و آلہ وسلم کوتسلی دی گئی ہے کہ دشمنوں کو کثر تعداد اور بے پناہ مادی وسائل سے آپ صلی اللہ علیہ و آلہ وسلم پر یشان نہ ہوں ۔کیونکہ خداوندمتعال نے آپ کو وہ انعامات عطافرمائے ہیں کہ جن کے مقابلے میں کافروں کی تعداداور مال ودولت کوئی حیثیت نہیں رکھتے مثلاً خداوندمتعال نے آپ صلی اللہ علیہ و آلہ وسلم کو سورہ حمد جیسی عظیم سورت اور قرآن عظیم جیسی عظیم کتاب عطافرمائی ہے۔>>سبع مثانی<< سے مراد:’’سورہ حمد کو ‘‘ سبع مثانی ‘‘ اس لئے فرمایاکہ >>’’سبع‘‘<< کے معنی سات کے ہیں اور سورہ حمدمیں سات آیتیں ہیں ۔ اور ’’مثانی‘‘ کے معنی دومرتبہ کے ہیں ۔ سورہ حمد کو >>’’مثانی‘‘<< اس لئے فرمایاکہ یہ سورت رسول اکرم صلی اللہ علیہ و آلہ وسلم پر دومرتبہ نازل ہوئی تھی۔ اور اس لئے بھی فرمایاکہ یہ سورہ دوحصوں پرمشتمل ہے۔ آدھی سورت خداوندمتعال کی حمد وثناء پرمشتمل ہے اور آدھی سورت بندوں سے متعلق ہے۔تیسرے یہ کہ یہ سورۃ ہرنماز میں دومرتبہ پڑھی جاتی ہے۔ &&(تفسیر نمونہ)&&{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے ارشادفرمایاہے کہ: ’’خداوندمتعال وند عالم نے ارشاد فرمایا میں نے نماز ( مراد سورہ حمد) کواپنے اور اپنے بندوں کے درمیان دوحصوں میں تقسیم کردیاہے۔ ایک حصہ مجھ سے متعلق ہے اور دوسراحصہ میرے بندوں سے متعلق ہے۔}} &&(تفسیر مجمع البیان)&&{{امیرالمومنین حضرت علی ابن ابی طالب نے فرمایا: ’’میں نے خود جناب رسول خداصلی اللہ علیہ و آلہ وسلم کو یہ فرماتے ہوئے سناہے کہ: ’’ خدا وندمتعال نے فرمایا: اے محمدؐ!ہم نے تم کو >>’’سبع مثانی‘‘ <<یعنی سورہ فاتحہ عطافرماکرتم پراحسان کیاہے۔ اور سورہ فاتحہ کو پورے قرآن کامدمقابل (برابر )قراردیاہے۔}}نوٹ:ـ یادررہے کہ سورہ حمد میں بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِيْمِ کوملاکر کل سات آیتیں ہیں ۔ &&(تفسیر صافی ص۲۷۲بحوالہ عیون اخبار الرضاؑ)&& (اس سے ثابت ہواکہ<< بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِيْمِ >>ہرسورہ کاجز ہے)&&(مؤلف)&&{{حضرت امام جعفرصادق علیہ السلام  سے اس آیت کے بارے میں پوچھاگیاتوفرمایا: <<’’سبع مثانی ‘‘>> سے مراد سورہ حمد ہے ۔اس میں سات آیتیں ہیں ۔ اور <<’’مثانی‘‘>> (دوبارہ) اس کانام اس لئے ہواکہ یہ ہرنماز میں دونوں رکعتوں میں پڑھی جاتی ہے۔‘‘}}&&(تفسیر عیاشی)&&{{حضرت امام محمد باقر علیہ السلام نے فرمایا کہ: ’’خداوندمتعال وند عالم نے اپنے رسول صلی اللہ علیہ و آلہ وسلم کو مثان (دودفعہ پڑھی جانے والی سورت) عطافرمائی اور ا س کے اصل مصداق ہم (اہل بیتؑ علیہم السلام) ہیں ۔‘‘}}&&(تفسیر قمی وتفسیر عیاشی)&&تشریح:یہ اس لئے کہ سورہ حمد کاحاصل یہ دعا ہے کہ خداوندمتعال یا!’’ہم کوصراط مستقیم کی ہدایت فرماتا رہ۔ (یعنی) ان لوگوں کاراستہ دکھاتارہ جن پرتونے نعمتیں نازل فرمائی ہیں ۔‘‘ اور صاحبان نعمت اولین معنی میں محمد وآل محمد صلی اللہ علیہ و آلہ وسلم ہیں ۔ اس لئے ہرنماز میں ان پر درود پڑھاجاتاہے۔ اس لئے محمد وآل محمد صلی اللہ علیہ و آلہ وسلم سورہ حمد کاحاصل اور ماحصل ہیں ۔ اسی لئے نماز میں محمد صلی اللہ علیہ و آلہ وسلم وآل محمدؑ پردرود پڑھاجاتاہے۔ &&(مؤلف)&&امام شافعی نے فرمایا:’’اے اہل بیت رسول اللہ صلی اللہ علیہ و آلہ وسلم تمہاری فضیلت کیلئے بس یہی بہت کافی ہے کہ :<<مَنْ لَّمْ یُصَلِّ عَلَیْکُمْ لَاصَلٰوۃَ لَہٗ>>۔یعنی: ’’جوتم پردرود نہ پڑھے اس کی نماز نہیں ہوتی ۔‘‘&&(امام شافعی)&& شیخ صدوق نے اس حدیث رسول صلی اللہ علیہ و آلہ وسلم کامطلب یہ لکھاکہ امام محمد علیہ السلام کے فرمانے کا مطلب یہ ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے ہم (آل محمدؐ) کوقرآن کے ساتھ ملایا ہے۔ اور امت کو قرآن اور اہل بیتؑ علیہم السلامدونوں کے ساتھ تمسک رکھنے کاحکم دیاہے۔ (اس لئے سورہ حمدکاحاصل محمد وآل محمد صلی اللہ علیہ و آلہ وسلم ہیں ۔) &&(الخصال ۔صحیح مسلم شریف)&&سورہ فاتحہ کو>>سبع مثانی<< کہنے کی وجوہات:ـ(۱)قرآن مجید کے تمام مضامین اس سور ہ میں مجملاً مذکور ہیں ۔اور پھر دوبارہ پورے قرآن میں ان کی تفصیل بیان کی گئی ہے ۔گویا پہلے پورے قرآن کیلئے سورہ حمد اجمالی خاکہ ہے اور پھرپوراقرآن اس کی تفصیل ہے۔(۲)یہ سورہ دو دفعہ نازل ہوااس لئے اس کو>> مثانی <<کہاگیاہے۔(۳)اس سورے کے دوحصے ہیں ۔ ایک حصہ حمد وثنائے الٰہی پرمشتمل ہے اور دوسراحصہ دعاء ہے۔(۴)اس سورے میں بعض الفاظ کی تکرار ہے جیسے رحمٰن،رحیم وغیرہ۔(۵)تثنیہ کے معنی موڑنے کے بھی ہوتے ہیں ۔ یہ سورہ ہمیں ظالموں ،فاسقوں اور خداوندمتعال کے معذب لوگوں سے موڑدیتا ہے۔ &&(تفسیر انوار النجف)&&خداوندمتعال کی تسلی:{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:’’جس کواللہ کی تسلی سے تسلی حاصل نہ ہو، وہ ہمیشہ دنیاکی حسرتوں ،ارمانوں اور مایوسیوں میں گرفتاررہے گا۔ جوشخص دنیاوی حالات پر غمگین اور ناراض ہوووہ اللہ سے ناراض ہے۔ اور جوشخص مصائب کاشکوہ کرتاپھرتاہے وہ مزید مصائب کانشانہ بنتاہے ۔کیونکہ مصائب پردوسروں سے شکوہ کرنا خداوندمتعال سے ناراض ہونااور خداوندمتعال کی شکایت کرناہے۔ اور میری امت میں جوشخص قرآن پڑھنے کے باوجود جہنم میں داخل ہوگا ،وہ وہی شخص ہوگاجو(۱)اللہ کی آیتوں کامذاق اڑاتاہوگا۔ (۲)امیروں اور رئیسوں کے سامنے کچھ لینے کیلئے جھکے گا،اور ان کی خاطر تواضع کرے گا، اور ان کی خوشامد کرے گا۔ ایساکرنے سے اس کادوتہائی دین جاتارہے گا۔ ‘‘&&(الحدیث ،تفسیر برہان)&&ا}}گرچہ بعض لوگوں نے ان سات آیتوں سے سات بڑی بڑی سورتیں بھی مراد لی ہیں جن میں دو دو سوآیتیں ہیں ۔ جیسے سورہ بقرہ ،آل عمران، نساء، مائدہ ،انعام، اعراف، یونس، انفال اور سورہ توبہ ۔لیکن سلف کی اکثریت اس بات پرمتفق ہے کہ اس سے مراد سورہ فاتحہ ہے۔امام بخاری نے تودو مرفوع روایتوں سے اس بات کوثابت کیاہے کہ حضور اکرم صلی اللہ علیہ و آلہ وسلم نے سبع من المثانی سے مراد سورہ فاتحہ کوبتایاہے۔ &&(صحیح بخاری)&&اس آیت کامقصد مسلمانوں کوان سخت تکلیف دہ حالات میں تسلی دینا ہے جبکہ کفار ہرقسم کی عیش اڑارہے تھے۔ خداوندمتعال مسلمانوں سے فرمایارہے کہ تم دل نہ توڑو۔ ہم نے تم کووہ دولت عطاکی ہے کہ جس کے مقابلے پردنیاکی ساری نعمتیں کچھ حقیقت نہیں رکھتیں ،تمہاری دولت ،علم ،اخلاق اور عرفان قابل رشک ہیں ۔ کافروں کی ساری دولت جووہ حرام طریقوں سے کمارہے ہیں اور حرام ہی پراڑے ہوئے ہیں ، سب فناہونے والی ہے اور ان سب کو خداوندمتعال کی سخت سزاہمیشہ ہمیشہ بھگتنی ہے۔ &&(تفہیم)&&!!نتائج:محققین نے نتیجہ نکالاکہ(۱)قرآن کاایک چھوٹا حصہ بھی قرآن ہے۔ اس لئے کہ خداوندمتعال نے سورہ حمد کوقرآن عظیم کہاہے۔ &&(موضح القرآن)&&مگرزیادہ رجحان یہی ہے کہ ’’قرآن عظیم ‘‘ سے مراد سورہ حمد کے علاوہ پوراقرآن ہے۔&&(تفسیر تبیان)&&(۲)دوسر انتیجہ یہ نکالاکہ: جسے قرآن کی سی عظیم نعمت نصیب ہو ( یعنی جوقرآن پڑھتا، سمجھتا،غور کرتااور اس پر عمل کرنے کی کوشش &&(کرتاہو)&& اور اس کے باوجود وہ یہ سمجھ ےکہ فلاں فلاں کومجھ سے زیادہ عزت ،مقام، اور مال ملاہے ،تووہ بیوقوف ہے ۔کیونکہ وہ عظیم دولت کوحقیر، اور حقیر چیزکوعظیم سمجھ رہاہے۔ &&(روح البیان)&&’’سبع المثانی‘‘ اس میں تین اقوال ہیں (۱)مثانی سے مراد پوراقرآن ہے جس طرح کہ ارشاد ہوا<<كِتٰبًا مُّتَشَابِہًا مَّثَانِيَ>>(۲)اس سے پہلی لمبی سات سورتیں مراد ہیں ۔جن کو سبع طوال بھی کہاجاتاہے۔ (۳)سورہ فاتحہ کاسبع مثانی ہونا۔<<بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِيْمِ>> کے جزو سورۃ ہونے کی دلیل بھی ہے کیونکہ اس کے بغیر آیات فاتحہ کی تعداد سات نہیں بنتی ۔ &&(تفسیر انوار النجف)&&
  15,88,آیت نمبر۸۸:مقصد یہ ہے کہ اے رسولؐ!آپ کافروں اور منکرین حق کی حالت پرافسوس نہ فرمائیں جواپنے خیرخواہ کواپنادشمن سمجھ رہے ہیں ۔اپنی گمراہیوں اور خرابیوں کواپنی خوبیاں اور ہنر سمجھ کوخود کواور اپنی پوری قوم کواس راستے پرلے جارہے ہیں جس کایقینی انجام ابد ی تباہی اور بربادی ہے۔&&(تفہیم)&&رسول اکرم صلی اللہ علیہ و آلہ وسلم سے دنیاکی ان ظاہری عارضی نعمتوں پرشوق کی نظریں بڑھانے کاتصور بھی نہیں ہوسکتا تھا۔ پس صرف اس بات کاامکان تھاکہ آپ اور آپ صلی اللہ علیہ و آلہ وسلم کے سچے ساتھی دشمنان خداوندمتعال کوان نعمتوں میں دیکھ کر کڑھیں اور یہ سوچیں کہ مومنین توتکلیفوں میں ہیں اور یہ بدمعاش عیش اڑارہے ہیں ۔پھریہ سوچیں کہ اگران بدکاروں سے یہ نعمتیں چھین لی جائیں توشاید یہ کمبخت حق کی طرف متوجہ ہوجائیں۔ غرض اس آیت نے ہرقسم کے رنج وغم کودورکردیاہے۔&&(ماجدی)&&آیت کاپیغام:(۱){{جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: جوشخص ان نعمتوں پرنظریں جماکے رکھے گا جوخداوندمتعال نے دوسروں کوعطافرمائی ہیں ، وہ ہمیشہ غمگین رہے ا، اور اس کے دل کی آتش غضب کبھی نہ بجھے گی۔}} &&(الحدیث۔تفسیر صافی)&&(۲)دوسرے یہ کہ اس آیت میں رسول اکرم صلی اللہ علیہ و آلہ وسلم کومومنین سے تواضع اور انکساری سے پیش آنے کاحکم دیاہے۔ یہ اس لئے کہ ہررہبر کیلئے ضروری ہوتاہے کہ وہ اپنے پیروکاروں کی عزت کرے، ان سے محبت اور نرمی سے پیش آئے ۔ اور یہ مقصد تواضع ،انکساری اور خیرخواہی کے بغیر حاصل نہیں ہوتا۔ &&(تفسیر نمونہ)&&]]یہی ہے رخت سفر میر کارواں کیلئے[[۔معلوم ہواکہ ہرانسان کی عزت کرنادین کی اولین تعلیم ہے۔اصل مذہب احترام آدمی است۔اصل دین یہی ہے کہ خداوندمتعال کے بعدانسان کااحترام کیاجائے۔ {{امیرالمومنین حضرت علی ابن ابی طالب نے مصرکے گورنر حضرت محمدابن ابوبکر کو خط لکھا:’’تم اپنے بال و پرعوام کیلئے جھکادو۔ ان سے نرمی سے پیش آئو، ہرایک سے مسکراکربات کرو۔ ان کے درمیان مساوات سے پیش آئواور سب کوبرابرکادرجہ اور مقام عطاکرو۔‘‘&&(نہج البلاغہ مکتوب ۔۲۷)&& }} (۱)غرض آیت میں مومنین کی تعظیم کرنے کاحکم خودرسول صلی اللہ علیہ و آلہ وسلم کودیاگیاہے۔ اس سے مومنین کی عظیمت ظاہرہے۔ (۲)آیت کے سیاق وسباق سے یہ نتیجہ نکالاکہ مومنین میں سے جوفقیر ہیں ان کی زیادہ تعظیم کرنی چاہیے۔ حضوراکرم صلی اللہ علیہ و آلہ وسلم نے فرمایا: جوشخص کسی دولتمند کی تعظیم اس کی دولت کی وجہ سے کرتاہے اس کا دوتہائی ایمان وہیں ختم ہوجاتاہے۔ ‘‘&&(الحدیث ۔از تحف العقول)&&
  15,89,آیت نمبر۸۹:یہودیوں اور مشرکوں کاخداوندمتعال کی کتاب کو ٹکڑے ٹکڑے کرنا:یہودیوں نے خداوندمتعال کی کتاب کے مضامین کوتقسیم کردیاتھا۔ کسی ٹکڑے کومانا، اور کسی کا انکار کیا۔مشرکوں نے بھی قرآن کوکئی حصوں میں بانٹا تھا۔ کسی حصے کوشعر کہتے تھے اور کسی حصے کوجادو کہتے تھے،اور کسی حصے کوافتراء کہتے تھے۔ ولید بن مغیرہ نے سولہ آدمیوں کومقرر کیا۔ جولوگوں کوحضرت رسالت مآب صلی اللہ علیہ و آلہ وسلم کی تعلیمات سے برگشتہ کریں ۔پس وہ تقسیم ہوکر مکہ کے گلی کوچوں میں پھیل گئے اور ایام حج میں لوگوں کوحضور اکرم صلی اللہ علیہ و آلہ وسلم سے برگشتہ کرنے کے درپے ہوئے۔ پس خداوندمتعال نے ان کوبدترین عذاب میں گرفتار کیا۔ یہی وہ لوگ تھے جنہوں نے قرآن مجید کے حصے کردیے۔ کسی حصے کو جاد و،کسی کوشعراور کسی کوافتراء کانام دیا۔ &&(تفسیر انوارالنجف)&&تقسیم کرنے کے دوسرے معنی:تقسیم کرنے کے دوسرے معنی یہ بھی ہوسکتے ہیں کہ : <<نُؤْمِنُ بِبَعْضٍ وَّنَكْفُرُ بِبَعْضٍ۰ۙ>> (یعنی) ہم کسی حصے پرایمان لائے (اور اس پرعمل کرتے ہیں ) اور کسی حصے کو نہیں مانتے یااس پرعمل نہیں کرتے ۔&&(سورہ نساء۔۱۵۰۔موضح القرآن)&& تیسرے معنی:شیخ الطائفہ لکھتے ہیں کہ:’’اس آیت سے قوم ثمود کے لوگ مراد ہیں ۔ جن کے لئے قرآن میں دوسری جگہ فرمایاگیا ہے کہ @@’’انہوں نے آپس میں قسمیں کھاکھاکر حضرت صالح کی مخالفت کی اور ان کوقتل کرنے کامنصوبہ بنایا۔@@ &&(تفسیر تبیان)&&اصل میں خداوندمتعال کے کچھ احکام توہمارے مفاد میں ہوتے ہیں ۔لیکن کچھ احکامات ایسے ہوتے ہیں کہ جن پر عمل کرنے سے ہمارامادی یامالی نقصان ہوتاہے۔ اب جوسچے مومن ہوتے ہیں وہ تودونوں قسم کے احکام کی اطاعت کرتے ہیں ۔ مگر مفاد پرست قسم کے لوگ صرف ان احکام کوقبول کرتے ہیں جن سے ان کوفائدہ ہوتاہے۔ اور ان احکام کورد کردیتےہیں جس سےان کونقصان ہوتاہے۔ خاص طور پر وہ لوگ جن کے دلوں میں بیماری ہوتی ہے وہ یہی چاہتے ہیں کہ دین خداوندمتعال کواپنے مفاد کیلئے استعمال کریں۔رند کے رند رہے ہاتھ سے جنت نہ گئی۔اس لئے وہ دین خداوندمتعال کاصرف وہی حصہ مانتے ہیں جس میں ان کافائدہ ہوتاہے۔ بلکہ بعض دفعہ توایک ہی آیت کے ایک حصےکومانتے ہیں اور دوسرے حصے کورد کردیتے ہیں اور پھرکہتے ہیں <<نُؤْمِنُ بِبَعْضٍ وَّنَكْفُرُ بِبَعْضٍ>>۰ۙ &&(تفسیر نمونہ)&&[[خود بدلتے نہیں قرآن کوبدل دیتے ہیں ۔ہوئے کس درجہ فقیہان حرم بے توفیق۔]]&&(اقبال)&&
