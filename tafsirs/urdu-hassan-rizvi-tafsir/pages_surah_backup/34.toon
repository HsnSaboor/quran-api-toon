  34,1,آیت نمبر۱:حمدکالفظ:خداوند عالم کاشروع میں یہ فرمانا کہ : تمام <<حمد >> اس اللہ کےلیے ہے، توحمد کا لفظ عربی میں (۱) تعریف کےلیے بھی استعمال ہوتاہے۔ اور (۲) شکرادا کرنے کےلیے بھی استعمال ہوتاہے۔ یہاں دونوں معنی مراد ہیں۔&&(مفردات لقرآن امام راغب)&& <<الحمد للہ>>:اچھے اور اختیاری فعل پر کسی کی تعریف کرنا تعظیم وتکریم کےطریقے سے حمد کہلاتاہے۔ اور اگر اختیار کی قید دور کی جائے۔ یعنی صرف کسی کی خوبی بیان کی جائے خواہ وہ خوبی اس میں اختیاری ہویا اضطراری ، تواس کو <<مدح >> کہاجاتاہے جس طرح موتی کی عمدگی بیان کرنا اس کی مدح ہے نہ کہ حمداور حمد میں ضروری نہیں کہ زبان سے ہی کی جائے بلکہ ہروہ طرز عمل جو کسی محسن کی تعظیم وتکریم پر دلالت کرے حمد کا بھی فرد ہوتاہے۔حمد کے بلند مراتب وہ ہیں جو عبادت کے موضوع میں داخل ہیں اور ان کا حقدار سوائے پروردگار عالم کے اور کوئی نہیں ہوسکتا، اور ان میں کسی کوپروردگار عالم ،اللہ ، کا شریک بنانا کفر ہے۔ اس مقام پر علامہ طبرسی فرماتے ہیں کہ قولوا فعل محذوف ہے یعنی اے اہل اسلام تم کہدو۔ &&(تفسیر انوار النجف)&& اور قرآن مجید کے جن سوروں کو الحمد سے شروع کیا گیا ہے۔ وہ پانچ ہیں : (۱) سورۃ الفاتحۃ (۲) سورۃ الانعام (۳) سورۃ الکہف (۴) سبا (۵) فاطر && (تفسیر انوار النجف)&& {{جناب رسول خدا صلی اللہ علیہ و آلہ و سلم نے فرمایا؛ <<من لم یشکرالناس لم یشکراللہ >> یعنی : @@جو شخص لوگوں کا شکریہ ادا نہیں کرتا، وہ اللہ کاشکر بھی ادا نہیں کرتا‘‘۔@@ && (الحدیث)&& }} خدانے فرمایا: خداشکریہ ادا کرو اور اپنے والدین کا شکریہ بھی ادا کرو‘‘۔ &&(القرآن)&&
  34,2,آیت نمبر۲:خداوند عالم کا فرمانا کہ: جو زمین کے اندرجاتاہے:‘‘ سے مراد بارش کا (۱)پانی، (۲)مردے بھی زمین میں دفن ہوتے ہیں۔ (۳) خزانے بھی جو زمین کے اندر دفن ہیں۔ اور خداکا فرمانا: جو زمین سے نکلتا ہے ‘‘۔ اس مراد پانی (۲)دھاتیں (۳) نباتات ہیں۔ اور خداکا فرمانا:جوآسمان سے اترتاہے ‘‘۔ اس سے مراد (۱)بارش کا پانی (۲) فرشتے (۳) رزق (۴) لباس <<(قدانزلنا علیکم لباساً)>> (”اعراف آیت جوآسمان میں چڑھتاہے‘‘ ) اس سے مراد (۱) لوگوں کے نیک اعمال (۲) دعائیں (۳) فرشتے ہیں۔ &&(تفسیر صافی ص۱۱۴ ، تفسیر انوار النجف)&& خدا اس کو بھی جانتا ہے جو زمین میں داخل ہوتاہے۔ مثلاً برقی لہریں ، مختلف گیسیں ، ہواوں کے ذرات۔ آخرمیں خدا کا خود کو غفور و رحیم فرمانا، شاید اس لیے ہے کہ جولوگ خدا کی ان نعمتوں کا شکریہ ادا کرتے ہیں ، خدا کی و رحمت ان کے شامل ہوجاتی ہے۔ اور جو لوگ گناہ کرکے شرمندہ ہوجاتے ہیں ، خدا کی معافیاں ان کو اپنے دامن میں سمیٹ لیتی ہیں۔&& (تفسیر نمونہ)&&
  34,3,آیت نمبر۳:{{فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام جعفر صادق علیہ السلام نے فرمایا کہ : جناب رسول خدا صلی اللہ علیہ و آلہ وسلم ارشاد فرمایاکہ:اول اول جب اللہ نے قلم کو پیدا فرمایا تواس کو حکم دیا کہ:لکھ : پس جو کچھ ہوچکا تھا، اور جو کچھ قیامت تک ہونے والا تھا قلم نے سب کچھ لکھ دیا۔&& (تفسیر صافی ۴۱۲ تفسیر قمی)&& &&(روح المعانی ، تفسیر انوار النجف)&& }} منکروں کا یہ کہنا کہ : کیابات ہے قیامت ہم پر نہیں آرہی ہے‘‘۔ طنزاً ہوا کرتاتھا اصل میں کافر و منکر لوگ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کوکستے تھے کہ یہ پیغمبر صلی اللہ علیہ و آلہ وسلم صاحب جو قیامت ٹوٹنے کی جھوٹی خبریں سنار ہے ہیں ، وہ آتے آتے کہاں رہ گئی؟ ہم نے کئی مرتبہ اس کو جھٹلایا ہے، اتنی گستاخیاں کی ہیں ، اس قدر جملے ، فقرے کسے ہیں ، مگر قیامت ہے کہ کسی طرح نہیں آتی۔ (تویہ سب ڈھکوسلے ہیں۔ ہر چند کہیں کہ ہے، نہیں ہے۔پھر جناب خدا صلی اللہ علیہ و آلہ وسلم سے کہا جارہا ہے کہ تم اس خداکی قسم کھاو جو ہر غیب کو جانتا ہے کہ قیامت ضرور آئے گی، مگر اس کے آنے کے وقت کو وہی عالم الغیب اللہ جانتاہے اور کوئی نہیں جانتا۔&&(تفہیم القرآن)&& اور آخرمیں خداوند عالم کا فرمانا کہ: ذرہ ذرہ کا علم اللہ کو ہے‘‘۔ یہ بتارہا ہے کہ جب انسان ذرےذرےہوکر منتشرہوجائیں گے اور مٹی میں مل کرمٹی بن جائیں گے، مگر پھر بھی خداکوان کا علم ہوگا کہ وہ ذرے کہاں کہاں ہیں۔ اس لیے وہ خدا ان ذروں کو پھرا نہی جسموں میں لوٹا کر دوبارہ زندہ کرکے کھڑا کردے گا۔ کیوں کہ خدا کو ہر چیز کا علم ہے کہ وہ کہاں ہے؟ (اور مکمل قدرت بھی حاصل ہے) اس لیے خدا کو انسان کو دوبارہ پیدا کرنے میں اور اس کے اجزاء سمٹنے میں کوئی وقت نہ ہوگی‘‘۔ && (تفسیر کبیر)&& <<’’قل بلیٰ‘‘>> @@(کہہ د وہاں )@@ کلام منفی کے جواب میں ایجاب کےلیے بلٰی آیا کرتاہے۔جس طرح << ’’ الست بربکم‘‘>> @@ (کیا میں تمہارا رب نہیں ہوں )@@ جواب میں ارواح نے کہا: بلیٰ : یعنی ہاں آپ ہمارا رب ہیں۔ اس مقام پر کفار کی جانب سے انکارقیامت کے جواب میں بلیٰ اثبات کےلیے ہے۔ یعنی کافروں نے کہا کہ قیامت نہیں آئے گی۔ تو پیغمبر صلی اللہ علیہ و آلہ وسلم کو حکم دیا گیا کہ ان کے جواب میں کہدو‘‘ ہاں ضرور آئے گی، اور قسم کھاکر کہو کہ ضرور آئے گی۔ &&(تفسیر انوار النجف)&&
  34,4,آیت نمبر۴:خداوند کریم نے آیت میں مغفرت کو پہلے بیان فرمایا اور رزق کریم کو بعد میں شاید اس لئے ذکر کیاہےکہ مومنین کو سب سے زیادہ ضرورت خدا سے معافیوں کی ہوتی ہے۔ اس لیے مغفرت کا ذکر فرما کران کو مطمئن فرمادیا دوسری وجہ یہ ہے کہ جب تک انسان اپنے گناہوں سے پاک نہ ہوجائے وہ عزت والے رزق کا مستحق بھی نہیں ہوگا۔ رزق کریم کے معنی ایسی روزی کے ہوتے ہیں جو قیمتی ہو۔ اس میں خدا کی تمام نعمتیں اور نعامات شامل ہیں۔ &&(تفسیر نمونہ)&& لیکن رزق کریم سے مراد خداکی ہرنعمت ہے۔ اس لئے کہ رزق کریم وسیع معنی رکھتاہے۔ &&(مفردات القرآن)&& اس آیت میں اللہ نے قیام قیامت کی غرض کو بیان فرمایا ہے کہ جزاء وسزا کےلیے اس دن کا لانا ضروری ہے، تاکہ (قیامت کی تکذیب اور مذاق اڑانے والوں کی آنکھیں کھل جائیں) اور تاکہ جو لوگ نیکی و اچھائی سے زندگی گذار کرگئے اور دنیا میں تنگی وعسرت، اور مشکلات سے دوچاررہےان کو نیکیوں کا نیک بدلہ دیاجائے گا اور جو لوگ دنیا میں بدکاری ، فحاشی، ظلم واستبداد کے ذریعہ کمزوروں کےلیے پریشانی کا باعث بنے اور احکامات خداوندی کو پامال کرتے رہے، ان کو اس دن برائیوں کے بدلے سخت سزادی جائے۔&&(تفسیر انوار النجف)&& ’’رزق کریم‘‘کا تعلق مومنوں سے ہے۔ اس لیے رزق کے ساتھ کریم کی صفت لگائی کہ ان کا رزق نفیس وعمدہ ہوگا۔&&( انوار النجف)&&
  34,5,آیت نمبر۵:خداکی بدترین سزا ایسے لوگوں کےلیے ہے جو خداکی آیتوں کو جھٹلانے کی کوششیں کرتے رہتے ہیں۔&&(روح بقول ابن زید)&& <<’’سعوا‘‘ >> <<”سعی‘‘ >> کے مادہ سے ہے جس کے معنی ہر قسم کی کوشش کرنا ہوتاہے۔ مگر یہاں مراد خداکی آتیوں کو جھوٹا قراردینا ، انکار کردینا اور لوگوں کو خدا کی اطاعت سے روکنے کی کوششیں کرنا۔&&(تفسیر نمونہ)&& <<’’معجزین‘‘>> <<” معاجزہ “>> کے معنی عاجز کردینے کے ہوتے ہیں۔ یہاں مطلب یہ ہے کہ خدا کی سزا سے بھاگ کر کوئی بچ نہیں سکتا۔ یعنی خدا کو کوئی شخص بدمعاشیوں کی سزادینے میں عاجز نہیں کرسکتا۔ &&(تفسیر کبیر، مفردات القرآن)&&
  34,6,آیت نمبر ٦ : اور جنہیں علم عطا ہوا ہے وہ (قرآن) کو خوب جانتے ہیں جو تمہارے پالنے والے مالک کی طرف سے تم پر اتارا گیا کہ وہ سراسر حقیقت ہے ،اور وہ اس خدا کا راستہ دکھاتا ہے۔جو صاحب عزت ،زبردست طاقت والا بھی ہے اور <<حمید>> تمام تعریفوں کا مستحق بھی ہے۔
  34,7,آیت ۷ : آیت کی تشریح : << ”اذامزقتم‘‘ >> @@(جب تم پوری طرح ریزہ ریزہ ہوجاوگے) @@ یعنی قیامت کا انکار کرتے ہوئے کافر لوگ ایک دوسرےسے از راہ استعجاب کہتے ہیں کہ ہم تم کو ایسے شخص کی نشاندہی کرتے ہیں جو کہتا پھرتا ہے کہ ذرہ ذرہ ہوجانے کے بعد پھرنئے سرے سے تم زندہ کیے جاوگے ‘‘۔ آنحضرت صلی اللہ علیہ و آلہ وسلم کے اعلان قیامت کو وہ لوگ مذاقاً ایک دوسرے کے سامنے دہراتے رہے اور اپنے طور پر اس قول کا پس منظر یہ بیان کرتے تھے کہ یا تو (معاذ اللہ ) اللہ پر صریح جھوٹ کا افتراء ہے اور ریا دیوانگی کا مظاہرہ ہے۔خداوند کریم نے ان کے اس بیان کی پر زور تردید کرتے ہوئے فرمایا کہ : میرے رسول صلی اللہ علیہ و آلہ وسلم کا یہ اعلان نہ افتراء ہے اور نہ دیوانہ پن ہے بلکہ یقیناً سچ ہے البتہ جو لوگ قیامت کے انکار پر مصر ہیں وہ دنیا میں واضح گمراہی میں ہیں۔ وہ قیامت کے دن سخت عذاب میں ڈالے جائیں گے۔&&(تفسیر انوار النجف)&&
  34,8,آیت نمبر ٨: تو کیا یہ اللہ پر جھوٹی تہمت لگاتا ہے ؟ یا یہ بلکل ہی دیوانہ ہوگیا ہے۔(ایسا نہیں ہے ) بلکہ (حقیقتًا) وہ آخرت کو ہی نہیں مانتے۔وہ خدا کے عذاب اور سخت گمراہی میں بہت ہی دور نکل چکے ہیں۔
  34,9,آیت۹ : آیت کی تشریح: اس آیت میں تین باتیں بتلائی گئی ہیں۔(۱) تم نے اس کائنات کو آنکھیں کھول کر دیکھا ہوتا تو تم آسانی سے سمجھ سکتے تھے کہ یہ تخلیقات کھلونا یا بیکار چیزیں نہیں ہیں یہ نظام اتفاقاً از خود نہیں بن سکتا۔ بلکہ یہ کمالِ قدرت و حکمت کے ساتھ کسی قادرِ مطلق اور حکیم و دانا کا بنایا ہوا ہے۔(۲) جو شخص بھی اس کائنات کو بغور دیکھے گا وہ آسانی سے سمجھ سکتا ہے کہ قیامت کا آنا کچھ مشکل یا عجیب نہیں۔ اس لئے کہ زمین اور آسمان کا نظام صرف کشش پر قائم ہے اس میں ذرا سا الٹ پھیرا سے فنا کر سکتاہے (۳) یہ کہ جو یہ دنیا بنا سکتا ہے ‘ وہ دوسری دنیا پھر دوبارہ بھی بنا سکتا ہے۔ اگر وہ دوسری دنیا نہیں بنا سکتا تو پھر اس نے یہ پہلی دنیا کیسے بنا لی؟غرض یہ سمجھانا مقصود ہے کہ تم ہر طرف سے خدا کی خدائی میں گھرے ہوئے ہو۔ جہاں بھی جاؤ گے اسی کی خدائی ہوگی۔وہ خدا اس قدر قادر ہے کہ جب چاہے تمہارے پیروں کے نیچے سے تم پر کوئی بلالے آئے ‘ اور جب چاہے تمہارے سروں سے کوئی بلا لا کر توڑ دے۔ خود تمہاری اپنی زمین کے نیچے کیسی کیسی بلائیں اور زلزلے دبے بیٹھےہیں جو ذرا سراٹھائیں تو تمہارا تیا پانچا ہو جائے۔ اسی طرح تمہارے سروں پر جو آسمان ہے اس میں کیسی کیسی بجلیاں ‘ بلائیں ‘ طوفان اور بارشیں ہیں جب خدا چاہےتم پر بجلیاں گرادے ‘ پتھروں اور آگ کی بارشیں برسادے۔(اس لئے تم کو خدا کی سزا اور قدرت سے ہر وقت ڈرے سہمے رہنا چاہئے‘ تاکہ تم گناہوں سے بچ سکو) &&(تفہیم القرآن)&& [[دل بینا بھی کر خدا سے طلب،آنکھ کا نور ، دل کا نور نہیں۔]] (اقبال)
  34,10,آیت نمبر۱۰:معلوم ہواکہ اللہ کی نعمتوں سے لوگوں کو فائدے پہنچانا اور نیک کام کرتے رہنا ہی ان نعمتوں کاشکرانہ (شکریہ اداکرنا) ہے۔اللہ کا پورا پورا شکر ادا کرنا یہ ہےکہ:}}جب اللہ تعالیٰ نے اپنے کسی بندے کوکوئی نعمت عطا فرمائی وہ نعمت چھوٹی ہویا بڑی، اگروہ بندہ یہ کہدے :<< ” الحمد للہ ‘‘>> تواس نے اس نعمت کا پورا پورا شکرادا کردیا &&(اصول کافی ازامام جعفر صادق علیہ السلام )&&{{ آیت ۱۰ کی تشریح:{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمدباقر علیہ السلام سے روایت ہے کہ : ’’ حضرت داود علیہ السلام جب جنگلوں سے گذرتے تھے اور زبور پڑھتے تھے توپہاڑ، پرندے ، وحشی جانور تک ان کی آوازسن کرتسبیح پڑھنے لگتے تھے۔اور خداوند قدیر نے لوہے کو حضرت داود علیہ السلام کے ہاتھوں میں اس قدرنرم کردیا (مثل موم کے) کہ وہ لوہے سے جوچاہتے تھے بنالیتے تھے‘‘۔&&(تفسیر صافی ۴۱۲، تفسیر قمی)&& یہاں پہاڑوں کا تسبیح پڑھنے کا ذکر نہ کیا جاتا۔ اور نہ حضرت داود علیہ السلام کی صدائے بازگشت مراد ہوسکتی ہے۔ وہ توسب کےلیے ہوتی ہے۔ اصل میں یہ وہی تسبیح ہے جیسی تسبیح جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کے ہاتھوں پر سنگریزوں نے پڑھی تھی۔&&(تفسیر کبیرامام رازی ، فصل الخطاب)&& }} خداوند عالم نے حضرت داود علیہ السلام پر بڑا فضل فرمایا کہ وہ بیت اللحم میں رہتے تھے یہودا قبیلے کے معمولی جوان تھے۔ ایک جنگ میں جالوت جیسے بڑے زبردست پہلوان کو قتل کرکے یکایک بنی اسرائیل کے ہیرو بن گئے۔ پھر طالوت کے مرنے کے بعد جبرون (موجودہ الخلیل)کے بادشادہ بن گئے پھرتم بنی اسرائیل کے قبیلوں نے مل کران کو اپنا بادشاہ مان لیا پھر یروشلم کو فتح کرکے انہوں نے اسے اسرائیل کا پایہ تخت بنالیا۔ اس طرح ان کی قیادت میں دنیا میں پہلی مرتبہ ایک خدا پرست سلطنت وجود میں آئی جو خلیج عقبہ سے دریائے فرات کے کناروں تک پھیلی ہوئی تھی۔ اس پر مزید یہ کہ خدانے حضرت داود علیہ السلام کو علم ، حکمت ، عدل وانصاف ، خدا پرستی اور خوف خدا کی زبردست توفیق عطا فرمائی۔&&(تفہیم القرآن)&& !!حضرت داود کا واقعہ :{{فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام جعفر صادق علیہ السلام سے منقول ہے کہ : بنی اسرائیل کے نبی علیہ السلام کو یہ وحی ہوئی تھی کہ جالوت (قبطی فرعونی پہلوان ) کو وہ شخص قتل کرے گا جس کے جسم پر حضرت موسیٰ علیہ السلام کی زرہ فٹ ہوگی اور وہ شخص لاوی بن یعقوب علیہ السلام کی اولاد سے ہے جس کا نام داود علیہ السلام ہے جو دنبیاں چراتاہے اور اس کے باپ کانام ایشا ہے‘‘۔ ایشا کے دس فرزند تھے اور داود علیہ السلام سب سے چھوٹے تھے۔ چنانچہ طالوت نے (جن کو نبی خدا حضرت اشمویل علیہ السلام نے بحکم خدا بادشاہ نامزدکیا تھا ) ایشا کے تمام بیٹوں کو طلب کیا۔ تو حضرت موسیٰ علیہ السلام کی زرہ سب بیٹوں کو باری باری پہنائی گئی۔ صرف داود کے جسم پر فٹ آگئی، لہٰذا طالوت نے ان کواس آزمائش کے بعد جو خداکی طرف سے تھی، داود علیہ السلام کو لشکر کا سردار بناکر جالوت کے مقابلے پر بھیجا۔ داود علیہ السلام جب اپنی جگہ سے چلے تھے توراستے میں تین پتھر بقدرت خداگویا ہوئے اور داود علیہ السلام سے کہا کہ ہمیں اُٹھا کراپنے تھیلے میں رکھ لو، ہم تمہارے کام آئیں گے۔ انہوں نے ان پتھروں کو خداوندی مدد سمجھ کر اُٹھا لیاتھا۔ اب جبکہ وہ جالوت کے مقابلے پر چلے تواپنی غلیل میں ایک پتھر کو رکھ کرجالوت کے شکر کے میمنہ (دائیں طرف) پھینکا دوسرا پتھر میسرہ (بائیں طرف) پھینکا۔ دونوں طرف کےلشکری جالوت کو چھوڑ کربھاگ کھڑے ہوئے۔پھرداود علیہ السلام نے تیسرا پتھر اپنی غلیل یاگو پھن میں رکھ کر جالوت کی طرف پھینکا۔ وہ پتھر سیدھا جالوت کی پیشانی پرلگا اور پیشانی کو توڑ کردماغ تک جاپہنچا، اور وہ ہاتھی کی پشت سے زمین پر گر کرفی النار ہوا۔اس طرح حضرت داود علیہ السلام کی شجاعت کو بنی اسرائیل نے تسلیم کرلیا۔ اور طالوت کے بعد حضرت داود علیہ السلام کو اپنا بادشاہ مان لیا۔ اہل تفاسیر نے اس قصے کو اسی طرح بیان کیاہے۔ میں نے کئی تفسیروں کے مختلف بیانات کو یک جاکردیاہے۔ &&(ازتفسیر انوار النجف جلد ۳ ص۱۲۴، ۱۲۵)&& && (ملخص، تفسیر کبیر،مجمع البیان)&& }} آیت مجیدہ میں حق سبحانہ نے حضرت داود علیہ السلام پراپنے فضل واحسان کا تذکرہ فرمایا ہے جو نبوت کتاب، اور قوت بیان اور دیگر معجزات کے علاوہ تھا۔ وہ عطیات آپ علیہ السلام کو امتیازی طور پردیے گئے۔حق سبحانہ نے فرمایا کہ ہم نے پہاڑوں کو حکم دیا کہ داود کی تسبیح کے جواب میں تسبیح پڑھیں‘‘۔ چنانچہ یہ بھی بطور معجزہ عطاہوا کہ آپ علیہ السلام کی تسبیح کے جواب میں پہاڑوں سےتسبیح کی صدا بلند ہوتی تھی۔دوسرا معجزہ یہ تھا کہ پرندے بھی آپ علیہ السلام کے ساتھ تسبیح پڑھتے تھے۔ (یہ بھی فضیلت تھی)تیسرا معجزہ یہ تھا کہ لوہے کو نرم کیا۔ جس سے آپ علیہ السلام زرہ بناتے تھے۔ (یہ بھی فضیلت تھی)حضرت داود علیہ السلام کیوں کہ اپنےزمانے کے مشہور بادشاہ تھے لیکن وہ بیت المال سے تنخواہ لیتے تھے جس کو آپ علیہ السلام پسند نہ فرماتے تھے۔ پس خدانے لوہے کو نرم کردیا جس سے آپ علیہ السلام روزانہ ایک زرہ تیار کرلیتے جس کوایک ہزار درہم میں فروخت کردیتے۔ اس طرح آپ علیہ السلام اپنے عیال کے واجب اخراجات نکال کرجو کچھ بچ رہتا، اس کو فقراء میں تقسیم کردیتے تھے۔&&(ملخص ازتفسیر انوار النجف جلد۱۱)&&
  34,11,آیت۱۱ : آیت کی تشریح :۔محققین نے نتیجے نکالے(۱) صناعی، دستکاری ، کاری گری نبوت کے منافی نہیں۔ ہاتھ سے کام کرنا اور محنت کرنا بہترین عبادت ہے۔{{جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:سب سے پاکیز رزق وہی سے جوہاتھ کی محنت سے حاصل ہو‘‘۔ (۲) دوسرا نتیجہ یہ نکالا کہ: خرق عادات ممکن ہے۔(۳) تیسرا نتیجہ یہ نکالا کہ : ہر کام میں اعتدال ، انتظام اور تناسب ضروری ہے۔&&(مرشد تھانوی)&& جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: خداوند عالم نے حضرت داود علیہ السلام پر وحی فرمائی کہ تم ایک اچھے آدمی ہو ،مگر تم بیت المال سے وظیفہ لیتے ہو، یہ سن کرحضرت داود علیہ السلام چالیس دن روتے رہے۔ (اور خداسے اسی مسئلے کے حل کی درخواست کرتے رہے۔ درخواست قبول ہوئی) پس خدا نے لوہے کوان کےلیے نرم کردیا۔ وہ ہرروز ایک زرہ بناکر فروخت کردیتے اور اس سےاپنے متعلقین کا ضروری خرچ پورا کرکے باقی رقم تصدق فرمادیتے تھے۔&&(تفسیر مجمع البیان)&& }}
  34,12,آیت نمبر۱۲:حضرت سلیمان علیہ السلام پراللہ کے احسانات:حضرت سلیمان علیہ السلام نے اللہ سے دعا مانگی تھی کہ : <<رب اغفرلی وھب لی ملکا لاینبغی الا حد من بعدی انک انترالوھاب>> &&(سورۃ ص آیت ۳۴ ،پ۲۳ )&& یعنی : @@پروردگارا مجھے بخش دیجئے ، اور مجھے ایسا ملک عطا فرماٸیے جو میرے بعد کسی کے واسطے شایان نہ ہو۔ اس میں توشک ہی نہیں کہ آپ بہت ہی بخشش والے ہیں ‘‘۔ پروردگار عالم کا یہ احسان صرف حضرت سلیمان علیہ السلام کے ساتھ مختص ہے کہ ان کی دعاکو قبول فرماکرجیسا ملک وہ چاہتے تھے عطافرمایا: اللہ نے حضرت سلیمان علیہ السلام کےلیے ہوا کر مسخرکردیا۔ چنانچہ ان کا تخت (بساط) ہوا کے دوش پر اڑتا تھا اور آپ علیہ السلام کو لشکر سمیت ہوا بارہ گھنٹے میں تیزرو گھوڑے سوار کی دوماہ کی مسافت پر پہنچا دیتی تھی بعض مفسرین نے ذکر کیاہے کہ صبح کے وقت دمشق سے روانہ ہو کر دوپہر کےوقت اصفہان میں آرام فرماتے تھے۔ پھر وہاں سے پرواز کرکے رات کا کابل جاکر ٹھہرتے۔بعض روایت مین جو یہ الفاظ ملتے ہیں کہ پوری روئے زمین پر چار آدمیوں کو حکومت نصیب ہوئی۔(۱) نمردو اور (۲) بخت نصر، یہ دونوں کافر تھے۔ اور (۳) ذوالقرنین علیہ السلام ، (۴) سلیمان علیہ السلام ، یہ دونوں مسلمان تھے۔اس کا مقصد یہ ہے کہ اپنے اپنے دور میں پوری دنیا کی مہذب آبادی ان کے زیر نگین تھی، باقی حکمراں ان کے مقابلے میں جزوی و ذیلی حیثیت رکھتے تھے۔نیز حضرت سلیمان علیہ السلام پر اللہ کا یہ بھی مخصوص احسان تھا کہ ان کےلیے پیتل اور تابنے کو پانی کی طرح جاری کردیا۔ مروی ہے کہ تین دن تک تانبا اور پیتل اپنی کان سے نکل کربہتارہا جس طرح پانی چشمے سے نکل کربہتا ہے۔ اسی لیے اس کو عین (چشمہ ) سے تعبیر کیا گیا۔تیسرا مخصوص احسان وفضل یہ تھا اللہ تعالیٰ نے جنوں کو حضرت سلیمان علیہ السلام کا تابع فرما کردیاکہ وہاں کی فرماں برداری کرتے، اور جو نافرمانی کرتا اس کو آگ کی سزادی جاتی تھی۔ منقول ہے کہ اللہ کی جانب سے ایک فرشتہ معین تھا، جس کے پاس آگ کا تازیانہ تھا۔ پس جنوں میں سے جو بھی ان کی حکم عدولی کرتا، وہ فرشتہ اس کو اس آتشی تازیانے سے مارتاتھا، اور وہ جل کرخاکستر ہوجاتاتھا۔&&(تفسیر انوار النجف) && بعض سرپھروں نے یہ لکھا کہ جن سے مرادلمبے چوڑے مضبوط آدمی۔ یہ کہنا عربی محاروے کے اعتبار سے بالکل غلط ہے &&(تفسیر کبیر امام رازی)&&
  34,13,آیت نمبر۱۳:<<’’محراب‘‘>> کا لفظ <<حرب >> سے بناہے۔ جس کے معنی جنگ کرنا ہوتاہے۔ محراب کے معنی جنگ کرنے کی جگہ۔ کیوں کہ انسان جب خداکی عبادت کرتاہے تو شیطان اور اپنی بری خواہشات دونوں سے بیک وقت جنگ کرتاہے۔ اس لیے عبادت خانوں کو محراب کہتے ہیں۔ &&(مفردات القرآن ، امام راغب)&& دوسرے یہ کہ حرب اس لباس کو بھی کہتے ہیں جو میدان جنگ میں دشمن کو قتل کرکے اس کے جسم سے اتارا جاتاہے۔ کیوں کہ عبادت خانوں میں انسان دنیوی فکروں اور آلودگیوں کو اتار پھینکتاہے اس لیے بھی عبادت خانوں کو محراب کہتے ہیں۔ &&(مفردات القرآن امام راغب)&& مبرد سے منقول ہے کہ محراب اس مکان کو کہا جاتاہے جس پر سیڑھیوں کے ذریعے چڑھا جاتاہے اس جگہ عبادت گاہیں اور عالی شان محلات مراد ہیں۔ &&(تفسیر انوار النجف)&& <<’’تماثیل‘‘ >> یعنی مجسمے‘‘۔ مجسمے بنانا پچھلی شریعتوں میں حرام نہ تھا۔ &&(ابوبکر حصاص)&& یہ معنی بھی لکھے گئے ہیں کہ یہ مجسمے انبیاء کرام علیہم السلام ملائکہ اور نیک لوگوں کےتھے۔&&(تفسیر ماجدی)&& عربی میں تماثیل ’’ (تمثیل کی جمع ہے) ہر اس مصنوعی چیز کو کہتے ہیں جو خدا کی بنائی ہوئی کسی بھی چیز کو مانند ہو۔ خواہ جاندار کی مانند ہویا بے جان چیز کی مانند ہو‘‘ (اس لیے یہ ضروری نہیں ہے۔) &&( لسان العرب)&& کہ حضرت سلیمان علیہ السلام نے جو تماثیل بنوائی تھیں وہ ضرور انسانوں یا حیوانوں کی تصویریں تھیں۔ ممکن ہے پھول پتیوں یا قدرتی مناظر کی تصویریں ہوں جن سے آپ علیہ السلام نے اپنے محل کو آراستہ کیاہو۔&& (تفہیم القرآن)&& بعض مفسرین کا یہ کہنا کہ انہوں نے کچھ پچھلے انبیاء کرام کی تصویریں بنوائی تھیں۔ تویہ بنی اسرائیل کی روایات ہیں ، جو اکثر ہوتی ہیں۔ کیوں کہ حضرت سلیمان علیہ السلام حضرت موسیٰ علیہ السلام کی شریعت کے پیرو تھے اور حضرت موسیٰ علیہ السلام کی شریعت میں جانداروں کی تصویریں بنانا حرام ہیں۔ توراۃ میں ہے کہ : ’’ تواپنے لیے کوئی تراشی ہوئی مورتی نہ بنانا‘‘۔ && (خروج باب ۲۰ آیت ۴)&& تم اپنے لیے بت نہ بنانا ، اور نہ تراشی ہوئی مورت اپنے لیے کھڑی کرنا، اور نہ ملک میں کوئی تنبیہ دار پتھررکھنا کہ اسے سجدہ کرو‘‘۔ &&(احبار باب ۲۶، آیت ۱)&& {{ جناب رسول خدا صلی اللہ علیہ و آلہ و سلم سے ان کی زوجہ جناب ام حبیبہ رضی اللہ عنہا نے حبش کے ایک کنیسہ کا ذکر کیا کہ جس میں تصویریں تھیں۔جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: یہ ان لوگوں کاکام تھا جوصالح انسان کے مرنے کے بعد اس کی تصویریں بنالیا کرتے تھے۔ اور پھراس کی قبر کو سجدے کرتے۔ یہ لوگ قیامت کے دن خدا کے نزدیک سب سے برے لوگ ہوں گے‘‘۔ &&(بخاری کتاب الصلوٰۃ، مسلم کتاب المساجد، نسائی کتاب المساجد)&& }} {{حضرت ابن عباس رضی اللہ عنہ سے روایت ہے کہ : جس شخص نے جاندار کی تصویر بنائی اسے عذاب دیاجائے گا کہ وہ اس میں روح پھونکے۔ مگر وہ اس میں روح نہ پھونک سکے گا‘‘۔ && (بخاری ، ترمذی، نسائی ،مسنداحمد)&& }} {{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے۔ کہ: یہ مجسمے صرف یادگار کے طورپر بنائے گئے تھے۔ برساتوں میں لوگ ان مجسموں کو گھروں کے اندر لاکررکھ دیتے تھے۔ پھر عبادات کے وقت ان مجسموں کو اپنے سامنے رکھنے لگے۔ پھرآنے والی نسلوں نے یہ سمجھا کہ ان مجسموں ہی کی عبادت کرنی چاہیے اس طرح شرک اور بت پرستی کی ابتداءہوئی۔&&(الحدیث)&& }} درختوں کی تصویر بنانا حرام نہیں :علامہ بدر الدین (عظیم سنی عالم) نے لکھاکہ: البتہ جاندار کے سواء کسی دوسری چیز مثلاًدرخت وغیرہ کی تصویر بنانا حرام نہیں۔ یہی رائے امام مالک ، سفیان ثوری امام ابو حنیفہ کی ہے۔ البتہ قاضی عیاض کہتے ہیں کہ بچوں کی گڑیاں مستثنیٰ ہیں ‘‘۔ &&(عمدۃ القاری جلد ۲۲ ، شرح نودی مطبوع مصر جلد ۱ص۴ ۸۱)&& مسجد میں تصاویر کا ہونا جائز نہیں :{{حضرت علی بن امام جعفر صادق علیہ السلام نے اپنے بھائی حضرت امام موسیٰ کا ظم علیہ السلام سے دریافت کیا: جس مسجد میں تصاویر وتماثیل موجودہوں ، اس میں نمازپڑھنا کیا ہے؟ امام علیہ السلام نے فرمایا: تماثیل کے سرتوڑ دو اور تصاویر کے سروں پرکوئی چیزمل کران کا حلیہ بگاڑ دو‘‘۔ &&(بروایت قرب الاسناد، انوار النجف۳۳۳)&& }} پس جس گھرمیں نماز پڑھی جائے اس کو تصاویر مجسموں سے زینت دینا ممنوع ہے۔ اسی طرح طرح حدیث میں ہے کہ مثال بنائے یعنی مجسمہ بنائے وہ اسلام سے خارج ہے۔ اولا تواس کا عطف ہے تجدید قبرپر۔ تجدید قبر مکروہ ہے۔ حدیث یہ ہے کہ @@(جس نے قبر کی تجدید کی یا مثال ایجاد کی وہ اسلام سے خارج ہے) @@ اگراس حدیث سے مجسمہ سازی کی حرمت ثابت کی جائے تو تجدید قبر کے معنی پرانی قبر کونئے سرے سے بنانا نہ ہوگا، بلکہ معنی یہ ہون گے کہ: جو کسی مومن کو قتل کرکے ایک قبر کا نیا اضافہ کرے یا مجسمہ سازی سے کسی بت پرست کےشرک کی تائید کرے تووہ اسلام سے خارج اور کافر ہے۔ اس بنامجسمہ سازی حرام ہوگی جولوگوں کی پرستش کےلیے معرض عمل میں آئے۔ لہٰذا عام مصوری اور مجسمہ سازی حرام نہ ہوگی۔ مسئلہ: اگر نمازی کے مصلے کے سامنے کوئی تصویر یا فوٹویا مجسمہ موجود ہو، خواہ مکان کے اندر نماز پڑھےیاباہر صحن میں ہو ، اس کو ڈھانپ دینا چاہیے، تاکہ بت پرستوں کی عبادت سے مشابہت نہ ہوجائے۔مسئلہـ: فوٹو گرافی کی صنعت فوٹو کھنچوانا، اس کا خریدنا اور گھر میں رکھنا حرام نہیں۔ مسئلہ: عورتوں کےلیے فوٹو کھنچوا کر پھراسے منظرعام پرلانا حرام ہے۔ کیوں کہ یہ پردہ داری کےخلاف ہے۔&& (تفسیر انوار النجف)&& دعوت شکر اور ناشکری کا شکوہ:حضرت داود علیہ السلام اور حضرت سلیمان علیہ السلام پر مخصوص نعمات کے بیان کے بعد آل داود علیہ السلام کو شکر کی دعوت دی اور عام بندوں کی ناشکری کا شکوہ ہے کہ بہت کم آدمیوں کا شیوہ شکر گذاری ہے اور اکثریت ہمیشہ احسان فراموش لوگوں کی ہوا کرتی ہے۔&& (تفسیر انوار النجف)&& {{فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام جعفر صادق علیہ السلام سے دریافت کیا گیا کہ کیا خدا کے شکرادا کرنے کی کوئی حدہے۔ جہاں پہنچ کر خدا انسان کو شاکر قراردے؟ آپ علیہ السلام نے فرمایا : ہاں : عرض کیا: کس طرح؟فرمایا: انسان کو چاہیے کہ خدا کی تمام نعمتوں پرچاہے وہ گھر سے متعلق ہوں یامال سے، سب پر خداکی حمد بجالاتا رہے۔ اور جومال اس کو دیا گیا ہے اس کا حق ادا کرے( یعنی حقدارکواس کا حق ادا کرے)۔&&(اصول کافی جلد۲ باب الشکر)&& نیز فرمایا:اللہ نے حضرت موسیٰ علیہ السلام کو وحی کی: اے موسیٰ علیہ السلام !میرا شکر ادا کرو۔ عرض کی: خداوند! میں آپ کا شکر کیسے ادا کرسکتاہوں ، اس لئے کہ جب بھی میں شکر ادا کرتاہوں توآپ ایک اور نعمت عطا فرمادیتے ہیں ‘‘۔ خداوند عالم نے فرمایا: اے موسیٰ علیہ السلام ! تم نے میرا حق شکرادا کردیا۔ اس لئے کہ تم نے جان لیا کہ میں ہی شکرادا کرنے کی توفیق عطاکرتاہوں۔ اور ہرنعمت میری ہی طرف سے ہے۔ بس یہی حق شکر ہے۔ &&(اصول کافی باب الشکر حدیث۲۷)&& }}
  34,14,آیت نمبر۱۴:حضرت سلیمان علیہ السلام کی موت کی تفصیل:اس واقعے کی تفصیل یہ ہے کہ حضرت سلیمان علیہ السلام اپنی عصا (لاٹھی) پر سہارا کیے کھڑے تھے اور انہوں نے جنوں سے کہا تھا کہ تم کام کرتے رہو میں دیکھ رہا ہوں۔ ادھر خدا کے حکم سے کھڑے ہی کھڑے اس کی روح قبض ہوگئی ، مگر جنات ان کو کھڑا دیکھ کر اپنے اپنے کام کرتے رہے۔ آخر کار دیمک نے ان کی عصا کو کھو کھلا کردیا توعصاٹوٹ گئی اور حضرت سلیمان علیہ السلام کا جسم گر پڑا تب جن سمجھے کہ ہم خواہ مخواہ کام کرتے رہے۔&&(فصل الخطاب)&& !!آیت کے نتائج:محققین نے نتیجہ نکالا کہ : (۱) جن غیب کا علم نہیں رکھتے۔ آیت کا پہلا مطلب یہی ہے کہ خود جنون کو پتہ چل گیا کہ وہ غیب کا علم نہیں رکھتے۔(۲) آیت کے دوسرے معنی یہ بھی ہوسکتے ہیں کہ جو لوگ جنوں کو غیب دان سمجھتے تھے وہ سمجھ گئے کہ جن غیب کا علم نہیں رکھتے۔&&(تفہیم القرآن)&& {{فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام علی رضا علیہ السلام سے منقول ہے کہ ایک دن حضرت سلیمان علیہ السلام نے اپنے اصحاب سے فرمایا کہ اللہ تعالیٰ نے مجھے ایسی حکومت عطافرمائی ہے کہ میرے بعد کسی کو نصیب نہ ہوگی۔ میرے لیے جن ، انس ،پرندے ، وحوش مسخر کردیے۔ مجھے پرندوں کی زبان فہمی کا علم عطافرمایا، اور ہر وہ چیز عطا فرمائی جس کی میں ضرورت محسوس کروں ، باوجود اس کے مجھے ایک دن کے لیے بھی آرام وسکون میسرنہ ہوا۔ میرا ارادہ ہے کہ کل میں اپنے محل کی منزل پر کھڑے ہوکہ اپنے تمام ممالک کا جائزہ لوں ، لہٰذا کسی کو میرے پاس آنے کی اجازت نہ دی جائے۔ حسب الحکم انتظام پرکڑی نگرانی کی گئی اور آپ علیہ السلام دوسرے روز عصا ہاتھ میں لیے محل کی بلند ترین منزل پر پہنچے اور وہاں عصا کے سہارے اپنی مملکت کی وسعت کو دیکھ کر خوش ہورہے تھے کہ اچانک ایک خوش پوش نوجوان نظرایا جو ظاہر افراطً محل کے گوشے سے نکلا تھا۔آپ علیہ السلام نے شاہانہ انداز میں اس سے فرمایا کہ تم کس کی اجازت سےاس محل میں داخل ہوئے؟ اس جوان نے فوراً جواب دیا کہ اس محل کے مالک حقیقی نے مجھے بھیجا ہے۔ پس آپ علیہ السلام سمجھ گئے کہ یہ ملک الموت ہے۔ آپ علیہ السلام نے فرمایا: تم اپناکام کرو، اگرچہ آج کادن میں نے اپنی خوشی کےلیے مقرر کیاتھا لیکن اللہ کو میرے وصال کے علاوہ میری دنیاوی خوشی پسند نہیں ہے۔ پس ملک الموت نے اس حالت میں روح قبض کرلی۔ رعایاان کو زندہ سمجھتی رہی۔ کیوں کہ آپ علیہ السلام کا جسم عصا کے سہارے پر قدرتاً کھڑا رہا۔ چنانچہ جب کافی عرصہ اسی صورت سے گذرگیا تو اعتقادی طور پر لوگوں کے تین گروہ ہوگئے۔ ایک گروہ کہنے لگا کہ حضرت سلیمان علیہ السلام عصا کےسہارے پر اتنی مدت سے کھڑے ہیں ، نہ ان کو تھکان محسوس ہوئی، نہ بھوک نہ پیاس اور نہ نیند نہ آرام کی ضرورت ان کو محسوس ہوئی پس معلوم ہوتاہے کہ ہمارے لائق عبادت معبود یہی ہے۔ دوسرے گروہ نے کہا کہ یہ جادوگرہے اور ہماری نظروں کو فریب دیا گیاہے کہ وہ اتنی مدت سے عصاکے سہارے پر کھڑاہے۔ تیسرا گروہ مومنوں کا تھا۔ انہوں نے کہا کہ وہ اللہ کے عبد اور برحق نبی علیہ السلام ہیں اللہ خود ان کے بدن کی تدبیر کا مالک ہے۔پس جب اللہ نے دیمک کو حکم دیا، اس نے عصا کو کھایا، عصا ٹوٹا اور حضرت سلیمان علیہ السلام کی لاش گری توسب کو پتہ چلا کہ وہ بہت پہلے مرچکے تھے۔ قوم جن اسی دن سے دیمک کے ممنون احسان ہوئے۔ &&(تفسیر انوار النجف)&& }}!!نتائج وتعلیمات:(۱) کیوں کہ حضرت سلیمان علیہ السلام کے بہت کام بڑے عجیب ہوتے تھےاس لیے روح قبض ہونے کے بعد وہ ایک مدت تک اسی طرح عصا کے سہارے پر کھڑے رہے اور لوگ یہی سمجھتے رہے کہ یہ زندہ ہیں اور ہماری نگہبانی کررہے ہیں۔ اس لیے ایک گروہ نے یہ عقیدہ قائم کرلیا کہ ان کی پرستش کرنی چاہیے کیوں کہ وہ نہ سوتے ہیں ، نہ کھاتے ہیں ، نہ کچھ پیتے ہیں۔ مگر جب دیمک نے ان کے عصاکو کھایا، اور حضرت سلیمان علیہ السلام کی لاش بے سہارا ہوکر گری، تب ان کو معلوم ہوا کہ حضرت سلیمان علیہ السلام لائق پرستش نہیں۔ نیز یہ بات بھی معلوم ہوگئی کہ انسان کی طاقت وحکومت کتنی ہی بڑھ جائے مگر اس کی طاقت خدائے واحد کی طاقت کے سامنے بے حقیقت ہے۔ &&(تفسیر نمونہ)&& {{امیر المومنین حضرت امام علی ابن ابی طالب علیہ السلام نے فرمایا: اگرکوئی شخص اس دنیا میں باقی رہ سکتا اور موت کو خودسے دورکرسکتا، تووہ سلیمان علیہ السلام تھے جن کو خدانے نبوت کے ساتھ ساتھ جنوں اور انسانوں وغیرہ پر حکومت بھی عطا کی تھی۔&&(نہج البلاغہ) && }} (۲) اس واقعہ سے پتہ چلاکہ جنوں کو غیب کا علم نہیں ہوتا۔
  34,15,آیت نمبر۱۵:قوم سبا کا واقعہ اور نعمتوں کی بے قدری پر عذاب :مورخین نے لکھا کہ ان باغوں کی وسعت ۲۰۰ مربع میل تھی۔ یہ سارے کا سارا علاقہ درختوں ، پھلوں ، پھولوں ، خوشبووں سے لدابھراتھا سبا کا یہ علاقہ یمن کا حصہ ہے۔ یہ علاقہ خدا کی صناعی اور قدرت کی دلیل تھا۔ &&(بیضادی )&& یہ وہی شہر سبا تھا جس کی ملکہ بلقیس تھیں۔سباابن یشحب یاشیعب بن یعرب بن قحطان بن عابر بن فانح بن ارفخشدبن سام بن حضرت مسکن (حضرت نوح علیہ السلام )۔&&( ازنسب نامہ سادات زیدی اہالیان موضع میمن)&& سباابن یشحب بن یعرب بن قحطان کے دس بیٹے تھے۔ ان میں سے چھ یمن میں آباد ہوئے اور چاربیٹے شام میں یمنیوں کے نام یہ ہیں !!۔ (۱) ازد(۲) کندہ مذحج(۴) اشعروں۔(۵) انمار(۶) حمیر، اور شام میں آبادہونے والوں کے نام یہ ہیں۔(۱) عاملہ (۲) خدام (۳) لخم (۴) غشان۔ &&(تفسیر انوار النجف)&& آیت مجیدہ میں سباسے مراد اولاد سبا ہے جو یمن میں آباد تھی۔ ان کی سکونت صنعا سے تین دن کے سفر کے فاصلے پر تھی اور اس جگہ کانام مآرب تھا۔ قوم سبا اللہ کا بڑاحسان تھا۔ جہاں وہ لوگ آباد تھے ان کے دائیں بائیں جانب میوہ جات کے باغات تھے اور اس میں توحید پروردگار کی عظیم نشانی تھی۔ اور جنتان ‘‘ بدل ہے ایۃ سے اور اس جگہ دوباغ مراد نہیں ، بلکہ ان کی آبادی کے دوطرفہ باغ مراد ہیں۔ اور ان کی تیرہ بستیاں ایک دوسری سے متصل تھیں۔ اور ہرایک بستی میں اللہ تعالیٰ کی طرف سے ان کو ہدایت پر مامور ایک ایک نبی علیہ السلام بھی موجود تھے۔ باغات اور میوہ جات کی کثرت کا یہ عالم تھا کہ اگر کوئی عورت ایک بستی سے دوسری بستی تک خالی ٹوکری سرپر رکھ کر سفر کرتی تو پکے پھلوں کے گرنے کی وجہ سے منزل مقصود تک پہنچے پہنچے اس کی ٹوکری میوہ جات سے لبریز ہوجاتی تھی۔مفسرین نے ذکر کیاہے کہ ان لوگوں پر اللہ کا فضل وکرم یہ بھی تھا کہ ان کی آبادیوں میں مچھر پسو مکھی، بچھواور سانپ وغیرہ کانام ونشان تک نہ تھا۔ حتیٰ کہ اگر کوئی مسافر ان کے ہاں وارد ہوتااور اس کے لباس میں پسو وغیرہ ہوتے تواس آب وہوا کی وجہ سے مرجاتے۔ان لوگوں نے نعمات کی کثرت سے غلط رویہ اختیار کرلیا۔ شکرادا کرنے کے بجائے کفران نعمت پر اتر آئے اور متکبر وسرکش ہوگئے اور انبیاء کی دعوت حق کو تکذیب کے باعث زوال نعمات کے مستحق ہوگئے۔
  34,16,آیت نمبر۱۶:<<’’سیل العرم‘‘>> کے معانی میں چند اقوال ہیں۔(۱) ”عرم‘‘اس وادی کانام تھا جس میں ہرطرف سے بارش کا پانی جمع ہوجاتاتھا۔ (۲) <<عرم>>اس چوہے کانام ہے جس نے اس بند میں سوراخ کیا تھا کہ جس کی وجہ سے طوفانی عذاب آیا۔ (۳) <<عرم>>کے معنی سخت بارش یعنی کثرت سے بارشیں ہوئیں اور پانی کے دباو سے بند ٹوٹ گیا۔ اور عذاب کا باعث ہوا۔ پھر قوم سبا کی آبادیوں کو ویرانوں میں اور پھلدار باغات کو بیریوں ، کیکروں ، خاردار جھاو کے درختوں ، جھاڑیوں کے جنگلات میں بدل کررکھ دیا۔ ناشکری کا یہی انجام ہوا کرتاہے۔ &&(تفسیر انوار النجف)&& (۴) <<عرم>>کا لفظ عرامہ ، بروزن علامہ ہے۔ ا س کے معنی سختی بداخلاقی کے ہوتے ہیں۔<<عرم>>کے معنی جنگلی چوہے‘‘۔ &&(لسان العرب)&& لیکن مناسب ترین معنی سخت سیلاب کے ہیں۔&& (تفسیر علی بن ابراہیم )&& <<”خمط“>> کڑوی گھاس کو کہتے ہیں۔ اور <<اثل>> کے معنی جھاڑ کے بیکار درختوں کو کہتے ہیں۔ &&(مفردات القرآن)&& >>خمط<< کے معنی پیلو‘‘ اور خاردار درخت بھی کہے گئے ہیں۔ اور اثل کیکر یا دوسرا کوئی خاردار درخت بھی کہا گیا ہے۔&& (لغات نعمانی)&&
  34,17,آیت نمبر۱۷:انبیاء علیہ السلام کی نافرمانیوں کی سزا:پس ان لوگوں نے ابنیاء علیہم السلام کی نافرمانی کی، اور بدکاریاں شروع کریں۔ اور خدائی احکامات کے سامنے سرکشی کا مظاہر ہ کیا اور اپنی حرکتوں سے باز نہ آئے تواللہ نے اس بند کوتوڑنے کےلیے (جو حضرت سلیمان علیہ السلام کے حکم سے پانی کوروکنے کےلیے جنوں نے باندھا تھا) گھونس کو جوایک بڑا چوہا ہوتا، مسلط کردیا۔ اس گھونس نے بند کے پتھروں کو اکھاڑ پھینکا، یہاں تک کہ سارے کاسارا بند خراب ہوگیا، اور ایک بہت بڑاسیلاب آگیا۔ اس نے ان کو ڈبودیا اور علاقہ ویران ہوگیا۔ &&(تفسیر صافی ص ۴۱۳بحوالہ تفسیر قمی)&& !!برکت والی بستیوں سے مراد:{{ فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام مہدی علیہ السلام نے فرمایا :(اولین معنی میں )!خداکی قسم !ہم (محمدوآل محمد صلی اللہ علیہ و آلہ وسلم ) ہی وہ بستیاں ہیں جن میں اللہ نے اپنی برکت کوقراردیا ہے۔ اور ظاہری طور پر وہ لوگ مراد ہیں جو ہمارے ماننے والے ہیں۔&& (اکمال الدین اتمام النعمہ)&& }}!!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام زین العابدین علیہ السلام سے رویت ہے کہ : ’’ یہاں بستیوں سے مراد <<’’رجال ‘‘ >> ہیں۔ یعنی لوگ’’ لیے گئے ہیں۔ پھرامام علیہ السلام نے قرآن مجید کی وہ ساری آتیں پڑھیں جہاں بستی سے مراد لوگ لیے گئےہیں۔امام علیہ السلام سے دریافت کیا گیا : یہاں >>رجال<< سے مراد کون سے رجال ہیں ‘‘؟ آپ علیہ السلام نے فرمایا: وہ ہم (محمدوآل محمد صلی اللہ علیہ و آلہ وسلم ) ہیں۔کیا تم نے خداوند عالم کا یہ قول نہیں سنا:’’رات دن ان راستوں پر چلوپھرو، پورے امن وعافیت کے ساتھ۔‘‘ یعنی ہر قسم کی غلطی سے محفوظ رہ کرزندگی بسر کرو‘‘۔ &&(تفسیر صافی ص۴۱۴)&& }} آیہ مجیدہ کی باطنی تفسیر یہ ہے کہ :‘‘ قرآن مجید کے مطالب کا صحیح استکشاف صرف حاملین علوم قرآنیہ یعنی محمد وآل محمد صلی اللہ علیہ و آلہ وسلم ہی کر سکتے ہیں۔ جس طرح قرآن مجید کا دعویٰ ہے کہ : ہر خشک وتر کا علم قرآن مبین میں موجود ہے اسی طرح قرآن مجید کا یہ دعویٰ بھی ہے کہ : قرآن کے ذریعہ پہاڑ چلائے جاسکتے ہیں ، زمین کا فاصلہ قطع کیا جاسکتا ہے اور مردوں سے کلام کیا جاسکتا ہے‘‘۔ جس طرح قرآن دوسرا دعویٰ حاملین قرآن ہی سے پایہ تکمیل کو پہنچ سکتاہے، اسی طرح اس کا پہلا دعویٰ بھی انہی (محمد وال محمد صلی اللہ علیہ و آلہ وسلم ) ہی سے پایہ ثبوت کو پہنچ سکتاہے۔&& (مقد مہ تفسیر انوار النجف جلد ۱۔ ۸۱) &&
  34,18,آیت نمبر ١٨ : اور ہم نے انکے اور انکی بستیوں کے درمیان نمایاں اور مسلسل بستیاں بسا دیں تھیں ،جن کو ہم نے برکت عطا کی تھی،اور ان میں آمدرفت کا سلسلہ بھی قاٸم کردیا تھا اور ان میں سفر کی مسافتیں ایک اندازے پر رکھ دی تھیں۔ان راستوں ہیں رات دن پورے امن و عافیت کیساتھ چلو پہرو۔
  34,19,آیت نمبر۱۹:<<’’بعد بین اسفارنا‘‘>> یعنی سبا والوں نے خدا کی عطا کردہ نعمات کی قدرنہ کی بلکہ کفران نعمت ان کا شیوہ بن گیا، انہوں نےان متصل آبادیوں اور پرامن سفر کے بجائے آبادیوں کا دور دور ہونا اور سفروں کا لمبا اور بامشقت ہونا پسند کیا۔ اور یہ بھی ممکن ہے کہ ان لوگوں کے حالت کفر وبے شکری اور نافرمانی نے زوال نعمت کو دعوت دی ہواور مطالبہ کیا ہو کہ درمیانی آبادیوں کو ہٹا دیا جائے اور درمیان کے سفر لمبے لمبے بامشقت کردیے جائیں۔ چنانچہ ایسا ہی ہوا پس سبا سے شام تک کی تمام آبادیوں ویرانوں سے بدل گئیں اور بعد والوں کےلیے ان کے تذکر صرف باتیں ہی باتیں (کہانیاں ) بن کررہ گئیں۔&& (تفسیر انوار النجف ملخص) && <<”صبارشکور‘‘>> صبا سے یہاں مراد ایسا آدمی ہے جو خدا کی بے انتہاء نعمتیں پاکر آپے سے باہر نہ ہوجائے۔ بلکہ جتنی نعمتیں زیادہ بڑھتی جائیں خدا کے شکر اور عملی اطاعت میں اور اضافہ ہوجائے۔&&(مفردات القرآن)&&
  34,20,آیت نمبر ٢٠ : اور شیطان نے اپنا خیال انکی بارے میں سچائی ثابت کر دکھایا کہ بلآخر انہوں نے شیطان کی ہی پیروی کی۔سوا مومنوں کی چھوٹی سی جماعت کے۔
  34,21,آیت نمبر۲۱:تاریخ سے ثابت ہے کہ سبا کی قوم میں ا یک گروہ خداپرست مومنوں کا بھی تھا، وہاں کے کھنڈرات سے ایک کتبہ ۴۶۵؁ میں ملاتھا اس میں یہ الفاظ لکھے ہیں : اس معبود کی مدد اور تائیدسے جو آسمانوں اور زمین کا مالک ہے۔ دوسرا کبتہ ۴۸۵؁ ملااس پر لکھا ہے۔<<” بردار رحمٰن << (رحمٰن کی مدد سے) &&(تفسیر القرآن)&& خدا شیطان کو یہ طاقت نہیں دی:محققین نے اس آیت ۲۰۔۲۱ سے یہ نتیجہ نکالا کہ : (۱) خدا نے ابلیس کو یہ طاقت نہیں دی ہے کہ وہ کسی کا ہاتھ پکڑ کر زبردستی گناہوں میں ڈال دے۔ خدا نے شیطان کو بس یہ طاقت دی ہے کہ وہ ہمیں بہکا سکتاہے، شک میں ڈال سکتاہے۔ لوگ خود اپنے اختیار سے شیطان کے پیچھے چلنے لگتے ہیں۔(۲)خدانے شیطان کو بہکانے کی اجازت اس لیے عطا کی ہے تاکہ آخرت کو دل سے ماننے والوں ، اور نہ ماننے والوں واضح ہوجائے۔(۳)تیسرا نتیجہ یہ نکالا کہ آخرت کے عقیدہ کے سوا کوئی دوسرا عقیدہ ایسا نہیں ہے جو انسان کو سیدھے راستے پر لگاسکتے، اور وہ قائم بھی رہ سکے۔ جو آخرت میں حساب کتاب ، جزاء وسزا کا قانوں نہیں وہ لازمی طور پر گمراہ اور بدکار ہوگا۔ کیوں کہ اس میں سرسے احساس ذمہ داری پیدا نہ ہوسکے گا۔ اس لیے شیطان کا سب سے بڑا حربہ یہی ہوتاہے کہ وہ انسان کو آخرت کے بارے میں شبہ میں ڈال دیتاہے دنیا میں جو شخص بھی گمراہ ہوا ہے وہ انکار آخرت سے، اور جو شخص بھی سیدھے راستے پر چلا ہے اس کے طرز عمل کی نبیاد آخرت پر ایمان ہی رہاہے۔&&(تفہیم القرآن)&& جب اولاد آدم نے شیطان کی اتباع شروع کی تو انہوں نےشیطان کے ظنی فیصلے کی تصدیق کردی چنانچہ شیطانی ظن کی تصدیق کرنے والوں میں قوم سبا بھی تھی۔ اور جو قوم یا شخص انبیاء علیہم السلام کی تبلیغ کو ٹھکراکر دینی تقاضوں کو پس پشت ڈالتے ہوئے خداوندی نعمات کا مقابلہ کفران سے کرے وہ شیطان کے ظن اور اس کی پیشین گوئی: یعنی <<(لاغوینھم )>> << (والاضلنھم)>> (میں آولاد آدم علیہ السلام کو راہ حق سے بھٹکاوں گا) (اور ان کو ضرور گمراہ کردوں گا) کی تصدیق کرنے والوں میں سے ہے۔&& (تفسیر انوار النجف ، مجمع البیان)&& چنانچہ {{ تفسیر برہان ، میں فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ :روز غدیر خم جب رسول خدا صلی اللہ علیہ و آلہ وسلم نے علی علیہ السلام کے بازو پکڑکر:ان کو بلند کرکے<< من کنت مولہ فھذاعلی مولہ >> (جس کا میں مولیٰ وسرپرست ہوں اس کے لے علی علیہ السلام بھی مولیٰ اور سرپرست ہیں ) کا اعلان فرمایا تھا تو ابلیس کی فوج ایک جگہ جمع ہوئی اور ابلیس نے ان کو اپنی شیطانی چالوں اور گمراہ کن پالیسیوں کے ناکام ہونے کے خطرے سے آگاہ کیا کہ اگر پیغمبر صلی اللہ علیہ و آلہ وسلم کی یہ وصیت کامیاب ہوگئی تو ہم یقیناً ناکامی کا منہ دیکھیں گے۔لیکن جب منافقوں نے باہمی سرگوشیوں میں اپنی بدباطینوں کا اظہار کیا: کسی نے کہا پیغمبر صلی اللہ علیہ و آلہ وسلم کا یہ اعلان خواہش پرستی کے سوا کچھ نہیں۔ اور کسی نے کہا:یہ دیوانہ ہوگیا ہے اپنے بھائی کی محبت میں ‘‘۔ تو ابلیس کی ڈھارس بندھ گئی۔ اور کہنے لگا: اب مجھے تسلی ہے کہ ہمارا مشن کامیاب ہوگا۔ اور پیغمبر صلی اللہ علیہ و آلہ وسلم کی وصیت پر عمل کرنے والے کم ہوں گے‘‘۔ چناں چہ وفات پیغمبراکرم صلی اللہ علیہ و آلہ وسلم کے بعد جب لوگوں نے حضرت امام امیرالمومنین علی علیہ السلام سے مکمل طور پر منہ موڑ لیا تو ابلیس نے پھر اپنی ایک تقریب منعقد کی اور بلند عالیشان منبرپر بیٹھ کر اپنے مریدوں کے اجتماع عظیم سے خطاب کرتے ہوئے اعلان کیا کہ: ہمارا مشن کامیاب ہے“۔ پھرامام علیہ السلام اسی آیت کی تلاوت فرمائی: <<ولقد صدق علیہم ابلیس ظنہ۔۔۔الخ>> && (تفسیر انوار النجف)&& }} <<’’وماکان لہ علیھم‘‘ >> یعنی : @@ابلیس کو انسانوں پر کوئی غلبہ یا طاقت نہیں دی گئی، بلکہ انسان اپنی مرضی سے ہی اس کی پیروی پر کمربستہ ہوگئے۔ اور اللہ نے شیطان کو گمراہ کرنے کےلیے کھلی چھٹی میں لیے دے رکھی ہے تاکہ مومن اور کافر کی تمیز ہوجائے۔ پس جو جنت میں جائے، توایمان وعمل کی بدولت دے رکھی ہے تاکہ مومن اور کافر کی تمیز ہوجائے۔ پس جو جنت میں جائے، توایمان وعمل کی بدولت استحقاق پیدا کرے، اور جو جہنم میں جائے، وہ بھی اپنے اختیار وعمل سے اس کی سزا کا مستحق ہو۔ <<لنعلم>> کے یہ معنی نہیں کہ شیطان کی گمراہی پر ہی اللہ کا علم موقوف ہے بلکہ مقصد یہ ہے کہ اللہ کو تو پہلے ہی سے پتہ ہے لیکن وہ چاہتاہے کہ تمام مخلوق کے سامنے اس کا استحقاق جنت یا دوزخ کےلیے واضح ہوجائے۔&&(تفسیر انوار النجف)&& قوم سبا کا ق صلی اللہ علیہ و آلہ وسلم:تاریخ کی روسے ’’سبا‘‘ جنوبی عرب کی ایک بہت بڑی قوم کانام ہے جن کے بڑے بڑے قبیلے تھے۔ {{جناب رسول خدا صلی اللہ علیہ و آلہ و سلم نے فرمایا: ’’سبا‘‘ عرب کے آدمی کانام ہے جس کی نسل سے درج ذیل قبیلے پیداہوئے: کندہ، حمیر، ازد، مذجح، انمار، عالمہ،جذام، لحم، غشان،&&(ابن جریر، امام احمد، ابن ابی حاتم ، ترمذی)&& قوم سبا کے عروج کا زمانہ گیارہ سوسال قبل مسیح تھا۔ یہ ایک دولتمندقوم تھی۔ پہلے یہ لوگ سورج کو پوجتے تھے، پھر حضرت سلیمان علیہ السلام کے ہاتھ پرایمان لاکرمسلمان ہوئے۔ پھر کافی عرصے کے بعد مشرک ہوگئے۔ قوم کے بادشاہ نے مود کو سورج دیوتا بنا کر اپنی اطاعت کوان کےلیے فرض قراردیا۔ آثارِقدیمہ کی تحقیقات سے یہاں سے تقریبا تین سوکتبے ملے ہیں۔ یہ قوم تجارت پیشہ تھی اور اپنا سامان تجارت بےخوف وخطر بحراحمر جیسے خطرناک سمندر میں جہاز کے ذریعہ لے جاتی، اور مصر اور اردن کی بندر گاہوں تک لے جاتی۔ برسی راستے سے یہ لوگ اپنا مال عدن مکہ، مدینہ تبوک سے شام تک لے جاتے تھے۔ آج تک سبا والوں کی آبادیوں کے نشانات ان راستوں پر ملتے ہیں۔ یہ لوگ من مانی قیمتیں وصول کرتے ہوئے ظلم پر اترا آئے۔ &&(تفہیم القرآن)&& }} یہ لوگ ابرہہ کے ساتھ مل کر خانہ کعبہ کو تباہ کرنے کےلیے چڑھ دوڑے۔ جن کے نتیجے میں ابابیل کے لشکر نے ان سب کو تہس نہس کرڈالا۔ یہ حملہ ۵۷۱؁ء میں جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کی ولادت سے پہلے ہوا۔ بالآخر یمن پر ایرانیوں کا قبضہ ہوگیا۔&&(متفقہ تاریخ)&&
  34,22,آیت نمبر ٢٢ : (مشرکین سے) کہہ دیجٸیے کہ پکارو (بلاٶ) اپنے ان (خداٶں) کو جنہیں تم اللہ کے سوا اپنا خدا سمجھ بیٹھے ہو۔ وہ نہ تو ذرہ بھر قدرت رکھتے ہیں آسمانوں میں اور نہ زمین میں اور وہ انکی ملکیت میں شریک بھی نہیں ہیں ، اور نہ ان میں سے کوٸی اللہ کا مددگار ہے۔
  34,23,آیت نمبر۲۳:مشرکین کےلیے فرمایا جارہاہے کہ: اے میرے رسول صلی اللہ علیہ و آلہ وسلم ! آپ ان مشر کوں سے کہدیجئے کہ جن معبودوں کو تم نے اللہ کے علاوہ اپنا حاجت روا اور لائق پرستش تجویز کررکھا ہے، کسی مشکل کے وقت ذران کو بلاو اور پکاروتوسہی ، اور پھر دیکھو کہ وہ تمہاری کیا مدد کرسکتے ہیں ، پس تم کو ان کی حقیقت کا پتہ اس طرح چل جائے گا کہ وہ آسمانوں میں اللہ کے ساتھ ان کا کوئی مدد گارہے اور نہ وہ اس سارے نظام عالم کی تخلیق و تدیبر میں اللہ کے معاون ومددگار نہیں۔&&(تفسیر انوار النجف)&& <<’’ولا تنفع الشفاعۃ‘‘>> یعنی @@ بروز محشر کسی کی کوئی سفارش نفع مندنہ ہوگی ، سوائے ان کے جو اللہ کی طرف سے ماذون واجازت یافتہ ہوں گے@@۔تفسیر برہان میں ہے کہ جناب رسالت مآب صلی اللہ علیہ و آلہ و سلم اللہ تعالیٰ کی اجازت سےاپنی امت کی شفاعت کریں گے، اور حضرت امام علی علیہ السلام سے حضرت امام مہدی علیہ السلام تک تمام ائمہ معصومین علیہم السلام اپنے شیعوں کی شفاعت کریں گے۔ اسی طرح باقی انبیاء علیہم السلام کو بھی حق شفاعت حاصل ہوگا‘‘۔ {{اور فرزند رسول خدا صلی اللہ علیہ و آلہ و سلم حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ : ایک ایک مومن بھی بیعہ ومضر کے قبائل کی تعداد برابرلوگوں کی شفاعت کرے گا۔<<’’اذافزع‘‘>> یعنی جب بارگاہ خداوندی میں حاضری کے وقت خطاب پروردگار کو سننے کےلیے ان لوگوں سے گھبراہٹ کو دورکیا جائے گا، اور وہ بات کو سننے اور سمجھنے کے قابل ہوں گے تو فرشتے ان سے پوچھیں گے کہ اللہ نے تم سے کیا فرمایاہے؟ تووہ جواب دیں گے کہ :اللہ نے سچ فرمایاہے۔ واقعی اللہ کے علاوہ ہمارا کسی کو حاجت روایا مدد گار اور لائق عبادت مان لینا بالکل غلط اور ناجائز تھا۔ &&(تفسیر انوالنجف)&& }} خداکا فرمانا کہ : سوااس شخص کے جس کو خدا نے سفارش کرنے کی اجازت دی ہو‘‘۔ اس کے دومعنی ہوسکتے ہیں۔(۱) یعنی صرف اس کی سفارش قبول ہوگی جسے خدانے سفارش کرنےکی اجازت دی ہوگی۔ (۲) دوسرے معنی یہ بھی ہوسکتے ہیں کہ صرف اس کی سفارش کی جاسکے گی جس کےلیے خدا سفارش کرنے کی اجازت دےگا کہ اس کی شفاعت کی جائے۔&&(فصل الخطاب)&& اور خداکا یہ فرمانا کہ : یہاں تک کہ جب ان (لوگوں اور فرشتوں ) کے دلوں سے گھبراہٹ دور کردی جائے گی‘‘۔ اس فقرہ سے معلوم ہواکہ قیامت کے دن ملائکہ تک خداکی ہیبت سے لرزرہے ہوں گے۔ پھر ہم گنہگاروں کا کیا حال ہوگا؟ && (الامان، الحفیظ)&& && (تفسیر ماجدی)&& غرض قیامت کے دن اضطراب اور وحشت کا غلبہ ہوگا۔ سب لوگ اس انتظار میں بے چین ہوں گے کہ دیکھیں خدا کن لوگوں کو اور کن لوگوں کی شفاعت کی اجازت دیتاہے یہ اضطراب اور بے چینی خداوندعالم کے فرمان کے جاری ہونے کے بعد ہی ختم ہوگی۔ تو شفاعت کرنے والوں کی نگا میں خدا کے حکم پر لگی ہوں گی۔&&(تفسیر نمونہ)&& آیت ۲۳کا مفہوم یہ کہ :تم خود دیکھ لو خدا تو قوموں کی قسمتیں بناتا اور بگاڑتاہے۔ جیسا کہ تم نے قوم سبا کا ذکر سن لیا۔ خدانے ان کو بنایا بھی اور ان کی کفر نعمت ، ظلم وستم کی وجہ سے ان کو تہس نہس بھی کردیا۔ اب ذرا تم اپنے بناوٹی خداوں کو دیکھ لو، کیا ان میں اتنی طاقت ہے کہ بنایا بگاڑ سکیں ، قوموں کی قسمتیں بدل سکیں ؟ یہ توخداکے سامنے سفارش تک نہیں کرسکتے۔(۲) دوسری بات یہ بتائی کہ : خداکے ہاں کوئی اپنے زور کے بل پر سفارش نہیں منوا سکے گا۔ صرف وہی سفارش کرسکے گا جسے خدا اجازت مرحمت فرمائے گا۔ &&(تفہیم القرآن )&& محققین نے نتیجے نکالے: (۱) ہیبت اور خوف کا اثر فہم وفراست پر پڑتاہے۔ (۲) کبھی کبھی خوف فہم کو اس قدر متاثر کردیتا ہے کہ انسان معذور ہوجاتاہے۔ جیسے اہل حال بےحال ہوجاتے ہیں۔&&(مرشد تھانوی)&&
  34,24,آیت نمبر۲۴:دعوت فکر کا بہترین طریقہ:یہ طرز کلام جاذبیت کےلیے ہے اور دعوت فکر کا بہترین طریقہ کارہے کیوں کہ جب یہ کہاجائے کہ تم اور ہم میں سے ایک گروہ غلطی پرہے اور دوسرا صحیح ہےتو دلائل وبراہین ہیں غورکرنے کے بعد فریق غلط کو دقبول حق کاراستہ آسانی سے مل جاتاہے۔ بخلاف اس کے جب یہ کہاجائے کہ ہم صحیح ہیں اور تم غلطی پر ہو، تو طریق مخالف میں ضد پیدا ہوجانے کا اندیشہ ہوتاہے پھروہ غور فکر کی توفیق سے محروم ہوکر حق بات کے سننے اور قبول کرنے سے محرم رہ جاتاہے۔&&(تفسیر انوار النجف)&& ادب کی انتہا ملا حظہ فرمائیں کہ اس قدر واضح دلیل دینے کےبعد بھی خداوند عالم نے یہ نہیں فرمایا کہ تم کھلی گمراہی میں پڑے ہو۔ بلکہ فرمایا:ہم نے سے کوئی ایک کھلی گمراہی میں پڑا ہوا ہے۔ یہ اس لئے کہ اگر مخاطب کو صاف صاف گمراہ کہدیاجائے گا تو وہ ضد پراتر آئے گاا ور حق بات کو ماننے پرآمادہ نہ ہوگا۔ کیوں کہ اصل مقصد ہدایت ہے اس لئے کوئی ایسا طریقہ اختیار نہ کیا جائے کہ مخاطب اپنی عقل کے دروازے بند کرلے اور ضد پر اترا آئے ، بلکہ اس کو خود سوچنے کا موقع دو۔ خود فیصلہ کرنا اسی کے ذمہ ڈالا و اس کی توہین نہ کرو کہیں دل نہ ٹوٹ جائے۔ &&(تفہیم القرآن)&&
  34,25,آیت نمبر ٢٥ : کہہ دیجٸیے کہ ” جو جرم ہم نے کیا ہوگا اس کو تم سے نہ پوچھا جاٸیگا ،اور جو کچھ تم کر رہے ہو اسکی جواب طلبی تم سے نہ کی جاٸیگی۔
  34,26,آیت نمبر ٢٦ : کہہ دیجٸیے کہ ” ہم سب کو ہمارا پالنے والا مالک ایک جگہ جمع کریگا اور پھر ہماے درماں بلکل ٹھیک ٹھیک فیصلہ کردیگا (کیونکہ) وہ زبردست فیصلہ کرنے والا ہے جو سب کچھ جانتا ہے۔
  34,27,آیت نمبر ٢٧ : ان سے کہہ دیجٸیے ” ذرا مجھے انہیں دکھاٶ تو سہی جنہیں تم نے خدا کیساتھ شریک بناکر ملایا ہے۔ہرگز ایسا نہیں ہے ،بلکہ زبردست طاقت اور عزت والا اور گہری مصلحتوں کے مطابق داناٸی کیساتھ کام کرنے والا تو بس وہ اللہ ہی ہے۔
  34,28,آیت نمبر۲۸:مجھے پانچ چیزیں بالخصوص عطا کی گئیں :{{تفسیر مجمع البیان میں بروایت ابن عباس رضی اللہ عنہ حضرت رسول کریم صلی اللہ علیہ و آلہ و سلم سے منقول ہے آپ صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’ مجھے پانچ چیزیں بالخصوص عطاکی گئیں ، اور یہ بڑائی کی بات نہیں۔(۱) میں ہر سیاہ وسفید (کالے وگوروں ) کی طرف مبعوث کیاگیا ہوں۔ (۲) میرے لیے پوری زمین جائے طہارت اور جائے سجدہ قراردی گئی ہے۔(۳) میرے لیے مال غنیمت کو حلال کیا گیا ہے، حالاں کہ مجھ سے پہلے کسی کےلیے حلال نہ تھا۔ (۴) میری نصرت رعب سے کی گئی ہے کہ وہ ایک مہینے کی مسافت کے فاصلے پر میرے آگے آگے چلتا ہے۔ یعنی جس طر ف میرا رخ ہوایک ماہ کی مسافت کے فاصلے تک لوگ مرعوب ہوجاتے ہیں۔ (۵)مجھے اللہ نے حق شفاعت عطافرمایا ہے جو میں نے روز محشر اپنی امت کے لیے بچاکر رکھا ہے‘‘۔ }} تفسیر برہان ومجمع البیان میں ہے کہ : حضوراکرم صلی اللہ علیہ و آلہ و سلم کو مشرق ومغرب ، آسمان وزمین ، جن وانس تمام کےلیے مبعوث کیا گیاہے۔ <<وماارسلنک۔۔۔ الخ>> کے معنی بھی اس توجیہ سے مطابقت رکھتے ہیں۔ &&(تفسیر انوار النجف)&& {{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا: ’’ خداوندعالم نے دوسر ے انبیاء کرام علیہم السلام مثلاً حضرت نوح علیہ السلام ، حضرت ابراہیم علیہ السلام ، حضرت موسیٰ علیہ السلام ، اور حضرت عیسیٰ علیہ السلام کو شریعتیں عطافرمائیں (مگر خاص قوم اور خاص وقت کےلیے ) جبکہ ہمارے رسول اکرم صلی اللہ علیہ و آلہ وسلم حضرت محمد مصطفےٰ صلی اللہ علیہ و آلہ و سلم کو تمام مخلوقات کی طرف رسول صلی اللہ علیہ و آلہ وسلم بناکر بھیجا ‘‘ خواہ وہ کالے ہوں یا گورے ، جن ہوں یا انسان سب کےلیے اپنا رسول صلی اللہ علیہ و آلہ وسلم بناکر بھیجا‘‘۔ && (تفسیر صافی ۴۱۴ بحوالہ کافی) && }} ایک تفسیر یہ بھی ہے کہ <<’’کافۃ ‘‘>> <<”کف ‘‘>> سےہے۔ یعنی روکنے والا۔اس لیے >>کافۃ <<رسول خدا صلی اللہ علیہ و آلہ و سلم کی صفت ہے۔ یعنی کفر وشرک وگناہ سے روکنے والا‘‘۔ &&(تفسیر نوارلثقلین)&& کافر جناب رسول خدا صلی اللہ علیہ و آلہ و سلم پر یہ دباو ڈالا کرتے تھے کہ قیامت آتی کیوں نہیں ؟اصل میں وہ مذاق اڑاتے تھے۔ قرآن ان سے کہہ رہا ہے کہ جلدی نہ مچاو قیامت کا دن اور وقت سب مقرر ہے، وہ اپنے وقت پر آکر رہے گی، تم اس کی تیاری کرلو۔ &&(تفسیر نمونہ)&& نتائج:(۱) محققین نے نتیجہ نکالا کہ جناب رسول خدا صلی اللہ علیہ و آلہ و سلم تمام نوع انسانی کےلیے بھیجے گئے تھے۔ (۲) پھر جبکہ خدانے رسول صلی اللہ علیہ و آلہ و سلم کی نبوت کو زمان ومکان سے مقید نہیں فرمایا تواس سے ختم نبوت بھی ثابت ہوگئی۔ کیوں کہ رسول خدا صلی اللہ علیہ و آلہ وسلم کے آنے سے رسالت کے مقصد کی تکمیل ہوگئی، جو پیغام خداوندعالم کو بھیجنا تھا وہ سب کا سب بھیج دیا گیا۔ اب آئندہ کسی نبی علیہ السلام کے بھیجنے کی کوئی ضرورت باقی نہ رہی۔ &&(فصل الخطاب)&& اتنی صراحت کے ساتھ عالمگیر مذہب ہونے کا دعویٰ کسی دوسرے دین نے نہیں کیا۔ تمام آسمانی کتابوں میں صرف قرآن نے واضح طورپر خود کو عالمگیر تہذیب قراردیا۔ &&(تفسیر ماجدی)&&
  34,29,آیت نمبر ٢٩ : پھر وہ تم سے کہتے ہیں کہ (قیامت کا) وعدہ کب پورا ہوگا،اگر تم سچے ہو؟ تو بتاٶ
  34,30,آیت نمبر ٣٠ : کہہ دیجٸیے کہ تمہارے لیے ایک ایسے دن کی وعدے کی معیاد مقرر ہے جس سے نہ ایک لمحہ پیچھے جاسکتے ہو نہ ایک لمحہ آگے بڑہ سکتے ہو۔
  34,31,آیت نمبر ٣١ : اور کافروں نے کہا :” ہم تو ہرگز اس قرآن کو نہ مانیں گے۔اور نہ اس سے پہلے کی آٸی ہوٸی کسی کتاب کو تسلیم کرینگے “۔کاش تم دیکھتے اس حالت کو جب یہ ظالم اپنے پالنے والے مالک کے سامنے کھڑے کیے جاٸینگے تو ان میں سے ہر ایک دوسرے سے سوال و جواب کر رہا ہوگا۔غرض جو دنیا میں دبا کر رکھے گٸے تھے وہ بڑے بننے والوں سے کہیں گے :” اگر تم لوگ نہ ہوتے توہم خدا اور رسول صلی اللہ علیہ و آلہ وسلم پر ایمان لے آٸے ہوتے“۔
  34,32,آیت نمبر۳۲:{{جناب امیر المومنین امام علی علیہ السلام نے فرمایا: ہرامت کے مالدار لوگوں نے ہمیشہ خداکی نعمتوں کے بل پر بیجاتکبر کیا، اور ہمیشہ یہی کہا کہ : ہم مال اور اولاد میں سب سے بہت زیادہ ہیں اور ہم پر خدا کا عذاب کبھی نہ آئے گا۔ پس اگر لوگوں پر یہ برتری جمانا ہی ضروری ہے تو قابل تعریف اور نیک کاموں پر ایسا کرنا چاہیے۔ عرب کے جاہل اعلیٰ اوصاف پر فخر کیا کرتے تھے۔ &&(نہج البلاغہ ، صافی)&& }}
  34,33,آیت نمبر ۳۳ : تو جو لوگ دبا کر کمزور بنا دیے گئے تھے وہ بڑے بننے والوں سے کہیں گے :" (ایسا نہیں ہے) بلکہ یہ (تمہاری) رات دن کی مکاریاں تھی ،جب تم ہم کو یہ حکم دیتے تھے کہ ہم اللہ کیساتھ کفر کریں ،اور دوسروں کو اس کے ساتھ شریک ٹھرائیں "۔ آخرکار جب وہ اللہ کے عذاب کو (آتا) دیکھ لینگے تو دل ہی دل میں بہت ہی پچھتائینگے۔تو ھہ ان لوگوں کی گردنوں میں زنجیر ڈال دینگے جنہوں نے ابدی حقیقتوں سے کفر و انکار اور ناشکری کا طریقہ اختیار کیا تھا۔کیا لوگوں کو انکے کاموں جیسے بدلے کے سوا کوئی اور بدلہ دیا جا سکتا ہے؟ غرض بلکل ویسی ہی سزا وہ پائیں۔ (جیسے کام وہ کیا کرتے تھے جیسی کرنی ویسی بھرنی۔)
  34,34,آیت نمبر۳۴:<<’’مترفوھا‘‘>> جناب رسول خدا صلی اللہ علیہ و آلہ و سلم اور جملہ مسلمانوں کو تسلی دی گئی ہے کہ آپ صلی اللہ علیہ و آلہ وسلم اہل مکہ کے صاحب ثروت مالدار لوگوں پر تعجب نہ کریں کیوں کہ ہمیشہ سے یہ دستور چلاآرہا ہے کہ جب بھی کسی بستی میں کوئی نبی علیہ السلام آیا، وہاں کے دولتمند طبقہ نے اس کی دعوت کو ٹھکرایا۔ پس ہمیشہ دین خداوند طبقہ غربامیں مقبول رہا اور متوسط طبقہ اس کا ہمنوا رہا ہے۔
  34,35,آیت نمبر۳۵:<<’’وقالوا انحن‘‘>> کفار مکہ اپنی کثرت اولاد اور مالداری پر اتراتے تھے اور یہی کہتے تھے کہ ہم خدا کو پیارے ہیں اس نے ہمیں کثرت اولاد اور اموال عطافرمایا ہے پس وہ ہمیں عذاب نہ دے گا۔ اور مسلمانوں کو غربت وافلاس کا طعنے دیتے تھے۔&&( انوار النجف)&& قرآن مجید میں یہ بات باربار بتلائی گئی ہے کہ انبیاء کرام علیہم السلام کا مقابلہ سب سے پہلے امیر خوشحال لوگ کیا کرتے ہیں۔ &&(تفہیم القرآن)&& کیوں کہ خوشحال طبقہ انبیاء کی تعلیمات سن کر یہ سمجھ لیتا ہے کہ اب ان کو مان لینے کے بعد ہم اپنی مان مانی نہیں سکتے ہیں۔&& (مولف)&&
  34,36,آیت نمبر۳۶:<<قُلْ اِنَّ رَبِّيْ يَبْسُطُ الرِّزْقَ لِمَنْ يَّشَاۗءُوَيَــقْدِرُ>>۔کفار مکہ نے اپنی کثرت اولاد کثرت مال پر اتراناشروع کردیا۔ وہ کہتے تھے کہ ہم ہی خدا کو پیارے ہیں کہ اس نے ہمیں کثرت اولاد مال سے سرفراز فرمایا ہے پس وہ ہم کو عذاب میں مبتلا نہ کرے گا، اور مسلمانوں کو طعنہ دیتے تھے کہ اگر تم اللہ کو پیارے ہوتے تو خدا تم کو محروم نہ رکھتا۔ &&(تفسیر انوار النجف، تفسیر کبیر امام رازی ، کشاف)&& خداوند کریم نے کفار کے اس مقولہ کی تردید فرمائی ہے کہ رزق کا کشادہ کرنایا تنگ کرنا اللہ کی مصلحت کے تابع ہے۔ وہ چاہے کافروں کو فراوانی سے رزق دے اور مومنوں کو تنگی رزق میں مبتلا کرے۔ رزق کی فراوانی یا تنگی میں انسان کی آزمائش کا راز پوشیدہ ے تاکہ پتہ چل جائے کہ رزق کی فراوانی کے بعد وہ شکر گذار بنتا ہے یاکفر ان نعمت کرتاہے۔ اور رزق کی تنگی کے بعد وہ صبر سے کام لے کراپنے پروردگار کی مشیت پر راضی رہتاہے یا اللہ کی رحمت سے مایوس ہوکر اس کا شکوہ کرکے کافر بنتا ہے پس اللہ کا محبوب اور مقصد میں کامیاب انسان وہ ہےجو ہر دو حالات میں رضائے پروردگار کو پیش نگاہ رکھے۔ اللہ کے نزدیک (مال یا اولاد) دنیا کی بے قدری کی دلیل بالکل واضح ہے کہ نمرود اور فرعون جیسے سرکشوں کو دولت کی فراوانی عطاکی، اور حضرت ابراہیم علیہ السلام و حضرت موسیٰ علیہ السلام اولواالغرم پیغمبروں کو تنگ دستی میں شکر گذار اور تبلیغ رسالت کے فریضے میں ثابت قدم پایا۔&&(تفسیر انوار النجف)&&
  34,37,آیت نمبر۳۷:مال کا ہونا مفید بھی ہو سکتاہے:ایک شخص نے حضرت امام جعفر صادق علیہ السلام کے سامنے دولتمندوں کی برائی کی۔ {{آپ علیہ السلام نے فرمایا: اگر کوئی دولت مند شخص صلہ رحمی کرنے والا ( یعنی اپنے رشتہ داروں کی مدد کرنے والا ہو) اور اپنے بھائیوں کو فائدے پہنچانے والا ہو، تواللہ تعالیٰ اس کو دوہرا اجردیتا ہے۔ جیساکہ اللہ نے اس آیت میں ارشاد فرمایاہے۔&& (تفسیر صافی ص۴۱۵تفسیر قمی)&&}} آیت کا مفہوم :یہ ہے کہ باوجود کو ششوں کے دولت سے محروم رہنا، یا دولت کامل جانا، یہ سب بطور امتحان ہوتا ہے اور خداکی مشیت تکوینی کے تحت ہوتا ہے ، جسے جاہل لوگ خداکی رضامندی کی علامت سمجھ لیتے ہیں۔ پھر اس بات کی وضاحت یوں کی گئی کہ: مال اور اولاد کی کثرت کسی کو خداسے قریب نہیں کرتی۔ کیوں کہ جو چیز خداسے قریب کرتی ہے۔ اور انسان کا نیک عمل اور اس کا قلبی ایمان وخلوص ہوتاہے۔ &&(فصل الخطاب)&&
  34,38,آیت نمبر۳۸:{{حضرت امام علی علیہ السلام سے روایت ہے کہ: جو شخص مال میسر آنے کے بعد خیرات کےلیے اپنا ہاتھ بڑھائے گا، تووہ جو بھی خرچ کرے گا، خداوند کریم اس کا عوض اس کو دنیا میں بھی دے گا،اور آخرت میں بھی کئی کئی گنا ثواب عطافرمائے گا۔کسی نے عرض کی: یا امیرالمومنین! میں خداکی راہ میں خرچ کرتاہوں مگراس کا کوئی عوض نہیں پاتا۔امام علیہ السلام نے فرمایا: کیا تمہارا گمان ہے کہ خدا وعدہ خلافی فرماتاہے؟اس نے عرض کی: ہرگز نہیں ‘‘۔ امام علیہ السلام نے فرمایا: اگرتم میں سے کوئی حلال طریقے سے مال پیدا کرے تواس میں سے وہ جو مال بھی اللہ کی راہ میں خرچ کرے گا، اس کا عوض ضرور پائے گا“۔ &&(تفسیر صافی ص۴۱۵بحوالہ کافی)&& }}!! خداکی راہ میں خرچ کرنے کا مفہوم :اسلام کی نگاہ میں بہت وسیع معنی رکھتاہے۔{{ جناب رسول صلی اللہ علیہ و آلہ وسلم خدا  نے ارشاد فرمایا: ہرنیک کام خواہ کسی بھی شکل میں کیوں نہ ہو صدقہ کہلاتاہے۔ ہرنیک کام خدا کی راہ میں خرچ کرنا شمار ہوتاہے۔ (کیوں کہ ہرنیک کام میں مال یا انسانی صلاحیت ، طاقت ، محنت اور وقت خرچ کرنا پڑتا ہے جو صرف خدا کی رضا کےلیے ہوتاہے) اور جو کچھ کہ انسان ،اپنے بیوی بچوں ، ماں باپ کےلیے خرچ کرتاہے وہ بھی انفاق یا صد قہ لکھا جاتاہے۔اور جو مال انسان اپنی عزت آبرو بچانے کےلیے خرچ کرتاہے، وہ بھی صدقہ ہے۔ اور جو کچھ بھی انسان خداکی راہ میں خرچ کرتاہے، خدااس کا عوض ضروردے گا، سوااس کے کہ جوانسان (بے ضرورت ) گھر بنانے پر خرچ کرے یاگناہ کے کاموں پر خرچ کردے‘‘۔ && (تفسیر قرطبی جلد ۶)&& }} اللہ کی راہ میں خرچ کرنا بہترین تجارت ہے:اللہ تعالیٰ کا یہ فرمانا کہ : جو چیز تم اللہ کی راہ خرچ کروگے، وہ اس کی جگہ اور دے دے گا“۔ اس سے معلوم ہواکہ اللہ کی راہ میں مال خرچ کرنا بہترین تجارت ہے۔ جس میں نقصان کا کوئی امکان ہی نہیں ہے(فائدہ ہی فائدہ ہے) کیوں کہ اللہ نے خود اس مال کی جگہ دوسرا مال دینے کا عدہ فرمالیا ہے، جو مال اللہ کی راہ میں خرچ کیا جائے گا۔پھر اللہ جیسی عظیم اور سخی ذات سے یہ تو قع ہی نہیں کی جاسکتی کہ وہ صرف اتنا ہی ما ل دے گا جتنا اللہ کی راہ میں خرچ کیا گیا ہے ، اس لیے کہ جب کوئی کچھ دینے کا وعدہ فرماتاہے اور معین نہیں کرتا، تو پھر وہ اپنی آن بان شان کے مطابق عطا فرمایا کرتا ہے۔ اس لیے جب اللہ اس مال کے بدلے مال یا کوئی اور نعمت عطافرمائے گا جواللہ کی راہ میں خرچ کی گئی ہے تو وہ کئی گنازیادہ عطافرمائے گا۔ اسی لیے اللہ نے ارشاد فرمایا: اللہ بہترین دینے والا ہے&&(تفسیر نمونہ)&& اللہ نے اسی بات کو سورۃ الصف آیت ۱۰۔۱۱ میں بہترین انداز سے اس طرح ارشاد فرمایا:<< يٰٓاَيُّہَا الَّذِيْنَ اٰمَنُوْا ہَلْ اَدُلُّكُمْ عَلٰي تِجَارَۃٍ تُنْجِيْكُمْ مِّنْ عَذَابٍ اَلِيْمٍ ۱۰ تُؤْمِنُوْنَ بِاللہِ وَرَسُوْلِہٖ وَتُجَاہِدُوْنَ فِيْ سَبِيْلِ اللہِ بِاَمْوَالِكُمْ وَاَنْفُسِكُمْ ۰ۭ ذٰلِكُمْ خَيْرٌ لَّكُمْ اِنْ كُنْتُمْ تَعْلَمُوْنَ >> &&(سورۃ الصف آیت ۱۰۔۱۱ پ ۶۸)&& یعنی : @@ اے وہ لوگو! جو اللہ اور اس کے رسول صلی اللہ علیہ و آلہ وسلم کو دل سے مانتے ہو! کیا میں تمہیں ایسی نفع بخش تجارت بتلادوں جو تمہیں (اللہ کی) سخت تکلیف دینے والی سزا سے بچالے؟(تو سنو وہ تجارت یہ ہے کہ )(۱) اللہ اور اس کے رسول صلی اللہ علیہ و آلہ وسلم کودل سے مان لو۔(۲) اور اللہ کی راہ میں اپنے مالوں اور اپنی جانوں سے جہاد (کوششیں ) کرو عمل تمہارے لیے بہت اچھا اور نفع بخش ہے بشر طیکہ تم جان سکو‘‘۔&&(القرآن)&& {{جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:ہر رات ایک پکارنے والا آسمان سے یہ آواز دیتاہے کہ : زندہ رہو مرنے کےلیے، عمارتیں بناو ٹوٹنے پھوٹنے ، برباد ہونے کےلیے، خداوند! جو لوگ تیری راہ میں مال خرچ کریں ان کو بہترین بدلہ عطا فرما، اور جو تیری راہ میں مال خرچ نہیں کرتے ان کا مال ضائع کردے۔ کاش انسان اس بات پر غور کرے کہ وہ کس لیے پیدا کیا گیا ہے‘‘۔ &&(تفسیر مجمع البیان )&& جناب رسول صلی اللہ علیہ و آلہ و سلم نے فرمایا: جس شخص کو اس بات کا جتنا یقین ہوگا کہ اسے بدلہ ضرور ملے گا، تووہ (اللہ کی راہ میں خرچ کرنے میں ) اتنا ہی سخی ہوگا‘‘۔ &&(تفسیر نورالثقلین جلد ۴)&& }} لمحہ فکریہ اور طریقہ دعا:{{فرزند رسول حضرت امام جعفر صادق علیہ السلام سے ایک شخص نے دریافت کیا: فرزند رسول علیہ السلام !میں قرآن کی دوآیتوں پر عمل کرتاہوں مگر ان کا نتیجہ نہیں پاتا۔ پہلی آیت تویہ کہ خدانے فرمایا: مجھے پکارومیں تمہاری دعا کو قبول کرتاہوں ‘‘۔]] میں خدا کو پکارتا ہوں لیکن میر دعائیں قبول نہیں ہوتیں[[۔ &&(سورۃ مومن آیت ۶۰)&& امام علیہ السلام نے فرمایا: کیا تمہارا خیال یہ ہے کہ اللہ اپنے وعدے پورےنہیں کرسکتا؟‘‘ اس نے عرض کی : نہیں ایسا نہیں ہے‘‘۔ امام علیہ السلام نے فرمایا: جو شخص اللہ سے اس طرح دعا کرے جیسے اللہ نے دعا مانگنے کا حکم دیا ہے تواللہ اس کی دعاضرور قبول فرمائے گا۔ (۱) سب سے پہلے اللہ کی حمد بجالاو، اللہ کی نعمتوں کوایک ایک کرکے یاد کرو(۲)پھر ان کا دل سے شکریہ ادا کرو، (۳) پھر پیغمبر صلی اللہ علیہ و آلہ وسلم اور ان کی آل پر درود پڑھو۔(۴) پھراپنے گناہوں اور کوتاہیوں کی دل سے معافی مانگو، اس طرح کہ پہلے ہرہر گناہ کو دل میں یاد کرکے ان کا اقرارکرو، پھراللہ سے اس کے عذاب سے پناہ طلب کرو، توبہ کرو، معافیاں مانگو اور استغفار کرو(۵) (پھراپنی حاجت طلب کرو) یہ دعا مانگنے کا طریقہ ہے۔پھر امام علیہ السلام نے فرمایا: وہ دوسری آیت کونسی ہے جس پر تم عمل کرتے ہواور نتیجہ نہیں پاتے ؟ اس نے عرض کی: میں خداکی راہ میں خرچ کرتاہوں مگر بدلہ نہیں پاتا‘‘۔ امام علیہ السلام نے فرمایا: اگرتم میں سے کوئی شخص کچھ حلال مال حاصل کرے اور اسے حلال طریقے سے خرچ بھی کرے تو وہ ایک درہم بھی خرچ نہیں کرتا، مگر یہ کہ اللہ اس کا عوض اس کو دے دیتاہے‘‘۔ &&(تفسیر برہان جلد۳)&& }}
  34,39,آیت نمبر ۳۹ : ان سے کہہ دیجیے کہ :" میرے پالنے والے مالک اپنے بندوں میں سے جسکے لیے چاہتا ہے اس کے رزق میں وسعت عطا فرماتا ہے ،اور جسے چاہتا ہے نپاتلا رزق تنگی سے عطا فرماتا ہے۔اور جو کچھ تم خیر خیرات کرتے ہو،اسکی جگہ وہی تم کو بدلے میں دیدیتا ہے (کیونکہ) وہ سب روزی دینے والوں سے بہتر روزی دینے والا ہے۔
  34,40,آیت نمبر۴۰:عرب میں فرشتوں کی پر ستش کی ابتداء اس طرح ہوئی کہ عمروبن لحی ایک سردار تھا جب وہ شام گیا تووہاں کے لوگوں کو پتھر اور لکڑی کے بت، فرشتوں اور مرے ہوئے بزرگوں کی ارواح کے خیالی مجسمے دیکھے عمروبن لحی کو یہ مجسمے اچھے لگے تووہ وہاں سے کچھ بت خرید کرلایا اور لوگوں کو ان کو پوجنے کی دعوت دی ، جو بڑی مقبول ہوئی۔ اس طرح عربستان (مجاز) میں بت پرستی شروع ہوئی۔&&(تفسیر روح المعانی جلد ۲۲، سیرۃ ابن ہشام جلد ۱۔ص۷۹)&&
  34,41,آیت نمبر۴۱:فرشتے عرض کریں گے:<<’’سبحٰنک انت ولینا۔۔۔ الخ >>فرشتے عرض کریں گے اے ہمارے پروردگار !ہم تو آپ کی تنزیہ وپاکی کے قائل ہیں ، یہ کس طرح ہوسکتا ہے کہ ہم آپ کے شریک بن بیٹھیں اور لوگوں کو اپنی عبادت کی دعوت دیں۔ آپ ہی ہمارے ولی ہیں اور ہم آپ کے عبادت گذارہیں۔ البتہ یہ لوگ جنوں کی عبادت کرتے تھےاور ان پر ان لوگوں کی اکثریت کا ایمان تھا۔فرشتوں کو یہ خطاب بعینہٖ اسی طرح ہے جس طرح حضرت عیسیٰ علیہ السلام سے اللہ کا خطاب ہوگا کہ اے عیسیٰ! کیا تم نے لوگوں سے کہا تھا کہ مجھے اور میری ماں کو معبود مانو؟حضرت عیسیٰ علیہ السلام عرض کریں گے کہ’’ اے ہمارے مالک ! آپ کو تواچھی طرح معلوم ہے کہ میں نے ان سے کیا کہا: یہ تواز خود ایسا کرتے تھے۔ پس حضرت عیسیٰ علیہ السلام ان لوگوں سے بیزار ہوں گے۔مقصد یہ ہے کہ جس طرح روز محشر مشرکین سے بازپرس ہوگی اسی طرح جن کو انہوں نے معبود بنارکھاتھا، اتمام حجت کے طور پر ان سے بھی پوچھا جائے گا، اور یہ چیز ان مشرکوں کے عذاب میں زیادتی کا باعث ہوگی۔ اور اسی طرح جن لوگوں نے حضرت محمد صلی اللہ علیہ و آلہ وسلم وآل محمد صلی اللہ علیہ و آلہ وسلم کو صفات خداوندی میں شریک مانا ہوگا وہ بھی میدان محشر میں مشرکین کی طرح رسوا ہوں گے۔ چنانچہ {{ معصوم علیہ السلام نے فرمایا ہے کہ : ہم ایسے لوگوں سے اسی طرح بری ہوں گے جس طرح حضرت عیسیٰ بن مریم علیہ السلام نصاریٰ سے بری ہوں گے‘‘۔ اور جو لوگ خالق یا رازق جیسی صفات کا اہل بیت پراطلاق درست قراردیتے ہیں <<خیرالرازقین یا احسن الخالقین>> کے الفاظ کو اپنے مسلک کی تائید میں پیش کرتے ہیں ، ان کا جواب یہ ہے کہ صفات کی تین قسمیں ہیں۔ (۱) ایسی صفات جن سے اللہ بھی متصف ہے اور بندےبھی۔ مثلاً آگ کا علم، کہ آگ گرم ہے۔ بندوں کو بھی علم ہے اور اللہ کو بھی لیکن اللہ کا علم قدیم ہے بندے کا علم حادث ہے۔ ( ۲) ایسی صفات جن کا اطلاق اللہ پر حقیقی ہے اور بندہ پر مجازی ہے جیسے خالق و رازق وغیر۔ (۳) ایسی صفات جن کا اطلاق صرف اللہ پر ہوسکتاہےبندوں پر قطعا ناجائز ہے جیسےالوہیت۔ &&(تفسیر انوار النجف ملخص)&& }}
  34,42,آیت نمبر ٤٢ : تو آج کے دن تم میں سے کوٸی ایک دوسرے کو کوٸی فاٸدہ یا نقصان نہیں پہنچا سکتا۔اور ہم ایسے ظالموں سے کہہ دینگے کہ اب چکھو اسی آگ کی سزا کا مزار جسے تم جھٹلایا کرتے تھے۔
  34,43,آیت نمبر ۴۳ : اور جب بھی انکے سامنے ہماری کھلی ہوئی آیتیں سنائی جاتی تھی تو وہ کہتے تھے :" یہ شخص تو بس یہ چاہتا ہے کہ تم کو تمہارے ان خداؤں سے پھیر دے جن کی بندگی اور پوجا پاٹ تمہارے باپ دادا کرتے چلے آئے ہیں "۔ پھر (مشرکین ) یہ بھی کہتے تھے کہ :" یہ قرآن کچھ نہیں ہے مگر ایک گھڑا ہوا جھوٹ"َ۔غرض ان کافروں کے سامنے جب بھی حق آیا تو انہوں نے یہ کیا کہ :"یہ کچھ نہیں ہے سوا کھلے ہوئے جادو کے"۔
  34,44,آیت نمبر۴۴:محققین نے اس آیت ۴۴ سے نتیجہ نکالا کہ: جس شخص نے بھی صرف اور صرف اپنی فکرپر تکیہ ہوئے کسی قسم کی آسانی ہدایت کے بغیر خرافات کو دل سے گھڑا اور زندگی کی راہ میں سفر کیا وہ برباد ہوا زندگی کے مقصد کو سمجھنے کےلیے خداکی ہدایتوں اور اس کی کتاب سے مددحاصل کرنے کی ضرورت ہے دوسرا یہ نتیجہ نکالاکہ خدا کی آیتوں کے انکار کا انجام تباہی کے سوا کچھ نہیں ہوتا۔ (اور تباہی بھی ہمیشہ کی) &&(تفسیر کبیر)&& مطلب یہ ہے کہ اس سے پہلے نہ کوئی کتاب خدا کی طرف سے ایسی آئی ہے اور نہ کوئی ایسا رسول آیا ہے جس نے آکر ان کو یہ تعلیم دی ہو کہ تم اللہ کو چھوڑ کر دوسروں کی عبادت کرو۔ اس لیے یہ لوگ کسی علم کی بنا نہیں بلکہ خالص جہالت کی بناء پر قرآن اور محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی رسالت اور پیغام توحید کا انکار کردیتے ہیں جس کی ان کے پاس کوئی دلیل نہیں ہے۔ &&(تفہیم القران)&&
  34,45,آیت نمبر۴۵:جائے عبرت ہے:پہلے زمانے والوں کو جومال ، قوت، طویل عمریں حاصل تھیں ، اس زمانے والوں کو اس کا دسواں حصہ بھی نہیں ملا۔ یا پھراس کا دوسرا مطلب یہ ہوسکتا ہے کہ اس زمانے والوں کو جس قدر ہدایت ، علم ،دلائل حق ملے ہیں پرانے زمانے والوں کو اس کا دسواں حصہ بھی نہیں ملاتھا۔ (آج کی جدید معلومات اور سائنس کی عجیب وغریب ایجادات پیش نظر رکھیے۔) &&(تفسیر صافی ص ۴۱۶)&& یہ مطلب بھی لکھا گیا ہے کہ ان لوگوں نے رسولوں کی تکذیب کی ،ان کو جھٹلایا، جبکہ محمدوآل محمد صلی اللہ علیہ و آلہ وسلم کو ہم نے جو کچھ علم وکمال عطا کیا ہے اس کا دسواں حصہ بھی ہم نے پچھلے انبیاء علیہ السلام کو نہ دیا تھا اس کے باوجود محمدوآل محمد صلی اللہ علیہ و آلہ وسلم کی تکذیب زیادہ کی گئی اور ان سے حسد بھی کیا گیا (ان کو اذیت بھی بےحد پہنچائی گئی)&&( تفسیر قمی)&& {{علامہ طبرسی نے لکھا کہ: مطلب یہ ہے کہ ہم نے ان کافروں کوکوئی ایسی کتاب نہیں دی جسے وہ آپ صلی اللہ علیہ و آلہ وسلم کے خلاف بطور سند پیش کرسکیں ، اور آپ صلی اللہ علیہ و آلہ وسلم سے پہلے ہم نے کوئی ایسا نہیں بھیجا جس نے آپ صلی اللہ علیہ و آلہ وسلم کا انکار کیا ہو۔ &&(مجمع البیان)&& }} مشرکین مکہ کو اس کا دسواں حصہ بھی نصیب نہیں ہوا جو کچھ ہم نے ان سے پہلے والوں کو عطا تھا اور جب انہوں انبیاء علیہ السلام کی تکذیب کی تھی توان کا حشر بھی کیساہوا، وہ مشرکین مکہ کے سامنے ہے کہ صفحہ ہستی سے ان کا نام ونشان بھی مٹ گیا۔ چناں چہ قوم سبا کا واقعہ ابھی ابھی گذرچکاہے پس ان کو اس واقعہ سے عبرت حاصل کرنی چاہیے۔&&( انوار النجف)&&
  34,46,آیت نمبر۴۶:( یعنی : دیوانہ وہ نہیں ہوتا جو کسی کو تباہی کے راستے پرجاتے ہوئے دیکھ کر تباہی سے بچانے، ڈرانے کی تنبیہ کرے، بلکہ وہ تو سب سے عقلمند انسان ہوتا ہے۔)آپس میں مل کر غور وفکر اور بحث کی اہمیت اور دعوت: یعنی ان سے کہدو کہ : میں تمہیں صرف ایک نصیحت کرتاہوں ، اور وہ یہ کہ اللہ کی توحید کے عقیدے میں ثابت قدم ہوجاو پھر ایک ایک ہوکریا دو دو مل کر آپس میں بحث وفکر کرو کہ کیا محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی کوئی بات خلاف عقل ہے یاان کا کوئی اقدام قابل نفرت یامذمت ہے یا ان کے کسی قول و فعل سے دیوانگی کا مظاہرہ ہوتاہے؟ پس تم کو صاف معلوم ہوجائے گا کہ ایسا نہیں ہے اور ان کی ہدایت دیوانگی نہیں بلکہ قرین عقل ہیں۔اور ان کا دین حق اور واجب القبول ہے، اور وہ تم کو آنے والے سخت عذاب سے ڈراتے ہیں۔پس آیت مجیدہ میں توحید، نبوت اور قیامت کے عقیدے کو بیان کیا گیا ہے۔ اور واحدۃ اس لیے کہاگیا کہ تمام اصول کی جڑ اور مرکزی نقط صرف عقیدئہ توحید ہے۔ جب یہ عقیدہ درست ہوتو باقی سب کی درستی اسی کی بدولت ہوسکتی ہے۔ {{ بروایت احتجاج طبرسیً حضرت امیرالمومنین علیہ السلام سے منقول ہے جس کا خلاصہ یہ ہے کہ : خداوند عالم نے رفتہ رفتہ احکام شریعت بھیجے۔ سب سے پہلےعقیدہ توحید ، پھرنبوت کی دعوت دی گئی۔ جب لوگوں نے اس کو تسلیم کرلیا تو یکے بعد دیگرے نماز ، روزہ ، حج جہاد اور زکوۃٰ وصدقات کے احکام نافذ کیے۔ تو منافقوں نے کہا: اے رسول صلی اللہ علیہ و آلہ وسلم ! اگر آپ کے پروردگار کی طرف سے کوئی اور حکم باقی رہ گیا ہو تووہ بھی بیان کردیجئے تاکہ ہم اطمینان کا سانس لیں ‘‘۔ پس یہ آیت اتری کہ: ’’ اب صرف ایک بات رہ گئی ہے اور وہ ہے ولایت علی علیہ السلام۔ پس اس میں توشک ہی نہیں کہ جو ولایت علی علیہ السلام کا قائل ہوجائے توگویاوہ تمام اصول کا قائل ہوا۔ &&(برہان ومتقنیات الدار بحوالہ تفسیر انوار النجف)&& }} {{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ : ’’ایک ساعت غوروفکر کرنا پوری رات کھڑے ہوکر نمازیں پڑھنے سے افضل ہے‘‘۔ &&(سفینۃ البحار جلد۲ ، مادہ فکر)&& امام علیہ السلام سے دریافت کیا گیا کہ غور فکر کرنے کا طریقہ کیا ہے؟‘‘فرمایا: جب تم کسی ویرانے سے گذروتواس ویرانے سے پوچھو کہ : تجھ میں رہنے والے کہاں چلے گئے؟ تیری بنیادرکھنے والوں کا کیا ہوا؟ تو بولتا کیوں نہیں ؟ &&(سفینۃ البحار)&& }} {{جناب امیرالمومنین علیہ السلام نے فرمایا: غورفکر کرنا نیکی اور اچھے کاموں کے انجام دینے کی دعوت دیتا ہے‘‘۔ &&(سفینۃ البحارجلد ۲) && }}
  34,47,آیت نمبر۴۷:اجر تبلیغ رسالت میں امت کا فائدہ ہے:{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمدباقر علیہ السلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: اس آیت کا مطلب یہ ہے کہ جس مودت اور محبت کامیں نے تم سے سوال کیا ہے اس محبت کے ذریعہ سےتم دنیا میں بھی ہدایت پاوگے اور قیامت کے دن بھی خدا کے عذاب سے نجات پاوگے‘‘۔ && (تفسیر صافی ص۴۱۶بحوالہ کافی)&& }} یہ حقیقت ہے کہ کسی نبی نے اپنی امت سے کوئی اجر طلب نہیں کیا۔ صرف ہمارے رسول صلی اللہ علیہ و آلہ وسلم نے خدا کے حکم پر اپنے قرابتداروں کی محبت کو بطور اجر رسالت طلب فرمایا: یہاں یہ سوال پیدا ہوتاہے کہ جو کام بغیر اجر کیا جائے وہ افضل ہوتاہے۔ اس لئے گذشتہ انبیاء کرام کا کام افضل قرارپائے گالیکن اس آیت نے اس سوال کو حل کردیا۔ کیوں کہ اس آیت میں بتلایاجارہا ہے کہ ہمارے رسول صلی اللہ علیہ و آلہ وسلم نے جو اجر طلب کیا ہے، وہ اپنے فائدہ کےلیے نہیں ، بلکہ خودامت کے فائدہ کےلیے طلب کیا ہے۔ یہ اپنی قسم کا واحدا جر ہے جو اجر طلب کرنے والے کے فائد کےلیے نہیں ہے، بلکہ اجرت ادا کرنے والے کے فائدہ کےلیے ہے یعنی نبی صلی اللہ علیہ و آلہ وسلم اپنے فائدہ کےلیے نہیں ، بلکہ امت کے فائدہ کےلیے اُجرت طلب فرمارہے ہیں۔ &&(فصل الخطاب)&&
  34,48,آیت نمبر ٤٨ : کہہ دیجٸیے :” حقیقت یہ ہے کہ میرا پالنے والا مالک حق کو (میرے دل میں )اتارتا ہے اور وہ تمام پوشیدہ حقیقتوں کا جاننے والا ہے۔
  34,49,آیت نمبر۴۹:<<’’قل جاء الحق‘‘ >> یعنی جب حکومت حق قائم ہوگئی تو باطل اپنے ہمنواوں کےلیے نہ دنیا میں کوئی اچھائی پیدا کرسکتا ہے اور نہ آخرت میں فائدہ پہنچاسکے گا۔&&(تفسیر انوار النجف)&& {{عبداللہ ابن مسعود روایت ہے کہ : جناب رسول خدا صلی اللہ علیہ و آلہ وسلم جب فتح مکہ کے موقع پر مکہ تشریف لائے تھے تو خانہ کعبہ کے چاروں طرف ۳۶۰ بت نصب تھے۔ آپ صلی اللہ علیہ و آلہ وسلم اپنے عصاسے ایک ایک بت کو گراتے جاتے اور فرماتے جاتے تھے۔ <<جاالحق زھق الباطل ان الباطل کان زھوقا>>۔ &&(سورۃ بنی اسرائیل آیت ۱۸ پارہ ۱۵)&& یعنی :@@ ”حق آگیا اور باطل مٹ گیا، یقینا باطل تو مٹنے ہی کےلیے ہے‘‘@@۔&&(تفسیر مجمع البیان جلد، تفسیر کبیر ، تفسیر انوار النجف)&& }}
  34,50,آیت نمبر۵۰:آیت کا مطلب یہ ہے کہ : جو کوئی غلط کام کرے وہ خود اپنے کواس کا ذمہ دار سمجھے لیکن جو اچھا کام کرے اس کاانجام دینے والا بھی وہ خود ہے۔ اس لیے اچھے کام کا اجروثواب بھی کام کے انجام دینے والے کو ملے گا۔ البتہ نیک کام انجام دینے کی توفیق خداوند عالم عطافرماتاہے نبی صلی اللہ علیہ و آلہ وسلم کو یہ توفیق وحی کے ذریعہ سے عطا ہوتی ہے، اور دوسروں کو یہ توفیق خداکی ہدایات اور القاء ذہنی کے ذریعہ سے عطاہوتی ہے۔نیز نبی صلی اللہ علیہ و آلہ وسلم کے الفاظ سے بھی انسان کو نیک کاموں کی ہدایات ملتی ہیں۔ خدا کی کتاب سے بھی نیک اعمال کی ترغیب اور توفیق حاصل ہوتی ہے۔&&(مدارک ، فصل الخطاب) && سورۃ الشمس میں فرمایا:<< فالھمھا فجورھا وتقوٰھا >> &&(سورۃ الشمس آیت ۸پ۳۰ٰ)&& یعنی : @@پس اس کی بدکاریاں اور اس کی پرہیزگاری اس پرالہام کردی۔ (سمجھادی)@@ یعنی ہدایت بذریعہ الہام بھی ہوتی ہے۔
  34,51,آیت نمبر۵۱:روز محشر کفار کی حالت: یعنی اگرتم دیکھو تو تمہیں عجیب امر دکھائی دے گا۔ یعنی :روز محشر کفار جب اپنی قبروں سے اٹھیں گے تو گھبرا جائیں گے اور ان کے بھاگ نکلنے کا کوئی امکان نہ ہوگا اور اللہ ان کو گرفتار عذاب کرے گا اور اس طرح پکڑے گا جس طرح کوئی چیز قریب نزدیک سے اٹھائی جائے۔ظہور امام مہدی علیہ السلام کی نشانی:یہ آیت مجیدہ ظہور امام مہدی علیہ السلام کے بعض حوادث کی نشاندہی کررہی ہے۔ چنانچہ مکان قریب سے گرفتار کیے جانے والے سفیانی کے لشکروالے ہوں گے۔ جو مدینہ کی تاراجی کے بعد مکہ کی طرف رخ کریں گے۔ جب یہ شکر سفیانی مقام بیداء پر پہنچے گا تو بحکم پروردگار زمین ان کو قدموں کے نیچے سے پکڑے گی اور وہ زمین میں دھنس جائیں گے۔&&(تفسیر انوار النجف)&& یہ آیت امام مہدی علیہ السلام کے ظہور کے وقت کافروں ، ظالموں کے حال زار کا نقشہ بھی پیش کررہی ہے۔ جیسا کہ {{جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: جب سفیانی (ابوسفیان کی فکر رکھنے والے یا دور جاہلیت کے ماننے والے یااس کی اولادوالے) حضرت امام مہدی علیہ السلام کے مقابلے پرآئیں گے تو مکہ کے قریب ایک صحرا (بیدا) میں گرفتار عذاب ہوں گے۔ زمین شگا فتہ ہوجائے گی اور سخت زلزے کی وجہ سے لرزنے کاپننے لگیں گے۔ اور پھرزمین میں دھنس جائیں گے ‘‘۔ &&(الحدیث ، ازابن عباس ، ابن مسعود ،ابوہریرہ ، ابو حذیفہ، ام سلمہ ، حضرت عالشہ ازکتب اہل سنت ، تفسیر المیزان جلد۱۶ ، بحار ال انوار النجف ۵۲ باب علامت ظہور مہدی علیہ السلام )&& }}
  34,52,آیت نمبر ۵۲ : اور اس وقت یہ کہیں گے کہ :" ہم نے مان لیا (یا) ہم ایمان لے آئے ،حالانکہ ہم اتنی دور نکلی ہوئی چیز (دنیا سے ) (ایمان کا) لینا کہان ممکن ہے۔
  34,53,آیت نمبر۵۳:ظالم وکافر کی موت کا نقشہ:{{حضرت امام علی علیہ السلام نے ظالم ، کافر کی موت کے وقت کا نقشہ اس طرح کھینچا کہ: ’’ موت کے وقت دنیا کی نعمتوں کےہاتھ سے نکل جانے کی حسرتیں حملہ کرتی ہیں ، ان کے اعضاء سست ہوجاتے ہیں ، چہروں کی رنگت زرد پڑجاتی ہے، زبان کام کرنا بند کردیتی ہے، صرف آنکھوں سے (مڑمڑ) گھروالوں کو دیکھ رہا ہوتا ہے، اور کانوں سے ان کی آوازیں سن رہا ہوتا ہے، اور سوچ رہا ہوتا ہے کہ اپنی عمر کس کام میں برباد کردی؟ پھراس مال کو یاد کرتا ہے جسے حرام حلال کی فکر کیے بغیر جمع کرلیا، پھر حیران پریشان ہوکر اپنے ہاتھ شرمندگی سے کاٹتا ہے کیوں کہ موت کے وقت وہ ساری باتیں اس پر کھل جاتی ہیں جو پہلے پوشیدہ تھیں اس وقت آرزو کرتاہے کہ جو لوگ مال کی وجہ سے مجھ پر رشک کرتے تھے کاش یہ مال ان کے پاس ہوتا۔&&(نہج البلاغہ خطبہ ۱۰۹)&& }}
  34,54,آیت نمبر۵۴:آیت میں شک میں پڑے رہنے والوں کا نقشہ کھینچاہےـ:کہ شک میں پڑے رہنے والوں کو چین کہاں ؟ یہ سکون واطمینان سے محروم لوگ تو ہمیشہ ترد و وتذبذب میں ہی پڑے حیران سرگرداں رہتے ہیں۔ &&(تفسیر ماجدی)&& شک کی چارشاخیں:{{جناب امیرالمومنین علیہ السلام نے فرمایا: شک کے چار شعبے ہیں (۱) التماری (کٹھ حجتی وجھگڑے کرنا) (۲) الہول۔(خوف)( ۳) التردد۔ (سرگردانی)(۴) الاستسلامہ (باطل کے آگے سر جھکادینا) پس جس نے کٹھ حجتی اور لڑائی جھگڑے کو اپنا شیوہ بنالیا اس کی رات کبھی صبح سے ہمکنار نہیں ہوسکتی ، اور جس کو سامنے کی چیزوں نے ہول میں ڈال دیا، وہ الٹے پیر پلٹ جاتاہے۔ اور شک وشبہ میں سرگرداں رہتا ہے اسے شیاطیں اپنے پنچوں روند ڈالتے ہیں ، اور جس نے دنیا وآخرت کی تباہی کے آگے سر تسلیم خم کردیا وہ دونوں جہانوں میں تباہ ہوجائے گا۔&&(نہج البلاغہ کلمات قصار ص۱۳)&& }}
