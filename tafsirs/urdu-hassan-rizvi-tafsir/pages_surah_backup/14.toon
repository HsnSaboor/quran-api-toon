  14,1,آیت نمبر۱:>>الف۔لام۔را <<کی تفسیر:>>’’الف۔لام۔را<<’’میں ‘‘الف‘‘ اشارہ ہے اٰلَآَ اللہ یعنی اللہ کی نعمتوں کی طرف،اور>>’’لام‘‘<<اشارہ ہے لطف اللہِ یعنی اللہ کے لطف و کرم کی طرف، اور >>’’را‘‘<< اشارہ ہے قرآن کی طرف۔ اب‘‘>>الف۔لام۔را‘‘<< کے معنی یہ ہوئے کہ خدا فرما رہا ہے۔’’مجھے اپنی نعمتوں کی قسم کی یہ میرے لطف وکرم کاتقاضا تھا کہ میں قرآن مجید کو نازل کروں ‘‘۔(تلاوتِ نجمیہ۔روح البیان)امام ماتریدی نے لکھا کہ حروفِ مقطعات ہماری آزمائش ہیں ۔ مومن ان کی تصدیق کریکا اور کافر تکذیب۔ &&(کاشفی) &&مفسرین کی ایک جماعت کا یہ کہنا ہے کہ حروفِ مقطعات قرآن مجید کے مختلف نام ہیں ۔ اس طرح>>’’الف۔لام۔را‘‘ <<بھی قرآن کاایک نام ہے۔ &&(روح البیان) && (اصل بات تویہ ہے کہ >>حروفِ مقطعات<< اللہ اور رسول اللہ صلی اللہ علیہ و آلہ وسلم  کے درمیان خفیہ کلام ہے۔ جب تک وہ خود ظاہر نہ فرمائیں ، قیاس آرائی ہے۔ &&(مولف) &&!!ظلمات سے مراد:ظلمات یعنی اندھیروں سے مراد گمراہی ہے ۔گمراہیوں یا اندھیروں کی تین بڑی قسمیں ہیں (۱) کفر(۲) جہالت(۳) شک و شبہ۔اسی طرح نور’’یعنی‘‘ہدایت‘‘ کی بھی تین بڑی قسمیں ہیں (۱) ایمان(۲) علم(۳) یقین۔{{ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’اللہ نے نور اور ظلمات کے ستر حجابات بنائے ہیں ۔اگر وہ حجابات کھل جائیں تو اُن کی تجلیات ساری مخلوقات کو جلادیں ۔ ان حجابات سے خدا کی توفیقات ہی انسان کو نکال سکتی ہیں ۔ اسی لیے فرمایا:<<’’اَللہُ وَلِيُّ الَّذِيْنَ اٰمَنُوْا ۰ۙ يُخْرِجُہُمْ مِّنَ الظُّلُمٰتِ اِلَى النُّوْرِ‘‘>>یعنی :@@خدا ہی مومنین کا سرپرست ہے جو انہیں اندھیروں سے نکال کر نور کی طرف لیجاتا ہے۔>>@@&& (آیت الکرسی) &&غرض اندھیروں سے نکالنے کا مطلب یہ ہے کہ جب انسان ظلماتِ جسمانیہ (ادنیٰ اور بُری خواہشات کے) اندھیروں سے نکلے گا تو اُسے اللہ کا راستہ ملے گا۔ خدا حمید ہے یعنی اپنی جلالیت اور جمالیت کے کمال کی وجہ سے عزت اور کبریائی کے پردوں میں محجوب ہے اور بندہ اُس تک نہیں پہنچ سکتا جب تک وہ انِ حجابات سے نہ نکلے۔&&(روح البیان) &&}}
  14,3,آیت۳:یصدون کے عربی میں دو معنی ہوتے ہیں ۔(۱) منہ موڑ کرچلے جانا۔ (۲) راستے سے روکنا۔ یہاں پر زیادہ مناسب‘‘ لوگوں کو راستے سے روکنا ہے۔‘‘&& (تفسیر تبیان۔ فصل الخطاب) &&دنیاوی زندگی کا اصل مقصد:خدا کا فرمانا:@@’’جو دنیا کی زندگی کو آخرت کی زندگی پر ترجیح دیتے ہیں ۔‘‘@@ ان الفاظ سے محققین نے نتیجہ نکالا کہ دنیا کی محبت سرے سے ممنوع نہیں ۔ کیونکہ دنیا ماں کی حیثیت رکھتی ہے جس کی گود میں ہم پلتے ہیں اس لیے اس کی محبت فطری ہے ۔{{امیر المومنین حضرت علی علیہ السلام  نے فرمایا:’’کسی کو اس کی ماں سے محبت کرنے پر برا بھلا نہیں کیاجاسکتا ۔اس لیے دنیا سے محبت کرنا عیب نہیں ہوسکتا۔‘‘}}!!دنیا کی تعریف میں فرمایا:{{جناب امیر المومنین علیہ السلام نے دنیا کی تعریف کرتے ہوئے فرمایا:’’بلاشبہ دنیا اُس شخص کے لیے جو باور کرے ، سچائی کا گھر ہے، اور جو اُسکی ان باتوں کو سمجھے اُس کے لیے امن وعافیت کی منزل ہے ، اور جو اُس سے زادراہ حاصل کرے، اُس کے لیے دولتمندی کی منزل ہے جو اس سے نصیحت حاصل کرے، اُس کے لیے وعظ و نصیحت کا محل ہے۔ وہ دوستان خدا کے لیے عبادت کی جگہ ، اللہ کے فرشتوں کے لیے نماز پڑھنے کامقام ، وحی الٰہی کی منزل اور اولیاءخدا کی تجارت کی جگہ(تجارتی منڈی) ہے۔ اُنہوں نے اس میں اللہ کے فضل ورحمت کاسودا کیا، اور اس میں رہتے ہوئے جنت کو فائدے میں حاصل کیا۔ تو اب کون ہے جو دنیا کی برائی کرے،؟جبکہ اس نے اپنے خدا ہونے کی خبر دی ہے اور اپنے بسنے والوں کی موت کااعلان کردیا ہے۔اور مسرتوں سے آخرت کی مسرّتوں کاشوق دلایا ہے۔ وہ رغبت دلانے، ڈرانے ، اور متنبہ کرنے کے لیے شام کوامن وعافیت کااور صبح کو درد و اندوہ کاپیغام لے کر آتی ہے۔ تو جن لوگوں نے شرمسار ہوکر صبح کی ، وہ اُس کی برائی کرنے لگے، اور دوسرے لوگ قیامت کے دن اُس کی تعریف کریں گے کہ دنیا نے اُن کی آخرت کی یاد دلائی تو اُنہوں نے یادرکھا اور اس نے اُنہیں خبر دی تو اُنہوں نے تصدیق کی ، اور اس نے اُنہیں پندونصیحت کی ، تو اُنہوں نے پندونصیحت حاصل کی (اور فائدہ حاصل کیا) && (نہج البلاغۃ) &&}}!!اللہ کے راستے کو ٹیڑھا بنا دینے کے معنی:(۱) اللہ کے دین میں اپنی طرف سے اُلٹی سیدھی باتیں شامل کرنا(۲) دین کے مسائل میں شکوک پیدا کردینا۔(۳) دین کے ذریعہ اپنے ذاتی مفادات حاصل کرنا(۴) اور غلط سلط تاویلات کرکے لوگوں کو دین سے بدظن کردینا، ہوتا ہے۔ && (تفسیر کبیر) &&{{حضرت امام جعفر صادق علیہ السلام  نے فرمایا:جولوگ دین کو دنیا کمانے کا ذریعہ بناتے ہیں ، اور احکامِ جور کے مفادات کی تائید کرتے ہیں وہ اللہ کے راستے کے ڈاکو ہیں ۔&& (الکافی) &&}}
  14,4,آیت نمبر۴:اللہ گمراہی میں چھوڑ دیتا ہے:@@’’اللہ جسے چاہتا ہے گمراہی میں چھوڑ دیتا ہے‘‘@@آیت کاواضح مطلب یہ ہے کہ جب رسول صلی اللہ علیہ و آلہ وسلم  اُن کو انہی کی زبان میں سمجھائیں گے تو اُن پرحجت تمام ہوجائے گی۔ اب اتنے واضح طور پر سمجھانے کے بعد بھی جو سیدھے راستے پر نہ آئے گا تو اُسے خدا گمراہ قرار دیگا اور جو رسول صلی اللہ علیہ و آلہ وسلم  کی واضح سچی باتوں کو سمجھ کر سیدھے راستے پر آجائے گا۔ وہ نجات پائے گا۔&&(تفسیر تبیان۔فصل الخطاب )&&رسول اکرم صلی اللہ علیہ و آلہ وسلم  کی دوحیثیتیں :کیونکہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  کے مخاطبین اوّل عرب تھے اس لیے عربی زبان میں قرآن نازل ہوا۔ مگر رسول صلی اللہ علیہ و آلہ وسلم  کی دوسری حیثیت رہبر عالم کی ہے ، اس لیے قرآن میں اس حیثیت کو کئی کئی طرح سے واضح کیا گیا۔ مثلاً رسول صلی اللہ علیہ و آلہ وسلم  کو تمام عالمین کے لیے رحمت قرار دیاگیا۔<< وَمَآ اَرْسَلْنٰكَ اِلَّا رَحْمَۃً لِّلْعٰلَمِيْنَ ۱۰۷ ‘‘>>&&(ماجدی )&&[[بمصطفیٰ برساں خویش راکہ دیں ہمہ اوست۔اگر باو نہ رسیدی، تمام بولہبی است۔]]&&(اقبالؒ )&&
  14,5,آیت نمبر۵:<<ایام اللہ>>یعنی :@@’’اللہ کے دن’’@@اللہ کے دنوں سے خاص طور پر مراد تین دن ہیں ۔ (۱) موت کادن (۲ ) قیامت کادن (۳) ظہورِ مہدی علیہ السلام  کادن&&(تفسیر صافی ص۲۶۳بحوالہ تفسیر قمی ۔تفسیر علی ابن ابرہیم )&&<<’’صبار‘‘>> مبالغہ کاصیغہ ہے یعنی بڑا صبر کرنے والا، صبر پر قائم رہنے والا۔جب صبر کرنے میں مجاہدہ اور تکلیف اُٹھانے کاپہلو واضح طور پر شامل ہوجائے تو ’’صبار‘‘ کہتے ہیں ۔&&(مفردات امام راغب )&&اللہ کے دنوں سے مراد: (۱ ) وہ دن بھی ہیں جن دنوں میں دینِ خدا کو تقویت پہنچانے والا کوئی کام کیا گیا ہو۔ (۲ ) خد اکی راہ میں قربانیاں دی گئی ہوں (۳ ) یاوہ دن بھی مراد ہیں جن دنوں میں انبیاء کرام علیہ السلام  کی بددعا یا اُمتوں کی بداعمالیوں کی وجہ سے خدا کاعذاب اُترنے کے دن۔ &&(تفسیر علی ابن ابراہیم )&&محققین نے نتیجے نکالے: (۱ ) ایسے تمام دن قابلِ ذکر ہیں اور اس قابل ہیں کہ اُن کی اہمیت اور یاد کو تازہ رکھاجائے۔ (۲ ) اور اس سے نسبت کی اہمیت بھی ثابت ہوگئی۔ &&(فصل الخطاب )&&خدا کے دنوں میں وہ دن بھی شامل ہیں جن میں خدا کے قانونِ جزاء وسزا کااظہار ہوا اور ان دنوں میں امام مھدی علیہ السلام  کے ظاہر ہونے کے دن بھی شامل ہیں ۔ &&(بقول امام محمدباقر علیہ السلام از تفسیر صافی )&&خدا کی نعمتوں کی ترتیب بزبانِ ولایت:خداکی نعمتوں پر شکرادا کرنے کے سلسلے میں{{ حضرت ابن عباسؓ سے روایت ہے کہ ایک روز جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  مسجد نبوی میں تشریف فرما تھے کہ خدا کی نعمتوں کاذکر چھڑ گیا تو حضورصلی اللہ علیہ و آلہ وسلم  نے اپنے اصحاب سے پوچھا:بتائو، تم پر خدا کی سب سے پہلی نعمت کونسی ہے؟ اصحاب نے جان ومال و رزق و اولاد و ازواج کو گننا شروع کیا۔ جب سب گن کر خاموش ہوگئے تو آنحضرتصلی اللہ علیہ و آلہ وسلم  نے حضرت علی علیہ السلام  سے دریافت فرمایا کہ اے علی علیہ السلام  !اب تم بتائو اللہ کی پہلی نعمت کونسی ہے؟آپ علیہ السلام  نے عرض کیا کہ’’میں کچھ نہ تھا اور اُس نے وجود عطا فرمایا۔‘‘ آنحضرتصلی اللہ علیہ و آلہ وسلم  نے فرمایا:دوسری؟ عرض کیا:اس نے مجھے زندگی بخشی آپ نے فرمایا: تیسری؟ عرض کیا اس نے مجھے اچھی شکل وصورت عطافرمائی۔آپ نے فرمایا: چوتھی؟ عرض کیا:’’اس نے مجھے فکر کرنے والا بنایا، غافل نہیں بنایا‘‘آپ صلی اللہ علیہ و آلہ وسلم  نے فرمایا:پانچویں ؟ عرض کیا: اس نے مجھے سوچنے کی قوتیں عطا فرمائیں ۔ آپ نے فرمایا؛ چھٹی ؟ عرض کیا :اُس نے مجھے اپنے دین کی طرف ہدایت فرمائی کہ میں گمراہ نہی ہوں ‘‘ پھر حضورصلی اللہ علیہ و آلہ وسلم  نے فرمایا:ساتویں ؟ عرض کیا:’’اس نے میرے لیے بازگشت ایسی بنائی کہ پھر میں وہاں فنا نہ ہوں گا۔ پھر فرمایا: آٹھویں ؟عرض کیا: اُس نے مجھے آزاد بنایا، غلام نہیں بنایا۔‘‘ پوچھا :نویں ؟عرض کیا:’’اُس نے آسمان و زمین اور اُن کے درمیان کی تمام چیزیں میرے لیے پیدا کیں ۔‘‘حضورصلی اللہ علیہ و آلہ وسلم  نے پھر سوال کیا کہ دسویں ؟عرض کیا:’’ اُس نے مجھے مرد اور حاکم بنایا۔‘‘ حضورصلی اللہ علیہ و آلہ وسلم  نے فرمایا:آگے بیان کرو؟ عرض کیا:’’ حضورصلی اللہ علیہ و آلہ وسلم !خدا کی نعمتیں حد وشمار سے باہر ہیں ۔ پس یہ سن آنحضرتصلی اللہ علیہ و آلہ وسلم  کے چہرہ نورانی پرمسکراہٹ ظاہر ہوئی، آپ صلی اللہ علیہ و آلہ وسلم  بہت خوش ہوئے اور ارشاد فرمایا:’’ اے علی علیہ السلام !تم کویہ علم وحکمت مبارک ہو، تم ہی تو میرے علم کے وارث اور اُمت کے معلم ہو۔ جو تمہاری اتباع کرے گا وہ صراطِ مستقیم پر ہوگا، اور جو تمہیں چھوڑ دے گا، وہ ذلیل ہوگا۔&&(ملحض ازتفسیر برہان۔امالی شیخ، تفسیر انوارالنجف )&& }}!!جناب رسول خداصلی اللہ علیہ و آلہ وسلم  کی فضیلت:خدا نے حضرت موسٰی کے لیے توبہ فرمایا کہ:’’تاکہ وہ اپنی قوم کو اندھیروں سے نکال کرروشنی کی طرف لائیں ۔‘‘ اس سے معلوم ہوا کہ حضرت موسٰی کی رسالت صرف بنی اسرائیل کے لیے تھی، جبکہ{{حضور اکرم صلی اللہ علیہ و آلہ وسلم  کے لیے ارشاد فرمایا:<<’’رحمۃ للعالمین۔‘‘>>یعنی حضور اکرم صلی اللہ علیہ و آلہ وسلم  تمام عالمین کے لیے رحمت ہیں ۔&&(روح البیان )&&{{!!نتیجے:آخر میں خدا کافرمانا:@@’’ہر اُس شخص کے لیے جو بڑاصبر اور شکر کرنے والا ہے‘‘@@ اس سے محققین نے نتیجہ نکالا کہ ایمان کے دواجزاء ہیں (۱ ) صبر (۲ ) شکر۔{{حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’دین کے دوحصے ہیں ۔ آدھا ’’صبر‘‘ اور آدھا’’شکر‘‘&&(الکافی )&&{{ (۲ ) اللہ کی نعمتیں تو سورج سے بھی زیادہ روشن ہیں ، مگرکیونکہ اُن سے اصل فائدہ مومن ہی کو ہوتا ہے، اس لیے خدا نے یہاں مومنین ہی کاذکر کیا ہے۔ &&(روح البیان )&&مسائل سلوک اور نتائج: (۱ ) حقیقت یہ ہے کہ گمراہی کے اندھیروں سے ہدایت کی روشنی کی طرف خود خدا ہی نکالتا ہے۔ لیکن اس کے باوجود خدا اندھیروں سے نکالنے کی نسبت رسول صلی اللہ علیہ و آلہ وسلم  کی طرف دینا بتاتا ہے کہ ہدایت اور رہنمائی کسی نہ کسی حد تک شیخ سے بھی متعلق ہوتی ہے۔ (۲ ) نیز خدا کایہ فرمانا کہ:@@’’خدا کی سزائوں کے دن یاددلائیے۔‘‘@@ اس سے عرفاء نے نتیجہ نکالا کہ :خدا کی طرف کی مصیبتوں میں بھی ہمارے لیے نفع اور تربیت کاسامان ہوتا ہے۔&&(تھانوی )&&
  14,6,آیت نمبر۶:خدا کی محبت پیدا کرنے کاطریقہ:اللہ نے حضرت موسٰی پروحی بھیجی کہ میرے بندوں کے دل میں میری محبت پیدا کرو۔ حضرت موسیٰ علیہ السلام  نے پوچھا:’’میں کیسے تیری محبت اُن کے دلوں میں پیدا کروں جبکہ دل تیرے اختیار میں ہیں ؟اللہ تعالیٰ نے ارشاد فرمایا:@@’’اُنہیں میری نعمتیں یاد دلائو۔‘‘@@علماء نے اسی بناء پر یہ حکم دیا ہے کہ دوست واحبات سے بات کرتے وقت ایسے الفاظ کہنے چاہئیں جو خدا کی نعمتوں کو یاد دلائیں اور اُس کی رحمت، لطف اور مہربانیوں کی اُمید دلائیں ۔&&(روح البیان )&&
  14,7,آیت نمبر۷:دل سے اقرارِ نعمت، شکرِ نعمت ہے:{{حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’جوشخص دل سے اس بات کااقرار کرلےکہ ہر نعمت خدا کی عطا ہے، تو قبل اس کے وہ زبان سے اللہ کاشکریہ ادا کرے، وہ اللہ کی طرف سے زیادتی نعمت کامستحق بن جاتا ہے، اور اللہ کی کوئی چھوٹی بڑی نعمت ایسی نہیں ہے کہ دل وزبان سے الحمد للہ کہنے سے اُس کاشکریہ ادا نہ ہوجاتا ہو۔‘‘&&(تفسیر صافی ۲۶۴بحوالہ کافی )&& }}{{حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے ارشاد فرمایا:کفرکی پانچ قسموں میں سے تیسری قسم کفرانِ نعمت ہے۔ جیسا کہ خود خدا نے ارشاد فرمایا ہے:<<’’ وَلَىِٕنْ كَفَرْتُمْ اِنَّ عَذَابِيْ لَشَدِيْدٌ  ‘‘>>اگر تم کفرنعمت کرو گے تو میری سزا بہت سخت ہے۔‘‘&&(تفسیر صافی ص۲۶۴بحوالہ کافی )&& }}جس قدرخدا کی نعمتوں پر شکرادا کیاجائے گااسی قدرنعمتوں میں اضافہ ہوگا ۔شکر کے معنی نعمت عطا کرنے والے کی عطائوں کااعتراف کرنا،اُس کی تعظیم کرنا، اُس کی تعریف کرنا، اُس کی اطاعت کرنا، اُس کی ناراضگی سے بچنا، اُس کو راضی کرنے کی کوشش کرنا ہوتا ہے۔ &&(تفسیر کبیر امام رازی )&&عرفاء کے نزدیک شکر کے معنی خود کو ناگوار اور مشکل احکاماتِ الٰہی کی اطاعت پرآمادہ کرنا، مصیبتوں پر غیر اللہ سے شکایت نہ کرنا، نعمتوں اور پسندیدہ نتائج پر خدا کی تعریف کرنا، اسباب کے حجابات سے گذر کر اپنے رب کوفاعلِ حقیقی سمجھنا، خداکے سامنے ادب سے دل ونگاہ جھکائے رکھنا، یعنی تسلیم ورضا سے کام لینا۔&&(ماجدی )&&شکر کانتیجہ:کاشفی نے لکھا کہ ابوعلی جرجانیؒ نے کہا کہ خدا کے فرمانے کامقصد یہ ہے کہ اگر تم اسلام کی نعمت پر شکر کرو گے تو میں تمہیں ایمان کی نعمت عطا کروں گا، اگر ایمان کی نعمت پر شکر کرو گے تو تقویٰ کی نعمت عطا کروں گا،اگر تقویٰ کی نعمت پر شکر کروگے تو احسان کی نعمت عطا کروں گا، احسان کی نعمت پر شکر کرو گے تو تمہیں خلوت گاہِ خاص کے مشاہدات سے نوازا جائے گا۔ اس سے ثابت ہوا کہ شکر کرنا درجات کی ترقی کاسبب بنتا ہے۔ &&(کاشفی )&&شکر کے یہ معنی بھی ہوسکتے ہیں کہ خدا فرمارہا ہے کہ@@’’اگر خدا کی توفیقات ونعمات کاشکر ادا کرو گے تو ہم سے قریب ہوجائو گے۔جب تم ہم سے قرب کاشکریہ ادا کرو گے تو ہم خود تم سے قریب ہوجائیں گے، پھر اگر تم ہمارے اس قرب کابھی شکریہ ادا کرو گے تو ہم تمہیں اپنی محبت سے نوازیں گے۔ اگر اس محبت کاشکرادا کرو گے تو ہم خود تم سے محبت کریں گے۔ پھر اگر ہماری اس محبت کی قدر کرو گے تو ہم تمہیں بقاء عطا فرمائیں گے، اگر تم اس پر بھی خوش ہوگے تو ہم تمہیں وحدت کادرجہ دیں گے اس پر بھی شکرکرو گے تو ہم تمہیں شکر پر صبر کرنے اور صبر پر صبر کرنے اور صبر پر شکر کرنے کےدرجات عطافرمائیں گے تاکہ تم صبور وشکور کے بلند ترین منازل تک پہنچ جائو۔@@چھ کام ،چھ نعمتیں :{{جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:جسے چھ کام کرنے کی توفیق ملی وہ چھ نعمتوں سے محروم نہ رہے گا۔ (۱ ) جسے صبر کرنا نصیب ہوا، وہ اس کے ثواب سے محروم نہ رہے گا۔ کیونکہ خدا فرماتا ہے کہ:@@’’بے شک صبر کرنے والوں کو بلا حساب ثواب عطا ہوگا۔‘‘@@(۳ ) جسے توبہ کرنا نصیب ہو، وہ خداکی معافیوں اور نجششوں سے نوازا جائے گا۔ کیونکہ خدا فرماتاہے@@’’اللہ اپنےبندوں کی توبہ قبول کرتا ہے۔‘‘@@(۴ ) جوخدا سے مغفرت طلب کرے گا اُس کوخدا اپنی رحمتوں سے ڈھک لے گا۔ کیونکہ خدا ارشاد فرماتا ہے:@@’’اپنے مالک سے استغفارکرو،حقیقتاً وہ بہت معاف کرنے والاہے۔‘‘@@ &&(۵ ) جوخدا سے دُعاء مانگے گا، اُس کی دُعاءقبول ہوگی۔کیونکہ خدا نے فرمایا ہے:’’مجھ سے دُعاء مانگو،میں قبول کروں گا۔‘‘ (۶ ) جوخدا کی راہ میں خرچ کرے گا، اللہ اُس کو اُس کا بہترین بدل عطا فرمائے گا۔کیونکہ خدافرماتا ہے:@@’’اور جو خدا کی راہ میں خرچ کرتا ہے اُس کواس کابدلہ ملتا ہے۔‘‘@@&&(روح البیان )&& }}نکتہ:خدا نے شکر کرنے پر تو فرمایا کہ@@’’میں اور زیادہ دوں گا۔‘‘@@اور ناشکری کرنے پر نہیں فرمایا کہ میں سزادوں گا،بلکہ صرف یہ فرمایا کہ@@’’ میری سزا بہت سخت ہے۔‘‘@@یعنی جب عطا کوفرمایا تو فعل کی نسبت اپنی طرف دی، مگر جب سزا کاذکر فرمایا تو اسلوب ہی بدل دیا۔ &&(روح البیان بقول سعدی مفتی )&&
  14,8,آیت نمبر۸:معرفت خداوندی اور شکر کے فوائد:خدا نے اس موقع پر خودکو<<’’غنی‘‘>>یعنی ’’بے نیاز اور لاپرواہ‘‘ فرماکر یہ بتادیا کہ تمہاری ناشکریوں سے خدا کو مطلق کوئی نقصان نہ پہنچے گا۔ اور خود کو<<’’حمیدٌ‘‘>>یعنی قابل تعریف فرماکر یہ بتادیاکہ خدا تمہاری تعریف کرنے کی وجہ سے قابلِ تعریف نہیں ہے،بلکہ ازخود اپنی ذات وصفات کی وجہ سے قابلِ تعریف ہے، خواہ کوئی اُس کی تعریف کرے یا نہ کرے۔ غرض وہ تمہاری کسی قسم کی تعریف کامحتاج نہیں ہے۔اب رہاتمہاراشکرادا کرنا، اورخدا کی تعریف کرنا، تویہ عمل خود تمہارے اپنے لیے بےحد مفید ہے۔ کیونکہ اس سے تمہاری بندگی ثابت ہوتی ہے، اور تمہاری نعمتوں میں اور خدا کی طرف کی توفیقات میں اضافہ ہوتا ہے۔&&(ماجدی )&&
  14,9,آیت نمبر۹: (۱ )@@'' اپنے ہاتھ اپنے منہ میں دبالینے ‘‘@@کے معنی ، بہت سے ہیں مثلاً: (۱ ) تعجب کے سبب سخت حیران ہونا&&(فتح الرحمٰن )&& (۳ ) سخت غصہ کرنا۔جیسے اُردو میں کہتے ہیں اپنی بوٹیاں نوچ لیں &&(جلالین )&& (۳ ) تکذیب اور مذاق کرتے ہوئے اپنی زبان بند کرنے کے لیے منہ میں انگلیاں لے لیں تاکہ کہیں کسی حق بات کااقرار نہ ہوجائے۔&&(تفسیر تبیان )&& (۴ ) اپنے ہاتھ رسولوں کے منہ میں ٹھونس دینا، تاکہ وہ بول نہ سکیں ۔&&(القرآن المبین )&& (۵ ) غصّہ میں اپنی انگلیاں چبانا۔&&(۶ )&& بُری طرح انکار کرتے ہوئے اپنامنہ بند &&(تفسیر تبیان )&&&&(۷ )&& ہاتھوں سے اشارہ کیا کہ خاموش ہوجائو۔&&(۸ )&& اپنے ہاتھ اُن کے منہ پر رکھ دیے۔ تاکہ وہ بول نہ سکیں &&(تفسیر انوارالنجف )&&عرفا ء نے نتیجہ نکالا کہ پیغمبروں  کا انکار ہی نہیں ، بلکہ اُن کی بے ادبی کرنا بھی ایک عظیم جرم ہے۔&&(ماجدی )&&دعوتِ حق کایہ خاصہ ہوتا ہے کہ جب کلمہ حق بلند ہوتا ہے تو ایک قسم کی کھلبلی مچ جاتی ہے ۔ حق کاانکار کرنے والے اپنے مفادات پر ضرب پڑنے کی وجہ سے انکار پر انکار کرتے ہیں ، مگر خود اپنے کی عقل وضمیر کی چٹکیاں اُن کو سخت پریشان کرنے لگتی ہیں جس کاانجام یہ ہوتا ہے کہ حق کاانکار کرنے والے خود ہی چین وسکون سے محروم ہوجاتے ہیں ۔&&(تفہیم القرآن )&&خداکافرمانا:@@’’جنہیں سوائے اللہ کے کوئی جانتا تک نہیں ‘‘@@ اس سے عبداللہ ابن مسعود نے نتیجہ نکالا کہ نساب جب یہ کہتے ہیں کہ ہم حضر ت آدم علیہ السلام  تک نسب بیان کرتے ہیں ۔‘‘تو وہ جھوٹ بولتے ہیں ۔ اس لیے کہ اللہ نے اس علم کی بندوں کے لیے نفی فرمائی ہے۔ &&(روح البیان )&&
  14,10,آیت نمبر۱۰:مشرک اور کافر ذہنیت:مشرکوں اور کافروں کو خداکا دیوتا یا اوتار کے جسم میں داخل ہوجانا تو بڑی آسانی سے سمجھ میں آجاتا ہے۔ لیکن کسی انسان کاخدا سے ایسا تعلق ہونا کہ وہ خدا کاپیغام وصول کرسکے۔ جبکہ وہ انسانوں کی طرح بازاروں میں چلتا پھرتا بھی ہو، سوتا جاگتا بھی ہو، شادیاں بھی کرتا ہو، قطعاً سمجھ میں نہیں آتا۔اُن کے نزدیک بھلاایسا انسان کس طرح زمین پر خدا کانمائندہ بن سکتا ہے؟ اس لیے مشرک وکافر ذہنیت کے لیے یہ ممکن ہی نہیں کہ وہ کسی انسان کو دیوتا کے مرتبے تک نہ پہنچائیں ۔ &&(ماجدی )&&!!اثباتِ وجود باری تعالیٰ:خدا کے وجود کے ثبوت کے سلسلے میں (حضرت امام جعفر صادق  علیہ السلام کے ایک شاگرد ) امام ابوحنیفہ نے ایک زندیق سے کہا کہ’’میں نے ایک کشتی دیکھی تھی جو اسباب سے بھر پورتھی، اور ملاح کے بغیر چل رہی تھی۔ زندیق نے کہا:اس کو عقل نہیں مان سکتی۔‘‘اس پر امام ابوحنیفہ نے فرمایا:’’ایک معولی کشتی تو ملاح کے بغیر چل نہیں سکتی ، پھر بھلا یہ کائنات کے چودہ افلاک وکواکب علوی وسفلی نظام بغیر کسی چلانے والے کے کیسے چل سکتا ہے؟&&(روح البیان )&&!!عقیدہ توحید اور اُس کے نتائج:آیت کامفہوم یہ ہے کہ آسمانوں اور زمین کاموجود ہونا خود اس بات کی دلیل ہے کہ ان کاکوئی پیدا کرنے والا ہے اور وہ ایک ہے۔ اتنی بڑی دلیل ہوتے ہوئے اتنی عظیم حقیقت پر شک کرنا بڑی تعجب کی بات ہے۔ اور نبی صلی اللہ علیہ و آلہ وسلم  کے فرمانے کامقصد یہ ہے کہ :’’اے کافرو!تم لوگ جو ہمارے توحید کی طرف بُلانے کو ہمارا اپنا دعویٰ سمجھتے ہو، یہ غلط ہے اگرچہ توحید کاپیغام اتنا معقول ہے کہ اگر کوئی شخص اپنی رائے سے بھی دوسرے کواس فکر کی طرف بلائے تو بھی مناسب ہوگا، لیکن ہمیں تو خدا ہی نے اس کام کاحکم دیا ہے، تاکہ تم اس کوقبول کرو اور اس کی برکت سے خدا تمہارے پچھلے گناہ معاف فرمادے، اور تمہیں تمہاری عمر کی مدت تک خیروخوبی کی زندگی عطا فرمائے۔ یعنی تمہیں دونوں جہانوں میں توحید کے ماننے کااجر عطا فرمائے۔ توحید کاعقیدہ دنیا میں اس لیے مفید ہے کہ خدا تمہیں اس کی وجہ سے اچھی زندگی عطا فرمائے گا۔ اور آخرت میں اس لیے فائدے مند ہے کہ وہ تمہارے گناہ معاف فرماکر اپنی رحمتوں میں ڈھک لے گا۔ اس طرح توحید اور رسالت دونوں کابیان ہوگیا۔ &&(تھانوی )&& }}
  14,11,آیت نمبر۱۱:نبوت کی حقیقت:منکرین نبوت کایہ اصول اور مقدمہ تو بالکل ٹھیک ہے کہ نبی بشر جیسے ہوتے ہیں ۔ مگر اُن کی دوسری منطق کہ جو بشر ہو وہ نبی یارسول نہیں ہوسکتا۔، بالکل لغواور غلط ہے اور یہ منطق بھی بالکل غلط ہے کہ نبی کاانسان جیسا ہونا صرف اور صرف ظاہری شکل وصورت کے اعتبار سے ہے، یاعبودیت کے لحاظ سے ہے۔ تمام انبیاء ہمارے جیسے انسان ہیں ، خدا کے بندے ہیں ، خدا کے شریک نہیں ، مافوق البشر بھی نہیں ، البتہ اُن کاہمہ وقت تعلق اللہ سے جڑا ہواہے۔ وہ صاحبانِ وحی ہیں ، کمال اطاعت پر فائز ہیں ۔ نمونہ کامل ہیں ، واجب الاطاعت ہیں ، اور اسی اعتبار سے ہم سے بہت بلنددرجے کے انسان ہیں ۔ &&(ماجدی )&&چہ نسبت خاک رابا عالم پاک مٹی کو عالم پاک سے کیا نسبت ہوسکتی ہےتوکل کی علامات اور تعریف:متوکلین یعنی اللہ پر بھروسہ کرنے والے۔متوکل ۔یعنی اللہ پربھروسہ کرنے والے کی ایک نشانی یہ ہے کہ وہ اپنی مشکلات سے بچنے کے لیے خدا کی نافرمانی نہیں کرتا۔&&(روح البیان )&&{{حضرت امام جعفر صادق علیہ السلام سے منقول ہے کہ:’’شیطان کہتا ہے کہ تمام لوگ میرے قبضے میں ہیں مگر پانچ قسم کے آدمی ایسے ہیں جن کامیرے پاس کوئی علاج نہیں ، کسی حیلے سے میں اُنہیں اپنے قابو میں نہیں لاسکتا۔ (۱ ) اوّل وہ جونیک نیتی سے اپنے کاموں میں خدا پر توکل کرتے ہیں ۔ (۲ ) دوم وہ جورات دن، ہروقت تسبیح خدا میں ،مصروف رہتے ہیں ۔ (۳ ) سوم وہ مومن جو اپنے مومن بھائیوں کے لیے وہی چاہتا ہے جو اپنے لیے چاہتاہے۔ (۴ ) چہارم وہ جو مصیبت وتکلیف کے وقت جزع فزع نہ کرے۔ (۵ ) پنجم وہ جو تقدیرات پر راضی ہو اور روزی کم ہونے کاغم نہ کرے}}۔{{ حضرت امام رضا علیہ السلام نے فرمایا:’’توکل کے معنی یہ ہیں کہ جب یہ یقین ہے کہ خدا ہمارے ساتھ ہے تو کسی سے نہ ڈرے، آرام ہو یاتکلیف ، ہرحال میں اُس کی رضا پر راضی وخوشنود رہے ، اور کسی کو اُس سے زیادہ اپنا معاون اور مددگار نہ سمجھے۔ اس لیے کہ دوسرے کی مدد پریقین کرنا بھی شرک خفی ہے۔ انگوٹھی کو ایک اُنگلی سے دوسری اُنگلی میں پہننا کہ فلاں کام یاد آجائے یہ بھی شرک خفی ہے۔‘‘ &&(روح الحیات ترجمہ عین الحیوۃ )&& }}متوکل یعنی اللہ پر بھروسہ کرنے والے کی ایک نشانی یہ ہے کہ وہ اپنی مشکلات سے بچنے کے لیے خدا کی نافرمانی نہیں کرتا۔۔&&(روح البیان )&&}}حضرت امام حسین علیہ السلام  نے بوقتِ شہادت ایک شعر پڑھا جس کامطلب یہ ہے کہ:’’میں نے ساری مخلوق کو صرف اس لیے چھوڑ دیا کہ تجھ سے ملاقات کروں ۔‘‘&&(خطبات وکلمات امام حسین علیہ السلام  )&&{{
  14,12,آیت نمبر۱۲:توکل کے درجات: (۱ ) مبتدی کا توکل یہ ہے کہ وہ اسباب پربھروسہ نہیں کرتا، اللہ پر بھروسہ کرتا ہے۔ (۲ ) متوسط کاتوکل یہ ہے کہ وہ مسبب الاسباب سے ایسا گہرا تعلق پیدا کرلیتا ہے کہ اسباب کی طرف متوجہ نہیں کرتا۔ (۳ ) منتہی کاتوکل یہ ہے کہ وہ اللہ کی طرف اتنا محو ہو جاتا ہے کہ ماسویٰ اللہ کاوہم وگمان بھی باقی نہیں رہتا۔&&(تاویلات نجمیہ )&&بلا پر صبر کرنا آسان ہوجاتا ہے جب بلا سے بچانے والا سامنے ہو۔&&(امام قشیر )&&!!نتیجہ اور پیغام:محققین نے نتیجہ نکالا کہ توکل ترک تدبیر کانام نہیں ۔اسی لیے انبیاء کرام عمل اور تدبیر سے کبھی غافل نہیں ہوتے۔ مگر وہ موثر حقیقی اپنی تدبیر اور عمل کو نہیں سمجھتے ، موثر حقیقی اور فاعل حقیقی خدا کی مشیت کو سمجھتے ہیں ۔&&(ماجدی )&&سُبل:یعنی خداکے راستوں سے مراد ایمان، خدا کی معرفت، محبت،سلوک، وصول الی اللہ کے بلند مقامات کے راستے ہیں ۔ &&(تاویلات نجمیہ )&&
  14,13,آیت نمبر۱۳:کافروں کی غلط فہمی:قوموں کاانبیاء سے یہ کہنا کہ:’’ تم کولازمی طور پر ہمارے مذہب میں پلٹ کر واپس آنا ہوگا۔‘‘خود اُن کے اپنے ناقص خیال کی وجہ سے تھا۔ کیونکہ نبی علیہ السلام  کو جب تک خدا کاحکم نہیں ہوتا، وہ اپنی نبوت کااعلان بھی نہیں کرتا، اور خدا کے دین کی تبلیغ بھی نہیں کرتا۔ اس لیے اُمتوں کو یہ غلط فہمی رہتی ہے کہ نبی ہمارے دین پر تھا اور اب پھر گیا۔ یہ غلط فہمی انبیاء کی خاموشی کیوجہ سے پیدا ہوتی ہے حالانکہ انبیاءکبھی گمراہیوں میں شامل نہیں ہوتے۔ البتہ وہ گمراہیوں کے خلاف خود اپنی طرف سے بولنا شروع نہیں کرتے۔جب خدا حکم دیتا ہے تب گمراہیوں کے خلاف کام کرتے ہیں ۔&&(تفسیر علی بن ابراہیم،فصل الخطاب )&&!!آیت کامفہوم:یہ ہے کہ کافروں نے رسولوں علیہ السلام  کو دھمکی دی کہ ’’ہم تم کو ضرور اپنی سرزمین سے نکال باہر کریں گے۔‘‘ اس بات پرخدا رسولوں کوتسلی دے رہا ہے کہ’’ہم ان ظالموں کو تہس نہس کرڈالیں گے، ان کاتیاپا نچا ہوجائے گا۔ اور اس کے بعد تم کو اس زمین پر آباد کریں گے۔ نیز یہ وعدہ صرف تمہارے ساتھ نہیں کیاجارہا ہے، بلکہ ہر اُس شخص کے لیے عام ہے جو میرے سامنے کھڑے ہونے سے ڈرے۔&&(تھانوی )&&
  14,14,آیت نمبر۱۴:]]’’مباش درپئے آزار و ہرچہ خواہی کن‘‘[[ یعنی کسی کو تکلیف نہ پہنچائو اور جو چاہو وہ کرو۔‘‘{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے ارشاد فرمایا:’’جو شخص اپنے پڑوسی کو اس لالچ میں تکلیف پہنچائے کہ اُس کامکان حاصل کرلے تو خدا اُس کااپنا مکان اُسی پڑوسی کو دلوادے گا۔‘‘&&(تفسیر صافی ص ۲۶۴ بحوالہ تفسیر قمی ، تفسیر مجع البیان، روح البیان )&& }}{{حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا کہ خداوندِ عالم ارشاد فرماتا ہے کہ: مجھے اپنی عزت وجلال کی قسم ہے کہ میں کسی انسان کو نہ تو دو خوف دوں گا اور نہ دو امن دوں گا، اگر وہ دنیا میں مجھ سے ڈرتا ہوگا تو آخرت میں اُس کو ہرگز نہ ڈرائوں گا، لیکن اگر وہ دنیا میں مجھ سے بے خوف ہوکر امن کی زندگی گذاریے گا تو اُس کوآخرت میں امن نصیب نہ ہوگا۔اُسے آخرت میں میری سزائوں سے ڈرنا پڑیگا۔‘‘&&(الکافی )&& }}ڈرنے کی قسمیں :عوام دوزخ میں داخلے سے ڈرتے ہیں ۔خواص جنت سے محروم رہ جانے سے ڈرتے ہیں اور اخص الخواصِ خدا کے مقامِ وصال وقرب کے فوت ہوجانے سے ڈرتے ہیں ۔&&(تاویلات نجمیہ )&&
  14,15,آیت نمبر۱۵ـ:جبار وعنید کے معنی اور مثال:{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے ارشاد فرمایا: ہر وہ شخص جو <لاالہ الااللہ>> کہنے سے انکار کرے وہ جبار وعنید یعنی سرکش’حق سے دشمنی رکھنے والا انسان ہے۔‘&&(تفسیر صافی ص ۲۶۴بحوالہ التوحید )&& }}}}حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ’’عنید‘‘ کے معنی حق سے منہ پھیرنے والا ہوتا ہے۔‘‘&&(تفسیر قمی )&&{{منقول ہے کہ ولید بن یزید بن عبدالملک اُموی خلیفہ نے ایک دن قرآن سے فال نکالی تو یہی آیت نکلی کہ’’ ہر سرکش جبار وعنید‘‘دشمن حق تباہ وبرباد کررہا۔ یہ الفاظ دیکھتے ہی وہ چڑ گیا اور سمجھا کہ یہ الفاظ اُسی کے لیے ہیں ۔ اُسی وقت قرآن کو پھاڑ دیا اور اُس پر تیر برسائے اور پھر یہ شعر کہے:[[<<التوعد کل جبار عنید۔فھاانا ذالک جبار عنید۔اذا ماجئت ربک یوم حشر۔فقل یا رب مزقنی الولید>>}}۔یعنی ’’اے قرآن!تو ہر سرکش دشمنِ حق کو دھمکیاں دیتا ہے۔ تو سُن لے کہ وہ جبار وعنید میں ہوں ۔ اور جب توقیامت کے دن اللہ کے سامنے حاضر ہونا تو کہہ دینا کہ ولید نے مجھے پھاڑ ڈالا تھا۔‘‘اس کے چند ہی دنوں بعد ولید کو قتل کردیاگیا اور اُس کاسراُس کے محل کے صدردروازہ پر لٹکادیاگیا۔ &&(حیواۃ الحیوان۔ ادب الدنیا والدین۔روح البیان )&&
  14,16,آیت نمبر۱۶:بُرے کاموں کے بُرے انجام :{{امیر المومنین حضرت علی علیہ السلام نے فرمایا:’’دوزخیوں کے پیٹوں میں کاٹنے دار جھاڑی اور تھوہر کھولتے ہوئے گرم پانی کی طرح اُبال کھائیں گے، اس لیے وہ شدید پیاس کی وجہ سے پانی مانگیں گے۔ اُس وقت اُن کو کچا خون اور پیپ جیسا گندہ بدبودار پانی پینے کو دیا جائے گا۔‘‘&&(تفسیر عیاشی )&& }}{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے ارشاد فرمایا:’’جودنیا سے نشہ پی کرنشے کی حالت میں رخصت ہوا&&(یعنی نشے کاعادی ہوکرمرا )&& تو وہ قبر میں بھی نشے کی حالت میں جائے گا۔ حکمِ خدا ہوگا کہ اُسے جہنم میں ڈالا جائے اور نشے کی حالت ہی میں ڈالا جائے۔ پھر جہنم میں ایک چشمہ ہے جس میں پیپ اور خون ہوگا، وہی اُس کاکھانا بھی ہوگا اور پینا بھی، جب تک آسمان اور زمین ہیں ۔‘‘ (یعنی ہمیشہ ہمیشہ کے لیے &&(روح البیان )&& {}اور {{حدیث قدسی میں ہے کہ:’’اے اولادِ آدم علیہ السلام !تم میری نافرمانی کیسے کرتے ہو۔ حالانکہ اس سورج اور تپتے ہوئے ریگستان کی حرات ہی سے تم جزع کرنے لگتے ہو اور یقیناً جہنم کے تو سات طبقے ہیں اور اُن کی ایسی آگ ہے کہ ایک آگ دوسری کو کھانے لگتی ہے۔}} &&(حدیث قدسی )&&{{ (یعنی ایک آگ دوسری سے بہت زیادہ گرم ۔ جیسے دنیا میں بھی ہیں ۔ لکڑی کی آگ سے ویلڈنگ کی آگ تیز ہے )
  14,17,آیت نمبر۱۷:خدا کی پکڑ بہت ہی سخت ہے:آیت کامطلب یہ ہے کہ وہ لوگ جس خدا کی سزا میں پہلے سے گرفتار ہوں گے، اُسی سزا میں اضافہ کیاجاتا رہے گا۔ &&(تفسیر صافی ص ۱۲۶ )&&{{حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ حضرت امیرا لمومنین علی بن ابی طالب علیہ السلام  نے فرمایا: دوزخیوں کی غذا پیپ اور کچا خون اور تھوہرہے۔‘‘}}{{آپ علیہ السلام  ہی نے فرمایا:’’اے لوگو!اُس اللہ سے ڈروکہ اگر تم کچھ کہو تو وہ سنتا ہے، اور دل میں چھپا کر رکھو تو وہ جان لیتا ہے۔ اُس موت کی طرف بڑھنے کاسروسامان کرو کہ جس سے تم بھاگو گے تو تمہیں پالے گی، اور اگر ٹھہرگئے تو وہ تمہیں اپنی گرفت میں لے لےگی، اور اگر تم اُسے بھول جائو گے تو وہ تمہیں یادرکھے گی۔‘‘&&(نہج البلاغہ )&& }}}}اے آدم علیہ السلام  کے فرزند!میں نے جہنم کی سخت ترین آگیں ہر کافر، بخیل ، چغل خور، ماں باپ کے نافرمان زکوٰۃ نہ دینے والے، سود خور، زناکار ، حرام سے جماعِ کرنے والے ، قرآن بھلا دینے اور پڑوسیوں کو تکلیف دینے والے کے لیے پیداکی ہیں ۔ &&(حدیث قدسی )&&{{
  14,18,آیت نمبر۱۸:قبولیت عمل کی شرط ایمان ہے:مطلب یہ ہے کہ حق دشمنوں نے جس قدر اچھے کام کیے ہوں گے ، وہ سب بے کار ثابت ہوں گے۔ اس لیے کہ اُنہوں نے وہ نیک کام کسی نہ کسی دنیوی مقصد مثلاً شہرت یا اپنے قلب کومطمئن کرنے کے لئے کئے تھے وہ کام خدا کو خوش کرنے یا آخرت کااجر لینے کے لیے انجام نہیں دیے تھے۔ (اس لیے اُن کا اجر آخرت میں نہیں ملے گا۔ ) &&(تفسیر صافی ص ۲۶۴ )&&مطلب یہ ہے کہ اگر نیک کام بغیر خدا رسول صلی اللہ علیہ و آلہ وسلم  اور آخرت کو دل سے مانے کیاجاتا ہے تو اُ س کی جزا آخرت میں نہیں ملتی ۔ اُن کاموں کی جزا دنیا ہی میں مل جاتی ہے۔ آخرت میں ایسے لوگ خالی ہاتھ ہوں گے کیونکہ اُن کے اعمال حبط ہوجائیں گے۔ &&(تفسیر جلالین، فتح الرحمٰن، فصل الخطاب )&&کفار کی غلط فہمیوں کاازالہ:پہلے کی آیتوں میں منکرین رسالت کاذکر تھا۔ اب کیوں کہ کچھ منکرین رسالت ایسے بھی ہوتے ہیں ۔جوکچھ اچھے کام بھی کرتے ہیں ۔ عوام کی فلاح وبہبود، صلہ ، رحمی، مہمان نوازی ، تعلیم اور قوم کی دیگر خدمات وغیرہ، توشبہ ہوسکتا تھا کہ (۱ ) شاید ان کے یہ نیک اعمال اُن کے کام آجائیں گے اور اُن کو عذابِ آخرت سے بچالیں گے اور (۲ ) یہ شبہ بھی ہوسکتا تھا کہ مرنے کے بعد بھلا کون زندہ ہوتا ہے؟ اس لیے عذاب کی گنجائش ہی کہاں رہی ؟یا (۳ ) پھر یہ شبہ ہوسکتا تھا کہ جن جھوٹے خدائوں کی ہم عبادت کررہے ہیں وہ ہمیں وہاں بھی بچالیں گے۔ تو ان سب سوالوں کاجواب یوں دیا گیا ہے۔ (۱ ) یہ قانون سن لوکہ جو لوگ اپنے مالک کے ساتھ کفر کرتے ہیں ، اُن کے نیک اعمال خدا قبول ہی نہیں فرماتا ۔ اُن کے اچھے اعمال کی مثال ایسی ہے کہ جیسے راکھ ہو اور اُسے آندھی کی ہوا جھٹ سے اڑالے جائے اور پھر راکھ کانام ونشان بھی باقی نہ رہے۔ (۲ ) رہا اُن کایہ خیال کہ قیامت کاوجود محال ہے اس لیے آخرت کے عذاب کاکوئی امکان ہی نہیں باقی رہتا ، تو اس کاجواب یہ ہے کہ جو خدا آسمانوں اور زمین کو ٹھیک ٹھیک پیدا کرسکتا ہے ، ایسا قادرِ مطلق اگر تم کو فنا کرنا چاہے تو اُس کے لیے کوئی مشکل نہیں ۔ اور جب اُس کے لیے سرے سے بالکل نئی مخلوق پیدا کردینا بالکل آسان ہے تو تم کو دوبارہ زندہ کردینا بھلا کیا مشکل ہوگا۔ خدا کی قدرتِ مطلقہ کو سمجھتا ہے تو زمین اور آسمانوں کو دیکھ لو جو اُس نے اپنی قدرت سے پیدا کردیے ہیں ۔ اس لیےوہ اُن کو دوبارہ بھی پیدا کرسکتا ہے۔ (۳ ) اب رہا یہ خبط کہ ہمارےبت اور خدایانِ باطل یا ہمارےا کابرین، یا دیوتایا جن، ہمیں خدا کے عذاب سے بچالیں گے۔ تو اس کی حقیقت بھی سُن لو کہ وہاں یہ بڑے جغادری جن کو تم خدا سمجھ رہے تھے، وہ تو وہاں خود گڑ گڑارہے ہوں گے اور کہہ رہے ہوں گے کہ’’اب تو ہمارے لیے بھی بھاگنے کی کوئی جگہ یابچنے کاکوئی طریقہ باقی نہیں رہا۔ &&(تھانوی )&&
  14,19,(آیت ۱۹ ){{ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’اللہ نے سب سے پہلے میری روح کو پیدا فرمایا۔ پھر اس کے بعد آسمانوں اور زمین کو پیدا کیا۔‘‘اس لیے آپ صلی اللہ علیہ و آلہ وسلم  کی روح نے تمام کائنات کی تخلیق کامعائنہ فرمایا: && (تاویلات نجمیہ ) }}&&آیت کامفہوم یہ ہے کہ’’اے لوگو!تمہیں خدا نے اپنے لطف وکرم کے قبول کرنے کی استعداد حاصل کرنے کے لیے پیدا کیا ہے۔ لیکن اگر تم نے اس استعداد کو حاصل نہ کیا تو اگر اللہ چاہے گا تو تمہیں دنیا سے لے جائے گا۔ اور انسان کے سوا کوئی اور مخلوق ایسی پیدا کردے گا جو خدا کے لطف وفیض کوقبول کرنے کی استعداد پیدا کرنے کی کوشش کریں گے ۔ استدلال یہ ہے کہ جو خدا زمین وآسمانوں کو پیدا کرسکتا ہے، وہ تمہارے بجائے دوسری مخلوقات کو لاسکتا ہے۔ ]]تمہاری داستاں تک بھی نہ ہوگی داستانوں میں[[  )&&تاویلات نجمیہ (&&
  14,21,آیت نمبر۲۱:بڑے بننے کے معنی: {{حضرت علی علیہ السلام نے عذیر کے موقع پر اپنے خطبہ میں اس آیت کو تلاوت فرمایا، پھر سوال کیا کہ کیا تم جانتے ہو کہ’’ استکبار‘‘یعنی بڑا بننے یابڑائی چاہنے کے کیا معنی ہیں ؟ پھر آپ علیہ السلام  نے خود ہی فرمایا کہ’’بڑا بننے یاتکبر کرنے کے معنی یہ ہیں کہ جس بات کا حکم دیا گیا ہو اُس کی اطاعت نہ کی جائے اور جس شخص کی پیروی کرنے کاحکم دیا جائے اُس سے اعلیٰ اور اونچا بننے کی کوشش کرنا۔‘‘&&(تفسیر صافی ص ۲۶۴بحوالہ مصباح المتہجد )&& }}
  14,22,آیت نمبر۲۲:شیطان اور شیطانی گروہ کا قیامت کے روز مکالمہ:شیطان کے کہنے کا مقصد یہ ہے کہ تمہارے گلے شکوے اس حد تک تو بالکل صحیح ہیں کہ میں جھوٹا تھا اور خدا سچا تھا۔ مجھے اس بات سے قطعاً کوئی انکار بھی نہیں ہے میں خود مانتا ہوں کہ جو بھروسے میں نے تمہیں دلائے تھے اور جن فائدوں کالالچ میں نے تمہیں دیاتھا۔ اور جو سبز باغ تمہیں میں نے دکھا کر تم سے گناہ پر گناہ کروائے تھے، وہ سب جھوٹے ڈھکوسلے تھے، اُن کی حقیقت نہ تھی۔ اور یہ پٹی جو میں نے تمہیں پڑھائی تھی کہ آخرت کی کوئی حقیقت نہیں ، وہ سب جھوٹ ،مکراور فریب تھا۔ شفاعت کاغلط تصّور کہ تم جوچاہو کرو، فلاں دیوتا یا فُلاں بزرگ تمہارے تمام گناہ بخشوادیں گے۔ یہ سب باتیں صرف تم کو بے وقوف بنانے کے لیے میں نے کی تھیں ۔ مگر یہ بات بھی تو حقیقت ہے کہ میں نے تمہارا ہاتھ پکڑ کر تمہیں زبردستی غلط راستے کی طرف نہیں کھینچا تھا۔ میں نے تو صرف تمہیں سچے ، سیدھے راستے کے مقابلے پر غلط اور بالکل غلط اور قطعاً باطل راستہ دکھایاتھا۔سچائی کے مقابلے پر جھوٹ کی طرف بلایا تھا۔ نیکی کے مقابلے پر برائی کی طرف تمہیں صرف پکارا تھا۔ زبردستی نہیں منوایا تھا۔ ماننے نہ ماننے کااختیار پورے کا پورا خود تمہارے پاس تھا۔ میرے پاس تم کو مجبور کرنے کی کوئی طاقت نہ تھی۔ ہاں یہ ٹھیک ہے کہ برائی کی طرف بلانے کامیں ضرور ذمہ دار ہوں ، اور میں اُسی کی سزا پائوں گا۔ مگر آپ لوگوں نے جو میرے پُکارنے کو مانا، اُس کی ذمہ داری مجھ پر کیوں ڈال رہے ہو؟تم نے خود اپنے اختیارات کو غلط استعمال کیا۔ تم نے خود اپنی ذمہ داری کی نہ پہچانا۔&&(تفہیم )&& (اس لیے اب تم اپنی ان غلطیوں او رکج فہمیوں کی سزا خود بھگتو۔اس کی ذمہ داری مجھ پر نہ ڈالو، مجھ پر لعنت ملامت نہ کرو، بلکہ تم خود اپنے اوپر لعنتیں بھیجو۔ تم نے اپنی عقل سلیم سے کام نہ لیا تو میں کیا کروں ۔ اب تو اللہ کا سخت ترین عذاب تمہارے لیے تیار ہے۔ &&(مولف )&&!!عملی شرک :شیطان کایہ کہنا کہ:’’تم نے مجھے خدا کی خدائی میں شریک بنارکھا تھا۔‘‘ تو شیطان کوکوئی خدا کاشریک اعتقاد نہیں بنایا کرتا شیطان کو خدا کاشریک اس طرح بنایا جاتا ہے۔ کہ جس طرح خدا کی اطاعت کی جانی چاہیے اُس طرح شیطان کی اطاعت کی جاتی ہے اس کو عملی شرک‘‘ کہتے ہیں ۔ اسی طرح کاعملی شرک اس طرح بھی کیاجاتا ہے کہ علماء دین کو حلال وحرام قرار دینے کااختیار دے دیا جاتا ہے۔ اسی لیے خدا نے فرمایا ہے کہ عیسائیوں اور یہودیوں نے اپنے علماء کوخدا بنارکھا ہے&&(اتخذوآاحبارھم ورُھبانھم ارباباً من دون اللہ والمسیح ابن مریم )&&یعنی اُنہوں نے اللہ کے بجائے اپنے عالموں اور اپنے راہبوں اور مسیح ابن مریم علیہ السلام  کو رب گردان لیا ہے ) &&(سورۃ التوبہ آیت ۳۱ )&& اسی طرح کاشرکِ عملی اُس وقت بھی انسان کرتا ہے جب اپنی خواہشات کو پورا کرنا زندگی کااصل مقصد قرار دے دیتا ہے۔ جیسا کہ خدا نے فرمایا:<<’’اریت من اتخذ الھَہٗ ھوٰئہیعنی :@@''کیا تم نے اُس آدمی کو دیکھا جس نے اپنی خواہشات کو اپنا معبود بنارکھا ہے۔‘‘@@ٗ‘‘>>&&(سورۃ الفرقان آیت ۴۳ )&&اس طرح نافرمان بندوں کے لیے خدا نے ارشاد فرمایا:<<’’ان لاتعبدو الشیطٰن انہ لکھ عدومبینہ‘‘>>&&(سورۃ یٰس آیت ۶۰ )&&کہ شیطان کی عبادت نہ کرنا۔ کیونکہ وہ تمہارا کھلا ہوا دشمن ہے۔‘‘ (عہد کرنےکے بعد شیطان کی عبادت کرنے لگے ) اسی طرح انسان کے بنائے ہوئے قوانین پر چلنے والوں کے لیے خدا نے فرمایا کہ:<<’’ام لھم شرکو اشرعوالھم من الدین مالم یاذن بہ اللہ‘‘>>یعنی :@@کیا اُن کے کوئی (ایسے ) شریک ہیں جنہوں نے اُن کے لیے دین کی ایسی شریعت یاراہ قائم کی جس کاکہ اللہ نے حکم نہیں دیا تھا۔@@ ‘‘ &&(سورۃ الشورٰی آیت ۲۱ )&&!!نتیجہ:محققین نے اس بات سے یہ نتیجہ نکالا کہ شرک صرف یہی نہیں کہ خدا کے ساتھ کسی دوسرے کو خدامان کر اُس کی پرستش کی جائے۔ &&(تفہیم القرآن )&&جب اہل ایمان جنت میں اور کفارومشرکین ، منافقین وظالمین جہنم میں بھیج دیے جائیں گے تو اہل دوزخ ، دوزخ میں شیطان کے گر دجمع ہوجائیں گے اور کہیں گے کہ کمبخت تو خود تو ڈوبا ہی ، اور ہمیں بھی لے ڈوبا‘‘اس وقت شیطان جواب دے گا کہ:’’ تم جو مجھے گالیوں پر گالیاں دے رہے ہو وہ ناحق ہیں ۔ کیونکہ اللہ نے تم سے جتنے وعدے کیے تھے کہ قیامت ہوگی، کفر سے ہلاکت ہوگی، ایمان اور عمل صالح سے نجات ہوگی‘‘وہ سب سچے ثابت ہوئے اور میں نے جو تم سے وعدے کیے تھے کہ’’قیامت نہ ہوگی‘‘ کفر وشرک سے نجات ملے گی‘‘تو میرے وعدے سب جھوٹے تھے۔ جبکہ خدا کے وعدے، دلائل قطعیہ اور عقلیہ سے ثابت تھے اور میرے تمام وعدے عقل وفہم کی مدد سے بالکل باطل تھے۔ مگر تم نے میرے وعدوں کوسچا اورصحیح سمجھا اور خدا کے سچے وعدوں کوجھوٹا سمجھا، تو تم خود اپنے ہاتھوں سے ڈوبے ہو۔ میں نے تم کو دھوکہ ضرور دیا، مگر تم مختار تھے، مجبور نہ تھے میں نے تمہارے ہاتھ نہیں تھامے تھے، نہ میرا تم پر کوئی زور چلتاتھا۔ میں تو صرف تم کو گمراہی کی طرف بلاتاتھا، اور تم دوڑے دوڑے میری طرف چلے آتے تھے۔ اس لیے تم مجھ پر لعنت ملامت مت کرو۔ اور اپنے کو بالکل بری الذمہ نہ سمجھو اپنے اوپر بھی لعنت ملامت کرو، کیونکہ سزاتمہیں خود تمہارے اپنے اعمال وکردار کی وجہ سے مل رہی ہے۔ میرا فعل فقط ایک سبب ہے۔ وہ بھی سبب بعید اور بغیراور غیر مستلزم۔ اب اگر تمہارا یہ کہنا ہے کہ میں تمہاری مدد کروں ، تو میں تو خدا عذاب الٰہی میں پھنسا ہوا، محتاج امدا دہوں ۔ اب نہ میں تمہاری کچھ مددکرسکتا ہوں اور نہ تم میری کوئی مدد کرسکتے ہو۔ اگر میں تمہارے طریقہ شرک کو حق سمجھتا تو شاید تمہارا کوئی حق بنتا کہ تم، ہم فکری اور ہم مشرب ہونے کی وجہ سے مجھ سے مدد مانگنے کا حق رکھتے اور مجھ سے بچانے کامطالبہ کرتے۔ مگر میں تو خود تمہارے اُس شرک اور کفر کے عقیدے سے بیزار ہوں ، اس عقیدے کو باطل سمجھتا ہوں ، تم خود مجھے خدا کاشریک قرار دیتے تھے یعنی میری اور بتوں کی ایسی عبادت،اطاعت اور خدمت کرتے تھے جیسی خدا کی کرنی چاہے تھی۔ پس مجھ سے تمہارا کوئی تعلق نہیں ۔ نہ تم کو مجھ سے مدد مانگنے کاکوئی حق ہے تم جیسے ظالموں کے لیے تو خدا کاعذاب مقرر ہے بس اُسی عذاب میں پڑے رہو اور جو تم نے کیا ہے اُس کی سزا بھگتو۔ اور جو میں نے کیا ہے، میں اُس کی سزا بھگت رہا ہوں ۔&&(تھانوی )&&حقیقت بھی یہی ہے کہ شیطان کسی انسان کو گمراہی کاراستہ اختیار کرنے پر مجبور نہیں کیا کرتا۔ وہ تو صرف سبز باغ دکھاتا ہے برائی کی طرف بلاتا ہے ۔پھر انسان اپنے ارادے اور اختیار سے اُس کی دعوت کو قبول کرلیتا ہے۔ اس لیے ہر گناہ کی ذمہ داری خود انسان پر عائد ہوتی ہے ، نہ کہ شیطان پر&&(مؤلف )&&!!نتیجے:شیطان کی کامل اطاعت کیے جانا، عملاً اُس کو خدا شریک بنا لینا ہے۔ &&(ماجدی )&& (۲ ) شرک صرف بت پرستی کانام نہیں ۔ کسی بھی غیر خدا کی اس طرح کامل اطاعت کرنا جیسی اطاعت خدا کی کی جانی چاہیے، بھی شرک ہے۔ &&(تفہیم )&& (۳ ) انسان اپنے اعمال میں خود مختار ہے، اس لیے اپنے اچھے بُرے اعمال کاخود ذمہ دار ہے۔{{ حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ جناب امیرالمومنین علی بن ابی طالب علیہ السلام  علیہ السلام نے فرمایا: اس آیت میں کفر و انکار سے مراد بریت یعنی علیحدہ ہوجانا ہے۔‘‘&&(تفسیر صافی ۲۶۵ )&& }}یعنی شیطان یہ کہہ رہا ہے کہ تم نے مجھے خدا کاشرک قرار دیاتھا۔ میں اس تمہارے وعدے سے علیحدگی اختیار کرتا ہوں ۔ یعنی میں اس بات کاانکار کرتا ہوں کہ میں خدا کے ساتھ خداکاشریک تھا، نہ ہوں اس لیے مجھ پر تمہارے اس شرک کی کوئی ذمہ داری نہیں ۔ &&(ماجدی )&&
  14,23,آیت نمبر۲۳:سلام کے دو معنی:دنیا میں سلام دعاء ہے۔ سلام کے معنی دنیا میں یہ ہیں کہ خدا تمہیں سلامت رکھے، ہر آفت سے محفوظ رکھے۔ مگرآخرت میں سلام مبارکباد ہے (یعنی تمہیں جنت اور جنت کی خوشیاں مبارک ہوں تم ہر آفت سے محفوظ ہو ) &&(موضح القرآن )&&!!سلام کاآغاز:حضرت آدم علیہ السلام  سے سلام کاآغاز ہوا جب حضرت آدم علیہ السلام  نے ہمارے رسول صلی اللہ علیہ و آلہ وسلم  کے نور کی جھلک دیکھی تو اللہ سے پوچھا، خدا نے فرمایا: یہ محمدصلی اللہ علیہ و آلہ وسلم  عربی کانور ہے جو تمہاری اولاد سے ہوں گے قیامت کے دن تمام انبیاء انہی کے جھنڈے تلے ہوں گے ۔ اس پر حضرت آدم علیہ السلام  آپ صلی اللہ علیہ و آلہ وسلم  کے دیدار کے مشتاق ہوئے تو خدا نے حضورصلی اللہ علیہ و آلہ وسلم  کانور حضرت آدم علیہ السلام  کی انگلیوں میں ظاہر کیا۔ یہ دیکھ کر حضرت آدم علیہ السلام  نے سلام کاتحفہ حضورصلی اللہ علیہ و آلہ وسلم کی خدمت میں پیش کیا۔ خدا نے حضورصلی اللہ علیہ و آلہ وسلم  کی طرف سے جواب سلام دیا اُسی وقت سے سلام کہنا سنت جواب دینا فرض ہوا۔&&(روح البیان )&&
  14,25,آیت نمبر۲۵:ایمان کے کلمہ کی بہترین مثال:کلمہ طیبہ یاکلمہ توحید درخت کی جڑ کی طرح ہے۔ اور وہ تمام اچھے اعمال جو اس کے نتائج ہیں  ، اُس کی شاخوں  کی طرح ہیں   پھر کلمہ طیبہ کابول بالا دنیامیں  بھی ہوتا ہے اور آخرت میں  بھی۔ آسان سے مراد اس جگہ بلندی ہے۔ (ماجدی)کلمہ طیبہ یاایمان کاکلمہ بیج کی طرح مومن کے دل میں  قرار پائے ہوئے رہتا ہے اور اُس کا عمل آسان کی طرف بلند ہوتا رہتا ہے، اور مومن کو اُس ایمان اور اپنے اچھے عمل سے خدا کی برکتیں  اور ثواب ملتا رہتا ہے جبکہ خبیث کلمہ کفر کاکلمہ ہے ۔ جس کی مثال خبیث اور گندے درخت کی سی ہے، جو ناپائیدار ہوتا ہے۔ نہ اُس سے خوشی ہوتی ہے نہ برکت۔(تفسیر جلالین)اللہ نے مومن کے ایمان کی درخت سے تشبیہ دی ہےمومن کاایمان اُس کے دل میں  ثابت اور مضبوط رہتا ہے اور اُس کے اعمال آسمانوں  میں  اعلیٰ علیین میں  پہنچئے ہیں   اور اُن کاثواب ہر زمانے میں  ملتا رہتا ہے۔ اُس کے پاس کوئی دلیل نہیں   ہوتی۔ اسی لیے اُس کو ثبات واستقرار نہیں   ہوتا۔ اُس کے اعمال بھی قابلِ قبول نہیں   ہوتے۔ اُس کی مثال اندرائن کی سی ہے کہ جس کی نہ جڑہوتی ہے نہ شاخیں ۔ نہ اُسے قرار(وثبات وپائیداری) ہے نہ اعتبار (روح البیان)شجرہ طیبہ کی اصل "میں"  صلی اللہ علیہ و آلہ وسلم  ہوں  :ان آیتوں  میں  کلمہ طیبہ سے مراد کلمہ توحید ونبوت وولایت ہے۔ چنانچہ {{حضرت امام صادق علیہ السلام  سے منقول ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا کہ:’’شجرہ طیبہ کی اصل "میں"  صلی اللہ علیہ و آلہ وسلم  ہوں  ، علی فرع ہے اور ائمہ اہل بیت علیہم السلام  اُس کی شاخیں ہیں   اور آئمہ  علیہم السلام    کاعلم اُس کاپھل ، اور شیعیان آل محمدصلی اللہ علیہ و آلہ وسلم  اس کے پتے ہیں ۔‘‘آخر میں  آپ صلی اللہ علیہ و آلہ وسلم  نے فرمایا کہ:’’جب کوئی شیعہ پیدا ہوتا ہے تو اس درخت میں  نیا پتا اُگ آتا ہے اور جب کوئی شیعہ مرتا ہے تو اُس کاایک پتا گر جاتا ہے۔ (تفسیر انوار النجف)}}
  14,26,آیت نمبر۲۶:آیت کی تاویل۔آیت کا گہرا مطلب:{{جناب امام جعفر صادق علیہ السلام سے روایت ہے ’’شجرہ طیبہ (یعنی اچھے نسل کے درخت ) اور شجرہ خبیثہ (یعنی خراب نسل کے درخت ) یہ دونوں مثالیں جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  کے اہل بیت علیہ السلام  اطہار علیہ السلام  اوراُن کے دشمنوں سے متعلق ہیں ۔‘‘&&(تفسیر صافی ص۲۶۵تفسیر عیاشی )&& }}{{حضرت امام جعفر صادق سے پوچھا گیا کہ اس آیت میں شجر (درخت ) کا کیا مطلب ہے؟حضرت امام علیہ السلام  نے فرمایا:’’ یہاں وہ درخت (شجرہ ) مراد ہے جس کی جڑ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  ہیں اور تنا حضرت علی علیہ السلام  میں اور جس کی شاخیں اَئمہ اہل بیت علیہ السلام  ہیں جو ان دونوں کی اولادیں ہیں ۔ اَئمہ اہل بیت علیہ السلام  کاعلم اُس درخت کے پھل ہیں ، اور ائمہ اہل بیت علیہ السلام  کے دوست اور پیروکار اُس درخت کے پتے ہیں ۔ جب کوئی مومن پیدا ہوتا ہے تو اُس درخت میں ایک پتا لگ جاتا ہے اور جب کوئی مومن مرجاتا ہے تو اُس کے نام کاپتا گر جاتا ہے ۔‘‘&&(الکافی )&&}}یہ تفسیر بھی مروی ہے کہ:{{’’اُس درخت کے پھل حضرت امام حسن علیہ السلام  اور حضرت امام حسین علیہ السلام  ہیں اور حضرت امام حسین علیہ السلام  کی اولاد میں نوامام اُس درخت کی شاخیں ہیں ۔‘‘&&(الاکمال )&&}}یہ تفسیر بھی کی گئی کہ:{{’’اُس درخت کی شاخ جناب فاطمہ زہرا ہیں اور آپ کی اولاد اُس کاپھل ہیں اور آپ کے شیعہ (ماننے والے اور پیروی کرنے والے ) اُس کے پتے ہیں ۔‘‘&&(معانی الاخبار )&&}}!!آیت کاحاصلِ مطلب:آیت کاحاصل مطلب یہ ہے :’’سچی شریعت عالمِ ملکوت میں قائم ہے اور دنیا میں روز بروز نئی مقبولیت حاصل کرتی ہے۔ اور لوگ اُس سے فائدہ اٹھاتے ہیں اور جاہلیت والا دھرم عالمِ بالا میں قائم نہیں رہتا۔ تھوڑے دن آدمیوں میں پھیلتا ہے اور پھر ختم ہوجاتا ہے۔ &&(فتح الرحمٰن )&&یعنی سچا دین دل میں اثر رکھتا ہے، روز بروز بڑھتا چڑھتا ہے۔ مگر کافروں کادعویٰ جڑ نہیں رکھتا۔ تھوڑا دھیان کرنےسے غلط معلوم ہونے لگتا ہے ، دل میں اُس سے کچھ نور نہیں پید اہوتا ۔ &&(موضح القرآن )&&غرض اس طرح ایمان کاکلمہ مومن کے دل میں قرار پاتا ہے ، مومن کاعمل آسمان کی طرف بلند ہوتا ہے، اُس کے عمل کی برکت اور ثواب سے ہر وقت اُسے فائدہ پہنچتا ہے ۔ جبکہ خبیث کلمہ کی مثال کفر کا کلمہ ہے ، اُس کو نہ پائیداری ہے، نہ اُس سے خوشی ہوتی ہے، نہ برکت۔&&(تفسیرجلالین )&&آیت میں انِ تما م معانی کی گنجائش موجود ہے۔ &&(فصل الخطاب )&&بنی اُمیہ میں سے ایک شخص جس کانام سعد تھا، ایک دن حضرت امام محمدباقر علیہ السلام کی خدمت میں روتا ہواآیا۔ آپ علیہ السلام  نے پوچھا : کیوں روتے ہو؟عرض کی، کہ’’میں بنی اُمیہ کی اولاد ہونے کی وجہ سے شجر ملعونہ کافرد ہوں ۔‘‘ اس پر {{حضرت امام محمد باقر علیہ السلام نے فرمایا:نہیں ، نہیں اگر چہ تم نسل کے اعتبار سے اُموی ہومگر (اصل کے اعتبار سے ) ہم میں سے ہو۔ دیکھو حضرت ابراہیم علیہ السلام  کی دعاء ہے کہ :’’ جو میری اطاعت کرے گا وہ مجھ سے ہوگا۔‘‘ (سعد اُموی اہل بیت علیہ السلام  رسول صلی اللہ علیہ و آلہ وسلم  سے محبت کرنے والا اور اُن کی پیروی کرنے والا تھا )}&&(تفسیر برہان )&&}}کلمہ طیبہ اور کلمہ خبیثہ یعنی پاک کلمہ اور پاک زندگی، اور خراب اور ناپاک کلمہ اور ناپاک زندگی کافرق اس طرح سمجھا جاسکتا ہے کہ دنیا کی تاریخ میں کلمہ طیبہ یعنی سچا دین اور عقیدہ ہمیشہ ایک ہی رہا ہے۔ مگر کلمات خبیثہ بے شمار رہے ہیں ۔ پاک کلمہ کبھی جڑ سے نہیں اکھاڑا جاسکا لیکن کلمات خبیثہ کی فہرست میں ہزاروں مردہ نظریات بھرے پڑے ہیں ۔ اپنے زمانے میں جن خبیث کلمات (عقائد ) کابڑا زور تھا، آج اُن پر لوگ تھوکتے ہیں ۔ حقیقت ابدی ہے مقام شبیری علیہ السلام ۔بدلتے رہتے ہیں اندازِ کوفی وشامی۔پھرکلمہ طیبہ (پاک عقیدوں ) کو جس قوم نے اپنایا وہاں کاماحول معطر ہوگیا:اُس کی برکتوں سے پوری قوم کو فائدہ پہنچا۔ پوری قوم کی فکر میں سلجھائو، طبیعت میں شرافت ، مزاج میں اعتدال، سیرت میں پاکیزگی اور مضبوطی، اخلاق میں بلندی، روح میں لطافت، جسم میں طہارت برتائو میں نزاکت، معاملات میں صداقت، معاشرت میں حسنِ سلوک، تہذیب میں فضیلت اور توازن پیدا ہوگیا۔ اور جہاں کلماتِ خبیثہ نے زندگی میں جڑ پکڑی ، اُس معاشرے کا سارے کاسارا ماحول گندہ اور پراگندہ ہوگیا۔&&(تفہیم )&&شجرِ خبیثہ کے اولین مصداق:برترین او رفاجر ترین گروہوں سے اوّلین مراد بنو مغیرہ او ربنو اُمیہ ہیں ۔بنو مغیرہ کو تو بدر میں سزا ملی اور بنواُمیہ کو مہلت ملی۔ یہ آیت اُنہی کے حق میں اُتری یہی بنی اُمیہ شجرہ خبیثہ ہیں ۔ اس میں یزید ملعون جیسے خبث شامل ہیں ۔ &&(روح المعانی ، روح البیان )&&
  14,27,آیت نمبر۲۷:موت کے وقت اور بعد کے حالات بقول حضرت علی علیہ السلام :{{حضرت علی بن ابی طالب علیہ السلام  علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’ان کو موت کے وقت اُس کامال، اولاد صورت اختیار کرکے اُس کے سامنے آتے ہیں ۔ انسان اپنے مال سے کہتا ہے کہ میں نے بڑی محنت کے بعد تجھے جمع کیاتھا، اب تو میری کیا مدد کرے گا؟ مال کہتا ہے کہ میں تجھے کفن فراہم کرسکتا ہوں ، اور بس مایوس ہو کر مرنے والا اپنی اولاد سے مخاطب ہوکر کہے گا کہ میں نے زندگی بھر تمہاری خدمت کی اب تم میر ی کیا مدد کرو گے؟اولاد کہے گی ہم تم کو تمہاری قبر میں دفن کرسکتے ہیں ، اور بس‘‘ پھروہ مرنے والا اپنے اعمال سے مخاطب ہوکر کہے گا۔ خدا کی قسم میں تجھ سے لاپرواہ تھا۔ اب میں تیری امداد کامحتاج ہوں ۔ ‘‘عمل کہے گا۔میں قبروحشراور دربار خداوندی تک تیرے ساتھ ساتھ رہوں گا۔ پھرمومن کااچھا عمل نہایت خوبصورت شکل میں اُس کے سامنے آئے گا، اور اُس کو جنت کی بشارت دے گا۔ مومن پوچھے گا۔ تو کون ہے؟‘‘ وہ جواب دیگا:’’میں تیرا نیک عمل ہوں ۔ پھر مرنے والا غسل دینے والے اور اپنے جسم کو اٹھانے والوں کو پہچانتا ہوگا اور ان کو جلدی لے جانے کی تلقین کرے گا۔ جب وہ قبر میں پہنچے گا تو دوفرشتے آئیں گے جن کے بال اور دانت زمین تک لمبے ہوں گے۔ اُن کی آواز بجلی کی کڑک اور آنکھیں بجلی کی چمک پیدا کرتی ہوں گی (جن کانام منکر نکیر ہوگا ) منکرنکیر اُس میں کمر تک روح ڈال کر بٹھائیں گے، پھر پوچھیں گے: تیرا رب کون ہے؟وہ کہے گا:اللہ پوچھیں گے تیرا نبی کون ہے؟‘‘وہ کہے گا ’’محمدمصطفےصلی اللہ علیہ و آلہ وسلم ‘‘ پوچھیں گے :تیرا دین کیا ہے؟وہ کہے گا: اسلام‘‘ پھرپوچھیں گے’’تیرا امام کون ہے؟ وہ کہے گا:’’علی علیہ السلام ‘‘ پھر ندا آئے گی: میرابندہ سچ کہہ رہا ہے ، اس کو جنت کا بستر دو، جنت کالباس پیش کرو۔ اور اس کی قبر میں جنت کی طرف دروازہ کھول دو۔‘‘ اس پر وہ فرشتے کہیں گے:’’خدا تجھے تیرے قول پرثابت رکھے۔‘‘اسی کے متعلق خدا فرماتا ہے کہ:’’اللہ ایمان والوں کو ثابت رکھتا ہے، قول ثابت پر دنیاوآخرت میں :<<(یثبت اللہ الذین اٰمنوا بالقولِ الثابت فی الحیوۃ الدنیا والاخرۃ )>>پھر قبر میں نظر کی حد تک وسعت دی جائے گی۔ اور اُس کی قبر میں جنت کادروازہ کھول دیں گے، اور منکر نکیر کہیں گے:’’آرام سے سوجا جس طرح بے فکر جوان سویا کرتے ہیں ۔‘‘اگر مرنے والا کافر ہوگا تو اُس کاعمل بُری شکل میں اُس کے سامنے مرتے وقت آئے گا۔ اُس کو دوزخ کی بشارت دے گا۔ فرشتے قبر میں اُس سے اُس کے نبی اور اُس کے دین کے متعلق پوچھیں گے۔ تو وہ کہے گا:’’مجھے کچھ پتہ نہیں ۔پس اُس کے سرپر جہنم کاگرز ماریں گے کہ تمام ذی روح سوائے انسانوں اور جنوں کے اُس کی آواز کوسنیں گے۔ اور گھبراجائیں گے۔ پھر اُس کی قبر میں جہنم کادروازہ کھول دیاجائے گا، جہنم کافرش بچھا دیاجائے گا، اور جہنم کالباس پہنا دیا جائے گا، جہنم کے سانپ بچھو اُس کی قبر میں آموجود ہوں گے اور اُس کو کاٹتے رہیں گے اور اس کادماغ ناخنوں کے ذریعہ پگھل کر باہر آئے گا، اور قیامت تک اسی حالت میں رہیگا۔‘‘الامان ، الحفیظ !! &&(تفسیر عیاشی۔کافی )&& }}غرض مطلب یہ ہے کہ خدا مومن کو مرنے کے وقت حق کی گواہی دینے کی توفیق عطا فرماتا ہے۔ اور منکر نکیر کے سوال کرنے کے وقت اس کی زبان پر حق کو لاتا ہے۔&&(فتح الرحمن )&&جب مومن، منکر نکیر کو صحیح جواب دیتا ہے تو وہ دونوں فرشتے مومن کو اس طرح دعا ء دیتے ہیں کہ ’’اللہ تجھے اچھی بات پر ثابت قدم رکھے۔‘‘&&(فصل الخطاب )&&{{امیر المومنین حضرت علی علیہ السلام نے فرمایا:’’حق پر قیام قبر میں نمایاں طور پر ظاہر ہوگا۔‘‘اور اس آیت سے مراد یہی موقع ہے۔‘‘&&(تفسیر علی ابن ابراہیم )&& }}!!تفسیر عارفانہ:اہل ایمان کو توحید اور کلمہ توحید کودل سے مان لینے کی وجہ سے زندگی بھر اور پھر مرنے کے بعد سیر فی الحقائق کی قدرت خدا عطا فرماتا ہے۔ اربابِ احوال کی سیر انوار ذکر کی برکت سے اللہ ثابت رکھے گا۔ وہ ہمیشہ ملکوت السموٰات والارض سیر کرتے رہیں گے ۔ بلکہ انوارِ ذکر کے پروں کی طاقت سے جبروت کے عالم میں اُنہیں پرواز کی طاقت بخش دی جائے گی۔&&(تاویلات نجمیہ )&&{{جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  اس طرح دعا فرمایا کرتے تھے!’’اے اللہ!میں بخل ، بزدلی، رذیل عمر، دجال کے فتنے اور عذابِ قبر سے پناہ مانگتا ہوں ۔‘‘&&(روح المعانی )&& }}خدا کافرمانا کہ:@@’’اللہ ایمانداروں کو ثابت قدم رکھتا ہے‘‘@@یعنی اُن پر شیطان کے بہکانے کا اثر اتنا نہیں ہوتا کہ وہ مرتے دم ایمان پرقائم نہ رہ سکیں ۔ اسی لیے وہ مرتے دم تک ایمان پر قائم رہتے ہیں جب منکر نکیر اُن سے سوال کرتے ہیں تو اُس کاجواب صحیح دیتے ہیں ۔ ثابت قدمی کے ساتھ اُن کو مطمئن کرتے ہیں ۔ ثابت قدمی کی یہی تفسیر بہت سی حدیثوں میں بھی آئی ہے۔ مثلاً طبرانی اور ابن مردویہ نے اس کو نقل کیا ہے۔
  14,28,آیت نمبر۲۸: ’’بوارِ‘‘کے اصلی معنی زیادہ کھوٹے ہونے کے ہیں ۔ اب کیونکہ کسی چیز میں زیادہ کھوٹ ہونا اُس کی ہلاکت کاباعث ہوتا ہے اس لیے بوار کے دوسرے معنی ہلاکت اور بربادی کے ہوجاتے ہیں ۔ &&(لغات القرآن نعمانی جلد ص۵۱ )&&
  14,29,آیت نمبر۲۹: خدا کی (سب سے بڑی ) نعمت اہلبیت رسول صلی اللہ علیہ و آلہ وسلم  ہیں :آیت کے آخری الفاظ ’’جہنم بہت ہی برا ٹھکانا ہے‘‘ اس ٹھکانے (قرار ) کے لفظ نے بتا دیا کہ کفر اور انکار کرنے والے صرف جہنم سے گذارے نہیں جائیں گے، بلکہ جہنم اُن کے لیے ہمیشہ ہمیشہ رہنے کی جگہ ہوگی۔ &&(الامان، الحفیظ .تفسیر کبیر )&&
  14,30,آیت نمبر۳۰:شرک کی قسمیں : (۱ ) شرک کی کئی قسمیں ہیں جیسے ستارہ پرستی۔ یعنی ستاروں کو فاعِل حقیقی، مستقل موثر اور کائنات کے نظام میں خدا کاشریک سمجھنا۔ (۲ ) شرک کی دوسری شکل اوتار پرستی کی ہے۔ اس کے معنی یہ ہیں کہ خدا فلاں شخص یا بزرگ یا جانور کے جسم میں داخل ہوگیا۔ (۳ ) شرک کی تیسری شکل اُمرا اور بادشاہوں کو ہر قسم کے نفع نقصان کامالک سمجھ لینا ہے۔ اُنہی سے تمام توقعات وابستہ کرلینا ہے۔ &&(ماجدی )&&[[بتوں سے تجھ کو امیدیں خدا سے نومیدی۔مجھے بتا تو سہی اور کافری کیا ہے؟]]&&(اقبال )&&اب خدا کایہ فرمانا کہ@@’’اچھا (کچھ دن اور ) مزے اُڑالو‘‘@@۔تو یہ بات یاد رہے کہ دنیا دار عمل ہے، داراالجزاء نہیں ۔ اس لیے دنیا میں سخت سے سخت کافر و مشرک اور فاسق بھی سزائے خدا وندی سے بچ سکتا ہے۔{{حضرت علی علیہ السلام  سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا کہ:’’بدترین اور فاجر ترین گروہوں نے تم سے برائی کرنے کا ارادہ کیا تو تم نے اُن کو پہلے بدر میں مزہ چکھا یا۔ پھر خدا نے اُن کو کچھ دن زندگی (گذارنے اور ) مزہ اڑانےکی مہلت دی‘‘۔&&(روح المعانی )&& }}
  14,31,آیت نمبر۳۱:قیامت کے روز اعمال کی خرید وفروخت نہ ہوگی:مطلب یہ ہے کہ نیک عمل بکائو مال نہیں ۔ اس لیے وہاں دوستی کے سبب کوئی رعایت نہ کرے گا۔ &&(موضح القرآن )&& قیامت میں کوئی دوستی یاکسی قسم کے کوئی تعلقات کام نہ آئیں گے۔&&(تفسیر علی ابن ابرہیم )&&خدا کایہ فرمانا کہ:@@’’میرے ان بندوں ‘‘@@ (عبادی ) یعنی خدا کا ہمیں اپنا بندہ فرمانا@@’’میرے بندے‘‘ @@کہنا، ہماری انتہائی عزت افزائی اورہمارا عظیم شرف ہے۔ &&(ماجدی )&&!!آیت کاپیغام:آیت کاپیغام یہ ہے کہ :اہل ایمان کاطریقہ زندگی کافروں کے طریقہ زندگی سے مختلف ہونا ضروری ہے کیونکہ کافر کفرِ نعمت (نعمت سے انکار ) کرتا ہے۔ اور مومن شکر ادا کرتا ہے۔ شکر کا عملی طریقہ یہ ہے کہ مومن نماز پڑھے اور اپنا مال خدا کی راہ میں خرچ کرے۔ &&(تفہیم القرآن )&&{{ امیر المومنین حضرت علی ابن ابی طالب علیہ السلام  علیہ السلام فرماتے ہیں کہ:<<’’اقل مایلزمکم اللہ ان لاتستعینوا بنعمہٖ علی معاصیہٖ‘‘>>یعنی (اللہ کاتم پر کم سے کم حق جو عائد ہوتا ہے وہ یہ ہے کہ اُس کی عطا کردہ نعمتوں سے گناہوں میں مدد نہ لو ) &&(نہج البلاغۃ ص ۹۲۴ )&&}}عبادی:’’میرا بندہ‘‘خداکاہم گناہگاروں کو اپنا بندہ (عبادی ) فرمانا اُس کابہت بڑا کرم ہے۔ اس لیے کہ اصولِ فقہ کاقاعدہ ہے کہ اگر کوئی شخص اپنے غلام کو بیٹا (یاولد، یا،ابن ) کہدے تو غلام آزاد نہیں ہوتا لیکن اگر اُسے ’’ولدی‘‘یا’’ابنی‘‘ یعنی’’میرا بیٹا‘‘ کہہ دے تو وہ آزاد ہوجائے گا، بوجہ اضافت کے ۔یعنی میرا بیٹا کہنے کی وجہ سے ۔ اس قاعدے کی روسے خدا نے ہم گنہگاروں کو اپنا بندہ’’عبادی‘‘ فرماکر اپنے مومن بندوں کو جہنم سے آزاد فرمادیا۔نیز یہ کہ بندگی سے بڑا کوئی عہدہ نہیں ۔ اپنا بندہ کہہ کر عظیم عزت سے نوازا۔&&(روح البیان )&& }}دوسری مدح مومنین کی یہ کی گئی کہ اُن کی مومنین کہہ کر مخاطب فرمایا۔ شکر کی ترغیب دے کر کفر نعمت کی آفت سے بچایا۔ &&(تھانوی )&&
  14,33,آیت نمبر۳۳:تسخیر کے معنی کسی چیز کوکسی کے قبضے یا قابو میں دینا ہے لیکن مشاہد اور وجدان یہ ہے کہ چاند اور سورج ہمارے قابومیں نہیں ہیں اس لیے یہ بات سمجھ میں آتی ہے کہ مستقبل میں انسان ارتقا کی کسی منزل پر ضرور چاند اور سورج کو قابومیں کر لے گا۔ البتہ روحانی طاقتوں کے بل پر کچھ ہستیاں ایسی تھیں جن کی حکمرانی چاند اور سورج پر بھی چلتی تھی۔۔۔۔&&(فصل الخطاب )&& (شق القمر اور ردِ شمس کاواقعہ رسول خداصلی اللہ علیہ و آلہ وسلم  اور وصی رسول صلی اللہ علیہ و آلہ وسلم  سے منسوب ہے )
  14,34,آیت نمبر۳۴:اللہ کی بے انتہا نعمتیں اور اُن کی عظمت:حضرت سماک جو ایک عظیم عارف انسان تھے ایک بادشاہ کے پاس اپنے کسی کام کے لیے تشریف لے گئے ، اُس وقت بادشاہ پانی کا ایک گلاس پینے کے لیے ہاتھ میں لیے بیٹھا تھا۔ بادشاہ نے حضرت سماک سے عرض کیا کہ مجھے کوئی نصیحت فرمائیں ۔ حضرت سماک نے فرمایا:’’ اگر ایسی سخت پیاس ہوکہ آپ جاں بلب ہورہے ہوں او رکوئی یہ کہے کہ ساری سلطنت مجھے دے دو تب پانی پلائوں گا، تو کیا آپ اپنی ساری سلطنت کے بدلے وہ پانی کاگلاس لینا پسند فرمائیں گے ؟بادشاہ نے کہا:’’تمام سلطنت جان سے زیادہ پیار ی نہیں ہوسکتی۔ میں اُسے ساری بادشاہی دینا منظور کرلوں گا۔ آپ نے فرمایا:’’جب صرف پانی کاایک پیالہ آپ کی ساری شاہی اور بادشاہی کی قیمت ہے تو پھر ایسی بادشاہی کاکیا اعتبار؟‘‘ اس سے معلوم ہوا کہ پانی خدا کی ایسی عظیم نعمت ہےجس پر بندہ ساری خدائی قربان کرسکتا ہے پھر دیگر نعمتوں کاکیا کہنا؟انسان تو ایک سانس کی نعمت کی قیمت ادا نہیں کرسکتا۔ ایک سانس اگر بند ہوجائے تو انسان اُس ایک سانس کو حاصل کرنے کے لیے ساری خدائی قربان کردے گا۔ اس سے ثابت ہوا کہ خدا کی نعمتوں کاشمار نہیں ہوسکتا۔ &&(روح البیان )&&حضرت دائود علیہ السلام نے عرض کیا:’’اے خدا!میں تیری نعمتوں کاشکریہ ادا نہیں کرسکتا۔ اس لیے کہ اگر صرف ایک سانس لینے کی نعمت کاشکر ادا کرنا چاہوں تو مجھ پر لازم ہوگا کہ ایک سانس لوں تو دوسجدے شکر کے ادا کروں ۔ اس لیے کہ ایک سانس میں دو نعمتیں پنہاں ہیں ایک سانس کاجسم میں داخل ہونا، اور پھر اُس کاخارج ہونا۔ جب صرف ایک سانس کا شکرادا نہیں کرسکتا تو دوسری تمام نعمتوں کاشکر کیسے ادا کرسکوں گا۔‘‘&&(زبور )&&{{حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ خداوند عالم نے حضرت موسیٰ علیہ السلام سے کہا:’’ تم میرا ایسا شکریہ ادا کرو جس کامیں مستحق ہوں ۔‘‘حضرت موسیٰ یہ حکم سن کر رونے لگے اور مسلسل گڑگڑاتے رہے کہ’’بارالہٰا!مجھے اس حکم سے معاف رکھ۔‘‘جب تین دن گذر گئے تو خدا وند عالم نے وحی کی کہ:’’موسیٰ!تم نے حق شکر ادا کردیا۔ اس لیے کہ جب تم نے اس بات کااعتراف کرلیا کہ میں خدا کاشکرادا نہیں کرسکتا تو تم نے حقیقت میں ایسا شکر ادا کیا جس کامیں مستحق اور سزاوار ہوں ۔‘‘&&(الکافی )&& }}نتیجے: (۱ ) اس آیت سے معلوم ہوتا ہے کہ ساری کائنات انسان کی خدمت کے لیے پیدا کی گئی ہے گویا اصل مقصود حضرتِ انسان ہے، باقی ساری کائنات انسان کے طفیل میں پیدا ہوئی ہے۔ نہ تو زمیں کے لیے ہے نہ آسماں کے لیے جہاں ہے تیرے لیے تو نہیں جہاں کے لیے (۲ ) خدا کی سب سے عظیم نعتیں خدا کی معرفت اور اُس کے دین کو سمجھنا ہے۔ (۳ ) جب انسان خدا کی نعمتوں کی ناشکری کرتا ہے تو وہی نعمتیں اُس کے لیے عذاب بن جاتی ہے۔&&(تاویلات نجمیہ۔ روح البیان )&&غرض اللہ کی نعمتیں تو اس قدر بے شمارہیں کہ اگر اُن کو گننے لگو تو گن نہیں سکتے مگر سچ یہ ہے کہ آدمی بہت بے انصاف ہے۔ بڑا ہی ناشکر ا ہے۔وہ کبھی اللہ کی نعمتوں کاشکر ادا نہیں کرتا۔ بلکہ اس کے برعکس کفر نعمت اور معصیت کرتارہتا ہے ۔ جیسا کہ خود آیت میں فرمایا ہے کہ:@@’’ حقیقت یہ ہے کہ انسان بڑا ظالم (بے انصاف ) حد سے بڑھ جانے والا، اور بڑا ہی ناشکرا ہے۔‘‘@@&&(تھانوی )&&یعنی انسان جو جو چیزیں مانگتا ہے مثلاً رزق، تندرستی ، مال ، گھر، دولت اور بیوی بچے وغیرہ۔ اُس نے یہ سب عطا فرمائیں ، بلکہ اگر شمار کرنا چاہو تو اُس کی نعمات حدوحساب سے باہر ہیں ۔ غالباً مقصود یہ ہے کہ جو چیزیں مانگتے ہیں ، اُس نے بے مانگے عطا فرمائی ہیں پس وہ لائق صد شکر ہے۔ &&(تفسیرانوار النجف )&&پھر یہ بھی فرمایا@@’’ اگر تم میری نعمتوں کا شکرادا کرو گے تو میں اُن میں اضافہ کردوں گا اور اگر کفرانِ نعمت کیا تو بلاشبہ میرا عذاب بھی بڑا سخت ہے۔‘‘@@&&(القرآن )&&
  14,35,آیت نمبر۳۵:نسلِ ابراہیمی علیہ السلام  کی فضیلت:{{ایک شخص حضرت امام جعفر صادق علیہ السلام کے پاس آیااور کہنے لگا کہ’’اگر آپ صلی اللہ علیہ و آلہ وسلم  اپنے باپ کے بیٹے ہیں تو یقیناً آپ علیہ السلام  بت پرستوں کی اولاد ہیں ۔ آپ علیہ السلام  نے فرمایا:’’تو نے جھوٹ بولا۔ اللہ نے حضرت ابراہیم علیہ السلام  کو یہ حکم دیا تھاکہ اسماعیل علیہ السلام  کو مکے لاکر آباد کریں ۔ اُنہوں نے ایسا ہی کیا۔ پھر اُنہوں نے خدا سے عرض کی: ’’اے میرے پالنے والے مالک !اس شہر (مکہ ) کو امن وامان کاشہر بنادے اور مجھے اور میری اولاد کو اس بات سے بچائے رکھ کہ ہم بتوں کو پوجیں ‘‘پس اوالادِ اسماعیل علیہ السلام  میں سے کسی نے بت نہیں پوجا۔ ہاں عرب ضرور بت پرست تھے۔ اولادِ اسماعیل علیہ السلام  میں جو کافر بھی ہوگئے تھے وہ بھی (بتوں کو نہیں پوجتے تھے ، بلکہ ) یہ کہتے تھے۔<<’’ ھولآ ء شفعآ ء نا‘‘>> (یعنی )’’یہ بت ہماری خدا سے شفاعت کریں گے۔‘‘ مگر اُنہوں نے بُت پوجے نہیں ۔‘‘&&(تفسیر صافی ص ۲۶۶ بحوالہ تفسیر قمی )&& }}{{امیرالمومنین حضرت علی بن ابی طالب علیہ السلام نے فرمایا کہ:’’خدا نے حضرت ابراہیم علیہ السلام  سے یہ ارشاد فرمایا:<<’’ لاینال عھدی الظلمین۔‘‘>> (یعنی)’’میری طرف کاعہدہ امامت ظالموں کو نہیں ملے گا۔‘‘ اب کیونکہ خدا نے خود شرک کو سب’’سے‘‘ بڑا ظالم قرار دیا ہے جیسا کہ خود ارشاد فرمایا ہے۔ <<’’ان الشرک لظلم عظیم‘‘>>&&(یعنی )&&@@‘‘ شرک یقیناً سب سے بڑا ظلم ہے۔‘‘@@پس حضرت ابراہیم علیہ السلام سمجھ گئے کہ امامت کاعہدہ نہ پاسکیں گے جو بت پوجیں گے اس لیے اُنہوں نے دعا کی’’اےاللہ! میری اولاد کو اس بات سے بچالے کہ بتوں کو پوجیں ۔‘‘}}&&(احتجاج طبرسیؒ )&&{{جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا’’ حضرت ابرہیم علیہ السلام  کی یہ دعا مجھ تک اور میرے بھائی علی علیہ السلام  تک پہنچی کہ ہم دونوں میں سے کسی نے کبھی کسی بت کو سجدہ نہیں کیا۔ پس اللہ نے مجھے نبیصلی اللہ علیہ و آلہ وسلم  بنایا اور علی علیہ السلام  کو میرا وصی بنایا۔‘‘&&(امالی )&& }}البتہ یہ بھی حقیقت ہے کہ حضرت ابراہیم علیہ السلام  کی اولاد میں بہت سے کافر اور مشرک بھی نظر آتے ہیں ۔ مگر یہ بھی حقیقت ہے کہ اولادِ ابراہیم علیہ السلام  میں ہر دور میں ایسے افراد ضرور رہے ہیں جن کی پیشانی کبھی معبود انِ باطل کے سامنے نہیں جھُکی ۔ وہی لوگ دعا ابراہیمی علیہ السلام  کے اصل مصداق ہیں ۔ &&(فصل الخطاب )&&اور ایسے افراد میں اکمل ترین افراد اہل بیت علیہ السلام  کی ذوات مقدسہ میں جن کے اعلیٰ ترین فرد حضرت علی علیہ السلام ہیں ۔ جن کو کرم اللہ وجہ، کہاجاتا ہے ۔ یعنی خدا نے اُن کے چہرے کو عزت بخشی کہ وہ کبھی غیر خدا کے سامنے نہیں جھُکا۔ &&(متفق علیہ )&&نتیجہ : جناب رسول خداصلی اللہ علیہ و آلہ وسلم  کے زمانے تک توحید کادامن اگر مضبوطی سے پکڑے رہنے والے کوئی تھے تو وہ حضرت ابراہیم علیہ السلام  کی اولاد میں سے تھے ۔ اسی لیے ہم اجدادِ رسول صلی اللہ علیہ و آلہ وسلم  کو مومن اور موحد مانتے ہیں ۔ &&(روح البیان )&&
  14,36,آیت نمبر۳۶:پیروی کرنے کانتیجہ:حضرت ابراہیم علیہ السلام  کی زبانی خدا کا یہ فرمانا کہ:@@’’جو میری پیروی کرتے ہوئے میرے راستے پر چلے گا، تو وہ حقیقتاً مجھ سے ہے۔‘‘ @@اس کی تفسیر فرماتے ہوئے {{حضرت امام محمد باقر علیہ السلام نے فرمایا:’’ جو شخص ہم (اہل بیت رسول صلی اللہ علیہ و آلہ وسلم) سے محبت رکھے گا۔ &&(یعنی ہماری محبت کی بنا ء پر ہماری پیروی کرے گا )&& وہ ہم اہل بیت علیہ السلام  میں شمار کیا جائے گا۔‘‘پوچھا گیا:’’کیا آپ علیہ السلام  کی طرح اہل بیت علیہ السلام  رسول صلی اللہ علیہ و آلہ وسلم  میں سے ہو جائے گا؟‘‘فرمایا:ہاں ، ہم میں سے ۔ کیا تم نے حضرت ابرہیم علیہ السلام  کایہ قول نہیں سنا:<<’’فمن تبعنی فانہ منی‘‘>> (جومیرے راستے پر چلے گا وہ حقیقتاً مجھ سے ہے ) ‘‘}}&&(تفسیر صافی ص ۲۶۶بحوالہ تفسیر قمی )&&{{حضرت ابراہیم علیہ السلام  کابتوں کے بارے میں فرمانا:’’مالک ان بتوں نے بہت سوں کو گمراہ کردیا ہے۔‘‘یہ مجازی کلام ہے کیونکہ بت بہت سے لوگوں کی گمراہی کاسبب بنتے ہیں ۔ اس لیے گمراہ کرنے کی نسبت اُن کی طرف دی گئی ہے۔ }}&&(ماجدی )&&حضرت ابراہیم علیہ السلام  کی انسان دوستی:اور آخر میں حضرت ابراہیم علیہ السلام  کا یہ فرمانا کہ:@@’’جومیرا کہنا نہ مانے تو بلاشبہ (اےخدا ) تو بڑا ہی بخشنے والا اور بے حد رحم کرنے والا ہے۔‘‘ یہ کلمات حضرت ابراہیم علیہ السلام  کی انتہائی شرافت شفقت، انسان دوستی اور نرم دلی کاثبوت ہیں ۔ وہ کسی بھی انسان کوکسی طرح عذاب الٰہی میں گرفتار ہوتا نہیں دیکھ سکتے تھے۔ وہ اپنے باغیوں تک کے لیے معافی کی درخواست فرمارہے ہیں ۔ یہ نہیں فرماتے کہ’’جو میرے خلاف چلے اُس کو سزا دیجیو، بلکہ فرمارہے ہیں کہ اُن کے لیے تو غفور ورحیم بن جاتا۔ حضرت ابراہیم علیہ السلام  کایہی حال اُس وقت ہوا جب قوم لوط علیہ السلام  پر عذاب لے کر فرشتے آئے۔ اُس وقت بھی خدا نے فرمایا کہ:@@’’ ابراہیم علیہ السلام  ہم سے جھگڑنے لگا‘‘@@<<(یجادلنا فی قوم لوطِ )>>&&(ہود ۱۱۸ )&&’’اگر حضور ان کو سزادیں تو یہ آپ کے بندے ہیں۔ اور اگر معاف کردیں تو آپ بالادست اور حکمت سے کام لینے والے ہیں ۔ &&(مائدہ ۱۱۸ )&& &&(تفہیم القرآن )&& [[خدا کے بندے تو ہیں ہزاروں بنوں میں پھرتے ہیں مارے مارے۔میں اُن کابندہ بنوں گا جن کو خدا کے بندوں سے پیار ہوگا]]۔&&(اقبال )&&اسماعیل حقی فرماتے ہیں کہ میرے شیخ نے فرمایا:’’دنیا کے طالب بہت ہیں ۔ مگر آخرت کے طالب بہت کم ہیں ۔ اور طالبِ مولیٰ (خدا کے طالب ) اس قدر کم ہیں جیسے سلاطین و ملوک کم ہوتے ہیں (اور عوام بے شمار ہوتے ہیں) اسی طرح اولیا خدا عوام کی بہ نسبت بہت کم ہوتے ہیں ۔ (اور اولیائے خدا طالبانِ مولیٰ ہوتے ہیں ) &&(روح البیان )&&نکتہ:{{حضرت ابرہیم علیہ السلام  علیہ السلام کایہ فرمانا کہ:’’اور جو میرا کہنا نہ مانے تو بلاشبہ (اے خدا ) تو بڑا بخشنے والا اور بےحد رحم کرنے والا ہے‘‘حضرت ابرہیم علیہ السلام  نے یہ نہ فرمایا کہ:@@’’جس نے تیرا کہنا نہ مانا‘‘@@بلکہ فرمایا:@@’’جس نے میرا کہنا نہ مانا۔‘‘@@ اس طرح خدا کی بارگاہ میں ادب بھی فرمایا اور گناہگاروں کے گناہ کو ہلکا فرماکر مغفرت اور رحمت کی درخواست کی ۔پھر خود اپنی شرافت کابھی ثبوت دیا، اور گناہگاروں کی معافی کا بھی بندوبست فرمایا کہ جب میں اپنے گناہگاروں کو معاف کرسکتا ہوں تو اے خدا!تیری مغفرت اور رحمت کی تو کوئی انتہا ہی نہیں ہے۔}} &&(تاویلات نجمیہ )&&رحمت خداوندی:{{جناب رسول صلی اللہ علیہ و آلہ وسلم  نے فرمایا کہ:’’قیامت کے دن اللہ کی طرف سے اعلان ہوگا کہ: ’’اے محمدصلی اللہ علیہ و آلہ وسلم  مصطفےٰ کی اُمت !جومیرا ذاتی حق ہے وہ میں نے تمیں معاف کیا۔اب اُس کے جو تبعات ہیں وہ تم ایک دوسرے کو معاف کردو اور میری بہشت میں داخل ہوجائو۔‘‘&&(روح البیان )&& }}{{امیر المومنین حضرت علی بن ابی طالب علیہ السلام  علیہ السلام نے اپنی دعامیں عرض کیا:’’اے خدا!اگر تیری رحمت صرف اطاعت کرنے والوں کے لیے ہے، تو گنہگاروں کو بخشنے والا کون ہے؟‘‘میں گنہگار، سیہ کار، خطا کارمگر۔کس کوبخشے تیری رحمت جو گنہگار نہ ہو؟}}
  14,37,آیت نمبر۳۷:حضرت ابراہیم علیہ السلام کی دُعا:حضرت ابرہیم علیہ السلام  کا اپنی اولاد کے لیے یہ دعا۔ فرمانا کہ:’’اے ہمارے پروردگار!تو کچھ لوگوں کے دلوں کو ایسا کردے کہ وہ اُن کی طرف جھُکنے لگیں ۔‘‘ اس سلسلے میں{{ امیرالمومنین حضرت علی علیہ السلام نے فرمایا:’’کچھ لوگوں کے دل ہماری طرف جھُکتے ہیں کیونکہ حضرت ابراہیم علیہ السلام  کی دُعا یہی تھی۔کہ’’اے ہمارے پالنے والے مالک!کچھ لوگوں کے دلوں کو ایسا کردے کہ وہ اُن کی طرف (یعنی میری اولاد کی طرف ) جھکنے لگیں ۔‘‘&&(تفسیر صافی ص ۲۶۶بحوالہ احتجاج طبرسی )&& }}{{حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ:’’حضرت ابراہیم علیہ السلام  کی مراد بیت اللہ نہ تھا۔ اگر بیت اللہ مراد ہوتا تو آپ علیہ السلام :<<’’تھویْ الیہ‘>> فرماتے۔ (یعنی الیھم جو ضمیر جانداروں کی طرف اشارہ کرتی ہے، نہ فرماتے ) خدا کی قسم!حضرت ابراہیم علیہ السلام  کاتسلسل ہی ، اسی لیے دررد میں آل ابراہیم علیہ السلام  کے ساتھ ساتھ آل محمدصلی اللہ علیہ و آلہ وسلم  پر درود پڑھا جاتا ہے ) &&(کافی )&& }}<<''اللھم صل علی محمد وعلیٰ اٰل محمد کما صلیت علی ابراہیم، وعلیٰ اٰل ابراہیم‘‘>>&&(قرآن مجید ترجمہ مولانا حافظ فرمان علیؒ )&&جب حضرت ابراہیم علیہ السلام  دعا مانگ چکے تو خدا کاحکم ہوا کہ اب کوہِ ابوقبیس پر چڑھ کر لوگوں کو حج پر آنے کے لیے بلائو۔ خدا نے اپنی قدرت سے مشرق سے مغرب تک آپ کی آواز پہنچادی۔قیامت تک پیدا ہونے والوں میں سے جن جن لوگوں کی ارواح نے آپ کی آواز پر لبیک کہا، وہی لوگ حج پر جاتے ہیں ۔‘‘&&(تفسیر برہان )&&یہ حضرت ابراہیم علیہ السلام  کی اسی دعا کی برکت ہے کہ دنیا بھر کے لوگ کھنچ کھنچ کر مکہ آتے ہیں اور ہرزمانے میں ہر طرح کے پھل، غلے اور تمام سامانِ رزق مکہ میں موجود پاتے ہیں ، حالانکہ اس وادی میں جانوروں کے لیے چارہ تک نہیں اُگتا۔ &&(تفہیم )&&عرفا کے نزدیک :<<''بیتک المحرم‘‘>>@@''تیرا پاک محترم گھر‘‘@@سے مراد مومن کا قلب:ہے اور یہ محترم اس لیے ہے کہ اس میں غیر اللہ کاداخلہ حرام ہے۔ جیسا کہ حدیث قدسی میں ہے کہ خدا نے ارشاد فرمایا:@@’’میں نہ زمین میں سما سکتا ہوں نہ آسمان میں ۔ میرا گھرمومن کاقلب ہے۔‘‘@@&&(تاویلات نجمیہ )&&کعبہ اگرچہ ٹوٹا تو کیا جائے غم ہے شیخ ۔کچھ قصرِ دل نہیں کہ بنایا نہ جاسکے۔دل بدست آور کہ حجِ اکبر است۔یعنی :مومن کادل خوش کرنا حج اکبر کاثواب رکھتا ہے۔ &&(سعدی )&&حضرت ابراہیم علیہ السلام نے یہ دعا مانگی تو اُس وقت یہ گھر نہ بناتھا، بلکہ جب اسمٰعیل علیہ السلام جو ان ہوئے تو (دونوں باپ بیٹے نے ملکر اس گھر کو بنایا ) مقصد یہ ہے کہ تیرے بننے والے گھر کے قریب میں اپنی ذریت کو چھوڑ کر جارہا ہوں کیونکہ حضرت ابراہیم علیہ السلام  کو یہ بات معلوم تھی کہ یہاں بیت اللہ پہلے موجود تھا، پس طسم وجدیس کے قبیلوں نے منہدم کردیاتھا۔ یایہ کہ طوفان نوح علیہ السلام  کے زمانہ میں اوپر اٹھا لیاگیا تھا۔ پس یہاں گھر سے مرا دہے، گھر کا مقامِ وقوع‘‘اور لوگوں کے دلوں کو مائل کرنے کی دعا ء اس لیے کی تاکہ اُن کی روزی کشادہ ہو، ورنہ اگر لوگوں کے دل حج وعمرہ کی غرض سے یا تجارت کی نیت سے اس طرف مائل نہ ہوِ تو وہاں کے لوگوں کے لیے زندگی مشکل ہوجائے۔ من الناس پر من بعضیہ لگا دیا پس دعا ء کو مسلمانوں کے لیے خاص کردیا ورنہ یہود و نصاریٰ ومجوس کی کثرت سے مکہ میں جگہ تنگ ہوجاتی۔ &&(تفسیر انوارالنجف )&&
  14,38,آیت نمبر۳۸:دعا کی ضرورت:خدا ہماری تمام حاجتوں تمنائوں ، خوابوں اور آرزوئوں کو خوب اچھی طرح جانتا ہے، خواہ ہم اُنہیں ظاہر کریں یا چھپائیں ۔ اب سوال یہ رہ جاتا ہے کہ پھر دُعا مانگنے کی کیا ضرورت ہے؟ دُعا مانگنے کے اوّلین مقاصد: (۱ ) اظہار عبدیت اور (۲ ) اپنی محتاجی کااعتراف کرنا ہے۔ (۳ ) نیز دعا کے ذریعہ سے خدا سے قلبی تعلق پیدا کرنا مقصود ہوتاہے۔ (۴ ) اپنے کبر و سرکشی کو کچلنا بھی دُعا کاایک اہم مقصد ہوتا ہے۔ (۵ ) اپنے اندر سے احساسِ تنہائی کو دور کرنا اور اپنے اندر (۶ ) خدا کی پناہ میں محفوظ ہونے کااحساس جگانا بھی دُعا کااہم مقصد ہے۔ &&(مولف)&&علم خدا کی وسعت:محققین نے اس آیت سے یہ بات ثابت کی ہے کہ: خدا کاعلم صرف کلیات ہی پرمحیط نہیں ، بلکہ جزئیات پر بھی حاوی ہے۔ اس لیے ہندوستان اور یونان کے اُن فلاسفا کا نظریہ غلط ہے جو یہ سمجھتے ہیں کہ خدا کاعلم صرف کلیات پر حاوی ہے، جزئیات پر حاوی نہیں ۔ &&(ماجدی )&&
  14,39,آیت نمبر۳۹:حضرت ابراہیم علیہ السلام  کو بڑھاپے میں اولاد عطا ہوئی:تفسیر مجمع البیان میں ہے کہ:جب حضرت ابراہیم علیہ السلام  کی عمر ۹۹برس تھی تو حضرت اسماعیل علیہ السلام  پیدا ہوئے۔ اور جب آپ علیہ السلام  کی عمر ۱۱۲برس تھی تو حضرت اسحاق علیہ السلام  پیدا ہوئے۔ اس سے معلوم ہوتا ہے کہ حضرت اسماعیل علیہ السلام  حضرت اسحاق علیہ السلام  سے سن وسال میں ۱۳برس بزرگ تھے۔ اور حضرت ابراہیم علیہ السلام  کاایک تیسرا بیٹا بھی بعض کتب میں منقول ہے جن کانام مدین تھا۔&&(تفسیر انوارالنجف )&&
  14,41,آیت نمبر۴۱:حضرت ابراہیم علیہ السلام  کی دعا:اہل سنت کے عظیم مفسر صاحبِ ’’جلالین‘‘ نے اس آیت پر یہ نوٹ لکھا ہے کہ ‘‘حضرت ابراہیم علیہ السلام  نے یہ دُعا اُس وقت فرمائی تھی جب اُنہیں یہ پتہ نہ تھا کہ اُن کے والدین اللہ کے دشمن ہیں ۔‘‘حالانکہ تمام مفسرین نے یہ بھی لکھا ہے کہ جب حضرت اسماعیل علیہ السلام  پیدا ہوئے تھے تو حضرت ابراہیم علیہ السلام  کی عمر ۹۹سال تھی، اور جب حضرت اسحاق علیہ السلام  پید اہوئے تھے تو حضرت ابراہیم علیہ السلام  کی عمر۱۱۲سال تھی۔ مگر اس کے باوجود اُن کو معلوم نہ ہوسکا کہ اُن کے والدین خدا کے دوست تھے یادشمن تھے۔ لیکن صاحبِ ’’جلالین‘‘ کو معلوم ہوگیا کہ وہ خدا کے دشمن تھے &&(فصل الخطاب )&&اصل یہ میں آیت اس بات کی واضح دلیل ہے کہ حضرت ابراہیم علیہ السلام  کے اصل والدین مومن تھے ۔ اور اُن کے پالنے والے آذر اُن کے چچا تھے۔ اس لیے قرآن نے آزر کو ’’اب‘‘کہا ہے، والدین نہیں کہا۔ اس سے بھی معلوم ہوا کہ آزر طبعی باپ نہ تھے۔ &&(تبیان )&&تاریخ سے یہ بات ثابت ہے کہ حضرت ابراہیم علیہ السلام  کے والدماجد کانام ’’تارخ‘‘تھا اور اس آیت میں والدین سے مراد اصل ماں باپ ہیں جو اہل ایمان میں سے تھے۔&&(تفسیرتبیان، تفسیر کبیر امام رازی )&&’’غفر‘‘کے اصل معنی رحمتِ خدا کاڈھانپ لینا ہوتا ہے۔ اور رحمتِ خدا کی ضرورت جس طرح غیر معصوم کو ہوتی ہے اُسی طرح معصوم کوبھی ہوتی ہے۔ اس لیے حضرت ابراہیم علیہ السلام  کااپنے لیے مغفرت طلب کرنا’’اُن کے غیر معصوم ہونے کو ثابت نہیں کرتا۔&&(ماجدی )&&{{جناب رسول صلی اللہ علیہ و آلہ وسلم  نے فرمایا:جس نے اپنی دعا میں مومن مرد اور مومنہ عورت کو شامل کیا اُس کی دعا قبول ہوگی۔‘‘ (مومنین کے لفظ میں تمام مومن عورتیں بھی شامل ہیں ) &&(روح البیان )&& }}امام جماعت کے لیے یہ مکروہ ہے کہ وہ نماز میں صیغہ واحد کے ساتھ اپنے لیے دعا کرے اُس کو دعا میں جمع کاصیغہ استعمال کرنا چاہیے تاکہ اُس کی دعا میں سب شامل ہوجائیں ۔ {{جناب رسول صلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’جو شخص کسی قوم کی امامت کرتا ہے اور دُعا میں صرف اپنے لیے دعا کرتا ہے اور جماعت کواپنی دعا میں شامل نہیں کرتا تو وہ اُن سے خیانت کرتا ہے۔‘‘&&(اسرار المحمدیہ )&& }}{{جناب رسول صلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’دعا میں جتنے مرد اور عورتیں اہل ایمان کو شامل کیاجائے گا اُس کی گنتی کے مطابق دعا کرنے والے کے نامہ اعمال میں نیکیاں لکھی جائیں گی‘‘&&(روح البیان )&&تفسیر عارفانہ:’’ربنا اغفرلی‘‘یعنی:اے ہمارے خدا!مجھے اپنی رحمت میں ڈھک لے‘‘یعنی:میں تیری رحمت میں اس طرح ڈھک جائوں کہ اپنے وجود کو بھی نہ دیکھ سکوں ، تاکہ میرا وجود میرے اور تیرے درمیان حجاب نہ رہے۔ &&(تاویلات نجمیہ )&& }}حضرت ابراہیم علیہ السلام  نے اپنی دعائے مغفرت کو قیامت کے دن سے مقید اس لیے فرمایا کہ وہی آخری دن ہے جب محاسبہ سے نجات ملے گی۔ اس لیے کہ انسان جب تک گناہوں سے پاک نہ ہو اُس وقت تک بلند درجات سے نہیں نوازا جائے گا۔ اس لیےا ہم شئے کو مقدم کیا، اور اُس دن کی تقدیم لازمی تھی۔ حضرت ابوبکر واسطیؒ نے فرمایا کہ انسان کواگر تین دولتیں نصیب ہوجائیں تو اُس جیسا خوش نصیب کوئی نہ ہوگا۔ (۱ ) زندگی بسر ہو تو خدا کی اطاعت میں بسر ہو۔ (۲ ) موت آئے تو کلمہ شہادت (زبان ) پر ہو۔ (۳ ) حشر نشر کو اُٹھے تو ملائکہ اُسے جنت کی خوشخبری سنائیں ۔ &&(روح البیان )&& {{ تفسیر برہان میں اختصاصِ مفید سے مروی ہے کہ بنی امیہ میں سے ایک شخص جس کا نام سعد تھا، عبدالعزیز بن مروان کی اولاد میں سے تھا۔ حضرت امام محمد باقر علیہ السلام اُس کو سعد الخیر کے نام سے یاد فرماتے تھے۔ ایک دن وہ روتا ہوا آیا۔ آپ علیہ السلام نے فرمایا کیوں روتے ہو؟اُس نے عرض کی :میں قرآن میں مذکورہ شجرہ ملعونہ کا فرد ہوں ۔ آپ نے فرمایا :نہیں نہیں تم ہم میں سے ہو، اگرچہ نسل کے لحاظ سے اُموی ہو! دیکھو!حضرت ابراہیم علیہ السلام  کی دعا میں ہے کہ:’’جو میری اطاعت کرے گا وہ مجھ سے ہے۔ حضرت ابراہیم علیہ السلام  کا اپنے والدین کے لیے دعاء کرنا اُن کے مومن ہونے کی دلیل ہے، کیونکہ مشرک کی بخشش کی دعا بالکل عبث ہے۔ (اور پیغمبر خدا علیہ السلام  کوئی کام یا دعا عبث نہیں کرسکتے ) &&(تفسیر انوار النجف )&&}}
  14,42,آیت نمبر۴۲:ھولِ محشر:<<لیوم تشخص>>:یعنی محشر کے ھول وہیبت کی وجہ سے لوگوں کی آنکھیں کھلی کی کھلی رہ جائیں گی اور بلانے والے کی آوازکی طرف جلدی سے دوڑتے ہوئے جائیں گے۔ اور اُن کے سر بلند ہوں گے آنکھیں آسمان کی طرف لگی ہوں گی۔ نیچے دیکھنے کی ہمت تک نہ ہوگی۔اور تحیر و رعب کی وجہ سے آنکھیں بند ہونا تو درکنار جھپکائی بھی نہ جاسکیں گی۔ اور ان کے دل ہر محبت ، تعلق اور رشتے سے بالکل خالی ہوں گے جس طرح آسمان و زمین کے درمیان ہوا کی حالت ، جنت وجہنم کاتصّور تک اُن کے دل سے اڑجائیگا، صرف ہیبت ورعب ہی کامنظر ہوگا۔&&(تفسیر انوارالجف )&&
  14,45,آیت ۴۵ قرآن میں خدا نے پچھلی قوموں کے واقعات کو اس لیے بیان فرمایا ہے کہ ہم اُن کے تجربات سے فائدہ اٹھائیں ۔ کیونہ عقلمند انسان وہی ہوتا ہے جو دوسروں کے تجربات سے فائدہ اٹھاتا ہے۔ تاریخ پڑھنے کااصل مقصد ہی یہ ہوتا ہے کہ ہم دوسری قوموں کے (حالات سے ) تجربات اور کارناموں سے سبق حاصل کریں ۔ &&(ماجدی )&&{{امیرالمومنین حضرت علی بن ابی طالب علیہ السلام نے عقل کی تعریف یوں فرمائی ہے ’’العقل حفظ التجارب‘‘ (عقل تجربات کو یادرکھنے کانام ہے )&&&&(نہج البلاغۃ )&&}}{{حضرت امام حسین علیہ السلام نے ارشاد فرمایا:<<دراسۃ العلم لقاح المعوفۃ وطول التجارب زیادہ فی العقل والشرف فی التقویٰ والمقنوع راحۃ الابدانِ، احبک من نھاک ومن ابغضک اغراکیعنی:&&(علم کاسیکھنا معرفت کی پیداوار کاذریعہ ہے۔ اور طولانی تجربات عقل کی زیادتی کا باعث ہیں ۔ اور شرف کاانحصار تقویٰ پر ہے۔ اور قناعت بدن کی راحت کاسبب ہے جو تمہیں محبو ب رکھے گاوہ ناپسندیدہ باتوں سے تم کوروکے گا۔ اور جو تمہارا دشمن ہوگا وہ تم کو بُری باتوں پر اُکسائے گا۔ ۔‘‘>>&&(بلاغت الحسین )&& }}!! خدا کافرمانا کہ:@@’’ہم نے تمہیں اُن کی مثالیں بھی دی ہیں ۔‘‘@@یعنی ہم نے تمہیں گذرے ہوئے لوگوں کے کردار اور اُن کے نتائج بتائے۔ تاکہ تم لوگ اُن سے عبرت اور سبق حاصل کرو اپنے اعمال کو اُن کے اعمال پر قیاس کرکے اُن کے انجام پر اپنے انجام کاتصور کرو۔ تمہارے ساتھ نرمی برتی گئی ہے اور تمہیں ایک عرصے تک مہلت دی گئی ہے۔ اس لیے اس مہلت سے فائدہ اٹھائو۔ کفراور گناہوں سے بازآجائو۔&&(روح البیان )&&
  14,46,آیت نمبر۴۶ـ:خدا کے مقابلے پر کفار کی چالیں :پہاڑوں کا اپنے مقام سے ہٹ جانے کامحاورہ عربی ادب میں کسی چیز کے انتہائی قوت کے اظہار کے لیے استعمال کیاجاتا ہے۔ &&(تفسیر کبیر )&&مقصد یہ ہے کہ تم یہ دیکھ چکے تھے کہ تم سے پہلے کی قوموں نے خدا کے قوانین کو توڑا‘‘اور پھر اُس کے نتائج سے بچنے کے لیے اُنہوں نے نئی نئی چالیں چلیں ۔ مگر وہ اللہ کی ایک چال کابھی مقابلہ نہ کرسکے اور بُری طرح نقصان اٹھا کررہے۔ &&(ماجدی )&&اُنہوں نے انبیاء کرام کو ناکام بنانے کے لیے اور قوانین الٰہیہ کو توڑنے کے لیے کیسی کیسی زبردست چالیں چلیں ۔ مگر وہ اللہ کی ایک چال کابھی مقابلہ نہ کرسکے۔ یہ سب کچھ سننے، دیکھنے، سمجھنے کے باوجود بھی اگر تم حق کے خلاف چالیں چلتے رہے تو تمہارا حشر بھی وہی ہوگا جو ان کاہوا تھا(اس لیے کہ تم میں کوئی سرخاب کاپر نہیں لگا ہوا ہے کہ تم خدا کی تدبیر چال، یاسزاسے بچ سکو ) &&(تفہیم القرآن )&&
  14,47,آیت نمبر۴۷:خدا وعدہ خلافی نہیں کرتا:اس آیت کابظاہر تخاطب تو جناب رسول صلی اللہ علیہ و آلہ وسلم  کی طرف ہے لیکن اصل میں سنانا آپ علیہ السلام  کے مخالفین کو مقصود ہے کہ اللہ نے پہلے بھی جو وعدے اپنے رسولوں علیہ السلام  سے کیے تھے وہ سب کے سب پورے کیے اور رسولوں علیہ السلام  کے مخالفین حق کو نہ دبا سکے۔ بالکل اسی طرح خدا اب جو وعدے اپنے آخری رسول صلی اللہ علیہ و آلہ وسلم  سے فرمارہا ہے۔ وہ ضرور پورے کرے گا، اور اسلام کابول بالا کرکے رہے گا۔ &&(تفہیم القرآن )&&مطلب یہ ہے کہ خدا کے بارے میں ہرگز یہ نہ سوچ لینا کہ اُس نے جووعدے اپنے رسولوں  علیہم السلام سے کیے ہیں ، وہ اُن کے خلاف کرے گا۔ یعنی یہ ہرگز ممکن نہیں ہے کہ خدا ظالموں کو سزانہ دے گا اور اہل ایمان کی مدد نہ فرمائے گا۔ خدا ضرور ظالموں کوسزا دے گا اور ضرور مومنین کی مددفرمائے گا۔&&(روح البیان )&&خدا یہ بیان فرمارہا ہے کہ تم لوگ انہیں لوگوں کے مکانوں میں رہ رہے ہو۔‘‘جنہوں نے کفر اور انکارِ قیامت کرکے خو داپنےکو نقصان پہنچایاتھا۔اور تم کو خود یہ بات اچھی طرح تو اتر اخبار سے معلوم ہے کہ ہم نے اُن کوکیسی سخت سزا دی تھی۔ اب تم خود سمجھ سکتے ہو کہ ہماری باتوں کاانکار موجب سزا ہے۔ ہماری باتوں کی تصدیق واجب ہے ۔اُنہیں لوگوں کے واقعات جن کے گھروں میں تم رہتے ہو، تمہاری عبرت کے لیے کافی ہیں ۔ ہم اُنہیں کی مثالیں تمہارے سامنے بیان کررہے ہیں ۔ ہم نے جن لوگوں کو اُن کے کفر وانکار وسرکشی پر سخت سزائیں دی تھیں ، اُنہوں نے بھی بچنے بچانے کی بڑی بڑی تدبیریں کیں تھیں ، مگر اُن کی کوئی تدبیر، چالاکی ومکاری خدا کے مقابلے پر نہ ٹک سکی۔ حالانکہ اُن کی مکاریاں ایسی غضب کی تھیں کہ پہاڑ اپنی جگہ سے ہٹ جاتے۔ مگر پھر بھی حق ہی غالب رہا، اور اُن کی ساری بدمعاشیاں ملیامیٹ ہوگئیں ۔ اور وہ ہلاک وبرباد ہوگئے۔ &&(مرشد تھانوی )&&اس سے معلوم ہوگیا کہ (۱ ) حق وہی ہے جو انبیاء فرماتے ہیں ۔ (۲ ) اُنکا انکار ہو جب سزا ہے۔ (۳ ) اللہ نے اپنے وعدوں کے خلاف کبھی کوئی بات نہیں کی۔ (۴ ) خدا ضرور قیامت میں منکرین حق کوسخت سزا دےکر رہے گا۔ (۵ ) اللہ زبردست ہے اور پورا پورا بدلہ لینے والا ہے۔خدا کوبدلہ لینے سے کوئی نہیں روک ٹوک سکتا۔ (۶ ) البتہ ہماری مہلت اتنی طویل ضروری تھی کہ ہمیں یہ خیال ہوگیا کہ خدا اپنا وعدہ پورا نہیں کرے گا۔ &&(تھانوی )&& (۶ ) {{حضرت امام حسین علیہ السلام نے فرمایا:’’جوشخص خدا سے دنیا میں ڈرتا ہوگا، بس وہی قیامت کے دن امن وطمینان میں ہوگا۔ &&(بلاغت الحسین )&& }}
  14,48,آیت نمبر۴۸:قیامت کے دن زمین و آسمان جدید ہوں گے:{{حضرت امام زین العابدین علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’ٰیہ (ہماری ) زمین ایسی زمین سے بدل دی جائے گی جس پر گناہ نہ کیے گئے ہوں گے۔ جس پر نہ تو پہاڑہوں گے اور نہ نباتات ہوگی جیسی کہ یہ زمین ابتدا میں بنائی گئی تھی۔‘‘ &&(تفسیر صافی ص ۲۶۸بحوالہ تفسیر قمی وتفسیر عیاشی )&& }}{{حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’جب سے یہ زمین پیدا ہوئی ہے اولادِ آدم علیہ السلام  سے پہلے سات عالم گذر چکے ہیں جو اولادِ آدم علیہ السلام  سے نہ تھے۔ وہ یکے بعد دیگرے اسی زمین پر رہے۔ پھر حضرت آدم علیہ السلام آئے۔ اُن کی اولاد سے زمین آباد ہوئی۔ اور جب سے جنت پیدا ہوئی ہے وہ مومنین کی ارواح سے خالی نہیں رہی۔ اور جب سے دوزخ پیدا ہوئی ہے، وہ کافروں کی ارواح سے خالی نہیں رہی۔ کیا تم یہ سمجھتے ہو کہ اہل جنت کے جنت میں جانے کے بعد، اور اہل دوزخ کے دوزخ میں جانے کے بعدزمین پر خدا کی عبادت کرنے والا اور اُس کی عظمت کو بیان کرنے والا کوئی نہ ہوگا؟‘‘ایسا نہیں ہے۔ بلکہ خدا نرومادہ کے بغیر ایک اور مخلوق کو پیدا کرے گا جو خدا کی توحید اور بزرگی کو بیان کریں گے اور وہ زمین پر رہیں گے ، اُن پر آسمان بھی سایہ کرے گا۔ اسی لیے خدا نے ارشاد فرمایا ہے کہ: @@’’قیامت کے دن میں اس زمین کے علاوہ دوسری زمین اور اس آسمان کے علاوہ کوئی دوسرا آسمان لایاجائے گا۔‘‘@@&&(تفسیر صافی )&& }}محققین نے نتیجے نکالے کہ: (۱ ) قیامت کے دن زمین وآسمان بالکل نیست ونابود نہیں ہوجائیں گے صرف موجودہ نظام طبعی کودرہم برہم کردیاجائےگا۔ زمین وآسمان کی موجودہ ہیبت بدل دی جائے گی۔ دوسرے قوانین فطرت نافذ ہوں گے ، تمام مرے ہوئے انسان زندہ ہوجائیں گے او رخدا کے دربار میں حاضر کردیے جائیں گے ۔ یہ حشر نشر اسی زمین پر ہوگا۔ یہیں خدا کی عدالت قائم ہوگی۔ یہیں میزان نصب ہوگی۔ پھر زمین کاقصہ زمین ہی پر نمٹا دیا جائے گا۔ (۲ ) آیات واحادیث سے واضح طور پر یہ ثابت ہے کہ تمام انسان اسی جسم کے ساتھ زندہ کیے جائیں گے جس طرح آج زندہ ہیں ۔ ہر انسان کی پوری وہی شخصیت جذبات و احساسات ہوں گے جو وہ چھوڑ کردنیا سے رخصت ہوا تھا۔ &&(تفہیم القرآن )&& (۳ ) زمین وآسمان دودفعہ تبدیل ہوں گے پہلی دفعہ صرف ان کی صفت تبدیل ہوگی۔ جو پہلے نفح صور سے ہوگا۔ اُس وقت آسمان کے ستارے جھڑ جائیں گے اور سورج بے نور ہوجائے گا۔ چاند کی چاندنی ختم ہوجائے گی سارے کاسارا عالم دھوئیں کی شکل میں نظرآئے گا۔ زمین چٹیل میدان بن جائے گی پہاڑ ہوا میں بادلوں کی طرح اُڑتے نظر آئیں گے۔ دریا، ندی، نالے سب خاک میں مل جائیں گے ۔ درخت کٹ کر مٹی ہوجائیں گے۔ دوسرے صور پر آسمان کی حقیقت بدل جائے گی۔ یہ اُس وقت ہوگا جب محشر میں اہل محشر ٹھہریں گے ۔ زمین چاندی کی ہوگی اور آسمان سونے کا۔&&(قرطبی بحوالہ الافصاح بروایت حضرت علی علیہ السلام  )&&تفسیر عارفانہ:یعنی بشریت کی زمین قلب کی زمین سے بدل جائے گی۔ جس سے بشریت کی ظلمت کمزور پڑ جائے گی قلوب کے انوار غالب آجائیں گے ۔اسرارکے آسمان ، ارواح کے آسمانوں سے بدل دیے جائیں گے۔ اس لیے کہ جب ارواح کے سورج اسرار کے ستاروں پر چمکتے ہیں تو اُن سورجوں کی شعاعوں کے غلبے سے ستاروں کے انوار مٹ جاتے ہیں ۔ (اسی طرح جب تجلیات الٰہی وحقیقی کی تجلی ظاہر ہوگی تو وجود مجازی کی زمین فنا ہوجائے گی۔ بقول خدائے تعالےٰ:<<’’واشرقت الارض بنور ربھا‘‘>> @@اور زمین اپنے رب کے نور سے چمک اٹھے گی @@ تمام مخلوق اپنی قبروں سے اُٹھ کھڑی ہوگی۔ اللہ واحد وقھار کے سامنے حساب کتاب دینے کے لیے قھار وہ ذات ہے جس کے قبضہ قدرت میں ہر چیز ہو۔ ہرچیز اُس کی مرضی کے تحت کام کرے۔ ہر چیز اُس کے غلبے سے عاجز ہو۔ جو سرکشوں کی گردن مروڑ دے اور اُن کو تباہ وبرباد کردے۔ &&(روح البیان۔ المفاتیح )&&
  14,50,آیت نمبر۵۰:گنہگاروں کے حُلیے:>>قطران<< کے مشہور معنی گندھک کے ہوتے ہیں ۔ اور دوسرے معنی’’پگھلے ہوئے تانبے‘‘ کے ہوتے ہیں ۔ غرض یہ ہے کہ جہنمیوں کے جسم پر ایسا لباس ہوگا جو آگ کے اثر کو خوب اچھی طرح قبول کریگا۔ &&(ماجدی )&&{{حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’جو لوگ خدا کو خوش کرنے کے لیے ایک دوسرے سے محبت رکھیں گے، وہ قیامت کے دن کی ہولناکیوں سے محفوظ ہوکر عرشِ الٰہی کے سائے میں زبرجد کی زمین پر عرشِ الٰہی کے یمین (عرش کے دائیں جانب ) ہوں گے۔‘‘&&(تفسیر صافی )&& }}{{جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  نے فرمایا:’’تمہاری یہ آگ جہنم کی آگ کاسترواں حصہ ہے۔ (یعنی جہنم کی آگ دنیا کی آگ سے ۷۰درجہ زیادہ گرم ہے۔ جبکہ دنیاوی آگ لوہے کو بھی پگھلا دیتی ہے۔ &&(روح البیان )&&{{
  14,52,آیت نمبر۵۲:عقل والوں سے خدا کاتخاطب:یہاں خدا وندِ عالم نے ’’عقل والے‘‘ << اُولوالاَلباب  >>کہہ کر یہ بتا دیا کہ انسان کااصل شرف عقل کے صحیح استعمال پر منحصر ہے۔ اور خدا تعالیٰ صرف عقل والوں ہی سے مخاطب ہوتا ہے۔&&(ماجدی )&&{{حضرت امام محمدباقر علیہ السلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم  نے ارشاد فرمایا:’’روزِ ازل جب عقل کو پیدا فرمایا تو اُس کو حکم دیا کہ:’’آگے آ‘‘۔ عقل آگے آئی، پھر حکم دیا کہ:’’پیچھے جا۔‘‘ عقل پیچھے ہٹ گئی۔‘‘ (معلوم ہوا کہ عقل وہ ہے جوخدا کے حکم پر اقدام کرے اور خدا کے حکم پر روکنے سے رُک جائے ) اس پر خدا نے عقل سے فرمایا: مجھے اپنی عزت اور جلالت کی قسم ہے کہ میں نے آج تک کوئی مخلوق ایسی نہیں پیدا کی جو مجھے تجھ سے زیادہ محبوب اور پسندیدہ ہو۔ میں تجھ ہی کو&&(روزِ قیامت )&& اجر و ثواب دوں گا، اور تجھ ہی سے حساب وکتاب لوں گا۔‘‘&&(اصولِ کافی )&& }}{{جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم  نے ارشاد فرمایا:’’جنت میں ایک نورانی شہر ہے جسے کسی ملک مقرب تک نے نہیں دیکھا۔ اُس میں بے شمار محلات، بالا خانے اورحوریں ، اور اَن گنت نعمتیں اور خدامِ نوری ہیں یہ شہر صرف اہل عقل کونصیب ہوں گے۔ خدا اہل عقل کو اہل جنت سے ممتاز کرکے یہاں ٹھہرائے گا۔ ہر اہل عقل کو اُس کی عقل کے مطابق جزا دے گا، او راُسی کے مطابق درجات اور مقامات عطا فرمائے گا۔ ہر ایک درجہ ہزاروں سال کی مسافت کاہوگا۔ جیسے مشرق ومغرب کے درمیان کی مسافت ہے، وہ درجات اس سے بھی ہزار گنا زیادہ بلند ہوں گے۔‘‘&&(روح البیان )&& }}
