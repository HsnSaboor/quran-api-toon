  60,1,آیت نمبر۱:شانِ نزول:حاطب بن ابی بلتعہ ایک بڑے صحابی رسول صلی اللہ علیہ و آلہ وسلم تھے ‘ غزوہ  بدر میں حصہ لے چکے تھے ‘ مہاجر تھے۔ انھوں نے فتح مکہ سے پہلے اپنے گھر والوں کو ‘ جو مکے میں تھے ‘ خط لکھا کہ عنقریب رسول صلی اللہ علیہ و آلہ وسلم مکے آنے والے ہیں ۔ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کو وحی کے ذریعہ معلوم ہوگیا ۔ جب حاطب کو بلایا گیا تو انھوں نے عرض کی کہ : میری نیت بری نہ تھے میں نہیں سمجھا تھا کہ میرے اس خط سےاسلام کو کوئی نقصان پہنچے گا‘ میرا خیال تھا کہ میرے اس خط سے اہل مکہ میرا احسان مانیں گے اور میرے گھر والوں کے ساتھ برا سلوک نہ کریں گے۔جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے ان کی نیک نیتی کی تصدیق فرمائی۔&&(مدارک ۔ بیضاوی)&& فقہاء نے نتیجہ نکالا کہ ایک صحابی ‘ جو بدری بھی ہو ‘ مہاجر بھی ہو ‘ اس کی ‘ کافروں کو راز بتانے پر اس قدر گرفت ہو‘ اس سے معلوم ہوا کہ مسلمانوں کو کفار جو حالتِ جنگ میں ہوں اس سے اچھے دوستانہ تعلقات قائم کرنا بہت ہی بری بات ہے۔&&(تفسیر کبیر ۔ مجمع البیان ‘ تفسیر روح المعانی‘ تفسیر روح البیان ‘ تفسیر قرطبی ۔ فی ظلال)&& آیت کا مطلب یہ ہے کہ اگر تم نے کافروں سے محبت کی اور مسلمانوں کے راز ان کو بتائے تو یہ بہت ہی بری بات ہے۔&&(بیضاوی ۔ جلالین)&& خدا وندِ عالم کے فرمانے کا مقصد یہ ہے کہ ’’ جب تم میری راہ میں ‘ میری محبت میں اپنا گھر بار چھوڑ کر نکل آئے: تو اب مشرکوں سے خط و کتابت کے ذریعہ تعلقات کیوں بڑھا رہے ہو ‘ جبکہ وہ تمھیں تمھارے گھروں سے ( اس وجہ سے نکال چکے ہیں کہ تم خدا و رسول صلی اللہ علیہ و آلہ وسلم پر ایمان لے آئے ہو پھر ان سے دوستی کیوں رکھتے ہو؟) &&(ابنِ جریر)&& اس سے معلوم ہوا کہ تمام صحابہ مثالی کردار کے مالک نہ تھے۔&&(فصل الخطاب)&& {{ حضرت عمرؓ نے عرض کی : ’’ یا رسول صلی اللہ علیہ و آلہ وسلم اللہ ! مجھے اس منافق ( حاطب صحابی ) کی گردن مارنے کی اجازت دیں ۔ اس نے اللہ اور رسول اللہ  صلی اللہ علیہ و آلہ وسلم سے خیانت کی ہے‘‘۔ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ اس نے جنگ بدر میں حصہ لیا ہے‘‘۔ یہ سن کر حضرت عمر رو دیے۔ &&(بخاری۔ مسلم ۔ احمد ۔ ابودائود‘ ترمذی ‘ نسائی ۔ ابن جریر ابن ہشام)&& }} {{ جناب امیر المومنین علیہ السّلام کے کاتب ‘ عبیداللہ بن ابی رافع سے جناب امیر المومنین علیہ السّلام کے پوتے حسن بن محمد بن حنیفہ علیہ السّلام نے روایت کی ہے کہ جناب امیرالمومنین علیہ السّلام نے فرمایا کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے حاطب کا عذر سن کر ان کو معاف کردیا ‘ اور انھیں کوئی سزا نہیں دی گئی۔&&(ابنِ جریر ۔ تفہیم)&& }}
  60,2,آیت نمبر۲:سبق:اللہ نے اس آیت سے یہ سبق دیا ہے کہ کسی شخص کا کسی مصلحت سے ایسا کوئی کام کرنا کہ جو اسلام یا مسلمانوں کے مفاد کے خلاف ہو ‘ ایما ن کے منافی ہے۔اگر کوئی اپنی ذاتی مجبوری کی وجہ سے بھی کوئی ایسا کام کرے تو بھی ایسا کام کرنا درست نہیں ہوگا۔&&(تفہیم ۔ تفسیر کبیر)&& اِس آیت میں تشریح کی گئی ہے کہ تم کافروں ‘ مشرکوں ‘ حق دشمنوں سے دوستی کیوں کرتے ہو‘ حالانکہ کہ وہ تمھارے ایسے دشمن ہیں کہ اگر تم پر مسلط ہوجائیں تو تم کو سخت تکلیفیں پہنچائیں ‘ اپنے ہاتھوں سےبھی اور اپنی زبانوں سے بھی ۔ ان کا اصل مقصد یہ ہے کہ تم کو اسلام سے پلٹا دیں اور تم کو ایمان سے محروم کردیں ۔&&(تفسیر نمونہ)&&
  60,3,آیت نمبر۳: اِس آیت میں بتایا جا رہا ہے کہ جن کی تم مدد کررہے ہو یہ تمھیں کوئی فائدہ نہیں پہنچا سکتے۔ &&(تفسیر ماجدی)&& آیت کا پیغام:(۱) مشرکین سے کسی خیر کی امید نہ رکھو ۔ کیوں کہ ان کی بس ایک تمنا ہے کہ تم کسی طرح اسلام سے الگ ہوجاؤ۔(۲) مشرکوں ‘ کافروں کے تعلقات صرف دنیا تک ہیں ۔ آخرت میں یہ سارے تعلقات کاٹ دیے جائیں  اور کوئی کسی کے کام نہ آئے گا۔(۳) حاطب نے اپنے رشتہ داروں کو بچانے کے لیے مشرکوں کو خط لکھا تھا اس لیے کہا جا رہا ہے کہ تم نے جن کی خاطر یہ کام کیا ہے وہ قیامت میں تمھارے کچھ بھی کام نہ آئیں گے کسی کی یہ مجال نہیں کہ خدا کے سامنے یہ کہہ سکے کہ فلاں نے میری خاطر یہ کام کیا تھا اس لیے اس کی جگہ میں سزا برداشت کرنے کو تیار ہوں ۔ قرآن میں دوسری جگہ اس کو یوں بھی فرمایا کہ:<< يُّبَصَّرُوْنَہُمْ۝۰ۭ يَوَدُّ الْمُجْرِمُ لَوْ يَفْتَدِيْ مِنْ عَذَابِ يَوْمِىِٕذٍؚبِبَنِيْہِ۝۱۱ۙ وَصَاحِبَتِہٖ وَاَخِيْہِ۝۱۲ۙ وَفَصِيْلَتِہِ الَّتِيْ تُـــــْٔـوِيْہِ۝۱۳ۙ وَمَنْ فِي الْاَرْضِ جَمِيْعًا۝۰ۙ ثُمَّ يُنْجِيْہِ۝۱۴ۙ كَلَّا۝۰ۭ >>  &&(سورۃ ۷۰ امعارج آیت ۱ ۱ تا ۱۴ ۔ ۱۵ پارہ ۲۹)&& یعنی : @@’’ ایک دوسرے کو دیکھ لینے کے باوجود قیامت کے مجرم یہ چاہے گا کہ کاش وہ اپنی اولاد ‘ اپنے بیوی ‘ اپنے بھائی ‘ اپنی حمایت کرنے والے خاندان ‘ بلکہ دنیا بھر کے لوگوں کو فدیہ میں دے کر عذاب سے چھوٹ بھاگے ۔ مگر ایسا ہرگز نہ ہوگا‘‘@@۔ دوسری جگہ فرمایا:<< يَوْمَ يَفِرُّ الْمَرْءُ مِنْ اَخِيْہِ۝۳۴ۙ وَاُمِّہٖ وَاَبِيْہِ۝۳۵ۙ وَصَاحِبَتِہٖ وَبَنِيْہِ۝۳۶ۭ لِكُلِّ امْرِئٍ مِّنْہُمْ يَوْمَىِٕذٍ شَاْنٌ يُّغْنِيْہِ۝۳۷ۭ >>  &&(سورۃ ۸۰ عبس آیت ۳۴ تا ۳۷ پار ہ ۲۰)&& یعنی : @@ ’’ اس دن آدمی اپنے بھائی ‘ اپنی ماں ‘ اپنے باپ ‘ اپنی بیوی اور اولاد تک سے بھاگے گا ( کیونکہ) ہر ایک اپنے ہی حال میں ایسا گرفتار ہوگا کہ کسی کو کسی کا ہوش تک نہ ہوگا‘‘@@ ۔ غرض آخرت میں دنیا کے تمام رشتے تعلقات توڑ دیے جائیں گے ۔ وہاں پارٹیوں کی شکل میں محاسبہ نہ ہوگا۔ ہر شخص الگ الگ اپنی ذاتی حیثیت سے پیش ہوگا اور ہر ایک کو اپنا اپنا حساب دینا ہوگا۔ اسلیے کسی کو دنیا میں کسی قرابتداری ‘ دوستی ‘ جتھ بندی وغیرہ کی وجہ سے کوئی غلط کام نہیں کرنا چاہئیے ‘ کیوں کہ برے کام کی سزا خود ہی بھگتنی ہوگی۔&&(تفسیر کبیر ۔ تفہیم)&& اسی لیے {{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ تم اپنے بھائی کی مدد کرو چاہے وہ ظالم ہو یا مظلوم ‘‘۔ پوچھا گیا کہ : ظالم کی مدد کس طرح کریں ؟فرمایا: ’’ اس طرح کہ اس کو ظلم کرنے سے روک دو‘‘ &&(الحدیث)&& }}
  60,4,آیت نمبر۴:{{ حضرت امام علی علیہ السّلام ابنِ ابی طالب علیہ السّلام نے فرمایا: اس آیت میں حضرت ابراہیم علیہ السّلام کے اس ارشاد کا کہ :<<  اِنَّا بُرَئٰٓ وُامِنْکُمْ >>  یعنی میں تم سے اور تمھارے ان خداؤں سے بیزار ہوں ‘‘ یہاں بیزار ہونے سے مراد الگ ہونے کے ہیں ‘‘۔ &&(تفسیر صافی ۔ کافی ۔ التوحید)&& }} آیت کا پیغام:یہ ہے کہ کافروں ‘ مشرکوں اور بتوں سے تبرا کیا جائے ۔ ان سے قلبی تعلقات نہ رکھے جائیں اس سلسلے میں مسلمانوں کو حضرت ابراہیم علیہ السّلام کی پیروی کرنی چاہئیے۔&&(حصاص)&& دوسرا پیغام یہ بھی ہے کہ مشرکوں کے لیے دعائے مغفرت نہ کی جائے ۔&&(حصاص ۔ مدارت بقول انِ عباس ‘ مجاہد ‘ قتادہ ۔۔ مقاتل ۔ ابنِ کثیر)&& عرفاء نے نتیجہ نکالا کہ اللہ کے لیے ‘ اللہ کےحکم پر جو کافروں ‘ مشرکوں سے دشمنی کی جاتی ہے وہ ان پر شفقت اور خیر خواہی کو ختم نہیں کرتی ‘ بخلاف ذاتی دشمنی کے۔&&(مرشد تھانوی)&& آخر میں توکل کا ذکر اس لیے کیا گیا کہ کافروں کے بائیکاٹ کرنے کی صورت میں ممکن ہے کہ مسلمانوں  کو مالی نقصان ہو ۔ اسے مواقع پر خدا پر بھروسہ کیا جائے گا تو خدا اس نقصان کو پورا کردے گا۔&&(تفسیر ماجدی)&& محققین نے نتیجے نکالے:(۱) اسلام میں قومیت کی بنیاد پر محبت نہیں کیجاتی بلکہ ایمان کی بنیاد پر ایک دوسرے سے محبت کی جانی چاہئیے۔(۲) کافروں ‘ مشرکوں ‘ ظالموں سے بیزاری ‘ علیٰحدگی اور تبرا کرنا ضروری ہے۔(۳) ملتِ مسلمہ کو حضرت ابراہیم علیہ السّلام کی پیروی کرنی چاہئیے ‘ مگر مشرکوں کے لیے دعائے مغفرت نہ کی جائے کیوں کہ بعد میں حضرت ابراہیم علیہ السّلام کو جب یہ معلوم ہوا کہ ان کا چچا مشرک ہے تو انھوں نے اس سے علیٰحدگی اختیار فرمالی۔&&(ابنِ جریر ۔ فصل الخظاب)&& (۴) ایمان کا تقاضا ‘ طاغوتی طاقتوں سے کفر و انکار ۔ کیوں کہ خدا نے قرآن میں فرمایا:<<  فَمَنْ یَّکْفُرْ بِالطَّاغُوْتِ وَیُوْمِنْ بِاللّٰہِ فَقَدِ اسّتَمَکَ بِالْعُرْ وَۃِ الْوَثْقٰے لَا انْفِصَامَ لَھَا >>  &&(سورۃ البقرۃ آیت ۲۵۶ پارہ ۳)&& یعنی: @@’’ جو شخص طاغوت ( شیطان ۔ سلطانِ جابر) سے کفرو انکار کرے اور اللہ کو دل سے مان لے اس نے حقیقتاً مضبوط سہارا تھام لیا ‘ جو ٹوٹنے والا نہیں ‘‘@@ ۔ آیت کا مطلب یہ ہے کہ حضرت ابراہیم علیہ السّلام کی یہ سنت ضرور قابلِ تقلید ہے کہ انھوں نے کافروں اور مشرکوں  سے بیزاری اور قطع تعلق کا اعلان فرمایا ‘ مگر ان کی یہ بات قابلِ تقلید نہیں ہے کہ انھو ں نے اپنے مشرک چچا سے دعائے مغفرت کا وعدہ کرلیا تھا ۔ کیوں کہ اہلِ کفرو شرک سے مسلمان کو اتنا سا تعلق بھی نہیں رکھنا چاہئیے کہ ان سے دعا کرنے کا وعدہ کرے۔ حضرت ابراہیم علیہ السّلام نے چلتے وقت اپنے چچا سے دعاء کرنے کا وعدہ تو کرلیا تھا لیکن جب بعد میں ان کو معلوم ہوا کہ وہ خدا کا دشمن تھا تو انھوں نے اس پر تبرا کیا اور اس سے محبت اور ہمدردی کا تعلق توڑ لیا۔&&(تفسیر روح المعانی ۔ تفسیر کبیر ۔ تفہیم ۔ تفسیر مجمع البیان)&& غرض مفسرین نے حضرت ابراہیم علیہ السّلام کے اس وعدہ استغفار کو ایک استثناء سمجھا اور کہا کہ سوا ان کے اپنے چچا آذر کے لیے استغفار کرنے کے ان کا ہر ہر عمل نمونہ عمل اور قابلِ پیروی ہے۔ مگر مفسرین کا خیال ہے کہ اگر ایسے حالات جو حضرت ابراہیم علیہ السّلام کے سامنے تھے ہمیں پیش آئیں تو ہم بھی حضرت ابراہیم علیہ السّلام کی پیروی کرسکتے ہیں ۔&&(تفسیر نمونہ)&& محققین نے نتیجہ نکالا کہ ’’ اللہ سے کسی کی زبردستی مغفرت کرا لینا نبی علیہ السّلام کے اختیار سے باہر ہے۔&&(تفسیر روح المعانی)&& بہر حال حضرت ابراہیم علیہ السّلام کی پوری زندگی میں ان کا یہ ایک عمل کہ انھوں نے اپنے چچا سے مغفرت کی دعاء کا وعدہ فرمایا تھا ایک استثناء رکھتا ہے اس کے علاوہ انھوں نے مشرکوں سے مکمل قطع تعلق کرلیا‘ اور ان سے کوئی محبت بھری بات نہ کہی چچا سے وعدہ کرتے ہوئے بھی حضرت ابراہیم علیہ السّلام نے فرمایا تھا کہ: اس وعدہ کے باوجود میں خدا کے مقابلے میں تیرے لیے کسی چیز کا مالک نہیں ہوں کیوں کہ گناہوں کا معاف کردینا صرف خدا کے ہاتھ میں ہے‘‘۔ &&(اصول کافی ‘ تفسیر نورالثقلین)&& غلط فہمی کا ازالہ: اصل بات یہ ہوتی ہے کہ حاطب بن بلتعہ کو معاف کرنے سے مسلمانوں میں یہ ایک غلط فہمی پیدا ہوسکتی تھی کہ مشرکوں سے روابط بڑھائے جاسکتے ہیں ۔ ان سے ہمدردی کی جاسکتی ہے۔ جیسے کہ حضرت ابراہیم علیہ السّلام نے اپنے چچا آذر سے خدا سے معافی طلب کرنے کا وعدہ کیا تھا ۔ اس لیے قرآن نے وضاحت فرمائی کہ ابراہیم علیہ السّلام کا وعدہ ایک استثناء ہے جو خاص حالات میں ہوا تھا ‘‘۔ حضرت ابراہیم علیہ السّلام نے وہ وعدہ کسی دینوی منفعت کی غرض سے نہیں فرمایا تھا ۔ ان کا اصل مقصد یہ تھا کہ کچھ ہمدردی کرکے اپنے چچا کو ایمان کی طرف کھینچ لائیں ‘ مگر جب ان پر واضح ہوگیا کہ وہ خدا کا دشمن ہے تو انھوں نے اس سے علٰیحدگی اوربیزاری ( تبرا ) اختیار کر لیا۔اصل میں حضرت ابراہیم علیہ السّلام بہت مہر بان اور بردبار آدمی تھے آپ علیہ السّلام کی مہربانی اور بردباری ( اور بندگانِ خدا سے ہمدردی) کا حال تو یہ تھا کہ جب قوم لوط جیسی بدکار قوم پر عذاب کے فرشتے خدا کا عذاب لے کر جانے لگے تو حضرت ابراہیم علیہ السّلام خداوندِ عالم سے جھگڑنے لگے ۔ بس اسی شرافت اور رحمدلی کی وجہ سے انھوں نے اپنے چچا سے دعاء مغفرت کا وعدہ کرلیا تھا ‘ اگر چہ مشرکوں سے ایسے وعدے اور ایسی ہمدردی نہیں کرنی چاہئیے۔&&(تفسیر نمونہ۔ مجمع البیان ۔ فصل الخطاب)&& آیت میں اللہ سے محبت اور بغض کا سبق دیا گیا ہے:یعنی انسانوں میں آپس سب سے گہرا رشتہ مذہب اور فکر کا ہوتاہے ‘ دوسرے تمام رشتے اور تعلقات ‘ دینی رشتے کے ماتحت ہونے چاہئیں ۔{{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:جو شخص خدا کے لیے دوستی رکھتا ہے اور خدا کے لیے دشمنی رکھتا ہے اور خدا ہی کے لیے عطائیں اور بخششیں کرتا ہے وہ ان لوگوں میں سے ہے جن کا ایمان کامل ہوگیا ہے‘‘۔ &&(اصول کافی ۔ تفسیر نمونہ)&& }} {{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’ ایمان کو محکم ترین ( بے حد مضبوط ) کرنے والی چیزوں میں سے یہ بھی ہے کہ تم صرف اللہ کیلئے دوستی رکھو اور اللہ ہی کے لیے دشمنی رکھو اللہ ہی کے لیے دو اور اللہ ہی کے لیے روکو ‘‘ ( نہ دو) &&(اصول کافی جلد ۲)&& }}
  60,5,آیت نمبر۵:حضرت ابراہیم علیہ السّلام کی دعاء کے یہ الفاظ کہ:’’ مالک ! تو ہمیں حق کے منکروں کے لیے فتنہ ‘ آزمائش (یعنی) تختہ مشق نہ بنا دینا ‘‘ ’’ فتنہ کے معنی : ذریعہ آزمائش کے ہیں ۔ جسے اردو میں ہم تختہ مشق بنانا کہتے ہیں ۔ مطلب یہ ہے کہ مالک! ایسا نہ ہوکہ منکرینِ حق ہم پر غالب آجائیں اور پھر ہم پر بلائوں کے طوفان توڑیں ‘ اور ہم ان کی سزائوں کا نشانہ بن کر رہ جائیں ۔ پھر وہ ہمیں امتحان کا ذریعہ بناکر یہ کہیں کہ دیکھو اگر ہم حق پر نہ ہوتے تو ہم غالب کیسے ہوتے ‘‘ ؟ &&(ابنِ جریر)&& {{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام صادق علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ پہلے حضرت آدم علیہ السّلام کی اولاد میں ہر ایماندار آدمی فقیر (تنگدست) ہوا کرتا تھا ‘ اور ہر کافر ‘ دولتمند ۔ یہاں تک کہ حضرت ابراہیم علیہ السّلام نے دعا فرمائی کہ ’’ مالک! تو ہمیں کافروں کے لئے فتنہ (یعنی) تختہ مشق نہ بنا‘‘۔ اللہ نے یہ دعا ء قبول فرمائی اورمومنین میں سے کچھ کو مالدار بنادیا۔ اور کچھ کو تنگدست اس طرح کافروں میں سے کچھ کو مالدار رکھا اور کچھ کو محتاج بنادیا‘‘۔ &&(تفسیر صافی ۔ الکافی)&& }} آخری مطلب یہ ہے کہ ’’ مالک ! ایسا نہ ہو کہ کافر ‘ مشرک ہم کو ستائیں اور ہم پر مصیبتیں ڈالنے پر قادر ہوجائیں ۔&&(تفسیر ماجدی)&& کافروں کے لئے’’ فتنہ‘‘ بننے کے کئی معنی ہیں ۔(۱) کافر ہم پر غالب آجائیں اور پھر کہیں کہ ہمارا غلبہ ‘ ہمارے حق پر ہونے کی دلیل ہے۔(۲) کافر ’ مومنین پر اس قدر ظلم کریں کہ مومنین اپنے دین کا سودا کرنے پر مجبور ہوجائیں ۔(۳) مومنین اخلاقی فضائل سے محروم ہوجائیں ‘ اور کافر ان پر ہنسیں ۔ کافر کہیں کہ ان میں آخر ایسی کونسی خوبی ہے کہ ہم ان کا دین قبول کریں ۔؟ &&(تفسیر کبیر۔ تفہیم)&&
  60,6,آیت نمبر۶:مطلب یہ ہے کہ اللہ کو ایسے ایمان لانے والوں کی کوئی ضرورت نہیں ہے جو اسلام دشمنوں سے دوستی رکھیں ‘ خدا تو ایسے بھی بے نیاز ہے‘ اُس کو اِس کی احتیاج نہیں ہے کہ لوگ خدا کی خدائی کو مانیں ‘ وہ خود اپنی ذات میں محمود ‘ یعنی قابلِ تعریف ہے ۔ کوئی ایمان لاتا ہے تو خود اپنے فائدہ کے لیے ۔ اور ایمان کا فائدہ اس وقت تک نہیں ہوتا جب تک ایمان لانے والا حضرت ابراہیم علیہ السّلام کی طرح کافروں ‘ مشرکوں سےمحبت کے رشتے نہ توڑلے۔&&(تفہیم ۔ تفسیر کبیر)&& جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی زندگی اور سیرت ایک مثالی نمونہ ہے خطروں سے بھری جنگ احزاب میں جبکہ مسلمانوں کی سخت آزمائش ہوئی اور ہمت توڑدینے والے واقعات ہوئے ‘ ساری قوم لرز لرز گئی ‘ مگر پیغمبرِاکرم صلی اللہ علیہ و آلہ وسلم کے قدم جمع رہے اور ان کے ساتھ ساتھ حضرت امام علی علیہ السّلام آپ صلی اللہ علیہ و آلہ وسلم کا دفاع کرتے رہے اسی لیے پیغمبرِ اکرم صلی اللہ علیہ و آلہ وسلم کی زندگی مسلمانوں کے لیے ایک نمونہ بن گئی اصل چیز نبی صلی اللہ علیہ و آلہ وسلم کا کردار ہوتی ہے جسے قرآن نے نور فرمایا ہے ۔ اپنے اعلیٰ کردار ہی کے ذریعہ انبیاء علیہ السّلام ہدایت کا کام انجام دیا کرتے ہیں ۔&&(تفسیر نمونہ)&& {{ فرزندِ رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر علیہ السّلام نے فرمایا ہے:’’ لوگوں کو اپنے عمل سے خدا کی طرف بلاؤ ‘ نہ کہ اپنی زبان ہے ‘‘۔ &&(سفینہ البحار جلد ۲۷۸ مادہ عمل)&& }} دنیا کی رہنمائی مفکرین اورفلاسفہ نے بھی کی ہے اور انبیاء کرام علیہ السّلام نے بھی کی ہے ۔ مفکرین نے لاکھوں ‘ کروڑوں کتابیں لکھیں ۔ مگر انبیاء کرام علیہ السّلام کے صحیفے بہت کم ہیں اس کے باوجود آج پوری دنیا میں انبیاء کرام علیہ السّلام کے ماننے والے ان کا کلمہ پڑھنے والے لاکھوں ‘ اربوں انسان ہیں ‘ جبکہ فلاسفہ کی تعلیمات کو جاننے والے معدو دے چند ہوں گے ۔ اس کی اصل وجہ سیرت کردار ہے۔ فلاسفہ اور مفکرین صرف کتابیں لکھتے ہیں گہرے اور دقیق مطالب بیان کرتے ہیں مگر ان پر خود عمل نہیں کر پاتے یعنی سیرت سے خالی ہیں جبکہ انبیاء کرام علیہ السّلام تعلیمات کے ساتھ ساتھ سیرت و کردار اور عمل کا نمونہ بن کر لوگوں کے سانسوں میں زندہ رہتے ہیں [[ بمصطفٰے صلی اللہ علیہ و آلہ وسلم برساں خویش راکہ دیں ہمہ اوست ۔اگر باو نرسیدی تمام بو لہبی است ]] ۔( اقبالؒ) (خود کو مصطفیٰ صلی اللہ علیہ و آلہ وسلم کی پیروی تک پہنچا دو کیوں کہ سارا کا سارا دین وہی ہیں ‘ ان کی پیروی میں ہے اگر ان تک نہ پہنچے ( ان کی سیرت کی پیروی نہ کی) تو پھر جو کچھ اس کے علاوہ ہے سب کفر ہی کفر ہے)خدا سب سے بے نیاز ہے:ہمارا کوئی نیک عمل خدا کو کوئی فائدہ نہیں پہنچا سکتا ‘ نہ کوئی برا عمل خدا کو کچھ نقصان پہنچا سکتا ہے کیوں کہ وہ مطلق بے نیاز ہے۔ خداوندِ عالم نے حدیثِ قدسی میں ارشاد فرمایا: ’’ اے میرے بندو ! تم مجھے ہرگز ہر گز کوئی نقصان نہیں پہنچا سکتے اور نہ کوئی فائدہ پہنچا سکتے ہو۔ اگر اولین و آخرین ‘ تمام جن و انس ‘ پاکیزہ ترین دل رکھتے ہوئے بھی میرے ملک میں  ذرہ برابر اضافہ نہیں کرسکتے ‘ اور اگر سارے اولین و آخرین ‘ تمام جن و انس ناپاک ترین دل والے ہوجائیں ‘ تو بھی میرے ملک میں کوئی کمی نہیں کرسکتے ‘‘۔ ’’ اے میرے بندو! اگر تمام اولین و آخرین ‘ تمام جن و انس کسی میدان میں جمع ہوجائیں ‘ اور جو چاہیں مجھ سے طلب کریں اور میں  وہ جو کچھ مانگیں سب کا سب ان کو دے دو ں تو بھی میرے خزانوں میں ذرہ برابر کسی چیز کی کمی نہ ہوگی وہ سب میرا دینا اس رطوبت کے برابر نہ ہوگا جو ایک رسی سمندر سے حاصل کرتی ہے( یعنی جتنا پانی ایک رسی کے بھیگنے سے سمندر میں سے کم ہوتا ہے ‘ اتنی کمی بھی میرے خزانوں میں نہ ہوگی۔’’ اَللّٰہُ اَکْبَرُ ‘‘’’اے میرے بندو ! میں تمھارے اعمال کا ذخیرہ کرتا رہتا ہوں اور پھر ان کو تمھیں لوٹا دونگا ( وہ بھی بے حد اجر کے ساتھ ) اب جو کوئی اچھی چیز حاصل کرے ( یعنی اچھا کام کرے) وہ خدا کا شکر ادا کرے (کیوں کہ اس نے خدا کو نہیں خود اپنے کو بے پناہ فائدہ پہنچایا ہے ) اور جو اس کے سوا دیکھے ( یعنی برے کام کرے تو وہ اپنے سوا کسی اور کو ملامت نہ کرے‘‘۔ &&(تفسیر روح البیان جلد ۹) && یعنی : برا کام کرکے خود کو اس کا ذمے دار قرار دے اور یہ سمجھے کہ اس نے خود اپنا ہی نقصان کیا ہے خدا کا نہیں اسی لیے خدا وند عالم نے یہ دعاء تعلیم فرمائی ہے:<<  رَبَّنَا ظَلَمْنَآ اَنْفُسَنَا وَاِنْ لَّمْ تَغْفِرْ لَنَا وَتَرْ حَمْنَا لَنَکُوْنَنَّ مِنَ الْخٰسِرِیْنَ >>  یعنی : @@ اے ہمارے مالک ! ہم نے خود اپنے اوپر ظلم کیاہے اب اگر تو نے ہمیں معاف نہ کیا ‘ اور ہم پر رحم نہ فرمایا ‘ تو ہم سخت نقصان اٹھانے والے ہوجائیں گے ‘‘@@ ۔ &&(القرآن)&&
  60,7,آیت نمبر۷:مطلب یہ ہے کہ خدا مسلمانوں کے شدید دشمنوں میں سے کچھ کو ہدایت دے کر مسلمان بنادے گا۔&&(تفسیر ماجدی)&& فقہاء نے لکھا کہ ’’ جو کافر اہل حرب میں سے نہ ہوں ‘ بلکہ ذمی ہوں ان کو صدقات دینا جائز ہے‘‘&&(جصاص)&& مگر جن کافروں کا رویہ مسلمان یا اسلام دشمنی ہو ‘ ان سے محبت کے تعلقات بڑھانا ٹھیک نہیں ۔ مگر اس معاملے میں بالکل مایوس نہ ہونا چاہئیے ‘ ہوسکتا ہے کسی وقت وہ خدا کا پیغام قبول کرلیں ۔ یا کم سے کم صلح پر اتر آئیں ۔ اس طرح اگر وہ برے کاموں کو چھوڑ کر توبہ کریں گے تو خدا ان کو معاف فرمائے گا۔ پھر تمھارے اور ان کے درمیان محبت کا رشتہ قائم فرمادے گا۔&&(فصل الخطاب)&& مسلمان اسلام کی محبت میں اپنے رشتہ داروں سے تعلقات توڑے بیٹھے تھے مگر خدا کو معلوم تھا کہ یہ بہت سخت کام ہے۔ اہل ایمان کے دلوں پر کیا کچھ گذر رہی ہے۔ اس لیے اللہ نے اس آیت میں مومنین کو تسلی دی کہ وہ وقت دور نہیں ہے کہ تمھارے رشتہ دار اسلام قبول کرلیں ۔ چند ہفتوں کے بعد ہی مکہ فتح ہوگیا اور مکے کے لوگ جوق در جوق مسلمان ہوگئے۔&&(تفسیر کبیر مجمع البیان ۔ تفہیم)&&
  60,8,آیت نمبر ۸ : اس آیت سے معلوم ہوا کہ ان کافروں سے اچھا سلوک کرنا ضروری ہے جو مسلمانوں سے جنگ نہیں  کرتے۔ ان سے انصاف اور حسنِ کردار کے ساتھ اچھے تعلقات قائم رکھو۔&&(مجمع البیان ۔ ابنِ جریر)&& شانِ نزول:روایت ہے کہ قتیلہ بنتِ عبدالعزیٰ مشرکہ تھی ۔ وہ اسماء بنت ابوبکر کے پاس کچھ تحفے لے کر آئی مگر اسماء نے اپنی ماں  کے تحفے اس لیے قبول نہ کیے کہ وہ کافرہ تھی ۔ اسماء نے اس کو اپنے گھر میں داخل بھی نہیں ہونے دیا۔ اس پر یہ آیت اتری۔&&(تفسیر صافی۔ تفسیر روح البیان۔ بخاری)&& محققین نے نتیجہ نکالا کہ ذمی اور صلح پسند کافروں سے صلح اور شفقت کا برتاؤ کرنا چاہئیے۔ اسی لیے عرفاء ایسے کافروں کے ساتھ بہت زیادہ شفقت سے پیش آتے ہیں تاکہ ان کو اسلام کی طرف رغبت ہو۔&&(تفسیر ماجدی)&& مطلب ہرگز یہ نہیں ہے کہ دشمنوں کے ساتھ بے انصافی کرنی چاہئیے۔ مطلب یہ ہے کہ جو شخص تم سے دشمنی نہیں کرتا‘ تم بھی اس کے ساتھ دشمنی نہ کرو ‘ انصاف کا تقاضا بھی یہی ہے دشمن اور غیر دشمن کو برابر قرار دینا انصاف کے خلاف ہے ۔ تم صرف ان کے ساتھ سخت رویہ اختیار کرسکتے ہو جنھوں نے ایمان لانے کے بعد تم پر ظلم توڑے۔ تم کو تمھارے وطن سے نکالا ‘ مگر جن لوگوں نے اس ظلم میں کوئی حصہ نہیں لیا ‘ انصاف یہ ہے کہ تم ان کے ساتھ اچھا سلوک کرو۔ رشتہ داری اور برادری کے حقوق ادا کرو۔ &&(تفسیر کبیر ۔ تفہیم)&& << لَاَیْنھٰکُمْ >>  یعنی جن کافروں نے دین کے معاملے میں تم سے کوئی چھیڑ چھاڑ نہیں کی اور اپنے صلح کے عہد پر قائم ہیں اور تمھاری جلاوطنی میں بھی ان کا عمل دخل نہیں ہے تو خدا ان کے ساتھ احسان کرنے سے تم کو نہیں روکتا ‘ بیشک ان کے ساتھ حسنِ سلوک سے پیش آؤ البتہ جو دین کے معاملے میں تم سے لڑتے جھگڑتے رہے ’ اور تمھاری جلاوطنی کا باعث بنے ’ یا اس میں ان کا بھی ہاتھ تھا تو ایسے لوگوں کی دوستی سے خدا تم کو روکتا ہے۔&&(تفسیر  انوار النجف)&&
  60,9,آیت نمبر۹:کافروں سے ترکِ تعلقات کی وجہ:آیت میں بتایا گیا ہے کہ کافروں سے ترکِ تعلقات کی وجہ انکار کفر یا شرک نہیں ہے بلکہ اس کی وجہ ان کا ظلم  اور مسلمانوں سے عداوت ہے اس لیے مسلمانوں کو دشمن کافر اور غیر دشمن کافر میں فرق کرنا چاہئیے ۔ ان کافروں کے ساتھ اچھا سلوک کرنا چاہئیے جنھوں نے ہمارے ساتھ کوئی برا سلوک نہیں کیا۔اس کی مثال اسماء بنتِ ابوبکر کا واقعہ ہے جن کی ماں کافرہ تھیں ‘ اور صلحِ حدیبیہ کے بعد جب وہ مدینہ آئیں تو بیٹی کے گھر آئیں اور کچھ تحفے بھی لائیں ۔ حضرت اسماء فرماتی ہیں کہ میں نے جاکر جناب رسول صلی اللہ علیہ و آلہ وسلم خدا سے پوچھا کہ کیا میں اپنی ماں سے مل لوں ؟ {{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ ملو اور صلہ رحمی کرو‘‘ }} ۔ اسماء نے پہلے اپنی والدہ سے ملنے سے انکار کردیا تھا۔ جب رسولِ خدا صلی اللہ علیہ و آلہ وسلم  نے اجازت دے دی تب وہ ان سے ملیں ۔&&(مسند احمد ۔ ابنِ جریر۔ ابنِ ابی حاتم)&& اسی طرح ذمی کافروں پر صدقات بھی خرچ کیے جاسکتے ہیں ۔&&(تفسیر روح المعانی۔ احکام القرآن للجصاص)&&
  60,11,آیت نمبر۱۱:’’ پھر جب تمھارے مہر دینے کی باری آئے ‘‘ کا مطلب یہ ہے کہ جب فتح اور غلبہ تمھارا ہو جائے تو تم ان کا ان کافر عورتوں کا مہر ادا کردو جو مسلمان ہوکر تمھارے پاس آگئی ہیں ۔&&(لغات القرآن نعانی)&& مطلب یہ ہے کہ جب کافر عورتیں کافروں سے نکل کر مسلمان سے آملیں ‘ جبکہ کافروں سے تمھارا کوئی معاہدہ بھی نہ ہو تو جب بھی تمھیں مالِ غنیمت ملے تو ان کافروں کو اتنا مال دے دو جتنا انھوں نے ان عورتوں پر خرچ کیا تھا۔&&(تفسیر صافی ۔ تفسیر قمی)&& نتائج و تعلیمات:غرض اس آیت میں دشمنوں ‘ کافروں ‘ مشرکوں تک سے عدل و انصاف کرنے کی تعلیم دی ہے اور عورتوں پر رحم کرنے کی تعلیم دی ہے یہی خوفِ خدا کا تقاضا بھی ہے ۔ &&(فیوض القرآن)&& اسلام میں عدل یعنی انصاف یعنی ہر ایک کے حق کو پورا پورا دا کرنے کو سب سے زیادہ اہمیت دی گئی ہے دشمنوں کے ساتھ بھی عد ل وانصاف کرنے کا حکم دیا گیا ہے ۔ ارشاد فرمایا کہ:’’ کسی قوم کی دشمنی تم کو اس بات پرآمادہ نہ کردے کہ تم ان کے ساتھ انصاف نہ کرو۔ انصاف کرو کہ یہ تقٰوی سے زیادہ قریب ہے ‘‘۔ &&(سورۃ ۵ ۔ آیت۸ پارہ ۶)&& دنیا کا کوئی مذہب دشمنوں کے ساتھ عدل کرنے پر اتنا زور نہیں دیتا جتنا اسلام نے زور دیا ہے کہ اسی کو تقٰوی قرار دیا ہے ۔ اور تقٰوی ‘ قرآن کا اصل پیغام ہے۔&&(مؤلف)&&
  60,12,آیت نمبر۱۲:ہندہ جگر خوارہ زوجہ ابوسفیان کی بیعت کا جب یہ آیت اتری تو جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم صفاء کی پہاڑی پر تشریف فرما تھے ہندہ عورتوں کے ساتھ اپنے چہرے پر نقاب ڈالے ہوئے آئی۔ {{ حضور اکرم صلی اللہ علیہ و آلہ وسلم نے تمام عورتوں سے مخاطب ہوکر فرمایا: ’’ میں تم سے بیعت لیتا ہوں  اس پر کہ (۱) تم کسی کو خدا کا شریک قرار نہ دو گی‘‘۔ اس پر ہندہ بول اٹھی کہ آپ صلی اللہ علیہ و آلہ وسلم ہم سے ایسا عہد لے رہے ہیں جو آپ صلی اللہ علیہ و آلہ وسلم نے مردوں سے نہیں لیا۔(کیوں کہ ) مردوں سے ایمان اور جہاد پر بیعت لی گئی تھی ۔ حالانکہ ایمان میں توحید کا عقیدہ داخل ہے) جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے اس کا جواب نہ دیا اور فرمایا کہ: ’’ تم چوری نہیں کرو گی‘‘ہندہ نے عرض کی :’’ ابوسفیان بڑا کنجوس ہے میں نے اس کے مال سے کچھ لے لیا ہے ابو سفیان نے کہا : ’’ پہلے جو تو نے میرے مال سے لیا ہے وہ سب میں نے حلال کیا۔ (آئندہ نہ لینا) یہ سن کر حضورِ اکرم صلی اللہ علیہ و آلہ وسلم ہنسے اور فرمایا : تو ہندہ ہے؟ہندہ نے عرض کی ‘ ’’ جی ہاں ‘‘آپ صلی اللہ علیہ و آلہ وسلم پچھلے سارے معاملات معاف کریجئیے۔ پھر آپ صلی اللہ علیہ و آلہ وسلم نے اپنی گفتگو جاری رکھی اور فرمایا: ’’ اے عورتو ! تم زنا مت کرنا‘‘۔ ہندہ نے تعجب سے کہا : ’’ کیا آزاد عورت بھی ایسا کام کرسکتی ہے؟اس پر سارا مجمع ہنسنے لگا۔ اسلیے کہ سب کہ سب ہندہ کی بدکرداری کو خوب جانتے تھے  اس کے بعد آں حضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ اے عورتو ! تم اپنی اولاد کو قتل نہیں کروگی‘‘۔ ہندہ نے عرض کی‘ ہم نے اپنی اولاد کو بچپن میں پالاپوسا ‘ مگر جب بڑے ہوئے تو آپ صلی اللہ علیہ و آلہ وسلم نے انھیں قتل کردیا ‘‘۔ ( اس کا اشارہ اپنے بیٹے حنظلہ کی طرف تھا جسے بدر کے دن حضرت امام علی علیہ السّلام نے قتل کیا تھا)پیغمبر اکرم صلی اللہ علیہ و آلہ وسلم مسکرا دیے اور فرمایا: ’’ اے عورتو ! تم بہتان روا نہ رکھو گی‘‘ہندہ نے عرض کی : ’’ بہتان لگانا تو بری بات ہے اور آپ صلی اللہ علیہ و آلہ وسلم نے ہمیں نیکیوں کی تعلیم دی ہے‘‘ پھر فرمایا: ’’ تم اچھے کاموں میں میری اطاعت کروگی‘‘۔ ہندہ بولی : ’’ ہم یہاں آکر اس لیے نہیں بیٹھے ہیں کہ آپ صلی اللہ علیہ و آلہ وسلم کی نافرمانی کریں ‘‘۔ &&(تفسیر مجمع البیان)&& }} << قُلْ اَطِيْعُوا اللہَ وَالرَّسُوْلَ۝۰ۚ فَاِنْ تَوَلَّوْا فَاِنَّ اللہَ لَا يُحِبُّ الْكٰفِرِيْنَ۝۳۲ >>  &&(سورۃ ۳ آیت ۳۲ پارہ ۳)&& یعنی @@’’ کہہ دیجئیے اللہ کی اطاعت کرو اور رسول صلی اللہ علیہ و آلہ وسلم کی بھی اور اگر تم رو گردانی کرو گے تو یقیناً اللہ انکار کرنے والے کو پسند نہیں کرتا‘‘۔ خداوند عالم کا فرمانا کہ: ’’ وہ اپنے ہاتھ پاؤں کے آگے کوئی بہتان نہیں گھڑیں گی ‘‘۔ اصل بات یہ تھی کہ کچھ عورتیں گرے پڑے ‘ ناجائز بچے اٹھا لیا کرتیں ‘ اور اپنے سفر سے لوٹے ہوئے خاوندوں سے کہتیں کہ یہ تمھاری اولاد ہیں ۔ گویا یہ ایسا بہتان تھا جو وہ اپنے ہاتھ پاؤں کے درمیان باندھتی تھیں ۔ مراد وہ بچے ہیں جو انھوں  نے جھوٹ بول کر اپنے خاوند کے سرمنڈھ دیے۔اصل میں وہ پیٹ جس میں بچہ رہتا ہے وہ دونوں ہاتھوں کے درمیان ہوتا ہے اور جس عضو سے عورت بچہ جنتی ہے وہ دونوں پاؤں کے درمیان ہوتا ہے ۔&&(صافی بحوالہ الجوامع ۔ ابن جریر)&& نتائج و تعلیمات: فقہاء نے لکھا کہ اس آیت نے ان غالیوں کو رد کردیا جو کسی پیشہ ور طوائف سے توبہ کرلینے کے بعد بھی نکاح کرنے کو جائز نہیں سمجھتے ۔(۲)  آیت سے بیعت لینے کے اغراض و مقاصد بھی معلوم ہوگئے۔(۳) ایسی بیعت باطل قرار پاگئی جس پر عمل کرنے کا ارادہ ہی نہ ہو۔(۴) شیخ‘ پیر ‘ مرشد کا یہ حق ہے کہ شیخ اس کے لیے دعا کرے۔ بیوی کے چوری کے سلسلے میں ابو سفیان کی بیوی نے رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے پوچھا:یا رسول اللہ ﷺ! ابو سفیان ذرا بخیل آدمی ہے ۔ کیا مجھ پر گناہ ہے کہ میں اپنی اور بچوں کی ضروریات کے لیے آئندہ اس سے پوچھے بغیر مال لے لیا کروں ؟{{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ بس معروف کی حد تک یعنی بس اتنا مال لے سکتی ہو جو واقعاً جائز ضروریات کے لیے کافی ہو‘‘ ۔ && (احکام القرآن ۔ ابن عربی)&& }}عورتوں کے بہتان:دو۲ قسم کے مراد ہیں :(۱) ایک عورت دوسری پر غیر مردوں سے تعلقات کی تہمتیں لگائے(۲) یہ کہ ایک عورت بچہ تو کسی اور کا جنے اور وہ اپنے شوہر کو یقین دلائے کہ یہ تیرا ہی بچہ ہے‘‘۔ &&(تفسیر کبیر۔ مجمع البیان۔ تفہیم)&& {{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ جو عورت کسی خاندان میں کوئی بچہ گُھسالائے جو اس خاندان کا نہیں ہے اس عورت کا اللہ سے کوئی واسطہ نہیں ۔ اللہ اسے کبھی جنت میں داخل نہ کرے گا‘‘۔ &&(ابو دائود)&& }} رسول صلی اللہ علیہ و آلہ وسلم کی مشروط اطاعت:یہاں  پر خدا وند عالم نے رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی اطاعت کے لیے بھی معروف کی شرط لگائی ہے کہ فرمایا: ’’ اور کسی امرِ معروف میں تمھاری نافرمانی نہ کریں ‘‘ ۔ اس سے ثابت ہوا کہ دنیا میں کسی مخلوق کی اطاعت خدا کے قانون کے خلاف نہیں کی جاسکتی۔ کیوں کہ جب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی اطاعت معرفت کے ساتھ مشروط ہے تو پھر دوسرے کے لیے غیر مشروط اطاعت کا سوال ہی پیدا نہیں ہوتا‘‘۔ {{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ اللہ کی نافرمانی میں کوئی اطاعت نہیں ‘ اطاعت صرف معروف میں ہے ‘‘۔ &&(مسلم ‘ ابودائود ‘ نسائی)&& }} ابوبکر حصّاص نے لکھا کہ: ’’ اللہ کو معلوم تھا کہ اس کا نبی صلی اللہ علیہ و آلہ وسلم کسی معروف (اچھے کام ) کے سوا کسی چیز کاحکم نہیں دیتا ‘ پھر بھی خدا نے معروف کی شرط لگادی تاکہ اس بات کی گنجائش ہی نہ رہے کہ سلاطین کی اطاعت خدا کے حکم کے خلاف کی جاسکے‘‘۔ {{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ جو شخص خالق کی معصیت میں کسی مخلوق کی اطاعت کرے ‘ اللہ اس پر اسی مخلوق کو مسلط کرسکتا ہے‘‘ &&(احکام القرآن)&& }} علامہ آلوسی نے لکھا:’’ یہ خیال ان جاہلوں کی تردید کرتا ہے جو یہ سمجھتے ہیں کہ اولو الامر ( خلیفہ) کی اطاعت مطلقاً لازم ہے ۔ اللہ نے تو رسول اکرم صلی اللہ علیہ و آلہ وسلم تک کی اطاعت پر معروف کی قید لگادی ‘ حالانکہ رسول خدا صلی اللہ علیہ و آلہ وسلم کبھی معروف کے سوا کو حکم نہیں دیتے ۔ اس کا مقصد یہ ہے کہ خالق کی معصیت میں کسی کی اطاعت واجب نہیں ۔&&(تفسیر روح المعانی)&&عورتوں سے بیعت لینے کا طریقہ: حضرت اُم المومنین عائشہؓ فرماتی ہیں :’’ خدا کی قسم ! بیعت لیتے و قت کبھی حضور صلی اللہ علیہ و آلہ وسلم کا ہاتھ کسی عورت کے ہاتھ سے چھوا تک نہیں ۔ صرف زبان سے فرماتے تھے کہ میں نے تجھ سے بیعت لی‘‘۔ &&(بخار ۔ ابن جریر)&& کچھ عورتوں نے بیعت کرتے ہوئے جناب رسولِ صلی اللہ علیہ و آلہ وسلم سے عرض کی کہ: ’’ ہاتھ بڑھایے تاکہ آپ صلی اللہ علیہ و آلہ وسلم کےہاتھ پر بیعت کریں ‘‘۔ {{ جناب رسولِ خدا  صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’ میں عوتوں سے مصافحہ نہیں کرتا بس میں تم سے عہد لوں گا ۔&&(مسند احمد ۔ ترمذی أ ضائی ۔ ابنِ ماجہ۔ ابنِ جریر ۔ ابنِ ابی حاتم)&& }} ایک مرتبہ عورتوں سے بیعت لیتے ہوئے عورتوں نے ایک چادر حضور صلی اللہ علیہ و آلہ وسلم کی طرف بڑھائی۔{{ آپ صلی اللہ علیہ و آلہ وسلم نے اس کو اپنے ہاتھ میں لے لیا اور بیعت لی ‘ اور فرمایا ‘ ’’ میں عورتوں میں مصافحہ نہیں کرتا‘‘۔ &&(ابو دائد ‘ ابنِ ابی حاتم نے شعببی سے )&& }} ( ایک دفعہ خطبہ دینے کے بعد آپ صلی اللہ علیہ و آلہ وسلم مردوں کی صفوں کو چیرتے ہوئے عورتوں کی طرف گئے اور عورتوں کے سامنے یہی آیت پڑھی اور پوچھا: کیا تم ان باتوں کا عہد کرتی ہو‘‘ ؟ ایک عورت نے جواب دیا : ’’ ہاں ‘‘ &&(بخاری ۔ بقول ابنِ عباس)&&
  60,13,آیت نمبر۱۳:شانِ نزول:فقراء و مساکین کی ایک جماعت مسلمانوں کی خبریں یہودیوں کو سنایا کرتے تھے اور یہودی اس کے بدلے میں انھیں اپنے درختوں کے کچھ پھل دے دیا کرتے تھے۔ اس پر یہ آیت اتری ۔&&(مجمع البیان)&& مگر اس کا مطلب یہ نہیں کہ آیت صرف فقراء کیلیے اتری ہے اس کا اطلاق عام ہے۔&&(تفسیر کبیر) && کافروں ‘ یہودیوں کے بارے میں ارشاد ہوا کہ ’’ وہ لوگ آخرت کی نجات کے بارے میں کلی طور پر مایوس ہیں اس طرح جیسے قبروں میں مدفون کفار آخرت کی نجات سے مایوس ہیں کیوں کہ ان کافروں نے عالمِ برزخ میں اپنا حشر نشر دیکھ لیا ہے ۔ حقائق کھل چکے ہیں ۔ اس لیے اب وہ قطعی طور پر قیامت کے دن کی نجات سے مایوس ہیں ۔&&(مجمع البیان)&& اب کیوں کہ وہ خدا کی رحمت سے قطعاً مایوس ہوچکے ہیں اس لیے ہر گناہ اور ہر جرم کرنے سے نہیں کتراتے ۔ اس لیے اب ان پر اعتماد نہ کرو اور نہ ان سے دوستی کرو۔&&(تفسیر نمونہ)&& اِس آیت کے دو معنی ہیں ۔(۱) ایمانداروں کو حکم دیا جا رہا ہے کہ وہ ان لوگوں کو دوست نہ بنائیں جو آخرت کے ثواب سے اسی طرح مایوس ہیں جس طرح آخرت کے منکر دوسری زندگی سے مایوس ہیں ۔&&(بقول ابن عباس ‘ حسن بصری ‘ قتادہ ‘ ضحاک از تفسیر کبیر)&& (۲) دوسرے معنی یہ بھی ہوسکتے ہیں کہ: ’’ مومنو ! ان لوگوں سے دوستیاں نہ بڑھاؤ کہ جو آخرت کی رحمت اور مغفرت سے اسی طرح مایوس ہیں جس طرح قبروں کے اندر پڑے ہوئے کافر مردے ہر خیرسے مایوس ہیں ۔ کیوں کہ ان کو اپنے عذابِ الہٰی میں مبتلا ہونے کا یقین ہوچکا ہے۔&&(بقول عبداللہ ابنِ مسعود ’ مجاہد ‘ عکرمہ ‘ ابنِ زید ‘ کلبی متقاتل منصور از تفسیر کبیر ‘ مجمع البیان ‘ تفہیم)&& ان لوگوں سے مراد جن پر خدا غضبناک ہوا ‘ عام کفار ہیں ۔ لیکن ایک روایت میں ہے کہ یہ آیت ان مسلمانوں کے بارے میں اتری ہے جو یہودیوں  کے ساتھ اس لیے دوستی رکھتے تھے کہ انھیں  ان کے باغوں میں سے کچھ میوے مل جایا کرتے۔&&(تفسیر صافی)&&
