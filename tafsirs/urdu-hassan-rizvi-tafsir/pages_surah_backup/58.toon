  58,1,آیت نمبر۱:شانِ نزول آیت نمبر ۱ تا نمبر ۴: انصار کی ایک عورت کا نام خولہ تھا شوہر نے غصہ میں کہہ دیا کہ:<<  اَنْتِ عَلَیَّ کَظَھْرِ اُمِّیْ >>  (یعنی) تو میرے لیے میری ماں کی پشت کی طرح ہے ‘‘زمانہ جاہلیت میں یہ کہہ دینا طلاق کی ایک قسم تھی ۔ کچھ عرصے کی بعد شوہر سخت پریشان ہوا اور بیوی سے کہا کہ رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے پاس جا کر اس کا حل تلاش کر۔ عورت نے حضورِ اکرم صلی اللہ علیہ و آلہ وسلم سے پورا قصہ بیان کردیا۔{{ آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ تو اس پر حرام ہوچکی ہے میرے پاس اس سلسلے میں کوئی دوسرا حکم نہیں ہے ۔عورت نے خدا سے دعا کرنی شروع کردی۔اُس وقت حضور اکرم صلی اللہ علیہ و آلہ وسلم پر وحی ہوئی اور یہ آیات اتریں ۔ آپ صلی اللہ علیہ و آلہ وسلم نے اس عورت کے شوہر کو طلب فرمایا‘ اور اس کے سامنے یہ آیات پڑھیں اور پوچھا۔ اس کہنے کے کفارے میں ایک غلام آزاد کرو۔ اُس نے معذرت کی پھر فرمایا: دو مہینے مسلسل روزے رکھو۔ اُس نے عرض کی میں اندھا ہوجاؤں گا۔ پھر فرمایا: ساٹھ مسکینوں کو کھانا کھلاؤ۔ اُس نے عرض کی آپ صلی اللہ علیہ و آلہ وسلم میری مدد فرمائیں ۔ تو حضورِ اکرم صلی اللہ علیہ و آلہ وسلم نے ساٹھ مسکینوں کو کھانا کھلانے کے لیے اس کو رقم عطا فرمائی۔&&(تفسیر مجمع البیان ‘ قرطبی ‘ وغیرہ وغیرہ)&& }}
  58,2,آیت نمبر۲: {{ فرزندِ رسولِ خدا حضرت جعفر صادق علیہ السّلام سے روایت ہے کہ ’’ مسلمانوں میں جس شخص نے سب سے پہلے ظہار کیا (یعنی اپنے بیوی کی پشت کو اپنی ماں کی پشت کہہ دیا ) و ہ انصار میں اوس بن صامت تھا زمانہ جاہلیت میں  جو کوئی اپنے بیوی سے یہ کلمات کہہ دیتا تھا ‘ اس پر اس کی بیوی حرام ہوجایا کرتی تھی جب اوس شرمندہ ہوا تو اس نے اپنی بیوی سے کہا کہ رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی خدمت میں جا اور دریافت کر کہ ایسا ایسا کہنے کا اسلام میں کیا حکم ہے ؟آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ اے عورت ! اب تو اس مرد پر حرام ہوچکی ہے۔‘‘یہ سن کر اس عورت نے اپنے دونوں ہاتھ آسمان کی طرف بلند کیے اور کہا کہ: میں خدا سے اپنے شوہر سے جدا ہونے پر فریاد کرتی ہوں ‘‘۔ اِس پر یہ آیات اتریں کہ : ’’ اللہ نے اس عورت کی بات سن لی ۔۔۔۔ الخ &&(تفسیر صافی ۔ من یحضرہ الفقیہ)&& }} اِس واقعہ سے دعاء کی طاقت کا اندازہ لگایا جاسکتا ہے کہ دل سے دعاء مانگنا کس قدر پر اثر ہوتا ہے ۔ {{ فرزندِ رسول صلی اللہ علیہ و آلہ وسلم خدا حضرت امام جعفر صادق علیہ السّلام نے فرمایا:<<  الدُّعَآئُ یَرِدُ الْقَضَآئَ >>  (دعاء قضائے الہی (اللہ کے حتمی فیصلوں کو رد کردیتی ہے ) &&(الحدیث)&& }} [[ دلِ سے جو بات نکلتی ہے ‘ اثر رکھتی ہے۔پر نہیں طاقتِ پرواز مگر رکھتی ہے۔قدسی الاصل ہے رِفعت پہ نظر رکھتی ہے ۔خاک سے اڑتی ہے ‘ گردوں پہ گذر رکھتی ہے ]] ۔( اقبالؒ) {{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام علی رضا السّلام اپنی دعاء میں فرماتے ہیں :’’ اے میرے مالک! آپ کا یہ کرم ہے کہ آپ نے اپنے فیصلوں کو دعاء کے ذریعہ سے بدل دینے کی طاقت عطا فرمائی۔:&&(ازمفاتیح الجنان)&& }}
  58,3,آیت نمبر۳:خدا وندِ عالم کا فرمانا : ’’ جو لوگ اپنی بیویوں سے ظہار کریں ( یعنی ان کو اپنی ماں کہہ دیں ) پھر اپنی اس بات سے رجوع کریں ‘‘ ۔ یعنی جو لوگ زمانہ جاہلیت میں ایسا کہنے کے عادی تھے اب اگر اسلام لانے کے بعد بھی وہ ایسا ہی کریں ‘ تو ان کی یہ سزا ہے چاہے یہ کہنے کے بعد وہ اپنے بیوی کو طلاق ہی کیوں نہ دیدیں یا بیوی مرہی کیوں نہ جائے ‘ پھر بھی کفارہ دینا ہوگا ۔ کیوں کہ یہ کہنا بذاتِ خود ایک جرم ہے ۔&&(تفسیر کبیر بقول طائوس ‘ مجاہد ‘ شعبی ‘ زہر ‘ قتادہ ‘ سفیان ثوری)&& اور آخر میں خدا کا یہ فرمانا کہ: جو کچھ تم کرتے ہو اللہ اُس سے باخبر ہے ‘‘ ۔ یعنی : اگر تم نے گھر میں چپکے سے بیوں کو ماں کہہ دیا ‘ اور پھر بھی بیوی سے تعلق قائم رکھا اور کفارہ بھی نہ دیا ‘ تو کسی اور کو خبر ہو یا نہ ہو خدا کو اس کی خبر ہے ‘‘۔&& (تفسیر کبیر ‘ مجمع البیان ‘ تفہیم)&& پلٹنے کے معنی ہیں کے ظہار کرنے کے بعد شوہر اپنی اس بیوی سے ہمبستری کرنا چاہے تو گویا وہ اب اپنے کلمہ  ظہار سے پلٹ گیا۔ &&(مؤلف)&& تمام فقہاء کے نزدیک ساٹھ مسکینوں کو ایک ساتھ کھانا کھلانا ضروری نہیں ہے بلکہ یہی تعداد قسطوں میں بھی پوری کی جاسکتی ہے ۔&&(فتح القدیر)&& مگر یہ ضروری ہے کہ جب تک ساٹھ مساکین کو کھانا نہ کھلا چکے ‘ ہم بستری نہ کرے۔&&(مؤلف)&&
  58,4,آیت نمبر۴:آیت میں ایمان والوں سے خطاب یہاں ’’ ایمان لائے ‘‘ سے مراد سچے اور مخلص مومن کا رویہ اختیار کرنا ہے کیوں کہ اس آیت کے مخاطب کفار و مشرکیں نہیں ہیں کیوں کہ یہ حکم سنانے کے بعد خداوند عالم نے فرمایا : ’’ یہ حکم تم کو اس لیے دیا جا رہا ہے کہ تم اللہ اور اس کے رسول صلی اللہ علیہ و آلہ وسلم پر ( حقیقی معنی میں ) ایمان لاؤ‘‘۔ مطلب یہ ہے کہ جو شخص زبان سے ایمان کا اعلان کرنے کے بعد بھی جاہلیت کے پرانے قوانین پر چلتا رہے تو اس کا یہ طرزِ عمل ایمان کے منافی ہوگا۔مومن کا یہ کام نہیں ہے کہ جب اللہ و رسول صلی اللہ علیہ و آلہ وسلم نے زندگی کے کسی معاملے میں کوئی قانون مقرر کردیا ہے اس کو چھوڑ کر اپنے من مانی کرتا رہے ۔ ( یا جاہلیت کے طرز پر چلتا رہے۔)اس لیے یہاں اس آیت میں کافر سے مراد منکر خدا و رسول صلی اللہ علیہ و آلہ وسلم نہیں ہے بلکہ مراد وہ شخص ہے جو بظاہر ایمان لانے کا اعلان کرے‘ مگر کفار کا طرز عمل اختیار کرے۔مطلب یہ ہے کہ یہ کافروں کا کام ہے کہ خدا و رسول صلی اللہ علیہ و آلہ وسلم کا حکم سن کر بھی وہ اپنی مرضی چلاتے ہیں ۔ اسلام تونام ہے خدا کی مرضی کو تسلیم کرنے کا۔ایمان لانے کے بعد اپنی مرضی چلانا یا جاہلیت کے قوانین پر عمل کرنا ہے ۔اور ایسے لوگوں کا شمار خداوند عالم کے ہاں مومنین میں نہ ہوگا‘ بلکہ کافروں میں ہوگا۔&&(تفسیر کبیر ‘ تفہیم ‘ مجمع البیان‘ تفسیر نمونہ)&& اس آیت سے معلوم ہوا کہ بیوی کو ماں کہہ دینے سے بیوی حرام تو نہیں ہوتی مگر کہنے والے کو شرعی جرمانہ جسے ’’ کفارہ‘‘ کہتے ہیں ادا کرنا پڑے گا ‘ تب بیوی حلال ہوگی۔کفارے کے سلسلے میں خداوند عالم نے کفارہ ادا کرنے والے کی مال اور جسمانی استعداد کو مدنظر رکھا ہے ۔&&(فصل الخطاب)&& ظاہری آیت سے تو ساٹھ دن مسلسل روزے رکھنا معلوم ہوتا ہے لیکن اَئمہ اہل بیت علیہ السّلام کی احادیث اور کچھ اہلِ سنت کے فقہاء کے فتووں کے مطابق ایک مہینہ مسلسل روزے رکھ کر اگر دوسرے مہینے میں کچھ دن بھی روزے رکھ لیے تو << شَہَرَیْنِ مُتَتَابِعَیْنِ >>  (دو مسلسل مہینوں ) کا تقاضا پورا ہوجاتا ہے ۔&&(وسائل الشیعہ)&&
  58,5,آیت نمبر۵:یہاں کافروں سے مراد وہ لوگ ہیں جو خدائی احکامات یعنی شریعت کو نہیں مانتے۔ کافروں سے مراد وہ لوگ نہیں  ہیں جو کسی وقت شریعت کے کسی حکم کو ادا نہیں کرتے۔&&(معالم ‘ بیضاوی ‘ تفسیر کبیر)&& فقہاء نے نتیجہ نکالا کہ بادشاہ ‘ سردار ‘ وڈیرے اپنے قانون نافذ کرتے ہیں وہ سب اسی آیت کے ذیل میں آتے ہیں کیوں کہ ان کے قانون خدا اور رسول صلی اللہ علیہ و آلہ وسلم کے قوانین کے خلاف ہوتے ہیں ۔البتہ اسلامی حکومت اگر فقہاء عظام سے فتویٰ لے کر کوئی مفید قانون نافذ کرے جس کا مقصد لوگوں کو فائدہ پہنچانا ہو ’ تو وہ جائز ہے ۔&&(تفسیر روح المعانی)&& اِس آیت میں خدا کے قوانین کے بجائے اپنی خواہش پر چلنے والوں کے لیے دو سزائوں کا ذکر ہے !!(۱) رسوائی جو اِسی دنیا میں  ہوگی(۲) دوسرے عذاب مھین ‘ ذلت کا عذاب جو آخرت میں ہوگا۔&&(تفسیر مجمع البیان ‘ تفسیر کبیر ‘ تفہیم)&&
  58,6,آیت نمبر۶:محققین نے نتیجے نکالے کہ (۱) خدا اپنے صرف ظاہری احکامات کی تعمیل کو کافی نہیں سمجھتا وہ انسان کے دل کو دیکھتا ہے کہ دل کے ارادے کیا ہیں ؟ انسان کا دل خدا کو حاضرو ناظر سمجھے (۲) خدا کو دھوکا دینا ممکن نہیں ۔&&(تفسیر ماجدی)&& مطلب یہ ہے کہ گناہ کرکے تمھارے بھول جانے سے معاملہ ختم نہیں ہوسکتا۔ اگر تم خدا کے احکامات کی پرواہ نہیں کرتے تو خدا کے نزدیک تمھارا یہ طرزعمل معمولی بات نہیں ہے ‘ خدا ہر ہر گناہ کو نوٹ فرماتا ہے کہ گناہ کرنے کے بعد کس کا عمل کیا تھا؟ &&(تفسیر کبیر ‘ مجمع البیان ‘ تفہیم ‘ تفسیر نمونہ)&&
  58,7,آیت نمبر۷:خلافتِ الٰہیّہ کے خلاف مشورے!!:{{ فرزندِ رسول صلی اللہ علیہ و آلہ وسلم خدا حضرت امام جعفر صادق علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ یہ آیت ابوعبیدہ جراح عبدالرحمٰن بن عوف ‘ اسالم مولیٰ ابی حذیفہ حضیرہ بن شعبہ اور فلاں کے بارے میں بھی اتری ہے جب انھوں نے آپس میں مشورہ کیا ‘ اور ایک معاہدہ لکھا اور سب نے اس کی توثیق کی کہ جب محمد صلی اللہ علیہ و آلہ وسلم کا انتقال ہوجائے گا تو ہم خلافت اور امامت کو نبوت کے ساتھ ساتھ بنی ہاشم کے گھر میں جمع نہیں ہونے دیں گے‘‘۔ &&(تفسیر صافی بحوالہ کافی ‘ تفسیر قمی)&& }} تاریخ کا یہ واقعہ ہے کہ حضرت عمرؓ نے حضرت ابن عباسؓ سے فرمایا کہ تم بنی ہاشم خواہ مخواہ ہم سے ناراض رہتے ہو ۔ اصل میں خدا یہ نہیں چاہتا تھا کے نبوت اور امامت ( خلافت ) کو ایک گھر میں جمع کردے تو مگر ستم ظریفی یہ ہے کہ جب حضرت عمرؓ کا انتقال ہونے لگا تو انھوں نے خلافت کے لیے دو نام تجویز کیے۔(۱) حضرت امام علی علیہ السّلام کا (۲) حضرت عثمانؓ کا ۔ اور ایک کمیٹی بنائی او رحکم دیا کہ وہ کمیٹی ان دونوں میں سے کسی ایک کو خلیفہ مقرر کردے۔&&(سیرۃ ابنِ ہشام)&& سوال یہ ہے کہ خدا یہ چاہتا ہی نہ تھا کے نبّوت اور خلافت ایک گھر میں جمع ہو تو پھر حضرت عمرؓ نے حضرت امام علی علیہ السّلام کا نام خلافت کے لیے کیوں منتخب فرمایا؟ &&(مؤلف)&& {{ فرزندِ رسول صلی اللہ علیہ و آلہ وسلم خدا حضرت صادق علیہ السّلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: یہاں پر اللہ کے ساتھ ہونے کے معنی اللہ کا جاننا اور ہر ہر شخص کا پوری طرح علمی احاطہ کر لینا ہے کیوں کے خدا کی ذات لامحدود ہے اس لیے اس کی ذات کی معیت مراد نہیں کیوں کہ اگر خدا کی معیت ذاتی کو مانا جائے گا تو خدا وند عالم کا محدود ہونا لازم آئے گا۔&&(تفسیر صافی ‘ اصولِ کافی)&& }} تفسیر اہل بیت:{{ حضرت امام علی علیہ السّلام ابن ابی طالب علیہ السّلام سے روایت ہے کہ:’’ اس آیت کا ایک مطلب یہ بھی ہے کہ خدا کے امناء ( علم کے امین اہل بیت) کو خدا کی طرف سے یہ قدرت بخشی گئی ہے کہ وہ ساری اس کی مخلوق پر تسلط رکھتے ہیں یہ اس لیے کے وہ جو کچھ کرتے ہیں ان کا فعل خدا کا فعل ہوتا ہے ( کیوں کے وہ ہر کام خدا کی مرضی کے تحت کرتے ہیں ) اس لیے ان کے علم کو خدا کا علم کہا گیا ہے ‘‘۔ &&(تفسیر نورالثقلین جلدہ حدیث ۲۰)&& }} {{حضرت امام علی علیہ السّلام سے پوچھا گیا کہ: خدا کہاں ہے؟فرمایا : ’’ اللہ اس جگہ ہے ‘ اِس جگہ  ہے ‘ اوپر ہے ‘ نیچے ہے ‘ ہم پر احاطہ کیے ہوئے ہے ‘ ہر ہر جگہ ہمارے ساتھ ساتھ ہے ۔ پھر اسی آیت کی تلاوت کی اور فرمایا ‘ اس آیت کے یہی معنی ہیں ۔&&(تفسیر نورالثقلین جلدہ)&& }} {{ فرزندِ رسول صلی اللہ علیہ و آلہ وسلم خدا حضرت جعفر صادق علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ خدا وہ ہے جو سخت پتھر پر چیونٹی کے چلنے کی آواز تک کو سنتا ہے وہ فضائوں میں پرندوں کے پر مارنے کی آوازیں سنتا ہے ۔ کوئی چیز جس کا کان ‘ آنکھیں ادراک کرتی ہیں خدا سے پوشیدہ نہیں ۔ تمام چھوٹی ‘ بڑی چیزیں خدا وند عالم کے لیے ظاہر و آشکار ہیں ۔&&(تفسیر نورالثقلین جلد5 حدیث)&& }}
  58,8,آیت نمبر۸:یہودیوں اور منافقوں کی حرکتوں پر سرزنش:جن لوگوں کو چھپ چھپ کر باتیں کرنے سے منع کیا گیا ہے ان سے اولین مراد یہودی اور منافقین ہیں جو مسلمان کے خلاف چھپ چھپ کر باتیں بناتے اور سازشیں تیار کرتے۔ وہ جب مومنوں کو دیکھتے تو ایک دوسرے کو آنکھوں سے اشارے کرتے۔ اس لیے حضور اکرم  صلی اللہ علیہ و آلہ وسلم نے ایسا کرنے سے سب کو منع کردیا۔ تاکہ یہودی اورمنافقین پہچانے جاسکیں ‘ اور وہ اس حکم کے بعد بھی ایسا ہی کرتے رہے۔&&(تفسیر صافی)&& یہودیوں کا طریقہ سلام:{{یہودی جب جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے پاس آتے تو سلام کرتے وقت یوں کہتے ’’ اَلسَّام علیکم ‘‘ یعنی تم پر موت آئے۔ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم جواب میں صرف ’’ علیکم‘‘ فرما دیا کرتے یعنی ’’ تم پر موت آئے‘‘ اس پر یہ آیت اتری۔&&(تفسیر صافی ‘ روضتہ الواعظین)&& }} تمام مفسرین نے ان آیتوں کو یہودیوں کے لیے لکھا ہے مگر حضرت ابن عباسؓ نے منافقوں کے لیے قرار دیا ہے جو زیادہ معقول ہے ۔&&(ابن جریر)&& جب یہود اور منافقین آپ صلی اللہ علیہ و آلہ وسلم کو السام علیکم یعنی (تم کو موت آجائے) کہہ کر سلام کرتے تھے تو حضرت عائشہؓ چیخ پڑتی تھیں کہ تمہیں موت آئے ‘ تم پر خدا کی لعنت پڑے ۔ حضور اکرم صلی اللہ علیہ و آلہ وسلم ان کو روکتے تھے۔ حضر ت عائشہؓ فرماتی تھی : یا رسول اللہؐ آپ صلی اللہ علیہ و آلہ وسلم نے سنا نہیں کہ انھوں نے کیا کہا؟ حضورِ اکرم صلی اللہ علیہ و آلہ وسلم فرماتے: تم نے نہیں سنا کہ میں نے کیا جواب دیا۔؟میں نے کہا ’’ وعلیکم ‘‘ ( اور تم پر موت آئے) &&(بخاری مسلم۔ ابن جریر ابن ابی حاتم بقول ابن عباس)&& نتیجہ نکلا کہ:برائی کا جواب اس قدر برائی سے دیا جاسکتا ہے &&(مئولف)&& آج کل اکثر و بیشتر سلام کرتے و قت جلدی میں سام علیکم کہنا رواج بن کیا گیا ہے اگرچہ برائی کے طور پر نہیں کہا جاتا۔تاہم اس کی اصلاح ہونی چاہئیے ۔ ’’ سلام علیکم‘‘ کہنے میں زیادہ آسانی اور بہتر طریقہ ہے۔
  58,9,آیت نمبر۹:ہر سرگوشی بری نہیں ہوتی:آخر میں یہ اصول بتایا گیا کہ ہر وہ بات جو چپکے چپکے کہی جائے بری نہیں ہوتی۔ مثلاً اگر کسی مسلمان بھائی میں کوئی عیب ہوتو اس کو تنہائی میں چپکے سے بتانا چاہئیے کسی کے سامنے بتانا اس کی توہین کرنے اور بدنام کرنے اور دل آزاری کے مترادف ہوگا۔&&(فصل الخطاب)&& آیت کا آخری مطلب یہ ہے کہ چپکے چپکے باتیں کرنا از خود کوئی گناہ نہیں ہے ۔ البتہ اگر اس کا مقصد برا ہو ‘ کسی کو بدنام کرنا ہو‘ یا کسی کے خلاف کوئی سازش کرنا ہو‘ تو یہ بہت بری چیز ہے۔ اب منافقوں کا اصل مقصد مسلمانوں کو نقصان پہنچانا اور تحقیر کرنا تھا ‘ اس لیے اس کام کے لیے چپکے چپکے باتیں کرنا گناہ قرار دیا گیا۔&&(تفسیر کبیر ‘ مجمع البیان)&&
  58,10,آیت نمبر۱۰:{{ جناب رسول صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ جب تم تین آدمی موجود ہوتو تم میں کے دو۲ آدمی تیسرے آدمی سے الگ ہوکر چپکے چپکے باتیں نہ کریں کیوں کے اس سے تیسرے آدمی کو رنج ہوگا‘‘۔ یہ بھی لکھا ہے کہ یہاں نجویٰ سے مراد وہ خواب ہیں جن کو دیکھ کر آدمی غمگین ہوتا ہے۔&&(تفسیر صافی ۔ تفسیر مجمع البیان)&& }} محققین نے اس آیت سے نتیجہ نکالا کہ:’’ شیطان میں اتنی قوت نہیں ہوتی کہ وہ کسی مومن کو خدا کی اجازت کے بغیر پریشان کرسکے ‘ خدا اس کو پریشان کرنے کی اجازت دیتا ہے تاکہ مومن کا امتحان ہو اور امتحان سے اس کے جوہر کھلیں اور لوگ اور فرشتے اس کے عظیم مراتب سے واقف ہوں ۔&&(تفسیر ماجدی)&&
  58,11,آیت نمبر۱۱:مجالس میں بیٹھنے کا طریقہ: خدا وندِ حکیم کا مومنین کو یہ حکم دینا کہ اگر کوئی رسول صلی اللہ علیہ و آلہ وسلم کی محفل و مجلس میں آئے تو تم پھیل پھیل کر اس کو حلقے میں بیٹھنے کے لیے جگہ دے دیا کرو ‘ اس لیے تم محفل میں کھل کر دور دور بیٹھو ( یعنی حلقہ کشادہ کردو) تاکہ آنے والوں کو حلقے میں بیٹھنے کی جگہ مل جائے۔ اصل میں لوگ ‘ رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے بہت قریب ہوکر بیٹھنا چاہتے تھے تاکہ آں حضرت صلی اللہ علیہ و آلہ وسلم کا کلام پوری طرح سن سکیں ۔ اس لیے حکم دیا جا رہا ہے کہ پھیل پھیل کر ( جگہ چھوڑ چھوڑ کر) بیٹھو تاکہ نئے آنے والے بھی آپ صلی اللہ علیہ و آلہ وسلم کی تعلیمات سے فیض حاصل کرسکیں ۔پھر یہ بھی کہا گیا کہ جب تم سے کہا جائے کہ اٹھ جاؤ ‘ تو تم اٹھ کر کھڑے ہوجایا کرو تاکہ حلقہ نشست وسیع ہوسکے۔&&(تفسیر صافی ‘ تفسیر قمی)&& اِس سے محققین نے یہ نتیجہ نکالا کہ : ’’ اگر کسی محفل میں کوئی عالم یا صاحبِ کردار شخص آئے تو اس کو اچھی جگہ بیٹھنے کو دی جائے ‘ اور اس کے لیے احتراماً کھڑا ہوجایا جائے‘‘۔ &&(فصل الخطاب)&& امام مالک نے فرمایا: ’’یہ قانون صرف رسول صلی اللہ علیہ و آلہ وسلم ہی کی محفل کے لیے نہیں ہے بلکہ ہر محفل کے لیے ہے پہلے سے بیٹھے ہوؤں کے لیے ضروری ہے کہ بعد میں آنے والوں کو جگہ دیں ‘ اور آنے والے زبردستی گھس گھس کر نہ بیٹھیں ۔ {{ جناب رسولِ صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’ کوئی شخص کسی کو اٹھا کر اس کی جگہ نہ بیٹھے ‘ بلکہ تم خود دوسروں کو بیٹھنے کی جگہ دو‘‘۔ &&(بخاری ‘ مسلم ‘ مسند)&& حضور اکرم صلی اللہ علیہ و آلہ وسلم نے یہ بھی ارشاد فرمایا کہ: ’’ کسی شخص کے لیے حلال نہیں ہے کہ وہ دو۲ آدمیوں کے درمیان ان کی اجازت کے بغیر دھنس جائے‘‘۔ &&(مسند احمد۔ ابودائود ۔ ترمذی)&& }} شانِ نزول:صحابہ کرامؓ کا بیان ہے کہ !!: ’’ لوگ دیر تک جنابِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے پاس بیٹھے باتیں بناتے رہتے تھے جس سے آنحضرت صلی اللہ علیہ و آلہ وسلم کو تکلیف ہوتی تھی ‘ آپ صلی اللہ علیہ و آلہ وسلم کے کاموں میں بھی حرج اور خلل ہوتا تھا دوسرے لوگ قریب نہ آسکتے تھے ۔ اس لیے یہ حکم آیا کہ: ’’ جب تم لوگوں سے کہا جائے کہ اٹھ جاؤ تو تم اٹھ جایا کرو‘‘ &&(ابنِ جریر ۔ ابنِ کثیر)&& دوسری شانِ نزول:مجاہدین اور اوّلین کا احترام!!:{{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم جمعہ کے دن ایک چبوترے پر تشریف فرما تھے۔ صحابہ کرامؓ کھڑے ہوئے تھے۔ جگہ تنگ تھی ۔ بدر کے مجاہدین تشریف لائے۔ حضور اکرم صلی اللہ علیہ و آلہ وسلم ان کا خاص احترام فرماتے تھے کسی نے ان کو جگہ نہ دی ‘ وہ کھڑے رہے ۔ یہ بات آن حضرت صلی اللہ علیہ و آلہ وسلم کو ناگوار گذری۔ آپ صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:فلاں فلاں شخص کھڑا ہوجائے ‘‘ ۔ مگر یہ بات منافقوں کو ناگوار گذری۔ فوراً بکواس شروع کردی۔ حالانکہ رسولِ خدا صلی اللہ علیہ و آلہ وسلم کا مقصد کسی کی توہین کرنا نہ تھا‘ بلکہ بدر کے مجاہدوں اور اسلام کے خادموں کا احترام کرنا سکھانا مقصود تھا۔&&(تفسیر روح المعانی جلد ۲۸ ۔ تفسیر کبیر ۔ قرطبی۔ سیوطی ‘ فی ظلال)&& }} انسان کے رتبے خدا کی نگاہ میں علماء کی فضیلت:{{ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:عالم شہید سے ایک درجہ بلند ہے ‘ اور شہید ‘ عابد سے ایک درجہ بلند ہے اور عالم کی فضیلت تمام دوسرے لوگوں کے مقابلے میں وہی ہے جو میری فضیلت ‘ پست ترین آدمی کے مقابلے میں ہے ۔&&(تفسیر مجمع البیان جلد ۹ ص ۲۵۳)&& }} اس حدیث سے معلوم ہوا کے خدا کی نگاہ میں سب سے بڑا درجہ عالم کا ہے بشرطیکہ وہ باعمل بھی ہو۔ {{ جناب امیرالمومنین علیہ السّلام نے فرمایا: ’’ جس کو طالبِ علمی کے زمانے میں موت آجائے ‘ اس کے اور انبیاء کرام علیہ السّلام کے درمیان ایک درجہ کا فاصلہ رہ جاتا ہے ‘‘۔ &&(جوامع الجامع ۔ نورالثقلین جلد ۵ ‘ قرطبی جلد ۹)&& }}
  58,12,آیت نمبر ۱۲ : آیت کی تشریح:{{ حضرت امام علی علیہ السّلام ابن طالب علیہ السّلام فرمایا کرتے تھے کہ: عالم اسلام کے عظیم مفسر قرآن مجاہد نے فرمایا:’’ حضرت امام علی علیہ السّلام کرم اللہ وجہہ ‘ فرمایا کرتے تھے کہ قرآن مجید میں  یہ (آیت نجوٰی ) ایسی آیت ہے کہ جس پر نہ مجھ سے پہلے کسی نے عمل کیا ‘ اور نہ بعد میں کوئی شخص اس پر عمل کرسکے گا۔&&(تفسیر صافی ۔ تفسیر قمی)&& }} محققین نے آیت کے آخری الفاظ سے نتیجہ نکالا کہ: ’’ خداوند عالم کی اطاعت کرنا گناہوں کی معافی کا ذریعہ ہوجاتی ہے ‘‘۔ &&(تفسیر ماجدی)&& آیت ۱۲ کا مطلب یہ ہے کہ: جب تم رسول صلی اللہ علیہ و آلہ وسلم سے اپنی کوئی بات کرنا چاہو ‘ یا کوئی حاجت طلب کرنا چاہو ‘ تو پہلے غریبوں کو کچھ صدقہ دیدیا کرو ‘ تاکہ وہ صدقہ تمھاری حاجت کو پورا کرانے کا بہترین ذریعہ بن جائے مگر اس حکم پر سوائے حضرت امام علی علیہ السّلام کے کسی نے عمل نہ کیا۔&&(فصل الخطاب ۔ مجمع البیان)&& {{ فرزند رسول صلی اللہ علیہ و آلہ وسلم خدا حضرت امام محمد باقرعلیہ السّلام سے روایت ہے کہ:’’ حضرت امام علی علیہ السّلام دس بار جناب رسول صلی اللہ علیہ و آلہ وسلم سے بات چیت کرنے کے لیے صدقہ دیا اور دسیوں مرتبہ آنحضرت صلی اللہ علیہ و آلہ وسلم سے راز کی باتیں سیکھیں ۔ پھر اللہ تعالیٰ نے اس حکم کو منسوخ کردیا۔&&(تفسیر صافی۔ تفسیر قمی)&& }} {{ حصرت امام علی علیہ السّلام ’ کرم اللہ وجہہ فرماتے ہیں کے جب یہ حکم آیا تو جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے مجھ سے پوچھا کہ کتنا صدقہ مقرر کیا جائے ؟ کیا ایک دینار مقرر کردوں ‘‘؟میں نے عرض کی: یہ لوگوں کی قوت سے زیادہ ہے۔پھر فرمایا: ’’ نصف دینار‘‘ ؟ میں نے عرض کی : ’’ یہ بھی زیادہ ہے‘‘۔ پھر فرمایا : ’’ کتنے مقرر کردوں ؛ میں نے عرض کی : ’’ ایک جو برابر سونا‘‘۔ فرمایا : ’’ یہ تو بہت کم مقدار ہوئی‘‘۔ &&(ابنِ جریر ۔ ترمذی ۔ سند ابویعلی)&& حضرت امام علی کرم اللہ وجہہ فرمایا کرتے تھے کہ ’’ قرآن کی یہ ایک ایسی آیت ہے جس پر میرے سوا کسی نے عمل ہی نہیں کیا‘‘۔ &&(ابنِ جریر۔ حاکم ۔ ابنِ منذر ۔ عبد ابنِ قمیہ۔ تفسیر کبیر)&& }} دوسری شانِ نزول:دولتمندوں کا ایک گروہ اس لیے رسولِ اکرم صلی اللہ علیہ و آلہ وسلم سے اکیلے میں باتیں کرنے کی درخواست کرتا تھا ‘ تاکہ ان کی برتری ثابت ہوجائے‘ اور منافقین چاہتے تھے کے اس طرح رسولِ خدا صلی اللہ علیہ و آلہ وسلم کا وقت ضائع ہوجائے۔ اس لیے خدا نے یہ آیت نازل فرمائی۔ جب خدا نے دیکھ لیا کہ امیر لوگ بھاگ نکلے تو حکم منسوخ فرمادیا۔&&(تفسیر مجمع البیان وغیرہ)&& میں نے صدقہ دے کر رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے یہ علم سیکھا: {{ حضرت امام علی علیہ السّلام نے فرمایا ’’ میں نے صدقہ دے کر رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے ملاقاتیں کیں اور یہ علم حاصل کیا:(۱) میں نے رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے پوچھا : ’’ وفا کیا ہے ‘‘ ؟ فرمایا: توحید کو دل سے سمجھنا اور اس کی گواہی دینا‘‘۔(۲) ’’فساد کیا ہے‘‘؟ فرمایا : ’’ کفر اور شرک ‘‘۔(۳)میں نے پوچھا: ’’ حق کیا ہے ‘‘؟ آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: اسلام ‘ قرآن اور ولایت۔(۴) میں نے پوچھا: ’’ مجھ پر کیا لازم ہے ‘‘ ؟ آپ صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’ اللہ اور رسول صلی اللہ علیہ و آلہ وسلم کی اطاعت کرنا‘‘۔(۵)میں نے پوچھا: ’’ اللہ سے اپنی حاجت کیسے مانگوں ‘‘ ؟ فرمایا : صدق اور یقین کے ساتھ ۔(۶) میں نے پوچھا: ’’ اللہ سے کیا مانگوں ‘‘؟ فرمایا : ’’عافیت‘‘(۷) میں پوچھا : ’’ سرور اور راحت کیا ہے ‘‘ ؟ فرمایا : جنت اور اللہ سے ملاقات‘‘۔ }} امام رازی کا نکتہ گریز:امام رازی نے لکھا کہ : بزرگان صحابہ نے اس لیے صدقہ دے کر رسول صلی اللہ علیہ و آلہ وسلم سے علیحدگی میں باتیں نہیں کیں کیونکہ انھوں نے اس کی ضرورت محسوں نہیں فرمائی یا ان کے پاس رسول صلی اللہ علیہ و آلہ وسلم سے باتیں کرنے کا وقت نہیں تھا۔ اس لیے حضرت امام علی علیہ السّلام کرم اللہ وجہہ کا صدقہ دے کر رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے بار بار علیحدگی میں باتیں کرنا کوئی فضیلت نہیں ہے ۔ اور دوسرے صحابہ کرام کی مذمت نہیں ہے ۔&&(تفسیر کبیر امام رازی)&& امام رازی نے کمالِ تجاہلِ عارفانہ اور حضرت امام علی علیہ السّلام سے بغض ظاہر کردیا۔ اور آیت کے ظاہری الفاظ تک پر غور نہیں فرمایا کہ خدا نے فرمایا کہ: ’’ ارے ‘ کیا تم ڈرگئے کے تم فقیر ہوجاؤ گے کہ تم نے اکیلے میں رسول صلی اللہ علیہ و آلہ وسلم سے بات کرنے سے پہلے صدقہ دینے سے ہاتھ کھینچ لیا اب جبکہ تم نے یہ کام نہیں کیا اور خدا نے تمھاری توبہ قبول کرلی تو اب تماز قائم کرو۔۔۔ الخ اگر یہ حضرت امام علی علیہ السّلام کی فضیلت نہ تھی تو حضرت عبداللہ ابنِ عمر نے یہ کیوں فرمایا کہ’’ علی علیہ السّلام کوتین ایسی فضیلتیں مل گئیں کہ اگر ان میں سے ایک بھی مجھے مل جاتی تو سرخ اونٹوں سے بہتر ہوتی۔ پہلی فضیلت حضرت فاطمہ علیہ السّلام سے شادی (۲) خیبر کے دن کا علم عطا ہونا (۳ ا)آیت نجویٰ پر عمل کرنا۔&&(تفسیر نمونہ ۔ روح البیان‘ کشاف )&& پھر حضرت عبداللہ ابنِ عمرؓ نے اپنے اس بیان میں ’’ فضیلت ‘ ‘ کا لفظ استعمال فرمایا ہے جبکہ امام رازی فرماتے ہیں کے اس میں حضرت علی علیہ السّلام کی کوئی فضیلت ثابت نہیں ہوتی۔ پھر حضرت عبداللہ ابن حصرت عمرؓنے اس آیت پر عمل کرنے کو جناب سیدہ علیہ السّلام سے شادی اور خیبر کے علم کے ساتھ ساتھ بیان فرمایا ہے جو سارے اکابرین کے نزدیک حتٰی کے امام بخاری کے نزدیک بھی حضرت امام علی علیہ السّلام کی فضیلت ہے کیوں کہ امام بخاری نے خیبر کی حدیث بابِ فضائلِ علی علیہ السّلام میں لکھی ہے ۔ (بہر حال امام رازی کا حضرت امام علی علیہ السّلام سے بغض ظاہر ہوگیا۔) &&(مؤلف)&&
  58,14,آیت نمبر۱۴:یہودیوں اور منافقوں کی دوستی پر سرزنش ہے:آیت میں اشارہ ہے یہودیوں کی طرف جن کو منافقوں نے اپنا خاص دوست بنا رکھا تھا ‘ اور یہ دوستی صرف خود غرضی کی بنا پر تھی سچی دوستی نہ تھی اور یہ منافق اس بات پر جھوٹی قسمیں کھایا کرتے تھی کہ ہم اسلام کو دل سے مانتے ہیں اور مسلمانوں کے وفادار ہیں ان قسموں کو انھوں نے اپنے لیے ڈھال بنا رکھا تھا ‘ تاکہ مسلمانوں کے حملوں سے بچ جائیں اور اسی آڑ میں وہ اسلام اور رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے خلاف طرح طرح کے پروپیگنڈے کرتے رہتے تھے‘ اور لوگوں کو راہِ حق سے روکتے رہتے تھے ‘ تاکہ لوگ اسلام قبول نہ کریں یہ اتنا برا کام تھا کے آخر میں خداوند عالم نے فرمایا کہ: ’’ یہ لوگ اللہ کی سزا سے بچ نہیں سکتے۔ یہ لوگ جہنم کے کندے ہیں جہاں وہ ہمیشہ ہمیشہ رہیں گے ‘‘ کیوں کہ یہ منافق ہیں اور بظاہر مسلمان بن کر اسلام کے خلاف باتیں کررہے ہیں ۔&&(تفسیر کبیر ۔ مجمع البیان ۔ تفہیم ۔ کشاف)&& {{ تفسیر برہان میں تفسیر قمی سے منقول ہے کہ ایک دفعہ حضرت رسول کریم صلی اللہ علیہ و آلہ وسلم اپنے ایک صحابی کے پاس سے گزرے تو وہ صحابی ایک یہودی سے کچھ چیزیں لکھ رہے تھے پس یہ آیت اتری۔ جب وہ صحابی حضور اکرم صلی اللہ علیہ و آلہ وسلم کی خدمت میں حاضر ہوئے تو آپ صلی اللہ علیہ و آلہ وسلم نے بطور سرزنش فرمایا: ’’ تم یہودی کے پاس بیٹھ کر کچھ لکھ رہے تھے حالانکہ اللہ تعالیٰ نے منع فرمایا ہے۔ وہ بولے: ’’ حضور صلی اللہ علیہ و آلہ وسلم! میں نے تورات سے آپ صلی اللہ علیہ و آلہ وسلم کے فضائل لکھے ہیں پھر پڑھ کر سنایا۔ حضور صلی اللہ علیہ و آلہ وسلم کے چہرے سے غصے کے آثار نمودار ہوئے۔ یہ دیکھ کر ایک انصاری نے کہاء تم حضور صلی اللہ علیہ و آلہ وسلم کے چہرے کو نہیں دیکھتے غصے سے سرخ ہورہا ہے پس صحابی نے کہا ء’’ میں خدا اور رسول صلی اللہ علیہ و آلہ وسلم کے غضب سے پناہ مانگتا ہوں ۔ پس حضور اکرم صلی اللہ علیہ و آلہ وسلم نے فرمایا کہ اے فلاں ! اگر ان یہودیوں میں خود موسٰی بن عمران علیہ السّلام بھی موجود ہوتے اور تم مجھ سے روگردانی کرکے ان کی طرف جاتے تو یقیناًتم کافر ہوجاتے۔&&(تفسیر انوارالنجف)&& }} یہ ان منافقوں کی مذمت میں ہے جو یہودیوں کے ساتھ اٹھتے بیٹھتے تھے اور ان سے برادرانہ تعلقات قائم کرتے تھے اور مومنوں کے خصوصی راز بھی ان کے سامنے ظاہر کرتے تھے۔ پھر اگر پیغمبر اکرم صلی اللہ علیہ و آلہ وسلم کی شکایت یہودی کرتے تو وہ ان کے ساتھ اس میں شریک ہوجاتے تھے ۔ ان کے متعلق فرمایا کہ: ’’ نہ وہ تم میں سے ہیں ‘‘ اگر ان کو سرزنش کی جائے تو جھوٹی قسمیں کھا کر اپنی برأت کی ضمانت دینے لگتے ہیں ‘ حالانکہ ان کو اپنی منافقانہ روش کا بخوبی علم ہے۔&&(انوار النجف)&&
  58,19,آیت نمبر۱۹:شیطان کا آلہ  کار:ہماری بری خواہشات ہوتی ہیں جن کو استعمال کرا کے وہ ہم سے گناہوں پر گناہ کراتا چلا جاتا ہے جس کا آخری نتیجہ یہ ہوتا ہے کہ ہم خدا اور اس کی سزاؤں کو بھول بیٹھتے ہیں ۔ اور آخر کار شیطان کے لشکروں میں شامل ہوجاتے ہیں ۔&&(تفسیر نمونہ)&& {{ جناب امیرالمومنین علیہ السّلام نے فرمایا:اے لوگو! تمام فتنوں اور خرابیوں کا آغاز غلط نظریات کی پیروی کرنے سے ہوتا ہے۔ یہ غلط نظریات ایسی بدعتیں  ہیں جو اللہ کے حکم کے خلاف لے جاتی ہیں ۔ لوگوں کا ایک گروہ دوسرے گروہ کی دوستی میں ان کی پیروی اختیار کرتا ہے ۔ اگر باطل اپنی خالص شکل میں خود کو پیش کرتا تو کسی عقلمند سے چھپا نہ رہتا ‘ اور اگر حق ‘ باطل سے ملاوٹ سے پاک و صاف ہوتا ‘ تو پھر اختلاف بھی نہ ہوتا ( کیوں کہ سب حق کو مان لیتے ) مگر ہوتا یہ ہے کہ ( بدمعاش لوگ ) کچھ حصہ حق میں سے لیتے ہیں ‘ کچھ حصہ باطل میں سے لیتے ہیں ‘ اور دونوں کو آپس میں ملا دتیے ہیں یہی وہ جگہ ہے کہ شیطان اپنے دوستوں پر غلبہ حاصل کر لیتا ہے ‘ پھر صرف وہ لوگ رہائی پالیتے ہیں جن کے ساتھ اللہ کی توفیقات شامل حال ہوتی ہیں ۔&&(اصول کافی ۔ تفسیر نورالثقلین جلد ۵)&& }} {{ جس وقت فرزندِ رسول صلی اللہ علیہ و آلہ وسلم خدا حضرت امام حسین علیہ السّلام نے کربلا میں کوفہ و شام کی فوجوں کو اندھیری رات میں غل مچاتے ہوئے دریا کی طرح بل کھاتے ہوئے اپنے مد مقابل دیکھا تو فرمایا:’’ تم بہت برے لوگ ہوکہ ایک طرف خدا کی اطاعت اور رسولِ خدا صلی اللہ علیہ و آلہ وسلم پر ایمان لانے کا اظہار کرتے ہو اور اس کے باوجود اب اس لیے آئے ہو کے اولاد پیغمبر صلی اللہ علیہ و آلہ وسلم کو ذبح کرو۔ اصل بات یہ ہے کہ شیطان نے تم پر غلبہ حاصل کرلیا ہے۔ اس نے خدائے عظیم کی یاد کو تمھارے دلوں سے نکال دیا ہے <<  اِنَّا لِلّٰہِ وَاِنَّا اِلَیْہِ رٰجِعُوْنَ >>  @@(ہم اللہ ہی کے لیے ہیں اور ہمیں اسی طرف لوٹ کر جانا ہے)@@ &&(نورالثقلین جلد ۵)&& }} << حِزْبُ الشَّیْطٰنِ >>  شیطانی ٹولہ کون؟اور فرقہ ناجیہ۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔۔ نجات پانے والا کون؟{{ سُلیم بن قیس ہلالی نے جناب امیرالمومنین علیہ السّلام سے روایت کی ہے کہ: آپ علیہ السّلام نے فرمایا : ’’ اس امت کے تہتر فرقے ہوں گے ۔ ان میں سے بہتر دوزخی اور ایک جنتی ہوگا۔تہتر میں ساٹھ عامۃ المسلمین کے ہوں گے۔ اور تیرہ فرقے ان لوگوں کے ہوں گے جو ہماری محبت کا دم بھرتے ہوں گے ۔ پس ان میں سے مومنہ ناجیہ فرقہ وہ ہے جو ہمارے احکام کی پیروی کرے گا‘ اور ہمارے دشمنوں سے بیزار ہوگا ہمارے حقِ امامت کا عارف ہوگا اور کتاب و سنت کے لحاظ سے ہماری اطاعت کو فرض سمجھے گا‘ اور ہمارے حقوق کی معرفت سے جو اس کا دل نورانی ہوگا تو اس میں وہ کبھی شک نہ کرے گا میں اور میرے اوصیاء جو قیامت تک ہونے والے ہیں وہ ہیں جن کو اللہ نے اپنی ذات کے ساتھ اور اپنے نبی صلی اللہ علیہ و آلہ وسلم کے ساتھ متعدد آیات میں ذکر فرمایا ہے۔ہمیں اللہ نے طاہر اور معصوم قرار د یا اور ہم اس کی مخلوق پر شہدا ہیں اور اس کی زمین پر اس کی حجت ہیں ۔ ہم قرآن کے ساتھ ہیں اور قرآن ہمارے ساتھ ہے کہ ایک دوسرے سے ہرگز جدا نہ ہوں گے یہاں تک کے حوضِ کوثر پر رسول اللہ  صلی اللہ علیہ و آلہ وسلم کے پاس پہنچیں گے۔پس یہ فرقہ تہتر فرقوں میں سے وہ ہوگا جس کو جہنم سے نجات ملے گی۔ اور تمام فتنوں اور گمراہیوں سے ان دامن پاک ہوگا اور وہ سچ مچ جنتی ہوں گے اور ان میں سے ستر ہزار ایسے ہیں جو بلا حساب جنت میں جائیں گے اور جو باقی بہتر فرقے ہوں گے وہ وہ ہیں  جو حق کے دشمن ہوں گے دینِ شیطان کے مددگار ہوں گے خدا اور رسول صلی اللہ علیہ و آلہ وسلم اور مومنوں کے دشمن ہوں گے پس وہ بلا حساب جہنم میں جائیں گے ۔ وہ قیامت کے دن قسمیں کھائیں گے کہ ہم ایمان پر تھے لیکن ان کو کچھ فائدہ نہ ہو سکے گا۔&&(تفسیر  انوار النجف)&& }}
  58,20,آیت نمبر ۲۰ : <<  یُحَآدُّوْنَ >>  کی اصل >> محادہ<< ہے جس کے معنی ایسی سخت مخالفت کے ہوتے ہیں جس کی وجہ سے مخالفین کا آپس میں ملنا مشکل ہوجاتا ہے ۔&&(فتح القدیر)&& آیت نمبر ۲۰ کا پیغام یہ ہے کہ جس طرح پچھلی امتوں میں سے جن لوگوں نے خدا اور رسولوں علیہ السّلام کی مخالفت کی تھی تو خدا نے ان کو ذلیل کیا تھا ‘ اسی طرح آج بھی جو کوئی اللہ اور رسول اللہ صلی اللہ علیہ و آلہ وسلم کی مخالفت کریگا ‘ ذلیل ہوگا۔اب کیوں کے یہ فیصلہ لکھنے والا خداوند عالم ہے جو سب پر غالب اور قوی ہے اس لیے اس کا فیصلہ کوئی بدل نہیں سکتا ۔ اس کا یہ فیصلہ قدرِ محکم اور امر مبرم ہوتا ہے ۔ [[ حقیقت ابدی ہے مقامِ شبیری علیہ السّلام ۔بدلتے رہتے ہیں انداز کوفی و شامی ]]۔&&(مؤلف)&& ایک اشکال:اس سلسلے میں اکثر پوچھا جاتا ہے کہ خداوند عالم تو یہ فرما رہا ہے کہ: ’’ میرے رسول صلی اللہ علیہ و آلہ وسلم کامیاب ہوں گے ‘ ضرور غالب ہوں گے کیونکہ خدا قوی اور ناقابلِ شکست ہے ‘‘ پھر سوال یہ ہے کہ امام حسین علیہ السّلام کو ظاہری شکست کیسے ہوگئی؟اصل بات یہ ہے فتح و شکست کا معیار قتل ہوجانا یا بچ جانا نہیں ہوا کرتا۔امام حسین علیہ السّلام نے یہ دعٰوی ہی نہیں کیا تھا کہ ’’ مجھے کوئی قتل نہیں کرسکتا ‘ ان کا قول تو یہ تھا میں اس زمانہ کا امام ہوں ‘ مجھ پر کسی کی بیعت کرنا نہیں ہے بلکہ میری بیعت سب پر واجب ہے ‘ میری اطاعت سب پر اسی طرح لازم ہے جیسے رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی بیعت اور اطاعت سب لوگوں پر واجب و لازم تھی ۔ کجا یزید کی بیعت‘‘۔(چہ نسبت خاک رابا عالمِ پاک)اور یزید کا دعوٰی یہ تھا کے میر بیعت کرو۔ فتح و شکست کا معیار مقصد یا دعوٰی کے پورا ہونے یا نہ ہونے پر ہوتا ہے۔ اب آپ دیکھیں کہ کیا مقصدِ یزید پورا ہوا؛ ہرگز پورا نہ ہوا۔یزید بیعت نہ لے سکا۔ وہ اپنے مقصد میں ناکام ہوا۔ اور امام حسین علیہ السّلام کو فتح حاصل ہوئی۔(۲) امام حسین علیہ السّلام کا اصل مقصد اسلام کی حفاظت کرنا ‘ اچھائی اور برائی کے فرق کو واضح کردینا تھا ‘ لٰہذا انھوں نے قتل ہوکر اسلام کو بقائے دوام بخشی اور آج کس کا نام زندہ ہے؟[[ ڈوب کر پار اُتر گیا اسلام۔آپ کیا جانیں کربلا کیا ہے؟ ]] (۳) امام حسین علیہ السّلام کا اللہ کی کتاب قرآن مجید کے احکامات ‘ اوامرو نواہی اورخداوند عالم کے پیغامات کو بحفاظت لوگوں تک پہنچانا مقصد تھا ‘ سو وہ آپ نے پہنچا دیا ‘ اور یہ کہ ظالم ‘ جابر ‘ فاسق ‘ فاجر حاکمِ جور کی اطاعت کرنا شیطان کی اطاعت کرنا ہے۔ یہ بات سب پر واضح ہوگئی امام علیہ السّلام کا مقصد پورا ہوگیا۔&&(مؤلف)&& (۴) امام حسین علیہ السّلام کا اصل مقصد قرآن اور اس کے پیغامات کو سمجھانا تھا جو آپ علیہ السّلام نے پورا کر دکھایا [[ رمزِ قرآن از حسین علیہ السّلام آموختیم۔زآتشِ او شُعلہا اندوختیم ]] ۔( اقبالؒ) یعنی : ہم نے قرآن کا راز امام حسین علیہ السّلام سے سیکھ لیا ۔ ان کے نورِ ایمان سے ہم نے اپنے ایمان کو منور کرلیا۔(۵) حضرت امام حسین علیہ السّلام کا اصل مقصد حریت کا سبق سکھانا تھا کہ انسان باطل کے سامنے سرنہ جھکا دے ‘ اور باطل کا مقابلہ ڈٹ کر کرے۔ تاکہ شیطانی قوت ختم ہوجائے یا اس کا زور ٹوٹ جائے اور منافقوں کے چہروں سے نقاب اتر جائے تاکہ لوگ حق اور باطل کو پہچان لیں ۔(۶) حضرت امام حسین علیہ السّلام کا اصل مقصد یہ تھا کے انسان صرف اللہ یکتا کی اطاعت اور بندگی کرے ‘ حاکم جور کی اطاعت اور بندگی کرنا شیطان کی اطاعت و بندگی کرنا ہے۔ <<  وَمَا خَلَقْتُ الْجِنَّ وَالْانْسَ اِلَّا لِیَعْبُدُوْنِ لَّا تَعْبُدُوا الشَّيْطٰنَ۝۰ۚ اِنَّہٗ لَكُمْ عَدُوٌّ مُّبِيْنٌ۝۶۰ۙ وَّاَنِ اعْبُدُوْنِيْ۝۰ۭؔ ھٰذَا صِرَاطٌ مُّسْتَــقِيْمٌ۝۶۱ >>  && (سورۃ یٰسٓ ا ٓیت ۶۰۔۶۱ پارہ ۳)&& [[ حسین علیہ السّلام نازِ مشیت ‘ حسین علیہ السّلام امام نیاز۔حسین علیہ السّلام ایسی حقیقت جو اصل میں  اعجاز ۔حسین علیہ السّلام اپنے ہی جد کی یہ مستقل آواز۔ہزار کرب و بلا ہوں مگر نماز نماز۔جناں کی سمت نہ وقتِ نماز بڑھ کے چلے۔نماز رہ گئی ‘ ایسی نماز پڑھ کے چلے ]]۔(آلِ رضاؒ)(۷) حضرت امام حسین علیہ السّلام کا مقصد مسلمانوں کے اندر تازہ روحِ جہاد پیدا کرنا تھا۔[[ تارِ ما از زخم اش لرزاں  ہنوز ۔زندہ از تکبیرِ او ایماں ہنوز۔ہمارے دلوں  کے تار ان کی ضرب سے آج تک لرز رہے ہیں ۔ان کی تکبیر سے آج بھی ایمان میں زندگی و تازگی ہے ]]۔۔( اقبالؒ)(۸) حضرت امام حسین علیہ السّلام کا مقصد مثالی قربانی پیش فرمانا تھا جس کا وعدہ روزِ الست اللہ تعالیٰ جل شانہ سے فرماچکے تھے ‘ اور جناب رسول صلی اللہ علیہ و آلہ وسلم نے اللہ عزاسمہ کا پیغام ان کو سنا دیا تھا کہ: <<  اِنَّ اللہَ (تَبَآرَکَ و تَعالیٰ) شَآ ئَ اَنْ یَرَاکَ قَتِیلًا بِالْعَراقِ >>  ۔ یعنی : @@’’ اللہ با برکت بلند و برتر ‘‘ @@ (اے حسین علیہ السّلام !) تم کو عراق ( کی سرزمین) میں قتل ہوتا ہوا دیکھنا چاہتا ہے &&(بحار الانوار ۔ جلاء العیون)&& حضرت امام حسین علیہ السّلام کا مقصد خدا و رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے کیا ہوا وعدہ قربانی پورا کرنا تھا۔ وہی وعدہ جسے قرآن مجید نے ذبح عظیم فرمایا ہے۔ جب حضرت اسماعیل علیہ السّلام کو اللہ نے ذبح ہونے سے بچایا تو ارشاد فرمایا: << وَفَدَيْنٰہُ بِذِبْحٍ عَظِيْمٍ۝۱۰۷ >>  یعنی : @@ ہم نے ان کو ذبح عظیم کی وجہ سے بچا لیا @@۔ &&(سورۃ ۳۷ ‘ آیت ۱۰۷ پارہ ۲۳)&& &&(القرآن)&& [[ اللہ اللہ بائے بسم اللہ پِدر۔معنیِ ذبحِ عظیم آمدِ پِسر۔غریب و سادہ ورنگیں ہے داستان حرم نہایت اس کی حسین علیہ السّلام ابتدا ہیں اسماعیل علیہ السّلام ]]۔( اقبالؒ)(۹) حضرت امام حسین علیہ السّلام کا اصل مقصد شہادت کے مرتبے پر فائز ہونا ‘ امر بالمعروف اور نہی عن المنکر تھا ۔ جس کا آپ علیہ السّلام ایہ نے پورا پورا حق ادا کردیا ‘ اور بقائے دوام اور خوشنودی پاک پروردگار حاصل کی:<< يٰٓاَيَّتُہَا النَّفْسُ الْمُطْمَىِٕنَّۃُ۝۲۷ۤۖ ارْجِعِيْٓ اِلٰى رَبِّكِ رَاضِيَۃً مَّرْضِيَّۃً۝۲۸ۚ فَادْخُلِيْ فِيْ عِبٰدِيْ۝۲۹ۙ وَادْخُلِيْ جَنَّتِيْ۝۳۰ۧ >>  &&(سورۃ الفجر ۔ پارہ ۳۰)&& یعنی : @@ ’’ اے نفس مطمنۂ ! اپنے پروردگار کی طرف لوٹ آ ایسی حالت میں کہ تو خوش اور پسندیدہ ہے اور میرے ( خاص الخاص) بندوں ‘ اطاعت گزاروں میں داخل ہوجا ۔ اور میری جنت میں داخل ہو(کر جوانانِ جنت کی سرداری کا عہدہ سنبھالے)‘‘@@۔ &&(مؤلف)&&
  58,22,آیت نمبر۲۲:{{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقرعلیہ السّلام سے روایت ہے کہ اس آیت میں ’’روح ‘‘ سے مراد ایمان ہے ‘‘۔ &&(تفسیر صافی)&& }} {{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السّلام سے روایت ہے کہ جناب رسول صلی اللہ علیہ و آلہ وسلم خدا نے فرمایا: کوئی مومن ایسا نہیں ہوتا جس کے دل کے اندر دو ۲ کان نہ ہوں ۔ ایک کان میں فرشتہ خدا کی طرف سے اس کو ہدایت سناتا رہتا ہے اور اس فرشتے کے ذریعہ مومن کی مدد بھی کرتا رہتا ہے اِ س آیت کا یہی مطلب ہے۔&&(تفسیر صافی ۔ بحوالہ الکافی)&& }} مومنِ کامل مخلص کی ایک علامت یہ ہوتی ہے کہ وہ خدا کے دوستوں کو دوست رکھتا ہے اورخدا کے دشمنوں  ‘ باغیوں سے دشمنی رکھتا ہے ۔ مطلب یہ ہے کہ اس کی طبعی اور فطری محبتوں پر اس کی عقلی محبت غالب آجاتی ہے۔&&(فصل الخطاب)&& {{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت جعفر صادق علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا کہ:’’ ایمان کی سب سے مضبوط شاخ خدا کے دوستوں سے دوستی رکھنا اور خدا کے دشمنوں سے دشمنی رکھنا ہے‘‘۔ &&(الکافی)&& }} [[ غالب ندیم دوست سے آتی ہے بوئے دوست۔مشغولِ حق ہوں بندگی بوتراب میں ]] ۔(غالب)سب سے افضل عمل:{{ فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم خدا حضرت امام جعفر صادق علیہ السّلام سے روایت ہے ’’ خدا وند عالم نے حضرت موسٰی علیہ السّلام پر وحی فرمائی کہ:’’ اے موسیٰ علیہ السّلام ! تم نے کوئی کام میرے لیے بھی انجام دیا ہے‘‘؟حضرت موسٰی علیہ السّلام نے عرض کی : ’’ جی ہاں ۔ میں نے آپ کے لیے نمازیں پڑھی ہیں ‘ روزے رکھے ہیں ‘ میں ہمیشہ آپ کو  یاد کرتا رہتا ہوں ‘‘ ۔ آپ کے لیے خیرات کرتا رہتا ہوں ۔خدا وندِ تعالیٰ نے وحی فرمائی:’’ اے موسیٰ علیہ السّلام ! نماز تمھارے حق کی نشانی ہے ( کہ تم حق پر ہو)روزہ جہنم کی آگ کے مقابلے پر تمھاری سپر ہے ۔ خیرات میدانِ حشر کے لیے سایہ ہے ۔ تمھارا مجھے یاد کرتے رہنا ‘ تمھارا نور ہے ‘ ( یہ سب تمھارے فائدہ کے لیے ہیں )اب تم یہ بتاؤ کہ تم نے میرے لیے کونسا کام کیا؟ حضرت موسیٰ علیہ السّلام نے عرض کی: پالنے والے! آپ خود ہی میری رہنمائی فرمائیں کہ آپ کے لیے کیا کام کروں ارشاد رب العزت ہوا: ’’ اے موسیٰ علیہ السّلام ! تم نے کبھی میرے لیے کسی سے محبت کی ؟ میری خاطر کسی سے دشمنی کی ؟  حضرت موسٰی علیہ السّلام سمجھ گئے کہ اللہ کے لیے دوستی اور دشمنی کرنا افضل عمل ہے }} ۔ایمان کی تکمیل اور اچھے برے کی پہچان:{{ فرزندِ رسول خدا  صلی اللہ علیہ و آلہ وسلم حضرت جعفر صادق علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ کسی شخص کا اللہ پر ایمان کامل نہیں ہوتا جب تک وہ اللہ کو اپنی جان ‘ مال ‘ ماں باپ ‘ اولاد اور گھر والوں  سے زیادہ محبوب نہ رکھے‘‘۔ &&(سفینہ البحار جول  ۲۰۱)&& }} {{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ اگر تم یہ جاننا چاہو کہ تم واقعاً اچھے انسان ہو ( یا نہیں ) تو اپنے دل میں جھانک کر دیکھو اگر تمھارا دل اللہ کی اطاعت کرنے والوں سے محبت کرتا ہے اور اللہ کے نافرمانوں کو دشمن رکھتا ہے تو جان لو کہ تم واقعاً اچھے انسان ہو اور یہ بھی کہ اللہ تمھیں پسند کرتا ہے اور تم سے محبت کرتا ہے ۔لیکن اگر تمھارا دل اللہ کی اطاعت کرنے والوں کا دشمن ہے اور اللہ کی معصیت کرنے والوں کو دوست رکھتا ہے تو پھر تم سمجھ لو کہ تمھارے اندر کوئی خوبی نہیں ہے ۔ اور یہ بھی سمجھ لو کہ اللہ تم سے دشمنی رکھتا ہے کیونکہ انسان ہمیشہ اسی کے ساتھ ساتھ رہے گا جسے وہ دوست رکھتا ہے ۔&&(سفینہ البحار جلد ۱)&& }} {{ حضورِ اکرم صلی اللہ علیہ و آلہ وسلم سے کسی صحابی نے دریافت کیا : ’ ’ قیامت کب آئے گی ‘‘؟۔ آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ تم نے قیامت کے لیے کیا سامان اکٹھا کیا ہے‘‘؟۔صحابی نے شرم سے سرجھکا لیا اور عرض کی : ’’ میرے پاس آپ صلی اللہ علیہ و آلہ وسلم کی محبت کے سوا کچھ بھی نہیں ‘‘۔ آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا : پھر سنو!<< اَلْمَرْئُ مَعَ اَحَبَّ >>  ہر شخص (وہاں ) اس کے ساتھ ہوگا جس سے وہ محبت کرتا ہوگا‘‘۔ &&(بخاری شریف)&& }} {{ حضرت سلمان فارسیؓ فرماتے ہیں کہ: ’’ میں جب بھی جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی خدمت میں حاضر ہوتا تھا ‘ آپ صلی اللہ علیہ و آلہ وسلم ہمیشہ میری ران پر ہاتھ مار کر حضرت امیر المومنین علیہ السّلام کی طرف اشارہ کرکے ارشاد فرماتے : << یَا سَلمانُ ھٰذَا وَ حِزْبُہٗ ھُمْ الْمُفْلِحُوْنَ >>  یعنی : اے سلمان ! یہ علی علیہ السّلام اور ان کا گروہ مکمل کامیابی حاصل کرنے والے ہیں ‘‘۔ &&(تفسیر برہان جلد ۴ ص ۳۲۱  مع مکمل حوالہ جات کتبِ اہل سنت)&& }} {{ حضورِ اکرم صلی اللہ علیہ و آلہ وسلم نے یہ بھی ارشاد فرمایا: <<  حُبُّ عَلِی عِبَادَۃ >>  ( علی سے محبت کرنا عبادت ہے ) &&(ارجع المطالب ‘ صواعقِ محرقہ)&& }} {{ فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’ جب انسان زنا کرتا ہے تو اس وقت اس کی روحِ ایمان اس سے جدا ہوجاتی ہے یہ روحِ ایمان وہی ہے جس کے متعلق خداوند عالم نے اس آیت میں فرمایا:<< وَاَیْدَھُم بِرُوْحِ مِّنْہُ >>  یعنی :@@ ’’ اللہ نے اپنی طرف کی روح سے ان کو تقویت پہنچائی‘‘ @@۔&&(اصول کافی ۔ تفسیر المیزان جلد ۱۹)&& }}خدا وند عالم کا آخر میں فرمانا : رَضِیَ اللّٰہُ عَنْھُم اللہ ان سے راضی ہوا۔ یہ ان صحابہ کرامؓ کے لیے اتری جو واقعاً خدا وند عالم کو دل سے مانتے تھے (۲) اللہ اور رسول صلی اللہ علیہ و آلہ وسلم کی مخالفت کرنے والوں سے محبت نہیں رکھتے تھے خواہ وہ ان کے باپ ‘ بیٹے ‘ بھا ئی یا کہنے والے ہی کیوں نہ ہوں ‘ گویا ان کی خدا و رسول صلی اللہ علیہ و آلہ وسلم سے محبت اتنی شدید تھی کہ ہر محبت پر غالب تھی یہی وہ لوگ تھے جن کی دلوں پر خدا نے ایمان لکھا یا تھا یعنی عظیم توفیقات سے نوازا تھا ان کی مدد اپنی طرف کی روح سےکی تھی۔اِ س آیت کے اولین مصداق وہی صحابہ کرامؓ ہیں لیکن اس کا اطلاق و مفہوم عام ہے۔&&(مؤلف)&&
