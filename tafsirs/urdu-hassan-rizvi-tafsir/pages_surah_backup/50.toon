  50,1,آیت نمبر۱:پہلی تفسیر : <<’’ق‘‘ >> کا لفظ مخفف ہے << قولنا قضیٰ >>۔ یعنی خدا فرما رہا ہے :@@’’ ہمارا قول فیصلہ کن ہے ‘‘۔ @@ اس میں رد وبدل نہیں ہوسکتی ۔ کوئی لفظ یا حرف ٹالا نہیں جا سکتا ۔&&(تفسیر روح المعانی)&& دوسری تفسیر: << ’’ق‘‘ >> سےمراد ہے << ’’قِفْ‘‘ >> یعنی ’’ذرا رکو اور  سوچو‘‘ {{ (تفسیر روح فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقرعلیہ السّلام سے منقول ہے کہ << ’’قاف‘‘ >> ایک سبزرنگ کا پہاڑ ہے۔ اور  دوسری روایت میں ہے کہ زبر جد سبز کا پہاڑ ہے۔ }} !!{{ (تفسیر تفسیر برہان میں کتاب’’ منہج التحقیق‘‘ سےمروی ہے کہ ایک مرتبہ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام حسن علیہ السّلام نے اپنے والد بزرگوار سے فرمائش کی کہ ہمیں اپنے فضل و کرامت میں سے کچھ دکھائیے؟چنانچہ جناب امیرالمومنین علیہ السّلام امام حسن علیہ السّلام اور  سلمانؓ کولے کر ہوا کے دوش پر سوار ہوئے اور  چند دقیقوں میں کوہ قاف پر جاپہنچے۔ وہ زمرد سبز کا پہاڑ تھا جس پرایک فرشتہ موجود تھا۔ اس نے جناب امیرالمومنین علیہ السّلام کوسلام کیا اور  کچھ پوچھنا چاہا، آپ علیہ السّلام نے فرمایا:کیا تم حضرت خضر علیہ السّلام کی زیارت کرنا چاہتے ہو؟ ‘‘ اس نے عرض کی:’’ جی ہاں ‘‘ آپ علیہ السّلام نے فرمایا :جائو تم کواجازت ہے۔فرشتے نے << بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِيْمِ >> پڑھا اور  چلا  گیا۔ اور  کچھ دیر نہ گزری تھی کہ وہ زیارت خضرعلیہ السّلام سے مشرف ہوکرواپس بھی آگیا ۔ پھرآپ علیہ السّلام نے فرمایا: ’’ اے سلمانؓ !خداکی قسم کہ جس نے آسمانوں کوبغیر ستونوں کے روکا ہوا ہے ان فرشتوں میں سے کوئی بھی ہماری اجازت کے بغیر اپنے مقررہ مقام سے حرکت نہیں کرسکتا اور  میرے بعد میرے فرزند حسن علیہ السّلام کا بھی یہی مقام ہوگا، اور ان کے بعدحسین علیہ السّلام،اور  پھر یکے بعد دیگرے ان کی اولاد سے نو اماموں کا یہی منصب ہوگا۔سلمانؓ کا بیان ہے کہ میں نے سوال کیا: ’’کوہ قاف پرموکل فرشتے کا کیا نام ہے؟‘‘ فرمایا:’’ اس کا نام ترجائیل ہے‘‘ ۔ سلمانؓ کہتے ہیں کہ میں نے پھر سوال کیا: ’’آپ علیہ السّلام کس طرح ہرشب اس مقام پرآتے اور واپس جاتے ہیں ‘‘۔ فرمایا:ـ’’ جس طرح اب تمھیں لے آیا ہوں ،اے سلمانؓ !مجھے اس ذات کی قسم جس نے دانے کو شگافتہ فرمایا اور  روح کو پیدا کیا،میرے پاس آسمانوں اور  زمینوں کے ایسے راز ہیں کہ ان میں سے کسی ایک کوبھی تم برداشت نہیں کرسکوگے۔بتحقیق خداوند متعال کا اسم اعظم بہتر حرفوں پر ہے اور  آصف بن برخیا کے پاس صرف ایک حرف تھا جس کے ذریعہ سے ان کے اور  تخت بلقیس تک کی درمیان زمین دھنس گئی تھی اور  انھوں نے تخت بلقیس کواس کے مقام سے اٹھا کر حضرت سلیمان علیہ السّلام کے سامنے لاکر رکھ دیا تھا۔ اور ہمارے پاس خداکی قسم ،اسم اعظم کے بہتر حرف ہیں اور  ایک حرف جس کا تعلق علم غیب سے ہے وہ اللہ کے پاس محفوظ ہے اس میں اس کا کوئی شریک نہیں پھرآپ علیہ السّلام نے << لاحوال ولاقوۃ الاباللہ العلی العظیم پڑھا……الخ۔>> &&(تفسیر برہان، انوارالنجف)&& }}
  50,3,آیت نمبر۳:خدا جواب دے رہا ہے کہ مرنے کے بعد خدا کیلئے تمھیں پلٹانا کوئی مشکل کام نہیں ہے کیونکہ خدا کاعلم ان تمام اجزاء پر محیط ہے جومرنے کے بعد زمین میں پھیل جاتے ہیں ۔ اس لئے خدا ان تمام بکھرے ہوئے اجزاء کوجمع کرنے پرقدرت رکھتا ہے، پھر تمھیں دوبارہ زند ہ کرنے پر بھی قادرہے۔&&(تفسیر تبیان)&&
  50,6,آیت نمبر۶:آسمان میں شگاف نہیں :(جدید تفسیر کے مطابق) آسمان میں شگاف نہ ہونے (۱) یعنی یہ فضا جو زمین کو گھیرے ہوئے ہے اس میں کہیں کوئی شگاف نہیں ہےاس لئے یہ ایک محفوظ چھت کی طرح ہے جوآسمانی پتھروں کو زمین کی طرف آنے سے روک دیتی ہے اور ان کو زمین تک آنے سے پہلے ہی جلا کر راکھ کر دیتی ہے اور ساتھ ہی ساتھ سورج کی نقصان دہ شعاعوں سے بھی ہمیں بچائے رہتی ہے۔(۲)دوسرے معنی یہ بھی ہوسکتے ہیں کہ اس میں پتھر کی طرف اشارہ ہے۔ جدید تحقیقات کے مطابق تمام سیاروں کے درمیان کا فاصلہ ایک بے رنگ بے وزن پتھریلے مادے سے پرہے جو روشنی کی لہروں کواٹھائے ہوئے ہے اور ان کوایک جگہ سے دوسری جگہ منتقل کرتاہے ۔اس لحاظ سے سارے عالم ہستی میں کوئی شگاف نہیں ہے۔&&(تفسیر نمونہ)&&
  50,7,آیت نمبر۷:آیت کا مطلب یہ ہے کہ جس طرح ہم نے آسمان سے پانی اتار کرمردہ زمین کوتمھاری آنکھوں کے سامنے زندہ کردیا،اسی طرح ہم تمھیں موت دینے کے بعد دوبارہ زندہ کراٹھائیں گے۔ جس طرح بارش برسنے پر نباتات زمین سے باہر نکل آتی ہے، تم بھی اسی طرح قیامت کےدن قبروں سے نکالے جائوگے۔&&(تفسیر صافی)&& مطلب یہ ہے کہ جب ہم بارش کے ذریعے زمین کے ذرات کوملا جلا کرنباتات کے نکالنے پر قادر ہیں تو پھر انہی مٹی کے ذرات کوملا جلا کر تمھیں بھی قبروں سے نکالنے پر قادر ہیں ۔&&(تفسیر علی ابن ابراہیم)&& نتائج وتعلیمات:محققین نے نتیجہ نکالا کہ یہاں پر(۱) خداوند عالم لوگوں کوجسمانی طورپر دوبارہ  زندہ ہوکر قبروں سے باہر نکلنے کی خبردے رہاہے۔ اس لئے فلسفیوں کی یہ بات غلط ثابت ہوگئی کہ ثواب وعذاب صرف روحانی چیز ہے ۔کیونکہ اگرقرآن جسمانی معاد کونہ مانتا تو بارش برسنے اور  نباتات کے زمین سے نکلنے کی مثال نہ دیتا۔&&(ماجدی)&& آیت کااستدلال یہ ہے کہ:’’ جوخدا بے جان مٹی کوبے جان پانی سے ملا کرنباتی زندگی پیدا کرسکتاہے۔ بھلا وہ خدا،مرنے کے بعد ہمیں زندگی کیوں نہیں دے سکتا؟تم آنکھوں سے دیکھ لوکہ زمین خشک ،مردہ بے جان پڑی ہے، بارش کا ایک چھینٹا پڑتے ہی اس میں  زندگی کے چشمے پھوٹنے لگتے ہیں، مدتوں سے مری ہوئی درختوں کی جڑیں یک لخت جی اٹھتی ہیں ۔ یہ بات صاف صاف ثابت کررہی ہے کہ موت کے بعد دوبارہ زندگی ممکن ہے، پھر تم کیسے اس بات کوجھٹلا رہے ہو۔ جب خدا چاہے گا توتم اسی طرح زمیں سے نکل آوگے ،جس طرح نباتات بارش کے برستے ہی زمین سے نکل آتی ہے۔ &&(تفسیر کبیر ،مجمع البیان، تفہیم ،نمونہ)&&
  50,12,آیت نمبر۱۲:عرب روایات کے مطابق <<الرس>> کے نام کے دو مقام مشہور ہیں ۔(ا) نجد میں (۲) دوسرا حجاز میں ،مگر نجد کا الرس زیادہ مشہورہے۔ یہ ایسی قوم تھی کہ جس نے اپنے نبی کوکنویں میں پھینک دیا تھا۔خداوند عالم نے فرعون کی قوم کے بجائے صرف فرعون کا نام اس لئے لیا کہ وہ اپنی قوم پراس طرح مسلط تھا کہ اس کے مقابلہ پر قوم کی کوئی آواز نہ تھی۔ اس لئے پوری قوم کی گمراہی کا ذمہ دار صرف فرعون کوقراردیا گیا ہے ،معلوم ہوا کہ جہاں آمر مسلط ہوتاہے، وہ پوری قوم کے گناہوں کا ذمہ دار ہوتا ہے۔ قوم کی ذمہ داری اپنے اعمال میں آزاد ہونے پر ہوتی ہے۔ &&(تفسیر، کبیر،تفسیر مجمع البیان، تفہیم ، تفسیر نمونہ)&& ’’الرس‘‘ ایک کنویں کا نام ہے جس کے پاس وہ قوم رہتی تھی، وہ بتوں کوپوجتے تھے، یہ قوم اس لئے ہلاک ہوئی کہ مرد مردوں کے ساتھ اور عورتیں ،عورتوں کے ساتھ ازدواجی تعلقات رکھتے تھے۔&&(تفسیر مجمع البیان ،تفسیر علی بن ابراہیم بقول امام محمد باقرعلیہ السّلام)&&
  50,15,آیت نمبر۱۵:{{ فرزند رسول خداصلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقرعلیہ السّلام سے روایت ہے کہ فرمایا:’’ کیا تم سمجھتے ہوکہ اللہ نے تمھارے سوا اور  آدمی پیدا نہیں کیے؟ خدا کی قسم! اللہ نے ہزاروں آدم علیہ السّلام پیدا کئے ہیں ‘‘۔ && (تفسیر صافی ص۴۷۴،توحید خصال عیاشی)&& ایک اور روایت میں ہے کہ آپ علیہ السّلام نے فرمایا کہ اللہ تعالیٰ نے جب سے زمین کوپیدا فرمایا ہے اس میں سات عالم پیدا کیے جن میں اولادِ آدم علیہ السّلام نہ تھی پس وہ زمین سے پیدا کیے اور  یکے بعد دیگرے رہے۔ ان کے بعد اللہ نےاس آدم علیہ السّلام کو پیدا فرمایا جوانسانوں کے باپ ہیں ، اور  ان سے ان کی ذریت کوپیدا فرمایا۔ خدا کی قسم ،جنت جب سے پیداہوئی ،ارواح مومنین سے خالی نہیں ہوئی، اور جہنم کوجب سے پیدا فرمایا ہے وہ بھی کفاراور  نافرمانوں سے کبھی خالی نہیں ہوئی۔ کیا تم یہ سمجھتے ہوکہ قیامت کے بعد مومنین کے جنتی بدن اپنی ارواح کے ساتھ جنت میں چلے جائیں گے اور جہنمی ارواح اپنے بدنوں کے ساتھ جہنم میں چلے جائیں گے توخدا کی عبادت کرنے والا کوئی باقی نہ ہوگا؟ نہیں نہیں،بلکہ خداوند قدیر پھر نرو مادہ کے بغیر ایک مخلوق کوپیدا کرے گا جو اللہ تعالیٰ کی عبادت اور تسبیح وتحمید کرتے رہیں گے، ان کیلئے ایک زمین بھی ہوگی اور ایک آسمان بھی ہوگا۔ چنانچہ فرمایا:<< ’’يَوْمَ تُبَدَّلُ الْاَرْضُ غَيْرَ الْاَرْضِ وَالسَّمٰوٰتُ……الخ >> &&(سورہ ابراہیم۔ آیت ۴۸۔ پارہ۱۳۔ تفسیر برہان ،انوارالنجف)&& }} !!{{ جب ذغلب یمانی نے خدا کی رویت کے بارے میں جناب امیرالمومنین علیہ السّلام سے سوال کیا تو……؟جناب امیرالمومنین حضرت امام  علی ابن ابی طالب علیہ السّلام نے جواب میں یہ ارشادفرمایا:’’آنکھیں اسے کھلم کھلا نہیں دیکھتیں ،بلکہ دل ایمانی حقیقتوں سے اسے پہچانتے ہیں وہ ہرچیز سے قریب ہے لیکن جسمانی اتصال کے ساتھ نہیں ،وہ ہرشے سے دورہے مگراس سے الگ نہیں وہ غوروفکر کیے بغیر کلام کرنے والا اور بغیر آمادگی کے قصد و ارادہ کرنے والا، اور  بغیر اعضاء کی مدد کے بنانے والاہے، وہ لطیف ہے لیکن پوشیدگی کے ساتھ اسے متصف نہیں کیا جا سکتا ، وہ بزرگ وبرترہے مگرتند خوئی اور بدخلقی کی صفت اس میں  نہیں،وہ دیکھنے والا ہے مگرحواس سے اسے موصوف نہیں کیا جا سکتا وہ رحم کرنے والاہے مگراس صفت کونرم دلی سے تعبیر نہیں  کیا جا سکتا ،چہرے اس کی عظمت کے سامنے ذلیل اور دل اس کے خوف سے لرزاں وہراساں ہیں ۔&&(نہج البلاغۃ خطبہ۱۷۷)&& }} فلاسفہ نےلکھا کہ خدا کی ذات اسم ہے اور باقی تمام موجودات حرف سے مشابہ ہیں ۔ مثلاً جب ہم کہتے ہیں  کہ کعبہ کی طرف رخ کرو۔ اس جملے میں ’’کی ‘‘کا لفظ اکیلا کوئی معنی نہیں رکھتا جب تک کہ اس کو’’کعبہ‘‘ کے ساتھ نہ لکھاجائے۔ بالکل اسی طرح انسان اکیلا کوئی معنی یا وجود نہیں رکھتا جب تک کہ اس کو خداسے تعلق حاصل نہ ہو۔ اسی طرح تمام موجودات عالم کا کوئی وجود یا حقیت نہیں ہے جب تک کہ اس کا تعلق خداسے نہ ہو۔[[ دوست نزدیک ترازمن بہ من است۔ویں عجب ترکہ من ازوے دُورم۔چکنم باکہ تواں گفت کہ دوست۔درکنار من ومن مہجورم۔]] یعنی : میرا دوست توخود مجھ سے بھی زیادہ میرے قریب ہے لیکن زیادہ عجیب بات یہ ہے کہ میں  پھربھی اس سے دور ہوں ۔ میں  کیا کروں کہ دوست تومیرے پہلو میں ہے مگرمیں پھر بھی اس سے دوری کی تکلیف سہ رہا ہوں ۔&&(تفسیر نمونہ)&& وہ توکھٹ ہی کے پٹ میں نہاں ہے میاں ۔ مگر اندھوں کوآتا نظرہی نہیں ۔{{ ایک دفعہ امام ابوحنیفہ علیہ السّلام ،حضرت امام جعفرصادق علیہ السّلام کی خدمت میں  ملاقات کیلئے تشریف لائے اور عرض کی کہ میں نے آپ علیہ السّلام کے فرزند امام موسیٰ کاظم علیہ السّلام کواس عالم میں دیکھا کہ وہ نمازپڑھ رہے تھے اور  لوگ ان کےسامنے سے گزر رہے ہیں اور انھوں نے ان کومنع بھی نہیں کیا حالانکہ یہ درست نہیں ہے۔ا مام جعفرصادق علیہ السّلام نے حکم دیا کہ میرے فرزند امام موسیٰ کاظم علیہ السّلام کوبلائواور امام ابوحنیفہ سے فرمایا کہ آپ خود ہی ان سے یہ سوال دریافت فرمالیں  ۔ چنانچہ انھوں نے امام علیہ السّلام سے سوال کیا:امام موسیٰ کاظم علیہ السّلام نے فرمایا:’’ میں جس ذات کی نماز پڑھ رہا تھا وہ ان لوگوں کی نسبت مجھ سے کہیں  زیادہ قریب تھا۔ جیسا کہ خدوند عالم نے خود ارشاد فرمایا ہےکہ: ’’ ہم انسان کی شہ رگ گردن سے بھی زیادہ قریب ہیں ‘‘ ۔ &&(قٓ آیت ۱۶)&& یہ جواب سن کر امام علیہ السّلام نے اپنے فرزند علیہ السّلام کواپنی گود میں لے لیا اور فرمایا کہ : میرے ماں باپ تم پر فدا ہوں یقیناً تم کوخدا نے اپنے اسرار عطا فرمائے ہیں ۔&& (نورالثقلین جلد۵،ص۱۰۸)&& }}
  50,17,آیت نمبر۱۷:کراماً کاتبین کا ذکر:دائیں بائیں بیٹھنے والوں سے مراد وہ فرشتے ہیں جوہمارے تمام اعمال کولکھتے چلے جاتے ہیں ۔ &&(تفسیر تبیان)&& ہروقت دوفرشتوں کا ہمارے تمام اعمال کولکھتے رہنا ہمارے اندر یہ احساس پیدا کرتا ہے کہ ہم اپنے تمام اعمال کے خود ذمہ دار ہیں ۔&&( تفسیر ماجدی)&& {{ تفسیر برہان میں حضرت نبی کریم صلی اللہ علیہ و آلہ وسلم سے مروی ہے کہ انسان جب نیکی کا ارادہ کرتا ہے تووہ عمل نہ کرے تواس کے لئے ایک نیکی لکھدی جاتی ہے اور اگر وہ عمل کرلے تودس نیکیاں اس کے نامہ عمل میں درج کردی جاتی ہیں ۔ لیکن جب برائی کا ارادہ کرے تواگر عمل نہ کرے توکچھ بھی نہیں لکھا جاتا ہے، اور  اگر برائی کر گزرے توسات گھنٹے مہلت دی جاتی ہے۔ کیونکہ دائیں جانب (نیکی لکھنے) والا فرشتہ ،بائیں جانب والے فرشتے سے کہتا ہے کہ جلدی نہ کر، شاید یہ کوئی ایسی نیکی کرلے جس سے اس کا وہ گناہ مٹ جائے۔ جیسا کہ خود خداوند عالم ارشاد فرماتا ہے:<< ’’اِنَّ الْحَسَنٰتِ يُذْہِبْنَ السَّـيِّاٰتِ۰ۭ >> یعنی : @@ یقیناً نیکیاں برائیوں کومٹادیتی ہیں ۔@@ &&(سورہ ھودآیت۔۱۱۴۔پارہ۱۲)&& }} پس اگروہ برائی کرنے والاتوبہ کرلے توکچھ بھی نہ لکھاجائے گا ،لیکن اگرسات گھنٹے گزرجائیں اور  وہ نہ کوئی نیکی بجائے اور نہ توبہ کرے تودائیں جانب والا فرشتہ بائیں جانب والے فرشتے سے کہتا ہے کہ اب اس بدبخت انسان کاعمل لکھ لو۔&&( تفسیر مجمع البیان جلد۹ ص۱۴۴،تفسیر برہان، انوارالنجف)&& مروی ہے کہ فرشتہ صرف اس دعاء اور قرأت کونامہ اعمال میں لکھتا ہے جوسنی جاسکے اور  جوذکر پروردگارِ انسان اپنے دل ہی دل میں کرتارہتا ہے اس کوفرشتہ نہیں لکھ سکتا ،بلکہ اس کا ثواب صرف اللہ کے علم میں ہوتا ہے۔ &&(تفسیر انورالنجف)&& {{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام موسیٰ کاظم علیہ السّلام سے دریافت کیا گیا کہ ’’ انسان جب نیکی یا بدی کا ارادہ کرتا ہے توفرشتوں کوکیسے معلوم ہوجاتا ہے؟‘‘امام علیہ السّلام نے فرمایا: ’’ انسان جب نیکی کاارادہ کرتا ہے تواس کے منہ سے ایک خوشبو نکلتی ہے۔ جس سے فرشتہ سمجھ جاتا ہے کہ اب اس کا ارادہ نیک کام کرنے کاہے، لہٰذا وہ ایک نیکی لکھ لیتا ہے۔ اور جب وہ عمل کرلے تودس نیکیاں  لکھتا ہے۔ اسی طرح جب کوئی انسان برائی کا ارادہ کرے تو اس کے منہ سے ایک قسم کی بدبو نکلتی ہے جس سے فرشتہ سمجھ جاتا ہے کہ اب اس کا ارادہ برائی کرنے کا ہے پس جب وہ کرگزرتا ہے تواس کی زبان قلم اور اس کا تھوک سیاہی بن جاتی ہے اور وہ عمل درج ہوجاتاہے‘‘۔&&(تفسیر انوارالنجف)&& }} !!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمدباقرعلیہ السّلام سے مروی ہے کہ ’’حضرت آدم علیہ السّلام نے عرض کی’’موت کے وقت جب انسان اس دنیا کوچھوڑ رہا ہوتا ہے اس وقت وہ ایک نیا ادراک نئی نگاہ اور  آگہی پیدا کرلیتا ہے۔اس دنیا کی بے ثباتی کوآنکھوں سے دیکھ لیتا ہے۔ عظیم وحشت اسے گھیر لیتی ہے جو مستی کے مشابہ ہوتی ہے جبکہ وہ مست نہیں ہوتا۔ لیکن جومومنین کاملین ہوتے ہیں وہ کامل اطمینان کے عالم میں ہوتے ہیں ۔ کیونکہ وہ ذہنی طور پربھی اس کیلئے آمادہ ہوتے ہیں ۔ جس وقت جناب رسول خداصلی اللہ علیہ و آلہ وسلم کی وفات کاوقت قریب آیا، آپ صلی اللہ علیہ و آلہ وسلم اپنادست مبارک باربارپانی کے برتن میں ڈالتے تھے،اور اپنے چہرہ اقدس پر پھیرتے تھے اور ارشاد فرماتے تھے << لَآاِلٰہَ اِلَّا اللہُ اِنَّ لِلْمَوْتِ سَکَرَاتٌ >> ۔ یعنی :@@ نہیں ہے کوئی معبود سوائے اللہ کے یقیناً موت کیلئے سکرات ہے@@۔&&(تفسیر روح البیان جلد۹ ص۱۱۸)&& }} !!{{ جناب امیرالمومنین حضرت امام  علی ابن ابی طالب علیہ السّلام نے موت کا نقشہ یوں  کھینچا ہے :’’ موت کی سکرات انسان کے اندر (دنیا کی) ہرچیز کوکھو دینے کی حسرت ساتھ لاتی ہے۔انسان کے بدن کے اعضاء سست پڑجاتے ہیں، چہروں کا رنگ اڑجاتا ہے پھرموت آہستہ آہستہ اس کے جسم کے اندر داخل ہونےلگتی ہے، پھراس کی زبان کام کرنا بند کردیتی ہے جبکہ وہ اپنے گھروالوں کے درمیان ہوتا ہے آنکھوں سے سب کودیکھ رہا ہوتا ہے، اور کانوں سے سب کچھ سن رہا ہوتا ہے،اس کی عقل وہوش صحیح سالم ہوتے ہیں مگروہ بات نہیں  کرسکتا ۔ اب وہ سوچتا ہے کہ اس نےاپنی عمر کس کام میں فنا کی؟ اور اپنا زمانہ کس راستے میں  ختم کیا؟ پھراسے اپنے مال کی یاد ستاتی ہے جس کوجمع کرنے میں اس نے حلال وحرام ،مشکوک اور  مشتبہ کسی چیز کا خیال نہ کیا اور اس کوجمع رکھنے کی ذمہ داری اپنے کندھوں پرلادلی ، حالانکہ اب اس مال سے جدائی کا وقت آن پہنچا، اب اس کا مال اس کے وارثوں  کے پاس چلا جائے گا، وہ تواس سے خوب خوب فائدے اٹھائیں گے، لیکن اس کواس مال کا حساب وکتاب چکانا ہوگا۔ &&(نہج البلاغہ)&& }}!! موت کی فضیلت:{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام زین العابدین علیہ السّلام سے سوال کیا گیا کہ موت کیا ہے؟امام علیہ السّلام نے فرمایا: ’’ موت مومن کےلئے توایسی ہے جیسے کوئی میلا کچیلا ،گندگی سے بھرا ہوا لباس اپنے بدن سےاتار پھینکے ،اور اس کی جگہ بہترین لباس ،عمدہ خوشبوئوں  سے معطر لباس پہن لے، اور  تیزرفتار آرام دہ سواری پر بیٹھ کر اپنی منزل کی طرف روانہ ہوجائے۔ مگر یہی موت کافر کیلئے ایسی ہے کہ جیسے کوئی فاخرہ لباس اتارکرمیلے کچیلے سخت تکلیف دینے والا لباس پہن کروحشت ناک اور خوفناک منزل کی طرف یعنی خدا کے عذاب میں منتقل ہوجائے۔ &&(بحارالانوار جلد۶)&& }} !!{{ فرزند رسول خداصلی اللہ علیہ و آلہ وسلم حضرت امام محمد تقی علیہ السّلام سے بھی کسی نے دریافت کیا کہ موت کیا ہے؟آپ علیہ السّلام نے فرمایا:’’موت وہی نیند ہے جوہر رات تمھیں آتی ہے مگریہ کہ اس کی مدت طولانی ہے۔ انسان اس سے قیامت تک بیدار نہیں  ہوگا‘‘۔ &&(بحارالانوار جلد۶)&& }} !!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام حسین علیہ السّلام نے موت کی حقیقت کواس طرح بیان فرمایا:(روز عاشورا) ’’صبر کرو اے نیک وبزرگ لوگوں کے بیٹو! موت صرف ایک پل ہے جوتمھیں  تکلیفوں اور  تاراجیوں سے جنت کے وسیع (سرسبزوشادات) باغوں  اور  ہمیشہ ہمیشہ باقی رہنے والی نعمتوں کی طرف منتقل کردیتی ہے۔ تم میں کون ایسا ہے جوقیدخانے سے محل میں منتقل ہونا نہ چاہتا ہو؟ ہاں موت تمھارے دشمنوں  کوقیدخانے اور عذاب خداوند کی طرف منتقل کردیگی۔ میرے والد بزرگوار نے جناب رسول خداصلی اللہ علیہ و آلہ وسلم کے الفاظ نقل فرمائے ہیں کہ: ’’دنیا مومن کیلئے قیدخانہ ہے اور کافر کیلئے دنیا جنت ہے‘‘۔ موت مومن کیلئے جنت کے باغوں میں پہنچا دینے والا ایک پل ہے مگر کافروں کیلئے جہنم میں لے جانے والا پل ہے۔&&(معافی الاخبار،ص۱۸۹)&& }} !!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام موسیٰ کاظم علیہ السّلام سے موت کی حقیقت کے بارے میں سوال کیا گیا ،تو آپ علیہ السّلام نے فرمایا:’’ موت پاک کرنے کا ذریعہ ہے موت مومنین کو گناہوں  سے پاک کرتی ہے ،یہ اس دنیا کی آخر ی تکلیف ہے اور ان کے گناہوں  کا آخری کفارہ ہے۔ جبکہ موت کافرکو دنیا کی نعمتوں سے جدا کرتی ہے اور یہ آخری لذت ہے جو کافر کو پہنچتی ہے اس کے کچھ اچھے کاموں کی وجہ سے جواس نے دنیا میں کیے ہوتے ہیں ۔ یہ ان کا آخری اجر ہے۔ رہا یہ مومن شخص جوموت کی حالت میں ہے ، تمام گناہوں سے پاک ہوچکا ہے ۔اب یہ خالص ہوگیا ہے جس طرح میلا کچیلا لباس دھونے سے پاک صاف ہوجاتا ہے، اب اس نے اپنے اندر یہ صلاحیت پیدا کرلی ہے کہ وہ ہمیشہ ہمیشہ کے گھر میں ہم اہل بیت علیہ السّلام رسول صلی اللہ علیہ و آلہ وسلم کے ساتھ ساتھ رہے۔ &&(معانی الاخبارباب معنی الموت ص۲۸۹)&& }} !!{{ ایک شخص نے حضرت عمرؓ سے کہا کہ:’’میں  فتنہ کو دوست رکھتا ہوں،حق سے بیزار(دوربھاگتا) ہوں اور  ان دیکھی (چیزکی) گواہی دیتا ہوں ۔ حضرت عمرؓ نے غصے میں آکر قیدخانے میں ڈال دیا کہ یہ ایسی مہمل باتیں  کرتا ہے۔ جب حضرت امیرالمومنین علیہ السّلام نے یہ واقعہ سنا توفرمایا کہ اے عمر! وہ سچ کہتا ہے اس کوقید کرنا ظلم ہے کیوںکہ’’ وہ اپنے مال واولاد کودوست رکھتا ہے جسے قرآن نے فتنہ کہا ہے۔ &&(سورہ تغابن آیت ۱۵، پار ہ۲۸)&& وہ موت سے بیزار (دوربھاگتا) ہے جسے قرآن نے حق کہا ہے۔&& (سورہ قٓ ۔۱۹)&& وہ خدا کی یکتائی کی گواہی دیتا ہے جس کواس نے کبھی نہیں  دیکھا۔ یہ سن کر حضرت عمرؓ بولےـ:<< لَولَا عَلی لَھَلَکَ عُمْر۔ >> && (تفسیر روح البیان جلد۹)&& }}
  50,19,آیت نمبر۱۹:<< سکرات >> (موت کی بیہوشی):<< سکرات>> ،<< سکرۃ >> کی جمع ہے۔ یہ اس حالت کوکہتے ہیں کہ جب کوئی شخص شدید حادثے کی وجہ سے اتنا بے چین ہوجائے کہ بظاہر مست دکھائی دینے لگے جبکہ وہ مست نہیں ہوتا۔&&( مفردات القرآن امام راغب)&& موت کی یہ حالت مومن کیلئے نعمتوں والی زندگی کی طرف منتقل ہونے کی حالت ہے۔ !!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ :’’ جب روح بدن سے الگ ہوتی ہے توانسان اسلئے تکلیف محسوس کرتا ہے کہ بدن کی نشوونما روح ہی سے ہوتی ہے۔ &&(بحارالانوار جلد۶)&& }} جس طرح فاسد خراب دانت نکالا جاتا ہے تواول اول تکلیف ضرور ہوتی ہے مگر بعد میں  بڑی راحت ملتی ہے۔ اسی طرح موت کے وقت جدائی کا لمحہ دردناک ہوتا ہے۔ قرآن وحد یث میں  آیا ہے کہ ’’انسان پر تین وقت سخت ہوتے ہیں : (۱) جس وقت وہ پیدا ہوتا ہے۔(۲)جس دن وہ مرتا ہے۔(۳) جس دن وہ میدان حشر میں وارد ہوگا۔&&(الحدیث)&& یہ بات یقینی ہے کہ جو لوگ دنیا سے بہت زیادہ محبت وتعلق رکھتے ہیں ان کیلئے موت کا وقت بہت سخت ہوتا ہے۔ اسی طرح کافروں اور سخت گناہگاروں کیلئے بھی سخت ہوتاہے۔&&( تفسیر نمونہ)&&
  50,22,آیت نمبر۲۲:مرنے سے پہلے جوباتیں پردہ غیب میں تھیں تویہ کا فر دنیا میں ان کا منکر تھا۔اب آخرت کے دوسرے مرحلے کواپنی آنکھوں سے دیکھ رہا ہے اب یہ کافرسب کچھ مان رہا ہے ۔ لیکن اب ماننے کا اسے کوئی فائدہ نہ ہوگا، کیونکہ وہ غیب پر ایمان نہ ہوگا، عقل وفکر کے ذریعہ ماننا نہ ہوگا۔ اس لئے وہ ماننا معتبر نہ ہوگا۔&&(تفسیر تبیان، فصل الخطاب)&&
  50,24,آیت نمبر۲۴:رسول خدا صلی اللہ علیہ و آلہ وسلم اور  علی مرتضیٰ علیہ السّلام جہنم میں ڈالیں گے:{{ فرزندر سول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام زین العابدین علیہ السّلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’ اے علی علیہ السّلام! جب اللہ تعالیٰ قیامت کے دن تمام آدمیوں کو ایک بلندی پر جمع کرے گا تومیں اور  تم عرش کے بائیں طرف ہوں گے۔ پھراللہ مجھ سے اور تم سے فرمائے گا کہ تم دونوں اُٹھو اور  جس جس نے تم دونوں سے دشمنی کی اور تمھیں جھٹلایا ہے ان کوجہنم میں  پھینک دو‘‘۔&& (تفسیر علی ابراہیم)&& کفار سے مراد جس نے میری نبوت کا انکار کیا ۔ اور ’’عنید‘‘ سے مراد ہر وہ شخس جس نے علی علیہ السّلام اور  اہل بیت علیہ السّلام کا انکار کیا۔&& (تفسیر برہان ، مناقب فاخرہ)&& }} جنت اور جہنم کے تقسیم کرنے والے علی علیہ السّلام ہیں :{{ تفسیر برہان میں سید رضی کی کتاب ’’مناقب فاخرہ‘‘ سے منقول ہے کہ ابن مسعود کہتے ہیں کہ میں  ایک دن جناب رسالت مآب صلی اللہ علیہ و آلہ وسلم کی خدمت میں حاضر ہوا اور  عرض کی یارسول اللہ صلی اللہ علیہ و آلہ وسلم ! مجھے حق دکھائیے تاکہ میں اس کی پیروی کروں ۔آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا:اے ابن مسعود! اس کمرے میں داخل ہوجائو۔ حق نظرآجائے گا۔ میں  کمرے میں داخل ہوا توجناب امیرالمومنین علیہ السّلام حالت نماز میں  تھے اور دعاء مانگ رہے تھے کہ یااللہ ! اپنے عبد و رسول محمد مصطفیٰ صلی اللہ علیہ و آلہ وسلم کے صدقے میں تیرے شیعوں کے گناہ بخش دے میں وہاں سے آنحضرت صلی اللہ علیہ و آلہ وسلم کی خدمت میں واپس آیا تودیکھا کہ آپ صلی اللہ علیہ و آلہ وسلم بھی نماز و دعا میں مشغول تھے اور دعا میں عرض کررہے ہیں یااللہ !اپنے عبد علی علیہ السّلام کے صدقے میں میری امت کے گنہگاروں کوبخش دے۔ مجھے یہ دیکھ کربڑی حیرت ہوئی اور  مدہوش سا ہوگیا۔ اتنے میں حضورصلی اللہ علیہ و آلہ وسلم نے سجدے سے سراٹھایا تومجھے دیکھ کر فرمایا: اے ابن مسعود! اب ایمان کے بعد کفر نہ کرنا۔ میں نے عرض کی حضور صلی اللہ علیہ و آلہ وسلم ! میں نے دیکھا کہ علی علیہ السّلام آپ صلی اللہ علیہ و آلہ وسلم کا واسطہ دے کردعاء مانگ رہے تھے اور آپ علی علیہ السّلام کاواسطہ دے کردعاء مانگ رہے تھے؟ آنحضرت صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: اے ابن مسعود !خداوند قدیر وعظیم نے مجھے علی علیہ السّلام اور حسن علیہ السّلام و حسین علیہ السّلام کوتمام مخلوق سے دوہزارسال قبل اپنے نور عظمت سے پیدا فرمایا جبکہ نہ تسبیح تھی نہ تقدیس ۔ پھر میرے نور سے آسمانوں اور  زمین کوپیدا فرمایا اور  میں آسمانوں  اور زمین سے افضل ہوں ۔ علی علیہ السّلام کے نورسے عرش وکرسی کوپیدا فرمایا ۔علی علیہ السّلام عرش وکرسی سے افضل ہیں ،حسن علیہ السّلام کے نورسے لوح وقلم کوپیدا فرمایا ۔حسن علیہ السّلام لوح وقلم سے افضل ہیں ۔ پھر حسین علیہ السّلام کے نورسے جنت اور  حورعین کوخلق فرمایا، حسین علیہ السّلام جنت و حورعین سے افضل ہیں ۔ پھرفرشتوں نے دعاء مانگی کہ ان انوارسے مشرق ومغرب کوروش فرما دیجئے تو اللہ نے ایک روح اور نور کو خلق فرمایا ان کوملا کرفاطمہ زہریٰ علیہا السّلام کوخلق فرمایا ان کے نورسے مشرق ومغرب کوروشن فرمایا ۔اے ابن مسعود! قیامت کے دن خدا مجھ کواور علی علیہ السّلام کوخطاب فرمائے گا کہ جسے چاہو جہنم میں داخل کروپس القیام فی جہنم کل کفار عنید کا مطلب یہ ہےکہ :کفار میری نبوت کا منکر ۔اور  <<عنید>> وہ ہے جوعلی علیہ السّلام اور  اہل بیت کا منکر ہے۔ &&(تفسیر برہان ،مناقب فاخرہ)&& }}
  50,26,آیت نمبر۲۶۔۲۷:ان آیتوں میں خداوند عالم نے وہ صفات گنا کر سنا دیں جو انسان کو جہنم کا مستحق بناتی ہیں ۔ وہ یہ ہیں ۔ (۱)خیر سے روکنے والا << مَنَّاعٍ لِّلْخَیْرِ>>۔(۲) انکارحق۔(۳) خداکی ناشکری (۴) حق اور اہل حق سے دشمنی۔ (۵)اپنے مال سے خدا اور  خدا کے بندوں کے حقوق نہ ادا کرنا (۶) معاملات میں حدوں سے تجاوز کرنا۔ (۷) لوگوں پر ظلم اور  زیادتیاں کرنا۔(۸) دین کی صداقتوں پرشک کرنا۔(۹) دوسروں کو دین کے معاملات میں شک میں ڈالنا۔ (۱۰)اللہ کے ساتھ کسی دوسرے کوخدا سمجھ کر شریک کرنا۔&& (تفسیر کبیر، مجمع البیان، تفہیم)&& یہ تمام صفتیں ایک دوسرے کے ساتھ نہ ٹوٹنے والارشتہ رکھتی ہیں ۔ اور  اللہ کے ساتھ دوسروں کو شریک کرنا، یہ تمام برائیوں کی جڑ ہے۔ &&(تفسیر المیزان)&& {{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقرعلیہ السّلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نےارشافرمایا: ’’ جب انسان پیدا ہوتا ہے تواس کے ساتھ ایک فرشتہ اور  ایک شیطان پیدا ہوتے ہیں۔ فرشتہ اس کوزندگی بھر نیکیوں کی راہ دکھاتا رہتاہے، اور  شیطان برائیوں کی۔ &&(الکافی)&& }} ہرانسان کے ساتھ ایک ہمزاد شیطان ہوتا ہے جب کافر اور  گنہگار انسان کا شیطان دیکھے گا کہ اس پرگناہوں کا الزام عائد کیا جارہا ہے تووہ اس الزام کواسی انسان پر الٹ دے گا اور  یہی بات کہے گا۔&&(تفسیر ماجدی)&& یہ آیت ان لوگوں کا منہ توڑ جواب ہے کہ جو اپنا الزام شیطان پر رکھتے ہیں کہ ہم اپنے گناہوں  کے ذمے دارنہیں ہیں بلکہ ہمیں بہکانے والاشیطان ذمے دارہے اس لئے وہ قیامت کے دن بھی خدا کے سامنے اپنے گناہوں کی تمام ذمے داری شطان پر ڈالنے کی اتنی زیادہ کوششیں کریں گے کہ خدا کے سامنے شیطان سے جھگڑنے لگیں  گے دونوں میں بحث مباحثہ شروع ہوجائے گا یہاں تک کہ خداوند عالم دونوں کوڈانٹ کر چپ کردیں  گے ۔کیونکہ خداوند عالم نے پہلے ہی دن جب ابلیس نے یہ کہا تھا کہ میں آدم علیہ السّلام کی اولاد کوبہکائوں  گا، فرما دیا تھا کہ ’’جا! ان میں  سے جوکوئی بھی تیری پیروی کرے گا توتم سب کی پوری پوری سزا جہنم ہے‘‘ ۔ &&(سورۃ اسراء( بنی اسرائیل آیت ۶۳۔ پارہ ۱۵)&& گویا خداوند عالم نے پہلے ہی دن اتمام حجت فرما دیا تھا انسانوں پر بھی اور  شیطانوں پر بھی۔(تفسیر آیت کے الفاظ بتا رہے ہیں کہ یہاں  ’’ساتھی‘‘ سے مراد شیطان ہے جودنیا میں اس آدمی کے ساتھ ساتھ رہتا تھا۔ اب وہ شخص اور  اس کا شیطان خدا کے سامنے جھگڑرہے ہیں ۔ آدمی کہہ رہاہے کہ حضور! یہ کمبخت دنیا میں میرے پیچھے پڑا رہتا تھا اور آخرکاراس نے مجھے گمراہ کرکے چھوڑا،اس لئے میرے گناہوں کا یہ ذمے دار ہے ،اس کوجہنم رسید کیا جائے۔ جواب میں  شیطان کہہ رہا ہے کہ سرکار!میرا اس پر کوئی زورتونہ تھا۔ میں  نے اس سے کو ئی زبردستی گناہ تھوڑی کرائے تھے۔ یہ کمبخت خود ہی میرے کاموں کاعاشق تھا اس لئے انبیاء کرام علیہم السّلام کی کوئی بات نہ سنتا تھا۔ اس لئے یہ اپنے کیے کا خو د ذمے دارہے۔&& (تفسیر کبیر، مجمع البیان، تفہیم ،تفسیر نمونہ)&&
  50,29,آیت نمبر۲۹:خدا کے عادل ہونے کا ثبوت:یہ آیت خداوند عالم کے عدل مطلق کوثابت کرتی ہے۔ مطلب یہ ہے کہ اگرپہلے سے بتائے سمجھائے بغیر ہم تم پر عذاب نازل کردیتے توہم ظالم قرار پاتے ۔ لیکن ہم توپہلے ہی حجت تمام کرچکے ہیں اس لئے ہم نے تم پرکوئی ظلم نہیں کیا۔&&( تفسیر ماجدی)&& <<’’ظَلَّامٍ‘‘ >> صیغہ مبالغہ ہے۔ یعنی بہت ظلم کرنے والا۔ جبکہ خدا تھوڑا سابھی ظلم نہیں کرتا۔ اس کا مطلب یہ ہے کہ ہوسکتا ہے کہ خدا کا مرتبہ ومعیار اس قدربلند ہے کہ چھوٹا سا ظلم اگر وہ کرے تووہ بہت بڑا ظلم کہلائے ۔ آخری مطلب یہ نکلا کہ خدا ہر قسم کے ظلم سے دور ہے ۔اس لئے بھی کہ وہ ہرعیب سے پاک ہے اور  اس لئے بھی کہ وہ سب سے زیادہ رحم کرنے والاہے۔ سوال: یہ ہے کہ خدا کا یہ فرمانا کہ :میری باتیں بدلا نہیں کرتیں ‘‘ ۔ پھربھی وہ ہمارے بہت سے گناہ معاف بھی کردیتا ہے؟ جواب: یہ ہے کہ خدا نے خود معاف کرنے کا وعدہ بھی فرمایا ہے اس لئے اس کا معاف کرنا اس کے وعدوں یا باتوں کی خلاف ورزی نہیں ہے۔ خداوند نے خود فرما دیا۔<< ’’اِنَّ الْحَسَنٰتِ يُذْہِبْنَ السَّـيِّاٰتِ۰ۭ ‘‘ >> @@یقیناً نیکیاں خود برائیوں کو دورکردیتی ہیں‘‘۔ &&( القرآن)&& ۔&&(مؤلف)&&
  50,30,آیت نمبر۳۰:جہنم کا یہ کہنا کہ << ہَلْ مِنْ مَّزِيْدٍ >>:اس کے دومطلب ہوسکتے ہیں : (۱) جہنم کہہ رہی ہے کہ مالک! ’’میرے اندر اب مزید جہنمیوں کو لینے کی گنجائش نہیں ہے‘‘۔ (۲)جہنم کہہ رہی ہے کہ مالک! جتنے مجرم بھی ہیں انھیں لے آئیے ‘‘۔ میں سب کو سمیٹ لوں گی۔ اگر پہلا مطلب لیا جائے تو اس سے یہ تصور سامنے آتا ہے کہ جہنم میں اس قدر ٹھونس ٹھونس کر مجرموں کو بھرا گیا ہے کہ جہنم میں مزید جگہ باقی نہیں رہی ہے۔ اب جو اس کے پاس اور  جہنمی آئے تو وہ چیخ اٹھی کہ ارے کیا اب بھی اور  آدمی باقی ہیں ؟ نوٹ:یہ خو د ساختہ تفسیر ہے۔ جہنم بھی کوئی دنیاوی قید خانوں کی طرح لوگوں کی بنائی ہوئی ہے جس میں گنجائش باقی نہ رہے ۔ جہنم توخدائےعلیم و خبیر کی ایجاد کردہ ہے جس کو اچھی طرح علم ہے کہ جہنم میں کتنے مجرموں کی گنجائش رکھی جائے ، جنت میں کتنی وسعت ہونی چاہئیے ؟ کتنےآدمی و جنات جہنم میں دھکیلے جائیں گے اور  کتنے جنت میں داخل کیے جائیں گے۔ اگرجہنم میں گنجائش نہ رہی تو باقی جہنمی کیا ان مفسرین کے گھرمیں جائیں گے، جنھوں نے یہ قیاس آرائی فرمائی ہے۔ &&(کاتب)&&(۲)دوسرا مطلب اگر لیا جائے کہ جہنم کہہ رہی ہے کہ:’’ کیا کچھ اور  بھی ہے؟‘‘ تو یہ بات سمجھ میں آتی ہے کہ جہنم اس قدرسخت غصے میں ہے کہ وہ چاہتی ہے کہ آج کوئی مجرم چھوٹنے نہ پائے۔ محققین نے جہنم کے بولنے سے نتیجہ نکالا کہ یا تو یہ مجازی کلام ہے ۔مقصد صرف صورت حال کا نقشہ کھینچنا ہے ۔جیسے کوئی اپنی موٹرسے پوچھے کہ تو چلتی کیوں نہیں ؟ اس نے جواب دیا کہ پٹرول نہیں ہے۔(۲)لیکن دوسرا مطلب یہ لکھا گیا کہ جہنم کا بولنا حقیقی بولنا ہے۔ دنیا میں جو چیزیں ہمیں جامد اور  ساکت دکھائی دیتی ہیں ضروری نہیں ہے کہ وہ خداکے سامنے بھی جامد اور  ساکت ہی ہوں ۔ خدا اپنی ہر مخلوق سے کلام کرسکتا ہے اور خدا کی ہرمخلوق خدا کے کلام کا جواب خدا کی عطا سے دے سکتی ہے۔&&( تفسیر کبیر، تفہیم ،مجمع البیان، تفسیر نمونہ)&& مگرعام طورپر << ہَلْ مِنْ مَّزِيْدٍ۳۰ >> کا مطلب یہی لیا گیا ہے کہ جہنم غصے کے عالم میں اور  آدمی مانگ رہی ہوگی۔ بخاری شریف میں ہے کہ ’’آخر کار خداوند عالم اپنی ٹانگ جہنم میں ڈال دے گا جس سے جہنم کا پیٹ بھر جائےگا۔ پھر وہ کہے گی قط قط یعنی،بس بس‘‘۔ &&(بخاری شریف)&& عامۃ المسلمین نے ا س جگہ سخت ٹھوکر کھائی ہے کہ :’’ جب خدا جہنم کوکہے گا: کیا تو بھرچکی ہے توہ مزید کی طالب ہوگی ۔ جب تمام خدا کے دشمن لقمہ جہنم ہوجائیں گے تب بھی وہ << ہَلْ مِنْ مَّزِيْدٍ۳۰ >> کی رٹ لگا رہی ہوگی۔ پھراس کے اندر پہاڑوں کو داخل کیا جائےگا۔ تب بھی اس کی ہوس پوری نہ ہوگی۔آخر کار << فَیَضَعُ الْجَبَّارُ فِیْھَا قَدَمَہٗ >> یعنی پس خدا اپنا قدم اس میں رکھے گا۔ تو وہ کہے گی۔ قط قط یعنی بس بس۔ میں بھر چکی ۔ &&(مشکوٰۃ ،بخاری وغیرہ)&& اور  آل محمدصلی اللہ علیہ و آلہ وسلم جو ابواب مدینہ علم نبویہ ہیں ان سے تفسیر قرآن حاصل نہ کرنے کے نتیجے میں اس قسم کی غلطیاں  لوگوں سے صادر ہوئیں ۔ حالانکہ خدا جسم و جسمانیت سے مبرا و منزہ ہے۔ اور  شیعہ عقیدے کے نزدیک وہ خدا خدا نہیں جو اپنے قدم کو جہنم میں ڈالنے والاہو۔ (وہ پتھر کے خدا تو ہو سکتے ہیں  جن کو خدا جہنم میں ان کے پچاریوں کے ساتھ ڈالے گا) اس جگہ << ہَلْ مِنْ مَّزِيْدٍ۳۰ >> کا استفہام انکاری ہے۔ یعنی : میں سیر ہوچکی ہوں ۔اب مزید گنجائش نہیں ۔ &&(تفسیرانوارالنجف)&& شیعہ تفسیر کے مطابق جہنم کا << ہَلْ مِنْ مَّزِيْدٍ۳۰ >> کہنا استفہام انکاری ہے۔ یعنی : جہنم یہ کہہ رہی ہوگی کہ اب مزید اضافے کی گوئی گنجائش ہی نہیں ہے۔ مطلب یہ ہے کہ ــ:’’ جب شیطان نے حضرت آدم علیہ السّلام کو سجدہ کرنے سے انکار کیا تھا توخداوند عالم نے اسی وقت ارشاد فرمایا تھا کہ : ’’ میں جہنم کوتیرے پیروکاروں سے بھر دوں گا‘‘۔ اب خداوند عالم کا وہ وعدہ پورا ہوگیا کہ خدا نے شیاطین جن وانس سے جہنم کو پوری پوری طرح بھردیا۔ &&(تفسیر تبیان، فصل الخطاب)&& شاہ ولی اللہ نے بھی ا س مطلب کی تائید فرمائی ہے۔ &&(فتح الرحمٰن)&& سوال: یہ ہے کہ خداوند عالم تو پہلے روز ہی فرما چکا تھا کہ: میں جہنم کو بھردوں گا شیطانوں اور  ان کی پیروی کرنے والوں سے۔&&(القرآن ، الاعراف ۔۱۸۔ پارہ۸)&& پھرجہنم بھری کیوں نہیں ؟ اس نے << ہَلْ مِنْ مَّزِيْدٍ۳۰ >> کا سوال کیوں کیا؟جواب: یہ ہے کہ : جہنم تو بھرگئی مگراس کا غیظ وغضب اتنا شدید ہے کہ وہ بھرجانے کے بعد بھی ظالموں،مجرموں(خدا و رسول صلی اللہ علیہ و آلہ وسلم و آل رسول علیھم السلام کے دشمنوں ) کو جلانے کا مطالبہ کر رہی ہے۔ بہرحال یہ آیت بتا رہی ہے کہ جہنمی بے حد زیادہ ہیں اور  وہ ان پرسخت غضب ناک ہے ۔ جبکہ خداوندعالم نے قرآن مجید میں ارشاد فرمایا:’’ جب وہ گنہگار مجرم خدا کے دشمن ،جہنم میں ڈالے جائیں گے تو وہ ان مجرموں کو دیکھ کر چنگھاڑنے لگے گی، گویا وہ جوش کھاتی ہوئی۔ << تَكَادُ تَمَيَّزُ مِنَ الْغَيْظِ >> یعنی:قریب ہے کہ وہ مارے غصے کے پھٹ پڑے گی۔ &&(سورہ ملک آیت ۸۔ پارہ ۲۹)&& اس حالت پر غور و فکر کرنا انسان کوخداوند عالم کےرعب وخوف سے لرزہ براندام کردیتا ہے۔ &&(تفسیر نمونہ)&&
  50,31,آیت نمبر۳۱:<< ’’اُزْلِفَتِ ‘‘ >> کے معنی ہیں کہ ان سے جنت کو قریب کردیا گیا۔&&(تفسیر صافی)&& اس کا مطلب یہ بھی ہے کہ : بہت جلدی پھرتی سے جنت کو بنا سجاد گیا ہے۔ &&(تفسیر قمی)&& مطلب یہ بھی ہے جنت کی نعمتوں کو حاصل کرنے میں کسی قسم کا کوئی وقت صرف نہ ہوگا۔ نہ کسی قسم کا کوئی انتظار کرنا ہوگا، چونکہ جنت از خود تمھارے پاس لے آئی جائے گی۔&&(تفسیر ماجدی)&& جیسے ہی کسی کے لئے جنتی ہونے کا فیصلہ خدا کی بارگاہ سے ہوگا، وہ فوراً جنت کو اپنے سامنے موجود پائے گا، پھر اسے جنت تک چلنے کی زحمت بھی گوارانہ کرنی پڑے گی،نہ کسی قسم کا کوئی انتظار کرنا پڑے گا۔ بس ادھر خدا کا فیصلہ ہوا، اُدھر جنتی جنت میں داخل ہوگیا۔ یعنی جنت میں پہنچایا نہیں گیا بلکہ جنت کو اٹھا کراس کے قدموں سے ملا دیا گیا۔اس سے معلوم ہوتا ہے کہ آخرت میں زمان و مکان کے تصورات ہماری اس دنیا کے تصورات سے کس قدرمختلف ہوں گے۔ وہاں دوری و نزدیکی کے سارے تصورات بے معنی ہو کر رہ جائیں گی۔ &&(تفسیر کبیر، مجمع البیان، تفہیم ،تفسیر نمونہ)&& جنت کومتقین کے قریب کردیا گیا۔ اس کا مطلب یہ ہے کہ آخرت میں نہیں بلکہ دنیا ہی میں جنت اور  متقین میں کوئی فاصلہ نہیں ۔اِدھر وہ دنیا سے جائیں گے۔ اُدھر جنت میں داخل ہوجائیں گے۔ &&(تفسیر نمونہ)&& مثلاً {{ حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ :’’ جوشخص ہر فرض نماز کے بعد آیۃ الکرسی پڑھتا رہے اس کے جنت میں داخل ہونے میں صرف اور صرف موت حائل ہوتی ہے۔&& (مفاتیح الجنان ۔شیخ عباس قمیؒ)&& }}
  50,32,آیت نمبر۳۲: <<اَوَّابٍ>>:جنتیوں کی پہلی صفت اواب بتلائی گئی ہے۔ <<’’ اَوَّابٍ‘‘ >> کا لفظ اَوْب کے مادے سے ہے جس کے معنی ’’پلٹنا‘‘ ہے۔ جب اس پرتشدید آگئی تومعنی ہوگئے ’’بار بار پلٹنا‘‘ ۔ یعنی چھوٹا سا گناہ بھی ہوگیا تو فوراً خدا کی طرف پلٹ کرمعافی مانگی ،اور پھر گناہ کی طرف نہ پلٹنا۔ مطلب یہ ہے کہ جنتی ایسے گناہوں سے بچنے والے لوگ ہوتے ہیں کہ اگر اتفاقاً کوئی عمل ایسا سرزد ہو جاتا ہے جو ان کو خدا سے دور کردیتا ہے ،تو وہ فوراً خدا اور اس کی اطاعت کی طرف پلٹ پلٹ کرآتے ہیں ،اپنی کوتاہیوں اور  گناہوں ،غفلتوں اور  سُستیوں پر باربار توبہ کرتے ہیں  اور خدا کی طرف باربار لوٹ لوٹ آتے ہیں ۔ &&(تفسیر نمونہ)&& ]]باز آ باز آ ہرچہ ہستی باز آ۔ایں درگہ من درگہ نومیدی نیست۔صدبار اگر توبہ شکستی باز آ{{، یعنی : لوٹ آ، لوٹ آ ،توکچھ بھی ہے لوٹ آ۔ اگرسو بار بھی تونے توبہ توڑی ہے پھر بھی لوٹ آ کیوں کہ میری بارگاہ ،نا امید ہونے کی جگہ نہیں ،لوٹ آ۔ میرے پاس لوٹ آ۔ &&(بابا طاہر عریاں)&& << حَفِيْظٍ >>: یعنی حفاظت کرنے والا۔ ایسا آدمی جو اللہ کے حدود کی حفاظت کرے، خدا کے عائد کیے ہوئے فرائض کو پوری پوری طرح ادا کرے ،اور اپنے آپ کو ہر قسم کے گناہ سے بچائے رکھے۔ گویا ہرمعاملہ میں خدا کے قانون پر عمل کرے،، خدا کی نافرمانی نہ کرے، گناہ پر باربار شرمند ہ ہوکر معافی مانگے۔
  50,33,آیت نمبر۳۳:<< بِقَلْبٍ مُّنِيْبِۨ >>: یعنی :ہر وقت اللہ کی طرف پلٹنے والا دل لے کر اللہ سے ملنا۔ ’’منیب‘‘ کا لفظ ’’انابت‘‘ سے ہے۔ انابت کے معنی ایک طرف رخ کیے رہنے کے ہوتے ہیں ۔ اور  بار بار ایک ہی طرف پلٹنے کے ہوتے ہیں جیسے قطب نما کی سوئی ہوتی ہے کہ اسے کتنا بھی ہلایا ،گھمایا جائے مگر وہ سوئی ہر پھر کر قطب ہی کی طرف آجاتی ہے۔ اس سے معلوم ہوا کہ خدا کے ہاں  اس آدمی کی قدرہوتی ہے جوصرف زبان سے نہیں بلکہ دل وجان اور  پورے خلوص کے ساتھ سچے دل سے صرف اور  صرف اللہ کا ہوکر رہ جائے۔ &&(مجمع البیان ،تفہیم)&& خوف اور خشیت کا فرق:خوف کا لفظ اس وقت بولاجاتا ہے کہ جب کسی کی طاقت کے سامنے اپنی کمزوری کے احساس سے انسان کے دل میں ڈر کی شکل پیدا ہوجاتی ہے۔ جبکہ’’خشیت‘‘ اس ہیئت کوکہتے ہیں  جو کسی کی عظمت یا بڑائی کوسمجھنے کے بعد آدمی کے دل پر طور ہوتی ہے ۔ خداوند عالم نے یہاں خوف کے بجائے خشیت استعمال فرمایا ہے۔ اس سے معلوم ہوا کہ مومن کے دل میں اللہ کاخوف صرف اللہ کی سزا کے خوف سے پیدا نہیں ہوتا بلکہ اللہ کی عظمت ،بزرگی و بڑائی اور  اس کا جمال و کمال دیکھ کراس سے مرعوب اور  ہیبت زدہ ہوجاتا ہے۔ &&(تفسیر کبیرامام رازی)&& قلب سے مراد:عقل و ادراک وشعور ہے &&( مفردات امام راغب ،لساب العرب اصول کافی بقول امام جعفرصادق علیہ السّلام)&&
  50,37,آیت نمبر۳۷:<< اَلْقَى السَّمْعَ >>: یعنی کان کو ڈالے رہے۔ یعنی کان دھرے انتہائی انہماک اور پوری پوری توجہ کے ساتھ بات سنے۔ فارسی میں کہتے ہیں: ’’گوش مانز دتواست‘‘ یعنی ہمارے کان تمھارے پاس ہیں۔ یعنی : ہم تمھاری باتوں کوخوب اچھی طرح سن سمجھ رہے ہیں ۔ &&(لغات القرآن نعمانی)&& <<شَہِيْدٌ >>: یعنی وہ آدمی جو دل لگا کر، حضور قلب کے ساتھ مطالب کو سنے سمجھے۔&&( مفردات القرآن امام راغب)&& << قَلْبٍ >>:کے معنی عقل کے ہوتے ہیں۔ &&(مجمع البیان بقول ابن عباس، الکافی بقول امام جعفرصادق علیہ السّلام، مفردات راغب)&&!! نتائج و تعلیمات:آیت سے معلوم ہوا کہ دو قسم کے آدمی نصیحت حاصل کرسکتے ہیں :(۱)پہلا گروہ وہ جوعقل و ہوش رکھتا ہو، خود مسائل کو سمجھ سکے،ان کا تجزیہ کرسکے۔ یہ علماءاور  دانشمندوں کا گروہ و مقام ہے۔(۲) دوسرا گروہ وہ ہے جوعلماء اور  دانشمند تو نہیں بن سکتا مگر پوری توجہ حضور قلب سے علماء اور  دانشمندوں کی باتیں سنتے ہیں اور  حقیقتوں کوسمجھ لیتے ہیں ۔ سورہ ملک میں ان دو گروہوں  کی طرف اشارہ اس طرح فرمایا ہے کہ:ِِ<< وَقَالُوْا لَوْ كُنَّا نَسْمَعُ اَوْ نَعْقِلُ مَا كُنَّا فِيْٓ اَصْحٰبِ السَّعِيْرِ۱۰ >> یعنی : @@اور  وہ کہیں گے کہ اے کاش! ہم سنتے اور عقل سے کام لیتے (عالم فاضل ہوتے) تو ہم دوزخی نہ ہوتے۔@@ &&(سورہ ملک آیت ۱۰)&& دوسرا گروہ یہ ہے:<<’’اِنَّ الَّذِيْنَ يَخْشَوْنَ رَبَّہُمْ بِالْغَيْبِ لَہُمْ مَّغْفِرَۃٌ وَّاَجْرٌ كَبِيْرٌ۱۲ >> &&( سورہ ملک آیت۔۱۲، پارہ ۲۹)&&
  50,38,آیت نمبر ۳۸:شان نزول :یھودی کہتے تھے کہ خداوند عالم نے آسمانوں اور  زمین کچھ دنوں میں پیدا کیا، پھر ہفتہ کے دن اس نے آرام کیا، اس طرح اپنا ایک پاوں دوسرے پائوں پر رکھا۔ اسی لئے وہ اس طرح بیٹھنے کو بے ادبی یا اللہ میاں کی نقل قرار دیتے ہیں ۔اس پر یہ آیت نازل ہوئی۔ &&(تفسیر درمنثور جلد۶، کتاب پیدائش ۲:۲)&& اور  کنگ جیمز کی مستند انگریزی بائیبل میں لکھا ہے۔And He (god) rested on the seventh dayبائیبل کے عربی ترجمے میں لکھا ہے << فاستراح فی الیوم السابع >> یعنی : پس ساتویں دن اللہ نے آرام کیا۔ &&(بائیبل مطبوعہ فلیڈیلفیا، امریکہ ۱۹۵۴ء)&& جہاں اللہ میاں کی قدرت کاملہ کا تصور اس قدر کمزور ہو ،وہاں انبیاء کرام علیہم السّلام کی جو بھی گت بنائی جائے وہ کم ہی ہوگی۔&&(مؤلف)&& خداوند عالم نے آسمانوں اور  زمین کو چھ دن میں خلق فرمایا : یعنی اس کی مصلحت کا تقاضا یہی تھا کہ چیزوں کی پیدائش اسباب و ذرائع سے (تدریجاً) ہوتا کہ لوگ اس کو امر اتفاقی نہ قراردیں ،ورنہ وہ چشم زدن میں بھی پیدا کرنے پر مکمل قادر ہے۔ {{ بروایت عکرمہ حضرت رسالت مآبصلی اللہ علیہ و آلہ وسلم سے مروی ہے کہ خداوند عالم نے زمین کو اتوار اور  سوموار کے دنوں میں خلق فرمایا پہاڑوں کومنگل کے دن ،درختوں ،پانی اور  آبادیاں ،ویرانے بدھ کے روز ۔ اور  یہ کل چار دن ہیں یعنی زمین اور  زمین کی اقوات و خوراک کی تکمیل چار دنوں میں ہوئی۔ یعنی صرف زمین کی پیدائش دو دنوں میں اور  باقی چیزوں کی پیدائش چار دنوں میں ہوئی۔&&(تفسیر انوارالنجف جلد۱۲ص۱۷۲)&& }}
  50,39,آیت نمبر۳۹: تین اوقات میں پانچ نمازوں مع نوافل شب کا ذکر:(۱) اللہ کی تسبیح حمد کے ساتھ پڑھنا ، یعنی نماز پڑھنا، (تین اوقات میں)(۱)طلوع آفتاب سے پہلے، فجر کی نماز۔(۲)غروب آفتاب سے پہلےدو نمازیں،ظہر و عصر۔(۳) رات کے وقت مراد مغرب وعشاء کی نمازیں ہیں &&(عشایین ۔(جلالین)&& نماز تہجد بھی رات ہی کی تسبیح میں شامل ہے۔&&(فصل الخطاب، تفسیر کبیرامام رازی، تفہیم مودودی)&& ان اذکار سے صبر حاصل ہوتا ہے!!:{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام نے اپنے دوستوں سے فرمایا:جو اس زمانے میں بڑے ہی سخت تکلیف دہ حالات سے گزر رہے تھے کہ تم پر لازم ہے کہ ہر معاملے میں صبر سے کام لو۔ کیوں کہ خداوند عالم نے جناب رسول خداصلی اللہ علیہ و آلہ وسلم کو بھی صبر سے کام لینے کا حکم دیا ہے۔ انھوں نے ہرحال میں صبر سے کام لیا۔ لوگوں  نے آنحضرت صلی اللہ علیہ و آلہ وسلم پرناروا غلط الزامات لگائے ،جب آپ صلی اللہ علیہ و آلہ وسلم کا دل تنگ ہونے لگا توخداند عالم نے فرمایا: ہم جانتے ہیں کہ ان کی باتیں تمھیں غمگین کرتی ہیں لیکن یہ لوگ تمھیں جھوٹا نہیں  قراردیتے ،بلکہ میری تکذیب کرتے ہیں ،خدا کی آیتوں کا انکار کرتے ہیں ۔ ان لوگوں نے تم سے پہلےانبیاء علیہم السّلام اور  رسولوں علیہ السّلام کی بھی تکذیب کی تھی۔ اور  ان رسولوں علیہ السّلام نے اس پر صبر کیا تھا یہاں تک کہ ہماری مدد ان تک آن پہنچی۔&&(سورۃ الانعام آیت ۳۳۔۳۴۔ پارہ۷)&& آنحضرت صلی اللہ علیہ و آلہ وسلم نے عر ض کی: اپنے مالک اپنے پالنے والے کیلئے برے الفاظ نہیں سن سکتا ۔ اس موقع پر خداوندعالم نے فرمایا: ’’ ہم نے آسمانوں اور  زمین کو اور  جوکچھ اس کے درمیان ہے چھ دنوں (چھ ادوار) میں پیدا کیا ہے۔&&(القرآن)&& یعنی ہم نے ان کے پیدا کرنے میں جلدی نہیں کی، اس لئے اے رسول صلی اللہ علیہ و آلہ وسلم ! تم بھی جلد بازی نہ کرو، ان کی باتوں پر صبر کرو۔ اس حکم کے ملنے پر آنحضرت صلی اللہ علیہ و آلہ وسلم نے ہرہر معاملے میں صبر سے کام لیا، یہاں تک کہ اپنے دشمنوں پر کامیاب ہوئے۔ &&(اصول کافی، نورالثقلین جلد۵)&& }} !!{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم سے غریب مہاجرین نے شکایت کی: یہ مالدار لوگ صدقات دیتے اور غلام آزاد کرتے ہیں اور ہماری طرح نماز ،روزے بھی ادا کرتے ہیں،لیکن ہمارے پاس مال وغیرہ نہیں،یہ لوگ ہم سے زیادہ ثواب حاصل کرتے ہیں ، آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا: میں تمھیں تسبیح بتائے دیتا ہوں تا کہ تم لوگ بھی دوسروں سے بازی لے جائو۔ اور  وہ تسبیح یہ ہے ہرنماز کے بعد۳۳،۳۳مرتبہ سبحان اللہ الحمدللہ اور  اللہ اکبر پڑھ لیا کرو۔ کچھ دنوں کےبعد لوگوں نے عرض کی: حضور اکرم صلی اللہ علیہ و آلہ وسلم مالداروں نے بھی یہی عمل شروع کردیا۔ آپ نے فرمایا:<< ذٰلک فضل اللہ یوتیہ من یشآء >> یہ تواللہ کافضل ہے وہ جسے چاہے عطا فرمائے۔ &&(بخاری ،مسلم)&& }}
  50,42,آیت نمبر۴۲:<< الصَّيْحَۃَ >> (سخت چیخ):اس آیت ۴۲ میں سخت چیخ حق کے ساتھ سے مراد وہ آواز ہے۔ جو امام مہدی علیہ السّلام کے ظہور کے وقت آسمان سے سنی جائے گی۔ &&(تفسیر قمی ص۴۷۶)&& {{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:<< ’’يَوْمُ الْخُرُوْجِ۴۲ ‘‘ >> سے مراد ’’رجعت‘‘ ہے ۔ یعنی ائمہ اہل بیت علیہ السّلام کا قبروں سے باہر نکل کر دنیا میں تشریف لانا مراد ہے۔ اور  یہ ظہور امام مہدی علیہ السّلام کے بعد ہوگا۔ &&(تفسیر صافی ص۴۷۶بحوالہ تفسیر قمی)&& }} خداوند عالم کا فرمانا: جس دن سب لوگ آوازہ حشرکوٹھیک ٹھیک (بالحق) سن رہے ہوں گے۔ یعنی حشر کے آوزر اتنی صاف اور  واضح ہوگی کہ ان کو پورا پورا یقین آجائے گا کہ یہ میدان حشر ہے اور  یہ سب میدان حشرکی آوازیں ہیں ، یہ کوئی خواب و خیال و ہم و گمان نہیں بلکہ واقعاً یہ حشرکا میدان ہے، اس میں ان کونہ کوئی شک وشبہ ہوگا، نہ وہم گمان ہوگا۔ &&(تفسیر کبیر ،مجمع البیان ،تفہیم، تفسیر نمونہ)&&
  50,44,آیت نمبر۴۴:یہ کفار کے اعتراض کا جواب ہے:یہ آیت کفارکے اس اعتراض کا جواب ہے جو آیت۲میں بیان کیا گیا تھا کہ وہ کہتے تھے۔ جب ہم مرکر خاک پتھر ہوجائیں گے پھر ہمیں کیسے زندہ کرکے اٹھایا جائیگا؟ یہ واپسی تو بعید از امکان ہے ۔ جواب میں فرمایا جا رہا ہے کہ اگلے پچھلے تمام انسانوں کو بیک وقت زندہ کرکے جمع کردینا ہمارے لئے بالکل آسان ہے کیونکہ ہم کوتمام انسانوں  کے بکھرے ہوئے تمام اجزاء کا پورا پوراعلم ہے۔ ہم ان سب کوسمیٹ کر ہر آدمی کے جسم کو دوبارہ بنا کر کھڑا کردیں گے،بس ہمارا ایک اشارہ ہوگا، ہماری قدرت کاملہ کے سامنے یہ کام ایک لمحہ کا بھی نہیں ۔البتہ تمھیں مشکل اور  نا ممکن نظرآتا ہے۔&&(تفسیر کبیر ،مجمع البیان ۔تفہیم)&& حدیث میں آیا ہے کہ :قیامت کے دن سب سے پہلے قبر سے نکل کرمیدان حشر میں وارد ہونے والے جناب رسول خدا صلی اللہ علیہ و آلہ وسلم ہوں گے اور  ان کے ساتھ ساتھ حضرت علی مرتضیٰ علیہ السّلام ہوں گے۔ &&(کتاب خصال ،تفسیر نورالثقلین)&&
  50,45,آیت نمبر۴۵:شانِ نزول:{{ ابن عباسؓ فرماتے ہیں کہ کچھ لوگ جناب رسول خداصلی اللہ علیہ و آلہ وسلم کی خدمت میں حاضر ہوئے اور  عرض کی: ہمارے اندر خوف خدا پیدا فرمایئے۔ اس پر یہ آیت اتری۔ &&(تفسیر قرطبی جلد۹)&& }} !!نتیجہ یہ نکلا:یہ آیتیں مومنین کو خدا کی ناراضگی اور  عذاب کا خوف دلانے کیلئے کافی ہیں۔ اس لئے کہ انسان اگر واقعاً قیامت کے واقعات کو یاد کرے کہ یکا یک زمینیں پھٹ جائیں  گی، مٹی میں جان پڑجائے گی، سارے مردے لباس زندگی پہن کر قبر وں سے باہر نکل آئیں گے ،سب کوخدا کی عدالت کی طرف ہانک ہانک کرلے جایا جائے گا۔ یہ تصورخوف خدا کے پیدا کرنے کیلئے کس قدر لرزا دینے والا ہے۔&&(تفسیر نمونہ)&& یاد رہے کہ قرآن کے مخاطب توسب کے سب ہیں البتہ قرآن سے نفع حاصل کرنے والے صرف وہی ہیں جن کے دل میں خدا کا خوف بھی موجود ہوگا۔ مگر ذوق جنگ رکھنے والوں نے یہاں بھی یہی لکھا کہ یہ صبرکرتے رہنے کا حکم جہاد کا حکم آنے سے پہلے کا تھا۔ &&(تفسیر تبیان بقول زجاج)&& حالانکہ اس قسم کے الفاظ قرآن مجید میں شروع سے آخرتک ملتے ہیں اس لئے اس کو وقتی پالیسی نہیں کہا جا سکتا ۔ یہ اصولی تعلیم ہے ۔جب خداخود اپنے دین کو اور  اپنی ذات تک کو منوانے میں جبر سے کام نہیں لیتا تواپنے رسول صلی اللہ علیہ و آلہ وسلم پر مجبور کرکے منوانے کا فریضہ کیسے عائد کرسکتا ہے؟&&(فصل الخطاب، مجمع البیان)&& اصل پیغام:اصل میں اس آیت میں جناب رسول خداصلی اللہ علیہ و آلہ وسلم کو تسلی دی جا رہی ہے اور  ساتھ ہی کفار کو دھمکی بھی دی جا رہی ہے۔ آنحضرت صلی اللہ علیہ و آلہ وسلم کومخاطب کرکے فرمایا جا رہا ہے کہ آپ صلی اللہ علیہ و آلہ وسلم لوگوں کے جملوں ،فقروں ، طنز و طعن کی قطعاً کوئی پرواہ نہ فرمائیں، کیونکہ ہم سب کچھ سن رہے ہیں اور  ہم ان سے اچھی طرح نمٹنا جانتے ہیں ۔ ساتھ ساتھ کفار کو یہ دھمکی دی جا رہی ہے کہ ہمارے نبی صلی اللہ علیہ و آلہ وسلم پر جوتم فقرے چست کر رہے ہو وہ تمھیں سخت مہنگے پڑیں گے، کیونکہ ہم خود ان کو اچھی طرح سن رہے ہیں ۔ ہم ایک ایک حرف کا خوب خوب بدلہ دیں گے اور  ایسی سخت سزا دیں گے کہ تمھارے ہوش ٹھکانے آجائیں گے۔ پھر حضور اکرم صلی اللہ علیہ و آلہ وسلم کو مخاطب کرکے کفار کوسنایا جارہا ہے کہ ہم نے نبی صلی اللہ علیہ و آلہ وسلم کوجبر کرنے نہیں بھیجا ہے ان کا کام زبردستی تمھیں مومن بنانا نہیں ہے بلکہ تم مانو یا نہ مانو وہ تمھیں منوا کر ہی چھوڑے۔ ہمارے رسول صلی اللہ علیہ و آلہ وسلم کی ذمہ داری صرف اور  صرف یہ ہے کہ وہ تمھیں حقیقت بتلادے۔اب جو کوئی اس کی باتیں سن کر ہوش میں آجائے اسے قرآن سنا کرحقیقتوں کوسمجھادے۔ &&(تفسیرکبیر ، مجمع البیان ،تفہیم)&& محققین نے نتیجہ نکالا:کہ جب رسول خدا صلی اللہ علیہ و آلہ وسلم کودین کے معاملے میں جبرکرنے کی اجازت نہیں دی گئی تو پھر کسی اور  کو دین کے معاملے میں جبر کرنے کا اختیارکیسے حاصل ہوسکتا ہے۔دعاء:آخر میں دعا ہے کہ خداوند کریم ہمیں ایسے لوگوں میں قراردے جوخدا کی ناراضگی اور عذاب سے ڈرتے ہوں اور  قرآن سے نصیحت حاصل کرنے والے ہوں اور  مالک!میدان محشر کی انتہائی تنہائی اور لاچاری کے عالم میں ہمیں اپنی رحمت کے دامن مغفرت میں جگہ عطا فرمانا۔ عذاب سے بچائے رکھنا بحق محمد صلی اللہ علیہ و آلہ وسلم وعلی علیہ السّلام و فاطمہ علیہ السّلام و حسن علیہ السّلام و حسین علیہ السّلام و جملہ ائمہ معصومین علیہم الصلوٰت والسلام ۔&&(تفسیر نمونہ)&&
