quran[8]{c,v,t}:
  41,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعَةࣰ﴾</span>: يابِسَةً مُسْتَكِينَةً لا نَباتَ فِيها.</p><p><span class="qpc-hafs">﴿ٱهۡتَزَّتۡ﴾</span>: تَحَرَّكَتْ وتَشَقَّقَتْ بالنَّباتِ.</p><p><span class="qpc-hafs">﴿وَرَبَتۡ﴾</span>: وانْتَفَخَتْ وعَلَتْ.</p></div>"
  41,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُلۡحِدُونَ﴾</span>: يَمِيلُونَ عَنِ الحَقِّ إنْكارًا لَهُ.</p><p><span class="qpc-hafs">﴿ٱعۡمَلُواْ مَا شِئۡتُمۡ﴾</span>: وعِيدٌ في صِيغَةِ الأمْر.</p></div>"
  41,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلذِّكۡرِ﴾</span>: بالقرآنِ.</p></div>"
  41,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَـٰطِلُ﴾</span>: الشَّيطانُ وأيُّ أمْرٍ يُبْطِلُ شَيئًا مِنهُ.</p><p><span class="qpc-hafs">﴿مِنۢ بَيۡنِ يَدَيۡهِ وَلَا مِنۡ خَلۡفِهِۦ﴾</span>: مِن أيِّ جِهَةٍ مِن جِهاتِهِ، فهو مَحْفُوظٌ بِحِفْظِ اللهِ.</p><p><span class="qpc-hafs">﴿حَكِيمٍ﴾</span>: ذِي حِكْمَةٍ.</p><p><span class="qpc-hafs">﴿حَمِيدࣲ﴾</span>: مَحْمُودٍ عَلى نِعَمِهِ عَلى الخَلْقِ وعَلى ما لَهُ مِن صِفاتِ الكَمالِ.</p></div>"
  41,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يُقَالُ لَكَ﴾</span>: لا يقُولُ لَكَ المشرِكُونَ.</p></div>"
  41,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡجَمِيࣰّا﴾</span>: عَلى غَيرِ لُغَةِ العَرَبِ.</p><p><span class="qpc-hafs">﴿لَوۡلَا﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿فُصِّلَتۡ ءَايَـٰتُهُۥٓ﴾</span>: بُيِّنتْ آياتُه فَنَفْقَهَهُ ونَعْلَمَهُ.</p><p><span class="qpc-hafs">﴿ءَا۬عۡجَمِيࣱّ وَعَرَبِيࣱّ﴾</span>: أأَعْجَمِيٌّ هَذا القُرآنُ، ولِسانُ الَّذِي أُنْزِل عَليهِ عَرَبيٌّ؟</p><p><span class="qpc-hafs">﴿هُدࣰى﴾</span>: بَيانٌ لِلْحَقِّ.</p><p><span class="qpc-hafs">﴿وَشِفَآءࣱ﴾</span>: مِنَ الجَهْلِ والأمْراضِ.</p><p><span class="qpc-hafs">﴿وَقۡرࣱ﴾</span>: ثِقَلٌ وصَمَمٌ.</p><p><span class="qpc-hafs">﴿وَهُوَ عَلَيۡهِمۡ عَمًى﴾</span>: عَمِيَتْ قُلُوبُهُم عَنِ القُرآنِ فَلا يَهْتَدُونَ بِهِ.</p><p><span class="qpc-hafs">﴿أُوْلَـٰٓئِكَ يُنَادَوۡنَ مِن مَّكَانِۭ بَعِيدࣲ﴾</span>: كَأنّ أُولئِكَ المشرِكِينَ يَسْمَعُونَ صَوْتًا مِن بَعِيدٍ، ولا يَفْهَمُونَ مَعانِيَهُ.</p></div>"
  41,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: التَّوراةَ.</p><p><span class="qpc-hafs">﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾</span>: بِتَأْجِيلِ العَذابِ عَن قَومِكَ.</p><p><span class="qpc-hafs">﴿لَقُضِيَ بَيۡنَهُمۡ﴾</span>: لَفُصِلَ بينهم بإهْلاكِ الكافِرينَ في الحالِ.</p><p><span class="qpc-hafs">﴿وَإِنَّهُمۡ لَفِي شَكࣲّ مِّنۡهُ﴾</span>: وإنّ الفريقَ المُبْطِلَ مِنهُم لَفِي شَكٍّ مما قالُوا في التَّوراةِ.</p><p><span class="qpc-hafs">﴿مُرِيبࣲ﴾</span>: مُوقِعٍ في قَلَقِ النَّفْسِ وعَدَمِ طُمَأنِينتِها؛ لأنّهُم قالُوهُ ظنًّا بِغَيرِ حُجَّةٍ.</p></div>"
  41,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَلَيۡهَا﴾</span>: فَعَلى نَفْسِهِ جَنى.</p><p><span class="qpc-hafs">﴿بِظَلَّـٰمࣲ﴾</span>: بِذِي ظُلْمٍ.</p></div>"