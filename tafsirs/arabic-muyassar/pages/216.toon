quran[9]{c,v,t}:
  10,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا هُمۡ يَحۡزَنُونَ﴾</span>: على ما فاتهم من حُظوظِ الدُّنيا.</p></div>"
  10,63,""
  10,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبُشۡرَىٰ﴾</span>: البِشارةُ بما يَسُرُّهم.</p><p><span class="qpc-hafs">﴿لَا تَبۡدِيلَ لِكَلِمَـٰتِ ٱللَّهِ﴾</span>: لا إخلافَ لوَعْدِ اللهِ.</p></div>"
  10,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعِزَّةَ لِلَّهِ جَمِيعًا﴾</span>: الغَلَبَةَ، والقوةَ والقدرةَ التامةَ له تعالى.</p></div>"
  10,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّنَّ﴾</span>: الشَّكَّ.</p><p><span class="qpc-hafs">﴿يَخۡرُصُونَ﴾</span>: يَكْذِبُون فيما يَنْسُبونَه إلى اللهِ.</p></div>"
  10,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُبۡصِرًا﴾</span>: مُضِيئًا يُبْصِرُ فيه الناسُ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: دَلالاتٍ وحججًا.</p></div>"
  10,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تَنْزِيهًا له عَمّا نَسَبُوه إليه.</p><p><span class="qpc-hafs">﴿إِنۡ عِندَكُم﴾</span>: ليس لَدَيكم.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنِۭ﴾</span>: حُجَّةٍ وبُرهانٍ.</p></div>"
  10,69,""
  10,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرۡجِعُهُمۡ﴾</span>: مَصِيرُهم.</p></div>"