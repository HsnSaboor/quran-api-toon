quran[6]{c,v,t}:
  31,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُولِجُ﴾</span>: يُدخِلُ.</p><p><span class="qpc-hafs">﴿سَخَّرَ﴾</span>: ذلَّلَ.</p><p><span class="qpc-hafs">﴿مُّسَمࣰّى﴾</span>: مَعْلُومٍ مُحدَّدٍ.</p></div>"
  31,30,"<div class=ar lang=ar></div>"
  31,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p><p><span class="qpc-hafs">﴿لِيُرِيَكُم﴾</span>: ليُظْهِرَ لَكُم.</p><p><span class="qpc-hafs">﴿مِّنۡ ءَايَـٰتِهِۦٓ﴾</span>: أي: مِن آياتِه الدّالَّةِ عَلى قُدْرَتِه.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لدَلالاتٍ.</p><p><span class="qpc-hafs">﴿صَبَّارࣲ شَكُورࣲ﴾</span>: أي: صَبّارٍ عَلى الضَّرّاءِ، وشَكُورٍ عَلى السَّرّاءِ.</p></div>"
  31,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَشِيَهُم﴾</span>: عَلاهُم وغَطّاهُم.</p><p><span class="qpc-hafs">﴿كَٱلظُّلَلِ﴾</span>: أي: كَشَيءٍ يكُونُ ظِلًّا مِثْلِ الِجبالِ والسَّحابِ.</p><p><span class="qpc-hafs">﴿مُّقۡتَصِدࣱ﴾</span>: مُتَوَسِّطٌ في عَمَلِهِ وعِبادَتِه.</p><p><span class="qpc-hafs">﴿يَجۡحَدُ﴾</span>: يُنكِرُ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بحُجَجِنا.</p><p><span class="qpc-hafs">﴿خَتَّارࣲ﴾</span>: غَدّارٍ ناقِضٍ لِلْعهَدِ.</p><p><span class="qpc-hafs">﴿كَفُورࣲ﴾</span>: جَحُودٍ للنِّعَمِ لا يَشْكُرُها.</p></div>"
  31,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱخۡشَوۡاْ يَوۡمࣰا﴾</span>: أي: خافُوه واسْتَعِدُّوا لَهُ.</p><p><span class="qpc-hafs">﴿لَّا يَجۡزِي﴾</span>: لا يُغْنِي.</p><p><span class="qpc-hafs">﴿فَلَا تَغُرَّنَّكُمُ﴾</span>: فلا تَخْدَعَنَّكُم.</p><p><span class="qpc-hafs">﴿ٱلۡغَرُورُ﴾</span>: ما يَغُرُّ ويَخْدَعُ مِن شَيطانٍ وغَيرِهِ.</p></div>"
  31,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَيۡثَ﴾</span>: المَطَرَ.</p><p><span class="qpc-hafs">﴿تَدۡرِي﴾</span>: تَعْلَمُ.</p></div>"