quran[8]{c,v,t}:
  12,104,"<div class=ar lang=ar></div>"
  12,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَأَيِّن﴾</span>: وكثيرٌ.</p><p><span class="qpc-hafs">﴿مِّنۡ ءَايَةࣲ﴾</span>: من الدلائلِ الدالَّةِ على وحْدانيةِ اللهِ وقدرتِه.</p><p><span class="qpc-hafs">﴿يَمُرُّونَ عَلَيۡهَا﴾</span>: يشاهِدُونها.</p></div>"
  12,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُم مُّشۡرِكُونَ﴾</span>: فهم يَخْلِطُون مع إيمانِهم باللهِ ربًّا الإشراكَ في ألوهيَّتِه وعبادتِه.</p></div>"
  12,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَـٰشِيَةࣱ﴾</span>: عقوبةٌ في الدنيا تَعُمُّهم.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأةً.</p></div>"
  12,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَصِيرَةٍ﴾</span>: يقينٍ وحُجَّةٍ واضحةٍ.</p></div>"
  12,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلِ ٱلۡقُرَىٰٓ﴾</span>: المدنِ والحاضرةِ.</p></div>"
  12,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَيۡـَٔسَ ٱلرُّسُلُ﴾</span>: يَئِسوا من إيمانِ قومِهم.</p><p><span class="qpc-hafs">﴿وَظَنُّوٓاْ أَنَّهُمۡ قَدۡ كُذِبُواْ﴾</span>: وظَنَّ المُرْسَلُ إليهم أن الرُّسَلَ قد كَذَبُوهم فيما أخبرُوهم عن اللهِ.</p><p><span class="qpc-hafs">﴿جَآءَهُمۡ نَصۡرُنَا﴾</span>: جاء نَصْرُنا لرُسِلِنا عند شِدَّةِ الكَرْبِ.</p><p><span class="qpc-hafs">﴿بَأۡسُنَا﴾</span>: عذابُنا.</p></div>"
  12,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِبۡرَةࣱ﴾</span>: عِظَةٌ.</p><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: أصحابِ العقولِ السليمةِ.</p><p><span class="qpc-hafs">﴿مَا كَانَ﴾</span>: أي: هذا القرآنُ.</p><p><span class="qpc-hafs">﴿يُفۡتَرَىٰ﴾</span>: يُخْتَلَقُ.</p><p><span class="qpc-hafs">﴿تَصۡدِيقَ ٱلَّذِي بَيۡنَ يَدَيۡهِ﴾</span>: أي: القرآنُ يَشْهَدُ على صِدْقِ ما تقدَّمه من الكتبِ المنزَّلةِ، وأنها من عندِ اللهِ.</p><p><span class="qpc-hafs">﴿وَتَفۡصِيلَ كُلِّ شَيۡءࣲ﴾</span>: تبيينَ ما يَحْتاجُ إليه العبادُ من أمورِ الدينِ.</p></div>"