quran[11]{c,v,t}:
  17,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَسۡتَفِزُّونَكَ﴾</span>: لَيُزعِجُونك بعَداوتهم لِيُخْرِجُوك.</p><p><span class="qpc-hafs">﴿مِنَ ٱلۡأَرۡضِ﴾</span>: من مكةَ.</p><p><span class="qpc-hafs">﴿وَإِذࣰا﴾</span>: لو أخرجُوك.</p><p><span class="qpc-hafs">﴿خِلَـٰفَكَ﴾</span>: بَعْدَك.</p></div>"
  17,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَحۡوِيلًا﴾</span>: تَبْديلًا.</p></div>"
  17,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِدُلُوكِ ٱلشَّمۡسِ﴾</span>: وقتِ ميلِها عن وسَطِ السماءِ، وهو الزَّوالُ في الظَّهيرةِ.</p><p><span class="qpc-hafs">﴿غَسَقِ ٱلَّيۡلِ﴾</span>: إقبالِ ظُلْمَتِه وسَوادِه.</p><p><span class="qpc-hafs">﴿وَقُرۡءَانَ ٱلۡفَجۡرِ﴾</span>: وأقمْ صَلاةَ الفجرِ.</p><p><span class="qpc-hafs">﴿مَشۡهُودࣰا﴾</span>: تَحْضُرُها ملائكةُ الليلِ، وملائكةُ النهارِ.</p></div>"
  17,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَهَجَّدۡ بِهِۦ﴾</span>: فاقْرأ القرآنَ في صلاةِ الليلِ.</p><p><span class="qpc-hafs">﴿نَافِلَةࣰ لَّكَ﴾</span>: زيادةً لك، وفضيلةً ورَفْعَ دَرَجاتٍ.</p><p><span class="qpc-hafs">﴿مَقَامࣰا مَّحۡمُودࣰا﴾</span>: شافِعًا للناسِ عند فَصْلِ القضاءِ بينَهم، يحْمَدُكَ فيه الأوَّلون والآخِرون.</p></div>"
  17,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُدۡخَلَ صِدۡقࣲ﴾</span>: إدخالًا مَرْضِيًّا لا أرى فيه ما أكْرَهُ.</p><p><span class="qpc-hafs">﴿مُخۡرَجَ صِدۡقࣲ﴾</span>: إخراجًا مَرْضِيًّا مما هوشَرٌّ لي.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً بيِّنةً ثابتةً، أو قوَّةً وعِزًّا.</p><p><span class="qpc-hafs">﴿نَّصِيرࣰا﴾</span>: ناصرًا ومُعِينًا على مَن خالفني.</p></div>"
  17,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: الإسلامُ.</p><p><span class="qpc-hafs">﴿وَزَهَقَ ٱلۡبَـٰطِلُ﴾</span>: ذَهَبَ وبَطَل الشِّرْكُ.</p></div>"
  17,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَسَارࣰا﴾</span>: ضَلالًا وهَلاكًا؛ بسبب كُفْرِهم.</p></div>"
  17,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَـَٔا بِجَانِبِهِۦ﴾</span>: تباعَدَ عن شُكْرِ اللهِ وطاعَتِه؛ تَكَبُّرًا.</p><p><span class="qpc-hafs">﴿ٱلشَّرُّ﴾</span>: الشِّدَّةُ والضَّرَرُ.</p><p><span class="qpc-hafs">﴿يَـُٔوسࣰا﴾</span>: شديدَ اليأسِ من رحمةِ الله.</p></div>"
  17,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَاكِلَتِهِۦ﴾</span>: ما يُجانِسُ أخلاقَه التي اعتادَ عليها.</p></div>"
  17,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۡ أَمۡرِ رَبِّي﴾</span>: مما استأثرَ اللهُ تعالى بعِلْمِها.</p></div>"
  17,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَذۡهَبَنَّ بِٱلَّذِيٓ أَوۡحَيۡنَآ إِلَيۡكَ﴾</span>: لَمَحَوْنا القرآنَ من القلوبِ والمصاحِفِ، حتى لا يَبْقى له أثرٌ.</p><p><span class="qpc-hafs">﴿وَكِيلًا﴾</span>: مَن يَلْتزِمُ باستردادِه بعد الذَّهابِ به.</p></div>"