quran[20]{c,v,t}:
  44,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡفَصۡلِ﴾</span>: يومَ القَضاءِ بَينَ الخَلْقِ.</p><p><span class="qpc-hafs">﴿مِيقَـٰتُهُمۡ﴾</span>: مَوعِدُ جزائِهِم</p></div>"
  44,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغۡنِي﴾</span>: يَدْفَعُ.</p><p><span class="qpc-hafs">﴿مَّوۡلࣰى﴾</span>: صاحِبٌ.</p></div>"
  44,42,""
  44,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرَتَ ٱلزَّقُّومِ﴾</span>: شَجَرةً كَرِيهةَ الرّائِحَةِ صَغِيرةَ الوَرَقِ مَسْمُومةً خَلَقَها اللهُ في جَهَنَّمَ.</p></div>"
  44,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَثِيمِ﴾</span>: الكَثِيرِ الآثامِ، والمرادُ بِه المشْرِكُ.</p></div>"
  44,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡمُهۡلِ﴾</span>: كالمَعْدَنِ المُذابِ.</p></div>"
  44,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَمِيمِ﴾</span>: الماءِ الَّذِي بَلَغَ الغايَةَ فِي الحرارةِ.</p></div>"
  44,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱعۡتِلُوهُ﴾</span>: ادْفَعُوهُ وقُودُوهُ بِعُنْفٍ.</p><p><span class="qpc-hafs">﴿سَوَآءِ﴾</span>: وسَطِ.</p></div>"
  44,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُبُّواْ﴾</span>: أفْرِغُوا.</p></div>"
  44,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُقۡ﴾</span>: قُولُوا لَهُ عَلى وجْهِ الإهانَةِ: أحْسِسْ.</p><p><span class="qpc-hafs">﴿أَنتَ ٱلۡعَزِيزُ ٱلۡكَرِيمُ﴾</span>: أي: الذَّلِيلُ المُهانُ، عُكِسَ المَدْلُولُ للتَّهَكُّمِ بِهِ.</p></div>"
  44,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمۡتَرُونَ﴾</span>: تَشُكُّونَ.</p></div>"
  44,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَقَامٍ﴾</span>: مَسْكَنٍ.</p><p><span class="qpc-hafs">﴿أَمِينࣲ﴾</span>: آمِنٍ صاحِبُه مِنَ الآفاتِ.</p></div>"
  44,52,""
  44,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُندُسࣲ﴾</span>: الرقِيقِ مِنَ الحرِيرِ الخالِصِ.</p><p><span class="qpc-hafs">﴿وَإِسۡتَبۡرَقࣲ﴾</span>: الغليظِ مِنَ الحريرِ الخالصِ.</p><p><span class="qpc-hafs">﴿مُّتَقَـٰبِلِينَ﴾</span>: أي: في مَجالِسِهِم ومُحادَثاتِهِم.</p></div>"
  44,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزَوَّجۡنَـٰهُم﴾</span>: قَرنّاهُم.</p><p><span class="qpc-hafs">﴿بِحُورٍ﴾</span>: جَمْعُ حَوْراءَ وهي البيضاءُ.</p><p><span class="qpc-hafs">﴿عِينࣲ﴾</span>: واسِعاتِ الأَعْيُنِ.</p></div>"
  44,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَدۡعُونَ﴾</span>: يَطْلُبُونَ.</p></div>"
  44,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَوۡتَةَ ٱلۡأُولَىٰ﴾</span>: الَّتِي سَلَفَتْ لَهُم في الُّدنيا.</p></div>"
  44,57,""
  44,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسَّرۡنَـٰهُ﴾</span>: سَهَّلْنا لَفْظَ القرآنِ ومَعْناهُ.</p></div>"
  44,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱرۡتَقِبۡ﴾</span>: فانْتَظِر ما وعَدْتُكَ.</p><p><span class="qpc-hafs">﴿مُّرۡتَقِبُونَ﴾</span>: مُنْتَظِرُونَ موتَكَ وقَهْرَكَ.</p></div>"