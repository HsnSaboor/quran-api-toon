quran[12]{c,v,t}:
  97,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنزَلۡنَـٰهُ﴾</span>: أنْزَلْنا القُرآنَ.</p><p><span class="qpc-hafs">﴿ٱلۡقَدۡرِ﴾</span>: الشَّرَفِ والفَضْلِ، وهي إحْدى لَيالِي شَهْرِ رَمَضانَ.</p></div>"
  97,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعْلَمَكَ؟</p></div>"
  97,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَيۡرࣱ مِّنۡ أَلۡفِ شَهۡرࣲ﴾</span>: فَضْلُها خَيرٌ مِن فَضْلِ ألْفِ شَهْرٍ.</p></div>"
  97,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنَزَّلُ ٱلۡمَلَـٰٓئِكَةُ وَٱلرُّوحُ فِيهَا﴾</span>: يَكْثُرُ نُزُولُ الملائِكةِ وجِبْريلَ عَلَيهِ السَّلامُ فِيها.</p><p><span class="qpc-hafs">﴿بِإِذۡنِ رَبِّهِم﴾</span>: أي في النُّزُولِ.</p><p><span class="qpc-hafs">﴿مِّن كُلِّ أَمۡرࣲ﴾</span>: مِن أجْلِ كُلِّ أمْرٍ أرادَ اللهُ قَضاءَه في تِلْك السَّنةِ.</p></div>"
  97,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَـٰمٌ هِيَ﴾</span>: هي أمْنٌ كُلُّها.</p><p><span class="qpc-hafs">﴿حَتَّىٰ مَطۡلَعِ ٱلۡفَجۡرِ﴾</span>: إلى طُلُوعِ الفجْرِ.</p></div>"
  98,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنفَكِّينَ﴾</span>: تاركِينَ كُفْرَهُم.</p><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَةُ﴾</span>: العَلامةُ الَّتِي وُعِدُوا بِها في الكُتُبِ السّابِقَةِ.</p></div>"
  98,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صُحُفࣰا﴾</span>: قُرآنًا في صُحُفٍ.</p></div>"
  98,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُتُبࣱ قَيِّمَةࣱ﴾</span>: أخْبارٌ صادِقَةٌ، تهدِي إلى الحقِّ.</p></div>"
  98,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَآءَتۡهُمُ ٱلۡبَيِّنَةُ﴾</span>: تَبيَّنُوا أنُّه النَّبِيُّ الَّذِي وُعِدُوا بِهِ.</p></div>"
  98,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُخۡلِصِينَ لَهُ ٱلدِّينَ﴾</span>: قاصِدِينَ بِعِبادَتِهِم وجْهَهُ.</p><p><span class="qpc-hafs">﴿حُنَفَآءَ﴾</span>: مائِلِينَ عَنِ الشِّركِ إلى الإيمانِ.</p><p><span class="qpc-hafs">﴿دِينُ ٱلۡقَيِّمَةِ﴾</span>: دِينُ الاسْتِقامةِ، وهو الإسلامُ.</p></div>"
  98,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَرُّ﴾</span>: أشَدُّ شَرًّا.</p></div>"
  98,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَرِيَّةِ﴾</span>: الخَلْقِ.</p></div>"