quran[8]{c,v,t}:
  16,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّسَانُ﴾</span>: لُغةُ وكلامُ.</p><p><span class="qpc-hafs">﴿يُلۡحِدُونَ إِلَيۡهِ﴾</span>: يَنْسِبُون إليه التعليمَ.</p><p><span class="qpc-hafs">﴿أَعۡجَمِيࣱّ﴾</span>: لا يُفْصِحُ عن مُرادِه.</p><p><span class="qpc-hafs">﴿مُّبِينٌ﴾</span>: في غايةِ الوضوحِ والبيانِ.</p></div>"
  16,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَهۡدِيهِمُ ٱللَّهُ﴾</span>: لا يُوَفِّقُهم للإيمانِ؛ لعِلْمِه بعدَمِ قَبولِهم له.</p></div>"
  16,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡتَرِي﴾</span>: يَخْتِلقُ.</p></div>"
  16,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن كَفَرَ بِٱللَّهِ﴾</span>: فهم الكاذبون حقًّا، وعليهم غَضَبٌ من الله.</p><p><span class="qpc-hafs">﴿أُكۡرِهَ﴾</span>: أُرْغِمَ على النُّطْقِ بالكفرِ فَتَلفَّظَ به؛ خَوْفًا من هَلاكِه.</p><p><span class="qpc-hafs">﴿شَرَحَ بِٱلۡكُفۡرِ صَدۡرࣰا﴾</span>: اعتَقَدَه وطابَتْ نفسُه به.</p></div>"
  16,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَحَبُّواْ ٱلۡحَيَوٰةَ﴾</span>: اختارُوها وفَضَّلُوها.</p></div>"
  16,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَبَعَ﴾</span>: خَتَم.</p></div>"
  16,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حقًّا، أو لا مَحالةَ.</p></div>"
  16,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُتِنُواْ﴾</span>: اختُبِرُوا بتعذيبِهم، وتَلَفَّظُوا بالكُفرِ.</p></div>"