tafsir[24]{c,v,t}:
  26,160,""
  26,161,""
  26,162,""
  26,163,""
  26,164,""
26,165," <q>﴿أَتَأۡتُونَ ٱلذُّكۡرَانَ﴾</q>: أتَنْكِحُونَ الرِّجالَ؟ "
26,166," <q>﴿وَتَذَرُونَ﴾</q>: وتَتْرُكُونَ. <q>﴿عَادُونَ﴾</q>: مُتَجاوِزُونَ ما أباحَهُ اللهُ لَكُم مِنَ الحَلالِ إلى الحَرامِ. "
  26,167,""
26,168," <q>﴿مِّنَ ٱلۡقَالِينَ﴾</q>: مِنَ المُبْغِضِينَ أشَدَّ البُغْضِ. "
  26,169,""
  26,170,""
26,171," <q>﴿فِي ٱلۡغَـٰبِرِينَ﴾</q>: في الباقِينَ في العذابِ والهلاكِ. "
26,172," <q>﴿دَمَّرۡنَا﴾</q>: أهْلَكْنا. "
  26,173,""
  26,174,""
  26,175,""
26,176," <q>﴿أَصۡحَـٰبُ لۡـَٔيۡكَةِ﴾</q>: أصْحابُ الشَّجَرِ المُلْتَفِّ. "
  26,177,""
  26,178,""
  26,179,""
  26,180,""
26,181," <q>﴿مِنَ ٱلۡمُخۡسِرِينَ﴾</q>: مِنَ النّاقِصِينَ للحُقُوقِ بالتَّطفِيفِ. "
26,182," <q>﴿بِٱلۡقِسۡطَاسِ﴾</q>: بالميزانِ. "
26,183," <q>﴿وَلَا تَبۡخَسُواْ﴾</q>: ولا تَنْقُصُوا. <q>﴿وَلَا تَعۡثَوۡاْ﴾</q>: ولا تُفْسِدُوا أشَدَّ الإفْسادِ. "
