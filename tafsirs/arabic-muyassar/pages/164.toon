quran[16]{c,v,t}:
  7,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقِيقٌ﴾</span>: جديرٌ وحَرِيٌّ.</p><p><span class="qpc-hafs">﴿بِبَيِّنَةࣲ﴾</span>: ببُرهانٍ وحُجَّةٍ واضحةٍ على صِدْقِ ما أقولُ.</p></div>"
  7,106,"<div class=ar lang=ar></div>"
  7,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُعۡبَانࣱ﴾</span>: حَيَّةٌ عظيمةٌ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: ظاهرةٌ لكلِّ مَن يَراها.</p></div>"
  7,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعَ يَدَهُۥ﴾</span>: وأخرجَ يدَه من فتحةِ قميصِه، أو من تحتِ إبْطِه.</p></div>"
  7,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: أشرافُ القومِ وسادَتُهم.</p></div>"
  7,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَأۡمُرُونَ﴾</span>: تُشيرون عليَّ أيها الأشرافُ.</p></div>"
  7,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡجِهۡ وَأَخَاهُ﴾</span>: أخِّرْ موسى وأخاه هارونَ، ولا تَفْصِلْ في شأنِهما الآن.</p><p><span class="qpc-hafs">﴿فِي ٱلۡمَدَآئِنِ﴾</span>: في مُدُنِ مِصْرَ وأقاليمِها.</p><p><span class="qpc-hafs">﴿حَـٰشِرِينَ﴾</span>: مَن يَحْشُرُ السَّحَرَةَ فيَجْمَعُهم إليك.</p></div>"
  7,112,"<div class=ar lang=ar></div>"
  7,113,"7:112"
  7,114,"7:112"
  7,115,"7:112"
  7,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَحَرُوٓاْ أَعۡيُنَ ٱلنَّاسِ﴾</span>: صَرَفُوها عن حقيقةِ إدراكِها، فخُيِّلَ إلى الأبصارِ أنّ ما فعلُوه حقيقةٌ.</p><p><span class="qpc-hafs">﴿وَٱسۡتَرۡهَبُوهُمۡ﴾</span>: وأخافوا الناسَ إخافةً شديدةً.</p></div>"
  7,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلۡقَفُ﴾</span>: تبتلِعُ بسرعة.</p><p><span class="qpc-hafs">﴿مَا يَأۡفِكُونَ﴾</span>: ما يُلْقُونه من الحِبال والعِصِيِّ، ويُوهِمونَ الناسَ أنه حقٌّ.</p></div>"
  7,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَقَعَ ٱلۡحَقُّ﴾</span>: فظهر الحقُّ في أمرِ موسى عليه السلام.</p></div>"
  7,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱنقَلَبُواْ﴾</span>: وانصرفَ فرعونُ وقومُه.</p><p><span class="qpc-hafs">﴿صَـٰغِرِينَ﴾</span>: أذلّاءَ بما لَحِقَهم من الهزيمةِ والخَيبةِ.</p></div>"
  7,120,"<div class=ar lang=ar></div>"