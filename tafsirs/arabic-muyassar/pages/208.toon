quran[6]{c,v,t}:
  10,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَكِيمِ﴾</span>: المُحْكَمِ في لَفْظِه ومعناه.</p></div>"
  10,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَمَ صِدۡقٍ﴾</span>: أجرًا حسنًا؛ بما قَدَّموا من صالحِ الأعمالِ.</p></div>"
  10,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: علا وارتفعَ، استواءً يَليق بجَلالِه وعَظَمَتِه.</p><p><span class="qpc-hafs">﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾</span>: يَقْضِي أمورَ الدنيا والآخرةِ، ويُصَرِّفُها وحدَه على أكملِ الوجوهِ.</p><p><span class="qpc-hafs">﴿إِلَّا مِنۢ بَعۡدِ إِذۡنِهِۦ﴾</span>: إلا أنْ يأذنَ اللهُ له بالشفاعةِ.</p></div>"
  10,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرۡجِعُكُمۡ﴾</span>: مَعادُكم يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعَدْلِ.</p><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: ماءٍ شديدِ الحرارةِ.</p></div>"
  10,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِيَآءࣰ﴾</span>: ذاتَ ضياءٍ في النهار.</p><p><span class="qpc-hafs">﴿نُورࣰا﴾</span>: ذاتَ نورٍ في الليل.</p><p><span class="qpc-hafs">﴿وَقَدَّرَهُۥ مَنَازِلَ﴾</span>: وهَيَّأ للقَمَرِ منازلَ لا يتَعدّاها.</p><p><span class="qpc-hafs">﴿وَٱلۡحِسَابَ﴾</span>: ولتعلمُوا حسابَ الأشهرِ والأيامِ.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: أي: الَخلْقُ والتقديرُ.</p><p><span class="qpc-hafs">﴿إِلَّا بِٱلۡحَقِّ﴾</span>: إلا لحكمةٍ عظيمةٍ بالغةٍ.</p><p><span class="qpc-hafs">﴿يُفَصِّلُ﴾</span>: يُبَيِّنُ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الحُجَجَ والأدَّلةَ الدالَّةَ على عَظَمَتِه.</p></div>"
  10,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: إتيانِ أحدِهما بعد الآخَرِ.</p></div>"