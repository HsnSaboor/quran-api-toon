quran[7]{c,v,t}:
  34,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡتَرَىٰ﴾</span>: هَلِ اخْتَلَقَ؟</p><p><span class="qpc-hafs">﴿جِنَّةُۢ﴾</span>: جُنُونٌ.</p></div>"
  34,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا بَيۡنَ أَيۡدِيهِمۡ وَمَا خَلۡفَهُم مِّنَ ٱلسَّمَآءِ وَٱلۡأَرۡضِ﴾</span>: أي: كُلٌّ مِنَ السَّماءِ والأرضِ يُحِيطُ بِهِم مِن أمامِهِم وخَلْفِهِم.</p><p><span class="qpc-hafs">﴿نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ﴾</span>: نَجْعَلِ الأرْضَ تَبْتَلِعُهُم وهُمْ أحْياءٌ.</p><p><span class="qpc-hafs">﴿كِسَفࣰا مِّنَ ٱلسَّمَآءِ﴾</span>: قِطَعًا مِنها.</p><p><span class="qpc-hafs">﴿مُّنِيبࣲ﴾</span>: راجِعٍ إلى رَبِّهِ بالتَّوبَةِ والطّاعَةِ.</p></div>"
  34,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوِّبِي﴾</span>: سَبِّحِي.</p><p><span class="qpc-hafs">﴿وَأَلَنَّا لَهُ ٱلۡحَدِيدَ﴾</span>: جَعَلْنا الحديدَ في يدِهِ لَيِّنًا، يَصْنَعُ بِهِ ما يَشاءُ.</p></div>"
  34,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَـٰبِغَـٰتࣲ﴾</span>: أي: دُرُوعًا واسِعاتٍ تُغَطِّي الِجسْمَ كلَّه.</p><p><span class="qpc-hafs">﴿قَدِّرۡ فِي ٱلسَّرۡدِ﴾</span>: أي: قَدِّرْ في نَسْجِ الدُّرُوعِ وإحْكامِها تَقْدِيرًا مُناسِبًا يَجْمَعُ ما بَينَ الخِفَّةِ والحَصانَةِ.</p></div>"
  34,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غُدُوُّهَا شَهۡرࣱ﴾</span>: أي: تَجْرِي الرِّيحُ مِن أوَّلِ النَّهارِ إلى انْتِصافِه مَسِيرَةَ شَهْرٍ بالسَّيرِ المُعْتادِ.</p><p><span class="qpc-hafs">﴿وَرَوَاحُهَا شَهۡرࣱ﴾</span>: أي: تَجْرِي الرِّيحُ مِن مُّنْتَصَفِ النَّهارِ إلى اللَّيلِ مَسِيرَةَ شَهْرٍ.</p><p><span class="qpc-hafs">﴿وَأَسَلۡنَا لَهُۥ عَيۡنَ ٱلۡقِطۡرِ﴾</span>: وأَسَلْنا لَهُ عَينَ النُّحاسِ كما يَسِيلُ الماءُ.</p><p><span class="qpc-hafs">﴿مَن يَزِغۡ﴾</span>: مَن يَمِلْ ويَعدِلْ.</p><p><span class="qpc-hafs">﴿ٱلسَّعِيرِ﴾</span>: النّارِ المسْتَعِرةِ.</p></div>"
  34,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّحَـٰرِيبَ﴾</span>: قُصُورٍ أو مساجِدَ.</p><p><span class="qpc-hafs">﴿وَتَمَـٰثِيلَ﴾</span>: صُوَرٍ مُجَسَّمَةٍ من نُّحاسٍ وزُجاجٍ وغيرِهِما (وحُرِّمَ ذلك في الإسْلامِ).</p><p><span class="qpc-hafs">﴿وَجِفَانࣲ﴾</span>: جَمْعُ «جَفْنَةٍ»، وهي القَصْعةُ الكَبِيرةُ.</p><p><span class="qpc-hafs">﴿كَٱلۡجَوَابِ﴾</span>: جَمْعِ «جابِيَةٍ»، وهي الحوضُ الكبيرُ الذي يُجْمعُ فيه الماءُ.</p><p><span class="qpc-hafs">﴿رَّاسِيَـٰتٍ﴾</span>: ثابتاتٍ على المواقِد، لا تَتَحَرَّكُ لِعِظَمِها.</p></div>"
  34,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَضَيۡنَا﴾</span>: حَكَمْنا.</p><p><span class="qpc-hafs">﴿دَآبَّةُ ٱلۡأَرۡضِ﴾</span>: الأَرَضَةُ الَّتي تَأْكُلُ الخَشَبَ.</p><p><span class="qpc-hafs">﴿مِنسَأَتَهُۥ﴾</span>: عَصاهُ.</p><p><span class="qpc-hafs">﴿خَرَّ﴾</span>: سَقَطَ ووَقَعَ.</p><p><span class="qpc-hafs">﴿تَبَيَّنَتِ﴾</span>: عَلِمَتْ.</p><p><span class="qpc-hafs">﴿مَا لَبِثُواْ﴾</span>: ما أقامُوا.</p><p><span class="qpc-hafs">﴿ٱلۡمُهِينِ﴾</span>: المُذِلِّ.</p></div>"