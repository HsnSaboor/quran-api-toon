tafsir[21]{c,v,t}:
26,207," <q>﴿مَآ أَغۡنَىٰ عَنۡهُم﴾</q>: أي: لم يَنْفَعْهُم. "
  26,208,""
26,209," <q>﴿ذِكۡرَىٰ﴾</q>: أي: تَذْكِيرٌ وتَنْبِيهٌ. "
  26,210,""
26,211," <q>﴿وَمَا يَنۢبَغِي لَهُمۡ﴾</q>: ولا يَصِحُّ مِنهُم. "
26,212," <q>﴿لَمَعۡزُولُونَ﴾</q>: لمحْجُوُبونَ. "
  26,213,""
26,214," <q>﴿عَشِيرَتَكَ﴾</q>: قَبِيلَتَكَ. "
26,215," <q>﴿وَٱخۡفِضۡ جَنَاحَكَ﴾</q>: ألِنْ جانِبَكَ وتَواضَعْ. "
  26,216,""
  26,217,""
  26,218,""
26,219," <q>﴿وَتَقَلُّبَكَ﴾</q>: وتَصرُّفَكَ أو تَقَلُّبَكَ في الرُّكُوعِ والسُّجُودِ والقِيامِ. "
  26,220,""
  26,221,""
26,222," <q>﴿أَفَّاكٍ﴾</q>: كَذّابٍ. <q>﴿أَثِيمࣲ﴾</q>: كَثِيرِ الآثامِ. "
26,223," <q>﴿يُلۡقُونَ ٱلسَّمۡعَ﴾</q>: يُلْقُونَ ما سَمِعُوه مِنَ السَّماءِ إلى الكُهّانِ. "
26,224," <q>﴿ٱلۡغَاوُۥنَ﴾</q>: الضّالُّونَ عَنِ الحقِّ. "
26,225," <q>﴿كُلِّ وَادࣲ﴾</q>: كلِّ فَنٍّ مِن فُنُونِ الكَذِبِ. <q>﴿يَهِيمُونَ﴾</q>: يخُوضُونَ. "
  26,226,""
26,227," <q>﴿يَنقَلِبُونَ﴾</q>: يَرْجِعُونَ إليهِ. "
