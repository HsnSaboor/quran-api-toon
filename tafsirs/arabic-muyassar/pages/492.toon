quran[14]{c,v,t}:
43,34," <q>﴿وَسُرُرًا﴾</q>: جَمْعُ سَرِيرٍ، وهو ككرْسِيٍّ واسِعٍ يُمْكِنُ الاضْطِجاعُ عَلَيهِ. <q>﴿يَتَّكِـُٔونَ﴾</q>: يَجْلِسُونَ عَلَيها مُعْتَمِدِينَ على مَرافِقِهِم. "
43,35," <q>﴿وَزُخۡرُفࣰا﴾</q>: وجَعَلْنا لهم ذَهَبًا. "
43,36," <q>﴿يَعۡشُ﴾</q>: يُعرِضْ. <q>﴿ذِكۡرِ ٱلرَّحۡمَـٰنِ﴾</q>: القرآن. <q>﴿نُقَيِّضۡ﴾</q>: نَجْعَلْ. <q>﴿قَرِينࣱ﴾</q>: مُلازِمٌ ومُصاحِبٌ. "
43,37," <q>﴿ٱلسَّبِيلِ﴾</q>: طَرِيقِ الحقِّ "
43,38," <q>﴿يَـٰلَيۡتَ﴾</q>: ودِدْتُّ وتمنَّيتُ. <q>﴿بُعۡدَ ٱلۡمَشۡرِقَيۡنِ﴾</q>: بُعْدَ ما بَينَ المشْرِقِ والمغْرِبِ. "
  43,39,""
  43,40,""
  43,41,""
  43,42,""
  43,43,""
43,44," <q>﴿لَذِكۡرࣱ﴾</q>: لَشَرَفٌ. "
43,45," <q>﴿مَنۡ أَرۡسَلۡنَا﴾</q>: أتْباعَ مَن أرْسَلْنا، وهُم مُّؤمِنُو أهْلِ الكِتابِ. "
43,46," <q>﴿بِـَٔايَـٰتِنَآ﴾</q>: بِحُجَجِنا. <q>﴿وَمَلَإِيْهِۦ﴾</q>: عُظَماءِ قَومِهِ. "
  43,47,""
