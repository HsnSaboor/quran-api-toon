quran[25]{c,v,t}:
  20,13,""
20,14," <q>﴿لِذِكۡرِيٓ﴾</q>: لِتَذْكُرَني فِيها. "
  20,15,""
20,16," <q>﴿فَلَا يَصُدَّنَّكَ﴾</q>: فلا يَصْرِفَنَّكَ. <q>﴿فَتَرۡدَىٰ﴾</q>: فَتَهْلَكَ. "
  20,17,""
20,18," <q>﴿أَتَوَكَّؤُاْ عَلَيۡهَا﴾</q>: أعْتَمِدُ عَلَيها في المَشْيِ. <q>﴿وَأَهُشُّ بِهَا﴾</q>: وأَهُزُّ بِها الشَّجَرَ لِيَسْقُطَ مِنه الوَرَقُ. <q>﴿مَـَٔارِبُ﴾</q>: حاجاتٌ ومَنافعُ. "
  20,19,""
  20,20,""
  20,21,""
20,22," <q>﴿إِلَىٰ جَنَاحِكَ﴾</q>: جَنبِك تَحْتَ العَضُدِ. <q>﴿مِنۡ غَيۡرِ سُوٓءٍ﴾</q>: مِن غَيرِ مَرَضٍ ولا بَرَصٍ. "
  20,23,""
20,24," <q>﴿طَغَىٰ﴾</q>: تَجاوَزَ حَدَّه بالتَّمَرُّدِ على ربِّه. "
  20,25,""
  20,26,""
20,27," <q>﴿وَٱحۡلُلۡ عُقۡدَةࣰ مِّن لِّسَانِي﴾</q>: وأَطْلِقْ عَنْ لِساني العُقْدَةَ التي فِيه. "
  20,28,""
20,29," <q>﴿وَزِيرࣰا﴾</q>: مُعِينًا في إبْلاغِ رِسالتِكَ. "
  20,30,""
20,31," <q>﴿ٱشۡدُدۡ بِهِۦٓ أَزۡرِي﴾</q>: قَوِّني به وشُدَّ به ظَهْري. "
20,32," <q>﴿فِيٓ أَمۡرِي﴾</q>: في النُّبوَّةِ وتَبْلِيغِ الرِّسالةِ. "
  20,33,""
  20,34,""
  20,35,""
20,36," <q>﴿أُوتِيتَ سُؤۡلَكَ﴾</q>: أُعطِيتَ كلَّ ما سألتَ. "
20,37," <q>﴿وَلَقَدۡ مَنَنَّا عَلَيۡكَ﴾</q>: ولَقَدْ أنْعَمْنا عَلَيكَ. <q>﴿مَرَّةً أُخۡرَىٰٓ﴾</q>: نِعْمَةً أُخْرى بإنْجائِكَ مِن بَطْشِ فِرْعَونَ وجُنُودِه حِينَ كُنْتَ رَضِيعًا. "
