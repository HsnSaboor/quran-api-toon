quran[7]{c,v,t}:
  40,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: الدَّلائِلِ الُمظْهِرَةِ أنّهُ رَسُول مِنَ اللهِ.</p><p><span class="qpc-hafs">﴿هَلَكَ﴾</span>: ماتَ.</p><p><span class="qpc-hafs">﴿مُسۡرِفࣱ﴾</span>: مُتَجاوِزٌ لِلْحَقِّ.</p><p><span class="qpc-hafs">﴿مُّرۡتَابٌ﴾</span>: شاكٌّ في وحْدانِيَّةِ اللهِ.</p></div>"
  40,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: حُجَّةٍ مَقْبُولةٍ.</p><p><span class="qpc-hafs">﴿يَطۡبَعُ ٱللَّهُ﴾</span>: يَخْتِمُ اللهُ.</p><p><span class="qpc-hafs">﴿جَبَّارࣲ﴾</span>: الَّذِي يُكْرِهُ الناسَ عَلى ما لا يُحِبُّونَ عَمَلَه لِظُلْمِهِ.</p></div>"
  40,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡحࣰا﴾</span>: بِناءً عَظِيمًا.</p><p><span class="qpc-hafs">﴿ٱلۡأَسۡبَـٰبَ﴾</span>: أبْوابَ السَّمَواتِ وما يُوصِلُنِي إلَيها.</p></div>"
  40,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدُ﴾</span>: احْتِيالُ.</p><p><span class="qpc-hafs">﴿تَبَابࣲ﴾</span>: خَسارٍ وبَوارٍ.</p></div>"
  40,38,"<div class=ar lang=ar></div>"
  40,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعࣱ﴾</span>: تَمَتُّعٌ في مُدَّةٍ قَلِيلَةٍ.</p><p><span class="qpc-hafs">﴿ٱلۡقَرَارِ﴾</span>: الدَّوامِ في المكانِ.</p></div>"
  40,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِغَيۡرِ حِسَابࣲ﴾</span>: بَغَيرِ تَقْتِيرٍ.</p></div>"