quran[22]{c,v,t}:
  38,62,""
38,63," <q>﴿أَتَّخَذۡنَـٰهُمۡ سِخۡرِيًّا﴾</q>: هَلْ أخْطأنا في تَحْقِيرِنا لَهُم، واسْتِهْزائِنا بِهِم؟ <q>﴿زَاغَتۡ﴾</q>: لم تَقَعْ عَلَيهِم. "
38,64," <q>﴿ذَ ٰ⁠لِكَ﴾</q>: جِدالَ أهْلِ النّارِ وخِصامَهُم. "
38,65," <q>﴿ٱلۡقَهَّارُ﴾</q>: الَّذي قَهَرَ كُلَّ شَيءٍ وغَلَبَهُ. "
  38,66,""
38,67," <q>﴿نَبَؤٌاْ عَظِيمٌ﴾</q>: خَبَرٌ عظِيمُ النَّفْعِ. "
  38,68,""
38,69," <q>﴿بِٱلۡمَلَإِ ٱلۡأَعۡلَىٰٓ﴾</q>: مَلائِكَةِ السَّماءِ. "
  38,70,""
  38,71,""
38,72," <q>﴿رُّوحِي﴾</q>: رُوحِ الحَياةِ الَّتي يَخْلُقُها اللهُ. <q>﴿فَقَعُواْ لَهُۥ سَـٰجِدِينَ﴾</q>: فاسْجُدُوا لَهُ سُجُودَ تَحِيَّةٍ وإكْرامٍ، لا سُجُودَ عِبادَةٍ وتَعْظِيمٍ. "
  38,73,""
  38,74,""
38,75," <q>﴿أَسۡتَكۡبَرۡتَ﴾</q>: أتَعَظَّمْتَ وتَكَبَّرْتَ الآنَ عَنِ السُّجُودِ لآدَمَ؟ <q>﴿أَمۡ كُنتَ مِنَ ٱلۡعَالِينَ﴾</q>: أم كُنْتَ مِنَ الُمتَكَبِّرِينَ عَلى رَبِكَ مِن قَبْلُ. "
  38,76,""
38,77," <q>﴿رَجِيمࣱ﴾</q>: مَطْرُودٌ. "
38,78," <q>﴿لَعۡنَتِيٓ﴾</q>: طَرْدِي وإبْعادِي. <q>﴿ٱلدِّينِ﴾</q>: الجَزاءِ. "
38,79," <q>﴿فَأَنظِرۡنِيٓ﴾</q>: فأخِّرْ أجَلِي، ولا تُهْلِكْنِي. "
38,80," <q>﴿ٱلۡمُنظَرِينَ﴾</q>: المُؤَخَّرِينَ. "
38,81," <q>﴿إِلَىٰ يَوۡمِ ٱلۡوَقۡتِ ٱلۡمَعۡلُومِ﴾</q>: إلى يومِ النَّفْخَةِ الأُولى الَّتي يَمُوتُ مِنها مَن بَقِيَ مِنَ الخلائِقِ. "
  38,82,""
38,83," <q>﴿ٱلۡمُخۡلَصِينَ﴾</q>: الَّذينَ أخْلَصْتَهُم لِعِبادَتِكَ وعَصَمْتَهم من إضْلالِ الشَّيطانِ. "
