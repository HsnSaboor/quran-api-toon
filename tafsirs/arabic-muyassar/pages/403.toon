quran[11]{c,v,t}:
  29,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجَلࣱ مُّسَمࣰّى﴾</span>: وقْتٌ مُعَيَّنٌ لا يَتَقَدَّمُ ولا يَتَأَخَّرُ.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فُجاءَةً.</p></div>"
  29,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمُحِيطَةُۢ﴾</span>: أي: سَتُحِيطُ بِهِم في الآخِرَةِ.</p></div>"
  29,55,""
  29,56,""
  29,57,""
  29,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنُبَوِّئَنَّهُم﴾</span>: لَنُنَزِّلَنَّهُم.</p><p><span class="qpc-hafs">﴿غُرَفࣰا﴾</span>: مَنازِلَ عالِيةً.</p></div>"
  29,59,""
  29,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَأَيِّن مِّن دَآبَّةࣲ﴾</span>: أي: كَثِيرٌ مِنَ الدَّوابِّ.</p><p><span class="qpc-hafs">﴿لَّا تَحۡمِلُ رِزۡقَهَا﴾</span>: أي: لا تُطِيقُ حَمْلَهُ ولا ادِّخارَهُ.</p></div>"
  29,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾</span>: فَكَيفَ يُصرَفُونَ عَن تَوحِيدِهِ؟</p></div>"
  29,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡسُطُ﴾</span>: يُوَسِّعُ.</p><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: يُضَيِّقُ.</p></div>"
  29,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ مَوۡتِهَا﴾</span>: مِن بَعْدِ قَحْطِ الأرْضِ وجَفافِها.</p></div>"