quran[13]{c,v,t}:
  19,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡحَسۡرَةِ﴾</span>: يومَ النَّدامةِ على ما فرَّطُوا في جَنْبِ اللهِ.</p></div>"
  19,40,""
  19,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِدِّيقࣰا﴾</span>: عَظِيمَ الصِّدقِ.</p></div>"
  19,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُغۡنِي﴾</span>: ولا يَدْفَعُ.</p></div>"
  19,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡدِكَ﴾</span>: أُرْشِدْكَ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣰا سَوِيࣰّا﴾</span>: طريقًا مُسْتَويًا لا اعْوِجاجَ فيه.</p></div>"
  19,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَعۡبُدِ ٱلشَّيۡطَـٰنَ﴾</span>: لا تُطِعِ الشَّيطانَ في عِبادةِ الأصْنام.</p><p><span class="qpc-hafs">﴿عَصِيࣰّا﴾</span>: مُخالِفًا مُسْتكْبِرًا عَن طاعَةِ اللهِ.</p></div>"
  19,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلشَّيۡطَـٰنِ وَلِيࣰّا﴾</span>: قَرِينًا لَه في اللَّعنةِ، وقريبًا منه في النّار.</p></div>"
  19,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَاغِبٌ أَنتَ عَنۡ ءَالِهَتِي﴾</span>: أمُعْرِضٌ أنت عَن عِبادَةِ آلَهتِي.</p><p><span class="qpc-hafs">﴿لَأَرۡجُمَنَّكَ﴾</span>: لَأَقْتُلَنَّك رَمْيًا بِالحِجارَةِ.</p><p><span class="qpc-hafs">﴿مَلِيࣰّا﴾</span>: زَمانًا طَوِيلًا مِنَ الدَّهْرِ.</p></div>"
  19,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَـٰمٌ عَلَيۡكَ﴾</span>: تحيةُ تَودِيعٍ ومُتارَكَةٍ، أي: تَسْلَمُ ممّا تَكْرَهُه مِنِّي.</p><p><span class="qpc-hafs">﴿بِي حَفِيࣰّا﴾</span>: كَثيرَ الِبرِّ واللُّطْفِ.</p></div>"
  19,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعۡتَزِلُكُمۡ﴾</span>: وأُفارِقُكُم.</p><p><span class="qpc-hafs">﴿شَقِيࣰّا﴾</span>: مَحْرُومًا مِن إجابَةِ الدُّعاءِ.</p></div>"
  19,49,""
  19,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِسَانَ صِدۡقٍ﴾</span>: ثَناءً حَسَنًا.</p><p><span class="qpc-hafs">﴿عَلِيࣰّا﴾</span>: رفيعَ القَدْرِ باقيًا في النّاسِ.</p></div>"
  19,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُخۡلَصࣰا﴾</span>: مُخْتارًا لِرِسالتِه.</p></div>"