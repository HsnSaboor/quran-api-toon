quran[8]{c,v,t}:
  40,59,"<div class=ar lang=ar></div>"
  40,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱدۡعُونِيٓ﴾</span>: خُصُّونِي بِدُعاءِ العِبادةِ ودُعاءِ المسْأَلةِ.</p><p><span class="qpc-hafs">﴿يَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِي﴾</span>: يَتَكَبَّرُونَ عَنْ إفْرادِي بالعِبادَةِ.</p><p><span class="qpc-hafs">﴿دَاخِرِينَ﴾</span>: صاغِرِينَ ذَلِيلِينَ.</p></div>"
  40,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَسۡكُنُواْ﴾</span>: لِتَهْدَؤُوا فِيهِ مِنَ الحرَكَةِ والتَّعَبِ.</p><p><span class="qpc-hafs">﴿مُبۡصِرًا﴾</span>: مُضِيئًا يُبْصِرُ فِيهِ النّاسُ.</p></div>"
  40,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾</span>: فَكَيفَ تُصْرَفُونَ عَنِ الحقِّ والصَّوابِ فَتَعْدِلُونَ عَنِ الإيمانِ باللهِ، وتَعْبُدُونَ غَيرَه؟</p></div>"
  40,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡفَكُ﴾</span>: يُصْرَفُ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِ ٱللَّهِ﴾</span>: مُعْجِزاتِهِ.</p><p><span class="qpc-hafs">﴿يَجۡحَدُونَ﴾</span>: يُكَذِّبُونَ.</p></div>"
  40,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرَارࣰا﴾</span>: مَكانَ اسْتِقْرارٍ، ويَسَّرَ لَكُم الإقامَةَ عَلَيها.</p><p><span class="qpc-hafs">﴿بِنَآءࣰ﴾</span>: سَقْفًا للأَرْضِ.</p><p><span class="qpc-hafs">﴿وَصَوَّرَكُمۡ فَأَحۡسَنَ صُوَرَكُمۡ﴾</span>: وخَلَقَكُم في أكْمَلِ هَيْئَةٍ، وأحْسَنِ تَقْويمٍ.</p><p><span class="qpc-hafs">﴿فَتَبَارَكَ ٱللَّهُ﴾</span>: فَتَكاثَر خَيْرُهُ وفَضْلُهُ وبَرَكتُهُ.</p></div>"
  40,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَيُّ﴾</span>: الموصُوفُ بالحياةِ الحقِيقِيَّةِ الكامِلةِ.</p><p><span class="qpc-hafs">﴿ٱلدِّينَ﴾</span>: الطّاعَةَ.</p></div>"
  40,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡبَيِّنَـٰتُ﴾</span>: دَلائلُ التَّوحِيدِ.</p><p><span class="qpc-hafs">﴿أُسۡلِمَ﴾</span>: أخْضَعَ وأنقادَ بالطّاعةِ التامَّةِ.</p></div>"