quran[10]{c,v,t}:
  20,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنَسِيتَهَا﴾</span>: أي: بِتَرْكِ الإيمانِ بها.</p><p><span class="qpc-hafs">﴿تُنسَىٰ﴾</span>: تُتْرَكُ في النّارِ.</p></div>"
  20,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنۡ أَسۡرَفَ﴾</span>: تَجاوَزَ حدودَ ما شَرَعَ اللهُ.</p><p><span class="qpc-hafs">﴿وَأَبۡقَىٰٓ﴾</span>: أدْوَمُ مِن عذابِ الدُّنيا، فلا يَنْقَطِعُ.</p></div>"
  20,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِ لَهُمۡ﴾</span>: أي: يَدُلَّهم على طَريقِ الرَّشادِ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡقُرُونِ﴾</span>: مِنَ الأُمَمِ الماضيةِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَعِبَرًا وعِظاتٍ.</p><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلنُّهَىٰ﴾</span>: لأصْحابِ العقولِ السَّلِيمةِ.</p></div>"
  20,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكَانَ لِزَامࣰا﴾</span>: لَلازَمَهم الهَلاكُ عاجِلًا؛ بسببِ كُفْرِهم.</p></div>"
  20,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَانَآيِٕ ٱلَّيۡلِ﴾</span>: ساعاتِ الليلِ.</p><p><span class="qpc-hafs">﴿تَرۡضَىٰ﴾</span>: أي: تُثابُ على عَمَلِك بما يُرضِيكَ.</p></div>"
  20,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَمُدَّنَّ عَيۡنَيۡكَ﴾</span>: لا تُكَرِّرِ النَّظَرَ إلى المُشْرِكِينَ مُسْتَحْسِنًا.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا مِّنۡهُمۡ﴾</span>: أصْنافًا مِن الكفّارِ.</p><p><span class="qpc-hafs">﴿زَهۡرَةَ ٱلۡحَيَوٰةِ﴾</span>: زينتَها وبَهْجَتَها التي لا تَدُومُ.</p><p><span class="qpc-hafs">﴿لِنَفۡتِنَهُمۡ﴾</span>: لِنَبْتليَهم.</p></div>"
  20,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡطَبِرۡ عَلَيۡهَا﴾</span>: داوِمْ على إقامةِ الصَّلاةِ بِصَبْرٍ.</p></div>"
  20,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةࣲ﴾</span>: بِمُعْجِزَةٍ.</p><p><span class="qpc-hafs">﴿بَيِّنَةُ مَا فِي ٱلصُّحُفِ ٱلۡأُولَىٰ﴾</span>: أي: هذا القرآنُ مصدِّقٌ لما في الكُتُبِ السّابِقَةِ مِنَ الحقِّ.</p></div>"
  20,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قَبۡلِهِۦ﴾</span>: أي: من قبْلِ أن نُرسِلَ إليهم رَسُولًا.</p><p><span class="qpc-hafs">﴿أَن نَّذِلَّ وَنَخۡزَىٰ﴾</span>: أن يُصيَبنا ذُلٌّ وخِزيٌ بعذابِكَ في الدُّنيا والآخِرةِ.</p></div>"
  20,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلࣱّ مُّتَرَبِّصࣱ﴾</span>: كلٌّ مِنّا ومِنكُم منتظِرٌ دوائرَ الزمانِ.</p><p><span class="qpc-hafs">﴿فَتَرَبَّصُواْ﴾</span>: فانْتَظِرُوا.</p></div>"