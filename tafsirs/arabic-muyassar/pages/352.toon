quran[7]{c,v,t}:
  24,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾</span>: طُرُقَه وآثارَه.</p><p><span class="qpc-hafs">﴿بِٱلۡفَحۡشَآءِ﴾</span>: ما عَظُمَ قُبْحُه مِنَ الذُّنوب.</p><p><span class="qpc-hafs">﴿وَٱلۡمُنكَرِ﴾</span>: ما يُنْكِرُه الشَّرعُ أو يَكرَهُه.</p><p><span class="qpc-hafs">﴿مَا زَكَىٰ﴾</span>: ما طَهُرَ، ولا تَطَهَّرَ مِن دَنَسِ الذُّنُوبِ</p><p><span class="qpc-hafs">﴿يُزَكِّي﴾</span>: يُطَهِّرُ.</p></div>"
  24,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَأۡتَلِ﴾</span>: ولا يَحْلِفْ.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡفَضۡلِ﴾</span>: أصْحابُ الفَضَلِ في الدِّينِ.</p><p><span class="qpc-hafs">﴿وَٱلسَّعَةِ﴾</span>: الغِنى في المالِ.</p><p><span class="qpc-hafs">﴿أَن يُؤۡتُوٓاْ﴾</span>: أي: يَحْلِفُونَ على ألّا يُعْطُوا.</p><p><span class="qpc-hafs">﴿أُوْلِي ٱلۡقُرۡبَىٰ﴾</span>: أصْحابَ القَرابَةِ.</p><p><span class="qpc-hafs">﴿وَلۡيَعۡفُواْ﴾</span>: أي: ولْيَتَجاوزُوا عَن ذَنْبِهِم وإساءَتِهِم.</p><p><span class="qpc-hafs">﴿وَلۡيَصۡفَحُوٓاْ﴾</span>: أي: بالإعْراضِ عَن مُّؤاخَذَتِهِم.</p></div>"
  24,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡمُونَ﴾</span>: يَقْذِفُون بالزِّنى.</p><p><span class="qpc-hafs">﴿ٱلۡمُحۡصَنَـٰتِ﴾</span>: العفِيفاتِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَـٰفِلَـٰتِ﴾</span>: اللّاتي لا تَخْطُرُ بِبالِهنَّ الفاحِشَةُ.</p></div>"
  24,24,"<div class=ar lang=ar></div>"
  24,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دِينَهُمُ ٱلۡحَقَّ﴾</span>: جَزاءَهم الثّابِتَ لهم بالعَدْلِ.</p></div>"
  24,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِمَّا يَقُولُونَ﴾</span>: أي: مِنِ اتِّهامِهِم.</p></div>"
  24,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَتَّىٰ تَسۡتَأۡنِسُواْ﴾</span>: حتى تَسْتأذِنُوا.</p></div>"