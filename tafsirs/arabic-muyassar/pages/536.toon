quran[26]{c,v,t}:
  56,51,""
  56,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرࣲ مِّن زَقُّومࣲ﴾</span>: شَجَرَةٍ كَرِيهَةِ الرّائِحَةِ يُنبتُها اللهُ في جَهَنَّمَ.</p></div>"
  56,53,""
  56,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَمِيمِ﴾</span>: هُوَ الماءُ الشَّدِيدُ الغَلَيانِ.</p></div>"
  56,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡهِيمِ﴾</span>: جَمْعُ أهْيَمَ، وهُوَ البَعِيرُ الَّذِي أصابَهُ الهُيامُ، وهو داءُ يُصُيِبُ الإبِلَ فلا تَزالُ تَشْرَبُ ولا تَرْوى.</p></div>"
  56,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُزُلُهُمۡ﴾</span>: النُّزُلُ هو ما يُقَدَّمُ للضَّيفِ مِن طَعامٍ.</p></div>"
  56,57,""
  56,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُمۡنُونَ﴾</span>: ما يَكُونُ مِنكُم مِن الَمنِيِّ.</p></div>"
  56,59,""
  56,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ﴾</span>: قَضَيْنا عَلَيكُم بِالمَوْتِ أوْ سَوَّينا بَينَكُم في الموتِ.</p><p><span class="qpc-hafs">﴿بِمَسۡبُوقِينَ﴾</span>: بِمَغْلُوبِينَ.</p></div>"
  56,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّبَدِّلَ أَمۡثَـٰلَكُمۡ﴾</span>: نُغَيِّرَ خَلْقَكُم.</p><p><span class="qpc-hafs">﴿فِي مَا لَا تَعۡلَمُونَ﴾</span>: مِنَ الصِّفاتِ والأحْوال.</p></div>"
  56,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّشۡأَةَ ٱلۡأُولَىٰ﴾</span>: خَلْقَ اللهِ إياكُم ولَمْ تكُونُوا شَيئًا مَذْكُورًا.</p></div>"
  56,63,""
  56,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَزۡرَعُونَهُۥٓ﴾</span>: تُنْبِتُونَهُ.</p></div>"
  56,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُطَـٰمࣰا﴾</span>: يابِسًا هَشِيمًا لا يُنْتَفعُ بِهِ.</p><p><span class="qpc-hafs">﴿فَظَلۡتُمۡ﴾</span>: فصِرْتُمْ.</p><p><span class="qpc-hafs">﴿تَفَكَّهُونَ﴾</span>: تَعْجَبُونَ مِن يُبْسِهِ بَعْدَ خُضْرَتِهِ.</p></div>"
  56,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّا لَمُغۡرَمُونَ﴾</span>: لَمُلْزَمُونَ غَرامَةَ ما أنْفَقْنا.</p></div>"
  56,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَحۡرُومُونَ﴾</span>: من الرِّزقِ.</p></div>"
  56,68,""
  56,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُزۡنِ﴾</span>: السَّحابِ.</p></div>"
  56,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُجَاجࣰا﴾</span>: شَدِيدَ المُلُوحَةِ.</p></div>"
  56,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُورُونَ﴾</span>: تُوقِدُونَ.</p></div>"
  56,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرَتَهَآ﴾</span>: الَّتِي تُقْدَحُ مِنها النّارُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنشِـُٔونَ﴾</span>: الخالِقُونَ.</p></div>"
  56,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَذۡكِرَةࣰ﴾</span>: تَذْكِيرًا لَكُم بِنارِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿وَمَتَـٰعࣰا﴾</span>: ومَنفَعَةً.</p><p><span class="qpc-hafs">﴿لِّلۡمُقۡوِينَ﴾</span>: لِلْمُسافِريِنَ.</p></div>"
  56,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَبِّحۡ﴾</span>: فنَزِّهْ.</p></div>"
  56,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ﴾</span>: بِمَساقِطِ النُّجُومِ في مَغارِبِها في السَّماءِ.</p></div>"
  56,76,""