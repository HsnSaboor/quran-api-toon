quran[12]{c,v,t}:
  25,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡأَنۡعَـٰمِ﴾</span>: كالبَهائِمِ لا يَفْهَمُونَ.</p></div>"
  25,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَدَّ ٱلظِّلَّ﴾</span>: بَسَطَه مِن طُلُوعِ الفَجْرِ إلى طُلُوعِ الشَّمسِ.</p><p><span class="qpc-hafs">﴿سَاكِنࣰا﴾</span>: ثابِتًا، لا تُزِيلُهُ الشَّمْسُ.</p><p><span class="qpc-hafs">﴿دَلِيلࣰا﴾</span>: أي: يُسْتَدَلُّ بأحْوالِ الشَّمسِ على أحْوالِ الظِّلِّ.</p></div>"
  25,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَبۡضࣰا يَسِيرࣰا﴾</span>: أي: يَتَقَلَّصُ الظِّلُّ تَدْرِيجيًّا بِقَدْرِ ارْتِفاعِ الشَّمسِ.</p></div>"
  25,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِبَاسࣰا﴾</span>: ساتِرًا بِظَلامِهِ.</p><p><span class="qpc-hafs">﴿سُبَاتࣰا﴾</span>: راحَةً لَكُم.</p><p><span class="qpc-hafs">﴿نُشُورࣰا﴾</span>: تَنْتَشِرُونَ فِيهِ لمَعاشِكُم.</p></div>"
  25,48,"<div class=ar lang=ar></div>"
  25,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡعَـٰمࣰا﴾</span>: بَهائِمَ.</p><p><span class="qpc-hafs">﴿وَأَنَاسِيَّ﴾</span>: أُناسًا.</p></div>"
  25,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرَّفۡنَـٰهُ بَيۡنَهُمۡ﴾</span>: أنْزَلْنا المَطَرَ على أنْحاءٍ مُخْتَلِفَةٍ.</p><p><span class="qpc-hafs">﴿كُفُورࣰا﴾</span>: جُحُودًا بالنِّعمَةِ.</p></div>"
  25,51,"<div class=ar lang=ar></div>"
  25,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَـٰهِدۡهُم بِهِۦ﴾</span>: وجاهِدِ الكُفّارَ بالقُرآنِ والبُرْهانِ.</p></div>"
  25,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرَجَ﴾</span>: خَلَطَ وأرْسَلَ.</p><p><span class="qpc-hafs">﴿عَذۡبࣱ فُرَاتࣱ﴾</span>: حُلْوٌ شَدِيدُ الحَلاوَةِ.</p><p><span class="qpc-hafs">﴿أُجَاجࣱ﴾</span>: شَدِيدُ المُلُوحَةِ.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمَا بَرۡزَخࣰا﴾</span>: حاجِزًا بين البَحْرَينِ يَمْنَعُ اخْتِلاطَ أحَدِهِما بالآخَر.</p><p><span class="qpc-hafs">﴿وَحِجۡرࣰا مَّحۡجُورࣰا﴾</span>: أي: مانِعًا حَصِينًا.</p></div>"
  25,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَآءِ﴾</span>: هو مَنِيُّ الرَّجلِ والمرْأةِ.</p><p><span class="qpc-hafs">﴿وَصِهۡرࣰا﴾</span>: القَرابَةَ النّاشِئَةَ مِنَ الزَّواجِ بَيْنَ الزَّوْجِ وأهْلِ زَوْجتِهِ.</p></div>"
  25,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ رَبِّهِۦ ظَهِيرࣰا﴾</span>: مُعِينًا للشَّيطانِ على رَبِّه.</p></div>"