quran[29]{c,v,t}:
  91,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضُحَىٰهَا﴾</span>: أقْسَمَ اللهُ بإشْراقِ الشَّمْسِ ضُحىً.</p></div>"
  91,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَلَىٰهَا﴾</span>: تَبِعَها في الطُّلُوعِ والأُفُول.</p></div>"
  91,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَلَّىٰهَا﴾</span>: جَلّى الظُّلْمةَ وكَشَفَها.</p></div>"
  91,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغۡشَىٰهَا﴾</span>: يُغَطِّي الأَرْضَ فيكُونُ ما عَلَيها مُظْلِمًا.</p></div>"
  91,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا بَنَىٰهَا﴾</span>: وبِنائِها المُحْكَمِ.</p></div>"
  91,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا طَحَىٰهَا﴾</span>: وبَسْطِها.</p></div>"
  91,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا سَوَّىٰهَا﴾</span>: وإكْمالِ اللهِ خَلْقَها لأداءِ مُهِمَّتِها.</p></div>"
  91,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَلۡهَمَهَا﴾</span>: فَبيَّنَ لَها.</p><p><span class="qpc-hafs">﴿فُجُورَهَا﴾</span>: طَرِيقَ الشَّرِّ.</p><p><span class="qpc-hafs">﴿وَتَقۡوَىٰهَا﴾</span>: وطَرِيقَ الخيرِ.</p></div>"
  91,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡلَحَ﴾</span>: فاز.</p><p><span class="qpc-hafs">﴿زَكَّىٰهَا﴾</span>: طَهَّرَها، ونَمّاها بالخيرِ.</p></div>"
  91,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَابَ﴾</span>: خَسِرَ.</p><p><span class="qpc-hafs">﴿دَسَّىٰهَا﴾</span>: أخْفى نَفْسَهُ في المعاصِي.</p></div>"
  91,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِطَغۡوَىٰهَآ﴾</span>: بِبُلُوغِها الغايةَ في العِصْيانِ.</p></div>"
  91,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنۢبَعَثَ﴾</span>: نَهَضَ لِعَقْرِ النّاقةِ.</p><p><span class="qpc-hafs">﴿أَشۡقَىٰهَا﴾</span>: أكْثَرُ القبيلةِ شَقاوَةً.</p></div>"
  91,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَاقَةَ ٱللَّهِ﴾</span>: احْذَرُوا أن تَمَسُّوا النّاقَةَ بسُوءٍ.</p><p><span class="qpc-hafs">﴿وَسُقۡيَـٰهَا﴾</span>: واحذَرُوا أن تَعْتَدُوا على سَقْيِها.</p></div>"
  91,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُوهَا﴾</span>: فَنَحَرُوها.</p><p><span class="qpc-hafs">﴿فَدَمۡدَمَ عَلَيۡهِمۡ﴾</span>: فَأَطْبَقَ عليهِم العُقُوبةَ.</p><p><span class="qpc-hafs">﴿فَسَوَّىٰهَا﴾</span>: فَجَعَلَها عَلَيهِم على السَّواءِ، فلم يُفْلِتْ مِنهُم أحَدٌ.</p></div>"
  91,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُقۡبَـٰهَا﴾</span>: تَبِعةَ ما أنزَلَهُ بِهِم مِنَ العِقابِ.</p></div>"
  92,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغۡشَىٰ﴾</span>: يُغَطِّي بِظلامِهِ الأَرْضَ وما عَلَيها.</p></div>"
  92,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَجَلَّىٰ﴾</span>: انكَشَفَ عَن ظَلام الليلِ بضِيائِهِ.</p></div>"
  92,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا خَلَقَ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ﴾</span>: أقْسَمَ اللهُ بِخَلْقِ الزَّوجِينِ.</p></div>"
  92,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ سَعۡيَكُمۡ لَشَتَّىٰ﴾</span>: عَمَلَكُم لَمُخْتَلِفٌ بَينَ عامِلٍ للدُّنيا وعامِلٍ للآخِرَةِ.</p></div>"
  92,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡطَىٰ﴾</span>: بَذَلَ مِن مّالِهِ.</p></div>"
  92,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحُسۡنَىٰ﴾</span>: ب «لا إلَه إلا اللهُ» وما دَلَّتْ عَلَيهِ، وما تَرتَّبَ عَلَيها مِنَ الجَزاءِ.</p></div>"
  92,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَنُيَسِّرُهُۥ﴾</span>: فَسَنُوَفِّقُهُ.</p><p><span class="qpc-hafs">﴿لِلۡيُسۡرَىٰ﴾</span>: لِعَمَلِ الخيرِ والشَّرِيعةِ السَّهْلَةِ.</p></div>"
  92,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَخِلَ﴾</span>: بِمالِهِ.</p><p><span class="qpc-hafs">﴿وَٱسۡتَغۡنَىٰ﴾</span>: عَن جزاءِ اللهِ.</p></div>"
  92,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحُسۡنَىٰ﴾</span>: بِالعِوَضِ مِنَ اللهِ.</p></div>"
  92,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَنُيَسِّرُهُۥ﴾</span>: فسَنُهَيُّئهُ في الدُّنيا.</p><p><span class="qpc-hafs">﴿لِلۡعُسۡرَىٰ﴾</span>: للْخَصْلَةِ العُسْرى، فَتَتَعَسَّرُ عَلَيه أسبابُ الخيرِ.</p></div>"
  92,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُغۡنِي عَنۡهُ﴾</span>: ولا يَنفَعُهُ.</p><p><span class="qpc-hafs">﴿تَرَدَّىٰٓ﴾</span>: وقَعَ في النّارِ.</p></div>"
  92,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَلۡهُدَىٰ﴾</span>: بيانَ طَرِيقِ الهُدى المُوصِلِ إلى اللهِ.</p></div>"
  92,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّ لَنَا لَلۡـَٔاخِرَةَ﴾</span>: وإنَّ لَنا مُلْكَ الحياةِ الآخِرَةِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأُولَىٰ﴾</span>: والحياةَ الدُّنيا.</p></div>"
  92,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنذَرۡتُكُمۡ﴾</span>: فَحَذَّرْتُكُم.</p><p><span class="qpc-hafs">﴿نَارࣰا تَلَظَّىٰ﴾</span>: نارًا تَتَوهَّجُ، وهي نارُ جَهَنَّمَ.</p></div>"