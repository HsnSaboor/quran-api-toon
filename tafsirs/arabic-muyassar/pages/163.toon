quran[9]{c,v,t}:
  7,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱتَّقَوۡاْ﴾</span>: واجتَنَبُوا ما نهاهم اللهُ عنه.</p><p><span class="qpc-hafs">﴿بَرَكَـٰتࣲ مِّنَ ٱلسَّمَآءِ وَٱلۡأَرۡضِ﴾</span>: ما يتتابعُ عليهم من الخير من كلِّ وجْهٍ.</p></div>"
  7,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَأۡسُنَا﴾</span>: عذابُ اللهِ.</p><p><span class="qpc-hafs">﴿بَيَـٰتࣰا﴾</span>: ليلًا.</p></div>"
  7,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلۡعَبُونَ﴾</span>: يشتغلون بما لا يعودُ عليهم بفائدةٍ.</p></div>"
  7,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَكۡرَ ٱللَّهِ﴾</span>: استدراجَه للمكذِّبين بما أنعمَ به عليهم، وعقوبتَهم.</p></div>"
  7,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِ﴾</span>: يتبيَّنْ.</p><p><span class="qpc-hafs">﴿يَرِثُونَ ٱلۡأَرۡضَ﴾</span>: بالسُّكنى.</p><p><span class="qpc-hafs">﴿مِنۢ بَعۡدِ أَهۡلِهَآ﴾</span>: من بعدِ إهلاكِ أهلِها السابقين.</p><p><span class="qpc-hafs">﴿وَنَطۡبَعُ﴾</span>: ونَخْتِمُ.</p><p><span class="qpc-hafs">﴿لَا يَسۡمَعُونَ﴾</span>: الموعظةَ سماعَ منتفعٍ بها.</p></div>"
  7,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَقُصُّ﴾</span>: نَذْكُرُ.</p><p><span class="qpc-hafs">﴿أَنۢبَآئِهَا﴾</span>: أخبارِها.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالحُجَجِ الظاهرةِ الدالَّةِ على صِدْقِهم.</p><p><span class="qpc-hafs">﴿ٱلۡكَـٰفِرِينَ﴾</span>: الذين كَتَبَ اللهُ عليهم ألّا يُؤمنوا.</p></div>"
  7,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡ عَهۡدࣲ﴾</span>: مِن وفاءٍ بما وصّاهم اللهُ به.</p><p><span class="qpc-hafs">﴿لَفَـٰسِقِينَ﴾</span>: لخارجينَ عن طاعةِ اللهِ وامتثالِ أمرِه.</p></div>"
  7,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَآ﴾</span>: بالمعجزاتِ الظاهرةِ الدالَّةِ على صِدْقِه.</p><p><span class="qpc-hafs">﴿فِرۡعَوۡنَ﴾</span>: لَقَبٌ لكلِّ مَن مَلَك مِصْرَ في القديم.</p><p><span class="qpc-hafs">﴿فَظَلَمُواْ بِهَا﴾</span>: فَجحَدُوا وكَفَروا بها.</p></div>"
  7,104,""