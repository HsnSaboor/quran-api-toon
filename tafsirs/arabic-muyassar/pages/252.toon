quran[10]{c,v,t}:
  13,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعۡمَىٰٓ﴾</span>: لا يُبْصِرُ الحَقَّ ولا يَتَّبِعُه.</p><p><span class="qpc-hafs">﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾</span>: أصحابُ العقولِ السليمةِ.</p></div>"
  13,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِعَهۡدِ ٱللَّهِ﴾</span>: ما أمَرَ اللهُ به.</p><p><span class="qpc-hafs">﴿ٱلۡمِيثَـٰقَ﴾</span>: العهدَ المؤكَّدَ الذي عاهدُوا اللهَ عليه.</p></div>"
  13,21,""
  13,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتِغَآءَ وَجۡهِ رَبِّهِمۡ﴾</span>: طَلَبًا لرِضاه.</p><p><span class="qpc-hafs">﴿وَيَدۡرَءُونَ﴾</span>: يَدْفَعُون، أو يُتْبِعُونَ.</p><p><span class="qpc-hafs">﴿عُقۡبَى ٱلدَّارِ﴾</span>: العاقبةُ المحمودةُ في الآخرةِ.</p></div>"
  13,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: دارُ إقامةٍ خالدين فيها.</p></div>"
  13,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلَـٰمٌ عَلَيۡكُم﴾</span>: تحيةٌ خاصةٌ بكم، وسَلِمْتُم من كلِّ سوءٍ.</p></div>"
  13,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّعۡنَةُ﴾</span>: الطَّرْدُ من رحمةِ اللهِ.</p><p><span class="qpc-hafs">﴿سُوٓءُ ٱلدَّارِ﴾</span>: العاقبةُ السيئةُ في الآخرةِ، وهي النارُ.</p></div>"
  13,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: يُضَيِّق الرزقَ على مَن يشاءُ؛ لحكمةٍ.</p><p><span class="qpc-hafs">﴿وَفَرِحُواْ﴾</span>: أي: الكفارُ، فَرَحَ طُغْيانٍ وبَطَرٍ.</p><p><span class="qpc-hafs">﴿مَتَـٰعࣱ﴾</span>: شيءٌ قليلٌ يُتَمَتَّعُ به، سريعُ الزَّوالِ.</p></div>"
  13,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَآ﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: مُعْجِزَةٌ محسوسةٌ، كناقةِ صالحٍ.</p><p><span class="qpc-hafs">﴿وَيَهۡدِيٓ﴾</span>: يُرْشِدُ ويُوَفِّقُ.</p><p><span class="qpc-hafs">﴿مَنۡ أَنَابَ﴾</span>: الذي رَجَعَ إلى اللهِ وطَلَبَ رِضْوانَه.</p></div>"
  13,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَطۡمَئِنُّ﴾</span>: تَسْكُنُ وتستأنِسُ.</p></div>"