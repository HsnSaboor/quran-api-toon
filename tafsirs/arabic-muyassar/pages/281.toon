quran[10]{c,v,t}:
  16,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسُّوٓءَ﴾</span>: الذُّنوبَ والمعاصِيَ.</p><p><span class="qpc-hafs">﴿بِجَهَـٰلَةࣲ﴾</span>: بِجَهْلٍ منهم لعاقبتِها وإيجابِها سَخَطَ اللهِ.</p><p><span class="qpc-hafs">﴿وَأَصۡلَحُوٓاْ﴾</span>: استقامُوا بعد تَوْبَتِهم.</p></div>"
  16,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّةࣰ﴾</span>: إمامًا قُدْوةً جامعًا لخِصالِ الخيرِ.</p><p><span class="qpc-hafs">﴿قَانِتࣰا لِّلَّهِ﴾</span>: مُطيعًا خاضِعًا له.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن الأديانِ الباطلةِ إلى الدِّينِ الحقِ.</p></div>"
  16,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱجۡتَبَىٰهُ﴾</span>: اختاره اللهُ لرسالتِه.</p><p><span class="qpc-hafs">﴿وَهَدَىٰهُ﴾</span>: أرْشَدَه ووَفَّقه.</p></div>"
  16,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣰ﴾</span>: نِعْمةً حسنةً، كالثَّناءِ الجميلِ عليه إلى يومِ القيامة، والاقتداءِ به.</p></div>"
  16,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِلَّةَ إِبۡرَ ٰ⁠هِيمَ﴾</span>: شريعتَه، وهي الإسلامُ.</p></div>"
  16,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُعِلَ ٱلسَّبۡتُ﴾</span>: فُرِضَ تَعْظِيمُه والتفرُّغُ للعبادةِ فيه.</p><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱخۡتَلَفُواْ فِيهِ﴾</span>: هم اليهودُ، حيث أمَرَهم نبيُّهم بتعظيمِ يومِ الجُمُعَةِ، فاختاروا السَّبْتَ.</p></div>"
  16,125,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡحِكۡمَةِ﴾</span>: بالطريقةِ الحَكِيمةِ وفْقَ شَرْعِ اللهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَوۡعِظَةِ ٱلۡحَسَنَةِ﴾</span>: بالتذكيرِ المناسِبِ للأشخاصِ والأحوالِ.</p></div>"
  16,126,""
  16,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡقࣲ﴾</span>: حَرَجٍ وغَمٍّ.</p></div>"
  16,128,""