quran[15]{c,v,t}:
  15,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِضِينَ﴾</span>: أجزاءً وأقسامًا؛ ليوافِقَ أهواءَهم.</p></div>"
  15,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَسۡـَٔلَنَّهُمۡ﴾</span>: سُؤالَ توبيخٍ، فلَنُحاسِبَنَّهم ولَنَجْزِيَنَّهم.</p></div>"
  15,93,"<div class=ar lang=ar></div>"
  15,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱصۡدَعۡ بِمَا تُؤۡمَرُ﴾</span>: اجهَرْ بدعوةِ الحقِّ وأظْهِرْها.</p></div>"
  15,95,"<div class=ar lang=ar></div>"
  15,96,"15:95"
  15,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَضِيقُ صَدۡرُكَ﴾</span>: يَنْقَبِضُ ألمًا وحُزْنًا.</p></div>"
  15,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّـٰجِدِينَ﴾</span>: المُصَلِّين العابِدين.</p></div>"
  15,99,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡيَقِينُ﴾</span>: الموتُ، المتيقَّنُ حُدوثُه.</p></div>"
  16,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَتَىٰٓ﴾</span>: قَرُبَ ودَنا.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: عقابُه للمُشْركين، أو القيامةُ.</p><p><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ﴾</span>: تنزيهًا لله.</p></div>"
  16,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلرُّوحِ﴾</span>: بالوَحْي؛ الذي فيه الحياةُ التامَّةُ.</p><p><span class="qpc-hafs">﴿مِنۡ عِبَادِهِۦٓ﴾</span>: الذين اختصَّهم بالرسالة.</p><p><span class="qpc-hafs">﴿أَنذِرُوٓاْ﴾</span>: خَوِّفُوا.</p></div>"
  16,3,"<div class=ar lang=ar></div>"
  16,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّطۡفَةࣲ﴾</span>: ماءِ الحياةِ، وهو المَنِيُّ.</p><p><span class="qpc-hafs">﴿خَصِيمࣱ﴾</span>: شديدُ الخصومةِ والمجادَلةِ.</p><p><span class="qpc-hafs">﴿مُّبِينࣱ﴾</span>: بيِّنُ الخُصومةِ واضحُها.</p></div>"
  16,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡأَنۡعَـٰمَ﴾</span>: هي الإبِلُ والبَقَرُ والغنم.</p><p><span class="qpc-hafs">﴿دِفۡءࣱ﴾</span>: ما تَسْتَدْفِئُون به مِن صوفِها ووَبَرِها وشَعْرِها.</p></div>"
  16,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمَالٌ﴾</span>: زينةٌ تَسُرُّكم.</p><p><span class="qpc-hafs">﴿تُرِيحُونَ﴾</span>: تَرُدُّونها في المساء إلى حَظائرِها.</p><p><span class="qpc-hafs">﴿تَسۡرَحُونَ﴾</span>: تُخْرِجُونها في الصَّباح إلى مَراعِيها.</p></div>"