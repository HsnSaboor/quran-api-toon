quran[8]{c,v,t}:
  16,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُخۡزِيهِمۡ﴾</span>: يُذِلُّهم اللهُ ويُهينُهم بالعذابِ.</p><p><span class="qpc-hafs">﴿شُرَكَآءِيَ﴾</span>: الآلهةُ التي عَبَدْتُموها من دوني.</p><p><span class="qpc-hafs">﴿تُشَـٰٓقُّونَ فِيهِمۡ﴾</span>: تُخاصِمُون وتُعادُون الأنبياءَ وأتباعَهم في شأنهم.</p><p><span class="qpc-hafs">﴿ٱلۡخِزۡيَ﴾</span>: الذُّلَّ والهَوانَ.</p><p><span class="qpc-hafs">﴿وَٱلسُّوٓءَ﴾</span>: العذابَ.</p></div>"
  16,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰٓئِكَةُ﴾</span>: تَقْبِضُ أرواحَهم.</p><p><span class="qpc-hafs">﴿فَأَلۡقَوُاْ ٱلسَّلَمَ﴾</span>: استَسْلَمُوا لأمرِ اللهِ حين رَأَوا الموتَ.</p></div>"
  16,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوَى ٱلۡمُتَكَبِّرِينَ﴾</span>: مَأْواهم ومَقَرُّهم.</p></div>"
  16,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣱ﴾</span>: مَكْرُمَةٌ من اللهِ بالعيشِ الهنيءِ والرِّزقِ الواسعِ.</p></div>"
  16,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: جناتُ إقامةٍ.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: من تحتِ قُصورِها وأشجارِها.</p></div>"
  16,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَيِّبِينَ﴾</span>: طاهِرين زاكِيَةً أفعالُهم وأقوالُهم.</p><p><span class="qpc-hafs">﴿سَلَـٰمٌ عَلَيۡكُمُ﴾</span>: تحيةٌ خاصةٌ بكم، وسَلِمْتُم من كلِّ آفةٍ.</p></div>"
  16,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ يَنظُرُونَ﴾</span>: ما ينتظِرُ الكفارُ.</p><p><span class="qpc-hafs">﴿تَأۡتِيَهُمُ ٱلۡمَلَـٰٓئِكَةُ﴾</span>: لقَبْضِ أرواحِهم.</p><p><span class="qpc-hafs">﴿أَمۡرُ رَبِّكَ﴾</span>: عذابُ الاستئصالِ في الدنيا، أو القيامةُ التي فيها عذابُهم.</p></div>"
  16,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَاقَ﴾</span>: نَزَلَ وأحاطَ.</p></div>"