quran[21]{c,v,t}:
  54,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُشَّعًا﴾</span>: ذَلِيلَةً.</p><p><span class="qpc-hafs">﴿ٱلۡأَجۡدَاثِ﴾</span>: القُبُورِ.</p><p><span class="qpc-hafs">﴿مُّنتَشِرࣱ﴾</span>: مُنْبَثٌّ عَلى وجْهِ الأرْضِ.</p></div>"
  54,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّهۡطِعِينَ﴾</span>: مُسْرِعِينَ مادِّينَ أعْناقَهُم.</p><p><span class="qpc-hafs">﴿ٱلدَّاعِ﴾</span>: صوتِ المَلَكِ.</p><p><span class="qpc-hafs">﴿عَسِرࣱ﴾</span>: شَدِيدُ الهَوْلِ.</p></div>"
  54,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱزۡدُجِرَ﴾</span>: وانْتَهَرُوهُ مُتَوَعِّدِينَ إيّاهُ بأنْواعِ الأَذى.</p></div>"
  54,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡلُوبࣱ﴾</span>: ضَعِيفٌ عَن مُقاوَمةِ هَؤُلاءِ.</p><p><span class="qpc-hafs">﴿فَٱنتَصِرۡ﴾</span>: لِي بِعِقابٍ مِن عِنْدِكَ.</p></div>"
  54,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّنۡهَمِرࣲ﴾</span>: كَثِيرٍ مُتَدَفِّقٍ.</p></div>"
  54,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَفَجَّرۡنَا﴾</span>: وشَقَقْنا.</p><p><span class="qpc-hafs">﴿عُيُونࣰا﴾</span>: مِن عُيُونٍ مُتَفَجِّرَةٍ بالماءِ.</p><p><span class="qpc-hafs">﴿فَٱلۡتَقَى ٱلۡمَآءُ﴾</span>: فالتَقى ماءُ السَّماءِ وماءُ الأرْضِ.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ أَمۡرࣲ قَدۡ قُدِرَ﴾</span>: عَلى إهْلاكِهِم الَّذِي قَدَّرَهُ اللهُ لَهُم.</p></div>"
  54,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَاتِ أَلۡوَ ٰ⁠حࣲ﴾</span>: سَفِيَنةٍ ذاتِ ألْواحٍ.</p><p><span class="qpc-hafs">﴿وَدُسُرࣲ﴾</span>: ومَسامِيرَ شُدَّتْ بِها.</p></div>"
  54,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَعۡيُنِنَا﴾</span>: بِمَرْأىً مِنّا وحِفْظٍ.</p></div>"
  54,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَد تَّرَكۡنَـٰهَآ﴾</span>: ولَقَدْ أبْقَينا قِصَّةَ نُوحٍ.</p><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: عِبْرةً.</p><p><span class="qpc-hafs">﴿مُّدَّكِرࣲ﴾</span>: مُتَّعِظٍ.</p></div>"
  54,16,""
  54,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسَّرۡنَا﴾</span>: سَهَّلْنا.</p><p><span class="qpc-hafs">﴿لِلذِّكۡرِ﴾</span>: لِلتِّلاوَةِ والحِفْظِ والفَهْمِ والتَّدَبُّرِ.</p></div>"
  54,18,""
  54,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡصَرࣰا﴾</span>: شَدِيدَةَ البَرْدِ والصَّوتِ.</p><p><span class="qpc-hafs">﴿نَحۡسࣲ﴾</span>: شُؤْمٍ.</p><p><span class="qpc-hafs">﴿مُّسۡتَمِرࣲّ﴾</span>: اسْتَمَرَّ بِهِمُ العَذابُ إلى أن وافى بِهِمْ جَهَنَّمَ.</p></div>"
  54,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنزِعُ ٱلنَّاسَ﴾</span>: تَقَلَعُ النّاسَ مِنَ الأرْضِ، فتَصْرَعُهم عَلى رُؤوسِهِم، فَتَنْدَقُّ رِقابُهُم وتَنْفَصِلُ عَنْ أجْسامِهِم.</p><p><span class="qpc-hafs">﴿أَعۡجَازُ﴾</span>: أُصُولُ.</p><p><span class="qpc-hafs">﴿مُّنقَعِرࣲ﴾</span>: مُنْقَلِعٍ.</p></div>"
  54,21,""
  54,22,""
  54,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلنُّذُرِ﴾</span>: بالآياتِ الَّتِي أُنْذِرُوا بِها.</p></div>"
  54,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ﴾</span>: بُعْدٍ عَنِ الصَّوابِ.</p><p><span class="qpc-hafs">﴿وَسُعُرٍ﴾</span>: جُنُونٍ.</p></div>"
  54,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَءُلۡقِيَ﴾</span>: أأُنْزِلَ.</p><p><span class="qpc-hafs">﴿ٱلذِّكۡرُ﴾</span>: الوَحْيُ والقُرآنُ.</p><p><span class="qpc-hafs">﴿أَشِرࣱ﴾</span>: صاحِبُ بَطَرٍ وتَكَبُّرٍ.</p></div>"
  54,26,""
  54,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُرۡسِلُواْ﴾</span>: مُخْرِجُو.</p><p><span class="qpc-hafs">﴿فَٱرۡتَقِبۡهُمۡ﴾</span>: اخْتِبارًا.</p><p><span class="qpc-hafs">﴿فَٱرۡتَقِبۡهُمۡ﴾</span>: فانْتَظِرْ ما يَحُلُّ عَلَيهِم مِنَ العَذابِ.</p><p><span class="qpc-hafs">﴿وَٱصۡطَبِر﴾</span>: واصْبِرْ عَلى الأَذى الَّذِي يُصِيبُكَ مِنَ المدْعُوِّينَ.</p></div>"