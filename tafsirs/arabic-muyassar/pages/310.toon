quran[12]{c,v,t}:
  19,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡطَبِرۡ لِعِبَـٰدَتِهِۦ﴾</span>: واثْبُتْ عَلى طاعةِ الله بِصَبْرٍ ومُواظَبَةٍ.</p><p><span class="qpc-hafs">﴿سَمِيࣰّا﴾</span>: مُماثِلًا في ذاتِه وأَسْمائِه وصِفاتِه وأفعالِه.</p></div>"
  19,66,""
  19,67,""
  19,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَحۡشُرَنَّهُمۡ﴾</span>: لَنَجْمَعَنَّ هَؤلاءِ المُنْكِرِينَ لِلبَعْثِ يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿جِثِيࣰّا﴾</span>: بارِكِينَ على رُكَبِهِم.</p></div>"
  19,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ لَنَنزِعَنَّ﴾</span>: ثم لَنَأخُذَنَّ.</p><p><span class="qpc-hafs">﴿شِيعَةٍ﴾</span>: طائِفَةٍ.</p><p><span class="qpc-hafs">﴿عِتِيࣰّا﴾</span>: تَمرُّدًا وعِصْيانًا للهِ تَعالى.</p></div>"
  19,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُمۡ أَوۡلَىٰ بِهَا صِلِيࣰّا﴾</span>: هُم أوْلى بجَهَنَّمَ دُخُولًا.</p></div>"
  19,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا وَارِدُهَا﴾</span>: إلّا واردٌ النارَ بالمُرُورِ على الصِّراطِ المنْصُوبِ على مَتْنِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿حَتۡمࣰا مَّقۡضِيࣰّا﴾</span>: أمْرًا مَحْتُومًا قُضِيَ وحُكِمَ أنّه لابُدَّ مِن وُقُوعِه.</p></div>"
  19,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَّنَذَرُ﴾</span>: ونَتْرُكُ.</p></div>"
  19,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَيۡرࣱ مَّقَامࣰا﴾</span>: أفْضَلُ مَنزِلًا.</p><p><span class="qpc-hafs">﴿وَأَحۡسَنُ نَدِيࣰّا﴾</span>: وأَحْسَنُ مَجْلِسًا.</p></div>"
  19,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قَرۡنٍ﴾</span>: مِن أُمَمٍ.</p><p><span class="qpc-hafs">﴿هُمۡ أَحۡسَنُ أَثَـٰثࣰا وَرِءۡيࣰا﴾</span>: أحْسنُ مَتاعًا مِنهُم، وأَجْمَلُ مَنظَرًا.</p></div>"
  19,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَمۡدُدۡ﴾</span>: فَلْيُمْهِلْهُ اسْتِدْراجًا.</p><p><span class="qpc-hafs">﴿هُوَ شَرࣱّ مَّكَانࣰا﴾</span>: شرٌّ مَسْكَنًا ومُسْتَقَرًّا.</p><p><span class="qpc-hafs">﴿وَأَضۡعَفُ جُندࣰا﴾</span>: وأَضْعَفُ قوةً ورِجالًا.</p></div>"
  19,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡبَـٰقِيَـٰتُ ٱلصَّـٰلِحَـٰتُ﴾</span>: أعمالُ الخيرِ.</p><p><span class="qpc-hafs">﴿وَخَيۡرࣱ مَّرَدًّا﴾</span>: وخيرٌ مَرْجِعًا وعاقِبَةً.</p></div>"