quran[5]{c,v,t}:
  9,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِرَارࣰا﴾</span>: لأجل الضَّرَر بِالمؤمنين.</p><p><span class="qpc-hafs">﴿وَإِرۡصَادࣰا﴾</span>: انتظارًا وإعدادًا.</p><p><span class="qpc-hafs">﴿لِّمَنۡ حَارَبَ ٱللَّهَ وَرَسُولَهُۥ﴾</span>: هو أبو عامرٍ الفاسقُ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: أي: من قَبْلِ بناءِ مسجدِ الضِّرارِ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الخيرَ والإحسانَ إلى المسلمين.</p></div>"
  9,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَقُمۡ فِيهِ﴾</span>: أي للصَّلاةِ في مَسْجدِ الضِّرارِ.</p><p><span class="qpc-hafs">﴿لَّمَسۡجِدٌ أُسِّسَ عَلَى ٱلتَّقۡوَىٰ﴾</span>: هو مَسْجدُ قُباءٍ.</p><p><span class="qpc-hafs">﴿يُحِبُّونَ أَن يَتَطَهَّرُواْ﴾</span>: طهارةً حسِّيةً من النجاساتِ، ومعنويةً من الذُّنوبِ والمعاصي.</p></div>"
  9,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرِضۡوَ ٰ⁠نٍ﴾</span>: ورجاءِ مَرْضاةِ اللهِ.</p><p><span class="qpc-hafs">﴿عَلَىٰ شَفَا جُرُفٍ﴾</span>: على طَرَفِ حُفْرَةٍ، أو مكانٍ يَجْرُفُه الماءُ.</p><p><span class="qpc-hafs">﴿هَارࣲ﴾</span>: مُشْرِفٍ على السُّقوط.</p><p><span class="qpc-hafs">﴿فَٱنۡهَارَ بِهِۦ﴾</span>: فسَقَطَ المكانُ بالبُنيانِ مع بانيه.</p><p><span class="qpc-hafs">﴿لَا يَهۡدِي﴾</span>: لا يُوَفِّقُ.</p></div>"
  9,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُنۡيَـٰنُهُمُ﴾</span>: مسجدُ الضِّرارِ.</p><p><span class="qpc-hafs">﴿رِيبَةࣰ فِي قُلُوبِهِمۡ﴾</span>: شَكًّا ونفاقًا راسخًا في قلوبِهم.</p><p><span class="qpc-hafs">﴿تَقَطَّعَ قُلُوبُهُمۡ﴾</span>: تتقَطَّعَ قلوبُهم بَمْوتِهم، فالنِّفاقُ ملازمٌ لهم ماداموا أحياءً.</p></div>"
  9,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسۡتَبۡشِرُواْ﴾</span>: أظْهِرُوا السُّرورَ.</p></div>"