quran[15]{c,v,t}:
  112,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ ٱللَّهُ أَحَدٌ﴾</span>: هُو اللهُ المتفرِّدُ بالأُلُوهِيَّةِ والرُّبُوبِيَّةِ والأسْماءِ والصِّفاتِ، لا يُشارِكُه أحَدٌ فِيها.</p></div>"
  112,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّهُ ٱلصَّمَدُ﴾</span>: اللهُ وحْدَهُ السَّيِّدُ الكاملُ الصفات، المَقْصُودُ في قَضاءِ الحوائِجِ.</p></div>"
  112,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ﴾</span>: لَيسَ لَهُ ولَدٌ ولا والِدٌ ولا صاحِبَةٌ.</p></div>"
  112,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَمۡ يَكُن لَّهُۥ كُفُوًا أَحَدُۢ﴾</span>: ولَمْ يَكُن لَهُ مُماثِلًا ولا مشابهًا أحدٌ مِن خَلْقِهِ، لا في أسمائِهِ ولا في صِفاتِهِ، ولا في أفعالِهِ، تَبارك وتَعالى وتَقَدَّسَ.</p></div>"
  113,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعُوذُ بِرَبِّ ٱلۡفَلَقِ﴾</span>: أعْتَصِمُ بِرَبِّ الصُّبْحِ.</p></div>"
  113,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن شَرِّ مَا خَلَقَ﴾</span>: مِن شَرِّ جَمِيعِ المخلوقات وأذاها.</p></div>"
  113,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَاسِقٍ﴾</span>: لَيلٍ شَدِيدِ الظُّلْمَةِ.</p><p><span class="qpc-hafs">﴿إِذَا وَقَبَ﴾</span>: دَخَلَ ظَلامُهُ في كُلِّ شَيءٍ.</p></div>"
  113,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّفَّـٰثَـٰتِ فِي ٱلۡعُقَدِ﴾</span>: السّاحِراتِ اللاتِي يَنفُخْنَ فِيما يَعْقِدْنَ مِن عُقَدٍ بِقَصْدِ السِّحْرِ.</p></div>"
  113,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ﴾</span>: ومِن شَرِّ حاسِدٍ مُبْغِضٍ للنّاسِ، إذا حَسَدَهُم عَلى ما وهَبَهُم اللهُ مِنَ النِّعَمِ.</p></div>"
  114,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعُوذُ بِرَبِّ ٱلنَّاسِ﴾</span>: أعْتَصِمُ بِرَبِّ النّاسِ.</p></div>"
  114,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلِكِ ٱلنَّاسِ﴾</span>: المُتَصرِّفِ في كُلِّ شُؤُونِهِم، الغَنِيِّ عَنْهُم.</p></div>"
  114,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَـٰهِ ٱلنَّاسِ﴾</span>: الَّذِي لا مَعْبُودَ بِحَقٍّ سِواهُ.</p></div>"
  114,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن شَرِّ ٱلۡوَسۡوَاسِ﴾</span>: مِن أذى الشَّيطانِ الَّذِي يُوسْوِسُ عِنْدَ الغَفْلةِ.</p><p><span class="qpc-hafs">﴿ٱلۡخَنَّاسِ﴾</span>: الَّذِي يَخْتفِي عِنْدَ ذِكْرِ اللهِ.</p></div>"
  114,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ﴾</span>: يَبُثُّ الشَّرَّ والشُّكُوكَ في صُدُورِ النّاسِ.</p></div>"
  114,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ﴾</span>: مِن شياطِينِ الجِنِّ والإنْسِ.</p></div>"