quran[11]{c,v,t}:
  31,1,"<div class=ar lang=ar></div>"
  31,2,"31:1"
  31,3,"31:1"
  31,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡتُونَ﴾</span>: يُعْطُونَ.</p><p><span class="qpc-hafs">﴿يُوقِنُونَ﴾</span>: يُؤْمِنُونَ.</p></div>"
  31,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ.</p></div>"
  31,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهۡوَ ٱلۡحَدِيثِ﴾</span>: هُوَ كلُّ ما يُلْهِي عَن طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿بِغَيۡرِ عِلۡمࣲ﴾</span>: جَهْلًا بِعاقِبَةِ ذَلِكَ.</p><p><span class="qpc-hafs">﴿وَيَتَّخِذَهَا﴾</span>: ويَتَّخِذَ سَبيلَ اللهِ وآياتِ كِتابِه.</p><p><span class="qpc-hafs">﴿هُزُوًا﴾</span>: مُسْتهْزَأً بهِا.</p></div>"
  31,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَّىٰ﴾</span>: أعْرَضَ وأَدْبَرَ.</p><p><span class="qpc-hafs">﴿مُسۡتَكۡبِرࣰا﴾</span>: مُتَكبِّرًا.</p><p><span class="qpc-hafs">﴿وَقۡرࣰا﴾</span>: ثِقَلًا أو صَمَمًا فلا يَنْتَفِعُ بِما يَسْمَعُ.</p></div>"
  31,8,"<div class=ar lang=ar></div>"
  31,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقࣰّا﴾</span>: أي: وعْدًا حَقًّا ثابِتًا.</p></div>"
  31,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَمَدࣲ﴾</span>: دَعائِمَ، مُفْرَدُه عِمادٌ.</p><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: أي: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿أَن تَمِيدَ بِكُمۡ﴾</span>: أي: لِئلا تَتَحَرَّكَ الأرْضُ وتَضْطَرِبَ بِكم.</p><p><span class="qpc-hafs">﴿بَثَّ﴾</span>: نَشَر وفَرَّقَ.</p><p><span class="qpc-hafs">﴿زَوۡجࣲ كَرِيمٍ﴾</span>: صِنْفٍ حَسَنٍ كَثِيرِ المَنفَعَةِ.</p></div>"
  31,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينࣲ﴾</span>: عُدُولٍ واضِحٍ عَنِ الطَّرِيقِ المُسْتَقِيمِ.</p></div>"