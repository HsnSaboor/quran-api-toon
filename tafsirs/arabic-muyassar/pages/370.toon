quran[23]{c,v,t}:
  26,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَمۡعَانِ﴾</span>: جَمْعُ مُوسى وهُم بنُو إسْرائيلَ، وجَمْعُ فِرْعَونَ وهم القِبْطُ.</p><p><span class="qpc-hafs">﴿لَمُدۡرَكُونَ﴾</span>: لَمُلحَقُون من قِبَلِ فِرْعَونَ وجُنُودِهِ.</p></div>"
  26,62,""
  26,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱنفَلَقَ﴾</span>: أي: انْشَقَّ البَحْرُ إلى اثْنَي عَشْرَ طَرِيقًا.</p><p><span class="qpc-hafs">﴿فِرۡقࣲ﴾</span>: قِطْعةٍ من البحْرِ مُرْتَفِعَةٍ.</p><p><span class="qpc-hafs">﴿كَٱلطَّوۡدِ﴾</span>: كالجَبَلِ المُتَطاوِلِ في السَّماءِ.</p></div>"
  26,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَزۡلَفۡنَا﴾</span>: وقَرَّبْنا.</p><p><span class="qpc-hafs">﴿ثَمَّ﴾</span>: هُناك.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔاخَرِينَ﴾</span>: وهم فِرْعَونُ وقَوْمُه.</p></div>"
  26,65,""
  26,66,""
  26,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَـَٔايَةࣰ﴾</span>: لَعِبرةً عَجِيبةً.</p></div>"
  26,68,""
  26,69,""
  26,70,""
  26,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهَا عَـٰكِفِينَ﴾</span>: على عِبادتِها مُقِيمِينَ على الدَّوامِ.</p></div>"
  26,72,""
  26,73,""
  26,74,""
  26,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَرَءَيۡتُم﴾</span>: هَل تأمَّلْتُم ما أنْتُم عَلَيه؟</p></div>"
  26,76,""
  26,77,""
  26,78,""
  26,79,""
  26,80,""
  26,81,""
  26,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلدِّينِ﴾</span>: يومَ الجَزاءِ.</p></div>"
  26,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُكۡمࣰا﴾</span>: عِلْمًا وفَهْمًا.</p></div>"