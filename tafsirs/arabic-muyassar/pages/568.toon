tafsir[28]{c,v,t}:
69,35," <q>﴿هَـٰهُنَا﴾</q>: يَومَ القِيامةِ. <q>﴿حَمِيمࣱ﴾</q>: قَرِيبٌ يدفعُ عنَه العذابَ. "
69,36," <q>﴿غِسۡلِينࣲ﴾</q>: صَدِيدِ أهْلِ النّارِ وما يَسِيلُ مِن أجْسادِهِم. "
69,37," <q>﴿ٱلۡخَـٰطِـُٔونَ﴾</q>: المذْنِبُونَ أشَدَّ الذَّنبِ وهو الإشْراكُ. "
69,38," <q>﴿بِمَا تُبۡصِرُونَ﴾</q>: مِنَ الأرضِ والجِبالِ والبِحارِ والبَشَرِ والسَّمواتِ ونحوِها. "
69,39," <q>﴿وَمَا لَا تُبۡصِرُونَ﴾</q>: مِنَ الأرواحِ والملائِكةِ وأُمُورِ الآخِرَةِ. "
69,40," <q>﴿لَقَوۡلُ رَسُولࣲ كَرِيمࣲ﴾</q>: يَنْطِقُ بِهِ مُحَمَّدٌ ﷺ، والكَلامُ كَلامُ المُرسِلِ سُبْحانَهُ وتَعالى. "
69,41," <q>﴿قَلِيلࣰا مَّا تُؤۡمِنُونَ﴾</q>: تُؤْمِنُونَ إيمانا قَلِيلا لا يُنْجِيكُم مِن الخُلُود في النّارِ. "
69,42," <q>﴿قَلِيلࣰا مَّا تَذَكَّرُونَ﴾</q>: تَتَذَكَّرُونَ تَذَكُّرًا قَلِيلًا. "
  69,43,""
69,44," <q>﴿وَلَوۡ تَقَوَّلَ عَلَيۡنَا بَعۡضَ ٱلۡأَقَاوِيلِ﴾</q>: ولَو كَذَبَ عَلَينا بأنّا قُلْنا قَوْلًا لم نَقُلْه. "
69,45," <q>﴿لَأَخَذۡنَا مِنۡهُ بِٱلۡيَمِينِ﴾</q>: لَأَخَذْناهُ بِقُوَّةٍ وقُدْرَةٍ. "
69,46," <q>﴿ٱلۡوَتِينَ﴾</q>: هو عِرْقٌ عُلِّقَ به القلبُ ويَسْقِي الجسدَ بالدَّمِ، فإذا قُطِعَ مات صاحِبُه. "
69,47," <q>﴿عَنۡهُ حَـٰجِزِينَ﴾</q>: يَمنعُونَ مِنهُ عِقابَنا. "
69,48," <q>﴿لَتَذۡكِرَةࣱ﴾</q>: لَعِظَةٌ. "
  69,49,""
69,50," <q>﴿وَإِنَّهُۥ﴾</q>: أي التَّكْذِيبَ. <q>﴿لَحَسۡرَةٌ﴾</q>: لَنَدامةٌ عَظِيمَةٌ. "
69,51," <q>﴿لَحَقُّ ٱلۡيَقِينِ﴾</q>: الخبرُ الصِّدقُ. "
69,52," <q>﴿فَسَبِّحۡ﴾</q>: فَنَزِّهْ. "
70,1," <q>﴿سَأَلَ سَآئِلُۢ﴾</q>: دَعا داعٍ مِنَ المُشْرِكِينَ على نَفْسِهِ وقَوْمِهِ. <q>﴿بِعَذَابࣲ﴾</q>: بِنُزُولِ العَذابِ عَلَيهِم. <q>﴿وَاقِعࣲ﴾</q>: مُتَحَقِّقِ الوُقُوعِ. "
70,2," <q>﴿دَافِعࣱ﴾</q>: مانِعٌ يَمْنَعُهُ مِنَ اللهِ عَزَّ وجَلَّ. "
70,3," <q>﴿ذِي ٱلۡمَعَارِجِ﴾</q>: صاحِبِ العُلُوِّ والفَواضِلِ. "
70,4," <q>﴿تَعۡرُجُ﴾</q>: تَصْعَدُ. <q>﴿وَٱلرُّوحُ﴾</q>: جِبْرِيلُ. <q>﴿خَمۡسِينَ أَلۡفَ سَنَةࣲ﴾</q>: أي مِن سَنَواتِ الدُّنيا عَلى الكافِرِ. "
  70,5,""
70,6," <q>﴿يَرَوۡنَهُۥ بَعِيدࣰا﴾</q>: يَرَونَ وقُوعَ العذابِ مُسْتَحِيلًا. "
  70,7,""
70,8," <q>﴿كَٱلۡمُهۡلِ﴾</q>: ما أُذِيب مِنَ النُّحاسِ وغَيرِهِ. "
70,9," <q>﴿كَٱلۡعِهۡنِ﴾</q>: كالصُّوفِ. "
70,10," <q>﴿وَلَا يَسۡـَٔلُ حَمِيمٌ حَمِيمࣰا﴾</q>: ولا يَتَفَرَّغُ قَرِيبٌ للسُّؤالِ عَنْ حالِ قَرِيبِهِ مِنَ الهَولِ والشُّغْلِ بِحالِ نَفْسِهِ. "
