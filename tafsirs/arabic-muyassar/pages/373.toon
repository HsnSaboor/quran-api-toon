quran[23]{c,v,t}:
  26,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنۡ هَـٰذَآ﴾</span>: ما هَذا.</p><p><span class="qpc-hafs">﴿خُلُقُ ٱلۡأَوَّلِينَ﴾</span>: دِينُ الأوَّلِينَ وعاداتُهُم.</p></div>"
  26,138,""
  26,139,""
  26,140,""
  26,141,""
  26,142,""
  26,143,""
  26,144,""
  26,145,""
  26,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا هَـٰهُنَآ﴾</span>: أي: في الدُّنيا.</p></div>"
  26,147,""
  26,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَلۡعُهَا﴾</span>: ثَمَرُها.</p><p><span class="qpc-hafs">﴿هَضِيمࣱ﴾</span>: مُنْكَسِرٌ مِن لِينِهِ ورُطُوبَتِه.</p></div>"
  26,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰرِهِينَ﴾</span>: ماهِرِين بنَحْتِها.</p></div>"
  26,150,""
  26,151,""
  26,152,""
  26,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلۡمُسَحَّرِينَ﴾</span>: مِنَ المغْلُوبِ على عُقُولِهِم بِكَثْرَةِ السِّحرِ.</p></div>"
  26,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةٍ﴾</span>: بِحُجَّةٍ واضِحَةٍ.</p></div>"
  26,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهَا شِرۡبࣱ﴾</span>: لها نَصِيبٌ مِنَ الماءِ.</p></div>"
  26,156,""
  26,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُوهَا﴾</span>: فَنَحَرُوها.</p></div>"
  26,158,""
