tafsir[23]{c,v,t}:
26,137," <q>﴿إِنۡ هَـٰذَآ﴾</q>: ما هَذا. <q>﴿خُلُقُ ٱلۡأَوَّلِينَ﴾</q>: دِينُ الأوَّلِينَ وعاداتُهُم. "
  26,138,""
  26,139,""
  26,140,""
  26,141,""
  26,142,""
  26,143,""
  26,144,""
  26,145,""
26,146," <q>﴿مَا هَـٰهُنَآ﴾</q>: أي: في الدُّنيا. "
  26,147,""
26,148," <q>﴿طَلۡعُهَا﴾</q>: ثَمَرُها. <q>﴿هَضِيمࣱ﴾</q>: مُنْكَسِرٌ مِن لِينِهِ ورُطُوبَتِه. "
26,149," <q>﴿فَـٰرِهِينَ﴾</q>: ماهِرِين بنَحْتِها. "
  26,150,""
  26,151,""
  26,152,""
26,153," <q>﴿مِنَ ٱلۡمُسَحَّرِينَ﴾</q>: مِنَ المغْلُوبِ على عُقُولِهِم بِكَثْرَةِ السِّحرِ. "
26,154," <q>﴿بِـَٔايَةٍ﴾</q>: بِحُجَّةٍ واضِحَةٍ. "
26,155," <q>﴿لَّهَا شِرۡبࣱ﴾</q>: لها نَصِيبٌ مِنَ الماءِ. "
  26,156,""
26,157," <q>﴿فَعَقَرُوهَا﴾</q>: فَنَحَرُوها. "
  26,158,""
  26,159,""
