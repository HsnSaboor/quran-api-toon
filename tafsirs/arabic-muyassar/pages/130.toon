quran[9]{c,v,t}:
  6,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۢ بَلَغَ﴾</span>: كلَّ مَن بَلَغَه.</p></div>"
  6,20,""
  6,21,""
  6,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيۡنَ شُرَكَآؤُكُمُ﴾</span>: أين آلهتُكم لينفعُوكُم؟</p></div>"
  6,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَتُهُمۡ﴾</span>: جوابُهم حين يُخْتَبَرُون بهذا السؤالِ.</p></div>"
  6,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم﴾</span>: وغابَ عنهم.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ يَفۡتَرُونَ﴾</span>: ما كانوا يعتقدونه مِن نَفْعِ آلهتِهم له.</p></div>"
  6,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكِنَّةً﴾</span>: أغْطِيةً فلا تفقهُ القرآنَ فِقْهَ انتفاعٍ به.</p><p><span class="qpc-hafs">﴿وَقۡرࣰا﴾</span>: ثِقَلًا، وصَمَمًا.</p><p><span class="qpc-hafs">﴿يُجَـٰدِلُونَكَ﴾</span>: يُخاصِمُونك.</p><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ﴾</span>: ما سَطَّرُوه من الأباطيلِ.</p></div>"
  6,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنۡهَوۡنَ عَنۡهُ﴾</span>: يَنْهَون الناسَ عن اتِّباع محمدٍ ﷺ.</p><p><span class="qpc-hafs">﴿وَيَنۡـَٔوۡنَ عَنۡهُ﴾</span>: ويَبْتَعِدُون عنه.</p></div>"
  6,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وُقِفُواْ﴾</span>: حُبِسُوا.</p><p><span class="qpc-hafs">﴿نُرَدُّ﴾</span>: إلى الدُّنيا.</p></div>"