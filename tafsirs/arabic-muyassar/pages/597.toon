quran[27]{c,v,t}:
  95,1,""
  95,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَطُورِ سِينِينَ﴾</span>: أقَسَمَ اللهُ بِجَبَلِ «طُورِ سَيناءَ» الَّذِي كَلَّمَ اللهُ عَلَيه مُوسى تَكْلِيمًا.</p></div>"
  95,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَـٰذَا ٱلۡبَلَدِ﴾</span>: وأَقَسَمَ اللهُ بمَكَّةَ.</p></div>"
  95,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أَحۡسَنِ تَقۡوِيمࣲ﴾</span>: في أحَسَنِ صُورَةٍ.</p></div>"
  95,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡفَلَ سَـٰفِلِينَ﴾</span>: أي: إلى النّارِ.</p></div>"
  95,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجۡرٌ غَيۡرُ مَمۡنُونࣲ﴾</span>: أجْرٌ عظِيمٌ غَيرُ مَقْطُوعٍ.</p></div>"
  95,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا يُكَذِّبُكَ بَعۡدُ بِٱلدِّينِ﴾</span>: أيُّ شَيءٍ يَحْمِلُكَ -أيُّها الإنسانُ- عَلى أن تُكَذِّبَ بالبَعْثِ والجزاءِ مَعَ وُضُوحِ الأدِلَّةِ عَلى قُدْرَةِ اللهِ تعالى؟</p></div>"
  95,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِأَحۡكَمِ ٱلۡحَـٰكِمِينَ﴾</span>: بأَحْكَمِ مَن حَكَمَ في أحْكامِهِ وفَصْلِ قَضائِهِ.</p></div>"
  96,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱقۡرَأۡ﴾</span>: اقْرَأْ -أيُّها النَّبِيُّ- ما أُنِزلَ إلَيكَ مِن القُرآنِ.</p><p><span class="qpc-hafs">﴿بِٱسۡمِ رَبِّكَ﴾</span>: مُفْتَتِحًا باسْمِ رَبِّكَ.</p><p><span class="qpc-hafs">﴿ٱلَّذِي خَلَقَ﴾</span>: المُتَفَرِّدِ بالخَلْقِ.</p></div>"
  96,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَقٍ﴾</span>: قِطْعَةِ دَمٍ غَلِيظ أحْمَرَ.</p></div>"
  96,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَكۡرَمُ﴾</span>: الكثِيرُ الإحسانِ.</p></div>"
  96,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡقَلَمِ﴾</span>: الكِتابة بالقَلَمِ.</p></div>"
  96,5,""
  96,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّآ﴾</span>: حَقًّا.</p><p><span class="qpc-hafs">﴿لَيَطۡغَىٰٓ﴾</span>: لَيتَجاوَزُ حُدُودَ اللهِ.</p></div>"
  96,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ﴾</span>: لِأَجْلِ أنَّهُ وجَدَ نَفْسَه مُسْتَغْنِيًا شَدِيدَ الغِنى.</p></div>"
  96,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرُّجۡعَىٰٓ﴾</span>: المَصِيرَ.</p></div>"
  96,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ﴾</span>: أرأيتَ أعْجَبَ مِن طُغيانِ هذا الرَّجُلِ -وهو أبو جَهْلٍ- الَّذِي يَنْهى.</p></div>"
  96,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبۡدًا﴾</span>: هو مُحَمَّدٌ ﷺ.</p></div>"
  96,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ﴾</span>: أرأيت إن كان المَنهِيُّ عَنِ الصَّلاةِ عَلى الهُدى فَكَيفَ يَنْهاهُ؟</p></div>"
  96,12,""
  96,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَوَلَّىٰٓ﴾</span>: وأَعْرَضَ عَنْهُ.</p></div>"
  96,14,""
  96,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: لَيسَ الأمرُ كَما يَزْعُمُ أبو جَهْلٍ.</p><p><span class="qpc-hafs">﴿لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ﴾</span>: لَنَأْخُذَنَّ بِمُقَدَّمِ رَأْسِهِ أخْذًا عَنِيفًا، وليُطْرَحَنَّ في النّارِ.</p></div>"
  96,16,""
  96,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَدۡعُ نَادِيَهُۥ﴾</span>: فليُحْضِرْ أهْلَ نادِيهِ الَّذِين يَسْتَنْصِرُ بِهِم.</p></div>"
  96,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنَدۡعُ ٱلزَّبَانِيَةَ﴾</span>: سَنَدعُو ملائِكةَ العذابِ.</p></div>"
  96,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: لَيس الأمرُ على ما يَظُنُّ. إنُّه لَن يَنالَكَ -أيُّها الرَّسُولُ- بِسُوءٍ.</p><p><span class="qpc-hafs">﴿لَا تُطِعۡهُ﴾</span>: فلا تُطِعْهُ فيما دَعاكَ إلَيهِ.</p><p><span class="qpc-hafs">﴿وَٱقۡتَرِب﴾</span>: واجْتَهِدْ في القُربِ مِن اللهِ.</p></div>"