quran[4]{c,v,t}:
  58,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُوَآدُّونَ﴾</span>: يُحِبُّونَ ويُوالُونَ.</p><p><span class="qpc-hafs">﴿حَآدَّ﴾</span>: عادى.</p><p><span class="qpc-hafs">﴿عَشِيرَتَهُمۡ﴾</span>: أقْرِباءَهُم.</p><p><span class="qpc-hafs">﴿كَتَبَ﴾</span>: ثَبَّتَ.</p><p><span class="qpc-hafs">﴿وَأَيَّدَهُم﴾</span>: قَوّاهُم.</p><p><span class="qpc-hafs">﴿بِرُوحࣲ﴾</span>: بِنَصْرٍ وتأْيِيدٍ.</p><p><span class="qpc-hafs">﴿حِزۡبَ ٱللَّهِ﴾</span>: أولياؤُهُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ بِسَعادةِ الدُّنيا والآخِرَةِ.</p></div>"
  59,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبَّحَ﴾</span>: نَزَّهَ.</p></div>"
  59,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ كَفَرُواْ﴾</span>: هُم بنُو النَّضِيرِ مِنَ اليهُودِ.</p><p><span class="qpc-hafs">﴿دِيَـٰرِهِمۡ﴾</span>: مَساكِنِهِم الَّتِي جاوَرُوا بِها المسْلِمِينَ حَوْلَ «المدينةِ».</p><p><span class="qpc-hafs">﴿لِأَوَّلِ ٱلۡحَشۡرِ﴾</span>: عِنْدَ أوَّلِ جَمْعِهِم لِلْخُرُوجِ مِن جَزِيرةِ العَرَبِ.</p><p><span class="qpc-hafs">﴿مَّانِعَتُهُمۡ﴾</span>: تَدْفَعُ عَنْهُم.</p><p><span class="qpc-hafs">﴿فَأَتَىٰهُمُ ٱللَّهُ﴾</span>: فَجاءَهُم أمْرُ اللهِ.</p><p><span class="qpc-hafs">﴿مِنۡ حَيۡثُ لَمۡ يَحۡتَسِبُواْ﴾</span>: مِن مَكانٍ لم يَظُنُّوهُ.</p><p><span class="qpc-hafs">﴿وَقَذَفَ﴾</span>: وجَعَل.</p><p><span class="qpc-hafs">﴿ٱلرُّعۡبَ﴾</span>: الخَوْفَ والفَزَعَ الشَّدِيدَ.</p><p><span class="qpc-hafs">﴿فَٱعۡتَبِرُواْ﴾</span>: فاتَّعِظُوا.</p><p><span class="qpc-hafs">﴿يَـٰٓأُوْلِي ٱلۡأَبۡصَـٰرِ﴾</span>: أصْحابَ البَصائِر السَّلِيمَةِ، والعُقُولِ الرّاجِحَةِ.</p></div>"
  59,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَلَآءَ﴾</span>: الخُرُوجَ مِنَ الوطنِ بِنِيَّةِ عَدَمِ العَوْدِ.</p></div>"