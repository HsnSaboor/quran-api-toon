quran[8]{c,v,t}:
  41,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَيۡهِ يُرَدُّ﴾</span>: إلى اللهِ وحْدَهُ يُرجَعُ.</p><p><span class="qpc-hafs">﴿مِّنۡ أَكۡمَامِهَا﴾</span>: مِن أوْعِيَتِها. مُفْرَدُها: كِمٌّ.</p><p><span class="qpc-hafs">﴿ءَاذَنَّـٰكَ﴾</span>: أعْلَمناكَ.</p><p><span class="qpc-hafs">﴿مَا مِنَّا مِن شَهِيدࣲ﴾</span>: يَشْهَدُ أنّ لَكَ شَريكًا.</p></div>"
  41,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم﴾</span>: وذَهَبَ عَنِ المشْرِكِينَ.</p><p><span class="qpc-hafs">﴿وَظَنُّواْ﴾</span>: أيقَنُوا.</p><p><span class="qpc-hafs">﴿مَّحِيصࣲ﴾</span>: مَلْجَأٍ مِن عَذابِ اللهِ.</p></div>"
  41,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَسۡـَٔمُ﴾</span>: لا يَمَلُّ.</p><p><span class="qpc-hafs">﴿ٱلۡإِنسَـٰنُ﴾</span>: المُرادُ هُنا الكافرُ بِاللهِ.</p><p><span class="qpc-hafs">﴿مِن دُعَآءِ ٱلۡخَيۡرِ﴾</span>: مِن سُؤالِهِ رَبَّهُ أن يَمُدَّهُ بالمالِ والصِّحَّةِ.</p><p><span class="qpc-hafs">﴿وَإِن مَّسَّهُ﴾</span>: وإنْ أصابَه.</p><p><span class="qpc-hafs">﴿ٱلشَّرُّ﴾</span>: فَقْرٌ ومَرَضٌ.</p><p><span class="qpc-hafs">﴿فَيَـُٔوسࣱ﴾</span>: مُبالِغٌ في اعْتِقادِ عَدَمِ حُصُولِ الخيرِ لَهُ.</p><p><span class="qpc-hafs">﴿قَنُوطࣱ﴾</span>: شَدِيد اليأسِ.</p></div>"
  41,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَرَّآءَ﴾</span>: شدَّةٍ وبَلاءٍ.</p><p><span class="qpc-hafs">﴿هَـٰذَا لِي﴾</span>: أسْتَحِقُّه على اللهِ لأنّه راضٍ عَنِّي.</p><p><span class="qpc-hafs">﴿لَلۡحُسۡنَىٰ﴾</span>: الجنَّةِ.</p><p><span class="qpc-hafs">﴿غَلِيظࣲ﴾</span>: شَدِيدٍ، وهو خُلُودُهُم في النّارِ.</p></div>"
  41,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَـَٔابِجَانِبِهِۦ﴾</span>: تَباعَدَ عَن شُكْرِ نِعْمَةِ اللهِ وطاعَتِهِ.</p><p><span class="qpc-hafs">﴿عَرِيضࣲ﴾</span>: كَثِيرٍ.</p></div>"
  41,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أخْبِرُونِي.</p><p><span class="qpc-hafs">﴿مَنۡ أَضَلُّ﴾</span>: لا أحَد أشَدُّ ذَهابًا عَن قَصْدِ السَّبيلِ.</p><p><span class="qpc-hafs">﴿فِي شِقَاقِۭ﴾</span>: في خِلافٍ وفِراقٍ لأمر الله.</p><p><span class="qpc-hafs">﴿بَعِيدࣲ﴾</span>: واسِع المسافَةِ مِنَ الرَّشادِ.</p></div>"
  41,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِنَا﴾</span>: مِنَ الفُتُوحاتِ وظُهُورِ الإسْلامِ عَلى الأقاليمِ وسائِرِ الأدْيانِ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔافَاقِ﴾</span>: أقْطارِ السَّمَواتِ والأرْضِ.</p><p><span class="qpc-hafs">﴿وَفِيٓ أَنفُسِهِمۡ﴾</span>: مِن لطِيفِ الصَّنْعَةِ وبدِيعِ الحِكْمةِ.</p><p><span class="qpc-hafs">﴿أَوَ لَمۡ يَكۡفِ بِرَبِّكَ﴾</span>: أو لم يَكْفِ ربُّكَ شاهِدًا عَلى صِدْقِكَ وصِدْقِ ما أُنزِلَ إليكَ.</p></div>"
  41,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِرۡيَةࣲ مِّن لِّقَآءِ رَبِّهِمۡ﴾</span>: شَكٍّ عَظِيمٍ مِنَ البعثِ بَعْدَ المماتِ.</p><p><span class="qpc-hafs">﴿مُّحِيطُۢ﴾</span>: أحاطَ بِكُلِّ شَيءٍ عِلْمًا.</p></div>"