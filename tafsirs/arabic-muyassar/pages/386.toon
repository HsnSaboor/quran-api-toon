quran[8]{c,v,t}:
  28,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُمَكِّنَ﴾</span>: ونُثَبِّتَ لهم.</p><p><span class="qpc-hafs">﴿يَحۡذَرُونَ﴾</span>: يَخافُونَ.</p></div>"
  28,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَوۡحَيۡنَآ﴾</span>: وألْهَمْنا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡيَمِّ﴾</span>: في نَهْرِ النِّيلِ.</p></div>"
  28,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡتَقَطَهُۥٓ﴾</span>: فأخَذَهُ.</p><p><span class="qpc-hafs">﴿لِيَكُونَ﴾</span>: أي: في المآلِ والعاقِبَةِ.</p></div>"
  28,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُرَّتُ عَيۡنࣲ﴾</span>: مَصْدرُ سُرورٍ وسَعادةٍ تَقَرُّ العَينُ بِهِ.</p></div>"
  28,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُؤَادُ﴾</span>: قَلْبُ.</p><p><span class="qpc-hafs">﴿فَـٰرِغًا﴾</span>: خالِيًا مِن كلِّ شَيءٍ، ليمْلَأَه هَمُّ مُوسى وذِكْرُه.</p><p><span class="qpc-hafs">﴿لَتُبۡدِي بِهِۦ﴾</span>: لَتُظْهِرُ أنَّ مُوسى ابْنُها.</p><p><span class="qpc-hafs">﴿أَن رَّبَطۡنَا﴾</span>: أن ثبَّتناها بالصَّبرِ والثَّباتِ.</p></div>"
  28,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُصِّيهِ﴾</span>: اتَّبعِي أثَرَ مُوسى وتَعَرَّفي خَبَرَه.</p><p><span class="qpc-hafs">﴿عَن جُنُبࣲ﴾</span>: عن بُعدٍ.</p></div>"
  28,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحَرَّمۡنَا عَلَيۡهِ﴾</span>: أي: مَنَعْناهُ مِن قَبُولِ الرَّضاعَةِ.</p><p><span class="qpc-hafs">﴿يَكۡفُلُونَهُۥ﴾</span>: يقُومُونَ بإرْضاعِه وتَرْبِيَتِهِ.</p><p><span class="qpc-hafs">﴿نَـٰصِحُونَ﴾</span>: مُشْفِقُونَ.</p></div>"
  28,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡ تَقَرَّ عَيۡنُهَا﴾</span>: كَي تُسَرَّ أمُّ مُوسى بِسَلامَةِ ولَدِها ورُجُوعِهِ إليها.</p></div>"