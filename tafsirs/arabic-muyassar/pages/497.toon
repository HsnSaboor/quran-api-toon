quran[21]{c,v,t}:
  44,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَن لَّا تَعۡلُواْ عَلَى ٱللَّهِ﴾</span>: لا تَتَكَبَّرُوا على اللهِ بِتَكْذِيبِ رُسُلِه.</p><p><span class="qpc-hafs">﴿بِسُلۡطَـٰنࣲ﴾</span>: بِبُرْهانٍ.</p></div>"
  44,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُذۡتُ بِرَبِّي﴾</span>: استَجَرْتُ بِاللهِ.</p><p><span class="qpc-hafs">﴿تَرۡجُمُونِ﴾</span>: تَقْتُلُوني رَجْمًا بالحِجارَةِ.</p></div>"
  44,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱعۡتَزِلُونِ﴾</span>: كُفُّوا عَنْ أذايَ.</p></div>"
  44,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّجۡرِمُونَ﴾</span>: مُشْرِكُونَ بِاللهِ كافِرُونَ.</p></div>"
  44,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَسۡرِ﴾</span>: اجْعَلْهُم يَسِيُرونَ لَيلًا.</p></div>"
  44,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَهۡوًا﴾</span>: ساكِنًا مُسْتَقِرًّا عَلى حالِه مُنْفَرِجًا.</p></div>"
  44,25,"<div class=ar lang=ar></div>"
  44,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَقَامࣲ كَرِيمࣲ﴾</span>: ومَنازِلَ جَمِيلَةٍ.</p></div>"
  44,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَعۡمَةࣲ﴾</span>: عَيْشٍ لَيِّنٍ رَغْدٍ.</p><p><span class="qpc-hafs">﴿فَـٰكِهِينَ﴾</span>: مُتَنَعِّمِينَ، مُتْرَفِينَ.</p></div>"
  44,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: مِثْلَ ذَلِكَ العِقابِ يُعاقِبُ اللهُ مَن كَذَّبَ، وبَدّلَ نِعْمةَ اللهِ كُفْرًا.</p><p><span class="qpc-hafs">﴿وَأَوۡرَثۡنَـٰهَا﴾</span>: ومَلَّكْناها.</p></div>"
  44,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنظَرِينَ﴾</span>: مُؤَخَّرِينَ عَنِ العُقُوبَةِ.</p></div>"
  44,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُهِينِ﴾</span>: المُذِلِّ.</p></div>"
  44,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَالِيࣰا﴾</span>: جَبّارًا.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡمُسۡرِفِينَ﴾</span>: مُتَجاوِزًا للحَدِّ في العُلوِّ والتَّكَبُّرِ عَلى عبادِ اللهِ.</p></div>"
  44,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَـٰلَمِينَ﴾</span>: عالَمِي زَمانِهِم.</p></div>"
  44,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الُمعْجِزاتِ.</p><p><span class="qpc-hafs">﴿بَلَـٰٓؤࣱاْ﴾</span>: اخْتِبارٌ بالرَّخاءِ والشِّدَةِ.</p></div>"
  44,34,"<div class=ar lang=ar></div>"
  44,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمُنشَرِينَ﴾</span>: بِمَبْعُوثِينَ.</p></div>"
  44,36,"<div class=ar lang=ar></div>"
  44,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُبَّعࣲ﴾</span>: أحَدِ مُلُوكِ اليمنِ الحِمْيَرِيِّينَ مِمَّن جَمَعَ مُلْكَ مَناطِقِ اليمنِ كُلِّها.</p></div>"
  44,38,"<div class=ar lang=ar></div>"
  44,39,"44:38"