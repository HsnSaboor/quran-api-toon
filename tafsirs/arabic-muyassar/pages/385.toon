quran[10]{c,v,t}:
  27,89,""
  27,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكُبَّتۡ وُجُوهُهُمۡ فِي ٱلنَّارِ﴾</span>: أي: أُلقُوا على وُجُوهِهِم فِيها.</p></div>"
  27,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَرَّمَهَا﴾</span>: جَعَلها حَرَمًا آمِنًا لا يُسْفَكُ فيها دَمٌ.</p></div>"
  27,92,""
  27,93,""
  28,1,""
  28,2,""
  28,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّبَإِ مُوسَىٰ﴾</span>: خَبَرِ مُوسى.</p><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالصِّدْقِ.</p></div>"
  28,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَا﴾</span>: تَجَبَّرَ وتكَبَّرَ.</p><p><span class="qpc-hafs">﴿شِيَعࣰا﴾</span>: طَوائِفَ مُتَفَرِّقةً.</p><p><span class="qpc-hafs">﴿وَيَسۡتَحۡيِۦ نِسَآءَهُمۡ﴾</span>: أي: يَسْتَبْقِيهِنَّ للخِدْمَةِ والامْتِهانِ.</p></div>"
  28,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن نَّمُنَّ﴾</span>: أن نَتَفَضَّلَ.</p><p><span class="qpc-hafs">﴿أَئِمَّةࣰ﴾</span>: قادَةً في الخيرِ.</p><p><span class="qpc-hafs">﴿ٱلۡوَ ٰ⁠رِثِينَ﴾</span>: أي: ورِثُوا أرضَ مِصْرَ بَعْدَ هَلاكِ فِرْعَونَ وقَومِهِ.</p></div>"