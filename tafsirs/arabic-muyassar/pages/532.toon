tafsir[24]{c,v,t}:
55,17," <q>﴿ٱلۡمَشۡرِقَيۡنِ﴾</q>: مَشْرِقَي الشَّمْسِ في الشِّتاءِ والصَّيفِ. <q>﴿ٱلۡمَغۡرِبَيۡنِ﴾</q>: مَغْرِبَيِ الشَّمسِ في الشِّتاءِ والصَّيفِ. "
  55,18,""
55,19," <q>﴿مَرَجَ﴾</q>: خَلَطَ. <q>﴿ٱلۡبَحۡرَيۡنِ﴾</q>: الماءَ العَذْبَ والمِلْحَ. <q>﴿يَلۡتَقِيَانِ﴾</q>: في مَرْأى العَينِ. "
55,20," <q>﴿بَرۡزَخࣱ﴾</q>: حاجِزٌ. <q>﴿لَّا يَبۡغِيَانِ﴾</q>: لا يطْغى أحَدُهُما عَلى الآخَرِ. "
  55,21,""
55,22," <q>﴿ٱللُّؤۡلُؤُ﴾</q>: الدُّرُّ. <q>﴿وَٱلۡمَرۡجَانُ﴾</q>: صِغارُ اللُّؤلُؤ. "
  55,23,""
55,24," <q>﴿ٱلۡجَوَارِ﴾</q>: السُّفُنُ الضَّخْمَةُ الَّتِي تَجْرِي في البَحْرِ. <q>﴿ٱلۡمُنشَـَٔاتُ﴾</q>: المَرْفُوعاتُ الشِّراعِ. <q>﴿كَٱلۡأَعۡلَـٰمِ﴾</q>: كالجِبالِ. "
  55,25,""
55,26," <q>﴿عَلَيۡهَا﴾</q>: عَلى وجْهِ الأرْضِ. <q>﴿فَانࣲ﴾</q>: هالِكٌ. "
55,27," <q>﴿ٱلۡجَلَـٰلِ﴾</q>: ذُو العَظَمَةِ والكِبْرِياءِ. <q>﴿وَٱلۡإِكۡرَامِ﴾</q>: والفَضْلِ والجُودِ. "
  55,28,""
  55,29,""
  55,30,""
55,31," <q>﴿سَنَفۡرُغُ﴾</q>: سنفرغ لحسابكم ومجازاتكم بأعْمالِكُم. <q>﴿أَيُّهَ ٱلثَّقَلَانِ﴾</q>: أيُّها الإنْسُ والجِنُّ. "
  55,32,""
55,33," <q>﴿تَنفُذُواْ﴾</q>: تَخْرُجُوا. <q>﴿أَقۡطَارِ﴾</q>: أطْرافِ. <q>﴿بِسُلۡطَـٰنࣲ﴾</q>: بِقُوَّةٍ وحُجَّةٍ. "
  55,34,""
55,35," <q>﴿شُوَاظࣱ﴾</q>: لَهَبٌ. <q>﴿وَنُحَاسࣱ﴾</q>: مُذابٌ يُصَبُّ على رُؤُوسِكُم. <q>﴿فَلَا تَنتَصِرَانِ﴾</q>: فَلا يَنْصُرُ بَعْضُكُم بَعْضًا. "
  55,36,""
55,37," <q>﴿ٱنشَقَّتِ﴾</q>: تَفَطَّرَتْ يَوْمَ القِيامَةِ. <q>﴿وَرۡدَةࣰ﴾</q>: حَمْراءَ كَلَونِ الوَرْدِ. <q>﴿كَٱلدِّهَانِ﴾</q>: كالزَّيتِ الَمغْلِيِّ والرَّصاصِ المُذابِ. "
  55,38,""
  55,39,""
  55,40,""
