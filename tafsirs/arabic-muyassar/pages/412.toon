quran[8]{c,v,t}:
  31,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لُقۡمَـٰنَ﴾</span>: هو رَجُلٌ صالِحٌ كانَ مِن حُكَماءِ بني إسرْائِيلَ.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: العقلَ والفهمَ وإصابةَ القولِ.</p><p><span class="qpc-hafs">﴿كَفَرَ﴾</span>: أي: جَحَدَ نِعَمَ اللهِ بِعَدَمِ شُكْرِها.</p></div>"
  31,13,""
  31,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَّيۡنَا﴾</span>: أمَرْنا.</p><p><span class="qpc-hafs">﴿وَهۡنًا﴾</span>: ضَعْفًا.</p><p><span class="qpc-hafs">﴿وَفِصَـٰلُهُۥ﴾</span>: فِطامُه عَنِ الرَّضاعَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ.</p></div>"
  31,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَـٰهَدَاكَ﴾</span>: بَذَلا الجُهْدَ وحاوَلا أن يُجْبِراكَ.</p><p><span class="qpc-hafs">﴿وَصَاحِبۡهُمَا﴾</span>: عاشِرْهُما.</p><p><span class="qpc-hafs">﴿أَنَابَ إِلَيَّ﴾</span>: رَجَع إليّ بالإخْلاصِ والتَّوبة.</p><p><span class="qpc-hafs">﴿مَرۡجِعُكُمۡ﴾</span>: مَصِيرُكُم.</p><p><span class="qpc-hafs">﴿فَأُنَبِّئُكُم﴾</span>: فَأُخْبِرُكُم.</p></div>"
  31,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّهَآ﴾</span>: أي: السَّيِّئةَ أو الحَسَنَةَ.</p><p><span class="qpc-hafs">﴿مِثۡقَالَ حَبَّةࣲ﴾</span>: وزْنَ حَبَّةٍ.</p><p><span class="qpc-hafs">﴿خَرۡدَلࣲ﴾</span>: وهْوَ أصْغَرُ الحُبُوبِ، والمرادُ أصغرُ شيءٍ.</p><p><span class="qpc-hafs">﴿فِي صَخۡرَةٍ﴾</span>: في باطِنِ جَبَلٍ.</p></div>"
  31,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡمَعۡرُوفِ﴾</span>: المعْرُوفُ كُلُّ فِعْلٍ يُعْرَفُ حُسْنُه بالشَّرْعِ أو العَقْلِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنكَرِ﴾</span>: وهْوَ كُلُّ فِعْلٍ يُنكِرُه الشَّرعُ أوِ العَقْلُ.</p><p><span class="qpc-hafs">﴿مِنۡ عَزۡمِ ٱلۡأُمُورِ﴾</span>: أي: مِنَ الأمُورِ الَّتي يَنْبَغِي العَزْمُ والحِرْصُ عليها.</p></div>"
  31,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُصَعِّرۡ خَدَّكَ﴾</span>: أي: لا تُمِلْه عُجْبًا واسْتِكْبارًا.</p><p><span class="qpc-hafs">﴿مَرَحًا﴾</span>: فَرَحًا وبَطَرًا.</p><p><span class="qpc-hafs">﴿مُخۡتَالࣲ﴾</span>: مُتَكَبِّرٍ.</p><p><span class="qpc-hafs">﴿فَخُورࣲ﴾</span>: مُتَباهٍ بنفسه.</p></div>"
  31,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱقۡصِدۡ فِي مَشۡيِكَ﴾</span>: أي: تَوَسَّطْ فِيه مَعَ تَواضُعٍ وسَكِينَةٍ.</p><p><span class="qpc-hafs">﴿وَٱغۡضُضۡ﴾</span>: واخْفِضْ.</p><p><span class="qpc-hafs">﴿أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ﴾</span>: أي: أقبَحَها.</p></div>"