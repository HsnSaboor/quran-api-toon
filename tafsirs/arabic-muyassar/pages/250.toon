quran[8]{c,v,t}:
  13,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡمَثُلَـٰتُ﴾</span>: جَمْعُ مَثُلَة، وهي عقوباتُ اللهِ التي تكونُ مَثَلًا يَرْدَعُ.</p></div>"
  13,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡلَآ﴾</span>: هَلّا.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: مُعْجِزَةٌ محسوسةٌ، كناقةِ صالحٍ.</p><p><span class="qpc-hafs">﴿هَادٍ﴾</span>: داعٍ يرشُدُهم، وهو نبيُّهم.</p></div>"
  13,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تَغِيضُ ٱلۡأَرۡحَامُ﴾</span>: ما تَنْقُصُه قبلَ اكتمالِ الحَمْلِ في بِنْيتِه أو مُدَّتِه، أو ما تُسْقِطُه ميتًا.</p><p><span class="qpc-hafs">﴿وَمَا تَزۡدَادُ﴾</span>: ما يَزْدادُه الحَمْلُ في جِسْمِه، أو مُدَّتِه، أو عَدَدِه.</p><p><span class="qpc-hafs">﴿بِمِقۡدَارٍ﴾</span>: بقَدْرٍ عندَ اللهِ لا يتعدّاه ولا يَنْقُصُ عنه.</p></div>"
  13,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَيۡبِ﴾</span>: ما خَفِيَ عن الأبصارِ والحواسِّ.</p><p><span class="qpc-hafs">﴿وَٱلشَّهَـٰدَةِ﴾</span>: ما هو مشاهَدٌ وحاضِرٌ.</p><p><span class="qpc-hafs">﴿ٱلۡكَبِيرُ﴾</span>: في ذاتِه وأسمائِه وصفاتِه.</p><p><span class="qpc-hafs">﴿ٱلۡمُتَعَالِ﴾</span>: المُسْتَعْلي على جميعِ خَلْقِه بذاتِه وقُدْرتِه وقَهْرِه.</p></div>"
  13,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَآءࣱ﴾</span>: يستوي في عِلْمِ اللهِ تعالى.</p><p><span class="qpc-hafs">﴿مَّنۡ أَسَرَّ ٱلۡقَوۡلَ﴾</span>: الذي أخفاه.</p><p><span class="qpc-hafs">﴿مُسۡتَخۡفِۭ بِٱلَّيۡلِ﴾</span>: مُسْتَتِرٌ بأعمالِه في ظُلْمَةِ الليلِ عن الأَعْيُنِ.</p><p><span class="qpc-hafs">﴿وَسَارِبُۢ بِٱلنَّهَارِ﴾</span>: ذاهبٌ في طريقِه وعَمَلِه نهارًا يُبْصِرُه كلُّ أحدٍ.</p></div>"
  13,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهُۥ﴾</span>: أي: لله، أو للمذكورِ من أحوالِ الإنسانِ.</p><p><span class="qpc-hafs">﴿مُعَقِّبَـٰتࣱ﴾</span>: ملائكةٌ حَفَظَةٌ يتعاقبون على الإنسان ليلًا ونهارًا.</p><p><span class="qpc-hafs">﴿يَحۡفَظُونَهُۥ مِنۡ أَمۡرِ ٱللَّهِ﴾</span>: بسبب أمرِ اللهِ لهم بحِفْظِه ورعايتِه.</p><p><span class="qpc-hafs">﴿وَالٍ﴾</span>: وليٍّ ناصرٍ يتولّى أمورَهم ويَدْفَعُ عنهم ما هم فيه.</p></div>"
  13,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَوۡفࣰا﴾</span>: من الصواعقِ المُحْرِقَةِ.</p><p><span class="qpc-hafs">﴿وَطَمَعࣰا﴾</span>: في نزولِ المَطَرِ.</p><p><span class="qpc-hafs">﴿وَيُنشِئُ﴾</span>: يُوجِدُ.</p><p><span class="qpc-hafs">﴿ٱلسَّحَابَ ٱلثِّقَالَ﴾</span>: المُحَمَّلَةَ بالماءِ، فتَثْقُلُ لكثرةِ مائِها.</p></div>"
  13,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُمۡ يُجَـٰدِلُونَ فِي ٱللَّهِ﴾</span>: والكفارُ يُجادِلون في وحْدانيةِ اللهِ وقدرتِه على البعثِ.</p><p><span class="qpc-hafs">﴿ٱلۡمِحَالِ﴾</span>: المكايَدَةِ والقوةِ والبَطْشِ بأعدائِه.</p></div>"