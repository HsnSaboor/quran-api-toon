tafsir[20]{c,v,t}:
50,16," <q>﴿مَا تُوَسۡوِسُ بِهِۦ﴾</q>: تُحَدِّث بِه. <q>﴿حَبۡلِ ٱلۡوَرِيدِ﴾</q>: عِرْقِ العُنُقِ المُتَّصِلِ بالقلبِ. "
50,17," <q>﴿يَتَلَقَّى﴾</q>: يُسَجِّلُ. <q>﴿ٱلۡمُتَلَقِّيَانِ﴾</q>: المَلَكانِ المُوكَّلانِ بِكِتابَةِ أعْمالِ النّاسِ وأَقْوالِهِم. <q>﴿عَنِ ٱلۡيَمِينِ﴾</q>: عَن يَمِينِ الإنْسانِ. <q>﴿قَعِيدࣱ﴾</q>: مُقاعِدٌ، مِثْلُ جَلِيسٍ للمُجالِسِ. "
50,18," <q>﴿رَقِيبٌ﴾</q>: مَلَكٌ يَرْقُبُ قَوْلَهُ ويَكْتُبُهُ. <q>﴿عَتِيدࣱ﴾</q>: حاضِرٌ مُعَدٌّ لِذَلِكَ. "
50,19," <q>﴿سَكۡرَةُ ٱلۡمَوۡتِ﴾</q>: شِدَّةُ غَمَراتِ الموتِ. <q>﴿تَحِيدُ﴾</q>: تَفِرُّ وتَهْرُبُ. "
50,20," <q>﴿ٱلصُّورِ﴾</q>: القَرْنِ الَّذِي يَنْفُخُ فِيهِ إسْرافِيلُ. <q>﴿يَوۡمُ ٱلۡوَعِيدِ﴾</q>: أي الَّذِي تَوَعَّدَ اللهُ بِه الكُفّارَ. "
50,21," <q>﴿سَآئِقࣱ﴾</q>: مَلَكٌ يَسُوقُ الإنْسانَ إلى المَحْشَرِ. <q>﴿وَشَهِيدࣱ﴾</q>: مَلَكٌ يَشْهَدُ عَلى النَّفْسِ بِما عَمِلَتْ. "
50,22," <q>﴿حَدِيدࣱ﴾</q>: قَوِيُّ الَّنفاذِ في المرئِي. "
50,23," <q>﴿قَرِينُهُۥ﴾</q>: المَلَكُ الكاتِبُ الشَّهِيدُ عَلَيهِ. <q>﴿عَتِيدٌ﴾</q>: مُهَيَّأٌ محفُوظٌ. "
50,24," <q>﴿عَنِيدࣲ﴾</q>: مُعانِدٍ لِلْحَقِّ. "
50,25," <q>﴿مُعۡتَدࣲ﴾</q>: ظالِمٍ مُتَجاوِزٍ لْلِحَقِّ. <q>﴿مُّرِيبٍ﴾</q>: شاكٍّ. "
  50,26,""
50,27," <q>﴿قَرِينُهُۥ﴾</q>: شَيْطانُه الَّذِي كانَ مُوَكَّلًا بِهِ في الدُّنيا. <q>﴿مَآ أَطۡغَيۡتُهُۥ﴾</q>: ما أضْلَلْتُهُ. <q>﴿ضَلَـٰلِۭ﴾</q>: طَرِيقٍ بَعِيدٍ عن سَبِيلِ الهُدى. "
50,28," <q>﴿قَدَّمۡتُ إِلَيۡكُم بِٱلۡوَعِيدِ﴾</q>: أعْلَمْتُكُم ما يَنْتَظِرُ العاصِيَ مِن العُقُوبَةِ. "
  50,29,""
50,30," <q>﴿مَّزِيدࣲ﴾</q>: زِيادةٍ في وارِدِيها. "
50,31," <q>﴿وَأُزۡلِفَتِ﴾</q>: وقُرِّبَتْ. <q>﴿غَيۡرَ بَعِيدٍ﴾</q>: مَكانًا غَيرَ بَعِيدٍ مِنَ المُتَّقِينَ. "
50,32," <q>﴿أَوَّابٍ﴾</q>: كَثِيرِ الرُّجُوعِ مِن ذُنُوبِهِ. <q>﴿حَفِيظࣲ﴾</q>: حافظٍ لِكُلِّ عَمَلٍ صالِحٍ قَرَّبَهُ إلى ربِّهِ. "
50,33," <q>﴿بِٱلۡغَيۡبِ﴾</q>: في حالِ غِيابهِ عَنْ أعْيُنِ النّاسِ. <q>﴿مُّنِيبٍ﴾</q>: تائبٍ مِن ذُنُوبِهِ. "
50,34," <q>﴿بِسَلَـٰمࣲ﴾</q>: وأَنْتُم سالِمُونَ. <q>﴿يَوۡمُ ٱلۡخُلُودِ﴾</q>: هُوَ الَّذِي لا زَوالَ لَهُ ولا مَوْتَ. "
50,35," <q>﴿مَزِيدࣱ﴾</q>: النَّظَرُ إلى وجْهِ اللهِ الكريمِ. "
