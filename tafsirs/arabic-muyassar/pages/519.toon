quran[20]{c,v,t}:
  50,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تُوَسۡوِسُ بِهِۦ﴾</span>: تُحَدِّث بِه.</p><p><span class="qpc-hafs">﴿حَبۡلِ ٱلۡوَرِيدِ﴾</span>: عِرْقِ العُنُقِ المُتَّصِلِ بالقلبِ.</p></div>"
  50,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَلَقَّى﴾</span>: يُسَجِّلُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُتَلَقِّيَانِ﴾</span>: المَلَكانِ المُوكَّلانِ بِكِتابَةِ أعْمالِ النّاسِ وأَقْوالِهِم.</p><p><span class="qpc-hafs">﴿عَنِ ٱلۡيَمِينِ﴾</span>: عَن يَمِينِ الإنْسانِ.</p><p><span class="qpc-hafs">﴿قَعِيدࣱ﴾</span>: مُقاعِدٌ، مِثْلُ جَلِيسٍ للمُجالِسِ.</p></div>"
  50,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَقِيبٌ﴾</span>: مَلَكٌ يَرْقُبُ قَوْلَهُ ويَكْتُبُهُ.</p><p><span class="qpc-hafs">﴿عَتِيدࣱ﴾</span>: حاضِرٌ مُعَدٌّ لِذَلِكَ.</p></div>"
  50,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَكۡرَةُ ٱلۡمَوۡتِ﴾</span>: شِدَّةُ غَمَراتِ الموتِ.</p><p><span class="qpc-hafs">﴿تَحِيدُ﴾</span>: تَفِرُّ وتَهْرُبُ.</p></div>"
  50,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الَّذِي يَنْفُخُ فِيهِ إسْرافِيلُ.</p><p><span class="qpc-hafs">﴿يَوۡمُ ٱلۡوَعِيدِ﴾</span>: أي الَّذِي تَوَعَّدَ اللهُ بِه الكُفّارَ.</p></div>"
  50,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَآئِقࣱ﴾</span>: مَلَكٌ يَسُوقُ الإنْسانَ إلى المَحْشَرِ.</p><p><span class="qpc-hafs">﴿وَشَهِيدࣱ﴾</span>: مَلَكٌ يَشْهَدُ عَلى النَّفْسِ بِما عَمِلَتْ.</p></div>"
  50,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَدِيدࣱ﴾</span>: قَوِيُّ الَّنفاذِ في المرئِي.</p></div>"
  50,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرِينُهُۥ﴾</span>: المَلَكُ الكاتِبُ الشَّهِيدُ عَلَيهِ.</p><p><span class="qpc-hafs">﴿عَتِيدٌ﴾</span>: مُهَيَّأٌ محفُوظٌ.</p></div>"
  50,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنِيدࣲ﴾</span>: مُعانِدٍ لِلْحَقِّ.</p></div>"
  50,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعۡتَدࣲ﴾</span>: ظالِمٍ مُتَجاوِزٍ لْلِحَقِّ.</p><p><span class="qpc-hafs">﴿مُّرِيبٍ﴾</span>: شاكٍّ.</p></div>"
  50,26,""
  50,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَرِينُهُۥ﴾</span>: شَيْطانُه الَّذِي كانَ مُوَكَّلًا بِهِ في الدُّنيا.</p><p><span class="qpc-hafs">﴿مَآ أَطۡغَيۡتُهُۥ﴾</span>: ما أضْلَلْتُهُ.</p><p><span class="qpc-hafs">﴿ضَلَـٰلِۭ﴾</span>: طَرِيقٍ بَعِيدٍ عن سَبِيلِ الهُدى.</p></div>"
  50,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّمۡتُ إِلَيۡكُم بِٱلۡوَعِيدِ﴾</span>: أعْلَمْتُكُم ما يَنْتَظِرُ العاصِيَ مِن العُقُوبَةِ.</p></div>"
  50,29,""
  50,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّزِيدࣲ﴾</span>: زِيادةٍ في وارِدِيها.</p></div>"
  50,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُزۡلِفَتِ﴾</span>: وقُرِّبَتْ.</p><p><span class="qpc-hafs">﴿غَيۡرَ بَعِيدٍ﴾</span>: مَكانًا غَيرَ بَعِيدٍ مِنَ المُتَّقِينَ.</p></div>"
  50,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّابٍ﴾</span>: كَثِيرِ الرُّجُوعِ مِن ذُنُوبِهِ.</p><p><span class="qpc-hafs">﴿حَفِيظࣲ﴾</span>: حافظٍ لِكُلِّ عَمَلٍ صالِحٍ قَرَّبَهُ إلى ربِّهِ.</p></div>"
  50,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡغَيۡبِ﴾</span>: في حالِ غِيابهِ عَنْ أعْيُنِ النّاسِ.</p><p><span class="qpc-hafs">﴿مُّنِيبٍ﴾</span>: تائبٍ مِن ذُنُوبِهِ.</p></div>"
  50,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِسَلَـٰمࣲ﴾</span>: وأَنْتُم سالِمُونَ.</p><p><span class="qpc-hafs">﴿يَوۡمُ ٱلۡخُلُودِ﴾</span>: هُوَ الَّذِي لا زَوالَ لَهُ ولا مَوْتَ.</p></div>"
  50,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَزِيدࣱ﴾</span>: النَّظَرُ إلى وجْهِ اللهِ الكريمِ.</p></div>"