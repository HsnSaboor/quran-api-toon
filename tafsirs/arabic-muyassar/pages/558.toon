quran[5]{c,v,t}:
  65,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِذَا طَلَّقۡتُمُ﴾</span>: إذا أرَدْتُم أن تُطَلِّقُوا.</p><p><span class="qpc-hafs">﴿لِعِدَّتِهِنَّ﴾</span>: مُسْتَقْبِلاتٍ لِعِدَّتِهِنَّ، أي: في طُهْرٍ لم يَقَعْ فِيه جِماعٌ، أو في حَمْلٍ ظاهِرٍ.</p><p><span class="qpc-hafs">﴿وَأَحۡصُواْ﴾</span>: واحْفَظُوا.</p><p><span class="qpc-hafs">﴿بِفَـٰحِشَةࣲ﴾</span>: بِفعْلَةٍ مُنْكَرَةٍ ظاهِرَةٍ كالزِّنى.</p><p><span class="qpc-hafs">﴿يَتَعَدَّ﴾</span>: يَتجاوَزْه.</p><p><span class="qpc-hafs">﴿يُحۡدِثُ بَعۡدَ ذَ ٰ⁠لِكَ أَمۡرࣰا﴾</span>: يُوقِعُ في قَلْبِ الزَّوجِ الَمحَبَّةَ لِرَجْعَتِها بَعْدَ الطَّلْقةِ والطَّلْقَتيَنِ.</p></div>"
  65,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلَغۡنَ أَجَلَهُنَّ﴾</span>: قارَبْنَ نِهايةَ عِدَّتِهِنَّ.</p><p><span class="qpc-hafs">﴿فَأَمۡسِكُوهُنَّ﴾</span>: فَراجِعُوهُنَّ.</p><p><span class="qpc-hafs">﴿بِمَعۡرُوفٍ﴾</span>: بحُسْنِ مُعاشَرَةٍ وإنْفاقٍ عَلَيهِنَّ.</p><p><span class="qpc-hafs">﴿فَارِقُوهُنَّ﴾</span>: اتْرُكُوهُنَّ حتّى تَنْقَضِيَ عِدَّتُهُنَّ.</p><p><span class="qpc-hafs">﴿بِمَعۡرُوفٍ﴾</span>: مَعَ إعْطائِهنَّ حُقُوقَهُنَّ مِن غَيرِ مُضارَّةٍ بِهِنَّ.</p><p><span class="qpc-hafs">﴿وَأَقِيمُواْ ٱلشَّهَـٰدَةَ لِلَّهِ﴾</span>: أدُّوا الشَّهادةَ خالصةً للهِ.</p><p><span class="qpc-hafs">﴿مَخۡرَجࣰا﴾</span>: مِن كُلِّ ضِيقٍ.</p></div>"
  65,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَحۡتَسِبُ﴾</span>: لا يَخْطُرُ على بالِهِ ولا يَكُونُ في حِسابِهِ.</p><p><span class="qpc-hafs">﴿حَسۡبُهُۥٓ﴾</span>: كافِيهِ في جَمِيعِ أُمُورِهِ.</p><p><span class="qpc-hafs">﴿بَـٰلِغُ أَمۡرِهِۦ﴾</span>: يَقْضِي ما يُرِيدُ.</p><p><span class="qpc-hafs">﴿قَدۡرࣰا﴾</span>: أجَلًا يَنْتَهِي إلَيهِ.</p></div>"
  65,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنِ ٱرۡتَبۡتُمۡ﴾</span>: شَكَكْتُم فَلَمْ تَدْرُوا ما عِدّتُهُنَّ؟</p><p><span class="qpc-hafs">﴿وَأُوْلَـٰتُ ٱلۡأَحۡمَالِ﴾</span>: ذواتُ الحمْلِ مِنَ النِّساءِ.</p><p><span class="qpc-hafs">﴿أَجَلُهُنَّ﴾</span>: عِدَّتُهُنَّ.</p></div>"
  65,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُكَفِّرۡ عَنۡهُ سَيِّـَٔاتِهِۦ﴾</span>: يَمْحُ عَنْهُ ذُنُوبَهُ.</p><p><span class="qpc-hafs">﴿وَيُعۡظِمۡ لَهُۥٓ أَجۡرًا﴾</span>: ويُجْزِلْ لَهُ الثَّوابَ.</p></div>"