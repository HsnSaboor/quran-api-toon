quran[9]{c,v,t}:
  41,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَضَىٰهُنَّ﴾</span>: فأَوْجَدَهُنَّ وفَرَغَ من خَلْقِهنَّ.</p><p><span class="qpc-hafs">﴿وَأَوۡحَىٰ فِي كُلِّ سَمَآءٍ أَمۡرَهَا﴾</span>: وألقى في كل سماءٍ من السمواتِ السبعِ ما أراد من الأمورِ التي بها قِوامُها وصَلاحُها.</p><p><span class="qpc-hafs">﴿بِمَصَـٰبِيحَ﴾</span>: بالنجومِ المضيئةِ.</p><p><span class="qpc-hafs">﴿وَحِفۡظࣰا﴾</span>: وزَيَّنّاها حِفْظًا لها من الشياطينِ الذين يَسْتَرِقون السَّمْعَ.</p></div>"
  41,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنذَرۡتُكُمۡ﴾</span>: خَوَّفْتُكُمْ.</p><p><span class="qpc-hafs">﴿صَـٰعِقَةࣰ﴾</span>: وقْعَةَ عذابٍ يَسْتأصِلُكم.</p></div>"
  41,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنۢ بَيۡنِ أَيۡدِيهِمۡ وَمِنۡ خَلۡفِهِمۡ﴾</span>: يَتْبَعُ بعضُهم بعضًا واتصلَتْ نِذارتُهم.</p></div>"
  41,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: الُمعْجزات.</p></div>"
  41,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرۡصَرࣰا﴾</span>: شديدةَ البُرودةِ والصوتِ.</p><p><span class="qpc-hafs">﴿نَّحِسَاتࣲ﴾</span>: مَشْؤوماتٍ عليهم.</p><p><span class="qpc-hafs">﴿ٱلۡخِزۡيِ﴾</span>: الهَوانِ والهلاكِ.</p></div>"
  41,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهَدَيۡنَـٰهُمۡ﴾</span>: بيَّنّا لهم طُرُقَ الخيرِ والشرِّ.</p><p><span class="qpc-hafs">﴿ٱلۡعَمَىٰ﴾</span>: الكفرَ.</p><p><span class="qpc-hafs">﴿فَأَخَذَتۡهُمۡ﴾</span>: فأهلكَتْهُم.</p><p><span class="qpc-hafs">﴿صَـٰعِقَةُ﴾</span>: مُهْلِكَةُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَذَابِ ٱلۡهُونِ﴾</span>: الذي معه هَوانٌ وإذلالٌ.</p></div>"
  41,18,""
  41,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحۡشَرُ﴾</span>: يُجْمَعُ.</p><p><span class="qpc-hafs">﴿يُوزَعُونَ﴾</span>: تَرُدُّ زبانيةُ العذابِ أوَّلَهم على آخِرِهم؛ ليجتمِعُوا جميعًا.</p></div>"
  41,20,""