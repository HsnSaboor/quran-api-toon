quran[7]{c,v,t}:
  24,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا تُلۡهِيهِمۡ﴾</span>: لا تشْغَلُهُم.</p><p><span class="qpc-hafs">﴿تَتَقَلَّبُ﴾</span>: تَضْطَربُ وتَتَحَوَّلُ.</p></div>"
  24,38,""
  24,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَسَرَابِۭ﴾</span>: السَّرابُ: ما يُرى ظُهرًا في المفاوِزِ من لَمَعانِ الشَّمْسِ عِنْدَ اشْتِدادِ الحرِّ، يَظُنُّه العَطْشانُ ماءً.</p><p><span class="qpc-hafs">﴿بِقِيعَةࣲ﴾</span>: جَمْعِ «قاعٍ» وهو المستَوي مِنَ الأرضِ.</p></div>"
  24,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لُّجِّيࣲّ﴾</span>: عَمِيقٍ كَثِيرِ الماءِ.</p><p><span class="qpc-hafs">﴿يَغۡشَىٰهُ﴾</span>: يَعْلوُ ويُغَطِّي.</p><p><span class="qpc-hafs">﴿يَدَهُۥ لَمۡ يَكَدۡ يَرَىٰهَا﴾</span>: لم يُقارِبْ رُؤيتَها مِن شِدَّةِ الظُّلُماتِ.</p></div>"
  24,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَـٰٓفَّـٰتࣲ﴾</span>: باسِطاتٍ أجْنِحَتَها في الهَواءِ.</p><p><span class="qpc-hafs">﴿صَلَاتَهُۥ﴾</span>: أي: المُصَلِّي مِنهُم عَلِم صَلاتَه.</p><p><span class="qpc-hafs">﴿وَتَسۡبِيحَهُۥ﴾</span>: أي: المُسَبِّحُ مِنهم عَلِمَ تَسْبِيحَهُ.</p></div>"
  24,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ بعد الموتِ.</p></div>"
  24,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُزۡجِي﴾</span>: يَسُوقُ بِرِفْقٍ.</p><p><span class="qpc-hafs">﴿يُؤَلِّفُ﴾</span>: يَجْمَعُ.</p><p><span class="qpc-hafs">﴿رُكَامࣰا﴾</span>: مُجْتَمِعًا ومُتَراكِمًا بَعْضُهَ فَوْقَ بَعْضٍ.</p><p><span class="qpc-hafs">﴿ٱلۡوَدۡقَ﴾</span>: المَطَرَ.</p><p><span class="qpc-hafs">﴿مِنۡ خِلَـٰلِهِۦ﴾</span>: مِن مَّخارِجِ السَّحابِ.</p><p><span class="qpc-hafs">﴿مِن جِبَالࣲ﴾</span>: أي: مِثلِ جبالٍ في عَظَمَتِه.</p><p><span class="qpc-hafs">﴿سَنَا بَرۡقِهِۦ﴾</span>: ضَوءُ بَرْقِه ولمَعانُه.</p></div>"