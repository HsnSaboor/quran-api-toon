quran[23]{c,v,t}:
  56,77,""
  56,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّكۡنُونࣲ﴾</span>: مَصُونٍ مَسْتُورٍ، وهو الكِتابُ الَّذِي بأيدِي الملائِكةِ.</p></div>"
  56,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُطَهَّرُونَ﴾</span>: هُمُ المَلائِكةُ الَّذِينَ طَهَّرَهُم اللهُ مِنَ الآفاتِ والذُّنُوبِ.</p></div>"
  56,80,""
  56,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَدِيثِ﴾</span>: القرآنِ.</p><p><span class="qpc-hafs">﴿مُّدۡهِنُونَ﴾</span>: مُكَذِّبُونَ.</p></div>"
  56,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رِزۡقَكُمۡ﴾</span>: شُكْرَكُم لِنِعَمِ اللهِ عَلَيكُم.</p></div>"
  56,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَآ﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿بَلَغَتِ﴾</span>: أي النَّفْسُ.</p><p><span class="qpc-hafs">﴿ٱلۡحُلۡقُومَ﴾</span>: الحَلْقَ.</p></div>"
  56,84,""
  56,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَحۡنُ أَقۡرَبُ إِلَيۡهِ مِنكُمۡ﴾</span>: بِمَلائِكَتِنا ولَكِنَّكُم لا تَرَونَهُم.</p></div>"
  56,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَآ﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿غَيۡرَ مَدِينِينَ﴾</span>: غَيرَ مُحاسَبِينَ ولا مَجْزِيِّينَ بِأَعْمالِكُم.</p></div>"
  56,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡجِعُونَهَآ﴾</span>: تَرُدُّونَ النَّفْسَ.</p></div>"
  56,88,""
  56,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَوۡحࣱ﴾</span>: فَلَهُ رَحْمَةٌ وفَرَحٌ عِنْدَ مَوتِهِ.</p><p><span class="qpc-hafs">﴿وَرَيۡحَانࣱ﴾</span>: مُسْتَراحٌ.</p></div>"
  56,90,""
  56,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَلَـٰمࣱ لَّكَ﴾</span>: فسَلامةٌ لَكَ وأَمْنٌ.</p></div>"
  56,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنُزُلࣱ﴾</span>: فَضِيافَةٌ.</p><p><span class="qpc-hafs">﴿حَمِيمࣲ﴾</span>: شَرابِ جَهَنَّمَ المَغْلِيِّ.</p></div>"
  56,93,""
  56,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَصۡلِيَةُ﴾</span>: وإدْخالٌ لِيُقاسِيَ الحرَّ.</p></div>"
  56,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقُّ ٱلۡيَقِينِ﴾</span>: اليَقِينُ حقًا.</p></div>"
  56,96,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَبِّحۡ﴾</span>: فَنَزِّهْ.</p></div>"
  57,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَبَّحَ لِلَّهِ﴾</span>: نَزَّهَهُ عِنِ السُّوءِ ومَجَّدَهُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: الَّذِي لا يُغْلَبُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمُ﴾</span>: الَّذِي يَضَعُ الأَفْعالَ حِيثُ يَلِيقُ بِها.</p></div>"
  57,2,""
  57,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَوَّلُ﴾</span>: الَّذِي ليسَ قَبْلَهُ شَيءٌ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔاخِرُ﴾</span>: الَّذِي لَيسَ بَعْدَه شَيءٌ.</p><p><span class="qpc-hafs">﴿ٱلظَّـٰهِرُ﴾</span>: الَّذِي لَيسَ فَوْقَه شَيءٌ.</p><p><span class="qpc-hafs">﴿ٱلۡبَاطِنُ﴾</span>: الَّذِي لَيسَ دُونَهُ شَيءٌ.</p></div>"