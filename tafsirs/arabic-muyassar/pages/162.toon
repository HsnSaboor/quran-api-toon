quran[8]{c,v,t}:
  7,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَكۡبَرُواْ﴾</span>: استعلَوْا عن الإيمانِ.</p><p><span class="qpc-hafs">﴿مِلَّتِنَا﴾</span>: دينِنا.</p></div>"
  7,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱفۡتَحۡ﴾</span>: احكُمْ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰتِحِينَ﴾</span>: الحاكمين.</p></div>"
  7,90,"<div class=ar lang=ar></div>"
  7,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّجۡفَةُ﴾</span>: الزَّلزلةُ الشديدةُ من الأرضِ.</p><p><span class="qpc-hafs">﴿جَـٰثِمِينَ﴾</span>: لاصِقين بالأرضِ على رُكَبِهم ووجوهِهم، لا حَراكَ بهم.</p></div>"
  7,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَا﴾</span>: كأنّ قومَ شُعَيبٍ لم يُقيموا في ديارِهم، و يتمتَّعوا فيها.</p></div>"
  7,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّىٰ﴾</span>: فأَعرَضَ.</p><p><span class="qpc-hafs">﴿ءَاسَىٰ﴾</span>: أحْزَنُ.</p></div>"
  7,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن نَّبِيٍّ﴾</span>: أي: كذَّبه قومُه.</p><p><span class="qpc-hafs">﴿أَخَذۡنَآ﴾</span>: ابتلَينا.</p><p><span class="qpc-hafs">﴿بِٱلۡبَأۡسَآءِ﴾</span>: البؤسِ وضيقِ المعيشةِ.</p><p><span class="qpc-hafs">﴿وَٱلضَّرَّآءِ﴾</span>: ما يَضرُّ الإنسانَ في نفسِه أو معيشتِه.</p><p><span class="qpc-hafs">﴿يَضَّرَّعُونَ﴾</span>: يُظْهِرُون الخضوعَ والاستكانةَ للهِ.</p></div>"
  7,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّيِّئَةِ﴾</span>: الحالِ السيئةِ من البلاءِ والجَدْبِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَسَنَةَ﴾</span>: الحالَ الحسنةَ من الرَّخاءِ والنِّعمةِ والعافيةِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ عَفَواْ﴾</span>: حتى كَثُروا وكَثُرَتْ أموالُهم.</p><p><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُم﴾</span>: فأهلَكْناهم.</p><p><span class="qpc-hafs">﴿بَغۡتَةࣰ﴾</span>: فَجْأةً.</p></div>"