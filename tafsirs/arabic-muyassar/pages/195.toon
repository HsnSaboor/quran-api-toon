quran[7]{c,v,t}:
  9,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتَغَوُاْ﴾</span>: طلبُوا وأرادوا.</p><p><span class="qpc-hafs">﴿ٱلۡفِتۡنَةَ﴾</span>: فتنةَ المؤمنين وصَدَّهم عن دينِهم.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: من قبلِ غزوةِ «تبوكَ».</p><p><span class="qpc-hafs">﴿وَقَلَّبُواْ لَكَ ٱلۡأُمُورَ﴾</span>: أرادُوا إبطالَ ما جِئْتَ به بتحايُلِهم ومَكْرِهم.</p><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: النصرُ من عندِ اللهِ.</p><p><span class="qpc-hafs">﴿وَظَهَرَ﴾</span>: علا وغَلَبَ.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: دينُه، وهو الإسلامُ.</p></div>"
  9,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنۡهُم﴾</span>: ومن المنافقين.</p><p><span class="qpc-hafs">﴿ٱئۡذَن لِّي﴾</span>: في التخَلُّف عن الجهادِ.</p><p><span class="qpc-hafs">﴿وَلَا تَفۡتِنِّيٓ﴾</span>: لاتُوقِعْني في فتنةِ النِّساءِ حالةَ الخروجِ معك.</p><p><span class="qpc-hafs">﴿فِي ٱلۡفِتۡنَةِ﴾</span>: فتنةِ النِّفاقِ والتخلُّفِ عن الجهادِ.</p><p><span class="qpc-hafs">﴿سَقَطُواْ﴾</span>: وقعوا في الإثمِ لمخالَفَتِهم أمرَ اللهِ ورسولِه.</p></div>"
  9,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسَنَةࣱ﴾</span>: نصرٌ وغنيمةٌ.</p><p><span class="qpc-hafs">﴿مُصِيبَةࣱ﴾</span>: مَكْرُوهٌ من هزيمةٍ أو شدَّةٍ.</p><p><span class="qpc-hafs">﴿قَدۡ أَخَذۡنَآ أَمۡرَنَا مِن قَبۡلُ﴾</span>: قد احْتَطْنا لأنفسِنا حين تَخَلَّفْنا عن الجهادِ قبلَ هذه المصيبةِ.</p><p><span class="qpc-hafs">﴿وَيَتَوَلَّواْ﴾</span>: وينصَرِفُوا.</p></div>"
  9,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا كَتَبَ ٱللَّهُ لَنَا﴾</span>: ما قَدَّرَه علينا.</p><p><span class="qpc-hafs">﴿هُوَ مَوۡلَىٰنَا﴾</span>: ناصِرُنا ومُتَوَلِّي أمورِنا.</p><p><span class="qpc-hafs">﴿وَعَلَى ٱللَّهِ فَلۡيَتَوَكَّلِ﴾</span>: فلْيَعْتَمِدْ ولْيُفَوِّضْ أمرَه إليه.</p></div>"
  9,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلۡ تَرَبَّصُونَ﴾</span>: ما تنتظرون أن يَقَعَ.</p><p><span class="qpc-hafs">﴿إِحۡدَى ٱلۡحُسۡنَيَيۡنِ﴾</span>: إحدى العاقبتَين: النصرَ، أوالشهادةَ في سبيلِ اللهِ.</p></div>"
  9,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَوۡعًا﴾</span>: طائعِين.</p><p><span class="qpc-hafs">﴿كَرۡهࣰا﴾</span>: كارهِين.</p><p><span class="qpc-hafs">﴿فَـٰسِقِينَ﴾</span>: خارجِين عن دينِ اللهِ.</p></div>"
  9,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُسَالَىٰ﴾</span>: متثاقلون عن الصَّلاةِ.</p></div>"