quran[7]{c,v,t}:
  9,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡفَ يَكُونُ﴾</span>: لا يكونُ.</p><p><span class="qpc-hafs">﴿عَهۡدٌ﴾</span>: التزامٌ بميثاقٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span>: الحَرَمِ كلِّه.</p><p><span class="qpc-hafs">﴿فَمَا ٱسۡتَقَـٰمُواْ لَكُمۡ﴾</span>: فما أقاموا على الوفاءِ بعهدكم.</p></div>"
  9,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظۡهَرُواْ عَلَيۡكُمۡ﴾</span>: يَظْفَرُوا بكم ويَغْلِبوكم.</p><p><span class="qpc-hafs">﴿لَا يَرۡقُبُواْ﴾</span>: لا يُراعُوا.</p><p><span class="qpc-hafs">﴿إِلࣰّا﴾</span>: قَرابةً ولا حِلْفًا.</p><p><span class="qpc-hafs">﴿ذِمَّةࣰ﴾</span>: عَهْدًا ولا حَقًّا.</p></div>"
  9,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱشۡتَرَوۡاْ﴾</span>: استبدَلُوا.</p><p><span class="qpc-hafs">﴿ثَمَنࣰا قَلِيلࣰا﴾</span>: عَرَضَ الدنيا الزائلَ.</p><p><span class="qpc-hafs">﴿فَصَدُّواْ عَن سَبِيلِهِۦٓ﴾</span>: فأعرضُوا عن الحقِّ، ومنعُوا غيرَهم عنه.</p><p><span class="qpc-hafs">﴿سَآءَ﴾</span>: قَبُحَ.</p></div>"
  9,10,"<div class=ar lang=ar></div>"
  9,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُفَصِّلُ﴾</span>: نُبيِّنُ.</p></div>"
  9,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّكَثُوٓاْ﴾</span>: نَقَضُوا.</p><p><span class="qpc-hafs">﴿أَيۡمَـٰنَهُم﴾</span>: مواثيقَهم المؤكَّدةَ بالأَيْمان.</p><p><span class="qpc-hafs">﴿وَطَعَنُواْ فِي دِينِكُمۡ﴾</span>: ذَمُّوا الإسلامَ وعابُوه.</p><p><span class="qpc-hafs">﴿لَآ أَيۡمَـٰنَ لَهُمۡ﴾</span>: لا عهودَ لهم يُوَفّى بها.</p></div>"
  9,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَمُّواْ﴾</span>: وعَزَمُوا وعَمِلوا.</p><p><span class="qpc-hafs">﴿بَدَءُوكُمۡ﴾</span>: بالإيذاءِ والقتالِ.</p><p><span class="qpc-hafs">﴿أَوَّلَ مَرَّةٍ﴾</span>: أولَ الأمرِ «بمكةَ» «وببَدْرٍ» وغيرِهما.</p><p><span class="qpc-hafs">﴿أَتَخۡشَوۡنَهُمۡ﴾</span>: أتَخافُونهم، أو أتخافون ملاقاتَهم في الحربِ؟</p></div>"