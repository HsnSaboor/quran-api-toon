quran[9]{c,v,t}:
  41,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلَ مَرَّةࣲ﴾</span>: الخَلْقَ الأَوَّلَ ولَمْ تَكُونُوا شيئًا.</p></div>"
  41,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡتَتِرُونَ﴾</span>: تَسْتَخْفُونَ عِنْدَ ارْتِكابِكُم المعاصِيَ في الدُّنيا.</p><p><span class="qpc-hafs">﴿أَن يَشۡهَدَ﴾</span>: مَخافَةَ أن يَشْهَدَ.</p></div>"
  41,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡدَىٰكُمۡ﴾</span>: أهْلَكَكُم، فَأَوْرَدَكُم النّارَ.</p><p><span class="qpc-hafs">﴿ٱلۡخَـٰسِرِينَ﴾</span>: الهالِكِينَ.</p></div>"
  41,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثۡوࣰى﴾</span>: مَأْوىً.</p><p><span class="qpc-hafs">﴿يَسۡتَعۡتِبُواْ﴾</span>: يَسْأَلُوا العُتْبى وهي الرَّجْعَةُ لَهُم إلى الَّذِي يُحِبُّونَ بِتَخْفِيفِ العَذابِ عَنْهُم.</p><p><span class="qpc-hafs">﴿ٱلۡمُعۡتَبِينَ﴾</span>: الَّذِينَ يُقْبَلُ عُذْرُهُم ويُجابُونَ إلى ما طَلَبُوا.</p></div>"
  41,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَيَّضۡنَا﴾</span>: هَيَّأنا وأَعْدَدْنا.</p><p><span class="qpc-hafs">﴿قُرَنَآءَ﴾</span>: نُظَراءَ مُلازِمِينَ مِن شَياطِينِ الإنْسِ والجِنِّ.</p><p><span class="qpc-hafs">﴿فَزَيَّنُواْ﴾</span>: فَحَسّنُوا.</p><p><span class="qpc-hafs">﴿مَّا بَيۡنَ أَيۡدِيهِمۡ﴾</span>: مِن أمْرِ الدُّنيا حتّى آثَرُوها على الآخِرةِ.</p><p><span class="qpc-hafs">﴿وَمَا خَلۡفَهُمۡ﴾</span>: ما بَعْدَ مَماتِهم وذَلكَ بالتَّكْذِيبِ بالَمعادِ.</p><p><span class="qpc-hafs">﴿وَحَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾</span>: وجَبَ لَهُم العَذابُ.</p><p><span class="qpc-hafs">﴿فِيٓ أُمَمࣲ﴾</span>: في جُمْلةِ أُمَمٍ كافِرةٍ.</p><p><span class="qpc-hafs">﴿قَدۡ خَلَتۡ﴾</span>: مَضَتْ.</p></div>"
  41,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡغَوۡاْ﴾</span>: وأْتُوا فِيهِ بالتَّخْلِيطِ والصَّفِيرِ عِنْدَ قِراءتِهِ.</p></div>"
  41,27,"<div class=ar lang=ar></div>"
  41,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَارُ ٱلۡخُلۡدِ﴾</span>: دارُ الإقامةِ الدّائِمَةِ.</p><p><span class="qpc-hafs">﴿يَجۡحَدُونَ﴾</span>: يَكْفُرُونَ.</p></div>"
  41,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَسۡفَلِينَ﴾</span>: أشَدَّ عَذابًا مِنّا.</p></div>"