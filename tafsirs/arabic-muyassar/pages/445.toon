quran[13]{c,v,t}:
  36,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّمَّا عَمِلَتۡ أَيۡدِينَآ﴾</span>: أي: مما أبْدَعْناهُ وعَمِلْناهُ.</p><p><span class="qpc-hafs">﴿لَهَا مَـٰلِكُونَ﴾</span>: مالِكُونَ أمْرَها، يَتَصَرَّفُونَ بِها كيفَ شاؤُوا.</p></div>"
  36,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَلَّلۡنَـٰهَا﴾</span>: سَخَّرْناها لَهُم.</p><p><span class="qpc-hafs">﴿رَكُوبُهُمۡ﴾</span>: مَرْكُوبُهم الّذي يَرْكَبُونَه.</p></div>"
  36,73,""
  36,74,""
  36,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهُمۡ لَهُمۡ جُندࣱ مُّحۡضَرُونَ﴾</span>: والحالُ أنَّ هذه الآلهةَ قَدْ أُحْضِرَتْ مُجْتَمِعَةً لِتُعايِنَ عذابَ عابِديِها، وهي لا تَسْتَطِيعُ نَصْرَهُم.</p></div>"
  36,76,""
  36,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن نُّطۡفَةࣲ﴾</span>: هي مَنِيُّ الرَّجُلِ يقْذِفُه في رَحمِ امْرَأتِه.</p><p><span class="qpc-hafs">﴿خَصِيمࣱ﴾</span>: كثيرُ الخُصُومَةِ بالباطلِ.</p></div>"
  36,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَمِيمࣱ﴾</span>: باليةٌ مُتفَتِّتةٌ.</p></div>"
  36,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنشَأَهَآ﴾</span>: خَلَقَها.</p></div>"
  36,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّنۡهُ تُوقِدُونَ﴾</span>: تَقْدَحُونَ منه.</p></div>"
  36,81,""
  36,82,""
  36,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَلَكُوتُ﴾</span>: هو المُلْكُ التّامُّ للأشياءِ كلِّها.</p></div>"