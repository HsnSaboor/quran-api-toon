quran[9]{c,v,t}:
  6,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلࣱ﴾</span>: رقيبٌ مُدَبِّرٌ لأمورِ خَلْقِه.</p></div>"
  6,103,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا تُدۡرِكُهُ﴾</span>: لا تُحيطُ به، ولا تَبْلُغُ كُنْهَ حَقيقتِه.</p></div>"
  6,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَصَآئِرُ﴾</span>: براهينُ واضحةٌ.</p><p><span class="qpc-hafs">﴿فَعَلَيۡهَا﴾</span>: فعلى نفسِه يعودُ وبالُ ذلك.</p><p><span class="qpc-hafs">﴿بِحَفِيظࣲ﴾</span>: أُحْصِي أعمالَكم، بل أنا مُبَلِّغٌ.</p></div>"
  6,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾</span>: نُبَيِّنُ البراهينَ، والحُجَجَ.</p><p><span class="qpc-hafs">﴿وَلِيَقُولُواْ دَرَسۡتَ﴾</span>: أي: لتقومَ الحُجَّةُ عليهم، وليقولوا: تَعَلَّمْتَ من أهلِ الكتابِ.</p></div>"
  6,106,""
  6,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَفِيظࣰا﴾</span>: رقيبًا تحفَظُ أقوالَهم وأعمالَهم.</p><p><span class="qpc-hafs">﴿بِوَكِيلࣲ﴾</span>: مُوَكَّلٍ على أمورِهم.</p></div>"
  6,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يَدۡعُونَ مِن دُونِ ٱللَّهِ﴾</span>: هم الأصنامُ.</p><p><span class="qpc-hafs">﴿عَدۡوَۢا﴾</span>: اعتداءً.</p><p><span class="qpc-hafs">﴿زَيَّنَّا﴾</span>: حَسَّنّا.</p></div>"
  6,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: بأيمانٍ مُؤَكَّدةٍ.</p><p><span class="qpc-hafs">﴿ءَايَةࣱ﴾</span>: معجزةٌ خارقةٌ:</p><p><span class="qpc-hafs">﴿وَمَا يُشۡعِرُكُمۡ﴾</span>: وما يُدْريكم.</p><p><span class="qpc-hafs">﴿أَنَّهَآ﴾</span>: لعلَّ المعجزاتِ.</p></div>"
  6,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُقَلِّبُ أَفۡـِٔدَتَهُمۡ﴾</span>: فنَحُولُ بينَهم وبينَ الإيمانِ.</p><p><span class="qpc-hafs">﴿فِي طُغۡيَـٰنِهِمۡ﴾</span>: في تَمَرُّدِهم.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يَتَحَيَّرون، فلا يَهْتَدُون إلى الحقِّ.</p></div>"