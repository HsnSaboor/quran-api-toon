quran[24]{c,v,t}:
37,1," <q>﴿وَٱلصَّـٰٓفَّـٰتِ﴾</q>: هي الملائِكَةُ التي تَصْطَفُّ في عِبادَتِها. "
37,2," <q>﴿فَٱلزَّ ٰ⁠جِرَ ٰ⁠تِ﴾</q>: هي الملائكةُ التي تَزْجُرُ السَّحابَ وتَسُوقُه. "
37,3," <q>﴿ذِكۡرًا﴾</q>: هو القرآنُ. "
  37,4,""
  37,5,""
37,6," <q>﴿ٱلۡكَوَاكِبِ﴾</q>: النُّجُومِ. "
37,7," <q>﴿مَّارِدࣲ﴾</q>: مُتَمَرِّدٍ خارجٍ عَنِ الطّاعةِ. "
37,8," <q>﴿وَيُقۡذَفُونَ﴾</q>: ويُرجَمُونَ (بالشُّهُبِ). "
37,9," <q>﴿دُحُورࣰا﴾</q>: إبْعادًا وطَرْدًا. <q>﴿وَاصِبٌ﴾</q>: دائمٌ لا يَنْقَطِعُ. "
37,10," <q>﴿خَطِفَ ٱلۡخَطۡفَةَ﴾</q>: أي: اسْتَرَقَ السَّمْعَ خِلْسةً. <q>﴿فَأَتۡبَعَهُۥ﴾</q>: تَبِعَه ولحِقَه. <q>﴿شِهَابࣱ ثَاقِبࣱ﴾</q>: نَجْمٌ مُضِيءٌ. "
37,11," <q>﴿لَّازِبِۭ﴾</q>: مُلْتَزِقٍ بَعْضُه ببَعْضٍ. "
37,12," <q>﴿وَيَسۡخَرُونَ﴾</q>: يَسْتَهْزِئُونَ بِكَ. "
  37,13,""
37,14," <q>﴿ءَايَةࣰ﴾</q>: مُعْجِزَةً مِن مُّعْجِزاتِكَ. <q>﴿يَسۡتَسۡخِرُونَ﴾</q>: يبالِغُونَ في سُخْرِيَّتِهِم. "
  37,15,""
  37,16,""
  37,17,""
37,18," <q>﴿دَ ٰ⁠خِرُونَ﴾</q>: أذِلّاءُ صاغِرُونَ. "
37,19," <q>﴿زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ﴾</q>: نَفْخَةٌ واحِدَةٌ. "
37,20," <q>﴿يَـٰوَيۡلَنَا﴾</q>: يا هَلاكَنا. "
37,21," <q>﴿يَوۡمُ ٱلۡفَصۡلِ﴾</q>: يومُ القضاءِ بَيْنَ الخَلْقِ. "
37,22," <q>﴿ٱحۡشُرُواْ﴾</q>: اجْمَعُوا. <q>﴿وَأَزۡوَ ٰ⁠جَهُمۡ﴾</q>: قُرَناءَهُم ونُظراءَهُم. "
37,23," <q>﴿فَٱهۡدُوهُمۡ إِلَىٰ صِرَ ٰ⁠طِ ٱلۡجَحِيمِ﴾</q>: دُلُّوهُم إلى طَرِيقِ النّارِ، وسُوقُوهُم إليها. "
37,24," <q>﴿وَقِفُوهُمۡ﴾</q>: احْبِسُوهُم في مَوْقِفِ الحِسابِ. "
