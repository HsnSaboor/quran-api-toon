quran[15]{c,v,t}:
  23,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡتُونَ مَآ ءَاتَواْ﴾</span>: يُعْطُونَ ما أعْطَوا مِنَ الصَّدقاتِ.</p><p><span class="qpc-hafs">﴿وَجِلَةٌ﴾</span>: خائِفَةٌ.</p></div>"
  23,61,"<div class=ar lang=ar></div>"
  23,62,"23:61"
  23,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي غَمۡرَةࣲ﴾</span>: في غَفْلَةٍ.</p><p><span class="qpc-hafs">﴿مِّن دُونِ ذَ ٰ⁠لِكَ﴾</span>: مِن دُونِ الشِّركِ.</p></div>"
  23,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتۡرَفِيهِم﴾</span>: مُنَعَّمِيهِم الذين أبْطَرَتْهُم النِّعَمُ.</p><p><span class="qpc-hafs">﴿يَجۡـَٔرُونَ﴾</span>: يَصْرُخُونَ مُسْتَغِيثِينَ.</p></div>"
  23,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَجۡـَٔرُواْ﴾</span>: لا تَصْرُخُوا.</p></div>"
  23,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنكِصُونَ﴾</span>: تَرْجِعُونَ وراءَكُم مُعْرِضِينَ عَنْ سَماعِ الآياتِ.</p></div>"
  23,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِهِۦ سَـٰمِرࣰا﴾</span>: أي: مُتَسامِرِينَ باللَّيلِ حَولَ الكَعْبَةِ.</p><p><span class="qpc-hafs">﴿تَهۡجُرُونَ﴾</span>: تَتَكَلَّمُونَ بِساقِطِ القولِ.</p></div>"
  23,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَلَمۡ يَدَّبَّرُواْ ٱلۡقَوۡلَ﴾</span>: أفلم يَتَفَكَّرُوا في القرآنِ.</p></div>"
  23,69,"<div class=ar lang=ar></div>"
  23,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جِنَّةُۢ﴾</span>: جُنُونٌ.</p></div>"
  23,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِذِكۡرِهِمۡ﴾</span>: بالقرآنِ الذي فِيهِ عِزُّهُم وشَرفُهُم.</p></div>"
  23,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَرۡجࣰا﴾</span>: أجْرًا مِنَ المالِ.</p><p><span class="qpc-hafs">﴿فَخَرَاجُ رَبِّكَ﴾</span>: ثوابُ اللهِ وعَطاؤُه.</p></div>"
  23,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: دِينٍ قَوِيمٍ وهو الإسْلامُ.</p></div>"
  23,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَـٰكِبُونَ﴾</span>: لمائِلُونَ ومُنْحَرِفُونَ عَنْه.</p></div>"