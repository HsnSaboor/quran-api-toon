quran[11]{c,v,t}:
  17,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱبۡتِغَآءَ رَحۡمَةࣲ﴾</span>: طَلَبًا لرزقٍ تنتظرُه.</p><p><span class="qpc-hafs">﴿مَّيۡسُورࣰا﴾</span>: لَيِّنًا لطيفًا.</p></div>"
  17,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَغۡلُولَةً﴾</span>: مقبوضَةً عن الإنفاقِ في الخيرِ.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡسُطۡهَا كُلَّ ٱلۡبَسۡطِ﴾</span>: لا تُسْرِفْ، ولا تتوسَّعْ في النفقةِ فوقَ طاقَتِك.</p><p><span class="qpc-hafs">﴿مَّحۡسُورًا﴾</span>: نادمًا على إسرافِك وضَياعِ مالِك.</p></div>"
  17,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡسُطُ ٱلرِّزۡقَ﴾</span>: يُوَسِّعُه.</p><p><span class="qpc-hafs">﴿وَيَقۡدِرُ﴾</span>: ويُضَيِّقُه.</p></div>"
  17,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِمۡلَـٰقࣲ﴾</span>: فَقْرٍ.</p><p><span class="qpc-hafs">﴿خِطۡـࣰٔا﴾</span>: إثمًا.</p></div>"
  17,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـٰحِشَةࣰ﴾</span>: فَعْلَةً قبيحةً ظاهرةَ القُبْحِ.</p><p><span class="qpc-hafs">﴿وَسَآءَ سَبِيلࣰا﴾</span>: بئسَ الطريقُ طريقُه.</p></div>"
  17,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَقَدۡ جَعَلۡنَا﴾</span>: بما أذِنَ فيه الشَّرْعُ، كالقِصاصِ.</p><p><span class="qpc-hafs">﴿لِوَلِيِّهِۦ﴾</span>: لِمَن يَلي أمرَه مِن وارثٍ أو حاكمٍ.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣰا﴾</span>: حُجَّةً في طَلَبِ قَتْلِ القاتلِ أو الدِّيَةِ.</p><p><span class="qpc-hafs">﴿فَلَا يُسۡرِف فِّي ٱلۡقَتۡلِ﴾</span>: لا يُجاوِزِ الحَدَّ المشروعَ فيه.</p></div>"
  17,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡيَتِيمِ﴾</span>: مَن مات أبوه وهو دونَ سِنِّ البُلوغِ.</p><p><span class="qpc-hafs">﴿هِيَ أَحۡسَنُ﴾</span>: بالطريقةِ الحُسنى.</p><p><span class="qpc-hafs">﴿يَبۡلُغَ أَشُدَّهُۥ﴾</span>: قوتَه على حِفْظِ مالِه، وحُسْنِ التصرُّفِ فيه.</p><p><span class="qpc-hafs">﴿مَسۡـُٔولࣰا﴾</span>: يُسأَل صاحبُ العهدِ عنه، ويحاسَبُ يومَ القيامةِ.</p></div>"
  17,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطَاسِ ٱلۡمُسۡتَقِيمِ﴾</span>: بالميزانِ السَّوِيِّ.</p><p><span class="qpc-hafs">﴿تَأۡوِيلࣰا﴾</span>: مآلًا وعاقبةً عندَ اللهِ.</p></div>"
  17,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَقۡفُ﴾</span>: لا تَتَّبِعْ.</p><p><span class="qpc-hafs">﴿مَا لَيۡسَ لَكَ بِهِۦ عِلۡمٌ﴾</span>: ما لا عِلْمَ لك به من قولٍ أو فِعْلٍ.</p><p><span class="qpc-hafs">﴿وَٱلۡفُؤَادَ﴾</span>: القلبَ.</p><p><span class="qpc-hafs">﴿مَسۡـُٔولࣰا﴾</span>: أي: صاحبُها، يُسْأَلُ عَمّا فَعَلَ بها.</p></div>"
  17,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَرَحًا﴾</span>: فَخْرًا وتكبُّرًا.</p><p><span class="qpc-hafs">﴿لَن تَخۡرِقَ ٱلۡأَرۡضَ﴾</span>: تَثْقُبَها بمَشْيِك عليها بهذه الصفةِ.</p></div>"
  17,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلُّ ذَ ٰ⁠لِكَ﴾</span>: ما تَقَدَّم ذِكْرُه من الأوامرِ والنَّواهي.</p><p><span class="qpc-hafs">﴿كَانَ سَيِّئُهُۥ﴾</span>: السَّيِّئُ منه، هو الَمنْهِيّاتُ.</p></div>"