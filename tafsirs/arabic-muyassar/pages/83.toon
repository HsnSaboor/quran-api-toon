quran[7]{c,v,t}:
  4,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَّبِعُونَ ٱلشَّهَوَ ٰ⁠تِ﴾</span>: يَنْقادُون لشهَواتِ أنفسِهم من أهلِ الباطلِ.</p><p><span class="qpc-hafs">﴿تَمِيلُواْ﴾</span>: تَنْحَرفُوا عن الدِّينِ بإتيانِكم ما حَرَّمَ عليكم.</p></div>"
  4,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يُخَفِّفَ﴾</span>: أن يُيَسِّرَ عليكم.</p></div>"
  4,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: كالرِّبا والقِمار.</p><p><span class="qpc-hafs">﴿تِجَـٰرَةً﴾</span>: موافِقَةً للشَّرعِ.</p><p><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوٓاْ أَنفُسَكُمۡ﴾</span>: بألّا تُهْلِكُوها بارتكابِ المعاصي، وألّا يقتلَ بعضُكم بعضًا، وألّا يقتلَ نفسَه حقيقةً.</p></div>"
  4,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: ما نهى اللهُ عنه مما تقدَّم.</p><p><span class="qpc-hafs">﴿عُدۡوَ ٰ⁠نࣰا﴾</span>: متجاوِزًا حَدَّ الشَّرْعِ.</p></div>"
  4,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَبَآئِرَ مَا تُنۡهَوۡنَ عَنۡهُ﴾</span>: هي كلُّ ذَنْبٍ رَتَّبَ اللهُ عليه الحَدَّ، أو صَرَّح بالوعيدِ فيه.</p><p><span class="qpc-hafs">﴿سَيِّـَٔاتِكُمۡ﴾</span>: الصَّغائرَ.</p><p><span class="qpc-hafs">﴿مُّدۡخَلࣰا كَرِيمࣰا﴾</span>: الجنةَ.</p></div>"
  4,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا فَضَّلَ ٱللَّهُ بِهِۦ بَعۡضَكُمۡ عَلَىٰ بَعۡضࣲ﴾</span>: ما فَضَّل اللهُ به غيرَكم عليكم في المواهِبِ والأرزاقِ.</p><p><span class="qpc-hafs">﴿نَصِيبࣱ﴾</span>: مقدارٌ من الجزاءِ بحسَبِ العملِ.</p><p><span class="qpc-hafs">﴿مِن فَضۡلِهِۦٓ﴾</span>: من عَوْنِه، وتوفيقِه.</p></div>"
  4,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِكُلࣲّ﴾</span>: ولكلِّ واحدٍ.</p><p><span class="qpc-hafs">﴿مَوَ ٰ⁠لِيَ﴾</span>: ورَثَةٌ يرثُون.</p><p><span class="qpc-hafs">﴿عَقَدَتۡ أَيۡمَـٰنُكُمۡ﴾</span>: تحالَفْتُم معهم بالأيمانِ على النُّصرةِ، وإعطائِهم قَدْرًا من الميراثِ، وهذا منسوخٌ.</p></div>"