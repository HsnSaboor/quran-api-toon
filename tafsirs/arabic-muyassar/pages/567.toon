quran[26]{c,v,t}:
  69,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمُؤۡتَفِكَـٰتُ﴾</span>: وأَهلُ قُرى قَوْمِ لُوطٍ الَّذِينَ انْقَلَبَتْ بِهم دِيارُهُم.</p><p><span class="qpc-hafs">﴿بِٱلۡخَاطِئَةِ﴾</span>: بِسَبَبِ الفَعْلَةِ المنكرَةِ مِنَ الكُفْرِ والفواحِشِ.</p></div>"
  69,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَخَذَهُمۡ﴾</span>: فَأَهْلَكَهُم.</p><p><span class="qpc-hafs">﴿رَّابِيَةً﴾</span>: بالِغةً في الشِّدَّةِ.</p></div>"
  69,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَا ٱلۡمَآءُ﴾</span>: جاوَزَ حَدَّهُ حتّى عَلا وارْتَفَعَ فَوْقَ كُلِّ شَيءٍ.</p><p><span class="qpc-hafs">﴿حَمَلۡنَـٰكُمۡ﴾</span>: حَمَلْناكُم وأنتُم في أصْلابِ آبائِكُم وأُمَّهاتِكُم.</p><p><span class="qpc-hafs">﴿ٱلۡجَارِيَةِ﴾</span>: السَّفِينَةِ الَّتِي تَجْرِي في الماءِ.</p></div>"
  69,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِنَجۡعَلَهَا﴾</span>: لِنَجْعَلَ الواقِعةَ الَّتِي نَجا فِيها المُؤمِنُونَ، وأُغْرِقَ فِيها الكافِرُونَ.</p><p><span class="qpc-hafs">﴿تَذۡكِرَةࣰ﴾</span>: عِبْرةً وعِظَةً.</p><p><span class="qpc-hafs">﴿وَتَعِيَهَآ﴾</span>: وتَحْفَظَها.</p></div>"
  69,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلصُّورِ﴾</span>: القَرْنِ الَّذِي يَنْفُخُ فيه المَلَكُ عِنْدَ قِيامِ السّاعةِ.</p></div>"
  69,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحُمِلَتِ ٱلۡأَرۡضُ وَٱلۡجِبَالُ﴾</span>: رُفِعَت عن أماكِنِها.</p><p><span class="qpc-hafs">﴿فَدُكَّتَا دَكَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: دُقَّتا دَقَّةً واحِدَةً.</p></div>"
  69,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَعَتِ ٱلۡوَاقِعَةُ﴾</span>: قامَتِ القِيامةِ.</p></div>"
  69,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱنشَقَّتِ﴾</span>: انْصَدَعَتْ مُتَشَقِّقَةً.</p><p><span class="qpc-hafs">﴿وَاهِيَةࣱ﴾</span>: ضَعِيفَةٌ لا تَماسُكَ فِيها.</p></div>"
  69,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمَلَكُ عَلَىٰٓ أَرۡجَآئِهَا﴾</span>: والملائِكَةُ على أطْرافِها.</p><p><span class="qpc-hafs">﴿عَرۡشَ رَبِّكَ﴾</span>: وهو سَرِيرُ الملْكِ الَّذِي تَحْمِلُه الملائِكةُ، واسْتَوى عَلَيهِ الرحمنُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ جَنَّةِ الفِرْدَوسِ.</p><p><span class="qpc-hafs">﴿ثَمَـٰنِيَةࣱ﴾</span>: أي من الملائِكةِ العِظامِ.</p></div>"
  69,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُعۡرَضُونَ﴾</span>: أي: عَلى اللهِ.</p><p><span class="qpc-hafs">﴿لَا تَخۡفَىٰ مِنكُمۡ خَافِيَةࣱ﴾</span>: لا تَخْفى عَلى اللهِ نَفْسٌ خافِيةٌ مِنكُم.</p></div>"
  69,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَآؤُمُ﴾</span>: تعالَوا.</p></div>"
  69,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَنَنتُ﴾</span>: أيْقَنْتُ.</p><p><span class="qpc-hafs">﴿حِسَابِيَهۡ﴾</span>: جَزائِي يومَ القيامةِ.</p></div>"
  69,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَّاضِيَةࣲ﴾</span>: مَرْضِيَّةٍ.</p></div>"
  69,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَالِيَةࣲ﴾</span>: مُرْتَفِعَةِ المكانِ والدَّرجاتِ.</p></div>"
  69,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُطُوفُهَا﴾</span>: ثِمارُها.</p><p><span class="qpc-hafs">﴿دَانِيَةࣱ﴾</span>: قَرِيبَةُ التَّناوُلِ.</p></div>"
  69,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَنِيٓـَٔۢا﴾</span>: أكْلًا وشُرْبًا يَهْنأُ بِهما صاحِبُهُما.</p><p><span class="qpc-hafs">﴿أَسۡلَفۡتُمۡ﴾</span>: قدَّمْتُم.</p><p><span class="qpc-hafs">﴿ٱلۡأَيَّامِ ٱلۡخَالِيَةِ﴾</span>: أيّامِ الدُّنيا الماضِيةِ.</p></div>"
  69,25,""
  69,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِسَابِيَهۡ﴾</span>: جَزائِي.</p></div>"
  69,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰلَيۡتَهَا﴾</span>: ياليتَ الموتَةَ الَّتِي مِتُّها في الدُّنيا.</p><p><span class="qpc-hafs">﴿ٱلۡقَاضِيَةَ﴾</span>: القاطِعةَ لِأَمْرِي فلا أُبْعَثُ.</p></div>"
  69,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَآ أَغۡنَىٰ﴾</span>: ما نَفَعَ.</p></div>"
  69,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلَكَ﴾</span>: غابَ.</p><p><span class="qpc-hafs">﴿سُلۡطَـٰنِيَهۡ﴾</span>: مُلْكِي.</p></div>"
  69,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَغُلُّوهُ﴾</span>: اجْعَلُوا القَيْدَ في عُنُقِه.</p></div>"
  69,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَلُّوهُ﴾</span>: أدْخِلُوهُ.</p></div>"
  69,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِلۡسِلَةࣲ﴾</span>: مَجْمُوعِ حَلَقٍ مِن حَدِيدٍ داخِلٍ بَعْضُها فِي بَعْضٍ.</p><p><span class="qpc-hafs">﴿ذَرۡعُهَا﴾</span>: مِقْدارُ طُولِها بالذِّراعِ.</p><p><span class="qpc-hafs">﴿فَٱسۡلُكُوهُ﴾</span>: فَأَدْخِلُوه في السِّلْسِلَةِ.</p></div>"
  69,33,""
  69,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَحُضُّ﴾</span>: ولا يَحُثُّ.</p></div>"