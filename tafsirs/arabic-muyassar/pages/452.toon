tafsir[29]{c,v,t}:
  37,154,""
  37,155,""
37,156," <q>﴿سُلۡطَـٰنࣱ مُّبِينࣱ﴾</q>: حُجَّةٌ واضِحةٌ. "
  37,157,""
37,158," <q>﴿وَبَيۡنَ ٱلۡجِنَّةِ﴾</q>: بَيْنَ الملائِكَةِ. <q>﴿لَمُحۡضَرُونَ﴾</q>: أي: لِلْعَذابِ. "
  37,159,""
  37,160,""
  37,161,""
37,162," <q>﴿بِفَـٰتِنِينَ﴾</q>: بمُضِلِّينَ ومُفْسِدِينَ أحَدًا. "
37,163," <q>﴿صَالِ ٱلۡجَحِيمِ﴾</q>: يَدْخُلُ النارَ، ويُقاسي حَرَّها. "
  37,164,""
37,165," <q>﴿ٱلصَّآفُّونَ﴾</q>: الواقِفُونَ صُفُوفًا. "
37,166," <q>﴿ٱلۡمُسَبِّحُونَ﴾</q>: المُنَزِّهُونَ للهِ والمُقَدِّسُونَ له عَن كُلِّ ما لا يَلِيقُ بِه. "
  37,167,""
37,168," <q>﴿ذِكۡرࣰا مِّنَ ٱلۡأَوَّلِينَ﴾</q>: أي: كِتابًا مِن كُتُبِ الأوَّلِينَ كالتَّوراةِ والإنْجِيلِ. "
  37,169,""
37,170," <q>﴿فَكَفَرُواْ بِهِۦ﴾</q>: أي: فَجاءَهُم الرَّسُولُ بالقرآنِ فَكَفَرُوا بِهِ. "
  37,171,""
  37,172,""
  37,173,""
  37,174,""
  37,175,""
  37,176,""
37,177," <q>﴿بِسَاحَتِهِمۡ﴾</q>: بِفِنائِهِم، والمرادُ: القَومُ. "
  37,178,""
  37,179,""
  37,180,""
  37,181,""
  37,182,""
