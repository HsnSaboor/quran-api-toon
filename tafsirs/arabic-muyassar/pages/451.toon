tafsir[27]{c,v,t}:
37,127," <q>﴿لَمُحۡضَرُونَ﴾</q>: أي: لِلْحِسابِ والعِقابِ. "
  37,128,""
37,129," <q>﴿عَلَيۡهِ﴾</q>: أي: على ذِكْرِه الحَسَنِ. <q>﴿فِي ٱلۡـَٔاخِرِينَ﴾</q>: في الأُمَمِ الَّتي جاءَتْ بَعْدَهُ. "
  37,130,""
  37,131,""
  37,132,""
  37,133,""
  37,134,""
37,135," <q>﴿فِي ٱلۡغَـٰبِرِينَ﴾</q>: الباقِينَ في العذابِ. "
37,136," <q>﴿دَمَّرۡنَا﴾</q>: أهْلَكْنا. <q>﴿ٱلۡـَٔاخَرِينَ﴾</q>: الباقِينَ مِن قَومِ لُوطٍ عَلَيهِ السَّلامُ الَّذينَ لم يُؤْمِنُوا بِهِ. "
37,137," <q>﴿مُّصۡبِحِينَ﴾</q>: داخِلِينَ وقْتَ الصَّباحِ. "
  37,138,""
  37,139,""
37,140," <q>﴿أَبَقَ﴾</q>: هَرَبَ. <q>﴿ٱلۡمَشۡحُونِ﴾</q>: المَمْلُوءِ. "
37,141," <q>﴿فَسَاهَمَ﴾</q>: اقْتَرَعَ وقَبِلَ القُرْعَةَ. <q>﴿ٱلۡمُدۡحَضِينَ﴾</q>: المَغْلُوبِينَ بالقُرْعَةِ. "
37,142," <q>﴿فَٱلۡتَقَمَهُ﴾</q>: فابْتَلَعَه. <q>﴿مُلِيمࣱ﴾</q>: آتٍ بما يُلامُ عَلَيهِ. "
37,143," <q>﴿ٱلۡمُسَبِّحِينَ﴾</q>: بِذِكْرِ اللهِ وكَثْرةِ العِبادةِ. "
37,144," <q>﴿لَلَبِثَ﴾</q>: لمَكَثَ. "
37,145," <q>﴿فَنَبَذۡنَـٰهُ﴾</q>: طَرَحْناه. <q>﴿بِٱلۡعَرَآءِ﴾</q>: بِأرْضٍ خاليةٍ عاريةٍ من الشَّجرِ والبناءِ. <q>﴿سَقِيمࣱ﴾</q>: ضَعِيفُ البَدَنِ بسَبِبِ حَبْسِهِ في بَطْنِ الحُوتِ. "
37,146," <q>﴿يَقۡطِينࣲ﴾</q>: القَرْعِ. "
  37,147,""
  37,148,""
  37,149,""
  37,150,""
37,151," <q>﴿إِفۡكِهِمۡ﴾</q>: من كَذِبِهِم وافْتِرائِهِم. "
  37,152,""
37,153," <q>﴿أَصۡطَفَى﴾</q>: هل اخْتارَ؟ "
