quran[9]{c,v,t}:
  17,50,"<div class=ar lang=ar></div>"
  17,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكۡبُرُ فِي صُدُورِكُمۡ﴾</span>: يَعْظُمُ ويُسْتَبْعَدُ في عقولِكم قَبولُه للحياةِ، كالسمواتِ.</p><p><span class="qpc-hafs">﴿يُعِيدُنَا﴾</span>: يُرْجِعُنا إلى الحياةِ بعدَ موتِنا.</p><p><span class="qpc-hafs">﴿فَطَرَكُمۡ﴾</span>: خَلَقَكم من غيرِ مثالٍ سابقٍ.</p><p><span class="qpc-hafs">﴿فَسَيُنۡغِضُونَ إِلَيۡكَ رُءُوسَهُمۡ﴾</span>: سيُحَرِّكُونها استهزاءً وتعجُّبًا.</p><p><span class="qpc-hafs">﴿مَتَىٰ هُوَ﴾</span>: أي: البعثُ.</p></div>"
  17,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَدۡعُوكُمۡ﴾</span>: يُناديكم خالقُكم على لسانِ المَلَكِ؛ للخروجِ من قبورِكم.</p><p><span class="qpc-hafs">﴿بِحَمۡدِهِۦ﴾</span>: بأمرِ اللهِ، حامدين اللهَ على كمالِ قدرتِه.</p></div>"
  17,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنزَغُ﴾</span>: يُفْسِدُ ويُوَسْوِسُ.</p><p><span class="qpc-hafs">﴿مُّبِينࣰا﴾</span>: واضحَ العداوةِ.</p></div>"
  17,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلࣰا﴾</span>: مُفَوَّضًا إليك أمرُهم.</p></div>"
  17,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضَّلۡنَا بَعۡضَ ٱلنَّبِيِّـۧنَ﴾</span>: بالفضائلِ وإنزالِ الكتبِ.</p><p><span class="qpc-hafs">﴿زَبُورࣰا﴾</span>: الكتابُ المنزَّلُ على داودَ عليه السلام، وكلُّه تحميدٌ وثناءٌ على اللهِ.</p></div>"
  17,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَشۡفَ ٱلضُّرِّ﴾</span>: إزالتَه.</p><p><span class="qpc-hafs">﴿تَحۡوِيلًا﴾</span>: نَقْلَه إلى غيرِكم، أوتبديلَه من حالٍ إلى أخرى.</p></div>"
  17,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ يَدۡعُونَ﴾</span>: اتخذهم المُشْركون آلهةً، كالملائكة والأنبياء.</p><p><span class="qpc-hafs">﴿يَبۡتَغُونَ﴾</span>: يَطْلبون باجتهادٍ.</p><p><span class="qpc-hafs">﴿ٱلۡوَسِيلَةَ﴾</span>: القُرْبةَ بالطاعةِ والدرجةِ العُليا.</p><p><span class="qpc-hafs">﴿أَيُّهُمۡ أَقۡرَبُ﴾</span>: يَطْلُبها الذي هو أقربُ إلى اللهِ، فكيف بمَن دونَه؟</p><p><span class="qpc-hafs">﴿مَحۡذُورࣰا﴾</span>: حقيقًا بأن يَحْذَرَه العِبادُ.</p></div>"
  17,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن مِّن قَرۡيَةٍ﴾</span>: وما مِن قريةٍ كَذَّب أهلُها.</p><p><span class="qpc-hafs">﴿فِي ٱلۡكِتَـٰبِ﴾</span>: في اللَّوحِ المحفوظِ.</p><p><span class="qpc-hafs">﴿مَسۡطُورࣰا﴾</span>: مَكْتوبًا.</p></div>"