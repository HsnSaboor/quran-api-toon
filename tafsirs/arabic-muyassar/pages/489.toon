quran[12]{c,v,t}:
  42,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُوحࣰا﴾</span>: قُرآنًا.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبُ﴾</span>: الكُتُبُ السّابِقَةُ.</p><p><span class="qpc-hafs">﴿لَتَهۡدِيٓ﴾</span>: لَتَدُلُّ وتُرْشِدُ.</p><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: هُوَ الإسْلامُ.</p></div>"
  42,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَصِيرُ﴾</span>: تَرْجِعُ.</p></div>"
  43,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: سَبَقَ الكَلامُ على الحُرُوفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البَقَرةِ.</p></div>"
  43,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡكِتَـٰبِ﴾</span>: القُرآنِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُبِينِ﴾</span>: الواضِح لَفْظًا ومَعْنىً.</p></div>"
  43,3,""
  43,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمِّ ٱلۡكِتَـٰبِ﴾</span>: اللَّوحِ المحْفُوظِ.</p><p><span class="qpc-hafs">﴿لَعَلِيٌّ﴾</span>: رَفِيعٌ.</p><p><span class="qpc-hafs">﴿حَكِيمٌ﴾</span>: مُحْكَمٌ لا اخْتِلافَ فِيهِ ولا تَناقُضَ.</p></div>"
  43,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ﴾</span>: أفَنُعْرِضُ عَنْكُم ونَتْرُكُ إنْزالَ القُرآنِ إلَيكُم.</p><p><span class="qpc-hafs">﴿صَفۡحًا﴾</span>: أي: إعْراضًا.</p><p><span class="qpc-hafs">﴿مُّسۡرِفِينَ﴾</span>: مُتَجاوِزِينَ الحدَّ في الإعْراضِ عَنِ القُرآنِ.</p></div>"
  43,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَمۡ﴾</span>: كَثِيرًا.</p><p><span class="qpc-hafs">﴿ٱلۡأَوَّلِينَ﴾</span>: القُرُونِ الَّتي مَضَتْ.</p></div>"
  43,7,""
  43,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَطۡشࣰا﴾</span>: قُوَّةً وبأسًا.</p><p><span class="qpc-hafs">﴿مَثَلُ﴾</span>: عُقُوبةُ.</p></div>"
  43,9,""
  43,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَهۡدࣰا﴾</span>: فِراشًا وبِساطًا.</p><p><span class="qpc-hafs">﴿سُبُلࣰا﴾</span>: طُرُقًا لِمَعاشِكُم ومَتاجِرِكُم.</p></div>"