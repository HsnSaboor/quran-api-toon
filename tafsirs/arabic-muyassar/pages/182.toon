quran[5]{c,v,t}:
  8,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَنِمۡتُم﴾</span>: ظَفِرْتُمْ به من الأعداءِ بالجِهادِ.</p><p><span class="qpc-hafs">﴿وَلِذِي ٱلۡقُرۡبَىٰ﴾</span>: قَرابةِ الرسولِ ﷺ، وهم بنو هاشمٍ وبنو المطَّلِبِ.</p><p><span class="qpc-hafs">﴿وَٱلۡيَتَـٰمَىٰ﴾</span>: الأطفالِ الذين مات آباؤُهم وهم دونَ سِنِّ البُلوغ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: أهلِ الحاجةِ الذين لا يَمْلِكُون ما يَكْفيهم.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: المسافرِ الذي انقطعَتْ به النفقةُ.</p><p><span class="qpc-hafs">﴿وَمَآ أَنزَلۡنَا﴾</span>: من الملائكةِ والآياتِ والنَّصْرِ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ٱلۡفُرۡقَانِ﴾</span>: يومَ «بَدْرٍ» حينَ فَرَقَ اللهُ بينَ الحقِّ والباطلِ.</p></div>"
  8,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡعُدۡوَةِ ٱلدُّنۡيَا﴾</span>: جانبِ الوادي الأقربِ إلى «المدينة».</p><p><span class="qpc-hafs">﴿ٱلۡقُصۡوَىٰ﴾</span>: البعيدةِ عن «المدينةِ».</p><p><span class="qpc-hafs">﴿وَٱلرَّكۡبُ﴾</span>: عِيرُ التجارةِ وأصحابُها.</p><p><span class="qpc-hafs">﴿أَسۡفَلَ مِنكُمۡ﴾</span>: في مكانٍ أسفلَ من مكانِكم جهةَ ساحلِ البحرِ الأحمرِ.</p><p><span class="qpc-hafs">﴿لِّيَقۡضِيَ ٱللَّهُ أَمۡرࣰا كَانَ مَفۡعُولࣰا﴾</span>: بنَصْرِ أوليائِه وخِذْلانِ أعدائِه.</p><p><span class="qpc-hafs">﴿لِّيَهۡلِكَ مَنۡ هَلَكَ﴾</span>: ليموتَ مَن يموتُ من الكفّارِ.</p><p><span class="qpc-hafs">﴿عَنۢ بَيِّنَةࣲ﴾</span>: عن حُجَّةٍ عايَنَها.</p><p><span class="qpc-hafs">﴿وَيَحۡيَىٰ مَنۡ حَيَّ﴾</span>: ويعيشَ مَن يعيشُ مِنهُم.</p></div>"
  8,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّفَشِلۡتُمۡ﴾</span>: لَجَبُنْتُم وضَعُفتم.</p><p><span class="qpc-hafs">﴿وَلَتَنَـٰزَعۡتُمۡ﴾</span>: اختلَفْتُم.</p><p><span class="qpc-hafs">﴿فِي ٱلۡأَمۡرِ﴾</span>: في القتالِ.</p><p><span class="qpc-hafs">﴿سَلَّمَ﴾</span>: عَصَمَ من الضَّعْفِ والاختلافِ.</p></div>"
  8,44,"<div class=ar lang=ar></div>"
  8,45,"8:44"