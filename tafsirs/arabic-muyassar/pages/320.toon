quran[12]{c,v,t}:
  20,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ﴾</span>: لا تُسارِعْ بِقِراءتِه.</p><p><span class="qpc-hafs">﴿مِن قَبۡلِ أَن يُقۡضَىٰٓ إِلَيۡكَ وَحۡيُهُۥ﴾</span>: من قَبْلِ أن يَفرغَ جبريلُ ويُتِمَّ إليك الوحيَ.</p></div>"
  20,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَهِدۡنَآ إِلَىٰٓ ءَادَمَ﴾</span>: وصَّيناهُ، أو أوحينا إليه.</p><p><span class="qpc-hafs">﴿عَزۡمࣰا﴾</span>: قوَّةً في الإرادةِ يَحْفَظُ بها ما أُمِرَ به.</p></div>"
  20,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبَىٰ﴾</span>: امْتَنَعَ مِنَ السُّجُودِ اسْتِكْبارًا.</p></div>"
  20,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَشۡقَىٰٓ﴾</span>: فتعانيَ المتاعِبَ والمشاقَّ في الدُّنيا.</p></div>"
  20,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَّا تَجُوعَ فِيهَا﴾</span>: أي: لا يُصِيبَكَ في الجنَّةِ جُوعٌ.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡرَىٰ﴾</span>: أي: لا تَعْرى فيها عن الملابِسِ.</p></div>"
  20,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا تَظۡمَؤُاْ فِيهَا﴾</span>: لا يُصِيبُكَ في الجنَّةِ عَطَشٌ.</p><p><span class="qpc-hafs">﴿وَلَا تَضۡحَىٰ﴾</span>: ولا يُصيبُك حرُّ شَمْسٍ.</p></div>"
  20,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَجَرَةِ ٱلۡخُلۡدِ﴾</span>: هي الشجرةُ التي مَن أكَلَ مِنها لم يَمُتْ.</p><p><span class="qpc-hafs">﴿لَّا يَبۡلَىٰ﴾</span>: لا يَنْقَطِعُ.</p></div>"
  20,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَدَتۡ لَهُمَا سَوۡءَ ٰ⁠ تُهُمَا﴾</span>: فانْكَشَفَتْ لِآدَمَ وحَوّاءَ عَوْراتُهما.</p><p><span class="qpc-hafs">﴿وَطَفِقَا يَخۡصِفَانِ﴾</span>: وجَعلا يَلْصَقان.</p><p><span class="qpc-hafs">﴿فَغَوَىٰ﴾</span>: فَضَلَّ طَريقَ الصَّوابِ.</p></div>"
  20,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱجۡتَبَـٰهُ﴾</span>: اصْطَفاه.</p></div>"
  20,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱهۡبِطَا﴾</span>: انْزِلا مِنَ الجَنَّةِ إلى الأرضِ.</p><p><span class="qpc-hafs">﴿فَلَا يَضِلُّ﴾</span>: أي: عَن طَرِيقِ الهِدايةِ.</p><p><span class="qpc-hafs">﴿وَلَا يَشۡقَىٰ﴾</span>: لا يَشْقى في الآخرةِ بعِقابِ اللهِ.</p></div>"
  20,124,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرِي﴾</span>: أي: عَن ذِكْرِي الَّذِي أُذَكِّرهُ بِهِ مِن قُرآنٍ وغَيْرِهِ.</p><p><span class="qpc-hafs">﴿ضَنكࣰا﴾</span>: ضَيِّقةً شاقَّةً في حَياتِه وقَبْرِه.</p></div>"
  20,125,""