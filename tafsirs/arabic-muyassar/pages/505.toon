quran[8]{c,v,t}:
  46,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡأَحۡقَافِ﴾</span>: الرِّمالِ الكثِيرَةِ الَّتي لَمْ تَبْلُغْ أن تَكُونَ جَبَلًا، وتَقَعُ في جَنُوبِ الجزِيرَةِ العَرَبِيَّةِ، وهي مَنازلُ عادٍ قَومِ هُودٍ.</p><p><span class="qpc-hafs">﴿ٱلنُّذُرُ﴾</span>: جَمْعُ النَّذِيرِ وهو الرَّسُولُ.</p></div>"
  46,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَأۡفِكَنَا﴾</span>: لِتَصْرِفَنا.</p></div>"
  46,23,"<div class=ar lang=ar></div>"
  46,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَأَوۡهُ﴾</span>: أي العذابَ.</p><p><span class="qpc-hafs">﴿عَارِضࣰا﴾</span>: كالسَّحابِ الَّذي يَعْتَرِضُ جَوَّ السَّماءِ.</p><p><span class="qpc-hafs">﴿أَوۡدِيَتِهِمۡ﴾</span>: منازِلِهم في السُّهُولِ.</p></div>"
  46,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلَّ شَيۡءِۭ﴾</span>: ما مِن شَأنِه أن تُدَمِّرَهُ مِنَ الإنْسانِ والحيوانِ والدِّيارِ.</p><p><span class="qpc-hafs">﴿مَسَـٰكِنُهُمۡ﴾</span>: أي آثارُ المساكِنِ وبقاياها.</p></div>"
  46,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيمَآ إِن مَّكَّنَّـٰكُمۡ فِيهِ﴾</span>: في الَّذِي لَم نَجْعَل لَّكُم القُدْرَةَ عَلَيهِ.</p><p><span class="qpc-hafs">﴿وَأَفۡـِٔدَةࣰ﴾</span>: عُقُولًا.</p><p><span class="qpc-hafs">﴿أَغۡنَىٰ﴾</span>: نَفَعَ.</p><p><span class="qpc-hafs">﴿يَجۡحَدُونَ﴾</span>: يُنْكِرُونَ.</p><p><span class="qpc-hafs">﴿وَحَاقَ بِهِم﴾</span>: ونَزَلَ وأَحاطَ بِهِم.</p><p><span class="qpc-hafs">﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾</span>: العَذابُ الَّذِي كانُوا يَسْخَرُونَ مِنهُ.</p></div>"
  46,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَصَرَّفۡنَا ٱلۡـَٔايَـٰتِ﴾</span>: بيَّنّا لَهُم أنْواعَ الأَدِلَّةِ.</p></div>"
  46,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَا﴾</span>: فَهَلّا.</p><p><span class="qpc-hafs">﴿قُرۡبَانًا﴾</span>: لِأَجْلِ التَّقَرُّبِ بِهِم إلى اللهِ، وهو مُعْتَرِضٌ بَيْنَ (ٱتَّخَذُواْ) ومَفْعُولِهِ: (ءالِهَةَۢ).</p><p><span class="qpc-hafs">﴿ضَلُّواْ عَنۡهُمۡ﴾</span>: غابُوا عَنْهُم.</p><p><span class="qpc-hafs">﴿إِفۡكُهُمۡ﴾</span>: كَذِبُهُم في زَعمِهِم أنَّ الأصْنامَ شُرَكاءُ لله.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَخْتَلِقُونَه مِن كَونِ الأصْنامِ تُقَرِّبُهُم إلى اللهِ.</p></div>"