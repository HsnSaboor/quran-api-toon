quran[9]{c,v,t}:
  8,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِيُبۡلِيَ ٱلۡمُؤۡمِنِينَ﴾</span>: وليختبرَ اللهُ المؤمنين بنِعَمِه وإحسانِه.</p></div>"
  8,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُوهِنُ﴾</span>: مُضْعِفُ ومُبْطِلُ.</p><p><span class="qpc-hafs">﴿كَيۡدِ ٱلۡكَـٰفِرِينَ﴾</span>: مَكْرِهم واحتيالِهم.</p></div>"
  8,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡتَفۡتِحُواْ﴾</span>: تطلُبوا النَّصْرَ أيها الكفارُ.</p><p><span class="qpc-hafs">﴿جَآءَكُمُ ٱلۡفَتۡحُ﴾</span>: تَهَكُّمٌ بالكفارِ، فقد نَصَرَ اللهُ المؤمنين ب «بَدْرٍ».</p><p><span class="qpc-hafs">﴿وَإِن تَعُودُواْ﴾</span>: إلى الكفرِ وقتالِ النبيِّ ﷺ.</p><p><span class="qpc-hafs">﴿نَعُدۡ﴾</span>: بهزيمَتِكم ونَصْرِه - ﷺ - عليكم.</p><p><span class="qpc-hafs">﴿فِئَتُكُمۡ﴾</span>: جماعتُكم.</p><p><span class="qpc-hafs">﴿مَعَ ٱلۡمُؤۡمِنِينَ﴾</span>: بتأييدِه ونَصْرِه.</p></div>"
  8,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَوَلَّوۡاْ﴾</span>: ولا تُعْرِضُوا عن طاعةِ اللهِ ورسولهِ.</p><p><span class="qpc-hafs">﴿تَسۡمَعُونَ﴾</span>: ما يُتلى عليكم من الحُجَجِ والبراهينِ.</p></div>"
  8,21,"<div class=ar lang=ar></div>"
  8,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلدَّوَآبِّ﴾</span>: جَمْعُ دابّة، وهي: ما دَبَّ على الأرضِ مِن خَلْقِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلصُّمُّ﴾</span>: مَنِ انسَدَّتْ آذانُهم عن سماعِ الحقِّ.</p><p><span class="qpc-hafs">﴿ٱلۡبُكۡمُ﴾</span>: مَن خَرِسَتْ ألسنتُهم عن النُّطقِ به.</p></div>"
  8,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّأَسۡمَعَهُمۡ﴾</span>: مواعِظَ القرآنِ وعِبَرَه.</p><p><span class="qpc-hafs">﴿لَتَوَلَّواْ﴾</span>: لَأَعْرَضُوا عن الإيمان عِنادًا.</p><p><span class="qpc-hafs">﴿مُّعۡرِضُونَ﴾</span>: صادُّون عنه.</p></div>"
  8,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَا يُحۡيِيكُمۡ﴾</span>: لما فيه الحياةُ الأبديةُ.</p><p><span class="qpc-hafs">﴿بَيۡنَ ٱلۡمَرۡءِ وَقَلۡبِهِۦ﴾</span>: بين الإنسانِ وخواطِرِ قلبِه، فاللهُ أملكُ لقلوبِ عبادِه منهم.</p></div>"
  8,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: ابتلاءً ومِحْنَةً تنزِلُ بكم.</p></div>"