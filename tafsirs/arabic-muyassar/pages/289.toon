quran[9]{c,v,t}:
  17,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلضُّرُّ﴾</span>: الشِّدَّةُ وخَوْفُ الغَرَقِ.</p><p><span class="qpc-hafs">﴿ضَلَّ﴾</span>: غابَ عن عقولِكم.</p><p><span class="qpc-hafs">﴿مَن تَدۡعُونَ إِلَّآ إِيَّاهُ﴾</span>: الذين تَعْبُدُونهم من الآلهةِ، وتَذَكَّرْتُم اللهَ وحدَه.</p></div>"
  17,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخۡسِفَ بِكُمۡ جَانِبَ ٱلۡبَرِّ﴾</span>: يُغَوِّرَ بكم الأرضَ، ويُغيِّبَكم فيها.</p><p><span class="qpc-hafs">﴿حَاصِبࣰا﴾</span>: المَطَرَ الذي فيه حِجارةٌ من السماء، أو ريحًا شديدة تَرْمي بالحصى الصِّغارِ.</p><p><span class="qpc-hafs">﴿وَكِيلًا﴾</span>: حَفيظًا وناصِرًا من الله.</p></div>"
  17,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِ﴾</span>: في البحر.</p><p><span class="qpc-hafs">﴿قَاصِفࣰا﴾</span>: شديدةً عاصفةً، تُكَسِّرُ كلَّ ما أتَتْ عليه.</p><p><span class="qpc-hafs">﴿تَبِيعࣰا﴾</span>: مُطالِبًا بما فَعَلْنا، ونصيرًا يأخذُ بالثأرِ لكم.</p></div>"
  17,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّمۡنَا بَنِيٓ ءَادَمَ﴾</span>: بالرسُلِ والرِّسالات، وغيرِها من النِّعَمِ. ومَنحْناهم عقولًا يُدْرِكون بها ويُمَيِّزون.</p></div>"
  17,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ﴾</span>: أي: يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿بِإِمَـٰمِهِمۡ﴾</span>: بمَنِ اقتَدَوْا به في الدُّنيا من كتابٍ، أو نبيّ، أو قائدٍ.</p><p><span class="qpc-hafs">﴿كِتَـٰبَهُۥ﴾</span>: كتابَ أعمالِه.</p><p><span class="qpc-hafs">﴿فَتِيلࣰا﴾</span>: مِقْدارَ الخيطِ الذي في شَقِّ النَّواة.</p></div>"
  17,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي هَـٰذِهِۦٓ أَعۡمَىٰ﴾</span>: في الدُّنيا أعمى القَلْبِ والبَصيرةِ.</p></div>"
  17,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِن كَادُواْ﴾</span>: ولقد قارَبَ المشركون.</p><p><span class="qpc-hafs">﴿لَيَفۡتِنُونَكَ﴾</span>: لَيَصْرِفُونك ويَخْدَعُونك في ظَنِّهم.</p><p><span class="qpc-hafs">﴿لِتَفۡتَرِيَ عَلَيۡنَا﴾</span>: لِتَتَقَوَّلَ علينا مَّما اقترحُوه عليك.</p><p><span class="qpc-hafs">﴿لَّٱتَّخَذُوكَ خَلِيلࣰا﴾</span>: خَصُّوك بالصداقةِ الخاصَّةِ.</p></div>"
  17,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡكَنُ﴾</span>: تميلُ.</p></div>"
  17,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِعۡفَ ٱلۡحَيَوٰةِ وَضِعۡفَ ٱلۡمَمَاتِ﴾</span>: عذابًا مُضاعَفًا مِثْلَي ما يُعَذَّبُ به غيرُك في الدنيا والآخِرَةِ.</p></div>"