quran[6]{c,v,t}:
  2,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾</span>: تعاقُبِهما.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكِ﴾</span>: السُّفُن.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَا﴾</span>: بعد قَحْطِها وجَفافِها.</p><p><span class="qpc-hafs">﴿بَثَّ﴾</span>: نَشَر، وفَرَّقَ.</p><p><span class="qpc-hafs">﴿دَآبَّةࣲ﴾</span>: كلِّ ما دَبَّ على وجهِ الأرضِ.</p><p><span class="qpc-hafs">﴿وَتَصۡرِيفِ ٱلرِّيَـٰحِ﴾</span>: تَوْجيهِها، وهُبوبِها، وفْقَ ما يريدُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُسَخَّرِ﴾</span>: المُسَيَّرِ.</p><p><span class="qpc-hafs">﴿لَـَٔايَـٰتࣲ﴾</span>: لَعلاماتٍ ودَلالاتٍ على قُدْرةِ اللهِ.</p></div>"
  2,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَندَادࣰا﴾</span>: نُظَراءَ كالأصنامِ والأولياءِ.</p><p><span class="qpc-hafs">﴿كَحُبِّ ٱللَّهِ﴾</span>: يَمْنحونهم من التعظيم ما لا يَليقُ إلا باللهِ.</p><p><span class="qpc-hafs">﴿إِذۡ يَرَوۡنَ ٱلۡعَذَابَ أَنَّ ٱلۡقُوَّةَ لِلَّهِ جَمِيعࣰا﴾</span>: أي: ليعلَمُوا حين يَرَوْنَ عذابَ جهنَّمَ أن اللهَ هو المتفرِّدُ بالقوةِ.</p></div>"
  2,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ ٱتُّبِعُواْ﴾</span>: هم الرؤساءُ.</p><p><span class="qpc-hafs">﴿ٱلۡأَسۡبَابُ﴾</span>: الصِّلاتُ من القَرابَةِ والأَتْباعِ وغيرِ ذلك.</p></div>"
  2,167,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّةࣰ﴾</span>: عودةً إلى الدنيا.</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: أي: كما أراهم عذابه، يُريهم أعمالَهم الفاسدةَ.</p><p><span class="qpc-hafs">﴿حَسَرَ ٰ⁠تٍ﴾</span>: نَداماتٍ.</p></div>"
  2,168,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾</span>: طُرُقَه، وآثارَه.</p></div>"
  2,169,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡفَحۡشَآءِ﴾</span>: المعصيةِ البالغةِ القُبْحِ.</p></div>"