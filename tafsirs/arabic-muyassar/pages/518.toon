quran[15]{c,v,t}:
  50,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قٓ﴾</span>: سَبَقَ الكلامُ على الحُروفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البقرةِ.</p><p><span class="qpc-hafs">﴿ٱلۡمَجِيدِ﴾</span>: ذي المجْدِ والشَّرَفِ.</p></div>"
  50,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَجِيبٌ﴾</span>: مُسْتَغْرَبٌ يُتَعَجَّبُ مِنهُ.</p></div>"
  50,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَجۡعُۢ﴾</span>: بَعْثٌ.</p></div>"
  50,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنقُصُ ٱلۡأَرۡضُ﴾</span>: تُفْنِي مِن أجْسامِهِم.</p><p><span class="qpc-hafs">﴿حَفِيظُۢ﴾</span>: مَحفُوظٌ.</p></div>"
  50,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرِيجٍ﴾</span>: مُخْتَلِطٍ مُضْطَرِبٍ.</p></div>"
  50,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فُرُوجࣲ﴾</span>: شُقُوقٍ وُصُدُوعٍ.</p></div>"
  50,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَدَدۡنَـٰهَا﴾</span>: بَسَطْناها.</p><p><span class="qpc-hafs">﴿رَوَ ٰ⁠سِيَ﴾</span>: جِبالًا ثَوابِتَ.</p><p><span class="qpc-hafs">﴿زَوۡجِۭ﴾</span>: نَوْعٍ وجِنْسٍ.</p><p><span class="qpc-hafs">﴿بَهِيجࣲ﴾</span>: حَسَنِ المنْظَر.</p></div>"
  50,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبۡصِرَةࣰ﴾</span>: تَجْعَلُ المرءَ مُبْصِرًا.</p><p><span class="qpc-hafs">﴿وَذِكۡرَىٰ﴾</span>: تُذَكِّرُ النّاسِي.</p><p><span class="qpc-hafs">﴿مُّنِيبࣲ﴾</span>: رَجّاعٍ إلى اللهِ.</p></div>"
  50,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبَـٰرَكࣰا﴾</span>: كَثِيرَ الخيَرِ والمنافِعِ.</p><p><span class="qpc-hafs">﴿وَحَبَّ ٱلۡحَصِيدِ﴾</span>: وحَبَّ الزَّرْعِ المحْصُودِ.</p></div>"
  50,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَاسِقَـٰتࣲ﴾</span>: مُرْتَفِعاتٍ.</p><p><span class="qpc-hafs">﴿طَلۡعࣱ﴾</span>: هُو أوَّلُ ما يَظْهَرُ مِن ثَمَرِ التَّمْرِ وهُو غِلافُ العُنْقُودِ.</p><p><span class="qpc-hafs">﴿نَّضِيدࣱ﴾</span>: مَنضُودٌ، مُصَفَّفٌ بعْضُهُ فَوْقَ بَعْضٍ.</p></div>"
  50,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّيۡتࣰا﴾</span>: أجْدَبَتْ وقَحَطَتْ.</p><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ﴾</span>: كَما أحْيا اللهُ هَذِه الأَرْضَ الميتَةَ.</p><p><span class="qpc-hafs">﴿ٱلۡخُرُوجُ﴾</span>: خَرُوجُ النّاسِ يَومَ البعْثِ.</p></div>"
  50,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّسِّ﴾</span>: البِئْرِ.</p></div>"
  50,13,"<div class=ar lang=ar></div>"
  50,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ ٱلۡأَيۡكَةِ﴾</span>: أصْحابُ الشَّجَرِ المُلْتَفِّ وهم قُوُم شُعَيبٍ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿وَقَوۡمُ تُبَّعࣲ﴾</span>: هُم سَبأٌ، وتُبَّعٌ هُوَ أحَدُ مُلُوكِ اليمَنِ.</p><p><span class="qpc-hafs">﴿فَحَقَّ﴾</span>: صَدَقَ وتَحَقَّقَ.</p><p><span class="qpc-hafs">﴿وَعِيدِ﴾</span>: إنذارِي بالعُقُوبةِ.</p></div>"
  50,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَعَيِينَا﴾</span>: أفَعَجَزْنا.</p><p><span class="qpc-hafs">﴿لَبۡسࣲ﴾</span>: اشْتِباهٍ وشَكٍّ.</p><p><span class="qpc-hafs">﴿خَلۡقࣲ جَدِيدࣲ﴾</span>: قِيامِ الخَلْقِ في البَعْثِ.</p></div>"