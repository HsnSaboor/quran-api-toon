quran[8]{c,v,t}:
  6,158,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُونَ﴾</span>: ينتظر المُعْرِضون.</p><p><span class="qpc-hafs">﴿ٱلۡمَلَـٰٓئِكَةُ﴾</span>: المختصُّون بقَبْضِ الأرواحِ.</p><p><span class="qpc-hafs">﴿يَأۡتِيَ رَبُّكَ﴾</span>: للفَصْل بين عبادِه يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿بَعۡضُ ءَايَـٰتِ رَبِّكَ﴾</span>: بعضُ علاماتِ السّاعةِ.</p><p><span class="qpc-hafs">﴿مِن قَبۡلُ﴾</span>: من قبلِ إتيانِ هذه الآياتِ.</p><p><span class="qpc-hafs">﴿خَيۡرࣰا﴾</span>: عملًا صالحًا.</p></div>"
  6,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَّقُواْ دِينَهُمۡ﴾</span>: جَعَلُوه متفرِّقًا، فأخذوا ببعضِه، وتركوا بعضَه.</p><p><span class="qpc-hafs">﴿شِيَعࣰا﴾</span>: فِرَقًا وأحزابًا.</p></div>"
  6,160,""
  6,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾</span>: طريقٍ لا عِوَجَ فيه، وهو الإسلامُ.</p><p><span class="qpc-hafs">﴿قِيَمࣰا﴾</span>: يقومُ بأمْرِ الدنيا والآخرةِ.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا إلى الحقِّ.</p></div>"
  6,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنُسُكِي﴾</span>: وذَبْحي للأنعام.</p><p><span class="qpc-hafs">﴿وَمَحۡيَايَ﴾</span>: ما أعمَلُه في حياتي.</p><p><span class="qpc-hafs">﴿وَمَمَاتِي﴾</span>: ما يُقَدِّره عليّ في الموتِ.</p></div>"
  6,163,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوَّلُ ٱلۡمُسۡلِمِينَ﴾</span>: أولُ مَن انقادَ للهِ من هذه الأمةِ.</p></div>"
  6,164,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبۡغِي﴾</span>: أطْلُبُ.</p><p><span class="qpc-hafs">﴿وَلَا تَكۡسِبُ كُلُّ نَفۡسٍ إِلَّا عَلَيۡهَا﴾</span>: لا يُؤاخَذُ ممّا أتَتْ به من الذَّنبِ سِواها.</p><p><span class="qpc-hafs">﴿وَلَا تَزِرُ وَازِرَةࣱ وِزۡرَ أُخۡرَىٰ﴾</span>: ولا تَحْمِلُ نفسٌ آثمةٌ إثمَ نفسٍ أخرى.</p></div>"
  6,165,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَـٰٓئِفَ﴾</span>: خُلَفاءَ الأممِ الماضيةِ.</p><p><span class="qpc-hafs">﴿وَرَفَعَ بَعۡضَكُمۡ فَوۡقَ بَعۡضࣲ﴾</span>: في الرِّزقِ والقوةِ وغيرِهما.</p><p><span class="qpc-hafs">﴿دَرَجَـٰتࣲ﴾</span>: مراتبَ.</p><p><span class="qpc-hafs">﴿لِّيَبۡلُوَكُمۡ﴾</span>: ليختبرَكم.</p><p><span class="qpc-hafs">﴿فِي مَآ ءَاتَىٰكُمۡ﴾</span>: أي: من نِعَمِه.</p></div>"