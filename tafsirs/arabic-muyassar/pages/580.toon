tafsir[25]{c,v,t}:
76,26," <q>﴿فَٱسۡجُدۡ لَهُۥ﴾</q>: فاخْضَعْ لِربِّكَ. <q>﴿وَسَبِّحۡهُ﴾</q>: وصَلِّ لَهُ، وتهجَّدْ لَهُ. "
76,27," <q>﴿ٱلۡعَاجِلَةَ﴾</q>: الدُّنيا. <q>﴿ثَقِيلࣰا﴾</q>: عَظِيمَ الشَّدائِدِ. "
76,28," <q>﴿وَشَدَدۡنَآ﴾</q>: وأحكمنا. <q>﴿أَسۡرَهُمۡ﴾</q>: خَلْقَهُم. <q>﴿بَدَّلۡنَآ أَمۡثَـٰلَهُمۡ﴾</q>: أهْلَكْناهُم، وجِئْنا بِقَوْمٍ مُطِيعِينَ. "
76,29," <q>﴿تَذۡكِرَةࣱ﴾</q>: عِظَةٌ للعالَمِينَ. <q>﴿سَبِيلࣰا﴾</q>: طَرِيقًا يُوصِلُهُ إلى مَغْفِرَةِ اللهِ ورِضْوانِهِ. "
  76,30,""
  76,31,""
77,1," <q>﴿وَٱلۡمُرۡسَلَـٰتِ﴾</q>: أُقسِمُ بالرِّياحِ حِينَ تَهُبُّ. <q>﴿عُرۡفࣰا﴾</q>: مُتَتابِعةً يَتْبَعُ بَعْضُها بَعْضًا كعُرْفِ الفَرَسِ. "
77,2," <q>﴿فَٱلۡعَـٰصِفَـٰتِ﴾</q>: وبالرِّياحِ الشَّدَيدَةِ الهُبُوبِ المُهْلِكَةِ. <q>﴿عَصۡفࣰا﴾</q>: هُبُوبًا شَدِيدًا. "
77,3," <q>﴿وَٱلنَّـٰشِرَ ٰ⁠تِ نَشۡرࣰا﴾</q>: وبالملائِكةِ المُوَكَّلِينَ بالسُّحُبِ يَسُوقُونَها حَيثُ شاء اللهُ. "
77,4," <q>﴿فَٱلۡفَـٰرِقَـٰتِ فَرۡقࣰا﴾</q>: وبالملائِكةِ الَّتِي تَنْزِلُ مِن عِندِ اللهِ بما يَفْرُقُ بَينَ الحقِّ والباطِلِ والحَلالِ والحَرامِ. "
77,5," <q>﴿فَٱلۡمُلۡقِيَـٰتِ ذِكۡرًا﴾</q>: وبالملائِكةِ الَّتِي تَتَلَقّى الوَحْيَ مِن عِنْدِ اللهِ وتُبَلّغُهُ رُسُلَهُ. "
77,6," <q>﴿عُذۡرًا أَوۡ نُذۡرًا﴾</q>: إعْذارًا وإنْذارًا مِنَ اللهِ إلى خَلْقِهِ. "
77,7," <q>﴿لَوَ ٰ⁠قِعࣱ﴾</q>: لَنازِلٌ بِكُم لا مَحالَةَ. "
77,8," <q>﴿طُمِسَتۡ﴾</q>: ذَهَبَ ضِياؤُها. "
77,9," <q>﴿فُرِجَتۡ﴾</q>: تَصَدَّعتْ. "
77,10," <q>﴿نُسِفَتۡ﴾</q>: تَطايَرَتْ وتَناثَرَتْ. "
77,11," <q>﴿أُقِّتَتۡ﴾</q>: عُيِّنَ لَهُم وقْتٌ لِلْفَصْلِ بَينَهُم وبَينَ الأُمَمِ. "
  77,12,""
77,13," <q>﴿لِيَوۡمِ ٱلۡفَصۡلِ﴾</q>: لِيومِ القضاءِ بين الخلائِقِ. "
77,14," <q>﴿وَمَآ أَدۡرَىٰكَ﴾</q>: وما أعْلَمَكَ. "
77,15," <q>﴿وَيۡلࣱ﴾</q>: هَلاكٌ عَظِيمٌ. "
77,16," <q>﴿ٱلۡأَوَّلِينَ﴾</q>: السابِقِينَ مِنَ الأُمَم الماضِيةِ. "
77,17," <q>﴿ثُمَّ نُتۡبِعُهُمُ ٱلۡـَٔاخِرِينَ﴾</q>: ثم نُلحِقُ بِهِمُ المُتَأخِّرِينَ المُكَذِّبِينَ. "
77,18," <q>﴿كَذَ ٰ⁠لِكَ﴾</q>: مِثلَ ذلِك الإهْلاكِ الفَظِيعِ. <q>﴿بِٱلۡمُجۡرِمِينَ﴾</q>: مِن كُفّارِ «مكَّةَ». "
77,19," <q>﴿وَيۡلࣱ﴾</q>: هَلاكٌ وعَذابٌ شَدِيدٌ. "
