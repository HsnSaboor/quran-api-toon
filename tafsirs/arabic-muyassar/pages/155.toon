quran[6]{c,v,t}:
  7,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أُمَمࣲ﴾</span>: في جملةِ جماعاتٍ من أمثالِكم في الكفر.</p><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: سَبَقتْ.</p><p><span class="qpc-hafs">﴿لَّعَنَتۡ أُخۡتَهَا﴾</span>: لَعَنَتِ الجماعةُ الداخلةُ النارَ،نظيرتَها من أهلِ ملَّتِها.</p><p><span class="qpc-hafs">﴿ٱدَّارَكُواْ فِيهَا﴾</span>: اجتمعَتِ الأممُ في النار جميعًا.</p><p><span class="qpc-hafs">﴿أُخۡرَىٰهُمۡ﴾</span>: منزلةً ودخولًا، وهم الأتباعُ.</p><p><span class="qpc-hafs">﴿لِأُولَىٰهُمۡ﴾</span>: منزلةً ودخولًا، وهم الرؤساءُ والقادةُ في الضلالِ.</p><p><span class="qpc-hafs">﴿ضِعۡفࣰا﴾</span>: زائدًا على مِثْلِه مرَّةً أو مرّاتٍ.</p><p><span class="qpc-hafs">﴿لَّا تَعۡلَمُونَ﴾</span>: لا تدْرِكُون -أيها الأتباعُ- ما لكلِّ فريقٍ منكم من العذابِ.</p></div>"
  7,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا كَانَ لَكُمۡ عَلَيۡنَا مِن فَضۡلࣲ﴾</span>: نحن القادةُ متساوون معكم-أيُّها الأتباعُ- في الضَّلالِ واستحقاقِ العذابِ.</p></div>"
  7,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بحُجَجِنا وآياتِنا الدالَّةِ على وحْدانيَّتِنا.</p><p><span class="qpc-hafs">﴿وَٱسۡتَكۡبَرُواْ عَنۡهَا﴾</span>: واستعْلَوْا عن التصديقِ بها، والعملِ بَشْرعِنا.</p><p><span class="qpc-hafs">﴿لَا تُفَتَّحُ لَهُمۡ أَبۡوَ ٰ⁠بُ ٱلسَّمَآءِ﴾</span>: لا يَصْعَدُ لهم في الحياةِ إلى اللهِ عملٌ صالحٌ، ولا تُفَتَّحُ لأرواحِهم إذا ماتوا أبوابُ السماءِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ يَلِجَ﴾</span>: إلا إذا دَخَلَ.</p><p><span class="qpc-hafs">﴿سَمِّ ٱلۡخِيَاطِ﴾</span>: ثَقْبِ الإبرةِ.</p></div>"
  7,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِهَادࣱ﴾</span>: فراشٌ مِن تحتهم.</p><p><span class="qpc-hafs">﴿غَوَاشࣲ﴾</span>: أغطيةٌ من النارِ.</p></div>"
  7,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا وُسۡعَهَآ﴾</span>: إلّا ما تُطيقُ من الأعمالِ.</p></div>"
  7,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعۡنَا﴾</span>: وأذهبَ اللهُ تعالى.</p><p><span class="qpc-hafs">﴿مِّنۡ غِلࣲّ﴾</span>: من حِقْدٍ وضغائنَ كانت من بعضِهم في الدُّنيا.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهِمُ﴾</span>: من تحتِ غُرَفِهم ومنازلهِم.</p><p><span class="qpc-hafs">﴿هَدَىٰنَا لِهَـٰذَا﴾</span>: وفَّقَنا للعملِ الصالحِ.</p><p><span class="qpc-hafs">﴿أُورِثۡتُمُوهَا﴾</span>: آلَ أمرُكم إليها.</p></div>"