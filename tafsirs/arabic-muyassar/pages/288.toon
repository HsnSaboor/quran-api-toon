quran[8]{c,v,t}:
  17,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡـَٔايَـٰتِ﴾</span>: بالمُعْجزاتِ التي اقترحها المشركون.</p><p><span class="qpc-hafs">﴿مُبۡصِرَةࣰ﴾</span>: معجزةً واضحةً.</p><p><span class="qpc-hafs">﴿فَظَلَمُواْ بِهَا﴾</span>: فكفَرُوا بها فأَهْلَكَهم اللهُ.</p></div>"
  17,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَحَاطَ بِٱلنَّاسِ﴾</span>: عِلْمًا وقُدرةً، فهُم في قَبْضَتِه، ولا يَخْرجُون عن مشيئتِه.</p><p><span class="qpc-hafs">﴿ٱلرُّءۡيَا﴾</span>: ما عاينَه النبيُّ ﷺ ليلةَ الإسراءِ والمعراجِ من عجائبِ مخلوقاتِ اللهِ.</p><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: ابتلاءً وامتحانًا.</p><p><span class="qpc-hafs">﴿وَٱلشَّجَرَةَ ٱلۡمَلۡعُونَةَ﴾</span>: شجرةَ الزَّقُّومِ، جَعَلَها اللهُ ابتلاءً لبعضِ الناس الذين أنكروا خَلْقَ شجرةٍ في النارِ.</p><p><span class="qpc-hafs">﴿وَنُخَوِّفُهُمۡ﴾</span>: نُخَوِّفُ المشركين بأصنافِ الوعيدِ والعذابِ.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنࣰا﴾</span>: تجاوُزًا للحَدِّ في الكفرِ والضَّلالِ.</p></div>"
  17,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡجُدُواْ لِـَٔادَمَ﴾</span>: تحيةً وإكرامًا له وإظهارًا لفضلِه، لا عِبادةً.</p></div>"
  17,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتَكَ﴾</span>: أخْبِرْني.</p><p><span class="qpc-hafs">﴿لَأَحۡتَنِكَنَّ ذُرِّيَّتَهُۥٓ﴾</span>: لأَسْتَوْلِيَنَّ عليهم بالإغواءِ والإضلالِ.</p><p><span class="qpc-hafs">﴿إِلَّا قَلِيلࣰا﴾</span>: مَن عَصَمَه اللهُ تعالى مِن عبادِه.</p></div>"
  17,63,"<div class=ar lang=ar></div>"
  17,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱسۡتَفۡزِزۡ﴾</span>: واستَخِفَّ، أو أزْعِجْ.</p><p><span class="qpc-hafs">﴿بِصَوۡتِكَ﴾</span>: بدَعْوَتِك إياهم إلى المعاصي والآثام.</p><p><span class="qpc-hafs">﴿وَأَجۡلِبۡ عَلَيۡهِم﴾</span>: واستحِثَّهم، واجْمَعْ عليهم كلَّ ما تَقْدِرُ عليه مِن جنودِك.</p><p><span class="qpc-hafs">﴿بِخَيۡلِكَ وَرَجِلِكَ﴾</span>: من كلِّ راكبٍ وماشٍ في المعصيةِ والفَسادِ.</p><p><span class="qpc-hafs">﴿وَشَارِكۡهُمۡ فِي ٱلۡأَمۡوَ ٰ⁠لِ﴾</span>: بتحريضِهم على كَسْبِ الأموالِ المحرَّمةِ، وإنفاقِها فيما يُغضبُ اللهَ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَوۡلَـٰدِ﴾</span>: وبتَزْيِينِ إنجابِهم عن طريقِ الزِّنى، أو التخلُّصِ منهم، وتجاوزِ حدودِ الشَّرعِ.</p><p><span class="qpc-hafs">﴿غُرُورًا﴾</span>: وعْدًا باطلًا خادعًا.</p></div>"
  17,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنࣱ﴾</span>: تَسَلُّطٌ وقوةٌ على إغوائِهم.</p><p><span class="qpc-hafs">﴿وَكِيلࣰا﴾</span>: حافِظًا لعبادِه.</p></div>"
  17,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُزۡجِي﴾</span>: يُجْري ويُسَيِّرُ برِفْقٍ.</p><p><span class="qpc-hafs">﴿ٱلۡفُلۡكَ﴾</span>: السُّفُنَ.</p><p><span class="qpc-hafs">﴿لِتَبۡتَغُواْ﴾</span>: لتَطْلُبُوا.</p><p><span class="qpc-hafs">﴿مِن فَضۡلِهِۦٓ﴾</span>: مِن رزقِ اللهِ.</p></div>"