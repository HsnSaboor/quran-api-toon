quran[10]{c,v,t}:
  16,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَآ ءَاتَيۡنَـٰهُمۡ﴾</span>: من النِّعَمِ.</p><p><span class="qpc-hafs">﴿فَتَمَتَّعُواْ﴾</span>: عِيشُوا في أمْنٍ وسلامةٍ، والتَذُّوا بالدنيا، والمرادُ التهديدُ.</p></div>"
  16,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَجۡعَلُونَ﴾</span>: ويجعلُ المشركون على وجْهِ التقرُّبِ.</p><p><span class="qpc-hafs">﴿لِمَا لَا يَعۡلَمُونَ﴾</span>: لآلهتِهم التي لا عِلْمَ لها، ولا تنفعُ ولا تَضُرُّ.</p><p><span class="qpc-hafs">﴿تَفۡتَرُونَ﴾</span>: تَكْذِبُون على الله من الباطِلِ.</p></div>"
  16,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّا يَشۡتَهُونَ﴾</span>: ما يُحِبُّون من البنين.</p></div>"
  16,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَظِيمࣱ﴾</span>: ممتلِئٌ غَمًّا وحُزْنًا وغَضَبًا.</p></div>"
  16,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَ ٰ⁠رَىٰ مِنَ ٱلۡقَوۡمِ﴾</span>: يَسْتَخْفي من قومِه؟</p><p><span class="qpc-hafs">﴿أَيُمۡسِكُهُۥ﴾</span>: أيُبقي مَوْلُودَه الأنثى حيًا.</p><p><span class="qpc-hafs">﴿هُونٍ﴾</span>: ذُلٍّ وهَوانٍ.</p><p><span class="qpc-hafs">﴿يَدُسُّهُۥ﴾</span>: يُخْفِيه، فَيدْفِنُه حيًّا حتى يموتَ.</p></div>"
  16,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَثَلُ ٱلسَّوۡءِ﴾</span>: الصِّفةُ القبيحةُ من كراهةِ البناتِ، والجهلِ، والكفرِ باللهِ.</p><p><span class="qpc-hafs">﴿وَلِلَّهِ ٱلۡمَثَلُ ٱلۡأَعۡلَىٰ﴾</span>: الصفةُ العُليا من استحقاقِ العبوديةِ، والكمالِ، والجلالِ، والغنى، والجودِ.</p></div>"
  16,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَجَلࣲ مُّسَمࣰّى﴾</span>: وقتٍ محدَّدٍ هو نهايةُ آجالِهم.</p><p><span class="qpc-hafs">﴿وَلَا يَسۡتَقۡدِمُونَ﴾</span>: لا يَتَقَدَّمون عليه.</p></div>"
  16,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يَكۡرَهُونَ﴾</span>: ما لا يُحبون نِسْبتَه إلى أنفسِهم من البناتِ.</p><p><span class="qpc-hafs">﴿وَتَصِفُ﴾</span>: تقولُ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: حُسْنَ العاقبةِ.</p><p><span class="qpc-hafs">﴿لَا جَرَمَ﴾</span>: حقًّا، أو لا مَحالةَ.</p><p><span class="qpc-hafs">﴿مُّفۡرَطُونَ﴾</span>: مَتْرُوكون مَنسِيُّون فيها أبدًا.</p></div>"
  16,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَزَيَّنَ﴾</span>: حَسَّنَ.</p><p><span class="qpc-hafs">﴿وَلِيُّهُمُ ٱلۡيَوۡمَ﴾</span>: مُتَوَلٍّ إغواءَهم في الدنيا.</p></div>"
  16,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القرآنَ العظيمَ.</p><p><span class="qpc-hafs">﴿لِتُبَيِّنَ لَهُمُ﴾</span>: لتُوَضِّحَ للناسِ.</p></div>"