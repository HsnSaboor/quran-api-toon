quran[18]{c,v,t}:
  98,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: جَنّاتُ إقامَةٍ واسْتِقرارٍ في مُنْتَهى الحُسْنِ.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: مِن تَحْتِ قُصُورِها وأشجارِها.</p><p><span class="qpc-hafs">﴿خَشِيَ رَبَّهُۥ﴾</span>: خافَ اللهَ واجْتَنَبَ مَعاصيَهُ.</p></div>"
  99,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُلۡزِلَتِ﴾</span>: رُجَّتْ.</p><p><span class="qpc-hafs">﴿زِلۡزَالَهَا﴾</span>: رَجًّا شَدِيدًا.</p></div>"
  99,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَثۡقَالَهَا﴾</span>: ما في بَطْنِها مِن مَوتى وكُنُوزٍ.</p></div>"
  99,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا لَهَا﴾</span>: ما الَّذِي حَدَثَ لَها؟</p></div>"
  99,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَئِذࣲ﴾</span>: يَومَ القيامةِ.</p><p><span class="qpc-hafs">﴿تُحَدِّثُ أَخۡبَارَهَا﴾</span>: تُخْبِرُ الأَرْضُ بِما عُمِلَ عَلَيها مِن خَيرٍ أو شَرٍّ.</p></div>"
  99,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡحَىٰ لَهَا﴾</span>: أمَرَها بأن تُخْبِرَ بِما عُمِلَ عَلَيها.</p></div>"
  99,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡدُرُ ٱلنَّاسُ﴾</span>: يَرْجِعُ النّاسُ عَن مَوقِفِ الحِسابِ.</p><p><span class="qpc-hafs">﴿أَشۡتَاتࣰا﴾</span>: أصنافًا مُتَفَرِّقِينَ.</p><p><span class="qpc-hafs">﴿لِّيُرَوۡاْ أَعۡمَـٰلَهُمۡ﴾</span>: لِيُرِيَهُم اللهُ ما عَمِلُوا.</p></div>"
  99,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِثۡقَالَ ذَرَّةٍ﴾</span>: وزنَ نَمْلَةٍ صَغِيرَةٍ.</p><p><span class="qpc-hafs">﴿يَرَهُۥ﴾</span>: يَرَ ثَوابَهُ في الآخِرَةِ.</p></div>"
  99,8,"<div class=ar lang=ar></div>"
  100,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡعَـٰدِيَـٰتِ﴾</span>: أقْسَمَ اللهُ تَعالى بالخَيلِ الجارياتِ في سَبِيلِ اللهِ.</p><p><span class="qpc-hafs">﴿ضَبۡحࣰا﴾</span>: حِينَ يَظْهَرُ صَوْتُها مِن سُرْعَةِ عَدْوِها.</p></div>"
  100,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡمُورِيَـٰتِ قَدۡحࣰا﴾</span>: فالخَيلِ اللاتِي تَنْقَدِحُ النّارُ مِن حَوافِرِها؛ من شِدَّةِ عَدْوِها.</p></div>"
  100,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡمُغِيرَ ٰ⁠تِ﴾</span>: فالمُغِيراتِ عَلى الأعداءِ.</p><p><span class="qpc-hafs">﴿صُبۡحࣰا﴾</span>: عِنْدَ الصُّبْحِ.</p></div>"
  100,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَثَرۡنَ بِهِۦ﴾</span>: فهَيَّجْنَ بِهذا العَدْوِ.</p><p><span class="qpc-hafs">﴿نَقۡعࣰا﴾</span>: غُبارًا.</p></div>"
  100,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَسَطۡنَ بِهِۦ﴾</span>: فتوسَّطْنَ بِرُكْبانِهِنَّ.</p><p><span class="qpc-hafs">﴿جَمۡعًا﴾</span>: جُموعَ الأعداءِ.</p></div>"
  100,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِرَبِّهِۦ لَكَنُودࣱ﴾</span>: لِنِعَمِ رَبَّهِ لَجَحُودٌ.</p></div>"
  100,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ ذَ ٰ⁠لِكَ لَشَهِيدࣱ﴾</span>: مُقِرٌّ بِجُحُودِهِ.</p></div>"
  100,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡخَيۡرِ﴾</span>: المالِ.</p></div>"
  100,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُعۡثِرَ مَا فِي ٱلۡقُبُورِ﴾</span>: أخْرَجَ اللهُ الأمواتَ مِنَ القُبُورِ لِلْحِسابِ؟</p></div>"