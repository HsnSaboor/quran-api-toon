quran[8]{c,v,t}:
  12,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَجۡمَعُوٓاْ﴾</span>: عَزَمُوا.</p><p><span class="qpc-hafs">﴿وَأَوۡحَيۡنَآ إِلَيۡهِ﴾</span>: أعلمَ اللهُ يوسُفَ؛ تَطْمينًا لقَلْبِه.</p><p><span class="qpc-hafs">﴿لَتُنَبِّئَنَّهُم﴾</span>: لتُخْبِرَنَّ إخوتَك.</p></div>"
  12,16,""
  12,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَسۡتَبِقُ﴾</span>: نتسابَقُ في الجَرْيِ والرَّمْيِ بالسِّهامِ.</p><p><span class="qpc-hafs">﴿مَتَـٰعِنَا﴾</span>: ما ننتفِعُ به من الطَّعامِ والثيابِ ونحوِهما.</p><p><span class="qpc-hafs">﴿بِمُؤۡمِنࣲ لَّنَا﴾</span>: بمُصَدِّقٍ لنا.</p></div>"
  12,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَوَّلَتۡ﴾</span>: زَيَّنَتْ.</p><p><span class="qpc-hafs">﴿فَصَبۡرࣱ جَمِيلࣱ﴾</span>: وهو ما لا جَزَعَ فيه، ولا شَكْوى معه لأحدٍ من الخَلْقِ.</p></div>"
  12,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيَّارَةࣱ﴾</span>: جماعةٌ من المسافرين.</p><p><span class="qpc-hafs">﴿وَارِدَهُمۡ﴾</span>: مَن يتقدَّمُهم ليطلُبَ لهم الماءَ.</p><p><span class="qpc-hafs">﴿فَأَدۡلَىٰ دَلۡوَهُۥ﴾</span>: فأَنْزَلَها الواردُ في البئرِ.</p><p><span class="qpc-hafs">﴿وَأَسَرُّوهُ﴾</span>: وأخفى الوارِدُ وأصحابُه يوسفَ عن بقيةِ المسافرين.</p><p><span class="qpc-hafs">﴿بِضَـٰعَةࣰ﴾</span>: متاعًا للتجارة.</p></div>"
  12,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَشَرَوۡهُ﴾</span>: باعه إخوتُه.</p><p><span class="qpc-hafs">﴿بَخۡسࣲ﴾</span>: قليلٍ ناقصٍ عن مِثْلِه.</p><p><span class="qpc-hafs">﴿ٱلزَّ ٰ⁠هِدِينَ﴾</span>: المُعْرِضين عنه، غيرِ المبالِين به.</p></div>"
  12,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكۡرِمِي مَثۡوَىٰهُ﴾</span>: اجعلي مَقامَه عندنا كريمًا.</p><p><span class="qpc-hafs">﴿فِي ٱلۡأَرۡضِ﴾</span>: أرضِ مصرَ.</p><p><span class="qpc-hafs">﴿وَٱللَّهُ غَالِبٌ عَلَىٰٓ أَمۡرِهِۦ﴾</span>: لا يُعْجِزُه شيءٌ، ولا ينازعُه في حُكْمِه أحدٌ.</p></div>"
  12,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَشُدَّهُۥٓ﴾</span>: منتهى قوتِه الجسميةِ، وتكامُلَ عَقْلِه.</p><p><span class="qpc-hafs">﴿حُكۡمࣰا﴾</span>: حِكْمةً وفَهْمًا سديدًا، أو النبوَّةَ.</p></div>"