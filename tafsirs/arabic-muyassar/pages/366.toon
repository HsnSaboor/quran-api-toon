quran[10]{c,v,t}:
  25,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَدۡعُونَ﴾</span>: لا يَعْبُدُونَ.</p><p><span class="qpc-hafs">﴿أَثَامࣰا﴾</span>: عِقابًا.</p></div>"
  25,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَخۡلُدۡ فِيهِۦ﴾</span>: ويَبْقى فيه على الدَّوامِ.</p><p><span class="qpc-hafs">﴿مُهَانًا﴾</span>: ذلِيلًا حَقِيرًا.</p></div>"
  25,70,""
  25,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَابࣰا﴾</span>: توبةً.</p></div>"
  25,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلزُّورَ﴾</span>: شَهادَةً كاذِبَةً.</p><p><span class="qpc-hafs">﴿بِٱللَّغۡوِ﴾</span>: بِكُلِّ ساقِطٍ مِن قَوْلٍ أو فِعْلٍ.</p><p><span class="qpc-hafs">﴿مَرُّواْ كِرَامࣰا﴾</span>: مُكْرِمِينَ أنْفُسَهُم بالإعْراضِ عَنْهُ.</p></div>"
  25,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمۡ يَخِرُّواْ﴾</span>: لم يَسْقُطُوا ولَمْ يَقَعُوا.</p><p><span class="qpc-hafs">﴿صُمࣰّا وَعُمۡيَانࣰا﴾</span>: أي: لا يَسْمَعُونَ ولا يُبْصِرُونَ، والمعنى إنّما يَخِرُّونَ عَلَيها سامِعِينَ مُبْصِرِينَ مُنْتَفِعِينَ.</p></div>"
  25,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُرَّةَ أَعۡيُنࣲ﴾</span>: مَوْضِعَ سُرورٍ وفَرَحٍ.</p></div>"
  25,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغُرۡفَةَ﴾</span>: المرادُ منها أعلى مَنازِلِ الجنَّةِ وأَفْضَلُها.</p></div>"
  25,76,""
  25,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يَعۡبَؤُاْ بِكُمۡ﴾</span>: لا يُبالي بكُم.</p><p><span class="qpc-hafs">﴿لِزَامَۢا﴾</span>: أي: عَذابًا داِئمًا مُلازِمًا لَكُم.</p></div>"