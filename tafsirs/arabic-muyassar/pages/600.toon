quran[21]{c,v,t}:
  100,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحُصِّلَ﴾</span>: واسْتُخْرِجَ.</p><p><span class="qpc-hafs">﴿مَا فِي ٱلصُّدُورِ﴾</span>: ما اسْتَتَرَ في الصُّدُورِ مِن خَيْرٍ أو شَرٍّ.</p></div>"
  100,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّخَبِيرُۢ﴾</span>: لَمُطَّلِعٌ على باطِنِ أمْرِهِم فلا يَخْفى عَلَيهِ شيءٌ مِن ذَلِكَ.</p></div>"
  101,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَارِعَةُ﴾</span>: السّاعةُ الَّتِي تَقْرَعُ قُلُوبَ النّاسِ بِأَهْوالِها.</p></div>"
  101,2,"<div class=ar lang=ar></div>"
  101,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعَلَمَكَ بِها؟</p></div>"
  101,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡفَرَاشِ ٱلۡمَبۡثُوثِ﴾</span>: كالفَراشِ المُنْتَشِرِ.</p></div>"
  101,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَٱلۡعِهۡنِ ٱلۡمَنفُوشِ﴾</span>: كالصُّوفِ المُتَعَدِّدِ الألوانِ الَّذِي يُنْفَشُ باليدِ، فَيَصِيرُ هَباءً ويَزُولُ.</p></div>"
  101,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: مَن رَجَحَتْ مَوازِينُ حَسَناتِهِ.</p></div>"
  101,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِيشَةࣲ رَّاضِيَةࣲ﴾</span>: حياةٍ مُرْضِيَةٍ في الجنَّةِ.</p></div>"
  101,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَنۡ خَفَّتۡ مَوَ ٰ⁠زِينُهُۥ﴾</span>: مَن خَفَّتْ مَوازِينُ حسناتِهِ ورَجَحَتْ مَوازينُ سَيِّئاتِهِ.</p></div>"
  101,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأُمُّهُۥ هَاوِيَةࣱ﴾</span>: فَمَأواهُ جَهَنَّمُ؛ لِأنّهُ يَهْوِي فِيها عَلى أُمِّ رَأْسِهِ.</p></div>"
  101,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شَيءٍ أعْلَمكَ؟</p><p><span class="qpc-hafs">﴿مَا هِيَهۡ﴾</span>: ما هذهِ الهاوِيةُ؟.</p></div>"
  101,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَامِيَةُۢ﴾</span>: قَدْ حَمِيَتْ مِنَ الوَقُودِ عَلَيها.</p></div>"
  102,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلۡهَىٰكُمُ﴾</span>: شَغَلَكُم عَن طاعَةِ اللهِ.</p><p><span class="qpc-hafs">﴿ٱلتَّكَاثُرُ﴾</span>: التَّفاخُرُ بِكَثْرةِ الأَمْوالِ والأولادِ.</p></div>"
  102,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَتَّىٰ زُرۡتُمُ ٱلۡمَقَابِرَ﴾</span>: وانْشَغَلتُم بِذَلِكَ إلى أن دُفِنتم في المقابِر.</p></div>"
  102,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلَّا﴾</span>: ما هَكَذا ينبغي أن يُلْهيَكُم التكاثُرُ بالأَمْوالِ.</p><p><span class="qpc-hafs">﴿سَوۡفَ تَعۡلَمُونَ﴾</span>: أنَّ الدّارَ الآخِرةَ خَيرٌ لَكُم.</p></div>"
  102,4,"<div class=ar lang=ar></div>"
  102,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡيَقِينِ﴾</span>: لو تَعْلَمُونَ حَقَّ العِلْمِ لانْزَجَرْتُم، ولَبادَرْتُم إلى إنقاذِ أنفُسِكُم مِنَ الهَلاكِ.</p></div>"
  102,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَتَرَوُنَّ ٱلۡجَحِيمَ﴾</span>: لَتُبصِرُنَّ الجحِيمَ.</p></div>"
  102,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ لَتَرَوُنَّهَا عَيۡنَ ٱلۡيَقِينِ﴾</span>: ثُمَّ لَتُبْصِرُنَّها دُونَ رَيبٍ.</p></div>"
  102,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَئِذٍ﴾</span>: يومَ القِيامةِ.</p><p><span class="qpc-hafs">﴿عَنِ ٱلنَّعِيمِ﴾</span>: عَن كُلِّ أنَواعِ النَّعِيمِ.</p></div>"