quran[15]{c,v,t}:
  72,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُسۡلِمُونَ﴾</span>: الخاضِعُونَ للهِ بالطّاعةِ.</p><p><span class="qpc-hafs">﴿ٱلۡقَـٰسِطُونَ﴾</span>: الجائِرُونَ العُصاةُ.</p><p><span class="qpc-hafs">﴿أَسۡلَمَ﴾</span>: وخَضَعَ للهِ بالطّاعةِ.</p><p><span class="qpc-hafs">﴿تَحَرَّوۡاْ﴾</span>: قَصَدُوا.</p><p><span class="qpc-hafs">﴿رَشَدࣰا﴾</span>: طَرِيقَ الحقِّ والصَّوابِ.</p></div>"
  72,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَمَّا ٱلۡقَـٰسِطُونَ﴾</span>: الجائِرُونَ عَن طَرِيقِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿حَطَبࣰا﴾</span>: وقُودًا.</p></div>"
  72,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَلَّوِ ٱسۡتَقَـٰمُواْ عَلَى ٱلطَّرِيقَةِ﴾</span>: لَو سارَ الكُفّارُ مِنَ الإنْسِ والِجنِّ على طَرِيقَةِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿غَدَقࣰا﴾</span>: كَثِيرًا.</p></div>"
  72,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّنَفۡتِنَهُمۡ فِيهِ﴾</span>: لِنَخْتَبِرَهُم.</p><p><span class="qpc-hafs">﴿ذِكۡرِ رَبِّهِۦ﴾</span>: طاعَةِ رَبِّهِ واسْتِماعِ القُرآنِ، والعَمَلِ بِهِ.</p><p><span class="qpc-hafs">﴿يَسۡلُكۡهُ﴾</span>: يُدْخِلْهُ.</p><p><span class="qpc-hafs">﴿صَعَدࣰا﴾</span>: شَدِيدًا شاقًّا.</p></div>"
  72,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّ ٱلۡمَسَـٰجِدَ لِلَّهِ﴾</span>: وأَنَّ المساجِدَ لِعبادَة اللهِ وحْدَهُ.</p><p><span class="qpc-hafs">﴿فَلَا تَدۡعُواْ مَعَ ٱللَّهِ أَحَدࣰا﴾</span>: فلا تَعْبُدُوا فِيها غَيرَهُ.</p></div>"
  72,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبۡدُ ٱللَّهِ﴾</span>: مُحَمَّدٌ ﷺ.</p><p><span class="qpc-hafs">﴿لِبَدࣰا﴾</span>: جَماعاتٍ مُتَراكِمَةً، بَعْضُها فَوْقَ بَعْضٍ؛ مِن شِدَّةِ ازْدِحامِهِم لِسَماعِ القُرآنِ مِنهُ.</p></div>"
  72,20,"<div class=ar lang=ar></div>"
  72,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنِّي لَآ أَمۡلِكُ لَكُمۡ ضَرࣰّا﴾</span>: لا أقْدِرُ أن أدْفَعَ عَنْكُم ضَرًّا.</p><p><span class="qpc-hafs">﴿وَلَا رَشَدࣰا﴾</span>: ولا أجْلِبُ لَكُم نَفْعًا.</p></div>"
  72,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَن يُجِيرَنِي﴾</span>: لَن يُنْقِذَني مِن عَذابِ اللهِ.</p><p><span class="qpc-hafs">﴿مُلۡتَحَدًا﴾</span>: مَلْجَأً أفِرُّ إلَيهِ مِن عَذابِهِ.</p></div>"
  72,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا بَلَـٰغࣰا مِّنَ ٱللَّهِ وَرِسَـٰلَـٰتِهِۦ﴾</span>: لَكِنْ أمْلِكُ أنْ أبَلِّغَكُم عَنِ اللهِ ما أمَرَنِي بِتَبْلِيغِهِ لَكُم.</p></div>"
  72,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا يُوعَدُونَ﴾</span>: ما يَعِدُهُم رَبُّهُم.</p><p><span class="qpc-hafs">﴿نَاصِرࣰا﴾</span>: مُعِينًا.</p><p><span class="qpc-hafs">﴿عَدَدࣰا﴾</span>: جُنْدًا.</p></div>"
  72,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنۡ أَدۡرِيٓ﴾</span>: ما أعْلَمُ.</p><p><span class="qpc-hafs">﴿مَّا تُوعَدُونَ﴾</span>: ما يَعِدُكُم رَبُّكُم مِنَ العَذابِ وقِيامِ السّاعةِ.</p><p><span class="qpc-hafs">﴿أَمَدًا﴾</span>: مُدَّةً طَوِيلَةً.</p></div>"
  72,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡغَيۡبِ﴾</span>: ما غابَ عَنِ الأبْصارِ.</p><p><span class="qpc-hafs">﴿فَلَا يُظۡهِرُ﴾</span>: فلا يُطْلِعُ.</p></div>"
  72,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا مَنِ ٱرۡتَضَىٰ مِن رَّسُولࣲ﴾</span>: إلّا مَن اختارهم اللهُ لِرسالَتِهِ، فَإنَّه يُطْلِعُهُم عَلى بَعْضِ الغَيبِ.</p><p><span class="qpc-hafs">﴿يَسۡلُكُ مِنۢ بَيۡنِ يَدَيۡهِ وَمِنۡ خَلۡفِهِۦ رَصَدࣰا﴾</span>: يُرْسِلُ مِن أمامِ الرَّسُولِ ومِن خَلْفِهِ ملائِكَةً يحفَظُونَهُ مِنَ الِجنِّ؛ لِئلّا يَسْتَرِقُوهُ ويَهْمِسُوا بِهِ إلى الكَهَنَةِ.</p></div>"
  72,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَحَاطَ بِمَا لَدَيۡهِمۡ﴾</span>: وعَلِمَ اللهُ بِكُلِّ ما عَنْدَهُم.</p><p><span class="qpc-hafs">﴿وَأَحۡصَىٰ كُلَّ شَيۡءٍ عَدَدَۢا﴾</span>: عَلِمَ اللهُ عَدَدَ الأَشْياءِ كُلِّها.</p></div>"