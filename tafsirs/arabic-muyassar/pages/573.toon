tafsir[15]{c,v,t}:
72,14," <q>﴿ٱلۡمُسۡلِمُونَ﴾</q>: الخاضِعُونَ للهِ بالطّاعةِ. <q>﴿ٱلۡقَـٰسِطُونَ﴾</q>: الجائِرُونَ العُصاةُ. <q>﴿أَسۡلَمَ﴾</q>: وخَضَعَ للهِ بالطّاعةِ. <q>﴿تَحَرَّوۡاْ﴾</q>: قَصَدُوا. <q>﴿رَشَدࣰا﴾</q>: طَرِيقَ الحقِّ والصَّوابِ. "
72,15," <q>﴿وَأَمَّا ٱلۡقَـٰسِطُونَ﴾</q>: الجائِرُونَ عَن طَرِيقِ الإسْلامِ. <q>﴿حَطَبࣰا﴾</q>: وقُودًا. "
72,16," <q>﴿وَأَلَّوِ ٱسۡتَقَـٰمُواْ عَلَى ٱلطَّرِيقَةِ﴾</q>: لَو سارَ الكُفّارُ مِنَ الإنْسِ والِجنِّ على طَرِيقَةِ الإسْلامِ. <q>﴿غَدَقࣰا﴾</q>: كَثِيرًا. "
72,17," <q>﴿لِّنَفۡتِنَهُمۡ فِيهِ﴾</q>: لِنَخْتَبِرَهُم. <q>﴿ذِكۡرِ رَبِّهِۦ﴾</q>: طاعَةِ رَبِّهِ واسْتِماعِ القُرآنِ، والعَمَلِ بِهِ. <q>﴿يَسۡلُكۡهُ﴾</q>: يُدْخِلْهُ. <q>﴿صَعَدࣰا﴾</q>: شَدِيدًا شاقًّا. "
72,18," <q>﴿وَأَنَّ ٱلۡمَسَـٰجِدَ لِلَّهِ﴾</q>: وأَنَّ المساجِدَ لِعبادَة اللهِ وحْدَهُ. <q>﴿فَلَا تَدۡعُواْ مَعَ ٱللَّهِ أَحَدࣰا﴾</q>: فلا تَعْبُدُوا فِيها غَيرَهُ. "
72,19," <q>﴿عَبۡدُ ٱللَّهِ﴾</q>: مُحَمَّدٌ ﷺ. <q>﴿لِبَدࣰا﴾</q>: جَماعاتٍ مُتَراكِمَةً، بَعْضُها فَوْقَ بَعْضٍ؛ مِن شِدَّةِ ازْدِحامِهِم لِسَماعِ القُرآنِ مِنهُ. "
  72,20,""
72,21," <q>﴿إِنِّي لَآ أَمۡلِكُ لَكُمۡ ضَرࣰّا﴾</q>: لا أقْدِرُ أن أدْفَعَ عَنْكُم ضَرًّا. <q>﴿وَلَا رَشَدࣰا﴾</q>: ولا أجْلِبُ لَكُم نَفْعًا. "
72,22," <q>﴿لَن يُجِيرَنِي﴾</q>: لَن يُنْقِذَني مِن عَذابِ اللهِ. <q>﴿مُلۡتَحَدًا﴾</q>: مَلْجَأً أفِرُّ إلَيهِ مِن عَذابِهِ. "
72,23," <q>﴿إِلَّا بَلَـٰغࣰا مِّنَ ٱللَّهِ وَرِسَـٰلَـٰتِهِۦ﴾</q>: لَكِنْ أمْلِكُ أنْ أبَلِّغَكُم عَنِ اللهِ ما أمَرَنِي بِتَبْلِيغِهِ لَكُم. "
72,24," <q>﴿مَا يُوعَدُونَ﴾</q>: ما يَعِدُهُم رَبُّهُم. <q>﴿نَاصِرࣰا﴾</q>: مُعِينًا. <q>﴿عَدَدࣰا﴾</q>: جُنْدًا. "
72,25," <q>﴿إِنۡ أَدۡرِيٓ﴾</q>: ما أعْلَمُ. <q>﴿مَّا تُوعَدُونَ﴾</q>: ما يَعِدُكُم رَبُّكُم مِنَ العَذابِ وقِيامِ السّاعةِ. <q>﴿أَمَدًا﴾</q>: مُدَّةً طَوِيلَةً. "
72,26," <q>﴿ٱلۡغَيۡبِ﴾</q>: ما غابَ عَنِ الأبْصارِ. <q>﴿فَلَا يُظۡهِرُ﴾</q>: فلا يُطْلِعُ. "
72,27," <q>﴿إِلَّا مَنِ ٱرۡتَضَىٰ مِن رَّسُولࣲ﴾</q>: إلّا مَن اختارهم اللهُ لِرسالَتِهِ، فَإنَّه يُطْلِعُهُم عَلى بَعْضِ الغَيبِ. <q>﴿يَسۡلُكُ مِنۢ بَيۡنِ يَدَيۡهِ وَمِنۡ خَلۡفِهِۦ رَصَدࣰا﴾</q>: يُرْسِلُ مِن أمامِ الرَّسُولِ ومِن خَلْفِهِ ملائِكَةً يحفَظُونَهُ مِنَ الِجنِّ؛ لِئلّا يَسْتَرِقُوهُ ويَهْمِسُوا بِهِ إلى الكَهَنَةِ. "
72,28," <q>﴿وَأَحَاطَ بِمَا لَدَيۡهِمۡ﴾</q>: وعَلِمَ اللهُ بِكُلِّ ما عَنْدَهُم. <q>﴿وَأَحۡصَىٰ كُلَّ شَيۡءٍ عَدَدَۢا﴾</q>: عَلِمَ اللهُ عَدَدَ الأَشْياءِ كُلِّها. "
