tafsir[19]{c,v,t}:
  26,1,""
26,2," <q>﴿ٱلۡكِتَـٰبِ﴾</q>: القرآنِ. "
26,3," <q>﴿بَـٰخِعࣱ نَّفۡسَكَ﴾</q>: مُهْلِكُها غَمًّا وحُزْنًا. "
26,4," <q>﴿ءَايَةࣰ﴾</q>: مُعْجِزَةً. <q>﴿خَـٰضِعِينَ﴾</q>: مُنْقادِينَ بالكُرْهِ مِنهُم. "
26,5," <q>﴿مُحۡدَثٍ﴾</q>: أي: مُجَدَّدٍ إنْزالُه. "
  26,6,""
26,7," <q>﴿أَوَ لَمۡ يَرَوۡاْ﴾</q>: أوَلَم يَنْظُرُوا. <q>﴿زَوۡجࣲ كَرِيمٍ﴾</q>: صِنْفٍ حَسَنٍ كَثِيرِ النَّفْعِ. "
26,8," <q>﴿لَـَٔايَةࣰ﴾</q>: لَدَلالةً واضِحَةً. "
  26,9,""
  26,10,""
26,11," <q>﴿أَلَا يَتَّقُونَ﴾</q>: ألا يَخافُونَ عِقابَ اللهِ تعالى؟ "
  26,12,""
  26,13,""
26,14," <q>﴿ذَنۢبࣱ﴾</q>: وهو قَتْلُ القِبْطِيِّ. "
26,15," <q>﴿بِـَٔايَـٰتِنَآ﴾</q>: بِمُعْجزاتِنا وحُجَجِنا. <q>﴿إِنَّا مَعَكُم﴾</q>: أي: بالعِلْمِ والحِفْظِ والنُّصْرَةِ. "
  26,16,""
  26,17,""
26,18," <q>﴿أَلَمۡ نُرَبِّكَ﴾</q>: ألم نَرْعَكَ. <q>﴿وَلِيدࣰا﴾</q>: صَغِيرًا. "
26,19," <q>﴿فَعۡلَتَكَ﴾</q>: أي: قَتْلَ القِبْطِيِّ. <q>﴿مِنَ ٱلۡكَـٰفِرِينَ﴾</q>: أي: من الجاحِدِينَ لِنِعْمَتِي. "
