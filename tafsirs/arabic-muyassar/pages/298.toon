quran[11]{c,v,t}:
  18,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَالِمࣱ لِّنَفۡسِهِۦ﴾</span>: كافرٌ بالبعثِ، مُعْجَبٌ بمالِه.</p><p><span class="qpc-hafs">﴿تَبِيدَ﴾</span>: تَهْلِكَ وتَفْنى.</p></div>"
  18,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَآئِمَةࣰ﴾</span>: كائنةً وواقعةً.</p><p><span class="qpc-hafs">﴿مُنقَلَبࣰا﴾</span>: مَرْجِعًا وعاقبةً.</p></div>"
  18,37,""
  18,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّـٰكِنَّا۠﴾</span>: لكنْ أنا أقولُ.</p></div>"
  18,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوۡلَآ﴾</span>: وهَلّا.</p></div>"
  18,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُسۡبَانࣰا﴾</span>: جَمْعُ حُسْبانَةٍ، وهو العذابُ كالصَّواعِقِ.</p><p><span class="qpc-hafs">﴿صَعِيدࣰا﴾</span>: أرضًا أو ترابًا.</p><p><span class="qpc-hafs">﴿زَلَقًا﴾</span>: لا نَباتَ فيها، ومَلْساءُ لا تَثْبُتُ عليها قَدَمٌ. والمرادُ أنها عَدِيمةُ النَّفْعِ.</p></div>"
  18,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَوۡرࣰا﴾</span>: غائِرًا ذاهبًا في أسفلِ الأرضِ.</p></div>"
  18,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُحِيطَ بِثَمَرِهِۦ﴾</span>: وأُهلِكَتْ أموالُ الكافرِ بما فيها حديقتاه، كما تَوَقَّعَ المؤمنُ.</p><p><span class="qpc-hafs">﴿يُقَلِّبُ كَفَّيۡهِ﴾</span>: دَلالةً على نَدَمِه وأَسَفِه وحَسْرَتِه.</p><p><span class="qpc-hafs">﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾</span>: متهدِّمةٌ سَقَطَ بعضُها على بعضٍ، خاليةٌ مما كان فيها.</p></div>"
  18,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِئَةࣱ﴾</span>: جماعةٌ ممَّنِ افتَخَرَ بهم.</p><p><span class="qpc-hafs">﴿وَمَا كَانَ مُنتَصِرًا﴾</span>: ما كان ممتنعًا بنفسِه وقوَّتِه عندَ انتقامِ اللهِ منه.</p></div>"
  18,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُنَالِكَ﴾</span>: في مثلِ هذه الشَّدائدِ، أو يومِ القيامةِ.</p><p><span class="qpc-hafs">﴿ٱلۡوَلَـٰيَةُ لِلَّهِ﴾</span>: النُّصْرَةُ للهِ وحدَه لا يَقْدِرُ عليها غيرُه.</p><p><span class="qpc-hafs">﴿عُقۡبࣰا﴾</span>: عاقبةً لمَن تَوَلّاهم.</p></div>"
  18,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱضۡرِبۡ لَهُم﴾</span>: اذكُرْ للناسِ وأَوْرِدْ.</p><p><span class="qpc-hafs">﴿مَّثَلَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: صِفَتَها في زينتِها، وتَقَلُّبَها وسُرْعَةَ زوالِها.</p><p><span class="qpc-hafs">﴿هَشِيمࣰا﴾</span>: يابسًا مُتَكَسِّرًا، بعد خُضْرَتِه ونَضارَتِه.</p><p><span class="qpc-hafs">﴿تَذۡرُوهُ ٱلرِّيَـٰحُ﴾</span>: تُذْهِبُه وتُفَرِّقُه إلى كلِّ جهةٍ.</p><p><span class="qpc-hafs">﴿مُّقۡتَدِرًا﴾</span>: كاملَ القُدْرةِ على كلِّ شيءٍ.</p></div>"