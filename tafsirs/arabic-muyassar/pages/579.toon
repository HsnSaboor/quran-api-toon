quran[20]{c,v,t}:
  76,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَشۡرَبُ بِهَا﴾</span>: يَشْرَبُ مِنها.</p><p><span class="qpc-hafs">﴿عِبَادُ ٱللَّهِ﴾</span>: هم الأبرارُ.</p><p><span class="qpc-hafs">﴿يُفَجِّرُونَهَا﴾</span>: يَسْتَقُونَ مِنها حيثُ شاؤُوا.</p><p><span class="qpc-hafs">﴿تَفۡجِيرࣰا﴾</span>: إجراءً سَهْلا.</p></div>"
  76,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُوفُونَ﴾</span>: يُؤَدُّونَ وافيًا دُونَ نَقْصٍ ولا تَقْصِيرٍ.</p><p><span class="qpc-hafs">﴿بِٱلنَّذۡرِ﴾</span>: ما أوْجَبُوهُ على أنْفُسِهِم مِن فِعْلِ الخيرِ المُتَقرَّبِ بِهِ إلى اللهِ.</p><p><span class="qpc-hafs">﴿وَيَخَافُونَ يَوۡمࣰا﴾</span>: ويخافُونَ عِقابَ اللهِ يومَ القِيامةِ.</p><p><span class="qpc-hafs">﴿مُسۡتَطِيرࣰا﴾</span>: مُنْتَشِرًا.</p></div>"
  76,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ حُبِّهِۦ﴾</span>: مَعَ حُبِّهِم لَهُ وحاجَتِهِم إلَيهِ.</p><p><span class="qpc-hafs">﴿مِسۡكِينࣰا﴾</span>: مُحْتاجًا.</p><p><span class="qpc-hafs">﴿وَيَتِيمࣰا﴾</span>: وطِفْلًا ماتَ أبُوهُ ولا مالَ لَهُ.</p><p><span class="qpc-hafs">﴿وَأَسِيرًا﴾</span>: الَّذِي تَمَّ أسْرُهُ في الحرْبِ.</p></div>"
  76,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِوَجۡهِ ٱللَّهِ﴾</span>: اْبتِغاءَ مَرْضاةِ اللهِ.</p><p><span class="qpc-hafs">﴿جَزَآءࣰ﴾</span>: عِوَضًا.</p></div>"
  76,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبُوسࣰا﴾</span>: تَكْلَحُ فِيهِ الوُجُوهُ.</p><p><span class="qpc-hafs">﴿قَمۡطَرِيرࣰا﴾</span>: تَتَقَطَّبُ الجِباهُ مِن فَظاعَةِ أمْرِهِ.</p></div>"
  76,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَّىٰهُمۡ﴾</span>: جَعَلَهُم يَلْقَونَ.</p><p><span class="qpc-hafs">﴿نَضۡرَةࣰ﴾</span>: نُورًا في وُجُوهِهِم.</p></div>"
  76,12,""
  76,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّتَّكِـِٔينَ﴾</span>: جالِسِينَ على وجْهِ التَّمَكُّنِ والرّاحَةِ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرَآئِكِ﴾</span>: الأَسِرَّةِ المزيَّنَةِ بفاخرِ الثِّيابِ والسُّتُورِ.</p><p><span class="qpc-hafs">﴿شَمۡسࣰا﴾</span>: حرَّ شَمْسٍ؛ لِعَدَمِ وُجُودِها.</p><p><span class="qpc-hafs">﴿زَمۡهَرِيرࣰا﴾</span>: شِدّةَ بَرْدٍ.</p></div>"
  76,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَدَانِيَةً عَلَيۡهِمۡ﴾</span>: وقَريبةً مِنهُم.</p><p><span class="qpc-hafs">﴿ظِلَـٰلُهَا﴾</span>: أشْجارُ الجنَّةِ مُظَلَّلَةٌ عَليهِم.</p><p><span class="qpc-hafs">﴿وَذُلِّلَتۡ﴾</span>: وسُهِّلَ لَهُم.</p><p><span class="qpc-hafs">﴿قُطُوفُهَا﴾</span>: أخْذُ ثِمارِها.</p></div>"
  76,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُطَافُ عَلَيۡهِم﴾</span>: ويَدُورُ عَلَيهِم الَخَدمُ.</p><p><span class="qpc-hafs">﴿بِـَٔانِيَةࣲ مِّن فِضَّةࣲ﴾</span>: بأواني الطَّعامِ وأَوْعِيَتِهِ الفِضِّيَّةِ.</p><p><span class="qpc-hafs">﴿قَوَارِيرَا۠﴾</span>: مِنَ الزُّجاجِ.</p></div>"
  76,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّرُوهَا تَقۡدِيرࣰا﴾</span>: قدَّرها السُّقاةُ على مِقْدارِ ما يَشْتَهِي الشارِبُونَ لا تَزِيدُ ولا تَنْقُصُ.</p></div>"
  76,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأۡسࣰا﴾</span>: إناءً مَمْلُوءًا خمَرًا.</p><p><span class="qpc-hafs">﴿مِزَاجُهَا﴾</span>: ما تُخْلَطُ بِهِ.</p></div>"
  76,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَلۡسَبِيلࣰا﴾</span>: الماءُ السَّهْلُ المَساغِ.</p></div>"
  76,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وِلۡدَ ٰ⁠نࣱ﴾</span>: غِلْمانٌ دائِمُونَ.</p><p><span class="qpc-hafs">﴿لُؤۡلُؤࣰا﴾</span>: دُرًّا مُضِيئًا.</p><p><span class="qpc-hafs">﴿مَّنثُورࣰا﴾</span>: مُفَرَّقًا.</p></div>"
  76,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَأَيۡتَ ثَمَّ﴾</span>: أبْصَرْتَ أيَّ مَكانٍ في الجنَّةِ.</p></div>"
  76,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَـٰلِيَهُمۡ﴾</span>: يَعْلُوهُم ويُجَمِّلُ أبْدانَهُم.</p><p><span class="qpc-hafs">﴿ثِيَابُ سُندُسٍ خُضۡرࣱ﴾</span>: ثِيابٌ بطائِنُها مِنَ الحريرِ الرَّقِيقِ الأخْضَرِ.</p><p><span class="qpc-hafs">﴿وَإِسۡتَبۡرَقࣱ﴾</span>: وظاهِرُها مِنَ الحريرِ الغلِيظِ.</p><p><span class="qpc-hafs">﴿وَحُلُّوٓاْ﴾</span>: وأُلْبِسُوا للزِّينَةِ.</p><p><span class="qpc-hafs">﴿أَسَاوِرَ﴾</span>: جَمْعُ سِوارٍ، وهو ما يُلْبسُ في المِعْصَمِ مِنَ الحُليِّ.</p><p><span class="qpc-hafs">﴿طَهُورًا﴾</span>: لا رِجْسَ فِيهِ ولا دَنَسَ.</p></div>"
  76,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَعۡيُكُم﴾</span>: عَمَلُكُم في الدُّنيا.</p><p><span class="qpc-hafs">﴿مَّشۡكُورًا﴾</span>: مَرْضِيًّا عِنْدَ اللهِ مَقْبُولًا.</p></div>"
  76,23,""
  76,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ﴾</span>: فاصْبِرْ لحُكْمِ رَبِّكَ القَدَريِّ واقْبَلْهُ، ولِحُكْمِهِ الدِّينِيِّ فامْضِ عَلَيهِ.</p><p><span class="qpc-hafs">﴿ءَاثِمًا﴾</span>: عاصِيًا.</p><p><span class="qpc-hafs">﴿أَوۡ كَفُورࣰا﴾</span>: أو مُبالِغًا في الكُفْرِ والضَّلالِ.</p></div>"
  76,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُكۡرَةࣰ﴾</span>: أوَّلَ النَّهارِ.</p><p><span class="qpc-hafs">﴿وَأَصِيلࣰا﴾</span>: آخِرَ النَّهارِ.</p></div>"