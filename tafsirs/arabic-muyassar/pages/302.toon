quran[9]{c,v,t}:
  18,75,"<div class=ar lang=ar></div>"
  18,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن لَّدُنِّي عُذۡرࣰا﴾</span>: إلى الغايةِ التي أعْذُرُكَ في فِراقي بسببِها.</p></div>"
  18,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَطۡعَمَآ أَهۡلَهَا﴾</span>: طَلَبا من أهلِ القريةِ الطعامَ على وجْهِ الضِّيافَةِ.</p><p><span class="qpc-hafs">﴿فَأَبَوۡاْ﴾</span>: امتنعُوا.</p><p><span class="qpc-hafs">﴿يُرِيدُ﴾</span>: يَقْرُبُ ويُوشِكُ.</p><p><span class="qpc-hafs">﴿أَن يَنقَضَّ﴾</span>: أن يسقطَ؛ بسببِ مَيَلانِه.</p><p><span class="qpc-hafs">﴿فَأَقَامَهُۥ﴾</span>: سوّاه الخَضرُ وعَدَّلَ ميلَه.</p></div>"
  18,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَأُنَبِّئُكَ﴾</span>: سأُخْبِرُكَ.</p><p><span class="qpc-hafs">﴿بِتَأۡوِيلِ﴾</span>: بحقيقةِ مَقْصِدي من أفعالي.</p></div>"
  18,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمَسَـٰكِينَ﴾</span>: محتاجِين لا يملِكُون ما يَكْفيهم ويَسُدُّ حاجتَهم.</p><p><span class="qpc-hafs">﴿أَعِيبَهَا﴾</span>: أُحْدِثَ فيها عَيْبًا بخَرْقِها.</p><p><span class="qpc-hafs">﴿وَرَآءَهُم﴾</span>: أمامَهم.</p><p><span class="qpc-hafs">﴿كُلَّ سَفِينَةٍ﴾</span>: صالحةٍ غيرِ مَعِيبةٍ.</p><p><span class="qpc-hafs">﴿غَصۡبࣰا﴾</span>: قَهْرًا وظُلْمًا.</p></div>"
  18,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُرۡهِقَهُمَا﴾</span>: يَدْفَعَ والدَيه إلى تجاوُزِ حدودِ اللهِ والكفرِ.</p></div>"
  18,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَكَوٰةࣰ﴾</span>: دِينًا وصَلاحًا.</p><p><span class="qpc-hafs">﴿رُحۡمࣰا﴾</span>: رحمةً بوالدَيه وبِرًّا بهما.</p></div>"
  18,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَنزࣱ﴾</span>: مالٌ مَدْفونٌ من الذَّهَبِ والفِضَّةِ.</p><p><span class="qpc-hafs">﴿يَبۡلُغَآ أَشُدَّهُمَا﴾</span>: قوَّتَهما وكمالَ عَقْلِهما.</p><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ تَأۡوِيلُ﴾</span>: الذي بَيَّنْتُ لك أسبابَه هو مآلُ تلك الأمورِ.</p></div>"
  18,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَسۡـَٔلُونَكَ﴾</span>: أي: كفارُ قريشٍ بتَلْقينٍ من اليهود.</p><p><span class="qpc-hafs">﴿ذِي ٱلۡقَرۡنَيۡنِ﴾</span>: عبدٌ صالحٌ مَلَّكه اللهُ الأرضَ، وأعطاه العِلْمَ والحكمةَ، حتى بَلَغَ سلطانُه المشرقَ والمغربَ، فسُمِّيَ ذا القَرْنين، فكأنه حاز قَرْنَي الدنيا.</p><p><span class="qpc-hafs">﴿ذِكۡرًا﴾</span>: خَبَرًا تتذكَّرون به.</p></div>"