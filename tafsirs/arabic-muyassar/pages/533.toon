tafsir[27]{c,v,t}:
55,41," <q>﴿بِسِيمَـٰهُمۡ﴾</q>: بعَلاماتِهِم. <q>﴿بِٱلنَّوَ ٰ⁠صِي﴾</q>: بمُقَدِّمَةِ رُؤُوسِهِم. "
  55,42,""
  55,43,""
55,44," <q>﴿حَمِيمٍ﴾</q>: الماءِ الشَّدِيدِ الحَرارَةِ. <q>﴿ءَانࣲ﴾</q>: بالغٍ مُنْتَهاهُ في الحرارةِ. "
  55,45,""
55,46," <q>﴿مَقَامَ رَبِّهِۦ﴾</q>: وقْتَ قِيامِهِ بين يَدَي رَبِّهِ. "
  55,47,""
55,48," <q>﴿أَفۡنَانࣲ﴾</q>: أغْصانٍ نَضِرَةٍ مِنَ الفَواكِهِ والثِّمارِ. "
  55,49,""
  55,50,""
  55,51,""
55,52," <q>﴿زَوۡجَانِ﴾</q>: صِنْفانِ. "
  55,53,""
55,54," <q>﴿بَطَآئِنُهَا﴾</q>: جَمْعُ بِطانَةٍ وهي: ما يَلِي الأرْضَ مِنَ الفِراشِ. <q>﴿إِسۡتَبۡرَقࣲ﴾</q>: غَلِيظِ الحرِيرِ الخالِصِ. <q>﴿وَجَنَى﴾</q>: وثَمَرُ. <q>﴿دَانࣲ﴾</q>: قَرِيبٌ إليهِم. "
  55,55,""
55,56," <q>﴿فِيهِنَّ﴾</q>: في هَذِه الفُرُشِ. <q>﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</q>: لا يَصْرِفْنَ أبْصارَهُنَّ إلى غَيرِ أزْواجِهِنَّ. <q>﴿لَمۡ يَطۡمِثۡهُنَّ﴾</q>: لم يَطَأْهُنَّ. "
  55,57,""
55,58," <q>﴿ٱلۡيَاقُوتُ﴾</q>: حَجَرٌ مِنَ الأحْجارِ الكَرِيمَةِ، ذُو ألْوانٍ. <q>﴿وَٱلۡمَرۡجَانُ﴾</q>: صِغارُ اللُّؤلُؤِ. "
  55,59,""
  55,60,""
  55,61,""
55,62," <q>﴿وَمِن دُونِهِمَا﴾</q>: ومِن دُونِ الجنَّتَينِ السّابِقَتَينِ في الدَّرَجِ. "
  55,63,""
55,64," <q>﴿مُدۡهَآمَّتَانِ﴾</q>: خَضْراوانِ، وقَدِ اشْتَدَّتْ خُضْرَتُهُما حَتّى مالَتْ إلى السَّوادِ. "
  55,65,""
55,66," <q>﴿نَضَّاخَتَانِ﴾</q>: فَوّارتانِ بالماءِ لا تَنْقَطِعانِ. "
  55,67,""
