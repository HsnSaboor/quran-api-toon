quran[8]{c,v,t}:
  2,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَوَاعِدَ مِنَ ٱلۡبَيۡتِ﴾</span>: أُسُس الكعبةِ التي تنهضُ عليها.</p></div>"
  2,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسۡلِمَيۡنِ لَكَ﴾</span>: منقادَيْن لأحكامِك.</p><p><span class="qpc-hafs">﴿مُّسۡلِمَةࣰ﴾</span>: منقادةً.</p><p><span class="qpc-hafs">﴿وَأَرِنَا مَنَاسِكَنَا﴾</span>: بَصِّرْنا بمعالِم عِبادتِنا.</p></div>"
  2,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِمۡ﴾</span>: في هذه الأمةِ.</p><p><span class="qpc-hafs">﴿مِّنۡهُمۡ﴾</span>: من ذريةِ إسماعيلَ.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ وَٱلۡحِكۡمَةَ﴾</span>: القرآنَ، والسُنَّةَ.</p><p><span class="qpc-hafs">﴿وَيُزَكِّيهِمۡ﴾</span>: يُطَهِّرُهم من الشِّرْكِ، وسوءِ الأخلاقِ.</p></div>"
  2,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرۡغَبُ عَن مِّلَّةِ إِبۡرَ ٰ⁠هِـۧمَ﴾</span>: يُعْرِضُ عن دينِه.</p><p><span class="qpc-hafs">﴿سَفِهَ نَفۡسَهُۥ﴾</span>: جَهِلَتْ نَفْسُه ما ينفعُها.</p><p><span class="qpc-hafs">﴿ٱصۡطَفَيۡنَـٰهُ﴾</span>: اختَرناه.</p></div>"
  2,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡلِمۡ﴾</span>: أخْلِصْ نفسَك لله.</p></div>"
  2,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱصۡطَفَىٰ﴾</span>: اختارَ.</p></div>"
  2,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُنتُمۡ﴾</span>: أيُّها اليهودُ.</p><p><span class="qpc-hafs">﴿شُهَدَآءَ﴾</span>: حاضِرِين، فلا تَدَّعُوا الأباطيلَ.</p><p><span class="qpc-hafs">﴿مُسۡلِمُونَ﴾</span>: مُنْقادُون، خاضِعُون.</p></div>"
  2,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ.</p><p><span class="qpc-hafs">﴿مَا كَسَبَتۡ﴾</span>: ما عَمِلَتْ.</p></div>"