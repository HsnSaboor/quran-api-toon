quran[8]{c,v,t}:
  8,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡتَغِيثُونَ﴾</span>: تَطْلُبون النَّصْرَ على عَدُوِّكم.</p><p><span class="qpc-hafs">﴿مُرۡدِفِينَ﴾</span>: يَتْبَعُ بعضُهم بعضًا.</p></div>"
  8,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا جَعَلَهُ ٱللَّهُ﴾</span>: وما جَعَلَ الإمدادَ.</p><p><span class="qpc-hafs">﴿وَلِتَطۡمَئِنَّ﴾</span>: ولِتَسْكُنَ وتُوقِنَ بنَصْرِ اللهِ.</p></div>"
  8,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُغَشِّيكُمُ﴾</span>: يُلْقي اللهُ عليكم.</p><p><span class="qpc-hafs">﴿أَمَنَةࣰ مِّنۡهُ﴾</span>: أمانًا من الله لكم.</p><p><span class="qpc-hafs">﴿وَيُذۡهِبَ﴾</span>: ويُزيلَ.</p><p><span class="qpc-hafs">﴿رِجۡزَ ٱلشَّيۡطَـٰنِ﴾</span>: وساوِسَه بما خَطَرَ لهم من الخوفِ والفَشَلِ.</p><p><span class="qpc-hafs">﴿وَلِيَرۡبِطَ عَلَىٰ قُلُوبِكُمۡ﴾</span>: وليُقَوِّيَها بالصَّبرِ والشَّجاعةِ.</p></div>"
  8,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنِّي مَعَكُمۡ﴾</span>: بإعانتي ونَصْري.</p><p><span class="qpc-hafs">﴿فَثَبِّتُواْ ٱلَّذِينَ ءَامَنُواْ﴾</span>: فَقَوُّوا عزائمَهم، وبَشِّرُوهم بالنَّصْرِ.</p><p><span class="qpc-hafs">﴿ٱلرُّعۡبَ﴾</span>: الخوفَ الشديدَ.</p><p><span class="qpc-hafs">﴿فَوۡقَ ٱلۡأَعۡنَاقِ﴾</span>: رؤوسَ الكفارِ.</p><p><span class="qpc-hafs">﴿كُلَّ بَنَانࣲ﴾</span>: كلَّ طَرَفٍ ومِفْصَلٍ في الجسمِ.</p></div>"
  8,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span>: ما وقَعَ عليهم من القَتْل.</p><p><span class="qpc-hafs">﴿شَآقُّواْ ٱللَّهَ﴾</span>: خالَفُوا أمْرَه.</p></div>"
  8,14,"<div class=ar lang=ar></div>"
  8,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَحۡفࣰا﴾</span>: مُتقارِبين يَدْنُو كلُّ فريقٍ من الآخَرِ.</p><p><span class="qpc-hafs">﴿فَلَا تُوَلُّوهُمُ ٱلۡأَدۡبَارَ﴾</span>: فلا تُدِيروا لهم ظُهورَكم مُنْهَزِمين.</p></div>"
  8,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَحَرِّفࣰا لِّقِتَالٍ﴾</span>: مائِلًا عن موقفِه إلى موضعٍ أصلَحَ للقتالِ فيه.</p><p><span class="qpc-hafs">﴿مُتَحَيِّزًا﴾</span>: مُنْحازًا ومنضَمًّا.</p><p><span class="qpc-hafs">﴿فِئَةࣲ﴾</span>: جماعةٍ من المسلمين في ميدانِ القتالِ.</p><p><span class="qpc-hafs">﴿بَآءَ بِغَضَبࣲ مِّنَ ٱللَّهِ﴾</span>: استحَقَّ غضَبه.</p></div>"