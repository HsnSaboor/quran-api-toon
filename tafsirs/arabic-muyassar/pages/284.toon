quran[10]{c,v,t}:
  17,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَاجِلَةَ﴾</span>: الحياةَ الدنيا.</p><p><span class="qpc-hafs">﴿يَصۡلَىٰهَا﴾</span>: يَدْخُلها.</p><p><span class="qpc-hafs">﴿مَذۡمُومࣰا﴾</span>: مَلُومًا.</p><p><span class="qpc-hafs">﴿مَّدۡحُورࣰا﴾</span>: مَطْرودًا من رحمةِ اللهِ.</p></div>"
  17,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّشۡكُورࣰا﴾</span>: مقبولًا عندَ اللهِ، وسيُثِيبُهم عليه.</p></div>"
  17,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُلࣰّا نُّمِدُّ﴾</span>: نَزيدُ كُلًّا من الفريقَين من غيرِ انقطاعٍ.</p><p><span class="qpc-hafs">﴿عَطَآءِ رَبِّكَ﴾</span>: رزقِه.</p><p><span class="qpc-hafs">﴿مَحۡظُورًا﴾</span>: ممنوعًا عن أحدٍ.</p></div>"
  17,21,"<div class=ar lang=ar></div>"
  17,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَقۡعُدَ﴾</span>: فتَصيرَ.</p><p><span class="qpc-hafs">﴿مَذۡمُومࣰا﴾</span>: من اللهِ وملائكتِه وصالحي المؤمنين.</p></div>"
  17,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَضَىٰ﴾</span>: حَكَمَ وأَمَرَ.</p><p><span class="qpc-hafs">﴿أُفࣲّ﴾</span>: كلمةٌ تَدُلُّ على التضجُّرِ والاستثقالِ.</p><p><span class="qpc-hafs">﴿وَلَا تَنۡهَرۡهُمَا﴾</span>: لا يَصْدُرْ منك إليهما قولٌ قبيحٌ.</p><p><span class="qpc-hafs">﴿كَرِيمࣰا﴾</span>: طَيِّبًا حَسَنًا مَقْرونًا بالاحترامِ والحياءِ.</p></div>"
  17,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱخۡفِضۡ لَهُمَا جَنَاحَ ٱلذُّلِّ﴾</span>: وكُنْ متواضِعًا مُتَذَلِّلًا لأمِّك وأبيك.</p><p><span class="qpc-hafs">﴿مِنَ ٱلرَّحۡمَةِ﴾</span>: لرِقَّتِك ورحمتِك بهما.</p></div>"
  17,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلۡأَوَّ ٰ⁠بِينَ﴾</span>: الرَّجّاعين إلى اللهِ بالتوبةِ والإنابةِ.</p></div>"
  17,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاتِ﴾</span>: وأعْطِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمِسۡكِينَ﴾</span>: الذي لا يَمْلِكُ ما يَكْفيه ويَسُدُّ حاجتَه.</p><p><span class="qpc-hafs">﴿وَٱبۡنَ ٱلسَّبِيلِ﴾</span>: المسافرَ المنقطعَ عن مالِه في سَفَرِه، وإن كان غنيًا في بلدِه.</p><p><span class="qpc-hafs">﴿وَلَا تُبَذِّرۡ﴾</span>: لا تُنْفِقْ مالَكَ في غيرِ موضِعِه الموافِقِ للشَّرعِ.</p></div>"
  17,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِخۡوَ ٰ⁠نَ ٱلشَّيَـٰطِينِ﴾</span>: أشباهَهم وقُرَناءَهم في الفسادِ والمعاصي.</p></div>"