quran[4]{c,v,t}:
  5,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلسُّحۡتِ﴾</span>: للمال الحَرامِ كالرَّشوة.</p><p><span class="qpc-hafs">﴿بِٱلۡقِسۡطِ﴾</span>: بالعدلِ.</p><p><span class="qpc-hafs">﴿ٱلۡمُقۡسِطِينَ﴾</span>: العادِلين.</p></div>"
  5,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَلَّوۡنَ مِنۢ بَعۡدِ ذَ ٰ⁠لِكَ﴾</span>: من بعدِ حُكْمِك إذا لم يُرْضِهم.</p></div>"
  5,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡلَمُواْ﴾</span>: انقادُوا لحُكْمِ اللهِ.</p><p><span class="qpc-hafs">﴿لِلَّذِينَ هَادُواْ﴾</span>: اليهودِ.</p><p><span class="qpc-hafs">﴿وَٱلرَّبَّـٰنِيُّونَ﴾</span>: والعُبّادُ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَحۡبَارُ﴾</span>: والعلماء.</p><p><span class="qpc-hafs">﴿ٱسۡتُحۡفِظُواْ﴾</span>: اسْتُودِعُوا عِلْمَه.</p><p><span class="qpc-hafs">﴿وَكَانُواْ عَلَيۡهِ شُهَدَآءَ﴾</span>: أي: الربّانيُّون والأحبارُ شهداءُ لمحمدٍ ﷺ بأنه نبيٌّ يَقْضي بالحقِّ.</p><p><span class="qpc-hafs">﴿وَلَا تَشۡتَرُواْ بِـَٔايَـٰتِي ثَمَنࣰا قَلِيلࣰا﴾</span>: ولا تأخُذُوا بتَرْكِ حُكمي مُقابِلًا حقيرًا.</p></div>"
  5,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلنَّفۡسِ﴾</span>: تُقْتَلُ بالنفسِ.</p><p><span class="qpc-hafs">﴿وَٱلۡجُرُوحَ قِصَاصࣱ﴾</span>: يُقْتَصُّ في الجُروحِ.</p><p><span class="qpc-hafs">﴿تَصَدَّقَ بِهِۦ﴾</span>: تجاوَزَ عن حَقِّه.</p><p><span class="qpc-hafs">﴿كَفَّارَةࣱ﴾</span>: تكفيرٌ لذنوبهِ.</p></div>"