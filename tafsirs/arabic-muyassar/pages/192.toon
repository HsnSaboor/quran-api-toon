quran[5]{c,v,t}:
  9,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُرِيدُونَ﴾</span>: يريدُ الكفّارُ بتكذيبهِم.</p><p><span class="qpc-hafs">﴿أَن يُطۡفِـُٔواْ﴾</span>: أن يُبْطِلُوا.</p><p><span class="qpc-hafs">﴿نُورَ ٱللَّهِ﴾</span>: دينَ الإسلامِ وما فيه من الهُدى والرَّشادِ.</p><p><span class="qpc-hafs">﴿يُتِمَّ نُورَهُۥ﴾</span>: يُكْمِلَ اللهُ دينَه ويُظْهِرَه.</p></div>"
  9,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡهُدَىٰ﴾</span>: بالإيمانِ الصَّحيحِ، والعلمِ النافعِ.</p><p><span class="qpc-hafs">﴿وَدِينِ ٱلۡحَقِّ﴾</span>: دينِ الإسلامِ.</p><p><span class="qpc-hafs">﴿لِيُظۡهِرَهُۥ﴾</span>: ليُعْلِيَه.</p><p><span class="qpc-hafs">﴿عَلَى ٱلدِّينِ كُلِّهِۦ﴾</span>: على الأديانِ جميعًا.</p></div>"
  9,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَأۡكُلُونَ أَمۡوَ ٰ⁠لَ ٱلنَّاسِ﴾</span>: لَيأخُذُونها.</p><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: بغيرِ حَقٍّ كالرِّشوةِ وغيرِها.</p><p><span class="qpc-hafs">﴿وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ﴾</span>: ويمنعون الناسَ من الدخولِ في الإسلامِ، أو اتباعِ الحقِّ.</p><p><span class="qpc-hafs">﴿يَكۡنِزُونَ ٱلذَّهَبَ وَٱلۡفِضَّةَ﴾</span>: يجمعونَ الأموالَ.</p><p><span class="qpc-hafs">﴿وَلَا يُنفِقُونَهَا فِي سَبِيلِ ٱللَّهِ﴾</span>: ولايُؤَدُّون زَكاتَها، ولايُخْرِجون منها الحقوقَ الواجبةَ.</p></div>"
  9,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتُكۡوَىٰ﴾</span>: تُحْرَقُ.</p><p><span class="qpc-hafs">﴿فَذُوقُواْ مَا كُنتُمۡ تَكۡنِزُونَ﴾</span>: ذُوقوا سوءَ عاقبةِ جَمْعِكم.</p></div>"
  9,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِدَّةَ ٱلشُّهُورِ﴾</span>: أي: عَدَدَها الذي يَتَألَّفُ منه العامُ.</p><p><span class="qpc-hafs">﴿فِي كِتَـٰبِ ٱللَّهِ﴾</span>: في حُكْمِه القَدَريِّ الذي كُتب في اللَّوحِ المحفوظِ.</p><p><span class="qpc-hafs">﴿أَرۡبَعَةٌ حُرُمࣱ﴾</span>: أي: ذاتُ حُرْمَةٍ وتعظيمٍ، وهي: رَجَبٌ، وذو القِعدة، وذو الحِجَّةِ، والمُحَرَّمُ.</p><p><span class="qpc-hafs">﴿ٱلۡقَيِّمُ﴾</span>: المستقيمُ الذي لا عِوَجَ فيه.</p><p><span class="qpc-hafs">﴿فَلَا تَظۡلِمُواْ فِيهِنَّ أَنفُسَكُمۡ﴾</span>: بارتكابِ ما حَرَّمَ اللهُ؛ لعِظَمِ حُرْمتِها.</p><p><span class="qpc-hafs">﴿كَآفَّةࣰ﴾</span>: جميعًا، وفي كلِّ الشهورِ.</p><p><span class="qpc-hafs">﴿وَٱعۡلَمُوٓاْ أَنَّ ٱللَّهَ مَعَ ٱلۡمُتَّقِينَ﴾</span>: بالعَوْنِ والنَّصرِ.</p></div>"