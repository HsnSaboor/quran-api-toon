quran[20]{c,v,t}:
26,20," <q>﴿مِنَ ٱلضَّآلِّينَ﴾</q>: مِنَ المُخْطِئِينَ لا المتعَمِّدِينَ. "
26,21," <q>﴿حُكۡمࣰا﴾</q>: أي: نُبُوَّةً وحِكْمَةً. "
26,22," <q>﴿تَمُنُّهَا عَلَيَّ﴾</q>: تَعُدُّها نِعْمَةً مِنكَ عليّ. <q>﴿عَبَّدتَّ﴾</q>: جَعَلْتَهُم عَبِيدًا تَذْبَحُ مَن تَشاءُ وتَتْرُكُ مَن تَشاءُ مِن أبْنائِهِم وتَسْتَبْقِي نِساءَهُم لِلْخِدْمَةِ والامْتِهانِ. "
  26,23,""
  26,24,""
  26,25,""
  26,26,""
  26,27,""
  26,28,""
  26,29,""
26,30," <q>﴿بِشَيۡءࣲ مُّبِينࣲ﴾</q>: أي: بِبُرْهانٍ قاطِعٍ. "
  26,31,""
  26,32,""
26,33," <q>﴿بَيۡضَآءُ﴾</q>: أي: مِن غَيرِ مَرَضٍ ولا بَرَصٍ. "
26,34," <q>﴿لِلۡمَلَإِ﴾</q>: لأشْرافِ قَوْمِهِ. <q>﴿لَسَـٰحِرٌ عَلِيمࣱ﴾</q>: أي: ساحِرٌ ماهِرٌ. "
  26,35,""
26,36," <q>﴿أَرۡجِهۡ﴾</q>: أخِّرْهُ. <q>﴿ٱلۡمَدَآئِنِ﴾</q>: المُدُنِ. <q>﴿حَـٰشِرِينَ﴾</q>: جامِعِينَ للسَّحَرةِ. "
  26,37,""
  26,38,""
  26,39,""
