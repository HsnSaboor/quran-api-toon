quran[4]{c,v,t}:
  2,187,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّفَثُ﴾</span>: الجِماعُ.</p><p><span class="qpc-hafs">﴿لِبَاسࣱ﴾</span>: سِتْرٌ وسَكَنٌ.</p><p><span class="qpc-hafs">﴿تَخۡتَانُونَ﴾</span>: تَخُونون. وكانوا يُجامِعُون نساءَهم بعدالعِشاء، وكان هذا مُحَرَّمًا أولَ الإسلامِ.</p><p><span class="qpc-hafs">﴿بَـٰشِرُوهُنَّ﴾</span>: جامِعُوهنَّ.</p><p><span class="qpc-hafs">﴿ٱبۡتَغُواْ مَا كَتَبَ ٱللَّهُ لَكُمۡ﴾</span>: واطْلبُوا ما قدَّره اللهُ من الوَلَدِ.</p><p><span class="qpc-hafs">﴿ٱلۡخَيۡطُ ٱلۡأَبۡيَضُ﴾</span>: ضوءُ الصبحِ.</p><p><span class="qpc-hafs">﴿ٱلۡخَيۡطِ ٱلۡأَسۡوَدِ﴾</span>: سوادِ الليلِ.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِهِۦ﴾</span>: أحكامَه.</p></div>"
  2,188,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡبَـٰطِلِ﴾</span>: بسببٍ باطلٍ كاليمينِ الكاذبةِ والرَّشوةِ.</p><p><span class="qpc-hafs">﴿وَتُدۡلُواْ بِهَآ إِلَى ٱلۡحُكَّامِ لِتَأۡكُلُواْ فَرِيقࣰا مِّنۡ أَمۡوَ ٰ⁠لِ ٱلنَّاسِ﴾</span>: لا تُلْقُوا بأموالِكم إلى الحُكّام؛ لتأكلوا أموالَ طائفةٍ من الناسِ بالحُجَجِ الباطلةِ.</p><p><span class="qpc-hafs">﴿وَأَنتُمۡ تَعۡلَمُونَ﴾</span>: تحريمَ ذلك.</p></div>"
  2,189,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَهِلَّةِ﴾</span>: جمعُ هِلالٍ، أي: عَنْ تَغَيُّر أحوالهِا بزيادةٍ أو نقصانٍ.</p><p><span class="qpc-hafs">﴿مَوَ ٰ⁠قِيتُ﴾</span>: علاماتٌ على أوقات العبادةِ والمعاملاتِ.</p><p><span class="qpc-hafs">﴿ٱلۡبِرُّ﴾</span>: الخير.</p><p><span class="qpc-hafs">﴿بِأَن تَأۡتُواْ ٱلۡبُيُوتَ مِن ظُهُورِهَا﴾</span>: كانوا أولَ الإسلام إذا أحْرَمُوا بحَجّ أو عُمْرَةٍ فَعَلُوا ذلك.</p><p><span class="qpc-hafs">﴿مَنِ ٱتَّقَىٰ﴾</span>: فِعْلُ مَن اتَّقى.</p></div>"
  2,190,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَعۡتَدُوٓاْ﴾</span>: لا تَرْتَكِبُوا المَناهيَ كقَتْلِ مَن لا يحِلُّ قَتْلُه.</p></div>"