quran[9]{c,v,t}:
  41,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَقَـٰمُواْ﴾</span>: سَلَكُوا الطَّريقَ القَوِيمَ، وأَدَّوا فَرائِضَ اللهِ.</p><p><span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيۡهِمُ ٱلۡمَلَـٰٓئِكَةُ﴾</span>: أي: عِنْدَ نُزُولِ الموتِ بِهِم مُطَمْئِنَةً.</p><p><span class="qpc-hafs">﴿أَلَّا تَخَافُواْ﴾</span>: تَقُولُ لَهُم: لا تخافُوا مِنَ الموتِ وما بَعْدَهُ.</p><p><span class="qpc-hafs">﴿وَلَا تَحۡزَنُواْ﴾</span>: عَلى ما تُخَلِّفُونَه وراءَكُم مِن أُمَورِ الدُّنيا.</p><p><span class="qpc-hafs">﴿وَأَبۡشِرُواْ﴾</span>: وسُرُّوا.</p></div>"
  41,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآؤُكُمۡ﴾</span>: أنْصارُكُم وأَحِبّاؤُكُم.</p><p><span class="qpc-hafs">﴿تَدَّعُونَ﴾</span>: تَتَمَنَّونَ.</p></div>"
  41,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُزُلࣰا﴾</span>: ضِيافَةً وتَكْرِمَةً.</p></div>"
  41,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۡ أَحۡسَنُ قَوۡلࣰا﴾</span>: لا أحَدَ أحْسَنُ قَولًا.</p><p><span class="qpc-hafs">﴿دَعَآ إِلَى ٱللَّهِ﴾</span>: دَعا إلى تَوْحِيدِ اللهِ وعِبادَتِه وحْدَهُ.</p></div>"
  41,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَسَنَةُ﴾</span>: الصَّبرُ والحِلْمُ والعَفْوُ.</p><p><span class="qpc-hafs">﴿ٱلسَّيِّئَةُ﴾</span>: الغَضَبُ والجَهْلُ والإساءَةُ.</p><p><span class="qpc-hafs">﴿ٱدۡفَعۡ بِٱلَّتِي هِيَ أَحۡسَنُ﴾</span>: ادْفَعْ -أيُّها الرَّسُولُ- بِعَفْوِكَ وحِلْمِكَ وإحْسانِكَ مَن أساءَ إليكَ.</p><p><span class="qpc-hafs">﴿وَلِيٌّ﴾</span>: مُحِبٌّ مُناصِرٌ.</p><p><span class="qpc-hafs">﴿حَمِيمࣱ﴾</span>: قَرِيبٌ مُشْفِقٌ.</p></div>"
  41,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا يُلَقَّىٰهَآ﴾</span>: وما يُعْطى ويُوفَّقُ لهذهِ الَمنْزِلَةِ الحمِيدَةِ.</p><p><span class="qpc-hafs">﴿حَظٍّ﴾</span>: نَصِيبٍ.</p></div>"
  41,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِمَّا يَنزَغَنَّكَ مِنَ ٱلشَّيۡطَـٰنِ نَزۡغࣱ﴾</span>: وإمّا يُلْقِيَنَّ الشَّيطانُ في نَفْسِكَ وسْوَسَةً مِن حدِيثِ النَّفْسِ تَحْمِلُكَ عَلى مُجازاةِ الُمسِيءِ بالإساءَةِ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾</span>: فاسْتَجِرْ بِاللهِ واعْتَصِمْ بِهِ.</p></div>"
  41,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنۡ ءَايَـٰتِهِ﴾</span>: ومِن حُجَجِ اللهِ عَلى خَلقِهِ، ودَلائِلِهِ عَلى وحْدانِيَّتهِ وكَمالِ قُدْرَتِهِ.</p></div>"
  41,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلَّذِينَ عِندَ رَبِّكَ﴾</span>: هُمُ الملائِكَةُ.</p><p><span class="qpc-hafs">﴿لَا يَسۡـَٔمُونَ﴾</span>: لا يَفْتُرُونَ ولا يَمَلُّونَ.</p></div>"