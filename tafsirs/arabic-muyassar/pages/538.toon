quran[8]{c,v,t}:
  57,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: عَلا وارْتَفَعَ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: سَرير المُلْكِ الَّذِي تَحْمِلُه الملائِكَةُ، واسْتَوىَ عَليهِ الرَّحمنُ، وهو أعْظَمُ المخلُوقاتِ، وهو سَقْفُ جَنَّةِ الفِرْدَوسِ.</p><p><span class="qpc-hafs">﴿يَلِجُ فِي ٱلۡأَرۡضِ﴾</span>: يَدْخُلُ مِن حَبٍّ ومَطَرٍ وغَيرِ ذَلِكَ.</p><p><span class="qpc-hafs">﴿يَعۡرُجُ فِيهَا﴾</span>: يَصْعَدُ مِنَ الملائِكةِ والأرْواحِ والأَدْعِيَةِ والأَعْمالِ.</p><p><span class="qpc-hafs">﴿مَعَكُمۡ﴾</span>: بِعِلْمِهِ.</p></div>"
  57,5,"<div class=ar lang=ar></div>"
  57,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُولِجُ ٱلَّيۡلَ فِي ٱلنَّهَارِ﴾</span>: يُدْخِلُ ما نَقَصَ مِن ساعاتِ الليل في النَّهارِ فَيَزِيدُ النَّهارَ.</p><p><span class="qpc-hafs">﴿وَيُولِجُ ٱلنَّهَارَ فِي ٱلَّيۡلِ﴾</span>: ويُدْخِلُ ما نَقَصَ من ساعاتِ النَّهارِ في الليلِ فَيَزيدُ الليلَ.</p><p><span class="qpc-hafs">﴿بِذَاتِ ٱلصُّدُورِ﴾</span>: بما فِي صُدُورِ خَلْقِهِ.</p></div>"
  57,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَعَلَكُم مُّسۡتَخۡلَفِينَ﴾</span>: جَعَلَها في أيْدِيكُم، واسْتَخْلَفَكُم عَلَيها.</p></div>"
  57,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِيثَـٰقَكُمۡ﴾</span>: عَهْدَكُم المؤَكَّدَ.</p></div>"
  57,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظُّلُمَـٰتِ﴾</span>: ظُلُماتِ الكُفْرِ.</p><p><span class="qpc-hafs">﴿ٱلنُّورِ﴾</span>: نُور الإيمانِ.</p><p><span class="qpc-hafs">﴿لَرَءُوفࣱ﴾</span>: لَرَحِيمٌ بِهِم أشَدَّ رَحْمةٍ.</p></div>"
  57,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لَكُمۡ أَلَّا تُنفِقُواْ﴾</span>: أيُّ شَيءٍ يَمْنَعُكُم مِنَ الإنْفاقِ؟</p><p><span class="qpc-hafs">﴿مِيرَ ٰ⁠ثُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span>: مُلْكُ السَّمَواتِ والأرْضِ، وسَيَنْتَقِلُ إلى مالِكِه الحقِيقِي.</p><p><span class="qpc-hafs">﴿ٱلۡفَتۡحِ﴾</span>: فَتْحِ مَكَّةَ.</p><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الجنَّةَ.</p></div>"
  57,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُقۡرِضُ ٱللَّهَ﴾</span>: يُنْفِقُ مُخْلِصًا عَمَلَهُ للهِ.</p></div>"