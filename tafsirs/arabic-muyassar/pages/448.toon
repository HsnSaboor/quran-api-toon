quran[25]{c,v,t}:
  37,52,""
37,53," <q>﴿لَمَدِينُونَ﴾</q>: لَمَجْزِيُّونَ ومُحاسَبُونَ. "
  37,54,""
37,55," <q>﴿سَوَآءِ ٱلۡجَحِيمِ﴾</q>: وسَطِها. "
37,56," <q>﴿تَٱللَّهِ﴾</q>: واللهِ. <q>﴿كِدتَّ﴾</q>: قارَبْتَ. <q>﴿لَتُرۡدِينِ﴾</q>: لَتُهْلِكُنِي. "
37,57," <q>﴿ٱلۡمُحۡضَرِينَ﴾</q>: أي: في العذابِ مِثلَك. "
  37,58,""
  37,59,""
  37,60,""
  37,61,""
37,62," <q>﴿نُّزُلًا﴾</q>: ما يُهَيَّأُ للنَّزيلِ إكْرامًا لهُ. <q>﴿شَجَرَةُ ٱلزَّقُّومِ﴾</q>: الشَّجَرَةُ الخَبيَثةُ الملعُونةُ ذاتُ الثَّمرِ المُرِّ الكرِيهِ الرّائِحَةِ. "
37,63," <q>﴿فِتۡنَةࣰ لِّلظَّـٰلِمِينَ﴾</q>: مِحْنَةً لَهُم لِكَوْنِهِم يُعَذَّبُونَ بِها في الآخِرةِ. "
37,64," <q>﴿تَخۡرُجُ﴾</q>: تَنْبُتُ. <q>﴿أَصۡلِ ٱلۡجَحِيمِ﴾</q>: قَعْرِ جَهَنَّمَ. "
37,65," <q>﴿طَلۡعُهَا﴾</q>: ثَمَرُها. <q>﴿كَأَنَّهُۥ رُءُوسُ ٱلشَّيَـٰطِينِ﴾</q>: تشبيهٌ للمَحْسُوسِ بالمتَخَيَّلِ؛ لِتناهِيهِ في البَشاعَةِ والقُبْحِ. "
  37,66,""
37,67," <q>﴿لَشَوۡبࣰا﴾</q>: لخَلْطًا ومِزاجًا. <q>﴿مِّنۡ حَمِيمࣲ﴾</q>: الماءِ الحارِّ الشَّديدِ الحرارةِ. "
37,68," <q>﴿مَرۡجِعَهُمۡ﴾</q>: مَرَدَّهُم. <q>﴿ٱلۡجَحِيمِ﴾</q>: جَهَنَّمَ. "
37,69," <q>﴿أَلۡفَوۡاْ﴾</q>: وجَدُوا. "
37,70," <q>﴿يُهۡرَعُونَ﴾</q>: يُسْرِعُونَ إلى متابعةِ آبائِهِم الضّالِّينَ. "
  37,71,""
37,72," <q>﴿مُّنذِرِينَ﴾</q>: مُرسَلِينَ. "
  37,73,""
  37,74,""
  37,75,""
37,76," <q>﴿ٱلۡكَرۡبِ ٱلۡعَظِيمِ﴾</q>: الغَرَقِ بالطُّوفانِ العظيمِ. "
