quran[8]{c,v,t}:
  16,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَكَنࣰا﴾</span>: مَسْكَنًا واستقرارًا لكم.</p><p><span class="qpc-hafs">﴿بُيُوتࣰا﴾</span>: كالخِيام.</p><p><span class="qpc-hafs">﴿تَسۡتَخِفُّونَهَا﴾</span>: تَجِدُونها خفيفةَ الحَمْلِ والنَّقْلِ.</p><p><span class="qpc-hafs">﴿يَوۡمَ ظَعۡنِكُمۡ﴾</span>: وقتَ سَفَرِكم.</p><p><span class="qpc-hafs">﴿وَمِنۡ أَصۡوَافِهَا﴾</span>: أي: أصوافِ الضَّأنِ.</p><p><span class="qpc-hafs">﴿وَأَوۡبَارِهَا﴾</span>: أي: أوبارِ الإبِل، وهو ما يَعْلُو أجسادَها.</p><p><span class="qpc-hafs">﴿وَأَشۡعَارِهَآ﴾</span>: أي: أشعارِ المَعْزِ.</p><p><span class="qpc-hafs">﴿أَثَـٰثࣰا﴾</span>: مَتاعًا لبيوتِكم، كالأغطيةِ والفُرُشِ.</p><p><span class="qpc-hafs">﴿وَمَتَـٰعًا﴾</span>: ما تتمتَّعُون وتنتفِعُون به.</p><p><span class="qpc-hafs">﴿إِلَىٰ حِينࣲ﴾</span>: إلى وقتٍ محدَّدٍ في الدنيا.</p></div>"
  16,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظِلَـٰلࣰا﴾</span>: ما تَسْتظِلُّون به من شدَّةِ الحرِّ.</p><p><span class="qpc-hafs">﴿أَكۡنَـٰنࣰا﴾</span>: أماكنَ وِقايةٍ وسِتْرٍ، كالكهوفِ.</p><p><span class="qpc-hafs">﴿سَرَ ٰ⁠بِيلَ﴾</span>: كلَّ ما يُلْبَس من ثيابٍ أو دُروعٍ.</p><p><span class="qpc-hafs">﴿بَأۡسَكُمۡ﴾</span>: الشدَّةَ في حروبِكم، كالطَّعْنِ والضَّرْبِ والشَّظايا.</p><p><span class="qpc-hafs">﴿تُسۡلِمُونَ﴾</span>: تَنقادُون وتَخْضَعُون لأمرِ اللهِ وحُكْمِه.</p></div>"
  16,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ﴾</span>: أعْرَضُوا.</p><p><span class="qpc-hafs">﴿ٱلۡمُبِينُ﴾</span>: الواضحُ.</p></div>"
  16,83,"<div class=ar lang=ar></div>"
  16,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: هو رسولُهم يَشْهَدُ على مَن آمَنَ منهم، وعلى مَن كَفَرَ.</p><p><span class="qpc-hafs">﴿لَا يُؤۡذَنُ لِلَّذِينَ كَفَرُواْ﴾</span>: بالاعتذار عَمّا وقَعَ منهم.</p><p><span class="qpc-hafs">﴿وَلَا هُمۡ يُسۡتَعۡتَبُونَ﴾</span>: لا يُطْلَبُ منهم العُتْبى، أي: الرجوعُ إلى ما يُرْضي اللهَ من التوبةِ والعملِ الصّالحِ.</p></div>"
  16,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنظَرُونَ﴾</span>: يُمْهَلُون ويُؤَخَّرون عنه.</p></div>"
  16,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُرَكَآءَهُمۡ﴾</span>: آلهتَهم المزعومةَ.</p><p><span class="qpc-hafs">﴿نَدۡعُواْ﴾</span>: نعبدُ.</p><p><span class="qpc-hafs">﴿فَأَلۡقَوۡاْ إِلَيۡهِمُ ٱلۡقَوۡلَ﴾</span>: رَدَّتِ الآلهةُ على عابدِيها قائلين.</p></div>"
  16,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَلۡقَوۡاْ إِلَى ٱللَّهِ يَوۡمَئِذٍ ٱلسَّلَمَ﴾</span>: أظهرَ المشركونَ خُضوعَهم وانقيادَهم للهِ يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: غابَ وضاعَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يختلِقُونَه مِن الأكاذيبِ.</p></div>"