quran[15]{c,v,t}:
  19,96,""
  19,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لُّدࣰّا﴾</span>: شَدِيدِي الخُصُومَةِ بالباطِل.</p></div>"
  19,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِّن قَرۡنٍ﴾</span>: مِن أُمَمٍ.</p><p><span class="qpc-hafs">﴿رِكۡزَۢا﴾</span>: صَوْتًا خَفِيًّا.</p></div>"
  20,1,""
  20,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَشۡقَىٰٓ﴾</span>: لِتَتْعبَ بفَرْطِ تأسُّفِكَ على كُفْرِهِم.</p></div>"
  20,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَذۡكِرَةࣰ﴾</span>: عِظَةً وعِبْرةً.</p></div>"
  20,4,""
  20,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هو سَرِيَرُ المُلْكِ الذي اسْتَوى عَلَيه الرحمنُ، وتَحمِلُه الملائِكةُ، وهو أعْظَمُ المخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p><p><span class="qpc-hafs">﴿ٱسۡتَوَىٰ﴾</span>: عَلا وارْتَفَعَ، اسْتِواءً يلِيقُ بِجَلالِه وعَظَمَتِه.</p></div>"
  20,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تَحۡتَ ٱلثَّرَىٰ﴾</span>: باطِنِ الأَرْضِ.</p></div>"
  20,7,""
  20,8,""
  20,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَدِيثُ مُوسَىٰٓ﴾</span>: خبرُ مُوسى بن عِمْرانَ عليه الصَّلاةُ والسَّلامُ، لمّا رَجَعَ مِن مَدْيَنَ إلى مِصْرَ.</p></div>"
  20,10,""
  20,11,""
  20,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طُوࣰى﴾</span>: اسْمِ الوادِي الُمقَدَّسِ.</p></div>"