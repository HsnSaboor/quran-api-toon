quran[24]{c,v,t}:
37,103," <q>﴿أَسۡلَمَا﴾</q>: اسْتَسْلَما لأمْرِ اللهِ وانْقادا لَه. <q>﴿وَتَلَّهُۥ لِلۡجَبِينِ﴾</q>: أي: أضْجَعَه على جَبينِه على الأرضِ. "
  37,104,""
  37,105,""
37,106," <q>﴿ٱلۡبَلَـٰٓؤُاْ ٱلۡمُبِينُ﴾</q>: الاخْتِبارُ الواضِحُ. "
37,107," <q>﴿بِذِبۡحٍ عَظِيمࣲ﴾</q>: بكَبْشٍ مَذْبُوحٍ عَظِيمِ القَدْرِ. "
37,108," <q>﴿عَلَيۡهِ﴾</q>: أي: على ذِكْرِه الحَسَنِ. <q>﴿فِي ٱلۡـَٔاخِرِينَ﴾</q>: في الأُمَمِ التي جاءتْ بَعْدَه. "
  37,109,""
  37,110,""
  37,111,""
  37,112,""
  37,113,""
  37,114,""
37,115," <q>﴿مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ﴾</q>: أي: مِنَ الغَرَقِ وتَسَلُّطِ فِرْعَونَ. "
  37,116,""
  37,117,""
  37,118,""
37,119," <q>﴿عَلَيۡهِمَا﴾</q>: أي: على ذِكْرِهِما الحَسَنِ. <q>﴿فِي ٱلۡـَٔاخِرِينَ﴾</q>: في الأمَمِ الَّتي جاءَتْ بَعْدَهُما. "
  37,120,""
  37,121,""
  37,122,""
  37,123,""
  37,124,""
37,125," <q>﴿بَعۡلࣰا﴾</q>: وهو اسْمٌ لِصَنَمٍ كانُوا يَعْبُدُونَهُ. <q>﴿وَتَذَرُونَ﴾</q>: تَتْرُكُونَ. "
  37,126,""
