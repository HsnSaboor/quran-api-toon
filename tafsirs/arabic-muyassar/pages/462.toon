tafsir[9]{c,v,t}:
39,32," <q>﴿فَمَنۡ أَظۡلَمُ﴾</q>: لا أحَدَ أظْلَمُ. <q>﴿بِٱلصِّدۡقِ﴾</q>: بالقرآنِ. <q>﴿مَثۡوࣰى﴾</q>: مأوىً ومَسْكَنٌ. "
39,33," <q>﴿بِٱلصِّدۡقِ﴾</q>: لا إلَهَ إلّا اللهُ. <q>﴿وَصَدَّقَ بِهِۦٓ﴾</q>: مَن آمَنَ بالقُرْآنِ مِن نَّبِيِّ اللهِ وأَتْباعِهِ. "
  39,34,""
  39,35,""
39,36," <q>﴿بِكَافٍ عَبۡدَهُۥ﴾</q>: حامِي رَسُولِهِ مُحَمَّدٍ ﷺ. <q>﴿مِن دُونِهِۦ﴾</q>: بالَّذِينَ يَعْبُدُونَ مِن دُونِهِ وهُمُ الأَصْنامُ. <q>﴿مِن دُونِهِۦ﴾</q>: آلهَتِهِم الَّذين يَزْعُمُون أنها سَتُؤْذِيكَ. "
39,37," <q>﴿وَمَن يَهۡدِ ٱللَّهُ﴾</q>: ومَن يُوفِّقْه اللهُ للإيمانِ بهِ والعملِ بِكِتابِهِ. "
39,38," <q>﴿مُمۡسِكَـٰتُ رَحۡمَتِهِۦ﴾</q>: حابِساتُ رَحْمَتِهَ. <q>﴿حَسۡبِيَ ٱللَّهُ﴾</q>: كافيَّ اللهُ. <q>﴿يَتَوَكَّلُ﴾</q>: يَعْتَمِدُ ويُفَوِّضُ أمْرَهُ. "
39,39," <q>﴿ٱعۡمَلُواْ عَلَىٰ مَكَانَتِكُمۡ﴾</q>: اعْمَلُوا على حالَتِكُم الَّتِي رَضَيتُمُوها لِأَنْفُسِكُم. "
39,40," <q>﴿يُخۡزِيهِ﴾</q>: يُهينُهُ. <q>﴿مُّقِيمٌ﴾</q>: دائِمٌ. "
