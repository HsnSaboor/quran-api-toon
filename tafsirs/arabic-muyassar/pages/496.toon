quran[18]{c,v,t}:
  44,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حمٓ﴾</span>: سَبَقَ الكلامُ عَلى الحُرُوفِ المقَطَّعةِ أوَّلَ سُورَةِ البقرةِ.</p></div>"
  44,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُبِينِ﴾</span>: الواضِحِ لَفْظًا ومَعْنىً.</p></div>"
  44,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّبَـٰرَكَةٍ﴾</span>: كَثِيرَةِ الخَيراتِ، وهي لَيلةُ القَدْرِ.</p></div>"
  44,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُفۡرَقُ﴾</span>: يُقضى ويُفَصَّلُ مِنَ اللوحِ المحْفُوظِ إلى الكَتَبةِ مِنَ الملائِكَةِ.</p><p><span class="qpc-hafs">﴿حَكِيمٍ﴾</span>: مُحْكَمٍ.</p></div>"
  44,5,"<div class=ar lang=ar></div>"
  44,6,"44:5"
  44,7,"44:5"
  44,8,"44:5"
  44,9,"44:5"
  44,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱرۡتَقِبۡ﴾</span>: فانْتَظِرْ.</p><p><span class="qpc-hafs">﴿بِدُخَانࣲ﴾</span>: ظُلْمَةٍ كَهَيئَةِ الدُّخانِ بِسَبِبِ الجَدْبِ.</p><p><span class="qpc-hafs">﴿مُّبِينࣲ﴾</span>: واضِحٍ.</p></div>"
  44,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغۡشَى﴾</span>: يَعُمُّ.</p></div>"
  44,12,"<div class=ar lang=ar></div>"
  44,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: كَيفَ.</p><p><span class="qpc-hafs">﴿ٱلذِّكۡرَىٰ﴾</span>: التَّذَكُّرُ والاتِّعاظُ.</p></div>"
  44,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّوۡاْ عَنۡهُ﴾</span>: أعْرَضُوا عَنْه.</p><p><span class="qpc-hafs">﴿مُعَلَّمࣱ﴾</span>: عَلَّمَه بَشَرٌ أو الكَهَنَةُ أو الشَّياطِينُ.</p></div>"
  44,15,"<div class=ar lang=ar></div>"
  44,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَبۡطِشُ﴾</span>: نُعَذِّبُ، والبَطْشُ أخْذٌ بِشِدَّةٍ.</p></div>"
  44,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنَّا﴾</span>: ابْتَلينا واخْتَبَرْنا.</p></div>"
  44,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَدُّوٓاْ﴾</span>: سَلِّمُوا وأرْسِلُوا مَعِي.</p><p><span class="qpc-hafs">﴿عِبَادَ ٱللَّهِ﴾</span>: بَنِي إسْرائِيلَ.</p></div>"