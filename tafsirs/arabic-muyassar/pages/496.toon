quran[18]{c,v,t}:
44,1," <q>﴿حمٓ﴾</q>: سَبَقَ الكلامُ عَلى الحُرُوفِ المقَطَّعةِ أوَّلَ سُورَةِ البقرةِ. "
44,2," <q>﴿ٱلۡمُبِينِ﴾</q>: الواضِحِ لَفْظًا ومَعْنىً. "
44,3," <q>﴿مُّبَـٰرَكَةٍ﴾</q>: كَثِيرَةِ الخَيراتِ، وهي لَيلةُ القَدْرِ. "
44,4," <q>﴿يُفۡرَقُ﴾</q>: يُقضى ويُفَصَّلُ مِنَ اللوحِ المحْفُوظِ إلى الكَتَبةِ مِنَ الملائِكَةِ. <q>﴿حَكِيمٍ﴾</q>: مُحْكَمٍ. "
  44,5,""
  44,6,""
  44,7,""
  44,8,""
  44,9,""
44,10," <q>﴿فَٱرۡتَقِبۡ﴾</q>: فانْتَظِرْ. <q>﴿بِدُخَانࣲ﴾</q>: ظُلْمَةٍ كَهَيئَةِ الدُّخانِ بِسَبِبِ الجَدْبِ. <q>﴿مُّبِينࣲ﴾</q>: واضِحٍ. "
44,11," <q>﴿يَغۡشَى﴾</q>: يَعُمُّ. "
  44,12,""
44,13," <q>﴿أَنَّىٰ﴾</q>: كَيفَ. <q>﴿ٱلذِّكۡرَىٰ﴾</q>: التَّذَكُّرُ والاتِّعاظُ. "
44,14," <q>﴿تَوَلَّوۡاْ عَنۡهُ﴾</q>: أعْرَضُوا عَنْه. <q>﴿مُعَلَّمࣱ﴾</q>: عَلَّمَه بَشَرٌ أو الكَهَنَةُ أو الشَّياطِينُ. "
  44,15,""
44,16," <q>﴿نَبۡطِشُ﴾</q>: نُعَذِّبُ، والبَطْشُ أخْذٌ بِشِدَّةٍ. "
44,17," <q>﴿فَتَنَّا﴾</q>: ابْتَلينا واخْتَبَرْنا. "
44,18," <q>﴿أَدُّوٓاْ﴾</q>: سَلِّمُوا وأرْسِلُوا مَعِي. <q>﴿عِبَادَ ٱللَّهِ﴾</q>: بَنِي إسْرائِيلَ. "
