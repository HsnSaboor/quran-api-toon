quran[27]{c,v,t}:
83,35," <q>﴿ٱلۡأَرَآئِكِ﴾</q>: المجالِسِ الفاخِرَةِ. <q>﴿يَنظُرُونَ﴾</q>: يَنْظُرُ المؤمِنُونَ إلى ما أعْطاهُم اللهُ مِنَ الكَرامةِ والنَّعِيم في الجنَّةِ. "
83,36," <q>﴿هَلۡ ثُوِّبَ ٱلۡكُفَّارُ﴾</q>: هل جُوزِي الكُفّارُ مِن جِنْسِ أعمالِهِم؟ "
84,1," <q>﴿ٱنشَقَّتۡ﴾</q>: تَصَدَّعتْ يومَ القِيامَةِ. "
84,2," <q>﴿وَأَذِنَتۡ لِرَبِّهَا﴾</q>: وأَطاعَتْ أمْرَ رَبِّها. <q>﴿وَحُقَّتۡ﴾</q>: وحُقَّ لَها أن تَنقادَ لِأَمْرِهِ. "
84,3," <q>﴿مُدَّتۡ﴾</q>: بُسِطَتْ ووُسِّعَتْ. "
84,4," <q>﴿وَأَلۡقَتۡ مَا فِيهَا﴾</q>: وقَذَفَتْ ما في بَطْنِها مِنَ الأمْواتِ. <q>﴿وَتَخَلَّتۡ﴾</q>: لم يَبْقَ شَيءٌ مِمّا في بَطْنِها. "
84,5," <q>﴿وَأَذِنَتۡ لِرَبِّهَا﴾</q>: وانْقادَتْ لِرَبِها فِيما أمَرها بِهِ. "
84,6," <q>﴿كَادِحٌ﴾</q>: ساعٍ إلى اللهِ. <q>﴿فَمُلَـٰقِيهِ﴾</q>: تُلاقِي الله يَومَ القِيامَةِ. "
84,7," <q>﴿أُوتِيَ كِتَـٰبَهُۥ﴾</q>: أُعطِيَ صَحِيفةَ أعمالِهِ. "
84,8," <q>﴿يَسِيرࣰا﴾</q>: سَهْلا. "
84,9," <q>﴿وَيَنقَلِبُ﴾</q>: ويَرْجِعُ. "
84,10," <q>﴿كِتَـٰبَهُۥ﴾</q>: صَحِيفةَ أعْمالِهِ. "
84,11," <q>﴿ثُبُورࣰا﴾</q>: بِالهَلاكِ. "
84,12," <q>﴿وَيَصۡلَىٰ سَعِيرًا﴾</q>: ويَدْخُلُ النّارَ مُقاسِيًا حَرَّها. "
84,13," <q>﴿مَسۡرُورًا﴾</q>: مَغْرُورًا لا يُفَكِّرُ في العواقِبِ. "
84,14," <q>﴿يَحُورَ﴾</q>: يَرْجِعَ إلى خالِقِه لِلْحِسابِ. "
  84,15,""
84,16," <q>﴿بِٱلشَّفَقِ﴾</q>: باحْمِرارِ الأُفُقِ عِنْدَ الغُرُوب. "
84,17," <q>﴿وَمَا وَسَقَ﴾</q>: وما جَمَعَ من الدَّوابِّ والحَشراتِ والهَوامِّ وغَيرِ ذَلِكَ. "
84,18," <q>﴿ٱتَّسَقَ﴾</q>: تَكامَلَ نُورُهُ. "
84,19," <q>﴿طَبَقًا عَن طَبَقࣲ﴾</q>: أطوارًا مُتَعَدِّدَةً وأَحْوالًا مُتَبايِنَةً: مِنَ النُّطْفَةِ إلى العَلَقَةِ إلى المُضْغةِ إلى نَفْخِ الرُّوحِ، إلى الموتِ، إلى البعْثِ والنُّشُورِ. "
84,20," <q>﴿فَمَا لَهُمۡ لَا يُؤۡمِنُونَ﴾</q>: فأيُّ شَيءٍ يَمْنَعُهُم مِنَ الإيمانِ بَعْدَ ما وُضِّحَتْ لَهُمُ الآياتُ؟ "
84,21," <q>﴿لَا يَسۡجُدُونَ﴾</q>: لا يَخْضَعُونَ للهِ، ولا يُسَلِّمُونَ بِما جاءَ في القُرآنِ. "
  84,22,""
84,23," <q>﴿بِمَا يُوعُونَ﴾</q>: بِما يَكْتُمُونَ مِن العِنادِ مَعَ عِلْمِهِم بأنّ ما جاءَ بهِ القرآنُ حَقٌّ. "
84,24," <q>﴿فَبَشِّرۡهُم﴾</q>: أي هَؤُلاءِ المكذِّبِينَ. "
84,25," <q>﴿غَيۡرُ مَمۡنُونِۭ﴾</q>: غَيرُ مَقْطُوعٍ ولا مَنقُوصٍ. "
