quran[28]{c,v,t}:
26,84," <q>﴿لِسَانَ صِدۡقࣲ﴾</q>: ثَناءً حَسَنًا. <q>﴿فِي ٱلۡـَٔاخِرِينَ﴾</q>: أي: في الَّذينَ يأتُونَ بَعْدِي إلى يومِ القِيامَةِ. "
  26,85,""
  26,86,""
26,87," <q>﴿وَلَا تُخۡزِنِي﴾</q>: ولا تَفْضَحْنِي. "
  26,88,""
26,89," <q>﴿بِقَلۡبࣲ سَلِيمࣲ﴾</q>: أي: مِنَ النِّفاقِ والكُفْرِ. "
26,90," <q>﴿وَأُزۡلِفَتِ﴾</q>: قُرِّبَتْ. "
26,91," <q>﴿وَبُرِّزَتِ﴾</q>: أُظْهِرَتْ. <q>﴿لِلۡغَاوِينَ﴾</q>: للضّالِينَ عَن طَرِيقِ الهِدايةِ. "
  26,92,""
  26,93,""
26,94," <q>﴿فَكُبۡكِبُواْ فِيهَا﴾</q>: أُلْقُوا في جَهَنَّمَ على وُجُوهِهِم مرَّةً بَعْدَ مَرَّةٍ إلى أنِ اسْتَقرُّوا في قَعْرِها. "
  26,95,""
26,96," <q>﴿يَخۡتَصِمُونَ﴾</q>: يَتَنازَعُون. "
26,97," <q>﴿إِن كُنَّا﴾</q>: إنَّنا كُنّا. "
26,98," <q>﴿نُسَوِّيكُم بِرَبِّ ٱلۡعَـٰلَمِينَ﴾</q>: نَجْعَلُكُم مِثْلَ رَبِّ العالَمِينَ. "
  26,99,""
26,100," <q>﴿شَـٰفِعِينَ﴾</q>: فَيُخَلِّصُونا مِنَ العَذابِ. "
26,101," <q>﴿حَمِيمࣲ﴾</q>: قَرِيبٍ ومُشْفِقٍ. "
26,102," <q>﴿كَرَّةࣰ﴾</q>: رَجْعَةً إلى الدُّنيا. "
  26,103,""
  26,104,""
  26,105,""
  26,106,""
  26,107,""
  26,108,""
  26,109,""
  26,110,""
26,111," <q>﴿ٱلۡأَرۡذَلُونَ﴾</q>: أي: أسافلُ النّاسِ وأَراذِلُهم. "
