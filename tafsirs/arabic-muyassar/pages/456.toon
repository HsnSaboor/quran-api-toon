quran[19]{c,v,t}:
  38,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡلَهُۥ﴾</span>: زَوْجَهُ ووَلَدَهُ.</p><p><span class="qpc-hafs">﴿وَمِثۡلَهُم مَّعَهُمۡ﴾</span>: وزِدْناهُ مِثْلَهُم بَنِينَ وحَفَدَةً.</p><p><span class="qpc-hafs">﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾</span>: لأصْحابِ العُقُولِ السَّلِيمَةِ.</p></div>"
  38,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِغۡثࣰا﴾</span>: حُزْمَةً مِنَ الحَشِيشِ ونَحْوِهِ.</p><p><span class="qpc-hafs">﴿وَلَا تَحۡنَثۡ﴾</span>: لا تَتْرُكِ الوفاءَ بِيَمِينِكَ.</p><p><span class="qpc-hafs">﴿أَوَّابࣱ﴾</span>: رَجّاعٌ إلى طاعَةِ اللهِ.</p></div>"
  38,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُوْلِي ٱلۡأَيۡدِي﴾</span>: أصْحابَ القُوى في طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَبۡصَـٰرِ﴾</span>: البصائرِ في الدِّينِ.</p></div>"
  38,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ﴾</span>: خَصَصْناهُم واصْطَفَيناهُم بِخاصَّةٍ عَظِيمَةٍ.</p><p><span class="qpc-hafs">﴿ذِكۡرَى ٱلدَّارِ﴾</span>: ذِكْرِ الدّارِ الآخرةِ في قُلُوبِهِم.</p></div>"
  38,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُصۡطَفَيۡنَ﴾</span>: الَّذينَ اخْتَرْناهُم لِرِسالَتِنا وطاعَتِنا.</p><p><span class="qpc-hafs">﴿ٱلۡأَخۡيَارِ﴾</span>: الُمخْتارِينَ الفضلاءِ المُخْتَصِّينَ بالخيرِ.</p></div>"
  38,48,""
  38,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذِكۡرࣱ﴾</span>: عِظَةٌ وشَرَفٌ لك أيُّها الرسولُ ولِقَومِكَ.</p><p><span class="qpc-hafs">﴿مَـَٔابࣲ﴾</span>: مَصِيرٍ.</p></div>"
  38,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتِ عَدۡنࣲ﴾</span>: جَنّاتِ إقامَةٍ.</p></div>"
  38,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَّكِـِٔينَ﴾</span>: جالِسِينَ مُتَمَكِّنِينَ على السُّرُرِ.</p><p><span class="qpc-hafs">﴿يَدۡعُونَ﴾</span>: يَطْلُبُونَ.</p></div>"
  38,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</span>: لا يَمْدُدْنَ أبْصارَهُنَّ إلى غَيْرِ أزْواجِهِنَّ.</p><p><span class="qpc-hafs">﴿أَتۡرَابٌ﴾</span>: مُتَساوِياتٌ في السِّنِّ.</p></div>"
  38,53,""
  38,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَّفَادٍ﴾</span>: فَناءٍ وانْقِطاعِ.</p></div>"
  38,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلطَّـٰغِينَ﴾</span>: الُمتَجاوِزِينَ الحَدَّ في الكُفْرِ والمعاصِي.</p><p><span class="qpc-hafs">﴿مَـَٔابࣲ﴾</span>: مَرْجِعٍ ومَصِيرٍ.</p></div>"
  38,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَصۡلَوۡنَهَا﴾</span>: يُعذَّبُونَ فِيها، تَغْمُرُهُم مِن جَمِيعِ جَوانِبِهِم.</p><p><span class="qpc-hafs">﴿ٱلۡمِهَادُ﴾</span>: الفِراشُ.</p></div>"
  38,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَمِيمࣱ﴾</span>: ماءٌ شَدِيدُ الحَرارَةِ.</p><p><span class="qpc-hafs">﴿وَغَسَّاقࣱ﴾</span>: صَدِيدٌ سائِلٌ مِن أجْسادِ أهْلِ النّارِ.</p></div>"
  38,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَءَاخَرُ﴾</span>: عَذابٌ آخَرُ.</p><p><span class="qpc-hafs">﴿شَكۡلِهِۦٓ﴾</span>: مِثْلِه.</p><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جٌ﴾</span>: أصْنافٌ وألْوانٌ.</p></div>"
  38,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوۡجࣱ﴾</span>: جَماعَةٌ عَظِيمةٌ.</p><p><span class="qpc-hafs">﴿مُّقۡتَحِمࣱ﴾</span>: داخِلٌ.</p><p><span class="qpc-hafs">﴿صَالُواْ ٱلنَّارِ﴾</span>: مُقاسُونَ حَرَّها.</p></div>"
  38,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدَّمۡتُمُوهُ لَنَا﴾</span>: بَدَأْتُم بالكُفْرِ قَبْلنا وسَنَنْتُمُوهُ لَنا.</p><p><span class="qpc-hafs">﴿ٱلۡقَرَارُ﴾</span>: دارُ الاسْتِقْرارِ، وهي جَهَنَّمُ.</p></div>"
  38,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِعۡفࣰا﴾</span>: مُضاعَفًا.</p></div>"