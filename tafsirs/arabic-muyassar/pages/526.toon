quran[26]{c,v,t}:
  53,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَوَىٰ﴾</span>: غابَ.</p></div>"
  53,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَوَىٰ﴾</span>: خَرَجَ عنِ الرَّشادِ.</p></div>"
  53,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡهَوَىٰٓ﴾</span>: ما تَمِيلُ إلَيهِ النَّفْسُ مِن غَيرِ دَلِيلٍ.</p></div>"
  53,4,"<div class=ar lang=ar></div>"
  53,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَدِيدُ ٱلۡقُوَىٰ﴾</span>: مَلَكٌ شَدِيدُ القُوَّةِ.</p></div>"
  53,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِرَّةࣲ﴾</span>: مَنظَرٍ حَسَنٍ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَوَىٰ﴾</span>: عَلى صُورَتِهِ الحقِيقِيَّةِ للرَّسولِ ﷺ.</p></div>"
  53,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ﴾</span>: أُفُقِ الشَّمسِ عِنْدَ مَطْلَعِها.</p></div>"
  53,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَدَلَّىٰ﴾</span>: فَزادَ في القُرْبِ.</p></div>"
  53,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَابَ قَوۡسَيۡنِ﴾</span>: مِقْدارَ قَوسَينِ.</p></div>"
  53,10,"<div class=ar lang=ar></div>"
  53,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡفُؤَادُ﴾</span>: قَلْبُه.</p></div>"
  53,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَتُمَـٰرُونَهُۥ﴾</span>: أتُكَذِّبُونَ مُحَمَّدًا ﷺ فَتُجادِلُونَه عَلى ما يَراهُ مِن آياتِ رَبِّهِ؟</p></div>"
  53,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَءَاهُ﴾</span>: رَأى مُحَمّدٌ ﷺ جِبْرِيلَ.</p><p><span class="qpc-hafs">﴿نَزۡلَةً﴾</span>: مَرَّةً.</p></div>"
  53,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِدۡرَةِ ٱلۡمُنتَهَىٰ﴾</span>: شَجَرةِ نَبْقٍ في السَّماءِ السّابِعةِ، يَنْتَهي إلَيها ما يُعْرَجُ بِهِ مِنَ الأَرْضِ، وما يُهْبَطُ بِه مِن فَوْقِها.</p></div>"
  53,15,"<div class=ar lang=ar></div>"
  53,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَغۡشَى ٱلسِّدۡرَةَ﴾</span>: يُغَطِّيها ويَسْتُرُها.</p></div>"
  53,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَاغَ﴾</span>: مالَ.</p><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: جاوَزَ ما أُمِرَ برُؤْيَتِهِ.</p></div>"
  53,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِ﴾</span>: دَلائلِ عَظَمةِ اللهِ.</p></div>"
  53,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱللَّـٰتَ وَٱلۡعُزَّىٰ ۞ وَمَنَوٰةَ﴾</span>: هي أصْنامٌ اتَّخَذَها العَربُ آلِهَةً.</p><p><span class="qpc-hafs">﴿ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰٓ﴾</span>: صِفَتا تأكيدٍ لمناةٍ.</p></div>"
  53,20,"53:19"
  53,21,"<div class=ar lang=ar></div>"
  53,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضِيزَىٰٓ﴾</span>: جائِرةٌ.</p></div>"
  53,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُلۡطَـٰنٍ﴾</span>: حُجَّةٍ.</p><p><span class="qpc-hafs">﴿تَهۡوَى﴾</span>: تَشْتَهِيهِ وتَمِيلُ إلَيهِ.</p></div>"
  53,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَمَنَّىٰ﴾</span>: اشْتَهى.</p></div>"
  53,25,"<div class=ar lang=ar></div>"
  53,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَم مِّن مَّلَكࣲ﴾</span>: وكَثِيرٍ مِنَ الملائِكَةِ.</p></div>"