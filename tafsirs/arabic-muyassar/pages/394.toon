quran[7]{c,v,t}:
  28,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرَءَيۡتُمۡ﴾</span>: أي: أخْبِرُونِي.</p><p><span class="qpc-hafs">﴿سَرۡمَدًا﴾</span>: دائِمًا مُسْتَمِرًّا.</p><p><span class="qpc-hafs">﴿بِضِيَآءٍ﴾</span>: بنُورٍ.</p></div>"
  28,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَسۡكُنُونَ فِيهِ﴾</span>: تَسْتَقِرُّونَ فِيه مِنَ التَّعَبِ.</p></div>"
  28,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِتَسۡكُنُواْ فِيهِ﴾</span>: لِتَسْتَقِرُّوا في اللَّيلِ وتَرْتاحَ أبْدانُكُم.</p><p><span class="qpc-hafs">﴿لِتَبۡتَغُواْ مِن فَضۡلِهِۦ﴾</span>: لِتطْلُبُوا وتَلْتَمِسُوا مِن رِزْقِهِ.</p></div>"
  28,74,""
  28,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَزَعۡنَا﴾</span>: وأَخْرَجْنا.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: وهو نَبِيُّ كُلِّ أُمَّةٍ.</p><p><span class="qpc-hafs">﴿هَاتُواْ بُرۡهَـٰنَكُمۡ﴾</span>: أحْضِرُوا حُجَّتَكُم.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَخْتَلِقُونَ.</p></div>"
  28,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبَغَىٰ عَلَيۡهِمۡ﴾</span>: تَكَبَّرَ عَلَيهِم.</p><p><span class="qpc-hafs">﴿وَءَاتَيۡنَـٰهُ﴾</span>: وأعْطَيناهُ.</p><p><span class="qpc-hafs">﴿ٱلۡكُنُوزِ﴾</span>: الأمْوالِ المدَّخَرَةِ في الخَزائِنِ.</p><p><span class="qpc-hafs">﴿لَتَنُوٓأُ بِٱلۡعُصۡبَةِ﴾</span>: لَتُثْقِلُ الجَماعَةَ الكَثِيرَةَ.</p><p><span class="qpc-hafs">﴿أُوْلِي ٱلۡقُوَّةِ﴾</span>: أصْحابِ القُوَّةِ، الأقْوِياءِ.</p><p><span class="qpc-hafs">﴿لَا تَفۡرَحۡ﴾</span>: لا تَبْطَرْ فَرَحًا بِكَثْرَةِ المالِ.</p></div>"
  28,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱبۡتَغِ﴾</span>: والتَمِسْ.</p><p><span class="qpc-hafs">﴿ءَاتَىٰكَ﴾</span>: أعْطاكَ.</p><p><span class="qpc-hafs">﴿وَلَا تَنسَ نَصِيبَكَ﴾</span>: ولا تَترُكْ حَظَّكَ مِنَ الدُّنيا.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡغِ﴾</span>: ولا تَلْتمِسْ.</p></div>"