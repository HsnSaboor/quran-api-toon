quran[17]{c,v,t}:
  103,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡعَصۡرِ﴾</span>: أقْسَمَ اللهُ بالدَّهْرِ.</p></div>"
  103,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِنَّ ٱلۡإِنسَـٰنَ﴾</span>: إنّ بَنِي آدَمَ.</p><p><span class="qpc-hafs">﴿لَفِي خُسۡرٍ﴾</span>: لَفِي هَلَكَةٍ ونُقْصانٍ، وسُوءِ عاقبةٍ.</p></div>"
  103,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَوَاصَوۡاْ﴾</span>: وأوصى بَعْضُهم بَعْضًا.</p><p><span class="qpc-hafs">﴿بِٱلۡحَقِّ﴾</span>: بالاسْتِمساكِ بالحقِّ، والعملِ بِطاعةِ اللهِ.</p></div>"
  104,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيۡلࣱ﴾</span>: شَرٌّ وهَلاكٌ.</p><p><span class="qpc-hafs">﴿لِّكُلِّ هُمَزَةࣲ﴾</span>: لِكُلِّ مُغْتابٍ للنّاسِ.</p><p><span class="qpc-hafs">﴿لُّمَزَةٍ﴾</span>: طَعّانٍ فِيهِم.</p></div>"
  104,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمَعَ مَالࣰا وَعَدَّدَهُۥ﴾</span>: كانَ همُّه جَمْعَ المالِ وتَعْدادَهُ.</p></div>"
  104,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخۡلَدَهُۥ﴾</span>: جَعَلَه خالِدًا في الدُّنيا.</p></div>"
  104,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيُنۢبَذَنَّ﴾</span>: ليُطْرَحَنَّ.</p><p><span class="qpc-hafs">﴿فِي ٱلۡحُطَمَةِ﴾</span>: في النّارِ الَّتِي تُحَطِّم كُلَّ ما يُلْقى فِيها.</p></div>"
  104,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَدۡرَىٰكَ﴾</span>: وأيُّ شيءٍ أعْلَمَكَ؟</p></div>"
  104,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُوقَدَةُ﴾</span>: المسْتَعِرَةُ الَّتِي لا يزُولُ لَهِيبُها.</p></div>"
  104,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ﴾</span>: من شِدَّتِها تَنفُذُ مِنَ الأجْسام إلى القُلُوبِ.</p></div>"
  104,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّؤۡصَدَةࣱ﴾</span>: مُغْلَقةٌ غَلْقًا مُطْبِقًا.</p></div>"
  104,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي عَمَدࣲ﴾</span>: مَوْثُوقِينَ في سَلاسِلَ وأغلالٍ.</p><p><span class="qpc-hafs">﴿مُّمَدَّدَةِۭ﴾</span>: مُطَوَّلَةٍ؛ لئلّا يَخرُجُوا مِنها.</p></div>"
  105,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ تَرَ﴾</span>: ألَمْ تَعْلَمْ.</p><p><span class="qpc-hafs">﴿بِأَصۡحَـٰبِ ٱلۡفِيلِ﴾</span>: أبْرَهَة الحَبَشِيِّ وجَيشِهِ الَّذِين أرادُوا تَدمِيرَ الكعْبةِ.</p></div>"
  105,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡدَهُمۡ﴾</span>: ما دبَّرُوهُ مِن شَرٍّ.</p><p><span class="qpc-hafs">﴿فِي تَضۡلِيلࣲ﴾</span>: في إبطالٍ وتَضْيِيعٍ؟.</p></div>"
  105,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَبَابِيلَ﴾</span>: في جماعاتٍ مُتَتابِعةٍ.</p></div>"
  105,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَرۡمِيهِم﴾</span>: تَقْذِفُهُم.</p><p><span class="qpc-hafs">﴿سِجِّيلࣲ﴾</span>: طِينٍ مُتَحَجِّرٍ.</p></div>"
  105,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَعَصۡفࣲ مَّأۡكُولِۭ﴾</span>: كَأَوْراقِ الزَّرعِ اليابِسةِ الَّتِي أكَلَتْها البهائِمُ ثُمَّ رَمَتْ بِها.</p></div>"