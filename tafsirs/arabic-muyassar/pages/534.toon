tafsir[27]{c,v,t}:
  55,68,""
  55,69,""
55,70," <q>﴿فِيهِنَّ﴾</q>: في هَذِه الجنّاتِ الأرْبَعِ. <q>﴿خَيۡرَ ٰ⁠تٌ﴾</q>: زَوْجاتٌ طيِّباتُ الأخْلاقِ. <q>﴿حِسَانࣱ﴾</q>: حِسانُ الوُجُوهِ. "
  55,71,""
55,72," <q>﴿حُورࣱ﴾</q>: نِساءٌ ذَواتُ حَوَرٍ، وهو شِدَّةُ بَياضِ العَينِ وشِدَّةُ سَوادِها. <q>﴿مَّقۡصُورَ ٰ⁠تࣱ﴾</q>: مَسْتُوراتٌ مَصُوناتٌ. <q>﴿ٱلۡخِيَامِ﴾</q>: البُيوتِ. "
  55,73,""
  55,74,""
  55,75,""
55,76," <q>﴿رَفۡرَفٍ﴾</q>: وسائِدَ ذَواتِ أغْطِيَةٍ. <q>﴿وَعَبۡقَرِيٍّ﴾</q>: وفُرُشٍ بَدِيعَةٍ. "
  55,77,""
55,78," <q>﴿تَبَـٰرَكَ﴾</q>: كَثُرَ خَيرُهُ. <q>﴿ٱلۡجَلَـٰلِ﴾</q>: العَظَمَةِ والمَجْدِ. <q>﴿وَٱلۡإِكۡرَامِ﴾</q>: لِأَوْلِيائِهِ. "
56,1," <q>﴿ٱلۡوَاقِعَةُ﴾</q>: القِيامَةُ. "
56,2," <q>﴿كَاذِبَةٌ﴾</q>: لا يَكُونُ عِنْدَ وُقُوعِها تَكْذِيبٌ. "
56,3," <q>﴿خَافِضَةࣱ رَّافِعَةٌ﴾</q>: هي خافِضَةٌ يَحْصُلُ عِنْدَها خَفْضُ أقْوامٍ كانُوا مُرْتَفِعِينَ ورَفْعُ أقْوامٍ كانُوا مُنْخَفِضِينَ، وخافِضَةُ جِهاتٍ كانَتْ مُرْتَفِعَةً كالجِبالِ والصَّوامِعِ، رافِعَةٌ ما كانَ مُنْخَفِضًا بِسَبَبِ ما يَحْدُثُ في الكَونِ. "
56,4," <q>﴿رُجَّتِ﴾</q>: اضْطَرَبَتْ، بِسَبَبِ الزَّلازِلِ والخَسْفِ ونَحْوِ ذَلِكَ. "
56,5," <q>﴿وَبُسَّتِ﴾</q>: فُتِّتَتِ الجبالُ ونُسِفَتْ. "
56,6," <q>﴿هَبَآءࣰ﴾</q>: ما يَلُوحُ في خُيُوطِ شُعاعِ الشَّمسِ مِن دَقِيقِ الغُبارِ. <q>﴿مُّنۢبَثࣰّا﴾</q>: مُتَفَرِّقًا. "
56,7," <q>﴿أَزۡوَ ٰ⁠جࣰا﴾</q>: أصْنافًا. "
56,8," <q>﴿أَصۡحَـٰبُ ٱلۡمَيۡمَنَةِ﴾</q>: هُمُ الَّذِينَ يُجْعَلُونَ في الجِهَةِ اليُمْنى فِي الجَنَّةِ أوْ فِي الَمحْشَرِ. "
56,9," <q>﴿أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ﴾</q>: أصْحابُ الشَّقاوَةِ الَّذِينَ يُؤْخَذُ بِهِم ذاتَ الشِّمال إلى النّارِ. "
56,10," <q>﴿وَٱلسَّـٰبِقُونَ﴾</q>: إلى الخَيْراتِ. <q>﴿ٱلسَّـٰبِقُونَ﴾</q>: إلى مُنْتَهى الفَضْلِ والرِّفْعَةِ. "
  56,11,""
  56,12,""
56,13," <q>﴿ثُلَّةࣱ﴾</q>: جَماعةٌ. "
  56,14,""
56,15," <q>﴿سُرُرࣲ﴾</q>: جَمْعُ سَرِيرٍ، وهو مَجِلِسُ العُظَماءِ والمُلُوكِ أيْضًا. <q>﴿مَّوۡضُونَةࣲ﴾</q>: مَسْبُوكٍ بَعْضُها بِبَعْضٍ. "
56,16," <q>﴿مُتَقَـٰبِلِينَ﴾</q>: يَجْلِسُ بَعْضُهُم مُقابِلَ بَعْضٍ، وذَلِكَ مِن تَمامِ النَّعِيمِ لمِا فِيهِ مِنَ الأُنْسِ بِمُشاهَدَةِ الأَصْحابِ والحَدِيثِ مَعَهُم. "
