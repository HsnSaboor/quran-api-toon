quran[27]{c,v,t}:
  55,68,"55:67"
  55,69,"55:67"
  55,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِنَّ﴾</span>: في هَذِه الجنّاتِ الأرْبَعِ.</p><p><span class="qpc-hafs">﴿خَيۡرَ ٰ⁠تٌ﴾</span>: زَوْجاتٌ طيِّباتُ الأخْلاقِ.</p><p><span class="qpc-hafs">﴿حِسَانࣱ﴾</span>: حِسانُ الوُجُوهِ.</p></div>"
  55,71,"<div class=ar lang=ar></div>"
  55,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُورࣱ﴾</span>: نِساءٌ ذَواتُ حَوَرٍ، وهو شِدَّةُ بَياضِ العَينِ وشِدَّةُ سَوادِها.</p><p><span class="qpc-hafs">﴿مَّقۡصُورَ ٰ⁠تࣱ﴾</span>: مَسْتُوراتٌ مَصُوناتٌ.</p><p><span class="qpc-hafs">﴿ٱلۡخِيَامِ﴾</span>: البُيوتِ.</p></div>"
  55,73,"<div class=ar lang=ar></div>"
  55,74,"55:73"
  55,75,"55:73"
  55,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَفۡرَفٍ﴾</span>: وسائِدَ ذَواتِ أغْطِيَةٍ.</p><p><span class="qpc-hafs">﴿وَعَبۡقَرِيٍّ﴾</span>: وفُرُشٍ بَدِيعَةٍ.</p></div>"
  55,77,"<div class=ar lang=ar></div>"
  55,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَـٰرَكَ﴾</span>: كَثُرَ خَيرُهُ.</p><p><span class="qpc-hafs">﴿ٱلۡجَلَـٰلِ﴾</span>: العَظَمَةِ والمَجْدِ.</p><p><span class="qpc-hafs">﴿وَٱلۡإِكۡرَامِ﴾</span>: لِأَوْلِيائِهِ.</p></div>"
  56,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡوَاقِعَةُ﴾</span>: القِيامَةُ.</p></div>"
  56,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَاذِبَةٌ﴾</span>: لا يَكُونُ عِنْدَ وُقُوعِها تَكْذِيبٌ.</p></div>"
  56,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَافِضَةࣱ رَّافِعَةٌ﴾</span>: هي خافِضَةٌ يَحْصُلُ عِنْدَها خَفْضُ أقْوامٍ كانُوا مُرْتَفِعِينَ ورَفْعُ أقْوامٍ كانُوا مُنْخَفِضِينَ، وخافِضَةُ جِهاتٍ كانَتْ مُرْتَفِعَةً كالجِبالِ والصَّوامِعِ، رافِعَةٌ ما كانَ مُنْخَفِضًا بِسَبَبِ ما يَحْدُثُ في الكَونِ.</p></div>"
  56,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رُجَّتِ﴾</span>: اضْطَرَبَتْ، بِسَبَبِ الزَّلازِلِ والخَسْفِ ونَحْوِ ذَلِكَ.</p></div>"
  56,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَبُسَّتِ﴾</span>: فُتِّتَتِ الجبالُ ونُسِفَتْ.</p></div>"
  56,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَبَآءࣰ﴾</span>: ما يَلُوحُ في خُيُوطِ شُعاعِ الشَّمسِ مِن دَقِيقِ الغُبارِ.</p><p><span class="qpc-hafs">﴿مُّنۢبَثࣰّا﴾</span>: مُتَفَرِّقًا.</p></div>"
  56,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَزۡوَ ٰ⁠جࣰا﴾</span>: أصْنافًا.</p></div>"
  56,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡمَيۡمَنَةِ﴾</span>: هُمُ الَّذِينَ يُجْعَلُونَ في الجِهَةِ اليُمْنى فِي الجَنَّةِ أوْ فِي الَمحْشَرِ.</p></div>"
  56,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ﴾</span>: أصْحابُ الشَّقاوَةِ الَّذِينَ يُؤْخَذُ بِهِم ذاتَ الشِّمال إلى النّارِ.</p></div>"
  56,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلسَّـٰبِقُونَ﴾</span>: إلى الخَيْراتِ.</p><p><span class="qpc-hafs">﴿ٱلسَّـٰبِقُونَ﴾</span>: إلى مُنْتَهى الفَضْلِ والرِّفْعَةِ.</p></div>"
  56,11,"<div class=ar lang=ar></div>"
  56,12,"56:11"
  56,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُلَّةࣱ﴾</span>: جَماعةٌ.</p></div>"
  56,14,"<div class=ar lang=ar></div>"
  56,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُرُرࣲ﴾</span>: جَمْعُ سَرِيرٍ، وهو مَجِلِسُ العُظَماءِ والمُلُوكِ أيْضًا.</p><p><span class="qpc-hafs">﴿مَّوۡضُونَةࣲ﴾</span>: مَسْبُوكٍ بَعْضُها بِبَعْضٍ.</p></div>"
  56,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَقَـٰبِلِينَ﴾</span>: يَجْلِسُ بَعْضُهُم مُقابِلَ بَعْضٍ، وذَلِكَ مِن تَمامِ النَّعِيمِ لمِا فِيهِ مِنَ الأُنْسِ بِمُشاهَدَةِ الأَصْحابِ والحَدِيثِ مَعَهُم.</p></div>"