quran[6]{c,v,t}:
  60,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُسۡوَةٌ﴾</span>: قُدْوَةٌ.</p><p><span class="qpc-hafs">﴿يَرۡجُواْ ٱللَّهَ﴾</span>: يَطْمَعُ في الخيرِ مِنَ اللهِ.</p><p><span class="qpc-hafs">﴿وَمَن يَتَوَلَّ﴾</span>: ومَن يُعْرضْ عَمّا أمَرهُ اللهُ بِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡغَنِيُّ﴾</span>: عَنْ عِبادِهِ.</p><p><span class="qpc-hafs">﴿ٱلۡحَمِيدُ﴾</span>: في ذاتِه وصِفاتِه، المحْمُودُ عَلى كُلِّ حالٍ.</p></div>"
  60,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَسَى ٱللَّهُ﴾</span>: وعَدَ اللهُ.</p></div>"
  60,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَرُّوهُمۡ﴾</span>: تُحْسِنُوا مُعامَلَتَهُم.</p><p><span class="qpc-hafs">﴿وَتُقۡسِطُوٓاْ إِلَيۡهِمۡ﴾</span>: وتَعْدِلُوا فِيهِم.</p></div>"
  60,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلدِّينِ﴾</span>: بِسَببِ الدِّينِ.</p><p><span class="qpc-hafs">﴿وَظَـٰهَرُواْ﴾</span>: وعاوَنُوا الكُفّارَ.</p><p><span class="qpc-hafs">﴿أَن تَوَلَّوۡهُمۡ﴾</span>: بالنُّصْرَةِ والمحبَّةِ.</p><p><span class="qpc-hafs">﴿وَمَن يَتَوَلَّهُمۡ﴾</span>: ومَنَ يَتَّخِذْهُم أنْصارًا عَلى المؤمِنِينَ.</p></div>"
  60,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُهَـٰجِرَ ٰ⁠تࣲ﴾</span>: مِن دارِ الكُفْرِ إلى دارِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿فَٱمۡتَحِنُوهُنَّ﴾</span>: فاخْتَبرُوا إيمانَهُنَّ.</p><p><span class="qpc-hafs">﴿وَءَاتُوهُم﴾</span>: وأعْطُوا أزواجَ اللاتِي أسْلَمْنَ.</p><p><span class="qpc-hafs">﴿مَّآ أَنفَقُواْ﴾</span>: مِثْلَ ما أعْطَوهُنَّ مِنَ المهُورِ.</p><p><span class="qpc-hafs">﴿أُجُورَهُنَّ﴾</span>: مُهُورَهُنَّ.</p><p><span class="qpc-hafs">﴿بِعِصَمِ﴾</span>: بِنِكاحِ، وأصْلُه جَمْعُ عِصْمَةٍ وهي: ما اعتُصِمَ بِهِ من العَقْدِ والسَّبَبِ.</p><p><span class="qpc-hafs">﴿ٱلۡكَوَافِرِ﴾</span>: الزَّوجاتِ الكافِراتِ.</p></div>"
  60,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاتَكُمۡ﴾</span>: فَرَرْنَ ولَحِقْنَ.</p><p><span class="qpc-hafs">﴿فَعَاقَبۡتُمۡ﴾</span>: كانَتِ العُقْبى لَكُم، وهي الغِنيمَةُ.</p></div>"