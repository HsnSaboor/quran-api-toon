quran[24]{c,v,t}:
  53,45,"<div class=ar lang=ar></div>"
  53,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُّطۡفَةٍ﴾</span>: ماءٍ قَلِيلٍ.</p><p><span class="qpc-hafs">﴿تُمۡنَىٰ﴾</span>: تُصَبُّ في الرَّحِمِ وتُقْذَفُ.</p></div>"
  53,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّشۡأَةَ﴾</span>: الخَلقَ.</p><p><span class="qpc-hafs">﴿ٱلۡأُخۡرَىٰ﴾</span>: الأخِيَرةَ الَّتِي لا نَشْأَةَ بَعْدَها.</p></div>"
  53,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَقۡنَىٰ﴾</span>: أرضى الَّذِي أغْناهُ.</p></div>"
  53,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشِّعۡرَىٰ﴾</span>: نَجْمٍ مُضِيءٍ كانَ يَعْبُدُهُ بَعْضُ أهْل الجاهِلِيَّةِ.</p></div>"
  53,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَادًا ٱلۡأُولَىٰ﴾</span>: قَوْمَ نَبِيِّ اللهِ هُودٍ عَلَيهِ السَّلامُ، وهي أوَّلُ العرَبِ البائِدةِ.</p></div>"
  53,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَثَمُودَاْ﴾</span>: قَوْمَ نَبِيِّ اللهِ صالِحٍ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿فَمَآ أَبۡقَىٰ﴾</span>: فَما تَرَكَها بَلْ أهْلَكَها.</p></div>"
  53,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَطۡغَىٰ﴾</span>: أشَدَّ طَغْيانًا وتَمَرُّدًا على اللهِ.</p></div>"
  53,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡمُؤۡتَفِكَةَ﴾</span>: هي القُرى المَخْسُوفُ بِها، المقلوبُ أعلاها أسفلها، وهي قُرى قَوْمِ لُوطٍ عَلَيهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿أَهۡوَىٰ﴾</span>: أسْقَطَ، فَجَعَلَها هاوِيَةً.</p></div>"
  53,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَغَشَّىٰهَا مَا غَشَّىٰ﴾</span>: فَأَلْبَسَها ما ألْبَسَها مِنَ الحِجارَةِ المُتَتابِعَةِ النّازِلَةِ عَلَيهِم.</p></div>"
  53,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَالَآءِ﴾</span>: نِعَمِ، جَمْعُ إلىً.</p><p><span class="qpc-hafs">﴿تَتَمَارَىٰ﴾</span>: تَتَشَكَّكُ.</p></div>"
  53,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: الَّذِي أنْذَرْتُكُم بِهِ مِنَ الوقائِعِ.</p><p><span class="qpc-hafs">﴿نَذِيرࣱ﴾</span>: إنْذارٌ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰٓ﴾</span>: الَّتي أنْذَرْتُها الأُمَمَ الَّتي قَبْلَكُم.</p></div>"
  53,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَزِفَتِ﴾</span>: قَرُبَتْ.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔازِفَةُ﴾</span>: القِيامَةُ.</p></div>"
  53,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ﴾</span>: لا يَعْلَمُ بوَقْتِ وُقُوعِها إلّا اللهُ.</p></div>"
  53,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا ٱلۡحَدِيثِ﴾</span>: القرآنِ.</p><p><span class="qpc-hafs">﴿تَعۡجَبُونَ﴾</span>: مِن أن يَكُونَ صَحِيحًا.</p></div>"
  53,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَضۡحَكُونَ﴾</span>: مِنهُ سُخْرِيَةً واسْتِهْزاءً.</p><p><span class="qpc-hafs">﴿وَلَا تَبۡكُونَ﴾</span>: خَوْفًا مِن وعِيدِهِ.</p></div>"
  53,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَـٰمِدُونَ﴾</span>: لاهُونَ مُعْرِضُونَ عَنْهُ.</p></div>"
  53,62,"<div class=ar lang=ar></div>"
  54,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّاعَةُ﴾</span>: القِيامَةُ.</p><p><span class="qpc-hafs">﴿وَٱنشَقَّ﴾</span>: انْفَلَقَ فِلْقَتَينِ.</p></div>"
  54,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: بُرْهانًا عَلى صِدْقِ الرَّسُولِ مُحَمَّدٍ ﷺ.</p><p><span class="qpc-hafs">﴿مُّسۡتَمِرࣱّ﴾</span>: ذاهِبٌ مُضْمَحِلٌّ لا دَوامَ لَهُ.</p></div>"
  54,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَهۡوَآءَهُمۡ﴾</span>: ما تُحِبُّهُ أنفُسُهُم مِنَ الضَّلالِ والتَّكْذِيبِ.</p><p><span class="qpc-hafs">﴿أَمۡرࣲ﴾</span>: مِن خَيرٍ أوْ شَرٍّ.</p><p><span class="qpc-hafs">﴿مُّسۡتَقِرࣱّ﴾</span>: واقِعٌ بأَهْلِهِ يَوْمَ القِيامَةِ.</p></div>"
  54,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُزۡدَجَرٌ﴾</span>: كِفايَةٌ لِرَدْعِهم.</p></div>"
  54,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِكۡمَةُۢ﴾</span>: هَذا القُرْآنُ فِيهِ حِكْمَةٌ عَظِيمةٌ.</p><p><span class="qpc-hafs">﴿بَـٰلِغَةࣱ﴾</span>: بالِغَةٌ غايَتَها.</p><p><span class="qpc-hafs">﴿فَمَا﴾</span>: فأيُّ شَيءٍ.</p><p><span class="qpc-hafs">﴿تُغۡنِ﴾</span>: تَدْفَعُ أوْ تَنْفَعُ.</p><p><span class="qpc-hafs">﴿ٱلنُّذُرُ﴾</span>: الإنْذاراتُ.</p></div>"
  54,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّ﴾</span>: فَأَعْرِضْ.</p><p><span class="qpc-hafs">﴿ٱلدَّاعِ﴾</span>: المَلَكُ بنَفْخِهِ في «القَرْنِ».</p><p><span class="qpc-hafs">﴿نُّكُرٍ﴾</span>: فَظِيعٍ مُنْكَرٍ وهو موقِفُ الحِسابِ.</p></div>"