quran[8]{c,v,t}:
  4,52,"<div class=ar lang=ar></div>"
  4,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصِيبࣱ﴾</span>: حَظٌّ.</p><p><span class="qpc-hafs">﴿فَإِذࣰا لَّا يُؤۡتُونَ﴾</span>: إن جُعِلَ لهم ذلك فإذن لايُعْطُون، لشِدَّةِ بُخْلِهم.</p><p><span class="qpc-hafs">﴿نَقِيرًا﴾</span>: النُّقطةَ في ظَهْر النَّواةِ، أو وسَطِها.</p></div>"
  4,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلنَّاسَ﴾</span>: محمدًا وأصحابَه.</p><p><span class="qpc-hafs">﴿فَضۡلِهِۦ﴾</span>: النبوَّةِ، والنصْرِ.</p><p><span class="qpc-hafs">﴿فَقَدۡ ءَاتَيۡنَآ ءَالَ إِبۡرَ ٰ⁠هِيمَ﴾</span>: فكيف لا يَحْسُدون آلَ إبراهيمَ، واليهودُ يعترفون به؟ فما آتينا محمدًا ليس ببِدْعٍ حتى يُحْسَدَ عليه.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: ما أُوحِي إليهم من غيرِ الكتابِ.</p><p><span class="qpc-hafs">﴿مُّلۡكًا عَظِيمࣰا﴾</span>: مُلْكَ سليمانَ.</p></div>"
  4,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَعِيرًا﴾</span>: نارًا تُوقَدُ عليهم.</p></div>"
  4,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَضِجَتۡ﴾</span>: احترقَتْ.</p></div>"
  4,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّطَهَّرَةࣱ﴾</span>: من كلِّ دَنَسٍ يكونُ في نساءِ أهلِ الدُّنيا.</p><p><span class="qpc-hafs">﴿ظَلِيلًا﴾</span>: كثيفًا ممتدًّا.</p></div>"
  4,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نِعِمَّا﴾</span>: نِعْمَ الشيءُ.</p></div>"
  4,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُوْلِي ٱلۡأَمۡرِ﴾</span>: الأئمةَ، ومَن ولّاه المسلمون، مالم يَكُنْ في طاعتِهم معصيةٌ.</p><p><span class="qpc-hafs">﴿فَرُدُّوهُ﴾</span>: أرْجِعُوا الحُكْمَ فيه.</p><p><span class="qpc-hafs">﴿تَأۡوِيلًا﴾</span>: عاقبةً ومَرْجِعًا.</p></div>"