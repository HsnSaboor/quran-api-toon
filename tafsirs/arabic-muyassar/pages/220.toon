quran[9]{c,v,t}:
  10,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَوۡلَا﴾</span>: فهَلّا.</p><p><span class="qpc-hafs">﴿ٱلۡخِزۡيِ﴾</span>: الذُّلِّ والهَوانِ.</p><p><span class="qpc-hafs">﴿إِلَىٰ حِينࣲ﴾</span>: إلى وقتِ انقضاءِ آجالِهم.</p></div>"
  10,99,"<div class=ar lang=ar></div>"
  10,100,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرِّجۡسَ﴾</span>: عذابَ اللهِ وغَضَبَه.</p></div>"
  10,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنظُرُواْ﴾</span>: تَفَكَّرُوا واعتَبِرُوا.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتُ﴾</span>: الدلائلُ والعِبَرُ.</p><p><span class="qpc-hafs">﴿وَٱلنُّذُرُ﴾</span>: جَمْعُ نَذِير، وهم: الرسُلُ.</p></div>"
  10,102,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِثۡلَ أَيَّامِ ٱلَّذِينَ خَلَوۡاْ مِن قَبۡلِهِمۡ﴾</span>: مثلَ ما حَلَّ بالأممِ السابقةِ من العذابِ.</p></div>"
  10,103,"<div class=ar lang=ar></div>"
  10,104,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَفَّىٰكُمۡ﴾</span>: يُمِيتُكم.</p></div>"
  10,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَقِمۡ وَجۡهَكَ لِلدِّينِ﴾</span>: استقِمْ على دينِ الإسلامِ مُخْلِصًا لله في عبادتِك وعَمَلِك.</p><p><span class="qpc-hafs">﴿حَنِيفࣰا﴾</span>: مائلًا عن الأديانِ الباطلةِ.</p></div>"
  10,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلظَّـٰلِمِينَ﴾</span>: المُشْركين.</p></div>"