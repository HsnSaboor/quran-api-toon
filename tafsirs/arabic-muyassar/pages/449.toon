quran[26]{c,v,t}:
  37,77,""
37,78," <q>﴿ٱلۡـَٔاخِرِينَ﴾</q>: الَّذينَ جاؤُوا بَعْدَه. "
  37,79,""
  37,80,""
  37,81,""
37,82," <q>﴿ٱلۡـَٔاخَرِينَ﴾</q>: الباقِينَ الَّذين كذَّبوُا نوحًا عليه الصَّلاةُ والسَّلامُ. "
37,83," <q>﴿شِيعَتِهِۦ﴾</q>: أي: جَماعَتِهِ الَّذينَ هُمُ الأنبِياءُ والمرْسَلُونَ عليهم الصَّلاةُ والسَّلامُ. "
  37,84,""
  37,85,""
37,86," <q>﴿أَئِفۡكًا﴾</q>: أكَذِبًا وباطِلًا. "
  37,87,""
37,88," <q>﴿فَنَظَرَ﴾</q>: تَأَمَّلَ. "
37,89," <q>﴿سَقِيمࣱ﴾</q>: مَرِيضٌ. "
37,90," <q>﴿فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ﴾</q>: فانصَرَفُوا عنه مُعْرِضِين. "
37,91," <q>﴿فَرَاغَ إِلَىٰٓ﴾</q>: ذَهَبَ خُفْيَةً. "
  37,92,""
37,93," <q>﴿فَرَاغَ عَلَيۡهِمۡ﴾</q>: مالَ وأَقْبَل عَلَيهِم. <q>﴿بِٱلۡيَمِينِ﴾</q>: أي: بيَدِه اليُمْنى. "
37,94," <q>﴿يَزِفُّونَ﴾</q>: يُسْرِعُونَ في مَشْيِهِم. "
37,95," <q>﴿تَنۡحِتُونَ﴾</q>: تَبْرُونَ وتَقْشِرُونَ بِأَيْدِيكُم. "
  37,96,""
37,97," <q>﴿ٱلۡجَحِيمِ﴾</q>: النّارِ الشَّديدةِ الاتِّقادِ. "
37,98," <q>﴿ٱلۡأَسۡفَلِينَ﴾</q>: المقْهُورِينَ المغْلُوبِينَ. "
  37,99,""
  37,100,""
37,101," <q>﴿حَلِيمࣲ﴾</q>: أي: عِنْدَما يَكْبَر. "
  37,102,""
