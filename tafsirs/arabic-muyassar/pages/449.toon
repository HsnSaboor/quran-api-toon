quran[26]{c,v,t}:
  37,77,""
  37,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡـَٔاخِرِينَ﴾</span>: الَّذينَ جاؤُوا بَعْدَه.</p></div>"
  37,79,""
  37,80,""
  37,81,""
  37,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡـَٔاخَرِينَ﴾</span>: الباقِينَ الَّذين كذَّبوُا نوحًا عليه الصَّلاةُ والسَّلامُ.</p></div>"
  37,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِيعَتِهِۦ﴾</span>: أي: جَماعَتِهِ الَّذينَ هُمُ الأنبِياءُ والمرْسَلُونَ عليهم الصَّلاةُ والسَّلامُ.</p></div>"
  37,84,""
  37,85,""
  37,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَئِفۡكًا﴾</span>: أكَذِبًا وباطِلًا.</p></div>"
  37,87,""
  37,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَنَظَرَ﴾</span>: تَأَمَّلَ.</p></div>"
  37,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَقِيمࣱ﴾</span>: مَرِيضٌ.</p></div>"
  37,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ﴾</span>: فانصَرَفُوا عنه مُعْرِضِين.</p></div>"
  37,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَاغَ إِلَىٰٓ﴾</span>: ذَهَبَ خُفْيَةً.</p></div>"
  37,92,""
  37,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَاغَ عَلَيۡهِمۡ﴾</span>: مالَ وأَقْبَل عَلَيهِم.</p><p><span class="qpc-hafs">﴿بِٱلۡيَمِينِ﴾</span>: أي: بيَدِه اليُمْنى.</p></div>"
  37,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَزِفُّونَ﴾</span>: يُسْرِعُونَ في مَشْيِهِم.</p></div>"
  37,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَنۡحِتُونَ﴾</span>: تَبْرُونَ وتَقْشِرُونَ بِأَيْدِيكُم.</p></div>"
  37,96,""
  37,97,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَحِيمِ﴾</span>: النّارِ الشَّديدةِ الاتِّقادِ.</p></div>"
  37,98,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَسۡفَلِينَ﴾</span>: المقْهُورِينَ المغْلُوبِينَ.</p></div>"
  37,99,""
  37,100,""
  37,101,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَلِيمࣲ﴾</span>: أي: عِنْدَما يَكْبَر.</p></div>"
  37,102,""