quran[22]{c,v,t}:
  54,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَبِّئۡهُمۡ﴾</span>: وأَخْبِرْهُم.</p><p><span class="qpc-hafs">﴿قِسۡمَةُۢ﴾</span>: مَقْسُومٌ.</p><p><span class="qpc-hafs">﴿بَيۡنَهُمۡ﴾</span>: بَيْنَ ثَمُودَ والنّاقَةِ.</p><p><span class="qpc-hafs">﴿كُلُّ شِرۡبࣲ﴾</span>: كُلُّ نَصِيبٍ مِن الشَّرابِ.</p><p><span class="qpc-hafs">﴿مُّحۡتَضَرࣱ﴾</span>: يَحْضُرُهُ صاحِبُهُ ويَسْتَحِقُّهُ.</p></div>"
  54,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَعَاطَىٰ﴾</span>: فَتَناوَلَ النّاقَةَ بِيَدِهِ لِيَعْقِرَها.</p><p><span class="qpc-hafs">﴿فَعَقَرَ﴾</span>: فَقَتَلَ.</p></div>"
  54,30,"<div class=ar lang=ar></div>"
  54,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَهَشِيمِ﴾</span>: كالشَّجَرِ اليابِسِ الَّذِي يَسْقُطُ ويَتَناثَرُ.</p><p><span class="qpc-hafs">﴿ٱلۡمُحۡتَظِرِ﴾</span>: الَّذِي يُرِيدُ أن يَعْمَلَ سِياجًا لِحِفْظِ المواشِي فَيَحْتَطِبَ لِذَلِكَ.</p></div>"
  54,32,"<div class=ar lang=ar></div>"
  54,33,"54:32"
  54,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاصِبًا﴾</span>: رِيحًا شَدِيدَةً تَرْمِيهِم بِحِجارَةٍ.</p><p><span class="qpc-hafs">﴿بِسَحَرࣲ﴾</span>: في آخِرِ الليلِ.</p></div>"
  54,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَجۡزِي﴾</span>: نُثِيبُ.</p><p><span class="qpc-hafs">﴿مَن شَكَرَ﴾</span>: مَن آمَنَ بِاللهِ ووَحّدَهُ.</p></div>"
  54,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدۡ أَنذَرَهُم﴾</span>: خَوَّفَهُم.</p><p><span class="qpc-hafs">﴿بَطۡشَتَنَا﴾</span>: بَأْسَنا وعَذابَنا.</p><p><span class="qpc-hafs">﴿فَتَمَارَوۡاْ﴾</span>: فَشَكُّوا.</p><p><span class="qpc-hafs">﴿بِٱلنُّذُرِ﴾</span>: بالإنْذارِ.</p></div>"
  54,37,"<div class=ar lang=ar></div>"
  54,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَبَّحَهُم بُكۡرَةً﴾</span>: جاءَهُم وقْتَ الصَّباحِ.</p><p><span class="qpc-hafs">﴿مُّسۡتَقِرࣱّ﴾</span>: نازلٌ بِهم.</p></div>"
  54,39,"<div class=ar lang=ar></div>"
  54,40,"54:39"
  54,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَالَ فِرۡعَوۡنَ﴾</span>: أتْباعَ فِرْعَونَ.</p><p><span class="qpc-hafs">﴿ٱلنُّذُرُ﴾</span>: الإنْذارُ تِلْو الإنْذارِ مِن مُوسى عَلَيهِ السَّلامُ بالعُقُوبةِ عَلى كُفْرِهِم.</p></div>"
  54,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: بِأَدلَّتِنا الدّالّةِ عَلى وحْدانِيَّتِنا ونُبُوَّةِ أنْبِيائِنا.</p><p><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُمۡ﴾</span>: فَعاقَبْناهُم.</p><p><span class="qpc-hafs">﴿عَزِيزࣲ﴾</span>: لا يُغالَبُ.</p><p><span class="qpc-hafs">﴿مُّقۡتَدِرٍ﴾</span>: قادِرٍ عَلى هَلاكِكُم.</p></div>"
  54,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَكُفَّارُكُمۡ﴾</span>: يا مَعْشَرَ العَرَبِ.</p><p><span class="qpc-hafs">﴿بَرَآءَةࣱ﴾</span>: مِنَ العذابِ ألّا يُصِيبَكُم ما أصابَهُم.</p><p><span class="qpc-hafs">﴿ٱلزُّبُرِ﴾</span>: الكُتُبِ المنَزَّلةِ عَلى الأنبياءِ المُتقَدِّمِينَ.</p></div>"
  54,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَمِيعࣱ﴾</span>: نَحْنَ يَدٌ واحِدَةٌ عَلى مَن خالَفَنا.</p><p><span class="qpc-hafs">﴿مُّنتَصِرࣱ﴾</span>: نَغْلِبُ غَيرَنا.</p></div>"
  54,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡجَمۡعُ﴾</span>: جَمْعُ كُفّارِ مَكَّةَ أمامَ المُؤمِنِينَ.</p></div>"
  54,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَدۡهَىٰ﴾</span>: أفْظَعُ وأَعْظَمُ.</p><p><span class="qpc-hafs">﴿وَأَمَرُّ﴾</span>: أشدُّ مَرارَةً مِنَ القَتْلِ والأَسْرِ.</p></div>"
  54,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ﴾</span>: تِيهٍ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿وَسُعُرࣲ﴾</span>: جُنُونٍ أو نارٍ تَسْتَعِرُ عَلَيهِم.</p></div>"
  54,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُسۡحَبُونَ﴾</span>: يُجَرُّونَ.</p><p><span class="qpc-hafs">﴿مَسَّ سَقَرَ﴾</span>: شِدَّةَ عَذابِ جَهَنَّمَ.</p></div>"
  54,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِقَدَرࣲ﴾</span>: بمِقَدارٍ قَدَّرْناهُ، وسَبَق عِلْمُنا بِهِ، وكِتابَتُنا لَهُ في اللَّوحِ المَحْفُوظِ.</p></div>"