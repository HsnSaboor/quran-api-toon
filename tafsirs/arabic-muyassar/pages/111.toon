quran[6]{c,v,t}:
  5,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَحۡنُ أَبۡنَـٰٓؤُاْ ٱللَّهِ﴾</span>: فقالت اليهودُ: عزيرٌ ابنُ اللهِ، وقالت النصارى: المسيحُ ابنُ اللهِ.</p><p><span class="qpc-hafs">﴿أَنتُم بَشَرࣱ﴾</span>: أنتم خَلْقٌ مثلُ سائرِ بني آدمَ يحاسبُهم على أعمالهم.</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المَرْجِعُ.</p></div>"
  5,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَسُولُنَا﴾</span>: محمدٌ ﷺ</p><p><span class="qpc-hafs">﴿عَلَىٰ فَتۡرَةࣲ مِّنَ ٱلرُّسُلِ﴾</span>: على انقطاعٍ من الرسلِ مُدّةً من الزمانِ.</p><p><span class="qpc-hafs">﴿أَن تَقُولُواْ﴾</span>: لئلّا تقُولوا.</p></div>"
  5,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجَعَلَكُم مُّلُوكࣰا﴾</span>: وجْهُ الامتنانِ كثرةُ الملوكِ والأنبياءِ فيهم، أو أنكم تملكون أمرَكم بعد أن كنتم مملوكين لفرعونَ.</p><p><span class="qpc-hafs">﴿مِّنَ ٱلۡعَـٰلَمِينَ﴾</span>: عالَمِي زمانِكم.</p></div>"
  5,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضَ ٱلۡمُقَدَّسَةَ﴾</span>: المطهَّرَةَ المباركةَ، وهي بيتُ المَقْدِسِ وما حولَها.</p><p><span class="qpc-hafs">﴿وَلَا تَرۡتَدُّواْ عَلَىٰٓ أَدۡبَارِكُمۡ﴾</span>: ولا تَرْجِعُوا عن قتالِ الأشدّاء.</p></div>"
  5,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَبَّارِينَ﴾</span>: أشدّاءَ، لاطاقَةَ لنا بحَرْبِهم.</p></div>"
  5,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخَافُونَ﴾</span>: أي: اللهَ.</p><p><span class="qpc-hafs">﴿ٱدۡخُلُواْ عَلَيۡهِمُ ٱلۡبَابَ﴾</span>: ادخُلوا على هؤلاءِ الأشدّاءِ بابَ مدينتِهم.</p></div>"