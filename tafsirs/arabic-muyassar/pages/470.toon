quran[8]{c,v,t}:
  40,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَرُونِيٓ﴾</span>: اتْرُكُونِي.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرْضِ مِصْرَ.</p></div>"
  40,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُذۡتُ﴾</span>: لَجَأْتُ واسْتَجَرْتُ.</p></div>"
  40,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُصِبۡكُم﴾</span>: يَلْحَقْكُم.</p><p><span class="qpc-hafs">﴿يَعِدُكُمۡ﴾</span>: يَتَوَعَّدُكُم بهِ مِنَ العُقُوبَةِ.</p><p><span class="qpc-hafs">﴿مُسۡرِفࣱ﴾</span>: مُتَجاوِزٌ لِلْحَدِّ بالشِّرْكِ والقَتْلِ بِغَيْرِ حَقٍّ.</p></div>"
  40,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَـٰهِرِينَ﴾</span>: غالِبينَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرْضِ مِصْرَ.</p><p><span class="qpc-hafs">﴿فَمَن يَنصُرُنَا﴾</span>: فَمَن يَدْفَعُ عَنّا.</p><p><span class="qpc-hafs">﴿بَأۡسِ ٱللَّهِ﴾</span>: عَذابِ اللهِ.</p><p><span class="qpc-hafs">﴿مَآ أُرِيكُمۡ إِلَّا مَآ أَرَىٰ﴾</span>: ما أُرِيكُم مِّنَ الرّأيِ والنَّصِيحَةِ إلّا ما أرى لِنَفْسِي ولَكُم صَلاحًا وصَوابًا.</p><p><span class="qpc-hafs">﴿سَبِيلَ ٱلرَّشَادِ﴾</span>: طَرِيقَ الحقِّ والصَّوابِ.</p></div>"
  40,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمِ ٱلۡأَحۡزَابِ﴾</span>: يَوْمِ عَذابِ الَّذينَ تَجَمَّعُوا على أنبيائِهِم فَأَهْلكَهُم اللهُ.</p></div>"
  40,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَأۡبِ﴾</span>: عادَةِ.</p></div>"
  40,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ ٱلتَّنَادِ﴾</span>: يَومَ يُنادِي فِيه بعضُ النّاسِ بَعْضًا مِن هَوْلِ الموقِفِ.</p></div>"
  40,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُوَلُّونَ﴾</span>: تَذْهَبُونَ وتَنْصَرِفُونَ.</p><p><span class="qpc-hafs">﴿مُدۡبِرِينَ﴾</span>: ذاهِبِينَ هارِبِينَ.</p><p><span class="qpc-hafs">﴿عَاصِمࣲ﴾</span>: مانِعٍ يَمْنَعُكُم.</p></div>"