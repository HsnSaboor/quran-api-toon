tafsir[13]{c,v,t}:
27,64," <q>﴿يَبۡدَؤُاْ ٱلۡخَلۡقَ﴾</q>: يُنْشِئُه. <q>﴿بُرۡهَـٰنَكُمۡ﴾</q>: حُجَّتَكُم. "
27,65," <q>﴿أَيَّانَ يُبۡعَثُونَ﴾</q>: مَتى يُبْعثُونَ مِن قُبُورِهِم. "
27,66," <q>﴿بَلِ ٱدَّ ٰ⁠رَكَ عِلۡمُهُمۡ فِي ٱلۡـَٔاخِرَةِ﴾</q>: بَلْ تَكامَلَ علمُهُم بِها عِنْدَما بُعِثُوا يومَ القيامةِ. <q>﴿فِي شَكࣲّ مِّنۡهَا﴾</q>: أي: مِنَ الآخِرةِ في الدُّنيا. <q>﴿عَمُونَ﴾</q>: أي: غافِلُونَ، فَقُلُوبُهُم عَمْياءُ. "
27,67," <q>﴿لَمُخۡرَجُونَ﴾</q>: لمَبْعُوثُونَ مِن قُبُورِنا. "
27,68," <q>﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</q>: الأكاذيبُ الَّتي كَتَبها المتقدِّمُونَ. "
  27,69,""
27,70," <q>﴿ضَيۡقࣲ﴾</q>: حَرَجٍ وضِيقِ صَدْرٍ. "
  27,71,""
27,72," <q>﴿رَدِفَ لَكُم﴾</q>: لَحِقَكُم، أو اقْتَرَبَ لَكُم. "
  27,73,""
27,74," <q>﴿مَا تُكِنُّ﴾</q>: ما تُخْفِي. <q>﴿وَمَا يُعۡلِنُونَ﴾</q>: وما يُظْهِرُونَ. "
27,75," <q>﴿غَآئِبَةࣲ﴾</q>: هو ما يَغيبُ ويَخْفى عَلى الخَلْقِ. <q>﴿مُّبِينٍ﴾</q>: واضِحٍ. "
  27,76,""
