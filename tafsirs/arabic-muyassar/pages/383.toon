quran[13]{c,v,t}:
  27,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَبۡدَؤُاْ ٱلۡخَلۡقَ﴾</span>: يُنْشِئُه.</p><p><span class="qpc-hafs">﴿بُرۡهَـٰنَكُمۡ﴾</span>: حُجَّتَكُم.</p></div>"
  27,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَّانَ يُبۡعَثُونَ﴾</span>: مَتى يُبْعثُونَ مِن قُبُورِهِم.</p></div>"
  27,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلِ ٱدَّ ٰ⁠رَكَ عِلۡمُهُمۡ فِي ٱلۡـَٔاخِرَةِ﴾</span>: بَلْ تَكامَلَ علمُهُم بِها عِنْدَما بُعِثُوا يومَ القيامةِ.</p><p><span class="qpc-hafs">﴿فِي شَكࣲّ مِّنۡهَا﴾</span>: أي: مِنَ الآخِرةِ في الدُّنيا.</p><p><span class="qpc-hafs">﴿عَمُونَ﴾</span>: أي: غافِلُونَ، فَقُلُوبُهُم عَمْياءُ.</p></div>"
  27,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمُخۡرَجُونَ﴾</span>: لمَبْعُوثُونَ مِن قُبُورِنا.</p></div>"
  27,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾</span>: الأكاذيبُ الَّتي كَتَبها المتقدِّمُونَ.</p></div>"
  27,69,"<div class=ar lang=ar></div>"
  27,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَيۡقࣲ﴾</span>: حَرَجٍ وضِيقِ صَدْرٍ.</p></div>"
  27,71,"<div class=ar lang=ar></div>"
  27,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَدِفَ لَكُم﴾</span>: لَحِقَكُم، أو اقْتَرَبَ لَكُم.</p></div>"
  27,73,"<div class=ar lang=ar></div>"
  27,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تُكِنُّ﴾</span>: ما تُخْفِي.</p><p><span class="qpc-hafs">﴿وَمَا يُعۡلِنُونَ﴾</span>: وما يُظْهِرُونَ.</p></div>"
  27,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿غَآئِبَةࣲ﴾</span>: هو ما يَغيبُ ويَخْفى عَلى الخَلْقِ.</p><p><span class="qpc-hafs">﴿مُّبِينٍ﴾</span>: واضِحٍ.</p></div>"
  27,76,"<div class=ar lang=ar></div>"