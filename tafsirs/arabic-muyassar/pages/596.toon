quran[26]{c,v,t}:
  92,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَصۡلَىٰهَآ﴾</span>: لا يُقاسِي حَرَّها.</p></div>"
  92,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَّبَ﴾</span>: لم يُصَدِّق نبيَّ اللهِ محمدًا ﷺ.</p><p><span class="qpc-hafs">﴿وَتَوَلَّىٰ﴾</span>: وأَعْرَضَ عَنِ الإيمانِ باللهِ ورسولِه، وطاعَتِهِما.</p></div>"
  92,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَسَيُجَنَّبُهَا﴾</span>: وسَيُزَحْزَحُ عَنْها.</p></div>"
  92,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُؤۡتِي مَالَهُۥ﴾</span>: يَبْذُلُ مالَهُ.</p><p><span class="qpc-hafs">﴿يَتَزَكَّىٰ﴾</span>: يَطلبُ المزيدَ مِنَ الخيرِ.</p></div>"
  92,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةࣲ تُجۡزَىٰٓ﴾</span>: ولَيسَ إنفاقُه ذاكَ مُكافأةً لِمنْ أسْدى إلَيهِ معرُوفًا.</p></div>"
  92,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا﴾</span>: لَكِنَّهُ.</p></div>"
  92,21,""
  93,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلضُّحَىٰ﴾</span>: أقْسَمَ اللهُ بِوقتِ الضُّحى، والمرادُ بِهِ النَّهارُ كُلُّهُ.</p></div>"
  93,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَجَىٰ﴾</span>: اشْتَدَّ ظَلامُهُ.</p></div>"
  93,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا وَدَّعَكَ﴾</span>: ما تَرَكَكَ.</p><p><span class="qpc-hafs">﴿وَمَا قَلَىٰ﴾</span>: وما أبْغَضَكَ حِينَ أبْطَأَ الوحْيُ عَنكَ.</p></div>"
  93,4,""
  93,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ﴾</span>: -أيُّها النَّبِيُّ- مِن أنواعِ الإنْعام في الآخِرَةِ.</p></div>"
  93,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَـَٔاوَىٰ﴾</span>: فَآواكَ ورَعاكَ.</p></div>"
  93,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَآلࣰّا﴾</span>: لا تَدْرِي ما الكِتابُ ولا الإيمانُ؟.</p><p><span class="qpc-hafs">﴿فَهَدَىٰ﴾</span>: فَعَلَّمكَ مالَمْ تَكُن تَعْلَمُ.</p></div>"
  93,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَآئِلࣰا﴾</span>: فقِيرًا.</p><p><span class="qpc-hafs">﴿فَأَغۡنَىٰ﴾</span>: فَساقَ لَكَ رِزْقَكَ، وأَغْنى نَفسَكَ بالقناعَةِ والصَّبْرِ؟</p></div>"
  93,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تَقۡهَرۡ﴾</span>: فلا تُسِئْ مُعامَلَتَهُ.</p></div>"
  93,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تَنۡهَرۡ﴾</span>: فَلا تَزْجُرْهُ.</p></div>"
  93,11,""
  94,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ﴾</span>: ألَمْ نُوَسِّعْ -أيُّها النَّبِيُّ- لَكَ صَدْرَكَ لِشرائِعِ الدِّينِ، والدَّعْوةِ إلى اللهِ، والاتِّصافِ بِمكارِمِ الأخلاقِ.</p></div>"
  94,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَوَضَعۡنَا عَنكَ وِزۡرَكَ﴾</span>: وحَطَطْنا عَنكَ بِذَلِكَ حِمْلكَ.</p></div>"
  94,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنقَضَ﴾</span>: أثْقَلَ.</p></div>"
  94,4,""
  94,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا﴾</span>: فإنّ مَعَ الضِّيقِ فَرَجًا.</p></div>"
  94,6,""
  94,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَرَغۡتَ﴾</span>: أتْمَمْتَ عَمَلًا مِن أُمُورِ الدُّنيا.</p><p><span class="qpc-hafs">﴿فَٱنصَبۡ﴾</span>: فَجِدَّ في الِعبادةِ.</p></div>"
  94,8,""