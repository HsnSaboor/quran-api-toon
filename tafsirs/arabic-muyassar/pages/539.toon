quran[7]{c,v,t}:
  57,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡعَىٰ نُورُهُم﴾</span>: يُضِيءُ لَهُم نُورُ عَمَلِهِم عَلى الصِّراطِ عَلى قَدْرِ أعْمالِهِم.</p></div>"
  57,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱنظُرُونَا﴾</span>: انْتَظِرُونا، وتَريَّثُوا في سَيرِكُم حتى نَلْحَقَ بِكُم.</p><p><span class="qpc-hafs">﴿نَقۡتَبِسۡ﴾</span>: نَأْخُذْ.</p><p><span class="qpc-hafs">﴿قِيلَ﴾</span>: القائِلُ: المؤمِنُونَ.</p><p><span class="qpc-hafs">﴿ٱرۡجِعُواْ وَرَآءَكُمۡ﴾</span>: ارْجِعُوا إلى المكانِ الَّذِي قَبَسْتُم فِيهِ النُّورَ.</p><p><span class="qpc-hafs">﴿فَٱلۡتَمِسُواْ﴾</span>: فاطْلُبُوا.</p><p><span class="qpc-hafs">﴿فَضُرِبَ بَيۡنَهُم﴾</span>: فَوُضِعَ بَيْنَ المؤمِنينَ والمنافِقِينَ.</p><p><span class="qpc-hafs">﴿بِسُورࣲ﴾</span>: بِجِدارٍ مُحِيطٍ مُرْتَفِعٍ.</p><p><span class="qpc-hafs">﴿بَاطِنُهُۥ﴾</span>: داخِلُهُ.</p><p><span class="qpc-hafs">﴿وَظَـٰهِرُهُۥ﴾</span>: خارِجُهُ.</p><p><span class="qpc-hafs">﴿مِن قِبَلِهِ﴾</span>: في جِهَتِهِ المقابِلَةِ الَّتِي فِيها المنافِقُونَ.</p></div>"
  57,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَنتُمۡ أَنفُسَكُمۡ﴾</span>: آثمْتُمُوها، وأَهْلَكْتُمُوها بالنِّفاقِ.</p><p><span class="qpc-hafs">﴿وَتَرَبَّصۡتُمۡ﴾</span>: وانْتَظَرْتُم بالنَّبِي الموتَ وبِالمؤمِنِينَ الدَّوائِرَ.</p><p><span class="qpc-hafs">﴿وَٱرۡتَبۡتُمۡ﴾</span>: شَكَكْتُم في التَّوحِيدِ ونُبُوَّةِ محمَّدٍ ﷺ.</p><p><span class="qpc-hafs">﴿وَغَرَّتۡكُمُ﴾</span>: خَدَعَتْكُم.</p><p><span class="qpc-hafs">﴿ٱلۡأَمَانِيُّ﴾</span>: ما تُمَنُّونَ بِهِ أنْفُسَكُم مِنَ الأباطِيلِ.</p><p><span class="qpc-hafs">﴿أَمۡرُ ٱللَّهِ﴾</span>: الموتُ.</p><p><span class="qpc-hafs">﴿ٱلۡغَرُورُ﴾</span>: الشَّيطانُ.</p></div>"
  57,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِدۡيَةࣱ﴾</span>: عِوَضٌ تَتَخَلّصُونَ بِهِ مِنَ العذابِ.</p><p><span class="qpc-hafs">﴿مَأۡوَىٰكُمُ﴾</span>: مَصِيرُكُم الَّذِي تَخْلُدُونَ فِيهِ.</p><p><span class="qpc-hafs">﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾</span>: وساءَ مَرْجِعُ مَن صارَ إلى النّارِ.</p></div>"
  57,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَلَمۡ يَأۡنِ﴾</span>: ألَمْ يَأْتِ الوَقْتُ؟</p><p><span class="qpc-hafs">﴿تَخۡشَعَ﴾</span>: تَرِقَّ وتَلِينَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَمَدُ﴾</span>: الزَّمانُ أو الغايَةُ، وبُعْدُ عَهْدِهِم بالأنبياءِ والصّالِحِينَ.</p></div>"
  57,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضَ﴾</span>: الميْتَةَ الَّتِي لا تُنْبِتُ شَيئًا.</p><p><span class="qpc-hafs">﴿بَعۡدَ مَوۡتِهَا﴾</span>: بَعْدَ يُبْسِها لاحْتِباسِ الماءِ عَنْها.</p><p><span class="qpc-hafs">﴿ٱلۡـَٔايَـٰتِ﴾</span>: الدَّلائِلَ والحُجَجَ.</p><p><span class="qpc-hafs">﴿لَعَلَّكُمۡ تَعۡقِلُونَ﴾</span>: رَجاءَ أن تَعْقِلُوا.</p></div>"
  57,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُصَّدِّقِينَ﴾</span>: المتَصَدِّقِينَ مِن أمْوالِهِم.</p><p><span class="qpc-hafs">﴿وَأَقۡرَضُواْ ٱللَّهَ قَرۡضًا﴾</span>: أنْفَقُوا في سَبِيلِ اللهِ نَفَقاتٍ طَيِّبةً بِها نُفُوسُهُم.</p></div>"