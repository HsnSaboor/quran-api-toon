quran[27]{c,v,t}:
  37,25,"<div class=ar lang=ar></div>"
  37,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُسۡتَسۡلِمُونَ﴾</span>: مُنْقادُونَ أذلّاءُ لِعَجِزِهِم عَنِ الحِيلَةِ.</p></div>"
  37,27,"<div class=ar lang=ar></div>"
  37,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَنِ ٱلۡيَمِينِ﴾</span>: أي: عَنِ النّاحيةِ الَّتي كان مِنها الحقُّ، فَتَصْرِفُونَنا عَنْها.</p></div>"
  37,29,"<div class=ar lang=ar></div>"
  37,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَـٰغِينَ﴾</span>: متجاوِزِينَ الحَدَّ في الكُفْرِ والضَّلالِ.</p></div>"
  37,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَقَّ﴾</span>: ثَبَتَ ووَجَبَ.</p></div>"
  37,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَغۡوَيۡنَـٰكُمۡ﴾</span>: فأَضْلَلْناكُم.</p><p><span class="qpc-hafs">﴿غَـٰوِينَ﴾</span>: ضالِّيِنَ.</p></div>"
  37,33,"<div class=ar lang=ar></div>"
  37,34,"37:33"
  37,35,"37:33"
  37,36,"37:33"
  37,37,"37:33"
  37,38,"37:33"
