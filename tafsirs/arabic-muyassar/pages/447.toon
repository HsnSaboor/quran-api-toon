tafsir[27]{c,v,t}:
  37,25,""
37,26," <q>﴿مُسۡتَسۡلِمُونَ﴾</q>: مُنْقادُونَ أذلّاءُ لِعَجِزِهِم عَنِ الحِيلَةِ. "
  37,27,""
37,28," <q>﴿عَنِ ٱلۡيَمِينِ﴾</q>: أي: عَنِ النّاحيةِ الَّتي كان مِنها الحقُّ، فَتَصْرِفُونَنا عَنْها. "
  37,29,""
37,30," <q>﴿طَـٰغِينَ﴾</q>: متجاوِزِينَ الحَدَّ في الكُفْرِ والضَّلالِ. "
37,31," <q>﴿فَحَقَّ﴾</q>: ثَبَتَ ووَجَبَ. "
37,32," <q>﴿فَأَغۡوَيۡنَـٰكُمۡ﴾</q>: فأَضْلَلْناكُم. <q>﴿غَـٰوِينَ﴾</q>: ضالِّيِنَ. "
  37,33,""
  37,34,""
  37,35,""
  37,36,""
  37,37,""
  37,38,""
  37,39,""
  37,40,""
  37,41,""
  37,42,""
  37,43,""
  37,44,""
37,45," <q>﴿يُطَافُ﴾</q>: يُدارُ. <q>﴿بِكَأۡسࣲ﴾</q>: بِكأسٍ مِن خمْرٍ. <q>﴿مَّعِينِۭ﴾</q>: نابِعٍ مِنَ العُيوَنِ. "
  37,46,""
37,47," <q>﴿لَا فِيهَا غَوۡلࣱ﴾</q>: لا أذىً فيها ولا مَكْروهٌ على شاربيها. <q>﴿وَلَا هُمۡ عَنۡهَا يُنزَفُونَ﴾</q>: ولا هم عَن شُرْبِها تَذْهَبُ عُقُولُهم، أي: لا تُنزَفُ عُقُولُهم كما يُنْزَفَ دَمُ الجَرِيحِ. "
37,48," <q>﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾</q>: حُورٌ قَصَرْنَ نَظَرَهُنَّ على أزْواجِهِنَّ. <q>﴿عِينࣱ﴾</q>: جَمْعُ «عَيناءَ»: واسعةُ العَينِ حَسَنَتُها. "
37,49," <q>﴿مَّكۡنُونࣱ﴾</q>: مَصُونٌ لم يَمْسَسْهُ أحَدٌ. "
  37,50,""
37,51," <q>﴿قَرِينࣱ﴾</q>: صاحِبٌ مُلازِمٌ. "
