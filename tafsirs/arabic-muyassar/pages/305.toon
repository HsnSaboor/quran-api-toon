quran[11]{c,v,t}:
  19,1,""
  19,2,""
  19,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَفِيࣰّا﴾</span>: سِرًّا.</p></div>"
  19,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَهَنَ﴾</span>: ضَعُفَ.</p><p><span class="qpc-hafs">﴿وَٱشۡتَعَلَ ٱلرَّأۡسُ شَيۡبࣰا﴾</span>: انْتَشَرَ الشَّيبُ في رَأسِي.</p><p><span class="qpc-hafs">﴿شَقِيࣰّا﴾</span>: مَحْرُومًا مِن إجابَةِ الدُّعاءِ.</p></div>"
  19,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَوَ ٰ⁠لِيَ﴾</span>: العَصَبَةَ وأقْرَبَ القَرابَةِ.</p><p><span class="qpc-hafs">﴿عَاقِرࣰا﴾</span>: التي لا تَلِدُ.</p><p><span class="qpc-hafs">﴿وَلِيࣰّا﴾</span>: ولَدًا وارِثًا ومُعِينًا.</p></div>"
  19,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَرِثُنِي﴾</span>: يَرِثُ نُبُوَّتي.</p><p><span class="qpc-hafs">﴿رَضِيࣰّا﴾</span>: مَرْضِيًّا مِنكَ ومِن عِبادِكَ.</p></div>"
  19,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَمِيࣰّا﴾</span>: مُسَمّىً باسْمِه.</p></div>"
  19,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: كيفَ؟</p><p><span class="qpc-hafs">﴿عِتِيࣰّا﴾</span>: النِّهايةَ في كِبَر السِّنِّ.</p></div>"
  19,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَيِّنࣱ﴾</span>: سَهْلٌ.</p><p><span class="qpc-hafs">﴿وَلَمۡ تَكُ شَيۡـࣰٔا﴾</span>: ولم تَكُ شيئًا مَذْكُورًا ولا مَوْجُودًا.</p></div>"
  19,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: علامةً.</p><p><span class="qpc-hafs">﴿سَوِيࣰّا﴾</span>: صَحِيحًا مُعافىً.</p></div>"
  19,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمِحۡرَابِ﴾</span>: المُصَلّى.</p><p><span class="qpc-hafs">﴿بُكۡرَةࣰ وَعَشِيࣰّا﴾</span>: صَباحًا ومَساءً.</p></div>"