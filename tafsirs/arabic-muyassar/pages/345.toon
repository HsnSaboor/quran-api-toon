quran[17]{c,v,t}:
  23,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَا تَسۡبِقُ﴾</span>: ما تَتَقَدَّمُ.</p><p><span class="qpc-hafs">﴿أَجَلَهَا﴾</span>: الوَقْتَ المَحْدُودَ لهلاكِها.</p><p><span class="qpc-hafs">﴿وَمَا يَسۡتَـٔۡخِرُونَ﴾</span>: ولا يتأخَّرُونَ.</p></div>"
  23,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتۡرَا﴾</span>: يَتْبَعُ بعضُهم بَعْضًا.</p><p><span class="qpc-hafs">﴿أَحَادِيثَ﴾</span>: أخْبارًا يَتَحَدَّثُ الناسُ بها للعِبْرَةِ وغيرِها.</p><p><span class="qpc-hafs">﴿فَبُعۡدࣰا﴾</span>: أي: بُعْدًا عَن رَّحْمَةِ اللهِ.</p></div>"
  23,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَـٰتِنَا﴾</span>: أي: بالمُعْجِزاتِ التِّسْعِ، وهي: العَصا واليدُ البيضاءُ والسِّنونَ المُجْدِبةُ ونَقْصُ الثَّمَراتِ، والطُّوفانُ والجَرادُ والقُمَّلُ والضَّفادِعُ والدَّمُ</p><p><span class="qpc-hafs">﴿وَسُلۡطَـٰنࣲ مُّبِينٍ﴾</span>: بُرْهانٍ مُظْهِرٍ لِلْحَقِّ.</p></div>"
  23,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَلَإِيْهِۦ﴾</span>: وأشْرافِ قَومِه.</p><p><span class="qpc-hafs">﴿عَالِينَ﴾</span>: مُسْتَعْلِينَ على النّاسِ بالبَغْيِ والظُّلْمِ.</p></div>"
  23,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنَا عَـٰبِدُونَ﴾</span>: أي: مُنْقادُون اْنِقيادَ العَبِيدِ.</p></div>"
  23,48,""
  23,49,""
  23,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَةࣰ﴾</span>: علامةً على عَظِيمِ قُدْرَتِنا.</p><p><span class="qpc-hafs">﴿وَءَاوَيۡنَـٰهُمَآ﴾</span>: وجَعَلْنا لَهُما مأْوىً ومْنزِلًا.</p><p><span class="qpc-hafs">﴿رَبۡوَةࣲ﴾</span>: بُقْعَةٍ مُرْتَفِعَةٍ.</p><p><span class="qpc-hafs">﴿ذَاتِ قَرَارࣲ﴾</span>: أي: فيها أسْبابُ الاسْتِقْرارِ من الزَّرِعِ والثِّمارِ.</p><p><span class="qpc-hafs">﴿وَمَعِينࣲ﴾</span>: وماءٍ جارٍ تَسْتَمْتِعُ بِرُؤيَتِه العُيونُ.</p></div>"
  23,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِنَ ٱلطَّيِّبَـٰتِ﴾</span>: مايُسْتَطابُ مِنَ الحَلالِ.</p></div>"
  23,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَّتُكُمۡ أُمَّةࣰ﴾</span>: دِينُكُم دِينٌ واحِدٌ وهو دَعْوةُ جَمِيعِ الأنْبِياءِ إلى عِبادَةِ اللهِ وحْدَه لا شَرِيكَ لَه.</p></div>"
  23,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَقَطَّعُوٓاْ أَمۡرَهُم بَيۡنَهُمۡ﴾</span>: تَفرَّقَ الأتْباعُ في أمْرِ دِينِهِم.</p><p><span class="qpc-hafs">﴿زُبُرࣰا﴾</span>: قِطَعًا وفِرَقًا.</p><p><span class="qpc-hafs">﴿فَرِحُونَ﴾</span>: مَسْرُورُونَ.</p></div>"
  23,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَذَرۡهُمۡ﴾</span>: فاتْرُكْهُم.</p><p><span class="qpc-hafs">﴿فِي غَمۡرَتِهِمۡ﴾</span>: في غَفْلَتِهِم التي غَمَرَتْهُم وغَطَّتْهم مِن كُلِّ الجِهاتِ.</p><p><span class="qpc-hafs">﴿حَتَّىٰ حِينٍ﴾</span>: إلى وقْتِ نُزُولِ العَذاب بِهِم.</p></div>"
  23,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَيَحۡسَبُونَ﴾</span>: أيظُنُّونَ.</p><p><span class="qpc-hafs">﴿نُمِدُّهُم﴾</span>: نُعْطِيهِم اسْتِدْراجًا</p></div>"
  23,56,""
  23,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّشۡفِقُونَ﴾</span>: وجِلُونَ وحَذِرُونَ.</p></div>"
  23,58,""
  23,59,""