quran[25]{c,v,t}:
  26,112,"<div class=ar lang=ar></div>"
  26,113,"26:112"
  26,114,"26:112"
  26,115,"26:112"
  26,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَرۡجُومِينَ﴾</span>: مِنَ المقْتُولِينَ رَمْيًا بالحِجارَةِ.</p></div>"
  26,117,"<div class=ar lang=ar></div>"
  26,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱفۡتَحۡ﴾</span>: فاحْكُمْ.</p></div>"
  26,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَشۡحُونِ﴾</span>: المَمْلُوءِ بالنّاسِ والدَّوابِّ والمتاعِ.</p></div>"
  26,120,"<div class=ar lang=ar></div>"
  26,121,"26:120"
  26,122,"26:120"
  26,123,"26:120"
  26,124,"26:120"
