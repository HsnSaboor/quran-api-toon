quran[25]{c,v,t}:
  26,112,""
  26,113,""
  26,114,""
  26,115,""
26,116," <q>﴿ٱلۡمَرۡجُومِينَ﴾</q>: مِنَ المقْتُولِينَ رَمْيًا بالحِجارَةِ. "
  26,117,""
26,118," <q>﴿فَٱفۡتَحۡ﴾</q>: فاحْكُمْ. "
26,119," <q>﴿ٱلۡمَشۡحُونِ﴾</q>: المَمْلُوءِ بالنّاسِ والدَّوابِّ والمتاعِ. "
  26,120,""
  26,121,""
  26,122,""
  26,123,""
  26,124,""
  26,125,""
  26,126,""
  26,127,""
26,128," <q>﴿رِيعٍ﴾</q>: مكانٍ مُرْتَفِعٍ. <q>﴿ءَايَةࣰ﴾</q>: بِناءً شامِخًا. "
26,129," <q>﴿مَصَانِعَ﴾</q>: حُصُونًا أو قُصُورًا. <q>﴿تَخۡلُدُونَ﴾</q>: أي: تَبْقَونَ في الدُّنيا ولا تَمُوتُونَ. "
26,130," <q>﴿بَطَشۡتُم﴾</q>: أخَذْتُم بِعُنْفٍ. <q>﴿جَبَّارِينَ﴾</q>: قاهِرِينَ ظالِمِين. "
  26,131,""
26,132," <q>﴿أَمَدَّكُم﴾</q>: أنْعَمَ عليكُم وأَعْطاكُم. "
26,133," <q>﴿بِأَنۡعَـٰمࣲ﴾</q>: مِنَ الإبِلِ والبَقَرِ والغَنَمِ. "
26,134," <q>﴿وَجَنَّـٰتࣲ﴾</q>: حَدائِقَ وبَساتِينَ. "
  26,135,""
  26,136,""
