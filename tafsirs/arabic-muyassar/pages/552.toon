quran[9]{c,v,t}:
  61,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّمَا بَيۡنَ يَدَيَّ﴾</span>: لِما جاءَ قَبْلي.</p><p><span class="qpc-hafs">﴿وَمُبَشِّرَۢا﴾</span>: ومُخْبِرًا بِمَجِيءِ الرَّسُولِ ﷺ.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: بالدَّلائِلِ الواضِحاتِ الدّالّةِ عَلى نُبُوَّتِهِ.</p></div>"
  61,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَنۡ أَظۡلَمُ﴾</span>: لا أحَدَ أظْلَمُ.</p><p><span class="qpc-hafs">﴿ٱفۡتَرَىٰ﴾</span>: اختَلَقَ.</p></div>"
  61,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُطۡفِـُٔواْ نُورَ ٱللَّهِ﴾</span>: لِيَقْضُوا عَلى دِينِ اللهِ.</p><p><span class="qpc-hafs">﴿مُتِمُّ نُورِهِۦ﴾</span>: سيُتِمُّ هَذا الإسلامَ حَتّى يَنْتَشِرَ.</p></div>"
  61,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلۡهُدَىٰ﴾</span>: بالقُرآنِ.</p><p><span class="qpc-hafs">﴿وَدِينِ ٱلۡحَقِّ﴾</span>: ودِينِ الإسْلامِ.</p><p><span class="qpc-hafs">﴿لِيُظۡهِرَهُۥ﴾</span>: ليُعْلِيَهُ.</p></div>"
  61,10,"<div class=ar lang=ar></div>"
  61,11,"61:10"
  61,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن تَحۡتِهَا﴾</span>: مِن تَحْتِ قُصُورِها وأَشْجارِها.</p><p><span class="qpc-hafs">﴿عَدۡنࣲ﴾</span>: إقامَةٍ دائِمَةٍ.</p></div>"
  61,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأُخۡرَىٰ﴾</span>: ونِعْمَةٌ أُخْرى.</p><p><span class="qpc-hafs">﴿قَرِيبࣱ﴾</span>: عاجِلٌ.</p></div>"
  61,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِلۡحَوَارِيِّـۧنَ﴾</span>: هُمْ أصْفِياءُ عِيسى –عَلَيهِ السَّلامُ- وخُلَّصُ أصحابِهِ.</p><p><span class="qpc-hafs">﴿ظَـٰهِرِينَ﴾</span>: غالِبِينَ: إما بالحُجَّةِ أو بِبِعْثَةِ مُحَمَّدٍ ﷺ.</p></div>"