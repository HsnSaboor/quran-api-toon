quran[6]{c,v,t}:
  5,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَيۡسِرُ﴾</span>: القِمارُ.</p><p><span class="qpc-hafs">﴿وَٱلۡأَنصَابُ﴾</span>: الحجارةُ التي يَذْبَحُون عندها تعظيمًا لها.</p><p><span class="qpc-hafs">﴿وَٱلۡأَزۡلَـٰمُ﴾</span>: القِداحُ التي يَسْتَقْسِمُون بها قبلَ الشُّروعِ في شيءٍ.</p><p><span class="qpc-hafs">﴿رِجۡسࣱ﴾</span>: إثمٌ وقَذَرٌ.</p></div>"
  5,91,"<div class=ar lang=ar></div>"
  5,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَوَلَّيۡتُمۡ﴾</span>: أعْرَضْتُم.</p></div>"
  5,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُنَاحࣱ﴾</span>: حَرَجٌ في شُرْبِهم الخمرَ قبلَ تحريمِها.</p></div>"
  5,94,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيَبۡلُوَنَّكُمُ﴾</span>: لَيختبرَنَّكم.</p><p><span class="qpc-hafs">﴿لِيَعۡلَمَ ٱللَّهُ﴾</span>: عِلْمًا ظاهرًا للخَلْقِ.</p><p><span class="qpc-hafs">﴿ٱعۡتَدَىٰ﴾</span>: تجاوزَ حدودَ اللهِ.</p></div>"
  5,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حُرُمࣱ﴾</span>: مُحْرِمُون بحَجٍّ أو عُمْرَةٍ.</p><p><span class="qpc-hafs">﴿مِّثۡلُ مَا قَتَلَ مِنَ ٱلنَّعَمِ﴾</span>: يَذْبَحُ مثلَ ذلك الصيدِ من بهيمةِ الأنعامِ: الإبلِ، أو البقرِ، أو الغنمِ.</p><p><span class="qpc-hafs">﴿ٱلۡكَعۡبَةِ﴾</span>: الحَرَمِ.</p><p><span class="qpc-hafs">﴿طَعَامُ مَسَـٰكِينَ﴾</span>: يَشْتري بقيمةِ المِثْل من النَّعَمِ طعامًا يُهديه لفقراءِ الحَرَمِ.</p><p><span class="qpc-hafs">﴿عَدۡلُ ذَ ٰ⁠لِكَ﴾</span>: ما عادَلَه من غيرِ جِنْسِه، فيصومُ بدَلَ الإطعامِ يومًا عن كل نصفِ صاعٍ. والجاني مُخَيَّرٌ بين الأنواعِ المذكورة.</p><p><span class="qpc-hafs">﴿وَبَالَ أَمۡرِهِۦ﴾</span>: عاقبةَ فِعْلهِ.</p><p><span class="qpc-hafs">﴿سَلَفَ﴾</span>: مضى قبلَ التحريمِ.</p></div>"