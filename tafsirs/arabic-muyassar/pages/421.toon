quran[8]{c,v,t}:
  33,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَضَىٰ نَحۡبَهُۥ﴾</span>: وفّى بِنَذْرِهِ ونالَ الشَّهادَةَ.</p><p><span class="qpc-hafs">﴿وَمَا بَدَّلُواْ تَبۡدِيلࣰا﴾</span>: وما غَيَّرُوا عَهْدَ اللهِ، بل ثَبَتُوا عَلَيهِ.</p></div>"
  33,24,""
  33,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِغَيۡظِهِمۡ﴾</span>: أي: مُتَلَبِّسين بِغَيظِهِم وغَضَبِهِم.</p></div>"
  33,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَـٰهَرُوهُم﴾</span>: أعانُوهُم.</p><p><span class="qpc-hafs">﴿مِن صَيَاصِيهِمۡ﴾</span>: مِن حُصُونِهِم ومَعاقِلِهِم.</p><p><span class="qpc-hafs">﴿وَقَذَفَ﴾</span>: وألْقى.</p><p><span class="qpc-hafs">﴿ٱلرُّعۡبَ﴾</span>: الخوفَ الشَّدِيدَ.</p><p><span class="qpc-hafs">﴿فَرِيقࣰا تَقۡتُلُونَ﴾</span>: وهم الرِّجالُ.</p><p><span class="qpc-hafs">﴿وَتَأۡسِرُونَ فَرِيقࣰا﴾</span>: وهم النِّساءُ والذُّرِّيَّةُ.</p></div>"
  33,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّمۡ تَطَـُٔوهَا﴾</span>: لم تَدْخُلُوها.</p></div>"
  33,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُمَتِّعۡكُنَّ﴾</span>: أُعْطِكُنَّ المُتْعَةَ بِشيءٍ مِنَ الدُّنيا.</p><p><span class="qpc-hafs">﴿وَأُسَرِّحۡكُنَّ﴾</span>: أفارِقْكُنَّ بالطَّلاقِ.</p></div>"
  33,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَعَدَّ﴾</span>: هَيَّأَ.</p><p><span class="qpc-hafs">﴿أَجۡرًا﴾</span>: ثوابًا.</p></div>"
  33,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِفَـٰحِشَةࣲ مُّبَيِّنَةࣲ﴾</span>: بمَعْصِيةٍ ظاهِرةِ القُبْحِ.</p><p><span class="qpc-hafs">﴿يَسِيرࣰا﴾</span>: هَيِّنًا.</p></div>"