quran[29]{c,v,t}:
81,1," <q>﴿كُوِّرَتۡ﴾</q>: لُفَّتْ، وذَهَبَ ضَوْءُها. "
81,2," <q>﴿ٱنكَدَرَتۡ﴾</q>: تَناثَرَتْ، فَذَهَبَ نُورُها. "
81,3," <q>﴿سُيِّرَتۡ﴾</q>: سُيِّرَتْ عن وجْهِ الأرْضِ فَصارَتْ هَباءً. "
81,4," <q>﴿ٱلۡعِشَارُ﴾</q>: النُوقُ الحوامِلُ. <q>﴿عُطِّلَتۡ﴾</q>: تُرِكَتْ وأُهْمِلَتْ. "
81,5," <q>﴿ٱلۡوُحُوشُ﴾</q>: الحيواناتُ الوَحْشِيِّةُ. <q>﴿حُشِرَتۡ﴾</q>: جُمِعَتْ واخْتَلَطَتْ، لِيَقْتَصَّ اللهُ مِن بَعْضِها لِبَعْضٍ. "
81,6," <q>﴿سُجِّرَتۡ﴾</q>: أُوقِدَتْ. "
81,7," <q>﴿زُوِّجَتۡ﴾</q>: قُرِنَتْ بأَمثالِها. "
81,8," <q>﴿ٱلۡمَوۡءُۥدَةُ﴾</q>: الطِّفْلةُ المدفُونةُ حَيَةً. <q>﴿سُئِلَتۡ﴾</q>: سُؤالَ تَطْيِيبٍ لها ولَومٍ لِوائِدِها. "
  81,9,""
81,10," <q>﴿ٱلصُّحُفُ﴾</q>: صُحُفُ الأَعْمالِ. <q>﴿نُشِرَتۡ﴾</q>: عُرِضَتْ. "
81,11," <q>﴿كُشِطَتۡ﴾</q>: أُزِيلَتْ مِن مَّكانِها. "
81,12," <q>﴿سُعِّرَتۡ﴾</q>: أُوقِدَتْ. "
81,13," <q>﴿أُزۡلِفَتۡ﴾</q>: قُرِّبَتْ مِن أهْلِها. "
81,14," <q>﴿أَحۡضَرَتۡ﴾</q>: قَدَّمَتْ من خَيرٍ أو شَرٍّ. "
81,15," <q>﴿بِٱلۡخُنَّسِ﴾</q>: بِالنُّجُومِ المُخْتَفِيَةِ أنْوارُها نهارًا. "
81,16," <q>﴿ٱلۡجَوَارِ﴾</q>: الجارِيةِ. <q>﴿ٱلۡكُنَّسِ﴾</q>: المسْتَتِرَةِ في أبْراجِها. "
81,17," <q>﴿عَسۡعَسَ﴾</q>: أقْبَلَ بِظَلامِهِ. "
81,18," <q>﴿تَنَفَّسَ﴾</q>: ظَهَرَ ضِياؤُه. "
81,19," <q>﴿إِنَّهُۥ﴾</q>: إنَّ القُرآنَ. <q>﴿رَسُولࣲ كَرِيمࣲ﴾</q>: هو جِبْرِيلُ -عَلَيه السَّلامُ-. "
81,20," <q>﴿ذِي ٱلۡعَرۡشِ﴾</q>: اللهِ. <q>﴿مَكِينࣲ﴾</q>: صاحبِ مَكانَةٍ رَفِيعَةٍ. "
81,21," <q>﴿ثَمَّ﴾</q>: هُناكَ. <q>﴿أَمِينࣲ﴾</q>: مُؤْتَمَنٍ على الوَحْيِ الَّذِي يَنْزِلُ بِه. "
81,22," <q>﴿صَاحِبُكُم﴾</q>: مُحَمَّدٌ ﷺ الَّذِي تَعْرِفُونَهُ. "
81,23," <q>﴿وَلَقَدۡ رَءَاهُ﴾</q>: ولَقَدْ رَأى مُحَمَّدٌ جِبْرِيلَ. <q>﴿بِٱلۡأُفُقِ ٱلۡمُبِينِ﴾</q>: بالأُفُقِ العَظِيمِ. "
81,24," <q>﴿عَلَى ٱلۡغَيۡبِ﴾</q>: بِتَبْلِيغ الوَحْيِ. <q>﴿بِضَنِينࣲ﴾</q>: ببَخِيلٍ. "
81,25," <q>﴿رَّجِيمࣲ﴾</q>: مَطْرُودٍ منِ رَّحْمَةِ اللهِ. "
81,26," <q>﴿فَأَيۡنَ تَذۡهَبُونَ﴾</q>: فَأَينَ تَذْهَبُ بِكُم عُقُولُكُم فَي التَّكْذِيبِ بالقُرآنِ بَعْدَ هذِه الحُجَجِ القاطِعَةِ؟ "
81,27," <q>﴿ذِكۡرࣱ﴾</q>: مَوعِظَةٌ. "
81,28," <q>﴿يَسۡتَقِيمَ﴾</q>: على الحقِّ والإيمانِ. "
  81,29,""
