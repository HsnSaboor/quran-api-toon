quran[14]{c,v,t}:
  106,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِإِيلَـٰفِ قُرَيۡشٍ﴾</span>: اعْجَبُوا لِعادَةِ قُرَيشٍ. وقُرِيشٌ: اسمُ قَبِيلةٍ.</p></div>"
  106,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِۦلَـٰفِهِمۡ رِحۡلَةَ ٱلشِّتَآءِ وَٱلصَّيۡفِ﴾</span>: تَعَوُّدِهِم عَلى انْتِظامِ رِحْلَتَيهِم في الشِّتاءِ إلى «اليمن»، وفي الصَّيفِ إلى «الشّامِ». والرِّحْلةُ: اسْمٌ للارْتِحالِ.</p></div>"
  106,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا ٱلۡبَيۡتِ﴾</span>: هُوَ الكَعْبَةُ.</p></div>"
  106,4,"<div class=ar lang=ar></div>"
  107,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلدِّينِ﴾</span>: بالبَعْثِ والجزاءِ.</p></div>"
  107,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَدُعُّ ٱلۡيَتِيمَ﴾</span>: يَدفعُ اليتيمَ بِعُنفٍ.</p></div>"
  107,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ﴾</span>: ولا يَحُضُّ غَيرَهُ عَلى إطْعامِ المِسْكِينِ.</p></div>"
  107,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَوَيۡلࣱ﴾</span>: فَعَذابٌ شَدِيدٌ.</p></div>"
  107,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَاهُونَ﴾</span>: لاهُونَ، لا يُقيمُونَها على وجْهِهِا، ولا يُؤَدُّونَها في وقْتِها.</p></div>"
  107,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلَّذِينَ هُمۡ يُرَآءُونَ﴾</span>: الَّذِين هُم يَعْمَلُونَ الخيرَ مُراءاةً للنّاسِ.</p></div>"
  107,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَمۡنَعُونَ ٱلۡمَاعُونَ﴾</span>: ويَمْنَعُونَ إعارَةَ ما لا تَضُرُّ إعارَتُهُ مِنَ الآنِيةِ وغَيرِها.</p></div>"
  108,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡكَوۡثَرَ﴾</span>: الخيرَ الكَثِيرَ في الدُّنيا والآخِرَةِ، ومِن ذَلِكَ نَهرُ الكَوْثَرِ في الجنَّةِ.</p></div>"
  108,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱنۡحَرۡ﴾</span>: واذْبَحْ ذَبيحَتكَ للهِ.</p></div>"
  108,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَانِئَكَ﴾</span>: مُبْغِضَكَ.</p><p><span class="qpc-hafs">﴿هُوَ ٱلۡأَبۡتَرُ﴾</span>: هُوَ المُنْقَطِعُ أثَرُهُ، المقطُوعُ مِن كُلِّ خَيرٍ.</p></div>"