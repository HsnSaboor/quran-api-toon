quran[11]{c,v,t}:
  7,196,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِـِّۧيَ﴾</span>: مُتَوَلِّي حِفْظي وجميعِ أموري.</p><p><span class="qpc-hafs">﴿ٱلۡكِتَـٰبَ﴾</span>: القرآنَ العظيمَ.</p></div>"
  7,197,"<div class=ar lang=ar></div>"
  7,198,"7:197"
  7,199,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُذِ﴾</span>: اقْبَلْ أنتَ وأمَّتُكَ.</p><p><span class="qpc-hafs">﴿ٱلۡعَفۡوَ﴾</span>: ما تيسَّرَ من أخلاقِ الناسِ وأعمالِهم.</p><p><span class="qpc-hafs">﴿بِٱلۡعُرۡفِ﴾</span>: هو كلُّ ما عُرِفَ حُسْنُه في الشَّرْعِ والعَقْلِ.</p></div>"
  7,200,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنزَغَنَّكَ﴾</span>: يُصِيبَنَّك وسْوَسَةٌ.</p><p><span class="qpc-hafs">﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾</span>: فاستَجِرْ به والَجأْ إليه.</p></div>"
  7,201,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱتَّقَوۡاْ﴾</span>: خافُوا اللهَ بفِعْلِ أوامرِه وتَرْكِ نواهِيه.</p><p><span class="qpc-hafs">﴿طَـٰٓئِفࣱ مِّنَ ٱلشَّيۡطَـٰنِ﴾</span>: عارضٌ من وسْوَسَتِه.</p><p><span class="qpc-hafs">﴿تَذَكَّرُواْ﴾</span>: عقابَ اللهِ وثوابَه.</p><p><span class="qpc-hafs">﴿مُّبۡصِرُونَ﴾</span>: مُنْتَهُون عن المعصيةِ على بَصيرةٍ.</p></div>"
  7,202,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِخۡوَ ٰ⁠نُهُمۡ﴾</span>: وإخوانُ الشَّياطين.</p><p><span class="qpc-hafs">﴿يَمُدُّونَهُمۡ﴾</span>: يَزيدُونهم.</p><p><span class="qpc-hafs">﴿ٱلۡغَيِّ﴾</span>: الضَّلالِ.</p><p><span class="qpc-hafs">﴿لَا يُقۡصِرُونَ﴾</span>: لا يَكُفُّون عن الإغواءِ.</p></div>"
  7,203,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِـَٔايَةࣲ﴾</span>: بعلامةٍ دالَّةٍ على صِدْقِك.</p><p><span class="qpc-hafs">﴿ٱجۡتَبَيۡتَهَا﴾</span>: اختلَقْتَها واخترَعْتَها.</p><p><span class="qpc-hafs">﴿هَـٰذَا﴾</span>: أي القرآنُ المجيدُ.</p><p><span class="qpc-hafs">﴿بَصَآئِرُ﴾</span>: جمعُ بَصيرةٍ، وهي الحُجَجُ والبراهينُ التي يُسْتَبصَرُ بها.</p><p><span class="qpc-hafs">﴿وَهُدࣰى﴾</span>: بيانٌ يَهْدي المؤمنين.</p></div>"
  7,204,"<div class=ar lang=ar></div>"
  7,205,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَضَرُّعࣰا﴾</span>: تَذَلُّلًا وخُضوعًا.</p><p><span class="qpc-hafs">﴿وَخِيفَةࣰ﴾</span>: خائفًا منه تعالى.</p><p><span class="qpc-hafs">﴿وَدُونَ ٱلۡجَهۡرِ﴾</span>: متوسِّطًا بين الَجهْرِ والإسرارِ.</p><p><span class="qpc-hafs">﴿بِٱلۡغُدُوِّ﴾</span>: أولِ النهارِ.</p><p><span class="qpc-hafs">﴿وَٱلۡـَٔاصَالِ﴾</span>: جمعُ أصيلٍ، وهو من العَصْرِ إلى المغربِ، والمرادُ: آخرُ النهارِ.</p></div>"
  7,206,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُسَبِّحُونَهُۥ﴾</span>: يُنَزِّهُونه عن كلِّ ما لا يليقُ به.</p></div>"