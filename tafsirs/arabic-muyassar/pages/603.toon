quran[14]{c,v,t}:
  109,1,"<div class=ar lang=ar></div>"
  109,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَآ أَعۡبُدُ مَا تَعۡبُدُونَ﴾</span>: لا تَحصُلُ منِّي عِبادَةُ ما تَعْبُدُونَ مِنَ الأصْنامِ والآلِهَةَ الزّائِفَةِ.</p></div>"
  109,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَنتُمۡ عَـٰبِدُونَ مَآ أَعۡبُدُ﴾</span>: وما أنتُم عابِدُونَ في المسْتَقْبَلِ ما أعْبُدُ مِن إلهٍ واحدٍ، هُوَ اللهُ رَبُّ العالمَينَ المُسْتَحِقُّ وحْدَهُ لِلعِبادةِ.</p></div>"
  109,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَنَا۠ عَابِدࣱ مَّا عَبَدتُّمۡ﴾</span>: ولا أنا عابِدٌ ما عبدتُم مِنَ الأصْنامِ والآلِهَةِ الباطِلةِ فيما مَضى مِنَ الأزْمانِ.</p></div>"
  109,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَآ أَنتُمۡ عَـٰبِدُونَ مَآ أَعۡبُدُ﴾</span>: ولا أنتُم عابِدُونَ مُسْتَقْبلًا ما أعْبُدُ.</p></div>"
  109,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَكُمۡ دِينُكُمۡ﴾</span>: الَّذِي أصْرَرْتُم على اتِّباعِهِ، يختصُّ بِكُم وأنا بَرِيءٌ مِنهُ.</p><p><span class="qpc-hafs">﴿وَلِيَ دِينِ﴾</span>: الَّذِي أنا مُخْتَصٌّ بِهِ لا تَشْرَكُونِي فِيه، ولَيسَ في الآيةِ إقْرارٌ لِدِينِهِم.</p></div>"
  110,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَصۡرُ ٱللَّهِ﴾</span>: النَّصْرُ عَلى كُفّارِ قُرَيشٍ.</p><p><span class="qpc-hafs">﴿وَٱلۡفَتۡحُ﴾</span>: وتَمَّ لَكَ فَتْحُ «مَكَّةَ».</p></div>"
  110,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفۡوَاجࣰا﴾</span>: جماعات جَماعاتٍ.</p></div>"
  110,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَسَبِّحۡ﴾</span>: فنزِّهْ رَبَّكَ.</p><p><span class="qpc-hafs">﴿بِحَمۡدِ رَبِّكَ﴾</span>: مُتلَبِّسًا بِحَمْدِ رَبّكَ.</p></div>"
  111,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَّتۡ يَدَآ أَبِي لَهَبࣲ﴾</span>: خَسِرتْ يدا أبي لَهَبٍ وشَقِيَ بِإيذائِهِ رَسُولَ اللهِ مُحَمَّدًا ﷺ.</p><p><span class="qpc-hafs">﴿وَتَبَّ﴾</span>: وقَد تَحقَّقَ خُسْرانُ أبي لَهَبٍ.</p></div>"
  111,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَآ أَغۡنَىٰ عَنۡهُ مَالُهُۥ﴾</span>: ما دَفعَ عنه مالُه، ولَن يَرُدَّ عنْهُ شَيئًا مِن عَذابِ اللهِ إذا نَزَلَ بِهِ.</p><p><span class="qpc-hafs">﴿وَمَا كَسَبَ﴾</span>: وكَسْبُه الَّذِي جَمَعَ.</p></div>"
  111,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَيَصۡلَىٰ﴾</span>: سَيَدْخُلُ.</p><p><span class="qpc-hafs">﴿ذَاتَ لَهَبࣲ﴾</span>: مُتَأَجِّجَةً.</p></div>"
  111,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱمۡرَأَتُهُۥ حَمَّالَةَ ٱلۡحَطَبِ﴾</span>: هُوَ وامْرأتُه الَّتِي كانتْ تَحْمِلُ الشَّوكَ، فَتَطْرَحُهُ في طَرِيقِ النَّبِيِّ ﷺ؛ لِأذِيَّتِهِ.</p></div>"
  111,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي جِيدِهَا﴾</span>: في عُنُقِها.</p><p><span class="qpc-hafs">﴿مِّن مَّسَدِۭ﴾</span>: حَبْلٌ مُحْكَمُ الفَتْلِ مِن لِيفٍ شَدِيدٍ خَشِنٍ، تُرْفَعُ بِهِ في نارِ جَهَنَّمَ، ثُمَّ تُرْمى إلى أسْفَلِها.</p></div>"