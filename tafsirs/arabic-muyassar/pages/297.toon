quran[7]{c,v,t}:
  18,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡبِرۡ نَفۡسَكَ﴾</span>: احبِسْها في طاعةِ اللهِ.</p><p><span class="qpc-hafs">﴿بِٱلۡغَدَوٰةِ وَٱلۡعَشِيِّ﴾</span>: أولِ النهار وآخرِه، والمرادُ دوامُ العبادةِ.</p><p><span class="qpc-hafs">﴿وَلَا تَعۡدُ عَيۡنَاكَ عَنۡهُمۡ﴾</span>: لا تَصْرِفْ نَظَرَكَ عنهم إلى غيرِهِم.</p><p><span class="qpc-hafs">﴿أَغۡفَلۡنَا قَلۡبَهُۥ﴾</span>: جَعَلْناه غافلًا.</p><p><span class="qpc-hafs">﴿فُرُطࣰا﴾</span>: ضَياعًا وهَلاكًا ومُتَجاوِزًا فيه الاعتدالَ.</p></div>"
  18,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: ما جئتكُم به هو الحقُّ.</p><p><span class="qpc-hafs">﴿فَمَن شَآءَ فَلۡيُؤۡمِن وَمَن شَآءَ فَلۡيَكۡفُرۡ﴾</span>: تهديدٌ ووعيدٌ لمن اختارَ الكفرَ بعد بيانِ الحقِّ ووُضوحِه.</p><p><span class="qpc-hafs">﴿سُرَادِقُهَا﴾</span>: سُورُها المحيطُ بها.</p><p><span class="qpc-hafs">﴿كَٱلۡمُهۡلِ﴾</span>: ماءٌ غليظٌ كالمُنْصَهِر من المعادنِ، أو كعَكَرِ الزيتِ، بَلَغَ منتهى الحَرارةِ.</p><p><span class="qpc-hafs">﴿مُرۡتَفَقًا﴾</span>: منزِلًا ومُقامًا.</p></div>"
  18,30,"<div class=ar lang=ar></div>"
  18,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتُ عَدۡنࣲ﴾</span>: جِنانُ إقامةٍ دائمةٍ.</p><p><span class="qpc-hafs">﴿يُحَلَّوۡنَ﴾</span>: يُزَيَّنُون.</p><p><span class="qpc-hafs">﴿سُندُسࣲ﴾</span>: رقيقِ الحَريرِ.</p><p><span class="qpc-hafs">﴿وَإِسۡتَبۡرَقࣲ﴾</span>: ما غَلُظَ من الحريرِ وثَخُنَ.</p><p><span class="qpc-hafs">﴿ٱلۡأَرَآئِكِ﴾</span>: الأَسِرَّةِ المزيَّنَةِ بفاخِرِ السَّتائرِ.</p></div>"
  18,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱضۡرِبۡ لَهُم﴾</span>: واذكُرْ للمؤمنين والكافرين المستكبرِين وأَوْرِدْ لهم.</p><p><span class="qpc-hafs">﴿جَنَّتَيۡنِ﴾</span>: حديقتَين.</p><p><span class="qpc-hafs">﴿وَحَفَفۡنَـٰهُمَا بِنَخۡلࣲ﴾</span>: جَعَلْنا النَّخْلَ محيطًا بكلٍّ منهما.</p></div>"
  18,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاتَتۡ أُكُلَهَا﴾</span>: أثمرَتْ ثمرَها الذي يُؤْكَلُ.</p><p><span class="qpc-hafs">﴿وَلَمۡ تَظۡلِم مِّنۡهُ﴾</span>: ولم تَنْقُصْ من إثمارها عَبْرَ السنينَ.</p></div>"
  18,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهُۥ ثَمَرࣱ﴾</span>: لصاحبِ البستانينِ أنواعٌ من المال سِوى حديقتَيه.</p><p><span class="qpc-hafs">﴿نَفَرࣰا﴾</span>: أولادًا وخَدَمًا وأعوانًا.</p></div>"