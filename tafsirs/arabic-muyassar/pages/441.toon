quran[15]{c,v,t}:
  36,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَصۡحَـٰبَ ٱلۡقَرۡيَةِ﴾</span>: أهْلَ القَرْيَةِ، وهي «أنْطاكِيَةُ».</p></div>"
  36,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَزَّزۡنَا بِثَالِثࣲ﴾</span>: أي: قوَّيناهُما بِرَسُولٍ ثالِثٍ.</p></div>"
  36,15,"<div class=ar lang=ar></div>"
  36,16,"36:15"
  36,17,"36:15"
  36,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَطَيَّرۡنَا بِكُمۡ﴾</span>: تَشاءَمْنا بِكُم.</p><p><span class="qpc-hafs">﴿لَنَرۡجُمَنَّكُمۡ﴾</span>: لَنَقْتُلَنَّكُم رَمْيًا بالِحجارَةِ.</p></div>"
  36,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَـٰٓئِرُكُم مَّعَكُمۡ﴾</span>: شُؤْمُكُم مَعَكُم، الذي هو كُفْرُكُم وشِرْكُكُم.</p></div>"
  36,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَقۡصَا ٱلۡمَدِينَةِ﴾</span>: مِن مَّكانٍ بَعِيدٍ فِيها.</p></div>"
  36,21,"<div class=ar lang=ar></div>"
  36,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطَرَنِي﴾</span>: خَلَقَنِي.</p></div>"
  36,23,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا يُنقِذُونِ﴾</span>: لا يُنَجُّونَنِي مِمّا أنافِيه.</p></div>"
  36,24,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ضَلَـٰلࣲ مُّبِينٍ﴾</span>: خَطَأٍ ظاهِرٍ.</p></div>"
  36,25,"<div class=ar lang=ar></div>"
  36,26,"36:25"
  36,27,"36:25"