quran[15]{c,v,t}:
36,13," <q>﴿أَصۡحَـٰبَ ٱلۡقَرۡيَةِ﴾</q>: أهْلَ القَرْيَةِ، وهي «أنْطاكِيَةُ». "
36,14," <q>﴿فَعَزَّزۡنَا بِثَالِثࣲ﴾</q>: أي: قوَّيناهُما بِرَسُولٍ ثالِثٍ. "
  36,15,""
  36,16,""
  36,17,""
36,18," <q>﴿تَطَيَّرۡنَا بِكُمۡ﴾</q>: تَشاءَمْنا بِكُم. <q>﴿لَنَرۡجُمَنَّكُمۡ﴾</q>: لَنَقْتُلَنَّكُم رَمْيًا بالِحجارَةِ. "
36,19," <q>﴿طَـٰٓئِرُكُم مَّعَكُمۡ﴾</q>: شُؤْمُكُم مَعَكُم، الذي هو كُفْرُكُم وشِرْكُكُم. "
36,20," <q>﴿أَقۡصَا ٱلۡمَدِينَةِ﴾</q>: مِن مَّكانٍ بَعِيدٍ فِيها. "
  36,21,""
36,22," <q>﴿فَطَرَنِي﴾</q>: خَلَقَنِي. "
36,23," <q>﴿وَلَا يُنقِذُونِ﴾</q>: لا يُنَجُّونَنِي مِمّا أنافِيه. "
36,24," <q>﴿ضَلَـٰلࣲ مُّبِينٍ﴾</q>: خَطَأٍ ظاهِرٍ. "
  36,25,""
  36,26,""
  36,27,""
