quran[7]{c,v,t}:
  62,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُودِيَ﴾</span>: نادى المؤَذِّنُ.</p><p><span class="qpc-hafs">﴿فَٱسۡعَوۡاْ﴾</span>: فامْضُوا وأَقْبِلُوا إلَيها.</p><p><span class="qpc-hafs">﴿ذِكۡرِ ٱللَّهِ﴾</span>: الموعظةِ في خُطْبَةِ الإمامِ.</p><p><span class="qpc-hafs">﴿وَذَرُواْ﴾</span>: واتْرُكُوا.</p></div>"
  62,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱبۡتَغُواْ مِن فَضۡلِ ٱللَّهِ﴾</span>: واطْلُبُوا مِن رِزْقِ اللهِ.</p><p><span class="qpc-hafs">﴿تُفۡلِحُونَ﴾</span>: تَفُوزُونَ بِخَيرَيِ الدُّنيا والآخِرَةِ.</p></div>"
  62,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَهۡوًا﴾</span>: صارِفًا عَنِ الصَّلاةِ.</p><p><span class="qpc-hafs">﴿ٱنفَضُّوٓاْ﴾</span>: تَفَرَّقُوا.</p><p><span class="qpc-hafs">﴿قَآئِمࣰا﴾</span>: أي: عَلى الِمنْبَرِ.</p></div>"
  63,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُنَـٰفِقُونَ﴾</span>: جَمْعُ مُنافِقٍ، وهو الَّذِي يُظْهِرُ الإيمانَ ويُسِرُّ الكُفْرَ.</p></div>"
  63,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُنَّةࣰ﴾</span>: وِقايةً لَهُم مِنَ العَذابِ.</p><p><span class="qpc-hafs">﴿فَصَدُّواْ﴾</span>: مَنَعُوا أنْفُسَهُم ومَنَعُوا النّاسَ.</p><p><span class="qpc-hafs">﴿سَآءَ﴾</span>: بِئْسَ.</p></div>"
  63,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَطُبِعَ﴾</span>: فَخُتِم.</p><p><span class="qpc-hafs">﴿لَا يَفۡقَهُونَ﴾</span>: لا يَفْهَمُونَ ولا يُدْرِكُونَ حُجَجَ الإيمانِ.</p></div>"
  63,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَأَيۡتَهُمۡ﴾</span>: نَظَرْتَ إلَيهِم.</p><p><span class="qpc-hafs">﴿تُعۡجِبُكَ أَجۡسَامُهُمۡ﴾</span>: تُعْجِبُكَ هَيْئاتُهُم.</p><p><span class="qpc-hafs">﴿تَسۡمَعۡ﴾</span>: تُصْغِ.</p><p><span class="qpc-hafs">﴿خُشُبࣱ مُّسَنَّدَةࣱ﴾</span>: الأَخْشابُ المُلْقاةُ على الحائِطِ، فلا نَفْعَ فِيها لِأَحَدٍ.</p><p><span class="qpc-hafs">﴿صَيۡحَةٍ﴾</span>: صَوْتٍ عالٍ.</p><p><span class="qpc-hafs">﴿عَلَيۡهِمۡ﴾</span>: واقِعًا عَلَيهِم، وضارًّا بِهِم.</p><p><span class="qpc-hafs">﴿قَـٰتَلَهُمُ ٱللَّهُ﴾</span>: طَرَدَهُم مِن رَّحْمتِهِ.</p><p><span class="qpc-hafs">﴿أَنَّىٰ﴾</span>: كَيفَ.</p><p><span class="qpc-hafs">﴿يُؤۡفَكُونَ﴾</span>: يُصْرَفُونَ عَنِ الحقِّ إلى الباطِلِ؟</p></div>"