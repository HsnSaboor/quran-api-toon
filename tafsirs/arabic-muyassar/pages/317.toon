quran[11]{c,v,t}:
  20,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنۡ أَسۡرِ﴾</span>: أنِ اخْرُجْ ليلًا بِعِبادِي.</p><p><span class="qpc-hafs">﴿فَٱضۡرِبۡ لَهُمۡ﴾</span>: فاجْعَلْ لهم.</p><p><span class="qpc-hafs">﴿يَبَسࣰا﴾</span>: يابسًا لا ماءٌ فِيها ولا طِينٌ.</p><p><span class="qpc-hafs">﴿لَّا تَخَـٰفُ دَرَكࣰا﴾</span>: لا تخافُ مِن فِرْعَونَ وجُنُودِهِ أن يَلْحَقَ بكُم فيُدْرِكَكُم.</p><p><span class="qpc-hafs">﴿وَلَا تَخۡشَىٰ﴾</span>: ولا تَخْشى مِنَ الغَرَقِ في البَحْرِ.</p></div>"
  20,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَغَشِيَهُم مِّنَ ٱلۡيَمِّ مَا غَشِيَهُمۡ﴾</span>: فَغَمَرَهُم مِن مّاءِ البَحْرِ ما لا يَعْلَمُ كُنهَه إلّا اللهُ.</p></div>"
  20,79,""
  20,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَنَّ﴾</span>: شيءٌ يُشْبِهُ الصَّمْغَ، طَعْمُه كالعَسَلِ.</p><p><span class="qpc-hafs">﴿وَٱلسَّلۡوَىٰ﴾</span>: طَيرٌ يُشْبِهُ السُّمانى.</p></div>"
  20,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَطۡغَوۡاْ فِيهِ﴾</span>: ولا تَحْمِلنَّكُم العافيةُ والسَّعَةُ في الرِّزقِ على تَجاوُزِ الحدِّ في العِصْيانِ.</p><p><span class="qpc-hafs">﴿فَيَحِلَّ عَلَيۡكُمۡ﴾</span>: فيَنْزِلَ بِكُم.</p><p><span class="qpc-hafs">﴿هَوَىٰ﴾</span>: هَلَكَ وخَسِرَ.</p></div>"
  20,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ ٱهۡتَدَىٰ﴾</span>: ثُمَّ التَزَمَ الهِدايةَ واسْتَقامَ عَلَيها.</p></div>"
  20,83,""
  20,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰٓ أَثَرِي﴾</span>: خَلْفي سَوفَ يَلْحَقُون بِي.</p><p><span class="qpc-hafs">﴿لِتَرۡضَىٰ﴾</span>: لِتَزْدادَ عَنِّي رِضًا.</p></div>"
  20,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَدۡ فَتَنَّا﴾</span>: قد ابتلينا.</p><p><span class="qpc-hafs">﴿وَأَضَلَّهُمُ﴾</span>: دَعاهُم إلى الضَّلالَةِ التي هِيَ عِبادةُ العِجْلِ.</p><p><span class="qpc-hafs">﴿ٱلسَّامِرِيُّ﴾</span>: مَنسُوبٌ إلى «قبيلةِ السّامِرَة» قيل: كان إسْرائِيليًا، وقيل: كانَ قِبْطيًا.</p></div>"
  20,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسِفࣰا﴾</span>: حَزِينًا كَئِيبًا.</p><p><span class="qpc-hafs">﴿وَعۡدًا حَسَنًا﴾</span>: أي: بإنزالِ التَّوراةِ.</p><p><span class="qpc-hafs">﴿ٱلۡعَهۡدُ﴾</span>: الزَّمانُ.</p><p><span class="qpc-hafs">﴿فَأَخۡلَفۡتُم مَّوۡعِدِي﴾</span>: خالفْتُم ما وعَدْتُّمُونِي مِن عِبادَةِ اللهِ وحْدَه.</p></div>"
  20,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِمَلۡكِنَا﴾</span>: باخْتِيارِنا.</p><p><span class="qpc-hafs">﴿أَوۡزَارࣰا﴾</span>: أثْقالًا.</p><p><span class="qpc-hafs">﴿مِّن زِينَةِ ٱلۡقَوۡمِ﴾</span>: مِن حُلِيِّ قومِ فِرْعَونَ.</p><p><span class="qpc-hafs">﴿فَقَذَفۡنَـٰهَا﴾</span>: فَأَلْقَينا الحُلِيَّ في النّارِ.</p><p><span class="qpc-hafs">﴿فَكَذَ ٰ⁠لِكَ أَلۡقَى ٱلسَّامِرِيُّ﴾</span>: أي: فَكَذَلِك ألْقى السّامِريُّ ما كان مَعَهُ مِن تُرْبَةِ حافِرِ فَرَسِ جِبْريلَ عليه السَّلامُ.</p></div>"