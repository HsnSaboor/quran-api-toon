quran[10]{c,v,t}:
  24,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّأُوْلِي ٱلۡأَبۡصَـٰرِ﴾</span>: لأصْحابِ العُقُولِ السَّلِيمةِ.</p></div>"
  24,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلَىٰ بَطۡنِهِۦ﴾</span>: كالحيّاتِ ونحوِها.</p><p><span class="qpc-hafs">﴿عَلَىٰ رِجۡلَيۡنِ﴾</span>: كالإنْسانِ.</p><p><span class="qpc-hafs">﴿عَلَىٰٓ أَرۡبَعࣲ﴾</span>: كالبهائِمِ ونحوِها.</p></div>"
  24,46,"<div class=ar lang=ar></div>"
  24,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَتَوَلَّىٰ﴾</span>: يُعرِضُ.</p></div>"
  24,48,"<div class=ar lang=ar></div>"
  24,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهُمُ ٱلۡحَقُّ﴾</span>: أي: في قَضاءِ النَّبيِّ ﷺ وحُكْمِهِ.</p><p><span class="qpc-hafs">﴿مُذۡعِنِينَ﴾</span>: مُسْرِعِينَ مُنْقادِينَ.</p></div>"
  24,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَّرَضٌ﴾</span>: أي: مِنَ النِّفاقِ.</p><p><span class="qpc-hafs">﴿ٱرۡتَابُوٓاْ﴾</span>: شَكُّوا.</p><p><span class="qpc-hafs">﴿أَن يَحِيفَ﴾</span>: أن يَجُورَ.</p></div>"
  24,51,"<div class=ar lang=ar></div>"
  24,52,"24:51"
  24,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾</span>: أي: بأَيمانٍ مُغَلَّظَةٍ.</p><p><span class="qpc-hafs">﴿لَيَخۡرُجُنَّ﴾</span>: أي: لِلْجِهادِ.</p></div>"