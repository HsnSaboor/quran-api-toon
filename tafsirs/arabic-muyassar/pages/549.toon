quran[5]{c,v,t}:
  60,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡلِيَآءَ﴾</span>: خُلَصاءَ وأحبّاءَ.</p><p><span class="qpc-hafs">﴿تُلۡقُونَ إِلَيۡهِم بِٱلۡمَوَدَّةِ﴾</span>: أي: فتُخْبِرُونَهُم بِأَخْبارِ الرَّسُولِ ﷺ وسَرائِر المسْلِمِينَ.</p><p><span class="qpc-hafs">﴿وَٱبۡتِغَآءَ﴾</span>: طَلَبَ.</p><p><span class="qpc-hafs">﴿تُسِرُّونَ﴾</span>: تَنْقُلُونَ إلَيهِمُ الأخْبارَ سِرًّا.</p><p><span class="qpc-hafs">﴿سَوَآءَ ٱلسَّبِيلِ﴾</span>: طَرِيقَ الحقِّ والصَّوابِ.</p></div>"
  60,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَثۡقَفُوكُمۡ﴾</span>: إن يَظْفَرْ بِكُم هَؤلاءِ الَّذِينَ تُسِرُّونَ إليهِم بالمودّةِ.</p><p><span class="qpc-hafs">﴿وَيَبۡسُطُوٓاْ إِلَيۡكُمۡ﴾</span>: ويَمُدُّوا إلَيكُم.</p><p><span class="qpc-hafs">﴿بِٱلسُّوٓءِ﴾</span>: بالقَتْلِ، والسَّبْيِ، والشَّتْمِ.</p></div>"
  60,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَرۡحَامُكُمۡ﴾</span>: قراباتُكُم.</p><p><span class="qpc-hafs">﴿يَفۡصِلُ بَيۡنَكُمۡ﴾</span>: يَفْرُقُ اللهُ بَيْنَكُم، فيُدْخِلُ أهلَ طاعَتهِ الجَّنَةَ، وأهلَ مَعْصِيتِه النّارَ.</p></div>"
  60,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُسۡوَةٌ﴾</span>: قُدْوَةٌ</p><p><span class="qpc-hafs">﴿كَفَرۡنَا بِكُمۡ﴾</span>: أنْكَرْنا ما أنتُم عَلَيهِ مِنَ الكُفْرِ.</p><p><span class="qpc-hafs">﴿وَبَدَا﴾</span>: وظَهَر.</p><p><span class="qpc-hafs">﴿تَوَكَّلۡنَا﴾</span>: اعْتَمَدْنا.</p><p><span class="qpc-hafs">﴿أَنَبۡنَا﴾</span>: رَجَعْنا بالتَّوبَةِ</p><p><span class="qpc-hafs">﴿ٱلۡمَصِيرُ﴾</span>: المرْجِعُ يومَ القِيامَةِ.</p></div>"
  60,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: مَفْتُونِينَ بِتَسْلِيطِ الكُفّارِ عَلَينا.</p><p><span class="qpc-hafs">﴿ٱلۡعَزِيزُ﴾</span>: الَّذِي لا يُغالَبُ.</p><p><span class="qpc-hafs">﴿ٱلۡحَكِيمُ﴾</span>: في أفْعالِهِ وأَقْوالِهِ.</p></div>"