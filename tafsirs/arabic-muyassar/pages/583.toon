quran[25]{c,v,t}:
  78,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَفَازًا﴾</span>: فَوْزًا بِدُخُولِهِم الجنَّةَ.</p></div>"
  78,32,""
  78,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَوَاعِبَ﴾</span>: نَواهِدَ، أثْداؤُهنَّ مُرْتَفِعَةٌ لم تَتَدَلَّ.</p><p><span class="qpc-hafs">﴿أَتۡرَابࣰا﴾</span>: مُسْتَوِياتٍ في سِنٍّ واحِدةٍ.</p></div>"
  78,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دِهَاقࣰا﴾</span>: مَمْلُوءةً خَمْرًا.</p></div>"
  78,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّا يَسۡمَعُونَ فِيهَا لَغۡوࣰا﴾</span>: باطِلًا مِنَ القول.</p><p><span class="qpc-hafs">﴿وَلَا كِذَّ ٰ⁠بࣰا﴾</span>: ولا تَكْذِيبًا.</p></div>"
  78,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِسَابࣰا﴾</span>: كَثِيرًا كافيًا لَهُم.</p></div>"
  78,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَمۡلِكُونَ مِنۡهُ خِطَابࣰا﴾</span>: لا يَسْتَطِيعُونَ خِطابًا يُبَلِّغُونَهُ إلى اللهِ.</p></div>"
  78,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرُّوحُ﴾</span>: جِبْريِلُ.</p><p><span class="qpc-hafs">﴿صَفࣰّا﴾</span>: مُصْطَفِّينَ.</p><p><span class="qpc-hafs">﴿صَوَابࣰا﴾</span>: حَقًّا وسَدادًا.</p></div>"
  78,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡيَوۡمُ ٱلۡحَقُّ﴾</span>: الثابِتُ الَّذِي لا رَيْبَ في وُقُوعِهِ.</p><p><span class="qpc-hafs">﴿مَـَٔابًا﴾</span>: مَرْجِعًا.</p></div>"
  78,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَنذَرۡنَـٰكُمۡ﴾</span>: حَذَّرْناكُم.</p><p><span class="qpc-hafs">﴿مَا قَدَّمَتۡ يَدَاهُ﴾</span>: ما عَمِلَ من خِيرٍ أو شَرٍّ.</p><p><span class="qpc-hafs">﴿يَـٰلَيۡتَنِي كُنتُ تُرَ ٰ⁠بَۢا﴾</span>: فلم أُبْعَثْ.</p></div>"
  79,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلنَّـٰزِعَـٰتِ﴾</span>: أُقْسِمُ بالملائِكةِ الَّتِي تَنْزِعُ أرْواحَ الكُفّارِ.</p><p><span class="qpc-hafs">﴿غَرۡقࣰا﴾</span>: نَزْعًا غَرْقًا، أي مُغْرِقًا، أي تَنْزِعُ الأرْواحَ من أقاصِي الأَجْسادِ.</p></div>"
  79,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلنَّـٰشِطَـٰتِ﴾</span>: والملائِكَةِ الَّتِي تَقْبِضُ أرْواحَ المؤمِنِينَ.</p><p><span class="qpc-hafs">﴿نَشۡطࣰا﴾</span>: بِنَشاطٍ ورِفقٍ.</p></div>"
  79,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلسَّـٰبِحَـٰتِ﴾</span>: والملائِكَةِ الَّتِي تَسْبَحُ في نُزُولِها مِنَ السَّماءِ وصُعُودِها إليها.</p></div>"
  79,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلسَّـٰبِقَـٰتِ﴾</span>: فالملائِكَةِ الَّتِي تُسارِعُ إلى تَنِفيذِ أمْرِ اللهِ.</p></div>"
  79,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱلۡمُدَبِّرَ ٰ⁠تِ أَمۡرࣰا﴾</span>: فالملائِكةِ المُنَفِّذاتِ أمْرَ رَبِّها.</p></div>"
  79,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ﴾</span>: يومَ تَضْطَرِبُ الأرضُ بالنَّفْخَةِ الأُولى نَفْخَةِ الإماتَةِ.</p></div>"
  79,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَتۡبَعُهَا ٱلرَّادِفَةُ﴾</span>: تَتْبَعُها نَفْخَةٌ أُخْرى لِبَعْثِ الخَلْقِ.</p></div>"
  79,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قُلُوبࣱ﴾</span>: قُلُوبُ الكُفّارِ.</p><p><span class="qpc-hafs">﴿وَاجِفَةٌ﴾</span>: مُضْطَرِبَةٌ مِن شِدَّةِ الخوفِ.</p></div>"
  79,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَـٰشِعَةࣱ﴾</span>: ذَلِيلَةٌ مِن هَوْلِ ما تَرى.</p></div>"
  79,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَءِنَّا لَمَرۡدُودُونَ﴾</span>: أنُرَدُّ بَعْدَ مَوتِنا؟.</p><p><span class="qpc-hafs">﴿ٱلۡحَافِرَةِ﴾</span>: إلى أوَّلِ حالِنا، فَنَصِيرُ أحياءً بَعْدَ مَوْتِنا.</p></div>"
  79,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَءِذَا كُنَّا عِظَـٰمࣰا نَّخِرَةࣰ﴾</span>: أنُرَدُّ وقَدْ صِرْنا عِظامًا بالِيةً.</p></div>"
  79,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَرَّةٌ خَاسِرَةࣱ﴾</span>: رَجْعَةٌ خائِبةٌ كاذِبةٌ.</p></div>"
  79,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ﴾</span>: نَفْخَةٌ واحِدَةٌ.</p></div>"
  79,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بِٱلسَّاهِرَةِ﴾</span>: على وجْهِ الأَرْضِ.</p></div>"
  79,15,""