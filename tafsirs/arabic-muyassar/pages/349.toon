quran[14]{c,v,t}:
  23,105,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَايَـٰتِي﴾</span>: أي: آياتُ القُرآن.</p></div>"
  23,106,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شِقۡوَتُنَا﴾</span>: هي المَلَذّاتُ والشَّهَواتُ التي كُتِبَتْ عَلَينا في سابِقِ عِلْمِكَ وساقَتْنا إلى الشِّقاءِ.</p></div>"
  23,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإِنۡ عُدۡنَا﴾</span>: فَإن رَّجَعْنا إلى الضَّلالِ.</p></div>"
  23,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱخۡسَـُٔواْ فِيهَا﴾</span>: امْكُثُوا في النّارِ أذِلّاءَ صاغِرِينَ.</p></div>"
  23,109,"<div class=ar lang=ar></div>"
  23,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِخۡرِيًّا﴾</span>: مَهْزُوءًا بهم.</p></div>"
  23,111,"<div class=ar lang=ar></div>"
  23,112,"23:111"
  23,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡعَآدِّينَ﴾</span>: أي: المُتَمَكِّنِينَ مِن مَّعْرِفَةِ العَدَدِ مِنَ الملائِكَةِ أو مِنَ النّاسِ.</p></div>"
  23,114,"<div class=ar lang=ar></div>"
  23,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَبَثࣰا﴾</span>: لَعِبًا مِن غَيرِ فائِدةٍ ولاحِكْمَةٍ.</p></div>"
  23,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلِكُ﴾</span>: الَّذي يَحِقُّ لَهُ المُلْكُ على الإطْلاقِ</p><p><span class="qpc-hafs">﴿ٱلۡحَقُّ﴾</span>: الثّابِتُ الَّذي لا يَزُولُ.</p><p><span class="qpc-hafs">﴿ٱلۡعَرۡشِ﴾</span>: هو سَرِيرُ المُلْكِ الَّذي اسْتَوى عليه الرَّحمنُ، وتَحْمِلُه الملائِكةُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.</p></div>"
  23,117,"<div class=ar lang=ar></div>"
  23,118,"23:117"