quran[13]{c,v,t}:
  72,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱسۡتَمَعَ﴾</span>: لِتِلاوَتِي لِلْقُرآنِ.</p><p><span class="qpc-hafs">﴿نَفَرࣱ﴾</span>: جَماعَةٌ.</p><p><span class="qpc-hafs">﴿عَجَبࣰا﴾</span>: بَدِيعًا في بَلاغَتِهِ وأَحْكامِهِ.</p></div>"
  72,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِيٓ إِلَى ٱلرُّشۡدِ﴾</span>: يَدْعُو إلى الحقِّ.</p></div>"
  72,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَعَـٰلَىٰ﴾</span>: عَلَتْ وارْتَفَعَتْ.</p><p><span class="qpc-hafs">﴿جَدُّ رَبِّنَا﴾</span>: عَظَمَةُ رَبِّنا وجَلالُهُ.</p><p><span class="qpc-hafs">﴿صَـٰحِبَةࣰ﴾</span>: زَوْجةً.</p></div>"
  72,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَفِيهُنَا﴾</span>: إبْلِيسُ.</p><p><span class="qpc-hafs">﴿شَطَطࣰا﴾</span>: قَوْلًا بعِيدًا عَنِ الحقِّ والصَّوابِ.</p></div>"
  72,5,""
  72,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَعُوذُونَ﴾</span>: يَسْتَجِيرُونَ ويَلُوذُونَ.</p><p><span class="qpc-hafs">﴿فَزَادُوهُمۡ﴾</span>: فَزادَ رِجالُ الجِنِّ الإنسَ باسْتِعاذَتِهم بِهِم.</p><p><span class="qpc-hafs">﴿رَهَقࣰا﴾</span>: خَوْفًا.</p></div>"
  72,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنَّهُمۡ﴾</span>: وأَنَّ كُفارَ الإنْسِ.</p><p><span class="qpc-hafs">﴿ظَنُّواْ كَمَا ظَنَنتُمۡ﴾</span>: حَسِبُوا كما حَسِبْتُم -يا مَعْشرَ الِجنِّ-.</p><p><span class="qpc-hafs">﴿أَن لَّن يَبۡعَثَ ٱللَّهُ أَحَدࣰا﴾</span>: بَعْدَ الموتِ.</p></div>"
  72,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَمَسۡنَا ٱلسَّمَآءَ﴾</span>: طَلَبْنا بُلُوغَ السَّماءِ لاسْتِماعِ كَلامِ أهْلِها.</p><p><span class="qpc-hafs">﴿حَرَسࣰا شَدِيدࣰا﴾</span>: مَلائِكةً تَحْرُسُها.</p><p><span class="qpc-hafs">﴿وَشُهُبࣰا﴾</span>: جَمْعُ شِهابٍ، وهي النُّجُومُ الَّتِي كانتْ تُرْجَمُ بِها الشَّياطِينُ.</p></div>"
  72,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَقۡعُدُ مِنۡهَا مَقَـٰعِدَ﴾</span>: نَتَّخِذُ مِنَ السَّماءِ مَواضِعَ.</p><p><span class="qpc-hafs">﴿لِلسَّمۡعِ﴾</span>: لِنَسْتَمِعَ إلى أخْبارِها.</p><p><span class="qpc-hafs">﴿فَمَن يَسۡتَمِعِ ٱلۡـَٔانَ﴾</span>: فَمَن يُحاوِلِ الآنَ اسْتِراقَ السَّمْعِ.</p><p><span class="qpc-hafs">﴿شِهَابࣰا﴾</span>: شِهابًا بالمِرْصادِ، يُحْرِقُه ويُهْلِكُهُ.</p></div>"
  72,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿رَشَدࣰا﴾</span>: خَيرًا وهُدىً.</p></div>"
  72,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِنَّا دُونَ ذَ ٰ⁠لِكَ﴾</span>: ومِنّا قَومٌ دُونَ ذَلِكَ كُفّارٌ وفُسّاقٌ.</p><p><span class="qpc-hafs">﴿طَرَآئِقَ﴾</span>: فِرَقًا ومَذاهِبَ.</p><p><span class="qpc-hafs">﴿قِدَدࣰا﴾</span>: مخْتَلِفَةً.</p></div>"
  72,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَنَنَّآ﴾</span>: أيْقَنّا.</p><p><span class="qpc-hafs">﴿أَن لَّن نُّعۡجِزَ ٱللَّهَ فِي ٱلۡأَرۡضِ﴾</span>: أن لَن نَفُوتَ اللهَ إذا أرادَ بِنا أمْرًا فِي الأَرْضِ.</p><p><span class="qpc-hafs">﴿وَلَن نُّعۡجِزَهُۥ هَرَبࣰا﴾</span>: ولَن نسْتَطِيعَ أن نُفْلِتَ مِن عِقابِهِ هَرَبًا.</p></div>"
  72,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡهُدَىٰٓ﴾</span>: القُرآنَ.</p><p><span class="qpc-hafs">﴿بَخۡسࣰا﴾</span>: نُقْصانًا مِن حَسَناتِه.</p><p><span class="qpc-hafs">﴿رَهَقࣰا﴾</span>: ظُلمًا يَلْحَقُهُ بِزِيادةٍ في سَيِّئاتِهِ.</p></div>"