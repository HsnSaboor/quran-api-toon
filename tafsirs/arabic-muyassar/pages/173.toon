quran[8]{c,v,t}:
  7,171,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نَتَقۡنَا﴾</span>: اقتلَعْنا ورَفَعْنا.</p><p><span class="qpc-hafs">﴿ظُلَّةࣱ﴾</span>: سَحابةٌ تُظِلُّهم.</p><p><span class="qpc-hafs">﴿وَظَنُّوٓاْ﴾</span>: وأيقَنُوا.</p><p><span class="qpc-hafs">﴿وَاقِعُۢ بِهِمۡ﴾</span>: إن لم يقبَلُوا أحكامَ التوراةِ.</p><p><span class="qpc-hafs">﴿بِقُوَّةࣲ﴾</span>: بجِدٍّ واجتهادٍ.</p><p><span class="qpc-hafs">﴿وَٱذۡكُرُواْ مَا فِيهِ﴾</span>: بالعملِ بما فيه.</p></div>"
  7,172,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَخَذَ﴾</span>: استخرج.</p><p><span class="qpc-hafs">﴿وَأَشۡهَدَهُمۡ عَلَىٰٓ أَنفُسِهِمۡ﴾</span>: وقرَّرَهم -جميعًا- بتوحيدِه بما أوْدَعَه في فِطَرِهم.</p><p><span class="qpc-hafs">﴿أَن تَقُولُواْ﴾</span>: لئلا تقولوا.</p></div>"
  7,173,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَتُهۡلِكُنَا﴾</span>: أفتعذِّبُنا.</p><p><span class="qpc-hafs">﴿ٱلۡمُبۡطِلُونَ﴾</span>: الذين أبْطَلُوا أعمالهم بالإشراكِ بالله.</p></div>"
  7,174,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُفَصِّلُ﴾</span>: نبيِّنُ.</p></div>"
  7,175,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱتۡلُ﴾</span>: واقصُصْ.</p><p><span class="qpc-hafs">﴿نَبَأَ﴾</span>: خبرَ رجلٍ من بني إسرائيلَ.</p><p><span class="qpc-hafs">﴿ءَاتَيۡنَـٰهُ ءَايَـٰتِنَا﴾</span>: أتاه اللهُ علمًا ببعض الكتبِ المنزَّلَةِ.</p><p><span class="qpc-hafs">﴿فَٱنسَلَخَ مِنۡهَا﴾</span>: ثم كَفَرَ بها وجَعَلَها وراءَ ظهرِه.</p><p><span class="qpc-hafs">﴿فَأَتۡبَعَهُ ٱلشَّيۡطَـٰنُ﴾</span>: لَحِقه فأدركَه فصارَ قرينَه.</p><p><span class="qpc-hafs">﴿ٱلۡغَاوِينَ﴾</span>: الضالِّين الراسِخين في الضلالِ.</p></div>"
  7,176,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَرَفَعۡنَـٰهُ﴾</span>: لَرَفَعْنا قَدْرَه بالعلمِ والعملِ بها.</p><p><span class="qpc-hafs">﴿أَخۡلَدَ إِلَى ٱلۡأَرۡضِ﴾</span>: رَكَنَ إلى الدُّنيا، واطمأَنَّ بها.</p></div>"
  7,177,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَآءَ﴾</span>: قَبُحَ.</p><p><span class="qpc-hafs">﴿يَظۡلِمُونَ﴾</span>: بالتكذيب وأنواع المعاصي.</p></div>"
  7,178,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَن يَهۡدِ ٱللَّهُ﴾</span>: مَن يُوَفِّقْه للإيمانِ والعَمَلِ الصالحِ.</p></div>"