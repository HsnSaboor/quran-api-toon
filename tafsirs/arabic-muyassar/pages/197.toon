quran[7]{c,v,t}:
  9,62,"<div class=ar lang=ar></div>"
  9,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُحَادِدِ﴾</span>: يخالِفْ.</p></div>"
  9,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُنَبِّئُهُم﴾</span>: تُخَبِّرُهم.</p><p><span class="qpc-hafs">﴿بِمَا فِي قُلُوبِهِمۡ﴾</span>: بما يُضْمِرُونَه في قلوبِهم من الكفرِ.</p><p><span class="qpc-hafs">﴿مُخۡرِجࣱ مَّا تَحۡذَرُونَ﴾</span>: مُظْهِرٌ ما تَخافُونه من الفضيحةِ.</p></div>"
  9,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَئِن سَأَلۡتَهُمۡ﴾</span>: عَمّا قالوا من الطَّعْنِ في حَقِّك وحَقِّ أصحابِك.</p><p><span class="qpc-hafs">﴿نَخُوضُ وَنَلۡعَبُ﴾</span>: نتحَدَّثُ بكلامٍ لم نَقْصِدْ به الإساءةَ.</p></div>"
  9,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن نَّعۡفُ عَن طَآئِفَةࣲ مِّنكُمۡ﴾</span>: بالتوفيق للتوبةِ والإخلاصِ فيها.</p><p><span class="qpc-hafs">﴿نُعَذِّبۡ طَآئِفَةَۢ﴾</span>: بسبب تَرْكِ التوبةِ والإصرارِ على النِّفاقِ.</p></div>"
  9,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَعۡضُهُم مِّنۢ بَعۡضࣲ﴾</span>: أي: مُتَشابهون في صفةِ النِّفاقِ والبُعْدِ عن الإيمانِ.</p><p><span class="qpc-hafs">﴿بِٱلۡمُنكَرِ﴾</span>: بالكفرِ والمعاصي.</p><p><span class="qpc-hafs">﴿ٱلۡمَعۡرُوفِ﴾</span>: هو كلُّ ما عُرِفَ حُسْنُه في الشَّرعِ والعَقْلِ.</p><p><span class="qpc-hafs">﴿وَيَقۡبِضُونَ أَيۡدِيَهُمۡ﴾</span>: ويُمْسِكُون عن الإنفاقِ في طاعةِ اللهِ ومَرْضاتِه.</p><p><span class="qpc-hafs">﴿نَسُواْ ٱللَّهَ﴾</span>: تَرَكُوا طاعتَه وأوامرَه.</p><p><span class="qpc-hafs">﴿فَنَسِيَهُمۡ﴾</span>: فتركَهم من رحمتِه وثوابِه.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقُونَ﴾</span>: الخارجُون عن الإيمانِ والطاعة.</p></div>"
  9,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسۡبُهُمۡ﴾</span>: كافِيهم؛ عقابًا على كفرِهم.</p><p><span class="qpc-hafs">﴿وَلَعَنَهُمُ ٱللَّهُ﴾</span>: طَرَدَهم مِن رحمتِه.</p><p><span class="qpc-hafs">﴿مُّقِيمࣱ﴾</span>: دائمٌ لا ينقطعُ.</p></div>"