quran[21]{c,v,t}:
  26,40,""
  26,41,""
  26,42,""
  26,43,""
  26,44,""
26,45," <q>﴿تَلۡقَفُ﴾</q>: تَبْتَلِعُ بِسُرْعَةٍ. <q>﴿مَا يَأۡفِكُونَ﴾</q>: ما يَكْذِبُونَهُ ويُمَوِّهُونَهُ. "
  26,46,""
  26,47,""
  26,48,""
26,49," <q>﴿مِّنۡ خِلَـٰفࣲ﴾</q>: أي: بِقَطْعِ اليَدِ اليُمْنى والرِّجْلِ اليُسْرى أو عَكْسِ ذَلِك. <q>﴿وَلَأُصَلِّبَنَّكُمۡ﴾</q>: ولَأُبالِغَنَّ في شَدِّ أطْرافِكُم ورَبْطِ أجْسادِكُم على جُذُوعِ النَّخْلِ. "
26,50," <q>﴿لَا ضَيۡرَ﴾</q>: لا ضَرَرَ عَلَينا فِيما يُصِيبُنا. <q>﴿مُنقَلِبُونَ﴾</q>: راجِعُونَ. "
26,51," <q>﴿أَوَّلَ ٱلۡمُؤۡمِنِينَ﴾</q>: أي: مِن قَومِ فِرْعَونَ. "
26,52," <q>﴿أَنۡ أَسۡرِ بِعِبَادِيٓ﴾</q>: أي: اخْرُجْ بِهِم لَيْلًا. <q>﴿مُّتَّبَعُونَ﴾</q>: يَتَّبِعُكُم فِرْعَونُ وجُنُودُه. "
26,53," <q>﴿ٱلۡمَدَآئِنِ﴾</q>: المُدُنِ. <q>﴿حَـٰشِرِينَ﴾</q>: جامِعِينَ لِلْجَيشِ. "
26,54," <q>﴿لَشِرۡذِمَةࣱ﴾</q>: لَطائِفَةٌ حَقِيرَةٌ قَلِيلةُ العَدَدِ. "
26,55," <q>﴿لَنَا لَغَآئِظُونَ﴾</q>: لَمُغْضِبُونا بِخُرُوجِهِم مِن غَيْرِ إذْنٍ مِنّا. "
26,56," <q>﴿حَـٰذِرُونَ﴾</q>: مُتَيَقِّظُونَ. "
26,57," <q>﴿جَنَّـٰتࣲ﴾</q>: بَساتِينَ. "
  26,58,""
  26,59,""
26,60," <q>﴿مُّشۡرِقِينَ﴾</q>: وقْتَ شُرُوقِ الشَّمْسِ. "
