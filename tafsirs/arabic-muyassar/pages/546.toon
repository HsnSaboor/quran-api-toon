quran[6]{c,v,t}:
  59,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَآقُّواْ﴾</span>: خالفُوا.</p></div>"
  59,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِّينَةٍ﴾</span>: نَخْلَةٍ ذاتِ ثَمَرٍ طَيِّبٍ.</p><p><span class="qpc-hafs">﴿أُصُولِهَا﴾</span>: قَواعِدِها، والمرادُ: سُوقُ النَّخْلِ.</p><p><span class="qpc-hafs">﴿وَلِيُخۡزِيَ﴾</span>: ولِيُهِينَ.</p><p><span class="qpc-hafs">﴿ٱلۡفَـٰسِقِينَ﴾</span>: الكافِرِينَ، وهُمْ يَهُودُ بَنِي النَّضِيرِ.</p></div>"
  59,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أَفَآءَ ٱللَّهُ عَلَىٰ رَسُولِهِۦ﴾</span>: وما أعطاهُ اللهُ لِرَسُولِه مما يَظْفَرُ بِهِ الجيشُ مِن عَدُوِّهِم.</p><p><span class="qpc-hafs">﴿فَمَآ أَوۡجَفۡتُمۡ﴾</span>: فَما أرْكَضْتُم للإغارَةِ، وأَوْجَفَهُ: حَمَلَهُ عَلى السَّيرِ السَّرِيعِ.</p><p><span class="qpc-hafs">﴿رِكَابࣲ﴾</span>: الإبِلِ الَّتِي تُرْكَبُ.</p></div>"
  59,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقُرَىٰ﴾</span>: قُرىً فُتِحَتْ في عَهْدِ الرَّسُولِ ﷺ.</p><p><span class="qpc-hafs">﴿فَلِلَّهِ وَلِلرَّسُولِ﴾</span>: أي يُصْرَفُ في مصالِحِ المسْلِمِينَ.</p><p><span class="qpc-hafs">﴿وَلِذِي ٱلۡقُرۡبَىٰ﴾</span>: ولِذِي قَرابَةِ رَسُولِ اللهِ ﷺ، وهم بنُو هاشِم، وبنُو المطَّلِبِ.</p><p><span class="qpc-hafs">﴿وَٱلۡيَتَـٰمَىٰ﴾</span>: الأَطْفالِ الَّذِين ماتَ آباؤُهم، وهم دُونَ سِنِّ البُلُوغِ.</p><p><span class="qpc-hafs">﴿وَٱلۡمَسَـٰكِينِ﴾</span>: هم أهلُ الحاجةِ الَّذِينَ لا يَمْلِكُونَ ما يَسُدُّ حاجَتَهَم.</p><p><span class="qpc-hafs">﴿وَٱبۡنِ ٱلسَّبِيلِ﴾</span>: هو الغريبُ المسافِر الَّذِي نَفِدَتْ نَفَقَتُهُ.</p><p><span class="qpc-hafs">﴿دُولَةَۢ بَيۡنَ ٱلۡأَغۡنِيَآءِ﴾</span>: مُداوَلَةً يَتَداولُه الأَغْنِياءُ ويتعاقَبُونَ في التَّصَرُّفِ فِيهِ.</p></div>"
  59,8,"<div class=ar lang=ar></div>"
  59,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَوَّءُو﴾</span>: اسْتَوطَنُوا وتَمَكَّنُوا.</p><p><span class="qpc-hafs">﴿ٱلدَّارَ﴾</span>: المدِينَةَ، وهي دارُ الهِجْرَةِ.</p><p><span class="qpc-hafs">﴿حَاجَةࣰ﴾</span>: حَسَدًا.</p><p><span class="qpc-hafs">﴿مِّمَّآ أُوتُواْ﴾</span>: مِمّا أُعْطِي المهاجِرُونَ من فَيْءِ بَنِي النَّضِيرِ.</p><p><span class="qpc-hafs">﴿وَيُؤۡثِرُونَ عَلَىٰٓ أَنفُسِهِمۡ﴾</span>: ويُقَدِّمُونَ غيرَهُم مِنَ المهاجِرِينَ وذَوِي الحاجةِ عَلى أنْفُسِهِم.</p><p><span class="qpc-hafs">﴿خَصَاصَةࣱ﴾</span>: شِدَّةُ احْتِياجٍ.</p><p><span class="qpc-hafs">﴿وَمَن يُوقَ﴾</span>: ومَن سَلَّمَهُ اللهُ فمُنِعَ.</p><p><span class="qpc-hafs">﴿شُحَّ نَفۡسِهِۦ﴾</span>: بُخْلَها مَعَ حِرْصِها.</p><p><span class="qpc-hafs">﴿ٱلۡمُفۡلِحُونَ﴾</span>: الفائِزُونَ بِمَطْلُوبِهِم.</p></div>"