quran[14]{c,v,t}:
  20,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَوۡحَيۡنَآ﴾</span>: ألْهَمْنا.</p></div>"
  20,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱقۡذِفِيهِ﴾</span>: ضَعِيه.</p><p><span class="qpc-hafs">﴿ٱلتَّابُوتِ﴾</span>: الصُّنْدُوقِ الخَشَبِيِّ.</p><p><span class="qpc-hafs">﴿فَٱقۡذِفِيهِ فِي ٱلۡيَمِّ﴾</span>: فاطْرَحِيه في النِّيلِ.</p><p><span class="qpc-hafs">﴿وَأَلۡقَيۡتُ عَلَيۡكَ مَحَبَّةࣰ مِّنِّي﴾</span>: أي: أحْبَبْتُك، فَصِرْتَ بِذَلكَ مَحْبُوبًا بَيْنَ العِبادِ.</p><p><span class="qpc-hafs">﴿وَلِتُصۡنَعَ عَلَىٰ عَيۡنِيٓ﴾</span>: ولِتُرَبّى بِمَرأىً مِنِّي.</p></div>"
  20,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَيۡ تَقَرَّ عَيۡنُهَا﴾</span>: كي تُسَرَّ أُمُّ مُوسى بِسَلامةِ ولَدِها ورُجُوعِه إليها.</p><p><span class="qpc-hafs">﴿وَفَتَنَّـٰكَ﴾</span>: وابْتَلَيناك.</p><p><span class="qpc-hafs">﴿عَلَىٰ قَدَرࣲ﴾</span>: عَلى مَوْعِدٍ مُوافِقٍ للوقْتِ الُمقدَّرِ في عِلْمِ اللهِ تَعالى.</p></div>"
  20,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱصۡطَنَعۡتُكَ لِنَفۡسِي﴾</span>: هَيَّأْتُكَ لِتَبْلِيغِ الرِّسالةِ عَنِّي.</p></div>"
  20,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تَنِيَا﴾</span>: ولا تَضْعُفا.</p></div>"
  20,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَغَىٰ﴾</span>: جاوَزَ الحَدَّ في الكُفْرِ والظُّلْمِ.</p></div>"
  20,44,""
  20,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَن يَفۡرُطَ عَلَيۡنَآ﴾</span>: أن يُعاجِلَنا ويُبادِرَ بالعُقُوبَةِ.</p><p><span class="qpc-hafs">﴿أَوۡ أَن يَطۡغَىٰ﴾</span>: أو أن يَتَمَرَّدَ على الحقِّ فلا يَقْبَلَه.</p></div>"
  20,46,""
  20,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُعَذِّبۡهُمۡ﴾</span>: أي: ولا تُعَذِّبْهم بِذَبْحِ أبْنائِهِم واسْتِحْياءِ بَناتِهِم وتَكْلِيفِهِم بِما لا يُطِيقُونَ مِنَ الأَعْمالِ.</p></div>"
  20,48,""
  20,49,""
  20,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلۡقَهُۥ﴾</span>: أي: صورتَه اللائِقَةَ بخاصَّتِه ومَنفَعَتِه.</p></div>"
  20,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَمَا بَالُ ٱلۡقُرُونِ ٱلۡأُولَىٰ﴾</span>: فما شأنُ الأممِ السّابِقَةِ؟</p></div>"