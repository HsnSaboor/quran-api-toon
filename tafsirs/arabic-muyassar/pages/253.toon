quran[6]{c,v,t}:
  13,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طُوبَىٰ لَهُمۡ﴾</span>: عَيْشٌ وحالٌ طيبةٌ في الآخرةِ.</p><p><span class="qpc-hafs">﴿مَـَٔابࣲ﴾</span>: مَرْجِعٍ.</p></div>"
  13,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ أَرۡسَلۡنَـٰكَ﴾</span>: كما أرْسَلْنا الُمرْسَلين قبلَك أرْسَلْناك.</p><p><span class="qpc-hafs">﴿خَلَتۡ﴾</span>: مَضَتْ.</p><p><span class="qpc-hafs">﴿تَوَكَّلۡتُ﴾</span>: اعتمَدْتُ على ربي، وفوَّضْتُ أمري إليه.</p><p><span class="qpc-hafs">﴿مَتَابِ﴾</span>: مَرْجِعي وتَوْبتي.</p></div>"
  13,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُيِّرَتۡ بِهِ ٱلۡجِبَالُ﴾</span>: نُقِلَتْ عن أماكنِها.</p><p><span class="qpc-hafs">﴿قُطِّعَتۡ بِهِ ٱلۡأَرۡضُ﴾</span>: شُقِّقَتْ به، فتَصِيرُ عيونًا وأنهارًا.</p><p><span class="qpc-hafs">﴿كُلِّمَ بِهِ ٱلۡمَوۡتَىٰ﴾</span>: بأَنْ تُحْيا، ويُقْرَأَ عليهم فَيفْهَمُوه كالأحياءِ.</p><p><span class="qpc-hafs">﴿أَفَلَمۡ يَاْيۡـَٔسِ﴾</span>: أفلم يَعْلَمْ ويتبيَّنْ.</p><p><span class="qpc-hafs">﴿قَارِعَةٌ﴾</span>: مصيبةٌ تَنْزِلُ بهم وتُهْلِكُهُم.</p><p><span class="qpc-hafs">﴿وَعۡدُ ٱللَّهِ﴾</span>: النصرُ عليهم، أو قيامُ الساعةِ.</p></div>"
  13,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَمۡلَيۡتُ﴾</span>: أمْهَلْتُ مدةً طويلةً.</p></div>"
  13,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَآئِمٌ عَلَىٰ كُلِّ نَفۡسِۭ﴾</span>: رقيبٌ وحافظٌ عليها، وهو اللهُ.</p><p><span class="qpc-hafs">﴿قُلۡ سَمُّوهُمۡ﴾</span>: اذكُروا أسماءَ الشُّركاءِ وصِفاتِهم.</p><p><span class="qpc-hafs">﴿أَم بِظَـٰهِرࣲ مِّنَ ٱلۡقَوۡلِ﴾</span>: بل أتُسَمُّونهم شركاءَ بقولٍ باطِلٍ لا حقيقةَ له.</p><p><span class="qpc-hafs">﴿زُيِّنَ﴾</span>: حَسَّنَ الشَّيطانُ.</p><p><span class="qpc-hafs">﴿مَكۡرُهُمۡ﴾</span>: كفْرُهم وقولُهم الباطِلَ.</p><p><span class="qpc-hafs">﴿هَادࣲ﴾</span>: أحدٍ يُوَفِّقُه إلى الخيرِ.</p></div>"
  13,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَّهُمۡ عَذَابࣱ فِي ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾</span>: بالقَتْلِ والأسْرِ وغيرِهما.</p><p><span class="qpc-hafs">﴿وَاقࣲ﴾</span>: مانعٍ وعاصمٍ.</p></div>"