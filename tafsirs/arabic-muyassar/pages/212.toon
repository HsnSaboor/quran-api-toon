quran[8]{c,v,t}:
  10,26,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡحُسۡنَىٰ﴾</span>: الجنةُ.</p><p><span class="qpc-hafs">﴿وَزِيَادَةࣱ﴾</span>: النظرُ إلى وجهِ اللهِ الكريمِ في الجنةِ.</p><p><span class="qpc-hafs">﴿وَلَا يَرۡهَقُ﴾</span>: لا يَغْشى ولا يعلوُ.</p><p><span class="qpc-hafs">﴿قَتَرࣱ﴾</span>: غبارٌ فيه سَوادٌ.</p><p><span class="qpc-hafs">﴿ذِلَّةٌ﴾</span>: هَوانٌ وكآبةٌ.</p></div>"
  10,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَسَبُواْ﴾</span>: عَمِلُوا.</p><p><span class="qpc-hafs">﴿مِّنَ ٱللَّهِ﴾</span>: من عذابِه.</p><p><span class="qpc-hafs">﴿مِنۡ عَاصِمࣲ﴾</span>: من مانعٍ.</p><p><span class="qpc-hafs">﴿قِطَعࣰا﴾</span>: أجزاءً.</p></div>"
  10,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِطَعࣰا﴾</span>: الزَمُوا مكانَكم في موقفِ الحسابِ.</p><p><span class="qpc-hafs">﴿أَنتُمۡ وَشُرَكَآؤُكُمۡ﴾</span>: أنتم وآلهتكُم، حتى تَرَوْا ما يُفْعَلُ بكم.</p><p><span class="qpc-hafs">﴿فَزَيَّلۡنَا بَيۡنَهُمۡ﴾</span>: فرَّقْنا بينَ المشركين ومَعْبُوديهم.</p></div>"
  10,29,""
  10,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبۡلُواْ﴾</span>: تَخْتَبِرُ وتَعْلَمُ.</p><p><span class="qpc-hafs">﴿مَّآ أَسۡلَفَتۡ﴾</span>: ما قَدَّمَتْ مِن عَمَلٍ.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span>: ذَهَبَ وبَطَلَ.</p><p><span class="qpc-hafs">﴿يَفۡتَرُونَ﴾</span>: يَعْبُدون مِن آلهةٍ مزعومةٍ.</p></div>"
  10,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾</span>: يَقْضي أمورَ الدُّنيا والآخرةِ ويُصَرِّفُها وحدَه على أكملِ الوجوهِ.</p></div>"
  10,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ تُصۡرَفُونَ﴾</span>: فكيف تُصْرَفون عن عبادةِ اللهِ إلى عبادةِ غيره؟</p></div>"
  10,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّتۡ﴾</span>: وجَبَتْ.</p><p><span class="qpc-hafs">﴿كَلِمَتُ رَبِّكَ﴾</span>: حُكْمُه وقضاؤُه.</p><p><span class="qpc-hafs">﴿فَسَقُوٓاْ﴾</span>: خرجُوا عن طاعةِ اللهِ وكفرُوا به.</p></div>"