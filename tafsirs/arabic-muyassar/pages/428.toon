quran[7]{c,v,t}:
  34,1,"<div class=ar lang=ar></div>"
  34,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلِجُ﴾</span>: يَدْخُلُ.</p><p><span class="qpc-hafs">﴿يَخۡرُجُ مِنۡهَا﴾</span>: أي: مِنَ النَّباتِ والمعادِن والِمياهِ.</p><p><span class="qpc-hafs">﴿وَمَا يَنزِلُ مِنَ ٱلسَّمَآءِ﴾</span>: مِنَ الأمْطارِ والملائِكةِ والكُتُبِ.</p><p><span class="qpc-hafs">﴿وَمَا يَعۡرُجُ فِيهَا﴾</span>: وما صَعَدُ إلَيها مِنَ الملائِكَةِ وأعْمالِ الخلْقِ.</p></div>"
  34,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلسَّاعَةُ﴾</span>: القِيامةُ.</p><p><span class="qpc-hafs">﴿لَا يَعۡزُبُ عَنۡهُ﴾</span>: لا يَغِيبُ عَنْهُ ولا يَخْفى عَلَيهِ.</p><p><span class="qpc-hafs">﴿مِثۡقَالُ ذَرَّةࣲ﴾</span>: مِقْدارُ أصْغرِ نَمْلَةٍ.</p><p><span class="qpc-hafs">﴿كِتَـٰبࣲ مُّبِينࣲ﴾</span>: كِتابٍ واضِحٍ، وهو اللَّوحُ المَحْفُوظُ.</p></div>"
  34,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرِزۡقࣱ كَرِيمࣱ﴾</span>: وهو الجنَّةُ.</p></div>"
  34,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُعَـٰجِزِينَ﴾</span>: ظانِّينَ أنّهم يُعْجِزُونَنا ويَغْلِبُونَنا.</p><p><span class="qpc-hafs">﴿مِّن رِّجۡزٍ﴾</span>: أسْوَأِ العَذابِ وأشَدِّهِ.</p></div>"
  34,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَرَى﴾</span>: يَعْلمُ.</p><p><span class="qpc-hafs">﴿وَيَهۡدِيٓ﴾</span>: يُرْشِدُ.</p></div>"
  34,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُنَبِّئُكُمۡ﴾</span>: يُخْبِرُكُم بِنَبَأٍ غَرِيبٍ.</p><p><span class="qpc-hafs">﴿مُزِّقۡتُمۡ﴾</span>: قُطِّعْتُم، وتَفَرَّقَتْ أجْسادُكُم إلى أجْزاءٍ.</p></div>"