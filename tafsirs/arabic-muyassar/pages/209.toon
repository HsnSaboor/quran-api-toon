quran[8]{c,v,t}:
  10,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يَرۡجُونَ لِقَآءَنَا﴾</span>: لا يتوقَّعُون حسابَ الآخرةِ.</p><p><span class="qpc-hafs">﴿وَٱطۡمَأَنُّواْ بِهَا﴾</span>: رَكَنُوا إليها.</p><p><span class="qpc-hafs">﴿ءَايَـٰتِنَا﴾</span>: الكونيةِ والشرعيةِ.</p><p><span class="qpc-hafs">﴿غَـٰفِلُونَ﴾</span>: ساهُون ومُعْرِضُون.</p></div>"
  10,8,"<div class=ar lang=ar></div>"
  10,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَهۡدِيهِمۡ﴾</span>: يُرْشِدُهم، ويُوَفِّقُهم إلى العملِ المُوصِلِ إلى الجنة.</p><p><span class="qpc-hafs">﴿مِن تَحۡتِهِمُ﴾</span>: مِن تحتِ غُرَفِهم ومنازلهِم.</p></div>"
  10,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَعۡوَىٰهُمۡ فِيهَا سُبۡحَـٰنَكَ ٱللَّهُمَّ﴾</span>: دعاؤُهم الذي يَدْعُون به في الجنةِ التسبيحُ والتنزيهُ لله.</p><p><span class="qpc-hafs">﴿وَتَحِيَّتُهُمۡ﴾</span>: من اللهِ وملائكتِه لهم، وتحيةُ بعضِهم بعضًا.</p><p><span class="qpc-hafs">﴿سَلَـٰمࣱ﴾</span>: دعاءٌ لهم بالسَّلامةِ من كلِّ مكروهٍ.</p></div>"
  10,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّرَّ﴾</span>: إجابةَ دعائِهم في الشرِّ.</p><p><span class="qpc-hafs">﴿ٱسۡتِعۡجَالَهُم بِٱلۡخَيۡرِ﴾</span>: تعجيلَ اللهِ لهم بالخيرِ.</p><p><span class="qpc-hafs">﴿لَقُضِيَ إِلَيۡهِمۡ أَجَلُهُمۡ﴾</span>: لأُهْلِكُوا جميعًا.</p><p><span class="qpc-hafs">﴿فَنَذَرُ﴾</span>: نَتْرُكُ.</p><p><span class="qpc-hafs">﴿طُغۡيَـٰنِهِمۡ﴾</span>: تجاوُزِهم الَحدَّ في إنكارِ البعثِ.</p><p><span class="qpc-hafs">﴿يَعۡمَهُونَ﴾</span>: يتردَّدُون متحَيِّرين.</p></div>"
  10,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَسَّ﴾</span>: أصاب.</p><p><span class="qpc-hafs">﴿ٱلضُّرُّ﴾</span>: الشِّدَّةُ والمكروهُ.</p><p><span class="qpc-hafs">﴿لِجَنۢبِهِۦٓ﴾</span>: مُضْطجعًا على جَنْبِه.</p><p><span class="qpc-hafs">﴿مَرَّ كَأَن لَّمۡ يَدۡعُنَآ﴾</span>: استمرَّ على ما كان عليه قبل أن يُبْتلى.</p><p><span class="qpc-hafs">﴿لِلۡمُسۡرِفِينَ﴾</span>: المتجاوِزِين الَحدَّ في الكفرِ والمعاصي.</p></div>"
  10,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقُرُونَ﴾</span>: جَمْعُ قَرْن، وهم: القومُ المقتَرِنون في زمانٍ واحدٍ.</p><p><span class="qpc-hafs">﴿ظَلَمُواْ﴾</span>: أشرَكُوا وكَذَّبُوا.</p><p><span class="qpc-hafs">﴿بِٱلۡبَيِّنَـٰتِ﴾</span>: الدَّلالاتِ الواضحاتِ الدالَّةِ على صدقِهم.</p></div>"
  10,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَـٰٓئِفَ﴾</span>: جَمْعُ خليفة، وهو مَن يَخْلُفُ غيرَه.</p></div>"