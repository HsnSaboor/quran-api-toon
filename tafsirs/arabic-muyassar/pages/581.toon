tafsir[31]{c,v,t}:
77,20," <q>﴿مَّآءࣲ مَّهِينࣲ﴾</q>: ماءٍ ضَعِيفٍ حَقِيرٍ وهو النطْفَةُ. "
77,21," <q>﴿فِي قَرَارࣲ مَّكِينٍ﴾</q>: في مَكانٍ حَصِينٍ، وهو رَحِمُ المرأَةِ. "
77,22," <q>﴿إِلَىٰ قَدَرࣲ مَّعۡلُومࣲ﴾</q>: وقتٍ مَعْلُومٍ عِندَ اللهِ تَعالى. "
77,23," <q>﴿فَقَدَرۡنَا﴾</q>: فَقَدَرْنا على خَلْقِهِ وتَصْوِيِرهِ وإخْراجِهِ. <q>﴿ٱلۡقَـٰدِرُونَ﴾</q>: على الأشياءِ. "
77,24," <q>﴿وَيۡلࣱ﴾</q>: هَلاكٌ وعَذابٌ شَدِيدٌ. "
77,25," <q>﴿كِفَاتًا﴾</q>: وِعاءً جامِعًا. "
77,26," <q>﴿أَحۡيَآءࣰ﴾</q>: تَضُمُّ على ظَهْرِها أحياءً. <q>﴿وَأَمۡوَ ٰ⁠تࣰا﴾</q>: و تَضُمُّ في بَطْنِها أمْواتًا. "
77,27," <q>﴿رَوَ ٰ⁠سِيَ﴾</q>: جِبالًا ثَوابِتَ. <q>﴿شَـٰمِخَـٰتࣲ﴾</q>: عالياتٍ. <q>﴿فُرَاتࣰا﴾</q>: عَذْبًا سائِغًا. "
77,28," <q>﴿وَيۡلࣱ﴾</q>: هلاكٌ ودمارٌ. "
77,29," <q>﴿ٱنطَلِقُوٓاْ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ﴾</q>: يُقال لِلْكافِرينَ يومَ القيامةِ: سيرُوا إلى عذابِ جَهَنَّم الَّذِي كُنْتُم بِهِ تُكَذِّبُونَ في الدُّنيا. "
77,30," <q>﴿ٱنطَلِقُوٓاْ إِلَىٰ ظِلࣲّ﴾</q>: سِيرُوا، فاسْتَظِلُّوا بِدُخانِ جَهَنَّمَ. <q>﴿شُعَبࣲ﴾</q>: قِطَعٍ. "
77,31," <q>﴿لَّا ظَلِيلࣲ﴾</q>: لا يُظِلُّ ذلك الظِّلُّ مِن حَرِّ ذَلِكَ اليومِ. <q>﴿وَلَا يُغۡنِي مِنَ ٱللَّهَبِ﴾</q>: ولا يَدْفَعُ مِنَ حرِّ اللهبِ شيئًا. "
77,32," <q>﴿إِنَّهَا﴾</q>: إنّ جَهَنَّمَ. <q>﴿بِشَرَرࣲ﴾</q>: اسْمِ جَمْعِ شَرَرَةٍ: وهي القِطعَةُ المشْتَعِلَةُ مِن دَقِيقِ الحَطَبِ يَدْفَعُها لَهَبُ النّارِ في الهواءِ. <q>﴿كَٱلۡقَصۡرِ﴾</q>: كالبِناءِ العَظِيمِ العالِي. "
77,33," <q>﴿جِمَـٰلَتࣱ﴾</q>: جمعُ جَمَلٍ، طائِفَةٌ مِنَ الإبِلِ الذُّكُورِ لا إناثَ فيها. <q>﴿صُفۡرࣱ﴾</q>: سُودٌ يمِيلُ لونُها إلى الصُّفْرةِ. "
77,34," <q>﴿وَيۡلࣱ﴾</q>: هَلاكٌ وعذابٌ شَدِيدٌ. "
77,35," <q>﴿لَا يَنطِقُونَ﴾</q>: لا يَنْطِقُ فيه المُكَذِّبُونَ بِكَلامٍ يَنْفَعُهُم. "
  77,36,""
  77,37,""
77,38," <q>﴿يَوۡمُ ٱلۡفَصۡلِ﴾</q>: يومٌ يَفْصِلُ اللهُ فِيهِ بَينَ الخلائِقِ. <q>﴿جَمَعۡنَـٰكُمۡ وَٱلۡأَوَّلِينَ﴾</q>: جَمَعْناكُم مَعَ الكُفّارِ مِنَ الأُمَمِ الماضِيةِ. "
77,39," <q>﴿كَيۡدࣱ﴾</q>: حِيلةٌ في الخلاصِ مِنَ العذابِ. <q>﴿فَكِيدُونِ﴾</q>: فاحْتالُوا، وأنقذوا أنفُسَكُم مِن بَطْشِ اللهِ وانتِقامِهِ. "
  77,40,""
77,41," <q>﴿وَعُيُونࣲ﴾</q>: وعُيُونِ الماءِ الجاريةِ. "
  77,42,""
77,43," <q>﴿هَنِيٓـَٔۢا﴾</q>: سائِغًا. "
  77,44,""
  77,45,""
  77,46,""
  77,47,""
  77,48,""
  77,49,""
77,50," <q>﴿فَبِأَيِّ حَدِيثِۭ﴾</q>: فبأيِّ كِتابٍ وكَلامٍ. "
