quran[7]{c,v,t}:
  8,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا لَهُمۡ أَلَّا يُعَذِّبَهُمُ ٱللَّهُ﴾</span>: وأيُّ شيءٍ يَمْنَعُ من عذابه لهم؟</p><p><span class="qpc-hafs">﴿يَصُدُّونَ﴾</span>: يَمْنَعُون.</p><p><span class="qpc-hafs">﴿عَنِ ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span>: عن الطَّوافِ بالكعبةِ، والصَّلاةِ فيه.</p><p><span class="qpc-hafs">﴿وَمَا كَانُوٓاْ أَوۡلِيَآءَهُۥٓ﴾</span>: وما كان الكفارُ أولياءَ اللهِ ولا المسجدِ الحرامِ.</p></div>"
  8,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُكَآءࣰ﴾</span>: صَفيرًا.</p><p><span class="qpc-hafs">﴿وَتَصۡدِيَةࣰ﴾</span>: وتَصْفيقًا.</p><p><span class="qpc-hafs">﴿فَذُوقُواْ ٱلۡعَذَابَ﴾</span>: في الدنيا بالقَتْلِ والأَسْرِ في «بدرٍ»، وفي الآخرةِ بالنارِ.</p></div>"
  8,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَسۡرَةࣰ﴾</span>: ندامةً وأَسَفًا.</p></div>"
  8,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيَمِيزَ﴾</span>: ليَفْصِلَ.</p><p><span class="qpc-hafs">﴿فَيَرۡكُمَهُۥ﴾</span>: يَجْمَعَه ويَضُمَّ بعضَه إلى بعضٍ.</p></div>"
  8,38,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِن يَنتَهُواْ﴾</span>: عن الكفرِ، ويَرْجِعُوا إلى الإيمان.</p><p><span class="qpc-hafs">﴿وَإِن يَعُودُواْ﴾</span>: إلى قتالِ النبيِّ ﷺ.</p><p><span class="qpc-hafs">﴿مَضَتۡ﴾</span>: سَبَقَتْ.</p><p><span class="qpc-hafs">﴿سُنَّتُ ٱلۡأَوَّلِينَ﴾</span>: سنَّتُنا في عقوبةِ مَن كَذَّبَ واستمرَّ على كُفْرِه.</p></div>"
  8,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣱ﴾</span>: شِرْكٌ وصَدٌّ عن سبيل الله.</p><p><span class="qpc-hafs">﴿وَيَكُونَ ٱلدِّينُ كُلُّهُۥ لِلَّهِ﴾</span>: وتكونَ الطاعةُ والعبادةُ كلُّهاخالصةً لله.</p><p><span class="qpc-hafs">﴿فَإِنِ ٱنتَهَوۡاْ﴾</span>: فإن انزجَرَ المشركون عن شِرْكِهم وفتنةِ المؤمنين.</p></div>"
  8,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَوۡلَىٰكُمۡ﴾</span>: مُعينُكم وناصِرُكم.</p></div>"