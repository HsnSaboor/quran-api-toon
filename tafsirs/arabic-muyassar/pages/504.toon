quran[6]{c,v,t}:
  46,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كُرۡهࣰا﴾</span>: مَشَقَّةً.</p><p><span class="qpc-hafs">﴿وَفِصَـٰلُهُۥ﴾</span>: وفِطامُهُ.</p><p><span class="qpc-hafs">﴿أَشُدَّهُۥ﴾</span>: نِهايةَ قُوَّتِهِ البَدَنِيَّةِ والعقْلِيَّةِ.</p><p><span class="qpc-hafs">﴿أَوۡزِعۡنِيٓ﴾</span>: ألْهِمْنِي.</p></div>"
  46,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيٓ أَصۡحَـٰبِ ٱلۡجَنَّةِ﴾</span>: في جُمْلة أصْحابِ الجنَّة.</p></div>"
  46,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُفࣲّ﴾</span>: اسْمُ فِعْلٍ مَعْناه: أتَضَجَّرُ.</p><p><span class="qpc-hafs">﴿أُخۡرَجَ﴾</span>: أُبْعَثَ بَعْدَ الموتِ.</p><p><span class="qpc-hafs">﴿خَلَتِ﴾</span>: مَضَتِ.</p><p><span class="qpc-hafs">﴿ٱلۡقُرُونُ﴾</span>: جَمْعُ قَرْنٍ وهو الأُمَّةُ الَّتي تَقارَبَ زَمانُ حياتِها أي: فماتُوا ولم يُبْعَثْ مِنهُم أحَدٌ؟</p><p><span class="qpc-hafs">﴿يَسۡتَغِيثَانِ ٱللَّهَ﴾</span>: يَطْلُبانِ عَوْنَهُ.</p><p><span class="qpc-hafs">﴿وَيۡلَكَ﴾</span>: هَلاكًا لَكَ.</p><p><span class="qpc-hafs">﴿أَسَـٰطِيرُ﴾</span>: القِصَصُ الباطِلةُ.</p></div>"
  46,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾</span>: وجَبَ عَلَيهِمُ القَوْلُ بالعَذابِ.</p></div>"
  46,19,""
  46,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَذۡهَبۡتُمۡ﴾</span>: يقُولُ اللهُ لَهُم ذَلِكَ.</p><p><span class="qpc-hafs">﴿ٱلۡهُونِ﴾</span>: الهَوانِ والذُّلِّ.</p><p><span class="qpc-hafs">﴿تَفۡسُقُونَ﴾</span>: تَخْرُجُونَ عَن طاعَةِ اللهِ بالشِّرْكِ.</p></div>"