quran[16]{c,v,t}:
  38,1,""
  38,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عِزَّةࣲ﴾</span>: تكبُّرٍ عَنِ الحقِّ.</p><p><span class="qpc-hafs">﴿وَشِقَاقࣲ﴾</span>: مُشاقَّةٍ ومُخالَفةٍ للهِ ولِرَسُولِهِ.</p></div>"
  38,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمۡ أَهۡلَكۡنَا﴾</span>: كَثِيرًا أهْلَكْنا.</p><p><span class="qpc-hafs">﴿مِّن قَرۡنࣲ﴾</span>: مِن أُمَّةٍ.</p><p><span class="qpc-hafs">﴿فَنَادَواْ﴾</span>: فاسْتَغاثُوا حِينَ عايَنُوا العَذابَ.</p><p><span class="qpc-hafs">﴿وَّلَاتَ﴾</span>: ولَيسَ.</p><p><span class="qpc-hafs">﴿حِينَ مَنَاصࣲ﴾</span>: وقتَ فِرارٍ.</p></div>"
  38,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُّنذِرࣱ مِّنۡهُمۡ﴾</span>: رَسُولٌ مِنهُم.</p></div>"
  38,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عُجَابࣱ﴾</span>: عَجِيبٌ.</p></div>"
  38,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمَلَأُ﴾</span>: أشْرافُ القوم ورُؤساؤُهُم.</p><p><span class="qpc-hafs">﴿أَنِ ٱمۡشُواْ﴾</span>: أنِ امْضُوا على ما كُنتُم عَلَيهِ ولا تَدْخُلُوا في دِينِه.</p><p><span class="qpc-hafs">﴿وَٱصۡبِرُواْ عَلَىٰٓ ءَالِهَتِكُمۡ﴾</span>: أي: اثبُتُوا على عِبادَتِها.</p><p><span class="qpc-hafs">﴿لَشَيۡءࣱ يُرَادُ﴾</span>: أي: شَيءٌ مُدَبَّرٌ يُريدُهُ محمدٌ بِنا وبآلَهتِنا؛ لِيَتَحَكَّمَ فِينا بِما يُرِيدُ.</p></div>"
  38,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمِلَّةِ ٱلۡـَٔاخِرَةِ﴾</span>: هي النَّصْرانِيَّةُ، أو دِينُ قُرَيشٍ.</p><p><span class="qpc-hafs">﴿إِلَّا ٱخۡتِلَـٰقٌ﴾</span>: إلا كَذِبٌ اختَلَقَهُ محمدٌ وافْتَراهُ.</p></div>"
  38,8,""
  38,9,""
  38,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلۡيَرۡتَقُواْ﴾</span>: فَلْيَصْعَدُوا.</p><p><span class="qpc-hafs">﴿ٱلۡأَسۡبَـٰبِ﴾</span>: المعارِجِ إلى السَّماءِ.</p></div>"
  38,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جُندࣱ مَّا هُنَالِكَ﴾</span>: أي: هَؤُلاءِ الجُنْدُ المكذِّبُونَ الَّذينَ هُم في عِزَّةٍ وشِقاقٍ.</p><p><span class="qpc-hafs">﴿مَهۡزُومࣱ مِّنَ ٱلۡأَحۡزَابِ﴾</span>: سَيُهْزَمُ هَذا الجُنْدُ ويُغلَبُ، كما هُزِمَ الَّذينَ مِن قَبْلِهِم مِنَ الأحْزابِ المكَذِّبِينَ.</p></div>"
  38,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَوۡتَادِ﴾</span>: صاحِبُ القُوَّةِ العظِيمةِ مِنَ الجُنُودِ والمبانِي الشّاهِقَةِ.</p></div>"
  38,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَصۡحَـٰبُ لۡـَٔيۡكَةِ﴾</span>: أصْحابُ الأشْجارِ والبَساتِينِ.</p></div>"
  38,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَقَّ عِقَابِ﴾</span>: فحَلَّ بهم عِقابِي وعَذابي.</p></div>"
  38,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنظُرُ﴾</span>: يَنْتَظِرُ.</p><p><span class="qpc-hafs">﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾</span>: نَفْخَةً واحِدةً في الصُّورِ.</p><p><span class="qpc-hafs">﴿مَّا لَهَا مِن فَوَاقࣲ﴾</span>: مالها مِن تَوقُّفٍ مِقْدارَ فَواقِ ناقَةٍ: وهو مابيَن حَلْبَتَيها مِنَ المدَّةِ القلِيلَةِ.</p></div>"
  38,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قِطَّنَا﴾</span>: نصيبَنا مِنَ العذابِ.</p></div>"