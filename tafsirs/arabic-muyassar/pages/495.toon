quran[16]{c,v,t}:
  43,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡمُجۡرِمِينَ﴾</span>: الكافِرينَ.</p></div>"
  43,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَا يُفَتَّرُ﴾</span>: لا يُخَفَّفُ.</p><p><span class="qpc-hafs">﴿مُبۡلِسُونَ﴾</span>: آيِسُونَ مِن رَّحْمَةِ اللهِ.</p></div>"
  43,76,""
  43,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَـٰمَـٰلِكُ﴾</span>: هو اسْمُ خازِنِ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿لِيَقۡضِ عَلَيۡنَا رَبُّكَ﴾</span>: لِيُمِتْنا ربُّكَ.</p><p><span class="qpc-hafs">﴿مَّـٰكِثُونَ﴾</span>: مُقِيمُونَ في العذابِ.</p></div>"
  43,78,""
  43,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَمۡ﴾</span>: بَلْ.</p><p><span class="qpc-hafs">﴿أَبۡرَمُوٓاْ﴾</span>: أحْكَمُوا.</p><p><span class="qpc-hafs">﴿مُبۡرِمُونَ﴾</span>: مُحْكِمُونَ أمْرًا في مُجازاتِهم بِالنَّكالِ والعَذابِ.</p></div>"
  43,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سِرَّهُمۡ﴾</span>: ما يُخْفُونَه مِن غَيرِهِم.</p><p><span class="qpc-hafs">﴿وَنَجۡوَىٰهُم﴾</span>: الحدِيثَ الَّذِي يَتَسارُّونَ بِهِ فِيما بَينَهُم.</p><p><span class="qpc-hafs">﴿وَرُسُلُنَا﴾</span>: الملائِكَةُ الحَفَظَةُ.</p></div>"
  43,81,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَا۠ أَوَّلُ ٱلۡعَـٰبِدِينَ﴾</span>: أوَّلُ عابِدِيهِ بِذلكَ مِنكُم، ولَكِنَّهُ لا ولَدَ لَهُ، فأَنا أعْبُدُهُ بِأنّه لا ولَدَ لَهُ.</p></div>"
  43,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سُبۡحَـٰنَ﴾</span>: تنْزِيهًا وتَقْدِيسًا.</p><p><span class="qpc-hafs">﴿يَصِفُونَ﴾</span>: يَكْذِبُونَ.</p></div>"
  43,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَخُوضُواْ﴾</span>: يَتَحَدَّثُوا بالباطِل على غيرِ هُدىً.</p></div>"
  43,84,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلسَّمَآءِ إِلَـٰهࣱ وَفِي ٱلۡأَرۡضِ إِلَـٰهࣱ﴾</span>: مَعْبُودٌ في السَّماءِ وفي الأَرْضِ.</p></div>"
  43,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَبَارَكَ﴾</span>: كَثُرَ خَيْرُهُ.</p><p><span class="qpc-hafs">﴿تُرۡجَعُونَ﴾</span>: تُرَدُّونَ بَعْدَ مَماتِكُم.</p></div>"
  43,86,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلشَّفَـٰعَةَ﴾</span>: طَلَبَ قَضاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المشْفُوعِ عِنْدَهُ مِنَ التَّجاوُزِ عَنِ السَّيئاتِ والزَّلّاتِ وغَيرِها.</p></div>"
  43,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾</span>: كَيْفَ يُصْرَفُونَ عَنْ عِبادَةِ الله؟</p></div>"
  43,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقِيلِهِۦ﴾</span>: وعِنْدَ اللهِ عِلْمُ قولِ الرَّسُولِ ﷺ.</p></div>"
  43,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱصۡفَحۡ﴾</span>: فَأَعْرِضْ.</p><p><span class="qpc-hafs">﴿سَلَـٰمࣱ﴾</span>: سَلامُ مُتارَكَةٍ ومُفارَقَةٍ لِلْجاهِلِينَ.</p></div>"