quran[13]{c,v,t}:
  19,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطُّورِ﴾</span>: جَبَلِ طُورِ سَيناءَ.</p><p><span class="qpc-hafs">﴿وَقَرَّبۡنَـٰهُ نَجِيࣰّا﴾</span>: فشَرَّفْناه بِمُناجاتِنا وتَكْلِيمِنا إيّاه سرًّا.</p></div>"
  19,53,"<div class=ar lang=ar></div>"
  19,54,"19:53"
  19,55,"19:53"
  19,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صِدِّيقࣰا﴾</span>: عظيمَ الصِّدقِ في قولِه وعَمَلِه.</p></div>"
  19,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَرَفَعۡنَـٰهُ﴾</span>: أي: ذِكْرَه ومَنزِلَتَه، قيل: إنّه رُفِعَ إلى السَّماءِ الرابعةِ.</p><p><span class="qpc-hafs">﴿عَلِيًّا﴾</span>: رفيعَ القَدْرِ، أو ذا مَكانٍ عالٍ في السَّماءِ.</p></div>"
  19,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱجۡتَبَيۡنَآ﴾</span>: واصْطَفَينا للرِّسالةِ والنُّبوَّةِ.</p><p><span class="qpc-hafs">﴿خَرُّواْ﴾</span>: وقَعُوا.</p><p><span class="qpc-hafs">﴿وَبُكِيࣰّا﴾</span>: وباكِينَ مِن خَشْيَتِه سُبْحانَه وتَعالىَ.</p></div>"
  19,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خَلَفَ مِنۢ بَعۡدِهِمۡ﴾</span>: فجاءَ بَعْدَهُم.</p><p><span class="qpc-hafs">﴿خَلۡفٌ﴾</span>: أتْباعُ سُوءٍ.</p><p><span class="qpc-hafs">﴿غَيًّا﴾</span>: جَزاءَ الغَيِّ، أو وادِيًا في جَهَنَّمَ.</p></div>"
  19,60,"<div class=ar lang=ar></div>"
  19,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّـٰتِ عَدۡنٍ﴾</span>: جناتِ خُلْدٍ وإقامَةٍ دائِمةٍ.</p><p><span class="qpc-hafs">﴿بِٱلۡغَيۡبِ﴾</span>: أي: غائبةً عَنْهم لا يُشاهِدُونها.</p><p><span class="qpc-hafs">﴿مَأۡتِيࣰّا﴾</span>: آتِيًا لا مَحالةَ.</p></div>"
  19,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَغۡوًا﴾</span>: كَلامًا باطِلًا.</p><p><span class="qpc-hafs">﴿بُكۡرَةࣰ وَعَشِيࣰّا﴾</span>: أي: على مِقْدارِ ما يَعرِفُونَ من الغَداءِ والعَشاءِ، وإلّا فليسَ في الجنَّةِ بُكْرَةٌ ولا عَشِيَّةٌ.</p></div>"
  19,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نُورِثُ﴾</span>: نُعْطِي.</p></div>"
  19,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا نَتَنَزَّلُ﴾</span>: أي: نَحْنُ الملائكةُ مِنَ السَّماءِ إلى الأرضِ.</p><p><span class="qpc-hafs">﴿لَهُۥ مَا بَيۡنَ أَيۡدِينَا﴾</span>: مما يُسْتَقْبَلُ مِن أُمُورِ الآخِرَةِ.</p><p><span class="qpc-hafs">﴿وَمَا خَلۡفَنَا﴾</span>: مِمّا مَضى مِن أُمُورِ الدُّنْيا.</p><p><span class="qpc-hafs">﴿وَمَا بَيۡنَ ذَ ٰ⁠لِكَ﴾</span>: وما بَيْنَ الدُّنْيا والآخِرةِ.</p><p><span class="qpc-hafs">﴿نَسِيࣰّا﴾</span>: ناسِيًا لشيءٍ مِنَ الأشياءِ.</p></div>"