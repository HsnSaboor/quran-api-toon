quran[8]{c,v,t}:
  4,106,""
  4,107,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَا تُجَـٰدِلۡ﴾</span>: ولا تُدافِعْ، وتخاصِمْ.</p><p><span class="qpc-hafs">﴿يَخۡتَانُونَ﴾</span>: يَخُونون بمعصيةِ اللهِ.</p><p><span class="qpc-hafs">﴿خَوَّانًا﴾</span>: كثيرَ الخيانةِ.</p><p><span class="qpc-hafs">﴿أَثِيمࣰا﴾</span>: كثيرَ الذَّنْبِ.</p></div>"
  4,108,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَسۡتَخۡفُونَ﴾</span>: يَسْتَتِرُون.</p><p><span class="qpc-hafs">﴿وَهُوَ مَعَهُمۡ﴾</span>: بعِلْمِه.</p><p><span class="qpc-hafs">﴿يُبَيِّتُونَ﴾</span>: يُدَبِّرُون ليلًا.</p></div>"
  4,109,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكِيلࣰا﴾</span>: مُجادِلًا يقومُ بأمرِهم.</p></div>"
  4,110,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَظۡلِمۡ نَفۡسَهُۥ﴾</span>: بارتكابِ معصيةٍ.</p></div>"
  4,111,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَكۡسِبُهُۥ عَلَىٰ نَفۡسِهِۦ﴾</span>: يَضُرُّها.</p></div>"
  4,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِثۡمࣰا﴾</span>: ذَنبًا عن عَمْدٍ.</p><p><span class="qpc-hafs">﴿ٱحۡتَمَلَ بُهۡتَـٰنࣰا﴾</span>: تَحَمَّلَ كَذِبًا.</p><p><span class="qpc-hafs">﴿مُّبِينࣰا﴾</span>: بَيِّنًا.</p></div>"
  4,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضۡلُ ٱللَّهِ﴾</span>: بالنبوَّةِ، فعَصَمَك بتوفيقِه.</p><p><span class="qpc-hafs">﴿يُضِلُّوكَ﴾</span>: يُزِلُّوك عن الحقِّ.</p><p><span class="qpc-hafs">﴿ٱلۡحِكۡمَةَ﴾</span>: السُّنَّةَ.</p></div>"