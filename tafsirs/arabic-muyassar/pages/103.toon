quran[8]{c,v,t}:
  4,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِمَا نَقۡضِهِم مِّيثَـٰقَهُمۡ﴾</span>: لَعَنّاهم بسببِ نَقْضِهم العهودَ المؤكَّدةَ.</p><p><span class="qpc-hafs">﴿غُلۡفُۢ﴾</span>: عليها أغطِيَةٌ، لاتفقَهُ ما تقولُ.</p><p><span class="qpc-hafs">﴿طَبَعَ﴾</span>: خَتَمَ.</p><p><span class="qpc-hafs">﴿إِلَّا قَلِيلࣰا﴾</span>: إلا إيمانًا قليلًا كإيمانِهم بموسى عليه السلامُ والتوراةِ.</p></div>"
  4,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بُهۡتَـٰنًا﴾</span>: افتراءً برَمْيِها بالزِّنى.</p></div>"
  4,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شُبِّهَ لَهُمۡ﴾</span>: قَتَلُوا رجلًا يُشْبِهُه.</p><p><span class="qpc-hafs">﴿يَقِينَۢا﴾</span>: مُتَيَقِّنِين بأنه عيسى، بل كانوا شاكِّين مُتَوَهِّمين فيه.</p></div>"
  4,158,"<div class=ar lang=ar></div>"
  4,159,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَيُؤۡمِنَنَّ بِهِۦ﴾</span>: أي: بعدَ نُزولِه آخرَ الزَّمانِ.</p><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: شاهدًا عليهم بتكذيبِ مَن كذَّبه، وغالى فيه.</p></div>"
  4,160,"<div class=ar lang=ar></div>"
  4,161,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَعۡتَدۡنَا﴾</span>: وأَعْدَدْنا.</p></div>"
  4,162,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلرَّ ٰ⁠سِخُونَ﴾</span>: المُتَمَكِّنون.</p><p><span class="qpc-hafs">﴿وَٱلۡمُقِيمِينَ ٱلصَّلَوٰةَ﴾</span>: أي: وأمدَحُ هؤلاء.</p></div>"