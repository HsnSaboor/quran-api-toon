quran[10]{c,v,t}:
  10,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَلِيمࣲ﴾</span>: مُتْقِنٍ للسِّحْرِ.</p></div>"
  10,80,""
  10,81,""
  10,82,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيُحِقُّ ٱللَّهُ ٱلۡحَقَّ﴾</span>: يُثَبِّتُه ويُظْهِره.</p><p><span class="qpc-hafs">﴿بِكَلِمَـٰتِهِۦ﴾</span>: بقضائِه وأمْرِه.</p></div>"
  10,83,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَفۡتِنَهُمۡ﴾</span>: يُعَذِّبَهم؛ ليَحْمِلَهم على الرجوعِ عن الإيمان.</p><p><span class="qpc-hafs">﴿لَعَالࣲ﴾</span>: متكبِّرٌ متطاولٌ.</p><p><span class="qpc-hafs">﴿ٱلۡمُسۡرِفِينَ﴾</span>: المتجاوِزِين الحَدَّ في الكفرِ والفسادِ.</p></div>"
  10,84,""
  10,85,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِتۡنَةࣰ﴾</span>: موضعَ ابتلاءٍ واختبارٍ.</p></div>"
  10,86,""
  10,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَبَوَّءَا﴾</span>: اتَّخِذا.</p><p><span class="qpc-hafs">﴿وَٱجۡعَلُواْ بُيُوتَكُمۡ﴾</span>: أي: اجعَلُوها مساجدَ تُصَلُّون فيها عند الخوفِ.</p></div>"
  10,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱطۡمِسۡ عَلَىٰٓ أَمۡوَ ٰ⁠لِهِمۡ﴾</span>: أهْلِكْها وأتْلِفْها.</p><p><span class="qpc-hafs">﴿وَٱشۡدُدۡ عَلَىٰ قُلُوبِهِمۡ﴾</span>: اخْتِمْ عليها.</p></div>"