quran[8]{c,v,t}:
  8,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَنفَالِ﴾</span>: جَمْعُ نَفَل، وهي: الغنائمُ في غزوةِ «بَدْر».</p><p><span class="qpc-hafs">﴿ذَاتَ بَيۡنِكُمۡ﴾</span>: الصِّلَةُ التي تَرْبِطُ بعضَكم ببعض.</p></div>"
  8,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَجِلَتۡ﴾</span>: خافَتْ وفَزِعَتْ.</p><p><span class="qpc-hafs">﴿وَعَلَىٰ رَبِّهِمۡ يَتَوَكَّلُونَ﴾</span>: يعتمدون عليه ويُفَوِّضون أمرَهم إليه.</p></div>"
  8,3,""
  8,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿دَرَجَـٰتٌ﴾</span>: منازلُ عاليةٌ.</p></div>"
  8,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَمَآ أَخۡرَجَكَ﴾</span>: هذه الحالُ في كراهةِ فريقٍ من المؤمنين للقتالِ بعد تَبَيُّنِه، مثلُ إخراجِك في حالِ كراهتِهم.</p></div>"
  8,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي ٱلۡحَقِّ﴾</span>: في القتالِ.</p></div>"
  8,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلطَّآئِفَتَيۡنِ﴾</span>: القافلةِ الآتيةِ من الشام وما تحمِلُه من أرزاقٍ، أو النَّفيرِ لقتالِ الأعداءِ.</p><p><span class="qpc-hafs">﴿غَيۡرَ ذَاتِ ٱلشَّوۡكَةِ﴾</span>: غيرَ ذاتِ السِّلاحِ والقُوَّةِ، وهي: القافلةُ.</p><p><span class="qpc-hafs">﴿وَيَقۡطَعَ دَابِرَ ٱلۡكَـٰفِرِينَ﴾</span>: الدابِرُ: الآخِرُ، أي: ويستأصِلَ الكافرين بالهَلاكِ.</p></div>"
  8,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِيُحِقَّ ٱلۡحَقَّ﴾</span>: ليُظْهِرَه للناسِ ويُبَيِّنَه.</p></div>"