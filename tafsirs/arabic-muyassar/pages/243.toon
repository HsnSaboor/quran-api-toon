quran[6]{c,v,t}:
  12,64,"<div class=ar lang=ar></div>"
  12,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَتَـٰعَهُمۡ﴾</span>: أوْعِيتَهم، أو أمتعتَهم.</p><p><span class="qpc-hafs">﴿مَا نَبۡغِي﴾</span>: ماذا نَطْلُبُ أكثرَ من هذا الإكرامِ؟</p><p><span class="qpc-hafs">﴿وَنَمِيرُ أَهۡلَنَا﴾</span>: نَجْلُبُ لهم الطعامَ.</p></div>"
  12,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مَوۡثِقࣰا مِّنَ ٱللَّهِ﴾</span>: عَهْدًا، وتُؤَكِّدُوه بالحَلِفِ باللهِ.</p><p><span class="qpc-hafs">﴿يُحَاطَ بِكُمۡ﴾</span>: تُغْلَبُوا، فلا تَسْتطيعوا الإتيانَ به، أو تَهْلِكُوا جميعًا.</p><p><span class="qpc-hafs">﴿وَكِيلࣱ﴾</span>: رقيبٌ مُطَّلعٌ.</p></div>"
  12,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَآ أُغۡنِي عَنكُم﴾</span>: لا أدْفَعُ عنكم.</p><p><span class="qpc-hafs">﴿عَلَيۡهِ تَوَكَّلۡتُ﴾</span>: اعتمَدْتُ على ربي وفَوَّضْتُ أمري إليه.</p></div>"
  12,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَاجَةࣰ فِي نَفۡسِ يَعۡقُوبَ﴾</span>: وهي شَفَقَتُه على أولادِه أن تصيبَهم العَيْنُ.</p><p><span class="qpc-hafs">﴿قَضَىٰهَا﴾</span>: أدْرَكَها، ووَصّى أولادَه باتِّقائِها.</p></div>"
  12,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ءَاوَىٰٓ إِلَيۡهِ أَخَاهُ﴾</span>: ضَمَّ إليه شقيقَه بِنْيامينَ.</p><p><span class="qpc-hafs">﴿فَلَا تَبۡتَئِسۡ﴾</span>: فلا تَحْزَنْ.</p></div>"