quran[11]{c,v,t}:
  12,53,""
  12,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَسۡتَخۡلِصۡهُ لِنَفۡسِي﴾</span>: أجْعَلْ يوسفَ مِن خاصَّتي وأهلِ مَشُورتي.</p><p><span class="qpc-hafs">﴿مَكِينٌ﴾</span>: ذو مَكانةٍ رفيعةٍ وقولٍ نافذٍ.</p></div>"
  12,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡأَرۡضِ﴾</span>: أرضِ مصرَ.</p></div>"
  12,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ﴾</span>: وكما أنْعَمْنا على يوسفَ بالخَلاصِ من السِّجْنِ.</p><p><span class="qpc-hafs">﴿يَتَبَوَّأُ مِنۡهَا﴾</span>: يَنْزِلُ من بلاد مِصرَ.</p></div>"
  12,57,""
  12,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنكِرُونَ﴾</span>: لم يَعْرِفُوا يوسفَ لطولِ المدةِ، وتَغَيُّرِهيئتِه.</p></div>"
  12,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَهَّزَهُم بِجَهَازِهِمۡ﴾</span>: هيَّأ لهم ما هم في حاجةٍ إليه من طعامٍ ومَتاعٍ.</p><p><span class="qpc-hafs">﴿ٱلۡمُنزِلِينَ﴾</span>: المُضِيفِين.</p></div>"
  12,60,""
  12,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿سَنُرَ ٰ⁠وِدُ عَنۡهُ أَبَاهُ﴾</span>: سنجتهدُ في استمالةِ أبيه برِفْقٍ؛ ليُرْسِلَه معنا.</p></div>"
  12,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِفِتۡيَـٰنِهِ﴾</span>: غِلْمانِ يوسفَ.</p><p><span class="qpc-hafs">﴿بِضَـٰعَتَهُمۡ فِي رِحَالِهِمۡ﴾</span>: ثمنَ ما اشترَوْه في أمتعتِهم.</p><p><span class="qpc-hafs">﴿ٱنقَلَبُوٓاْ﴾</span>: رَجَعُوا.</p></div>"
  12,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُنِعَ مِنَّا ٱلۡكَيۡلُ﴾</span>: حُكِمَ بمَنعِه عنّا بعدَ هذه المرَّةِ.</p><p><span class="qpc-hafs">﴿نَكۡتَلۡ﴾</span>: نَحصُلْ على ما نَحْتاج إليه مُقَدَّرًا بالكَيْلِ.</p></div>"