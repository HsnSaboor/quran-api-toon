quran[7]{c,v,t}:
  5,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تَكُونُ لَنَا عِيدࣰا﴾</span>: نَتَّخِذُ يومَ نُزُولِها عيدًا لنا، فنُعَظِّمُه.</p><p><span class="qpc-hafs">﴿لِّأَوَّلِنَا وَءَاخِرِنَا﴾</span>: لنا ولمَن بعدَنا من عَقِبِنا.</p><p><span class="qpc-hafs">﴿وَءَايَةࣰ﴾</span>: وعلامةً على صِدْقِك.</p></div>"
  5,115,"<div class=ar lang=ar></div>"
  5,116,"5:115"
  5,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿شَهِيدࣰا﴾</span>: رقيبًا.</p><p><span class="qpc-hafs">﴿تَوَفَّيۡتَنِي﴾</span>: وفَّيْتَ أجلي على الأرضِ ورَفَعْتَني إلى السماءِ حيًّا.</p></div>"
  5,118,"<div class=ar lang=ar></div>"
  5,119,"5:118"
  5,120,"5:118"