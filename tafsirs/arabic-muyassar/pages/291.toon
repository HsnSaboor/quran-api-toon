quran[10]{c,v,t}:
  17,87,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلَّا رَحۡمَةࣰ مِّن رَّبِّكَ﴾</span>: لكن رحمةً من اللهِ أبقَيْنا القرآنَ فلم نُذْهِبْه.</p></div>"
  17,88,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ظَهِيرࣰا﴾</span>: مُعِينًا على تحقيقِ مُرادِهم.</p></div>"
  17,89,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿صَرَّفۡنَا﴾</span>: بَيَّنّا ونَوَّعْنا بأساليبَ مختلفةٍ.</p><p><span class="qpc-hafs">﴿كُلِّ مَثَلࣲ﴾</span>: كلِّ معنى يَحْصُلُ الاتعاظُ به.</p><p><span class="qpc-hafs">﴿كُفُورࣰا﴾</span>: جُحودًا للحَقِّ.</p></div>"
  17,90,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَنۢبُوعًا﴾</span>: عَيْنًا لا يَجِفُّ ماؤُها.</p></div>"
  17,91,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿جَنَّةࣱ﴾</span>: حديقةٌ.</p><p><span class="qpc-hafs">﴿فَتُفَجِّرَ ٱلۡأَنۡهَـٰرَ﴾</span>: تُجْرِيها بقُوَّةٍ.</p></div>"
  17,92,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كِسَفًا﴾</span>: قِطَعًا.</p><p><span class="qpc-hafs">﴿قَبِيلًا﴾</span>: مقابَلَةً وعِيانًا.</p></div>"
  17,93,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿زُخۡرُفٍ﴾</span>: ذَهَبٍ.</p><p><span class="qpc-hafs">﴿تَرۡقَىٰ﴾</span>: تَصْعَدَ.</p><p><span class="qpc-hafs">﴿سُبۡحَانَ رَبِّي﴾</span>: تَنْزيهًا للهِ عن اقتراحاتهم، وتَعجُّبًا من شِدَّةِ كُفْرِهم.</p></div>"
  17,94,""
  17,95,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُطۡمَئِنِّينَ﴾</span>: ساكنِين فيها.</p></div>"
  17,96,""