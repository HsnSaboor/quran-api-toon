tafsir[23]{c,v,t}:
  51,52,""
51,53," <q>﴿أَتَوَاصَوۡاْ﴾</q>: هَلْ أوصْىَ بَعْضُهُم بَعْضًا؟ <q>﴿طَاغُونَ﴾</q>: مُتَعَدُّونَ، طُغاةٌ عَنْ أمْرِ رَبِّهِم. "
51,54," <q>﴿فَتَوَلَّ عَنۡهُمۡ﴾</q>: فأَعْرِضْ عَنْهُم. <q>﴿فَمَآ أَنتَ بِمَلُومࣲ﴾</q>: فَلَيسَ عَلَيكَ لَوْمٌ في ذَنْبِهِم. "
51,55," <q>﴿ٱلذِّكۡرَىٰ﴾</q>: التَّذْكِيرَ والمَوعِظَةَ. "
51,56," <q>﴿لِيَعۡبُدُونِ﴾</q>: إرادَةَ أن يَعْبُدُونِي إرادَةً شَرْعِيَّةً دِينِيَّةً، وقَدْ تَقَعُ العِبادة وقَدْ لا تَقَعُ. "
  51,57,""
51,58," <q>﴿ٱلۡمَتِينُ﴾</q>: الشَّدِيدُ الكامِلُ في قُوَّتِهِ. "
51,59," <q>﴿ذَنُوبࣰا﴾</q>: حَظًّا ونَصِيبًا. "
51,60," <q>﴿فَوَيۡلࣱ﴾</q>: عَذابٌ وهَلاكٌ. "
52,1," <q>﴿وَٱلطُّورِ﴾</q>: هُوَ الجَبَلُ الَّذِي كَلَّمَ اللهُ عَلَيهِ مُوسى عَلَيهِ السَّلامُ. "
52,2," <q>﴿مَّسۡطُورࣲ﴾</q>: مَكْتُوبٍ، وهُو القُرآنُ. "
52,3," <q>﴿فِي رَقࣲّ مَّنشُورࣲ﴾</q>: مَكْتُوبٍ في صَحِيفةٍ مَبْسُوطَةٍ. "
52,4," <q>﴿وَٱلۡبَيۡتِ ٱلۡمَعۡمُورِ﴾</q>: هو فَوْقَ السَّماءِ السّابِعةِ تَطُوفُ بِه الملائِكةُ دائِمًا. "
52,5," <q>﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ﴾</q>: هو السَّماءُ الدُّنيا، جَعَلَها اللهُ سَقْفًا للأرْضِ. "
52,6," <q>﴿ٱلۡمَسۡجُورِ﴾</q>: الممْلُوءِ بالمياهِ. "
  52,7,""
52,8," <q>﴿دَافِعࣲ﴾</q>: مانِعٍ يَمْنَعُه حِينَ وقُوعِهِ. "
52,9," <q>﴿تَمُورُ﴾</q>: تَتَحرَّكُ وتَضْطَرِبُ. "
52,10," <q>﴿وَتَسِيرُ﴾</q>: تَزُولُ عَنْ أماكِنِها وتَسيرُ كَسَيرِ السَّحابِ. "
52,11," <q>﴿فَوَيۡلࣱ﴾</q>: فَهَلاكٌ. "
52,12," <q>﴿فِي خَوۡضࣲ﴾</q>: في انْدِفاعٍ في الكَلامِ الباطِلِ. <q>﴿يَلۡعَبُونَ﴾</q>: يَسْتَهْزِئُونَ. "
52,13," <q>﴿يُدَعُّونَ﴾</q>: يُدْفَعُونَ. <q>﴿دَعًّا﴾</q>: دَفْعًا بِعُنْفٍ ومهانَةٍ. "
  52,14,""
