quran[5]{c,v,t}:
  33,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقۡنُتۡ﴾</span>: يَخْضَعْ ويُطِعْ.</p><p><span class="qpc-hafs">﴿أَعۡتَدۡنَا﴾</span>: أعْدَدْنا وهَيَّأنا.</p><p><span class="qpc-hafs">﴿رِزۡقࣰا كَرِيمࣰا﴾</span>: وهو الجنَّةُ.</p></div>"
  33,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَلَا تَخۡضَعۡنَ بِٱلۡقَوۡلِ﴾</span>: فلا تُلِنَّ القولَ والحديثَ للرِّجال.</p><p><span class="qpc-hafs">﴿مَرَضࣱ﴾</span>: فُجُورٌ ومَيْلٌ إلى المعْصِيَةِ.</p><p><span class="qpc-hafs">﴿مَّعۡرُوفࣰا﴾</span>: مُعْتَدِلًا بعِيدًا عَنِ الرِّيبةِ والشَّكِّ.</p></div>"
  33,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَرۡنَ﴾</span>: والزَمْنَ.</p><p><span class="qpc-hafs">﴿وَلَا تَبَرَّجۡنَ﴾</span>: ولا تُظْهِرْنَ محاسِنَكُنَّ.</p><p><span class="qpc-hafs">﴿ٱلۡجَـٰهِلِيَّةِ ٱلۡأُولَىٰ﴾</span>: أي: التي كانتْ قَبْلَ الإسْلامِ.</p><p><span class="qpc-hafs">﴿ٱلرِّجۡسَ﴾</span>: الأذىَ والسُّوءَ والخُبْثَ.</p></div>"
  33,34,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَٱلۡحِكۡمَةِ﴾</span>: السُّنَّةِ النَّبَويَّةِ.</p></div>"
  33,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱلۡقَـٰنِتِينَ﴾</span>: المطِيعِينَ الخاضِعِينَ للهِ.</p><p><span class="qpc-hafs">﴿وَٱلۡحَـٰفِظِينَ فُرُوجَهُمۡ﴾</span>: أي: عَنِ الزِّنى ومُقَدِّماتِه.</p><p><span class="qpc-hafs">﴿أَعَدَّ﴾</span>: هيَّأ.</p><p><span class="qpc-hafs">﴿أَجۡرًا عَظِيمࣰا﴾</span>: ثوابًا عَظِيمًا، وهو الجنّةُ.</p></div>"