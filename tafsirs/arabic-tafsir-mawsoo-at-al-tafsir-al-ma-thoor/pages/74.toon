tafsir[56]{c,v,t}:
  74,1,"مقدمة السورة٧٩٥٨١- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة المُدَّثِّر بمكة{1}. (١٥/٦١)٧٩٥٨٢- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٦١)٧٩٥٨٣- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكّيّة، ونزلت بعد: ﴿يا أيُّها المُزَّمِّل﴾{3}. (ز)٧٩٥٨٤- عن عكرمة مولى ابن عباس= (ز)٧٩٥٨٥- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)٧٩٥٨٦- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)٧٩٥٨٧- عن محمد بن مسلم الزُّهريّ: مكّيّة،، وذكرها بمسمّى: ﴿يا أيها المُدَّثِّر﴾، وأنها نزلت بعد: ﴿يا أيُّها المُزَّمِّل﴾{6}. (ز)٧٩٥٨٨- عن علي بن أبي طلحة: مكّيّة{7}. (ز)٧٩٥٨٩- قال مقاتل بن سليمان: سورة المُدَّثِّر مكّيّة، عددها ست وخمسون آية كوفي{8}٦٨٦٣. (ز)٦٨٦٣ قال ابن عطية (٨/٤٥٠): «وهي مكّيّة بإجماع من أهل التأويل»."
  74,2,"﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١ قُمۡ فَأَنذِرۡ ۝٢﴾ - نزول الآيات٧٩٥٩٠- عن يحيى بن أبي كَثِير، قال: سألتُ أبا سَلمة بن عبد الرحمن عن أول ما نَزَل من القرآن. فقال: ﴿يا أيُّها المُدَّثِّر﴾. قلتُ: يقولون: ﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾. فقال أبو سَلمة: سألتُ جابر بن عبد الله عن ذلك، قلتُ له مثل ما قلتَ، قال جابر: لا أُحدِّثك إلا ما حَدَّثنا رسول الله ﷺ، قال: «جاورتُ بحِراء، فلمّا قَضيتُ جواري هبَطتُ، فنُوديتُ، فنَظرتُ عن يميني، فلم أرَ شيئًا، ونظرتُ عن شمالي، فلم أرَ شيئًا، ونظرتُ خلفي، فلم أرَ شيئًا، فرفعتُ رأسي فإذا المَلَك الذي جاءني بحِراء جالس على كرسي بين السماء والأرض، فجُئِثْتُ{1} منه رُعبًا، فرجعتُ فقلتُ: دَثِّروني، فدَثَّروني»، فنزلت: ﴿يا أيُّها المُدَّثِّر قُمْ فَأَنْذِرْ﴾ إلى قوله: ﴿والرُّجْزَ فاهْجُرْ﴾{2}٦٨٦٤. (١٥/٦١)٦٨٦٤ رجّح ابنُ كثير (١٤/١٧٦) بهذا الأثر أنّ الآيات الأولى من سورة اقرأ هي أول آيات القرآن نزولًا، حيث قال معلقًا على هذا الأثر: «هذا السياق هو المحفوظ، وهو يقتضي أنه قد نَزل الوحي قبل هذا؛ لقوله: «فإذا المَلَك الذي جاءني بحِراء». وهو جبريل حين أتاه بقوله: ﴿اقرأ باسم ربك الذي خلق ...﴾، ثم إنه حَصل بعد هذا فترة، ثم نزل الملك بعد هذا». ثم وجّه ما جاء في بعض الروايات عن جابر وتفيد أنّ آيات المُدَّثِّر هي أول آيات القرآن نزولًا بقوله: «ووجه الجمع: أنّ أول شيء نَزل بعد فترة الوحي هذه السورة».وبنحوه قال ابنُ تيمية (٦/٤١٩).٧٩٥٩١- عن عبد الله بن عباس -من طريق ابن أبي مُلَيْكَة-: أنّ الوليد بن المُغيرة صَنع لقريش طعامًا، فلمّا أكلوا قال: ما تقولون في هذا الرجل؟ فقال بعضهم: ساحر. وقال بعضهم: ليس بساحر. وقال بعضهم: كاهن. وقال بعضهم: ليس بكاهن. وقال بعضهم: شاعر. وقال بعضهم: ليس بشاعر. وقال بعضهم: سحرٌ يُؤثر. فاجتمع رأيهم على أنه سحرٌ يُؤثر، فبَلغ ذلك النبيَّ ﷺ، فحَزن، وقنَّع رأسه، وتَدثّر؛ فأنزل الله: ﴿يا أيُّها المُدَّثِّر﴾ إلى قوله: ﴿ولِرَبِّكَ فاصْبِرْ﴾{3}. (١٥/٦٢)٧٩٥٩٢- عن إبراهيم النَّخَعي -من طريق المُغيرة- ﴿يا أيُّها المُدَّثِّر﴾، قال: كان مُتَدَثِّرًا في قَطيفة، وذُكر أنّ هذه الآية أول شيء نَزل من القرآن على رسول الله ﷺ، وأنه قيل له: ﴿يا أيُّها المُدَّثِّر﴾{4}. (ز)٧٩٥٩٣- عن محمد ابن شهاب الزُّهريّ -من طريق معمر- قال: فَتَر الوحيُ عن رسول الله ﷺ فَتْرةً، فحَزِن حُزنًا، فجعل يعدو إلى شواهق رؤوس الجبال ليَتَردّى منها، فكلّما أوفى بذُروة جبل تبَدّى له جبريل ﵇، فيقول: إنّك نبي الله. فيَسكن لذلك جأْشه، وتَرجع إليه نفسه؛ فكان النبي ﷺ يُحدِّث عن ذلك، قال: «فبينما أنا أمشي يومًا إذ رأيتُ المَلَك الذي كان يأتيني بحِراء على كرسي بين السماء والأرض، فجُثِثْتُ{5} منه رُعبًا، فرَجعتُ إلى خديجة، فقلتُ: زَمِّلُوني». فزَمَّلناه، أي: فدَثَّرناه؛ فأنزل الله: ﴿يا أيُّها المُدَّثِّر قُمْ فَأَنْذِرْ ورَبَّكَ فَكَبِّرْ وثِيابَكَ فَطَهِّرْ﴾. قال الزُّهريّ: فكان أول شيء أُنزل عليه: ﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾ حتى بلغ: ﴿ما لَمْ يَعْلَمْ﴾{6}٦٨٦٥. (ز)٦٨٦٥ لم يذكر ابن جرير (٢٣/٤٠٠-٤٠٣) غير قول الزُّهريّ، وإبراهيم النَّخَعي.٧٩٥٩٤- عن محمد ابن شهاب الزُّهريّ أنه قال: ... ويزعم ناسٌ أنّ ﴿يا أيها المُدَّثِّر﴾ أول سورة أُنزِلَتْ عليه، والله أعلم{7}. (ز)٧٩٥٩٥- قال مقاتل بن سليمان: ﴿يا أيُّها المُدَّثِّر﴾، يعني: النبي ﷺ، وذلك أنّ كفار مكة آذَوه، فانطَلق إلى جبل حِراء ليتوارى عنهم، فبينما هو يمشي إذ سمع مناديًا يقول: يا محمد. فنظر يمينًا وشمالًا وإلى السماء، فلم يرَ شيئًا، فمَضى على وجهه، فنُودي الثانية: يا محمد. فنظر يمينًا وشمالًا ومن خلفه، فلم يرَ شيئًا إلا السماء، ففَزع، وقال: لعلّ هذا شيطان يدعوني. فمَضى على وجهه، فنودي في قفاه: يا محمد، يا محمد. فنظر خلفه وعن يمينه وعن شماله، ثم نظر إلى السماء، فرأى مثل السرير بين السماء والأرض، وعليه دَرْبوكة{8} قد غَطَّت الأُفُق، وعليه جبريل ﵇ مثل النور المتوقِّد يتلألأ، حتى كاد أن يَغشى البصر، ففَزع فزعًا شديدًا، ثم وقَع مغشيًّا عليه، ولبث ساعة، ثم أفاق، فقام يمشي -وبه رِعْدة شديدة، ورِجلاه تَصطكّان- راجعًا حتى دخل على خديجة، فدعا بماء، فصَبّه عليه، فقال: دثِّروني. فدَثَّروه بقَطيفة حتى استدفأ، فلمّا أفاق قال: لقد أشفقتُ على نفسي. قالت له خديجة: أبشِر، فواللهِ، لا يسوءُك الله أبدًا؛ لأنك تَصدق الحديث، وتَصِل الرَّحِم، وتَحمل الكَلّ، وتَقري الضيف، وتُعين على نوائب الخير. فأتاه جبريل ﵇ وهو مُتَقنِّع بالقَطيفة، فقال: يا أيها المُتَدَثِّر بقَطيفته، المُتَقَنِّع فيها{9}. (ز)٧٩٥٩٦- قال يحيى بن سلّام: قال جابر بن عبد الله: ﴿يا أيُّها المُدَّثِّر﴾ هذه أول آية نزلت على النبي، والعامّة على أنّ أول ما نَزل: ﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾{10}٦٨٦٦. (ز)٦٨٦٦ في أول آيات القرآن نزولًا قولان، كما في قول يحيى بن سلام.وقد رجح ابنُ عطية (٨/٤٥١) -مستندًا إلى السنة- أن الآيات الأولى من سورة اقرأ هي أول القرآن نزولًا، فقال: «واختلف الناس في أول ما نزل من كتاب الله تعالى؛ فقال جابر بن عبد الله، وأبو سلمة، والنَّخَعي، ومجاهد هو: ﴿يا أيُّها المُدَّثِّر﴾ الآيات. وقال الزُّهريّ، والجمهور هو: ﴿اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ﴾، وهذا هو الأصح، وحديث صدر كتاب البخاري نص في ذلك».٧٩٥٩٧- قال ابن هشام: حَدَّثني بعض أهل العلم: أنّ أشدّ ما لقي رسول الله ﷺ من قريش أنه خرج يومًا فلم يَلقه أحد من الناس إلا كَذَّبه وآذاه، لا حرٌّ ولا عبدٌ، فرجع رسول الله ﷺ إلى منزله، فتَدثَّر من شدّة ما أصابه؛ فأَنزل الله تعالى عليه: ﴿يا أيها المُدَّثِّر قم فأنذر﴾{11}. (ز)﴿یَـٰۤأَیُّهَا ٱلۡمُدَّثِّرُ ۝١﴾ - تفسير٧٩٥٩٨- عن عبد الله بن عباس -من طريق عكرمة- ﴿يا أيُّها المُدَّثِّر﴾، قال: دُثِّرْتَ هذا الأمرَ، فقُم به{12}. (١٥/٦٣)٧٩٥٩٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿يا أيُّها المُدَّثِّر﴾، قال: النائم{13}. (١٥/٦٤)٧٩٦٠٠- عن إبراهيم النَّخَعي-من طريق المغيرة- ﴿يا أيُّها المُدَّثِّر﴾، قال: كان مُتَدَثِّرًا في قَطيفة، يعني: شَملة صغيرة الخَمْلِ{14}. (١٥/٦٣)٧٩٦٠١- عن عكرمة مولى ابن عباس -من طريق داود- في قوله: ﴿يا أيُّها المُدَّثِّر﴾، أنه قال: دُثِّرْتَ هذا الأمر فقُم به{15}. (ز)٧٩٦٠٢- عن قتادة بن دعامة -من طريق سعيد- ﴿يا أيُّها المُدَّثِّر﴾، قال: المُتَدَثِّر في ثيابه{16}. (١٥/٦٣)٧٩٦٠٣- قال مقاتل بن سليمان: ﴿يا أيُّها المُدَّثِّر﴾ يعني: النبي ﷺ ... أتاه جبريل ﵇ وهو مُتَقنِّع بالقَطيفة، فقال: يا أيها المُتَدَثِّر بقَطيفته، المُتَقَنِّع فيها{9}. (ز)﴿قُمۡ فَأَنذِرۡ ۝٢﴾ - تفسير٧٩٦٠٤- عن قتادة بن دعامة -من طريق سعيد- ﴿قُمْ فَأَنْذِرْ﴾، قال: أنذِر عذابَ ربك، ووقائعَه في الأمم، وشدّة نِقمته إذا انتقم{16}. (١٥/٦٣)٧٩٦٠٥- قال مقاتل بن سليمان: ﴿قُمْ فَأَنْذِرْ﴾ كفارَ مكةَ العذابَ إن لم يُوحِّدوا الله تعالى{9}. (ز)"
  74,3,"﴿وَرَبَّكَ فَكَبِّرۡ ۝٣﴾ - تفسير٧٩٦٠٦- عن أبي مالك غَزْوان الغفاري، ﴿ورَبَّكَ فَكَبِّرْ﴾، قال: عَظِّم{1}. (١٥/٦٤)٧٩٦٠٧- قال مقاتل بن سليمان: ﴿ورَبَّكَ فَكَبِّرْ﴾ يعني: فعَظِّم، ولا تعظمن كفار مكة في نفسك. فقام من مضجعه ذلك، فقال: «الله أكبر كبيرًا». فكبّرتْ خديجة، وخَرجتْ، وعَلمتْ أنه قد أُوحي إليه{2}. (ز)"
  74,4,"﴿وَثِیَابَكَ فَطَهِّرۡ ۝٤﴾ - تفسير٧٩٦٠٨- قال أُبيّ بن كعب: ﴿وثِيابَكَ فَطَهِّرْ﴾ لا تلبسها على غَدرٍ، ولا على ظُلمٍ، ولا إثم، البسْها وأنت بَرٌّ جواد طاهر{1}. (ز)٧٩٦٠٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: لا تَكُن ثيابُك التي تلبِس من مَكْسِبة{2} باطل{3}. (١٥/٦٤)٧٩٦١٠- عن عبد الله بن عباس -من طريق عطاء- ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: من الإثم. قال: وهي في كلام العرب: نقيُّ الثياب{4}. (١٥/٦٤)٧٩٦١١- عن عبد الله بن عباس، في قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: مِن الغدر، لا تَكُن غدّارًا{5}. (١٥/٦٥)٧٩٦١٢- عن عبد الله بن عباس، ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: لستَ بساحر، ولا كاهن{5}. (١٥/٦٦)٧٩٦١٣- عن عكرمة: أنّ عبد الله بن عباس سُئل عن قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾. قال: لا تَلبسها على غَدْرةٍ، ولا فَجْرةٍ. ثم قال: ألا تسمعون قول غَيلان بن سَلمة:وإني بحمد الله لا ثوبَ فاجرٍ لَبِستُ ولا من غَدْرةٍ أتقنّع{7}. (١٥/٦٥)٧٩٦١٤- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق منصور- ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: عمَلك أصلِحْهُ، كان أهل الجاهلية إذا كان الرجل حسنَ العمل قالوا: فلانٌ طاهر الثياب{8}. (١٥/٦٥)٧٩٦١٥- عن سعيد بن جُبَير، قال: كان الرجل في الجاهلية إذا كان غدّارًا قالوا: فلانٌ دَنِسُ الثياب{9}. (١٥/٦٥)٧٩٦١٦- قال سعيد بن جُبَير: ﴿وثِيابَكَ فَطَهِّرْ﴾ وقلبك ونيَّتك فطهِّر{10}. (ز)٧٩٦١٧- عن إبراهيم النَّخَعي، ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: مِن الإثم{11}. (١٥/٦٣)٧٩٦١٨- عن مجاهد بن جبر -من طريق منصور- في قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: وعمَلَك فأصلِح{12}. (١٥/٦٦)٧٩٦١٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: لستَ بكاهن، ولا ساحر؛ فأَعرِض عما قالوا{13}. (١٥/٦٦)٧٩٦٢٠- عن مجاهد بن جبر، ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: ليس ثيابه الذي يَلبس{14}. (١٥/٦٦)٧٩٦٢١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾، يقول: لا تَلبس ثيابك على معصية{15}. (ز)٧٩٦٢٢- عن الضَّحّاك بن مُزاحِم-من طريق أبي روق- ﴿وثِيابَكَ فَطَهِّرْ﴾: وعمَلك فأصلِح{16}. (ز)٧٩٦٢٣- عن عكرمة مولى ابن عباس -من طريق الأَجْلَح- قال: لا تَلبس ثيابك على معصية{17}. (ز)٧٩٦٢٤- عن أبي مالك غَزْوان الغفاري، ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: عَنى نفسه{14}. (١٥/٦٦)٧٩٦٢٥- عن عامر الشعبي= (ز)٧٩٦٢٦- وعطاء -من طريق جابر- قالا: من الخطايا{17}. (ز)٧٩٦٢٧- قال طاووس بن كيسان: ﴿وثِيابَكَ فَطَهِّرْ﴾ وثيابك فقصِّر؛ لأنّ تقصير الثياب طُهرةٌ لها{10}. (ز)٧٩٦٢٨- عن الحسن البصري، في قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: خُلُقك فحَسِّنه{21}. (١٥/٦٦)٧٩٦٢٩- عن محمد بن سيرين -من طريق ابن عون- ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: اغسلها بالماء{22}. (١٥/٦٧)٧٩٦٣٠- عن قتادة بن دعامة -من طريق سعيد- ﴿وثِيابَكَ فَطَهِّرْ﴾، يقول: طهِّرها من المعاصي، وهي كلمة عربية، كانت العرب إذا نَكث الرجل ولم يُوفِ بعهده قالوا: إنّ فلانًا لَدَنِسُ الثياب. وإذا وفى وأَصلَح قالوا: إنّ فلانًا لَطاهرُ الثياب{23}. (١٥/٦٣)٧٩٦٣١- قال محمد بن كعب القُرَظيّ: ﴿وثِيابَكَ فَطَهِّرْ﴾ وخُلقك فحسِّن{10}. (ز)٧٩٦٣٢- عن محمد ابن شهاب الزُّهريّ: ﴿وثِيابَكَ فَطَهِّرْ﴾ نفسك فطهِّر عن الذّنب{25}. (ز)٧٩٦٣٣- قال إسماعيل السُّدِّيّ: ﴿وثِيابَكَ فَطَهِّرْ﴾ يقال للرجل إذا كان صالحًا: إنّه لَطاهرُ الثياب، وإذا كان فاجرًا: إنّه لَخبيث الثياب{16}. (ز)٧٩٦٣٤- عن يزيد بن مَرثَد، في قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾: أنه أُلقي على رسول الله ﷺ سلا{27} شاة{21}. (١٥/٦٧)٧٩٦٣٥- قال مقاتل بن سليمان: ﴿وثِيابَكَ فَطَهِّرْ﴾، يقول: طهِّر بالتوبة من المعاصي. وكانت العرب تقول للرجل إذا أذنب: إنّه دَنِس الثياب، وإذا تَوقّى قالوا: إنّه لَطاهرُ الثياب{29}. (ز)٧٩٦٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿وثِيابَكَ فَطَهِّرْ﴾، قال: كان المشركون لا يَتطهَّرون، فأمره أن يَتطهَّر، ويُطهِّر ثيابه{30}٦٨٦٧. (ز)٦٨٦٧ اختُلف في قوله: ﴿وثيابك فطهر﴾ على أقوال: الأول: لا تَلبس ثيابك على معصية، ولا على غَدْرة. الثاني: لا تَلبس ثيابك من مَكسبٍ غير طيّب. الثالث: أصلِح عملك. الرابع: اغسلها بالماء، وطهِّرها من النجاسة. الخامس: حَسِّن خُلقك. السادس: طهِّر قلبك ونيّتك.وعلّق ابنُ عطية (٨/٤٥٢) على القول الأول والثاني بقوله: «وهذا كلّه معنًى قريب بعضه من بعض».وقد رجّح ابنُ جرير (٢٣/٤٠٩-٤١٠) -مستندًا إلى أنه الأظهر- القول الرابع، فقال: «وهذا القول الذي قاله ابن سيرين، وابن زيد في ذلك أظهر معانيه». ثم قال معلقًا: «والذي قاله ابن عباس، وعكرمة، ومَن ذكرنا قوله عليه أكثر السلف من أنه عني به: جسمك فطَهِّر من الذّنوب. والله أعلم بمراده من ذلك».ولم يذكر ابنُ تيمية (٦/٤٢٠-٤٢٢) غير القول الثالث والرابع، ورجّح أنّ الآية تعمّهما، فقال: «والأشبه -والله أعلم- أنّ الآية تعمُّ نوعي الطهارة، وتشمل هذا كلَّه، فيكون مأمورًا بتطهير الثياب المتضمّنة تطهير البدن والنفس مِن كلّ ما يُستقذر شرعًا مِن الأعيان والأخلاق والأعمال؛ لأنّ تطهيرها أن تُجعل طاهرة، ومتى اتصل بها وبصاحبها شيءٌ مِن النجاسة لم تكن مُطهّرة على الإطلاق؛ فإنها متى أُزيل عنها نَجسٌ دون نَجس لم تكن قد طَهرتْ حتى يزال عنها كلّ نَجس، بل كلّ ما أمر الله باجتنابه من الأرجاس وجَب التطهير منه، وهو داخل في عموم هذا الخطاب»."
  74,5,"﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ ۝٥﴾ - قراءات٧٩٦٣٧- عن جابر بن عبد الله، قال: سمعتُ رسول الله ﷺ يقرأ: ﴿والرُّجْزَ فاهْجُرْ﴾ برفع الراء ...{1}. (١٥/٦٧)٧٩٦٣٨- عن عبد الله بن مسعود، أنه قرأ على رسول الله ﷺ: ‹والرِّجْزَ فاهْجُرْ› بالكسر{2}. (١٥/٦٧)٧٩٦٣٩- عن أبي محمد يحيى بن زكريا الكوفي -ويُعرف بابن أبي الحواجب-، قال: كنت آخِذًا بيد الأعمش أقوده، فقلت له: كيف تقرأ: ﴿والرُّجْزَ فاهْجُرْ﴾ أو ‹والرِّجْزَ فاهْجُرْ›؟ فقال: أوَهمَّك ذلك؟ قرأتُ القرآن على يحيى بن وثّاب ثلاثين مرة كلّه يقرأ كذلك، وكذلك قرأ يحيى على عَلقمة، وكذلك قرأ عَلقمة على ابن مسعود، وابن مسعود على رسول الله ﷺ، يعني: ﴿الرُّجْزَ﴾ بالضم{3}. (ز)٧٩٦٤٠- عن الحسن البصري، أنه كان يقرؤها: ﴿والرُّجْزَ فاهْجُرْ﴾ بالرفع ...{4}٦٨٦٨. (١٥/٦٧)٦٨٦٨ ذكر ابن جرير (٢٣/٤١٠) قراءة الرفع والكسر، ووجّههما، فقال: «فمَن ضَم الراء وجّهه إلى الأوثان، وقال: معنى الكلام: والأوثان فاهجُر عبادتها، واترك خدمتها. ومَن كسر الراء وجّهه إلى العذاب، وقال: معناه: والعذاب فاهجُر. أي: ما أوجب لك العذاب من الأعمال فاهجُر». وعلّق عليهما قائلًا: «والصواب من القول في ذلك أنهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب، والضم والكسر في ذلك لغتان بمعنًى واحد، ولم نجد أحدًا من متقدمي أهل التأويل فَرّق بين تأويل ذلك، وإنما فَرّق بين ذلك فيما بلغنا الكسائي».وعلّق ابنُ عطية (٥/٣٩٣ ط: دار الكتب العلمية بتصرف) على القراءتين بقوله: «قيل: هما بمعنًى، يراد بهما: الأصنام والأوثان، وقيل: هما لمعنيين: الكسر للنّتن والنقائص وفُجور الكفار، والضم لصنمين إساف ونائلة».﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ ۝٥﴾ - تفسير الآية٧٩٦٤١- عن جابر بن عبد الله، قال: سمعتُ رسول الله ﷺ يقرأ: ﴿والرُّجْز فاهْجُرْ﴾ برفع الراء، وقال: «هي الأوثان»{5}. (١٥/٦٧)٧٩٦٤٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿والرُّجْزَ فاهْجُرْ﴾، قال: الأصنام{6}. (١٥/٦٤)٧٩٦٤٣- عن عبد الله بن عباس، ﴿والرُّجْزَ فاهْجُرْ﴾: معناه: اترك المآثم{7}٦٨٦٩. (ز)٦٨٦٩ ذكر ابنُ عطية (٨/٤٥٢) قولًا آخر عن ابن عباس، فقال: «وقال ابن عباس: الرُّجز: السخط». ثم وجّهه بقوله: «فالمعنى: اهجر ما يؤدي إليه، ويُوجبه».٧٩٦٤٤- قال أبو العالية الرِّياحيّ= (ز)٧٩٦٤٥- والربيع بن أنس: ﴿الرُّجز﴾ -بضم الراء-: الصنم. -وبالكسر-: النجاسة والمعصية{8}. (ز)٧٩٦٤٦- عن إبراهيم النَّخَعي -من طريق مغيرة- ﴿والرُّجْزَ فاهْجُرْ﴾، قال: الإثم{9}. (١٥/٦٣)٧٩٦٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿والرُّجْزَ فاهْجُرْ﴾، قال: الأوثان{10}. (١٥/٦٦)٧٩٦٤٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿والرُّجْزَ فاهْجُرْ﴾، يقول: اهجر المعصية{11}. (ز)٧٩٦٤٩- قال الضَّحّاك بن مُزاحِم: ﴿والرُّجْزَ فاهْجُرْ﴾، يعني: الشّرك{7}. (ز)٧٩٦٥٠- عن أبي مالك غَزْوان الغفاري، ﴿والرُّجْزَ فاهْجُرْ﴾، قال: الشيطان، والأوثان{13}. (١٥/٦٤)٧٩٦٥١- عن عكرمة مولى ابن عباس -من طريق جابر- ﴿والرُّجْزَ فاهْجُرْ﴾، قال: الأوثان{14}. (ز)٧٩٦٥٢- عن الحسن البصري أنه كان يقرؤها: ﴿والرُّجْزَ فاهْجُرْ﴾ بالرفع، وقال: هي الأوثان{4}. (١٥/٦٧)٧٩٦٥٣- عن قتادة بن دعامة -من طريق سعيد- ﴿والرُّجْزَ فاهْجُرْ﴾، قال: هما صنمان كانا عند البيت؛ إساف ونائلة، يَمسح وجوههما مَن أتى عليهما من المشركين، فأمر الله نبيَّه ﷺ أن يَهجرهما ويُجانبهما{16}. (١٥/٦٣)٧٩٦٥٤- عن محمد ابن شهاب الزُّهريّ -من طريق معمر- ﴿والرُّجْزَ فاهْجُرْ﴾، قال: هي الأوثان{17}. (ز)٧٩٦٥٥- عن عطاء الخراساني -من طريق يونس بن يزيد- ﴿والرجز فاهجر﴾، قال: الأوثان{18}. (ز)٧٩٦٥٦- قال محمد بن السّائِب الكلبي: ﴿والرُّجْزَ فاهْجُرْ﴾، يعني: العذاب{7}. (ز)٧٩٦٥٧- قال مقاتل بن سليمان: ﴿والرُّجْزَ فاهْجُرْ﴾ يعني: الأوثان؛ يساف ونائلة، وهما صنمان عند البيت، يَمسح وجوهَهما مَن مَرّ بهما مِن كفار مكة، فأمَر الله -تبارك وتعالى- النبيَّ ﷺ أن يجتنبهما. يعني بالرجز: أوثانًا لا تَتحرّك، بمنزلة الإبل، يعني: داء يأخذها ذلك الداء فلا تَتحرّك مِن وجع الرّجز، فشبّه الآلهة بها{20}. (ز)٧٩٦٥٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿والرُّجْزَ فاهْجُرْ﴾، قال: الرُّجز: آلهتهم التي كانوا يَعبدون، أمَره أن يَهجرها، فلا يأتيها، ولا يَقربها{14}. (ز)"
  74,6,"﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾ - قراءات٧٩٦٥٩- عن حمّاد بن أبي سليمان، قال: قرأتُ في مصحف أُبيّ [بن كعب]: (ولا تَمْنُنْ أن تَستَكْثِر){1}. (١٥/٦٨)٧٩٦٦٠- قال يحيى بن سلام: وكان الحسن البصري يقرؤها: (تَسْتَكْثِرْ) موقوفة{2}٦٨٧٠. (ز)٦٨٧٠ علق ابنُ عطية (٨/٣٩٣ ط: دار الكتب العلمية) على هذه القراءة، فقال: «وقرأ الحسن بن أبي الحسن: (تَسْتَكْثِرْ) بجزم الراء، وذلك كأنه قال: لا تَسْتَكْثِرْ».﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ ۝٦﴾ - تفسير الآية٧٩٦٦١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ الرجل عطاءً رجاءَ أن يُعطيك أكثر منه{3}. (١٥/٦٨)٧٩٦٦٢- عن عبد الله بن عباس، ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾ قال: لا تَقُلْ: قد دَعوتُهم فلم يُقبل مني. عُد، فادْعُهم، ﴿ولِرَبِّكَ فاصْبِرْ﴾ على ذلك{4}. (١٥/٦٩)٧٩٦٦٣- عن عبد الله بن عمر -من طريق نافع- ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ شيئًا تَطلب أكثر منه{5}. (ز)٧٩٦٦٤- عن أبي الأَحْوَص= (ز)٧٩٦٦٥- وضَمْرة بن حبيب -من طريق أرطاة- في قوله: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ شيئًا لِتُعطى أكثر منه{6}. (ز)٧٩٦٦٦- عن إبراهيم النَّخَعي -من طريق مُغيرة- ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ شيئًا لِتُعطى أكثرَ منه{7}. (١٥/٦٣)٧٩٦٦٧- قال مجاهد بن جبر: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾ كان هذا للنبيِّ ﷺ خاصة{8}. (ز)٧٩٦٦٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ مُصانعةً؛ رجاء أفضل منه من الثواب{9}. (١٥/٦٦)٧٩٦٦٩- عن مجاهد بن جبر -من طريق خُصَيف- في قوله: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تَضْعُف أن تَستَكْثِر من الخير. قال: ﴿تَمْنُن﴾ في كلام العرب: تَضْعُف{10}. (ز)٧٩٦٧٠- عن مجاهد بن جبر، ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعَظِّم عملَك في عينك أن تَستَكْثِر من الخير{11}. (١٥/٦٨)٧٩٦٧١- قال الضَّحّاك بن مُزاحِم -من طريق أبي حُجَيرة-: هما رِبَوان؛ حلال وحرام، فأمّا الحلال فالهدايا، وأمّا الحرام فالربا{12}. (ز)٧٩٦٧٢- عن الضَّحّاك بن مُزاحِم، ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ شيئًا لتُعطى أكثر منه، وهي للنبي ﷺ خاصة، والناس مُوَسَّع عليهم{13}. (١٥/٦٨)٧٩٦٧٣- عن عكرمة مولى ابن عباس: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، يقول: ولا تُعطِ شيئًا لتُعطى أكثر منه، وإنما نزل هذا في النبيِّ ﷺ{14}. (١٥/٦٨)٧٩٦٧٤- قال طاووس بن كيسان -من طريق ابنه-= (ز)٧٩٦٧٥- وقتادة بن دعامة -من طريق معمر - ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ شيئًا لتُثاب أفضل منه{15}. (ز)٧٩٦٧٦- عن الحسن البصري، (ولا تَمْنُن تَسْتَكْثِرْ)، قال: لا تَستَكْثِر عملك{16}. (١٥/٦٨)٧٩٦٧٧- عن قتادة بن دعامة -من طريق سعيد- ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تُعطِ شيئًا لمثابة الدنيا، ولا لِمُجازاة الناس{17}. (١٥/٦٣)٧٩٦٧٨- قال محمد بن كعب القُرَظيّ: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾ لا تُعطِ مالَك مُصانعة{18}. (ز)٧٩٦٧٩- عن الربيع بن أنس -من طريق أبي جعفر- قوله: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا يَكثُر عملك في عينك، فإنه فيما أنعم الله عليك وأعطاك قليل{19}. (ز)٧٩٦٨٠- قال مقاتل بن سليمان: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، يقول: ولا تُعطِ عطيةً لِتُعطى أكثر من عَطِيّتك{20}. (ز)٧٩٦٨١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿ولا تَمْنُنْ تَسْتَكْثِرُ﴾، قال: لا تَمْنُن بالنبوة والقرآن الذي أرسلناك به تَسْتَكْثِرهم به، تأخذ عليه عِوضًا من الدنيا{10}٦٨٧١. (ز)٦٨٧١ اختُلف في قوله: ﴿ولا تمنن تستكثر﴾ على أقوال: الأول: ولا تُعطِ -يا محمد- عَطِيّة لِتُعطى أكثر منها. الثاني: ولا تَمْنُن عملك على ربّك تَسْتَكْثِر. الثالث: لا تَضْعُف أن تَسْتَكْثِر من الخير. الرابع: لا تَمْنُن بالنبوة على الناس، تأخذ عليه منهم أجرًا.ووجّه ابنُ عطية (٨/٤٥٣) القول الأول، فقال: «فكأنه من قولهم: مَنَّ إذا أعطى، وقال الضَّحّاك: وهذا خاصٌّ بالنبي ﵇، ومباح لأُمّته، لكن لا أجر لهم فيه. قال مكي: وهذا معنى قوله تعالى: ﴿وما آتَيْتُمْ مِن رِبًا لِيَرْبُوا فِي أمْوالِ النّاسِ فَلا يَرْبُوا عِنْدَ اللَّهِ﴾ [الروم:٣٩]». وانتقده مستندًا للسياق، فقال: «وهذا معنًى أجنبي مِن معنى هذه السورة». وعلّق على القول الثاني بقوله: «ففي هذا التأويل تحريض على الجد، وتخويف». وعلّق على القول الثالث، فقال: «وقال مجاهد: معناه: ولا تَضْعُف تَسْتَكْثِر ما حمّلناك من أعباء الرسالة وتَسْتَكْثِر من الخير. فهذه من قولهم: حبل منين، أي: ضعيف».وقد رجح ابنُ جرير (٢٣/٤١٧) -مستندًا إلى السياق، والقراءات- القول الثاني، فقال: «وإنما قلتُ ذلك أولى بالصواب؛ لأن ذلك في سياق آيات تَقدّم فيهنّ أمْر الله نبيّه ﷺ بالجد في الدعاء إليه، والصبر على ما يَلقى من الأذى فيه، فهذه بأن تكون من أنواع تلك أشبه منها بأن تكون من غيرها. وذكر عن عبد الله بن مسعود أنّ ذلك في قراءته: (ولا تَمْنُنْ أن تَسْتَكْثِر)»."
  74,7,"﴿وَلِرَبِّكَ فَٱصۡبِرۡ ۝٧﴾ - تفسير٧٩٦٨٢- عن إبراهيم النَّخَعي -من طريق مُغيرة- ﴿ولِرَبِّكَ فاصْبِرْ﴾، قال: إذا أعطيتَ عَطِيّةً فأَعطِها لربّك، واصبر حتى يكون هو الذي يُثيبُك{1}. (١٥/٦٣)٧٩٦٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿ولِرَبِّكَ فاصْبِرْ﴾، قال: على ما أُوذيتَ{2}. (١٥/٦٦)٧٩٦٨٤- قال زيد بن أسلم: ﴿ولِرَبِّكَ فاصْبِرْ﴾ إذا أعطيتَ عَطِيّة فأَعطِها لربّك، واصبر حتى يكون هو الذي يُثيبُك عليها{3}. (ز)٧٩٦٨٥- قال مقاتل بن سليمان: ﴿ولِرَبِّكَ فاصْبِرْ﴾ يُعزِّي نبيَّه ﷺ ليَصبر على الأذى والتكذيب من كفار مكة{4}٦٨٧٢. (ز)٦٨٧٢ قال ابنُ جرير (٢٣/٤١٧): «وقوله: ﴿ولربك فاصبر﴾ يقول -تعالى ذِكْره-: ولربك فاصبر على ما لَقِيتَ فيه من المكروه. وبنحو الذي قلنا في ذلك قال جماعة من أهل التأويل على اختلاف فيه بين أهل التأويل». ثم ذكر قول مجاهد، وابن زيد، وإبراهيم النَّخَعي.٧٩٦٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿ولِرَبِّكَ فاصْبِرْ﴾، قال: حُمِّل أمرًا عظيمًا؛ محاربة العرب، ثم العَجَم من بعد العرب في الله{5}. (ز)"
  74,8,"﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾ - تفسير٧٩٦٨٧- عن عبد الله بن عباس، قال: لَمّا نزلت: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾ قال رسول الله ﷺ: «كيف أنعَم وصاحبُ الصُّور قد التَقم القَرن، وحَنى جَبهته، يَستمع متى يُؤمر؟!». قالوا: كيف نقول، يا رسول الله؟ قال: «قولوا: حَسْبنا الله ونِعْم والوكيل، على الله توكَّلنا»{1}. (١٥/٦٩)٧٩٦٨٨- عن عبد الله بن عباس -من طريق العَوفيّ- قوله: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، قال: هو يوم يُنفخ في الصُّور الذي يُنفخ فيه. قال ابن عباس: إنّ نبي الله ﷺ خرج إلى أصحابه، فقال: «كيف أنعَم وصاحب القَرن قد التَقم القَرن، وحَنى جَبهته، ثم أقبل بأُذُنه يَستمع متى يُؤمر بالصيحة». فاشتدّ ذلك على أصحابه، فأمَرهم أن يقولوا: «حَسْبنا الله ونِعْم والوكيل، على الله توكَّلنا»{2}. (ز)٧٩٦٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، قال: الصُّور{3}. (١٥/٦٩)٧٩٦٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: ﴿النّاقور﴾ الصُّور؛ كهيئة البُوق{4}. (١٥/٦٩)٧٩٦٩١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، يعني: الصُّور{5}. (ز)٧٩٦٩٢- عن عكرمة مولى ابن عباس -من طريق أبي رجاء-= (ز)٧٩٦٩٣- وعامر الشعبي= (ز)٧٩٦٩٤- وأبي مالك غَزْوان الغفاري، مثله{6}. (١٥/٦٩)٧٩٦٩٥- قال الحسن البصري -من طريق معمر- ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، قال: إذا نُفخ في الصُّور{5}. (ز)٧٩٦٩٦- عن قتادة بن دعامة -من طريق معمر- ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، قال: فإذا نُفخ في الصُّور{8}. (١٥/٦٩)٧٩٦٩٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿فإذا نقر في الناقور﴾: والنّاقور: الصُّور، والصُّور: الخَلْق{5}. (ز)٧٩٦٩٨- عن الربيع بن أنس -من طريق أبي جعفر- قوله: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، قال: النّاقور: الصُّور{5}. (ز)٧٩٦٩٩- قال مقاتل بن سليمان: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، يعني: نُفخ في الصُّور، والنّاقور: القَرن الذي يَنفخ فيه إسرافيل، وهو الصُّور{11}. (ز)٧٩٧٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾، قال: الصُّور{5}. (ز)﴿فَإِذَا نُقِرَ فِی ٱلنَّاقُورِ ۝٨﴾ - آثار متعلقة بالآية٧٩٧٠١- عن بَهْز بن حكيم، قال: أمَّنا زُرارة بن أوْفى، فقرأ المدثِّر، فلما بلغ: ﴿فَإذا نُقِرَ فِي النّاقُورِ﴾ خرّ مَيِّتًا، فكنتُ في مَن حَمله{13}. (١٥/٧٠)"
  74,9,"﴿فَذَ ٰ⁠لِكَ یَوۡمَىِٕذࣲ یَوۡمٌ عَسِیرٌ ۝٩ عَلَى ٱلۡكَـٰفِرِینَ غَیۡرُ یَسِیرࣲ ۝١٠﴾ - تفسير٧٩٧٠٢- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿يَوْمٌ عَسِيرٌ﴾، قال: شديد{1}. (١٥/٦٩)٧٩٧٠٣- عن قتادة بن دعامة -من طريق سعيد- ﴿فَذَلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ﴾ قال: شديد، ثم بَيَّن على مَن مَشقَّتُه وعُسْرُه، فقال: ﴿عَلى الكافِرِينَ غَيْرُ يَسِيرٍ﴾{2}. (١٥/٧٠)٧٩٧٠٤- قال مقاتل بن سليمان: ﴿فَذلِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ﴾ يعني: مَشقَّتَه وشدّته، ﴿عَلى الكافِرِينَ غَيْرُ يَسِيرٍ﴾ يعني: غير هيّن، ويَهُونُ ذلك على المؤمن كأدنى صلاته{3}. (ز)"
  74,10,"74:9"
  74,11,"﴿ذَرۡنِی وَمَنۡ خَلَقۡتُ وَحِیدࣰا ۝١١﴾ الآيات - نزول الآيات٧٩٧٠٥- عن عبد الله بن عباس -من طريق عكرمة-: أنّ الوليد بن المُغيرة جاء إلى النبيِّ ﷺ، فقَرأ عليه القرآن، فكأنه رَقَّ له، فبَلغ ذلك أبا جهل، فأتاه، فقال: يا عمّ، إنّ قومك يريدون أن يجمعوا لك مالًا ليُعطوكه، فإنك أتيتَ محمدًا لتَعرَّض لِما قِبلَه. قال: قد عَلمتْ قريش أني مِن أكثرها مالًا. قال: فقُلْ فيه قولًا يَبلغ قومك أنّك مُنكِرٌ له، أو أنك كارهٌ له. قال: وماذا أقول؟ فواللهِ، ما فيكم رجل أعلم بالشِّعر مني، ولا برَجَزِهِ ولا بقِصِيده مني، ولا بأشعار الجنّ، واللهِ، ما يُشبه الذي يقول شيئًا من هذا، وواللهِ، إنّ لِقَوْله الذي يقول حلاوة، وإنّ عليه لَطُلاوة{1}، وإنه لَمُثمِرٌ أعلاه، مُغدِقٌ أسفله، وإنّه لَيَعلو وما يُعلى، وإنه ليَحْطِم ما تحته. قال: لا يرضى عنك قومك حتى تقول فيه. قال: فدعني حتى أُفكّر. فلما فَكّر قال: هذا سحرٌ يُؤثر؛ يَأْثُره عن غيره. فنَزلت: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾{2}. (١٥/٧٢)٧٩٧٠٦- عن عكرمة مولى ابن عباس -من طريق معمر، عن رجل-، مثله{3}. (ز)٧٩٧٠٧- عن عكرمة مولى ابن عباس -من طريق أيوب- في قول الوليد بن المُغيرة: إنّه يأمر بالعدل، والإحسان{4}. (ز)٧٩٧٠٨- عن عبد الله بن عباس -من طريق عطية- قال: دَخل الوليدُ بن المُغيرة على أبي بكر، فسأله عن القرآن، فلمّا أخبَره خرج على قريش، فقال: يا عجبًا لِما يقول ابنُ أبي كَبْشَة، فواللهِ، ما هو بشعرٍ، ولا بسحرٍ، ولا بهَذْي من الجنون، وإنّ قوله لَمِن كلام الله. فلمّا سمع النّفرُ مِن قريش ائتمروا، وقالوا: واللهِ، لَئِن صَبأ الوليدُ لَتَصْبأنّ قريشٌ. فلما سمع بذلك أبو جهل قال: واللهِ، أنا أكفيكم شأنَه. فانطَلق حتى دَخل عليه بيتَه، فقال للوليد: ألم ترَ قومك قد جَمعوا لك الصدقة؟ فقال: ألستُ أكثرهم مالًا وولدًا؟! فقال له أبو جهل: يَتحدَّثون أنك إنما تَدخل على ابن أبي قُحافة لِتُصيب من طعامه. فقال الوليد: لقد تَحدّث بهذا عشيرتي! فواللهِ، لا أقرب ابنَ أبي قُحافة، ولا عمر، ولا ابن أبي كَبْشَة، وما قوله إلا سحرٌ يُؤثر. فأَنزل الله: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾ إلى قوله: ﴿لا تُبْقِي ولا تَذَرُ﴾{5}. (١٥/٧٤)٧٩٧٠٩- عن عبد الله بن عباس -من طريق ابن إسحاق بسنده- قال: أنزل الله في الوليد بن المُغيرة قوله: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، وقوله: ﴿فَوَرَبِّكَ لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾ [الحجر:٩٢] إلى آخرها{6}. (ز)٧٩٧١٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، قال: نزلت في الوليد بن المُغيرة{7}. (١٥/٧١)٧٩٧١١- عن قتادة بن دعامة -من طريق معمر- أنه قال: خَرج مِن بطن أمه وحيدًا. قال: نزلت فيه هذه الآيات حتى بلغ: ﴿عليها تسعة عشر﴾{8}. (ز)٧٩٧١٢- قال مقاتل بن سليمان: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، يعني: الوليد بن المُغيرة المخزومي، كان يُسمّى: الوحيد في قومه، وذلك أنّ الله ﷿ أنزل على النبي ﷺ: ﴿حم، تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ العَلِيمِ. غافِرِ الذَّنْبِ وقابِلِ التَّوْبِ شَدِيدِ العِقابِ ذِي الطَّوْلِ لا إلهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾ [غافر:١-٣، فلما نزلت هذه الآية قام النبيُّ ﷺ في المسجد الحرام، فقرأها، والوليد بن المُغيرة قريبًا منه يستمع إلى قراءته، فلمّا فَطِن ﷺ أنّ الوليد بن المُغيرة يَستمع إلى قراءته أعاد النبيُّ ﷺ يقرأ هذه الآية: ﴿حم تَنْزِيلُ الكِتابِ مِنَ اللَّهِ العَزِيزِ﴾ إلى قوله: ﴿لا إلهَ إلّا هُوَ إلَيْهِ المَصِيرُ﴾ ... فلمّا سمعها الوليد انطلَق حتى أتى مجلس بني مخزوم، فقال: واللهِ، لَقد سمعتُ مِن محمد كلامًا آنفًا ما هو مِن كلام الإنس، ولا مِن كلام الجنّ، وإنّ أسفله لَمُغدِق، وإنّ أعلاه لَمُونقٌ، وإنّ له لَحلاوة، وإنّ عليه لَطُلاوة، وإنه لَيَعلو وما يُعلى. ثم انصرف إلى منزله، فقالت قريش: لقد صَبأ الوليد، واللهِ، لئن صَبأ لتَصبونّ قريش كلّها. وكان يقال للوليد: ريحانة قريش، فقال أبو جهل: أنا أكفيكموه. فانطلَق أبو جهل حتى دَخل على الوليد، فقعد إليه كَشَبَه الحزين، فقال له الوليد: ما لي أراك -يا ابن أخي- حزينًا؟ فقال أبو جهل: ما يمنعني أن لا أحزن وهذه قريش يَجمعون لك نفقةً لِيُعينوك على كِبَرك، ويزعمون أنك إنما زَيّنتَ قول محمد لِتُصيب مِن فضل طعامه. فغضب الوليدُ عند ذلك، وقال: أوَليس قد عَلمتْ قريشٌ أني مِن أكثرهم مالًا وولدًا، وهل يَشبع محمدٌ وأصحابُه مِن الطعام فيكون لهم فضل؟ فقال أبو جهل: فإنهم يزعمون أنك إنما زَيّنتَ قول محمد من أجل ذلك. فقام الوليد، فانطلَق مع أبي جهل، حتى أتى مجلس قومه بني مخزوم، فقال: تزعمون أنّ محمدًا كاهن، فهل سمعتموه يُخبر بما يكون في غد؟ قالوا: اللهم، لا. قال: وتزعمون أنّ محمدًا شاعر، فهل رأيتموه يَنطق فيكم بشعرٍ قطّ؟ قالوا: اللهم، لا. قال: وتزعمون أنّ محمدًا كذّاب، فهل رأيتموه يَكذب فيكم قطّ؟ قالوا: اللهم، لا. وكان يُسمّى محمد ﷺ قبل النبوة: الأمين، فبَرّأه من هذه المقالة كلّها، فقالت قريش: وما هو، يا أبا المُغيرة؟ فتفَكّر في نفسه ما يقول عن محمد ﷺ: ﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾ فقَدَّر له السحر، ﴿فَقُتِلَ﴾ يعني: لُعِن ﴿كَيْفَ قَدَّرَ﴾ لمحمد ﷺ السحر، ﴿ثُمَّ نَظَرَ ثُمَّ عَبَسَ﴾ يقول: ثم كَلَح، ﴿وبَسَرَ﴾ يعني: وتَغيّر لونه، [﴿ثم أدبر﴾]{9} يعني: أعرَض عن الإيمان، ﴿واسْتَكْبَرَ﴾ عنه، فقال الوليد لقومه: ﴿إنْ هذا﴾ الذي يقول محمد ﴿إلّا سِحْرٌ يُؤْثَرُ﴾. فقال له قومه: وما السِّحر، يا أبا المُغيرة؟ وفرحوا، فقال: شيء يكون ببابل، إذا تعلّمه الإنسان يُفرِّق بين الاثنين، ومحمد يَأْثُره ولمّا يحذقه بعدُ، وايمُ الله، لقد أصاب فيه حاجته، أما رأيتموه فَرّق بين فلان وبين أهله، وبين فلان وبين أبيه، وبين فلان وبين أخيه، وبين فلان وبين مولاه، فهذا الذي يقول محمد سحرٌ يُؤثر عن مُسَيلمة بن حبيب -الحنفي الكذّاب-. يقول: يرويه عنه، فذلك قوله: ﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ إنْ هَذا إلّا قَوْلُ البَشَرِ﴾ يقول: إنْ هذا الذي يقول محمد إلا قول البشر. قال الوليد بن المُغيرة: عن يَسار أبي فكيهة، هو الذي يأتيه به من مُسَيلمة –الكذّاب-، فجَعل الله له سَقر، وهو الباب الخامس مِن جهنم، فلمّا قال ذلك الوليد شَقّ ذلك على النبي ﷺ ما لم يشقّ عليه فيما قُذف بغيره من الكذب؛ فأَنزل الله تعالى على نبيّه ﷺ يعزيه ليَصبِر على تكذيبهم، فقال: يا محمد ﴿كَذلِكَ ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلّا قالُوا ساحِرٌ أوْ مَجْنُونٌ﴾ [الذاريات:٥٢]، وأَنزل في الوليد بن المُغيرة: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾{10}. (ز)٧٩٧١٣- تفسير الكلبي: ﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾ إلى قوله: ﴿إنْ هَذا إلّا قَوْلُ البَشَرِ﴾ أنّ الوليد بن المُغيرة قال: يا قوم، إنّ أمْر هذا الرجل -يعني: النبي ﷺ- قد فشا، وقد حضَر الموسم، وإنّ الناس سيسألونكم عنه، ... بنحو ما سبق مختصرًا{11}. (ز)٧٩٧١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾ إلى قوله: ﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾ حتى بلَغ: ﴿سَأُصْلِيهِ سَقَرَ﴾، قال: هذه الآيات أُنزِلَتْ في الوليد بن المُغيرة{12}. (ز)﴿ذَرۡنِی وَمَنۡ خَلَقۡتُ وَحِیدࣰا ۝١١﴾ - تفسير٧٩٧١٥- عن عبد الله بن عباس، ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، قال: الوليد بن المُغيرة{13}. (١٥/٧٠)٧٩٧١٦- قال عبد الله بن عباس: وكان يُسمّى: الوحيد في قومه{14}. (ز)٧٩٧١٧- عن سعيد بن جُبَير، ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾ الآيات، قال: هو الوليد بن المُغيرة بن هشام المَخزوميّ، وكان له ثلاثة عشر ولدًا، كلّهم ربّ بيت، فلما نزلت: ﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾ لم يَزل في إدبار مِن الدنيا في نفسه وماله وولده حتى أخرجه الله من الدنيا{15}. (١٥/٧١)٧٩٧١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿وحِيدًا﴾، قال: خَلَقتُه وحده، ليس له مال ولا ولد{7}. (١٥/٧١)٧٩٧١٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، يعني: الوليد بن المُغيرة{12}. (ز)٧٩٧٢٠- عن عامر الشعبي -من طريق حُصَين- في قوله ﷿: ﴿ذرني ومن خلقت وحيدًا﴾، قال: هو الوليد بن المُغيرة المَخزوميّ{18}. (ز)٧٩٧٢١- عن قتادة بن دعامة -من طريق سعيد- ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، قال: هو الوليد بن المُغيرة، أخرجه الله مِن بطن أمه وحيدًا، لا مال له ولا ولد، فرَزقه الله المال والولد والثّروة والنّماء{19}. (١٥/٧٠)٧٩٧٢٢- عن أبي مالك غَزْوان الغفاري، ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، قال: الوليد بن المُغيرة{20}. (١٥/٧١)٧٩٧٢٣- قال مقاتل بن سليمان: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾، يعني: الوليد بن المُغيرة المَخزوميّ، كان يُسمّى: الوحيد في قومه ...{10}. (ز)٧٩٧٢٤- قال مقاتل بن سليمان: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾ يقول: خَلِّ بيني -يا محمد- وبين مَن خَلقتُ وحيدًا. يقول: حين لم يكن له مال ولا بنون، يعني: خَلِّ بيني وبينه، فأنا أتفرّد بهلاكه، وأمّا الوليد يعني: خَلَقتُه وحده ليس له شيء{22}٦٨٧٣. (ز)٦٨٧٣ أفادت الآثار أنّ وصف الوليد بالوحيد لأنه وُلد بلا مال ولا ولد، ثم رزقه الله المال والولد. وقد ذكر ابنُ عطية (٨/٤٥٥) هذا القول، وزاد عليه قولًا آخر، فقال: «وقيل: المعنى: خَلَقتُه وحدي، لم يشركني فيه أحد». وعلّق عليه قائلًا: «فـ﴿وحيدا﴾ حال من التاء في ﴿خَلَقْتُ﴾»."
  74,12,"﴿وَجَعَلۡتُ لَهُۥ مَالࣰا مَّمۡدُودࣰا ۝١٢﴾ - تفسير٧٩٧٢٥- عن عمر بن الخطاب -من طريق عطاء- أنه سُئل عن قوله: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾. قال: غَلة شهر بشهر{1}٦٨٧٤. (١٥/٧٢)٦٨٧٤ علّق ابنُ عطية (٨/٤٥٥) على قول عمر، فقال: «فهو مَدٌّ في الزمان لا ينقطع».٧٩٧٢٦- عن عبد الله بن عباس، ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾، قال: ألف دينار{2}. (١٥/٧١)٧٩٧٢٧- قال عبد الله بن عباس: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾ تسعة آلاف مثقال فِضّة{3}. (ز)٧٩٧٢٨- عن عبد الله بن عباس: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾ كان له بين مكة والطائف إبل وخيل ونَعم وغنم، وكان له عِير كثيرة، وعبيدٌ، وجوار{4}. (ز)٧٩٧٢٩- قال سعيد بن جُبَير -من طريق محمد بن سوقة- ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾: ألف دينار{5}. (ز)٧٩٧٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾، قال: ألف دينار{6}. (١٥/٧١)٧٩٧٣١- عن النعمان بن سالم -من طريق شعبة- في قوله: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾، قال: الأرض{7}. (١٥/٧٢)٧٩٧٣٢- عن إبراهيم بن المهاجر -من طريق قيس بن الربيع- قال: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾، قال: ألف دينار{8}. (ز)٧٩٧٣٣- قال قتادة بن دعامة: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾ أربعة آلاف دينار{9}. (ز)٧٩٧٣٤- قال مقاتل بن سليمان: يقول ﷿: فأَعطيتُه المالَ والولد، فذلك قوله: ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾ يعني بالمال: بُستانه الذي له بالطائف، والممدود: الذي لا يَنْقطع خيره شتًاء ولا صيفًا، كقوله: ﴿وظِلٍّ مَمْدُودٍ﴾ [الواقعة:٣٠]، يعني: لا يَنقطع{10}. (ز)٧٩٧٣٥- عن سفيان [الثوري] -من طريق مهران- ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾، قال: بلَغني: أنه أربعة آلاف دينار{11}. (ز)٧٩٧٣٦- عن سفيان، ﴿وجَعَلْتُ لَهُ مالًا مَمْدُودًا﴾، قال: ألف ألف{12}٦٨٧٥. (١٥/٧٢)٦٨٧٥ علّق ابن عطية (٨/٤٥٥) على قول مَن حدّ المال الممدود بعدد معين بقوله: «فهذا مَدّ في العدد».ورجّح ابنُ جرير (٢٣/٤٢٤) العموم، وأنّ المال الممدود هو الكثير، الممدود عدده أو مساحته، دون تعيين لحدّه أو مقداره، فقال: «والصواب من القول في ذلك أن يُقال كما قال الله: ﴿وجعلت له مالا ممدودًا﴾، وهو الكثير الممدود عدده أو مساحته»."
  74,13,"﴿وَبَنِینَ شُهُودࣰا ۝١٣﴾ - تفسير٧٩٧٣٧- قال سعيد بن جُبَير: ﴿وبَنِينَ شُهُودًا﴾ كانوا ثلاثة عشر ولدًا{1}. (ز)٧٩٧٣٨- عن مجاهد بن جبر -من طريق إبراهيم- ﴿وبَنِينَ﴾ قال: كانوا عشرة، ﴿شُهُودًا﴾ قال: لا يَغيبون{2}. (١٥/٧١)٧٩٧٣٩- عن أبي مالك غَزْوان الغفاري، ﴿وبَنِينَ شُهُودًا﴾، قال: كانوا ثلاثة عشر{3}. (١٥/٧١)٧٩٧٤٠- قال قتادة بن دعامة: ﴿وبَنِينَ شُهُودًا﴾ حُضورًا بمكة، لا يَغيبون عنه، وكانوا عشرة{4}. (ز)٧٩٧٤١- قال مقاتل بن سليمان: ﴿وبَنِينَ شُهُودًا﴾ يعني: حُضورًا، لا يَغيبون أبدًا عنه في تجارة ولا غيرها؛ لكثرة أموالهم بمكة، وكلّهم رجال، منهم الوليد بن الوليد، وخالد بن الوليد -وهو سيف الله أسلم بعد ذلك-، وعمارة بن الوليد، وهشام بن الوليد، والعاص بن الوليد، وقيس بن الوليد، وعبد شمس بن الوليد{5}. (ز)"
  74,14,"﴿وَمَهَّدتُّ لَهُۥ تَمۡهِیدࣰا ۝١٤﴾ - تفسير٧٩٧٤٢- قال عبد الله بن عباس: ﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾، يعني: المال بعضه على بعض، كما تُمهد الفُرش{1}. (ز)٧٩٧٤٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾، قال: بَسطتُ له من المال والولد{2}. (١٥/٧١)٧٩٧٤٤- قال محمد بن السّائِب الكلبي: ﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾، يعني: المال بعضه على بعض، كما يُمهد الفُرش{3}. (ز)٧٩٧٤٥- قال مقاتل بن سليمان: ﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾، يقول: بَسطتُ له في المال والولد والخير بَسطًا{4}. (ز)٧٩٧٤٦- عن سفيان [الثوري] -من طريق مهران- ﴿ومَهَّدْتُ لَهُ تَمْهِيدًا﴾، قال: بُسِط له{5}. (ز)"
  74,15,"﴿ثُمَّ یَطۡمَعُ أَنۡ أَزِیدَ ۝١٥ كَلَّاۤۖ﴾ - تفسير٧٩٧٤٧- عن مجاهد بن جبر ﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ * كَلّا﴾، قال: فما زال يَرى النقصان في ماله وولده حتى هَلك{1}. (١٥/٧١)٧٩٧٤٨- عن أبي مالك غَزْوان الغفاري، ﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ * كَلّا﴾، قال: فلم يُولَد له بعد يومئذ، ولم يَزدد له من المال إلا ما كان{2}. (١٥/٧١)٧٩٧٤٩- قال الحسن البصري: ﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ﴾ ثم يطمع أنْ أُدخله الجنة{3}. (ز)٧٩٧٥٠- قال مقاتل بن سليمان: ﴿ثُمَّ يَطْمَعُ أنْ أزِيدَ﴾ يقول: ثم يرجو أنْ أزيده في ماله وولده، ﴿كَلّا﴾ لا أزيده، بل أقطع ذلك عنه وأُهلكه، ثم مَنعه الله المال، فلم يُعطه شيئًا حتى افتقر وسأل الناس، فأَهلكه الله تعالى، ومات فقيرًا في المُستهزئين، ثم نَعتَ عمله الخبيث، فقال: ﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾{4}. (ز)﴿كَلَّاۤۖ إِنَّهُۥ كَانَ لِـَٔایَـٰتِنَا عَنِیدࣰا ۝١٦﴾ - تفسير٧٩٧٥١- عن عبد الله بن عباس -من طريق علي- ﴿عَنِيدًا﴾، قال: جَحودًا{5}. (١٥/٧٤)٧٩٧٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾، قال: مُعانِدًا عنها، مُجانِبًا لها{6}. (١٥/٧١)٧٩٧٥٣- عن أبي مالك غَزْوان الغفاري، ﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾، قال: مُشاقًّا{2}. (١٥/٧١)٧٩٧٥٤- عن قتادة بن دعامة -من طريق سعيد- ﴿كَلّا إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾، قال: كفورًا بآيات الله، جَحودًا بها{8}. (١٥/٧٠)٧٩٧٥٥- قال مقاتل بن سليمان: ﴿إنَّهُ كانَ لِآياتِنا عَنِيدًا﴾ يعني: كان عن آيات القرآن مُعرِضًا مُجانبًا له، لا يُؤمن بالقرآن. ثم أخبر الله تعالى ما يَصنع به في الآخرة، فقال: ﴿سَأُرْهِقُهُ صَعُودًا﴾{9}٦٨٧٦. (ز)٦٨٧٦ ذكر ابنُ عطية (٨/٤٥٥-٤٥٦) أنّ قوله: ﴿لآياتنا﴾ هي العِبر، ثم ذكر القول بأنها آيات القرآن، كما في قول مقاتل، ورجّحه مستندًا إلى السياق، فقال: «ويحتمل أن يريد بالآيات: آيات القرآن، وهو الأصح في التأويل؛ بسبب كلام الوليد في القرآن بأنه سحرٌ».٧٩٧٥٦- عن سفيان [الثوري] -من طريق مهران- ﴿لِآياتِنا عَنِيدًا﴾، قال: مُشاقًّا{10}. (ز)"
  74,16,"74:15"
  74,17,"﴿سَأُرۡهِقُهُۥ صَعُودًا ۝١٧﴾ - تفسير٧٩٧٥٧- عن أبي سعيد الخدري، عن النبيِّ ﷺ، قال: «الصَّعود: جبل في النار، يَصعد فيه الكافر سبعين خريفًا، ثم يَهوي وهو كذلك فيه أبدًا»{1}. (١٥/٧٤)٧٩٧٥٨- عن عبد الله بن عباس، في قوله: ﴿سَأُرْهِقُهُ صَعُودًا﴾، قال: جبل في النار{2}. (١٥/٧٥)٧٩٧٥٩- عن عبد الله بن عباس، قال: صَعُودٌ: صخرة في جهنم، يُسحب عليها الكافر على وجهه{3}. (١٥/٧٥)٧٩٧٦٠- عن أبي سعيد الخُدري -من طريق عطية العَوفيّ- في قوله: ﴿سَأُرْهِقُهُ صَعُودًا﴾، قال: هو جبل في النار، يُكلّفون أن يصعدوا فيه، فكُلّما وضعوا أيديهم عليه ذابتْ، فإذا رفعوها عادتْ كما كانت{4}. (١٥/٧٢)٧٩٧٦١- عن أبي سعيد الخُدري -من طريق عطية العَوفيّ- قال: إنّ صَعُودًا صخرة في جهنم، إذا وضعوا أيديهم عليها ذابتْ، فإذا رفعوها عادتْ، واقتحامها: ﴿فَكُّ رَقَبَةٍ أوْ إطْعامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ﴾ [البلد:١٣-١٤]{5}. (١٥/٧٥)٧٩٧٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿سَأُرْهِقُهُ صَعُودًا﴾، قال: مَشقّة مِن العذاب{6}. (١٥/٧١)٧٩٧٦٣- عن الضَّحّاك بن مُزاحِم، ﴿سَأُرْهِقُهُ صَعُودًا﴾، قال: صخرة ملساء في جهنم، يُكلّفون الصُّعود عليها{7}. (١٥/٧٥)٧٩٧٦٤- عن الحسن البصري، في قوله: ﴿صَعُودًا﴾، قال: جبلًا في جهنم{7}. (١٥/٧٥)٧٩٧٦٥- عن الحسن البصري= (ز)٧٩٧٦٦- وقتادة بن دعامة -من طريق عمرو- في قوله تعالى: ﴿سأرهقه صعودًا﴾، قال: عذابًا لا راحة فيه{9}. (ز)٧٩٧٦٧- عن شُفَيّ بن ماتع الأَصبحيّ -من طريق أيوب بن بَشِير- قال: في جهنم جبل يُدعى: صَعودًا، يَطْلُع فيه الكافر أربعين خريفًا قبل أن يرقاه، قال الله ﷿: ﴿سَأُرْهِقُهُ صَعُودًا﴾{10}. (ز)٧٩٧٦٨- عن قتادة بن دعامة -من طريق أبي هلال- ﴿سَأُرْهِقُهُ صَعُودًا﴾، قال: مَشقّة من العذاب{11}. (ز)٧٩٧٦٩- قال محمد بن السّائِب الكلبي: الصعود: صخرة ملساء في النار، يُكلّف أن يَصعدها، لا يُترك أن يَتنفّس في صعوده، ويُجذب مِن أمامه بسلاسل مِن حديد، ويُضرب مِن خلفه بمَقامع مِن حديد، فيَصعدها في أربعين عامًا، فإذا بَلغ ذروتها أُحْدِرَ إلى أسفلها، ثم يُكلّف أن يَصعدها، ويُجذب من أمامه، ويُضرب من خلفه، فذلك دأْبه أبدًا أبدًا{12}. (ز)٧٩٧٧٠- قال مقاتل بن سليمان: ﴿سَأُرْهِقُهُ صَعُودًا﴾ يعني: سُأكَلّفه أن يَصعد على صخرة من النار ملساء في الباب الخامس، واسم ذلك الباب: سَقر، في تلك الصخرة كُوًى{13} تَخرج منها ريح، وهي ريح حارة، وهي التي ذَكر الله تعالى ﴿عَذابَ السَّمُومِ﴾ [الطور:٢٧]، فإذا أصابته تلك الريح تَناثر لحمه، يقول الله -جلّ وعزّ-: ﴿سَأُرْهِقُهُ صَعُودًا﴾ يقول: سأُغشي وجهه تلك الصخرة، وهي جبلٌ من نار، طوله مسيرة سبعين سنة، ويَصعد به فيها على وجهه، فإذا بلَغ الكافر أعلاها انحطّ إلى أسفلها، ثم يُكلّف أيضًا صُعودها، ويَخرج إليه من كُوى تلك الصخرة ريح باردة من فوقها ومن تحتها، تَقْطَعُ تلك الريحُ لحمه وجِلدة وجهه، فكُلّما أصعد أصابته تلك الريح وإذا انحطّ، حتى يَنتثِر اللحم من العظم، ثم يَشرب من عين آنية، التي قد انتهى حرّها، فهذا دأْبه أبدًا{14}. (ز)٧٩٧٧١- عن عبد الرحمن بن زيد بن أسلم- من طريق ابن وهب- قال في قوله: ﴿سَأُرْهِقُهُ صَعُودًا﴾، قال: تعبًا مِن العذاب{15}. (ز)"
  74,18,"﴿إِنَّهُۥ فَكَّرَ وَقَدَّرَ ۝١٨ فَقُتِلَ كَیۡفَ قَدَّرَ ۝١٩ ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾ - نزول الآيات٧٩٧٧٢- عن عبد الله بن عباس، قال: لَمّا بُعِث النبيُّ ﷺ جمع الوليد بن المُغيرة قريشًا، فقال: ما تقولون؟ يعني: في هذا الرجل، فقال بعضهم: هو شاعر. وقال بعضهم: هو كاهن. فقال الوليد: سمعتُ قول الشاعر فما هو بشاعر، وسمعتُ قول الكهنة فما هو مثله. قالوا: فما تقول أنتَ؟ قال: فنظر ساعة، ثم فَكّر وقَدّر، ﴿فَقُتِلَ كَيْفَ قَدَّرَ﴾ إلى قوله: ﴿سِحْرٌ يُؤْثَرُ﴾{1}. (١٥/٧٣)٧٩٧٧٣- قال مجاهد: إنّ الوليد بن المُغيرة كان يَغشى النبيَّ ﷺ وأبا بكر ﵁، حتى حَسبتْ قريش أنه يُسلم، فقال له أبو جهل: إنّ قريشًا تزعم أنك إنما تأتي محمدًا وابن أبي قُحافة تُصيب من طعامهما. فقال الوليد لقريش: إنكم ذوو أحساب وذوو أحلام، وإنكم تزعمون أنّ محمدًا مجنون، وهل رأيتموه يُجَنُّ قطّ؟ قالوا: اللهم، لا. قال: تزعمون أنه كاهن، وهل رأيتموه يتكهّن قطّ؟ قالوا: اللهم، لا. قال: تزعمون أنه شاعر، هل رأيتموه يَنطق بشعرٍ قطّ؟ قالوا: لا. قال: فتزعمون أنه كذّاب، فهل جربتم عليه شيئًا من الكذب؟ قالوا: لا. قالتْ قريش للوليد: فما هو؟ فتفَكّر في نفسه، ثم نَظر، وعبس، فقال: ما هو إلا ساحر، وما يقوله سحرٌ. فذلك قوله: ﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾ إلى قوله تعالى: ﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾{2}. (ز)٧٩٧٧٤- عن قتادة بن دعامة -من طريق سعيد- ﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾، قال: ذُكر لنا أنه قال: لقد نظرتُ فيما قال هذا الرجل، فإذا هو ليس بشعرٍ، وإنّ له لَحلاوة، وإن عليه لَطُلاوَةً، وإنه ليَعلو ولا يُعلى، وما أشكّ أنه سحرٌ. فأنزل الله فيه: ﴿فَقُتِلَ كَيْفَ قَدَّرَ﴾ إلى قوله: ﴿وبَسَرَ﴾{3}. (١٥/٧٠)﴿إِنَّهُۥ فَكَّرَ وَقَدَّرَ ۝١٨ فَقُتِلَ كَیۡفَ قَدَّرَ ۝١٩ ثُمَّ قُتِلَ كَیۡفَ قَدَّرَ ۝٢٠﴾ - تفسير الآية٧٩٧٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: ﴿فَكَّرَ وقَدَّرَ﴾، قال: الوليد بن المُغيرة يوم دار النَّدوة{4}. (ز)٧٩٧٧٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿ذَرْنِي ومَن خَلَقْتُ وحِيدًا﴾ يعني: الوليد بن المُغيرة، دعاه نبي الله ﷺ إلى الإسلام، فقال: حتى أنظر. ففكّر، ﴿ثُمَّ نَظَرَ ثُمَّ عَبَسَ وبَسَرَ ثُمَّ أدْبَرَ واسْتَكْبَرَ فَقالَ إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾. فجَعل الله له سَقر{4}. (ز)٧٩٧٧٧- قال محمد بن شهاب الزُّهريّ: ﴿فَقُتِلَ﴾ عُذّب{6}. (ز)٧٩٧٧٨- قال مقاتل بن سليمان: ﴿إنَّهُ فَكَّرَ وقَدَّرَ﴾ ثم قال -يعني: الوليد بن المُغيرة-: ﴿إنَّهُ فَكَّرَ﴾ في أمْر محمد ﷺ، فزعم أنه ساحر، وقال مثل ما قال في التقديم، ﴿وقَدَّرَ﴾ في قوله: إنّ محمدًا يُفرّق بين الاثنين. ﴿فَقُتِلَ كيف قدر﴾ يقول: فلُعِن كيف قدَّر السحر، ﴿ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾ يعني: ثم لُعِن كيف قدّر السِّحر{7}. (ز)٧٩٧٧٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿فَقُتِلَ كَيْفَ قَدَّرَ ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾، قال: قُتل كيف قدّر حين قال: ليس بشعرٍ. ثم قُتل كيف قدّر حين قال: ليس بكهانة{4}٦٨٧٧. (ز)٦٨٧٧ ذكر ابنُ عطية (٨/٤٥٧-٤٥٨) في قوله: ﴿فقتل كيف قدر﴾ احتمالين: الأول: «أن يكون دعاء عليه على معنى تقبيح حاله». ثم وجّه معنى قوله: ﴿ثم نظر﴾ على هذا الاحتمال، فقال: «وعلى التأويل الأول أنّ الدعاء عليه دعاء على مُستقبح فعله يجيء قوله: ﴿ثُمَّ نَظَرَ﴾ معنىً معادًا بعينه؛ لأن ﴿فَكَّرَ وقَدَّرَ﴾ يقتضيه، لكنه إخبار بترديده النظر في الأمر، وقد رُوي أنّ النبي ﷺ دعا الوليد فقال له: «أنظُرُ وأُفَكِّرُ». فلمّا فَكّر قال ما تقدم». الثاني: «يحتمل أن يكون دعاء مقتضاه استحسان منزعه الأول في مدحه القرآن، وفي نفيه الشعر والكهانة والجنون عنه، فيجري هذا مجرى قول النبي ﷺ لأبي جَندل بن سهيل: «ويل أمه، مسْعَر حرب». ومجرى قول عبد الملك بن مروان: قاتل الله كُثَيِّرًا، كأنه رآنا حين قال كذا. وهذا معنًى مشهور في كلام العرب». ثم وجّه معنى قوله: ﴿ثم نظر﴾ على هذا الاحتمال، فقال: «وإذا قلنا إنّ ذلك دعاء على مستحسن فعله فيجيء قوله تعالى: ﴿ثُمَّ نَظَرَ﴾ فيما احتج به للقرآن، فرأى ما فيه من علوِّ مرتبة محمد ﵇، فـ﴿عَبَسَ﴾ لذلك، ﴿وبَسَرَ﴾ أي: قطب، وقبض ما بين عينيه، واربدَّ وجهه حسدًا له»."
  74,19,"74:18"
  74,20,"74:18"
  74,21,"﴿ثُمَّ نَظَرَ ۝٢١ ثُمَّ عَبَسَ وَبَسَرَ ۝٢٢ ثُمَّ أَدۡبَرَ وَٱسۡتَكۡبَرَ ۝٢٣﴾ - تفسير٧٩٧٨٠- عن قتادة بن دعامة ﴿وبَسَرَ﴾، قال: كَلَح{1}. (١٥/٧٠)٧٩٧٨١- عن قتادة بن دعامة، في قوله: ﴿عَبَسَ وبَسَرَ﴾، قال: قَبض ما بين عينيه، وكَلَح{2}. (١٥/٧٦)٧٩٧٨٢- عن محمد بن السّائِب الكلبي -من طريق معمر- في قوله تعالى: ﴿عَبَسَ وبَسَرَ﴾، قال: عَبَس، وكَلَح{3}. (ز)٧٩٧٨٣- قال مقاتل بن سليمان: ﴿ثُمَّ نَظَرَ﴾ فيما يقول لمحمد ﷺ مِن السِّحر، ﴿ثُمَّ عَبَسَ﴾ وجهه، يعني: كَلَح. كقوله: ﴿عَبَسَ وتَوَلّى﴾ [عبس:١]، يعني: كَلَح في وجه ابن أم مكتوم. ﴿وبَسَرَ﴾ يعني: وتغيّر لون وجهه، يعني: أعرَض عن الإيمان، ﴿واسْتَكْبَرَ﴾ عنه{4}. (ز)"
  74,22,"74:21"
  74,23,"74:21"
  74,24,"﴿فَقَالَ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ یُؤۡثَرُ ۝٢٤ إِنۡ هَـٰذَاۤ إِلَّا قَوۡلُ ٱلۡبَشَرِ ۝٢٥﴾ - تفسير٧٩٧٨٤- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل- ﴿إنْ هَذا إلّا سِحْرٌ يُؤْثَرُ﴾، قال: يَأْثُره عن غيره{1}. (١٥/٧٦)٧٩٧٨٥- قال الحسن البصري، في قوله: ﴿إنْ هَذا إلا قَوْلُ البشر﴾، يَعنون: عَدّاسًا غلام عُتْبَة. كقوله: ﴿ولَقَدْ نَعْلَمُ أنَّهُمْ يَقُولُونَ إنَّما يُعَلِّمُهُ بَشَرٌ﴾ [النحل:١٠٣] هو عَدّاس{2}. (ز)٧٩٧٨٦- قال مقاتل بن سليمان: ﴿فَقالَ﴾ الوليد لقومه: ﴿إنْ هَذا﴾ الذي يقول محمد ﴿إلّا سِحْرٌ يُؤْثَرُ إنْ هَذا إلّا قَوْلُ البَشَرِ﴾{3}. (ز)"
  74,25,"74:24"
  74,26,"﴿سَأُصۡلِیهِ سَقَرَ ۝٢٦ وَمَاۤ أَدۡرَىٰكَ مَا سَقَرُ ۝٢٧﴾ - تفسير٧٩٧٨٧- عن عبد الله بن عباس، قال: ﴿سَقَرُ﴾ أسفل الجحيم، نابتٌ فيها شجرة الزَّقوم{1}. (١٥/٧٦)٧٩٧٨٨- قال مقاتل بن سليمان: ﴿سَأُصْلِيهِ سَقَرَ﴾، يعني: الباب الخامس من جهنم{2}. (ز)"
  74,27,"74:26"
  74,28,"﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾ - تفسير٧٩٧٨٩- عن عبد الله بن عباس: ﴿لا تُبْقِي﴾ إذا أخذتْ فيهم لم تُبق منهم شيئًا، وإذا بُدِّلوا خَلْقًا جديدًا لم تَذرْ أن تُعاودهم سبيل العذاب الأول{1}. (١٥/٧٦)٧٩٧٩٠- عن ابن بُرَيْدة، ﴿لا تُبْقِي ولا تَذَرُ﴾، قال: تأكل اللحم، والعظم، والعِرق، والمخ، ولا تَذره على ذلك{1}. (١٥/٧٧)٧٩٧٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿لا تُبْقِي ولا تَذَرُ﴾، قال: لا تُحْيِي، ولا تميت{3}٦٨٧٨. (١٥/٧٦)٦٨٧٨ لم يذكر ابنُ جرير (٢٣/٤٣٣) غير قول مجاهد، ومزيدة.٧٩٧٩٢- عن الضَّحّاك بن مُزاحِم: ﴿لا تُبْقِي ولا تَذَرُ﴾ تأكله كلّه، فإذا تَبدّى خَلْقه لم تَذره حتى تقوم عليه{1}. (١٥/٧٦)٧٩٧٩٣- قال إسماعيل السُّدِّيّ، في قوله: ﴿لا تُبْقِي ولا تَذَرُ﴾: لا تُبقي لهم لحمًا، ولا تَذر لهم عظمًا{5}. (ز)٧٩٧٩٤- عن مَزِيدة [بن جابر الهجري] -من طريق [محمد بن عبد الرحمن] بن أبي ليلى- في قوله: ﴿لا تُبْقِي ولا تَذَرُ﴾، قال: لا تُبقي منهم شيئًا أن تأكلهم، فإذا خُلِقوا لها لا تَذرهم حتى تأخذهم فتَأكلهم{6}. (ز)٧٩٧٩٥- قال مقاتل بن سليمان: ﴿لا تُبْقِي ولا تَذَرُ﴾ يعني: لا تُبْقِي النار إذا رَأتْهم حتى تأكلهم، ولا تَذرهم إذا حَلَفُوا لها حتى تواقعهم{7}. (ز)﴿لَا تُبۡقِی وَلَا تَذَرُ ۝٢٨﴾ - آثار متعلقة بالآية٧٩٧٩٦- عن أبي هريرة، عن رسول الله ﷺ: «قال موسى لربّه ﷿: أيُّ عبادك أفقرُ؟ قال: صاحب سقر»{8}. (ز)"
  74,29,"﴿لَوَّاحَةࣱ لِّلۡبَشَرِ ۝٢٩﴾ - تفسير٧٩٧٩٧- عن أبي هريرة -من طريق عبد الله بن أبي الهُذيل- في قوله ﷿: ﴿لواحة للبشر﴾، قال: تَلقاهم جهنم يوم القيامة، فتَلفحهم لَفحةً، فلا تَترك لحمًا على عظمٍ إلا وضعتْه على العراقيب{1}. (ز)٧٩٧٩٨- عن عبد الله بن عباس، ﴿لَوّاحَةٌ﴾، قال: مُحرِقة{2}. (١٥/٧٧)٧٩٧٩٩- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، يقول: مُغَيِّرة{3}. (ز)٧٩٨٠٠- عن عبد الله بن عباس، ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، قال: تُلوِّح الجلد، فتَحرقه، فيَتغيّر لونه، فيصير أسودَ من الليل{4}. (١٥/٧٧)٧٩٨٠١- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل بن سُمَيع- ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، قال: تُلَوِّح جلده حتى تَدعه أشدّ سوادًا من الليل. وفي رواية: غيَّرت جلودَهم فاسودَّت{5}. (١٥/٧٧)٧٩٨٠٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، قال: للجلد{6}. (١٥/٧٧)٧٩٨٠٣- قال الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، يعني: بَشر الإنسان، يقول: تَحرق بَشره{7}. (ز)٧٩٨٠٤- قال الحسن البصري: يعني: تَلوح لهم جهنم حتى يَروها عيانًا{8}٦٨٧٩. (ز)٦٨٧٩ ذكر ابنُ عطية (٨/٤٥٩) قول الحسن، ووجّهه بقوله: «فالمعنى: أنها تظهر للناس -وهم البشر- مِن مسيرة خمسمائة عام، وذلك لعِظَمها وهولها وزفيرها».٧٩٨٠٥- عن قتادة بن دعامة -من طريق سعيد- ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، قال: حرّاقة للجلد{6}. (١٥/٧٧)٧٩٨٠٦- عن عطاء الخراساني -من طريق يونس بن يزيد- ﴿لواحة للبشر﴾، قال: بَشرة الإنسان تُلَوَّح على النار{10}. (ز)٧٩٨٠٧- عن زيد بن أسلم -من طريق ابن أبي هلال- قال: ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، أي: تُلَوَّح أجسادهم عليها{11}. (ز)٧٩٨٠٨- قال مقاتل بن سليمان: ﴿لَوّاحَةٌ لِلْبَشَرِ﴾ مُحرِقة للخَلْق{12}. (ز)٧٩٨٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿لَوّاحَةٌ لِلْبَشَرِ﴾، قال: تُغيّر البشَر، تَحرق البشَر، يقال: قد لاحه استقباله السماء، ثم قال: والنار تُغيّر ألوانهم{7}٦٨٨٠. (ز)٦٨٨٠ لم يذكر ابنُ جرير (٢٣/٤٣٣-٤٣٥) غير قول عبد الرحمن بن زيد، وقتادة، والضَّحّاك، ومجاهد، وأبي رَزِين، وزيد بن أسلم، وابن عباس من طريق علي.ووجّهه ابنُ عطية (٨/٤٥٨) قائلا: ""فالبَشَر: جمع بشَرة، وتقول العرب: لاحت النارُ الشيءَ إذا أحرقَتْه وسَوّدتْه. وقال الشاعر:لاحَهُ الصيفُ والغِيارُ وإشفا ... قٌ على سقبة كقوس الضالِوأنشد أبو عبيدة:... يا ابنة عمي لاحَني الهواجرُ""."
  74,30,"﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾ - نزول الآية٧٩٨١٠- عن البراء بن عازب -من طريق عامر-: أنّ رهطًا مِن اليهود سألوا رجلًا مِن أصحاب النبيِّ ﷺ عن خَزنة جهنم. فقال: الله ورسوله أعلم. فجاء، فأخبَر النَّبيّ ﷺ؛ فنَزل عليه ساعتئذ: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾{1}. (١٥/٧٧)٧٩٨١١- عن عبد الله بن عباس -من طريق عطية- قال: لَمّا سمع أبو جهل: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ قال لقريش: ثَكِلتْكم أُمّهاتكم، أسمعُ ابنَ أبي كَبْشَة يُخبركم أنّ خَزنة النار تسعة عشر، وأنتم الدَّهْم{2}! أفيَعجز كلُّ عشرة منكم أن يَبطشوا برجلٍ من خَزنة جهنم؟! فأوحى الله إلى نبيّه أن يأتي أبا جهل، فيأخذ بيده في بطحاء مكة، فيقول له: ﴿أوْلى لَكَ فَأَوْلى ثُمَّ أوْلى لَكَ فَأَوْلى﴾ [القيامة:٣٤-٣٥]{3}. (١٥/٧٨)٧٩٨١٢- قال الضَّحّاك بن مُزاحِم: لما نزلت هذه الآية ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ قال أبو جهل لقريش: ثَكِلتْكم أُمّهاتكم، أسمع ابن أبي كَبْشَة يُخبِر أنّ خَزنة النار تسعة عشر وأنتم الدَّهْم! -أي: الشّجعان- أفيَعجز كلّ عشرة منكم أن يَبطشوا بواحد من خَزنة جهنم؟! قال أبو الأشَدِّ أُسَيْد بن كَلَدَة بن خَلف الجُمحيّ: أنا أكفيكم منهم سبعة عشر؛ عشرة على ظهري، وسبعة على بطني، فاكفوني أنتم اثنين{4}. (ز)٧٩٨١٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾، قال: ذُكر لنا: أنّ أبا جهل حين أُنزِلَتْ هذه الآية قال: يا معشر قريش، ما يستطيع كلّ عشرة منكم أن يغلبوا واحدًا مِن خَزنة النار وأنتم الدَّهْمُ؟!{5}. (١٥/٧٩)﴿عَلَیۡهَا تِسۡعَةَ عَشَرَ ۝٣٠﴾ - تفسير الآية٧٩٨١٤- عن جابر بن عبد الله، قال: قال ناس من اليهود لأناس مِن أصحاب النبِيِّ ﷺ: هل يَعلم نبيُّكم عددَ خَزنة جهنم؟ قالوا: لا ندري حتى نسأله. فجاءوا إلى النبي ﷺ، فقالوا: كم عدد خَزنة جهنم؟ قال: «هكذا، وهكذا». في مرّة عشرة، وفي مرّة تسعة{6}. (١٥/٧٨)٧٩٨١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾، قال: جُعلوا فتنة. قال: قال أبو الأَشَدَّين الجُمحيّ: لا يَبلغون رَبوتي حتى أُجهِضَهم{7} عن جهنم{8}. (١٥/٧٩)٧٩٨١٦- قال عمرو بن دينار: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ إنّ واحدًا منهم يَدفع بالدّفعة الواحدة في جهنم أكثر من ربيعة ومُضر{9}. (ز)٧٩٨١٧- قال مقاتل بن سليمان: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ يقول: في النار من الملائكة تسعة عشر خَزنتها؛ يعني: مالكًا ومَن معه ثمانية عشر مَلكًا، أعينهم كالبَرْق الخاطف، وأنيابهم كالصَّياصيّ -يعني: مثل قرون البقر-، وأشعارهم تمسّ أقدامهم، يَخرج لهب النار مِن أفواههم، ما بين مَنكِبي أحدهم مسيرة سبعين سنة، يَسع كفُّ أحدهم مثل ربيعة ومضر، قد نُزعتْ منهم الرأفة والرحمة غِضابًا، يدفع أحدهم سبعين ألفًا، فيُلقيهم حيث أراد من جهنم، فيَهوي أحدهم في جهنم مسيرة أربعين سنة، لا تَضُرّهم النار؛ لأنّ نورهم أشدّ مِن حرّ النار، ولولا ذلك لم يُطيقوا دخول النار طرْفة عين، فلمّا قال الله: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ قال أبو جهل بن هشام: يا معشر قريش، ما لِمُحمد من الجنود إلا تسعة عشر، ويزعم أنهم خَزنة جهنم، يُخوّفكم بتسعة عشر وأنتم الدَّهْم! أيَعجز كلّ مائة منكم أن تَبطش بواحد منهم، فيَخرجوا منها؟! وقال أبو الأَشَدَّين اسمه أُسَيْد بن كَلَدَة بن خلف الجُمحيّ: أنا أكفيكم سبعة عشر؛ أحمل منهم عشرة على ظهري، وسبعة على صدري، واكفوني منهم اثنين. وكان شديدًا فسُمّي: أبا الأَشَدَّين؛ لشدّته بذلك سُمّي، وكنيته: أبو الأعور{10}. (ز)٧٩٨١٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾، قال: خَزنتها تسعة عشر{11}. (ز)٧٩٨١٩- عن رجل من بني تميم -من طريق الأزرق بن قيس- قال: كُنّا عند أبي العوّام، فقرأ هذه الآية: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾. فقال: ما تقولون أتسعة عشر مَلكًا، أو تسعة عشر ألفًا؟ قلتُ: لا، بل تسعة عشر مَلكًا. فقال: ومَن أين علمتَ ذلك؟ قلتُ: لأنّ الله يقول: ﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾. قال: صدقتَ، هم تسعة عشر مَلكًا، بيد كلّ مَلكٍ منهم مِرْزَبّة مِن حديد له شُعبتان، فيَضرب بها الضربة يَهوي بها في جهنم سبعين ألفًا، بين مَنكِبي كلّ مَلكٍ منهم مسيرة كذا وكذا{12}. (١٥/٧٩)"
  74,31,"﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةࣰ لِّلَّذِینَ كَفَرُوا۟﴾ - نزول الآية٧٩٨٢٠- قال عبد الله بن عباس= (ز)٧٩٨٢١- والضَّحّاك بن مُزاحِم= (ز)٧٩٨٢٢- وقتادة: لَمّا نزلت هذه الآية: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ قال أبو جهل لقريش: ثَكِلتْكم أُمّهاتكم، أسمع ابن أبي كَبْشَة يُخبركم أنّ خَزنة النار تسعة عشر، وأنتم الدَّهم! -أي: الشّجعان- أفَيعجز كلّ عشرة منكم أن يَبطشوا برجلٍ من خَزنة جهنم؟! فقال أبو الأَشَدَّين كَلَدَة بن خَلف بن أسد الجُمحيّ: أنا أكفيكم منهم سبعة عشر؛ عشرة على ظهري، وسبعة على بطني، واكفوني أنتم اثنين. فأنزل الله ﷾: ﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾{1}. (ز)٧٩٨٢٣- عن إسماعيل السُّدِّيّ، قال: لَمّا نزلت: ﴿عَلَيْها تِسْعَةَ عَشَرَ﴾ قال رجل من قريش -يُدعى: أبا الأَشَدَّين-: يا معشر قريش، لا يَهولنَّكم التسعة عشر، أنا أدفع عنكم بمَنكِبي الأيمن عشرة، وبمَنكِبي الأيسر تسعة. فأنزل الله: ﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾{2}. (١٥/٧٨)٧٩٨٢٤- قال مقاتل بن سليمان: ﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾ حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأَنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾. وأَنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: ﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾ [التحريم:٦]{3}. (ز)٧٩٨٢٥- عن محمد بن إسحاق -من طريق سلمة-: قال أبو جهل يومًا وهو يهزأُ برسول الله ﷺ، وبما جاء به من الحق: يا معشر قريش، يزعم محمدٌ أنّ جنود الله الذين يعذبونكم في النار ويحبسونكم فيها تسعة عشر، وأنتم أكثر الناس عددًا وكثرة، أفيعجزكم مائةُ رجل منكم عن رجل منهم؟! فأنزل الله ﷿ في ذلك من قوله: ﴿وما جعلنا أصحاب النار إلا ملائكة وما جعلنا عدتهم إلا فتنة للذين كفروا﴾{4}. (ز)﴿وَمَا جَعَلۡنَاۤ أَصۡحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰۤىِٕكَةࣰۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةࣰ لِّلَّذِینَ كَفَرُوا۟﴾ - تفسير٧٩٨٢٦- عن عبد الله بن عباس، في قوله: ﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾، قال: قال أبو الأَشَدَّين: خَلُّوا بيني وبين خَزنة جهنم، أنا أكفيكم مُؤْنتهم. قال: وحُدِّثت: أنّ النبيَّ ﷺ وصف خُزّان جهنم، فقال: «كأنّ أعينهم البَرْق، وكأن أفواههم الصَّياصِيُّ{5}، يَجُرُّون أشعارهم، لهم مثل قوة الثّقلين، يُقبل أحدهم بالأُمّة مِن الناس يَسوقهم، على رقبته جبل، حتى يَرمي بهم في النار، فيَرمي بالجبل عليهم»{6}. (١٥/٨٠)٧٩٨٢٧- عن قتادة بن دعامة -من طريق سعيد- ﴿وما جَعَلْنا عِدَّتَهُمْ إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾: إلا بلاء{7}. (ز)٧٩٨٢٨- قال مقاتل بن سليمان: ﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾ يعني: خُزّان النار، ﴿وما جَعَلْنا عِدَّتَهُمْ﴾ يعني: قِلَّتهم ﴿إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾ حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأَنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾ يقول: ما يَعلم كثرتهم أحد إلا الله، وأَنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: ﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾ [التحريم:٦]، ﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾ يعني: خُزّان النار، ﴿وما جَعَلْنا عِدَّتَهُمْ﴾ يعني: قِلّتهم ﴿إلّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾ يعني: أبا جهل، وأبا الأَشَدَّين، والمُستهزئين من قريش{3}. (ز)٧٩٨٢٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿وما جَعَلْنا أصْحابَ النّارِ إلّا مَلائِكَةً﴾، قال: ما جعلناهم رجالًا، فيأخذ كلُّ رجل رجلًا كما قال هذا{7}. (ز)﴿لِیَسۡتَیۡقِنَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟ إِیمَـٰنࣰا﴾ - تفسير٧٩٨٣٠- عن عبد الله بن عباس -من طريق عطية- قوله: ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾، قال: وإنها في التوراة والإنجيل تسعة عشر، فأراد الله أن يَستَيقِن أهلُ الكتاب، ويَزداد الذين آمنوا إيمانًا{10}. (ز)٧٩٨٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾، قال: يَجدونه مكتوبًا عندهم عِدّة خَزنة النار{11}. (١٥/٨٠)٧٩٨٣٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾، قال: عِدّة خَزنة جهنم تسعة عشر في التوراة والإنجيل{12}. (ز)٧٩٨٣٣- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾، قال: ليَستَيقن أهل الكتاب حين وافق عددُ خَزنة النار ما في كتابهم{13}. (١٥/٨٠)٧٩٨٣٤- عن قتادة بن دعامة -من طريق سعيد- ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾، قال: صدّق القرآنُ الكتبَ التي خَلتْ قبله؛ التوراة والإنجيل، أنّ خزنة جهنم تسعة عشر{14}. (١٥/٨١)٧٩٨٣٥- عن عبد الملك ابن جُرَيْج: ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾ إنهم يجدون عِدّتهم في كتابهم تسعة عشر، ﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾ فيؤمنوا بما في كتابهم مِن عِدّتهم؛ فيَزدادوا بذلك إيمانًا{15}. (١٥/٨٠)٧٩٨٣٦- قال مقاتل بن سليمان: ﴿لِيَسْتَيْقِنَ﴾ لكي يستيقن ﴿الَّذِينَ أُوتُوا الكِتابَ﴾ يقول: لِيَعلم مؤمنو أهل التوراة أنّ الذي قال محمد ﷺ حقٌّ؛ لأنّ عِدّة خُزّان جهنم في التوراة تسعة عشر، ﴿ويَزْدادَ الَّذِينَ آمَنُوا إيمانًا﴾ يعني: تصديقًا، ولا يشُكُّوا في محمدٍ ﷺ بما جاء به{3}. (ز)٧٩٨٣٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الكِتابَ﴾: أنك رسول الله{12}. (ز)﴿لِیَسۡتَیۡقِنَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَیَزۡدَادَ ٱلَّذِینَ ءَامَنُوۤا۟ إِیمَـٰنࣰا﴾ - آثار متعلقة بالآية٧٩٨٣٨- عن الرّبيع بن سليمان، قال: سمعتُ الشافعي يقول: الإيمان قول وعمل، يزيد بالطاعة، ويَنقص بالمعصية. ثم تلا هذه الآية: ﴿ويزداد الذين آمنوا إيمانًا﴾ الآية{18}. (ز)﴿وَلَا یَرۡتَابَ ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ وَٱلۡمُؤۡمِنُونَ﴾ - تفسير٧٩٨٣٩- قال مقاتل بن سليمان: ﴿ولا يَرْتابَ﴾ يقول: ولكي لا يرتاب، يعني: لكي لا يشكّ، يقول: لئلا يشكّ ﴿الَّذِينَ أُوتُوا الكِتابَ﴾ يعني: أهل التوراة، ﴿و﴾لا يشكّ ﴿المُؤْمِنُونَ﴾ أنّ خَزنة جهنم تسعة عشر{3}. (ز)﴿وَلِیَقُولَ ٱلَّذِینَ فِی قُلُوبِهِم مَّرَضࣱ وَٱلۡكَـٰفِرُونَ مَاذَاۤ أَرَادَ ٱللَّهُ بِهَـٰذَا مَثَلࣰاۚ﴾ - تفسير٧٩٨٤٠- عن قتادة بن دعامة -من طريق سعيد- ﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾، قال: الذين في قلوبهم النفاق{20}٦٨٨١. (١٥/٨١)٦٨٨١ لم يذكر ابنُ جرير (٢٣/٤٤٠) غير قول قتادة.٧٩٨٤١- قال مقاتل بن سليمان: ﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾ يعني: الشكّ، وهم اليهود من أهل المدينة، ﴿والكافِرُونَ﴾ من أهل مكة، يعني: مشركي العرب: ﴿ماذا أرادَ اللَّهُ بِهذا مَثَلًا﴾ يعني: ذِكْره عِدّة خَزنة جهنم، يَستَقلُّونهم{3}. (ز)٧٩٨٤٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿ولِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ والكافِرُونَ ماذا أرادَ اللَّهُ بِهَذا مَثَلًا﴾: يقولون: حين يُخوِّفنا بهؤلاء التسعة عشر{22}. (ز)﴿كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ﴾ - نزول الآية٧٩٨٤٣- قال مقاتل بن سليمان: حين قال أبو الأَشَدَّين وأبو جهل ما قالا؛ فأنزل الله تعالى في قول أبي جهل: ما لمحمد من الجنود إلا تسعة عشر: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُو﴾، يقول: ما يَعلم كثرتهم أحد إلا الله. وأنزل الله في قول أبي الأَشَدَّين: أنا أكفيكم منهم سبعة عشر: ﴿عَلَيْها مَلائِكَةٌ غِلاظٌ شِدادٌ﴾ [التحريم:٦]{3}. (ز)﴿كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ مَن یَشَاۤءُ وَیَهۡدِی مَن یَشَاۤءُۚ وَمَا یَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ﴾ - تفسير الآية٧٩٨٤٤- عن أبي سعيد الخُدري: أنّ رسول الله ﷺ حدّثهم عن ليلة أُسري به قال: «فصعدتُ أنا وجبريل إلى السماء الدنيا، فإذا أنا بمَلَكٍ يُقال له: إسماعيل، وهو صاحب سماء الدنيا، وبين يديه سبعون ألف مَلَك، مع كلّ مَلَكٍ منهم جنده مائة ألف». وتلا هذه الآية: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾{24}. (١٥/٨١)٧٩٨٤٥- عن الحسن البصري: أنّ سائلًا سأل رسول الله عن خَلْق الملائكة: مِن أي شيء خُلقتْ؟ فقال: «من نور الحُجُب السبعين التي تَلي الرّبّ؛ كلّ حجاب منها مسيرة خمسمائة عام، فليس مَلَك إلا وهو يَدخل في نهر الحياة، فيَغتسل، فيكون مِن كلّ قطرة من ذلك الماء مَلَك، فلا يُحصي أحد ما يكون في يوم واحد». فهو قوله: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾{25}. (ز)٧٩٨٤٦- عن قتادة بن دعامة -من طريق سعيد- ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾، قال: من كثرتهم{26}. (١٥/٨١)٧٩٨٤٧- عن عبد الملك ابن جُرَيْج، مثله{15}. (١٥/٨١)٧٩٨٤٨- قال عطاء: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾، يعني: من الملائكة الذين خَلَقهم لتعذيب أهل النار، لا يَعلم عِدّتهم إلا الله{28}. (ز)٧٩٨٤٩- قال مقاتل بن سليمان: ﴿وما يَعْلَمُ جُنُودَ رَبِّكَ إلّا هُوَ﴾ مِن الكثرة حين استَقلُّوهم، فقال أبو جهل لقريش: أيَعجز ... مثل ما قال، في التقديم{29}. (ز)﴿وَمَا هِیَ إِلَّا ذِكۡرَىٰ لِلۡبَشَرِ ۝٣١﴾ - تفسير٧٩٨٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿وما هِيَ إلّا ذِكْرى لِلْبَشَرِ﴾، قال: النار{30}٦٨٨٢. (١٥/٨٢)٦٨٨٢ أفاد قول مجاهد أنّ الضمير في ﴿هي﴾ عائد على النار، وقد ذكر ابنُ عطية (٨/٤٦١) هذا، وزاد قولين آخرين، فقال: «وقال بعض الحُذّاق: قوله تعالى: ﴿وما هِيَ﴾ يُراد بها الحال والمخاطبة والنذارة، قال الثعلبي: وقيل: ﴿وما هِيَ﴾ يراد نار الدنيا، أي: إنّ هذه تذكرةٌ للبشر بنار الآخرة».٧٩٨٥١- عن قتادة بن دعامة -من طريق سعيد-، مثله{26}. (١٥/٨٢)"
  74,32,"﴿كَلَّا وَٱلۡقَمَرِ ۝٣٢﴾ - تفسير٧٩٨٥٢- قال مقاتل بن سليمان: أقسم الرّبُّ مِن أجل سَقر، فقال: ﴿كَلّا والقَمَرِ﴾{1}. (ز)"
  74,33,"﴿وَٱلَّیۡلِ إِذۡ أَدۡبَرَ ۝٣٣﴾ - قراءات٧٩٨٥٣- عن هارون بن موسى النّحوي، قال: إنها في حرف أُبَيّ= (ز)٧٩٨٥٤- وابن مسعود: (إذَآ أدْبَرَ) يعني: بألِفين{1}. (١٥/٨٣)٧٩٨٥٥- عن عبد الله بن عباس، أنه قرأ: ‹واللَّيْلِ إذا دَبَرَ› فجعل الألف مع ‹إذا›{2}. (١٥/٨٢)٧٩٨٥٦- عن عبد الله بن الزُّبير، أنه كان يقرأ: ‹واللَّيْلِ إذا دَبَرَ›{3}. (١٥/٨٢)٧٩٨٥٧- عن الحسن البصري، أنه قرأها: ‹إذا دَبَرَ› مثل قراءة عبد الله بن عباس{4}. (١٥/٨٣)٧٩٨٥٨- عن الحسن البصري، أنه قرأها: ﴿واللَّيْلِ إذْ﴾ بغير ألف ﴿أدْبَرَ﴾ بألف{5}٦٨٨٣. (١٥/٨٣)٦٨٨٣ ذكر ابنُ جرير (٢٣/٤٤٢) القراءتين الواردتين في قوله: ﴿إذ أدبر﴾، ثم علّق عليهما بقوله: «والصواب من القول في ذلك عندنا أنهما قراءتان معروفتان صحيحتا المعنى، فبأيّتهما قرأ القارئ فمصيب». ثم ذكر اختلاف أهل اللغة في ذلك، وعلّق بقوله: «والصواب من القول في ذلك عندي: أنهما لغتان بمعنًى، وذلك أنه محكي عن العرب: قبّح الله ما قَبل منه وما دَبر. وأخرى: أنّ أهل التفسير لم يُميّزوا في تفسيرهم بين القراءتين، وذلك دليل على أنهم فعلوا ذلك كذلك؛ لأنهما بمعنًى واحد».﴿وَٱلَّیۡلِ إِذۡ أَدۡبَرَ ۝٣٣﴾ - تفسير الآية٧٩٨٥٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ‹واللَّيْلِ إذا دَبَرَ›، قال: دُبُورُه: ظلامه{6}. (١٥/٨٣)٧٩٨٦٠- عن مجاهد، قال: سألتُ ابن عباس عن قوله: ‹واللَّيْلِ إذا دَبَرَ›. فسكَتَ عني، حتى إذا كان مِن آخر الليل وسمع الأذان الأول ناداني: يا مجاهد، هذا حين دَبر الليل{7}. (١٥/٨٣)٧٩٨٦١- عن قتادة بن دعامة -من طريق سعيد- ﴿واللَّيْلِ إذْ أدْبَرَ﴾: إذ ولّى{8}. (ز)٧٩٨٦٢- قال مقاتل بن سليمان: ﴿واللَّيْلِ إذْ أدْبَرَ﴾، يعني: إذا ذَهبتْ ظُلمته{9}. (ز)"
  74,34,"﴿وَٱلصُّبۡحِ إِذَاۤ أَسۡفَرَ ۝٣٤﴾ - تفسير٧٩٨٦٣- عن قتادة بن دعامة -من طريق سعيد- ﴿والصُّبْحِ إذا أسْفَرَ﴾، قال: إذا أضاء{1}. (١٥/٨٣)٧٩٨٦٤- قال مقاتل بن سليمان: ﴿والصُّبْحِ إذا أسْفَرَ﴾، يعني: ضوءه عن ظُلمة الليل{2}. (ز)"
  74,35,"﴿إِنَّهَا لَإِحۡدَى ٱلۡكُبَرِ ۝٣٥﴾ - تفسير٧٩٨٦٥- عن عبد الله بن عباس -من طريق عطية-: ﴿إنَّها لَإحْدى الكُبَرِ﴾، يعني: جهنم{1}. (ز)٧٩٨٦٦- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل- ﴿إنَّها لَإحْدى الكُبَرِ نَذِيرًا لِلْبَشَرِ﴾، قال: هي جهنم{2}. (١٥/٨٤)٧٩٨٦٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿إنَّها لَإحْدى الكُبَرِ﴾، قال: النار{3}. (١٥/٨٤)٧٩٨٦٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿إنَّها لَإحْدى الكُبَرِ﴾: يعني: جهنم{1}. (ز)٧٩٨٦٩- عن قتادة بن دعامة -من طريق معمر- ﴿إنَّها لَإحْدى الكُبَرِ﴾: النار{5}. (١٥/٨٣)٧٩٨٧٠- قال محمد بن السّائِب الكلبي: ﴿إنَّها لَإحْدى الكُبَرِ﴾ أراد بالكُبَر: دَرَكات جهنم، وهي سبعة: جهنم، ولَظى، والحُطَمة، والسَّعير، وسَقر، والجحيم، والهاوية{6}. (ز)٧٩٨٧١- قال مقاتل بن سليمان: ﴿إنَّها﴾ إنّ سَقر ﴿لَإحْدى الكُبَرِ﴾ مِن أبواب جهنم السبعة: جهنم، ولَظى، والحُطَمة، والسَّعير، وسَقر، والجحيم، والهاوية{7}. (ز)٧٩٨٧٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿إنَّها لَإحْدى الكُبَرِ﴾، قال: هذه النار{8}٦٨٨٤. (ز)٦٨٨٤ أفادت الآثار عوْد الضمير من قوله: ﴿إنها﴾ على جهنم. وقد ذكر ابنُ عطية (٨/٤٦٣) ذلك، ثم بيّن احتمال الآية وجهًا آخر، فقال: «ويحتمل أن يكون الضمير للنّذارة وأمر الآخرة، فهو للحال والقصة». ووجّهه بقوله: «وتكون هذه الآية مثل قوله ﷿: ﴿قُلْ هُوَ نَبَأٌ عَظِيمٌ * أنْتُمْ عَنْهُ مُعْرِضُونَ﴾ [ص:٦٧، ٦٨]»."
  74,36,"﴿نَذِیرࣰا لِّلۡبَشَرِ ۝٣٦﴾ - تفسير٧٩٨٧٣- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق إسماعيل-: ﴿نَذِيرًا لِلْبَشَرِ﴾، يقول الله: أنا لكم منها نذير؛ فاتَّقوها{1}. (ز)٧٩٨٧٤- قال الحسن البصري -من طريق قتادة-: واللهِ، ما أنذر الناسَ بشيء أدهى منها، أو بداهية هي أدهى منها{2}. (ز)٧٩٨٧٥- قال مقاتل بن سليمان: ﴿نَذِيرًا﴾ يعني: تَذْكِرة ﴿لِلْبَشَرِ﴾ يعني: للعالمين{3}. (ز)٧٩٨٧٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿نَذِيرًا لِلْبَشَرِ﴾، قال: الخَلْق. قال: بنو آدمَ البشرُ. فقيل له: محمد النَّذير؟ قال: نعم، يُنذِرهم{1}٦٨٨٥. (ز)٦٨٨٥ اختُلف في معنى قوله: ﴿نذيرا للبشر﴾ على أقوال: الأول: أي: النار. الثاني: أنّ ذلك من صفة الله تعالى، وهو خبر من الله عن نفسه، أنه نذير لخَلْقه. الثالث: ذلك من صفة رسول الله ﷺ.وعلّق ابنُ جرير (٢٣/٤٤٥) على القول الأول، فقال: «فعلى قول هؤلاء: النَّذير نُصب على القطع مِن إحْدى الكُبَر؛ لأن إحْدى الكُبَر مَعْرِفة، وقوله: ﴿نذيرا﴾ نكرة، والكلام قد يحسن الوقوف عليه دونه».وعلّق عليه ابنُ عطية (٨/٤٦٣)، فقال: «وهذا القول يقتضي أنّ ﴿نذيرا﴾ حال من الضمير في ﴿إنَّها﴾، أو من قوله: ﴿لَإحْدى﴾، وكذلك أيضًا على الاحتمال في أن تكون ﴿إنَّها﴾ يُراد بها: قصة الآخرة وحال المعاد».وعلّق ابنُ جرير على القول الثاني، فقال: «وعلى هذا القول يجب أن يكون نصب قوله: ﴿نذيرًا﴾ على الخروج مِن جملة الكلام المتقدم، فيكون معنى الكلام: وما جعلنا أصحاب النار إلا ملائكة نذيرًا للبشر، يعني: إنذارًا لهم؛ فيكون قوله: ﴿نذيرًا﴾ بمعنى: إنذارًا لهم؛ كما قال: ﴿كيف نذير﴾ [الملك:١٧]، بمعنى: إنذاري، ويكون أيضًا بمعنى: إنها إحْدى الكُبَر صَيّرنا ذلك كذلك نذيرًا، فيكون قوله: ﴿إنها لإحدى الكبر﴾ مُؤدّيًا عن معنى صيّرنا ذلك كذلك، وهذا المعنى قصد مَن قال ذلك إن شاء الله».وعلّق عليه ابنُ عطية (٥/٣٩٨)، فقال: «فهذا القول يَقتضي أنّ ﴿نذيرًا﴾ معمول لفعل تقديره: اعبدوا نذيرًا للبشر، أو ادعوا نذيرًا للبشر». وعلّق على القول الثالث، فقال: «فهذا القول يَقتضي أنّ ﴿نذيرًا﴾ معمول لفعل تقديره: نادِ نذيرًا، أو: بلغ نذيرًا، ونحو هذا»."
  74,37,"﴿لِمَن شَاۤءَ مِنكُمۡ أَن یَتَقَدَّمَ أَوۡ یَتَأَخَّرَ ۝٣٧﴾ - تفسير٧٩٨٧٧- عن حُذيفة بن اليمان -من طريق رجل- قال: ما مِن صباح ولا مساء إلا ومنادٍ ينادي: يا أيها الناس، الرَّحيلَ الرَّحيلَ. وإنّ تصديق ذلك في كتاب الله: ﴿إنَّها لَإحْدى الكُبَرِ نَذِيرًا لِلْبَشَرِ لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾ قال: في الموت، ﴿أوْ يَتَأَخَّرَ﴾ قال: في الموت{1}. (١٥/٨٤)٧٩٨٧٨- عن عبد الله بن عباس -من طريق عطية- ﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ أوْ يَتَأَخَّرَ﴾، قال: مَن شاء اتّبع طاعة الله، ومَن شاء تأخّر عنها{2}. (١٥/٨٤)٧٩٨٧٩- قال الحسن البصري: وهذا وعيد لهم، كقوله: ﴿فَمَن شاءَ فَلْيُؤْمِن ومَن شاءَ فَلْيَكْفُرْ﴾ [الكهف:٢٩]{3}. (ز)٧٩٨٨٠- عن قتادة بن دعامة -من طريق سعيد- ﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾ قال: في طاعة الله، ﴿أوْ يَتَأَخَّرَ﴾ قال: في معصية الله{4}٦٨٨٦. (١٥/٨٤)٦٨٨٦ لم يذكر ابنُ جرير (٢٣/٤٤٦-٤٤٧) غير قول قتادة، وابن عباس.٧٩٨٨١- قال مقاتل بن سليمان: ﴿لِمَن شاءَ مِنكُمْ أنْ يَتَقَدَّمَ﴾ في الخير، ﴿أوْ يَتَأَخَّرَ﴾ منه إلى المعصية، هذا تهديد، كقوله: ﴿فَمَن شاءَ فَلْيُؤْمِن ومَن شاءَ فَلْيَكْفُرْ﴾ [الكهف:٢٩]، وكقوله: ﴿اعْمَلُوا ما شِئْتُمْ﴾ [فصلت:٤٠]{5}٦٨٨٧. (ز)٦٨٨٧ ذكر ابنُ عطية (٨/٤٦٤) نحو هذ القول، ثم علّق قائلًا: «هو بيان في النذارة، وإعلام بأنّ كلّ أحد يَسلك طريق الهدى والحق إذا حقّق النظر، أو بعينه يَتأخّر عن هذه الرُّتبة؛ لغفلته وسُوء نظره»."
  74,38,"﴿كُلُّ نَفۡسِۭ بِمَا كَسَبَتۡ رَهِینَةٌ ۝٣٨﴾ - تفسير٧٩٨٨٢- عن علي بن أبي طالب -من طريق زاذان- ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾، قال: مُرتَهنة{1}. (ز)٧٩٨٨٣- عن عبد الله بن عباس -من طريق عطية- في قوله: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾، قال: مأخوذة بعملها{2}. (١٥/٨٤)٧٩٨٨٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾، قال: كلّ نفس سَبقتْ لها كلمة العذاب يَرتَهنها الله في النار، لا يَرتهن اللهُ أحدًا من أهل الجنة، ألم تَسمع أنه قال: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾ يقول: ليسوا رهينة، ﴿فِي جَنّاتٍ يَتَساءَلُونَ﴾{3}. (ز)٧٩٨٨٥- قال مقاتل بن سليمان: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ﴾، يقول: كلّ كافر مُرتهن بذنوبه في النار{4}. (ز)٧٩٨٨٦- عن يحيى بن سلّام -من طريق أحمد- في قوله: ﴿كل نفس﴾ يعني: مِن أهل النار ﴿بما كسبت﴾ بما عَمِلتْ ﴿رهينة﴾ في النار{5}. (ز)"
  74,39,"﴿إِلَّاۤ أَصۡحَـٰبَ ٱلۡیَمِینِ ۝٣٩﴾ - تفسير٧٩٨٨٧- عن علي بن أبي طالب -من طريق زاذان- في قوله: ﴿إلّا أصْحابَ اليَمِينِ﴾، قال: هم أطفال المسلمين{1}. (١٥/٨٥)٧٩٨٨٨- عن عبد الله بن عباس -من طريق أبي ظَبْيان- في هذه الآية: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾، قال: هم الملائكة{2}. (ز)٧٩٨٨٩- عن عبد الله بن عباس، في قوله: ﴿إلّا أصْحابَ اليَمِينِ﴾، قال: هم المسلمون{3}. (١٥/٨٥)٧٩٨٩٠- عن عبد الله بن عمر -من طريق أبي سهل- في قوله: ﴿إلّا أصْحابَ اليَمِينِ﴾، قال: هم أطفال المسلمين{4}. (١٥/٨٥)٧٩٨٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾، قال: لا يُحاسَبون{5}. (١٥/٨٥)٧٩٨٩٢- قال الحسن البصري: ﴿إلّا أصْحابَ اليَمِينِ﴾ هم المسلمون المُخلصون= (ز)٧٩٨٩٣- وعن الحسن البصري أيضًا: هم الذين كانوا ميامين على أنفسهم{6}. (ز)٧٩٨٩٤- عن قتادة بن دعامة -من طريق سعيد- ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾، قال: علَّق الناسَ كلّهم، إلا أصحاب اليمين{7}. (١٥/٨٤)٧٩٨٩٥- قال مقاتل بن سليمان: ﴿إلّا أصْحابَ اليَمِينِ﴾ الذين أُعطوا كُتبهم بأيمانهم، ولا يُرتَهنون بذنوبهم في النار، ثم هم ﴿فِي جَنّاتٍ يَتَساءَلُونَ عَنِ المُجْرِمِينَ﴾{8}. (ز)٧٩٨٩٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿كُلُّ نَفْسٍ بِما كَسَبَتْ رَهِينَةٌ إلّا أصْحابَ اليَمِينِ﴾: أصحاب اليمين لا يُرتَهنون بذنوبهم، ولكن يَغفرها الله لهم. وقرأ قول الله -جلّ ثناؤه-: ﴿إلّا عِبادَ اللَّهِ المُخْلَصِينَ﴾ [الصافات:٤٠]، قال: لا يُؤاخذهم الله بسيئ أعمالهم، ولكن يَغفرها الله لهم، ويَتجاوز عنهم كما وعدهم{9}٦٨٨٨. (ز)٦٨٨٨ اختُلف فيمن عنى الله بقوله: ﴿إلا أصحاب اليمين﴾ على أقوال: الأول: أنهم المسلمون الصالحون. الثاني: أنهم أطفال المسلمين. الثالث: أنهم الملائكة.ولم يذكر ابنُ جرير (٢٣/٤٥٠) غير القول الثاني والثالث، ثم قال معلقًا عليهما: «وإنما قال مَن قال: أصحاب اليمين في هذا الموضع: هم الولدان وأطفال المسلمين، ومَن قال: هم الملائكة؛ لأنّ هؤلاء لم يكن لهم ذنوب، وقالوا: لم يكونوا ليسألوا المجرمين: ﴿ما سلككم في سقر﴾؟ إلا أنهم لم يَقتَرفوا في الدنيا مآثم، ولو كانوا اقترفوها وعرفوها لم يكونوا ليسألوهم عما سلكهم في سَقر؛ لأن كلّ مَن دَخل من بني آدم ممن بلغ التكليف، ولزمه فرض الأمر والنهي، قد عَلم أنّ أحدًا لا يُعاقب إلا على المعصية».وزاد ابنُ عطية (٨/٤٦٤) في الآية قولًا آخر، حكاه عن الضَّحّاك، أنه قال: «هم الذين سَبَقتْ لهم من الله الحُسنى».٧٩٨٩٧- عن يحيى بن سلّام -من طريق أحمد- في قوله: ﴿إلا أصحاب اليمين﴾، قال: هم أصحاب الجنة كلّهم{10}. (ز)"
  74,40,"﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾ - قراءات٧٩٨٩٨- عن عمرو بن دينار، عن عبد الله بن الزُّبير، عن عمر أنه قرأ: (يَآ أيُّها المَرْءُ ما سَلَكَكَ فِي سَقَرَ). قال: أقرأنيها عمر، فلم أنسها بعد{1}. (ز)٧٩٨٩٩- عن عمرو بن دينار -من طريق سفيان بن عُيينة- قال: سمعتُ عبد الله بن الزُّبير يقرأ: (فِي جَنّاتٍ يَتَسَآءَلُونَ عَنِ المُجْرِمِينَ يا فُلان ما سَلَكَكُمْ فِي سَقَرَ).= (ز)٧٩٩٠٠- قال عمرو: وأخبرني لقيط قال: سمعتُ ابن الزُّبير قال: سمعتُ عمر بن الخطاب يقرؤها كذلك{2}. (١٥/٨٥)٧٩٩٠١- عن عبد الله بن مسعود -من طريق أبي الزّعراء- أنه قرأ: (يَآ أيُّها الكُفّارُ ما سَلَكَكُمْ فِي سَقَرَ){3}. (١٥/٨٦)﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾ - تفسير الآية٧٩٩٠٢- عن عبد الله بن مسعود -من طريق أبي الزّعراء- في قصة ذكرها في الشفاعة، قال: ثُمَّ تَشفع الملائكة والنَّبيّون والشهداء والصالحون والمؤمنون، ويُشفّعهم الله، فيقول: أنا أرحم الراحمين. فيُخرِج مِن النار أكثرَ مما أخرج مِن جميع الخَلْق مِن النار، ثم يقول: أنا أرحم الراحمين. ثم قرأ عبد الله: (يَآ أيُّها الكُفّارُ ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ}، وعقَد بيده أربعًا، ثم قال: هل تَرون في هؤلاء مِن خير، ألا ما يُترك فيها أحدٌ فيه خير{4}. (ز)٧٩٩٠٣- قال مقاتل بن سليمان: ... فلمّا أخرج الله أهل التوحيد من النارِ قال المؤمنون لِمَن بقي في النار: ﴿ما سَلَكَكُمْ فِي سَقَرَ﴾، يعني: ما جعلكم في سَقر؟ يعني: ما حبسكم في النار؟{5}. (ز)﴿فِی جَنَّـٰتࣲ یَتَسَاۤءَلُونَ ۝٤٠ عَنِ ٱلۡمُجۡرِمِینَ ۝٤١ مَا سَلَكَكُمۡ فِی سَقَرَ ۝٤٢﴾ - آثار متعلقة بالآية٧٩٩٠٤- عن معونة بن قُرّة{6} -من طريق سلام- قال: ما يَسُرّني بهذه الآية الدنيا وما فيها؛ قوله ﷿: ﴿ما سَلَكَكُمْ فِي سَقَرَ﴾، ألا ترى أنه ليس فيهم خير{7}. (ز)"
  74,41,"74:40"
  74,42,"74:40"
  74,43,"﴿قَالُوا۟ لَمۡ نَكُ مِنَ ٱلۡمُصَلِّینَ ۝٤٣ وَلَمۡ نَكُ نُطۡعِمُ ٱلۡمِسۡكِینَ ۝٤٤﴾ - تفسير٧٩٩٠٥- قال مقاتل بن سليمان: فأجابهم أهلُ النار عن أنفسهم، فـ﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾ في الدنيا لله، ﴿ولَمْ نَكُ نُطْعِمُ المِسْكِينَ﴾ في الدنيا{1}. (ز)"
  74,44,"74:43"
  74,45,"﴿وَكُنَّا نَخُوضُ مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥ وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾ - تفسير٧٩٩٠٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: ﴿وكُنّا نَخُوضُ مَعَ الخائِضِينَ﴾، قال: يقولون: أي: كُلّما غوى غاوٍٍ غَوينا معه{1}. (١٥/٨٦)٧٩٩٠٧- قال مقاتل بن سليمان: ﴿وكُنّا نَخُوضُ مَعَ الخائِضِينَ﴾ في الدنيا في الباطل والتكذيب كما يَخوض كفار مكة، ﴿وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ﴾ يعني: بيوم الحساب أنه غير كائن{2}. (ز)﴿وَكُنَّا نَخُوضُ مَعَ ٱلۡخَاۤىِٕضِینَ ۝٤٥ وَكُنَّا نُكَذِّبُ بِیَوۡمِ ٱلدِّینِ ۝٤٦﴾ - آثار متعلقة بالآية٧٩٩٠٨- قال ابن عون: ما رأيتُ أحدًا كان أعظم رجاء للمُوحِّدين مِن محمد بن سيرين، وكان يتلو هؤلاء الآيات: ﴿إنَّهُمْ كانُوا إذا قِيلَ لَهُمْ لا إلَهَ إلّا اللَّهُ يَسْتَكْبِرُونَ﴾ [الصافات:٣٥]، ويتلو: ﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ﴾، ويتلو: ﴿لا يَصْلاها إلّا الأَشْقى الَّذِي كَذَّبَ وتَوَلّى﴾ [الليل:١٥-١٦]{3}. (ز)"
  74,46,"74:45"
  74,47,"﴿حَتَّىٰۤ أَتَىٰنَا ٱلۡیَقِینُ ۝٤٧﴾ - تفسير٧٩٩٠٩- عن عبد الله بن عباس، ﴿حَتّى أتانا اليَقِينُ﴾، قال: الموت{1}. (١٥/٨٦)٧٩٩١٠- عن سالم بن عبد الله بن عمر، في قوله تعالى: ﴿حَتّى أتانا اليَقِينُ﴾، قال: اليقين: الموت{1}. (١٥/٨٦)٧٩٩١١- قال مقاتل بن سليمان: ﴿حَتّى أتانا اليَقِينُ﴾، يعني: الموت{3}٦٨٨٩. (ز)٦٨٨٩ رجّح ابنُ عطية (٨/٤٦٥) أنّ اليقين معناه: «صحة ما كانوا يُكذِّبون به مِن الرجوع إلى الله تعالى والدار الآخرة». ثم انتقد -مستندًا إلى الدلالة العقلية- القول بأنه الموت، فقال: «وقال المفسرون: اليَقِين: الموت. وذلك عندي هنا مُتعقّب؛ لأن نفس الموت يقين عند الكافر وهو حي، فإنما اليَقِين الذي عَنوا في هذه الآية فهو الشيء الذي كانوا يُكذِّبون به وهم أحياء في الدنيا، فتَيقّنوه بعد الموت، وإنما ُيُفَسَّر اليقين بالموت في قوله تعالى: ﴿واعْبُدْ رَبَّكَ حَتّى يَأْتِيَكَ اليَقِينُ﴾ [الحجر:٩٩]»."
  74,48,"﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾ - تفسير٧٩٩١٢- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «لَيَخرُجنّ بشفاعتي من أهل الإيمان من النار، حتى لا يبقى فيها أحدٌ إلا أهل هذه الآية: ﴿ما سَلَكَكُمْ فِي سَقَرَ﴾ إلى قوله: ﴿شَفاعَةُ الشّافِعِينَ﴾»{1}. (١٥/٨٧)٧٩٩١٣- عن أنس، عن النبيِّ ﷺ، قال: «يُؤتى بأدنى أهل النار منزلة يوم القيامة، فيقول اللهُ له: تَفتدي بملء الأرض ذهبًا وفِضّة؟ فيقول: نعم، إن قَدَرتُ عليه. فيقول: كَذبتَ، قد كنتُ أسألك ما هو أيسرُ عليك مِن أن تسألني فأُعطيك، وتَستغفرني فأغفر لك، وتدعوني فأستجيب لك، فلم تَخفني ساعة قطّ من ليل ونهار، ولم تَرجُ ما عندي قطّ، ولم تَخشَ عقابي ساعة قطّ. وليس وراءه أحد إلا وهو شرٌّ منه، فيقال له: ﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾ إلى قوله: ﴿حَتّى أتانا اليَقِينُ﴾، يقول الله: ﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾»{2}. (١٥/٨٧)٧٩٩١٤- عن حبيبة -أو أُمّ حبيبة- قالت: كُنّا في بيت عائشة، فدخل رسول الله ﷺ، فقال: «ما مِن مُسلِمَيْن يموت لهما ثلاثة من الولد أطفال لم يَبلغوا الحِنث إلا جيء بهم حتى يُوقفوا على باب الجنة، فيقال لهم: ادخلوا الجنة أنتم وآباؤكم». قال: فذلك قوله: ﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾. فعقّب، قال: نَفعت الآباء شفاعة أبنائهم{3}. (ز)٧٩٩١٥- عن عبد الله بن مسعود -من طريق أبي الزّعراء- قال: يُعذِّب الله قومًا مِن أهل الإيمان، ثم يُخرجهم بشفاعة محمد ﷺ، حتى لا يَبقى إلا مَن ذَكر الله: ﴿ما سَلَكَكُمْ فِي سَقَرَ﴾ إلى قوله: ﴿شَفاعَةُ الشّافِعِينَ﴾{4}. (١٥/٨٩)٧٩٩١٦- عن عبد الله [بن مسعود] -من طريق أبي الزّعراء- في حديث طويل عن آخر الزمان ومبدأ البعث، قال: ... ثم يَشفع الملائكة، والنَّبيّون، والشهداء، والصالحون، والمؤمنون، فيُشفِّعهم الله، قال: ثم يقول: أنا أرحم الراحمين. قال: فيُخرج من النار أكثرَ مما أُخرج مِن جميع الخَلْق برحمته، حتى ما يَترك فيها أحدًا فيه خير. ثم قرأ عبد الله: ﴿ما سَلَكَكُمْ فِي سَقَرَ﴾ قال: وجعل يعقِد حتى عدَّ أربعًا: ﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾ ثم قال عبد الله: أترون في هؤلاء خيرًا؟! ما تُرك فيها أحد فيه خير{5}. (ز)٧٩٩١٧- قال عمران بن الحُصَين: الشفاعة نافعةٌ لكلّ واحد، دون هؤلاء الذين تَسمعون{6}. (ز)٧٩٩١٨- عن عبد الرحمن بن ميمون الأَودي: أنّ كعب [الأحبار] دخل يومًا على عمر بن الخطاب، فقال له عمر: حَدِّثني إلى ما تنتهي شفاعة محمد ﷺ يوم القيامة؟ فقال كعب: قد أخبَرك الله في القرآن؛ إنّ الله يقول: ﴿ما سَلَكَكُمْ فِي سَقَرَ﴾ إلى قوله: ﴿اليَقِينُ﴾. قال كعب: فيَشفع يومئذ حتى يَبلغ مَن لم يُصلِّ صلاة قطّ، ولم يُطعم مسكينًا قطّ، ولم يُؤمن ببعثٍ قطّ، فإذا بَلغت هؤلاء لم يبق أحد فيه خير{7}. (١٥/٨٧)٧٩٩١٩- عن مجاهد بن جبر، ﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾، قال: لا تنالهم شفاعة مَن يَشفع{8}. (١٥/٨٧)٧٩٩٢٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾، قال: تعلَّموا أن الله يُشَفِّع المؤمنين يوم القيامة بعضهم في بعض. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «إنّ في أمتي لَرجلًا ليُدخِلنّ الله الجنةَ بشفاعته أكثر من بني تميم». وقال الحسن البصري: أكثر من ربيعة ومُضر. قال: وكُنّا نُحدَّث أنّ الشهيد يَشفع في سبعين من أهل بيته{9}. (١٥/٨٦)٧٩٩٢١- عن إسماعيل السُّدِّيّ -من طريق سفيان- ﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾، قال: لا تَنالهم{10}. (ز)٧٩٩٢٢- قال مقاتل بن سليمان: ﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾، يعني: لا يَنالهم يومئذ شفاعة الملائكة والنَّبيّين{11}. (ز)﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾ - آثار متعلقة بالآية٧٩٩٢٣- عن أنس، يقول: قال النبي ﷺ: «إنّ الرجل ليشفع للرجلين، والثلاثة، والرجل للرجال»{12}. (ز)٧٩٩٢٤- عن أنس، قال: قال رسول الله ﷺ يَصِف أهلَ النار: «فيَمُرّ فيهم الرجل من أهل الجنة، فيقول الرجل منهم: يا فلان. قال: فيقول: ما تريد؟ فيقول: أما تذكر رجلًا سَقاك شربة يوم كذا وكذا؟ قال فيقول: وإنّك لَأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه. قال: ثم يَمُرّ بهم الرجل من أهل الجنة، فيقول: يا فلان، فيقول: ما تريد؟ فيقول: أما تَذكر رجلًا وهب لك وضوءًا يوم كذا وكذا؟ فيقول: إنك لأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه»{13}. (ز)٧٩٩٢٥- عن يزيد بن صُهيب الفقير، قال: كُنّا بمكة ومعي طَلق بن حبيب، وكنا نرى رأي الخوارج، فبَلغنا أنّ جابر بن عبد الله يقول في الشفاعة، فأتيناه، فقلنا له: بلغنا عنك في الشفاعة قولٌ، اللهُ مخالفٌ لك فيها في كتابه. فنَظر في وجوهنا، فقال: مِن أهل العراق أنتم؟ قلنا: نعم. فتبَسّم، وقال: وأين تجدون في كتاب الله؟ قلت: حيث يقول: ﴿رَبَّنا إنَّكَ مَن تُدْخِلِ النّارَ فَقَدْ أخْزَيْتَهُ﴾ [آل عمران:١٩٢]، و﴿يُرِيدُونَ أنْ يَخْرُجُوا مِنَ النّارِ وما هُمْ بِخارِجِينَ مِنها﴾ [المائدة:٣٧]، و﴿كُلَّما أرادُوا أنْ يَخْرُجُوا مِنها أُعِيدُوا فِيها﴾ [السجدة:٢٠]، وأشباه هذا من القرآن. فقال: أنتم أعلم بكتاب الله أم أنا؟ قلنا: بل أنتَ أعلم به منّا. قال: فواللهِ، لقد شهدتُ تنزيل هذا على عهد رسول الله ﷺ وشفاعة الشافعين، ولقد سمعتُ تأويله من رسول الله ﷺ، وإنّ الشفاعة لنبيّه في كتاب الله؛ قال في السورة التي يذكر فيها المُدَّثِّر: ﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾ الآية، ألا تَرون أنها حلّتْ لِمن لا يُشرك بالله شيئًا؟ سمعتُ رسول الله ﷺ يقول: «إنّ الله خَلَق خَلْقًا، ولم يَستعن على ذلك، ولم يُشاور فيه أحدًا، فأَدخلَ مَن شاء الجنة برحمته، وأَدخلَ مَن شاء النار، ثم إنّ الله تحنّن على المُوحِّدين، فبَعث ملَكًا مِن قِبَله بماء ونور، فدَخل النار، فنَضح، فلم يُصب إلا مَن شاء، ولم يُصب إلا مَن خَرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم رجع إلى ربّه، فأمدّه بماء ونور، ثم دَخل فنَضح، فلم يُصب إلا مَن شاء الله، ثم لم يُصب إلا مَن خرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم أذِن الله للشفعاء، فشَفعوا لهم، فأَدخلهم الله الجنة برحمته وشفاعة الشافعين»{14}. (١٥/٨٨)"
  74,49,"﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾ - نزول الآية٧٩٩٢٦- قال مقاتل بن سليمان: ﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾ نزلت هذه الآية في كفار قريش حين أعرَضوا ولم يؤمنوا{1}. (ز)﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾ - تفسير الآية٧٩٩٢٧- عن قتادة بن دعامة -من طريق سعيد- ﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾، قال: عن القرآن{2}. (١٥/٩٠)٧٩٩٢٨- قال مقاتل بن سليمان: ﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ﴾ يعني: عن القرآن ﴿مُعرِضين﴾{3}. (ز)"
  74,50,"﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾ - قراءات٧٩٩٢٩- عن الحسن البصري= (ز)٧٩٩٣٠- وأبي رجاء أنهما قرآ: ‹مُّسْتَنفَرَةٌ›، يعني: بنصب الفاء{1}. (١٥/٩٠)٧٩٩٣١- عن عاصم بن أبي النجود أنه قرأ: ﴿كَأَنَّهُمْ حُمُرٌ﴾ مُثقّلة، ﴿مُسْتَنْفِرَةٌ﴾ بخفض الفاء{2}٦٨٩٠. (١٥/٩٠)٦٨٩٠ ذكر ابنُ جرير (٢٣/٤٥٥) هذه القراءة، وقراءة مَن قرأ ذلك: ‹مُّسْتَنفَرَةٌ›، ثم قال معلقًا: «والصواب من القول في ذلك عندنا أنهما قراءتان معروفتان، صحيحتا المعنى، فبأيّتهما قرأ القارئ فمصيب».﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾ - تفسير الآية٧٩٩٣٢- قال مقاتل بن سليمان: شبّههم بالحُمُر الوحشية المذْعُورة، فقال: ﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ﴾ بترْكهم القرآن، إذا سمعوه فرُّوا منه مثل الحُمر{3}. (ز)"
  74,51,"﴿فَرَّتۡ مِن قَسۡوَرَةِۭ ۝٥١﴾ - تفسير٧٩٩٣٣- عن أبي موسى الأشعري -من طريق أبي ظَبْيان- في قوله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: هم الرُّماة؛ رجال القَنص{1}. (١٥/٩٠)٧٩٩٣٤- عن أبي هريرة -من طريق زيد بن أسلم- في قوله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: الأسد{2}. (١٥/٩٢)٧٩٩٣٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: القَسْورة: الرّجال الرُّماة؛ رجال القَنص{3}. (١٥/٩٠)٧٩٩٣٦- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿مِن قَسْوَرَةٍ﴾، قال: هو بلسان العرب: الأسد، وبلسان الحبشة: قَسْورة{4}. (١٥/٩٢)٧٩٩٣٧- عن عبد الله بن عباس -من طريق أبي حمزة- أنه سأله: القَسْورة الأسد؟ فقال: ما أعلمه بلغة أحد من العرب الأسد، هم عُصْبة الرجال{5}. (١٥/٩١)٧٩٩٣٨- عن عبد الله بن عباس -من طريق يوسف بن مهران- أنه سئل عن قوله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾. قال: هو بالعربية: الأسد، وبالفارسية: شار، وبالنّبَطِيّة: أريا، وبالحبشية: قَسْورة{6}. (ز)٧٩٩٣٩- عن عبد الله بن عباس، ﴿مِن قَسْوَرَةٍ﴾، قال: مِن حبال الصيادين{7}. (١٥/٩١)٧٩٩٤٠- عن عبد الله بن عباس -من طريق عطاء- ﴿مِن قَسْوَرَةٍ﴾، قال: هو رِكْزُ الناس. يعني: أصواتهم{8}. (١٥/٩١)٧٩٩٤١- عن عبد الله بن عباس -من طريق عبّاد بن عبد الرحمن مولى بني هاشم- أنه سئل عن القَسْورة. قال: جمْع الرجال، ألم تسمع ما قالتْ فلانة في الجاهلية:يا بنتي كوني خيْرةً لخَيِّرهأخوالها في الحي مثل القَسْورهْ{9}. (ز)٧٩٩٤٢- عن سعيد بن جُبَير -من طريق أبي بشر- ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: القُنّاص{10}. (١٥/٩١)٧٩٩٤٣- عن مجاهد بن جبر -من طريق منصور- ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: الرُّماة{11}. (١٥/٩١)٧٩٩٤٤- قال الضَّحّاك بن مُزاحِم: هم الرُّماة{12}. (ز)٧٩٩٤٥- قال عكرمة مولى ابن عباس: ﴿قَسْوَرَةٍ﴾، القَسْورة: هي مِن ظُلمة الليل{13}. (ز)٧٩٩٤٦- عن عكرمة مولى ابن عباس، ﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: وحشيّة فرّتْ من رُماتها{14}. (١٥/٩١)٧٩٩٤٧- عن عكرمة مولى ابن عباس -من طريق سِماك- في قوله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: القَسْورة: الرُّماة. فقال رجل لعكرمة: هو الأسد بلسان الحبشة. فقال عكرمة: اسم الأسد بلسان الحبشة: عَنبَسة{15}. (ز)٧٩٩٤٨- عن أبي مالك غَزْوان الغفاري، قال: القَسْورة: الرُّماة{14}. (١٥/٩١)٧٩٩٤٩- عن عطاء بن أبي رباح، مثله{17}. (١٥/٩١)٧٩٩٥٠- عن أبي المُتوكِّل [الناجي] -من طريق إسماعيل بن مسلم العبدي - قال: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾ هي لغَط القوم، وأصواتهم{18}. (ز)٧٩٩٥١- عن قتادة بن دعامة -من طريق معمر- قال: القَسْورة: النَّبْل{19}. (١٥/٩١)٧٩٩٥٢- عن قتادة بن دعامة -من طريق سعيد- ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾: وهم الرُّماة القُنّاص{20}. (ز)٧٩٩٥٣- عن ابن لَهِيعة: أنّ يزيد بن أبي حبيب سُئل عن قول الله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾. فزعم أنه يقال: هم الرُّماة{21}. (ز)٧٩٩٥٤- قال زيد بن أسلم: أي: من رجال أقوياء، وكلّ ضخم شديد عند العرب: قَسْوَر، وقَسْوَرة{13}. (ز)٧٩٩٥٥- عن زيد بن أسلم -من طريق داود بن قيس- في قول الله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: هو الأسد{23}. (ز)٧٩٩٥٦- قال مقاتل بن سليمان: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، يعني: الرُّماة، وقالوا: الأسد{24}. (ز)٧٩٩٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: ﴿فَرَّتْ مِن قَسْوَرَةٍ﴾، قال: القَسْورة: الأسد{6}٦٨٩١. (ز)٦٨٩١ قال ابنُ تيمية (٦/٤٢٨): «و﴿قسورة﴾ يُراد به: الرامي، ويُراد به: الأسد»."
  74,52,"﴿بَلۡ یُرِیدُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُؤۡتَىٰ صُحُفࣰا مُّنَشَّرَةࣰ ۝٥٢﴾ - نزول الآية، وتفسيرها٧٩٩٥٨- عن عبد الله بن عباس -من طريق زاذان- يقول: ﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾، كان المشركون يقولون: لو كان محمد صادقًا فليُصبح عند كلِّ رأس رجل منّا صحيفةٌ فيها براءته وأَمْنه مِن النار{1}. (ز)٧٩٩٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾، قال: إلى فلان بن فلان مِن ربّ العالمين؛ يُصبح عند رأس كلّ رجل صحيفة موضوعة يقرؤها{2}. (١٥/٩٢)٧٩٩٦٠- عن أبي صالح باذام -من طريق السُّدِّيّ- قال: قالوا: إن كان محمد صادقًا فليُصبح تحت رأس كلّ رجل منّا صحيفة فيها براءةٌ وأمَنَةٌ من النار. فنَزلت: ﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾{3}. (١٥/٩٢)٧٩٩٦١- عن قتادة بن دعامة -من طريق سعيد- ﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾، قال: قد قال قائلون من الناس: يا محمد، إن سرَّك أن نتّبعك فأتِنا بكتاب خاصة إلى فلان وفلان، نُؤمر فيه باتّباعك. قال قتادة: يريدون أن يُؤتوا براءة بغير عمل{4}٦٨٩٢. (ز)٦٨٩٢ لم يذكر ابنُ جرير (٢٣/٤٦١) غير قول قتادة، ومجاهد.٧٩٩٦٢- قال مطر الوراق: كانوا يريدون أن يؤتوا براءة من غير عمل{1}. (ز)٧٩٩٦٣- قال محمد بن السّائِب الكلبي: إنّ المشركين قالوا: يا محمد، بلَغنا أنّ الرجل من بني إسرائيل يُصبح مكتوب عند رأسه ذَنبه وكفّارته؛ فأتِنا بمثل ذلك. فكَرهه رسول الله ﷺ، وأنزل الله سبحانه هذه الآية: ﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾{6}. (ز)٧٩٩٦٤- قال مقاتل بن سليمان: ﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى﴾ يقول: يُعطى ﴿صُحُفًا مُنَشَّرَةً﴾ فيها كتاب من الله تعالى. وذلك أنّ كفار مكة قالوا للنبي ﷺ: كان الرجل مِن بني إسرائيل ذَنبه وكفّارة ذَنبه يُصبح مكتوبًا عند رأسه، فهلا تُرينا مثل هؤلاء الآيات إن كنت رسولًا كما تزعم. فقال جبريل: إن شئتَ فعلنا بهم كفِعْلنا ببني إسرائيل، وأَخذناهم بما أخذنا به بني إسرائيل. فكَره النبي ﷺ، وقالوا: ليُصبح عند رأس كلّ رجل منّا كتابٌ منشور مِن الله بأنّ آلهتنا باطل، وأنّ الإله الذي في السماء حقٌّ، وأنك رسول، وأنّ الذي جئت به حقٌّ، وتجيء معك بملائكة يَشهدون بذلك كقول ابن أبي أُمَيّة في سورة بني إسرائيل{7}. (ز)"
  74,53,"﴿كَلَّاۖ بَل لَّا یَخَافُونَ ٱلۡـَٔاخِرَةَ ۝٥٣﴾ - تفسير٧٩٩٦٥- عن الحسن البصري -من طريق أبي الأشهب- ﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾، قال: هذا الذي فَضحهم{1}. (١٥/٩٣)٧٩٩٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾، قال: ذلك الذي تَضَحَّك بالقوم وأَفسدهم؛ أنهم كانوا لا يَخافون الآخرة، ولا يُصدِّقون بها{2}. (١٥/٩٢)٧٩٩٦٧- قال مقاتل بن سليمان: ﴿كَلّا﴾ لا يؤمنون بالصُّحف التي أرادوها، ثم استأنف فقال: ﴿بَلْ﴾ لكن ﴿لا يَخافُونَ﴾ عذاب ﴿الآخِرَةَ﴾{3}. (ز)"
  74,54,"﴿كَلَّاۤ إِنَّهُۥ تَذۡكِرَةࣱ ۝٥٤ فَمَن شَاۤءَ ذَكَرَهُۥ ۝٥٥﴾ - تفسير٧٩٩٦٨- عن قتادة بن دعامة -من طريق سعيد- في قوله ﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾، قال: هذا القرآن{1}. (١٥/٩٢)٧٩٩٦٩- قال مقاتل بن سليمان: ﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾ يعني: القرآن ﴿فَمَن شاءَ ذَكَرَهُ﴾ يعني: فَهِمَهُ، يعني: القرآن{2}. (ز)"
  74,55,"74:54"
  74,56,"﴿وَمَا یَذۡكُرُونَ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ وَأَهۡلُ ٱلۡمَغۡفِرَةِ ۝٥٦﴾ - تفسير٧٩٩٧٠- عن أنس، عن النبيِّ ﷺ، قرأ هذه الآية: ﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾، فقال: «قد قال ربكم: أنا أهْلٌ أنْ أُتَّقى فلا يُجعل معي إلهًا، فمَن اتقاني فلم يَجعل معي إلهًا فأنا أهْلٌ أنْ أغفر له»{1}. (١٥/٩٣)٧٩٩٧١- عن عبد الله بن دينار، قال: سمعتُ أبا هريرة، وابن عمر، وابن عباس، يقولون: سُئِل رسول الله ﷺ عن قول الله: ﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾. قال: «يقول الله: أنا أهْلٌ أنْ أُتقى فلا يُجعل معي شريك، فإذا اتُّقِيتُ ولم يُجعل معي شريك فأنا أهْلٌ أنْ أغفر ما سوى ذلك»{2}. (١٥/٩٤)٧٩٩٧٢- عن الحسن البصري، قال: قال رسول الله ﷺ: «قال الله: لأنا أكرم وأعظم عفوًا من أنْ أستر على عبد لي في الدنيا ثم أفضحه بعد أن سَترتُه، ولا أزال أغفر لعبدي ما استغفرني». قال رسول الله ﷺ: «يقول الله تعالى: إني لأجدني أستحي مِن عبدي، يَرفع يديه إلَيَّ، ثم أردّهما. قالت الملائكة: إلهنا، ليس لذلك بأهل. قال الله: لكني أهْلُ التقوى وأهْلُ المغفرة، أشهدكم أني قد غفرتُ له». قال رسول الله ﷺ: «ويقول الله: إني لأستحي مِن عبدي وأَمَتي يَشيبان في الإسلام، ثم أُعذّبهما بعد ذلك في النار»{3}. (١٥/٩٤)٧٩٩٧٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾، قال: إنّ ربّنا محقوقٌ أن تُتقى محارمه، وهو أهْلٌ أن يغفر الذّنوب الكثيرة لعباده{4}. (١٥/٩٢)٧٩٩٧٤- قال مقاتل بن سليمان: ﴿وما يَذْكُرُونَ﴾ يعني: وما يهتدون ﴿إلّا أنْ يَشاءَ اللَّهُ هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾ يعني: الرّبّ -تبارك وتعالى- نفسه، يقول: هو أهْلٌ أن يُتقى ولا يُعصى، وهو أهْلُ المغفرة لمن يتوب من المعاصي{5}. (ز)٧٩٩٧٥- عن عبد القُدُّوس بن بكر، قال: سمعت ابن النضر الحارثي يذكر في قوله ﷿: ﴿هو أهل التقوى وأهل المغفرة﴾، قال: أنا أهْلٌ لأن يَتقيني عبدي، فإن لم يَفعل كنتُ أهلًا لأنْ أغفر له{6}. (ز)"
