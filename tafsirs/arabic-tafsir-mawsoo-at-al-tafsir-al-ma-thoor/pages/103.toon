tafsir[3]{c,v,t}:
  103,1,"مقدمة السورة٨٤٧٧٥- عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (ز)٨٤٧٧٦- عن عبد الله بن عباس، قال: نزلت سورة ﴿والعصر﴾ بمكة{2}. (١٥/٦٤١)٨٤٧٧٧- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: أنها مكّيّة، وذكرها بمسمّى: ﴿والعصر﴾، وأنها نزلت بعد ﴿ألم نشرح﴾{3}. (ز)٨٤٧٧٨- عن عكرمة مولى ابن عباس= (ز)٨٤٧٧٩- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)٨٤٧٨٠- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)٨٤٧٨١- عن محمد بن مسلم الزُّهريّ -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمّى: ﴿والعصر﴾، وأنها نزلت بعد ﴿والعاديات﴾{6}. (ز)٨٤٧٨٢- عن علي بن أبي طلحة: مكّيّة{7}. (ز)٨٤٧٨٣- قال مقاتل بن سليمان: سورة العصر مكّيّة، عددها ثلاث آيات كوفي{8}. (ز)٨٤٧٨٤- عن أبي مَدينة الدارمي -وكانت له صحبة- قال: كان الرجلان من أصحاب رسول الله ﷺ إذا التقيا لم يتفرّقا حتى يقرأ أحدُهما على الآخر سورة: ﴿والعَصْرِ إنَّ الإنْسانَ لَفِي خُسْرٍ﴾ إلى آخرها، ثم يُسلّم أحدهما على الآخر{9}. (١٥/٦٤١)﴿وَٱلۡعَصۡرِ ۝١﴾ - قراءات٨٤٧٨٥- عن علي بن أبي طالب -من طريق عمرو ذي مر- أنه كان يقرأ: (والعَصْرِ ونَوَآئِبِ الدَّهْرِ){10}. (١٥/٦٤١)﴿وَٱلۡعَصۡرِ ۝١﴾ - تفسير الآية٨٤٧٨٦- عن أُبيّ بن كعب، قال: قرأتُ على رسول الله صلى الله عليه وآله وسلم: ﴿والعصر﴾، فقلتُ: بأبي وأمي يا رسول الله، وما تفسيرها؟ فقال: «﴿والعَصْرِ﴾ قَسَمٌ مِن الله أقسم لكم بآخر النهار، ﴿إنَّ الاْنسانَ لَفِي خُسْر﴾». قال: «أبو جهل بن هشام، ﴿إلاَّ الَّذِينَ آمَنُوا﴾ أبو بكر الصِّدِّيق، ﴿وعَمِلُوا الصّالِحاتِ﴾ عمر بن الخطّاب، ﴿وتَواصَوْا بِالحَقِّ﴾ عثمان بن عفّان، ﴿وتَواصَوْا بِالصَّبْرِ﴾ علي بن أبي طالب»{11}. (ز)٨٤٧٨٧- عن عبد الله بن عباس، في قوله: ﴿والعَصْرِ﴾، قال: الدَّهر{12}. (١٥/٦٤٣)٨٤٧٨٨- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿والعَصْرِ﴾، قال: ساعة من ساعات النهار{13}. (١٥/٦٤٣)٨٤٧٨٩- عن عبد الله بن عباس، ﴿والعَصْرِ﴾، قال: هو ما قبل مغيب الشمس من العشي{12}. (١٥/٦٤٣)٨٤٧٩٠- عن الحسن البصري -من طريق معمر- ﴿والعَصْرِ﴾، قال: العشي{15}. (١٥/٦٤٣)٨٤٧٩١- عن محمد بن كعب القُرَظيّ -من طريق عبد العزيز بن أبي رواد- ﴿والعَصْرِ﴾، قال: قَسمٌ أقسم به ربُّنا -وتبارك وتعالى-{16}. (١٥/٦٤٤)٨٤٧٩٢- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿والعَصْرِ﴾، قال: ساعة من ساعات النهار{17}. (١٥/٦٤٣)٨٤٧٩٣- عن زيد بن أسلم، ﴿والعَصْرِ﴾، قال: هو في كلام العرب: الدَّهر{18}. (١٥/٦٤٣)٨٤٧٩٤- قال مقاتل بن سليمان: ﴿والعَصْرِ﴾ قَسمُ، أقسم الله ﷿ بعصر النهار، وهو آخر ساعة من النهار، وأيضًا العصر{19} سُمّيت العصر حين تصوّبت الشمس للغروب، وهو عصر النهار، فأقسم الله ﷿ بصلاة العصر{20}٧٢٩٢. (ز)٧٢٩٢ اختُلف فيما عنى الله بقوله: ﴿والعصر﴾ على أقوال: الأول: الدهر. الثاني: العشي. الثالث: أنها صلاة العصر.وقد رجّح ابنُ جرير (٢٤/٦١٢) العموم، فقال: «والصواب من القول في ذلك أن يقال: إنّ ربّنا أقسم بالعصر، والعصر اسم للدَّهر، وهو العشي والليل والنهار، ولم يخصص مما شمله هذا الاسم معنى دون معنى، فكلّ ما لزمه هذا الاسم فداخل فيما أقسم به -جلّ ثناؤه-».ورجّح ابنُ القيم (٣/٣٦٧) -مستندًا إلى اللغة- القول الأول، فقال: ""وأكثر المفسرين على أنه الدَّهر، وهذا هو الراجح، وتسمية الدَّهر عصرًا معروف في لغتهم، قال:ولن يلبث العصران يوم وليلة إذا طلبا أن يدركا ما تيمما"".وعلّق ابنُ كثير (١٤/٤٥١) فقال: «والمشهور الأول»."
  103,2,"﴿إِنَّ ٱلۡإِنسَـٰنَ لَفِی خُسۡرٍ ۝٢﴾ - قراءات٨٤٧٩٥- عن إسماعيل بن عبد الملك، قال: سمعتُ سعيد بن جُبَير يقرأ قراءة ابن مسعود: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ * إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ){1}. (١٥/٦٤٢)٨٤٧٩٦- عن حَوْشَب، قال: أرسَل بشر بن مروان إلى عبد الله بن عُتبة بن مسعود، فقال: كيف كان ابن مسعود يقرأ: ﴿والعَصْرِ﴾؟ فقال: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وهُوَ فِيهِ إلى ءاخِرِ الدَّهْرِ). فقال له بشر: هو يكفر به. فقال عبد الله: لكني أومن به{2}. (١٥/٦٤٣)٨٤٧٩٧- عن علي بن أبي طالب -من طريق عمرو ذي مر- أنه كان يقرأ: (إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ){3}. (١٥/٦٤١)٨٤٧٩٨- عن إبراهيم النَّخعي، قال: قراءتنا: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ لَفِيهِ إلى ءاخِرِ الدَّهْرِ * إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ){2}. (١٥/٦٤٢)٨٤٧٩٩- عن ميمون بن مهران أنه قرأ: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ* إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ وتَواصوْا بِالحَقِّ وتَواصَوْا بِالصَّبْرِ).= (ز)٨٤٨٠٠- ذُكر أنها في قراءة عبد الله بن مسعود{2}. (١٥/٦٤٢)٨٤٨٠١- عن قتادة بن دعامة -من طريق سعيد- ﴿إنَّ الإنسانَ لَفِي خُسْرٍ﴾: ففي بعض القراءات: (وإنَّهُ فِيهِ إلى ءاخِرِ الدَّهْرِ){6}. (ز)﴿إِنَّ ٱلۡإِنسَـٰنَ لَفِی خُسۡرٍ ۝٢﴾ - نزول الآية، وتفسيرها٨٤٨٠٢- عن أُبيّ بن كعب، قال: قال رسول الله صلى الله عليه وآله وسلم: ﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾، قال: «أبو جهل بن هشام»{7}. (ز)٨٤٨٠٣- عن عبد الله بن عباس -من طريق رفاعة القرظي- في قوله: ﴿والعَصْرِ إنَّ الإنْسانَ لَفِي خُسْرٍ﴾: يعني: أبا جهل بن هشام{8}. (١٥/٦٤٤)٨٤٨٠٤- عن كعب [الأحبار] – من طريق ابن علي- ﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾، قال: يعني: آدم وبنيه{9}. (ز)٨٤٨٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: ﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾، يعني: ضلال{10}. (١٥/٦٤٤)٨٤٨٠٦- عن إبراهيم [النَّخْعي] -من طريق ابن عون- قال: أراد أنّ الإنسان إذا عمّر في الدنيا وهَرم لَفي نقصٍ وضعفٍ وتراجع؛ إلّا المؤمنين، فإنّهم يُكتب لهم أجورهم ومحاسن أعمالهم التي كانوا يعملونها في حال شبابهم وقوّتهم وصحّتهم، وهي مثل قوله سبحانه: ﴿لَقَدْ خَلَقْنا الإنْسانَ فِي أحْسَنِ تَقْوِيمٍ ثُمَّ رَدَدْناهُ أسْفَلَ سافِلِينَ إلّا الَّذِينَ آمَنُوا...﴾ [التين:٤-٦]{11}. (ز)٨٤٨٠٧- عن محمد بن كعب القُرَظيّ -من طريق عبد العزيز بن أبي رواد- ﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾، قال: الناس كلهم{12}. (١٥/٦٤٤)٨٤٨٠٨- قال مقاتل بن سليمان: ﴿إنَّ الإنْسانَ لَفِي خُسْرٍ﴾ نزلت في أبي لهب، اسمه: عبد العُزّى بن عبد المُطَّلب، يعني: إنه لفي ضلال أبدًا حتى يدخل النار{13}. (ز)"
  103,3,"﴿إِلَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ﴾ - تفسير٨٤٨٠٩- عن أُبيّ بن كعب، قال: قال رسول الله صلى الله عليه وآله وسلم: «﴿إلّا الَّذِينَ آمَنُوا﴾ أبو بكر الصِّدِّيق، ﴿وعَمِلُوا الصّالِحاتِ﴾ عمر بن الخطاب، ﴿وتواصوا بالحقّ﴾ عثمان بن عفان، ﴿وتواصوا بالصبر﴾ علي بن أبي طالب»{1}. (ز)٨٤٨١٠- عن عبد الله بن عباس -من طريق رفاعة القرظي-: ﴿إلّا الَّذِينَ آمَنُوا﴾ أبو بكر الصِّدِّيق، ﴿وعَمِلُوا الصّالِحاتِ﴾ عمر بن الخطاب{2}. (ز)٨٤٨١١- عن عبد الله بن عباس، في قوله: ﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ﴾: ذكر عليًّا، وسلمان{3}. (١٥/٦٤٤)٨٤٨١٢- عن إبراهيم النَّخْعي، قال: قراءتنا: (والعَصْرِ * إنَّ الإنسانَ لَفِي خُسْرٍ * وإنَّهُ لَفِيهِ إلى ءاخِرِ الدَّهْرِ * إلّا الَّذِينَ ءامَنُواْ وعَمِلُواْ الصّالِحاتِ). قال: هي مثل التي في «التين والزيتون» [٤-٦]: ﴿لَقَدْ خَلَقْنا الإنسانَ فِي أحْسَنِ تَقْوِيمٍ ثُمَّ رَدَدْناهُ أسْفَلَ سافِلِينَ إلّا الَّذِينَ ءامَنُوا وعَمِلُوا الصّالِحاتِ﴾{4}. (١٥/٦٤٢)٨٤٨١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿إلّا الَّذِينَ آمَنُوا﴾، قال: إلا مَن آمن{5}. (١٥/٦٤٤)٨٤٨١٤- عن محمد بن كعب القُرَظيّ -من طريق عبد العزيز بن أبي رواد-: ثم استثنى، فقال: ﴿إلّا الَّذِينَ آمَنُوا﴾ ثم لم يدعهم، وذاك حتى قال: ﴿وعَمِلُوا الصّالِحاتِ﴾{6}. (١٥/٦٤٤)٨٤٨١٥- قال مقاتل بن سليمان: ﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ﴾ فليسوا في خُسران{7}. (ز)﴿وَتَوَاصَوۡا۟ بِٱلۡحَقِّ وَتَوَاصَوۡا۟ بِٱلصَّبۡرِ ۝٣﴾ - تفسير٨٤٨١٦- عن أُبيّ بن كعب، قال: قال رسول الله صلى الله عليه وآله وسلم: «﴿وتَواصَوْا بِالحَقِّ﴾ عثمان بن عفان، ﴿وتَواصَوْا بِالصَّبْرِ﴾ علي بن أبي طالب»{8}. (ز)٨٤٨١٧- عن عبد الله بن عباس -من طريق رفاعة القرظي-: ﴿وتَواصَوْا بِالحَقِّ﴾ عثمان بن عفان، ﴿وتَواصَوْا بِالصَّبْرِ﴾ علي بن أبي طالب{2}. (ز)٨٤٨١٨- عن كعب [الأحبار] -من طريق ابن علي- ﴿وتَواصَوْا بِالحَقِّ﴾ قال: الحقّ هو الله ﷿، والإيمان به، ﴿وتَواصَوْا بِالصَّبْرِ﴾ على فرائض الله وحُكمه{10}. (ز)٨٤٨١٩- عن الحسن البصري -من طريق معمر- في قوله تعالى: ﴿وتَواصَوْا بِالحَقِّ﴾ قال: الحقّ: كتاب الله، ﴿وتَواصَوْا بِالصَّبْرِ﴾ والصبر: طاعة الله{11}. (ز)٨٤٨٢٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿وتَواصَوْا بِالحَقِّ﴾ قال: كتاب الله، ﴿وتَواصَوْا بِالصَّبْرِ﴾ قال: طاعة الله{12}٧٢٩٣. (١٥/٦٤٣)٧٢٩٣ لم يذكر ابن جرير (٢٤/٦١٤-٦١٥) غير قول قتادة، والحسن.٨٤٨٢١- عن محمد بن كعب القُرَظيّ -من طريق عبد العزيز بن أبي رواد-: ثم لم يدعهم وذاك حتى قال: ﴿وتَواصَوْا بِالحَقِّ﴾، ثم لم يدعهم وذاك حتى قال: ﴿وتَواصَوْا بِالصَّبْرِ﴾ شروطًا يشترط عليهم{6}. (١٥/٦٤٤)٨٤٨٢٢- قال مقاتل بن سليمان: ﴿وتَواصَوْا بِالحَقِّ﴾ يعني: بتوحيد الله ﷿، ﴿وتَواصَوْا بِالصَّبْرِ﴾ يعني: على أمر الله ﷿، فمَن فعل هذين كان مِن الذين آمنوا وعملوا الصالحات، فليسوا من الخُسران في شيء، ولكنهم في الجنان مُخلَّدون{7}. (ز)٨٤٨٢٣- قال يحيى بن سلّام: ﴿وتواصوا بالحق﴾ يعني بالحق: الله، ﴿وتواصوا بالصبر﴾ على فرائضه{15}. (ز)"
