tafsir[44]{c,v,t}:
  70,1,"مقدمة السورة٧٨٦٥٣- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة ﴿سأل﴾ بمكة{1}. (١٤/٦٨٦)٧٨٦٥٤- عن عبد الله بن الزبير، مثله{2}. (١٤/٦٨٦)٧٨٦٥٥- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسَمّاها: ﴿سأل سائل﴾، ونزلت بعد الحاقة{3}. (ز)٧٨٦٥٦- عن عكرمة مولى ابن عباس= (ز)٧٨٦٥٧- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسَمّياها: ﴿سأل سائل﴾{4}. (ز)٧٨٦٥٨- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)٧٨٦٥٩- عن محمد بن مسلم الزُّهريّ: مكّيّة، وسَمّاها: ﴿سأل سائل﴾، ونزلت بعد الحاقة{6}. (ز)٧٨٦٦٠- عن علي بن أبي طلحة: مكّيّة{7}. (ز)٧٨٦٦١- قال مقاتل بن سليمان: سورة المعارج مكّيّة، عددها أربع وأربعون آية كوفي{8}٦٧٨١. (ز)٦٧٨١ ذكر ابنُ عطية (٨/٣٩٩): «أنّ هذه السورة مكّيّة بلا خلاف بين الرواة».وبنحوه قال ابنُ تيمية (٦/٣٩٤)."
  70,2,"﴿سَأَلَ سَاۤىِٕلُۢ بِعَذَابࣲ وَاقِعࣲ ۝١ لِّلۡكَـٰفِرِینَ لَیۡسَ لَهُۥ دَافِعࣱ ۝٢﴾ - نزول الآية٧٨٦٦٢- عن عبد الله بن عباس -من طريق سعيد- في قوله: ﴿سَأَلَ سائِلٌ﴾، قال: هو النَّضر بن الحارث، قال: ﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ﴾ [الأنفال:٣٢]{1}. (١٤/٦٨٦)٧٨٦٦٣- عن زيد بن أسلم، مثله{2}. (١٤/٦٨٦)٧٨٦٦٤- عن الحسن البصري، قال: نزلت: ﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾، فقال الناس: على مَن يقع العذاب؟ فأنزل الله: (عَلى الكافِرِينَ لَيْسَ لَهُ دافِعٌ){3}. (١٤/٦٨٧)٧٨٦٦٥- عن إسماعيل السُّدِّيّ، في قوله: ﴿سَأَلَ سائِلٌ﴾، قال: نَزَلَتْ بمكة في النَّضر بن الحارث وقد قال: ﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ﴾ الآية [الأنفال:٣٢]، وكان عذابه يوم بدر{4}. (١٤/٦٨٦)٧٨٦٦٦- قال مقاتل بن سليمان: ﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾ نزلت في النَّضر بن الحارث بن عَلقمة بن كلدة القُرشي مِن بني عبد الدار بن قُصي، وذلك أنه قال: اللهم إن كان ما يقول محمد هو الحق مِن عندك فأمطر علينا حجارة من السماء أو ائتنا بعذاب أليم. فقُتِل يوم بدر{5}. (ز)﴿سَأَلَ سَاۤىِٕلُۢ بِعَذَابࣲ وَاقِعࣲ ۝١ لِّلۡكَـٰفِرِینَ لَیۡسَ لَهُۥ دَافِعࣱ ۝٢﴾ - تفسير الآية، وقراءاتها٧٨٦٦٧- قال زيد بن ثابت: سال وادٍ مِن أودية جهنم يُقال له: سائل{6}. (ز)٧٨٦٦٨- عن عبد الله بن عباس، في قوله: ‹سالَ سَآئِلٌ›، قال: سال وادٍ في جهنم{7}. (١٤/٦٨٨)٧٨٦٦٩- عن عبد الله بن عباس -من طريق سعيد- في قوله: ﴿بِعَذابٍ واقِعٍ﴾، قال: كائن{8}. (١٤/٦٨٦)٧٨٦٧٠- عن زيد بن أسلم، مثله{2}. (١٤/٦٨٦)٧٨٦٧١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: ﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾، قال: ذاك سؤال الكفار عن عذاب الله، وهو واقع{10}. (ز)٧٨٦٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿سَأَلَ سائِلٌ﴾ قال: دعا داعٍ. وفي قوله: ﴿بِعَذابٍ واقِعٍ﴾ قال: يقع في الآخرة، وهو قولهم: ﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾ [الأنفال:٣٢]{11}. (١٤/٦٨٧)٧٨٦٧٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿بِعَذابٍ واقِعٍ لِلْكافِرِينَ﴾، يقول: واقع على الكافرين{12}. (ز)٧٨٦٧٤- قال الحسن البصري: إنّ المشركين قالوا للنبيِّ ﷺ: لِمَن هذا العذابُ الذي تَذكر أنّه يكون في الآخرة؟ فقال الله: ﴿سَأَلَ سائِلٌ بِعَذابٍ﴾ أي: عن عذاب ﴿واقِعٍ لِلْكافِرِينَ﴾{13}. (ز)٧٨٦٧٥- عن عطاء، قال: قال رجلٌ مِن عبد الدار يُقال له: الحارث بن عَلقمة: ﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾ [الأنفال:٣٢]. فقال الله: ﴿وقالُوا رَبَّنا عَجِّلْ لَنا قِطَّنا قَبْلَ يَوْمِ الحِسابِ﴾ [ص:١٦]. وقال الله: ﴿ولَقَدْ جِئْتُمُونا فُرادى﴾ [الأنعام:٩٤]. وقال الله: ﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾ هو الذي قال: ﴿إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ فَأَمْطِرْ﴾، وهو الذي قال: ﴿رَبَّنا عَجِّلْ لَنا قِطَّنا﴾، وهو الذي سأل عذابًا هو واقع به{14}. (١٤/٦٨٧)٧٨٦٧٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: ﴿سَأَلَ سائِلٌ﴾، قال: سأل سائل عن عذاب واقع، فقال الله: ﴿لِلْكافِرِينَ لَيْسَ لَهُ دافِعٌ مِنَ اللَّهِ﴾{15}. (ز)٧٨٦٧٧- قال مقاتل بن سليمان:... هذا العذاب الذي سأل النَّضر بن الحارث في الدنيا هو ﴿لِلْكافِرينَ﴾ في الآخرة، ﴿لَيْسَ لَهُ دافِعٌ* مِنَ اللَّهِ﴾ يقول: لا يَدفع عنهم أحدٌ حين يَقع بهم العذاب{5}. (ز)٧٨٦٧٨- عن عبد الملك ابن جُرَيْج، في قوله: ﴿بِعَذابٍ واقِعٍ﴾ قال: يقع في الآخرة، قولهم في الدنيا: ﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقَّ مِن عِنْدِكَ﴾ [الأنفال:٣٢]، هو النَّضر بن الحارث{2}. (١٤/٦٨٧)٧٨٦٧٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: ﴿سَأَلَ سائِلٌ بِعَذابٍ واقِعٍ﴾، قال: قال بعض أهل العلم: هو وادٍ في جهنم، يُقال له: سائل{18}٦٧٨٢. (ز)٦٧٨٢ اختُلف في المراد بقوله: ﴿سأل سائل﴾ على قولين: الأول: أنه من السؤال، ومَن قال بهذا قرأ قوله: ﴿سأل سائل﴾ بالهمز. الثاني: أنه وادٍ في جهنم يقال له: سائل، ومَن قال بهذا قرأ: ‹سالَ سائِلٌ› بدون همز، ووجّهه إلى أنه فعْل من السّيل.ورجَّح ابنُ جرير (٢٣/٢٤٨) -مستندًا إلى إجماع القراء، والسلف من أهل التأويل- قراءة الهمز، والقول الأول الذي قاله ابن عباس من طريق العَوفيّ، ومجاهد، والحسن، وعطاء، وقتادة، ومقاتل، وذلك: «لإجماع الحُجّة مِن القراء على ذلك، وأنّ عامة أهل التأويل من السلف بمعنى الهمز تأولوه».ورجَّحه ابنُ كثير (١٤/١٢٥) مستندًا إلى السياق، فقال: «والصحيح الأول؛ لدلالة السياق عليه». وانتقد القول الثاني الذي قاله زيد بن ثابت، وابن زيد، فقال: «وهذا القول ضعيف، بعيد عن المراد».وساق ابنُ عطية (٨/٤٠١) القول الثاني، ثم علَّق بقوله: «ويحتمل -إن لم يصح أمر الوادي- أن يكون الإخبار عن نفوذ القَدَر بذلك العذاب، فاستُعير له لفظ السّيل؛ لِما عُهد من نفوذ السّيل وتصميمه». واختَلَف مَن قرأ بالهمز في المعنى المراد على قولين: الأول: أنّ المعنى: دعا داعٍ. الثاني: استفهم مُستفهم.وذكر ابنُ عطية (٨/٣٩٩) أنّ على القول الأول الذي قاله مجاهد فالباء في قوله: ﴿بعذاب﴾ على عُرفها. وأنه على القول الثاني الذي قاله الحسن، وقتادة، فالباء تُوصّل توصيل «عن»، كأنه تعالى قال: «عن عذاب»."
  70,3,"﴿مِّنَ ٱللَّهِ ذِی ٱلۡمَعَارِجِ ۝٣﴾ - تفسير٧٨٦٨٠- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: ﴿مِنَ اللَّهِ ذِي المَعارِجِ﴾، قال: ذي الدَّرجات{1}. (١٤/٦٨٦)٧٨٦٨١- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿ذِي المَعارِجِ﴾، قال: ذي العُلُوِّ والفواضل{2}٦٧٨٣. (١٤/٦٨٨)٦٧٨٣ ذكر ابنُ عطية (٨/٤٠١) أنّ المعارج على هذا القول مستعارة في الرُّتَب والصفات.٧٨٦٨٢- قال عبد الله بن عباس: ﴿مِنَ اللهِ ذِي المَعارِجِ﴾، يعني: ذي السماوات{3}. (ز)٧٨٦٨٣- قال سعيد بن جُبَير: ﴿ذِي المَعارِجِ﴾ ذي الدَّرجات{3}. (ز)٧٨٦٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿ذِي المَعارِجِ﴾، قال: معارج السماء{5}. (١٤/٦٨٨)٧٨٦٨٥- عن مجاهد بن جبر، في قوله: ﴿ذِي المَعارِجِ﴾، قال: معارج الملائكة{6}. (١٤/٦٨٨)٧٨٦٨٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿ذِي المَعارِجِ﴾، قال: ذي الفضائل والنّعم{7}. (١٤/٦٨٨)٧٨٦٨٧- قال مقاتل بن سليمان: ثم عظّم الرّبُّ -تبارك وتعالى- نفسه، فقال: ﴿مِنَ اللَّهِ ذِي المَعارِجِ﴾ يعني: ذا الدرجات، يعني: السموات، والعرش فوقهم، والله تعالى على العرش. كقوله: ﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾ [الزخرف:٣٣]{8}. (ز)٧٨٦٨٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿ذِي المَعارِجِ﴾، قال: الله ذو المعارج{9}. (ز)﴿مِّنَ ٱللَّهِ ذِی ٱلۡمَعَارِجِ ۝٣﴾ - آثار متعلقة بالآية٧٨٦٨٩- عن عبد الله بن عباس، قال: آخرُ شيء حُفِظ عن رسول الله ﷺ قوله: «رفيع الدَّرجات ذو المعارج، قد بلّغتُ» ثلاثًا «الصلاةَ، ومِلكَ اليمين». ثلاثًا{10}. (ز)٧٨٦٩٠- عن سعد بن أبي وقّاص، أنه سمع رجلًا يقول: لبّيك، ذا المعارج. فقال: إنه لذو المعارج، ولكنّا كُنّا مع رسول الله ﷺ لا نقول ذلك{11}. (١٤/٦٨٨)"
  70,4,"﴿تَعۡرُجُ ٱلۡمَلَـٰۤىِٕكَةُ وَٱلرُّوحُ إِلَیۡهِ﴾ - قراءات٧٨٦٩١- عن عاصم أنه قرأ: ﴿تَعْرُجُ المَلَآئِكَةُ﴾ بالتاء{1}. (١٤/٦٨٩)٧٨٦٩٢- عن أبي إسحاق، قال: كان عبد الله [بن مسعود] يقرأ: ‹يَعْرُجُ الـمَلَآئِكَةُ› بالياء{2}٦٧٨٤. (١٤/٦٨٩)٦٧٨٤ اختُلف في قراءة قوله: ﴿تعرج﴾؛ فقرأ قوم بالتاء، وقرأ آخرون بالياء.ورجَّح ابنُ جرير (٢٣/٢٥٤) -مستندًا إلى إجماع القراء- قراءة التاء، فقال: «والصوابُ مِن قراءة ذلك عندنا ما عليه قراء الأمصار، وهو بالتاء؛ لإجماع الحُجّة من القُراء عليه».﴿تَعۡرُجُ ٱلۡمَلَـٰۤىِٕكَةُ وَٱلرُّوحُ إِلَیۡهِ﴾ - تفسير الآية٧٨٦٩٣- قال مقاتل بن سليمان: ﴿تَعْرُجُ﴾ يعني: تصعد ﴿المَلائِكَةُ﴾ مِن سماءٍ إلى سماءِ العرش ﴿والرُّوحُ﴾ يعني: جبريل ﵇ ﴿إلَيْهِ﴾ في الدنيا برِزق السموات السبع{3}٦٧٨٥. (ز)٦٧٨٥ ذكر ابنُ عطية (٨/٤٠١) أنّ ﴿الروح﴾ هو جبريل عند الجمهور، وأنه خَصّصه بالذكر تشريفًا. وذكر قولين آخرين: الأول: أنّ الروح: ملائكة حفظة للملائكة الحافظين لبني آدم، لا تراهم الملائكة كما لا نرى نحن الملائكة. ونسبه لمجاهد. الثاني: أنه اسم الجنس في أرواح الحيوان. ونسبه لبعض المفسرين.وذكر ابنُ كثير (١٤/١٢٥) قولًا ثالثًا، ونسبه لأبي صالح، وهو أنّ الروح خَلْقٌ من خَلْق الله، يُشبِهون الناس، وليسوا أناسًا. ثم علَّق بقوله: «ويحتمل أن يكون المراد به جبريل، ويكون من باب عطف الخاص على العام. ويحتمل أن يكون اسم جنس لأرواح بني آدم، فإنها إذا قُبِضتْ يُصعَد بها إلى السماء، كما دلّ عليه حديث البراء».﴿فِی یَوۡمࣲ كَانَ مِقۡدَارُهُۥ خَمۡسِینَ أَلۡفَ سَنَةࣲ ۝٤﴾ - تفسير٧٨٦٩٤- عن أبي سعيد الخُدري، قال: سُئل رسول الله ﷺ عن: ﴿يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾ ما أطول هذا اليوم! فقال: «والذي نفسي بيده، إنه لَيُخفّف على المؤمن حتى يكون أهون عليه مِن صلاة مكتوبة يُصلّيها في الدنيا»{4}٦٧٨٦. (١٤/٦٩١)٦٧٨٦ ذكر ابنُ عطية (٨/٤٠٢) أنه على هذا فاليوم المشار إليه يوم القيامة، والقدْر في الهول والشدّة. ثم قال: «وهذا كما تقول في اليوم العصيب: إنه كسَنَة، ونحو هذا».٧٨٦٩٥- عن عبد الله بن عباس -من طريق ليث، عن مجاهد- في قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: مُنتهى أمْره من أسفل الأرضين إلى مُنتهى أمْره مِن فوق سبع سموات مِقدار خمسين ألف سنة، و﴿فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾ [السجدة:٥] يعني بذلك: يَنزل الأمْرُ مِن السماء إلى الأرض ومن الأرض إلى السماء في يوم واحد، فذلك مِقداره ألف سنة؛ لأن ما بين السماء والأرض مسيرة خمسمائة عام{5}٦٧٨٧. (١٤/٦٨٩)٦٧٨٧ علَّق ابنُ كثير (١٤/١٢٧) على هذا الأثر بقوله: «قد رواه ابن جرير عن ابن حميد، عن حكام بن سلم، عن عمر بن معروف، عن ليث، عن مجاهد قوله، لم يذكر ابن عباس».٧٨٦٩٦- عن عبد الله بن عباس -من طريق عبد الوهاب بن مجاهد بن جبر، عن أبيه- قال: غِلظ كلّ أرض خمسمائة عام، وبين كلّ أرض إلى أرض خمسمائة عام، ومن السماء إلى السماء خمسمائة عام، فذلك أربعة عشر ألف عام، وبين السماء السابعة وبين العرش مسيرة ستة وثلاثين ألف عام، فذلك قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾{6}. (١٤/٦٨٩)٧٨٦٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ مِمّا تَعُدُّونَ﴾ [السجدة:٥]، قال: هذا في الدنيا؛ تَعرج الملائكة في يوم كان مِقداره ألف سنة. وفي قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾: فهذا يوم القيامة، جَعله الله على الكافرين مقدار خمسين ألف سنة{7}. (١٤/٦٨٩)٧٨٦٩٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: لو قدّرتموه لكان خمسين ألف سنة مِن أيامكم. قال: يعني: يوم القيامة{8}٦٧٨٨. (١٤/٦٩٠)٦٧٨٨ علَّق ابنُ عطية (٨/٤٠٢) على هذا القول بقوله: «وهذا هو ظاهر قول النبي ﷺ: «ما من رجل لا يُؤدّي زكاة ماله إلا جُعل له صفائح من نار يوم القيامة، تُكوى بها جبهته وظهره وجنباه، في يوم كان مقداره ألف سنة»». وذكر أنه قد ورد في يوم القيامة أنه كألف سنة، وعلَّق عليه بقوله: «وهذا يشبه أن يكون في طوائف دون طوائف».٧٨٦٩٩- عن عبد الله بن عباس -من طريق ابن أبي مُلَيْكَة- أنّ رجلًا سأله عن يوم كان مِقداره ألف سنة. فقال: ما يوم كان مِقداره خمسين ألف سنة؟ قال: إنما سألتُك لتُخبِرني! قال: هما يومان ذكرهما الله في القرآن، الله أعلم بهما. فكَره أن يقول في كتاب الله ما لا يعلم{9}. (ز)٧٨٧٠٠- قال عبد الله بن عباس -من طريق عطاء-= (ز)٧٨٧٠١- ومقاتل: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، معناه: لو ولي محاسبة العباد في ذلك اليوم غير الله لم يَفرغ منه خمسين ألف سنة{10}. (ز)٧٨٧٠٢- عن عكرمة، قال: سأل رجلٌ ابنَ عباس: ما هؤلاء الآيات: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، و﴿يُدَبِّرُ الأَمْرَ مِنَ السَّماءِ إلى الأَرْضِ ثُمَّ يَعْرُجُ إلَيْهِ فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ مِمّا تَعُدُّونَ﴾ [السجدة:٥]، ﴿ويَسْتَعْجِلُونَكَ بِالعَذابِ ولَنْ يُخْلِفَ اللَّهُ وعْدَهُ وإنَّ يَوْمًا عِنْدَ رَبِّكَ كَأَلْفِ سَنَةٍ مِمّا تَعُدُّونَ﴾ [الحج:٤٧]؟ قال: يوم القيامة حساب خمسين ألف سنة، وخلق الله السماوات والأرض في ستة أيام، كل يوم ألف سنة، و﴿يُدَبِّرُ الأَمْرَ مِنَ السَّماءِ إلى الأَرْضِ ثُمَّ يَعْرُجُ إلَيْهِ فِي يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾ [السجدة:٥]، قال: ذلك مقدار المسير{11}. (١٤/٦٩٠)٧٨٧٠٣- عن مجاهد بن جبر -من طريق ليث- ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: مِن مُنتهى أمْره مِن أسفل الأرضين إلى مُنتهى أمْره مِن فوق السماوات مقدار خمسين ألف سنة، و﴿يَوْمٍ كانَ مِقْدارُهُ ألْفَ سَنَةٍ﴾ [السجدة:٥]، يعني بذلك: نَزل الأمر من السماء إلى الأرض ومن الأرض إلى السماء في يوم واحد، فذلك مِقداره ألف سنة؛ لأن ما بين السماء إلى الأرض مسيرة خمس مائة عام{12}. (ز)٧٨٧٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح-= (ز)٧٨٧٠٥- وعكرمة مولى ابن عباس -من طريق الحكم بن أبان- ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قالا: هي الدنيا أولها إلى آخرها يومٌ مقداره خمسون ألف سنة، لا يدري أحد كم مضى، ولا كم بقي إلا الله{13}٦٧٨٩. (١٤/٦٩٠)٦٧٨٩ ساق ابنُ عطية (٨/٤٠٢) هذا القول، ثم علَّق بقوله: «فالمعنى: تَعرج الملائكة والروح إليه في مدة الدنيا، وبقاء هذه البِنْية». ثم قال: «ويتمكن -على هذا- في ﴿الروح﴾ أن يكون جنس أرواح الحيوان».٧٨٧٠٦- عن عكرمة مولى ابن عباس -من طريق سماك بن حرب- ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: يوم القيامة{14}. (ز)٧٨٧٠٧- عن عكرمة مولى ابن عباس -من طريق سِماك بن حرب- ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: في يوم واحد يَفْرَغ في ذلك اليوم من القضاء، كقدر خمسين ألف سنة{15}. (ز)٧٨٧٠٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾: يعني: يوم القيامة{16}. (ز)٧٨٧٠٩- قال الحسن البصري: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾ هو يوم القيامة{17}. (ز)٧٨٧١٠- قال عطاء: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾ ويَفْرَغ الله منه في مِقدار نصف يوم من أيام الدنيا{10}. (ز)٧٨٧١١- عن وهْب بن مُنَبِّه -من طريق ابن أبي نجيح- قال: هو ما بين أسفل الأرض إلى العرش{19}٦٧٩٠. (١٤/٦٩١)٦٧٩٠ قال ابنُ عطية (٨/٤٠٢): «من جعل ﴿الروح﴾ جبريل أو نوعًا مِن الملائكة قال: المسافة هي مِن قَعْر الأرض السابعة إلى العرش. قاله مجاهد. ومَن جعل ﴿الروح﴾ جنس الحيوان قال: المسافة من وجه هذه الأرض إلى مُنتهى العرش عُلوًّا. قاله وهْب بن مُنَبِّه».٧٨٧١٢- عن قتادة بن دعامة -من طريق سعيد- ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: ذلك يوم القيامة{20}. (١٤/٦٩١)٧٨٧١٣- عن محمد بن السّائِب الكلبي -من طريق محمد بن الفضل- قال: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، يقول: لو ولَّيْتُ حسابَ ذلك اليوم الملائكةَ والجنَ والإنسَ، وطَوَّقْتُهُم محاسبتهم؛ لم يَفْرَغوا منه إلا بعد خمسين ألف سنة، وأنا أفْرغ منها في ساعة واحدة من النهار{21}. (ز)٧٨٧١٤- قال مقاتل بن سليمان: ثم أخبر الله ﷿ عن ذلك العذاب متى يقع بها، فقال: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾ فيها تقديم، وطول ذلك اليوم كأدنى صلاتهم. يقول: لو ولي حسابَ الخلائق وعرْضَهم غيري لم يَفْرَغ منه إلا في مِقدار خمسين ألف سنة، فإذا أخذ الله تعالى في عرْضهم يَفْرَغ الله منه على مِقدار نصف يوم من أيام الدنيا، فلا يَنتصف النهار حتى يستقرّ أهلُ الجنة في الجنة، وأهلُ النار في النار. وهذه الآية نَزَلَتْ فيهم: ﴿أصْحابُ الجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًّا وأَحْسَنُ مَقِيلًا﴾ [الفرقان:٢٤]، يقول: ليس مَقِيلهم كمَقِيل أهل النار{22}. (ز)٧٨٧١٥- قال محمد بن إسحاق: لو سار بنو آدم مِن الدنيا إلى موضع العرش لَساروا خمسين ألف سنة مِن سِنِي الدنيا{23}. (ز)٧٨٧١٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿فِي يَوْمٍ كانَ مِقْدارُهُ خَمْسِينَ ألْفَ سَنَةٍ﴾، قال: هذا يوم القيامة{16}٦٧٩١. (ز)٦٧٩١ اختُلف في المراد بقوله: ﴿في يوم كان مقداره خمسين ألف سنة﴾ على أقوال: الأول: أنّ المراد بذلك: يوم القيامة. الثاني: مدة بقاء الدنيا. الثالث: الحساب.وساق ابنُ عطية (٨/٤٠٢-٤٠٣) الأقوال، ثم علَّق بقوله: «والعامل في قوله تعالى: ﴿يوم﴾ -على قول مَن قال: إنه يوم القيامة- قوله: ﴿دافع﴾، وعلى سائر الأقوال: ﴿تعرج﴾».وذكر ابنُ كثير (١٤/١٢٧) أنّ القول الأول وردت فيه أحاديث، وساق الحديث الوارد عن أبي سعيد في تفسير الآية، والوارد عن أبي هريرة في الآثار المتعلقة بالآية. وذكر قولًا آخر وهو أنه اليوم الفاصل بين الدنيا والآخرة. ونسبه لمحمد بن كعب، وعلَّق عليه بقوله: «وهو قول غريب جدًّا».﴿فِی یَوۡمࣲ كَانَ مِقۡدَارُهُۥ خَمۡسِینَ أَلۡفَ سَنَةࣲ ۝٤﴾ - آثار متعلقة بالآية٧٨٧١٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «ما مِن رجل لا يُؤدّي زكاة ماله إلا جُعِل يوم القيامة صفائح مِن نار يُكوى بها جنبه وجبهته وظهره، في يوم كان مِقداره خمسين ألف سنة»{25}. (ز)٧٨٧١٨- عن أبي هريرة مرفوعًا، قال: «ما قدْر طول يوم القيامة على المؤمنين إلا كقدْر ما بين الظهر إلى العصر»{26}. (١٤/٦٩٢)٧٨٧١٩- عن الحسن، قال: قال رسول الله ﷺ: «إنّ طول يوم القيامة على المؤمن مثل صلاة صَلّاها في الدنيا فأكمَلها وأحسَنها»{27}. (ز)٧٨٧٢٠- عن عبد الله بن عمرو، قال: يَشتدّ كَرْبُ يوم القيامة حتى يُلجم الكافرَ العَرقُ. قيل: فأين المؤمنون يومئذ؟ قال: يُوضع لهم كراسي من ذهب، ويُظلّل عليهم الغَمام، ويُقَصَّر ذلك اليوم عليهم ويُهَوّن، حتى يكون كيوم من أيامكم هذه{2}. (١٤/٦٩١)٧٨٧٢١- عن الحسن البصري، قال: يكون عليهم كصلاة مكتوبة{2}. (١٤/٦٩٢)٧٨٧٢٢- عن إبراهيم التيميّ -من طريق الثوري- قال: قدْر يوم القيامة على المؤمن قدْر ما بين الظهر إلى العصر{30}. (١٤/٦٩١)"
  70,5,"﴿فَٱصۡبِرۡ صَبۡرࣰا جَمِیلًا ۝٥﴾ - تفسير٧٨٧٢٣- عن عبد الله بن عباس، في قوله: ﴿صَبْرًا جَمِيلًا﴾، قال: لا تشكو إلى أحد غيري{1}. (١٤/٦٩٢)٧٨٧٢٤- قال مقاتل بن سليمان: ﴿فاصْبِرْ﴾ يا محمد ﴿صَبْرًا جَمِيلًا﴾ يُعزّي نبيَّه ﷺ؛ صبرًا لا جَزع فيه لتكذيبهم إيّاك بأنّ العذاب غير كائن{2}. (ز)٧٨٧٢٥- عن عبد الأعلى بن الحجاج، في قوله: ﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾، قال: يكون صاحبُ المصيبة في القوم لا يُعرف مَن هو{3}. (١٤/٦٩٢)﴿فَٱصۡبِرۡ صَبۡرࣰا جَمِیلًا ۝٥﴾ - النسخ في الآية٧٨٧٢٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾، قال: هذا حين كان يأمره بالعفو عنهم، لا يُكافئهم، فلمّا أُمِر بالجهاد والغِلْظة عليهم أُمِر بالشدّة والقتل حتى يَتركوا، ونُسخ هذا{4}. (ز)٧٨٧٢٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿فاصْبِرْ صَبْرًا جَمِيلًا﴾، قال: ... نُسِخ هذا{5}٦٧٩٢. (ز)٦٧٩٢ انتقد ابنُ جرير (٢٣/٢٥٥) قول ابن زيد مستندًا إلى عدم الدليل، فقال: «وهذا الذي قاله ابن زيد أنه كان أُمِر بالعفو بهذه الآية، ثم نُسخ ذلك، قول لا وجْه له؛ لأنه لا دلالة على صحة ما قال مِن بعض الأوجه التي تَصحّ منها الدعاوي، وليس في أمْر الله نبيّه ﷺ في الصبر الجميل على أذى المشركين ما يوجب أن يكون ذلك أمرًا منه له به في بعض الأحوال، بل كان ذلك أمرًا مِن الله له به في كل الأحوال؛ لأنّه لم يزل ﷺ من لدن بَعثه الله إلى أن اختَرمه في أذًى منهم، وهو في كلّ ذلك صابر على ما يَلقى منهم مِن أذى قبل أن يأذن الله له بحربهم، وبعد إذنه له بذلك».وذكر ابنُ عطية (٨/٤٠٣) أنّ الأمْر بالصبر الجميل محكم في كل حالة."
  70,6,"﴿إِنَّهُمۡ یَرَوۡنَهُۥ بَعِیدࣰا ۝٦ وَنَرَىٰهُ قَرِیبࣰا ۝٧﴾ - تفسير٧٨٧٢٨- عن سليمان بن مهران الأعمش -من طريق سفيان- ﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا﴾، قال: الساعة{1}. (١٤/٦٩٢)٧٨٧٢٩- قال مقاتل بن سليمان: ثم قال: ﴿إنَّهُمْ يَرَوْنَهُ﴾ يعني: كفار مكة ﴿بَعِيدًا﴾ يعني: العذاب أنه غير كائن، ﴿ونَراهُ قَرِيبًا﴾ أنه كائن{2}. (ز)٧٨٧٣٠- عن عبد الملك ابن جُرَيْج، في قوله: ﴿إنَّهُمْ يَرَوْنَهُ بَعِيدًا﴾ قال: بتكذيبهم، ﴿ونَراهُ قَرِيبًا﴾ قال: صِدقًا كائنًا{3}. (١٤/٦٩٢)"
  70,7,"70:6"
  70,8,"﴿یَوۡمَ تَكُونُ ٱلسَّمَاۤءُ كَٱلۡمُهۡلِ ۝٨﴾ - تفسير٧٨٧٣١- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- في قوله: ﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾، قال: كدُرْدِيّ الزَّيْت{1}{2}. (١٤/٦٩٢)٧٨٧٣٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: ﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾. قال: كدُردِيّ الزّيت وسواد العَرق مِن خوف يوم القيامة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول الشاعر:تُبارِي به العِيسُ السمومَ كأنها تبطّنت الأقراب{3} من عَرَق مُهلا؟{4}. (١٤/٦٩٣)٧٨٧٣٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾، قال: عكَر الزّيت{5}٦٧٩٣. (١٤/٦٩٣)٦٧٩٣ علَّق ابنُ عطية (٨/٤٠٣) على هذا القول بقوله: «فهي لسوادها وانكدار أنوارها تُشبه ذلك».٧٨٧٣٤- قال الحسن البصري: ﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾ كالفِضّة إذا أُذيبتْ{6}٦٧٩٤. (ز)٦٧٩٤ علَّق ابنُ عطية (٨/٤٠٣) على هذا القول بقوله: «فيجيء له ألوان وتميُّع مختلط، والسماء أيضًا -للأهوال التي تُدركها- تصير مثل ذلك».٧٨٧٣٥- عن قتادة بن دعامة -من طريق سعيد- ﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾، قال: إنها الآن خضراء، وإنها تُحوّل يوم القيامة لونًا آخر إلى الحُمرة{7}. (١٤/٦٩٣)٧٨٧٣٦- قال زيد بن أسلم: ﴿كالمُهْلِ﴾ كعَكر الزّيت{8}. (ز)٧٨٧٣٧- قال مقاتل بن سليمان: ثم أخبر متى يقع بهم العذاب، فقال: يقع بهم العذاب ﴿يَوْمَ تَكُونُ السَّماءُ كالمُهْلِ﴾ مِن الخوف، يعني: أسود غليظًا كدُردِيّ الزيت بعد الشدّة والقوة{9}. (ز)"
  70,9,"﴿وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ۝٩﴾ - تفسير٧٨٧٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿وتَكُونُ الجِبالُ كالعِهْنِ﴾، قال: كالصُّوف{1}. (١٤/٦٩٣)٧٨٧٣٩- قال الحسن البصري: ﴿كالعِهْنِ﴾ كالصُّوف الأحمر، وهو أضعف الصُّوف{2}. (ز)٧٨٧٤٠- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: ﴿كالعِهْنِ﴾ قال: كالصُّوف{3}. (ز)٧٨٧٤١- قال مقاتل بن سليمان: ﴿وتَكُونُ الجِبالُ كالعِهْنِ﴾ فشبّهها في اللين والوَهن بالصُّوف المنفوش بعد القوة، وذلك أوهن ما يكون من الصُّوف{4}٦٧٩٥. (ز)٦٧٩٥ ذكر ابنُ عطية (٨/٤٠٣-٤٠٤) أنّ بعض اللغويين قال: العهن: «هو الصوف المصبوغ ألوانًا». وبيّن أنّ مَن قال بهذا استدلّ بقول زُهير:كأن فُتات العِهْن في كلّ منزل نَزلْنَ به حَبُّ الفَنا لم يُحَطَّمِثم قال: «وحب الفنا: هو عِنَب الثعلب. وكذلك هو عند طِيبه وقبل تحطّمه ألوان بعضه أحمر، وبعضه أصفر، وبعضه أخضر؛ لاختلافه في النضج». ثم علَّق بقوله: «وتشبه ﴿الجبال﴾ به -على هذا القول-؛ لأنها جُدَد بِيض وحُمر وسُود، فيجيء التشبيه من وجهين: أحدهما: في الألوان. والثاني: في الانتفاش». وبيّن (٨/٤٠٤) أنّ مَن قال: إنّ العهن: الصوف دون تقييد، جَعل التشبيه في الانتفاش وتخلخل الأجزاء فقط."
  70,10,"﴿وَلَا یَسۡـَٔلُ حَمِیمٌ حَمِیمࣰا ۝١٠﴾ - تفسير٧٨٧٤٢- عن الضَّحّاك بن مُزاحِم -من طريق جُويبر- ﴿ولا يَسْئَلُ حَمِيمٌ حَمِيمًا﴾، قال: يَرى أُمّه وزوجته وحميمه، فلا يَسأل عنه من الخوف{1}. (ز)٧٨٧٤٣- قال الحسن البصري: ﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾ لا يَسأل قريبٌ قريبَه أن يَحمل عنه مِن ذنوبه شيئًا؛ كما كان يَحمل بعضهم في الدنيا عن بعض{2}. (ز)٧٨٧٤٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾، قال: شُغِل كلُّ إنسان بنفسه عن الناس{3}. (١٤/٦٩٣)٧٨٧٤٥- قال مقاتل بن سليمان: ﴿ولا يَسْئَلُ حَمِيمٌ حَمِيمًا﴾ يعني: قريب قريبًا، يقول: لا يَسأل الرجلُ قرابتَه، ولا يُكلّمه مِن شدّة الأهوال{4}. (ز)"
  70,11,"﴿یُبَصَّرُونَهُمۡۚ﴾ - تفسير٧٨٧٤٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿يُبَصَّرُونَهُمْ﴾، قال: يَعْرِف بعضهم بعضًا ويَتعارفون، ثم يَفرّ بعضهم من بعض. يقول: ﴿لكل امرئ منهم يومئذ شأن يغنيه﴾ [عبس:٣٧]{1}. (١٤/٦٩٤)٧٨٧٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿يُبَصَّرُونَهُمْ﴾، قال: المؤمنون يُبصرون الكافرين{2}. (١٤/٦٩٣)٧٨٧٤٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿يُبَصَّرُونَهُمْ﴾ قال: يُعَرَّفونهم؛ يُعلَّمون، واللهِ، ليَعرفنّ يوم القيامة قومٌ قومًا، وأناسٌ أناسًا، ﴿يَوَدُّ المُجْرِمُ لَوْ يَفْتَدِي﴾ الآيةَ قال: يتمنّى يوم القيامة لو يَفتدي بالأَحبّ فالأَحبّ، والأقرب فالأقرب، من أهله وعشيرته؛ لشدّة ذلك اليوم{2}. (١٤/٦٩٣)٧٨٧٤٩- قال إسماعيل السُّدِّيّ: ﴿يُبَصَّرُونَهُمْ﴾ يعرفونهم؛ أما المؤمن فببياض وجهه، وأما الكافر فبسواد وجهه{4}. (ز)٧٨٧٥٠- قال مقاتل بن سليمان: ﴿يُبَصَّرُونَهُمْ﴾ يقول: يعرفونهم، ولا يُكلّمونهم، وذلك قوله: ﴿فهم لا يتساءلون﴾ [القصص:٦٦]، ﴿خاشِعَةً أبْصارُهُمْ﴾ [القلم:٤٣] خافضة أبصارهم ذليلة عند مُعاينة النار{5}. (ز)٧٨٧٥١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿يُبَصَّرُونَهُمْ﴾، قال: يُبصرون الذين أضلُّوهم في الدنيا في النار{6}٦٧٩٦. (ز)٦٧٩٦ اختُلف في الذين عُنوا بالهاء والميم في قوله: ﴿يبصرونهم﴾ على أقوال: الأول: أنه عُني بذلك: الأقرباء؛ أنهم يَعرفون أقرباءهم، ويَعرف كلّ إنسان قريبه، فذلك تبصير الله إياهم. الثاني: أنّ المؤمنين يُبصرون الكافرين. الثالث: أنّ الكفار الذين كانوا أتباعًا لآخرين في الدنيا على الكفر يُعرّفون المتبوعين في النار.ورجَّح ابنُ جرير (٢٣/٢٥٩) -مستندًا إلى السياق- القول الأول الذي قاله ابن عباس، وقتادة، فقال: «لأنّ ذلك أشبهها بما دلّ عليه ظاهر التنزيل، وذلك أنّ قوله: ﴿يبصرونهم﴾ تلا قوله: ﴿ولا يسأل حميم حميما﴾؛ فلأن تكون الهاء والميم من ذكرهم أشبه منها بأن تكون مِن ذِكْر غيرهم».﴿یَوَدُّ ٱلۡمُجۡرِمُ لَوۡ یَفۡتَدِی مِنۡ عَذَابِ یَوۡمِىِٕذِۭ بِبَنِیهِ ۝١١﴾ - تفسير٧٨٧٥٢- قال مقاتل بن سليمان: ﴿يَوَدُّ المُجْرِمُ﴾ يعني: الكافر ﴿لَوْ يَفْتَدِي مِن عَذابِ يَوْمِئِذٍ﴾ يوم القيامة ﴿بِبَنِيهِ﴾{5}. (ز)"
  70,12,"﴿وَصَـٰحِبَتِهِۦ وَأَخِیهِ ۝١٢﴾ - تفسير٧٨٧٥٣- قال مقاتل بن سليمان: ﴿وصاحِبَتِهِ﴾ يعني: امرأته{1}. (ز)٧٨٧٥٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿وصاحِبَتِهِ﴾، قال: الصاحبة الزوجة{2}. (ز)"
  70,13,"﴿وَفَصِیلَتِهِ ٱلَّتِی تُـٔۡوِیهِ ۝١٣ وَمَن فِی ٱلۡأَرۡضِ جَمِیعࣰا ثُمَّ یُنجِیهِ ۝١٤﴾ - تفسير٧٨٧٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿وفَصِيلَتِهِ﴾، قال: قبيلته{1}. (١٤/٦٩٤)٧٨٧٥٦- عن الضَّحّاك بن مُزاحِم، ﴿وفَصِيلَتِهِ﴾، قال: عشيرته{2}. (١٤/٦٩٤)٧٨٧٥٧- عن محمد بن كعب القُرَظيّ، ﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾، قال: قبيلته التي يَنتسب إليها{2}. (١٤/٦٩٤)٧٨٧٥٨- قال مقاتل بن سليمان: ﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾ يعني: رهطه وفَخذه الأدنى الذي يساوى إليهم، ﴿ومَن فِي الأَرْضِ جَمِيعًا﴾ مِن شيء، ﴿ثُمَّ يُنْجِيهِ﴾{4}. (ز)٧٨٧٥٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾، قال: فصيلته: عشيرته{5}٦٧٩٧. (ز)٦٧٩٧ ذكر ابنُ عطية (٨/٤٠٥) أنّ الفصيلة -في هذه الآية-: قرابة الرجل الأدنون. مثال ذلك: بنو هاشم مع النبي ﷺ. وأنها أيضًا في كلام العرب: الزوجة. ثم قال: «ولكن ذكْر الصاحبة في هذه الآية لم يُبْق في معنى الفصيلة إلا الوجه الذي ذكرناه»."
  70,14,"70:13"
  70,15,"﴿كَلَّاۤۖ إِنَّهَا لَظَىٰ ۝١٥﴾ - تفسير٧٨٧٦٠- قال مقاتل بن سليمان: يقول الله تعالى: ﴿كَلّا﴾ لا يُنجيه ذلك لو افتَدى بهذا كلّه، ثم استأنف فقال: ﴿إنَّها لَظى﴾ يعني بلَظى: استطالتها وقُدرتها عليهم، يعني: النار{1}. (ز)"
  70,16,"﴿نَزَّاعَةࣰ لِّلشَّوَىٰ ۝١٦﴾ - تفسير٧٨٧٦١- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- في قوله: ﴿نَزّاعَةً لِلشَّوى﴾، قال: تَنزع أُمّ الراس{1}. (١٤/٦٩٤)٧٨٧٦٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: ﴿نَزّاعَةً لِلشَّوى﴾ يعني: الجلود والهام{1}. (ز)٧٨٧٦٣- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- ﴿نَزّاعَةً لِلشَّوى﴾: للعَصب والعَقب{3}. (ز)٧٨٧٦٤- قال أبو العالية الرِّياحيّ: ﴿نَزّاعَةً لِّلشَّوى﴾ لمحاسن وجهه{4}. (ز)٧٨٧٦٥- قال مُرّة: ﴿نَزّاعَةً لِلشَّوى﴾ للأعضاء{3}. (ز)٧٨٧٦٦- عن سعيد بن جُبَير، ﴿نَزّاعَةً لِلشَّوى﴾، قال: فَروة الرأس{6}. (١٤/٦٩٥)٧٨٧٦٧- عن إبراهيم بن المُهاجر، قال: سألتُ سعيد بن جُبَير عن قوله: ﴿نَزّاعَةً لِلشَّوى﴾. فلم يُخبر، فسألتُ عنها مجاهد بن جبر، فقلتُ: اللحم دون العظم؟ فقال: نعم{1}. (ز)٧٨٧٦٨- عن مجاهد بن جبر -من طريق الأعمش- ﴿نَزّاعَةً لِلشَّوى﴾، قال: الشّوى: الأطراف{8}. (١٤/٦٩٥)٧٨٧٦٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿نَزّاعَةً لِلشَّوى﴾، قال: لجلود الرأس{9}. (١٤/٦٩٤)٧٨٧٧٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿نَزّاعَةً لِلشَّوى﴾: تَبري اللحم والجلد عن العظم، حتى لا تَترك منه شيئًا{10}. (ز)٧٨٧٧١- عن الحسن البصري -من طريق قُرّة بن خالد- ﴿نَزّاعَةً لِلشَّوى﴾، قال: للهام، تَحرق كلّ شيء منه، ويَبقى فؤاده يصيح{11}. (ز)٧٨٧٧٢- عن أبي صالح باذام -من طريق إسماعيل- ﴿نَزّاعَةً لِلشَّوى﴾، قال: للحم السّاقين{12}. (١٤/٦٩٥)٧٨٧٧٣- عن أبي صالح باذام، ﴿نَزّاعَةً لِلشَّوى﴾، قال: الأطراف{6}. (١٤/٦٩٥)٧٨٧٧٤- عن قتادة بن دعامة -من طريق سعيد- ﴿نَزّاعَةً لِلشَّوى﴾، قال: لِهامته، ومَكارم وجهه{14}. (١٤/٦٩٤)٧٨٧٧٥- عن ثابت البُناني -من طريق جعفر- ﴿نَزّاعَةً لِلشَّوى﴾، قال: لِمَكارِم وجه ابن آدم{15}. (١٤/٦٩٥)٧٨٧٧٦- قال محمد بن السّائِب الكلبي: ﴿نَزّاعَةً لِّلشَّوى﴾ لأُمّ الرأس، تأكل الدِّماغ كلّه، ثم يعود كما كان، ثم تعود لأَكْله، فذلك دَأْبها{4}. (ز)٧٨٧٧٧- قال مقاتل بن سليمان: ﴿نَزّاعَةً لِلشَّوى﴾، يقول: تَنزع النارُ الهامةَ، والأطرافَ؛ فلا تَبْقى{17}. (ز)٧٨٧٧٨- عن قُرّة بن خالد، ﴿نَزّاعَةً لِلشَّوى﴾، قال: نزّاعة للهام، تحرق كلّ شيء منه، ويبقى فؤاده نضيجًا{18}. (١٤/٦٩٥)٧٨٧٧٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿نَزّاعَةً لِلشَّوى﴾، قال: الشوى: الآراب العظام، ذاك الشوى{19}٦٧٩٨. (ز)٦٧٩٨ ذكر ابنُ جرير (٢٣/٢٦١) أنّ «الشوى»: جمع شواة، وهي من جوارح الإنسان ما لم يكن مَقتلًا، يقال: رمى فأشوى: إذا لم يُصب مقتلًا، ثم علَّق بقوله: ""فربما وصف الواصف بذلك جِلدة الرأس، كما قال الأعشى:قالَتْ قُتَيْلَةُ ما لَهُ قَدْ جُلِّلَتْ شَيْبًا شَواتُهْ؟وربما وصف بذلك الساق كقولهم في صفة الفرس:عبْل الشوى نهد الجزارهيعني بذلك: قوائمه، وأصل ذلك كله ما وصفت"".وبنحوه قال ابنُ عطية (٨/٤٠٥-٤٠٦)، وكذا قال ابنُ القيم (٣/١٩٦)."
  70,17,"﴿تَدۡعُوا۟ مَنۡ أَدۡبَرَ وَتَوَلَّىٰ ۝١٧﴾ - تفسير٧٨٧٨٠- قال عبد الله بن عباس: ﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾ تدعو الكافرين والمنافقين بأسمائهم بلسان فصيح، ثم تَلتَقطهم كما يَلتَقط الطيرُ الحَبَّ{1}٦٧٩٩. (ز)٦٧٩٩ ذكر ابنُ عطية (٨/٤٠٦) أنه على هذا القول فدعاء النار حقيقة، ثم نَقل عن الخليل بن أحمد القول بأنّ نداءها عبارة عن حِرْصها عليهم، واستدنائها لهم، وما تُوقعه من عذابها. ونَقل عن ثعلب القول بأنّ: ﴿تَدْعُو﴾ معناه: تُهلك، ثم علَّق بقوله: «تقول العرب: دعاك الله، أي: أهلكك، وحكاه الخليل عن العرب».٧٨٧٨١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾، قال: عن الحق{2}. (١٤/٦٩٤)٧٨٧٨٢- عن قتادة بن دعامة -من طريق سعيد- ﴿تَدْعُو مَن أدْبَرَ﴾ قال: عن طاعة الله، ﴿وتَوَلّى﴾ قال: عن كتاب الله، وعن حقّه{3}. (١٤/٦٩٤)٧٨٧٨٣- قال مقاتل بن سليمان: ﴿تَدْعُوا مَن أدْبَرَ﴾ يعني: تدعو النار يوم القيامة، تقول: إلَيَّ أهلي. فهذا دعاؤها لـــ﴿مَن أدْبَرَ﴾ عن الإيمان، ﴿وتَوَلّى﴾ يقول: وأَعرَض عنه إلى الكفر{4}. (ز)٧٨٧٨٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾، قال: ليس لها سلطان إلا على هوان مَن كَفر وتَولّى وأَدبَر عن الله، فأمّا مَن آمن بالله ورسوله فليس لها عليه سلطان{5}. (ز)"
  70,18,"﴿وَجَمَعَ فَأَوۡعَىٰۤ ۝١٨﴾ - تفسير٧٨٧٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿وجَمَعَ فَأَوْعى﴾، قال: جمع المال{1}. (١٤/٦٩٤)٧٨٧٨٦- عن قتادة بن دعامة -من طريق سعيد- ﴿وجَمَعَ فَأَوْعى﴾، قال: كان جَموعًا للخبيث{2}. (١٤/٦٩٤)٧٨٧٨٧- قال مقاتل بن سليمان: قوله: ﴿وجَمَعَ فَأَوْعى﴾، يعني: فأَكثر مِن المال، وأَمسَك، فلم يُؤدّ حقّ الله فيه{3}. (ز)﴿وَجَمَعَ فَأَوۡعَىٰۤ ۝١٨﴾ - آثار متعلقة بالآية٧٨٧٨٨- عن الحكم، قال: كان عبد الله بن عُكَيم لا يَربط كِيسه، قال: سمعتُ الله يقول: ﴿وجَمَعَ فَأَوْعى﴾{4}. (١٤/٦٩٥)"
  70,19,"﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾ - نزول الآية٧٨٧٨٩- عن عبد الله بن عباس، قال: نَزَلَتْ في أبي جهل بن هشام{1}. (١٤/٦٩٦)٧٨٧٩٠- قال مقاتل بن سليمان: ﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾، يعني: ضَجرًا، فهو أُمَيّة بن خلف الجُمَحي{2}. (ز)﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾ - تفسير الآية٧٨٧٩١- عن عبد الله بن عباس، ﴿هَلُوعًا﴾، قال: الشَّرِه{3}. (١٤/٦٩٦)٧٨٧٩٢- عن عكرمة، قال: سُئل ابن عباس عن الهَلُوع، فقال: هو كما قال الله؛ إذا مسه الشر كان جَزُوعًا، وإذا مَسَّهُ الخَيْر كان مَنُوعًا، فهو الهَلُوع{4}. (١٤/٦٩٥)٧٨٧٩٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾، قال: هو الذي قال الله: ﴿إذا مَسَّهُ الشَّرُّ جَزُوعًا وإذا مَسَّهُ الخَيْر مَنُوعًا﴾. ويقال: الهَلُوع: هو الجَزُوع الحريص، وهذا في أهل الشّرك{5}. (ز)٧٨٧٩٤- عن عبد الله بن عباس -من طريق السدي، عن أبي صالح- في قوله: ﴿هَلُوعًا﴾، قال: الحريص على ما لا يحل له{6}. (ز)٧٨٧٩٥- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: ﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾. قال: ضَجورًا جَزوعًا، نَزَلَتْ في أبي جهل بن هشام. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ بِشر بن أبي خازم وهو يقول:لا مانعًا لليتيم نِحْلته ولا مُكِبًا بخلْقه هلِعًا؟{7}. (١٤/٦٩٦)٧٨٧٩٦- عن سعيد بن جُبَير -من طريق جعفر بن أبي المُغيرة- في قوله: ﴿هَلُوعًا﴾، قال: شَحيحًا جَزُوعًا{8}. (١٤/٦٩٦)٧٨٧٩٧- قال مجاهد بن جبر: ﴿منوعا﴾ شرِهًا{6}. (ز)٧٨٧٩٨- عن الضَّحّاك بن مُزاحِم، ﴿هَلُوعًا﴾، قال: الذي لا يَشبع مِن جَمْع المال{3}. (١٤/٦٩٦)٧٨٧٩٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿إنَّ الإنْسانَ﴾ يعني: الكافر ﴿خُلِقَ هَلُوعًا﴾ يقول: هو بخيلٌ، مَنوعٌ للخير، جَزوعٌ إذا نَزل به البلاء، فهذا الهَلُوع{5}. (ز)٧٨٨٠٠- عن عكرمة مولى ابن عباس -من طريق إسماعيل بن أبي خالد- ﴿هَلُوعًا﴾، قال: الضَّجِر{8}. (١٤/٦٩٦)٧٨٨٠١- عن الحسن البصري -من طريق حُميد- أنه سُئِل عن قوله: ﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾. قال: اقرأ ما بعدها. فقرأ: ﴿إذا مَسَّهُ الشَّرُّ جَزُوعًا وإذا مَسَّهُ الخَيْر مَنُوعًا﴾. قال: هو هكذا، خُلِق هكذا{13}. (١٤/٦٩٦)٧٨٨٠٢- قال الحسن البصري -من طريق معمر-: ﴿هَلُوعًا﴾ هو الشَّرِه{14}. (ز)٧٨٨٠٣- عن منصور بن زاذان، عن الحسن [البصري]، في قوله: ﴿إن الإنسان خلق هلوعا﴾، قال: بخيلًا بالخير{15}. (ز)٧٨٨٠٤- قال عطاء: ﴿منوعا﴾ عَجُولًا{6}. (ز)٧٨٨٠٥- عن قتادة بن دعامة -من طريق معمر- ﴿هَلُوعًا﴾، قال: جَزُوعًا{17}. (١٤/٦٩٦)٧٨٨٠٦- عن حُصَيْن بن عبد الرحمن -من طريق شعبة- ﴿هَلُوعًا﴾، قال: الحريص{18}. (١٤/٦٩٦)٧٨٨٠٧- قال مقاتل بن سليمان: ﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾ يعني: ضَجِرًا، فهو أُمَيّة بن خلف الجُمحي، ثم نَعتَه، فقال: ﴿إذا مَسَّهُ الشَّرُّ﴾ يقول: إذا أصابه ﴿جَزُوعًا﴾، ﴿وإذا مَسَّهُ الخَيْر﴾ يعني: المال ﴿مَنُوعًا﴾ فمَنع وبَخِل بحقّ الله تعالى{2}. (ز)٧٨٨٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾، قال: الهَلُوع: الجَزُوع{20}٦٨٠٠. (ز)٦٨٠٠ نَقل ابنُ تيمية (٦/٣٩٤) عن الجوهري القول بأنّ الهَلَع: أفحَش الجَزع. وعن غيره أنه في اللغة: أشدّ الحِرص وأسوأ الجَزع. وساق قول النبي ﷺ: «شرُّ ما في المرء شُحٌّ هالِع، وجُبْنٌ خالع». ثم علَّق بقوله: «ولهذا كان كلام السلف في تفسيره يتضمن هذه المعاني». وساق الآثار.﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾ - آثار متعلقة بالآية٧٨٨٠٩- عن عليٍّ مرفوعًا: «يُكتب أنين المريض؛ فإن كان صابرًا كان أنينه حسنات، وإن كان جَزوعًا كُتب هَلُوعًا لا أجْر له»{21}. (١٤/٦٩٧)"
  70,20,"70:19"
  70,21,"70:19"
  70,22,"﴿إِلَّا ٱلۡمُصَلِّینَ ۝٢٢ ٱلَّذِینَ هُمۡ عَلَىٰ صَلَاتِهِمۡ دَاۤىِٕمُونَ ۝٢٣﴾ - تفسير٧٨٨١٠- عن عبد الله بن مسعود -من طريق عبد الرحمن- ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: على مواقيتها{1}. (١٤/٦٩٧)٧٨٨١١- عن مَسروق بن الأَجْدع الهَمداني، مثله{2}. (١٤/٦٩٧)٧٨٨١٢- عن عِمران بن حُصَيْن -من طريق أبي الأسود- ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: الذي لا يَلتفتُ في صلاته{3}. (١٤/٦٩٧)٧٨٨١٣- عن عُقبة بن عامر -من طريق أبي الخير- في قوله: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: هم الذين إذا صَلَّوْا لم يَلتفِتوا{4}. (١٤/٦٩٨)٧٨٨١٤- عن أبي الخير، أنّ عُقبة بن عامر قال لهم: مَن ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾؟ قلنا: الذين لا يَزالون يُصلُّون. فقال: لا، ولكن الذين إذا صَلَّوا لم يَلتفِتوا عن يمين وشمال{5}٦٨٠١. (١٤/٦٩٨)٦٨٠١ علَّق ابنُ كثير (١٤/١٣٣ بتصرف) على هذا القول بقوله: «كقوله: ﴿قد أفلح المؤمنون الذين هم في صلاتهم خاشعون﴾ [المؤمنون:١-٢]، ومنه: الماء الدائم، أي: الساكن الراكد».وبنحوه قال ابنُ عطية (٨/٤٠٧).وساق ابنُ القيم (٣/١٩٧) قول عُقبة، ثم علَّق بقوله: «قلتُ: هما أمران: الدوام عليها، والمداومة عليها، فهذا الدوام والمداومة في قوله تعالى: ﴿والذين هم على صلاتهم يحافظون﴾». ثم قال: «وفُسِّر الدوام: بسكون الأطراف والطمأنينة».٧٨٨١٥- عن سعيد بن المسيّب، سُئل عن قول الله: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾. قال: يُداوم عليها، ولا يَدَعها، ويُداوم على مواقيتها وحدودها{6}. (ز)٧٨٨١٦- عن أبي سَلمة بن عبد الرحمن، عن عائشة، قالت: قال رسول الله ﷺ: «خذوا من العمل ما تُطيقون؛ فإنّ الله لا يَملّ حتى تَملّوا». قالت: وكان أحب الأعمال إلى رسول الله ﷺ ما دام عليه وإن قلّ، وكان إذا صلّى صلاة دام عليها. قال أبو سَلمة: قال الله: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾{7}. (١٤/٦٩٨)٧٨٨١٧- عن إبراهيم التيميّ، في قوله: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: المكتوبة{2}. (١٤/٦٩٧)٧٨٨١٨- عن إبراهيم [النخعي] -من طريق منصور- في قوله: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: الصلوات الخمس{9}. (ز)٧٨٨١٩- عن عكرمة مولى ابن عباس -من طريق يزيد بن عبد الرحمن بن جَسّاسٍ- ﴿على صلاتهم دائمون﴾، قال: على مواقيتها{10}. (ز)٧٨٨٢٠- قال الحسن البصري: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾ يَدُومون عليها{11}. (ز)٧٨٨٢١- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿إلّا المُصَلِّينَ الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: ذُكر لنا: أنّ دانيال نَعتَ أُمّة محمد ﷺ، فقال: يُصَلُّون صلاة لو صَلّاها قوم نوح ما أُغرقوا، أو عاد ما أُرسلتْ عليهم الريح العقيم، أو ثمود ما أخذتْهم الصّيحة. قال قتادة: فعليكم بالصلاة؛ فإنها خُلُقٌ من أخلاق المؤمنين حسن{12}. (١٤/٦٩٧)٧٨٨٢٢- قال مقاتل بن سليمان: ثم استأنف فقال: ﴿إلّا المُصَلِّينَ﴾ فليسوا كذلك، ثم نَعتَهم الله تعالى فقال: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ﴾ يعني: الصلوات الخمس ﴿دائِمُونَ﴾ بالليل والنهار، لا يَدَعونها{13}. (ز)٧٨٨٢٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾، قال: هؤلاء المؤمنون الذين مع النبي ﷺ على صلاتهم دائمون{14}٦٨٠٢. (ز)٦٨٠٢ ذكر ابنُ عطية (٨/٤٠٧) أنّ الجمهور على أنّ المعنى: مواظبون قائمون لا يَملُّون في وقت من الأوقات فيتركونها. ثم علَّق بقوله: «وهذا في المكتوب، وأما النافلة فالدوام عليها الإكثار منها بحسب الطاقة، وقد قال ﷺ: «أحبّ العمل إلى الله ما داوم عليه صاحبه»».وذكر ابنُ تيمية (٦/٣٩٥) أنّ السلف فسَّروا الدائم على الصلاة بالمُحافِظ على أوقاتها، وبالدائم على أفعالها بالإقبال عليها. ثم علَّق بقوله: «والآية تعمّ هذا وهذا، فإنه قال: ﴿على صلاتهم دائمون﴾، والدائم على الفعل هو المُديم له الذي يفعله دائمًا، فإذا كان هذا فيما يفعل في الأوقات المتفرقة، هو أن يَفعله كلّ يوم بحيث لا يَفعله تارة ويتركه أخرى، وسُمّي ذلك دوامًا عليه، فالدوام على الفعل الواحد المتصل أولى أن يكون دوامًا وأن تتناول الآية ذلك، وذلك يدل على وجوب إدامة أفعالها؛ لأن الله ﷿ ذمّ عموم الإنسان، واستثنى المُداوِم على هذه الصفة، فتاركُ إدامة أفعالها يكون مذمومًا من الشارع، والشارع لا يذمّ إلا على ترْك واجب أو فِعْل محرم»."
  70,23,"70:22"
  70,24,"﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤ لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝٢٥﴾ - نزول الآية٧٨٨٢٤- عن الحسن بن محمد: أنّ النبي ﷺ بَعثَ سَرِيّة، فغنموا، وفُتح عليهم، فجاء قوم لم يشهدوا، فنَزلت: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾{1}. (ز)﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾ - تفسير٧٨٨٢٥- عن أنس بن مالك، قال: قال رسول الله ﷺ: «يا أنس، ويل للأغنياء مِن الفقراء يوم القيامة، يقولون: ربّنا، ظلمونا حقوقنا التي فَرضتَ لنا عليهم. فيقول: وعزّتي وجلالي، لأقرِّبنكم ولأُبعّدنهم». قال: وتلا رسول الله ﷺ: ﴿والذين فِي أمْوالِهِمْ حَقٌّ معلوم لِلسّائِلِ والمَحْرُومِ﴾{2}. (١٣/٦٧٧)٧٨٨٢٦- عن عبد الله بن عباس -من طريق عليّ- في قوله: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾، يقول: هو سوى الصّدقة يَصل بها رَحِمه، أو يَقري بها ضيفًا، أو يَحمل بها كَلًّا، أو يُعين بها محرومًا{3}. (ز)٧٨٨٢٧- عن قزعة: أن ابن عمر سُئِل عن قوله: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾ أهي الزَّكاة؟ فقال: إنّ عليك حقوقًا سوى ذلك{3}. (ز)٧٨٨٢٨- عن إبراهيم النَّخَعي، في قوله: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾، قال: كانوا إذا خَرجَت الأُعطية أُعطوا منها{5}. (١٤/٦٩٨)٧٨٨٢٩- عن مجاهد بن جبر -من طريق سفيان- في قوله: ﴿فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾، قال: سوى الزَّكاة{6}. (ز)٧٨٨٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾، قال: الزَّكاة المفروضة{3}. (ز)٧٨٨٣١- عن زياد بن أبي مريم -من طريق خُصَيف- في قوله: ﴿حق معلوم﴾، قال: الزَّكاة{8}٦٨٠٣. (ز)٦٨٠٣ اختُلف في المراد بالحق المعلوم على قولين: الأول: أنه الزَّكاة المفروضة. الثاني: أنه حقٌّ سوى الزَّكاة.ورجَّح ابنُ عطية (٨/٤٠٨) -مستندًا إلى أحوال النزول- القول الثاني الذي قاله ابن عمر، ومجاهد، والنَّخَعي، فقال: «هو الأصحُّ في هذه الآية؛ لأنّ السورة مكّيّة، وفرْض الزَّكاة وبيانها إنما كان بالمدينة».﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾ - النسخ في الآية٧٨٨٣٢- عن خالد بن أبي عمران، قال: سألتُ القاسم [بن محمد]= (ز)٧٨٨٣٣- وسالم [بن عبد الله بن عمر] عن قول الله: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾. فقالا: المعلوم منسوخة، وكلّ صَدقة في القرآن منسوخة، نَسَخَتْها هذه الآية: ﴿إنَّما الصَّدَقاُت لِلْفُقَراءِ والـمَساكِينِ﴾ إلى آخر الآية [التوبة:٦٠]. قالا: والمحروم مُحارَف في الرزق والتجارة{9}. (ز)﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾ - آثار متعلقة بالآية٧٨٨٣٤- عن إبراهيم النَّخَعي -من طريق الأعمش- قال: في المال حقٌّ سوى الزَّكاة{3}. (ز)٧٨٨٣٥- عن عامر الشعبي -من طريق بيان- قال: إنّ في المال حقًّا سوى الزَّكاة{3}. (ز)﴿لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ﴾{12} - تفسير٧٨٨٣٦- عن إبراهيم النَّخَعي: أنّ ناسًا قدموا على علي [بن أبي طالب] ﵁ الكوفة بعد وقْعة الجمل، فقال: اقسِموا لهم. وقال: هذا المحروم{13}. (ز)٧٨٨٣٧- عن أبي قِلابة عبد الله بن زيد الجرمي، قال: جاء سَيلٌ باليمامة، فذَهب بمال رجل، فقال رجل من أصحاب النبي ﷺ: هذا المحروم{14}. (ز)٧٨٨٣٨- عن عبد الله بن عباس -من طريق قيس بن كُركُم- في قوله: ﴿لِلسّائِلِ والمَحْرُومِ﴾، قال: السائل: الذي يسأل. والمحروم: المُحارَف الذي ليس له في الإسلام سهم{15}. (ز)٧٨٨٣٩- عن أبي بشر، قال: سألتُ سعيد بن جُبَير عن المحروم، فلم يَقُلْ فيه شيئًا. قال: وقال عطاء: هو المحدود{16} المُحارَف{17}. (١٣/٦٧٧)٧٨٨٤٠- عن إبراهيم النَّخَعي -من طريق منصور- قال: المحروم: الذي لا فَيء له في الإسلام، وهو مُحارَف في الناس{13}. (ز)٧٨٨٤١- عن سعيد بن المسيّب -من طريق قتادة بن دعامة-: المحروم: المُحارَف{17}. (ز)٧٨٨٤٢- عن الحسن بن محمد: أنّ النبي ﷺ بَعثَ سَرِيّة، فغنموا، وفُتح عليهم، فجاء قومٌ لم يشهدوا، فنَزلت: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾ يعني: هؤلاء{1}. (ز)٧٨٨٤٣- عن مجاهد بن جبر -من طريق ابن أبى نجيح- قال: المحروم: الذي لا يُهدى له شيء، وهو مُحارَف{17}. (ز)٧٨٨٤٤- عن عكرمة مولى ابن عباس -من طريق حُصَيْن- قال: قال: السائل: الذي يسألك. والمَحْرُوم: الذي لا يَنمِي له مال{1}. (ز)٧٨٨٤٥- عن عكرمة مولى ابن عباس -من طريق حُسين بن قيس- قال: المحروم: الرجل كانت له مَعيشة، فأُصيب بها{23}. (ز)٧٨٨٤٦- عن عامر الشعبي -من طريق ابن عَوْن- قال: أعياني أنْ أعلم ما المحروم{14}٦٨٠٤. (ز)٦٨٠٤ علَّق ابنُ عطية (٨/٤٠٨) على قول الشعبي بقوله: «يرحم الله الشعبي فإنه في هذه المسألة محروم، ولو أخذه اسم جنس فيمن عسُرت مطالبه بان له، وإنما كان يطلبه نوعًا مخصوصًا كالسائل».٧٨٨٤٧- عن خالد بن أبي عمران، عن القاسم [بن محمد]= (ز)٧٨٨٤٨- وسالم [بن عبد الله بن عمر] في قول الله: قالا: المحروم مُحارَف في الرزق والتجارة{25}. (ز)٧٨٨٤٩- قال الحسن البصري: ﴿لِلسّائِلِ والمَحْرُومِ﴾، السائل: المسكين الذي يسأل عند الحاجة. والمَحْرُوم: الفقير الذي لا يَسأل على حال، فحُرم أن يُعطى عن المسألة كما يُعطى السائل، وإنْ أُعطي شيئًا قَبل{26}. (ز)٧٨٨٥٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿لِلسّائِلِ والمَحْرُومِ﴾، قال: السائل: الذي يسأل بكَفّه. والمَحْرُوم: المُتعفِّف، ولكليهما عليك حقٌّ، يا ابن آدم{14}. (ز)٧٨٨٥١- عن نافع -من طريق أيوب- قال: المحروم: هو المُحارَف{13}. (ز)٧٨٨٥٢- عن زياد بن أبي مريم -من طريق خُصَيف- في قوله: ﴿والمحروم﴾: الذي لم يُبسَط له في المَعيشة، ولم يُعط باب المسألة{8}. (ز)٧٨٨٥٣- قال مقاتل بن سليمان: ﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾ يعني: مفروض ﴿لِلسّائِلِ﴾ يعني: المسكين ﴿والمَحْرُومِ﴾ يعني: الفقير الذي لا سهم له في الخُمس ولا الفَيء{30}. (ز)٧٨٨٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿والمَحْرُومِ﴾، قال: المحروم: المُصاب ثمره وزَرْعه. وقرأ: ﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ﴾ حتى بَلغ: ﴿مَحْرُومُونَ﴾ [الواقعة:٦٣-٦٧]. وقال أصحاب الجنة: ﴿إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾ [القلم:٢٦-٢٧]{14}٦٨٠٥. (ز)٦٨٠٥ ذكر ابنُ عطية (٨/٤٠٨) في المحروم أقوالًا: الأول: مَن احترق زَرْعه. الثاني: مَن ماتتْ ماشيته. وعلَّق عليهما بقوله: «وهذه أنواع الحرمان، لا أنّ الاسم يلزم هذا خاصّة». الثالث: أنه الكلب. ونسبه لعمر بن عبد العزيز. ووجّهه بقوله: «أراد -والله أعلم- أن يُعطي مثالًا من الحيوان ذي الكبد الرّطبة لما فيه من الأجر حسب الحديث المأثور»."
  70,25,"70:24"
  70,26,"﴿وَٱلَّذِینَ یُصَدِّقُونَ بِیَوۡمِ ٱلدِّینِ ۝٢٦ وَٱلَّذِینَ هُم مِّنۡ عَذَابِ رَبِّهِم مُّشۡفِقُونَ ۝٢٧ إِنَّ عَذَابَ رَبِّهِمۡ غَیۡرُ مَأۡمُونࣲ ۝٢٨﴾ - تفسير٧٨٨٥٥- قال مقاتل بن سليمان: ﴿والَّذِينَ يُصَدِّقُونَ بِيَوْمِ الدِّينِ﴾ يعني به: الحساب؛ بأنه كائن، ﴿والَّذِينَ هُمْ مِن عَذابِ رَبِّهِمْ مُشْفِقُونَ﴾ يعني: وجِلين أن يُصيبهم، ﴿إنَّ عَذابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ﴾ يقول: لا يأمنون العذاب من الشَّفقة والخوف{1}. (ز)"
  70,27,"70:26"
  70,28,"70:26"
  70,29,"﴿وَٱلَّذِینَ هُمۡ لِفُرُوجِهِمۡ حَـٰفِظُونَ ۝٢٩ إِلَّا عَلَىٰۤ أَزۡوَ ٰ⁠جِهِمۡ أَوۡ مَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ فَإِنَّهُمۡ غَیۡرُ مَلُومِینَ ۝٣٠ فَمَنِ ٱبۡتَغَىٰ وَرَاۤءَ ذَ ٰ⁠لِكَ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡعَادُونَ ۝٣١﴾ - تفسير٧٨٨٥٦- قال مقاتل بن سليمان: ﴿والَّذِينَ هُمْ لِفُرُوجِهِمْ حافِظُونَ﴾ عن الفواحش، ثم استثنى فقال: ﴿إلّا عَلى أزْواجِهِمْ أوْ ما مَلَكَتْ أيْمانُهُمْ﴾ يعني به: الولائد ﴿فإنهم غير ملومين﴾ يعني: لا يُلامون على الحلال، ﴿فَمَنِ ابْتَغى وراءَ ذَلِكَ﴾ بعد أزواجه وولائده ما لا يَحلّ له وهو الزنا، ﴿فَأُولَئِكَ هُمُ العادُونَ﴾ يعني: المُعتدين في دينهم{1}٦٨٠٦. (ز)٦٨٠٦ ذكر ابنُ عطية (٨/٤٠٩) أن «الفروج» في هذه الآية: هي الفروج المعروفة، والمعنى: يحفظونها مِن الزنا. ثم نقل عن الحسن بن أبي الحسن القول بأنه أراد فروج الثياب، وعلَّق عليه بقوله: «وإلى معنى الوطء يعود»."
  70,30,"70:29"
  70,31,"70:29"
  70,32,"﴿وَٱلَّذِینَ هُمۡ لِأَمَـٰنَـٰتِهِمۡ وَعَهۡدِهِمۡ رَ ٰ⁠عُونَ ۝٣٢ وَٱلَّذِینَ هُم بِشَهَـٰدَ ٰ⁠تِهِمۡ قَاۤىِٕمُونَ ۝٣٣﴾ - تفسير٧٨٨٥٧- قال مقاتل بن سليمان: ﴿والَّذِينَ هُمْ لِأَماناتِهِمْ وعَهْدِهِمْ راعُونَ﴾ يعني: يؤدون الأمانة، ويوفون بالعهد، ثم قال: ﴿راعُونَ﴾ يرعونه ويتعاهدونه كما يرعى الراعي الشفيق غنمه عن مواقع الهلكة، ﴿والَّذِينَ هُمْ بِشَهاداتِهِمْ قائِمُونَ﴾ يعني: يقومون بها بالحق، لا يمنعونها ولا يكتمونها إذا دعوا إليها{1}٦٨٠٧. (ز)٦٨٠٧ ذكر ابنُ عطية (٨/٤١٠-٤١١) أنّ قوله: ﴿والذين هم بشهاداتهم قائمون﴾ له معنيان: الأول: أنهم يَحفظون ما يَشهدون فيه، ويَتيقّنونه ويَقومون بمعانيه حتى لا يكون لهم فيه تقصير. وعلَّق عليه بقوله: «وهذا هو وصف من تمثيل قول النبي ﷺ: «على مثل الشمس فاشهد»». الثاني: أنّ المعنى: الذين إذا كانت عندهم شهادة ورأوا حقًّا يدرَس أو حُرمة لله تُنتهك قاموا بشهادتهم. ونَقل عن ابن عباس القول بأنّ شهادتهم في هذه الآية: لا إله إلا الله وحده لا شريك له. وساق حديث النبي ﷺ: «خير الشهداء الذي يأتي بشهادته قبل أن يُسألها». ثم قال: «واختلف الناس في معنى هذا الحديث بحسب المَعْنَيَيْن اللذَيْن ذكرنا في الآية، إحداهما: أنْ يكون يحفظها مُتقنة فيأتي بها ولا يَحتاج أن يُسْتَفْهَم عن شيء منها ولا أن يُعارَض. والثاني: إذا رأى حقًّا يعمل بخلافه وعنده في إحياء الحق شهادة». ثم ساق حديث النبي ﷺ: «سيأتي قوم يخونون ولا يُؤتمنون، ويشهدون ولا يُستشهدون، ويظهر فيهم السّمَن». وبيّن أنه اختُلف في معنى هذا الحديث على قولين: الأول: أنهم قوم مُؤمنون يَتعرّضون ويحرصون على وضْع أسمائهم في وثائق الناس، وينصبون لذلك الحبائل من زي وهيئة وهم غير عُدول في أنفسهم فيغرّون بذلك ويَضرّون. وعلَّق عليه بقوله: «فهذا في ابتداء الشهادة لا في أدائها، ويجيء قوله ﷺ: «ولا يُستشهدون»، أي: وهم غير أهل لذلك». الثاني: أنهم هم شهود الزُّور، يؤدونها، والمشهود عليهم لم يشهدهم، ولا الآخر""."
  70,33,"70:32"
  70,34,"﴿وَٱلَّذِینَ هُمۡ عَلَىٰ صَلَاتِهِمۡ یُحَافِظُونَ ۝٣٤ أُو۟لَـٰۤىِٕكَ فِی جَنَّـٰتࣲ مُّكۡرَمُونَ ۝٣٥﴾ - تفسير٧٨٨٥٨- عن الحسن البصري -من طريق خُليد- ﴿والذين هم على صلاتهم يحافظون﴾، قال: على المواقيت{1}. (ز)٧٨٨٥٩- قال مقاتل بن سليمان: ﴿والَّذِينَ هُمْ عَلى صَلاتِهِمْ﴾ الخمس ﴿يُحافِظُونَ﴾ عليها في مواقيتها، ﴿أُولَئِكَ﴾ الذين هذه أعمالهم ﴿فِي جَنّاتٍ مُكْرَمُونَ﴾ يعني: يُكرمون فيها{2}٦٨٠٨. (ز)٦٨٠٨ ذكر ابنُ تيمية (٦/٣٩٦) أنّ ابن جُرَيْج قال في قوله: ﴿والذين هم على صلواتهم يحافظون﴾ المكتوبة، والتي في سأل سائل: التطوع. وانتقده بقوله: «وهذا قول ضعيف»."
  70,35,"70:34"
  70,36,"﴿فَمَالِ ٱلَّذِینَ كَفَرُوا۟ قِبَلَكَ مُهۡطِعِینَ ۝٣٦﴾ - نزول الآية٧٨٨٦٠- قال مقاتل بن سليمان: ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾ نزلت هذه الآيةُ في المُستهزئين من قريش، والمُطعمين في غزوة بدر{1}. (ز)﴿فَمَالِ ٱلَّذِینَ كَفَرُوا۟ قِبَلَكَ مُهۡطِعِینَ ۝٣٦﴾ - تفسير الآية٧٨٨٦١- عن عبد الله بن عباس -من طريق عطية- في قوله: ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾، قال: يَنظرون{2}. (١٤/٦٩٨)٧٨٨٦٢- عن الحسن البصري -من طريق قُرّة- ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾، قال: مُنطَلِقين{3}. (١٤/٦٩٩)٧٨٨٦٣- عن قتادة بن دعامة -من طريق سعيد- ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾، قال: عامِدين{3}. (١٤/٦٩٩)٧٨٨٦٤- قال مقاتل بن سليمان: ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾ يعني: مُقْبِلين، نزلت هذه الآيةُ في المُستهزئين من قريش، والمُطعمين في غزوة بدر، مُقْبِلين يَنظرون عن يمين النبي ﷺ{1}. (ز)٧٨٨٦٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾، قال: المُهطِع: الذي لا يَطرِف{6}. (ز)"
  70,37,"﴿عَنِ ٱلۡیَمِینِ وَعَنِ ٱلشِّمَالِ عِزِینَ ۝٣٧﴾ - تفسير٧٨٨٦٦- عن عبد الله بن عباس -من طريق عطية- في قوله: ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾، قال: العُصَبُ{1} من الناس عن يمين وشمال، مُعرضين يستهزئون به{2}. (١٤/٦٩٨)٧٨٨٦٧- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾. قال: الحِلَق الرّقاق. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ عَبِيد بن الأَبْرص وهو يقول:فجاؤا يُهرعون إليه حتى يكونوا حول مِنبره عِزينا؟{3}. (١٤/٦٩٩)٧٨٨٦٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ﴾ قال: عن يمين النبيِّ ﷺ وعن شماله ﴿عِزِينَ﴾ قال: مجالس مُحتَبين، نَفرٌ قليل قليل{4}. (١٤/٦٩٩)٧٨٨٦٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿عِزِينَ﴾، قال: حِلَقًا، ورفقاء{5}. (ز)٧٨٨٧٠- عن الحسن البصري -من طريق قُرّة- ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾، قال: مُتَفرِّقين، يأخذون يمينًا وشمالًا، يقولون: ما يقول هذا الرجل؟!{6}. (١٤/٦٩٩)٧٨٨٧١- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿عِزِينَ﴾، قال: الحِلَق، المجالس{7}. (١٤/٧٠٠)٧٨٨٧٢- عن قتادة بن دعامة -من طريق سعيد- ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾، قال: فِرقًا حول نبي الله، لا يَرغبون في كتاب الله ولا ذِكره{8}. (١٤/٦٩٩)٧٨٨٧٣- قال مقاتل بن سليمان: ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾ يعني: حِلقًا حِلقًا جُلوسًا، لا يَدنون من النبي ﷺ فيَنتفعون بمجلسه{9}. (ز)٧٨٨٧٤- عن ابن لَهِيعة -من طريق ابن وهب- في قول الله: ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾، قال: يقال: العِزين: المُتَفَرِّقين، وقال الشاعر:بمعزاة أضحت صداها ترى ركبانها عُصبًا عزينا{10}. (ز)٧٨٨٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في في قوله: ﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾، قال: العِزين: المجلس الذي فيه الثلاثة والأربعة، والمجالس الثلاثة والأربعة أولئك العُزون{5}. (ز)﴿عَنِ ٱلۡیَمِینِ وَعَنِ ٱلشِّمَالِ عِزِینَ ۝٣٧﴾ - آثار متعلقة بالآية٧٨٨٧٦- عن أبي هريرة، قال: خرج رسول الله ﷺ وأصحابه جلوس حِلقٌ حِلقٌ، فقال: «مالي أراكم عِزين؟»{12}. (١٤/٧٠٠)٧٨٨٧٧- عن جابر بن سَمُرَة، قال: دخل علينا رسول الله ﷺ المسجد ونحن حِلقٌ مُتَفَرِّقون، فقال: «مالي أراكم عِزين؟»{13}. (١٤/٧٠٠)٧٨٨٧٨- عن عُبادة بن نُسَيٍّ، قال: دخل رسول الله ﷺ المسجد، فقال: «مالي أراكم عِزين، حِلقًا حِلَق الجاهلية؟». قعد الرجل خلف أخيه{14}. (١٤/٧٠٠)"
  70,38,"﴿أَیَطۡمَعُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُدۡخَلَ جَنَّةَ نَعِیمࣲ ۝٣٨ كَلَّاۤۖ﴾ - قراءات٧٨٨٧٩- عن عاصم أنه قرأ: ﴿أن يُدْخَلَ﴾ برفع الياء{1}. (١٤/٧٠١)٧٨٨٨٠- عن أبي معمر أنه قرأ: (أن يَدْخُلَ) بنصب الياء ورفع الخاء{2}٦٨٠٩. (١٤/٧٠١)٦٨٠٩ اختُلف في قراءة قوله: ﴿أن يدخل﴾؛ فقرأ قوم بضم الياء على وجه ما لم يُسمّ فاعله. وقرأ آخرون بفتحها على بناء الفعل للفاعل.ورجَّح ابنُ جرير (٢٣/٢٨٢) قراءة الضم مستندًا إلى إجماع القراء، فقال: «والصواب من القراءة في ذلك ما عليه قراء الأمصار، وهي ضم الياء؛ لإجماع الحُجّة من القُراء عليه».﴿أَیَطۡمَعُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُدۡخَلَ جَنَّةَ نَعِیمࣲ ۝٣٨ كَلَّاۤۖ﴾ - تفسير الآية٧٨٨٨١- قال عبد الله بن عباس: ﴿أيَطْمَعُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُدْخَلَ جَنَّةَ نَعِيمٍ﴾ معناه: أيطمع كلّ رجل منهم أن يَدخل جنتي كما يَدخلها المسلمون ويَتنعّم فيها وقد كذّب نبِيِّي؟ ﴿كَلا﴾ لا يَدخلونها{3}. (ز)٧٨٨٨٢- عن الضَّحّاك بن مُزاحِم، في قوله: ﴿أيَطْمَعُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُدْخَلَ جَنَّةَ نَعِيمٍ كلا﴾ قال: كلا لستُ فاعلًا. ثم ذكر خَلْقهم، فقال: ﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾{4}. (١٤/٧٠١)٧٨٨٨٣- قال مقاتل بن سليمان: ﴿أيَطْمَعُ كُلُّ امْرِئٍ مِنهُمْ﴾ يعني: قريشًا ﴿أنْ يُدْخَلَ جَنَّةَ نَعِيمٍ﴾ كلّ واحد منهم يقول: إنّ لي في الجنة حقًّا. يقول ذلك استهزاء، يقول: أُعطى منها ما يُعطى المؤمنون. يقول الله تعالى: ﴿كَلا﴾ لا يَدخلها{5}. (ز)﴿كَلَّاۤۖ إِنَّا خَلَقۡنَـٰهُم مِّمَّا یَعۡلَمُونَ ۝٣٩﴾ - تفسير٧٨٨٨٤- عن بُسْر بن جِحاش، قال: قرأ رسول الله ﷺ هذه الآية: ﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾ إلى قوله: ﴿كَلّا إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾، ثم بَزَق رسول الله ﷺ على كَفّه، ووضع عليها إصبعه، وقال: «يقول الله: ابن آدم، أنّى تُعجِزُني وقد خَلَقتُك مِن مثل هذه، حتى إذا سوّيتُك وعدَّلتُك مَشيْتَ بين بُرْدَيْن وللأرض منك وئيد{6}، فجَمَعْتَ ومَنَعْتَ، حتى إذا بلَغت التَّراقيَ قلتُ: أتصدّق. وأنّى أوان الصدقة؟!»{7}. (١٤/٧٠١)٧٨٨٨٥- عن الضَّحّاك بن مُزاحِم، في قوله: ﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾، يعني: النُّطفة التي خُلق منها البشر{4}. (١٤/٧٠١)٧٨٨٨٦- عن قتادة بن دعامة -من طريق سعيد- ﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾، قال: إنما خُلِقْتَ مِن قَذرٍ، يا ابن آدم، فاتّق الله{9}. (١٤/٧٠١)٧٨٨٨٧- قال مقاتل بن سليمان: يقول الله تعالى: ﴿كَلا﴾ لا يَدخلها، ثم استأنف فقال لما كذّبوا بالغيب: ﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾ خُلقوا من نُطفة، ثم من عَلقة، ثم من مُضغة{5}. (ز)﴿كَلَّاۤۖ إِنَّا خَلَقۡنَـٰهُم مِّمَّا یَعۡلَمُونَ ۝٣٩﴾ - آثار متعلقة بالآية٧٨٨٨٨- عن أنس بن مالك، قال: كان أبو بكر الصِّدِّيق إذا خَطبنا ذَكر مَناتِن ابنِ آدم، فذَكر بدء خَلْقه أنه يَخرج مِن مَخرج البول مرتين، ثم يقع في الرَّحِم نُطفة، ثم عَلقة، ثم مُضغة، ثم يَخرج مِن بطن أُمّه فيَتلوّث في بوله وخَراه؛ حتى يَقذر أحدُنا نفسَه{11}. (ز)"
  70,39,"70:38"
  70,40,"﴿فَلَاۤ أُقۡسِمُ بِرَبِّ ٱلۡمَشَـٰرِقِ وَٱلۡمَغَـٰرِبِ إِنَّا لَقَـٰدِرُونَ ۝٤٠ عَلَىٰۤ أَن نُّبَدِّلَ خَیۡرࣰا مِّنۡهُمۡ وَمَا نَحۡنُ بِمَسۡبُوقِینَ ۝٤١﴾ - تفسير٧٨٨٨٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: ﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾، قال: للشمس كلّ يوم مَطلِع تَطلع فيه، ومَغرِب تغرب فيه، غير مَطلِعها بالأمس، وغير مَغرِبها بالأمس{1}. (١٤/٧٠٢)٧٨٨٩٠- عن عبد الله بن عباس -من طريق عكرمة- قال: ﴿بِرَبِّ المَشارِقِ والمَغارِبِ﴾ إنّ الشمس تَطلع كلّ سنة في ثلاثمائة وستين كَوّة، تَطلع كلّ يوم في كَوّة؛ لا تَرجع إلى تلك الكَوّة إلى ذلك اليوم من العام المُقبل، ولا تَطلع إلا وهي كارهة، تقول: ربّ، لا تُطلعني على عبادك؛ فإني أراهم يَعصُونك، يَعملون بمعاصيك أراهم. قال: أولم تَسمعوا إلى قول أُميّة بن أبي الصّلت:حتى تُجرّ وتُجلَد؟قلت: يا مولاه، وتُجلد الشمس؟ فقال: عضِضتَ بِهَنِ أبيك، إنما اضطره الرَّوِيُّ إلى الجَلْد{2}. (ز)٧٨٨٩١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾، قال: هو مَطلِع الشمس ومَغرِبها، ومَطلِع القمر ومَغرِبه{3}. (ز)٧٨٨٩٢- عن عكرمة مولى ابن عباس، في قوله: ﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾، قال: المنازل التي تجري فيها الشمس والقمر{4}. (١٤/٧٠٢)٧٨٨٩٣- قال قتادة بن دعامة: ﴿فَلا أُقْسِمُ بِرَبِّ المَشارِقِ والمَغارِبِ﴾ للشمس ثلاثمائة وستون مَشرقًا، وثلاثمائة وستون مغربًا{5}. (ز)٧٨٨٩٤- قال مقاتل بن سليمان: ﴿فَلا أُقْسِمُ﴾ يقول: أُقسم ﴿بِرَبِّ المَشارِقِ والمَغارِبِ﴾ وهو مائة وثمانون مَشرقًا، ومائة وثمانون مَغربًا، في كلّ منزلة تَطلع يومين في السنة، تَطلع فيها الشمس وتَغرب فيها، فأَقسم الله تعالى بالمشارق والمغارب، فقال: ﴿إنّا لَقادِرُونَ عَلى أنْ نُبَدِّلَ خَيْرًا مِنهُمْ﴾ يعني: على أن نأتي بخلْقٍ أمثل منهم، وأطوع لله منهم، وأرضى منهم، ﴿وما نَحْنُ بِمَسْبُوقِينَ﴾ يعني: وما نحن بُمعجزين إنْ أردنا ذلك{6}٦٨١٠. (ز)٦٨١٠ ذكر ابنُ كثير (١٤/١٣٧) أنّ معنى قوله: ﴿أن نبدل خيرا منهم﴾: أن نعيدهم بأبدان خير من هذه، فإنّ قدرته تعالى صالحة لذلك. ثم ساق هذا المعنى بأنه الإتيان بخلق أمثل وأطوع.ورجَّح -مستندًا إلى السياق- المعنى الأول، فقال: «والمعنى الأول أظهر؛ لدلالة الآيات الأُخَر عليه»."
  70,41,"70:40"
  70,42,"﴿فَذَرۡهُمۡ یَخُوضُوا۟ وَیَلۡعَبُوا۟ حَتَّىٰ یُلَـٰقُوا۟ یَوۡمَهُمُ ٱلَّذِی یُوعَدُونَ ۝٤٢﴾ - تفسير٧٨٨٩٥- قال مقاتل بن سليمان: فقال الله ﷿: ﴿فَذَرْهُم﴾ خَلِّ عنهم يا محمد ﴿يَخُوضُوا﴾ في الباطل ﴿ويَلْعَبُوا﴾ يعني: ويلهوا في دنياهم؛ ﴿حَتّى يُلاقُوا يَوْمَهُمُ﴾ في الآخرة ﴿الَّذِي يُوعَدُونَ﴾ العذاب{1}. (ز)"
  70,43,"﴿یَوۡمَ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ سِرَاعࣰا كَأَنَّهُمۡ إِلَىٰ نُصُبࣲ یُوفِضُونَ ۝٤٣﴾ - قراءات٧٨٨٩٦- عن أبي العالية الرِّياحيّ أنه قرأ: ‹إلى نَصْبٍ يُوفِضُونَ› بنصب النون، على معنى الواحد{1}. (١٤/٧٠٣)٧٨٨٩٧- عن عاصم أنه قرأ: ‹إلى نَصْبٍ يُوفِضُونَ› خفيفة، منصوبة النون، على معنى الوحدة{2}٦٨١١. (١٤/٧٠٣)٦٨١١ اختُلف في قراءة قوله: ﴿نصب﴾؛ فقرأ قوم: ‹نَصْبٍ› بفتح النون. وقرأ آخرون: ﴿نُصُب﴾ بضمّها مع الصاد.وذكر ابنُ جرير (٢٣/٢٨٥) «أنه أجمعت قُراء الأمصار على فتح النون، وأنّ مَن قرأ بالفتح يوجّه النصب إلى أنه مصدر من قول القائل: نَصَبْت الشيء أنصبه نصبًا». وكأن تأويله عندهم: «كأنهم إلى صنم منصوب يُسرعون سعيًا». وأنّ مَن قرأ بالضم فإنه يوجّهه إلى أنه واحد الأنصاب، وهي آلهتهم التي كانوا يعبدونها.وبنحوه قال ابنُ كثير (١٤/١٣٧).﴿یَوۡمَ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ سِرَاعࣰا كَأَنَّهُمۡ إِلَىٰ نُصُبࣲ یُوفِضُونَ ۝٤٣﴾ - تفسير الآية٧٨٨٩٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾، قال: إلى عَلَم يَسْعَوْن{3}. (١٤/٧٠٢)٧٨٨٩٩- عن مجاهد بن جبر -من طريق ابن أبى نجيح- ﴿إلى نُصُبٍ﴾ قال: غاية، ﴿يُوفِضُونَ﴾ قال: يَستَبِقون{4}. (١٤/٧٠٢)٧٨٩٠٠- عن أبي العالية الرِّياحيّ -من طريق عَوْف-، مثله{5}. (١٤/٧٠٣)٧٨٩٠١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿إلى نُصُبٍ يُوفِضُونَ﴾: إلى عَلَم يَنطلِقون{6}. (ز)٧٨٩٠٢- عن مسلم بن جُندُب الهُذلي -من طريق نافع بن أبي نعيم القارئ- عن قول الله: ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾، قال: إلى غاية{7}. (ز)٧٨٩٠٣- عن الحسن البصري -من طريق قُرّة- ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾، قال: يَبْتَدِرون نُصبهم، أيّهم يَستلمه أول{8}. (١٤/٧٠٣)٧٨٩٠٤- عن قتادة بن دعامة -من طريق معمر- ﴿يَوْمَ يَخْرُجُونَ مِنَ الأَجْداثِ﴾ قال: القبور، ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾ قال: إلى عَلَم يَسعَون{9}. (١٤/٧٠٣)٧٨٩٠٥- قال محمد بن كعب القُرَظيّ: ﴿إلى نُصُبٍ يُوفِضُونَ﴾ يشتدّون{10}. (ز)٧٨٩٠٦- عن يحيى بن أبي كثير -من طريق أبي عمرو- في قوله تعالى: ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾، قال: إلى غاية يَسْتَبِقون{6}. (ز)٧٨٩٠٧- قال محمد بن السّائِب الكلبي: ﴿إلى نُصُبٍ يُوفِضُونَ﴾ إلى عَلَم وراية{12}. (ز)٧٨٩٠٨- قال مقاتل بن سليمان: ﴿يَوْمَ يَخْرُجُونَ مِنَ الأَجْداثِ﴾ يعني: القبور ﴿سِراعًا﴾ إلى الصوت، ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾ يقول: كأنهم إلى عَلَم يَسعَون إليه قد نُصب لهم{13}. (ز)٧٨٩٠٩- عن سفيان [الثوري] -من طريق مهران- في قوله: ﴿إلى نُصُبٍ يُوفِضُونَ﴾، قال: إلى عَلَم يَسْتَبِقون{6}. (ز)٧٨٩١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿كَأَنَّهُمْ إلى نُصُبٍ يُوفِضُونَ﴾ قال: النُّصب: حجارة كانوا يعبدونها، حجارة طوال يقال لها نُصب، وفي قوله: ﴿يُوفِضُونَ﴾ قال: يُسْرِعون إليه كما يُسرعون إلى نُصُب يُوفضون. قال ابن زيد: والأنصاب التي كان أهل الجاهلية يعبدونها ويأتونها ويعظِّمونها، كان أحدهم يَحمله معه، فإذا رأى أحسن منه أخذَه، وألقى هذا، فقال له: ﴿كَلٌّ عَلى مَوْلاهُ أيْنَما يُوَجِّهْهُ لا يَأْتِ بِخَيْرٍ هَلْ يَسْتَوِي هُوَ ومَن يَّأْمُرُ بِالعَدْلِ وهُوَ عَلى صَراطٍ مُّسْتَقِيمٍ﴾ [النحل:٧٦]{15}. (ز)"
  70,44,"﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۚ﴾ - قراءات٧٨٩١١- عن الحسن البصري -من طريق أبي الأشهب- أنه كان يقرؤها: (خاشِعًا أبْصارُهُمْ).= (ز)٧٨٩١٢- قال: وكان أبو رجاء يقرؤها: ﴿خاشِعَةً أبْصارُهُمْ﴾{1}. (١٤/٧٠٣)﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۚ﴾ - تفسير الآية٧٨٩١٣- قال قتادة بن دعامة: ﴿خاشِعَةً أبْصارُهُمْ﴾ بسواد الوجوه{2}. (ز)٧٨٩١٤- قال مقاتل بن سليمان: ﴿خاشِعَةً أبْصارُهُمْ﴾ خافضة أبصارهم ذليلة عند مُعاينة النار، ﴿تَرْهَقُهُمْ ذِلَّةٌ﴾ يعني: تَغشاهم مَذَلّة{3}. (ز)﴿ذَ ٰ⁠لِكَ ٱلۡیَوۡمُ ٱلَّذِی كَانُوا۟ یُوعَدُونَ ۝٤٤﴾ - تفسير٧٨٩١٥- عن قتادة بن دعامة -من طريق معمر- ﴿ذَلِكَ اليَوْمُ الَّذِي كانُوا يُوعَدُونَ﴾، قال: ذلك يوم القيامة{4}. (١٤/٧٠٣)٧٨٩١٦- قال مقاتل بن سليمان: يقول: ﴿ذلك﴾ الذي ذُكِر مِن أمر القيامة ﴿اليوم الَّذِي كانُوا يُوعَدُونَ﴾ الذي كانوا يُوعَدون فيه في الدنيا العذاب، وذلك أنّ الله أوعدهم في الدنيا على ألسنة الرُّسُل أنّ العذاب كائن، لما كذّب كفار مكة النبي ﷺ، فقال الله ﷿: ﴿فَذَرْهُم﴾ يعني: قريشًا، يعني: فخَلِّ عنهم ﴿يَخُوضُوا ويَلْعَبُوا حَتّى يُلاقُوا يَوْمَهُمُ الَّذِي يُوعَدُونَ﴾ العذاب فيه{3}. (ز)"
