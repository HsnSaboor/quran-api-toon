tafsir[26]{c,v,t}:
  88,1,"مقدمة السورة٨٢٧٦١- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الغاشية بمكة{1}. (١٥/٣٨٠)٨٢٧٦٢- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٣٨٠)٨٢٧٦٣- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمُسمّى: ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾، وأنها نزلت بعد سورة الذاريات{3}. (ز)٨٢٧٦٤- عن عكرمة مولى ابن عباس= (ز)٨٢٧٦٥- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)٨٢٧٦٦- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)٨٢٧٦٧- عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد ﴿والذّارِيات﴾{6}. (ز)٨٢٧٦٨- عن علي بن أبي طلحة: مكّيّة{7}. (ز)٨٢٧٦٩- قال مقاتل بن سليمان: سورة الغاشية مكّيّة، عددها ست وعشرون آية{8}. (ز)﴿هَلۡ أَتَىٰكَ حَدِیثُ ٱلۡغَـٰشِیَةِ ۝١﴾ - تفسير٨٢٧٧٠- عن عمرو بن ميمون، قال: مَرَّ النبيُّ ﷺ على امرأة تقرأ: ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾، فقام يستمع، ويقول: «نعم، قد جاءني»{9}. (١٥/٣٨٠)٨٢٧٧١- عن عبد الله بن عباس -من طريق علي- قال: الغاشية مِن أسماء يوم القيامة، عظّمه الله، وحذّره عباده{10}. (١٥/٣٨٠)٨٢٧٧٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾، قال: الساعة{11}. (١٥/٣٨١)٨٢٧٧٣- عن سعيد بن جُبَير -من طريق أشعث- قال: الغاشية: غاشية النار{12}. (١٥/٣٨١)٨٢٧٧٤- عن الضَّحّاك بن مُزاحِم، قال: الغاشية: القيامة{13}. (١٥/٣٨١)٨٢٧٧٥- قال الحسن البصري: ﴿الغاشِيَةِ﴾ يعني: القيامة، تغشى الناسَ بعذابها وعقابها{14}. (ز)٨٢٧٧٦- عن قتادة بن دعامة -من طريق سعيد- ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾، قال: حديث الساعة{15}. (١٥/٣٨١)٨٢٧٧٧- قال مقاتل بن سليمان: ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾ يعني: قد أتاك حديث أهل النار، وكلّ شيء في القرآن ﴿هَلْ أتاكَ﴾: قد أتاك{16}٧١٣٩. (ز)٧١٣٩ اختُلف في معنى: ﴿الغاشية﴾ في هذه الآية على قولين: الأول: أنها القيامة تغشى الناس بالأهوال. الثاني: أنها النار تغشى وجوه الكفرة.وعلَّق ابنُ عطية (٨/٥٩٦) على القول الأول بقوله: «يؤيده قوله تعالى: ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾، والوجوه الخاشعة هي وجوه الكفار، وخشوعها: ذُلُّها وتغيُّرُها بالعذاب». وعلَّق على القول الثاني بقوله: «وقد قال تعالى: ﴿وتَغْشى وُجُوهَهُمُ النّارُ﴾ [إبراهيم:٥٠]، وقال: ﴿ومِن فَوْقِهِمْ غَواشٍ﴾ [الأعراف:٤١]، فهي تغشى سكانها».ورجَّح ابنُ جرير (٢٤/٣٢٧) العموم، فقال: «إن الله قال لنبيّه: ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾، ولم يُخْبِرنا أنه عَنى غاشية القيامة، ولا أنه عَنى غاشية النار، وكلتاهما غاشيةٌ، هذه تغشى الناس بالبلابل والأهوال والكروب، وهذه تغشى الكفار باللفْح في الوجوه والشُّواظ والنُّحاس، فلا قول أصحُّ في ذلك مِن أن يقال كما قال -جلَّ ثناؤه-، ويُعَمَّ الخبرُ بذلك كما عمَّه»."
  88,2,"﴿وُجُوهࣱ یَوۡمَىِٕذٍ خَـٰشِعَةٌ ۝٢﴾ - تفسير٨٢٧٧٨- عن سعيد بن جُبَير، ﴿وُجُوهٌ يَوْمَئِذٍ﴾، قال: يعني: في الآخرة{1}. (١٥/٣٨٢)٨٢٧٧٩- عن قتادة بن دعامة -من طريق معمر- ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾، قال: خاشعة في النار{2}. (ز)٨٢٧٨٠- عن قتادة بن دعامة، ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾، قال: ذليلة في النار{3}. (١٥/٣٨١)٨٢٧٨١- قال مقاتل بن سليمان: ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ﴾، يعني: ذليلة{4}. (ز)"
  88,3,"﴿عَامِلَةࣱ نَّاصِبَةࣱ ۝٣﴾ - تفسير٨٢٧٨٢- عن أبي عمران الجَونيّ، قال: مَرَّ عمر بن الخطاب براهبٍ، فوقف، ونودي الراهب، فقيل له: هذا أمير المؤمنين. فاطّلع، فإذا إنسان به مِن الضر والاجتهاد وتَرْك الدنيا، فلمّا رآه عمر بكى، فقيل له: إنه نصراني! فقال عمر: قد علمتُ، ولكني رحِمتُه؛ ذكرتُ قول الله: ﴿عامِلَةٌ ناصِبَةٌ تَصْلى نارًا حامِيَةً﴾، فرحمتُ نَصَبه واجتهاده، وهو في النار{1}. (١٥/٣٨٢)٨٢٧٨٣- عن عبد الله بن عباس -من طريق عكرمة- ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾، قال: يعني: اليهود والنصارى، تخشع ولا ينفعها عملُها{2}. (١٥/٣٨٢)٨٢٧٨٤- عن عبد الله بن عباس -من طريق علي- ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: النصارى{3}. (ز)٨٢٧٨٥- عن عبد الله بن عباس -من طريق أبي الضحى- ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: الرُّهبان{4}. (ز)٨٢٧٨٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾، قال: تعمل وتَنصَب في النار{5}٧١٤٠. (١٥/٣٨١)٧١٤٠ لم يذكر ابنُ جرير (٢٤/٣٢٨) في معنى: ﴿عامِلَةٌ ناصِبَةٌ﴾ سوى قول ابن عباس من طريق العَوفيّ، وقول الحسن، وقتادة، وابن زيد.٨٢٧٨٧- قال سعيد بن جُبَير= (ز)٨٢٧٨٨- وزيد بن أسلم: ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾ هم الرُّهبان، وأصحاب الصوامع{6}. (ز)٨٢٧٨٩- قال الضَّحّاك بن مُزاحِم: ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾ يُكلّفون ارتقاء جبل مِن حديد في النار{7}. (ز)٨٢٧٩٠- عن عكرمة مولى ابن عباس، في قوله: ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: عاملة في الدنيا بالمعاصي، تَنصَب في النار يوم القيامة{8}٧١٤١. (١٥/٣٨٢)٧١٤١ اختُلف في معنى: ﴿عامِلَةٌ ناصِبَةٌ﴾ على أقوال: الأول: عاملة في النار ناصبة فيها. الثاني: عاملة في الدنيا ناصبة فيها، والآية في القِسِّيسين، وعباد الأوثان، وكلّ مَن اجتهد في كُفر. الثالث: عاملة في الدنيا ناصبة يوم القيامة.ووجَّه ابنُ عطية (٨/٥٩٦) القول الثالث بقوله: «فالعمل -على هذا- هو مساعي الدنيا».ورجَّح ابنُ تيمية (٧/٥) -مستندًا إلى اللغة، والدلالة العقلية، والنظائر- القول الأول، فقال: «هذا هو الحق لوجوه: أحدها: أنه على هذا التقدير يتعلق الظرف بما يليه، أي: وجوه يوم الغاشية خاشعة عاملة ناصبة صالية، وعلى الأولى لا يتعلق إلا بقوله: ﴿تصلى﴾، ويكون قوله: ﴿خاشعة﴾ صفة للوجوه، قد فصل بين الصفة والموصوف بأجنبي متعلّق بصفة أخرى متأخرة، والتقدير: وجوه خاشعة عاملة ناصبة يومئذٍ تصلى نارًا حامية، والتقديم والتأخير على خلاف الأصل؛ فالأصل إقرار الكلام على نظْمه وترتيبه لا تغيير ترتيبه، ثم إنما يجوز فيه التقديم والتأخير مع القرينة، أما مع اللبس فلا يجوز؛ لأنه يلتبس على المخاطب، ومعلوم أنه ليس هنا قرينة تدل على التقديم والتأخير، بل القرينة تدل على خلاف ذلك، فإرادة التقديم والتأخير بمثل هذا الخطاب خلاف البيان، وأمْر المخاطب بفهمه تكليف لما لا يطاق. الوجه الثاني: أنّ الله قد ذكر وجوه الأشقياء ووجوه السعداء في السورة، فقال بعد ذلك: ﴿وُجُوهٌ يَوْمَئِذٍ ناعِمَةٌ لِسَعْيِها راضِيَةٌ فِي جَنَّةٍ عالِيَةٍ﴾، ومعلوم أنه إنما وصفها بالنعمة يوم القيامة لا في الدنيا؛ إذ هذا ليس بمدح، فالواجب تشابه الكلام وتناظر القسمين، لا اختلافهما، وحينئذ فيكون الأشقياء وُصفتْ وجوههم بحالها في الآخرة. الثالث: أنّ نظير هذا التقسيم قوله: ﴿وُجُوهٌ يَوْمَئِذٍ ناضِرَةٌ إلى رَبِّها ناظِرَةٌ ووُجُوهٌ يَوْمَئِذٍ باسِرَةٌ تَظُنُّ أنْ يُفْعَلَ بِها فاقِرَةٌ﴾ [القيامة:٢٢-٢٥]، وقوله: ﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ ضاحِكَةٌ مُسْتَبْشِرَةٌ ووُجُوهٌ يَوْمَئِذٍ عَلَيْها غَبَرَةٌ تَرْهَقُها قَتَرَةٌ أُولَئِكَ هُمُ الكَفَرَةُ الفَجَرَةُ﴾ [عبس:٣٨-٤٢]، وهذا كله وصفٌ للوجوه لحالها في الآخرة لا في الدنيا. الرابع: أنّ وصف الوجوه بالأعمال ليس في القرآن، وإنما في القرآن ذِكْر العلامة، كقوله: ﴿سِيمِاهُمْ فِي وُجُوهِهِمْ﴾ [الفتح:٢٩]، وقوله: ﴿ولَوْ نَشاءُ لأَرَيْناكَهُمْ فَلَعَرَفْتَهُمْ بِسِيماهُمْ﴾ [محمد:٣٠]، وقوله: ﴿وإذا تُتْلى عَلَيْهِمْ آياتُنا بَيِّناتٍ تَعْرِفُ فِي وُجُوهِ الَّذِينَ كَفَرُوا المُنْكَرَ يَكادُونَ يَسْطُونَ بِالَّذِينَ يَتْلُونَ عَلَيْهِمْ آياتِنا﴾ [الحج:٧٢]، وذلك لأنّ العمل والنَّصَب ليس قائمًا بالوجوه فقط؛ بخلاف السيما والعلامة. الخامس: أنّ قوله: ﴿خاشِعَةً عامِلَةٌ ناصِبَةٌ﴾ لو جُعل صفة لهم في الدنيا لم يكن في هذا اللفظ ذم، فإنّ هذا إلى المدح أقرب، وغايته أنه وصفٌ مشترك بين عُبّاد المؤمنين وعُبّاد الكفار، والذم لا يكون بالوصف المشترك، ولو أُريد المختص لقيل: خاشعة للأوثان -مثلًا-، عاملة لغير الله، ناصبة في طاعة الشيطان. وليس في الكلام ما يقتضي كون هذا الوصف مختصًّا بالكفار، ولا كونه مذمومًا، وليس في القرآن ذمٌّ لهذا الوصف مطلقًا، ولا وعيد عليه، فحمْله على هذا المعنى خروج عن الخطاب المعروف في القرآن. السادس: أنّ هذا الوصف مختص ببعض الكفار، ولا موجب للتخصيص، فإنّ الذين لا يتعبّدون من الكفار أكثر، وعقوبة فُسّاقهم في دينهم أشد في الدنيا والآخرة، فإنّ مَن كفَّ منهم عن المحرمات المتفق عليها، وأدّى الواجبات المتفق عليها لم تكن عقوبته كعقوبة الذين يدعون مع الله إلهًا آخر، ويقتلون النفس التي حرّم الله إلا بالحق ويَزْنُون. فإذا كان الكفر والعذاب على هذا التقدير في القسم المتروك أكثر وأكبر؛ كان هذا التخصيص عكس الواجب. السابع: أنّ هذا الخطاب فيه تنفير عن العبادة والنُّسك ابتداء، ثم إذا قُيِّد ذلك بعبادة الكفار والمبتدعة -وليس في الخطاب تقييد- كان هذا سعيًا في إصلاح الخطاب بما لم يُذكر فيه».٨٢٧٩١- عن الحسن البصري -من طريق أبي رجاء- أنه قرأ: ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: لم تعمل لله في الدنيا، فأعْملها في النار{9}. (ز)٨٢٧٩٢- عن الحسن البصري -من طريق يونس- في قوله تعالى: ﴿وجوه يومئذ خاشعة عاملة ناصبة﴾، قال: لم تخشع لله في الدنيا فأخْشعها وأنصبها في النار، فذلك عمَلها{10}. (ز)٨٢٧٩٣- عن قتادة بن دعامة -من طريق سعيد- ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: تكبّرتْ في الدنيا عن طاعة الله، فأعْملها وأنصبها في النار{11}. (١٥/٣٨١)٨٢٧٩٤- عن قتادة بن دعامة -من طريق معمر- ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: عاملة ناصبة في النار{12}. (ز)٨٢٧٩٥- قال محمد بن السّائِب الكلبي: ﴿وُجُوهٌ يَوْمَئِذٍ خاشِعَةٌ عامِلَةٌ ناصِبَةٌ﴾ يُجَرُّون على وجوههم في النار{13}. (ز)٨٢٧٩٦- قال مقاتل بن سليمان: ﴿عامِلَةٌ ناصِبَةٌ﴾ يعني: عاملة في النار، النار تأكله ويأكل مِن النار، يعني: ناصبة للعذاب صاغِرة{14}. (ز)٨٢٧٩٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿عامِلَةٌ ناصِبَةٌ﴾، قال: لا أحد أنصب ولا أشدّ مِن أهل النار{15}. (ز)"
  88,4,"﴿تَصۡلَىٰ نَارًا حَامِیَةࣰ ۝٤﴾ - تفسير٨٢٧٩٨- قال عبد الله بن مسعود: ﴿تَصْلى نارًا حامِيَةً﴾ تخوض في النار كما تخوض الإبل في الوَحْل{1}. (ز)٨٢٧٩٩- عن عبد الله بن عباس، في قوله: ﴿تَصْلى نارًا حامِيَةً﴾، قال: حارّة{2}. (١٥/٣٨٢)"
  88,5,"﴿تُسۡقَىٰ مِنۡ عَیۡنٍ ءَانِیَةࣲ ۝٥﴾ - تفسير٨٢٨٠٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾، قال: هي التي قد طال أنْيُها{1}. (١٥/٣٨١)٨٢٨٠١- عن عبد الله بن عباس، ﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾، قال: قد أنى غليانها{2}. (١٥/٣٨٢)٨٢٨٠٢- عن عبد الله بن عباس، ﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾، قال: انتهى حرُّها{3}. (١٥/٣٨٢)٨٢٨٠٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿مِن عَيْنٍ آنِيَةٍ﴾، قال: قد بلغتْ إناها، وحان شُربها{4}. (١٥/٣٨٣)٨٢٨٠٤- عن الحسن البصري -من طريق معمر- ﴿مِن عَيْنٍ آنِيَةٍ﴾، قال: قد أنى حرّها{5}. (١٥/٣٨٣)٨٢٨٠٥- عن الحسن البصري -من طريق أبي رجاء- ﴿مِن عَيْنٍ آنِيَةٍ﴾، قال: قد آن طبخُها منذ خلق الله السماوات والأرض{6}. (١٥/٣٨٣)٨٢٨٠٦- عن قتادة بن دعامة -من طريق سعيد- ﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾، قال: أنى طبخها منذ خلق الله السماوات والأرض{7}. (١٥/٣٨١)٨٢٨٠٧- عن إسماعيل السُّدِّيّ، ﴿مِن عَيْنٍ آنِيَةٍ﴾، قال: انتهى حرُّها، فليس فوقه حرّ{2}. (١٥/٣٨٣)٨٢٨٠٨- قال مقاتل بن سليمان: ﴿تُسْقى مِن عَيْنٍ آنِيَةٍ﴾ مِن عينٍ قد انتهى حرُّها، وذلك أنّ جهنم تُسَعَّر عليهم منذ يوم خُلقتْ إلى يوم يدخلونها، وهي عينٌ تخرج مِن أصل جبل طولها مسيرة سبعين عامًا، ماؤها أسود كدرديّ الزيت، كدرٌ غليظ، كثير الدعاميص{9}، تسقيه الملائكة بإناء مِن حديد مِن نار، فيشربه، فإذا قرّب الإناء مِن فِيه أحرق شدقيه، وتناثرتْ أنيابُه وأضراسُه، فإذا بلغ صدره نضج قلبه، فإذا بلغ بطنه غلى كما يغلي الحميم مِن شدة الحرّ حتى يذوب كما يذوب الرصاص إذا أصابه النار، فيدعو الشقيُّ بالويل{10}. (ز)٨٢٨٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿آنِيَةٍ﴾، قال: حاضرة{11}٧١٤٢. (١٥/٣٨٣)٧١٤٢ علَّق ابنُ عطية (٨/٥٩٧) على قول ابن زيد بقوله: «من قولهم: أنى الشيءُ: إذا حضر»."
  88,6,"﴿لَّیۡسَ لَهُمۡ طَعَامٌ إِلَّا مِن ضَرِیعࣲ ۝٦ لَّا یُسۡمِنُ وَلَا یُغۡنِی مِن جُوعࣲ ۝٧﴾ - تفسير٨٢٨١٠- عن أبي الدّرداء، قال: قال رسول الله ﷺ: «يُلقى على أهل النار الجوعُ، حتى يعدل ما هم فيه مِن العذاب، فيستغيثون بالطعام، فيُغاثون بطعام مِن ضريع، لا يُسمن ولا يُغني مِن جوع»{1}. (١٥/٣٨٤)٨٢٨١١- عن عبد الله بن عباس، ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: قال رسول الله ﷺ: «شيء يكون في النار شبه الشوك، أمرّ مِن الصبر، وأنتن مِن الجِيفة، وأشدّ حرًّا مِن النار، سمّاه الله: الضريع، إذا طعمه صاحبه لا يدخل البطن، ولا يرتفع إلى الفم، فيبقى بين ذلك، ولا يُغني من جوع»{2}. (١٥/٣٨٥)٨٢٨١٢- قال أبو الدّرداء= (ز)٨٢٨١٣- والحسن البصري: إنّ الله تعالى يُرسل على أهل النار الجوع، حتى يعدل عندهم ما هم فيه من العذاب، فيستغيثون، فيُغاثون مِن الضّريع، ثم يستغيثون، فيُغاثون بطعام ذا غُصّة، فيذكرون أنهم كانوا يجيزون الغصص في الدنيا بالماء، فيستسقون، فيُعطشهم ألف سنة، ثم يُسقون من عين آنية، شَربةً لا هنيئة ولا مريئة، فإذا أدنوه من وجوههم سلخ جلود وجوههم وشواها، فإذا وصل إلى بطونهم قطعها، فذلك قوله عز جل: ﴿وسُقُوا ماءً حَمِيمًا فَقَطَّعَ أمْعاءَهُمْ﴾ [محمد:١٥]{3}. (ز)٨٢٨١٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: الشِّبرِق{4}. (١٥/٣٨١)٨٢٨١٥- عن عبد الله بن عباس -من طريق علي- ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، يقول: مِن شجر مِن نار{5}. (١٥/٣٨٢)٨٢٨١٦- عن عبد الله بن عباس، ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: الشِّبرِق اليابس{6}. (١٥/٣٨٣)٨٢٨١٧- عن عبد الله بن عباس -من طريق عطاء- ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾: هو شيء يطرحه البحر المالح، يُسمِّيه أهل اليمن: الضريع{7}. (ز)٨٢٨١٨- عن أبي الجَوْزاء -من طريق عمرو بن مالك- قال: الضريع: السُّلّاء، وهو الشوك، وكيف يَسمَن مَن كان طعامه الشوك؟!{8}. (١٥/٣٨٤)٨٢٨١٩- عن سعيد بن جُبَير -من طريق جعفر- ﴿إلّا مِن ضَرِيعٍ﴾، قال: مِن حجارة{9}. (١٥/٣٨٤)٨٢٨٢٠- عن سعيد بن جُبَير، ﴿إلّا مِن ضَرِيعٍ﴾، قال: الزّقوم{10}٧١٤٣. (١٥/٣٨٤)٧١٤٣ وجَّه ابنُ عطية (٨/٥٩٧) قول سعيد بن جُبَير بقوله: «لأنّ الله تعالى قد أخبر في هذه الآية أنّ الكفار لا طعام لهم إلا مِن ضَرِيعٍ، وقد أخبر أنّ الزّقوم طعام الأثيم، فذلك يقتضي أنّ الضّريع: الزّقوم».٨٢٨٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿إلّا مِن ضَرِيعٍ﴾، قال: الشِّبرِق اليابس{11}. (١٥/٣٨٣)٨٢٨٢٢- عن عكرمة مولى ابن عباس -من طريق عبد الرحمن الأصبهاني- في قوله: ﴿إلّا مِن ضَرِيعٍ﴾، قال: الشِّبرِق{12}. (١٥/٣٨٢)٨٢٨٢٣- عن عكرمة مولى ابن عباس -من طريق رجل من عبد القيس- قال: الضّريع: الشِّبرِق؛ شجرة ذات شوك لاطئة بالأرض، فإذا كان الربيع سمّتها قريش: الشِّبرِق، فإذا هاج العود سمّتها: الضّريع{13}. (١٥/٣٨٤)٨٢٨٢٤- عن قتادة بن دعامة، قال: الضّريع بلغة قريش في الربيع: الشِّبرِق، وفي الصيف: الضّريع{14}. (١٥/٣٨٤)٨٢٨٢٥- عن قتادة بن دعامة -من طريق معمر- ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: هو الشِّبرِق، إذا يبس يُسمّى: الضّريع{15}. (١٥/٣٨١)٨٢٨٢٦- عن قتادة بن دعامة -من طريق سعيد- ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: مِن شرّ الطعام، وأبشعه، وأخبثه{16}. (١٥/٣٨١)٨٢٨٢٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: ﴿طعام إلا من ضريع﴾، قال: شجرة يقال لها: الشِّبرِق{17}. (ز)٨٢٨٢٨- قال محمد بن السّائِب الكلبي: ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾ نبْتٌ يَنبت في الربيع، فإذا كان في الصيف يبس؛ فاسمه إذا كان عليه ورقه: شِبرِق، وإذا تساقط ورقه فهو: الضّريع، فالإبل تأكله أخضر، فإذا يبس لم تذقه{18}. (ز)٨٢٨٢٩- قال مقاتل بن سليمان: ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾ وهي شجرة تكون بمكة كثيرة الشوك، لا تَقربها دابة في الأرض مِن شوكها، ولا يستطيع أحد أن يمسّها مِن كثرة شوكها، وتُسمّيها قريش وهي رطبة في الربيع: الشِّبرِق، وتصيب الإبل من ورقها في الربيع ما دامت رطبة، فإذا يبستْ لم تَقربها الإبل، وما من دابة في الأرض من الهوام والسباع وما يؤذي بني آدم إلا مثلها في النار، سلّطها الله ﷿ على أهلها، لكنها مِن نار، وما خلق الله شيئًا في النار إلا من النار، ﴿لا يُسْمِنُ ولا يُغْنِي مِن جُوعٍ﴾ فإنهم لا يطعمون مِن أجل الجوع، وإنما من أجل العذاب{19}. (ز)٨٢٨٣٠- عن شريك بن عبد الله -من طريق محمد بن عبيد- في قوله: ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: الشِّبرِق{20}. (ز)٨٢٨٣١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿لَيْسَ لَهُمْ طَعامٌ إلّا مِن ضَرِيعٍ﴾، قال: الضّريع: الشوك من النار. قال: وأما في الدنيا فإنّ الضّريع: الشوك اليابس الذي ليس له ورق، تدعوه العرب: الضّريع، وهو في الآخرة شوك من نار{21}٧١٤٤. (ز)٧١٤٤ زاد ابنُ عطية (٨/٥٩٨-٥٩٩) في معنى الآية أقوالًا أخرى، وعلَّق على بعضها، فقال: «وقيل: الضريع: العِشْرِقُ. وقال النبي ﷺ: «الضريع شوك في النار». وقال بعض اللغويين: الضريع يَبِسُ العَرْفَج إذا تحطّم. وقال آخرون: هو رَطْبُ العَرْفج. وقال الزَّجّاج: هو نَبْتٌ كالعَوْسج. وقال بعض المفسرين: الضّريع نبتٌ في البحر أخضر منتن مُجَوَّف مستطيل له نَوْر فيه كبير ... وكلّ مَن ذَكر شيئًا مما قدمناه فإنما يعني أنّ ذلك من نار ولا بُدّ، وكلّ ما في النار فهو نار. وقال قوم: ضَرِيع وادٍ في جهنم. وقال جماعة من المتأولين: الضّريعُ طعام أهل النار. ولم يُرِد أن يخصص شيئًا مما ذُكِر، قال بعض اللغويين: وهذا مما لا تعرفه العرب. وقيل: الضّريع: الجلدة التي على العظم تحت اللحم». ثم علَّق بقوله: «ولا أعرف مَن تأوَّل الآية بهذا، وأهل هذه الأقاويل يقولون: الزّقوم لطائفة، والضّريع لطائفة، والغِسْلين لطائفة»."
  88,7,"88:6"
  88,8,"﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾ - قراءات٨٢٨٣٢- عن سعيد بن جُبَير أنه قرأ في سورة الغاشية: (مُتَّكِئِينَ فِيها ناعِمِينَ فِيها){1}. (١٥/٣٨٥)﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾ - تفسير الآية٨٢٨٣٣- قال مقاتل بن سليمان: ﴿وُجُوهٌ يَوْمَئِذٍ ناعِمَةٌ﴾ يعني: فَرِحة، شبّه الله ﷿ وجوههم بوجوه قوم فَرِحين؛ إذا أصابوا الشراب طابتْ أنفسهم، فاجتمع الدم في وجوههم، فاجتمع فرح القلوب وفرح الشراب، فهو ضاحك الوجه، مبتسم طيّب النفس{2}. (ز)"
  88,9,"﴿لِّسَعۡیِهَا رَاضِیَةࣱ ۝٩﴾ - تفسير٨٢٨٣٤- قال مقاتل بن سليمان: ﴿لِسَعْيِها راضِيَةٌ﴾، يعني: قد رضي الله عمله، فأثابه الله ﷿ ذلك بعمله{1}. (ز)٨٢٨٣٥- عن سفيان، في قوله: ﴿لِسَعْيِها راضِيَةٌ﴾، قال: رَضِيَتْ عملها{2}. (١٥/٣٨٥)"
  88,10,"﴿فِی جَنَّةٍ عَالِیَةࣲ ۝١٠﴾ - تفسير٨٢٨٣٦- قال مقاتل بن سليمان: ﴿فِي جَنَّةٍ عالِيَةٍ﴾ وإنما سمّاها عالية لأن جهنم أسفل منها، وهي دركات، والجنة درجات{1}. (ز)"
  88,11,"﴿لَّا تَسۡمَعُ فِیهَا لَـٰغِیَةࣰ ۝١١﴾ - قراءات٨٢٨٣٧- عن عاصم أنه قرأ: ﴿لا تَسْمَعُ فِيها﴾ بالتاء ونصب التاء، ﴿لاغِيَةً﴾ منصوبة منونة{1}٧١٤٥. (١٥/٣٨٥)٧١٤٥ اختلفت القرأة في قراءة قوله تعالى: ﴿لا تَسْمَعُ فِيها لاغِيَةً﴾ على ثلاث قراءات: الأولى: ﴿لا تَسْمَعُ﴾ بفتح التاء، بمعنى: لا تسمع الوجوه. الثانية: ‹لا تُسْمَعُ› بضم التاء، بمعنى: ما لم يُسمّ فاعله. الثالثة: ‹لا يُسْمَعُ› بالضم أيضًا غير أنها بالياء.ورجَّح ابنُ جرير (٢٤/٣٣٦) «أن كل ذلك قراءاتٌ معروفاتٌ صحيحات المعاني، فبأيِّ ذلك قرأ القارئ فمصيبٌ».﴿لَّا تَسۡمَعُ فِیهَا لَـٰغِیَةࣰ ۝١١﴾ - تفسير الآية٨٢٨٣٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿لا تَسْمَعُ فِيها لاغِيَةً﴾، يقول: لا تَسمع أذًى ولا باطلًا{2}. (١٥/٣٨٥)٨٢٨٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿لا تَسْمَعُ فِيها لاغِيَةً﴾، قال: شتمًا{3}. (١٥/٣٨٦)٨٢٨٤٠- عن قتادة بن دعامة -من طريق معمر- ﴿لا تَسْمَعُ فِيها لاغِيَةً﴾، قال: لا تَسمع فيها باطلًا، ولا مَأْثَمًا{4}. (١٥/٣٨٦)٨٢٨٤١- عن سليمان بن مهران الأعمش، ﴿لا تَسْمَعُ فِيها لاغِيَةً﴾، قال: مُؤْذِيَة{5}. (١٥/٣٨٦)٨٢٨٤٢- قال مقاتل بن سليمان: ﴿لا تَسْمَعُ فِيها لاغِيَةً﴾، يقول: لا يسمع بعضهم من بعض غيبة، ولا كذب، ولا شتم{6}٧١٤٦. (ز)٧١٤٦ ذكر ابنُ جرير (٢٤/٣٣٤) عن بعض نحويي الكوفة أنّ معنى الآية: «لا تسمع فيها حالفةٌ على الكذب، ولذلك قيل: لاغية». ثم انتقده -مستندًا إلى أقوال السلف- قائلًا: «ولهذا الذي قاله مذهبٌ ووجْهٌ، لولا أنّ أهل التأويل من الصحابة والتابعين على خلافه، وغير جائزٍ لأحدٍ خلافهم فيما كانوا عليه مُجْمِعين»."
  88,12,"﴿فِیهَا عَیۡنࣱ جَارِیَةࣱ ۝١٢﴾ - تفسير٨٢٨٤٣- قال مقاتل بن سليمان: ﴿فِيها عَيْنٌ جارِيَةٌ﴾ يعني: في الجنة؛ لأنها فيها تجري الأنهار{1}٧١٤٧. (ز)٧١٤٧ ذكر ابنُ عطية (٨/٦٠٠) في معنى: ﴿عَيْنٌ﴾ قوله: «﴿عَيْنٌ﴾ في هذه الآية اسم جنس، ويحتمل أن تكون عينًا مخصوصة ذُكرت على جهة التشريف لها»."
  88,13,"﴿فِیهَا سُرُرࣱ مَّرۡفُوعَةࣱ ۝١٣﴾ - تفسير٨٢٨٤٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾، قال: بعضها فوق بعض{1}. (١٥/٣٨٦)٨٢٨٤٥- قال عبد الله بن عباس: ﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾ ألواحها مِن ذهب، مُكلّلة بالزَّبَرْجد والدُّرّ والياقوت، مرتفعة ما لم يجئ أهلها، فإذا أراد أن يجلس عليها تواضعتْ له حتى يجلس عليها، ثم ترتفع إلى مواضعها{2}. (ز)٨٢٨٤٦- قال مقاتل بن سليمان: ﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾ منسوجة بقضبان الدُّرّ والذَّهب، عليها سبعون فراشًا، كلّ فراش قدر غرفة مِن غرف الدنيا{3}. (ز)٨٢٨٤٧- عن عبد الملك ابن جُرَيْج، ﴿فِيها سُرُرٌ مَرْفُوعَةٌ﴾، قال: مرتفعة{4}. (١٥/٣٨٦)"
  88,14,"﴿وَأَكۡوَابࣱ مَّوۡضُوعَةࣱ ۝١٤﴾ - تفسير٨٢٨٤٨- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: ﴿وأكواب﴾، قال: الأكواب: الأقساط{1}. (ز)٨٢٨٤٩- قال مقاتل بن سليمان: ﴿وأَكْوابٌ مَوْضُوعَةٌ﴾، يعني: مصفوفة، وهي أكواب من فِضّة، وهي في الصفاء مثل القوارير، مُدَوَّرة الرؤوس، ليس لها عُرًى ولا خراطيم{2}. (ز)"
  88,15,"﴿وَنَمَارِقُ مَصۡفُوفَةࣱ ۝١٥﴾ - تفسير٨٢٨٥٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿ونَمارِقُ﴾، قال: مجالس{1}. (١٥/٣٨٦)٨٢٨٥١- عن عبد الله بن عباس، في قوله: ﴿ونَمارِقُ﴾، قال: الوسائد{2}. (١٥/٣٨٦)٨٢٨٥٢- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿ونَمارِقُ﴾، قال: المرافق{3}. (١٥/٣٨٦)٨٢٨٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿ونَمارِقُ﴾، قال: الوسائد{4}. (١٥/٣٨٦)٨٢٨٥٤- قال مقاتل بن سليمان: ﴿ونَمارِقُ مَصْفُوفَةٌ﴾، يعني: الوسائد الكبار العظام، مصفوفة على الطنافس، وهي بلغة قريش خاصة{5}. (ز)"
  88,16,"﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾ - قراءات٨٢٨٥٥- عن عمار بن محمد، قال: صَلّيتُ خلف منصور بن المعتمر، فقرأ: ﴿هَلْ أتاكَ حَدِيثُ الغاشِيَةِ﴾، فقرأ فيها: (وزَرابِيُّ مَبْثُوثَةٌ مُّتَّكِئِينَ فِيها ناعِمِينَ){1}. (١٥/٣٨٧)﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾ - تفسير الآية٨٢٨٥٦- عن عبد الله بن عباس، في قوله: ﴿وزَرابِيُّ﴾، قال: البُسط{2}. (١٥/٣٨٦)٨٢٨٥٧- قال عبد الله بن عباس: ﴿وزَرابِيُّ﴾ هي الطنافس التي لها خمل رقيق{3}. (ز)٨٢٨٥٨- عن عكرمة مولى ابن عباس، ﴿وزَرابِيُّ مَبْثُوثَةٌ﴾، قال: بعضها على بعض{4}. (١٥/٣٨٧)٨٢٨٥٩- عن الحسن البصري، ﴿وزَرابِيُّ﴾، قال: البُسُط{5}. (١٥/٣٨٦)٨٢٨٦٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: ﴿مَبْثُوثَةٌ﴾، قال: مبسوطة{6}. (١٥/٣٨٦)٨٢٨٦١- قال مقاتل بن سليمان: ﴿وزَرابِيُّ مَبْثُوثَةٌ﴾، يعني: طنافس مبسوطة بعضها على بعض، يذكّرهم الله ﷿ صُنعه؛ ليعتبر عباده، فيحرصوا عليها، ويرغبوا فيها، ويحذروا النار، فإنّ عقوبته على قدر سلطانه، وكرامته قدر سلطانه{7}. (ز)﴿وَزَرَابِیُّ مَبۡثُوثَةٌ ۝١٦﴾ - آثار متعلقة بالآية٨٢٨٦٢- عن عبد الله بن أبي الهذيل: أنّ موسى أو غيره من الأنبياء قال: يا ربّ، كيف يكون هذا منك؟! أولياؤك في الأرض خائفون يُقتلون، ويطلبون فلا يُعطون، وأعداؤك يأكلون ما شاؤوا، ويشربون ما شاؤوا! ونحو هذا، فقال: انطلِقوا بعبدي إلى الجنة. فينظر ما لم يَر مثله قطّ؛ إلى أكواب موضوعة، ونمارق مصفوفة، وزرابيّ مبثوثة، وإلى الحُور العين، وإلى الثمار، وإلى الخدم كأنهم لؤلؤ مكنون، فقال: ما ضرّ أوليائي ما أصابهم في الدنيا إذا كان مصيرهم إلى هذا؟! ثم قال: انطلِقوا بعبدي. فانطُلق به إلى النار، فخرج منها عُنق، فصَعِق العبد، ثم أفاق، فقال: ما نفع أعدائي ما أعطيتُهم في الدنيا إذا كان مصيرهم إلى هذا؟ قال: لا شيء{8}. (١٥/٣٨٧)٨٢٨٦٣- عن عبد الله بن عمار -من طريق عكرمة بن خالد- قال: رأيتُ عمر بن الخطاب يُصلِّي على عبقريّ، وهو الزرابيّ{9}. (ز)"
  88,17,"﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾ - نزول الآية٨٢٨٦٤- عن قتادة بن دعامة -من طريق سعيد- قال: لما نعت الله ما في الجنة عجِب من ذلك أهلُ الضلالة؛ فأنزل الله: ﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾، وكانت الإبل عيشًا من عيش العرب، وخَوَلًا مِن خَوَلهم{1}. (١٥/٣٨٨)٨٢٨٦٥- عن قتادة بن دعامة، قال: ذكر الله تعالى ارتفاع سُرُرِ الجنة، وفُرُشِها، فقالوا: كيف نصعدها؟ فأنزل الله تعالى هذه الآية{2}. (ز)﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾ - تفسير الآية٨٢٨٦٦- سُئِل الحسن البصري عن هذه الآية: ﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾، وقيل له: الفيل أعظم في الأعجوبة؟ فقال: أمّا الفيل فالعرب بعيدة العهد بها، ثم هو لا خير فيه، لا يُركب ظهرها، ولا يؤكل لحمها، ولا يُحلب درّها، والإبل أعزّ مالٍ للعرب وأنفَسها، تأكل النوى والقتّ وتُخرج اللبن{2}. (ز)٨٢٨٦٧- قال محمد بن السّائِب الكلبي: ﴿أفَلا يَنْظُرُونَ إلى الإبِلِ كَيْفَ خُلِقَتْ﴾ لأنّها تنهض بحمْلها وهي باركة، ولأنه ليس شيء مِن الحيوانات سابقها غيرها{2}. (ز)٨٢٨٦٨- قال مقاتل بن سليمان: ﴿أفَلا يَنْظُرُونَ إلى الإبِلِ﴾ لأنّ العرب لم يكونوا رأوا الفيل، وإنما ذكر لهم ما أبصروا، ولو أنه قال: أفلا ينظرون إلى الفِيَلة ﴿كَيْفَ خُلِقَتْ﴾ لم يتعجّبوا لها؛ لأنهم لم يَروها{5}٧١٤٨. (ز)٧١٤٨ نقل ابنُ عطية (٨/٦٠١) عن المبرد قوله: «الإبل هنا: السحاب؛ لأنّ العرب قد تسميها بذلك إذ تأتي أرسالًا كالإبل، وتُزْجى كما تُزْجى الإبل، وهي في هيئتها أحيانًا تشبه الإبل والنعام». واستشهد ببيت من الشعر:كأن السحاب دوين السما ء نعام تعلق بالأرجل.﴿أَفَلَا یَنظُرُونَ إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾ - آثار متعلقة بالآية٨٢٨٦٩- عن شريح [القاضي] -من طريق أبي إسحاق، عمَّن سمعه- أنه كان يقول لأصحابه: اخرجوا بنا إلى السوق فننظر إلى الإبل كيف خُلقتْ؟{6}. (١٥/٣٨٩)"
  88,18,"﴿وَإِلَى ٱلسَّمَاۤءِ كَیۡفَ رُفِعَتۡ ۝١٨ وَإِلَى ٱلۡجِبَالِ كَیۡفَ نُصِبَتۡ ۝١٩﴾ - تفسير٨٢٨٧٠- عن قتادة بن دعامة -من طريق سعيد- قال: ﴿وإلى السَّماءِ كَيْفَ رُفِعَتْ وإلى الجِبالِ كَيْفَ نُصِبَتْ﴾، قال: تصعد إلى الجبل الصَّيْخُود{1} عامة يومك، فإذا أفضيتَ إلى أعلاه أفضيتَ إلى عيون مُتفجِّرة، وأثمار متهدّلة، لم تغرسه الأيدي، ولم تعمله الناس، نعمة من الله، وبُلْغَة إلى أجل{2}. (١٥/٣٨٨)٨٢٨٧١- قال مقاتل بن سليمان: ﴿وإلى السَّماءِ كَيْفَ رُفِعَتْ﴾ من فوقهم خمسمائة عام، ﴿وإلى الجِبالِ كَيْفَ نُصِبَتْ﴾ على الأرض أوتادًا لِئلّا تزول بأهلها{3}. (ز)"
  88,19,"88:18"
  88,20,"﴿وَإِلَى ٱلۡأَرۡضِ كَیۡفَ سُطِحَتۡ ۝٢٠﴾ - تفسير٨٢٨٧٢- عن عبد الله بن عباس -من طريق عطاء- ﴿وإلى الأرْضِ كَيْفَ سُطِحَتْ﴾: هل يقدر أحد أن يَخلُق مثل الإبل، أو يرفع مثل السماء، أو ينصب مثل الجبال، أو يسطح مثل الأرض غيري؟!{1}. (ز)٨٢٨٧٣- عن قتادة بن دعامة -من طريق سعيد- قال: ﴿وإلى الأَرْضِ كَيْفَ سُطِحَتْ﴾ أي: بُسطتْ. يقول: الذي خَلَق هذا قادر على أن يَخلُق في الجنة ما أراد{2}. (١٥/٣٨٨)٨٢٨٧٤- قال مقاتل بن سليمان: ﴿وإلى الأَرْضِ كَيْفَ سُطِحَتْ﴾، يعني: كيف بُسطتْ مِن تحت الكعبة مسيرة خمسمائة عام{3}. (ز)"
  88,21,"﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾ - قراءات٨٢٨٧٥- عن جابر، قال: قرأ رسول الله ﷺ: ﴿لَسْتَ عَلَيْهِم بِمُصَيْطِرٍ﴾ بالصاد{1}. (١٥/٣٨٩)﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾ - تفسير الآية٨٢٨٧٦- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «أُمرتُ أنْ أقاتل الناس حتى يقولوا: لا إله إلا الله. فإذا قالوها عصموا مِنِّي دماءهم وأموالهم إلا بحقِّها، وحسابهم على الله». ثم قرأ: ﴿فَذَكِّرْ إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾{2}. (١٥/٣٨٩)٨٢٨٧٧- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، يقول: بجبّار، فاعفُ عنهم واصفح{3}. (١٥/٣٨٩)٨٢٨٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، قال: جبّار{4}. (١٥/٣٩٠)٨٢٨٧٩- عن الضَّحّاك بن مُزاحِم، ﴿بِمُصَيْطِرٍ﴾، قال: بمُسلَّط{5}. (١٥/٣٩٠)٨٢٨٨٠- عن قتادة بن دعامة -من طريق معمر- ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، قال: بقاهر{6}. (١٥/٣٩٠)٨٢٨٨١- عن قتادة بن دعامة -من طريق سعيد- ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، قال: كِلْ عبادي إلَيَّ{7}. (١٥/٣٩٠)٨٢٨٨٢- قال مقاتل بن سليمان: ﴿فَذَكِّرْ﴾ أهل مكة، يا محمد ﴿إنَّما أنْتَ مُذَكِّرٌ﴾ كالذين من قبلك، ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾ يقول: لستَ عليهم بملِك{8}. (ز)٨٢٨٨٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، قال: لستَ عليهم بمُسلَّط أن تُكرههم على الإيمان{9}. (ز)﴿فَذَكِّرۡ إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١ لَّسۡتَ عَلَیۡهِم بِمُصَیۡطِرٍ ۝٢٢﴾ - النسخ في الآية٨٢٨٨٤- عن عبد الله بن عباس، ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، قال: نسَخ ذلك، فقال: ﴿اقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾ [التوبة:٥]{10}. (١٥/٣٩٠)٨٢٨٨٥- قال مقاتل بن سليمان: ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، يقول: لستَ عليهم بملِك، ثم نَسَخَتْها آيةُ السيف في براءة{8}. (ز)٨٢٨٨٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿إنَّما أنْتَ مُذَكِّرٌ لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، قال: لستَ عليهم بمُسلَّط أن تُكرههم على الإيمان. قال: ثم جاء بعد هذا: ﴿جاهِدِ الكُفّارَ والمُنافِقِينَ واغْلُظْ عَلَيْهِمْ﴾ [التوبة:٧٣، والتحريم:٩]، وقال: ﴿واقْعُدُوا لَهُمْ كُلَّ مَرْصَدٍ﴾ وارصدوهم لا يخرجوا في البلاد، ﴿فَإنْ تابُوا وأَقامُوا الصَّلاةَ وآتَوُا الزَّكاةَ فَخَلُّوا سَبِيلَهُمْ إنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾ [التوبة:٥]. قال: فنَسَخَتْ ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾. قال: جاء اقتله أو يُسلِم. قال: والتذكرة كما هي لم تُنسخ. وقرأ: ﴿وذَكِّرْ فَإنَّ الذِّكْرى تَنْفَعُ المُؤْمِنِينَ﴾ [الذاريات:٥٥]{9}٧١٤٩. (ز)٧١٤٩ ذكر ابنُ عطية (٨/٦٠٢) اختلاف المفسرين في قوله تعالى: ﴿إلا مَن تَوَلّى وكَفَرَ﴾ على قولين: الأول: «أنّ الاستثناء متصل، والمعنى: إلا مَن تولى وكفر فأنت مُسيطِرٌ عليه». ثم وجَّهه بقوله: «فالآية -على هذا- لا نسخ فيها». الثاني: «أن الاستثناء منفصل، والمعنى: ﴿لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ﴾، وتمَّ الكلام، وهي آية موادعة منسوخة بالسيف، ثم قال تعالى: ﴿إلّا مَن تَوَلّى وكَفَرَ * فَيُعَذِّبُهُ﴾». ثم رجَّحه مستندًا إلى أحوال النزول، فقال: «وهذا هو القول الصحيح؛ لأن السورة مكّيّة، والقتال إنما نزل بالمدينة»."
  88,22,"88:21"
  88,23,"﴿إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ۝٢٣ فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾ - قراءات٨٢٨٨٧- في قراءة عبد الله بن مسعود: (فَإنَّهُ يُعَذِّبُهُ اللهُ العَذابَ الأَكْبَرَ){1}. (ز)﴿إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ۝٢٣ فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾ - تفسير الآية٨٢٨٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿إلّا مَن تَوَلّى وكَفَرَ﴾، قال: حسابه على الله{2}. (١٥/٣٩٠)٨٢٨٨٩- قال مقاتل بن سليمان: ﴿إلّا مَن تَوَلّى﴾ يعني: أعرَض، ﴿وكَفَرَ﴾ بالإيمان، ﴿فَيُعَذِّبُهُ اللَّهُ﴾ في الآخرة ﴿العَذابَ الأَكْبَرَ﴾ وإنما سمّاه الله الأكبر لأنّ الله كان أوعدهم القتل والجوع في الدنيا، فقال الأكبر؛ لأنه أكبر من الجوع والقتل، وهو عذاب جهنم{3}. (ز)"
  88,24,"88:23"
  88,25,"﴿إِنَّ إِلَیۡنَاۤ إِیَابَهُمۡ ۝٢٥ ثُمَّ إِنَّ عَلَیۡنَا حِسَابَهُم ۝٢٦﴾ - تفسير٨٢٨٩٠- عن عبد الله بن عباس -من طريق ابن جُرَيْج، عن عطاء الخُراسانيّ- في قوله: ﴿إنَّ إلَيْنا إيابَهُمْ﴾، قال: مرجعهم{1}. (١٥/٣٩٠)٨٢٨٩١- عن عطاء، مثله{2}. (١٥/٣٩١)٨٢٨٩٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: ﴿إنَّ إلَيْنا إيابَهُمْ﴾. قال: الإياب: المرجع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت عَبيد بن الأَبْرص يقول:وكلّ ذي غَيْبة يؤوب وغائب الموت لا يؤوبوقال الآخر:فأَلقتْ عصاها واستقرّ بها النَّوى كما قرّ عَينًا بالإياب المسافر{3}. (١٥/٣٩١)٨٢٨٩٣- عن قتادة بن دعامة -من طريق سعيد- ﴿إنَّ إلَيْنا إيابَهُمْ ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾، قال: إلى الله الإياب، وعلى الله الحساب{4}. (١٥/٣٩١)٨٢٨٩٤- عن إسماعيل السُّدِّيّ، ﴿إنَّ إلَيْنا إيابَهُمْ﴾، قال: مُنقَلَبهم{5}. (١٥/٣٩١)٨٢٨٩٥- قال إسماعيل السُّدِّيّ: ﴿ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾، يعني: جزاءهم{6}. (ز)٨٢٨٩٦- قال مقاتل بن سليمان: ﴿إنَّ إلَيْنا إيابَهُمْ﴾ يعني: مصيرهم، ﴿ثُمَّ إنَّ عَلَيْنا حِسابَهُمْ﴾ يعني: جزاءهم على الله هَيِّن{7}. (ز)"
  88,26,"88:25"
