tafsir[30]{c,v,t}:
  67,1,"مقدمة السورة٧٧٧٧٧- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: أُنزلت ﴿تبارك﴾ المُلك في أهل مكة، إلا ثلاث آيات{1}. (١٤/٥٩٩)٧٧٧٧٨- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها ﴿تبارك﴾ المُلك، وذكر أنها بعد الطُّور{2}. (ز)٧٧٧٧٩- عن عبد الله بن عباس -من طريق خُصَيف عن مجاهد-: مكّيّة، وسمّاها: ﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾{3}. (١٤/٥٩٩)٧٧٧٨٠- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء عن مجاهد- قال: مكّيّة{4}. (١٤/٥٩٩)٧٧٧٨١- عن عبد الله بن الزبير، مثله{5}. (١٤/٥٩٩)٧٧٧٨٢- عن عكرمة مولى ابن عباس= (ز)٧٧٧٨٣- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{6}. (ز)٧٧٧٨٤- عن قتادة بن دعامة -من طرق-: مكّيّة{7}. (ز)٧٧٧٨٥- عن محمد بن شهاب الزُّهريّ: مكّيّة، ونزلت بعد سورة الطُّور{8}. (ز)٧٧٧٨٦- عن علي بن أبي طلحة: مكّيّة{9}. (ز)٧٧٧٨٧- قال مقاتل بن سليمان: سورة المُلك مكّيّة، عددها ثلاثون آية{10}٦٦٩٦. (ز)٦٦٩٦ قال ابن عطية (٨/٣٥٠): «وهي مكّيّة بإجماع».٧٧٧٨٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «إنّ سورةً مِن كتاب الله ما هي إلا ثلاثون آية شَفَعتْ لرجل حتى غُفر له؛ ﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾»{11}. (١٤/٥٩٩)٧٧٧٨٩- عن عبد الله بن عباس، قال: ضَرب بعض أصحابُ النبيِّ ﷺ خِباءه على قبر، وهو لا يَحسَب أنه قبر، فإذا فيه إنسان يقرأ سورة المُلك حتى خَتمَها، فأتى النبيَّ ﷺ، فأَخبَره، فقال رسول الله ﷺ: «هي المانعة، هي المُنجِية؛ تُنجِيه من عذاب القبر»{12}. (١٤/٦٠٠)٧٧٧٩٠- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «إنِّي لَأجد في كتاب الله سورة هي ثلاثون آية، مَن قرأها عند نومه كُتب له منها ثلاثون حسنة، ومُحِي عنه ثلاثون سيئة، ورُفع له ثلاثون درجة، وبَعث الله إليه مَلكًا مِن الملائكة لِيَبسُط عليه جَناحه، ويَحفظه مِن كلّ سوء حتى يَستيقظ، وهي المُجادِلة؛ تُجادل عن صاحبها في القبر، وهي: ﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾»{13}. (١٤/٦٠٥)٧٧٧٩١- عن عبد الله بن عباس، أنه قال لرجل: ألا أُتْحِفُك بحديث تَفرح به؟ قال: بلى. قال: اقرأ: ﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾، وعلِّمها أهلك وجميع ولدك وصبيان بيتك وجيرانك؛ فإنها المُنجِية والمُجادِلة يوم القيامة عند ربها لقارئها، وتَطلب له أن تُنجِيه من عذاب النار، ويَنجو بها صاحبها من عذاب القبر. قال: قال رسول الله ﷺ: «لودِدتُ أنها في قلب كلِّ إنسان مِن أُمّتي»{14}. (١٤/٦٠١)٧٧٧٩٢- عن أنس مرفوعًا، قال: «يُبعث رجل يوم القيامة لم يَترك شيئًا من المعاصي إلا رَكِبها، إلا أنه كان يُوَحِّد الله، ولم يكن يقرأ من القرآن إلا سورة واحدة، فيُؤمر به إلى النار، فطار مِن جوفه شيء كالشّهاب، فقالت: اللهم، إنِّي مما أنزَلَتْ على نبيّك ﷺ، وكان عبدك هذا يقرؤني. فما زالت تَشفع حتى أدخلتْه الجنة، وهي المُنجِية: ﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾»{15}. (١٤/٦٠٤)٧٧٧٩٣- عن أنس، قال: قال رسول الله ﷺ: «إنّ رجلًا مِمّن كان قبلكم مات وليس معه شيء من كتاب الله إلا ﴿تَبارَكَ﴾، فلما وُضع في حُفرته أتاه المَلَك، فثارت السورة في وجهه، فقال لها: إنكِ من كتاب الله، وأنا أكره مساءتكِ، وإني لا أملك لكِ ولا له ولا لنفسي ضَرًّا ولا نَفعًا، فإنْ أردتِ هذا به فانطلِقي إلى الرّبّ، فاشفعي له. فانطلَقتْ إلى الرّبّ، فتقول: يا ربِّ، إنّ فلانًا عَمد إلَيّ مِن بين كتابك، فتعلَّمني، وتلاني، أفتحرقه أنتَ بالنار وتُعذِّبه وأنا في جوفه؟! فإن كنتَ فاعلًا به فامحُني مِن كتابكَ. فيقول: ألا أراكِ غضبتِ. فتقول: وحُقَّ لي أنْ أغضب. فيقول: اذهبي، فقد وهبتُه لكِ، وشَفّعتُكِ فيه. فتجيء، فَتَزبُر{16} المَلك، فيَخرج كاسِفَ البال{17}، لم يحْلَ{18} منه بشيء، فتجيء، فتضع فاها على فيه، فتقول: مرحبًا بهذا الفم فرُبّما تلاني، ومرحبًا بهذا الصدر فرُبّما وعاني، ومرحبًا بهاتين القدمين فرُبّما قامتا بي. وتُؤنسه في قبره مخافة الوحْشة عليه». فلمّا حَدّث رسول الله ﷺ هذا الحديث لم يبقَ صغير ولا كبير ولا حُرّ ولا عبد إلا تعلَّمها، وسمّاها رسول الله ﷺ المُنجِية{19}. (١٤/٦٠١)٧٧٧٩٤- عن رافع بن خُدَيج، وأبي هريرة، أنهما سمعا رسول الله ﷺ يقول: «أُنزِلَتْ عليّ سورة تبارك -وهي ثلاثون آية- جملة واحدة». وقال: «هي المانعة في القبور، وإنّ قراءة ﴿قُلْ هُوَ اللَّهُ أحَدٌ﴾ تَعدِل في الصلاة قراءة ثُلث القرآن، وإنّ قراءة ﴿قُلْ يا أيُّها الكافِرُونَ﴾ في الصلاة تَعدِل ربع القرآن، وإنّ قراءة ﴿إذا زُلْزِلَتِ﴾ في صلاة تَعدِل نصف القرآن»{5}. (١٤/٦٠٠)٧٧٧٩٥- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «سورة تبارك هي المانعة من عذاب القبر»{21}. (١٤/٦٠٠)٧٧٧٩٦- عن عبد العزيز، عن أبيه، قال: قال رسول الله ﷺ: «دخل رجل الجنة بشفاعة سورة من القرآن، وما هي إلا ثلاثون آية: ﴿تَبارَكَ الَّذِي بِيَدِهِ المُلْكُ﴾»{5}. (١٤/٦٠٦)٧٧٧٩٧- عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيْش- قال: يُؤتى الرجل في قبره، فيُؤتى من قِبَل رجليه، فتقول رِجلاه: ليس لكم على ما قِبَلي سبيل؛ قد كان يقوم علينا بسورة المُلك. ثم يُؤتى من قِبَل صدره، فيقول: ليس لكم على ما قِبَلي سبيل؛ قد كان وعى فيّ سورة الملك. ثم يُؤتى من قِبَل رأسه، فيقول: ليس لكم على ما قِبَلي سبيل؛ قد كان يقرأ بي سورة المُلك. فهي المانعة تمنع من عذاب القبر، وهي في التوراة سورة المُلك، مَن قرأها في ليلة فقد أكثر وأطيَب{23}. (١٤/٦٠٣)٧٧٧٩٨- عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيْش- قال: كُنّا نُسمِّيها في عهد رسول الله ﷺ: المانعة، وإنها لفي كتاب الله: سورة المُلك. من قرأها في ليلة فقد أكثر وأطيَب{24}. (١٤/٦٠٣)٧٧٧٩٩- عن عبد الله بن مسعود -من طريق مُرّة- قال: إنّ الميت إذا مات أُوقدت حوله نيران، فتأكل كلّ نار ما يليها إن لم يكن له عمل يَحوُل بينه وبينها، وإنّ رجلًا مات ولم يكن يقرأ من القرآن إلا سورة ثلاثين آية، فأَتتْه من قِبَل رأسه، فقالتْ: إنه كان يقرأ بي. فأَتتْه من قِبَل رجليه، فقالتْ: إنه كان يقوم بي. فأتته من قِبَل جوفه، فقالتْ: إنه كان وعاني. فأَنجتْه. قال: فنظرتُ أنا ومَسروق في المصحف، فلم نجد سورة ثلاثين آية إلا ﴿تبارك﴾{25}. (١٤/٦٠٣)٧٧٨٠٠- عن مُرّة مثله، مرسلًا{26}. (١٤/٦٠٤)٧٧٨٠١- عن مُرّة الهَمذاني، قال: أُتِيَ رجل من جوانب قبره، فجَعلتْ سورةٌ مِن القرآن ثلاثون آية تُجادِل عنه، حتى مَنعتْه من عذاب القبر، فنظرتُ أنا ومَسروق فلم نجدها إلا ﴿تبارك﴾{27}. (١٤/٦٠٥)٧٧٨٠٢- عن عمرو بن مُرّة، قال: كان يقال: إنّ من القرآن سورة تُجادِل عن صاحبها في القبر تكون ثلاثين آية. فنَظروا فوجدوها ﴿تبارك﴾{28}. (١٤/٦٠٤)﴿تَبَـٰرَكَ ٱلَّذِی بِیَدِهِ ٱلۡمُلۡكُ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝١﴾ - تفسير٧٧٨٠٣- قال مقاتل بن سليمان: ﴿تَبارَكَ﴾ يعني: افتَعل البركة، ﴿وهُوَ عَلى كُلِّ شَيْءٍ﴾ أراده ﴿قَدِيرٌ﴾{29}. (ز)"
  67,2,"﴿ٱلَّذِی خَلَقَ ٱلۡمَوۡتَ وَٱلۡحَیَوٰةَ﴾ - تفسير٧٧٨٠٤- عن قتادة، في قوله: ﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾، قال: كان رسول الله ﷺ يقول: «إنّ الله أذَلّ بني آدم بالموت، وجعل الدنيا دار حياة ثم دار موت، وجعل الآخرة دار جزاء ثم دار بقاء»{1}. (١٤/٦٠٧)٧٧٨٠٥- عن عبد الله بن عباس: ﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾، يريد: الموت في الدنيا، والحياة في الآخرة{2}. (ز)٧٧٨٠٦- قال عبد الله بن عباس: خلق الله الموت على صورة كَبشٍ أمْلح، لا يمُرّ بشيء ولا يجد رِيحه شيء إلا مات، وخَلق الحياة على صورة فرسٍ بلقاء أنثى، وهي التي كان جبريل والأنبياء يَركبونها، لا تمُرّ بشيء ولا يجد ريحها شيء إلا حَيي، وهي التي أخذ السّامريُّ قبضة مِن أثرها فألقى على العجل فحَيي{3}. (ز)٧٧٨٠٧- عن الحسن البصري= (ز)٧٧٨٠٨- وقتادة بن دعامة -من طريق معمر-: أنه يُجاء بالموت يوم القيامة في صورة كبش، فيقال: يا أهل الجنة، هل تعرفون هذا؟ فيقولون: نعم. ثم يُقال لأهل النار: هل تعرفون هذا؟ فيقولون: يا ربّ، هذا الموت. فَيُسْحَطُ سَحَطًا؛ يعني: يُذبح ذبحًا، ثم يقال: خلود لا موت فيه. قال معمر: سمعتُ إنسانًا يقول: فما أتى على أهل النار يومٌ قطّ أشدّ حزنًا منه، وما أتى على أهل الجنة يوم قطّ أشد سرورًا منه{4}. (ز)٧٧٨٠٩- عن وهْب بن مُنَبِّه -من طريق عبد الصمد- قال: خلَق الله الموتَ كبشًا أملح مُستترًا بسواد وبياض، له أربعة أجنحة؛ جَناح تحت العرش، وجَناح في الثَّرى، وجَناح في المشرق، وجَناح في المغرب{5}. (١٤/٦٠٧)٧٧٨١٠- عن قتادة بن دعامة، في قوله: ﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾، قال: الحياة فرس جبريل ﵇، والموت كبش أملح{6}. (١٤/٦٠٧)٧٧٨١١- قال مقاتل بن سليمان: ﴿الَّذِي خَلَقَ المَوْتَ والحَياةَ﴾ فيُميت الأحياء، ويُحيي الموتى من نُطفة، ثم عَلقة، ثم يَنفخ فيه الروح، فيصير حيًّا{7}. (ز)﴿لِیَبۡلُوَكُمۡ أَیُّكُمۡ أَحۡسَنُ عَمَلࣰاۚ وَهُوَ ٱلۡعَزِیزُ ٱلۡغَفُورُ ۝٢﴾ - تفسير٧٧٨١٢- عن أبي قتادة، قال: قلتُ: يا رسول الله، أرأيتَ قول الله تعالى: ﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾ ما عني به؟ قال: «يقول: أيكم أحسن عقلًا»{8}. (ز)٧٧٨١٣- عن ابن عمر مرفوعًا: «﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾: «أحسن عقلًا، وأورع عن محارم الله، وأسرع في طاعة الله»{9}. (ز)٧٧٨١٤- عن عبد الله بن عباس -من طريق الضَّحّاك بن مُزاحِم- قال: ﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾ أيّكم أتمُّ للفريضة{7}. (ز)٧٧٨١٥- قال الحسن البصري: ﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾ أيّكم أزهد في الدنيا وأَتْرك لها{11}. (ز)٧٧٨١٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: ﴿أيُّكُمْ أحْسَنُ عَمَلًا﴾، قال: أيّكم أكثر للموت ذِكرًا، وله أحسن استعدادًا، ومنه أشد خوفًا وحذرًا{12}. (١٤/٦٠٦)٧٧٨١٧- قال مقاتل بن سليمان: ﴿لِيَبْلُوَكُمْ﴾ يعني: ليختبركم بها، ﴿وهُوَ العَزِيزُ﴾ في مُلكه، في نِقمته لمن عصاه، ﴿الغَفُورُ﴾ لذنوب المؤمنين{7}. (ز)٧٧٨١٨- عن فُضَيل بن عِياض -من طريق إبراهيم بن الأشعث- ﴿لِيَبْلُوَكُمْ أيُّكُمْ أحْسَنُ عَمَلًا﴾، قال: أخلَصه وأَصوَبه، قال: إنّ العمل إذا كان خالصًا ولم يكن صوابًا لم يُقبل، وإذا كان صوابًا ولم يكن خالصًا لم يُقبل، حتى يكون خالصًا صوابًا، والخالص: إذا كان لله، والصواب: إذا كان على السُّنّة{14}. (ز)"
  67,3,"﴿ٱلَّذِی خَلَقَ سَبۡعَ سَمَـٰوَ ٰ⁠تࣲ طِبَاقࣰاۖ﴾ - تفسير٧٧٨١٩- عن عبد الله بن عباس، في قوله: ﴿سَبْعَ سَماواتٍ طِباقًا﴾، قال: بعضها فوق بعض{1}. (١٤/٦٠٧)٧٧٨٢٠- عن عبد الملك ابن جُرَيْج، مثله{2}. (١٤/٦٠٧)٧٧٨٢١- قال مقاتل بن سليمان: ﴿الَّذِي خَلَقَ سَبْعَ سَماواتٍ﴾ في يومين ﴿طِباقًا﴾ بعضها فوق بعض، بين كلّ سماءين مسيرة خمسمائة سنة، وغِلظ كلّ سماء مسيرة خمسمائة سنة{3}٦٦٩٧. (ز)٦٦٩٧ ذكر ابنُ كثير (١٤/٧١) في قوله: ﴿خلق سبع سموات طباقا﴾ قولين: الأول: أنهن متواصلات بمعنى أنهن علويات بعضهنّ فوق بعض. الثاني: أنهن متفاصلات بينهن خلاء.ورجّح -مستندًا إلى السنة- الثاني بقوله: «أصحهما الثاني، كما دل على ذلك حديث الإسراء وغيره».﴿مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ﴾ - قراءات٧٧٨٢٢- عن عبد الله بن مسعود أنه قرأ: ‹مِن تَفَوُّتٍ›{4}. (١٤/٦٠٨)٧٧٨٢٣- عن عَلقمة بن قيس أنه كان يقرأ: ‹ما تَرى فِي خَلْقِ الرَّحْمَنِ مِن تَفَوُّتٍ›{5}٦٦٩٨. (١٤/٦٠٨)٦٦٩٨ ذكر ابنُ جرير (٢٣/١٢٠) القراءتين، ثم علّق قائلًا: «والصواب من القول في ذلك أنهما قراءتان معروفتان بمعنى واحد، كما قيل: ولا تصاعر؛ ولا تصعر، وتعهدتُ فلانًا؛ وتعاهدتُه، وتظهرت؛ وتظاهرت، وكذلك التفاوت والتفوت».وعلّق عليهما ابنُ عطية (٨/٣٥٢) بقوله: «وهما بمعنى واحد».﴿مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ﴾ - تفسير الآية٧٧٨٢٤- عن عبد الله بن عباس، في قوله: ﴿ما تَرى فِي خَلْقِ الرَّحْمَنِ مِن تَفاوُتٍ﴾ قال: ما يَفُوت بعضه بعضًا. تَفاوتٌ: تَفرّقٌ{6}. (١٤/٦٠٧)٧٧٨٢٥- عن عبد الله بن عباس، في قوله: ﴿مِن تَفاوُتٍ﴾، قال: تَشقُّقٌ{7}. (١٤/٦٠٨)٧٧٨٢٦- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿مِن تَفاوُتٍ﴾، قال: من اختلاف{8}٦٦٩٩. (١٤/٦٠٨)٦٦٩٩ لم يذكر ابنُ جرير (٢٣/١١٩) غير قول قتادة.٧٧٨٢٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله تعالى: ﴿ما ترى في خلق الرحمن من تفاوت﴾، قال: يقال: لا يَفُوت بعضه بعضًا{9}. (ز)٧٧٨٢٨- قال مقاتل بن سليمان: ﴿ما تَرى فِي خَلْقِ الرَّحْمنِ مِن تَفاوُتٍ﴾، يقول: ما ترى ابن آدم في خَلْق السموات من عيب{3}٦٧٠٠. (ز)٦٧٠٠ أفاد قول مقاتل أنّ قوله تعالى: ﴿في خلق الرحمن﴾ مراد به السموات، وقد ذكر ذلك ابنُ عطية (٨/٣٥٢) وزاد قولًا آخر، فقال: «وقال آخرون: ﴿في خلق الرحمن﴾ مَعنيّ به: جميع ما في خَلْق الله تعالى من الأشياء، فإنها لا تَفاوت فيها ولا فُطور، جارية على غير إتقان، ومتى كانت فُطور لا تُفسد الشيء المخلوق من حيث هو ذلك الشيء، بل هي إتقان فيه، فليست تلك المرادة في الآية، وقال مُنذر بن سعيد: أمَر الله تعالى بالنظر إلى السماء وخَلْقها، ثم أمر بالتكرير في النظر، وكذلك جميع المخلوقات متى نظرها ناظر ليرى فيها خللًا أو نقصًا، فإنّ بصره يَنقلب خاسئًا حسيرًا».﴿فَٱرۡجِعِ ٱلۡبَصَرَ هَلۡ تَرَىٰ مِن فُطُورࣲ ۝٣﴾ - تفسير٧٧٨٢٩- عن عبد الله بن عباس، في قوله: ﴿هَلْ تَرى مِن فُطُورٍ﴾، قال: شُقوق{7}. (١٤/٦٠٨)٧٧٨٣٠- عن عبد الله بن عباس، في قوله: ﴿مِن فُطُورٍ﴾، قال: تَشقُّقٌ أو خَلَل{2}. (١٤/٦٠٩)٧٧٨٣١- عن عبد الله بن عباس -من طريق العَوفيّ- قال: ﴿هَلْ تَرى مِن فُطُورٍ﴾، الفطور: الوُهِيّ{13}. (١٤/٦٠٩)٧٧٨٣٢- قال الضَّحّاك بن مُزاحِم: ﴿هَلْ تَرى مِن فُطُورٍ﴾ اختلاف وشُطور{14}. (ز)٧٧٨٣٣- قال عطية بن سعد العَوفيّ: ﴿هَلْ تَرى مِن فُطُورٍ﴾ عَيب{14}. (ز)٧٧٨٣٤- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿مِن فُطُورٍ﴾، قال: مِن خَلَل{16}. (١٤/٦٠٨)٧٧٨٣٥- قال محمد بن كعب القُرَظيّ: ﴿هَلْ تَرى مِن فُطُورٍ﴾ فُروج{14}. (ز)٧٧٨٣٦- عن إسماعيل السُّدِّيّ، في قوله: ﴿مِن فُطُورٍ﴾، قال: مِن خَلَل{2}. (١٤/٦٠٩)٧٧٨٣٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- قوله ﷿: ﴿هل ترى من فطور﴾، قال: يقال: هل تَرى من تَشقُّق أو خَلل{9}. (ز)٧٧٨٣٨- قال مقاتل بن سليمان: ﴿فارْجِعِ البَصَرَ﴾ يعني: أعِدِ البصرَ ثانية إلى السماوات، ﴿هَلْ تَرى﴾ ابن آدم في السموات ﴿مِن فُطُورٍ﴾ يعني: مِن فُروج{3}. (ز)٧٧٨٣٩- عن سفيان [الثوري] -من طريق مهران- ﴿هَلْ تَرى مِن فُطُورٍ﴾، قال: مِن شُقوق{21}. (ز)"
  67,4,"﴿ثُمَّ ٱرۡجِعِ ٱلۡبَصَرَ كَرَّتَیۡنِ﴾ - تفسير٧٧٨٤٠- عن عبد الله بن عباس -من طريق العَوفيّ- ﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾، يقول: هل تَرى في السماء مِن خَلَل{1}. (ز)٧٧٨٤١- قال عبد الله بن عباس: ﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾ مَرّة بعد مَرّة{2}. (ز)٧٧٨٤٢- قال مقاتل بن سليمان: ﴿ثُمَّ ارْجِعِ البَصَرَ كَرَّتَيْنِ﴾، يقول: أعِدِ البصرَ الثانية{3}. (ز)﴿یَنقَلِبۡ إِلَیۡكَ ٱلۡبَصَرُ خَاسِئࣰا﴾ - تفسير٧٧٨٤٣- عن عبد الله بن عباس، في قوله: ﴿يَنْقَلِبْ إلَيْكَ﴾، قال: يَرجع إليك{4}. (١٤/٦٠٩)٧٧٨٤٤- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿خاسِئًا﴾، قال: ذليلًا{5}. (١٤/٦٠٨)٧٧٨٤٥- عن عبد الله بن عباس، في قوله: ﴿خاسِئًا﴾، قال: صاغرًا{4}. (١٤/٦٠٩)٧٧٨٤٦- عن قتادة بن دعامة -من طريق معمر- ﴿خاسِئًا﴾، قال: صاغرًا{7}. (١٤/٦٠٨)٧٧٨٤٧- عن قتادة بن دعامة -من طريق سعيد- قوله: ﴿يَنْقَلِبْ إلَيْكَ البَصَرُ خاسِئًا﴾ أي: حاسرًا{8}. (ز)٧٧٨٤٨- قال مقاتل بن سليمان: ﴿يَنْقَلِبْ﴾ يعني: يَرجع ﴿إلَيْكَ﴾ ابن آدم ﴿البَصَرُ خاسِئًا﴾ يعني: إذا اشتدّ البصرُ يقع فيه الماء خاسئًا، يعني: صاغرًا{3}. (ز)٧٧٨٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: ﴿يَنْقَلِبْ إلَيْكَ البَصَرُ خاسِئًا﴾ الخاسئ، والخاسر واحد؛ حسُر طرْفه أن يرى فيها فَطْرًا، فرجع وهو حسير قبل أن يَرى فيها فَطْرًا. قال: فإذا جاء يوم القيامة انفطَرتْ، ثم انشقّتْ، ثم جاء أمر أكبر من ذلك؛ انكَشطتْ{8}. (ز)﴿وَهُوَ حَسِیرࣱ ۝٤﴾ - تفسير٧٧٨٥٠- عن عبد الله بن عباس، في قوله: ﴿وهُوَ حَسِيرٌ﴾، قال: كَلِيل{11}. (١٤/٦٠٨)٧٧٨٥١- عن عبد الله بن عباس، في قوله: ﴿وهُوَ حَسِيرٌ﴾، قال: مُعْيٍ، ولا يَرى شيئًا{4}. (١٤/٦٠٩)٧٧٨٥٢- عن عبد الله بن عباس -من طريق العَوفيّ-: ﴿وهُوَ حَسِيرٌ﴾ بسواد الليل{1}. (ز)٧٧٨٥٣- عن عبد الله بن عباس، ﴿وهُوَ حَسِيرٌ﴾، قال: متوجع{14}. (١٤/٦٠٩)٧٧٨٥٤- عن عبد الله بن عباس -من طريق علي- ﴿وهُوَ حَسِيرٌ﴾، قال: مُرجفٌ{1}. (ز)٧٧٨٥٥- عن قتادة بن دعامة -من طريق معمر- ﴿وهُوَ حَسِيرٌ﴾ قال: مُعْيٍ لا يَرى في خلْق الرحمن تَفاوتًا ولا خَللًا{16}. (١٤/٦٠٨)٧٧٨٥٦- عن محمد بن السّائِب الكلبي -من طريق معمر- ﴿وهُوَ حَسِيرٌ﴾، يقول: هو المُعْيى{17}. (ز)٧٧٨٥٧- قال مقاتل بن سليمان: ﴿وهُوَ حَسِيرٌ﴾ يعني: كالًّا مُنقطعًا، لا يَرى فيها عَيبًا ولا فُطورًا{18}. (ز)"
  67,5,"﴿وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ ۝٥﴾ - تفسير٧٧٨٥٨- قال مقاتل بن سليمان: ﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا﴾ لأنها أدنى السموات، وأقربها من الأرض مِن غيرها ﴿بِمَصابِيحَ﴾ وحفظًا، يعني: الكواكب، ﴿وجَعَلْناها﴾ يعني: الكواكب ﴿رُجُومًا﴾ يعني: رميًا ﴿لِلشَّياطِينِ﴾ يعني: إذا ارتَقوا إلى السماء، ﴿وأَعْتَدْنا لَهُمْ﴾ يعني: للشياطين ﴿عَذابَ السَّعِيرِ﴾ يعني: الوقود{1}٦٧٠١. (ز)٦٧٠١ قال ابنُ عطية (٨/٣٥٣): «أخبر تعالى أنه زيّن السماء الدنيا إلينا -أي: التي تلينا- بمصابيح، وهي النّجوم، فإن كانت جميع النّجوم في السماء الدنيا فهذا اللفظ عام للكواكب، وإن كان في سائر السماوات كواكب؛ فإما أن يريد كواكب سماء الدنيا فقط، وإما أن يريد الجميع على أنّ ما في غيرها لما كانت هي تشفّ عنه، ويظهر منها، فقد تزيّنتْ به بوجه ما، ومَن تكلّف القول لمواضع الكواكب وفي أي سماء هي فقوله ليس من الشريعة».﴿وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ ۝٥﴾ - آيات متعلقة بالآية٧٧٨٥٩- عن قتادة بن دعامة -من طريق سعيد- ﴿ولَقَدْ زَيَّنّا السَّماءَ الدُّنْيا بِمَصابِيحَ وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾: إنّ الله -جلّ ثناؤه- إنما خلَق هذه النّجوم لثلاث خِصال: خَلَقها زِينة للسماء الدنيا، ورُجومًا للشياطين، وعلامات يُهتدى بها؛ فمَن يَتأوّل منها غير ذلك فقد قال برأيه، وأخطأ حظّه، وأضاع نصيبه، وتَكلّف ما لا عِلم له به{2}٦٧٠٢. (ز)٦٧٠٢ قال ابنُ عطية (٨/٣٥٣-٣٥٤): «﴿وجَعَلْناها رُجُومًا لِلشَّياطِينِ﴾ معناه: وجعلنا منها، وهذا كما تقول: أكرمتُ بني فلان وصنعتُ بهم، وأنتَ إنما فعلتَ ذلك ببعضهم دون بعض، ويوجب هذا التأويل في الآية أنّ الكواكب الثابتة والبروج، وكلّ ما يُهتدى به في البر والبحر فليست برواجم، وهذا نصٌ في حديث السير». ثم ذكر قول قتادة."
  67,6,"﴿وَلِلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ عَذَابُ جَهَنَّمَۖ وَبِئۡسَ ٱلۡمَصِیرُ ۝٦﴾ - تفسير٧٧٨٦٠- قال مقاتل بن سليمان: ﴿ولِلَّذِينَ كَفَرُوا بِرَبِّهِمْ﴾ الذين كفروا بتوحيد الله، لهم في الآخرة ﴿عَذابُ جَهَنَّمَ وبِئْسَ المَصِيرُ﴾ حيث يصيرون إليها{1}. (ز)"
  67,7,"﴿إِذَاۤ أُلۡقُوا۟ فِیهَا سَمِعُوا۟ لَهَا شَهِیقࣰا﴾ - تفسير٧٧٨٦١- قال مقاتل بن سليمان: ﴿إذا أُلْقُوا فِيها﴾ يعني: في جهنم، اختطفتهم الخَزنة بالكلاليب ﴿سَمِعُوا لَها شَهِيقًا﴾ يعني: مثل نهيق الحمار{1}. (ز)٧٧٨٦٢- عن عبد الملك ابن جُرَيْج، في قوله: ﴿سَمِعُوا لَها شَهِيقًا﴾، قال: صِياحًا{2}. (١٤/٦٠٩)﴿وَهِیَ تَفُورُ ۝٧﴾ - تفسير٧٧٨٦٣- عن مجاهد بن جبر -من طريق سفيان- في قوله: ﴿وهِيَ تَفُورُ﴾، قال: تفور بهم، كما يفور الحَبُّ القليل في الماء الكثير{3}. (١٤/٦١٠)٧٧٨٦٤- قال مقاتل بن سليمان: ﴿وهِيَ تَفُورُ﴾، يعني: تغلي{1}. (ز)﴿وَهِیَ تَفُورُ ۝٧﴾ - آثار متعلقة بالآية٧٧٨٦٥- عن أبي يحيى، قال: إنّ الرجل لَيُجرّ إلى النار، فتنزوي ويَنقبض بعضها إلى بعض، فيقول لها الرحمن: ما لكِ؟ قالت: إنّه كان يستحي مني. فيقول: أرسِلوا عبدي. قال: وإنّ العبد ليُجرّ إلى النار، فيقول: يا ربّ، ما كان هذا الظنّ بك. قال: فما كان ظنّك؟ قال: كان ظني أن تَسعني رحمتكَ. فيقول: أرسِلوا عبدي. قال: وإنّ الرجل ليُجرّ إلى النار، فتَشهق إليه النار شَهيق البَغلة إلى الشّعير، ثم تَزفر زَفرة لا يبقى أحدٌ إلا خاف{5}. (١٤/٦٠٩٠)"
  67,8,"﴿تَكَادُ تَمَیَّزُ مِنَ ٱلۡغَیۡظِۖ﴾ - تفسير٧٧٨٦٦- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿تَكادُ تَمَيَّزُ﴾، قال: تَتفرّق{1}. (١٤/٦١٠)٧٧٨٦٧- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: ﴿تَكادُ تَمَيَّزُ﴾، قال: يُفارِق بعضُها بعضًا، وتَنفطر{2}. (١٤/٦١٠)٧٧٨٦٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- ﴿تَكادُ تَمَيَّزُ﴾، يقول: تَفرّق{3}. (ز)٧٧٨٦٩- قال مقاتل بن سليمان: ﴿تَكادُ تَمَيَّزُ﴾ تَفرّق جهنم عليهم ﴿مِنَ الغَيْظِ﴾ على الكفار تأخذهم{4}. (ز)٧٧٨٧٠- عن فُضَيل بن عِياض -من طريق فضيل- في قوله: ﴿تَكادُ تَمَيَّزُ مِنَ الغَيْظِ﴾، قال: تَقَطَّع{5}. (ز)٧٧٨٧١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- ﴿تَكادُ تَمَيَّزُ مِنَ الغَيْظِ﴾، قال: التَّميّز: التَّفرّق مِن الغيظ على أهل معاصي الله؛ غضبًا لله، وانتقامًا له{3}. (ز)﴿كُلَّمَاۤ أُلۡقِیَ فِیهَا فَوۡجࣱ سَأَلَهُمۡ خَزَنَتُهَاۤ أَلَمۡ یَأۡتِكُمۡ نَذِیرࣱ ۝٨﴾ - تفسير٧٧٨٧٢- قال مقاتل بن سليمان: ﴿كُلَّما أُلْقِيَ فِيها فَوْجٌ﴾ يعني: زُمرة؛ اختَطفتهم الخَزنة بالكلاليب، يعني: مشركي العرب واليهود والنصارى والمجوس وغيرهم ﴿سَأَلَهُمْ خَزَنَتُها﴾ خُزّان جهنم: ﴿ألَمْ يَأْتِكُمْ نَذِيرٌ﴾ يعني: رسول، وهو محمد ﷺ{4}. (ز)"
  67,9,"﴿قَالُوا۟ بَلَىٰ قَدۡ جَاۤءَنَا نَذِیرࣱ فَكَذَّبۡنَا وَقُلۡنَا مَا نَزَّلَ ٱللَّهُ مِن شَیۡءٍ إِنۡ أَنتُمۡ إِلَّا فِی ضَلَـٰلࣲ كَبِیرࣲ ۝٩﴾ - تفسير٧٧٨٧٣- قال مقاتل بن سليمان: ﴿قالُوا بَلى قَدْ جاءَنا نَذِيرٌ فَكَذَّبْنا﴾ بالنذير، يعني: النبي ﷺ، ﴿وقُلْنا﴾ للنبي ﷺ: ﴿ما نَزَّلَ اللَّهُ مِن شَيْءٍ﴾ يعني: ما أرسل الله من أحد، يعني: من نبي، وقالوا للرسول محمد ﷺ: ما بَعث الله من رسول. ﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ كَبِيرٍ﴾ يعني: شِقاق{1}٦٧٠٣. (ز)٦٧٠٣ ذكر ابنُ عطية (٨/٣٥٥) في قائل: ﴿إن أنتم إلا في ضلال كبير﴾ احتمالين، فقال: «وقوله تعالى: ﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ كَبِيرٍ﴾ يحتمل أن يكون من قول الملائكة للكفار حين أخبروا عن أنفسهم أنهم كَذّبوا النُّذر، ويحتمل أن يكون من كلام الكفار للنّذر»."
  67,10,"﴿وَقَالُوا۟ لَوۡ كُنَّا نَسۡمَعُ أَوۡ نَعۡقِلُ مَا كُنَّا فِیۤ أَصۡحَـٰبِ ٱلسَّعِیرِ ۝١٠﴾ - تفسير٧٧٨٧٤- عن أبي سعيد الخُدري، أنّ رسول الله ﷺ، قال: «إنّ لكل شيء دعامة، ودعامة المؤمن عقله، فبقدْر ما يَعقل يَعبُد ربه، ولَعَمري لقد ندم الكفار يوم القيامة، ﴿وقالوا لو كنا نسمع أو نعقل ما كنا في أصحاب السعير﴾»{1}. (ز)٧٧٨٧٥- قال عبد الله بن عباس: ﴿لَوْ كُنّا نَسْمَعُ﴾ الهُدى أو نعقله؛ فنعمل به{2}. (ز)٧٧٨٧٦- قال مقاتل بن سليمان: ﴿وقالُوا لَوْ كُنّا نَسْمَعُ أوْ نَعْقِلُ﴾ المواعظ{3}. (ز)"
  67,11,"﴿فَٱعۡتَرَفُوا۟ بِذَنۢبِهِمۡ فَسُحۡقࣰا لِّأَصۡحَـٰبِ ٱلسَّعِیرِ ۝١١﴾ - تفسير٧٧٨٧٧- عن عبد الله بن عباس-من طريق علي- ﴿فَسُحْقًا﴾، قال: بُعدًا{1}. (١٤/٦١١)٧٧٨٧٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: ﴿فَسُحْقًا﴾، قال: بُعدًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حسان:ألا مِن مُبلِّغ عنِّي أُبيًّا فقد أُلقيتَ في سُحق السعير؟{2}. (١٤/٦١١)٧٧٨٧٨/ب عن سعيد بن جُبَير -من طريق سَلمة بن كُهيل- في قوله: ﴿فَسُحْقًا﴾، قال: سُحْقٌ: وادٍ في جهنم{3}٦٧٠٤. (١٤/٦١١)٦٧٠٤ لم يذكر ابنُ جرير (٢٣/١٢٦) غير قول سعيد بن جُبَير.٧٧٨٧٩- قال مقاتل بن سليمان: يقول الله تعالى: ﴿فاعْتَرَفُوا بِذَنْبِهِمْ﴾ يعني: بتكذيبهم الرُّسُل ﴿فَسُحْقًا لِأَصْحابِ السَّعِيرِ﴾ يعني: الوقود{4}. (ز)"
  67,12,"﴿إِنَّ ٱلَّذِینَ یَخۡشَوۡنَ رَبَّهُم بِٱلۡغَیۡبِ لَهُم مَّغۡفِرَةࣱ وَأَجۡرࣱ كَبِیرࣱ ۝١٢﴾ - تفسير٧٧٨٨٠- عن عبد الله بن عباس، ﴿إنَّ الَّذِينَ يَخْشَوْنَ رَبَّهُمْ بِالغَيْبِ﴾، قال: أبو بكر، وعمر، وعلي، وأبو عبيدة بن الجرّاح{1}. (١٤/٦١١)٧٧٨٨١- قال مقاتل بن سليمان: ﴿إنَّ الَّذِينَ يَخْشَوْنَ رَبَّهُمْ بِالغَيْبِ﴾ ولم يَروه، فآمنوا ﴿لَهُمْ مَغْفِرَةٌ﴾ لذنوبهم، ﴿وأَجْرٌ كَبِيرٌ﴾ يعني: جزاء كبيرًا في الجنة{2}٦٧٠٥. (ز)٦٧٠٥ ذكر ابنُ عطية (٨/٣٥٦) في قوله: ﴿بالغيب﴾ احتمالين، ووجّههما، فقال: «﴿بِالغَيْبِ﴾ يحتمل معنيين: أحدهما: بالغَيْبِ الذي أُخبروا به من الحَشْر والصراط والميزان والجنة والنار، فآمَنوا بذلك، وخَشوا ربهم فيه، ونحا إلى هذا قتادة. والمعنى الثاني: أنهم يَخشَون ربهم إذا غابوا عن أعين الناس، أي: في خلواتهم، ومنه تقول العرب: فلان سالم الغيب، أي: لا يضر، فالمعنى: يعملون بحسب الخشية في صلاتهم وعباداتهم، وانفرادهم، فالاحتمال الأول: مدحٌ بالإخلاص والإيمان، والثاني: مدحٌ بالأعمال الصالحة في الخلوات، وذلك أحرى أن يعملوها علانية».٧٧٨٨٢- عن عبد الملك ابن جُرَيْج، في قوله: ﴿وأَجْرٌ كَبِيرٌ﴾، قال: الجنة{3}. (١٤/٦١١)"
  67,13,"﴿وَأَسِرُّوا۟ قَوۡلَكُمۡ أَوِ ٱجۡهَرُوا۟ بِهِۦۤۖ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝١٣﴾ - نزول الآية٧٧٨٨٣- قال عبد الله بن عباس: ﴿وأَسِرُّوا قَوْلَكُمْ﴾ نزلت في المشركين، كانوا يَنالون مِن رسول الله ﷺ، فيُخبِره جبريل ﵇ بما قالوا، فقال بعضهم لبعض: أسِرُّوا قولكم؛ كي لا يسمع إله محمد{1}. (ز)﴿وَأَسِرُّوا۟ قَوۡلَكُمۡ أَوِ ٱجۡهَرُوا۟ بِهِۦۤۖ إِنَّهُۥ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ ۝١٣﴾ - تفسير الآية٧٧٨٨٤- قال مقاتل بن سليمان: ﴿وأَسِرُّوا قَوْلَكُمْ﴾ في النبي ﷺ في القلوب، ﴿أوِ اجْهَرُوا بِهِ﴾ يعني: أو تَكلّموا به علانية. يعني به: كفار مكة؛ ﴿إنَّهُ عَلِيمٌ بِذاتِ الصُّدُورِ﴾ يعني: بما في القلوب{2}. (ز)"
  67,14,"﴿أَلَا یَعۡلَمُ مَنۡ خَلَقَ وَهُوَ ٱللَّطِیفُ ٱلۡخَبِیرُ ۝١٤﴾ - تفسير٧٧٨٨٥- قال مقاتل بن سليمان: ﴿ألا يَعْلَمُ مَن خَلَقَ﴾ يقول: أنا خلقتُ السِّرَّ في القلوب، ألا أكون عالِمًا بما أخلق من السّرّ في القلوب، ﴿وهُوَ اللَّطِيفُ الخَبِيرُ﴾ يعني: لَطف عِلْمه بما في القلوب، خبيرٌ بما فيها من السِّرِّ والوسوسة{1}. (ز)"
  67,15,"﴿هُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ ذَلُولࣰا فَٱمۡشُوا۟ فِی مَنَاكِبِهَا وَكُلُوا۟ مِن رِّزۡقِهِۦۖ وَإِلَیۡهِ ٱلنُّشُورُ ۝١٥﴾ - تفسير٧٧٨٨٦- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿مَناكِبِها﴾، قال: جبالها{1}. (١٤/٦١٢)٧٧٨٨٧- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: ﴿مَناكِبِها﴾، قال: أطرافها{2}. (١٤/٦١٢)٧٧٨٨٨- عن قتادة: أنّ بَشير بن كعب قرأ هذه الآية: ﴿فامْشُوا فِي مَناكِبِها﴾، فقال لجاريته: إن دريتِ ما مَناكبها فأنت حُرّة لوجه الله. فقالت: فإن مناكبها: جبالها. فسأل أبا الدّرداء، فقال: دعْ ما يَريبك إلى ما لا يَريبك{3}. (١٤/٦١٢)٧٧٨٨٩- قال الضَّحّاك بن مُزاحِم: ﴿مَناكِبِها﴾ آكامها{4}. (ز)٧٧٨٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿مَناكِبِها﴾، قال: أطرافها، وفِجاجها{5}٦٧٠٦. (١٤/٦١٢)٦٧٠٦ ذكر ابنُ عطية (٨/٣٥٧) قول مجاهد، وعلّق عليه قائلًا: «وهذا قول جارٍ مع اللغة؛ لأنها تنكب يَمنة ويَسرة، وينكب الماشي فيها في مناكب».٧٧٨٩١- قال مجاهد بن جبر= (ز)٧٧٨٩٢- والحسن البصري: ﴿مَناكِبِها﴾ طرقها{6}. (ز)٧٧٨٩٣- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿مَناكِبِها﴾، قال: في جبالها{7}. (ز)٧٧٨٩٤- قال محمد بن السّائِب الكلبي: ﴿مَناكِبِها﴾ أطرافها{8}. (ز)٧٧٨٩٥- قال مقاتل بن سليمان: ﴿هُوَ الَّذِي جَعَلَ لَكُمُ الأَرْضَ ذَلُولًا﴾ أثبَتها بالجبال؛ لئلا تزول بأهلها، ﴿فامْشُوا﴾ يعني: فمُرّوا ﴿فِي مَناكِبِها﴾ يعني: في نواحيها وجوانبها آمنين كيف شِئتم، ﴿وكُلُوا مِن رِزْقِهِ﴾ الحلال، ﴿وإلَيْهِ النُّشُورُ﴾ يقول: إلى الله تُبعثُون مِن قبوركم أحياء بعد الموت{9}٦٧٠٧. (ز)٦٧٠٧ في قوله: ﴿مناكبها﴾ قولان: الأول: جبالها. الثاني: نواحيها وأطرافها.وعلّق ابنُ القيم (٣/١٧٤) على القول الأول، فقال: «وحسُن التعبير بمناكبها عن طُرقها وفِجاجها لما تقدّم من وصفها بكونها ذلولًا، فالماشي عليها يطأ على مناكبها، وهو أعلى شيء فيها، ولهذا فُسّرتْ المناكب بالجبل؛ كمناكب الإنسان وهي أعاليه. قالوا: وذلك تنبيه على أنّ المشي في سُهولها أيسر».وقد رجّح ابنُ جرير (٢٣/١٢٩) القول الثاني مستندًا إلى اللغة، فقال: «وأولى القولين عندي بالصواب قول مَن قال: معنى ذلك: فامشوا في نواحيها وجوانبها، وذلك أنّ نواحيها نظير مناكب الإنسان التي هي من أطرافه».ورجّح ابنُ القيم -مستندًا إلى الدلالة العقلية- أنّ المناكب هي الأعالي، فقال: «والذي يظهر أنّ المراد بالمناكب: الأعالي. وهذا الوجه الذي يمشي عليه الحيوان هو العالي من الأرض دون الوجه المقابل له، فإن سطح الكرة أعلاها، والمشي إنما يقع في سَطحها، وحسُن التعبير عنه بالمناكب لما تقدم من وصفها بأنها ذلول»."
  67,16,"﴿ءَأَمِنتُم مَّن فِی ٱلسَّمَاۤءِ أَن یَخۡسِفَ بِكُمُ ٱلۡأَرۡضَ﴾ - تفسير٧٧٨٩٦- قال عبد الله بن عباس: ﴿أأَمِنتُمْ مَن فِي السَّماءِ﴾، أي: عذاب مَن في السماء إنْ عَصَيتموه{1}. (ز)٧٧٨٩٧- عن مجاهد بن جبر، في قوله: ﴿أأَمِنتُمْ مَن فِي السَّماءِ﴾، قال: الله تعالى{2}. (١٤/٦١٣)٧٧٨٩٨- قال مقاتل بن سليمان: ﴿أأَمِنتُمْ﴾ عقوبة ﴿مَن فِي السَّماءِ﴾ يعني: الرّبّ -تبارك وتعالى- نفسه؛ لأنه في السماء العُليا{3}. (ز)﴿فَإِذَا هِیَ تَمُورُ ۝١٦﴾ - تفسير٧٧٨٩٩- عن مجاهد بن جبر، في قوله: ﴿فَإذا هِيَ تَمُورُ﴾، قال: يمُور بعضها في بعض، واستدارتها{4}. (١٤/٦١٣)٧٧٩٠٠- قال الضَّحّاك بن مُزاحِم: ﴿فَإذا هِيَ تَمُورُ﴾ تدور بهم، وهم في قَعرها{5}. (ز)٧٧٩٠١- قال الحسن البصري: ﴿فَإذا هِيَ تَمُورُ﴾ أي: تتحرّك بأهلها{6}. (ز)٧٧٩٠٢- قال مقاتل بن سليمان: ﴿فَإذا هِيَ تَمُورُ﴾ يعني: فإذا هي تدور بكم إلى الأرض السُّفلى{3}. (ز)"
  67,17,"﴿أَمۡ أَمِنتُم مَّن فِی ٱلسَّمَاۤءِ أَن یُرۡسِلَ عَلَیۡكُمۡ حَاصِبࣰاۖ فَسَتَعۡلَمُونَ كَیۡفَ نَذِیرِ ۝١٧﴾ - تفسير٧٧٩٠٣- قال مقاتل بن سليمان: ﴿أمْ أمِنتُمْ﴾ عقوبة ﴿مَن فِي السَّماءِ﴾ يعني: الرّبّ ﷿ ﴿أنْ يُرْسِلَ عَلَيْكُمْ حاصِبًا﴾ يعني: الحجارة من السماء، كما فَعل بمن كان قبلكم مِن كفار العرب الخالية؛ قوم لوط وغيرهم، ﴿فَسَتَعْلَمُونَ﴾ يا أهل مكة عند نزول العذاب ﴿كَيْفَ نَذِيرِ﴾ يقول: كيف عذابي{1}. (ز)"
  67,18,"﴿وَلَقَدۡ كَذَّبَ ٱلَّذِینَ مِن قَبۡلِهِمۡ فَكَیۡفَ كَانَ نَكِیرِ ۝١٨﴾ - تفسير٧٧٩٠٤- قال مقاتل بن سليمان: ﴿ولَقَدْ كَذَّبَ الَّذِينَ مِن قَبْلِهِمْ﴾ يعني: قبل كفار مكة مِن الأمم الخالية؛ رُسلَهم، فعذّبناهم ﴿فَكَيْفَ كانَ نَكِيرِ﴾ يعني: تغييري وإنكاري، ألم يجدوا العذاب حقًّا، يُخوّف كفار مكة{1}. (ز)"
  67,19,"﴿أَوَلَمۡ یَرَوۡا۟ إِلَى ٱلطَّیۡرِ فَوۡقَهُمۡ صَـٰۤفَّـٰتࣲ وَیَقۡبِضۡنَۚ مَا یُمۡسِكُهُنَّ إِلَّا ٱلرَّحۡمَـٰنُۚ إِنَّهُۥ بِكُلِّ شَیۡءِۭ بَصِیرٌ ۝١٩﴾ - تفسير٧٧٩٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ﴾ قال: ﴿صافّاتٍ﴾ يَبسُطنَ أجنحتهنّ، ﴿ويَقْبِضْنَ﴾ قال: يَضربنَ بأجنحتهنّ{1}. (١٤/٦١٣)٧٧٩٠٦- عن قتادة بن دعامة -من طريق معمر- ﴿صافّاتٍ﴾، قال: الطير يَصُفّ جناحه كما رأيتَ، ثم يَقبضه{2}. (ز)٧٧٩٠٧- قال مقاتل بن سليمان: ﴿أوَلَمْ يَرَوْا إلى الطَّيْرِ فَوْقَهُمْ صافّاتٍ ويَقْبِضْنَ﴾ يعني: الأجنحة؛ حين يُردنَ أن يَقعنَ، ﴿ما يُمْسِكُهُنَّ إلّا الرَّحْمنُ﴾ عند القَبْض والبَسْط{3}. (ز)"
  67,20,"﴿أَمَّنۡ هَـٰذَا ٱلَّذِی هُوَ جُندࣱ لَّكُمۡ یَنصُرُكُم مِّن دُونِ ٱلرَّحۡمَـٰنِۚ﴾ - تفسير٧٧٩٠٨- قال عبد الله بن عباس: ﴿جُنْدٌ لَكُمْ﴾ أي: مَنعة لكم{1}. (ز)٧٧٩٠٩- قال مقاتل بن سليمان: ﴿أمَّنْ هذا الَّذِي هُوَ جُنْدٌ﴾ يعني: حزب ﴿لَكُمْ﴾ يا أهل مكة ﴿يَنْصُرُكُمْ﴾ يمنعكم ﴿مِن دُونِ الرَّحْمنِ﴾ إذا نزل بكم العذاب{2}. (ز)﴿إِنِ ٱلۡكَـٰفِرُونَ إِلَّا فِی غُرُورٍ ۝٢٠﴾ - تفسير٧٧٩١٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: ﴿إلّا فِي غُرُورٍ﴾. قال: في باطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حسان:تَمنَّتك الأماني من بعيد وقول الكفر يَرجع في غُرور؟{3}. (١٤/٦١٤)٧٧٩١١- قال مقاتل بن سليمان: ﴿إنِ الكافِرُونَ﴾ يعني: ما ﴿إلّا فِي غُرُورٍ﴾ في باطل، الذي ليس بشيء{2}. (ز)"
  67,21,"﴿أَمَّنۡ هَـٰذَا ٱلَّذِی یَرۡزُقُكُمۡ إِنۡ أَمۡسَكَ رِزۡقَهُۥۚ بَل لَّجُّوا۟ فِی عُتُوࣲّ وَنُفُورٍ ۝٢١﴾ - تفسير٧٧٩١٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: ﴿فِي عُتُوٍّ ونُفُورٍ﴾، قال: في ضلال{1}. (١٤/٦١٤)٧٧٩١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ﴿فِي عُتُوٍّ ونُفُورٍ﴾، قال: كُفور{2}. (١٤/٦١٤)٧٧٩١٤- قال مقاتل بن سليمان: ﴿أمَّنْ هذا الَّذِي يَرْزُقُكُمْ﴾ من المطر، من الآلهة غيري ﴿إنْ أمْسَكَ رِزْقَهُ﴾ عنكم، فهاتُوا المطر. يقول الله تعالى: أنا الرّزاق، ﴿بَلْ لَجُّوا فِي عُتُوٍّ﴾ يعني: تَمادَوا في الكفر، ﴿ونُفُورٍ﴾ يعني: تَباعُد من الإيمان{3}. (ز)"
  67,22,"﴿أَفَمَن یَمۡشِی مُكِبًّا عَلَىٰ وَجۡهِهِۦۤ أَهۡدَىٰۤ أَمَّن یَمۡشِی سَوِیًّا عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٢٢﴾ - تفسير٧٧٩١٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾ قال: في الضّلالة، ﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾ قال: مُهتديًا{1}. (١٤/٦١٤)٧٧٩١٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾ قال: في الضّلالة، ﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾ قال: على الحقّ المستقيم{2}. (١٤/٦١٤)٧٧٩١٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- ﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾ يعني: الكافر، ﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾ المؤمن{3}. (ز)٧٧٩١٨- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ أهدى﴾ قال: هو الكافر عمِل بمعصية الله، فحَشره الله يوم القيامة على وجهه، ﴿أمَّنْ يَمْشِي سَوِيًّا عَلى صِراطٍ مُسْتَقِيمٍ﴾ قال: المؤمن عمِل بطاعة الله، فحَشره الله على طاعته{4}. (١٤/٦١٥)٧٧٩١٩- قال مقاتل بن سليمان: ﴿أفَمَن يَمْشِي مُكِبًّا عَلى وجْهِهِ﴾ يعني: الكافر يمشي ضالًّا في الكفر أعمى القلب، يعني: أبا جهل بن هشام ﴿أهْدى أمَّنْ يَمْشِي سَوِيًّا﴾ يعني: النبي ﷺ مُؤمنًا مُهتديًا، نقيّ القلب ﴿عَلى صِراطٍ مُسْتَقِيمٍ﴾ يعني: طريق الإسلام{5}٦٧٠٨. (ز)٦٧٠٨ قال ابنُ جرير (٢٣/١٣٢): «قوله تعالى: ﴿أفمن يمشي مكبا على وجهه أهدى أمن يمشي سويا على صراط مستقيم﴾ يقول -تعالى ذِكره-: أفمن يمشي -أيها الناس- مُكبًّا على وجهه لا يُبصر ما بين يديه، وما عن يمينه وشماله ﴿أهدى﴾ أشدّ استقامة على الطريق، وأهدى له، ﴿أمن يمشي سويا﴾ مَشي بني آدم على قدميه ﴿على صراط مستقيم﴾ يقول: على طريق لا اعوجاج فيه». وذكر على ذلك أقوال السلف، ثم ذكر قول مَن قال: عُني بذلك: أنّ الكافر يحشره الله يوم القيامة على وجهه. ولم يعلّق عليه.وذكر ابنُ عطية (٨/٣٦٠-٣٦١) في نزول هذه الآية عدة أقوال، ثم وجّه معنى الآية عليها، فقال: «واخَتلف أهل التأويل في سبب قوله: ﴿أفَمَن يَمْشِي مُكِبًّا﴾ الآية، فقال جماعة مِن رواة الأسباب: نزلت مثلًا لأبي جهل بن هشام وحمزة بن عبد المطلب. وقال ابن عباس، وابن الكلبي، وغيره: نزلت مثلًا لأبي جهل بن هشام ومحمد ﷺ. وقال ابن عباس أيضًا، ومجاهد، والضَّحّاك: نزلت مثالًا للمؤمنين والكافرين على العموم. وقال قتادة: نزلت مُخبرة عن حال القيامة، وإنّ الكفار يمشُون فيها على وجوههم، والمؤمنون يمشُون على استقامة، وقيل للنبي: كيف يمشي الكافر على وجهه؟ قال: «إنّ الذي أمشاه في الدنيا على رجليه قادر على أن يُمشيه في الآخرة على وجهه». فوقف الكفار على هاتين الحالتين حينئذ، ففي الأقوال الثلاثة الأُول المشي مجاز يُتخيّل، وفي القول الرابع هو حقيقة يقع يوم القيامة»."
  67,23,"﴿قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ ۝٢٣﴾ - تفسير٧٧٩٢٠- قال مقاتل بن سليمان: ﴿قُلْ هُوَ الَّذِي أنْشَأَكُمْ﴾ يعني: خَلَقكم، ﴿وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ﴾ يعني: القلوب، ﴿قَلِيلًا ما تَشْكُرُونَ﴾ يعني بالقليل: أنهم قوم لا يَعقلون، فيشكروا ربّ هذه النعم البَيِّنة في حُسن خَلْقهم، فيُوحِّدونه{1}. (ز)﴿قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ ۝٢٣﴾ - آثار متعلقة بالآية٧٧٩٢١- عن عبد الله بن عباس قال: قال النَّبِيّ ﷺ: «مَن اشتكى ضِرسه فليَضع أصبعه عليه، وليقرأ هذه الآية: ﴿هُوَ الَّذِي أنْشَأَكُمْ وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ قَلِيلًا ما تَشْكُرُونَ﴾»{2}. (١٤/٦١٢)٧٧٩٢٢- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «مَن اشتكى ضِرسه فليَضع أصبعه عليه، وليقرأ هاتين الآيتين سبع مرات: ﴿وهُوَ الَّذِي أنْشَأَكُمْ مِن نَفْسٍ واحِدَةٍ فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ قَدْ فَصَّلْنا الآياتِ لِقَوْمٍ يَفْقَهُونَ﴾ [الأنعام:٩٨]، ﴿هُوَ الَّذِي أنْشَأَكُمْ وجَعَلَ لَكُمُ السَّمْعَ والأَبْصارَ والأَفْئِدَةَ قَلِيلًا ما تَشْكُرُونَ﴾ فإنه يَبْرأ بإذن الله تعالى»{3}. (١٤/٦١٢)"
  67,24,"﴿قُلۡ هُوَ ٱلَّذِی ذَرَأَكُمۡ فِی ٱلۡأَرۡضِ وَإِلَیۡهِ تُحۡشَرُونَ ۝٢٤﴾ - تفسير٧٧٩٢٣- قال مقاتل بن سليمان: ﴿قُلْ هُوَ الَّذِي ذَرَأَكُمْ فِي الأَرْضِ﴾ يعني: خَلَقكم في الأرض، ﴿وإلَيْهِ﴾ يعني: إلى الله ﴿تُحْشَرُونَ﴾ في الآخرة، فيَجزيكم بأعمالكم{1}. (ز)"
  67,25,"﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٢٥﴾ - تفسير٧٧٩٢٤- قال مقاتل بن سليمان: ﴿ويَقُولُونَ مَتى هذا الوَعْدُ﴾ متى هذا الذي تُوعدنا به؛ ﴿إنْ كُنْتُمْ صادِقِينَ﴾ بأنّ العذاب نازِل بنا في الدنيا{1}. (ز)"
  67,26,"﴿قُلۡ إِنَّمَا ٱلۡعِلۡمُ عِندَ ٱللَّهِ وَإِنَّمَاۤ أَنَا۠ نَذِیرࣱ مُّبِینࣱ ۝٢٦﴾ - تفسير٧٧٩٢٥- قال مقاتل بن سليمان: ﴿قُلْ﴾ لكفار مكة: ﴿إنَّما العِلْمُ﴾ يعني: عِلْم نزول العذاب بكم ببدر ﴿عِنْدَ اللَّهِ﴾ وليس بيدي، ﴿وإنَّما أنا نَذِيرٌ﴾ بالعذاب ﴿مُبِينٌ﴾{1}. (ز)"
  67,27,"﴿فَلَمَّا رَأَوۡهُ﴾ - تفسير٧٧٩٢٦- قال مجاهد بن جبر: ﴿فَلَمّا رَأَوْهُ﴾ يعني: العذاب ببدر{1}. (ز)٧٧٩٢٧- عن الحسن البصري -من طريق أبي رجاء- ﴿فَلَمّا رَأَوْهُ﴾، قال: لَمّا عايَنوه{2}. (ز)٧٧٩٢٨- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿فَلَمّا رَأَوْهُ﴾، قال: لَمّا رَأوا عذاب الله{3}. (١٤/٦١٥)٧٧٩٢٩- قال مقاتل بن سليمان: ﴿فَلَمّا رَأَوْهُ﴾ يعني: العذاب والنار في الآخرة{4}٦٧٠٩. (ز)٦٧٠٩ رجّح ابنُ تيمية (٦/٣٦٧ بتصرف) في عوْد الضمير في قوله: ﴿فلما رأوه﴾ ما جاء في قول مقاتل وغيره مِن أنه عائد على ما وُعدوا من العذاب يوم القيامة، وذكر قولًا لم يَنسبه لأحد مِن السلف أنّ الضمير عائد على الله تعالى، وانتقده مستندًا إلى السياق، فقال: «ومَن قال: إنّ الضمير عائد هنا إلى الله. فقوله ضعيف؛ فإنّ الله قال: ﴿ويقولون متى هذا الوعد إن كنتم صادقين قل إنما العلم عند الله وإنما أنا نذير مبين فلما رأوه زلفة سيئت وجوه الذين كفروا وقيل هذا الذي كنتم به تدعون﴾، فهذا يُبيّن أنّ الذي رَأوه هو الوعد، أي: الموعود به من العذاب، ألا تراه يقول: ﴿وقيل هذا الذي كنتم به تدعون﴾».﴿زُلۡفَةࣰ﴾ - تفسير٧٧٩٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿زُلْفَةً﴾، قال: قد اقترب{5}. (١٤/٦١٥)٧٧٩٣١- قال مقاتل بن سليمان: ﴿زُلْفَةً﴾ قريبًا{4}. (ز)٧٧٩٣٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: ﴿زُلْفَةً﴾ الزُّلفة: حاضرٌ، قد حضرهم عذاب الله ﷿{2}. (ز)﴿سِیۤـَٔتۡ وُجُوهُ ٱلَّذِینَ كَفَرُوا۟﴾ - تفسير٧٧٩٣٣- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾، قال: سِيئت بما رأتْ من عذاب الله وهَوانه{8}. (١٤/٦١٥)٧٧٩٣٤- قال مقاتل بن سليمان: ﴿سِيئَتْ وُجُوهُ الَّذِينَ كَفَرُوا﴾، يعني: سِيئ لذلك وجوههم{4}. (ز)﴿وَقِیلَ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَدَّعُونَ ۝٢٧﴾ - قراءات٧٧٩٣٥- عن الحسن البصري أنه قرأ: ‹وقِيلَ هَذا الَّذِي كُنتُم بِهِ تَدْعُونَ› مُخفّفة{10}. (١٤/٦١٥)٧٧٩٣٦- عن قتادة بن دعامة -من طريق أبان العطار، وسعيد بن أبي عَروبة- أنه قرأها: ‹الَّذِي كُنتُم بِهِ تَدْعُونَ› خفيفة{11}. (ز)٧٧٩٣٧- عن أبي بكر بن عيّاش، أنّ عاصمًا قرأ: ﴿تَدَّعُونَ﴾ مُثقّلة{12}٦٧١٠. (١٤/٦١٥)٦٧١٠ ذكر ابنُ جرير (٢٣/١٣٧) القراءتين، ووجّههما، فقال: «واختلفت القرّاء في قراءة ذلك، فقرأته عامة قراء الأمصار: ﴿هذا الذي كنتم به تدعون﴾ بتشديد الدال، بمعنى: تفتعلون من الدعاء. وذكر عن قتادة، والضَّحّاك أنهما قرآ ذلك: ‹تَدْعُونَ› بمعنى: تفعلون في الدنيا».ووجّههما ابنُ عطية (٨/٣٦٢-٣٦٣)، فقال: «وقرأ جمهور الناس ونافع بخلاف عنه: ﴿تدعون﴾ بفتح الدال وشدّها، على وزن: تفتعلون، أي: تتداعون أمره بينكم، وقال الحسن: يدّعون أنه لا جنة ولا نار. وقرأ أبو رجاء، والحسن، والضَّحّاك، وقتادة، وابن يَسار، وسلام: (يَدْعُونَ) بسكون الدال على معنى: يستعجلون، كقولهم: ﴿عَجِّلْ لَنا قِطَّنا﴾ [ص:١٦]، و﴿فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ﴾ [الأنفال:٣٢]، وغير ذلك».ورجّح ابن جرير -مستندًا لإجماع الحجة من القراء- قراءة التشديد، فقال: «والصواب من القراءة في ذلك ما عليه قراء الأمصار؛ لإجماع الحُجّة من القراء عليه».﴿وَقِیلَ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَدَّعُونَ ۝٢٧﴾ - تفسير الآية٧٧٩٣٨- قال الحسن البصري: ﴿الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾ تدّعون أن لا جنة ولا نار{13}. (ز)٧٧٩٣٩- عن قتادة بن دعامة -من طريق أبان العطار، وسعيد بن أبي عَروبة- أنه قرأها: (الَّذِي كُنتُم بِهِ تَدْعُونَ) خفيفة، ويقول: كانوا يَدْعُون بالعذاب. ثم قرأ: ﴿وإذ قالوا اللهم إن كان هذا هو الحق من عندك فأمطر علينا حجارة من السماء أو ائتنا بعذاب أليم﴾ [الأنفال:٣٢]{11}. (ز)٧٧٩٤٠- قال مقاتل بن سليمان: ﴿وقِيلَ﴾ لهم، يعني: قالتْ لهم الخَزنة: ﴿هَذا﴾ العذاب ﴿الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾ يعني: تَمتَرون في الدنيا{4}. (ز)٧٧٩٤١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- ﴿وقِيلَ هَذا الَّذِي كُنْتُمْ بِهِ تَدَّعُونَ﴾، قال: استعجالهم بالعذاب{11}. (ز)٧٧٩٤٢- قال أبو بكر بن عياش: تفسير ﴿تَدَّعُونَ﴾: تَستعجلون{12}. (١٤/٦١٥)"
  67,28,"﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَهۡلَكَنِیَ ٱللَّهُ وَمَن مَّعِیَ أَوۡ رَحِمَنَا فَمَن یُجِیرُ ٱلۡكَـٰفِرِینَ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٨﴾ - تفسير٧٧٩٤٣- قال مقاتل بن سليمان: ﴿قُلْ﴾ لكفار مكة، يا محمد: ﴿أرَأَيْتُمْ إنْ أهْلَكَنِيَ اللَّهُ﴾ إنْ عذَّبني الله، ﴿ومَن مَعِيَ﴾ من المؤمنين ﴿أوْ رَحِمَنا﴾ فلم يُعذّبنا، وأَنعَم علينا؛ ﴿فَمَن يُجِيرُ الكافِرِينَ﴾ فمَن يُؤمّنكم أنتم ﴿مِن عَذابٍ ألِيمٍ﴾ وجيع{1}. (ز)"
  67,29,"﴿قُلۡ هُوَ ٱلرَّحۡمَـٰنُ ءَامَنَّا بِهِۦ وَعَلَیۡهِ تَوَكَّلۡنَاۖ فَسَتَعۡلَمُونَ مَنۡ هُوَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٢٩﴾ - تفسير٧٧٩٤٤- قال مقاتل بن سليمان: ﴿قُلْ هُوَ الرَّحْمنُ﴾ الذي يفعل ذلك ﴿آمَنّا بِهِ﴾ يقول: صدَّقنا بتوحيده؛ إن شاء أهلكنا أو عذَّبنا، ﴿وعَلَيْهِ تَوَكَّلْنا﴾ يعني: بالله وثقنا، ﴿فَسَتَعْلَمُونَ﴾ عند نزول العذاب ﴿مَن هُوَ فِي ضَلالٍ مُبِينٍ﴾ يعني: باطل ليس بشيء، أنحن أم أنتم؟{1}. (ز)"
  67,30,"﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا﴾ - نزول الآية٧٧٩٤٥- عن محمد بن السّائِب الكلبي -من طريق سفيان - قال: نزلت هذه الآية: ﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ غَوْرًا﴾ في بئر زمزم، وبئر ميمون بن الحَضرميّ{1}، وكانت جاهليةً{2}٦٧١١. (١٤/٦١٦)٦٧١١ ذكر ابنُ عطية (٨/٣٦٣) ما جاء في هذا الأثر، ثم قال معلِّقًا: «ويشبه أن تكون هاتان عُظْم ماءِ مكة، وإلا فكانت فيها آبار كثيرة كخُم والجَفر وغيرهما».﴿قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا﴾ - تفسير الآية٧٧٩٤٦- عن عبد الله بن عباس، في قوله: ﴿غَوْرًا﴾، قال: داخِلًا في الأرض{3}. (١٤/٦١٦)٧٧٩٤٧- عن عبد الله بن عباس، ﴿غَوْرًا﴾، قال: يَرجع في الأرض{3}. (١٤/٦١٦)٧٧٩٤٨- عن سعيد بن جُبَير -من طريق سالم- ﴿غَوْرًا﴾: لا تَناله الدِّلاء{5}. (ز)٧٧٩٤٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- ﴿غَوْرًا﴾: ذاهِبًا{5}. (ز)٧٧٩٥٠- عن قتادة بن دعامة -من طريق سعيد- ﴿غَوْرًا﴾، قال: ذاهبًا{7}. (١٤/٦١٦)٧٧٩٥١- قال محمد بن السّائِب الكلبي= (ز)٧٧٩٥٢- ومقاتل: ﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ غَوْرًا﴾، يعني: ماء زمزم، وبئر ميمون الحضرمي، وهي بئر عادية قديمة{8}. (ز)٧٧٩٥٣- قال مقاتل بن سليمان: ﴿قُلْ أرَأَيْتُمْ إنْ أصْبَحَ ماؤُكُمْ﴾ يعني: ماء زمزم وغيره ﴿غَوْرًا﴾ يعني: غارَ في الأرض، فذَهب؛ فلم تَقدِروا عليه{9}. (ز)﴿فَمَن یَأۡتِیكُم بِمَاۤءࣲ مَّعِینِۭ ۝٣٠﴾ - تفسير٧٧٩٥٤- عن عبد الله بن عباس، في قوله: ﴿ماءٍ مَعِينٍ﴾، قال: الجاري{3}. (١٤/٦١٦)٧٧٩٥٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ﴿ماءٍ مَعِينٍ﴾، قال: عَذْب{11}. (١٤/٦١٦)٧٧٩٥٦- عن عبد الله بن عباس، ﴿ماءٍ مَعِينٍ﴾، قال: ظاهِر{12}. (١٤/٦١٦)٧٧٩٥٧- عن مجاهد بن جبر= (ز)٧٧٩٥٨- وعكرمة مولى ابن عباس -من طريق جابر-، مثله{13}. (١٤/٦١٦)٧٧٩٥٩- عن سعيد بن جُبَير -من طريق سالم- ﴿ماءٍ مَعِينٍ﴾، قال: الظّاهر{5}. (ز)٧٧٩٦٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- ﴿ماءٍ مَعِينٍ﴾: جارٍ{5}. (ز)٧٧٩٦١- قال الحسن البصري: ﴿ماءٍ مَعِينٍ﴾، المعين: الذي أصله من العيون{16}. (ز)٧٧٩٦٢- عن قتادة بن دعامة -من طريق سعيد- ﴿ماءٍ مَعِينٍ﴾، قال: الجاري{7}. (١٤/٦١٦)٧٧٩٦٣- قال مقاتل بن سليمان: ﴿فَمَن يَأْتِيكُمْ بِماءٍ مَعِينٍ﴾ ظاهر تَناله الدِّلاء{9}. (ز)"
