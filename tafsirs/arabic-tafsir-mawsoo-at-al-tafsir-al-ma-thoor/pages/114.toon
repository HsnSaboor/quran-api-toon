tafsir[6]{c,v,t}:
  114,1,"مقدمة السورة٨٥٦٩٤- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد-: مدنية{1}. (ز)٨٥٦٩٥- عن عبد الله بن عباس -من طريق خُصَيف، عن مجاهد-: مكّيّة{2}. (ز)٨٥٦٩٦- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمّى: ﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾، وأنها نزلت بعد ﴿قل أعوذ برب الفلق﴾{3}. (ز)٨٥٦٩٧- عن عبد الله بن عباس، قال: أُنزل بمكة ﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾{4}. (١٥/٨٠٦)٨٥٦٩٨- عن عبد الله بن الزُّبير، قال: أُنزل بالمدينة ﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾{4}. (١٥/٨٠٦)٨٥٦٩٩- عن عكرمة مولى ابن عباس= (ز)٨٥٧٠٠- والحسن البصري -من طريق يزيد النحوي-: أنها مكّيّة، وذكراها بمسمّى: ﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾{6}. (ز)٨٥٧٠١- عن قتادة بن دعامة -من طرق-: مكّيّة{7}. (ز)٨٥٧٠٢- عن محمد بن مسلم الزُّهريّ: أنها مكّيّة، ونزلت بعد سورة الفلق{8}. (ز)٨٥٧٠٣- عن علي بن أبي طلحة: مكّيّة {9}. (ز)٨٥٧٠٤- قال مقاتل بن سليمان: سورة الناس مكّيّة، عددها ست آيات{10}. (ز)"
  114,2,"﴿قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ ۝١ مَلِكِ ٱلنَّاسِ ۝٢ إِلَـٰهِ ٱلنَّاسِ ۝٣﴾ - تفسير٨٥٧٠٥- قال مقاتل بن سليمان: ﴿قُلْ أعُوذُ بِرَبِّ النّاسِ﴾ أمَر الله ﷿ النبيَّ ﷺ أن يتعوّذ برب الناس، الذي هو ﴿مَلِكِ النّاسِ﴾ بِمَلِكهم في برِّهم وبحرهم، وفاجرهم وصالحهم وطالحهم، وهو ﴿إلهِ النّاسِ﴾ كلّهم{1}. (ز)"
  114,3,"114:2"
  114,4,"﴿مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ ۝٤﴾ - تفسير٨٥٧٠٦- عن أنس، عن النبيِّ ﷺ، قال: «إنّ الشيطان واضعٌ خَطْمه{1} على قلب ابن آدم، فإنْ ذَكر الله خَنَس{2}، وإنْ نسي التَقم قلبه، فذلك الوسواس الخناس»{3}. (١٥/٨٠٧)٨٥٧٠٧- عن أنس بن مالك: سمعتُ رسول الله ﷺ يقول: «إنّ للوسواس خَطْمًا كخطم الطائر، فإذا غفل ابنُ آدم وضَع ذلك المنقار في أُذن القلب يوسوس، فإنِ ابن آدم ذكر الله نكَص وخَنس؛ فلذلك سُمّي: الوسواس الخناس»{4}. (١٥/٨٠٧)٨٥٧٠٨- عن عبد الله بن عباس في قوله: ﴿الوَسْواسِ الخَنّاسِ﴾ قال: مثل الشيطان كمثل ابن عِرْس؛ واضعٌ فمه على فم القلب فيوسوس إليه، فإذا ذَكر الله خَنس، وإنْ سكت عاد إليه فهو الوسواس الخناس{5}. (١٥/٨٠٧)٨٥٧٠٩- عن عبد الله بن عباس -من طريق سعيد- في قوله: ﴿الوَسْواسِ الخَنّاسِ﴾، قال: الشيطان جاثِمٌ على قلب ابن آدم، فإذا سها وغفل وسوس، وإذا ذَكر الله خَنس{6}. (١٥/٨٠٨)٨٥٧١٠- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: ما من مولود يولد إلا على قلبه الوسواس، فإذا عقل فذَكر الله خَنس، وإذا غفل وسوس؛ فلذلك قوله: ﴿الوَسْواسِ الخَنّاسِ﴾{7}. (١٥/٨٠٨)٨٥٧١١- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله ﴿الوَسْواسِ﴾، قال: هو الشيطان يأمره، فإذا أُطيع خَنَس{8}. (ز)٨٥٧١٢- عن مجاهد بن جبر -من طريق عثمان بن الأسود- ﴿الوَسْواسِ الخَنّاسِ﴾، قال: ينبسط، فإذا ذَكر الله خَنَس وانقبض، فإذا غفل انبسط{9}. (ز)٨٥٧١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله ﴿الوَسْواسِ الخَنّاسِ﴾، قال: الشيطان يكون على قلب الإنسان، فإذا ذكر الله خنَس{10}. (ز)٨٥٧١٤- عن قتادة بن دعامة -من طريق معمر- ﴿الوَسْواسِ﴾، قال: هو الشيطان، وهو الخنّاس أيضًا، إذا ذكر العبد ربّه خَنَس، وهو يوسوس ويَخْنَس{11}. (ز)٨٥٧١٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: الخنّاس: الذي يوسوس مرة ويَخنس مرة، من الجنّ والإنس، وكان يُقال: شيطان الإنس أشدّ على الناس من شيطان الجن؛ شيطان الجن يوسوس ولا تراه، وهذا يعاينك معاينة{8}. (١٥/٨٠٨)٨٥٧١٦- عن ابن ثور، عن أبيه، ذُكر لي: أنّ الشيطان -أو قال: الوسواس- ينفث في قلب الإنسان عند الحُزن وعند الفرح، وإذا ذَكر الله خَنس{8}. (ز)﴿مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ ۝٤﴾ - آثار متعلقة بالآية٨٥٧١٧- عن الحكم بن عُمير الثُّمّالي، عن النبيِّ ﷺ، قال: «الحذر، أيها الناس، وإياكم والوسواس الخنّاس، فإنما يبلوكم أيكم أحسن عملًا»{14}. (١٥/٨٠٦)٨٥٧١٨- عن معاوية بن أبي طلحة، قال: كان من دعاء النبيِّ ﷺ: «اللهم، اعمُر قلبي من وساوس ذِكرك، واطرد عنِّي وساوس الشيطان»{15}. (١٥/٨٠٧)٨٥٧١٩- عن عبد الله بن مغفل -من طريق عقبة- قال: البول في المُغتسل يأخذ منه الوسواسُ{16}. (١٥/٨٠٦)٨٥٧٢٠- عن إبراهيم التيميّ -من طريق العوام- قال: أول ما يبدأ الوسواسُ من الوضوء{17}. (١٥/٨٠٦)٨٥٧٢١- عن عمرو بن مُرّة -من طريق مسعر- قال: ما وساوسه بأوْلع ممن يراها تعملُ فيه{18}. (١٥/٨٠٦)"
  114,5,"﴿ٱلَّذِی یُوَسۡوِسُ فِی صُدُورِ ٱلنَّاسِ ۝٥﴾ - تفسير٨٥٧٢٢- عن عكرمة مولى ابن عباس، قال: الوسواس محلّه على فؤاد الإنسان، وفي عينه، وفي ذَكَره، ومحلّه من المرأة في عينها، وفي فرْجها إذا أقبلتْ، وفي دُبرها إذا أدبرتْ؛ هذه مجالِسه{1}. (١٥/٨٠٩)٨٥٧٢٣- عن عروة بن رُوَيم -من طريق أبي فضالة-: أنّ عيسى ابن مريم ﵇ دعا ربّه أن يُريَه موضع الشيطان مِن ابن آدم، فجُلِّي له، فإذا رأسه مثل رأس الحيّة، واضعًا رأسه على ثمرة القلب، فإذا ذَكر الله خَنس، وإذا لم يذكره وضع رأسه على ثمرة قلبه فحدَّثه{2}. (١٥/٨٠٨)٨٥٧٢٤- عن يحيى بن أبي كثير، قال: إنّ الوسواس له باب في صدر ابن آدم يوسوس منه{3}. (١٥/٨٠٨)٨٥٧٢٥- قال مقاتل بن سليمان: ﴿مِن شَرِّ الوَسْواسِ الخَنّاسِ﴾ وهو الشيطان في صورة خنزير معلّق بالقلب في جسد ابن آدم، وهو يجري مجرى الدم، سلّطه الله على ذلك من الإنسان، فذلك قوله: ﴿الَّذِي يُوَسْوِسُ فِي صُدُورِ النّاسِ﴾، فإذا انتهى ابن آدم وسوس في قلبه حتى يبتلع{4} قلبه، والخنّاس الذي إذا ذَكر اللهَ ابنُ آدم خَنس عن قلبه، فذهب عنه، ويخرج من جسده{5}٧٣٤٥. (ز)٧٣٤٥ اختُلف في معنى: ﴿مِن شَرِّ الوَسْواسِ الخَنّاسِ﴾ على قولين: الأول: ﴿مِن شَرِّ الوَسْواسِ﴾ يعني: من شرّ الشيطان ﴿الخَنّاسِ﴾ الذي يَخنس مرة ويوسوس أخرى، وإنما يَخنس عند ذِكْر العبد ربَّه. الثاني: الذي يوسوس بالدعاء إلى طاعته في صدور الناس، حتى يستجاب له إلى ما دعا إليه من طاعته، فإذا استجيب له إلى ذلك خنس.وعلَّق ابنُ تيمية (٧/٣٩٦) على القول الأول -وهو قول ابن زيد وما في معناه- بقوله: «فبيَّن ابن زيد أنّ الوسواس الخنّاس من الصِّنفين».ورجَّح ابنُ جرير (٢٤/٧٥٥) العموم، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنّ الله أمر نبيَّه محمدًا أن يستعيذ به من شرّ شيطانٍ يوسوس مرة ويَخْنِسُ أخرى، ولم يَخُصَّ وسوسته على نوعٍ من أنواعها، ولا خُنُوسَه على وجْهٍ دون وجْه، وقد يوسوس بالدعاء إلى معصية الله، فإذا أُطِيع فيها خَنَس، وقد يوسوس بالنهي عن طاعة الله، فإذا ذَكَر العبد أمر ربّه، فأطاعه فيه وعصى الشيطان خَنس، فهو في كلّ حالتيه وسْواسٌ خَنّاس، وهذه الصفة صفته».ورجَّح ابنُ تيمية (٧/٣٩٣-٣٩٤) قائلًا: «والقول الصحيح الذي عليه أكثر السلف أنّ المعنى: من شرّ الموسوس من الجِنّة ومن الناس، من شياطين الإنس والجن»، فـ«قوله: ﴿مِن الجِنَّةِ والنّاسِ﴾ لبيان الوسواس، أي: الذي يوسوس من الجِنّة، ومن الناس في صدور الناس»."
  114,6,"﴿مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ ۝٦﴾ - تفسير٨٥٧٢٦- عن قتادة بن دعامة -من طريق معمر- في قوله: ﴿مِنَ الجِنَّةِ والنّاسِ﴾، قال: إنّ من الناس شياطين، فنعوذ بالله من شياطين الإنس والجن{1}. (١٥/٨٠٩)٨٥٧٢٧- قال محمد بن السّائِب الكلبي: ﴿مِنَ الجِنَّةِ والنّاسِ﴾، يعني: يدخل في الجنيّ كما يدخل في الإنسيّ، ويوسوس للجنيّ كما يوسوس للإنسيّ{2}. (ز)٨٥٧٢٨- قال مقاتل بن سليمان: ﴿مِنَ﴾ شر ﴿الجِنَّةِ والنّاسِ﴾ يعني: الجن والإنس{3}. (ز)٨٥٧٢٩- عن عبد الملك ابن جُرَيْج، في قوله: ﴿مِنَ الجِنَّةِ والنّاسِ﴾، قال: هما وسواسان؛ فوسواس من الجِنَّة، وهو الجن، ووسواس من نفس الإنسان، فهو قوله: ﴿والنّاسِ﴾{4}٧٣٤٦. (١٥/٨٠٩)٧٣٤٦ ذكر ابنُ عطية (٨/٧١٨) معنى قول ابن جُرَيْج، وذكر احتمالًا آخر، فقال: «ويظهر أيضًا أن يكون قوله تعالى: ﴿والنّاسِ﴾ يراد به: من يوسوس بخدعه من البشر، ويدعو إلى الباطل، فهو في ذلك كالشيطان».٨٥٧٣٠- قال يحيى بن سلام: ﴿والنّاسِ﴾ ومن شرّ شياطين الإنس{5}. (ز)"
