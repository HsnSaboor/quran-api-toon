tafsir[11]{c,v,t}:
  100,1,"مقدمة السورة٨٤٤٣٣- عن عبد الله بن عباس -من طريق مجاهد-: مكّيّة{1}. (ز)٨٤٤٣٤- عن عبد الله بن عباس، قال: نزلت ﴿والعاديات﴾ بمكة{2}. (١٥/٥٩٧)٨٤٤٣٥- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: أنها مكّيّة، وأوردها بمسمّى: ﴿والعاديات﴾، وأنها نزلت بعد ﴿والعصر﴾{3}. (ز)٨٤٤٣٦- عن عكرمة مولى ابن عباس= (ز)٨٤٤٣٧- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز)٨٤٤٣٨- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)٨٤٤٣٩- عن محمد بن مسلم الزُّهريّ: أنها مكّيّة، وأوردها بمسمّى: ﴿والعاديات﴾، وأنها نزلت بعد ﴿ألم نشرح﴾{6}. (ز)٨٤٤٤٠- عن علي بن أبي طلحة: مكّيّة{7}. (ز)٨٤٤٤١- قال مقاتل بن سليمان: سورة العاديات مكّيّة، عددها إحدى عشرة آية كوفي{8}٧٢٦١. (ز)٧٢٦١ ذكر ابن تيمية (٧/١٧٠) خلافًا في نزول السورة على قولين: الأول: أنها نزلت بمكة. الثاني: أنها نزلت بالمدينة، حكاه عن ابن عباس -كماسيأتي في نزول السورة-، وقتادة. وعلّق على القول الثاني بقوله: «وهذا القول يناسب قول مَن فسّر: ﴿والعاديات﴾ بخَيْل المجاهدين».﴿وَٱلۡعَـٰدِیَـٰتِ ضَبۡحࣰا ۝١﴾ - نزول الآيات٨٤٤٤٢- عن عبد الله بن عباس -من طريق عكرمة- قال: بَعث رسول الله ﷺ خيلًا، فأشْهرتْ{9} شهرًا لا يأتيه منها خبر؛ فنزلت: ﴿والعادِياتِ ضَبْحًا﴾ ...{10}. (١٥/٥٩٧)٨٤٤٤٣- قال أنس بن مالك: إنّ قومًا كان بينهم وبين النبي ﷺ عهد، فنقضوه، وهم أهل فدَك، فبعث إليهم رسول الله خيله، فصبّحوهم، وهم الذين أنزل الله فيهم: ﴿والعادِياتِ ضَبْحًا﴾{11}. (ز)٨٤٤٤٤- قال مقاتل بن سليمان: قوله: ﴿والعادِياتِ ضَبْحًا﴾ وذلك أنّ النبي ﷺ بعث سَريّة إلى حُنَين مِن كنانة، واستعمل عليهم المنذر بن عمرو الأنصاري أحد النُّقباء، فغابتْ، فلم يأت النبيَّ ﷺ خبرُها، فأخبره الله ﷿ عنها، فقال: ﴿والعادِياتِ ضَبْحًا﴾ يعني: الخيل. وقيل: إنّ رسول الله ﷺ بَعث سَريّة إلى أرض تِهامة، وأبطأ عليه الخبر، فجعلت اليهود والمنافقون إذا رأَوا رجلًا من الأنصار أو من المهاجرين تناجَوا بأمره، فكان الرجل يظن أنه قد مات، أو قُتل أخوه، أو أبوه، أو عمّه، وكان يجِد مِن ذلك أمرًا عظيمًا، فجاءه جبريل ﵇ يوم الجمعة عند وقت الضُّحى، فقال: ﴿والعادِياتِ ضَبْحًا فالمُورِياتِ قَدْحًا فالمُغِيراتِ صُبْحًا فَأَثَرْنَ بِهِ نَقْعًا فَوَسَطْنَ بِهِ جَمْعًا﴾ يقول: فوسَطْن بذلك الغبار جمعًا، يقول: حمل المسلمون عليهم، فهزموهم، فضرب بعضهم بعضًا، حتى ارتفع الوهج الذي كان ارتفع مِن حوافر الخيل إلى السماء، فهزم الله المشركين، وقتلهم، فأخبره الله ﷿ بعلامات الخيل، والغبار، وكيف فعل بهم، فقال رسول الله ﷺ: «يا جبريل، ومتى كان هذا؟». قال: اليوم. فخرج رسول الله ﷺ، فأخبر المسلمين بذلك، وقرأ عليهم كتاب الله ﷿، ففرحوا، واستبشروا، وأخزى الله ﷿ اليهود والمنافقين{12}. (ز)﴿وَٱلۡعَـٰدِیَـٰتِ ضَبۡحࣰا ۝١﴾ - تفسير٨٤٤٤٥- عن عبد الله بن مسعود -من طريق إبراهيم- ﴿والعادِياتِ ضَبْحًا﴾، قال: الإبل.= (ز)٨٤٤٤٦- قال إبراهيم: وقال علي بن أبي طالب: هي الإبل.= (ز)٨٤٤٤٧- وقال ابن عباس: هي الخيل. فبلغ عليًّا قولُ ابن عباس، فقال: ما كانت لنا خيل يوم بدر. قال ابن عباس: إنما كان ذلك في سَريّة بُعثتْ{13}. (١٥/٦٠٠)٨٤٤٤٨- عن عبد الله بن مسعود -من طريق إبراهيم- ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الإبل في الحج{14}. (١٥/٦٠٤)٨٤٤٤٩- عن عبد الله بن مسعود -من طريق إبراهيم- ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الإبل، إذا ضَبحتْ تنفّستْ{15}. (ز)٨٤٤٥٠- عن مجاهد، ﴿والعادِياتِ ضَبْحًا﴾، قال: قال ابن عباس: القتال.= (ز)٨٤٤٥١- وقال ابن مسعود: الحج{16}. (١٥/٦٠١)٨٤٤٥٢- عن أبي صالح، قال: تقاولتُ أنا وعكرمة في شأن العاديات، فقال: قال ابن عباس: هي الخيل في القتال، وضبْحها حين تُرخي مشافِرها إذا عَدَتْ. ﴿فالمُورِياتِ قَدْحًا﴾ قال: أرت المشركين مكرهم. ﴿فالمُغِيراتِ صُبْحًا﴾ قال: إذا صبَّحت العدوّ. ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾ قال: إذا توسّطت العدّو.= (ز)٨٤٤٥٣- وقال أبو صالح: فقلتُ: قال عليٌّ: هي الإبل في الحج، ومولاي كان أعلم من مولاك{17}. (١٥/٥٩٨)٨٤٤٥٤- عن عامر الشعبي، قال: تمارى عليٌّ= (ز)٨٤٤٥٥- وابنُ عباس في: ﴿العادِياتِ ضَبْحًا﴾، فقال ابن عباس: هي الخيل. وقال علي: كذبتَ، يا ابن فلانة، واللهِ، ما كان معنا يوم بدر فارس إلا المِقداد، وكان على فرس أبْلق. قال: وكان يقول: هي الإبل. فقال ابن عباس: ألا ترى أنها تُثير نقعًا، فما شيء تُثيره إلا بحوافرها!{18}. (١٥/٦٠٠)٨٤٤٥٦- عن عبد الله بن عباس، قال: بَعث رسول الله ﷺ سَريّة إلى العدو، فأبطأ خبرها، فشقّ ذلك عليه، فأخبره الله خبرهم وما كان من أمرهم، فقال: ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الخيل، والضَّبْح: نخير الخيل حتى تنخر{2}. (١٥/٥٩٨)٨٤٤٥٧- عن عبد الله بن عباس -من طريق مجاهد- ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل{20}. (١٥/٦٠٠)٨٤٤٥٨- عن عبد الله بن عباس، ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل، ضبْحها: زحيرها{21}{22}. (١٥/٦٠١)٨٤٤٥٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: بينما أنا في الحِجْر جالس إذا أتاني رجل يسأل عن: ﴿العادِياتِ ضَبْحًا﴾. فقلتُ: الخيل حين تُغير في سبيل الله، ثم تأوي إلى الليل، فيصنعون طعامهم، ويُورون نارهم. فانفتل عنِّي= (ز)٨٤٤٦٠- فذهب إلى علي بن أبي طالب وهو جالس تحت سقاية زمزم، فسأله عن: ﴿العادِياتِ ضَبْحًا﴾. فقال: سألتَ عنها أحدًا قبلي؟ قال: نعم، سألتُ عنها ابن عباس، فقال: هي الخيل حين تُغير في سبيل الله. فقال: اذهب، فادعُه لي. فلما وقفتُ على رأسه قال: تفتي الناس بما لا علم لك، واللهِ، إن كانت أول غزوة في الإسلام لبدر، وما كان معنا إلا فرسان؛ فرس للزُّبير، وفرس للمِقداد بن الأسود، فكيف تكون العاديات ضبحًا؟ إنما العاديات ضبحًا مِن عرفة إلى المُزدلفة، فإذا أووا إلى المزدلفة أورُوا النيران، ﴿فالمُغِيراتِ صُبْحًا﴾ من المُزدلفة إلى مِنى، فذلك جمْع، وأمّا قوله: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾ فهو نقع الأرض حين تطؤه بخفافها وحوافرها. قال ابن عباس: فنَزعتُ عن قولي، ورجعتُ إلى الذي قال علي{23}. (١٥/٥٩٩)٨٤٤٦١- قال عُبيد بن عُمَير -من طريق عمرو بن دينار- ﴿والعادِياتِ ضَبْحًا﴾: هي الإبل{24}. (١٥/٦٠١)٨٤٤٦٢- عن إبراهيم النَّخْعي -من طريق منصور- ﴿والعادِياتِ ضَبْحًا﴾، قال: الإبل{25}. (ز)٨٤٤٦٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل{26}. (١٥/٦٠٢)٨٤٤٦٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الخيل{27}. (ز)٨٤٤٦٥- عن عكرمة مولى ابن عباس -من طريق سماك- ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الخيل{28}. (١٥/٦٠٢)٨٤٤٦٦- عن سالم [بن عبد الله بن عمر] -من طريق سعيد- أنه سمعه يقرأ: ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الخيل عَدَتْ ضبحًا{27}. (ز)٨٤٤٦٧- قال أبو العالية الرِّياحيّ= (ز)٨٤٤٦٨- والحسن البصري= (ز)٨٤٤٦٩- والربيع بن أنس= (ز)٨٤٤٧٠- ومحمد بن السّائِب الكلبي= (ز)٨٤٤٧١- ومقاتل بن حيان: ﴿العادِياتِ ضَبْحًا﴾ هي الخيل التي تعدو في سبيل اللّه وتَضبح{30}. (ز)٨٤٤٧٢- عن عطية بن سعد العَوفيّ، ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل، ألم ترها إذا عَدْتْ تَزْحَر. يقول: تنخر{18}. (١٥/٦٠٣)٨٤٤٧٣- عن عطاء بن أبي رباح، ﴿والعادِياتِ ضَبْحًا﴾، قال: الإبل{18}. (١٥/٦٠٤)٨٤٤٧٤- عن عطاء بن أبي رباح -من طريق واصل- ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل{27}. (ز)٨٤٤٧٥- عن قتادة بن دعامة -من طريق معمر- ﴿والعادِياتِ ضَبْحًا﴾، قال: هي الخيل تعدو حتى تَضبح{34}. (١٥/٦٠٢)٨٤٤٧٦- عن محمد بن كعب القُرَظيّ، ﴿والعادِياتِ ضَبْحًا﴾، قال: الدّفعة من عرفة{18}. (١٥/٦٠٤)٨٤٤٧٧- عن إسماعيل السُّدِّيّ: أنها الإبل في الحج، تعدو مِن عرفة إلى المُزدلفة، ومن المُزدلفة إلى مِنى{36}. (ز)٨٤٤٧٨- قال مقاتل بن سليمان: قوله: ﴿والعادِياتِ ضَبْحًا﴾، يقول: غَدَت الخيل إلى الغزوة حتى أصبحتْ{12}. (ز)٨٤٤٧٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ﴿والعادِياتِ ضَبْحًا فالمُورِياتِ قَدْحًا﴾ قال: هذا قَسمٌ أقسم الله به. وفي قوله: ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾ قال: كلّ هذا قَسمٌ.= (ز)٨٤٤٨٠- قال: ولم يكن أبِي ينظر فيه إذا سُئِل عنه، ولا يذكره، يريد به القسم{38}. (ز)﴿ضَبۡحࣰا ۝١﴾ - تفسير٨٤٤٨١- عن علي بن أبي طالب -من طريق أبي صالح- قال: الضَّبح من الخيل: الحَمْحَمة، ومن الإبل: النَّفَس{39}. (١٥/٦٠١)٨٤٤٨٢- عن عبد الله بن عباس -من طريق أبي صالح، عن عكرمة-: ضبْحها: نفسها بمشافرها{40}. (ز)٨٤٤٨٣- عن عبد الله بن عباس -من طريق عكرمة- قال: ... ﴿والعادِياتِ ضَبْحًا﴾ ضبَحتْ بأرجلها. ولفظ ابن مردويه: ضبَحتْ بمناخرها{41}. (١٥/٥٩٧)٨٤٤٨٤- عن عطاء، قال: سمعت ابن عباس يصف الضّبح: أحْ أحْ{39}. (ز)٨٤٤٨٥- عن عبد الله بن عباس، ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل، ضبْحها: زحيرها{21}، ألم تر أنّ الفرس إذا عدا قال: أحْ أحْ. فذاك ضبْحها{22}. (١٥/٦٠١)٨٤٤٨٦- عن عبد الله بن عباس -من طريق عمرو بن دينار عن عطاء- ﴿والعادِياتِ ضَبْحًا﴾، قال: ليس شيء من الدواب يضْبح إلا كلب أو فرس{45}٧٢٦٢. (١٥/٦٠١)٧٢٦٢ ذكر ابنُ عطية (٨/٦٧٢-٦٧٣) قول ابن عباس، وانتقده -مستندًا للغة، والواقع- بقوله: ""وهذا عندي لا يصح عن ابن عباس ﵁، وذلك أنّ الإبل تضبْح، والأسود من الحيّات والبوم والصدى والأرنب والثعلب والفرس هذه كلّها قد استعملتْ لها العرب الضبح، وأنشد أبو حنيفة في صفة قوس:حنانة من نشم أو تالب تضبح في الكف ضباح الثعلب"".٨٤٤٨٧- عن عكرمة مولى ابن عباس -من طريق أبي رجاء- ﴿والعادِياتِ ضَبْحًا﴾، قال: الخيل، ألم تر إلى الفرس إذا جرى كيف يضبح؟ وما ضبح بعيرٌ قطّ{28}. (١٥/٦٠٢)٨٤٤٨٨- عن عطاء بن أبي رباح -من طريق ابن جُرَيْج- قال: ليس شيء من الدواب يَضبح غير الكلب والفرس{47}. (ز)٨٤٤٨٩- قال مقاتل بن سليمان: قوله: ﴿والعادِياتِ ضَبْحًا﴾، يقول: غَدَت الخيل إلى الغزوة حتى أصبحتْ، فعَلَتْ أنفاسها بأفواهها، فكان لها ضباح كضباح الثعلب{12}٧٢٦٣. (ز)٧٢٦٣ اختُلف في قوله: ﴿والعاديات ضبحا﴾ على قولين: الأول: أنها الخيل. الثاني: أنها الإبل.وقد بيّن ابنُ القيم أنّ قوله: ﴿ضبحا﴾ على القول الأول يكون حالًا، وعلى الثاني يكون مصدرًا.وقد رجّح ابنُ جرير (٢٤/٥٧٤ بتصرف) القول الأول -مستندًا إلى دلالة الواقع، واللغة، وأقوال السلف- وعلَّل ذلك بقوله: «وذلك أنّ الإبل لا تَضبح، وإنما تَضبح الخيل، وقد أخبر الله تعالى أنها تعدو ضبحًا، وبما قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على أنّ الضبح هو الحَمْحَمة.وذكر ابنُ عطية (٨/٦٧٣) القولين، ثم قال: «والظاهر في الآية أنّ القسم بالخيل، أو بالإبل، أو بهما».وبيّن ابنُ القيم أنّ ذكر خيل المجاهدين أخصّ ما دخل في هذا الوصف على سبيل التمثيل، وليس الاختصاص، فقال: وذكر خيل المجاهدين أحقّ ما دخل في هذا الوصف، فذكره على وجه التمثيل لا الاختصاص؛ فإنّ هذا شأن خيل المقاتلة، وأشرف أنواع الخيل خيل المجاهدين، والقَسم إنما وقع بما تضمّنه شأن هذه العاديات مِن الآيات البيّنات مِن خلق هذا الحيوان الذي هو من أكرم البهيم وأشرفه، وهو الذي يحصل به العِزّ والظفر والنصر على الأعداء، فتعدو طالبة للعدو وهاربة منه، فيُثير عَدْوها الغبار لشدته، وتُوري حوافرها وسنابكها النار من الأحجار لشدة عَدْوها، فتدرك الغارة التي طلبتها حتى تتوسط جمْع الأعداء، فهذا من أعظم آيات الرّبّ تعالى وأدلة قدرته وحكمته، فذكّرهم بنعمة عليهم في خَلْق هذا الحيوان الذي ينتصرون به على أعدائهم، ويُدركون به ثأرهم، كما ذكّرهم سبحانه بنِعمه عليهم في خَلْق الإبل التي تحمل أثقالهم من بلد إلى بلد، فالإبل أخصّ بحمل الأثقال، والخيل أخص بنُصرة الرجال، فذكّرهم بنِعمه بهذا وهذا""."
  100,2,"﴿فَٱلۡمُورِیَـٰتِ قَدۡحࣰا ۝٢﴾ - تفسير٨٤٤٩٠- عن عبد الله بن مسعود -من طريق إبراهيم- ﴿فالمُورِياتِ قَدْحًا﴾: إذا نَسفَت الحصى بمناسمها{1}، فضَرَب الحصى بعضُه بعضًا، فتخرج منه النار{2}. (١٥/٦٠٤)٨٤٤٩١- عن علي بن أبي طالب -من طريق سعيد بن جُبَير، عن ابن عباس-: ... إنما العاديات ضبحًا من عرفة إلى المُزدلفة، ومن المُزدلفة إلى مِنى، فإذا أوَوْا إلى المزدلفة أورَوُا النيران{3}٧٢٦٤. (١٥/٥٩٩)٧٢٦٤ ذكر ابنُ القيم (٣/٣٤٩-٣٥٠) بعض ما جاء في قول ابن عباس، فقال: «روى سعيد بن جُبَير عن ابن عباس: هم الذين يُغيرون، فيُورون بالليل نيرانهم لطعامهم وحاجتهم». ووجّهه بقوله: «كأنهم أخذوه من قوله تعالى: ﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾ [الواقعة:٧١]». ثم علّق عليه قائلًا: «وهذا إنْ أريد به التمثيل وأنّ الآية تدل عليه فصحيح، وإنْ أريد به اختصاص المُوريات فليس كذلك؛ لأنّ المُوريات هي العاديات بعينها، ولهذا عطفها عليه بالفاء التي للتسبب، فإنها عَدَتْ فأَوْرتْ».٨٤٤٩٢- عن عبد الله بن عباس -من طريق عكرمة- قال: ﴿فالمُورِياتِ قَدْحًا﴾ قَدحتْ بحوافرها الحجارة، فأَورتْ نارًا{4}. (١٥/٥٩٧)٨٤٤٩٣- عن عبد الله بن عباس، قال: ﴿فالمُورِياتِ قَدْحًا﴾، قال: حين تجري الخيل تُوري نارًا؛ أصابت سنابكها الحجارة{5}. (١٥/٥٩٨)٨٤٤٩٤- عن عبد الله بن عباس -من طريق مجاهد- ﴿فالمُورِياتِ قَدْحًا﴾، قال: الرجل إذا أورى زَنده{6}. (١٥/٦٠٠)٨٤٤٩٥- عن عبد الله بن عباس -من طريق عطية- ﴿فالمُورِياتِ قَدْحًا﴾ قال: المكر{7}. (ز)٨٤٤٩٦- عن عبد الله بن عباس -من طريق عمرو بن دينار، عن عطاء- ﴿فالمُورِياتِ قَدْحًا﴾، قال: هو مكر الرجل، قدح فأورى{8}. (١٥/٦٠١)٨٤٤٩٧- عن عبد الله بن عباس، ﴿فالمُورِياتِ قَدْحًا﴾، قال: كان مكر المشركين إذا مكروا قَدحوا النيران حتى يُروا أنهم كثير{5}. (١٥/٦٠٣)٨٤٤٩٨- قال سعيد بن جُبَير: يعني: رجال الحرب{10}. (ز)٨٤٤٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿فالمُورِياتِ قَدْحًا﴾، قال: مكر الرجال{11}. (١٥/٦٠٢)٨٤٥٠٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: ﴿فالمُورِياتِ قَدْحًا﴾، قال: تُوري الحجارة بحوافرها{12}. (ز)٨٤٥٠١- عن عكرمة مولى ابن عباس -من طريق سماك بن حرب- ﴿فالمُورِياتِ قَدْحًا﴾، قال: المكر، تقول العرب إذا أراد الرجل أن يمكر بصاحبه: أما -واللهِ- لَأقدحنّ لك، ثم لَأُورِينّ{13}. (١٥/٦٠٢)٨٤٥٠٢- عن عطية بن سعد العَوفيّ، ﴿فالمُورِياتِ قَدْحًا﴾، قال: المكر{14}. (١٥/٦٠٣)٨٤٥٠٣- عن عطاء، ﴿فالمُورِياتِ قَدْحًا﴾، قال: الخيل{14}. (١٥/٦٠٤)٨٤٥٠٤- عن عطاء -من طريق واصل- ﴿فالمُورِياتِ قَدْحًا﴾، قال: أوْرت النار بحوافرها{12}. (ز)٨٤٥٠٥- عن محمد بن كعب القُرَظيّ، ﴿فالمُورِياتِ قَدْحًا﴾، قال: النيران تُجمع{14}٧٢٦٥. (١٥/٦٠٤)٧٢٦٥ ذكر ابنُ القيم (٣/٣٤٩) عن محمد بن كعب أنه قال: «هم الحاجّ إذا أوقدوا نيرانهم ليلة المزدلفة». وعلّق عليه قائلًا: «وعلى هذا فيكون التقدير: فالجماعات الموريات». وانتقده بقوله: «وهذا خلاف الظاهر».٨٤٥٠٦- عن قتادة بن دعامة -من طريق معمر- ﴿فالمُورِياتِ قَدْحًا﴾، قال: هي الخيل قد قدحت النار بحوافرها{18}. (١٥/٦٠٢)٨٤٥٠٧- عن قتادة بن دعامة -من طريق سعيد- ﴿فالمُورِياتِ قَدْحًا﴾، قال: هِجْنَ الحربَ بينهم وبين عدوّهم{12}. (ز)٨٤٥٠٨- قال زيد بن أسلم: هي مكر الرجل{20}. (ز)٨٤٥٠٩- عن محمد بن السّائِب الكلبي -من طريق معمر- ﴿فالمُورِياتِ قَدْحًا﴾، قال: تقدح بحوافرها حتى يخرج منها النار{21}. (ز)٨٤٥١٠- قال مقاتل بن سليمان: ثم قال: ﴿فالمُورِياتِ قَدْحًا﴾، يقول: يقدحنَ بحوافرهنّ في الحجارة نارًا كنار أبي حباحب، وكان شيخًا مِن مضر في الجاهلية، له نويرة تقدح مرّة وتخمد مرّة لكيلا يمُرّ به ضيف، فشبّه الله ﷿ ضوء وقع حوافرهنّ في أرض حصباء بنويرة أبي حباحب، وأيضًا ﴿فالمُورِياتِ قَدْحًا﴾ قال: كانت تصيب حوافرهنّ الحجارة، فتقدح منهنّ النار{22}. (ز)٨٤٥١١- عن ابن جُرَيْج، عن بعضهم: ﴿فالمُورِياتِ قَدْحًا﴾ فالمنجّحات عملًا، كنجاح الزند إذا أورى{10}٧٢٦٦. (ز)٧٢٦٦ اختُلف في قوله: ﴿فالموريات قدحا﴾ على أقوال: الأول: هي الخيل تُوري النار بحوافرها. الثاني: الخيل هِجْنَ الحرب بين أصحابهنّ وركبانهن. الثالث: عني بذلك: الذين يُورون النار بعد انصرافهم من الحرب. الرابع: معنى ذلك: مكر الرجال. الخامس: هي الألسنة. السادس: هي الإبل حين تسير تنسف بمناسمها الحصى.وعلّق ابنُ عطية (٨/٦٧٣) على القول الثاني بقوله: «فهذا أيضًا على الاستعارة البيّنة». وعلّق على القول الخامس بقوله: «فهذا على الاستعارة، أي: ببيانها تقدح الحجج وتُظهرها».وقد رجّح ابنُ جرير (٢٤/٥٧٨) العموم، فقال: «وأولى الأقوال في ذلك بالصواب: أن يُقال: إنّ الله -تعالى ذِكْره- أقسم بالموريات التي تُوري النيران قدحًا؛ فالخيل تُوري بحوافرها، والناس يُورونها بالزند، واللسان مثلًا يُوري بالمنطق، والرجال يُورون بالمكر مثلًا، وكذلك الخيل تهيج الحرب بين أهلها إذا التقتْ في الحرب. ولم يضع الله دلالة على أنّ المراد من ذلك بعض دون بعض، فكل ما أورت النار قدحًا فداخلة فيما أقسم به؛ لعموم ذلك بالظاهر».وذكر ابنُ عطية قولًا آخر نسبه لابن عباس وجماعة، وقال: «وقال ابن عباس أيضًا وجماعة من العلماء: الكلام عامٌّ يدخل في القَسم كلّ مَن يظهر بقدحه نارًا، وذلك شائع في الأُمَم طول الدهر، وهو نفع عظيم مِن الله تعالى، وقد وقف عليه في قوله تعالى: ﴿أفرأيتم النار التي تورون﴾ [الواقعة:٧١]، معناه: تُظهرون بالقدح».وذكر ابنُ القيم (٣/٣٥٠) القول الثاني والرابع والخامس، وانتقدها مستندًا إلى السياق، فقال: «وقال قتادة: الموريات: هي الخيل تُوري نار العداوة بين المقتتلين. وهذا ليس بشيء، وهو بعيد من معنى الآية وسياقها، وأضعف منه قول عكرمة: هي الألسنة توري نار العداوة بعظيم ما نتكلّم به. وأضعف منه ما ذُكر [عن] مجاهد: هي أفكار الرجال تُوري نار المكر والخديعة في الحرب». ثم علّق قائلًا: «وهذه الأقوال إنْ أريد أنّ اللفظ دلّ عليها وأنها هي المراد فغلط، وإنْ أريد أنها أُخِذتْ من طريق الإشارة والقياس فأمرها قريب». ثم ذكر قول ابن جُرَيْج أنه فسّر: ﴿قدحا﴾ بـ: المنجحات أمرًا. وضعفه كذلك."
  100,3,"﴿فَٱلۡمُغِیرَ ٰ⁠تِ صُبۡحࣰا ۝٣﴾ - تفسير٨٤٥١٢- عن عبد الله بن مسعود -من طريق إبراهيم- ﴿فالمُغِيراتِ صُبْحًا﴾: حين يُفيضون من جمْع{1}. (١٥/٦٠٤)٨٤٥١٣- عن علي بن أبي طالب -من طريق سعيد بن جُبَير، عن ابن عباس-: ... ﴿فالمُغِيراتِ صُبْحًا﴾ مِن المُزدلفة إلى مِنى، فذلك جمْع{2}. (١٥/٥٩٩)٨٤٥١٤- عن عبد الله بن عباس-من طريق عكرمة-، قال: ﴿فالمُغِيراتِ صُبْحًا﴾ صبَّحت القومَ بغارة{3}. (١٥/٥٩٧)٨٤٥١٥- عن عبد الله بن عباس، قال: ﴿فالمُغِيراتِ صُبْحًا﴾، قال: هي الخيلُ أغارتْ، فصبّحت العدّو{4}. (١٥/٥٩٨)٨٤٥١٦- عن عبد الله بن عباس -من طريق مجاهد- ﴿فالمُغِيراتِ صُبْحًا﴾، قال: الخيل تصبّح العدو{5}. (١٥/٦٠٠)٨٤٥١٧- عن عبد الله بن عباس -من طريق عطاء- ﴿فالمُغِيراتِ صُبْحًا﴾، قال: غارت الخيل صُبحًا{6}. (١٥/٦٠١)٨٤٥١٨- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: سألني رجل عن: ﴿فالمُغِيراتِ صُبْحًا﴾. فقال: الخيل تُغير في سبيل الله{7}. (ز)٨٤٥١٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿فالمُغِيراتِ صُبْحًا﴾، قال: الخيل{8}. (١٥/٦٠٢)٨٤٥٢٠- عن عكرمة مولى ابن عباس -من طريق سماك- ﴿فالمُغِيراتِ صُبْحًا﴾، قال: الخيل{9}. (١٥/٦٠٢)٨٤٥٢١- عن عكرمة مولى ابن عباس -من طريق أبي رجاء- أنه سأله عن قوله: ﴿فالمُغِيراتِ صُبْحًا﴾. قال: أغارتْ على العدوِّ صُبحًا{10}. (ز)٨٤٥٢٢- قال الحسن البصري: ﴿فالمُغِيراتِ صُبْحًا﴾ هي الخيل تُغير على العدوّ إذا أصبحتْ{11}. (ز)٨٤٥٢٣- عن عطية بن سعد العَوفيّ، ﴿فالمُغِيراتِ صُبْحًا﴾، قال: الخيل{12}. (١٥/٦٠٣)٨٤٥٢٤- عن قتادة بن دعامة -من طريق معمر- ﴿فالمُغِيراتِ صُبْحًا﴾، قال: أغارتْ حين أصبحتْ{13}. (١٥/٦٠٢)٨٤٥٢٥- عن محمد بن كعب القُرَظيّ، ﴿فالمُغِيراتِ صُبْحًا﴾، قال: الدّفعة مِن جمْع{12}. (١٥/٦٠٤)٨٤٥٢٦- قال مقاتل بن سليمان: ثم قال: ﴿فالمُغِيراتِ صُبْحًا﴾، وذلك أنّ الخيل صبّحت العدوّ بغارة، يقول: غارتْ عليهم صُبحًا{15}٧٢٦٧. (ز)٧٢٦٧ اختُلف في ﴿والمُغيرات صبحًا﴾ على أقوال: الأول: فالمغيرات صُبحًا على عدوّها. الثاني: عني بذلك: الإبل حين تدفع بركبانها مِن جمْع يوم النَّحر إلى مِنى.وعلّق ابنُ عطية (٥/٦٧٤) على القول الثاني، فقال: «وقوله تعالى: ﴿فالمغيرات صبحا﴾ قال علي وابن مسعود: هي الإبل من مُزدلفة إلى مِنى أو في بدر. والعرب تقول: أغار إذا عدا جريًا ونحوه». وعلّق على الأول، فقال: «وقال ابن عباس وجماعة كثيرة: هي الخيل، واللفظة من الغارة في سبيل الله وغير ذلك من سير الأمم».وقد رجّح ابنُ جرير (٢٤/٥٨٠) العموم، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: إنّ الله -جلّ ثناؤه- أقسم بالمُغيرات صُبحًا، ولم يخصص من ذلك مُغيرة دون مُغيرة، فكلّ مُغيرة صُبحًا فداخلة فيما أقسم به».﴿فَٱلۡمُغِیرَ ٰ⁠تِ صُبۡحࣰا ۝٣﴾ - آثار متعلقة بالسورة٨٤٥٢٧- عن أبي هريرة -من طريق البختري بن عبيد، عن أبيه- قال: قال رجل: يا رسول الله، ما العاديات ضَبْحًا؟ فأَعرض عنه، ثم رجع إليه من الغد، فقال: ما المُوريات قَدْحًا؟ فأَعرض عنه، ثم رجع الثالثة، فقال: ما المُغيرات صُبْحًا؟ فرفع العمامة والقلنسوة عن رأسه بمِخصَرته{16}، فوجده مُفْرَعًا{17} رأسه، فقال: «لو وجدتُه طامًّا{18} رأسه لوضعتُ الذي فيه عيناه». ففزع الملأ مِن قوله، فقالوا: يا نبي الله، ولم؟ قال: «إنه سيكون أناس من أمتي يَضربون القرآن بعضه ببعض ليُبطلوه، ويتَّبعون ما تشابه منه، ويزعمون أنّ لهم في أمر ربّهم سبيلًا، ولكلّ دين مجوس، وهم مجوس أُمّتي وكلاب النار». فكأنه يقول: هم القدرية{19}. (١٥/٦٠٧)"
  100,4,"﴿فَأَثَرۡنَ بِهِۦ نَقۡعࣰا ۝٤﴾ - تفسير٨٤٥٢٨- عن عبد الله بن مسعود -من طريق إبراهيم- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: إذا سِرن يُثِرْن التراب{1}. (١٥/٦٠٤)٨٤٥٢٩- عن علي بن أبي طالب -من طريق سعيد بن جُبَير، عن ابن عباس-: ... وأمّا قوله: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾ فهو نقْع الأرض حين تطؤه بخِفافها وحوافرها{2}. (١٥/٥٩٩)٨٤٥٣٠- عن عبد الله بن عباس -من طريق عكرمة- قال: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾ أثارتْ بحوافرها التراب{3}. (١٥/٥٩٧)٨٤٥٣١- عن عبد الله بن عباس، قال: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: هي الخيل أثرنَ بحوافرها. يقول: تعدو الخيل، والنّقع: الغبار{4}. (١٥/٥٩٨)٨٤٥٣٢- عن عبد الله بن عباس -من طريق مجاهد- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: التراب{5}. (١٥/٦٠٠)٨٤٥٣٣- عن عبد الله بن عباس -من طريق عطاء- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: غبارًا؛ وقْع سنابك الخيل{6}. (١٥/٦٠١)٨٤٥٣٤- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾. قال: النّقع: ما يسطع مِن حوافر الخيل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ حسّان بن ثابت وهو يقول:عدِمنا خيلَنا إن لم تَرَوها تُثِيرُ النَّقْعَ مَوعِدُها كَداءُ{7}. (١٥/٦٠٣)٨٤٥٣٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: الخيل{8}. (١٥/٦٠٢)٨٤٥٣٦- عن عكرمة مولى ابن عباس -من طريق سماك- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: التراب مِن وقْع الخيل{9}. (١٥/٦٠٢)٨٤٥٣٧- قال الحسن البصري: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾ تُثِير التراب بحوافرها{10}. (ز)٨٤٥٣٨- عن عطية بن سعد العَوفيّ، ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: الغبار{11}. (١٥/٦٠٣)٨٤٥٣٩- عن قتادة بن دعامة -من طريق معمر- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: غُبارًا{12}. (١٥/٦٠٢)٨٤٥٤٠- عن محمد بن كعب القُرَظيّ، ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: بطن الوادي{11}٧٢٦٨. (١٥/٦٠٤)٧٢٦٨ ذكر ابنُ عطية (٨٥/٦٧٤) في عود الضمير من قوله: ﴿به﴾ قولين، فقال: «والضمير في ﴿به﴾ ظاهر أنه للصُّبح المذكور، ويحتمل أن يكون للمكان والموضع الذي يقتضيه المعنى، وإن كان لم يجْرِ له ذكر».٨٤٥٤١- عن عطاء= (ز)٨٤٥٤٢- وعبد الرحمن بن زيد بن أسلم -من طريق واصل- ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، قال: النّقع: الغبار{14}. (ز)٨٤٥٤٣- قال مقاتل بن سليمان: ﴿فَأَثَرْنَ بِهِ نَقْعًا﴾، يقول: فأثَرنَ بجريهنّ -يعني: بحوافرهنّ- نقعًا في التراب{15}. (ز)"
  100,5,"﴿فَوَسَطۡنَ بِهِۦ جَمۡعًا ۝٥﴾ - تفسير٨٤٥٤٤- عن عبد الله بن مسعود -من طريق إبراهيم-: ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، يعني: مُزدلفة{1}. (ز)٨٤٥٤٥- عن عبد الله بن عباس -من طريق عكرمة- قال: ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾ صبّحت القوم جميعًا{2}. (١٥/٥٩٧)٨٤٥٤٦- عن عبد الله بن عباس، قال: ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: الجمع: العدوّ{3}. (١٥/٥٩٨)٨٤٥٤٧- عن عبد الله بن عباس -من طريق مجاهد- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: العدوّ{4}. (١٥/٦٠٠)٨٤٥٤٨- عن عبد الله بن عباس -من طريق عطاء- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: جمْع العدوّ{5}. (١٥/٦٠١)٨٤٥٤٩- عن مجاهد بن جبر -من طريق بن أبي نجيح- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: هؤلاء وهؤلاء{6}. (١٥/٦٠٢)٨٤٥٥٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾: الجمْع: الكتيبة{7}. (ز)٨٤٥٥١- عن عكرمة مولى ابن عباس -من طريق أبي رجاء- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: جمْع العدوّ{8}. (١٥/٦٠٢)٨٤٥٥٢- عن عطية بن سعد العَوفيّ، ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: جمْع المشركين{9}. (١٥/٦٠٣)٨٤٥٥٣- عن قتادة بن دعامة -من طريق معمر- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: جمْع القوم{10}. (١٥/٦٠٢)٨٤٥٥٤- عن محمد بن كعب القُرَظيّ، ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: جمْع مِنى{9}. (١٥/٦٠٤)٨٤٥٥٥- عن عطاء -من طريق واصل- ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾، قال: القوم{12}. (١٥/٦٠٤)٨٤٥٥٦- قال مقاتل بن سليمان: ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾ يعني: بعَدْوِهِنّ، يقول: حين تعدو الخيل جمْع القوم، يعني: العدوّ ... ﴿فَوَسَطْنَ بِهِ جَمْعًا﴾ يقول: فوسطْنَ بذلك الغبار جمعًا، يقول: حمل المسلمون عليهم، فهزموهم، فضرب بعضهم بعضًا، حتى ارتفع الوهج الذي كان ارتفع من حوافر الخيل إلى السماء، فهزم الله المشركين وقتلهم ...{13}٧٢٦٩. (ز)٧٢٦٩ قال ابنُ جرير (٢٤/٥٨٢): «وقوله: ﴿فوسطن به جمعا﴾ يقول -تعالى ذِكْره-: فوسَطْن بركبانهن جمْع القوم، يقال: وسَطت القوم -بالتخفيف-، ووسّطته -بالتشديد-، وتوسّطته؛ بمعنًى واحد. وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على هذا، ثم ذكر قول من قال: عني بذلك مُزدلفة."
  100,6,"﴿إِنَّ ٱلۡإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودࣱ ۝٦﴾ - نزول الآية٨٤٥٥٧- قال مقاتل بن سليمان: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾ نزلت في قرط بن عبد الله بن عمرو بن نَوْفل القرشي{1}. (ز)﴿إِنَّ ٱلۡإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودࣱ ۝٦﴾ - تفسير الآية٨٤٥٥٨- عن أبي أُمامة، عن النبِيِّ ﷺ، في قوله: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: «لكفور»{2}. (١٥/٦٠٥)٨٤٥٥٩- عن أبي أُمامة، قال: قال رسول الله ﷺ: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: «لكفور، الذي يأكل وحده، ويضرب عبده، ويمنع رِفده{3}»{4}. (١٥/٦٠٥)٨٤٥٦٠- عن أبي أُمامة -من طريق حمزة بن هانئ- قال: الكَنُود: الذي يمنع رِفده، وينزل وحده، ويضرب عبده{5}. (١٥/٦٠٥)٨٤٥٦١- عن عبد الله بن عباس -من طرق- ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لكفور{6}. (١٥/٦٠٠)٨٤٥٦٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾. قال: الكَنُود: الكفور للنعمة؛ وهو الذي يأكل وحده، ويمنع رِفده، ويُجيع عبده. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول:شَكَرتُ له يومَ العكاظِ نواله ولم أكُ للمعروفِ ثَمَّ كنودا؟{7}. (١٥/٦٠٣)٨٤٥٦٣- عن عبد الله بن عباس، قال: الكَنُود بلساننا أهل البلد: الكفور{8}. (١٥/٦٠٤)٨٤٥٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لكفور{9}. (١٥/٦٠٢)٨٤٥٦٥- عن عكرمة مولى ابن عباس، ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لَكفور{10}. (١٥/٦٠٢)٨٤٥٦٦- عن الحسن البصري -من طريق شعيب بن الحبحاب- ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لكفور، يعدّد المُصيبات، وينسى نِعَم ربّه{11}. (١٥/٦٠٦)٨٤٥٦٧- عن الحسن البصري= (ز)٨٤٥٦٨- وقتادة بن دعامة -من طريق سعيد- في قوله: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قالا: لكفور للنعمة؛ البخيل بما أُعطي، الذي يمنع رِفده، ويُجيع عبده، ويأكل وحده، ولا يُعطي النائبة تكون في قومه، ولا يكون كنودًا حتى تكون هذه الخصال فيه{12}. (١٥/٦٠٥)٨٤٥٦٩- قال محمد بن سيرين: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾ هو اللوّام لربّه{13}. (ز)٨٤٥٧٠- عن عطية بن سعد العَوفيّ، ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لكفور{14}. (١٥/٦٠٣)٨٤٥٧١- عن عطاء، ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لكفور{14}. (١٥/٦٠٤)٨٤٥٧٢- قال عطاء: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، الكَنُود: الذي لا يُعطي في النائبة مع قومه{16}. (ز)٨٤٥٧٣- عن قتادة بن دعامة -من طريق سعيد- ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: لكفور{17}. (١٥/٦٠٢)٨٤٥٧٤- عن سِماك -من طريق شعبة- قال: إنما سُميت: كندة؛ أنها قطعت أباها ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾ قال: لكفور{18}. (ز)٨٤٥٧٥- عن الربيع بن أنس -من طريق أبي جعفر- ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: الكَنُود: الكفور{19}. (ز)٨٤٥٧٦- قال محمد بن السّائِب الكلبي: هو بلسان كِندة وحضْرمَوت، وبلسان معدٍ كلّهم: العاصي، وبلسان مُضر وربيعة وقضاعة: الكفور، وبلسان بني مالك: البخيل{20}. (ز)٨٤٥٧٧- قال مقاتل بن سليمان: ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، يعني: لكفور، نزلت في قرط بن عبد الله بن عمرو بن نَوْفل القرشي، وهو الرجل الذي أكل وحده، وأشبع بطنه، وأجاع عبده، ومنع رِفده، ولم يُعطِ قومه شيئًا، يُسمّى بلسان بني مالك بن كنانة: الكَنُود{1}. (ز)٨٤٥٧٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- ﴿إنَّ الإنْسانَ لِرَبِّهِ لَكَنُودٌ﴾، قال: الكَنُود: الكفور. وقرأ: ﴿إنَّ الإنْسانَ لَكَفُورٌ﴾ [الحج:٦٦]{18}. (ز)٨٤٥٧٩- قال الفُضَيل بن عياض: الكنود: الذي أنسته الخصلة الواحدة مِن الإساءة الخصال الكثيرة من الإحسان. والشكور: الذي أنسته الخصلة الواحدة من الإحسان الخصال الكثيرة من الإساءة{16}. (ز)"
  100,7,"﴿وَإِنَّهُۥ عَلَىٰ ذَ ٰ⁠لِكَ لَشَهِیدࣱ ۝٧﴾ - قراءات٨٤٥٨٠- عن قتادة بن دعامة -من طريق سعيد- ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾ في بعض القراءات: (إنّ اللهَ عَلى ذَلِكَ لَشَهِيدٌ){1}. (ز)﴿وَإِنَّهُۥ عَلَىٰ ذَ ٰ⁠لِكَ لَشَهِیدࣱ ۝٧﴾ - تفسير الآية٨٤٥٨١- عن عبد الله بن عباس، ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾، قال: الإنسان{2}. (١٥/٦٠٦)٨٤٥٨٢- عن مجاهد بن جبر، ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾، قال: الله ﷿{3}. (١٥/٦٠٦)٨٤٥٨٣- عن محمد بن كعب القُرَظيّ، ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾، قال: الإنسان شاهد على نفسه{3}٧٢٧٠. (١٥/٦٠٦)٧٢٧٠ وجّه ابنُ كثير (٨/٤٦٧) المعنى على قول مَن قال بعود الضمير على الإنسان، فقال: «ويحتمل أن يعود الضمير على الإنسان. قاله محمد بن كعب القُرَظيّ، فيكون تقديره: وإنّ الإنسان على كونه كَنُودًا لشهيد، أي: بلسان حاله، أي: ظاهر ذلك عليه في أقواله وأفعاله، كما قال تعالى: ﴿ما كان للمشركين أن يعمروا مساجد الله شاهدين على أنفسهم بالكفر﴾ [التوبة:١٧]».وبنحوه قال ابنُ عطية (٥/٥١٤).وعلّق ابنُ القيم (٣/٣٥١ بتصرف) على قول مَن جعل الضمير عائدًا على الإنسان بقوله: «ويؤيد هذا القول سياق الضمائر؛ فإنّ قوله: ﴿وإنَّهُ لِحُبِّ الخَيْرِ لَشَدِيدٌ﴾ للإنسان، فافتتح الخبر عن الإنسان بكونه كَنُودًا، ثم ثنّاه بكونه شهيدًا على ذلك، ثم ختمه بكونه بخيلًا بماله لحُبّه إياه». وعلّق على قول مَن جعله عائدًا على الله بقوله: «ويؤيد هذا أنه أتى بعلى، فقال: ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾ أي: مُطَّلِع عالم به، كقوله: ﴿ثُمَّ اللَّهُ شَهِيدٌ عَلى ما يَفْعَلُونَ﴾ [يونس:٤٦]، ولو أريد شهادة الإنسان لأتى بالباء، فقيل: وإنه بذلك لشهيد كما قال تعالى: ﴿ما كانَ لِلْمُشْرِكِينَ أنْ يَعْمُرُوا مَساجِدَ اللَّهِ شاهِدِينَ عَلى أنْفُسِهِمْ بِالكُفْرِ﴾ [التوبة:١٧]، فلو أراد شهادة الإنسان لقال: وإنه على نفسه لشهيد؛ فإنّ كنوده المشهود به ونفسه هي المشهود عليها».٨٤٥٨٤- عن قتادة بن دعامة -من طريق سعيد- ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾، قال: يقول: إنّ الله على ذلك لشهيد{5}٧٢٧١. (ز)٧٢٧١ ذكر ابنُ عطية (٨/٦٧٥) قول قتادة، وعلّق عليه، فقال: «وقوله تعالى: ﴿وإنه على ذلك لشهيد﴾ يحتمل الضمير أن يعود على الله تعالى، وقاله قتادة، أي: وربّه شاهد عليه، ونفس هذا الخبر يقتضي الشهادة بذلك».٨٤٥٨٥- عن قتادة بن دعامة، ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾، قال: هذه من مقاديم الكلام، يقول: وإنّ الله على ذلك لشهيد، وإنّ الإنسان لحُبّ الخير لشديد{6}. (١٥/٦٠٦)٨٤٥٨٦- قال مقاتل بن سليمان: ثم قال: ﴿وإنَّهُ عَلى ذلِكَ لَشَهِيدٌ﴾، يقول: إنّ الله ﷿ على كُفر قرط لشهيد{7}. (ز)٨٤٥٨٧- عن سفيان [الثوري] -من طريق مهران- ﴿وإنَّهُ عَلى ذَلِكَ لَشَهِيدٌ﴾، يقول: وإنّ الله عليه شهيد{8}٧٢٧٢. (ز)٧٢٧٢ لم يذكر ابنُ جرير (٢٤/٥٨٧) غير قول سفيان وقتادة."
  100,8,"﴿وَإِنَّهُۥ لِحُبِّ ٱلۡخَیۡرِ لَشَدِیدٌ ۝٨﴾ - تفسير٨٤٥٨٨- عن عبد الله بن عباس، ﴿وإنَّهُ لِحُبِّ الخَيْرِ﴾، قال: المال{1}. (١٥/٦٠٦)٨٤٥٨٩- عن قتادة بن دعامة-من طريق معمر- ﴿وإنَّهُ لِحُبِّ الخَيْرِ لَشَدِيدٌ﴾، قال: هو المال{2}. (١٥/٦٠٦)٨٤٥٩٠- قال مقاتل بن سليمان: ثم أخبر عنه، فقال: ﴿وإنَّهُ لِحُبِّ الخَيْرِ لَشَدِيدٌ﴾، يعني: المال{3}. (ز)٨٤٥٩١- قال الليث بن سعد -من طريق ابن وهب- في قول الله: ﴿وإنَّهُ لِحُبِّ الخَيْرِ لَشَدِيدٌ﴾، قال: الخير: المال{4}. (ز)٨٤٥٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- ﴿وإنَّهُ لِحُبِّ الخَيْرِ لَشَدِيدٌ﴾، قال: الخير: الدنيا. وقرأ: ﴿إنْ تَرَكَ خَيْرًا الوَصِيَّةُ﴾ [البقرة:١٨٠]، قال: فقلتُ له: إن ترك خيرًا: المال؟ قال: نعم، وأي شيء هو إلا المال؟! قال: وعسى أن يكون حرامًا، ولكن الناس يعُدُّونه خيرًا، فسمّاه الله: خيرًا؛ لأنّ الناس يُسمُّونه خيرًا في الدنيا، وعسى أن يكون خبيثًا، وسُمّي القتال في سبيل الله: سوءًا. وقرأ قول الله: ﴿فانْقَلَبُوا بِنِعْمَةٍ مِنَ اللَّهِ وفَضْلٍ لَمْ يَمْسَسْهُمْ سُوءٌ﴾ [آل عمران:١٧٤]، قال: لم يمسسهم قتال. قال: وليس هو عند الله بسوء، ولكن يُسمُّونه: سوءًا{5}٧٢٧٣. (ز)٧٢٧٣ ذكر ابن عطية (٨/٦٧٦) ما أفادته آثار السلف من أن الخير في الآية: المال. ثم ذكر احتمالًا آخر، فقال: «ويحتمل أن يراد هنا: الخير الدنيوي؛ من مال، وصحة، وجاه عند الملوك، ونحوه؛ لأنّ الكفار والجهال لا يعرفون غير ذلك، فأمّا المُحبّ في خير الآخرة فممدوح مرجوّ له الفوز»."
  100,9,"﴿أَفَلَا یَعۡلَمُ إِذَا بُعۡثِرَ مَا فِی ٱلۡقُبُورِ ۝٩﴾ - تفسير٨٤٥٩٣- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿إذا بُعْثِرَ ما فِي القُبُورِ﴾، قال: بُحِث{1}. (١٥/٦٠٧)٨٤٥٩٤- عن محمد بن كعب القُرَظيّ، ﴿أفَلا يَعْلَمُ إذا بُعْثِرَ ما فِي القُبُورِ﴾، قال: حين يُبعثون{2}. (١٥/٦٠٦)٨٤٥٩٥- قال مقاتل بن سليمان: ﴿أفَلا يَعْلَمُ﴾ يعني: فهلّا يعلم ﴿إذا بُعْثِرَ﴾ يعني: بُعِث ﴿ما فِي القُبُورِ﴾ من الموتى{3}. (ز)"
  100,10,"﴿وَحُصِّلَ مَا فِی ٱلصُّدُورِ ۝١٠﴾ - تفسير٨٤٥٩٦- عن عبد الله بن عباس -من طريق علي- في قوله: ﴿وحُصِّلَ ما فِي الصُّدُورِ﴾، قال: أُبرِز{1}. (١٥/٦٠٧)٨٤٥٩٧- عن أبي صالح [باذام]: ﴿وحُصِّلَ ما فِي الصُّدُورِ﴾، قال: أُخرِج ما في الصدور{2}. (١٥/٦٠٧)٨٤٥٩٨- عن محمد بن كعب القُرَظيّ، ﴿وحُصِّلَ ما فِي الصُّدُورِ﴾، قال: الأعمال، حُصِّل ما فيها{3}. (١٥/٦٠٦)٨٤٥٩٩- قال مقاتل بن سليمان: ﴿وحُصِّلَ ما فِي الصُّدُورِ﴾ مِن الخير والشّرّ، يعني: تَمَيّز ما في القلوب{4}. (ز)٨٤٦٠٠- عن سفيان [الثوري] -من طريق مهران- ﴿وحُصِّلَ ما فِي الصُّدُورِ﴾، يقول: مُيِّز{5}. (ز)"
  100,11,"﴿إِنَّ رَبَّهُم بِهِمۡ یَوۡمَىِٕذࣲ لَّخَبِیرُۢ ۝١١﴾ - تفسير٨٤٦٠١- قال مقاتل بن سليمان: ﴿إنَّ رَبَّهُمْ بِهِمْ يَوْمَئِذٍ﴾ يعني: يوم القيامة ﴿لَخَبِيرٌ﴾ بالصالح منهم والطالح{1}. (ز)"
