quran[8]{c,v,t}:
98,1,لَمْ یَكُنِ الَّذِیْنَ كَفَرُوْا مِنْ اَهْلِ الْكِتٰبِ وَ الْمُشْرِكِیْنَ مُنْفَكِّیْنَ حَتّٰى تَاْتِیَهُمُ الْبَیِّنَةُۙ لَمْ يَكُنِ : نہ تھے الَّذِيْنَ كَفَرُوْا : وہ جو کفر کیا مِنْ : سے اَهْلِ الْكِتٰبِ : اہل کتاب وَالْمُشْرِكِيْنَ : اور مشرکین مُنْفَكِّيْنَ : باز آنے والے حَتّٰى : یہاں تک کہ تَاْتِيَهُمُ : آئے ان کے پاس الْبَيِّنَةُ : کھلی دلیل اہل کتاب کے کافر (1) اور مشرک لوگ جب تک کہ ان کے پاس ظاہر دلیل نہ آجائے باز رہنے والے نہ تھے (وہ دلیل یہ تھی کہ)
98,2,رَسُوْلٌ مِّنَ اللّٰهِ یَتْلُوْا صُحُفًا مُّطَهَّرَةًۙ رَسُوْلٌ : رسول مِّنَ اللّٰهِ : اللہ سے يَتْلُوْا صُحُفًا : پڑھتا ہے۔ صحیفے مُّطَهَّرَةً : پاک اللہ تعالیٰ کا ایک رسول (1) جو پاک آسمانی کتاب پڑھے۔ (2)
98,3,فِیْهَا كُتُبٌ قَیِّمَةٌؕ فِيْهَا : اس میں كُتُبٌ : لکھے ہوئے قَيِّمَةٌ : مضبوط جن میں صحیح اور درست احکام ہوں۔ (1)
98,4,وَ مَا تَفَرَّقَ الَّذِیْنَ اُوْتُوا الْكِتٰبَ اِلَّا مِنْۢ بَعْدِ مَا جَآءَتْهُمُ الْبَیِّنَةُؕ وَمَا تَفَرَّقَ : اور نہ جدا جدا ہوئے الَّذِيْنَ : وہ جو کہ اُوْتُوا الْكِتٰبَ : کتاب دئیے گئے اِلَّا : مگر مِنْۢ بَعْدِ : اسکے بعد مَا : جب جَآءَتْهُمُ : انکے پاس آگئی الْبَيِّنَةُ : کھلی بات اہل کتاب اپنے پاس ظاہر دلیل آجانے کے بعد ہی (اختلاف میں پڑ کر) متفرق ہوگئے (1)
98,5,وَ مَاۤ اُمِرُوْۤا اِلَّا لِیَعْبُدُوا اللّٰهَ مُخْلِصِیْنَ لَهُ الدِّیْنَ١ۙ۬ حُنَفَآءَ وَ یُقِیْمُوا الصَّلٰوةَ وَ یُؤْتُوا الزَّكٰوةَ وَ ذٰلِكَ دِیْنُ الْقَیِّمَةِؕ وَمَآ اُمِرُوْٓا : اور نہ حکم دیا گیا اِلَّا : مگر لِيَعْبُدُوا اللّٰهَ : یہ کہ عبادت کریں اللہ کی مُخْلِصِيْنَ : خاص کرتے ہوئے لَهُ الدِّيْنَ : اسکے لئے دین حُنَفَآءَ : یک رخ وَيُقِيْمُوا : اور قائم کریں الصَّلٰوةَ : نماز وَيُؤْتُوا : اور ادا کریں الزَّكٰوةَ : زکوۃ وَذٰلِكَ : اور یہ دِيْنُ الْقَيِّمَةِ : دین مضبوط انہیں اس کے سوا کوئی حکم نہیں دیا گیا (1) کہ صرف اللہ کی عبادت کریں اسی کے لئے دین کو خالص رکھیں۔ ابراہیم حنیف کے دین پر اور نماز قائم رکھیں اور زکوٰۃ دیتے رہیں یہی ہے دین سیدھی ملت کا۔
98,6,اِنَّ الَّذِیْنَ كَفَرُوْا مِنْ اَهْلِ الْكِتٰبِ وَ الْمُشْرِكِیْنَ فِیْ نَارِ جَهَنَّمَ خٰلِدِیْنَ فِیْهَا١ؕ اُولٰٓئِكَ هُمْ شَرُّ الْبَرِیَّةِؕ اِنَّ الَّذِيْنَ كَفَرُوْا : بیشک جن لوگوں نے کفر کیا مِنْ : سے اَهْلِ الْكِتٰبِ : اہل کتاب وَالْمُشْرِكِيْنَ : اور مشرکین فِيْ : میں نَارِ جَهَنَّمَ : جہنم کی آگ خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَا : اس میں ۭ اُولٰٓئِكَ : یہی لوگ هُمْ : وہ شَرُّ الْبَرِيَّةِ : بدترین مخلوق بیشک جو لوگ اہل کتاب میں سے کافر ہوئے اور مشرکین سب دوزخ کی آگ میں جائیں گے جہاں وہ ہمیشہ ہمیشہ رہیں گے یہ لوگ بدترین خلائق ہیں (1)
98,7,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ١ۙ اُولٰٓئِكَ هُمْ خَیْرُ الْبَرِیَّةِؕ اِنَّ : بیشک الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کئے الصّٰلِحٰتِ : نیک ۙ اُولٰٓئِكَ : یہی لوگ هُمْ : وہ خَيْرُ الْبَرِيَّةِ : بہترین مخلوق بیشک جو لوگ ایمان لائے اور نیک عمل کئے یہ لوگ بہترین خلائق ہیں (1)
98,8,جَزَآؤُهُمْ عِنْدَ رَبِّهِمْ جَنّٰتُ عَدْنٍ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ خٰلِدِیْنَ فِیْهَاۤ اَبَدًا١ؕ رَضِیَ اللّٰهُ عَنْهُمْ وَ رَضُوْا عَنْهُ١ؕ ذٰلِكَ لِمَنْ خَشِیَ رَبَّهٗ۠    ۧ جَزَآؤُهُمْ : ان کی جزا عِنْدَ : پاس رَبِّهِمْ : ان کے رب کے جَنّٰتُ : باغ عَدْنٍ : ہمیشہ رہنے والے تَجْرِيْ : بہتی ہیں مِنْ تَحْتِهَا : ان کے نیچے الْاَنْهٰرُ : نہریں خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَآ : اس میں اَبَدًا : ہمیشہ ہمیشہ ۭرَضِيَ اللّٰهُ : اللہ راضی ہوا عَنْهُمْ : ان سے وَرَضُوْا عَنْهُ : اور وہ راضی اس سے ۭ ذٰلِكَ لِمَنْ : یہ ۔ اسکے لئے جو خَشِيَ رَبَّهٗ : ڈرے اپنے رب سے ان کا بدلہ ان کے رب کے پاس ہمیشگی والی جنتیں ہیں جنکے نیچے نہریں بہہ رہی ہیں جن میں وہ ہمیشہ ہمیشہ رہیں گے۔ اللہ ان سے راضی ہوا اور یہ اس سے راضی ہوئے (1) یہ ہے اس کے لئے جو اپنے پروردگار سے ڈرے۔
