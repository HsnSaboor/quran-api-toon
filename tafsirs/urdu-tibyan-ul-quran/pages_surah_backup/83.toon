quran[36]{c,v,t}:
83,1,وَیْلٌ لِّلْمُطَفِّفِیْنَۙ وَيْلٌ : خرابی ہے لِّلْمُطَفِّفِيْنَ : کمی کرنے والوں کیلئے بڑی خرابی ہے ناپ تول میں کمی کرنے والوں کی۔
83,2,الَّذِیْنَ اِذَا اكْتَالُوْا عَلَى النَّاسِ یَسْتَوْفُوْنَ٘ۖ الَّذِيْنَ : وہ جو کہ اِذَا : جب اكْتَالُوْا : ماپ کرلیں عَلَي النَّاسِ : لوگوں پر (سے) يَسْتَوْفُوْنَ : پورا بھر کرلیں کہ جب لوگوں سے ناپ کرلیتے ہیں تو پورا پورا لیتے ہیں۔
83,3,وَ اِذَا كَالُوْهُمْ اَوْ وَّ زَنُوْهُمْ یُخْسِرُوْنَؕ وَاِذَا : اور جب كَالُوْهُمْ : ماپ کردیں وہ اَوْ وَّزَنُوْهُمْ : یا تول کردیں يُخْسِرُوْنَ : گھٹا کردیں جب انہیں ناپ کر یا تول کردیتے ہیں تو کم دیتے ہیں (1)
83,4,اَلَا یَظُنُّ اُولٰٓئِكَ اَنَّهُمْ مَّبْعُوْثُوْنَۙ اَلَا : کیا نہیں يَظُنُّ : خیال کرتے اُولٰٓئِكَ : یہ لوگ اَنَّهُمْ : کہ وہ مَّبْعُوْثُوْنَ : اٹھائے جانے والے ہیں کیا انہیں مرنے کے بعد اٹھنے کا خیال نہیں۔
83,5,لِیَوْمٍ عَظِیْمٍۙ لِيَوْمٍ عَظِيْمٍ : ایک بڑے دن اس عظیم دن کے لئے۔
83,6,یَّوْمَ یَقُوْمُ النَّاسُ لِرَبِّ الْعٰلَمِیْنَؕ يَّوْمَ : دن يَقُوْمُ : کھڑے ہوں گے النَّاسُ : لوگ لِرَبِّ : رب کے سامنے الْعٰلَمِيْنَ : تمام جہان جس دن سب لوگ رب العالمین کے سامنے کھڑے ہوں گے۔
83,7,كَلَّاۤ اِنَّ كِتٰبَ الْفُجَّارِ لَفِیْ سِجِّیْنٍؕ كَلَّآ : ہرگز نہیں اِنَّ : بیشک كِتٰبَ : اعمال نامہ الْفُجَّارِ : بدکاروں کا لَفِيْ سِجِّيْنٍ : البتہ سجین میں یقیناً بدکاروں کا اعمالنامہ سجین میں ہے (1)
83,8,وَ مَاۤ اَدْرٰىكَ مَا سِجِّیْنٌؕ وَمَآ اَدْرٰىكَ : اور کیا خبر ہے تجھے مَا سِجِّيْنٌ : کیا ہے سجین تجھے کیا معلوم سجین کیا ہے۔
83,9,كِتٰبٌ مَّرْقُوْمٌؕ كِتٰبٌ : ایک دفتر مَّرْقُوْمٌ : لکھا ہوا (یہ تو) لکھی ہوئی کتاب ہے۔
83,10,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَۙ وَيْلٌ : خرابی يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کی بڑی خرابی ہے۔
83,11,الَّذِیْنَ یُكَذِّبُوْنَ بِیَوْمِ الدِّیْنِؕ الَّذِيْنَ : جو لوگ يُكَذِّبُوْنَ : جھٹلاتے ہیں بِيَوْمِ الدِّيْنِ : روز جزا وسزا کو جو جزا اور سزا کے دن کو جھٹلاتے رہے۔
83,12,وَ مَا یُكَذِّبُ بِهٖۤ اِلَّا كُلُّ مُعْتَدٍ اَثِیْمٍۙ وَمَا يُكَذِّبُ : اور نہیں جھٹلاتے بِهٖٓ : اس کو اِلَّا : مگر كُلُّ : ہر مُعْتَدٍ : حد سے بڑھ جانیوالا اَثِيْمٍ : گنہگار اسے صرف وہی جھٹلاتا ہے جو حد سے آگے نکل جانے والا (اور) گناہگار ہوتا ہے۔
83,13,اِذَا تُتْلٰى عَلَیْهِ اٰیٰتُنَا قَالَ اَسَاطِیْرُ الْاَوَّلِیْنَؕ اِذَا تُتْلٰى : جب پڑھی جائیں عَلَيْهِ اٰيٰتُنَا : اس پر ہماری آیتیں قَالَ : کہے اَسَاطِيْرُ : کہانیاں الْاَوَّلِيْنَ : پہلے جب اس کے سامنے ہماری آیتیں پڑھی جاتی ہیں تو کہہ دیتا ہے کہ یہ اگلوں کے افسانے ہیں (1)
83,14,كَلَّا بَلْ١ٚ رَانَ عَلٰى قُلُوْبِهِمْ مَّا كَانُوْا یَكْسِبُوْنَ كَلَّا : ہرگز نہیں بَلْ ۫ : بلکہ رَانَ : زنگ پکڑ گیا ہے عَلٰي قُلُوْبِهِمْ : ان کے دلوں پر مَّا : جو كَانُوْا يَكْسِبُوْنَ : وہ کماتے تھے یوں نہیں بلکہ ان کے دلوں پر ان کے اعمال کی وجہ سے زنگ (چڑھ گیا) ہے (1)
83,15,كَلَّاۤ اِنَّهُمْ عَنْ رَّبِّهِمْ یَوْمَئِذٍ لَّمَحْجُوْبُوْنَؕ كَلَّآ اِنَّهُمْ : ہرگز نہیں بیشک وہ عَنْ رَّبِّهِمْ : اپنے رب سے يَوْمَئِذٍ : اس دن لَّمَحْجُوْبُوْنَ : روک دئیے جائیں گے ہرگز نہیں یہ لوگ اس دن اپنے رب سے اوٹ میں رکھے جائیں گے (1)
83,16,ثُمَّ اِنَّهُمْ لَصَالُوا الْجَحِیْمِؕ ثُمَّ : پھر اِنَّهُمْ : بیشک وہ لَصَالُوا : داخل ہونیوالے الْجَحِيْمِ : جہنم پھر یہ لوگ بالیقین جہنم میں جھونکے جائیں گے۔
83,17,ثُمَّ یُقَالُ هٰذَا الَّذِیْ كُنْتُمْ بِهٖ تُكَذِّبُوْنَؕ ثُمَّ يُقَالُ : پھر کہاجائے گا هٰذَا الَّذِيْ : یہ وہ جو کہ كُنْتُمْ بِهٖ : تم تھے اس کو تُكَذِّبُوْنَ : جھوٹ جانتے پھر کہہ دیا جائے گا کہ یہی ہے وہ جسے تم جھٹلاتے رہے۔
83,18,كَلَّاۤ اِنَّ كِتٰبَ الْاَبْرَارِ لَفِیْ عِلِّیِّیْنَؕ كَلَّآ : ہرگز نہیں اِنَّ : بیشک كِتٰبَ : اعمال نامہ الْاَبْرَارِ : نیک لوگ لَفِيْ عِلِّيِّيْنَ : البتہ علیین میں یقیناً یقیناً نیکوکاروں کا نامہ اعمال علیین میں ہے (1)
83,19,وَ مَاۤ اَدْرٰىكَ مَا عِلِّیُّوْنَؕ وَمَآ : اور کیا اَدْرٰىكَ : تجھے خبر مَا عِلِّيُّوْنَ : کیا ہے علیین تجھے کیا پتہ کہ علیین کیا ہے ؟
83,20,كِتٰبٌ مَّرْقُوْمٌۙ كِتٰبٌ : ایک دفتر مَّرْقُوْمٌ : لکھا ہوا (وہ تو) لکھی ہوئی کتاب ہے۔
83,21,یَّشْهَدُهُ الْمُقَرَّبُوْنَۙ يَّشْهَدُهُ : دیکھتے ہیں الْمُقَرَّبُوْنَ : نزدیک والے مقرب (فرشتے) اس کا مشاہدہ کرتے ہیں۔
83,22,اِنَّ الْاَبْرَارَ لَفِیْ نَعِیْمٍۙ اِنَّ الْاَبْرَارَ : بیشک نیک بندے لَفِيْ نَعِيْمٍ : البتہ نعمت آرام میں یقیناً نیک لوگ (بڑی) نعمتوں میں ہونگے۔
83,23,عَلَى الْاَرَآئِكِ یَنْظُرُوْنَۙ عَلَي الْاَرَآئِكِ : تختوں پر يَنْظُرُوْنَ : دیکھتے ہوں گے مسہریوں میں بیٹھے دیکھ رہے ہونگے۔
83,24,تَعْرِفُ فِیْ وُجُوْهِهِمْ نَضْرَةَ النَّعِیْمِۚ تَعْرِفُ : تو پہچان لے گا فِيْ وُجُوْهِهِمْ : ان کے چہروں میں نَضْرَةَ : تروتازگی النَّعِيْمِ : نعمت کی تو ان کے چہروں سے ہی نعمتوں کی ترو تازگی پہچان لے گا۔
83,25,یُسْقَوْنَ مِنْ رَّحِیْقٍ مَّخْتُوْمٍۙ يُسْقَوْنَ : انہیں پلائی جاتی ہے مِنْ رَّحِيْقٍ : خالص شراب مَّخْتُوْمٍ : سر بمہر یہ لوگ سر بمہر خالص شراب پلائے جائیں گے۔
83,26,خِتٰمُهٗ مِسْكٌ١ؕ وَ فِیْ ذٰلِكَ فَلْیَتَنَافَسِ الْمُتَنَافِسُوْنَؕ خِتٰمُهٗ : اس کی مہر مِسْكٌ ۭ : مشک وَفِيْ ذٰلِكَ : اور اس میں فَلْيَتَنَافَسِ : چاہیے رغبت کریں الْمُتَنَافِسُوْنَ : رغبت کرنے والے جس پر مشک کی مہر ہوگی، سبقت لے جانے والوں کو اسی میں سبقت کرنی چاہیے (1)
83,27,وَ مِزَاجُهٗ مِنْ تَسْنِیْمٍۙ وَمِزَاجُهٗ : اس کی آمیزش مِنْ تَسْنِيْمٍ : تسنیم سے اور اس کی آمیزش تسنیم ہوگی (1)
83,28,عَیْنًا یَّشْرَبُ بِهَا الْمُقَرَّبُوْنَؕ عَيْنًا يَّشْرَبُ : ایک چشمہ پیتے ہیں بِهَا الْمُقَرَّبُوْنَ : اس سے مقرب وہ چشمہ جس کا پانی مقرب لوگ پئیں گے۔
83,29,اِنَّ الَّذِیْنَ اَجْرَمُوْا كَانُوْا مِنَ الَّذِیْنَ اٰمَنُوْا یَضْحَكُوْنَ٘ۖ اِنَّ : بیشک الَّذِيْنَ : وہ لوگ جو اَجْرَمُوْا : جرم کیا كَانُوْا : تھے مِنَ : سے (پر) الَّذِيْنَ اٰمَنُوْا : جو ایمان لائے يَضْحَكُوْنَ : ہنستے گنہگار لوگ ایمانداروں کی ہنسی اڑیا کرتے تھے (1)
83,30,وَ اِذَا مَرُّوْا بِهِمْ یَتَغَامَزُوْنَ٘ۖ وَاِذَا : اور جب مَرُّوْا : گزرتے بِهِمْ : ان سے يَتَغَامَزُوْنَ : آنکھ مارتے ان کے پاس سے گزرتے ہوئے آپس میں آنکھ کے اشارے کرتے تھے۔
83,31,وَ اِذَا انْقَلَبُوْۤا اِلٰۤى اَهْلِهِمُ انْقَلَبُوْا فَكِهِیْنَ٘ۖ وَاِذَا : اور جب انْقَلَبُوْٓا : وہ لوٹتے اِلٰٓى اَهْلِهِمُ : اپنے گھر والے انْقَلَبُوْا : لوٹتے فَكِهِيْنَ : ہنستے (باتیں بناتے) اور جب اپنے والوں کی طرف لوٹتے تو دل لگیاں کرتے تھے (1)
83,32,وَ اِذَا رَاَوْهُمْ قَالُوْۤا اِنَّ هٰۤؤُلَآءِ لَضَآلُّوْنَۙ وَاِذَا : اور جب رَاَوْهُمْ : انہیں دیکھتے قَالُوْٓا : کہتے اِنَّ هٰٓؤُلَآءِ : بیشک یہ لوگ لَضَآلُّوْنَ : گمراہ (جمع) اور جب انہیں دیکھتے تو کہتے یقیناً یہ لوگ گمراہ (بےراہ) ہیں۔
83,33,وَ مَاۤ اُرْسِلُوْا عَلَیْهِمْ حٰفِظِیْنَؕ وَمَآ اُرْسِلُوْا : اور نہیں بھیجے گئے عَلَيْهِمْ : ان پر حٰفِظِيْنَ : نگہبان یہ ان پر پاسبان بنا کر تو نہیں بھیجے گئے (1)
83,34,فَالْیَوْمَ الَّذِیْنَ اٰمَنُوْا مِنَ الْكُفَّارِ یَضْحَكُوْنَۙ فَالْيَوْمَ : پس آج الَّذِيْنَ اٰمَنُوْا : ایمان والے مِنَ الْكُفَّارِ : کافروں سے (پر) يَضْحَكُوْنَ : ہنستے ہیں پس آج ایمان والے ان کافروں پر ہنسیں گے۔
83,35,عَلَى الْاَرَآئِكِ١ۙ یَنْظُرُوْنَؕ عَلَي : پر الْاَرَآئِكِ ۙ : تختوں يَنْظُرُوْنَ : دیکھتے ہیں تختوں پر بیٹھے دیکھ رہے ہونگے۔
83,36,هَلْ ثُوِّبَ الْكُفَّارُ مَا كَانُوْا یَفْعَلُوْنَ۠    ۧ هَلْ : کیا ثُوِّبَ : بدلہ دیا گیا الْكُفَّارُ : کافر (جمع) مَا : جو كَانُوْا يَفْعَلُوْنَ : وہ کرتے تھے کہ اب ان منکروں نے جیسا یہ کرتے تھے پورا پورا بدلہ پا لیا (1)
