quran[19]{c,v,t}:
82,1,اِذَا السَّمَآءُ انْفَطَرَتْۙ اِذَا السَّمَآءُ : جب آسمان انْفَطَرَتْ : پھٹ جائے جب آسمان پھٹ جائے گا (1)
82,2,وَ اِذَا الْكَوَاكِبُ انْتَثَرَتْۙ وَاِذَا : اور جب الْكَوَاكِبُ : ستارے انْتَثَرَتْ : جھڑ پڑیں جب ستارے جھڑ جائیں گے۔
82,3,وَ اِذَا الْبِحَارُ فُجِّرَتْۙ وَاِذَا الْبِحَارُ : اور جب دریا فُجِّرَتْ : اُبل پڑیں (بہہ نکلیں) سمندر بہہ نکلیں گے
82,4,وَ اِذَا الْقُبُوْرُ بُعْثِرَتْۙ وَاِذَا الْقُبُوْرُ : اور جب قبریں بُعْثِرَتْ : کریدی جائیں اور جب قبریں (شق کر کے) اکھاڑ دی جائیں گی (1)
82,5,عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَ اَخَّرَتْؕ عَلِمَتْ نَفْسٌ : جان لے ہر شخص مَّا قَدَّمَتْ : کیا اس نے آگے بھیجا وَاَخَّرَتْ : اور پیچھے چھوڑا (اس وقت) ہر شخص اپنے آگے بھیجے ہوئے اور پیچھے چھوڑے ہوئے (یعنی اگلے پچھلے اعمال) کو معلوم کرلے گا۔
82,6,یٰۤاَیُّهَا الْاِنْسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِیْمِۙ يٰٓاَيُّهَا الْاِنْسَانُ : اے انسان مَا غَرَّكَ : کس چیز نے تجھے دھوکہ دیا بِرَبِّكَ الْكَرِيْمِ : اپنے رب کریم کے بارے میں اے انسان ! تجھے اپنے رب کریم سے کس چیز نے بہکایا ؟
82,7,الَّذِیْ خَلَقَكَ فَسَوّٰىكَ فَعَدَلَكَۙ الَّذِيْ : جس نے خَلَقَكَ : تجھے پیدا کیا فَسَوّٰىكَ : پھر تجھے ٹھیک کیا فَعَدَلَكَ : پھر برابر کیا جس (رب نے) تجھے پیدا کیا (1) پھر ٹھیک ٹھاک کیا (2) اور پھر درست اور برابر بنایا
82,8,فِیْۤ اَیِّ صُوْرَةٍ مَّا شَآءَ رَكَّبَكَؕ فِيْٓ : میں اَيِّ صُوْرَةٍ : جس صورت مَّا شَآءَ : چاہا رَكَّبَكَ : تجھے جو ڑدیا جس صورت میں چاہا تجھے جوڑ دیا۔
82,9,كَلَّا بَلْ تُكَذِّبُوْنَ بِالدِّیْنِۙ كَلَّا : ہرگز نہیں بَلْ : بلکہ تُكَذِّبُوْنَ : تم جھٹلاتے ہو بِالدِّيْنِ : جزا وسزا کا دن ہرگز نہیں بلکہ تم تو جزا و سزا کے دن کو جھٹلاتے ہو۔
82,10,وَ اِنَّ عَلَیْكُمْ لَحٰفِظِیْنَۙ وَاِنَّ : اور بیشک عَلَيْكُمْ : تم پر لَحٰفِظِيْنَ : نگہبان یقیناً تم پر نگہبان عزت والے۔
82,11,كِرَامًا كَاتِبِیْنَۙ كِرَامًا : عزت والے كَاتِبِيْنَ : لکھنے والے لکھنے والے مقرر ہیں۔
82,12,یَعْلَمُوْنَ مَا تَفْعَلُوْنَ يَعْلَمُوْنَ : وہ جانتے ہیں مَا : جو تَفْعَلُوْنَ : تم کرتے ہو جو کچھ تم کرتے ہو وہ جانتے ہیں۔
82,13,اِنَّ الْاَبْرَارَ لَفِیْ نَعِیْمٍۚ اِنَّ الْاَبْرَارَ : بیشک نیک لوگ لَفِيْ نَعِيْمٍ : جنت میں یقیناً نیک لوگ (جنت کے عیش آرام اور) نعمتوں میں ہونگے۔
82,14,وَ اِنَّ الْفُجَّارَ لَفِیْ جَحِیْمٍۚۖ وَاِنَّ الْفُجَّارَ : اور بیشک گنہگار لَفِيْ جَحِيْمٍ : جہنم میں اور یقیناً بدکار لوگ دوزخ میں ہونگے۔
82,15,یَّصْلَوْنَهَا یَوْمَ الدِّیْنِ يَّصْلَوْنَهَا : ڈالے جائیں گے اس میں يَوْمَ الدِّيْنِ : روزِجزاوسزا (قیامت) بدلے والے دن اس میں جائیں گے (1)
82,16,وَ مَا هُمْ عَنْهَا بِغَآئِبِیْنَؕ وَمَا هُمْ : اور وہ نہیں عَنْهَا : اس سے بِغَآئِبِيْنَ : غائب (جدا ہونے واے) وہ اس سے کبھی غائب نہ ہونے پائیں گے۔
82,17,وَ مَاۤ اَدْرٰىكَ مَا یَوْمُ الدِّیْنِۙ وَمَآ اَدْرٰىكَ : اور تمہیں کیا خبر مَا يَوْمُ الدِّيْنِ : کیا ہے روز جزا وسزا تجھے کچھ خبر بھی ہے کہ بدلے کا دن کیا ہے۔
82,18,ثُمَّ مَاۤ اَدْرٰىكَ مَا یَوْمُ الدِّیْنِؕ ثُمَّ مَآ اَدْرٰىكَ : پھر تمہیں کیا خبر مَا يَوْمُ الدِّيْنِ : کیا ہے روز جزا وسزا پھر میں (کہتا ہوں) تجھے کیا معلوم کہ جزا و سزا کا دن کیا ہے۔
82,19,یَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَیْئًا١ؕ وَ الْاَمْرُ یَوْمَئِذٍ لِّلّٰهِ۠    ۧ يَوْمَ : جس دن لَا تَمْلِكُ : مالک نہ ہوگا نَفْسٌ : کوئی شخص لِّنَفْسٍ : کسی شخص کے لئے شَيْئًا ۭ : کچھ وَالْاَمْرُ : اور حکم يَوْمَئِذٍ : اس دن لِّلّٰهِ : اللہ کے لئے (وہ ہے) جس دن کوئی شخص کسی شخص کے لئے کسی چیز کا مختار نہ ہوگا، اور (تمام تر) احکام اس روز اللہ کے ہی ہوں گے (1)
