quran[44]{c,v,t}:
70,1,سَاَلَ سَآئِلٌۢ بِعَذَابٍ وَّاقِعٍۙ سَاَلَ : سوال کیا سَآئِلٌۢ : سوال کرنے والے نے بِعَذَابٍ : عذاب کا وَّاقِعٍ : جو واقع ہونے والا ہے ایک سوال کرنے والے نے (1) اس عذاب کا سوال کیا جو واضح ہونے والا ہے۔
70,2,لِّلْكٰفِرِیْنَ لَیْسَ لَهٗ دَافِعٌۙ لِّلْكٰفِرِيْنَ : کافروں کے لیے لَيْسَ : نہیں ہے لَهٗ دَافِعٌ : واسطے اس کے کوئی دفع کرنے والا کافروں پر، جسے کوئی ہٹانے والا نہیں
70,3,مِّنَ اللّٰهِ ذِی الْمَعَارِجِؕ مِّنَ اللّٰهِ : اللہ کی طرف سے ذِي الْمَعَارِجِ : جو عروج کے زینوں کا مالک ہے اس اللہ کی طرف سے جو سیڑھیوں والا ہے (1)
70,4,تَعْرُجُ الْمَلٰٓئِكَةُ وَ الرُّوْحُ اِلَیْهِ فِیْ یَوْمٍ كَانَ مِقْدَارُهٗ خَمْسِیْنَ اَلْفَ سَنَةٍۚ تَعْرُجُ : چڑھتے ہیں الْمَلٰٓئِكَةُ : فرشتے وَالرُّوْحُ : اور روح اِلَيْهِ : اس کی طرف فِيْ يَوْمٍ : ایک دن میں كَانَ مِقْدَارُهٗ : ہے اس کی مقدار خَمْسِيْنَ : پچاس اَلْفَ سَنَةٍ : ہزار سال جس کی طرف فرشتے اور روح چڑھتے ہیں (1) ایک دن میں جس کی مقدار پچاس ہزار سال کی ہے
70,5,فَاصْبِرْ صَبْرًا جَمِیْلًا فَاصْبِرْ : پس صبر کیجیے صَبْرًا : صبر جَمِيْلًا : اچھی طرح پس تو اچھی طرح صبر کر۔
70,6,اِنَّهُمْ یَرَوْنَهٗ بَعِیْدًاۙ اِنَّهُمْ يَرَوْنَهٗ : بیشک وہ دیکھتے ہیں اس کو بَعِيْدًا : دور بیشک یہ اس (عذاب) کو دور سمجھ رہے ہیں۔
70,7,وَّ نَرٰىهُ قَرِیْبًاؕ وَّنَرٰىهُ : اور ہم دیکھ رہے ہیں اس کو قَرِيْبًا : قریب اور ہم اسے قریب دیکھتے ہیں (1)
70,8,یَوْمَ تَكُوْنُ السَّمَآءُ كَالْمُهْلِۙ يَوْمَ : جس دن تَكُوْنُ السَّمَآءُ : ہوگا آسمان كَالْمُهْلِ : تیل کی تلچھٹ کی طرح جس دن آسمان مثل تیل کی تلچھٹ کے ہوجائے گا۔
70,9,وَ تَكُوْنُ الْجِبَالُ كَالْعِهْنِۙ وَتَكُوْنُ الْجِبَالُ : اور ہم دیکھ رہے ہیں اس کو كَالْعِهْنِ : دھنی ہوئی روئی کی طرح اور پہاڑ مثل رنگین اون کے ہوجائیں گے (1)
70,10,وَ لَا یَسْئَلُ حَمِیْمٌ حَمِیْمًاۚۖ وَلَا يَسْئَلُ : اور نہ پوچھے گا حَمِيْمٌ : ولی دوست حَمِيْمًا : ولی دوست کو اور کوئی دوست کسی دوست کو نہ پوچھے گا۔
70,11,یُّبَصَّرُوْنَهُمْ١ؕ یَوَدُّ الْمُجْرِمُ لَوْ یَفْتَدِیْ مِنْ عَذَابِ یَوْمِئِذٍۭ بِبَنِیْهِۙ يُّبَصَّرُوْنَهُمْ : وہ دکھائے جائیں گے ان کو يَوَدُّ : چاہے گا الْمُجْرِمُ : مجرم لَوْ يَفْتَدِيْ : کاش فدیے میں دے دے مِنْ عَذَابِ يَوْمِئِذٍۢ : اس دن کے عذاب سے بِبَنِيْهِ : اپنے بیٹے کو گنہگار اس دن کے عذاب کے بدلے فدیے میں اپنے بیٹوں کو۔ (حالانکہ) ایک دوسرے کو دکھا دیئے جائیں گے (1)
70,12,وَ صَاحِبَتِهٖ وَ اَخِیْهِۙ وَصَاحِبَتِهٖ : اور اپنی بیوی کو وَاَخِيْهِ : اور اپنے بھائی کو اپنی بیوی کو اور اپنے بھائی کو۔
70,13,وَ فَصِیْلَتِهِ الَّتِیْ تُئْوِیْهِۙ وَفَصِيْلَتِهِ : اور اپنے کنبے کو الَّتِيْ : وہ جو تُئْوِيْهِ : پناہ دیتا تھا اس کو اپنے کنبے کو جو اسے پناہ دیتا تھا۔
70,14,وَ مَنْ فِی الْاَرْضِ جَمِیْعًا١ۙ ثُمَّ یُنْجِیْهِۙ وَمَنْ فِي الْاَرْضِ : اور اس کو جو زمین میں ہے جَمِيْعًا : سب کے سب کو ثُمَّ يُنْجِيْهِ : پھر وہ بچا لے اس کو اور روئے زمین کے سب لوگوں کو دینا چاہے گا تاکہ یہ اسے نجات دلا دے (1)
70,15,كَلَّا١ؕ اِنَّهَا لَظٰىۙ كَلَّا : ہرگز نہیں اِنَّهَا لَظٰى : بیشک وہ شعلے والی آگ ہے مگر یہ ہرگز نہ ہوگا، یقیناً وہ شعلے والی (آگ) ہے (1)
70,16,نَزَّاعَةً لِّلشَّوٰىۚۖ نَزَّاعَةً : کھینچنے والی ہے لِّلشَّوٰى : منہ کی کھال کو جو منہ اور سر کی کھال کھینچ لانے والی ہے (1)
70,17,تَدْعُوْا مَنْ اَدْبَرَ وَ تَوَلّٰىۙ تَدْعُوْا : پکارے گی مَنْ اَدْبَرَ : جس نے پیٹھ پھیری وَتَوَلّٰى : اور منہ موڑا وہ ہر شخص کو پکارے گی جو پیچھے ہٹتا اور منہ موڑتا ہے۔
70,18,وَ جَمَعَ فَاَوْعٰى وَجَمَعَ : اور جمع کیا فَاَوْعٰى : پھر سمیٹ کر رکھا اور جمع کرکے سنبھال رکھتا ہے (1)
70,19,اِنَّ الْاِنْسَانَ خُلِقَ هَلُوْعًاۙ اِنَّ الْاِنْسَانَ : بیشک انسان خُلِقَ : پیدا کیا گیا هَلُوْعًا : بےصبرا۔ تھڑ دلا بیشک انسان بڑے کچے دل والا بنایا گیا ہے (1)
70,20,اِذَا مَسَّهُ الشَّرُّ جَزُوْعًاۙ اِذَا : جب مَسَّهُ الشَّرُّ : پہنچتی ہے اس کو تکلیف جَزُوْعًا : گھبرا اٹھتا ہے جب اسے مصیبت پہنچتی ہے تو ہڑ بڑا اٹھتا ہے۔
70,21,وَّ اِذَا مَسَّهُ الْخَیْرُ مَنُوْعًاۙ وَّاِذَا : اور جب مَسَّهُ : پہنچتی ہے اس کو الْخَيْرُ : بھلائی مَنُوْعًا : بخل کرنے لگتا ہے۔ روکنے لگتا ہے اور جب راحت ملتی ہے تو بخل کرنے لگتا ہے۔
70,22,اِلَّا الْمُصَلِّیْنَۙ اِلَّا الْمُصَلِّيْنَ : سوائے نمازیوں کے مگر وہ نمازی۔
70,23,الَّذِیْنَ هُمْ عَلٰى صَلَاتِهِمْ دَآئِمُوْنَ۪ۙ الَّذِيْنَ : وہ نمازی هُمْ : وہ عَلٰي : پر صَلَاتِهِمْ : اپنی نمازوں (پر) دَآئِمُوْنَ : دوام اختیار کرنے والے ہیں جو اپنی نمازوں پر ہمیشگی کرنے والے ہیں (1)
70,24,وَ الَّذِیْنَ فِیْۤ اَمْوَالِهِمْ حَقٌّ مَّعْلُوْمٌ۪ۙ وَالَّذِيْنَ : اور وہ لوگ فِيْٓ اَمْوَالِهِمْ : ان کے مالوں میں حَقٌّ : حق ہے مَّعْلُوْمٌ : معلوم۔ مقرر اور جن کے مالوں میں مقررہ حصہ ہے (1)
70,25,لِّلسَّآئِلِ وَ الْمَحْرُوْمِ۪ۙ لِّلسَّآئِلِ : سوالی کے لیے وَالْمَحْرُوْمِ : اور محروم کے لیے مانگنے والوں کا بھی اور سوال سے بچنے والوں کا بھی۔ (1)
70,26,وَ الَّذِیْنَ یُصَدِّقُوْنَ بِیَوْمِ الدِّیْنِ۪ۙ وَالَّذِيْنَ : اور وہ لوگ يُصَدِّقُوْنَ : جو تصدیق کرتے ہیں بِيَوْمِ الدِّيْنِ : روز جزا کی اور جو انصاف کے دن پر یقین رکھتے ہیں۔ (1)
70,27,وَ الَّذِیْنَ هُمْ مِّنْ عَذَابِ رَبِّهِمْ مُّشْفِقُوْنَۚ وَالَّذِيْنَ : اور وہ لوگ هُمْ : وہ مِّنْ عَذَابِ رَبِّهِمْ : اپنے رب کے عذاب سے مُّشْفِقُوْنَ : ڈرنے والے ہیں اور جو اپنے رب کے عذاب سے ڈرتے ہیں۔ (1)
70,28,اِنَّ عَذَابَ رَبِّهِمْ غَیْرُ مَاْمُوْنٍ اِنَّ : بیشک عَذَابَ رَبِّهِمْ : ان کے رب کا عذاب غَيْرُ مَاْمُوْنٍ : بےخوف ہونے کی چیز نہیں بیشک ان کے رب کا عذاب بےخوف ہونے کی چیز نہیں۔ (1)
70,29,وَ الَّذِیْنَ هُمْ لِفُرُوْجِهِمْ حٰفِظُوْنَۙ وَالَّذِيْنَ : اور وہ لوگ هُمْ لِفُرُوْجِهِمْ : وہ اپنی شرمگاہوں کے لیے حٰفِظُوْنَ : حفاظت کرنے والے ہیں اور جو لوگ اپنی شرمگاہوں کی (حرام سے) حفاظت کرتے ہیں۔
70,30,اِلَّا عَلٰۤى اَزْوَاجِهِمْ اَوْ مَا مَلَكَتْ اَیْمَانُهُمْ فَاِنَّهُمْ غَیْرُ مَلُوْمِیْنَۚ اِلَّا : سوائے عَلٰٓي : اوپر اَزْوَاجِهِمْ : اپنی بیویوں کے اَوْ مَا مَلَكَتْ : یا جو مالک ہوئے اَيْمَانُهُمْ : ان کے دائیں ہاتھ فَاِنَّهُمْ : تو بیشک وہ غَيْرُ : نہیں مَلُوْمِيْنَ : ملامت کیے گئے ہاں ان کی بیویاں اور لونڈیوں کے بارے میں جن کے وہ مالک ہیں انہیں کوئی ملامت نہیں (1)
70,31,فَمَنِ ابْتَغٰى وَرَآءَ ذٰلِكَ فَاُولٰٓئِكَ هُمُ الْعٰدُوْنَۚ فَمَنِ ابْتَغٰى : پھر جو کوئی تلاش کرے وَرَآءَ ذٰلِكَ : اس کے علاوہ فَاُولٰٓئِكَ : تو یہی لوگ هُمُ : وہ الْعٰدُوْنَ : حد سے بڑھنے والے ہیں اب جو کوئی اس کے علاوہ (راہ) ڈھونڈے گا تو ایسے لوگ حد سے گزر جانے والے ہونگے۔
70,32,وَ الَّذِیْنَ هُمْ لِاَمٰنٰتِهِمْ وَ عَهْدِهِمْ رٰعُوْنَ۪ۙ وَالَّذِيْنَ : اور وہ لوگ هُمْ لِاَمٰنٰتِهِمْ : وہ اپنی امانتوں کے لیے وَعَهْدِهِمْ : اور اپنے وعدوں کے رٰعُوْنَ : نگران ہیں جو اپنی امانتوں کا اور اپنے قول وقرار کا پاس رکھتے ہیں۔ (1)
70,33,وَ الَّذِیْنَ هُمْ بِشَهٰدٰتِهِمْ قَآئِمُوْنَ۪ۙ وَالَّذِيْنَ : اور وہ لوگ هُمْ بِشَهٰدٰتِهِمْ : وہ پانی گواہیوں پر قَآئِمُوْنَ : قائم رہنے والے ہیں اور جو اپنی گواہیوں پر سیدھے اور قائم رہتے ہیں۔ (1)
70,34,وَ الَّذِیْنَ هُمْ عَلٰى صَلَاتِهِمْ یُحَافِظُوْنَؕ وَ : اور الَّذِيْنَ : وہ لوگ هُمْ عَلٰي صَلَاتِهِمْ : وہ اپنی نمازوں پر يُحَافِظُوْنَ : حفاظت کرتے ہیں جو اپنی نمازوں کی حفاظت کرتے ہیں۔
70,35,اُولٰٓئِكَ فِیْ جَنّٰتٍ مُّكْرَمُوْنَ٢ؕ۠    ۧ اُولٰٓئِكَ : یہی لوگ فِيْ جَنّٰتٍ : باغوں میں مُّكْرَمُوْنَ : عزت سے رکھے جانے والے ہیں یہی لوگ جنتوں میں عزت والے ہونگے۔
70,36,فَمَالِ الَّذِیْنَ كَفَرُوْا قِبَلَكَ مُهْطِعِیْنَۙ فَمَالِ الَّذِيْنَ : تو کیا ہے ان لوگوں کو كَفَرُوْا : جنہوں نے کفر کیا قِبَلَكَ : آپ کی طرف۔ آپ کے سامنے مُهْطِعِيْنَ : دوڑ کے آنے والے ہیں پس کافروں کو کیا ہوگیا ہے کہ وہ تیری طرف دوڑتے آتے ہیں۔
70,37,عَنِ الْیَمِیْنِ وَ عَنِ الشِّمَالِ عِزِیْنَ عَنِ الْيَمِيْنِ : دائیں طرف سے وَعَنِ الشِّمَالِ : اور بائیں طرف سے عِزِيْنَ : گرو درگروہ دائیں اور بائیں سے گروہ کے گروہ (1)
70,38,اَیَطْمَعُ كُلُّ امْرِئٍ مِّنْهُمْ اَنْ یُّدْخَلَ جَنَّةَ نَعِیْمٍۙ اَيَطْمَعُ : کیا لالچ رکھتا ہے كُلُّ امْرِۍ مِّنْهُمْ : ہر شخص ان میں سے اَنْ يُّدْخَلَ جَنَّةَ : کہ داخل کیا جائے جنت میں نَعِيْمٍ : نعمتوں بھری کیا ان میں سے ہر ایک کی توقع یہ ہے کہ وہ نعمتوں والی جنت میں داخل کیا جائے گا ؟
70,39,كَلَّا١ؕ اِنَّا خَلَقْنٰهُمْ مِّمَّا یَعْلَمُوْنَ كَلَّا : ہرگز نہیں اِنَّا خَلَقْنٰهُمْ : بیشک ہم نے، پیدا کیا ہم نے ان کو مِّمَّا يَعْلَمُوْنَ : اس سے جو وہ جانتے ہیں (ایسا) ہرگز نہ ہوگا ہم نے انہیں اس (چیز) سے پیدا کیا ہے جسے وہ جانتے ہیں (1)
70,40,فَلَاۤ اُقْسِمُ بِرَبِّ الْمَشٰرِقِ وَ الْمَغٰرِبِ اِنَّا لَقٰدِرُوْنَۙ فَلَآ : پس نہیں اُقْسِمُ : میں قسم کھاتا ہوں بِرَبِّ الْمَشٰرِقِ : مشرقوں کے رب کی وَالْمَغٰرِبِ : اور مغربوں کے اِنَّا لَقٰدِرُوْنَ : بیشک ہم البتہ قادر ہیں پس مجھے قسم ہے مشرقوں اور مغربوں (1) کے رب کی (کہ) ہم یقیناً قادر ہیں
70,41,عَلٰۤى اَنْ نُّبَدِّلَ خَیْرًا مِّنْهُمْ١ۙ وَ مَا نَحْنُ بِمَسْبُوْقِیْنَ عَلٰٓي : اس بات پر اَنْ نُّبَدِّلَ : کہ ہم بدل دیں خَيْرًا مِّنْهُمْ : بہتران سے وَمَا نَحْنُ : اور نہیں ہم بِمَسْبُوْقِيْنَ : سبقت لیے جانے والے اس پر ان کے عوض ان سے اچھے لوگ لے آئیں گے اور ہم عاجز نہیں ہیں (1)
70,42,فَذَرْهُمْ یَخُوْضُوْا وَ یَلْعَبُوْا حَتّٰى یُلٰقُوْا یَوْمَهُمُ الَّذِیْ یُوْعَدُوْنَۙ فَذَرْهُمْ : تو چھوڑ دو ان کو يَخُوْضُوْا : وہ بحثیں کریں وَيَلْعَبُوْا : اور کھیل میں پڑیں۔ کھیلتے رہیں حَتّٰى يُلٰقُوْا : یہاں تک کہ وہ آ ملیں يَوْمَهُمُ : اپنے دن کو الَّذِيْ : وہ جو يُوْعَدُوْنَ : وہ وعدہ کیے جاتے ہیں پس تو انہیں جھگڑتا کھیلتا چھوڑ دے یہاں تک کہ یہ اپنے اس دن سے جا ملیں جس کا ان سے وعدہ کیا جاتا ہے۔ (1)
70,43,یَوْمَ یَخْرُجُوْنَ مِنَ الْاَجْدَاثِ سِرَاعًا كَاَنَّهُمْ اِلٰى نُصُبٍ یُّوْفِضُوْنَۙ يَوْمَ يَخْرُجُوْنَ : جس دن وہ نکلیں گے مِنَ الْاَجْدَاثِ : قبروں سے سِرَاعًا : دوڑتے ہوئے كَاَنَّهُمْ : گویا کہ وہ اِلٰى نُصُبٍ : طرف آستانوں کے يُّوْفِضُوْنَ : دوڑتے ہیں جس دن یہ قبروں سے دوڑتے ہوئے نکلیں گے، گویا کہ وہ کسی جگہ کی طرف تیز تیز جا رہے ہیں۔ (1)
70,44,خَاشِعَةً اَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ١ؕ ذٰلِكَ الْیَوْمُ الَّذِیْ كَانُوْا یُوْعَدُوْنَ۠    ۧ خَاشِعَةً : دبی ہوئی ہوں گی۔ جھکی ہوئی ہوں گی اَبْصَارُهُمْ : ان کی نگاہیں تَرْهَقُهُمْ : چھا رہی ہوں گی ان پر ذِلَّةٌ : ذلت ذٰلِكَ : یہ ہے الْيَوْمُ : دن الَّذِيْ : جو كَانُوْا : وہ تھے يُوْعَدُوْنَ : وعدہ کیے گئے ان کی آنکھیں جھکی ہوئی ہونگیں (1) ان پر ذلت چھا رہی ہوگی (2) یہ ہے وہ دن جس کا ان سے وعدہ کیا جاتا تھا (3)۔
