quran[46]{c,v,t}:
79,1,وَ النّٰزِعٰتِ غَرْقًاۙ وَالنّٰزِعٰتِ : قسم ہے ان فرشتوں کی جو کھینچنے والے ہیں غَرْقًا : غرق ہوکر/ ڈوب کر ڈوب کر سختی سے کھنچنے والوں کی قسم (1)
79,2,وَّ النّٰشِطٰتِ نَشْطًاۙ وَّالنّٰشِطٰتِ : قسم ہے ان فرشتوں کی جو آسانی سے نکالنے والے ہیں نَشْطًا : نکال لینا بند کھول کر چھڑا دینے والوں کی قسم (1)
79,3,وَّ السّٰبِحٰتِ سَبْحًاۙ وَّالسّٰبِحٰتِ : قسم ہے ان فرشتوں کی جو تیرنے والے ہیں سَبْحًا : تیرنا اور تیرنے پھرنے والوں کی قسم (1)
79,4,فَالسّٰبِقٰتِ سَبْقًاۙ فَالسّٰبِقٰتِ : پھر آگے بڑھنے والوں کی/ سبقت کرنے والوں کی سَبْقًا : سبقت کرنا/ آگے بڑھنا پھر دوڑ کر آگے بڑھنے والوں کی قسم (1)
79,5,فَالْمُدَبِّرٰتِ اَمْرًاۘ فَالْمُدَبِّرٰتِ : پھر تدبیر کرنے والوں کی اَمْرًا : کام میں/ کام کی پھر کام کی تدبیر کرنے والوں کی قسم (1)
79,6,یَوْمَ تَرْجُفُ الرَّاجِفَةُۙ يَوْمَ : جس دن تَرْجُفُ : کانپے گی الرَّاجِفَةُ : کانپنے والی جس دن کا پنے والی کانپے گی (1)
79,7,تَتْبَعُهَا الرَّادِفَةُؕ تَتْبَعُهَا : پیچھے آئے گی اس کے الرَّادِفَةُ : پیچھے آنے والی اس کے بعد ایک پیچھے آنے والی (پیچھے پیچھے) آئے گی (1)
79,8,قُلُوْبٌ یَّوْمَئِذٍ وَّاجِفَةٌۙ قُلُوْبٌ : کچھ دل يَّوْمَئِذٍ : اس دن وَّاجِفَةٌ : دھڑکنے والے ہیں/ ہوں گے (بہت سے) دل اس دن دھڑ کتے ہونگے (1)
79,9,اَبْصَارُهَا خَاشِعَةٌۘ اَبْصَارُهَا : نگاہیں ان کی خَاشِعَةٌ : دبی ہوئی ہوں گی/ سہمی ہوئی ہوں گی جس کی نگاہیں نیچی ہونگی (1)
79,10,یَقُوْلُوْنَ ءَاِنَّا لَمَرْدُوْدُوْنَ فِی الْحَافِرَةِؕ يَقُوْلُوْنَ : کہتے ہیں ءَاِنَّا : کیا بیشک ہم لَمَرْدُوْدُوْنَ : البتہ پھیرے جانے والے ہیں فِي الْحَافِرَةِ : پہلی حالت میں کہتے ہیں کہ کیا پہلی کی سی حالت کی طرف لوٹائے جائیں گے (1)
79,11,ءَاِذَا كُنَّا عِظَامًا نَّخِرَةًؕ ءَاِذَا كُنَّا : کیا جب ہوں گے ہم عِظَامًا : ہڈیاں نَّخِرَةً : بھربھری/ گلی سڑی کیا اس وقت جب کہ ہم بوسیدہ ہڈیاں ہوجائیں گے (1)
79,12,قَالُوْا تِلْكَ اِذًا كَرَّةٌ خَاسِرَةٌۘ قَالُوْا تِلْكَ : انہوں نے کہا یہ اِذًا : تب كَرَّةٌ خَاسِرَةٌ : واپسی ہے گھاٹے کی/ خسارے کی کہتے ہیں کہ پھر تو یہ لوٹنا نقصان دہ ہے (1)
79,13,فَاِنَّمَا هِیَ زَجْرَةٌ وَّاحِدَةٌۙ فَاِنَّمَا ھِيَ : تو بیشک وہ زَجْرَةٌ : ایک ڈانٹ ہے وَّاحِدَةٌ : بس ایک ہی (معلوم ہونا چاہیئے) وہ تو صرف ایک (خوفناک) ڈانٹ ہے۔
79,14,فَاِذَا هُمْ بِالسَّاهِرَةِؕ فَاِذَا هُمْ : تو اچانک وہ بِالسَّاهِرَةِ : میدان میں ہوں گے کہ (جس کے ظاہر ہوتے ہی) وہ ایک دم میدان میں جمع ہوجائیں گے (1)
79,15,هَلْ اَتٰىكَ حَدِیْثُ مُوْسٰىۘ هَلْ اَتٰىكَ : کیا آئی ہے تیرے پاس حَدِيْثُ مُوْسٰى : بات موسیٰ کی کیا موسیٰ ؑ کی خبر تمہیں پہنچی ہے ؟
79,16,اِذْ نَادٰىهُ رَبُّهٗ بِالْوَادِ الْمُقَدَّسِ طُوًىۚ اِذْ نَادٰىهُ : جب پکارا اس کو رَبُّهٗ : اس کے رب نے بِالْوَادِ الْمُقَدَّسِ : مقدس وادی میں طُوًى : طویٰ کی جب کہ انہیں ان کے رب نے پاک میدان طویٰ میں پکارا (1)
79,17,اِذْهَبْ اِلٰى فِرْعَوْنَ اِنَّهٗ طَغٰى٘ۖ اِذْهَبْ اِلٰى : جاؤ، طرف فِرْعَوْنَ : فرعون کے اِنَّهٗ طَغٰى : بیشک وہ سرکش ہوگیا ہے یہ کہ تم فرعون کے پاس جاؤ اس نے سرکشی اختیار کرلی ہے (1)
79,18,فَقُلْ هَلْ لَّكَ اِلٰۤى اَنْ تَزَكّٰىۙ فَقُلْ : پس کہو هَلْ لَّكَ : کیا تیرے لئے ہے اِلٰٓى اَنْ : طرف اس بات کے کہ تَزَكّٰى : تو پاکیزگی اختیار کرے اس سے کہو کہ کیا تو اپنی درستگی اور اصلاح چاہتا ہے (1)
79,19,وَ اَهْدِیَكَ اِلٰى رَبِّكَ فَتَخْشٰىۚ وَاَهْدِيَكَ : اور میں رہنمائی کروں تیری اِلٰى رَبِّكَ : تیرے رب کی طرف فَتَخْشٰى : تاکہ تو ڈرے اور یہ کہ میں تجھے تیرے رب کی راہ دکھاؤں تاکہ تو (اس سے) ڈرنے لگے (1)
79,20,فَاَرٰىهُ الْاٰیَةَ الْكُبْرٰى٘ۖ فَاَرٰىهُ : پس دکھائی اس کو الْاٰيَةَ الْكُبْرٰى : بڑی نشانی پس اسے بڑی نشانی دکھائی (1)
79,21,فَكَذَّبَ وَعَصٰى٘ۖ فَكَذَّبَ : تو اس نے جھٹلادیا وَعَصٰى : اور نافرمانی کی تو اس نے جھٹلایا اور نافرمانی کی۔
79,22,ثُمَّ اَدْبَرَ یَسْعٰى٘ۖ ثُمَّ : پھر اَدْبَرَ : اس نے پیٹھ پھیری يَسْعٰى : دوڑتے ہوئے پھر پلٹا دوڑ دھوپ کرتے ہوئے (1)
79,23,فَحَشَرَ فَنَادٰى٘ۖ فَحَشَرَ : پھر اس نے اکٹھا کیا فَنَادٰى : پھر پکارا پھر سب کو جمع کر کے پکارا۔
79,24,فَقَالَ اَنَا رَبُّكُمُ الْاَعْلٰى٘ۖ فَقَالَ اَنَا : پھر کہا میں رَبُّكُمُ : تمہارا رب ہوں الْاَعْلٰى : سب سے اعلیٰ/ سب سے بڑا تم سب کا رب میں ہی ہوں۔
79,25,فَاَخَذَهُ اللّٰهُ نَكَالَ الْاٰخِرَةِ وَ الْاُوْلٰىؕ فَاَخَذَهُ اللّٰهُ : تو پکڑ لیا اس کو اللہ نے نَكَالَ الْاٰخِرَةِ : آخرت کے عذاب میں/ سزا میں وَالْاُوْلٰى : اور دنیا کے تو (سب سے بلند وبالا) اللہ نے بھی اسے آخرت کے اور دنیا کے عذاب میں گرفتار کرلیا (1)
79,26,اِنَّ فِیْ ذٰلِكَ لَعِبْرَةً لِّمَنْ یَّخْشٰى٢ؕ۠    ۧ اِنَّ فِيْ ذٰلِكَ : یقیناً اس میں لَعِبْرَةً : البتہ عبرت ہے لِّمَنْ يَّخْشٰى : واسطے اس کے جو ڈرتا ہو بیشک اس میں اس شخص کے لئے عبرت ہے جو ڈرے (1)
79,27,ءَاَنْتُمْ اَشَدُّ خَلْقًا اَمِ السَّمَآءُ١ؕ بَنٰىهَاٙ ءَاَنْتُمْ : کیا تم اَشَدُّ خَلْقًا : زیادہ سخت ہو تخلیق میں اَمِ السَّمَآءُ ۭ : یا آسمان بَنٰىهَا : اس نے بنایا اس کو کیا تمہارا پیدا کرنا زیادہ دشوار ہے یا آسمان کا ؟ اللہ نے اسے بنایا۔
79,28,رَفَعَ سَمْكَهَا فَسَوّٰىهَاۙ رَفَعَ : اٹھایا سَمْكَهَا : اس کی بلندی کو فَسَوّٰىهَا : پھر درست کردیا اس کو اس کی بلندی اونچی کی پھر اسے ٹھیک ٹھاک کردیا۔ (1)
79,29,وَ اَغْطَشَ لَیْلَهَا وَ اَخْرَجَ ضُحٰىهَا۪ وَاَغْطَشَ لَيْلَهَا : اور ڈھانک دیا اس کی رات کو وَاَخْرَجَ ضُحٰىهَا : اور نکالا اس کی دھوپ کو/ اس کے دن کو/ اگلا پہر اسکی رات کو تاریک بنایا اسکے دن کو روشن بنایا۔
79,30,وَ الْاَرْضَ بَعْدَ ذٰلِكَ دَحٰىهَاؕ وَالْاَرْضَ بَعْدَ : اور زمین کو بعد ذٰلِكَ : اس کے دَحٰىهَا : اس نے بچھا دیا اس کے بعد زمین کو (ہموار) بچھا دیا۔
79,31,اَخْرَجَ مِنْهَا مَآءَهَا وَ مَرْعٰىهَا۪ اَخْرَجَ مِنْهَا : اس نے نکالا اس سے مَآءَهَا : اس کا پانی وَمَرْعٰىهَا : اور اس کا چارہ اس میں سے پانی اور چارہ نکالا۔
79,32,وَ الْجِبَالَ اَرْسٰىهَاۙ وَالْجِبَالَ : اور پہاڑوں کو اَرْسٰىهَا : اس نے گاڑ دیا ان کو اور پہاڑوں کو (مضبوط) گاڑھ دیا۔
79,33,مَتَاعًا لَّكُمْ وَ لِاَنْعَامِكُمْؕ مَتَاعًا : فائدے کی چیزیں/ فائدے کا سامان لَّكُمْ : واسطے تمہارے وَلِاَنْعَامِكُمْ : اور تمہارے مویشیوں کے لئے یہ سب تمہارے اور تمہارے جانوروں کے فائدے کے لئے ہیں۔
79,34,فَاِذَا جَآءَتِ الطَّآمَّةُ الْكُبْرٰى٘ۖ فَاِذَا : پھر جب جَآءَتِ الطَّآمَّةُ : آجائے گی آفت الْكُبْرٰى : بڑی پس جب وہ بڑی آفت (قیامت) آجائے گی۔
79,35,یَوْمَ یَتَذَكَّرُ الْاِنْسَانُ مَا سَعٰىۙ يَوْمَ : اس دن يَتَذَكَّرُ الْاِنْسَانُ : یاد کرے گا انسان مَا سَعٰى : جو اس نے کوشش کی جس دن کے انسان اپنے کئے ہوئے کاموں کو یاد کرے گا۔
79,36,وَ بُرِّزَتِ الْجَحِیْمُ لِمَنْ یَّرٰى وَبُرِّزَتِ : اور کھول دی جائے گی/ ظاہر کردی جائے گی الْجَحِيْمُ : جہنم لِمَنْ يَّرٰى : واسطے اس کے جو دیکھتا ہو اور ہر دیکھنے والے کے سامنے جہنم ظاہر کی جائے گی۔
79,37,فَاَمَّا مَنْ طَغٰىۙ فَاَمَّا مَنْ طَغٰى : تو رہا وہ جس نے سرکشی کی تو جس (شخص) نے سرکشی کی (ہوگی) (1)
79,38,وَ اٰثَرَ الْحَیٰوةَ الدُّنْیَاۙ وَاٰثَرَ : اور ترجیح دی الْحَيٰوةَ الدُّنْيَا : دنیا کی زندگی کو اور دنیاوی زندگی کو ترجیح دی ہوگی۔
79,39,فَاِنَّ الْجَحِیْمَ هِیَ الْمَاْوٰىؕ فَاِنَّ : تو بیشک الْجَحِيْمَ : جہنم ہی ھِيَ الْمَاْوٰى : وہ ٹھکانہ ہوگی (اسکا) ٹھکانا جہنم ہی ہے۔
79,40,وَ اَمَّا مَنْ خَافَ مَقَامَ رَبِّهٖ وَ نَهَى النَّفْسَ عَنِ الْهَوٰىۙ وَاَمَّا مَنْ : اور رہا وہ جو خَافَ مَقَامَ : ڈرا کھڑے ہونے سے رَبِّهٖ : اپنے رب کے سامنے وَنَهَى : اور روکا اس نے النَّفْسَ : نفس کو عَنِ الْهَوٰى : خواہشات سے ہاں جو شخص اپنے رب کے سامنے کھڑے ہونے (1) سے ڈرتا رہا ہوگا اور اپنے نفس کو خواہش سے روکا ہوگا۔
79,41,فَاِنَّ الْجَنَّةَ هِیَ الْمَاْوٰىؕ فَاِنَّ الْجَنَّةَ : تو یقیناً جنت ہی ھِيَ الْمَاْوٰى : وہ ٹھکانہ ہوگی تو اس کا ٹھکانا جنت ہی ہے۔
79,42,یَسْئَلُوْنَكَ عَنِ السَّاعَةِ اَیَّانَ مُرْسٰىهَاؕ يَسْئَلُوْنَكَ : وہ سوال کرتے ہیں آپ سے عَنِ السَّاعَةِ : قیامت کے بارے میں اَيَّانَ مُرْسٰىهَا : کب ہے ٹھہرنا اس کا لوگ آپ سے قیامت کے واقع ہونے کا وقت دریافت کرتے ہیں (1)
79,43,فِیْمَ اَنْتَ مِنْ ذِكْرٰىهَاؕ فِيْمَ اَنْتَ : بیچ کس بات کے تو مِنْ ذِكْرٰىهَا : اس کے ذکر سے آپ کو اس کے بیان کرنے سے کیا تعلق ؟ (1)
79,44,اِلٰى رَبِّكَ مُنْتَهٰىهَاؕ اِلٰى رَبِّكَ : تیرے رب کی طرف مُنْتَهٰهَا : اس کی انتہاء ہے اس کے علم کی انتہا تو اللہ کی جانب ہے۔
79,45,اِنَّمَاۤ اَنْتَ مُنْذِرُ مَنْ یَّخْشٰىهَاؕ اِنَّمَآ : بیشک اَنْتَ مُنْذِرُ : تو خبردار کرنے والا ہے مَنْ يَّخْشٰىهَا : اس کو جو ڈرتا ہو اس سے آپ تو صرف اس سے ڈرتے رہنے والوں کو آگاہ کرنے والے ہیں (1)
79,46,كَاَنَّهُمْ یَوْمَ یَرَوْنَهَا لَمْ یَلْبَثُوْۤا اِلَّا عَشِیَّةً اَوْ ضُحٰىهَا۠    ۧ كَاَنَّهُمْ : گویا کہ وہ يَوْمَ يَرَوْنَهَا : جس دن وہ دیکھ لیں گے اس کو ( تو کہیں گے گویا کہ) لَمْ يَلْبَثُوْٓا : نہیں وہ ٹھہرے اِلَّا عَشِيَّةً : مگر شام کا وقت اَوْ ضُحٰىهَا : یا اس کی صبح جس روز یہ اسے دیکھ لیں گے تو ایسا معلوم ہوگا کہ صرف دن کا آخری حصہ یا اول حصہ ہی (دنیا میں) رہے ہیں (1)
