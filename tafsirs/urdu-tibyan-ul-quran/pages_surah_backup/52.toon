quran[49]{c,v,t}:
52,1,وَ الطُّوْرِۙ وَالطُّوْرِ : قسم ہے طور کی قسم ہے طور کی (1)
52,2,وَ كِتٰبٍ مَّسْطُوْرٍۙ وَكِتٰبٍ : اور کتاب کی مَّسْطُوْرٍ : لکھی ہوئی اور لکھی ہوئی کتاب کی (1)
52,3,فِیْ رَقٍّ مَّنْشُوْرٍۙ فِيْ رَقٍّ : جھلی میں مَّنْشُوْرٍ : پھیلی ہوئی جو جھلی کے کھلے ہوئے ورق میں ہے۔ (1)
52,4,وَّ الْبَیْتِ الْمَعْمُوْرِۙ وَّالْبَيْتِ : اور قسم ہے گھر کی الْمَعْمُوْرِ : آباد وہ آباد گھر کی (1)۔
52,5,وَ السَّقْفِ الْمَرْفُوْعِۙ وَالسَّقْفِ : اور چھت کی الْمَرْفُوْعِ : جو اونچی ہے اور اونچی چھت کی (1)
52,6,وَ الْبَحْرِ الْمَسْجُوْرِۙ وَالْبَحْرِ : اور سمندر کی الْمَسْجُوْرِ : جو موجزن ہے اور بھڑکائے ہوئے سمندر کی (1)
52,7,اِنَّ عَذَابَ رَبِّكَ لَوَاقِعٌۙ اِنَّ عَذَابَ : بیشک عذاب رَبِّكَ : تیرے رب کا لَوَاقِعٌ : البتہ واقع ہونے والا ہے بیشک آپ کے رب کا عذاب ہو کر رہنے والا ہے۔
52,8,مَّا لَهٗ مِنْ دَافِعٍۙ مَّا لَهٗ : نہیں اس کے لیے مِنْ دَافِعٍ : کوئی دور کرنے والا اسے کوئی روکنے والا نہیں۔ (1)
52,9,یَّوْمَ تَمُوْرُ السَّمَآءُ مَوْرًاۙ يَّوْمَ : جس دن تَمُوْرُ السَّمَآءُ : پھٹ جائے گا۔ لرزے گا، آسمان مَوْرًا : لرزنا۔ ڈگمگانا جس دن آسمان تھرتھرانے لگے گا (1)
52,10,وَّ تَسِیْرُ الْجِبَالُ سَیْرًاؕ وَّتَسِيْرُ : اور چلیں گے الْجِبَالُ : پہاڑ سَيْرًا : چلنا اور پہاڑ چلنے پھرنے لگیں گے۔
52,11,فَوَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَۙ فَوَيْلٌ : پس ہلاکت ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کے لیے اس دن جھٹلانے والوں کی (پوری) خرابی ہے۔
52,12,الَّذِیْنَ هُمْ فِیْ خَوْضٍ یَّلْعَبُوْنَۘ الَّذِيْنَ : وہ لوگ هُمْ : وہ فِيْ خَوْضٍ : جھگڑے میں يَّلْعَبُوْنَ : اچھل کود کر رہے ہیں جو اپنی بیہودہ گوئی میں اچھل کود رہے ہیں (1)
52,13,یَوْمَ یُدَعُّوْنَ اِلٰى نَارِ جَهَنَّمَ دَعًّاؕ يَوْمَ يُدَعُّوْنَ : جس دن دھکے دیئے جائیں گے ان کو اِلٰى نَارِ جَهَنَّمَ : جہنم کی آگ کی طرف دَعًّا : دھکے مارنا جس دن وہ دھکے دے (1) کر آتش جہنم کی طرف لائے جائیں گے۔
52,14,هٰذِهِ النَّارُ الَّتِیْ كُنْتُمْ بِهَا تُكَذِّبُوْنَ هٰذِهِ النَّارُ : یہ ہے آگ الَّتِيْ : وہ جو كُنْتُمْ : تھے تم بِهَا تُكَذِّبُوْنَ : اس کو تم جھٹلاتے یہی وہ آتش دوزخ ہے جسے تم جھوٹ بتلاتے تھے (1)۔
52,15,اَفَسِحْرٌ هٰذَاۤ اَمْ اَنْتُمْ لَا تُبْصِرُوْنَۚ اَفَسِحْرٌ ھٰذَآ : کیا بھلا جادو ہے یہ اَمْ اَنْتُمْ : یا تم لَا تُبْصِرُوْنَ : نہیں تم دیکھتے (اب بتاؤ) کیا یہ جادو ہے ؟ (1) یا تم دیکھتے نہیں (2)
52,16,اِصْلَوْهَا فَاصْبِرُوْۤا اَوْ لَا تَصْبِرُوْا١ۚ سَوَآءٌ عَلَیْكُمْ١ؕ اِنَّمَا تُجْزَوْنَ مَا كُنْتُمْ تَعْمَلُوْنَ اِصْلَوْهَا : جھلسو اس میں فَاصْبِرُوْٓا : پس صبر کرو اَوْ لَا تَصْبِرُوْا ۚ : یا نہ تم صبر کرو سَوَآءٌ عَلَيْكُمْ ۭ : برابر ہے تم پر اِنَّمَا تُجْزَوْنَ : بیشک تم بدلہ دیئے جاتے ہو مَا كُنْتُمْ : جو تھے تم تَعْمَلُوْنَ : تم عمل کرتے جاؤ دوزخ میں اب تمہارا صبر کرنا اور نہ کرنا تمہارے لئے یکساں ہے۔ تمہیں فقط تمہارے کئے کا بدل دیا جائے گا۔
52,17,اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ نَعِیْمٍۙ اِنَّ الْمُتَّقِيْنَ : یشک متقی لوگ فِيْ جَنّٰتٍ : باغوں میں وَّنَعِيْمٍ : اور نعمتوں میں ہوں گے یقیناً پرہیزگار لوگ جنتوں میں اور نعمتوں میں ہیں (1)
52,18,فٰكِهِیْنَ بِمَاۤ اٰتٰىهُمْ رَبُّهُمْ١ۚ وَ وَقٰىهُمْ رَبُّهُمْ عَذَابَ الْجَحِیْمِ فٰكِهِيْنَ : خوش ہوں گے بِمَآ اٰتٰىهُمْ رَبُّهُمْ ۚ : بوجہ اس کے جو دے گا ان کو ان کا رب وَوَقٰىهُمْ : اور بچا لے گا ان کو رَبُّهُمْ : ان کا رب عَذَابَ الْجَحِيْمِ : جہنم کے عذاب میں جو انہیں ان کے رب نے دے رکھی ہیں اس پر خوش خوش ہیں (1) اور ان کے پروردگار نے انہیں جہنم کے عذاب سے بچا لیا ہے۔
52,19,كُلُوْا وَ اشْرَبُوْا هَنِیْٓئًۢا بِمَا كُنْتُمْ تَعْمَلُوْنَۙ كُلُوْا : کھاؤ وَاشْرَبُوْا : اور پیو هَنِيْٓئًۢا : مزے سے بِمَا : بوجہ اس کے جو كُنْتُمْ : تھے تم تَعْمَلُوْنَ : تم عمل کرتے تم مزے سے کھاتے پیتے رہو ان اعمال کے بدلے جو تم کرتے تھے (1)۔
52,20,مُتَّكِئِیْنَ عَلٰى سُرُرٍ مَّصْفُوْفَةٍ١ۚ وَ زَوَّجْنٰهُمْ بِحُوْرٍ عِیْنٍ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے ہوں گے عَلٰي سُرُرٍ : اوپر تختوں کے مَّصْفُوْفَةٍ ۚ : صف باندھے ہوئے وَزَوَّجْنٰهُمْ : اور بیادہ دیں گے ہم ان کو بِحُوْرٍ عِيْنٍ : ساتھ سفید عورتوں کے، بڑی آنکھوں والی برابر بچھے ہوئے شاندار تختے پر تکیے لگائے ہوئے (1) اور ہم نے ان کے نکاح بڑی بڑی آنکھوں والی (حوروں) سے کرا دیئے ہیں۔
52,21,وَ الَّذِیْنَ اٰمَنُوْا وَ اتَّبَعَتْهُمْ ذُرِّیَّتُهُمْ بِاِیْمَانٍ اَلْحَقْنَا بِهِمْ ذُرِّیَّتَهُمْ وَ مَاۤ اَلَتْنٰهُمْ مِّنْ عَمَلِهِمْ مِّنْ شَیْءٍ١ؕ كُلُّ امْرِئٍۭ بِمَا كَسَبَ رَهِیْنٌ وَالَّذِيْنَ اٰمَنُوْا : اور وہ لوگ جو ایمان لائے وَاتَّبَعَتْهُمْ : اور پیروی کی ان کی ذُرِّيَّتُهُمْ : ان کی اولاد نے بِاِيْمَانٍ : ایمان کے ساتھ اَلْحَقْنَا بِهِمْ : ہم ملا دیں گے ان کے ساتھ ذُرِّيَّتَهُمْ : ان کی اولاد کو وَمَآ اَلَتْنٰهُمْ : اور نہ کمی کریں گے ہم ان کے مِّنْ عَمَلِهِمْ : ان کے عمل میں سے مِّنْ شَيْءٍ ۭ : کچھ بھی كُلُّ امْرِی : ہر شخص بِمَا كَسَبَ : ساتھ اس کے جو اس نے کمائی کی رَهِيْنٌ : رھن ہے۔ گروی ہے اور جو لوگ ایمان لائے اور ان کی اولاد نے بھی ایمان میں ان کی پیروی کی ہم ان کی اولاد کو ان تک پہنچا دیں گے اور ان کے عمل سے ہم کچھ کم نہ کریں گے (1) ہر شخص اپنے اپنے اعمال کا گروی ہے (2)
52,22,وَ اَمْدَدْنٰهُمْ بِفَاكِهَةٍ وَّ لَحْمٍ مِّمَّا یَشْتَهُوْنَ وَاَمْدَدْنٰهُمْ : اور مدد دیں گے ہم ان کو۔ زیادہ دیں گے ہم ان کو۔ پے در پے دیں گے ہم ان کو بِفَاكِهَةٍ : پھل وَّلَحْمٍ : اور گوشت مِّمَّا يَشْتَهُوْنَ : اس میں سے جو وہ خواہش کریں گے ہم نے ان کے لئے میوے اور مرغوب گوشت کی ریل پیل کردیں گے (1)
52,23,یَتَنَازَعُوْنَ فِیْهَا كَاْسًا لَّا لَغْوٌ فِیْهَا وَ لَا تَاْثِیْمٌ يَتَنَازَعُوْنَ : ایک دوسرے سے چھینیں گے فِيْهَا : اس میں كَاْسًا : جام میں۔ پیالوں میں لَّا لَغْوٌ فِيْهَا : نہ کوئی بےہودہ گوئی ہوگی اس میں وَلَا تَاْثِيْمٌ : اور نہ کوئی گناہ (خوش طبعی کے ساتھ) ایک دوسرے سے جام (شراب) چھینا جھپٹی کریں گے (1) جس شراب کے سرور میں تو بیہودہ گوئی ہوگی نہ گناہ (2)
52,24,وَ یَطُوْفُ عَلَیْهِمْ غِلْمَانٌ لَّهُمْ كَاَنَّهُمْ لُؤْلُؤٌ مَّكْنُوْنٌ وَيَطُوْفُ : اور گھوم رہے ہوں گے عَلَيْهِمْ : ان پر غِلْمَانٌ لَّهُمْ : نو عمر خادم ان کے لیے كَاَنَّهُمْ لُؤْلُؤٌ : گویا کہ وہ موتی ہیں مَّكْنُوْنٌ : چھپے ہوئے۔ چھپا کر رکھے ہوئے اور ان کے ارد گرد ان کے نو عمر غلام پھر رہے ہونگے، گویا موتی تھے جو ڈھکے رکھے تھے (1)
52,25,وَ اَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ وَاَقْبَلَ : اور متوجہ ہوں گے بَعْضُهُمْ : ان میں سے بعض عَلٰي بَعْضٍ : بعض پر يَّتَسَآءَلُوْنَ : ایک دوسرے سے سوال کریں گے اور آپس میں ایک دوسرے کی طرف متوجہ ہو کر سوال کریں گے (1)
52,26,قَالُوْۤا اِنَّا كُنَّا قَبْلُ فِیْۤ اَهْلِنَا مُشْفِقِیْنَ قَالُوْٓا اِنَّا : کہیں گے بیشک ہم كُنَّا : تھے ہم قَبْلُ : اس سے پہلے فِيْٓ اَهْلِنَا : اپنے گھر والوں میں مُشْفِقِيْنَ : ڈرنے والے کہیں گے کہ اس سے پہلے ہم اپنے گھر والوں کے درمیان بہت ڈرا کرتے تھے (1)
52,27,فَمَنَّ اللّٰهُ عَلَیْنَا وَ وَقٰىنَا عَذَابَ السَّمُوْمِ فَمَنَّ اللّٰهُ : پس احسان کیا اللہ نے عَلَيْنَا : ہم پر وَوَقٰىنَا : اور بچا لیا ہم کو عَذَابَ السَّمُوْمِ : لُو کے عذاب سے پس اللہ تعالیٰ نے ہم پر بڑا احسان کیا اور ہمیں تیز و تند گرم ہواؤں کے عذاب سے بچا لیا (1)
52,28,اِنَّا كُنَّا مِنْ قَبْلُ نَدْعُوْهُ١ؕ اِنَّهٗ هُوَ الْبَرُّ الرَّحِیْمُ۠    ۧ اِنَّا : بیشک ہم كُنَّا : تھے ہم مِنْ قَبْلُ : اس سے پہلے نَدْعُوْهُ ۭ : اس سے دعا کرتے۔ اسی کو پکارا کرتے اِنَّهٗ : بیشک وہ هُوَ الْبَرُّ : وہی محسن ہے الرَّحِيْمُ : رحم فرمانے والا ہے ہم اس سے پہلے ہی اس کی عبادت کیا کرتے تھے بیشک وہ محسن اور مہربان ہے۔ (1)
52,29,فَذَكِّرْ فَمَاۤ اَنْتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَّ لَا مَجْنُوْنٍؕ فَذَكِّرْ : پس نصیحت کیجیے فَمَآ اَنْتَ : پس نہیں آپ بِنِعْمَتِ : نعمت سے رَبِّكَ : اپنے رب کی بِكَاهِنٍ : کا ھن وَّلَا مَجْنُوْنٍ : اور نہ مجنون تو آپ سمجھاتے رہیں کیونکہ آپ اپنے رب کے فضل سے نہ تو کاہن ہیں نہ دیوانہ (1)
52,30,اَمْ یَقُوْلُوْنَ شَاعِرٌ نَّتَرَبَّصُ بِهٖ رَیْبَ الْمَنُوْنِ اَمْ يَقُوْلُوْنَ : یا وہ کہتے ہیں شَاعِرٌ : ایک شاعر ہے نَّتَرَبَّصُ : ہم انتظار کر رہے ہیں بِهٖ : اس کے بارے میں رَيْبَ : حوادث کا الْمَنُوْنِ : موت کے۔ زمانے کے کیا کافر یوں کہتے ہیں کہ یہ شاعر ہے ہم اس پر زمانے کے حوادث (یعنی موت) کا انتظار کر رہے ہیں (1)۔
52,31,قُلْ تَرَبَّصُوْا فَاِنِّیْ مَعَكُمْ مِّنَ الْمُتَرَبِّصِیْنَؕ قُلْ : کہہ دیجیے تَرَبَّصُوْا : انتظار کرو فَاِنِّىْ : پس بیشک میں مَعَكُمْ : تمہارے ساتھ مِّنَ الْمُتَرَبِّصِيْنَ : انتظار کرنے والوں میں سے ہوں کہہ دیجئے ! تم منتظر رہو میں بھی تمہارے ساتھ انتظار کرنے والوں میں ہوں (1)
52,32,اَمْ تَاْمُرُهُمْ اَحْلَامُهُمْ بِهٰذَاۤ اَمْ هُمْ قَوْمٌ طَاغُوْنَۚ اَمْ تَاْمُرُهُمْ : یا حکم دیتی ہیں ان کو اَحْلَامُهُمْ : ان کی عقلیں بِھٰذَآ : اس کا اَمْ هُمْ : یا وہ قَوْمٌ طَاغُوْنَ : لوگ ہیں سرکش کیا ان کی عقلیں انہیں یہی سکھاتی ہیں (1) یا یہ لوگ ہی سرکش ہیں (2)
52,33,اَمْ یَقُوْلُوْنَ تَقَوَّلَهٗ١ۚ بَلْ لَّا یُؤْمِنُوْنَۚ اَمْ يَقُوْلُوْنَ : یا وہ کہتے ہیں تَقَوَّلَهٗ ۚ : اس نے گھڑ لیا اس کو بَلْ لَّا : بلکہ نہیں يُؤْمِنُوْنَ : وہ ایمان لاتے کیا یہ کہتے ہیں اس نبی نے (قرآن) خود گھڑ لیا ہے، واقع یہ ہے کہ وہ ایمان نہیں لاتے۔ (1)
52,34,فَلْیَاْتُوْا بِحَدِیْثٍ مِّثْلِهٖۤ اِنْ كَانُوْا صٰدِقِیْنَؕ فَلْيَاْتُوْا : پس چاہیے کہ وہ لائیں بِحَدِيْثٍ مِّثْلِهٖٓ : کوئی بات اس جیسی اِنْ كَانُوْا : اگر ہیں وہ صٰدِقِيْنَ : سچے اچھا اگر یہ سچے ہیں تو بھلا اس جیسی ایک (ہی) بات یہ (بھی) تو لے آئیں (1)
52,35,اَمْ خُلِقُوْا مِنْ غَیْرِ شَیْءٍ اَمْ هُمُ الْخٰلِقُوْنَؕ اَمْ خُلِقُوْا : یا وہ پیدا کیے گئے مِنْ غَيْرِ شَيْءٍ : بغیر کسی چیز کے اَمْ هُمُ الْخٰلِقُوْنَ : یا وہ خالق ہیں۔ بنانے والے ہیں کیا یہ بغیر کسی (پیدا کرنے والے) کے خود بخود پیدا ہوگئے ہیں ؟ (1) یا خود پیدا کرنے والے ہیں۔ (2)
52,36,اَمْ خَلَقُوا السَّمٰوٰتِ وَ الْاَرْضَ١ۚ بَلْ لَّا یُوْقِنُوْنَؕ اَمْ خَلَقُوا : یا انہوں نے پیدا کیے السَّمٰوٰتِ : آسمان وَالْاَرْضَ ۚ : اور زمین بَلْ لَّا يُوْقِنُوْنَ : بلکہ وہ یقین نہیں کرتے کیا انہوں نے ہی آسمان اور زمین کو پیدا کیا ہے، بلکہ یہ یقین نہ کرنے والے لوگ ہیں (1)
52,37,اَمْ عِنْدَهُمْ خَزَآئِنُ رَبِّكَ اَمْ هُمُ الْمُصَۜیْطِرُوْنَؕ اَمْ عِنْدَهُمْ : یا ان کے پاس خَزَآئِنُ : خزانے ہیں رَبِّكَ : تیرے رب کے اَمْ هُمُ الْمُصَۜيْطِرُوْنَ : یا وہ محفاظ ہیں۔ داروغہ ہیں یا کیا ان کے پاس تیرے رب کے خزانے ہیں ؟ (1) یا (ان خزانوں کے) یہ دروغہ ہیں۔ (2)
52,38,اَمْ لَهُمْ سُلَّمٌ یَّسْتَمِعُوْنَ فِیْهِ١ۚ فَلْیَاْتِ مُسْتَمِعُهُمْ بِسُلْطٰنٍ مُّبِیْنٍؕ اَمْ لَهُمْ سُلَّمٌ : یا ان کے لیے کوئی سیڑھی ہے يَّسْتَمِعُوْنَ فِيْهِ ۚ : وہ غور سے سنتے ہیں اس میں (چڑھ کر) فَلْيَاْتِ : پس چاہیے کہ لائے مُسْتَمِعُهُمْ : ان کا سننے والا بِسُلْطٰنٍ مُّبِيْنٍ : کھلی دلیل یا کیا ان کے پاس کوئی سیڑھی ہے جس پر چڑھ کر سنتے ہیں ؟ (1) (اگر ایسا ہے) تو ان کا سننے والا کوئی روشن دلیل پیش کرے
52,39,اَمْ لَهُ الْبَنٰتُ وَ لَكُمُ الْبَنُوْنَؕ اَمْ لَهُ الْبَنٰتُ : یا اس کے لیے ہیں بیٹیاں وَلَكُمُ الْبَنُوْنَ : اور تمہارے لیے ہیں بیٹے کیا اللہ کے تو سب لڑکیاں ہیں اور تمہارے ہاں لڑکے ہیں ؟
52,40,اَمْ تَسْئَلُهُمْ اَجْرًا فَهُمْ مِّنْ مَّغْرَمٍ مُّثْقَلُوْنَؕ اَمْ تَسْئَلُهُمْ اَجْرًا : یا تم مانگتے ہو ان سے کوئی اجر فَهُمْ مِّنْ مَّغْرَمٍ : تو وہ تاوان سے مُّثْقَلُوْنَ : بوجھل ہورہے ہیں کیا تو ان سے کوئی اجرت طلب کرتا ہے کہ یہ اس کے تاوان سے بو جھل ہو رہے ہیں (1)۔
52,41,اَمْ عِنْدَهُمُ الْغَیْبُ فَهُمْ یَكْتُبُوْنَؕ اَمْ : یا عِنْدَهُمُ الْغَيْبُ : ان کے پاس غیب ہے فَهُمْ يَكْتُبُوْنَ : تو وہ لکھ رہے ہیں کیا ان کے پاس علم غیب ہے جسے یہ لکھ لیتے ہیں ؟ (1)
52,42,اَمْ یُرِیْدُوْنَ كَیْدًا١ؕ فَالَّذِیْنَ كَفَرُوْا هُمُ الْمَكِیْدُوْنَؕ اَمْ يُرِيْدُوْنَ : یا وہ چاہتے ہیں كَيْدًا ۭ : ایک چال فَالَّذِيْنَ كَفَرُوْا : تو وہ لوگ جنہوں نے کفر کیا هُمُ الْمَكِيْدُوْنَ : وہ مکر کیے گئے ہیں کیا یہ لوگ کوئی فریب کرنا چاہتے ہیں ؟ (1) تو یقین کرلیں کہ فریب خوردہ کافر ہی ہیں۔ (2)
52,43,اَمْ لَهُمْ اِلٰهٌ غَیْرُ اللّٰهِ١ؕ سُبْحٰنَ اللّٰهِ عَمَّا یُشْرِكُوْنَ اَمْ لَهُمْ : یا ان کے لیے اِلٰهٌ غَيْرُ اللّٰهِ ۭ : کوئی الہ ہے اللہ کے سوا سُبْحٰنَ اللّٰهِ : پاک ہے اللہ عَمَّا يُشْرِكُوْنَ : اس سے جو وہ شریک ٹھہراتے ہیں کیا اللہ کے سوا کوئی معبود ہے ؟ (ہرگز نہیں) اللہ تعالیٰ ان کے شرک سے پاک ہے۔
52,44,وَ اِنْ یَّرَوْا كِسْفًا مِّنَ السَّمَآءِ سَاقِطًا یَّقُوْلُوْا سَحَابٌ مَّرْكُوْمٌ وَاِنْ : اور اگر يَّرَوْا كِسْفًا : وہ دیکھیں ایک ٹکڑا مِّنَ السَّمَآءِ : آسمان سے سَاقِطًا : گرنے والا يَّقُوْلُوْا : وہ کہیں گے سَحَابٌ : بادل ہیں مَّرْكُوْمٌ : تہ بہ تہ اگر یہ لوگ آسمان کے کسی ٹکڑے کو گرتا ہوا دیکھ لیں تب بھی کہہ دیں کہ یہ تہ بتہ بادل ہے (1)
52,45,فَذَرْهُمْ حَتّٰى یُلٰقُوْا یَوْمَهُمُ الَّذِیْ فِیْهِ یُصْعَقُوْنَۙ فَذَرْهُمْ : پس چھوڑو ان کو حَتّٰى يُلٰقُوْا : یہاں تک کہ وہ جا ملیں يَوْمَهُمُ : اپنے دن سے الَّذِيْ : وہ جو فِيْهِ : اس میں يُصْعَقُوْنَ : بےہوش کیے جائیں گے تو انہیں چھوڑ دے یہاں تک کہ انہیں اس دن سے سابقہ پڑے جس میں یہ بےہوش کردیئے جائیں گے۔
52,46,یَوْمَ لَا یُغْنِیْ عَنْهُمْ كَیْدُهُمْ شَیْئًا وَّ لَا هُمْ یُنْصَرُوْنَؕ يَوْمَ لَا يُغْنِيْ عَنْهُمْ : جس دن نہ کام آئے گی ان کو كَيْدُهُمْ : ان کی چال شَيْئًا : کچھ بھی وَّلَا هُمْ : اور نہ وہ يُنْصَرُوْنَ : وہ مدد کیے جائیں گے جس دن انہیں ان کا مکر کچھ کام نہ دے گا اور نہ وہ مدد کئے جائیں گے۔
52,47,وَ اِنَّ لِلَّذِیْنَ ظَلَمُوْا عَذَابًا دُوْنَ ذٰلِكَ وَ لٰكِنَّ اَكْثَرَهُمْ لَا یَعْلَمُوْنَ وَاِنَّ لِلَّذِيْنَ : اور بیشک ان لوگوں کے لیے ظَلَمُوْا : جنہوں نے ظلم کیا عَذَابًا : عذاب ہے دُوْنَ ذٰلِكَ : اس کے علاوہ وَلٰكِنَّ اَكْثَرَهُمْ : لیکن ان میں سے اکثر لَا يَعْلَمُوْنَ : علم نہیں رکھتے بیشک ظالموں کے لئے اس کے علاوہ اور عذاب بھی ہیں (1) لیکن ان لوگوں میں سے اکثر بےعلم ہیں (2)
52,48,وَ اصْبِرْ لِحُكْمِ رَبِّكَ فَاِنَّكَ بِاَعْیُنِنَا وَ سَبِّحْ بِحَمْدِ رَبِّكَ حِیْنَ تَقُوْمُۙ وَاصْبِرْ : اور صبر کیجیے لِحُكْمِ رَبِّكَ : اپنے رب کے فیصلے کے لیے فَاِنَّكَ بِاَعْيُنِنَا : پس بیشک آپ ہماری نگاہوں میں ہیں وَسَبِّحْ بِحَمْدِ رَبِّكَ : اور تسبیح کیجیئے اپنے رب کی حمد کے ساتھ حِيْنَ : جس وقت تَقُوْمُ : آپ کھڑے ہوتے ہیں تو اپنے رب کے حکم کے انتظار میں صبر سے کام لے، بیشک تو ہماری آنکھوں کے سامنے ہے۔ صبح کو جب تو اٹھے (1) اپنے رب کی پاکی اور حمد بیان کر۔
52,49,وَ مِنَ الَّیْلِ فَسَبِّحْهُ وَ اِدْبَارَ النُّجُوْمِ۠    ۧ وَمِنَ الَّيْلِ : اور رات کے اوقات میں سے فَسَبِّحْهُ : پس تسبیح کیجیے اس کی وَاِدْبَارَ النُّجُوْمِ : اور ستاروں کے پلٹنے کے وقت اور رات کو بھی اس کی تسبیح پڑھ اور ستاروں کے ڈوبتے وقت بھی (1)
