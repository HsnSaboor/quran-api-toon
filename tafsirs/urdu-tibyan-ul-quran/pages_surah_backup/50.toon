quran[45]{c,v,t}:
50,1,قٓ١ۚ۫ وَ الْقُرْاٰنِ الْمَجِیْدِۚ قٓ : قاف وَالْقُرْاٰنِ : قسم ہے قرآن کی الْمَجِيْدِ : مجید ق ! بہت بڑی شان والے اس قرآن کی قسم ہے (1)
50,2,بَلْ عَجِبُوْۤا اَنْ جَآءَهُمْ مُّنْذِرٌ مِّنْهُمْ فَقَالَ الْكٰفِرُوْنَ هٰذَا شَیْءٌ عَجِیْبٌۚ بَلْ : بلکہ عَجِبُوْٓا : انہوں نے تعجب کیا اَنْ جَآءَهُمْ : کہ ان کے پاس آیا مُّنْذِرٌ : ایک ڈر سنانے والا مِّنْهُمْ : ان میں سے فَقَالَ : تو کہا الْكٰفِرُوْنَ : کافروں ھٰذَا شَيْءٌ : یہ بات عَجِيْبٌ : عجیب بلکہ انہیں تعجب معلوم ہوا کہ ان کے پاس انہی میں سے ایک آگاہ کرنے والا آیا تو کافروں نے کہا کہ یہ ایک عجیب چیز ہے (1)
50,3,ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا١ۚ ذٰلِكَ رَجْعٌۢ بَعِیْدٌ ءَاِذَا مِتْنَا : کیا جب ہم مرگئے وَكُنَّا تُرَابًا ۚ : اور ہوگئے مٹی ذٰلِكَ رَجْعٌۢ : یہ دوبارہ لوٹنا بَعِيْدٌ : دور کیا جب ہم مر کر مٹی ہوجائیں گے۔ پھر یہ واپسی دور (از عقل) ہے (1)
50,4,قَدْ عَلِمْنَا مَا تَنْقُصُ الْاَرْضُ مِنْهُمْ١ۚ وَ عِنْدَنَا كِتٰبٌ حَفِیْظٌ قَدْ عَلِمْنَا : تحقیق ہم نے جان لیا مَا تَنْقُصُ الْاَرْضُ : اس کا بھی جو کمی کرتی ہے زمین مِنْهُمْ ۚ : ان میں سے وَعِنْدَنَا : اور ہمارے پاس كِتٰبٌ حَفِيْظٌ : ایک کتاب ہے محفوظ۔ حفاظت کرنے والی زمین جو کچھ ان میں سے گھٹاتی ہے وہ ہمیں معلوم ہے اور ہمارے پاس سب یاد رکھنے والی کتاب ہے (1)۔
50,5,بَلْ كَذَّبُوْا بِالْحَقِّ لَمَّا جَآءَهُمْ فَهُمْ فِیْۤ اَمْرٍ مَّرِیْجٍ بَلْ : بلکہ كَذَّبُوْا : انہوں نے جھٹلایا بِالْحَقِّ : حق کو لَمَّا : جب وہ آیا جَآءَهُمْ : ان کے پاس فَهُمْ : پس وہ فِيْٓ اَمْرٍ : ایک بات میں مَّرِيْجٍ : الجھی ہوئی بلکہ انہوں نے سچی بات کو جھوٹ کہا جبکہ وہ ان کے پاس پہنچ چکی پس وہ الجھاؤ میں پڑگئے ہیں (1)۔
50,6,اَفَلَمْ یَنْظُرُوْۤا اِلَى السَّمَآءِ فَوْقَهُمْ كَیْفَ بَنَیْنٰهَا وَ زَیَّنّٰهَا وَ مَا لَهَا مِنْ فُرُوْجٍ اَفَلَمْ يَنْظُرُوْٓا : تو کیا وہ نہیں دیکھتے اِلَى السَّمَآءِ : آسمان کی طرف فَوْقَهُمْ : ان کے اوپر كَيْفَ : کیسے بَنَيْنٰهَا : بنایا اس کو وَزَيَّنّٰهَا : اور اسکو آراستہ کیا وَمَا لَهَا : اور اس میں نہیں مِنْ فُرُوْجٍ : کوئی شگاف کیا انہوں نے آسمان کو اپنے اوپر نہیں دیکھا ؟ کہ ہم نے اسے کس طرح بنایا (1) ہے اور زینت دی (2) ہے اس میں کوئی شگاف نہیں۔ (3)
50,7,وَ الْاَرْضَ مَدَدْنٰهَا وَ اَلْقَیْنَا فِیْهَا رَوَاسِیَ وَ اَنْۢبَتْنَا فِیْهَا مِنْ كُلِّ زَوْجٍۭ بَهِیْجٍۙ وَالْاَرْضَ : اور زمین مَدَدْنٰهَا : ہم نے پھیلایا وَاَلْقَيْنَا : اور ڈالے (جمائے) فِيْهَا : اس میں رَوَاسِيَ : پہاڑ (جمع) وَاَنْۢبَتْنَا فِيْهَا : اور اگائے اس میں مِنْ كُلِّ زَوْجٍۢ : ہر قسم سے ، کے بَهِيْجٍ : خوشنما اور زمین کو ہم نے بچھا دیا ہے اور اس میں ہم نے پہاڑ ڈال دیئے ہیں اور اس میں ہم نے قسم قسم کی خوشنما چیزیں اگا دیں ہیں (1)
50,8,تَبْصِرَةً وَّ ذِكْرٰى لِكُلِّ عَبْدٍ مُّنِیْبٍ تَبْصِرَةً : ذریعۂ بینائی وَّذِكْرٰى : اور نصیحت لِكُلِّ : لئے، ہر عَبْدٍ مُّنِيْبٍ : رجوع کرنیوالا بندہ تاکہ ہر رجوع کرنے والے بندے کے لئے بینائی اور دانائی کا ذریعہ ہو۔ (1)
50,9,وَ نَزَّلْنَا مِنَ السَّمَآءِ مَآءً مُّبٰرَكًا فَاَنْۢبَتْنَا بِهٖ جَنّٰتٍ وَّ حَبَّ الْحَصِیْدِۙ وَنَزَّلْنَا : اور ہم نے اتارا مِنَ السَّمَآءِ : آسمان سے مَآءً مُّبٰرَكًا : پانی بابرکت فَاَنْۢبَتْنَا : پھر ہم نے اگائے بِهٖ : اس سے جَنّٰتٍ : باغات وَّحَبَّ : اور دانہ (غلہ) الْحَصِيْدِ : کاٹنے (کھیتی) اور ہم نے آسمان سے بابرکت پانی برسایا اور اس سے باغات اور کٹنے والے کھیت کے غلے پیدا کئے۔ (1)
50,10,وَ النَّخْلَ بٰسِقٰتٍ لَّهَا طَلْعٌ نَّضِیْدٌۙ وَالنَّخْلَ : اور کھجور کے درخت بٰسِقٰتٍ : بلند و بالا لَّهَا طَلْعٌ : جن کے خوشے نَّضِيْدٌ : تہ بہ تہ اور کھجوروں کے بلند وبالا درخت جن کے خوشے تہ بہ تہ ہیں۔ (1)
50,11,رِّزْقًا لِّلْعِبَادِ١ۙ وَ اَحْیَیْنَا بِهٖ بَلْدَةً مَّیْتًا١ؕ كَذٰلِكَ الْخُرُوْجُ رِّزْقًا : رزق لِّلْعِبَادِ ۙ : بندوں کیلئے وَاَحْيَيْنَا : اور ہم نے زندہ کیا بِهٖ : اس سے بَلْدَةً : شہر (زمین) مَّيْتًا ۭ : مردہ كَذٰلِكَ : اسی طرح الْخُرُوْجُ : نکلنا بندوں کی روزی کے لئے اور ہم نے پانی سے مردہ شہر کو زندہ کردیا۔ اسی طرح (قبروں سے) نکلنا (1)
50,12,كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ وَّ اَصْحٰبُ الرَّسِّ وَ ثَمُوْدُۙ كَذَّبَتْ : جھٹلایا قَبْلَهُمْ : ان سے قبل قَوْمُ نُوْحٍ : نوح کی قوم وَّاَصْحٰبُ : اور اہلِ الرَّسِّ : رس وَثَمُوْدُ : اور ثمود ان سے پہلے نوح کی قوم نے اور رس والوں (1) نے اور ثمود نے۔
50,13,وَ عَادٌ وَّ فِرْعَوْنُ وَ اِخْوَانُ لُوْطٍۙ وَعَادٌ : اور عاد وَّفِرْعَوْنُ : اور فرعون وَاِخْوَانُ : اور بھائی (جمع) لُوْطٍ : لوط اور عاد نے اور فرعون نے اور برادران لوط نے۔
50,14,وَّ اَصْحٰبُ الْاَیْكَةِ وَ قَوْمُ تُبَّعٍ١ؕ كُلٌّ كَذَّبَ الرُّسُلَ فَحَقَّ وَعِیْدِ وَّ اَصْحٰبُ الْاَيْكَةِ : اور اہل ایکہ (بن کے رہنے والے) وَقَوْمُ تُبَّعٍ ۭ : اور قوم تبع كُلٌّ كَذَّبَ : سب نے جھٹلایا الرُّسُلَ : رسولوں فَحَقَّ : پس ثابت ہوگیا وَعِيْدِ : وعدۂ عذاب اور ایکہ (1) والوں نے اور تبع کی قوم (2) نے بھی تکذیب کی تھی۔ سب نے پیغمبروں کو جھٹلایا (3) پس میرا وعدہ عذاب ان پر صادق آگیا۔
50,15,اَفَعَیِیْنَا بِالْخَلْقِ الْاَوَّلِ١ؕ بَلْ هُمْ فِیْ لَبْسٍ مِّنْ خَلْقٍ جَدِیْدٍ۠    ۧ اَفَعَيِيْنَا : تو کیا ہم تھک گئے بِالْخَلْقِ : پیدا کرنے سے الْاَوَّلِ ۭ : پہلی بار بَلْ : بلکہ هُمْ : وہ فِيْ لَبْسٍ : شک میں مِّنْ : سے خَلْقٍ جَدِيْدٍ : پیدا کرنا ازسر نو کیا ہم پہلی بار پیدا کرنے سے تھک گئے ؟ (1) بلکہ یہ لوگ نئی پیدائش کی طرف سے شک میں ہیں (2)
50,16,وَ لَقَدْ خَلَقْنَا الْاِنْسَانَ وَ نَعْلَمُ مَا تُوَسْوِسُ بِهٖ نَفْسُهٗ١ۖۚ وَ نَحْنُ اَقْرَبُ اِلَیْهِ مِنْ حَبْلِ الْوَرِیْدِ وَلَقَدْ : اور تحقیق خَلَقْنَا : ہم نے پیدا کیا الْاِنْسَانَ : انسان وَنَعْلَمُ : اور ہم جانتے ہیں مَا تُوَسْوِسُ : جو وسوسے گزرتے ہیں بِهٖ : اس کے نَفْسُهٗ ښ : اس کا جی وَنَحْنُ : اور ہم اَقْرَبُ : بہت قریب اِلَيْهِ : اس کے مِنْ : سے حَبْلِ الْوَرِيْدِ : رگِ گردن (جان) ہم نے انسان کو پیدا کیا اور اس کے دل میں جو خیالات اٹھتے ہیں ان سے ہم واقف ہیں (1) اور ہم اس کی رگ جان سے بھی زیادہ اس سے قریب ہیں (2)
50,17,اِذْ یَتَلَقَّى الْمُتَلَقِّیٰنِ عَنِ الْیَمِیْنِ وَ عَنِ الشِّمَالِ قَعِیْدٌ اِذْ يَتَلَقَّى : جب لیتے (لکھ لیتے) ہیں الْمُتَلَقِّيٰنِ : دولینے (لکھ لینے) والے عَنِ الْيَمِيْنِ : دائیں سے وَعَنِ الشِّمَالِ : اور بائیں سے قَعِيْدٌ : بیٹھا ہوا جس وقت دو لینے والے جا لیتے ہیں ایک دائیں طرف اور ایک بائیں طرف بیٹھا ہوا ہے۔
50,18,مَا یَلْفِظُ مِنْ قَوْلٍ اِلَّا لَدَیْهِ رَقِیْبٌ عَتِیْدٌ مَا : اور نہیں يَلْفِظُ : نکالتا مِنْ : کوئی قَوْلٍ : بات اِلَّا : مگر لَدَيْهِ : اس کے پاس رَقِيْبٌ : ایک نگہبان عَتِيْدٌ : تیار بیٹھا ہوا (انسان) منہ سے کوئی لفظ نکال نہیں پاتا مگر اس کے پاس نگہبان تیار ہے (1)۔
50,19,وَ جَآءَتْ سَكْرَةُ الْمَوْتِ بِالْحَقِّ١ؕ ذٰلِكَ مَا كُنْتَ مِنْهُ تَحِیْدُ وَجَآءَتْ : اور آگئی سَكْرَةُ الْمَوْتِ : موت کی بیہوشی بِالْحَقِّ ۭ : حق کے ساتھ ذٰلِكَ : یہ مَا كُنْتَ : جس سے تو تھا مِنْهُ : اس سے تَحِيْدُ : بھاگتا (بدکتا) اور موت کی بےہوشی حق لے کر پہنچی یہی ہے جس سے تو بدکتا پھرتا تھا (1)
50,20,وَ نُفِخَ فِی الصُّوْرِ١ؕ ذٰلِكَ یَوْمُ الْوَعِیْدِ وَنُفِخَ : اور پھونکا گیا فِي الصُّوْرِ ۭ : صور میں ذٰلِكَ : یہ يَوْمُ الْوَعِيْدِ : وعید کا دن اور صور پھونک دیا جائے گا۔ وعدہ عذاب کا دن یہی ہے۔
50,21,وَ جَآءَتْ كُلُّ نَفْسٍ مَّعَهَا سَآئِقٌ وَّ شَهِیْدٌ وَجَآءَتْ : اور آئیگا (حاضر ہوگا ) كُلُّ : ہر نَفْسٍ : شخص مَّعَهَا : اس کے ساتھ سَآئِقٌ : ایک چلانے والا وَّشَهِيْدٌ : اور ایک گواہی دینے والا اور ہر شخص اس طرح آئے گا کہ اس کے ساتھ ایک لانے والا ہوگا اور ایک گواہی دینے والا (1)
50,22,لَقَدْ كُنْتَ فِیْ غَفْلَةٍ مِّنْ هٰذَا فَكَشَفْنَا عَنْكَ غِطَآءَكَ فَبَصَرُكَ الْیَوْمَ حَدِیْدٌ لَقَدْ كُنْتَ : تحقیق تو تھا فِيْ غَفْلَةٍ : غفلت میں مِّنْ ھٰذَا : اس سے فَكَشَفْنَا : تو ہم نے ہٹادیا عَنْكَ : تجھ سے غِطَآءَكَ : تیرا پردہ فَبَصَرُكَ : پس تیری نظر الْيَوْمَ حَدِيْدٌ : آج بڑی تیز یقیناً تو اس سے غفلت میں تھا لیکن ہم نے تیرے سامنے سے پردہ ہٹا دیا پس آج تیری نگاہ بہت تیز ہے۔
50,23,وَ قَالَ قَرِیْنُهٗ هٰذَا مَا لَدَیَّ عَتِیْدٌؕ و َقَالَ : اور کہے گا قَرِيْنُهٗ : اس کا ہم نشین ھٰذَا مَا لَدَيَّ : یہ جو میرے پاس عَتِيْدٌ : حاضر اس کا ہم نشین (فرشتہ) کہے گا یہ حاضر ہے جو کہ میرے پاس تھا (1)۔
50,24,اَلْقِیَا فِیْ جَهَنَّمَ كُلَّ كَفَّارٍ عَنِیْدٍۙ اَلْقِيَا : تم دونوں ڈال دو فِيْ جَهَنَّمَ : جہنم میں كُلَّ كَفَّارٍ : ہر ناشکرا عَنِيْدٍ : سرکش ڈال دو جہنم میں ہر کافر سرکش کو۔
50,25,مَّنَّاعٍ لِّلْخَیْرِ مُعْتَدٍ مُّرِیْبِۙ مَّنَّاعٍ : منع کرنے و الا لِّلْخَيْرِ : مال کے لئے مُعْتَدٍ : حد سے گزرنے والا مُّرِيْبِۨ : شبہات ڈالنے والا جو نیک کام سے روکنے والا حد سے گزر جانے والا اور شک کرنے والا تھا۔
50,26,اِ۟لَّذِیْ جَعَلَ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ فَاَلْقِیٰهُ فِی الْعَذَابِ الشَّدِیْدِ الَّذِيْ : وہ جس جَعَلَ : ٹھہرایا مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا اٰخَرَ : معبود دوسرا فَاَلْقِيٰهُ : پس اسے ڈال دو فِي : میں الْعَذَابِ : عذاب الشَّدِيْدِ : سخت جس نے اللہ کے ساتھ دوسرا معبود بنا لیا تھا پس اسے سخت عذاب میں ڈال دو۔ (1)
50,27,قَالَ قَرِیْنُهٗ رَبَّنَا مَاۤ اَطْغَیْتُهٗ وَ لٰكِنْ كَانَ فِیْ ضَلٰلٍۭ بَعِیْدٍ قَالَ قَرِيْنُهٗ : کہے گا اس کا ہم نشین رَبَّنَا : اے ہمارے رب مَآ اَطْغَيْتُهٗ : میں نے اسے سرکش نہیں بنایا وَلٰكِنْ : اور لیکن وہ كَانَ : تھا فِيْ ضَلٰلٍۢ : گمراہی میں بَعِيْدٍ : پرلے درجے کی اس کا ہم نشین (شیطان) کہے گا اے ہمارے رب ! میں نے اسے گمراہ نہیں کیا تھا بلکہ یہ خود ہی دور دراز کی گمراہی میں تھا (1)
50,28,قَالَ لَا تَخْتَصِمُوْا لَدَیَّ وَ قَدْ قَدَّمْتُ اِلَیْكُمْ بِالْوَعِیْدِ قَالَ : ارشاد ہوگا لَا : نہ تَخْتَصِمُوْا : تم جھگڑو لَدَيَّ : میرے پاس، سامنے وَقَدْ قَدَّمْتُ : اور میں پہلے بھیج چکا ہوں اِلَيْكُمْ : تمہاری طرف بِالْوَعِيْدِ : وعدۂ عذاب حق تعالیٰ فرمائے گا بس میرے سامنے جھگڑے کی بات مت کرو میں تو پہلے ہی تمہاری طرف وعید (وعدہ عذاب) بھیج چکا تھا (1)۔
50,29,مَا یُبَدَّلُ الْقَوْلُ لَدَیَّ وَ مَاۤ اَنَا بِظَلَّامٍ لِّلْعَبِیْدِ۠    ۧ مَا : نہیں يُبَدَّلُ : بدلی جاتی الْقَوْلُ : بات لَدَيَّ : میرے پاس، ہاں وَمَآ : اور نہیں اَنَا : میں بِظَلَّامٍ : ظلم کرنے والا لِّلْعَبِيْدِ : بندوں پر میرے ہاں بات بد لتی نہیں (1) نہ میں اپنے بندوں پر ذرا بھی ظلم کرنے والا ہوں۔
50,30,یَوْمَ نَقُوْلُ لِجَهَنَّمَ هَلِ امْتَلَاْتِ وَ تَقُوْلُ هَلْ مِنْ مَّزِیْدٍ يَوْمَ : جس دن نَقُوْلُ : ہم کہیں گے لِجَهَنَّمَ : جہنم سے هَلِ : کیا امْتَلَاْتِ : کیا تو بھر گئی وَتَقُوْلُ : اور وہ کہے گی هَلْ : کیا مِنْ مَّزِيْدٍ : کچھ مزید ہے جس دن ہم دوزخ سے پوچھیں گے کیا تو بھر چکی ؟ وہ جواب دے گی کیا کچھ اور زیادہ بھی ہے ؟ (1)۔
50,31,وَ اُزْلِفَتِ الْجَنَّةُ لِلْمُتَّقِیْنَ غَیْرَ بَعِیْدٍ وَاُزْلِفَتِ : اور نزدیک کردی جائے گی الْجَنَّةُ : جنت لِلْمُتَّقِيْنَ : پرہیزگاروں کیلئے غَيْرَ بَعِيْدٍ : نہ دور اور جنت پرہیز گاروں کے لئے بالکل قریب کردی جائے گی ذرا بھی دور نہ ہوگی۔ (1)
50,32,هٰذَا مَا تُوْعَدُوْنَ لِكُلِّ اَوَّابٍ حَفِیْظٍۚ ھٰذَا : یہ مَا : جو تُوْعَدُوْنَ : تم سے وعدہ کیا جاتا تھا لِكُلِّ اَوَّابٍ : ہر رجوع کرنے والے کیلئے حَفِيْظٍ : نگہداشت کرنے والا یہ جس کا تم سے وعدہ کیا جاتا تھا ہر اس شخص کے لئے جو رجوع کرنے والا اور پابندی کرنے والا ہو (1)
50,33,مَنْ خَشِیَ الرَّحْمٰنَ بِالْغَیْبِ وَ جَآءَ بِقَلْبٍ مُّنِیْبِۙ مَنْ : جو خَشِيَ : ڈرا الرَّحْمٰنَ : رحمٰن (اللہ) سے بِالْغَيْبِ : بن دیکھے وَجَآءَ : اور آیا بِقَلْبٍ : دل کے ساتھ مُّنِيْبِۨ : رجوع کرنے والے جو رحمان کا غائبانہ خوف رکھتا ہو اور توجہ والا دل لایا ہو (1)
50,34,اِ۟دْخُلُوْهَا بِسَلٰمٍ١ؕ ذٰلِكَ یَوْمُ الْخُلُوْدِ ادْخُلُوْهَا : اس میں داخل ہوجاؤ بِسَلٰمٍ ۭ : سلامتی کے ساتھ ذٰلِكَ : یہ يَوْمُ الْخُلُوْدِ : ہمیشہ رہنے کا دن تم اس جنت میں سلامتی کے ساتھ داخل ہوجاؤ یہ ہمیشہ رہنے کا دن ہے۔
50,35,لَهُمْ مَّا یَشَآءُوْنَ فِیْهَا وَ لَدَیْنَا مَزِیْدٌ لَهُمْ : ان کیلئے مَّا : جو يَشَآءُوْنَ فِيْهَا : وہ چاہیں گے اس میں وَلَدَيْنَا : اور ہمارے پاس مَزِيْدٌ : اور بھی زیادہ یہ وہاں جو چاہیں انہیں ملے گا (بلکہ) ہمارے پاس اور بھی زیادہ ہے۔ (4)
50,36,وَ كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنْ قَرْنٍ هُمْ اَشَدُّ مِنْهُمْ بَطْشًا فَنَقَّبُوْا فِی الْبِلَادِ١ؕ هَلْ مِنْ مَّحِیْصٍ وَكَمْ : اور کتنی اَهْلَكْنَا : ہلاک کیں ہم نے قَبْلَهُمْ : ان سے قبل مِّنْ قَرْنٍ : امتیں هُمْ اَشَدُّ : وہ زیادہ سخت مِنْهُمْ : ان سے بَطْشًا : پکڑ میں فَنَقَّبُوْا : پس کریدنے (گشت کرنے) لگے فِي الْبِلَادِ ۭ : شہروں میں هَلْ : کیا مِنْ : سے (کہیں) مَّحِيْصٍ : بھاگنے کی جگہ اور اس سے پہلے بھی ہم بہت سی امتوں کو ہلاک کرچکے ہیں جو ان سے طاقت میں زیادہ تھیں وہ شہروں میں ڈھونڈھتے ہی (1) رہ گئے، کہ کوئی بھا گنے کا ٹھکانا ہے۔
50,37,اِنَّ فِیْ ذٰلِكَ لَذِكْرٰى لِمَنْ كَانَ لَهٗ قَلْبٌ اَوْ اَلْقَى السَّمْعَ وَ هُوَ شَهِیْدٌ اِنَّ فِيْ ذٰلِكَ : بیشک اس میں لَذِكْرٰى : نصیحت لِمَنْ : اسکے لئے جو كَانَ لَهٗ : ہو اس کا قَلْبٌ : دل اَوْ اَلْقَى : یا ڈالے (لگائے) السَّمْعَ : کان وَهُوَ شَهِيْدٌ : اور وہ متوجہ اس میں ہر صاحب دل کے لئے عبرت ہے اور اس کے لئے جو دل (1) متوجہ ہو کر کان لگائے (2) اور وہ حاضر ہو (3)
50,38,وَ لَقَدْ خَلَقْنَا السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَا فِیْ سِتَّةِ اَیَّامٍ١ۖۗ وَّ مَا مَسَّنَا مِنْ لُّغُوْبٍ وَلَقَدْ : اور تحقیق خَلَقْنَا : ہم نے پیدا کیا السَّمٰوٰتِ : آسمانوں وَالْاَرْضَ : اور زمین وَمَا بَيْنَهُمَا : اور جو ان دونوں کے درمیان فِيْ : میں سِتَّةِ اَيَّامٍ ڰ : چھ دن وَّمَا : اور نہیں مَسَّنَا : چھوا ہمیں مِنْ : کسی لُّغُوْبٍ : تکان نے یقیناً ہم نے آسمانوں اور زمین اور جو کچھ اس کے درمیان ہے سب کو (صرف) چھ دن میں پیدا کردیا اور ہمیں تکان نے چھوا تک نہیں۔
50,39,فَاصْبِرْ عَلٰى مَا یَقُوْلُوْنَ وَ سَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوْعِ الشَّمْسِ وَ قَبْلَ الْغُرُوْبِۚ فَاصْبِرْ : پس صبر کرو عَلٰي : پر مَا يَقُوْلُوْنَ : جو وہ کہتے ہیں وَسَبِّحْ : اور پاکیزگی بیان کرو بِحَمْدِ : تعریف کے ساتھ رَبِّكَ : اپنے رب کی قَبْلَ : قبل طُلُوْعِ : طلوع الشَّمْسِ : سورج کا وَقَبْلَ : اور قبل الْغُرُوْبِ : غروب ہونے سے پس یہ جو کچھ کہتے ہیں آپ اس پر صبر کریں اور اپنے رب کی تسبیح تعریف کے ساتھ بیان کریں سورج نکلنے سے پہلے بھی اور سورج غروب ہونے سے پہلے بھی (1)
50,40,وَ مِنَ الَّیْلِ فَسَبِّحْهُ وَ اَدْبَارَ السُّجُوْدِ وَمِنَ الَّيْلِ : اور رات میں فَسَبِّحْهُ : پس اس کی پاکیزگی بیان کرو وَاَدْبَارَ : اور بعد السُّجُوْدِ : سجدوں (نماز) اور رات کے کسی وقت بھی تسبیح کریں (1) اور نماز کے بعد بھی (2)
50,41,وَ اسْتَمِعْ یَوْمَ یُنَادِ الْمُنَادِ مِنْ مَّكَانٍ قَرِیْبٍۙ وَاسْتَمِعْ يَوْمَ : اور سنو جس دن يُنَادِ الْمُنَادِ : پکارنے والا پکاریگا مِنْ مَّكَانٍ : جگہ سے قَرِيْبٍ : قریب اور سن رکھیں (1) کہ جس دن ایک پکارنے (2) والا قریب ہی جگہ سے پکارے گا (3)
50,42,یَّوْمَ یَسْمَعُوْنَ الصَّیْحَةَ بِالْحَقِّ١ؕ ذٰلِكَ یَوْمُ الْخُرُوْجِ يَّوْمَ : جس دن يَسْمَعُوْنَ : وہ سنیں گے الصَّيْحَةَ : چیخ بِالْحَقِّ ۭ : حق کے ساتھ ذٰلِكَ : یہ يَوْمُ الْخُرُوْجِ : باہر نکلنے کا دن جس روز اس تند تیز چیخ کو یقین کے ساتھ سن لیں گے یہ دن ہوگا نکلنے کا (1)
50,43,اِنَّا نَحْنُ نُحْیٖ وَ نُمِیْتُ وَ اِلَیْنَا الْمَصِیْرُۙ اِنَّا نَحْنُ : بیشک ہم نُحْيٖ : زندگی دیتے ہیں وَنُمِيْتُ : اور مارتے ہیں وَاِلَيْنَا : اور ہماری طرف الْمَصِيْرُ : پھر لوٹ کر آنا ہے ہم ہی جلاتے ہیں اور ہم ہی مارتے ہیں (1) اور ہماری ہی طرف لوٹ کر آنا ہے۔ (2)
50,44,یَوْمَ تَشَقَّقُ الْاَرْضُ عَنْهُمْ سِرَاعًا١ؕ ذٰلِكَ حَشْرٌ عَلَیْنَا یَسِیْرٌ يَوْمَ : جس دن تَشَقَّقُ : شق ہوجائے گی الْاَرْضُ : زمین عَنْهُمْ : ان سے سِرَاعًا ۭ : جلدی کرتے ہوئے ذٰلِكَ حَشْرٌ : یہ حشر عَلَيْنَا : ہمارے لئے يَسِيْرٌ : آسان جس دن زمین پھٹ جائے گی اور یہ دوڑتے ہوئے (1) (نکل پڑیں گے) یہ جمع کرلینا ہم پر بہت ہی آسان ہے۔
50,45,نَحْنُ اَعْلَمُ بِمَا یَقُوْلُوْنَ وَ مَاۤ اَنْتَ عَلَیْهِمْ بِجَبَّارٍ١۫ فَذَكِّرْ بِالْقُرْاٰنِ مَنْ یَّخَافُ وَعِیْدِ۠    ۧ نَحْنُ : ہم اَعْلَمُ : خوب جانتے ہیں بِمَا يَقُوْلُوْنَ : وہ جو کہتے ہیں وَمَآ : اور نہیں اَنْتَ : آپ عَلَيْهِمْ : ان پر بِجَبَّارٍ ۣ : جبر کرنے والے فَذَكِّرْ : پس نصیحت کریں بِالْقُرْاٰنِ : قرآن سے مَنْ : جو يَّخَافُ : وہ ڈرتا ہے وَعِيْدِ : میری وعید یہ جو کچھ کہہ رہے ہیں ہم بخوبی جانتے ہیں اور آپ ان پر جبر کرنے والے نہیں (1) تو آپ قرآن کے ذریعے انہیں سمجھاتے رہیں جو میرے وعید (ڈراوے کے وعدوں) سے ڈرتے ہیں (2)۔
