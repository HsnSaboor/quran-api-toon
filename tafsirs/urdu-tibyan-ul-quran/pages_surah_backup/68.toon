quran[52]{c,v,t}:
68,1,نٓ وَ الْقَلَمِ وَ مَا یَسْطُرُوْنَۙ نٓ : ن وَالْقَلَمِ : قسم ہے قلم کی وَمَا يَسْطُرُوْنَ : اور قسم ہے اس کی جو کچھ وہ لکھ رہے ہیں ن، قسم ہے قلم کی اور (1) اس کی جو کچھ وہ (فرشتے) لکھتے ہیں۔
68,2,مَاۤ اَنْتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُوْنٍۚ مَآ اَنْتَ : نہیں ہیں آپ بِنِعْمَةِ رَبِّكَ : اپنے رب کی نعمت کے ساتھ بِمَجْنُوْنٍ : مجنون تو اپنے رب کے فضل سے دیوانہ نہیں ہے (1)
68,3,وَ اِنَّ لَكَ لَاَجْرًا غَیْرَ مَمْنُوْنٍۚ وَاِنَّ لَكَ : اور بیشک آپ کے لیے لَاَجْرًا : البتہ اجر ہے غَيْرَ مَمْنُوْنٍ : نہ ختم ہونے والا اور بیشک تیرے لئے بےانتہاء اجر ہے (1)۔
68,4,وَ اِنَّكَ لَعَلٰى خُلُقٍ عَظِیْمٍ وَاِنَّكَ : اور بیشک آپ لَعَلٰى خُلُقٍ عَظِيْمٍ : البتہ اخلاق کے بلند مرتبے پر ہیں اور بیشک تو بہت بڑے (عمدہ) اخلاق پر ہے۔ (1)
68,5,فَسَتُبْصِرُ وَ یُبْصِرُوْنَۙ فَسَتُبْصِرُ : پس عنقریب تم بھی دیکھو گے وَيُبْصِرُوْنَ : اور وہ بھی دیکھیں گے پس اب تو بھی دیکھ لے گا اور یہ بھی دیکھ لیں گے۔
68,6,بِاَىیِّكُمُ الْمَفْتُوْنُ بِاَىيِّكُمُ الْمَفْتُوْنُ : کون تم میں کا مجنون ہے کہ تم میں سے کون فتنہ میں پڑا ہوا ہے۔
68,7,اِنَّ رَبَّكَ هُوَ اَعْلَمُ بِمَنْ ضَلَّ عَنْ سَبِیْلِهٖ١۪ وَ هُوَ اَعْلَمُ بِالْمُهْتَدِیْنَ اِنَّ رَبَّكَ : بیشک رب تیرا هُوَ اَعْلَمُ : وہ زیادہ جانتا ہے بِمَنْ ضَلَّ : اس کو جو بھٹک گیا عَنْ سَبِيْلِهٖ : اس کے راستے سے وَهُوَ اَعْلَمُ : اور وہ زیادہ جانتا ہے بِالْمُهْتَدِيْنَ : ہدایت پانے والوں کو بیشک تیرا رب اپنی راہ سے بہکنے والوں کو خوب جانتا ہے، اور وہ راہ یافتہ لوگوں کو بھی بخوبی جانتا ہے۔
68,8,فَلَا تُطِعِ الْمُكَذِّبِیْنَ فَلَا : پس نہ تُطِعِ : تم اطاعت کرو الْمُكَذِّبِيْنَ : جھٹلانے والوں کی پس تو جھٹلانے والوں کو نہ مان (1)
68,9,وَدُّوْا لَوْ تُدْهِنُ فَیُدْهِنُوْنَ وَدُّوْا : وہ چاہتے ہیں لَوْ تُدْهِنُ : کاش تم سستی کرو فَيُدْهِنُوْنَ : تو وہ بھی سستی کریں۔ مداہنت کریں وہ چاہتے ہیں کہ تو ذرا ڈھیلا ہو تو یہ بھی ڈھیلے پڑجائیں (1)
68,10,وَ لَا تُطِعْ كُلَّ حَلَّافٍ مَّهِیْنٍۙ وَلَا : اور نہ تُطِعْ : تم اطاعت کرو كُلَّ حَلَّافٍ : بہت قسمیں کھانے والے کی مَّهِيْنٍ : ذلیل اور تو کسی ایسے شخص کا بھی کہنا نہ ماننا جو زیادہ قسمیں کھانے والا۔
68,11,هَمَّازٍ مَّشَّآءٍۭ بِنَمِیْمٍۙ هَمَّازٍ : عیب جوئی کرنے والا مَّشَّآءٍۢ : چلنے والا بِنَمِيْمٍ : ساتھ چغل خوری کے وقار، کمینہ، عیب گو، چغل خور۔
68,12,مَّنَّاعٍ لِّلْخَیْرِ مُعْتَدٍ اَثِیْمٍۙ مَّنَّاعٍ : بہت روکنے والا لِّلْخَيْرِ : بھلائی کا مُعْتَدٍ : حد سے بڑھنے والا اَثِيْمٍ : گناہ گار بھلائی سے روکنے والا حد سے بڑھ جانے والا گنہگار۔
68,13,عُتُلٍّۭ بَعْدَ ذٰلِكَ زَنِیْمٍۙ عُتُلٍّۢ : بدمزاج بَعْدَ ذٰلِكَ : اس کے بعد زَنِيْمٍ : بداصل بھی ہے گردن کش پھر ساتھ ہی بےنسب ہو (1)
68,14,اَنْ كَانَ ذَا مَالٍ وَّ بَنِیْنَؕ اَنْ كَانَ : کہ ہے وہ ذَا مَالٍ : مال والا وَّبَنِيْنَ : اور بیٹوں والا اس کی سرکشی صرف اس لئے ہے کہ وہ مال والا اور بیٹوں والا ہے (1)
68,15,اِذَا تُتْلٰى عَلَیْهِ اٰیٰتُنَا قَالَ اَسَاطِیْرُ الْاَوَّلِیْنَ اِذَا : جب تُتْلٰى : پڑھی جاتی ہیں عَلَيْهِ : اس پر اٰيٰتُنَا : ہماری آیات قَالَ : کہتا ہے اَسَاطِيْرُ : کہانیاں ہیں الْاَوَّلِيْنَ : پہلوں کی جب اس کے سامنے ہماری آیتیں پڑھی جاتی ہیں تو کہہ دیتا ہے یہ تو اگلوں کے قصے ہیں۔
68,16,سَنَسِمُهٗ عَلَى الْخُرْطُوْمِ سَنَسِمُهٗ : عنقریب ہم داغ دیں گے اس کو۔ داغ لگائیں گے اس کو عَلَي : اوپر الْخُرْطُوْمِ : ناک کے ہم بھی اس کی سونڈ (ناک) پر داغ دیں گے (1)
68,17,اِنَّا بَلَوْنٰهُمْ كَمَا بَلَوْنَاۤ اَصْحٰبَ الْجَنَّةِ١ۚ اِذْ اَقْسَمُوْا لَیَصْرِمُنَّهَا مُصْبِحِیْنَۙ اِنَّا : بیشک ہم نے بَلَوْنٰهُمْ : آزمائش میں ڈالا ہم نے ان کو كَمَا بَلَوْنَآ : جیسا کہ آزمایا ہم نے اَصْحٰبَ الْجَنَّةِ : باغ والوں کو اِذْ اَقْسَمُوْا : جب انہوں نے قسم کھائی لَيَصْرِمُنَّهَا : البتہ ضرور کاٹ لیں گے اس کو مُصْبِحِيْنَ : صبح سویرے بیشک ہم نے انہیں اسی طرح آزما لیا (1) جس طرح ہم نے باغ والوں کو (2) آزمایا تھا جبکہ انہوں نے قسمیں کھائیں کہ صبح ہوتے ہی اس باغ کے پھل اتار لیں گے۔
68,18,وَ لَا یَسْتَثْنُوْنَ وَلَا : اور نہ يَسْتَثْنُوْنَ : وہ استثناء کررہے تھے اور انشاء اللہ نہ کہا۔
68,19,فَطَافَ عَلَیْهَا طَآئِفٌ مِّنْ رَّبِّكَ وَ هُمْ نَآئِمُوْنَ فَطَافَ : تو پھر گیا عَلَيْهَا : اس پر طَآئِفٌ : ایک پھرنے والا مِّنْ رَّبِّكَ : تیرے رب کی طرف سے وَهُمْ نَآئِمُوْنَ : اور وہ سو رہے تھے پس اس پر تیرے رب کی جانب سے ایک بلا چاروں طرف گھوم گئی اور یہ سو رہے تھے (1)
68,20,فَاَصْبَحَتْ كَالصَّرِیْمِۙ فَاَصْبَحَتْ : تو ہوگیا وہ باغ كَالصَّرِيْمِ : جڑکٹا۔ مانند جڑ کئے کے پس وہ باغ ایسا ہوگیا جیسے کٹی ہوئی کھیتی (1)
68,21,فَتَنَادَوْا مُصْبِحِیْنَۙ فَتَنَادَوْا : تو ایک دوسرے کو پکارے لگے مُصْبِحِيْنَ : صبح سویرے اب صبح ہوتے ہی انہوں نے ایک دوسرے کو آوازیں دیں۔
68,22,اَنِ اغْدُوْا عَلٰى حَرْثِكُمْ اِنْ كُنْتُمْ صٰرِمِیْنَ اَنِ اغْدُوْا : کہ چلو عَلٰي حَرْثِكُمْ : اپنے کھیت پر اِنْ كُنْتُمْ : اگر ہو تم صٰرِمِيْنَ : کاٹنے والے اگر تمہیں پھل اتارنے ہیں تو اپنی کھیتی پر سویرے ہی سویرے چل پڑو۔
68,23,فَانْطَلَقُوْا وَ هُمْ یَتَخَافَتُوْنَۙ فَانْطَلَقُوْا : تو وہ چل دئیے وَهُمْ يَتَخَافَتُوْنَ : اور وہ چپکے چپکے باتیں کررہے تھے پھر جب یہ چپکے چپکے یہ باتیں کرتے ہوئے چلے (1)
68,24,اَنْ لَّا یَدْخُلَنَّهَا الْیَوْمَ عَلَیْكُمْ مِّسْكِیْنٌۙ اَنْ لَّا : کہ نہیں يَدْخُلَنَّهَا : داخل ہوگا اس پر الْيَوْمَ : آج عَلَيْكُمْ : تم پر مِّسْكِيْنٌ : کوئی مسکین کہ آج کے دن کوئی مسکین تمہارے پاس نہ آنے پائے (1)
68,25,وَّ غَدَوْا عَلٰى حَرْدٍ قٰدِرِیْنَ وَّغَدَوْا : اور وہ صبح سویرے گئے عَلٰي حَرْدٍ : اوپر بخیلی کے۔ بخل کرتے ہوئے قٰدِرِيْنَ : جیسا کہ قدرت رکھنے والے ہوں اور لپکے ہوئے صبح صبح گئے (سمجھ رہے تھے) کہ ہم قابو پا گئے (1)
68,26,فَلَمَّا رَاَوْهَا قَالُوْۤا اِنَّا لَضَآلُّوْنَۙ فَلَمَّا : تو جب رَاَوْهَا : انہوں نے دیکھا اس کو قَالُوْٓا : کہنے لگے اِنَّا لَضَآلُّوْنَ : بیشک ہم البتہ بھٹک گئے ہیں جب انہوں نے باغ دیکھا (1) تو کہنے لگے یقیناً ہم راستہ بھول گئے ہیں۔ (1)
68,27,بَلْ نَحْنُ مَحْرُوْمُوْنَ بَلْ : (نہیں) بلکہ نَحْنُ : ہم مَحْرُوْمُوْنَ : محروم کردئیے گئے ہیں نہیں نہیں ہماری قسمت پھوٹ گئی (1)
68,28,قَالَ اَوْسَطُهُمْ اَلَمْ اَقُلْ لَّكُمْ لَوْ لَا تُسَبِّحُوْنَ قَالَ : بولا اَوْسَطُهُمْ : ان کا درمیانہ۔ ان کا بہتر شخص اَلَمْ : کیا نہیں اَقُلْ لَّكُمْ : میں نے کہا تھا تم سے لَوْلَا : کیوں نہیں تُسَبِّحُوْنَ : تم تسبیح کرتے ان سب میں جو بہتر تھا اس نے کہا میں تم سے نہ کہتا تھا کہ تم اللہ کی پاکیزگی کیوں نہیں بیان کرتے (1)
68,29,قَالُوْا سُبْحٰنَ رَبِّنَاۤ اِنَّا كُنَّا ظٰلِمِیْنَ قَالُوْا : انہوں نے کہا سُبْحٰنَ رَبِّنَآ : پاک ہے رب ہمارا اِنَّا : بیشک ہم كُنَّا : تھے ہم ظٰلِمِيْنَ : ظالم تو سب کہنے لگے ہمارا رب پاک ہے بیشک ہم ہی ظالم تھے۔ (1)
68,30,فَاَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَلَاوَمُوْنَ فَاَقْبَلَ : تو متوجہ ہوا بَعْضُهُمْ : ان کا بعض عَلٰي بَعْضٍ : بعض پر يَّتَلَاوَمُوْنَ : آپس میں ملامت کرتے ہوئے پھر ایک دوسرے کی طرف رخ کر کے آپس میں ملامت کرنے لگے۔
68,31,قَالُوْا یٰوَیْلَنَاۤ اِنَّا كُنَّا طٰغِیْنَ قَالُوْا : انہوں نے کہا يٰوَيْلَنَآ : ہائے افسوس ہم پر اِنَّا : بیشک ہم كُنَّا : تھے ہم طٰغِيْنَ : سرکش کہنے لگے ہائے افسوس ! یقیناً ہم سرکش تھے۔
68,32,عَسٰى رَبُّنَاۤ اَنْ یُّبْدِلَنَا خَیْرًا مِّنْهَاۤ اِنَّاۤ اِلٰى رَبِّنَا رٰغِبُوْنَ عَسٰى : امید ہے کہ رَبُّنَآ : ہمارا رب اَنْ يُّبْدِلَنَا : کہ بدل کردے ہم کو خَيْرًا مِّنْهَآ : بہتر اس سے اِنَّآ : بیشک ہم اِلٰى رَبِّنَا : اپنے رب کی طرف رٰغِبُوْنَ : رغبت کرنے والے ہیں کیا عجب ہے کہ ہمارا رب ہمیں اس سے بہتر بدلہ دے ہم تو اب (1) اپنے رب سے ہی آرزو رکھتے ہیں
68,33,كَذٰلِكَ الْعَذَابُ١ؕ وَ لَعَذَابُ الْاٰخِرَةِ اَكْبَرُ١ۘ لَوْ كَانُوْا یَعْلَمُوْنَ۠    ۧ كَذٰلِكَ : اسی طرح ہوتا ہے۔ ایسا ہوتا ہے الْعَذَابُ : عذاب وَلَعَذَابُ الْاٰخِرَةِ : اور البتہ عذاب آخرت کا اَكْبَرُ : زیادہ بڑا ہے لَوْ كَانُوْا : کاش وہ ہوتے يَعْلَمُوْنَ : وہ جانتے یوں ہی آفت آتی ہے (1) اور آخرت کی آفت بہت ہی بڑی ہے کاش انہیں سمجھ ہوتی (1)
68,34,اِنَّ لِلْمُتَّقِیْنَ عِنْدَ رَبِّهِمْ جَنّٰتِ النَّعِیْمِ اِنَّ لِلْمُتَّقِيْنَ : بیشک متقی لوگوں کے لیے عِنْدَ رَبِّهِمْ : ان کے رب کے نزدیک جَنّٰتِ : باغات ہیں النَّعِيْمِ : نعمتوں والے پرہیزگاروں کے لئے ان کے رب کے پاس نعمتوں والی جنتیں ہیں۔
68,35,اَفَنَجْعَلُ الْمُسْلِمِیْنَ كَالْمُجْرِمِیْنَؕ اَفَنَجْعَلُ الْمُسْلِمِيْنَ : کیا بھلا ہم کردیں مسلمانوں کو۔ فرماں بردار کو كَالْمُجْرِمِيْنَ : مجرموں کی طرح کیا ہم مسلمانوں کو مثل گناہ گاروں کے کردیں گے (1)
68,36,مَا لَكُمْ١ٙ كَیْفَ تَحْكُمُوْنَۚ مَا لَكُمْ : کیا ہے تم کو كَيْفَ تَحْكُمُوْنَ : کیسے تم فیصلے کرتے ہو تمہیں کیا ہوگیا، کیسے فیصلے کر رہے ہو ؟
68,37,اَمْ لَكُمْ كِتٰبٌ فِیْهِ تَدْرُسُوْنَۙ اَمْ لَكُمْ : یا تمہارے لیے كِتٰبٌ : کوئی کتاب فِيْهِ : جس میں تَدْرُسُوْنَ : تم پڑھتے ہو کیا تمہارے پاس کوئی کتاب (1) ہے جس میں تم پڑھتے ہو ؟
68,38,اِنَّ لَكُمْ فِیْهِ لَمَا تَخَیَّرُوْنَۚ اِنَّ لَكُمْ : بیشک تمہارے لیے فِيْهِ : اس میں لَمَا تَخَيَّرُوْنَ : البتہ وہ ہے جو تم پسند کرو۔ اختیار کرو کہ اس میں تمہاری من مانی باتیں ہوں۔
68,39,اَمْ لَكُمْ اَیْمَانٌ عَلَیْنَا بَالِغَةٌ اِلٰى یَوْمِ الْقِیٰمَةِ١ۙ اِنَّ لَكُمْ لَمَا تَحْكُمُوْنَۚ اَمْ لَكُمْ : یا تمہارے لیے اَيْمَانٌ : کوئی عہد ہیں۔ قسمیں ہیں عَلَيْنَا : ہم پر بَالِغَةٌ : باقی رہنے والی اِلٰي يَوْمِ الْقِيٰمَةِ : قیامت کے دن تک اِنَّ لَكُمْ : بیشک تمہارے لیے لَمَا تَحْكُمُوْنَ : البتہ وہ ہے جو تم فیصلہ کرو گے یا تم نے ہم سے قسمیں لی ہیں ؟ جو قیامت تک باقی رہیں کہ تمہارے لئے وہ سب ہے جو تم اپنی طرف سے مقرر کرلو (1)۔
68,40,سَلْهُمْ اَیُّهُمْ بِذٰلِكَ زَعِیْمٌۚۛ سَلْهُمْ : پوچھو ان سے اَيُّهُمْ : کون سا ان میں سے بِذٰلِكَ زَعِيْمٌ : ساتھ اس کے ضامن ہے ان سے پوچھو تو کہ ان میں سے کون اس بات کا ذمہ دار (اور دعویدار) ہے (1)
68,41,اَمْ لَهُمْ شُرَكَآءُ١ۛۚ فَلْیَاْتُوْا بِشُرَكَآئِهِمْ اِنْ كَانُوْا صٰدِقِیْنَ اَمْ لَهُمْ : یا ان کے لیے شُرَكَآءُ : کچھ شریک ہیں فَلْيَاْتُوْا : پس چاہیے کہ لے آئیں بِشُرَكَآئِهِمْ : اپنے شریکوں کو اِنْ كَانُوْا : اگر ہیں وہ صٰدِقِيْنَ : سچے کیا ان کے کوئی شریک ہیں ؟ تو چاہیے کہ اپنے اپنے شریکوں کو لے آئیں اگر یہ سچے ہیں۔ (1)
68,42,یَوْمَ یُكْشَفُ عَنْ سَاقٍ وَّ یُدْعَوْنَ اِلَى السُّجُوْدِ فَلَا یَسْتَطِیْعُوْنَۙ يَوْمَ يُكْشَفُ : جس دن کھول دیاجائے گا عَنْ سَاقٍ : پنڈلی سے وَّيُدْعَوْنَ : اور وہ بلائے جائیں گے اِلَى السُّجُوْدِ : طرف سجدوں کے فَلَا يَسْتَطِيْعُوْنَ : تو وہ استطاعت نہ رکھتے ہوں گے جس دن پنڈلی کھول دی جائے گی اور سجدے کے لئے بلائے جائیں گے تو (سجدہ) نہ کرسکیں گے (1)
68,43,خَاشِعَةً اَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ١ؕ وَ قَدْ كَانُوْا یُدْعَوْنَ اِلَى السُّجُوْدِ وَ هُمْ سٰلِمُوْنَ خَاشِعَةً : نیچی ہوں گی اَبْصَارُهُمْ : ان کی نگاہیں تَرْهَقُهُمْ : چھا رہی ہوگی ان پر ذِلَّةٌ : ذلت وَقَدْ كَانُوْا : اور تحقیق تھے وہ يُدْعَوْنَ : بلائے جاتے اِلَى السُّجُوْدِ : سجدوں کی طرف وَهُمْ سٰلِمُوْنَ : اور وہ صحیح سلامت تھے نگاہیں نیچی ہوں گی ان پر ذلت و خواری چھا رہی (1) ہوگی حالانکہ یہ سجدے کے لئے (اس وقت بھی) بلائے جاتے تھے جبکہ صحیح سلامت تھے (2)
68,44,فَذَرْنِیْ وَ مَنْ یُّكَذِّبُ بِهٰذَا الْحَدِیْثِ١ؕ سَنَسْتَدْرِجُهُمْ مِّنْ حَیْثُ لَا یَعْلَمُوْنَۙ فَذَرْنِيْ : پس چھوڑدو مجھ کو وَمَنْ يُّكَذِّبُ : اور جو کوئی جھٹلاتا ہے بِهٰذَا : اس الْحَدِيْثِ : بات کو سَنَسْتَدْرِجُهُمْ : عنقریب ہم آہستہ آہستہ کھینچیں گے ان کو مِّنْ حَيْثُ : جہاں سے لَا يَعْلَمُوْنَ : وہ جانتے نہ ہوں گے پس مجھے اور اس کلام کو جھٹلانے والے کو چھوڑ دے ہم انہیں اس طرح آہستہ آہستہ کھینچیں گے کہ انہیں معلوم بھی نہ ہوگا (1)
68,45,وَ اُمْلِیْ لَهُمْ١ؕ اِنَّ كَیْدِیْ مَتِیْنٌ وَ : اور اُمْلِيْ لَهُمْ : میں ڈھیل دے رہا ہوں ان کے لیے اِنَّ : بیشک كَيْدِيْ : میری چال مَتِيْنٌ : بہت پختہ ہے اور میں انہیں ڈھیل دونگا، بیشک میری تدبیر بڑی مضبوط ہے۔
68,46,اَمْ تَسْئَلُهُمْ اَجْرًا فَهُمْ مِّنْ مَّغْرَمٍ مُّثْقَلُوْنَۚ اَمْ تَسْئَلُهُمْ : یا تم سوال کرتے ہو ان سے اَجْرًا : کسی اجر کا فَهُمْ : تو وہ مِّنْ مَّغْرَمٍ : تاوان سے مُّثْقَلُوْنَ : دبے جاتے ہوں کیا تو ان سے کوئی اجرت چاہتا ہے جس کے تاوان سے یہ دبے جاتے ہوں (1)
68,47,اَمْ عِنْدَهُمُ الْغَیْبُ فَهُمْ یَكْتُبُوْنَ اَمْ : یا عِنْدَهُمُ : ان کے پاس الْغَيْبُ : کوئی غیب ہے فَهُمْ يَكْتُبُوْنَ : تو وہ لکھ رہے ہیں ان کے پاس علم غیب ہے جسے وہ لکھتے ہوں۔ (1)
68,48,فَاصْبِرْ لِحُكْمِ رَبِّكَ وَ لَا تَكُنْ كَصَاحِبِ الْحُوْتِ١ۘ اِذْ نَادٰى وَ هُوَ مَكْظُوْمٌؕ فَاصْبِرْ : پس صبر کرو لِحُكْمِ رَبِّكَ : اپنے رب کے حکم کے لیے وَلَا تَكُنْ : اور نہ تم ہو كَصَاحِبِ الْحُوْتِ : مانند مچھلی والے کے اِذْ نَادٰى : جب اس نے پکارا وَهُوَ مَكْظُوْمٌ : اور وہ غم سے بھرا ہوا تھا بس تو اپنے رب کے حکم کا صبر سے انتظار کر اور مچھلی والے کی طرح نہ ہوجا جب (1) کہ اس نے غم کی حالت میں دعا کی (1)
68,49,لَوْ لَاۤ اَنْ تَدٰرَكَهٗ نِعْمَةٌ مِّنْ رَّبِّهٖ لَنُبِذَ بِالْعَرَآءِ وَ هُوَ مَذْمُوْمٌ لَوْلَآ : اگر نہ ہوتی یہ بات اَنْ تَدٰرَكَهٗ : کہ پالیا اس کو نِعْمَةٌ : ایک نعمت نے مِّنْ رَّبِّهٖ : اس کے رب کی طرف سے لَنُبِذَ : البتہ پھینک دیا جاتا بِالْعَرَآءِ : چٹیل میدان میں وَهُوَ : اور وہ مَذْمُوْمٌ : مذموم ہوتا اگر اسے اس کے رب کی نعمت نہ پالیتی تو یقیناً وہ برے حالوں میں چٹیل میدان میں ڈال دیا جاتا (1)۔
68,50,فَاجْتَبٰىهُ رَبُّهٗ فَجَعَلَهٗ مِنَ الصّٰلِحِیْنَ فَاجْتَبٰىهُ : تو چن لیا اس کو رَبُّهٗ : اس کے رب نے فَجَعَلَهٗ : تو بنادیا اس کو مِنَ الصّٰلِحِيْنَ : صالح لوگوں میں سے اس کے رب نے پھر نوازا اور اسے نیک کاروں میں کردیا (1)
68,51,وَ اِنْ یَّكَادُ الَّذِیْنَ كَفَرُوْا لَیُزْلِقُوْنَكَ بِاَبْصَارِهِمْ لَمَّا سَمِعُوا الذِّكْرَ وَ یَقُوْلُوْنَ اِنَّهٗ لَمَجْنُوْنٌۘ وَاِنْ يَّكَادُ : اور بیشک قریب ہے کہ الَّذِيْنَ كَفَرُوْا : وہ لوگ جنہوں نے کفر کیا لَيُزْلِقُوْنَكَ : البتہ پھیلا دیں گے آپ کو بِاَبْصَارِهِمْ : اپنی نگاہوں سے لَمَّا سَمِعُوا : جب وہ سنتے ہیں الذِّكْرَ : ذکر کو وَيَقُوْلُوْنَ : اور وہ کہتے ہیں اِنَّهٗ لَمَجْنُوْنٌ : بیشک وہ البتہ مجنون ہے اور قریب ہے کہ کافر اپنی تیز نگاہوں سے آپ کو پھسلا دیں (1) جب کبھی قرآن سنتے ہیں اور کہہ دیتے ہیں یہ تو ضرور دیوانہ ہے (2)
68,52,وَ مَا هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِیْنَ۠    ۧ وَمَا هُوَ : اور نہیں ہے وہ اِلَّا ذِكْرٌ لِّلْعٰلَمِيْنَ : مگر ایک نصیحت جہانوں کے لیے در حقیقت یہ (قرآن) تو تمام جہان والوں کے لئے سراسر نصیحت ہے (1)
