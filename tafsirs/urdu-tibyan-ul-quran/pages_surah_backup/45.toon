quran[37]{c,v,t}:
45,1,حٰمٓۚ حٰمٓ : حا۔ میم حم
45,2,تَنْزِیْلُ الْكِتٰبِ مِنَ اللّٰهِ الْعَزِیْزِ الْحَكِیْمِ تَنْزِيْلُ : نازل کرتا ہے الْكِتٰبِ : کتاب کا مِنَ اللّٰهِ : اللہ کی طرف الْعَزِيْزِ الْحَكِيْمِ : جو زبردست ہے، حکمت والا ہے یہ کتاب اللہ غالب حکمت والے کی طرف سے نازل کی ہوئی ہے۔
45,3,اِنَّ فِی السَّمٰوٰتِ وَ الْاَرْضِ لَاٰیٰتٍ لِّلْمُؤْمِنِیْنَؕ اِنَّ فِي السَّمٰوٰتِ : بیشک آسمانوں میں وَالْاَرْضِ : اور زمین میں لَاٰيٰتٍ لِّلْمُؤْمِنِيْنَ : البتہ نشانیاں ہیں ایمان لانے والوں کے لیے آسمانوں اور زمین میں ایمان داروں کے لئے یقیناً بہت سی نشانیاں ہیں۔
45,4,وَ فِیْ خَلْقِكُمْ وَ مَا یَبُثُّ مِنْ دَآبَّةٍ اٰیٰتٌ لِّقَوْمٍ یُّوْقِنُوْنَۙ وَفِيْ خَلْقِكُمْ : اور تمہاری پیدائش میں وَمَا يَبُثُّ : اور جو پھیلا رہا ہے مِنْ دَآبَّةٍ : جانوروں میں سے اٰيٰتٌ : نشانیاں ہیں لِّقَوْمٍ يُّوْقِنُوْنَ : ان لوگوں کے لیے جو یقین رکھتے ہوں اور خود تمہاری پیدائش میں اور ان جانوروں کی پیدائش میں جنہیں وہ پھیلاتا ہے یقین رکھنے والی قوم کے لئے بہت سی نشانیاں ہیں۔
45,5,وَ اخْتِلَافِ الَّیْلِ وَ النَّهَارِ وَ مَاۤ اَنْزَلَ اللّٰهُ مِنَ السَّمَآءِ مِنْ رِّزْقٍ فَاَحْیَا بِهِ الْاَرْضَ بَعْدَ مَوْتِهَا وَ تَصْرِیْفِ الرِّیٰحِ اٰیٰتٌ لِّقَوْمٍ یَّعْقِلُوْنَ وَاخْتِلَافِ الَّيْلِ وَالنَّهَارِ : اور رات اور دن کے اختلاف میں وَمَآ : اور جو اَنْزَلَ اللّٰهُ : نازل کیا اللہ نے مِنَ السَّمَآءِ : آسمان سے مِنْ رِّزْقٍ : رزق میں سے فَاَحْيَا : پھر اس نے زندہ کیا بِهِ الْاَرْضَ : ساتھ اس کے زمین کو بَعْدَ مَوْتِهَا : اس کی موت کے بعد وَتَصْرِيْفِ الرِّيٰحِ : اور ہواؤں کی گردش میں اٰيٰتٌ : نشانیاں ہیں لِّقَوْمٍ يَّعْقِلُوْنَ : اس قوم کے لیے جو عقل رکھتی ہو اور رات دن کے بدلے میں اور جو کچھ روزی اللہ تعالیٰ آسمان سے نازل فرما کر زمین کو اسکی موت کے بعد زندہ کردیتا ہے (1) (اس میں) اور ہواؤں کے بدلنے میں بھی ان لوگوں کے لئے جو عقل رکھتے ہیں نشانیاں ہیں (2)۔
45,6,تِلْكَ اٰیٰتُ اللّٰهِ نَتْلُوْهَا عَلَیْكَ بِالْحَقِّ١ۚ فَبِاَیِّ حَدِیْثٍۭ بَعْدَ اللّٰهِ وَ اٰیٰتِهٖ یُؤْمِنُوْنَ تِلْكَ : یہ اٰيٰتُ اللّٰهِ : اللہ کی آیات ہیں نَتْلُوْهَا : ہم پڑھتے ہیں ان کو عَلَيْكَ بالْحَقِّ : آپ پر حق کے ساتھ فَبِاَيِّ حَدِيْثٍۢ : تو ساتھ کون سی بات کے بَعْدَ اللّٰهِ : بعد اللہ کے وَ : اور اٰيٰتِهٖ يُؤْمِنُوْنَ : اس کی آیات کے وہ ایمان لائیں گے یہ ہیں اللہ کی آیتیں جنہیں ہم آپ کو راستی سے سنا رہے ہیں، پس اللہ تعالیٰ اور اس کی آیتوں کے بعد یہ کس بات پر ایمان لائیں گے۔ (1)
45,7,وَیْلٌ لِّكُلِّ اَفَّاكٍ اَثِیْمٍۙ وَيْلٌ : ہلاکت ہے لِّكُلِّ : واسطے ہر اَفَّاكٍ : بہت جھوٹے اَثِيْمٍ : بہت گناہ گار کے ' ویل ' اور افسوس ہے ہر ایک جھوٹے گنہگار پر۔
45,8,یَّسْمَعُ اٰیٰتِ اللّٰهِ تُتْلٰى عَلَیْهِ ثُمَّ یُصِرُّ مُسْتَكْبِرًا كَاَنْ لَّمْ یَسْمَعْهَا١ۚ فَبَشِّرْهُ بِعَذَابٍ اَلِیْمٍ يَّسْمَعُ : وہ سنتا ہے اٰيٰتِ اللّٰهِ : اللہ کی آیات کو تُتْلٰى عَلَيْهِ : پڑھی جاتی ہیں اس پر ثُمَّ : پھر يُصِرُّ : وہ اڑ جاتا ہے۔ اصرار کرتا ہے مُسْتَكْبِرًا : تکبر کرتے ہوئے كَاَنْ لَّمْ : گویا کہ نہیں يَسْمَعْهَا : اس نے سنا اس کو فَبَشِّرْهُ : تو خوش خبری دے دو اس کو بِعَذَابٍ اَلِيْمٍ : دردناک عذاب کی جو آیتیں اللہ کے اپنے سامنے پڑھی جاتی ہوئی سنے پھر بھی غرور کرتا ہوا اس طرح اڑا رہے کہ گویا سنی ہی نہیں (1) تو ایسے لوگوں کو دردناک عذاب کی خبر (پہنچا) دیجئے۔
45,9,وَ اِذَا عَلِمَ مِنْ اٰیٰتِنَا شَیْئَا اِ۟تَّخَذَهَا هُزُوًا١ؕ اُولٰٓئِكَ لَهُمْ عَذَابٌ مُّهِیْنٌؕ وَاِذَا : اور جب عَلِمَ : وہ جان لیتا ہے مِنْ اٰيٰتِنَا : ہماری آیات میں سے شَيْئَۨا : کوئی چیز اتَّخَذَهَا : بنالیتا ہے اس کو هُزُوًا : مذاق اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے عَذَابٌ مُّهِيْنٌ : عذاب ہے رسوا کرنے والا۔ ذلیل کرنے والے وہ جب ہماری آیتوں میں سے کسی آیت کی خبر پا لیتا ہے تو اس کی ہنسی اڑاتا ہے (1) یہی لوگ ہیں جن کے لئے رسوائی کی مار ہے۔
45,10,مِنْ وَّرَآئِهِمْ جَهَنَّمُ١ۚ وَ لَا یُغْنِیْ عَنْهُمْ مَّا كَسَبُوْا شَیْئًا وَّ لَا مَا اتَّخَذُوْا مِنْ دُوْنِ اللّٰهِ اَوْلِیَآءَ١ۚ وَ لَهُمْ عَذَابٌ عَظِیْمٌؕ مِنْ وَّرَآئِهِمْ : ان کے آگے جَهَنَّمُ : جہنم ہے وَلَا يُغْنِيْ : اور نہ کام آئے گا عَنْهُمْ : ان کو مَّا كَسَبُوْا شَيْئًا : جو انہوں نے کمایا کچھ بھی وَّلَا : اور نہ مَا اتَّخَذُوْا : جو انہوں نے بنا لیے مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا سے اَوْلِيَآءَ : سرپرست۔ مددگار وَلَهُمْ : اور ان کے لیے عَذَابٌ : عذاب ہے عَظِيْمٌ : بڑا ان کے پیچھے دوزخ ہے (1) جو کچھ انہوں نے حاصل کیا تھا وہ انہیں کچھ بھی نفع نہ دے گا اور نہ وہ (کچھ کام آئیں گے) جن کو انہوں نے اللہ کے سوا کارساز بنا رکھا تھا ان کے لئے تو بہت بڑا عذاب ہے۔
45,11,هٰذَا هُدًى١ۚ وَ الَّذِیْنَ كَفَرُوْا بِاٰیٰتِ رَبِّهِمْ لَهُمْ عَذَابٌ مِّنْ رِّجْزٍ اَلِیْمٌ۠    ۧ ھٰذَا هُدًى : یہ ہے ہدایت وَالَّذِيْنَ كَفَرُوْا : اور وہ لوگ جنہوں نے انکار کیا بِاٰيٰتِ : آیات کا رَبِّهِمْ : اپنے رب کی لَهُمْ : ان کے لیے عَذَابٌ : عذاب ہے مِّنْ رِّجْزٍ اَلِيْمٌ : ہے قرار کرنے والا۔ رسوا کن یہ (سرتاپا) ہدایت (1) ہے اور جن لوگوں نے اپنے رب کی آیتوں کو نہ مانا ان کے لئے بہت سخت دردناک عذاب ہے۔
45,12,اَللّٰهُ الَّذِیْ سَخَّرَ لَكُمُ الْبَحْرَ لِتَجْرِیَ الْفُلْكُ فِیْهِ بِاَمْرِهٖ وَ لِتَبْتَغُوْا مِنْ فَضْلِهٖ وَ لَعَلَّكُمْ تَشْكُرُوْنَۚ اَللّٰهُ : اللہ الَّذِيْ : وہ ذات ہے سَخَّرَ : جس نے مسخر کیا لَكُمُ الْبَحْرَ : تمہارے لیے سمندر کو لِتَجْرِيَ الْفُلْكُ : تاکہ چلیں کشتیاں فِيْهِ : اس میں بِاَمْرِهٖ : ساتھ اس کے حکم کے وَلِتَبْتَغُوْا : اور تاکہ تم تلاش کرو مِنْ فَضْلِهٖ : اس کے فضل میں وَلَعَلَّكُمْ : اور تاکہ تم تَشْكُرُوْنَ : تم شکرادا کرو اللہ ہی ہے جس نے تمہارے لئے دریا (1) کو تابع بنادیا تاکہ اس کے حکم سے اس میں کشتیاں چلیں اور تم اس کا فضل تلاش کرو اور تاکہ تم شکر بجا لاؤ۔
45,13,وَ سَخَّرَ لَكُمْ مَّا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ جَمِیْعًا مِّنْهُ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّقَوْمٍ یَّتَفَكَّرُوْنَ وَسَخَّرَ لَكُمْ : اور اس نے مسخر کیا تمہارے لیے مَّا فِي السَّمٰوٰتِ : جو کچھ آسمانوں میں ہے وَمَا : اور جو کچھ فِي الْاَرْضِ : زمین میں ہے جَمِيْعًا : سارے کا سارا مِّنْهُ : اس سے اِنَّ فِيْ ذٰلِكَ : بیشک اس میں لَاٰيٰتٍ : البتہ نشانیاں لِّقَوْمٍ يَّتَفَكَّرُوْنَ : اس قوم کے لیے جو غور و فکر کرتی ہو اور آسمان و زمین کی ہر ہر چیز کو بھی اس نے اپنی طرف سے تمہارے لئے تابع کردیا ہے (1) جو غور کریں یقیناً وہ اس میں بہت سی نشانیاں پالیں گے۔
45,14,قُلْ لِّلَّذِیْنَ اٰمَنُوْا یَغْفِرُوْا لِلَّذِیْنَ لَا یَرْجُوْنَ اَیَّامَ اللّٰهِ لِیَجْزِیَ قَوْمًۢا بِمَا كَانُوْا یَكْسِبُوْنَ قُلْ : کہہ دیجئے لِّلَّذِيْنَ اٰمَنُوْا : ان لوگوں کو جو ایمان لائے يَغْفِرُوْا : درگزر کریں لِلَّذِيْنَ : ان لوگوں کے لیے لَا يَرْجُوْنَ : نہیں وہ امید رکھتے اَيَّامَ اللّٰهِ : اللہ کے دنوں کی لِيَجْزِيَ : تاکہ وہ بدلہ دے قَوْمًۢا : ایک قوم کو بِمَا : بوجہ اس کے جو كَانُوْا : تھے وہ يَكْسِبُوْنَ : کمائی کرتے آپ ایمان والوں سے کہہ دیں کہ وہ ان لوگوں سے درگزر کریں جو اللہ کے دنوں کی توقع نہیں رکھتے، تاکہ اللہ تعالیٰ ایک قوم کو ان کے کرتوتوں کا بدلہ دے۔
45,15,مَنْ عَمِلَ صَالِحًا فَلِنَفْسِهٖ١ۚ وَ مَنْ اَسَآءَ فَعَلَیْهَا١٘ ثُمَّ اِلٰى رَبِّكُمْ تُرْجَعُوْنَ مَنْ عَمِلَ : جس نے عمل کیے صَالِحًا : اچھے فَلِنَفْسِهٖ : تو اس کی ذات کے لیے وَمَنْ اَسَآءَ : اور جو برائی کرتا ہے فَعَلَيْهَا : تو اسی پر ہے (اس کا ذمہ) ثُمَّ : پھر اِلٰى رَبِّكُمْ : اپنے رب کی طرف تُرْجَعُوْنَ : تم سب لوٹائے جاؤ گے جو نیکی کرے گا وہ اپنے ذاتی بھلے کے لئے اور جو برائی کرے گا اس کا وبال اسی پر ہے (1) پھر تم سب اپنے پروردگار کی طرف لوٹائے جاؤ گے۔
45,16,وَ لَقَدْ اٰتَیْنَا بَنِیْۤ اِسْرَآءِیْلَ الْكِتٰبَ وَ الْحُكْمَ وَ النُّبُوَّةَ وَ رَزَقْنٰهُمْ مِّنَ الطَّیِّبٰتِ وَ فَضَّلْنٰهُمْ عَلَى الْعٰلَمِیْنَۚ وَلَقَدْ اٰتَيْنَا : اور البتہ تحقیق دی ہم نے بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل کو الْكِتٰبَ : کتاب وَالْحُكْمَ : اور حکومت وَالنُّبُوَّةَ : اور نبوت وَرَزَقْنٰهُمْ : اور رزق دیا ہم نے ان کو مِّنَ : سے الطَّيِّبٰتِ : پاکیزہ چیزوں میں (سے) وَفَضَّلْنٰهُمْ : اور فضیلت دی ہم نے ان کو عَلَي الْعٰلَمِيْنَ : تمام جہانوں پر یقیناً ہم نے بنی اسرائیل کو کتاب، حکومت (1) اور نبوت دی تھی اور ہم نے انہیں پاکیزہ اور نفیس روزیاں دی تھیں اور انہیں دنیا والوں پر فضیلت دی تھی۔
45,17,وَ اٰتَیْنٰهُمْ بَیِّنٰتٍ مِّنَ الْاَمْرِ١ۚ فَمَا اخْتَلَفُوْۤا اِلَّا مِنْۢ بَعْدِ مَا جَآءَهُمُ الْعِلْمُ١ۙ بَغْیًۢا بَیْنَهُمْ١ؕ اِنَّ رَبَّكَ یَقْضِیْ بَیْنَهُمْ یَوْمَ الْقِیٰمَةِ فِیْمَا كَانُوْا فِیْهِ یَخْتَلِفُوْنَ وَاٰتَيْنٰهُمْ : اور دیں ہم نے ان کو بَيِّنٰتٍ : واضح نشانیاں مِّنَ الْاَمْرِ : دین میں سے فَمَا اخْتَلَفُوْٓا : تو نہیں انہوں نے اختلاف کیا اِلَّا مِنْۢ بَعْدِ : اس کے بعد مَا جَآءَهُمُ الْعِلْمُ : جو آیا ان کے پاس علم بَغْيًۢا : بغاوت۔ سرکشی کی وجہ سے بَيْنَهُمْ : آپس میں اِنَّ رَبَّكَ : بیشک رب تیرا يَقْضِيْ : فیصلہ کرے گا بَيْنَهُمْ : ان کے درمیان يَوْمَ الْقِيٰمَةِ : قیامت کے دن فِيْمَا كَانُوْا : اس میں سے جو تھے وہ فِيْهِ : جس میں يَخْتَلِفُوْنَ : وہ اختلاف کرتے اور ہم نے انہیں دین کی صاف صاف دلیلیں دیں (1) پھر انہوں نے اپنے پاس علم کے پہنچ جانے کے بعد آپس کی ضد بحث سے ہی اختلاف برپا کر ڈالا یہ جن جن چیزوں میں اختلاف کر رہے ہیں ان کا فیصلہ قیامت والے دن ان کے درمیان (خود) تیرا رب کرے گا (2)۔
45,18,ثُمَّ جَعَلْنٰكَ عَلٰى شَرِیْعَةٍ مِّنَ الْاَمْرِ فَاتَّبِعْهَا وَ لَا تَتَّبِعْ اَهْوَآءَ الَّذِیْنَ لَا یَعْلَمُوْنَ ثُمَّ جَعَلْنٰكَ : پھر لگایا ہم نے آپ کو عَلٰي شَرِيْعَةٍ : اوپر ایک طریقے کے۔ شریعت کے مِّنَ الْاَمْرِ : دین میں سے۔ حکم میں سے فَاتَّبِعْهَا : پس پیروی کرو اس کی وَلَا : اور نہ تَتَّبِعْ : تم پیروی کرو اَهْوَآءَ الَّذِيْنَ : ان لوگوں کی خواہشات کی لَا يَعْلَمُوْنَ : جو علم نہیں رکھتے پھر ہم نے آپ کو دین کی (ظاہر) راہ پر قائم کردیا (1) سو آپ اس پر لگیں رہیں اور نادانوں کی خواہش کی پیروی میں نہ پڑیں (2)۔
45,19,اِنَّهُمْ لَنْ یُّغْنُوْا عَنْكَ مِنَ اللّٰهِ شَیْئًا١ؕ وَ اِنَّ الظّٰلِمِیْنَ بَعْضُهُمْ اَوْلِیَآءُ بَعْضٍ١ۚ وَ اللّٰهُ وَلِیُّ الْمُتَّقِیْنَ اِنَّهُمْ : بیشک وہ لَنْ يُّغْنُوْا : نہیں کام آسکتے عَنْكَ : تجھ کو مِنَ اللّٰهِ : اللہ سے شَيْئًا : کچھ بھی وَاِنَّ : اور بیشک الظّٰلِمِيْنَ : ظالم لوگ بَعْضُهُمْ : ان میں سے بعض اَوْلِيَآءُ : دوست ہیں بَعْضٍ : بعض کے وَاللّٰهُ : اور اللہ وَلِيُّ : دوست ہے الْمُتَّقِيْنَ : متقی لوگوں کا (یاد رکھیں) کہ یہ لوگ ہرگز اللہ کے سامنے آپ کے کچھ کام نہیں آسکتے (سمجھ لیں کہ) ظالم لوگ آپس میں ایک دوسرے کے رفیق ہوتے ہیں اور پرہیزگاروں کا کارساز اللہ تعالیٰ ہے۔
45,20,هٰذَا بَصَآئِرُ لِلنَّاسِ وَ هُدًى وَّ رَحْمَةٌ لِّقَوْمٍ یُّوْقِنُوْنَ ھٰذَا بَصَآئِرُ : یہ روشن نشانیاں ہیں۔ بصیرت کی روشنیاں ہیں لِلنَّاسِ : لوگوں کے لیے وَهُدًى : اور ہدایت وَّرَحْمَةٌ : اور رحمت لِّقَوْمٍ يُّوْقِنُوْنَ : اس قوم کے لیے جو یقین رکھتی ہو یہ (قرآن) ان لوگوں کے لئے بصیرت کی باتیں (1) اور ہدایت و رحمت ہے (2) اس قوم کے لئے جو یقین رکھتی ہے۔
45,21,اَمْ حَسِبَ الَّذِیْنَ اجْتَرَحُوا السَّیِّاٰتِ اَنْ نَّجْعَلَهُمْ كَالَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ١ۙ سَوَآءً مَّحْیَاهُمْ وَ مَمَاتُهُمْ١ؕ سَآءَ مَا یَحْكُمُوْنَ۠    ۧ اَمْ : یا حَسِبَ الَّذِيْنَ : خیال کیا ان لوگوں نے اجْتَرَحُوا : جنہوں نے کام کیے۔ کمائی کی السَّيِّاٰتِ : برے اَنْ نَّجْعَلَهُمْ : کہ ہم کردیں گے ان کو كَالَّذِيْنَ : ان لوگوں کی طرح اٰمَنُوْا : جو ایمان لائے وَعَمِلُوا الصّٰلِحٰتِ : اور انہوں نے عمل کیے اچھے سَوَآءً : برابر ہے مَّحْيَاهُمْ : ان کا جینا وَمَمَاتُهُمْ : اور ان کا مرنا سَآءَ : کتنا برا ہے مَا يَحْكُمُوْنَ : جو وہ فیصلہ کررہے ہیں کیا ان لوگوں کا جو برے کام کرتے ہیں یہ گمان ہے کہ ہم انہیں ان لوگوں جیسا کردیں جو ایمان لائے اور نیک کام کئے ان کا مرنا جینا یکساں ہوجائے (1) برا ہے وہ فیصلہ وہ جو کر رہے ہیں۔
45,22,وَ خَلَقَ اللّٰهُ السَّمٰوٰتِ وَ الْاَرْضَ بِالْحَقِّ وَ لِتُجْزٰى كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ وَ هُمْ لَا یُظْلَمُوْنَ وَخَلَقَ اللّٰهُ : اور پیدا کیا اللہ نے السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین بالْحَقِّ : حق (حکمت) کے ساتھ وَلِتُجْزٰى : اور تا کہ بدلہ دیا جائے كُلُّ نَفْسٍۢ : ہر شخص بِمَا : اس کا كَسَبَتْ : جو اس نے کمایا (اعمال) وَهُمْ : اور وہ لَا يُظْلَمُوْنَ : ظلم نہ کئے جائیں گے اور آسمانوں اور زمین کو اللہ نے بہت ہی عدل کے ساتھ پیدا کیا ہے اور تاکہ ہر شخص کو اس کے کئے ہوئے کام کا پورا پورا بدلہ دیا جائے اور ان پر ظلم نہ کیا جائے۔
45,23,اَفَرَءَیْتَ مَنِ اتَّخَذَ اِلٰهَهٗ هَوٰىهُ وَ اَضَلَّهُ اللّٰهُ عَلٰى عِلْمٍ وَّ خَتَمَ عَلٰى سَمْعِهٖ وَ قَلْبِهٖ وَ جَعَلَ عَلٰى بَصَرِهٖ غِشٰوَةً١ؕ فَمَنْ یَّهْدِیْهِ مِنْۢ بَعْدِ اللّٰهِ١ؕ اَفَلَا تَذَكَّرُوْنَ اَفَرَءَيْتَ : کیا پھر تم نے دیکھا مَنِ اتَّخَذَ : جس نے بنا لیا اِلٰهَهٗ : اپنا الہ هَوٰىهُ : اپنی خواہش نفس کو وَاَضَلَّهُ اللّٰهُ : اور بھٹکا دیا اس کو اللہ نے عَلٰي عِلْمٍ : علم کے باوجود وَّخَتَمَ : اور مہر لگا دی عَلٰي سَمْعِهٖ : اس کے کان پر وَقَلْبِهٖ : اور اس کے دل پر وَجَعَلَ : اور اس نے ڈال دیا عَلٰي بَصَرِهٖ : اس کی آنکھ پر غِشٰوَةً : ایک پردہ فَمَنْ يَّهْدِيْهِ : تو کون ہدایت دے گا اس کو مِنْۢ بَعْدِ اللّٰهِ : اللہ کے بعد اَفَلَا : کیا بھلا نہیں تَذَكَّرُوْنَ : تم نصیحٹ پکڑتے کیا آپ نے اسے بھی دیکھا ؟ جس نے اپنی خواہش نفس کو اپنا معبود بنا رکھا ہے اور باوجود سمجھ بوجھ کے اللہ نے اسے گمراہ کردیا (1) ہے اور اس کے کان اور دل پر مہر لگا دی ہے اور اس کی آنکھ پر بھی پردہ ڈال دیا (2) ہے اب ایسے شخص کو اللہ کے بعد کون ہدایت دے سکتا ہے۔
45,24,وَ قَالُوْا مَا هِیَ اِلَّا حَیَاتُنَا الدُّنْیَا نَمُوْتُ وَ نَحْیَا وَ مَا یُهْلِكُنَاۤ اِلَّا الدَّهْرُ١ۚ وَ مَا لَهُمْ بِذٰلِكَ مِنْ عِلْمٍ١ۚ اِنْ هُمْ اِلَّا یَظُنُّوْنَ وَقَالُوْا : اور انہوں نے کہا مَا هِىَ : نہیں ہے یہ اِلَّا حَيَاتُنَا : مگر ہماری زندگی الدُّنْيَا : دنیا کی نَمُوْتُ : ہم مریں گے وَنَحْيَا : اور ہم جئیں گے وَمَا يُهْلِكُنَآ : اور ہلاک کرتا ہم کو اِلَّا الدَّهْرُ : مگر زمانہ وَمَا لَهُمْ : اور نہیں ان کے لیے بِذٰلِكَ : اس کا مِنْ عِلْمٍ : کوئی علم اِنْ هُمْ : نہیں وہ اِلَّا : مگر يَظُنُّوْنَ : وہ گمان کرتے ہیں کیا اب بھی تم نصیحت نہیں پکڑتے انہوں نے کہا کہ ہماری زندگی تو صرف دنیا کی زندگی ہی ہے۔ ہم مرتے ہیں اور جیتے ہیں اور ہمیں صرف زمانہ ہی مار ڈالتا ہے (1) (دراصل) انہیں اس کا علم ہی نہیں یہ تو صرف قیاس آرائیاں ہیں اور اٹکل سے ہی کام لے رہے ہیں۔
45,25,وَ اِذَا تُتْلٰى عَلَیْهِمْ اٰیٰتُنَا بَیِّنٰتٍ مَّا كَانَ حُجَّتَهُمْ اِلَّاۤ اَنْ قَالُوا ائْتُوْا بِاٰبَآئِنَاۤ اِنْ كُنْتُمْ صٰدِقِیْنَ وَاِذَا تُتْلٰى : اور جب پڑھی جاتی ہیں عَلَيْهِمْ : ان پر اٰيٰتُنَا : ہماری آیات ۔ نشانیاں بَيِّنٰتٍ : روشن مَّا كَانَ : نہیں ہوتی حُجَّتَهُمْ : ان کی حجت اِلَّآ : مگر اَنْ قَالُوا : یہ کہ وہ کہتے ہیں ائْتُوْا : لاؤ بِاٰبَآئِنَآ : ہمارے باپ دادا کو اِنْ كُنْتُمْ : اگر ہو تم صٰدِقِيْنَ : سچے اور جب ان کے سامنے ہماری واضح اور روشن آیتوں کی تلاوت کی جاتی ہے تو ان کے پاس اس قول کے سوا کوئی دلیل نہیں ہوتی کہ اگر تم سچے ہو تو ہمارے باپ دادوں کو لاؤ (1)
45,26,قُلِ اللّٰهُ یُحْیِیْكُمْ ثُمَّ یُمِیْتُكُمْ ثُمَّ یَجْمَعُكُمْ اِلٰى یَوْمِ الْقِیٰمَةِ لَا رَیْبَ فِیْهِ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ۠    ۧ قُلِ اللّٰهُ : کہہ دیجئے اللہ يُحْيِيْكُمْ : زندہ کرتا ہے تم کو ثُمَّ يُمِيْتُكُمْ : پھر موت دے گا تم کو ثُمَّ يَجْمَعُكُمْ : پھر جمع کرے گا تم کو اِلٰى يَوْمِ : دن تک الْقِيٰمَةِ : قیامت کے لَا رَيْبَ فِيْهِ : نہیں کوئی شک اس میں وَلٰكِنَّ : لیکن اَكْثَرَ النَّاسِ : اکثر لوگ لَا يَعْلَمُوْنَ : علم نہیں رکھتے آپ کہہ دیجئے ! اللہ ہی تمہیں زندہ کرتا ہے پھر تمہیں مار ڈالتا ہے پھر تمہیں قیامت کے دن جمع کرے گا جس میں کوئی شک نہیں لیکن اکثر لوگ نہیں سمجھتے۔
45,27,وَ لِلّٰهِ مُلْكُ السَّمٰوٰتِ وَ الْاَرْضِ١ؕ وَ یَوْمَ تَقُوْمُ السَّاعَةُ یَوْمَئِذٍ یَّخْسَرُ الْمُبْطِلُوْنَ وَلِلّٰهِ : اور اللہ ہی کے لیے ہے مُلْكُ السَّمٰوٰتِ : بادشاہت آسمانوں کی وَالْاَرْضِ : اور زمین کی وَيَوْمَ : اور جس دن تَقُوْمُ السَّاعَةُ : قائم ہوگی قیامت يَوْمَئِذٍ : اس دن يَّخْسَرُ الْمُبْطِلُوْنَ : خسارہ پاجائیں گے باطل پرست اور آسمانوں اور زمین کی بادشاہی اللہ ہی کی ہے اور جس دن قیامت قائم ہوگی اس دن اہل باطل بڑے نقصان میں پڑیں گے۔
45,28,وَ تَرٰى كُلَّ اُمَّةٍ جَاثِیَةً١۫ كُلُّ اُمَّةٍ تُدْعٰۤى اِلٰى كِتٰبِهَا١ؕ اَلْیَوْمَ تُجْزَوْنَ مَا كُنْتُمْ تَعْمَلُوْنَ وَتَرٰى : اور تم دیکھو گے كُلَّ اُمَّةٍ : ہر امت کو جَاثِيَةً : گھٹنوں پر گری ہوئی۔ زانوؤں پر گری ہوئی كُلُّ اُمَّةٍ : ہر امت تُدْعٰٓى : بلائی جائے گی اِلٰى كِتٰبِهَا : طرف اپنے اعمال نامے کے اَلْيَوْمَ : آج تُجْزَوْنَ : تم جزا دئیے جاؤ گے مَا كُنْتُمْ : جو تھے تم تَعْمَلُوْنَ : تم عمل کرتے اور آپ دیکھیں گے کہ ہر امت گھٹنوں کے بل گری ہوئی ہوگی (1) ہر گروہ اپنے نامہ اعمال کی طرف بلایا جائے گا آج تمہیں اپنے کئے کا بدلہ دیا جائے گا۔
45,29,هٰذَا كِتٰبُنَا یَنْطِقُ عَلَیْكُمْ بِالْحَقِّ١ؕ اِنَّا كُنَّا نَسْتَنْسِخُ مَا كُنْتُمْ تَعْمَلُوْنَ ھٰذَا كِتٰبُنَا : یہ ہے کتاب ہماری يَنْطِقُ : بولے گی عَلَيْكُمْ : تم پر بِالْحَقِّ : حق کے ساتھ اِنَّا : بیشک ہم كُنَّا نَسْتَنْسِخُ : لکھواتے تھے ہم مَا كُنْتُمْ : جو تھے تم تَعْمَلُوْنَ : تم عمل کرتے یہ ہماری کتاب جو تمہارے بارے میں سچ سچ بول رہی ہے ہم تمہارے اعمال لکھواتے جاتے تھے (1)۔
45,30,فَاَمَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ فَیُدْخِلُهُمْ رَبُّهُمْ فِیْ رَحْمَتِهٖ١ؕ ذٰلِكَ هُوَ الْفَوْزُ الْمُبِیْنُ فَاَمَّا : تو رہے الَّذِيْنَ : وہ لوگ اٰمَنُوْا : جو ایمان لائے وَعَمِلُوا الصّٰلِحٰتِ : اور انہوں نے عمل کیے اچھے فَيُدْخِلُهُمْ : تو داخل کرے گا ان کو رَبُّهُمْ : ان کا رب فِيْ رَحْمَتِهٖ : اپنی رحمت میں ذٰلِكَ : یہ ہے هُوَ الْفَوْزُ : وہ کامیابی الْمُبِيْنُ : جو کھلی۔ صریح ہے پس لیکن جو لوگ ایمان لائے اور انہوں نے نیک کام (1) کئے تو ان کو ان کا رب اپنی رحمت تلے لے لے گا یہی صریح کامیابی ہے۔
45,31,وَ اَمَّا الَّذِیْنَ كَفَرُوْا١۫ اَفَلَمْ تَكُنْ اٰیٰتِیْ تُتْلٰى عَلَیْكُمْ فَاسْتَكْبَرْتُمْ وَ كُنْتُمْ قَوْمًا مُّجْرِمِیْنَ وَاَمَّا الَّذِيْنَ : اور ہے وہ لوگ كَفَرُوْا : جنہوں نے کفر کیا اَفَلَمْ : کیا پھر نہ تَكُنْ اٰيٰتِيْ : تھیں میری آیات تُتْلٰى : پڑھی جاتیں عَلَيْكُمْ : تم پر فَاسْتَكْبَرْتُمْ : تو تکبر کیا تم نے وَكُنْتُمْ : اور تھے تم قَوْمًا مُّجْرِمِيْنَ : مجرم لوگ لیکن جن لوگوں نے کفر کیا تو (میں ان سے کہوں گا) کیا میری آیتیں تمہیں سنائی نہیں جاتی تھیں (1) پھر بھی تم تکبر کرتے رہے اور تم تھے ہی گناہ گار لوگ (2)
45,32,وَ اِذَا قِیْلَ اِنَّ وَعْدَ اللّٰهِ حَقٌّ وَّ السَّاعَةُ لَا رَیْبَ فِیْهَا قُلْتُمْ مَّا نَدْرِیْ مَا السَّاعَةُ١ۙ اِنْ نَّظُنُّ اِلَّا ظَنًّا وَّ مَا نَحْنُ بِمُسْتَیْقِنِیْنَ وَاِذَا قِيْلَ : اور جب کہا جاتا اِنَّ وَعْدَ اللّٰهِ : بیشک وعدہ اللہ کا حَقٌّ : سچا ہے وَّالسَّاعَةُ : اور قیامت لَا رَيْبَ فِيْهَا : نہیں کوئی شک اس میں قُلْتُمْ : کہا تم نے مَّا نَدْرِيْ : ہم نہیں جانتے مَا السَّاعَةُ : قیامت کیا ہوتی ہے اِنْ نَّظُنُّ : نہیں ہم سمجھتے اِلَّا ظَنًّا : مگر ایک گمان وَّمَا نَحْنُ : اور نہیں ہیں ہم بِمُسْتَيْقِنِيْنَ : یقین کرنے والے اور جب کبھی کہا جاتا ہے کہ اللہ کا وعدہ یقیناً سچا ہے اور قیامت کے آنے میں کوئی شک نہیں تو تم جواب دیتے تھے کہ ہم نہیں جانتے قیامت کیا چیز ہے ؟ ہمیں کچھ یوں ہی سا خیال ہوجاتا ہے لیکن ہمیں یقین نہیں (1)
45,33,وَ بَدَا لَهُمْ سَیِّاٰتُ مَا عَمِلُوْا وَ حَاقَ بِهِمْ مَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ وَبَدَا لَهُمْ : اور ظاہر ہوجائیں گی ان کے لیے سَيِّاٰتُ : برائیاں مَا عَمِلُوْا : جو انہوں نے عمل کیے وَحَاقَ بِهِمْ : اور گھیر لے گا ان کو مَّا : وہ جو كَانُوْا : تھے وہ بِهٖ يَسْتَهْزِءُوْنَ : ساتھ اس کے مذاق اڑاتے اور ان پر اپنے اعمال کی برائیاں کھل گئیں اور جس کا وہ مذاق اڑا رہے تھے اس نے انہیں گھیر لیا۔
45,34,وَ قِیْلَ الْیَوْمَ نَنْسٰىكُمْ كَمَا نَسِیْتُمْ لِقَآءَ یَوْمِكُمْ هٰذَا وَ مَاْوٰىكُمُ النَّارُ وَ مَا لَكُمْ مِّنْ نّٰصِرِیْنَ وَقِيْلَ : اور کہہ دیاجائے گا الْيَوْمَ : آج نَنْسٰىكُمْ : ہم بھلائے دیتے ہیں تم کو كَمَا نَسِيْتُمْ : جیسا کہ تم بھول گئے لِقَآءَ : ملاقات کو يَوْمِكُمْ ھٰذَا : تمہارے اس دن کی وَمَاْوٰىكُمُ النَّارُ : اور ٹھکانہ تمہارا آگ ہے وَمَا لَكُمْ : اور نہیں تمہارے لیے مِّنْ نّٰصِرِيْنَ : مددگاروں میں سے اور کہہ دیا گیا کہ آج ہم تمہیں بھلا دیں گے جیسے کہ تم نے اپنے اس دن سے ملنے کو (1) بھلا دیا تھا تمہارا ٹھکانا جہنم ہے اور تمہارا مددگار کوئی نہیں۔
45,35,ذٰلِكُمْ بِاَنَّكُمُ اتَّخَذْتُمْ اٰیٰتِ اللّٰهِ هُزُوًا وَّ غَرَّتْكُمُ الْحَیٰوةُ الدُّنْیَا١ۚ فَالْیَوْمَ لَا یُخْرَجُوْنَ مِنْهَا وَ لَا هُمْ یُسْتَعْتَبُوْنَ ذٰلِكُمْ : یہ بات بِاَنَّكُمُ : بوجہ اس کے کہ یقینا تم اتَّخَذْتُمْ : بنا لیا تم نے اٰيٰتِ اللّٰهِ : اللہ کی آیات کو هُزُوًا : مذاق وَّغَرَّتْكُمُ : اور دھوکے میں ڈالا تم کو الْحَيٰوةُ الدُّنْيَا : دنیا کی زندگی نے فَالْيَوْمَ : تو آج لَا يُخْرَجُوْنَ مِنْهَا : نہ وہ نکالے جائیں گے اس سے وَلَا هُمْ : اور نہ وہ يُسْتَعْتَبُوْنَ : عذر قبول کیے جائیں گے یہ اس لئے ہے کہ تم نے اللہ تعالیٰ کی آیتوں کی ہنسی اڑائی تھی اور دنیا کی زندگی نے تمہیں دھوکے میں ڈال رکھا تھا، پس آج کے دن نہ تو یہ (دوزخ) سے نکالے جائیں گے اور نہ ان سے عذر و معذرت قبول کیا جائے گا۔
45,36,فَلِلّٰهِ الْحَمْدُ رَبِّ السَّمٰوٰتِ وَ رَبِّ الْاَرْضِ رَبِّ الْعٰلَمِیْنَ فَلِلّٰهِ الْحَمْدُ : پس اللہ ہی کے لیے حمد رَبِّ السَّمٰوٰتِ : جو آسمانوں کا رب ہے وَرَبِّ الْاَرْضِ : اور زمین کا رب ہے رَبِّ : رب ہے الْعٰلَمِيْنَ : تمام جہانوں کا پس اللہ کی تعریف ہے جو آسمانوں اور زمین اور تمام جہان کا پالنہار ہے۔
45,37,وَ لَهُ الْكِبْرِیَآءُ فِی السَّمٰوٰتِ وَ الْاَرْضِ١۪ وَ هُوَ الْعَزِیْزُ الْحَكِیْمُ۠    ۧ وَلَهُ الْكِبْرِيَآءُ : اور اسی کے لیے ہے بڑائی فِي السَّمٰوٰتِ : آسمانوں میں وَالْاَرْضِ : اور زمین میں وَهُوَ الْعَزِيْزُ الْحَكِيْمُ : اور وہ غالب ہے، حکمت والا ہے تمام (بزرگی اور) بڑائی آسمانوں اور زمین میں اسی کی (1) ہے اور وہی غالب اور حکمت والا ہے۔
