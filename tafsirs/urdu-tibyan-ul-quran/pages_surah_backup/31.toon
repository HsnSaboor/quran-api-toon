quran[34]{c,v,t}:
31,1,الٓمّٓۚ الف۔ لام ۔ میم الم 1
31,2,تِلْكَ اٰیٰتُ الْكِتٰبِ الْحَكِیْمِۙ تِلْكَ : یہ اٰيٰتُ : آیتیں الْكِتٰبِ الْحَكِيْمِ : پر حکمت کتاب یہ حکمت والی کتاب کی آیتیں ہیں۔
31,3,هُدًى وَّ رَحْمَةً لِّلْمُحْسِنِیْنَۙ هُدًى : ہدایت وَّرَحْمَةً : اور رحمت لِّلْمُحْسِنِيْنَ : نیکوکاروں کے لیے جو نیکوکاروں کے 1 لئے رہبر اور (سراسر) رحمت ہے۔
31,4,الَّذِیْنَ یُقِیْمُوْنَ الصَّلٰوةَ وَ یُؤْتُوْنَ الزَّكٰوةَ وَ هُمْ بِالْاٰخِرَةِ هُمْ یُوْقِنُوْنَؕ الَّذِيْنَ : جو لوگ يُقِيْمُوْنَ : قائم کرتے ہیں الصَّلٰوةَ : نماز وَيُؤْتُوْنَ : اور ادا کرتے ہیں الزَّكٰوةَ : زکوۃ وَهُمْ : اور وہ بِالْاٰخِرَةِ : آخرت پر هُمْ يُوْقِنُوْنَ : وہ یقین رکھتے ہیں جو لوگ نماز قائم کرتے ہیں اور زکوٰۃ ادا کرتے ہیں اور آخرت پر (کامل) یقین رکھتے ہیں 1۔
31,5,اُولٰٓئِكَ عَلٰى هُدًى مِّنْ رَّبِّهِمْ وَ اُولٰٓئِكَ هُمُ الْمُفْلِحُوْنَ اُولٰٓئِكَ : یہی لوگ عَلٰي : پر هُدًى : ہدایت مِّنْ رَّبِّهِمْ : اپنے رب سے وَاُولٰٓئِكَ : اور یہی لوگ هُمُ : وہ الْمُفْلِحُوْنَ : فلاحپانے والے یہی لوگ ہیں جو اپنے رب کی طرف سے ہدایت پر ہیں اور یہی لوگ نجات پانے والے ہیں 1۔
31,6,وَ مِنَ النَّاسِ مَنْ یَّشْتَرِیْ لَهْوَ الْحَدِیْثِ لِیُضِلَّ عَنْ سَبِیْلِ اللّٰهِ بِغَیْرِ عِلْمٍ١ۖۗ وَّ یَتَّخِذَهَا هُزُوًا١ؕ اُولٰٓئِكَ لَهُمْ عَذَابٌ مُّهِیْنٌ وَمِنَ : اور سے النَّاسِ : لوگ مَنْ : جو يَّشْتَرِيْ : خریدتا ہے لَهْوَ الْحَدِيْثِ : کھیل کی (بیہودہ) باتیں لِيُضِلَّ : تاکہ وہ گمراہ کرے عَنْ : سے سَبِيْلِ اللّٰهِ : اللہ کا راستہ بِغَيْرِ عِلْمٍ ڰ : بےسمجھے وَّيَتَّخِذَهَا : اور وہ اسے ٹھہراتے ہیں هُزُوًا ۭ : ہنسی مذاق اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے عَذَابٌ مُّهِيْنٌ : ذلت والا عذاب اور بعض لوگ ایسے بھی ہیں جو لغو باتوں کو مول لیتے ہیں 1 کہ بےعلمی کے ساتھ لوگوں کو اللہ کی راہ سے بہکائیں اور اسے ہنسی بنائیں 2 یہی وہ لوگ ہیں جن کے لئے رسوا کرنے والا عذاب ہے 3۔
31,7,وَ اِذَا تُتْلٰى عَلَیْهِ اٰیٰتُنَا وَلّٰى مُسْتَكْبِرًا كَاَنْ لَّمْ یَسْمَعْهَا كَاَنَّ فِیْۤ اُذُنَیْهِ وَقْرًا١ۚ فَبَشِّرْهُ بِعَذَابٍ اَلِیْمٍ وَاِذَا : اور جب تُتْلٰى عَلَيْهِ : پڑھی جاتی ہیں اس پر اٰيٰتُنَا : ہماری آیتیں وَلّٰى : وہ منہ موڑ لیتا ہے مُسْتَكْبِرًا : تکبر کرتے ہوئے كَاَنْ : گویا لَّمْ يَسْمَعْهَا : اس نے اسے سنا نہیں كَاَنَّ : گویا فِيْٓ اُذُنَيْهِ : اس کے کانوں میں وَقْرًا ۚ : گرانی فَبَشِّرْهُ : پس اسے خوشخبری دو بِعَذَابٍ : عذاب کی اَلِيْمٍ : دردناک جب اس کے سامنے ہماری آیتیں تلاوت کی جاتی ہیں تو تکبر کرتا ہوا اس طرح منہ پھیر لیتا ہے گویا اس نے سنا ہی نہیں گویا کہ اس کے دونوں کانوں میں ڈاٹ لگے ہوئے ہیں 1 آپ اسے دردناک عذاب کی خبر سنا دیجئے۔
31,8,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ لَهُمْ جَنّٰتُ النَّعِیْمِۙ اِنَّ الَّذِيْنَ : بیشک جو لوگ اٰمَنُوْا : ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : اچھے لَهُمْ : ان کے لیے جَنّٰتُ النَّعِيْمِ : نعمتوں کے باغات بیشک جن لوگوں نے ایمان قبول کیا اور کام بھی نیک کئے ان کے لئے نعمتوں والی جنتیں ہیں۔
31,9,خٰلِدِیْنَ فِیْهَا١ؕ وَعْدَ اللّٰهِ حَقًّا١ؕ وَ هُوَ الْعَزِیْزُ الْحَكِیْمُ خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَا ۭ : اس میں وَعْدَ اللّٰهِ : اللہ کا وعدہ حَقًّا ۭ : سچا وَهُوَ : اور وہ الْعَزِيْزُ : غالب الْحَكِيْمُ : حکمت والا جہاں وہ ہمیشہ رہیں گے۔ اللہ کا سچا وعدہ ہے، 1 وہ بہت بڑی عزت و غلبہ والا اور کامل حکمت والا ہے۔
31,10,خَلَقَ السَّمٰوٰتِ بِغَیْرِ عَمَدٍ تَرَوْنَهَا وَ اَلْقٰى فِی الْاَرْضِ رَوَاسِیَ اَنْ تَمِیْدَ بِكُمْ وَ بَثَّ فِیْهَا مِنْ كُلِّ دَآبَّةٍ١ؕ وَ اَنْزَلْنَا مِنَ السَّمَآءِ مَآءً فَاَنْۢبَتْنَا فِیْهَا مِنْ كُلِّ زَوْجٍ كَرِیْمٍ خَلَقَ : اس نے پیدا کیا السَّمٰوٰتِ : آسمان (جمع) بِغَيْرِ عَمَدٍ : بغیر ستون تَرَوْنَهَا : تم انہیں دیکھتے ہو وَاَلْقٰى : اور اس نے ڈالے فِي الْاَرْضِ : زمین میں رَوَاسِيَ : پہاڑ (جمع) اَنْ : کہ تَمِيْدَ بِكُمْ : جھک (نہ) جائے تمہارے ساتھ وَبَثَّ : اور پھیلائے فِيْهَا : اس میں مِنْ كُلِّ : ہر قسم دَآبَّةٍ ۭ : جانور وَاَنْزَلْنَا : اور ہم نے اتارا مِنَ السَّمَآءِ : آسمان سے مَآءً : پانی فَاَنْۢبَتْنَا : پھر ہم نے اگائے فِيْهَا : اس میں مِنْ كُلِّ : ہر قسم زَوْجٍ : جوڑے كَرِيْمٍ : عمدہ اسی نے آسمانوں کو بغیر ستون کے پیدا کیا ہے تم انھیں دیکھ رہے 1 ہو اور اس نے زمین میں پہاڑوں کو ڈال دیا تاکہ وہ تمہیں جنبش نہ دے سکے 2 اور ہر طرح کے جاندار زمین میں پھیلا دیئے 3 اور ہم نے آسمان سے پانی برسا کر زمین میں ہر قسم کے نفیس جوڑے اگا دیئے۔ 4
31,11,هٰذَا خَلْقُ اللّٰهِ فَاَرُوْنِیْ مَا ذَا خَلَقَ الَّذِیْنَ مِنْ دُوْنِهٖ١ؕ بَلِ الظّٰلِمُوْنَ فِیْ ضَلٰلٍ مُّبِیْنٍ۠    ۧ ھٰذَا : یہ خَلْقُ اللّٰهِ : خلقت (بنایا ہوا) اللہ کا فَاَرُوْنِيْ : پس تم مجھے دکھاؤ مَاذَا : کیا خَلَقَ : پیدا کیا الَّذِيْنَ : وہ جو مِنْ دُوْنِهٖ ۭ : اس کے سوا بَلِ : بلکہ الظّٰلِمُوْنَ : ظالم (جمع) فِيْ : میں ضَلٰلٍ مُّبِيْنٍ : کھلی گمراہی یہ ہے اللہ کی مخلوق 1 اب تم مجھے اس کے سوا دوسرے کسی کی کوئی مخلوق تو دکھاؤ (کچھ نہیں) بلکہ یہ ظالم کھلی گمراہی میں ہیں۔
31,12,وَ لَقَدْ اٰتَیْنَا لُقْمٰنَ الْحِكْمَةَ اَنِ اشْكُرْ لِلّٰهِ١ؕ وَ مَنْ یَّشْكُرْ فَاِنَّمَا یَشْكُرُ لِنَفْسِهٖ١ۚ وَ مَنْ كَفَرَ فَاِنَّ اللّٰهَ غَنِیٌّ حَمِیْدٌ وَلَقَدْ اٰتَيْنَا : اور البتہ ہم نے دی لُقْمٰنَ : لقمان الْحِكْمَةَ : حکمت اَنِ : کہ اشْكُرْ : تم شکر کرو لِلّٰهِ ۭ : اللہ کا وَمَنْ : اور جو يَّشْكُرْ : شکر کرتا ہے فَاِنَّمَا : تو اس کے سوا نہیں (صرف) يَشْكُرُ : وہ شکر کرتا ہے لِنَفْسِهٖ ۚ : اپنے لیے وَمَنْ كَفَرَ : اور جس نے ناشکری کی فَاِنَّ اللّٰهَ : تو بیشک اللہ غَنِيٌّ : بےنیاز حَمِيْدٌ : تعریفوں کے ساتھ اور ہم نے یقیناً لقمان کو حکمت دی 1 تھی کہ تو اللہ تعالیٰ کا شکر کر 2 ہر شکر کرنے والا اپنے ہی نفع کے لئے شکر کرتا ہے جو بھی ناشکری کرے وہ جان لے کہ اللہ تعالیٰ بےنیاز اور تعریفوں والا ہے۔
31,13,وَ اِذْ قَالَ لُقْمٰنُ لِابْنِهٖ وَ هُوَ یَعِظُهٗ یٰبُنَیَّ لَا تُشْرِكْ بِاللّٰهِ١ؔؕ اِنَّ الشِّرْكَ لَظُلْمٌ عَظِیْمٌ وَاِذْ : اور جب قَالَ : کہا لُقْمٰنُ : لقمان لِابْنِهٖ : اپنے بیٹے کو وَهُوَ : اور وہ يَعِظُهٗ : اسے نصیحت کر رہا تھا يٰبُنَيَّ : اے میرے بیٹے لَا تُشْرِكْ : تو نہ شریک ٹھہرا بِاللّٰهِ : اللہ کے ساتھ اِنَّ الشِّرْكَ : بیشک شرک لَظُلْمٌ عَظِيْمٌ : البتہ ظلم عظیم اور جب کہ لقمان نے وعظ کہتے ہوئے اپنے لڑکے سے فرمایا کہ میرے پیارے بچے ! اللہ کے ساتھ شریک نہ کرنا 1 بیشک شرک بڑا بھاری ظلم ہے۔ 2
31,14,وَ وَصَّیْنَا الْاِنْسَانَ بِوَالِدَیْهِ١ۚ حَمَلَتْهُ اُمُّهٗ وَهْنًا عَلٰى وَهْنٍ وَّ فِصٰلُهٗ فِیْ عَامَیْنِ اَنِ اشْكُرْ لِیْ وَ لِوَالِدَیْكَ١ؕ اِلَیَّ الْمَصِیْرُ وَوَصَّيْنَا : اور ہم نے تاکید کردی الْاِنْسَانَ : انسان بِوَالِدَيْهِ ۚ : اس کے ماں باپ کے بارہ میں حَمَلَتْهُ : اسے پیٹ میں رکھا اُمُّهٗ : اس کی ماں وَهْنًا : کمزوری عَلٰي وَهْنٍ : پر کمزوری وَّفِصٰلُهٗ : اور اس کا دودھ چھڑانا فِيْ عَامَيْنِ : دو سال میں اَنِ اشْكُرْ لِيْ : کہ تو میرا شکر کر وَلِوَالِدَيْكَ ۭ : اور اپنے ماں باپ کا اِلَيَّ : میری طرف الْمَصِيْرُ : لوٹ کر آنا ہم نے انسان کو اس کے ماں باپ کے متعلق نصیحت کی 1 ہے، اس کی ماں نے دکھ پر دکھ اٹھا کر 2 اسے حمل میں رکھا اور اس کی دودھ چھڑائی دو برس میں ہے 3 کہ تو میری اور اپنے ماں باپ کی شکر گزاری کر، (تم سب کو) میری ہی طرف لوٹ کر آنا ہے۔
31,15,وَ اِنْ جَاهَدٰكَ عَلٰۤى اَنْ تُشْرِكَ بِیْ مَا لَیْسَ لَكَ بِهٖ عِلْمٌ١ۙ فَلَا تُطِعْهُمَا وَ صَاحِبْهُمَا فِی الدُّنْیَا مَعْرُوْفًا١٘ وَّ اتَّبِعْ سَبِیْلَ مَنْ اَنَابَ اِلَیَّ١ۚ ثُمَّ اِلَیَّ مَرْجِعُكُمْ فَاُنَبِّئُكُمْ بِمَا كُنْتُمْ تَعْمَلُوْنَ وَاِنْ : اور اگر جَاهَدٰكَ : وہ تیرے ساتھ کوشش کریں عَلٰٓي : پر (کی) اَنْ تُشْرِكَ : کہ تو شیرک ٹھہرائے بِيْ : میرا مَا لَيْسَ : جس کا نہیں لَكَ : تجھے بِهٖ : اس کا عِلْمٌ ۙ : کوئی علم فَلَا تُطِعْهُمَا : تو ان دونوں کا کہا نہ مان وَصَاحِبْهُمَا : اور ان کے ساتھ بسر کر فِي الدُّنْيَا : دنیا میں مَعْرُوْفًا ۡ : اچھے طریقے سے وَّاتَّبِعْ : اور تو پیروی کر سَبِيْلَ : راستہ مَنْ : جو اَنَابَ : رجوع کرے اِلَيَّ ۚ : میری طرف ثُمَّ : پھر اِلَيَّ : میری طرف مَرْجِعُكُمْ : تمہیں لوٹ کر آنا ہے فَاُنَبِّئُكُمْ : سو میں تمہیں آگاہ کروں گا بِمَا : جو کچھ كُنْتُمْ تَعْمَلُوْنَ : تم کرتے تھے اور اگر وہ دونوں تجھ پر اس بات کا دباؤ ڈالیں کہ تو میرے ساتھ شریک کرے جس کا تجھے علم نہ ہو تو تو ان کا کہنا نہ ماننا، ہاں دنیا میں ان کے ساتھ اچھی طرح بسر کرنا اور اس کی راہ چلنا جو میری طرف جھکا ہو 1 تمہارا سب کا لوٹنا میری ہی طرف ہے تم جو کچھ کرتے ہو اس سے پھر میں تمہیں خبردار کردوں گا۔
31,16,یٰبُنَیَّ اِنَّهَاۤ اِنْ تَكُ مِثْقَالَ حَبَّةٍ مِّنْ خَرْدَلٍ فَتَكُنْ فِیْ صَخْرَةٍ اَوْ فِی السَّمٰوٰتِ اَوْ فِی الْاَرْضِ یَاْتِ بِهَا اللّٰهُ١ؕ اِنَّ اللّٰهَ لَطِیْفٌ خَبِیْرٌ يٰبُنَيَّ : اے میرے بیٹے اِنَّهَآ : بیشک وہ اِنْ تَكُ : اگر ہو مِثْقَالَ حَبَّةٍ : وزن (برابر) دانہ مِّنْ : سے (کے) خَرْدَلٍ : رائی فَتَكُنْ : پھر وہ ہو فِيْ : میں صَخْرَةٍ : سخت پتھر اَوْ : یا فِي السَّمٰوٰتِ : آسمانوں میں اَوْ : یا فِي الْاَرْضِ : زمین میں يَاْتِ بِهَا : لے آئے گا اسے اللّٰهُ ۭ : اللہ اِنَّ اللّٰهَ : بیشک اللہ لَطِيْفٌ : باریک بین خَبِيْرٌ : خبردار پیارے بیٹے ! اگر کوئی چیز رائی کے دانے کے برابر ہو 1 پھر وہ (بھی) خواہ کسی چٹان میں ہو یا آسمانوں میں ہو یا زمین میں ہو اسے اللہ تعالیٰ ضرور لائے گا اللہ تعالیٰ بڑا باریک بین اور خبردار ہے۔
31,17,یٰبُنَیَّ اَقِمِ الصَّلٰوةَ وَ اْمُرْ بِالْمَعْرُوْفِ وَ انْهَ عَنِ الْمُنْكَرِ وَ اصْبِرْ عَلٰى مَاۤ اَصَابَكَ١ؕ اِنَّ ذٰلِكَ مِنْ عَزْمِ الْاُمُوْرِۚ يٰبُنَيَّ : اے میرے بیٹے اَقِمِ الصَّلٰوةَ : قائم کر نماز وَاْمُرْ : اور حکم دے بِالْمَعْرُوْفِ : اچھے کام وَانْهَ : اور روک تو عَنِ : سے الْمُنْكَرِ : بری بات وَاصْبِرْ : اور صبر کر عَلٰي : پر مَآ اَصَابَكَ ۭ : جو تجھ پر پہنچے اِنَّ ذٰلِكَ : بیشک یہ مِنْ : سے عَزْمِ الْاُمُوْرِ : بڑی ہمت کے کام اے میرے پیارے بیٹے ! تو نماز قائم رکھنا اچھے کاموں کی نصیحت کرتے رہنا، برے کاموں سے منع کیا کرنا اور جو مصیبت تم پر آئے صبر کرنا 1 (یقین مان) کہ یہ بڑے تاکیدی کاموں میں سے ہے 2
31,18,وَ لَا تُصَعِّرْ خَدَّكَ لِلنَّاسِ وَ لَا تَمْشِ فِی الْاَرْضِ مَرَحًا١ؕ اِنَّ اللّٰهَ لَا یُحِبُّ كُلَّ مُخْتَالٍ فَخُوْرٍۚ وَلَا تُصَعِّرْ : اور توٹیڑھا نہ کر خَدَّكَ : اپنا رخسار لِلنَّاسِ : لوگوں سے وَلَا تَمْشِ : اور نہ چل تو فِي الْاَرْضِ : زمین میں مَرَحًا ۭ : اتراتا اِنَّ اللّٰهَ : بیشک اللہ لَا يُحِبُّ : پسند نہیں کرتا كُلَّ : ہر۔ کسی مُخْتَالٍ : اترانے والا فَخُوْرٍ : خود پسند لوگوں کے سامنے اپنے گال نہ پھلا 1 اور زمین پر اکڑ کر نہ چل 2 کسی تکبر کرنے والے شیخی خورے کو اللہ پسند نہیں فرماتا۔
31,19,وَ اقْصِدْ فِیْ مَشْیِكَ وَ اغْضُضْ مِنْ صَوْتِكَ١ؕ اِنَّ اَنْكَرَ الْاَصْوَاتِ لَصَوْتُ الْحَمِیْرِ۠    ۧ وَاقْصِدْ : اور میانہ روی کر فِيْ مَشْيِكَ : اپنی رفتار میں وَاغْضُضْ : اور پست کر مِنْ صَوْتِكَ ۭ : اپنی آواز کو اِنَّ : بیشک اَنْكَرَ : سب سے ناپسندیدہ الْاَصْوَاتِ : آوازیں لَصَوْتُ : آواز الْحَمِيْرِ : گدھا اپنی رفتار میں میانہ روی اختیار کر 1 اور اپنی آواز پست کر 2 یقیناً آوازوں میں سب سے بدتر آواز گدھوں کی آواز ہے۔
31,20,اَلَمْ تَرَوْا اَنَّ اللّٰهَ سَخَّرَ لَكُمْ مَّا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ وَ اَسْبَغَ عَلَیْكُمْ نِعَمَهٗ ظَاهِرَةً وَّ بَاطِنَةً١ؕ وَ مِنَ النَّاسِ مَنْ یُّجَادِلُ فِی اللّٰهِ بِغَیْرِ عِلْمٍ وَّ لَا هُدًى وَّ لَا كِتٰبٍ مُّنِیْرٍ اَلَمْ تَرَوْا : کیا تم نے نہیں دیکھا اَنَّ اللّٰهَ : کہ اللہ سَخَّرَ : مسخر کیا لَكُمْ : تمہارے لیے مَّا : جو کچھ فِي السَّمٰوٰتِ : آسمانوں میں وَمَا : اور جو کچھ فِي الْاَرْضِ : زمین میں وَاَسْبَغَ : اور بھرپور دیں عَلَيْكُمْ : تم پر (تمہیں) نِعَمَهٗ : اپنی نعمتیں ظَاهِرَةً : ظاہر وَّبَاطِنَةً ۭ : اور پوشیدہ وَمِنَ : اور بعض النَّاسِ : لوگ مَنْ : جو يُّجَادِلُ : جھگڑتا ہے فِي اللّٰهِ : اللہ (کے بارہ) میں بِغَيْرِ : بغیر عِلْمٍ : علم وَّلَا هُدًى : اور بغیر ہدایت وَّلَا كِتٰبٍ مُّنِيْرٍ : اور بغیر کتاب روشن کیا تم نہیں دیکھتے کہ اللہ تعالیٰ نے زمین اور آسمان کی ہر چیز کو ہمارے کام میں لگا رکھا ہے 1 اور تمہیں اپنی ظاہری و باطنی نعمتیں بھرپور دے رکھی ہیں 2 بعض لوگ اللہ کے بارے میں بغیر علم کے بغیر ہدایت کے اور بغیر روشن کتاب کے جھگڑا کرتے ہیں 3۔
31,21,وَ اِذَا قِیْلَ لَهُمُ اتَّبِعُوْا مَاۤ اَنْزَلَ اللّٰهُ قَالُوْا بَلْ نَتَّبِعُ مَا وَجَدْنَا عَلَیْهِ اٰبَآءَنَا١ؕ اَوَ لَوْ كَانَ الشَّیْطٰنُ یَدْعُوْهُمْ اِلٰى عَذَابِ السَّعِیْرِ وَاِذَا : اور جب قِيْلَ : کہا جائے لَهُمُ : ان سے اتَّبِعُوْا : تم پیروی کرو مَآ اَنْزَلَ : جو نازل کیا اللّٰهُ : اللہ قَالُوْا : وہ کہتے ہیں بَلْ نَتَّبِعُ : بلکہ ہم پیروی کریں گے مَا وَجَدْنَا : جو ہم نے پایا عَلَيْهِ : اس پر اٰبَآءَنَا ۭ : اپنے باپ دادا اَوَلَوْ : کیا اگر كَانَ : ہو الشَّيْطٰنُ : شیطان يَدْعُوْهُمْ : ان کو بلاتا اِلٰى : طرف عَذَابِ : عذاب السَّعِيْرِ : دوزخ اور جب ان سے کہا جاتا ہے کہ اللہ کی اتاری ہوئی وحی کی تابعداری کرو تو کہتے ہیں کہ ہم نے تو جس طریق 1 پر اپنے باپ دادوں کو پایا ہے اسی کی تابعداری کریں گے، اگرچہ شیطان ان کے بڑوں کو دوزخ کے عذاب کی طرف بلاتا ہو۔
31,22,وَ مَنْ یُّسْلِمْ وَجْهَهٗۤ اِلَى اللّٰهِ وَ هُوَ مُحْسِنٌ فَقَدِ اسْتَمْسَكَ بِالْعُرْوَةِ الْوُثْقٰى١ؕ وَ اِلَى اللّٰهِ عَاقِبَةُ الْاُمُوْرِ وَمَنْ : اور جو يُّسْلِمْ : جھکا دے وَجْهَهٗٓ : اپنا چہرہ اِلَى اللّٰهِ : اللہ کی طرف وَهُوَ : اور وہ مُحْسِنٌ : نیکو کار فَقَدِ اسْتَمْسَكَ : تو بیشک اس نے تھاما بِالْعُرْوَةِ الْوُثْقٰى ۭ : حلقہ مضبوط وَاِلَى اللّٰهِ : اور اللہ کی طرف عَاقِبَةُ : انتہا الْاُمُوْرِ : تمام کام (جمع) اور جو (شخص) اپنے آپ کو اللہ کے تابع کر دے 1 اور ہو بھی نیکوکار 2 یقیناً اس نے مضبوط کڑا تھام لیا 3 تمام کاموں کا انجام اللہ کی طرف ہے۔
31,23,وَ مَنْ كَفَرَ فَلَا یَحْزُنْكَ كُفْرُهٗ١ؕ اِلَیْنَا مَرْجِعُهُمْ فَنُنَبِّئُهُمْ بِمَا عَمِلُوْا١ؕ اِنَّ اللّٰهَ عَلِیْمٌۢ بِذَاتِ الصُّدُوْرِ وَمَنْ كَفَرَ : اور جو کفر کرے فَلَا يَحْزُنْكَ : تو آپ غمگین نہ کردے كُفْرُهٗ ۭ : اس کا کفر اِلَيْنَا : ہماری طرف مَرْجِعُهُمْ : ان کا لوٹنا فَنُنَبِّئُهُمْ بِمَا : پھر ہم انہیں ضرور جتلائیں گے وہ جو عَمِلُوْا ۭ : وہ کرتے تھے اِنَّ اللّٰهَ : بیشک اللہ عَلِيْمٌۢ : جاننے والا بِذَاتِ الصُّدُوْرِ : سینوں (دلوں) کے بھید کافروں کے کفر سے آپ رنجیدہ نہ ہوں 1 آخر ان سب کا لوٹنا تو ہماری جانب ہی ہے پھر ہم ان کو بتائیں گے جو انہوں نے کیا، بیشک اللہ سینوں 2 کے بھید 3 تک سے واقف ہے۔
31,24,نُمَتِّعُهُمْ قَلِیْلًا ثُمَّ نَضْطَرُّهُمْ اِلٰى عَذَابٍ غَلِیْظٍ نُمَتِّعُهُمْ : ہم انہیں فائدہ دیں گے قَلِيْلًا : تھوڑا ثُمَّ نَضْطَرُّهُمْ : پھر ہم انہیں کھینچ لائیں گے اِلٰى : طرف عَذَابٍ : عذاب غَلِيْظٍ : سخت ہم انھیں گو کچھ یونہی فائدہ دے دیں لیکن (بالآخر) ہم انھیں نہایت بیچارگی کی حالت میں سخت عذاب کی طرف ہنکالے جائیں گے 1
31,25,وَ لَئِنْ سَاَلْتَهُمْ مَّنْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ لَیَقُوْلُنَّ اللّٰهُ١ؕ قُلِ الْحَمْدُ لِلّٰهِ١ؕ بَلْ اَكْثَرُهُمْ لَا یَعْلَمُوْنَ وَلَئِنْ : اور اگر سَاَلْتَهُمْ : تم ان سے پوچھو مَّنْ خَلَقَ : کس نے پیدا کیا السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین لَيَقُوْلُنَّ : تو وہ یقینا کہیں گے اللّٰهُ ۭ : اللہ قُلِ : فرمادیں الْحَمْدُ لِلّٰهِ ۭ : تمام تعریفیں اللہ کے لیے بَلْ اَكْثَرُهُمْ : بلکہ ان کے اکثر لَا يَعْلَمُوْنَ : جانتے نہیں اگر آپ ان سے دریافت کریں کہ آسمان و زمین کا خالق کون ہے ؟ تو ضرور جواب دیں گے کہ اللہ 1 تو کہہ دیجئے کہ سب تعریفوں کے لائق اللہ ہی ہے 2 لیکن ان میں اکثر بےعلم ہیں۔
31,26,لِلّٰهِ مَا فِی السَّمٰوٰتِ وَ الْاَرْضِ١ؕ اِنَّ اللّٰهَ هُوَ الْغَنِیُّ الْحَمِیْدُ لِلّٰهِ : اللہ کے لیے مَا : جو کچھ فِي السَّمٰوٰتِ : آسمانوں میں وَالْاَرْضِ ۭ : اور زمین اِنَّ اللّٰهَ : بیشک اللہ هُوَ : وہ الْغَنِيُّ : بےنیاز الْحَمِيْدُ : تعریفوں کے ساتھ آسمانوں میں اور زمین میں جو کچھ ہے وہ سب اللہ ہی کا ہے 1 یقیناً اللہ تعالیٰ بہت بڑا بےنیاز 2 اور سزاوار حمد ثنا ہے 3۔
31,27,وَ لَوْ اَنَّ مَا فِی الْاَرْضِ مِنْ شَجَرَةٍ اَقْلَامٌ وَّ الْبَحْرُ یَمُدُّهٗ مِنْۢ بَعْدِهٖ سَبْعَةُ اَبْحُرٍ مَّا نَفِدَتْ كَلِمٰتُ اللّٰهِ١ؕ اِنَّ اللّٰهَ عَزِیْزٌ حَكِیْمٌ وَلَوْ : اور اگر اَنَّ : یہ ہو کہ مَا : جو فِي الْاَرْضِ : زمین میں مِنْ : سے۔ کوئی شَجَرَةٍ : درخت اَقْلَامٌ : قلمیں وَّالْبَحْرُ : اور سمندر يَمُدُّهٗ : اس کی سیاہی مِنْۢ بَعْدِهٖ : اس کے بعد سَبْعَةُ : سات اَبْحُرٍ : سمندر (جمع) مَّا نَفِدَتْ : تو بھی ختم نہ ہوں كَلِمٰتُ اللّٰهِ ۭ : اللہ کی باتیں اِنَّ اللّٰهَ : بیشک اللہ عَزِيْزٌ : غالب حَكِيْمٌ : حکمت والا روئے زمین کے (تمام) درختوں کے اگر قلمیں ہوجائیں اور تمام سمندروں کی سیاہی ہو اور ان کے بعد سات سمندر اور ہوں تاہم اللہ کے کلمات ختم نہیں ہوسکتے 1 بیشک اللہ تعالیٰ غالب اور باحکمت ہے۔
31,28,مَا خَلْقُكُمْ وَ لَا بَعْثُكُمْ اِلَّا كَنَفْسٍ وَّاحِدَةٍ١ؕ اِنَّ اللّٰهَ سَمِیْعٌۢ بَصِیْرٌ مَا خَلْقُكُمْ : نہیں تم سب کا پیدا کرنا وَلَا بَعْثُكُمْ : اور نہیں تمہارا جی اٹھنا اِلَّا : مگر كَنَفْسٍ وَّاحِدَةٍ ۭ : جیسے ایک شخص اِنَّ اللّٰهَ : بیشک اللہ سَمِيْعٌۢ : سننے والا بَصِيْرٌ : دیکھنے والا تم سب کی پیدائش اور مرنے کے بعد زندہ کرنا ایسا ہی ہے جیسے ایک جی کا، 1 بیشک اللہ تعالیٰ سننے والا دیکھنے والا ہے۔
31,29,اَلَمْ تَرَ اَنَّ اللّٰهَ یُوْلِجُ الَّیْلَ فِی النَّهَارِ وَ یُوْلِجُ النَّهَارَ فِی الَّیْلِ وَ سَخَّرَ الشَّمْسَ وَ الْقَمَرَ١٘ كُلٌّ یَّجْرِیْۤ اِلٰۤى اَجَلٍ مُّسَمًّى وَّ اَنَّ اللّٰهَ بِمَا تَعْمَلُوْنَ خَبِیْرٌ اَلَمْ تَرَ : کیا تو نے نہیں دیکھا اَنَّ اللّٰهَ : کہ اللہ يُوْ لِجُ : داخل کرتا ہے الَّيْلَ : رات فِي النَّهَارِ : دن میں وَيُوْ لِجُ : اور داخل کرتا ہے النَّهَارَ : دن فِي الَّيْلِ : رات میں وَسَخَّرَ : اور اس نے مسخر کیا الشَّمْسَ : سورج وَالْقَمَرَ ۡ : اور چاند كُلٌّ : ہر ایک يَّجْرِيْٓ : چلتا رہے گا اِلٰٓى : طرف اَجَلٍ : مدت مُّسَمًّى : مقررہ وَّاَنَّ : اور یہ کہ اللّٰهَ : اللہ بِمَا تَعْمَلُوْنَ : اس سے جو کچھ تم کرتے ہو خَبِيْرٌ : خبردار کیا آپ نے نہیں دیکھا کہ اللہ تعالیٰ رات کو دن میں اور دن کو رات میں کھپا دیتا ہے 1 سورج چاند کو اسی نے فرماں بردار کر رکھا ہے کہ ہر ایک مقررہ وقت تک چلتا رہے 2 اللہ تعالیٰ ہر اس چیز سے جو تم کرتے ہو خبردار ہے۔
31,30,ذٰلِكَ بِاَنَّ اللّٰهَ هُوَ الْحَقُّ وَ اَنَّ مَا یَدْعُوْنَ مِنْ دُوْنِهِ الْبَاطِلُ١ۙ وَ اَنَّ اللّٰهَ هُوَ الْعَلِیُّ الْكَبِیْرُ۠    ۧ ذٰلِكَ : یہ بِاَنَّ اللّٰهَ : اس لیے کہ اللہ هُوَ الْحَقُّ : وہی برحق وَاَنَّ : اور یہ کہ مَا : جو جس يَدْعُوْنَ : وہ پرستش کرتے ہیں مِنْ دُوْنِهِ : اس کے سوا الْبَاطِلُ ۙ : باطل وَاَنَّ : اور یہ کہ اللّٰهَ : اللہ هُوَ : وہی الْعَلِيُّ : بلند مرتبہ الْكَبِيْرُ : بڑائی والا یہ سب (انتظامات) اس وجہ سے ہیں کہ اللہ تعالیٰ حق ہے اور اس کے سوا جن جن کو لوگ پکارتے ہیں سب باطل ہیں 1 اور یقیناً اللہ تعالیٰ بہت بلندیوں والا اور بڑی شان والا ہے 2
31,31,اَلَمْ تَرَ اَنَّ الْفُلْكَ تَجْرِیْ فِی الْبَحْرِ بِنِعْمَتِ اللّٰهِ لِیُرِیَكُمْ مِّنْ اٰیٰتِهٖ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّكُلِّ صَبَّارٍ شَكُوْرٍ اَلَمْ تَرَ : کیا تو نے نہیں دیکھا اَنَّ : کہ الْفُلْكَ : کشتی تَجْرِيْ : چلتی ہے فِي الْبَحْرِ : دریا میں بِنِعْمَتِ اللّٰهِ : اللہ کی نعمتوں کے ساتھ لِيُرِيَكُمْ : تاکہ وہ تمہیں دکھا دے مِّنْ اٰيٰتِهِ ۭ : اس کی نشانیاں اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ : البتہ نشانیاں لِّكُلِّ : واسطے ہر صَبَّارٍ : بڑے صبر والے شَكُوْرٍ : بڑے شکر گزار کیا تم اس پر غور نہیں کرتے کہ دریا میں کشتیاں اللہ کے فضل سے چل رہی ہیں اس لئے کہ وہ تمہیں اپنی نشانیاں دکھا دے، 1 یقیناً اس میں ہر ایک صبر و شکر کرنے والے 2 کے لئے بہت سی نشانیاں ہیں۔
31,32,وَ اِذَا غَشِیَهُمْ مَّوْجٌ كَالظُّلَلِ دَعَوُا اللّٰهَ مُخْلِصِیْنَ لَهُ الدِّیْنَ١ۚ۬ فَلَمَّا نَجّٰىهُمْ اِلَى الْبَرِّ فَمِنْهُمْ مُّقْتَصِدٌ١ؕ وَ مَا یَجْحَدُ بِاٰیٰتِنَاۤ اِلَّا كُلُّ خَتَّارٍ كَفُوْرٍ وَاِذَا : اور جب غَشِيَهُمْ : ان پر چھا جاتی ہے مَّوْجٌ : موج كَالظُّلَلِ : سائبانوں کی طرح دَعَوُا اللّٰهَ : وہ اللہ کو پکارتے ہیں مُخْلِصِيْنَ : خالص کر کے لَهُ الدِّيْنَ ڬ : اس کے لیے دین (عبادت) فَلَمَّا : پھر جب نَجّٰىهُمْ : اس نے انہیں بچا لیا اِلَى الْبَرِّ : خشکی کی طرف فَمِنْهُمْ : تو ان میں کوئی مُّقْتَصِدٌ ۭ : میانہ رو وَمَا يَجْحَدُ : اور انکار نہیں کرتا بِاٰيٰتِنَآ : ہماری آیتوں کا اِلَّا : سوائے كُلُّ : ہر خَتَّارٍ : عہد شکن كَفُوْرٍ : ناشکرا اور جب سمندر پر موجیں سائبانوں کی طرح چھا جاتی ہیں تو وہ (نہایت) خلوص کے ساتھ اعتقاد کر کے اللہ تعالیٰ ہی کو پکارتے ہیں 1 پھر جب وہ (باری تعالیٰ) انھیں نجات دے کر خشکی کی طرف پہنچاتا ہے تو کچھ ان میں سے اعتدال پر رہتے ہیں 2 اور ہماری آیتوں کا انکار صرف وہی کرتے ہیں جو بدعہد اور ناشکرے ہوں۔ 3
31,33,یٰۤاَیُّهَا النَّاسُ اتَّقُوْا رَبَّكُمْ وَ اخْشَوْا یَوْمًا لَّا یَجْزِیْ وَالِدٌ عَنْ وَّلَدِهٖ١٘ وَ لَا مَوْلُوْدٌ هُوَ جَازٍ عَنْ وَّالِدِهٖ شَیْئًا١ؕ اِنَّ وَعْدَ اللّٰهِ حَقٌّ فَلَا تَغُرَّنَّكُمُ الْحَیٰوةُ الدُّنْیَا١ٙ وَ لَا یَغُرَّنَّكُمْ بِاللّٰهِ الْغَرُوْرُ يٰٓاَيُّهَا : اے النَّاسُ : لوگو اتَّقُوْا : تم ڈرو رَبَّكُمْ : اپنا پروردگار وَاخْشَوْا : اور خوف کرو يَوْمًا : وہ دن لَّا يَجْزِيْ : نہ کام آئے گا وَالِدٌ : کوئی باپ عَنْ : سے۔ کے وَّلَدِهٖ ۡ : اپنے بیٹے وَلَا مَوْلُوْدٌ : اور نہ کوئی بیٹا هُوَ : وہ جَازٍ : کام آئے گا عَنْ وَّالِدِهٖ : سے ۔ کے باپ شَيْئًا ۭ : کچھ اِنَّ : بیشک وَعْدَ اللّٰهِ : اللہ کا وعدہ حَقٌّ : سچا فَلَا تَغُرَّنَّكُمُ : سو تمہیں ہرگز دھوکے میں نہ ڈالے الْحَيٰوةُ الدُّنْيَا ۪ : دنیا کی زندگی وَلَا يَغُرَّنَّكُمْ : اور تمہیں ہرگز دھوکے نہ دے بِاللّٰهِ : اللہ سے الْغَرُوْرُ : دھوکہ دینے والا لوگو اپنے رب سے ڈرو اور اس دن کا خوف کرو جس دن باپ اپنے بیٹے کو کوئی نفع نہ پہنچا سکے گا اور نہ بیٹا اپنے باپ کا ذرا سا بھی نفع کرنے والا ہوگا 1 (یاد رکھو) اللہ کا وعدہ سچا ہے (دیکھو) تمہیں دنیا کی زندگی دھوکے میں نہ ڈالے اور نہ دھوکے باز (شیطان) تمہیں دھوکے میں ڈال دے۔
31,34,اِنَّ اللّٰهَ عِنْدَهٗ عِلْمُ السَّاعَةِ١ۚ وَ یُنَزِّلُ الْغَیْثَ١ۚ وَ یَعْلَمُ مَا فِی الْاَرْحَامِ١ؕ وَ مَا تَدْرِیْ نَفْسٌ مَّا ذَا تَكْسِبُ غَدًا١ؕ وَ مَا تَدْرِیْ نَفْسٌۢ بِاَیِّ اَرْضٍ تَمُوْتُ١ؕ اِنَّ اللّٰهَ عَلِیْمٌ خَبِیْرٌ۠    ۧ اِنَّ اللّٰهَ : بیشک اللہ عِنْدَهٗ : اس کے پاس عِلْمُ السَّاعَةِ ۚ : قیامت کا علم وَيُنَزِّلُ : اور وہ نازل کرتا ہے الْغَيْثَ ۚ : بارش وَيَعْلَمُ : اور وہ جانتا ہے مَا : جو فِي الْاَرْحَامِ ۭ : (حاملہ کے) رحم میں وَمَا : اور نہیں تَدْرِيْ : جانتا نَفْسٌ : کوئی شخص مَّاذَا : کیا تَكْسِبُ : وہ کرے گا غَدًا ۭ : کل وَمَا تَدْرِيْ : اور نہیں جانتا نَفْسٌۢ : کوئی شخص بِاَيِّ : کس اَرْضٍ : زمین تَمُوْتُ ۭ : وہ مرے گا اِنَّ اللّٰهَ : بیشک اللہ عَلِيْمٌ : علم والا خَبِيْرٌ : خبردار بیشک اللہ تعالیٰ ہی کے پاس قیامت کا علم ہے وہی بارش نازل فرماتا ہے اور ماں کے پیٹ میں جو ہے اسے جانتا ہے کوئی (بھی) نہیں جانتا کہ کل کیا (کچھ) کرے گا ؟ نہ کسی کو یہ معلوم ہے کہ کس زمین میں مرے گا (یاد رکھو) اللہ تعالیٰ پورے علم والا اور صحیح خبروں والا ہے۔
