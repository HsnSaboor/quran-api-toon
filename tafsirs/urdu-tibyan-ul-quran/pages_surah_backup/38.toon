quran[88]{c,v,t}:
38,1,صٓ وَ الْقُرْاٰنِ ذِی الذِّكْرِؕ صٓ : صاد وَالْقُرْاٰنِ : قرآن کی قسم ذِي الذِّكْرِ : نصیحت دینے والے ص ! اس نصیحت والے قرآن کی قسم (1)
38,2,بَلِ الَّذِیْنَ كَفَرُوْا فِیْ عِزَّةٍ وَّ شِقَاقٍ بَلِ : بلکہ الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) فِيْ عِزَّةٍ : گھمنڈ میں وَّشِقَاقٍ : اور مخالفت بلکہ کفار غرور و مخالفت میں پڑے ہوئے ہیں (1)۔
38,3,كَمْ اَهْلَكْنَا مِنْ قَبْلِهِمْ مِّنْ قَرْنٍ فَنَادَوْا وَّ لَاتَ حِیْنَ مَنَاصٍ كَمْ : کتنی ہی اَهْلَكْنَا : ہم نے ہلاک کردیں مِنْ قَبْلِهِمْ : ان سے قبل مِّنْ قَرْنٍ : امتیں فَنَادَوْا : تو وہ فریاد کرنے لگے وَّلَاتَ : اور نہ تھا حِيْنَ : وقت مَنَاصٍ : چھٹکارا ہم نے ان سے پہلے بھی بہت سی امتوں کو تباہ کر ڈالا (1) انہوں نے ہرچند چیخ پکار کی لیکن وہ وقت چھٹکارے کا نہ تھا۔
38,4,وَ عَجِبُوْۤا اَنْ جَآءَهُمْ مُّنْذِرٌ مِّنْهُمْ١٘ وَ قَالَ الْكٰفِرُوْنَ هٰذَا سٰحِرٌ كَذَّابٌۖۚ وَعَجِبُوْٓا : اور انہوں نے تعجب کیا اَنْ : کہ جَآءَهُمْ : ان کے پاس آیا مُّنْذِرٌ : ایک ڈرانے والا مِّنْهُمْ ۡ : ان میں سے وَقَالَ : اور کہا الْكٰفِرُوْنَ : (جمع) کافر ھٰذَا سٰحِرٌ : یہ جادوگر كَذَّابٌ : جھوٹا اور کافروں کو اس بات پر تعجب ہوا کہ ان ہی میں سے ایک انہیں ڈرانے والا آگیا (1) اور کہنے لگے کہ یہ تو جادوگر اور جھوٹا ہے۔
38,5,اَجَعَلَ الْاٰلِهَةَ اِلٰهًا وَّاحِدًا١ۖۚ اِنَّ هٰذَا لَشَیْءٌ عُجَابٌ اَجَعَلَ : کیا اس نے بنادیا الْاٰلِهَةَ : (جمع) معبود اِلٰهًا : معبود وَّاحِدًا ښ : ایک اِنَّ ھٰذَا : بیشک یہ لَشَيْءٌ : ایک شے (بات) عُجَابٌ : بڑی عجیب کیا اس نے اتنے سارے معبودوں کا ایک ہی معبود کردیا واقعی یہ بہت ہی عجیب بات ہے (1)
38,6,وَ انْطَلَقَ الْمَلَاُ مِنْهُمْ اَنِ امْشُوْا وَ اصْبِرُوْا عَلٰۤى اٰلِهَتِكُمْ١ۖۚ اِنَّ هٰذَا لَشَیْءٌ یُّرَادُۖۚ وَانْطَلَقَ : اور چل پڑے الْمَلَاُ : سردار مِنْهُمْ : ان کے اَنِ : کہ امْشُوْا : چلو وَاصْبِرُوْا : اور جمے رہو عَلٰٓي اٰلِهَتِكُمْ ښ : اپنے معبودوں پر اِنَّ ھٰذَا : بیشک یہ لَشَيْءٌ : کوئی شے (بات) يُّرَادُ : ارادہ کی ہوئی (مطلب کی) ان کے سردار یہ کہتے ہوئے چلے کہ چلو جی اور اپنے معبودوں پر جمے رہو (1) یقیناً اس بات میں تو کوئی غرض ہے (2)
38,7,مَا سَمِعْنَا بِهٰذَا فِی الْمِلَّةِ الْاٰخِرَةِ١ۖۚ اِنْ هٰذَاۤ اِلَّا اخْتِلَاقٌۖۚ مَا سَمِعْنَا : ہم نے نہیں سنا بِھٰذَا : ایسی فِي : میں الْمِلَّةِ : مذہب الْاٰخِرَةِ ښ : پچھلا اِنْ : نہیں ھٰذَآ : یہ اِلَّا : مگر۔ محض اخْتِلَاقٌ : من گھڑت ہم نے تو یہ بات پچھلے دین میں بھی نہیں سنی (1) کچھ نہیں یہ تو صرف گھڑنت ہے (2)
38,8,ءَاُنْزِلَ عَلَیْهِ الذِّكْرُ مِنْۢ بَیْنِنَا١ؕ بَلْ هُمْ فِیْ شَكٍّ مِّنْ ذِكْرِیْ١ۚ بَلْ لَّمَّا یَذُوْقُوْا عَذَابِؕ ءَاُنْزِلَ : کیا نازل کیا گیا عَلَيْهِ : اس پر الذِّكْرُ : ذکر (کلام) مِنْۢ بَيْنِنَا ۭ : ہم میں سے بَلْ : بلکہ هُمْ : وہ فِيْ شَكٍّ : شک میں مِّنْ ذِكْرِيْ ۚ : میری نصیحت سے بَلْ : بلکہ لَّمَّا : نہیں يَذُوْقُوْا : چکھا انہوں نے عَذَابِ : میرا عذاب کیا ہم سب میں سے اسی پر کلام الٰہی کیا گیا ہے ؟ (1) دراصل یہ لوگ میری وحی کی طرف سے شک میں ہیں (2) بلکہ (صحیح یہ ہے کہ) انہوں نے اب تک میرا عذاب چکھا ہی نہیں۔
38,9,اَمْ عِنْدَهُمْ خَزَآئِنُ رَحْمَةِ رَبِّكَ الْعَزِیْزِ الْوَهَّابِۚ اَمْ : کیا عِنْدَهُمْ : ان کے پاس خَزَآئِنُ : خزانے رَحْمَةِ رَبِّكَ : تمہارے رب کی رحمت الْعَزِيْزِ : غالب الْوَهَّابِ : بہت عطا کرنے والا یا کیا ان کے پاس تیرے زبردست فیاض رب کی رحمت کے خزانے ہیں (1)
38,10,اَمْ لَهُمْ مُّلْكُ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا١۫ فَلْیَرْتَقُوْا فِی الْاَسْبَابِ اَمْ لَهُمْ : کیا ان کے لیے مُّلْكُ السَّمٰوٰتِ : بادشاہت آسمانوں وَالْاَرْضِ : اور زمین وَمَا بَيْنَهُمَا ۣ : اور جو ان دونوں کے درمیان فَلْيَرْتَقُوْا : تو وہ چڑھ جائیں فِي الْاَسْبَابِ : رسیوں میں (رسیاں تان کر) یا کیا آسمان و زمین اور ان کے درمیان کی ہر چیز کی بادشاہت ان ہی کی ہے، تو پھر رسیاں تان کر چڑھ جائیں (1)
38,11,جُنْدٌ مَّا هُنَالِكَ مَهْزُوْمٌ مِّنَ الْاَحْزَابِ جُنْدٌ : ایک لشکر مَّا : جو هُنَالِكَ : یہاں مَهْزُوْمٌ : شکست خوردہ مِّنَ الْاَحْزَابِ : گروہوں میں سے یہ بھی (بڑے بڑے) لشکروں میں سے شکست پایا ہوا (چھوٹا سا) لشکر ہے (1)
38,12,كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ وَّ عَادٌ وَّ فِرْعَوْنُ ذُو الْاَوْتَادِۙ كَذَّبَتْ : جھٹلایا قَبْلَهُمْ : ان سے پہلے قَوْمُ : قوم نُوْحٍ : نوح وَّعَادٌ : اور عاد وَّفِرْعَوْنُ : اور فرعون ذُوالْاَوْتَادِ : میخوں والا ان سے پہلے بھی قوم نوح اور عاد اور میخوں والے فرعون (1) نے جھٹلایا تھا۔
38,13,وَ ثَمُوْدُ وَ قَوْمُ لُوْطٍ وَّ اَصْحٰبُ لْئَیْكَةِ١ؕ اُولٰٓئِكَ الْاَحْزَابُ ثَمُوْدُ : اور ثمود وَقَوْمُ لُوْطٍ : اور قوم لوط وَّاَصْحٰبُ لْئَيْكَةِ ۭ : اور ایکہ والے اُولٰٓئِكَ : یہی وہ الْاَحْزَابُ : گروہ اور ثمود نے اور قوم لوط نے اور أیکہ کے رہنے والوں نے بھی یہی (بڑے) تھے (1)
38,14,اِنْ كُلٌّ اِلَّا كَذَّبَ الرُّسُلَ فَحَقَّ عِقَابِ۠    ۧ اِنْ : نہیں كُلٌّ : سب اِلَّا : مگر كَذَّبَ : جھٹلایا الرُّسُلَ : رسولوں فَحَقَّ : پس آپڑا عِقَابِ : عذاب ان میں سے ایک بھی ایسا نہ تھا جس نے رسولوں کو نہیں جھٹلایا پس میری سزا ان پر ثابت ہوگئی۔
38,15,وَ مَا یَنْظُرُ هٰۤؤُلَآءِ اِلَّا صَیْحَةً وَّاحِدَةً مَّا لَهَا مِنْ فَوَاقٍ وَمَا يَنْظُرُ : اور وہ انتظار نہیں کرتے هٰٓؤُلَآءِ : یہ لوگ اِلَّا : مگر صَيْحَةً : چنگھاڑ وَّاحِدَةً : ایک مَّا لَهَا : جس کے لیے نہیں مِنْ : کوئی فَوَاقٍ : ڈھیل انہیں صرف ایک چیخ کا انتظار (1) ہے جس میں کوئی توقف (اور ڈھیل) نہیں ہے (2)
38,16,وَ قَالُوْا رَبَّنَا عَجِّلْ لَّنَا قِطَّنَا قَبْلَ یَوْمِ الْحِسَابِ وَقَالُوْا : اور انہوں نے کہا رَبَّنَا : اے ہمارے رب عَجِّلْ : جلدی دے لَّنَا : ہمیں قِطَّنَا : ہمارا حصہ قَبْلَ : پہلے يَوْمِ الْحِسَابِ : روز حساب اور انہوں نے کہا کہ اے ہمارے رب ! ہماری سر نوشت تو ہمیں روز حساب سے پہلے ہی دے دے (1)
38,17,اِصْبِرْ عَلٰى مَا یَقُوْلُوْنَ وَ اذْكُرْ عَبْدَنَا دَاوٗدَ ذَا الْاَیْدِ١ۚ اِنَّهٗۤ اَوَّابٌ اِصْبِرْ : آپ صبر کریں عَلٰي : اس پر مَا يَقُوْلُوْنَ : جو وہ کہتے ہیں وَاذْكُرْ : اور یاد کریں عَبْدَنَا : ہمارے بندے دَاوٗدَ : داؤد ذَا الْاَيْدِ ۚ : قوت والا اِنَّهٗٓ : بیشک وہ اَوَّابٌ : خوب رجوع کرنے والا آپ ان کی باتوں پر صبر کریں اور ہمارے بندے داؤد ؑ کو یاد کریں جو بڑی قوت والا تھا (1) یقیناً وہ بہت رجوع کرنے والا تھا۔
38,18,اِنَّا سَخَّرْنَا الْجِبَالَ مَعَهٗ یُسَبِّحْنَ بِالْعَشِیِّ وَ الْاِشْرَاقِۙ اِنَّا سَخَّرْنَا : بیشک ہم نے مسخر کردیے الْجِبَالَ : پہاڑ مَعَهٗ : اس کے ساتھ يُسَبِّحْنَ : وہ تسبیح کرتے تھے بِالْعَشِيِّ : شام کے وقت وَالْاِشْرَاقِ : اور صبح کے وقت ہم نے پہاڑوں کو اس کے تابع کر رکھا تھا کہ اس کے ساتھ شام کو اور صبح کو تسبیح خوانی کریں۔
38,19,وَ الطَّیْرَ مَحْشُوْرَةً١ؕ كُلٌّ لَّهٗۤ اَوَّابٌ وَالطَّيْرَ : اور پرندے مَحْشُوْرَةً ۭ : اکٹھے کیے ہوئے كُلٌّ : سب لَّهٗٓ : اس کی طرف اَوَّابٌ : رجوع کرنے والے اور پرندوں کو بھی جمع ہو کر سب کے سب اس کے زیر فرمان رہتے (1)
38,20,وَ شَدَدْنَا مُلْكَهٗ وَ اٰتَیْنٰهُ الْحِكْمَةَ وَ فَصْلَ الْخِطَابِ وَشَدَدْنَا : اور ہم نے مضبوط کی مُلْكَهٗ : اس کی بادشاہت وَاٰتَيْنٰهُ : اور ہم نے اس کو دی الْحِكْمَةَ : حکمت وَفَصْلَ : اور فیصلہ کن الْخِطَابِ : خطاب اور ہم نے اس کی سلطنت کو مضبوط کردیا تھا (1) اور اسے حکومت دی تھی (2) اور بات کا فیصلہ کرنا (3)
38,21,وَ هَلْ اَتٰىكَ نَبَؤُا الْخَصْمِ١ۘ اِذْ تَسَوَّرُوا الْمِحْرَابَۙ وَهَلْ : اور کیا اَتٰىكَ : آپ کے پاس آئی (پہنچی) نَبَؤُا الْخَصْمِ ۘ : خبر جھگڑنے والے اِذْ : جب تَسَوَّرُوا : وہ دیوار پھاند کر آئے الْمِحْرَابَ : محراب (مسجد) اور کیا تجھے جھگڑا کرنے والوں کی (بھی) خبر ملی ؟ جبکہ وہ دیوار پھاند کر محراب میں آگئے (1)۔
38,22,اِذْ دَخَلُوْا عَلٰى دَاوٗدَ فَفَزِعَ مِنْهُمْ قَالُوْا لَا تَخَفْ١ۚ خَصْمٰنِ بَغٰى بَعْضُنَا عَلٰى بَعْضٍ فَاحْكُمْ بَیْنَنَا بِالْحَقِّ وَ لَا تُشْطِطْ وَ اهْدِنَاۤ اِلٰى سَوَآءِ الصِّرَاطِ اِذْ دَخَلُوْا : جب وہ داخل ہوئے عَلٰي : پر۔ پاس دَاوٗدَ : داؤد فَفَزِعَ : تو وہ گھبرایا مِنْهُمْ : ان سے قَالُوْا : انہوں نے کہا لَا تَخَفْ ۚ : خوف نہ کھاؤ خَصْمٰنِ : ہم دو جھگڑنے والے بَغٰى : زیادتی کی بَعْضُنَا : ہم میں سے ایک عَلٰي بَعْضٍ : دوسرے پر فَاحْكُمْ : تو آپ فیصلہ کردیں بَيْنَنَا : ہمارے درمیان بِالْحَقِّ : حق کے ساتھ وَلَا تُشْطِطْ : اور زیادتی (بےانصافی نہ) کریں وَاهْدِنَآ اِلٰى : اور ہماری رہنمائی کریں طرف سَوَآءِ : سیدھا الصِّرَاطِ : راستہ جب یہ (حضرت) داؤد ؑ کے پاس پہنچے، پس یہ ان سے ڈر گئے (1) انہوں نے کہا خوف نہ کیجئے ! ہم دو فریق مقدمہ ہیں، ہم میں سے ایک نے دوسرے پر زیادتی کی ہے، پس آپ ہمارے درمیان حق کے ساتھ فیصلہ کر دیجئے اور ناانصافی نہ کیجئے اور ہمیں سیدھی راہ بتا دیجئے (1)۔
38,23,اِنَّ هٰذَاۤ اَخِیْ١۫ لَهٗ تِسْعٌ وَّ تِسْعُوْنَ نَعْجَةً وَّلِیَ نَعْجَةٌ وَّاحِدَةٌ١۫ فَقَالَ اَكْفِلْنِیْهَا وَ عَزَّنِیْ فِی الْخِطَابِ اِنَّ ھٰذَآ : بیشک یہ اَخِيْ ۣ : میرا بھائی لَهٗ : اس کے پاس تِسْعٌ وَّتِسْعُوْنَ : ننانوے نَعْجَةً : دنبیاں وَّلِيَ : اور میرے پاس نَعْجَةٌ : دنبی وَّاحِدَةٌ ۣ : ایک فَقَالَ : پس اس نے کہا اَكْفِلْنِيْهَا : وہ میرے حوالے کردے وَعَزَّنِيْ : اور اس نے مجھے دبایا فِي الْخِطَابِ : گفتگو میں (سنیئے) یہ میرا بھائی ہے (1) اس کے پاس نناوے دنبیاں ہیں اور میرے پاس ایک ہی دنبی ہے لیکن یہ مجھ سے کہہ رہا ہے کہ اپنی یہ ایک دنبی بھی مجھ ہی کو دے دے (2) اور مجھ پر بات میں بڑی سختی برتتا ہے (3)۔
38,24,قَالَ لَقَدْ ظَلَمَكَ بِسُؤَالِ نَعْجَتِكَ اِلٰى نِعَاجِهٖ١ؕ وَ اِنَّ كَثِیْرًا مِّنَ الْخُلَطَآءِ لَیَبْغِیْ بَعْضُهُمْ عَلٰى بَعْضٍ اِلَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ وَ قَلِیْلٌ مَّا هُمْ١ؕ وَ ظَنَّ دَاوٗدُ اَنَّمَا فَتَنّٰهُ فَاسْتَغْفَرَ رَبَّهٗ وَ خَرَّ رَاكِعًا وَّ اَنَابَ۩  ۞ قَالَ : (داود نے) کہا لَقَدْ ظَلَمَكَ : واقعی اس نے ظلم کیا بِسُؤَالِ : مانگنے سے نَعْجَتِكَ : تیری دنبی اِلٰى : طرف۔ ساتھ نِعَاجِهٖ ۭ : اپنی دنبیاں وَاِنَّ : اور بیشک كَثِيْرًا : اکثر مِّنَ : سے الْخُلَطَآءِ : شرکاء لَيَبْغِيْ : زیادتی کیا کرتے ہیں بَعْضُهُمْ : ان میں سے بعض عَلٰي : پر بَعْضٍ : بعض اِلَّا : سوائے الَّذِيْنَ اٰمَنُوْا : جو ایمان لائے وَعَمِلُوا الصّٰلِحٰتِ : اور انہوں نے عمل کیے درست وَقَلِيْلٌ : اور بہت کم مَّا هُمْ ۭ : وہ ۔ ایسے وَظَنَّ : اور خیال کیا دَاوٗدُ : داؤد اَنَّمَا : کہ کچھ فَتَنّٰهُ : ہم نے اسے آزمایا فَاسْتَغْفَرَ : تو اس نے مغفرت طلب کی رَبَّهٗ : اپنا رب وَخَرَّ : اور گرگیا رَاكِعًا : جھک کر وَّاَنَابَ : اور اس نے رجوع کیا آپ نے فرمایا ! اس کا اپنی دنبیوں کے ساتھ تیری ایک دنبی ملا لینے کا سوال بیشک تیرے اوپر ایک ظلم ہے اور اکثر حصہ دار اور شریک (ایسے ہی ہوتے ہیں کہ) ایک دوسرے پر ظلم کرتے ہیں (1) ، سوائے ان کے جو ایمان لائے اور جنہوں نے نیک عمل کئے اور ایسے لوگ بہت ہی کم ہیں (2) اور (حضرت) داؤد ؑ سمجھ گئے کہ ہم نے انہیں آزمایا ہے، پھر تو اپنے رب سے استغفار کرنے لگے اور عاجزی کرتے ہوئے گرپڑے اور پوری طرح رجوع کیا۔
38,25,فَغَفَرْنَا لَهٗ ذٰلِكَ١ؕ وَ اِنَّ لَهٗ عِنْدَنَا لَزُلْفٰى وَ حُسْنَ مَاٰبٍ فَغَفَرْنَا : پس ہم نے بخش دیا لَهٗ : اس کی ذٰلِكَ ۭ : یہ وَاِنَّ : اور بیشک لَهٗ : اس کے لیے عِنْدَنَا : ہمارے پاس لَزُلْفٰى : البتہ قرب وَحُسْنَ : اور اچھا مَاٰبٍ : ٹھکانا پس ہم نے بھی ان کا وہ (قصور) معاف کردیا یقیناً وہ ہمارے نزدیک بڑے مرتبہ والے اور بہت اچھے ٹھکانے والے ہیں۔
38,26,یٰدَاوٗدُ اِنَّا جَعَلْنٰكَ خَلِیْفَةً فِی الْاَرْضِ فَاحْكُمْ بَیْنَ النَّاسِ بِالْحَقِّ وَ لَا تَتَّبِعِ الْهَوٰى فَیُضِلَّكَ عَنْ سَبِیْلِ اللّٰهِ١ؕ اِنَّ الَّذِیْنَ یَضِلُّوْنَ عَنْ سَبِیْلِ اللّٰهِ لَهُمْ عَذَابٌ شَدِیْدٌۢ بِمَا نَسُوْا یَوْمَ الْحِسَابِ۠    ۧ يٰدَاوٗدُ : اے داؤد اِنَّا : بیشک ہم نے جَعَلْنٰكَ : ہم نے تجھے بنایا خَلِيْفَةً : نائب فِي الْاَرْضِ : زمین میں فَاحْكُمْ : سو تو فیصلہ کر بَيْنَ النَّاسِ : لوگوں کے درمیان بِالْحَقِّ : حق کے ساتھ وَلَا تَتَّبِعِ : اور نہ پیروی کر الْهَوٰى : خواہش فَيُضِلَّكَ : کہ وہ تجھے بھٹکا دے عَنْ : سے سَبِيْلِ اللّٰهِ ۭ : اللہ کا راستہ اِنَّ : بیشک الَّذِيْنَ : جو لوگ يَضِلُّوْنَ : بھٹکتے ہیں عَنْ : سے سَبِيْلِ اللّٰهِ : اللہ کا راستہ لَهُمْ : ان کے لیے عَذَابٌ : عذاب شَدِيْدٌۢ : شدید بِمَا : اس پر کہ نَسُوْا : انہوں نے بھلا دیا يَوْمَ الْحِسَابِ : روز حساب اے داؤد ! ہم نے تمہیں زمین میں خلیفہ بنادیا تم لوگوں کے درمیان حق کے ساتھ فیصلے کرو اور اپنی نفسانی خواہش کی پیروی نہ کرو ورنہ وہ تمہیں اللہ کی راہ سے بھٹکا دے گی، یقیناً جو لوگ اللہ کی راہ سے بھٹک جاتے ہیں ان کے لئے سخت عذاب ہے اس لئے انہوں نے حساب کے دن کو بھلا دیا ہے۔
38,27,وَ مَا خَلَقْنَا السَّمَآءَ وَ الْاَرْضَ وَ مَا بَیْنَهُمَا بَاطِلًا١ؕ ذٰلِكَ ظَنُّ الَّذِیْنَ كَفَرُوْا١ۚ فَوَیْلٌ لِّلَّذِیْنَ كَفَرُوْا مِنَ النَّارِؕ وَ : اور مَا خَلَقْنَا : نہیں پیدا کیا ہم نے السَّمَآءَ : اور زمین وَالْاَرْضَ : اور زمین وَمَا : اور جو بَيْنَهُمَا : ان کے درمیان بَاطِلًا ۭ : باطل ذٰلِكَ : یہ ظَنُّ : گمان الَّذِيْنَ كَفَرُوْا ۚ : جن لوگوں نے کفر کیا فَوَيْلٌ : پس خرابی ہے لِّلَّذِيْنَ كَفَرُوْا : ان کے لیے جنہوں نے کفر کیا (کافر) مِنَ : سے النَّارِ : آگ اور ہم نے آسمان و زمین اور ان کے درمیان کی چیزوں کو ناحق پیدا نہیں کیا (1) یہ گمان تو کافروں کا ہے سو کافروں کے لئے خرابی ہے آگ کی۔
38,28,اَمْ نَجْعَلُ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ كَالْمُفْسِدِیْنَ فِی الْاَرْضِ١٘ اَمْ نَجْعَلُ الْمُتَّقِیْنَ كَالْفُجَّارِ اَمْ : کیا نَجْعَلُ : ہم کردیں گے الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : اچھے كَالْمُفْسِدِيْنَ : ان کی طرح جو فساد پھیلاتے ہیں فِي الْاَرْضِ ۡ : زمین میں اَمْ : کیا نَجْعَلُ : ہم کردیں گے الْمُتَّقِيْنَ : پرہیزگاروں كَالْفُجَّارِ : فاجروں (بدکرداروں) کی طرح کیا ہم ان لوگوں کو جو ایمان لائے اور نیک عمل کئے ان کے برابر کردیں گے جو (ہمیشہ) زمین میں فساد مچاتے رہے، یا پرہیزگاروں کو بدکاروں جیسا کردیں گے ؟
38,29,كِتٰبٌ اَنْزَلْنٰهُ اِلَیْكَ مُبٰرَكٌ لِّیَدَّبَّرُوْۤا اٰیٰتِهٖ وَ لِیَتَذَكَّرَ اُولُوا الْاَلْبَابِ كِتٰبٌ : ایک کتاب اَنْزَلْنٰهُ : ہم نے اسے نازل کیا اِلَيْكَ : آپ کی طرف مُبٰرَكٌ : مبارک لِّيَدَّبَّرُوْٓا : تاکہ وہ غور کریں اٰيٰتِهٖ : اس کی آیات وَلِيَتَذَكَّرَ : اور تاکہ نصیحت پکڑیں اُولُوا الْاَلْبَابِ : عقل والے یہ بابرکت کتاب ہے جسے ہم نے آپ کی طرف اس لئے نازل فرمایا ہے کہ لوگ اس کی آیتوں پر غور و فکر کریں اور عقلمند اس سے نصیحت حاصل کریں۔
38,30,وَ وَهَبْنَا لِدَاوٗدَ سُلَیْمٰنَ١ؕ نِعْمَ الْعَبْدُ١ؕ اِنَّهٗۤ اَوَّابٌؕ وَوَهَبْنَا : اور ہم نے عطا کیا لِدَاوٗدَ : داؤد کو سُلَيْمٰنَ ۭ : سلیمان نِعْمَ الْعَبْدُ ۭ : بہت اچھا بندہ اِنَّهٗٓ : بیشک وہ اَوَّابٌ : رجوع کرنے والا اور ہم نے داؤد کو سلیمان (نامی فرزند) عطا فرمایا، جو بڑا اچھا بندہ تھا اور بیحد رجوع کرنے والا تھا۔
38,31,اِذْ عُرِضَ عَلَیْهِ بِالْعَشِیِّ الصّٰفِنٰتُ الْجِیَادُۙ اِذْ : جب عُرِضَ : پیش کیے گئے عَلَيْهِ : اس پر۔ سامنے بِالْعَشِيِّ : شام کے وقت الصّٰفِنٰتُ : اصلی گھوڑے الْجِيَادُ : عمدہ جب ان کے سامنے شام کے وقت تیز رو خاصے گھوڑے پیش کئے گئے (1)
38,32,فَقَالَ اِنِّیْۤ اَحْبَبْتُ حُبَّ الْخَیْرِ عَنْ ذِكْرِ رَبِّیْ١ۚ حَتّٰى تَوَارَتْ بِالْحِجَابِٙ فَقَالَ : تو اس نے کہا اِنِّىْٓ : بیشک میں اَحْبَبْتُ : میں نے دوست رکھا حُبَّ الْخَيْرِ : مال کی محبت عَنْ : سے ذِكْرِ رَبِّيْ ۚ : اپنے رب کی یاد حَتّٰى : یہاں تک کہ تَوَارَتْ : چھپ گیا بِالْحِجَابِ : پردہ میں تو کہنے لگے میں نے اپنے پروردگار کی یاد پر ان گھوڑوں کی محبت کو ترجیح دی، یہاں تک کہ (آفتاب) چھپ گیا۔
38,33,رُدُّوْهَا عَلَیَّ١ؕ فَطَفِقَ مَسْحًۢا بِالسُّوْقِ وَ الْاَعْنَاقِ رُدُّوْهَا : پھیر لاؤ انہیں عَلَيَّ ۭ : میرے سامنے فَطَفِقَ : پھر شروع کیا مَسْحًۢا : ہاتھ پھیرنا۔ صاف کرنا بِالسُّوْقِ : پنڈلیوں پر وَالْاَعْنَاقِ : اور گردنوں ان (گھوڑوں) کو دوبارہ میرے سامنے لاؤ ! پھر تو پنڈلیوں اور گردنوں پر ہاتھ پھیرنا شروع کردیا (1)
38,34,وَ لَقَدْ فَتَنَّا سُلَیْمٰنَ وَ اَلْقَیْنَا عَلٰى كُرْسِیِّهٖ جَسَدًا ثُمَّ اَنَابَ وَلَقَدْ : اور البتہ فَتَنَّا : ہم نے آزمائش کی سُلَيْمٰنَ : سلیمان وَاَلْقَيْنَا : اور ہم نے ڈالا عَلٰي كُرْسِيِّهٖ : اس کے تخت پر جَسَدًا : ایک دھڑ ثُمَّ اَنَابَ : پھر اس نے رجوع کیا اور ہم نے سلیمان ؑ کی آزمائش کی اور ان کے تخت پر ایک جسم ڈال دیا پھر (1) اس نے رجوع کیا۔
38,35,قَالَ رَبِّ اغْفِرْ لِیْ وَهَبْ لِیْ مُلْكًا لَّا یَنْۢبَغِیْ لِاَحَدٍ مِّنْۢ بَعْدِیْ١ۚ اِنَّكَ اَنْتَ الْوَهَّابُ قَالَ : اس نے کہا رَبِّ : اے میرے رب اغْفِرْ لِيْ : مجھے بخش دے تو وَهَبْ لِيْ : اور عطا فرما دے مجھے مُلْكًا : ایسی سلطنت لَّا يَنْۢبَغِيْ : نہ سزادار ہو لِاَحَدٍ : کسی کو مِّنْۢ بَعْدِيْ ۚ : میرے بعد اِنَّكَ : بیشک تو اَنْتَ : تو الْوَهَّابُ : عطا فرمانے والا کہا اے میرے رب ! مجھے بخش دے اور مجھے ایسا ملک عطا فرما جو میرے سوا کسی (شخص) کے لائق نہ ہو (1) تو بڑا ہی دینے والا ہے۔
38,36,فَسَخَّرْنَا لَهُ الرِّیْحَ تَجْرِیْ بِاَمْرِهٖ رُخَآءً حَیْثُ اَصَابَۙ فَسَخَّرْنَا : پھر ہم نے مسخر کردیا لَهُ : اس کے لیے الرِّيْحَ : ہوا تَجْرِيْ : وہ چلتی تھی بِاَمْرِهٖ : اس کے حکم سے رُخَآءً : نرمی سے حَيْثُ : جہاں اَصَابَ : وہ پہنچنا چاہتا پس ہم نے ہوا کو ان کے ماتحت کردیا وہ آپ کے حکم سے جہاں آپ چاہتے نرمی سے پہنچا دیا کرتی تھی۔
38,37,وَ الشَّیٰطِیْنَ كُلَّ بَنَّآءٍ وَّ غَوَّاصٍۙ وَالشَّيٰطِيْنَ : اور دیو (جنات) كُلَّ : تمام بَنَّآءٍ : عمارت بنانے والے وَّغَوَّاصٍ : اور غوطہ مارنے والا اور (طاقتور) جنات کو بھی (ان کے ماتحت کردیا) ہر عمارت بنانے والے کو اور غوط خور کو۔
38,38,وَّ اٰخَرِیْنَ مُقَرَّنِیْنَ فِی الْاَصْفَادِ وَّاٰخَرِيْنَ : اور دوسرے مُقَرَّنِيْنَ : جکڑے ہوئے فِي الْاَصْفَادِ : زنجیروں میں اور دوسرے جنات کو بھی جو زنجیروں میں جکڑے رہتے (1)
38,39,هٰذَا عَطَآؤُنَا فَامْنُنْ اَوْ اَمْسِكْ بِغَیْرِ حِسَابٍ ھٰذَا : یہ عَطَآؤُنَا : ہمارا عطیہ فَامْنُنْ : اب تو احسان کر اَوْ : یا اَمْسِكْ : روک رکھ بِغَيْرِ حِسَابٍ : حساب کے بغیر یہ ہے ہمارا عطیہ اب تو احسان کر یا روک رکھ، کچھ حساب نہیں (1)۔
38,40,وَ اِنَّ لَهٗ عِنْدَنَا لَزُلْفٰى وَ حُسْنَ مَاٰبٍ۠    ۧ وَاِنَّ لَهٗ : اور بیشک اس کے لیے عِنْدَنَا : ہمارے پاس لَزُلْفٰى : البتہ قرب وَحُسْنَ : اور اچھا مَاٰبٍ : ٹھکانا ان کے لئے ہمارے پاس بڑا تقرب ہے اور بہت اچھا ٹھکانا ہے (1)
38,41,وَ اذْكُرْ عَبْدَنَاۤ اَیُّوْبَ١ۘ اِذْ نَادٰى رَبَّهٗۤ اَنِّیْ مَسَّنِیَ الشَّیْطٰنُ بِنُصْبٍ وَّ عَذَابٍؕ وَاذْكُرْ : اور آپ یاد کریں عَبْدَنَآ : ہمارا بندہ اَيُّوْبَ ۘ : ایوب اِذْ نَادٰى : جب اس نے پکارا رَبَّهٗٓ : اپنا رب اَنِّىْ : بیشک میں مَسَّنِيَ : مجھے پہنچایا الشَّيْطٰنُ : شیطان بِنُصْبٍ : ایذا وَّعَذَابٍ : اور دکھ اور ہمارے بندے ایوب ؑ کا (بھی) ذکر کر، جبکہ اس نے اپنے رب کو پکارا کہ مجھے شیطان نے رنج اور دکھ پہنچایا ہے (1)
38,42,اُرْكُضْ بِرِجْلِكَ١ۚ هٰذَا مُغْتَسَلٌۢ بَارِدٌ وَّ شَرَابٌ اُرْكُضْ : (زمین پر) مار بِرِجْلِكَ ۚ : اپنا پاؤں ھٰذَا : یہ مُغْتَسَلٌۢ : غسل کے لیے بَارِدٌ : ٹھنڈا وَّشَرَابٌ : اور پینے کے لیے اپنا پاؤں مارو، یہ نہانے کا ٹھنڈا اور پینے کا پانی ہے (1)
38,43,وَ وَهَبْنَا لَهٗۤ اَهْلَهٗ وَ مِثْلَهُمْ مَّعَهُمْ رَحْمَةً مِّنَّا وَ ذِكْرٰى لِاُولِی الْاَلْبَابِ وَوَهَبْنَا : اور ہم نے عطا کیا لَهٗٓ : اس کو اَهْلَهٗ : اس کے اہل خانہ وَمِثْلَهُمْ : اور ان جیسے مَّعَهُمْ : ان کے ساتھ رَحْمَةً : ایک رحمت مِّنَّا : ہماری (طرف) سے وَذِكْرٰى : اور نصیحت لِاُولِي الْاَلْبَابِ : عقل والوں کے لیے اور ہم نے اسے اس کا پورا کنبہ عطا فرمایا بلکہ اتنا ہی اور بھی اس کے ساتھ اپنی (خاص) رحمت سے، (1) اور عقلمندوں کی نصیحت کے لئے (2)۔
38,44,وَ خُذْ بِیَدِكَ ضِغْثًا فَاضْرِبْ بِّهٖ وَ لَا تَحْنَثْ١ؕ اِنَّا وَجَدْنٰهُ صَابِرًا١ؕ نِعْمَ الْعَبْدُ١ؕ اِنَّهٗۤ اَوَّابٌ وَخُذْ : اور تو لے بِيَدِكَ : اپنے ہاتھ میں ضِغْثًا : جھاڑو فَاضْرِبْ بِّهٖ : اس سے مار اس کو وَلَا تَحْنَثْ ۭ : اور قسم نہ توڑ اِنَّا : بیشک ہم وَجَدْنٰهُ : ہم نے اسے پایا صَابِرًا ۭ : صابر نِعْمَ الْعَبْدُ ۭ : اچھا بندہ اِنَّهٗٓ : بیشک وہ اَوَّابٌ : (اللہ کی طرف) رجوع کرنے والا اور اپنے ہاتھ میں تنکوں کا ایک مٹھا (جھاڑو) لے کر مار دے اور قسم کا خلاف نہ کر (1) سچ تو یہ ہے کہ ہم نے اسے بڑا صابر بندہ پایا، وہ بڑا نیک بندہ تھا اور بڑی ہی رغبت رکھنے والا۔
38,45,وَ اذْكُرْ عِبٰدَنَاۤ اِبْرٰهِیْمَ وَ اِسْحٰقَ وَ یَعْقُوْبَ اُولِی الْاَیْدِیْ وَ الْاَبْصَارِ وَاذْكُرْ : اور یاد کریں عِبٰدَنَآ : ہمارا بندوں اِبْرٰهِيْمَ : ابراہیم وَاِسْحٰقَ : اور اسحاق وَيَعْقُوْبَ : اور یعقوب اُولِي الْاَيْدِيْ : ہاتھوں والے وَالْاَبْصَارِ : اور آنکھوں والے ہمارے بندوں ابراہیم، اسحاق اور یعقوب (علیہم السلام) کا بھی لوگوں سے ذکر کرو جو ہاتھوں اور آنکھوں والے (1) تھے۔
38,46,اِنَّاۤ اَخْلَصْنٰهُمْ بِخَالِصَةٍ ذِكْرَى الدَّارِۚ اِنَّآ : بیشک ہم اَخْلَصْنٰهُمْ : ہم نے انہیں ممتاز کیا بِخَالِصَةٍ : خاص صفت ذِكْرَى : یاد الدَّارِ : گھر ( آخرت کا) ہم نے انہیں ایک خاص بات یعنی آخرت کی یاد کے ساتھ مخصوص کردیا تھا۔
38,47,وَ اِنَّهُمْ عِنْدَنَا لَمِنَ الْمُصْطَفَیْنَ الْاَخْیَارِؕ وَاِنَّهُمْ : اور بیشک وہ عِنْدَنَا : ہمارے نزدیک لَمِنَ : البتہ ۔ سے الْمُصْطَفَيْنَ : چنے ہوئے الْاَخْيَارِ : سب سے اچھے یہ سب ہمارے نزدیک برگزیدہ اور بہترین لوگ تھے۔
38,48,وَ اذْكُرْ اِسْمٰعِیْلَ وَ الْیَسَعَ وَ ذَا الْكِفْلِ١ؕ وَ كُلٌّ مِّنَ الْاَخْیَارِؕ وَاذْكُرْ : اور یاد کریں اِسْمٰعِيْلَ : اسماعیل وَالْيَسَعَ : اور الیسع وَذَا الْكِفْلِ ۭ : اور ذو الکفل وَكُلٌّ : اور یہ تمام مِّنَ : سے الْاَخْيَارِ : سب سے اچھے لوگ اسماعیل، یسع اور ذوالکفل (علیہم السلام) کا بھی ذکر کر دیجئے، یہ سب بہترین لوگ (1) تھے۔
38,49,هٰذَا ذِكْرٌ١ؕ وَ اِنَّ لِلْمُتَّقِیْنَ لَحُسْنَ مَاٰبٍۙ ھٰذَا ذِكْرٌ ۭ : یہ ایک نصیحت وَاِنَّ : اور بیشک لِلْمُتَّقِيْنَ : پرہیزگاروں کے لیے لَحُسْنَ : البتہ اچھا مَاٰبٍ : ٹھکانا یہ نصیحت ہے اور یقین مانو کہ پرہیزگاروں کی بڑی اچھی جگہ ہے۔
38,50,جَنّٰتِ عَدْنٍ مُّفَتَّحَةً لَّهُمُ الْاَبْوَابُۚ جَنّٰتِ : باغات عَدْنٍ : ہمیشہ رہنے کے مُّفَتَّحَةً : کھلے ہوئے لَّهُمُ : ان کے لیے الْاَبْوَابُ : دروازے (یعنی ہمیشگی والی) جنتیں جن کے دروازے ان کے لئے کھلے ہوئے ہیں۔
38,51,مُتَّكِئِیْنَ فِیْهَا یَدْعُوْنَ فِیْهَا بِفَاكِهَةٍ كَثِیْرَةٍ وَّ شَرَابٍ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے وہ فِيْهَا : ان میں يَدْعُوْنَ : منگوائیں گے فِيْهَا : ان میں بِفَاكِهَةٍ : میوے كَثِيْرَةٍ : بہت سے وَّشَرَابٍ : اور شراب (مشروبات) جن میں با فراغت تکیے لگائے بیٹھے ہوئے طرح طرح کے میوے اور قسم قسم کی شرابوں کی فرمائشیں کر رہے ہیں۔
38,52,وَ عِنْدَهُمْ قٰصِرٰتُ الطَّرْفِ اَتْرَابٌ وَعِنْدَهُمْ : اور ان کے پاس قٰصِرٰتُ : نیچے رکھنے والیاں الطَّرْفِ : نگاہ اَتْرَابٌ : ہم عمر اور ان کے پاس نیچی نظروں والی ہم عمر حوریں ہوں گی (1)۔
38,53,هٰذَا مَا تُوْعَدُوْنَ لِیَوْمِ الْحِسَابِ ھٰذَا : یہ مَا : جو ۔ جس تُوْعَدُوْنَ : وعدہ کیا جاتا ہے تم سے لِيَوْمِ الْحِسَابِ : روز حساب کے لیے یہ ہے جس کا وعدہ تم سے حساب کے دن کے لئے کیا جاتا تھا۔
38,54,اِنَّ هٰذَا لَرِزْقُنَا مَا لَهٗ مِنْ نَّفَادٍۚۖ اِنَّ : بیشک ھٰذَا : یہ لَرِزْقُنَا : یقینا ہمارا رزق مَا لَهٗ : اس کے لیے ۔ اس کو نہیں مِنْ نَّفَادٍ : ختم ہونا بیشک روزیاں (خاص) ہمارا عطیہ ہیں جن کا کبھی خاتمہ ہی نہیں (1)
38,55,هٰذَا١ؕ وَ اِنَّ لِلطّٰغِیْنَ لَشَرَّ مَاٰبٍۙ ھٰذَا ۭ : یہ وَاِنَّ : اور بیشک لِلطّٰغِيْنَ : سرکشوں کے لیے لَشَرَّ : البتہ برا مَاٰبٍ : ٹھکانا یہ تو ہوئی جزا، (1) (یاد رکھو کہ) سرکشوں کے لئے (2) بڑی بری جگہ ہے۔
38,56,جَهَنَّمَ١ۚ یَصْلَوْنَهَا١ۚ فَبِئْسَ الْمِهَادُ جَهَنَّمَ ۚ : جہنم يَصْلَوْنَهَا ۚ : وہ اس میں داخل ہوں گے فَبِئْسَ : سو برا الْمِهَادُ : بچھونا دوزخ ہے جس میں وہ جائیں گے (آہ) کیا ہی برا بچھونا ہے۔
38,57,هٰذَا١ۙ فَلْیَذُوْقُوْهُ حَمِیْمٌ وَّ غَسَّاقٌۙ ھٰذَا ۙ : یہ فَلْيَذُوْقُوْهُ : پس اس کو چکھو تم حَمِيْمٌ : کھولتا ہوا پانی وَّغَسَّاقٌ : اور پیپ یہ ہے، پس اسے چکھیں، گرم پانی اور پیپ (1)
38,58,وَّ اٰخَرُ مِنْ شَكْلِهٖۤ اَزْوَاجٌؕ وَّاٰخَرُ : اور اس کے علاوہ مِنْ شَكْلِهٖٓ : اس کی شکل کی اَزْوَاجٌ : کئی قسمیں اس کے علاوہ اور طرح طرح کے عذاب۔
38,59,هٰذَا فَوْجٌ مُّقْتَحِمٌ مَّعَكُمْ١ۚ لَا مَرْحَبًۢا بِهِمْ١ؕ اِنَّهُمْ صَالُوا النَّارِ ھٰذَا : یہ فَوْجٌ : ایک جماعت مُّقْتَحِمٌ : گھس رہے ہیں مَّعَكُمْ ۚ : تمہارے ساتھ لَا مَرْحَبًۢا : نہ ہو کوئی فراخی بِهِمْ ۭ : انہیں اِنَّهُمْ : بیشک وہ صَالُوا النَّارِ : داخل ہونے والے جہنم میں یہ ایک قوم ہے جو تمہارے ساتھ (آگ میں) جانی والی ہے، (1) کوئی خوش آمدید ان کے لئے نہیں ہے (2) یہی تو جہنم میں جانے والے ہیں۔
38,60,قَالُوْا بَلْ اَنْتُمْ١۫ لَا مَرْحَبًۢا بِكُمْ١ؕ اَنْتُمْ قَدَّمْتُمُوْهُ لَنَا١ۚ فَبِئْسَ الْقَرَارُ قَالُوْا : وہ کہیں گے بَلْ اَنْتُمْ ۣ : بلکہ تم لَا مَرْحَبًۢا : کوئی فراخی نہ ہو بِكُمْ ۭ : تمہیں اَنْتُمْ : بیشک تم قَدَّمْتُمُوْهُ : تم ہی یہ آگے لائے لَنَا ۚ : ہمارے لیے فَبِئْسَ : سو برا الْقَرَارُ : ٹھکانا وہ کہیں گے بلکہ تم ہی ہو جن کے لئے کوئی خوش آمدید نہیں ہے تم ہی نے تو اسے پہلے ہی سے ہمارے سامنے لا رکھا تھا (1) پس رہنے کی بڑی بری جگہ ہے۔
38,61,قَالُوْا رَبَّنَا مَنْ قَدَّمَ لَنَا هٰذَا فَزِدْهُ عَذَابًا ضِعْفًا فِی النَّارِ قَالُوْا : وہ کہیں گے رَبَّنَا : اے ہمارے رب مَنْ قَدَّمَ : جو آگے لایا لَنَا : ہمارے لیے ھٰذَا : یہ فَزِدْهُ : تو زیادہ کردے عَذَابًا : عذاب ضِعْفًا : دوچند فِي النَّارِ : جہنم میں وہ کہیں گے اے ہمارے رب ! جس نے (کفر کی رسم) ہمارے لئے پہلے سے نکالی ہو (1) اس کے حق میں جہنم کی دگنی سزا کر دے (2)
38,62,وَ قَالُوْا مَا لَنَا لَا نَرٰى رِجَالًا كُنَّا نَعُدُّهُمْ مِّنَ الْاَشْرَارِؕ وَقَالُوْا : اور وہ کہیں گے مَا لَنَا : کیا ہوا ہمیں لَا نَرٰى : ہم نہیں دیکھتے رِجَالًا : وہ لوگ كُنَّا نَعُدُّهُمْ : ہم شمار کرتے تھے انہیں مِّنَ : سے الْاَشْرَارِ : (جمع) شریر (بہت برے) اور جہنمی کہیں گے کیا یہ بات ہے کہ وہ لوگ ہمیں دکھائی نہیں دیتے جنہیں ہم برے لوگوں میں شمار کرتے تھے (1)۔
38,63,اَتَّخَذْنٰهُمْ سِخْرِیًّا اَمْ زَاغَتْ عَنْهُمُ الْاَبْصَارُ اَتَّخَذْنٰهُمْ : کیا ہم نے انہیں پکڑا تھا سِخْرِيًّا : ٹھٹھے میں اَمْ : یا زَاغَتْ : کج ہوگئی ہیں عَنْهُمُ : ان سے الْاَبْصَارُ : آنکھیں کیا ہم نے ان کا مذاق بنا رکھا تھا (1) یا ہماری نگاہیں ان سے ہٹ گئی ہیں (2)
38,64,اِنَّ ذٰلِكَ لَحَقٌّ تَخَاصُمُ اَهْلِ النَّارِ۠    ۧ اِنَّ ذٰلِكَ : بیشک یہ لَحَقٌّ : بالکل سچ تَخَاصُمُ : باہم جھگڑتا اَهْلِ النَّارِ : اہل دوزخ یقین جانو کہ دوزخیوں کا یہ جھگڑا ضرور ہی ہوگا (1)
38,65,قُلْ اِنَّمَاۤ اَنَا مُنْذِرٌ١ۖۗ وَّ مَا مِنْ اِلٰهٍ اِلَّا اللّٰهُ الْوَاحِدُ الْقَهَّارُۚ قُلْ : فرما دیں اِنَّمَآ : اس کے سوا نہیں اَنَا : کہ میں مُنْذِرٌ ڰ : ڈرانے والا وَّمَا : اور نہیں مِنْ اِلٰهٍ : کوئی معبود اِلَّا اللّٰهُ : اللہ کے سوا الْوَاحِدُ : واحد (یکتا) الْقَهَّارُ : زبردست کہہ دیجئے ! کہ میں تو صرف خبردار کرنے والا ہوں (1) اور بجز اللہ واحد غالب کے کوئی لائق عبادت نہیں۔
38,66,رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا الْعَزِیْزُ الْغَفَّارُ رَبُّ : پروردگار السَّمٰوٰتِ : آسمانوں وَالْاَرْضِ : اور زمین وَمَا : اور جو بَيْنَهُمَا : ان دونوں کے درمیان الْعَزِيْزُ : غالب الْغَفَّارُ : بڑا بخشنے والا جو پروردگار ہے آسمانوں اور زمین کا اور جو کچھ ان کے درمیان ہے، وہ زبردست اور بڑا بخشنے والا ہے۔
38,67,قُلْ هُوَ نَبَؤٌا عَظِیْمٌۙ قُلْ : فرمادیں هُوَ : وہ ۔ یہ نَبَؤٌا عَظِيْمٌ : ایک خبر بڑی آپ کہہ دیجئے کہ یہ بہت بڑی خبر ہے (1)
38,68,اَنْتُمْ عَنْهُ مُعْرِضُوْنَ اَنْتُمْ : تم عَنْهُ : اس سے مُعْرِضُوْنَ : منہ پھیرنے والے (بےپرواہ ہو) جس سے تم بےپروا ہو رہے ہو۔
38,69,مَا كَانَ لِیَ مِنْ عِلْمٍۭ بِالْمَلَاِ الْاَعْلٰۤى اِذْ یَخْتَصِمُوْنَ مَا كَانَ : نہ تھا لِيَ : میرے پاس (مجھے) مِنْ عِلْمٍۢ : کچھ خبر بِالْمَلَاِ الْاَعْلٰٓي : عالم بالا کی اِذْ : جب يَخْتَصِمُوْنَ : وہ باہم جھگڑتے تھے مجھے ان بلند قدر فرشتوں کی (بات چیت کا) کوئی علم ہی نہیں جبکہ وہ تکرار کر رہے تھے (1)
38,70,اِنْ یُّوْحٰۤى اِلَیَّ اِلَّاۤ اَنَّمَاۤ اَنَا نَذِیْرٌ مُّبِیْنٌ اِنْ يُّوْحٰٓى : نہیں وحی کی جاتی اِلَيَّ : میری طرف اِلَّآ : سوائے اَنَّمَآ : یہ کہ اَنَا نَذِيْرٌ : میں ڈرانے والا مُّبِيْنٌ : صاف صاف میری طرف فقط یہی وحی کی جاتی ہے کہ میں صاف صاف آگاہ کردینے والا ہوں (1)۔
38,71,اِذْ قَالَ رَبُّكَ لِلْمَلٰٓئِكَةِ اِنِّیْ خَالِقٌۢ بَشَرًا مِّنْ طِیْنٍ اِذْ قَالَ : جب کہا رَبُّكَ : تمہارا رب لِلْمَلٰٓئِكَةِ : فرشتوں کو اِنِّىْ : کہ میں خَالِقٌۢ : پیدا کرنے والا بَشَرًا : ایک بشر مِّنْ طِيْنٍ : مٹی سے جبکہ آپ کے رب نے فرشتوں سے ارشاد فرمایا (1) میں مٹی سے انسان کو پیدا (2) کرنے والا ہوں۔
38,72,فَاِذَا سَوَّیْتُهٗ وَ نَفَخْتُ فِیْهِ مِنْ رُّوْحِیْ فَقَعُوْا لَهٗ سٰجِدِیْنَ فَاِذَا : پھر جب سَوَّيْتُهٗ : میں درست کردوں اسے وَنَفَخْتُ : اور میں پھونکوں فِيْهِ : اس میں مِنْ : سے رُّوْحِيْ : اپنی روح فَقَعُوْا : تو تم گر پڑو لَهٗ : اس کے لیے ( آگے) سٰجِدِيْنَ : سجدہ کرتے ہوئے سو جب میں اسے ٹھیک ٹھاک کرلوں (1) اور اس میں اپنی روح پھونک دوں، (2) تو تم سب اس کے سامنے سجدے میں گرپڑنا (3)
38,73,فَسَجَدَ الْمَلٰٓئِكَةُ كُلُّهُمْ اَجْمَعُوْنَۙ فَسَجَدَ : پس سجدہ کیا الْمَلٰٓئِكَةُ : فرشتے (جمع) كُلُّهُمْ : سب اَجْمَعُوْنَ : اکٹھے چناچہ تمام فرشتوں نے سجدہ کیا (1)
38,74,اِلَّاۤ اِبْلِیْسَ١ؕ اِسْتَكْبَرَ وَ كَانَ مِنَ الْكٰفِرِیْنَ اِلَّآ : سوائے اِبْلِيْسَ ۭ : ابلیس اِسْتَكْبَرَ : اس نے تکبر کیا وَكَانَ : اور وہ ہوگیا مِنَ : سے الْكٰفِرِيْنَ : کافروں مگر ابلیس نے (نہ کیا) ، اس نے تکبر کیا (1) اور وہ تھا کافروں میں سے (2)
38,75,قَالَ یٰۤاِبْلِیْسُ مَا مَنَعَكَ اَنْ تَسْجُدَ لِمَا خَلَقْتُ بِیَدَیَّ١ؕ اَسْتَكْبَرْتَ اَمْ كُنْتَ مِنَ الْعَالِیْنَ قَالَ : اس نے فرمایا يٰٓاِبْلِيْسُ : اے ابلیس مَا مَنَعَكَ : کس نے منع کیا تجھے اَنْ تَسْجُدَ : کہ تو سجدہ کرے لِمَا : اس کو جسے خَلَقْتُ : میں نے پیدا کیا بِيَدَيَّ ۭ : اپنے ہاتھوں سے اَسْتَكْبَرْتَ : کیا تو نے تکبر کیا اَمْ كُنْتَ : یا تو ہے مِنَ : سے الْعَالِيْنَ : بلند درجہ والے اللہ تعالیٰ نے) فرمایا اے ابلیس ! تجھے اسے سجدہ کرنے سے کس چیز نے روکا جسے میں نے اپنے ہاتھوں سے پیدا کیا (1) کیا تو کچھ گھمنڈ میں آگیا ہے ؟ یا تو بڑے درجے والوں میں سے ہے۔
38,76,قَالَ اَنَا خَیْرٌ مِّنْهُ١ؕ خَلَقْتَنِیْ مِنْ نَّارٍ وَّ خَلَقْتَهٗ مِنْ طِیْنٍ قَالَ : اس نے کہا اَنَا : میں خَيْرٌ : بہتر مِّنْهُ ۭ : اس سے خَلَقْتَنِيْ : تو نے پیدا کیا مجھے مِنْ نَّارٍ : آگ سے وَّخَلَقْتَهٗ : اور تو نے پیدا کیا اسے مِنْ : سے طِيْنٍ : مٹی اس نے جواب دیا کہ میں اس سے بہتر ہوں، تو نے مجھے آگ سے بنایا، اور اسے مٹی سے بنایا ہے (1)
38,77,قَالَ فَاخْرُجْ مِنْهَا فَاِنَّكَ رَجِیْمٌۚۖ قَالَ : اس نے فرمایا فَاخْرُجْ : پس نکل جا مِنْهَا : یہاں سے فَاِنَّكَ : کیونکہ تو رَجِيْمٌ : راندہ درگاہ ارشاد ہوا کہ تو یہاں سے نکل جا تو مردود ہوا۔
38,78,وَّ اِنَّ عَلَیْكَ لَعْنَتِیْۤ اِلٰى یَوْمِ الدِّیْنِ وَّاِنَّ : اور بیشک عَلَيْكَ : تجھ پر لَعْنَتِيْٓ : میری لعنت اِلٰى : تک يَوْمِ الدِّيْنِ : روز قیامت اور تجھ پر قیامت کے دن تک میری لعنت و پھٹکار ہے
38,79,قَالَ رَبِّ فَاَنْظِرْنِیْۤ اِلٰى یَوْمِ یُبْعَثُوْنَ قَالَ : اس نے کہا رَبِّ : اے میرے رب فَاَنْظِرْنِيْٓ : پس تو مجھے مہلت دے اِلٰى : تک يَوْمِ يُبْعَثُوْنَ : جس دن اٹھائے جائیں گے کہنے لگا میرے رب مجھے لوگوں کے اٹھ کھڑے ہونے کے دن تک مہلت دے۔
38,80,قَالَ فَاِنَّكَ مِنَ الْمُنْظَرِیْنَۙ قَالَ : اس نے فرمایا فَاِنَّكَ : پس بیشک تو مِنَ : سے الْمُنْظَرِيْنَ : مہلت دیے جانے والے (اللہ تعالیٰ نے) فرمایا تو مہلت والوں میں سے ہے۔
38,81,اِلٰى یَوْمِ الْوَقْتِ الْمَعْلُوْمِ اِلٰى : تک يَوْمِ : دن الْوَقْتِ الْمَعْلُوْمِ : وقت معین متعین وقت کے دن تک۔
38,82,قَالَ فَبِعِزَّتِكَ لَاُغْوِیَنَّهُمْ اَجْمَعِیْنَۙ قَالَ : اس نے کہا فَبِعِزَّتِكَ : سو تیری عزت کی قسم لَاُغْوِيَنَّهُمْ : میں ضرور انہیں گمراہ کروں گا اَجْمَعِيْنَ : سب کہنے لگا پھر تو تیری عزت کی قسم ! میں ان سب کو یقیناً بہکا دونگا۔
38,83,اِلَّا عِبَادَكَ مِنْهُمُ الْمُخْلَصِیْنَ اِلَّا : سوائے عِبَادَكَ : تیرے بندے مِنْهُمُ : ان میں سے الْمُخْلَصِيْنَ : (جمع) مخلص بجز تیرے ان بندوں کے جو چیدہ اور پسندیدہ ہوں۔
38,84,قَالَ فَالْحَقُّ١٘ وَ الْحَقَّ اَقُوْلُۚ قَالَ : اس نے فرمایا فَالْحَقُّ ۡ : یہ حق (سچ) وَالْحَقَّ : اور سچ اَقُوْلُ : میں کہتا ہوں فرمایا سچ تو یہ ہے، اور میں سچ ہی کہا کرتا ہوں۔
38,85,لَاَمْلَئَنَّ جَهَنَّمَ مِنْكَ وَ مِمَّنْ تَبِعَكَ مِنْهُمْ اَجْمَعِیْنَ لَاَمْلَئَنَّ : میں ضرور بھر دوں گا جَهَنَّمَ : جہنم مِنْكَ : تجھ سے وَمِمَّنْ : اور ان سے جو تَبِعَكَ : تیرے پیچھے چلیں مِنْهُمْ : ان سے اَجْمَعِيْنَ : سب کہ تجھ سے اور تیرے تمام ماننے والوں میں (بھی) جہنم کو بھر دونگا۔
38,86,قُلْ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ وَّ مَاۤ اَنَا مِنَ الْمُتَكَلِّفِیْنَ قُلْ : فرما دیں مَآ : نہیں اَسْئَلُكُمْ : میں مانگتا تم سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر وَّمَآ اَنَا : اور نہیں میں مِنَ : سے الْمُتَكَلِّفِيْنَ : بناوٹ کرنے والے کہہ دیجئے کہ میں تم سے اس پر کوئی بدلہ طلب نہیں کرتا (1) اور نہ میں تکلف کرنے والوں میں سے ہوں (2)۔
38,87,اِنْ هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِیْنَ اِنْ : نہیں هُوَ اِلَّا : یہ مگر ذِكْرٌ : نصیحت لِّلْعٰلَمِيْنَ : تمام جہانوں کے لیے یہ تمام جہان والوں کے لئے سرا سر نصیحت (و عبرت) ہے (1)۔
38,88,وَ لَتَعْلَمُنَّ نَبَاَهٗ بَعْدَ حِیْنٍ۠    ۧ وَلَتَعْلَمُنَّ : اور تم ضرور جان لو گے نَبَاَهٗ : اس کا حال بَعْدَ : بعد حِيْنٍ : ایک وقت یقیناً تم اس کی حقیقت کو کچھ ہی وقت کے بعد (صحیح طور پر) جان لو گے (1)۔
