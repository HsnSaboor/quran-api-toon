quran[30]{c,v,t}:
67,1,تَبٰرَكَ الَّذِیْ بِیَدِهِ الْمُلْكُ١٘ وَ هُوَ عَلٰى كُلِّ شَیْءٍ قَدِیْرُۙ تَبٰرَكَ الَّذِيْ : بہت بابرکت ہے وہ ذات بِيَدِهِ : جس کے ہاتھ میں ہے الْمُلْكُ : ساری بادشاہت وَهُوَ : اور وہ عَلٰي كُلِّ شَيْءٍ : ہر چیز پر قَدِيْرُۨ : قدرت رکھنے والا ہے بہت بابرکت ہے وہ اللہ جس کے ہاتھ میں بادشاہی ہے (1) اور ہر چیز پر قدرت رکھنے والا ہے۔
67,2,اِ۟لَّذِیْ خَلَقَ الْمَوْتَ وَ الْحَیٰوةَ لِیَبْلُوَكُمْ اَیُّكُمْ اَحْسَنُ عَمَلًا١ؕ وَ هُوَ الْعَزِیْزُ الْغَفُوْرُۙ الَّذِيْ : جس نے خَلَقَ الْمَوْتَ : پیدا کیا موت کو وَالْحَيٰوةَ : اور زندگی کو لِيَبْلُوَكُمْ : تاکہ آزمائے تم کو اَيُّكُمْ : کون ساتم میں سے اَحْسَنُ عَمَلًا : زیادہ اچھا ہے عمل میں وَهُوَ الْعَزِيْزُ : اور وہ زبردست ہے الْغَفُوْرُ : بخشش کرنے والا ہے جس نے موت اور حیات کو اس لئے پیدا کیا کہ تمہیں آزمائے کہ تم میں اچھے کام کون کرتا ہے، اور وہ غالب اور بخشنے والا ہے۔
67,3,الَّذِیْ خَلَقَ سَبْعَ سَمٰوٰتٍ طِبَاقًا١ؕ مَا تَرٰى فِیْ خَلْقِ الرَّحْمٰنِ مِنْ تَفٰوُتٍ١ؕ فَارْجِعِ الْبَصَرَ١ۙ هَلْ تَرٰى مِنْ فُطُوْرٍ الَّذِيْ : جس نے خَلَقَ : بنائے سَبْعَ سَمٰوٰتٍ : سات آسمان طِبَاقًا : اوپر تلے۔ تہ بہ تہ مَا تَرٰى : نہ تم دیکھو گے فِيْ خَلْقِ الرَّحْمٰنِ : رحمن کی تخلیق میں مِنْ تَفٰوُتٍ : کوئی نقص۔ کجی۔ خلل فَارْجِعِ الْبَصَرَ : پھر لوٹاؤ نگاہ کو هَلْ تَرٰى : کیا تم دیکھتے ہو مِنْ فُطُوْرٍ : کوئی شگاف۔ کوئی رخنہ جس نے سات آسمان اوپر تلے بنائے۔ (تو اسے دیکھنے والے) اللہ رحمٰن کی پیدائش میں کوئی بےضابطگی نہ دیکھے گا (1) دوبارہ (نظریں ڈال کر) دیکھ لے کیا کوئی شگاف بھی نظر آ رہا ہے (2)۔
67,4,ثُمَّ ارْجِعِ الْبَصَرَ كَرَّتَیْنِ یَنْقَلِبْ اِلَیْكَ الْبَصَرُ خَاسِئًا وَّ هُوَ حَسِیْرٌ ثُمَّ ارْجِعِ : پھر لوٹاؤ الْبَصَرَ : نگاہ کو كَرَّتَيْنِ : بار بار يَنْقَلِبْ : لوٹ آئے گی اِلَيْكَ الْبَصَرُ : تیری طرف نگاہ خَاسِئًا : ذلیل ہوکر۔ عاجز ہو کر وَّهُوَ حَسِيْرٌ : اور وہ تھکی ہوئی ہوگی پھر دوہرا کردو دو بار دیکھ لے تیری نگاہ تیری طرف ذلیل (و عاجز) ہو کر تھکی ہوئی لوٹ آئے گی۔ (1)
67,5,وَ لَقَدْ زَیَّنَّا السَّمَآءَ الدُّنْیَا بِمَصَابِیْحَ وَ جَعَلْنٰهَا رُجُوْمًا لِّلشَّیٰطِیْنِ وَ اَعْتَدْنَا لَهُمْ عَذَابَ السَّعِیْرِ وَلَقَدْ : اور البتہ تحقیق زَيَّنَّا : زینت دی ہم نے۔ خوب صورت بنایا ہم نے السَّمَآءَ الدُّنْيَا : آسمان دنیا کو بِمَصَابِيْحَ : چراغوں کے ساتھ وَجَعَلْنٰهَا : اور بنایا ہم نے ان کو رُجُوْمًا : مارنے کی چیز لِّلشَّيٰطِيْنِ : شیطانوں کے لیے وَاَعْتَدْنَا : اور تیار کیا ہم نے لَهُمْ : ان کے لیے عَذَابَ السَّعِيْرِ : جلنے کا عذاب بیشک ہم نے آسمان دنیا کو چراغوں (ستاروں) سے آراستہ کیا اور انہیں شیطان کے مارنے کا ذریعہ (1) بنادیا اور شیطانوں کے لئے ہم نے (دوزخ جلانے والا) عذاب تیار کردیا۔
67,6,وَ لِلَّذِیْنَ كَفَرُوْا بِرَبِّهِمْ عَذَابُ جَهَنَّمَ١ؕ وَ بِئْسَ الْمَصِیْرُ وَلِلَّذِيْنَ كَفَرُوْا : اور ان لوگوں کے لیے جنہوں نے کفر کیا بِرَبِّهِمْ : اپنے رب کے ساتھ عَذَابُ : عذاب ہے جَهَنَّمَ : جہنم کا وَبِئْسَ الْمَصِيْرُ : اور کتنا برا ہے ٹھکانہ۔ لوٹنے کی جگہ اور اپنے رب کے ساتھ کفر کرنے والوں کے لئے جہنم کا عذاب ہے اور وہ کیا ہی بری جگہ ہے۔
67,7,اِذَاۤ اُلْقُوْا فِیْهَا سَمِعُوْا لَهَا شَهِیْقًا وَّ هِیَ تَفُوْرُۙ اِذَآ اُلْقُوْا : جب وہ ڈالیں جائیں گے فِيْهَا : اس میں سَمِعُوْا : سنیں گے لَهَا : واسطے اس کے شَهِيْقًا : چلانا وَّهِىَ تَفُوْرُ : اور وہ جوش کھارہی ہوگی جب اس میں یہ ڈالے جائیں گے تو اس کی بڑے زور سے کی آواز سنیں گے اور وہ جوش مار رہی ہوگی (1)۔
67,8,تَكَادُ تَمَیَّزُ مِنَ الْغَیْظِ١ؕ كُلَّمَاۤ اُلْقِیَ فِیْهَا فَوْجٌ سَاَلَهُمْ خَزَنَتُهَاۤ اَلَمْ یَاْتِكُمْ نَذِیْرٌ تَكَادُ : قریب ہے کہ تَمَيَّزُ : پھٹ جائے مِنَ الْغَيْظِ : غضب سے۔ غصے سے كُلَّمَآ : جب کبھی اُلْقِيَ فِيْهَا : ڈالی جائے گی اس میں فَوْجٌ : کوئی فوج۔ لوگوں کا گروہ سَاَلَهُمْ : پوچھیں گے ان سے خَزَنَتُهَآ : ان کے داروغہ۔ چوکیدار اَلَمْ يَاْتِكُمْ : کیا نہیں آیا تھا تمہارے پاس نَذِيْرٌ : کوئی ڈرانے والا قریب ہے کہ (ابھی) غصے کے مارے پھٹ جائے (1) جب کبھی اس میں کوئی گروہ ڈالا جائے گا اس سے جہنم کے دروغے پوچھیں گے کہ کیا تمہارے پاس ڈرانے والا کوئی نہیں آیا تھا (2)
67,9,قَالُوْا بَلٰى قَدْ جَآءَنَا نَذِیْرٌ١ۙ۬ فَكَذَّبْنَا وَ قُلْنَا مَا نَزَّلَ اللّٰهُ مِنْ شَیْءٍ١ۖۚ اِنْ اَنْتُمْ اِلَّا فِیْ ضَلٰلٍ كَبِیْرٍ قَالُوْا : وہ کہیں گے بَلٰي : کیوں نہیں قَدْ جَآءَنَا : تحقیق آیا ہمارے پاس نَذِيْرٌ : ڈرانے والا فَكَذَّبْنَا : تو جھٹلادیا ہم نے وَقُلْنَا : اور کہا ہم نے مَا نَزَّلَ اللّٰهُ : نہیں نازل کی اللہ نے مِنْ شَيْءٍ : کوئی چیز اِنْ اَنْتُمْ : نہیں تم اِلَّا : مگر فِيْ : میں ضَلٰلٍ كَبِيْرٍ : بڑی گمراہی وہ جواب دیں گے کہ بیشک آیا تھا لیکن ہم نے اسے جھٹلایا اور ہم نے کہا اللہ تعالیٰ نے کچھ بھی نازل نہیں فرمایا۔ تم بہت بڑی گمراہی میں ہو (1)
67,10,وَ قَالُوْا لَوْ كُنَّا نَسْمَعُ اَوْ نَعْقِلُ مَا كُنَّا فِیْۤ اَصْحٰبِ السَّعِیْرِ وَقَالُوْا : اور وہ کہیں گے لَوْ كُنَّا : کاش ہم ہوتے نَسْمَعُ : ہم سنتے اَوْ نَعْقِلُ : یا ہم سمجھتے ہوتے مَا : نہ كُنَّا : ہوتے ہم فِيْٓ اَصْحٰبِ السَّعِيْرِ : دوزخ والوں میں سے اور کہیں گے کہ اگر ہم سنتے ہوتے یا عقل رکھتے ہوتے تو دوزخیوں میں (شریک) نہ ہوتے (1)۔
67,11,فَاعْتَرَفُوْا بِذَنْۢبِهِمْ١ۚ فَسُحْقًا لِّاَصْحٰبِ السَّعِیْرِ فَاعْتَرَفُوْا : تو وہ اعتراف کرلیں گے بِذَنْۢبِهِمْ : اپنے گناہوں کا فَسُحْقًا : تو لعنت ہے۔ دوری ہے لِّاَصْحٰبِ السَّعِيْرِ : دوزخ والوں کے لیے پس انہوں نے اپنے جرم کا اقبال کرلیا (1) اب یہ دوزخی دفع ہوں (دور ہوں) (2)۔
67,12,اِنَّ الَّذِیْنَ یَخْشَوْنَ رَبَّهُمْ بِالْغَیْبِ لَهُمْ مَّغْفِرَةٌ وَّ اَجْرٌ كَبِیْرٌ اِنَّ الَّذِيْنَ : بیشک وہ لوگ يَخْشَوْنَ : جو ڈرتے ہیں رَبَّهُمْ : اپنے رب سے بِالْغَيْبِ : ساتھ غیب کے۔ غائبانہ طور پر لَهُمْ مَّغْفِرَةٌ : ان کے لیے بخشش ہے وَّاَجْرٌ : اور اجر كَبِيْرٌ : بہت بڑا بیشک جو لوگ اپنے پروردگار سے غائبانہ طور پر ڈرتے رہتے ہیں ان کے لئے بخشش ہے اور بڑا ثواب ہے۔ (1)
67,13,وَ اَسِرُّوْا قَوْلَكُمْ اَوِ اجْهَرُوْا بِهٖ١ؕ اِنَّهٗ عَلِیْمٌۢ بِذَاتِ الصُّدُوْرِ وَاَسِرُّوْا : اور چھپاؤ۔ چپکے سے کرو قَوْلَكُمْ : بات اپنی اَوِ اجْهَرُوْا بِهٖ : یا ظاہر کرو اس کو اِنَّهٗ : بیشک وہ عَلِيْمٌۢ : جاننے والا ہے بِذَاتِ الصُّدُوْرِ : سینوں کے بھید تم اپنی باتوں کو چھپاؤ یا ظاہر کرو (1) وہ تو سینوں کی پوشیدگی کو بھی بخوبی جانتا ہے
67,14,اَلَا یَعْلَمُ مَنْ خَلَقَ١ؕ وَ هُوَ اللَّطِیْفُ الْخَبِیْرُ۠    ۧ اَلَا يَعْلَمُ : کیا نہیں جانے گا مَنْ خَلَقَ : وہ جس نے پیدا کیا وَهُوَ اللَّطِيْفُ : اور وہ باریک بین ہے الْخَبِيْرُ : باخبر ہے کیا وہی نہ جانے جس نے پیدا کیا (1) پھر وہ باریک بین اور باخبر ہو۔
67,15,هُوَ الَّذِیْ جَعَلَ لَكُمُ الْاَرْضَ ذَلُوْلًا فَامْشُوْا فِیْ مَنَاكِبِهَا وَ كُلُوْا مِنْ رِّزْقِهٖ١ؕ وَ اِلَیْهِ النُّشُوْرُ هُوَ : وہ الَّذِيْ : اللہ وہ ذات ہے جَعَلَ : جس نے بنایا لَكُمُ الْاَرْضَ : تمہارے لیے زمین ذَلُوْلًا : تابع۔ فرش فَامْشُوْا : پس چلو فِيْ مَنَاكِبِهَا : اس کے اطراف میں وَكُلُوْا : اور کھاؤ مِنْ رِّزْقِهٖ : اس کے رزق میں سے وَاِلَيْهِ : اور اسی کی طرف النُّشُوْرُ : دوبارہ زندہ ہونا وہ ذات جس نے تمہارے لئے زمین کو پست و مطیع کردیا تاکہ تم اس کی راہوں میں چلتے پھرتے رہو اور اللہ کی روزیاں کھاؤ (پیو) (1) اسی کی طرف (تمہیں) جی کر اٹھ کھڑے ہونا ہے۔
67,16,ءَاَمِنْتُمْ مَّنْ فِی السَّمَآءِ اَنْ یَّخْسِفَ بِكُمُ الْاَرْضَ فَاِذَا هِیَ تَمُوْرُۙ ءَاَمِنْتُمْ : کیا بےخوف ہوگئے تم مَّنْ : اس سے جو فِي السَّمَآءِ : آسمان میں ہے اَنْ يَّخْسِفَ : کہ دھنسا دے بِكُمُ الْاَرْضَ : تم کو زمین میں فَاِذَا هِيَ : تو اچانک وہ تَمُوْرُ : لرزنے لگے۔ پھٹ جائے کیا تم اس بات سے بےخوف ہوگئے ہو کہ آسمان والا تمہیں زمین میں نہ دھنسا دے اور اچانک زمین لرزنے لگے (1)
67,17,اَمْ اَمِنْتُمْ مَّنْ فِی السَّمَآءِ اَنْ یُّرْسِلَ عَلَیْكُمْ حَاصِبًا١ؕ فَسَتَعْلَمُوْنَ كَیْفَ نَذِیْرِ اَمْ اَمِنْتُمْ : کیا بےخوف ہوگئے تم کو مَّنْ فِي السَّمَآءِ : اس سے جو آسمان میں ہے اَنْ يُّرْسِلَ : کہ وہ بھیجے عَلَيْكُمْ : تم پر حَاصِبًا : پتھروں کی بارش فَسَتَعْلَمُوْنَ : پس عنقریب تم جان لو گے كَيْفَ نَذِيْرِ : کیسے تھا ڈراؤ میرا یا کیا تم اس بات سے نڈر ہوگئے ہو کہ آسمانوں والا تم پر پتھر برسائے (1) پھر تمہیں معلوم ہو ہی جائے گا کہ میرا ڈرانا کیسا تھا (2)
67,18,وَ لَقَدْ كَذَّبَ الَّذِیْنَ مِنْ قَبْلِهِمْ فَكَیْفَ كَانَ نَكِیْرِ وَلَقَدْ : اور البتہ تحقیق كَذَّبَ : جھٹلایا الَّذِيْنَ : ان لوگوں نے مِنْ قَبْلِهِمْ : جو ان سے پہلے تھے فَكَيْفَ : تو کس طرح كَانَ نَكِيْرِ : تھی پکڑ میری اور ان سے پہلے لوگوں نے بھی جھٹلایا تھا تو دیکھو ان پر میرا عذاب کیسا ہوا ؟
67,19,اَوَ لَمْ یَرَوْا اِلَى الطَّیْرِ فَوْقَهُمْ صٰٓفّٰتٍ وَّ یَقْبِضْنَ١ؕۘؔ مَا یُمْسِكُهُنَّ اِلَّا الرَّحْمٰنُ١ؕ اِنَّهٗ بِكُلِّ شَیْءٍۭ بَصِیْرٌ اَوَلَمْ يَرَوْا : کیا بھلا انہوں نے دیکھا نہیں اِلَى الطَّيْرِ : پرندوں کی طرف فَوْقَهُمْ : ان کے اوپر صٰٓفّٰتٍ : صف بستہ وَّيَقْبِضْنَ : اور سمیٹ لیتے ہیں مَا يُمْسِكُهُنَّ : نہیں تھامتا ان کو اِلَّا الرَّحْمٰنُ : مگر رحمن اِنَّهٗ : بیشک وہ بِكُلِّ شَيْءٍۢ : ہر چیز کو بَصِيْرٌ : دیکھنے والا ہے کیا یہ اپنے پر کھولے ہوئے اور (کبھی کبھی) سمیٹے ہوئے (اڑنے والے) پرندوں کو نہیں دیکھتے (1) انہیں (اللہ) ہی (ہوا فضا) میں تھامے ہوئے ہے (2) بیشک ہر چیز اس کی نگاہ میں ہے۔
67,20,اَمَّنْ هٰذَا الَّذِیْ هُوَ جُنْدٌ لَّكُمْ یَنْصُرُكُمْ مِّنْ دُوْنِ الرَّحْمٰنِ١ؕ اِنِ الْكٰفِرُوْنَ اِلَّا فِیْ غُرُوْرٍۚ اَمَّنْ هٰذَا : یا کون ہے یہ الَّذِيْ : جو هُوَ جُنْدٌ لَّكُمْ : وہ لشکر ہو تمہارا يَنْصُرُكُمْ : جو مدد کرے تمہاری مِّنْ دُوْنِ الرَّحْمٰنِ : رحمن کے سوا اِنِ الْكٰفِرُوْنَ : نہیں ہیں کافر اِلَّا : مگر فِيْ غُرُوْرٍ : دھوکے میں سوائے اللہ کے تمہارا وہ کون سا لشکر ہے جو تمہاری مدد کرسکے کافر تو سراسر دھو کے میں ہیں (1)
67,21,اَمَّنْ هٰذَا الَّذِیْ یَرْزُقُكُمْ اِنْ اَمْسَكَ رِزْقَهٗ١ۚ بَلْ لَّجُّوْا فِیْ عُتُوٍّ وَّ نُفُوْرٍ اَمَّنْ هٰذَا الَّذِيْ : یا کون ہے وہ جو يَرْزُقُكُمْ : رزق دے گا تم کو اِنْ اَمْسَكَ : اگر تھام لیا۔ روک لیا رِزْقَهٗ : اس نے رزق اپنا بَلْ لَّجُّوْا : بلکہ وہ اڑے ہوئے ہیں فِيْ عُتُوٍّ : سرکشی میں وَّنُفُوْرٍ : بھاگنے میں اگر اللہ تعالیٰ اپنی روزی روک لے تو بتاؤ کون ہے جو پھر تمہیں روزی دے گا (1) بلکہ (کافر) تو سرکشی اور بدکنے پر اڑ گئے ہیں۔
67,22,اَفَمَنْ یَّمْشِیْ مُكِبًّا عَلٰى وَجْهِهٖۤ اَهْدٰۤى اَمَّنْ یَّمْشِیْ سَوِیًّا عَلٰى صِرَاطٍ مُّسْتَقِیْمٍ اَفَمَنْ يَّمْشِيْ : کیا پھر جو چلتا ہے مُكِبًّا : سرنگوں ہوکر۔ سر جھکا کر عَلٰي وَجْهِهٖٓ : اپنے چہرے پر اَهْدٰٓى : زیادہ ہدایت یافتہ ہے اَمَّنْ يَّمْشِيْ : یا جو چلتا ہے سَوِيًّا : سیدھا عَلٰي صِرَاطٍ مُّسْتَقِيْمٍ : سیدھے راستے پر اچھا وہ شخص زیادہ ہدایت والا ہے جو اپنے سرکے بل اوندھا ہو کر چلے (1) یا وہ جو سیدھا (پیروں کے بل) راہ راست پر چلا ہو۔ (2)
67,23,قُلْ هُوَ الَّذِیْۤ اَنْشَاَكُمْ وَ جَعَلَ لَكُمُ السَّمْعَ وَ الْاَبْصَارَ وَ الْاَفْئِدَةَ١ؕ قَلِیْلًا مَّا تَشْكُرُوْنَ قُلْ : کہہ دیجئے هُوَ الَّذِيْٓ : وہ ذات ہے اَنْشَاَكُمْ : جس نے پیدا کیا تم کو وَجَعَلَ : اور بنائے اس نے لَكُمُ السَّمْعَ : تمہارے لیے کان وَالْاَبْصَارَ : اور آنکھیں وَالْاَفْئِدَةَ : اور دل قَلِيْلًا مَّا : کتنا تھوڑا تَشْكُرُوْنَ : تم شکر ادا کرتے ہو کہہ دیجئے کہ وہی اللہ ہے جس نے تمہیں پیدا کیا (1) اور تمہارے کان آنکھیں اور اور دل بنائے (2) تم بہت ہی کم شکر گزاری کرتے ہو (2)۔
67,24,قُلْ هُوَ الَّذِیْ ذَرَاَكُمْ فِی الْاَرْضِ وَ اِلَیْهِ تُحْشَرُوْنَ قُلْ : کہہ دیجئے هُوَ الَّذِيْ : وہ اللہ وہ ذات ہے ذَرَاَكُمْ : جس نے پھیلایا تم کو فِي الْاَرْضِ : زمین میں وَاِلَيْهِ تُحْشَرُوْنَ : اور اسی کی طرف تم سمیٹے جاؤ گے کہہ دیجئے ! کہ وہی ہے جس نے تمہیں زمین میں پھیلا دیا اور اس کی طرف تم اکٹھے کئے جاؤ گے۔ (1)
67,25,وَ یَقُوْلُوْنَ مَتٰى هٰذَا الْوَعْدُ اِنْ كُنْتُمْ صٰدِقِیْنَ وَيَقُوْلُوْنَ : اور وہ کہتے ہیں مَتٰى : کب ہے هٰذَا الْوَعْدُ : یہ وعدہ اِنْ كُنْتُمْ : اگر ہو تم صٰدِقِيْنَ : سچے (کافر) پوچھتے ہیں کہ وہ وعدہ کب ظاہر ہوگا اگر تم سچے ہو (تو بتاؤ) ؟ (1)
67,26,قُلْ اِنَّمَا الْعِلْمُ عِنْدَ اللّٰهِ١۪ وَ اِنَّمَاۤ اَنَا نَذِیْرٌ مُّبِیْنٌ قُلْ : کہہ دیجئے اِنَّمَا الْعِلْمُ : بیشک علم عِنْدَ اللّٰهِ : اللہ کے پاس ہے وَاِنَّمَآ : اور بیشک اَنَا نَذِيْرٌ : میں ڈرانے والا ہوں مُّبِيْنٌ : کھلم کھلا آپ کہہ دیجئے کہ اس کا علم تو اللہ ہی کو ہے میں تو صرف کھلے طور پر آگاہ کردینے والا ہوں (1)
67,27,فَلَمَّا رَاَوْهُ زُلْفَةً سِیْٓئَتْ وُجُوْهُ الَّذِیْنَ كَفَرُوْا وَ قِیْلَ هٰذَا الَّذِیْ كُنْتُمْ بِهٖ تَدَّعُوْنَ فَلَمَّا : پھر جب رَاَوْهُ : وہ دیکھ لیں گے اس کو زُلْفَةً : نزدیک سِيْٓئَتْ : بگڑ جائیں گے وُجُوْهُ الَّذِيْنَ : چہرے ان لوگوں کے كَفَرُوْا : جنہوں نے کفر کیا وَقِيْلَ : اور کہہ دیاجائے گا هٰذَا الَّذِيْ : یہ ہے وہ چیز كُنْتُمْ : تھے تم بِهٖ : ساتھ اس کے تَدَّعُوْنَ : تم تقاضا کرتے جب یہ لوگ اس وعدے کو قریب تر پالیں گے اس وقت ان کافروں کے چہرے بگڑ جائیں گے (1) اور کہہ دیا جائے گا کہ یہی ہے جسے تم طلب کرتے تھے۔
67,28,قُلْ اَرَءَیْتُمْ اِنْ اَهْلَكَنِیَ اللّٰهُ وَ مَنْ مَّعِیَ اَوْ رَحِمَنَا١ۙ فَمَنْ یُّجِیْرُ الْكٰفِرِیْنَ مِنْ عَذَابٍ اَلِیْمٍ قُلْ : کہہ دیجئے اَرَءَيْتُمْ : کیا دیکھا تم نے اِنْ اَهْلَكَنِيَ اللّٰهُ : اگر ہلاک کردے مجھ کو اللہ وَمَنْ مَّعِيَ : ار اسے جو میرے ساتھ ہے اَوْ رَحِمَنَا : یا وہ رحم کرے ہم پر فَمَنْ يُّجِيْرُ : تو کون پناہ دے گا الْكٰفِرِيْنَ : کافروں کو مِنْ عَذَابٍ اَلِيْمٍ : دردناک عذاب سے آپ کہہ دیجئے ! اچھا اگر مجھے اور میرے ساتھیوں کو اللہ تعالیٰ ہلاک کر دے یا ہم پر رحم کرے (بہر صورت یہ تو بتاؤ) کہ کافروں کو دردناک عذاب سے کون بچائے گا ؟ (1)
67,29,قُلْ هُوَ الرَّحْمٰنُ اٰمَنَّا بِهٖ وَ عَلَیْهِ تَوَكَّلْنَا١ۚ فَسَتَعْلَمُوْنَ مَنْ هُوَ فِیْ ضَلٰلٍ مُّبِیْنٍ قُلْ : کہہ دیجئے هُوَ : وہی الرَّحْمٰنُ : رحمن اٰمَنَّا بِهٖ : ایمان لائے ہم اس پر وَعَلَيْهِ تَوَكَّلْنَا : اور اسی پر توکل کیا ہم نے فَسَتَعْلَمُوْنَ : پس عنقریب تم جان لوگے مَنْ هُوَ : کون ہے وہ جو فِيْ ضَلٰلٍ مُّبِيْنٍ : کھلی گمراہی میں ہے آپ کہہ دیجئے کہ وہی رحمٰن ہے۔ ہم تو اس پر ایمان لاچکے (1) اور اسی پر ہمارا بھروسہ ہے (2) تمہیں عنقریب معلوم ہوجائے گا کہ صریح گمراہی میں کون ہے۔
67,30,قُلْ اَرَءَیْتُمْ اِنْ اَصْبَحَ مَآؤُكُمْ غَوْرًا فَمَنْ یَّاْتِیْكُمْ بِمَآءٍ مَّعِیْنٍ۠    ۧ قُلْ اَرَءَيْتُمْ : کہہ دیجئے کیا دیکھا تم نے اِنْ : اگر اَصْبَحَ : ہوجائے مَآؤُكُمْ : پانی تمہارا غَوْرًا : خشک ۔ گہرا فَمَنْ يَّاْتِيْكُمْ : تو کون ہے جو لائے تمہارے پاس بِمَآءٍ مَّعِيْنٍ : بہتا پانی آپ کہہ دیجئے ! کہ اچھا یہ تو بتاؤ کہ اگر تمہارے (پینے کا) پانی زمین میں اتر جائے تو کون ہے جو تمہارے لئے نتھرا ہوا پانی لائے ؟ (1)۔
