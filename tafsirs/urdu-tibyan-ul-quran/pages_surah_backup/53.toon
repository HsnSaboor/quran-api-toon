quran[62]{c,v,t}:
53,1,وَ النَّجْمِ اِذَا هَوٰىۙ وَالنَّجْمِ : قسم ہے تارے کی اِذَا هَوٰى : جب وہ گرا قسم ہے ستارے کی جب وہ گرے (1)
53,2,مَا ضَلَّ صَاحِبُكُمْ وَ مَا غَوٰىۚ مَا ضَلَّ : نہیں بھٹکا صَاحِبُكُمْ : ساتھی تمہارا وَمَا غَوٰى : اور نہ وہ بہکا کہ تمہارے ساتھی نے نہ راہ گم کی ہے اور نہ ٹیڑھی راہ پر ہے (1)
53,3,وَ مَا یَنْطِقُ عَنِ الْهَوٰىؕ وَمَا يَنْطِقُ : اور نہیں وہ بولتا۔ بات کرتا عَنِ الْهَوٰى : خواہش نفس سے اور نہ وہ اپنی خواہش سے کوئی بات کہتے ہیں۔
53,4,اِنْ هُوَ اِلَّا وَحْیٌ یُّوْحٰىۙ اِنْ هُوَ : نہیں وہ اِلَّا وَحْيٌ : مگر ایک وحی ہے يُّوْحٰى : جو وحی کی جاتی ہے وہ تو صرف وحی ہے جو اتاری جاتی ہے۔
53,5,عَلَّمَهٗ شَدِیْدُ الْقُوٰىۙ عَلَّمَهٗ : سکھایا اس کو شَدِيْدُ الْقُوٰى : زبردست قوت والے نے اسے پوری طاقت والے فرشتے نے سکھایا۔
53,6,ذُوْ مِرَّةٍ١ؕ فَاسْتَوٰىۙ ذُوْ مِرَّةٍ ۭ : صاحب قوت ہے فَاسْتَوٰى : پھر پورا نظر آیا۔ سیدھا کھڑا ہوگیا۔ درست ہوگیا جو زور آور ہے پھر وہ سیدھا کھڑا ہوگیا۔
53,7,وَ هُوَ بِالْاُفُقِ الْاَعْلٰىؕ وَهُوَ : اور وہ بِالْاُفُقِ : افق پر تھا الْاَعْلٰى : بالائی۔ اعلیٰ اور وہ بلند آسمان کے کناروں پر تھا۔
53,8,ثُمَّ دَنَا فَتَدَلّٰىۙ ثُمَّ دَنَا : پھر قریب آیا فَتَدَلّٰى : پھر اتر آیا پھر نزدیک ہوا اور اتر آیا۔
53,9,فَكَانَ قَابَ قَوْسَیْنِ اَوْ اَدْنٰىۚ فَكَانَ قَابَ : تو تھا اندازے سے۔ برابر قَوْسَيْنِ : دو کمان کے اَوْ اَدْنٰى : یا اس سے کم تر۔ قریب پس وہ دو کمانوں کے بقدر فاصلہ پر رہ گیا بلکہ اس سے بھی کم۔
53,10,فَاَوْحٰۤى اِلٰى عَبْدِهٖ مَاۤ اَوْحٰىؕ فَاَوْحٰٓى اِلٰى عَبْدِهٖ : تو اس نے وحی کی اس کے بندے کی طرف مَآ اَوْحٰى : جو اس نے وحی کی۔ وحی پہنچائی پس اس نے اللہ کے بندے کو وحی پہنچائی۔
53,11,مَا كَذَبَ الْفُؤَادُ مَا رَاٰى مَا : نہیں كَذَبَ : جھوٹ بولا الْفُؤَادُ : دل نے مَا رَاٰى : جو اس نے دیکھا دل نے جھوٹ نہیں کہا (پیغمبر نے) دیکھا (1)
53,12,اَفَتُمٰرُوْنَهٗ عَلٰى مَا یَرٰى اَفَتُمٰرُوْنَهٗ : کیا پھر تم جھگڑتے ہو اس سے عَلٰي مَا يَرٰى : اوپر اس کے جو وہ دیکھتا ہے کیا تم جھگڑا کرتے ہو اس پر جو (پیغمبر) دیکھتے ہیں۔
53,13,وَ لَقَدْ رَاٰهُ نَزْلَةً اُخْرٰىۙ وَلَقَدْ رَاٰهُ : اور البتہ تحقیق اس نے دیکھا اس کو نَزْلَةً : اترنا اُخْرٰى : ایک مرتبہ پھر اسے تو ایک مرتبہ اور بھی دیکھا تھا۔
53,14,عِنْدَ سِدْرَةِ الْمُنْتَهٰى عِنْدَ : پاس سِدْرَةِ الْمُنْتَهٰى : سدرۃ المنتہی کے سدرۃ المنتہیٰ کے پاس (1)۔
53,15,عِنْدَهَا جَنَّةُ الْمَاْوٰىؕ عِنْدَهَا : اس کے پاس جَنَّةُ الْمَاْوٰى : جنت الماویٰ ہے اسی کے پاس جنتہ الماویٰ ہے (1)
53,16,اِذْ یَغْشَى السِّدْرَةَ مَا یَغْشٰىۙ اِذْ يَغْشَى السِّدْرَةَ : جب چھا رہا تھا سدرہ پر مَا يَغْشٰى : جو کچھ چھا رہا تھا جب کہ سدرہ کو چھپائے لیتی تھی وہ چیز جو اس پر چھا رہی تھی (1)
53,17,مَا زَاغَ الْبَصَرُ وَ مَا طَغٰى مَا زَاغَ الْبَصَرُ : نہیں کجی کی نگاہ نے وَمَا طَغٰى : اور نہ وہ حد سے بڑھی نہ تو نگاہ بہکی نہ حد سے بڑھی (1)
53,18,لَقَدْ رَاٰى مِنْ اٰیٰتِ رَبِّهِ الْكُبْرٰى لَقَدْ رَاٰى : البتہ تحقیق اس نے دیکھیں مِنْ اٰيٰتِ رَبِّهِ : اپنے رب کی نشانیوں میں سے الْكُبْرٰى : بڑی بڑی یقیناً اس نے اپنے رب کی بڑی بڑی نشانیوں میں سے بعض نشانیاں دیکھ لیں (1)
53,19,اَفَرَءَیْتُمُ اللّٰتَ وَ الْعُزّٰىۙ اَفَرَءَيْتُمُ اللّٰتَ : کیا پھر دیکھا تم نے لات کو وَالْعُزّٰى : اور عزی کو کیا تم نے لات اور عزیٰ کو دیکھا۔
53,20,وَ مَنٰوةَ الثَّالِثَةَ الْاُخْرٰى وَمَنٰوةَ : اور منات کو الثَّالِثَةَ : تیسری الْاُخْرٰى : ایک اور اور منات تیسرے پچھلے کو (1)
53,21,اَلَكُمُ الذَّكَرُ وَ لَهُ الْاُنْثٰى اَلَكُمُ الذَّكَرُ : کیا تمہارے لیے لڑکے ہیں وَلَهُ الْاُنْثٰى : اور اس کے لیے لڑکیاں کیا تمہارے لئے لڑکے اور اللہ کے لئے لڑکیاں ہیں (1)
53,22,تِلْكَ اِذًا قِسْمَةٌ ضِیْزٰى تِلْكَ : یہ اِذًا قِسْمَةٌ : تب ایک تقسیم ہے ضِيْزٰى : ظلم کی یہ تو اب بڑی بےانصافی کی تقسیم ہے۔ (1)
53,23,اِنْ هِیَ اِلَّاۤ اَسْمَآءٌ سَمَّیْتُمُوْهَاۤ اَنْتُمْ وَ اٰبَآؤُكُمْ مَّاۤ اَنْزَلَ اللّٰهُ بِهَا مِنْ سُلْطٰنٍ١ؕ اِنْ یَّتَّبِعُوْنَ اِلَّا الظَّنَّ وَ مَا تَهْوَى الْاَنْفُسُ١ۚ وَ لَقَدْ جَآءَهُمْ مِّنْ رَّبِّهِمُ الْهُدٰىؕ اِنْ هِىَ : نہیں وہ اِلَّآ اَسْمَآءٌ : مگر کچھ نام ہیں سَمَّيْتُمُوْهَآ : نام رکھے تم نے ان کے اَنْتُمْ : تم نے وَاٰبَآؤُكُمْ : اور تمہارے آباؤ اجداد نے مَّآ اَنْزَلَ اللّٰهُ : نہیں نازل کی اللہ نے بِهَا مِنْ سُلْطٰنٍ ۭ : ساتھ اس کے کوئی دلیل اِنْ يَّتَّبِعُوْنَ : نہیں وہ پیروی کرتے اِلَّا الظَّنَّ : مگر گمان کی وَمَا تَهْوَى الْاَنْفُسُ ۚ : اور جو خواہش کرتے ہیں نفس وَلَقَدْ جَآءَهُمْ : اور البتہ تحقیق آئی ان کے پاس مِّنْ رَّبِّهِمُ الْهُدٰى : ان کے رب کی طرف سے ہدایت دراصل یہ صرف نام ہیں جو تم نے اور تمہارے باپ دادوں نے ان کے لئے رکھ لئے ہیں اللہ نے ان کی کوئی دلیل نہیں اتاری۔ یہ لوگ صرف اٹکل کے اور اپنی نفسانی خواہشوں کے پیچھے پڑے ہوئے ہیں اور یقیناً ان کے رب کی طرف سے ان کے پاس ہدایت آچکی ہے۔
53,24,اَمْ لِلْاِنْسَانِ مَا تَمَنّٰى٘ۖ اَمْ لِلْاِنْسَانِ : یا انسان کے لیے ہے مَا تَمَنّٰى : جو وہ تمنا کرے کیا ہر شخص جو آرزو کرے اسے میسر ہے ؟ (1)
53,25,فَلِلّٰهِ الْاٰخِرَةُ وَ الْاُوْلٰى۠    ۧ فَلِلّٰهِ : تو اللہ کے لیے ہے الْاٰخِرَةُ : پچھلی وَالْاُوْلٰى : اور پہلی اللہ ہی کے ساتھ ہے یہ جہان اور وہ جہان (1)
53,26,وَ كَمْ مِّنْ مَّلَكٍ فِی السَّمٰوٰتِ لَا تُغْنِیْ شَفَاعَتُهُمْ شَیْئًا اِلَّا مِنْۢ بَعْدِ اَنْ یَّاْذَنَ اللّٰهُ لِمَنْ یَّشَآءُ وَ یَرْضٰى وَكَمْ مِّنْ مَّلَكٍ : اور کتنے ہی فرشتے ہیں فِي السَّمٰوٰتِ : آسمانوں میں لَا : نہ تُغْنِيْ شَفَاعَتُهُمْ : کام آئے گی ان کی سفارش شَيْئًا : کچھ بھی اِلَّا مِنْۢ بَعْدِ : مگر اس کے بعد اَنْ يَّاْذَنَ اللّٰهُ : کہ اجازت دے اللہ لِمَنْ يَّشَآءُ : جس کے لیے چاہے وَيَرْضٰى : اور وہ راضی ہوجائے اور بہت سے فرشتے آسمانوں میں ہیں جن کی سفارش کچھ بھی نفع نہیں دے سکتی مگر یہ اور بات ہے کہ اللہ تعالیٰ اپنی خوشی اور اپنی چاہت سے جس کے لئے چاہے اجازت دے دے (1)
53,27,اِنَّ الَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ لَیُسَمُّوْنَ الْمَلٰٓئِكَةَ تَسْمِیَةَ الْاُنْثٰى اِنَّ الَّذِيْنَ : یشک وہ لوگ لَا يُؤْمِنُوْنَ بالْاٰخِرَةِ : جو ایمان نہیں لاتے آخرت پر لَيُسَمُّوْنَ الْمَلٰٓئِكَةَ : البتہ وہ نام رکھتے ہیں فرشتوں کے تَسْمِيَةَ الْاُنْثٰى : نام عورتوں والے بیشک لوگ آخرت پر ایمان نہیں رکھتے وہ فرشتوں کا زنانہ نام مقرر کرتے ہیں
53,28,وَ مَا لَهُمْ بِهٖ مِنْ عِلْمٍ١ؕ اِنْ یَّتَّبِعُوْنَ اِلَّا الظَّنَّ١ۚ وَ اِنَّ الظَّنَّ لَا یُغْنِیْ مِنَ الْحَقِّ شَیْئًاۚ وَمَا لَهُمْ : اور نہیں ان کے لیے بِهٖ : ساتھ اس کے مِنْ عِلْمٍ ۭ : کوئی علم اِنْ يَّتَّبِعُوْنَ : نہیں وہ پیروی کرتے اِلَّا الظَّنَّ ۚ : مگر گمان کی وَاِنَّ الظَّنَّ : اور بیشک گمان لَا : نہیں يُغْنِيْ : کام آتا مِنَ الْحَقِّ شَيْئًا : حق سے کچھ بھی۔ کوئی چیز حالانکہ انہیں اس کا علم نہیں وہ صرف اپنے گمان کے پیچھے پڑے ہوئے ہیں اور بیشک وہم (گمان) حق کے مقابلے میں کچھ کام نہیں دیتا۔
53,29,فَاَعْرِضْ عَنْ مَّنْ تَوَلّٰى١ۙ۬ عَنْ ذِكْرِنَا وَ لَمْ یُرِدْ اِلَّا الْحَیٰوةَ الدُّنْیَاؕ فَاَعْرِضْ : تو اعراض برتیئے عَنْ مَّنْ تَوَلّٰى : اس سے جو منہ موڑے عَنْ ذِكْرِنَا : ہمارے ذکر سے وَلَمْ يُرِدْ : اور نہ چاہے وہ اِلَّا الْحَيٰوةَ الدُّنْيَا : مگر دنیا کی زندگی تو آپ اس سے منہ موڑ لیں جو ہماری یاد سے منہ موڑے اور جن کا ارادہ بجز زندگانی دنیا کے اور کچھ نہیں۔
53,30,ذٰلِكَ مَبْلَغُهُمْ مِّنَ الْعِلْمِ١ؕ اِنَّ رَبَّكَ هُوَ اَعْلَمُ بِمَنْ ضَلَّ عَنْ سَبِیْلِهٖ١ۙ وَ هُوَ اَعْلَمُ بِمَنِ اهْتَدٰى ذٰلِكَ : یہی مَبْلَغُهُمْ : ان کی انتہا ہے مِّنَ الْعِلْمِ ۭ : علم میں سے اِنَّ رَبَّكَ : بیشک رب تیرا هُوَ اَعْلَمُ : وہ زیادہ جانتا ہے بِمَنْ ضَلَّ : اس کو جو بھٹک گیا عَنْ سَبِيْلِهٖ ۙ : اس کے راستے سے وَهُوَ اَعْلَمُ : اور وہ زیادہ جانتا ہے بِمَنِ اهْتَدٰى : اس کو جو ہدایت پا گیا یہی ان کے علم کی انتہا ہے۔ آپ کا رب اس سے خوب واقف ہے جو اس کی راہ سے بھٹک گیا ہے اور وہی خوب واقف ہے اس سے بھی جو راہ یافتہ ہے۔
53,31,وَ لِلّٰهِ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ١ۙ لِیَجْزِیَ الَّذِیْنَ اَسَآءُوْا بِمَا عَمِلُوْا وَ یَجْزِیَ الَّذِیْنَ اَحْسَنُوْا بِالْحُسْنٰىۚ وَلِلّٰهِ : اور اللہ ہی کے لیے ہے مَا : جو کچھ فِي السَّمٰوٰتِ : آسمانوں میں ہے وَمَا فِي الْاَرْضِ ۙ : اور جو کچھ زمین میں ہے لِيَجْزِيَ الَّذِيْنَ : تاکہ بدلہ دے ان لوگوں کو اَسَآءُوْا : جنہوں نے برا کیا بِمَا عَمِلُوْا : ساتھ اس کے جو انہوں نے کام کیے وَيَجْزِيَ الَّذِيْنَ : اور جزا دے ان لوگوں کو اَحْسَنُوْا بالْحُسْنٰى : جنہوں نے اچھا کیا ساتھ بھلائی کے اور اللہ ہی کا ہے جو کچھ آسمانوں میں ہے اور جو کچھ زمین میں ہے تاکہ اللہ تعالیٰ برے عمل کرنے والوں کو ان کے اعمال کا بدلہ دے اور نیک کام کرنے والوں کو اچھا بدلہ عنایت فرمائے (1)
53,32,اَلَّذِیْنَ یَجْتَنِبُوْنَ كَبٰٓئِرَ الْاِثْمِ وَ الْفَوَاحِشَ اِلَّا اللَّمَمَ١ؕ اِنَّ رَبَّكَ وَاسِعُ الْمَغْفِرَةِ١ؕ هُوَ اَعْلَمُ بِكُمْ اِذْ اَنْشَاَكُمْ مِّنَ الْاَرْضِ وَ اِذْ اَنْتُمْ اَجِنَّةٌ فِیْ بُطُوْنِ اُمَّهٰتِكُمْ١ۚ فَلَا تُزَكُّوْۤا اَنْفُسَكُمْ١ؕ هُوَ اَعْلَمُ بِمَنِ اتَّقٰى۠    ۧ اَلَّذِيْنَ : وہ لوگ يَجْتَنِبُوْنَ : جو اجتناب برتتے ہیں كَبٰٓئِرَ الْاِثْمِ : بڑے گناہوں سے وَالْفَوَاحِشَ : اور بےحیائی کی باتوں سے اِلَّا اللَّمَمَ ۭ : مگر چھوٹے گناہ اِنَّ رَبَّكَ : بیشک رب تیرا وَاسِعُ الْمَغْفِرَةِ ۭ : وسیع مغفرت والا ہے هُوَ اَعْلَمُ بِكُمْ : وہ زیادہ جانتا ہے تم کو اِذْ اَنْشَاَكُمْ : جب اس نے پیدا کیا تم کو مِّنَ الْاَرْضِ : زمین سے وَاِذْ اَنْتُمْ : اور جب تم اَجِنَّةٌ : ناپختہ بچے تھے۔ جنین فِيْ بُطُوْنِ : پیٹوں میں اُمَّهٰتِكُمْ ۚ : اپنی ماؤں کے فَلَا تُزَكُّوْٓا : پس نہ تم پاک ٹھہراؤ اَنْفُسَكُمْ ۭ : اپنے نفسوں کو هُوَ اَعْلَمُ : وہ زیادہ جانتا ہے بِمَنِ اتَّقٰى : اس کو جو تقوی اختیار کرے اور ان لوگوں کو جو بڑے گناہوں سے بچتے ہیں اور بےحیائی سے بھی سوائے کسی چھوٹے گناہ کے (1) بیشک تیرا رب بہت کشادہ مغفرت والا ہے، وہ تمہیں بخوبی جانتا ہے جبکہ اس نے تمہیں زمین سے پیدا کیا اور جبکہ تم اپنی ماؤں کے پیٹ میں بچے تھے (2) پس تم اپنی پاکیزگی آپ بیان نہ کرو۔ وہی پرہیزگاروں کو خوب جانتا ہے
53,33,اَفَرَءَیْتَ الَّذِیْ تَوَلّٰىۙ اَفَرَءَيْتَ : کیا بھلا دیکھا تم نے الَّذِيْ تَوَلّٰى : اس شخص کو جو منہ موڑ گیا کیا آپ نے اسے دیکھا جس نے منہ موڑ لیا۔
53,34,وَ اَعْطٰى قَلِیْلًا وَّ اَكْدٰى وَاَعْطٰى : اور اس نے دیا قَلِيْلًا : تھوڑا سا وَّاَكْدٰى : اور بند کردیا اور بہت کم دیا اور ہاتھ روک لیا (1)
53,35,اَعِنْدَهٗ عِلْمُ الْغَیْبِ فَهُوَ یَرٰى اَعِنْدَهٗ : کیا اس کے پاس عِلْمُ الْغَيْبِ : علم غیب ہے فَهُوَ يَرٰى : تو وہ دیکھ رہا ہے کیا اسے علم غیب ہے کہ وہ (سب کچھ) دیکھ رہا ہے (1)
53,36,اَمْ لَمْ یُنَبَّاْ بِمَا فِیْ صُحُفِ مُوْسٰىۙ اَمْ لَمْ يُنَبَّاْ : یا نہیں خبر دیا گیا۔ آگاہ کیا گیا بِمَا : ساتھ اس کے جو فِيْ صُحُفِ : صحیفوں میں ہے مُوْسٰى : موسیٰ کے کیا اسے اس چیز کی خبر نہیں دی گئی جو موسیٰ ؑ کے۔
53,37,وَ اِبْرٰهِیْمَ الَّذِیْ وَفّٰۤىۙ وَاِبْرٰهِيْمَ الَّذِيْ : اور ابراہیم جس نے وَفّيٰٓ : وفا کی اور وفادار ابراہیم ؑ کی آسمانی کتابوں میں تھا۔
53,38,اَلَّا تَزِرُ وَازِرَةٌ وِّزْرَ اُخْرٰىۙ اَلَّا : کہ نہیں تَزِرُ وَازِرَةٌ : بوجھ اٹھائے گا کوئی بوجھ اٹھانے والا وِّزْرَ اُخْرٰى : بوجھ کسی دوسرے کا کہ کوئی شخص کسی دوسرے کا بوجھ نہ اٹھائے گا۔
53,39,وَ اَنْ لَّیْسَ لِلْاِنْسَانِ اِلَّا مَا سَعٰىۙ وَاَنْ لَّيْسَ : اور یہ کہ نہیں لِلْاِنْسَانِ : انسان کے لیے اِلَّا مَا سَعٰى : مگر جو اس نے کوشش کی اور یہ کہ ہر انسان کے لئے صرف وہی ہے جس کی کوشش خود اس نے کی (1)۔
53,40,وَ اَنَّ سَعْیَهٗ سَوْفَ یُرٰى۪ وَاَنَّ سَعْيَهٗ : اور یہ کہ اس کی کوشش سَوْفَ يُرٰى : عنقریب دیکھی جائے گی اور یہ بیشک اس کی کوشش عنقریب دیکھی جائے گی۔ (1)
53,41,ثُمَّ یُجْزٰىهُ الْجَزَآءَ الْاَوْفٰىۙ ثُمَّ يُجْزٰىهُ : پھر بدلہ دیا جائے گا اس کو الْجَزَآءَ : بدلہ الْاَوْفٰى : پورا پورا پھر اسے پورا پورا بدلہ دیا جائے گا۔
53,42,وَ اَنَّ اِلٰى رَبِّكَ الْمُنْتَهٰىۙ وَاَنَّ اِلٰى رَبِّكَ : اور بیشک تیرے رب کی طرف الْمُنْتَهٰى : پہنچنا ہے۔ انتہا ہے اور یہ کہ آپ کے رب ہی کی طرف سے پہنچنا ہے۔
53,43,وَ اَنَّهٗ هُوَ اَضْحَكَ وَ اَبْكٰىۙ وَاَنَّهٗ : اور بیشک اس نے هُوَ اَضْحَكَ : وہی ہے جس نے ہنسایا وَاَبْكٰى : اور رلایا اور یہ کہ وہی ہنساتا ہے اور وہی رلاتا ہے۔
53,44,وَ اَنَّهٗ هُوَ اَمَاتَ وَ اَحْیَاۙ وَاَنَّهٗ : اور بیشک وہ هُوَ اَمَاتَ : وہی ہے جس نے موت دی وَاَحْيَا : اور زندہ کیا اور یہ کہ وہی مارتا ہے اور جلاتا ہے۔
53,45,وَ اَنَّهٗ خَلَقَ الزَّوْجَیْنِ الذَّكَرَ وَ الْاُنْثٰىۙ وَاَنَّهٗ : اور بیشک وہی ہے خَلَقَ الزَّوْجَيْنِ : جس نے پیدا کیا جوڑوں کو الذَّكَرَ وَالْاُنْثٰى : نر اور مادہ (کی شکل میں) اور اسی نے جوڑا یعنی نر مادہ پیدا کیا۔
53,46,مِنْ نُّطْفَةٍ اِذَا تُمْنٰى۪ مِنْ نُّطْفَةٍ : نطفے سے اِذَا تُمْنٰى : جب وہ ٹپکایا جاتا ہے نطفہ سے جب وہ ٹپکایا جاتا ہے۔
53,47,وَ اَنَّ عَلَیْهِ النَّشْاَةَ الْاُخْرٰىۙ وَاَنَّ عَلَيْهِ : اور بیشک اس پر ہے النَّشْاَةَ الْاُخْرٰى : دوسری دفعہ جی اٹھنا اور یہ کہ اسی کے ذمہ دوبارہ پیدا کرنا ہے۔
53,48,وَ اَنَّهٗ هُوَ اَغْنٰى وَ اَقْنٰىۙ وَاَنَّهٗ : اور بیشک وہ هُوَ اَغْنٰى : وہی ہے جس نے غنی کیا وَاَقْنٰى : اور جائیداد بخشی۔ دولت مند کیا اور یہ کہ وہی مالدار بناتا ہے اور سرمایا دیتا ہے (1)
53,49,وَ اَنَّهٗ هُوَ رَبُّ الشِّعْرٰىۙ وَاَنَّهٗ : اور بیشک وہ هُوَ رَبُّ الشِّعْرٰى : وہی رب ہے شعری (ستارے) کا اور یہ کہ وہی شعریٰ (ستارے) کا رب ہے (1)۔
53,50,وَ اَنَّهٗۤ اَهْلَكَ عَادَا اِ۟لْاُوْلٰىۙ وَاَنَّهٗٓ : اور بیشک وہی ہے اَهْلَكَ : جس نے ہلاک کیا عَادَۨا الْاُوْلٰى : عاد اولیٰ کو اور یہ کہ اسی نے عاد اول کو ہلاک کیا ہے (1)۔
53,51,وَ ثَمُوْدَاۡ فَمَاۤ اَبْقٰىۙ وَثَمُوْدَا۟ : اور ثمود کو فَمَآ اَبْقٰى : پس نہ کچھ باقی چھوڑا اور ثمود کو بھی (جن میں سے) ایک کو بھی باقی نہ رکھا۔
53,52,وَ قَوْمَ نُوْحٍ مِّنْ قَبْلُ١ؕ اِنَّهُمْ كَانُوْا هُمْ اَظْلَمَ وَ اَطْغٰىؕ وَقَوْمَ نُوْحٍ : اور قوم نوح کو مِّنْ قَبْلُ ۭ : اس سے قبل اِنَّهُمْ : بیشک وہ كَانُوْا : تھے وہ هُمْ اَظْلَمَ : وہ زیادہ ظالم وَاَطْغٰى : اور زیادہ سرکش اور اس سے پہلے قوم نوح کو، یقیناً وہ بڑے ظالم اور سرکش تھے۔
53,53,وَ الْمُؤْتَفِكَةَ اَهْوٰىۙ وَالْمُؤْتَفِكَةَ : اور اوندھی گرنے والی بستیاں اَهْوٰى : اس نے ان کو اوپر سے نیچے دے مارا اور مؤتفکہ (شہر یا الٹی ہوئی بستیوں کو) اسی نے الٹ دیا (1)۔
53,54,فَغَشّٰىهَا مَا غَشّٰىۚ فَغَشّٰىهَا : تو ڈھانکا اس کو مَا غَشّٰى : جس چیز نے ڈھانکا پھر اس پر چھا دیا جو چھایا (1)
53,55,فَبِاَیِّ اٰلَآءِ رَبِّكَ تَتَمَارٰى فَبِاَيِّ اٰلَآءِ رَبِّكَ : پس کون سی اپنے رب کی نعمتوں کے ساتھ۔ پس ساتھ کون سی اپنے رب کی نعمتوں کے تَتَمَارٰى : تم جھگڑتے ہو پس اے انسان تو اپنے رب کی کس کس نعمت کے بارے میں جھگڑے گا ؟ (1)
53,56,هٰذَا نَذِیْرٌ مِّنَ النُّذُرِ الْاُوْلٰى ھٰذَا نَذِيْرٌ : یہ ایک ڈراوا ہے مِّنَ النُّذُرِ الْاُوْلٰى : پہلے ڈراووں میں سے یہ (نبی) ڈرانے والے ہیں پہلے ڈرانے والوں میں سے۔
53,57,اَزِفَتِ الْاٰزِفَةُۚ اَزِفَتِ : نزدیک آگئی الْاٰزِفَةُ : نزدیک آنے والی آنے والی گھڑی قریب آگئی ہے۔
53,58,لَیْسَ لَهَا مِنْ دُوْنِ اللّٰهِ كَاشِفَةٌؕ لَيْسَ لَهَا : نہیں اس کے لیے مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا كَاشِفَةٌ : کوئی ہٹانے والی اللہ کے سوا اس کا (وقت معین پر کھول) دکھانے والا اور کوئی نہیں۔
53,59,اَفَمِنْ هٰذَا الْحَدِیْثِ تَعْجَبُوْنَۙ اَفَمِنْ ھٰذَا : کیا بھلا اس الْحَدِيْثِ : بات سے تَعْجَبُوْنَ : تم تعجب کرتے ہو پس کیا تم اس بات سے تعجب کرتے ہو ؟ (1)
53,60,وَ تَضْحَكُوْنَ وَ لَا تَبْكُوْنَۙ وَتَضْحَكُوْنَ : اور تم ہنستے ہو وَلَا تَبْكُوْنَ : اور نہیں تم روتے ہو اور ہنس رہے ہو ؟ روتے نہیں ؟
53,61,وَ اَنْتُمْ سٰمِدُوْنَ وَاَنْتُمْ : اور تم سٰمِدُوْنَ : غفلت میں رہتے ہو۔ گاتے بجاتے ہو بلکہ تم کھیل رہے ہو
53,62,فَاسْجُدُوْا لِلّٰهِ وَ اعْبُدُوْا۠۩  ۞    ۧ فَاسْجُدُوْا : پس سجدہ کرو لِلّٰهِ : اللہ کے لیے وَاعْبُدُوْا : اور عبادت کرو اب اللہ کے سامنے سجدے کرو اور (اسی کی) عبادت کرو (1)
