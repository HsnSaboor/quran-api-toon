quran[118]{c,v,t}:
23,1,قَدْ اَفْلَحَ الْمُؤْمِنُوْنَۙ قَدْ اَفْلَحَ : فلائی پائی (کامیاب ہوئے) الْمُؤْمِنُوْنَ : مومن (جمع) یقیناً ایمان والوں نے فلاح حاصل کرلی 1
23,2,الَّذِیْنَ هُمْ فِیْ صَلَاتِهِمْ خٰشِعُوْنَۙ الَّذِيْنَ : اور جو هُمْ : وہ فِيْ صَلَاتِهِمْ : اپنی نمازوں میں خٰشِعُوْنَ : خشوع (عاجزی) کرنے والے جو اپنی نماز میں خشوع کرتے ہیں 1
23,3,وَ الَّذِیْنَ هُمْ عَنِ اللَّغْوِ مُعْرِضُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ عَنِ اللَّغْوِ : لغو (بیہودی باتوں) سے مُعْرِضُوْنَ : منہ پھیرنے والے جو لغویات سے منہ موڑ لیتے ہیں 1
23,4,وَ الَّذِیْنَ هُمْ لِلزَّكٰوةِ فٰعِلُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ لِلزَّكٰوةِ : زکوۃ (کو) فٰعِلُوْنَ : ادا کرنے والے جو زکوٰۃ ادا کرنے والے ہیں 1
23,5,وَ الَّذِیْنَ هُمْ لِفُرُوْجِهِمْ حٰفِظُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ لِفُرُوْجِهِمْ : اپنی شرمگاہوں کی حٰفِظُوْنَ : حفاطت کرنے والے جو اپنی شرم گاہوں کی حفاظت کرنے والے ہیں۔
23,6,اِلَّا عَلٰۤى اَزْوَاجِهِمْ اَوْ مَا مَلَكَتْ اَیْمَانُهُمْ فَاِنَّهُمْ غَیْرُ مَلُوْمِیْنَۚ اِلَّا : مگر عَلٰٓي : پر۔ سے اَزْوَاجِهِمْ : اپنی بیویاں اَوْ : یا مَا مَلَكَتْ : جو مالک ہوئے اَيْمَانُهُمْ : ان کے دائیں ہاتھ فَاِنَّهُمْ : پس بیشک وہ غَيْرُ مَلُوْمِيْنَ : کوئی ملامت نہیں بجز اپنی بیویوں اور ملکیت کی لونڈیوں کے یقیناً یہ ملامتیوں میں سے نہیں ہیں۔
23,7,فَمَنِ ابْتَغٰى وَرَآءَ ذٰلِكَ فَاُولٰٓئِكَ هُمُ الْعٰدُوْنَۚ فَمَنِ : پس جو ابْتَغٰى : چاہے وَرَآءَ : سوا ذٰلِكَ : اس فَاُولٰٓئِكَ : تو وہی هُمُ : وہ الْعٰدُوْنَ : حد سے بڑھنے والے جو اس کے سوا کچھ اور چاہیں وہی حد سے تجاوز کر جانے والے ہیں 1
23,8,وَ الَّذِیْنَ هُمْ لِاَمٰنٰتِهِمْ وَ عَهْدِهِمْ رٰعُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ لِاَمٰنٰتِهِمْ : اپنی امانتیں وَعَهْدِهِمْ : اور اپنے عہد رٰعُوْنَ : رعایت کرنے والے جو اپنی امانتوں اور وعدے کی حفاظت کرنے والے ہیں 1
23,9,وَ الَّذِیْنَ هُمْ عَلٰى صَلَوٰتِهِمْ یُحَافِظُوْنَۘ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ عَلٰي : پر۔ کی صَلَوٰتِهِمْ : اپنی نمازیں يُحَافِظُوْنَ : حفاظت کرنے والے ہیں جو اپنی نمازوں کی نگہبانی کرتے ہیں 1
23,10,اُولٰٓئِكَ هُمُ الْوٰرِثُوْنَۙ اُولٰٓئِكَ : یہی لوگ هُمُ : وہ الْوٰرِثُوْنَ : وارث (جمع) یہی وارث ہیں۔
23,11,الَّذِیْنَ یَرِثُوْنَ الْفِرْدَوْسَ١ؕ هُمْ فِیْهَا خٰلِدُوْنَ الَّذِيْنَ : جو يَرِثُوْنَ : وارث (جمع) الْفِرْدَوْسَ : جنت هُمْ : وہ فِيْهَا : اس میں خٰلِدُوْنَ : ہمیشہ رہیں گے جو فردوس کے وارث ہونگے جہاں وہ ہمیشہ رہیں گے 1
23,12,وَ لَقَدْ خَلَقْنَا الْاِنْسَانَ مِنْ سُلٰلَةٍ مِّنْ طِیْنٍۚ وَ : اور لَقَدْ خَلَقْنَا : البتہ ہم نے پیدا کیا الْاِنْسَانَ : انسان مِنْ : سے سُلٰلَةٍ : خلاصہ (چنی ہوئی) مِّنْ طِيْنٍ : مٹی سے یقیناً ہم نے انسان کو مٹی کے جوہر سے پیدا کیا 1
23,13,ثُمَّ جَعَلْنٰهُ نُطْفَةً فِیْ قَرَارٍ مَّكِیْنٍ۪ ثُمَّ : پھر جَعَلْنٰهُ : ہم نے اسے ٹھہرایا نُطْفَةً : نطفہ فِيْ : میں قَرَارٍ مَّكِيْنٍ : مضبوط جگہ پھر اسے نطفہ بنا کر محفوظ جگہ میں قرار دے دیا 1۔
23,14,ثُمَّ خَلَقْنَا النُّطْفَةَ عَلَقَةً فَخَلَقْنَا الْعَلَقَةَ مُضْغَةً فَخَلَقْنَا الْمُضْغَةَ عِظٰمًا فَكَسَوْنَا الْعِظٰمَ لَحْمًا١ۗ ثُمَّ اَنْشَاْنٰهُ خَلْقًا اٰخَرَ١ؕ فَتَبٰرَكَ اللّٰهُ اَحْسَنُ الْخٰلِقِیْنَؕ ثُمَّ : پھر خَلَقْنَا : ہم نے بنایا النُّطْفَةَ : نطفہ عَلَقَةً : جما ہوا خون فَخَلَقْنَا : پس ہم نے بنایا الْعَلَقَةَ : جما ہوا خون مُضْغَةً : بوٹی فَخَلَقْنَا : پھر ہم نے بنایا الْمُضْغَةَ : بوٹی عِظٰمًا : ہڈیاں فَكَسَوْنَا : پھر ہم پہنایا الْعِظٰمَ : ہڈیاں لَحْمًا : گوشت ثُمَّ : پھر اَنْشَاْنٰهُ : ہم نے اسے اٹھایا خَلْقًا : صورت اٰخَرَ : نئی فَتَبٰرَكَ : پس برکت والا اللّٰهُ : اللہ اَحْسَنُ : بہترین الْخٰلِقِيْنَ : پید ا کرنے والا پھر نطفہ کو ہم نے جما ہوا خون بنادیا، پھر خون کے لوتھڑے کو گوشت کا ٹکڑا کردیا، پھر گوشت کے ٹکڑے کو ہڈیاں بنادیں، پھر ہڈیوں کو ہم نے گوشت پہنا دیا 1 پھر دوسری بناوٹ میں اسے پیدا کردیا 2 برکتوں والا ہے وہ اللہ جو سب سے بہترین پیدا کرنے والا ہے 3۔
23,15,ثُمَّ اِنَّكُمْ بَعْدَ ذٰلِكَ لَمَیِّتُوْنَؕ ثُمَّ : پھر اِنَّكُمْ : بیشک تم بَعْدَ ذٰلِكَ : اس کے بعد لَمَيِّتُوْنَ : ضرور مرنے والے اس کے بعد پھر تم سب یقیناً مرجانے والے ہو۔
23,16,ثُمَّ اِنَّكُمْ یَوْمَ الْقِیٰمَةِ تُبْعَثُوْنَ ثُمَّ : پھر اِنَّكُمْ : بیشک تم يَوْمَ الْقِيٰمَةِ : روز قیامت تُبْعَثُوْنَ : اٹھائے جاؤگے پھر قیامت کے دن بلاشبہ تم سب اٹھائے جاؤ گے۔
23,17,وَ لَقَدْ خَلَقْنَا فَوْقَكُمْ سَبْعَ طَرَآئِقَ١ۖۗ وَ مَا كُنَّا عَنِ الْخَلْقِ غٰفِلِیْنَ وَ : اور لَقَدْ خَلَقْنَا : تحقیق ہم نے بنائے فَوْقَكُمْ : تمہارے اوپر سَبْعَ : ساتھ طَرَآئِقَ : راستے وَمَا كُنَّا : اور ہم نہیں عَنِ : سے الْخَلْقِ : خلق (پیدائش) غٰفِلِيْنَ : غافل ہم نے تمہارے اوپر سات آسمان بنائے ہیں 1 اور ہم مخلوقات میں غافل نہیں ہیں 2۔
23,18,وَ اَنْزَلْنَا مِنَ السَّمَآءِ مَآءًۢ بِقَدَرٍ فَاَسْكَنّٰهُ فِی الْاَرْضِ١ۖۗ وَ اِنَّا عَلٰى ذَهَابٍۭ بِهٖ لَقٰدِرُوْنَۚ وَاَنْزَلْنَا : اور ہم نے اتارا مِنَ السَّمَآءِ : آسمانوں سے مَآءً : پانی بِقَدَرٍ : اندازہ کے ساتھ فَاَسْكَنّٰهُ : ہم نے اسے ٹھہرایا فِي الْاَرْضِ : زمین میں وَاِنَّا : اور بیشک ہم عَلٰي : پر ذَهَابٍ : لے جانا بِهٖ : اس کا لَقٰدِرُوْنَ : البتہ قادر ہم ایک صحیح انداز سے آسمان سے پانی برساتے ہیں، 1 پھر اسے زمین میں ٹھہرا دیتے ہیں 2 اور ہم اس کے لے جانے پر یقیناً قادر ہیں۔
23,19,فَاَنْشَاْنَا لَكُمْ بِهٖ جَنّٰتٍ مِّنْ نَّخِیْلٍ وَّ اَعْنَابٍ١ۘ لَكُمْ فِیْهَا فَوَاكِهُ كَثِیْرَةٌ وَّ مِنْهَا تَاْكُلُوْنَۙ فَاَنْشَاْنَا : پس ہم نے پیدا کیے لَكُمْ : تمہارے لیے بِهٖ : اس سے جَنّٰتٍ : باغات مِّنْ : سے۔ کے نَّخِيْلٍ : کھجور (جمع) وَّاَعْنَابٍ : اور انگور (جمع) لَكُمْ : تمہارے لیے فِيْهَا : اس میں فَوَاكِهُ : میوے كَثِيْرَةٌ : بہت وَّمِنْهَا : اور اس سے تَاْكُلُوْنَ : تم کھاتے ہو اسی پانی کے ذریعے سے ہم تمہارے لئے کھجوروں اور انگوروں کے باغات پیدا کردیتے ہیں، کہ تمہارے لیے ان میں بہت سے میوے ہوتے ہیں انہی میں سے تم کھاتے بھی ہو 1
23,20,وَ شَجَرَةً تَخْرُجُ مِنْ طُوْرِ سَیْنَآءَ تَنْۢبُتُ بِالدُّهْنِ وَ صِبْغٍ لِّلْاٰكِلِیْنَ وَشَجَرَةً : اور درخت تَخْرُجُ : نکلتا ہے مِنْ : سے طُوْرِ سَيْنَآءَ : طور سینا تَنْۢبُتُ : گتا ہے بِالدُّهْنِ : تیل کے ساتھ لیے وَصِبْغٍ : اور سالن لِّلْاٰكِلِيْنَ : کھانے والوں کے لیے اور وہ درخت جو طور سینا پہاڑ سے نکلتا ہے جو تیل نکالتا ہے اور کھانے والے کے لئے سالن ہے 1۔
23,21,وَ اِنَّ لَكُمْ فِی الْاَنْعَامِ لَعِبْرَةً١ؕ نُسْقِیْكُمْ مِّمَّا فِیْ بُطُوْنِهَا وَ لَكُمْ فِیْهَا مَنَافِعُ كَثِیْرَةٌ وَّ مِنْهَا تَاْكُلُوْنَۙ وَاِنَّ : اور بیشک لَكُمْ : تمہارے لیے فِي الْاَنْعَامِ : چوپایوں میں لَعِبْرَةً : عبرت۔ غور کا مقام نُسْقِيْكُمْ : ہم تمہیں پلاتے ہیں مِّمَّا : اس سے جو فِيْ بُطُوْنِهَا : ان کے پیٹوں میں وَلَكُمْ : اور تمہارے لیے فِيْهَا : ان میں مَنَافِعُ : فائدے كَثِيْرَةٌ : بہت وَّمِنْهَا : اور ان سے تَاْكُلُوْنَ : تم کھاتے ہو تمہارے لئے چوپایوں میں بھی بڑی بھاری عبرت ہے۔ ان کے پیٹوں میں سے ہم تمہیں دودھ پلاتے ہیں اور بھی بہت سے نفع تمہارے لئے ان میں ہیں ان میں سے بعض کو تم کھاتے بھی ہو۔
23,22,وَ عَلَیْهَا وَ عَلَى الْفُلْكِ تُحْمَلُوْنَ۠    ۧ وَعَلَيْهَا : اور ان پر وَعَلَي الْفُلْكِ : اور کشتی پر تُحْمَلُوْنَ : سوار کیے جاتے ہو اور ان پر اور کشتیوں پر تم سوار کرائے جاتے ہو 1
23,23,وَ لَقَدْ اَرْسَلْنَا نُوْحًا اِلٰى قَوْمِهٖ فَقَالَ یٰقَوْمِ اعْبُدُوا اللّٰهَ مَا لَكُمْ مِّنْ اِلٰهٍ غَیْرُهٗ١ؕ اَفَلَا تَتَّقُوْنَ وَ : اور لَقَدْ اَرْسَلْنَا : البتہ ہم نے بھیجا نُوْحًا : نوح اِلٰى قَوْمِهٖ : اس کی قوم کی طرف فَقَالَ : پس اس نے کہا يٰقَوْمِ : اے میری قوم اعْبُدُوا : تم عبادت کرو اللّٰهَ : اللہ مَا لَكُمْ : تمہارے لیے نہیں مِّنْ اِلٰهٍ : کوئی معبود غَيْرُهٗ : اس کے سوا اَفَلَا تَتَّقُوْنَ : کیا تو تم ڈرتے نہیں یقیناً ہم نے نوح ؑ کو اس کی قوم کی طرف رسول بنا کر بھیجا، اس نے کہا کہ اے میری قوم کے لوگو ! اللہ کی عبادت کرو اور اس کے سوا تمہارا کوئی معبود نہیں، کیا تم (اس سے) نہیں ڈرتے۔
23,24,فَقَالَ الْمَلَؤُا الَّذِیْنَ كَفَرُوْا مِنْ قَوْمِهٖ مَا هٰذَاۤ اِلَّا بَشَرٌ مِّثْلُكُمْ١ۙ یُرِیْدُ اَنْ یَّتَفَضَّلَ عَلَیْكُمْ١ؕ وَ لَوْ شَآءَ اللّٰهُ لَاَنْزَلَ مَلٰٓئِكَةً١ۖۚ مَّا سَمِعْنَا بِهٰذَا فِیْۤ اٰبَآئِنَا الْاَوَّلِیْنَۚ فَقَالَ : تو وہ بولے الْمَلَؤُا : سردار الَّذِيْنَ كَفَرُوْا : جنہوں نے کفر کیا مِنْ : سے۔ کے قَوْمِهٖ : اس کی قوم مَا ھٰذَآ : یہ نہیں اِلَّا : مگر بَشَرٌ : ایک بشر مِّثْلُكُمْ : تم جیسا يُرِيْدُ : وہ چاہتا ہے اَنْ يَّتَفَضَّلَ : کہ بڑا بن بیٹھے وہ عَلَيْكُمْ : تم پر وَلَوْ : اور اگر شَآءَ اللّٰهُ : اللہ چاہتا لَاَنْزَلَ : تو اتارتا مَلٰٓئِكَةً : فرشتے مَّا سَمِعْنَا : نہیں سنا ہم نے بِھٰذَا : یہ فِيْٓ اٰبَآئِنَا : اپنے باپ داد سے الْاَوَّلِيْنَ : پہلے اس کی قوم کے کافر سرداروں نے صاف کہہ دیا کہ یہ تو تم جیسا ہی انسان ہے، یہ تم پر فضیلت اور بڑائی حاصل کرنا چاہتا ہے 1 اگر اللہ ہی کو منظور ہوتا تو کسی فرشتے کو اتارتا 2 ہم نے تو اسے اپنے اگلے باپ دادوں کے زمانے میں سنا ہی نہیں 3
23,25,اِنْ هُوَ اِلَّا رَجُلٌۢ بِهٖ جِنَّةٌ فَتَرَبَّصُوْا بِهٖ حَتّٰى حِیْنٍ اِنْ هُوَ : نہیں وہ۔ یہ اِلَّا : مگر رَجُلٌ : ایک آدمی بِهٖ : جس کو جِنَّةٌ : جنون فَتَرَبَّصُوْا : سو تم انتظار کرو بِهٖ : اس کا حَتّٰى حِيْنٍ : ایک مدت تک یقیناً اس شخص کو جنون ہے، پس تم اسے ایک وقت مقرر تک ڈھیل دو 1۔
23,26,قَالَ رَبِّ انْصُرْنِیْ بِمَا كَذَّبُوْنِ قَالَ : اس نے کہا رَبِّ : اے میرے رب انْصُرْنِيْ : میری مدد فرما بِمَا : اس پر كَذَّبُوْنِ : انہوں نے مجھے جھٹلایا نوح ؑ نے دعا کی اے میرے رب ان کو جھٹلانے پر تو میری مدد کر 1
23,27,فَاَوْحَیْنَاۤ اِلَیْهِ اَنِ اصْنَعِ الْفُلْكَ بِاَعْیُنِنَا وَ وَحْیِنَا فَاِذَا جَآءَ اَمْرُنَا وَ فَارَ التَّنُّوْرُ١ۙ فَاسْلُكْ فِیْهَا مِنْ كُلٍّ زَوْجَیْنِ اثْنَیْنِ وَ اَهْلَكَ اِلَّا مَنْ سَبَقَ عَلَیْهِ الْقَوْلُ مِنْهُمْ١ۚ وَ لَا تُخَاطِبْنِیْ فِی الَّذِیْنَ ظَلَمُوْا١ۚ اِنَّهُمْ مُّغْرَقُوْنَ فَاَوْحَيْنَآ : تو ہم نے وحی بھیجی اِلَيْهِ : اس کی طرف اَنِ : کہ اصْنَعِ : تم بناؤ الْفُلْكَ : کشتی بِاَعْيُنِنَا : ہماری آنکھوں کے سامنے وَوَحْيِنَا : اور ہمارا حکم فَاِذَا : پھر جب جَآءَ : آجائے اَمْرُنَا : ہمارا حکم وَفَارَ التَّنُّوْرُ : اور تنور ابلنے لگے فَاسْلُكْ : تو چلا لے (رکھ لے) فِيْهَا : اس میں مِنْ : سے كُلٍّ : ہر (قسم) زَوْجَيْنِ : جوڑا اثْنَيْنِ : دو وَاَهْلَكَ : اور اپنے گھروالے اِلَّا : سوا مَنْ : جو۔ جس سَبَقَ : پہلے ہوچکا عَلَيْهِ : اس پر الْقَوْلُ : حکم مِنْهُمْ : ان میں سے وَلَا تُخَاطِبْنِيْ : اور نہ کرنا مجھ سے بات فِي : میں۔ بارہ میں الَّذِيْنَ ظَلَمُوْا : وہ جنہوں نے ظلم کیا اِنَّهُمْ : بیشک وہ مُّغْرَقُوْنَ : غرق کیے جانے والے ہیں تو ہم نے ان کی طرف وحی بھیجی کہ تو ہماری آنکھوں کے سامنے ہماری وحی کے مطابق ایک کشتی بنا جب ہمارا حکم آجائے 1 اور تنور ابل پڑے 2 تو تو ہر قسم کا ایک ایک جوڑا اس میں رکھ لے 3 اور اپنے اہل کو بھی، مگر ان میں سے جن کی بابت ہماری بات پہلے گزر چکی ہے 4 خبردار جن لوگوں نے ظلم کیا ان کے بارے میں مجھ سے کچھ کلام نہ کرنا وہ تو سب ڈبوئے جائیں گے 5۔
23,28,فَاِذَا اسْتَوَیْتَ اَنْتَ وَ مَنْ مَّعَكَ عَلَى الْفُلْكِ فَقُلِ الْحَمْدُ لِلّٰهِ الَّذِیْ نَجّٰىنَا مِنَ الْقَوْمِ الظّٰلِمِیْنَ فَاِذَا : پھر جب اسْتَوَيْتَ : تم بیٹھ جاؤ اَنْتَ : تم وَمَنْ : اور جو مَّعَكَ : تیرے ساتھ (ساتھی) عَلَي : پر الْفُلْكِ : کشتی فَقُلِ : تو کہنا الْحَمْدُ : تمام تعریفیں لِلّٰهِ : اللہ کے لیے الَّذِيْ : وہ جس نے نَجّٰىنَا : ہمیں نجات دی مِنَ : سے الْقَوْمِ : قوم الظّٰلِمِيْنَ : ظالم (جمع) جب تو اور تیرے ساتھی کشتی پر باطمینان بیٹھ جاؤ تو کہنا کہ سب تعریف اللہ کے لئے ہی ہے جس نے ہمیں ظالم لوگوں سے نجات عطا فرمائی۔
23,29,وَ قُلْ رَّبِّ اَنْزِلْنِیْ مُنْزَلًا مُّبٰرَكًا وَّ اَنْتَ خَیْرُ الْمُنْزِلِیْنَ وَقُلْ : اور کہو رَّبِّ : اے میرے رب اَنْزِلْنِيْ : مجھے اتار مُنْزَلًا : منزل مُّبٰرَكًا : مبارک وَّاَنْتَ : اور تو خَيْرُ : بہترین الْمُنْزِلِيْنَ : اتارنے والے اور کہنا کہ اے میرے رب ! 1 مجھے بابرکت اتارنا اتار اور تو ہی بہتر ہے اتارنے والوں میں 2۔
23,30,اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ وَّ اِنْ كُنَّا لَمُبْتَلِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ : البتہ نشانیاں وَّاِنْ كُنَّا : اور بیشک ہم ہیں لَمُبْتَلِيْنَ : آزمائش یقیناً اس میں بڑی بڑی نشانیاں ہیں 1 اور ہم بیشک آزمائش کرنے والے ہیں 2۔
23,31,ثُمَّ اَنْشَاْنَا مِنْۢ بَعْدِهِمْ قَرْنًا اٰخَرِیْنَۚ ثُمَّ : پھر اَنْشَاْنَا : ہم نے پیدا کیا مِنْۢ بَعْدِهِمْ : ان کے بعد قَرْنًا : گروہ اٰخَرِيْنَ : دوسرا پھر ان کے بعد ہم نے ایک اور امت پیدا کی 1
23,32,فَاَرْسَلْنَا فِیْهِمْ رَسُوْلًا مِّنْهُمْ اَنِ اعْبُدُوا اللّٰهَ مَا لَكُمْ مِّنْ اِلٰهٍ غَیْرُهٗ١ؕ اَفَلَا تَتَّقُوْنَ۠    ۧ فَاَرْسَلْنَا : پھر بھیجے ہم نے فِيْهِمْ : ان کے درمیان رَسُوْلًا : رسول (جمع) مِّنْهُمْ : ان میں سے اَنِ : کہ اعْبُدُوا : تم عبادت کرو اللّٰهَ : اللہ مَا لَكُمْ : نہیں تمہارے لیے مِّنْ اِلٰهٍ : کوئی معبود غَيْرُهٗ : اس کے سوا اَفَلَا تَتَّقُوْنَ : کیا پھر تم ڈرتے نہیں پھر ان میں خود ان میں سے (ہی) رسول بھی بھیجا 1 کہ تم سب اللہ کی عبادت کرو اس کے سوا تمہارا کوئی معبود نہیں 2 تم کیوں نہیں ڈرتے ؟
23,33,وَ قَالَ الْمَلَاُ مِنْ قَوْمِهِ الَّذِیْنَ كَفَرُوْا وَ كَذَّبُوْا بِلِقَآءِ الْاٰخِرَةِ وَ اَتْرَفْنٰهُمْ فِی الْحَیٰوةِ الدُّنْیَا١ۙ مَا هٰذَاۤ اِلَّا بَشَرٌ مِّثْلُكُمْ١ۙ یَاْكُلُ مِمَّا تَاْكُلُوْنَ مِنْهُ وَ یَشْرَبُ مِمَّا تَشْرَبُوْنَ۪ۙ وَقَالَ : اور کہا الْمَلَاُ : سرداروں مِنْ قَوْمِهِ : اس کی قوم کے الَّذِيْنَ : وہ جنہوں نے كَفَرُوْا : کفر کیا وَكَذَّبُوْا : اور جھٹلایا بِلِقَآءِ : حاضری کو الْاٰخِرَةِ : آخرت وَاَتْرَفْنٰهُمْ : اور ہم نے انہیں عیش دیا فِي : میں الْحَيٰوةِ الدُّنْيَا : دنیا کی زندگی مَا ھٰذَآ : یہ نہیں اِلَّا : مگر بَشَرٌ : ایک بشر مِّثْلُكُمْ : تمہیں جیسا يَاْكُلُ : وہ کھاتا ہے مِمَّا : اس سے جو تَاْكُلُوْنَ : تم کھاتے ہو مِنْهُ : اس سے وَيَشْرَبُ : اور پیتا ہے مِمَّا : اس سے جو تَشْرَبُوْنَ : تم پیتے ہو اور سردار قوم 1 نے جواب دیا، جو کفر کرتے تھے اور آخرت کی ملاقات کو جھٹلاتے تھے اور ہم نے انھیں دنیاوی زندگی میں خوشحال کر رکھا تھا 2 کہ یہ تو تم جیسا ہی انسان ہے، تمہاری ہی خوراک یہ بھی کھاتا ہے اور تمہارے پینے کا پانی ہی یہ بھی پیتا ہے 3۔
23,34,وَ لَئِنْ اَطَعْتُمْ بَشَرًا مِّثْلَكُمْ اِنَّكُمْ اِذًا لَّخٰسِرُوْنَۙ وَلَئِنْ : اور اگر اَطَعْتُمْ : تم نے اطاعت کی بَشَرًا : ایک بشر مِّثْلَكُمْ : اپنے جیسا اِنَّكُمْ : بیشک تم اِذًا : اس وقت لَّخٰسِرُوْنَ : گھاٹے میں رہو گے اگر تم نے اپنے جیسے ہی انسان کی تابعداری کرلی تو بیشک تم سخت خسارے والے ہو 1۔
23,35,اَیَعِدُكُمْ اَنَّكُمْ اِذَا مِتُّمْ وَ كُنْتُمْ تُرَابًا وَّ عِظَامًا اَنَّكُمْ مُّخْرَجُوْنَ۪ۙ اَيَعِدُكُمْ : کیا وہ وعدہ دیتا ہے تمہیں اَنَّكُمْ : کہ تم اِذَا : جب مِتُّمْ : مرگئے وَكُنْتُمْ : اور تم ہوگئے تُرَابًا : مٹی وَّعِظَامًا : اور ہڈیاں اَنَّكُمْ : تو تم مُّخْرَجُوْنَ : نکالے جاؤگے کیا یہ تمہیں اس بات کا وعدہ کرتا ہے کہ جب تم مر کر صرف خاک اور ہڈی رہ جاؤ گے تو تم پھر زندہ کیے جاؤ گے۔
23,36,هَیْهَاتَ هَیْهَاتَ لِمَا تُوْعَدُوْنَ۪ۙ هَيْهَاتَ : بعید ہے هَيْهَاتَ : بعید ہے لِمَا : وہ جو تُوْعَدُوْنَ : تمہیں وعدہ دیا جاتا ہے نہیں نہیں دور اور بہت دور ہے وہ جس کا تم وعدہ دیے جاتے ہو 1۔
23,37,اِنْ هِیَ اِلَّا حَیَاتُنَا الدُّنْیَا نَمُوْتُ وَ نَحْیَا وَ مَا نَحْنُ بِمَبْعُوْثِیْنَ۪ۙ اِنْ هِىَ : نہیں اِلَّا : مگر حَيَاتُنَا : ہماری زندگی الدُّنْيَا : دنیا نَمُوْتُ : اور ہم مرتے ہیں وَنَحْيَا : اور ہم جیتے ہیں وَمَا : اور نہیں نَحْنُ : ہم بِمَبْعُوْثِيْنَ : پھر اٹھائے جانے والے (زندگی) تو صرف دنیا کی زندگی ہے ہم مرتے جیتے رہتے ہیں اور یہ نہیں کہ ہم اٹھائے جائیں گے۔
23,38,اِنْ هُوَ اِلَّا رَجُلُ اِ۟فْتَرٰى عَلَى اللّٰهِ كَذِبًا وَّ مَا نَحْنُ لَهٗ بِمُؤْمِنِیْنَ اِنْ : نہیں هُوَ : وہ اِلَّا : مگر رَجُلُ : ایک آدمی ۨ افْتَرٰى : اس نے جھوٹ باندھا عَلَي اللّٰهِ : اللہ پر كَذِبًا : جھوٹ وَّمَا : اور نہیں نَحْنُ : ہم لَهٗ : اس پر بِمُؤْمِنِيْنَ : ایمان لانے والے یہ تو بس ایسا شخص ہے جس نے اللہ پر جھوٹ (بہتان) باندھ لیا ہے، 1 ہم تو اس پر ایمان لانے والے نہیں ہیں۔
23,39,قَالَ رَبِّ انْصُرْنِیْ بِمَا كَذَّبُوْنِ قَالَ : اس نے عرض کیا رَبِّ : میرے رب انْصُرْنِيْ : میری مدد فرما بِمَا : اس پر جو كَذَّبُوْنِ : انہوں نے مجھے جھٹلایا نبی نے دعا کی کہ پروردگار ! ان کے جھٹلانے پر میری مدد کر 1
23,40,قَالَ عَمَّا قَلِیْلٍ لَّیُصْبِحُنَّ نٰدِمِیْنَۚ قَالَ : اس نے فرمایا عَمَّا قَلِيْلٍ : بہت جلد لَّيُصْبِحُنَّ : وہ ضرور رہ جائیں گے نٰدِمِيْنَ : پچھتانے والے جواب ملا کہ یہ تو بہت ہی جلد اپنے کیے پر پچھتانے لگیں گے 1
23,41,فَاَخَذَتْهُمُ الصَّیْحَةُ بِالْحَقِّ فَجَعَلْنٰهُمْ غُثَآءً١ۚ فَبُعْدًا لِّلْقَوْمِ الظّٰلِمِیْنَ فَاَخَذَتْهُمُ : پس انہیں آپکڑا الصَّيْحَةُ : چنگھاڑ بِالْحَقِّ : (وعدہ) حق کے مطابق فَجَعَلْنٰهُمْ : سو ہم نے انہیں کردیا غُثَآءً : خس و خاشاک فَبُعْدًا : دوری (مار) لِّلْقَوْمِ : قوم کے لیے الظّٰلِمِيْنَ : ظالم (جمع) بالآخر عدل کے تقاضے کے مطابق چیخ 1 نے پکڑ لیا اور ہم نے انھیں کوڑا کرکٹ کر ڈالا 2 پس ظالموں کے لئے دوری ہو۔
23,42,ثُمَّ اَنْشَاْنَا مِنْۢ بَعْدِهِمْ قُرُوْنًا اٰخَرِیْنَؕ ثُمَّ : پھر اَنْشَاْنَا : ہم نے پیدا کیں مِنْۢ بَعْدِهِمْ : ان کے بعد قُرُوْنًا : امتیں اٰخَرِيْنَ : دوسری۔ اور ان کے بعد ہم نے اور بھی بہت سی امتیں پیدا کیں 1
23,43,مَا تَسْبِقُ مِنْ اُمَّةٍ اَجَلَهَا وَ مَا یَسْتَاْخِرُوْنَؕ مَا تَسْبِقُ : نہیں سبقت کرتی ہے مِنْ اُمَّةٍ : کوئی امت اَجَلَهَا : اپنی میعاد وَمَا : اور نہ يَسْتَاْخِرُوْنَ : پیچھے رہ جاتی ہے نہ تو کوئی امت اپنے وقت مقرہ سے آگے بڑھی اور نہ پیچھے رہی 1
23,44,ثُمَّ اَرْسَلْنَا رُسُلَنَا تَتْرَا١ؕ كُلَّمَا جَآءَ اُمَّةً رَّسُوْلُهَا كَذَّبُوْهُ فَاَتْبَعْنَا بَعْضَهُمْ بَعْضًا وَّ جَعَلْنٰهُمْ اَحَادِیْثَ١ۚ فَبُعْدًا لِّقَوْمٍ لَّا یُؤْمِنُوْنَ ثُمَّ : پھر اَرْسَلْنَا : ہم نے بھیجے رُسُلَنَا : رسول (جمع) تَتْرَا : پے در پے كُلَّمَا : جب بھی جَآءَ : آیا اُمَّةً : کسی امت میں رَّسُوْلُهَا : اس کا رسول كَذَّبُوْهُ : انہوں نے اسے جھٹلایا فَاَتْبَعْنَا : تو ہم پیچھے لائے بَعْضَهُمْ : ان میں سے ایک بَعْضًا : دوسرے وَّجَعَلْنٰهُمْ : اور انہیں بنادیا ہم نے اَحَادِيْثَ : افسانے فَبُعْدًا : سو دوری (مار) لِّقَوْمٍ : لوگوں کے لیے لَّا يُؤْمِنُوْنَ : جو ایمان نہیں لائے پھر ہم نے لگاتار رسول بھیجے 1 جب جب جس امت کے پاس اس کا رسول آیا اس نے جھٹلایا، پس ہم نے ایک کو دوسرے کے پیچھے لگا دیا 2 اور انھیں افسانہ 3 بنادیا۔ ان لوگوں کو دوری ہے جو ایمان قبول نہیں کرتے۔
23,45,ثُمَّ اَرْسَلْنَا مُوْسٰى وَ اَخَاهُ هٰرُوْنَ١ۙ۬ بِاٰیٰتِنَا وَ سُلْطٰنٍ مُّبِیْنٍۙ ثُمَّ : پھر اَرْسَلْنَا : ہم نے بھیجا مُوْسٰى : موسیٰ وَاَخَاهُ : اور ان کا بھائی هٰرُوْنَ : ہارون بِاٰيٰتِنَا : ساتھ (ہماری) اپنی نشانیاں وَ سُلْطٰنٍ : اور دلائل مُّبِيْنٍ : کھلے پھر ہم نے موسیٰ ؑ کو اور اس کے بھائی ہارون ؑ کو اپنی آیتوں اور کھلی دلیل 1 کے ساتھ بھیجا۔
23,46,اِلٰى فِرْعَوْنَ وَ مَلَاۡئِهٖ فَاسْتَكْبَرُوْا وَ كَانُوْا قَوْمًا عَالِیْنَۚ اِلٰى : طرف فِرْعَوْنَ : فرعون وَمَلَا۟ئِهٖ : اور اس کے سردار فَاسْتَكْبَرُوْا : تو انہوں نے تکبر کیا وَكَانُوْا : اور وہ تھے قَوْمًا : لوگ عَالِيْنَ : سرکش فرعون اور اس کے لشکروں کی طرف، پس انہوں نے تکبر کیا اور تھے ہی وہ سرکش لوگ 1۔
23,47,فَقَالُوْۤا اَنُؤْمِنُ لِبَشَرَیْنِ مِثْلِنَا وَ قَوْمُهُمَا لَنَا عٰبِدُوْنَۚ فَقَالُوْٓا : پس انہوں نے کہا اَنُؤْمِنُ : کیا ہم ایمان لے آئیں لِبَشَرَيْنِ : دو آدمیوں پر مِثْلِنَا : اپنے جیسا وَقَوْمُهُمَا : اور ان کی قوم لَنَا : ہماری عٰبِدُوْنَ : بندگی (خدمت) کرنے والے کہنے لگے کہ کیا ہم اپنے جیسے دو شخصوں پر ایمان لائیں ؟ حالانکہ خود ان کی قوم (بھی) ہمارے ماتحت 1 ہے۔
23,48,فَكَذَّبُوْهُمَا فَكَانُوْا مِنَ الْمُهْلَكِیْنَ فَكَذَّبُوْهُمَا : پس انہوں نے جھٹلایا دونوں کو فَكَانُوْا : تو وہ ہوگئے مِنَ : سے الْمُهْلَكِيْنَ : ہلاک ہونے والے پس انہوں نے دونوں کو جھٹلایا آخر وہ بھی ہلاک شدہ لوگوں میں مل گئے۔
23,49,وَ لَقَدْ اٰتَیْنَا مُوْسَى الْكِتٰبَ لَعَلَّهُمْ یَهْتَدُوْنَ وَلَقَدْ : اور تحقیق اٰتَيْنَا : ہم نے دی مُوْسَى : موسیٰ الْكِتٰبَ : کتب لَعَلَّهُمْ : تاکہ وہ لوگ يَهْتَدُوْنَ : ہدایت پالیں ہم نے موسیٰ ؑ کو کتاب (بھی) دی کہ لوگ راہ راست پر آجائیں 1۔
23,50,وَ جَعَلْنَا ابْنَ مَرْیَمَ وَ اُمَّهٗۤ اٰیَةً وَّ اٰوَیْنٰهُمَاۤ اِلٰى رَبْوَةٍ ذَاتِ قَرَارٍ وَّ مَعِیْنٍ۠    ۧ وَجَعَلْنَا : اور ہم نے بنایا ابْنَ مَرْيَمَ : مریم کے بیٹے (عیسی) کو وَاُمَّهٗٓ : اور ان کی ماں اٰيَةً : ایک نشانی وَّاٰوَيْنٰهُمَآ : اور ہم نے انہیں ٹھکانہ دیا اِلٰى : طرف رَبْوَةٍ : ایک بلند ٹیلہ ذَاتِ قَرَارٍ : ٹھہرنے کا مقام وَّمَعِيْنٍ : اور جاری پانی ہم نے ابن مریم اور اس کی والدہ کو ایک نشانی بنایا 1 اور ان دونوں کو بلند صاف قرار والی اور جاری پانی 2 والی جگہ میں پناہ دی۔
23,51,یٰۤاَیُّهَا الرُّسُلُ كُلُوْا مِنَ الطَّیِّبٰتِ وَ اعْمَلُوْا صَالِحًا١ؕ اِنِّیْ بِمَا تَعْمَلُوْنَ عَلِیْمٌؕ يٰٓاَيُّهَا : اے الرُّسُلُ : رسول (جمع) كُلُوْا : کھاؤ مِنَ : سے الطَّيِّبٰتِ : پاکیزہ چیزیں وَاعْمَلُوْا : اور عمل کرو صَالِحًا : نیک اِنِّىْ : بیشک میں بِمَا : اسے جو تَعْمَلُوْنَ : تم کرتے ہو عَلِيْمٌ : جاننے والا اے پیغمبر ! حلال چیزیں کھاؤ اور نیک عمل کرو 1 تم جو کچھ کر رہے ہو اس سے میں بخوبی واقف ہوں۔
23,52,وَ اِنَّ هٰذِهٖۤ اُمَّتُكُمْ اُمَّةً وَّاحِدَةً وَّ اَنَا رَبُّكُمْ فَاتَّقُوْنِ وَاِنَّ : اور بیشک هٰذِهٖٓ : یہ اُمَّتُكُمْ : تمہاری امت اُمَّةً وَّاحِدَةً : ایک امت، امت واحدہ وَّاَنَا : اور میں رَبُّكُمْ : تمہارا رب فَاتَّقُوْنِ : پس مجھ سے ڈرو یقیناً تمہارا یہ دین ایک ہی دین ہے 1 اور میں ہی تم سب کا رب ہوں، پس تم مجھ سے ڈرتے رہو۔
23,53,فَتَقَطَّعُوْۤا اَمْرَهُمْ بَیْنَهُمْ زُبُرًا١ؕ كُلُّ حِزْبٍۭ بِمَا لَدَیْهِمْ فَرِحُوْنَ فَتَقَطَّعُوْٓا : پھر انہوں نے کاٹ لیا اَمْرَهُمْ : اپنا کام بَيْنَهُمْ : آپس میں زُبُرًا : ٹکڑے ٹکڑے كُلُّ حِزْبٍ : ہر گروہ بِمَا : اس پر جو لَدَيْهِمْ : ان کے پاس فَرِحُوْنَ : خوش پھر انہوں نے خود (ہی) اپنے امر (دین) کے آپس میں ٹکڑے ٹکڑے کر لئے، ہر گروہ جو کچھ اس کے پاس ہے اس پر اترا رہا ہے۔
23,54,فَذَرْهُمْ فِیْ غَمْرَتِهِمْ حَتّٰى حِیْنٍ فَذَرْهُمْ : پس چھوڑ دے انہیں فِيْ غَمْرَتِهِمْ : ان کی غفلت میں حَتّٰى : تک حِيْنٍ : ایک مدت مقررہ پس آپ (بھی) انھیں انکی غفلت میں ہی کچھ مدت پڑا رہنے دیں۔ 2
23,55,اَیَحْسَبُوْنَ اَنَّمَا نُمِدُّهُمْ بِهٖ مِنْ مَّالٍ وَّ بَنِیْنَۙ اَيَحْسَبُوْنَ : کیا وہ گمان کرتے ہیں اَنَّمَا : کہ جو کچھ نُمِدُّهُمْ : ہم مدد کر رہے ہیں ان کی بِهٖ : اس کے ساتھ مِنْ : سے مَّالٍ : مال وَّبَنِيْنَ : اور اولاد کیا یہ (یوں) سمجھ بیٹھے ہیں ؟ کہ ہم جو بھی ان کے مال و اولاد بڑھا رہے ہیں۔
23,56,نُسَارِعُ لَهُمْ فِی الْخَیْرٰتِ١ؕ بَلْ لَّا یَشْعُرُوْنَ نُسَارِعُ : ہم جلدی کر رہے ہیں لَهُمْ : ان کے لیے فِي الْخَيْرٰتِ : بھلائی میں بَلْ : بلکہ لَّا يَشْعُرُوْنَ : وہ شعور (سمجھ) نہیں رکھتے وہ ان کے لئے بھلائیوں میں جلدی کر رہے ہیں (نہیں نہیں) بلکہ یہ سمجھتے ہی نہیں۔
23,57,اِنَّ الَّذِیْنَ هُمْ مِّنْ خَشْیَةِ رَبِّهِمْ مُّشْفِقُوْنَۙ اِنَّ : بیشک الَّذِيْنَ : جو لوگ هُمْ : وہ مِّنْ : سے خَشْيَةِ : ڈر رَبِّهِمْ : اپنا رب مُّشْفِقُوْنَ : ڈرنے والے (سہمے ہوئے) یقیناً جو لوگ اپنے رب کی ہیبت سے ڈرتے ہیں۔
23,58,وَ الَّذِیْنَ هُمْ بِاٰیٰتِ رَبِّهِمْ یُؤْمِنُوْنَۙ وَالَّذِيْنَ : اور جو لوگ هُمْ : وہ بِاٰيٰتِ : آیتوں پر رَبِّهِمْ : اپنا رب يُؤْمِنُوْنَ : ایمان رکھتے ہیں یقیناً جو لوگ اپنے رب کی آیتوں پر ایمان رکھتے ہیں۔
23,59,وَ الَّذِیْنَ هُمْ بِرَبِّهِمْ لَا یُشْرِكُوْنَۙ وَالَّذِيْنَ : اور جو لوگ هُمْ : وہ بِرَبِّهِمْ : اپنے رب کے ساتھ لَا يُشْرِكُوْنَ : شریک نہیں کرتے اور جو اپنے رب کے ساتھ کسی کو شریک نہیں کرتے
23,60,وَ الَّذِیْنَ یُؤْتُوْنَ مَاۤ اٰتَوْا وَّ قُلُوْبُهُمْ وَجِلَةٌ اَنَّهُمْ اِلٰى رَبِّهِمْ رٰجِعُوْنَۙ وَالَّذِيْنَ : اور جو لوگ يُؤْتُوْنَ : دیتے ہیں مَآ اٰتَوْا : جو وہ دیتے ہیں وَّقُلُوْبُهُمْ : اور ان کے دل وَجِلَةٌ : ڈرتے ہیں اَنَّهُمْ : کہ وہ اِلٰى : طرف رَبِّهِمْ : اپنا رب رٰجِعُوْنَ : لوٹنے والے اور جو لوگ دیتے ہیں جو کچھ دیتے ہیں اور ان کے دل کپکپاتے ہیں کہ وہ اپنے رب کی طرف لوٹنے والے ہیں 1۔
23,61,اُولٰٓئِكَ یُسٰرِعُوْنَ فِی الْخَیْرٰتِ وَ هُمْ لَهَا سٰبِقُوْنَ اُولٰٓئِكَ : یہی لوگ يُسٰرِعُوْنَ : جلدی کرتے ہیں فِي الْخَيْرٰتِ : بھلائیوں میں وَهُمْ : اور وہ لَهَا : ان کی طرف سٰبِقُوْنَ : سبقت لے جانیوالے ہیں یہی ہیں جو جلدی جلدی بھلائیاں حاصل کر رہے ہیں اور یہی ہیں جو ان کی طرف دوڑ جانے والے ہیں۔
23,62,وَ لَا نُكَلِّفُ نَفْسًا اِلَّا وُسْعَهَا وَ لَدَیْنَا كِتٰبٌ یَّنْطِقُ بِالْحَقِّ وَ هُمْ لَا یُظْلَمُوْنَ وَلَا نُكَلِّفُ : اور ہم تکلیف نہیں دیتے نَفْسًا : کسی کو اِلَّا : مگر وُسْعَهَا : اس کی طاقت کے مطابق وَلَدَيْنَا : اور ہمارے پاس كِتٰبٌ : ایک کتاب (رجسٹر) يَّنْطِقُ : وہ بتلاتا ہے بِالْحَقِّ : ٹھیک ٹھیک وَهُمْ : اور وہ (ان) لَا يُظْلَمُوْنَ : ظلم نہ کیے جائیں گے (ظلم نہ ہوگا) ہم کسی نفس کو اس کی طاقت سے زیادہ تکلیف نہیں دیتے 1 اور ہمارے پاس ایسی کتاب ہے جو حق کے ساتھ بولتی ہے، ان کے اوپر کچھ بھی ظلم نہ کیا جائے گا۔
23,63,بَلْ قُلُوْبُهُمْ فِیْ غَمْرَةٍ مِّنْ هٰذَا وَ لَهُمْ اَعْمَالٌ مِّنْ دُوْنِ ذٰلِكَ هُمْ لَهَا عٰمِلُوْنَ بَلْ : بلکہ قُلُوْبُهُمْ : ان کے دل فِيْ غَمْرَةٍ : غفلت میں مِّنْ ھٰذَا : اس سے وَلَهُمْ : اور ان کے اَعْمَالٌ : اعمال (جمع) مِّنْ دُوْنِ : علاوہ ذٰلِكَ : اس هُمْ لَهَا : وہ انہیں عٰمِلُوْنَ : کرتے رہتے ہیں بلکہ ان کے دل اس طرف سے غفلت میں ہیں اور ان کے لئے اس کے سوا بھی بہت سے اعمال ہیں 1 جنہیں وہ کرنے والے ہیں۔
23,64,حَتّٰۤى اِذَاۤ اَخَذْنَا مُتْرَفِیْهِمْ بِالْعَذَابِ اِذَا هُمْ یَجْئَرُوْنَؕ حَتّيٰٓ اِذَآ : یہاں تک کہ جب اَخَذْنَا : ہم نے پکڑا مُتْرَفِيْهِمْ : ان کے خوشحال لوگ بِالْعَذَابِ : عذاب میں اِذَا هُمْ : اس وقت وہ يَجْئَرُوْنَ : فریاد کرنے لگے یہاں تک کہ جب ہم نے ان کے آسودہ حال لوگوں کو عذاب میں پکڑ لیا 1 تو بلبلانے لگے۔
23,65,لَا تَجْئَرُوا الْیَوْمَ١۫ اِنَّكُمْ مِّنَّا لَا تُنْصَرُوْنَ لَا تَجْئَرُوا : تم فریاد نہ کرو الْيَوْمَ : آج اِنَّكُمْ : بیشک تم مِّنَّا : ہم سے لَا تُنْصَرُوْنَ : تم مدد نہ دئیے جاؤگے آج مت بلبلاؤ یقیناً تم ہمارے مقابلہ پر مدد نہ کئے جاؤ گے 1۔
23,66,قَدْ كَانَتْ اٰیٰتِیْ تُتْلٰى عَلَیْكُمْ فَكُنْتُمْ عَلٰۤى اَعْقَابِكُمْ تَنْكِصُوْنَۙ قَدْ كَانَتْ : البتہ تھیں اٰيٰتِيْ : میری آیتیں تُتْلٰى : پڑھی جاتی تھیں عَلَيْكُمْ : تم پر فَكُنْتُمْ : تو تم تھے عَلٰٓي اَعْقَابِكُمْ : اپنی ایڑیوں کے بل تَنْكِصُوْنَ : پھرجاتے میری آیتیں تو تمہارے سامنے پڑھی جاتی تھیں 1 پھر بھی تم اپنی ایڑیوں کے بل الٹے بھاگتے تھے 2
23,67,مُسْتَكْبِرِیْنَ١ۖۗ بِهٖ سٰمِرًا تَهْجُرُوْنَ مُسْتَكْبِرِيْنَ : تکبر کرتے ہوئے بِهٖ : اس کے ساتھ سٰمِرًا : افسانہ کوئی کرتے ہوئے تَهْجُرُوْنَ : بیہودہ بکواس کرتے ہوئے اکڑتے اینٹھتے 1 افسانہ گوئی کرتے اسے چھوڑ دیتے تھے 2۔
23,68,اَفَلَمْ یَدَّبَّرُوا الْقَوْلَ اَمْ جَآءَهُمْ مَّا لَمْ یَاْتِ اٰبَآءَهُمُ الْاَوَّلِیْنَ٘ اَفَلَمْ يَدَّبَّرُوا : کیا پس انہوں نے غور نہیں کیا الْقَوْلَ : کلام اَمْ : یا جَآءَهُمْ : ان کے پاس آیا مَّا : جو لَمْ يَاْتِ : نہیں آیا اٰبَآءَهُمُ : ان کے باپ دادا الْاَوَّلِيْنَ : پہلے کیا انہوں نے اس بات میں غور و فکر ہی نہیں کیا 1 بلکہ ان کے پاس وہ آیا جو ان کے اگلے باپ دادوں کے پاس نہیں آیا تھا 2۔
23,69,اَمْ لَمْ یَعْرِفُوْا رَسُوْلَهُمْ فَهُمْ لَهٗ مُنْكِرُوْنَ٘ اَمْ : یا لَمْ يَعْرِفُوْا : انہوں نے نہیں پہچانا رَسُوْلَهُمْ : اپنے رسول فَهُمْ : تو وہ لَهٗ : اس کے مُنْكِرُوْنَ : منکر ہیں یا انہوں نے اپنے پیغمبر کو پہچانا نہیں کہ اس کے منکر ہو رہے ہیں 1۔
23,70,اَمْ یَقُوْلُوْنَ بِهٖ جِنَّةٌ١ؕ بَلْ جَآءَهُمْ بِالْحَقِّ وَ اَكْثَرُهُمْ لِلْحَقِّ كٰرِهُوْنَ اَمْ : یا يَقُوْلُوْنَ : وہ کہتے ہیں بِهٖ : اس کو جِنَّةٌ : دیوانگی بَلْ : بلکہ جَآءَهُمْ : وہ آیا ان کے پاس بِالْحَقِّ : ساتح حق بات وَاَكْثَرُهُمْ : اور ان میں سے اکثر لِلْحَقِّ : حق سے كٰرِهُوْنَ : نفر رکھنے والے یا یہ کہتے ہیں کہ اسے جنون ہے 1 بلکہ وہ تو ان کے پاس حق لایا ہے۔ ہاں ان میں اکثر حق سے چڑنے والے ہیں 2۔
23,71,وَ لَوِ اتَّبَعَ الْحَقُّ اَهْوَآءَهُمْ لَفَسَدَتِ السَّمٰوٰتُ وَ الْاَرْضُ وَ مَنْ فِیْهِنَّ١ؕ بَلْ اَتَیْنٰهُمْ بِذِكْرِهِمْ فَهُمْ عَنْ ذِكْرِهِمْ مُّعْرِضُوْنَؕ وَلَوِ : اور اگر اتَّبَعَ : پیروی کرتا الْحَقُّ : حق (اللہ) اَهْوَآءَهُمْ : ان کی خواہشات لَفَسَدَتِ : البتہ درہم برہم ہوجاتا السَّمٰوٰتُ : آسمان (جمع) وَالْاَرْضُ : اور زمین وَمَنْ : اور جو فِيْهِنَّ : ان کے درمیان بَلْ : بلکہ اَتَيْنٰهُمْ : ہم لائے ہیں ان کے پاس بِذِكْرِهِمْ : ان کی نصیحت فَهُمْ : پھر وہ عَنْ ذِكْرِهِمْ : اپنی نصیحت سے مُّعْرِضُوْنَ : روگردانی کرنے والے ہیں اگر حق ہی ان کی خواہشوں کا پیرو ہوجائے تو زمین و آسمان اور ان کے درمیان کی ہر چیز درہم برہم ہوجائے 1 حق تو یہ ہے کہ ہم نے انھیں ان کی نصیحت پہنچا دی ہے لیکن وہ اپنی نصیحت سے منہ موڑنے والے ہیں۔
23,72,اَمْ تَسْئَلُهُمْ خَرْجًا فَخَرَاجُ رَبِّكَ خَیْرٌ١ۖۗ وَّ هُوَ خَیْرُ الرّٰزِقِیْنَ اَمْ تَسْئَلُهُمْ : کیا تم ان سے مانگتے ہو خَرْجًا : اجر فَخَرَاجُ : تو اجر رَبِّكَ : تمہارا رب خَيْرٌ : بہتر وَّهُوَ : اور وہ خَيْرُ الرّٰزِقِيْنَ : بہترین روزی دہندہ ہے کیا آپ ان سے کوئی اجرت چاہتے ہیں ؟ یاد رکھئے کہ آپ کے رب کی اجرت بہت ہی بہتر ہے اور وہ سب سے بہتر روزی رساں ہے۔
23,73,وَ اِنَّكَ لَتَدْعُوْهُمْ اِلٰى صِرَاطٍ مُّسْتَقِیْمٍ وَاِنَّكَ : اور بیشک تم لَتَدْعُوْهُمْ : انہیں بلاتے ہو اِلٰى : طرف صِرَاطٍ : راہ راستہ مُّسْتَقِيْمٍ : سیدھا۔ راستہ یقیناً آپ انھیں راہ راست کی طرف بلا رہے ہیں۔
23,74,وَ اِنَّ الَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ عَنِ الصِّرَاطِ لَنٰكِبُوْنَ وَاِنَّ : اور بیشک الَّذِيْنَ : جو لوگ لَا يُؤْمِنُوْنَ : ایمان نہیں لاتے بِالْاٰخِرَةِ : آخرت پر عَنِ : سے الصِّرَاطِ : راہ (حق) لَنٰكِبُوْنَ : البتہ ہٹے ہوئے ہیں بیشک جو لوگ آخرت پر یقین نہیں رکھتے وہ سیدھے راستے سے مڑ جانے والے ہیں 1۔
23,75,وَ لَوْ رَحِمْنٰهُمْ وَ كَشَفْنَا مَا بِهِمْ مِّنْ ضُرٍّ لَّلَجُّوْا فِیْ طُغْیَانِهِمْ یَعْمَهُوْنَ وَلَوْ : اور اگر رَحِمْنٰهُمْ : ہم ان پر رحم کریں وَكَشَفْنَا : اور ہم دور کردیں مَا بِهِمْ : جو ان پر مِّنْ ضُرٍّ : جو تکلیف لَّلَجُّوْا : ارے رہیں فِيْ : میں۔ پر طُغْيَانِهِمْ : اپنی سرکشی يَعْمَهُوْنَ : بھٹکتے رہیں اور اگر ہم ان پر رحم فرمائیں اور ان کی تکلیفیں دور کردیں تو یہ تو اپنی اپنی سرکشی میں جم کر اور بہکنے لگیں 1
23,76,وَ لَقَدْ اَخَذْنٰهُمْ بِالْعَذَابِ فَمَا اسْتَكَانُوْا لِرَبِّهِمْ وَ مَا یَتَضَرَّعُوْنَ وَ : اور لَقَدْ اَخَذْنٰهُمْ : البتہ ہم نے انہیں پکڑا بِالْعَذَابِ : عذاب فَمَا اسْتَكَانُوْا : پھر انہوں نے عاجزی نہ کی لِرَبِّهِمْ : اپنے رب کے سامنے وَمَا يَتَضَرَّعُوْنَ : اور وہ نہ گڑگڑائے اور ہم نے انھیں عذاب میں پکڑا تاہم یہ لوگ نہ تو اپنے پروردگار کے سامنے جھکے اور نہ ہی عاجزی اختیار کی 1۔
23,77,حَتّٰۤى اِذَا فَتَحْنَا عَلَیْهِمْ بَابًا ذَا عَذَابٍ شَدِیْدٍ اِذَا هُمْ فِیْهِ مُبْلِسُوْنَ۠    ۧ حَتّٰٓي : یہاں تک کہ اِذَا : جب فَتَحْنَا : ہم نے کھول دئیے عَلَيْهِمْ : ان پر بَابًا : دروازے ذَا عَذَابٍ : عذاب والا شَدِيْدٍ : سخت اِذَا هُمْ : تو اس وقت وہ فِيْهِ : اس میں مُبْلِسُوْنَ : مایوس ہوئے یہاں تک کہ جب ہم نے ان پر سخت عذاب کا دروازہ کھول دیا تو اسی وقت فوراً مایوس ہوگئے 1
23,78,وَ هُوَ الَّذِیْۤ اَنْشَاَ لَكُمُ السَّمْعَ وَ الْاَبْصَارَ وَ الْاَفْئِدَةَ١ؕ قَلِیْلًا مَّا تَشْكُرُوْنَ وَهُوَ : اور وہ الَّذِيْٓ : وہی جس نے اَنْشَاَ لَكُمُ : بنائے تمہارے لیے السَّمْعَ : کان وَالْاَبْصَارَ : اور آنکھیں وَالْاَفْئِدَةَ : اور دل (جمع) قَلِيْلًا : بہت ہی کم مَّا تَشْكُرُوْنَ : جو تم شکر کرتے ہو وہ اللہ ہے جس نے تمہارے لئے کان اور آنکھیں اور دل پیدا کئے، مگر تم بہت (ہی) کم شکر کرتے ہو 1
23,79,وَ هُوَ الَّذِیْ ذَرَاَكُمْ فِی الْاَرْضِ وَ اِلَیْهِ تُحْشَرُوْنَ وَهُوَ : اور وہ الَّذِيْ : وہی جس نے ذَرَاَكُمْ : پھیلایا تمہیں فِي الْاَرْضِ : زمین میں وَاِلَيْهِ : اور اس کی طرف تُحْشَرُوْنَ : تم جمع ہو کر جاؤ گے اور وہی ہے جس نے تمہیں پیدا کرکے زمین میں پھیلا دیا اور اسی کی طرف جمع کئے جاؤ گے 1۔
23,80,وَ هُوَ الَّذِیْ یُحْیٖ وَ یُمِیْتُ وَ لَهُ اخْتِلَافُ الَّیْلِ وَ النَّهَارِ١ؕ اَفَلَا تَعْقِلُوْنَ وَهُوَ : اور وہ الَّذِيْ : وہی جو يُحْيٖ : زندہ کرتا ہے وَيُمِيْتُ : اور مارتا ہے وَ لَهُ : اور اسی کے لیے اخْتِلَافُ : آنا جانا الَّيْلِ : رات وَالنَّهَارِ : اور دن اَفَلَا تَعْقِلُوْنَ : کیا پس تم سمجھتے نہیں اور وہی ہے جو جلاتا ہے اور مارتا ہے اور رات دن کے ردو بدل 1 کا مختار بھی وہی ہے۔ کیا تم کو سمجھ بوجھ نہیں 2
23,81,بَلْ قَالُوْا مِثْلَ مَا قَالَ الْاَوَّلُوْنَ بَلْ قَالُوْا : بلکہ انہوں نے کہا مِثْلَ : جیسے مَا قَالَ : جو کہا الْاَوَّلُوْنَ : پہلوں نے بلکہ ان لوگوں نے بھی ویسی ہی بات کہی جو اگلے کہتے چلے آئے
23,82,قَالُوْۤا ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَبْعُوْثُوْنَ قَالُوْٓا : وہ بولے ءَاِذَا : کیا جب مِتْنَا : ہم مرگئے وَكُنَّا تُرَابًا : اور ہم ہوگئے مٹی وَّعِظَامًا : اور ہڈیاں ءَ اِنَّا : کیا ہم لَمَبْعُوْثُوْنَ : پھر اٹھائے جائیں گے کہ کیا جب ہم مر کر مٹی اور ہڈی ہوجائیں گے کیا پھر بھی ہم ضرور اٹھائے جائیں گے۔
23,83,لَقَدْ وُعِدْنَا نَحْنُ وَ اٰبَآؤُنَا هٰذَا مِنْ قَبْلُ اِنْ هٰذَاۤ اِلَّاۤ اَسَاطِیْرُ الْاَوَّلِیْنَ لَقَدْ وُعِدْنَا : البتہ ہم سے وعدہ کیا گیا نَحْنُ : ہم وَاٰبَآؤُنَا : اور ہمارے باپ دادا ھٰذَا : یہ مِنْ قَبْلُ : اس سے قبل اِنْ ھٰذَآ : یہ نہیں اِلَّآ : مگر (صرف) اَسَاطِيْرُ : کہانیاں الْاَوَّلِيْنَ : پہلے لوگ ہم سے ہمارے باپ دادوں سے پہلے ہی سے یہ وعدہ ہوتا چلا آیا ہے کچھ نہیں یہ صرف اگلے لوگوں کے افسانے ہیں۔
23,84,قُلْ لِّمَنِ الْاَرْضُ وَ مَنْ فِیْهَاۤ اِنْ كُنْتُمْ تَعْلَمُوْنَ قُلْ : فرما دیں لِّمَنِ : کسی کے لیے الْاَرْضُ : زمین وَمَنْ : اور جو فِيْهَآ : اس میں اِنْ : اگر كُنْتُمْ تَعْلَمُوْنَ : تم جانتے ہو پوچھیے تو سہی کہ زمین اور اس کی کل چیزیں کس کی ہیں ؟ بتلاؤ اگر جانتے ہو۔
23,85,سَیَقُوْلُوْنَ لِلّٰهِ١ؕ قُلْ اَفَلَا تَذَكَّرُوْنَ سَيَقُوْلُوْنَ : جلدی (ضرور) وہ کہیں گے لِلّٰهِ : اللہ کے لیے قُلْ : فرمادیں اَفَلَا تَذَكَّرُوْنَ : کیا پس تم غور نہیں کرتے فوراً جواب دیں گے کہ اللہ کی، کہہ دیجئے کہ پھر تم نصیحت کیوں نہیں حاصل کرتے۔
23,86,قُلْ مَنْ رَّبُّ السَّمٰوٰتِ السَّبْعِ وَ رَبُّ الْعَرْشِ الْعَظِیْمِ قُلْ : فرما دیں مَنْ : کون رَّبُّ : رب السَّمٰوٰتِ : آسمان (جمع) السَّبْعِ : سات وَرَبُّ : اور رب الْعَرْشِ الْعَظِيْمِ : عرش عظیم دریافت کیجئے کہ ساتوں آسمانوں کا اور بہت با عظمت عرش کا رب کون ہے ؟
23,87,سَیَقُوْلُوْنَ لِلّٰهِ١ؕ قُلْ اَفَلَا تَتَّقُوْنَ سَيَقُوْلُوْنَ : جلد (ضرو) وہ کہیں گے لِلّٰهِ : اللہ کا قُلْ : فرما دیں اَفَلَا تَتَّقُوْنَ : کیا پس تم نہیں ڈرتے وہ لوگ جواب دیں گے کہ اللہ ہی ہے۔ کہہ دیجئے کہ پھر تم کیوں نہیں ڈرتے 1۔
23,88,قُلْ مَنْۢ بِیَدِهٖ مَلَكُوْتُ كُلِّ شَیْءٍ وَّ هُوَ یُجِیْرُ وَ لَا یُجَارُ عَلَیْهِ اِنْ كُنْتُمْ تَعْلَمُوْنَ قُلْ : فرما دیں مَنْ : کون بِيَدِهٖ : اس کے ہاتھ میں مَلَكُوْتُ : بادشاہت (اختیار) كُلِّ شَيْءٍ : ہر چیز وَّهُوَ : اور وہ يُجِيْرُ : پناہ دیتا ہے وَلَا يُجَارُ : اور پناہ نہیں دیا جاتا عَلَيْهِ : اس کے خلاف اِنْ : اگر كُنْتُمْ تَعْلَمُوْنَ : تم جانتے ہو پوچھئے کہ تمام چیزوں کا اختیار کس کے ہاتھ میں ہے ؟ جو پناہ دیتا ہے 1 اور جس کے مقابلے میں کوئی پناہ نہیں دیا جاتا 2 اگر تم جانتے ہو تو بتلاؤ ؟
23,89,سَیَقُوْلُوْنَ لِلّٰهِ١ؕ قُلْ فَاَنّٰى تُسْحَرُوْنَ سَيَقُوْلُوْنَ : جلد (ضرور) وہ کہیں گے لِلّٰهِ : اللہ کے لیے قُلْ : فرما دیں فَاَنّٰى : پھر کہاں سے تُسْحَرُوْنَ : تم جادو میں پھنس گئے ہو یہی جواب دیں گے کہ اللہ ہی ہے۔ کہہ دیجئے پھر تم کدھر جادو کردیئے جاتے ہو 1
23,90,بَلْ اَتَیْنٰهُمْ بِالْحَقِّ وَ اِنَّهُمْ لَكٰذِبُوْنَ بَلْ : بلکہ اَتَيْنٰهُمْ : ہم لائے ہیں ان کے پاس بِالْحَقِّ : سچی بات وَاِنَّهُمْ : اور بیشک وہ لَكٰذِبُوْنَ : البتہ جھوٹے ہیں حق یہ ہے کہ ہم نے انھیں حق پہنچا دیا ہے اور یہ بیشک جھوٹے ہیں۔
23,91,مَا اتَّخَذَ اللّٰهُ مِنْ وَّلَدٍ وَّ مَا كَانَ مَعَهٗ مِنْ اِلٰهٍ اِذًا لَّذَهَبَ كُلُّ اِلٰهٍۭ بِمَا خَلَقَ وَ لَعَلَا بَعْضُهُمْ عَلٰى بَعْضٍ١ؕ سُبْحٰنَ اللّٰهِ عَمَّا یَصِفُوْنَۙ مَا اتَّخَذَ : نہیں بنایا اللّٰهُ : اللہ مِنْ وَّلَدٍ : کسی کو بیٹا وَّمَا كَانَ : اور نہیں ہے مَعَهٗ : اس کے ساتھ مِنْ اِلٰهٍ : کوئی اور معبود اِذًا : اس صورت میں لَّذَهَبَ : لے جاتا كُلُّ : ہر اِلٰهٍ : معبود بِمَا خَلَقَ : جو اس نے پیدا کیا وَلَعَلَا : اور چڑھائی کرتا بَعْضُهُمْ : ان کا ایک عَلٰي بَعْضٍ : دوسرے پر سُبْحٰنَ اللّٰهِ : پاک ہے اللہ عَمَّا : اس سے جو يَصِفُوْنَ : وہ بیان کرتے ہیں نہ تو اللہ نے کسی کو بیٹا بنایا اور نہ اس کے ساتھ اور کوئی معبود ہے، ورنہ ہر معبود اپنی مخلوق کو لئے لئے پھرتا اور ہر ایک دوسرے پر چڑھ دوڑتا جو اوصاف یہ بتلاتے ہیں ان سے اللہ پاک (اور بےنیاز) ہے۔
23,92,عٰلِمِ الْغَیْبِ وَ الشَّهَادَةِ فَتَعٰلٰى عَمَّا یُشْرِكُوْنَ۠    ۧ عٰلِمِ الْغَيْبِ : جاننے والا پوشیدہ وَالشَّهَادَةِ : اور آشکارا فَتَعٰلٰى : پس برتر عَمَّا : اس سے جو يُشْرِكُوْنَ : وہ شریک سمجھتے ہیں وہ غائب حاضر کا جاننے والا ہے اور جو شرک یہ کرتے ہیں اس سے بالا تر ہے۔
23,93,قُلْ رَّبِّ اِمَّا تُرِیَنِّیْ مَا یُوْعَدُوْنَۙ قُلْ : فرما دیں رَّبِّ : اے میرے رب اِمَّا تُرِيَنِّيْ : اگر تو مجھے دکھا دے مَا يُوْعَدُوْنَ : جو ان سے وعدہ کیا جاتا ہے آپ دعا کریں کہ اے میرے پروردگار ! اگر تو مجھے وہ دکھائے جس کا وعدہ انھیں دیا جا رہا ہے۔
23,94,رَبِّ فَلَا تَجْعَلْنِیْ فِی الْقَوْمِ الظّٰلِمِیْنَ رَبِّ : اے میرے رب فَلَا تَجْعَلْنِيْ : پس تو مجھے نہ کرنا فِي : میں الْقَوْمِ الظّٰلِمِيْنَ : ظالم لوگ تو اے رب ! تو مجھے ان ظالموں کے گروہ میں نہ کرنا 1
23,95,وَ اِنَّا عَلٰۤى اَنْ نُّرِیَكَ مَا نَعِدُهُمْ لَقٰدِرُوْنَ وَاِنَّا : اور بیشک ہم عَلٰٓي : پر اَنْ نُّرِيَكَ : کہ ہم تمہیں دکھا دیں مَا نَعِدُهُمْ : جو ہم وعدہ کر رہے ہیں ان سے لَقٰدِرُوْنَ : البتہ قادر ہیں ہم جو کچھ وعدے انھیں دے رہے ہیں سب آپ کو دکھا دینے پر یقیناً قادر ہیں۔
23,96,اِدْفَعْ بِالَّتِیْ هِیَ اَحْسَنُ السَّیِّئَةَ١ؕ نَحْنُ اَعْلَمُ بِمَا یَصِفُوْنَ اِدْفَعْ : دفع کرو بِالَّتِيْ : اس سے جو هِىَ : وہ اَحْسَنُ : سب سے اچھی بھلائی السَّيِّئَةَ : برائی نَحْنُ : ہم اَعْلَمُ : خوب جانتے ہیں بِمَا : اس کو جو يَصِفُوْنَ : وہ بیان کرتے ہیں برائی کو اس طریقے سے دور کریں جو سراسر بھلائی والا ہو، 1 جو کچھ بیان کرتے ہیں ہم بخوبی واقف ہیں۔
23,97,وَ قُلْ رَّبِّ اَعُوْذُ بِكَ مِنْ هَمَزٰتِ الشَّیٰطِیْنِۙ وَقُلْ : اور آپ فرما دیں رَّبِّ : اے میرے رب اَعُوْذُ : میں پناہ چاہتا ہوں بِكَ : تیری مِنْ : سے هَمَزٰتِ : وسوسے (جمع) الشَّيٰطِيْنِ : شیطان (جمع) اور دعا کریں کہ اے میرے پروردگار ! میں شیطانوں کے وسوسوں سے تیری پناہ چاہتا ہوں 1۔
23,98,وَ اَعُوْذُ بِكَ رَبِّ اَنْ یَّحْضُرُوْنِ وَاَعُوْذُ : اور میں پناہ چاہتا ہوں بِكَ : تیری رَبِّ : اے میری رب اَنْ يَّحْضُرُوْنِ : کہ وہ آئیں میرے پاس اور اے میرے رب ! میں تیری پناہ چاہتا ہوں کہ وہ میرے پاس آجائیں 1
23,99,حَتّٰۤى اِذَا جَآءَ اَحَدَهُمُ الْمَوْتُ قَالَ رَبِّ ارْجِعُوْنِۙ حَتّيٰٓ : یہانتک کہ اِذَا جَآءَ : جب آئے اَحَدَهُمُ : ان میں کسی کو الْمَوْتُ : موت قَالَ : کہتا ہے رَبِّ : اے میرے رب ارْجِعُوْنِ : مجھے واپس بھیج دے یہاں تک کہ جب ان میں سے کسی کو موت آنے لگتی ہے تو کہتا ہے اے میرے پروردگار ! مجھے واپس لوٹا دے۔
23,100,لَعَلِّیْۤ اَعْمَلُ صَالِحًا فِیْمَا تَرَكْتُ كَلَّا١ؕ اِنَّهَا كَلِمَةٌ هُوَ قَآئِلُهَا١ؕ وَ مِنْ وَّرَآئِهِمْ بَرْزَخٌ اِلٰى یَوْمِ یُبْعَثُوْنَ لَعَلِّيْٓ : شاید میں اَعْمَلُ : کام کرلوں صَالِحًا : کوئی اچھا کام فِيْمَا : اس میں تَرَكْتُ : میں چھوڑ آیا ہوں كَلَّا : ہرگز نہیں اِنَّهَا : یہ تو كَلِمَةٌ : ایک بات هُوَ : وہ قَآئِلُهَا : کہہ رہا ہے وَ : اور مِنْ وَّرَآئِهِمْ : ان کے آگے بَرْزَخٌ : ایک برزخ اِلٰى يَوْمِ : اس دن تک يُبْعَثُوْنَ : وہ اٹھائے جائیں گے کہ اپنی چھوڑی ہوئی دنیا میں جاکر نیک اعمال کرلوں 1 ہرگز ایسا نہیں ہوگا 2 یہ تو صرف ایک قول ہے جس کا یہ قائل ہے 3 ان کے پس پشت تو ایک حجاب ہے، ان کے دوبارہ جی اٹھنے کے دن تک 4۔
23,101,فَاِذَا نُفِخَ فِی الصُّوْرِ فَلَاۤ اَنْسَابَ بَیْنَهُمْ یَوْمَئِذٍ وَّ لَا یَتَسَآءَلُوْنَ فَاِذَا : پھر جب نُفِخَ : پھونکا جائے گا فِي الصُّوْرِ : صور میں فَلَآ اَنْسَابَ : تو نہ رشتے بَيْنَهُمْ : ان کے درمیان يَوْمَئِذٍ : اس دن وَّلَا يَتَسَآءَلُوْنَ : اور نہ وہ ایک دوسرے کو پوچھیں گے پس جب صور پھونک دیا جائیگا اس دن نہ تو آپس کے رشتے ہی رہیں گے، نہ آپس کی پوچھ گچھ 1
23,102,فَمَنْ ثَقُلَتْ مَوَازِیْنُهٗ فَاُولٰٓئِكَ هُمُ الْمُفْلِحُوْنَ فَمَنْ : پس جو۔ جس ثَقُلَتْ : بھاری ہوئی مَوَازِيْنُهٗ : اس کا تول (پلہ) فَاُولٰٓئِكَ : پس وہ لوگ هُمُ : وہ الْمُفْلِحُوْنَ : فلاح پانے والے جن کی ترازو کا پلہ بھاری ہوگیا وہ تو نجات والے ہوگئے۔
23,103,وَ مَنْ خَفَّتْ مَوَازِیْنُهٗ فَاُولٰٓئِكَ الَّذِیْنَ خَسِرُوْۤا اَنْفُسَهُمْ فِیْ جَهَنَّمَ خٰلِدُوْنَۚ وَمَنْ : اور جو۔ جس خَفَّتْ : ہلکی ہوئی مَوَازِيْنُهٗ : اس کے تول (پلہ) فَاُولٰٓئِكَ : تو وہی لوگ الَّذِيْنَ : وہ جنہوں نے خَسِرُوْٓا : خسارہ میں ڈالا اَنْفُسَهُمْ : اپنی جانیں فِيْ جَهَنَّمَ : جہنم میں خٰلِدُوْنَ : ہمیشہ رہیں گے اور جن کے ترازو کا پلہ ہلکا ہوگیا یہ ہیں وہ جنہوں نے اپنا نقصان آپ کرلیا جو ہمیشہ جہنم واصل ہوئے۔
23,104,تَلْفَحُ وُجُوْهَهُمُ النَّارُ وَ هُمْ فِیْهَا كٰلِحُوْنَ تَلْفَحُ : جھلس دے گی وُجُوْهَهُمُ : ان کے چہرے النَّارُ : آگ وَهُمْ : اور وہ فِيْهَا : اس میں كٰلِحُوْنَ : تیوری چڑھائے ہوئے ان کے چہروں کو آگ جھلستی رہے گی 1 اور وہ وہاں بد شکل بنے ہوئے ہونگے 2۔
23,105,اَلَمْ تَكُنْ اٰیٰتِیْ تُتْلٰى عَلَیْكُمْ فَكُنْتُمْ بِهَا تُكَذِّبُوْنَ اَلَمْ تَكُنْ : کیا نہ تھیں اٰيٰتِيْ : میری آیتیں تُتْلٰى : پڑھی جاتیں عَلَيْكُمْ : تم پر فَكُنْتُمْ : پس تم تھے بِهَا : انہیں تُكَذِّبُوْنَ : تم جھٹلاتے تھے کیا میری آیتیں تمہارے سامنے تلاوت نہیں کی جاتی تھیں ؟ پھر بھی تم انھیں جھٹلاتے تھے۔
23,106,قَالُوْا رَبَّنَا غَلَبَتْ عَلَیْنَا شِقْوَتُنَا وَ كُنَّا قَوْمًا ضَآلِّیْنَ قَالُوْا : وہ کہیں گے رَبَّنَا : اے ہمارے رب غَلَبَتْ : غالب آگئی عَلَيْنَا : ہم پر شِقْوَتُنَا : ہماری بدبختی وَكُنَّا : اور ہم تھے قَوْمًا : لوگ ضَآلِّيْنَ : راستہ سے بھٹکے ہوئے کہیں گے کہ اے پروردگار ! ہماری بدبختی ہم پر غالب آگئی (واقعی) ہم تھے ہی گمراہ۔
23,107,رَبَّنَاۤ اَخْرِجْنَا مِنْهَا فَاِنْ عُدْنَا فَاِنَّا ظٰلِمُوْنَ رَبَّنَآ : اے ہمارے رب اَخْرِجْنَا : ہمیں نکال لے مِنْهَا : اس سے فَاِنْ : پھر اگر عُدْنَا : دوبارہ کیا ہم نے فَاِنَّا : تو بیشک ہم ظٰلِمُوْنَ : ظالم (جمع) اے پروردگار ! ہمیں یہاں سے نجات دے اگر اب بھی ہم ایسا ہی کریں تو بیشک ہم ظالم ہیں۔
23,108,قَالَ اخْسَئُوْا فِیْهَا وَ لَا تُكَلِّمُوْنِ قَالَ : فرمائے گا اخْسَئُوْا : پھٹکارے ہوئے پڑے رہو فِيْهَا : اس میں وَلَا تُكَلِّمُوْنِ : اور کلام نہ کرو مجھ سے اللہ تعالیٰ فرمائے گا پھٹکارے ہوئے یہیں پڑے رہو اور مجھ سے کلام نہ کرو۔
23,109,اِنَّهٗ كَانَ فَرِیْقٌ مِّنْ عِبَادِیْ یَقُوْلُوْنَ رَبَّنَاۤ اٰمَنَّا فَاغْفِرْ لَنَا وَ ارْحَمْنَا وَ اَنْتَ خَیْرُ الرّٰحِمِیْنَۚۖ اِنَّهٗ : بیشک وہ كَانَ : تھا فَرِيْقٌ : ایک گروہ مِّنْ عِبَادِيْ : میرے بندوں کا يَقُوْلُوْنَ : وہ کہتے تھے رَبَّنَآ : اے ہمارے رب اٰمَنَّا : ہم ایمان لائے فَاغْفِرْ لَنَا : سو ہمیں بخشدے وَارْحَمْنَا : اور ہم پر رحم فرما وَاَنْتَ : اور تو خَيْرُ : بہترین الرّٰحِمِيْنَ : رحم کرنے والے میرے بندوں کی ایک جماعت تھی جو برابر یہی کہتی رہی کہ اے ہمارے پروردگار ! ہم ایمان لا چکے ہیں تو ہمیں بخش اور ہم پر رحم فرما تو سب مہربانوں سے زیادہ مہربان ہے۔
23,110,فَاتَّخَذْتُمُوْهُمْ سِخْرِیًّا حَتّٰۤى اَنْسَوْكُمْ ذِكْرِیْ وَ كُنْتُمْ مِّنْهُمْ تَضْحَكُوْنَ فَاتَّخَذْتُمُوْهُمْ : پس تم نے انہیں بنا لیا سِخْرِيًّا : ٹھٹھا ﱑ : یہاں تک کہ اَنْسَوْكُمْ : انہوں نے بھلا دیا تمہیں ذِكْرِيْ : میری یاد وَكُنْتُمْ : اور تم تھے مِّنْهُمْ : ان سے تَضْحَكُوْنَ : ہنسی کیا کرتے تھے (لیکن) تم انھیں مذاق ہی اڑاتے رہے یہاں تک کہ (اس مشغلے نے) تم کو میری یاد (بھی) بھلا دی اور تم ان سے مذاق کرتے رہے۔
23,111,اِنِّیْ جَزَیْتُهُمُ الْیَوْمَ بِمَا صَبَرُوْۤا١ۙ اَنَّهُمْ هُمُ الْفَآئِزُوْنَ اِنِّىْ : بیشک میں جَزَيْتُهُمُ : میں نے جزا دی انہیں الْيَوْمَ : آج بِمَا : اس کے بدلے صَبَرُوْٓا : انہوں نے صبر کیا اَنَّهُمْ : بیشک وہ هُمُ : وہی الْفَآئِزُوْنَ : مراد کو پہنچنے والے میں نے آج انھیں ان کے اس صبر کا بدلہ دے دیا ہے کہ وہ خاطر خواہ اپنی مراد کو پہنچ چکے ہیں۔ 1
23,112,قٰلَ كَمْ لَبِثْتُمْ فِی الْاَرْضِ عَدَدَ سِنِیْنَ قٰلَ : فرمائے گا كَمْ لَبِثْتُمْ : کتنی مدت رہے تم فِي الْاَرْضِ : زمین (دنیا) میں عَدَدَ : شمار (حساب) سِنِيْنَ : سال (جمع) اللہ تعالیٰ دریافت فرمائے گا کہ زمین میں باعتبار برسوں کی گنتی کے کس قدر رہے ؟
23,113,قَالُوْا لَبِثْنَا یَوْمًا اَوْ بَعْضَ یَوْمٍ فَسْئَلِ الْعَآدِّیْنَ قَالُوْا : وہ کہیں گے لَبِثْنَا : ہم رہے يَوْمًا : ایک دن اَوْ : یا بَعْضَ يَوْمٍ : ایک دن کا کچھ حصہ فَسْئَلِ : پس پوچھ لے الْعَآدِّيْنَ : شمار کرنے والے وہ کہیں گے ایک دن یا ایک دن سے بھی کم، گنتی گننے والوں سے بھی پوچھ لیجئے 1
23,114,قٰلَ اِنْ لَّبِثْتُمْ اِلَّا قَلِیْلًا لَّوْ اَنَّكُمْ كُنْتُمْ تَعْلَمُوْنَ قٰلَ : فرمائے گا اِنْ لَّبِثْتُمْ : نہیں تم رہے اِلَّا : مگر (صرف) قَلِيْلًا : تھوڑا (عرصہ) لَّوْ : کاش اَنَّكُمْ : کہ تم كُنْتُمْ تَعْلَمُوْنَ : جانتے ہوئے اللہ تعالیٰ فرمائے گا فی الواقع تم وہاں بہت ہی کم رہے ہو اے کاش ! تم اسے پہلے ہی جان لیتے ؟ 1
23,115,اَفَحَسِبْتُمْ اَنَّمَا خَلَقْنٰكُمْ عَبَثًا وَّ اَنَّكُمْ اِلَیْنَا لَا تُرْجَعُوْنَ اَفَحَسِبْتُمْ : کیا تم خیال کرتے ہو اَنَّمَا : کہ خَلَقْنٰكُمْ : ہم نے تمہیں پیدا کیا عَبَثًا : عبث (بیکار) وَّاَنَّكُمْ : اور یہ کہ تم اِلَيْنَا : ہماری طرف لَا تُرْجَعُوْنَ : نہیں لوٹائے جاؤگے کیا تم یہ گمان کئے ہوئے ہو کہ ہم نے تمہیں یونہی بیکار پیدا کیا ہے اور یہ کہ تم ہماری طرف لوٹائے ہی نہ جاؤ گے۔
23,116,فَتَعٰلَى اللّٰهُ الْمَلِكُ الْحَقُّ١ۚ لَاۤ اِلٰهَ اِلَّا هُوَ١ۚ رَبُّ الْعَرْشِ الْكَرِیْمِ فَتَعٰلَى : پس بلند تر اللّٰهُ : اللہ الْمَلِكُ : بادشاہ الْحَقُّ : حقیقی لَآ : نہیں اِلٰهَ : کوئی معبود اِلَّا هُوَ : اس کے سوا رَبُّ : مالک الْعَرْشِ الْكَرِيْمِ : عزت والا عرش اللہ تعالیٰ سچا بادشاہ ہے وہ بڑی بلندی والا ہے 1 اس کے سوا کوئی معبود نہیں، وہی بزرگ عرش کا مالک ہے 2
23,117,وَ مَنْ یَّدْعُ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ١ۙ لَا بُرْهَانَ لَهٗ بِهٖ١ۙ فَاِنَّمَا حِسَابُهٗ عِنْدَ رَبِّهٖ١ؕ اِنَّهٗ لَا یُفْلِحُ الْكٰفِرُوْنَ وَ : اور مَنْ يَّدْعُ : جو پکارے مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا اٰخَرَ : کوئی اور معبود لَا بُرْهَانَ : نہیں کوئی سند لَهٗ : اس کے پاس بِهٖ : اس کے لیے فَاِنَّمَا : سو، تحقیق حِسَابُهٗ : اس کا حساب عِنْدَ رَبِّهٖ : اس کے رب کے پاس اِنَّهٗ : بیشک وہ لَا يُفْلِحُ : فلاح (کامیابی) نہیں پائینگے الْكٰفِرُوْنَ : کافر (جمع) جو شخص اللہ کے ساتھ کسی دوسرے معبود کو پکارے جس کی کوئی دلیل اس کے پاس نہیں، پس اس کا حساب تو اس کے رب کے اوپر ہی ہے۔ بیشک کافر لوگ نجات سے محروم ہیں 1۔
23,118,وَ قُلْ رَّبِّ اغْفِرْ وَ ارْحَمْ وَ اَنْتَ خَیْرُ الرّٰحِمِیْنَ۠    ۧ وَقُلْ : اور آپ کہیں رَّبِّ : اے میرے رب اغْفِرْ : بخش دے وَارْحَمْ : اور رحم فرما وَاَنْتَ : اور تو خَيْرُ الرّٰحِمِيْنَ : بہترین رحم کرنے والا ہے اور کہو کہ اے میرے رب ! تو بخش اور رحم کر اور تو سب مہربانوں سے بہتر مہربانی کرنے والا ہے۔
