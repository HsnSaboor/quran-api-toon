quran[17]{c,v,t}:
86,1,وَ السَّمَآءِ وَ الطَّارِقِۙ وَالسَّمَآءِ : قسم آسمان کی وَالطَّارِقِ : اور رات کو آنے والے کی قسم ہے آسمان کی اور اندھیرے میں روشن ہونے والے کی۔
86,2,وَ مَاۤ اَدْرٰىكَ مَا الطَّارِقُۙ وَمَآ اَدْرٰىكَ : اور تم نے کیا سمجھا مَا : کیا ہے الطَّارِقُ : طارق تجھے معلوم بھی ہے کہ وہ رات کو نمودار ہونے والی چیز کیا ہے ؟
86,3,النَّجْمُ الثَّاقِبُۙ النَّجْمُ : ستارا الثَّاقِبُ : چمکتا ہوا وہ روشن ستارہ ہے (1)
86,4,اِنْ كُلُّ نَفْسٍ لَّمَّا عَلَیْهَا حَافِظٌؕ اِنْ : نہیں كُلُّ نَفْسٍ : کوئی جان لَّمَّا : مگر عَلَيْهَا حَافِظٌ : اس پر نگہبان کوئی ایسا نہیں جس پر نہگبان فرشتہ نہ ہو (1)
86,5,فَلْیَنْظُرِ الْاِنْسَانُ مِمَّ خُلِقَؕ فَلْيَنْظُرِ : چاہیے کہ دیکھے الْاِنْسَانُ : انسان مِمَّ : کس چیز سے خُلِقَ : پیدا کیا گیا انسان کو دیکھنا چاہیے کہ وہ کس چیز سے پیدا کیا گیا ہے۔ (1)
86,6,خُلِقَ مِنْ مَّآءٍ دَافِقٍۙ خُلِقَ : پیدا کیا گیا مِنْ : سے مَّآءٍ : پانی دَافِقٍ : اچھلتا ہوا وہ ایک اچھلتے ہوئے پانی سے پیدا کیا گیا ہے۔
86,7,یَّخْرُجُ مِنْۢ بَیْنِ الصُّلْبِ وَ التَّرَآئِبِؕ يَّخْرُجُ : نکلتا ہے مِنْۢ : سے بَيْنِ الصُّلْبِ : درمیان پیٹھ وَالتَّرَآئِبِ : اور سینہ جو پیٹھ اور سینے کے درمیان سے نکلتا ہے۔ (1)
86,8,اِنَّهٗ عَلٰى رَجْعِهٖ لَقَادِرٌؕ اِنَّهٗ : بیشک وہ عَلٰي : پر رَجْعِهٖ : دوبارہ لوٹانا لَقَادِرٌ : قادر بیشک وہ اسے پھیر لانے پر یقیناً قدرت رکھنے والا ہے (1)
86,9,یَوْمَ تُبْلَى السَّرَآئِرُۙ يَوْمَ : دن تُبْلَى : جانچے جائیں گے السَّرَآئِرُ : راز جس دن پوشیدہ باتوں کی جانچ پڑتال ہوگی۔ (1)
86,10,فَمَا لَهٗ مِنْ قُوَّةٍ وَّ لَا نَاصِرٍؕ فَمَا : تو نہ لَهٗ : اس کیلئے مِنْ قُوَّةٍ : قوت سے وَّلَا : اور نہ نَاصِرٍ : مددگار تو نہ ہوگا اس کے پاس کچھ زور نہ مددگار۔ (1)
86,11,وَ السَّمَآءِ ذَاتِ الرَّجْعِۙ وَالسَّمَآءِ : قسم آسمان کی ذَاتِ الرَّجْعِ : بارش والا بارش والے آسمان کی قسم (1)
86,12,وَ الْاَرْضِ ذَاتِ الصَّدْعِۙ وَالْاَرْضِ : اور زمین کی ذَاتِ الصَّدْعِ : پھٹ جانے والی اور پھٹنے والی زمین کی قسم (1)
86,13,اِنَّهٗ لَقَوْلٌ فَصْلٌۙ اِنَّهٗ لَقَوْلٌ : بیشک وہ کلام فَصْلٌ : فیصلہ کردینے والا بیشک یہ (قرآن) البتہ دو ٹوک فیصلہ کرنے والا کلام ہے۔ (1)
86,14,وَّ مَا هُوَ بِالْهَزْلِؕ وَّمَا : اور نہیں هُوَ : وہ بِالْهَزْلِ : بیہودہ بات یہ ہنسی کی (اور بےفائدہ) بات نہیں (1)
86,15,اِنَّهُمْ یَكِیْدُوْنَ كَیْدًاۙ اِنَّهُمْ : بیشک وہ يَكِيْدُوْنَ : تدبیر کرتے ہیں كَيْدًا : تدبیر البتہ کافر داؤ گھات میں ہیں (1)
86,16,وَّ اَكِیْدُ كَیْدًاۚۖ وَّاَكِيْدُ : اور میں تدبیر کرتا ہوں كَيْدًا : ایک تدبیر اور میں بھی ایک چال چل رہا ہوں (1)
86,17,فَمَهِّلِ الْكٰفِرِیْنَ اَمْهِلْهُمْ رُوَیْدًا۠    ۧ فَمَهِّلِ : پس ڈھیل دو الْكٰفِرِيْنَ : کافروں کو اَمْهِلْهُمْ رُوَيْدًا : ڈھیل دو تھوڑی تو کافروں کو مہلت دے (1) انہیں تھوڑے دن چھوڑ دے۔
