quran[78]{c,v,t}:
55,1,اَلرَّحْمٰنُۙ اَلرَّحْمٰنُ : الرحمان رحمٰن نے۔
55,2,عَلَّمَ الْقُرْاٰنَؕ عَلَّمَ الْقُرْاٰنَ : اس نے تعلیم دی قرآن کی قرآن سکھایا (1)
55,3,خَلَقَ الْاِنْسَانَۙ خَلَقَ الْاِنْسَانَ : اس نے پیدا کیا انسان کو اسی نے انسان کو پیدا کیا (2)
55,4,عَلَّمَهُ الْبَیَانَ عَلَّمَهُ : سکھایا اس کو الْبَيَانَ : بولنا اور اسے بولنا سکھایا (3)
55,5,اَلشَّمْسُ وَ الْقَمَرُ بِحُسْبَانٍ۪ اَلشَّمْسُ : سورج وَالْقَمَرُ : اور چاند بِحُسْبَانٍ : حساب کے ساتھ ہیں آفتاب اور مہتاب (مقررہ) حساب سے ہیں (1)
55,6,وَّ النَّجْمُ وَ الشَّجَرُ یَسْجُدٰنِ وَّالنَّجْمُ : اور تارے وَالشَّجَرُ : اور درخت يَسْجُدٰنِ : سجدہ کر رہے ہیں اور ستارے اور درخت دونوں سجدہ کرتے ہیں (1)
55,7,وَ السَّمَآءَ رَفَعَهَا وَ وَضَعَ الْمِیْزَانَۙ وَالسَّمَآءَ : اور آسمان رَفَعَهَا : اس نے بلند کیا اس کو وَوَضَعَ : اور قائم کردی۔ رکھ دی الْمِيْزَانَ : میزان اسی نے آسمان کو بلند کیا اور اسی نے ترازو رکھی (1)
55,8,اَلَّا تَطْغَوْا فِی الْمِیْزَانِ اَلَّا تَطْغَوْا : کہ نہ تم خلل ڈالو۔ زیادتی کرو فِي الْمِيْزَانِ : میزان میں تاکہ تولنے میں تجاوز نہ کرو (1)
55,9,وَ اَقِیْمُوا الْوَزْنَ بِالْقِسْطِ وَ لَا تُخْسِرُوا الْمِیْزَانَ وَاَقِيْمُوا : اور قائم کرو۔ تولو الْوَزْنَ : وزن کو بِالْقِسْطِ : انصاف کے ساتھ وَلَا : اور نہ تُخْسِرُوا : خسارہ کر کے دو ۔ نقصان دو الْمِيْزَانَ : میزان میں۔ ترازو میں انصاف کے ساتھ وزن کو ٹھیک رکھو اور تول میں کم نہ دو۔
55,10,وَ الْاَرْضَ وَ ضَعَهَا لِلْاَنَامِۙ وَالْاَرْضَ : اور زمین وَضَعَهَا : اس نے رکھ دیا اس کو لِلْاَنَامِ : مخلوقات کے لیے اور اسی نے مخلوق کے لئے زمین بچھا دی۔
55,11,فِیْهَا فَاكِهَةٌ١۪ۙ وَّ النَّخْلُ ذَاتُ الْاَكْمَامِۖ فِيْهَا فَاكِهَةٌ ۽ : اس میں پھل ہیں وَّالنَّخْلُ : اور کھجور کے درخت ذَاتُ الْاَكْمَامِ : خوشوں والے جس میں میوے ہیں اور خوشے والے کھجور کے درخت ہیں (1)۔
55,12,وَ الْحَبُّ ذُو الْعَصْفِ وَ الرَّیْحَانُۚ وَالْحَبُّ : اور غلے ذُو الْعَصْفِ : بھس والے وَالرَّيْحَانُ : اور خوشبودار پھول اور بھس والا اناج (1) اور خشبودار پھول ہیں۔
55,13,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس (اے انسانو اور جنو !) تم اپنے پروردگار کی کس کس نعمت کو جھٹلاؤ گے ؟ (1)
55,14,خَلَقَ الْاِنْسَانَ مِنْ صَلْصَالٍ كَالْفَخَّارِۙ خَلَقَ الْاِنْسَانَ : اس نے پیدا کیا انسان کو مِنْ صَلْصَالٍ : بجنے والی مٹی سے كَالْفَخَّارِ : ٹھیکری کی طرح اس نے انسان کو بجنے والی مٹی سے پیدا کیا جو ٹھیکری کی طرح تھی (1)
55,15,وَ خَلَقَ الْجَآنَّ مِنْ مَّارِجٍ مِّنْ نَّارٍۚ وَخَلَقَ الْجَآنَّ : اور اس نے پیدا کیا جن کو مِنْ مَّارِجٍ : شعلے والی سے مِّنْ نَّارٍ : آگ سے۔ آگ کے اور جنات کو آگ کے شعلے سے پیدا کیا (1)
55,16,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس (اے انسانو اور جنو !) تم اپنے پروردگار کی کس کس نعمت کو جھٹلاؤ گے ؟ (1)
55,17,رَبُّ الْمَشْرِقَیْنِ وَ رَبُّ الْمَغْرِبَیْنِۚ رَبُّ الْمَشْرِقَيْنِ : رب ہے دو مشرقوں کا وَرَبُّ الْمَغْرِبَيْنِ : اور رب ہے دو مغربوں کا وہ رب ہے دونوں مشرقوں کا اور دونوں مغربوں کا (1)
55,18,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس (اے انسانو اور جنو !) تم اپنے پروردگار کی کس کس نعمت کو جھٹلاؤ گے ؟
55,19,مَرَجَ الْبَحْرَیْنِ یَلْتَقِیٰنِۙ مَرَجَ الْبَحْرَيْنِ : اس نے چھوڑ دیا دو سمندروں کو يَلْتَقِيٰنِ : کہ دونوں باہم مل جائیں اس نے دو دریا جاری کردیئے جو ایک دوسرے سے مل جاتے ہیں۔
55,20,بَیْنَهُمَا بَرْزَخٌ لَّا یَبْغِیٰنِۚ بَيْنَهُمَا بَرْزَخٌ : ان دونوں کے درمیان ایک پردہ ہے لَّا يَبْغِيٰنِ : نہیں وہ تجاوز کرتے۔ آگے بڑھتے ان دونوں میں سے ایک آڑ ہے کہ اس سے بڑھ نہیں سکتے (1)
55,21,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
55,22,یَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجَانُۚ يَخْرُجُ مِنْهُمَا : نکلتے ہیں ان دونوں سے اللُّؤْلُؤُ : موتی وَالْمَرْجَانُ : اور مونگے ان دونوں میں سے موتی اور مونگے برآمد ہوتے ہیں (1)
55,23,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
55,24,وَ لَهُ الْجَوَارِ الْمُنْشَئٰتُ فِی الْبَحْرِ كَالْاَعْلَامِۚ وَلَهُ الْجَوَارِ : اور اسی کے لیے ہیں جہاز الْمُنْشَئٰتُ : اونچے اٹھے ہوئے فِي الْبَحْرِ : سمندر میں كَالْاَعْلَامِ : اونچے پہاڑوں کی طرح اور اللہ ہی کی (ملکیت میں) ہیں جہاز جو سمندروں میں پہاڑ کی طرح بلند (چل پھر رہے) ہیں (1)
55,25,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ۠    ۧ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
55,26,كُلُّ مَنْ عَلَیْهَا فَانٍۚۖ كُلُّ مَنْ عَلَيْهَا : سب کے سب جو اس پر ہیں فَانٍ : فنا ہونے والے ہیں زمین پر جو ہیں سب فنا ہونے والے ہیں۔
55,27,وَّ یَبْقٰى وَجْهُ رَبِّكَ ذُو الْجَلٰلِ وَ الْاِكْرَامِۚ وَّيَبْقٰى : اور باقی رہے گی وَجْهُ رَبِّكَ : تیرے رب کی ذات ذُو الْجَلٰلِ : بزرگی والی وَالْاِكْرَامِ : اور کرم والی صرف تیرے رب کی ذات جو عظمت اور عزت والی ہے باقی رہ جائے گی۔
55,28,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
55,29,یَسْئَلُهٗ مَنْ فِی السَّمٰوٰتِ وَ الْاَرْضِ١ؕ كُلَّ یَوْمٍ هُوَ فِیْ شَاْنٍۚ يَسْئَلُهٗ : مانگتے ہیں اس سے مَنْ : جو بھی فِي السَّمٰوٰتِ : آسمانوں میں ہیں وَالْاَرْضِ ۭ : اور زمین میں كُلَّ يَوْمٍ : ہر روز هُوَ فِيْ شَاْنٍ : وہ نئی شان میں ہے سب آسمان و زمین والے اسی سے مانگتے ہیں (1) ہر روز وہ ایک شان میں ہے (2)۔
55,30,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
55,31,سَنَفْرُغُ لَكُمْ اَیُّهَ الثَّقَلٰنِۚ سَنَفْرُغُ لَكُمْ : عنقریب ہم فارغ ہوجائیں گے تمہارے لیے اَيُّهَا الثَّقَلٰنِ : اے دو بوجھو (جنوں اور انسانوں کے گروہو !) عنقریب ہم تمہاری طرف پوری طرح متوجہ ہوجائیں گے (1)
55,32,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
55,33,یٰمَعْشَرَ الْجِنِّ وَ الْاِنْسِ اِنِ اسْتَطَعْتُمْ اَنْ تَنْفُذُوْا مِنْ اَقْطَارِ السَّمٰوٰتِ وَ الْاَرْضِ فَانْفُذُوْا١ؕ لَا تَنْفُذُوْنَ اِلَّا بِسُلْطٰنٍۚ يٰمَعْشَرَ الْجِنِّ وَالْاِنْسِ : اے گروہ جن و انس اِنِ اسْتَطَعْتُمْ : اگر تم استطاعت رکھتے ہو اَنْ تَنْفُذُوْا : کہ تم نکل بھاگو مِنْ اَقْطَارِ : کناروں سے السَّمٰوٰتِ : آسمانوں کے وَالْاَرْضِ : اور زمین کے فَانْفُذُوْا ۭ : تو بھاگ نکلو لَا تَنْفُذُوْنَ : نہیں تم بھاگ سکتے اِلَّا بِسُلْطٰنٍ : مگر ساتھ ایک زور کے اے گروہ جنات و انسان ! اگر تم میں آسمانوں اور زمین میں کے کناروں سے باہر نکل جانے کی طاقت ہے تو نکل بھاگو ! (1) بغیر غلبہ اور طاقت کے تم نہیں نکل سکتے۔ (2)
55,34,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
55,35,یُرْسَلُ عَلَیْكُمَا شُوَاظٌ مِّنْ نَّارٍ١ۙ۬ وَّ نُحَاسٌ فَلَا تَنْتَصِرٰنِۚ يُرْسَلُ عَلَيْكُمَا : چھوڑ دیا جائے گا تم پر شُوَاظٌ : شعلہ مِّنْ نَّارٍ : آگ میں سے وَّنُحَاسٌ : اور دھواں فَلَا تَنْتَصِرٰنِ : تو نہ تم دونوں مقابلہ کرسکو گے تم پر آگ کے شعلے اور دھواں چھوڑا جائے گا (1) پھر تم مقابلہ نہ کرسکو گے۔ (2)
55,36,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
55,37,فَاِذَا انْشَقَّتِ السَّمَآءُ فَكَانَتْ وَرْدَةً كَالدِّهَانِۚ فَاِذَا انْشَقَّتِ السَّمَآءُ : تو جب پھٹ جائے گا آسمان فَكَانَتْ : تو ہوجائے گا وَرْدَةً : سرخ كَالدِّهَانِ : سرخ چمڑے کی طرح۔ تیل کی تلچھٹ کی طرح پس جب کہ آسمان پھٹ کر سرخ ہوجائے جیسے کہ سرخ چمڑہ (1)
55,38,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
55,39,فَیَوْمَئِذٍ لَّا یُسْئَلُ عَنْ ذَنْۢبِهٖۤ اِنْسٌ وَّ لَا جَآنٌّۚ فَيَوْمَئِذٍ : تو اس دن لَّا يُسْئَلُ : نہ پوچھا جائے گا عَنْ ذَنْۢبِهٖٓ : اپنے گناہوں کے بارے میں اِنْسٌ وَّلَا جَآنٌّ : کوئی انسان اور نہ کوئی جن اس دن کسی انسان اور کسی جن سے اس کے گناہوں کی پرسش نہ کی جائے گی (1)
55,40,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
55,41,یُعْرَفُ الْمُجْرِمُوْنَ بِسِیْمٰىهُمْ فَیُؤْخَذُ بِالنَّوَاصِیْ وَ الْاَقْدَامِۚ يُعْرَفُ الْمُجْرِمُوْنَ : پہچانے جائیں گے مجرم بِسِيْمٰهُمْ : اپنے چہروں کے ساتھ فَيُؤْخَذُ بالنَّوَاصِيْ : تو پکڑے جائیں گے پیشانی کے بالوں سے وَالْاَقْدَامِ : اور قدموں سے گناہگار صرف حلیہ سے ہی پہچانے جائیں گے (1) اور ان کے پیشانیوں کے بال اور قدم پکڑ لئے جائیں گے (2)۔
55,42,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,43,هٰذِهٖ جَهَنَّمُ الَّتِیْ یُكَذِّبُ بِهَا الْمُجْرِمُوْنَۘ هٰذِهٖ : یہ ہے جَهَنَّمُ : وہ جہنم الَّتِيْ : وہ جو يُكَذِّبُ : جھٹلاتے تھے بِهَا : جس کو الْمُجْرِمُوْنَ : مجرم یہ ہے وہ جہنم جسے مجرم جھوٹا جانتے تھے۔
55,44,یَطُوْفُوْنَ بَیْنَهَا وَ بَیْنَ حَمِیْمٍ اٰنٍۚ يَطُوْفُوْنَ بَيْنَهَا : گردش کریں گے اس کے درمیان وَبَيْنَ : اور درمیان حَمِيْمٍ : کھولتے پانی کے اٰنٍ : جو سخت گرم ہوگا۔ شدید گرم ہوگا اس کے اور کھولتے ہوئے گرم پانی کے درمیان چکر کھائیں گے (1)
55,45,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ۠    ۧ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,46,وَ لِمَنْ خَافَ مَقَامَ رَبِّهٖ جَنَّتٰنِۚ وَلِمَنْ خَافَ : اور واسطے اس کے جو ڈرے مَقَامَ رَبِّهٖ : اپنے رب کے سامنے کھڑے ہونے سے جَنَّتٰنِ : دو باغ ہیں اور اس شخص کے لئے جو اپنے رب کے سامنے کھڑا ہونے سے ڈرا دو جنتیں ہیں (1)
55,47,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۙ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,48,ذَوَاتَاۤ اَفْنَانٍۚ ذَوَاتَآ اَفْنَانٍ : ہری بھری ڈالیوں والے (دونوں جنتیں) بہت سی ٹہنیوں اور شاخوں والی ہیں (1)
55,49,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,50,فِیْهِمَا عَیْنٰنِ تَجْرِیٰنِۚ فِيْهِمَا عَيْنٰنِ : ان دونوں میں دو چشمے ہیں تَجْرِيٰنِ : بہتے ہوئے ان دونوں (جنتوں) میں دو بہتے ہوئے چشمے ہیں (1)
55,51,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,52,فِیْهِمَا مِنْ كُلِّ فَاكِهَةٍ زَوْجٰنِۚ فِيْهِمَا : ان دونوں میں مِنْ كُلِّ فَاكِهَةٍ : ہر قسم کے پھلوں میں سے ہیں زَوْجٰنِ : دو قسم ان دونوں جنتوں میں ہر قسم کے میووں کی دو قسمیں ہونگی (1)
55,53,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,54,مُتَّكِئِیْنَ عَلٰى فُرُشٍۭ بَطَآئِنُهَا مِنْ اِسْتَبْرَقٍ١ؕ وَ جَنَا الْجَنَّتَیْنِ دَانٍۚ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے ہوں گے عَلٰي فُرُشٍۢ : ایسے فرشوں پر بَطَآئِنُهَا : ان کے استر مِنْ اِسْتَبْرَقٍ ۭ : موٹے تافتے کے ہوں گے وَجَنَا الْجَنَّتَيْنِ : اور پھل دونوں باغوں کے۔ پھل توڑیں گے دونوں باغوں کے دَانٍ : قریب قریب ہوں گے۔ جھکے ہوئے ہوں گے جنتی ایسے فرشوں پر تکیہ لگائے ہوئے ہونگے جن کے استر و بیز ریشم کے ہونگے (1) اور دونوں جنتوں کے میوے بالکل قریب ہونگے (2)
55,55,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,56,فِیْهِنَّ قٰصِرٰتُ الطَّرْفِ١ۙ لَمْ یَطْمِثْهُنَّ اِنْسٌ قَبْلَهُمْ وَ لَا جَآنٌّۚ فِيْهِنَّ : ان میں ہوں گی قٰصِرٰتُ : جھکانے والیاں الطَّرْفِ ۙ : نگاہوں کو لَمْ يَطْمِثْهُنَّ : نہیں چھوا ہوگا ان کو اِنْسٌ : کسی انسان نے قَبْلَهُمْ : ان سے پہلے وَلَا جَآنٌّ : اور نہ کسی جن نے وہاں (شرمیلی) نیچی نگاہ والی حوریں ہیں (1) جنہیں ان سے پہلے کسی جن و انس نے ہاتھ نہیں لگایا (2)
55,57,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,58,كَاَنَّهُنَّ الْیَاقُوْتُ وَ الْمَرْجَانُۚ كَاَنَّهُنَّ الْيَاقُوْتُ : گویا کہ وہ یاقوت ہیں وَالْمَرْجَانُ : اور موتی وہ حوریں مثل یاقوت اور مونگے کے ہوں گی (1)
55,59,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,60,هَلْ جَزَآءُ الْاِحْسَانِ اِلَّا الْاِحْسَانُۚ هَلْ : کیا جَزَآءُ : بدلہ ہے الْاِحْسَانِ : احسن کا اِلَّا الْاِحْسَانُ : سوائے احسان کے (کچھ اور ہے ؟ ) احسان کا بدلہ احسان کے سوا کیا ہے (1)
55,61,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,62,وَ مِنْ دُوْنِهِمَا جَنَّتٰنِۚ وَمِنْ دُوْنِهِمَا : اور ان دونوں کے علاوہ جَنَّتٰنِ : دو باغ ہیں اور ان کے سوا دو جنتیں اور ہیں (1)۔
55,63,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۙ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,64,مُدْهَآ مَّتٰنِۚ مُدْهَآمَّتٰنِ : نہایت سبز جو دونوں گہری سبز سیاہی مائل ہیں (1)۔
55,65,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,66,فِیْهِمَا عَیْنٰنِ نَضَّاخَتٰنِۚ فِيْهِمَا عَيْنٰنِ : ان دونوں میں دو چشمے ہیں نَضَّاخَتٰنِ : جوش مارنے والے ان میں دو (جوش سے) ابلنے والے چشمے ہیں (1)
55,67,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,68,فِیْهِمَا فَاكِهَةٌ وَّ نَخْلٌ وَّ رُمَّانٌۚ فِيْهِمَا فَاكِهَةٌ : ان دونوں میں پھل ہیں وَّنَخْلٌ : اور کھجور کے درخت وَّرُمَّانٌ : اور انار ان دونوں میں میوے اور کھجور اور انار ہوں گے (1)
55,69,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,70,فِیْهِنَّ خَیْرٰتٌ حِسَانٌۚ فِيْهِنَّ خَيْرٰتٌ : ان میں اچھی عورتیں ہیں۔ بہترین عورتیں ہیں حِسَانٌ : خوبصورت ان میں نیک سیرت خوبصورت عورتیں ہیں (1)
55,71,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,72,حُوْرٌ مَّقْصُوْرٰتٌ فِی الْخِیَامِۚ حُوْرٌ : حوریں مَّقْصُوْرٰتٌ : ٹھہرائی ہوئیں۔ روکی ہوئیں فِي الْخِيَامِ : خیموں میں (گوری رنگت کی) حوریں جنتی خیموں میں رہنے والیاں ہیں (1)
55,73,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,74,لَمْ یَطْمِثْهُنَّ اِنْسٌ قَبْلَهُمْ وَ لَا جَآنٌّۚ لَمْ يَطْمِثْهُنَّ : نہیں چھوا ہوگا ان کو اِنْسٌ : کسی انسان نے قَبْلَهُمْ : ان سے پہلے وَلَا جَآنٌّ : اور نہ کسی جن نے ان کو ہاتھ نہیں لگایا کسی انسان یا جن نے اس سے قبل۔
55,75,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,76,مُتَّكِئِیْنَ عَلٰى رَفْرَفٍ خُضْرٍ وَّ عَبْقَرِیٍّ حِسَانٍۚ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے ہوں گے عَلٰي رَفْرَفٍ : مسندوں پر خُضْرٍ : سبز وَّعَبْقَرِيٍّ : اور نادر حِسَانٍ : نفیس سبز مسندوں اور عمدہ فرشوں پر تکیہ لگائے ہوئے ہوں گے (1)
55,77,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
55,78,تَبٰرَكَ اسْمُ رَبِّكَ ذِی الْجَلٰلِ وَ الْاِكْرَامِ۠    ۧ تَبٰرَكَ اسْمُ : بہت بابرکت ہے نام رَبِّكَ : تیرے رب کا ذِي الْجَلٰلِ : جو صاحب جلال ہے وَالْاِكْرَامِ : اور کریم ہے۔ صاحب اکرام ہے تیرے پروردگار کا نام بابرکت ہے (1) جو عزت و جلال والا ہے۔
