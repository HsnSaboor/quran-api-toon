quran[59]{c,v,t}:
44,1,حٰمٓۚۛ حٰمٓ : حا۔ میم حم
44,2,وَ الْكِتٰبِ الْمُبِیْنِۙۛ وَالْكِتٰبِ الْمُبِيْنِ : قسم ہے کتاب روشن کی قسم ہے اس وضاحت والی کتاب کی۔
44,3,اِنَّاۤ اَنْزَلْنٰهُ فِیْ لَیْلَةٍ مُّبٰرَكَةٍ اِنَّا كُنَّا مُنْذِرِیْنَ اِنَّآ : بیشک ہم نے اَنْزَلْنٰهُ : نازل کیا ہم نے اس کو فِيْ لَيْلَةٍ : ایک رات میں مُّبٰرَكَةٍ : بابرکت اِنَّا : بیشک ہم كُنَّا مُنْذِرِيْنَ : تھے ہم ڈرانے والے۔ متنبہ کرنے والے یقیناً ہم نے اسے بابرکت رات (1) میں اتارا ہے بیشک ہم ڈرانے والے ہیں
44,4,فِیْهَا یُفْرَقُ كُلُّ اَمْرٍ حَكِیْمٍۙ فِيْهَا : اس میں يُفْرَقُ : فیصلہ کیا جاتا ہے كُلُّ : ہر اَمْرٍ حَكِيْمٍ : مضبوط کام کا اسی رات میں ہر ایک مضبوط کام کا فیصلہ کیا جاتا ہے
44,5,اَمْرًا مِّنْ عِنْدِنَا١ؕ اِنَّا كُنَّا مُرْسِلِیْنَۚ اَمْرًا : ایک حکم مِّنْ عِنْدِنَا : ہماری طرف سے۔ ہمارے پاس سے اِنَّا : بیشک ہم كُنَّا مُرْسِلِيْنَ : تھے ہم بھیجنے والے ہمارے پاس سے حکم ہو کر (1) ہم ہی ہیں رسول بنا کر بھیجنے والے۔
44,6,رَحْمَةً مِّنْ رَّبِّكَ١ؕ اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُۙ رَحْمَةً : رحمت کے طور پر مِّنْ رَّبِّكَ : تیرے رب کی طرف سے اِنَّهٗ : بیشک وہ هُوَ السَّمِيْعُ : وہ سننے والا ہے الْعَلِيْمُ : علم والا ہے آپ کے رب کی مہربانی سے (1) وہی سننے والا جاننے والا۔
44,7,رَبِّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا١ۘ اِنْ كُنْتُمْ مُّوْقِنِیْنَ رَبِّ السَّمٰوٰتِ : رب ہے آسمانوں کا وَالْاَرْضِ : اور زمین کا وَمَا بَيْنَهُمَا : اور جو ان دونوں کے درمیان اِنْ كُنْتُمْ : اگر ہو تم مُّوْقِنِيْنَ : یقین کرنے والے جو رب ہے آسمانوں کا اور زمین کا اور جو کچھ ان کے درمیان ہے، اگر تم یقین کرنے والے ہو۔
44,8,لَاۤ اِلٰهَ اِلَّا هُوَ یُحْیٖ وَ یُمِیْتُ١ؕ رَبُّكُمْ وَ رَبُّ اٰبَآئِكُمُ الْاَوَّلِیْنَ لَآ اِلٰهَ : نہیں کوئی الہ برحق اِلَّا هُوَ : مگر وہی يُحْيٖ : وہ زندہ کرتا ہے وَيُمِيْتُ : اور وہ موت دیتا ہے رَبُّكُمْ : رب تمہارا وَرَبُّ اٰبَآئِكُمُ الْاَوَّلِيْنَ : اور رب تمہارے آباؤاجداد کا۔ پہلوں کا کوئی معبود نہیں اس کے سوا وہی جلاتا ہے اور مارتا ہے، وہی تمہارا رب ہے اور تمہارے اگلے باپ دادوں کا۔
44,9,بَلْ هُمْ فِیْ شَكٍّ یَّلْعَبُوْنَ بَلْ : بلکہ هُمْ : وہ فِيْ شَكٍّ : شک میں يَّلْعَبُوْنَ : کھیل رہے ہیں بلکہ وہ شک میں پڑے کھیل رہے ہیں (1)۔
44,10,فَارْتَقِبْ یَوْمَ تَاْتِی السَّمَآءُ بِدُخَانٍ مُّبِیْنٍۙ فَارْتَقِبْ : پس انتظار کرو يَوْمَ : جس دن تَاْتِي السَّمَآءُ : آئے گا آسمان بِدُخَانٍ مُّبِيْنٍ : ساتھ کھلے دھوئیں گے آپ اس دن کے منتظر رہیں جب کہ آسمان ظاہر دھواں لائے گا (1)
44,11,یَّغْشَى النَّاسَ١ؕ هٰذَا عَذَابٌ اَلِیْمٌ يَّغْشَى النَّاسَ : ڈھانپ لے گا لوگوں کو ھٰذَا : یہ ہے عَذَابٌ : عذاب اَلِيْمٌ : دردناک جو لوگوں کو گھیر لے گا، یہ دردناک عذاب ہے۔
44,12,رَبَّنَا اكْشِفْ عَنَّا الْعَذَابَ اِنَّا مُؤْمِنُوْنَ رَبَّنَا اكْشِفْ : (کہیں گے) اے ہمارے رب مٹا دے عَنَّا الْعَذَابَ : ہم سے عذاب کو اِنَّا مُؤْمِنُوْنَ : بیشک ہم ماننے والے ہیں کہیں گے اے ہمارے رب ! یہ آفت ہم سے دور کر ہم ایمان قبول کرتے ہیں (1)
44,13,اَنّٰى لَهُمُ الذِّكْرٰى وَ قَدْ جَآءَهُمْ رَسُوْلٌ مُّبِیْنٌۙ اَنّٰى : کہاں سے ہے لَهُمُ الذِّكْرٰى : ان کے لیے نصیحت وَقَدْ جَآءَهُمْ : اور تحقیق آچکا ان کے پاس رَسُوْلٌ مُّبِيْنٌ : رسول مبین۔ بیان کرنے والا ان کے لئے نصیحت کہاں ہے ؟ کھول کھول کر بیان کرنے والے پیغمبر ان کے پاس آچکے۔
44,14,ثُمَّ تَوَلَّوْا عَنْهُ وَ قَالُوْا مُعَلَّمٌ مَّجْنُوْنٌۘ ثُمَّ تَوَلَّوْا : پھر وہ منہ موڑ گئے عَنْهُ : اس سے وَقَالُوْا : اور انہوں نے کہا مُعَلَّمٌ مَّجْنُوْنٌ : سکھایا پڑھایا ہے، دیوانہ ہے پھر بھی انہوں نے منہ پھیرا اور کہہ دیا کہ سکھایا پڑھایا ہوا باؤلا ہے۔
44,15,اِنَّا كَاشِفُوا الْعَذَابِ قَلِیْلًا اِنَّكُمْ عَآئِدُوْنَۘ اِنَّا : بیشک ہم كَاشِفُوا الْعَذَابِ : ہٹانے والے ہیں عذاب کو قَلِيْلًا : تھوڑا سا اِنَّكُمْ عَآئِدُوْنَ : بیشک تم لوٹنے والے ہو ہم عذاب کو تھوڑا دور کردیں گے تو تم پھر اپنی سی حالت پر آجاؤ گے۔
44,16,یَوْمَ نَبْطِشُ الْبَطْشَةَ الْكُبْرٰى١ۚ اِنَّا مُنْتَقِمُوْنَ يَوْمَ : جس دن نَبْطِشُ : ہم پکڑیں گے الْبَطْشَةَ : پکڑ الْكُبْرٰى : بڑی اِنَّا مُنْتَقِمُوْنَ : بیشک ہم انتقام لینے والے ہیں جس دن ہم بڑی سخت پکڑ پکڑیں گے (1) بالیقین ہم بدلہ لینے والے ہیں۔
44,17,وَ لَقَدْ فَتَنَّا قَبْلَهُمْ قَوْمَ فِرْعَوْنَ وَ جَآءَهُمْ رَسُوْلٌ كَرِیْمٌۙ وَلَقَدْ : اور البتہ تحقیق فَتَنَّا : آزمایا ہم نے قَبْلَهُمْ : ان سے قبل قَوْمَ فِرْعَوْنَ : قوم فرعون کو وَجَآءَهُمْ : اور آیا ان کے پاس رَسُوْلٌ : رسول كَرِيْمٌ : کریم۔ عزت والا رسول یقیناً ان سے پہلے ہم قوم فرعون کو (بھی) آزما چکے ہیں (1) جن کے پاس (اللہ کا) با عزت رسول آیا۔
44,18,اَنْ اَدُّوْۤا اِلَیَّ عِبَادَ اللّٰهِ١ؕ اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اَنْ اَدُّوْٓا : (اس نے کہا) کہ حوالے کر دو اِلَيَّ : میری طرف عِبَادَ اللّٰهِ : اللہ کے بندوں کو ۭ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ اَمِيْنٌ : رسول ہوں امانت دار کہ اللہ کے بندوں کو میرے حوالے کر (1) دو ، یقین مانو کہ میں تمہارے لئے امانت دار رسول ہوں (2)۔
44,19,وَّ اَنْ لَّا تَعْلُوْا عَلَى اللّٰهِ١ۚ اِنِّیْۤ اٰتِیْكُمْ بِسُلْطٰنٍ مُّبِیْنٍۚ وَّاَنْ لَّا : اور یہ کہ نہ تَعْلُوْا : تم سرکشی کرو عَلَي اللّٰهِ : اللہ کے مقابلے پر اِنِّىْٓ : بیشک میں اٰتِيْكُمْ : لایا ہوں تمہارے پاس بِسُلْطٰنٍ مُّبِيْنٍ : کھلی دلیل اور تم اللہ تعالیٰ کے سامنے سرکشی نہ کرو (1) میں تمہارے پاس کھلی دلیل لانے والا ہوں (2)۔
44,20,وَ اِنِّیْ عُذْتُ بِرَبِّیْ وَ رَبِّكُمْ اَنْ تَرْجُمُوْنِ٘ وَاِنِّىْ : اور بیشک میں عُذْتُ : میں پناہ لے چکا بِرَبِّيْ : اپنے رب کی وَرَبِّكُمْ : اور تمہارے رب کی اَنْ تَرْجُمُوْنِ : کہ تم سنگسار کرو مجھے اور میں اپنے اور تمہارے رب کی پناہ میں آتا ہوں اس سے کہ تم مجھے سنگسار کردو (1)۔
44,21,وَ اِنْ لَّمْ تُؤْمِنُوْا لِیْ فَاعْتَزِلُوْنِ وَاِنْ لَّمْ : اور اگر نہیں تُؤْمِنُوْا لِيْ : تم مانو گے میری بات فَاعْتَزِلُوْنِ : تو چھوڑ دو مجھ کو اور اگر تم مجھ پر ایمان نہیں لاتے تو مجھ سے الگ ہی رہو (1)۔
44,22,فَدَعَا رَبَّهٗۤ اَنَّ هٰۤؤُلَآءِ قَوْمٌ مُّجْرِمُوْنَ فَدَعَا رَبَّهٗٓ : تو اس نے پکارا اپنے رب کو اَنَّ هٰٓؤُلَآءِ : بیشک یہ قَوْمٌ : لوگ مُّجْرِمُوْنَ : مجرم ہیں پھر انہوں نے اپنے رب سے دعا کی کہ یہ سب گنہگار لوگ ہیں (1)۔
44,23,فَاَسْرِ بِعِبَادِیْ لَیْلًا اِنَّكُمْ مُّتَّبَعُوْنَۙ فَاَسْرِ بِعِبَادِيْ : تو لے چل میرے بندوں کو لَيْلًا : راتوں رات اِنَّكُمْ : بیشک تم مُّتَّبَعُوْنَ : تم پیچھا کیے جانے والے ہو (ہم نے کہہ دیا) کہ راتوں رات تو میرے بندوں کو لے کر نکل، یقیناً تمہارا (1) پیچھا کیا جائے گا۔
44,24,وَ اتْرُكِ الْبَحْرَ رَهْوًا١ؕ اِنَّهُمْ جُنْدٌ مُّغْرَقُوْنَ وَاتْرُكِ الْبَحْرَ : اور چھوڑ دو سمندر کو رَهْوًا : ساکن اِنَّهُمْ : بیشک وہ جُنْدٌ مُّغْرَقُوْنَ : لشکر ہے غرق ہونے والا تو دریا کو ساکن چھوڑ کر چلا جا (1) بلاشبہ یہ لشکر غرق کردیا جائے گا۔
44,25,كَمْ تَرَكُوْا مِنْ جَنّٰتٍ وَّ عُیُوْنٍۙ كَمْ تَرَكُوْا : کتنے ہی وہ چھوڑ گئے مِنْ جَنّٰتٍ : باغات میں سے وَّعُيُوْنٍ : اور چشمے وہ بہت سے باغات اور چشمے چھوڑ گئے۔
44,26,وَّ زُرُوْعٍ وَّ مَقَامٍ كَرِیْمٍۙ وَّزُرُوْعٍ : اور کھیتیاں وَّ : اور مَقَامٍ كَرِيْمٍ : مقام عمدہ اور کھتیاں اور راحت بخش ٹھکانے۔
44,27,وَّ نَعْمَةٍ كَانُوْا فِیْهَا فٰكِهِیْنَۙ وَّنَعْمَةٍ : اور نعمتیں۔ آرام کی چیزیں كَانُوْا : تھے وہ فِيْهَا فٰكِهِيْنَ : اس میں عیش کرنے والے اور آرام کی چیزیں جن میں عیش کر رہے تھے۔
44,28,كَذٰلِكَ١۫ وَ اَوْرَثْنٰهَا قَوْمًا اٰخَرِیْنَ كَذٰلِكَ : اسی طرح وَاَوْرَثْنٰهَا : اور وارث بنادیا ہم نے ان کا قَوْمًا اٰخَرِيْنَ : دوسری قوم کو اسی طرح ہوگیا (1) اور ہم نے ان سب کا وارث دوسری قوم کو بنادیا (1)
44,29,فَمَا بَكَتْ عَلَیْهِمُ السَّمَآءُ وَ الْاَرْضُ وَ مَا كَانُوْا مُنْظَرِیْنَ۠    ۧ فَمَا : تو نہ بَكَتْ : رویا عَلَيْهِمُ السَّمَآءُ : ان پر آسمان وَالْاَرْضُ : اور زمین وَمَا كَانُوْا : اور نہ تھے وہ مُنْظَرِيْنَ : مہلت دئیے جانے والے سو ان پر نہ تو آسمان و زمین (1) روئے اور نہ انہیں مہلت ملی۔
44,30,وَ لَقَدْ نَجَّیْنَا بَنِیْۤ اِسْرَآءِیْلَ مِنَ الْعَذَابِ الْمُهِیْنِۙ وَلَقَدْ نَجَّيْنَا : اور البتہ تحقیق نجات دی ہم نے بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل کو مِنَ : سے الْعَذَابِ الْمُهِيْنِ : رسوا کن عذاب (سے) اور بیشک ہم نے (ہی) بنی اسرائیل کو (سخت) رسوا کن سزا سے نجات دی۔
44,31,مِنْ فِرْعَوْنَ١ؕ اِنَّهٗ كَانَ عَالِیًا مِّنَ الْمُسْرِفِیْنَ مِنْ فِرْعَوْنَ : فرعون سے اِنَّهٗ كَانَ : بیشک تھا وہ عَالِيًا مِّنَ الْمُسْرِفِيْنَ : بلند درجے والا، حد سے بڑھنے والوں میں سے (جو) فرعون کی طرف سے (ہو رہی) تھی۔ فی الواقع وہ سرکش اور حد سے گزر جانے والوں میں تھا۔
44,32,وَ لَقَدِ اخْتَرْنٰهُمْ عَلٰى عِلْمٍ عَلَى الْعٰلَمِیْنَۚ وَلَقَدِ : اور البتہ تحقیق اخْتَرْنٰهُمْ : ترجیح دی تھی ہم نے ان کو عَلٰي : باوجود عِلْمٍ : علم کے عَلَي الْعٰلَمِيْنَ : جہان والوں پر ہم نے دانستہ طور پر بنی اسرائیل کو دنیا جہان والوں پر فوقیت دی (1)۔
44,33,وَ اٰتَیْنٰهُمْ مِّنَ الْاٰیٰتِ مَا فِیْهِ بَلٰٓؤٌا مُّبِیْنٌ وَاٰتَيْنٰهُمْ : اور دیں ہم نے ان کو مِّنَ الْاٰيٰتِ : نشانیوں میں سے مَا : جو فِيْهِ : اس میں بَلٰٓؤٌا مُّبِيْنٌ : آزمائش تھی کھلی اور ہم نے انہیں ایسی نشانیاں دیں جن میں صریح آزمائش تھی۔
44,34,اِنَّ هٰۤؤُلَآءِ لَیَقُوْلُوْنَۙ اِنَّ : بیشک هٰٓؤُلَآءِ : یہ لوگ لَيَقُوْلُوْنَ : البتہ کہتے ہیں یہ لوگ تو یہی کہتے ہیں (1)
44,35,اِنْ هِیَ اِلَّا مَوْتَتُنَا الْاُوْلٰى وَ مَا نَحْنُ بِمُنْشَرِیْنَ اِنْ هِىَ : نہیں یہ اِلَّا مَوْتَتُنَا الْاُوْلٰى : مگر ہماری موت پہلی وَمَا نَحْنُ : اور نہیں ہم بِمُنْشَرِيْنَ : اٹھائے جانے والے کہ (آخری چیز) یہی ہمارا پہلی بار (دنیا سے) مرجانا اور ہم (1) دوبارہ اٹھائے نہیں جائیں گے۔
44,36,فَاْتُوْا بِاٰبَآئِنَاۤ اِنْ كُنْتُمْ صٰدِقِیْنَ فَاْتُوْا : پس لے آؤ بِاٰبَآئِنَآ : ہمارے باپ دادا کو اِنْ كُنْتُمْ : اگر ہو تم صٰدِقِيْنَ : سچے اگر تم سچے ہو تو ہمارے باپ دادوں کو لے آؤ (1)
44,37,اَهُمْ خَیْرٌ اَمْ قَوْمُ تُبَّعٍ١ۙ وَّ الَّذِیْنَ مِنْ قَبْلِهِمْ١ؕ اَهْلَكْنٰهُمْ١٘ اِنَّهُمْ كَانُوْا مُجْرِمِیْنَ اَهُمْ خَيْرٌ : کیا وہ اچھے ہیں اَمْ قَوْمُ تُبَّعٍ : یا تبع کی قوم وَّالَّذِيْنَ : اور وہ لوگ مِنْ قَبْلِهِمْ : جو ان سے پہلے تھے اَهْلَكْنٰهُمْ : ہلاک کردیا ہم نے ان کو ۡ اِنَّهُمْ : بیشک وہ كَانُوْا مُجْرِمِيْنَ : مجرم تھے کیا یہ لوگ بہتر ہیں یا تمہاری قوم کے لوگ اور جو ان سے بھی پہلے تھے ہم نے ان سب کو ہلاک کردیا یقیناً وہ گنہگار تھے (1)
44,38,وَ مَا خَلَقْنَا السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَا لٰعِبِیْنَ وَمَا : اور نہیں خَلَقْنَا : پیدا کیا ہم نے السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین کو وَمَا بَيْنَهُمَا : اور جو ان دونوں کے درمیان ہے لٰعِبِيْنَ : کھیل تماشے کے طور پر۔ کھیلنے والے ہو کر ہم نے زمین اور آسمانوں اور ان کے درمیان کی چیزوں کو کھیل کے طور پر پیدا نہیں کیا (1)
44,39,مَا خَلَقْنٰهُمَاۤ اِلَّا بِالْحَقِّ وَ لٰكِنَّ اَكْثَرَهُمْ لَا یَعْلَمُوْنَ مَا خَلَقْنٰهُمَآ : نہیں پیدا کیا ہم نے ان دونوں کو اِلَّا بالْحَقِّ : مگر حق کے ساتھ وَلٰكِنَّ اَكْثَرَهُمْ : لیکن ان میں سے اکثر لَا : نہیں يَعْلَمُوْنَ : علم رکھتے بلکہ ہم نے انہیں درست تدبیر کے ساتھ ہی پیدا کیا (1) ہے لیکن ان میں سے اکثر لوگ نہیں جانتے۔
44,40,اِنَّ یَوْمَ الْفَصْلِ مِیْقَاتُهُمْ اَجْمَعِیْنَۙ اِنَّ يَوْمَ الْفَصْلِ : بیشک فیصلے کا دن مِيْقَاتُهُمْ : ان کی میعاد ہے اَجْمَعِيْنَ : سب کی یقیناً فیصلے کا دن ان سب کا طے شدہ وقت ہے۔ (1)
44,41,یَوْمَ لَا یُغْنِیْ مَوْلًى عَنْ مَّوْلًى شَیْئًا وَّ لَا هُمْ یُنْصَرُوْنَۙ يَوْمَ : جس دن لَا يُغْنِيْ : نہ کام آئے گا مَوْلًى : کوئی عزیز۔ قریب عَنْ مَّوْلًى : عزیز کو۔ قریب کو شَيْئًا : کچھ بھی وَّلَا هُمْ : اور نہ وہ يُنْصَرُوْنَ : مددئیے جائیں گے اس دن کوئی دوست کسی دوست کے کچھ کام بھی نہ آئے گا اور نہ ان کی امداد کی جائے گی۔
44,42,اِلَّا مَنْ رَّحِمَ اللّٰهُ١ؕ اِنَّهٗ هُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ اِلَّا : مگر مَنْ رَّحِمَ اللّٰهُ : جس پر رحم فرمائے اللہ اِنَّهٗ : یقینا وہ هُوَ : وہی الْعَزِيْزُ الرَّحِيْمُ : غالب ہے ، رحم فرمانے والا ہے مگر جس پر اللہ کی مہربانی ہوجائے وہ زبردست اور رحم کرنے والا ہے۔
44,43,اِنَّ شَجَرَتَ الزَّقُّوْمِۙ اِنَّ : بیشک شَجَرَتَ الزَّقُّوْمِ : درخت زقوم کا بیشک زقوم (تھوہر) کا درخت۔
44,44,طَعَامُ الْاَثِیْمِ٤ۖۛۚ طَعَامُ : کھانا ہے الْاَثِيْمِ : گناہ گاروں کا گنہگار کا کھانا ہے۔
44,45,كَالْمُهْلِ١ۛۚ یَغْلِیْ فِی الْبُطُوْنِۙ كَالْمُهْلِ : گلے ہوئے تانبے کی طرح يَغْلِيْ : جوش کھائے گا فِي الْبُطُوْنِ : پیٹوں میں جو مثل تلچھٹ (1) کے ہے اور پیٹ میں کھولتا رہتا ہے۔
44,46,كَغَلْیِ الْحَمِیْمِ كَغَلْيِ : مانند جوش کھانے الْحَمِيْمِ : کھولتے پانی مثل تیز گرم پانی کے (1)
44,47,خُذُوْهُ فَاعْتِلُوْهُ اِلٰى سَوَآءِ الْجَحِیْمِۗۖ خُذُوْهُ : کہا جائے گا) پکڑو اس کو فَاعْتِلُوْهُ : پس گھسیٹو اس کو اِلٰى : طرف سَوَآءِ الْجَحِيْمِ : جہنم کے وسط میں اسے پکڑ لو پھر گھسیٹتے ہوئے بیچ جہنم تک پہنچاؤ (1)
44,48,ثُمَّ صُبُّوْا فَوْقَ رَاْسِهٖ مِنْ عَذَابِ الْحَمِیْمِؕ ثُمَّ صُبُّوْا : پھر انڈیل دو فَوْقَ رَاْسِهٖ : اس کے سر کے اوپر مِنْ عَذَابِ الْحَمِيْمِ : کھولتے پانی کے عذاب سے پھر اس کے سر پر سخت گرم پانی کا عذاب بہاؤ۔
44,49,ذُقْ١ۙۚ اِنَّكَ اَنْتَ الْعَزِیْزُ الْكَرِیْمُ ذُقْ : (کہا جائے گا) چکھو اِنَّكَ : بیشک تم اَنْتَ الْعَزِيْزُ الْكَرِيْمُ : تم زبردست تھے، عزت والے تھے (اس سے کہا جائے گا) چکھتا جا تو تو بڑا ذی عزت اور بڑے اکرام والا تھا (1)۔
44,50,اِنَّ هٰذَا مَا كُنْتُمْ بِهٖ تَمْتَرُوْنَ اِنَّ : بیشک ھٰذَا : یہ مَا كُنْتُمْ بِهٖ : وہ ہے جو تھے تم ساتھ اس کے تَمْتَرُوْنَ : تم شک کرتے تھے یہی وہ چیز ہے جس میں تم شک کیا کرتے تھے۔
44,51,اِنَّ الْمُتَّقِیْنَ فِیْ مَقَامٍ اَمِیْنٍۙ اِنَّ الْمُتَّقِيْنَ : بیشک متقی لوگ فِيْ مَقَامٍ : جگہ پر ہوں گے اَمِيْنٍ : امن والی بیشک (اللہ سے) ڈرنے والے امن چین کی جگہ میں ہونگے۔
44,52,فِیْ جَنّٰتٍ وَّ عُیُوْنٍۚۙ فِيْ جَنّٰتٍ : باغوں میں وَّعُيُوْنٍ : اور چشموں میں باغوں اور چشموں میں۔
44,53,یَّلْبَسُوْنَ مِنْ سُنْدُسٍ وَّ اِسْتَبْرَقٍ مُّتَقٰبِلِیْنَۚۙ يَّلْبَسُوْنَ : پہنیں گے وہ مِنْ سُنْدُسٍ : باریک ریشم میں سے وَّاِسْتَبْرَقٍ : اور موٹا ریشم مُّتَقٰبِلِيْنَ : آمنے سامنے بیٹھنے والے باریک اور ریشم کے لباس پہنے ہوئے آمنے سامنے بیٹھے ہونگے (1)۔
44,54,كَذٰلِكَ١۫ وَ زَوَّجْنٰهُمْ بِحُوْرٍ عِیْنٍؕ كَذٰلِكَ : اسی طرح وَزَوَّجْنٰهُمْ : اور بیاہ دیں گے ہم انکو بِحُوْرٍ عِيْنٍ : موٹی آنکھوں والی سفید عورتوں سے یہ اسی طرح ہے (1) اور ہم بڑی بڑی آنکھوں والی حوروں سے ان کا نکاح کردیں گے (2)۔
44,55,یَدْعُوْنَ فِیْهَا بِكُلِّ فَاكِهَةٍ اٰمِنِیْنَۙ يَدْعُوْنَ : وہ طلب کریں گے فِيْهَا : اس میں بِكُلِّ : ہر قسم کے فَاكِهَةٍ : پھل اٰمِنِيْنَ : امن سے رہنے والے دل جمعی کے ساتھ وہاں ہر طرح کے میووں کی فرمائشیں کرتے ہونگے (1)
44,56,لَا یَذُوْقُوْنَ فِیْهَا الْمَوْتَ اِلَّا الْمَوْتَةَ الْاُوْلٰى١ۚ وَ وَقٰىهُمْ عَذَابَ الْجَحِیْمِۙ لَا يَذُوْقُوْنَ : نہ وہ چکھیں گے فِيْهَا الْمَوْتَ : اس میں موت کو اِلَّا الْمَوْتَةَ الْاُوْلٰى : مگر پہلی موت وَوَقٰىهُمْ : اور بچا لے گا ان کو عَذَابَ الْجَحِيْمِ : جہنم کے عذاب سے وہاں وہ موت چکھنے کے نہیں ہاں پہلی موت (1) (جو وہ مرچکے) انہیں اللہ تعالیٰ نے دوزخ کی سزا سے بچا دیا۔
44,57,فَضْلًا مِّنْ رَّبِّكَ١ؕ ذٰلِكَ هُوَ الْفَوْزُ الْعَظِیْمُ فَضْلًا : فضل ہوگا مِّنْ رَّبِّكَ : تیرے رب کی طرف سے ذٰلِكَ : یہی هُوَ الْفَوْزُ : وہ کامیابی الْعَظِيْمُ : بہت بڑی یہ صرف تیرے رب کا فضل ہے (1) یہی ہے بڑی کامیابی۔
44,58,فَاِنَّمَا یَسَّرْنٰهُ بِلِسَانِكَ لَعَلَّهُمْ یَتَذَكَّرُوْنَ فَاِنَّمَا : پس بیشک يَسَّرْنٰهُ : آسان کردیا ہم نے اس کو بِلِسَانِكَ : تیری زبان پر لَعَلَّهُمْ يَتَذَكَّرُوْنَ : شاید کہ وہ نصیحت پکڑیں ہم نے اس (قرآن) کو تیری زبان میں آسان کردیا تاکہ وہ نصیحت حاصل کریں۔
44,59,فَارْتَقِبْ اِنَّهُمْ مُّرْتَقِبُوْنَ۠    ۧ فَارْتَقِبْ : پس انتظار کرو اِنَّهُمْ مُّرْتَقِبُوْنَ : بیشک وہ انتظار کرنے والے ہیں اب تو منتظر رہ یہ بھی منتظر ہیں (1)
