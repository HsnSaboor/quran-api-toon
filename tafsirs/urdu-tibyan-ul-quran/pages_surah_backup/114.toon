quran[6]{c,v,t}:
114,1,قُلْ اَعُوْذُ بِرَبِّ النَّاسِۙ قُلْ : کہدیجئے اَعُوْذُ : میں پناہ میں آتا ہوں بِرَبِّ النَّاسِ : لوگو کے رب کی آپ کہہ دیجئے ! کہ میں لوگوں کے پروردگار کی پناہ میں آتا ہوں۔
114,2,مَلِكِ النَّاسِۙ مَلِكِ : بادشاہ النَّاسِ : لوگ لوگوں کے مالک کی (1)
114,3,اِلٰهِ النَّاسِۙ اِلٰهِ : معبود النَّاسِ : لوگ لوگوں کے معبود کی (پناہ میں) (1)۔
114,4,مِنْ شَرِّ الْوَسْوَاسِ١ۙ۬ الْخَنَّاسِ۪ۙ مِنْ شَرِّ : شر سے الْوَسْوَاسِ : وسوسہ ڈالنے والے الْخَنَّاسِ : چھپ چھپ کر حملہ کرنے والے وسوسہ ڈالنے والے پیچھے ہٹ جانے والے کے شر سے۔ (1)
114,5,الَّذِیْ یُوَسْوِسُ فِیْ صُدُوْرِ النَّاسِۙ الَّذِيْ يُوَسْوِسُ : جو وسوسہ ڈالتا ہے فِيْ : میں صُدُوْرِ النَّاسِ : لوگوں کے دلوں جو لوگوں کے سینوں میں وسوسہ ڈالتا ہے۔
114,6,مِنَ الْجِنَّةِ وَ النَّاسِ۠    ۧ مِنَ الْجِنَّةِ : جنوں میں سے وَالنَّاسِ : اور انسان (خواہ) وہ جن میں سے ہو یا انسان میں سے (1)
