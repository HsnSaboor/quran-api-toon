quran[55]{c,v,t}:
54,1,اِقْتَرَبَتِ السَّاعَةُ وَ انْشَقَّ الْقَمَرُ اِقْتَرَبَتِ السَّاعَةُ : قریب آگئی قیامت وَانْشَقَّ الْقَمَرُ : اور شق ہوگیا چاند قیامت قریب آگئی (1) اور چاند پھٹ گیا (2)۔
54,2,وَ اِنْ یَّرَوْا اٰیَةً یُّعْرِضُوْا وَ یَقُوْلُوْا سِحْرٌ مُّسْتَمِرٌّ وَاِنْ يَّرَوْا : اور اگر وہ دیکھ لیں اٰيَةً : کوئی بھی نشانی يُّعْرِضُوْا : منہ موڑ جاتے ہیں وَيَقُوْلُوْا : اور کہتے ہیں سِحْرٌ مُّسْتَمِرٌّ : جادو ہے گزرنے والا۔ جاری رہنے والا۔ مسلسل یہ اگر کوئی معجزہ دیکھتے ہیں تو منہ پھیر لیتے ہیں اور کہہ دیتے ہیں یہ پہلے سے چلا آتا ہوا جادو ہے (1)
54,3,وَ كَذَّبُوْا وَ اتَّبَعُوْۤا اَهْوَآءَهُمْ وَ كُلُّ اَمْرٍ مُّسْتَقِرٌّ وَكَذَّبُوْا : اور انہوں نے جھٹلایا وَاتَّبَعُوْٓا : اور پیروی کی اَهْوَآءَهُمْ : اپنی خواہشات کی وَكُلُّ : اور ہر اَمْرٍ مُّسْتَقِرٌّ : کام کا وقت مقرر ہے انہوں نے جھٹلایا اور اپنی خواہشوں کی پیروی کی اور ہر کام ٹھہرے ہوئے وقت پر مقرر ہے (1)
54,4,وَ لَقَدْ جَآءَهُمْ مِّنَ الْاَنْۢبَآءِ مَا فِیْهِ مُزْدَجَرٌۙ وَلَقَدْ جَآءَهُمْ : اور البتہ تحقیق آئیں ان کے پاس مِّنَ الْاَنْۢبَآءِ : خبروں میں سے مَا فِيْهِ : جو اس میں مُزْدَجَرٌ : ڈانٹنا ہے۔ کافی تنبیہ ہے یقیناً ان کے پاس وہ خبریں آچکی ہیں (1) جن میں ڈانٹ ڈپٹ (کی نصیحت) ہے۔
54,5,حِكْمَةٌۢ بَالِغَةٌ فَمَا تُغْنِ النُّذُرُۙ حِكْمَةٌۢ بَالِغَةٌ : حکمت پہنچنے والی۔ کامل فَمَا : تو نہ تُغْنِ النُّذُرُ : کام آئے ڈراوے اور کامل عقل کی بات ہے (1) لیکن ان ڈراؤنی باتوں نے بھی کچھ فائدہ نہ دیا۔
54,6,فَتَوَلَّ عَنْهُمْ١ۘ یَوْمَ یَدْعُ الدَّاعِ اِلٰى شَیْءٍ نُّكُرٍۙ فَتَوَلَّ عَنْهُمْ ۘ : تو منہ پھیر لو ان سے يَوْمَ يَدْعُ : جس دن پکارے گا الدَّاعِ : پکارنے والا اِلٰى : طرف شَيْءٍ : ایک چیز کے نُّكُرٍ : انجان پس (اے نبی) تم ان سے اعراض کرو جس دن ایک پکارنے والا ناگوار چیز کی طرف پکارے گا (1)
54,7,خُشَّعًا اَبْصَارُهُمْ یَخْرُجُوْنَ مِنَ الْاَجْدَاثِ كَاَنَّهُمْ جَرَادٌ مُّنْتَشِرٌۙ خُشَّعًا : جھکی ہوئی ہوں گی اَبْصَارُهُمْ : ان کی نگاہیں يَخْرُجُوْنَ : نکلیں گے مِنَ الْاَجْدَاثِ : قبروں سے كَاَنَّهُمْ : گویا کہ وہ جَرَادٌ مُّنْتَشِرٌ : ٹڈیاں ہیں پھیلی ہوئیں یہ جھکی آنکھوں قبروں سے اس طرح نکل کھڑے ہونگے کہ گویا وہ پھیلا ہوا ٹڈی دل ہے (1)۔
54,8,مُّهْطِعِیْنَ اِلَى الدَّاعِ١ؕ یَقُوْلُ الْكٰفِرُوْنَ هٰذَا یَوْمٌ عَسِرٌ مُّهْطِعِيْنَ : دوڑنے والے ہیں اِلَى : طرف الدَّاعِ ۭ : پکارنے والے کے يَقُوْلُ الْكٰفِرُوْنَ : کہیں گے کافر ھٰذَا يَوْمٌ عَسِرٌ : یہ دن ہے سخت پکارنے والے کی طرف دوڑتے ہونگے اور کافر کہیں گے کہ یہ دن تو بہت سخت ہے۔
54,9,كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ فَكَذَّبُوْا عَبْدَنَا وَ قَالُوْا مَجْنُوْنٌ وَّ ازْدُجِرَ كَذَّبَتْ : جھٹلایا قَبْلَهُمْ : ان سے پہلے قَوْمُ نُوْحٍ : قوم نوح نے فَكَذَّبُوْا عَبْدَنَا : تو انہوں نے جھٹلایا ہمارے بندے کو وَقَالُوْا : اور انہوں نے کہا مَجْنُوْنٌ : مجنون ہے وَّازْدُجِرَ : اور ڈانٹا گیا۔ خوب دھمکی دیا گیا ان سے پہلے قوم نوح نے بھی ہمارے بندے کو جھٹلایا تھا اور دیوانہ بتلا کر جھڑک دیا گیا تھا (1)۔
54,10,فَدَعَا رَبَّهٗۤ اَنِّیْ مَغْلُوْبٌ فَانْتَصِرْ فَدَعَا رَبَّهٗٓ : تو اس نے پکارا اپنے رب کو اَنِّىْ مَغْلُوْبٌ : بیشک میں مغلوب ہوں فَانْتَصِرْ : پس بدلہ لے۔ انتقام لے پس اس نے اپنے رب سے دعا کی کہ میں بےبس ہوں تو میری مدد کر۔
54,11,فَفَتَحْنَاۤ اَبْوَابَ السَّمَآءِ بِمَآءٍ مُّنْهَمِرٍ٘ۖ فَفَتَحْنَآ : تو کھول دیئے ہم نے اَبْوَابَ السَّمَآءِ : دروازے آسمان کے بِمَآءٍ : ساتھ ایک پانی کے مُّنْهَمِرٍ : برسنے والا پس ہم نے آسمان کے دروازوں کو زور کے مینہ سے کھول دیا۔
54,12,وَّ فَجَّرْنَا الْاَرْضَ عُیُوْنًا فَالْتَقَى الْمَآءُ عَلٰۤى اَمْرٍ قَدْ قُدِرَۚ وَّفَجَّرْنَا : اور پھاڑ دیا ہم نے الْاَرْضَ : زمین کو عُيُوْنًا : چشموں میں فَالْتَقَى الْمَآءُ : پس مل گیا پانی عَلٰٓي اَمْرٍ : ایک حکم پر قَدْ قُدِرَ : تحقیق جس کا اندازہ کیا گیا تھا۔ جو مقدر ہوچکا تھا اور زمین سے چشموں کو جاری کردیا پس اس کام کے لئے جو مقدر کیا گیا تھا (دونوں) پانی جمع ہوگئے۔
54,13,وَ حَمَلْنٰهُ عَلٰى ذَاتِ اَلْوَاحٍ وَّ دُسُرٍۙ وَحَمَلْنٰهُ : اور اٹھایا ہم نے اس کو۔ سوار کیا ہم نے اس کو عَلٰي ذَاتِ اَلْوَاحٍ : اوپر تختوں والی کے وَّدُسُرٍ : اور میخوں والی کے اور ہم نے اسے تختوں اور کیلوں والی کشتی پر سوار کرلیا۔
54,14,تَجْرِیْ بِاَعْیُنِنَا١ۚ جَزَآءً لِّمَنْ كَانَ كُفِرَ تَجْرِيْ : چل رہی تھی بِاَعْيُنِنَا ۚ : ہماری نگاہوں کے سامنے۔ ساتھ جَزَآءً : بدلہ تھا لِّمَنْ : اس کے لیے جو كَانَ كُفِرَ : تھا انکار کیا گیا۔ کفر کیا گیا جو ہماری آنکھوں کے سامنے چل رہی تھی۔ بدلہ اس کی طرف سے جس کا کفر کیا گیا تھا۔
54,15,وَ لَقَدْ تَّرَكْنٰهَاۤ اٰیَةً فَهَلْ مِنْ مُّدَّكِرٍ وَلَقَدْ تَّرَكْنٰهَآ : اور البتہ تحقیق چھوڑ دیا ہم نے اس کو اٰيَةً : ایک نشانی کے طور پر فَهَلْ : تو کیا مِنْ مُّدَّكِرٍ : ہے کوئی نصیحت حاصل کرنے والا اور بیشک ہم نے اس واقعہ کو نشانی بنا کر باقی رکھا پس کوئی ہے نصیحت حاصل کرنے والا (1)
54,16,فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ فَكَيْفَ : تو کس طرح تھا كَانَ عَذَابِيْ : عذاب میرا وَنُذُرِ : اور ڈرانا میرا بتاؤ میرا عذاب اور میری ڈرانے والی باتیں کیسی رہیں ؟
54,17,وَ لَقَدْ یَسَّرْنَا الْقُرْاٰنَ لِلذِّكْرِ فَهَلْ مِنْ مُّدَّكِرٍ وَلَقَدْ : اور البتہ تحقیق يَسَّرْنَا الْقُرْاٰنَ : آسان کردیا ہم نے قرآن کو لِلذِّكْرِ : نصیحت کے لیے فَهَلْ : تو کیا مِنْ مُّدَّكِرٍ : ہے کوئی نصیحت پکڑنے والا اور بیشک ہم نے قرآن کو سمجھنے کے لئے آسان کردیا ہے (1) پس کیا کوئی نصیحت حاصل کرنے والا ہے۔
54,18,كَذَّبَتْ عَادٌ فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ كَذَّبَتْ : جھٹلایا عَادٌ : عاد نے فَكَيْفَ : تو کس طرح كَانَ عَذَابِيْ : تھا عذاب میرا وَنُذُرِ : اور ڈراوے میرے قوم عاد نے بھی جھٹلایا پس کیسا ہوا میرا عذاب اور میری ڈرانے والی باتیں۔
54,19,اِنَّاۤ اَرْسَلْنَا عَلَیْهِمْ رِیْحًا صَرْصَرًا فِیْ یَوْمِ نَحْسٍ مُّسْتَمِرٍّۙ اِنَّآ : بیشک ہم نے اَرْسَلْنَا : بھیجا ہم نے عَلَيْهِمْ : ان پر رِيْحًا : ایک ہوا کو صَرْصَرًا : تند۔ تیز فِيْ يَوْمِ نَحْسٍ : نحوست کے ایک دن مُّسْتَمِرٍّ : مستقل۔ مسلسل ہم نے ان پر تیز و تند مسلسل چلنے والی ہوا، ایک منحوس دن میں بھیج دی (1)
54,20,تَنْزِعُ النَّاسَ١ۙ كَاَنَّهُمْ اَعْجَازُ نَخْلٍ مُّنْقَعِرٍ تَنْزِعُ النَّاسَ ۙ : اکھاڑ کر پھینک رہی تھی لوگوں کو كَاَنَّهُمْ : گویا کہ وہ اَعْجَازُ نَخْلٍ : تنے تھے کھجور کے مُّنْقَعِرٍ : جڑے سے کٹے ہوئے۔ جڑے سے اکھڑے ہوئے جو لوگوں کو اٹھا اٹھا کر دے پٹختی تھی، گویا کہ وہ جڑ سے کٹے ہوئے کھجور کے تنے ہیں۔
54,21,فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ فَكَيْفَ : تو کس طرح كَانَ عَذَابِيْ : تھا میرا عذاب وَنُذُرِ : ڈرانا میرا۔ ڈراوے میرے پس کیسی رہی میری سزا اور میرا ڈرانا۔
54,22,وَ لَقَدْ یَسَّرْنَا الْقُرْاٰنَ لِلذِّكْرِ فَهَلْ مِنْ مُّدَّكِرٍ۠    ۧ وَلَقَدْ : اور البتہ تحقیق يَسَّرْنَا الْقُرْاٰنَ : آسان کردیا ہم نے قرآن کو لِلذِّكْرِ : نصیحت کے لیے فَهَلْ مِنْ : تو کیا مُّدَّكِرٍ : ہے کوئی نصیحت پکڑنے والا یقیناً ہم نے قرآن کو نصیحت کے لئے آسان کردیا ہے، پس کیا ہے کوئی نصیحت حاصل کرنے والا۔
54,23,كَذَّبَتْ ثَمُوْدُ بِالنُّذُرِ كَذَّبَتْ : جھٹلایا ثَمُوْدُ بالنُّذُرِ : ثمود نے ڈراووں کو۔ تنبیہات کو قوم ثمود نے ڈرانے والوں کو جھٹلایا۔
54,24,فَقَالُوْۤا اَبَشَرًا مِّنَّا وَاحِدًا نَّتَّبِعُهٗۤ١ۙ اِنَّاۤ اِذًا لَّفِیْ ضَلٰلٍ وَّ سُعُرٍ فَقَالُوْٓا : تو انہوں نے کہا اَبَشَرًا مِّنَّا : کیا ایک انسان ہے ہم میں سے وَاحِدًا : ایک ہی نَّتَّبِعُهٗٓ ۙ : ہم پیروی کریں اس کی اِنَّآ اِذًا : بیشک ہم تب لَّفِيْ ضَلٰلٍ : البتہ گمراہی میں ہوں گے وَّسُعُرٍ : اور جنون میں اور کہنے لگے کیا ہم ایک شخص کی فرمانبرداری کرنے لگیں گے ؟ تب تم یقیناً غلطی اور دیوانگی میں پڑے ہوئے ہونگے (1)
54,25,ءَاُلْقِیَ الذِّكْرُ عَلَیْهِ مِنْۢ بَیْنِنَا بَلْ هُوَ كَذَّابٌ اَشِرٌ ءَاُلْقِيَ : کیا ڈالا گیا الذِّكْرُ : ذکر۔ نصیحت عَلَيْهِ : اس پر مِنْۢ بَيْنِنَا : ہمارے درمیان سے بَلْ هُوَ كَذَّابٌ : بلکہ وہ سخت جھوٹا ہے اَشِرٌ : اترانے والا کیا ہمارے سب کے درمیان صرف اسی پر وحی اتاری گئی ؟ نہیں بلکہ وہ جھوٹا شیخی خور ہے (1)
54,26,سَیَعْلَمُوْنَ غَدًا مَّنِ الْكَذَّابُ الْاَشِرُ سَيَعْلَمُوْنَ : عنقریب وہ جان لیں گے غَدًا : کل مَّنِ الْكَذَّابُ : کون جھوٹا ہے الْاَشِرُ : اترانے والا ہے اب سب جان لیں گے کل کو کہ کون جھوٹا اور شیخی خور تھا ؟ (1)
54,27,اِنَّا مُرْسِلُوا النَّاقَةِ فِتْنَةً لَّهُمْ فَارْتَقِبْهُمْ وَ اصْطَبِرْ٘ اِنَّا مُرْسِلُوا : بیشک ہم بھیجنے والے ہیں النَّاقَةِ : اونٹنی کو فِتْنَةً لَّهُمْ : آزمائش کے طور پر ان کے لیے فَارْتَقِبْهُمْ : پس انتظار کرو ان کا وَاصْطَبِرْ : اور صبر کرو بیشک ہم ان کی آزمائش کے لئے اونٹنی بھیجیں گے (1) پس (اے صالح) تو ان کا منتظر رہ اور صبر کر۔
54,28,وَ نَبِّئْهُمْ اَنَّ الْمَآءَ قِسْمَةٌۢ بَیْنَهُمْ١ۚ كُلُّ شِرْبٍ مُّحْتَضَرٌ وَنَبِّئْهُمْ : اور آگاہ کرو ان کو اَنَّ الْمَآءَ : بیشک پانی قِسْمَةٌۢ بَيْنَهُمْ ۚ : تقسیم کیا ہوا ہے ان کے درمیان كُلُّ شِرْبٍ : ہر ایک کے پانی کی باری مُّحْتَضَرٌ : حاضر کی گئی ہے ہاں انہیں خبردار کر دے کہ پانی ان میں تقسیم شدہ ہے۔ (1) ہر ایک اپنی باری پر حاضر ہوگا (2)
54,29,فَنَادَوْا صَاحِبَهُمْ فَتَعَاطٰى فَعَقَرَ فَنَادَوْا : تو انہوں نے پکارا صَاحِبَهُمْ : اپنے ساتھی کو فَتَعَاطٰى : تو اس نے پکڑا فَعَقَرَ : تو کاٹ ڈالا۔ کونچیں کاٹ ڈالیں انہوں نے اپنے ساتھی کو آواز دی (1) جس نے (اونٹنی پر) وار کیا (2) اور (اس کی) کوچیں کاٹ دیں۔
54,30,فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ فَكَيْفَ : پھر کس طرح كَانَ عَذَابِيْ : تھا عذاب میرا وَنُذُرِ : اور ڈراوے میرے پس کیونکر ہوا میرا عذاب اور میرا ڈرانا۔
54,31,اِنَّاۤ اَرْسَلْنَا عَلَیْهِمْ صَیْحَةً وَّاحِدَةً فَكَانُوْا كَهَشِیْمِ الْمُحْتَظِرِ اِنَّآ : بیشک ہم نے اَرْسَلْنَا : بھیجا ہم نے عَلَيْهِمْ : ان پر صَيْحَةً : ایک دھماکہ وَّاحِدَةً : بس ایک ہی فَكَانُوْا : تو تھے وہ كَهَشِيْمِ : مانند گھاس کے الْمُحْتَظِرِ : باڑے والے کی ہم نے ان پر ایک چیخ بھیجی پس ایسے ہوگئے جیسے باڑ بنانے والے کی روندی ہوئی گھاس (1)
54,32,وَ لَقَدْ یَسَّرْنَا الْقُرْاٰنَ لِلذِّكْرِ فَهَلْ مِنْ مُّدَّكِرٍ وَلَقَدْ : اور البتہ تحقیق يَسَّرْنَا الْقُرْاٰنَ : آسان کردیا ہم نے قرآن کو لِلذِّكْرِ : نصیحت کے لیے فَهَلْ مِنْ مُّدَّكِرٍ : تو ہے کوئی نصیحت پکڑنے والا اور ہم نے نصیحت کے لئے قرآن کو آسان کردیا پس کیا ہے کوئی جو نصیحت قبول کرے۔
54,33,كَذَّبَتْ قَوْمُ لُوْطٍۭ بِالنُّذُرِ كَذَّبَتْ قَوْمُ لُوْطٍۢ : جھٹلایا قوم لوط نے بِالنُّذُرِ : ڈراووں کو۔ ڈرانے والوں کو قوم لوط نے بھی ڈرانے والوں کو جھٹلایا۔
54,34,اِنَّاۤ اَرْسَلْنَا عَلَیْهِمْ حَاصِبًا اِلَّاۤ اٰلَ لُوْطٍ١ؕ نَجَّیْنٰهُمْ بِسَحَرٍۙ اِنَّآ : بھیجا ہم نے اَرْسَلْنَا : بھیجی ہم نے عَلَيْهِمْ : ان پر حَاصِبًا : پتھروں کی بارش اِلَّآ اٰلَ لُوْطٍ ۭ : سوائے آل لوط کے نَجَّيْنٰهُمْ : نجات دی ہم نے ان کو بِسَحَرٍ : رات کے آخری حصے میں۔ سحر کے وقت بیشک ہم نے ان پر پتھر برسانے والی ہوا بھیجی (1) سوائے لوط ؑ کے گھر والوں کے، انہیں ہم نے سحر کے وقت نجات دی۔
54,35,نِّعْمَةً مِّنْ عِنْدِنَا١ؕ كَذٰلِكَ نَجْزِیْ مَنْ شَكَرَ نِّعْمَةً : بطور نعمت مِّنْ عِنْدِنَا ۭ : ہمارے پاس سے كَذٰلِكَ نَجْزِيْ : اسی طرح ہم بدلہ دیتے ہیں مَنْ : اسے شَكَرَ : جو شکر ادا کرے اپنے احسان سے (1) ہر ہر شکر گزار کو ہم اسی طرح بدلہ دیتے ہیں۔
54,36,وَ لَقَدْ اَنْذَرَهُمْ بَطْشَتَنَا فَتَمَارَوْا بِالنُّذُرِ وَلَقَدْ : اور البتہ تحقیق اَنْذَرَهُمْ : اس نے ڈرایا ان کو (لوط نے) بَطْشَتَنَا : ہماری پکڑ سے فَتَمَارَوْا بالنُّذُرِ : تو وہ جھگڑے تنبیہات پر یقیناً (لوط علیہ السلام) نے انہیں ہماری پکڑ سے ڈرایا (1) تھا لیکن انہوں نے ڈرانے والے کے بارے میں (شک و شبہ اور) جھگڑا کیا (2)
54,37,وَ لَقَدْ رَاوَدُوْهُ عَنْ ضَیْفِهٖ فَطَمَسْنَاۤ اَعْیُنَهُمْ فَذُوْقُوْا عَذَابِیْ وَ نُذُرِ وَلَقَدْ رَاوَدُوْهُ : اور البتہ تحقیق انہوں نے بہلایا اس کو عَنْ ضَيْفِهٖ : اس کے مہمانوں سے فَطَمَسْنَآ اَعْيُنَهُمْ : تو موند ڈالیں ہم نے ان کی آنکھیں فَذُوْقُوْا : تو چکھو عَذَابِيْ وَنُذُرِ : عذاب میر اور ڈراوے میرے اور ان (لوط علیہ السلام) کو ان کے مہمانوں کے بارے میں پھسلایا (1) پس ہم نے ان کی آنکھیں اندھی کردیں (2) اور کہہ دیا میرا ڈرانا اور میرا عذاب چکھو۔
54,38,وَ لَقَدْ صَبَّحَهُمْ بُكْرَةً عَذَابٌ مُّسْتَقِرٌّۚ وَلَقَدْ : اور البتہ تحقیق صَبَّحَهُمْ : صبح کی ان پر بُكْرَةً : صبح سویرے عَذَابٌ : ایک عذاب نے مُّسْتَقِرٌّ : مستقل۔ اٹل اور یقینی بات ہے کہ انہیں صبح سویرے ہی ایک جگہ پکڑنے والے مقررہ عذاب نے غارت کردیا (1)۔
54,39,فَذُوْقُوْا عَذَابِیْ وَ نُذُرِ فَذُوْقُوْا : تو چکھو عَذَابِيْ وَنُذُرِ : عذاب میرا اور ڈراوے میرے پس میرے عذاب اور میرے ڈراوے کا مزہ چکھو۔
54,40,وَ لَقَدْ یَسَّرْنَا الْقُرْاٰنَ لِلذِّكْرِ فَهَلْ مِنْ مُّدَّكِرٍ۠    ۧ وَلَقَدْ يَسَّرْنَا : اور البتہ تحقیق آسان کردیا ہم نے الْقُرْاٰنَ : قرآن کو لِلذِّكْرِ : نصیحت کے لیے فَهَلْ مِنْ مُّدَّكِرٍ : تو کیا کوئی نصیحت پکڑنے والا ہے اور یقیناً ہم نے قرآن کو پند و واعظ کے لئے آسان کردیا ہے (1) پس کیا کوئی ہے نصیحت پکڑنے والا۔
54,41,وَ لَقَدْ جَآءَ اٰلَ فِرْعَوْنَ النُّذُرُۚ وَلَقَدْ : اور البتہ تحقیق جَآءَ : آئے اٰلَ فِرْعَوْنَ النُّذُرُ : آل فرعون کے پاس ڈراوے اور فرعونیوں کے پاس بھی ڈرانے والے آئے۔
54,42,كَذَّبُوْا بِاٰیٰتِنَا كُلِّهَا فَاَخَذْنٰهُمْ اَخْذَ عَزِیْزٍ مُّقْتَدِرٍ كَذَّبُوْا بِاٰيٰتِنَا : انہوں نے جھٹلایا ہماری آیات کو كُلِّهَا : ساری کی ساری فَاَخَذْنٰهُمْ : تو پکڑ لیا ہم نے ان کو اَخْذَ عَزِيْزٍ مُّقْتَدِرٍ : پکڑنا زبردست اقتدار والے کا انہوں نے ہماری تمام نشانیاں جھٹلائیں (1) پس ہم نے بڑے غالب قوی پکڑنے والے کی طرح پکڑ لیا۔
54,43,اَكُفَّارُكُمْ خَیْرٌ مِّنْ اُولٰٓئِكُمْ اَمْ لَكُمْ بَرَآءَةٌ فِی الزُّبُرِۚ اَكُفَّارُكُمْ : کیا کفار تمہارے خَيْرٌ : بہتر ہیں مِّنْ اُولٰٓئِكُمْ : ان لوگوں سے اَمْ لَكُمْ بَرَآءَةٌ : یا تمہارے لیے کوئی معافی ہے فِي الزُّبُرِ : صحیفوں میں اے قریشیو ! کیا تمہارے کافر ان کافروں سے کچھ بہتر ہیں ؟ (1) یا تمہارے لئے اگلی کتابوں میں چھٹکارا لکھا ہوا ہے۔
54,44,اَمْ یَقُوْلُوْنَ نَحْنُ جَمِیْعٌ مُّنْتَصِرٌ اَمْ يَقُوْلُوْنَ : یا وہ کہتے ہیں نَحْنُ جَمِيْعٌ : ہم سب کے سب۔ جماعت مُّنْتَصِرٌ : بدلہ لینے والے ہیں یا یہ کہتے ہیں کہ ہم غلبہ پانے والی جماعت ہیں (1)۔
54,45,سَیُهْزَمُ الْجَمْعُ وَ یُوَلُّوْنَ الدُّبُرَ سَيُهْزَمُ : عنقریب شکست کھاجائے گا الْجَمْعُ : جتھا وَيُوَلُّوْنَ الدُّبُرَ : اور وہ پھیر لیں گے پشت۔ پیٹھ عنقریب یہ جماعت شکست دی جائے گی اور پیٹھ دے کر بھاگے گی (1)
54,46,بَلِ السَّاعَةُ مَوْعِدُهُمْ وَ السَّاعَةُ اَدْهٰى وَ اَمَرُّ بَلِ السَّاعَةُ : بلکہ قیامت مَوْعِدُهُمْ : ان کے وعدے کی جگہ ہے۔ وقت ہے وَالسَّاعَةُ : اور قیامت اَدْهٰى : بہت سخت ہے وَاَمَرُّ : اور بہت کڑوی بلکہ قیامت کی گھڑی ان کے وعدے کے وقت ہے اور قیامت بڑی سخت اور کڑوی چیز ہے (1)
54,47,اِنَّ الْمُجْرِمِیْنَ فِیْ ضَلٰلٍ وَّ سُعُرٍۘ اِنَّ الْمُجْرِمِيْنَ : بیشک مجرم لوگ فِيْ ضَلٰلٍ : گمراہی میں ہیں وَّسُعُرٍ : اور جنون میں بیشک گناہ گار گمراہی میں اور عذاب میں ہیں۔
54,48,یَوْمَ یُسْحَبُوْنَ فِی النَّارِ عَلٰى وُجُوْهِهِمْ١ؕ ذُوْقُوْا مَسَّ سَقَرَ يَوْمَ يُسْحَبُوْنَ : جس دن وہ گھسیٹے جائیں گے فِي النَّارِ : آگ میں عَلٰي وُجُوْهِهِمْ ۭ : اپنے چہروں کے بل (کہا جائے گا) ذُوْقُوْا مَسَّ : چکھو لپٹنا۔ چھونا۔ مس سَقَرَ : دوزخ کا جس دن وہ اپنے منہ کے بل آگ میں گھسیٹے جائیں گے (اور ان سے کہا جائے گا) دوزخ کی آگ لگنے کے مزے چکھو (3)
54,49,اِنَّا كُلَّ شَیْءٍ خَلَقْنٰهُ بِقَدَرٍ اِنَّا : بیشک ہم نے كُلَّ شَيْءٍ : ہر چیز کو خَلَقْنٰهُ بِقَدَرٍ : پیدا کیا ہم نے اس کو ایک اندازے کے ساتھ بیشک ہم نے ہر چیز کو ایک (مقررہ) اندازے سے پیدا کیا ہے۔
54,50,وَ مَاۤ اَمْرُنَاۤ اِلَّا وَاحِدَةٌ كَلَمْحٍۭ بِالْبَصَرِ وَمَآ اَمْرُنَآ : اور نہیں حکم ہمارا اِلَّا وَاحِدَةٌ : مگر یکبارگی۔ ایک ہی بار كَلَمْحٍۢ : مانند جھپکنے کے بِالْبَصَرِ : نگاہ کے اور ہمارا حکم صرف ایک دفعہ (کا ایک کلمہ) ہی ہوتا ہے جیسے آنکھ کا جھپکنا۔
54,51,وَ لَقَدْ اَهْلَكْنَاۤ اَشْیَاعَكُمْ فَهَلْ مِنْ مُّدَّكِرٍ وَلَقَدْ اَهْلَكْنَآ : اور البتہ تحقیق ہلاک کیا ہم نے اَشْيَاعَكُمْ : تمہارے جیسوں کو۔ تمہارے گروہوں کو فَهَلْ : تو کیا مِنْ مُّدَّكِرٍ : ہے کوئی نصیحت پکڑنے والا اور ہم نے تم جیسے بہتیروں کو ہلاک کردیا ہے (1) پس کوئی ہے نصیحت لینے والا۔
54,52,وَ كُلُّ شَیْءٍ فَعَلُوْهُ فِی الزُّبُرِ وَكُلُّ شَيْءٍ : اور ہر چیز فَعَلُوْهُ : انہوں نے کیا اس کو فِي الزُّبُرِ : صحیفوں میں ہے جو کچھ انہوں نے (اعمال) کئے ہیں سب نامہ اعمال میں لکھے ہوئے ہیں (1)۔
54,53,وَ كُلُّ صَغِیْرٍ وَّ كَبِیْرٍ مُّسْتَطَرٌ وَكُلُّ : اور ہر صَغِيْرٍ وَّكَبِيْرٍ : چھوٹا اور بڑا مُّسْتَطَرٌ : لکھا ہوا ہے (اسی طرح) ہر چھوٹی بڑی بات لکھی ہوئی ہے (1)
54,54,اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ نَهَرٍۙ اِنَّ الْمُتَّقِيْنَ : بیشک تقوی والے فِيْ جَنّٰتٍ : باغوں میں ہوں گے وَّنَهَرٍ : اور نہروں میں یقیناً ہمارا ڈر رکھنے والے جنتوں اور نہروں میں ہونگے (1)
54,55,فِیْ مَقْعَدِ صِدْقٍ عِنْدَ مَلِیْكٍ مُّقْتَدِرٍ۠    ۧ فِيْ مَقْعَدِ صِدْقٍ : سچی عزت کی جگہ۔ سچائی کی جگہ عِنْدَ مَلِيْكٍ : بادشاہ کے نزدیک مُّقْتَدِرٍ : جو اقتدار والا ہے راستی اور عزت کی بیٹھک میں (1) قدرت والے بادشاہ کے پاس۔
