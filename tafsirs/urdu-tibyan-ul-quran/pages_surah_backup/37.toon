quran[182]{c,v,t}:
37,1,وَ الصّٰٓفّٰتِ صَفًّاۙ وَ : قسم الصّٰٓفّٰتِ : صف باندھنے والے صَفًّا : پرا جما کر قسم صف باندھنے والے (فرشتوں) کی۔
37,2,فَالزّٰجِرٰتِ زَجْرًاۙ فَالزّٰجِرٰتِ : پھر ڈانٹنے والے زَجْرًا : جھڑک کر پھر پوری طرح ڈانٹنے والوں کی۔
37,3,فَالتّٰلِیٰتِ ذِكْرًاۙ فَالتّٰلِيٰتِ : پھر تلاوت کرنے والے ذِكْرًا : ذکر (قرآن) پھر ذکر اللہ کی تلاوت کرنے والوں کی۔
37,4,اِنَّ اِلٰهَكُمْ لَوَاحِدٌؕ اِنَّ : بیشک اِلٰهَكُمْ : تمہارا معبود لَوَاحِدٌ : البتہ ایک یقیناً تم سب کا معبود ایک ہی ہے (1)۔
37,5,رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا وَ رَبُّ الْمَشَارِقِؕ رَبُّ : پروردگار السَّمٰوٰتِ : آسمانوں وَالْاَرْضِ : اور زمین وَمَا بَيْنَهُمَا : اور جو ان کے درمیان وَرَبُّ : اور پروردگار الْمَشَارِقِ : مشرقوں آسمانوں اور زمین اور ان کے درمیان کی تمام چیزوں اور مشرقوں کا رب وہی ہے۔
37,6,اِنَّا زَیَّنَّا السَّمَآءَ الدُّنْیَا بِزِیْنَةِ اِ۟لْكَوَاكِبِۙ اِنَّا زَيَّنَّا : بیشک ہم نے مزین کیا السَّمَآءَ الدُّنْيَا : آسمان دنیا بِزِيْنَةِۨ : زینت سے الْكَوَاكِبِ : ستارے ہم نے آسمان دنیا کو ستاروں کی زینت سے آراستہ کیا۔
37,7,وَ حِفْظًا مِّنْ كُلِّ شَیْطٰنٍ مَّارِدٍۚ وَحِفْظًا : اور محفوظ کیا مِّنْ : سے كُلِّ شَيْطٰنٍ : ہر شیطان مَّارِدٍ : سرکش اور حفاظت کی سرکش شیطان سے (1)۔
37,8,لَا یَسَّمَّعُوْنَ اِلَى الْمَلَاِ الْاَعْلٰى وَ یُقْذَفُوْنَ مِنْ كُلِّ جَانِبٍۗۖ لَا يَسَّمَّعُوْنَ : کان نہیں لگا سکتے اِلَى : طرف الْمَلَاِ الْاَعْلٰي : ملائے اعلی وَيُقْذَفُوْنَ : اور مارے جاتے ہیں مِنْ : سے كُلِّ جَانِبٍ : ہر طرف عالم بالا کے فرشتوں (کی باتوں) کو سننے کے لئے وہ کان بھی نہیں لگا سکتے، بلکہ ہر طرف سے وہ مارے جاتے ہیں۔
37,9,دُحُوْرًا وَّ لَهُمْ عَذَابٌ وَّاصِبٌۙ دُحُوْرًا : بھگانے کو وَّلَهُمْ : اور ان کے لیے عَذَابٌ وَّاصِبٌ : عذاب دائمی بھگانے کے لئے اور ان کے لئے دائمی عذاب ہے۔
37,10,اِلَّا مَنْ خَطِفَ الْخَطْفَةَ فَاَتْبَعَهٗ شِهَابٌ ثَاقِبٌ اِلَّا : سوائے مَنْ : جو خَطِفَ : لے بھاگا الْخَطْفَةَ : اچک کر فَاَتْبَعَهٗ : تو اس کے پیچھے لگا شِهَابٌ ثَاقِبٌ : ایک انگارا دہکتا ہوا مگر جو کوئی ایک آدھ بات اچک لے بھاگے تو (فورا ہی) اس کے پیچھے دہکتا ہوا شعلہ لگ جاتا ہے۔
37,11,فَاسْتَفْتِهِمْ اَهُمْ اَشَدُّ خَلْقًا اَمْ مَّنْ خَلَقْنَا١ؕ اِنَّا خَلَقْنٰهُمْ مِّنْ طِیْنٍ لَّازِبٍ فَاسْتَفْتِهِمْ : پس ان سے پوچھیں اَهُمْ : کیا ان اَشَدُّ خَلْقًا : زیادہ مشکل پیدا کرنا اَمْ : یا مَّنْ : جو خَلَقْنَا ۭ : ہم نے پیدا کیا اِنَّا خَلَقْنٰهُمْ : بیشک ہم نے پیدا کیا انہیں مِّنْ : سے طِيْنٍ لَّازِبٍ : مٹی چپکتی ہوئی ان کافروں سے پوچھو تو کہ آیا ان کا پیدا کرنا زیادہ دشوار ہے یا (ان کا) جنہیں ہم نے ان کے علاوہ پیدا کیا ہے ؟ (1) ہم نے (انسانوں) کو لیسدار مٹی سے پیدا کیا ہے ؟ (2)۔
37,12,بَلْ عَجِبْتَ وَ یَسْخَرُوْنَ۪ بَلْ : بلکہ عَجِبْتَ : آپ نے تعجب کیا وَيَسْخَرُوْنَ : اور وہ مذاق اڑاتے ہیں بلکہ تو تعجب کر رہا ہے اور یہ مسخرا پن کر رہے ہیں (1)۔
37,13,وَ اِذَا ذُكِّرُوْا لَا یَذْكُرُوْنَ۪ وَاِذَا : اور جب ذُكِّرُوْا : نصیحت کی جائے لَا يَذْكُرُوْنَ : وہ نصیحت قبول نہیں کرتے اور جب انہیں نصیحت کی جاتی ہے یہ نہیں مانتے۔
37,14,وَ اِذَا رَاَوْا اٰیَةً یَّسْتَسْخِرُوْنَ۪ وَاِذَا : اور جب رَاَوْا : وہ دیکھتے ہیں اٰيَةً : کوئی نشانی يَّسْتَسْخِرُوْنَ : وہ ہنسی میں اڑا دیتے ہیں اور جب کسی معجزے کو دیکھتے ہیں تو مذاق اڑاتے ہیں۔
37,15,وَ قَالُوْۤا اِنْ هٰذَاۤ اِلَّا سِحْرٌ مُّبِیْنٌۚۖ وَقَالُوْٓا : اور انہوں نے کہا اِنْ : نہیں ھٰذَآ : یہ اِلَّا : مگر ۔ صرف سِحْرٌ مُّبِيْنٌ : جادو کھلا اور کہتے ہیں کہ یہ تو بالکل کھلم کھلا جادو ہی ہے (1)
37,16,ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَبْعُوْثُوْنَۙ ءَاِذَا : کیا جب مِتْنَا : ہم مرگئے وَكُنَّا : اور ہم ہوگئے تُرَابًا : مٹی وَّعِظَامًا : اور ہڈیاں ءَاِنَّا : کیا ہم لَمَبْعُوْثُوْنَ : پھر اٹھائے جائیں گے کیا جب ہم مرجائیں گے خاک اور ہڈی ہوجائیں گے پھر کیا (سچ مچ) ہم اٹھائے جائیں گے ؟
37,17,اَوَ اٰبَآؤُنَا الْاَوَّلُوْنَؕ اَوَ : کیا اٰبَآؤُنَا الْاَوَّلُوْنَ : ہمارے باپ دادا پہلے کیا ہم سے پہلے کے ہمارے باپ دادا بھی ؟
37,18,قُلْ نَعَمْ وَ اَنْتُمْ دَاخِرُوْنَۚ قُلْ : فرما دیں نَعَمْ : ہاں وَاَنْتُمْ : اور تم دَاخِرُوْنَ : ذلیل و خوار آپ جواب دیجئے کہ ہاں ہاں اور تم ذلیل (بھی) (1)۔
37,19,فَاِنَّمَا هِیَ زَجْرَةٌ وَّاحِدَةٌ فَاِذَا هُمْ یَنْظُرُوْنَ فَاِنَّمَا هِىَ : پس اس کے سوا نہیں وہ زَجْرَةٌ : للکار وَّاحِدَةٌ : ایک فَاِذَا : پس ناگہاں هُمْ : وہ يَنْظُرُوْنَ : دیکھنے لگیں گے وہ تو صرف ایک روز کی جھڑکی ہے (1) کہ یکایک یہ دیکھنے لگیں گے (2)۔
37,20,وَ قَالُوْا یٰوَیْلَنَا هٰذَا یَوْمُ الدِّیْنِ وَقَالُوْا : اور وہ کہیں گے يٰوَيْلَنَا : ہائے ہماری خرابی ھٰذَا : یہ يَوْمُ الدِّيْنِ : بدلے کا دن اور کہیں گے کہ ہائے ہماری خرابی یہی جزا (سزا) کا دن ہے۔
37,21,هٰذَا یَوْمُ الْفَصْلِ الَّذِیْ كُنْتُمْ بِهٖ تُكَذِّبُوْنَ۠    ۧ ھٰذَا : یہ يَوْمُ الْفَصْلِ : فیصلے کا دن الَّذِيْ : وہ جس كُنْتُمْ : تم تھے بِهٖ : اس کو تُكَذِّبُوْنَ : جھٹلاتے یہی فیصلہ کا دن ہے جسے تم جھٹلاتے ہو (1)
37,22,اُحْشُرُوا الَّذِیْنَ ظَلَمُوْا وَ اَزْوَاجَهُمْ وَ مَا كَانُوْا یَعْبُدُوْنَۙ اُحْشُرُوا : تم جمع کرو الَّذِيْنَ ظَلَمُوْا : وہ جنہوں نے ظلم کیا (ظالم) وَاَزْوَاجَهُمْ : اور ان کے جوڑے (ساتھی) وَمَا : اور جس كَانُوْا يَعْبُدُوْنَ : وہ پرستش کرتے تھے ظالموں کو (1) اور ان کے ہمراہیوں کو (2) اور (جن) جن کی وہ اللہ کے علاوہ پرستش کرتے تھے (5)۔
37,23,مِنْ دُوْنِ اللّٰهِ فَاهْدُوْهُمْ اِلٰى صِرَاطِ الْجَحِیْمِ مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا فَاهْدُوْهُمْ : پس تم ان کو دکھاؤ اِلٰى : طرف صِرَاطِ : راستہ الْجَحِيْمِ : جہنم (ان سب کو) جمع کرکے انہیں دوزخ کی راہ دکھا دو۔
37,24,وَ قِفُوْهُمْ اِنَّهُمْ مَّسْئُوْلُوْنَۙ وَقِفُوْهُمْ : اور ٹھہراؤ ان کو اِنَّهُمْ : بیشک وہ مَّسْئُوْلُوْنَ : ان سے پرستش ہوگی اور انہیں ٹھہرا لو، (1) اس لئے کہ ان سے ضروری سوال کیئے جانے والے ہیں۔
37,25,مَا لَكُمْ لَا تَنَاصَرُوْنَ مَا لَكُمْ : کیا ہوا تمہیں لَا تَنَاصَرُوْنَ : تم ایک دوسرے کی مدد نہیں کرتے تمہیں کیا ہوگیا ہے کہ (اس وقت) تم ایک دوسروں کی مدد نہیں کرتے۔
37,26,بَلْ هُمُ الْیَوْمَ مُسْتَسْلِمُوْنَ بَلْ هُمُ : بلکہ وہ الْيَوْمَ : آج مُسْتَسْلِمُوْنَ : سرجھکائے فرمانبردار بلکہ وہ (سب کے سب) آج فرمانبردار بن گئے۔
37,27,وَ اَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ وَاَقْبَلَ : اور رخ کرے گا بَعْضُهُمْ : ان میں سے بعض (ایک) عَلٰي بَعْضٍ : بعض پر دوسرے کی طرف يَّتَسَآءَلُوْنَ : باہم سوال کرتے ہوئے وہ ایک دوسرے کی طرف متوجہ ہو کر سوال و جواب کرنے لگیں گے۔
37,28,قَالُوْۤا اِنَّكُمْ كُنْتُمْ تَاْتُوْنَنَا عَنِ الْیَمِیْنِ قَالُوْٓا : وہ کہیں گے اِنَّكُمْ : بیشک تم كُنْتُمْ تَاْتُوْنَنَا : تم ہم پر آئے تھے عَنِ الْيَمِيْنِ : دائیں طرف سے کہیں گے کہ تم ہمارے پاس ہماری دائیں طرف سے آتے تھے (1)
37,29,قَالُوْا بَلْ لَّمْ تَكُوْنُوْا مُؤْمِنِیْنَۚ قَالُوْا : وہ کہیں گے بَلْ : بلکہ لَّمْ تَكُوْنُوْا : تم نہ تھے مُؤْمِنِيْنَ : ایمان لانے و الے وہ جواب دیں گے کہ نہیں بلکہ تم ہی ایماندار نہ تھے (1)
37,30,وَ مَا كَانَ لَنَا عَلَیْكُمْ مِّنْ سُلْطٰنٍ١ۚ بَلْ كُنْتُمْ قَوْمًا طٰغِیْنَ وَمَا : اور نہ كَانَ : تھا لَنَا : ہمارا عَلَيْكُمْ : تم پر مِّنْ سُلْطٰنٍ ۚ : کوئی زور بَلْ : بلکہ كُنْتُمْ : تم تھے قَوْمًا : ایک قوم طٰغِيْنَ : سرکش اور کچھ ہمارا زور تو تھا (ہی) نہیں، بلکہ تم (خود) سرکش لوگ تھے (1)
37,31,فَحَقَّ عَلَیْنَا قَوْلُ رَبِّنَاۤ١ۖۗ اِنَّا لَذَآئِقُوْنَ فَحَقَّ : پس ثابت ہوگئی عَلَيْنَا : ہم پر قَوْلُ : بات رَبِّنَآ ڰ : ہمارا رب اِنَّا : بیشک ہم لَذَآئِقُوْنَ : البتہ چکھنے والے اب تو ہم (سب) پر ہمارے رب کی بات ثابت ہوچکی کہ ہم (عذاب) چکھنے والے ہیں۔
37,32,فَاَغْوَیْنٰكُمْ اِنَّا كُنَّا غٰوِیْنَ فَاَغْوَيْنٰكُمْ : پس ہم نے بہکایا تمہیں اِنَّا كُنَّا : بیشک ہم تھے غٰوِيْنَ : گمراہ پس ہم نے تمہیں گمراہ کیا ہم خود گمراہ ہی تھے۔ (1)
37,33,فَاِنَّهُمْ یَوْمَئِذٍ فِی الْعَذَابِ مُشْتَرِكُوْنَ فَاِنَّهُمْ : پس بیشک وہ يَوْمَئِذٍ : اس دن فِي الْعَذَابِ : عذاب میں مُشْتَرِكُوْنَ : مشترک (شریک) سو اب آج کے دن (سب کے سب) عذاب میں شریک ہیں (1)
37,34,اِنَّا كَذٰلِكَ نَفْعَلُ بِالْمُجْرِمِیْنَ اِنَّا : بیشک ہم كَذٰلِكَ : اسی طرح نَفْعَلُ : کرتے ہیں بِالْمُجْرِمِيْنَ : مجرموں کے ساتھ ہم گناہگاروں کے ساتھ اسی طرح کرتے ہیں (1)
37,35,اِنَّهُمْ كَانُوْۤا اِذَا قِیْلَ لَهُمْ لَاۤ اِلٰهَ اِلَّا اللّٰهُ١ۙ یَسْتَكْبِرُوْنَۙ اِنَّهُمْ : بیشک وہ كَانُوْٓا : وہ تھے اِذَا : جب قِيْلَ : کہا جاتا لَهُمْ : ان کو لَآ : نہیں اِلٰهَ : کوئی معبود اِلَّا اللّٰهُ ۙ : اللہ کے سوا يَسْتَكْبِرُوْنَ : وہ تکبر کرتے تھے یہ وہ (لوگ) ہیں کہ جب ان سے کہا جاتا ہے کہ اللہ کے سوا کوئی معبود نہیں تو یہ سرکشی کرتے تھے (1)
37,36,وَ یَقُوْلُوْنَ اَئِنَّا لَتَارِكُوْۤا اٰلِهَتِنَا لِشَاعِرٍ مَّجْنُوْنٍؕ وَيَقُوْلُوْنَ : ور وہ کہتے ہیں اَئِنَّا : کیا ہم لَتَارِكُوْٓا : چھوڑ دینے والے اٰلِهَتِنَا : اپنے معبود لِشَاعِرٍ : ایک شاعر کی خاطر مَّجْنُوْنٍ : دیوانے اور کہتے تھے کہ کیا ہم اپنے معبودوں کو ایک دیوانے شاعر کی بات پر چھوڑ دیں (1)۔
37,37,بَلْ جَآءَ بِالْحَقِّ وَ صَدَّقَ الْمُرْسَلِیْنَ بَلْ : بلکہ جَآءَ : وہ آئے بِالْحَقِّ : حق کے ساتھ وَصَدَّقَ : اور تصدیق کی الْمُرْسَلِيْنَ : رسولوں کی (نہیں نہیں) بلکہ (نبی) تو حق (سچا دین) لائے ہیں اور سب رسولوں کو سچا جانتے ہیں (1)
37,38,اِنَّكُمْ لَذَآئِقُوا الْعَذَابِ الْاَلِیْمِۚ اِنَّكُمْ : بیشک تم لَذَآئِقُوا : ضرور چکھنے والے الْعَذَابِ : عذاب الْاَلِيْمِ : دردناک یقیناً تم دردناک عذاب (کا مزہ) چکھنے والے ہو۔
37,39,وَ مَا تُجْزَوْنَ اِلَّا مَا كُنْتُمْ تَعْمَلُوْنَۙ وَمَا تُجْزَوْنَ : اور تمہیں بدلہ نہ دیا جائے گا اِلَّا : مگر مَا : جو كُنْتُمْ تَعْمَلُوْنَ : تم کرتے تھے تمہیں اسکا بدلہ دیا جائے گا جو تم کرتے تھے (1)۔
37,40,اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ اِلَّا : مگر عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : خاص کیے ہوئے مگر اللہ تعالیٰ کے خالص برگزیدہ بندے (1)۔
37,41,اُولٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُوْمٌۙ اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے رِزْقٌ مَّعْلُوْمٌ : رزق معلوم انہیں کے لئے مقررہ روزی ہے۔
37,42,فَوَاكِهُ١ۚ وَ هُمْ مُّكْرَمُوْنَۙ فَوَاكِهُ ۚ : میوے وَهُمْ : اور وہ مُّكْرَمُوْنَ : اعزاز والے ہوں گے (ہر طرح) کے میوے، اور باعزت و اکرام ہونگے۔
37,43,فِیْ جَنّٰتِ النَّعِیْمِۙ فِيْ : میں جَنّٰتِ النَّعِيْمِ : نعمت کے باغات نعمتوں والی جنتوں میں۔
37,44,عَلٰى سُرُرٍ مُّتَقٰبِلِیْنَ عَلٰي : پر سُرُرٍ مُّتَقٰبِلِيْنَ : (جمع) تخت آمنے سامنے تختوں پر ایک دوسرے کے سامنے (بیٹھے) ہوں گے۔
37,45,یُطَافُ عَلَیْهِمْ بِكَاْسٍ مِّنْ مَّعِیْنٍۭۙ يُطَافُ : دورہ ہوگا عَلَيْهِمْ : ان پر۔ ان کے آگے بِكَاْسٍ : جام مِّنْ : سے ۔ کا مَّعِيْنٍۢ : بہتا ہوا مشروب جاری شراب کے جام کا ان پر دور چل رہا ہوگا (1)
37,46,بَیْضَآءَ لَذَّةٍ لِّلشّٰرِبِیْنَۚۖ بَيْضَآءَ : سفید لَذَّةٍ : لذت لِّلشّٰرِبِيْنَ : پینے والوں کے لیے جو صاف شفاف اور پینے میں لذیذ ہوگی (1)
37,47,لَا فِیْهَا غَوْلٌ وَّ لَا هُمْ عَنْهَا یُنْزَفُوْنَ لَا فِيْهَا : نہ اس میں غَوْلٌ : خرابی (درد سر) وَّلَا هُمْ : اور نہ وہ عَنْهَا : اس سے يُنْزَفُوْنَ : بہکی باتیں کریں گے نہ اس سے درد ہوگا اور نہ اسکے پینے سے بہکیں گے (1)
37,48,وَ عِنْدَهُمْ قٰصِرٰتُ الطَّرْفِ عِیْنٌۙ وَعِنْدَهُمْ : اور ان کے پاس قٰصِرٰتُ الطَّرْفِ : نیچی نگاہوں والیاں عِيْنٌ : بڑی آنکھوں والیاں اور ان کے پاس نیچی نظروں، بڑی بڑی آنکھوں والی (حوریں) ہونگی (1)
37,49,كَاَنَّهُنَّ بَیْضٌ مَّكْنُوْنٌ كَاَنَّهُنَّ : گویا وہ بَيْضٌ : انڈے مَّكْنُوْنٌ : پوشیدہ رکھے ہوئے ایسی جیسے چھپائے ہوئے انڈے (1)
37,50,فَاَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ فَاَقْبَلَ : پس رخ کرے گا بَعْضُهُمْ : ان میں سے بعض (ایک) عَلٰي بَعْضٍ : بعض پر (دوسرے کی طرف) يَّتَسَآءَلُوْنَ : باہم سوال کرتے ہوئے جنتی) ایک دوسرے کی طرف رخ کرکے پوچھیں گے (1)۔
37,51,قَالَ قَآئِلٌ مِّنْهُمْ اِنِّیْ كَانَ لِیْ قَرِیْنٌۙ قَالَ : کہے گا قَآئِلٌ : ایک کہنے والا مِّنْهُمْ : ان میں سے اِنِّىْ : یشک میں كَانَ : تھا لِيْ : میرا قَرِيْنٌ : ایک ہم نشین ان میں سے ایک کہنے والا کہے گا کہ میرا ایک ساتھی تھا
37,52,یَّقُوْلُ اَئِنَّكَ لَمِنَ الْمُصَدِّقِیْنَ يَّقُوْلُ : وہ کہتا تھا اَئِنَّكَ : کیا تو لَمِنَ : سے الْمُصَدِّقِيْنَ : سچے جاننے والے جو (مجھ سے) کہا کرتا تھا کیا تو (قیامت کے آنے کا) یقین کرنے والوں سے ہے ؟ (1)
37,53,ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَدِیْنُوْنَ ءَاِذَا : کیا جب مِتْنَا : ہم مرگئے وَكُنَّا : اور ہوگئے تُرَابًا : مٹی وَّعِظَامًا : اور ہڈیاں ءَاِنَّا : کیا ہم لَمَدِيْنُوْنَ : البتہ بدلہ دیے جائیں گے کیا جب ہم مر کر مٹی اور ہڈی ہوجائیں گے کیا اسوقت ہم جزا دیئے جانے والے ہیں ؟ (1)
37,54,قَالَ هَلْ اَنْتُمْ مُّطَّلِعُوْنَ قَالَ : وہ کہنے لگا هَلْ : کیا اَنْتُمْ : تم مُّطَّلِعُوْنَ : جھانکنے والے ہو کہے گا تم چاہتے ہو کہ جھانک کر دیکھ لو ؟ (1)
37,55,فَاطَّلَعَ فَرَاٰهُ فِیْ سَوَآءِ الْجَحِیْمِ فَاطَّلَعَ : تو وہ جھانکے گا فَرَاٰهُ : تو اسے دیکھے گا فِيْ : میں سَوَآءِ : درمیان الْجَحِيْمِ : دوزخ جھانکتے ہی اسے بیچوں بیچ جہنم میں (جلتا ہوا) دیکھے گا۔
37,56,قَالَ تَاللّٰهِ اِنْ كِدْتَّ لَتُرْدِیْنِۙ قَالَ : وہ کہے گا تَاللّٰهِ : اللہ کی قسم اِنْ كِدْتَّ : تو قریب تھا لَتُرْدِيْنِ : کہ تو مجھے ہلاک کر ڈالے کہے گا واللہ ! قریب تھا کہ مجھے (بھی) برباد کردے۔
37,57,وَ لَوْ لَا نِعْمَةُ رَبِّیْ لَكُنْتُ مِنَ الْمُحْضَرِیْنَ وَلَوْ : اور اگر لَا : نہ نِعْمَةُ : نعمت رَبِّيْ : میرا رب لَكُنْتُ : تو میں ضرور ہوتا مِنَ : سے الْمُحْضَرِيْنَ : حاضر کیے جانے والے اگر میرے رب کا احسان نہ ہوتا تو میں بھی دوزخ میں حاضر کئے جانے والوں میں ہوتا (1)
37,58,اَفَمَا نَحْنُ بِمَیِّتِیْنَۙ اَفَمَا نَحْنُ : کیا پس نہیں ہم بِمَيِّتِيْنَ : مرنے والوں میں سے کیا (یہ صحیح ہے) ہم مرنے والے ہی نہیں ؟ (1)
37,59,اِلَّا مَوْتَتَنَا الْاُوْلٰى وَ مَا نَحْنُ بِمُعَذَّبِیْنَ اِلَّا : سوائے مَوْتَتَنَا : ہماری موت الْاُوْلٰى : پہلی وَمَا : اور نہیں نَحْنُ : ہم بِمُعَذَّبِيْنَ : عذاب دیے جانے والوں میں سے بجز پہلی ایک موت کے، (1) اور ہم نہ عذاب کیے جانے والے ہیں۔
37,60,اِنَّ هٰذَا لَهُوَ الْفَوْزُ الْعَظِیْمُ اِنَّ : بیشک ھٰذَا : یہ لَهُوَ : البتہ وہ الْفَوْزُ الْعَظِيْمُ : کامیابی عظیم پھر تو (ظاہر بات ہے کہ) یہ بڑی کامیابی ہے (1)
37,61,لِمِثْلِ هٰذَا فَلْیَعْمَلِ الْعٰمِلُوْنَ لِمِثْلِ ھٰذَا : اس جیسی (نعمت) کے لیے فَلْيَعْمَلِ : پس چاہیے ضرور عمل کریں الْعٰمِلُوْنَ : عمل کرنے والے ایسی (کامیابی) کے عمل کرنے والوں کو عمل کرنا چاہیے (1)۔
37,62,اَذٰلِكَ خَیْرٌ نُّزُلًا اَمْ شَجَرَةُ الزَّقُّوْمِ اَذٰلِكَ : کیا یہ خَيْرٌ : بہتر نُّزُلًا : ضایفت اَمْ : یا شَجَرَةُ الزَّقُّوْمِ : درخت تھوہر کیا یہ مہمانی اچھی ہے یا (زقوم) کا درخت (1)
37,63,اِنَّا جَعَلْنٰهَا فِتْنَةً لِّلظّٰلِمِیْنَ اِنَّا : بیشک ہم جَعَلْنٰهَا : ہم نے اس کو بنایا فِتْنَةً : ایک آزمائش لِّلظّٰلِمِيْنَ : ظالموں کے لیے جسے ہم نے ظالموں کے لئے سخت آزمائش بنا رکھا ہے (1)
37,64,اِنَّهَا شَجَرَةٌ تَخْرُجُ فِیْۤ اَصْلِ الْجَحِیْمِۙ اِنَّهَا : بیشک وہ شَجَرَةٌ : ایک درخت تَخْرُجُ : وہ نکلتا ہے فِيْٓ : میں اَصْلِ : جڑ الْجَحِيْمِ : جہنم بیشک وہ درخت جہنم کی جڑ میں سے نکلتا ہے (1)
37,65,طَلْعُهَا كَاَنَّهٗ رُءُوْسُ الشَّیٰطِیْنِ طَلْعُهَا : اس کا خوشہ كَاَنَّهٗ : گویا کہ وہ رُءُوْسُ : سر (جمع) الشَّيٰطِيْنِ : شیطانوں جسکے خوشے شیطانوں کے سروں جیسے ہوتے ہیں (1)۔
37,66,فَاِنَّهُمْ لَاٰكِلُوْنَ مِنْهَا فَمَالِئُوْنَ مِنْهَا الْبُطُوْنَؕ فَاِنَّهُمْ : پس بیشک وہ لَاٰكِلُوْنَ : کھانے والے ہیں مِنْهَا : اس سے فَمَالِئُوْنَ : سو بھرنے والے مِنْهَا : اس سے الْبُطُوْنَ : پیٹ (جمع) (جہنمی) اسی درخت میں سے کھائیں گے اور اسی سے پیٹ بھریں گے (1)۔
37,67,ثُمَّ اِنَّ لَهُمْ عَلَیْهَا لَشَوْبًا مِّنْ حَمِیْمٍۚ ثُمَّ : پھر اِنَّ : بیشک لَهُمْ : ان کے لیے عَلَيْهَا : اس پر لَشَوْبًا : ملا ملا کر مِّنْ : سے حَمِيْمٍ : کھولتا ہوا پانی پھر اس پر گرم کھولتا ہوا پانی پلایا جائیگا (1)
37,68,ثُمَّ اِنَّ مَرْجِعَهُمْ لَاۡاِلَى الْجَحِیْمِ ثُمَّ : پھر اِنَّ : بیشک مَرْجِعَهُمْ : ان کی بازگشت لَا۟ : البتہ اِلَى : طرف الْجَحِيْمِ : جہنم پھر ان سب کا لوٹنا جہنم کی بھڑکتی ہوئی آگ کی طرف ہوگا (1)۔
37,69,اِنَّهُمْ اَلْفَوْا اٰبَآءَهُمْ ضَآلِّیْنَۙ اِنَّهُمْ : بیشک ان اَلْفَوْا : انہوں نے پایا اٰبَآءَهُمْ : اپنے باپ دادا ضَآلِّيْنَ : گمراہ (جمع) یقین مانو ! کہ انہوں نے اپنے باپ دادا کو بہکایا ہوا پایا۔
37,70,فَهُمْ عَلٰۤى اٰثٰرِهِمْ یُهْرَعُوْنَ فَهُمْ : سو وہ عَلٰٓي اٰثٰرِهِمْ : ان کے نقش قدم پر يُهْرَعُوْنَ : دوڑتے جاتے تھے یہ انہی کے نشان قدم پر دوڑتے رہے (1)
37,71,وَ لَقَدْ ضَلَّ قَبْلَهُمْ اَكْثَرُ الْاَوَّلِیْنَۙ وَلَقَدْ ضَلَّ : اور تحقیق گمراہ ہوئے قَبْلَهُمْ : ان سے پہلے اَكْثَرُ الْاَوَّلِيْنَ : اگلوں میں سے اکثر ان سے پہلے بھی بہت سے اگلے بہک چکے ہیں (1)
37,72,وَ لَقَدْ اَرْسَلْنَا فِیْهِمْ مُّنْذِرِیْنَ وَلَقَدْ اَرْسَلْنَا : اور تحقیق ہم نے بھیجے فِيْهِمْ : ان میں مُّنْذِرِيْنَ : ڈرانے والے جن میں ہم نے ڈرانے والے (رسول) بھیجے تھے (1)
37,73,فَانْظُرْ كَیْفَ كَانَ عَاقِبَةُ الْمُنْذَرِیْنَۙ فَانْظُرْ : سو دیکھیں كَيْفَ : کیسا كَانَ : ہوا عَاقِبَةُ : انجام الْمُنْذَرِيْنَ : جنہیں ڈرایا گیا اب تو دیکھ لے کہ جنہیں دھمکایا گیا تھا ان کا انجام کیسا ہوا
37,74,اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ۠    ۧ اِلَّا : مگر عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : خاص کیے ہوئے سوائے اللہ کے برگزیدہ بندوں کے (1)
37,75,وَ لَقَدْ نَادٰىنَا نُوْحٌ فَلَنِعْمَ الْمُجِیْبُوْنَ٘ۖ وَلَقَدْ نَادٰىنَا : اور تحقیق ہمیں پکارا نُوْحٌ : نوح فَلَنِعْمَ : سو ہم البتہ خوب الْمُجِيْبُوْنَ : دعا قبول کرنے والے اور ہمیں نوح ؑ نے پکارا تو (دیکھ لو) ہم کیسے اچھے دعا قبول کرنے والے ہیں (1)۔
37,76,وَ نَجَّیْنٰهُ وَ اَهْلَهٗ مِنَ الْكَرْبِ الْعَظِیْمِ٘ۖ وَنَجَّيْنٰهُ : اور ہم نے نجات دی اسے وَاَهْلَهٗ : اور اس کے گھر والے مِنَ : سے الْكَرْبِ : مصیبت الْعَظِيْمِ : بڑی ہم نے اسے اور اس کے گھر والوں کو (1) اس زبردست مصیبت سے بچا لیا۔
37,77,وَ جَعَلْنَا ذُرِّیَّتَهٗ هُمُ الْبٰقِیْنَ٘ۖ وَجَعَلْنَا : اور ہم نے کیا ذُرِّيَّتَهٗ : اس کی اولاد هُمُ : وہ الْبٰقِيْنَ : باقی رہنے والی اور اس کی اولاد کو باقی رہنے والی بنادی (1)
37,78,وَ تَرَكْنَا عَلَیْهِ فِی الْاٰخِرِیْنَ٘ۖ وَتَرَكْنَا : اور ہم نے چھوڑا عَلَيْهِ : اس پر۔ اس کا فِي : میں الْاٰخِرِيْنَ : بعد میں آنے والے اور ہم نے اس کا (ذکر خیر) پچھلوں میں باقی رکھا (1)
37,79,سَلٰمٌ عَلٰى نُوْحٍ فِی الْعٰلَمِیْنَ سَلٰمٌ : سلام ہو عَلٰي : پر نُوْحٍ : نوح فِي الْعٰلَمِيْنَ : سارے جہانوں میں نوح ؑ پر تمام جہانوں میں سلام ہو۔
37,80,اِنَّا كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ اِنَّا : بیشک ہم كَذٰلِكَ : اسی طرح نَجْزِي : ہم جزا دیتے ہیں الْمُحْسِنِيْنَ : نیکوکاروں ہم نیکی کرنے والوں کو اسی طرح بدلہ دیتے ہیں (1)
37,81,اِنَّهٗ مِنْ عِبَادِنَا الْمُؤْمِنِیْنَ اِنَّهٗ : بیشک وہ مِنْ : سے عِبَادِنَا : ہمارے بندے الْمُؤْمِنِيْنَ : مومن (جمع) وہ ہمارے ایماندار بندوں میں سے تھا۔
37,82,ثُمَّ اَغْرَقْنَا الْاٰخَرِیْنَ ثُمَّ : پھر اَغْرَقْنَا : ہم نے غرق کردیا الْاٰخَرِيْنَ : دوسرے پھر ہم نے دوسروں کو ڈبو دیا۔
37,83,وَ اِنَّ مِنْ شِیْعَتِهٖ لَاِبْرٰهِیْمَۘ وَاِنَّ : اور بیشک مِنْ : سے شِيْعَتِهٖ : اس کے طریقے پر چلنے والے لَاِبْرٰهِيْمَ : البتہ ابراہیم اور اس (نوح علیہ السلام) کی تابعداری کرنے والوں میں سے (ہی) ابراہیم ؑ (بھی) تھے (1)
37,84,اِذْ جَآءَ رَبَّهٗ بِقَلْبٍ سَلِیْمٍ اِذْ جَآءَ : (یاد کرو) جب وہ آیا رَبَّهٗ : اپنا رب بِقَلْبٍ : دل کے ساتھ سَلِيْمٍ : صاف جبکہ اپنے رب کے پاس بےعیب دل لائے۔
37,85,اِذْ قَالَ لِاَبِیْهِ وَ قَوْمِهٖ مَا ذَا تَعْبُدُوْنَۚ اِذْ قَالَ : جب اس نے کہا لِاَبِيْهِ : اپنے باپ کو وَقَوْمِهٖ : اور اپنی قوم مَاذَا : کس چیز تَعْبُدُوْنَ : تم پرستش کرتے ہو انہوں نے اپنے باپ اور اپنی قوم سے کہا کہ تم کیا پوج رہے ہو ؟
37,86,اَئِفْكًا اٰلِهَةً دُوْنَ اللّٰهِ تُرِیْدُوْنَؕ اَئِفْكًا : کیا جھوٹ موٹ کے اٰلِهَةً : معبود دُوْنَ اللّٰهِ : اللہ کے سوا تُرِيْدُوْنَ : تم چاہتے ہو کیا تم اللہ کے سوا گھڑے ہوئے معبود چاہتے ہو ؟ (1)
37,87,فَمَا ظَنُّكُمْ بِرَبِّ الْعٰلَمِیْنَ فَمَا : سو کیا ظَنُّكُمْ : تمہارا گمان بِرَبِّ : پروردگار کے بارے میں الْعٰلَمِيْنَ : تمام جہانوں تو یہ (بتلاؤ کہ) تم نے رب العالمین کو کیا سمجھ رکھا ہے ؟ (1)
37,88,فَنَظَرَ نَظْرَةً فِی النُّجُوْمِۙ فَنَظَرَ : پھر اس نے دیکھا نَظْرَةً : ایک نظر فِي : میں۔ کو النُّجُوْمِ : ستارے اب ابراہیم ؑ نے ایک نگاہ ستاروں کی طرف اٹھائی۔
37,89,فَقَالَ اِنِّیْ سَقِیْمٌ فَقَالَ : تو اس نے کہا اِنِّىْ : بیشک میں سَقِيْمٌ : بیمار ہوں اور کہا میں بیمار ہوں (1)۔
37,90,فَتَوَلَّوْا عَنْهُ مُدْبِرِیْنَ فَتَوَلَّوْا : پس وہ پھرگئے عَنْهُ : اس سے مُدْبِرِيْنَ : پیٹھ پھیر کر اس پر سب اس سے منہ موڑے ہوئے واپس چلے گئے۔
37,91,فَرَاغَ اِلٰۤى اٰلِهَتِهِمْ فَقَالَ اَلَا تَاْكُلُوْنَۚ فَرَاغَ : پھر پوشیدہ گھس کیا اِلٰٓى : طرف۔ میں اٰلِهَتِهِمْ : ان کے معبودوں فَقَالَ : پھر کہنے لگا اَلَا تَاْكُلُوْنَ : کیا تم نہیں کھاتے آپ (چپ چپاتے) ان کے معبودوں کے پاس گئے اور فرمانے لگے تم کھاتے کیوں نہیں ؟ (1)
37,92,مَا لَكُمْ لَا تَنْطِقُوْنَ مَا لَكُمْ : کیا ہوا تمہیں ؟ لَا تَنْطِقُوْنَ : تم بولتے نہیں تمہیں کیا ہوگیا بات نہیں کرتے ہو۔
37,93,فَرَاغَ عَلَیْهِمْ ضَرْبًۢا بِالْیَمِیْنِ فَرَاغَ : پھر جا پڑا وہ عَلَيْهِمْ : ان پر ضَرْبًۢا : مارتا ہوا بِالْيَمِيْنِ : اپنے دائیں ہاتھ (قدرت سے) پھر تو (پوری قوت کے ساتھ) دائیں ہاتھ سے انہیں مارنے پر پل پڑے (1)۔
37,94,فَاَقْبَلُوْۤا اِلَیْهِ یَزِفُّوْنَ فَاَقْبَلُوْٓا : پھر وہ متوجہ ہوئے اِلَيْهِ : اس کی طرف يَزِفُّوْنَ : دوڑے ہوئے وہ (بت پرست) دوڑے بھاگے آپ کی طرف متوجہ ہوئے (1)
37,95,قَالَ اَتَعْبُدُوْنَ مَا تَنْحِتُوْنَۙ قَالَ : اس نے فرمایا اَ تَعْبُدُوْنَ : کیا تم پرستش کرتے ہو مَا تَنْحِتُوْنَ : جو تم تراشتے ہو تو آپ نے فرمایا تم انہیں پوجتے ہو جنہیں (خود) تم تراشتے ہو
37,96,وَ اللّٰهُ خَلَقَكُمْ وَ مَا تَعْمَلُوْنَ وَاللّٰهُ : حالانکہ اللہ خَلَقَكُمْ : اس نے پیدا کیا تمہیں وَمَا : اور جو تَعْمَلُوْنَ : تم کرتے ہو حالانکہ تمہیں اور تمہاری بنائی ہوئی چیزوں کو اللہ ہی نے پیدا کیا ہے (1)
37,97,قَالُوا ابْنُوْا لَهٗ بُنْیَانًا فَاَلْقُوْهُ فِی الْجَحِیْمِ قَالُوا : انہوں نے کہا ابْنُوْا : بناؤ لَهٗ : اس کے لیے بُنْيَانًا : ایک عمارت فَاَلْقُوْهُ : پھر ڈال دو اسے فِي الْجَحِيْمِ : آگ میں وہ کہنے لگے اس کے لئے ایک مکان بناؤ اور اس (دھکتی ہوئی) آگ میں ڈال دو۔
37,98,فَاَرَادُوْا بِهٖ كَیْدًا فَجَعَلْنٰهُمُ الْاَسْفَلِیْنَ فَاَرَادُوْا : پھر انہوں نے چاہا بِهٖ : اس پر كَيْدًا : داؤ فَجَعَلْنٰهُمُ : تو ہم نے کردیا انہیں الْاَسْفَلِيْنَ : زیر انہوں نے تو اس (ابراہیم علیہ السلام) کے ساتھ مکر کرنا چاہا لیکن ہم نے انہیں کو نیچا کردیا (1)۔
37,99,وَ قَالَ اِنِّیْ ذَاهِبٌ اِلٰى رَبِّیْ سَیَهْدِیْنِ وَقَالَ : اور اس (ابراہیم نے) کہا اِنِّىْ : بیشک میں ذَاهِبٌ : جانے والا ہوں اِلٰى رَبِّيْ : اپنے رب کی طرف سَيَهْدِيْنِ : عنقریب وہ مجھے راہ دکھائے گا اپنے پروردگار کی طرف جانے والا ہوں (1) وہ ضرور میری رہنمائی کرے گا۔
37,100,رَبِّ هَبْ لِیْ مِنَ الصّٰلِحِیْنَ رَبِّ : اے میرے رب هَبْ لِيْ : مجھے عطا فرما مِنَ : سے الصّٰلِحِيْنَ : نیک صالح (جمع) اے میرے رب ! مجھے نیک بخت اولاد عطا فرما۔
37,101,فَبَشَّرْنٰهُ بِغُلٰمٍ حَلِیْمٍ فَبَشَّرْنٰهُ : پس بشارت دی ہم نے اسے بِغُلٰمٍ : ایک لڑکا حَلِيْمٍ : بردبار تو ہم نے اسے ایک بردبار بچے کی بشارت دی (1)۔
37,102,فَلَمَّا بَلَغَ مَعَهُ السَّعْیَ قَالَ یٰبُنَیَّ اِنِّیْۤ اَرٰى فِی الْمَنَامِ اَنِّیْۤ اَذْبَحُكَ فَانْظُرْ مَا ذَا تَرٰى١ؕ قَالَ یٰۤاَبَتِ افْعَلْ مَا تُؤْمَرُ١٘ سَتَجِدُنِیْۤ اِنْ شَآءَ اللّٰهُ مِنَ الصّٰبِرِیْنَ فَلَمَّا : پھر جب بَلَغَ : وہ پہنچا مَعَهُ : اس کے ساتھ السَّعْيَ : دوڑنے قَالَ : اس نے کہا يٰبُنَيَّ : اے میرے بیٹے اِنِّىْٓ اَرٰى : بیشک میں دیکھا ہون فِي : میں الْمَنَامِ : خواب اَنِّىْٓ : کہ میں اَذْبَحُكَ : تجھے ذبح کر رہا ہوں فَانْظُرْ : اب تو دیکھ مَاذَا : کیا تَرٰى ۭ : تیری رائے قَالَ : اس نے کہا يٰٓاَبَتِ : اے میرے ابا جان افْعَلْ : آپ کریں مَا تُؤْمَرُ ۡ : جو آپ کو حکم کیا جاتا ہے سَتَجِدُنِيْٓ : آپ جلد ہی مجھے پائیں گے اِنْ : اگر شَآءَ اللّٰهُ : اللہ نے چاہا مِنَ : سے الصّٰبِرِيْنَ : صبر کرنے والے پھر جب وہ (بچہ) اتنی عمر کو پہنچا کہ اس کے ساتھ چلے پھرے، (1) تو اس (ابراہیم علیہ السلام) نے کہا کہ میرے پیارے بچے ! میں خواب میں اپنے آپ کو تجھے ذبح کرتے ہوئے دیکھ رہا ہوں۔ اب تو بتا کہ تیری کیا رائے ہے (2) بیٹے نے جواب دیا کہ ابا ! جو حکم ہوا ہے اسے بجا لائیے انشاء اللہ آپ مجھے صبر کرنے والوں میں پائیں گے۔
37,103,فَلَمَّاۤ اَسْلَمَا وَ تَلَّهٗ لِلْجَبِیْنِۚ فَلَمَّآ : پس جب اَسْلَمَا : دونوں نے حکم (الہی) مان لیا وَتَلَّهٗ : (باپ نے بیٹے کو) لٹایا لِلْجَبِيْنِ : پیشانی کے بل اس کو (بیٹے کو) پیشانی (1) کے بل گرا دیا۔
37,104,وَ نَادَیْنٰهُ اَنْ یّٰۤاِبْرٰهِیْمُۙ وَنَادَيْنٰهُ : اور ہم نے اس کو پکارا اَنْ : کہ يّٰٓاِبْرٰهِيْمُ : اے ابراہیم تو ہم نے آواز دی کہ اے ابراہیم !۔
37,105,قَدْ صَدَّقْتَ الرُّءْیَا١ۚ اِنَّا كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ قَدْ صَدَّقْتَ : تحقیق تو نے سچ کر دکھایا الرُّءْيَا ۚ : خواب اِنَّا كَذٰلِكَ : بیشک ہم اسی طرح نَجْزِي : ہم جزا دیا کرتے ہیں الْمُحْسِنِيْنَ : نیکوکاروں یقیناً تو نے اپنے خواب کو سچا کر دکھایا (1) بیشک ہم نیکی کرنے والوں کو اسی طرح جزا دیتے ہیں۔
37,106,اِنَّ هٰذَا لَهُوَ الْبَلٰٓؤُا الْمُبِیْنُ اِنَّ ھٰذَا : بیشک یہ لَهُوَ : البتہ وہ الْبَلٰٓؤُا : آزمائش الْمُبِيْنُ : کھلی درحقیقت یہ کھلا امتحان تھا (1)۔
37,107,وَ فَدَیْنٰهُ بِذِبْحٍ عَظِیْمٍ وَفَدَيْنٰهُ : اور ہم نے اس کا فدیہ دیا بِذِبْحٍ : ایک ذبیحہ عَظِيْمٍ : بڑا اور ہم نے ایک بڑا ذبیحہ اس کے فدیہ میں دے دیا (1)
37,108,وَ تَرَكْنَا عَلَیْهِ فِی الْاٰخِرِیْنَۖ وَتَرَكْنَا : اور ہم نے باقی رکھا عَلَيْهِ : اس پر (اس کا ذکر خیر) فِي الْاٰخِرِيْنَ : بعد میں آنے والوں میں اور ہم نے ان کا ذکر خیر پچھلوں میں باقی رکھا۔
37,109,سَلٰمٌ عَلٰۤى اِبْرٰهِیْمَ سَلٰمٌ : سلام عَلٰٓي : پر اِبْرٰهِيْمَ : ابراہیم ابراہیم ؑ پر سلام ہو۔
37,110,كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ كَذٰلِكَ : اسی طرح نَجْزِي : ہم جزا دیا کرتے ہیں الْمُحْسِنِيْنَ : نیکوکاروں ہم نیکوکاروں کو اسی طرح بدلہ دیتے ہیں۔
37,111,اِنَّهٗ مِنْ عِبَادِنَا الْمُؤْمِنِیْنَ اِنَّهٗ : بیشک وہ مِنْ : سے عِبَادِنَا : ہمارے بندے الْمُؤْمِنِيْنَ : جمع (مومن) بیشک وہ ہمارے ایمان دار بندوں میں سے تھا۔
37,112,وَ بَشَّرْنٰهُ بِاِسْحٰقَ نَبِیًّا مِّنَ الصّٰلِحِیْنَ وَبَشَّرْنٰهُ : اور ہم نے اسے بشارت دی بِاِسْحٰقَ : اسحاق کی نَبِيًّا : ایک نبی مِّنَ : سے الصّٰلِحِيْنَ : جمع صالح اور ہم نے اس کو اسحاق ؑ نبی کی بشارت دی جو صالح لوگوں میں سے ہوگا (1)
37,113,وَ بٰرَكْنَا عَلَیْهِ وَ عَلٰۤى اِسْحٰقَ١ؕ وَ مِنْ ذُرِّیَّتِهِمَا مُحْسِنٌ وَّ ظَالِمٌ لِّنَفْسِهٖ مُبِیْنٌ۠    ۧ وَبٰرَكْنَا : اور ہم نے برکت نازل کی عَلَيْهِ : اس پر۔ اس کو وَعَلٰٓي : اور پر اِسْحٰقَ ۭ : اسحاق وَمِنْ : اور سے ۔ میں ذُرِّيَّتِهِمَا : ان دونوں کی اولاد مُحْسِنٌ : نیکو کار وَّظَالِمٌ : اور ظلم کرنے والا لِّنَفْسِهٖ : اپنی جان پر مُبِيْنٌ : صریح اور ہم نے ابراہیم و اسحاق (علیہما السلام) پر برکتیں نازل فرمائیں (1) اور ان دونوں کی اولاد میں بعضے تو نیک بخت اور بعض اپنے نفس پر صریح ظلم کرنے والے ہیں (2)
37,114,وَ لَقَدْ مَنَنَّا عَلٰى مُوْسٰى وَ هٰرُوْنَۚ وَلَقَدْ : اور البتہ تحقیق مَنَنَّا : ہم نے احسان کیا عَلٰي مُوْسٰى وَهٰرُوْنَ : موسیٰ پر اور ہارون پر یقیناً ہم نے موسیٰ اور ہارون (علیہما السلام) پر بڑا احسان کیا (1)۔
37,115,وَ نَجَّیْنٰهُمَا وَ قَوْمَهُمَا مِنَ الْكَرْبِ الْعَظِیْمِۚ وَنَجَّيْنٰهُمَا : اور ان دونوں کو نجات دی وَقَوْمَهُمَا : اور ان کی قوم مِنَ : سے الْكَرْبِ : غم الْعَظِيْمِ : بڑا اور انہیں اور ان کی قوم کو بہت بڑے دکھ درد سے نجات دی (1)
37,116,وَ نَصَرْنٰهُمْ فَكَانُوْا هُمُ الْغٰلِبِیْنَۚ وَنَصَرْنٰهُمْ : اور ہم نے مدد کی ان کی فَكَانُوْا : تو وہ رہے هُمُ : وہی الْغٰلِبِيْنَ : (جمع) غالب اور ان کی مدد کی تو وہی غالب رہے۔
37,117,وَ اٰتَیْنٰهُمَا الْكِتٰبَ الْمُسْتَبِیْنَۚ وَاٰتَيْنٰهُمَا : اور ہم نے ان دونوں کو دی الْكِتٰبَ : کتاب الْمُسْتَبِيْنَ : واضح اور ہم نے انہیں (واضح اور) روشن کتاب دی۔
37,118,وَ هَدَیْنٰهُمَا الصِّرَاطَ الْمُسْتَقِیْمَۚ وَهَدَيْنٰهُمَا : اور ہم نے ان دونوں کو ہدایت دی الصِّرَاطَ : راستہ الْمُسْتَقِيْمَ : سیدھا اور انہیں سیدھے راستے پر قائم رکھا۔
37,119,وَ تَرَكْنَا عَلَیْهِمَا فِی الْاٰخِرِیْنَۙ وَتَرَكْنَا : اور ہم نے باقی رکھا عَلَيْهِمَا : ان دونوں پر (ان کا ذکر خیر) فِي الْاٰخِرِيْنَ : بعد میں آنے والوں میں اور ہم نے ان دونوں کے لئے پیچھے آنے والوں میں یہ بات باقی رکھی۔
37,120,سَلٰمٌ عَلٰى مُوْسٰى وَ هٰرُوْنَ سَلٰمٌ : سلام عَلٰي مُوْسٰى : موسیٰ پر وَهٰرُوْنَ : اور ہارون کہ موسیٰ اور ہارون (علیہما السلام) پر سلام ہو۔
37,121,اِنَّا كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ اِنَّا كَذٰلِكَ : بیشک ہم اسی طرح نَجْزِي : ہم جزا دیتے ہیں الْمُحْسِنِيْنَ : نیکو کاروں بیشک ہم نیک لوگوں کو اسی طرح بدلہ دیا کرتے ہیں۔
37,122,اِنَّهُمَا مِنْ عِبَادِنَا الْمُؤْمِنِیْنَ اِنَّهُمَا : بیشک وہ دونوں مِنْ : سے عِبَادِنَا : ہمارے بندے الْمُؤْمِنِيْنَ : (جمع) مومن یقیناً دونوں ہمارے مومن بندوں میں سے تھے۔
37,123,وَ اِنَّ اِلْیَاسَ لَمِنَ الْمُرْسَلِیْنَؕ وَاِنَّ : اور بیشک اِلْيَاسَ : الیاس لَمِنَ : البتہ۔ سے الْمُرْسَلِيْنَ : رسولوں (جمع) بیشک الیاس ؑ بھی پیغمبروں میں سے تھے (1)۔
37,124,اِذْ قَالَ لِقَوْمِهٖۤ اَلَا تَتَّقُوْنَ اِذْ قَالَ : جب اس نے کہا لِقَوْمِهٖٓ : اپنی قوم کو اَلَا تَتَّقُوْنَ : کیا تم نہیں ڈرتے جب کہ انہوں نے اپنی قوم سے فرمایا کہ تم اللہ سے ڈرتے نہیں ہو ؟ (1)
37,125,اَتَدْعُوْنَ بَعْلًا وَّ تَذَرُوْنَ اَحْسَنَ الْخَالِقِیْنَۙ اَتَدْعُوْنَ : کیا تم پکارتے ہو بَعْلًا : بعل وَّتَذَرُوْنَ : اور تم چھوڑ دیتے ہو اَحْسَنَ : سب سے بہتر الْخَالِقِيْنَ : پیدا کرنے والا (جمع) کیا تم بعل (نامی بت) کو پکارتے ہو ؟ اور سب سے بہتر خالق کو چھوڑ دیتے ہو ؟
37,126,اللّٰهَ رَبَّكُمْ وَ رَبَّ اٰبَآئِكُمُ الْاَوَّلِیْنَ اللّٰهَ : اللہ رَبَّكُمْ : تمہارا رب وَرَبَّ : اور رب اٰبَآئِكُمُ : تمہارے باپ دادا الْاَوَّلِيْنَ : پہلے اللہ جو تمہارے اگلے تمام باپ دادوں کا رب ہے (1)
37,127,فَكَذَّبُوْهُ فَاِنَّهُمْ لَمُحْضَرُوْنَۙ فَكَذَّبُوْهُ : پس انہوں نے جھٹلایا فَاِنَّهُمْ : تو بیشک وہ لَمُحْضَرُوْنَ : وہ ضرور حاضر کیے جائیں گے لیکن قوم نے انہیں جھٹلایا، پس وہ ضرور (عذاب میں) حاضر رکھے جائیں گے (1)۔
37,128,اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ اِلَّا : سوائے عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : (جمع) مخلص سوائے اللہ تعالیٰ کے مخلص بندوں کے۔
37,129,وَ تَرَكْنَا عَلَیْهِ فِی الْاٰخِرِیْنَۙ وَتَرَكْنَا : اور ہم نے باقی رکھا عَلَيْهِ : اس پر (اس کا ذکر خیر) فِي الْاٰخِرِيْنَ : بعد میں آنے والوں میں ہم نے الیاس ؑ کا ذکر خیر پچھلوں میں بھی باقی رکھا۔
37,130,سَلٰمٌ عَلٰۤى اِلْ یَاسِیْنَ سَلٰمٌ : سلام عَلٰٓي : پر اِلْ يَاسِيْنَ : الیاسین (الیاس) کہ الیاس پر سلام ہو (1)۔
37,131,اِنَّا كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ اِنَّا كَذٰلِكَ : بیشک ہم اسی طرح نَجْزِي : جزا دیا کرتے ہیں الْمُحْسِنِيْنَ : نیکوکاروں ہم نیکی کرنے والوں کو اسی طرح بدلہ دیتے ہیں۔
37,132,اِنَّهٗ مِنْ عِبَادِنَا الْمُؤْمِنِیْنَ اِنَّهٗ : بیشک وہ مِنْ : سے عِبَادِنَا : ہمارے بندے الْمُؤْمِنِيْنَ : (جمع) مومن بیشک وہ ہمارے ایمان دار بندوں میں سے تھے۔
37,133,وَ اِنَّ لُوْطًا لَّمِنَ الْمُرْسَلِیْنَؕ وَاِنَّ لُوْطًا : اور بیشک لوط لَّمِنَ : البتہ میں سے الْمُرْسَلِيْنَ : رسولوں (میں سے) تھے بیشک لوط ؑ بھی پیغمبروں میں سے تھے۔
37,134,اِذْ نَجَّیْنٰهُ وَ اَهْلَهٗۤ اَجْمَعِیْنَۙ اِذْ : جب نَجَّيْنٰهُ : ہم نے اسے نجات دی وَاَهْلَهٗٓ : اور اس کے گھر والے اَجْمَعِيْنَ : سب ہم نے انہیں اور ان کے گھر والوں کو سب کو نجات دی۔
37,135,اِلَّا عَجُوْزًا فِی الْغٰبِرِیْنَ اِلَّا : سوائے عَجُوْزًا : ایک بڑھیا فِي الْغٰبِرِيْنَ : پیچھے رہ جانے والے بجز اس بڑھیا کے جو پیچھے رہ جانے والوں میں رہ گئی (1)
37,136,ثُمَّ دَمَّرْنَا الْاٰخَرِیْنَ ثُمَّ : پھر دَمَّرْنَا : ہم نے ہلاک کیا الْاٰخَرِيْنَ : اوروں کو پھر ہم نے اوروں کو ہلاک کردیا۔
37,137,وَ اِنَّكُمْ لَتَمُرُّوْنَ عَلَیْهِمْ مُّصْبِحِیْنَ وَاِنَّكُمْ : اور بیشک تم لَتَمُرُّوْنَ : البتہ گزرتے ہو عَلَيْهِمْ : ان پر مُّصْبِحِيْنَ : صبح کرتے ہوئے (صبح ہوتے) اور تم تو صبح ہونے پر ان کی بستیوں کے پاس سے گزرتے ہو۔
37,138,وَ بِالَّیْلِ١ؕ اَفَلَا تَعْقِلُوْنَ۠    ۧ وَبِالَّيْلِ ۭ : اور رات میں اَفَلَا تَعْقِلُوْنَ : تو کیا تم عقل سے کام نہیں لیتے اور رات کو بھی، کیا پھر بھی نہیں سمجھتے ؟ (1)۔
37,139,وَ اِنَّ یُوْنُسَ لَمِنَ الْمُرْسَلِیْنَؕ وَاِنَّ : اور بیشک يُوْنُسَ : یونس لَمِنَ : البتہ۔ سے الْمُرْسَلِيْنَ : رسولوں اور بلاشبہ یونس ؑ نبیوں میں سے تھے۔
37,140,اِذْ اَبَقَ اِلَى الْفُلْكِ الْمَشْحُوْنِۙ اِذْ : جب اَبَقَ : بھاگ گئے وہ اِلَى : طرف الْفُلْكِ : کشتی الْمَشْحُوْنِ : بھری ہوئی جب بھاگ کر پہنچے بھری کشتی پر۔
37,141,فَسَاهَمَ فَكَانَ مِنَ الْمُدْحَضِیْنَۚ فَسَاهَمَ : تو قرعہ ڈالا فَكَانَ : سو وہ ہوا مِنَ : سے الْمُدْحَضِيْنَ : دھکیلے گئے پھر قرعہ اندازی ہوئی تو یہ مغلوب ہوگئے۔
37,142,فَالْتَقَمَهُ الْحُوْتُ وَ هُوَ مُلِیْمٌ فَالْتَقَمَهُ : پھر اسے نگل لیا الْحُوْتُ : مچھلی وَهُوَ : اور وہ مُلِيْمٌ : ملامت کرنے والا تو پھر انہیں مچھلی نے نگل لیا اور وہ خود اپنے آپ کو ملامت (1) کرنے لگ گئے۔
37,143,فَلَوْ لَاۤ اَنَّهٗ كَانَ مِنَ الْمُسَبِّحِیْنَۙ فَلَوْلَآ : پھر اگر نہ اَنَّهٗ : یہ کہ وہ كَانَ : ہوتا مِنَ : سے الْمُسَبِّحِيْنَ : تسبیح کرنے والے پس اگر یہ پاکی بیان کرنے والوں میں سے نہ ہوتے۔
37,144,لَلَبِثَ فِیْ بَطْنِهٖۤ اِلٰى یَوْمِ یُبْعَثُوْنَۚ لَلَبِثَ : البتہ رہتا فِيْ بَطْنِهٖٓ : اس کے پیٹ میں اِلٰى : تک يَوْمِ يُبْعَثُوْنَ : بعثت کے دن (روز محشر) تو لوگوں کے اٹھائے جانے کے دن تک اس کے پیٹ میں ہی رہتے (1)
37,145,فَنَبَذْنٰهُ بِالْعَرَآءِ وَ هُوَ سَقِیْمٌۚ فَنَبَذْنٰهُ : پھر ہم نے اسے پھینک دیا بِالْعَرَآءِ : چٹیل میدان میں وَهُوَ : اور وہ سَقِيْمٌ : بیمار پس انہیں ہم نے چٹیل میدان میں ڈال دیا اور وہ اس وقت بیمار تھے (1)
37,146,وَ اَنْۢبَتْنَا عَلَیْهِ شَجَرَةً مِّنْ یَّقْطِیْنٍۚ وَاَنْۢبَتْنَا : اور ہم نے اگایا عَلَيْهِ : اس پر شَجَرَةً : ایک پودا مِّنْ : سے يَّقْطِيْنٍ : بیلدار (کدو) اور ان پر سایہ کرنے والا ایک بیل دار درخت (1) ہم نے اگاہ دیا۔
37,147,وَ اَرْسَلْنٰهُ اِلٰى مِائَةِ اَلْفٍ اَوْ یَزِیْدُوْنَۚ وَاَرْسَلْنٰهُ : اور ہم نے بھیجا اس کو اِلٰى : طرف مِائَةِ اَلْفٍ : ایک لاکھ اَوْ : یا يَزِيْدُوْنَ : اس سے زیادہ اور ہم نے انہیں ایک لاکھ بلکہ اور زیادہ آدمیوں کی طرف بھیجا۔
37,148,فَاٰمَنُوْا فَمَتَّعْنٰهُمْ اِلٰى حِیْنٍؕ فَاٰمَنُوْا : سو وہ ایمان لائے فَمَتَّعْنٰهُمْ : تو ہم نے انہیں بہرہ مند کیا اِلٰى حِيْنٍ : ایک مدت تک پس وہ ایمان لائے (1) اور ہم نے انہیں ایک زمانہ تک عیش و عشرت دی۔
37,149,فَاسْتَفْتِهِمْ اَلِرَبِّكَ الْبَنَاتُ وَ لَهُمُ الْبَنُوْنَۙ فَاسْتَفْتِهِمْ : پس پوچھیں ان سے اَلِرَبِّكَ : کیا تیرے رب کے لیے الْبَنَاتُ : بیٹیاں وَلَهُمُ : اور ان کے لیے الْبَنُوْنَ : بیٹے ان سے دریافت کیجئے ! کہ کیا آپ کے رب کی بیٹیاں ہیں اور ان کے بیٹے ہیں ؟
37,150,اَمْ خَلَقْنَا الْمَلٰٓئِكَةَ اِنَاثًا وَّ هُمْ شٰهِدُوْنَ اَمْ : کیا خَلَقْنَا : ہم نے پیدا کیا الْمَلٰٓئِكَةَ : فرشتے اِنَاثًا : عورت وَّهُمْ : اور وہ شٰهِدُوْنَ : دیکھ رہے تھے یا یہ اس وقت موجود تھے جبکہ ہم نے فرشتوں کو مؤنث پیدا کیا (1)۔
37,151,اَلَاۤ اِنَّهُمْ مِّنْ اِفْكِهِمْ لَیَقُوْلُوْنَۙ اَلَآ : یاد رکھو اِنَّهُمْ : بیشک وہ مِّنْ : سے اِفْكِهِمْ : اپنی بہتان طرازی لَيَقُوْلُوْنَ : البتہ کہتے ہیں آگاہ رہو ! کہ یہ لوگ صرف اپنی بہتان پروازی سے کہہ رہے ہیں۔
37,152,وَلَدَ اللّٰهُ١ۙ وَ اِنَّهُمْ لَكٰذِبُوْنَ وَلَدَ اللّٰهُ ۙ : پیدا کیا اللہ نے وَاِنَّهُمْ لَكٰذِبُوْنَ : اور بیشک وہ البتہ جھوٹے ہیں کہ اللہ تعالیٰ کی اولاد ہے۔ یقیناً یہ محض جھوٹے ہیں۔
37,153,اَصْطَفَى الْبَنَاتِ عَلَى الْبَنِیْنَؕ اَصْطَفَى : کیا اس نے پسند کیا الْبَنَاتِ : بیٹیاں عَلَي الْبَنِيْنَ : بیٹوں پر کیا اللہ تعالیٰ نے اپنے لئے بیٹیوں کو بیٹوں پر ترجیح دی (1)۔
37,154,مَا لَكُمْ١۫ كَیْفَ تَحْكُمُوْنَ مَا لَكُمْ ۣ : تمہیں کیا ہوگیا كَيْفَ : کیسا تَحْكُمُوْنَ : تم فیصلہ کرتے ہو تمہیں کیا ہوگیا ہے کیسے حکم لگاتے پھرتے ہو ؟
37,155,اَفَلَا تَذَكَّرُوْنَۚ اَفَلَا تَذَكَّرُوْنَ : تو کیا تم غور نہیں کرتے ؟ کیا تم اس قدر بھی نہیں سمجھتے ؟
37,156,اَمْ لَكُمْ سُلْطٰنٌ مُّبِیْنٌۙ اَمْ : کیا لَكُمْ : تمہارے پاس سُلْطٰنٌ : کوئی سند مُّبِيْنٌ : تو لے آؤ یا تمہارے پاس اس کی کوئی صاف دلیل ہے۔
37,157,فَاْتُوْا بِكِتٰبِكُمْ اِنْ كُنْتُمْ صٰدِقِیْنَ فَاْتُوْا : تو لے آؤ بِكِتٰبِكُمْ : اپنی کتاب اِنْ : اگر كُنْتُمْ : تم ہو صٰدِقِيْنَ : سچے تو جاؤ اگر سچے ہو اپنی کتاب لے آؤ (1)
37,158,وَ جَعَلُوْا بَیْنَهٗ وَ بَیْنَ الْجِنَّةِ نَسَبًا١ؕ وَ لَقَدْ عَلِمَتِ الْجِنَّةُ اِنَّهُمْ لَمُحْضَرُوْنَۙ وَجَعَلُوْا : اور انہوں نے ٹھہرایا بَيْنَهٗ : اس کے درمیان وَبَيْنَ : اور درمیان الْجِنَّةِ : جنات نَسَبًا ۭ : ایک رشتہ وَلَقَدْ عَلِمَتِ : اور تحقیق جان لی الْجِنَّةُ : جنات اِنَّهُمْ : بیشک وہ لَمُحْضَرُوْنَ : حاضر کیے جائیں گے اور لوگوں نے تو اللہ کے اور جنات کے درمیان بھی قرابت داری ٹھہرائی (1) ہے، اور حالانکہ خود جنات کو معلوم ہے کہ وہ (اس عقیدے کے لوگ عذاب کے سامنے) پیش کئے جائیں گے (2)
37,159,سُبْحٰنَ اللّٰهِ عَمَّا یَصِفُوْنَۙ سُبْحٰنَ اللّٰهِ : پاک ہے اللہ عَمَّا : اس سے جو يَصِفُوْنَ : وہ بیان کرتے ہیں جو کچھ یہ (اللہ کے بارے میں) بیان کر رہے ہیں اس سے اللہ تعالیٰ بالکل پاک ہے۔
37,160,اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ اِلَّا : مگر عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : خاص کیے ہوئے (چنے ہوئے) سوائے ! اللہ کے مخلص بندوں کے (1)
37,161,فَاِنَّكُمْ وَ مَا تَعْبُدُوْنَۙ فَاِنَّكُمْ : تو بیشک تم وَمَا : اور جو تَعْبُدُوْنَ : تم پرستش کرتے ہو یقین مانو کہ تم سب اور تمہارے معبودان (باطل)۔
37,162,مَاۤ اَنْتُمْ عَلَیْهِ بِفٰتِنِیْنَۙ مَآ اَنْتُمْ : نہیں ہو تم عَلَيْهِ : اس کے خلاف بِفٰتِنِيْنَ : بہکانے والے کسی ایک کو بھی بہکا نہیں سکتے۔
37,163,اِلَّا مَنْ هُوَ صَالِ الْجَحِیْمِ اِلَّا : سوائے مَنْ هُوَ : جو۔ وہ صَالِ : جانے والا الْجَحِيْمِ : جہنم بجز اس کے جو جہنمی ہی ہے (1)
37,164,وَ مَا مِنَّاۤ اِلَّا لَهٗ مَقَامٌ مَّعْلُوْمٌۙ وَمَا : اور نہیں مِنَّآ : ہم میں سے اِلَّا لَهٗ : مگر اس کے لیے مَقَامٌ مَّعْلُوْمٌ : ایک معین درجہ فرشتوں کا قول ہے کہ) ہم میں سے تو ہر ایک کی جگہ مقرر ہے (1)
37,165,وَّ اِنَّا لَنَحْنُ الصَّآفُّوْنَۚ وَّاِنَّا : اور بیشک ہم لَنَحْنُ : البتہ ہم الصَّآفُّوْنَ : صف بستہ ہونے والے اور ہم تو (بندگی الٰہی میں) صف بستہ کھڑے ہیں۔
37,166,وَ اِنَّا لَنَحْنُ الْمُسَبِّحُوْنَ وَاِنَّا : اور بیشک ہم لَنَحْنُ : البتہ ہم الْمُسَبِّحُوْنَ : تسبیح کرنے والے اور اس کی تسبیح بیان کر رہے ہو (1)۔
37,167,وَ اِنْ كَانُوْا لَیَقُوْلُوْنَۙ وَاِنْ : اور بیشک كَانُوْا لَيَقُوْلُوْنَ : وہ کہا کرتے تھے کفار تو کہا کرتے تھے۔
37,168,لَوْ اَنَّ عِنْدَنَا ذِكْرًا مِّنَ الْاَوَّلِیْنَۙ لَوْ اَنَّ : اگر ہوتی عِنْدَنَا : ہمارے پاس ذِكْرًا : کوئی نصیحت مِّنَ : سے الْاَوَّلِيْنَ : پہلے لوگ اگر ہمارے سامنے اگلے لوگوں کا ذکر ہوتا۔
37,169,لَكُنَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ لَكُنَّا : ضرور ہم ہوتے عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : خاص کیے (منتخب) تو ہم بھی اللہ کے چیدہ بندے بن جاتے (1)
37,170,فَكَفَرُوْا بِهٖ فَسَوْفَ یَعْلَمُوْنَ فَكَفَرُوْا : پھر انہوں نے انکار کیا بِهٖ : اس کا فَسَوْفَ : تو عنقریب يَعْلَمُوْنَ : وہ جان لیں گے عنقریب جان لیں گے (1)۔
37,171,وَ لَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا الْمُرْسَلِیْنَۚۖ وَلَقَدْ سَبَقَتْ : اور پہلے صادر ہوچکا ہے كَلِمَتُنَا : ہمارا وعدہ لِعِبَادِنَا : اپنے بندوں کے لیے الْمُرْسَلِيْنَ : رسولوں اور البتہ ہمارا وعدہ پہلے ہی اپنے رسولوں کے لئے صادر ہوچکا ہے۔
37,172,اِنَّهُمْ لَهُمُ الْمَنْصُوْرُوْنَ۪ اِنَّهُمْ : بیشک وہ لَهُمُ : البتہ وہی الْمَنْصُوْرُوْنَ : فتح مند کہ یقیناً وہ ہی مدد کئے جائیں گے۔
37,173,وَ اِنَّ جُنْدَنَا لَهُمُ الْغٰلِبُوْنَ وَاِنَّ : اور بیشک جُنْدَنَا : ہمارا لشکر لَهُمُ : البتہ وہی الْغٰلِبُوْنَ : غالب (جمع) اور ہمارا ہی لشکر غالب (اور برتر) رہے گا (1)۔
37,174,فَتَوَلَّ عَنْهُمْ حَتّٰى حِیْنٍۙ فَتَوَلَّ : پس اعراض کریں عَنْهُمْ : ان سے حَتّٰى : تک حِيْنٍ : ایک وقت تک اب آپ کچھ دنوں تک منہ پھیر لیجئے (1)
37,175,وَّ اَبْصِرْهُمْ فَسَوْفَ یُبْصِرُوْنَ وَّاَبْصِرْهُمْ : اور انہیں دیکھتے رہیں فَسَوْفَ : پس عنقریب يُبْصِرُوْنَ : وہ دیکھ لیں گے اور انہیں دیکھتے رہیئے (1) اور یہ بھی آگے چل کر دیکھ لینگے (1)
37,176,اَفَبِعَذَابِنَا یَسْتَعْجِلُوْنَ اَفَبِعَذَابِنَا : تو کیا ہمارے عذاب کے لیے يَسْتَعْجِلُوْنَ : وہ جلدی کر رہے ہیں کیا ہمارے عذاب کی جلدی مچا رہے ہیں ؟
37,177,فَاِذَا نَزَلَ بِسَاحَتِهِمْ فَسَآءَ صَبَاحُ الْمُنْذَرِیْنَ فَاِذَا : تو جب نَزَلَ : وہ نازل ہوگا بِسَاحَتِهِمْ : ان کے میدان میں فَسَآءَ : تو بری صَبَاحُ : صبح الْمُنْذَرِيْنَ : جن کو ڈرایا جاچکا ہے سنو ! جب ہمارا عذاب ان کے میدان میں اتر آئے گا اس وقت ان کی جن کو متنبہ کردیا گیا تھا (1) بڑی بری صبح ہوگی۔
37,178,وَ تَوَلَّ عَنْهُمْ حَتّٰى حِیْنٍۙ وَتَوَلَّ : اور اعراض کریں عَنْهُمْ : ان سے حَتّٰى : تک حِيْنٍ : ایک مدت آپ کچھ وقت تک ان کا خیال چھوڑ دیجئے۔
37,179,وَّ اَبْصِرْ فَسَوْفَ یُبْصِرُوْنَ وَّاَبْصِرْ : اور دیکھتے رہیں فَسَوْفَ : پس عنقریب يُبْصِرُوْنَ : وہ دیکھ لیں گے اور دیکھتے رہیئے یہ بھی ابھی ابھی دیکھ لیں گے (1)۔
37,180,سُبْحٰنَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا یَصِفُوْنَۚ سُبْحٰنَ : پاک ہے رَبِّكَ : تمہارا رب رَبِّ الْعِزَّةِ : عزت والا رب عَمَّا : اس سے جو يَصِفُوْنَ : وہ بیان کرتے ہیں پاک ہے آپ کا رب جو بہت بڑی عزت والا ہے ہر اس چیز سے (جو مشرک) بیان کرتے ہیں (1)
37,181,وَ سَلٰمٌ عَلَى الْمُرْسَلِیْنَۚ وَسَلٰمٌ : اور سلام عَلَي : پر الْمُرْسَلِيْنَ : رسولوں پیغمبروں پر سلام ہے (1)۔
37,182,وَ الْحَمْدُ لِلّٰهِ رَبِّ الْعٰلَمِیْنَ۠    ۧ وَالْحَمْدُ : اور تمام تعریفیں لِلّٰهِ : اللہ کے لیے رَبِّ الْعٰلَمِيْنَ : تمام جہانوں کا رب اور سب طرح کی تعریف اللہ کے لئے ہے جو سارے جہان کا رب ہے (1)
