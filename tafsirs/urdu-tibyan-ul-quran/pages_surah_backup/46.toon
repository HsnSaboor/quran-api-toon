quran[35]{c,v,t}:
46,1,حٰمٓۚ حٰمٓ : حا۔ میم حم
46,2,تَنْزِیْلُ الْكِتٰبِ مِنَ اللّٰهِ الْعَزِیْزِ الْحَكِیْمِ تَنْزِيْلُ : نازل کرنا الْكِتٰبِ : کتاب مِنَ اللّٰهِ : اللہ سے الْعَزِيْزِ : غالب الْحَكِيْمِ : حکمت والا اس کتاب کا اتارنا اللہ تعالیٰ غالب حکمت والے کی طرف سے ہے۔ (1)
46,3,مَا خَلَقْنَا السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَاۤ اِلَّا بِالْحَقِّ وَ اَجَلٍ مُّسَمًّى١ؕ وَ الَّذِیْنَ كَفَرُوْا عَمَّاۤ اُنْذِرُوْا مُعْرِضُوْنَ مَا خَلَقْنَا : نہیں پیدا کیا ہم نے السَّمٰوٰتِ : آسمانوں وَالْاَرْضَ : اور زمین وَمَا : اور جو بَيْنَهُمَآ : ان دونوں کے درمیان اِلَّا بالْحَقِّ : مگر حق کے ساتھ وَاَجَلٍ : اور میعاد مُّسَمًّى ۭ : مقررہ وَالَّذِيْنَ : اور جن لوگوں نے كَفَرُوْا : کفر کیا عَمَّآ : جس سے اُنْذِرُوْا : وہ ڈرائے جاتے ہیں مُعْرِضُوْنَ : روگردانی کرنیوالے ہم نے آسمانوں اور زمین اور ان دونوں کے درمیان کی تمام چیزوں کو بہترین تدبیر کے ساتھ ہی ایک مدت معین کے لئے پیدا کیا ہے (1) اور کافر لوگ جس چیز سے ڈرائے جاتے ہیں منہ موڑ لیتے ہیں۔ (2)
46,4,قُلْ اَرَءَیْتُمْ مَّا تَدْعُوْنَ مِنْ دُوْنِ اللّٰهِ اَرُوْنِیْ مَا ذَا خَلَقُوْا مِنَ الْاَرْضِ اَمْ لَهُمْ شِرْكٌ فِی السَّمٰوٰتِ١ؕ اِیْتُوْنِیْ بِكِتٰبٍ مِّنْ قَبْلِ هٰذَاۤ اَوْ اَثٰرَةٍ مِّنْ عِلْمٍ اِنْ كُنْتُمْ صٰدِقِیْنَ قُلْ : فرمادیں اَرَءَيْتُمْ : بھلا تم دیکھو مَّا تَدْعُوْنَ : جن کو تم بلاتے ہو مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا اَرُوْنِيْ : دکھاؤ مجھے مَاذَا خَلَقُوْا : کیا انہوں نے پیدا کیا مِنَ الْاَرْضِ : زمین سے اَمْ لَهُمْ : یا ان کے لئے شِرْكٌ : کچھ ساجھا فِي السَّمٰوٰتِ ۭ : آسمانوں میں اِيْتُوْنِيْ : لے آؤ میرے پاس بِكِتٰبٍ : کوئی کتاب مِّنْ قَبْلِ ھٰذَآ : اس سے پہلے اَوْ اَثٰرَةٍ : یا آثار مِّنْ عِلْمٍ : علم سے، کی اِنْ : اگر كُنْتُمْ صٰدِقِيْنَ : تم ہو سچے آپ کہہ دیجئے ! بھلا دیکھو تو جنہیں تم اللہ کے سوا پکارتے ہو مجھے بھی تو دکھاؤ کہ انہوں نے زمین کا کون سا ٹکڑا بنایا ہے یا آسمانوں میں کون سا حصہ ہے (1) اگر تم سچے ہو تو اس سے پہلے ہی کوئی کتاب یا کوئی علم ہے جو نقل کیا جاتا ہو میرے پاس لاؤ (2)۔
46,5,وَ مَنْ اَضَلُّ مِمَّنْ یَّدْعُوْا مِنْ دُوْنِ اللّٰهِ مَنْ لَّا یَسْتَجِیْبُ لَهٗۤ اِلٰى یَوْمِ الْقِیٰمَةِ وَ هُمْ عَنْ دُعَآئِهِمْ غٰفِلُوْنَ وَمَنْ اَضَلُّ : اور کون بڑا گمراہ مِمَّنْ : اس سے جو يَّدْعُوْا : وہ پکارتا ہے مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا مَنْ : جو لَّا يَسْتَجِيْبُ : جواب نہ دے گا لَهٗٓ : اس کو اِلٰى : تک يَوْمِ الْقِيٰمَةِ : قیامت کا دن وَهُمْ : اور وہ عَنْ دُعَآئِهِمْ : ان کے پکارنے سے غٰفِلُوْنَ : بیخبر ہیں اور اس سے بڑھ کر گمراہ اور کون ہوگا ؟ جو اللہ کے سوا ایسوں کو پکارتا ہے جو قیامت تک اس کی دعا قبول نہ کرسکیں بلکہ ان کے پکارنے سے محض بیخبر ہوں (1)
46,6,وَ اِذَا حُشِرَ النَّاسُ كَانُوْا لَهُمْ اَعْدَآءً وَّ كَانُوْا بِعِبَادَتِهِمْ كٰفِرِیْنَ وَاِذَا : اور جب حُشِرَ : جمع کئے جائیں گے النَّاسُ : لوگ كَانُوْا : وہ ہوں گے لَهُمْ : ان کے اَعْدَآءً : دشمن وَّكَانُوْا : اور ہوں گے بِعِبَادَتِهِمْ : ان کی عبادت سے كٰفِرِيْنَ : منکر (جمع) اور جب لوگوں کو جمع کیا جائے گا تو یہ ان کے دشمن ہوجائیں گے اور ان کی پرستش سے صاف انکار کر جائیں گے۔ (1)
46,7,وَ اِذَا تُتْلٰى عَلَیْهِمْ اٰیٰتُنَا بَیِّنٰتٍ قَالَ الَّذِیْنَ كَفَرُوْا لِلْحَقِّ لَمَّا جَآءَهُمْ١ۙ هٰذَا سِحْرٌ مُّبِیْنٌؕ وَاِذَا : اور جب تُتْلٰى : پڑھی جاتی ہیں عَلَيْهِمْ : ان پر اٰيٰتُنَا : آیات ہماری بَيِّنٰتٍ : واضح قَالَ : کہتے ہیں الَّذِيْنَ : جن لوگوں نے كَفَرُوْا : انکار کیا لِلْحَقِّ : حق کا لَمَّا : جب جَآءَهُمْ ۙ : ان کے پاس آگیا ھٰذَا سِحْرٌ : یہ جادو مُّبِيْنٌ : کھلا اور انہیں جب ہماری واضح آیتیں پڑھ کر سنائی جاتی ہیں تو منکر لوگ سچی بات کو جب کہ ان کے پاس آچکی، کہہ دیتے ہیں کہ یہ صریح جادو ہے۔
46,8,اَمْ یَقُوْلُوْنَ افْتَرٰىهُ١ؕ قُلْ اِنِ افْتَرَیْتُهٗ فَلَا تَمْلِكُوْنَ لِیْ مِنَ اللّٰهِ شَیْئًا١ؕ هُوَ اَعْلَمُ بِمَا تُفِیْضُوْنَ فِیْهِ١ؕ كَفٰى بِهٖ شَهِیْدًۢا بَیْنِیْ وَ بَیْنَكُمْ١ؕ وَ هُوَ الْغَفُوْرُ الرَّحِیْمُ اَمْ يَقُوْلُوْنَ : کیا وہ کہتے ہیں افْتَرٰىهُ ۭ : اس نے خود بنالیا ہے اسے قُلْ : فرمادیں اِنِ افْتَرَيْتُهٗ : اگر میں نے خود بنالیا ہے اسے فَلَا تَمْلِكُوْنَ : تو تم اختیار نہیں رکھتے لِيْ : میرے لئے مِنَ اللّٰهِ : اللہ سے شَيْئًا ۭ : کچھ بھی هُوَ اَعْلَمُ : وہ خوب جانتا ہے بِمَا : وہ جو تُفِيْضُوْنَ : تم باتیں بناتے ہو فِيْهِ ۭ : اس میں كَفٰى : وہ کافی ہے بِهٖ : اس کا شَهِيْدًۢا : گواہ بَيْنِيْ : میرے درمیان وَبَيْنَكُمْ ۭ : اور تمہارے درمیان وَهُوَ : اور وہ الْغَفُوْرُ : بخشنے والا الرَّحِيْمُ : رحم کرنے والا کیا وہ کہتے ہیں کہ اسے تو اس نے خود گھڑ لیا (1) ہے آپ کہہ دیجئے ! کہ اگر میں ہی اسے بنا لایا ہوں تو میرے لئے اللہ کی طرف سے کسی چیز کا اختیار نہیں رکھتے (2) تم اس قرآن کے بارے میں جو کچھ سن رہے ہو اسے اللہ خوب جانتا ہے (3) میرے اور تمہارے درمیان گواہی کے لئے وہی کافی ہے (4) اور وہ بخشنے والا مہربان ہے۔ (5)
46,9,قُلْ مَا كُنْتُ بِدْعًا مِّنَ الرُّسُلِ وَ مَاۤ اَدْرِیْ مَا یُفْعَلُ بِیْ وَ لَا بِكُمْ١ؕ اِنْ اَتَّبِعُ اِلَّا مَا یُوْحٰۤى اِلَیَّ وَ مَاۤ اَنَا اِلَّا نَذِیْرٌ مُّبِیْنٌ قُلْ : فرمادیں مَا كُنْتُ : نہیں ہوں میں بِدْعًا : نیا مِّنَ الرُّسُلِ : رسولوں میں سے وَمَآ اَدْرِيْ : اور نہیں جانتا میں مَا يُفْعَلُ : کیا کیا جائے گا بِيْ : میرے ساتھ وَلَا بِكُمْ ۭ : اور نہ تمہارے ساتھ اِنْ اَتَّبِعُ : نہیں پیروی کرتا میں اِلَّا : سوائے، صرف مَا يُوْحٰٓى : جو وحی کیا جاتا ہے اِلَيَّ : میری طرف وَمَآ اَنَا : اور نہیں ہوں میں اِلَّا : مگر، صرف نَذِيْرٌ : ڈر سنانے والا مُّبِيْنٌ : صاف صاف آپ کہہ دیجئے ! کہ میں کوئی بالکل انو کھا پیغمبر نہیں (1) نہ مجھے یہ معلوم ہے کہ میرے ساتھ اور تمہارے ساتھ کیا کیا جائے گا (2)۔ میں تو صرف اسی کی پیروی کرتا ہوں جو میری طرف وحی بھیجی جاتی ہے اور میں تو صرف علی الاعلان کردینے والا ہوں۔
46,10,قُلْ اَرَءَیْتُمْ اِنْ كَانَ مِنْ عِنْدِ اللّٰهِ وَ كَفَرْتُمْ بِهٖ وَ شَهِدَ شَاهِدٌ مِّنْۢ بَنِیْۤ اِسْرَآءِیْلَ عَلٰى مِثْلِهٖ فَاٰمَنَ وَ اسْتَكْبَرْتُمْ١ؕ اِنَّ اللّٰهَ لَا یَهْدِی الْقَوْمَ الظّٰلِمِیْنَ۠    ۧ قُلْ : فرمادیں اَرَءَيْتُمْ : بھلا تم دیکھو تو اِنْ كَانَ : اگر ہے مِنْ عِنْدِ اللّٰهِ : اللہ کے پاس سے وَكَفَرْتُمْ : اور تم نے انکار کیا بِهٖ : اسکا وَشَهِدَ : اور گواہی دی شَاهِدٌ : ایک گواہ مِّنْۢ : سے بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل عَلٰي مِثْلِهٖ : اس جیسی (ایک کتاب) پر فَاٰمَنَ : پھر وہ ایمان لے آیا وَاسْتَكْبَرْتُمْ ۭ : اور تم نے تکبر کیا اِنَّ اللّٰهَ : بیشک اللہ لَا يَهْدِي : ہدایت نہیں دیتا الْقَوْمَ : لوگ الظّٰلِمِيْنَ : ظالم (جمع) آپ کہہ دیجئے ! اگر یہ (قرآن) اللہ ہی کی طرف سے ہو اور تم نے اسے نہ مانا ہو اور بنی اسرائیل کا ایک گواہ اس جیسی کی گواہی بھی دے چکا ہو اور ایمان بھی لا چکا ہو اور تم نے سرکشی کی ہو (1) تو بیشک اللہ تعالیٰ ظالموں کو راہ نہیں دکھاتا۔
46,11,وَ قَالَ الَّذِیْنَ كَفَرُوْا لِلَّذِیْنَ اٰمَنُوْا لَوْ كَانَ خَیْرًا مَّا سَبَقُوْنَاۤ اِلَیْهِ١ؕ وَ اِذْ لَمْ یَهْتَدُوْا بِهٖ فَسَیَقُوْلُوْنَ هٰذَاۤ اِفْكٌ قَدِیْمٌ وَقَالَ : اور کہا الَّذِيْنَ : وہ لوگ جنہوں نے كَفَرُوْا : کفر کیا (کافر) لِلَّذِيْنَ : ان کیلئے جو اٰمَنُوْا : ایمان لائے ( مومن ) لَوْ كَانَ خَيْرًا : اگر ہوتا بہتر مَّا : نہ سَبَقُوْنَآ : وہ پہل کرتے ہم پر اِلَيْهِ ۭ : اس کی طرف وَاِذْ : اور جب لَمْ يَهْتَدُوْا : نہ ہدایت پائی انہوں نے بِهٖ : اس سے فَسَيَقُوْلُوْنَ : تو اب کہیں گے ھٰذَآ اِفْكٌ : یہ جھوٹ قَدِيْمٌ : پُرانا اور کافروں نے ایمانداروں کی نسبت کہا کہ اگر یہ (دین) بہتر ہوتا تو یہ لوگ اس کی طرف ہم سے سبقت کرنے نہ پاتے اور چونکہ انہوں نے اس قرآن سے ہدایت نہیں پائی پس یہ کہہ دیں گے کہ قدیمی جھوٹ ہے (1)
46,12,وَ مِنْ قَبْلِهٖ كِتٰبُ مُوْسٰۤى اِمَامًا وَّ رَحْمَةً١ؕ وَ هٰذَا كِتٰبٌ مُّصَدِّقٌ لِّسَانًا عَرَبِیًّا لِّیُنْذِرَ الَّذِیْنَ ظَلَمُوْا١ۖۗ وَ بُشْرٰى لِلْمُحْسِنِیْنَۚ وَمِنْ قَبْلِهٖ : اور اس سے پہلے كِتٰبُ مُوْسٰٓى : موسیٰ کی کتاب اِمَامًا : رہنما وَّرَحْمَةً ۭ : اور رحمت وَھٰذَا كِتٰبٌ : اور یہ کتاب مُّصَدِّقٌ : تصدیق کرنیوالی لِّسَانًا عَرَبِيًّا : زبان عربی لِّيُنْذِرَ : تاکہ وہ ڈرائے الَّذِيْنَ ظَلَمُوْا ڰ : ان لوگوں کو جنہوں نے ظلم کیا وَبُشْرٰى : اور خوشخبری لِلْمُحْسِنِيْنَ : نیکو کاروں کے لئے اور اس سے پہلے موسیٰ کی کتاب پیشوا اور رحمت تھی اور یہ کتاب ہے تصدیق کرنے والی عربی زبان میں تاکہ ظالموں کو ڈرائے اور نیک کاروں کو بشارت ہو۔
46,13,اِنَّ الَّذِیْنَ قَالُوْا رَبُّنَا اللّٰهُ ثُمَّ اسْتَقَامُوْا فَلَا خَوْفٌ عَلَیْهِمْ وَ لَا هُمْ یَحْزَنُوْنَۚ اِنَّ : بیشک الَّذِيْنَ قَالُوْا : جن لوگوں نے کہا رَبُّنَا اللّٰهُ : ہمارا رب اللہ ثُمَّ اسْتَقَامُوْا : پھر وہ قائم رہے فَلَا خَوْفٌ : تو کوئی خوف نہیں عَلَيْهِمْ : ان پر وَلَا هُمْ : اور نہ وہ يَحْزَنُوْنَ : غمگین ہوں گے بیشک جن لوگوں نے کہا کہ ہمارا رب اللہ ہے پھر اس پر جمے رہے تو ان پر نہ کوئی خوف ہوگا نہ غمگین ہونگے۔
46,14,اُولٰٓئِكَ اَصْحٰبُ الْجَنَّةِ خٰلِدِیْنَ فِیْهَا١ۚ جَزَآءًۢ بِمَا كَانُوْا یَعْمَلُوْنَ اُولٰٓئِكَ : یہی لوگ اَصْحٰبُ الْجَنَّةِ : اہل جنت خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَا ۚ : اس میں جَزَآءًۢ : جزا بِمَا : اس کی جو كَانُوْا يَعْمَلُوْنَ : وہ عمل کرتے تھے یہ تو اہل جنت ہیں جو سدا اسی میں رہیں گے، ان اعمال کے بدلے جو وہ کیا کرتے تھے۔
46,15,وَ وَصَّیْنَا الْاِنْسَانَ بِوَالِدَیْهِ اِحْسٰنًا١ؕ حَمَلَتْهُ اُمُّهٗ كُرْهًا وَّ وَضَعَتْهُ كُرْهًا١ؕ وَ حَمْلُهٗ وَ فِصٰلُهٗ ثَلٰثُوْنَ شَهْرًا١ؕ حَتّٰۤى اِذَا بَلَغَ اَشُدَّهٗ وَ بَلَغَ اَرْبَعِیْنَ سَنَةً١ۙ قَالَ رَبِّ اَوْزِعْنِیْۤ اَنْ اَشْكُرَ نِعْمَتَكَ الَّتِیْۤ اَنْعَمْتَ عَلَیَّ وَ عَلٰى وَالِدَیَّ وَ اَنْ اَعْمَلَ صَالِحًا تَرْضٰىهُ وَ اَصْلِحْ لِیْ فِیْ ذُرِّیَّتِیْ١ؕۚ اِنِّیْ تُبْتُ اِلَیْكَ وَ اِنِّیْ مِنَ الْمُسْلِمِیْنَ وَوَصَّيْنَا : اور ہم نے حکم دیا الْاِنْسَانَ : انسان بِوَالِدَيْهِ : ماں باپ کے ساتھ اِحْسٰنًا ۭ : حسن سلوک کا حَمَلَتْهُ : وہ اس کو اٹھائے رہی اُمُّهٗ : اس کی ماں كُرْهًا : تکلیف کے ساتھ وَّوَضَعَتْهُ : اور اس نے اس کو جنا كُرْهًا ۭ : تکلیف کے ساتھ وَحَمْلُهٗ : اور اس کا حمل وَفِصٰلُهٗ : اور اسکا دودھ چھڑانا ثَلٰثُوْنَ شَهْرًا ۭ : تیس مہینے حَتّىٰٓ : یہاں تک اِذَا بَلَغَ : جب وہ پہنچا اَشُدَّهٗ : اپنے زور (جوانی) کو وَبَلَغَ : اور وہ پہنچا (ہوا) اَرْبَعِيْنَ سَنَةً ۙ : چالیس سال قَالَ : اس نے عرض کی رَبِّ : اے میرے رب اَوْزِعْنِيْٓ : توفیق دے مجھے اَنْ اَشْكُرَ : کہ میں شکر کروں نِعْمَتَكَ : تیری نعمت الَّتِيْٓ : وہ جو اَنْعَمْتَ : تو نے انعام فرمائی عَلَيَّ : مجھ پر وَعَلٰي : اور پر وَالِدَيَّ : میرے ماں باپ وَاَنْ : اور یہ کہ اَعْمَلَ : میں عمل کروں صَالِحًا : نیک عمل تَرْضٰىهُ : تو پسند کرے اسے وَاَصْلِحْ : اور اصلاح کردے لِيْ : میرے لئے فِيْ ذُرِّيَّتِيْ ڝ : میری اولاد میں اِنِّىْ تُبْتُ : بیشک میں نے توبہ کی اِلَيْكَ : تیری طرف وَاِنِّىْ : اور بیشک میں مِنَ الْمُسْلِمِيْنَ : مسلمانوں (فرمانبرداروں) سے اور ہم نے انسان کو اپنے ماں باپ کے ساتھ حسن سلوک کرنے کا حکم دیا ہے۔ اس کی ماں نے اسے تکلیف جھیل کر پیٹ میں رکھا اور تکلیف برداشت کرکے اسے جنا (1) اس کے حمل کا اور اس کے دودھ چھڑانے کا زمانہ تیس مہینے ہے (2) یہاں تک کہ جب وہ اپنی پختگی اور چالیس سال کی عمر کو پہنچا (3) تو کہنے لگا اے میرے پروردگار مجھے توفیق دے (4) کہ میں تیری اس نعمت کا شکر بجا لاؤ جو تو نے مجھ پر اور میرے ماں باپ پر انعام کیا ہے اور یہ کہ میں ایسے نیک عمل کروں جن سے تو خوش ہوجائے اور تو میری اولاد کو بھی صالح بنا۔ میں تیری طرف رجوع کرتا ہوں اور میں مسلمانوں میں سے ہوں۔
46,16,اُولٰٓئِكَ الَّذِیْنَ نَتَقَبَّلُ عَنْهُمْ اَحْسَنَ مَا عَمِلُوْا وَ نَتَجَاوَزُ عَنْ سَیِّاٰتِهِمْ فِیْۤ اَصْحٰبِ الْجَنَّةِ١ؕ وَعْدَ الصِّدْقِ الَّذِیْ كَانُوْا یُوْعَدُوْنَ اُولٰٓئِكَ : یہی لوگ الَّذِيْنَ : وہ جو کہ نَتَقَبَّلُ : ہم قبول کرتے ہیں عَنْهُمْ : ان سے اَحْسَنَ : بہترین (عمل) مَا : جو عَمِلُوْا : انہوں نے کئے وَنَتَجَاوَزُ : اور ہم درگزر کرتے ہیں عَنْ سَيِّاٰتِهِمْ : ان کی بُرائیوں سے فِيْٓ اَصْحٰبِ الْجَنَّةِ ۭ : اہل جنت میں وَعْدَ الصِّدْقِ : سچا وعدہ الَّذِيْ : وہ جو كَانُوْا يُوْعَدُوْنَ : انہیں وعدہ دیا جاتا تھا یہی وہ لوگ ہیں جن کے نیک اعمال تو ہم قبول فرما لیتے ہیں اور جن کے بعض اعمال سے درگزر کرلیتے ہیں، یہ جنتی لوگوں میں ہیں۔ اس سچے وعدے کے مطابق جو ان سے کیا جاتا ہے۔
46,17,وَ الَّذِیْ قَالَ لِوَالِدَیْهِ اُفٍّ لَّكُمَاۤ اَتَعِدٰنِنِیْۤ اَنْ اُخْرَجَ وَ قَدْ خَلَتِ الْقُرُوْنُ مِنْ قَبْلِیْ١ۚ وَ هُمَا یَسْتَغِیْثٰنِ اللّٰهَ وَیْلَكَ اٰمِنْ١ۖۗ اِنَّ وَعْدَ اللّٰهِ حَقٌّ١ۖۚ فَیَقُوْلُ مَا هٰذَاۤ اِلَّاۤ اَسَاطِیْرُ الْاَوَّلِیْنَ وَالَّذِيْ : اور وہ جس قَالَ : اس نے کہا لِوَالِدَيْهِ : اپنے ماں باپ کیلئے اُفٍّ : تف لَّكُمَآ : تم پر اَتَعِدٰنِنِيْٓ : کیا تم مجھے وعدہ (خبر) دیتے ہو اَنْ اُخْرَجَ : کہ میں نکالا جاؤں گا وَقَدْ خَلَتِ : حالانکہ گزر چکے الْقُرُوْنُ : (بہت سے) گروہ مِنْ قَبْلِيْ ۚ : مجھ سے پہلے وَهُمَا : اور وہ دونوں يَسْتَغِيْثٰنِ : فریاد کرتے ہیں اللّٰهَ : اللہ سے وَيْلَكَ : تیرا بُرا ہو اٰمِنْ ڰ : تو ایمان لے آ اِنَّ : بیشک وَعْدَ اللّٰهِ : اللہ کا وعدہ حَقٌّ ښ : سچا فَيَقُوْلُ : تو وہ کہتا ہے مَا ھٰذَآ : نہیں یہ اِلَّآ : مگر، صرف اَسَاطِيْرُ : کہانیاں الْاَوَّلِيْنَ : پہلوں اور جس نے اپنے ماں باپ سے کہا کہ تم سے میں تنگ آگیا (1) تم مجھ سے یہ کہتے رہو گے کہ میں مرنے کے بعد زندہ ہوجاؤں گا مجھ سے پہلے بھی امتیں گزر چکی ہیں (2) وہ دونوں جناب باری میں فریاد کرتے ہیں اور کہتے ہیں تجھے خرابی ہو تو ایمان لے آ، بیشک اللہ کا وعدہ حق ہے، وہ جواب دیتا ہے کہ یہ تو صرف اگلوں کے افسانے ہیں (3)۔
46,18,اُولٰٓئِكَ الَّذِیْنَ حَقَّ عَلَیْهِمُ الْقَوْلُ فِیْۤ اُمَمٍ قَدْ خَلَتْ مِنْ قَبْلِهِمْ مِّنَ الْجِنِّ وَ الْاِنْسِ١ؕ اِنَّهُمْ كَانُوْا خٰسِرِیْنَ اُولٰٓئِكَ : یہی لوگ الَّذِيْنَ : وہ جو حَقَّ : ثابت ہوگئی عَلَيْهِمُ : ان پر الْقَوْلُ : بات (عذاب) فِيْٓ اُمَمٍ : امتوں میں قَدْ خَلَتْ : گزر چکیں مِنْ قَبْلِهِمْ : ان سے قبل مِّنَ الْجِنِّ : جنات سے وَالْاِنْسِ ۭ : اور انسان (جمع) اِنَّهُمْ كَانُوْا : بیشک وہ تھے خٰسِرِيْنَ : خسارہ پانے والے یہی وہ لوگ ہیں جن پر (اللہ کے عذاب کا) وعدہ صادق آگیا (1) ان جنات اور انسانوں کے گروہوں کے ساتھ جو ان سے پہلے گزر چکے (2) یقیناً یہ نقصان پانے والے تھے۔
46,19,وَ لِكُلٍّ دَرَجٰتٌ مِّمَّا عَمِلُوْا١ۚ وَ لِیُوَفِّیَهُمْ اَعْمَالَهُمْ وَ هُمْ لَا یُظْلَمُوْنَ وَلِكُلٍّ : اور ہر ایک کیلئے دَرَجٰتٌ : درجے مِّمَّا عَمِلُوْا ۚ : اس سے جو انہوں نے کیا وَلِيُوَفِّيَهُمْ : اور تاکہ وہ پورا دے ان کو اَعْمَالَهُمْ : ان کے اعمال وَهُمْ لَا يُظْلَمُوْنَ : اور ان پر ظلم نہ کیا جائیگا اور ہر ایک کو اپنے اپنے اعمال کے مطابق درجے ملیں گے (1) تاکہ انہیں ان کے اعمال کا پورے بدلے دے اور ان پر ظلم نہ کیا جائے گا۔ (2)
46,20,وَ یَوْمَ یُعْرَضُ الَّذِیْنَ كَفَرُوْا عَلَى النَّارِ١ؕ اَذْهَبْتُمْ طَیِّبٰتِكُمْ فِیْ حَیَاتِكُمُ الدُّنْیَا وَ اسْتَمْتَعْتُمْ بِهَا١ۚ فَالْیَوْمَ تُجْزَوْنَ عَذَابَ الْهُوْنِ بِمَا كُنْتُمْ تَسْتَكْبِرُوْنَ فِی الْاَرْضِ بِغَیْرِ الْحَقِّ وَ بِمَا كُنْتُمْ تَفْسُقُوْنَ۠    ۧ وَيَوْمَ : اور جس دن يُعْرَضُ : لائے جائیں گے الَّذِيْنَ كَفَرُوْا : وہ جنہوں نے کفر کیا (کافر) عَلَي النَّارِ ۭ : آگ کے سامنے اَذْهَبْتُمْ : تم لے گئے (حاصل کرچکے) طَيِّبٰتِكُمْ : اپنی نعمتیں فِيْ حَيَاتِكُمُ الدُّنْيَا : اپنی دنیا کی زندگی میں وَاسْتَمْتَعْتُمْ : اور تم فائدہ اٹھاچکے بِهَا ۚ : ان کا فَالْيَوْمَ : پس آج تُجْزَوْنَ : تمہیں بدلہ دیا جائے گا عَذَابَ الْهُوْنِ : رسوائی کا عذاب بِمَا : اس لئے کہ كُنْتُمْ تَسْتَكْبِرُوْنَ : تم تکبر کرتے تھے فِي الْاَرْضِ : زمین میں بِغَيْرِ الْحَقِّ : ناحق وَبِمَا : اور اس لئے کہ كُنْتُمْ تَفْسُقُوْنَ : تم نافرمانیاں کرتے تھے اور جس دن کافر جہنم کے سرے پر لائے جائیں گے (1) (کہا جائے گا) تم نے اپنی نیکیاں دنیا کی زندگی میں ہی برباد کردیں اور ان کا فائدہ نہ اٹھا چکے، پس آج تمہیں ذلت کے عذاب کی سزا دی جائے گی (2) اس باعث کہ تم زمین میں ناحق تکبر کیا کرتے تھے اور اس باعث بھی کہ تم حکم عدولی کرتے تھے (3)
46,21,وَ اذْكُرْ اَخَا عَادٍ١ؕ اِذْ اَنْذَرَ قَوْمَهٗ بِالْاَحْقَافِ وَ قَدْ خَلَتِ النُّذُرُ مِنْۢ بَیْنِ یَدَیْهِ وَ مِنْ خَلْفِهٖۤ اَلَّا تَعْبُدُوْۤا اِلَّا اللّٰهَ١ؕ اِنِّیْۤ اَخَافُ عَلَیْكُمْ عَذَابَ یَوْمٍ عَظِیْمٍ وَاذْكُرْ : اور یاد کر اَخَا عَادٍ ۭ : عاد کے بھائی اِذْ اَنْذَرَ : جب اس نے ڈرایا قَوْمَهٗ : اپنی قوم بِالْاَحْقَافِ : احقاف میں وَقَدْ خَلَتِ : اور گزرچکے النُّذُرُ : ڈرانے والے مِنْۢ بَيْنِ يَدَيْهِ : اس سے پہلے وَمِنْ خَلْفِهٖٓ : اور اس کے بعد اَلَّا تَعْبُدُوْٓا : کہ تم عبادت نہ کرو اِلَّا اللّٰهَ ۭ : اللہ کے سوا اِنِّىْٓ اَخَافُ : بیشک میں ڈرتا ہوں عَلَيْكُمْ : تم پر عَذَابَ : عذاب يَوْمٍ : ایک دن عَظِيْمٍ : بڑا اور عاد کے بھائی کو یاد کرو، جبکہ اس نے اپنی قوم کو احقاف میں ڈرایا (1) اور یقیناً اس سے پہلے بھی ڈرانے والے گزر چکے ہیں اور اس کے بعد بھی یہ کہ تم سوائے اللہ تعالیٰ کے اور کی عبادت نہ کرو بیشک میں تم پر بڑے دن کے عذاب سے خوف کھاتا ہوں (2)۔
46,22,قَالُوْۤا اَجِئْتَنَا لِتَاْفِكَنَا عَنْ اٰلِهَتِنَا١ۚ فَاْتِنَا بِمَا تَعِدُنَاۤ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ قَالُوْٓا : وہ بولے اَجِئْتَنَا : کیا تو ہمارے پاس آیا لِتَاْفِكَنَا : کہ تو پھیر دے ہمیں عَنْ اٰلِهَتِنَا ۚ : ہمارے معبودوں سے فَاْتِنَا : پس لے آ ہم پر بِمَا : جو کچھ تَعِدُنَآ : تو وعدہ کرتا ہے ہم سے اِنْ كُنْتَ : اگر تو ہے مِنَ الصّٰدِقِيْنَ : سچوں میں سے قوم نے جواب دیا کیا آپ ہمارے پاس اس لئے آئے ہیں کہ ہمیں اپنے معبودوں (کی پرستش) سے باز رکھیں (1) پس اگر آپ سچے ہیں تو جس عذاب کا آپ وعدہ کرتے ہیں اسے ہم پر لا ڈالیں۔
46,23,قَالَ اِنَّمَا الْعِلْمُ عِنْدَ اللّٰهِ١ۖ٘ وَ اُبَلِّغُكُمْ مَّاۤ اُرْسِلْتُ بِهٖ وَ لٰكِنِّیْۤ اَرٰىكُمْ قَوْمًا تَجْهَلُوْنَ قَالَ : اس نے کہا اِنَّمَا : اس کے سوا نہیں الْعِلْمُ : علم عِنْدَ اللّٰهِ ڮ : اللہ کے پاس ہے وَاُبَلِّغُكُمْ : اور میں پہنچاتا ہوں تمہیں مَّآ اُرْسِلْتُ : جو میں بھیجا گیا ہوں بِهٖ : اس کے ساتھ وَلٰكِنِّىْٓ : اور لیکن میں اَرٰىكُمْ : دیکھتا ہوں تمہیں قَوْمًا : گروہ، لوگ تَجْهَلُوْنَ : تم جہالت کرتے ہو (حضرت ہود نے) کہا (اس کا) علم تو اللہ ہی کے پاس ہے میں تو جو پیغام دے کر بھیجا گیا تھا وہ تمہیں پہنچا رہا ہوں (1) لیکن میں دیکھتا ہوں کہ تم لوگ نادانی کر رہے ہو (2)
46,24,فَلَمَّا رَاَوْهُ عَارِضًا مُّسْتَقْبِلَ اَوْدِیَتِهِمْ١ۙ قَالُوْا هٰذَا عَارِضٌ مُّمْطِرُنَا١ؕ بَلْ هُوَ مَا اسْتَعْجَلْتُمْ بِهٖ١ؕ رِیْحٌ فِیْهَا عَذَابٌ اَلِیْمٌۙ فَلَمَّا : پھر جب رَاَوْهُ : دیکھا انہوں نے اسکو عَارِضًا : ایک ابر مُّسْتَقْبِلَ : سامنے (چلا) آرہا ہے اَوْدِيَتِهِمْ ۙ : ان کی وادیاں قَالُوْا : وہ بولے ھٰذَا : یہ عَارِضٌ : ایک بادل مُّمْطِرُنَا ۭ : ہم پر بارش برسانے والا بَلْ هُوَ : بلکہ وہ مَا اسْتَعْجَلْتُمْ : جس کی تم جلدی کرتے تھے بِهٖ ۭ : اس کی رِيْحٌ : ایک ہوا، آندھی فِيْهَا : اس میں عَذَابٌ : دردناک اَلِيْمٌ : عذاب پھر جب انہوں نے عذاب کو بصورت بادل دیکھا اپنی وادیوں کی طرف آتے ہوئے کہنے لگے، یہ بادل ہم پر برسنے والا ہے (1) (نہیں) بلکہ دراصل یہ ابر وہ (عذاب) ہے جس کی تم جلدی کر رہے تھے (2) ہوا ہے جس میں دردناک عذاب ہے۔ (3)
46,25,تُدَمِّرُ كُلَّ شَیْءٍۭ بِاَمْرِ رَبِّهَا فَاَصْبَحُوْا لَا یُرٰۤى اِلَّا مَسٰكِنُهُمْ١ؕ كَذٰلِكَ نَجْزِی الْقَوْمَ الْمُجْرِمِیْنَ تُدَمِّرُ : وہ تہس نہس کردے گی كُلَّ شَيْءٍۢ : ہر شے کو بِاَمْرِ : حکم سے رَبِّهَا : اپنا رب فَاَصْبَحُوْا : پس رہ گئے لَا يُرٰٓى : نہ دکھائی دیتا تھا اِلَّا : سوائے مَسٰكِنُهُمْ ۭ : ان کے مکان كَذٰلِكَ : اسی طرح نَجْزِي : ہم بدلہ دیتے ہیں الْقَوْمَ : لوگ الْمُجْرِمِيْنَ : مجرم (جمع) جو اپنے رب کے حکم سے ہر چیز کو ہلاک کر دے گا، پس وہ ایسے ہوگئے کہ بجز ان کے مکانات کے اور کچھ دکھائی نہ دیتا (1) تھا گناہ گاروں کے گروہ کو ہم ایسی ہی سزا دیتے ہیں۔
46,26,وَ لَقَدْ مَكَّنّٰهُمْ فِیْمَاۤ اِنْ مَّكَّنّٰكُمْ فِیْهِ وَ جَعَلْنَا لَهُمْ سَمْعًا وَّ اَبْصَارًا وَّ اَفْئِدَةً١ۖ٘ فَمَاۤ اَغْنٰى عَنْهُمْ سَمْعُهُمْ وَ لَاۤ اَبْصَارُهُمْ وَ لَاۤ اَفْئِدَتُهُمْ مِّنْ شَیْءٍ اِذْ كَانُوْا یَجْحَدُوْنَ١ۙ بِاٰیٰتِ اللّٰهِ وَ حَاقَ بِهِمْ مَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ۠    ۧ وَلَقَدْ : اور البتہ مَكَّنّٰهُمْ : ہم نے ان کو قدرت دی تھی فِيْمَآ : اس میں اِنْ : نہیں مَّكَّنّٰكُمْ : ہم نے قدرت دی تمہیں فِيْهِ : اس میں، پر وَجَعَلْنَا : اور ہم نے بنائے، دئیے لَهُمْ : انہیں سَمْعًا : کان وَّاَبْصَارًا : اور آنکھیں وَّاَفْئِدَةً ڮ : اور دل (جمع) فَمَآ اَغْنٰى : تو نہ کام آئے عَنْهُمْ : ان کے سَمْعُهُمْ : ان کے کان وَلَآ اَبْصَارُهُمْ : اور نہ ان کی آنکھیں وَلَآ اَفْئِدَتُهُمْ : اور نہ دل ان کے مِّنْ شَيْءٍ : کچھ بھی اِذْ : جب كَانُوْا يَجْحَدُوْنَ ۙ : وہ انکار کرتے تھے بِاٰيٰتِ اللّٰهِ : اللہ کی آیات کا وَحَاقَ : اور اس نے گھیر لیا بِهِمْ : ان کو مَّا كَانُوْا : جو وہ تھے بِهٖ : اس کا يَسْتَهْزِءُوْنَ : مذاق اڑاتے اور بالیقین ہم نے (قوم عاد) کو وہ مقدور دیئے تھے جو تمہیں تو دیئے بھی نہیں اور ہم نے انہیں کان آنکھیں اور دل بھی دے رکھے تھے۔ لیکن ان کے کانوں اور آنکھوں اور دلوں نے انہیں کچھ بھی نفع نہ پہنچایا (1) جبکہ اللہ تعالیٰ کی آیتوں کا انکار کرنے لگے اور جس چیز کا وہ مذاق اڑایا کرتے تھے وہی ان پر الٹ پڑی (2)۔
46,27,وَ لَقَدْ اَهْلَكْنَا مَا حَوْلَكُمْ مِّنَ الْقُرٰى وَ صَرَّفْنَا الْاٰیٰتِ لَعَلَّهُمْ یَرْجِعُوْنَ وَلَقَدْ : اور تحقیق اَهْلَكْنَا : ہم نے ہلاک کردیا مَا حَوْلَكُمْ : جو تمہارے اردگرد مِّنَ : سے الْقُرٰى : بستیاں وَصَرَّفْنَا : اور ہم نے بار بار دکھائیں الْاٰيٰتِ : اپنی نشانیاں لَعَلَّهُمْ : تاکہ وہ يَرْجِعُوْنَ : لوٹ آئیں اور یقیناً ہم نے تمہارے آس پاس کی بستیاں تباہ کردیں (1) اور طرح طرح کی ہم نے اپنی نشانیاں بیان کردیں تاکہ وہ رجوع کرلیں (2)۔
46,28,فَلَوْ لَا نَصَرَهُمُ الَّذِیْنَ اتَّخَذُوْا مِنْ دُوْنِ اللّٰهِ قُرْبَانًا اٰلِهَةً١ؕ بَلْ ضَلُّوْا عَنْهُمْ١ۚ وَ ذٰلِكَ اِفْكُهُمْ وَ مَا كَانُوْا یَفْتَرُوْنَ فَلَوْلَا : پھر کیوں نہ نَصَرَهُمُ : مدد کی ان کی الَّذِيْنَ اتَّخَذُوْا : جنہیں بنالیا انہوں نے مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا قُرْبَانًا : قرب حاصل کرنے کو اٰلِهَةً ۭ : معبود بَلْ ضَلُّوْا : بلکہ وہ گم (غائب) ہوگئے عَنْهُمْ ۚ : ان سے وَذٰلِكَ : اور یہ اِفْكُهُمْ : ان کا بہتان وَمَا : اور جو كَانُوْا يَفْتَرُوْنَ : وہ افترا کرتے تھے پس قرب الٰہی حاصل کرنے کے لئے انہوں نے اللہ کے سوا جن جن کو اپنا معبود بنا رکھا تھا انہوں نے ان کی مدد کیوں نہ کی ؟ بلکہ وہ تو ان سے کھو گئے، بلکہ دراصل یہ محض جھوٹ اور بالکل بہتان تھا۔ (1)
46,29,وَ اِذْ صَرَفْنَاۤ اِلَیْكَ نَفَرًا مِّنَ الْجِنِّ یَسْتَمِعُوْنَ الْقُرْاٰنَ١ۚ فَلَمَّا حَضَرُوْهُ قَالُوْۤا اَنْصِتُوْا١ۚ فَلَمَّا قُضِیَ وَ لَّوْا اِلٰى قَوْمِهِمْ مُّنْذِرِیْنَ وَاِذْ : اور جب صَرَفْنَآ : ہم پھیر لائے اِلَيْكَ : آپ کی طرف نَفَرًا : ایک جماعت مِّنَ الْجِنِّ : جنات کی يَسْتَمِعُوْنَ : وہ سنتے تھے الْقُرْاٰنَ ۚ : قرآن فَلَمَّا : پس جب حَضَرُوْهُ : وہ حاضر ہوئے ان کے پاس قَالُوْٓا : انہوں نے کہا اَنْصِتُوْا ۚ : چپ رہو فَلَمَّا : پھر جب قُضِيَ : (پڑھنا) تمام ہوا وَلَّوْا : وہ لوٹے اِلٰى قَوْمِهِمْ : اپنی قوم کی طرف مُّنْذِرِيْنَ : ڈر سناتے ہوئے اور یاد کرو ! جبکہ ہم نے جنوں کی ایک جماعت کو تیری طرف متوجہ کیا کہ وہ قرآن سنیں، پس جب (نبی کے) پاس پہنچ گئے تو (ایک دوسرے سے) کہنے لگے خاموش ہوجاؤ (1) پھر جب پڑھ کر ختم ہوگیا (2) تو اپنی قوم کو خبردار کرنے کے لئے واپس لوٹ گئے۔
46,30,قَالُوْا یٰقَوْمَنَاۤ اِنَّا سَمِعْنَا كِتٰبًا اُنْزِلَ مِنْۢ بَعْدِ مُوْسٰى مُصَدِّقًا لِّمَا بَیْنَ یَدَیْهِ یَهْدِیْۤ اِلَى الْحَقِّ وَ اِلٰى طَرِیْقٍ مُّسْتَقِیْمٍ قَالُوْا : انہوں نے کہا يٰقَوْمَنَآ : اے ہماری قوم اِنَّا سَمِعْنَا : بیشک ہم نے سنی كِتٰبًا : ایک کتاب اُنْزِلَ : نازل کی گئی مِنْۢ بَعْدِ مُوْسٰى : موسیٰ کے بعد مُصَدِّقًا : تصدیق کرنے والی لِّمَا : اس کی بَيْنَ يَدَيْهِ : جو اس سے (اپنے سے) پہلے يَهْدِيْٓ : وہ رہنمائی کرتی ہے اِلَى الْحَقِّ : حق کی طرف وَاِلٰى : اور طرف طَرِيْقٍ : راہ مُّسْتَقِيْمٍ : راست کہنے لگے اے ہماری قوم ! ہم نے یقیناً وہ کتاب سنی ہے جو موسیٰ ؑ کے بعد نازل کی گئی ہے جو اپنے سے پہلی کتابوں کی تصدیق کرنے والی ہے جو سچے دین کی اور راہ راست کی رہنمائی کرتی ہے۔
46,31,یٰقَوْمَنَاۤ اَجِیْبُوْا دَاعِیَ اللّٰهِ وَ اٰمِنُوْا بِهٖ یَغْفِرْ لَكُمْ مِّنْ ذُنُوْبِكُمْ وَ یُجِرْكُمْ مِّنْ عَذَابٍ اَلِیْمٍ يٰقَوْمَنَآ : اے ہماری قوم اَجِيْبُوْا : قبول کرلو دَاعِيَ اللّٰهِ : اللہ کی طرف بلانے والا وَاٰمِنُوْا : اور ایمان لے آؤ بِهٖ : اس پر يَغْفِرْ لَكُمْ : بخشدے گا تمہیں مِّنْ : سے ذُنُوْبِكُمْ : تمہارے گناہ وَيُجِرْكُمْ : اور وہ پناہ دے گا تمہیں مِّنْ : سے عَذَابٍ اَلِيْمٍ : دردناک عذاب اے ہماری قوم ! اللہ کے بلانے والے کا کہا مانو، اس پر ایمان لاؤ (1) تو اللہ تمہارے تمام گناہ بخش دے گا اور تمہیں المناک سزا سے پناہ دے گا (2)
46,32,وَ مَنْ لَّا یُجِبْ دَاعِیَ اللّٰهِ فَلَیْسَ بِمُعْجِزٍ فِی الْاَرْضِ وَ لَیْسَ لَهٗ مِنْ دُوْنِهٖۤ اَوْلِیَآءُ١ؕ اُولٰٓئِكَ فِیْ ضَلٰلٍ مُّبِیْنٍ وَمَنْ لَّا يُجِبْ : اور جو نہ قبول کریگا دَاعِيَ اللّٰهِ : اللہ کی طرف بلانیوالا فَلَيْسَ : تو نہیں بِمُعْجِزٍ : عاجز کرنے والا فِي الْاَرْضِ : زمین میں وَلَيْسَ : اور نہیں لَهٗ : اس کے لئے مِنْ دُوْنِهٖٓ : اس کے سوا اَوْلِيَآءُ ۭ : حمایتی اُولٰٓئِكَ : یہی لوگ فِيْ : میں ضَلٰلٍ مُّبِيْنٍ : گمراہی کھلی اور جو شخص اللہ کے بلانے والے کا کہا نہ مانے گا پس وہ زمین میں کہیں (بھاگ کر اللہ کو) عاجز نہیں کرسکتا (1) اور نہ اللہ کے سوا اور کوئی مددگار ہوں گے (2) یہ لوگ کھلی گمراہی میں ہیں۔
46,33,اَوَ لَمْ یَرَوْا اَنَّ اللّٰهَ الَّذِیْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ وَ لَمْ یَعْیَ بِخَلْقِهِنَّ بِقٰدِرٍ عَلٰۤى اَنْ یُّحْیَِۧ الْمَوْتٰى١ؕ بَلٰۤى اِنَّهٗ عَلٰى كُلِّ شَیْءٍ قَدِیْرٌ اَوَ : کیا لَمْ : نہیں يَرَوْا : دیکھا انہوں نے اَنَّ اللّٰهَ : کہ اللہ الَّذِيْ : وہ جس نے خَلَقَ : پیدا کیا السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین کو وَلَمْ يَعْيَ : اور وہ تھکا نہیں بِخَلْقِهِنَّ : انکے پیدا کرنے سے بِقٰدِرٍ : وہ قادر ہے عَلٰٓي : پر اَنْ يُّحْيِۦ : کہ زندہ کرے الْمَوْتٰى ۭ : مردے بَلٰٓي : ہاں اِنَّهٗ : بیشک وہ عَلٰي كُلِّ شَيْءٍ : ہر شے پر قَدِيْرٌ : قدرت رکھنے والا کیا وہ نہیں دیکھتے کہ جس اللہ نے آسمانوں اور زمین کو پیدا کیا اور ان کے پیدا کرنے سے وہ نہ تھکا، وہ یقیناً ہر چیز پر قادر ہے (1)
46,34,وَ یَوْمَ یُعْرَضُ الَّذِیْنَ كَفَرُوْا عَلَى النَّارِ١ؕ اَلَیْسَ هٰذَا بِالْحَقِّ١ؕ قَالُوْا بَلٰى وَ رَبِّنَا١ؕ قَالَ فَذُوْقُوا الْعَذَابَ بِمَا كُنْتُمْ تَكْفُرُوْنَ وَيَوْمَ : اور جس دن يُعْرَضُ : پیش کئے جائیں گے الَّذِيْنَ : جنہوں نے كَفَرُوْا : کفر کیا عَلَي النَّارِ ۭ : آگ کے سامنے اَلَيْسَ : کیا نہیں ھٰذَا : یہ بِالْحَقِّ ۭ : حق قَالُوْا : وہ کہیں گے بَلٰي : ہاں وَرَبِّنَا ۭ : ہمارے رب کی قسم قَالَ : وہ فرمائے گا فَذُوْقُوا : پس تم چکھو الْعَذَابَ : عذاب بِمَا : وہ جس كُنْتُمْ تَكْفُرُوْنَ : تم انکار کرتے تھے وہ لوگ جنہوں نے کفر کیا جس دن جہنم کے سامنے لائے جائیں گے (اور ان سے کہا جائے گا کہ) کیا یہ حق نہیں ہے ؟ تو جواب دیں گے کہ ہاں قسم ہے (1) ہمارے رب کی (حق ہے) (اللہ) فرمائے گا اب اپنے کفر کے بدلے عذاب کا مزہ چکھو (2)۔
46,35,فَاصْبِرْ كَمَا صَبَرَ اُولُوا الْعَزْمِ مِنَ الرُّسُلِ وَ لَا تَسْتَعْجِلْ لَّهُمْ١ؕ كَاَنَّهُمْ یَوْمَ یَرَوْنَ مَا یُوْعَدُوْنَ١ۙ لَمْ یَلْبَثُوْۤا اِلَّا سَاعَةً مِّنْ نَّهَارٍ١ؕ بَلٰغٌ١ۚ فَهَلْ یُهْلَكُ اِلَّا الْقَوْمُ الْفٰسِقُوْنَ۠    ۧ فَاصْبِرْ : پس آپ صبر کریں كَمَا صَبَرَ : جیسے صبر کیا اُولُوا الْعَزْمِ : اولوالعزم مِنَ الرُّسُلِ : رسولوں نے، سے وَلَا تَسْتَعْجِلْ : اور جلدی نہ کریں لَّهُمْ ۭ : ان کے لئے كَاَنَّهُمْ : گویا کہ وہ يَوْمَ يَرَوْنَ : جس دن دیکھیں گے مَا : جس کا يُوْعَدُوْنَ ۙ : و عدہ کیا جاتا ہے ان سے لَمْ يَلْبَثُوْٓا : وہ نہیں ٹھہرے اِلَّا : مگر، صرف سَاعَةً : ایک گھڑی مِّنْ نَّهَارٍ ۭ : دن کی بَلٰغٌ ۚ : پہنچانا فَهَلْ : پس نہیں يُهْلَكُ : ہلاک ہوں گے اِلَّا : مگر الْقَوْمُ : لوگ الْفٰسِقُوْنَ : نافرمان پس (اے پیغمبر !) تم ایسا صبر کرو جیسا صبر عالی ہمت رسولوں نے کیا اور ان کے لئے عذاب طلب کرنے میں جلدی نہ کرو (1) یہ جس دن اس عذاب کو دیکھ لیں گے جس کا وعدہ دیئے جاتے ہیں تو (یہ معلوم ہونے لگے گا کہ دن کی ایک گھڑی ہی دنیا میں) ٹھہرے تھے (2) یہ ہے پیغام پہنچا (3) دینا، پس بدکاروں کے سوا کوئی ہلاک نہ کیا جائے گا۔ (4)
