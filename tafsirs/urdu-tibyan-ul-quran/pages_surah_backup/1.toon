quran[7]{c,v,t}:
1,1,بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ بِ : سے اسْمِ : نام اللّٰهِ : اللہ ال : جو رَحْمٰنِ : بہت مہربان الرَّحِيمِ : جو رحم کرنے والا شروع کرتا ہوں میں اللہ تعالیٰ کے نام سے جو نہایت مہربان بڑا رحم والا ہے
1,2,اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰلَمِیْنَۙ الْحَمْدُ : تمام تعریفیں لِلّٰہِ : اللہ کے لیے رَبِّ : رب الْعَالَمِينَ : تمام جہان سب تعریفیں اللہ تعالیٰ کے لیے ہیں (1) جو تمام جہانوں کا پالنے والا ہے (2)
1,3,الرَّحْمٰنِ الرَّحِیْمِۙ الرَّحْمٰنِ : جو بہت مہربان الرَّحِيم : رحم کرنے والا بڑا مہربان نہایت رحم کرنے والا (1)۔
1,4,مٰلِكِ یَوْمِ الدِّیْنِؕ مَالِكِ : مالک يَوْمِ : دن الدِّينِ : بدلہ بدلے کے دن (یعنی قیامت کا) مالک ہے (1)
1,5,اِیَّاكَ نَعْبُدُ وَ اِیَّاكَ نَسْتَعِیْنُؕ اِيَّاكَ : صرف تیری نَعْبُدُ : ہم عبادت کرتے ہیں وَ : اور اِيَّاكَ : صرف تجھ سے نَسْتَعِيْنُ : ہم مدد چاہتے ہیں ہم صرف تیری ہی عبادت کرتے ہیں اور تجھ سے ہی مدد چاہتے ہیں (1)۔
1,6,اِهْدِنَا الصِّرَاطَ الْمُسْتَقِیْمَۙ اِهْدِنَا : ہمیں ہدایت دے الصِّرَاطَ : راستہ الْمُسْتَقِيمَ : سیدھا ہمیں سچی اور سیدھی راہ دکھا (1)۔
1,7,صِرَاطَ الَّذِیْنَ اَنْعَمْتَ عَلَیْهِمْ١ۙ۬ۦ غَیْرِ الْمَغْضُوْبِ عَلَیْهِمْ وَ لَا الضَّآلِّیْنَ۠    ۧ صِرَاطَ : راستہ الَّذِينَ : ان لوگوں کا أَنْعَمْتَ : تونے انعام کیا عَلَيْهِمْ : ان پر غَيْرِ : نہ الْمَغْضُوبِ : غضب کیا گیا عَلَيْهِمْ : ان پر وَلَا : اور نہ الضَّالِّينَ : جو گمراہ ہوئے ان لوگوں کا راستہ جن پر تو نے انعام کیا (1)۔ ان کا نہیں جن پر غضب کیا گیا اور نہ گمراہوں کا۔ (2)
