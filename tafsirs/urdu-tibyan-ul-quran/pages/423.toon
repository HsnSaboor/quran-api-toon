tafsir[8]{c,v,t}:
  33,36,وَ مَا كَانَ لِمُؤْمِنٍ وَّ لَا مُؤْمِنَةٍ اِذَا قَضَى اللّٰهُ وَ رَسُوْلُهٗۤ اَمْرًا اَنْ یَّكُوْنَ لَهُمُ الْخِیَرَةُ مِنْ اَمْرِهِمْ١ؕ وَ مَنْ یَّعْصِ اللّٰهَ وَ رَسُوْلَهٗ فَقَدْ ضَلَّ ضَلٰلًا مُّبِیْنًاؕ وَمَا كَانَ : اور نہیں ہے لِمُؤْمِنٍ : کسی مومن مرد کے لیے وَّلَا مُؤْمِنَةٍ : اور نہ کسی مومن عورت کے لیے اِذَا : جب قَضَى : فیصلہ کردیں اللّٰهُ : اللہ وَرَسُوْلُهٗٓ : اور اس کا رسول اَمْرًا : کسی کام کا اَنْ يَّكُوْنَ : کہ (باقی) ہو لَهُمُ : ان کے لیے الْخِيَرَةُ : کوئی اختیار مِنْ اَمْرِهِمْ ۭ : ان کے کام میں وَمَنْ : اور جو يَّعْصِ : نافرمانی کرے گا اللّٰهَ : اللہ وَرَسُوْلَهٗ : اور اس کا رسول فَقَدْ ضَلَّ : تو البتہ وہ گمراہی میں جا پڑا ضَلٰلًا : گمراہی مُّبِيْنًا : صریح اور (دیکھو) کسی مومن مرد و عورت کو اللہ اور اس کے رسول کے فیصلہ کے بعد کسی امر کا کا کوئی اختیار باقی نہیں رہتا 1 یاد رکھو اللہ تعالیٰ اور اس کے رسول کی بھی نافرمانی کرے گا وہ صریح گمراہی میں پڑے گا۔
  33,37,وَ اِذْ تَقُوْلُ لِلَّذِیْۤ اَنْعَمَ اللّٰهُ عَلَیْهِ وَ اَنْعَمْتَ عَلَیْهِ اَمْسِكْ عَلَیْكَ زَوْجَكَ وَ اتَّقِ اللّٰهَ وَ تُخْفِیْ فِیْ نَفْسِكَ مَا اللّٰهُ مُبْدِیْهِ وَ تَخْشَى النَّاسَ١ۚ وَ اللّٰهُ اَحَقُّ اَنْ تَخْشٰىهُ١ؕ فَلَمَّا قَضٰى زَیْدٌ مِّنْهَا وَطَرًا زَوَّجْنٰكَهَا لِكَیْ لَا یَكُوْنَ عَلَى الْمُؤْمِنِیْنَ حَرَجٌ فِیْۤ اَزْوَاجِ اَدْعِیَآئِهِمْ اِذَا قَضَوْا مِنْهُنَّ وَطَرًا١ؕ وَ كَانَ اَمْرُ اللّٰهِ مَفْعُوْلًا وَاِذْ : اور (یاد کرو) جب تَقُوْلُ : آپ فرماتے تھے لِلَّذِيْٓ : اس شخص کو اَنْعَمَ اللّٰهُ : اللہ نے انعام کیا عَلَيْهِ : اس پر وَاَنْعَمْتَ : اور آپ نے انعام کیا عَلَيْهِ : اس پر اَمْسِكْ : روکے رکھ عَلَيْكَ : اپنے پاس زَوْجَكَ : اپنی بیوی وَاتَّقِ اللّٰهَ : اور ڈر اللہ سے وَتُخْفِيْ : اور آپ چھپاتے تھے فِيْ نَفْسِكَ : اپنے دل میں مَا اللّٰهُ : جو اللہ مُبْدِيْهِ : اس کو ظاہر کرنے والا وَتَخْشَى : اور آپ ڈرتے تھے النَّاسَ ۚ : لوگ وَاللّٰهُ : اور اللہ اَحَقُّ : زیادہ حقدار اَنْ : کہ تَخْشٰىهُ ۭ : تم اس سے ڈرو فَلَمَّا : پھر جب قَضٰى : پوری کرلی زَيْدٌ : زید مِّنْهَا : اس سے وَطَرًا : اپنی حاجت زَوَّجْنٰكَهَا : ہم نے اسے تمہارے نکاح میں دیدیا لِكَيْ : تاکہ لَا يَكُوْنَ : نہ رہے عَلَي : پر الْمُؤْمِنِيْنَ : مومنوں حَرَجٌ : کوئی تنگی فِيْٓ اَزْوَاجِ : بیویوں میں اَدْعِيَآئِهِمْ : اپنے لے پالک اِذَا : جب وہ قَضَوْا : پوری کرچکیں مِنْهُنَّ : ان سے وَطَرًا ۭ : اپنی حاجت وَكَانَ : اور ہے اَمْرُ اللّٰهِ : اللہ کا حکم مَفْعُوْلًا : ہوکر رہنے والا یاد کرو) جبکہ تو اس شخص سے کہہ رہا تھا کہ جس پر اللہ نے بھی انعام کیا اور تو نے بھی کہ تو اپنی بیوی کو اپنے پاس رکھ اور اللہ سے ڈر تو نے اپنے دل میں وہ جو چھپائے ہوئے تھا جسے اللہ ظاہر کرنے والا تھا اور تو لوگوں سے خوف کھاتا تھا، حالانکہ اللہ تعالیٰ اس کا زیادہ حق دار تھا کہ تو اسے ڈرے (1) پس جب کہ زید نے اس عورت سے اپنی غرض پوری کرلی (2) ہم نے اسے تیرے نکاح میں دے دیا (3) تاکہ مسلمانوں پر اپنے لے پالک بیویوں کے بارے میں کسی طرح تنگی نہ رہے جب کہ وہ اپنی غرض ان سے پوری کرلیں (4) اللہ کا (یہ) حکم تو ہو کر ہی رہنے والا ہے (5)
  33,38,مَا كَانَ عَلَى النَّبِیِّ مِنْ حَرَجٍ فِیْمَا فَرَضَ اللّٰهُ لَهٗ١ؕ سُنَّةَ اللّٰهِ فِی الَّذِیْنَ خَلَوْا مِنْ قَبْلُ١ؕ وَ كَانَ اَمْرُ اللّٰهِ قَدَرًا مَّقْدُوْرَا٘ۙ مَا كَانَ : نہیں ہے عَلَي النَّبِيِّ : نبی پر مِنْ حَرَجٍ : کوئی حرج فِيْمَا : اس میں جو فَرَضَ اللّٰهُ : مقرر کیا اللہ نے لَهٗ ۭ : اس کے لیے سُنَّةَ اللّٰهِ : اللہ کا دستور فِي : میں الَّذِيْنَ : وہ جو خَلَوْا : گزرے مِنْ قَبْلُ ۭ : پہلے وَكَانَ : اور ہے اَمْرُ اللّٰهِ : اللہ کا حکم قَدَرًا : مقرر کیا ہوا مَّقْدُوْرَۨا : اندازہ سے جو چیزیں اللہ تعالیٰ نے اپنے نبی کے لئے مقرر کی ہیں ان میں نبی پر کوئی حرج نہیں (1) (یہی) اللہ کا دستور ان میں بھی رہے جو پہلے ہوئے (2) اور اللہ تعالیٰ کے کام اندازے پر مقرر کئے ہوئے ہیں۔
  33,39,اِ۟لَّذِیْنَ یُبَلِّغُوْنَ رِسٰلٰتِ اللّٰهِ وَ یَخْشَوْنَهٗ وَ لَا یَخْشَوْنَ اَحَدًا اِلَّا اللّٰهَ١ؕ وَ كَفٰى بِاللّٰهِ حَسِیْبًا الَّذِيْنَ : وہ جو يُبَلِّغُوْنَ : پہنچاتے ہیں رِسٰلٰتِ اللّٰهِ : اللہ کے پیغامات وَيَخْشَوْنَهٗ : اور اس سے ڈرتے ہیں وَلَا يَخْشَوْنَ : اور وہ نہیں ڈرتے اَحَدًا : کسی سے اِلَّا اللّٰهَ : اللہ کے سوا وَكَفٰى : اور کافی ہے بِاللّٰهِ : اللہ حَسِيْبًا : حساب لینے والا یہ سب ایسے تھے کے اللہ تعالیٰ کے احکام پہنچایا کرتے تھے اور اللہ ہی سے ڈرتے تھے اور اللہ کے سوا کسی سے نہ ڈرتے تھے (1) اللہ تعالیٰ حساب لینے کے لئے کافی ہے۔ (2)
  33,40,مَا كَانَ مُحَمَّدٌ اَبَاۤ اَحَدٍ مِّنْ رِّجَالِكُمْ وَ لٰكِنْ رَّسُوْلَ اللّٰهِ وَ خَاتَمَ النَّبِیّٖنَ١ؕ وَ كَانَ اللّٰهُ بِكُلِّ شَیْءٍ عَلِیْمًا۠    ۧ مَا كَانَ : نہیں ہیں مُحَمَّدٌ : محمد اَبَآ : باپ اَحَدٍ : کسی کے مِّنْ رِّجَالِكُمْ : تمہارے مردوں میں سے وَلٰكِنْ : اور لیکن رَّسُوْلَ اللّٰهِ : اللہ کے رسول وَخَاتَمَ : اور مہر النَّبِيّٖنَ ۭ : نبیوں وَكَانَ : اور ہے اللّٰهُ : اللہ بِكُلِّ شَيْءٍ : ہر شے کا عَلِيْمًا : جاننے والا (لوگو) تمہارے مردوں میں کسی کے باپ محمد ﷺ نہیں (1) لیکن اللہ تعالیٰ کے رسول ہیں اور تمام نبیوں کے ختم کرنے والے ہیں (2) اور اللہ تعالیٰ ہر چیز کو (خوب) جانتا ہے ـ
  33,41,یٰۤاَیُّهَا الَّذِیْنَ اٰمَنُوا اذْكُرُوا اللّٰهَ ذِكْرًا كَثِیْرًاۙ يٰٓاَيُّهَا : اے الَّذِيْنَ اٰمَنُوا : ایمان والو اذْكُرُوا : یاد کرو تم اللّٰهَ : اللہ ذِكْرًا : یاد كَثِيْرًا : بکثرت مسلمانوں اللہ تعالیٰ کا ذکر بہت کیا کرو۔
  33,42,وَّ سَبِّحُوْهُ بُكْرَةً وَّ اَصِیْلًا وَّسَبِّحُوْهُ : اور پاکیزگی بیان کرو اس کی بُكْرَةً : صبح وَّاَصِيْلًا : اور شام اور صبح شام اس کی پاکیزگی بیان کرو۔
  33,43,هُوَ الَّذِیْ یُصَلِّیْ عَلَیْكُمْ وَ مَلٰٓئِكَتُهٗ لِیُخْرِجَكُمْ مِّنَ الظُّلُمٰتِ اِلَى النُّوْرِ١ؕ وَ كَانَ بِالْمُؤْمِنِیْنَ رَحِیْمًا هُوَ الَّذِيْ : وہی جو يُصَلِّيْ :  رحمت بھیجتا ہے عَلَيْكُمْ : تم پر وَمَلٰٓئِكَتُهٗ : اور اس کے فرشتے لِيُخْرِجَكُمْ : تاکہ وہ تمہیں نکالے مِّنَ : سے الظُّلُمٰتِ : اندھیروں اِلَى النُّوْرِ ۭ : نور کی طرف وَكَانَ : اور ہے بِالْمُؤْمِنِيْنَ : مومنوں پر رَحِيْمًا : مہربان وہی ہے جو تم پر رحمتیں بھیجتا ہے اور اس کے فرشتے (تمہارے لئے دعائے رحمت کرتے ہیں) تاکہ وہ تمہیں اندھیروں سے اجالے کی طرف لے جائے اور اللہ تعالیٰ مومنوں پر بہت ہی مہربان ہے
