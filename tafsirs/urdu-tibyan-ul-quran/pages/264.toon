tafsir[20]{c,v,t}:
  15,32,قَالَ یٰۤاِبْلِیْسُ مَا لَكَ اَلَّا تَكُوْنَ مَعَ السّٰجِدِیْنَ قَالَ : اس نے فرمایا يٰٓاِبْلِيْسُ : اے ابلیس مَا لَكَ : تجھے کیا ہوا اَلَّا تَكُوْنَ : کہ تو نہ ہوا مَعَ : ساتھ السّٰجِدِيْنَ : سجدہ کرنے والے (اللہ تعالیٰ نے) فرمایا اے ابلیس تجھے کیا ہوا کہ تو سجدہ کرنے والوں میں شامل نہ ہوا ؟
  15,33,قَالَ لَمْ اَكُنْ لِّاَسْجُدَ لِبَشَرٍ خَلَقْتَهٗ مِنْ صَلْصَالٍ مِّنْ حَمَاٍ مَّسْنُوْنٍ قَالَ : اس نے کہا لَمْ اَكُنْ : میں نہیں ہوں لِّاَسْجُدَ : کہ سجدہ کروں لِبَشَرٍ : انسان کو خَلَقْتَهٗ : تو نے اس کو پیدا کیا مِنْ : سے صَلْصَالٍ : کھکھناتا ہوا مِّنْ : سے حَمَاٍ : سیاہ گارا مَّسْنُوْنٍ : سڑا ہوا وہ بولا کہ میں ایسا نہیں کہ اس انسان کو سجدہ کروں جسے تو نے کالی اور سڑی ہوئی کھنکھناتی مٹی سے پیدا کیا ہے (1)۔
  15,34,قَالَ فَاخْرُجْ مِنْهَا فَاِنَّكَ رَجِیْمٌۙ قَالَ : اس نے کہا فَاخْرُجْ : پس نکل جا مِنْهَا : یہاں سے فَاِنَّكَ : بیشک تو رَجِيْمٌ : مردود فرمایا اب تو بہشت سے نکل جا کیونکہ تو راندہ درگاہ ہے۔
  15,35,وَّ اِنَّ عَلَیْكَ اللَّعْنَةَ اِلٰى یَوْمِ الدِّیْنِ وَّاِنَّ : اور بیشک عَلَيْكَ : تجھ پر اللَّعْنَةَ : لعنت اِلٰى : تک يَوْمِ الدِّيْنِ : روز انصاف تجھ پر میری پھٹکار ہے قیامت کے دن تک۔
  15,36,قَالَ رَبِّ فَاَنْظِرْنِیْۤ اِلٰى یَوْمِ یُبْعَثُوْنَ قَالَ : اس نے کہا رَبِّ : اے میرے رب فَاَنْظِرْنِيْٓ : تو مجھے مہلت دے اِلٰى : تک يَوْمِ يُبْعَثُوْنَ : جس دن (مردے) اٹھائے جائیں کہنے لگا میرے رب ! مجھے اس دن تک کی ڈھیل دے کہ لوگ دوبارہ اٹھ کھڑے کیئے جائیں۔
  15,37,قَالَ فَاِنَّكَ مِنَ الْمُنْظَرِیْنَۙ قَالَ : اس نے کہا فَاِنَّكَ : بیشک تو مِنَ : سے الْمُنْظَرِيْنَ : مہلت دئیے جانے والے فرمایا کہ اچھا تو ان میں سے ہے جنہیں مہلت ملی ہے۔
  15,38,اِلٰى یَوْمِ الْوَقْتِ الْمَعْلُوْمِ اِلٰى : تک يَوْمِ : دن الْوَقْتِ : وقت الْمَعْلُوْمِ : معلوم (مقرر) روز مقرر کے وقت تک۔
  15,39,قَالَ رَبِّ بِمَاۤ اَغْوَیْتَنِیْ لَاُزَیِّنَنَّ لَهُمْ فِی الْاَرْضِ وَ لَاُغْوِیَنَّهُمْ اَجْمَعِیْنَۙ قَالَ : اس نے کہا رَبِّ : اے میرے رب بِمَآ : جیسا کہ اَغْوَيْتَنِيْ : تونے مجھے گمراہ کیا لَاُزَيِّنَنَّ : تو میں ضرور آراستہ کروں گا لَهُمْ : ان کے لیے فِي الْاَرْضِ : زمین میں وَلَاُغْوِيَنَّهُمْ : اور میں ضرور گمراہ کروں گا ان کو اَجْمَعِيْنَ : سب (شیطان نے) کہا اے میرے رب ! چونکہ تو نے مجھے گمراہ کیا ہے مجھے بھی قسم ہے کہ میں بھی زمین میں ان کے لئے معاصی کو مزین کروں گا اور ان سب کو بہکاؤں گا بھی۔
  15,40,اِلَّا عِبَادَكَ مِنْهُمُ الْمُخْلَصِیْنَ اِلَّا : سوائے عِبَادَكَ : تیرے بندے مِنْهُمُ : ان میں سے الْمُخْلَصِيْنَ : مخلص (جمع) سوائے تیرے ان بندوں کے جو منتخب کرلئے گئے ہیں۔
  15,41,قَالَ هٰذَا صِرَاطٌ عَلَیَّ مُسْتَقِیْمٌ قَالَ : اس نے کہا ھٰذَا : یہ صِرَاطٌ : راستہ عَلَيَّ : مجھ تک مُسْتَقِيْمٌ : سیدھا ارشاد ہوا کہ ہاں یہی مجھ تک پہنچنے کی سیدھی راہ ہے (1)
  15,42,اِنَّ عِبَادِیْ لَیْسَ لَكَ عَلَیْهِمْ سُلْطٰنٌ اِلَّا مَنِ اتَّبَعَكَ مِنَ الْغٰوِیْنَ اِنَّ : بیشک عِبَادِيْ : میرے بندے لَيْسَ : نہیں لَكَ : تیرے لیے (تیرا) عَلَيْهِمْ : ان پر سُلْطٰنٌ : کوئی زور اِلَّا : مگر مَنِ : جو۔ جس اتَّبَعَكَ : تیری پیروی کی مِنَ : سے الْغٰوِيْنَ : بہکے ہوئے (گمراہ) میرے بندوں پر تجھے کوئی غلبہ نہیں (1) لیکن ہاں جو گمراہ لوگ تیری پیروی کریں۔
  15,43,وَ اِنَّ جَهَنَّمَ لَمَوْعِدُهُمْ اَجْمَعِیْنَ۫ۙ وَاِنَّ : اور بیشک جَهَنَّمَ : جہنم لَمَوْعِدُهُمْ : ان کے لیے وعدہ گاہ اَجْمَعِيْنَ : سب یقیناً سب کے وعدے کی جگہ جہنم ہے (1)
  15,44,لَهَا سَبْعَةُ اَبْوَابٍ١ؕ لِكُلِّ بَابٍ مِّنْهُمْ جُزْءٌ مَّقْسُوْمٌ۠    ۧ لَهَا : اس کے لیے سَبْعَةُ : سات اَبْوَابٍ : دروازے لِكُلِّ بَابٍ : ہر دروازہ کے لیے مِّنْهُمْ : ان سے جُزْءٌ : ایک حصہ مَّقْسُوْمٌ : تقسیم شدہ جس کے سات دروازے ہیں۔ ہر دروازے کے لئے ان کا ایک حصہ بنا ہوا ہے (1)
  15,45,اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ عُیُوْنٍؕ اِنَّ : بیشک الْمُتَّقِيْنَ : پرہیزگار فِيْ : میں جَنّٰتٍ : باغات وَّعُيُوْنٍ : اور چشمے پرہیزگار جنتی لوگ باغوں اور چشموں میں ہونگے (1)
  15,46,اُدْخُلُوْهَا بِسَلٰمٍ اٰمِنِیْنَ اُدْخُلُوْهَا : تم ان میں داخل ہوجاؤ بِسَلٰمٍ : سلامتی کے ساتھ اٰمِنِيْنَ : بےخوف وخطر (ان سے کہا جائیگا) سلامتی اور امن کے ساتھ اس میں داخل ہوجاؤ۔
  15,47,وَ نَزَعْنَا مَا فِیْ صُدُوْرِهِمْ مِّنْ غِلٍّ اِخْوَانًا عَلٰى سُرُرٍ مُّتَقٰبِلِیْنَ وَنَزَعْنَا : اور ہم نے کھینچ لیا مَا : جو فِيْ : میں صُدُوْرِهِمْ : ان کے سینے مِّنْ : سے غِلٍّ : کینہ اِخْوَانًا : بھائی بھائی عَلٰي : پر سُرُرٍ : تخت (جمع) مُّتَقٰبِلِيْنَ : آمنے سامنے ان کے دلوں میں جو کچھ رنجش و کینہ تھا، ہم سب کچھ نکال دیں گے (1) وہ بھائی بھائی بنے ہوئے ایک دوسرے کے آمنے سامنے تختوں پر بیٹھے ہونگے۔
  15,48,لَا یَمَسُّهُمْ فِیْهَا نَصَبٌ وَّ مَا هُمْ مِّنْهَا بِمُخْرَجِیْنَ لَا يَمَسُّهُمْ : انہیں نہ چھوئے گی فِيْهَا : اس میں نَصَبٌ : کوئی تکلیف وَّمَا : اور نہ هُمْ : وہ مِّنْهَا : اس سے بِمُخْرَجِيْنَ : نکالے جائیں گے نہ تو وہاں انھیں کوئی تکلیف چھو سکتی ہے اور نہ وہاں سے کبھی نکالے جائیں گے۔
  15,49,نَبِّئْ عِبَادِیْۤ اَنِّیْۤ اَنَا الْغَفُوْرُ الرَّحِیْمُۙ نَبِّئْ : خبر دیدو عِبَادِيْٓ : میرے بندے اَنِّىْٓ : کہ بیشک اَنَا : میں الْغَفُوْرُ : بخشنے والا الرَّحِيْمُ : نہایت مہربان میرے بندوں کو خبر دے دو کہ میں بہت ہی بخشنے والا اور بڑا مہربان ہوں۔
  15,50,وَ اَنَّ عَذَابِیْ هُوَ الْعَذَابُ الْاَلِیْمُ وَاَنَّ : اور یہ کہ عَذَابِيْ : میرا عذاب هُوَ : وہ (ہی) الْعَذَابُ : عذاب الْاَلِيْمُ : دردناک ساتھ ہی میرے عذاب بھی نہایت دردناک ہیں۔
  15,51,وَ نَبِّئْهُمْ عَنْ ضَیْفِ اِبْرٰهِیْمَۘ وَنَبِّئْهُمْ : اور انہیں خبر دو (سنا دو ) عَنْ : سے۔ کا ضَيْفِ : مہمان اِبْرٰهِيْمَ : ابراہیم انہیں ابراہیم کے مہمانوں کا (بھی) حال سنادو۔
