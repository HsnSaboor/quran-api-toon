tafsir[6]{c,v,t}:
  6,152,وَ لَا تَقْرَبُوْا مَالَ الْیَتِیْمِ اِلَّا بِالَّتِیْ هِیَ اَحْسَنُ حَتّٰى یَبْلُغَ اَشُدَّهٗ١ۚ وَ اَوْفُوا الْكَیْلَ وَ الْمِیْزَانَ بِالْقِسْطِ١ۚ لَا نُكَلِّفُ نَفْسًا اِلَّا وُسْعَهَا١ۚ وَ اِذَا قُلْتُمْ فَاعْدِلُوْا وَ لَوْ كَانَ ذَا قُرْبٰى١ۚ وَ بِعَهْدِ اللّٰهِ اَوْفُوْا١ؕ ذٰلِكُمْ وَصّٰىكُمْ بِهٖ لَعَلَّكُمْ تَذَكَّرُوْنَۙ وَلَا تَقْرَبُوْا : اور قریب نہ جاؤ مَالَ : مال الْيَتِيْمِ : یتیم اِلَّا : مگر بِالَّتِيْ : ایسے جو هِىَ : وہ اَحْسَنُ : بہترین حَتّٰي : یہاں تک کہ يَبْلُغَ : پہنچ جائے اَشُدَّهٗ : اپنی جوانی وَاَوْفُوا : اور پورا کرو الْكَيْلَ : ماپ وَالْمِيْزَانَ : اور تول بِالْقِسْطِ : انصاف کے ساتھ لَا نُكَلِّفُ : ہم تکلیف نہیں دیتے نَفْسًا : کسی کو اِلَّا : مگر وُسْعَهَا : اس کی وسعت (مقدور) وَاِذَا : اور جب قُلْتُمْ : تم بات کرو فَاعْدِلُوْا : تو انصاف کرو وَلَوْ كَانَ : خواہ ہو ذَا قُرْبٰي : رشتہ دار وَ : اور بِعَهْدِ : عہد اللّٰهِ : اللہ اَوْفُوْا : پورا کرو ذٰلِكُمْ : یہ وَصّٰىكُمْ : اس نے تمہیں حکم دیا بِهٖ : اس کا لَعَلَّكُمْ : تا کہ تم تَذَكَّرُوْنَ : نصیحت پکڑو اور یتیم کے مال کے پاس نہ جاؤ مگر ایسے طریقے سے جو کہ مستحسن ہے یہاں تک کہ وہ اپنے سن رشد تک پہنچ جائے (1) اور ناپ تول پوری پوری کرو، انصاف کے ساتھ (2) ہم کسی شخص کو اس کی طاقت سے زیادہ تکلیف نہیں دیتے (3) اور جب تم بات کرو تو انصاف کرو گو وہ شخص قرابت دار ہی ہو اور اللہ تعالیٰ سے جو عہد کیا اس کو پورا کرو ان کا اللہ تعالیٰ نے حکم دیا ہے تاکہ تم یاد رکھو۔
  6,153,وَ اَنَّ هٰذَا صِرَاطِیْ مُسْتَقِیْمًا فَاتَّبِعُوْهُ١ۚ وَ لَا تَتَّبِعُوا السُّبُلَ فَتَفَرَّقَ بِكُمْ عَنْ سَبِیْلِهٖ١ؕ ذٰلِكُمْ وَصّٰىكُمْ بِهٖ لَعَلَّكُمْ تَتَّقُوْنَ وَاَنَّ : اور یہ کہ ھٰذَا : یہ صِرَاطِيْ : یہ راستہ مُسْتَقِيْمًا : سیدھا فَاتَّبِعُوْهُ : پس اس پر چلو وَلَا تَتَّبِعُوا : اور نہ چلو السُّبُلَ : راستے فَتَفَرَّقَ : پس جدا کردیں بِكُمْ : تمہیں عَنْ : سے سَبِيْلِهٖ : اس کا راستہ ذٰلِكُمْ : یہ وَصّٰىكُمْ بِهٖ : حکم دیا اس کا لَعَلَّكُمْ : تاکہ تم تَتَّقُوْنَ : پرہیزگاری اختیار کرو اور یہ کہ دین (1) میرا راستہ ہے جو مستقیم ہے سو اس راہ پر چلو (2) دوسری راہوں پر مت چلو کہ وہ راہیں تم کو اللہ کی راہ سے جدا کردیں گی۔ اس کا تم کو اللہ تعالیٰ نے تاکیدی حکم دیا ہے تاکہ تم پرہیزگاری اختیار کرو۔
  6,154,ثُمَّ اٰتَیْنَا مُوْسَى الْكِتٰبَ تَمَامًا عَلَى الَّذِیْۤ اَحْسَنَ وَ تَفْصِیْلًا لِّكُلِّ شَیْءٍ وَّ هُدًى وَّ رَحْمَةً لَّعَلَّهُمْ بِلِقَآءِ رَبِّهِمْ یُؤْمِنُوْنَ۠    ۧ ثُمَّ اٰتَيْنَا : پھر ہم نے دی مُوْسَى : موسیٰ الْكِتٰبَ : کتاب تَمَامًا : نعمت پوری کرنے کو عَلَي : پر الَّذِيْٓ : جو اَحْسَنَ : نیکو کار ہے وَتَفْصِيْلًا : اور تفصیل لِّكُلِّ شَيْءٍ : ہر چیز کی وَّهُدًى : اور ہدایت وَّرَحْمَةً : اور رحمت لَّعَلَّهُمْ : تاکہ وہ بِلِقَآءِ : ملاقات پر رَبِّهِمْ : اپنا رب يُؤْمِنُوْنَ : ایمان لائیں پھر ہم نے موسیٰ ؑ کو کتاب دی تھی جس سے اچھی طرح عمل کرنے والوں پر نعمت پوری ہو اور رحمت ہو (1) تاکہ وہ لوگ اپنے رب کو ملنے پر یقین لائیں۔
  6,155,وَ هٰذَا كِتٰبٌ اَنْزَلْنٰهُ مُبٰرَكٌ فَاتَّبِعُوْهُ وَ اتَّقُوْا لَعَلَّكُمْ تُرْحَمُوْنَۙ وَھٰذَا : اور یہ كِتٰب : کتاب اَنْزَلْنٰهُ : ہم نے نازل کی مُبٰرَكٌ : برکت والی فَاتَّبِعُوْهُ : پس اس کی پیروی کرو وَاتَّقُوْا : اور پرہیزگاری اختیار کرو لَعَلَّكُمْ : تاکہ تم پر تُرْحَمُوْنَ : رحم کیا جائے تم پر اور یہ ایک کتاب ہے جس کو ہم نے بھیجا بڑی خیرو برکت والی (2) سو اس کا اتباع کرو اور ڈرو تاکہ تم پر رحمت ہو۔
  6,156,اَنْ تَقُوْلُوْۤا اِنَّمَاۤ اُنْزِلَ الْكِتٰبُ عَلٰى طَآئِفَتَیْنِ مِنْ قَبْلِنَا١۪ وَ اِنْ كُنَّا عَنْ دِرَاسَتِهِمْ لَغٰفِلِیْنَۙ اَنْ : کہ تَقُوْلُوْٓا : تم کہو اِنَّمَآ : اس کے سوا نہیں اُنْزِلَ : اتاری گئی تھی الْكِتٰبُ : کتاب عَلٰي : پر طَآئِفَتَيْنِ : دو گروہ مِنْ قَبْلِنَا : ہم سے پہلے وَاِنْ : اور یہ کہ كُنَّا : ہم تھے عَنْ : سے دِرَاسَتِهِمْ : ان کے پڑھنے پڑھانے لَغٰفِلِيْنَ : بیخبر کہیں تم لوگ یوں نہ کہو (1) کہ کتاب تو صرف ہم سے پہلے جو دو فرقے تھے ان پر نازل ہوئی تھی اور ہم ان کے پڑھنے پڑھانے سے محض بیخبر تھے (2)
  6,157,اَوْ تَقُوْلُوْا لَوْ اَنَّاۤ اُنْزِلَ عَلَیْنَا الْكِتٰبُ لَكُنَّاۤ اَهْدٰى مِنْهُمْ١ۚ فَقَدْ جَآءَكُمْ بَیِّنَةٌ مِّنْ رَّبِّكُمْ وَ هُدًى وَّ رَحْمَةٌ١ۚ فَمَنْ اَظْلَمُ مِمَّنْ كَذَّبَ بِاٰیٰتِ اللّٰهِ وَ صَدَفَ عَنْهَا١ؕ سَنَجْزِی الَّذِیْنَ یَصْدِفُوْنَ عَنْ اٰیٰتِنَا سُوْٓءَ الْعَذَابِ بِمَا كَانُوْا یَصْدِفُوْنَ اَوْ تَقُوْلُوْا : یا تم کہو لَوْ اَنَّآ : اگر ہم اُنْزِلَ : اتاری جاتی عَلَيْنَا : ہم پر الْكِتٰبُ : کتاب لَكُنَّآ : البتہ ہم ہوتے اَهْدٰي : زیادہ ہدایت پر مِنْهُمْ : ان سے فَقَدْ جَآءَكُمْ : پس آگئی تمہارے پاس بَيِّنَةٌ : روشن دلیل مِّنْ : سے رَّبِّكُمْ : تمہارا رب وَهُدًى : اور ہدایت وَّرَحْمَةٌ : اور رحمت فَمَنْ : پس کون اَظْلَمُ : بڑا ظالم مِمَّنْ : اس سے جو كَذَّبَ : جھٹلا دے بِاٰيٰتِ : آیتوں کو اللّٰهِ : اللہ وَصَدَفَ : اور کترائے عَنْهَا : اس سے سَنَجْزِي : ہم جلد سزا دیں گے الَّذِيْنَ : ان لوگوں کو جو يَصْدِفُوْنَ : کتراتے ہیں وہ عَنْ : سے اٰيٰتِنَا : ہماری آیتیں سُوْٓءَ : برا الْعَذَابِ : عذاب بِمَا : اس کے بدلے كَانُوْا يَصْدِفُوْنَ : وہ کتراتے تھے یا یوں نہ کہو کہ اگر ہم پر کوئی کتاب نازل ہوتی تو ہم اب سے بھی زیادہ راہ راست پر ہوتے۔ سو اب تمہارے پاس رب کے پاس سے ایک کتاب واضح اور رہنمائی کا ذریعہ اور رحمت آچکی ہے (1) ان میں اس شخص سے زیادہ ظالم کون ہوگا جو ہماری ان آیتوں کو جھوٹا بتائے اور اس سے روکے (2) ہم جلدی ہی ان لوگوں کو جو ہماری آیتوں سے روکتے ہیں ان کے اس روکنے کے سبب سخت سزا دیں گے۔
