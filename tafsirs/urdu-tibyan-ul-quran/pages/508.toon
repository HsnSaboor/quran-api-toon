tafsir[8]{c,v,t}:
  47,12,اِنَّ اللّٰهَ یُدْخِلُ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ جَنّٰتٍ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ١ؕ وَ الَّذِیْنَ كَفَرُوْا یَتَمَتَّعُوْنَ وَ یَاْكُلُوْنَ كَمَا تَاْكُلُ الْاَنْعَامُ وَ النَّارُ مَثْوًى لَّهُمْ اِنَّ اللّٰهَ : بیشک اللہ يُدْخِلُ : داخل کرتا ہے الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کئے الصّٰلِحٰتِ : نیک جَنّٰتٍ : باغات تَجْرِيْ : بہتی ہیں مِنْ تَحْتِهَا : ان کے نیچے الْاَنْهٰرُ ۭ : نہریں وَالَّذِيْنَ : اور جن لوگوں نے كَفَرُوْا : کفر کیا يَتَمَتَّعُوْنَ : وہ فائدہ اٹھاتے ہیں وَيَاْكُلُوْنَ : اور وہ کھاتے ہیں كَمَا : جیسے تَاْكُلُ : کھاتے ہیں الْاَنْعَامُ : چوپائے وَالنَّارُ : اور آگ مَثْوًى : ٹھکانا لَّهُمْ : ان کیلئے جو لوگ ایمان لائے اور انہوں نے نیک اعمال کئے انہیں اللہ تعالیٰ یقیناً ایسے باغوں میں داخل کرے گا جن کے نیچے نہریں جاری ہیں اور جو لوگ کافر ہوئے وہ (دنیا ہی کا) فائدہ اٹھا رہے ہیں اور مثل چوپایوں کے کھا رہے ہیں (1) ان کا اصل ٹھکانا جہنم ہے۔
  47,13,وَ كَاَیِّنْ مِّنْ قَرْیَةٍ هِیَ اَشَدُّ قُوَّةً مِّنْ قَرْیَتِكَ الَّتِیْۤ اَخْرَجَتْكَ١ۚ اَهْلَكْنٰهُمْ فَلَا نَاصِرَ لَهُمْ وَكَاَيِّنْ : اور بہت سی مِّنْ قَرْيَةٍ : بستیاں هِىَ اَشَدُّ : وہ بہت ہی سخت قُوَّةً : قوت میں مِّنْ قَرْيَتِكَ : آپ کی بستی سے الَّتِيْٓ : وہ جس اَخْرَجَتْكَ ۚ : آپ کو نکال دیا اَهْلَكْنٰهُمْ : ہم نے ہلاک کردیا انہیں فَلَا : تو نہ نَاصِرَ : کوئی مدد کرنے والا لَهُمْ : ان کے لئے ہم نے کتنی بستیوں کو جو طاقت میں تیری اس بستی سے زیادہ تھیں جس سے تجھے نکالا گیا ہم نے انہیں ہلاک کردیا جن کا مددگار کوئی نہ اٹھا۔
  47,14,اَفَمَنْ كَانَ عَلٰى بَیِّنَةٍ مِّنْ رَّبِّهٖ كَمَنْ زُیِّنَ لَهٗ سُوْٓءُ عَمَلِهٖ وَ اتَّبَعُوْۤا اَهْوَآءَهُمْ اَفَمَنْ : پس کیا جو كَانَ : ہے عَلٰي بَيِّنَةٍ : روشن (راستہ) پر مِّنْ رَّبِّهٖ : اپنے رب سے، کے كَمَنْ : اس کی طرح زُيِّنَ : آراستہ دکھائے گئے لَهٗ : اس کو سُوْٓءُ : بُرے عَمَلِهٖ : اس کے عمل وَاتَّبَعُوْٓا : اور انہوں نے پیروی کی اَهْوَآءَهُمْ : اپنی خواہشات کیا ' پس وہ شخص جو اپنے پروردگار کی طرف سے دلیل پر ہو اس شخص جیسا ہوسکتا ہے ؟ جس کے لئے اس کا برا کام مزین کردیا گیا ہو اور وہ اپنی نفسانی خواہشوں کا پیرو ہو (1)
  47,15,مَثَلُ الْجَنَّةِ الَّتِیْ وُعِدَ الْمُتَّقُوْنَ١ؕ فِیْهَاۤ اَنْهٰرٌ مِّنْ مَّآءٍ غَیْرِ اٰسِنٍ١ۚ وَ اَنْهٰرٌ مِّنْ لَّبَنٍ لَّمْ یَتَغَیَّرْ طَعْمُهٗ١ۚ وَ اَنْهٰرٌ مِّنْ خَمْرٍ لَّذَّةٍ لِّلشّٰرِبِیْنَ١ۚ۬ وَ اَنْهٰرٌ مِّنْ عَسَلٍ مُّصَفًّى١ؕ وَ لَهُمْ فِیْهَا مِنْ كُلِّ الثَّمَرٰتِ وَ مَغْفِرَةٌ مِّنْ رَّبِّهِمْ١ؕ كَمَنْ هُوَ خَالِدٌ فِی النَّارِ وَ سُقُوْا مَآءً حَمِیْمًا فَقَطَّعَ اَمْعَآءَهُمْ مَثَلُ : مثال (کیفیت) الْجَنَّةِ : جنت الَّتِيْ : وہ جو وُعِدَ : وعدہ کی گئی الْمُتَّقُوْنَ ۭ : پرہیزگاروں فِيْهَآ : اس میں اَنْهٰرٌ : نہریں مِّنْ مَّآءٍ : پانی کی غَيْرِ اٰسِنٍ ۚ : بدبو نہ کرنے والے وَاَنْهٰرٌ : اور نہریں مِّنْ لَّبَنٍ : دودھ کی لَّمْ يَتَغَيَّرْ : نہ متغیر ہونے والا طَعْمُهٗ ۚ : اس کا ذائقہ وَاَنْهٰرٌ : اور نہریں مِّنْ خَمْرٍ : شراب کی لَّذَّةٍ : سراسر لذت لِّلشّٰرِبِيْنَ ڬ : پینے والوں کے لئے وَاَنْهٰرٌ : اور نہریں مِّنْ عَسَلٍ : شہد کی مُّصَفًّى ۭ : مصفی وَلَهُمْ : اور انکے لئے فِيْهَا : اس میں مِنْ كُلِّ الثَّمَرٰتِ : ہر قسم کے پھل وَمَغْفِرَةٌ : اور بخشش مِّنْ رَّبِّهِمْ ۭ : ان کے رب سے كَمَنْ هُوَ : اس کی طرح جو وہ خَالِدٌ : ہمیشہ رہنے والا فِي النَّارِ : آگ میں وَسُقُوْا : اور انہیں پلایاجائیگا مَآءً : پانی حَمِيْمًا : گرم فَقَطَّعَ : ٹکڑے ٹکڑے کرڈالے گا اَمْعَآءَهُمْ : ان کی انتڑیاں اس جنت کی صفت جس کا پرہیزگاروں سے وعدہ کیا گیا ہے، یہ ہے کہ اس میں پانی کی نہریں ہیں جو بدبو کرنے والا نہیں (1) اور دودھ کی نہریں ہیں جن کا مزہ نہیں بدلہ (2) اور شراب کی نہریں ہیں جن میں پینے والوں کے لئے بڑی لذت ہے (3) اور نہریں ہیں شہد کی جو بہت صاف ہیں (4) ان کے لئے ہر قسم کے میوے ہیں اور ان کے رب کی طرف سے مغفرت ہے، کیا یہ مثل اس کے ہیں جو ہمیشہ آگ میں رہنے والا ہے ؟ اور جنہیں گرم کھولتا ہوا پانی پلایا جائے گا جو ان کی آنتوں کو ٹکڑے ٹکڑے کر دیگا (5)
  47,16,وَ مِنْهُمْ مَّنْ یَّسْتَمِعُ اِلَیْكَ١ۚ حَتّٰۤى اِذَا خَرَجُوْا مِنْ عِنْدِكَ قَالُوْا لِلَّذِیْنَ اُوْتُوا الْعِلْمَ مَا ذَا قَالَ اٰنِفًا١۫ اُولٰٓئِكَ الَّذِیْنَ طَبَعَ اللّٰهُ عَلٰى قُلُوْبِهِمْ وَ اتَّبَعُوْۤا اَهْوَآءَهُمْ وَمِنْهُمْ : اور ان میں سے مَّنْ يَّسْتَمِعُ : جو سنتا ہے اِلَيْكَ ۚ : آپ کی طرف حَتّىٰٓ : یہاں تک کہ اِذَا خَرَجُوْا : جب وہ نکلتے ہیں مِنْ عِنْدِكَ : آپ کے پاس سے قَالُوْا : وہ کہتے ہیں لِلَّذِيْنَ : ان لوگوں کو جنہیں اُوْتُوا الْعِلْمَ : علم دیا گیا (اہل علم) مَاذَا : کیا قَالَ : اس نے کہا اٰنِفًا ۣ : ابھی اُولٰٓئِكَ : یہی لوگ الَّذِيْنَ : وہ جو طَبَعَ : مہر کردی اللّٰهُ : اللہ نے عَلٰي قُلُوْبِهِمْ : ان کے دلوں پر وَاتَّبَعُوْٓا : اور انہوں نے پیروی کی اَهْوَآءَهُمْ : اپنی خواہشات اور ان میں بعض ایسے بھی ہیں کہ تیری طرف کان لگاتے ہیں، یہاں تک کہ جب تیرے پاس سے جاتے ہیں تو اہل علم سے پوچھتے ہیں کہ اس نے ابھی کیا کہا تھا ؟ (1) یہی لوگ ہیں جن کے دلوں پر اللہ نے مہر کردی اور وہ اپنی خواہشوں کی پیروی کرتے ہیں۔
  47,17,وَ الَّذِیْنَ اهْتَدَوْا زَادَهُمْ هُدًى وَّ اٰتٰىهُمْ تَقْوٰىهُمْ وَالَّذِيْنَ : اور وہ لوگ جنہوں نے اهْتَدَوْا : ہدایت پائی زَادَهُمْ : اور زیادہ دی انہیں هُدًى : ہدایت وَّاٰتٰىهُمْ : اور انہیں عطا کی تَقْوٰىهُمْ : ان کی پرہیزگاری اور جو لوگ ہدایت یافتہ ہیں اللہ نے انہیں ہدایت میں بڑھا دیا ہے اور انہیں ان کی پرہیزگاری عطا فرمائی ہے (1)
  47,18,فَهَلْ یَنْظُرُوْنَ اِلَّا السَّاعَةَ اَنْ تَاْتِیَهُمْ بَغْتَةً١ۚ فَقَدْ جَآءَ اَشْرَاطُهَا١ۚ فَاَنّٰى لَهُمْ اِذَا جَآءَتْهُمْ ذِكْرٰىهُمْ فَهَلْ : پس نہیں وہ يَنْظُرُوْنَ : منتظر اِلَّا السَّاعَةَ : مگر قیامت اَنْ تَاْتِيَهُمْ : کہ آجائے ان پر بَغْتَةً ۚ : اچانک فَقَدْ جَآءَ : سو آچکی ہیں اَشْرَاطُهَا ۚ : اسکی علامات فَاَنّٰى لَهُمْ : تو کہاں ان کیلئے، کو اِذَا : جب جَآءَتْهُمْ : وہ آگئی ان کے پاس ذِكْرٰىهُمْ : ان کا نصیحت (قبول کرنا) تو کیا یہ قیامت کا انتطار کر رہے ہیں کہ ان کے پاس اچانک آجائے یقیناً اس کی علامتیں تو آچکی ہیں (1) پھر جبکہ ان کے پاس قیامت آجائے انہیں نصیحت کرنا کہاں ہوگا (2)
  47,19,فَاعْلَمْ اَنَّهٗ لَاۤ اِلٰهَ اِلَّا اللّٰهُ وَ اسْتَغْفِرْ لِذَنْۢبِكَ وَ لِلْمُؤْمِنِیْنَ وَ الْمُؤْمِنٰتِ١ؕ وَ اللّٰهُ یَعْلَمُ مُتَقَلَّبَكُمْ وَ مَثْوٰىكُمْ۠    ۧ فَاعْلَمْ : سو جان لو اَنَّهٗ : یہ کہ لَآ اِلٰهَ : نہیں کوئی معبود اِلَّا اللّٰهُ : اللہ کے سوا وَاسْتَغْفِرْ : اور بخشش مانگیں آپ لِذَنْۢبِكَ : اپنے ذنب (اپنے اوپر لگائے گئے الزام) کیلئے وَلِلْمُؤْمِنِيْنَ : اور مومن مردوں کیلئے وَالْمُؤْمِنٰتِ ۭ : اور مومن عورتوں وَاللّٰهُ : اور اللہ يَعْلَمُ : جانتا ہے مُتَقَلَّبَكُمْ : تمہارا چلنا پھرنا وَمَثْوٰىكُمْ : اور تمہارے رہنے سہنے کا مقام سو (اے نبی !) آپ یقین کرلیں کہ اللہ کے سوا کوئی معبود نہیں (1) اور اپنے گناہوں کی بخشش مانگا کریں اور مومن مردوں اور مومن عورتوں کے حق میں بھی (2) اللہ تم لوگوں کے آمد ورفت کی اور رہنے سہنے کی جگہ کو خوب جانتا ہے۔ (3)
