quran[135]{c,v,t}:
20,1,طٰهٰۚ طٰهٰ : طہ طٰہٰ
20,2,مَاۤ اَنْزَلْنَا عَلَیْكَ الْقُرْاٰنَ لِتَشْقٰۤىۙ مَآ اَنْزَلْنَا : ہم نے نازل نہیں کیا عَلَيْكَ : تم پر الْقُرْاٰنَ : قرآن لِتَشْقٰٓي : تاکہ تم مشقت میں پڑجاؤ ہم نے یہ قرآن تجھ پر اس لئے نہیں اتارا کہ تو مشقت میں پڑجائے۔ (1)
20,3,اِلَّا تَذْكِرَةً لِّمَنْ یَّخْشٰىۙ اِلَّا : مگر تَذْكِرَةً : یاد دہانی لِّمَنْ : اس کے لیے جو يَّخْشٰى : ڈرتا ہے بلکہ اس کی نصیحت کے لئے جو اللہ سے ڈرتا ہے۔
20,4,تَنْزِیْلًا مِّمَّنْ خَلَقَ الْاَرْضَ وَ السَّمٰوٰتِ الْعُلٰىؕ تَنْزِيْلًا : نازل کیا ہوا مِّمَّنْ : سے۔ جس خَلَقَ : بنایا الْاَرْضَ : زمین وَالسَّمٰوٰتِ : اور آسمان (جمع) الْعُلٰى : اونچے اس کا اتارنا اس کی طرف سے ہے جس نے زمین کو اور بلند آسمان کو پیدا کیا ہے۔
20,5,اَلرَّحْمٰنُ عَلَى الْعَرْشِ اسْتَوٰى اَلرَّحْمَنُ : رحمن عَلَي الْعَرْشِ : عرش پر اسْتَوٰى : قائم جو رحمٰن ہے، عرش پر قائم ہے (1)
20,6,لَهٗ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ وَ مَا بَیْنَهُمَا وَ مَا تَحْتَ الثَّرٰى لَهٗ مَا : اس کے لیے جو فِي السَّمٰوٰتِ : آسمانوں میں وَمَا : اور جو فِي الْاَرْضِ : زمین میں وَمَا : اور جو بَيْنَهُمَا : ان دونوں کے درمیان وَمَا : اور جو تَحْتَ : نیچے الثَّرٰى : گیلی مٹی جس کی ملکیت آسمانوں اور زمین اور ان دونوں کے درمیان اور (کرہ خاک) کے نیچے کی ہر ایک چیز پر ہے (1)۔
20,7,وَ اِنْ تَجْهَرْ بِالْقَوْلِ فَاِنَّهٗ یَعْلَمُ السِّرَّ وَ اَخْفٰى وَاِنْ : اور اگر تَجْهَرْ : تو پکار کر کہے بِالْقَوْلِ : بات فَاِنَّهٗ : تو بیشک وہ يَعْلَمُ : جانتا ہے السِّرَّ : بھید وَاَخْفٰي : اور نہایت پوشیدہ اگر تو اونچی بات کہے تو وہ تو ہر ایک پوشیدہ، بلکہ پوشیدہ سے پوشیدہ تر بات کو بھی بخوبی جانتا ہے
20,8,اَللّٰهُ لَاۤ اِلٰهَ اِلَّا هُوَ١ؕ لَهُ الْاَسْمَآءُ الْحُسْنٰى اَللّٰهُ : اللہ لَآ اِلٰهَ : نہیں کوئی معبود اِلَّا هُوَ : اس کے سوا لَهُ : اسی کے لیے الْاَسْمَآءُ : سب نام الْحُسْنٰى : اچھے وہی اللہ ہے جس کے سوا کوئی معبود نہیں، بہترین نام اسی کے ہیں (1)۔
20,9,وَ هَلْ اَتٰىكَ حَدِیْثُ مُوْسٰىۘ وَهَلْ : اور کیا اَتٰىكَ : تمہارے پاس آئی حَدِيْثُ : بات۔ خبر مُوْسٰى : موسیٰ تجھے موسیٰ ؑ کا قصہ بھی معلوم ہے۔
20,10,اِذْ رَاٰ نَارًا فَقَالَ لِاَهْلِهِ امْكُثُوْۤا اِنِّیْۤ اٰنَسْتُ نَارًا لَّعَلِّیْۤ اٰتِیْكُمْ مِّنْهَا بِقَبَسٍ اَوْ اَجِدُ عَلَى النَّارِ هُدًى اِذْ رَاٰ : جب اس نے دیکھی نَارًا : آگ فَقَالَ : تو کہا لِاَهْلِهِ : اپنے گھروالوں کو امْكُثُوْٓا : تم ٹھہرو اِنِّىْٓ : بیشک میں نے اٰنَسْتُ : دیکھی ہے نَارًا : آگ لَّعَلِّيْٓ : شاید میں اٰتِيْكُمْ : تمہارے پاس لاؤں مِّنْهَا : اس سے بِقَبَسٍ : چنگاری اَوْ : یا اَجِدُ : میں پاؤں عَلَي النَّارِ : آگ پر۔ کے هُدًى : راستہ جبکہ اس نے آگ دیکھ کر اپنے گھر والوں سے کہا کہ تم ذرا سی دیر ٹھہر جاؤ مجھے آگ دکھائی دی ہے۔ بہت ممکن ہے کہ میں اس کا کوئی انگارا تمہارے پاس لاؤں یا آگ کے پاس سے راستے کی اطلاع پاؤں (1)۔
20,11,فَلَمَّاۤ اَتٰىهَا نُوْدِیَ یٰمُوْسٰىؕ فَلَمَّآ : پس جب اَتٰىهَا : وہ وہاں آئے نُوْدِيَ : آواز آئی يٰمُوْسٰى : اے موسیٰ جب وہ وہاں پہنچے تو آواز دی گئی (1) اے موسٰی۔
20,12,اِنِّیْۤ اَنَا رَبُّكَ فَاخْلَعْ نَعْلَیْكَ١ۚ اِنَّكَ بِالْوَادِ الْمُقَدَّسِ طُوًىؕ اِنِّىْٓ : بیشک میں اَنَا : میں رَبُّكَ : تمہارا رب فَاخْلَعْ : سو اتار لو نَعْلَيْكَ : اپنی جوتیاں اِنَّكَ : بیشک تم بِالْوَادِ الْمُقَدَّسِ : میدان پاک طُوًى : طوی یقیناً میں تیرا پروردگار ہوں تو اپنی جوتیاں اتار دے، (1) کیونکہ تو پاک میدان طویٰ میں ہے (2)۔
20,13,وَ اَنَا اخْتَرْتُكَ فَاسْتَمِعْ لِمَا یُوْحٰى وَاَنَا : اور میں اخْتَرْتُكَ : تمہیں پسند کیا فَاسْتَمِعْ : پس کان لگا کر سنو لِمَا يُوْحٰى : اس کی طرف جو وحی کی جائے اور میں نے تجھے منتخب کرلیا ہے (1) اب جو وحی کی جائے اسے کان لگا کر سن۔
20,14,اِنَّنِیْۤ اَنَا اللّٰهُ لَاۤ اِلٰهَ اِلَّاۤ اَنَا فَاعْبُدْنِیْ١ۙ وَ اَقِمِ الصَّلٰوةَ لِذِكْرِیْ اِنَّنِيْٓ : بیشک میں اَنَا : میں اللّٰهُ : اللہ لَآ اِلٰهَ : نہیں کوئی معبود اِلَّآ اَنَا : میرے سوا فَاعْبُدْنِيْ : پس میری عبادت کرو وَاَ قِمِ : اور قائم کرو الصَّلٰوةَ : نماز لِذِكْرِيْ : میری یاد کے لیے بیشک میں ہی اللہ ہوں، میرے سوا عبادت کے لائق اور کوئی نہیں پس تو میری ہی عبادت کر (1) اور میری یاد کے لئے نماز قائم رکھ (2)۔
20,15,اِنَّ السَّاعَةَ اٰتِیَةٌ اَكَادُ اُخْفِیْهَا لِتُجْزٰى كُلُّ نَفْسٍۭ بِمَا تَسْعٰى اِنَّ : بیشک السَّاعَةَ : قیامت اٰتِيَةٌ : آنے والی اَكَادُ : میں چاہتا ہوں اُخْفِيْهَا : میں اسے پوشیدہ رکھوں لِتُجْزٰى : تاکہ بدلہ دیا جائے كُلُّ نَفْسٍ : ہر شخص بِمَا تَسْعٰي : اس کا جو وہ کوشش کرے قیامت یقیناً آنے والی ہے جسے میں پوشیدہ رکھنا چاہتا ہوں تاکہ ہر شخص کو وہ بدلہ دیا جائے جو اس نے کوشش کی ہو۔
20,16,فَلَا یَصُدَّنَّكَ عَنْهَا مَنْ لَّا یُؤْمِنُ بِهَا وَ اتَّبَعَ هَوٰىهُ فَتَرْدٰى فَلَا يَصُدَّنَّكَ : پس تجھے روک نہ دے عَنْهَا : اس سے مَنْ : جو لَّا يُؤْمِنُ : ایمان نہیں رکھتا بِهَا : اس پر وَاتَّبَعَ : اور وہ پیچھے پڑا هَوٰىهُ : اپنی خواہش فَتَرْدٰى : پھر تو ہلاک ہوجائے پس اب اس کے یقین سے تجھے کوئی ایسا شخص روک نہ دے جو اس پر ایمان نہ رکھتا ہو اور اپنی خواہش کے پیچھے پڑا ہو، ورنہ تو ہلاک ہوجائے گا (1)۔
20,17,وَ مَا تِلْكَ بِیَمِیْنِكَ یٰمُوْسٰى وَمَا : اور کیا تِلْكَ : یہ بِيَمِيْنِكَ : تیرے داہنے ہاتھ میں يٰمُوْسٰى : اے موسیٰ اے موسٰی ! تیرے اس دائیں ہاتھ میں کیا ہے ؟
20,18,قَالَ هِیَ عَصَایَ١ۚ اَتَوَكَّؤُا عَلَیْهَا وَ اَهُشُّ بِهَا عَلٰى غَنَمِیْ وَ لِیَ فِیْهَا مَاٰرِبُ اُخْرٰى قَالَ : اس نے کہا هِىَ : یہ عَصَايَ : میرا عصا اَتَوَكَّؤُا : میں ٹیک لگاتا ہوں عَلَيْهَا : اس پر وَاَهُشُّ : اور میں پتے جھاڑتا ہوں بِهَا : اس سے عَلٰي : پر غَنَمِيْ : اپنی بکریاں وَلِيَ : اور میرے لیے فِيْهَا : اس میں مَاٰرِبُ : ضرورتیں (فائدے) اُخْرٰى : اور بھی جواب دیا کہ یہ میری لاٹھی ہے، جس پر میں ٹیک لگاتا ہوں اور جس سے میں اپنی بکریوں کے لئے پتے جھاڑ لیا کرتا ہوں اور بھی اس میں مجھے بہت سے فائدے ہیں۔
20,19,قَالَ اَلْقِهَا یٰمُوْسٰى قَالَ : فرمایا اَلْقِهَا : اسے ڈال دے يٰمُوْسٰى : اے موسیٰ فرمایا اے موسٰی ! اسے ہاتھ سے نیچے ڈال دے۔
20,20,فَاَلْقٰىهَا فَاِذَا هِیَ حَیَّةٌ تَسْعٰى فَاَلْقٰىهَا : پس اس نے اسے ڈالدیا فَاِذَا هِىَ : تو ناگاہ وہ حَيَّةٌ : سانپ تَسْعٰي : دوڑتا ہوا ڈالتے ہی وہ سانپ بن کر دوڑنے لگی۔
20,21,قَالَ خُذْهَا وَ لَا تَخَفْ١ٙ سَنُعِیْدُهَا سِیْرَتَهَا الْاُوْلٰى قَالَ : فرمایا خُذْهَا : اسے پکڑلے وَلَا تَخَفْ : اور نہ ڈر سَنُعِيْدُهَا : ہم جلد اسے لوٹا دیں گے سِيْرَتَهَا : اس کی حالت الْاُوْلٰى : پہلی فرمایا بےخوف ہو کر اسے پکڑ لے، ہم اسے اسی پہلی سی صورت میں دوبارہ لادیں گے (1)
20,22,وَ اضْمُمْ یَدَكَ اِلٰى جَنَاحِكَ تَخْرُجْ بَیْضَآءَ مِنْ غَیْرِ سُوْٓءٍ اٰیَةً اُخْرٰىۙ وَ : اور اضْمُمْ : ملا (لگا) يَدَكَ : اپنا ہاتھ اِلٰى : تک۔ سے جَنَاحِكَ : اپنی بغل تَخْرُجْ : وہ نکلے گا بَيْضَآءَ : سفید مِنْ غَيْرِ سُوْٓءٍ : بغیر کسی عیب اٰيَةً : نشانی اُخْرٰى : دوسری اور اپنا ہاتھ بغل میں ڈال لے تو وہ سفید چمکتا ہوا ہو کر نکلے گا، لیکن بغیر کسی عیب (اور روگ) کے (1) یہ دوسرا معجزہ ہے
20,23,لِنُرِیَكَ مِنْ اٰیٰتِنَا الْكُبْرٰىۚ لِنُرِيَكَ : تاکہ ہم تجھے دکھائیں مِنْ : سے اٰيٰتِنَا : اپنی نشانیاں الْكُبْرٰى : بڑی یہ اس لئے کہ ہم تجھے اپنی بڑی بڑی نشانیاں دکھانا چاہتے ہیں
20,24,اِذْهَبْ اِلٰى فِرْعَوْنَ اِنَّهٗ طَغٰى۠    ۧ اِذْهَبْ : تو جا اِلٰى : طرف فِرْعَوْنَ : فرعون اِنَّهٗ : بیشک وہ طَغٰي : سرکش ہوگیا اب تو فرعون کی طرف جا اس نے بڑی سرکشی مچا رکھی ہے (1)
20,25,قَالَ رَبِّ اشْرَحْ لِیْ صَدْرِیْۙ قَالَ : اس نے کہا رَبِّ : اے میرے رب اشْرَحْ : کشادہ کردے لِيْ : میرے لیے صَدْرِيْ : میرا سینہ موسیٰ ؑ نے کہا اے میرے پروردگار ! میرا سینہ میرے لئے کھول دے۔
20,26,وَ یَسِّرْ لِیْۤ اَمْرِیْۙ وَيَسِّرْ لِيْٓ : اور میرے لیے آسان کردے اَمْرِيْ : میرا کام اور میرے کام کو مجھ پر آسان کر دے
20,27,وَ احْلُلْ عُقْدَةً مِّنْ لِّسَانِیْۙ وَاحْلُلْ : اور کھول دے عُقْدَةً : گرہ مِّنْ : سے۔ کی لِّسَانِيْ : میری زبان اور میری زبان کی گرہ بھی کھول دے۔
20,28,یَفْقَهُوْا قَوْلِیْ۪ يَفْقَهُوْا : وہ سمجھ لیں قَوْلِيْ : میری بات تاکہ لوگ میری بات اچھی طرح سمجھ سکیں۔
20,29,وَ اجْعَلْ لِّیْ وَزِیْرًا مِّنْ اَهْلِیْۙ وَاجْعَلْ : اور بنادے لِّيْ : میرے لیے وَزِيْرًا : وزیر مِّنْ : سے اَهْلِيْ : میرا خاندان اور میرا وزیر میرے کنبے میں سے کر دے۔
20,30,هٰرُوْنَ اَخِیۙ هٰرُوْنَ : ہارون اَخِي : میرا بھائی یعنی میرا بھائی ہارون ؑ کو۔
20,31,اشْدُدْ بِهٖۤ اَزْرِیْۙ اشْدُدْ بِهٖٓ : مضبوط کرو اس سے اَزْرِيْ : میری قوت تو اس سے میری کمر کس دے۔
20,32,وَ اَشْرِكْهُ فِیْۤ اَمْرِیْۙ وَاَشْرِكْهُ : اور شریک کردے اسے فِيْٓ اَمْرِيْ : میرے کام میں اور اسے میرا شریک کار کر دے (1)
20,33,كَیْ نُسَبِّحَكَ كَثِیْرًاۙ كَيْ : تاکہ نُسَبِّحَكَ : ہم تیری تسبیح کریں كَثِيْرًا : کثرت سے تاکہ ہم دونوں بکثرت تیری تسبیح بیان کریں
20,34,وَّ نَذْكُرَكَ كَثِیْرًاؕ وَّنَذْكُرَكَ : اور تجھے یاد کریں كَثِيْرًا : کثرت سے اور بکثرت تیری یاد کریں (1)۔
20,35,اِنَّكَ كُنْتَ بِنَا بَصِیْرًا اِنَّكَ : بیشک تو كُنْتَ : تو ہے بِنَا بَصِيْرًا : ہمیں خوب دیکھتا ہے بیشک تو ہمیں خوب دیکھنے بھالنے والا ہے (1)۔
20,36,قَالَ قَدْ اُوْتِیْتَ سُؤْلَكَ یٰمُوْسٰى قَالَ : اللہ نے فرمایا قَدْ اُوْتِيْتَ : تحقیق تجھے دیدیا گیا سُؤْلَكَ : جو تونے مانگا يٰمُوْسٰى : اے موسیٰ جناب باری تعالیٰ نے فرمایا موسیٰ تیرے تمام سوالات پورے کردیے گئے (1)
20,37,وَ لَقَدْ مَنَنَّا عَلَیْكَ مَرَّةً اُخْرٰۤىۙ وَلَقَدْ مَنَنَّا : اور تحقیق ہم نے احسان کیا عَلَيْكَ : تجھ پر مَرَّةً : ایک بار اُخْرٰٓى : اور بھی ہم نے تو تجھ پر ایک بار اور بھی بڑا احسان کیا ہے (1)
20,38,اِذْ اَوْحَیْنَاۤ اِلٰۤى اُمِّكَ مَا یُوْحٰۤىۙ اِذْ : جب اَوْحَيْنَآ : ہم نے الہام کیا اِلٰٓى : طرف۔ کو اُمِّكَ : تیری والدہ مَا يُوْحٰٓي : جو الہام کرنا تھا جب کہ ہم نے تیری ماں کو وہ الہام کیا جس کا ذکر اب کیا جا رہا ہے۔
20,39,اَنِ اقْذِفِیْهِ فِی التَّابُوْتِ فَاقْذِفِیْهِ فِی الْیَمِّ فَلْیُلْقِهِ الْیَمُّ بِالسَّاحِلِ یَاْخُذْهُ عَدُوٌّ لِّیْ وَ عَدُوٌّ لَّهٗ١ؕ وَ اَلْقَیْتُ عَلَیْكَ مَحَبَّةً مِّنِّیْ١ۚ۬ وَ لِتُصْنَعَ عَلٰى عَیْنِیْۘ اَنِ اقْذِفِيْهِ : کہ تو اسے ڈال فِي التَّابُوْتِ : صندوق فَاقْذِفِيْهِ : پھر اسے ڈالدے فِي الْيَمِّ : دریا میں فَلْيُلْقِهِ : پھر اسے ڈالدے گا الْيَمُّ : دریا بِالسَّاحِلِ : ساحل پر يَاْخُذْهُ : اسے لے لے گا عَدُوٌّ لِّيْ : میرا دشمن وَعَدُوٌّ لَّهٗ : اور اس کا دشمن وَاَلْقَيْتُ : اور میں نے ڈالدی عَلَيْكَ : تجھ پر مَحَبَّةً : محبت مِّنِّيْ : اپنی طرف سے وَلِتُصْنَعَ : اور تاکہ تو پرورش پائے عَلٰي عَيْنِيْ : میری آنکھوں پر (میرے سامنے) کہ تو اسے صندوق میں بند کر کے دریا میں چھوڑ دے، پس دریا اسے کنارے لا ڈالے گا اور میرا اور خود اس کا دشمن اسے لے لے گا (1) اور میں نے اپنی طرف کی خاص محبت و مقبولیت تجھ پر ڈال دی (2) تاکہ تیری پرورش میری آنکھوں کے سامنے (3) کی جائے۔
20,40,اِذْ تَمْشِیْۤ اُخْتُكَ فَتَقُوْلُ هَلْ اَدُلُّكُمْ عَلٰى مَنْ یَّكْفُلُهٗ١ؕ فَرَجَعْنٰكَ اِلٰۤى اُمِّكَ كَیْ تَقَرَّ عَیْنُهَا وَ لَا تَحْزَنَ١ؕ۬ وَ قَتَلْتَ نَفْسًا فَنَجَّیْنٰكَ مِنَ الْغَمِّ وَ فَتَنّٰكَ فُتُوْنًا١۫۬ فَلَبِثْتَ سِنِیْنَ فِیْۤ اَهْلِ مَدْیَنَ١ۙ۬ ثُمَّ جِئْتَ عَلٰى قَدَرٍ یّٰمُوْسٰى اِذْ : جب تَمْشِيْٓ : جارہی تھی اُخْتُكَ : تیری بہن فَتَقُوْلُ : تو وہ کہہ رہی تھی هَلْ اَدُلُّكُمْ : کیا میں تمہیں بتاؤں عَلٰي : پر مَنْ : جو يَّكْفُلُهٗ : اس کی پرورش کرے فَرَجَعْنٰكَ : پس ہم نے تجھے لوٹا دیا اِلٰٓى : طرف اُمِّكَ : تیری ماں كَيْ تَقَرَّ : تاکہ ٹھندی ہو عَيْنُهَا : اس کی آنکھ وَلَا تَحْزَنَ : اور وہ غم نہ کرے وَقَتَلْتَ : اور تونے قتل کردیا نَفْسًا : ایک شخص فَنَجَّيْنٰكَ : تو ہم نے تجھے نجات دی مِنَ الْغَمِّ : غم سے وَفَتَنّٰكَ : اور تجھے آزمایا فُتُوْنًا : کئی آزمائشیں فَلَبِثْتَ : پھر تو ٹھہرا رہا سِنِيْنَ : کئی سال فِيْٓ : میں اَهْلِ مَدْيَنَ : مدین والے ثُمَّ : پھر جِئْتَ : تو آیا عَلٰي قَدَرٍ : وقت مقرر پر يّٰمُوْسٰى : اے موسیٰ (یاد کر) جبکہ تیری بہن چل رہی تھی اور کہہ رہی تھی کہ اگر تم کہو تو میں بتادوں جو اس کی نگہبانی کرے (1) اس تدبیر سے ہم نے تجھے تیری ماں کے پاس پہنچایا کہ اس کی آنکھیں ٹھنڈی رہیں اور وہ غمگین نہ ہو، اور تو نے ایک شخص کو مار ڈالا تھا (2) اس پر بھی ہم نے تمہیں غم سے بچا لیا، غرض ہم نے تجھے اچھی طرح آزما لیا (3)۔ پھر تو کئی سال تک مدین کے لوگوں میں ٹھہرا رہا (4) پھر تقدیر الٰہی کے مطابق اے (5) موسٰی ! تو آیا۔
20,41,وَ اصْطَنَعْتُكَ لِنَفْسِیْۚ وَاصْطَنَعْتُكَ : اور میں تجھے بنایا لِنَفْسِيْ : خاص اپنے لیے اور میں نے تجھے خاص اپنی ذات کے لئے پسند فرمایا لیا۔
20,42,اِذْهَبْ اَنْتَ وَ اَخُوْكَ بِاٰیٰتِیْ وَ لَا تَنِیَا فِیْ ذِكْرِیْۚ اِذْهَبْ : تو جا اَنْتَ : تو وَاَخُوْكَ : اور تیرا بھائی بِاٰيٰتِيْ : میری نشانیوں کے ساتھ وَلَا تَنِيَا : اور سستی نہ کرنا فِيْ ذِكْرِيْ : میری یاد میں اب تو اپنے بھائی سمیت میری نشانیاں ہمراہ لئے ہوئے جا، اور خبردار میرے ذکر میں سستی نہ کرنا (1)
20,43,اِذْهَبَاۤ اِلٰى فِرْعَوْنَ اِنَّهٗ طَغٰىۚۖ اِذْهَبَآ : تم دونوں جاؤ اِلٰى : طرف۔ پاس فِرْعَوْنَ : فرعون اِنَّهٗ : بیشک وہ طَغٰى : سرکش ہوگیا تم دونوں فرعون کے پاس جاؤ اس نے بڑی سرکشی کی ہے
20,44,فَقُوْلَا لَهٗ قَوْلًا لَّیِّنًا لَّعَلَّهٗ یَتَذَكَّرُ اَوْ یَخْشٰى فَقُوْلَا : تم کہو لَهٗ : اس کو قَوْلًا لَّيِّنًا : نرم بات لَّعَلَّهٗ : شاید وہ يَتَذَكَّرُ : نصیحت پکڑ لے اَوْ : یا يَخْشٰى : وہ ڈر جائے اسے نرمی (1) سے سمجھاؤ کہ شاید وہ سمجھ لے یا ڈر جائے۔
20,45,قَالَا رَبَّنَاۤ اِنَّنَا نَخَافُ اَنْ یَّفْرُطَ عَلَیْنَاۤ اَوْ اَنْ یَّطْغٰى قَالَا : دونوں بولے رَبَّنَآ : اے ہمارے رب اِنَّنَا نَخَافُ : بیشک ہم ڈرتے ہیں اَنْ يَّفْرُطَ : کہ وہ زیادتی کرے عَلَيْنَآ : ہم پر اَوْ : یا اَنْ يَّطْغٰي : وہ حد سے بڑھے دونوں نے کہا اے ہمارے رب ! ہمیں خوف ہے کہ کہیں فرعون ہم پر کوئی زیادتی نہ کرے یا اپنی سرکشی میں بڑھ نہ جائے۔
20,46,قَالَ لَا تَخَافَاۤ اِنَّنِیْ مَعَكُمَاۤ اَسْمَعُ وَ اَرٰى قَالَ : اس نے فرمایا لَا تَخَافَآ : تم ڈرو نہیں اِنَّنِيْ : بیشک میں مَعَكُمَآ : تمہارے ساتھ ہوں اَسْمَعُ : میں سنتا ہوں وَاَرٰى : اور میں دیکھتا ہوں جواب ملا کہ تم مطلقاً خوف نہ کرو میں تمہارے ساتھ ہوں اور سنتا اور دیکھتا رہوں گا (1)
20,47,فَاْتِیٰهُ فَقُوْلَاۤ اِنَّا رَسُوْلَا رَبِّكَ فَاَرْسِلْ مَعَنَا بَنِیْۤ اِسْرَآءِیْلَ١ۙ۬ وَ لَا تُعَذِّبْهُمْ١ؕ قَدْ جِئْنٰكَ بِاٰیَةٍ مِّنْ رَّبِّكَ١ؕ وَ السَّلٰمُ عَلٰى مَنِ اتَّبَعَ الْهُدٰى فَاْتِيٰهُ : پس جاؤ اس کے پاس فَقُوْلَآ : اور تم کہو اِنَّا رَسُوْلَا : بیشک ہم دونوں بھیجے ہوئے رَبِّكَ : تیرا رب فَاَرْسِلْ : پس بھیجدے مَعَنَا : ہمارے ساتھ بَنِيْٓ اِسْرَآءِ يْلَ : بنی اسرائیل وَلَا تُعَذِّبْهُمْ : اور انہیں سزا نہ دے قَدْ جِئْنٰكَ : ہم تیرے پاس آئے ہیں بِاٰيَةٍ : نشانی کے ساتھ مِّنْ : سے رَّبِّكَ : تیرا رب وَالسَّلٰمُ : اور سلام عَلٰي : پر مَنِ : جو۔ جس اتَّبَعَ : اس نے پیروی کی الْهُدٰى : ہدایت تم اس کے پاس جا کر کہو کہ ہم تیرے پروردگار کے پیغمبر ہیں تو ہمارے ساتھ بنی اسرائیل کو بھیج دے، ان کی سزائیں موقوف کر۔ ہم تو تیرے پاس تیرے رب کی طرف سے نشانی لے کر آئے ہیں اور سلامتی اس کے لئے ہے جو ہدایت کا پابند (1) ہوجائے۔
20,48,اِنَّا قَدْ اُوْحِیَ اِلَیْنَاۤ اَنَّ الْعَذَابَ عَلٰى مَنْ كَذَّبَ وَ تَوَلّٰى اِنَّا : بیشک قَدْ اُوْحِيَ : وحی کی گئی اِلَيْنَآ : ہماری طرف اَنَّ : کہ الْعَذَابَ : عذاب عَلٰي : پر مَنْ كَذَّبَ : جس نے جھٹلایا وَتَوَلّٰى : اور منہ پھیرا ہمارے طرف وحی کی گئی ہے کہ جو جھٹلائے اور روگردانی کرے اس کے لئے عذاب ہے
20,49,قَالَ فَمَنْ رَّبُّكُمَا یٰمُوْسٰى قَالَ : اس نے کہا فَمَنْ : پس کون رَّبُّكُمَا : تمہارا رب يٰمُوْسٰى : اے موسیٰ فرعون نے پوچھا کہ اے موسٰی ! تم دونوں کا رب کون ہے ؟
20,50,قَالَ رَبُّنَا الَّذِیْۤ اَعْطٰى كُلَّ شَیْءٍ خَلْقَهٗ ثُمَّ هَدٰى قَالَ : اس نے کہا رَبُّنَا : ہمارا رب الَّذِيْٓ : جس نے اَعْطٰي : عطا کی كُلَّ شَيْءٍ : ہر چیز خَلْقَهٗ : اس کی شکل و صورت ثُمَّ : پھر هَدٰى : رہنمائی کی جواب دیا کہ ہمارا رب وہ ہے جس نے ہر ایک کو اس کی خاص صورت، شکل عنایت فرمائی پھر راہ سجھا دی (1)۔
20,51,قَالَ فَمَا بَالُ الْقُرُوْنِ الْاُوْلٰى قَالَ : اس نے کہا فَمَا : پھر کیا بَالُ : حال الْقُرُوْنِ : جماعتیں الْاُوْلٰى : پہلی اس نے کہا اچھا یہ تو بتاؤ اگلے زمانے والوں کا حال کیا ہونا ہے (1)
20,52,قَالَ عِلْمُهَا عِنْدَ رَبِّیْ فِیْ كِتٰبٍ١ۚ لَا یَضِلُّ رَبِّیْ وَ لَا یَنْسَى٘ قَالَ : اس نے کہا عِلْمُهَا : اس کا علم عِنْدَ : پاس رَبِّيْ : میرا رب فِيْ كِتٰبٍ : کتاب میں لَا يَضِلُّ : وہ نہ غلطی کرتا ہے رَبِّيْ : میرا رب وَ : اور لَا يَنْسَى : نہ وہ بھولتا ہے جواب دیا کہ ان کا علم میرے رب کے ہاں کتاب میں موجود ہے، نہ تو میرا رب غلطی کرتا ہے نہ بھولتا ہے (1)
20,53,الَّذِیْ جَعَلَ لَكُمُ الْاَرْضَ مَهْدًا وَّ سَلَكَ لَكُمْ فِیْهَا سُبُلًا وَّ اَنْزَلَ مِنَ السَّمَآءِ مَآءً١ؕ فَاَخْرَجْنَا بِهٖۤ اَزْوَاجًا مِّنْ نَّبَاتٍ شَتّٰى الَّذِيْ : وہ جس نے جَعَلَ : بنایا لَكُمُ : تمہارے لیے الْاَرْضَ : زمین مَهْدًا : بچھونا وَّسَلَكَ : اور چلائیں لَكُمْ : تمہارے لیے فِيْهَا : اس میں سُبُلًا : راہیں وَّ اَنْزَلَ : اور اتارا مِنَ : سے السَّمَآءِ : آسمان مَآءً : پانی فَاَخْرَجْنَا : پھر ہم نے نکالے بِهٖٓ : اس سے اَزْوَاجًا : جوڑے (اقسام) مِّنْ : سے نَّبَاتٍ : سبزی شَتّٰى : مختلف اسی نے تمہارے لئے زمین کو فرش بنایا اور اس میں تمہارے چلنے کے لئے راستے بنائے ہیں اور آسمان سے پانی بھی وہی برساتا ہے، پھر برسات کی وجہ سے مختلف قسم کی پیداوار بھی ہم ہی پیدا کرتے ہیں۔
20,54,كُلُوْا وَ ارْعَوْا اَنْعَامَكُمْ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّاُولِی النُّهٰى۠    ۧ كُلُوْا : تم کھاؤ وَارْعَوْا : اور چراؤ اَنْعَامَكُمْ : اپنے مویشی اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ : نشانیاں لِّاُولِي النُّهٰى : عقل والوں کے لیے تم خود کھاؤ اور اپنے چوپاؤں کو بھی چراؤ (1) کچھ شک نہیں کہ اس میں عقلمندوں کے لئے (2) بہت سی نشانیاں ہیں۔
20,55,مِنْهَا خَلَقْنٰكُمْ وَ فِیْهَا نُعِیْدُكُمْ وَ مِنْهَا نُخْرِجُكُمْ تَارَةً اُخْرٰى مِنْهَا : اس سے خَلَقْنٰكُمْ : ہم نے تمہیں پیدا کیا وَفِيْهَا : اور اس میں نُعِيْدُكُمْ : ہم لوٹا دیں گے تمہیں وَمِنْهَا : اور اس سے نُخْرِجُكُمْ : ہم نکالیں گے تمہیں تَارَةً اُخْرٰى : دوسری بار اس زمین میں سے ہم نے تمہیں پیدا کیا اور اسی میں پھر واپس لوٹائیں گے اور اسی سے پھر دوبارہ تم سب (1) کو نکال کھڑا کریں گے۔
20,56,وَ لَقَدْ اَرَیْنٰهُ اٰیٰتِنَا كُلَّهَا فَكَذَّبَ وَ اَبٰى وَلَقَدْ اَرَيْنٰهُ : اور ہم نے اسے دکھائیں اٰيٰتِنَا : اپنی نشانیاں كُلَّهَا : تمام فَكَذَّبَ : تو اس نے جھٹلایا وَاَبٰى : اور انکار کیا ہم نے اسے اپنی سب نشانیاں دکھا دیں لیکن پھر بھی اس نے جھٹلایا اور انکار کردیا۔
20,57,قَالَ اَجِئْتَنَا لِتُخْرِجَنَا مِنْ اَرْضِنَا بِسِحْرِكَ یٰمُوْسٰى قَالَ : اس نے کہا اَجِئْتَنَا : کیا تو آیا ہے ہمارے پاس لِتُخْرِجَنَا : کہ تو نکالدے ہمیں مِنْ اَرْضِنَا : ہماری زمین سے بِسِحْرِكَ : اپنے جادو کے ذریعہ يٰمُوْسٰى : اے موسیٰ کہنے لگا اے موسٰی ! کیا تو اسی لئے آیا ہے کہ ہمیں اپنے جادو کے زور سے ہمارے ملک سے باہر نکال دے (1)
20,58,فَلَنَاْتِیَنَّكَ بِسِحْرٍ مِّثْلِهٖ فَاجْعَلْ بَیْنَنَا وَ بَیْنَكَ مَوْعِدًا لَّا نُخْلِفُهٗ نَحْنُ وَ لَاۤ اَنْتَ مَكَانًا سُوًى فَلَنَاْتِيَنَّكَ : پس ضرور ہم تیرے مقابل لائیں گے بِسِحْرٍ : ایک جادو مِّثْلِهٖ : اس جیسا فَاجْعَلْ : پس مقرر کر بَيْنَنَا : ہمارے درمیان وَبَيْنَكَ : اور اپنے درمیان مَوْعِدًا : ایک وعدہ (وقت) لَّا نُخْلِفُهٗ : ہم اس کے خلاف نہ کریں نَحْنُ : ہم وَلَآ : اور نہ اَنْتَ : تو مَكَانًا سُوًى : ایک ہموار میدان اچھا ہم بھی تیرے مقابلے میں اسی جیسا جادو ضرور لائیں گے، پس تو ہمارے اور اپنے درمیان ایک وعدے کا وقت مقرر کرلے (1) کہ نہ ہم اس کا خلاف کریں اور نہ تو، صاف میدان میں مقابلہ ہو۔ (2)
20,59,قَالَ مَوْعِدُكُمْ یَوْمُ الزِّیْنَةِ وَ اَنْ یُّحْشَرَ النَّاسُ ضُحًى قَالَ : اس نے کہا مَوْعِدُكُمْ : تمہارا وعدہ يَوْمُ الزِّيْنَةِ : زینت (میلے) کا دن وَاَنْ : اور یہ کہ يُّحْشَرَ : جمع کیے جائیں النَّاسُ : لوگ ضُحًي : دن چڑھے موسیٰ ؑ نے جواب دیا کہ زینت اور جشن کے دن (1) کا وعدہ ہے اور یہ کہ لوگ دن چڑھے ہی جمع ہوجائیں
20,60,فَتَوَلّٰى فِرْعَوْنُ فَجَمَعَ كَیْدَهٗ ثُمَّ اَتٰى فَتَوَلّٰى : پھر لوٹ گیا فِرْعَوْنُ : فرعون فَجَمَعَ : اس نے جمع کیا كَيْدَهٗ : اپنا داؤ ثُمَّ : پھر اَتٰى : وہ آیا پس فرعون لوٹ گیا اور اس نے اپنے ہتھکنڈے جمع کئے پھر آگیا (1)
20,61,قَالَ لَهُمْ مُّوْسٰى وَیْلَكُمْ لَا تَفْتَرُوْا عَلَى اللّٰهِ كَذِبًا فَیُسْحِتَكُمْ بِعَذَابٍ١ۚ وَ قَدْ خَابَ مَنِ افْتَرٰى قَالَ : اس نے کہا لَهُمْ : ان سے مُّوْسٰى : موسیٰ وَيْلَكُمْ : خرابی تم پر لَا تَفْتَرُوْا : نہ گھڑو عَلَي اللّٰهِ : اللہ پر كَذِبًا : جھوٹ فَيُسْحِتَكُمْ : کہ وہ ہلاک کر دے تمہیں بِعَذَابٍ : عذاب سے وَقَدْ خَابَ : اور وہ نامراد ہوا مَنِ افْتَرٰى : جس نے جھوٹ باندھا موسٰی ؑ نے کہا تمہاری شامت آچکی، اللہ تعالیٰ پر جھوٹ اور افتراء نہ باندھو کہ تمہیں عذابوں سے ملیامیٹ کردے، یاد رکھو وہ کبھی کامیاب نہ ہوگا جس نے جھوٹی بات گھڑی۔ (1)۔
20,62,فَتَنَازَعُوْۤا اَمْرَهُمْ بَیْنَهُمْ وَ اَسَرُّوا النَّجْوٰى فَتَنَازَعُوْٓا : تو وہ جھگڑنے لگے اَمْرَهُمْ : اپنے کام میں بَيْنَهُمْ : باہم وَاَسَرُّوا : اور انہوں نے چھپ کر کیا النَّجْوٰى : مشورہ پس یہ لوگ آپس کے مشوروں میں مختلف رائے ہوگئے اور چھپ کر چپکے چپکے مشورہ کرنے لگے (1)۔
20,63,قَالُوْۤا اِنْ هٰذٰىنِ لَسٰحِرٰنِ یُرِیْدٰنِ اَنْ یُّخْرِجٰكُمْ مِّنْ اَرْضِكُمْ بِسِحْرِهِمَا وَ یَذْهَبَا بِطَرِیْقَتِكُمُ الْمُثْلٰى قَالُوْٓا : وہ کہنے لگے اِنْ : تحقیق ھٰذٰىنِ : یہ دونوں لَسٰحِرٰنِ : البتہ جادوگر يُرِيْدٰنِ : یہ چاہتے ہیں اَنْ يُّخْرِجٰكُمْ : کہ تمہیں نکال دیں مِّنْ : سے اَرْضِكُمْ : تمہاری سرزمین بِسِحْرِهِمَا : اپنے جادو کے ذریعہ وَيَذْهَبَا : اور وہ لے جائیں بِطَرِيْقَتِكُمُ : تمہارا طریقہ الْمُثْلٰى : اچھا کہنے لگے یہ دونوں محض جادوگر ہیں اور ان کا پختہ ارادہ ہے کہ اپنے جادو کے زور سے تمہیں تمہارے ملک سے نکال باہر کریں اور تمہارے بہترین مذہب کو برباد کریں (1)۔
20,64,فَاَجْمِعُوْا كَیْدَكُمْ ثُمَّ ائْتُوْا صَفًّا١ۚ وَ قَدْ اَفْلَحَ الْیَوْمَ مَنِ اسْتَعْلٰى فَاَجْمِعُوْا : لہذا اکٹھا کرلو تم كَيْدَكُمْ : اپنے داؤ ثُمَّ ائْتُوْا : پھر تم آؤ صَفًّا : صف باندھ کر وَقَدْ اَفْلَحَ : اور تحقیق کامیاب ہوگا الْيَوْمَ : آج مَنِ : جو اسْتَعْلٰى : غالب رہا تو تم بھی اپنا کوئی داؤ اٹھا نہ رکھو، پھر صف بندی کرکے آؤ، جو آج غالب آگیا وہی بازی لے گیا۔
20,65,قَالُوْا یٰمُوْسٰۤى اِمَّاۤ اَنْ تُلْقِیَ وَ اِمَّاۤ اَنْ نَّكُوْنَ اَوَّلَ مَنْ اَلْقٰى قَالُوْا : وہ بولے يٰمُوْسٰٓى : اے موسیٰ اِمَّآ : یا تو اَنْ تُلْقِيَ : یہ کہ تو ڈالے وَاِمَّآ : اور یا اَنْ نَّكُوْنَ : یہ کہ ہم ہوں اَوَّلَ : پہلے مَنْ : جو اَلْقٰي : ڈالیں کہنے لگے اے موسٰی ! یا تو پہلے ڈال یا ہم پہلے ڈالنے والے بن جائیں۔
20,66,قَالَ بَلْ اَلْقُوْا١ۚ فَاِذَا حِبَالُهُمْ وَ عِصِیُّهُمْ یُخَیَّلُ اِلَیْهِ مِنْ سِحْرِهِمْ اَنَّهَا تَسْعٰى قَالَ : اس نے کہا بَلْ : بلکہ اَلْقُوْا : تم ڈالو فَاِذَا : تو ناگہاں حِبَالُهُمْ : ان کی رسیاں وَعِصِيُّهُمْ : اور ان کی لاٹھیاں يُخَيَّلُ : خیال میں آئیں اِلَيْهِ : اس کے مِنْ : سے سِحْرِهِمْ : ان کا جادو اَنَّهَا : کہ وہ تَسْعٰي : دوڑ رہی ہیں جواب دیا کہ نہیں تم ہی پہلے ڈالو (1) اب تو موسیٰ ؑ کو یہ خیال گزرنے لگا کہ ان کی رسیاں اور لکڑیاں ان کے جادو کے زور سے دوڑ بھاگ رہی ہیں (2)
20,67,فَاَوْجَسَ فِیْ نَفْسِهٖ خِیْفَةً مُّوْسٰى فَاَوْجَسَ : تو پایا (محسوس کیا) فِيْ نَفْسِهٖ : اپنے دل میں خِيْفَةً : کچھ خوف مُّوْسٰى : موسیٰ پس موسیٰ ؑ نے اپنے دل ہی دل میں ڈر محسوس کیا۔
20,68,قُلْنَا لَا تَخَفْ اِنَّكَ اَنْتَ الْاَعْلٰى قُلْنَا : ہم نے کہا لَا تَخَفْ : تم ڈرو نہیں اِنَّكَ : بیشک تم اَنْتَ : تم (ہی) الْاَعْلٰى : غالب ہم نے فرمایا کچھ خوف نہ کر یقیناً تو ہی غالب اور برتر رہے گا (1)۔
20,69,وَ اَلْقِ مَا فِیْ یَمِیْنِكَ تَلْقَفْ مَا صَنَعُوْا١ؕ اِنَّمَا صَنَعُوْا كَیْدُ سٰحِرٍ١ؕ وَ لَا یُفْلِحُ السَّاحِرُ حَیْثُ اَتٰى وَاَلْقِ : اور ڈالو مَا : جو فِيْ يَمِيْنِكَ : تمہارے دائیں ہاتھ میں تَلْقَفْ : وہ نگل جائے گا مَا صَنَعُوْا : جو انہوں نے بنایا اِنَّمَا : بیشک صَنَعُوْا : انہوں نے بنایا كَيْدُ : فریب سٰحِرٍ : جادوگر وَلَا يُفْلِحُ : اور کامیاب نہیں ہوگا السَّاحِرُ : جادوگر حَيْثُ : جہاں (کہیں) اَتٰى : وہ آئے اور تیرے دائیں ہاتھ میں جو ہے اسے ڈال دے کہ ان کی تمام کاریگری کو وہ نگل جائے، انہوں نے جو کچھ بنایا ہے یہ صرف جادوگروں کے کرتب ہیں اور جادوگر کہیں سے بھی آئے کامیاب نہیں ہوتا۔
20,70,فَاُلْقِیَ السَّحَرَةُ سُجَّدًا قَالُوْۤا اٰمَنَّا بِرَبِّ هٰرُوْنَ وَ مُوْسٰى فَاُلْقِيَ : پس ڈالدئیے گئے السَّحَرَةُ : جادوگر سُجَّدًا : سجدہ میں قَالُوْٓا : وہ بولے اٰمَنَّا : ہم ایمان لائے بِرَبِّ : رب پر هٰرُوْنَ : ہارون وَمُوْسٰى : اور موسیٰ اب تو تمام جادوگر سجدے میں گرپڑے اور پکار اٹھے کہ ہم تو ہارون اور موسیٰ (علیہما السلام) کے رب پر ایمان لائے
20,71,قَالَ اٰمَنْتُمْ لَهٗ قَبْلَ اَنْ اٰذَنَ لَكُمْ١ؕ اِنَّهٗ لَكَبِیْرُكُمُ الَّذِیْ عَلَّمَكُمُ السِّحْرَ١ۚ فَلَاُقَطِّعَنَّ اَیْدِیَكُمْ وَ اَرْجُلَكُمْ مِّنْ خِلَافٍ وَّ لَاُصَلِّبَنَّكُمْ فِیْ جُذُوْعِ النَّخْلِ١٘ وَ لَتَعْلَمُنَّ اَیُّنَاۤ اَشَدُّ عَذَابًا وَّ اَبْقٰى قَالَ : اس نے کہا اٰمَنْتُمْ : تم ایمان لائے لَهٗ : اس پر قَبْلَ : پہلے اَنْ اٰذَنَ : کہ میں اجازت دوں لَكُمْ : تمہیں اِنَّهٗ : بیشک وہ لَكَبِيْرُكُمُ : تمہارا بڑا الَّذِيْ : وہ جس نے عَلَّمَكُمُ : تمہیں سکھایا السِّحْرَ : جادو فَلَاُقَطِّعَنَّ : پس میں ضرور کاٹوں گا اَيْدِيَكُمْ : تمہارے ہاتھ وَاَرْجُلَكُمْ : اور تمہارے پاؤں مِّنْ خِلَافٍ : دوسری طرف سے وَّلَاُوصَلِّبَنَّكُمْ : اور میں تمہیں ضرور سولی دوں گا فِيْ : میں۔ پر جُذُوْعِ النَّخْلِ : کھجور کے تنے وَلَتَعْلَمُنَّ : اور تم خوب جان لوگے اَيُّنَآ : ہم میں کون اَشَدُّ : زیادہ سخت عَذَابًا : عذاب میں وَّاَبْقٰي : اور تا دیر رہنے والا فرعون کہنے لگا کہ کیا میری اجازت سے پہلے ہی تم اس پر ایمان لے آئے ؟ یقیناً تمہارا بڑا بزرگ ہے جس نے تم سب کو جادو سکھایا ہے، (سن لو) میں تمہارے ہاتھ پاؤں الٹے سیدھے (1) کٹوا کر تم سب کو کھجور کے تنوں میں سولی پر لٹکوا دوں گا، اور تمہیں پوری طرح معلوم ہوجائے گا کہ ہم میں سے کس کی مار زیادہ سخت اور دیرپا ہے۔
20,72,قَالُوْا لَنْ نُّؤْثِرَكَ عَلٰى مَا جَآءَنَا مِنَ الْبَیِّنٰتِ وَ الَّذِیْ فَطَرَنَا فَاقْضِ مَاۤ اَنْتَ قَاضٍ١ؕ اِنَّمَا تَقْضِیْ هٰذِهِ الْحَیٰوةَ الدُّنْیَاؕ قَالُوْا : انہوں نے کہا لَنْ نُّؤْثِرَكَ : ہم ہرگز تجھے ترجیح نہ دیں گے عَلٰي : پر مَا جَآءَنَا : جو ہمارے پاس آئے مِنَ الْبَيِّنٰتِ : واضح دلائل سے وَالَّذِيْ فَطَرَنَا : اور وہ جس نے ہمیں پیدا کیا فَاقْضِ : پس تو کر گزر مَآ : جو اَنْتَ : تو قَاضٍ : کرنے والا اِنَّمَا : اس کے سوا نہیں تَقْضِيْ : تو کرے گا هٰذِهِ : اس الْحَيٰوةَ الدُّنْيَا : دنیا کی زندگی انہوں نے جواب دیا کہ ناممکن ہے کہ ہم تجھے ترجیح دیں ان دلیلوں پر جو ہمارے سامنے آچکیں ہیں، اور اس اللہ پر جس نے ہمیں پیدا کیا ہے (1) اب تو تو جو کچھ کرنے والا ہے کر گزر، تو جو کچھ بھی حکم چلا سکتا ہے وہ اسی دنیاوی زندگی (2) میں ہی ہے۔
20,73,اِنَّاۤ اٰمَنَّا بِرَبِّنَا لِیَغْفِرَ لَنَا خَطٰیٰنَا وَ مَاۤ اَكْرَهْتَنَا عَلَیْهِ مِنَ السِّحْرِ١ؕ وَ اللّٰهُ خَیْرٌ وَّ اَبْقٰى اِنَّآ اٰمَنَّا : بیشک ہم ایمان لائے بِرَبِّنَا : اپنے رب پر لِيَغْفِرَ لَنَا : کہ وہ بخشدے خَطٰيٰنَا : ہماری خطائیں وَمَآ : اور جو اَكْرَهْتَنَا : تو نے ہمیں مجبور کیا عَلَيْهِ : اس پر مِنَ : سے السِّحْرِ : جادو وَاللّٰهُ : اور اللہ خَيْرٌ : بہتر وَّاَبْقٰي : اور ہمیشہ باقی رہنے والا ہم (اس امید سے) اپنے پروردگار پر ایمان لائے کہ وہ ہماری خطائیں معاف فرما دے اور (خاص کر) جادوگری (کا گناہ) جس پر تم نے ہمیں مجبور کیا ہے (1) اللہ ہی بہتر اور ہمیشہ باقی رہنے والا ہے (2)۔
20,74,اِنَّهٗ مَنْ یَّاْتِ رَبَّهٗ مُجْرِمًا فَاِنَّ لَهٗ جَهَنَّمَ١ؕ لَا یَمُوْتُ فِیْهَا وَ لَا یَحْیٰى اِنَّهٗ : بیشک وہ مَنْ يَّاْتِ : جو آیا رَبَّهٗ : اپنے رب کے سامنے مُجْرِمًا : مجرم بن کر فَاِنَّ : تو بیشک لَهٗ : اس کے لیے جَهَنَّمَ : جہنم لَا يَمُوْتُ : نہ وہ مرے گا فِيْهَا : اس میں وَ : اور لَا يَحْيٰي : نہ جئے گا بات یہی ہے کہ جو بھی گناہ گار بن کر اللہ تعالیٰ کے ہاں حاضر ہوگا اس کے لئے دوزخ ہے، جہاں نہ موت ہوگی اور نہ زندگی (1)
20,75,وَ مَنْ یَّاْتِهٖ مُؤْمِنًا قَدْ عَمِلَ الصّٰلِحٰتِ فَاُولٰٓئِكَ لَهُمُ الدَّرَجٰتُ الْعُلٰىۙ وَمَنْ : اور جو يَّاْتِهٖ : اس کے پاس آیا مُؤْمِنًا : مومن بن کر قَدْ عَمِلَ : اس نے کیے عمل الصّٰلِحٰتِ : اچھے فَاُولٰٓئِكَ : پس یہی لوگ لَهُمُ : ان کے لیے الدَّرَجٰتُ : درجے الْعُلٰي : بلند اور جو بھی اس کے پاس ایماندار ہو کر حاضر ہوگا اور اس نے اعمال بھی نیک کئے ہونگے اس کے لئے بلند وبالا درجے ہیں۔
20,76,جَنّٰتُ عَدْنٍ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ خٰلِدِیْنَ فِیْهَا١ؕ وَ ذٰلِكَ جَزٰٓؤُا مَنْ تَزَكّٰى۠    ۧ جَنّٰتُ : باغات عَدْنٍ : ہمیشہ رہنے والے تَجْرِيْ : جاری ہیں مِنْ تَحْتِهَا : ان کے نیچے الْاَنْهٰرُ : نہریں خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَا : اس میں وَذٰلِكَ : اور یہ جَزٰٓؤُا : جزا ہے مَنْ تَزَكّٰى : جو پاک ہوا ہمیشگی والی جنتیں جن کے نیچے نہریں بہہ رہی ہیں جہاں وہ ہمیشہ ہمیشہ رہیں گے۔ یہی انعام ہے ہر اس شخص کا جو پاک ہوا (1)۔
20,77,وَ لَقَدْ اَوْحَیْنَاۤ اِلٰى مُوْسٰۤى١ۙ۬ اَنْ اَسْرِ بِعِبَادِیْ فَاضْرِبْ لَهُمْ طَرِیْقًا فِی الْبَحْرِ یَبَسًا١ۙ لَّا تَخٰفُ دَرَكًا وَّ لَا تَخْشٰى وَلَقَدْ اَوْحَيْنَآ : اور تحقیق ہم نے وحی کی اِلٰى : طرف۔ کو مُوْسٰٓى : موسیٰ اَنْ اَسْرِ : کہ راتوں رات لے جا بِعِبَادِيْ : میرے بندے فَاضْرِبْ : پس بنا لینا لَهُمْ : ان کے لیے طَرِيْقًا : راستہ فِي الْبَحْرِ : دریا میں يَبَسًا : خشک لَّا : نہ تَخٰفُ : خوف ہوگا دَرَكًا : پکڑنا وَّلَا تَخْشٰى : اور نہ ڈر ہم نے موسیٰ ؑ کی طرف وحی نازل فرمائی کہ تو راتوں رات میرے بندوں کو لے چل (1) پھر نہ تجھے کسی کے آپکڑنے کا خطرہ ہوگا نہ ڈر (2)۔
20,78,فَاَتْبَعَهُمْ فِرْعَوْنُ بِجُنُوْدِهٖ فَغَشِیَهُمْ مِّنَ الْیَمِّ مَا غَشِیَهُمْؕ فَاَتْبَعَهُمْ : پھر ان کا پیچھا کیا فِرْعَوْنُ : فرعون بِجُنُوْدِهٖ : اپنے لشکر کے ساتھ فَغَشِيَهُمْ : انہیں ڈھانپ لیا مِّنَ الْيَمِّ : دریا سے مَا غَشِيَهُمْ : جیسا کہ ان کو ڈھانپ لیا فرعون نے اپنے لشکروں سمیت ان کا تعاقب کیا پھر تو دریا ان سب پر چھا گیا جیسا کچھ چھا جانے والا تھا (1)
20,79,وَ اَضَلَّ فِرْعَوْنُ قَوْمَهٗ وَ مَا هَدٰى وَاَضَلَّ : اور گمراہ کیا فِرْعَوْنُ : فرعون قَوْمَهٗ : اپنی قوم وَمَا هَدٰى : اور نہ ہدایت دی فرعون نے اپنی قوم کو گمراہی میں ڈال دیا اور سیدھا راستہ نہ دکھایا (1)
20,80,یٰبَنِیْۤ اِسْرَآءِیْلَ قَدْ اَنْجَیْنٰكُمْ مِّنْ عَدُوِّكُمْ وَ وٰعَدْنٰكُمْ جَانِبَ الطُّوْرِ الْاَیْمَنَ وَ نَزَّلْنَا عَلَیْكُمُ الْمَنَّ وَ السَّلْوٰى يٰبَنِيْٓ اِسْرَآءِيْلَ : اے بنی اسرائیل قَدْ : تحقیق اَنْجَيْنٰكُمْ : ہم نے تمہیں نجات دی مِّنْ : سے عَدُوِّكُمْ : تمہارا دشمن وَوٰعَدْنٰكُمْ : اور ہم نے تم سے وعدہ کیا جَانِبَ : جانب الطُّوْرِ الْاَيْمَنَ : کوہ طور دائیں وَنَزَّلْنَا : اور ہم نے اتارا عَلَيْكُمُ : تم پر الْمَنَّ : من وَالسَّلْوٰى : اور سلوی اے بنی اسرائیل ! دیکھو ہم نے تمہیں تمہارے دشمن سے نجات دی اور تم سے کوہ طور کی دائیں طرف کا وعدہ (1) اور تم پر من وسلویٰ اتارا (2)
20,81,كُلُوْا مِنْ طَیِّبٰتِ مَا رَزَقْنٰكُمْ وَ لَا تَطْغَوْا فِیْهِ فَیَحِلَّ عَلَیْكُمْ غَضَبِیْ١ۚ وَ مَنْ یَّحْلِلْ عَلَیْهِ غَضَبِیْ فَقَدْ هَوٰى كُلُوْا : تم کھاؤ مِنْ : سے طَيِّبٰتِ : پاکیزہ چیزیں مَا رَزَقْنٰكُمْ : جو ہم نے تمہیں دیا وَ : اور لَا تَطْغَوْا : نہ سرکشی کرو فِيْهِ : اس میں فَيَحِلَّ : کہ اترے گا عَلَيْكُمْ : تم پر غَضَبِيْ : میرا غضب وَمَنْ : اور جو يَّحْلِلْ : اترا عَلَيْهِ : اس پر غَضَبِيْ : میرا غضب فَقَدْ هَوٰى : تو وہ گرا (نیست ونابود ہوا) تم ہماری دی ہوئی پاکیزہ روزی کھاؤ، اور اس میں حد سے آگے نہ بڑھو (1) ورنہ تم پر میرا غضب نازل ہوگا، اور جس پر میرا غضب نازل ہوجائے وہ یقیناً تباہ ہوا (2)۔
20,82,وَ اِنِّیْ لَغَفَّارٌ لِّمَنْ تَابَ وَ اٰمَنَ وَ عَمِلَ صَالِحًا ثُمَّ اهْتَدٰى وَاِنِّىْ : اور بیشک میں لَغَفَّارٌ : بڑا بخشنے والا لِّمَنْ : اس کو۔ جو جس تَابَ : توبہ کی وَاٰمَنَ : اور وہ ایمان لایا وَعَمِلَ : اور اس نے عمل کیا صَالِحًا : نیک ثُمَّ : پھر اهْتَدٰى : ہدایت پر رہا ہاں بیشک میں انھیں بخش دینے والا ہوں جو توبہ کریں ایمان لائیں نیک عمل کریں اور راہ راست پر بھی رہیں (1)
20,83,وَ مَاۤ اَعْجَلَكَ عَنْ قَوْمِكَ یٰمُوْسٰى وَمَآ : اور کیا (چیز) اَعْجَلَكَ : تجھے جلد لائی عَنْ قَوْمِكَ : اپنی قوم سے يٰمُوْسٰى : اے موسیٰ اے موسٰی ! تجھے اپنی قوم سے (غافل کرکے) کون سی چیز جلدی لے آئی ؟
20,84,قَالَ هُمْ اُولَآءِ عَلٰۤى اَثَرِیْ وَ عَجِلْتُ اِلَیْكَ رَبِّ لِتَرْضٰى قَالَ : اس نے کہا هُمْ : وہ اُولَآءِ : یہ ہیں عَلٰٓي اَثَرِيْ : میرے پیچھے وَعَجِلْتُ : اور میں نے جلدی کی اِلَيْكَ : تیری طرف رَبِّ : اے میرے رب لِتَرْضٰى : تا کہ تو راضی ہو کہا کہ وہ لوگ بھی میرے پیچھے ہی پیچھے ہیں، اور میں نے اے رب ! تیری طرف جلدی اس لئے کی کہ تو خوش ہوجائے (1)۔
20,85,قَالَ فَاِنَّا قَدْ فَتَنَّا قَوْمَكَ مِنْۢ بَعْدِكَ وَ اَضَلَّهُمُ السَّامِرِیُّ قَالَ : اس نے کہا فَاِنَّا : پس ہم نے قَدْ : تحقیق فَتَنَّا : آزمائش میں ڈالا قَوْمَكَ : تیری قوم مِنْۢ بَعْدِكَ : تیرے بعد وَاَضَلَّهُمُ : اور انہیں گمراہ کیا السَّامِرِيُّ : سامری فرمایا ! ہم نے تیری قوم کو تیرے پیچھے آزمائش میں ڈال دیا اور انھیں سامری نے بہکا دیا ہے (1)
20,86,فَرَجَعَ مُوْسٰۤى اِلٰى قَوْمِهٖ غَضْبَانَ اَسِفًا١ۚ۬ قَالَ یٰقَوْمِ اَلَمْ یَعِدْكُمْ رَبُّكُمْ وَعْدًا حَسَنًا١ؕ۬ اَفَطَالَ عَلَیْكُمُ الْعَهْدُ اَمْ اَرَدْتُّمْ اَنْ یَّحِلَّ عَلَیْكُمْ غَضَبٌ مِّنْ رَّبِّكُمْ فَاَخْلَفْتُمْ مَّوْعِدِیْ فَرَجَعَ : پس لوٹا مُوْسٰٓى : موسیٰ اِلٰى قَوْمِهٖ : اپنی قوم غَضْبَانَ : غصہ مٰں بھرا ہوا اَسِفًا : افسوس کرتا قَالَ : اس نے کہا يٰقَوْمِ : اے میری قوم اَلَمْ يَعِدْكُمْ : کیا تم سے وعدہ نہیں کیا تھا رَبُّكُمْ : تمہارا رب وَعْدًا حَسَنًا : اچھا وعدہ اَفَطَالَ : کیا طویل ہوگئی عَلَيْكُمُ : تم پر الْعَهْدُ : مدت اَمْ اَرَدْتُّمْ : یا تم نے چاہا اَنْ يَّحِلَّ : کہ اترے عَلَيْكُمْ : تم پر غَضَبٌ : غضب مِّنْ : سے۔ کا رَّبِّكُمْ : تمہارا رب فَاَخْلَفْتُمْ : پھر تم نے خلاف کیا مَّوْعِدِيْ : میرا وعدہ پس موسیٰ ؑ سخت غضبناک ہو کر رنج کے ساتھ واپس لوٹے، اور کہنے لگے کہ اے میری قوم والو ! کیا تم سے تمہارے پروردگار نے نیک وعدہ نہیں کیا (1) تھا ؟ کیا اس کی مدت تمہیں لمبی معلوم ہوئی ؟ (2) بلکہ تمہارا ارادہ ہی یہ ہے کہ تم پر تمہارے پروردگار کا غضب نازل ہو ؟ کہ تم نے میرے وعدے کے خلاف کیا (3)
20,87,قَالُوْا مَاۤ اَخْلَفْنَا مَوْعِدَكَ بِمَلْكِنَا وَ لٰكِنَّا حُمِّلْنَاۤ اَوْزَارًا مِّنْ زِیْنَةِ الْقَوْمِ فَقَذَفْنٰهَا فَكَذٰلِكَ اَلْقَى السَّامِرِیُّۙ قَالُوْا : وہ بولے مَآ اَخْلَفْنَا : ہم نے خلاف نہیں کیا مَوْعِدَكَ : تمہارا وعدہ بِمَلْكِنَا : اپنے اختیار سے وَلٰكِنَّا : اور لیکن (بلکہ) حُمِّلْنَآ : ہم پر لادا گیا اَوْزَارًا : بوجھ مِّنْ : سے۔ کا زِيْنَةِ الْقَوْمِ : قوم کا زیور فَقَذَفْنٰهَا : تو ہم نے اسے ڈالدیا فَكَذٰلِكَ : پھر اسی طرح اَلْقَي : ڈالا السَّامِرِيُّ : سامری انہوں نے جواب دیا کہ ہم نے اپنے اختیار سے آپ کے ساتھ وعدے کے خلاف نہیں کیا (1) بلکہ ہم پر زیورات قوم کے جو بوجھ لاد دیئے گئے تھے، انھیں ہم نے ڈال دیا، اور اسی طرح سامری نے بھی ڈال دیئے۔
20,88,فَاَخْرَجَ لَهُمْ عِجْلًا جَسَدًا لَّهٗ خُوَارٌ فَقَالُوْا هٰذَاۤ اِلٰهُكُمْ وَ اِلٰهُ مُوْسٰى١۬ فَنَسِیَؕ فَاَخْرَجَ : پھر اس نے نکالا لَهُمْ : ان کے لیے عِجْلًا : ایک بچھڑا جَسَدًا : ایک قالب لَّهٗ : اس کے لیے خُوَارٌ : گائے کی آواز فَقَالُوْا : پھر انہوں نے کہا ھٰذَآ : یہ اِلٰهُكُمْ : تمہارا معبود وَاِلٰهُ : اور معبود مُوْسٰى : موسیٰ فَنَسِيَ : پھر وہ بھول گیا پھر اس نے لوگوں کے لئے ایک بچھڑا نکال کھڑا کیا یعنی بچھڑے کا بت، جس کی گائے کی سی آواز بھی تھی پھر کہنے لگے کہ یہی تمہارا بھی معبود ہے (1) اور موسیٰ کا بھی۔ لیکن موسیٰ بھول گیا ہے۔
20,89,اَفَلَا یَرَوْنَ اَلَّا یَرْجِعُ اِلَیْهِمْ قَوْلًا١ۙ۬ وَّ لَا یَمْلِكُ لَهُمْ ضَرًّا وَّ لَا نَفْعًا۠    ۧ اَفَلَا يَرَوْنَ : پس کیا وہ نہیں دیکھتے اَلَّا يَرْجِعُ : کہ وہ نہیں پھیرتا اِلَيْهِمْ : ان کی طرف قَوْلًا : بات (جواب) وَّلَا يَمْلِكُ : اور اختیار نہیں رکھتا لَهُمْ : ان کے ضَرًّا : نقصان وَّ : اور لَا نَفْعًا : ں ہ نفع کیا یہ گمراہ لوگ یہ بھی نہیں دیکھتے کہ وہ تو ان کی بات کا جواب بھی نہیں دے سکتا اور نہ ان کے کسی برے بھلے کا اختیار رکھتا ہے (1)
20,90,وَ لَقَدْ قَالَ لَهُمْ هٰرُوْنُ مِنْ قَبْلُ یٰقَوْمِ اِنَّمَا فُتِنْتُمْ بِهٖ١ۚ وَ اِنَّ رَبَّكُمُ الرَّحْمٰنُ فَاتَّبِعُوْنِیْ وَ اَطِیْعُوْۤا اَمْرِیْ وَ : اور لَقَدْ قَالَ : تحقیق کہا لَهُمْ : ان سے هٰرُوْنُ : ہارون مِنْ قَبْلُ : اس سے پہلے يٰقَوْمِ : اے میری قوم اِنَّمَا : اس کے سوا نہیں فُتِنْتُمْ : تم آزمائے گئے بِهٖ : اس سے وَاِنَّ : اور بیشک رَبَّكُمُ : تمہارا رب الرَّحْمٰنُ : رحمن ہے فَاتَّبِعُوْنِيْ : سو میری پیروی کرو وَاَطِيْعُوْٓا : اور اطاعت کرو (مانو) اَمْرِيْ : میری بات اور ہارون ؑ نے اس سے پہلے ہی ان سے کہہ دیا تھا اے میری قوم والو ! اس بچھڑے سے صرف تمہاری آزمائش کی گئی ہے، تمہارا حقیقی پروردگار تو اللہ رحمٰن ہی ہے، پس تم سب میری تابعداری کرو۔ اور میری بات مانتے چلے جاؤ (1)۔
20,91,قَالُوْا لَنْ نَّبْرَحَ عَلَیْهِ عٰكِفِیْنَ حَتّٰى یَرْجِعَ اِلَیْنَا مُوْسٰى قَالُوْا : انہوں نے کہا لَنْ نَّبْرَحَ : ہم ہرگز جدا نہ ہوں گے عَلَيْهِ : اس پر عٰكِفِيْنَ : جمے ہوئے حَتّٰى : یہانتک کہ يَرْجِعَ : لوٹے اِلَيْنَا : ہماری طرف مُوْسٰى : موسیٰ انہوں نے جواب دیا کہ موسیٰ ؑ کی واپسی تک تو ہم اسی کے مجاور بنے بیٹھے رہیں گے (1)
20,92,قَالَ یٰهٰرُوْنُ مَا مَنَعَكَ اِذْ رَاَیْتَهُمْ ضَلُّوْۤاۙ قَالَ : اس نے کہا يٰهٰرُوْنُ : اے ہارون مَا مَنَعَكَ : تجھے کس چیز نے روکا اِذْ : جب رَاَيْتَهُمْ : تو نے دیکھا انہیں ضَلُّوْٓا : وہ گمراہ ہوگئے موسیٰ ؑ کہنے لگے اے ہارون ! انھیں گمراہ ہوتا ہوا دیکھتے ہوئے تجھے کس چیز نے روکا تھا۔
20,93,اَلَّا تَتَّبِعَنِ١ؕ اَفَعَصَیْتَ اَمْرِیْ اَلَّا تَتَّبِعَنِ : کیوں نہ پیروی کی تم نے میری اَفَعَصَيْتَ : تو کیا تونے نافرمانی کی اَمْرِيْ : میرا یہ حکم کہ تو میرے پیچھے نہ آیا۔ کیا تو بھی میرے فرمان کا نافرمان بن بیٹھا (1)
20,94,قَالَ یَبْنَؤُمَّ لَا تَاْخُذْ بِلِحْیَتِیْ وَ لَا بِرَاْسِیْ١ۚ اِنِّیْ خَشِیْتُ اَنْ تَقُوْلَ فَرَّقْتَ بَیْنَ بَنِیْۤ اِسْرَآءِیْلَ وَ لَمْ تَرْقُبْ قَوْلِیْ قَالَ : اس نے کہا يَبْنَؤُمَّ : اے میرے ماں جائے لَا تَاْخُذْج : نہ پکڑیں بِلِحْيَتِيْ : مجھے داڑھی سے وَلَا بِرَاْسِيْ : اور نہ سر سے اِنِّىْ : بیشک میں خَشِيْتُ : ڈرا اَنْ تَقُوْلَ : کہ تم کہو گے فَرَّقْتَ : تونے تفرقہ ڈالدیا بَيْنَ : درمیان بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل وَ : اور لَمْ تَرْقُبْ : نہ خیال رکھا قَوْلِيْ : میری بات ہارون ؑ نے کہا اے میرے ماں جائے بھائی ! میری داڑھی نہ پکڑ اور سر کے بال نہ کھینچ، مجھے تو صرف یہ خیال دامن گیر ہوا کہ کہیں آپ یہ (نہ) فرمائیں (1) کہ تو نے بنی اسرائیل میں تفرقہ ڈال دیا اور میری بات کا انتظار نہ کیا۔ (2)
20,95,قَالَ فَمَا خَطْبُكَ یٰسَامِرِیُّ قَالَ : اس نے کہا فَمَا : پس کیا خَطْبُكَ : تیرا حال يٰسَامِرِيُّ : اے سامری موسیٰ ؑ نے پوچھا سامری تیرا کیا معاملہ ہے۔
20,96,قَالَ بَصُرْتُ بِمَا لَمْ یَبْصُرُوْا بِهٖ فَقَبَضْتُ قَبْضَةً مِّنْ اَثَرِ الرَّسُوْلِ فَنَبَذْتُهَا وَ كَذٰلِكَ سَوَّلَتْ لِیْ نَفْسِیْ قَالَ : وہ بولا بَصُرْتُ : میں نے دیکھا بِمَا : وہ جو کہ لَمْ يَبْصُرُوْا : انہوں نے نہ دیکھا بِهٖ : اس کو فَقَبَضْتُ : پس میں نے مٹھی بھرلی قَبْضَةً : ایک مٹھی مِّنْ : سے اَثَرِ الرَّسُوْلِ : فرشتہ کا نقش قدم فَنَبَذْتُهَا : تو میں نے وہ ڈالدی وَكَذٰلِكَ : اور اسی طرح سَوَّلَتْ : پھسلایا لِيْ : مجھے نَفْسِيْ : میرا نفس اس نے جواب دیا کہ مجھے وہ چیز دکھائی دی جو انھیں دکھائی نہیں دی، تو میں نے قاصد الٰہی کے نقش قدم سے ایک مٹھی بھر لی اسے اس میں ڈال دیا (1) اسی طرح میرے دل نے یہ بات میرے لئے بھلی بنادی۔
20,97,قَالَ فَاذْهَبْ فَاِنَّ لَكَ فِی الْحَیٰوةِ اَنْ تَقُوْلَ لَا مِسَاسَ١۪ وَ اِنَّ لَكَ مَوْعِدًا لَّنْ تُخْلَفَهٗ١ۚ وَ انْظُرْ اِلٰۤى اِلٰهِكَ الَّذِیْ ظَلْتَ عَلَیْهِ عَاكِفًا١ؕ لَنُحَرِّقَنَّهٗ ثُمَّ لَنَنْسِفَنَّهٗ فِی الْیَمِّ نَسْفًا قَالَ : اس نے کہا فَاذْهَبْ : پس تو جا فَاِنَّ لَكَ : بیشک تیرے لیے فِي الْحَيٰوةِ : زندگی میں اَنْ : کہ تَقُوْلَ : تو کہے لَا : نہ مِسَاسَ : چھونا (ہاتھ لگانا) وَاِنَّ : اور بیشک لَكَ : تیرے لیے مَوْعِدًا : ایک وقت مقرر لَّنْ تُخْلَفَهٗ : رہ گز تجھ سے خلاف نہ ہوگا وَانْظُرْ : اور دیکھ اِلٰٓى : طرف اِلٰهِكَ : اپنے معبود الَّذِيْ : وہ جس ظَلْتَ : تو رہتا تھا عَلَيْهِ : اس پر عَاكِفًا : جما ہوا لَنُحَرِّقَنَّهٗ : ہم اسے البتہ جلائیں گے ثُمَّ لَنَنْسِفَنَّهٗ : پھر البتہ اسے بکھیر دیں گے فِي الْيَمِّ : دریا میں نَسْفًا : اڑا کر کہا اچھا جا دنیا کی زندگی میں تیری سزا یہی ہے کہ تو کہتا رہے کہ مجھے نہ چھونا (1) اور ایک اور بھی وعدہ تیرے ساتھ ہے جو تجھ سے ہرگز نہیں ٹلے گا (2) اور اب تو اپنے اس معبود کو بھی دیکھ لینا جس کا اعتکاف کئے ہوئے تھا کہ ہم اسے جلا کر دریا میں ریزہ ریزہ اڑائیں گے۔ (3)
20,98,اِنَّمَاۤ اِلٰهُكُمُ اللّٰهُ الَّذِیْ لَاۤ اِلٰهَ اِلَّا هُوَ١ؕ وَسِعَ كُلَّ شَیْءٍ عِلْمًا اِنَّمَآ : اس کے سوا نہیں اِلٰهُكُمُ : تمہارا معبود اللّٰهُ : اللہ الَّذِيْ : وہ جو لَآ : نہیں اِلٰهَ : کوئی معبود اِلَّا هُوَ : اس کے سوا وَسِعَ : اسیع (محیط ہے) كُلَّ شَيْءٍ : ہر شے عِلْمًا : علم اصل بات یہی ہے کہ تم سب کا معبود برحق صرف اللہ ہی ہے اس کے سوا کوئی پرستش کے قابل نہیں۔ اس کا علم تمام چیزوں پر حاوی ہے
20,99,كَذٰلِكَ نَقُصُّ عَلَیْكَ مِنْ اَنْۢبَآءِ مَا قَدْ سَبَقَ١ۚ وَ قَدْ اٰتَیْنٰكَ مِنْ لَّدُنَّا ذِكْرًاۖۚ كَذٰلِكَ : اسی طرح نَقُصُّ : ہم بیان کرتے ہیں عَلَيْكَ : تجھ پر۔ سے مِنْ : سے اَنْۢبَآءِ : خبریں، احوال مَا : جو قَدْ سَبَقَ : گزر چکا وَقَدْ اٰتَيْنٰكَ : اور تحقیق ہم نے تمہیں دیا مِنْ لَّدُنَّا : اپنے پاس سے ذِكْرًا : (کتاب) نصیحت اس طرح ہم تیرے سامنے (1) پہلے کی گزری ہوئی وارداتیں بیان فرما رہے ہیں اور یقیناً ہم تجھے اپنے پاس سے نصیحت عطا فرما چکے ہیں (2)۔
20,100,مَنْ اَعْرَضَ عَنْهُ فَاِنَّهٗ یَحْمِلُ یَوْمَ الْقِیٰمَةِ وِزْرًاۙ مَنْ : جس اَعْرَضَ : منہ پھیرا عَنْهُ : اس سے فَاِنَّهٗ : تو بیشک وہ يَحْمِلُ : لادے گا يَوْمَ الْقِيٰمَةِ : قیامت کے دن وِزْرًا : (بھاری) بوجھ اس سے جو منہ پھیر لے گا (1) وہ یقیناً قیامت کے دن اپنا بھاری بوجھ لادے ہوئے ہوگا (2)۔
20,101,خٰلِدِیْنَ فِیْهِ١ؕ وَ سَآءَ لَهُمْ یَوْمَ الْقِیٰمَةِ حِمْلًاۙ خٰلِدِيْنَ : وہ ہمیشہ رہیں گے فِيْهِ : اس میں وَسَآءَ : اور برا ہے لَهُمْ : ان کے لیے يَوْمَ الْقِيٰمَةِ : قیامت کے دن حِمْلًا : بوجھھ جس میں ہمیشہ رہے گا (1) اور ان کے لئے قیامت کے دن (بڑا) برا بوجھ ہے
20,102,یَّوْمَ یُنْفَخُ فِی الصُّوْرِ وَ نَحْشُرُ الْمُجْرِمِیْنَ یَوْمَئِذٍ زُرْقًاۚۖ يَّوْمَ : جس دن يُنْفَخُ : پھونک ماری جائیگی فِي الصُّوْرِ : صور میں وَنَحْشُرُ : اور ہم اکٹھا کرینگے الْمُجْرِمِيْنَ : مجرموں کو يَوْمَئِذٍ : اس دن زُرْقًا : نیلی آنکھیں جس دن صور پھونکا جائیگا (1) اور گناہ گاروں کو ہم اس دن (دہشت کی وجہ سے) نیلی پیلی آنکھوں کے ساتھ گھیر لائیں گے
20,103,یَّتَخَافَتُوْنَ بَیْنَهُمْ اِنْ لَّبِثْتُمْ اِلَّا عَشْرًا يَّتَخَافَتُوْنَ : آہستہ آہستہ کہیں گے بَيْنَهُمْ : آپس میں اِنْ : نہیں لَّبِثْتُمْ : رہے تم اِلَّا : مگر (صرف) عَشْرًا : دس دن وہ آپس میں چپکے چپکے کہہ رہے (1) ہونگے کہ ہم تو (دنیا میں) صرف دس دن ہی رہے۔
20,104,نَحْنُ اَعْلَمُ بِمَا یَقُوْلُوْنَ اِذْ یَقُوْلُ اَمْثَلُهُمْ طَرِیْقَةً اِنْ لَّبِثْتُمْ اِلَّا یَوْمًا۠    ۧ نَحْنُ : ہم اَعْلَمُ : خوب جانتے ہیں بِمَا : وہ جو يَقُوْلُوْنَ : وہ کہتے ہیں اِذْ يَقُوْلُ : جب کہے گا اَمْثَلُهُمْ : سب سے اچھی طَرِيْقَةً : راہ اِنْ : نہیں لَّبِثْتُمْ : رہے تم اِلَّا : مگر (صرف) يَوْمًا : ایک دن جو کچھ وہ کہہ رہے ہیں اس کی حقیقت سے ہم باخبر ہیں ان میں سب سے زیادہ اچھی رائے (1) والا کہہ رہا ہوگا کہ تم صرف ایک ہی دن دنیا میں رہے۔
20,105,وَ یَسْئَلُوْنَكَ عَنِ الْجِبَالِ فَقُلْ یَنْسِفُهَا رَبِّیْ نَسْفًاۙ وَيَسْئَلُوْنَكَ : اور وہ آپ سے دریافت کرینگے عَنِ الْجِبَالِ : پہاڑ کے متعلق فَقُلْ : تو کہ دیں يَنْسِفُهَا : انہیں بکھیر دیگا رَبِّيْ : میرا رب نَسْفًا : اڑا کر وہ آپ سے پہاڑوں کی نسبت سوال کرتے ہیں، تو آپ کہہ دیں کہ انھیں میرا رب ریزہ ریزہ کرکے اڑا دے گا۔
20,106,فَیَذَرُهَا قَاعًا صَفْصَفًاۙ فَيَذَرُهَا : پھر اسے چھوڑ دیگا قَاعًا : میدان صَفْصَفًا : ایک ہموار اور زمین کو بالکل ہموار صاف میدان کرکے چھوڑے گا۔
20,107,لَّا تَرٰى فِیْهَا عِوَجًا وَّ لَاۤ اَمْتًاؕ لَّا تَرٰى : نہ دیکھے گا تو فِيْهَا : اس میں عِوَجًا : کوئی کجی وَّلَآ : اور نہ اَمْتًا : کوئی بلندی جس میں تو نہ کہیں موڑ توڑ دیکھے گا، نہ اونچ نیچ۔
20,108,یَوْمَئِذٍ یَّتَّبِعُوْنَ الدَّاعِیَ لَا عِوَجَ لَهٗ١ۚ وَ خَشَعَتِ الْاَصْوَاتُ لِلرَّحْمٰنِ فَلَا تَسْمَعُ اِلَّا هَمْسًا يَوْمَئِذٍ : اس دن يَّتَّبِعُوْنَ : وہ سب پیچھے چلیں گے الدَّاعِيَ : ایک پکارنے والا لَا عِوَجَ : نہیں کوئی کجی لَهٗ : اس کے لیے وَخَشَعَتِ : اور پست ہوجائیں گی الْاَصْوَاتُ : آوازیں لِلرَّحْمٰنِ : اللہ کیلئے۔ سامنے فَلَا تَسْمَعُ : پس تو نہ سنے گا اِلَّا : مگر (صرف) هَمْسًا : آہستہ آواز جس دن لوگ پکارنے والے کے پیچھے چلیں (1) گے جس میں کوئی کجی نہ ہوگی (2) اور اللہ رحمٰن کے سامنے تمام آوازیں پست ہوجائیں گی سوائے کھسر پھسر کے تجھے کچھ بھی سنائی نہ دے گا (3)۔
20,109,یَوْمَئِذٍ لَّا تَنْفَعُ الشَّفَاعَةُ اِلَّا مَنْ اَذِنَ لَهُ الرَّحْمٰنُ وَ رَضِیَ لَهٗ قَوْلًا يَوْمَئِذٍ : اس دن لَّا تَنْفَعُ : نہ نفع دے گی الشَّفَاعَةُ : کوئی شفاعت اِلَّا : مگر مَنْ : جس اَذِنَ لَهُ : اجازت دے اس کو الرَّحْمٰنُ : اللہ وَرَضِيَ : اور پسند کرے لَهٗ : اس کی قَوْلًا : بات اس دن سفارش کچھ کام نہ آئیگی مگر جسے رحمٰن حکم دے اور اس کی بات کو پسند فرمائے (1)
20,110,یَعْلَمُ مَا بَیْنَ اَیْدِیْهِمْ وَ مَا خَلْفَهُمْ وَ لَا یُحِیْطُوْنَ بِهٖ عِلْمًا يَعْلَمُ : وہ جانتا ہے مَا : جو بَيْنَ اَيْدِيْهِمْ : ان کے ہاتھوں کے درمیان ( آگے) وَمَا : اور جو خَلْفَهُمْ : ان کے پیچھے وَلَا يُحِيْطُوْنَ : اور وہ احاطہ نہیں کرسکتے بِهٖ : اس کا عِلْمًا : علم کے اندر جو کچھ ان کے آگے پیچھے ہے اسے اللہ ہی جانتا ہے مخلوق کا علم اس پر حاوی نہیں ہوسکتا۔ (1)
20,111,وَ عَنَتِ الْوُجُوْهُ لِلْحَیِّ الْقَیُّوْمِ١ؕ وَ قَدْ خَابَ مَنْ حَمَلَ ظُلْمًا وَعَنَتِ : جھک جائیں گے الْوُجُوْهُ : چہرے لِلْحَيِّ : سامنے ” حی “ الْقَيُّوْمِ :” قیوم “ وَقَدْ خَابَ : اور نامراد ہوا مَنْ : جو۔ جس حَمَلَ : بوجھ اٹھایا ظُلْمًا : ظلم تمام چہرے اس زندہ اور قائم دائم اور مدبر، اللہ کے سامنے کمال عاجزی سے جھکے ہوئے ہونگے، یقیناً وہ برباد ہوا جس نے ظلم لاد لیا (1)
20,112,وَ مَنْ یَّعْمَلْ مِنَ الصّٰلِحٰتِ وَ هُوَ مُؤْمِنٌ فَلَا یَخٰفُ ظُلْمًا وَّ لَا هَضْمًا وَمَنْ : اور جو يَّعْمَلْ : کرے مِنَ : سے۔ کوئی الصّٰلِحٰتِ وَ : نیکی اور (بشرطیکہ) هُوَ : وہ مُؤْمِنٌ : مومن فَلَا يَخٰفُ : تو نہ اسے خوف ہوگا ظُلْمًا : کسی ظلم کا وَّلَا هَضْمًا : اور نہ کسی نقصان کا اور جو نیک اعمال کرے اور ایمان دار بھی ہو تو نہ اسے بےانصافی کا کھٹکا ہوگا نہ حق تلفی کا (1)
20,113,وَ كَذٰلِكَ اَنْزَلْنٰهُ قُرْاٰنًا عَرَبِیًّا وَّ صَرَّفْنَا فِیْهِ مِنَ الْوَعِیْدِ لَعَلَّهُمْ یَتَّقُوْنَ اَوْ یُحْدِثُ لَهُمْ ذِكْرًا وَكَذٰلِكَ : اور اسی طرح اَنْزَلْنٰهُ : ہم نے اس پر نازل کیا قُرْاٰنًا : قرآن عَرَبِيًّا : عربی وَّصَرَّفْنَا فِيْهِ : اور ہم نے طرح طرح سے بیان کیے اس میں مِنَ : سے الْوَعِيْدِ : ڈراوے لَعَلَّهُمْ : تاکہ وہ يَتَّقُوْنَ : پرہیزگار ہوجائیں اَوْ يُحْدِثُ : یا وہ پیدا کردے لَهُمْ : ان کے لیے ذِكْرًا : کوئی نصیحت اس طرح ہم نے تجھ پر عربی میں قرآن نازل فرمایا ہے اور طرح طرح سے اس میں ڈر کا بیان سنایا ہے تاکہ لوگ پرہیزگار بن (1) جائیں یا ان کے دل میں سوچ سمجھ تو پیدا کرے (2)
20,114,فَتَعٰلَى اللّٰهُ الْمَلِكُ الْحَقُّ١ۚ وَ لَا تَعْجَلْ بِالْقُرْاٰنِ مِنْ قَبْلِ اَنْ یُّقْضٰۤى اِلَیْكَ وَحْیُهٗ١٘ وَ قُلْ رَّبِّ زِدْنِیْ عِلْمًا فَتَعٰلَى اللّٰهُ : سو بلندو برتر ہے اللہ الْمَلِكُ : بادشاہ الْحَقُّ : سچا وَلَا : اور نہ تَعْجَلْ : جلدی کرو بِالْقُرْاٰنِ : قرآن میں مِنْ قَبْلِ : اس سے قبل کہ اَنْ : کہ يُّقْضٰٓى : پوری کی جائے اِلَيْكَ : پوری کی جائے وَحْيُهٗ : اس کی وحی وَقُلْ : اور کہیے رَّبِّ : اے میرے رب زِدْنِيْ : زیادہ دے مجھے عِلْمًا : علم پس اللہ عالی شان والا سچا اور حقیقی بادشاہ (1) ہے۔ تو قرآن پڑھنے میں جلدی نہ کر اس سے پہلے کہ تیری طرف جو وحی کی جاتی ہے وہ پوری کی جائے، (2) ہاں یہ دعا کر کہ پروردگار میرا علم بڑھا (3)
20,115,وَ لَقَدْ عَهِدْنَاۤ اِلٰۤى اٰدَمَ مِنْ قَبْلُ فَنَسِیَ وَ لَمْ نَجِدْ لَهٗ عَزْمًا۠    ۧ وَلَقَدْ عَهِدْنَآ : اور ہم نے حکم بھیجا اِلٰٓى : طرف۔ کو اٰدَمَ : آدم مِنْ قَبْلُ : اس سے قبل فَنَسِيَ : تو وہ بھول گیا وَلَمْ نَجِدْ : اور ہم نے نہ پایا لَهٗ : اس میں عَزْمًا : پختہ ارادہ ہم نے آدم کو پہلے تاکیدی حکم دے دیا تھا لیکن وہ بھول گیا اور ہم نے اس میں کوئی عزم نہیں پایا (1)
20,116,وَ اِذْ قُلْنَا لِلْمَلٰٓئِكَةِ اسْجُدُوْا لِاٰدَمَ فَسَجَدُوْۤا اِلَّاۤ اِبْلِیْسَ١ؕ اَبٰى وَاِذْ : اور (یاد کرو) جب قُلْنَا : ہم نے کہا لِلْمَلٰٓئِكَةِ : فرشتوں کو اسْجُدُوْا : تم سجدہ کرو لِاٰدَمَ : آدم کو فَسَجَدُوْٓا : تو سب نے سجدہ کیا اِلَّآ : سوائے اِبْلِيْسَ : ابلیس اَبٰى : اس نے انکار کیا اور جب ہم نے فرشتوں سے کہا کہ آدم ؑ کو سجدہ کرو تو ابلیس کے سوا سب نے کیا۔ اس نے صاف انکار کردیا۔
20,117,فَقُلْنَا یٰۤاٰدَمُ اِنَّ هٰذَا عَدُوٌّ لَّكَ وَ لِزَوْجِكَ فَلَا یُخْرِجَنَّكُمَا مِنَ الْجَنَّةِ فَتَشْقٰى فَقُلْنَا : پس ہم نے کہا يٰٓاٰدَمُ : اے آدم اِنَّ : بیشک ھٰذَا : یہ عَدُوٌّ : دشمن لَّكَ : تمہارا وَلِزَوْجِكَ : اور تمہاری بیوی کا فَلَا : سو تمہیں يُخْرِجَنَّكُمَا : نہ نکلوا دے مِنَ الْجَنَّةِ : جنت سے فَتَشْقٰي : پھر تم مصیبت میں پڑجاؤ تو ہم نے کہا اے آدم ! یہ تیرا اور تیری بیوی کا دشمن ہے (خیال رکھنا) ایسا نہ ہو کہ وہ تم دونوں کو جنت سے نکلوا دے کہ تو مصیبت میں پڑجائے (1)
20,118,اِنَّ لَكَ اَلَّا تَجُوْعَ فِیْهَا وَ لَا تَعْرٰىۙ اِنَّ : بیشک لَكَ : تمہارے لیے اَلَّا تَجُوْعَ : یہ کہ نہ بھوکے رہو فِيْهَا : اس میں وَلَا : اور نہ تَعْرٰى : ننگے یہاں تو تجھے یہ آرام ہے کہ نہ تو بھوکا ہوتا ہے نہ ننگا۔
20,119,وَ اَنَّكَ لَا تَظْمَؤُا فِیْهَا وَ لَا تَضْحٰى وَاَنَّكَ : اور یہ کہ تم لَا : نہ تَظْمَؤُا : پیاسے رہو گے فِيْهَا : اس میں وَلَا تَضْحٰي : اور نہ دھوپ میں رہو گے اور نہ تو یہاں پیاسا ہوتا ہے نہ دھوپ سے تکلیف اٹھاتا ہے۔
20,120,فَوَسْوَسَ اِلَیْهِ الشَّیْطٰنُ قَالَ یٰۤاٰدَمُ هَلْ اَدُلُّكَ عَلٰى شَجَرَةِ الْخُلْدِ وَ مُلْكٍ لَّا یَبْلٰى فَوَسْوَسَ : پھر وسوسہ ڈالا اِلَيْهِ : اسکی طرف (دل میں) الشَّيْطٰنُ : شیطان قَالَ : اس نے کہا يٰٓاٰدَمُ : اے آدم هَلْ : کیا اَدُلُّكَ : میں تیری رہنمائی کروں عَلٰي : پر شَجَرَةِ : درخت الْخُلْدِ : ہمیشگی وَمُلْكٍ : اور بادشاہت لَّا يَبْلٰى : نہ پرانی (زوال پذیر) ہو) لیکن شیطان نے وسوسہ ڈالا، کہنے لگا کہ کیا میں تجھے دائمی زندگی کا درخت اور بادشاہت بتلاؤں کہ جو کبھی پرانی نہ ہو
20,121,فَاَكَلَا مِنْهَا فَبَدَتْ لَهُمَا سَوْاٰتُهُمَا وَ طَفِقَا یَخْصِفٰنِ عَلَیْهِمَا مِنْ وَّرَقِ الْجَنَّةِ١٘ وَ عَصٰۤى اٰدَمُ رَبَّهٗ فَغَوٰى۪ۖ فَاَكَلَا : پس دونوں نے کھایا مِنْهَا : اس سے فَبَدَتْ : تو ظاہر ہوگئیں لَهُمَا : ان پر سَوْاٰتُهُمَا : ان کی شرم گاہیں وَ : اور طَفِقَا يَخْصِفٰنِ : وہ دونوں لگے جوڑنے (ڈھانپنے) عَلَيْهِمَا : اپنے اوپر مِنْ : سے وَّرَقِ الْجَنَّةِ : جنت کے پتے وَعَصٰٓى : اور نافرمانی کی اٰدَمُ : آدم رَبَّهٗ : اپنا رب فَغَوٰى : تو وہ بہک گیا چناچہ ان دونوں نے اس درخت سے کچھ کھالیا پس ان کے ستر کھل گئے اور بہشت کے پتے اپنے اوپر ٹانکنے لگے۔ آدم ؑ نے اپنے رب کی نافرمانی کی پس بہک گیا (1)
20,122,ثُمَّ اجْتَبٰهُ رَبُّهٗ فَتَابَ عَلَیْهِ وَ هَدٰى ثُمَّ : پھر اجْتَبٰىهُ : اس کو چن لیا رَبُّهٗ : اس کا رب فَتَابَ : توجہ فرمائی عَلَيْهِ : اس پر وَهَدٰى : اور اسے راہ دکھائی پھر اس کے رب نے نوازا، اس کی توبہ قبول کی اور اس کی راہنمائی کی (1)
20,123,قَالَ اهْبِطَا مِنْهَا جَمِیْعًۢا بَعْضُكُمْ لِبَعْضٍ عَدُوٌّ١ۚ فَاِمَّا یَاْتِیَنَّكُمْ مِّنِّیْ هُدًى١ۙ۬ فَمَنِ اتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَ لَا یَشْقٰى قَالَ : فرمایا اهْبِطَا : تم دونوں اتر جاؤ مِنْهَا : یہاں سے جَمِيْعًۢا : سب بَعْضُكُمْ : تم میں سے بعض لِبَعْضٍ : بعض کے عَدُوٌّ : دشمن فَاِمَّا : پس اگر يَاْتِيَنَّكُمْ : تمہارے پاس آئے مِّنِّيْ : میری طرف سے هُدًى : ہدایت فَمَنِ : تو جس نے اتَّبَعَ : پیروی کی هُدَايَ : میری ہدایت فَلَا يَضِلُّ : تو نہ وہ گمراہ ہوگا وَ : اور لَا يَشْقٰي : نہ بدبخت ہوگا فرمایا، تم دونوں یہاں سے اتر جاؤ تم آپس میں ایک دوسرے کے دشمن ہو، اب تمہارے پاس جب کبھی میری طرف سے ہدایت پہنچے تو میری ہدایت کی پیروی کرے نہ تو وہ بہکے گا نہ تکلیف میں پڑے گا۔
20,124,وَ مَنْ اَعْرَضَ عَنْ ذِكْرِیْ فَاِنَّ لَهٗ مَعِیْشَةً ضَنْكًا وَّ نَحْشُرُهٗ یَوْمَ الْقِیٰمَةِ اَعْمٰى وَمَنْ : اور جس اَعْرَضَ : منہ موڑا عَنْ : سے ذِكْرِيْ : میرے ذکر۔ نصیحت فَاِنَّ : تو بیشک لَهٗ : اس کے لیے مَعِيْشَةً : گزران ضَنْكًا : تنگ وَّنَحْشُرُهٗ : اور ہم اسے اٹھائیں گے يَوْمَ الْقِيٰمَةِ : قیامت کے دن اَعْمٰى : اندھا اور (ہاں) جو میری یاد سے روگردانی کرے گا اس کی زندگی تنگی میں رہے گی، (1) اور ہم اسے بروز قیامت اندھا کرکے اٹھائیں گے (2)
20,125,قَالَ رَبِّ لِمَ حَشَرْتَنِیْۤ اَعْمٰى وَ قَدْ كُنْتُ بَصِیْرًا قَالَ : وہ کہے گا رَبِّ : اے میرے رب لِمَ حَشَرْتَنِيْٓ : تونے مجھے کیوں اٹھایا اَعْمٰي : اندھا وَ : اندھا قَدْ كُنْتُ : میں تو تھا بَصِيْرًا : دیکھتا۔ بینا وہ کہے گا کہ الٰہی ! مجھے تو نے اندھا بنا کر کیوں اٹھایا ؟ حالانکہ میں تو دیکھتا بھالتا تھا۔
20,126,قَالَ كَذٰلِكَ اَتَتْكَ اٰیٰتُنَا فَنَسِیْتَهَا١ۚ وَ كَذٰلِكَ الْیَوْمَ تُنْسٰى قَالَ : وہ فرمائے گا كَذٰلِكَ : اسی طرح اَتَتْكَ : تیرے پاس آئیں اٰيٰتُنَا : ہماری آیات فَنَسِيْتَهَا : تو تونے انہیں بھلایا وَكَذٰلِكَ : اور اسی طرح الْيَوْمَ : آج تُنْسٰى : ہم تجھے بھلا دیں گے (جواب ملے گا کہ) اسی طرح ہونا چاہیے تھا تو میری آئی ہوئی آیتوں کو بھول گیا تو آج تو بھی بھلا دیا جاتا ہے
20,127,وَ كَذٰلِكَ نَجْزِیْ مَنْ اَسْرَفَ وَ لَمْ یُؤْمِنْۢ بِاٰیٰتِ رَبِّهٖ١ؕ وَ لَعَذَابُ الْاٰخِرَةِ اَشَدُّ وَ اَبْقٰى وَكَذٰلِكَ : اور اسی طرح نَجْزِيْ : ہم بدلہ دیتے ہیں مَنْ : جو اَسْرَفَ : حد سے نکل جائے وَلَمْ يُؤْمِنْ : اور نہ ایمان لائے بِاٰيٰتِ : آیتوں پر رَبِّهٖ : اپنا رب وَلَعَذَابُ : اور البتہ عذاب الْاٰخِرَةِ : آخرت اَشَدُّ : شدید ترین وَاَبْقٰي : اور زیادہ دیر تک رہنے والا ہے ہم ایسا ہی بدلہ ہر اس شخص کو دیا کرتے ہیں جو حد سے گزر جائے اور اپنے رب کی آیتوں پر ایمان نہ لائے، اور بیشک آخرت کا عذاب نہایت ہی سخت اور باقی رہنے والا ہے۔
20,128,اَفَلَمْ یَهْدِ لَهُمْ كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنَ الْقُرُوْنِ یَمْشُوْنَ فِیْ مَسٰكِنِهِمْ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّاُولِی النُّهٰى۠    ۧ اَفَلَمْ يَهْدِ : کیا ہدایت نہ دی لَهُمْ : انہیں كَمْ : کتنی ہی اَهْلَكْنَا : ہم نے ہلاک کردیں قَبْلَهُمْ : ان سے قبل مِّنَ الْقُرُوْنِ : قومیں۔ جماعتیں يَمْشُوْنَ : وہ چلتے پھرتے ہیں فِيْ مَسٰكِنِهِمْ : ان کے مساکن میں اِنَّ : بیشک فِيْ : میں ذٰلِكَ : اس لَاٰيٰتٍ : البتہ نشانیاں ہیں لِّاُولِي النُّهٰى : عقل والوں کے لیے کیا ان کی رہبری اس بات نے بھی نہیں کی کہ ہم نے ان سے پہلے بہت سی بستیاں ہلاک کردی ہیں جن کے رہنے سہنے کی جگہ یہ چل پھر رہے ہیں۔ یقیناً اس میں عقلمندوں کے لئے بہت سی نشانیاں ہیں۔
20,129,وَ لَوْ لَا كَلِمَةٌ سَبَقَتْ مِنْ رَّبِّكَ لَكَانَ لِزَامًا وَّ اَجَلٌ مُّسَمًّىؕ وَلَوْ : اور اگر لَا كَلِمَةٌ : نہ ہوتی ایک بات سَبَقَتْ : ہوچکی مِنْ : سے رَّبِّكَ : تمہارا رب لَكَانَ : تو ضرور آجاتا لِزَامًا : عذاب وَّاَجَلٌ : اور میعاد مُّسَمًّى : مقرر اگر تیرے رب کی بات پہلے ہی سے مقرر شدہ اور وقت معین کردہ نہ ہوتا تو اسی وقت عذاب آچمٹتا (1)۔
20,130,فَاصْبِرْ عَلٰى مَا یَقُوْلُوْنَ وَ سَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوْعِ الشَّمْسِ وَ قَبْلَ غُرُوْبِهَا١ۚ وَ مِنْ اٰنَآئِ الَّیْلِ فَسَبِّحْ وَ اَطْرَافَ النَّهَارِ لَعَلَّكَ تَرْضٰى فَاصْبِرْ : پس صبر کریں عَلٰي : پر مَا يَقُوْلُوْنَ : جو وہ کہتے ہیں وَسَبِّحْ : اور تسبیح کریں بِحَمْدِ : تعریف کے ساتھ رَبِّكَ : اپنا رب قَبْلَ : پہلے طُلُوْعِ الشَّمْسِ : طلوعِ آفتاب وَقَبْلَ : اور پہلے غُرُوْبِهَا : اس کے غروب وَمِنْ : اور کچھ اٰنَآئِ الَّيْلِ : رات کی گھڑیاں فَسَبِّحْ : پس تسبیح کریں وَاَطْرَافَ : اور کنارے النَّهَارِ : دن لَعَلَّكَ : تاکہ تم تَرْضٰى : خوش ہوجاؤ پس ان کی باتوں پر صبر کر اور اپنے پروردگار کی تسبیح اور تعریف بیان کرتا رہ، سورج نکلنے سے پہلے اور اس کے ڈوبنے سے پہلے، رات کے مختلف وقتوں میں بھی اور دن کے حصوں میں بھی تسبیح کرتا رہ (1) بہت ممکن ہے کہ تو راضی ہوجائے (2)
20,131,وَ لَا تَمُدَّنَّ عَیْنَیْكَ اِلٰى مَا مَتَّعْنَا بِهٖۤ اَزْوَاجًا مِّنْهُمْ زَهْرَةَ الْحَیٰوةِ الدُّنْیَا١ۙ۬ لِنَفْتِنَهُمْ فِیْهِ١ؕ وَ رِزْقُ رَبِّكَ خَیْرٌ وَّ اَبْقٰى وَ : اور لَا تَمُدَّنَّ : نہ پھیلانا عَيْنَيْكَ : اپنی آنکھیں اِلٰى : طرف مَا مَتَّعْنَا : جو ہم نے برتنے کو دیا بِهٖٓ : اس سے اَزْوَاجًا : جوڑے مِّنْهُمْ : ان سے۔ کے زَهْرَةَ : آرائش الْحَيٰوةِ الدُّنْيَا : دنیا کی زندگی لِنَفْتِنَهُمْ : تاکہ ہم انہیں آزمائیں فِيْهِ : اس میں وَرِزْقُ : اور عطیہ رَبِّكَ : تیرا رب خَيْرٌ : بہتر وَّاَبْقٰي : اور تادیر رہنے والا اور اپنی نگاہیں ہرگز چیزوں کی طرف نہ دوڑانا جو ہم نے ان میں سے مختلف لوگوں کو آرائش دنیا کی دے رکھی ہیں تاکہ انھیں اس میں آزمالیں (1) تیرے رب کا دیا ہوا ہی (بہت) بہتر اور بہت باقی رہنے والا ہے (2)۔
20,132,وَ اْمُرْ اَهْلَكَ بِالصَّلٰوةِ وَ اصْطَبِرْ عَلَیْهَا١ؕ لَا نَسْئَلُكَ رِزْقًا١ؕ نَحْنُ نَرْزُقُكَ١ؕ وَ الْعَاقِبَةُ لِلتَّقْوٰى وَاْمُرْ : اور حکم دو تم اَهْلَكَ : اپنے گھر والے بِالصَّلٰوةِ : نماز کا وَاصْطَبِرْ : اور قائم رہو عَلَيْهَا : اس پر لَا نَسْئَلُكَ : ہم تجھ سے نہیں مانگتے رِزْقًا : رزق نَحْنُ : ہم نَرْزُقُكَ : تجھے رزق دیتے ہیں وَالْعَاقِبَةُ : اور انجام لِلتَّقْوٰى : اہل تقویٰ کے لیے اپنے گھرانے کے لوگوں پر نماز کی تاکید رکھ اور خود بھی اس پر جما رہ (1) ہم تجھ سے روزی نہیں مانگتے، بلکہ ہم خود تجھے روزی دیتے ہیں، آخر میں بول بالا پرہیزگاری ہی کا ہے۔
20,133,وَ قَالُوْا لَوْ لَا یَاْتِیْنَا بِاٰیَةٍ مِّنْ رَّبِّهٖ١ؕ اَوَ لَمْ تَاْتِهِمْ بَیِّنَةُ مَا فِی الصُّحُفِ الْاُوْلٰى وَقَالُوْا : اور وہ کہتے ہیں لَوْ : کیوں لَا يَاْتِيْنَا : نہیں لاتے بِاٰيَةٍ : کوئی نشانی مِّنْ : سے رَّبِّهٖ : اپنا رب اَوَ : کیا لَمْ تَاْتِهِمْ : ان کے پاس نہیں آئی بَيِّنَةُ : واضح نشانی مَا : جو فِي : میں الصُّحُفِ : صحیفے الْاُوْلٰى : پہلے انہوں نے کہا کہ یہ نبی ہمارے پاس اپنے پروردگار کی طرف سے کوئی نشانی کیوں نہیں لایا ؟ (1) کیا ان کے پاس اگلی کتابوں کی واضح دلیل نہیں پہنچی ؟ (2)
20,134,وَ لَوْ اَنَّاۤ اَهْلَكْنٰهُمْ بِعَذَابٍ مِّنْ قَبْلِهٖ لَقَالُوْا رَبَّنَا لَوْ لَاۤ اَرْسَلْتَ اِلَیْنَا رَسُوْلًا فَنَتَّبِعَ اٰیٰتِكَ مِنْ قَبْلِ اَنْ نَّذِلَّ وَ نَخْزٰى وَلَوْ : اور اگر اَنَّآ : ہم اَهْلَكْنٰهُمْ : انہیں ہلاک کردیتے بِعَذَابٍ : کسی عذاب سے مِّنْ قَبْلِهٖ : اس سے قبل لَقَالُوْا : تو وہ کہتے رَبَّنَا لَوْ : اے ہمارے رب کیوں لَآ اَرْسَلْتَ : تونے نہ بھیجا اِلَيْنَا : ہماری طرف رَسُوْلًا : کوئی رسول فَنَتَّبِعَ : تو ہم پیروی کرتے اٰيٰتِكَ : تیرے احکام مِنْ قَبْلِ : اس سے قبل اَنْ نَّذِلَّ : کہ ہم ذلیل ہوں وَنَخْزٰى : اور ہم رسوا ہوں اور ہم اس سے پہلے (1) ہی انھیں عذاب سے ہلاک کردیتے تو یقیناً یہ کہہ اٹھتے کہ اے ہمارے پروردگار تو نے ہمارے پاس اپنا رسول کیوں نہ بھیجا ؟ کہ ہم تیری آیتوں کی تابعداری کرتے اس سے پہلے کہ ہم ذلیل و رسوا ہوتے۔
20,135,قُلْ كُلٌّ مُّتَرَبِّصٌ فَتَرَبَّصُوْا١ۚ فَسَتَعْلَمُوْنَ مَنْ اَصْحٰبُ الصِّرَاطِ السَّوِیِّ وَ مَنِ اهْتَدٰى۠    ۧ قُلْ : آپ کہ دیں كُلٌّ : سب مُّتَرَبِّصٌ : منتظر ہیں فَتَرَبَّصُوْا : پس تم انتظار کرو فَسَتَعْلَمُوْنَ : سو عنقریب تم جان لو گے مَنْ : کون اَصْحٰبُ : والے الصِّرَاطِ : راستہ السَّوِيِّ : سیدھا وَمَنِ : اور کون اهْتَدٰى : اس نے ہدایت پائی کہہ دیجئے ! ہر ایک انجام کا منتظر (1) ہے پس تم بھی انتظار میں رہو۔ ابھی ابھی قطعاً جان لو گے کہ راہ راست والے کون ہیں اور کون راہ یافتہ ہیں (2)۔
