tafsir[9]{c,v,t}:
  39,32,فَمَنْ اَظْلَمُ مِمَّنْ كَذَبَ عَلَى اللّٰهِ وَ كَذَّبَ بِالصِّدْقِ اِذْ جَآءَهٗ١ؕ اَلَیْسَ فِیْ جَهَنَّمَ مَثْوًى لِّلْكٰفِرِیْنَ فَمَنْ : پس کون اَظْلَمُ : بڑا ظالم مِمَّنْ : سے ۔ جس كَذَبَ : جھوٹ باندھا عَلَي : پر اللّٰهِ : اللہ وَكَذَّبَ : اور اس نے جھٹلایا بِالصِّدْقِ : سچائی کو اِذْ : جب جَآءَهٗ ۭ : وہ اس کے پاس آئے اَلَيْسَ : کیا نہیں فِيْ جَهَنَّمَ : جہنم میں مَثْوًى : ٹھکانا لِّلْكٰفِرِيْنَ : کافروں کے لیے اس سے بڑھ کر ظالم کون ہے جو اللہ تعالیٰ پر جھوٹ بولے ؟ (1) اور سچا دین جب اس کے پاس آئے تو اسے جھوٹا بتائے ؟ (2) کیا ایسے کفار کے لئے جہنم ٹھکانا نہیں ہے ؟
  39,33,وَ الَّذِیْ جَآءَ بِالصِّدْقِ وَ صَدَّقَ بِهٖۤ اُولٰٓئِكَ هُمُ الْمُتَّقُوْنَ وَالَّذِيْ : اور جو شخص جَآءَ : آیا بِالصِّدْقِ : سچائی کے ساتھ وَصَدَّقَ : اور اس نے تصدیق کی بِهٖٓ : اس کو اُولٰٓئِكَ : یہی لوگ هُمُ : وہ الْمُتَّقُوْنَ : (جمع) متقی اور جو سچے دین کو لائے (1) اور جس نے اس کی تصدیق کی (2) یہی لوگ پارسا ہیں۔
  39,34,لَهُمْ مَّا یَشَآءُوْنَ عِنْدَ رَبِّهِمْ١ؕ ذٰلِكَ جَزٰٓؤُا الْمُحْسِنِیْنَۚۖ لَهُمْ : ان کے لیے مَّا يَشَآءُوْنَ : جو وہ چاہیں گے عِنْدَ : ہاں۔ پاس رَبِّهِمْ ۭ : ان کا رب ذٰلِكَ : یہ جَزَآءُ : جزا الْمُحْسِنِيْنَ : (جمع) نیکوکاروں ان کے لئے ان کے رب کے پاس ہر وہ چیز ہے جو یہ چاہیں، (1) نیک لوگوں کا یہی بدلہ ہے۔ (2)
  39,35,لِیُكَفِّرَ اللّٰهُ عَنْهُمْ اَسْوَاَ الَّذِیْ عَمِلُوْا وَ یَجْزِیَهُمْ اَجْرَهُمْ بِاَحْسَنِ الَّذِیْ كَانُوْا یَعْمَلُوْنَ لِيُكَفِّرَ : تاکہ دور کردے اللّٰهُ : اللہ عَنْهُمْ : ان سے اَسْوَاَ : برائی الَّذِيْ : وہ جو عَمِلُوْا : انہوں نے کیے (اعمال) وَيَجْزِيَهُمْ : اور انہیں جزا دے اَجْرَهُمْ : ان کا اجر بِاَحْسَنِ : بہترین (اعمال) الَّذِيْ : وہ جو كَانُوْا يَعْمَلُوْنَ : وہ کرتے تھے تاکہ اللہ تعالیٰ ان سے ان کے برے عملوں کو دور کر دے اور جو نیک کام انہوں نے کئے ہیں ان کا اچھا بدلہ عطا فرمائے۔
  39,36,اَلَیْسَ اللّٰهُ بِكَافٍ عَبْدَهٗ١ؕ وَ یُخَوِّفُوْنَكَ بِالَّذِیْنَ مِنْ دُوْنِهٖ١ؕ وَ مَنْ یُّضْلِلِ اللّٰهُ فَمَا لَهٗ مِنْ هَادٍۚ اَلَيْسَ : کیا نہیں اللّٰهُ : اللہ بِكَافٍ : کافی عَبْدَهٗ ۭ : اپنے بندے کو وَيُخَوِّفُوْنَكَ : اور وہ خوف دلاتے ہیں آپ کو بِالَّذِيْنَ : ان سے جو مِنْ دُوْنِهٖ ۭ : اس کے سوا وَمَنْ : اور جس يُّضْلِلِ : گمراہ کردے اللّٰهُ : اللہ فَمَا لَهٗ : تو نہیں اس کے لیے مِنْ : کوئی هَادٍ : ہدایت دینے والا کیا اللہ تعالیٰ اپنے بندے کے لئے کافی نہیں ؟ (1) یہ لوگ آپ کو اللہ کے سوا اوروں سے ڈرا رہے ہیں اور جسے اللہ گمراہ کردے اس کی رہنمائی کرنے والا کوئی نہیں (2)
  39,37,وَ مَنْ یَّهْدِ اللّٰهُ فَمَا لَهٗ مِنْ مُّضِلٍّ١ؕ اَلَیْسَ اللّٰهُ بِعَزِیْزٍ ذِی انْتِقَامٍ وَمَنْ : اور جس يَّهْدِ اللّٰهُ : اللہ ہدایت دے فَمَا : تو نہیں لَهٗ : اس کے لیے مِنْ : کوئی مُّضِلٍّ ۭ : گمراہ کرنے والا اَلَيْسَ : کیا نہیں اللّٰهُ : اللہ بِعَزِيْزٍ : غالب ذِي انْتِقَامٍ : بدلہ لینے والا اور جسے وہ ہدایت دے اسے کوئی گمراہ کرنے والا نہیں (1) کیا اللہ تعالیٰ غالب اور بدلہ لینے والا نہیں ہے ؟ (2)۔
  39,38,وَ لَئِنْ سَاَلْتَهُمْ مَّنْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ لَیَقُوْلُنَّ اللّٰهُ١ؕ قُلْ اَفَرَءَیْتُمْ مَّا تَدْعُوْنَ مِنْ دُوْنِ اللّٰهِ اِنْ اَرَادَنِیَ اللّٰهُ بِضُرٍّ هَلْ هُنَّ كٰشِفٰتُ ضُرِّهٖۤ اَوْ اَرَادَنِیْ بِرَحْمَةٍ هَلْ هُنَّ مُمْسِكٰتُ رَحْمَتِهٖ١ؕ قُلْ حَسْبِیَ اللّٰهُ١ؕ عَلَیْهِ یَتَوَكَّلُ الْمُتَوَكِّلُوْنَ وَلَئِنْ : اور اگر سَاَلْتَهُمْ : تم پوچھو ان سے مَّنْ : کون۔ کس خَلَقَ : پیدا کیا السَّمٰوٰتِ : آسمانوں وَالْاَرْضَ : اور زمین لَيَقُوْلُنَّ : تو وہ ضرور کہیں گے اللّٰهُ ۭ : اللہ قُلْ : فرمادیں اَفَرَءَيْتُمْ : کیا پس دیکھا تم نے مَّا تَدْعُوْنَ : جن کو تم پکارتے ہو مِنْ : سے دُوْنِ اللّٰهِ : اللہ کے سوائے اِنْ : اگر اَرَادَنِيَ : چاہے میرے لیے اللّٰهُ : اللہ بِضُرٍّ : کوئی ضرر هَلْ : کیا هُنَّ : وہ سب كٰشِفٰتُ : دور کرنے والے ہیں ضُرِّهٖٓ : اس کا ضرر اَوْ : یا اَرَادَنِيْ : وہ چاہے میرے لیے بِرَحْمَةٍ : کوئی رحمت هَلْ : کیا هُنَّ : وہ سب مُمْسِكٰتُ : روکنے والے ہیں رَحْمَتِهٖ ۭ : اس کی رحمت قُلْ : فرما دیں حَسْبِيَ اللّٰهُ ۭ : کافی ہے میرے لیے اللہ عَلَيْهِ : اس پر يَتَوَكَّلُ : بھروسہ کرتے ہیں الْمُتَوَكِّلُوْنَ : بھروسہ کرنے والے اگر آپ ان سے پوچھیں کہ آسمان و زمین کو کس نے پیدا کیا ہے ؟ تو یقیناً وہ یہی جواب دیں گے کہ اللہ نے۔ آپ ان سے کہئے کہ اچھا یہ تو بتاؤ جنہیں تم اللہ کے سوا پکارتے ہو اگر اللہ تعالیٰ مجھے نقصان پہنچانا چاہے تو کیا یہ اس کے نقصان کو ہٹا سکتے ہیں ؟ یا اللہ تعالیٰ مجھ پر مہربانی کا ارادہ کرے تو کیا یہ اس کی مہربانی کو روک سکتے ہیں ؟ آپ کہہ دیں کہ اللہ مجھے کافی ہے (1) توکل کرنے والے اسی پر توکل کرتے ہیں (2)۔
  39,39,قُلْ یٰقَوْمِ اعْمَلُوْا عَلٰى مَكَانَتِكُمْ اِنِّیْ عَامِلٌ١ۚ فَسَوْفَ تَعْلَمُوْنَۙ قُلْ : فرمادیں يٰقَوْمِ : اے میری قوم اعْمَلُوْا : تم کام کیے جاؤ عَلٰي : پر مَكَانَتِكُمْ : اپنی جگہ اِنِّىْ : بیشک میں عَامِلٌ ۚ : کام کرتا ہوں فَسَوْفَ : پس عنقریب تَعْلَمُوْنَ : تم جان لو گے کہہ دیجئے کہ اے میری قوم ! تم اپنی جگہ پر عمل کئے جاؤ میں بھی عمل کر رہا ہوں (1) ابھی ابھی تم جان لو گے۔
  39,40,مَنْ یَّاْتِیْهِ عَذَابٌ یُّخْزِیْهِ وَ یَحِلُّ عَلَیْهِ عَذَابٌ مُّقِیْمٌ مَنْ : کون يَّاْتِيْهِ : آتا ہے اس پر عَذَابٌ : عذاب يُّخْزِيْهِ : رسوا کردے اس کو وَيَحِلُّ : اور اتر آتا ہے عَلَيْهِ : اس پر عَذَابٌ : عذاب مُّقِيْمٌ : دائمی کہ کس پر رسوا کرنے والا عذاب آتا ہے (1) اور کس پر دائمی مار اور ہمیشگی کی سزا ہوتی ہے (2)
