tafsir[12]{c,v,t}:
  16,15,وَ اَلْقٰى فِی الْاَرْضِ رَوَاسِیَ اَنْ تَمِیْدَ بِكُمْ وَ اَنْهٰرًا وَّ سُبُلًا لَّعَلَّكُمْ تَهْتَدُوْنَۙ وَاَلْقٰى : اور ڈالے (رکھے) فِي الْاَرْضِ : زمین میں۔ پر رَوَاسِيَ : پہاڑ اَنْ تَمِيْدَ : کہ جھک نہ پڑے بِكُمْ : تمہیں لے کر وَاَنْهٰرًا : اور نہریں دریا وَّسُبُلًا : اور راستے لَّعَلَّكُمْ : تاکہ تم تَهْتَدُوْنَ : راہ پاؤ اور اس نے زمین میں پہاڑ گاڑ دیئے ہیں تاکہ تمہیں لے کر ہلے نہ (1) اور نہریں اور راہیں بنادیں تاکہ تم منزل مقصود کو پہنچو (2)۔
  16,16,وَ عَلٰمٰتٍ١ؕ وَ بِالنَّجْمِ هُمْ یَهْتَدُوْنَ وَعَلٰمٰتٍ : اور علامتیں وَبِالنَّجْمِ : اور ستارہ هُمْ : وہ يَهْتَدُوْنَ : راستہ پاتے ہیں اور بھی بہت سی نشانیاں مقرر فرمائیں اور ستاروں سے بھی لوگ راہ حاصل کرتے ہیں۔
  16,17,اَفَمَنْ یَّخْلُقُ كَمَنْ لَّا یَخْلُقُ١ؕ اَفَلَا تَذَكَّرُوْنَ اَفَمَنْ : کیا۔ پس جو يَّخْلُقُ : پیدا کرے كَمَنْ : اس جیسا جو لَّا يَخْلُقُ : پیدا نہیں کرتا اَفَلَا تَذَكَّرُوْنَ : کیا۔ پس تم غور نہیں کرتے تو کیا وہ جو پیدا کرتا ہے اس جیسا ہے جو پیدا نہیں کرسکتا ؟ کیا تم بالکل نہیں سوچتے (1)۔
  16,18,وَ اِنْ تَعُدُّوْا نِعْمَةَ اللّٰهِ لَا تُحْصُوْهَا١ؕ اِنَّ اللّٰهَ لَغَفُوْرٌ رَّحِیْمٌ وَاِنْ : اور اگر تَعُدُّوْا : تم شمار کرو نِعْمَةَ اللّٰهِ : اللہ کی نعمت لَا تُحْصُوْهَا : اس کو پورا نہ گن سکو گے اِنَّ اللّٰهَ : بیشک اللہ لَغَفُوْرٌ : البتہ بخشنے والا رَّحِيْمٌ : نہایت مہربان اور اگر تم اللہ کی نعمتوں کا شمار کرنا چاہو تو تم اسے نہیں کرسکتے۔ بیشک اللہ بڑا بخشنے والا مہربان ہے
  16,19,وَ اللّٰهُ یَعْلَمُ مَا تُسِرُّوْنَ وَ مَا تُعْلِنُوْنَ وَاللّٰهُ : اور اللہ يَعْلَمُ : جانتا ہے مَا تُسِرُّوْنَ : جو تم چھپاتے ہو وَمَا : اور جو تُعْلِنُوْنَ : تم ظاہر کرتے ہو اور جو کچھ تم چھپاؤ اور ظاہر کرو اللہ تعالیٰ سب کچھ جانتا ہے (1)۔
  16,20,وَ الَّذِیْنَ یَدْعُوْنَ مِنْ دُوْنِ اللّٰهِ لَا یَخْلُقُوْنَ شَیْئًا وَّ هُمْ یُخْلَقُوْنَؕ وَالَّذِيْنَ : اور جنہیں يَدْعُوْنَ : وہ پکارتے ہیں مِنْ دُوْنِ : سوائے اللّٰهِ : اللہ لَا يَخْلُقُوْنَ : وہ پیدا نہیں کرتے شَيْئًا : کچھ بھی وَّهُمْ : اور وہ (خود) يُخْلَقُوْنَ : پیدا کیے گئے اور جن جن کو یہ لوگ اللہ تعالیٰ کے سوا پکارتے ہیں وہ کسی چیز کو پیدا نہیں کرسکتے، بلکہ وہ خود پیدا کیئے ہوئے ہیں (1)۔
  16,21,اَمْوَاتٌ غَیْرُ اَحْیَآءٍ١ۚ وَ مَا یَشْعُرُوْنَ١ۙ اَیَّانَ یُبْعَثُوْنَ۠    ۧ اَمْوَاتٌ : مردے غَيْرُ : نہیں اَحْيَآءٍ : زندہ وَمَا يَشْعُرُوْنَ : اور وہ نہیں جانتے اَيَّانَ : کب يُبْعَثُوْنَ : وہ اٹھائے جائیں گے مردے ہیں زندہ نہیں (1) انھیں تو یہ بھی شعور نہیں کہ کب اٹھائے جائیں گے (2)
  16,22,اِلٰهُكُمْ اِلٰهٌ وَّاحِدٌ١ۚ فَالَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ قُلُوْبُهُمْ مُّنْكِرَةٌ وَّ هُمْ مُّسْتَكْبِرُوْنَ اِلٰهُكُمْ : تمہارا معبود اِلٰهٌ : معبود وَّاحِدٌ : ایک (یکتا) فَالَّذِيْنَ : پس جو لوگ لَا يُؤْمِنُوْنَ : ایمان نہیں رکھتے بِالْاٰخِرَةِ : آخرت پر قُلُوْبُهُمْ : ان کے دل مُّنْكِرَةٌ : منکر (انکار کرنیوالے) وَّهُمْ : اور وہ مُّسْتَكْبِرُوْنَ : تکبر کرنے والے (مغرور) تم سب کا معبود صرف اللہ تعالیٰ اکیلا اور آخرت پر ایمان نہ رکھنے والوں کے دل منکر ہیں اور وہ خود تکبر سے بھرے ہوئے ہیں (1)۔
  16,23,لَا جَرَمَ اَنَّ اللّٰهَ یَعْلَمُ مَا یُسِرُّوْنَ وَ مَا یُعْلِنُوْنَ١ؕ اِنَّهٗ لَا یُحِبُّ الْمُسْتَكْبِرِیْنَ لَاجَرَمَ : یقینی بات اَنَّ : کہ اللّٰهَ : اللہ يَعْلَمُ : جانتا ہے مَا : جو يُسِرُّوْنَ : وہ چھپاتے ہیں وَمَا : اور جو يُعْلِنُوْنَ : وہ ظاہر کرتے ہیں اِنَّهٗ : بیشک وہ لَا يُحِبُّ : پسند نہیں کرتا الْمُسْتَكْبِرِيْنَ : تکبر کرنے والے بیشک و شبہ اللہ تعالیٰ ہر اس چیز کو، جسے وہ لوگ چھپاتے ہیں اور جسے ظاہر کرتے ہیں، بخوبی جانتا ہے۔ وہ غرور کرنے والوں کو پسند نہیں فرماتا (1)
  16,24,وَ اِذَا قِیْلَ لَهُمْ مَّا ذَاۤ اَنْزَلَ رَبُّكُمْ١ۙ قَالُوْۤا اَسَاطِیْرُ الْاَوَّلِیْنَۙ وَاِذَا : اور جب قِيْلَ : کہا جائے لَهُمْ : ان سے مَّاذَآ : کیا اَنْزَلَ : نازل کیا رَبُّكُمْ : تمہارا رب قَالُوْٓا : وہ کہتے ہیں اَسَاطِيْرُ : کہانیاں الْاَوَّلِيْنَ : پہلے لوگ ان سے جب دریافت کیا جاتا ہے کہ تمہارے پروردگار نے کیا نازل فرمایا ہے ؟ تو جواب دیتے ہیں کہ اگلوں کی کہانیاں (1)۔
  16,25,لِیَحْمِلُوْۤا اَوْزَارَهُمْ كَامِلَةً یَّوْمَ الْقِیٰمَةِ١ۙ وَ مِنْ اَوْزَارِ الَّذِیْنَ یُضِلُّوْنَهُمْ بِغَیْرِ عِلْمٍ١ؕ اَلَا سَآءَ مَا یَزِرُوْنَ۠    ۧ لِيَحْمِلُوْٓا : انجام کار وہ اٹھائیں گے اَوْزَارَهُمْ : اپنے بوجھ (گناہ) كَامِلَةً : پورے يَّوْمَ الْقِيٰمَةِ : قیامت کے دن وَمِنْ : اور کچھ اَوْزَارِ : بوجھ الَّذِيْنَ : ان کے جنہیں يُضِلُّوْنَهُمْ : وہ گمراہ کرتے ہیں بِغَيْرِ عِلْمٍ : علم کے بغیر اَلَا : خوب سن لو سَآءَ : برا مَا يَزِرُوْنَ : جو وہ لاتے ہیں اس کا نتیجہ ہوگا کہ قیامت کے دن یہ لوگ اپنے پورے بوجھ کے ساتھ ہی ان کے بوجھ کے حصے دار ہوں گے جنہیں بےعلمی سے گمراہ کرتے رہے۔ دیکھو تو کیسا برا بوجھ اٹھا رہے ہیں (1)۔
  16,26,قَدْ مَكَرَ الَّذِیْنَ مِنْ قَبْلِهِمْ فَاَتَى اللّٰهُ بُنْیَانَهُمْ مِّنَ الْقَوَاعِدِ فَخَرَّ عَلَیْهِمُ السَّقْفُ مِنْ فَوْقِهِمْ وَ اَتٰىهُمُ الْعَذَابُ مِنْ حَیْثُ لَا یَشْعُرُوْنَ قَدْ مَكَرَ : تحقیق مکاری کی الَّذِيْنَ : وہ لوگ جو مِنْ قَبْلِهِمْ : ان سے پہلے فَاَتَى : پس آیا اللّٰهُ : اللہ بُنْيَانَهُمْ : ان کی عمارت مِّنَ : سے الْقَوَاعِدِ : بنیاد (جمع) فَخَرَّ : پس گر پڑی عَلَيْهِمُ : ان پر السَّقْفُ : چھت مِنْ : سے فَوْقِهِمْ : ان کے اوپر وَاَتٰىهُمُ : اور آیا ان پر الْعَذَابُ : عذاب مِنْ : سے حَيْثُ : جہاں سے لَا يَشْعُرُوْنَ : انہیں خیال نہ تھا ان سے پہلے کے لوگوں نے بھی مکر کیا تھا، (آخر) اللہ نے (ان کے منصوبوں) کی عمارتوں کو جڑوں سے اکھیڑ دیا اور ان (کے سروں) پر (ان کی) چھتیں اوپر سے گرپڑیں (1) اور ان کے پاس عذاب وہاں سے آگیا جہاں کا انھیں وہم و گمان بھی نہ تھا (2)
