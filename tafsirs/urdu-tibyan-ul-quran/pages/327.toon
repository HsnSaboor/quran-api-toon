tafsir[15]{c,v,t}:
  21,58,فَجَعَلَهُمْ جُذٰذًا اِلَّا كَبِیْرًا لَّهُمْ لَعَلَّهُمْ اِلَیْهِ یَرْجِعُوْنَ فَجَعَلَهُمْ : پس اس نے انہیں کر ڈالا جُذٰذًا : ریزہ ریزہ اِلَّا : سوائے كَبِيْرًا : بڑا لَّهُمْ : ان کا لَعَلَّهُمْ : تاکہ وہ اِلَيْهِ : اس کی طرف يَرْجِعُوْنَ : رجوع کریں پس اس نے سب کے ٹکڑے ٹکڑے کر دئیے ہاں صرف بڑے بت کو چھوڑ دیا یہ بھی اس لئے کہ وہ سب اس کی طرف ہی لوٹیں (1)
  21,59,قَالُوْا مَنْ فَعَلَ هٰذَا بِاٰلِهَتِنَاۤ اِنَّهٗ لَمِنَ الظّٰلِمِیْنَ قَالُوْا : کہنے لگے مَنْ : کون۔ کس فَعَلَ : کیا ھٰذَا : یہ بِاٰلِهَتِنَآ : ہمارے معبودوں کے ساتھ اِنَّهٗ : بیشک وہ لَمِنَ : البتہ۔ سے الظّٰلِمِيْنَ : ظالم (جمع) کہنے لگے ہمارے خداؤں کے ساتھ یہ کس نے کیا ؟ ایسا شخص تو یقیناً ظالموں میں سے ہے (1)
  21,60,قَالُوْا سَمِعْنَا فَتًى یَّذْكُرُهُمْ یُقَالُ لَهٗۤ اِبْرٰهِیْمُؕ قَالُوْا : وہ بولے سَمِعْنَا : ہم نے سنا ہے فَتًى : ایک جوان يَّذْكُرُهُمْ : وہ ان کے بارے میں باتیں کرتا ہے يُقَالُ : کہا جاتا ہے لَهٗٓ : اس کو اِبْرٰهِيْمُ : ابراہیم بولے ہم نے ایک نوجوان کو ان کا تذکرہ کرتے ہوئے سنا تھا جسے ابراہیم ؑ کہا جاتا ہے (1)۔
  21,61,قَالُوْا فَاْتُوْا بِهٖ عَلٰۤى اَعْیُنِ النَّاسِ لَعَلَّهُمْ یَشْهَدُوْنَ قَالُوْا : وہ بولے فَاْتُوْا : ہم نے سنا ہے بِهٖ : اسے عَلٰٓي : سامنے اَعْيُنِ : آنکھیں النَّاسِ : لوگ لَعَلَّهُمْ : تاکہ وہ يَشْهَدُوْنَ : وہ دیکھیں سب نے کہا اچھا اسے مجمع میں لوگوں کی نگاہوں کے سامنے لاؤ تاکہ سب دیکھیں (1)
  21,62,قَالُوْۤا ءَاَنْتَ فَعَلْتَ هٰذَا بِاٰلِهَتِنَا یٰۤاِبْرٰهِیْمُؕ قَالُوْٓا : انہوں نے کہا ءَاَنْتَ : کیا تو فَعَلْتَ : تونے کیا ھٰذَا : یہ بِاٰلِهَتِنَا : ہمارے معبودوں کے ساتھ يٰٓاِبْرٰهِيْمُ : اے ابراہیم کہنے لگے ! اے ابراہیم ؑ کیا تو نے ہی ہمارے خداؤں کے ساتھ یہ حرکت کی ہے۔
  21,63,قَالَ بَلْ فَعَلَهٗ١ۖۗ كَبِیْرُهُمْ هٰذَا فَسْئَلُوْهُمْ اِنْ كَانُوْا یَنْطِقُوْنَ قَالَ : اس نے کہا بَلْ : بلکہ فَعَلَه : اس نے کیا ہے كَبِيْرُهُمْ : ان کا بڑا ھٰذَا : یہ فَسْئَلُوْهُمْ : تو ان سے پوچھ لو اِنْ : اگر كَانُوْا يَنْطِقُوْنَ : وہ بولتے ہیں آپ نے جواب دیا بلکہ اس کام کو ان کے بڑے نے کیا ہے تم اپنے خداؤں سے پوچھ لو، اگر یہ بولتے چالتے ہوں (1)
  21,64,فَرَجَعُوْۤا اِلٰۤى اَنْفُسِهِمْ فَقَالُوْۤا اِنَّكُمْ اَنْتُمُ الظّٰلِمُوْنَۙ فَرَجَعُوْٓا : پس وہ لوٹے (سوچ میں پڑھ گئے) اِلٰٓى : طرف۔ میں اَنْفُسِهِمْ : اپنے دل فَقَالُوْٓا : پھر انہوں نے کہا اِنَّكُمْ : بیشک تم اَنْتُمُ : تم ہی الظّٰلِمُوْنَ : ظالم (جمع) پس یہ لوگ اپنے دلوں میں قائل ہوگئے اور کہنے لگے واقع ظالم تو تم ہی ہو (1)
  21,65,ثُمَّ نُكِسُوْا عَلٰى رُءُوْسِهِمْ١ۚ لَقَدْ عَلِمْتَ مَا هٰۤؤُلَآءِ یَنْطِقُوْنَ ثُمَّ نُكِسُوْا : پھر وہ اوندھے کیے گئے عَلٰي رُءُوْسِهِمْ : اپنے سروں پر لَقَدْ عَلِمْتَ : تو خوب جانتا ہے مَا : جو هٰٓؤُلَآءِ : یہ يَنْطِقُوْنَ : بولتے ہیں پھر اپنے سروں کے بل اوندھے ہوگئے (اور کہنے لگے کہ) یہ تجھے بھی معلوم ہے یہ بولنے چالنے والے نہیں (1)
  21,66,قَالَ اَفَتَعْبُدُوْنَ مِنْ دُوْنِ اللّٰهِ مَا لَا یَنْفَعُكُمْ شَیْئًا وَّ لَا یَضُرُّكُمْؕ قَالَ : اس نے کہا اَفَتَعْبُدُوْنَ : کیا پھر تم پرستش کرتے ہو مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا مَا : جو لَا يَنْفَعُكُمْ : نہ تمہیں نفع پہنچا سکیں شَيْئًا : کچھ وَّلَا يَضُرُّكُمْ : اور نہ نقصان پہنچا سکیں تمہیں اللہ کے خلیل نے اسی وقت فرمایا افسوس ! کیا تم اللہ کے علاوہ ان کی عبادت کرتے ہو جو نہ تمہیں کچھ بھی نفع پہنچا سکیں نہ نقصان۔
  21,67,اُفٍّ لَّكُمْ وَ لِمَا تَعْبُدُوْنَ مِنْ دُوْنِ اللّٰهِ١ؕ اَفَلَا تَعْقِلُوْنَ اُفٍّ : تف لَّكُمْ : تم پر وَلِمَا : اور اس پر جسے تَعْبُدُوْنَ : پرستش کرتے ہو تم مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا اَ : کیا فَلَا تَعْقِلُوْنَ : پھر تم نہیں سمجھتے تف ہے تم پر اور ان پر جن کی تم اللہ کے سوا عبادت کرتے ہو۔ کیا تمہیں اتنی سی عقل نہیں (1)۔
  21,68,قَالُوْا حَرِّقُوْهُ وَ انْصُرُوْۤا اٰلِهَتَكُمْ اِنْ كُنْتُمْ فٰعِلِیْنَ قَالُوْا : وہ کہنے لگے حَرِّقُوْهُ : تم اسے جلا ڈالو وَانْصُرُوْٓا : اور تم مدد کرو اٰلِهَتَكُمْ : اپنے معبودوں کو اِنْ : اگر كُنْتُمْ فٰعِلِيْنَ : تم ہو کرنے والے (کچھ کرنا ہے) کہنے لگے کہ اسے جلا دو اور اپنے خداؤں کی مدد کرو اگر تمہیں کچھ کرنا ہی ہے (1)
  21,69,قُلْنَا یٰنَارُ كُوْنِیْ بَرْدًا وَّ سَلٰمًا عَلٰۤى اِبْرٰهِیْمَۙ قُلْنَا : ہم نے حکم دیا يٰنَارُكُوْنِيْ : اے آگ تو ہوجا بَرْدًا : ٹھنڈی وَّسَلٰمًا : اور سلامتی عَلٰٓي : پر اِبْرٰهِيْمَ : ابراہیم ہم نے فرما دیا اے آگ ! تو ٹھندی پڑجا اور ابراہیم ؑ کے لئے سلامتی (اور آرام کی چیز) بن جا۔
  21,70,وَ اَرَادُوْا بِهٖ كَیْدًا فَجَعَلْنٰهُمُ الْاَخْسَرِیْنَۚ وَاَرَادُوْا : اور انہوں نے ارادہ کیا بِهٖ : اس کے ساتھ كَيْدًا : فریب فَجَعَلْنٰهُمُ : تو ہم نے انہیں کردیا الْاَخْسَرِيْنَ : بہت خسارہ پانیوالے (زیاں کار) گو انہوں نے ابراہیم ؑ کا برا چاہا، لیکن ہم نے انھیں ناکام بنادیا۔
  21,71,وَ نَجَّیْنٰهُ وَ لُوْطًا اِلَى الْاَرْضِ الَّتِیْ بٰرَكْنَا فِیْهَا لِلْعٰلَمِیْنَ وَنَجَّيْنٰهُ : اور ہم نے اسے بچا لیا وَلُوْطًا : اور لوط اِلَى : طرف الْاَرْضِ : سرزمین الَّتِيْ بٰرَكْنَا : وہ جس میں ہمنے برکت رکھی فِيْهَا : اس میں لِلْعٰلَمِيْنَ : جہانوں کے لیے اور ہم ابراہیم اور لوط کو بچا کر اس زمین کی طرف لے چلے جس میں ہم نے تمام جہان والوں کے لئے برکت رکھی تھی (1)۔
  21,72,وَ وَهَبْنَا لَهٗۤ اِسْحٰقَ١ؕ وَ یَعْقُوْبَ نَافِلَةً١ؕ وَ كُلًّا جَعَلْنَا صٰلِحِیْنَ وَوَهَبْنَا : اور ہم نے عطا کیا لَهٗٓ : اس کو اِسْحٰقَ : اسحق وَيَعْقُوْبَ : اور یعقوب نَافِلَةً : پوتا وَكُلًّا : اور سب جَعَلْنَا : ہم نے بنایا صٰلِحِيْنَ : صالح (نیکو کار) اور ہم نے اسے اسحاق عطا فرمایا اور یعقوب اس پر مزید (1) اور ہر ایک کو ہم نے صالح بنایا۔
