tafsir[18]{c,v,t}:
  98,8,جَزَآؤُهُمْ عِنْدَ رَبِّهِمْ جَنّٰتُ عَدْنٍ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ خٰلِدِیْنَ فِیْهَاۤ اَبَدًا١ؕ رَضِیَ اللّٰهُ عَنْهُمْ وَ رَضُوْا عَنْهُ١ؕ ذٰلِكَ لِمَنْ خَشِیَ رَبَّهٗ۠    ۧ جَزَآؤُهُمْ : ان کی جزا عِنْدَ : پاس رَبِّهِمْ : ان کے رب کے جَنّٰتُ : باغ عَدْنٍ : ہمیشہ رہنے والے تَجْرِيْ : بہتی ہیں مِنْ تَحْتِهَا : ان کے نیچے الْاَنْهٰرُ : نہریں خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَآ : اس میں اَبَدًا : ہمیشہ ہمیشہ ۭرَضِيَ اللّٰهُ : اللہ راضی ہوا عَنْهُمْ : ان سے وَرَضُوْا عَنْهُ : اور وہ راضی اس سے ۭ ذٰلِكَ لِمَنْ : یہ ۔ اسکے لئے جو خَشِيَ رَبَّهٗ : ڈرے اپنے رب سے ان کا بدلہ ان کے رب کے پاس ہمیشگی والی جنتیں ہیں جنکے نیچے نہریں بہہ رہی ہیں جن میں وہ ہمیشہ ہمیشہ رہیں گے۔ اللہ ان سے راضی ہوا اور یہ اس سے راضی ہوئے (1) یہ ہے اس کے لئے جو اپنے پروردگار سے ڈرے۔
  99,1,اِذَا زُلْزِلَتِ الْاَرْضُ زِلْزَالَهَاۙ اِذَا زُلْزِلَتِ : جب ہلا ڈالی جائے الْاَرْضُ : زمین زِلْزَالَهَا : اس کا زلزلہ جب زمین پوری طرح جھنجھوڑ دی جائے گی (1)
  99,2,وَ اَخْرَجَتِ الْاَرْضُ اَثْقَالَهَاۙ وَاَخْرَجَتِ : اور باہر نکال ڈالے الْاَرْضُ : زمین اَثْقَالَهَا : اپنے بوجھ اور اپنے بوجھ باہر نکال پھینکے گی (1)
  99,3,وَ قَالَ الْاِنْسَانُ مَا لَهَاۚ وَقَالَ الْاِنْسَانُ : اور کہے گا انسان مَا لَهَا : اسے کیا ہوگیا انسان کہنے لگے گا اسے کیا ہوگیا ہے۔ (1)
  99,4,یَوْمَئِذٍ تُحَدِّثُ اَخْبَارَهَاۙ يَوْمَئِذٍ : اس دن تُحَدِّثُ : بیان کرے گی اَخْبَارَهَا : اپنی خبریں (حالات) اس دن زمین اپنی سب خبریں بیان کر دے گی (1)
  99,5,بِاَنَّ رَبَّكَ اَوْحٰى لَهَاؕ بِاَنَّ : کیونکہ رَبَّكَ : تیرا رب اَوْحٰى : حکم بھیجا لَهَا : اسکو اس لئے کہ تیرے رب نے اسے حکم دیا ہوگا۔ (1)
  99,6,یَوْمَئِذٍ یَّصْدُرُ النَّاسُ اَشْتَاتًا١ۙ۬ لِّیُرَوْا اَعْمَالَهُمْؕ يَوْمَئِذٍ : اس دن يَّصْدُرُ : باہر نکلیں گے النَّاسُ : لوگ اَشْتَاتًا : گروہ در گروہ لِّيُرَوْا : تاکہ دکھائے اَعْمَالَهُمْ : ان کے عمل اس روز لوگ مختلف جماعتیں ہو کر (واپس) لوٹیں گے (1) تاکہ انہیں ان کے اعمال دکھا دیئے جائیں (1)
  99,7,فَمَنْ یَّعْمَلْ مِثْقَالَ ذَرَّةٍ خَیْرًا یَّرَهٗؕ فَمَنْ : پس جس نے يَّعْمَلْ : کی ہوگی مِثْقَالَ : برابر ذَرَّةٍ : ایک ذرہ خَيْرًا : نیکی يَّرَهٗ : اس کو دیکھے گا پس جس نے ذرہ برابر بھی نیکی کی ہوگی وہ اسے دیکھ لے گا۔ (1)
  99,8,وَ مَنْ یَّعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا یَّرَهٗ۠    ۧ وَمَنْ : اور جس نے يَّعْمَلْ : کی ہوگی مِثْقَالَ : برابر ذَرَّةٍ : ایک ذرہ شَرًّا : بُرائی يَّرَهٗ : اس کو دیکھے گا اور جس نے ذرہ برابر برائی کی ہوگی وہ اسے دیکھ لے گا۔ (1)
  100,1,وَ الْعٰدِیٰتِ ضَبْحًاۙ وَالْعٰدِيٰتِ : قسم ہے دوڑنے والے گھوڑوں کی ضَبْحًا : ہانپنے والے ہانپتے ہوئے دوڑنے والے گھوڑوں کی قسم (1)
  100,2,فَالْمُوْرِیٰتِ قَدْحًاۙ فَالْمُوْرِيٰتِ : چنگاریاں اڑانیوالے قَدْحًا : جھاڑ کر پھر ٹاپ مار کر آگ جھاڑنے والوں کی قسم (1)
  100,3,فَالْمُغِیْرٰتِ صُبْحًاۙ فَالْمُغِيْرٰتِ : غارتگری کرنیوالے صُبْحًا : صبح کو پھر صبح کے وقت دھاوا بولنے والوں کی قسم (1)
  100,4,فَاَثَرْنَ بِهٖ نَقْعًاۙ فَاَثَرْنَ بِهٖ : پھر اڑائیں اس سے نَقْعًا : گرد اڑاتے پس اس وقت گرد و غبار اڑاتے ہیں۔
  100,5,فَوَسَطْنَ بِهٖ جَمْعًاۙ فَوَسَطْنَ : پھر جاگھسیں بِهٖ : اس وقت جَمْعًا : جماعت (فوج) پھر اسی کے ساتھ فوجوں کے درمیان گھس جاتے ہیں۔ (1)
  100,6,اِنَّ الْاِنْسَانَ لِرَبِّهٖ لَكَنُوْدٌۚ اِنَّ : بیشک الْاِنْسَانَ : انسان لِرَبِّهٖ : اپنے رب کا لَكَنُوْدٌ : ناشکرا یقیناً انسان اپنے رب کا ناشکرا ہے۔
  100,7,وَ اِنَّهٗ عَلٰى ذٰلِكَ لَشَهِیْدٌۚ وَاِنَّهٗ : اور بیشک وہ عَلٰي : پر ذٰلِكَ : اس لَشَهِيْدٌ : گواہ اور یقیناً وہ خود بھی اس پر گواہ ہے۔ (1)
  100,8,وَ اِنَّهٗ لِحُبِّ الْخَیْرِ لَشَدِیْدٌؕ وَاِنَّهٗ : اور بیشک وہ لِحُبِّ : محبت میں الْخَيْرِ : مال و دولت لَشَدِيْدٌ : البتہ سخت یہ مال کی محبت میں بھی بڑا سخت ہے (1)
  100,9,اَفَلَا یَعْلَمُ اِذَا بُعْثِرَ مَا فِی الْقُبُوْرِۙ اَفَلَا يَعْلَمُ : پس کیا نہیں جانتا اِذَا : جب بُعْثِرَ : اٹھائے جائیں گے مَا : جو فِي الْقُبُوْرِ : قبروں میں کیا اسے وہ وقت معلوم نہیں جب قبروں میں جو (کچھ) ہے نکال لیا جائے گا (1)
