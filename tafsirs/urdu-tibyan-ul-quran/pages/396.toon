tafsir[10]{c,v,t}:
  28,85,اِنَّ الَّذِیْ فَرَضَ عَلَیْكَ الْقُرْاٰنَ لَرَآدُّكَ اِلٰى مَعَادٍ١ؕ قُلْ رَّبِّیْۤ اَعْلَمُ مَنْ جَآءَ بِالْهُدٰى وَ مَنْ هُوَ فِیْ ضَلٰلٍ مُّبِیْنٍ اِنَّ : بیشک الَّذِيْ : وہ (اللہ) جس نے فَرَضَ : لازم کیا عَلَيْكَ : تم پر الْقُرْاٰنَ : قرآن لَرَآدُّكَ : ضرور پھیر لائے گا تمہیں اِلٰى مَعَادٍ : لوٹنے کی جگہ قُلْ : فرما دیں رَّبِّيْٓ : میرا رب اَعْلَمُ : خوب جانتا ہے مَنْ : کون جَآءَ : آیا بِالْهُدٰى : ہدایت کے ساتھ وَمَنْ هُوَ : اور وہ کون فِيْ : میں ضَلٰلٍ مُّبِيْنٍ : کھلی گمراہی جس اللہ نے آپ پر قرآن نازل فرمایا ہے 1 وہ آپ کو دوبارہ پہلی جگہ لانے والا ہے 2 کہہ دیجئے کہ میرا رب اسے بخوبی جانتا ہے جو ہدایت لایا اور اس سے بھی کھلی گمراہی میں ہے۔ 3
  28,86,وَ مَا كُنْتَ تَرْجُوْۤا اَنْ یُّلْقٰۤى اِلَیْكَ الْكِتٰبُ اِلَّا رَحْمَةً مِّنْ رَّبِّكَ فَلَا تَكُوْنَنَّ ظَهِیْرًا لِّلْكٰفِرِیْنَ٘ وَمَا كُنْتَ : اور تم نہ تھے تَرْجُوْٓا : امید رکھتے اَنْ يُّلْقٰٓى : کہ اتاری جائے گی اِلَيْكَ : تمہاری طرف الْكِتٰبُ : کتاب اِلَّا : مگر رَحْمَةً : رحمت مِّنْ : سے رَّبِّكَ : تمہارا رب فَلَا تَكُوْنَنَّ : سو تو ہرگز نہ ہوتا ظَهِيْرًا : مددگار لِّلْكٰفِرِيْنَ : کافروں کے لیے آپ کو تو کبھی خیال بھی نہ گزرا تھا کہ آپ کی طرف کتاب نازل فرمائی جائے گی 1 لیکن یہ آپ کے رب کی مہربانی سے اترا 2 اب آپ کو ہرگز کافروں کا مددگار نہ ہونا چاہیے 3
  28,87,وَ لَا یَصُدُّنَّكَ عَنْ اٰیٰتِ اللّٰهِ بَعْدَ اِذْ اُنْزِلَتْ اِلَیْكَ وَ ادْعُ اِلٰى رَبِّكَ وَ لَا تَكُوْنَنَّ مِنَ الْمُشْرِكِیْنَۚ وَلَا يَصُدُّنَّكَ : اور وہ تمہیں ہرگز نہ روکیں عَنْ : سے اٰيٰتِ اللّٰهِ : اللہ کے احکام بَعْدَ : بعد اِذْ : جبکہ اُنْزِلَتْ : نازل کیے گئے اِلَيْكَ : تمہاری طرف وَادْعُ : اور آپ بلائیں اِلٰى رَبِّكَ : اپنے رب کی طرف وَ : اور لَا تَكُوْنَنَّ : تم ہرگز نہ ہونا مِنَ : سے الْمُشْرِكِيْنَ : جمع مشرک خیال رکھئے کہ یہ کفار آپ کو اللہ تعالیٰ کی آیتوں کی تبلیغ سے روک نہ دیں اس کے بعد کہ یہ آپ کی جانب اتاری گئیں، تو اپنے رب کی طرف بلاتے رہیں اور شرک کرنے والوں میں سے نہ ہوں۔ 1
  28,88,وَ لَا تَدْعُ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ١ۘ لَاۤ اِلٰهَ اِلَّا هُوَ١۫ كُلُّ شَیْءٍ هَالِكٌ اِلَّا وَجْهَهٗ١ؕ لَهُ الْحُكْمُ وَ اِلَیْهِ تُرْجَعُوْنَ۠    ۧ وَلَا تَدْعُ : اور نہ پکارو تم مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا : کوئی معبود اٰخَرَ : دوسرا لَآ : نہیں اِلٰهَ : کوئی معبود اِلَّا هُوَ : اس کے سوا كُلُّ شَيْءٍ : ہر چیز هَالِكٌ : فنا ہونے والی اِلَّا : سوا اس کی ذات وَجْهَهٗ : اس کی ذات لَهُ : اسی کے لیے۔ کا الْحُكْمُ : حکم وَ : اور اِلَيْهِ : اس کی طرف تُرْجَعُوْنَ : تم لوٹ کر جاؤگے اللہ تعالیٰ کے ساتھ کسی اور کو معبود نہ پکارنا 1 بجز اللہ تعالیٰ کے کوئی اور معبود نہیں، ہر چیز فنا ہونے والی ہے مگر اس کا منہ 2 (اور ذات) اسی کے لئے فرمانروائی ہے 3 اور تم اس کی طرف لو ٹائے جاؤ گے۔ 4
  29,1,الٓمّٓۚ الٓمّٓ : الف۔ لام۔ میم ا لم
  29,2,اَحَسِبَ النَّاسُ اَنْ یُّتْرَكُوْۤا اَنْ یَّقُوْلُوْۤا اٰمَنَّا وَ هُمْ لَا یُفْتَنُوْنَ اَحَسِبَ : کیا گمان کیا ہے النَّاسُ : لوگ اَنْ يُّتْرَكُوْٓا : کہ وہ چھوڑ دئیے جائیں گے اَنْ : کہ يَّقُوْلُوْٓا : انہوں نے کہہ دیا اٰمَنَّا : ہم ایمان لائے وَهُمْ : اور وہ لَا يُفْتَنُوْنَ : وہ آزمائے جائیں گے کیا لوگوں نے یہ گمان کر رکھا ہے کہ ان کے صرف اس دعوے پر کہ ہم ایمان لائے ہیں ہم انھیں بغیر آزمائے ہوئے ہی چھوڑ دیں گے ؟ 1
  29,3,وَ لَقَدْ فَتَنَّا الَّذِیْنَ مِنْ قَبْلِهِمْ فَلَیَعْلَمَنَّ اللّٰهُ الَّذِیْنَ صَدَقُوْا وَ لَیَعْلَمَنَّ الْكٰذِبِیْنَ وَ : اور لَقَدْ فَتَنَّا : البتہ ہم نے آزمایا الَّذِيْنَ : وہ لوگ جو مِنْ قَبْلِهِمْ : ان سے پہلے فَلَيَعْلَمَنَّ : تو ضرور معلوم کرلے گا اللّٰهُ : اللہ الَّذِيْنَ : وہ لوگ جو صَدَقُوْا : سچے ہیں وَ : اور لَيَعْلَمَنَّ : وہ ضرور معلوم کرلے گا الْكٰذِبِيْنَ : جھوٹے ان اگلوں کو بھی ہم نے خوب جانچا یقیناً اللہ تعالیٰ انھیں بھی جان لے گا جو سچ کہتے ہیں اور انھیں بھی معلوم کرلے گا جو جھوٹے ہیں۔ 1
  29,4,اَمْ حَسِبَ الَّذِیْنَ یَعْمَلُوْنَ السَّیِّاٰتِ اَنْ یَّسْبِقُوْنَا١ؕ سَآءَ مَا یَحْكُمُوْنَ اَمْ حَسِبَ : کیا گمان الَّذِيْنَ : وہ لوگ جو يَعْمَلُوْنَ : کرتے ہیں السَّيِّاٰتِ : برے کام اَنْ : کہ يَّسْبِقُوْنَا : وہ ہم سے باہر بچ نکلیں گے سَآءَ : برا ہے مَا يَحْكُمُوْنَ : جو وہ فیصلہ کر رہے ہیں کیا جو لوگ برائیاں کر رہے ہیں انہوں نے یہ سمجھ رکھا ہے کہ ہمارے قابو سے باہر ہوجائیں گے 1 یہ لوگ کیسی بری تجویزیں کر رہے ہیں 2
  29,5,مَنْ كَانَ یَرْجُوْا لِقَآءَ اللّٰهِ فَاِنَّ اَجَلَ اللّٰهِ لَاٰتٍ١ؕ وَ هُوَ السَّمِیْعُ الْعَلِیْمُ مَنْ : جو كَانَ يَرْجُوْا : وہ امید رکھتا ہے لِقَآءَ اللّٰهِ : اللہ سے ملاقات کی فَاِنَّ : تو بیشک اَجَلَ اللّٰهِ : اللہ کا وعدہ لَاٰتٍ : ضرور آنے والا وَهُوَ : اور وہ السَّمِيْعُ : سننے والا الْعَلِيْمُ : جاننے والا جسے اللہ کی ملاقات کی امید ہو پس اللہ کا ٹھہرایا ہوا وقت یقیناً آنے والا ہے 1 وہ سب کچھ سننے والا سب کچھ جاننے والا ہے۔ 2
  29,6,وَ مَنْ جَاهَدَ فَاِنَّمَا یُجَاهِدُ لِنَفْسِهٖ١ؕ اِنَّ اللّٰهَ لَغَنِیٌّ عَنِ الْعٰلَمِیْنَ وَمَنْ : اور جو جَاهَدَ : کوشش کرتا ہے فَاِنَّمَا : تو صرف يُجَاهِدُ : کوشش کرتا ہے لِنَفْسِهٖ : اپنی ذات کے لیے اِنَّ : بیشک اللّٰهَ : اللہ لَغَنِيٌّ : البتہ بےنیاز عَنِ : سے الْعٰلَمِيْنَ : جہان والے اور ہر ایک کوشش کرنے والا اپنے ہی بھلے کی کوشش کرتا ہے۔ ویسے تو اللہ تعالیٰ تمام جہان والوں سے بےنیاز ہے 1
