tafsir[18]{c,v,t}:
  73,20,اِنَّ رَبَّكَ یَعْلَمُ اَنَّكَ تَقُوْمُ اَدْنٰى مِنْ ثُلُثَیِ الَّیْلِ وَ نِصْفَهٗ وَ ثُلُثَهٗ وَ طَآئِفَةٌ مِّنَ الَّذِیْنَ مَعَكَ١ؕ وَ اللّٰهُ یُقَدِّرُ الَّیْلَ وَ النَّهَارَ١ؕ عَلِمَ اَنْ لَّنْ تُحْصُوْهُ فَتَابَ عَلَیْكُمْ فَاقْرَءُوْا مَا تَیَسَّرَ مِنَ الْقُرْاٰنِ١ؕ عَلِمَ اَنْ سَیَكُوْنُ مِنْكُمْ مَّرْضٰى١ۙ وَ اٰخَرُوْنَ یَضْرِبُوْنَ فِی الْاَرْضِ یَبْتَغُوْنَ مِنْ فَضْلِ اللّٰهِ١ۙ وَ اٰخَرُوْنَ یُقَاتِلُوْنَ فِیْ سَبِیْلِ اللّٰهِ١ۖ٘ فَاقْرَءُوْا مَا تَیَسَّرَ مِنْهُ١ۙ وَ اَقِیْمُوا الصَّلٰوةَ وَ اٰتُوا الزَّكٰوةَ وَ اَقْرِضُوا اللّٰهَ قَرْضًا حَسَنًا١ؕ وَ مَا تُقَدِّمُوْا لِاَنْفُسِكُمْ مِّنْ خَیْرٍ تَجِدُوْهُ عِنْدَ اللّٰهِ هُوَ خَیْرًا وَّ اَعْظَمَ اَجْرًا١ؕ وَ اسْتَغْفِرُوا اللّٰهَ١ؕ اِنَّ اللّٰهَ غَفُوْرٌ رَّحِیْمٌ۠    ۧ اِنَّ رَبَّكَ : بیشک آپ کا رب يَعْلَمُ : وہ جانتا ہے اَنَّكَ : کہ آپ تَقُوْمُ : قیام کرتے ہیں اَدْنٰى : قریب ہے مِنْ ثُلُثَيِ الَّيْلِ : دوتہائی رات کے وَنِصْفَهٗ : اور آدھی رات کے وَثُلُثَهٗ : اور اس کا تہائی وَطَآئِفَةٌ : اور ایک جماعت مِّنَ : سے الَّذِيْنَ مَعَكَ ۭ : جو آپ کے ساتھ وَاللّٰهُ : اور اللہ يُقَدِّرُ : اندازہ فرماتا ہے الَّيْلَ وَالنَّهَارَ ۭ : رات اور دن عَلِمَ : اس نے جانا اَنْ : کہ لَّنْ تُحْصُوْهُ : تم ہرگز نباہ نہ کرسکوگے فَتَابَ : تو اس نے عنایت کی عَلَيْكُمْ : تم پر فَاقْرَءُوْا : تو تم پڑھا کرو مَا : جس قدر تَيَسَّرَ : آسانی ہوسکے مِنَ الْقُرْاٰنِ ۭ : قرآن سے عَلِمَ : اس نے جانا اَنْ سَيَكُوْنُ : کہ البتہ ہوں گے مِنْكُمْ : تم میں سے مَّرْضٰى ۙ : کوئی بیمار وَاٰخَرُوْنَ : اور کوئی اور يَضْرِبُوْنَ : وہ سفر کریں گے فِي الْاَرْضِ : زمین میں يَبْتَغُوْنَ : تلاش کرتے ہوئے مِنْ فَضْلِ اللّٰهِ ۙ : اللہ کا فضل (روزی) وَاٰخَرُوْنَ : اور کئی دوسرے يُقَاتِلُوْنَ : وہ جہاد کریں گے فِيْ سَبِيْلِ اللّٰهِ ڮ : اللہ کی راہ میں فَاقْرَءُوْا : پس پڑھ لیا کرو مَا : جس قدر تَيَسَّرَ : آسانی ہوسکے مِنْهُ ۙ : اس سے وَاَقِيْمُوا : اور تم قائم کرو الصَّلٰوةَ : نماز وَاٰتُوا : اور ادا کرتے رہو الزَّكٰوةَ : زکوۃ وَاَقْرِضُوا اللّٰهَ : اور اللہ کو قرض دو قَرْضًا حَسَنًا ۭ : قرض حسنہ (اخلاص سے) وَمَا : اور جو تُقَدِّمُوْا : تم آگے بھیجو گے لِاَنْفُسِكُمْ : اپنے لئے مِّنْ خَيْرٍ : کوئی نیکی تَجِدُوْهُ : تم پاؤگے عِنْدَ اللّٰهِ : اللہ کے ہاں هُوَ خَيْرًا : وہ بہتر وَّاَعْظَمَ اَجْرًا ۭ : اور بڑا اجر میں وَاسْتَغْفِرُوا : اور تم بخشش مانگوگے اللّٰهَ ۭ : اللہ سے اِنَّ اللّٰهَ : بیشک اللہ غَفُوْرٌ : بخشنے والا رَّحِيْمٌ : نہایت رحم کرنیوالا آپ کا رب بخوبی جانتا ہے کہ آپ اور آپ کے ساتھ کے لوگوں کی ایک جماعت قریب دو تہائی رات کے اور آدھی رات کے اور ایک تہائی رات کے تہجد پڑھتی ہے (1) اور رات دن کا پورا اندازہ اللہ تعالیٰ کو ہی ہے، (2) وہ خوب جانتا ہے کہ تم اسے ہرگز نہ نبھا سکو گے (3) پس تم پر مہربانی کی (4) لہذا جتنا قرآن پڑھنا تمہارے لیے آسان ہو پڑھو وہ جانتا ہے کہ تم میں بعض بیمار بھی ہوں گے بعض دوسرے زمین میں چل پھر کر اللہ تعالیٰ کا فضل یعنی روزی بھی تلاش کریں گے (5) اور کچھ لوگ اللہ کی راہ میں جہاد بھی کریں گے (6) سو تم بہ آسانی جتنا قرآن پڑھ سکو پڑھو (7) اور نماز کی پابندی کیا کرو اور زکوٰۃ دیتے رہا کرو اور اللہ تعالیٰ کو اچھا قرض دو اور جو نیکی تم اپنے لیے آگے بھیجو گے اسے اللہ تعالیٰ کے ہاں بہتر سے بہتر اور ثواب میں بہت زیادہ پاؤ گے (8) اللہ تعالیٰ سے معافی مانگتے رہا کرو یقیناً اللہ تعالیٰ بخشنے والا مہربان ہے۔
  74,1,یٰۤاَیُّهَا الْمُدَّثِّرُۙ يٰٓاَيُّهَا الْمُدَّثِّرُ : اے کپڑے میں لپٹے ہوئے (محمد) اے کپڑا اوڑھنے والے (1)
  74,2,قُمْ فَاَنْذِرْ۪ۙ قُمْ : کھڑے ہوجاؤ فَاَنْذِرْ : پھر ڈراؤ کھڑا ہوجا اور آگاہ کر دے (1)۔
  74,3,وَ رَبَّكَ فَكَبِّرْ۪ۙ وَرَبَّكَ : اور اپنا رب فَكَبِّرْ : بڑائی بیان کرو اور اپنے رب ہی کی بڑائیاں بیان کر۔
  74,4,وَ ثِیَابَكَ فَطَهِّرْ۪ۙ وَثِيَابَكَ : اور اپنے کپڑے فَطَهِّرْ : سو پاک کرو اپنے کپڑوں کو پاک رکھا کر (1)
  74,5,وَ الرُّجْزَ فَاهْجُرْ۪ۙ وَالرُّجْزَ : اور پلیدی فَاهْجُرْ : سو دور رہو ناپاکی کو چھوڑ دے (1)
  74,6,وَ لَا تَمْنُنْ تَسْتَكْثِرُ۪ۙ وَلَا : اور نہ تَمْنُنْ : احسان رکھو تَسْتَكْثِرُ : زیادہ لینے (کی غرض سے) اور احسان کرکے زیادہ لینے کی خواہش نہ کر (1)
  74,7,وَ لِرَبِّكَ فَاصْبِرْؕ وَلِرَبِّكَ : اور اپنے رب کیلئے فَاصْبِرْ : صبر کرو اور اپنے رب کی راہ میں صبر کر۔
  74,8,فَاِذَا نُقِرَ فِی النَّاقُوْرِۙ فَاِذَا : پھر جب نُقِرَ : پھونکاجائے گا فِي النَّاقُوْرِ : صور میں پس جبکہ صور میں پھونک ماری جائے گی۔
  74,9,فَذٰلِكَ یَوْمَئِذٍ یَّوْمٌ عَسِیْرٌۙ فَذٰلِكَ : تو وہ يَوْمَئِذٍ : اس دن يَّوْمٌ عَسِيْرٌ : بڑا دشوار دن وہ دن بڑا سخت دن ہوگا۔
  74,10,عَلَى الْكٰفِرِیْنَ غَیْرُ یَسِیْرٍ عَلَي الْكٰفِرِيْنَ : کافروں پر غَيْرُ يَسِيْرٍ : نہ آسان جو کافروں پر آسان نہ ہوگا۔ (1)
  74,11,ذَرْنِیْ وَ مَنْ خَلَقْتُ وَحِیْدًاۙ ذَرْنِيْ : مجھے چھوڑدو وَمَنْ : اور جسے خَلَقْتُ : میں نے پیدا کیا وَحِيْدًا : اکیلا مجھے اور اسے چھوڑ دے جسے میں نے اکیلا پیدا کیا ہے (1)
  74,12,وَّ جَعَلْتُ لَهٗ مَالًا مَّمْدُوْدًاۙ وَّجَعَلْتُ لَهٗ : اور میں نے دیا اسے مَالًا مَّمْدُوْدًا : مال کثیر اور اسے بہت سا مال دے رکھا تھا۔
  74,13,وَّ بَنِیْنَ شُهُوْدًاۙ وَّبَنِيْنَ : اور بیٹے شُهُوْدًا : سامنے حاضر رہنے والے اور حاضر باش فرزند بھی (1)
  74,14,وَّ مَهَّدْتُّ لَهٗ تَمْهِیْدًاۙ وَّمَهَّدْتُّ : اور بچھایا (مہیا کیا) لَهٗ : اس کے لئے تَمْهِيْدًا : بچھونا (سامان) اور میں نے اسے بہت کچھ کشادگی دے رکھی ہے (1)
  74,15,ثُمَّ یَطْمَعُ اَنْ اَزِیْدَۗۙ ثُمَّ يَطْمَعُ : پھر وہ طمع کرتا ہے اَنْ اَزِيْدَ : کہ (اور) زیادہ دوں پھر بھی اس کی چاہت ہے کہ میں اسے اور زیادہ دوں۔ (1)
  74,16,كَلَّا١ؕ اِنَّهٗ كَانَ لِاٰیٰتِنَا عَنِیْدًاؕ كَلَّا ۭ : ہرگز نہیں اِنَّهٗ كَانَ : بیشک وہ ہے لِاٰيٰتِنَا : ہماری آیات کا عَنِيْدًا : عناد رکھنے والا (مخالف) نہیں نہیں (1) وہ ہماری آیتوں کا مخالف ہے۔
  74,17,سَاُرْهِقُهٗ صَعُوْدًاؕ سَاُرْهِقُهٗ : اب اسے چڑھواؤنگا صَعُوْدًا : بڑی چڑھائی عنقریب میں اسے ایک سخت چڑھائی چڑھاؤں گا (1)
