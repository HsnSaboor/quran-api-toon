quran[227]{c,v,t}:
26,1,طٰسٓمّٓ طٰسٓمّٓ : طا۔ سین۔ میم طسم 1
26,2,تِلْكَ اٰیٰتُ الْكِتٰبِ الْمُبِیْنِ تِلْكَ : یہ اٰيٰتُ : آیتیں الْكِتٰبِ الْمُبِيْنِ : روشن کتاب یہ آیتیں روشن کتاب کی ہیں 2
26,3,لَعَلَّكَ بَاخِعٌ نَّفْسَكَ اَلَّا یَكُوْنُوْا مُؤْمِنِیْنَ لَعَلَّكَ : شاید تم بَاخِعٌ : ہلاک کرلوگے نَّفْسَكَ : اپنے تئیں اَلَّا يَكُوْنُوْا : کہ وہ نہیں مُؤْمِنِيْنَ : ایمان لاتے ان کے ایمان نہ لانے پر شاید آپ تو اپنی جان کھو دیں گے 1
26,4,اِنْ نَّشَاْ نُنَزِّلْ عَلَیْهِمْ مِّنَ السَّمَآءِ اٰیَةً فَظَلَّتْ اَعْنَاقُهُمْ لَهَا خٰضِعِیْنَ اِنْ نَّشَاْ : اگر ہم چاہیں نُنَزِّلْ : ہم اتار دیں عَلَيْهِمْ : ان پر مِّنَ السَّمَآءِ : آسمان سے اٰيَةً : کوئی نشانی فَظَلَّتْ : تو ہوجائیں اَعْنَاقُهُمْ : ان کی گردنیں لَهَا : اس کے آگے خٰضِعِيْنَ : پست اگر ہم چاہتے تو ان پر آسمان سے کوئی ایسی نشانی اتارتے کہ جس کے سامنے ان کی گردنیں خم ہوجاتیں 1
26,5,وَ مَا یَاْتِیْهِمْ مِّنْ ذِكْرٍ مِّنَ الرَّحْمٰنِ مُحْدَثٍ اِلَّا كَانُوْا عَنْهُ مُعْرِضِیْنَ وَ : اور مَا يَاْتِيْهِمْ : نہیں آتی ان کے پاس مِّنْ ذِكْرٍ : کوئی نصیحت مِّنَ : (طرف) سے الرَّحْمٰنِ : رحمن مُحْدَثٍ : نئی اِلَّا : مگر كَانُوْا : ہوجاتے ہیں وہ عَنْهُ : اس سے مُعْرِضِيْنَ : روگردان اور ان کے پاس رحمان کی طرف سے جو بھی نئی نصیحت آئی یہ اس سے روگردانی کرنے والے بن گئے۔
26,6,فَقَدْ كَذَّبُوْا فَسَیَاْتِیْهِمْ اَنْۢبٰٓؤُا مَا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ فَقَدْ كَذَّبُوْا : پس بیشک انہوں نے جھٹلایا فَسَيَاْتِيْهِمْ : تو جلد آئیں گی ان کے پاس اَنْۢبٰٓؤُا : خبریں مَا كَانُوْا : جو وہ تھے بِهٖ : اس کا يَسْتَهْزِءُوْنَ : مذاق اڑاتے ان لوگوں نے جھٹلایا ہے اب انکے پاس جلدی سے اسکی خبریں آجائیں گی جسکے ساتھ وہ مسخرا پن کر رہے ہیں 1
26,7,اَوَ لَمْ یَرَوْا اِلَى الْاَرْضِ كَمْ اَنْۢبَتْنَا فِیْهَا مِنْ كُلِّ زَوْجٍ كَرِیْمٍ اَوَلَمْ يَرَوْا : کیا انہوں نے نہیں دیکھا اِلَى الْاَرْضِ : زمین کی طرف كَمْ : کس قدر اَنْۢبَتْنَا : اگائیں ہم نے فِيْهَا : اس میں مِنْ كُلِّ : ہر قسم زَوْجٍ : جوڑا جوڑا كَرِيْمٍ : عمدہ کیا انہوں نے زمین پر نظریں نہیں ڈالیں ؟ کہ ہم نے اس میں ہر طرح کے نفیس جوڑے کس قدر اگائے ہیں ؟ 1
26,8,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا كَانَ : اور نہیں ہیں اَكْثَرُهُمْ : ان میں اکثر مُّؤْمِنِيْنَ : ایمان لانے والے بیشک اس میں یقیناً نشانی ہے 1 اور ان میں کے اکثر لوگ مومن نہیں ہیں 2
26,9,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان اور تیرا رب یقیناً وہی غالب اور مہربان ہے 1۔
26,10,وَ اِذْ نَادٰى رَبُّكَ مُوْسٰۤى اَنِ ائْتِ الْقَوْمَ الظّٰلِمِیْنَۙ وَاِذْ : اور جب نَادٰي : پکارا (فرمایا) رَبُّكَ : تمہارا رب مُوْسٰٓي : موسیٰ اَنِ ائْتِ : کہ تو جا الْقَوْمَ الظّٰلِمِيْنَ : ظالم لوگ اور جب آپ کے رب نے موسیٰ ؑ کو آواز دی کہ تو ظالم قوم کے پاس جا 1۔
26,11,قَوْمَ فِرْعَوْنَ١ؕ اَلَا یَتَّقُوْنَ قَوْمَ فِرْعَوْنَ : قوم فرعون اَلَا يَتَّقُوْنَ : کیا وہ مجھ سے نہیں ڈرتے قوم فرعون کے پاس، کیا وہ پرہیزگاری نہ کریں گے۔
26,12,قَالَ رَبِّ اِنِّیْۤ اَخَافُ اَنْ یُّكَذِّبُوْنِؕ قَالَ : اس نے کہا رَبِّ : اے میرے رب اِنِّىْٓ اَخَافُ : بیشک میں ڈرتا ہوں اَنْ : کہ يُّكَذِّبُوْنِ : وہ مجھے جھٹلائیں گے مو سٰی ؑ نے کہا میرے پروردگار ! مجھے خوف ہے کہ کہیں وہ مجھے جھٹلا (نہ) دیں۔
26,13,وَ یَضِیْقُ صَدْرِیْ وَ لَا یَنْطَلِقُ لِسَانِیْ فَاَرْسِلْ اِلٰى هٰرُوْنَ وَيَضِيْقُ : اور تنگ ہوتا ہے صَدْرِيْ : میرا سینہ (دل) وَلَا يَنْطَلِقُ : اور نہیں چلتی لِسَانِيْ : میری زبان فَاَرْسِلْ : پس پیغام بھیج اِلٰى : طرف هٰرُوْنَ : ہارون اور میرا سینہ تنگ ہو رہا ہے 1 میری زبان چل نہیں رہی 2 پس تو ہارون کی طرف بھی (وحی) بھیج 3۔
26,14,وَ لَهُمْ عَلَیَّ ذَنْۢبٌ فَاَخَافُ اَنْ یَّقْتُلُوْنِۚ وَلَهُمْ : اور ان کا عَلَيَّ : مجھ پر ذَنْۢبٌ : ایک الزام فَاَخَافُ : پس میں ڈرتا ہوں اَنْ : کہ يَّقْتُلُوْنِ : قتل نہ کردیں اور ان کا مجھ پر میرے ایک قصور کا (دعویٰ) بھی ہے مجھے ڈر ہے کہ کہیں وہ مجھے مار نہ ڈالیں 1
26,15,قَالَ كَلَّا١ۚ فَاذْهَبَا بِاٰیٰتِنَاۤ اِنَّا مَعَكُمْ مُّسْتَمِعُوْنَ قَالَ : فرمایا كَلَّا : ہرگز نہیں فَاذْهَبَا بِاٰيٰتِنَآ : پس تم دونوں جاؤ ہماری نشانیوں کے ساتھ اِنَّا : بیشک ہم مَعَكُمْ : تمہارے ساتھ مُّسْتَمِعُوْنَ : سننے والے جناب باری تعالیٰ نے فرمایا ! ہرگز ایسا نہ ہوگا، تم دونوں ہماری نشانیاں لے کر جاؤ 1 ہم خود سننے والے تمہارے ساتھ ہیں 2
26,16,فَاْتِیَا فِرْعَوْنَ فَقُوْلَاۤ اِنَّا رَسُوْلُ رَبِّ الْعٰلَمِیْنَۙ فَاْتِيَا : پس تم دونوں جاؤ فِرْعَوْنَ : فرعون فَقُوْلَآ : تو اسے کہو اِنَّا رَسُوْلُ : بیشک ہم رسول رَبِّ الْعٰلَمِيْنَ : تمام جہانوں کا رب تم دونوں فرعون کے پاس جا کر کہو کہ بلاشبہ ہم رب العالمین کے بھیجے ہوئے ہیں۔
26,17,اَنْ اَرْسِلْ مَعَنَا بَنِیْۤ اِسْرَآءِیْلَؕ اَنْ : کہ اَرْسِلْ : تو بھیج دے مَعَنَا : ہمارے ساتھ بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل کہ تو ہمارے ساتھ بنی اسرائیل روانہ کر دے 1
26,18,قَالَ اَلَمْ نُرَبِّكَ فِیْنَا وَلِیْدًا وَّ لَبِثْتَ فِیْنَا مِنْ عُمُرِكَ سِنِیْنَۙ قَالَ : فرعون نے کہا اَلَمْ نُرَبِّكَ : کیا ہمنے تجھے نہیں پالا فِيْنَا : اپنے درمیان وَلِيْدًا : بچپن میں وَّلَبِثْتَ : اور تو رہا فِيْنَا : ہمارے درمیان مِنْ عُمُرِكَ : اپنی عمر کے سِنِيْنَ : کئی برس فرعوں نے کہا کہ کیا ہم نے تجھے تیرے بچپن کے زمانہ میں اپنے ہاں نہیں پالا تھا ؟ 1 اور تو نے اپنی عمر کے بہت سے سال ہم میں نہیں گزارے ؟ 2
26,19,وَ فَعَلْتَ فَعْلَتَكَ الَّتِیْ فَعَلْتَ وَ اَنْتَ مِنَ الْكٰفِرِیْنَ وَفَعَلْتَ : اور تونے کیا فَعْلَتَكَ : اپنا (وہ) کام الَّتِيْ فَعَلْتَ : جو تونے کیا وَاَنْتَ : اور تو مِنَ : سے الْكٰفِرِيْنَ : ناشکرے پھر تو اپنا وہ کام کر گیا جو کر گیا اور تو ناشکروں میں ہے 1۔
26,20,قَالَ فَعَلْتُهَاۤ اِذًا وَّ اَنَا مِنَ الضَّآلِّیْنَؕ قَالَ : موسیٰ نے کہا فَعَلْتُهَآ : میں وہ کیا تھا اِذًا : جب وَّاَنَا : اور میں مِنَ : سے الضَّآلِّيْنَ : راہ سے بیخبر (جمع) (حضرت) موسیٰ ؑ نے جواب دیا کہ میں نے اس کام کو اس وقت کیا تھا جبکہ میں راہ بھولے ہوئے لوگوں میں سے تھا 1
26,21,فَفَرَرْتُ مِنْكُمْ لَمَّا خِفْتُكُمْ فَوَهَبَ لِیْ رَبِّیْ حُكْمًا وَّ جَعَلَنِیْ مِنَ الْمُرْسَلِیْنَ فَفَرَرْتُ : تو میں بھاگ گیا مِنْكُمْ : تم سے لَمَّا خِفْتُكُمْ : جب میں ڈرا تم سے فَوَهَبَ لِيْ : پس عطا کیا مجھے رَبِّيْ : میرا رب حُكْمًا : حکم وَّ : اور جَعَلَنِيْ : مجھے بنایا مِنَ : سے الْمُرْسَلِيْنَ : رسول (جمع) پھر تم سے خوف کھا کر میں تم میں سے بھاگ گیا، پھر مجھے میرے رب نے حکم و علم عطا فرمایا اور مجھے پیغمبروں میں سے کردیا 1
26,22,وَ تِلْكَ نِعْمَةٌ تَمُنُّهَا عَلَیَّ اَنْ عَبَّدْتَّ بَنِیْۤ اِسْرَآءِیْلَؕ وَتِلْكَ : اور یہ نِعْمَةٌ : کوئی نعمت تَمُنُّهَا عَلَيَّ : تو اس کا احسان رکھتا ہے مجھ پر اَنْ عَبَّدْتَّ : کہ تونے غلام بنایا بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل مجھ پر تیرا کیا یہی وہ احسان ہے ؟ جسے تو جتلا رہا ہے کہ تو نے بنی اسرائیل کو غلام بنا رکھا ہے 1
26,23,قَالَ فِرْعَوْنُ وَ مَا رَبُّ الْعٰلَمِیْنَؕ قَالَ فِرْعَوْنُ : فرعون نے کہا وَمَا : اور کیا ہے رَبُّ : رب الْعٰلَمِيْنَ : سارے جہان فرعون نے کہا رب العالمین کیا (چیز) ہے ؟ 1
26,24,قَالَ رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا١ؕ اِنْ كُنْتُمْ مُّوْقِنِیْنَ قَالَ : اس نے کہا رَبُّ السَّمٰوٰتِ : رب ہے آسمانوں کا وَالْاَرْضِ : اور زمین وَمَا بَيْنَهُمَا : اور جو ان کے درمیان اِنْ : اگر كُنْتُمْ : تم ہو مُّوْقِنِيْنَ : یقین کرنے والے (حضرت) موسیٰ ؑ نے فرمایا وہ آسمانوں اور زمین اور ان کے درمیان کی تمام چیزوں کا رب ہے، اگر تم یقین رکھنے والے ہو۔
26,25,قَالَ لِمَنْ حَوْلَهٗۤ اَلَا تَسْتَمِعُوْنَ قَالَ : اس نے کہا لِمَنْ : انہیں جو حَوْلَهٗٓ : اس کے اردگرد اَلَا تَسْتَمِعُوْنَ : کیا تم سنتے نہیں فرعون نے اپنے گرد والوں سے کہا کیا تم سن نہیں رہے ؟ 1
26,26,قَالَ رَبُّكُمْ وَ رَبُّ اٰبَآئِكُمُ الْاَوَّلِیْنَ قَالَ : (موسی) نے کہا رَبُّكُمْ : تمہارا رب وَرَبُّ : اور رب اٰبَآئِكُمُ : تمہارے باپ دادا الْاَوَّلِيْنَ : پہلے (حضرت موسیٰ ؑ نے فرمایا وہ تمہارا اور تمہارے اگلے باپ دادوں کا پروردگار ہے۔
26,27,قَالَ اِنَّ رَسُوْلَكُمُ الَّذِیْۤ اُرْسِلَ اِلَیْكُمْ لَمَجْنُوْنٌ قَالَ : فرعون بولا اِنَّ : بیشک رَسُوْلَكُمُ : تمہارا رسول الَّذِيْٓ : وہ جو اُرْسِلَ : بھیجا گیا اِلَيْكُمْ : تمہاری طرف لَمَجْنُوْنٌ : البتہ دیوانہ فرعون نے کہا (لوگو !) تمہارا یہ رسول جو تمہاری طرف بھیجا گیا ہے یہ تو یقیناً دیوانہ ہے۔
26,28,قَالَ رَبُّ الْمَشْرِقِ وَ الْمَغْرِبِ وَ مَا بَیْنَهُمَا١ؕ اِنْ كُنْتُمْ تَعْقِلُوْنَ قَالَ : (موسی) نے کہا رَبُّ : رب الْمَشْرِقِ : مشرق وَالْمَغْرِبِ : اور مغرب وَمَا : اور جو بَيْنَهُمَا : ان دونوں کے درمیان اِنْ : اگر كُنْتُمْ تَعْقِلُوْنَ : تم سمجھتے ہو (حضرت) موسیٰ ؑ نے فرمایا مشرق و مغرب کا اور ان کے درمیان کی تمام چیزوں کا رب 1 ہے، اگر تم عقل رکھتے ہو۔
26,29,قَالَ لَئِنِ اتَّخَذْتَ اِلٰهًا غَیْرِیْ لَاَجْعَلَنَّكَ مِنَ الْمَسْجُوْنِیْنَ قَالَ : وہ بولا لَئِنِ : البتہ اگر اتَّخَذْتَ : تونے بنایا اِلٰهًا : کوئی معبود غَيْرِيْ : میرے سوا لَاَجْعَلَنَّكَ : تو میں ضرور کردوں گا تجھے مِنَ : سے الْمَسْجُوْنِيْنَ : قیدی (جمع) فرعون کہنے لگا سن لے ! اگر تو نے میرے سوا کسی اور کو معبود بنایا تو میں تجھے قیدیوں میں ڈال دونگا 1
26,30,قَالَ اَوَ لَوْ جِئْتُكَ بِشَیْءٍ مُّبِیْنٍۚ قَالَ : (موسی) نے کہا اَوَلَوْ جِئْتُكَ : خواہ میں لاؤں تیرے پاس بِشَيْءٍ مُّبِيْنٍ : ایک شے (معجزہ) واضح مو سٰی ؑ نے کہا اگرچہ میں تیرے پاس کوئی کھلی چیز لے آؤں ؟ 1
26,31,قَالَ فَاْتِ بِهٖۤ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ قَالَ : وہ بولا فَاْتِ بِهٖٓ : تو لے آ اسے اِنْ كُنْتَ : اگر تو ہے مِنَ : سے الصّٰدِقِيْنَ : سچے فرعوں نے کہا اگر تو سچوں میں سے ہے تو اسے پیش کر۔
26,32,فَاَلْقٰى عَصَاهُ فَاِذَا هِیَ ثُعْبَانٌ مُّبِیْنٌۚۖ فَاَلْقٰى : پس موسیٰ نے ڈالا عَصَاهُ : اپنا عصا فَاِذَا هِىَ : تو اچانک وہ ثُعْبَانٌ : اژدہا مُّبِيْنٌ : کھلا (نمایاں آپ نے (اسی وقت) اپنی لاٹھی ڈال دی جو اچانک کھلم کھلا (زبردست) اژدھا بن گئی 1
26,33,وَّ نَزَعَ یَدَهٗ فَاِذَا هِیَ بَیْضَآءُ لِلنّٰظِرِیْنَ۠    ۧ وَّنَزَعَ : اور اس نے کھینچا (نکالا) يَدَهٗ : اپنا ہاتھ فَاِذَا هِىَ : تو ناگاہ وہ بَيْضَآءُ : چمکتا ہوا لِلنّٰظِرِيْنَ : دیکھنے والوں کے لیے اور اپنا ہاتھ کھینچ نکالا تو وہ بھی اسی وقت دیکھنے والے کو سفید چمکیلا نظر آنے لگا 1
26,34,قَالَ لِلْمَلَاِ حَوْلَهٗۤ اِنَّ هٰذَا لَسٰحِرٌ عَلِیْمٌۙ قَالَ : فرعون نے کہا لِلْمَلَاِ : سرداروں سے حَوْلَهٗٓ : اپنے گرد اِنَّ ھٰذَا : بیشک یہ لَسٰحِرٌ : جادوگر عَلِيْمٌ : دانا، ماہر فرعون اپنے آس پاس کے سرداروں سے کہنے لگا بھئی یہ تو کوئی بڑا دانا جادوگر ہے 1
26,35,یُّرِیْدُ اَنْ یُّخْرِجَكُمْ مِّنْ اَرْضِكُمْ بِسِحْرِهٖ١ۖۗ فَمَا ذَا تَاْمُرُوْنَ يُّرِيْدُ : وہ چاہتا ہے اَنْ : کہ يُّخْرِجَكُمْ : تمہیں نکال دے مِّنْ : سے اَرْضِكُمْ : تمہاری سرزمین بِسِحْرِهٖ : اپنے جادو سے فَمَاذَا : تو کیا تَاْمُرُوْنَ : تم حکم (مشورہ) دیتے ہو یہ تو چاہتا ہے کہ اپنے جادو کے زور سے تمہیں تمہاری سرزمین سے ہی نکال دے، بتاؤ اب تم کیا حکم دیتے ہو 1۔
26,36,قَالُوْۤا اَرْجِهْ وَ اَخَاهُ وَ ابْعَثْ فِی الْمَدَآئِنِ حٰشِرِیْنَۙ قَالُوْٓا : وہ بولے اَرْجِهْ : مہلت دے اسے وَاَخَاهُ : اور اس کے بھائی کو وَابْعَثْ : اور بھیج فِي : میں الْمَدَآئِنِ : شہروں (جمع) حٰشِرِيْنَ : اکٹھا کرنے والے (نقیب) ان سب نے کہا آپ اسے اور اس کے بھائی کو مہلت دیجئے اور تمام شہروں میں ہر کارے بھیج دیجئے۔
26,37,یَاْتُوْكَ بِكُلِّ سَحَّارٍ عَلِیْمٍ يَاْتُوْكَ : لے آئیں تیرے پاس بِكُلِّ سَحَّارٍ : تمام بڑے جادوگر عَلِيْمٍ : ماہر جو آپ کے پاس ذی علم جادوگروں کو لے آئیں 1
26,38,فَجُمِعَ السَّحَرَةُ لِمِیْقَاتِ یَوْمٍ مَّعْلُوْمٍۙ فَجُمِعَ : پس جمع کیے گئے السَّحَرَةُ : جادوگر لِمِيْقَاتِ : مقررہ وقت پر يَوْمٍ : ایک دن مَّعْلُوْمٍ : جانے پہچانے (معین) پھر ایک مقرر دن کے وعدے پر تمام جادوگر جمع کئے گئے 1
26,39,وَّ قِیْلَ لِلنَّاسِ هَلْ اَنْتُمْ مُّجْتَمِعُوْنَۙ وَّقِيْلَ : اور کہا گیا لِلنَّاسِ : لوگوں سے هَلْ : کیا اَنْتُمْ : تم مُّجْتَمِعُوْنَ : جمع ہونے ہو (جمع ہوگے) اور عام لوگوں سے بھی کہہ دیا گیا کہ تم بھی مجمع میں حاضر ہوجاؤ گے ؟ 1
26,40,لَعَلَّنَا نَتَّبِعُ السَّحَرَةَ اِنْ كَانُوْا هُمُ الْغٰلِبِیْنَ لَعَلَّنَا : تاکہ ہم نَتَّبِعُ : پیروی کریں السَّحَرَةَ : جادوگر (جمع) اِنْ : اگر كَانُوْا هُمُ : ہوں وہ الْغٰلِبِيْنَ : غالب (جمع) تاکہ اگر جادوگر غالب آجائیں تو ہم انکی پیروی کریں۔
26,41,فَلَمَّا جَآءَ السَّحَرَةُ قَالُوْا لِفِرْعَوْنَ اَئِنَّ لَنَا لَاَجْرًا اِنْ كُنَّا نَحْنُ الْغٰلِبِیْنَ فَلَمَّا : پس جب جَآءَ : آئے السَّحَرَةُ : جادوگر قَالُوْا : انہوں نے کہا لِفِرْعَوْنَ : فرعون سے اَئِنَّ لَنَا : کیا یقیناً ہمارے لیے لَاَجْرًا : کچھ انعام اِنْ : اگر كُنَّا : ہم ہوئے نَحْنُ : ہم الْغٰلِبِيْنَ : غالب (جمع) جادوگر آکر فرعون سے کہنے لگے کہ اگر ہم جیت گئے تو ہمیں کچھ انعام بھی ملے گا ؟
26,42,قَالَ نَعَمْ وَ اِنَّكُمْ اِذًا لَّمِنَ الْمُقَرَّبِیْنَ قَالَ : اس نے کہا نَعَمْ : ہاں وَاِنَّكُمْ : اور بیشک تم اِذًا : اس وقت لَّمِنَ : البتہ۔ سے الْمُقَرَّبِيْنَ : مقربین فرعون نے کہا ہاں ! (بڑی خوشی سے) بلکہ ایسی صورت میں تم میرے خاص درباری بن جاؤ گے۔
26,43,قَالَ لَهُمْ مُّوْسٰۤى اَلْقُوْا مَاۤ اَنْتُمْ مُّلْقُوْنَ قَالَ : کہا لَهُمْ : ان سے مُّوْسٰٓي : موسیٰ اَلْقُوْا : تم ڈالو مَآ : جو اَنْتُمْ : تم مُّلْقُوْنَ : ڈالنے والے (حضرت) موسیٰ ؑ نے جادوگروں سے فرمایا جو کچھ تمہیں ڈالنا ہے ڈال دو 1۔
26,44,فَاَلْقَوْا حِبَالَهُمْ وَ عِصِیَّهُمْ وَ قَالُوْا بِعِزَّةِ فِرْعَوْنَ اِنَّا لَنَحْنُ الْغٰلِبُوْنَ فَاَلْقَوْا : پس انہوں نے ڈالیں حِبَالَهُمْ : اپنی رسیاں وَعِصِيَّهُمْ : اور اپنی لاٹھیاں وَقَالُوْا : اور بولے وہ بِعِزَّةِ : اقبال کی قسم فِرْعَوْنَ : فرعون اِنَّا لَنَحْنُ : بیشک البتہ ہم الْغٰلِبُوْنَ : غالب آنے والے انہوں نے اپنی رسیاں اور لاٹھیاں ڈال دیں اور کہنے لگے عزت فرعون کی قسم ! ہم یقیناً غالب ہی رہیں گے 1
26,45,فَاَلْقٰى مُوْسٰى عَصَاهُ فَاِذَا هِیَ تَلْقَفُ مَا یَاْفِكُوْنَۚۖ فَاَلْقٰى : پس ڈالا مُوْسٰي : موسیٰ عَصَاهُ : اپنا عصا فَاِذَا هِىَ : تو نگاہ وہ تَلْقَفُ : نگلنے لگا مَا : جو يَاْفِكُوْنَ : انہوں نے ڈھکوسلا بنایا اب (حضرت) موسیٰ ؑ نے بھی اپنی لاٹھی میدان میں ڈال دی جس نے اسی وقت ان کے جھوٹ موٹ کے کرتب کو نگلنا شروع کردیا۔
26,46,فَاُلْقِیَ السَّحَرَةُ سٰجِدِیْنَۙ فَاُلْقِيَ السَّحَرَةُ : پس ڈالدئیے گئے (گر پڑے) سٰجِدِيْنَ : سجدہ کرتے ہوئے یہ دیکھتے ہی جادوگر بےاختیار سجدے میں گرگئے۔
26,47,قَالُوْۤا اٰمَنَّا بِرَبِّ الْعٰلَمِیْنَۙ قَالُوْٓا : وہ بولے اٰمَنَّا : ہم ایمان لائے بِرَبِّ الْعٰلَمِيْنَ : سارے جہانوں کے رب پر اور انہوں نے صاف کہہ دیا کہ ہم تو اللہ رب العالمین پر ایمان لائے۔
26,48,رَبِّ مُوْسٰى وَ هٰرُوْنَ رَبِّ : رب مُوْسٰي : موسیٰ وَهٰرُوْنَ : اور ہارون یعنی موسیٰ ؑ اور ہارون کے رب پر۔
26,49,قَالَ اٰمَنْتُمْ لَهٗ قَبْلَ اَنْ اٰذَنَ لَكُمْ١ۚ اِنَّهٗ لَكَبِیْرُكُمُ الَّذِیْ عَلَّمَكُمُ السِّحْرَ١ۚ فَلَسَوْفَ تَعْلَمُوْنَ١ؕ۬ لَاُقَطِّعَنَّ اَیْدِیَكُمْ وَ اَرْجُلَكُمْ مِّنْ خِلَافٍ وَّ لَاُوصَلِّبَنَّكُمْ اَجْمَعِیْنَۚ قَالَ : (فرعون) نے کہا اٰمَنْتُمْ لَهٗ : تم ایمان لائے اس پر قَبْلَ : پہلے اَنْ : کہ میں اٰذَنَ : اجازت دوں لَكُمْ : تمہیں اِنَّهٗ : بیشک وہ لَكَبِيْرُكُمُ : البتہ بڑا ہے تمہارا الَّذِيْ : جس نے عَلَّمَكُمُ : سکھایا ت میں السِّحْرَ : جادو فَلَسَوْفَ : پس جلد تَعْلَمُوْنَ : تم جان لو گے لَاُقَطِّعَنَّ : البتہ میں ضرور کاٹ ڈالوں گا اَيْدِيَكُمْ : تمہارے ہاتھ وَاَرْجُلَكُمْ : اور تمہارے پاؤں مِّنْ : سے۔ کے خِلَافٍ : ایکدوسرے کے خلاف کا وَّلَاُوصَلِّبَنَّكُمْ : اور ضرور تمہیں سولی دوں گا اَجْمَعِيْنَ : سب کو فرعون نے کہا کہ میری اجازت سے پہلے تم اس پر ایمان لے آئے ؟ یقیناً یہی تمہارا بڑا (سردار) ہے جس نے تم سب کو جادو سکھایا 1 سو تمہیں ابھی ابھی معلوم ہوجائے گا، قسم ہے میں ابھی تمہارے ہاتھ پاؤں الٹے طور پر کاٹ دونگا اور تم سب کو سولی پر لٹکا دونگا۔ 2
26,50,قَالُوْا لَا ضَیْرَ١٘ اِنَّاۤ اِلٰى رَبِّنَا مُنْقَلِبُوْنَۚ قَالُوْا : وہ بولے لَا ضَيْرَ : کچھ نقصان (حرج) نہیں اِنَّآ : بیشک ہم اِلٰى رَبِّنَا : اپنے رب کی طرف مُنْقَلِبُوْنَ : لوٹ کر جانے والے ہیں انہوں نے کہا کوئی حرج نہیں 1 ہم تو اپنے رب کی طرف لوٹنے والے ہیں ہی۔
26,51,اِنَّا نَطْمَعُ اَنْ یَّغْفِرَ لَنَا رَبُّنَا خَطٰیٰنَاۤ اَنْ كُنَّاۤ اَوَّلَ الْمُؤْمِنِیْنَؕ۠    ۧ اِنَّا نَطْمَعُ : بیشک ہم امید رکھتے ہیں اَنْ : کہ يَّغْفِرَ : بخش دے لَنَا : ہمیں رَبُّنَا : ہمارا رب خَطٰيٰنَآ : ہماری خطائیں اَنْ كُنَّآ : کہ ہم ہیں اَوَّلَ : پہلے الْمُؤْمِنِيْنَ : ایمان لانے والے اس بنا پر کہ ہم سب سے پہلے ایمان والے بنے ہیں 1 ہمیں امید پڑتی ہے کہ ہمارا رب ہماری سب خطائیں معاف فرما دے گا۔
26,52,وَ اَوْحَیْنَاۤ اِلٰى مُوْسٰۤى اَنْ اَسْرِ بِعِبَادِیْۤ اِنَّكُمْ مُّتَّبَعُوْنَ وَاَوْحَيْنَآ : اور ہم نے وحی کی اِلٰى : طرف مُوْسٰٓي : موسیٰ اَنْ اَسْرِ : کہ راتوں رات لے نکل بِعِبَادِيْٓ : میرے بندوں کو اِنَّكُمْ : بیشک تم مُّتَّبَعُوْنَ : پیچھا کیے جاؤگے اور ہم نے موسیٰ کو وحی کی کہ راتوں رات میرے بندوں کو نکال لے چل تم سب پیچھا کئے جاؤ گے 1
26,53,فَاَرْسَلَ فِرْعَوْنُ فِی الْمَدَآئِنِ حٰشِرِیْنَۚ فَاَرْسَلَ : پس بھیجا فِرْعَوْنُ : فرعون نے فِي الْمَدَآئِنِ : شہروں میں حٰشِرِيْنَ : اکٹھا کرنے والے (نقیب) فرعون نے شہروں میں ہر کاروں کو بھیج دیا۔
26,54,اِنَّ هٰۤؤُلَآءِ لَشِرْذِمَةٌ قَلِیْلُوْنَۙ اِنَّ : بیشک هٰٓؤُلَآءِ : یہ لوگ ہیں لَشِرْذِمَةٌ : ایک جماعت قَلِيْلُوْنَ : تھوڑی سی کہ یقیناً یہ گروہ بہت ہی کم تعداد میں ہے 1
26,55,وَ اِنَّهُمْ لَنَا لَغَآئِظُوْنَۙ وَاِنَّهُمْ : اور بیشک وہ لَنَا : ہمیں لَغَآئِظُوْنَ : غصہ میں لانے والے ہیں اور اس پر یہ ہمیں سخت غضبناک کر رہے ہیں 1
26,56,وَ اِنَّا لَجَمِیْعٌ حٰذِرُوْنَؕ وَاِنَّا : اور بیشک ہم لَجَمِيْعٌ : ایک جماعت حٰذِرُوْنَ : مسلح۔ محتاط اور یقیناً ہم بڑی جماعت ہیں ان سے چوکنا رہنے والے 1
26,57,فَاَخْرَجْنٰهُمْ مِّنْ جَنّٰتٍ وَّ عُیُوْنٍۙ فَاَخْرَجْنٰهُمْ : پس ہم نے انہیں نکالا مِّنْ : سے جَنّٰتٍ : باغات وَّعُيُوْنٍ : اور چشمے بالآخر ہم نے انھیں باغات سے اور چشموں سے۔
26,58,وَّ كُنُوْزٍ وَّ مَقَامٍ كَرِیْمٍۙ وَّكُنُوْزٍ : اور خزانے وَّمَقَامٍ : اور ٹھکانے كَرِيْمٍ : عمدہ اور خزانوں سے۔ اور اچھے اچھے مقامات سے نکال باہر کیا 1
26,59,كَذٰلِكَ١ؕ وَ اَوْرَثْنٰهَا بَنِیْۤ اِسْرَآءِیْلَؕ كَذٰلِكَ : اسی طرح وَاَوْرَثْنٰهَا : اور ہم نے وراث بنایا ان کا بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل اسی طرح ہوا اور ہم نے ان (تمام) چیزوں کا وارث بنی اسرائیل کو بنادیا 1
26,60,فَاَتْبَعُوْهُمْ مُّشْرِقِیْنَ فَاَتْبَعُوْهُمْ : پس انہوں نے پیچھا کیا ان کا مُّشْرِقِيْنَ : سورج نکلتے پس فرعونی سورج نکلتے ہی ان کے تعاقب میں نکلے 1
26,61,فَلَمَّا تَرَآءَ الْجَمْعٰنِ قَالَ اَصْحٰبُ مُوْسٰۤى اِنَّا لَمُدْرَكُوْنَۚ فَلَمَّا : پس جب تَرَآءَ : دیکھا ایکدوسرے کو الْجَمْعٰنِ : دونوں جماعتیں قَالَ : کہا (کہنے لگے) اَصْحٰبُ مُوْسٰٓي : موسیٰ کے ساتھی اِنَّا : یقیناً ہم لَمُدْرَكُوْنَ : پکڑ لیے گئے پس جب دونوں نے ایک دوسرے کو دیکھ لیا، تو موسیٰ کے ساتھیوں نے کہا، ہم یقیناً پکڑ لئے گئے 1
26,62,قَالَ كَلَّا١ۚ اِنَّ مَعِیَ رَبِّیْ سَیَهْدِیْنِ قَالَ كَلَّا : اس نے کہا ہرگز نہیں اِنَّ : بیشک مَعِيَ : میرے ساتھ رَبِّيْ : میرا رب سَيَهْدِيْنِ : وہ جلد مجھے راہ دکھائیگا موسٰی نے کہا، ہرگز نہیں۔ یقین مانو، میرا رب میرے ساتھ ہے جو ضرور مجھے راہ دکھائے گا 1
26,63,فَاَوْحَیْنَاۤ اِلٰى مُوْسٰۤى اَنِ اضْرِبْ بِّعَصَاكَ الْبَحْرَ١ؕ فَانْفَلَقَ فَكَانَ كُلُّ فِرْقٍ كَالطَّوْدِ الْعَظِیْمِۚ فَاَوْحَيْنَآ : پس ہم نے وحی بھیجی اِلٰى : طرف مُوْسٰٓي : موسیٰ اَنِ : کہ اضْرِبْ : تو مار بِّعَصَاكَ : اپنا عصا الْبَحْرَ : دریا فَانْفَلَقَ : تو وہ پھٹ گیا فَكَانَ : پس ہوگیا كُلُّ فِرْقٍ : ہر حصہ كَالطَّوْدِ : پہاڑ کی طرح الْعَظِيْمِ : بڑے ہم نے موسیٰ کی طرف وحی بھیجی کہ دریا پر اپنی لاٹھی مارو 1 پس اس وقت دریا پھٹ گیا اور ہر ایک حصہ پانی کا مثل بڑے پہاڑ کے ہوگیا۔ 2
26,64,وَ اَزْلَفْنَا ثَمَّ الْاٰخَرِیْنَۚ وَاَزْلَفْنَا : پھر ہم نے قریب کردیا ثَمَّ : اس جگہ الْاٰخَرِيْنَ : دوسروں کو اور ہم نے اسی جگہ دوسروں کو نزدیک لا کھڑا کردیا 1۔
26,65,وَ اَنْجَیْنَا مُوْسٰى وَ مَنْ مَّعَهٗۤ اَجْمَعِیْنَۚ وَاَنْجَيْنَا : اور ہم نے بچالیا مُوْسٰي : موسیٰ وَمَنْ : اور جو مَّعَهٗٓ : اس کے ساتھ اَجْمَعِيْنَ : سب اور موسیٰ ؑ اور ان پر ایمان لانے والوں کو ہم نے نجات دی۔
26,66,ثُمَّ اَغْرَقْنَا الْاٰخَرِیْنَؕ ثُمَّ : پھر اَغْرَقْنَا : ہم نے غرق کردیا الْاٰخَرِيْنَ : دوسروں کو پھر اور سب دوسروں کو ڈبو دیا 1
26,67,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا : اور نہ كَانَ : تھے اَكْثَرُهُمْ : ان سے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے یقیناً اس میں بڑی عبرت ہے اور ان میں کے اکثر لوگ ایمان والے نہیں 1۔
26,68,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان اور بیشک آپ کا رب بڑا ہی غالب و مہربان ہے۔
26,69,وَ اتْلُ عَلَیْهِمْ نَبَاَ اِبْرٰهِیْمَۘ وَاتْلُ : اور آپ پڑھیں عَلَيْهِمْ : ان پر۔ انہیں نَبَاَ : خبر۔ واقعہ اِبْرٰهِيْمَ : ابراہیم انہیں ابراہیم ؑ کا واقعہ بھی سنا دو۔
26,70,اِذْ قَالَ لِاَبِیْهِ وَ قَوْمِهٖ مَا تَعْبُدُوْنَ اِذْ : جب قَالَ : اس نے کہا لِاَبِيْهِ : اپنے باپ کو وَقَوْمِهٖ : اور اپنی قوم مَا : کیا۔ کس تَعْبُدُوْنَ : تم پرستش کرتے ہو جبکہ انہوں نے اپنے باپ اور اپنی قوم سے فرمایا کہ تم کس کی عبادت کرتے ہو ؟
26,71,قَالُوْا نَعْبُدُ اَصْنَامًا فَنَظَلُّ لَهَا عٰكِفِیْنَ قَالُوْا : انہوں نے کہا نَعْبُدُ : ہم پرستش کرتے ہیں اَصْنَامًا : بتوں کی فَنَظَلُّ : پس ہم بیٹھے رہتے ہیں ان کے پاس لَهَا : ان کے پاس عٰكِفِيْنَ : جمے ہوئے انہوں نے جواب دیا کہ عبادت کرتے ہیں بتوں کی، ہم تو برابر ان کے مجاور بنے بیٹھے ہیں 1
26,72,قَالَ هَلْ یَسْمَعُوْنَكُمْ اِذْ تَدْعُوْنَۙ قَالَ : اس نے کہا هَلْ : کیا يَسْمَعُوْنَكُمْ : وہ سنتے ہیں تمہاری اِذْ : جب تَدْعُوْنَ : تم پکارتے ہو آپ نے فرمایا کہ جب تم انھیں پکارتے ہو تو کیا وہ سنتے بھی ہیں ؟
26,73,اَوْ یَنْفَعُوْنَكُمْ اَوْ یَضُرُّوْنَ اَوْ يَنْفَعُوْنَكُمْ : یا وہ نفع پہنچاتے ہیں تمہیں اَوْ يَضُرُّوْنَ : یا وہ نقصان پہنچاتے ہیں یا تمہیں نفع نقصان بھی پہنچا سکتے ہیں 1۔
26,74,قَالُوْا بَلْ وَجَدْنَاۤ اٰبَآءَنَا كَذٰلِكَ یَفْعَلُوْنَ قَالُوْا : وہ بولے بَلْ : بلکہ وَجَدْنَآ : ہم نے پایا اٰبَآءَنَا : اپنے باپ دادا كَذٰلِكَ : اسی طرح يَفْعَلُوْنَ : وہ کرتے انہوں نے کہا یہ (ہم کچھ نہیں جانتے) ہم نے تو اپنے باپ دادوں کو اسی طرح کرتے پایا 1
26,75,قَالَ اَفَرَءَیْتُمْ مَّا كُنْتُمْ تَعْبُدُوْنَۙ قَالَ : ابراہیم نے کہا اَفَرَءَيْتُمْ : کیا پس تم نے دیکھا مَّا : کس كُنْتُمْ تَعْبُدُوْنَ : تم پرستش کرتے ہو آپ نے فرمایا کچھ خبر بھی ہے 1 جنہیں تم پوج رہے ہو ؟
26,76,اَنْتُمْ وَ اٰبَآؤُكُمُ الْاَقْدَمُوْنَ٘ۖ اَنْتُمْ : تم وَاٰبَآؤُكُمُ : اور تمہارے باپ دادا الْاَقْدَمُوْنَ : پہلے تم اور تمہارے اگلے باپ دادا،
26,77,فَاِنَّهُمْ عَدُوٌّ لِّیْۤ اِلَّا رَبَّ الْعٰلَمِیْنَۙ فَاِنَّهُمْ : تو بیشک وہ عَدُوٌّ لِّيْٓ : میرے دشمن اِلَّا : مگر رَبَّ الْعٰلَمِيْنَ : سارے جہانوں کا رب وہ سب میرے دشمن ہیں 1 بجز سچے اللہ تعالیٰ کے جو تمام جہان کا پالنہار ہے 2
26,78,الَّذِیْ خَلَقَنِیْ فَهُوَ یَهْدِیْنِۙ الَّذِيْ : وہ جس نے خَلَقَنِيْ : مجھے پیدا کیا فَهُوَ : پس وہ يَهْدِيْنِ : مجھے راہ دکھاتا ہے جس نے مجھے پیدا کیا ہے اور وہی میری رہبری فرماتا ہے 1
26,79,وَ الَّذِیْ هُوَ یُطْعِمُنِیْ وَ یَسْقِیْنِۙ وَالَّذِيْ : اور وہ جو هُوَ : وہ يُطْعِمُنِيْ : مجھے کھلاتا ہے وَيَسْقِيْنِ : اور مجھے پلاتا ہے وہی مجھے کھلاتا پلاتا ہے 1
26,80,وَ اِذَا مَرِضْتُ فَهُوَ یَشْفِیْنِ۪ۙ وَاِذَا : اور جب مَرِضْتُ : میں بیمار ہوتا ہوں فَهُوَ : تو وہ يَشْفِيْنِ : مجھے شفا دیتا ہے اور جب میں بیمار پڑجاؤں تو مجھے شفا عطا فرماتا ہے 1
26,81,وَ الَّذِیْ یُمِیْتُنِیْ ثُمَّ یُحْیِیْنِۙ وَالَّذِيْ : اور وہ جو يُمِيْتُنِيْ : مجھے موت دے گا ثُمَّ : پھر يُحْيِيْنِ : مجھے زندہ کرے گا اور وہی مجھے مار ڈالے گا پھر زندہ کردے گا 1
26,82,وَ الَّذِیْۤ اَطْمَعُ اَنْ یَّغْفِرَ لِیْ خَطِیْٓئَتِیْ یَوْمَ الدِّیْنِؕ وَالَّذِيْٓ : اور وہ جس سے اَطْمَعُ : میں امید رکھتا ہوں اَنْ يَّغْفِرَ لِيْ : کہ مجھے بخش دے گا خَطِيْٓئَتِي : میری خطائیں يَوْمَ الدِّيْنِ : بدلہ کے دن اور جس سے امید بندھی ہوئی ہے کہ وہ روز جزا میں میرے گناہوں کو بخش دے گا 1
26,83,رَبِّ هَبْ لِیْ حُكْمًا وَّ اَلْحِقْنِیْ بِالصّٰلِحِیْنَۙ رَبِّ : اے میرے رب هَبْ لِيْ : مجھے عطا کر حُكْمًا : حکم۔ حکمت وَّاَلْحِقْنِيْ : اور مجھے ملا دے بِالصّٰلِحِيْنَ : نیک بندوں کے ساتھ اے میرے رب ! مجھے قوت فیصلہ 1 عطا فرما اور مجھے نیک لوگوں میں ملا دے۔
26,84,وَ اجْعَلْ لِّیْ لِسَانَ صِدْقٍ فِی الْاٰخِرِیْنَۙ وَاجْعَلْ : اور کر لِّيْ لِسَانَ : میرے لیے۔ میرا ذکر صِدْقٍ : اچھا۔ خیر فِي الْاٰخِرِيْنَ : بعد میں آنے والوں میں اور میرا ذکر خیر پچھلے لوگوں میں بھی باقی رکھ 1
26,85,وَ اجْعَلْنِیْ مِنْ وَّرَثَةِ جَنَّةِ النَّعِیْمِۙ وَاجْعَلْنِيْ : اور تو مجھے بنا دے مِنْ وَّرَثَةِ : وارثوں میں سے جَنَّةِ : بہشت النَّعِيْمِ : نعمتوں والی مجھے نعمتوں والی جنت کے وارثوں میں سے بنادے۔
26,86,وَ اغْفِرْ لِاَبِیْۤ اِنَّهٗ كَانَ مِنَ الضَّآلِّیْنَۙ وَاغْفِرْ : اور بخشدے لِاَبِيْٓ : میرے باپ کو اِنَّهٗ : بیشک وہ كَانَ : وہ ہے مِنَ : سے الضَّآلِّيْنَ : گمراہ (جمع) اور میرے باپ کو بخش دے یقیناً وہ گمراہوں میں سے تھا 1
26,87,وَ لَا تُخْزِنِیْ یَوْمَ یُبْعَثُوْنَۙ وَلَا تُخْزِنِيْ : اور مجھے رسوا نہ کرنا يَوْمَ يُبْعَثُوْنَ : جس دن سب اٹھائے جائیں گے اور جس دن کہ لوگ دوبارہ جلائے جائیں مجھے رسوا نہ کر 1
26,88,یَوْمَ لَا یَنْفَعُ مَالٌ وَّ لَا بَنُوْنَۙ يَوْمَ : جس دن لَا يَنْفَعُ : نہ کام آئے گا مَالٌ : مال وَّلَا : اور نہ بَنُوْنَ : بیٹے جس دن کہ مال اور اولاد کچھ کام نہ آئے گی۔
26,89,اِلَّا مَنْ اَتَى اللّٰهَ بِقَلْبٍ سَلِیْمٍؕ اِلَّا : مگر مَنْ : جو اَتَى اللّٰهَ : اللہ کے پاس آیا بِقَلْبٍ : دل سَلِيْمٍ : پاک لیکن فائدہ والا وہی ہوگا جو اللہ تعالیٰ کے سامنے بےعیب دل لے کر جائے 1
26,90,وَ اُزْلِفَتِ الْجَنَّةُ لِلْمُتَّقِیْنَۙ وَاُزْلِفَتِ : اور نزدیک کردی جائے گی الْجَنَّةُ : جنت لِلْمُتَّقِيْنَ : پرہیزگاروں کے لیے اور پرہیزگاروں کے لئے جنت بالکل نزدیک لا دی جائے گی۔
26,91,وَ بُرِّزَتِ الْجَحِیْمُ لِلْغٰوِیْنَۙ وَبُرِّزَتِ : اور ظاہر کردی جائے گی الْجَحِيْمُ : دوزخ لِلْغٰوِيْنَ : گمراہوں کے لیے اور گمراہ لوگوں کے لئے جہنم ظاہر کردی جائے گی 1
26,92,وَ قِیْلَ لَهُمْ اَیْنَمَا كُنْتُمْ تَعْبُدُوْنَۙ وَقِيْلَ : اور کہا جائے گا لَهُمْ : انہیں اَيْنَ مَا : کہاں ہیں وہ جو كُنْتُمْ تَعْبُدُوْنَ : تم پرستش کرتے تھے اور ان سے پوچھا جائے گا کہ جن کی تم پوجا کرتے رہے وہ کہاں ہیں ؟
26,93,مِنْ دُوْنِ اللّٰهِ١ؕ هَلْ یَنْصُرُوْنَكُمْ اَوْ یَنْتَصِرُوْنَؕ مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا هَلْ : کیا يَنْصُرُوْنَكُمْ : وہ تمہاری مدد کرسکتے ہیں اَوْ يَنْتَصِرُوْنَ : یا بدلہ لے سکتے ہیں جو اللہ تعالیٰ کے سوا تھے، کیا وہ تمہاری مدد کرتے ہیں ؟ یا کوئی بدلہ لے سکتے ہیں 1
26,94,فَكُبْكِبُوْا فِیْهَا هُمْ وَ الْغَاوٗنَۙ فَكُبْكِبُوْا فِيْهَا : پھر اوندھے منہ ڈالے جائیں گے اس میں هُمْ : وہ وَ : اور الْغَاوٗنَ : گمراہ پس وہ سب اور کل گمراہ لوگ جہنم میں اوندھے منہ ڈال دیئے جائیں گے 1۔
26,95,وَ جُنُوْدُ اِبْلِیْسَ اَجْمَعُوْنَؕ وَجُنُوْدُ : اور لشکر (جمع) اِبْلِيْسَ : ابلیس اَجْمَعُوْنَ : سب کے سب اور ابلیس کے تمام لشکر 1 بھی وہاں۔
26,96,قَالُوْا وَ هُمْ فِیْهَا یَخْتَصِمُوْنَۙ قَالُوْا : وہ کہیں گے وَهُمْ : اور وہ فِيْهَا : اس (جہنم) میں يَخْتَصِمُوْنَ : جھگڑتے ہوں گے آپس میں لڑتے جھگڑتے ہوئے کہیں گے۔
26,97,تَاللّٰهِ اِنْ كُنَّا لَفِیْ ضَلٰلٍ مُّبِیْنٍۙ تَاللّٰهِ : قسم اللہ کی اِنۡ : بیشک كُنَّا : تھے ہم لَفِىۡ ضَلٰلٍ : البتہ گمراہی میں مُّبِيۡنٍۙ‏ : کھلی کھلی کہ قسم اللہ کی ! یقیناً ہم تو کھلی غلطی پر تھے۔
26,98,اِذْ نُسَوِّیْكُمْ بِرَبِّ الْعٰلَمِیْنَ اِذْ : جب نُسَوِّيْكُمْ : ہم برابر ٹھہراتے تھے تمہیں بِرَبِّ الْعٰلَمِيْنَ : سارے جہانوں کے رب کے ساتھ جبکہ تمہیں رب العالمین کے برابر سمجھ بیٹھے تھے 1
26,99,وَ مَاۤ اَضَلَّنَاۤ اِلَّا الْمُجْرِمُوْنَ وَمَآ اَضَلَّنَآ : اور نہیں گمراہ کیا ہمیں اِلَّا : مگر (صرف) الْمُجْرِمُوْنَ : مجرم (جمع) اور ہمیں تو سوا ان بدکاروں کے کسی اور نے گمراہ نہیں کیا تھا 1
26,100,فَمَا لَنَا مِنْ شَافِعِیْنَۙ فَمَا لَنَا : پس نہیں ہمارے لیے مِنْ : کوئی شَافِعِيْنَ : سفارش کرنے والا (جمع) اب تو ہمارا کوئی سفارشی بھی نہیں۔
26,101,وَ لَا صَدِیْقٍ حَمِیْمٍ وَلَا صَدِيْقٍ : اور نہ کوئی دوست حَمِيْمٍ : غم خوار اور نہ کوئی (سچا) غم خوار دوست 1۔
26,102,فَلَوْ اَنَّ لَنَا كَرَّةً فَنَكُوْنَ مِنَ الْمُؤْمِنِیْنَ فَلَوْ : پس کاش اَنَّ لَنَا : کہ ہمارے لیے كَرَّةً : لوٹنا فَنَكُوْنَ : تو ہم ہوتے مِنَ : سے الْمُؤْمِنِيْنَ : مومن (جمع) اگر کاش کہ ہمیں ایک مرتبہ پھرجانا ملتا تو ہم پکے سچے مومن بن جاتے۔ 1
26,103,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ ایک نشانی وَمَا كَانَ : اور نہٰں ہیں اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے یہ ماجرہ یقیناً آپ کے لئے ایک زبردست نشانی ہے 1 ان میں اکثر لوگ ایمان لانے والے نہیں 2
26,104,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان یقیناً آپ کا پروردگار ہی غالب مہربان ہے۔
26,105,كَذَّبَتْ قَوْمُ نُوْحِ اِ۟لْمُرْسَلِیْنَۚۖ كَذَّبَتْ : جھٹلایا قَوْمُ نُوْحِ : نوح کی قوم الْمُرْسَلِيْنَ : رسولوں کو قوم نوح نے بھی نبیوں کو جھٹلایا 1
26,106,اِذْ قَالَ لَهُمْ اَخُوْهُمْ نُوْحٌ اَلَا تَتَّقُوْنَۚ اِذْ قَالَ : جب کہا لَهُمْ : ان سے اَخُوْهُمْ : ان کے بھائی نُوْحٌ : نوح اَلَا : کیا نہیں تَتَّقُوْنَ : تم ڈرتے جبکہ ان کے بھائی 1 نوح ؑ نے کہا کہ کیا تمہیں اللہ کا خوف نہیں !
26,107,اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ : رسول اَمِيْنٌ : امانت دار سنو ! میں تمہاری طرف اللہ کا ایماندار رسول ہوں 1
26,108,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا اللّٰهَ : پس ڈرو اللہ سے تم وَاَطِيْعُوْنِ : اور میری اطاعت کرو تمہیں اللہ سے ڈرنا چاہیے اور میری بات ماننی چاہیے 1
26,109,وَ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ١ۚ اِنْ اَجْرِیَ اِلَّا عَلٰى رَبِّ الْعٰلَمِیْنَۚ وَ : اور مَآ اَسْئَلُكُمْ : میں نہیں مانگتا تم سے عَلَيْهِ : اس پر مِنْ : کوئی اَجْرٍ : جر اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر (صرف) عَلٰي : پر رَبِّ الْعٰلَمِيْنَ : رب العالمین میں تم سے اس پر کوئی اجر نہیں چاہتا، میرا بدلہ تو صرف رب العالمین کے ہاں ہے 1
26,110,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِؕ فَاتَّقُوا : پس ڈرو تم اللّٰهَ : اللہ سے وَاَطِيْعُوْنِ : اور میری اطاعت کرو پس تم اللہ کا خوف رکھو اور میری فرمانبرداری کرو 1
26,111,قَالُوْۤا اَنُؤْمِنُ لَكَ وَ اتَّبَعَكَ الْاَرْذَلُوْنَؕ قَالُوْٓا : وہ بولے اَنُؤْمِنُ : کیا ہم ایمان لے آئیں لَكَ : تجھ پر وَاتَّبَعَكَ : جبکہ تیری پیروی کی الْاَرْذَلُوْنَ : رذیلوں نے قوم نے جواب دیا کہ ہم تجھ پر ایمان لائیں ! تیری تابعداری تو رذیل لوگوں نے کی ہے۔ 1
26,112,قَالَ وَ مَا عِلْمِیْ بِمَا كَانُوْا یَعْمَلُوْنَۚ قَالَ : (نوح) نے کہا وَمَا عِلْمِىْ : اور مجھے کیا علم بِمَا : اس کی جو كَانُوْا يَعْمَلُوْنَ : وہ کرتے تھے آپ نے فرمایا ! مجھے کیا خبر کہ وہ پہلے کیا کرتے رہے ؟ 1
26,113,اِنْ حِسَابُهُمْ اِلَّا عَلٰى رَبِّیْ لَوْ تَشْعُرُوْنَۚ اِنْ : نہیں حِسَابُهُمْ : ان کا حساب اِلَّا : مگر۔ صرف عَلٰي رَبِّيْ : میرے رب پر لَوْ : اگر تَشْعُرُوْنَ : تم سمجھو ان کا حساب تو میرے رب کے ذمہ 1 ہے اگر تمہیں شعور ہو تو۔
26,114,وَ مَاۤ اَنَا بِطَارِدِ الْمُؤْمِنِیْنَۚ وَمَآ : اور نہیں اَنَا : میں بِطَارِدِ : ہانکنے والا (دور کرنے والا) الْمُؤْمِنِيْنَ : مومن (جمع) میں ایمان داروں کو دھکے دینے والا نہیں 1
26,115,اِنْ اَنَا اِلَّا نَذِیْرٌ مُّبِیْنٌؕ اِنْ اَنَا : نہیں میں اِلَّا : مگر۔ صرف نَذِيْرٌ : ڈرانے والا مُّبِيْنٌ : صاف طور پر میں تو صاف طور پر ڈرا دینے والا ہوں 1
26,116,قَالُوْا لَئِنْ لَّمْ تَنْتَهِ یٰنُوْحُ لَتَكُوْنَنَّ مِنَ الْمَرْجُوْمِیْنَؕ قَالُوْا : بولے لَئِنْ : اگر لَّمْ تَنْتَهِ : تم باز نہ آئے يٰنُوْحُ : اے نوح لَتَكُوْنَنَّ : تو ضرور ہوگے مِنَ : سے الْمَرْجُوْمِيْنَ : سنگسار کیے جانے والے انہوں نے کہا کہ اے نوح ! اگر تو باز نہ آیا تو یقیناً تجھے سنگسار کردیا جائے گا۔
26,117,قَالَ رَبِّ اِنَّ قَوْمِیْ كَذَّبُوْنِۚۖ قَالَ : (نوح نے) کہا رَبِّ : اے میرے رب اِنَّ : بیشک قَوْمِيْ : میری قوم كَذَّبُوْنِ : مجھے جھٹلایا آپ نے کہا اے میرے پروردگار ! میری قوم نے مجھے جھٹلا دیا۔
26,118,فَافْتَحْ بَیْنِیْ وَ بَیْنَهُمْ فَتْحًا وَّ نَجِّنِیْ وَ مَنْ مَّعِیَ مِنَ الْمُؤْمِنِیْنَ فَافْتَحْ : پس فیصلہ کردے بَيْنِيْ : میرے درمیان وَبَيْنَهُمْ : اور ان کے درمیان فَتْحًا : ایک کھلا فیصلہ وَّنَجِّنِيْ : اور نجات دے مجھے وَمَنْ : اور جو مَّعِيَ : میرے ساتھی مِنَ : سے الْمُؤْمِنِيْنَ : ایمان والے پس تو مجھ میں اور ان میں کوئی قطعی فیصلہ کردے اور مجھے اور میرے باایمان ساتھیوں کو نجات دے۔
26,119,فَاَنْجَیْنٰهُ وَ مَنْ مَّعَهٗ فِی الْفُلْكِ الْمَشْحُوْنِۚ فَاَنْجَيْنٰهُ : تو ہم نے نجات دی اسے وَمَنْ : اور جو مَّعَهٗ : اس کے ساتھ فِي الْفُلْكِ : کشتی میں الْمَشْحُوْنِ : بھری ہوئی چناچہ ہم نے اسے اور اس کے ساتھیوں کو بھری ہوئی کشتی میں (سوار کراکر) نجات دے دی۔
26,120,ثُمَّ اَغْرَقْنَا بَعْدُ الْبٰقِیْنَؕ ثُمَّ : پھر اَغْرَقْنَا : غرق کردیا ہم نے بَعْدُ : اس کے بعد الْبٰقِيْنَ : باقیوں کو بعد ازاں باقی تمام لوگوں کو ڈبو دیا 1
26,121,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا : اور نہ كَانَ : تھے اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے یقیناً اس میں بہت بڑی عبرت ہے۔ ان میں سے اکثر لوگ ایمان لانے والے تھے بھی نہیں۔
26,122,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان اور بیشک آپ کا پروردگار البتہ وہی ہے زبردست رحم کرنے والا۔
26,123,كَذَّبَتْ عَادُ اِ۟لْمُرْسَلِیْنَۚۖ كَذَّبَتْ : جھٹلایا عَادُ : عاد ۨ الْمُرْسَلِيْنَ : رسول (جمع) عادیوں نے بھی رسولوں کو جھٹلایا 1
26,124,اِذْ قَالَ لَهُمْ اَخُوْهُمْ هُوْدٌ اَلَا تَتَّقُوْنَۚ اِذْ قَالَ : جب کہا لَهُمْ : ان سے اَخُوْهُمْ : ان کے بھائی هُوْدٌ : ہود اَلَا تَتَّقُوْنَ : کیا تم ڈرتے نہیں جبکہ ان سے ان کے بھائی ہود 1 نے کہا کہ کیا تم ڈرتے نہیں ؟۔
26,125,اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ : رسول اَمِيْنٌ : امانت دار میں تمہارا امانتدار پیغمبر ہوں۔
26,126,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا اللّٰهَ : سو تم ڈرو اللہ سے وَاَطِيْعُوْنِ : اور میری اطاعت کرو پس اللہ سے ڈرو اور میرا کہا مانو !۔
26,127,وَ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ١ۚ اِنْ اَجْرِیَ اِلَّا عَلٰى رَبِّ الْعٰلَمِیْنَؕ وَمَآ اَسْئَلُكُمْ : اور میں نہیں مانگتا تم سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر۔ صرف عَلٰي : پر رَبِّ الْعٰلَمِيْنَ : رب العالمین میں اس پر تم سے کوئی اجرت طلب نہیں کرتا، میرا ثواب تو تمام جہان کے پروردگار کے ہی پاس ہے۔
26,128,اَتَبْنُوْنَ بِكُلِّ رِیْعٍ اٰیَةً تَعْبَثُوْنَ اَتَبْنُوْنَ : کیا تم تعمیر کرتے ہو بِكُلِّ رِيْعٍ : ہر بلندی پر اٰيَةً : ایک نشانی تَعْبَثُوْنَ : کھیلنے کو (بلا ضرورت) کیا تم ایک ایک ٹیلے پر بطور کھیل تماشہ یادگار (عمارت) بنا رہے ہو 1۔
26,129,وَ تَتَّخِذُوْنَ مَصَانِعَ لَعَلَّكُمْ تَخْلُدُوْنَۚ وَتَتَّخِذُوْنَ : اور تم بناتے ہو مَصَانِعَ : مضبوط۔ شاندار محل) لَعَلَّكُمْ : شاید تم تَخْلُدُوْنَ : تم ہمیشہ رہو گے اور بڑی صنعت والے (مضبوط محل تعمیر) کر رہے ہو، گویا کہ تم ہمیشہ یہیں رہو گے 1
26,130,وَ اِذَا بَطَشْتُمْ بَطَشْتُمْ جَبَّارِیْنَۚ وَاِذَا : اور جب بَطَشْتُمْ : تم گرفت کرتے ہو بَطَشْتُمْ : گرفت کرتے ہو تم جَبَّارِيْنَ : جابر بن کر اور جب کسی پر ہاتھ ڈالتے ہو تو سختی اور ظلم سے پکڑتے ہو 1
26,131,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : پس ڈرو اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور میری اطاعت کرو اللہ سے ڈرو اور میری پیروی کرو 1
26,132,وَ اتَّقُوا الَّذِیْۤ اَمَدَّكُمْ بِمَا تَعْلَمُوْنَۚ وَاتَّقُوا : اور ڈرو الَّذِيْٓ : وہ جس نے اَمَدَّكُمْ : مدد کی تمہاری بِمَا تَعْلَمُوْنَ : اس سے جو تم جانتے ہو اس سے ڈرو جس نے ان چیزوں سے تمہاری امداد کی جنہیں تم نہیں جانتے۔
26,133,اَمَدَّكُمْ بِاَنْعَامٍ وَّ بَنِیْنَۚۙ اَمَدَّكُمْ : تمہاری مدد کی بِاَنْعَامٍ : مویشیوں سے وَّبَنِيْنَ : اور بیٹوں اس نے تمہاری مدد کی مال سے اور اولاد سے۔
26,134,وَ جَنّٰتٍ وَّ عُیُوْنٍۚ وَجَنّٰتٍ : اور باغات وَّعُيُوْنٍ : اور چشمے باغات اور چشموں سے۔
26,135,اِنِّیْۤ اَخَافُ عَلَیْكُمْ عَذَابَ یَوْمٍ عَظِیْمٍؕ اِنِّىْٓ اَخَافُ : بیشک میں ڈرتا ہوں عَلَيْكُمْ : تم پر عَذَابَ : عذاب يَوْمٍ عَظِيْمٍ : ایک بڑا دن مجھے تو تمہاری نسبت بڑے دن کے عذاب کا اندیشہ ہے 1۔
26,136,قَالُوْا سَوَآءٌ عَلَیْنَاۤ اَوَ عَظْتَ اَمْ لَمْ تَكُنْ مِّنَ الْوٰعِظِیْنَۙ قَالُوْا : وہ بولے سَوَآءٌ : برابر عَلَيْنَآ : ہم پر اَوَعَظْتَ : خواہ تم نصیحت کرو اَمْ لَمْ تَكُنْ : یا نہ ہو تم مِّنَ : سے الْوٰعِظِيْنَ : نصیحت کرنے والے انہوں نے کہا کہ آپ وعظ کہیں یا وعظ کہنے والوں میں نہ ہوں ہم یکساں ہیں۔
26,137,اِنْ هٰذَاۤ اِلَّا خُلُقُ الْاَوَّلِیْنَۙ اِنْ ھٰذَآ : نہیں ہے اِلَّا : مگر خُلُقُ : عادت الْاَوَّلِيْنَ : اگلے لوگ یہ تو بس پرانے لوگوں کی عادت ہے 1
26,138,وَ مَا نَحْنُ بِمُعَذَّبِیْنَۚ وَمَا : اور نہیں نَحْنُ : ہم بِمُعَذَّبِيْنَ : عزاب دئیے جانیوالوں سے اور ہم ہرگز عذاب نہیں دیئے جائیں گے 1
26,139,فَكَذَّبُوْهُ فَاَهْلَكْنٰهُمْ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ فَكَذَّبُوْهُ : پس انہوں نے جھٹلایا اسے فَاَهْلَكْنٰهُمْ : تو ہم نے ہلاک کردیا انہیں اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا كَانَ : اور نہیں تھے اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے چونکہ عادیوں نے حضرت ہود کو جھٹلایا، اس لئے ہم نے انھیں تباہ کردیا 1 یقیناً اس میں نشانی ہے اور ان میں سے اکثر بےایمان تھے۔
26,140,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان بیشک آپ کا رب وہی ہے غالب مہربان۔
26,141,كَذَّبَتْ ثَمُوْدُ الْمُرْسَلِیْنَۚۖ كَذَّبَتْ : جھٹلایا ثَمُوْدُ : ثمود الْمُرْسَلِيْنَ : رسول (جمع) ثمودیوں 1 نے بھی پیغمبروں کو جھٹلایا۔
26,142,اِذْ قَالَ لَهُمْ اَخُوْهُمْ صٰلِحٌ اَلَا تَتَّقُوْنَۚ اِذْ : جب قَالَ : کہا لَهُمْ : ان سے اَخُوْهُمْ : ان کے بھائی صٰلِحٌ : صالح اَلَا تَتَّقُوْنَ : کیا تم ڈرتے نہیں ان کے بھائی صالح نے فرمایا کہ کیا تم اللہ سے نہیں ڈرتے ؟
26,143,اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ : رسول اَمِيْنٌ : امانت دار میں تمہاری طرف اللہ کا امانت دار پیغمبر ہوں۔
26,144,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : سو تم ڈرو اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور تم میری اطاعت کرو تو تم اللہ سے ڈرو اور میرا کہا مانو۔
26,145,وَ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ١ۚ اِنْ اَجْرِیَ اِلَّا عَلٰى رَبِّ الْعٰلَمِیْنَؕ وَمَآ اَسْئَلُكُمْ : اور میں نہیں مانگتا تم سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر عَلٰي : پر رَبِّ الْعٰلَمِيْنَ : رب العالمین میں اس پر تم سے کوئی اجرت نہیں مانگتا، میری اجرت تو بس پروردگار عالم پر ہی ہے۔
26,146,اَتُتْرَكُوْنَ فِیْ مَا هٰهُنَاۤ اٰمِنِیْنَۙ اَتُتْرَكُوْنَ : کیا چھوڑ دئیے جاؤگے تم فِيْ : میں مَا هٰهُنَآ : جو یہاں ہے اٰمِنِيْنَ : بےفکر کیا ان چیزوں جو یہاں ہیں تم امن کے ساتھ چھوڑ دیئے جاؤ گے 1
26,147,فِیْ جَنّٰتٍ وَّ عُیُوْنٍۙ فِيْ جَنّٰتٍ : باغات میں وَّعُيُوْنٍ : اور چشمے یعنی ان باغوں اور ان چشموں۔
26,148,وَّ زُرُوْعٍ وَّ نَخْلٍ طَلْعُهَا هَضِیْمٌۚ وَّزُرُوْعٍ : اور کھیتیاں وَّنَخْلٍ : اور کھجوریں طَلْعُهَا : ان کے خوشے هَضِيْمٌ : نرم و نازک اور ان کھیتوں اور ان کھجوروں کے باغوں میں جن کے شگوفے نرم و نازک ہیں 1۔
26,149,وَ تَنْحِتُوْنَ مِنَ الْجِبَالِ بُیُوْتًا فٰرِهِیْنَۚ وَتَنْحِتُوْنَ : اور تم تراشتے ہو مِنَ الْجِبَالِ : پہاڑوں سے بُيُوْتًا : گھر فٰرِهِيْنَ : خوش ہوکر اور تم پہاڑوں کو تراش تراش کر پر تکلف مکانات بنا رہے ہو 1
26,150,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : سو ڈرو تم اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور میری اطاعت کرو پس اللہ سے ڈرو اور میری اطاعت کرو۔
26,151,وَ لَا تُطِیْعُوْۤا اَمْرَ الْمُسْرِفِیْنَۙ وَلَا تُطِيْعُوْٓا : اور نہ کہا مانو اَمْرَ : حکم الْمُسْرِفِيْنَ : حد سے بڑھ جانیوالے بےباک حد سے گزر جانے والوں کی 1 اطاعت سے باز آجاؤ۔
26,152,الَّذِیْنَ یُفْسِدُوْنَ فِی الْاَرْضِ وَ لَا یُصْلِحُوْنَ الَّذِيْنَ : جو لوگ يُفْسِدُوْنَ : فساد کرتے ہیں فِي : میں الْاَرْضِ : زمین وَ : اور لَا يُصْلِحُوْنَ : اصلاح نہیں کرتے جو ملک میں فساد پھیلا رہے ہیں اور اصلاح نہیں کرتے۔
26,153,قَالُوْۤا اِنَّمَاۤ اَنْتَ مِنَ الْمُسَحَّرِیْنَۚ قَالُوْٓا : انہوں نے کہا اِنَّمَآ : اس کے سوا نہیں اَنْتَ : تم مِنَ : سے الْمُسَحَّرِيْنَ : سحر زدہ لوگ وہ بولے کہ بس تو ان میں سے ہے جن پر جادو کردیا گیا ہے۔
26,154,مَاۤ اَنْتَ اِلَّا بَشَرٌ مِّثْلُنَا١ۖۚ فَاْتِ بِاٰیَةٍ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ مَآ اَنْتَ : تم نہیں اِلَّا بَشَرٌ : مگر۔ صرف۔ ایک بشر مِّثْلُنَا : ہم جیسا فَاْتِ : پس لاؤ بِاٰيَةٍ : کوئی نشانی اِنْ : اگر كُنْتَ : تو مِنَ : سے الصّٰدِقِيْنَ : سچے لوگ تو تو ہم جیسا ہی انسان ہے۔ اگر تو سچوں سے ہے تو کوئی معجزہ لے آ۔
26,155,قَالَ هٰذِهٖ نَاقَةٌ لَّهَا شِرْبٌ وَّ لَكُمْ شِرْبُ یَوْمٍ مَّعْلُوْمٍۚ قَالَ : اس نے فرمایا هٰذِهٖ : یہ نَاقَةٌ : اونٹنی لَّهَا : اس کے لیے شِرْبٌ : پانی پینے کی باری وَّلَكُمْ : اور تمہارے لیے شِرْبُ : بایک باری پانی پینے کی يَوْمٍ مَّعْلُوْمٍ : معین دن آپ نے فرمایا یہ ہے اونٹنی، پانی پینے کی ایک باری اس کی اور ایک مقررہ دن کی باری پانی پینے کی تمہاری 1۔
26,156,وَ لَا تَمَسُّوْهَا بِسُوْٓءٍ فَیَاْخُذَكُمْ عَذَابُ یَوْمٍ عَظِیْمٍ وَلَا تَمَسُّوْهَا : اور اسے ہاتھ نہ لگانا بِسُوْٓءٍ : برائی سے فَيَاْخُذَكُمْ : سو (ورنہ) تمہیں آپکڑے گا عَذَابُ : عذاب يَوْمٍ عَظِيْمٍ : ایک بڑا دن (خبر دار) اسے برائی سے ہاتھ نہ لگانا ورنہ ایک بڑے بھاری دن کا عذاب تمہاری گرفت کرلے گا 1
26,157,فَعَقَرُوْهَا فَاَصْبَحُوْا نٰدِمِیْنَۙ فَعَقَرُوْهَا : پھر انہوں نے کونچیں کاٹ دیں اسکی فَاَصْبَحُوْا : پس رہ گئے نٰدِمِيْنَ : پشیمان پھر بھی انہوں نے اس کی کوچیں کاٹ ڈالیں، 1 بس وہ پشیمان ہوگئے 2۔
26,158,فَاَخَذَهُمُ الْعَذَابُ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ فَاَخَذَهُمُ : پھر انہیں آپکڑا الْعَذَابُ : عذاب اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا : اور نہیں كَانَ : ہیں اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے اور عذاب نے آدبوچا 1 بیشک اس میں عبرت ہے۔ اور ان میں اکثر لوگ مومن نہ تھے۔
26,159,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان اور بیشک آپ کا رب بڑا زبردست اور مہربان ہے۔
26,160,كَذَّبَتْ قَوْمُ لُوْطِ اِ۟لْمُرْسَلِیْنَۚۖ كَذَّبَتْ : جھٹلایا قَوْمُ لُوْطِ : قومِ لوط ۨ الْمُرْسَلِيْنَ : رسولوں کو قوم لوط 1 نے بھی نبیوں کو جھٹلایا۔
26,161,اِذْ قَالَ لَهُمْ اَخُوْهُمْ لُوْطٌ اَلَا تَتَّقُوْنَۚ اِذْ : جب قَالَ : کہا لَهُمْ : ان سے اَخُوْهُمْ : ان کے بھائی لُوْطٌ : لوط اَلَا تَتَّقُوْنَ : کیا تم ڈرتے نہیں ان سے ان کے بھائی لوط ؑ نے کہا کیا تم اللہ کا خوف نہیں رکھتے ؟
26,162,اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ : رسول اَمِيْنٌ : امانت دار میں تمہاری طرف امانت دار رسول ہوں۔
26,163,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : پس تم ڈرو اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور تم میری اطاعت کرو پس تم اللہ سے ڈرو اور میری اطاعت کرو۔
26,164,وَ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ١ۚ اِنْ اَجْرِیَ اِلَّا عَلٰى رَبِّ الْعٰلَمِیْنَؕ وَمَآ اَسْئَلُكُمْ : اور میں نہیں مانگتا تم سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر۔ صرف عَلٰي : پر رَبِّ الْعٰلَمِيْنَ : رب العالمین میں تم میں سے اس پر کوئی بدلہ نہیں مانگتا میرا اجر تو صرف اللہ تعالیٰ پر ہے جو تمام جہان کا مالک ہے۔
26,165,اَتَاْتُوْنَ الذُّكْرَانَ مِنَ الْعٰلَمِیْنَۙ اَتَاْتُوْنَ : کیا تم آتے ہو الذُّكْرَانَ : مردوں کے پاس مِنَ : سے الْعٰلَمِيْنَ : تمام جہانوں کیا تم جہان والوں میں سے مردوں کے ساتھ شہوت رانی کرتے ہو۔
26,166,وَ تَذَرُوْنَ مَا خَلَقَ لَكُمْ رَبُّكُمْ مِّنْ اَزْوَاجِكُمْ١ؕ بَلْ اَنْتُمْ قَوْمٌ عٰدُوْنَ وَتَذَرُوْنَ : اور تم چھوڑتے ہو مَا خَلَقَ : جو اس نے پیدا کیا لَكُمْ : تمہارے لیے رَبُّكُمْ : تمہارا رب مِّنْ : سے اَزْوَاجِكُمْ : تمہاری بیویاں بَلْ : بلکہ اَنْتُمْ : تم قَوْمٌ : لوگ عٰدُوْنَ : حد سے بڑھنے والے اور تمہاری جن عورتوں کو اللہ تعالیٰ نے تمہارا جوڑا بنایا ہے ان کو چھوڑ دیتے ہو 1 بلکہ تم ہو ہی حد سے گزر جانے والے 2۔
26,167,قَالُوْا لَئِنْ لَّمْ تَنْتَهِ یٰلُوْطُ لَتَكُوْنَنَّ مِنَ الْمُخْرَجِیْنَ قَالُوْا : بولے وہ لَئِنْ : اگر لَّمْ تَنْتَهِ : تم باز نہ آئے يٰلُوْطُ : اے لوط لَتَكُوْنَنَّ : البتہ ضرور تم ہوگے مِنَ : سے الْمُخْرَجِيْنَ : مخرج (نکالے جانے والے انہوں نے جواب دیا کہ اے لوط ! اگر تو باز نہ آیا تو یقیناً نکال دیا جائے گا 1
26,168,قَالَ اِنِّیْ لِعَمَلِكُمْ مِّنَ الْقَالِیْنَؕ قَالَ : اس نے کہا اِنِّىْ : بیشک میں لِعَمَلِكُمْ : تمہارے فعل سے مِّنَ : سے الْقَالِيْنَ : نفرت کرنے والے آپ نے فرمایا، میں تمہارے کام سے سخت ناخوش ہوں 1
26,169,رَبِّ نَجِّنِیْ وَ اَهْلِیْ مِمَّا یَعْمَلُوْنَ رَبِّ : اے میرے رب نَجِّنِيْ : مجھے نجات دے وَاَهْلِيْ : اور میرے گھر والے مِمَّا : اس سے جو يَعْمَلُوْنَ : وہ کرتے ہیں میرے پروردگار ! مجھے اور میرے گھرانے کو اس (وبال) سے بچا لے جو یہ کرتے ہیں۔
26,170,فَنَجَّیْنٰهُ وَ اَهْلَهٗۤ اَجْمَعِیْنَۙ فَنَجَّيْنٰهُ : تو ہم نے نجات دی اسے وَاَهْلَهٗٓ : اور اس کے گھر والے اَجْمَعِيْنَ : سب پس ہم نے اسے اور اسکے متعلقین کو سب کو بچالیا۔
26,171,اِلَّا عَجُوْزًا فِی الْغٰبِرِیْنَۚ اِلَّا : سوائے عَجُوْزًا : ایک بڑھیا فِي الْغٰبِرِيْنَ : پیچھے رہ جانے والوں میں بجز ایک بڑھیا کے وہ پیچھے رہ جانے والوں میں ہوگئی 1
26,172,ثُمَّ دَمَّرْنَا الْاٰخَرِیْنَۚ ثُمَّ دَمَّرْنَا : پھر ہم نے ہلاک کردیا الْاٰخَرِيْنَ : دوسرے پھر ہم نے باقی اور سب کو ہلاک کردیا۔
26,173,وَ اَمْطَرْنَا عَلَیْهِمْ مَّطَرًا١ۚ فَسَآءَ مَطَرُ الْمُنْذَرِیْنَ وَاَمْطَرْنَا : اور ہم نے بارش برسائی عَلَيْهِمْ : ان پر مَّطَرًا : ایک بارش فَسَآءَ : پس بری مَطَرُ : بارش الْمُنْذَرِيْنَ : ڈرائے گئے اور ہم نے ان پر خاص قسم کا مینہ برسایا، پس بہت ہی برا مینہ تھا جو ڈرائے گئے ہوئے لوگوں پر برسا 1
26,174,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ ایک نشانی وَمَا : اور نہ كَانَ : تھے اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے یہ ما جرہ بھی سرا سر عبرت ہے۔ ان میں سے بھی اکثر مسلمان نہ تھے۔
26,175,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان بیشک تیرا پروردگار وہی غلبے والا مہربانی والا۔
26,176,كَذَّبَ اَصْحٰبُ لْئَیْكَةِ الْمُرْسَلِیْنَۚۖ كَذَّبَ : جھٹلایا اَصْحٰبُ لْئَيْكَةِ : ایکہ (بن) والے الْمُرْسَلِيْنَ : رسول (جمع) ایکہ والوں 1 نے بھی رسولوں کو جھٹلایا۔
26,177,اِذْ قَالَ لَهُمْ شُعَیْبٌ اَلَا تَتَّقُوْنَۚ اِذْ قَالَ : جب کہا لَهُمْ : انہیں شُعَيْبٌ : شعیب اَلَا تَتَّقُوْنَ : کیا تم ڈرتے نہیں جبکہ ان سے شعیب ؑ نے کہا کہ کیا تمہیں ڈر خوف نہیں ؟۔
26,178,اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ : رسول اَمِيْنٌ : امانت دار میں تمہاری طرف امانتدار رسول ہوں۔
26,179,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : سو ڈرو تم اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور میری اطاعت کرو اللہ کا خوف کھاؤ اور میری فرمانبرداری کرو۔
26,180,وَ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ١ۚ اِنْ اَجْرِیَ اِلَّا عَلٰى رَبِّ الْعٰلَمِیْنَؕ وَمَآ اَسْئَلُكُمْ : اور میں نہیں مانگتا تم سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر عَلٰي : پر رَبِّ الْعٰلَمِيْنَ : رب العالمین میں اس پر تم سے کوئی اجرت نہیں چاہتا، میرا اجر تمام جہانوں کے پالنے والے کے پاس ہے۔
26,181,اَوْفُوا الْكَیْلَ وَ لَا تَكُوْنُوْا مِنَ الْمُخْسِرِیْنَۚ اَوْفُوا : تم پورا کرو الْكَيْلَ : ماپ وَلَا تَكُوْنُوْا : اور نہ ہو تم مِنَ : سے الْمُخْسِرِيْنَ : نقصان دینے والے ناپ پورا بھرا کرو کم دینے والوں میں شمولیت نہ کرو 1
26,182,وَزِنُوْا بِالْقِسْطَاسِ الْمُسْتَقِیْمِۚ وَزِنُوْا : اور وزن کرو بِالْقِسْطَاسِ : ترازو سے الْمُسْتَقِيْمِ : ٹھیک سیدھی اور سیدھی صحیح ترازو سے تولا کرو 1
26,183,وَ لَا تَبْخَسُوا النَّاسَ اَشْیَآءَهُمْ وَ لَا تَعْثَوْا فِی الْاَرْضِ مُفْسِدِیْنَۚ وَلَا تَبْخَسُوا : اور نہ گھٹاؤ النَّاسَ : لوگ اَشْيَآءَهُمْ : ان کی چیزیں وَلَا تَعْثَوْا : اور نہ پھرو فِي الْاَرْضِ : زمین میں مُفْسِدِيْنَ : فساد مچاتے ہوئے لوگوں کو ان کی چیزیں کمی سے نہ دو 1 بےباکی کے ساتھ زمین میں فساد نہ مچاتے پھرو۔ 2
26,184,وَ اتَّقُوا الَّذِیْ خَلَقَكُمْ وَ الْجِبِلَّةَ الْاَوَّلِیْنَؕ وَاتَّقُوا : اور ڈرو الَّذِيْ : وہ جس نے خَلَقَكُمْ : یدا کیا تمہیں وَالْجِبِلَّةَ : اور مخلوق الْاَوَّلِيْنَ : پہلی اس اللہ کا خوف رکھو جس نے خود تمہیں اور اگلی مخلوق کو پیدا کیا۔ 1
26,185,قَالُوْۤا اِنَّمَاۤ اَنْتَ مِنَ الْمُسَحَّرِیْنَۙ قَالُوْٓا : وہ بولے (کہنے لگے) اِنَّمَآ : اس کے سوا نہیں اَنْتَ : تو مِنَ : سے الْمُسَحَّرِيْنَ : سحر زدہ (جمع) انہوں نے کہا تو ان میں سے ہے جن پر جادو کردیا جاتا ہے۔
26,186,وَ مَاۤ اَنْتَ اِلَّا بَشَرٌ مِّثْلُنَا وَ اِنْ نَّظُنُّكَ لَمِنَ الْكٰذِبِیْنَۚ وَمَآ اَنْتَ : اور نہیں تو اِلَّا : مگر۔ صرف بَشَرٌ : ایک بشر مِّثْلُنَا : ہم جیسا وَاِنْ نَّظُنُّكَ : اور البتہ ہم گمان کرتے ہیں تجھے لَمِنَ : البتہ۔ سے الْكٰذِبِيْنَ : جھوٹے انہوں نے کہا تو تو ہم جیسا ایک انسان ہے اور ہم تجھے جھوٹ بولنے والوں میں سے ہی سمجھتے ہیں 1
26,187,فَاَسْقِطْ عَلَیْنَا كِسَفًا مِّنَ السَّمَآءِ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَؕ فَاَسْقِطْ : سو تو گرا عَلَيْنَا : ہم پر كِسَفًا : ایک ٹکڑا مِّنَ : سے۔ کا السَّمَآءِ : آسمان اِنْ كُنْتَ : اگر تو ہے مِنَ : سے الصّٰدِقِيْنَ : سچے اگر تو سچے لوگوں میں سے ہے تو ہم پر آسمان کے ٹکڑے گرا دے 1
26,188,قَالَ رَبِّیْۤ اَعْلَمُ بِمَا تَعْمَلُوْنَ قَالَ : فرمایا رَبِّيْٓ : میرا رب اَعْلَمُ : خوب جانتا ہے بِمَا : جو کچھ تَعْمَلُوْنَ : تم کرتے ہو کہا کہ میرا رب خوب جاننے والا ہے جو کچھ تم کر رہے ہو 1
26,189,فَكَذَّبُوْهُ فَاَخَذَهُمْ عَذَابُ یَوْمِ الظُّلَّةِ١ؕ اِنَّهٗ كَانَ عَذَابَ یَوْمٍ عَظِیْمٍ فَكَذَّبُوْهُ : تو انہوں نے جھٹلایا اسے فَاَخَذَهُمْ : پس پکڑا انہیں عَذَابُ : عذاب يَوْمِ الظُّلَّةِ : سائبان والا دن اِنَّهٗ : بیشک وہ كَانَ : تھا عَذَابَ : عذاب يَوْمٍ عَظِيْمٍ : بڑا (سخت) دن چونکہ انہوں نے اسے جھٹلایا تو انھیں سائبان والے دن کے عذاب نے پکڑ لیا 1 وہ بڑے بھاری دن کا عذاب تھا۔
26,190,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَ : اور مَا كَانَ : نہ تھے اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے یقیناً اس میں بڑی نشانی ہے اور ان میں کے اکثر مسلمان نہ تھے۔
26,191,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تیرا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان اور یقیناً تیرا پروردگار البتہ وہی ہے غلبے والا مہربانی والا
26,192,وَ اِنَّهٗ لَتَنْزِیْلُ رَبِّ الْعٰلَمِیْنَؕ وَاِنَّهٗ : اور بیشک یہ لَتَنْزِيْلُ : البتہ اتارا ہوا رَبِّ الْعٰلَمِيْنَ : سارے جہانوں کا رب اور بیشک و شبہ یہ (قرآن) رب العالمین کا نازل فرمایا ہوا ہے۔
26,193,نَزَلَ بِهِ الرُّوْحُ الْاَمِیْنُۙ نَزَلَ بِهِ : اس کے ساتھ (لے کر) اترا الرُّوْحُ الْاَمِيْنُ : جبریل امین اسے امانت دار فرشتہ لے کر آیا ہے 1
26,194,عَلٰى قَلْبِكَ لِتَكُوْنَ مِنَ الْمُنْذِرِیْنَ عَلٰي : پر قَلْبِكَ : تمہارا دل لِتَكُوْنَ : تاکہ تم ہو مِنَ الْمُنْذِرِيْنَ : ڈر سنانے والوں میں سے آپ کے دل پر اترا ہے 1 کہ آپ آگاہ کردینے والوں میں سے ہوجائیں 2
26,195,بِلِسَانٍ عَرَبِیٍّ مُّبِیْنٍؕ بِلِسَانٍ : زبان میں عَرَبِيٍّ : عربی مُّبِيْنٍ : روشن (واضح) صاف عربی زبان میں ہے۔
26,196,وَ اِنَّهٗ لَفِیْ زُبُرِ الْاَوَّلِیْنَ وَاِنَّهٗ : اور بیشک یہ لَفِيْ : میں زُبُرِ : صحیفے الْاَوَّلِيْنَ : پہلے (پیغمبر) اگلے نبیوں کی کتابوں میں بھی اس قرآن کا تذکرہ ہے 1
26,197,اَوَ لَمْ یَكُنْ لَّهُمْ اٰیَةً اَنْ یَّعْلَمَهٗ عُلَمٰٓؤُا بَنِیْۤ اِسْرَآءِیْلَؕ اَوَ : کیا لَمْ يَكُنْ : نہیں ہے لَّهُمْ : ان کے لیے اٰيَةً : ایک نشانی اَنْ يَّعْلَمَهٗ : کہ جانتے ہیں اس کو عُلَمٰٓؤُا : علما بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل کیا انھیں یہ نشانی کافی نہیں کہ حقانیت قرآن کو بنی اسرائیل کے علماء بھی جانتے ہیں 1
26,198,وَ لَوْ نَزَّلْنٰهُ عَلٰى بَعْضِ الْاَعْجَمِیْنَۙ وَلَوْ : اور اگر نَزَّلْنٰهُ : ہم نازل کرتے اسے عَلٰي بَعْضِ : کسی پر الْاَعْجَمِيْنَ : عجمی (غیر عربی) اور اگر ہم کسی عجمی شخص پر نازل فرماتے۔
26,199,فَقَرَاَهٗ عَلَیْهِمْ مَّا كَانُوْا بِهٖ مُؤْمِنِیْنَؕ فَقَرَاَهٗ : پھر وہ پڑھتا اسے عَلَيْهِمْ : ان کے سامنے مَّا : نہ كَانُوْ : وہ ہوتے بِهٖ : اس پر مُؤْمِنِيْنَ : ایمان لانے والے پس وہ ان کے سامنے اس کی تلاوت کرتا تو یہ اسے باور کرنے والے نہ ہوتے 1
26,200,كَذٰلِكَ سَلَكْنٰهُ فِیْ قُلُوْبِ الْمُجْرِمِیْنَؕ كَذٰلِكَ : اسی طرح سَلَكْنٰهُ : یہ چلایا ہے (انکار داخل کردیا ہے) فِيْ قُلُوْبِ : دلوں میں الْمُجْرِمِيْنَ : مجرم (جمع) اسی طرح ہم نے گنہگاروں کے دلوں میں اس انکار کو داخل کردیا ہے 1
26,201,لَا یُؤْمِنُوْنَ بِهٖ حَتّٰى یَرَوُا الْعَذَابَ الْاَلِیْمَۙ لَا يُؤْمِنُوْنَ : وہ ایمان نہ لائیں گے بِهٖ : اس پر حَتّٰى : یہاں تک کہ يَرَوُا : وہ دیکھ لیں گے الْعَذَابَ الْاَلِيْمَ : دردناک عذاب وہ جب تک دردناک عذابوں کو ملاحظہ نہ کرلیں ایمان نہ لائیں گے۔
26,202,فَیَاْتِیَهُمْ بَغْتَةً وَّ هُمْ لَا یَشْعُرُوْنَۙ فَيَاْتِيَهُمْ : تو وہ آجائے گا ان پر بَغْتَةً : اچانک وَّهُمْ : اور انہیں لَا يَشْعُرُوْنَ : خبر (بھی) نہ ہوگی پس وہ عذاب ان کو ناگہاں آجائے گا انھیں اس کا شعور بھی نہ ہوگا۔
26,203,فَیَقُوْلُوْا هَلْ نَحْنُ مُنْظَرُوْنَؕ فَيَقُوْلُوْا : پھر وہ کہیں گے هَلْ : کیا نَحْنُ : ہم۔ ہمیں مُنْظَرُوْنَ : مہلت دی جائے گی اس وقت کہیں گے کہ کیا ہمیں کچھ مہلت دی جائے گی 1۔
26,204,اَفَبِعَذَابِنَا یَسْتَعْجِلُوْنَ اَفَبِعَذَابِنَا : کیا پس ہمارے عذاب کو يَسْتَعْجِلُوْنَ : وہ جلدی چاہتے ہیں پس کیا یہ ہمارے عذاب کی جلدی مچا رہے ہیں 1
26,205,اَفَرَءَیْتَ اِنْ مَّتَّعْنٰهُمْ سِنِیْنَۙ اَفَرَءَيْتَ : کیا تم نے دیکھا ؟ اِنْ : اگر مَّتَّعْنٰهُمْ : ہم انہیں فائدہ پہنچائیں سِنِيْنَ : کئی برس۔ برسوں اچھا یہ بھی بتاؤ کہ اگر ہم نے انھیں کئی سال بھی فائدہ اٹھانے دیا۔
26,206,ثُمَّ جَآءَهُمْ مَّا كَانُوْا یُوْعَدُوْنَۙ ثُمَّ : پھر جَآءَهُمْ : پہنچے ان پر مَّا : جو كَانُوْا يُوْعَدُوْنَ : انہیں وعید کی جاتی تھی پھر انھیں وہ عذاب آلگا جن سے یہ دھمکائے جاتے تھے۔
26,207,مَاۤ اَغْنٰى عَنْهُمْ مَّا كَانُوْا یُمَتَّعُوْنَؕ مَآ اَغْنٰى : کیا کام ٓئے گا عَنْهُمْ : ان کے مَّا : جو (جس سے) كَانُوْا يُمَتَّعُوْنَ : وہ فائدہ اٹھاتے تھے تو جو کچھ بھی یہ برتتے رہے اس میں سے کچھ بھی فائدہ نہ پہنچا سکے گا 1۔
26,208,وَ مَاۤ اَهْلَكْنَا مِنْ قَرْیَةٍ اِلَّا لَهَا مُنْذِرُوْنَ٥ۗۛۖ وَ : اور مَآ اَهْلَكْنَا : نہیں ہلاک کیا ہم نے مِنْ قَرْيَةٍ : کسی بستی کو اِلَّا : مگر لَهَا : اس کے لیے مُنْذِرُوْنَ : ڈرانے والے ہم نے کسی بستی کو ہلاک نہیں کیا ہے مگر اسی حال میں کہ اس کے لئے ڈرانے والے تھے۔
26,209,ذِكْرٰى١ۛ۫ وَ مَا كُنَّا ظٰلِمِیْنَ ذِكْرٰي : نصیحت کے لیے وَمَا كُنَّا : اور نہ تھے ہم ظٰلِمِيْنَ : ظلم کرنے والے نصیحت کے طور پر اور ہم ظلم کرنے والے نہیں ہیں 1
26,210,وَ مَا تَنَزَّلَتْ بِهِ الشَّیٰطِیْنُ وَ : اور مَا تَنَزَّلَتْ : نہیں اترے بِهِ : اسے لے کر الشَّيٰطِيْنُ : شیطان (جمع) اس قرآن کو شیطان نہیں لائے۔
26,211,وَ مَا یَنْۢبَغِیْ لَهُمْ وَ مَا یَسْتَطِیْعُوْنَؕ وَمَا يَنْۢبَغِيْ : اور سزاوار نہیں لَهُمْ : ان کو وَمَا يَسْتَطِيْعُوْنَ : اور نہ وہ کرسکتے ہیں نہ وہ اس قابل ہیں، نہ انھیں اس کی طاقت ہے۔
26,212,اِنَّهُمْ عَنِ السَّمْعِ لَمَعْزُوْلُوْنَؕ اِنَّهُمْ : بیشک وہ عَنِ : سے السَّمْعِ : سننا لَمَعْزُوْلُوْنَ : دور کردئیے گئے ہیں بلکہ وہ سننے سے محروم کردیئے گئے ہیں 1
26,213,فَلَا تَدْعُ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ فَتَكُوْنَ مِنَ الْمُعَذَّبِیْنَۚ فَلَا تَدْعُ : پس نہ پکارو مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا اٰخَرَ : کوئی دوسرا معبود فَتَكُوْنَ : کہ ہوجاؤ مِنَ : سے الْمُعَذَّبِيْنَ : مبتلائے عذاب پس تو اللہ کے ساتھ کسی اور معبود کو نہ پکار کہ تو بھی سزا پانے والوں میں سے ہوجائے
26,214,وَ اَنْذِرْ عَشِیْرَتَكَ الْاَقْرَبِیْنَۙ وَاَنْذِرْ : اور تم ڈراؤ عَشِيْرَتَكَ : اپنے رشتہ دار الْاَقْرَبِيْنَ : قریب ترین اپنے قریبی رشتہ والوں کو ڈرا دے 1
26,215,وَ اخْفِضْ جَنَاحَكَ لِمَنِ اتَّبَعَكَ مِنَ الْمُؤْمِنِیْنَۚ وَ : اور اخْفِضْ : جھکاؤ جَنَاحَكَ : اپنا بازو لِمَنِ : اس کے لیے جس نے اتَّبَعَكَ : تمہاری پیروی کی مِنَ : سے الْمُؤْمِنِيْنَ : مومنوں اس کے ساتھ نرمی سے پیش آ، جو بھی ایمان لانے والا ہو کہ تیری تابعداری کرے۔
26,216,فَاِنْ عَصَوْكَ فَقُلْ اِنِّیْ بَرِیْٓءٌ مِّمَّا تَعْمَلُوْنَۚ فَاِنْ : پھر اگر عَصَوْكَ : وہ تمہاری نافرمانی کریں فَقُلْ : تو کہ دیں اِنِّىْ بَرِيْٓءٌ : بیشک میں بیزار ہوں مِّمَّا : اس سے جو تَعْمَلُوْنَ : تم کرتے ہو اگر یہ لوگ تیری نافرمانی کریں تو اعلان کر دے کہ میں ان کاموں سے بیزار ہوں جو تم کر رہے ہو۔
26,217,وَ تَوَكَّلْ عَلَى الْعَزِیْزِ الرَّحِیْمِۙ وَتَوَكَّلْ : اور بھروسہ کرو عَلَي : پر الْعَزِيْزِ : غالب الرَّحِيْمِ : نہایت مہربان اپنا پورا بھروسہ غالب مہربان اللہ پر رکھ۔
26,218,الَّذِیْ یَرٰىكَ حِیْنَ تَقُوْمُۙ الَّذِيْ : وہ جو يَرٰىكَ : تمہیں دیکھتا ہے حِيْنَ : جب تَقُوْمُ : تم کھڑے ہوتے ہو جو تجھے دیکھتا رہتا ہے جبکہ تو کھڑا ہوتا ہے۔
26,219,وَ تَقَلُّبَكَ فِی السّٰجِدِیْنَ وَتَقَلُّبَكَ : اور تمہارا پھرنا فِي : میں السّٰجِدِيْنَ : سجدہ کرنے والے (نمازی) اور سجدہ کرنے والوں کے درمیان تیرا گھومنا پھرنا بھی 1
26,220,اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُ اِنَّهٗ : بیشک وہ هُوَ : وہی السَّمِيْعُ : سننے والا الْعَلِيْمُ : جاننے والا وہ بڑا ہی سننے والا اور خوب ہی جاننے والا ہے۔
26,221,هَلْ اُنَبِّئُكُمْ عَلٰى مَنْ تَنَزَّلُ الشَّیٰطِیْنُؕ هَلْ : کیا اُنَبِّئُكُمْ : میں تمہیں بتاؤں عَلٰي مَنْ : کسی پر تَنَزَّلُ : اترتے ہیں الشَّيٰطِيْنُ : شیطان (جمع) کیا میں تمہیں بتاؤں کہ شیطان کس پر اترتے ہیں۔
26,222,تَنَزَّلُ عَلٰى كُلِّ اَفَّاكٍ اَثِیْمٍۙ تَنَزَّلُ : وہ اترتے ہیں عَلٰي : پر كُلِّ : ہر اَفَّاكٍ : بہتان لگانے والا اَثِيْمٍ : گنہگار وہ ہر جھوٹے گنہگار پر اترتے ہیں 1
26,223,یُّلْقُوْنَ السَّمْعَ وَ اَكْثَرُهُمْ كٰذِبُوْنَؕ يُّلْقُوْنَ : ڈالدیتے ہیں السَّمْعَ : سنی سنائی بات وَاَكْثَرُهُمْ : اور ان میں اکثر كٰذِبُوْنَ : جھوٹے ہیں (اچٹتی) ہوئی سنی سنائی پہنچا دیتے ہیں اور ان میں سے اکثر جھوٹے ہیں 1
26,224,وَ الشُّعَرَآءُ یَتَّبِعُهُمُ الْغَاوٗنَؕ وَالشُّعَرَآءُ : اور شاعر (جمع يَتَّبِعُهُمُ : ان کی پیروی کرتے ہیں الْغَاوٗنَ : گمراہ لوگ شاعروں کی پیروی وہ کرتے ہیں جو بہکے ہوئے ہوں۔
26,225,اَلَمْ تَرَ اَنَّهُمْ فِیْ كُلِّ وَادٍ یَّهِیْمُوْنَۙ اَلَمْ تَرَ : کیا تم نے نہیں دیکھا اَنَّهُمْ فِيْ كُلِّ وَادٍ : کہ وہ ہر ادی میں يَّهِيْمُوْنَ : سرگرداں پھرتے ہیں کیا آپ نے نہیں دیکھا کہ شاعر ایک ایک بیابان میں سر ٹکراتے پھرتے ہیں۔
26,226,وَ اَنَّهُمْ یَقُوْلُوْنَ مَا لَا یَفْعَلُوْنَۙ وَاَنَّهُمْ : اور یہ کہ وہ يَقُوْلُوْنَ : وہ کہتے ہیں مَا : جو لَا يَفْعَلُوْنَ : وہ کرتے نہیں اور وہ کہتے ہیں جو کرتے نہیں 1
26,227,اِلَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ وَ ذَكَرُوا اللّٰهَ كَثِیْرًا وَّ انْتَصَرُوْا مِنْۢ بَعْدِ مَا ظُلِمُوْا١ؕ وَ سَیَعْلَمُ الَّذِیْنَ ظَلَمُوْۤا اَیَّ مُنْقَلَبٍ یَّنْقَلِبُوْنَ۠    ۧ اِلَّا : مگر الَّذِيْنَ : جو لوگ اٰمَنُوْا : ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : اچھے وَذَكَرُوا اللّٰهَ : اور اللہ کو یاد کیا كَثِيْرًا : بکثرت وَّانْتَصَرُوْا : اور انہوں نے بدلہ لیا مِنْۢ بَعْدِ : اس کے بعد مَا ظُلِمُوْا : کہ ان پر ظلم ہوا وَسَيَعْلَمُ : اور عنقریب جان لیں گے الَّذِيْنَ : وہ لوگ جنہوں نے ظَلَمُوْٓا : ظلم کیا اَيَّ : کس مُنْقَلَبٍ : لوٹنے کی جگہ (کروٹ) يَّنْقَلِبُوْنَ : وہ الٹتے ہیں (انہیں لوٹ کر جانا ہے سوائے ان کے جو ایمان لائے 1 اور نیک عمل کئے اور بکثرت اللہ تعالیٰ کا ذکر کیا اور اپنی مظلومی کے بعد انتقام لیا 2 جنہوں نے ظلم کیا ہے وہ بھی ابھی جان لیں گے کہ کس کروٹ الٹتے ہیں 3
