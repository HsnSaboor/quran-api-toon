tafsir[7]{c,v,t}:
  29,24,فَمَا كَانَ جَوَابَ قَوْمِهٖۤ اِلَّاۤ اَنْ قَالُوا اقْتُلُوْهُ اَوْ حَرِّقُوْهُ فَاَنْجٰىهُ اللّٰهُ مِنَ النَّارِ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّقَوْمٍ یُّؤْمِنُوْنَ فَمَا كَانَ : سو نہ تھا جَوَابَ : جواب قَوْمِهٖٓ : اس کی قوم اِلَّا : سوائے اَنْ : یہ کہ قَالُوا : انہوں نے کہا اقْتُلُوْهُ : قتل کردو اس کو اَوْ حَرِّقُوْهُ : یا جلا دو اس کو فَاَنْجٰىهُ : سو بچا لیا اس کو اللّٰهُ : اللہ مِنَ النَّارِ : آگ سے اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ : نشانیاں ہیں لِّقَوْمٍ : ان لوگوں کے لیے يُّؤْمِنُوْنَ : جو ایمان رکھتے ہیں ان کی قوم کا جواب بجز اس کے کچھ نہ تھا کہ کہنے لگے کہ اس مار ڈالو یا اسے جلا 1 دو آخر اللہ نے انھیں آگ سے بچا لیا 2 اس میں ایماندار لوگوں کے لئے تو بہت سی نشانیاں ہیں۔
  29,25,وَ قَالَ اِنَّمَا اتَّخَذْتُمْ مِّنْ دُوْنِ اللّٰهِ اَوْثَانًا١ۙ مَّوَدَّةَ بَیْنِكُمْ فِی الْحَیٰوةِ الدُّنْیَا١ۚ ثُمَّ یَوْمَ الْقِیٰمَةِ یَكْفُرُ بَعْضُكُمْ بِبَعْضٍ وَّ یَلْعَنُ بَعْضُكُمْ بَعْضًا١٘ وَّ مَاْوٰىكُمُ النَّارُ وَ مَا لَكُمْ مِّنْ نّٰصِرِیْنَۗۙ وَقَالَ : اور (ابراہیم نے) کہا اِنَّمَا : اس کے سوا نہیں اتَّخَذْتُمْ : تم نے بنا لیے ہیں مِّنْ دُوْنِ اللّٰهِ : اللہ کے سوا اَوْثَانًا : بت (جمع) مَّوَدَّةً : دوستی بَيْنِكُمْ : اپنے درمیان ( آپس میں) فِي الْحَيٰوةِ الدُّنْيَا : دنیا کی زندگی میں ثُمَّ : پھر يَوْمَ الْقِيٰمَةِ : قیامت کے دن يَكْفُرُ : کافر (مخالف) ہوجائیگا بَعْضُكُمْ : تم میں سے بعض (ایک) بِبَعْضٍ : بعض (دوسرے) کا وَّيَلْعَنُ : اور لعنت کرے گا بَعْضُكُمْ : تم میں سے بعض (ایک) بَعْضًا : بعض (دوسرے) کا وَّمَاْوٰىكُمُ : اور تمہارا ٹھکانا النَّارُ : جہنم وَمَا لَكُمْ : اور نہیں تمہارے لیے مِّنْ نّٰصِرِيْنَ : کوئی مددگار (حضرت ابراہیم ؑ نے) کہا کہ تم نے جن بتوں کی پرستش اللہ کے سوا کی ہے انھیں تم نے اپنی آپس کی دنیاوی دوستی کی بنا ٹھہرالی ہے 1 تم سب قیامت کے دن ایک دوسرے سے کفر کرنے لگو گے اور ایک دوسرے پر لعنت کرنے لگو گے 2 اور تمہارا سب کا ٹھکانا دوزخ ہوگا اور تمہارا کوئی مددگار نہ ہوگا۔
  29,26,فَاٰمَنَ لَهٗ لُوْطٌ١ۘ وَ قَالَ اِنِّیْ مُهَاجِرٌ اِلٰى رَبِّیْ١ؕ اِنَّهٗ هُوَ الْعَزِیْزُ الْحَكِیْمُ فَاٰمَنَ : پس ایمان لایا لَهٗ : اس پر لُوْطٌ : لوط وَقَالَ : اور اس نے کہا اِنِّىْ : بیشک میں مُهَاجِرٌ : ہجرت کرنیوالا اِلٰى رَبِّيْ : اپنے رب کی طرف اِنَّهٗ : بیشک وہ هُوَ : وہ الْعَزِيْزُ : زبردست غالب الْحَكِيْمُ : حکمت والا پس حضرت ابراہیم ؑ پر حضرت لوط (علیہ السلام ایمان لائے 1 اور کہنے لگے کہ میں اپنے رب کی طرف ہجرت کرنے والا ہو 2 وہ بڑا ہی غالب اور حکیم ہے۔
  29,27,وَ وَهَبْنَا لَهٗۤ اِسْحٰقَ وَ یَعْقُوْبَ وَ جَعَلْنَا فِیْ ذُرِّیَّتِهِ النُّبُوَّةَ وَ الْكِتٰبَ وَ اٰتَیْنٰهُ اَجْرَهٗ فِی الدُّنْیَا١ۚ وَ اِنَّهٗ فِی الْاٰخِرَةِ لَمِنَ الصّٰلِحِیْنَ وَوَهَبْنَا : اور ہم نے عطا فرمائے لَهٗٓ : اس کو اِسْحٰقَ : اسحق وَيَعْقُوْبَ : اور یعقوب وَجَعَلْنَا : ور ہم نے رکھی فِيْ ذُرِّيَّتِهِ : اس کی اولاد میں النُّبُوَّةَ : نبوت وَالْكِتٰبَ : اور کتاب وَاٰتَيْنٰهُ : اور ہم نے دیا اس کو اَجْرَهٗ : اس کا اجر فِي الدُّنْيَا : دنیا میں وَاِنَّهٗ : اور بیشک وہ فِي الْاٰخِرَةِ : آخرت میں لَمِنَ الصّٰلِحِيْنَ : البتہ نیکو کاروں میں سے اور ہم نے انھیں (ابراہیم کو) اسحاق و یعقوب (علیہما السلام) عطا کئے اور ہم نے نبوت اور کتاب ان کی اولاد میں ہی کردی 1 اور ہم نے دنیا میں بھی اسے ثواب دیا 2 اور آخرت میں تو وہ صالح لوگوں میں سے ہے 3۔
  29,28,وَ لُوْطًا اِذْ قَالَ لِقَوْمِهٖۤ اِنَّكُمْ لَتَاْتُوْنَ الْفَاحِشَةَ١٘ مَا سَبَقَكُمْ بِهَا مِنْ اَحَدٍ مِّنَ الْعٰلَمِیْنَ وَلُوْطًا : اور لوط اِذْ : (یاد کرو) جب قَالَ : اس نے کہا لِقَوْمِهٖٓ : اپنی قوم کو اِنَّكُمْ : بیشک لَتَاْتُوْنَ : تم کرتے ہو الْفَاحِشَةَ : بےحیائی مَا سَبَقَكُمْ : نہیں پہلے کیا تم نے بِهَا : اس کو مِنْ اَحَدٍ : کسی نے مِّنَ : سے الْعٰلَمِيْنَ : جہان والے اور حضرت لوط ؑ کا بھی ذکر کرو جب کہ انہوں نے اپنی قوم سے فرمایا کہ تم بدکاری پر اتر آئے ہو 1 جسے تم سے پہلے دنیا بھر میں سے کسی نے نہیں کیا۔
  29,29,اَئِنَّكُمْ لَتَاْتُوْنَ الرِّجَالَ وَ تَقْطَعُوْنَ السَّبِیْلَ١ۙ۬ وَ تَاْتُوْنَ فِیْ نَادِیْكُمُ الْمُنْكَرَ١ؕ فَمَا كَانَ جَوَابَ قَوْمِهٖۤ اِلَّاۤ اَنْ قَالُوا ائْتِنَا بِعَذَابِ اللّٰهِ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ اَئِنَّكُمْ : کیا تم واقعی لَتَاْتُوْنَ : البتہ تم کرتے ہو الرِّجَالَ : مرد (جمع) وَتَقْطَعُوْنَ : اور ماتے ہو السَّبِيْلَ : راہ وَتَاْتُوْنَ : اور تم کرتے ہو فِيْ نَادِيْكُمُ : اپن محفلوں میں الْمُنْكَرَ : ناشائستہ حرکات فَمَا كَانَ : سو نہ تھا جَوَابَ قَوْمِهٖٓ : اس کی قوم کا جواب اِلَّآ : سوائے اَنْ : کہ قَالُوا : انہوں نے کہا ائْتِنَا : لے آ ہم پر بِعَذَابِ اللّٰهِ : اللہ کا عذاب اِنْ كُنْتَ : اگر تو ہے مِنَ : سے الصّٰدِقِيْنَ : سچے لوگ کیا تم مردوں کے پاس بدفعلی کے لئے آتے ہو 1 اور راستے بند کرتے ہو 2 اور اپنی عام مجلسوں میں بےحیائیوں کا کام کرتے ہو 3 اس کے جواب میں اس کی قوم نے بجز اس کے اور کچھ نہیں کہا بس 4 جا اگر سچا ہے تو ہمارے پاس اللہ تعالیٰ کا عذاب لے آ۔
  29,30,قَالَ رَبِّ انْصُرْنِیْ عَلَى الْقَوْمِ الْمُفْسِدِیْنَ۠    ۧ قَالَ : کہا رَبِّ : اے میرے رب انْصُرْنِيْ : میری مدد فرما عَلَي : پر الْقَوْمِ : قوم۔ لوگ الْمُفْسِدِيْنَ : مفسد (جمع) حضرت لوط ؑ نے دعا کی 1 کہ پروردگار ! اس مفسد قوم پر میری مدد فرما۔
