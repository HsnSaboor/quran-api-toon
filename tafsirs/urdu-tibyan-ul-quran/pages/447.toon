tafsir[27]{c,v,t}:
  37,25,مَا لَكُمْ لَا تَنَاصَرُوْنَ مَا لَكُمْ : کیا ہوا تمہیں لَا تَنَاصَرُوْنَ : تم ایک دوسرے کی مدد نہیں کرتے تمہیں کیا ہوگیا ہے کہ (اس وقت) تم ایک دوسروں کی مدد نہیں کرتے۔
  37,26,بَلْ هُمُ الْیَوْمَ مُسْتَسْلِمُوْنَ بَلْ هُمُ : بلکہ وہ الْيَوْمَ : آج مُسْتَسْلِمُوْنَ : سرجھکائے فرمانبردار بلکہ وہ (سب کے سب) آج فرمانبردار بن گئے۔
  37,27,وَ اَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ وَاَقْبَلَ : اور رخ کرے گا بَعْضُهُمْ : ان میں سے بعض (ایک) عَلٰي بَعْضٍ : بعض پر دوسرے کی طرف يَّتَسَآءَلُوْنَ : باہم سوال کرتے ہوئے وہ ایک دوسرے کی طرف متوجہ ہو کر سوال و جواب کرنے لگیں گے۔
  37,28,قَالُوْۤا اِنَّكُمْ كُنْتُمْ تَاْتُوْنَنَا عَنِ الْیَمِیْنِ قَالُوْٓا : وہ کہیں گے اِنَّكُمْ : بیشک تم كُنْتُمْ تَاْتُوْنَنَا : تم ہم پر آئے تھے عَنِ الْيَمِيْنِ : دائیں طرف سے کہیں گے کہ تم ہمارے پاس ہماری دائیں طرف سے آتے تھے (1)
  37,29,قَالُوْا بَلْ لَّمْ تَكُوْنُوْا مُؤْمِنِیْنَۚ قَالُوْا : وہ کہیں گے بَلْ : بلکہ لَّمْ تَكُوْنُوْا : تم نہ تھے مُؤْمِنِيْنَ : ایمان لانے و الے وہ جواب دیں گے کہ نہیں بلکہ تم ہی ایماندار نہ تھے (1)
  37,30,وَ مَا كَانَ لَنَا عَلَیْكُمْ مِّنْ سُلْطٰنٍ١ۚ بَلْ كُنْتُمْ قَوْمًا طٰغِیْنَ وَمَا : اور نہ كَانَ : تھا لَنَا : ہمارا عَلَيْكُمْ : تم پر مِّنْ سُلْطٰنٍ ۚ : کوئی زور بَلْ : بلکہ كُنْتُمْ : تم تھے قَوْمًا : ایک قوم طٰغِيْنَ : سرکش اور کچھ ہمارا زور تو تھا (ہی) نہیں، بلکہ تم (خود) سرکش لوگ تھے (1)
  37,31,فَحَقَّ عَلَیْنَا قَوْلُ رَبِّنَاۤ١ۖۗ اِنَّا لَذَآئِقُوْنَ فَحَقَّ : پس ثابت ہوگئی عَلَيْنَا : ہم پر قَوْلُ : بات رَبِّنَآ ڰ : ہمارا رب اِنَّا : بیشک ہم لَذَآئِقُوْنَ : البتہ چکھنے والے اب تو ہم (سب) پر ہمارے رب کی بات ثابت ہوچکی کہ ہم (عذاب) چکھنے والے ہیں۔
  37,32,فَاَغْوَیْنٰكُمْ اِنَّا كُنَّا غٰوِیْنَ فَاَغْوَيْنٰكُمْ : پس ہم نے بہکایا تمہیں اِنَّا كُنَّا : بیشک ہم تھے غٰوِيْنَ : گمراہ پس ہم نے تمہیں گمراہ کیا ہم خود گمراہ ہی تھے۔ (1)
  37,33,فَاِنَّهُمْ یَوْمَئِذٍ فِی الْعَذَابِ مُشْتَرِكُوْنَ فَاِنَّهُمْ : پس بیشک وہ يَوْمَئِذٍ : اس دن فِي الْعَذَابِ : عذاب میں مُشْتَرِكُوْنَ : مشترک (شریک) سو اب آج کے دن (سب کے سب) عذاب میں شریک ہیں (1)
  37,34,اِنَّا كَذٰلِكَ نَفْعَلُ بِالْمُجْرِمِیْنَ اِنَّا : بیشک ہم كَذٰلِكَ : اسی طرح نَفْعَلُ : کرتے ہیں بِالْمُجْرِمِيْنَ : مجرموں کے ساتھ ہم گناہگاروں کے ساتھ اسی طرح کرتے ہیں (1)
  37,35,اِنَّهُمْ كَانُوْۤا اِذَا قِیْلَ لَهُمْ لَاۤ اِلٰهَ اِلَّا اللّٰهُ١ۙ یَسْتَكْبِرُوْنَۙ اِنَّهُمْ : بیشک وہ كَانُوْٓا : وہ تھے اِذَا : جب قِيْلَ : کہا جاتا لَهُمْ : ان کو لَآ : نہیں اِلٰهَ : کوئی معبود اِلَّا اللّٰهُ ۙ : اللہ کے سوا يَسْتَكْبِرُوْنَ : وہ تکبر کرتے تھے یہ وہ (لوگ) ہیں کہ جب ان سے کہا جاتا ہے کہ اللہ کے سوا کوئی معبود نہیں تو یہ سرکشی کرتے تھے (1)
  37,36,وَ یَقُوْلُوْنَ اَئِنَّا لَتَارِكُوْۤا اٰلِهَتِنَا لِشَاعِرٍ مَّجْنُوْنٍؕ وَيَقُوْلُوْنَ : ور وہ کہتے ہیں اَئِنَّا : کیا ہم لَتَارِكُوْٓا : چھوڑ دینے والے اٰلِهَتِنَا : اپنے معبود لِشَاعِرٍ : ایک شاعر کی خاطر مَّجْنُوْنٍ : دیوانے اور کہتے تھے کہ کیا ہم اپنے معبودوں کو ایک دیوانے شاعر کی بات پر چھوڑ دیں (1)۔
  37,37,بَلْ جَآءَ بِالْحَقِّ وَ صَدَّقَ الْمُرْسَلِیْنَ بَلْ : بلکہ جَآءَ : وہ آئے بِالْحَقِّ : حق کے ساتھ وَصَدَّقَ : اور تصدیق کی الْمُرْسَلِيْنَ : رسولوں کی (نہیں نہیں) بلکہ (نبی) تو حق (سچا دین) لائے ہیں اور سب رسولوں کو سچا جانتے ہیں (1)
  37,38,اِنَّكُمْ لَذَآئِقُوا الْعَذَابِ الْاَلِیْمِۚ اِنَّكُمْ : بیشک تم لَذَآئِقُوا : ضرور چکھنے والے الْعَذَابِ : عذاب الْاَلِيْمِ : دردناک یقیناً تم دردناک عذاب (کا مزہ) چکھنے والے ہو۔
  37,39,وَ مَا تُجْزَوْنَ اِلَّا مَا كُنْتُمْ تَعْمَلُوْنَۙ وَمَا تُجْزَوْنَ : اور تمہیں بدلہ نہ دیا جائے گا اِلَّا : مگر مَا : جو كُنْتُمْ تَعْمَلُوْنَ : تم کرتے تھے تمہیں اسکا بدلہ دیا جائے گا جو تم کرتے تھے (1)۔
  37,40,اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ اِلَّا : مگر عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : خاص کیے ہوئے مگر اللہ تعالیٰ کے خالص برگزیدہ بندے (1)۔
  37,41,اُولٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُوْمٌۙ اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے رِزْقٌ مَّعْلُوْمٌ : رزق معلوم انہیں کے لئے مقررہ روزی ہے۔
  37,42,فَوَاكِهُ١ۚ وَ هُمْ مُّكْرَمُوْنَۙ فَوَاكِهُ ۚ : میوے وَهُمْ : اور وہ مُّكْرَمُوْنَ : اعزاز والے ہوں گے (ہر طرح) کے میوے، اور باعزت و اکرام ہونگے۔
  37,43,فِیْ جَنّٰتِ النَّعِیْمِۙ فِيْ : میں جَنّٰتِ النَّعِيْمِ : نعمت کے باغات نعمتوں والی جنتوں میں۔
  37,44,عَلٰى سُرُرٍ مُّتَقٰبِلِیْنَ عَلٰي : پر سُرُرٍ مُّتَقٰبِلِيْنَ : (جمع) تخت آمنے سامنے تختوں پر ایک دوسرے کے سامنے (بیٹھے) ہوں گے۔
  37,45,یُطَافُ عَلَیْهِمْ بِكَاْسٍ مِّنْ مَّعِیْنٍۭۙ يُطَافُ : دورہ ہوگا عَلَيْهِمْ : ان پر۔ ان کے آگے بِكَاْسٍ : جام مِّنْ : سے ۔ کا مَّعِيْنٍۢ : بہتا ہوا مشروب جاری شراب کے جام کا ان پر دور چل رہا ہوگا (1)
  37,46,بَیْضَآءَ لَذَّةٍ لِّلشّٰرِبِیْنَۚۖ بَيْضَآءَ : سفید لَذَّةٍ : لذت لِّلشّٰرِبِيْنَ : پینے والوں کے لیے جو صاف شفاف اور پینے میں لذیذ ہوگی (1)
  37,47,لَا فِیْهَا غَوْلٌ وَّ لَا هُمْ عَنْهَا یُنْزَفُوْنَ لَا فِيْهَا : نہ اس میں غَوْلٌ : خرابی (درد سر) وَّلَا هُمْ : اور نہ وہ عَنْهَا : اس سے يُنْزَفُوْنَ : بہکی باتیں کریں گے نہ اس سے درد ہوگا اور نہ اسکے پینے سے بہکیں گے (1)
  37,48,وَ عِنْدَهُمْ قٰصِرٰتُ الطَّرْفِ عِیْنٌۙ وَعِنْدَهُمْ : اور ان کے پاس قٰصِرٰتُ الطَّرْفِ : نیچی نگاہوں والیاں عِيْنٌ : بڑی آنکھوں والیاں اور ان کے پاس نیچی نظروں، بڑی بڑی آنکھوں والی (حوریں) ہونگی (1)
  37,49,كَاَنَّهُنَّ بَیْضٌ مَّكْنُوْنٌ كَاَنَّهُنَّ : گویا وہ بَيْضٌ : انڈے مَّكْنُوْنٌ : پوشیدہ رکھے ہوئے ایسی جیسے چھپائے ہوئے انڈے (1)
  37,50,فَاَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ فَاَقْبَلَ : پس رخ کرے گا بَعْضُهُمْ : ان میں سے بعض (ایک) عَلٰي بَعْضٍ : بعض پر (دوسرے کی طرف) يَّتَسَآءَلُوْنَ : باہم سوال کرتے ہوئے جنتی) ایک دوسرے کی طرف رخ کرکے پوچھیں گے (1)۔
  37,51,قَالَ قَآئِلٌ مِّنْهُمْ اِنِّیْ كَانَ لِیْ قَرِیْنٌۙ قَالَ : کہے گا قَآئِلٌ : ایک کہنے والا مِّنْهُمْ : ان میں سے اِنِّىْ : یشک میں كَانَ : تھا لِيْ : میرا قَرِيْنٌ : ایک ہم نشین ان میں سے ایک کہنے والا کہے گا کہ میرا ایک ساتھی تھا
