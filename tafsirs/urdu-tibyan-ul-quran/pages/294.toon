tafsir[11]{c,v,t}:
  18,5,مَا لَهُمْ بِهٖ مِنْ عِلْمٍ وَّ لَا لِاٰبَآئِهِمْ١ؕ كَبُرَتْ كَلِمَةً تَخْرُجُ مِنْ اَفْوَاهِهِمْ١ؕ اِنْ یَّقُوْلُوْنَ اِلَّا كَذِبًا مَا : نہیں لَهُمْ بِهٖ : ان کو اس کا مِنْ عِلْمٍ : کوئی علم وَّلَا : اور نہ لِاٰبَآئِهِمْ : ان کے باپ دادا كَبُرَتْ : بڑی ہے كَلِمَةً : بات تَخْرُجُ : نکلتی ہے مِنْ : سے اَفْوَاهِهِمْ : ان کے منہ (جمع) اِنْ : نہیں يَّقُوْلُوْنَ : وہ کہتے ہیں اِلَّا : مگر كَذِبًا : جھوٹ در حقیقت نہ تو خود انھیں اس کا علم ہے نہ ان کے باپ دادوں کو۔ یہ تہمت بڑی بری ہے جو ان کے منہ سے نکل رہی ہے وہ نرا جھوٹ بک رہے ہیں۔
  18,6,فَلَعَلَّكَ بَاخِعٌ نَّفْسَكَ عَلٰۤى اٰثَارِهِمْ اِنْ لَّمْ یُؤْمِنُوْا بِهٰذَا الْحَدِیْثِ اَسَفًا فَلَعَلَّكَ : تو شاید آپ بَاخِعٌ : ہلاک کرنیوالا نَّفْسَكَ : اپنی جان عَلٰٓي : پر اٰثَارِهِمْ : ان کے پیچھے اِنْ : اگر لَّمْ يُؤْمِنُوْا : وہ ایمان نہ لائے بِهٰذَا : اس الْحَدِيْثِ : بات اَسَفًا : غم کے مارے پس اگر یہ لوگ اس بات (1) پر ایمان نہ لائیں تو کیا آپ ان کے پیچھے اس رنج میں اپنی جان ہلاک کر ڈالیں گے
  18,7,اِنَّا جَعَلْنَا مَا عَلَى الْاَرْضِ زِیْنَةً لَّهَا لِنَبْلُوَهُمْ اَیُّهُمْ اَحْسَنُ عَمَلًا اِنَّا : بیشک ہم جَعَلْنَا : ہم نے بنایا مَا : جو عَلَي الْاَرْضِ : زمین پر زِيْنَةً : زینت لَّهَا : اس کے لیے لِنَبْلُوَهُمْ : تاکہ ہم انہیں آزمائیں اَيُّهُمْ : کون ان میں سے اَحْسَنُ : بہتر عَمَلًا : عمل میں روئے زمین پر جو کچھ (1) ہے ہم نے اسے زمین کی رونق کا باعث بنایا ہے کہ ہم انھیں آزمالیں کہ ان میں سے کون نیک اعمال والا ہے
  18,8,وَ اِنَّا لَجٰعِلُوْنَ مَا عَلَیْهَا صَعِیْدًا جُرُزًاؕ وَاِنَّا : اور بیشک ہم لَجٰعِلُوْنَ : البتہ کرنے والے مَا عَلَيْهَا : جو اس پر صَعِيْدًا : صاف میدان جُرُزًا : بنجر (چٹیل) اس پر جو کچھ ہے ہم اسے ایک ہموار صاف میدان کر ڈالنے والے ہیں (1)۔
  18,9,اَمْ حَسِبْتَ اَنَّ اَصْحٰبَ الْكَهْفِ وَ الرَّقِیْمِ١ۙ كَانُوْا مِنْ اٰیٰتِنَا عَجَبًا اَمْ حَسِبْتَ : کیا تم نے گمان کیا اَنَّ : کہ اَصْحٰبَ الْكَهْفِ : اصحاب کہف (غار والے) وَالرَّقِيْمِ : اور رقیم كَانُوْا : وہ تھے مِنْ : سے اٰيٰتِنَا عَجَبًا : ہماری نشانیاں عجب کیا تو اپنے خیال میں غار اور کتبے والوں کو ہماری نشانیوں میں سے کوئی بہت عجیب نشانی سمجھ رہا ہے (1)
  18,10,اِذْ اَوَى الْفِتْیَةُ اِلَى الْكَهْفِ فَقَالُوْا رَبَّنَاۤ اٰتِنَا مِنْ لَّدُنْكَ رَحْمَةً وَّ هَیِّئْ لَنَا مِنْ اَمْرِنَا رَشَدًا اِذْ : جب اَوَى : پناہ لی الْفِتْيَةُ : جوان (جمع) اِلَى : طرف۔ میں الْكَهْفِ : غار فَقَالُوْا : تو انہوں نے کہا رَبَّنَآ : اے ہمارے رب اٰتِنَا : ہمیں دے مِنْ لَّدُنْكَ : اپنی طرف سے رَحْمَةً : رحمت وَّهَيِّئْ : اور مہیا کر لَنَا : ہمارے لیے مِنْ اَمْرِنَا : ہمارے کام میں رَشَدًا : درستی ان چند نو جوانوں نے جب غار میں پناہ لی تو دعا کی کہ اے ہمارے پروردگار ! ہمیں اپنے پاس سے رحمت عطا فرما اور ہمارے کام میں ہمارے لئے راہ یابی کو آسان کر دے (1)۔
  18,11,فَضَرَبْنَا عَلٰۤى اٰذَانِهِمْ فِی الْكَهْفِ سِنِیْنَ عَدَدًاۙ فَضَرَبْنَا : پس ہم نے مارا (پردہ ڈالا) عَلٰٓي : پر اٰذَانِهِمْ : ان کے کان (جمع) فِي الْكَهْفِ : غار میں سِنِيْنَ عَدَدًا : کئی سال پس ہم نے ان کے کانوں پر گنتی کے کئی سال اسی غار میں پردے ڈال دیئے (1)۔
  18,12,ثُمَّ بَعَثْنٰهُمْ لِنَعْلَمَ اَیُّ الْحِزْبَیْنِ اَحْصٰى لِمَا لَبِثُوْۤا اَمَدًا۠    ۧ ثُمَّ : پھر بَعَثْنٰهُمْ : ہم نے انہیں اٹھایا لِنَعْلَمَ : تاکہ ہم دیکھیں اَيُّ : کون۔ کس الْحِزْبَيْنِ : دونوں گروہ اَحْصٰى : خوب یاد رکھا لِمَا لَبِثُوْٓا : کتنی دیر رہے اَمَدًا : مدت پھر ہم نے انھیں اٹھا کھڑا کیا کہ ہم یہ معلوم کرلیں کہ دونوں گروہ میں سے اس انتہائی مدت کو جو انہوں نے گزاری کس نے زیادہ (1) یاد رکھا
  18,13,نَحْنُ نَقُصُّ عَلَیْكَ نَبَاَهُمْ بِالْحَقِّ١ؕ اِنَّهُمْ فِتْیَةٌ اٰمَنُوْا بِرَبِّهِمْ وَ زِدْنٰهُمْ هُدًىۗۖ نَحْنُ : ہم نَقُصُّ : بیان کرتے ہیں عَلَيْكَ : تجھ سے نَبَاَهُمْ : ان کا حال بِالْحَقِّ : ٹھیک ٹھیک اِنَّهُمْ : بیشک وہ فِتْيَةٌ : چند نوجوان اٰمَنُوْا : وہ ایمان لائے بِرَبِّهِمْ : اپنے رب پر وَزِدْنٰهُمْ هُدًى : اور ہم نے اور زیادہ دی انہیں۔ ہدایت ہم ان کا صحیح واقعہ تیرے سامنے بیان فرما رہے ہیں۔ یہ چند نوجوان (1) اپنے رب پر ایمان لائے تھے اور ہم نے ان کی ہدایت میں ترقی دی تھی۔
  18,14,وَّ رَبَطْنَا عَلٰى قُلُوْبِهِمْ اِذْ قَامُوْا فَقَالُوْا رَبُّنَا رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ لَنْ نَّدْعُوَاۡ مِنْ دُوْنِهٖۤ اِلٰهًا لَّقَدْ قُلْنَاۤ اِذًا شَطَطًا وَّرَبَطْنَا : اور ہم نے گرہ لگا دی عَلٰي : پر قُلُوْبِهِمْ : ان کے دل اِذْ : جب قَامُوْا : وہ کھڑے ہوئے فَقَالُوْا : تو انہوں نے کہا رَبُّنَا : ہمارا رب رَبُّ : پروردگار السَّمٰوٰتِ : آسمانوں وَالْاَرْضِ : اور زمین لَنْ نَّدْعُوَا : ہم ہرگز نہ پکاریں گے مِنْ دُوْنِهٖٓ : اس کے سوائے اِلٰهًا : کوئی معبود لَّقَدْ قُلْنَآ : البتہ ہم نے کہی اِذًا : اس وقت شَطَطًا : بےجا بات ہم نے ان کے دل مضبوط کردیئے (1) تھے جبکہ یہ اٹھ کر کھڑے ہوئے (2) اور کہنے لگے کہ ہمارا پروردگار تو وہی ہے جو آسمان و زمین کا پروردگار ہے، ناممکن ہے کہ ہم اس کے سوا کسی اور کو معبود پکاریں اگر ایسا کیا تو ہم نے نہایت ہی غلط بات کہی۔
  18,15,هٰۤؤُلَآءِ قَوْمُنَا اتَّخَذُوْا مِنْ دُوْنِهٖۤ اٰلِهَةً١ؕ لَوْ لَا یَاْتُوْنَ عَلَیْهِمْ بِسُلْطٰنٍۭ بَیِّنٍ١ؕ فَمَنْ اَظْلَمُ مِمَّنِ افْتَرٰى عَلَى اللّٰهِ كَذِبًاؕ هٰٓؤُلَآءِ : یہ ہے قَوْمُنَا : ہماری قوم اتَّخَذُوْا : انہوں نے بنا لیے مِنْ دُوْنِهٖٓ : اس کے سوا اٰلِهَةً : اور معبود لَوْ : کیوں لَا يَاْتُوْنَ : وہ نہیں لاتے عَلَيْهِمْ : ان پر بِسُلْطٰنٍ : کوئی دلیل بَيِّنٍ : واضح فَمَنْ : پس کون اَظْلَمُ : بڑا ظالم مِمَّنِ : اس سے جو افْتَرٰى : افترا کرے عَلَي : پر اللّٰهِ : اللہ كَذِبًا : جھوٹ یہ ہے ہماری قوم جس نے اس کے سوا اور معبود بنا رکھے ہیں۔ ان کی خدائی کی یہ کوئی صاف دلیل کیوں پیش نہیں کرتے اللہ پر جھوٹ افترا باندھنے والے سے زیادہ ظالم کون ہے۔
