quran[54]{c,v,t}:
41,1,حٰمٓۚ حٰمٓ : حا۔ میم ح م
41,2,تَنْزِیْلٌ مِّنَ الرَّحْمٰنِ الرَّحِیْمِۚ تَنْزِيْلٌ : نازل کیا ہوا مِّنَ : سے الرَّحْمٰنِ : نہایت رحم کرنیوالا الرَّحِيْمِ : مہربان اتاری ہوئی ہے بڑے مہربان بہت رحم والے کی طرف سے۔
41,3,كِتٰبٌ فُصِّلَتْ اٰیٰتُهٗ قُرْاٰنًا عَرَبِیًّا لِّقَوْمٍ یَّعْلَمُوْنَۙ كِتٰبٌ : ایک کتاب فُصِّلَتْ : جدا جدا (واضح) کردی گئیں اٰيٰتُهٗ : اس کی آیتیں قُرْاٰنًا : قرآن عَرَبِيًّا : عربی (زبان) میں لِّقَوْمٍ : ان لوگوں کے لئے يَّعْلَمُوْنَ : وہ جانتے ہیں ایسی کتاب جس کی آیتوں کی واضح تفصیل کی گئی ہے (1) (اس حال میں کہ) قرآن عربی زبان میں ہے (2) اس قوم کے لئے جو جانتی ہے (3)
41,4,بَشِیْرًا وَّ نَذِیْرًا١ۚ فَاَعْرَضَ اَكْثَرُهُمْ فَهُمْ لَا یَسْمَعُوْنَ بَشِيْرًا : خوشخبری دینے والا وَّنَذِيْرًا ۚ : اور ڈرانے والا فَاَعْرَضَ : سو منہ پھیرلیا اَكْثَرُهُمْ : ان میں سے اکثر فَهُمْ : پس وہ لَا : نہیں يَسْمَعُوْنَ : سنتے خوشخبری سنانے والا اور ڈرانے والا (1) ہے پھر بھی ان کی اکثریت نے منہ پھیرلیا اور وہ سنتے ہی نہیں (2)۔
41,5,وَ قَالُوْا قُلُوْبُنَا فِیْۤ اَكِنَّةٍ مِّمَّا تَدْعُوْنَاۤ اِلَیْهِ وَ فِیْۤ اٰذَانِنَا وَقْرٌ وَّ مِنْۢ بَیْنِنَا وَ بَیْنِكَ حِجَابٌ فَاعْمَلْ اِنَّنَا عٰمِلُوْنَ وَقَالُوْا : اور انہوں نے کہا قُلُوْبُنَا : ہمارے دل فِيْٓ اَكِنَّةٍ : پردوں میں مِّمَّا : اس سے جو تَدْعُوْنَآ : تم بلاتے ہو ہمیں اِلَيْهِ : اس کی طرف وَفِيْٓ اٰذَانِنَا : اور ہمارے کانوں میں وَقْرٌ : بوجھ، گرانی وَّمِنْۢ بَيْنِنَا : اور ہمارے درمیان وَبَيْنِكَ : اور تمہارے درمیان حِجَابٌ : ایک پردہ فَاعْمَلْ : سو تم کام کرو اِنَّنَا : بیشک ہم عٰمِلُوْنَ : کام کرتے ہیں اور انہوں نے کہا کہ تو جس کی طرف ہمیں بلا رہا ہے ہمارے دل تو اس سے پردے میں ہیں (1) اور ہمارے کانوں میں گرانی ہے (2) اور ہم میں اور تجھ میں ایک حجاب ہے، اچھا تو اب اپنا کام کئے جا ہم بھی یقیناً کام کرنے والے ہیں (3)
41,6,قُلْ اِنَّمَاۤ اَنَا بَشَرٌ مِّثْلُكُمْ یُوْحٰۤى اِلَیَّ اَنَّمَاۤ اِلٰهُكُمْ اِلٰهٌ وَّاحِدٌ فَاسْتَقِیْمُوْۤا اِلَیْهِ وَ اسْتَغْفِرُوْهُ١ؕ وَ وَیْلٌ لِّلْمُشْرِكِیْنَۙ قُلْ : فرمادیں اِنَّمَآ : اس کے سوا نہیں اَنَا بَشَرٌ : کہ میں ایک بشر مِّثْلُكُمْ : تم جیسا يُوْحٰٓى : وحی کی جاتی ہے اِلَيَّ : میری طرف اَنَّمَآ : یہ کہ اِلٰهُكُمْ : تمہارا معبود اِلٰهٌ وَّاحِدٌ : معبود یکتا فَاسْتَقِيْمُوْٓا : پس سیدھے رہو اِلَيْهِ : اس کی طرف (اس کے حضور) وَاسْتَغْفِرُوْهُ ۭ : اور اس سے مغفرت مانگو وَوَيْلٌ : اور خرابی لِّلْمُشْرِكِيْنَ : مشرکوں کے لئے آپ کہہ دیجئے ! کہ میں تم ہی جیسا انسان ہوں مجھ پر وحی نازل کی جاتی ہے (1) کہ تم سب کا معبود ایک اللہ ہی ہے سو تم اس کی طرف متوجہ ہوجاؤ اور اس سے گناہوں کی معافی چاہو، اور ان مشرکوں کے لئے (بڑی ہی) خرابی ہے۔
41,7,الَّذِیْنَ لَا یُؤْتُوْنَ الزَّكٰوةَ وَ هُمْ بِالْاٰخِرَةِ هُمْ كٰفِرُوْنَ الَّذِيْنَ : وہ جو لَا يُؤْتُوْنَ : نہیں دیتے الزَّكٰوةَ : زکوۃ وَهُمْ : اور وہ بِالْاٰخِرَةِ : آخرت کے هُمْ : وہ كٰفِرُوْنَ : منکر ہیں جو زکوٰۃ نہیں دیتے (1) اور آخرت کے بھی منکر ہی رہتے ہیں۔
41,8,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ لَهُمْ اَجْرٌ غَیْرُ مَمْنُوْنٍ۠    ۧ اِنَّ الَّذِيْنَ : بیشک جو لوگ اٰمَنُوْا : ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کئے الصّٰلِحٰتِ : اچھے لَهُمْ : ان کے لئے اَجْرٌ : اجر غَيْرُ مَمْنُوْنٍ : ختم نہ ہونے والا بیشک جو لوگ ایمان لائیں اور بھلے کام کریں ان کے لئے نہ ختم ہونے والا اجر ہے۔ (1)
41,9,قُلْ اَئِنَّكُمْ لَتَكْفُرُوْنَ بِالَّذِیْ خَلَقَ الْاَرْضَ فِیْ یَوْمَیْنِ وَ تَجْعَلُوْنَ لَهٗۤ اَنْدَادًا١ؕ ذٰلِكَ رَبُّ الْعٰلَمِیْنَۚ قُلْ : فرمادیں اَئِنَّكُمْ : کیا تم لَتَكْفُرُوْنَ : انکار کرتے ہو بِالَّذِيْ : اس کا جس نے خَلَقَ : پیدا کیا الْاَرْضَ : زمین فِيْ يَوْمَيْنِ : دودنوں میں وَتَجْعَلُوْنَ : اور تم ٹھہراتے ہو لَهٗٓ : اس کے اَنْدَادًا ۭ : شریک (جمع) ذٰلِكَ : یہ رَبُّ : رب الْعٰلَمِيْنَ : سارے جہانوں کا آپ کہہ دیجئے ! کہ تم اس اللہ کا انکار کرتے ہو اور تم اس کے شریک مقرر کرتے ہو جس نے دو دن میں زمین پیدا کردی (4) سارے جہانوں کا پروردگار وہی ہے۔
41,10,وَ جَعَلَ فِیْهَا رَوَاسِیَ مِنْ فَوْقِهَا وَ بٰرَكَ فِیْهَا وَ قَدَّرَ فِیْهَاۤ اَقْوَاتَهَا فِیْۤ اَرْبَعَةِ اَیَّامٍ١ؕ سَوَآءً لِّلسَّآئِلِیْنَ وَجَعَلَ : اور اس نے بنایا فِيْهَا : اس میں رَوَاسِيَ : پہاڑ (جمع) مِنْ فَوْقِهَا : اسی کے اوپر وَبٰرَكَ : اور برکت رکھی فِيْهَا : اس میں وَقَدَّرَ : اور مقرر کیں فِيْهَآ : اس میں اَقْوَاتَهَا : ان کی خوراکیں فِيْٓ اَرْبَعَةِ اَيَّامٍ ۭ : چار دنوں میں سَوَآءً : یکساں لِّلسَّآئِلِيْنَ : تمام سوال کرنیوالوں کے لئے اور اس نے زمین میں اس کے اوپر سے پہاڑ گاڑ دیئے (1) اور اس میں برکت رکھ دی (2) اور اس میں (رہنے والوں) کی غذاؤں کی تجویز بھی اسی میں کردی (3) (صرف) چار دن میں (4) ضرورت مندوں کے لئے یکساں طور پر (5)۔
41,11,ثُمَّ اسْتَوٰۤى اِلَى السَّمَآءِ وَ هِیَ دُخَانٌ فَقَالَ لَهَا وَ لِلْاَرْضِ ائْتِیَا طَوْعًا اَوْ كَرْهًا١ؕ قَالَتَاۤ اَتَیْنَا طَآئِعِیْنَ ثُمَّ : پھر اسْتَوٰٓى : اس نے توجہ فرمائی اِلَى : طرف السَّمَآءِ : آسمان وَهِىَ : اور وہ دُخَانٌ : ایک دھواں فَقَالَ : تو اس نے کہا لَهَا : اس سے وَلِلْاَرْضِ : اور زمین سے ائْتِيَا : تم دونوں آؤ طَوْعًا : خوشی سے اَوْ كَرْهًا ۭ : یا ناخوشی سے قَالَتَآ : ان دونوں نے کہا اَتَيْنَا : ہم دونوں آئے (حاضر ہیں) طَآئِعِيْنَ : خوشی سے پھر آسمانوں کی طرف متوجہ ہوا اور وہ دھواں (سا) تھا پس اسے اور زمین سے فرمایا کہ تم دونوں خوشی سے آؤ یا ناخوشی سے (1) دونوں نے عرض کیا بخوشی حاضر ہیں۔
41,12,فَقَضٰىهُنَّ سَبْعَ سَمٰوَاتٍ فِیْ یَوْمَیْنِ وَ اَوْحٰى فِیْ كُلِّ سَمَآءٍ اَمْرَهَا١ؕ وَ زَیَّنَّا السَّمَآءَ الدُّنْیَا بِمَصَابِیْحَ١ۖۗ وَ حِفْظًا١ؕ ذٰلِكَ تَقْدِیْرُ الْعَزِیْزِ الْعَلِیْمِ فَقَضٰهُنَّ : پھر اس نے بنائے سَبْعَ : سات سَمٰوَاتٍ : آسمان فِيْ يَوْمَيْنِ : دو دنوں میں وَاَوْحٰى : اور وحی کردی فِيْ : میں، کو كُلِّ سَمَآءٍ : ہر آسمان اَمْرَهَا ۭ : اس کا کام وَزَيَّنَّا : اور ہم نے زینت دی السَّمَآءَ الدُّنْيَا : آسمانِ دنیا بِمَصَابِيْحَ ڰ : چراغوں (ستاروں) سے وَحِفْظًا ۭ : اور حفاظت کیلئے ذٰلِكَ تَقْدِيْرُ : یہ اندازہ (فیصلہ) الْعَزِيْزِ : غالب الْعَلِيْمِ : علم والا پس دو دن میں سات آسمان بنا دیئے اور ہر آسمان میں اس کے مناسب احکام کی وحی بھیج دی (1) اور ہم نے آسمان دنیا کو چراغوں سے زینت دی اور نگہبانی کی (2) یہ تدبیر اللہ غا لب و دانا کی ہے۔
41,13,فَاِنْ اَعْرَضُوْا فَقُلْ اَنْذَرْتُكُمْ صٰعِقَةً مِّثْلَ صٰعِقَةِ عَادٍ وَّ ثَمُوْدَؕ فَاِنْ : پھر اگر اَعْرَضُوْا : وہ منہ موڑلیں فَقُلْ : تو فرمادیں اَنْذَرْتُكُمْ : میں ڈراتا ہوں تمہیں صٰعِقَةً : ایک چنگھاڑ مِّثْلَ صٰعِقَةِ : جیسی چنگھاڑ عَادٍ : عاد وَّثَمُوْدَ : اور ثمود اب یہ روگردان ہوں تو کہہ دیجئے ! کہ میں تمہیں اس کڑک (عذاب آسمانی) سے اتارتا ہوں جو مثل عادیوں اور ثمودیوں کی کڑک کے ہوگی۔
41,14,اِذْ جَآءَتْهُمُ الرُّسُلُ مِنْۢ بَیْنِ اَیْدِیْهِمْ وَ مِنْ خَلْفِهِمْ اَلَّا تَعْبُدُوْۤا اِلَّا اللّٰهَ١ؕ قَالُوْا لَوْ شَآءَ رَبُّنَا لَاَنْزَلَ مَلٰٓئِكَةً فَاِنَّا بِمَاۤ اُرْسِلْتُمْ بِهٖ كٰفِرُوْنَ اِذْ : جب جَآءَتْهُمُ : آئے ان کے پاس الرُّسُلُ : رسول مِنْۢ بَيْنِ اَيْدِيْهِمْ : ان کے آگے سے وَمِنْ خَلْفِهِمْ : اور ان کے پیچھے سے اَلَّا تَعْبُدُوْٓا : کہ تم نہ عبادت کرو اِلَّا اللّٰهَ ۭ : سوائے اللہ قَالُوْا : انہوں نے جواب دیا لَوْ شَآءَ : اگر چاہتا رَبُّنَا : ہمارا رب لَاَنْزَلَ : تو ضرور اتارتا مَلٰٓئِكَةً : فرشتے فَاِنَّا : پس ہم بِمَآ : اس کا جو اُرْسِلْتُمْ : تم بھیجے گئے ہو بِهٖ كٰفِرُوْنَ : اسکے ساتھ منکر ہیں ان کے پاس جب ان کے آگے پیچھے سے پیغمبر آئے کہ تم اللہ کے سوا کسی کی عبادت نہ کرو تو انہوں نے جواب دیا کہ اگر ہمارا پروردگار چاہتا تو فرشتوں کو بھیجتا۔ ہم تو تمہاری رسالت کے بالکل منکر ہیں (1)
41,15,فَاَمَّا عَادٌ فَاسْتَكْبَرُوْا فِی الْاَرْضِ بِغَیْرِ الْحَقِّ وَ قَالُوْا مَنْ اَشَدُّ مِنَّا قُوَّةً١ؕ اَوَ لَمْ یَرَوْا اَنَّ اللّٰهَ الَّذِیْ خَلَقَهُمْ هُوَ اَشَدُّ مِنْهُمْ قُوَّةً١ؕ وَ كَانُوْا بِاٰیٰتِنَا یَجْحَدُوْنَ فَاَمَّا عَادٌ : پھر جو عاد فَاسْتَكْبَرُوْا : تو وہ غرور کرنے لگے فِي الْاَرْضِ : زمین (ملک) میں بِغَيْرِ الْحَقِّ : ناحق وَقَالُوْا : اور وہ کہنے لگے مَنْ اَشَدُّ : کون زیادہ مِنَّا قُوَّةً ۭ : ہم سے قوت میں اَوَلَمْ يَرَوْا : کیا وہ نہیں دیکھتے اَنَّ اللّٰهَ : کہ اللہ الَّذِيْ : وہ جس نے خَلَقَهُمْ : پیدا کیا انہیں هُوَ اَشَدُّ : وہ بہت زیادہ مِنْهُمْ : ان سے قُوَّةً ۭ : قوت وَكَانُوْا : اور وہ تھے بِاٰيٰتِنَا : ہماری آیتوں کا يَجْحَدُوْنَ : انکار کرتے اب قوم عاد نے تو بےوجہ زمین میں سرکشی شروع کردی اور کہنے لگے ہم سے زور آور کون ہے ؟ (1) کیا انہیں یہ نظر نہ آیا کہ جس نے اسے پیدا کیا وہ ان سے (بہت ہی) زیادہ زور آور ہے، (2) وہ (آخر تک) ہماری آیتوں کا (3) انکار ہی کرتے رہے۔
41,16,فَاَرْسَلْنَا عَلَیْهِمْ رِیْحًا صَرْصَرًا فِیْۤ اَیَّامٍ نَّحِسَاتٍ لِّنُذِیْقَهُمْ عَذَابَ الْخِزْیِ فِی الْحَیٰوةِ الدُّنْیَا١ؕ وَ لَعَذَابُ الْاٰخِرَةِ اَخْزٰى وَ هُمْ لَا یُنْصَرُوْنَ فَاَرْسَلْنَا : پس ہم نے بھیجی عَلَيْهِمْ : ان پر رِيْحًا : ہوا صَرْصَرًا : تند وتیز فِيْٓ اَيَّامٍ : دنوں میں نَّحِسَاتٍ : نحوست لِّنُذِيْقَهُمْ : تاکہ ہم چکھائیں عَذَابَ : عذاب الْخِزْيِ : رسوائی فِي : میں الْحَيٰوةِ الدُّنْيَا ۭ : دنیا کی زندگی وَلَعَذَابُ : اور البتہ عذاب الْاٰخِرَةِ : آخرت اَخْزٰى : زیادہ رسوا کرنیوالا وَهُمْ : اور وہ لَا يُنْصَرُوْنَ : مدد نہ کئے جائیں گے بالآخر ہم نے ان پر ایک تیز تند آندھی (1) منحوس دنوں میں (2) بھیج دی کہ انہیں دنیاوی زندگی میں ذلت کے عذاب کا مزہ چکھا دیں، اور (یقین مانو) کہ آخرت کا عذاب اس سے بہت زیادہ رسوائی والا اور وہ مدد نہیں کئے جائیں گے۔
41,17,وَ اَمَّا ثَمُوْدُ فَهَدَیْنٰهُمْ فَاسْتَحَبُّوا الْعَمٰى عَلَى الْهُدٰى فَاَخَذَتْهُمْ صٰعِقَةُ الْعَذَابِ الْهُوْنِ بِمَا كَانُوْا یَكْسِبُوْنَۚ وَاَمَّا : اور رہے ثَمُوْدُ : ثمود فَهَدَيْنٰهُمْ : سو ہم نے راستہ دکھایا انہیں فَاسْتَحَبُّوا : تو انہوں نے پسند کیا الْعَمٰى : اندھا رہنا عَلَي : پر الْهُدٰى : ہدایت فَاَخَذَتْهُمْ : تو انہیں آپکڑا صٰعِقَةُ : چنگھاڑ الْعَذَابِ : عذاب الْهُوْنِ : ذلت بِمَا : اس کی سزا میں جو كَانُوْا يَكْسِبُوْنَ : وہ کماتے (کرتے) تھے رہے قوم ثمود، سو ہم نے ان کی بھی راہبری کی (1) پھر بھی انہوں نے ہدایت پر اندھے پن کو ترجیح دی (2) جس بنا پر انہیں (سراپا) ذلت کے عذاب، کی کڑک نے ان کے کرتوتوں کے باعث پکڑ لیا۔ (3)
41,18,وَ نَجَّیْنَا الَّذِیْنَ اٰمَنُوْا وَ كَانُوْا یَتَّقُوْنَ۠    ۧ وَنَجَّيْنَا : اور ہم نے بچالیا الَّذِيْنَ : وہ لوگ جو اٰمَنُوْا : ایمان لائے وَكَانُوْا : اور وہ تھے يَتَّقُوْنَ : پرہیزگاری کرتے اور (ہاں) ایمان دار اور پارساؤں کو ہم نے (بال بال) بچا لیا۔
41,19,وَ یَوْمَ یُحْشَرُ اَعْدَآءُ اللّٰهِ اِلَى النَّارِ فَهُمْ یُوْزَعُوْنَ وَيَوْمَ : اور جس دن يُحْشَرُ : جمع کئے جائیں گے اَعْدَآءُ اللّٰهِ : اللہ کے دشمن اِلَى : طرف النَّارِ : جہنم فَهُمْ : تو وہ يُوْزَعُوْنَ : گروہ گروہ کئے جائیں گے اور جس دن (1) اللہ کے دشمن دوزخ کی طرف لائے جائیں گے اور ان (سب) کو جمع کردیا جائے گا۔ (2)
41,20,حَتّٰۤى اِذَا مَا جَآءُوْهَا شَهِدَ عَلَیْهِمْ سَمْعُهُمْ وَ اَبْصَارُهُمْ وَ جُلُوْدُهُمْ بِمَا كَانُوْا یَعْمَلُوْنَ حَتّىٰٓ : یہاں تک کہ اِذَا : جب مَا جَآءُوْهَا : وہ آئیں گے اس کے پاس شَهِدَ : گواہی دیں گے عَلَيْهِمْ : ان پر سَمْعُهُمْ : ان کے کان وَاَبْصَارُهُمْ : اور ان کی آنکھیں وَجُلُوْدُهُمْ : اور انکی جلدیں (گوشت پوست) بِمَا : اس پر كَانُوْا يَعْمَلُوْنَ : جو وہ کرتے تھے یہاں تک کہ جب بالکل جہنم کے پاس آجائیں گے ان پر ان کے کان پر اور ان کی آنکھیں اور ان کی کھالیں ان کے اعمال کی گواہی دیں گی (1)
41,21,وَ قَالُوْا لِجُلُوْدِهِمْ لِمَ شَهِدْتُّمْ عَلَیْنَا١ؕ قَالُوْۤا اَنْطَقَنَا اللّٰهُ الَّذِیْۤ اَنْطَقَ كُلَّ شَیْءٍ وَّ هُوَ خَلَقَكُمْ اَوَّلَ مَرَّةٍ وَّ اِلَیْهِ تُرْجَعُوْنَ وَقَالُوْا : اور وہ کہیں گے لِجُلُوْدِهِمْ : اپنی جلدوں سے لِمَ : کیوں شَهِدْتُّمْ : تم نے گواہی دی عَلَيْنَا ۭ : ہم پر (ہمارے خلاف) قَالُوْٓا : وہ جواب دیں گے اَنْطَقَنَا : ہمیں گویائی دی اللّٰهُ : اللہ نے الَّذِيْٓ : وہ جس نے اَنْطَقَ : گویا فرمایا كُلَّ شَيْءٍ : ہر شے وَّهُوَ خَلَقَكُمْ : اور وہ تمہیں پیدا کیا اَوَّلَ مَرَّةٍ : پہلی بار وَّاِلَيْهِ : اور اسی کی طرف تُرْجَعُوْنَ : تم لوٹائے جاؤگے یہ اپنی کھالوں سے کہیں گے کہ تم نے ہمارے خلاف شہادت کیوں دی (1) وہ جواب دیں گی ہمیں اس اللہ نے قوت گویائی عطا فرمائی جس نے ہر چیز کو بولنے کی طاقت بخشی ہے، اسی نے تمہیں اول مرتبہ پیدا کیا اور اسی کی طرف تم سب لوٹائے جاؤ گے۔ (2)
41,22,وَ مَا كُنْتُمْ تَسْتَتِرُوْنَ اَنْ یَّشْهَدَ عَلَیْكُمْ سَمْعُكُمْ وَ لَاۤ اَبْصَارُكُمْ وَ لَا جُلُوْدُكُمْ وَ لٰكِنْ ظَنَنْتُمْ اَنَّ اللّٰهَ لَا یَعْلَمُ كَثِیْرًا مِّمَّا تَعْمَلُوْنَ وَمَا : اور جو كُنْتُمْ : تھے تَسْتَتِرُوْنَ : تم چھپاتے اَنْ يَّشْهَدَ : کہ گواہی دیں گے عَلَيْكُمْ : تم پر (تمہارے خلاف) سَمْعُكُمْ : تمہارے کان وَلَآ : اور نہ اَبْصَارُكُمْ : تمہاری آنکھیں وَلَا جُلُوْدُكُمْ : اور نہ تمہاری جلدیں (گوشت پوست) وَلٰكِنْ : اور لیکن (بلکہ) ظَنَنْتُمْ : تم نے گمان کرلیا تھا اَنَّ اللّٰهَ : کہ اللہ لَا يَعْلَمُ كَثِيْرًا : نہیں جانتا بہت کچھ مِّمَّا تَعْمَلُوْنَ : اس سے تم کرتے ہو اور تم (اپنی بد اعمالیوں) اس وجہ سے پوشیدہ رکھتے ہی نہ تھے کہ تم پر تمہارے کان اور تمہاری آنکھیں اور تمہاری کھالیں گواہی دیں گی (1) ہاں تم یہ سمجھتے رہے کہ تم جو کچھ کر رہے ہو اس میں سے بہت سے اعمال سے اللہ بیخبر ہے۔ (2)
41,23,وَ ذٰلِكُمْ ظَنُّكُمُ الَّذِیْ ظَنَنْتُمْ بِرَبِّكُمْ اَرْدٰىكُمْ فَاَصْبَحْتُمْ مِّنَ الْخٰسِرِیْنَ وَذٰلِكُمْ : اور اس ظَنُّكُمُ : تمہارا گمان الَّذِيْ : وہ جو ظَنَنْتُمْ : تم نے گمان کیا تھا بِرَبِّكُمْ : اپنے پروردگار کے متعلق اَرْدٰىكُمْ : ہلاک کیا تمہیں فَاَصْبَحْتُمْ : سو تم ہوگئے مِّنَ : سے الْخٰسِرِيْنَ : خسارہ پانے والے تمہاری اس بدگمانی نے جو تم نے اپنے رب سے کر رکھی تھی تمہیں ہلاک کردیا (3) اور بالآخر تم زیاں کاروں میں ہوگئے۔
41,24,فَاِنْ یَّصْبِرُوْا فَالنَّارُ مَثْوًى لَّهُمْ١ۚ وَ اِنْ یَّسْتَعْتِبُوْا فَمَا هُمْ مِّنَ الْمُعْتَبِیْنَ فَاِنْ يَّصْبِرُوْا : پھر اگر وہ صبر کریں فَالنَّارُ : تو جہنم مَثْوًى لَّهُمْ ۭ : ٹھکانہ ان کے لئے وَاِنْ : اور اگر يَّسْتَعْتِبُوْا : وہ معافی چاہیں فَمَا هُمْ : تو نہ وہ مِّنَ الْمُعْتَبِيْنَ : معافی قبول کئے جانے والوں میں سے اب اگر یہ صبر کریں تو بھی ان کا ٹھکانا جہنم ہی ہے۔ اور اگر یہ (عذر و) معافی کے خواستگار ہوں تو بھی معذور و) معاف نہیں رکھے جائیں گے (1)
41,25,وَ قَیَّضْنَا لَهُمْ قُرَنَآءَ فَزَیَّنُوْا لَهُمْ مَّا بَیْنَ اَیْدِیْهِمْ وَ مَا خَلْفَهُمْ وَ حَقَّ عَلَیْهِمُ الْقَوْلُ فِیْۤ اُمَمٍ قَدْ خَلَتْ مِنْ قَبْلِهِمْ مِّنَ الْجِنِّ وَ الْاِنْسِ١ۚ اِنَّهُمْ كَانُوْا خٰسِرِیْنَ۠    ۧ وَقَيَّضْنَا : اور ہم نے مقرر کئے لَهُمْ قُرَنَآءَ : ان کیلئے کچھ ہم نشین فَزَيَّنُوْا : تو انہوں نے آراستہ کردکھایا لَهُمْ : ان کے لئے مَّا : جو بَيْنَ اَيْدِيْهِمْ : ان کے آگے وَمَا : اور جو خَلْفَهُمْ : ان کے پیچھے وَحَقَّ : اور پوری ہوگئی عَلَيْهِمُ : ان پر الْقَوْلُ : بات فِيْٓ اُمَمٍ : ان امتوں میں قَدْ خَلَتْ : جو گزرچکیں مِنْ قَبْلِهِمْ : ان سے قبل مِّنَ الْجِنِّ : جنات میں سے، کی وَالْاِنْسِ ۚ : اور انسان اِنَّهُمْ : بیشک وہ كَانُوْا : تھے خٰسِرِيْنَ : خسارہ پانے والے اور ہم نے ان کے کچھ ہم نشین مقرر کر رکھے تھے جنہوں نے ان کے اگلے پچھلے اعمال ان کی نگاہوں میں خوبصورت بنا رکھے (1) تھے اور ان کے حق میں بھی اللہ کا قول امتوں کے ساتھ پورا ہوا جو ان سے پہلے جنوں اور انسانوں کی گزر چکی ہیں۔ یقیناً وہ زیاں کار ثابت ہوئے۔
41,26,وَ قَالَ الَّذِیْنَ كَفَرُوْا لَا تَسْمَعُوْا لِهٰذَا الْقُرْاٰنِ وَ الْغَوْا فِیْهِ لَعَلَّكُمْ تَغْلِبُوْنَ وَقَالَ : اور کہا الَّذِيْنَ : ان لوگوں نے جو كَفَرُوْا : انہوں نے کفر کیا لَا تَسْمَعُوْا : تم مت سنو لِھٰذَا الْقُرْاٰنِ : یہ قرآن وَالْغَوْا فِيْهِ : اور غل مچاؤ اس میں لَعَلَّكُمْ : شاید کہ تم تَغْلِبُوْنَ : تم غالب آجاؤ اور کافروں نے کہا اس قرآن کی سنو ہی مت (1) (اس کے پڑھے جانے کے وقت) اور بےہودہ گوئی کرو (2) کیا عجب کہ تم غالب آجاؤ (3)
41,27,فَلَنُذِیْقَنَّ الَّذِیْنَ كَفَرُوْا عَذَابًا شَدِیْدًا١ۙ وَّ لَنَجْزِیَنَّهُمْ اَسْوَاَ الَّذِیْ كَانُوْا یَعْمَلُوْنَ فَلَنُذِيْقَنَّ : پس ہم ضرور چکھائیں گے الَّذِيْنَ : ان لوگوں کو جنہوں نے كَفَرُوْا : کفر کیا (کافر) عَذَابًا شَدِيْدًا ۙ : عذاب سخت وَّلَنَجْزِيَنَّهُم : اور ہم انہیں ضرور بدلہ دیں گے ْاَسْوَاَ : بدترین الَّذِيْ : وہ جو كَانُوْا يَعْمَلُوْنَ : وہ کرتے تھے (اعمال) پس یقیناً ہم ان کافروں کو سخت عذاب کا مزہ چکھائیں گے۔ اور انہیں ان کے بدترین اعمال کا بدلہ (ضرور) ضرور دیں گے (1)
41,28,ذٰلِكَ جَزَآءُ اَعْدَآءِ اللّٰهِ النَّارُ١ۚ لَهُمْ فِیْهَا دَارُ الْخُلْدِ١ؕ جَزَآءًۢ بِمَا كَانُوْا بِاٰیٰتِنَا یَجْحَدُوْنَ ذٰلِكَ : یہ جَزَآءُ : بدلہ اَعْدَآءِ اللّٰهِ : اللہ کے دشمن (جمع) النَّارُ ۚ : جہنم لَهُمْ : ان کے لئے فِيْهَا : اس میں دَارُ الْخُلْدِ ۭ : ہمیشگی کا گھر جَزَآءًۢ : بدلہ بِمَا : اس کا جو كَانُوْا : وہ تھے بِاٰيٰتِنَا : ہماری آیتوں کا يَجْحَدُوْنَ : انکار کرتے اللہ کے دشمنوں کی سزا یہی دوزخ کی آگ ہے جس میں ان کا ہمیشگی کا گھر ہے (یہ) بدلہ ہے ہماری آیتوں سے انکار کرنے کا۔
41,29,وَ قَالَ الَّذِیْنَ كَفَرُوْا رَبَّنَاۤ اَرِنَا الَّذَیْنِ اَضَلّٰنَا مِنَ الْجِنِّ وَ الْاِنْسِ نَجْعَلْهُمَا تَحْتَ اَقْدَامِنَا لِیَكُوْنَا مِنَ الْاَسْفَلِیْنَ وَقَالَ : اور کہیں گے الَّذِيْنَ كَفَرُوْا : وہ لوگ جنہوں نے کفر کیا رَبَّنَآ : اے ہمارے رب اَرِنَا : ہمیں دکھادے الَّذَيْنِ : وہ دونوں اَضَلّٰنَا : جنہوں نے گمراہ کیا ہمیں مِنَ الْجِنِّ : جنات میں سے وَالْاِنْسِ : اور انسانوں نَجْعَلْهُمَا : ہم ان دونوں کو ڈالیں تَحْتَ اَقْدَامِنَا : اپنے پاؤں تلے لِيَكُوْنَا : تاکہ وہ ہوں مِنَ : سے الْاَسْفَلِيْنَ : انتہائی ذلیل (جمع) اور کافر لوگ کہیں گے اے ہمارے رب ! ہمیں جنوں انسانوں (کے وہ دونوں فریق) دکھا جنہوں نے ہمیں گمراہ کیا (1) ہے (تاکہ) ہم انہیں اپنے قدموں تلے ڈال دیں تاکہ وہ جہنم میں سب سے نیچے (سخت عذاب میں) ہوجائیں۔ (2)
41,30,اِنَّ الَّذِیْنَ قَالُوْا رَبُّنَا اللّٰهُ ثُمَّ اسْتَقَامُوْا تَتَنَزَّلُ عَلَیْهِمُ الْمَلٰٓئِكَةُ اَلَّا تَخَافُوْا وَ لَا تَحْزَنُوْا وَ اَبْشِرُوْا بِالْجَنَّةِ الَّتِیْ كُنْتُمْ تُوْعَدُوْنَ اِنَّ : بیشک الَّذِيْنَ : وہ جنہوں نے قَالُوْا : انہوں نے کہا رَبُّنَا اللّٰهُ : ہمارا رب اللہ ثُمَّ : پھر اسْتَقَامُوْا : وہ ثابت قدم رہے تَتَنَزَّلُ : اترتے ہیں عَلَيْهِمُ : ان پر الْمَلٰٓئِكَةُ : فرشتے اَلَّا تَخَافُوْا : کہ نہ تم خوف کھاؤ وَلَا تَحْزَنُوْا : اور نہ غمگین ہو وَاَبْشِرُوْا : اور تم خوش ہو بِالْجَنَّةِ : جنت پر الَّتِيْ : وہ جو كُنْتُمْ تُوْعَدُوْنَ : تمہیں وعدہ دیاجاتا تھا (واقعی) جن لوگوں نے کہا ہمارا پروردگار اللہ ہے (1) اور پھر اسی پر قائم رہے (2) ان کے پاس فرشتے (یہ کہتے ہوئے) آتے ہیں (4) کہ تم کچھ بھی اندیشہ اور غم نہ کرو (3) (بلکہ) اس جنت کی بشارت سن لو جس کا تم وعدہ دیئے گئے ہو (5)۔
41,31,نَحْنُ اَوْلِیٰٓؤُكُمْ فِی الْحَیٰوةِ الدُّنْیَا وَ فِی الْاٰخِرَةِ١ۚ وَ لَكُمْ فِیْهَا مَا تَشْتَهِیْۤ اَنْفُسُكُمْ وَ لَكُمْ فِیْهَا مَا تَدَّعُوْنَؕ نَحْنُ : ہم اَوْلِيٰٓؤُكُمْ : تمہارے رفیق فِي الْحَيٰوةِ : زندگی میں الدُّنْيَا : دنیا وَفِي الْاٰخِرَةِ ۚ : اور آخرت میں وَلَكُمْ : اور تمہارے لئے فِيْهَا : اس میں مَا تَشْتَهِيْٓ : جو چاہیں اَنْفُسُكُمْ : تمہارے دل وَلَكُمْ : اور تمہارے لئے فِيْهَا : اس میں مَا تَدَّعُوْنَ : جو تم مانگو گے تمہاری دنیاوی زندگی میں بھی ہم تمہارے رفیق تھے اور آخرت میں بھی رہیں گے (1) جس چیز کو تمہارا جی چاہے اور جو کچھ تم مانگو سب تمہارے لئے (جنت میں موجود) ہے۔
41,32,نُزُلًا مِّنْ غَفُوْرٍ رَّحِیْمٍ۠    ۧ نُزُلًا : ضیافت مِّنْ : سے غَفُوْرٍ : بخشنے والا رَّحِيْمٍ : مہربان غفور و رحیم (معبود) کی طرف سے یہ سب کچھ بطور مہمانی کے ہے۔
41,33,وَ مَنْ اَحْسَنُ قَوْلًا مِّمَّنْ دَعَاۤ اِلَى اللّٰهِ وَ عَمِلَ صَالِحًا وَّ قَالَ اِنَّنِیْ مِنَ الْمُسْلِمِیْنَ وَمَنْ : اور کس اَحْسَنُ : بہترین قَوْلًا : بات مِّمَّنْ : اس سے جو دَعَآ : بلائے اِلَى اللّٰهِ : اللہ کی طرف وَعَمِلَ : اور عمل کرے صَالِحًا : اچھے وَّقَالَ : اور وہ کہے اِنَّنِيْ : بیشک میں مِنَ : سے الْمُسْلِمِيْنَ : مسلمانوں اور اس سے زیادہ اچھی بات والا کون ہے جو اللہ کی طرف بلائے اور نیک کام کرے اور کہے کہ میں یقیناً مسلمانوں میں سے ہوں (1)
41,34,وَ لَا تَسْتَوِی الْحَسَنَةُ وَ لَا السَّیِّئَةُ١ؕ اِدْفَعْ بِالَّتِیْ هِیَ اَحْسَنُ فَاِذَا الَّذِیْ بَیْنَكَ وَ بَیْنَهٗ عَدَاوَةٌ كَاَنَّهٗ وَلِیٌّ حَمِیْمٌ وَلَا تَسْتَوِي : اور برابر نہیں ہوتی الْحَسَنَةُ : نیکی وَلَا السَّيِّئَةُ ۭ : اور نہ بُرائی اِدْفَعْ : دور کردیں بِالَّتِيْ : اس سے جو هِىَ اَحْسَنُ : وہ بہترین فَاِذَا الَّذِيْ : تو یکایک وہ جو شخص بَيْنَكَ : آپ کے درمیان وَبَيْنَهٗ : اور اس کے درمیان عَدَاوَةٌ : عداوت كَاَنَّهٗ وَلِيٌّ : گویا کہ وہ دوست حَمِيْمٌ : قرابتی (جگری) نیکی اور بدی برابر نہیں ہوتی (1) برائی کو بھلائی سے دفع کرو پھر وہی جس کے اور تمہارے درمیان دشمنی ہے ایسا ہوجائے گا جیسے دلی دوست۔ (2)
41,35,وَ مَا یُلَقّٰىهَاۤ اِلَّا الَّذِیْنَ صَبَرُوْا١ۚ وَ مَا یُلَقّٰىهَاۤ اِلَّا ذُوْ حَظٍّ عَظِیْمٍ وَمَا يُلَقّٰىهَآ : اور نہیں ملتی یہ اِلَّا : مگر الَّذِيْنَ : وہ جنہوں نے صَبَرُوْا ۚ : صبر کیا وَمَا يُلَقّٰىهَآ : اور نہیں ملتی یہ اِلَّا : مگر ذُوْ حَظٍّ : نصیب والے عَظِيْمٍ : بڑے اور یہ بات انہیں نصیب ہوتی ہے جو صبر کریں (1) اور اسے سوائے بڑے نصیبے والوں کے کوئی نہیں پاسکتا (2)
41,36,وَ اِمَّا یَنْزَغَنَّكَ مِنَ الشَّیْطٰنِ نَزْغٌ فَاسْتَعِذْ بِاللّٰهِ١ؕ اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُ وَاِمَّا يَنْزَغَنَّكَ : اور اگر تمہیں وسوسہ آئے۔ مِنَ : سے الشَّيْطٰنِ : شیطان نَزْغٌ : کوئی وسوسہ فَاسْتَعِذْ باللّٰهِ ۭ : تو پناہ چاہیں اللہ کی اِنَّهٗ : بیشک وہ هُوَ السَّمِيْعُ : وہی سننے والا الْعَلِيْمُ : جاننے والا اور اگر شیطان کی طرف سے کوئی وسوسہ آئے تو اللہ کی پناہ طلب کرو (1) یقیناً وہ بہت ہی سننے والا جاننے والا ہے (2)
41,37,وَ مِنْ اٰیٰتِهِ الَّیْلُ وَ النَّهَارُ وَ الشَّمْسُ وَ الْقَمَرُ١ؕ لَا تَسْجُدُوْا لِلشَّمْسِ وَ لَا لِلْقَمَرِ وَ اسْجُدُوْا لِلّٰهِ الَّذِیْ خَلَقَهُنَّ اِنْ كُنْتُمْ اِیَّاهُ تَعْبُدُوْنَ وَمِنْ اٰيٰتِهِ : اور اس کی نشانیوں میں سے ہے الَّيْلُ : رات وَالنَّهَارُ : اور دن وَالشَّمْسُ : اور سورج وَالْقَمَرُ ۭ : اور چاند لَا تَسْجُدُوْا : اور نہ سجدہ کرو لِلشَّمْسِ : سورج کو وَلَا لِلْقَمَرِ : اور نہ چاند کو وَاسْجُدُوْا : اور تم سجدہ کرو لِلّٰهِ : اللہ کو الَّذِيْ : وہ جس نے خَلَقَهُنَّ : پیدا کیا انہیں اِنْ كُنْتُمْ : اگر تم ہو اِيَّاهُ : اس کی تَعْبُدُوْنَ : عبادت کرتے اور دن رات اور سورج چاند بھی (اسی کی) نشانیوں میں سے ہیں (1) تم سورج کو سجدہ نہ کرو نہ چاند کو (2) بلکہ سجدہ اس اللہ کے لئے کرو جس نے سب کو پیدا کیا ہے (3) اگر تمہیں اس کی عبادت کرنی ہے تو۔
41,38,فَاِنِ اسْتَكْبَرُوْا فَالَّذِیْنَ عِنْدَ رَبِّكَ یُسَبِّحُوْنَ لَهٗ بِالَّیْلِ وَ النَّهَارِ وَ هُمْ لَا یَسْئَمُوْنَ۩  ۞ فَاِنِ : پس اگر وہ اسْتَكْبَرُوْا : تکبر کریں فَالَّذِيْنَ : سو وہ جو عِنْدَ رَبِّكَ : آپ کے رب کے نزدیک يُسَبِّحُوْنَ : وہ تسبیح کرتے ہیں لَهٗ بالَّيْلِ : اس کی رات وَالنَّهَارِ : اور دن وَهُمْ : اور وہ لَا يَسْئَمُوْنَ : نہیں اکتاتے پھر بھی اگر یہ کبر و غرور کریں تو وہ (فرشتے) جو آپ کے رب کے نزدیک ہیں وہ تو رات دن اس کی تسبیح بیان کر رہے ہیں اور (کسی وقت بھی) نہیں اکتاتے۔
41,39,وَ مِنْ اٰیٰتِهٖۤ اَنَّكَ تَرَى الْاَرْضَ خَاشِعَةً فَاِذَاۤ اَنْزَلْنَا عَلَیْهَا الْمَآءَ اهْتَزَّتْ وَ رَبَتْ١ؕ اِنَّ الَّذِیْۤ اَحْیَاهَا لَمُحْیِ الْمَوْتٰى١ؕ اِنَّهٗ عَلٰى كُلِّ شَیْءٍ قَدِیْرٌ وَمِنْ اٰيٰتِهٖٓ : اور اس کی نشانیوں میں سے اَنَّكَ تَرَى : کہ تو تو دیکھتا ہے الْاَرْضَ : زمین خَاشِعَةً : دبی ہوئی (سنسان) فَاِذَآ اَنْزَلْنَا : پھر جب ہم نے اتارا عَلَيْهَا : اس پر الْمَآءَ : پانی اهْتَزَّتْ : وہ لہلہانے لگتی ہے وَرَبَتْ ۭ : اور پھولتی ہے اِنَّ الَّذِيْٓ : بیشک وہ جس نے اَحْيَاهَا : اس کو زندہ کیا لَمُحْىِ : البتہ زندہ کرنیوالا الْمَوْتٰى ۭ : مردوں کو اِنَّهٗ : بیشک وہ عَلٰي كُلِّ شَيْءٍ : ہر شے پر قَدِيْرٌ : قدرت رکھنے والا اور اس اللہ کی نشانیوں میں سے (یہ بھی) ہے کہ تو زمین کو دبی دبائی دیکھتا ہے (1) پھر جب ہم اس پر مینہ برساتے ہیں تو وہی ترو تازہ ہو کر ابھرنے لگتی ہے (2) جس نے اسے زندہ کیا وہی یقینی طور پر مردوں کو بھی زندہ کرنے والا ہے (3)
41,40,اِنَّ الَّذِیْنَ یُلْحِدُوْنَ فِیْۤ اٰیٰتِنَا لَا یَخْفَوْنَ عَلَیْنَا١ؕ اَفَمَنْ یُّلْقٰى فِی النَّارِ خَیْرٌ اَمْ مَّنْ یَّاْتِیْۤ اٰمِنًا یَّوْمَ الْقِیٰمَةِ١ؕ اِعْمَلُوْا مَا شِئْتُمْ١ۙ اِنَّهٗ بِمَا تَعْمَلُوْنَ بَصِیْرٌ اِنَّ الَّذِيْنَ : بیشک جو لوگ يُلْحِدُوْنَ : کج روی کرتے ہیں فِيْٓ اٰيٰتِنَا : ہماری آیات سے لَا يَخْفَوْنَ : وہ پوشیدہ نہیں عَلَيْنَا ۭ : ہم پر اَفَمَنْ يُّلْقٰى : تو کیا جو ڈالا جائے فِي النَّارِ : آگ میں خَيْرٌ : بہتر اَمْ : یا مَّنْ يَّاْتِيْٓ : جو آئے اٰمِنًا : امان کے ساتھ يَّوْمَ الْقِيٰمَةِ ۭ : روز قیامت اِعْمَلُوْا : تم کرو مَا شِئْتُمْ ۙ : جو تم چاہو اِنَّهٗ بِمَا : بیشک وہ جو تَعْمَلُوْنَ : تم کرتے ہو بَصِيْرٌ : دیکھنے والا بیشک جو لوگ ہماری آیتوں میں کج روی کرتے ہیں (1) وہ (کچھ) ہم سے مخفی نہیں (2) (بتلاؤ تو) جو آگ میں ڈالا جائے وہ اچھا ہے یا وہ جو امن وامان کے ساتھ قیامت کے دن آئے ؟ (2) تم جو چاہو کرتے چلے جاؤ (3) وہ تمہارا سب کیا کرایا دیکھ رہا ہے۔ (4)
41,41,اِنَّ الَّذِیْنَ كَفَرُوْا بِالذِّكْرِ لَمَّا جَآءَهُمْ١ۚ وَ اِنَّهٗ لَكِتٰبٌ عَزِیْزٌۙ اِنَّ الَّذِيْنَ : بیشک وہ جنہوں نے كَفَرُوْا : انکار کیا بِالذِّكْرِ : ذکر (قرآن) کا لَمَّا : جب جَآءَهُمْ ۚ : وہ آیا ان کے پاس وَاِنَّهٗ : اور بیشک یہ لَكِتٰبٌ : البتہ کتاب ہے عَزِيْزٌ : گرامی قدر جن لوگوں نے اپنے پاس قرآن پہنچ جانے کے باوجود اس سے کفر کیا، (وہ بھی ہم سے پوشیدہ نہیں) یہ (1) با وقعت کتاب ہے (2)
41,42,لَّا یَاْتِیْهِ الْبَاطِلُ مِنْۢ بَیْنِ یَدَیْهِ وَ لَا مِنْ خَلْفِهٖ١ؕ تَنْزِیْلٌ مِّنْ حَكِیْمٍ حَمِیْدٍ لَّا يَاْتِيْهِ : اسکے پاس نہیں آتا الْبَاطِلُ : باطل مِنْۢ بَيْنِ يَدَيْهِ : اسکے سامنے سے وَلَا : اور نہ مِنْ خَلْفِهٖ ۭ : اس کے پیچھے سے تَنْزِيْلٌ : نازل کیا گیا مِّنْ : سے حَكِيْمٍ : حکمت والے حَمِيْدٍ : سزاوار حمد جس کے پاس باطل پھٹک نہیں سکتا نہ اس کے آگے سے اور نہ اس کے پیچھے سے، یہ ہے نازل کردہ حکمتوں والے خوبیوں والے (اللہ) کی طرف سے (1)
41,43,مَا یُقَالُ لَكَ اِلَّا مَا قَدْ قِیْلَ لِلرُّسُلِ مِنْ قَبْلِكَ١ؕ اِنَّ رَبَّكَ لَذُوْ مَغْفِرَةٍ وَّ ذُوْ عِقَابٍ اَلِیْمٍ مَا يُقَالُ : نہیں کہاجاتا لَكَ : آپ کو اِلَّا : سوائے مَا : جو قَدْ قِيْلَ : کہا جاچکا ہے لِلرُّسُلِ : رسولوں کو مِنْ قَبْلِكَ ۭ : آپ سے قبل اِنَّ : بیشک رَبَّكَ : آپ کا رب لَذُوْ مَغْفِرَةٍ : بڑی مغفرت والا وَّذُوْ عِقَابٍ : اور سزا دینے والا اَلِيْمٍ : دردناک آپ سے وہی کہا جاتا ہے جو آپ سے پہلے کے رسولوں سے بھی کہا گیا ہے (1) یقیناً آپ کا رب معافی والا (2) اور دردناک عذاب والا ہے (3)۔
41,44,وَ لَوْ جَعَلْنٰهُ قُرْاٰنًا اَعْجَمِیًّا لَّقَالُوْا لَوْ لَا فُصِّلَتْ اٰیٰتُهٗ١ؕ ءَؔاَعْجَمِیٌّ وَّ عَرَبِیٌّ١ؕ قُلْ هُوَ لِلَّذِیْنَ اٰمَنُوْا هُدًى وَّ شِفَآءٌ١ؕ وَ الَّذِیْنَ لَا یُؤْمِنُوْنَ فِیْۤ اٰذَانِهِمْ وَقْرٌ وَّ هُوَ عَلَیْهِمْ عَمًى١ؕ اُولٰٓئِكَ یُنَادَوْنَ مِنْ مَّكَانٍۭ بَعِیْدٍ۠    ۧ وَلَوْ : اور اگر جَعَلْنٰهُ : ہم بناتے قُرْاٰنًا : قرآن کو اَعْجَمِيًّا : عجمی (زبان کا) لَّقَالُوْا : تو وہ کہتے لَوْلَا : کیوں نہ فُصِّلَتْ : صاف بیان کی گئیں اٰيٰتُهٗ ڼ : اس کی آیتیں ءَاَعْجَمِيٌّ : کیا عجمی (کتاب) وَّعَرَبِيٌّ ۭ : اور عربی (رسول) قُلْ : فرمادیں هُوَ : وہ، یہ لِلَّذِيْنَ : ان لوگوں کیلئے جو اٰمَنُوْا : ایمان لائے هُدًى : ہدایت وَّشِفَآءٌ ۭ : اور شفاء وَالَّذِيْنَ : اور جو لوگ لَا يُؤْمِنُوْنَ : ایمان نہیں لائے فِيْٓ اٰذَانِهِمْ : انکے کانوں میں وَقْرٌ : گرانی وَّهُوَ : اور وہ ۔ یہ عَلَيْهِمْ : ان پر عَمًى ۭ : اندھا پن اُولٰٓئِكَ : یہ لوگ يُنَادَوْنَ : پکارے جاتے ہیں مِنْ : سے مَّكَانٍۢ : کسی جگہ بَعِيْدٍ : دور اور اگر ہم اسے عجمی زبان کا قرآن بناتے تو کہتے (1) کہ اس کی آیتیں صاف صاف بیان کیوں نہیں کی گئیں ؟ (2) یہ کیا کہ عجمی کتاب اور آپ عربی رسول ؟ (3) آپ کہہ دیجئے ! کہ یہ تو ایمان والوں کے لئے ہدایت و شفا ہے اور جو ایمان نہیں لاتے ان کے کانوں میں تو (بہرہ پن اور) بوجھ ہے اور یہ ان پر اندھا پن ہے، یہ وہ لوگ ہیں جو کسی بہت دور دراز جگہ سے پکارے جا رہے ہیں (4)
41,45,وَ لَقَدْ اٰتَیْنَا مُوْسَى الْكِتٰبَ فَاخْتُلِفَ فِیْهِ١ؕ وَ لَوْ لَا كَلِمَةٌ سَبَقَتْ مِنْ رَّبِّكَ لَقُضِیَ بَیْنَهُمْ١ؕ وَ اِنَّهُمْ لَفِیْ شَكٍّ مِّنْهُ مُرِیْبٍ وَلَقَدْ اٰتَيْنَا : اور تحقیق ہم نے دی مُوْسَى : موسیٰ الْكِتٰبَ : کتاب فَاخْتُلِفَ : تو اختلاف کیا فِيْهِ ۭ : اس میں وَلَوْلَا : اور اگر نہ ہوتی كَلِمَةٌ : ایک بات سَبَقَتْ : پہلے ٹھہر چکی مِنْ : سے رَّبِّكَ : آپ کا رب لَقُضِيَ : تو فیصلہ ہوچکا ہوتا بَيْنَهُمْ ۭ : ان کے درمیان وَاِنَّهُمْ : اور بیشک وہ لَفِيْ شَكٍّ : ضرور شک میں مِّنْهُ : اس سے مُرِيْبٍ : تردد میں ڈالنے والے شک میں یقیناً ہم نے موسیٰ ؑ کو کتاب دی تھی، سو اس میں بھی اختلاف کیا گیا اور اگر (وہ) بات نہ ہوتی (جو) آپ کے رب کی طرف سے پہلے ہی مقرر ہوچکی ہے (1) تو ان کے درمیان (کبھی) کا فیصلہ ہوچکا ہوتا (2) یہ لوگ تو اسکے بارے میں سخت بےچین کرنے والے شک میں ہیں (3)
41,46,مَنْ عَمِلَ صَالِحًا فَلِنَفْسِهٖ وَ مَنْ اَسَآءَ فَعَلَیْهَا١ؕ وَ مَا رَبُّكَ بِظَلَّامٍ لِّلْعَبِیْدِ مَنْ عَمِلَ : جس نے عمل کیا صَالِحًا : اچھے فَلِنَفْسِهٖ : تو اپنی ذات کیلئے وَمَنْ اَسَآءَ : اور جسنے بُرائی کی فَعَلَيْهَا ۭ : تو اس پر (ا سکا وبال) وَمَا رَبُّكَ : اور نہیں آپ کا رب بِظَلَّامٍ : مطلق ظلم کرنے والا لِّلْعَبِيْدِ : اپنے بندوں پر جو شخص نیک کام کرے گا وہ اپنے نفع کے لئے اور جو برا کام کرے گا اس کا وبال بھی اسی پر ہے۔ اور آپ کا رب بندوں پر ظلم کرنے والا نہیں (1)۔
41,47,اِلَیْهِ یُرَدُّ عِلْمُ السَّاعَةِ١ؕ وَ مَا تَخْرُجُ مِنْ ثَمَرٰتٍ مِّنْ اَكْمَامِهَا وَ مَا تَحْمِلُ مِنْ اُنْثٰى وَ لَا تَضَعُ اِلَّا بِعِلْمِهٖ١ؕ وَ یَوْمَ یُنَادِیْهِمْ اَیْنَ شُرَكَآءِیْ١ۙ قَالُوْۤا اٰذَنّٰكَ١ۙ مَا مِنَّا مِنْ شَهِیْدٍۚ اِلَيْهِ : اس کی طرف يُرَدُّ : لوٹایا (حوالے کیا) جاتا ہے عِلْمُ السَّاعَةِ ۭ : قیامت کا علم وَمَا تَخْرُجُ : اور نہیں نکالتا مِنْ ثَمَرٰتٍ : کوئی پھل (جمع) مِّنْ اَكْمَامِهَا : اپنے غلافوں (گابھوں) سے وَمَا تَحْمِلُ : اور نہیں حاملہ ہوتی مِنْ اُنْثٰى : کوئی عورت وَلَا تَضَعُ : اور نہ وہ بچہ جنتی ہے اِلَّا بِعِلْمِهٖ ۭ : مگر اس کے علم میں وَيَوْمَ : اور جس دن يُنَادِيْهِمْ : وہ پکارے گا انہیں اَيْنَ : کہاں شُرَكَآءِيْ ۙ : میرے شریک قَالُوْٓا : وہ کہیں گے اٰذَنّٰكَ ۙ : اطلاع دیدی ہم نے تجھے مَا مِنَّا : نہیں ہم سے مِنْ شَهِيْدٍ : کوئی شاہد قیامت کا علم اللہ ہی کی طرف لوٹایا جاتا ہے (1) اور جو جو پھل اپنے شگوفوں میں سے نکلتے ہیں اور جو مادہ حمل سے ہوتی ہے اور جو بچے وہ جنتی ہے سب کا علم اسے ہے (2) اور جس دن اللہ تعالیٰ ان (مشرکوں) کو بلا کر دریافت فرمائے گا میرے شریک کہاں ہیں، وہ جواب دیں گے کہ ہم نے تو تجھے کہہ سنایا کہ ہم میں سے تو کوئی اس کا گواہ نہیں (3)۔
41,48,وَ ضَلَّ عَنْهُمْ مَّا كَانُوْا یَدْعُوْنَ مِنْ قَبْلُ وَ ظَنُّوْا مَا لَهُمْ مِّنْ مَّحِیْصٍ وَضَلَّ عَنْهُمْ : اور کھویا گیا ان سے مَّا : جو كَانُوْا يَدْعُوْنَ : وہ پکارتے تھے مِنْ قَبْلُ : اس سے قبل وَظَنُّوْا : اور انہوں نے سمجھ لیا مَا لَهُمْ : نہیں ان کے لئے مِّنْ مَّحِيْصٍ : کوئی بچاؤ (خلاصی) اور یہ جن (جن) کی پرستش اس سے پہلے کرتے تھے وہ ان کی نگاہ سے گم ہوگئے (1) اور انہوں نے سمجھ لیا ان کے لئے کوئی بچاؤ نہیں (2)
41,49,لَا یَسْئَمُ الْاِنْسَانُ مِنْ دُعَآءِ الْخَیْرِ١٘ وَ اِنْ مَّسَّهُ الشَّرُّ فَیَئُوْسٌ قَنُوْطٌ لَا يَسْئَمُ : نہیں تھکتا الْاِنْسَانُ : انسان مِنْ دُعَآءِ الْخَيْرِ ۡ : بھلائی مانگنے سے وَاِنْ : اور اگر مَّسَّهُ : اسے لگ جائے الشَّرُّ : بُرائی فَيَئُوْسٌ : تو مایوس ہوجاتا ہے قَنُوْطٌ : ناامید بھلائی کے مانگنے سے انسان تھکتا نہیں اور اگر اسے کوئی تکلیف پہنچ جائے تو مایوس اور ناامید ہوجاتا ہے (1)۔
41,50,وَ لَئِنْ اَذَقْنٰهُ رَحْمَةً مِّنَّا مِنْۢ بَعْدِ ضَرَّآءَ مَسَّتْهُ لَیَقُوْلَنَّ هٰذَا لِیْ١ۙ وَ مَاۤ اَظُنُّ السَّاعَةَ قَآئِمَةً١ۙ وَّ لَئِنْ رُّجِعْتُ اِلٰى رَبِّیْۤ اِنَّ لِیْ عِنْدَهٗ لَلْحُسْنٰى١ۚ فَلَنُنَبِّئَنَّ الَّذِیْنَ كَفَرُوْا بِمَا عَمِلُوْا١٘ وَ لَنُذِیْقَنَّهُمْ مِّنْ عَذَابٍ غَلِیْظٍ وَلَئِنْ : اور البتہ اگر اَذَقْنٰهُ : ہم چکھائیں اسے رَحْمَةً : رحمت مِّنَّا : اپنی طرف سے مِنْۢ بَعْدِ : بعد ضَرَّآءَ : کسی تکلیف مَسَّتْهُ : جو اس کو پہنچی لَيَقُوْلَنَّ : تو وہ ضرور کہے گا ھٰذَا لِيْ ۙ : یہ میرے لئے وَمَآ اَظُنُّ : اور میں خیال نہیں رکھتا السَّاعَةَ : قیامت قَآئِمَةً ۙ : قائم ہونے والی وَّلَئِنْ : اور البتہ اگر رُّجِعْتُ : مجھے لوٹایا گیا اِلٰى رَبِّيْٓ : اپنے رب کی طرف اِنَّ لِيْ : بیشک میرے لئے عِنْدَهٗ : اسکے پاس لَلْحُسْنٰى ۚ : البتہ بھلائی فَلَنُنَبِّئَنَّ : پس ہم ضرور آگاہ کردیں گے الَّذِيْنَ : جن لوگوں نے كَفَرُوْا : کفر کیا بِمَا : اس سے جو عَمِلُوْا ۡ : انہوں نے کیا (اعمال) وَلَنُذِيْقَنَّهُمْ : اور البتہ ہم ضرور چکھائیں انہیں مِّنْ : سے عَذَابٍ : ایک عذاب غَلِيْظٍ : سخت اور جو مصیبت اسے پہنچ چکی ہے اس کے بعد اگر ہم اسے کسی رحمت کا مزہ چکھائیں تو وہ کہہ اٹھتا ہے کہ اس کا تو میں حقدار (1) ہی تھا میں تو خیال نہیں کرسکتا کہ قیامت قائم ہوگی اور اگر میں اپنے رب کے پاس واپس گیا تو بھی یقیناً میرے لئے اس کے پاس بھی بہتری (2) ہے، یقیناً ہم ان کفار کو ان کے اعمال سے خبردار کریں گے اور انہیں سخت عذاب کا مزہ چکھائیں گے۔
41,51,وَ اِذَاۤ اَنْعَمْنَا عَلَى الْاِنْسَانِ اَعْرَضَ وَ نَاٰ بِجَانِبِهٖ١ۚ وَ اِذَا مَسَّهُ الشَّرُّ فَذُوْ دُعَآءٍ عَرِیْضٍ وَاِذَآ : اور جب اَنْعَمْنَا : ہم انعام کرتے ہیں عَلَي : پر الْاِنْسَانِ : انسان اَعْرَضَ : وہ منہ موڑلیتا ہے وَنَاٰ : اور بدل لیتا ہے بِجَانِبِهٖ ۚ : اپنا پہلو وَاِذَا : اور جب مَسَّهُ : آلگے اسے الشَّرُّ : بُرائی فَذُوْ دُعَآءٍ : تو دعاؤں والا عَرِيْضٍ : (لمبی) چوڑی اور جب ہم انسان پر اپنا انعام کرتے ہیں تو وہ منہ پھیر لیتا ہے اور کنارہ کش ہوجاتا ہے (1) اور جب اسے مصیبت پڑتی ہے تو بڑی لمبی چوڑی دعائیں کرنے والا بن جاتا ہے۔
41,52,قُلْ اَرَءَیْتُمْ اِنْ كَانَ مِنْ عِنْدِ اللّٰهِ ثُمَّ كَفَرْتُمْ بِهٖ مَنْ اَضَلُّ مِمَّنْ هُوَ فِیْ شِقَاقٍۭ بَعِیْدٍ قُلْ : فرمادیں اَرَءَيْتُمْ : کیا تم نے دیکھا اِنْ كَانَ : اگر ہو مِنْ : سے عِنْدِ اللّٰهِ : اللہ کے پاس ثُمَّ كَفَرْتُمْ : پھر تم نے کفر کیا بِهٖ : اس سے مَنْ اَضَلُّ : کون بڑا گمراہ مِمَّنْ : اس سے جو هُوَ : وہ فِيْ شِقَاقٍۢ : ضد میں بَعِيْدٍ : دور دراز آپ کہہ دیجئے ! کہ بھلا یہ تو بتاؤ کہ اگر یہ قرآن اللہ کی طرف سے آیا ہوا ہو پھر تم نے اسے نہ مانا بس اس سے بڑھ کر بہکا ہوا کون ہوگا (1) جو مخالفت میں (حق سے) دور چلا جائے۔
41,53,سَنُرِیْهِمْ اٰیٰتِنَا فِی الْاٰفَاقِ وَ فِیْۤ اَنْفُسِهِمْ حَتّٰى یَتَبَیَّنَ لَهُمْ اَنَّهُ الْحَقُّ١ؕ اَوَ لَمْ یَكْفِ بِرَبِّكَ اَنَّهٗ عَلٰى كُلِّ شَیْءٍ شَهِیْدٌ سَنُرِيْهِمْ : ہم جلد دکھادیں گے انہیں اٰيٰتِنَا : اپنی آیات فِي الْاٰفَاقِ : اطراف عالم میں وَفِيْٓ اَنْفُسِهِمْ : اور ان کی ذات میں حَتّٰى : یہاں تک کہ يَتَبَيَّنَ : ظاہر ہوجائے لَهُمْ : ان کیلئے اَنَّهُ الْحَقُّ ۭ : کہ وہ حق اَوَ : کیا لَمْ يَكْفِ : کافی نہیں بِرَبِّكَ : آپ کے رب کیلئے اَنَّهٗ : کہ وہ عَلٰي : پر كُلِّ شَيْءٍ : ہر شے شَهِيْدٌ : شاہد عنقریب ہم انہیں اپنی نشانیاں آفاق عالم میں بھی دکھائیں گے اور خود ان کی اپنی ذات میں بھی یہاں تک کہ ان پر کھل جائے کہ حق یہی ہے کیا آپ کے رب کا ہر چیز سے واقف و آگاہ ہونا کافی نہیں (1)
41,54,اَلَاۤ اِنَّهُمْ فِیْ مِرْیَةٍ مِّنْ لِّقَآءِ رَبِّهِمْ١ؕ اَلَاۤ اِنَّهٗ بِكُلِّ شَیْءٍ مُّحِیْطٌ۠    ۧ اَلَآ : خوب یاد رکھو اِنَّهُمْ : بیشک وہ فِيْ مِرْيَةٍ : شک میں مِّنْ لِّقَآءِ : ملاقات سے رَبِّهِمْ ۭ : اپنا رب اَلَآ : یاد رکھو ! اِنَّهٗ : بیشک وہ بِكُلِّ شَيْءٍ : ہر شے کا مُّحِيْطٌ : احاطہ کئے ہوئے یقین جانو ! کہ یہ لوگ اپنے رب کے روبرو جانے سے شک میں ہیں (1) یاد رکھو کہ اللہ تعالیٰ ہر چیز کا احاطہ کئے ہوئے ہے۔ (2)
