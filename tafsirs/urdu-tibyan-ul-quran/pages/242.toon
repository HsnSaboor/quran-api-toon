tafsir[11]{c,v,t}:
  12,53,وَ مَاۤ اُبَرِّئُ نَفْسِیْ١ۚ اِنَّ النَّفْسَ لَاَمَّارَةٌۢ بِالسُّوْٓءِ اِلَّا مَا رَحِمَ رَبِّیْ١ؕ اِنَّ رَبِّیْ غَفُوْرٌ رَّحِیْمٌ وَ : اور مَآ اُبَرِّئُ : پاک، بےقصور نہیں کہتا نَفْسِيْ : اپنا نفس اِنَّ : بیشک النَّفْسَ : نفس لَاَمَّارَةٌ : سکھانے والا بِالسُّوْٓءِ : برائی اِلَّا : مگر مَارَحِمَ : جس پر رحم کیا رَبِّيْ : میرا رب اِنَّ : بیشک رَبِّيْ : میرا رب غَفُوْرٌ : بخشنے والا رَّحِيْمٌ : نہایت مہربان میں اپنے نفس کی پاکیزگی بیان نہیں کرتا (1) بیشک نفس تو برائی پر ابھارنے والا ہی ہے (2) مگر یہ کہ میرا پروردگار ہی اپنا رحم کے (3) یقیناً میرا رب پالنے والا بڑی بخشش کرنے والا اور بہت مہربانی فرمانے والا ہے۔
  12,54,وَ قَالَ الْمَلِكُ ائْتُوْنِیْ بِهٖۤ اَسْتَخْلِصْهُ لِنَفْسِیْ١ۚ فَلَمَّا كَلَّمَهٗ قَالَ اِنَّكَ الْیَوْمَ لَدَیْنَا مَكِیْنٌ اَمِیْنٌ وَقَالَ : اور کہا الْمَلِكُ : بادشاہ ائْتُوْنِيْ : لے آؤ میرے پاس بِهٖٓ : اس کو اَسْتَخْلِصْهُ : اس کو خاص کروں لِنَفْسِيْ : اپنی ذات کے لیے فَلَمَّا : پھر جب كَلَّمَهٗ : اس سے بات کی قَالَ : اس نے کہا اِنَّكَ : بیشک تم الْيَوْمَ : آج لَدَيْنَا : ہمارے پاس مَكِيْنٌ : باوقار اَمِيْنٌ : امین بادشاہ نے کہا کہ اسے میرے پاس لاؤ کہ میں اسے اپنے خاص کاموں کے لئے مقرر کرلوں (1) پھر جب اس سے بات چیت کی تو کہنے لگا کہ آپ ہمارے ہاں ذی عزت اور امانت دار ہیں (2)
  12,55,قَالَ اجْعَلْنِیْ عَلٰى خَزَآئِنِ الْاَرْضِ١ۚ اِنِّیْ حَفِیْظٌ عَلِیْمٌ قَالَ : اس نے کہا اجْعَلْنِيْ : مجھے کردے عَلٰي : پر خَزَآئِنِ : خزانے الْاَرْضِ : زمین (ملک) اِنِّىْ : بشیک میں حَفِيْظٌ : حفاظت کرنیوالا عَلِيْمٌ : علم والا (یوسف) نے کہا آپ مجھے ملک کے خزانوں پر معمور کر دیجئے (1) میں حفاظت کرنے والا اور باخبر ہوں (2)
  12,56,وَ كَذٰلِكَ مَكَّنَّا لِیُوْسُفَ فِی الْاَرْضِ١ۚ یَتَبَوَّاُ مِنْهَا حَیْثُ یَشَآءُ١ؕ نُصِیْبُ بِرَحْمَتِنَا مَنْ نَّشَآءُ وَ لَا نُضِیْعُ اَجْرَ الْمُحْسِنِیْنَ وَكَذٰلِكَ : اور اسی طرح مَكَّنَّا : ہم نے قدرت دی لِيُوْسُفَ : یوسف کو فِي الْاَرْضِ : زمین میں (ملک پر) يَتَبَوَّاُ : وہ رہتے مِنْهَا : اس سے (میں) حَيْثُ : جہاں يَشَآءُ : وہ چاہتے نُصِيْبُ : ہم پہنچا دیتے ہیں بِرَحْمَتِنَا : اپنی رحمت سے مَنْ نَّشَآءُ : جس کو ہم چاہتے ہیں وَلَا نُضِيْعُ : اور ہم ضائع نہیں کرتے اَجْرَ : بدلہ الْمُحْسِنِيْنَ : نیکی کرنے والے اسی طرح ہم نے یوسف ؑ کو ملک کا قبضہ دے دیا کہ وہ جہاں کہیں چاہے رہے سہے (1) ہم جسے چاہیں اپنی رحمت پہنچا دیتے ہیں۔ ہم نیکوکاروں کا ثواب ضائع نہیں کرتے (2)۔
  12,57,وَ لَاَجْرُ الْاٰخِرَةِ خَیْرٌ لِّلَّذِیْنَ اٰمَنُوْا وَ كَانُوْا یَتَّقُوْنَ۠    ۧ وَلَاَجْرُ الْاٰخِرَةِ : اور آخرت کا بدلہ البتہ خَيْرٌ : بہتر لِّلَّذِيْنَ : ان کے لیے جو اٰمَنُوْا : ایمان لائے وَكَانُوْا : اور تھے وہ يَتَّقُوْنَ : پرہیزگاری کرتے یقیناً ایمان داروں اور پرہیزگاروں کا اخروی اجر بہت ہی بہتر ہے۔
  12,58,وَ جَآءَ اِخْوَةُ یُوْسُفَ فَدَخَلُوْا عَلَیْهِ فَعَرَفَهُمْ وَ هُمْ لَهٗ مُنْكِرُوْنَ وَجَآءَ : اور آئے اِخْوَةُ : بھائی يُوْسُفَ : یوسف فَدَخَلُوْا : پس وہ داخل ہوئے عَلَيْهِ : اس کے پاس فَعَرَفَهُمْ : تو اس نے انہیں پہچان لیا وَهُمْ : اور وہ لَهٗ : اس کو مُنْكِرُوْنَ : وہ نہ پہچانے یوسف کے بھائی آئے اور یوسف کے پاس گئے تو اس نے انھیں پہچان لیا اور انہوں نے اسے نہ پہچانا (1)
  12,59,وَ لَمَّا جَهَّزَهُمْ بِجَهَازِهِمْ قَالَ ائْتُوْنِیْ بِاَخٍ لَّكُمْ مِّنْ اَبِیْكُمْ١ۚ اَلَا تَرَوْنَ اَنِّیْۤ اُوْفِی الْكَیْلَ وَ اَنَا خَیْرُ الْمُنْزِلِیْنَ وَلَمَّا : اور جب جَهَّزَهُمْ : جب انہیں تیار کردیا بِجَهَازِهِمْ : ان کا سامان قَالَ : کہا اس نے ائْتُوْنِيْ : لاؤ میرے پاس بِاَخٍ : بھائی لَّكُمْ : تمہارا (اپنا) مِّنْ اَبِيْكُمْ : تمہارے باپ سے اَلَا تَرَوْنَ : کیا تم نہیں دیکھتے اَنِّىْٓ : کہ میں اُوْفِي : پورا کرتا ہوں الْكَيْلَ : پیمانہ وَاَنَا : اور میں خَيْرُ : بہترین الْمُنْزِلِيْنَ : اتارنے والا (مہمان نواز) جب انھیں ان کا اسباب مہیا کردیا تو کہا کہ تم میرے پاس اپنے اس بھائی کو بھی لانا جو تمہارے باپ سے ہے، کیا تم نے نہیں دیکھا کہ میں پورا ناپ کردیتا ہوں اور میں ہوں بھی بہترین میزبانی کرنے والوں میں (1)
  12,60,فَاِنْ لَّمْ تَاْتُوْنِیْ بِهٖ فَلَا كَیْلَ لَكُمْ عِنْدِیْ وَ لَا تَقْرَبُوْنِ فَاِنْ : پھر اگر لَّمْ تَاْتُوْنِيْ : میرے پاس نہ لائے بِهٖ : اس کو فَلَا كَيْلَ : تو کوئی ناپ نہیں لَكُمْ : تمہارے لیے عِنْدِيْ : میرے پاس وَلَا تَقْرَبُوْنِ : اور نہ آنا میرے پاس پس اگر تم اسے لے کر نہ آئے تو میری طرف سے تمہیں کوئی ناپ بھی نہ ملے گا بلکہ تم میرے قریب بھی نہ پھٹکنا (1)
  12,61,قَالُوْا سَنُرَاوِدُ عَنْهُ اَبَاهُ وَ اِنَّا لَفٰعِلُوْنَ قَالُوْا : وہ بولے سَنُرَاوِدُ : ہم خواہش کریں گے عَنْهُ : اس کے متعلق اَبَاهُ : اس کا باپ وَاِنَّا : اور ہم لَفٰعِلُوْنَ : ضرور کرنیوالے ہیں (کرنا ہے) انہوں نے کہا ہم اس کے باپ کو اس کی بابت پھسلائیں گے اور پوری کوشش کریں گے (1)۔
  12,62,وَ قَالَ لِفِتْیٰنِهِ اجْعَلُوْا بِضَاعَتَهُمْ فِیْ رِحَالِهِمْ لَعَلَّهُمْ یَعْرِفُوْنَهَاۤ اِذَا انْقَلَبُوْۤا اِلٰۤى اَهْلِهِمْ لَعَلَّهُمْ یَرْجِعُوْنَ وَقَالَ : اور اس نے کہا لِفِتْيٰنِهِ : اپنے خدمتگاروں کو اجْعَلُوْا : اور تم رکھدو بِضَاعَتَهُمْ : ان کی پونجی فِيْ رِحَالِهِمْ : ان کے بوروں میں لَعَلَّهُمْ : شاید وہ يَعْرِفُوْنَهَآ : اس کو معلوم کرلیں اِذَا انْقَلَبُوْٓا : جب وہ لوٹیں اِلٰٓى : طرف اَهْلِهِمْ : اپنے لوگ لَعَلَّهُمْ : شاید وہ يَرْجِعُوْنَ : پھر آجائیں اپنے خدمت گاروں سے کہا کہ (1) ان کی پونجی انہی کی بوریوں میں رکھ دو (2) کہ جب لوٹ کر اپنے اہل و عیال میں جائیں اور پونجیوں کو پہچان لیں تو بہت ممکن ہے کہ پھر لوٹ کر آئیں۔
  12,63,فَلَمَّا رَجَعُوْۤا اِلٰۤى اَبِیْهِمْ قَالُوْا یٰۤاَبَانَا مُنِعَ مِنَّا الْكَیْلُ فَاَرْسِلْ مَعَنَاۤ اَخَانَا نَكْتَلْ وَ اِنَّا لَهٗ لَحٰفِظُوْنَ فَلَمَّا : پس جب رَجَعُوْٓا : وہ لوٹے اِلٰٓى : طرف اَبِيْهِمْ : اپنا باپ قَالُوْا : وہ بولے يٰٓاَبَانَا : اے ہمارے ابا مُنِعَ : روک دیا گیا مِنَّا : ہم سے الْكَيْلُ : ناپ فَاَرْسِلْ : پس بھیجدیں مَعَنَآ : ہمارے ساتھ اَخَانَا : ہمارے بھائی کو نَكْتَلْ : ناپ (غلہ) لائیں وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَحٰفِظُوْنَ : نگہبان ہیں جب یہ لوگ لوٹ کر اپنے والد کے پاس گئے تو کہنے لگے کہ ہم سے تو غلہ کا ناپ روک لیا گیا (1) اب آپ ہمارے ساتھ بھائی کو بھیجئے کہ ہم پیمانہ بھر کر لائیں ہم اس کی نگہبانی کے ذمہ دار ہیں۔
