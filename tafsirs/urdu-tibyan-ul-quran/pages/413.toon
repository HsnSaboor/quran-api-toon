tafsir[9]{c,v,t}:
  31,20,اَلَمْ تَرَوْا اَنَّ اللّٰهَ سَخَّرَ لَكُمْ مَّا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ وَ اَسْبَغَ عَلَیْكُمْ نِعَمَهٗ ظَاهِرَةً وَّ بَاطِنَةً١ؕ وَ مِنَ النَّاسِ مَنْ یُّجَادِلُ فِی اللّٰهِ بِغَیْرِ عِلْمٍ وَّ لَا هُدًى وَّ لَا كِتٰبٍ مُّنِیْرٍ اَلَمْ تَرَوْا : کیا تم نے نہیں دیکھا اَنَّ اللّٰهَ : کہ اللہ سَخَّرَ : مسخر کیا لَكُمْ : تمہارے لیے مَّا : جو کچھ فِي السَّمٰوٰتِ : آسمانوں میں وَمَا : اور جو کچھ فِي الْاَرْضِ : زمین میں وَاَسْبَغَ : اور بھرپور دیں عَلَيْكُمْ : تم پر (تمہیں) نِعَمَهٗ : اپنی نعمتیں ظَاهِرَةً : ظاہر وَّبَاطِنَةً ۭ : اور پوشیدہ وَمِنَ : اور بعض النَّاسِ : لوگ مَنْ : جو يُّجَادِلُ : جھگڑتا ہے فِي اللّٰهِ : اللہ (کے بارہ) میں بِغَيْرِ : بغیر عِلْمٍ : علم وَّلَا هُدًى : اور بغیر ہدایت وَّلَا كِتٰبٍ مُّنِيْرٍ : اور بغیر کتاب روشن کیا تم نہیں دیکھتے کہ اللہ تعالیٰ نے زمین اور آسمان کی ہر چیز کو ہمارے کام میں لگا رکھا ہے 1 اور تمہیں اپنی ظاہری و باطنی نعمتیں بھرپور دے رکھی ہیں 2 بعض لوگ اللہ کے بارے میں بغیر علم کے بغیر ہدایت کے اور بغیر روشن کتاب کے جھگڑا کرتے ہیں 3۔
  31,21,وَ اِذَا قِیْلَ لَهُمُ اتَّبِعُوْا مَاۤ اَنْزَلَ اللّٰهُ قَالُوْا بَلْ نَتَّبِعُ مَا وَجَدْنَا عَلَیْهِ اٰبَآءَنَا١ؕ اَوَ لَوْ كَانَ الشَّیْطٰنُ یَدْعُوْهُمْ اِلٰى عَذَابِ السَّعِیْرِ وَاِذَا : اور جب قِيْلَ : کہا جائے لَهُمُ : ان سے اتَّبِعُوْا : تم پیروی کرو مَآ اَنْزَلَ : جو نازل کیا اللّٰهُ : اللہ قَالُوْا : وہ کہتے ہیں بَلْ نَتَّبِعُ : بلکہ ہم پیروی کریں گے مَا وَجَدْنَا : جو ہم نے پایا عَلَيْهِ : اس پر اٰبَآءَنَا ۭ : اپنے باپ دادا اَوَلَوْ : کیا اگر كَانَ : ہو الشَّيْطٰنُ : شیطان يَدْعُوْهُمْ : ان کو بلاتا اِلٰى : طرف عَذَابِ : عذاب السَّعِيْرِ : دوزخ اور جب ان سے کہا جاتا ہے کہ اللہ کی اتاری ہوئی وحی کی تابعداری کرو تو کہتے ہیں کہ ہم نے تو جس طریق 1 پر اپنے باپ دادوں کو پایا ہے اسی کی تابعداری کریں گے، اگرچہ شیطان ان کے بڑوں کو دوزخ کے عذاب کی طرف بلاتا ہو۔
  31,22,وَ مَنْ یُّسْلِمْ وَجْهَهٗۤ اِلَى اللّٰهِ وَ هُوَ مُحْسِنٌ فَقَدِ اسْتَمْسَكَ بِالْعُرْوَةِ الْوُثْقٰى١ؕ وَ اِلَى اللّٰهِ عَاقِبَةُ الْاُمُوْرِ وَمَنْ : اور جو يُّسْلِمْ : جھکا دے وَجْهَهٗٓ : اپنا چہرہ اِلَى اللّٰهِ : اللہ کی طرف وَهُوَ : اور وہ مُحْسِنٌ : نیکو کار فَقَدِ اسْتَمْسَكَ : تو بیشک اس نے تھاما بِالْعُرْوَةِ الْوُثْقٰى ۭ : حلقہ مضبوط وَاِلَى اللّٰهِ : اور اللہ کی طرف عَاقِبَةُ : انتہا الْاُمُوْرِ : تمام کام (جمع) اور جو (شخص) اپنے آپ کو اللہ کے تابع کر دے 1 اور ہو بھی نیکوکار 2 یقیناً اس نے مضبوط کڑا تھام لیا 3 تمام کاموں کا انجام اللہ کی طرف ہے۔
  31,23,وَ مَنْ كَفَرَ فَلَا یَحْزُنْكَ كُفْرُهٗ١ؕ اِلَیْنَا مَرْجِعُهُمْ فَنُنَبِّئُهُمْ بِمَا عَمِلُوْا١ؕ اِنَّ اللّٰهَ عَلِیْمٌۢ بِذَاتِ الصُّدُوْرِ وَمَنْ كَفَرَ : اور جو کفر کرے فَلَا يَحْزُنْكَ : تو آپ غمگین نہ کردے كُفْرُهٗ ۭ : اس کا کفر اِلَيْنَا : ہماری طرف مَرْجِعُهُمْ : ان کا لوٹنا فَنُنَبِّئُهُمْ بِمَا : پھر ہم انہیں ضرور جتلائیں گے وہ جو عَمِلُوْا ۭ : وہ کرتے تھے اِنَّ اللّٰهَ : بیشک اللہ عَلِيْمٌۢ : جاننے والا بِذَاتِ الصُّدُوْرِ : سینوں (دلوں) کے بھید کافروں کے کفر سے آپ رنجیدہ نہ ہوں 1 آخر ان سب کا لوٹنا تو ہماری جانب ہی ہے پھر ہم ان کو بتائیں گے جو انہوں نے کیا، بیشک اللہ سینوں 2 کے بھید 3 تک سے واقف ہے۔
  31,24,نُمَتِّعُهُمْ قَلِیْلًا ثُمَّ نَضْطَرُّهُمْ اِلٰى عَذَابٍ غَلِیْظٍ نُمَتِّعُهُمْ : ہم انہیں فائدہ دیں گے قَلِيْلًا : تھوڑا ثُمَّ نَضْطَرُّهُمْ : پھر ہم انہیں کھینچ لائیں گے اِلٰى : طرف عَذَابٍ : عذاب غَلِيْظٍ : سخت ہم انھیں گو کچھ یونہی فائدہ دے دیں لیکن (بالآخر) ہم انھیں نہایت بیچارگی کی حالت میں سخت عذاب کی طرف ہنکالے جائیں گے 1
  31,25,وَ لَئِنْ سَاَلْتَهُمْ مَّنْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ لَیَقُوْلُنَّ اللّٰهُ١ؕ قُلِ الْحَمْدُ لِلّٰهِ١ؕ بَلْ اَكْثَرُهُمْ لَا یَعْلَمُوْنَ وَلَئِنْ : اور اگر سَاَلْتَهُمْ : تم ان سے پوچھو مَّنْ خَلَقَ : کس نے پیدا کیا السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین لَيَقُوْلُنَّ : تو وہ یقینا کہیں گے اللّٰهُ ۭ : اللہ قُلِ : فرمادیں الْحَمْدُ لِلّٰهِ ۭ : تمام تعریفیں اللہ کے لیے بَلْ اَكْثَرُهُمْ : بلکہ ان کے اکثر لَا يَعْلَمُوْنَ : جانتے نہیں اگر آپ ان سے دریافت کریں کہ آسمان و زمین کا خالق کون ہے ؟ تو ضرور جواب دیں گے کہ اللہ 1 تو کہہ دیجئے کہ سب تعریفوں کے لائق اللہ ہی ہے 2 لیکن ان میں اکثر بےعلم ہیں۔
  31,26,لِلّٰهِ مَا فِی السَّمٰوٰتِ وَ الْاَرْضِ١ؕ اِنَّ اللّٰهَ هُوَ الْغَنِیُّ الْحَمِیْدُ لِلّٰهِ : اللہ کے لیے مَا : جو کچھ فِي السَّمٰوٰتِ : آسمانوں میں وَالْاَرْضِ ۭ : اور زمین اِنَّ اللّٰهَ : بیشک اللہ هُوَ : وہ الْغَنِيُّ : بےنیاز الْحَمِيْدُ : تعریفوں کے ساتھ آسمانوں میں اور زمین میں جو کچھ ہے وہ سب اللہ ہی کا ہے 1 یقیناً اللہ تعالیٰ بہت بڑا بےنیاز 2 اور سزاوار حمد ثنا ہے 3۔
  31,27,وَ لَوْ اَنَّ مَا فِی الْاَرْضِ مِنْ شَجَرَةٍ اَقْلَامٌ وَّ الْبَحْرُ یَمُدُّهٗ مِنْۢ بَعْدِهٖ سَبْعَةُ اَبْحُرٍ مَّا نَفِدَتْ كَلِمٰتُ اللّٰهِ١ؕ اِنَّ اللّٰهَ عَزِیْزٌ حَكِیْمٌ وَلَوْ : اور اگر اَنَّ : یہ ہو کہ مَا : جو فِي الْاَرْضِ : زمین میں مِنْ : سے۔ کوئی شَجَرَةٍ : درخت اَقْلَامٌ : قلمیں وَّالْبَحْرُ : اور سمندر يَمُدُّهٗ : اس کی سیاہی مِنْۢ بَعْدِهٖ : اس کے بعد سَبْعَةُ : سات اَبْحُرٍ : سمندر (جمع) مَّا نَفِدَتْ : تو بھی ختم نہ ہوں كَلِمٰتُ اللّٰهِ ۭ : اللہ کی باتیں اِنَّ اللّٰهَ : بیشک اللہ عَزِيْزٌ : غالب حَكِيْمٌ : حکمت والا روئے زمین کے (تمام) درختوں کے اگر قلمیں ہوجائیں اور تمام سمندروں کی سیاہی ہو اور ان کے بعد سات سمندر اور ہوں تاہم اللہ کے کلمات ختم نہیں ہوسکتے 1 بیشک اللہ تعالیٰ غالب اور باحکمت ہے۔
  31,28,مَا خَلْقُكُمْ وَ لَا بَعْثُكُمْ اِلَّا كَنَفْسٍ وَّاحِدَةٍ١ؕ اِنَّ اللّٰهَ سَمِیْعٌۢ بَصِیْرٌ مَا خَلْقُكُمْ : نہیں تم سب کا پیدا کرنا وَلَا بَعْثُكُمْ : اور نہیں تمہارا جی اٹھنا اِلَّا : مگر كَنَفْسٍ وَّاحِدَةٍ ۭ : جیسے ایک شخص اِنَّ اللّٰهَ : بیشک اللہ سَمِيْعٌۢ : سننے والا بَصِيْرٌ : دیکھنے والا تم سب کی پیدائش اور مرنے کے بعد زندہ کرنا ایسا ہی ہے جیسے ایک جی کا، 1 بیشک اللہ تعالیٰ سننے والا دیکھنے والا ہے۔
