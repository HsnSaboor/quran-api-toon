tafsir[7]{c,v,t}:
  63,5,وَ اِذَا قِیْلَ لَهُمْ تَعَالَوْا یَسْتَغْفِرْ لَكُمْ رَسُوْلُ اللّٰهِ لَوَّوْا رُءُوْسَهُمْ وَ رَاَیْتَهُمْ یَصُدُّوْنَ وَ هُمْ مُّسْتَكْبِرُوْنَ وَ : اور اِذَا قِيْلَ لَهُمْ : جب ان سے کہا جاتا ہے تَعَالَوْا : آؤ يَسْتَغْفِرْ لَكُمْ : بخشش مانگتے ہیں تمہارے لیے رَسُوْلُ اللّٰهِ : اللہ کے رسول لَوَّوْا : موڑتے ہیں رُءُوْسَهُمْ : اپنے سروں کو وَرَاَيْتَهُمْ : اور تم دیکھتے ہو ان کو يَصُدُّوْنَ : وہ باز رہتے ہیں وَهُمْ مُّسْتَكْبِرُوْنَ : اور وہ تکبر کرنے والے ہیں اور جب ان سے کہا جاتا ہے کہ آؤ تمہارے لئے اللہ کے رسول استغفار کریں تو اپنے سر مٹکاتے ہیں (1) اور آپ دیکھیں گے کہ وہ تکبر کرتے ہوئے رک جاتے ہیں (2)۔
  63,6,سَوَآءٌ عَلَیْهِمْ اَسْتَغْفَرْتَ لَهُمْ اَمْ لَمْ تَسْتَغْفِرْ لَهُمْ١ؕ لَنْ یَّغْفِرَ اللّٰهُ لَهُمْ١ؕ اِنَّ اللّٰهَ لَا یَهْدِی الْقَوْمَ الْفٰسِقِیْنَ سَوَآءٌ عَلَيْهِمْ : برابر ہے ان پر اَسْتَغْفَرْتَ لَهُمْ : خواہ تم بخشش مانگو ان کے لیے اَمْ لَمْ تَسْتَغْفِرْ : یا نہ تم بخشش مانگو لَهُمْ : ان کے لیے لَنْ : ہرگز نہ يَّغْفِرَ اللّٰهُ لَهُمْ : معاف کرے گا اللہ ان کو اِنَّ اللّٰهَ : کیونکہ اللہ تعالیٰ لَا يَهْدِي : نہیں ہدایت دیتا الْقَوْمَ الْفٰسِقِيْنَ : فاسق قوم کو ان کے حق میں آپکا استغفار کرنا اور نہ کرنا دونوں برابر ہیں (1) اللہ تعالیٰ انہیں ہرگز نہ بخشے گا (2) بیشک اللہ تعالیٰ (ایسے) نافرمان لوگوں کو ہدایت نہیں دیتا،
  63,7,هُمُ الَّذِیْنَ یَقُوْلُوْنَ لَا تُنْفِقُوْا عَلٰى مَنْ عِنْدَ رَسُوْلِ اللّٰهِ حَتّٰى یَنْفَضُّوْا١ؕ وَ لِلّٰهِ خَزَآئِنُ السَّمٰوٰتِ وَ الْاَرْضِ وَ لٰكِنَّ الْمُنٰفِقِیْنَ لَا یَفْقَهُوْنَ هُمُ الَّذِيْنَ : وہ لوگ ہیں يَقُوْلُوْنَ : جو کہتے ہیں لَا تُنْفِقُوْا : نہ تم خرچ کرو عَلٰي : اوپر مَنْ عِنْدَ : اس کے جو پاس ہیں رَسُوْلِ اللّٰهِ : اللہ کے رسول کے حَتّٰى يَنْفَضُّوْا : یہاں تک کہ وہ بھاگ جائیں وَلِلّٰهِ : اور اللہ کے لیے ہیں خَزَآئِنُ : خزانے السَّمٰوٰتِ : آسمانوں کے وَالْاَرْضِ : اور زمین کے وَلٰكِنَّ الْمُنٰفِقِيْنَ : لیکن منافق لوگ لَا : نہیں يَفْقَهُوْنَ : سمجھتے یہی وہ ہیں جو کہتے ہیں کہ جو لوگ رسول اللہ کے پاس ہیں ان پر کچھ خرچ نہ کرو یہاں تک کہ وہ ادھر ادھر ہوجائیں اور آسمان و زمین کے خزانے اللہ تعالیٰ کی ملکیت ہیں (1) لیکن یہ منافق بےسمجھ ہیں (2)۔
  63,8,یَقُوْلُوْنَ لَئِنْ رَّجَعْنَاۤ اِلَى الْمَدِیْنَةِ لَیُخْرِجَنَّ الْاَعَزُّ مِنْهَا الْاَذَلَّ١ؕ وَ لِلّٰهِ الْعِزَّةُ وَ لِرَسُوْلِهٖ وَ لِلْمُؤْمِنِیْنَ وَ لٰكِنَّ الْمُنٰفِقِیْنَ لَا یَعْلَمُوْنَ۠    ۧ يَقُوْلُوْنَ : وہ کہتے ہیں لَئِنْ رَّجَعْنَآ : البتہ اگر لوٹے ہم اِلَى الْمَدِيْنَةِ : مدینہ کی طرف لَيُخْرِجَنَّ : البتہ ضرور نکالے گا الْاَعَزُّ مِنْهَا : زیادہ عزت والا اس سے الْاَذَلَّ : زیادہ ذلیل کو وَلِلّٰهِ الْعِزَّةُ : اور اللہ کے لیے ہے عزت وَلِرَسُوْلِهٖ : اور اس کے رسول کے لیے وَلِلْمُؤْمِنِيْنَ : اور مومنوں کے لیے وَلٰكِنَّ الْمُنٰفِقِيْنَ : لیکن منافق لوگ لَا يَعْلَمُوْنَ : علم نہیں رکھتے یہ کہتے ہیں کہ اگر ہم اب لوٹ کر مدینے جائیں گے تو عزت والا وہاں سے ذلت والے کو نکال دے گا (1) سنو ! عزت تو صرف اللہ تعالیٰ کے لئے اور اس کے رسول کے لئے اور ایمانداروں کے لئے ہے (2) لیکن یہ منافق جانتے نہیں۔ (3)
  63,9,یٰۤاَیُّهَا الَّذِیْنَ اٰمَنُوْا لَا تُلْهِكُمْ اَمْوَالُكُمْ وَ لَاۤ اَوْلَادُكُمْ عَنْ ذِكْرِ اللّٰهِ١ۚ وَ مَنْ یَّفْعَلْ ذٰلِكَ فَاُولٰٓئِكَ هُمُ الْخٰسِرُوْنَ يٰٓاَيُّهَا : اے الَّذِيْنَ اٰمَنُوْا : لوگو ! جو ایمان لائے ہو لَا تُلْهِكُمْ : نہ غافل کریں تم کو اَمْوَالُكُمْ : مال تمہارے وَلَآ اَوْلَادُكُمْ : اور نہ اولاد تمہاری عَنْ ذِكْرِ اللّٰهِ : اللہ کے ذکر سے وَمَنْ يَّفْعَلْ ذٰلِكَ : اور جو کوئی ایسا کرے گا فَاُولٰٓئِكَ : تو یہی لوگ هُمُ الْخٰسِرُوْنَ : وہ ہیں جو خسارہ پانے والے ہیں اے مسلمانو ! تمہارے مال اور تمہاری اولاد تمہیں اللہ کے ذکر سے غافل نہ کردیں (1) اور جو ایسا کریں وہ بڑے ہی زیاں کار لوگ ہیں۔
  63,10,وَ اَنْفِقُوْا مِنْ مَّا رَزَقْنٰكُمْ مِّنْ قَبْلِ اَنْ یَّاْتِیَ اَحَدَكُمُ الْمَوْتُ فَیَقُوْلَ رَبِّ لَوْ لَاۤ اَخَّرْتَنِیْۤ اِلٰۤى اَجَلٍ قَرِیْبٍ١ۙ فَاَصَّدَّقَ وَ اَكُنْ مِّنَ الصّٰلِحِیْنَ وَاَنْفِقُوْا : اور خرچ کرو مِنْ مَّا رَزَقْنٰكُمْ : اس میں سے جو رزق دیا ہم نے تم کو مِّنْ : سے قَبْلِ : اس (سے) پہلے اَنْ يَّاْتِيَ : کہ آجائے اَحَدَكُمُ الْمَوْتُ : تم میں سے کسی ایک کو موت فَيَقُوْلَ رَبِّ : تو کہے، اے میرے رب لَوْلَآ : کیوں نہ اَخَّرْتَنِيْٓ : تو نے ڈھیل دی مجھ کو اِلٰٓى اَجَلٍ : ایک وقت تک قَرِيْبٍ : قریب کے فَاَصَّدَّقَ : تو میں صدقہ کرتا۔ خیرات دیتا وَاَكُنْ مِّنَ : اور میں ہوجاتا ، سے الصّٰلِحِيْنَ : نیکیوں میں (سے) اور جو کچھ ہم نے تمہیں دے رکھا ہے اس میں سے (ہماری راہ میں) اس سے پہلے خرچ کرو (1) کہ تم میں سے کسی کو موت آجائے تو کہنے لگے اے میرے پروردگار مجھے تو تھوڑی دیر کی مہلت کیوں نہیں دیتا ؟ کہ میں صدقہ کروں اور نیک لوگوں میں ہوجاؤں۔
  63,11,وَ لَنْ یُّؤَخِّرَ اللّٰهُ نَفْسًا اِذَا جَآءَ اَجَلُهَا١ؕ وَ اللّٰهُ خَبِیْرٌۢ بِمَا تَعْمَلُوْنَ۠    ۧ وَلَنْ يُّؤَخِّرَ اللّٰهُ : اور ہرگز نہ مہلت دے گا اللہ۔ ڈھیل دے گا اللہ نَفْسًا : کسی نفس کو اِذَا جَآءَ : جب آجائے اَجَلُهَا : اس کی موت کا وقت وَاللّٰهُ : اور اللہ خَبِيْرٌۢ : خبر رکھنے والا ہے بِمَا تَعْمَلُوْنَ : ساتھ اس کے جو تم عمل کرتے ہو اور جب کسی کا مقررہ وقت آجاتا ہے پھر اسے اللہ تعالیٰ ہرگز مہلت نہیں دیتا اور جو کچھ تم کرتے ہو اس سے اللہ تعالیٰ بخوبی باخبر ہے۔
