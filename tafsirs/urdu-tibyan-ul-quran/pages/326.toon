tafsir[13]{c,v,t}:
  21,45,قُلْ اِنَّمَاۤ اُنْذِرُكُمْ بِالْوَحْیِ١ۖ٘ وَ لَا یَسْمَعُ الصُّمُّ الدُّعَآءَ اِذَا مَا یُنْذَرُوْنَ قُلْ : فرما دیں اِنَّمَآ : اس کے سوا نہیں کہ اُنْذِرُكُمْ : میں تمہیں ڈراتا ہوں بِالْوَحْيِ : وحی سے وَ : اور لَا يَسْمَعُ : نہیں سنتے ہیں الصُّمُّ : بہرے الدُّعَآءَ : پکار اِذَا : جب مَا : بھی يُنْذَرُوْنَ : انہیں ڈرایا جائے کہہ دیجئے ! میں تمہیں اللہ کی وحی کے ذریعہ آگاہ کر رہا ہوں مگر بہرے لوگ بات نہیں سنتے جبکہ انھیں آگاہ کیا جائے (1)۔
  21,46,وَ لَئِنْ مَّسَّتْهُمْ نَفْحَةٌ مِّنْ عَذَابِ رَبِّكَ لَیَقُوْلُنَّ یٰوَیْلَنَاۤ اِنَّا كُنَّا ظٰلِمِیْنَ وَلَئِنْ : اور اگر مَّسَّتْهُمْ : انہیں چھوئے نَفْحَةٌ : ایک لپٹ مِّنْ عَذَابِ : عذاب سے رَبِّكَ : تیرا رب لَيَقُوْلُنَّ : وہ ضرور کہیں گے يٰوَيْلَنَآ : ہائے ہماری شامت اِنَّا كُنَّا : بیشک ہم تھے ظٰلِمِيْنَ : ظالم (جمع) اگر انھیں تیرے رب کے کسی عذاب کا جھونکا بھی لگ جائے تو پکار اٹھیں کہ ہائے ہماری بدبختی یقیناً ہم گناہ گار تھے (1)۔
  21,47,وَ نَضَعُ الْمَوَازِیْنَ الْقِسْطَ لِیَوْمِ الْقِیٰمَةِ فَلَا تُظْلَمُ نَفْسٌ شَیْئًا١ؕ وَ اِنْ كَانَ مِثْقَالَ حَبَّةٍ مِّنْ خَرْدَلٍ اَتَیْنَا بِهَا١ؕ وَ كَفٰى بِنَا حٰسِبِیْنَ وَنَضَعُ : اور ہم رکھیں گے (قائم کرینگے) الْمَوَازِيْنَ : ترازو۔ میزان الْقِسْطَ : انصاف لِيَوْمِ : دن الْقِيٰمَةِ : قیامت فَلَا تُظْلَمُ : تو نہ ظلم کیا جائے گا نَفْسٌ : کسی شخص پر شَيْئًا : کچھ بھی وَ اِنْ : اور اگر كَانَ : ہوگا مِثْقَالَ : وزان۔ برابر حَبَّةٍ : ایک دانہ مِّنْ خَرْدَلٍ : رائی سے۔ کا اَتَيْنَا بِهَا : ہم اسے لے آئیں گے وَكَفٰى : اور کافی بِنَا : ہم حٰسِبِيْنَ : حساب لینے والے قیامت کے دن ہم درمیان میں لا رکھیں گے ٹھیک ٹھیک تولنے والی ترازو کو۔ پھر کسی پر کچھ ظلم بھی نہ کیا جائے گا۔ اور اگر ایک رائی کے دانے کے برابر بھی عمل ہوگا ہم اسے لا حاضر کریں گے، اور ہم کافی ہیں حساب کرنے والے (1)۔
  21,48,وَ لَقَدْ اٰتَیْنَا مُوْسٰى وَ هٰرُوْنَ الْفُرْقَانَ وَ ضِیَآءً وَّ ذِكْرًا لِّلْمُتَّقِیْنَۙ وَلَقَدْ اٰتَيْنَا : اور البتہ ہم نے عطا کی مُوْسٰى : موسیٰ وَهٰرُوْنَ : اور ہارون الْفُرْقَانَ : فرق کرنیوالی (کتاب) وَضِيَآءً : اور روشنی وَّذِكْرًا : اور نصیحت لِّلْمُتَّقِيْنَ : پرہیزگاروں کے لیے یہ بالکل سچ ہے کہ ہم نے موسیٰ و ہارون کو فیصلے کرنے والی نورانی اور پرہیزگاروں کے لئے وعظ و نصیحت والی کتاب عطا فرمائی ہے (1)
  21,49,الَّذِیْنَ یَخْشَوْنَ رَبَّهُمْ بِالْغَیْبِ وَ هُمْ مِّنَ السَّاعَةِ مُشْفِقُوْنَ الَّذِيْنَ : جو لوگ يَخْشَوْنَ : وہ ڈرتے ہیں رَبَّهُمْ : اپنا رب بِالْغَيْبِ : بغیر دیکھے وَهُمْ : اور وہ مِّنَ : سے السَّاعَةِ : قیامت مُشْفِقُوْنَ : خوف کھاتے ہیں وہ لوگ جو اپنے رب سے بن دیکھے خوف کھاتے ہیں اور قیامت (کے تصور) سے کانپتے رہتے ہیں (1)۔
  21,50,وَ هٰذَا ذِكْرٌ مُّبٰرَكٌ اَنْزَلْنٰهُ١ؕ اَفَاَنْتُمْ لَهٗ مُنْكِرُوْنَ۠    ۧ وَھٰذَا : اور یہ ذِكْرٌ : نصیحت مُّبٰرَكٌ : بابرکت اَنْزَلْنٰهُ : ہم نے اسے نازل کیا اَفَاَنْتُمْ : تو کیا تم لَهٗ : اس کے مُنْكِرُوْنَ : منکر (جمع) اور یہ نصیحت اور برکت والا قرآن بھی ہم نے نازل فرمایا ہے کیا پھر بھی تم اس کے منکر ہو (1)۔
  21,51,وَ لَقَدْ اٰتَیْنَاۤ اِبْرٰهِیْمَ رُشْدَهٗ مِنْ قَبْلُ وَ كُنَّا بِهٖ عٰلِمِیْنَۚ وَ : اور لَقَدْ اٰتَيْنَآ : تحقیق البتہ ہم نے دی اِبْرٰهِيْمَ : ابراہیم رُشْدَهٗ : ہدایت یابی (فہم سلیم) مِنْ قَبْلُ : اس سے قبل وَكُنَّا : اور ہم تھے بِهٖ : اس کے عٰلِمِيْنَ : جاننے والے یقیناً ہم نے اس سے پہلے ابراہیم کو اسکی سمجھ بوجھ بخشی تھی اور (1) ہم اسکے احوال سے بخوبی واقف تھے (2)۔
  21,52,اِذْ قَالَ لِاَبِیْهِ وَ قَوْمِهٖ مَا هٰذِهِ التَّمَاثِیْلُ الَّتِیْۤ اَنْتُمْ لَهَا عٰكِفُوْنَ اِذْ قَالَ : جب اس نے کہا لِاَبِيْهِ : اپنے باپ سے وَقَوْمِهٖ : اور اپنی قوم مَا هٰذِهِ : کیا ہیں یہ التَّمَاثِيْلُ : مورتیاں الَّتِيْٓ : جو کہ اَنْتُمْ : تم لَهَا : ان کے لیے عٰكِفُوْنَ : جمے بیٹھے ہو جبکہ اس نے اپنے باپ سے اور اپنی قوم سے کہا کہ یہ مورتیاں جن کے تم مجاور بنے بیٹھے ہو کیا ہیں ؟ (1)۔
  21,53,قَالُوْا وَجَدْنَاۤ اٰبَآءَنَا لَهَا عٰبِدِیْنَ قَالُوْا : وہ بولے وَجَدْنَآ : ہم نے پایا اٰبَآءَنَا : اپنے باپ دادا لَهَا : انکے لیے۔ کی عٰبِدِيْنَ : پوجا کرنے والے سب نے جواب دیا کہ ہم نے اپنے باپ دادا کو انہی کی عبادت کرتے ہوئے پایا۔
  21,54,قَالَ لَقَدْ كُنْتُمْ اَنْتُمْ وَ اٰبَآؤُكُمْ فِیْ ضَلٰلٍ مُّبِیْنٍ قَالَ : اس نے کہا لَقَدْ كُنْتُمْ : تحقیق تم رہے اَنْتُمْ : تم وَاٰبَآؤُكُمْ : اور تمہارے باپ دادا فِيْ ضَلٰلٍ : گمراہی میں مُّبِيْنٍ : صریح آپ نے فرمایا ! پھر تم اور تمہارے باپ دادا سبھی یقیناً کھلی گمراہی میں مبتلا رہے۔
  21,55,قَالُوْۤا اَجِئْتَنَا بِالْحَقِّ اَمْ اَنْتَ مِنَ اللّٰعِبِیْنَ قَالُوْٓا : وہ بولے اَجِئْتَنَا : کیا تم لائے ہو ہمارے پاس بِالْحَقِّ : حق کو اَمْ : یا اَنْتَ : تم مِنَ : سے اللّٰعِبِيْنَ : کھیلنے والے (دل لگی کرنیوالے) کہنے لگے کیا آپ ہمارے پاس سچ مچ حق لائے ہیں یا یوں ہی مذاق کر رہے ہیں (1)۔
  21,56,قَالَ بَلْ رَّبُّكُمْ رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ الَّذِیْ فَطَرَهُنَّ١ۖ٘ وَ اَنَا عَلٰى ذٰلِكُمْ مِّنَ الشّٰهِدِیْنَ قَالَ : اس نے کہا بَلْ : بلکہ رَّبُّكُمْ : تمہارا رب رَبُّ : رب (مالک) السَّمٰوٰتِ : آسمان (جمع) وَالْاَرْضِ : اور زمین الَّذِيْ : وہ جس نے فَطَرَهُنَّ : انہیں پیدا کیا ڮ وَاَنَا : اور میں عَلٰي ذٰلِكُمْ : اس بات پر مِّنَ : سے الشّٰهِدِيْنَ : گواہ (جمع) آپ نے فرمایا نہیں درحقیقت تم سب کا پروردگار تو وہ ہے جو آسمانوں اور زمین کا مالک ہے جس نے انھیں پیدا کیا ہے، میں تو اپنی بات کا گواہ اور قائل ہوں (1)
  21,57,وَ تَاللّٰهِ لَاَكِیْدَنَّ اَصْنَامَكُمْ بَعْدَ اَنْ تُوَلُّوْا مُدْبِرِیْنَ وَتَاللّٰهِ : اور اللہ کی قسم لَاَكِيْدَنَّ : البتہ میں ضرور چال چلوں گا اَصْنَامَكُمْ : تمہارے بت (جمع) بَعْدَ : بعد اَنْ : کہ تُوَلُّوْا : تم جاؤگے مُدْبِرِيْنَ : پیٹھ پھیر کر اور اللہ کی قسم میں تمہارے ان معبودوں کے ساتھ جب تم علیحدہ پیٹھ پھیر کر چل دو گے ایک چال چلوں گا
