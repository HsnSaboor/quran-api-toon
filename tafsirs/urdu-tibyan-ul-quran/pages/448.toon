tafsir[25]{c,v,t}:
  37,52,یَّقُوْلُ اَئِنَّكَ لَمِنَ الْمُصَدِّقِیْنَ يَّقُوْلُ : وہ کہتا تھا اَئِنَّكَ : کیا تو لَمِنَ : سے الْمُصَدِّقِيْنَ : سچے جاننے والے جو (مجھ سے) کہا کرتا تھا کیا تو (قیامت کے آنے کا) یقین کرنے والوں سے ہے ؟ (1)
  37,53,ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَدِیْنُوْنَ ءَاِذَا : کیا جب مِتْنَا : ہم مرگئے وَكُنَّا : اور ہوگئے تُرَابًا : مٹی وَّعِظَامًا : اور ہڈیاں ءَاِنَّا : کیا ہم لَمَدِيْنُوْنَ : البتہ بدلہ دیے جائیں گے کیا جب ہم مر کر مٹی اور ہڈی ہوجائیں گے کیا اسوقت ہم جزا دیئے جانے والے ہیں ؟ (1)
  37,54,قَالَ هَلْ اَنْتُمْ مُّطَّلِعُوْنَ قَالَ : وہ کہنے لگا هَلْ : کیا اَنْتُمْ : تم مُّطَّلِعُوْنَ : جھانکنے والے ہو کہے گا تم چاہتے ہو کہ جھانک کر دیکھ لو ؟ (1)
  37,55,فَاطَّلَعَ فَرَاٰهُ فِیْ سَوَآءِ الْجَحِیْمِ فَاطَّلَعَ : تو وہ جھانکے گا فَرَاٰهُ : تو اسے دیکھے گا فِيْ : میں سَوَآءِ : درمیان الْجَحِيْمِ : دوزخ جھانکتے ہی اسے بیچوں بیچ جہنم میں (جلتا ہوا) دیکھے گا۔
  37,56,قَالَ تَاللّٰهِ اِنْ كِدْتَّ لَتُرْدِیْنِۙ قَالَ : وہ کہے گا تَاللّٰهِ : اللہ کی قسم اِنْ كِدْتَّ : تو قریب تھا لَتُرْدِيْنِ : کہ تو مجھے ہلاک کر ڈالے کہے گا واللہ ! قریب تھا کہ مجھے (بھی) برباد کردے۔
  37,57,وَ لَوْ لَا نِعْمَةُ رَبِّیْ لَكُنْتُ مِنَ الْمُحْضَرِیْنَ وَلَوْ : اور اگر لَا : نہ نِعْمَةُ : نعمت رَبِّيْ : میرا رب لَكُنْتُ : تو میں ضرور ہوتا مِنَ : سے الْمُحْضَرِيْنَ : حاضر کیے جانے والے اگر میرے رب کا احسان نہ ہوتا تو میں بھی دوزخ میں حاضر کئے جانے والوں میں ہوتا (1)
  37,58,اَفَمَا نَحْنُ بِمَیِّتِیْنَۙ اَفَمَا نَحْنُ : کیا پس نہیں ہم بِمَيِّتِيْنَ : مرنے والوں میں سے کیا (یہ صحیح ہے) ہم مرنے والے ہی نہیں ؟ (1)
  37,59,اِلَّا مَوْتَتَنَا الْاُوْلٰى وَ مَا نَحْنُ بِمُعَذَّبِیْنَ اِلَّا : سوائے مَوْتَتَنَا : ہماری موت الْاُوْلٰى : پہلی وَمَا : اور نہیں نَحْنُ : ہم بِمُعَذَّبِيْنَ : عذاب دیے جانے والوں میں سے بجز پہلی ایک موت کے، (1) اور ہم نہ عذاب کیے جانے والے ہیں۔
  37,60,اِنَّ هٰذَا لَهُوَ الْفَوْزُ الْعَظِیْمُ اِنَّ : بیشک ھٰذَا : یہ لَهُوَ : البتہ وہ الْفَوْزُ الْعَظِيْمُ : کامیابی عظیم پھر تو (ظاہر بات ہے کہ) یہ بڑی کامیابی ہے (1)
  37,61,لِمِثْلِ هٰذَا فَلْیَعْمَلِ الْعٰمِلُوْنَ لِمِثْلِ ھٰذَا : اس جیسی (نعمت) کے لیے فَلْيَعْمَلِ : پس چاہیے ضرور عمل کریں الْعٰمِلُوْنَ : عمل کرنے والے ایسی (کامیابی) کے عمل کرنے والوں کو عمل کرنا چاہیے (1)۔
  37,62,اَذٰلِكَ خَیْرٌ نُّزُلًا اَمْ شَجَرَةُ الزَّقُّوْمِ اَذٰلِكَ : کیا یہ خَيْرٌ : بہتر نُّزُلًا : ضایفت اَمْ : یا شَجَرَةُ الزَّقُّوْمِ : درخت تھوہر کیا یہ مہمانی اچھی ہے یا (زقوم) کا درخت (1)
  37,63,اِنَّا جَعَلْنٰهَا فِتْنَةً لِّلظّٰلِمِیْنَ اِنَّا : بیشک ہم جَعَلْنٰهَا : ہم نے اس کو بنایا فِتْنَةً : ایک آزمائش لِّلظّٰلِمِيْنَ : ظالموں کے لیے جسے ہم نے ظالموں کے لئے سخت آزمائش بنا رکھا ہے (1)
  37,64,اِنَّهَا شَجَرَةٌ تَخْرُجُ فِیْۤ اَصْلِ الْجَحِیْمِۙ اِنَّهَا : بیشک وہ شَجَرَةٌ : ایک درخت تَخْرُجُ : وہ نکلتا ہے فِيْٓ : میں اَصْلِ : جڑ الْجَحِيْمِ : جہنم بیشک وہ درخت جہنم کی جڑ میں سے نکلتا ہے (1)
  37,65,طَلْعُهَا كَاَنَّهٗ رُءُوْسُ الشَّیٰطِیْنِ طَلْعُهَا : اس کا خوشہ كَاَنَّهٗ : گویا کہ وہ رُءُوْسُ : سر (جمع) الشَّيٰطِيْنِ : شیطانوں جسکے خوشے شیطانوں کے سروں جیسے ہوتے ہیں (1)۔
  37,66,فَاِنَّهُمْ لَاٰكِلُوْنَ مِنْهَا فَمَالِئُوْنَ مِنْهَا الْبُطُوْنَؕ فَاِنَّهُمْ : پس بیشک وہ لَاٰكِلُوْنَ : کھانے والے ہیں مِنْهَا : اس سے فَمَالِئُوْنَ : سو بھرنے والے مِنْهَا : اس سے الْبُطُوْنَ : پیٹ (جمع) (جہنمی) اسی درخت میں سے کھائیں گے اور اسی سے پیٹ بھریں گے (1)۔
  37,67,ثُمَّ اِنَّ لَهُمْ عَلَیْهَا لَشَوْبًا مِّنْ حَمِیْمٍۚ ثُمَّ : پھر اِنَّ : بیشک لَهُمْ : ان کے لیے عَلَيْهَا : اس پر لَشَوْبًا : ملا ملا کر مِّنْ : سے حَمِيْمٍ : کھولتا ہوا پانی پھر اس پر گرم کھولتا ہوا پانی پلایا جائیگا (1)
  37,68,ثُمَّ اِنَّ مَرْجِعَهُمْ لَاۡاِلَى الْجَحِیْمِ ثُمَّ : پھر اِنَّ : بیشک مَرْجِعَهُمْ : ان کی بازگشت لَا۟ : البتہ اِلَى : طرف الْجَحِيْمِ : جہنم پھر ان سب کا لوٹنا جہنم کی بھڑکتی ہوئی آگ کی طرف ہوگا (1)۔
  37,69,اِنَّهُمْ اَلْفَوْا اٰبَآءَهُمْ ضَآلِّیْنَۙ اِنَّهُمْ : بیشک ان اَلْفَوْا : انہوں نے پایا اٰبَآءَهُمْ : اپنے باپ دادا ضَآلِّيْنَ : گمراہ (جمع) یقین مانو ! کہ انہوں نے اپنے باپ دادا کو بہکایا ہوا پایا۔
  37,70,فَهُمْ عَلٰۤى اٰثٰرِهِمْ یُهْرَعُوْنَ فَهُمْ : سو وہ عَلٰٓي اٰثٰرِهِمْ : ان کے نقش قدم پر يُهْرَعُوْنَ : دوڑتے جاتے تھے یہ انہی کے نشان قدم پر دوڑتے رہے (1)
  37,71,وَ لَقَدْ ضَلَّ قَبْلَهُمْ اَكْثَرُ الْاَوَّلِیْنَۙ وَلَقَدْ ضَلَّ : اور تحقیق گمراہ ہوئے قَبْلَهُمْ : ان سے پہلے اَكْثَرُ الْاَوَّلِيْنَ : اگلوں میں سے اکثر ان سے پہلے بھی بہت سے اگلے بہک چکے ہیں (1)
  37,72,وَ لَقَدْ اَرْسَلْنَا فِیْهِمْ مُّنْذِرِیْنَ وَلَقَدْ اَرْسَلْنَا : اور تحقیق ہم نے بھیجے فِيْهِمْ : ان میں مُّنْذِرِيْنَ : ڈرانے والے جن میں ہم نے ڈرانے والے (رسول) بھیجے تھے (1)
  37,73,فَانْظُرْ كَیْفَ كَانَ عَاقِبَةُ الْمُنْذَرِیْنَۙ فَانْظُرْ : سو دیکھیں كَيْفَ : کیسا كَانَ : ہوا عَاقِبَةُ : انجام الْمُنْذَرِيْنَ : جنہیں ڈرایا گیا اب تو دیکھ لے کہ جنہیں دھمکایا گیا تھا ان کا انجام کیسا ہوا
  37,74,اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ۠    ۧ اِلَّا : مگر عِبَادَ اللّٰهِ : اللہ کے بندے الْمُخْلَصِيْنَ : خاص کیے ہوئے سوائے اللہ کے برگزیدہ بندوں کے (1)
  37,75,وَ لَقَدْ نَادٰىنَا نُوْحٌ فَلَنِعْمَ الْمُجِیْبُوْنَ٘ۖ وَلَقَدْ نَادٰىنَا : اور تحقیق ہمیں پکارا نُوْحٌ : نوح فَلَنِعْمَ : سو ہم البتہ خوب الْمُجِيْبُوْنَ : دعا قبول کرنے والے اور ہمیں نوح ؑ نے پکارا تو (دیکھ لو) ہم کیسے اچھے دعا قبول کرنے والے ہیں (1)۔
  37,76,وَ نَجَّیْنٰهُ وَ اَهْلَهٗ مِنَ الْكَرْبِ الْعَظِیْمِ٘ۖ وَنَجَّيْنٰهُ : اور ہم نے نجات دی اسے وَاَهْلَهٗ : اور اس کے گھر والے مِنَ : سے الْكَرْبِ : مصیبت الْعَظِيْمِ : بڑی ہم نے اسے اور اس کے گھر والوں کو (1) اس زبردست مصیبت سے بچا لیا۔
