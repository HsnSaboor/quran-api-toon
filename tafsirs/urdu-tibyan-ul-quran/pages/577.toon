tafsir[28]{c,v,t}:
  74,48,فَمَا تَنْفَعُهُمْ شَفَاعَةُ الشّٰفِعِیْنَؕ فَمَا تَنْفَعُهُمْ : اور انہیں نفع نہ دیا شَفَاعَةُ : سفارش الشّٰفِعِيْنَ : سفارش کرنے والوں پس انہیں سفارش کرنے والوں کی سفارش نفع نہ دے گی (1)
  74,49,فَمَا لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِیْنَۙ فَمَا : تو کیا ہوا لَهُمْ : انہیں عَنِ : سے التَّذْكِرَةِ : نصیحت مُعْرِضِيْنَ : منہ پھیرتے ہیں انہیں کیا ہوگیا ہے ؟ کہ نصیحت سے منہ موڑ رہے ہیں۔
  74,50,كَاَنَّهُمْ حُمُرٌ مُّسْتَنْفِرَةٌۙ كَاَنَّهُمْ : گویا کہ وہ حُمُرٌ : گدھے مُّسْتَنْفِرَةٌ : بھاگے ہوئے گویا کہ وہ بہکے ہوئے گدھے ہیں۔
  74,51,فَرَّتْ مِنْ قَسْوَرَةٍؕ فَرَّتْ : بھاگے جاتے ہیں مِنْ قَسْوَرَةٍ : شیر سے جو شیر سے بھاگے ہوں۔ (1)
  74,52,بَلْ یُرِیْدُ كُلُّ امْرِئٍ مِّنْهُمْ اَنْ یُّؤْتٰى صُحُفًا مُّنَشَّرَةًۙ بَلْ يُرِيْدُ : بلکہ چاہتا ہے كُلُّ امْرِۍ : ہر آدمی مِّنْهُمْ : ان میں سے اَنْ يُّؤْتٰى : کہ وہ دئے جائیں صُحُفًا : صحیفے مُّنَشَّرَةً : کھلے ہوئے بلکہ ان میں سے ہر ایک شخص چاہتا ہے کہ اسے کھلی ہوئی کتابیں دی جائیں (1)
  74,53,كَلَّا١ؕ بَلْ لَّا یَخَافُوْنَ الْاٰخِرَةَؕ كَلَّا ۭ : ہرگز نہیں بَلْ : بلکہ لَّا يَخَافُوْنَ : وہ نہیں ڈرتے الْاٰخِرَةَ : آخرت ہرگز ایسا نہیں (ہو سکتا بلکہ) یہ قیامت سے بےخوف ہیں (1)
  74,54,كَلَّاۤ اِنَّهٗ تَذْكِرَةٌۚ كَلَّآ : ہرگز نہیں اِنَّهٗ تَذْكِرَةٌ : بیشک یہ نصیحت سچی بات تو یہ ہے کہ یہ (قرآن) ایک نصیحت ہے (1)
  74,55,فَمَنْ شَآءَ ذَكَرَهٗؕ فَمَنْ شَآءَ : سو وہ جو چاہے ذَكَرَهٗ : اسے یاد رکھے اب جو چاہے اس سے نصیحت حاصل کرے۔
  74,56,وَ مَا یَذْكُرُوْنَ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ١ؕ هُوَ اَهْلُ التَّقْوٰى وَ اَهْلُ الْمَغْفِرَةِ۠    ۧ وَمَا : اور نہ يَذْكُرُوْنَ : وہ یاد رکھیں گے اِلَّآ : مگر اَنْ : یہ کہ يَّشَآءَ اللّٰهُ ۭ : اللہ چاہے هُوَ : وہی اَهْلُ التَّقْوٰى : ڈرنے کے لائق وَاَهْلُ الْمَغْفِرَةِ : مغفرت کے لائق اور وہ اس وقت نصیحت حاصل کریں گے جب اللہ تعالیٰ چاہے (1) وہ اسی لائق ہے کہ اس سے ڈریں اور اس لائق بھی کہ وہ بخشے (2)۔
  75,1,لَاۤ اُقْسِمُ بِیَوْمِ الْقِیٰمَةِۙ لَآ اُقْسِمُ : نہیں میں قسم کھاتا ہوں بِيَوْمِ الْقِيٰمَةِ : قیامت کے دن کی میں قسم کھاتا ہوں قیامت کے دن کی (1)۔
  75,2,وَ لَاۤ اُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِؕ وَلَآ اُقْسِمُ : اور نہیں میں قسم کھاتا ہوں بِالنَّفْسِ : دل کی اللَّوَّامَةِ : اپنے اوپر ملامت کرنیوالے اور قسم کھاتا ہوں اس نفس کی جو ملامت کرنے والا ہو (1)۔
  75,3,اَیَحْسَبُ الْاِنْسَانُ اَلَّنْ نَّجْمَعَ عِظَامَهٗؕ اَيَحْسَبُ : کیا گمان کرتا ہے الْاِنْسَانُ : انسان اَلَّنْ نَّجْمَعَ : کہ ہم ہرگز جمع نہ کریں گے عِظَامَهٗ : اس کی ہڈیاں کیا انسان یہ خیال کرتا ہے کہ ہم اس کی ہڈیاں جمع کریں گے ہی نہیں (1)۔
  75,4,بَلٰى قٰدِرِیْنَ عَلٰۤى اَنْ نُّسَوِّیَ بَنَانَهٗ بَلٰى : کیوں نہیں قٰدِرِيْنَ : ہم قادر ہیں عَلٰٓي : پر اَنْ : کہ نُّسَوِّيَ : ہم درست کریں بَنَانَهٗ : اس کے پورے پورے ہاں ضرور کریں گے ہم تو قادر ہیں کہ اس کی پور پور تک درست کردیں (1)۔
  75,5,بَلْ یُرِیْدُ الْاِنْسَانُ لِیَفْجُرَ اَمَامَهٗۚ بَلْ : بلکہ يُرِيْدُ : چاہتا ہے الْاِنْسَانُ : انسان لِيَفْجُرَ : کہ گناہ کرتا رہے اَمَامَهٗ : اپنے آگے کو بھی بلکہ انسان تو چاہتا ہے کہ آگے آگے نافرمانیاں کرتا جائے (1)
  75,6,یَسْئَلُ اَیَّانَ یَوْمُ الْقِیٰمَةِؕ يَسْئَلُ : اور پوچھتا ہے اَيَّانَ : کب يَوْمُ الْقِيٰمَةِ : روز قیامت پوچھتا ہے کہ قیامت کا دن کب آئے گا (1)
  75,7,فَاِذَا بَرِقَ الْبَصَرُۙ فَاِذَا : پس جب بَرِقَ : چندھیاں جائیں گی الْبَصَرُ : آنکھیں پس جس وقت کہ نگاہ پتھرا جائے گی (1)۔
  75,8,وَ خَسَفَ الْقَمَرُۙ وَخَسَفَ : اور گرہن لگ جائیگا الْقَمَرُ : چاند اور چاند بےنور ہوجائے گا (1)
  75,9,وَ جُمِعَ الشَّمْسُ وَ الْقَمَرُۙ وَجُمِعَ : اور جمع کردئیے جائیں گے الشَّمْسُ : سورج وَالْقَمَرُ : اور چاند اور سورج اور چاند جمع کردیئے جائیں گے (1)۔
  75,10,یَقُوْلُ الْاِنْسَانُ یَوْمَئِذٍ اَیْنَ الْمَفَرُّۚ يَقُوْلُ : کہے گا الْاِنْسَانُ : انسان يَوْمَئِذٍ : آج کے دن اَيْنَ الْمَفَرُّ : کہاں بھاگنے کی جگہ اس دن انسان کہے گا کہ آج بھاگنے کی جگہ کہاں ہے (1)۔
  75,11,كَلَّا لَا وَزَرَؕ كَلَّا : ہرگز نہیں لَا وَزَرَ : نہیں کوئی بچاؤ نہیں نہیں کوئی پناہ گاہ نہیں (1)۔
  75,12,اِلٰى رَبِّكَ یَوْمَئِذِ اِ۟لْمُسْتَقَرُّؕ اِلٰى : طرف رَبِّكَ : تیرا رب يَوْمَئِذِۨ : آج کے دن الْمُسْتَقَرُّ : ٹھکانا آج تیرے پروردگار کی طرف ہی قرار گاہ ہے (1)
  75,13,یُنَبَّؤُا الْاِنْسَانُ یَوْمَئِذٍۭ بِمَا قَدَّمَ وَ اَخَّرَؕ يُنَبَّؤُا : وہ جتلادیا جائے گا الْاِنْسَانُ : انسان يَوْمَئِذٍۢ : آج کے دن بِمَا قَدَّمَ : وہ جو اس نے آگے بھیجا وَاَخَّرَ : اور اس نے پیچھے چھوڑا آج انسان کو اس کے آگے بھیجے ہوئے اور پیچھے چھوڑے ہوئے سے آگاہ کیا جائے گا (1)
  75,14,بَلِ الْاِنْسَانُ عَلٰى نَفْسِهٖ بَصِیْرَةٌۙ بَلِ الْاِنْسَانُ : بلکہ انسان عَلٰي : پر نَفْسِهٖ : اپنی جان (حالت) بَصِيْرَةٌ : باخبر بلکہ انسان خود اپنے اوپر حجت ہے (1)۔
  75,15,وَّ لَوْ اَلْقٰى مَعَاذِیْرَهٗؕ وَّلَوْ اَلْقٰى : اگرچہ لاڈالے مَعَاذِيْرَهٗ : اپنے عذر اگرچہ کتنے ہی بہانے پیش کرے (1)۔
  75,16,لَا تُحَرِّكْ بِهٖ لِسَانَكَ لِتَعْجَلَ بِهٖؕ لَا تُحَرِّكْ : آپ حرکت نہ دیں بِهٖ : اس (قرآن) کے ساتھ لِسَانَكَ : اپنی زبان کو لِتَعْجَلَ : کہ جلد (یاد کرلیں) بِهٖ : اس کو (اے نبی) آپ قرآن کو جلدی (یاد کرنے) کے لئے اپنی زبان کو حرکت (1) نہ دیں۔
  75,17,اِنَّ عَلَیْنَا جَمْعَهٗ وَ قُرْاٰنَهٗۚۖ اِنَّ : بیشک عَلَيْنَا : ہم پر (ہمارے ذمے) جَمْعَهٗ : اس کا جمع کرنا وَقُرْاٰنَه ٗ : اور اس کا پڑھنا اسکا جمع کرنا اور (آپ کی زبان سے) پڑھنا ہمارے ذمہ ہے (1)
  75,18,فَاِذَا قَرَاْنٰهُ فَاتَّبِعْ قُرْاٰنَهٗۚ فَاِذَا : پس جب قَرَاْنٰهُ : ہم اسے پڑھیں فَاتَّبِعْ : تو آپ پیروی کریں قُرْاٰنَهٗ : اس کے پڑھنے کی ہم جب اسے پڑھ لیں تو آپ اس کے پڑھنے کی پیروی کریں (1)
  75,19,ثُمَّ اِنَّ عَلَیْنَا بَیَانَهٗؕ ثُمَّ اِنَّ : پھر بیشک عَلَيْنَا : ہم پر (ہمارے ذمے) بَيَانَهٗ : اس کا بیان پھر اس کا واضح کردینا ہمارا ذمہ ہے۔
