quran[29]{c,v,t}:
81,1,اِذَا الشَّمْسُ كُوِّرَتْ۪ۙ اِذَا الشَّمْسُ : جب سورج كُوِّرَتْ : لپیٹ دیا جائے جب سورج لپیٹ میں آجائے گا (1)
81,2,وَ اِذَا النُّجُوْمُ انْكَدَرَتْ۪ۙ وَاِذَا النُّجُوْمُ : اور جب ستارے انْكَدَرَتْ : ماند پڑجائیں اور جب ستارے بےنور ہوجائیں گے (1)
81,3,وَ اِذَا الْجِبَالُ سُیِّرَتْ۪ۙ وَاِذَا الْجِبَالُ : اور جب پہاڑ سُيِّرَتْ : چلائے جائیں اور جب پہاڑ چلائے جائیں گے (1)
81,4,وَ اِذَا الْعِشَارُ عُطِّلَتْ۪ۙ وَاِذَا : اور جب الْعِشَارُ : دس ماہ کی گابھن اونٹنیاں عُطِّلَتْ : چھٹی پھریں اور جب دس ماہ کی حاملہ اونٹنیاں چھوڑ دی جائیں گی (1)
81,5,وَ اِذَا الْوُحُوْشُ حُشِرَتْ۪ۙ وَاِذَا الْوُحُوْشُ : اور جب وحشی جانور حُشِرَتْ : اکھٹے کئے جائیں اور جب وحشی جانور اکھٹے کئے جائیں گے (1)
81,6,وَ اِذَا الْبِحَارُ سُجِّرَتْ۪ۙ وَاِذَا الْبِحَارُ : ار جب دریا سُجِّرَتْ : بھڑکائے جائیں اور جب سمندر بھڑکائے جائیں گے
81,7,وَ اِذَا النُّفُوْسُ زُوِّجَتْ۪ۙ وَاِذَا النُّفُوْسُ : اور جب جانیں زُوِّجَتْ : جوڑے باندھے جائیں اور جب جانیں (جسموں سے) ملا دی جائیں گی (1)
81,8,وَ اِذَا الْمَوْءٗدَةُ سُئِلَتْ۪ۙ وَاِذَا : اور جب الْمَوْءٗدَةُ : زندہ گاڑی ہوئی لڑکی سُئِلَتْ : پوچھا جائے جب زندہ گاڑی ہوئی لڑکی سے سوال کیا جائے گا۔
81,9,بِاَیِّ ذَنْۢبٍ قُتِلَتْۚ بِاَيِّ : کس ذَنْۢبٍ : گناہ قُتِلَتْ : ماری گئی کہ کس گناہ کی وجہ سے وہ قتل کی گئی
81,10,وَ اِذَا الصُّحُفُ نُشِرَتْ۪ۙ وَاِذَا الصُّحُفُ : اور جب اعمال نامے نُشِرَتْ : کھولے جائیں جب نامہ اعمال کھول دئیے جائیں گے (1)
81,11,وَ اِذَا السَّمَآءُ كُشِطَتْ۪ۙ وَاِذَا السَّمَآءُ : اور جب آسمان كُشِطَتْ : کھال کھینچ لی جائے اور جب آسمان کی کھال اتار لی جائے گی (1)
81,12,وَ اِذَا الْجَحِیْمُ سُعِّرَتْ۪ۙ وَاِذَا الْجَحِيْمُ : اور جب جہنم سُعِّرَتْ : بھڑکائی جائے اور جب جہنم بھڑکائی جائے گی۔
81,13,وَ اِذَا الْجَنَّةُ اُزْلِفَتْ۪ۙ وَاِذَا الْجَنَّةُ : اور جب جنت اُزْلِفَتْ : قریب لائی جائے اور جب جنت نزدیک کردی جائے گی۔
81,14,عَلِمَتْ نَفْسٌ مَّاۤ اَحْضَرَتْؕ عَلِمَتْ : جان لے گا نَفْسٌ : ہر شخص مَّآ : جو کچھ اَحْضَرَتْ : وہ لایا تو اس دن ہر شخص جان لے گا جو کچھ لے کر آیا ہوگا (1)
81,15,فَلَاۤ اُقْسِمُ بِالْخُنَّسِۙ فَلَآ اُقْسِمُ : سو میں قسم کھاتاہوں بِالْخُنَّسِ : پیچھے ہٹ جانیوالے میں قسم کھاتا ہوں پیچھے ہٹنے والے۔
81,16,الْجَوَارِ الْكُنَّسِۙ الْجَوَارِ : سیدھے چلنے والے الْكُنَّسِ : چھپ جانے والے پھر چلنے پھرنے والے چھپنے والے ستاروں کی (1)
81,17,وَ الَّیْلِ اِذَا عَسْعَسَۙ وَالَّيْلِ : اور رات اِذَا عَسْعَسَ : جب پھیل جائے اور رات کی جب جانے لگے۔
81,18,وَ الصُّبْحِ اِذَا تَنَفَّسَۙ وَالصُّبْحِ : اور صبح اِذَا تَنَفَّسَ : جب دم بھرے اور صبح کی جب چمکنے لگے۔
81,19,اِنَّهٗ لَقَوْلُ رَسُوْلٍ كَرِیْمٍۙ اِنَّهٗ لَقَوْلُ : بیشک یہ کلام رَسُوْلٍ : قاصد كَرِيْمٍ : عزت والا یقیناً ایک بزرگ رسول کا کہا ہوا ہے (1)
81,20,ذِیْ قُوَّةٍ عِنْدَ ذِی الْعَرْشِ مَكِیْنٍۙ ذِيْ قُوَّةٍ : قوت والا عِنْدَ : نزدیک ذِي الْعَرْشِ : عرش کے مالک مَكِيْنٍ : بلند مرتبہ جو قوت والا ہے عرش والے (اللہ) کے نزدیک بلند مرتبہ ہے۔
81,21,مُّطَاعٍ ثَمَّ اَمِیْنٍؕ مُّطَاعٍ : سب کا مانا ہوا ثَمَّ اَمِيْنٍ : وہاں کا امانتدار جس کی (آسمانوں میں) اطاعت کی جاتی ہے، امین ہے۔
81,22,وَ مَا صَاحِبُكُمْ بِمَجْنُوْنٍۚ وَمَا : اور نہیں صَاحِبُكُمْ : تمہارا رفیق بِمَجْنُوْنٍ : دیوانہ اور تمہارا ساتھی دیوانہ نہیں (1)
81,23,وَ لَقَدْ رَاٰهُ بِالْاُفُقِ الْمُبِیْنِۚ وَلَقَدْ رَاٰهُ : اور اس نے اس کو دیکھا ہے بِالْاُفُقِ : کنارہ پر الْمُبِيْنِ : کھلا اس نے اس (فرشتے) کو آسمان کے کھلے کنارے پر دیکھا بھی ہے (1)
81,24,وَ مَا هُوَ عَلَى الْغَیْبِ بِضَنِیْنٍۚ وَمَا : اور نہیں هُوَ : وہ عَلَي الْغَيْبِ : غیب پر بِضَنِيْنٍ : بخل کرنے والا اور یہ غیب کی باتوں کو بتلانے کے لئے بخیل بھی نہیں۔
81,25,وَ مَا هُوَ بِقَوْلِ شَیْطٰنٍ رَّجِیْمٍۙ وَمَا هُوَ : اور نہیں وہ بِقَوْلِ : کہا ہوا شَيْطٰنٍ : شیطان رَّجِيْمٍ : مردود اور یہ قرآن شیطان مردود کا کلام نہیں۔
81,26,فَاَیْنَ تَذْهَبُوْنَؕ فَاَيْنَ : پھر کدھر تَذْهَبُوْنَ : تم جارہے ہو پھر تم کہاں جا رہے ہو (1)
81,27,اِنْ هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِیْنَۙ اِنْ هُوَ : نہیں وہ اِلَّا ذِكْرٌ : مگر نصیحت لِّلْعٰلَمِيْنَ : تمام جہانوں کے لئے یہ تمام جہان والوں کے لئے نصیحت نامہ ہے۔
81,28,لِمَنْ شَآءَ مِنْكُمْ اَنْ یَّسْتَقِیْمَؕ لِمَنْ شَآءَ : جو چاہے مِنْكُمْ : تم سے اَنْ يَّسْتَقِيْمَ : کہ سیدھا چلے (بالخصوص) اس کے لئے جو تم میں سے سیدھی راہ پر چلنا چاہے۔
81,29,وَ مَا تَشَآءُوْنَ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ رَبُّ الْعٰلَمِیْنَ۠    ۧ وَمَا تَشَآءُوْنَ : اور تم نہ چاہوگے اِلَّآ : مگر اَنْ يَّشَآءَ اللّٰهُ : یہ کہ چاہے اللہ رَبُّ الْعٰلَمِيْنَ : رب تمام جہان اور تم بغیر پروردگار عالم کے چاہے کچھ نہیں چاہ سکتے (1)
