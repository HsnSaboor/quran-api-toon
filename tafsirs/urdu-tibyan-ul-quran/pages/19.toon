quran[98]{c,v,t}:
19,1,كٓهٰیٰعٓصٓ۫ۚ كٓهٰيٰعٓصٓ : کاف۔ ہا۔ یا۔ عین۔ صاد کہیعص
19,2,ذِكْرُ رَحْمَتِ رَبِّكَ عَبْدَهٗ زَكَرِیَّاۖۚ ذِكْرُ : ذکر رَحْمَتِ : رحمت رَبِّكَ : تیرا رب عَبْدَهٗ : اپنا بندہ زَكَرِيَّا : زکریا یہ ہے تیرے پروردگار کی اس مہربانی کا ذکر جو اس نے اپنے بندے زکریا (1) پر کی تھی۔
19,3,اِذْ نَادٰى رَبَّهٗ نِدَآءً خَفِیًّا اِذْ : جب نَادٰى : اس نے پکارا رَبَّهٗ : اپنا رب نِدَآءً : پکارنا خَفِيًّا : آہستہ سے جبکہ اس نے اپنے رب سے چپکے چپکے دعا کی تھی (1)
19,4,قَالَ رَبِّ اِنِّیْ وَهَنَ الْعَظْمُ مِنِّیْ وَ اشْتَعَلَ الرَّاْسُ شَیْبًا وَّ لَمْ اَكُنْۢ بِدُعَآئِكَ رَبِّ شَقِیًّا قَالَ : اس نے کہا رَبِّ : اے میرے رب اِنِّىْ : بیشک میں وَهَنَ : کمزور ہوگئی الْعَظْمُ : ہڈیاں مِنِّيْ : میری وَاشْتَعَلَ : اور شعلہ مارنے لگا الرَّاْسُ : سر شَيْبًا : سفید بال وَّ : اور لَمْ اَكُنْ : میں نہیں رہا بِدُعَآئِكَ : تجھ سے مانگ کر رَبِّ : اے میرے رب شَقِيًّا : محروم کہ اے میرے پروردگار ! میری ہڈیاں کمزور ہوگئی ہیں اور سر بڑھاپے کی وجہ سے بھڑک اٹھا ہے (1) لیکن میں کبھی بھی تجھ سے دعا کرکے محروم نہیں رہا (2)
19,5,وَ اِنِّیْ خِفْتُ الْمَوَالِیَ مِنْ وَّرَآءِیْ وَ كَانَتِ امْرَاَتِیْ عَاقِرًا فَهَبْ لِیْ مِنْ لَّدُنْكَ وَلِیًّاۙ وَاِنِّىْ : اور البتہ میں خِفْتُ : ڈرتا ہوں الْمَوَالِيَ : اپنے رشتے دار مِنْ وَّرَآءِيْ : اپنے بعد وَكَانَتِ : اور ہے امْرَاَتِيْ : میری بیوی عَاقِرًا : بانجھ فَهَبْ لِيْ : تو مجھے عطا کر مِنْ لَّدُنْكَ : اپنے پاس سے وَلِيًّا : ایک وارث مجھے اپنے مرنے کے بعد اپنے قرابت والوں کا ڈر ہے (1) میری بیوی بھی بانجھ ہے پس تو مجھے اپنے پاس سے (2) وارث عطا فرما۔
19,6,یَّرِثُنِیْ وَ یَرِثُ مِنْ اٰلِ یَعْقُوْبَ١ۖۗ وَ اجْعَلْهُ رَبِّ رَضِیًّا يَّرِثُنِيْ : میرا وارث ہو وَيَرِثُ : اور وارث ہو مِنْ : سے۔ کا اٰلِ يَعْقُوْبَ : اولادِ یعقوب وَاجْعَلْهُ : اور اسے بنا دے رَبِّ : اے میرے رب رَضِيًّا : پسندیدہ جو میرا بھی وارث ہو اور یعقوب ؑ کے خاندان کا بھی جانشین اور میرے رب ! تو اسے مقبول بندہ بنالے۔
19,7,یٰزَكَرِیَّاۤ اِنَّا نُبَشِّرُكَ بِغُلٰمِ اِ۟سْمُهٗ یَحْیٰى١ۙ لَمْ نَجْعَلْ لَّهٗ مِنْ قَبْلُ سَمِیًّا يٰزَكَرِيَّآ : اے زکریا اِنَّا : بیشک ہم نُبَشِّرُكَ : تجھے بشارت دیتے ہیں بِغُلٰمِ : ایک لڑکا اسْمُهٗ : اس کا نام يَحْيٰى : یحییٰ لَمْ نَجْعَلْ : نہیں بنایا ہم نے لَّهٗ : اس کا مِنْ قَبْلُ : اس سے قبل سَمِيًّا : کوئی ہم نام اے زکریا ! ہم تجھے ایک بچے کی خوشخبری دیتے ہیں جس کا نام یحیٰی ہے، ہم نے اس سے پہلے اس کا ہم نام بھی کسی کو نہیں کیا (1)۔
19,8,قَالَ رَبِّ اَنّٰى یَكُوْنُ لِیْ غُلٰمٌ وَّ كَانَتِ امْرَاَتِیْ عَاقِرًا وَّ قَدْ بَلَغْتُ مِنَ الْكِبَرِ عِتِیًّا قَالَ : اس نے کہا رَبِّ : اے میرے رب اَنّٰى : کیسے يَكُوْنُ : ہوگا وہ لِيْ غُلٰمٌ : میرے لیے۔ میرا۔ لڑکا وَّكَانَتِ : جبکہ وہ ہے امْرَاَتِيْ : میری بیوی عَاقِرًا : بانجھ وَّقَدْ بَلَغْتُ : اور میں پہنچ چکا ہوں مِنَ : سے۔ کی الْكِبَرِ : بڑھاپا عِتِيًّا : انتہائی حد زکریا ؑ کہنے لگے میرے رب ! میرے ہاں لڑکا کیسے ہوگا، جب کہ میری بیوی بانجھ اور میں خود بڑھاپے کے انتہائی ضعف کو پہنچ چکا ہوں (1)۔
19,9,قَالَ كَذٰلِكَ١ۚ قَالَ رَبُّكَ هُوَ عَلَیَّ هَیِّنٌ وَّ قَدْ خَلَقْتُكَ مِنْ قَبْلُ وَ لَمْ تَكُ شَیْئًا قَالَ : اس نے کہا كَذٰلِكَ : اسی طرح قَالَ : فرمایا رَبُّكَ : تیرا رب هُوَ : وہ (یہ) عَلَيَّ : مجھ پر هَيِّنٌ : آسان وَّ : اور قَدْ خَلَقْتُكَ : میں نے تجھے پیدا کیا مِنْ قَبْلُ : اس سے قبل وَ : جبکہ لَمْ تَكُ : تو نہ تھا شَيْئًا : کوئی چیز۔ کچھ بھی ارشاد ہوا کہ وعدہ اسی طرح ہوچکا، تیرے رب نے فرما دیا کہ مجھ پر تو یہ بالکل آسان ہے اور تو خود جبکہ کچھ نہ تھا میں تجھے پیدا کرچکا ہوں (1)
19,10,قَالَ رَبِّ اجْعَلْ لِّیْۤ اٰیَةً١ؕ قَالَ اٰیَتُكَ اَلَّا تُكَلِّمَ النَّاسَ ثَلٰثَ لَیَالٍ سَوِیًّا قَالَ : اس نے کہا رَبِّ : اے میرے رب اجْعَلْ : کردے لِّيْٓ : میرے لیے اٰيَةً : کوئی نشانی قَالَ : فرمایا اٰيَتُكَ : تیری نشانی اَلَّا تُكَلِّمَ : تو نہ بات کرے گا النَّاسَ : لوگ (جمع) ثَلٰثَ : تین لَيَالٍ : رات سَوِيًّا : ٹھیک کہنے لگے میرے پروردگار میرے لئے کوئی علامت مقرر فرما دے ارشاد ہوا کہ تیرے لئے علامت یہ ہے کہ باوجود بھلا چنگا ہونے کے تین راتوں تک کسی شخص سے بول نہ سکے گا۔ (1)
19,11,فَخَرَجَ عَلٰى قَوْمِهٖ مِنَ الْمِحْرَابِ فَاَوْحٰۤى اِلَیْهِمْ اَنْ سَبِّحُوْا بُكْرَةً وَّ عَشِیًّا فَخَرَجَ : پھر وہ نکلا عَلٰي : پاس قَوْمِهٖ : اپنی قوم مِنَ : سے الْمِحْرَابِ : محراب فَاَوْحٰٓى : تو اس نے اشارہ کیا اِلَيْهِمْ : ان کی طرف اَنْ سَبِّحُوْا : کہ اس کی پاکیزگی بیان کرو بُكْرَةً : صبح وَّعَشِيًّا : اور شام اب زکریا ؑ اپنے حجرے (1) سے نکل کر اپنی قوم کے پاس آکر انھیں اشارہ کرتے ہیں کہ تم صبح وشام اللہ تعالیٰ کی تسبیح بیان کرو (2)۔
19,12,یٰیَحْیٰى خُذِ الْكِتٰبَ بِقُوَّةٍ١ؕ وَ اٰتَیْنٰهُ الْحُكْمَ صَبِیًّاۙ يٰيَحْيٰى : اے یحییٰ خُذِ : پکڑو (تھام لو) الْكِتٰبَ : کتاب بِقُوَّةٍ : مضبوطی سے وَاٰتَيْنٰهُ : اور ہم نے اسے دی الْحُكْمَ : نبوت۔ دانائی صَبِيًّا : بچپن سے اے یحیٰی ! میری کتاب (1) کو مضبوطی سے تھام لے اور ہم نے اسے لڑکپن ہی سے دانائی عطا فرما دی (2)
19,13,وَّ حَنَانًا مِّنْ لَّدُنَّا وَ زَكٰوةً١ؕ وَ كَانَ تَقِیًّاۙ وَّحَنَانًا : اور شفقت مِّنْ لَّدُنَّا : اپنے پاس سے وَزَكٰوةً : اور پاکیزگی وَكَانَ : اور وہ تھا تَقِيًّا : پرہیزگار اور اپنے پاس سے شفقت اور پاکیزگی بھی (1) وہ پرہیزگار شخص تھا۔
19,14,وَّ بَرًّۢا بِوَالِدَیْهِ وَ لَمْ یَكُنْ جَبَّارًا عَصِیًّا وَّبَرًّۢا : اور اچھا سلوک کرنیوالا بِوَالِدَيْهِ : اپنے ماں باپ سے وَلَمْ يَكُنْ : اور نہ تھا وہ جَبَّارًا : گردن کش عَصِيًّا : نافرمان اور اپنے ماں باپ سے نیک سلوک کرنے والا تھا وہ سرکش اور گناہ گار نہ تھا (1)
19,15,وَ سَلٰمٌ عَلَیْهِ یَوْمَ وُلِدَ وَ یَوْمَ یَمُوْتُ وَ یَوْمَ یُبْعَثُ حَیًّا۠    ۧ وَسَلٰمٌ : اور سلام عَلَيْهِ : اس پر يَوْمَ : جس دن وُلِدَ : وہ پیدا ہوا وَيَوْمَ : اور جس دن يَمُوْتُ : وہ فوت ہوگا وَيَوْمَ : اور جس دن يُبْعَثُ : اٹھایا جائے گا حَيًّا : زندہ ہو کر اس پر سلام ہے جس دن وہ پیدا ہوا اور جس دن وہ مرے اور جس دن وہ زندہ کر کے اٹھایا جائے (1)۔
19,16,وَ اذْكُرْ فِی الْكِتٰبِ مَرْیَمَ١ۘ اِذِ انْتَبَذَتْ مِنْ اَهْلِهَا مَكَانًا شَرْقِیًّاۙ وَاذْكُرْ : اور ذکر کرو فِى الْكِتٰبِ : کتاب میں مَرْيَمَ : مریم اِذِ انْتَبَذَتْ : جب وہ یکسو ہوگئی مِنْ اَهْلِهَا : اپنے گھروالوں سے مَكَانًا : مکان شَرْقِيًّا : مشرقی اس کتاب میں مریم کا بھی واقعہ بیان کر۔ جبکہ وہ اپنے گھر کے لوگوں سے علیحدہ ہو کر مشرقی جانب آئیں
19,17,فَاتَّخَذَتْ مِنْ دُوْنِهِمْ حِجَابًا١۪۫ فَاَرْسَلْنَاۤ اِلَیْهَا رُوْحَنَا فَتَمَثَّلَ لَهَا بَشَرًا سَوِیًّا فَاتَّخَذَتْ : پھر ڈال لیا مِنْ : سے دُوْنِهِمْ : ان کی طرف حِجَابًا : پردہ فَاَرْسَلْنَآ : پھر ہم نے بھیجا اِلَيْهَا : اس کی طرف رُوْحَنَا : اپنی روح (فرشتہ) فَتَمَثَّلَ : شکل بن گیا لَهَا : اس کے لیے بَشَرًا : ایک آدمی سَوِيًّا : ٹھیک اور ان لوگوں کی طرف سے پردہ کرلیا (1) پھر ہم نے اس کے پاس اپنی روح (جبرائیل علیہ السلام) کو بھیجا پس وہ اس کے سامنے پورا آدمی بن کر ظاہر ہوا (2)۔
19,18,قَالَتْ اِنِّیْۤ اَعُوْذُ بِالرَّحْمٰنِ مِنْكَ اِنْ كُنْتَ تَقِیًّا قَالَتْ : وہ بولی اِنِّىْٓ : بیشک میں اَعُوْذُ : پناہ میں آتی ہوں بِالرَّحْمٰنِ : رحمن (اللہ) کی مِنْكَ : تجھ سے اِنْ كُنْتَ : اگر تو ہے تَقِيًّا : پرہیزگار یہ کہنے لگیں میں تجھ سے رحمٰن کی پناہ مانگتی ہوں اگر تو کچھ بھی اللہ سے ڈرنے والا ہے۔
19,19,قَالَ اِنَّمَاۤ اَنَا رَسُوْلُ رَبِّكِ١ۖۗ لِاَهَبَ لَكِ غُلٰمًا زَكِیًّا قَالَ : اس نے کہا اِنَّمَآ : اس کے سوا نہیں اَنَا : کہ میں رَسُوْلُ : بھیجا ہوا رَبِّكِ : تیرے رب کا لِاَهَبَ : تاکہ عطا کروں لَكِ : تجھ کو غُلٰمًا : ایک لڑکا زَكِيًّا : پاکیزہ اس نے جواب دیا کہ میں تو اللہ کا بھیجا ہوا قاصد ہوں، تجھے ایک پاکیزہ لڑکا دینے آیا ہوں۔
19,20,قَالَتْ اَنّٰى یَكُوْنُ لِیْ غُلٰمٌ وَّ لَمْ یَمْسَسْنِیْ بَشَرٌ وَّ لَمْ اَكُ بَغِیًّا قَالَتْ : وہ بولی اَنّٰى : کیسے يَكُوْنُ : ہوگا لِيْ : میرے غُلٰمٌ : لڑکا وَّ : جبکہ لَمْ يَمْسَسْنِيْ : مجھے چھوا نہیں بَشَرٌ : کسی بشر نے وَّ : اور لَمْ اَكُ : میں نہیں ہوں بَغِيًّا : بدکار کہنے لگیں بھلا میرے ہاں بچہ کیسے ہوسکتا ہے ؟ مجھے تو کسی انسان کا ہاتھ تک نہ لگا اور نہ میں بدکار ہوں۔
19,21,قَالَ كَذٰلِكِ١ۚ قَالَ رَبُّكِ هُوَ عَلَیَّ هَیِّنٌ١ۚ وَ لِنَجْعَلَهٗۤ اٰیَةً لِّلنَّاسِ وَ رَحْمَةً مِّنَّا١ۚ وَ كَانَ اَمْرًا مَّقْضِیًّا قَالَ : اس نے کہا كَذٰلِكِ : یونہی قَالَ : فرمایا رَبُّكِ : تیرا رب هُوَ : وہ یہ عَلَيَّ : مجھ پر هَيِّنٌ : آسان وَلِنَجْعَلَهٗٓ : اور تاکہ ہم اسے بنائیں اٰيَةً : ایک نشانی لِّلنَّاسِ : لوگوں کے لیے وَرَحْمَةً : اور رحمت مِّنَّا : اپنی طرف سے وَكَانَ : اور ہے اَمْرًا : ایک امر مَّقْضِيًّا : طے شدہ اس نے کہا بات تو یہی ہے، (1) لیکن تیرے پروردگار کا ارشاد ہے کہ وہ مجھ پر بہت ہی آسان ہے ہم تو اسے لوگوں کے لئے ایک نشانی بنادیں گے (2) اور اپنی خاص رحمت (3) یہ تو ایک طے شدہ بات ہے (4)۔
19,22,فَحَمَلَتْهُ فَانْتَبَذَتْ بِهٖ مَكَانًا قَصِیًّا فَحَمَلَتْهُ : پھر اسے حمل رہ گیا فَانْتَبَذَتْ : پس وہ چلی گئی بِهٖ : اسے لیکر مَكَانًا : ایک جگہ قَصِيًّا : دور پس وہ حمل سے ہوگئیں اور اسی وجہ سے وہ یکسو ہو کر ایک دور کی جگہ چلی گئیں۔
19,23,فَاَجَآءَهَا الْمَخَاضُ اِلٰى جِذْعِ النَّخْلَةِ١ۚ قَالَتْ یٰلَیْتَنِیْ مِتُّ قَبْلَ هٰذَا وَ كُنْتُ نَسْیًا مَّنْسِیًّا فَاَجَآءَهَا : پھر اسے لے آیا الْمَخَاضُ : دردِ زہ اِلٰى : طرف جِذْعِ : جڑ النَّخْلَةِ : کھجور کا درخت قَالَتْ : وہ بولی يٰلَيْتَنِيْ : اے کاش میں مِتُّ : مرچکی ہوتی قَبْلَ ھٰذَا : اس سے قبل وَكُنْتُ : اور میں ہوجاتی نَسْيًا مَّنْسِيًّا : بھولی بسری پھر درد زہ اسے ایک کھجور کے تنے کے نیچے لے آیا، بولی کاش ! میں اس سے پہلے ہی مرگئی ہوتی اور لوگوں کی یاد سے بھی بھولی بسری ہوجاتی (1)۔
19,24,فَنَادٰىهَا مِنْ تَحْتِهَاۤ اَلَّا تَحْزَنِیْ قَدْ جَعَلَ رَبُّكِ تَحْتَكِ سَرِیًّا فَنَادٰىهَا : پس اسے آواز دی مِنْ : سے تَحْتِهَآ : اس کے نیچے اَلَّا تَحْزَنِيْ : کہ نہ گھبرا تو قَدْ جَعَلَ : کردیا ہے رَبُّكِ : تیرا رب تَحْتَكِ : تیرے نیچے سَرِيًّا : ایک چشمہ اتنے میں اسے نیچے سے ہی آواز دی کہ آزردہ خاطر نہ ہو، تیرے رب نے تیرے پاؤں تلے ایک چشمہ جاری کردیا ہے
19,25,وَ هُزِّیْۤ اِلَیْكِ بِجِذْعِ النَّخْلَةِ تُسٰقِطْ عَلَیْكِ رُطَبًا جَنِیًّا٘ وَهُزِّيْٓ : اور ہلا اِلَيْكِ : اپنی طرف بِجِذْعِ : تنے کو النَّخْلَةِ : کھجور تُسٰقِطْ : جھڑ پڑیں گی عَلَيْكِ : تجھ پر رُطَبًا : تازہ تازہ جَنِيًّا : کھجوریں اور اس کھجور کے تنے کو اپنی طرف ہلا، یہ تیرے سامنے ترو تازہ پکی کھجوریں گرا دے گا (1)۔
19,26,فَكُلِیْ وَ اشْرَبِیْ وَ قَرِّیْ عَیْنًا١ۚ فَاِمَّا تَرَیِنَّ مِنَ الْبَشَرِ اَحَدًا١ۙ فَقُوْلِیْۤ اِنِّیْ نَذَرْتُ لِلرَّحْمٰنِ صَوْمًا فَلَنْ اُكَلِّمَ الْیَوْمَ اِنْسِیًّاۚ فَكُلِيْ : تو کھا وَاشْرَبِيْ : اور پی وَقَرِّيْ : اور ٹھنڈی کر عَيْنًا : آنکھیں فَاِمَّا تَرَيِنَّ : پھر اگر تو دیکھے مِنَ : سے الْبَشَرِ : آدمی اَحَدًا : کوئی فَقُوْلِيْٓ : تو کہدے اِنِّىْ نَذَرْتُ : میں نے نذر مانی ہے لِلرَّحْمٰنِ : رحمن کے لیے صَوْمًا : روزہ فَلَنْ اُكَلِّمَ : پس میں ہرگز کلام نہ کرونگی الْيَوْمَ : آج اِنْسِيًّا : کسی آدمی اب چین سے کھا پی اور آنکھیں ٹھنڈی رکھ (1) اگر تجھے کوئی انسان نظر پڑجائے تو کہہ (2) دینا کہ میں نے اللہ رحمان کے نام کا روزہ رکھا ہے۔ میں آج کسی شخص سے بات نہ کروں گی۔
19,27,فَاَتَتْ بِهٖ قَوْمَهَا تَحْمِلُهٗ١ؕ قَالُوْا یٰمَرْیَمُ لَقَدْ جِئْتِ شَیْئًا فَرِیًّا فَاَتَتْ بِهٖ : پھر وہ اسے لیکر آئی قَوْمَهَا : اپنی قوم تَحْمِلُهٗ : اسے اٹھائے ہوئے قَالُوْا : وہ بولے يٰمَرْيَمُ : اے مریم لَقَدْ جِئْتِ : تو لائی ہے شَيْئًا : شے فَرِيًّا : بری (غضب کی) اب حضرت عیسیٰ ؑ کو لئے ہوئے وہ اپنی قوم کے پاس آئیں۔ سب کہنے لگے مریم تو نے بڑی بری حرکت کی
19,28,یٰۤاُخْتَ هٰرُوْنَ مَا كَانَ اَبُوْكِ امْرَاَ سَوْءٍ وَّ مَا كَانَتْ اُمُّكِ بَغِیًّاۖۚ يٰٓاُخْتَ هٰرُوْنَ : اے ہارون کی بہن مَا : نہ كَانَ : تھا اَبُوْكِ : تیرا باپ امْرَاَ : آدمی سَوْءٍ : برا وَّ : اور مَا كَانَتْ : نہ تھی اُمُّكِ : تیری ماں بَغِيًّا : بدکار اے ہارون کی بہن ! (1) نہ تو تیرا باپ برا آدمی تھا اور نہ تیری ماں بدکار تھی
19,29,فَاَشَارَتْ اِلَیْهِ١ؕ قَالُوْا كَیْفَ نُكَلِّمُ مَنْ كَانَ فِی الْمَهْدِ صَبِیًّا فَاَشَارَتْ : تو مریم نے اشارہ کیا اِلَيْهِ : اس کی طرف قَالُوْا : وہ بولے كَيْفَ نُكَلِّمُ : کیسے ہم بات کریں مَنْ كَانَ : جو ہے فِي الْمَهْدِ : گہوارہ میں صَبِيًّا : بچہ مریم نے اپنے بچے کی طرف اشارہ کیا۔ سب کہنے لگے کہ لو بھلا ہم گود کے بچے سے باتیں کیسے کریں ؟
19,30,قَالَ اِنِّیْ عَبْدُ اللّٰهِ١ؕ۫ اٰتٰىنِیَ الْكِتٰبَ وَ جَعَلَنِیْ نَبِیًّاۙ قَالَ : بچہ نے اِنِّىْ : بیشک میں عَبْدُ اللّٰهِ : اللہ کا بندہ اٰتٰىنِيَ : اس نے مجھے دی ہے الْكِتٰبَ : کتاب وَجَعَلَنِيْ : اور مجھے بنایا ہے نَبِيًّا : نبی بچہ بول اٹھا کہ میں اللہ تعالیٰ کا بندہ ہوں۔ اس نے مجھے کتاب عطا فرمائی اور مجھے اپنا پیغمبر بنایا (1) ہے
19,31,وَّ جَعَلَنِیْ مُبٰرَكًا اَیْنَ مَا كُنْتُ١۪ وَ اَوْصٰنِیْ بِالصَّلٰوةِ وَ الزَّكٰوةِ مَا دُمْتُ حَیًّا٢۪ۖ وَّجَعَلَنِيْ : اور مجھے بنایا ہے مُبٰرَكًا : بابرکت اَيْنَ مَا : جہاں کہیں كُنْتُ : میں ہوں ‎وَاَوْصٰىنِيْ : مجھے حکم دیا ہے اس نے بِالصَّلٰوةِ : نماز کا وَالزَّكٰوةِ : اور زکوۃ کا مَا دُمْتُ : جب تک میں رہوں حَيًّا : زندہ اور اس نے مجھے بابرکت کیا ہے (1) جہاں بھی میں ہوں، اور اس نے مجھے نماز اور زکوٰۃ کا حکم دیا ہے جب تک بھی میں زندہ رہوں
19,32,وَّ بَرًّۢا بِوَالِدَتِیْ١٘ وَ لَمْ یَجْعَلْنِیْ جَبَّارًا شَقِیًّا وَّبَرًّۢا : اور اچھا سلوک کرنیوالا بِوَالِدَتِيْ : اپنی ماں سے وَ : اور لَمْ يَجْعَلْنِيْ : اس نے مجھے نہیں بنایا جَبَّارًا : سرکش شَقِيًّا : بدنصیب اور اس نے مجھے اپنی والدہ کا خدمت گزار بنایا ہے (1) اور مجھے سرکش اور بدبخت نہیں کیا (2)۔
19,33,وَ السَّلٰمُ عَلَیَّ یَوْمَ وُلِدْتُّ وَ یَوْمَ اَمُوْتُ وَ یَوْمَ اُبْعَثُ حَیًّا وَالسَّلٰمُ : اور سلامتی عَلَيَّ : مجھ پر يَوْمَ : جس دن وُلِدْتُّ : میں پیدا ہوا وَيَوْمَ : اور جس دن اَمُوْتُ : میں مروں گا وَيَوْمَ : اور جس دن اُبْعَثُ : اٹھایا جاؤں گا حَيًّا : زندہ ہوکر اور مجھ پر میری پیدائش کے دن اور میری موت کے دن اور جس دن کہ میں دوبارہ زندہ کھڑا کیا جاؤں گا، سلام ہی سلام ہے۔
19,34,ذٰلِكَ عِیْسَى ابْنُ مَرْیَمَ١ۚ قَوْلَ الْحَقِّ الَّذِیْ فِیْهِ یَمْتَرُوْنَ ذٰلِكَ : یہ عِيْسَى : عیسیٰ ابْنُ مَرْيَمَ : ابن مریم قَوْلَ : بات الْحَقِّ : سچی الَّذِيْ فِيْهِ : وہ جس میں يَمْتَرُوْنَ : وہ شک کرتے ہیں یہ ہے صحیح واقعہ عیسیٰ بن مریم ؑ کا، یہی ہے وہ حق بات جس میں لوگ شک شبہ میں مبتلا ہیں (1)
19,35,مَا كَانَ لِلّٰهِ اَنْ یَّتَّخِذَ مِنْ وَّلَدٍ١ۙ سُبْحٰنَهٗ١ؕ اِذَا قَضٰۤى اَمْرًا فَاِنَّمَا یَقُوْلُ لَهٗ كُنْ فَیَكُوْنُؕ مَا كَانَ : نہیں ہے لِلّٰهِ : اللہ کیلئے اَنْ : کہ يَّتَّخِذَ : وہ بنائے مِنْ : کوئی وَّلَدٍ : بیٹا سُبْحٰنَهٗ : وہ پاک ہے اِذَا قَضٰٓى : جب وہ فیصلہ کرتا ہے اَمْرًا : کسی کام فَاِنَّمَا : تو اس کے سوا نہیں يَقُوْلُ : وہ کہتا ہے لَهٗ : اس کو كُنْ : ہوجا فَيَكُوْنُ : پس وہ ہوجاتا ہے اللہ تعالیٰ کے لئے اولاد کا ہونا لائق نہیں، وہ بالکل پاک ذات ہے، وہ تو جب کسی کام کے سر انجام دینے کا ارادہ کرتا ہے تو اسے کہہ دیتا ہے کہ ہوجا، وہ اسی وقت ہوجاتا ہے (1)۔
19,36,وَ اِنَّ اللّٰهَ رَبِّیْ وَ رَبُّكُمْ فَاعْبُدُوْهُ١ؕ هٰذَا صِرَاطٌ مُّسْتَقِیْمٌ وَاِنَّ : اور بیشک اللّٰهَ : اللہ رَبِّيْ : میرا رب وَرَبُّكُمْ : اور تمہارا رب فَاعْبُدُوْهُ : پس اس کی عبادت کرو ھٰذَا : یہ صِرَاطٌ : راستہ مُّسْتَقِيْمٌ : سیدھا میرا اور تم سب کا پروردگار صرف اللہ تعالیٰ ہی ہے۔ تم سب اسی کی عبادت کرو، یہی سیدھی راہ ہے۔
19,37,فَاخْتَلَفَ الْاَحْزَابُ مِنْۢ بَیْنِهِمْ١ۚ فَوَیْلٌ لِّلَّذِیْنَ كَفَرُوْا مِنْ مَّشْهَدِ یَوْمٍ عَظِیْمٍ فَاخْتَلَفَ : پھر اختلاف کیا الْاَحْزَابُ : فرقے مِنْۢ بَيْنِهِمْ : آپس میں (باہم) فَوَيْلٌ : پس خرابی لِّلَّذِيْنَ كَفَرُوْا : کافروں کے لیے مِنْ : سے مَّشْهَدِ : حاضری يَوْمٍ عَظِيْمٍ : بڑا دن پھر یہ فرماتے آپس میں اختلاف کرنے لگے، (1) پس کافروں کے لئے ' ویل ' ہے ایک بڑے (سخت) دن کی حاضری سے (2)۔
19,38,اَسْمِعْ بِهِمْ وَ اَبْصِرْ١ۙ یَوْمَ یَاْتُوْنَنَا لٰكِنِ الظّٰلِمُوْنَ الْیَوْمَ فِیْ ضَلٰلٍ مُّبِیْنٍ اَسْمِعْ : سنیں گے بِهِمْ : کیا کچھ وَاَبْصِرْ : اور دیکھیں گے يَوْمَ : جس دن يَاْتُوْنَنَا : وہ ہمارے سامنے آئیں گے لٰكِنِ : لیکن الظّٰلِمُوْنَ : ظالم (جمع) الْيَوْمَ : آج کے دن فِيْ : میں ضَلٰلٍ مُّبِيْنٍ : کھلی گمراہی کیا خوب دیکھنے سننے والے ہونگے اس دن جبکہ ہمارے سامنے حاضر ہوں گے، (1) لیکن آج تو یہ ظالم لوگ صریح گمراہی میں پڑے ہوئے ہیں
19,39,وَ اَنْذِرْهُمْ یَوْمَ الْحَسْرَةِ اِذْ قُضِیَ الْاَمْرُ١ۘ وَ هُمْ فِیْ غَفْلَةٍ وَّ هُمْ لَا یُؤْمِنُوْنَ وَاَنْذِرْهُمْ : اور ان کو ڈراویں آپ يَوْمَ الْحَسْرَةِ : حسرت کا دن اِذْ : جب قُضِيَ : فیصلہ کردیاجائیگا الْاَمْرُ : کام وَهُمْ : لیکن وہ فِيْ غَفْلَةٍ : غفلت میں ہیں وَّهُمْ : اور وہ لَا يُؤْمِنُوْنَ : ایمان نہیں لاتے تو انھیں اس رنج و افسوس کے دن (1) کا ڈر سنا دے جبکہ کام انجام کو پہنچا دیا جائے گا (2) اور یہ لوگ غفلت اور بےایمانی میں ہی رہ جائیں گے۔
19,40,اِنَّا نَحْنُ نَرِثُ الْاَرْضَ وَ مَنْ عَلَیْهَا وَ اِلَیْنَا یُرْجَعُوْنَ۠ اِنَّا نَحْنُ : بیشک ہم نَرِثُ : وارث ہونگے الْاَرْضَ : زمین وَمَنْ : اور جو عَلَيْهَا : اس پر وَاِلَيْنَا : اور ہماری طرف يُرْجَعُوْنَ : وہ لوٹائے جائیں گے خود زمین کے اور تمام زمین والوں کے وارث ہم ہی ہونگے اور سب لوگ ہماری ہی طرف لوٹا کر لائے جائیں گے۔
19,41,وَ اذْكُرْ فِی الْكِتٰبِ اِبْرٰهِیْمَ١ؕ۬ اِنَّهٗ كَانَ صِدِّیْقًا نَّبِیًّا    ۧ وَاذْكُرْ : اور یاد کرو فِي الْكِتٰبِ : کتاب میں اِبْرٰهِيْمَ : ابراہیم اِنَّهٗ كَانَ : بیشک وہ تھے صِدِّيْقًا : سچے نَّبِيًّا : نبی اس کتاب میں ابراہیم ؑ کا قصہ بیان کر، بیشک وہ بڑی سچائی والے پیغمبر تھے (1)۔
19,42,اِذْ قَالَ لِاَبِیْهِ یٰۤاَبَتِ لِمَ تَعْبُدُ مَا لَا یَسْمَعُ وَ لَا یُبْصِرُ وَ لَا یُغْنِیْ عَنْكَ شَیْئًا اِذْ قَالَ : جب اس نے کہا لِاَبِيْهِ : اپنے باپ کو يٰٓاَبَتِ : اے میرے ابا لِمَ تَعْبُدُ : تم کیوں پرستش کرتے ہو مَا لَا يَسْمَعُ : جو نہ سنے وَلَا يُبْصِرُ : اور نہ دیکھے وَلَا يُغْنِيْ : اور نہ کام آئے عَنْكَ : تمہارے شَيْئًا : کچھ جب کہ انہوں نے اپنے باپ سے کہا کہ ابا جان ! آپ ان کی پوجا پاٹ کیوں کر رہے ہیں جو نہ سنیں نہ دیکھیں ؟ نہ آپ کو کچھ بھی فائدہ پہنچا سکیں۔
19,43,یٰۤاَبَتِ اِنِّیْ قَدْ جَآءَنِیْ مِنَ الْعِلْمِ مَا لَمْ یَاْتِكَ فَاتَّبِعْنِیْۤ اَهْدِكَ صِرَاطًا سَوِیًّا يٰٓاَبَتِ : اے میرے ابا اِنِّىْ : بیشک میں قَدْ جَآءَنِيْ : بیشک میرے پاس آیا ہے مِنَ الْعِلْمِ : وہ علم مَا : جو لَمْ يَاْتِكَ : تمہارے پاس نہیں آیا فَاتَّبِعْنِيْٓ : پس میری بات مانو اَهْدِكَ : میں تمہیں دکھاؤں گا صِرَاطًا : راستہ سَوِيًّا : سیدھا میرے مہربان باپ ! آپ دیکھیے میرے پاس وہ علم آیا ہے جو آپ کے پاس آیا ہی نہیں، (1) تو آپ میری ہی مانیں میں بالکل سیدھی راہ کی طرف آپ کی رہبری کروں گا (2)۔
19,44,یٰۤاَبَتِ لَا تَعْبُدِ الشَّیْطٰنَ١ؕ اِنَّ الشَّیْطٰنَ كَانَ لِلرَّحْمٰنِ عَصِیًّا يٰٓاَبَتِ : اے میرے ابا لَا تَعْبُدِ : پرستش نہ کر الشَّيْطٰنَ : شیطان اِنَّ : بشیک الشَّيْطٰنَ : شیطان كَانَ : ہے لِلرَّحْمٰنِ : رحمن کا عَصِيًّا : نافرمان میرے ابا جان آپ شیطان کی پرستش سے باز آجائیں شیطان تو رحم و کرم والے اللہ تعالیٰ کا بڑا ہی نافرمان ہے (1)۔
19,45,یٰۤاَبَتِ اِنِّیْۤ اَخَافُ اَنْ یَّمَسَّكَ عَذَابٌ مِّنَ الرَّحْمٰنِ فَتَكُوْنَ لِلشَّیْطٰنِ وَلِیًّا يٰٓاَبَتِ : اے میرے ابا اِنِّىْٓ : بیشک میں اَخَافُ : ڈرتا ہوں اَنْ : کہ يَّمَسَّكَ : تجھے آپکڑے عَذَابٌ : عذاب مِّنَ : سے۔ کا الرَّحْمٰنِ : رحمن فَتَكُوْنَ : پھر تو ہوجائے لِلشَّيْطٰنِ : شیطان کا وَلِيًّا : ساتھی ابا جان ! مجھے خوف لگا ہوا ہے کہ کہیں آپ پر کوئی عذاب الٰہی نہ آپڑے کہ آپ شیطان کے ساتھی بن جائیں (1)
19,46,قَالَ اَرَاغِبٌ اَنْتَ عَنْ اٰلِهَتِیْ یٰۤاِبْرٰهِیْمُ١ۚ لَئِنْ لَّمْ تَنْتَهِ لَاَرْجُمَنَّكَ وَ اهْجُرْنِیْ مَلِیًّا قَالَ : اس نے کہا اَ رَاغِبٌ : کیا روگرداں اَنْتَ : تو عَنْ : سے اٰلِهَتِيْ : میرے معبود (جمع) يٰٓاِبْرٰهِيْمُ : اے ابراہیم لَئِنْ : اگر لَّمْ تَنْتَهِ : تو باز نہ آیا لَاَرْجُمَنَّكَ : تو میں تجھے ضرور سنگسار کروں گا وَاهْجُرْنِيْ : اور مجھے چھوڑ دے مَلِيًّا : ایک مدت کے لیے اس نے جواب دیا کہ اے ابراہیم ! کیا تو ہمارے معبودوں سے روگردانی کر رہا ہے۔ سن اگر تو باز نہ آیا تو میں تجھے پتھروں سے مار ڈالوں گا، جا ایک مدت دراز تک مجھ سے الگ رہ (1)۔
19,47,قَالَ سَلٰمٌ عَلَیْكَ١ۚ سَاَسْتَغْفِرُ لَكَ رَبِّیْ١ؕ اِنَّهٗ كَانَ بِیْ حَفِیًّا قَالَ : اس نے کہا سَلٰمٌ : سلام عَلَيْكَ : تجھ پر سَاَسْتَغْفِرُ : میں ابھی بخشش مانگوں گا لَكَ : تیرے لیے رَبِّيْ : اپنا رب اِنَّهٗ : بیشک وہ كَانَ : ہے بِيْ : مجھ پر حَفِيًّا : مہربان کہا اچھا تم پر سلام ہو (1) میں تو اپنے پروردگار سے تمہاری بخشش کی دعا کرتا رہوں گا (2) وہ مجھ پر حد درجہ مہربان ہے۔
19,48,وَ اَعْتَزِلُكُمْ وَ مَا تَدْعُوْنَ مِنْ دُوْنِ اللّٰهِ وَ اَدْعُوْا رَبِّیْ١ۖ٘ عَسٰۤى اَلَّاۤ اَكُوْنَ بِدُعَآءِ رَبِّیْ شَقِیًّا وَاَعْتَزِلُكُمْ : اور کنارہ کشی کرتا ہوں تم سے وَمَا : اور جو تَدْعُوْنَ : تم پرستش کرتے ہو مِنْ دُوْنِ : سوائے اللّٰهِ : اللہ وَاَدْعُوْا : اور میں عبادت کروں گا رَبِّيْ : اپنا رب عَسٰٓى : امید ہے اَلَّآ اَكُوْنَ : کہ نہ رہوں گا بِدُعَآءِ : عبادت سے رَبِّيْ : اپنا رب شَقِيًّا : محروم میں تو تمہیں بھی اور جن جن کو تم اللہ تعالیٰ کے سوا پکارتے ہو انھیں بھی سب کو چھوڑ رہا ہوں۔ صرف اپنے پروردگار کو پکارتا رہوں گا، مجھے یقین ہے کہ میں اپنے پروردگار سے دعا مانگ کر محروم نہ رہوں گا۔
19,49,فَلَمَّا اعْتَزَلَهُمْ وَ مَا یَعْبُدُوْنَ مِنْ دُوْنِ اللّٰهِ١ۙ وَهَبْنَا لَهٗۤ اِسْحٰقَ وَ یَعْقُوْبَ١ؕ وَ كُلًّا جَعَلْنَا نَبِیًّا فَلَمَّا : پھر جب اعْتَزَلَهُمْ : وہ کنارہ کش ہوگئے ان سے وَمَا : اور جو يَعْبُدُوْنَ : وہ پرستش کرتے تھے مِنْ دُوْنِ : سوائے اللّٰهِ : اللہ وَهَبْنَا : ہم نے عطا کیا لَهٗٓ : اس کو اِسْحٰقَ : اسحق وَيَعْقُوْبَ : اور یعقوب وَكُلًّا : اور سب کو جَعَلْنَا : ہم نے بنایا نَبِيًّا : نبی جب ابراہیم ؑ ان سب کو اور اللہ کے سوا ان کے سب معبودوں کو چھوڑ چکے تو ہم نے انھیں اسحاق و یعقوب (علیہما السلام) عطا فرمائے، (1) اور دونوں کو نبی بنادیا۔
19,50,وَ وَهَبْنَا لَهُمْ مِّنْ رَّحْمَتِنَا وَ جَعَلْنَا لَهُمْ لِسَانَ صِدْقٍ عَلِیًّا۠    ۧ وَوَهَبْنَا : اور ہم نے عطا کیا لَهُمْ : انہیں مِّنْ : سے رَّحْمَتِنَا : اپنی رحمت وَجَعَلْنَا : اور ہم نے کیا لَهُمْ : ان کا لِسَانَ : ذکر صِدْقٍ : سچا۔ جمیل عَلِيًّا : نہایت بلند اور ان سب کو ہم نے اپنی بہت سی رحمتیں (1) عطا فرمائیں اور ہم نے ان کے ذکر جمیل کو بلند درجے کا کردیا (2)۔
19,51,وَ اذْكُرْ فِی الْكِتٰبِ مُوْسٰۤى١٘ اِنَّهٗ كَانَ مُخْلَصًا وَّ كَانَ رَسُوْلًا نَّبِیًّا وَاذْكُرْ : اور یاد کرو فِي الْكِتٰبِ : کتاب میں مُوْسٰٓى : موسیٰ اِنَّهٗ : بیشک وہ كَانَ : تھا مُخْلَصًا : برگزیدہ وَّكَانَ : اور تھا رَسُوْلًا : رسول نَّبِيًّا : نبی اس قرآن میں موسیٰ ؑ کا ذکر، جو چنا ہوا (1) اور رسول اور نبی تھا
19,52,وَ نَادَیْنٰهُ مِنْ جَانِبِ الطُّوْرِ الْاَیْمَنِ وَ قَرَّبْنٰهُ نَجِیًّا وَنَادَيْنٰهُ : اور ہم نے اسے پکارا مِنْ : سے جَانِبِ : جانب الطُّوْرِ : کوہ طور الْاَيْمَنِ : داہنی وَقَرَّبْنٰهُ : اور اسے نزدیک بلایا نَجِيًّا : راز بتانے کو ہم نے اسے طور کی دائیں جانب سے آواز کی اور راز گوئی کرتے ہوئے اسے قریب کرلیا۔
19,53,وَ وَهَبْنَا لَهٗ مِنْ رَّحْمَتِنَاۤ اَخَاهُ هٰرُوْنَ نَبِیًّا وَوَهَبْنَا : اور ہم نے عطا کیا لَهٗ : اسے مِنْ رَّحْمَتِنَآ : اپنی رحمت سے اَخَاهُ : اس کا بھائی هٰرُوْنَ : ہارون نَبِيًّا : نبی اور اپنی خاص مہربانی سے اس کے بھائی کو نبی بنا کر عطا فرمایا
19,54,وَ اذْكُرْ فِی الْكِتٰبِ اِسْمٰعِیْلَ١٘ اِنَّهٗ كَانَ صَادِقَ الْوَعْدِ وَ كَانَ رَسُوْلًا نَّبِیًّاۚ وَاذْكُرْ : اور یاد کرو فِي الْكِتٰبِ : کتاب میں اِسْمٰعِيْلَ : اسمعیل اِنَّهٗ : بیشک وہ كَانَ : تھے صَادِقَ الْوَعْدِ : وعدہ کا سچا وَكَانَ : اور تھے رَسُوْلًا : رسول نَّبِيًّا : نبی اس کتاب میں اسماعیل ؑ کا واقعہ بھی بیان کر، وہ بڑا ہی وعدے کا سچا تھا اور تھا بھی رسول اور نبی۔
19,55,وَ كَانَ یَاْمُرُ اَهْلَهٗ بِالصَّلٰوةِ وَ الزَّكٰوةِ١۪ وَ كَانَ عِنْدَ رَبِّهٖ مَرْضِیًّا وَكَانَ يَاْمُرُ : اور حکم دیتے تھے اَهْلَهٗ : اپنے گھروالے بِالصَّلٰوةِ : نماز کا وَالزَّكٰوةِ : اور زکوۃ وَكَانَ : اور وہ تھے عِنْدَ رَبِّهٖ : اپنے رب کے ہاں مَرْضِيًّا : پسندیدہ وہ اپنے گھر والوں کو برابر نماز اور زکوٰۃ کا حکم دیتا تھا، اور تھا بھی اپنے پروردگار کی بارگاہ میں پسندیدہ اور مقبول۔
19,56,وَ اذْكُرْ فِی الْكِتٰبِ اِدْرِیْسَ١٘ اِنَّهٗ كَانَ صِدِّیْقًا نَّبِیًّاۗۙ وَاذْكُرْ : اور یاد کرو فِي الْكِتٰبِ : کتاب میں اِدْرِيْسَ : ادریس اِنَّهٗ : بیشک وہ كَانَ : تھے صِدِّيْقًا : سچے نَّبِيًّا : نبی اور اس کتاب میں ادریس ؑ کا بھی ذکر کر، وہ بھی نیک کردار پیغمبر تھا۔
19,57,وَّ رَفَعْنٰهُ مَكَانًا عَلِیًّا وَّرَفَعْنٰهُ : اور ہم نے اسے اٹھا لیا مَكَانًا : ایک مقام عَلِيًّا : بلند ہم نے اسے بلند مقام پر اٹھا لیا (1)
19,58,اُولٰٓئِكَ الَّذِیْنَ اَنْعَمَ اللّٰهُ عَلَیْهِمْ مِّنَ النَّبِیّٖنَ مِنْ ذُرِّیَّةِ اٰدَمَ١ۗ وَ مِمَّنْ حَمَلْنَا مَعَ نُوْحٍ١٘ وَّ مِنْ ذُرِّیَّةِ اِبْرٰهِیْمَ وَ اِسْرَآءِیْلَ١٘ وَ مِمَّنْ هَدَیْنَا وَ اجْتَبَیْنَا١ؕ اِذَا تُتْلٰى عَلَیْهِمْ اٰیٰتُ الرَّحْمٰنِ خَرُّوْا سُجَّدًا وَّ بُكِیًّا۩  ۞ اُولٰٓئِكَ : یہ وہ لوگ الَّذِيْنَ : وہ جنہیں اَنْعَمَ اللّٰهُ : اللہ نے انعام کیا عَلَيْهِمْ : ان پر مِّنَ : سے النَّبِيّٖنَ : نبی (جمع) مِنْ : سے ذُرِّيَّةِ اٰدَمَ : اولاد آدم وَمِمَّنْ : اور ان سے جنہیں حَمَلْنَا : سوار کیا ہم نے مَعَ : ساتھ نُوْحٍ : نوح وَّ : اور مِنْ : سے ذُرِّيَّةِ : اولاد اِبْرٰهِيْمَ : ابراہیم وَاِسْرَآءِيْلَ : اور یعقوب وَمِمَّنْ : اور ان سے جنہیں هَدَيْنَا : ہم نے ہدایت دی وَاجْتَبَيْنَا : اور ہم نے چنا اِذَا تُتْلٰى : جب پڑھی جاتیں عَلَيْهِمْ : ان پر اٰيٰتُ الرَّحْمٰنِ : رحمن کی آیتیں خَرُّوْا : وہ گرپڑتے سُجَّدًا : سجدہ کرتے ہوئے وَّبُكِيًّا : اور روتے ہوئے یہی وہ انبیاء ہیں جن پر اللہ تعالیٰ نے فضل و کرم کیا جو اولاد آدم میں سے ہیں اور ان لوگوں کی نسل سے ہیں جنہیں ہم نے نوح ؑ کے ساتھ کشتی میں چڑھا لیا تھا، اور اولاد ابراہیم و یعقوب سے اور ہماری طرف سے راہ یافتہ اور ہمارے پسندیدہ لوگوں میں سے۔ ان کے سامنے جب اللہ رحمان کی آیتوں کی تلاوت کی جاتی تھی یہ سجدہ کرتے روتے گڑ گڑاتے گرپڑتے تھے (1)۔
19,59,فَخَلَفَ مِنْۢ بَعْدِهِمْ خَلْفٌ اَضَاعُوا الصَّلٰوةَ وَ اتَّبَعُوا الشَّهَوٰتِ فَسَوْفَ یَلْقَوْنَ غَیًّاۙ فَخَلَفَ : پھر جانشین ہوئے مِنْۢ بَعْدِهِمْ : ان کے بعد خَلْفٌ : چند جانشین (ناخلف) اَضَاعُوا : انہوں نے گنوادی الصَّلٰوةَ : نماز وَاتَّبَعُوا : اور پیروی کی الشَّهَوٰتِ : خواہشات فَسَوْفَ : پس عنقریب يَلْقَوْنَ : انہیں ملے گی غَيًّا : گمراہی پھر ان کے بعد ایسے اطاعت نہ کرنے والے پیدا ہوئے کہ انہوں نے نماز ضائع کردی اور نفسانی خواہشوں کے پیچھے پڑگئے، سو ان کا نقصان ان کے آگے آئے گا (1)
19,60,اِلَّا مَنْ تَابَ وَ اٰمَنَ وَ عَمِلَ صَالِحًا فَاُولٰٓئِكَ یَدْخُلُوْنَ الْجَنَّةَ وَ لَا یُظْلَمُوْنَ شَیْئًاۙ اِلَّا : مگر مَنْ : جو۔ جس تَابَ : توبہ کی وَاٰمَنَ : وہ ایمان لایا وَعَمِلَ : اور عمل کیے صَالِحًا : نیک فَاُولٰٓئِكَ : پس یہی لوگ يَدْخُلُوْنَ : وہ داخل ہوں گے الْجَنَّةَ : جنت وَلَا يُظْلَمُوْنَ : اور ان کا نہ نقصان کیا جائیگا شَيْئًا : کچھ۔ ذرا بجز ان کے جو توبہ کرلیں اور ایمان لائیں اور نیک عمل کریں۔ ایسے لوگ جنت میں جائیں گے اور ان کی ذرا سی بھی حق تلفی نہ کی جائے گی (1)
19,61,جَنّٰتِ عَدْنِ اِ۟لَّتِیْ وَعَدَ الرَّحْمٰنُ عِبَادَهٗ بِالْغَیْبِ١ؕ اِنَّهٗ كَانَ وَعْدُهٗ مَاْتِیًّا جَنّٰتِ عَدْنِ : ہمیشگی کے باغات الَّتِيْ : وہ جو وَعَدَ : وعدہ کیا الرَّحْمٰنُ : رحمن عِبَادَهٗ : اپنے بندے (جمع) بِالْغَيْبِ : غائبانہ اِنَّهٗ : بیشک وہ كَانَ : ہے وَعْدُهٗ : اس کا وعدہ مَاْتِيًّا : آنے والا ہمیشگی والی جنتوں میں جن کا غائبانہ وعدہ (1) اللہ مہربان نے اپنے بندوں سے کیا ہے۔ بیشک اس کا وعدہ پورا ہونے والا ہی ہے۔
19,62,لَا یَسْمَعُوْنَ فِیْهَا لَغْوًا اِلَّا سَلٰمًا١ؕ وَ لَهُمْ رِزْقُهُمْ فِیْهَا بُكْرَةً وَّ عَشِیًّا لَا يَسْمَعُوْنَ : وہ نہ سنیں گے فِيْهَا : اس میں لَغْوًا : بےہودہ اِلَّا سَلٰمًا : سوائے سلام وَلَهُمْ : اور ان کے لیے رِزْقُهُمْ : ان کا رزق فِيْهَا : اس میں بُكْرَةً : صبح وَّعَشِيًّا : اور شام وہ لوگ وہاں کوئی لغو بات نہ سنیں گے صرف سلام ہی سلام سنیں (1) گے، ان کے لئے وہاں صبح شام ان کا رزق ہوگا (2)۔
19,63,تِلْكَ الْجَنَّةُ الَّتِیْ نُوْرِثُ مِنْ عِبَادِنَا مَنْ كَانَ تَقِیًّا تِلْكَ : یہ الْجَنَّةُ : جنت الَّتِيْ : وہ جو کہ نُوْرِثُ : ہم وارث بنائینگے مِنْ : سے ۔ کو عِبَادِنَا : اپنے بندے مَنْ : جو كَانَ : ہوں گے تَقِيًّا : پرہیزگار یہ ہے وہ جنت جس کا وارث ہم اپنے بندوں میں سے انھیں بناتے ہیں جو متقی ہوں۔
19,64,وَ مَا نَتَنَزَّلُ اِلَّا بِاَمْرِ رَبِّكَ١ۚ لَهٗ مَا بَیْنَ اَیْدِیْنَا وَ مَا خَلْفَنَا وَ مَا بَیْنَ ذٰلِكَ١ۚ وَ مَا كَانَ رَبُّكَ نَسِیًّاۚ وَمَا : اور ہم نَتَنَزَّلُ : نہیں اترتے اِلَّا : مگر بِاَمْرِ : حکم سے رَبِّكَ : تمہارا رب لَهٗ : اس کے لیے مَا بَيْنَ اَيْدِيْنَا : جو ہمارے ہاتھوں میں ( آگے) وَمَا : اور جو خَلْفَنَا : ہمارے پیچھے وَمَا : اور جو بَيْنَ ذٰلِكَ : اس کے درمیان وَمَا : اور نہیں كَانَ : ہے رَبُّكَ : تمہارا رب نَسِيًّا : بھولنے والا ہم بغیر تیرے رب کے حکم کے اتر نہیں سکتے (1) ہمارے آگے پیچھے اور ان کے درمیان کی کل چیزیں اس کی ملکیت میں ہیں، تیرا پروردگار بھولنے والا نہیں۔
19,65,رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا فَاعْبُدْهُ وَ اصْطَبِرْ لِعِبَادَتِهٖ١ؕ هَلْ تَعْلَمُ لَهٗ سَمِیًّا۠    ۧ رَبُّ السَّمٰوٰتِ : آسمانوں کا رب وَالْاَرْضِ : اور زمین وَمَا : اور جو بَيْنَهُمَا : ان کے درمیان فَاعْبُدْهُ : پس اس کی عبادت کرو وَاصْطَبِرْ : اور ثابت قدم رہو لِعِبَادَتِهٖ : اس کی عبادت پر هَلْ : کیا تَعْلَمُ : تو جانتا ہے لَهٗ : اس کا سَمِيًّا : ہم نام کوئی آسمانوں کا، زمین کا اور جو کچھ ان کے درمیان ہے سب کا رب وہی ہے تو اسی کی بندگی کر اور اس کی عبادت پر جم جا۔ کیا تیرے علم میں اس کا ہم نام ہم پلہ کوئی اور بھی ہے ؟ (1)
19,66,وَ یَقُوْلُ الْاِنْسَانُ ءَاِذَا مَا مِتُّ لَسَوْفَ اُخْرَجُ حَیًّا وَيَقُوْلُ : اور کہتا ہے الْاِنْسَانُ : انسان ءَ اِذَا : کیا جب مَا مِتُّ : میں مرگیا لَسَوْفَ : تو پھر اُخْرَجُ : میں نکالا جاؤں گا حَيًّا : زندہ انسان کہتا (1) ہے کہ جب میں مر جاؤنگا تو کیا پھر زندہ کر کے نکالا جاؤنگا (2)۔
19,67,اَوَ لَا یَذْكُرُ الْاِنْسَانُ اَنَّا خَلَقْنٰهُ مِنْ قَبْلُ وَ لَمْ یَكُ شَیْئًا اَوَ : کیا لَا يَذْكُرُ : یاد نہیں کرتا الْاِنْسَانُ : انسان اَنَّا : بیشک ہم خَلَقْنٰهُ : ہم نے اسے پیدا کیا مِنْ قَبْلُ : اس سے قبل وَلَمْ يَكُ : جبکہ وہ نہ تھا شَيْئًا : کچھ بھی کیا یہ انسان اتنا بھی یاد نہیں رکھتا کہ ہم نے اسے اس سے پہلے پیدا کیا حالانکہ وہ کچھ بھی نہ تھا (1)۔
19,68,فَوَرَبِّكَ لَنَحْشُرَنَّهُمْ وَ الشَّیٰطِیْنَ ثُمَّ لَنُحْضِرَنَّهُمْ حَوْلَ جَهَنَّمَ جِثِیًّاۚ فَوَرَبِّكَ : سو تمہارے رب کی قسم لَنَحْشُرَنَّهُمْ : ہم انہیں ضرور جمع کریں گے وَالشَّيٰطِيْنَ : اور شیطان (جمع) ثُمَّ : پھر لَنُحْضِرَنَّهُمْ : ہم انہیں ضرور حاضر کرلیں گے حَوْلَ : ارد گرد جَهَنَّمَ : جہنم جِثِيًّا : گھٹنوں کے بل گرے ہوئے تیرے پروردگار کی قسم ! ہم انھیں اور شیطانوں کو جمع کر کے ضرور ضرور جہنم کے ارد گرد گھٹنوں کے بل گرے ہوئے حاضر کردیں گے (1)
19,69,ثُمَّ لَنَنْزِعَنَّ مِنْ كُلِّ شِیْعَةٍ اَیُّهُمْ اَشَدُّ عَلَى الرَّحْمٰنِ عِتِیًّاۚ ثُمَّ : پھر لَنَنْزِعَنَّ : ضرور کھینچ نکالیں گے مِنْ : سے كُلِّ : ہر شِيْعَةٍ : گروہ اَيُّهُمْ : جو ان میں سے اَشَدُّ : بہت زیادہ عَلَي الرَّحْمٰنِ : اللہ رحمن سے عِتِيًّا : سرکشی کرنے والا ہم ہر ہر گروہ سے انھیں الگ نکال کھڑا کریں گے جو اللہ رحمٰن سے بہت اکڑے اکڑے پھرتے تھے (1)
19,70,ثُمَّ لَنَحْنُ اَعْلَمُ بِالَّذِیْنَ هُمْ اَوْلٰى بِهَا صِلِیًّا ثُمَّ : پھر لَنَحْنُ : البتہ اَعْلَمُ : خوب واقف بِالَّذِيْنَ : ان سے جو هُمْ : وہ اَوْلٰى بِهَا : زیادہ مستحق اس میں صِلِيًّا : داخل ہونا پھر ہم انھیں بھی خوب جانتے ہیں جو جہنم کے داخلے کے زیادہ سزاوار ہیں (1)۔
19,71,وَ اِنْ مِّنْكُمْ اِلَّا وَارِدُهَا١ۚ كَانَ عَلٰى رَبِّكَ حَتْمًا مَّقْضِیًّاۚ وَاِنْ : اور نہیں مِّنْكُمْ : تم میں سے اِلَّا : مگر وَارِدُهَا : یہاں سے گزرنا ہوگا كَانَ : ہے عَلٰي : پر رَبِّكَ : تمہارا رب حَتْمًا : لازم مَّقْضِيًّا : مقرر کیا ہوا تم میں سے ہر ایک وہاں ضرور وارد ہونے والا ہے، یہ تیرے پروردگار کے ذمے قطعی، طے شدہ امر ہے۔
19,72,ثُمَّ نُنَجِّی الَّذِیْنَ اتَّقَوْا وَّ نَذَرُ الظّٰلِمِیْنَ فِیْهَا جِثِیًّا ثُمَّ : پھر نُنَجِّي : ہم نجات دینگے الَّذِيْنَ اتَّقَوْا : وہ جنہوں نے پرہیزگاری کی وَّنَذَرُ : اور ہم چھوڑ دینگے الظّٰلِمِيْنَ : ظالم (جمع) فِيْهَا : اس میں جِثِيًّا : گھٹنوں کے بل گرے ہوئے پھر ہم پرہیزگاروں کو تو بچا لیں گے اور نافرمانوں کو اسی میں گھٹنوں کے بل گرا ہوا چھوڑ دیں گے (1)۔
19,73,وَ اِذَا تُتْلٰى عَلَیْهِمْ اٰیٰتُنَا بَیِّنٰتٍ قَالَ الَّذِیْنَ كَفَرُوْا لِلَّذِیْنَ اٰمَنُوْۤا١ۙ اَیُّ الْفَرِیْقَیْنِ خَیْرٌ مَّقَامًا وَّ اَحْسَنُ نَدِیًّا وَاِذَا : اور جب تُتْلٰى : پڑھی جاتی ہیں عَلَيْهِمْ : ان پر اٰيٰتُنَا : ہماری آیتیں بَيِّنٰتٍ : واضح قَالَ : کہتے ہیں الَّذِيْنَ : وہ جنہوں نے كَفَرُوْا : کفر کیا لِلَّذِيْنَ : ان سے جو اٰمَنُوْٓا : وہ ایمان لائے اَيُّ : کون سا الْفَرِيْقَيْنِ : دونوں فریق خَيْرٌ مَّقَامًا : بہتر مقام وَّاَحْسَنُ : اور اچھی نَدِيًّا : مجلس جب ان کے سامنے ہماری روشن آیتیں تلاوت کی جاتی ہیں تو کافر مسلمانوں سے کہتے ہیں بتاؤ ہم تم دونوں جماعتوں میں سے کس کا مرتبہ زیادہ ہے ؟ اور کس کی مجلس شاندار ہے (1)۔
19,74,وَ كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنْ قَرْنٍ هُمْ اَحْسَنُ اَثَاثًا وَّ رِءْیًا وَكَمْ : اور کتنے ہی اَهْلَكْنَا : ہم ہلاک کرچکے قَبْلَهُمْ : ان سے پہلے مِّنْ قَرْنٍ : گروہوں میں سے هُمْ : وہ اَحْسَنُ : بہت اچھے اَثَاثًا : سامان وَّرِءْيًا : اور نمود ہم تو ان سے پہلے بہت سی جماعتوں کو غارت کرچکے ہیں جو سازو سامان اور نام و نمود میں (1) ان سے بڑھ چڑھ کر تھیں
19,75,قُلْ مَنْ كَانَ فِی الضَّلٰلَةِ فَلْیَمْدُدْ لَهُ الرَّحْمٰنُ مَدًّا١ۚ۬ حَتّٰۤى اِذَا رَاَوْا مَا یُوْعَدُوْنَ اِمَّا الْعَذَابَ وَ اِمَّا السَّاعَةَ١ؕ فَسَیَعْلَمُوْنَ مَنْ هُوَ شَرٌّ مَّكَانًا وَّ اَضْعَفُ جُنْدًا قُلْ : کہہ دیجئے مَنْ كَانَ : جو ہے فِي الضَّلٰلَةِ : گمراہی میں فَلْيَمْدُدْ : تو ڈھیل دے رہا ہے لَهُ : اس کو الرَّحْمٰنُ : اللہ مَدًّا : خوب ڈھیل حَتّٰٓي : یہاں تک کہ اِذَا : جب رَاَوْا : وہ دیکھیں گے مَا يُوْعَدُوْنَ : جس کا وعدہ کیا جاتا ہے اِمَّا : خواہ الْعَذَابَ : عذاب وَاِمَّا : اور خواہ السَّاعَةَ : قیامت فَسَيَعْلَمُوْنَ : پس اب وہ جان لیں گے مَنْ : کون هُوَ : وہ شَرٌّ مَّكَانًا : بدتر مقام وَّاَضْعَفُ : اور کمزور تر جُنْدًا : لشکر کہہ دیجئے ! جو گمراہی میں ہوتا ہے اللہ رحمٰن اس کو خوب لمبی مہلت دیتا ہے، یہاں تک کہ وہ ان چیزوں کو دیکھ لیں جن کا وعدہ کیے جاتے ہیں یعنی عذاب یا قیامت کو، اس وقت ان کو صحیح طور پر معلوم ہوجائے گا کہ کون برے مرتبے والا اور کس کا گروہ کمزور ہے (1)۔
19,76,وَ یَزِیْدُ اللّٰهُ الَّذِیْنَ اهْتَدَوْا هُدًى١ؕ وَ الْبٰقِیٰتُ الصّٰلِحٰتُ خَیْرٌ عِنْدَ رَبِّكَ ثَوَابًا وَّ خَیْرٌ مَّرَدًّا وَيَزِيْدُ : اور زیادہ دیتا ہے اللّٰهُ : اللہ الَّذِيْنَ اهْتَدَوْا : جن لوگوں نے ہدایت حاصل کی هُدًى : ہدایت وَالْبٰقِيٰتُ : اور باقی رہنے والی الصّٰلِحٰتُ : نیکیاں خَيْرٌ : بہتر عِنْدَ رَبِّكَ : تمہارے رب کے نزدیک ثَوَابًا : باعتبار ثواب وَّخَيْرٌ : اور بہتر مَّرَدًّا : باعتبار انجام اور ہدایت یافتہ لوگوں کو اللہ تعالیٰ ہدایت میں بڑھاتا ہے (1) اور باقی رہنے والی نیکیاں تیرے رب کے نزدیک ثواب کے لحاظ سے اور انجام کے لحاظ سے بہت ہی بہتر ہیں (2)۔
19,77,اَفَرَءَیْتَ الَّذِیْ كَفَرَ بِاٰیٰتِنَا وَ قَالَ لَاُوْتَیَنَّ مَالًا وَّ وَلَدًاؕ اَفَرَءَيْتَ : پس کیا تونے دیکھا الَّذِيْ : وہ جس نے كَفَرَ : انکار کیا بِاٰيٰتِنَا : ہمارے حکموں کا وَقَالَ : اور اس نے کہا لَاُوْتَيَنَّ : میں ضرور دیا جاؤں گا مَالًا : مال وَّوَلَدًا : اور اولاد کیا تو نے اسے بھی دیکھا جس نے ہماری آیتوں سے کفر کیا اور کہا کہ مجھے تو مال و اولاد ضرور ہی دی جائے گی۔
19,78,اَطَّلَعَ الْغَیْبَ اَمِ اتَّخَذَ عِنْدَ الرَّحْمٰنِ عَهْدًاۙ اَطَّلَعَ : کیا وہ مطلع ہوگیا ہے الْغَيْبَ : غیب اَمِ : یا اتَّخَذَ : اس نے لے لیا عِنْدَ الرَّحْمٰنِ : اللہ رحمن سے عَهْدًا : کوئی عہد کیا وہ غیب پر مطلع ہے یا اللہ کا کوئی وعدہ لے چکا ہے ؟
19,79,كَلَّا١ؕ سَنَكْتُبُ مَا یَقُوْلُ وَ نَمُدُّ لَهٗ مِنَ الْعَذَابِ مَدًّاۙ كَلَّا : ہرگز نہیں سَنَكْتُبُ : اب ہم لکھ لیں گے مَا يَقُوْلُ : وہ جو کہتا ہے وَنَمُدُّ : اور ہم بڑھا دینگے لَهٗ : اس کو مِنَ الْعَذَابِ : عذاب سے مَدًّا : اور لمبا ہرگز نہیں، یہ جو بھی کہہ رہا ہے ہم ضرور لکھ لیں گے، اور اس کے لئے عذاب بڑھائے چلے جائیں گے۔
19,80,وَّ نَرِثُهٗ مَا یَقُوْلُ وَ یَاْتِیْنَا فَرْدًا وَّنَرِثُهٗ : اور ہم وارث ہوں گے مَا يَقُوْلُ : جو وہ کہتا ہے وَيَاْتِيْنَا : اور وہ ہمارے پاس آئیگا فَرْدًا : اکیلا یہ جن چیزوں کو کہہ رہا ہے اسے ہم اس کے بعد لے لیں گے۔ اور یہ تو بالکل اکیلا ہی ہمارے سامنے حاضر ہوگا (1)۔
19,81,وَ اتَّخَذُوْا مِنْ دُوْنِ اللّٰهِ اٰلِهَةً لِّیَكُوْنُوْا لَهُمْ عِزًّاۙ وَاتَّخَذُوْا : اور انہوں نے بنالیا مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا اٰلِهَةً : معبود لِّيَكُوْنُوْا : تاکہ وہ ہوں لَهُمْ : ان کے لیے عِزًّا : موجب عزت انہوں نے اللہ کے سوا دوسرے معبود بنا رکھے ہیں کہ وہ ان کے لئے باعث عزت ہوں۔
19,82,كَلَّا١ؕ سَیَكْفُرُوْنَ بِعِبَادَتِهِمْ وَ یَكُوْنُوْنَ عَلَیْهِمْ ضِدًّا۠    ۧ كَلَّا : ہرگز نہیں سَيَكْفُرُوْنَ : جلد ہی وہ انکار کرینگے بِعِبَادَتِهِمْ : ان کی بندگی سے وَيَكُوْنُوْنَ : اور ہوجائیں گے عَلَيْهِمْ : ان کے ضِدًّا : مخالف لیکن ایسا ہرگز نہیں۔ وہ تو پوجا سے منکر ہوجائیں گے، الٹے ان کے دشمن (1) بن جائیں گے۔
19,83,اَلَمْ تَرَ اَنَّاۤ اَرْسَلْنَا الشَّیٰطِیْنَ عَلَى الْكٰفِرِیْنَ تَؤُزُّهُمْ اَزًّاۙ اَلَمْ تَرَ : کیا تم نے نہیں دیکھا اَنَّآ اَرْسَلْنَا : بیشک ہم نے بھیجے الشَّيٰطِيْنَ : شیطان (جمع) عَلَي : پر الْكٰفِرِيْنَ : کافر (جمع) تَؤُزُّهُمْ : اکساتے ہیں انہیں اَزًّا : خوب اکسانا کیا تو نے نہیں دیکھا کہ ہم کافروں کے پاس شیطانوں کو بھیجتے ہیں جو انھیں خوب اکساتے ہیں (1)
19,84,فَلَا تَعْجَلْ عَلَیْهِمْ١ؕ اِنَّمَا نَعُدُّ لَهُمْ عَدًّاۚ فَلَا تَعْجَلْ : سو تم جلدی نہ کرو عَلَيْهِمْ : ان پر اِنَّمَا : صرف نَعُدُّ : ہم گنتی پوری کر رہے ہیں لَهُمْ : ان کی عَدًّا : گنتی تو ان کے بارے میں جلدی نہ کر، ہم تو خود ہی ان کے لئے مدت شمار کر رہے ہیں (1)۔
19,85,یَوْمَ نَحْشُرُ الْمُتَّقِیْنَ اِلَى الرَّحْمٰنِ وَفْدًاۙ يَوْمَ : جس دن نَحْشُرُ : ہم جمع کرلیں گے الْمُتَّقِيْنَ : پرہیزگار (جمع) اِلَى الرَّحْمٰنِ : رحمن کی طرف وَفْدًا : مہمان بنا کر جس دن ہم پرہیزگاروں کو اللہ رحمان کی طرف بطور مہمان جمع کریں گے۔
19,86,وَّ نَسُوْقُ الْمُجْرِمِیْنَ اِلٰى جَهَنَّمَ وِرْدًاۘ وَّنَسُوْقُ : اور ہانک کرلے جائیں گے الْمُجْرِمِيْنَ : گنہ گار (جمع) اِلٰى : طرف جَهَنَّمَ : جہنم وِرْدًا : پیاسے اور گنہگاروں کو سخت پیاس کی حالت میں جہنم کی طرف ہانک لے جائیں گے (1)۔
19,87,لَا یَمْلِكُوْنَ الشَّفَاعَةَ اِلَّا مَنِ اتَّخَذَ عِنْدَ الرَّحْمٰنِ عَهْدًاۘ لَا يَمْلِكُوْنَ : وہ اختیار نہیں رکھتے الشَّفَاعَةَ : شفاعت اِلَّا : سوائے مَنِ اتَّخَذَ : جس نے لیا ہو عِنْدَ الرَّحْمٰنِ : رحمن کے پاس عَهْدًا : اقرار کسی کو شفاعت کا اختیار نہ ہوگا سوائے ان کے جنہوں نے اللہ تعالیٰ کی طرف سے کوئی قول قرار لے لیا ہے (1)۔
19,88,وَ قَالُوا اتَّخَذَ الرَّحْمٰنُ وَلَدًاؕ وَقَالُوا : اور وہ کہتے ہیں اتَّخَذَ : بنالیا ہے الرَّحْمٰنُ : رحمن وَلَدًا : بیٹا ان کا قول یہ ہے کہ اللہ رحمٰن نے بھی اولاد اختیار کی ہے۔
19,89,لَقَدْ جِئْتُمْ شَیْئًا اِدًّاۙ لَقَدْ جِئْتُمْ : تحقیق تم لائے ہو شَيْئًا : ایک بات اِدًّا : بری یقیناً تم بہت بری اور بھاری چیز لائے ہو۔
19,90,تَكَادُ السَّمٰوٰتُ یَتَفَطَّرْنَ مِنْهُ وَ تَنْشَقُّ الْاَرْضُ وَ تَخِرُّ الْجِبَالُ هَدًّاۙ تَكَادُ : قریب ہے السَّمٰوٰتُ : آسمان يَتَفَطَّرْنَ : پھٹ پڑیں مِنْهُ : اس سے وَتَنْشَقُّ : اور ٹکڑے ٹکرے الْاَرْضُ : زمین وَتَخِرُّ : اور گرپڑیں الْجِبَالُ : پہاڑ هَدًّا : پارہ پارہ قریب ہے کہ اس قول کی وجہ سے آسمان پھٹ جائیں اور زمین شق ہوجائے اور پہاڑ ریزہ ریزہ ہوجائیں
19,91,اَنْ دَعَوْا لِلرَّحْمٰنِ وَلَدًاۚ اَنْ دَعَوْا : کہ انہوں نے پکارا (منسوب کیا) لِلرَّحْمٰنِ : اللہ کے لیے وَلَدًا : بیٹا کہ وہ رحمٰن کی اولاد ثابت کرنے بیٹھے (1)۔
19,92,وَ مَا یَنْۢبَغِیْ لِلرَّحْمٰنِ اَنْ یَّتَّخِذَ وَلَدًاؕ وَمَا : جبکہ نہیں يَنْۢبَغِيْ : شایان لِلرَّحْمٰنِ : رحمن کے لیے اَنْ يَّتَّخِذَ : کہ وہ بنائے وَلَدًا : بیٹا شان رحمٰن کے لائق نہیں کہ وہ اولاد رکھے۔
19,93,اِنْ كُلُّ مَنْ فِی السَّمٰوٰتِ وَ الْاَرْضِ اِلَّاۤ اٰتِی الرَّحْمٰنِ عَبْدًاؕ اِنْ كُلُّ : نہیں تمام۔ کوئی مَنْ : جو فِي السَّمٰوٰتِ : آسمانوں میں وَالْاَرْضِ : اور زمین اِلَّآ اٰتِي : مگر آتا ہے الرَّحْمٰنِ : رحمن عَبْدًا : بندہ آسمان و زمین میں جو بھی ہیں سب کے سب اللہ کے غلام بن کر ہی آنے والے ہیں (1)۔
19,94,لَقَدْ اَحْصٰىهُمْ وَ عَدَّهُمْ عَدًّاؕ لَقَدْ اَحْصٰىهُمْ : اس نے ان کو گھیر لیا ہے وَعَدَّهُمْ : اور ان کا شمار کرلیا ہے عَدًّا : گن کر ان سب کو اس نے گھیر رکھا ہے اور سب کو پورے گن بھی رکھا ہے (1)
19,95,وَ كُلُّهُمْ اٰتِیْهِ یَوْمَ الْقِیٰمَةِ فَرْدًا وَكُلُّهُمْ : اور ان میں سے ہر ایک اٰتِيْهِ : آئیگا اس کے سامنے يَوْمَ الْقِيٰمَةِ : قیامت کے دن فَرْدًا : اکیلا یہ سارے کے سارے قیامت کے دن اکیلے اس کے پاس حاضر ہونے والے ہیں (1)
19,96,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ سَیَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا اِنَّ : بیشک الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : نیک سَيَجْعَلُ : پیدا کردے گا لَهُمُ : ان کے لیے الرَّحْمٰنُ : رحمن وُدًّا : محبت بیشک جو ایمان لائے ہیں اور جنہوں نے شائستہ اعمال کیے ہیں ان کے لئے اللہ رحمٰن محبت پیدا کر دے گا (1)
19,97,فَاِنَّمَا یَسَّرْنٰهُ بِلِسَانِكَ لِتُبَشِّرَ بِهِ الْمُتَّقِیْنَ وَ تُنْذِرَ بِهٖ قَوْمًا لُّدًّا فَاِنَّمَا : پس اس کے سوا نہیں يَسَّرْنٰهُ : ہم نے اسے آسان کردیا ہے بِلِسَانِكَ : آپ کی زبان پر لِتُبَشِّرَ بِهِ : تاکہ آپ خوشخبری دیں اس کے ساتھ الْمُتَّقِيْنَ : پرہیزگاروں وَتُنْذِرَ بِهٖ : اور ڈرائیں اس سے قَوْمًا لُّدًّا : جھگڑالو لوگ ہم نے اس قرآن کو تیری زبان میں بہت ہی آسان کردیا ہے (1) کہ تو اس کے ذریعہ سے پرہیزگاروں کو خوشخبری دے اور جھگڑالو (2) کو ڈرا دے۔
19,98,وَ كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنْ قَرْنٍ١ؕ هَلْ تُحِسُّ مِنْهُمْ مِّنْ اَحَدٍ اَوْ تَسْمَعُ لَهُمْ رِكْزًا۠    ۧ وَكَمْ : اور کتنے ہی اَهْلَكْنَا : ہم نے ہلاک کردئیے قَبْلَهُمْ : ان سے قبل مِّنْ : سے قَرْنٍ : گروہ هَلْ : کیا تُحِسُّ : تم دیکھتے ہو مِنْهُمْ : ان سے مِّنْ اَحَدٍ : کوئی۔ کسی کو اَوْ تَسْمَعُ : یا تم سنتے ہو لَهُمْ : ان کی رِكْزًا : آہٹ ہم نے اس سے پہلے بہت سی جماعتیں تباہ کردیں ہیں، کیا ان میں سے ایک بھی آہٹ تو پاتا ہے یا ان کی آواز کی بھنک بھی تیرے کان میں پڑتی ہے ؟ (1)۔
