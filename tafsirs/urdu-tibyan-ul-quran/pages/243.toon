tafsir[6]{c,v,t}:
  12,64,قَالَ هَلْ اٰمَنُكُمْ عَلَیْهِ اِلَّا كَمَاۤ اَمِنْتُكُمْ عَلٰۤى اَخِیْهِ مِنْ قَبْلُ١ؕ فَاللّٰهُ خَیْرٌ حٰفِظًا١۪ وَّ هُوَ اَرْحَمُ الرّٰحِمِیْنَ قَالَ : اس نے کہا هَلْ اٰمَنُكُمْ : کیا میں تمہارا اعتبار کروں عَلَيْهِ : اس کے متعلق اِلَّا : مگر كَمَآ : جیسے اَمِنْتُكُمْ : میں نے تمہارا اعتبار کیا عَلٰٓي اَخِيْهِ : اس کے بھائی کے متعلق مِنْ قَبْلُ : اس سے پہلے فَاللّٰهُ : سو اللہ خَيْرٌ : بہتر حٰفِظًا : نگہبان وَّهُوَ : اور وہ اَرْحَمُ الرّٰحِمِيْنَ : تمام مہربانوں سے بڑا مہربانی کرنیوالا ہے (یعقوب ؑ نے) کہا مجھے تو اس کی بابت تمہارا بس ویسا ہی اعتبار ہے، جیسا اس سے پہلے اس کے بھائی کے بارے میں تھا (1) بس اللہ ہی بہترین محافظ ہے اور وہ سب مہربانوں سے بڑا مہربان ہے۔ 2
  12,65,وَ لَمَّا فَتَحُوْا مَتَاعَهُمْ وَجَدُوْا بِضَاعَتَهُمْ رُدَّتْ اِلَیْهِمْ١ؕ قَالُوْا یٰۤاَبَانَا مَا نَبْغِیْ١ؕ هٰذِهٖ بِضَاعَتُنَا رُدَّتْ اِلَیْنَا١ۚ وَ نَمِیْرُ اَهْلَنَا وَ نَحْفَظُ اَخَانَا وَ نَزْدَادُ كَیْلَ بَعِیْرٍ١ؕ ذٰلِكَ كَیْلٌ یَّسِیْرٌ وَلَمَّا : اور جب فَتَحُوْا : انہوں نے کھولا مَتَاعَهُمْ : اپنا سامان وَجَدُوْا : انہوں نے پائی بِضَاعَتَهُمْ : اپنی پونجی رُدَّتْ : واپس کردی گئی اِلَيْهِمْ : ان کی طرف (انہیں) قَالُوْا : بولے يٰٓاَبَانَا : اے ہمارے ابا مَا نَبْغِيْ : کیا چاہتے ہیں ہم هٰذِهٖ : یہ بِضَاعَتُنَا : ہماری پونجی رُدَّتْ : لوٹا دی گئی اِلَيْنَا : ہماری طرف وَنَمِيْرُ : اور ہم غلہ لائینگے اَهْلَنَا : اپنے گھر وَنَحْفَظُ : اور ہم حفاظت کرینگے اَخَانَا : اپنا بھائی وَنَزْدَادُ : اور زیادہ لیں گے كَيْلَ : بوجھ بَعِيْرٍ : ایک اونٹ ذٰلِكَ : یہ كَيْلٌ : بوجھ (غلہ) يَّسِيْرٌ : آسان (تھوڑا) جب انہوں نے اپنا اسباب کھولا تو اپنا سرمایا موجود پایا جو ان کی جانب لوٹا دیا گیا تھا کہنے لگے اے ہمارے باپ ہمیں اور کیا چاہیے (1) دیکھئے تو ہمارا سرمایا بھی واپس لوٹا دیا گیا ہے، ہم اپنے خاندان کو رسد لا دیں گے اور اپنے بھائی کی نگرانی رکھیں گے اور ایک اونٹ کے بوجھ کا غلہ زیادہ لائیں گے (1) یہ ناپ تو بہت آسان ہے (3)۔
  12,66,قَالَ لَنْ اُرْسِلَهٗ مَعَكُمْ حَتّٰى تُؤْتُوْنِ مَوْثِقًا مِّنَ اللّٰهِ لَتَاْتُنَّنِیْ بِهٖۤ اِلَّاۤ اَنْ یُّحَاطَ بِكُمْ١ۚ فَلَمَّاۤ اٰتَوْهُ مَوْثِقَهُمْ قَالَ اللّٰهُ عَلٰى مَا نَقُوْلُ وَكِیْلٌ قَالَ : اس نے کہا لَنْ اُرْسِلَهٗ : ہرگز نہ بھیجوں گا اسے مَعَكُمْ : تمہارے ساتھ حَتّٰى : یہانتک تُؤْتُوْنِ : تم دو مجھے مَوْثِقًا : پختہ عہد مِّنَ اللّٰهِ : اللہ کی طرف سے لَتَاْتُنَّنِيْ بِهٖٓ : تم لے آؤ گے ضرور میرے پاس اس کو اِلَّآ : مگر اَنْ : یہ کہ يُّحَاطَ : گھیر لیا جائے بِكُمْ : تمہیں فَلَمَّآ : پھر جب اٰتَوْهُ : انہوں نے اسے دیا مَوْثِقَهُمْ : اپنا پختہ عہد قَالَ : کہا اس نے اللّٰهُ : اللہ عَلٰي : پر مَا نَقُوْلُ : جو ہم کہتے ہیں وَكِيْلٌ : نگہبان (ضامن) یعقوب ؑ نے کہا ! میں تو اسے ہرگز ہرگز تمہارے ساتھ نہ بھیجوں گا جب تک کہ تم اللہ کو بیچ میں رکھ کر مجھے قول وقرار نہ دو کہ تم اسے میرے پاس پہنچا دو گے، سوائے اس ایک صورت کے کہ تم سب گرفتار کر لئے جاؤ (1) جب انہوں نے پکا قول قرار دے دیا تو انہوں نے کہا کہ ہم جو کچھ کہتے ہیں اللہ اس پر نگہبان ہے۔
  12,67,وَ قَالَ یٰبَنِیَّ لَا تَدْخُلُوْا مِنْۢ بَابٍ وَّاحِدٍ وَّ ادْخُلُوْا مِنْ اَبْوَابٍ مُّتَفَرِّقَةٍ١ؕ وَ مَاۤ اُغْنِیْ عَنْكُمْ مِّنَ اللّٰهِ مِنْ شَیْءٍ١ؕ اِنِ الْحُكْمُ اِلَّا لِلّٰهِ١ؕ عَلَیْهِ تَوَكَّلْتُ١ۚ وَ عَلَیْهِ فَلْیَتَوَكَّلِ الْمُتَوَكِّلُوْنَ وَقَالَ : اور اس نے کہا يٰبَنِيَّ : اے میرے بیٹو لَا تَدْخُلُوْا : تم نہ داخل ہونا مِنْ : سے بَابٍ وَّاحِدٍ : ایک دروازہ وَّادْخُلُوْا : اور داخل ہونا مِنْ : سے اَبْوَابٍ : دروازے مُّتَفَرِّقَةٍ : جدا جدا وَمَآ اُغْنِيْ : اور میں نہیں بچا سکتا عَنْكُمْ : تم سے (کو) مِّنَ : سے (کی) اللّٰهِ : اللہ مِنْ شَيْءٍ : کیس چیز (بات) سے اِنِ : نہیں الْحُكْمُ : حکم اِلَّا : سوا لِلّٰهِ : اللہ کا عَلَيْهِ : اس پر تَوَكَّلْتُ : میں نے بھرسہ کیا وَعَلَيْهِ : اور اس پر فَلْيَتَوَكَّلِ : پس چاہیے بھروسہ کریں الْمُتَوَكِّلُوْنَ : بھروسہ کرنے والے اور (یعقوب علیہ السلام) نے کہا اے میرے بچو ! تم سب ایک دروازے سے نہ جانا بلکہ کئی جدا جدا دروازوں میں سے داخل ہونا (1) میں اللہ کی طرف سے آنے والی کسی چیز کو تم سے ٹال نہیں سکتا حکم صرف اللہ ہی کا چلتا ہے (2) میرا کامل بھروسہ اسی پر ہے اور ہر ایک بھروسہ کرنے والے کو اسی پر بھروسہ کرنا چاہیئے۔
  12,68,وَ لَمَّا دَخَلُوْا مِنْ حَیْثُ اَمَرَهُمْ اَبُوْهُمْ١ؕ مَا كَانَ یُغْنِیْ عَنْهُمْ مِّنَ اللّٰهِ مِنْ شَیْءٍ اِلَّا حَاجَةً فِیْ نَفْسِ یَعْقُوْبَ قَضٰىهَا١ؕ وَ اِنَّهٗ لَذُوْ عِلْمٍ لِّمَا عَلَّمْنٰهُ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ۠    ۧ وَلَمَّا : اور جب دَخَلُوْا : وہ داخل ہوئے مِنْ حَيْثُ : جہاں سے اَمَرَهُمْ : انہیں حکم دیا اَبُوْهُمْ : ان کا باپ مَا كَانَ : نہیں تھا يُغْنِيْ : وہ بچا سکتا عَنْهُمْ : ان سے (انہیں) مِّنَ : سے (کی) اللّٰهِ : اللہ مِنْ : سے شَيْءٍ : کسی چیز (بات) اِلَّا : مگر حَاجَةً : ایک خواہش فِيْ : میں نَفْسِ : دل يَعْقُوْبَ : یعقوب قَضٰىهَا : وہ اسنے پوری کرلی وَاِنَّهٗ : اور بیشک وہ لَذُوْ عِلْمٍ : صاحب علم لِّمَا : اس کا جو عَلَّمْنٰهُ : ہم نے اسے سکھایا وَلٰكِنَّ : اور لیکن اَكْثَرَ : اکثر النَّاسِ : لوگ لَا يَعْلَمُوْنَ : نہیں جانتے جب وہ انھیں راستوں سے جن کا حکم ان کے والد نے انھیں دیا تھا گئے۔ کچھ نہ تھا کہ اللہ نے جو بات مقرر کردی ہے وہ اس سے انھیں ذرا بھی بچا لے۔ مگر یعقوب ؑ کے دل میں ایک خیال پیدا ہوا جسے اس نے پورا کرلیا (1) بلاشبہ وہ ہمارے سکھلائے ہوئے علم کا عالم تھا لیکن اکثر لوگ نہیں جانتے (2)
  12,69,وَ لَمَّا دَخَلُوْا عَلٰى یُوْسُفَ اٰوٰۤى اِلَیْهِ اَخَاهُ قَالَ اِنِّیْۤ اَنَا اَخُوْكَ فَلَا تَبْتَئِسْ بِمَا كَانُوْا یَعْمَلُوْنَ وَلَمَّا : اور جب دَخَلُوْا : وہ داخل ہوئے عَلٰي يُوْسُفَ : یوسف کے پاس اٰوٰٓى : اس نے جگہ دی اِلَيْهِ : اپنے پاس اَخَاهُ : اپنا بھائی قَالَ : اس نے کہا اِنِّىْٓ : بیشک میں اَنَا اَخُوْكَ : میں تیرا بھائی فَلَا تَبْتَئِسْ : سو تو غمگین نہ ہو بِمَا : اس پر جو كَانُوْا : وہ کرتے تھے يَعْمَلُوْنَ : وہ کرتے تھے یہ سب جب یوسف کے پاس پہنچ گئے تو اس نے اپنے بھائی کو اپنے پاس بٹھا لیا اور کہا کہ میں تیرا بھائی (یوسف) ہوں پس یہ جو کچھ کرتے رہے اس کا کچھ رنج نہ کر (1)۔
