tafsir[13]{c,v,t}:
  45,1,حٰمٓۚ حٰمٓ : حا۔ میم حم
  45,2,تَنْزِیْلُ الْكِتٰبِ مِنَ اللّٰهِ الْعَزِیْزِ الْحَكِیْمِ تَنْزِيْلُ : نازل کرتا ہے الْكِتٰبِ : کتاب کا مِنَ اللّٰهِ : اللہ کی طرف الْعَزِيْزِ الْحَكِيْمِ : جو زبردست ہے، حکمت والا ہے یہ کتاب اللہ غالب حکمت والے کی طرف سے نازل کی ہوئی ہے۔
  45,3,اِنَّ فِی السَّمٰوٰتِ وَ الْاَرْضِ لَاٰیٰتٍ لِّلْمُؤْمِنِیْنَؕ اِنَّ فِي السَّمٰوٰتِ : بیشک آسمانوں میں وَالْاَرْضِ : اور زمین میں لَاٰيٰتٍ لِّلْمُؤْمِنِيْنَ : البتہ نشانیاں ہیں ایمان لانے والوں کے لیے آسمانوں اور زمین میں ایمان داروں کے لئے یقیناً بہت سی نشانیاں ہیں۔
  45,4,وَ فِیْ خَلْقِكُمْ وَ مَا یَبُثُّ مِنْ دَآبَّةٍ اٰیٰتٌ لِّقَوْمٍ یُّوْقِنُوْنَۙ وَفِيْ خَلْقِكُمْ : اور تمہاری پیدائش میں وَمَا يَبُثُّ : اور جو پھیلا رہا ہے مِنْ دَآبَّةٍ : جانوروں میں سے اٰيٰتٌ : نشانیاں ہیں لِّقَوْمٍ يُّوْقِنُوْنَ : ان لوگوں کے لیے جو یقین رکھتے ہوں اور خود تمہاری پیدائش میں اور ان جانوروں کی پیدائش میں جنہیں وہ پھیلاتا ہے یقین رکھنے والی قوم کے لئے بہت سی نشانیاں ہیں۔
  45,5,وَ اخْتِلَافِ الَّیْلِ وَ النَّهَارِ وَ مَاۤ اَنْزَلَ اللّٰهُ مِنَ السَّمَآءِ مِنْ رِّزْقٍ فَاَحْیَا بِهِ الْاَرْضَ بَعْدَ مَوْتِهَا وَ تَصْرِیْفِ الرِّیٰحِ اٰیٰتٌ لِّقَوْمٍ یَّعْقِلُوْنَ وَاخْتِلَافِ الَّيْلِ وَالنَّهَارِ : اور رات اور دن کے اختلاف میں وَمَآ : اور جو اَنْزَلَ اللّٰهُ : نازل کیا اللہ نے مِنَ السَّمَآءِ : آسمان سے مِنْ رِّزْقٍ : رزق میں سے فَاَحْيَا : پھر اس نے زندہ کیا بِهِ الْاَرْضَ : ساتھ اس کے زمین کو بَعْدَ مَوْتِهَا : اس کی موت کے بعد وَتَصْرِيْفِ الرِّيٰحِ : اور ہواؤں کی گردش میں اٰيٰتٌ : نشانیاں ہیں لِّقَوْمٍ يَّعْقِلُوْنَ : اس قوم کے لیے جو عقل رکھتی ہو اور رات دن کے بدلے میں اور جو کچھ روزی اللہ تعالیٰ آسمان سے نازل فرما کر زمین کو اسکی موت کے بعد زندہ کردیتا ہے (1) (اس میں) اور ہواؤں کے بدلنے میں بھی ان لوگوں کے لئے جو عقل رکھتے ہیں نشانیاں ہیں (2)۔
  45,6,تِلْكَ اٰیٰتُ اللّٰهِ نَتْلُوْهَا عَلَیْكَ بِالْحَقِّ١ۚ فَبِاَیِّ حَدِیْثٍۭ بَعْدَ اللّٰهِ وَ اٰیٰتِهٖ یُؤْمِنُوْنَ تِلْكَ : یہ اٰيٰتُ اللّٰهِ : اللہ کی آیات ہیں نَتْلُوْهَا : ہم پڑھتے ہیں ان کو عَلَيْكَ بالْحَقِّ : آپ پر حق کے ساتھ فَبِاَيِّ حَدِيْثٍۢ : تو ساتھ کون سی بات کے بَعْدَ اللّٰهِ : بعد اللہ کے وَ : اور اٰيٰتِهٖ يُؤْمِنُوْنَ : اس کی آیات کے وہ ایمان لائیں گے یہ ہیں اللہ کی آیتیں جنہیں ہم آپ کو راستی سے سنا رہے ہیں، پس اللہ تعالیٰ اور اس کی آیتوں کے بعد یہ کس بات پر ایمان لائیں گے۔ (1)
  45,7,وَیْلٌ لِّكُلِّ اَفَّاكٍ اَثِیْمٍۙ وَيْلٌ : ہلاکت ہے لِّكُلِّ : واسطے ہر اَفَّاكٍ : بہت جھوٹے اَثِيْمٍ : بہت گناہ گار کے ' ویل ' اور افسوس ہے ہر ایک جھوٹے گنہگار پر۔
  45,8,یَّسْمَعُ اٰیٰتِ اللّٰهِ تُتْلٰى عَلَیْهِ ثُمَّ یُصِرُّ مُسْتَكْبِرًا كَاَنْ لَّمْ یَسْمَعْهَا١ۚ فَبَشِّرْهُ بِعَذَابٍ اَلِیْمٍ يَّسْمَعُ : وہ سنتا ہے اٰيٰتِ اللّٰهِ : اللہ کی آیات کو تُتْلٰى عَلَيْهِ : پڑھی جاتی ہیں اس پر ثُمَّ : پھر يُصِرُّ : وہ اڑ جاتا ہے۔ اصرار کرتا ہے مُسْتَكْبِرًا : تکبر کرتے ہوئے كَاَنْ لَّمْ : گویا کہ نہیں يَسْمَعْهَا : اس نے سنا اس کو فَبَشِّرْهُ : تو خوش خبری دے دو اس کو بِعَذَابٍ اَلِيْمٍ : دردناک عذاب کی جو آیتیں اللہ کے اپنے سامنے پڑھی جاتی ہوئی سنے پھر بھی غرور کرتا ہوا اس طرح اڑا رہے کہ گویا سنی ہی نہیں (1) تو ایسے لوگوں کو دردناک عذاب کی خبر (پہنچا) دیجئے۔
  45,9,وَ اِذَا عَلِمَ مِنْ اٰیٰتِنَا شَیْئَا اِ۟تَّخَذَهَا هُزُوًا١ؕ اُولٰٓئِكَ لَهُمْ عَذَابٌ مُّهِیْنٌؕ وَاِذَا : اور جب عَلِمَ : وہ جان لیتا ہے مِنْ اٰيٰتِنَا : ہماری آیات میں سے شَيْئَۨا : کوئی چیز اتَّخَذَهَا : بنالیتا ہے اس کو هُزُوًا : مذاق اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے عَذَابٌ مُّهِيْنٌ : عذاب ہے رسوا کرنے والا۔ ذلیل کرنے والے وہ جب ہماری آیتوں میں سے کسی آیت کی خبر پا لیتا ہے تو اس کی ہنسی اڑاتا ہے (1) یہی لوگ ہیں جن کے لئے رسوائی کی مار ہے۔
  45,10,مِنْ وَّرَآئِهِمْ جَهَنَّمُ١ۚ وَ لَا یُغْنِیْ عَنْهُمْ مَّا كَسَبُوْا شَیْئًا وَّ لَا مَا اتَّخَذُوْا مِنْ دُوْنِ اللّٰهِ اَوْلِیَآءَ١ۚ وَ لَهُمْ عَذَابٌ عَظِیْمٌؕ مِنْ وَّرَآئِهِمْ : ان کے آگے جَهَنَّمُ : جہنم ہے وَلَا يُغْنِيْ : اور نہ کام آئے گا عَنْهُمْ : ان کو مَّا كَسَبُوْا شَيْئًا : جو انہوں نے کمایا کچھ بھی وَّلَا : اور نہ مَا اتَّخَذُوْا : جو انہوں نے بنا لیے مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا سے اَوْلِيَآءَ : سرپرست۔ مددگار وَلَهُمْ : اور ان کے لیے عَذَابٌ : عذاب ہے عَظِيْمٌ : بڑا ان کے پیچھے دوزخ ہے (1) جو کچھ انہوں نے حاصل کیا تھا وہ انہیں کچھ بھی نفع نہ دے گا اور نہ وہ (کچھ کام آئیں گے) جن کو انہوں نے اللہ کے سوا کارساز بنا رکھا تھا ان کے لئے تو بہت بڑا عذاب ہے۔
  45,11,هٰذَا هُدًى١ۚ وَ الَّذِیْنَ كَفَرُوْا بِاٰیٰتِ رَبِّهِمْ لَهُمْ عَذَابٌ مِّنْ رِّجْزٍ اَلِیْمٌ۠    ۧ ھٰذَا هُدًى : یہ ہے ہدایت وَالَّذِيْنَ كَفَرُوْا : اور وہ لوگ جنہوں نے انکار کیا بِاٰيٰتِ : آیات کا رَبِّهِمْ : اپنے رب کی لَهُمْ : ان کے لیے عَذَابٌ : عذاب ہے مِّنْ رِّجْزٍ اَلِيْمٌ : ہے قرار کرنے والا۔ رسوا کن یہ (سرتاپا) ہدایت (1) ہے اور جن لوگوں نے اپنے رب کی آیتوں کو نہ مانا ان کے لئے بہت سخت دردناک عذاب ہے۔
  45,12,اَللّٰهُ الَّذِیْ سَخَّرَ لَكُمُ الْبَحْرَ لِتَجْرِیَ الْفُلْكُ فِیْهِ بِاَمْرِهٖ وَ لِتَبْتَغُوْا مِنْ فَضْلِهٖ وَ لَعَلَّكُمْ تَشْكُرُوْنَۚ اَللّٰهُ : اللہ الَّذِيْ : وہ ذات ہے سَخَّرَ : جس نے مسخر کیا لَكُمُ الْبَحْرَ : تمہارے لیے سمندر کو لِتَجْرِيَ الْفُلْكُ : تاکہ چلیں کشتیاں فِيْهِ : اس میں بِاَمْرِهٖ : ساتھ اس کے حکم کے وَلِتَبْتَغُوْا : اور تاکہ تم تلاش کرو مِنْ فَضْلِهٖ : اس کے فضل میں وَلَعَلَّكُمْ : اور تاکہ تم تَشْكُرُوْنَ : تم شکرادا کرو اللہ ہی ہے جس نے تمہارے لئے دریا (1) کو تابع بنادیا تاکہ اس کے حکم سے اس میں کشتیاں چلیں اور تم اس کا فضل تلاش کرو اور تاکہ تم شکر بجا لاؤ۔
  45,13,وَ سَخَّرَ لَكُمْ مَّا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ جَمِیْعًا مِّنْهُ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّقَوْمٍ یَّتَفَكَّرُوْنَ وَسَخَّرَ لَكُمْ : اور اس نے مسخر کیا تمہارے لیے مَّا فِي السَّمٰوٰتِ : جو کچھ آسمانوں میں ہے وَمَا : اور جو کچھ فِي الْاَرْضِ : زمین میں ہے جَمِيْعًا : سارے کا سارا مِّنْهُ : اس سے اِنَّ فِيْ ذٰلِكَ : بیشک اس میں لَاٰيٰتٍ : البتہ نشانیاں لِّقَوْمٍ يَّتَفَكَّرُوْنَ : اس قوم کے لیے جو غور و فکر کرتی ہو اور آسمان و زمین کی ہر ہر چیز کو بھی اس نے اپنی طرف سے تمہارے لئے تابع کردیا ہے (1) جو غور کریں یقیناً وہ اس میں بہت سی نشانیاں پالیں گے۔
