tafsir[9]{c,v,t}:
  34,23,وَ لَا تَنْفَعُ الشَّفَاعَةُ عِنْدَهٗۤ اِلَّا لِمَنْ اَذِنَ لَهٗ١ؕ حَتّٰۤى اِذَا فُزِّعَ عَنْ قُلُوْبِهِمْ قَالُوْا مَا ذَا١ۙ قَالَ رَبُّكُمْ١ؕ قَالُوا الْحَقَّ١ۚ وَ هُوَ الْعَلِیُّ الْكَبِیْرُ وَلَا تَنْفَعُ : اور نفع نہیں دیتی الشَّفَاعَةُ : شفاعت عِنْدَهٗٓ : اس کے پاس اِلَّا : سوائے لِمَنْ اَذِنَ : جسے وہ اجازتے دے لَهٗ ۭ : اس کو حَتّىٰٓ : یہاں تک اِذَا : جب فُزِّعَ : دور کردی جاتی ہے عَنْ قُلُوْبِهِمْ : ان کے دلوں سے قَالُوْا : کہتے ہیں مَاذَا ۙ : کیا قَالَ : کہا رَبُّكُمْ ۭ : تمہارے رب نے قَالُوا : وہ کہتے ہیں الْحَقَّ ۚ : حق وَهُوَ : اور وہ الْعَلِيُّ : بلند مرتبہ الْكَبِيْرُ : بزرگ قدر شفاعت (شفارش) بھی اس کے پاس کچھ نفع نہیں دیتی بجز ان کے جن کے لئے اجازت ہوجائے (1) یہاں تک کہ جب ان کے دلوں سے گھبراہٹ دور کردی جاتی ہے تو پوچھتے ہیں تمہارے پروردگار نے کیا فرمایا ؟ جواب دیتے ہیں کہ حق فرمایا (2) اور وہ بلند وبالا اور بہت بڑا ہے۔
  34,24,قُلْ مَنْ یَّرْزُقُكُمْ مِّنَ السَّمٰوٰتِ وَ الْاَرْضِ١ؕ قُلِ اللّٰهُ١ۙ وَ اِنَّاۤ اَوْ اِیَّاكُمْ لَعَلٰى هُدًى اَوْ فِیْ ضَلٰلٍ مُّبِیْنٍ قُلْ : فرمادیں مَنْ : کون يَّرْزُقُكُمْ : تمہیں رزق دیتا ہے مِّنَ السَّمٰوٰتِ : آسمانوں سے وَالْاَرْضِ ۭ : اور زمین قُلِ : فرمادیں اللّٰهُ ۙ : اللہ وَاِنَّآ : اور بیشک ہم اَوْ : یا اِيَّاكُمْ : تم ہی لَعَلٰى هُدًى : البتہ ہدایت پر اَوْ : یا فِيْ ضَلٰلٍ : گمراہی میں مُّبِيْنٍ : کھلی پوچھئے کہ تمہیں آسمانوں اور زمین سے روزی کون پہنچاتا ہے ؟ (خود) جواب دیجئے ! کہ اللہ تعالیٰ۔ (سنو) ہم یا تم۔ یا تو یقیناً ہدایت پر ہیں یا کھلی گمراہی میں ہیں ؟ (1)
  34,25,قُلْ لَّا تُسْئَلُوْنَ عَمَّاۤ اَجْرَمْنَا وَ لَا نُسْئَلُ عَمَّا تَعْمَلُوْنَ قُلْ : فرمادیں لَّا تُسْئَلُوْنَ : تم سے نہ پوچھا جائے عَمَّآ : اس کی بابت اَجْرَمْنَا : جو ہم نے گناہ کیا وَلَا نُسْئَلُ : اور نہ ہم سے پوچھا جائے گا عَمَّا : اس کی بابت تَعْمَلُوْنَ : جو تم کرتے ہو کہہ دیجئے ! ہمارے کئے ہوئے گناہوں کی بابت تم سے کوئی سوال نہ کیا جائے گا نہ تمہارے اعمال کی باز پرس ہم سے کی جائے گی۔
  34,26,قُلْ یَجْمَعُ بَیْنَنَا رَبُّنَا ثُمَّ یَفْتَحُ بَیْنَنَا بِالْحَقِّ١ؕ وَ هُوَ الْفَتَّاحُ الْعَلِیْمُ قُلْ : فرما دیں آپ يَجْمَعُ : وہ جمع کرے گا بَيْنَنَا : ہم سب کو رَبُّنَا : ہمارا رب ثُمَّ : پھر يَفْتَحُ : فیصلہ کرے گا بَيْنَنَا : ہمارے درمیان بِالْحَقِّ ۭ : ٹھیک ٹھیک وَهُوَ : اور وہ الْفَتَّاحُ : فیصلہ کرنے والا الْعَلِيْمُ : جاننے والا انہیں خبر دے دیجئے کہ سب کو ہمارا رب جمع کر کے پھر ہم میں سے سچے فیصلے کر دے گا (1) وہ فیصلے چکانے والا ہے
  34,27,قُلْ اَرُوْنِیَ الَّذِیْنَ اَلْحَقْتُمْ بِهٖ شُرَكَآءَ كَلَّا١ؕ بَلْ هُوَ اللّٰهُ الْعَزِیْزُ الْحَكِیْمُ قُلْ : فرمادیں اَرُوْنِيَ : مجھے دکھاؤ الَّذِيْنَ : وہ جنہیں اَلْحَقْتُمْ : تم نے ساتھ ملا دیا ہے بِهٖ : اس کے ساتھ شُرَكَآءَ : شریک كَلَّا ۭ : ہرگز نہیں بَلْ : بلکہ هُوَ اللّٰهُ : وہ اللہ الْعَزِيْزُ : غالب الْحَكِيْمُ : حکمت والا کہہ دیجئے ! اچھا مجھے بھی تو انھیں دکھا دو جنہیں تم اللہ کا شریک ٹھہرا کر اس کے ساتھ ملا رہے ہو، ایسا ہرگز نہیں (1) بلکہ وہی اللہ ہے غالب با حکمت۔
  34,28,وَ مَاۤ اَرْسَلْنٰكَ اِلَّا كَآفَّةً لِّلنَّاسِ بَشِیْرًا وَّ نَذِیْرًا وَّ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ وَمَآ : اور نہیں اَرْسَلْنٰكَ : آپ کو بھیجا ہم نے اِلَّا كَآفَّةً لِّلنَّاسِ : مگر تمام لوگوں (نوع انسانی) کے لیے بَشِيْرًا : خوشخبردی دینے والا وَّنَذِيْرًا : اور ڈر سنانے والا وَّلٰكِنَّ : اور لیکن اَكْثَرَ النَّاسِ : اکثر لوگ لَا يَعْلَمُوْنَ : نہیں جانتے ہم نے آپ کو تمام لوگوں کے لئے خوشخبریاں سنانے والا اور ڈرانے والا بنا کر بھیجا ہے ہاں مگر (یہ صحیح ہے) کہ لوگوں کی اکثریت بےعلم ہے (1)
  34,29,وَ یَقُوْلُوْنَ مَتٰى هٰذَا الْوَعْدُ اِنْ كُنْتُمْ صٰدِقِیْنَ وَيَقُوْلُوْنَ : اور وہ کہتے ہیں مَتٰى : کب ھٰذَا الْوَعْدُ : یہ وعدہ (قیامت) اِنْ : اگر كُنْتُمْ : تم ہو صٰدِقِيْنَ : سچے پوچھتے ہیں کہ وہ وعدہ ہے کب ؟ سچے ہو تو بتادو۔ (1)
  34,30,قُلْ لَّكُمْ مِّیْعَادُ یَوْمٍ لَّا تَسْتَاْخِرُوْنَ عَنْهُ سَاعَةً وَّ لَا تَسْتَقْدِمُوْنَ۠    ۧ قُلْ : فرمادیں لَّكُمْ : تمہارے لیے مِّيْعَادُ : وعدہ يَوْمٍ : ایک دن لَّا تَسْتَاْخِرُوْنَ : نہ تم پیچھے ہٹ سکتے ہو عَنْهُ : اس سے سَاعَةً : ایک گھڑی وَّلَا : اور نہ تَسْتَقْدِمُوْنَ : تم آگے بڑھ سکتے ہو جواب دیجئے کہ وعدے کا دن ٹھیک معین ہے جس سے ایک ساعت نہ تم پیچھے ہٹ سکتے ہو نہ آگے بڑھ سکتے ہو (1)۔
  34,31,وَ قَالَ الَّذِیْنَ كَفَرُوْا لَنْ نُّؤْمِنَ بِهٰذَا الْقُرْاٰنِ وَ لَا بِالَّذِیْ بَیْنَ یَدَیْهِ١ؕ وَ لَوْ تَرٰۤى اِذِ الظّٰلِمُوْنَ مَوْقُوْفُوْنَ عِنْدَ رَبِّهِمْ١ۖۚ یَرْجِعُ بَعْضُهُمْ اِلٰى بَعْضِ اِ۟لْقَوْلَ١ۚ یَقُوْلُ الَّذِیْنَ اسْتُضْعِفُوْا لِلَّذِیْنَ اسْتَكْبَرُوْا لَوْ لَاۤ اَنْتُمْ لَكُنَّا مُؤْمِنِیْنَ وَقَالَ : اور کہتے ہیں الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) لَنْ نُّؤْمِنَ : ہم ہرگز ایمان نہ لائیں گے بِھٰذَا الْقُرْاٰنِ : اس قرآن پر وَلَا : اور نہ بِالَّذِيْ : اس پر جو بَيْنَ يَدَيْهِ ۭ : اس سے پہلے وَلَوْ تَرٰٓى : اور کاش تم دیکھو اِذِ : جب الظّٰلِمُوْنَ : ظالم (جمع) مَوْقُوْفُوْنَ : کھڑے کیے جائیں گے عِنْدَ رَبِّهِمْ ښ : اپنے رب کے سامنے يَرْجِعُ : لوٹائے گا (رد کرے گا) بَعْضُهُمْ : ان میں سے ایک اِلٰى : طرف بَعْضِۨ : دوسرے الْقَوْلَ ۚ : بات يَقُوْلُ : کہیں گے الَّذِيْنَ اسْتُضْعِفُوْا : جو کمزور کئے گئے (ناتوان) لِلَّذِيْنَ : ان لوگوں کو اسْتَكْبَرُوْا : تکبر کرتے تھے (بڑے لوگ) لَوْلَآ اَنْتُمْ : اگر نہ تم ہوتے لَكُنَّا : ضرور ہم ہوتے مُؤْمِنِيْنَ : ایمان لانے والے اور کافروں نے کہا ہم ہرگز نہ تو اس قرآن کو مانیں نہ اس سے پہلے کی کتابوں کو ! (1) اے دیکھنے والے کاش کہ تو ان ظالموں کو اس وقت دیکھتا جبکہ یہ اپنے رب کے سامنے کھڑے ہوئے ایک دوسرے کو الزام لگا رہے ہونگے (2) کمزور لوگ بڑے لوگوں سے کہیں گے (3) اگر تم نہ ہوتے تو ہم مومنوں میں سے ہوتے (4)۔
