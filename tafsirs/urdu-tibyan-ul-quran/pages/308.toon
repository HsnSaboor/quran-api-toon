tafsir[13]{c,v,t}:
  19,39,وَ اَنْذِرْهُمْ یَوْمَ الْحَسْرَةِ اِذْ قُضِیَ الْاَمْرُ١ۘ وَ هُمْ فِیْ غَفْلَةٍ وَّ هُمْ لَا یُؤْمِنُوْنَ وَاَنْذِرْهُمْ : اور ان کو ڈراویں آپ يَوْمَ الْحَسْرَةِ : حسرت کا دن اِذْ : جب قُضِيَ : فیصلہ کردیاجائیگا الْاَمْرُ : کام وَهُمْ : لیکن وہ فِيْ غَفْلَةٍ : غفلت میں ہیں وَّهُمْ : اور وہ لَا يُؤْمِنُوْنَ : ایمان نہیں لاتے تو انھیں اس رنج و افسوس کے دن (1) کا ڈر سنا دے جبکہ کام انجام کو پہنچا دیا جائے گا (2) اور یہ لوگ غفلت اور بےایمانی میں ہی رہ جائیں گے۔
  19,40,اِنَّا نَحْنُ نَرِثُ الْاَرْضَ وَ مَنْ عَلَیْهَا وَ اِلَیْنَا یُرْجَعُوْنَ۠ اِنَّا نَحْنُ : بیشک ہم نَرِثُ : وارث ہونگے الْاَرْضَ : زمین وَمَنْ : اور جو عَلَيْهَا : اس پر وَاِلَيْنَا : اور ہماری طرف يُرْجَعُوْنَ : وہ لوٹائے جائیں گے خود زمین کے اور تمام زمین والوں کے وارث ہم ہی ہونگے اور سب لوگ ہماری ہی طرف لوٹا کر لائے جائیں گے۔
  19,41,وَ اذْكُرْ فِی الْكِتٰبِ اِبْرٰهِیْمَ١ؕ۬ اِنَّهٗ كَانَ صِدِّیْقًا نَّبِیًّا    ۧ وَاذْكُرْ : اور یاد کرو فِي الْكِتٰبِ : کتاب میں اِبْرٰهِيْمَ : ابراہیم اِنَّهٗ كَانَ : بیشک وہ تھے صِدِّيْقًا : سچے نَّبِيًّا : نبی اس کتاب میں ابراہیم ؑ کا قصہ بیان کر، بیشک وہ بڑی سچائی والے پیغمبر تھے (1)۔
  19,42,اِذْ قَالَ لِاَبِیْهِ یٰۤاَبَتِ لِمَ تَعْبُدُ مَا لَا یَسْمَعُ وَ لَا یُبْصِرُ وَ لَا یُغْنِیْ عَنْكَ شَیْئًا اِذْ قَالَ : جب اس نے کہا لِاَبِيْهِ : اپنے باپ کو يٰٓاَبَتِ : اے میرے ابا لِمَ تَعْبُدُ : تم کیوں پرستش کرتے ہو مَا لَا يَسْمَعُ : جو نہ سنے وَلَا يُبْصِرُ : اور نہ دیکھے وَلَا يُغْنِيْ : اور نہ کام آئے عَنْكَ : تمہارے شَيْئًا : کچھ جب کہ انہوں نے اپنے باپ سے کہا کہ ابا جان ! آپ ان کی پوجا پاٹ کیوں کر رہے ہیں جو نہ سنیں نہ دیکھیں ؟ نہ آپ کو کچھ بھی فائدہ پہنچا سکیں۔
  19,43,یٰۤاَبَتِ اِنِّیْ قَدْ جَآءَنِیْ مِنَ الْعِلْمِ مَا لَمْ یَاْتِكَ فَاتَّبِعْنِیْۤ اَهْدِكَ صِرَاطًا سَوِیًّا يٰٓاَبَتِ : اے میرے ابا اِنِّىْ : بیشک میں قَدْ جَآءَنِيْ : بیشک میرے پاس آیا ہے مِنَ الْعِلْمِ : وہ علم مَا : جو لَمْ يَاْتِكَ : تمہارے پاس نہیں آیا فَاتَّبِعْنِيْٓ : پس میری بات مانو اَهْدِكَ : میں تمہیں دکھاؤں گا صِرَاطًا : راستہ سَوِيًّا : سیدھا میرے مہربان باپ ! آپ دیکھیے میرے پاس وہ علم آیا ہے جو آپ کے پاس آیا ہی نہیں، (1) تو آپ میری ہی مانیں میں بالکل سیدھی راہ کی طرف آپ کی رہبری کروں گا (2)۔
  19,44,یٰۤاَبَتِ لَا تَعْبُدِ الشَّیْطٰنَ١ؕ اِنَّ الشَّیْطٰنَ كَانَ لِلرَّحْمٰنِ عَصِیًّا يٰٓاَبَتِ : اے میرے ابا لَا تَعْبُدِ : پرستش نہ کر الشَّيْطٰنَ : شیطان اِنَّ : بشیک الشَّيْطٰنَ : شیطان كَانَ : ہے لِلرَّحْمٰنِ : رحمن کا عَصِيًّا : نافرمان میرے ابا جان آپ شیطان کی پرستش سے باز آجائیں شیطان تو رحم و کرم والے اللہ تعالیٰ کا بڑا ہی نافرمان ہے (1)۔
  19,45,یٰۤاَبَتِ اِنِّیْۤ اَخَافُ اَنْ یَّمَسَّكَ عَذَابٌ مِّنَ الرَّحْمٰنِ فَتَكُوْنَ لِلشَّیْطٰنِ وَلِیًّا يٰٓاَبَتِ : اے میرے ابا اِنِّىْٓ : بیشک میں اَخَافُ : ڈرتا ہوں اَنْ : کہ يَّمَسَّكَ : تجھے آپکڑے عَذَابٌ : عذاب مِّنَ : سے۔ کا الرَّحْمٰنِ : رحمن فَتَكُوْنَ : پھر تو ہوجائے لِلشَّيْطٰنِ : شیطان کا وَلِيًّا : ساتھی ابا جان ! مجھے خوف لگا ہوا ہے کہ کہیں آپ پر کوئی عذاب الٰہی نہ آپڑے کہ آپ شیطان کے ساتھی بن جائیں (1)
  19,46,قَالَ اَرَاغِبٌ اَنْتَ عَنْ اٰلِهَتِیْ یٰۤاِبْرٰهِیْمُ١ۚ لَئِنْ لَّمْ تَنْتَهِ لَاَرْجُمَنَّكَ وَ اهْجُرْنِیْ مَلِیًّا قَالَ : اس نے کہا اَ رَاغِبٌ : کیا روگرداں اَنْتَ : تو عَنْ : سے اٰلِهَتِيْ : میرے معبود (جمع) يٰٓاِبْرٰهِيْمُ : اے ابراہیم لَئِنْ : اگر لَّمْ تَنْتَهِ : تو باز نہ آیا لَاَرْجُمَنَّكَ : تو میں تجھے ضرور سنگسار کروں گا وَاهْجُرْنِيْ : اور مجھے چھوڑ دے مَلِيًّا : ایک مدت کے لیے اس نے جواب دیا کہ اے ابراہیم ! کیا تو ہمارے معبودوں سے روگردانی کر رہا ہے۔ سن اگر تو باز نہ آیا تو میں تجھے پتھروں سے مار ڈالوں گا، جا ایک مدت دراز تک مجھ سے الگ رہ (1)۔
  19,47,قَالَ سَلٰمٌ عَلَیْكَ١ۚ سَاَسْتَغْفِرُ لَكَ رَبِّیْ١ؕ اِنَّهٗ كَانَ بِیْ حَفِیًّا قَالَ : اس نے کہا سَلٰمٌ : سلام عَلَيْكَ : تجھ پر سَاَسْتَغْفِرُ : میں ابھی بخشش مانگوں گا لَكَ : تیرے لیے رَبِّيْ : اپنا رب اِنَّهٗ : بیشک وہ كَانَ : ہے بِيْ : مجھ پر حَفِيًّا : مہربان کہا اچھا تم پر سلام ہو (1) میں تو اپنے پروردگار سے تمہاری بخشش کی دعا کرتا رہوں گا (2) وہ مجھ پر حد درجہ مہربان ہے۔
  19,48,وَ اَعْتَزِلُكُمْ وَ مَا تَدْعُوْنَ مِنْ دُوْنِ اللّٰهِ وَ اَدْعُوْا رَبِّیْ١ۖ٘ عَسٰۤى اَلَّاۤ اَكُوْنَ بِدُعَآءِ رَبِّیْ شَقِیًّا وَاَعْتَزِلُكُمْ : اور کنارہ کشی کرتا ہوں تم سے وَمَا : اور جو تَدْعُوْنَ : تم پرستش کرتے ہو مِنْ دُوْنِ : سوائے اللّٰهِ : اللہ وَاَدْعُوْا : اور میں عبادت کروں گا رَبِّيْ : اپنا رب عَسٰٓى : امید ہے اَلَّآ اَكُوْنَ : کہ نہ رہوں گا بِدُعَآءِ : عبادت سے رَبِّيْ : اپنا رب شَقِيًّا : محروم میں تو تمہیں بھی اور جن جن کو تم اللہ تعالیٰ کے سوا پکارتے ہو انھیں بھی سب کو چھوڑ رہا ہوں۔ صرف اپنے پروردگار کو پکارتا رہوں گا، مجھے یقین ہے کہ میں اپنے پروردگار سے دعا مانگ کر محروم نہ رہوں گا۔
  19,49,فَلَمَّا اعْتَزَلَهُمْ وَ مَا یَعْبُدُوْنَ مِنْ دُوْنِ اللّٰهِ١ۙ وَهَبْنَا لَهٗۤ اِسْحٰقَ وَ یَعْقُوْبَ١ؕ وَ كُلًّا جَعَلْنَا نَبِیًّا فَلَمَّا : پھر جب اعْتَزَلَهُمْ : وہ کنارہ کش ہوگئے ان سے وَمَا : اور جو يَعْبُدُوْنَ : وہ پرستش کرتے تھے مِنْ دُوْنِ : سوائے اللّٰهِ : اللہ وَهَبْنَا : ہم نے عطا کیا لَهٗٓ : اس کو اِسْحٰقَ : اسحق وَيَعْقُوْبَ : اور یعقوب وَكُلًّا : اور سب کو جَعَلْنَا : ہم نے بنایا نَبِيًّا : نبی جب ابراہیم ؑ ان سب کو اور اللہ کے سوا ان کے سب معبودوں کو چھوڑ چکے تو ہم نے انھیں اسحاق و یعقوب (علیہما السلام) عطا فرمائے، (1) اور دونوں کو نبی بنادیا۔
  19,50,وَ وَهَبْنَا لَهُمْ مِّنْ رَّحْمَتِنَا وَ جَعَلْنَا لَهُمْ لِسَانَ صِدْقٍ عَلِیًّا۠    ۧ وَوَهَبْنَا : اور ہم نے عطا کیا لَهُمْ : انہیں مِّنْ : سے رَّحْمَتِنَا : اپنی رحمت وَجَعَلْنَا : اور ہم نے کیا لَهُمْ : ان کا لِسَانَ : ذکر صِدْقٍ : سچا۔ جمیل عَلِيًّا : نہایت بلند اور ان سب کو ہم نے اپنی بہت سی رحمتیں (1) عطا فرمائیں اور ہم نے ان کے ذکر جمیل کو بلند درجے کا کردیا (2)۔
  19,51,وَ اذْكُرْ فِی الْكِتٰبِ مُوْسٰۤى١٘ اِنَّهٗ كَانَ مُخْلَصًا وَّ كَانَ رَسُوْلًا نَّبِیًّا وَاذْكُرْ : اور یاد کرو فِي الْكِتٰبِ : کتاب میں مُوْسٰٓى : موسیٰ اِنَّهٗ : بیشک وہ كَانَ : تھا مُخْلَصًا : برگزیدہ وَّكَانَ : اور تھا رَسُوْلًا : رسول نَّبِيًّا : نبی اس قرآن میں موسیٰ ؑ کا ذکر، جو چنا ہوا (1) اور رسول اور نبی تھا
