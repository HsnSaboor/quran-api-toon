tafsir[30]{c,v,t}:
  74,18,اِنَّهٗ فَكَّرَ وَ قَدَّرَۙ اِنَّهٗ فَكَّرَ : بیشک اس نے سوچا وَقَدَّرَ : اور اس نے اندازہ کیا اس نے غور کرکے تجویز کی (1)
  74,19,فَقُتِلَ كَیْفَ قَدَّرَۙ فَقُتِلَ : سو وہ مارا جائے گا كَيْفَ : کیسا قَدَّرَ : اس نے اندازہ کیا اسے ہلاکت ہو کیسی (تجویز) سوچی ؟
  74,20,ثُمَّ قُتِلَ كَیْفَ قَدَّرَۙ ثُمَّ : پھر قُتِلَ : وہ مارا جائے گا كَيْفَ : کیسا قَدَّرَ : اس نے اندازہ کیا وہ پھر غارت ہو کس طرح اندازہ کیا (1)۔
  74,21,ثُمَّ نَظَرَۙ ثُمَّ نَظَرَ : پھر اس نے دیکھا اس نے پھر دیکھا (1)
  74,22,ثُمَّ عَبَسَ وَ بَسَرَۙ ثُمَّ : پھر عَبَسَ : اس نے تیوری چڑھائی وَبَسَرَ : اور منہ بگاڑلیا پھر تیوری چڑھائی اور منہ بنایا (1)
  74,23,ثُمَّ اَدْبَرَ وَ اسْتَكْبَرَۙ ثُمَّ : پھر اَدْبَرَ : اس نے پیٹھ پھیرلی وَاسْتَكْبَرَ : اور اس نے تکبر کیا پھر پیچھے ہٹ گیا اور غرور کیا (1)
  74,24,فَقَالَ اِنْ هٰذَاۤ اِلَّا سِحْرٌ یُّؤْثَرُۙ فَقَالَ : تو اس نے کہا اِنْ هٰذَآ : نہیں یہ اِلَّا : مگر (صرف) سِحْرٌ : جادو يُّؤْثَرُ : اگلوں سے نقل کیا جاتا ہے اور کہنے لگا یہ تو صرف جادو ہے جو نقل کیا جاتا ہے (1)
  74,25,اِنْ هٰذَاۤ اِلَّا قَوْلُ الْبَشَرِؕ اِنْ : نہیں هٰذَآ اِلَّا : یہ مگر (صرف) قَوْلُ الْبَشَرِ : آدمی کا کلام سوائے انسانی کلام کے کچھ بھی نہیں۔
  74,26,سَاُصْلِیْهِ سَقَرَ سَاُصْلِيْهِ : عنقریب اسے ڈالدوں گا سَقَرَ : جہنم میں عنقریب اس دوزخ میں ڈالوں گا۔
  74,27,وَ مَاۤ اَدْرٰىكَ مَا سَقَرُؕ وَمَآ اَدْرٰىكَ : اور تم کیا سمجھے مَا : کیا ہے سَقَرُ : جہنم اور تجھے کیا خبر کہ دوزخ کیا چیز ہے (1)۔
  74,28,لَا تُبْقِیْ وَ لَا تَذَرُۚ لَا تُبْقِيْ : وہ نہ باقی رکھے گی وَلَا تَذَرُ : اور نہ چھوڑے گی نہ وہ باقی رکھتی ہے نہ چھوڑتی ہے (1)
  74,29,لَوَّاحَةٌ لِّلْبَشَرِۚۖ لَوَّاحَةٌ : جھلس دینے والی لِّلْبَشَرِ : آدمی کو کھال کو جھلسا دیتی ہے۔
  74,30,عَلَیْهَا تِسْعَةَ عَشَرَؕ عَلَيْهَا : اس پر ہیں تِسْعَةَ عَشَرَ : انیس (داروغہ) اور اس میں انیس (فرشتے مقرر) ہیں (1)۔
  74,31,وَ مَا جَعَلْنَاۤ اَصْحٰبَ النَّارِ اِلَّا مَلٰٓئِكَةً١۪ وَّ مَا جَعَلْنَا عِدَّتَهُمْ اِلَّا فِتْنَةً لِّلَّذِیْنَ كَفَرُوْا١ۙ لِیَسْتَیْقِنَ الَّذِیْنَ اُوْتُوا الْكِتٰبَ وَ یَزْدَادَ الَّذِیْنَ اٰمَنُوْۤا اِیْمَانًا وَّ لَا یَرْتَابَ الَّذِیْنَ اُوْتُوا الْكِتٰبَ وَ الْمُؤْمِنُوْنَ١ۙ وَ لِیَقُوْلَ الَّذِیْنَ فِیْ قُلُوْبِهِمْ مَّرَضٌ وَّ الْكٰفِرُوْنَ مَا ذَاۤ اَرَادَ اللّٰهُ بِهٰذَا مَثَلًا١ؕ كَذٰلِكَ یُضِلُّ اللّٰهُ مَنْ یَّشَآءُ وَ یَهْدِیْ مَنْ یَّشَآءُ١ؕ وَ مَا یَعْلَمُ جُنُوْدَ رَبِّكَ اِلَّا هُوَ١ؕ وَ مَا هِیَ اِلَّا ذِكْرٰى لِلْبَشَرِ۠    ۧ وَمَا : اور نہیں جَعَلْنَآ : ہم نے بنائے اَصْحٰبَ النَّارِ : دوزخ کے داروغہ اِلَّا : مگر (صرف) مَلٰٓئِكَةً ۠ : فرشتے وَّمَا : اور نہیں جَعَلْنَا : ہم نے رکھی عِدَّتَهُمْ : ان کی تعداد اِلَّا : مگر (صرف) فِتْنَةً : آزمائش کو لِّلَّذِيْنَ : ان لوگوں کیلئے جو كَفَرُوْا ۙ : کافر ہوئے لِيَسْتَيْقِنَ : تاکہ وہ یقین کرلیں الَّذِيْنَ : وہ لوگ جنہیں اُوْتُوا الْكِتٰبَ : کتاب دی گئی (اہل کتاب) وَيَزْدَادَ : اور زیادہ ہو الَّذِيْنَ : جو لوگ اٰمَنُوْٓا : ایمان لائے اِيْمَانًا : ایمان وَّلَا يَرْتَابَ : اور شک نہ کریں الَّذِيْنَ : وہ لوگ جنہیں اُوْتُوا الْكِتٰبَ : کتاب دی گئی وَالْمُؤْمِنُوْنَ ۙ : اور مومن (جمع) وَلِيَقُوْلَ : اور تاکہ وہ کہیں الَّذِيْنَ : وہ لوگ فِيْ قُلُوْبِهِمْ : جن کے دلوں میں مَّرَضٌ : روگ وَّالْكٰفِرُوْنَ : اور کافر (جمع) مَاذَآ : کیا اَرَادَ اللّٰهُ : ارادہ کیا اللہ نے بِهٰذَا مَثَلًا ۭ : اس مثال سے كَذٰلِكَ : اسی طرح يُضِلُّ اللّٰهُ : اللہ گمراہ کرتا ہے مَنْ يَّشَآءُ : جسے وہ چاہتا ہے وَيَهْدِيْ : اور ہدایت دیتا ہے مَنْ يَّشَآءُ ۭ : جسے وہ چاہتا ہے وَمَا يَعْلَمُ : اور نہیں جانتا جُنُوْدَ : لشکروں کو رَبِّكَ : تیرے رب کے اِلَّا هُوَ ۭ : سوائے وہ (خود) وَمَا ھِيَ : اور نہیں یہ اِلَّا ذِكْرٰى : مگر نصیحت لِلْبَشَرِ : آدمی کیلئے ہم نے دوزخ کے دروغے صرف فرشتے رکھے ہیں اور ہم نے ان کی تعداد صرف کافروں کی آزمائش کے لئے مقرر کی ہے (1) تاکہ اہل کتاب یقین کرلیں (2) اور ایماندار ایمان میں اور بڑھ جائیں (3) اور اہل کتاب اور مسلمان شک نہ کریں اور جن کے دلوں میں بیماری ہے اور وہ کافر کہیں کہ اس بیان سے اللہ تعالیٰ کی کیا مراد ہے ؟ (4) اس طرح اللہ تعالیٰ جسے چاہتا ہے گمراہ کرتا ہے اور جسے چاہتا ہے ہدایت دیتا ہے (5) تیرے رب کے لشکروں کو اس کے سوا کوئی نہیں جانتا (6) یہ تو کل بنی آدم کے لیے سراسر پندونصیحت ہے۔ (7)
  74,32,كَلَّا وَ الْقَمَرِۙ كَلَّا : نہیں نہیں وَالْقَمَرِ : قسم ہے چاند کی قسم ہے چاند کی
  74,33,وَ الَّیْلِ اِذْ اَدْبَرَۙ وَالَّيْلِ : اور رات اِذْ اَدْبَرَ : جب وہ پیٹھ پھیرے اور رات جب وہ پیچھے ہٹے۔
  74,34,وَ الصُّبْحِ اِذَاۤ اَسْفَرَۙ وَالصُّبْحِ : اور صبح اِذَآ اَسْفَرَ : جب وہ روشن ہو اور صبح کی جب وہ روشن ہوجائے،
  74,35,اِنَّهَا لَاِحْدَى الْكُبَرِۙ اِنَّهَا لَاِحْدَى الْكُبَرِ : بیشک یہ ایک ہے بڑی (آفت) کہ (یقیناً وہ جہنم) بڑی چیزوں میں سے ایک ہے (1)
  74,36,نَذِیْرًا لِّلْبَشَرِۙ نَذِيْرًا : ڈرانے والی لِّلْبَشَرِ : لوگوں کو بنی آدم کو ڈرانے والی۔
  74,37,لِمَنْ شَآءَ مِنْكُمْ اَنْ یَّتَقَدَّمَ اَوْ یَتَاَخَّرَؕ لِمَنْ : اور جو کوئی شَآءَ : چاہے مِنْكُمْ : تم میں سے اَنْ يَّتَقَدَّمَ : کہ وہ آگے بڑھے اَوْ : یا يَتَاَخَّرَ : پیچھے رہے (یعنی) اسے (1) جو تم میں سے آگے بڑھنا چاہے یا پیچھے ہٹنا چاہئے۔
  74,38,كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ رَهِیْنَةٌۙ كُلُّ نَفْسٍۢ : ہر شخص بِمَا : اس کے بدلے جو كَسَبَتْ : اس نے کمایا (اعمال) رَهِيْنَةٌ : گروی ہر شخص اپنے اعمال کے بدلے میں گروی ہے (1)
  74,39,اِلَّاۤ اَصْحٰبَ الْیَمِیْنِؕۛ اِلَّآ : مگر اَصْحٰبَ الْيَمِيْنِ : داہنی طرف والے مگر دائیں ہاتھ والے (1)
  74,40,فِیْ جَنّٰتٍ١ۛؕ۫ یَتَسَآءَلُوْنَۙ فِيْ جَنّٰتٍ ۺ : باغات میں يَتَسَآءَلُوْنَ : وہ پوچھیں گے اہل جنت بالاخانوں میں بیٹھے وہ سوال کرتے ہونگے گے۔ (1)
  74,41,عَنِ الْمُجْرِمِیْنَۙ عَنِ : سے الْمُجْرِمِيْنَ : گنہگاروں جہنمیوں سے
  74,42,مَا سَلَكَكُمْ فِیْ سَقَرَ مَا : کیا (چیز) سَلَكَكُمْ : تمہیں لے گئی فِيْ : میں سَقَرَ : جہنم تمہیں دوزخ میں کس چیز نے ڈالا۔
  74,43,قَالُوْا لَمْ نَكُ مِنَ الْمُصَلِّیْنَۙ قَالُوْا : وہ کہیں گے لَمْ نَكُ : نہ تھے ہم مِنَ : سے الْمُصَلِّيْنَ : نماز پڑھنے والے وہ جواب دیں گے ہم نمازی نہ تھے۔
  74,44,وَ لَمْ نَكُ نُطْعِمُ الْمِسْكِیْنَۙ وَلَمْ : اور نہ نَكُ : تھے ہم نُطْعِمُ : ہم کھانا کھلاتے الْمِسْكِيْنَ : محتاجوں کو نہ مسکینوں کو کھانا کھلاتے تھے۔ (1)
  74,45,وَ كُنَّا نَخُوْضُ مَعَ الْخَآئِضِیْنَۙ وَكُنَّا : اور ہم تھے نَخُوْضُ : (بیہودہ باتوں میں) دھنستے رہتے تھے مَعَ الْخَآئِضِيْنَ : بیہودہ باتوں میں لگے رہنے والوں کے ساتھ اور ہم بحث کرنے والے (انکاریوں) کا ساتھ دے کر بحث مباحثہ میں مشغول رہا کرتے تھے (1)
  74,46,وَ كُنَّا نُكَذِّبُ بِیَوْمِ الدِّیْنِۙ وَكُنَّا نُكَذِّبُ : اور ہم جھٹلاتے تھے بِيَوْمِ الدِّيْنِ : روز جزا وسزاکو اور روز جزا کو جھٹلاتے تھے۔
  74,47,حَتّٰۤى اَتٰىنَا الْیَقِیْنُؕ حَتّىٰٓ : یہاں تک کہ اَتٰىنَا : آگئی ہمیں الْيَقِيْنُ : موت یہاں تک کہ ہمیں موت آگئی۔
