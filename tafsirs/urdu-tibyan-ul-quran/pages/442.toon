tafsir[13]{c,v,t}:
  36,28,وَ مَاۤ اَنْزَلْنَا عَلٰى قَوْمِهٖ مِنْۢ بَعْدِهٖ مِنْ جُنْدٍ مِّنَ السَّمَآءِ وَ مَا كُنَّا مُنْزِلِیْنَ وَمَآ اَنْزَلْنَا : اور نہیں اتارا عَلٰي : پر قَوْمِهٖ : اس کی قوم مِنْۢ بَعْدِهٖ : اس کے بعد مِنْ جُنْدٍ : کوئی لشکر مِّنَ : سے السَّمَآءِ : آسمان وَمَا كُنَّا : اور نہ تھے ہم مُنْزِلِيْنَ : اتارنے والے اس کے بعد ہم نے اس کی قوم پر آسمان سے کوئی لشکر نہ اتارا (1) اور نہ اس طرح ہم اتارا کرتے ہیں (2)۔
  36,29,اِنْ كَانَتْ اِلَّا صَیْحَةً وَّاحِدَةً فَاِذَا هُمْ خٰمِدُوْنَ اِنْ كَانَتْ : نہ تھی اِلَّا : مگر صَيْحَةً : چنگھاڑ وَّاحِدَةً : ایک فَاِذَا : پس اچانک هُمْ : وہ خٰمِدُوْنَ : بجھ کر رہ گئے وہ تو صرف ایک زور کی چیخ تھی کہ یکایک وہ سب کے سب بجھ بھجا گئے (1)
  36,30,یٰحَسْرَةً عَلَى الْعِبَادِ١ۣۚ مَا یَاْتِیْهِمْ مِّنْ رَّسُوْلٍ اِلَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ يٰحَسْرَةً : ہائے حسرت عَلَي الْعِبَادِ ڱ : بندوں پر مَا يَاْتِيْهِمْ : نہیں آیا ان کے پاس مِّنْ رَّسُوْلٍ : کوئی رسول اِلَّا : مگر كَانُوْا : وہ تھے بِهٖ : اس سے يَسْتَهْزِءُوْنَ : ہنسی اڑاتے (ایسے) بندوں پر افسوس ! (1) کبھی بھی کوئی رسول ان کے پاس نہیں آیا جس کی ہنسی انہوں نے نہ اڑائی ہو۔
  36,31,اَلَمْ یَرَوْا كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنَ الْقُرُوْنِ اَنَّهُمْ اِلَیْهِمْ لَا یَرْجِعُوْنَؕ اَلَمْ يَرَوْا : کیا انہوں نے نہیں دیکھا كَمْ : کتنی اَهْلَكْنَا : ہلاک کیں ہم نے قَبْلَهُمْ : ان سے قبل مِّنَ الْقُرُوْنِ : بستیاں اَنَّهُمْ : کہ وہ اِلَيْهِمْ : ان کی طرف لَا يَرْجِعُوْنَ : لوٹ کر نہیں آئیں گے وہ کیا انہوں نے نہیں دیکھا کہ ان سے پہلے بہت سی قوموں کو ہم نے غارت کردیا کہ وہ ان (1) کی طرف لوٹ کر نہیں آئیں گے۔
  36,32,وَ اِنْ كُلٌّ لَّمَّا جَمِیْعٌ لَّدَیْنَا مُحْضَرُوْنَ۠    ۧ وَاِنْ : اور نہیں كُلٌّ : سب لَّمَّا : مگر جَمِيْعٌ : سب کے سب لَّدَيْنَا : ہمارے روبرو مُحْضَرُوْنَ : حاضر کیے جائیں گے اور نہیں ہے کوئی جماعت مگر یہ وہ جمع ہو کر ہمارے سامنے حاضر کی جائے گی (1)
  36,33,وَ اٰیَةٌ لَّهُمُ الْاَرْضُ الْمَیْتَةُ١ۖۚ اَحْیَیْنٰهَا وَ اَخْرَجْنَا مِنْهَا حَبًّا فَمِنْهُ یَاْكُلُوْنَ وَاٰيَةٌ : ایک نشانی لَّهُمُ : ان کے لیے الْاَرْضُ : زمین الْمَيْتَةُ ښ : مردہ اَحْيَيْنٰهَا : ہم نے زندہ کیا اسے وَاَخْرَجْنَا : اور نکالا ہم نے مِنْهَا : اس سے حَبًّا : اناج فَمِنْهُ : پس اس سے يَاْكُلُوْنَ : وہ کھاتے ہیں اور ان کے لئے ایک نشانی (1) (خشک) زمین ہے جس کو ہم نے زندہ کردیا اور اس سے غلہ نکالا جس میں سے وہ کھاتے ہیں۔
  36,34,وَ جَعَلْنَا فِیْهَا جَنّٰتٍ مِّنْ نَّخِیْلٍ وَّ اَعْنَابٍ وَّ فَجَّرْنَا فِیْهَا مِنَ الْعُیُوْنِۙ وَجَعَلْنَا : اور بنائے ہم نے فِيْهَا : اس میں جَنّٰتٍ : باغات مِّنْ : سے ۔ کے نَّخِيْلٍ : کھجور وَّاَعْنَابٍ : اور انگور وَّفَجَّرْنَا : اور جاری کیے ہم نے فِيْهَا : اس میں مِنَ : سے الْعُيُوْنِ : چشمے اور ہم نے اس میں کھجوروں کے اور انگور کے باغات پیدا کردیئے (1) اور جن میں ہم نے چشمے بھی جاری کردیئے ہیں۔
  36,35,لِیَاْكُلُوْا مِنْ ثَمَرِهٖ١ۙ وَ مَا عَمِلَتْهُ اَیْدِیْهِمْ١ؕ اَفَلَا یَشْكُرُوْنَ لِيَاْكُلُوْا : تاکہ وہ کھائیں مِنْ ثَمَرِهٖ ۙ : اس کے پھلوں سے وَمَا : اور نہیں عَمِلَتْهُ : بنایا اسے اَيْدِيْهِمْ ۭ : ان کے ہاتھوں اَفَلَا يَشْكُرُوْنَ : تو کیا وہ شکر نہ کریں گے تاکہ (لوگ) اس کے پھل کھائیں (1) اور اس کو ان کے ہاتھوں نے نہیں بنایا (2) پھر کیوں شکر گزاری نہیں کرتے۔
  36,36,سُبْحٰنَ الَّذِیْ خَلَقَ الْاَزْوَاجَ كُلَّهَا مِمَّا تُنْۢبِتُ الْاَرْضُ وَ مِنْ اَنْفُسِهِمْ وَ مِمَّا لَا یَعْلَمُوْنَ سُبْحٰنَ : پاک الَّذِيْ : وہ ذات جس نے خَلَقَ : پیدا کیے الْاَزْوَاجَ : جوڑے كُلَّهَا : ہر چیز مِمَّا : اس سے جو تُنْۢبِتُ : اگاتی ہے الْاَرْضُ : زمین وَمِنْ اَنْفُسِهِمْ : اور ان کی جانوں سے وَمِمَّا : اور اس سے جو لَا يَعْلَمُوْنَ : وہ نہیں جانتے وہ پاک ذات ہے جس نے ہر چیز کے جوڑے پیدا کیے خواہ وہ زمین کی اگائی ہوئی چیزیں ہوں، خواہ خود ان کے نفوس ہوں خواہ وہ (چیزیں) ہوں جنہیں یہ جانتے بھی نہیں (1)
  36,37,وَ اٰیَةٌ لَّهُمُ الَّیْلُ١ۖۚ نَسْلَخُ مِنْهُ النَّهَارَ فَاِذَا هُمْ مُّظْلِمُوْنَۙ وَاٰيَةٌ : اور ایک نشانی لَّهُمُ : ان کے لیے الَّيْلُ ښ : رات نَسْلَخُ : ہم کھینچتے ہیں مِنْهُ : اس سے النَّهَارَ : دن فَاِذَا : تو اچانک هُمْ : وہ مُّظْلِمُوْنَ : اندھیرے میں رہ جاتے ہیں اور ان کے لئے ایک نشانی رات ہے جس سے ہم دن کو کھنچ دیتے ہیں تو یکایک اندھیرے میں رہ جاتے ہیں (1)
  36,38,وَ الشَّمْسُ تَجْرِیْ لِمُسْتَقَرٍّ لَّهَا١ؕ ذٰلِكَ تَقْدِیْرُ الْعَزِیْزِ الْعَلِیْمِؕ وَالشَّمْسُ : اور سورج تَجْرِيْ : چلتا رہتا ہے لِمُسْتَقَرٍّ : ٹھکانے (مقررہ راستہ لَّهَا ۭ : اپنے ذٰلِكَ : یہ تَقْدِيْرُ : نظام الْعَزِيْزِ : غالب الْعَلِيْمِ : جاننے والا (دانا) اور سورج کے لئے جو مقررہ راہ ہے وہ اسی پر چلتا رہتا ہے یہ ہے مقرر کردہ غالب، باعلم اللہ تعالیٰ کا۔ (1)
  36,39,وَ الْقَمَرَ قَدَّرْنٰهُ مَنَازِلَ حَتّٰى عَادَ كَالْعُرْجُوْنِ الْقَدِیْمِ وَالْقَمَرَ : اور چاند قَدَّرْنٰهُ : ہم نے مقرر کیں اس کو مَنَازِلَ : منزلیں حَتّٰى : یہاں تک کہ عَادَ : ہوجاتا ہے كَالْعُرْجُوْنِ : کھجور کی شاخ کی طرح الْقَدِيْمِ : پرانی اور چاند کی منزلیں مقرر کر رکھی ہیں (1) کہ وہ لوٹ کر پرانی ٹہنی کی طرح ہوجاتا ہے (2)
  36,40,لَا الشَّمْسُ یَنْۢبَغِیْ لَهَاۤ اَنْ تُدْرِكَ الْقَمَرَ وَ لَا الَّیْلُ سَابِقُ النَّهَارِ١ؕ وَ كُلٌّ فِیْ فَلَكٍ یَّسْبَحُوْنَ لَا : نہ الشَّمْسُ : سورج يَنْۢبَغِيْ : لائق (مجال) لَهَآ : اس کے لیے اَنْ : کہ تُدْرِكَ : جاپکڑے وہ الْقَمَرَ : چاند وَلَا : اور نہ الَّيْلُ : رات سَابِقُ : پہلے آسکے النَّهَارِ ۭ : دن وَكُلٌّ : اور سب فِيْ فَلَكٍ : دائرہ میں يَّسْبَحُوْنَ : تیرے (گردش کرتے) ہیں نہ آفتاب کی یہ مجال ہے کہ چاند کو پکڑے (1) اور نہ رات دن پر آگے بڑھ جانے والی ہے (2) اور سب کے سب آسمان میں تیرتے پھرتے ہیں (3)۔
