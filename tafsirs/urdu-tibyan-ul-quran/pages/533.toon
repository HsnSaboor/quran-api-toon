tafsir[27]{c,v,t}:
  55,41,یُعْرَفُ الْمُجْرِمُوْنَ بِسِیْمٰىهُمْ فَیُؤْخَذُ بِالنَّوَاصِیْ وَ الْاَقْدَامِۚ يُعْرَفُ الْمُجْرِمُوْنَ : پہچانے جائیں گے مجرم بِسِيْمٰهُمْ : اپنے چہروں کے ساتھ فَيُؤْخَذُ بالنَّوَاصِيْ : تو پکڑے جائیں گے پیشانی کے بالوں سے وَالْاَقْدَامِ : اور قدموں سے گناہگار صرف حلیہ سے ہی پہچانے جائیں گے (1) اور ان کے پیشانیوں کے بال اور قدم پکڑ لئے جائیں گے (2)۔
  55,42,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,43,هٰذِهٖ جَهَنَّمُ الَّتِیْ یُكَذِّبُ بِهَا الْمُجْرِمُوْنَۘ هٰذِهٖ : یہ ہے جَهَنَّمُ : وہ جہنم الَّتِيْ : وہ جو يُكَذِّبُ : جھٹلاتے تھے بِهَا : جس کو الْمُجْرِمُوْنَ : مجرم یہ ہے وہ جہنم جسے مجرم جھوٹا جانتے تھے۔
  55,44,یَطُوْفُوْنَ بَیْنَهَا وَ بَیْنَ حَمِیْمٍ اٰنٍۚ يَطُوْفُوْنَ بَيْنَهَا : گردش کریں گے اس کے درمیان وَبَيْنَ : اور درمیان حَمِيْمٍ : کھولتے پانی کے اٰنٍ : جو سخت گرم ہوگا۔ شدید گرم ہوگا اس کے اور کھولتے ہوئے گرم پانی کے درمیان چکر کھائیں گے (1)
  55,45,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ۠    ۧ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,46,وَ لِمَنْ خَافَ مَقَامَ رَبِّهٖ جَنَّتٰنِۚ وَلِمَنْ خَافَ : اور واسطے اس کے جو ڈرے مَقَامَ رَبِّهٖ : اپنے رب کے سامنے کھڑے ہونے سے جَنَّتٰنِ : دو باغ ہیں اور اس شخص کے لئے جو اپنے رب کے سامنے کھڑا ہونے سے ڈرا دو جنتیں ہیں (1)
  55,47,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۙ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,48,ذَوَاتَاۤ اَفْنَانٍۚ ذَوَاتَآ اَفْنَانٍ : ہری بھری ڈالیوں والے (دونوں جنتیں) بہت سی ٹہنیوں اور شاخوں والی ہیں (1)
  55,49,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,50,فِیْهِمَا عَیْنٰنِ تَجْرِیٰنِۚ فِيْهِمَا عَيْنٰنِ : ان دونوں میں دو چشمے ہیں تَجْرِيٰنِ : بہتے ہوئے ان دونوں (جنتوں) میں دو بہتے ہوئے چشمے ہیں (1)
  55,51,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,52,فِیْهِمَا مِنْ كُلِّ فَاكِهَةٍ زَوْجٰنِۚ فِيْهِمَا : ان دونوں میں مِنْ كُلِّ فَاكِهَةٍ : ہر قسم کے پھلوں میں سے ہیں زَوْجٰنِ : دو قسم ان دونوں جنتوں میں ہر قسم کے میووں کی دو قسمیں ہونگی (1)
  55,53,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,54,مُتَّكِئِیْنَ عَلٰى فُرُشٍۭ بَطَآئِنُهَا مِنْ اِسْتَبْرَقٍ١ؕ وَ جَنَا الْجَنَّتَیْنِ دَانٍۚ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے ہوں گے عَلٰي فُرُشٍۢ : ایسے فرشوں پر بَطَآئِنُهَا : ان کے استر مِنْ اِسْتَبْرَقٍ ۭ : موٹے تافتے کے ہوں گے وَجَنَا الْجَنَّتَيْنِ : اور پھل دونوں باغوں کے۔ پھل توڑیں گے دونوں باغوں کے دَانٍ : قریب قریب ہوں گے۔ جھکے ہوئے ہوں گے جنتی ایسے فرشوں پر تکیہ لگائے ہوئے ہونگے جن کے استر و بیز ریشم کے ہونگے (1) اور دونوں جنتوں کے میوے بالکل قریب ہونگے (2)
  55,55,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,56,فِیْهِنَّ قٰصِرٰتُ الطَّرْفِ١ۙ لَمْ یَطْمِثْهُنَّ اِنْسٌ قَبْلَهُمْ وَ لَا جَآنٌّۚ فِيْهِنَّ : ان میں ہوں گی قٰصِرٰتُ : جھکانے والیاں الطَّرْفِ ۙ : نگاہوں کو لَمْ يَطْمِثْهُنَّ : نہیں چھوا ہوگا ان کو اِنْسٌ : کسی انسان نے قَبْلَهُمْ : ان سے پہلے وَلَا جَآنٌّ : اور نہ کسی جن نے وہاں (شرمیلی) نیچی نگاہ والی حوریں ہیں (1) جنہیں ان سے پہلے کسی جن و انس نے ہاتھ نہیں لگایا (2)
  55,57,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,58,كَاَنَّهُنَّ الْیَاقُوْتُ وَ الْمَرْجَانُۚ كَاَنَّهُنَّ الْيَاقُوْتُ : گویا کہ وہ یاقوت ہیں وَالْمَرْجَانُ : اور موتی وہ حوریں مثل یاقوت اور مونگے کے ہوں گی (1)
  55,59,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,60,هَلْ جَزَآءُ الْاِحْسَانِ اِلَّا الْاِحْسَانُۚ هَلْ : کیا جَزَآءُ : بدلہ ہے الْاِحْسَانِ : احسن کا اِلَّا الْاِحْسَانُ : سوائے احسان کے (کچھ اور ہے ؟ ) احسان کا بدلہ احسان کے سوا کیا ہے (1)
  55,61,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,62,وَ مِنْ دُوْنِهِمَا جَنَّتٰنِۚ وَمِنْ دُوْنِهِمَا : اور ان دونوں کے علاوہ جَنَّتٰنِ : دو باغ ہیں اور ان کے سوا دو جنتیں اور ہیں (1)۔
  55,63,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۙ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,64,مُدْهَآ مَّتٰنِۚ مُدْهَآمَّتٰنِ : نہایت سبز جو دونوں گہری سبز سیاہی مائل ہیں (1)۔
  55,65,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,66,فِیْهِمَا عَیْنٰنِ نَضَّاخَتٰنِۚ فِيْهِمَا عَيْنٰنِ : ان دونوں میں دو چشمے ہیں نَضَّاخَتٰنِ : جوش مارنے والے ان میں دو (جوش سے) ابلنے والے چشمے ہیں (1)
  55,67,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
