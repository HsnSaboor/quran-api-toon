tafsir[12]{c,v,t}:
  20,65,قَالُوْا یٰمُوْسٰۤى اِمَّاۤ اَنْ تُلْقِیَ وَ اِمَّاۤ اَنْ نَّكُوْنَ اَوَّلَ مَنْ اَلْقٰى قَالُوْا : وہ بولے يٰمُوْسٰٓى : اے موسیٰ اِمَّآ : یا تو اَنْ تُلْقِيَ : یہ کہ تو ڈالے وَاِمَّآ : اور یا اَنْ نَّكُوْنَ : یہ کہ ہم ہوں اَوَّلَ : پہلے مَنْ : جو اَلْقٰي : ڈالیں کہنے لگے اے موسٰی ! یا تو پہلے ڈال یا ہم پہلے ڈالنے والے بن جائیں۔
  20,66,قَالَ بَلْ اَلْقُوْا١ۚ فَاِذَا حِبَالُهُمْ وَ عِصِیُّهُمْ یُخَیَّلُ اِلَیْهِ مِنْ سِحْرِهِمْ اَنَّهَا تَسْعٰى قَالَ : اس نے کہا بَلْ : بلکہ اَلْقُوْا : تم ڈالو فَاِذَا : تو ناگہاں حِبَالُهُمْ : ان کی رسیاں وَعِصِيُّهُمْ : اور ان کی لاٹھیاں يُخَيَّلُ : خیال میں آئیں اِلَيْهِ : اس کے مِنْ : سے سِحْرِهِمْ : ان کا جادو اَنَّهَا : کہ وہ تَسْعٰي : دوڑ رہی ہیں جواب دیا کہ نہیں تم ہی پہلے ڈالو (1) اب تو موسیٰ ؑ کو یہ خیال گزرنے لگا کہ ان کی رسیاں اور لکڑیاں ان کے جادو کے زور سے دوڑ بھاگ رہی ہیں (2)
  20,67,فَاَوْجَسَ فِیْ نَفْسِهٖ خِیْفَةً مُّوْسٰى فَاَوْجَسَ : تو پایا (محسوس کیا) فِيْ نَفْسِهٖ : اپنے دل میں خِيْفَةً : کچھ خوف مُّوْسٰى : موسیٰ پس موسیٰ ؑ نے اپنے دل ہی دل میں ڈر محسوس کیا۔
  20,68,قُلْنَا لَا تَخَفْ اِنَّكَ اَنْتَ الْاَعْلٰى قُلْنَا : ہم نے کہا لَا تَخَفْ : تم ڈرو نہیں اِنَّكَ : بیشک تم اَنْتَ : تم (ہی) الْاَعْلٰى : غالب ہم نے فرمایا کچھ خوف نہ کر یقیناً تو ہی غالب اور برتر رہے گا (1)۔
  20,69,وَ اَلْقِ مَا فِیْ یَمِیْنِكَ تَلْقَفْ مَا صَنَعُوْا١ؕ اِنَّمَا صَنَعُوْا كَیْدُ سٰحِرٍ١ؕ وَ لَا یُفْلِحُ السَّاحِرُ حَیْثُ اَتٰى وَاَلْقِ : اور ڈالو مَا : جو فِيْ يَمِيْنِكَ : تمہارے دائیں ہاتھ میں تَلْقَفْ : وہ نگل جائے گا مَا صَنَعُوْا : جو انہوں نے بنایا اِنَّمَا : بیشک صَنَعُوْا : انہوں نے بنایا كَيْدُ : فریب سٰحِرٍ : جادوگر وَلَا يُفْلِحُ : اور کامیاب نہیں ہوگا السَّاحِرُ : جادوگر حَيْثُ : جہاں (کہیں) اَتٰى : وہ آئے اور تیرے دائیں ہاتھ میں جو ہے اسے ڈال دے کہ ان کی تمام کاریگری کو وہ نگل جائے، انہوں نے جو کچھ بنایا ہے یہ صرف جادوگروں کے کرتب ہیں اور جادوگر کہیں سے بھی آئے کامیاب نہیں ہوتا۔
  20,70,فَاُلْقِیَ السَّحَرَةُ سُجَّدًا قَالُوْۤا اٰمَنَّا بِرَبِّ هٰرُوْنَ وَ مُوْسٰى فَاُلْقِيَ : پس ڈالدئیے گئے السَّحَرَةُ : جادوگر سُجَّدًا : سجدہ میں قَالُوْٓا : وہ بولے اٰمَنَّا : ہم ایمان لائے بِرَبِّ : رب پر هٰرُوْنَ : ہارون وَمُوْسٰى : اور موسیٰ اب تو تمام جادوگر سجدے میں گرپڑے اور پکار اٹھے کہ ہم تو ہارون اور موسیٰ (علیہما السلام) کے رب پر ایمان لائے
  20,71,قَالَ اٰمَنْتُمْ لَهٗ قَبْلَ اَنْ اٰذَنَ لَكُمْ١ؕ اِنَّهٗ لَكَبِیْرُكُمُ الَّذِیْ عَلَّمَكُمُ السِّحْرَ١ۚ فَلَاُقَطِّعَنَّ اَیْدِیَكُمْ وَ اَرْجُلَكُمْ مِّنْ خِلَافٍ وَّ لَاُصَلِّبَنَّكُمْ فِیْ جُذُوْعِ النَّخْلِ١٘ وَ لَتَعْلَمُنَّ اَیُّنَاۤ اَشَدُّ عَذَابًا وَّ اَبْقٰى قَالَ : اس نے کہا اٰمَنْتُمْ : تم ایمان لائے لَهٗ : اس پر قَبْلَ : پہلے اَنْ اٰذَنَ : کہ میں اجازت دوں لَكُمْ : تمہیں اِنَّهٗ : بیشک وہ لَكَبِيْرُكُمُ : تمہارا بڑا الَّذِيْ : وہ جس نے عَلَّمَكُمُ : تمہیں سکھایا السِّحْرَ : جادو فَلَاُقَطِّعَنَّ : پس میں ضرور کاٹوں گا اَيْدِيَكُمْ : تمہارے ہاتھ وَاَرْجُلَكُمْ : اور تمہارے پاؤں مِّنْ خِلَافٍ : دوسری طرف سے وَّلَاُوصَلِّبَنَّكُمْ : اور میں تمہیں ضرور سولی دوں گا فِيْ : میں۔ پر جُذُوْعِ النَّخْلِ : کھجور کے تنے وَلَتَعْلَمُنَّ : اور تم خوب جان لوگے اَيُّنَآ : ہم میں کون اَشَدُّ : زیادہ سخت عَذَابًا : عذاب میں وَّاَبْقٰي : اور تا دیر رہنے والا فرعون کہنے لگا کہ کیا میری اجازت سے پہلے ہی تم اس پر ایمان لے آئے ؟ یقیناً تمہارا بڑا بزرگ ہے جس نے تم سب کو جادو سکھایا ہے، (سن لو) میں تمہارے ہاتھ پاؤں الٹے سیدھے (1) کٹوا کر تم سب کو کھجور کے تنوں میں سولی پر لٹکوا دوں گا، اور تمہیں پوری طرح معلوم ہوجائے گا کہ ہم میں سے کس کی مار زیادہ سخت اور دیرپا ہے۔
  20,72,قَالُوْا لَنْ نُّؤْثِرَكَ عَلٰى مَا جَآءَنَا مِنَ الْبَیِّنٰتِ وَ الَّذِیْ فَطَرَنَا فَاقْضِ مَاۤ اَنْتَ قَاضٍ١ؕ اِنَّمَا تَقْضِیْ هٰذِهِ الْحَیٰوةَ الدُّنْیَاؕ قَالُوْا : انہوں نے کہا لَنْ نُّؤْثِرَكَ : ہم ہرگز تجھے ترجیح نہ دیں گے عَلٰي : پر مَا جَآءَنَا : جو ہمارے پاس آئے مِنَ الْبَيِّنٰتِ : واضح دلائل سے وَالَّذِيْ فَطَرَنَا : اور وہ جس نے ہمیں پیدا کیا فَاقْضِ : پس تو کر گزر مَآ : جو اَنْتَ : تو قَاضٍ : کرنے والا اِنَّمَا : اس کے سوا نہیں تَقْضِيْ : تو کرے گا هٰذِهِ : اس الْحَيٰوةَ الدُّنْيَا : دنیا کی زندگی انہوں نے جواب دیا کہ ناممکن ہے کہ ہم تجھے ترجیح دیں ان دلیلوں پر جو ہمارے سامنے آچکیں ہیں، اور اس اللہ پر جس نے ہمیں پیدا کیا ہے (1) اب تو تو جو کچھ کرنے والا ہے کر گزر، تو جو کچھ بھی حکم چلا سکتا ہے وہ اسی دنیاوی زندگی (2) میں ہی ہے۔
  20,73,اِنَّاۤ اٰمَنَّا بِرَبِّنَا لِیَغْفِرَ لَنَا خَطٰیٰنَا وَ مَاۤ اَكْرَهْتَنَا عَلَیْهِ مِنَ السِّحْرِ١ؕ وَ اللّٰهُ خَیْرٌ وَّ اَبْقٰى اِنَّآ اٰمَنَّا : بیشک ہم ایمان لائے بِرَبِّنَا : اپنے رب پر لِيَغْفِرَ لَنَا : کہ وہ بخشدے خَطٰيٰنَا : ہماری خطائیں وَمَآ : اور جو اَكْرَهْتَنَا : تو نے ہمیں مجبور کیا عَلَيْهِ : اس پر مِنَ : سے السِّحْرِ : جادو وَاللّٰهُ : اور اللہ خَيْرٌ : بہتر وَّاَبْقٰي : اور ہمیشہ باقی رہنے والا ہم (اس امید سے) اپنے پروردگار پر ایمان لائے کہ وہ ہماری خطائیں معاف فرما دے اور (خاص کر) جادوگری (کا گناہ) جس پر تم نے ہمیں مجبور کیا ہے (1) اللہ ہی بہتر اور ہمیشہ باقی رہنے والا ہے (2)۔
  20,74,اِنَّهٗ مَنْ یَّاْتِ رَبَّهٗ مُجْرِمًا فَاِنَّ لَهٗ جَهَنَّمَ١ؕ لَا یَمُوْتُ فِیْهَا وَ لَا یَحْیٰى اِنَّهٗ : بیشک وہ مَنْ يَّاْتِ : جو آیا رَبَّهٗ : اپنے رب کے سامنے مُجْرِمًا : مجرم بن کر فَاِنَّ : تو بیشک لَهٗ : اس کے لیے جَهَنَّمَ : جہنم لَا يَمُوْتُ : نہ وہ مرے گا فِيْهَا : اس میں وَ : اور لَا يَحْيٰي : نہ جئے گا بات یہی ہے کہ جو بھی گناہ گار بن کر اللہ تعالیٰ کے ہاں حاضر ہوگا اس کے لئے دوزخ ہے، جہاں نہ موت ہوگی اور نہ زندگی (1)
  20,75,وَ مَنْ یَّاْتِهٖ مُؤْمِنًا قَدْ عَمِلَ الصّٰلِحٰتِ فَاُولٰٓئِكَ لَهُمُ الدَّرَجٰتُ الْعُلٰىۙ وَمَنْ : اور جو يَّاْتِهٖ : اس کے پاس آیا مُؤْمِنًا : مومن بن کر قَدْ عَمِلَ : اس نے کیے عمل الصّٰلِحٰتِ : اچھے فَاُولٰٓئِكَ : پس یہی لوگ لَهُمُ : ان کے لیے الدَّرَجٰتُ : درجے الْعُلٰي : بلند اور جو بھی اس کے پاس ایماندار ہو کر حاضر ہوگا اور اس نے اعمال بھی نیک کئے ہونگے اس کے لئے بلند وبالا درجے ہیں۔
  20,76,جَنّٰتُ عَدْنٍ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ خٰلِدِیْنَ فِیْهَا١ؕ وَ ذٰلِكَ جَزٰٓؤُا مَنْ تَزَكّٰى۠    ۧ جَنّٰتُ : باغات عَدْنٍ : ہمیشہ رہنے والے تَجْرِيْ : جاری ہیں مِنْ تَحْتِهَا : ان کے نیچے الْاَنْهٰرُ : نہریں خٰلِدِيْنَ : ہمیشہ رہیں گے فِيْهَا : اس میں وَذٰلِكَ : اور یہ جَزٰٓؤُا : جزا ہے مَنْ تَزَكّٰى : جو پاک ہوا ہمیشگی والی جنتیں جن کے نیچے نہریں بہہ رہی ہیں جہاں وہ ہمیشہ ہمیشہ رہیں گے۔ یہی انعام ہے ہر اس شخص کا جو پاک ہوا (1)۔
