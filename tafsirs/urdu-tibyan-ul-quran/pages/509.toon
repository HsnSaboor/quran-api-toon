tafsir[10]{c,v,t}:
  47,20,وَ یَقُوْلُ الَّذِیْنَ اٰمَنُوْا لَوْ لَا نُزِّلَتْ سُوْرَةٌ١ۚ فَاِذَاۤ اُنْزِلَتْ سُوْرَةٌ مُّحْكَمَةٌ وَّ ذُكِرَ فِیْهَا الْقِتَالُ١ۙ رَاَیْتَ الَّذِیْنَ فِیْ قُلُوْبِهِمْ مَّرَضٌ یَّنْظُرُوْنَ اِلَیْكَ نَظَرَ الْمَغْشِیِّ عَلَیْهِ مِنَ الْمَوْتِ١ؕ فَاَوْلٰى لَهُمْۚ وَيَقُوْلُ : اور وہ کہتے ہیں الَّذِيْنَ : وہ لوگ جو اٰمَنُوْا : ایمان لائے لَوْلَا نُزِّلَتْ : کیوں نہ اتاری گئی سُوْرَةٌ ۚ : ایک سورة فَاِذَآ : سو جب اُنْزِلَتْ : اتاری جاتی ہے سُوْرَةٌ : سورة مُّحْكَمَةٌ : صاف صاف معانی والی وَّذُكِرَ : اور ذکر کیا جاتا ہے فِيْهَا : اس میں الْقِتَالُ ۙ : جنگ رَاَيْتَ الَّذِيْنَ : تم دیکھوگے وہ لوگ فِيْ قُلُوْبِهِمْ : ان کے دلوں میں مَّرَضٌ : بیماری يَّنْظُرُوْنَ : وہ دیکھتے ہیں اِلَيْكَ : آپ کی طرف نَظَرَ : دیکھنا الْمَغْشِيِّ : بیہوشی طاری ہوگئی عَلَيْهِ : اس پر مِنَ الْمَوْتِ ۭ : موت کی فَاَوْلٰى : سو خرابی لَهُمْ : ان کے لئے اور جو لوگ ایمان لائے اور کہتے ہیں کوئی سورت کیوں نازل نہیں کی گئی ؟ (1) پھر جب کوئی صاف مطلب والی سورت (2) نازل کی جاتی ہے اور اس میں قتال کا ذکر کیا جاتا ہے تو آپ دیکھتے ہیں کہ جن لوگوں کے دلوں میں بیماری ہے وہ آپ کی طرف اس طرح دیکھتے ہیں جیسے اس شخص کی نظر ہوتی ہے جس پر موت کی بیہوشی طاری ہو (3) پس بہت بہتر تھا ان کے لئے۔
  47,21,طَاعَةٌ وَّ قَوْلٌ مَّعْرُوْفٌ١۫ فَاِذَا عَزَمَ الْاَمْرُ١۫ فَلَوْ صَدَقُوا اللّٰهَ لَكَانَ خَیْرًا لَّهُمْۚ طَاعَةٌ : اطاعت وَّقَوْلٌ : اور بات مَّعْرُوْفٌ ۣ : معقول فَاِذَا : پھر جب عَزَمَ الْاَمْرُ ۣ : پختہ ہوجائے کام فَلَوْ صَدَقُوا : تو اگر وہ سچے ہوتے اللّٰهَ : اللہ لَكَانَ خَيْرًا لَّهُمْ : البتہ ہوتا بہتر ان کیلئے فرمان کا بجا لانا اور اچھی بات کا کہنا پھر جب کام مقرر ہوجائے (1) تو اگر اللہ کے ساتھ سچے رہیں (2) تو ان کے لئے بہتری ہے (3)۔
  47,22,فَهَلْ عَسَیْتُمْ اِنْ تَوَلَّیْتُمْ اَنْ تُفْسِدُوْا فِی الْاَرْضِ وَ تُقَطِّعُوْۤا اَرْحَامَكُمْ فَهَلْ عَسَيْتُمْ : سو تم اسکے نزدیک اِنْ تَوَلَّيْتُمْ : اگر تم والی (حاکم) ہوجاؤ اَنْ : کہ تُفْسِدُوْا : تم فساد مچاؤ فِي الْاَرْضِ : زمین میں وَتُقَطِّعُوْٓا : اور تم کاٹو (توڑ ڈالو) اَرْحَامَكُمْ : اپنے رشتے اور تم سے یہ بھی بعید نہیں کہ اگر تم کو حکومت مل جائے تو تم زمین میں فساد برپا کردو (1) اور رشتے ناتے توڑ ڈالو۔
  47,23,اُولٰٓئِكَ الَّذِیْنَ لَعَنَهُمُ اللّٰهُ فَاَصَمَّهُمْ وَ اَعْمٰۤى اَبْصَارَهُمْ اُولٰٓئِكَ : یہی ہیں الَّذِيْنَ : وہ لوگ جن پر لَعَنَهُمُ اللّٰهُ : اللہ نے لعنت کی فَاَصَمَّهُمْ : پھر ان کو بہرا کردیا وَاَعْمٰٓى : اور اندھا کردیا اَبْصَارَهُمْ : ان کی آنکھیں یہ وہی لوگ ہیں جن پر اللہ کی پھٹکار ہے اور جن کی سماعت اور آنکھوں کی روشنی چھین لی ہے (1)۔
  47,24,اَفَلَا یَتَدَبَّرُوْنَ الْقُرْاٰنَ اَمْ عَلٰى قُلُوْبٍ اَقْفَالُهَا اَفَلَا يَتَدَبَّرُوْنَ : تو کیا وہ غور نہیں کرتے الْقُرْاٰنَ : قرآن اَمْ : کیا عَلٰي : پر قُلُوْبٍ : دلوں اَقْفَالُهَا : ان کے تالے کیا یہ قرآن میں غورو فکر نہیں کرتے ؟ یا ان کے دلوں پر ان کے تالے لگ گئے ہیں (1)۔
  47,25,اِنَّ الَّذِیْنَ ارْتَدُّوْا عَلٰۤى اَدْبَارِهِمْ مِّنْۢ بَعْدِ مَا تَبَیَّنَ لَهُمُ الْهُدَى١ۙ الشَّیْطٰنُ سَوَّلَ لَهُمْ١ؕ وَ اَمْلٰى لَهُمْ اِنَّ الَّذِيْنَ : بیشک جو لوگ ارْتَدُّوْا : پلٹ گئے عَلٰٓي اَدْبَارِهِمْ : اپنی پشت پر مِّنْۢ بَعْدِ : اس کے بعد مَا تَبَيَّنَ : جب واضح ہوگئی لَهُمُ : ان کے لئے الْهُدَى ۙ : ہدایت الشَّيْطٰنُ : شیطان سَوَّلَ : آراستہ کر دکھایا لَهُمْ ۭ : ان کے لئے وَاَمْلٰى : اور ڈھیل دی لَهُمْ : ان کو جو لوگ اپنی پیٹھ کے بل الٹے پھرگئے اس کے بعد کہ ان کے لئے ہدایت واضح (1) ہوچکی یقیناً شیطان نے ان کے لئے (ان کے فعل کو) مزین کردیا ہے اور انہیں ڈھیل دے رکھی ہے۔ (2)
  47,26,ذٰلِكَ بِاَنَّهُمْ قَالُوْا لِلَّذِیْنَ كَرِهُوْا مَا نَزَّلَ اللّٰهُ سَنُطِیْعُكُمْ فِیْ بَعْضِ الْاَمْرِ١ۖۚ وَ اللّٰهُ یَعْلَمُ اِسْرَارَهُمْ ذٰلِكَ : یہ بِاَنَّهُمْ : اس لئے کہ وہ قَالُوْا : انہوں نے کہا لِلَّذِيْنَ : ان لوگوں سے جنہوں نے كَرِهُوْا : انہوں نے ناپسند کیا مَا نَزَّلَ اللّٰهُ : جو نازل کیا اللہ نے سَنُطِيْعُكُمْ : عنقریب ہم تمہارا کہنا مان لیں گے فِيْ بَعْضِ الْاَمْرِ ښ : بعض کاموں میں وَاللّٰهُ : اور اللہ يَعْلَمُ : جانتا ہے اِسْرَارَهُمْ : ان کی خفیہ باتیں یہ (1) اس لئے کہ انہوں نے ان لوگوں سے جنہوں نے اللہ کی نازل کردہ وحی کو برا سمجھا (2) کہ ہم بھی عنقریب بعض کاموں (3) میں تمہارا کہا مانیں گے، اور اللہ ان کی پوشیدہ باتیں خوب جانتا ہے۔ (4)
  47,27,فَكَیْفَ اِذَا تَوَفَّتْهُمُ الْمَلٰٓئِكَةُ یَضْرِبُوْنَ وُجُوْهَهُمْ وَ اَدْبَارَهُمْ فَكَيْفَ : پس کیسا اِذَا تَوَفَّتْهُمُ : جب ان کی روح قبض کریں گے الْمَلٰٓئِكَةُ : فرشتے يَضْرِبُوْنَ : وہ مارتے ہیں وُجُوْهَهُمْ : ان کے چہروں وَاَدْبَارَهُمْ : اور ان کی پیٹھوں پس ان کی کیسی (درگت) ہوگی جبکہ فرشتے ان کی روح قبض کرتے ہوئے ان کے چہروں اور ان کی سروں پر ماریں گے (1)۔
  47,28,ذٰلِكَ بِاَنَّهُمُ اتَّبَعُوْا مَاۤ اَسْخَطَ اللّٰهَ وَ كَرِهُوْا رِضْوَانَهٗ فَاَحْبَطَ اَعْمَالَهُمْ۠    ۧ ذٰلِكَ : یہ بِاَنَّهُمُ : اس لئے کہ انہوں نے اتَّبَعُوْا : پیروی کی مَآ اَسْخَطَ : جس نے ناراض کیا اللّٰهَ : اللہ کو وَكَرِهُوْا : اور انہوں نے پسند نہ کیا رِضْوَانَهٗ : اس کی رضا فَاَحْبَطَ : تو اس نے اکارت کردئیے اَعْمَالَهُمْ : ان کے اعمال یہ اس بنا پر کہ یہ وہ راہ چلے جس سے انہوں نے اللہ کو ناراض کردیا اور انہوں نے اس کی رضامندی کو برا جانا، تو اللہ نے ان کے اعمال اکارت کردیئے۔
  47,29,اَمْ حَسِبَ الَّذِیْنَ فِیْ قُلُوْبِهِمْ مَّرَضٌ اَنْ لَّنْ یُّخْرِجَ اللّٰهُ اَضْغَانَهُمْ اَمْ حَسِبَ : کیا گمان کرتے ہیں الَّذِيْنَ : (وہ لوگ) جن فِيْ قُلُوْبِهِمْ : ان کے دلوں میں مَّرَضٌ : روگ اَنْ : کہ لَّنْ يُّخْرِجَ : ہرگز ظاہر نہ کرے گا اللّٰهُ : اللہ اَضْغَانَهُمْ : ان کے دل کی عداوتیں کیا ان لوگوں نے جن کے دلوں میں بیماری ہے یہ سمجھ رکھا ہے کہ اللہ ان کے حسد اور کینوں کو ظاہر ہی نہ کر دے (1) ،
