tafsir[19]{c,v,t}:
  73,1,یٰۤاَیُّهَا الْمُزَّمِّلُۙ يٰٓاَيُّهَا الْمُزَّمِّلُ : اے کپڑوں میں لپٹنے والے (محمد) اے کپڑے میں لپٹنے والے (1)
  73,2,قُمِ الَّیْلَ اِلَّا قَلِیْلًاۙ قُمِ الَّيْلَ : رات میں قیام کریں اِلَّا قَلِيْلًا : مگر تھوڑا رات (کے وقت نماز) میں کھڑے ہوجاؤ مگر کم (1)
  73,3,نِّصْفَهٗۤ اَوِ انْقُصْ مِنْهُ قَلِیْلًاۙ نِّصْفَهٗٓ : اس کا نصف اَوِ انْقُصْ : یا کم کرلیں مِنْهُ قَلِيْلًا : اس میں سے تھوڑا آدھی رات یا اس سے بھی کچھ کم کرلے۔
  73,4,اَوْ زِدْ عَلَیْهِ وَ رَتِّلِ الْقُرْاٰنَ تَرْتِیْلًاؕ اَوْ زِدْ : یا زیادہ کرلیں عَلَيْهِ : اس پر، سے وَرَتِّلِ الْقُرْاٰنَ : اور ٹھہر ٹھہر کر پڑھیں قرآن تَرْتِيْلًا : ترتیل کے ساتھ یا اس پر بڑھا دے (1) اور قرآن ٹھہر ٹھہر کر (صاف) پڑھا کرو (2)
  73,5,اِنَّا سَنُلْقِیْ عَلَیْكَ قَوْلًا ثَقِیْلًا اِنَّا سَنُلْقِيْ : بیشک ہم عنقریب ڈال دیں گے عَلَيْكَ : آپ پر قَوْلًا ثَقِيْلًا : ایک کلام بھاری یقیناً ہم تجھ پر بہت بھاری بات عنقریب نازل کریں گے (1)
  73,6,اِنَّ نَاشِئَةَ الَّیْلِ هِیَ اَشَدُّ وَطْاً وَّ اَقْوَمُ قِیْلًاؕ اِنَّ : بیشک نَاشِئَةَ : اٹھنا الَّيْلِ : رات هِيَ : یہ اَشَدُّ : سخت (نفس کو) وَطْاً : روندنے والا وَّاَقْوَمُ : اور زیادہ درست قِيْلًا : الفاظ کے تلفظ میں بیشک رات کا اٹھنا دل جمعی کے لئے انتہائی مناسب ہے اور بات کو بالکل درست کردینے والا ہے (1)
  73,7,اِنَّ لَكَ فِی النَّهَارِ سَبْحًا طَوِیْلًاؕ اِنَّ لَكَ : بیشک آپ کیلئے فِي النَّهَارِ : دن میں سَبْحًا : شغل طَوِيْلًا : طویل یقیناً تجھے دن میں بہت شغل رہتا ہے (1)
  73,8,وَ اذْكُرِ اسْمَ رَبِّكَ وَ تَبَتَّلْ اِلَیْهِ تَبْتِیْلًاؕ وَاذْكُرِ : اور آپ یاد کریں اسْمَ : نام رَبِّكَ : اپنارب وَتَبَتَّلْ : اور چھوٹ جائیں اِلَيْهِ : اس کی طرف تَبْتِيْلًا : (سب سے) چھوٹ کر تو اپنے رب کے نام کا ذکر کیا کر اور تمام مخلوقات سے کٹ کر اس کی طرف متوجہ ہوجا۔ (1)
  73,9,رَبُّ الْمَشْرِقِ وَ الْمَغْرِبِ لَاۤ اِلٰهَ اِلَّا هُوَ فَاتَّخِذْهُ وَكِیْلًا رَبُّ : رب الْمَشْرِقِ : مشرق کا وَالْمَغْرِبِ : اور مغرب لَآ اِلٰهَ : نہیں کوئی معبود اِلَّا هُوَ : اس کے سوا فَاتَّخِذْهُ : پس پکڑ لو (بنالو) اسکو وَكِيْلًا : کارساز مشرق و مغرب کا پروردگار جس کے سوا کوئی معبود نہیں، تو اسی کو اپنا کارساز بنا لے۔
  73,10,وَ اصْبِرْ عَلٰى مَا یَقُوْلُوْنَ وَ اهْجُرْهُمْ هَجْرًا جَمِیْلًا وَاصْبِرْ : اور آپ صبر کریں عَلٰي : اس پر مَا : جو يَقُوْلُوْنَ : وہ کہتے ہیں وَاهْجُرْهُمْ : اور انہیں چھوڑدیں هَجْرًا : کنارہ کش ہوکر جَمِيْلًا : اچھی طرح اور جو کچھ وہ کہیں تو سہتا رہ اور وضعداری کے ساتھ ان سے الگ تھلگ رہ۔
  73,11,وَ ذَرْنِیْ وَ الْمُكَذِّبِیْنَ اُولِی النَّعْمَةِ وَ مَهِّلْهُمْ قَلِیْلًا وَذَرْنِيْ : اور مجھے چھوڑدو وَالْمُكَذِّبِيْنَ : اور جھٹلانے والوں اُولِي النَّعْمَةِ : خوشحال لوگوں وَمَهِّلْهُمْ : اور ان کو مہلت دیدیں قَلِيْلًا : تھوڑی اور مجھے اور ان جھٹلانے والے آسودہ حال لوگوں کو چھوڑ دے اور انہیں ذرا سی مہلت دے۔
  73,12,اِنَّ لَدَیْنَاۤ اَنْكَالًا وَّ جَحِیْمًاۙ اِنَّ لَدَيْنَآ : بیشک ہمارے ہاں اَنْكَالًا : عذاب وَّجَحِيْمًا : اور دہکتی آگ یقیناً ہمارے ہاں سخت بیڑیاں ہیں اور سلگتی ہوئی جہنم۔
  73,13,وَّ طَعَامًا ذَا غُصَّةٍ وَّ عَذَابًا اَلِیْمًاۗ وَّطَعَامًا : اور کھانا ذَا غُصَّةٍ : گلے میں اٹک جانیوالا وَّعَذَابًا : اور عذاب اَلِيْمًا : دردناک اور حلق میں اٹکنے والا کھانا ہے اور درد دینے والا عذاب ہے (1)
  73,14,یَوْمَ تَرْجُفُ الْاَرْضُ وَ الْجِبَالُ وَ كَانَتِ الْجِبَالُ كَثِیْبًا مَّهِیْلًا يَوْمَ : جس دن تَرْجُفُ : کانپے گی الْاَرْضُ : زمین وَالْجِبَالُ : اور پہاڑ وَكَانَتِ : اور ہوجائیں گے الْجِبَالُ : پہاڑ كَثِيْبًا : ریت کے تودے مَّهِيْلًا : ریزہ ریزہ جس دن زمین اور پہاڑ تھر تھرائیں گے اور پہاڑ مثل بھربھری ریت کے ٹیلوں کے ہوجائیں گے۔ (1)
  73,15,اِنَّاۤ اَرْسَلْنَاۤ اِلَیْكُمْ رَسُوْلًا١ۙ۬ شَاهِدًا عَلَیْكُمْ كَمَاۤ اَرْسَلْنَاۤ اِلٰى فِرْعَوْنَ رَسُوْلًاؕ اِنَّآ اَرْسَلْنَآ : بیشک ہم نے بھیجا اِلَيْكُمْ : تمہاری طرف رَسُوْلًا : ایک رسول شَاهِدًا : گواہی دینے والا عَلَيْكُمْ : تم پر كَمَآ اَرْسَلْنَآ : جیسے ہم نے بھیجا اِلٰى فِرْعَوْنَ : فرعون کی طرف رَسُوْلًا : ایک رسول بیشک ہم نے تمہاری طرف بھی تم پر گواہی دینے والا (1) رسول بھیج دیا ہے جیسے کہ ہم نے فرعون کے پاس رسول بھیجا تھا۔
  73,16,فَعَصٰى فِرْعَوْنُ الرَّسُوْلَ فَاَخَذْنٰهُ اَخْذًا وَّبِیْلًا فَعَصٰى : پس کہا نہ مانا فِرْعَوْنُ : فرعون نے الرَّسُوْلَ : رسول کا فَاَخَذْنٰهُ : پس ہم نے اسے پکڑلیا اَخْذًا : پکڑ وَّبِيْلًا : بڑے وبال تو فرعون نے اس رسول کی نافرمانی کی تو ہم نے اسے سخت (وبال) کی پکڑ میں پکڑ لیا (1)
  73,17,فَكَیْفَ تَتَّقُوْنَ اِنْ كَفَرْتُمْ یَوْمًا یَّجْعَلُ الْوِلْدَانَ شِیْبَاۗۖ فَكَيْفَ : تو کیسے تَتَّقُوْنَ : تم بچوگے اِنْ : اگر كَفَرْتُمْ : تم کفر کروگے يَوْمًا : اس دن يَّجْعَلُ : کردے گا الْوِلْدَانَ : بچوں کو شِيْبَۨا : بوڑھا تم اگر کافر رہے تو اس دن کیسے پناہ پاؤ گے جو دن بچوں کو بوڑھا کر دے گا (1)
  73,18,اِ۟لسَّمَآءُ مُنْفَطِرٌۢ بِهٖ١ؕ كَانَ وَعْدُهٗ مَفْعُوْلًا السَّمَآءُ : آسمان مُنْفَطِرٌۢ : پھٹ جائے گا بِهٖ ۭ : اس سے كَانَ : ہے وَعْدُهٗ : اس کا وعدہ مَفْعُوْلًا : پورا ہوکر رہنے والا جس دن آسمان پھٹ جائے گا (1) اللہ تعالیٰ کا یہ وعدہ ہو کر ہی رہے گا۔ (2)
  73,19,اِنَّ هٰذِهٖ تَذْكِرَةٌ١ۚ فَمَنْ شَآءَ اتَّخَذَ اِلٰى رَبِّهٖ سَبِیْلًا۠    ۧ اِنَّ هٰذِهٖ : بیشک یہ تَذْكِرَةٌ ۚ : نصیحت فَمَنْ : تو جو شَآءَ : چاہے اتَّخَذَ : اختیار کرلے اِلٰى رَبِّهٖ : اپنے رب کی طرف سَبِيْلًا : راہ بیشک یہ نصیحت ہے پس جو چاہے اپنے رب کی طرف راہ اختیار کرے۔
