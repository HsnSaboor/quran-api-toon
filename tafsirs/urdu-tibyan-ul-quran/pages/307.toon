tafsir[13]{c,v,t}:
  19,26,فَكُلِیْ وَ اشْرَبِیْ وَ قَرِّیْ عَیْنًا١ۚ فَاِمَّا تَرَیِنَّ مِنَ الْبَشَرِ اَحَدًا١ۙ فَقُوْلِیْۤ اِنِّیْ نَذَرْتُ لِلرَّحْمٰنِ صَوْمًا فَلَنْ اُكَلِّمَ الْیَوْمَ اِنْسِیًّاۚ فَكُلِيْ : تو کھا وَاشْرَبِيْ : اور پی وَقَرِّيْ : اور ٹھنڈی کر عَيْنًا : آنکھیں فَاِمَّا تَرَيِنَّ : پھر اگر تو دیکھے مِنَ : سے الْبَشَرِ : آدمی اَحَدًا : کوئی فَقُوْلِيْٓ : تو کہدے اِنِّىْ نَذَرْتُ : میں نے نذر مانی ہے لِلرَّحْمٰنِ : رحمن کے لیے صَوْمًا : روزہ فَلَنْ اُكَلِّمَ : پس میں ہرگز کلام نہ کرونگی الْيَوْمَ : آج اِنْسِيًّا : کسی آدمی اب چین سے کھا پی اور آنکھیں ٹھنڈی رکھ (1) اگر تجھے کوئی انسان نظر پڑجائے تو کہہ (2) دینا کہ میں نے اللہ رحمان کے نام کا روزہ رکھا ہے۔ میں آج کسی شخص سے بات نہ کروں گی۔
  19,27,فَاَتَتْ بِهٖ قَوْمَهَا تَحْمِلُهٗ١ؕ قَالُوْا یٰمَرْیَمُ لَقَدْ جِئْتِ شَیْئًا فَرِیًّا فَاَتَتْ بِهٖ : پھر وہ اسے لیکر آئی قَوْمَهَا : اپنی قوم تَحْمِلُهٗ : اسے اٹھائے ہوئے قَالُوْا : وہ بولے يٰمَرْيَمُ : اے مریم لَقَدْ جِئْتِ : تو لائی ہے شَيْئًا : شے فَرِيًّا : بری (غضب کی) اب حضرت عیسیٰ ؑ کو لئے ہوئے وہ اپنی قوم کے پاس آئیں۔ سب کہنے لگے مریم تو نے بڑی بری حرکت کی
  19,28,یٰۤاُخْتَ هٰرُوْنَ مَا كَانَ اَبُوْكِ امْرَاَ سَوْءٍ وَّ مَا كَانَتْ اُمُّكِ بَغِیًّاۖۚ يٰٓاُخْتَ هٰرُوْنَ : اے ہارون کی بہن مَا : نہ كَانَ : تھا اَبُوْكِ : تیرا باپ امْرَاَ : آدمی سَوْءٍ : برا وَّ : اور مَا كَانَتْ : نہ تھی اُمُّكِ : تیری ماں بَغِيًّا : بدکار اے ہارون کی بہن ! (1) نہ تو تیرا باپ برا آدمی تھا اور نہ تیری ماں بدکار تھی
  19,29,فَاَشَارَتْ اِلَیْهِ١ؕ قَالُوْا كَیْفَ نُكَلِّمُ مَنْ كَانَ فِی الْمَهْدِ صَبِیًّا فَاَشَارَتْ : تو مریم نے اشارہ کیا اِلَيْهِ : اس کی طرف قَالُوْا : وہ بولے كَيْفَ نُكَلِّمُ : کیسے ہم بات کریں مَنْ كَانَ : جو ہے فِي الْمَهْدِ : گہوارہ میں صَبِيًّا : بچہ مریم نے اپنے بچے کی طرف اشارہ کیا۔ سب کہنے لگے کہ لو بھلا ہم گود کے بچے سے باتیں کیسے کریں ؟
  19,30,قَالَ اِنِّیْ عَبْدُ اللّٰهِ١ؕ۫ اٰتٰىنِیَ الْكِتٰبَ وَ جَعَلَنِیْ نَبِیًّاۙ قَالَ : بچہ نے اِنِّىْ : بیشک میں عَبْدُ اللّٰهِ : اللہ کا بندہ اٰتٰىنِيَ : اس نے مجھے دی ہے الْكِتٰبَ : کتاب وَجَعَلَنِيْ : اور مجھے بنایا ہے نَبِيًّا : نبی بچہ بول اٹھا کہ میں اللہ تعالیٰ کا بندہ ہوں۔ اس نے مجھے کتاب عطا فرمائی اور مجھے اپنا پیغمبر بنایا (1) ہے
  19,31,وَّ جَعَلَنِیْ مُبٰرَكًا اَیْنَ مَا كُنْتُ١۪ وَ اَوْصٰنِیْ بِالصَّلٰوةِ وَ الزَّكٰوةِ مَا دُمْتُ حَیًّا٢۪ۖ وَّجَعَلَنِيْ : اور مجھے بنایا ہے مُبٰرَكًا : بابرکت اَيْنَ مَا : جہاں کہیں كُنْتُ : میں ہوں ‎وَاَوْصٰىنِيْ : مجھے حکم دیا ہے اس نے بِالصَّلٰوةِ : نماز کا وَالزَّكٰوةِ : اور زکوۃ کا مَا دُمْتُ : جب تک میں رہوں حَيًّا : زندہ اور اس نے مجھے بابرکت کیا ہے (1) جہاں بھی میں ہوں، اور اس نے مجھے نماز اور زکوٰۃ کا حکم دیا ہے جب تک بھی میں زندہ رہوں
  19,32,وَّ بَرًّۢا بِوَالِدَتِیْ١٘ وَ لَمْ یَجْعَلْنِیْ جَبَّارًا شَقِیًّا وَّبَرًّۢا : اور اچھا سلوک کرنیوالا بِوَالِدَتِيْ : اپنی ماں سے وَ : اور لَمْ يَجْعَلْنِيْ : اس نے مجھے نہیں بنایا جَبَّارًا : سرکش شَقِيًّا : بدنصیب اور اس نے مجھے اپنی والدہ کا خدمت گزار بنایا ہے (1) اور مجھے سرکش اور بدبخت نہیں کیا (2)۔
  19,33,وَ السَّلٰمُ عَلَیَّ یَوْمَ وُلِدْتُّ وَ یَوْمَ اَمُوْتُ وَ یَوْمَ اُبْعَثُ حَیًّا وَالسَّلٰمُ : اور سلامتی عَلَيَّ : مجھ پر يَوْمَ : جس دن وُلِدْتُّ : میں پیدا ہوا وَيَوْمَ : اور جس دن اَمُوْتُ : میں مروں گا وَيَوْمَ : اور جس دن اُبْعَثُ : اٹھایا جاؤں گا حَيًّا : زندہ ہوکر اور مجھ پر میری پیدائش کے دن اور میری موت کے دن اور جس دن کہ میں دوبارہ زندہ کھڑا کیا جاؤں گا، سلام ہی سلام ہے۔
  19,34,ذٰلِكَ عِیْسَى ابْنُ مَرْیَمَ١ۚ قَوْلَ الْحَقِّ الَّذِیْ فِیْهِ یَمْتَرُوْنَ ذٰلِكَ : یہ عِيْسَى : عیسیٰ ابْنُ مَرْيَمَ : ابن مریم قَوْلَ : بات الْحَقِّ : سچی الَّذِيْ فِيْهِ : وہ جس میں يَمْتَرُوْنَ : وہ شک کرتے ہیں یہ ہے صحیح واقعہ عیسیٰ بن مریم ؑ کا، یہی ہے وہ حق بات جس میں لوگ شک شبہ میں مبتلا ہیں (1)
  19,35,مَا كَانَ لِلّٰهِ اَنْ یَّتَّخِذَ مِنْ وَّلَدٍ١ۙ سُبْحٰنَهٗ١ؕ اِذَا قَضٰۤى اَمْرًا فَاِنَّمَا یَقُوْلُ لَهٗ كُنْ فَیَكُوْنُؕ مَا كَانَ : نہیں ہے لِلّٰهِ : اللہ کیلئے اَنْ : کہ يَّتَّخِذَ : وہ بنائے مِنْ : کوئی وَّلَدٍ : بیٹا سُبْحٰنَهٗ : وہ پاک ہے اِذَا قَضٰٓى : جب وہ فیصلہ کرتا ہے اَمْرًا : کسی کام فَاِنَّمَا : تو اس کے سوا نہیں يَقُوْلُ : وہ کہتا ہے لَهٗ : اس کو كُنْ : ہوجا فَيَكُوْنُ : پس وہ ہوجاتا ہے اللہ تعالیٰ کے لئے اولاد کا ہونا لائق نہیں، وہ بالکل پاک ذات ہے، وہ تو جب کسی کام کے سر انجام دینے کا ارادہ کرتا ہے تو اسے کہہ دیتا ہے کہ ہوجا، وہ اسی وقت ہوجاتا ہے (1)۔
  19,36,وَ اِنَّ اللّٰهَ رَبِّیْ وَ رَبُّكُمْ فَاعْبُدُوْهُ١ؕ هٰذَا صِرَاطٌ مُّسْتَقِیْمٌ وَاِنَّ : اور بیشک اللّٰهَ : اللہ رَبِّيْ : میرا رب وَرَبُّكُمْ : اور تمہارا رب فَاعْبُدُوْهُ : پس اس کی عبادت کرو ھٰذَا : یہ صِرَاطٌ : راستہ مُّسْتَقِيْمٌ : سیدھا میرا اور تم سب کا پروردگار صرف اللہ تعالیٰ ہی ہے۔ تم سب اسی کی عبادت کرو، یہی سیدھی راہ ہے۔
  19,37,فَاخْتَلَفَ الْاَحْزَابُ مِنْۢ بَیْنِهِمْ١ۚ فَوَیْلٌ لِّلَّذِیْنَ كَفَرُوْا مِنْ مَّشْهَدِ یَوْمٍ عَظِیْمٍ فَاخْتَلَفَ : پھر اختلاف کیا الْاَحْزَابُ : فرقے مِنْۢ بَيْنِهِمْ : آپس میں (باہم) فَوَيْلٌ : پس خرابی لِّلَّذِيْنَ كَفَرُوْا : کافروں کے لیے مِنْ : سے مَّشْهَدِ : حاضری يَوْمٍ عَظِيْمٍ : بڑا دن پھر یہ فرماتے آپس میں اختلاف کرنے لگے، (1) پس کافروں کے لئے ' ویل ' ہے ایک بڑے (سخت) دن کی حاضری سے (2)۔
  19,38,اَسْمِعْ بِهِمْ وَ اَبْصِرْ١ۙ یَوْمَ یَاْتُوْنَنَا لٰكِنِ الظّٰلِمُوْنَ الْیَوْمَ فِیْ ضَلٰلٍ مُّبِیْنٍ اَسْمِعْ : سنیں گے بِهِمْ : کیا کچھ وَاَبْصِرْ : اور دیکھیں گے يَوْمَ : جس دن يَاْتُوْنَنَا : وہ ہمارے سامنے آئیں گے لٰكِنِ : لیکن الظّٰلِمُوْنَ : ظالم (جمع) الْيَوْمَ : آج کے دن فِيْ : میں ضَلٰلٍ مُّبِيْنٍ : کھلی گمراہی کیا خوب دیکھنے سننے والے ہونگے اس دن جبکہ ہمارے سامنے حاضر ہوں گے، (1) لیکن آج تو یہ ظالم لوگ صریح گمراہی میں پڑے ہوئے ہیں
