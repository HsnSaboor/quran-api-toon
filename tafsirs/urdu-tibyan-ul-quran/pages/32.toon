quran[30]{c,v,t}:
32,1,الٓمّٓۚ الف۔ لام۔ میم الف لام میم
32,2,تَنْزِیْلُ الْكِتٰبِ لَا رَیْبَ فِیْهِ مِنْ رَّبِّ الْعٰلَمِیْنَؕ تَنْزِيْلُ : نازل کرنا الْكِتٰبِ : کتاب لَا رَيْبَ : کوئی شبہ نہیں فِيْهِ : اس میں مِنْ : سے رَّبِّ : پروردگار الْعٰلَمِيْنَ : تمام جہان بلا شبہ اس کتاب کا اتارنا تمام جہانوں کے پروردگار کی طرف سے ہے 1
32,3,اَمْ یَقُوْلُوْنَ افْتَرٰىهُ١ۚ بَلْ هُوَ الْحَقُّ مِنْ رَّبِّكَ لِتُنْذِرَ قَوْمًا مَّاۤ اَتٰىهُمْ مِّنْ نَّذِیْرٍ مِّنْ قَبْلِكَ لَعَلَّهُمْ یَهْتَدُوْنَ اَمْ : کیا يَقُوْلُوْنَ : وہ کہتے ہیں افْتَرٰىهُ ۚ : یہ اس نے گھڑ لیا ہے بَلْ : بلکہ هُوَ : یہ الْحَقُّ : حق مِنْ : سے رَّبِّكَ : تمہارا رب لِتُنْذِرَ : تاکہ تم ڈراؤ قَوْمًا : اس قوم کو مَّآ اَتٰىهُمْ : ان کے پاس نہیں آیا مِّنْ : کوئی نَّذِيْرٍ : ڈرانے والا مِّنْ : سے قَبْلِكَ : تم سے پہلے لَعَلَّهُمْ : تاکہ وہ يَهْتَدُوْنَ : ہدایت پالیں کیا یہ کہتے ہیں کہ اس نے گھڑ لیا ہے 1 (نہیں نہیں) بلکہ یہ تیرے رب تعالیٰ کی طرف سے حق ہے تاکہ آپ انھیں ڈرائیں جنکے پاس آپ سے پہلے کوئی ڈرانے والا نہیں آیا 2 تاکہ وہ راہ راست پر آجائیں۔
32,4,اَللّٰهُ الَّذِیْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَا فِیْ سِتَّةِ اَیَّامٍ ثُمَّ اسْتَوٰى عَلَى الْعَرْشِ١ؕ مَا لَكُمْ مِّنْ دُوْنِهٖ مِنْ وَّلِیٍّ وَّ لَا شَفِیْعٍ١ؕ اَفَلَا تَتَذَكَّرُوْنَ اَللّٰهُ : اللہ الَّذِيْ : وہ جس نے خَلَقَ : پیدا کیا السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین وَمَا : اور جو بَيْنَهُمَا : ان کے درمیان فِيْ : میں سِتَّةِ : چھ اَيَّامٍ : دن ثُمَّ : پھر اسْتَوٰي : اس نے قرار کیا عَلَي الْعَرْشِ ۭ : عرش پر مَا لَكُمْ : تمہارے لیے نہیں مِّنْ دُوْنِهٖ : اس کے سوا مِنْ : سے۔ کوئی وَّلِيٍّ : مددگار وَّلَا شَفِيْعٍ ۭ : اور نہ سفارش کرنے والا اَفَلَا تَتَذَكَّرُوْنَ : سو کیا تم غور نہیں کرتے اللہ تعالیٰ وہ ہے جس نے آسمان و زمین اور جو کچھ ان درمیان ہے سب کو چھ دن میں پیدا کردیا پھر عرش پر قائم ہوا 1 تمہارے لئے اس کے سوا کوئی مددگار اور سفارشی نہیں 2 کیا اس پر بھی تم نصیحت حاصل نہیں کرتے 3۔
32,5,یُدَبِّرُ الْاَمْرَ مِنَ السَّمَآءِ اِلَى الْاَرْضِ ثُمَّ یَعْرُجُ اِلَیْهِ فِیْ یَوْمٍ كَانَ مِقْدَارُهٗۤ اَلْفَ سَنَةٍ مِّمَّا تَعُدُّوْنَ يُدَبِّرُ : وہ تدبیر کرتا ہے الْاَمْرَ : تمام کام مِنَ : سے السَّمَآءِ : آسمان اِلَى الْاَرْضِ : زمین تک ثُمَّ : پھر يَعْرُجُ : وہ رجوع کرے گا اِلَيْهِ : اس کی طرف فِيْ يَوْمٍ : ایک دن میں كَانَ : ہے مِقْدَارُهٗٓ : اس کی مقدار اَلْفَ سَنَةٍ : ایک ہزار سال مِّمَّا : اس سے جو تَعُدُّوْنَ : تم شمار کرتے ہو وہ آسمان سے لے کر زمین تک (ہر) کام کی تدبیر کرتا ہے 1 پھر (وہ کام) ایک ایسے دن میں اس کی طرف چڑھ جاتا ہے جس کا اندازہ تمہاری گنتی کے ایک ہزار سال کے برابر ہے۔ 2
32,6,ذٰلِكَ عٰلِمُ الْغَیْبِ وَ الشَّهَادَةِ الْعَزِیْزُ الرَّحِیْمُۙ ذٰلِكَ : وہ عٰلِمُ الْغَيْبِ : جاننے والا پوشیدہ وَالشَّهَادَةِ : اور ظاہر الْعَزِيْزُ : غالب الرَّحِيْمُ : مہربان یہی ہے چھپے کھلے کا جاننے والا، زبردست غالب بہت ہی مہربان۔
32,7,الَّذِیْۤ اَحْسَنَ كُلَّ شَیْءٍ خَلَقَهٗ وَ بَدَاَ خَلْقَ الْاِنْسَانِ مِنْ طِیْنٍۚ الَّذِيْٓ : وہ جس نے اَحْسَنَ : بہت خوب بنائی كُلَّ شَيْءٍ : ہر شے خَلَقَهٗ : جو اس نے پیدا کی وَبَدَاَ : اور ابتدا کی خَلْقَ : پیدائش الْاِنْسَانِ : انسان مِنْ : سے طِيْنٍ : مٹی جس نے نہایت خوب بنائی جو چیز بھی بنائی 1 اور انسان کی بناوٹ مٹی سے شروع کی 2۔
32,8,ثُمَّ جَعَلَ نَسْلَهٗ مِنْ سُلٰلَةٍ مِّنْ مَّآءٍ مَّهِیْنٍۚ ثُمَّ : پھر جَعَلَ : بنایا نَسْلَهٗ : اس کی نسل مِنْ سُلٰلَةٍ : خلاصہ سے مِّنْ : سے مَّآءٍ مَّهِيْنٍ : حقیر (بےقدر) پانی پھر اس کی نسل ایک بےوقعت پانی کے نچوڑ سے چلائی 1
32,9,ثُمَّ سَوّٰىهُ وَ نَفَخَ فِیْهِ مِنْ رُّوْحِهٖ وَ جَعَلَ لَكُمُ السَّمْعَ وَ الْاَبْصَارَ وَ الْاَفْئِدَةَ١ؕ قَلِیْلًا مَّا تَشْكُرُوْنَ ثُمَّ سَوّٰىهُ : پھر اس (کے اعضا) کو ٹھیک کیا وَنَفَخَ : اور پھونکی فِيْهِ : اس میں مِنْ : سے رُّوْحِهٖ : اپنی روح وَجَعَلَ : اور بنائے لَكُمُ : تمہارے لیے السَّمْعَ : کان وَالْاَبْصَارَ : اور آنکھیں وَالْاَفْئِدَةَ ۭ : اور دل ( جمع) قَلِيْلًا : بہت کم مَّا : جو تَشْكُرُوْنَ : تم شکر کرتے ہو جسے ٹھیک ٹھاک کر کے اس میں اس نے روح پھونکی 1 اسی نے تمہارے کان آنکھیں اور دل بنائے 2 (اس پر بھی) تم بہت ہی تھوڑا احسان مانتے ہو 2
32,10,وَ قَالُوْۤا ءَاِذَا ضَلَلْنَا فِی الْاَرْضِ ءَاِنَّا لَفِیْ خَلْقٍ جَدِیْدٍ١ؕ۬ بَلْ هُمْ بِلِقَآئِ رَبِّهِمْ كٰفِرُوْنَ وَقَالُوْٓا : اور انہوں نے کہا ءَاِذَا : کیا جب ضَلَلْنَا : ہم گم ہوجائیں گے فِي الْاَرْضِ : زمین میں ءَاِنَّا : کیا ہم لَفِيْ : تو۔ میں خَلْقٍ جَدِيْدٍ : نئی پیدائش بَلْ : بلکہ هُمْ : وہ بِلِقَآئِ : ملاقات سے رَبِّهِمْ : اپنا رب كٰفِرُوْنَ : منکر (جمع) اور انہوں نے کہا کیا جب ہم زمین میں رل مل جائیں گے 1 کیا پھر نئی پیدائش میں آجائیں گے ؟ بلکہ (بات یہ ہے) کہ وہ لوگ اپنے پروردگار کی ملاقات کے منکر ہیں۔
32,11,قُلْ یَتَوَفّٰىكُمْ مَّلَكُ الْمَوْتِ الَّذِیْ وُكِّلَ بِكُمْ ثُمَّ اِلٰى رَبِّكُمْ تُرْجَعُوْنَ۠    ۧ قُلْ : فرما دیں يَتَوَفّٰىكُمْ : تمہاری روح قبض کرتا ہے مَّلَكُ الْمَوْتِ : موت کا فرشتہ الَّذِيْ : وہ جو کہ وُكِّلَ : مقرر کیا گیا ہے بِكُمْ : تم پر ثُمَّ : پھر اِلٰى رَبِّكُمْ : تم اپنے رب کی طرف تُرْجَعُوْنَ : لوٹائے جاؤ گے کہہ دیجئے ! کہ تمہیں موت کا فرشتہ فوت کرے گا جو تم پر مقرر کیا گیا ہے 1 پھر تم سب اپنے پروردگار کی طرف لوٹائے جاؤ گے۔
32,12,وَ لَوْ تَرٰۤى اِذِ الْمُجْرِمُوْنَ نَاكِسُوْا رُءُوْسِهِمْ عِنْدَ رَبِّهِمْ١ؕ رَبَّنَاۤ اَبْصَرْنَا وَ سَمِعْنَا فَارْجِعْنَا نَعْمَلْ صَالِحًا اِنَّا مُوْقِنُوْنَ وَلَوْ : اور اگر تَرٰٓي : تم دیکھو اِذِ : جب الْمُجْرِمُوْنَ : مجرم (جمع) نَاكِسُوْا : جھکائے ہوں گے رُءُوْسِهِمْ : اپنے سر عِنْدَ رَبِّهِمْ ۭ : اپنے رب کے سامنے رَبَّنَآ : اے ہمارے رب اَبْصَرْنَا : ہم نے دیکھ لیا وَسَمِعْنَا : اور ہم نے سن لیا فَارْجِعْنَا : پس ہمیں لوٹا دے نَعْمَلْ : ہم عمل کریں گے صَالِحًا : اچھے عمل اِنَّا : بیشک ہم مُوْقِنُوْنَ : یقین کرنے والے کاش کہ آپ دیکھتے جب کہ گناہگار لوگ اپنے رب تعالیٰ کے سامنے سر جھکائے ہوئے ہوں 1 گے، کہیں گے اے ہمارے رب ! ہم نے دیکھ لیا اور سن لیا اب 2 تو ہمیں واپس لوٹا دے ہم نیک اعمال کریں گے ہم یقین کرنے والے ہیں 3۔
32,13,وَ لَوْ شِئْنَا لَاٰتَیْنَا كُلَّ نَفْسٍ هُدٰىهَا وَ لٰكِنْ حَقَّ الْقَوْلُ مِنِّیْ لَاَمْلَئَنَّ جَهَنَّمَ مِنَ الْجِنَّةِ وَ النَّاسِ اَجْمَعِیْنَ وَلَوْ : اور اگر شِئْنَا : ہم چاہتے لَاٰتَيْنَا : ہم ضرور دیتے كُلَّ نَفْسٍ : ہر شخص هُدٰىهَا : اس کی ہدایت وَلٰكِنْ : اور لیکن حَقَّ : ثابت ہوچکی الْقَوْلُ : بات مِنِّيْ : میری طرف سے لَاَمْلَئَنَّ جَهَنَّمَ : البتہ میں ضرور بھردوں گا جہنم مِنَ : سے الْجِنَّةِ : جنوں وَالنَّاسِ : اور انسان اَجْمَعِيْنَ : اکٹھے اگر ہم چاہتے تو ہر شخص کو ہدایت نصیب 1 فرما دیتے، لیکن میری بات بالکل حق ہوچکی ہے کہ میں ضرور ضرور جہنم کو انسانوں اور جنوں سے پر کر دونگا 2۔
32,14,فَذُوْقُوْا بِمَا نَسِیْتُمْ لِقَآءَ یَوْمِكُمْ هٰذَا١ۚ اِنَّا نَسِیْنٰكُمْ وَ ذُوْقُوْا عَذَابَ الْخُلْدِ بِمَا كُنْتُمْ تَعْمَلُوْنَ فَذُوْقُوْا : پس چکھو تم بِمَا : وہ جو نَسِيْتُمْ : تم نے بھلا دیا تھا لِقَآءَ : ملاقات يَوْمِكُمْ : اپنے دن ھٰذَا ۚ : اس اِنَّا نَسِيْنٰكُمْ : بیشک ہم نے تمہیں بھلا دیا وَذُوْقُوْا : اور چکھو تم عَذَابَ الْخُلْدِ : ہمیشہ کا عذاب بِمَا : اس کا بدلہ جو كُنْتُمْ تَعْمَلُوْنَ : تم کرتے تھے اب تم اپنے اس دن کی ملاقات کے فراموش کردینے کا مزہ چکھو ہم نے بھی تمہیں بھلا دیا 1 اور اپنے کئے ہوئے اعمال (کی شامت) سے ہمیشہ عذاب کا مزہ چکھو۔
32,15,اِنَّمَا یُؤْمِنُ بِاٰیٰتِنَا الَّذِیْنَ اِذَا ذُكِّرُوْا بِهَا خَرُّوْا سُجَّدًا وَّ سَبَّحُوْا بِحَمْدِ رَبِّهِمْ وَ هُمْ لَا یَسْتَكْبِرُوْنَ۩  ۞ اِنَّمَا : اس کے سوا نہیں يُؤْمِنُ : ایمان لاتے ہیں بِاٰيٰتِنَا : ہماری آیتوں پر الَّذِيْنَ : وہ جو اِذَا : جب ذُكِّرُوْا : یاد دلائی جاتی ہیں بِهَا : وہ خَرُّوْا سُجَّدًا : گرپڑتے ہیں سجدہ میں وَّسَبَّحُوْا : اور پاکیزگی بیان کرتے ہیں بِحَمْدِ : تعریف کے ساتھ رَبِّهِمْ : اپنا رب وَهُمْ : اور وہ لَا يَسْتَكْبِرُوْنَ : تکبر نہیں کرتے ہماری آیاتوں پر وہی ایمان لاتے ہیں 1 جنہیں جب کبھی ان سے نصیحت کی جاتی ہے تو وہ سجدے میں گرپڑتے ہیں 2 اور اپنے رب کی حمد کے ساتھ اس کی تسبیح پڑھتے ہیں 3 اور تکبر نہیں کرتے 4۔
32,16,تَتَجَافٰى جُنُوْبُهُمْ عَنِ الْمَضَاجِعِ یَدْعُوْنَ رَبَّهُمْ خَوْفًا وَّ طَمَعًا١٘ وَّ مِمَّا رَزَقْنٰهُمْ یُنْفِقُوْنَ تَتَجَافٰى : الگ رہتے ہیں جُنُوْبُهُمْ : ان کے پہلو عَنِ : سے الْمَضَاجِعِ : خوابگاہوں (بستروں) يَدْعُوْنَ : وہ پکارتے ہیں رَبَّهُمْ : اپنا رب خَوْفًا : ڈر وَّطَمَعًا ۡ : اور امید وَّمِمَّا : اور اس سے جو رَزَقْنٰهُمْ : ہم نے انہیں دیا يُنْفِقُوْنَ : وہ خرچ کرتے ہیں ان کی کروٹیں اپنے بستروں سے الگ رہتی ہیں 1 اپنے رب کے خوف اور امید کے ساتھ پکارتے ہیں 2 اور جو کچھ ہم نے انھیں دے رکھا ہے وہ خرچ کرتے ہیں 3
32,17,فَلَا تَعْلَمُ نَفْسٌ مَّاۤ اُخْفِیَ لَهُمْ مِّنْ قُرَّةِ اَعْیُنٍ١ۚ جَزَآءًۢ بِمَا كَانُوْا یَعْمَلُوْنَ فَلَا تَعْلَمُ : سو نہیں جانتا نَفْسٌ : کوئی شخص مَّآ : جو اُخْفِيَ : چھپا رکھا گیا لَهُمْ : ان کے لیے مِّنْ : سے قُرَّةِ اَعْيُنٍ ۚ : آنکھوں کی ٹھنڈک جَزَآءًۢ : جزا بِمَا : اس کا كَانُوْا يَعْمَلُوْنَ : جو وہ کرتے تھے کوئی نفس نہیں جانتا جو کچھ ہم نے ان کی آنکھوں کی ٹھنڈک ان کے لئے پوشیدہ کر رکھی ہے 1 جو کچھ کرتے تھے یہ اس کا بدلہ ہے 2
32,18,اَفَمَنْ كَانَ مُؤْمِنًا كَمَنْ كَانَ فَاسِقًا١ؔؕ لَا یَسْتَوٗنَؐ اَفَمَنْ : تو کیا جو كَانَ : ہو مُؤْمِنًا : مومن كَمَنْ : اس کے مانند جو كَانَ : ہو فَاسِقًا ڼ : فاسق (نافرمان) لَا يَسْتَوٗنَ : وہ برابر نہیں ہوتے کیا جو مومن ہو مثل اس کے ہے جو فاسق ہو ؟ 1 یہ برابر نہیں ہوسکتے۔
32,19,اَمَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ فَلَهُمْ جَنّٰتُ الْمَاْوٰى١٘ نُزُلًۢا بِمَا كَانُوْا یَعْمَلُوْنَ اَمَّا : رہے الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : اچھے فَلَهُمْ : تو ان کے لیے جَنّٰتُ الْمَاْوٰي ۡ : باغات رہنے کے نُزُلًۢا : مہمانی بِمَا : اس کے (صلہ میں) جو كَانُوْا يَعْمَلُوْنَ : وہ کرتے تھے جن لوگوں نے ایمان قبول کیا اور نیک اعمال بھی کیے ان کے لئے ہمیشگی والی جنتیں ہیں، مہمانداری ہے ان کے اعمال کے بدلے جو وہ کرتے تھے۔
32,20,وَ اَمَّا الَّذِیْنَ فَسَقُوْا فَمَاْوٰىهُمُ النَّارُ١ؕ كُلَّمَاۤ اَرَادُوْۤا اَنْ یَّخْرُجُوْا مِنْهَاۤ اُعِیْدُوْا فِیْهَا وَ قِیْلَ لَهُمْ ذُوْقُوْا عَذَابَ النَّارِ الَّذِیْ كُنْتُمْ بِهٖ تُكَذِّبُوْنَ وَاَمَّا : اور رہے الَّذِيْنَ : وہ جنہوں نے فَسَقُوْا : نافرمانی کی فَمَاْوٰىهُمُ : تو ان کا ٹھکانا النَّارُ ۭ : جہنم كُلَّمَآ : جب بھی اَرَادُوْٓا : وہ ارادہ کریں گے اَنْ يَّخْرُجُوْا : کہ وہ نکلیں مِنْهَآ : اس سے اُعِيْدُوْا : لوٹا دیئے جائیں گے فِيْهَا : اس میں وَقِيْلَ : اور کہا جائے گا لَهُمْ : انہیں ذُوْقُوْا : تم چکھو عَذَابَ النَّارِ : دوزخ کا عذاب الَّذِيْ : وہ جو كُنْتُمْ : تم تھے بِهٖ : اس کو تُكَذِّبُوْنَ : جھٹلاتے لیکن جن لوگوں نے حکم عدولی کی ان کا ٹھکانا دوزخ ہے، جب کبھی اس سے باہر نکلنا چاہیں گے اسی میں لوٹا دیئے جائیں گے 1 اور کہہ دیا جائیگا کہ 2 اپنے جھٹلانے کے بدلے آگ کا عذاب چکھو۔
32,21,وَ لَنُذِیْقَنَّهُمْ مِّنَ الْعَذَابِ الْاَدْنٰى دُوْنَ الْعَذَابِ الْاَكْبَرِ لَعَلَّهُمْ یَرْجِعُوْنَ وَلَنُذِيْقَنَّهُمْ : اور البتہ ہم انہیں ضرور چکھائیں گے مِّنَ : کچھ الْعَذَابِ : عذاب الْاَدْنٰى : نزدیک دُوْنَ : سوائے (پہلے) الْعَذَابِ : عذاب الْاَكْبَرِ : بڑا لَعَلَّهُمْ : شاید وہ يَرْجِعُوْنَ : لوٹ آئیں بالیقین ہم انھیں قریب کے چھوٹے سے بعض عذاب 1 اس بڑے عذاب کے سوا چکھائیں گے تاکہ وہ لوٹ آئیں 2
32,22,وَ مَنْ اَظْلَمُ مِمَّنْ ذُكِّرَ بِاٰیٰتِ رَبِّهٖ ثُمَّ اَعْرَضَ عَنْهَا١ؕ اِنَّا مِنَ الْمُجْرِمِیْنَ مُنْتَقِمُوْنَ۠    ۧ وَمَنْ : اور کون اَظْلَمُ : بڑا ظالم مِمَّنْ : اس سے جو ذُكِّرَ : اسے نصیحت کی گئی بِاٰيٰتِ رَبِّهٖ : اس کے رب کی آیات سے ثُمَّ : پھر اَعْرَضَ : اس نے منہ پھیرلیا عَنْهَا ۭ : اس سے اِنَّا : بیشک ہم مِنَ : سے الْمُجْرِمِيْنَ : جمع (مجرم) مُنْتَقِمُوْنَ : انتقام لینے والے اس سے بڑھ کر ظالم کون ہے جسے اللہ تعالیٰ کی آیتوں سے وعظ کیا گیا پھر بھی اس نے ان سے منہ پھیرلیا 1 (یقین مانو) کہ ہم بھی گناہ گار سے انتقام لینے والے ہیں۔
32,23,وَ لَقَدْ اٰتَیْنَا مُوْسَى الْكِتٰبَ فَلَا تَكُنْ فِیْ مِرْیَةٍ مِّنْ لِّقَآئِهٖ وَ جَعَلْنٰهُ هُدًى لِّبَنِیْۤ اِسْرَآءِیْلَۚ وَلَقَدْ اٰتَيْنَا : اور تحقیق ہم نے دی مُوْسَى : موسیٰ الْكِتٰبَ : کتاب (توریت) فَلَا تَكُنْ : تو تم نہ رہو فِيْ مِرْيَةٍ : شک میں مِّنْ : سے۔ متعلق لِّقَآئِهٖ : اس کا ملنا وَجَعَلْنٰهُ : اور ہم نے بنایا اسے هُدًى : ہدایت لِّبَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل کے لیے بیشک ہم نے موسیٰ کو کتاب دی، پس آپ کو ہرگز اس کی ملاقات میں شک نہ کرنا 1 چاہیے اور ہم نے اسے 2 بنی اسرائیل کی ہدایت کا ذریعہ بنایا۔
32,24,وَ جَعَلْنَا مِنْهُمْ اَئِمَّةً یَّهْدُوْنَ بِاَمْرِنَا لَمَّا صَبَرُوْا١ؕ۫ وَ كَانُوْا بِاٰیٰتِنَا یُوْقِنُوْنَ وَجَعَلْنَا : اور ہم نے بنایا مِنْهُمْ : ان سے اَئِمَّةً : جمع امام (پیشوا) يَّهْدُوْنَ : وہ رہنمائی کرتے بِاَمْرِنَا : ہمارے حکم سے لَمَّا : جب صَبَرُوْا ڜ : انہوں نے صبر کیا وَكَانُوْا : اور وہ تھے بِاٰيٰتِنَا : ہماری آیتوں پر يُوْقِنُوْنَ : یقین کرتے اور جب ان لوگوں نے صبر کیا تو ہم نے ان میں سے ایسے پیشوا بنائے جو ہمارے حکم سے لوگوں کو ہدایت کرتے تھے، اور وہ ہماری آیتوں پر یقین رکھتے تھے 1
32,25,اِنَّ رَبَّكَ هُوَ یَفْصِلُ بَیْنَهُمْ یَوْمَ الْقِیٰمَةِ فِیْمَا كَانُوْا فِیْهِ یَخْتَلِفُوْنَ اِنَّ : بیشک رَبَّكَ : تمہارا رب هُوَ : وہ يَفْصِلُ : فیصلہ کرے گا بَيْنَهُمْ : ان کے درمیان يَوْمَ الْقِيٰمَةِ : قیامت کے دن فِيْمَا : اس میں كَانُوْا : وہ تھے فِيْهِ : اس میں يَخْتَلِفُوْنَ : اختلاف کرتے آپ کا رب ان (سب) کے درمیاں ان (تمام (باتوں کا فیصلہ قیامت) کے دن کرے گا جن میں وہ اختلاف کر رہے ہیں 1
32,26,اَوَ لَمْ یَهْدِ لَهُمْ كَمْ اَهْلَكْنَا مِنْ قَبْلِهِمْ مِّنَ الْقُرُوْنِ یَمْشُوْنَ فِیْ مَسٰكِنِهِمْ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ١ؕ اَفَلَا یَسْمَعُوْنَ اَوَ : کیا لَمْ يَهْدِ : ہدایت نہ ہوئی لَهُمْ : ان کے لیے كَمْ اَهْلَكْنَا : ہم نے کتنی ہلاک کیں مِنْ قَبْلِهِمْ : ان سے قبل مِّنَ : سے الْقُرُوْنِ : امتیں يَمْشُوْنَ : وہ چلتے ہیں فِيْ : میں مَسٰكِنِهِمْ ۭ : ان کے گھر (جمع) اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ ۭ : البتہ نشانیاں اَفَلَا يَسْمَعُوْنَ : تو کیا وہ سنتے نہیں کیا اس بات نے بھی انھیں کوئی ہدایت نہیں دی کہ ہم نے پہلے بہت سی امتوں کو ہلاک کردیا جن کے مکانوں میں یہ چل پھر رہے ہیں 1 اس میں تو بڑی بڑی نشانیاں ہیں، کیا پھر بھی یہ نہیں سنتے ؟
32,27,اَوَ لَمْ یَرَوْا اَنَّا نَسُوْقُ الْمَآءَ اِلَى الْاَرْضِ الْجُرُزِ فَنُخْرِجُ بِهٖ زَرْعًا تَاْكُلُ مِنْهُ اَنْعَامُهُمْ وَ اَنْفُسُهُمْ١ؕ اَفَلَا یُبْصِرُوْنَ اَوَ : کیا لَمْ يَرَوْا : انہوں نے نہیں دیکھا اَنَّا نَسُوْقُ : کہ ہم چلاتے ہیں الْمَآءَ : پانی اِلَى : طرف الْاَرْضِ : زمین الْجُرُزِ : خشک فَنُخْرِجُ بِهٖ زَرْعًا : پھر ہم نکالتے ہیں اس سے کھیتی تَاْكُلُ : کھاتے ہیں مِنْهُ : اس سے اَنْعَامُهُمْ : ان کے مویشی وَاَنْفُسُهُمْ ۭ : اور وہ خود اَفَلَا : تو کیا يُبْصِرُوْنَ : دیکھتے نہیں وہ کیا یہ نہیں دیکھتے کہ ہم پانی کو بنجر زمین کی طرف بہا کرلے جاتے ہیں پھر اس سے ہم کھیتیاں نکالتے ہیں جسے ان کے چوپائے اور یہ خود کھاتے ہیں 1 کیا پھر بھی یہ نہیں دیکھتے ـ۔
32,28,وَ یَقُوْلُوْنَ مَتٰى هٰذَا الْفَتْحُ اِنْ كُنْتُمْ صٰدِقِیْنَ وَيَقُوْلُوْنَ : اور وہ کہتے ہیں مَتٰى : کب ھٰذَا : یہ الْفَتْحُ : فتح (فیصلہ) اِنْ : اگر كُنْتُمْ : تم ہو صٰدِقِيْنَ : سچے اور کہتے ہیں کہ یہ فیصلہ کب ہوگا، اگر تم سچے ہو تو بتلاؤ۔
32,29,قُلْ یَوْمَ الْفَتْحِ لَا یَنْفَعُ الَّذِیْنَ كَفَرُوْۤا اِیْمَانُهُمْ وَ لَا هُمْ یُنْظَرُوْنَ قُلْ : فرمادیں يَوْمَ الْفَتْحِ : فتح (فیصلے) کے دن لَا يَنْفَعُ : نفع نہ دے گا الَّذِيْنَ كَفَرُوْٓا : جنہوں نے کفر کیا (کافر) اِيْمَانُهُمْ : ان کا ایمان وَلَا : اور نہ هُمْ : وہ يُنْظَرُوْنَ : مہلت دیئے جائیں گے جواب دے دو کہ فیصلے والے دن ایمان لانا بےایمانوں کو کچھ کام نہ آئے گا اور نہ انھیں ڈھیل دی جائے گی 1۔
32,30,فَاَعْرِضْ عَنْهُمْ وَ انْتَظِرْ اِنَّهُمْ مُّنْتَظِرُوْنَ۠    ۧ فَاَعْرِضْ : پس منہ پھیر لو تم عَنْهُمْ : ان سے وَانْتَظِرْ : اور تم انتظار کرو اِنَّهُمْ : بیشک وہ مُّنْتَظِرُوْنَ : منتظر ہیں اب آپ ان کا خیال چھوڑ دیں 1 اور منتظر رہیں 2 یہ بھی منتظر رہیں 3۔
