tafsir[25]{c,v,t}:
  78,31,اِنَّ لِلْمُتَّقِیْنَ مَفَازًاۙ اِنَّ لِلْمُتَّقِيْنَ : بیشک متقی لوگوں کے لئے مَفَازًا : کامیابی ہے یقیناً پرہیزگار لوگوں کے لئے کامیابی ہے۔
  78,32,حَدَآئِقَ وَ اَعْنَابًاۙ حَدَآئِقَ : باغات ہیں وَاَعْنَابًا : اور انگور ہیں باغات ہیں اور انگور ہیں۔
  78,33,وَّ كَوَاعِبَ اَتْرَابًاۙ وَّكَوَاعِبَ : اور نوخیز لڑکیاں اَتْرَابًا : ہم عمر اور نوجوان کنواری ہم عمر عورتیں ہیں (1)
  78,34,وَّ كَاْسًا دِهَاقًاؕ وَّكَاْسًا : اور جام دِهَاقًا : چھلکتے ہوئے/ بھرے ہوئے چھلکتے ہوئے جام شراب ہیں۔
  78,35,لَا یَسْمَعُوْنَ فِیْهَا لَغْوًا وَّ لَا كِذّٰبًاۚ لَا يَسْمَعُوْنَ : نہ وہ سنیں گے فِيْهَا : اس میں لَغْوًا : کوئی لغو بات وَّلَا كِذّٰبًا : اور نہ کوئی جھوٹی بات اور وہاں نہ تو وہ بیہودہ باتیں سنیں گے اور نہ ہی جھوٹیں باتیں سنیں گے (1)
  78,36,جَزَآءً مِّنْ رَّبِّكَ عَطَآءً حِسَابًاۙ جَزَآءً : بدلہ ہے مِّنْ رَّبِّكَ : تیرے رب کی طرف سے عَطَآءً : بدلہ/ بخشش حِسَابًا : بےحساب/ کفایت کرنے والی (ان کو) تیرے رب کی طرف سے (ان کے نیک اعمال کا) یہ بدلہ ملے گا جو کافی انعام ہوگا (1)
  78,37,رَّبِّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا الرَّحْمٰنِ لَا یَمْلِكُوْنَ مِنْهُ خِطَابًاۚ رَّبِّ السَّمٰوٰتِ : جو رب ہے آسمانوں کا وَالْاَرْضِ : اور زمین کا وَمَا بَيْنَهُمَا الرَّحْمٰنِ : اور جو ان دونوں کے درمیان ہے رحمن لَا يَمْلِكُوْنَ : نہ مالک ہوں گے مِنْهُ خِطَابًا : اس سے بات کرنے کے (اس رب کی طرف سے ملے گا جو کہ) آسمانوں کا اور زمین کا اور جو کچھ ان کے درمیان ہے ان کا پروردگار ہے اور بڑی بخشش کرنے والا ہے۔ کسی کو اس سے بات چیت کرنے کا اختیار نہیں ہوگا (1)
  78,38,یَوْمَ یَقُوْمُ الرُّوْحُ وَ الْمَلٰٓئِكَةُ صَفًّا١ۙۗؕ لَّا یَتَكَلَّمُوْنَ اِلَّا مَنْ اَذِنَ لَهُ الرَّحْمٰنُ وَ قَالَ صَوَابًا يَوْمَ : جس دن يَقُوْمُ الرُّوْحُ : قیام کریں گے روح/ روح الامین وَالْمَلٰٓئِكَةُ : اور فرشتے صَفًّا ٷ : صف در صف لَّا يَتَكَلَّمُوْنَ : نہ کلام کرسکیں گے/ نہ بات کرسیں گے اِلَّا : مگر مَنْ اَذِنَ : جس کو اجازت دے لَهُ : اس کے لئے الرَّحْمٰنُ : رحمن وَقَالَ صَوَابًا : اور وہ کہے درست بات جس دن روح اور فرشتے صفیں باندھ کھڑے ہونگے تو کوئی کلام نہ کرسکے گا مگر جسے رحمٰن اجازت دے دے اور وہ ٹھیک بات زبان سے نکالے (1)
  78,39,ذٰلِكَ الْیَوْمُ الْحَقُّ١ۚ فَمَنْ شَآءَ اتَّخَذَ اِلٰى رَبِّهٖ مَاٰبًا ذٰلِكَ : یہ ہے الْيَوْمُ الْحَقُّ ۚ : دن برحق فَمَنْ : پس جو کوئی شَآءَ : چاہے اتَّخَذَ : بنالے اِلٰى رَبِّهٖ : اپنے رب کی طرف مَاٰبًا : ٹھکانہ یہ دن ہے اب جو چاہے اپنے رب کے پاس (نیک اعمال کر کے) ٹھکانا بنالے (1)
  78,40,اِنَّاۤ اَنْذَرْنٰكُمْ عَذَابًا قَرِیْبًا١ۖۚ۬ یَّوْمَ یَنْظُرُ الْمَرْءُ مَا قَدَّمَتْ یَدٰهُ وَ یَقُوْلُ الْكٰفِرُ یٰلَیْتَنِیْ كُنْتُ تُرٰبًا۠    ۧ اِنَّآ اَنْذَرْنٰكُمْ : بیشک ہم نے، خبردار کیا ہم نے تم کو عَذَابًا قَرِيْبًا ڄ : قریبی عذاب سے يَّوْمَ يَنْظُرُ : جس دن دیکھے گا الْمَرْءُ : انسان مَا قَدَّمَتْ يَدٰهُ : جو آگے بھیجا اس کے دونوں ہاتھوں نے وَيَقُوْلُ الْكٰفِرُ : اور کہے گا کافر يٰلَيْتَنِيْ : اے کاش کہ میں كُنْتُ تُرٰبًا : میں ہوتا مٹی/خاک ہم نے تمہیں عنقریب آنے والے عذاب سے ڈرا دیا اور (چوکنا کردیا) ہے جس دن انسان اپنے ہاتھوں کی کمائی کو دیکھ لے گا اور کافر کہے گا کہ کاش ! میں مٹی ہوجاتا (1)
  79,1,وَ النّٰزِعٰتِ غَرْقًاۙ وَالنّٰزِعٰتِ : قسم ہے ان فرشتوں کی جو کھینچنے والے ہیں غَرْقًا : غرق ہوکر/ ڈوب کر ڈوب کر سختی سے کھنچنے والوں کی قسم (1)
  79,2,وَّ النّٰشِطٰتِ نَشْطًاۙ وَّالنّٰشِطٰتِ : قسم ہے ان فرشتوں کی جو آسانی سے نکالنے والے ہیں نَشْطًا : نکال لینا بند کھول کر چھڑا دینے والوں کی قسم (1)
  79,3,وَّ السّٰبِحٰتِ سَبْحًاۙ وَّالسّٰبِحٰتِ : قسم ہے ان فرشتوں کی جو تیرنے والے ہیں سَبْحًا : تیرنا اور تیرنے پھرنے والوں کی قسم (1)
  79,4,فَالسّٰبِقٰتِ سَبْقًاۙ فَالسّٰبِقٰتِ : پھر آگے بڑھنے والوں کی/ سبقت کرنے والوں کی سَبْقًا : سبقت کرنا/ آگے بڑھنا پھر دوڑ کر آگے بڑھنے والوں کی قسم (1)
  79,5,فَالْمُدَبِّرٰتِ اَمْرًاۘ فَالْمُدَبِّرٰتِ : پھر تدبیر کرنے والوں کی اَمْرًا : کام میں/ کام کی پھر کام کی تدبیر کرنے والوں کی قسم (1)
  79,6,یَوْمَ تَرْجُفُ الرَّاجِفَةُۙ يَوْمَ : جس دن تَرْجُفُ : کانپے گی الرَّاجِفَةُ : کانپنے والی جس دن کا پنے والی کانپے گی (1)
  79,7,تَتْبَعُهَا الرَّادِفَةُؕ تَتْبَعُهَا : پیچھے آئے گی اس کے الرَّادِفَةُ : پیچھے آنے والی اس کے بعد ایک پیچھے آنے والی (پیچھے پیچھے) آئے گی (1)
  79,8,قُلُوْبٌ یَّوْمَئِذٍ وَّاجِفَةٌۙ قُلُوْبٌ : کچھ دل يَّوْمَئِذٍ : اس دن وَّاجِفَةٌ : دھڑکنے والے ہیں/ ہوں گے (بہت سے) دل اس دن دھڑ کتے ہونگے (1)
  79,9,اَبْصَارُهَا خَاشِعَةٌۘ اَبْصَارُهَا : نگاہیں ان کی خَاشِعَةٌ : دبی ہوئی ہوں گی/ سہمی ہوئی ہوں گی جس کی نگاہیں نیچی ہونگی (1)
  79,10,یَقُوْلُوْنَ ءَاِنَّا لَمَرْدُوْدُوْنَ فِی الْحَافِرَةِؕ يَقُوْلُوْنَ : کہتے ہیں ءَاِنَّا : کیا بیشک ہم لَمَرْدُوْدُوْنَ : البتہ پھیرے جانے والے ہیں فِي الْحَافِرَةِ : پہلی حالت میں کہتے ہیں کہ کیا پہلی کی سی حالت کی طرف لوٹائے جائیں گے (1)
  79,11,ءَاِذَا كُنَّا عِظَامًا نَّخِرَةًؕ ءَاِذَا كُنَّا : کیا جب ہوں گے ہم عِظَامًا : ہڈیاں نَّخِرَةً : بھربھری/ گلی سڑی کیا اس وقت جب کہ ہم بوسیدہ ہڈیاں ہوجائیں گے (1)
  79,12,قَالُوْا تِلْكَ اِذًا كَرَّةٌ خَاسِرَةٌۘ قَالُوْا تِلْكَ : انہوں نے کہا یہ اِذًا : تب كَرَّةٌ خَاسِرَةٌ : واپسی ہے گھاٹے کی/ خسارے کی کہتے ہیں کہ پھر تو یہ لوٹنا نقصان دہ ہے (1)
  79,13,فَاِنَّمَا هِیَ زَجْرَةٌ وَّاحِدَةٌۙ فَاِنَّمَا ھِيَ : تو بیشک وہ زَجْرَةٌ : ایک ڈانٹ ہے وَّاحِدَةٌ : بس ایک ہی (معلوم ہونا چاہیئے) وہ تو صرف ایک (خوفناک) ڈانٹ ہے۔
  79,14,فَاِذَا هُمْ بِالسَّاهِرَةِؕ فَاِذَا هُمْ : تو اچانک وہ بِالسَّاهِرَةِ : میدان میں ہوں گے کہ (جس کے ظاہر ہوتے ہی) وہ ایک دم میدان میں جمع ہوجائیں گے (1)
  79,15,هَلْ اَتٰىكَ حَدِیْثُ مُوْسٰىۘ هَلْ اَتٰىكَ : کیا آئی ہے تیرے پاس حَدِيْثُ مُوْسٰى : بات موسیٰ کی کیا موسیٰ ؑ کی خبر تمہیں پہنچی ہے ؟
