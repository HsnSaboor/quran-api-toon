tafsir[23]{c,v,t}:
  26,137,اِنْ هٰذَاۤ اِلَّا خُلُقُ الْاَوَّلِیْنَۙ اِنْ ھٰذَآ : نہیں ہے اِلَّا : مگر خُلُقُ : عادت الْاَوَّلِيْنَ : اگلے لوگ یہ تو بس پرانے لوگوں کی عادت ہے 1
  26,138,وَ مَا نَحْنُ بِمُعَذَّبِیْنَۚ وَمَا : اور نہیں نَحْنُ : ہم بِمُعَذَّبِيْنَ : عزاب دئیے جانیوالوں سے اور ہم ہرگز عذاب نہیں دیئے جائیں گے 1
  26,139,فَكَذَّبُوْهُ فَاَهْلَكْنٰهُمْ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ فَكَذَّبُوْهُ : پس انہوں نے جھٹلایا اسے فَاَهْلَكْنٰهُمْ : تو ہم نے ہلاک کردیا انہیں اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا كَانَ : اور نہیں تھے اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے چونکہ عادیوں نے حضرت ہود کو جھٹلایا، اس لئے ہم نے انھیں تباہ کردیا 1 یقیناً اس میں نشانی ہے اور ان میں سے اکثر بےایمان تھے۔
  26,140,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان بیشک آپ کا رب وہی ہے غالب مہربان۔
  26,141,كَذَّبَتْ ثَمُوْدُ الْمُرْسَلِیْنَۚۖ كَذَّبَتْ : جھٹلایا ثَمُوْدُ : ثمود الْمُرْسَلِيْنَ : رسول (جمع) ثمودیوں 1 نے بھی پیغمبروں کو جھٹلایا۔
  26,142,اِذْ قَالَ لَهُمْ اَخُوْهُمْ صٰلِحٌ اَلَا تَتَّقُوْنَۚ اِذْ : جب قَالَ : کہا لَهُمْ : ان سے اَخُوْهُمْ : ان کے بھائی صٰلِحٌ : صالح اَلَا تَتَّقُوْنَ : کیا تم ڈرتے نہیں ان کے بھائی صالح نے فرمایا کہ کیا تم اللہ سے نہیں ڈرتے ؟
  26,143,اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے رَسُوْلٌ : رسول اَمِيْنٌ : امانت دار میں تمہاری طرف اللہ کا امانت دار پیغمبر ہوں۔
  26,144,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : سو تم ڈرو اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور تم میری اطاعت کرو تو تم اللہ سے ڈرو اور میرا کہا مانو۔
  26,145,وَ مَاۤ اَسْئَلُكُمْ عَلَیْهِ مِنْ اَجْرٍ١ۚ اِنْ اَجْرِیَ اِلَّا عَلٰى رَبِّ الْعٰلَمِیْنَؕ وَمَآ اَسْئَلُكُمْ : اور میں نہیں مانگتا تم سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر عَلٰي : پر رَبِّ الْعٰلَمِيْنَ : رب العالمین میں اس پر تم سے کوئی اجرت نہیں مانگتا، میری اجرت تو بس پروردگار عالم پر ہی ہے۔
  26,146,اَتُتْرَكُوْنَ فِیْ مَا هٰهُنَاۤ اٰمِنِیْنَۙ اَتُتْرَكُوْنَ : کیا چھوڑ دئیے جاؤگے تم فِيْ : میں مَا هٰهُنَآ : جو یہاں ہے اٰمِنِيْنَ : بےفکر کیا ان چیزوں جو یہاں ہیں تم امن کے ساتھ چھوڑ دیئے جاؤ گے 1
  26,147,فِیْ جَنّٰتٍ وَّ عُیُوْنٍۙ فِيْ جَنّٰتٍ : باغات میں وَّعُيُوْنٍ : اور چشمے یعنی ان باغوں اور ان چشموں۔
  26,148,وَّ زُرُوْعٍ وَّ نَخْلٍ طَلْعُهَا هَضِیْمٌۚ وَّزُرُوْعٍ : اور کھیتیاں وَّنَخْلٍ : اور کھجوریں طَلْعُهَا : ان کے خوشے هَضِيْمٌ : نرم و نازک اور ان کھیتوں اور ان کھجوروں کے باغوں میں جن کے شگوفے نرم و نازک ہیں 1۔
  26,149,وَ تَنْحِتُوْنَ مِنَ الْجِبَالِ بُیُوْتًا فٰرِهِیْنَۚ وَتَنْحِتُوْنَ : اور تم تراشتے ہو مِنَ الْجِبَالِ : پہاڑوں سے بُيُوْتًا : گھر فٰرِهِيْنَ : خوش ہوکر اور تم پہاڑوں کو تراش تراش کر پر تکلف مکانات بنا رہے ہو 1
  26,150,فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِۚ فَاتَّقُوا : سو ڈرو تم اللّٰهَ : اللہ وَاَطِيْعُوْنِ : اور میری اطاعت کرو پس اللہ سے ڈرو اور میری اطاعت کرو۔
  26,151,وَ لَا تُطِیْعُوْۤا اَمْرَ الْمُسْرِفِیْنَۙ وَلَا تُطِيْعُوْٓا : اور نہ کہا مانو اَمْرَ : حکم الْمُسْرِفِيْنَ : حد سے بڑھ جانیوالے بےباک حد سے گزر جانے والوں کی 1 اطاعت سے باز آجاؤ۔
  26,152,الَّذِیْنَ یُفْسِدُوْنَ فِی الْاَرْضِ وَ لَا یُصْلِحُوْنَ الَّذِيْنَ : جو لوگ يُفْسِدُوْنَ : فساد کرتے ہیں فِي : میں الْاَرْضِ : زمین وَ : اور لَا يُصْلِحُوْنَ : اصلاح نہیں کرتے جو ملک میں فساد پھیلا رہے ہیں اور اصلاح نہیں کرتے۔
  26,153,قَالُوْۤا اِنَّمَاۤ اَنْتَ مِنَ الْمُسَحَّرِیْنَۚ قَالُوْٓا : انہوں نے کہا اِنَّمَآ : اس کے سوا نہیں اَنْتَ : تم مِنَ : سے الْمُسَحَّرِيْنَ : سحر زدہ لوگ وہ بولے کہ بس تو ان میں سے ہے جن پر جادو کردیا گیا ہے۔
  26,154,مَاۤ اَنْتَ اِلَّا بَشَرٌ مِّثْلُنَا١ۖۚ فَاْتِ بِاٰیَةٍ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ مَآ اَنْتَ : تم نہیں اِلَّا بَشَرٌ : مگر۔ صرف۔ ایک بشر مِّثْلُنَا : ہم جیسا فَاْتِ : پس لاؤ بِاٰيَةٍ : کوئی نشانی اِنْ : اگر كُنْتَ : تو مِنَ : سے الصّٰدِقِيْنَ : سچے لوگ تو تو ہم جیسا ہی انسان ہے۔ اگر تو سچوں سے ہے تو کوئی معجزہ لے آ۔
  26,155,قَالَ هٰذِهٖ نَاقَةٌ لَّهَا شِرْبٌ وَّ لَكُمْ شِرْبُ یَوْمٍ مَّعْلُوْمٍۚ قَالَ : اس نے فرمایا هٰذِهٖ : یہ نَاقَةٌ : اونٹنی لَّهَا : اس کے لیے شِرْبٌ : پانی پینے کی باری وَّلَكُمْ : اور تمہارے لیے شِرْبُ : بایک باری پانی پینے کی يَوْمٍ مَّعْلُوْمٍ : معین دن آپ نے فرمایا یہ ہے اونٹنی، پانی پینے کی ایک باری اس کی اور ایک مقررہ دن کی باری پانی پینے کی تمہاری 1۔
  26,156,وَ لَا تَمَسُّوْهَا بِسُوْٓءٍ فَیَاْخُذَكُمْ عَذَابُ یَوْمٍ عَظِیْمٍ وَلَا تَمَسُّوْهَا : اور اسے ہاتھ نہ لگانا بِسُوْٓءٍ : برائی سے فَيَاْخُذَكُمْ : سو (ورنہ) تمہیں آپکڑے گا عَذَابُ : عذاب يَوْمٍ عَظِيْمٍ : ایک بڑا دن (خبر دار) اسے برائی سے ہاتھ نہ لگانا ورنہ ایک بڑے بھاری دن کا عذاب تمہاری گرفت کرلے گا 1
  26,157,فَعَقَرُوْهَا فَاَصْبَحُوْا نٰدِمِیْنَۙ فَعَقَرُوْهَا : پھر انہوں نے کونچیں کاٹ دیں اسکی فَاَصْبَحُوْا : پس رہ گئے نٰدِمِيْنَ : پشیمان پھر بھی انہوں نے اس کی کوچیں کاٹ ڈالیں، 1 بس وہ پشیمان ہوگئے 2۔
  26,158,فَاَخَذَهُمُ الْعَذَابُ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیَةً١ؕ وَ مَا كَانَ اَكْثَرُهُمْ مُّؤْمِنِیْنَ فَاَخَذَهُمُ : پھر انہیں آپکڑا الْعَذَابُ : عذاب اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی وَمَا : اور نہیں كَانَ : ہیں اَكْثَرُهُمْ : ان کے اکثر مُّؤْمِنِيْنَ : ایمان لانے والے اور عذاب نے آدبوچا 1 بیشک اس میں عبرت ہے۔ اور ان میں اکثر لوگ مومن نہ تھے۔
  26,159,وَ اِنَّ رَبَّكَ لَهُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تمہارا رب لَهُوَ : البتہ وہ الْعَزِيْزُ : غالب الرَّحِيْمُ : نہایت مہربان اور بیشک آپ کا رب بڑا زبردست اور مہربان ہے۔
