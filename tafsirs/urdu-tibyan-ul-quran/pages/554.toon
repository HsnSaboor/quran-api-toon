tafsir[7]{c,v,t}:
  62,9,یٰۤاَیُّهَا الَّذِیْنَ اٰمَنُوْۤا اِذَا نُوْدِیَ لِلصَّلٰوةِ مِنْ یَّوْمِ الْجُمُعَةِ فَاسْعَوْا اِلٰى ذِكْرِ اللّٰهِ وَ ذَرُوا الْبَیْعَ١ؕ ذٰلِكُمْ خَیْرٌ لَّكُمْ اِنْ كُنْتُمْ تَعْلَمُوْنَ يٰٓاَيُّهَا الَّذِيْنَ اٰمَنُوْٓا : اے لوگو جو ایمان لائے ہو اِذَا نُوْدِيَ للصَّلٰوةِ : جب پکارا جائے نماز کے لیے مِنْ يَّوْمِ : دن الْجُمُعَةِ : جمعہ کے فَاسْعَوْا : تو دوڑو اِلٰى ذِكْرِ اللّٰهِ : اللہ کے ذکر کی طرف وَذَرُوا الْبَيْعَ : اور چھوڑ دو تجارت ذٰلِكُمْ : یہ خَيْرٌ لَّكُمْ : بہتر ہے تمہارے لیے اِنْ كُنْتُمْ تَعْلَمُوْنَ : اگر تم علم رکھتے ہو اے وہ لوگوں جو ایمان لائے ہو ! جمعہ کے دن نماز کی اذان دی جائے تو تم اللہ کے ذکر کی طرف دوڑ پڑو اور خریدو فروخت چھوڑ دو (1) یہ تمہارے حق میں بہت ہی بہتر ہے اگر تم جانتے ہو۔
  62,10,فَاِذَا قُضِیَتِ الصَّلٰوةُ فَانْتَشِرُوْا فِی الْاَرْضِ وَ ابْتَغُوْا مِنْ فَضْلِ اللّٰهِ وَ اذْكُرُوا اللّٰهَ كَثِیْرًا لَّعَلَّكُمْ تُفْلِحُوْنَ فَاِذَا قُضِيَتِ : پھر جب پوری ہوجائے الصَّلٰوةُ : نماز فَانْتَشِرُوْا : تو پھیل جاؤ فِي الْاَرْضِ : زمین میں وَابْتَغُوْا : اور تلاش کرو مِنْ فَضْلِ : فضل میں سے اللّٰهِ : اللہ کے وَاذْكُرُوا اللّٰهَ : اور ذکر کرو اللہ کا كَثِيْرًا : بہت لَّعَلَّكُمْ : تاکہ تم تُفْلِحُوْنَ : تم فلاح پاؤ پھر جب نماز ہوچکے تو زمین میں پھیل جاؤ اور اللہ کا فضل تلاش کرو (1) اور بکثرت اللہ کا ذکر کیا کرو تاکہ تم فلاح پالو۔
  62,11,وَ اِذَا رَاَوْا تِجَارَةً اَوْ لَهْوَا اِ۟نْفَضُّوْۤا اِلَیْهَا وَ تَرَكُوْكَ قَآئِمًا١ؕ قُلْ مَا عِنْدَ اللّٰهِ خَیْرٌ مِّنَ اللَّهْوِ وَ مِنَ التِّجَارَةِ١ؕ وَ اللّٰهُ خَیْرُ الرّٰزِقِیْنَ۠    ۧ وَاِذَا : اور جب رَاَوْا : انہوں نے دیکھا تِجَارَةً : تجارت کو اَوْ لَهْوَۨا : یا کھیل تماشے کو انْفَضُّوْٓا اِلَيْهَا : مائل ہوگئے اس کی طرف وَتَرَكُوْكَ : اور انہوں نے چھوڑ دیا آپ کو قَآئِمًا : کھڑے۔ کھڑی حالت میں قُلْ : کہہ دیجئے مَا عِنْدَ اللّٰهِ : جو اللہ کے پاس ہے خَيْرٌ : بہتر ہے مِّنَ اللَّهْوِ : کھیل تماشے سے وَمِنَ : اور ، سے التِّجَارَةِ : تجارت (سے) وَاللّٰهُ : اور اللہ خَيْرُ الرّٰزِقِيْنَ : بہترین رزق دینے والا ہے جب کوئی سودا بکتا دیکھیں یا کوئی تماشا نظر آجائے تو اس کی طرف دوڑ جاتے ہیں اور آپ کو کھڑا ہی چھوڑ دیتے ہیں (1) آپ کہہ دیجئے کہ اللہ کے پاس جو ہے (2) وہ کھیل اور تجارت سے بہتر ہے (3) اور اللہ تعالیٰ بہترین روزی رساں ہے (4)۔
  63,1,اِذَا جَآءَكَ الْمُنٰفِقُوْنَ قَالُوْا نَشْهَدُ اِنَّكَ لَرَسُوْلُ اللّٰهِ١ۘ وَ اللّٰهُ یَعْلَمُ اِنَّكَ لَرَسُوْلُهٗ١ؕ وَ اللّٰهُ یَشْهَدُ اِنَّ الْمُنٰفِقِیْنَ لَكٰذِبُوْنَۚ اِذَا جَآءَكَ : جب آتے ہیں تیرے پاس الْمُنٰفِقُوْنَ : منافق قَالُوْا نَشْهَدُ : کہتے ہیں ہم گواہی دیتے ہو اِنَّكَ لَرَسُوْلُ اللّٰهِ : بیشک آپ البتہ اللہ کے رسول ہیں وَاللّٰهُ : اور اللہ يَعْلَمُ : جانتا ہے اِنَّكَ لَرَسُوْلُهٗ : بیشک آپ البتہ اس کے رسول ہیں وَاللّٰهُ يَشْهَدُ : اور اللہ گواہی دیتا ہے اِنَّ : بیشک الْمُنٰفِقِيْنَ : منافق لَكٰذِبُوْنَ : البتہ جھوٹے ہیں تیرے پاس جب منافق آتے ہیں تو کہتے ہیں ہم اس بات کے گواہ ہیں کہ بیشک آپ اللہ کے رسول ہیں (1) اور اللہ جانتا ہے کہ یقیناً آپ اللہ کے رسول ہیں (2) اور اللہ گواہی دیتا ہے کہ یہ منافق قطعًا جھوٹے ہیں (3)
  63,2,اِتَّخَذُوْۤا اَیْمَانَهُمْ جُنَّةً فَصَدُّوْا عَنْ سَبِیْلِ اللّٰهِ١ؕ اِنَّهُمْ سَآءَ مَا كَانُوْا یَعْمَلُوْنَ اِتَّخَذُوْٓا : انہوں نے بنا لیا اَيْمَانَهُمْ : اپنی قسموں کو جُنَّةً : ڈھال فَصَدُّوْا : تو انہوں نے روکا عَنْ سَبِيْلِ اللّٰهِ : اللہ کے راستے سے اِنَّهُمْ : بیشک وہ سَآءَ : کتنا برا ہے مَا كَانُوْا : جو کچھ وہ ہیں يَعْمَلُوْنَ : وہ کررہے انہوں نے اپنی قسموں کو ڈھال بنا رکھا ہے (1) پس اللہ کی راہ سے رک گئے (2) بیشک برا ہے وہ کام جو یہ کر رہے ہیں۔
  63,3,ذٰلِكَ بِاَنَّهُمْ اٰمَنُوْا ثُمَّ كَفَرُوْا فَطُبِعَ عَلٰى قُلُوْبِهِمْ فَهُمْ لَا یَفْقَهُوْنَ ذٰلِكَ بِاَنَّهُمْ : یہ بوجہ اس کے کہ بیشک وہ اٰمَنُوْا : ایمان لائے ثُمَّ كَفَرُوْا : پھر انہوں نے کفر کیا فَطُبِعَ : تو مہر لگا دی گئی عَلٰي : اوپر قُلُوْبِهِمْ : ان کے دلوں کے فَهُمْ : پس وہ لَا يَفْقَهُوْنَ : سمجھتے نہیں ہیں یہ اس سب اسلئے ہے کہ یہ ایمان لا کر پھر کافر ہوگئے (1) پس ان کے دلوں پر مہر کردی گئی ہے۔ اب یہ نہیں سمجھتے۔
  63,4,وَ اِذَا رَاَیْتَهُمْ تُعْجِبُكَ اَجْسَامُهُمْ١ؕ وَ اِنْ یَّقُوْلُوْا تَسْمَعْ لِقَوْلِهِمْ١ؕ كَاَنَّهُمْ خُشُبٌ مُّسَنَّدَةٌ١ؕ یَحْسَبُوْنَ كُلَّ صَیْحَةٍ عَلَیْهِمْ١ؕ هُمُ الْعَدُوُّ فَاحْذَرْهُمْ١ؕ قٰتَلَهُمُ اللّٰهُ١٘ اَنّٰى یُؤْفَكُوْنَ وَاِذَا : پھر جب رَاَيْتَهُمْ : تم دیکھو ان کو تُعْجِبُكَ : اچھے لگیں گے تم کو اَجْسَامُهُمْ : ان کے جسم وَاِنْ يَّقُوْلُوْا : اور اگر وہ بات کریں تَسْمَعْ لِقَوْلِهِمْ : تم سنتے جاؤ ان کی بات کو كَاَنَّهُمْ : گویا کہ وہ خُشُبٌ : لکڑیاں ہیں مُّسَنَّدَةٌ : تختہ لگائی ہوئیں يَحْسَبُوْنَ : وہ سمجھتے ہیں كُلَّ صَيْحَةٍ : ہر سخت آواز کو عَلَيْهِمْ : اپنے اوپر هُمُ : وہ الْعَدُوُّ : دشمن ہیں فَاحْذَرْهُمْ : پس ڈرو ان سے۔ بچو ان سے قٰتَلَهُمُ اللّٰهُ : غارت کرے ان کو اللہ اَنّٰى يُؤْفَكُوْنَ : کہاں سے وہ پھرے جاتے ہیں جب آپ انہیں دیکھ لیں تو ان کے جسم آپ کو خوشنما معلوم ہوں (1) یہ جب باتیں کرنے لگیں تو آپ ان کی باتوں پر (اپنا) کان لگائیں (2) گویا کہ یہ لکڑیاں ہیں اور دیوار کے سہارے لگائی ہوئی (3) ہیں ہر سخت آواز کو اپنے خلاف سمجھتے ہیں (4) یہی حقیقی دشمن ہیں ان سے بچو اللہ انہیں غارت کرے کہاں سے پھرے جاتے ہیں۔
