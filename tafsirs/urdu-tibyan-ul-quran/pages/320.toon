tafsir[12]{c,v,t}:
  20,114,فَتَعٰلَى اللّٰهُ الْمَلِكُ الْحَقُّ١ۚ وَ لَا تَعْجَلْ بِالْقُرْاٰنِ مِنْ قَبْلِ اَنْ یُّقْضٰۤى اِلَیْكَ وَحْیُهٗ١٘ وَ قُلْ رَّبِّ زِدْنِیْ عِلْمًا فَتَعٰلَى اللّٰهُ : سو بلندو برتر ہے اللہ الْمَلِكُ : بادشاہ الْحَقُّ : سچا وَلَا : اور نہ تَعْجَلْ : جلدی کرو بِالْقُرْاٰنِ : قرآن میں مِنْ قَبْلِ : اس سے قبل کہ اَنْ : کہ يُّقْضٰٓى : پوری کی جائے اِلَيْكَ : پوری کی جائے وَحْيُهٗ : اس کی وحی وَقُلْ : اور کہیے رَّبِّ : اے میرے رب زِدْنِيْ : زیادہ دے مجھے عِلْمًا : علم پس اللہ عالی شان والا سچا اور حقیقی بادشاہ (1) ہے۔ تو قرآن پڑھنے میں جلدی نہ کر اس سے پہلے کہ تیری طرف جو وحی کی جاتی ہے وہ پوری کی جائے، (2) ہاں یہ دعا کر کہ پروردگار میرا علم بڑھا (3)
  20,115,وَ لَقَدْ عَهِدْنَاۤ اِلٰۤى اٰدَمَ مِنْ قَبْلُ فَنَسِیَ وَ لَمْ نَجِدْ لَهٗ عَزْمًا۠    ۧ وَلَقَدْ عَهِدْنَآ : اور ہم نے حکم بھیجا اِلٰٓى : طرف۔ کو اٰدَمَ : آدم مِنْ قَبْلُ : اس سے قبل فَنَسِيَ : تو وہ بھول گیا وَلَمْ نَجِدْ : اور ہم نے نہ پایا لَهٗ : اس میں عَزْمًا : پختہ ارادہ ہم نے آدم کو پہلے تاکیدی حکم دے دیا تھا لیکن وہ بھول گیا اور ہم نے اس میں کوئی عزم نہیں پایا (1)
  20,116,وَ اِذْ قُلْنَا لِلْمَلٰٓئِكَةِ اسْجُدُوْا لِاٰدَمَ فَسَجَدُوْۤا اِلَّاۤ اِبْلِیْسَ١ؕ اَبٰى وَاِذْ : اور (یاد کرو) جب قُلْنَا : ہم نے کہا لِلْمَلٰٓئِكَةِ : فرشتوں کو اسْجُدُوْا : تم سجدہ کرو لِاٰدَمَ : آدم کو فَسَجَدُوْٓا : تو سب نے سجدہ کیا اِلَّآ : سوائے اِبْلِيْسَ : ابلیس اَبٰى : اس نے انکار کیا اور جب ہم نے فرشتوں سے کہا کہ آدم ؑ کو سجدہ کرو تو ابلیس کے سوا سب نے کیا۔ اس نے صاف انکار کردیا۔
  20,117,فَقُلْنَا یٰۤاٰدَمُ اِنَّ هٰذَا عَدُوٌّ لَّكَ وَ لِزَوْجِكَ فَلَا یُخْرِجَنَّكُمَا مِنَ الْجَنَّةِ فَتَشْقٰى فَقُلْنَا : پس ہم نے کہا يٰٓاٰدَمُ : اے آدم اِنَّ : بیشک ھٰذَا : یہ عَدُوٌّ : دشمن لَّكَ : تمہارا وَلِزَوْجِكَ : اور تمہاری بیوی کا فَلَا : سو تمہیں يُخْرِجَنَّكُمَا : نہ نکلوا دے مِنَ الْجَنَّةِ : جنت سے فَتَشْقٰي : پھر تم مصیبت میں پڑجاؤ تو ہم نے کہا اے آدم ! یہ تیرا اور تیری بیوی کا دشمن ہے (خیال رکھنا) ایسا نہ ہو کہ وہ تم دونوں کو جنت سے نکلوا دے کہ تو مصیبت میں پڑجائے (1)
  20,118,اِنَّ لَكَ اَلَّا تَجُوْعَ فِیْهَا وَ لَا تَعْرٰىۙ اِنَّ : بیشک لَكَ : تمہارے لیے اَلَّا تَجُوْعَ : یہ کہ نہ بھوکے رہو فِيْهَا : اس میں وَلَا : اور نہ تَعْرٰى : ننگے یہاں تو تجھے یہ آرام ہے کہ نہ تو بھوکا ہوتا ہے نہ ننگا۔
  20,119,وَ اَنَّكَ لَا تَظْمَؤُا فِیْهَا وَ لَا تَضْحٰى وَاَنَّكَ : اور یہ کہ تم لَا : نہ تَظْمَؤُا : پیاسے رہو گے فِيْهَا : اس میں وَلَا تَضْحٰي : اور نہ دھوپ میں رہو گے اور نہ تو یہاں پیاسا ہوتا ہے نہ دھوپ سے تکلیف اٹھاتا ہے۔
  20,120,فَوَسْوَسَ اِلَیْهِ الشَّیْطٰنُ قَالَ یٰۤاٰدَمُ هَلْ اَدُلُّكَ عَلٰى شَجَرَةِ الْخُلْدِ وَ مُلْكٍ لَّا یَبْلٰى فَوَسْوَسَ : پھر وسوسہ ڈالا اِلَيْهِ : اسکی طرف (دل میں) الشَّيْطٰنُ : شیطان قَالَ : اس نے کہا يٰٓاٰدَمُ : اے آدم هَلْ : کیا اَدُلُّكَ : میں تیری رہنمائی کروں عَلٰي : پر شَجَرَةِ : درخت الْخُلْدِ : ہمیشگی وَمُلْكٍ : اور بادشاہت لَّا يَبْلٰى : نہ پرانی (زوال پذیر) ہو) لیکن شیطان نے وسوسہ ڈالا، کہنے لگا کہ کیا میں تجھے دائمی زندگی کا درخت اور بادشاہت بتلاؤں کہ جو کبھی پرانی نہ ہو
  20,121,فَاَكَلَا مِنْهَا فَبَدَتْ لَهُمَا سَوْاٰتُهُمَا وَ طَفِقَا یَخْصِفٰنِ عَلَیْهِمَا مِنْ وَّرَقِ الْجَنَّةِ١٘ وَ عَصٰۤى اٰدَمُ رَبَّهٗ فَغَوٰى۪ۖ فَاَكَلَا : پس دونوں نے کھایا مِنْهَا : اس سے فَبَدَتْ : تو ظاہر ہوگئیں لَهُمَا : ان پر سَوْاٰتُهُمَا : ان کی شرم گاہیں وَ : اور طَفِقَا يَخْصِفٰنِ : وہ دونوں لگے جوڑنے (ڈھانپنے) عَلَيْهِمَا : اپنے اوپر مِنْ : سے وَّرَقِ الْجَنَّةِ : جنت کے پتے وَعَصٰٓى : اور نافرمانی کی اٰدَمُ : آدم رَبَّهٗ : اپنا رب فَغَوٰى : تو وہ بہک گیا چناچہ ان دونوں نے اس درخت سے کچھ کھالیا پس ان کے ستر کھل گئے اور بہشت کے پتے اپنے اوپر ٹانکنے لگے۔ آدم ؑ نے اپنے رب کی نافرمانی کی پس بہک گیا (1)
  20,122,ثُمَّ اجْتَبٰهُ رَبُّهٗ فَتَابَ عَلَیْهِ وَ هَدٰى ثُمَّ : پھر اجْتَبٰىهُ : اس کو چن لیا رَبُّهٗ : اس کا رب فَتَابَ : توجہ فرمائی عَلَيْهِ : اس پر وَهَدٰى : اور اسے راہ دکھائی پھر اس کے رب نے نوازا، اس کی توبہ قبول کی اور اس کی راہنمائی کی (1)
  20,123,قَالَ اهْبِطَا مِنْهَا جَمِیْعًۢا بَعْضُكُمْ لِبَعْضٍ عَدُوٌّ١ۚ فَاِمَّا یَاْتِیَنَّكُمْ مِّنِّیْ هُدًى١ۙ۬ فَمَنِ اتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَ لَا یَشْقٰى قَالَ : فرمایا اهْبِطَا : تم دونوں اتر جاؤ مِنْهَا : یہاں سے جَمِيْعًۢا : سب بَعْضُكُمْ : تم میں سے بعض لِبَعْضٍ : بعض کے عَدُوٌّ : دشمن فَاِمَّا : پس اگر يَاْتِيَنَّكُمْ : تمہارے پاس آئے مِّنِّيْ : میری طرف سے هُدًى : ہدایت فَمَنِ : تو جس نے اتَّبَعَ : پیروی کی هُدَايَ : میری ہدایت فَلَا يَضِلُّ : تو نہ وہ گمراہ ہوگا وَ : اور لَا يَشْقٰي : نہ بدبخت ہوگا فرمایا، تم دونوں یہاں سے اتر جاؤ تم آپس میں ایک دوسرے کے دشمن ہو، اب تمہارے پاس جب کبھی میری طرف سے ہدایت پہنچے تو میری ہدایت کی پیروی کرے نہ تو وہ بہکے گا نہ تکلیف میں پڑے گا۔
  20,124,وَ مَنْ اَعْرَضَ عَنْ ذِكْرِیْ فَاِنَّ لَهٗ مَعِیْشَةً ضَنْكًا وَّ نَحْشُرُهٗ یَوْمَ الْقِیٰمَةِ اَعْمٰى وَمَنْ : اور جس اَعْرَضَ : منہ موڑا عَنْ : سے ذِكْرِيْ : میرے ذکر۔ نصیحت فَاِنَّ : تو بیشک لَهٗ : اس کے لیے مَعِيْشَةً : گزران ضَنْكًا : تنگ وَّنَحْشُرُهٗ : اور ہم اسے اٹھائیں گے يَوْمَ الْقِيٰمَةِ : قیامت کے دن اَعْمٰى : اندھا اور (ہاں) جو میری یاد سے روگردانی کرے گا اس کی زندگی تنگی میں رہے گی، (1) اور ہم اسے بروز قیامت اندھا کرکے اٹھائیں گے (2)
  20,125,قَالَ رَبِّ لِمَ حَشَرْتَنِیْۤ اَعْمٰى وَ قَدْ كُنْتُ بَصِیْرًا قَالَ : وہ کہے گا رَبِّ : اے میرے رب لِمَ حَشَرْتَنِيْٓ : تونے مجھے کیوں اٹھایا اَعْمٰي : اندھا وَ : اندھا قَدْ كُنْتُ : میں تو تھا بَصِيْرًا : دیکھتا۔ بینا وہ کہے گا کہ الٰہی ! مجھے تو نے اندھا بنا کر کیوں اٹھایا ؟ حالانکہ میں تو دیکھتا بھالتا تھا۔
