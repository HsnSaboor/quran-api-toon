tafsir[17]{c,v,t}:
  23,1,قَدْ اَفْلَحَ الْمُؤْمِنُوْنَۙ قَدْ اَفْلَحَ : فلائی پائی (کامیاب ہوئے) الْمُؤْمِنُوْنَ : مومن (جمع) یقیناً ایمان والوں نے فلاح حاصل کرلی 1
  23,2,الَّذِیْنَ هُمْ فِیْ صَلَاتِهِمْ خٰشِعُوْنَۙ الَّذِيْنَ : اور جو هُمْ : وہ فِيْ صَلَاتِهِمْ : اپنی نمازوں میں خٰشِعُوْنَ : خشوع (عاجزی) کرنے والے جو اپنی نماز میں خشوع کرتے ہیں 1
  23,3,وَ الَّذِیْنَ هُمْ عَنِ اللَّغْوِ مُعْرِضُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ عَنِ اللَّغْوِ : لغو (بیہودی باتوں) سے مُعْرِضُوْنَ : منہ پھیرنے والے جو لغویات سے منہ موڑ لیتے ہیں 1
  23,4,وَ الَّذِیْنَ هُمْ لِلزَّكٰوةِ فٰعِلُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ لِلزَّكٰوةِ : زکوۃ (کو) فٰعِلُوْنَ : ادا کرنے والے جو زکوٰۃ ادا کرنے والے ہیں 1
  23,5,وَ الَّذِیْنَ هُمْ لِفُرُوْجِهِمْ حٰفِظُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ لِفُرُوْجِهِمْ : اپنی شرمگاہوں کی حٰفِظُوْنَ : حفاطت کرنے والے جو اپنی شرم گاہوں کی حفاظت کرنے والے ہیں۔
  23,6,اِلَّا عَلٰۤى اَزْوَاجِهِمْ اَوْ مَا مَلَكَتْ اَیْمَانُهُمْ فَاِنَّهُمْ غَیْرُ مَلُوْمِیْنَۚ اِلَّا : مگر عَلٰٓي : پر۔ سے اَزْوَاجِهِمْ : اپنی بیویاں اَوْ : یا مَا مَلَكَتْ : جو مالک ہوئے اَيْمَانُهُمْ : ان کے دائیں ہاتھ فَاِنَّهُمْ : پس بیشک وہ غَيْرُ مَلُوْمِيْنَ : کوئی ملامت نہیں بجز اپنی بیویوں اور ملکیت کی لونڈیوں کے یقیناً یہ ملامتیوں میں سے نہیں ہیں۔
  23,7,فَمَنِ ابْتَغٰى وَرَآءَ ذٰلِكَ فَاُولٰٓئِكَ هُمُ الْعٰدُوْنَۚ فَمَنِ : پس جو ابْتَغٰى : چاہے وَرَآءَ : سوا ذٰلِكَ : اس فَاُولٰٓئِكَ : تو وہی هُمُ : وہ الْعٰدُوْنَ : حد سے بڑھنے والے جو اس کے سوا کچھ اور چاہیں وہی حد سے تجاوز کر جانے والے ہیں 1
  23,8,وَ الَّذِیْنَ هُمْ لِاَمٰنٰتِهِمْ وَ عَهْدِهِمْ رٰعُوْنَۙ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ لِاَمٰنٰتِهِمْ : اپنی امانتیں وَعَهْدِهِمْ : اور اپنے عہد رٰعُوْنَ : رعایت کرنے والے جو اپنی امانتوں اور وعدے کی حفاظت کرنے والے ہیں 1
  23,9,وَ الَّذِیْنَ هُمْ عَلٰى صَلَوٰتِهِمْ یُحَافِظُوْنَۘ وَالَّذِيْنَ : اور وہ جو هُمْ : وہ عَلٰي : پر۔ کی صَلَوٰتِهِمْ : اپنی نمازیں يُحَافِظُوْنَ : حفاظت کرنے والے ہیں جو اپنی نمازوں کی نگہبانی کرتے ہیں 1
  23,10,اُولٰٓئِكَ هُمُ الْوٰرِثُوْنَۙ اُولٰٓئِكَ : یہی لوگ هُمُ : وہ الْوٰرِثُوْنَ : وارث (جمع) یہی وارث ہیں۔
  23,11,الَّذِیْنَ یَرِثُوْنَ الْفِرْدَوْسَ١ؕ هُمْ فِیْهَا خٰلِدُوْنَ الَّذِيْنَ : جو يَرِثُوْنَ : وارث (جمع) الْفِرْدَوْسَ : جنت هُمْ : وہ فِيْهَا : اس میں خٰلِدُوْنَ : ہمیشہ رہیں گے جو فردوس کے وارث ہونگے جہاں وہ ہمیشہ رہیں گے 1
  23,12,وَ لَقَدْ خَلَقْنَا الْاِنْسَانَ مِنْ سُلٰلَةٍ مِّنْ طِیْنٍۚ وَ : اور لَقَدْ خَلَقْنَا : البتہ ہم نے پیدا کیا الْاِنْسَانَ : انسان مِنْ : سے سُلٰلَةٍ : خلاصہ (چنی ہوئی) مِّنْ طِيْنٍ : مٹی سے یقیناً ہم نے انسان کو مٹی کے جوہر سے پیدا کیا 1
  23,13,ثُمَّ جَعَلْنٰهُ نُطْفَةً فِیْ قَرَارٍ مَّكِیْنٍ۪ ثُمَّ : پھر جَعَلْنٰهُ : ہم نے اسے ٹھہرایا نُطْفَةً : نطفہ فِيْ : میں قَرَارٍ مَّكِيْنٍ : مضبوط جگہ پھر اسے نطفہ بنا کر محفوظ جگہ میں قرار دے دیا 1۔
  23,14,ثُمَّ خَلَقْنَا النُّطْفَةَ عَلَقَةً فَخَلَقْنَا الْعَلَقَةَ مُضْغَةً فَخَلَقْنَا الْمُضْغَةَ عِظٰمًا فَكَسَوْنَا الْعِظٰمَ لَحْمًا١ۗ ثُمَّ اَنْشَاْنٰهُ خَلْقًا اٰخَرَ١ؕ فَتَبٰرَكَ اللّٰهُ اَحْسَنُ الْخٰلِقِیْنَؕ ثُمَّ : پھر خَلَقْنَا : ہم نے بنایا النُّطْفَةَ : نطفہ عَلَقَةً : جما ہوا خون فَخَلَقْنَا : پس ہم نے بنایا الْعَلَقَةَ : جما ہوا خون مُضْغَةً : بوٹی فَخَلَقْنَا : پھر ہم نے بنایا الْمُضْغَةَ : بوٹی عِظٰمًا : ہڈیاں فَكَسَوْنَا : پھر ہم پہنایا الْعِظٰمَ : ہڈیاں لَحْمًا : گوشت ثُمَّ : پھر اَنْشَاْنٰهُ : ہم نے اسے اٹھایا خَلْقًا : صورت اٰخَرَ : نئی فَتَبٰرَكَ : پس برکت والا اللّٰهُ : اللہ اَحْسَنُ : بہترین الْخٰلِقِيْنَ : پید ا کرنے والا پھر نطفہ کو ہم نے جما ہوا خون بنادیا، پھر خون کے لوتھڑے کو گوشت کا ٹکڑا کردیا، پھر گوشت کے ٹکڑے کو ہڈیاں بنادیں، پھر ہڈیوں کو ہم نے گوشت پہنا دیا 1 پھر دوسری بناوٹ میں اسے پیدا کردیا 2 برکتوں والا ہے وہ اللہ جو سب سے بہترین پیدا کرنے والا ہے 3۔
  23,15,ثُمَّ اِنَّكُمْ بَعْدَ ذٰلِكَ لَمَیِّتُوْنَؕ ثُمَّ : پھر اِنَّكُمْ : بیشک تم بَعْدَ ذٰلِكَ : اس کے بعد لَمَيِّتُوْنَ : ضرور مرنے والے اس کے بعد پھر تم سب یقیناً مرجانے والے ہو۔
  23,16,ثُمَّ اِنَّكُمْ یَوْمَ الْقِیٰمَةِ تُبْعَثُوْنَ ثُمَّ : پھر اِنَّكُمْ : بیشک تم يَوْمَ الْقِيٰمَةِ : روز قیامت تُبْعَثُوْنَ : اٹھائے جاؤگے پھر قیامت کے دن بلاشبہ تم سب اٹھائے جاؤ گے۔
  23,17,وَ لَقَدْ خَلَقْنَا فَوْقَكُمْ سَبْعَ طَرَآئِقَ١ۖۗ وَ مَا كُنَّا عَنِ الْخَلْقِ غٰفِلِیْنَ وَ : اور لَقَدْ خَلَقْنَا : تحقیق ہم نے بنائے فَوْقَكُمْ : تمہارے اوپر سَبْعَ : ساتھ طَرَآئِقَ : راستے وَمَا كُنَّا : اور ہم نہیں عَنِ : سے الْخَلْقِ : خلق (پیدائش) غٰفِلِيْنَ : غافل ہم نے تمہارے اوپر سات آسمان بنائے ہیں 1 اور ہم مخلوقات میں غافل نہیں ہیں 2۔
