tafsir[17]{c,v,t}:
  52,15,اَفَسِحْرٌ هٰذَاۤ اَمْ اَنْتُمْ لَا تُبْصِرُوْنَۚ اَفَسِحْرٌ ھٰذَآ : کیا بھلا جادو ہے یہ اَمْ اَنْتُمْ : یا تم لَا تُبْصِرُوْنَ : نہیں تم دیکھتے (اب بتاؤ) کیا یہ جادو ہے ؟ (1) یا تم دیکھتے نہیں (2)
  52,16,اِصْلَوْهَا فَاصْبِرُوْۤا اَوْ لَا تَصْبِرُوْا١ۚ سَوَآءٌ عَلَیْكُمْ١ؕ اِنَّمَا تُجْزَوْنَ مَا كُنْتُمْ تَعْمَلُوْنَ اِصْلَوْهَا : جھلسو اس میں فَاصْبِرُوْٓا : پس صبر کرو اَوْ لَا تَصْبِرُوْا ۚ : یا نہ تم صبر کرو سَوَآءٌ عَلَيْكُمْ ۭ : برابر ہے تم پر اِنَّمَا تُجْزَوْنَ : بیشک تم بدلہ دیئے جاتے ہو مَا كُنْتُمْ : جو تھے تم تَعْمَلُوْنَ : تم عمل کرتے جاؤ دوزخ میں اب تمہارا صبر کرنا اور نہ کرنا تمہارے لئے یکساں ہے۔ تمہیں فقط تمہارے کئے کا بدل دیا جائے گا۔
  52,17,اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ نَعِیْمٍۙ اِنَّ الْمُتَّقِيْنَ : یشک متقی لوگ فِيْ جَنّٰتٍ : باغوں میں وَّنَعِيْمٍ : اور نعمتوں میں ہوں گے یقیناً پرہیزگار لوگ جنتوں میں اور نعمتوں میں ہیں (1)
  52,18,فٰكِهِیْنَ بِمَاۤ اٰتٰىهُمْ رَبُّهُمْ١ۚ وَ وَقٰىهُمْ رَبُّهُمْ عَذَابَ الْجَحِیْمِ فٰكِهِيْنَ : خوش ہوں گے بِمَآ اٰتٰىهُمْ رَبُّهُمْ ۚ : بوجہ اس کے جو دے گا ان کو ان کا رب وَوَقٰىهُمْ : اور بچا لے گا ان کو رَبُّهُمْ : ان کا رب عَذَابَ الْجَحِيْمِ : جہنم کے عذاب میں جو انہیں ان کے رب نے دے رکھی ہیں اس پر خوش خوش ہیں (1) اور ان کے پروردگار نے انہیں جہنم کے عذاب سے بچا لیا ہے۔
  52,19,كُلُوْا وَ اشْرَبُوْا هَنِیْٓئًۢا بِمَا كُنْتُمْ تَعْمَلُوْنَۙ كُلُوْا : کھاؤ وَاشْرَبُوْا : اور پیو هَنِيْٓئًۢا : مزے سے بِمَا : بوجہ اس کے جو كُنْتُمْ : تھے تم تَعْمَلُوْنَ : تم عمل کرتے تم مزے سے کھاتے پیتے رہو ان اعمال کے بدلے جو تم کرتے تھے (1)۔
  52,20,مُتَّكِئِیْنَ عَلٰى سُرُرٍ مَّصْفُوْفَةٍ١ۚ وَ زَوَّجْنٰهُمْ بِحُوْرٍ عِیْنٍ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے ہوں گے عَلٰي سُرُرٍ : اوپر تختوں کے مَّصْفُوْفَةٍ ۚ : صف باندھے ہوئے وَزَوَّجْنٰهُمْ : اور بیادہ دیں گے ہم ان کو بِحُوْرٍ عِيْنٍ : ساتھ سفید عورتوں کے، بڑی آنکھوں والی برابر بچھے ہوئے شاندار تختے پر تکیے لگائے ہوئے (1) اور ہم نے ان کے نکاح بڑی بڑی آنکھوں والی (حوروں) سے کرا دیئے ہیں۔
  52,21,وَ الَّذِیْنَ اٰمَنُوْا وَ اتَّبَعَتْهُمْ ذُرِّیَّتُهُمْ بِاِیْمَانٍ اَلْحَقْنَا بِهِمْ ذُرِّیَّتَهُمْ وَ مَاۤ اَلَتْنٰهُمْ مِّنْ عَمَلِهِمْ مِّنْ شَیْءٍ١ؕ كُلُّ امْرِئٍۭ بِمَا كَسَبَ رَهِیْنٌ وَالَّذِيْنَ اٰمَنُوْا : اور وہ لوگ جو ایمان لائے وَاتَّبَعَتْهُمْ : اور پیروی کی ان کی ذُرِّيَّتُهُمْ : ان کی اولاد نے بِاِيْمَانٍ : ایمان کے ساتھ اَلْحَقْنَا بِهِمْ : ہم ملا دیں گے ان کے ساتھ ذُرِّيَّتَهُمْ : ان کی اولاد کو وَمَآ اَلَتْنٰهُمْ : اور نہ کمی کریں گے ہم ان کے مِّنْ عَمَلِهِمْ : ان کے عمل میں سے مِّنْ شَيْءٍ ۭ : کچھ بھی كُلُّ امْرِی : ہر شخص بِمَا كَسَبَ : ساتھ اس کے جو اس نے کمائی کی رَهِيْنٌ : رھن ہے۔ گروی ہے اور جو لوگ ایمان لائے اور ان کی اولاد نے بھی ایمان میں ان کی پیروی کی ہم ان کی اولاد کو ان تک پہنچا دیں گے اور ان کے عمل سے ہم کچھ کم نہ کریں گے (1) ہر شخص اپنے اپنے اعمال کا گروی ہے (2)
  52,22,وَ اَمْدَدْنٰهُمْ بِفَاكِهَةٍ وَّ لَحْمٍ مِّمَّا یَشْتَهُوْنَ وَاَمْدَدْنٰهُمْ : اور مدد دیں گے ہم ان کو۔ زیادہ دیں گے ہم ان کو۔ پے در پے دیں گے ہم ان کو بِفَاكِهَةٍ : پھل وَّلَحْمٍ : اور گوشت مِّمَّا يَشْتَهُوْنَ : اس میں سے جو وہ خواہش کریں گے ہم نے ان کے لئے میوے اور مرغوب گوشت کی ریل پیل کردیں گے (1)
  52,23,یَتَنَازَعُوْنَ فِیْهَا كَاْسًا لَّا لَغْوٌ فِیْهَا وَ لَا تَاْثِیْمٌ يَتَنَازَعُوْنَ : ایک دوسرے سے چھینیں گے فِيْهَا : اس میں كَاْسًا : جام میں۔ پیالوں میں لَّا لَغْوٌ فِيْهَا : نہ کوئی بےہودہ گوئی ہوگی اس میں وَلَا تَاْثِيْمٌ : اور نہ کوئی گناہ (خوش طبعی کے ساتھ) ایک دوسرے سے جام (شراب) چھینا جھپٹی کریں گے (1) جس شراب کے سرور میں تو بیہودہ گوئی ہوگی نہ گناہ (2)
  52,24,وَ یَطُوْفُ عَلَیْهِمْ غِلْمَانٌ لَّهُمْ كَاَنَّهُمْ لُؤْلُؤٌ مَّكْنُوْنٌ وَيَطُوْفُ : اور گھوم رہے ہوں گے عَلَيْهِمْ : ان پر غِلْمَانٌ لَّهُمْ : نو عمر خادم ان کے لیے كَاَنَّهُمْ لُؤْلُؤٌ : گویا کہ وہ موتی ہیں مَّكْنُوْنٌ : چھپے ہوئے۔ چھپا کر رکھے ہوئے اور ان کے ارد گرد ان کے نو عمر غلام پھر رہے ہونگے، گویا موتی تھے جو ڈھکے رکھے تھے (1)
  52,25,وَ اَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ وَاَقْبَلَ : اور متوجہ ہوں گے بَعْضُهُمْ : ان میں سے بعض عَلٰي بَعْضٍ : بعض پر يَّتَسَآءَلُوْنَ : ایک دوسرے سے سوال کریں گے اور آپس میں ایک دوسرے کی طرف متوجہ ہو کر سوال کریں گے (1)
  52,26,قَالُوْۤا اِنَّا كُنَّا قَبْلُ فِیْۤ اَهْلِنَا مُشْفِقِیْنَ قَالُوْٓا اِنَّا : کہیں گے بیشک ہم كُنَّا : تھے ہم قَبْلُ : اس سے پہلے فِيْٓ اَهْلِنَا : اپنے گھر والوں میں مُشْفِقِيْنَ : ڈرنے والے کہیں گے کہ اس سے پہلے ہم اپنے گھر والوں کے درمیان بہت ڈرا کرتے تھے (1)
  52,27,فَمَنَّ اللّٰهُ عَلَیْنَا وَ وَقٰىنَا عَذَابَ السَّمُوْمِ فَمَنَّ اللّٰهُ : پس احسان کیا اللہ نے عَلَيْنَا : ہم پر وَوَقٰىنَا : اور بچا لیا ہم کو عَذَابَ السَّمُوْمِ : لُو کے عذاب سے پس اللہ تعالیٰ نے ہم پر بڑا احسان کیا اور ہمیں تیز و تند گرم ہواؤں کے عذاب سے بچا لیا (1)
  52,28,اِنَّا كُنَّا مِنْ قَبْلُ نَدْعُوْهُ١ؕ اِنَّهٗ هُوَ الْبَرُّ الرَّحِیْمُ۠    ۧ اِنَّا : بیشک ہم كُنَّا : تھے ہم مِنْ قَبْلُ : اس سے پہلے نَدْعُوْهُ ۭ : اس سے دعا کرتے۔ اسی کو پکارا کرتے اِنَّهٗ : بیشک وہ هُوَ الْبَرُّ : وہی محسن ہے الرَّحِيْمُ : رحم فرمانے والا ہے ہم اس سے پہلے ہی اس کی عبادت کیا کرتے تھے بیشک وہ محسن اور مہربان ہے۔ (1)
  52,29,فَذَكِّرْ فَمَاۤ اَنْتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَّ لَا مَجْنُوْنٍؕ فَذَكِّرْ : پس نصیحت کیجیے فَمَآ اَنْتَ : پس نہیں آپ بِنِعْمَتِ : نعمت سے رَبِّكَ : اپنے رب کی بِكَاهِنٍ : کا ھن وَّلَا مَجْنُوْنٍ : اور نہ مجنون تو آپ سمجھاتے رہیں کیونکہ آپ اپنے رب کے فضل سے نہ تو کاہن ہیں نہ دیوانہ (1)
  52,30,اَمْ یَقُوْلُوْنَ شَاعِرٌ نَّتَرَبَّصُ بِهٖ رَیْبَ الْمَنُوْنِ اَمْ يَقُوْلُوْنَ : یا وہ کہتے ہیں شَاعِرٌ : ایک شاعر ہے نَّتَرَبَّصُ : ہم انتظار کر رہے ہیں بِهٖ : اس کے بارے میں رَيْبَ : حوادث کا الْمَنُوْنِ : موت کے۔ زمانے کے کیا کافر یوں کہتے ہیں کہ یہ شاعر ہے ہم اس پر زمانے کے حوادث (یعنی موت) کا انتظار کر رہے ہیں (1)۔
  52,31,قُلْ تَرَبَّصُوْا فَاِنِّیْ مَعَكُمْ مِّنَ الْمُتَرَبِّصِیْنَؕ قُلْ : کہہ دیجیے تَرَبَّصُوْا : انتظار کرو فَاِنِّىْ : پس بیشک میں مَعَكُمْ : تمہارے ساتھ مِّنَ الْمُتَرَبِّصِيْنَ : انتظار کرنے والوں میں سے ہوں کہہ دیجئے ! تم منتظر رہو میں بھی تمہارے ساتھ انتظار کرنے والوں میں ہوں (1)
