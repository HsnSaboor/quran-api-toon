tafsir[24]{c,v,t}:
  55,17,رَبُّ الْمَشْرِقَیْنِ وَ رَبُّ الْمَغْرِبَیْنِۚ رَبُّ الْمَشْرِقَيْنِ : رب ہے دو مشرقوں کا وَرَبُّ الْمَغْرِبَيْنِ : اور رب ہے دو مغربوں کا وہ رب ہے دونوں مشرقوں کا اور دونوں مغربوں کا (1)
  55,18,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس (اے انسانو اور جنو !) تم اپنے پروردگار کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,19,مَرَجَ الْبَحْرَیْنِ یَلْتَقِیٰنِۙ مَرَجَ الْبَحْرَيْنِ : اس نے چھوڑ دیا دو سمندروں کو يَلْتَقِيٰنِ : کہ دونوں باہم مل جائیں اس نے دو دریا جاری کردیئے جو ایک دوسرے سے مل جاتے ہیں۔
  55,20,بَیْنَهُمَا بَرْزَخٌ لَّا یَبْغِیٰنِۚ بَيْنَهُمَا بَرْزَخٌ : ان دونوں کے درمیان ایک پردہ ہے لَّا يَبْغِيٰنِ : نہیں وہ تجاوز کرتے۔ آگے بڑھتے ان دونوں میں سے ایک آڑ ہے کہ اس سے بڑھ نہیں سکتے (1)
  55,21,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
  55,22,یَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجَانُۚ يَخْرُجُ مِنْهُمَا : نکلتے ہیں ان دونوں سے اللُّؤْلُؤُ : موتی وَالْمَرْجَانُ : اور مونگے ان دونوں میں سے موتی اور مونگے برآمد ہوتے ہیں (1)
  55,23,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
  55,24,وَ لَهُ الْجَوَارِ الْمُنْشَئٰتُ فِی الْبَحْرِ كَالْاَعْلَامِۚ وَلَهُ الْجَوَارِ : اور اسی کے لیے ہیں جہاز الْمُنْشَئٰتُ : اونچے اٹھے ہوئے فِي الْبَحْرِ : سمندر میں كَالْاَعْلَامِ : اونچے پہاڑوں کی طرح اور اللہ ہی کی (ملکیت میں) ہیں جہاز جو سمندروں میں پہاڑ کی طرح بلند (چل پھر رہے) ہیں (1)
  55,25,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ۠    ۧ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
  55,26,كُلُّ مَنْ عَلَیْهَا فَانٍۚۖ كُلُّ مَنْ عَلَيْهَا : سب کے سب جو اس پر ہیں فَانٍ : فنا ہونے والے ہیں زمین پر جو ہیں سب فنا ہونے والے ہیں۔
  55,27,وَّ یَبْقٰى وَجْهُ رَبِّكَ ذُو الْجَلٰلِ وَ الْاِكْرَامِۚ وَّيَبْقٰى : اور باقی رہے گی وَجْهُ رَبِّكَ : تیرے رب کی ذات ذُو الْجَلٰلِ : بزرگی والی وَالْاِكْرَامِ : اور کرم والی صرف تیرے رب کی ذات جو عظمت اور عزت والی ہے باقی رہ جائے گی۔
  55,28,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
  55,29,یَسْئَلُهٗ مَنْ فِی السَّمٰوٰتِ وَ الْاَرْضِ١ؕ كُلَّ یَوْمٍ هُوَ فِیْ شَاْنٍۚ يَسْئَلُهٗ : مانگتے ہیں اس سے مَنْ : جو بھی فِي السَّمٰوٰتِ : آسمانوں میں ہیں وَالْاَرْضِ ۭ : اور زمین میں كُلَّ يَوْمٍ : ہر روز هُوَ فِيْ شَاْنٍ : وہ نئی شان میں ہے سب آسمان و زمین والے اسی سے مانگتے ہیں (1) ہر روز وہ ایک شان میں ہے (2)۔
  55,30,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے پروردگار کی کون کون سی نعمت کو جھٹلاؤ گے۔
  55,31,سَنَفْرُغُ لَكُمْ اَیُّهَ الثَّقَلٰنِۚ سَنَفْرُغُ لَكُمْ : عنقریب ہم فارغ ہوجائیں گے تمہارے لیے اَيُّهَا الثَّقَلٰنِ : اے دو بوجھو (جنوں اور انسانوں کے گروہو !) عنقریب ہم تمہاری طرف پوری طرح متوجہ ہوجائیں گے (1)
  55,32,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
  55,33,یٰمَعْشَرَ الْجِنِّ وَ الْاِنْسِ اِنِ اسْتَطَعْتُمْ اَنْ تَنْفُذُوْا مِنْ اَقْطَارِ السَّمٰوٰتِ وَ الْاَرْضِ فَانْفُذُوْا١ؕ لَا تَنْفُذُوْنَ اِلَّا بِسُلْطٰنٍۚ يٰمَعْشَرَ الْجِنِّ وَالْاِنْسِ : اے گروہ جن و انس اِنِ اسْتَطَعْتُمْ : اگر تم استطاعت رکھتے ہو اَنْ تَنْفُذُوْا : کہ تم نکل بھاگو مِنْ اَقْطَارِ : کناروں سے السَّمٰوٰتِ : آسمانوں کے وَالْاَرْضِ : اور زمین کے فَانْفُذُوْا ۭ : تو بھاگ نکلو لَا تَنْفُذُوْنَ : نہیں تم بھاگ سکتے اِلَّا بِسُلْطٰنٍ : مگر ساتھ ایک زور کے اے گروہ جنات و انسان ! اگر تم میں آسمانوں اور زمین میں کے کناروں سے باہر نکل جانے کی طاقت ہے تو نکل بھاگو ! (1) بغیر غلبہ اور طاقت کے تم نہیں نکل سکتے۔ (2)
  55,34,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
  55,35,یُرْسَلُ عَلَیْكُمَا شُوَاظٌ مِّنْ نَّارٍ١ۙ۬ وَّ نُحَاسٌ فَلَا تَنْتَصِرٰنِۚ يُرْسَلُ عَلَيْكُمَا : چھوڑ دیا جائے گا تم پر شُوَاظٌ : شعلہ مِّنْ نَّارٍ : آگ میں سے وَّنُحَاسٌ : اور دھواں فَلَا تَنْتَصِرٰنِ : تو نہ تم دونوں مقابلہ کرسکو گے تم پر آگ کے شعلے اور دھواں چھوڑا جائے گا (1) پھر تم مقابلہ نہ کرسکو گے۔ (2)
  55,36,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
  55,37,فَاِذَا انْشَقَّتِ السَّمَآءُ فَكَانَتْ وَرْدَةً كَالدِّهَانِۚ فَاِذَا انْشَقَّتِ السَّمَآءُ : تو جب پھٹ جائے گا آسمان فَكَانَتْ : تو ہوجائے گا وَرْدَةً : سرخ كَالدِّهَانِ : سرخ چمڑے کی طرح۔ تیل کی تلچھٹ کی طرح پس جب کہ آسمان پھٹ کر سرخ ہوجائے جیسے کہ سرخ چمڑہ (1)
  55,38,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
  55,39,فَیَوْمَئِذٍ لَّا یُسْئَلُ عَنْ ذَنْۢبِهٖۤ اِنْسٌ وَّ لَا جَآنٌّۚ فَيَوْمَئِذٍ : تو اس دن لَّا يُسْئَلُ : نہ پوچھا جائے گا عَنْ ذَنْۢبِهٖٓ : اپنے گناہوں کے بارے میں اِنْسٌ وَّلَا جَآنٌّ : کوئی انسان اور نہ کوئی جن اس دن کسی انسان اور کسی جن سے اس کے گناہوں کی پرسش نہ کی جائے گی (1)
  55,40,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پھر اپنے رب کی کون کون سی نعمت کو جھٹلاؤ گے ؟
