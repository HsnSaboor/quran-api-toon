tafsir[17]{c,v,t}:
  103,1,وَ الْعَصْرِۙ وَالْعَصْرِ : قسم زمانہ کی زمانے کی قسم (1)
  103,2,اِنَّ الْاِنْسَانَ لَفِیْ خُسْرٍۙ اِنَّ : بیشک الْاِنْسَانَ : انسان لَفِيْ خُسْرٍ : خسارہ میں بیشک (بالیقین) انسان سراسر نقصان میں ہے (1)
  103,3,اِلَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ وَ تَوَاصَوْا بِالْحَقِّ١ۙ۬ وَ تَوَاصَوْا بِالصَّبْرِ۠    ۧ اِلَّا : سوائے الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا الصّٰلِحٰتِ : اور انہوں نے عمل کئے نیک وَتَوَاصَوْا بالْحَقِّ : اور ایک دوسرے کو وصیت کی حق کی وَتَوَاصَوْا : اور وصیت کی بِالصَّبْرِ : صبر کی سوائے ان لوگوں کے جو ایمان لائے (1) اور نیک عمل کئے اور (جنہوں نے) آپس میں حق کی وصیت کی اور ایک دوسرے کو صبر کی نصیحت کی۔ (2)
  104,1,وَیْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةِۙ وَيْلٌ : خرابی لِّكُلِّ : واسطے، ہر هُمَزَةٍ : طعنہ زن لُّمَزَةِۨ : عیب جو بڑی خرابی ہے ہر ایسے شخص کی جو عیب ٹٹولنے والا غیبت کرنے والا ہو۔
  104,2,اِ۟لَّذِیْ جَمَعَ مَالًا وَّ عَدَّدَهٗۙ الَّذِيْ : جس جَمَعَ : جمع کیا مَالًا : مال وَّعَدَّدَهٗ : اسے گن گن کر رکھا جو مال کو جمع کرتا جائے اور گنتا جائے۔ (1)
  104,3,یَحْسَبُ اَنَّ مَالَهٗۤ اَخْلَدَهٗۚ يَحْسَبُ : وہ گمان کرتا ہے اَنَّ : کہ مَالَهٗٓ : اس کا مال اَخْلَدَهٗ : اسے ہمیشہ رکھے گا وہ سمجھتا ہے کہ اس کا مال اس کے پاس سدا رہے گا۔
  104,4,كَلَّا لَیُنْۢبَذَنَّ فِی الْحُطَمَةِ٘ۖ كَلَّا : ہرگز نہیں لَيُنْۢبَذَنَّ : ضرور ڈالا جائے گا فِي : میں الْحُطَمَةِ : حطمہ ہرگز (1) یہ تو ضرور توڑ پھوڑ دینے والی آگ میں پھینک دیا جائے گا (2)
  104,5,وَ مَاۤ اَدْرٰىكَ مَا الْحُطَمَةُؕ وَمَآ اَدْرٰىكَ : اور کیا تم سمجھے مَا الْحُطَمَةُ : حطمہ کیا ہے اور تجھے کیا معلوم کہ ایسی آگ کیا ہوگی۔ (1)
  104,6,نَارُ اللّٰهِ الْمُوْقَدَةُۙ نَارُ اللّٰهِ : اللہ کی آگ الْمُوْقَدَةُ : بھڑکائی ہوئی وہ اللہ تعالیٰ کی سلگائی ہوئی آگ ہوگی۔
  104,7,الَّتِیْ تَطَّلِعُ عَلَى الْاَفْئِدَةِؕ الَّتِيْ : جو کہ تَطَّلِعُ : جا پہنچے عَلَي : پر الْاَفْئِدَةِ : دلوں جو دلوں پر چڑھتے چلی جائے گی۔ (1)
  104,8,اِنَّهَا عَلَیْهِمْ مُّؤْصَدَةٌۙ اِنَّهَا عَلَيْهِمْ : بیشک وہ ان پر مُّؤْصَدَةٌ : بند کی ہوئی اور ان پر بڑے بڑے ستونوں میں۔
  104,9,فِیْ عَمَدٍ مُّمَدَّدَةٍ۠    ۧ فِيْ عَمَدٍ : ستونوں میں مُّمَدَّدَةٍ : لمبے لمبے ہر طرف سے بند ہوئی ہوگی۔ (1)
  105,1,اَلَمْ تَرَ كَیْفَ فَعَلَ رَبُّكَ بِاَصْحٰبِ الْفِیْلِؕ اَلَمْ تَرَ : کیا تم نے نہیں دیکھا كَيْفَ فَعَلَ : کیسا کیا رَبُّكَ : تمہارا رب بِاَصْحٰبِ : والوں کے ساتھ الْفِيْلِ : ہاتھی کیا تو نے نہیں دیکھا کہ تیرے رب نے ہاتھی والوں کے ساتھ کیا کیا ؟ (1)
  105,2,اَلَمْ یَجْعَلْ كَیْدَهُمْ فِیْ تَضْلِیْلٍۙ اَلَمْ : کیا نہیں يَجْعَلْ : کردیا كَيْدَهُمْ : ان کا داؤ فِيْ تَضْلِيْلٍ : گمراہی میں (بیکار) کیا ان کے مکر کو بےکار نہیں کردیا (1)
  105,3,وَّ اَرْسَلَ عَلَیْهِمْ طَیْرًا اَبَابِیْلَۙ وَّاَرْسَلَ : اور بھیجے عَلَيْهِمْ : ان پر طَيْرًا : پرندے اَبَابِيْلَ : جھنڈ کے جھنڈ اور ان پر پرندوں کے جھنڈ پر جھنڈ بھیج دیئے۔ (1)
  105,4,تَرْمِیْهِمْ بِحِجَارَةٍ مِّنْ سِجِّیْلٍ۪ۙ تَرْمِيْهِمْ : پھینکتے تھے بِحِجَارَةٍ : کنکریاں مِّنْ : سے سِجِّيْلٍ : سنگ گل جو ان کو مٹی اور پتھر کی کنکریاں مار رہے تھے۔ (1)
  105,5,فَجَعَلَهُمْ كَعَصْفٍ مَّاْكُوْلٍ۠    ۧ فَجَعَلَهُمْ : پس ان کو کردیا كَعَصْفٍ : بھوسہ کی طرح مَّاْكُوْلٍ : کھائے ہوئے پس انہیں کھائے ہوئے بھوسے کی طرح کردیا۔ (1)
