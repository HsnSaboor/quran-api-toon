quran[54]{c,v,t}:
34,1,اَلْحَمْدُ لِلّٰهِ الَّذِیْ لَهٗ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ وَ لَهُ الْحَمْدُ فِی الْاٰخِرَةِ١ؕ وَ هُوَ الْحَكِیْمُ الْخَبِیْرُ اَلْحَمْدُ : تمام تعریفیں لِلّٰهِ : اللہ کے لیے الَّذِيْ لَهٗ : وہ جس کے لیے مَا : جو فِي السَّمٰوٰتِ : آسمانوں میں وَمَا : اور جو فِي الْاَرْضِ : زمین میں وَلَهُ : اور اسی کے لیے الْحَمْدُ : ہر تعریف فِي الْاٰخِرَةِ ۭ : آخرت میں وَهُوَ : اور وہ الْحَكِيْمُ : حکمت والا الْخَبِيْرُ : خبر رکھنے والا تمام تعریفیں اس اللہ کے لئے سزاوار ہیں جس کی ملکیت میں وہ سب کچھ ہے جو آسمان اور زمین میں ہے (1) آخرت میں بھی تعریف اسی کے لئے ہے (2) وہ (بڑی) حکمتوں والا اور پورا خبردار ہے
34,2,یَعْلَمُ مَا یَلِجُ فِی الْاَرْضِ وَ مَا یَخْرُجُ مِنْهَا وَ مَا یَنْزِلُ مِنَ السَّمَآءِ وَ مَا یَعْرُجُ فِیْهَا١ؕ وَ هُوَ الرَّحِیْمُ الْغَفُوْرُ يَعْلَمُ : وہ جانتا ہے مَا يَلِجُ : جو داخل ہوتا ہے فِي الْاَرْضِ : زمین میں وَمَا : اور جو يَخْرُجُ : نکلتا ہے مِنْهَا : اس سے وَمَا : اور جو يَنْزِلُ : نازل ہوتا ہے مِنَ السَّمَآءِ : آسمان سے وَمَا : اور جو يَعْرُجُ : چڑھتا ہے فِيْهَا ۭ : اس میں وَهُوَ : اور وہ الرَّحِيْمُ : مہربان الْغَفُوْرُ : بخشنے والا جو زمین میں جائے (1) اور جو اس سے نکلے جو آسمان سے اترے (2) اور جو چڑھ کر اس میں جائے (3) وہ سب سے باخبر ہے اور مہربان نہایت بخشش والا۔
34,3,وَ قَالَ الَّذِیْنَ كَفَرُوْا لَا تَاْتِیْنَا السَّاعَةُ١ؕ قُلْ بَلٰى وَ رَبِّیْ لَتَاْتِیَنَّكُمْ١ۙ عٰلِمِ الْغَیْبِ١ۚ لَا یَعْزُبُ عَنْهُ مِثْقَالُ ذَرَّةٍ فِی السَّمٰوٰتِ وَ لَا فِی الْاَرْضِ وَ لَاۤ اَصْغَرُ مِنْ ذٰلِكَ وَ لَاۤ اَكْبَرُ اِلَّا فِیْ كِتٰبٍ مُّبِیْنٍۗۙ وَقَالَ : اور کہا (کہتے ہیں) الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) لَا تَاْتِيْنَا : ہم پر نہیں آئے گی السَّاعَةُ ۭ : قیامت قُلْ : فرما دیں بَلٰى : ہاں وَرَبِّيْ : قسم میرے رب کی لَتَاْتِيَنَّكُمْ ۙ : البتہ تم پر ضرور آئے گی عٰلِمِ : جاننے والا الْغَيْبِ ۚ : غیب لَا يَعْزُبُ : پوشیدہ نہیں عَنْهُ : اس سے مِثْقَالُ ذَرَّةٍ : ایک ذرہ کے برابر فِي السَّمٰوٰتِ : آسمانوں میں وَلَا : اور نہ فِي الْاَرْضِ : زمین میں وَلَآ : اور نہ اَصْغَرُ : چھوٹا مِنْ ذٰلِكَ : اس سے وَلَآ : اور نہ اَكْبَرُ : بڑا اِلَّا : مگر فِيْ : میں كِتٰبٍ مُّبِيْنٍ : روشن کتاب کفار کہتے ہیں ہم پر قیامت نہیں آئے گی۔ آپ کہہ دیجئے ! مجھے میرے رب کی قسم ! جو عالم الغیب ہے وہ یقیناً تم پر آئے گی (1) اللہ تعالیٰ سے ایک ذرے کے برابر کی چیز بھی پوشیدہ نہیں (2) نہ آسمانوں میں نہ زمین میں بلکہ اس سے بھی چھوٹی اور بڑی ہر چیز کھلی کتاب میں موجود ہے (3)۔
34,4,لِّیَجْزِیَ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ١ؕ اُولٰٓئِكَ لَهُمْ مَّغْفِرَةٌ وَّ رِزْقٌ كَرِیْمٌ لِّيَجْزِيَ : تاکہ جزا دے الَّذِيْنَ اٰمَنُوْا : ان لوگوں کو جو ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ ۭ : نیک اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے مَّغْفِرَةٌ : بخشش وَّرِزْقٌ كَرِيْمٌ : اور عزت کی روزی تاکہ وہ ایمان والوں اور نیکوں کاروں کو بھلا بدلہ عطا فرمائے یہی لوگ ہیں جن کے لئے مغفرت اور عزت کی روزی ہے۔
34,5,وَ الَّذِیْنَ سَعَوْ فِیْۤ اٰیٰتِنَا مُعٰجِزِیْنَ اُولٰٓئِكَ لَهُمْ عَذَابٌ مِّنْ رِّجْزٍ اَلِیْمٌ وَالَّذِيْنَ : اور وہ لوگ جو سَعَوْ : انہوں نے کوشش کی فِيْٓ اٰيٰتِنَا : ہماری آیتوں میں مُعٰجِزِيْنَ : ہرانے کے لیے اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے عَذَابٌ : عذاب مِّنْ : سے رِّجْزٍ اَلِيْمٌ : سخت دردناک اور ہماری آیاتوں کو نیچا دکھانے کی جنہوں نے کوشش کی ہے (1) یہ وہ لوگ ہیں جن کے لئے بدترین قسم کا دردناک عذاب ہے۔
34,6,وَ یَرَى الَّذِیْنَ اُوْتُوا الْعِلْمَ الَّذِیْۤ اُنْزِلَ اِلَیْكَ مِنْ رَّبِّكَ هُوَ الْحَقَّ١ۙ وَ یَهْدِیْۤ اِلٰى صِرَاطِ الْعَزِیْزِ الْحَمِیْدِ وَيَرَى : اور وہ دیکھتے ہیں الَّذِيْنَ : وہ لوگ جنہیں اُوْتُوا : دیا گیا الْعِلْمَ : علم الَّذِيْٓ : وہ جو کہ اُنْزِلَ : نازل کیا گیا اِلَيْكَ : تمہاری طرف مِنْ رَّبِّكَ : تمہارے رب کی طرف سے هُوَ الْحَقَّ ۙ : وہ حق وَيَهْدِيْٓ : اور وہ رہنمائی کرتا ہے اِلٰى : طرف صِرَاطِ : راستہ الْعَزِيْزِ : غالب الْحَمِيْدِ : سزاوار تعریف اور جنہیں علم ہے وہ دیکھ لیں گے کہ جو آپ کی جانب آپ کے رب کی طرف سے نازل ہوا ہے وہ (سراسر) حق (1) ہے اور اللہ غالب خوبیوں والے کی راہ کی راہبری کرتا ہے۔ (2)
34,7,وَ قَالَ الَّذِیْنَ كَفَرُوْا هَلْ نَدُلُّكُمْ عَلٰى رَجُلٍ یُّنَبِّئُكُمْ اِذَا مُزِّقْتُمْ كُلَّ مُمَزَّقٍ١ۙ اِنَّكُمْ لَفِیْ خَلْقٍ جَدِیْدٍۚ وَقَالَ : اور کہا (کہتے ہیں الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) هَلْ : کیا نَدُلُّكُمْ : ہم بتلائیں تمہیں عَلٰي : پر۔ کا رَجُلٍ : ایسا آدمی يُّنَبِّئُكُمْ : وہ خبر دیتا ہے تمہیں اِذَا : جب مُزِّقْتُمْ : تم ریزہ ریزہ ہوجاؤ گے كُلَّ مُمَزَّقٍ ۙ : پوری طرح ریزہ ریزہ اِنَّكُمْ : بیشک تم لَفِيْ : البتہ میں خَلْقٍ جَدِيْدٍ : زندگی نئی اور کافروں نے کہا (1) (آؤ) ہم تمہیں ایک ایسا شخص بتلائیں (2) جو تمہیں یہ خبر پہنچا رہا ہے (3) کہ جب تم بالکل ہی ریزہ ریزہ ہوجاؤ گے تو پھر سے ایک نئی پیدائش میں آؤ گے۔
34,8,اَفْتَرٰى عَلَى اللّٰهِ كَذِبًا اَمْ بِهٖ جِنَّةٌ١ؕ بَلِ الَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ فِی الْعَذَابِ وَ الضَّلٰلِ الْبَعِیْدِ اَفْتَرٰى : اس نے باندھا عَلَي اللّٰهِ : اللہ پر كَذِبًا : جھوٹ اَمْ : یا بِهٖ : اسے جِنَّةٌ ۭ : جنون بَلِ : بلکہ الَّذِيْنَ : وہ لوگ جو لَا يُؤْمِنُوْنَ : ایمان نہیں رکھتے بِالْاٰخِرَةِ : آخرت پر فِي الْعَذَابِ : عذاب میں وَالضَّلٰلِ : اور گمراہی الْبَعِيْدِ : دور (ہم نہیں کہہ سکتے) کہ خود اس نے (ہی) اللہ پر جھوٹ باندھ لیا ہے یا اسے دیوانگی ہے (1) بلکہ (حقیقت یہ ہے) کہ آخرت پر یقین نہ رکھنے والے ہی عذاب میں اور دور کی گمراہی میں ہیں۔ (2)
34,9,اَفَلَمْ یَرَوْا اِلٰى مَا بَیْنَ اَیْدِیْهِمْ وَ مَا خَلْفَهُمْ مِّنَ السَّمَآءِ وَ الْاَرْضِ١ؕ اِنْ نَّشَاْ نَخْسِفْ بِهِمُ الْاَرْضَ اَوْ نُسْقِطْ عَلَیْهِمْ كِسَفًا مِّنَ السَّمَآءِ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیَةً لِّكُلِّ عَبْدٍ مُّنِیْبٍ۠    ۧ اَفَلَمْ يَرَوْا : کیا انہوں نے نہیں دیکھا اِلٰى : طرف مَا : جو بَيْنَ اَيْدِيْهِمْ : ان کے آگے وَمَا : اور جو خَلْفَهُمْ : ان کے پیچھے مِّنَ السَّمَآءِ : آسمان سے وَالْاَرْضِ ۭ : اور زمین اِنْ نَّشَاْ : اگر ہم چاہیں نَخْسِفْ بِهِمُ : انہیں دھنسا دیں ہم الْاَرْضَ : زمین اَوْ نُسْقِطْ : یا گرا دیں عَلَيْهِمْ : ان پر كِسَفًا : ٹکڑا مِّنَ السَّمَآءِ ۭ : آسمان سے اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيَةً : البتہ نشانی لِّكُلِّ : لیے۔ ہر عَبْدٍ : بندہ مُّنِيْبٍ : رجوع کرنے والا کیا پس وہ اپنے آگے پیچھے آسمان و زمین کو دیکھ نہیں رہے ہیں ؟ (1) اگر ہم چاہیں تو انھیں زمین میں دھنسا دیں یا ان پر آسمان کے ٹکڑے گرا دیں (2) یقیناً اس میں پوری دلیل ہے ہر اس بندے کے لئے جو (دل سے) متوجہ ہو۔
34,10,وَ لَقَدْ اٰتَیْنَا دَاوٗدَ مِنَّا فَضْلًا١ؕ یٰجِبَالُ اَوِّبِیْ مَعَهٗ وَ الطَّیْرَ١ۚ وَ اَلَنَّا لَهُ الْحَدِیْدَۙ وَلَقَدْ اٰتَيْنَا : اور تحقیق ہم نے دیا دَاوٗدَ : داؤد مِنَّا : اپنی طرف سے فَضْلًا ۭ : فضل يٰجِبَالُ : اے پہاڑو اَوِّبِيْ : تسبیح کرو مَعَهٗ : اس کے ساتھ وَالطَّيْرَ ۚ : اور پرندو وَاَلَنَّا : اور ہم نے نرم کردیا لَهُ : اس کے لیے الْحَدِيْدَ : لوہا اور ہم نے داؤد پر اپنا فضل کیا (1) اے پہاڑو ! اس کے ساتھ رغبت سے تسبیح پڑھا کرو اور پرندوں کو بھی (2) (یہی حکم ہے) اور ہم نے اسی لئے لوہا نرم کردیا (3)
34,11,اَنِ اعْمَلْ سٰبِغٰتٍ وَّ قَدِّرْ فِی السَّرْدِ وَ اعْمَلُوْا صَالِحًا١ؕ اِنِّیْ بِمَا تَعْمَلُوْنَ بَصِیْرٌ اَنِ : کہ اعْمَلْ : بناؤ سٰبِغٰتٍ : کشادہ زرہیں وَّقَدِّرْ : اور اندازہ رکھو فِي السَّرْدِ : (کڑیوں کے) جوڑنے میں وَاعْمَلُوْا : اور عمل کرو صَالِحًا ۭ : اچھے اِنِّىْ : بیشک بِمَا تَعْمَلُوْنَ : تم جو کچھ کرتے ہو اس کو بَصِيْرٌ : دیکھ رہا ہوں کہ تو پوری پوری زرہیں بنا (1) اور جوڑوں میں اندازہ رکھ تم سب نیک کام کرو (2) یقین مانو کہ میں تمہارے اعمال دیکھ رہا ہوں۔
34,12,وَ لِسُلَیْمٰنَ الرِّیْحَ غُدُوُّهَا شَهْرٌ وَّ رَوَاحُهَا شَهْرٌ١ۚ وَ اَسَلْنَا لَهٗ عَیْنَ الْقِطْرِ١ؕ وَ مِنَ الْجِنِّ مَنْ یَّعْمَلُ بَیْنَ یَدَیْهِ بِاِذْنِ رَبِّهٖ١ؕ وَ مَنْ یَّزِغْ مِنْهُمْ عَنْ اَمْرِنَا نُذِقْهُ مِنْ عَذَابِ السَّعِیْرِ وَلِسُلَيْمٰنَ : اور سلیمان کے لیے الرِّيْحَ : ہوا غُدُوُّهَا : اس کی صبح کی منزل شَهْرٌ : ایک ماہ وَّ رَوَاحُهَا : اور شام کی منزل شَهْرٌ ۚ : ایک ماہ وَاَسَلْنَا لَهٗ : اور ہم نے بہایا اس کے لیے عَيْنَ الْقِطْرِ ۭ : تانبے کا چشمہ وَمِنَ : اور سے الْجِنِّ : جن مَنْ يَّعْمَلُ : وہ کام کرتے بَيْنَ يَدَيْهِ : اس کے سامنے بِاِذْنِ : اذن (حکم) سے رَبِّهٖ ۭ : اس کے رب کے وَمَنْ : اور جو يَّزِغْ : کجی کرے گا مِنْهُمْ : ان میں سے عَنْ اَمْرِنَا : ہمارے حکم سے نُذِقْهُ : ہم اس کو چکھائیں گے مِنْ : سے۔ کا عَذَابِ : عذاب السَّعِيْرِ : آگ (دوزخ) اور ہم نے سلیمان کے کے لئے ہوا کو مسخر کردیا کہ صبح کی منزل اس کی مہینہ بھر کی ہوتی تھی اور شام کی منزل بھی (1) اور ہم نے ان کے لئے تانبے کا چشمہ بہا دیا (2) اور اس کے رب کے حکم سے بعض جنات اس کی ماتحتی میں اس کے سامنے کام کرتے تھے اور ان میں سے جو بھی ہمارے حکم سے سرتابی کرے ہم اسے بھڑکتی ہوئی آگ کا مزہ چکھائیں گے۔
34,13,یَعْمَلُوْنَ لَهٗ مَا یَشَآءُ مِنْ مَّحَارِیْبَ وَ تَمَاثِیْلَ وَ جِفَانٍ كَالْجَوَابِ وَ قُدُوْرٍ رّٰسِیٰتٍ١ؕ اِعْمَلُوْۤا اٰلَ دَاوٗدَ شُكْرًا١ؕ وَ قَلِیْلٌ مِّنْ عِبَادِیَ الشَّكُوْرُ يَعْمَلُوْنَ : وہ بناتے لَهٗ : اس کے لیے مَا يَشَآءُ : جو وہ چاہتے مِنْ : سے مَّحَارِيْبَ : بڑی عمارتیں (قلعے) وَتَمَاثِيْلَ : اور تصویریں وَجِفَانٍ : اور لگن كَالْجَوَابِ : حوض جیسے وَقُدُوْرٍ : اور دیگیں رّٰسِيٰتٍ ۭ : ایک جگہ جمی ہوئی اِعْمَلُوْٓا : تم عمل کرو اٰلَ دَاوٗدَ : اے خاندان داؤد شُكْرًا ۭ : شکر بجا لاکر وَقَلِيْلٌ : اور تھوڑے مِّنْ : سے عِبَادِيَ : میرے بندے الشَّكُوْرُ : شکر گزار جو کچھ سلیمان چاہتے وہ جنات تیار کردیتے مثلا قلعے اور اور مجسمے اور حوضوں کے برابر لگن اور چولہوں پر جمی ہوئی مضبوط دیگیں (2) اے داؤد اس کے شکریہ میں نیک عمل کرو، میرے بندوں میں سے شکر گزار بندے کم ہی ہوتے ہیں۔
34,14,فَلَمَّا قَضَیْنَا عَلَیْهِ الْمَوْتَ مَا دَلَّهُمْ عَلٰى مَوْتِهٖۤ اِلَّا دَآبَّةُ الْاَرْضِ تَاْكُلُ مِنْسَاَتَهٗ١ۚ فَلَمَّا خَرَّ تَبَیَّنَتِ الْجِنُّ اَنْ لَّوْ كَانُوْا یَعْلَمُوْنَ الْغَیْبَ مَا لَبِثُوْا فِی الْعَذَابِ الْمُهِیْنِؕ فَلَمَّا : پھر جب ہم نے قَضَيْنَا : حکم جاری کیا عَلَيْهِ : اس پر الْمَوْتَ : موت مَا دَلَّهُمْ : انہیں پتہ نہ دیا عَلٰي مَوْتِهٖٓ : اس کی موت کا اِلَّا : مگر دَآبَّةُ الْاَرْضِ : گھن کا کیڑا تَاْكُلُ : وہ کھاتا تھا مِنْسَاَتَهٗ ۚ : اس کا عصا فَلَمَّا : پھر جب خَرَّ : وہ گرپڑا تَبَيَّنَتِ : حقیقت کھلی الْجِنُّ : جن اَنْ : اگر لَّوْ كَانُوْا يَعْلَمُوْنَ : وہ جانتے ہوتے الْغَيْبَ : غیب مَا لَبِثُوْا : وہ نہ رہتے فِي : میں الْعَذَابِ : عذاب الْمُهِيْنِ : ذلت پھر جب ہم نے ان پر موت کا حکم بھیج دیا تو ان کی خبر جنات کو کسی نے نہ دی سوائے گھن کے کیڑے کے جو ان کے عصا کو کھا رہا تھا۔ پس جب (سلیمان) گرپڑے اس وقت جنوں نے جان لیا کہ اگر وہ غیب دان ہوتے تو اس ذلت کے عذاب میں مبتلا نہ رہتے۔ (1)
34,15,لَقَدْ كَانَ لِسَبَاٍ فِیْ مَسْكَنِهِمْ اٰیَةٌ١ۚ جَنَّتٰنِ عَنْ یَّمِیْنٍ وَّ شِمَالٍ١ؕ۬ كُلُوْا مِنْ رِّزْقِ رَبِّكُمْ وَ اشْكُرُوْا لَهٗ١ؕ بَلْدَةٌ طَیِّبَةٌ وَّ رَبٌّ غَفُوْرٌ لَقَدْ كَانَ : البتہ تھی لِسَبَاٍ : (قوم) سبا کے لیے فِيْ : میں مَسْكَنِهِمْ : ان کی آبادی اٰيَةٌ ۚ : ایک نشانی جَنَّتٰنِ : دو باغ عَنْ يَّمِيْنٍ : دائیں سے وَّ شِمَالٍ : اور بائیں كُلُوْا : تم کھاؤ مِنْ : سے رِّزْقِ رَبِّكُمْ : اپنے رب کے رزق وَاشْكُرُوْا : اور شکر ادا کرو لَهٗ ۭ : اس کا بَلْدَةٌ : شہر طَيِّبَةٌ : پاکیزہ وَّرَبٌّ : اور پروردگار غَفُوْرٌ : بخشنے والا قوم سبا کے لئے اپنی بستیوں میں (قدرت الٰہی کی) نشانی تھی (1) ان کے دائیں بائیں دو باغ تھے (2) (ہم نے ان کو حکم دیا تھا کہ) اپنے رب کی دی ہوئی روزی کھاؤ (3) اور شکر ادا کرو (4) یہ عمدہ شہر (5) اور وہ بخشنے والا رب ہے (6)۔
34,16,فَاَعْرَضُوْا فَاَرْسَلْنَا عَلَیْهِمْ سَیْلَ الْعَرِمِ وَ بَدَّلْنٰهُمْ بِجَنَّتَیْهِمْ جَنَّتَیْنِ ذَوَاتَیْ اُكُلٍ خَمْطٍ وَّ اَثْلٍ وَّ شَیْءٍ مِّنْ سِدْرٍ قَلِیْلٍ فَاَعْرَضُوْا : پھر انہوں نے منہ موڑ لیا فَاَرْسَلْنَا : تو ہم نے بھیجا عَلَيْهِمْ : ان پر سَيْلَ الْعَرِمِ : سیلاب بند سے (رکا ہوا) وَبَدَّلْنٰهُمْ : اور ہم نے انہیں بدل دیے بِجَنَّتَيْهِمْ : ان کے دو باغوں کے بدلے جَنَّتَيْنِ : دو باغ ذَوَاتَىْ : والے اُكُلٍ : میوہ خَمْطٍ : بدمزہ وَّاَثْلٍ : اور جھاڑ وَّشَيْءٍ : اور کچھ مِّنْ سِدْرٍ : بیریاں قَلِيْلٍ : تھوڑی لیکن انہوں نے روگردانی کی تو ہم نے ان پر زور کے سیلاب (کا پانی) بھیج دیا اور ہم ان کے ہرے بھرے باغوں کے بدلے دو (ایسے) باغ دیئے جو بدمزہ میووں والے اور (بکثرت) جھاؤ اور کچھ بیری کے درختوں والے تھے۔ (1)
34,17,ذٰلِكَ جَزَیْنٰهُمْ بِمَا كَفَرُوْا١ؕ وَ هَلْ نُجٰزِیْۤ اِلَّا الْكَفُوْرَ ذٰلِكَ : یہ جَزَيْنٰهُمْ : ہم نے ان کو سزا دی بِمَا : اس کے سبب جو كَفَرُوْا ۭ : انہوں نے ناشکری کی وَهَلْ : اور نہیں نُجٰزِيْٓ : ہم سزا دیتے اِلَّا : مگر۔ صرف الْكَفُوْرَ : ناشکرا ہم نے ان کی ناشکری کا بدلہ انھیں دیا۔ ہم (ایسی) سخت سزا بڑے بڑے ناشکروں کو ہی دیتے ہیں۔
34,18,وَ جَعَلْنَا بَیْنَهُمْ وَ بَیْنَ الْقُرَى الَّتِیْ بٰرَكْنَا فِیْهَا قُرًى ظَاهِرَةً وَّ قَدَّرْنَا فِیْهَا السَّیْرَ١ؕ سِیْرُوْا فِیْهَا لَیَالِیَ وَ اَیَّامًا اٰمِنِیْنَ وَجَعَلْنَا : اور ہم نے ( آباد) کردیے بَيْنَهُمْ : ان کے درمیان وَبَيْنَ : اور درمیان الْقُرَى : بستیاں الَّتِيْ : وہ جنہیں بٰرَكْنَا : ہم نے برکت دی فِيْهَا : اس میں قُرًى : بستیاں ظَاهِرَةً : ایک دوسرے سے متصل وَّقَدَّرْنَا : اور ہم نے منفرد کردیا فِيْهَا السَّيْرَ : ان میں آمد و رفت سِيْرُوْا : تم چلو (پھرو) فِيْهَا : ان میں لَيَالِيَ : راتوں وَاَيَّامًا : اور دنوں اٰمِنِيْنَ : امن سے (ب خوف و خطر) ہم نے ان کے اور ان بستیوں کے درمیان جن میں ہم نے برکت دے رکھی تھی چند بستیاں اور (آباد) رکھی تھیں جو سر راہ ظاہر تھیں (1) اور ان میں چلنے کی منزلیں مقرر تھیں (2) ان میں راتوں اور دنوں کو بھی امن وامان چلتے پھرتے رہو۔ (3)
34,19,فَقَالُوْا رَبَّنَا بٰعِدْ بَیْنَ اَسْفَارِنَا وَ ظَلَمُوْۤا اَنْفُسَهُمْ فَجَعَلْنٰهُمْ اَحَادِیْثَ وَ مَزَّقْنٰهُمْ كُلَّ مُمَزَّقٍ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّكُلِّ صَبَّارٍ شَكُوْرٍ فَقَالُوْا : وہ کہنے لگے رَبَّنَا : اے ہمارے رب بٰعِدْ : دوری پیدا کرے بَيْنَ اَسْفَارِنَا : ہمارے سفروں کے درمیان وَظَلَمُوْٓا : اور انہوں نے ظلم کیا اَنْفُسَهُمْ : اپنی جانوں پر فَجَعَلْنٰهُمْ : تو ہم نے بنادیا انہیں اَحَادِيْثَ : افسانے وَمَزَّقْنٰهُمْ : اور ہم نے انہیں پراگندہ کردیا كُلَّ مُمَزَّقٍ ۭ : پوری طرح پراگندہ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ : نشانیاں لِّكُلِّ صَبَّارٍ : ہر بڑے صبر کرنے والے شَكُوْرٍ : شکر گزارے لیکن انہوں نے پھر کہا اے ہمارے پروردگار ! ہمارے سفر دور دراز کر دے (1) چونکہ خود انہوں نے اپنے ہاتھوں اپنا برا کیا اس لئے ہم نے انھیں (گذشتہ) افسانوں کی صورت میں کردیا (2) اور ان کے ٹکڑے ٹکڑے اڑا دیئے (3) بلاشبہ ہر ایک صبر شکر کرنے والے کے لئے اس (ماجرے) میں بہت سی عبرتیں ہیں۔
34,20,وَ لَقَدْ صَدَّقَ عَلَیْهِمْ اِبْلِیْسُ ظَنَّهٗ فَاتَّبَعُوْهُ اِلَّا فَرِیْقًا مِّنَ الْمُؤْمِنِیْنَ وَلَقَدْ : اور البتہ صَدَّقَ : سچ کر دکھایا عَلَيْهِمْ : ان پر اِبْلِيْسُ : ابلیس ظَنَّهٗ : اپنا گمان فَاتَّبَعُوْهُ : پس انہوں نے اس کی پیروی کی اِلَّا : سوائے فَرِيْقًا : ایک گروہ مِّنَ : سے۔ کا الْمُؤْمِنِيْنَ : مومن (جمع) اور شیطان نے ان کے بارے میں اپنا گمان سچا کر دکھایا یہ لوگ سب کے سب اس کے تابعدار بن گئے سوائے مومنوں کی ایک جماعت کے۔
34,21,وَ مَا كَانَ لَهٗ عَلَیْهِمْ مِّنْ سُلْطٰنٍ اِلَّا لِنَعْلَمَ مَنْ یُّؤْمِنُ بِالْاٰخِرَةِ مِمَّنْ هُوَ مِنْهَا فِیْ شَكٍّ١ؕ وَ رَبُّكَ عَلٰى كُلِّ شَیْءٍ حَفِیْظٌ۠    ۧ وَمَا كَانَ : اور نہ تھا لَهٗ : اسے (ابلیس کو) عَلَيْهِمْ : ان پر مِّنْ سُلْطٰنٍ : کوئی غلبہ اِلَّا : مگر لِنَعْلَمَ : تاکہ ہم معلوم کرلیں مَنْ يُّؤْمِنُ : جو ایمان رکھتا ہے بِالْاٰخِرَةِ : آخرت پر مِمَّنْ : اس سے جو هُوَ : وہ مِنْهَا : اس سے فِيْ شَكٍّ ۭ : شک میں وَرَبُّكَ : اور تیرا رب عَلٰي : پر كُلِّ شَيْءٍ : ہر شے حَفِيْظٌ : نگہبان شیطان کا ان پر کوئی زور (اور دباؤ) نہ تھا مگر اس لئے کہ ہم ان لوگوں کو جو آخرت پر ایمان رکھتے ہیں ظاہر کردیں ان لوگوں میں سے جو اس سے شک میں ہیں۔ اور آپ کا رب (ہر) ہر چیز پر نگہبان ہے۔
34,22,قُلِ ادْعُوا الَّذِیْنَ زَعَمْتُمْ مِّنْ دُوْنِ اللّٰهِ١ۚ لَا یَمْلِكُوْنَ مِثْقَالَ ذَرَّةٍ فِی السَّمٰوٰتِ وَ لَا فِی الْاَرْضِ وَ مَا لَهُمْ فِیْهِمَا مِنْ شِرْكٍ وَّ مَا لَهٗ مِنْهُمْ مِّنْ ظَهِیْرٍ قُلِ : فرمادیں ادْعُوا : پکارو الَّذِيْنَ : ان کو جنہیں زَعَمْتُمْ : گمان کرتے ہو مِّنْ دُوْنِ اللّٰهِ ۚ : اللہ کے سوا لَا يَمْلِكُوْنَ : وہ مالک نہیں ہیں مِثْقَالَ ذَرَّةٍ : ایک ذرہ کے برابر فِي السَّمٰوٰتِ : آسمانوں میں وَلَا : اور نہ فِي الْاَرْضِ : زمین میں وَمَا : اور نہین لَهُمْ : ان کا فِيْهِمَا مِنْ شِرْكٍ : ان ( آسمان و زمین) میں کوئی ساجھا وَّمَا لَهٗ : اور نہیں اس (اللہ) کا) مِنْهُمْ : ان میں سے مِّنْ ظَهِيْرٍ : کوئی مددگار کہہ دیجئے ! کہ اللہ کے سوا جن جن کا تمہیں گمان ہے (سب) کو پکار لو (1) نہ ان میں سے کسی کو آسمانوں اور زمینوں میں سے ایک ذرہ کا اختیار ہے (2) نہ ان کا ان میں کوئی حصہ (3) نہ ان میں سے کوئی اللہ کا مددگار ہے (4)
34,23,وَ لَا تَنْفَعُ الشَّفَاعَةُ عِنْدَهٗۤ اِلَّا لِمَنْ اَذِنَ لَهٗ١ؕ حَتّٰۤى اِذَا فُزِّعَ عَنْ قُلُوْبِهِمْ قَالُوْا مَا ذَا١ۙ قَالَ رَبُّكُمْ١ؕ قَالُوا الْحَقَّ١ۚ وَ هُوَ الْعَلِیُّ الْكَبِیْرُ وَلَا تَنْفَعُ : اور نفع نہیں دیتی الشَّفَاعَةُ : شفاعت عِنْدَهٗٓ : اس کے پاس اِلَّا : سوائے لِمَنْ اَذِنَ : جسے وہ اجازتے دے لَهٗ ۭ : اس کو حَتّىٰٓ : یہاں تک اِذَا : جب فُزِّعَ : دور کردی جاتی ہے عَنْ قُلُوْبِهِمْ : ان کے دلوں سے قَالُوْا : کہتے ہیں مَاذَا ۙ : کیا قَالَ : کہا رَبُّكُمْ ۭ : تمہارے رب نے قَالُوا : وہ کہتے ہیں الْحَقَّ ۚ : حق وَهُوَ : اور وہ الْعَلِيُّ : بلند مرتبہ الْكَبِيْرُ : بزرگ قدر شفاعت (شفارش) بھی اس کے پاس کچھ نفع نہیں دیتی بجز ان کے جن کے لئے اجازت ہوجائے (1) یہاں تک کہ جب ان کے دلوں سے گھبراہٹ دور کردی جاتی ہے تو پوچھتے ہیں تمہارے پروردگار نے کیا فرمایا ؟ جواب دیتے ہیں کہ حق فرمایا (2) اور وہ بلند وبالا اور بہت بڑا ہے۔
34,24,قُلْ مَنْ یَّرْزُقُكُمْ مِّنَ السَّمٰوٰتِ وَ الْاَرْضِ١ؕ قُلِ اللّٰهُ١ۙ وَ اِنَّاۤ اَوْ اِیَّاكُمْ لَعَلٰى هُدًى اَوْ فِیْ ضَلٰلٍ مُّبِیْنٍ قُلْ : فرمادیں مَنْ : کون يَّرْزُقُكُمْ : تمہیں رزق دیتا ہے مِّنَ السَّمٰوٰتِ : آسمانوں سے وَالْاَرْضِ ۭ : اور زمین قُلِ : فرمادیں اللّٰهُ ۙ : اللہ وَاِنَّآ : اور بیشک ہم اَوْ : یا اِيَّاكُمْ : تم ہی لَعَلٰى هُدًى : البتہ ہدایت پر اَوْ : یا فِيْ ضَلٰلٍ : گمراہی میں مُّبِيْنٍ : کھلی پوچھئے کہ تمہیں آسمانوں اور زمین سے روزی کون پہنچاتا ہے ؟ (خود) جواب دیجئے ! کہ اللہ تعالیٰ۔ (سنو) ہم یا تم۔ یا تو یقیناً ہدایت پر ہیں یا کھلی گمراہی میں ہیں ؟ (1)
34,25,قُلْ لَّا تُسْئَلُوْنَ عَمَّاۤ اَجْرَمْنَا وَ لَا نُسْئَلُ عَمَّا تَعْمَلُوْنَ قُلْ : فرمادیں لَّا تُسْئَلُوْنَ : تم سے نہ پوچھا جائے عَمَّآ : اس کی بابت اَجْرَمْنَا : جو ہم نے گناہ کیا وَلَا نُسْئَلُ : اور نہ ہم سے پوچھا جائے گا عَمَّا : اس کی بابت تَعْمَلُوْنَ : جو تم کرتے ہو کہہ دیجئے ! ہمارے کئے ہوئے گناہوں کی بابت تم سے کوئی سوال نہ کیا جائے گا نہ تمہارے اعمال کی باز پرس ہم سے کی جائے گی۔
34,26,قُلْ یَجْمَعُ بَیْنَنَا رَبُّنَا ثُمَّ یَفْتَحُ بَیْنَنَا بِالْحَقِّ١ؕ وَ هُوَ الْفَتَّاحُ الْعَلِیْمُ قُلْ : فرما دیں آپ يَجْمَعُ : وہ جمع کرے گا بَيْنَنَا : ہم سب کو رَبُّنَا : ہمارا رب ثُمَّ : پھر يَفْتَحُ : فیصلہ کرے گا بَيْنَنَا : ہمارے درمیان بِالْحَقِّ ۭ : ٹھیک ٹھیک وَهُوَ : اور وہ الْفَتَّاحُ : فیصلہ کرنے والا الْعَلِيْمُ : جاننے والا انہیں خبر دے دیجئے کہ سب کو ہمارا رب جمع کر کے پھر ہم میں سے سچے فیصلے کر دے گا (1) وہ فیصلے چکانے والا ہے
34,27,قُلْ اَرُوْنِیَ الَّذِیْنَ اَلْحَقْتُمْ بِهٖ شُرَكَآءَ كَلَّا١ؕ بَلْ هُوَ اللّٰهُ الْعَزِیْزُ الْحَكِیْمُ قُلْ : فرمادیں اَرُوْنِيَ : مجھے دکھاؤ الَّذِيْنَ : وہ جنہیں اَلْحَقْتُمْ : تم نے ساتھ ملا دیا ہے بِهٖ : اس کے ساتھ شُرَكَآءَ : شریک كَلَّا ۭ : ہرگز نہیں بَلْ : بلکہ هُوَ اللّٰهُ : وہ اللہ الْعَزِيْزُ : غالب الْحَكِيْمُ : حکمت والا کہہ دیجئے ! اچھا مجھے بھی تو انھیں دکھا دو جنہیں تم اللہ کا شریک ٹھہرا کر اس کے ساتھ ملا رہے ہو، ایسا ہرگز نہیں (1) بلکہ وہی اللہ ہے غالب با حکمت۔
34,28,وَ مَاۤ اَرْسَلْنٰكَ اِلَّا كَآفَّةً لِّلنَّاسِ بَشِیْرًا وَّ نَذِیْرًا وَّ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ وَمَآ : اور نہیں اَرْسَلْنٰكَ : آپ کو بھیجا ہم نے اِلَّا كَآفَّةً لِّلنَّاسِ : مگر تمام لوگوں (نوع انسانی) کے لیے بَشِيْرًا : خوشخبردی دینے والا وَّنَذِيْرًا : اور ڈر سنانے والا وَّلٰكِنَّ : اور لیکن اَكْثَرَ النَّاسِ : اکثر لوگ لَا يَعْلَمُوْنَ : نہیں جانتے ہم نے آپ کو تمام لوگوں کے لئے خوشخبریاں سنانے والا اور ڈرانے والا بنا کر بھیجا ہے ہاں مگر (یہ صحیح ہے) کہ لوگوں کی اکثریت بےعلم ہے (1)
34,29,وَ یَقُوْلُوْنَ مَتٰى هٰذَا الْوَعْدُ اِنْ كُنْتُمْ صٰدِقِیْنَ وَيَقُوْلُوْنَ : اور وہ کہتے ہیں مَتٰى : کب ھٰذَا الْوَعْدُ : یہ وعدہ (قیامت) اِنْ : اگر كُنْتُمْ : تم ہو صٰدِقِيْنَ : سچے پوچھتے ہیں کہ وہ وعدہ ہے کب ؟ سچے ہو تو بتادو۔ (1)
34,30,قُلْ لَّكُمْ مِّیْعَادُ یَوْمٍ لَّا تَسْتَاْخِرُوْنَ عَنْهُ سَاعَةً وَّ لَا تَسْتَقْدِمُوْنَ۠    ۧ قُلْ : فرمادیں لَّكُمْ : تمہارے لیے مِّيْعَادُ : وعدہ يَوْمٍ : ایک دن لَّا تَسْتَاْخِرُوْنَ : نہ تم پیچھے ہٹ سکتے ہو عَنْهُ : اس سے سَاعَةً : ایک گھڑی وَّلَا : اور نہ تَسْتَقْدِمُوْنَ : تم آگے بڑھ سکتے ہو جواب دیجئے کہ وعدے کا دن ٹھیک معین ہے جس سے ایک ساعت نہ تم پیچھے ہٹ سکتے ہو نہ آگے بڑھ سکتے ہو (1)۔
34,31,وَ قَالَ الَّذِیْنَ كَفَرُوْا لَنْ نُّؤْمِنَ بِهٰذَا الْقُرْاٰنِ وَ لَا بِالَّذِیْ بَیْنَ یَدَیْهِ١ؕ وَ لَوْ تَرٰۤى اِذِ الظّٰلِمُوْنَ مَوْقُوْفُوْنَ عِنْدَ رَبِّهِمْ١ۖۚ یَرْجِعُ بَعْضُهُمْ اِلٰى بَعْضِ اِ۟لْقَوْلَ١ۚ یَقُوْلُ الَّذِیْنَ اسْتُضْعِفُوْا لِلَّذِیْنَ اسْتَكْبَرُوْا لَوْ لَاۤ اَنْتُمْ لَكُنَّا مُؤْمِنِیْنَ وَقَالَ : اور کہتے ہیں الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) لَنْ نُّؤْمِنَ : ہم ہرگز ایمان نہ لائیں گے بِھٰذَا الْقُرْاٰنِ : اس قرآن پر وَلَا : اور نہ بِالَّذِيْ : اس پر جو بَيْنَ يَدَيْهِ ۭ : اس سے پہلے وَلَوْ تَرٰٓى : اور کاش تم دیکھو اِذِ : جب الظّٰلِمُوْنَ : ظالم (جمع) مَوْقُوْفُوْنَ : کھڑے کیے جائیں گے عِنْدَ رَبِّهِمْ ښ : اپنے رب کے سامنے يَرْجِعُ : لوٹائے گا (رد کرے گا) بَعْضُهُمْ : ان میں سے ایک اِلٰى : طرف بَعْضِۨ : دوسرے الْقَوْلَ ۚ : بات يَقُوْلُ : کہیں گے الَّذِيْنَ اسْتُضْعِفُوْا : جو کمزور کئے گئے (ناتوان) لِلَّذِيْنَ : ان لوگوں کو اسْتَكْبَرُوْا : تکبر کرتے تھے (بڑے لوگ) لَوْلَآ اَنْتُمْ : اگر نہ تم ہوتے لَكُنَّا : ضرور ہم ہوتے مُؤْمِنِيْنَ : ایمان لانے والے اور کافروں نے کہا ہم ہرگز نہ تو اس قرآن کو مانیں نہ اس سے پہلے کی کتابوں کو ! (1) اے دیکھنے والے کاش کہ تو ان ظالموں کو اس وقت دیکھتا جبکہ یہ اپنے رب کے سامنے کھڑے ہوئے ایک دوسرے کو الزام لگا رہے ہونگے (2) کمزور لوگ بڑے لوگوں سے کہیں گے (3) اگر تم نہ ہوتے تو ہم مومنوں میں سے ہوتے (4)۔
34,32,قَالَ الَّذِیْنَ اسْتَكْبَرُوْا لِلَّذِیْنَ اسْتُضْعِفُوْۤا اَنَحْنُ صَدَدْنٰكُمْ عَنِ الْهُدٰى بَعْدَ اِذْ جَآءَكُمْ بَلْ كُنْتُمْ مُّجْرِمِیْنَ قَالَ : کہیں گے الَّذِيْنَ اسْتَكْبَرُوْا : جو لوگ تکبر کرتے تھے (بڑے لوگ) لِلَّذِيْنَ اسْتُضْعِفُوْٓا : ان سے جو کمزور کیے گئے (ناتوان) اَنَحْنُ : کیا ہم صَدَدْنٰكُمْ : ہم نے روکا تمہیں عَنِ : سے الْهُدٰى : ہدایت بَعْدَ : اس کے بعد اِذْ جَآءَكُمْ : جب آگئی تمہارے پاس بَلْ : بلکہ كُنْتُمْ : تم تھے مُّجْرِمِيْنَ : مجرم (جمع) یہ بڑے لوگ ان کمزوروں کو جواب دیں گے کہ کیا تمہارے پاس ہدایت آچکنے کے بعد ہم نے تمہیں اس سے روکا تھا ؟ (نہیں) بلکہ تم (خود) ہی مجرم تھے (1)۔
34,33,وَ قَالَ الَّذِیْنَ اسْتُضْعِفُوْا لِلَّذِیْنَ اسْتَكْبَرُوْا بَلْ مَكْرُ الَّیْلِ وَ النَّهَارِ اِذْ تَاْمُرُوْنَنَاۤ اَنْ نَّكْفُرَ بِاللّٰهِ وَ نَجْعَلَ لَهٗۤ اَنْدَادًا١ؕ وَ اَسَرُّوا النَّدَامَةَ لَمَّا رَاَوُا الْعَذَابَ١ؕ وَ جَعَلْنَا الْاَغْلٰلَ فِیْۤ اَعْنَاقِ الَّذِیْنَ كَفَرُوْا١ؕ هَلْ یُجْزَوْنَ اِلَّا مَا كَانُوْا یَعْمَلُوْنَ وَقَالَ : اور کہیں گے الَّذِيْنَ : وہ لوگ جو اسْتُضْعِفُوْا : کمزور کیے گئے (ناتوان) لِلَّذِيْنَ اسْتَكْبَرُوْا : ان لوگوں سے جو تکبر کرتے تھے (بڑے) بَلْ : بلکہ مَكْرُ : چال الَّيْلِ وَالنَّهَارِ : رات اور دن اِذْ تَاْمُرُوْنَنَآ : جب تم حکم دیتے تھے ہمیں اَنْ نَّكْفُرَ : کہ ہم انکار کریں بِاللّٰهِ : اللہ کا وَنَجْعَلَ : اور ہم ٹھہرائیں لَهٗٓ : اس کے لیے اَنْدَادًا ۭ : شریک (جمع) وَاَسَرُّوا : اور وہ چھپائیں گے النَّدَامَةَ : شرمندگی لَمَّا رَاَوُا : جب وہ دیکھیں گے الْعَذَابَ ۭ : عذاب وَجَعَلْنَا : اور ہم ڈالیں گے الْاَغْلٰلَ : طوق فِيْٓ اَعْنَاقِ : گردنوں میں الَّذِيْنَ كَفَرُوْا ۭ : جن لوگوں نے کفر کیا (کافر) هَلْ يُجْزَوْنَ : وہ سزا نہ دیے جائیں گے اِلَّا : مگر مَا : جو كَانُوْا يَعْمَلُوْنَ : وہ کرتے تھے اس کے جواب میں) یہ کمزور لوگ ان متکبروں سے کہیں گے، (نہیں نہیں) بلکہ دن رات مکرو فریب سے ہمیں اللہ کے ساتھ کفر کرنے اور اس کے شریک مقرر کرنے کا ہمارا حکم دینا ہماری بےایمانی کا باعث ہوا (1) اور عذاب کو دیکھتے ہی سب کے سب دل میں پشیمان ہو رہے ہونگے (2) اور کافروں کی گردنوں میں ہم طوق ڈال دیں گے (3) انھیں صرف ان کے کئے کرائے اعمال کا بدلہ دیا جائے گا۔ (4)
34,34,وَ مَاۤ اَرْسَلْنَا فِیْ قَرْیَةٍ مِّنْ نَّذِیْرٍ اِلَّا قَالَ مُتْرَفُوْهَاۤ١ۙ اِنَّا بِمَاۤ اُرْسِلْتُمْ بِهٖ كٰفِرُوْنَ وَمَآ اَرْسَلْنَا : اور ہم نے نہیں بھیجا فِيْ قَرْيَةٍ : کسی بستی میں مِّنْ نَّذِيْرٍ : کوئی ڈرانے والا اِلَّا : مگر قَالَ : کہا مُتْرَفُوْهَآ ۙ : اس کے خوشحال لوگ اِنَّا : بیشک ہم بِمَآ اُرْسِلْتُمْ : تم جو دے کر بھیجے گئے ہو بِهٖ : اس کے كٰفِرُوْنَ : منکر ہیں اور ہم نے جس بستی میں جو بھی آگاہ کرنے والا بھیجا وہاں کے خوشحال لوگوں نے یہی کیا کہ جس چیز کے ساتھ تم بھیجے گئے ہو ہم اس کے ساتھ جو کفر کرنے والے ہیں (1)۔
34,35,وَ قَالُوْا نَحْنُ اَكْثَرُ اَمْوَالًا وَّ اَوْلَادًا١ۙ وَّ مَا نَحْنُ بِمُعَذَّبِیْنَ وَقَالُوْا : اور انہوں نے کہا نَحْنُ : ہم اَكْثَرُ : زیادہ اَمْوَالًا : مال میں وَّاَوْلَادًا ۙ : اور اولاد میں وَّمَا : اور نہیں نَحْنُ : ہم بِمُعَذَّبِيْنَ : عذاب دیئے جانے والے اور کہا ہم مال اولاد میں بہت بڑے ہوئے ہیں یہ نہیں ہوسکتا کہ ہم عذاب دیئے جائیں (1)
34,36,قُلْ اِنَّ رَبِّیْ یَبْسُطُ الرِّزْقَ لِمَنْ یَّشَآءُ وَ یَقْدِرُ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ۠    ۧ قُلْ : فرمادیں اِنَّ : بیشک رَبِّيْ : میرا رب يَبْسُطُ : وسیع فرماتا ہے الرِّزْقَ : رزق لِمَنْ يَّشَآءُ : جس کے لیے وہ چاہتا ہے وَيَقْدِرُ : اور تنگ کردیتا ہے وَلٰكِنَّ : اور لیکن اَكْثَرَ النَّاسِ : اکثر لوگ لَا يَعْلَمُوْنَ : نہیں جانتے کہہ دیجئے ! کہ میرا رب جس کے لئے چاہے روزی کشادہ کر کردیتا ہے (2) لیکن اکثر لوگ نہیں جانتے۔
34,37,وَ مَاۤ اَمْوَالُكُمْ وَ لَاۤ اَوْلَادُكُمْ بِالَّتِیْ تُقَرِّبُكُمْ عِنْدَنَا زُلْفٰۤى اِلَّا مَنْ اٰمَنَ وَ عَمِلَ صَالِحًا١٘ فَاُولٰٓئِكَ لَهُمْ جَزَآءُ الضِّعْفِ بِمَا عَمِلُوْا وَ هُمْ فِی الْغُرُفٰتِ اٰمِنُوْنَ وَمَآ : اور نہیں اَمْوَالُكُمْ : تمہارے مال وَلَآ : اور نہ اَوْلَادُكُمْ : تمہاری اولاد بِالَّتِيْ : وہ جو کہ تُقَرِّبُكُمْ : تمہیں نزدیک کردے عِنْدَنَا : ہمارے نزدیک زُلْفٰٓي : درجہ اِلَّا : مگر مَنْ : جو اٰمَنَ : ایمان لایا وَعَمِلَ صَالِحًا ۡ : اور اس نے اچھے عمل کیے فَاُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے جَزَآءُ : جزا الضِّعْفِ : دوگنی بِمَا عَمِلُوْا : اس کے بدلے جو انہوں نے کیا وَهُمْ : اور وہ فِي الْغُرُفٰتِ : بالاخانوں میں اٰمِنُوْنَ : امن سے ہوں گے اور تمہارا مال اور اولاد ایسے نہیں کہ تمہیں ہمارے پاس (مرتبوں) قریب کردیں (1) ہاں جو ایمان لائیں اور نیک عمل کریں (2) ان کے لئے ان کے اعمال کا دوہرا اجر ہے (3) اور وہ نڈر و بےخوف ہو کر بالا خانوں میں رہیں گے۔
34,38,وَ الَّذِیْنَ یَسْعَوْنَ فِیْۤ اٰیٰتِنَا مُعٰجِزِیْنَ اُولٰٓئِكَ فِی الْعَذَابِ مُحْضَرُوْنَ وَالَّذِيْنَ : اور جو لوگ يَسْعَوْنَ : کوشش کرتے ہیں فِيْٓ اٰيٰتِنَا : ہماری آیتوں میں مُعٰجِزِيْنَ : عاجزی کرنے (ہرانے) والے اُولٰٓئِكَ : یہی لوگ فِي الْعَذَابِ : عذاب میں مُحْضَرُوْنَ : حاضر کیے جائیں گے اور جو لوگ ہماری آیتوں کے مقابلے کی تگ و دو میں لگے رہتے ہیں یہی ہیں جو عذاب میں پکڑ کر حاضر رکھے جائیں گے۔
34,39,قُلْ اِنَّ رَبِّیْ یَبْسُطُ الرِّزْقَ لِمَنْ یَّشَآءُ مِنْ عِبَادِهٖ وَ یَقْدِرُ لَهٗ١ؕ وَ مَاۤ اَنْفَقْتُمْ مِّنْ شَیْءٍ فَهُوَ یُخْلِفُهٗ١ۚ وَ هُوَ خَیْرُ الرّٰزِقِیْنَ قُلْ : فرمادیں اِنَّ : بیشک رَبِّيْ : میرا رب يَبْسُطُ : وسیع فرماتا ہے الرِّزْقَ : رزق لِمَنْ يَّشَآءُ : جس کے لیے وہ چاہتا ہے مِنْ عِبَادِهٖ : اپنے بندوں میں سے وَيَقْدِرُ : اور تنگ کردیتا ہے لَهٗ ۭ : اس کے لیے وَمَآ : اور جو اَنْفَقْتُمْ : تم خرچ کرو گے مِّنْ شَيْءٍ : کوئی شے فَهُوَ : تو وہ يُخْلِفُهٗ ۚ : اس کا عوض دے گا وَهُوَ : اور وہ خَيْرُ : بہترین الرّٰزِقِيْنَ : رزق دینے والا کہہ دیجئے ! کہ میرا رب اپنے بندوں میں جس کے لئے چاہے روزی کشادہ کرتا ہے اور جس کے لئے چاہے تنگ کردیتا (1) ہے تم جو کچھ بھی اللہ کی راہ میں خرچ کرو گے اللہ اس کا (پورا پورا) بدلہ دے گا (2) اور سب سے بہتر روزی دینے والا ہے۔ (3)
34,40,وَ یَوْمَ یَحْشُرُهُمْ جَمِیْعًا ثُمَّ یَقُوْلُ لِلْمَلٰٓئِكَةِ اَهٰۤؤُلَآءِ اِیَّاكُمْ كَانُوْا یَعْبُدُوْنَ وَيَوْمَ : اور جس دن يَحْشُرُهُمْ : وہ جمع کرے گا ان کو جَمِيْعًا : سب ثُمَّ يَقُوْلُ : پھر فرمائے گا لِلْمَلٰٓئِكَةِ : فرشتوں کو اَهٰٓؤُلَآءِ : کیا یہ لوگ اِيَّاكُمْ : تمہاری ہی كَانُوْا يَعْبُدُوْنَ : پرستش کرتے تھے اور ان سب کو اللہ اس دن جمع کرکے فرشتوں سے دریافت فرمائے گا کہ کیا یہ لوگ تمہاری عبادت کرتے تھے (1)۔
34,41,قَالُوْا سُبْحٰنَكَ اَنْتَ وَلِیُّنَا مِنْ دُوْنِهِمْ١ۚ بَلْ كَانُوْا یَعْبُدُوْنَ الْجِنَّ١ۚ اَكْثَرُهُمْ بِهِمْ مُّؤْمِنُوْنَ قَالُوْا : وہ کہیں گے سُبْحٰنَكَ : تو پاک ہے اَنْتَ : تو وَلِيُّنَا : ہمارا کارساز مِنْ دُوْنِهِمْ ۚ : ان کے سوائے (نہ کہ وہ) بَلْ : بلکہ كَانُوْا يَعْبُدُوْنَ : وہ پرستش کرتے تھے الْجِنَّ ۚ : جن (جمع) اَكْثَرُهُمْ : ان میں سے اکثر بِهِمْ : ان پر مُّؤْمِنُوْنَ : اعتقاد رکھتے تھے اور کہیں گے تیری ذات پاک ہے اور ہمارا ولی تو تو ہے نہ کہ یہ (1) بلکہ یہ لوگ جنوں کی عبادت کرتے تھے ان میں اکثر کا انہی پر ایمان تھا۔
34,42,فَالْیَوْمَ لَا یَمْلِكُ بَعْضُكُمْ لِبَعْضٍ نَّفْعًا وَّ لَا ضَرًّا١ؕ وَ نَقُوْلُ لِلَّذِیْنَ ظَلَمُوْا ذُوْقُوْا عَذَابَ النَّارِ الَّتِیْ كُنْتُمْ بِهَا تُكَذِّبُوْنَ فَالْيَوْمَ : سو آج لَا يَمْلِكُ : اختیار نہیں رکھتا بَعْضُكُمْ : تم میں سے بعض (ایک) لِبَعْضٍ : بعض (دوسرے) کے لیے نَّفْعًا : نفع کا وَّلَا ضَرًّا ۭ : اور نہ نقصان کا وَنَقُوْلُ : اور ہم کہیں گے لِلَّذِيْنَ : ان لوگوں کو ظَلَمُوْا : جنہوں نے ظلم کیا ذُوْقُوْا : تم چکھو عَذَابَ النَّارِ : آگ (جہنم) کا عذاب الَّتِيْ : وہ جس كُنْتُمْ : تم تھے بِهَا : اس کو تُكَذِّبُوْنَ : تم جھٹلاتے تھے پس آج تم سے کوئی (بھی) کسی کے لئے (بھی کسی قسم کے) نفع نقصان کا مالک نہ ہوگا (1) اور ہم ظالموں (2) سے کہہ دے گیں کہ اس آگ کا عذاب چکھو جو جسے تم جھٹلاتے رہے۔
34,43,وَ اِذَا تُتْلٰى عَلَیْهِمْ اٰیٰتُنَا بَیِّنٰتٍ قَالُوْا مَا هٰذَاۤ اِلَّا رَجُلٌ یُّرِیْدُ اَنْ یَّصُدَّكُمْ عَمَّا كَانَ یَعْبُدُ اٰبَآؤُكُمْ١ۚ وَ قَالُوْا مَا هٰذَاۤ اِلَّاۤ اِفْكٌ مُّفْتَرًى١ؕ وَ قَالَ الَّذِیْنَ كَفَرُوْا لِلْحَقِّ لَمَّا جَآءَهُمْ١ۙ اِنْ هٰذَاۤ اِلَّا سِحْرٌ مُّبِیْنٌ وَاِذَا : اور جب تُتْلٰى : پڑھی جاتی ہیں عَلَيْهِمْ : ان پر اٰيٰتُنَا : ہماری آیات بَيِّنٰتٍ : واضح قَالُوْا : وہ کہتے ہیں مَا ھٰذَآ : نہیں ہے یہ اِلَّا : مگر۔ صرف رَجُلٌ : ایک آدمی يُّرِيْدُ : وہ چاہتا ہے اَنْ يَّصُدَّكُمْ : کہ روکے تمہیں عَمَّا : اس سے جس كَانَ يَعْبُدُ : پرستش کرتے تھے اٰبَآؤُكُمْ ۚ : تمہارے باپ دادا وَقَالُوْا : اور وہ کہتے ہیں مَا ھٰذَآ : نہیں یہ اِلَّآ : مگر اِفْكٌ مُّفْتَرًى ۭ : جھوٹ گھڑا ہوا وَقَالَ : اور کہا الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا ( کافر) لِلْحَقِّ : حق کے بارے میں لَمَّا جَآءَهُمْ ۙ : جب وہ آیا ان کے پاس اِنْ ھٰذَآ : یہ نہیں اِلَّا : مگر سِحْرٌ مُّبِيْنٌ : جادو کھلا اور جب ان کے سامنے ہماری صاف صاف آیتیں پڑھی جاتی ہیں تو کہتے ہیں کہ یہ ایسا شخص ہے (1) جو تمہیں تمہارے باپ دادا کے معبودوں سے روک دینا چاہتا ہے (اس کے سوا کوئی بات نہیں) ، اور کہتے ہیں یہ تو گھڑا ہوا جھوٹ ہے (2) اور حق ان کے پاس آچکا ہے پھر بھی کافر یہی کہتے رہے کہ یہ تو کھلا ہوا جادو ہے (3)۔
34,44,وَ مَاۤ اٰتَیْنٰهُمْ مِّنْ كُتُبٍ یَّدْرُسُوْنَهَا وَ مَاۤ اَرْسَلْنَاۤ اِلَیْهِمْ قَبْلَكَ مِنْ نَّذِیْرٍؕ وَمَآ : اور نہ اٰتَيْنٰهُمْ : دیں ہم نے انہیں مِّنْ كُتُبٍ : کتابیں يَّدْرُسُوْنَهَا : کہ انہیں پڑھیں وَمَآ : اور نہ اَرْسَلْنَآ : بھیجا ہم نے اِلَيْهِمْ : ان کی طرف قَبْلَكَ : آپ سے پہلے مِنْ نَّذِيْرٍ : کوئی ڈرانے والا اور ان (مکہ والوں) کو نہ تو ہم نے کتابیں دے رکھی ہیں جنہیں یہ پڑھتے ہوں نہ ان کے پاس آپ سے پہلے کوئی آگاہ کرنے والا آیا (1)
34,45,وَ كَذَّبَ الَّذِیْنَ مِنْ قَبْلِهِمْ١ۙ وَ مَا بَلَغُوْا مِعْشَارَ مَاۤ اٰتَیْنٰهُمْ فَكَذَّبُوْا رُسُلِیْ١۫ فَكَیْفَ كَانَ نَكِیْرِ۠    ۧ وَكَذَّبَ : اور جھٹلایا الَّذِيْنَ : انہوں نے جو مِنْ قَبْلِهِمْ ۙ : ان سے پہلے وَمَا بَلَغُوْا : اور وہ نہ پہنچے مِعْشَارَ : دسواں حصہ مَآ اٰتَيْنٰهُمْ : جو ہم نے انہیں دیا فَكَذَّبُوْا : سو انہوں نے جھٹلایا رُسُلِيْ ۣ : میرے رسولوں کو فَكَيْفَ : تو کیسا كَانَ : ہوا نَكِيْرِ : میرا عذاب اور ان سے پہلے کے لوگوں نے بھی ہماری باتوں کو جھٹلایا تھا اور انہیں ہم نے جو دے رکھا تھا یہ تو اس کے دسویں حصے بھی نہیں پہنچے، پس انہوں نے میرے رسولوں کو جھٹلایا، (پھر دیکھ کہ) میرا عذاب کیسا (سخت تھا) (1)
34,46,قُلْ اِنَّمَاۤ اَعِظُكُمْ بِوَاحِدَةٍ١ۚ اَنْ تَقُوْمُوْا لِلّٰهِ مَثْنٰى وَ فُرَادٰى ثُمَّ تَتَفَكَّرُوْا١۫ مَا بِصَاحِبِكُمْ مِّنْ جِنَّةٍ١ؕ اِنْ هُوَ اِلَّا نَذِیْرٌ لَّكُمْ بَیْنَ یَدَیْ عَذَابٍ شَدِیْدٍ قُلْ : فرما دیں اِنَّمَآ اَعِظُكُمْ : میں صرف نصیحت کرتا ہوں تمہیں بِوَاحِدَةٍ ۚ : ایک بات کی اَنْ تَقُوْمُوْا : کہ تم کھڑے ہوجاؤ لِلّٰهِ : اللہ کے واسطے مَثْنٰى : دو ، دو وَفُرَادٰى : اور اکیلے اکیلے ثُمَّ تَتَفَكَّرُوْا ۣ : پھر تم غور کرو مَا بِصَاحِبِكُمْ : نہیں تمہارے اس ساتھی کو مِّنْ جِنَّةٍ ۭ : کوئی جنون اِنْ : نہیں هُوَ : وہ اِلَّا : مگر۔ صرف نَذِيْرٌ : ڈرانے والے لَّكُمْ : تمہیں بَيْنَ يَدَيْ : آگے ( آنے سے پہلے) عَذَابٍ شَدِيْدٍ : سخت عذاب کہہ دیجئے ! کہ میں تمہیں صرف ایک ہی بات کی نصیحت کرتا ہوں کہ تم اللہ کے واسطے (ضد چھوڑ کر) وہ دو مل کر یا تنہا تنہا کھڑے ہو کر سوچو تو سہی، تمہارے اس رفیق کو کوئی جنون تو نہیں (1) وہ تو تمہیں ایک بڑے (سخت) عذاب کے آنے سے پہلے ڈرانے والا ہے (2)۔
34,47,قُلْ مَا سَاَلْتُكُمْ مِّنْ اَجْرٍ فَهُوَ لَكُمْ١ؕ اِنْ اَجْرِیَ اِلَّا عَلَى اللّٰهِ١ۚ وَ هُوَ عَلٰى كُلِّ شَیْءٍ شَهِیْدٌ قُلْ : فرمادیں مَا سَاَلْتُكُمْ : جو میں نے مانگا ہو تم سے مِّنْ اَجْرٍ : کوئی اجر فَهُوَ : تو وہ لَكُمْ ۭ : تمہارا ہے اِنْ : نہیں اَجْرِيَ : میرا اجر اِلَّا : مگر۔ صرف عَلَي اللّٰهِ ۚ : اللہ کے ذمے وَهُوَ : اور وہ عَلٰي : ہر۔ کی كُلِّ شَيْءٍ : ہر شے شَهِيْدٌ : اطلاع رکھنے والا ہے کہ دیجئے ! کہ جو بدلہ تم سے مانگوں وہ تمہارے لئے ہے (1) میرا بدلہ تو اللہ ہی کے ذمے ہے۔ وہ ہر چیز سے باخبر اور مطلع ہے۔
34,48,قُلْ اِنَّ رَبِّیْ یَقْذِفُ بِالْحَقِّ١ۚ عَلَّامُ الْغُیُوْبِ قُلْ : فرمادیں اِنَّ : بیشک رَبِّيْ : میرا رب يَقْذِفُ : ڈالتا (اوپر سے) اتارتا ہے بِالْحَقِّ ۚ : حق کو عَلَّامُ الْغُيُوْبِ : سب غیبوں کا جاننے والا کہہ دیجئے ! کہ میرا رب حق (سچی وحی) نازل فرماتا ہے وہ ہر غیب کا جاننے والا ہے (1)
34,49,قُلْ جَآءَ الْحَقُّ وَ مَا یُبْدِئُ الْبَاطِلُ وَ مَا یُعِیْدُ قُلْ : فرمادیں جَآءَ الْحَقُّ : حق آگیا وَمَا يُبْدِئُ : اور نہ پیدا کرے گا الْبَاطِلُ : باطل وَمَا يُعِيْدُ : اور نہ لوٹائے گا کہہ دیجئے ! کہ حق آچکا باطل نہ پہلے کچھ کرسکا ہے اور نہ کرسکے گا (1)۔
34,50,قُلْ اِنْ ضَلَلْتُ فَاِنَّمَاۤ اَضِلُّ عَلٰى نَفْسِیْ١ۚ وَ اِنِ اهْتَدَیْتُ فَبِمَا یُوْحِیْۤ اِلَیَّ رَبِّیْ١ؕ اِنَّهٗ سَمِیْعٌ قَرِیْبٌ قُلْ : فرمادیں اِنْ : اگر ضَلَلْتُ : میں بہکا ہوں فَاِنَّمَآ : تو اس کے سوا نہیں اَضِلُّ : میں بہکا ہوں عَلٰي نَفْسِيْ ۚ : اپنی جان پر (اپنے نقصان کو) وَاِنِ : اور اگر اهْتَدَيْتُ : میں ہدایت پر ہوں فَبِمَا : تو اس کی بدولت يُوْحِيْٓ : وہ وحی کرتا ہے اِلَيَّ : میری طرف رَبِّيْ ۭ : میرا رب اِنَّهٗ : بیشک وہ سَمِيْعٌ : سننے والا قَرِيْبٌ : قریب کہہ دیجئے کہ اگر میں بہک جاؤں تو میرے بہکنے (کا وبال) مجھ پر ہے اور اگر میں راہ ہدایت پر ہوں توبہ سبب اس وحی کے جو میرا پروردگار مجھے کرتا (1) ہے وہ بڑا ہی سننے والا اور بہت ہی قریب ہے (2)۔
34,51,وَ لَوْ تَرٰۤى اِذْ فَزِعُوْا فَلَا فَوْتَ وَ اُخِذُوْا مِنْ مَّكَانٍ قَرِیْبٍۙ وَلَوْ تَرٰٓى : اے کاش تم دیکھو اِذْ : جب فَزِعُوْا : وہ گھبرائیں گے فَلَا فَوْتَ : اور نہ بچ سکیں گے وَاُخِذُوْا : اور پکڑ لیے جائیں گے مِنْ : سے مَّكَانٍ قَرِيْبٍ : قریب جگہ (پاس) اور اگر آپ (وہ وقت) ملاحظہ کریں جبکہ یہ کفار گھبرائے پھریں گے اور پھر نکل بھاگنے کی کوئی صورت نہ ہوگی (1) اور قریب کی جگہ سے گرفتار کر لئے جائیں گے۔
34,52,وَّ قَالُوْۤا اٰمَنَّا بِهٖ١ۚ وَ اَنّٰى لَهُمُ التَّنَاوُشُ مِنْ مَّكَانٍۭ بَعِیْدٍۚۖ وَّقَالُوْٓا : اور وہ کہیں گے اٰمَنَّا : ہم ایمان لائے بِهٖ ۚ : اس پر وَاَنّٰى : اور کہاں لَهُمُ : ان کے لیے التَّنَاوُشُ : پکڑنا (ہاتھ آنا) مِنْ : سے مَّكَانٍۢ : جگہ بَعِيْدٍ : دور (دار الجزا) اس وقت کہیں گے کہ ہم اس قرآن پر ایمان لائے لیکن اس قدر دور جگہ سے (مطلوبہ چیز) کیسے ہاتھ (1) آسکتی ہے۔
34,53,وَّ قَدْ كَفَرُوْا بِهٖ مِنْ قَبْلُ١ۚ وَ یَقْذِفُوْنَ بِالْغَیْبِ مِنْ مَّكَانٍۭ بَعِیْدٍ وَّقَدْ كَفَرُوْا : اور تحقیق انہوں نے کفر کیا بِهٖ : اس سے مِنْ قَبْلُ ۚ : اس سے قبل وَيَقْذِفُوْنَ : اور وہ پھینکتے ہیں بِالْغَيْبِ : بن دیکھے مِنْ : سے مَّكَانٍۢ بَعِيْدٍ : دور جگہ اس سے پہلے تو انہوں نے اس سے کفر کیا تھا، اور دور دراز سے بن دیکھے بھٹکتے رہے (1)۔
34,54,وَ حِیْلَ بَیْنَهُمْ وَ بَیْنَ مَا یَشْتَهُوْنَ كَمَا فُعِلَ بِاَشْیَاعِهِمْ مِّنْ قَبْلُ١ؕ اِنَّهُمْ كَانُوْا فِیْ شَكٍّ مُّرِیْبٍ۠    ۧ وَحِيْلَ : اور آڑ کردی گئی بَيْنَهُمْ : ان کے درمیان وَبَيْنَ : اور درمیان مَا يَشْتَهُوْنَ : جو وہ چاہتے تھے كَمَا : جیسے فُعِلَ : کیا گیا بِاَشْيَاعِهِمْ : ان کے ہم جنسوں کے ساتھ مِّنْ قَبْلُ ۭ : اس سے قبل اِنَّهُمْ : بیشک وہ كَانُوْا : وہ تھے فِيْ : میں شَكٍّ : شک مُّرِيْبٍ : تردد میں ڈالنے والے ان کی چاہتوں اور ان کے درمیان پردہ حائل کردیا گیا (1) جیسے کہ اس سے پہلے بھی ان جیسوں کے ساتھ کیا گیا (2) وہ بھی (انہی کی طرح) شک و تردد میں پڑے ہوئے تھے۔ (3)
