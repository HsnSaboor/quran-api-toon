tafsir[21]{c,v,t}:
  54,7,خُشَّعًا اَبْصَارُهُمْ یَخْرُجُوْنَ مِنَ الْاَجْدَاثِ كَاَنَّهُمْ جَرَادٌ مُّنْتَشِرٌۙ خُشَّعًا : جھکی ہوئی ہوں گی اَبْصَارُهُمْ : ان کی نگاہیں يَخْرُجُوْنَ : نکلیں گے مِنَ الْاَجْدَاثِ : قبروں سے كَاَنَّهُمْ : گویا کہ وہ جَرَادٌ مُّنْتَشِرٌ : ٹڈیاں ہیں پھیلی ہوئیں یہ جھکی آنکھوں قبروں سے اس طرح نکل کھڑے ہونگے کہ گویا وہ پھیلا ہوا ٹڈی دل ہے (1)۔
  54,8,مُّهْطِعِیْنَ اِلَى الدَّاعِ١ؕ یَقُوْلُ الْكٰفِرُوْنَ هٰذَا یَوْمٌ عَسِرٌ مُّهْطِعِيْنَ : دوڑنے والے ہیں اِلَى : طرف الدَّاعِ ۭ : پکارنے والے کے يَقُوْلُ الْكٰفِرُوْنَ : کہیں گے کافر ھٰذَا يَوْمٌ عَسِرٌ : یہ دن ہے سخت پکارنے والے کی طرف دوڑتے ہونگے اور کافر کہیں گے کہ یہ دن تو بہت سخت ہے۔
  54,9,كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ فَكَذَّبُوْا عَبْدَنَا وَ قَالُوْا مَجْنُوْنٌ وَّ ازْدُجِرَ كَذَّبَتْ : جھٹلایا قَبْلَهُمْ : ان سے پہلے قَوْمُ نُوْحٍ : قوم نوح نے فَكَذَّبُوْا عَبْدَنَا : تو انہوں نے جھٹلایا ہمارے بندے کو وَقَالُوْا : اور انہوں نے کہا مَجْنُوْنٌ : مجنون ہے وَّازْدُجِرَ : اور ڈانٹا گیا۔ خوب دھمکی دیا گیا ان سے پہلے قوم نوح نے بھی ہمارے بندے کو جھٹلایا تھا اور دیوانہ بتلا کر جھڑک دیا گیا تھا (1)۔
  54,10,فَدَعَا رَبَّهٗۤ اَنِّیْ مَغْلُوْبٌ فَانْتَصِرْ فَدَعَا رَبَّهٗٓ : تو اس نے پکارا اپنے رب کو اَنِّىْ مَغْلُوْبٌ : بیشک میں مغلوب ہوں فَانْتَصِرْ : پس بدلہ لے۔ انتقام لے پس اس نے اپنے رب سے دعا کی کہ میں بےبس ہوں تو میری مدد کر۔
  54,11,فَفَتَحْنَاۤ اَبْوَابَ السَّمَآءِ بِمَآءٍ مُّنْهَمِرٍ٘ۖ فَفَتَحْنَآ : تو کھول دیئے ہم نے اَبْوَابَ السَّمَآءِ : دروازے آسمان کے بِمَآءٍ : ساتھ ایک پانی کے مُّنْهَمِرٍ : برسنے والا پس ہم نے آسمان کے دروازوں کو زور کے مینہ سے کھول دیا۔
  54,12,وَّ فَجَّرْنَا الْاَرْضَ عُیُوْنًا فَالْتَقَى الْمَآءُ عَلٰۤى اَمْرٍ قَدْ قُدِرَۚ وَّفَجَّرْنَا : اور پھاڑ دیا ہم نے الْاَرْضَ : زمین کو عُيُوْنًا : چشموں میں فَالْتَقَى الْمَآءُ : پس مل گیا پانی عَلٰٓي اَمْرٍ : ایک حکم پر قَدْ قُدِرَ : تحقیق جس کا اندازہ کیا گیا تھا۔ جو مقدر ہوچکا تھا اور زمین سے چشموں کو جاری کردیا پس اس کام کے لئے جو مقدر کیا گیا تھا (دونوں) پانی جمع ہوگئے۔
  54,13,وَ حَمَلْنٰهُ عَلٰى ذَاتِ اَلْوَاحٍ وَّ دُسُرٍۙ وَحَمَلْنٰهُ : اور اٹھایا ہم نے اس کو۔ سوار کیا ہم نے اس کو عَلٰي ذَاتِ اَلْوَاحٍ : اوپر تختوں والی کے وَّدُسُرٍ : اور میخوں والی کے اور ہم نے اسے تختوں اور کیلوں والی کشتی پر سوار کرلیا۔
  54,14,تَجْرِیْ بِاَعْیُنِنَا١ۚ جَزَآءً لِّمَنْ كَانَ كُفِرَ تَجْرِيْ : چل رہی تھی بِاَعْيُنِنَا ۚ : ہماری نگاہوں کے سامنے۔ ساتھ جَزَآءً : بدلہ تھا لِّمَنْ : اس کے لیے جو كَانَ كُفِرَ : تھا انکار کیا گیا۔ کفر کیا گیا جو ہماری آنکھوں کے سامنے چل رہی تھی۔ بدلہ اس کی طرف سے جس کا کفر کیا گیا تھا۔
  54,15,وَ لَقَدْ تَّرَكْنٰهَاۤ اٰیَةً فَهَلْ مِنْ مُّدَّكِرٍ وَلَقَدْ تَّرَكْنٰهَآ : اور البتہ تحقیق چھوڑ دیا ہم نے اس کو اٰيَةً : ایک نشانی کے طور پر فَهَلْ : تو کیا مِنْ مُّدَّكِرٍ : ہے کوئی نصیحت حاصل کرنے والا اور بیشک ہم نے اس واقعہ کو نشانی بنا کر باقی رکھا پس کوئی ہے نصیحت حاصل کرنے والا (1)
  54,16,فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ فَكَيْفَ : تو کس طرح تھا كَانَ عَذَابِيْ : عذاب میرا وَنُذُرِ : اور ڈرانا میرا بتاؤ میرا عذاب اور میری ڈرانے والی باتیں کیسی رہیں ؟
  54,17,وَ لَقَدْ یَسَّرْنَا الْقُرْاٰنَ لِلذِّكْرِ فَهَلْ مِنْ مُّدَّكِرٍ وَلَقَدْ : اور البتہ تحقیق يَسَّرْنَا الْقُرْاٰنَ : آسان کردیا ہم نے قرآن کو لِلذِّكْرِ : نصیحت کے لیے فَهَلْ : تو کیا مِنْ مُّدَّكِرٍ : ہے کوئی نصیحت پکڑنے والا اور بیشک ہم نے قرآن کو سمجھنے کے لئے آسان کردیا ہے (1) پس کیا کوئی نصیحت حاصل کرنے والا ہے۔
  54,18,كَذَّبَتْ عَادٌ فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ كَذَّبَتْ : جھٹلایا عَادٌ : عاد نے فَكَيْفَ : تو کس طرح كَانَ عَذَابِيْ : تھا عذاب میرا وَنُذُرِ : اور ڈراوے میرے قوم عاد نے بھی جھٹلایا پس کیسا ہوا میرا عذاب اور میری ڈرانے والی باتیں۔
  54,19,اِنَّاۤ اَرْسَلْنَا عَلَیْهِمْ رِیْحًا صَرْصَرًا فِیْ یَوْمِ نَحْسٍ مُّسْتَمِرٍّۙ اِنَّآ : بیشک ہم نے اَرْسَلْنَا : بھیجا ہم نے عَلَيْهِمْ : ان پر رِيْحًا : ایک ہوا کو صَرْصَرًا : تند۔ تیز فِيْ يَوْمِ نَحْسٍ : نحوست کے ایک دن مُّسْتَمِرٍّ : مستقل۔ مسلسل ہم نے ان پر تیز و تند مسلسل چلنے والی ہوا، ایک منحوس دن میں بھیج دی (1)
  54,20,تَنْزِعُ النَّاسَ١ۙ كَاَنَّهُمْ اَعْجَازُ نَخْلٍ مُّنْقَعِرٍ تَنْزِعُ النَّاسَ ۙ : اکھاڑ کر پھینک رہی تھی لوگوں کو كَاَنَّهُمْ : گویا کہ وہ اَعْجَازُ نَخْلٍ : تنے تھے کھجور کے مُّنْقَعِرٍ : جڑے سے کٹے ہوئے۔ جڑے سے اکھڑے ہوئے جو لوگوں کو اٹھا اٹھا کر دے پٹختی تھی، گویا کہ وہ جڑ سے کٹے ہوئے کھجور کے تنے ہیں۔
  54,21,فَكَیْفَ كَانَ عَذَابِیْ وَ نُذُرِ فَكَيْفَ : تو کس طرح كَانَ عَذَابِيْ : تھا میرا عذاب وَنُذُرِ : ڈرانا میرا۔ ڈراوے میرے پس کیسی رہی میری سزا اور میرا ڈرانا۔
  54,22,وَ لَقَدْ یَسَّرْنَا الْقُرْاٰنَ لِلذِّكْرِ فَهَلْ مِنْ مُّدَّكِرٍ۠    ۧ وَلَقَدْ : اور البتہ تحقیق يَسَّرْنَا الْقُرْاٰنَ : آسان کردیا ہم نے قرآن کو لِلذِّكْرِ : نصیحت کے لیے فَهَلْ مِنْ : تو کیا مُّدَّكِرٍ : ہے کوئی نصیحت پکڑنے والا یقیناً ہم نے قرآن کو نصیحت کے لئے آسان کردیا ہے، پس کیا ہے کوئی نصیحت حاصل کرنے والا۔
  54,23,كَذَّبَتْ ثَمُوْدُ بِالنُّذُرِ كَذَّبَتْ : جھٹلایا ثَمُوْدُ بالنُّذُرِ : ثمود نے ڈراووں کو۔ تنبیہات کو قوم ثمود نے ڈرانے والوں کو جھٹلایا۔
  54,24,فَقَالُوْۤا اَبَشَرًا مِّنَّا وَاحِدًا نَّتَّبِعُهٗۤ١ۙ اِنَّاۤ اِذًا لَّفِیْ ضَلٰلٍ وَّ سُعُرٍ فَقَالُوْٓا : تو انہوں نے کہا اَبَشَرًا مِّنَّا : کیا ایک انسان ہے ہم میں سے وَاحِدًا : ایک ہی نَّتَّبِعُهٗٓ ۙ : ہم پیروی کریں اس کی اِنَّآ اِذًا : بیشک ہم تب لَّفِيْ ضَلٰلٍ : البتہ گمراہی میں ہوں گے وَّسُعُرٍ : اور جنون میں اور کہنے لگے کیا ہم ایک شخص کی فرمانبرداری کرنے لگیں گے ؟ تب تم یقیناً غلطی اور دیوانگی میں پڑے ہوئے ہونگے (1)
  54,25,ءَاُلْقِیَ الذِّكْرُ عَلَیْهِ مِنْۢ بَیْنِنَا بَلْ هُوَ كَذَّابٌ اَشِرٌ ءَاُلْقِيَ : کیا ڈالا گیا الذِّكْرُ : ذکر۔ نصیحت عَلَيْهِ : اس پر مِنْۢ بَيْنِنَا : ہمارے درمیان سے بَلْ هُوَ كَذَّابٌ : بلکہ وہ سخت جھوٹا ہے اَشِرٌ : اترانے والا کیا ہمارے سب کے درمیان صرف اسی پر وحی اتاری گئی ؟ نہیں بلکہ وہ جھوٹا شیخی خور ہے (1)
  54,26,سَیَعْلَمُوْنَ غَدًا مَّنِ الْكَذَّابُ الْاَشِرُ سَيَعْلَمُوْنَ : عنقریب وہ جان لیں گے غَدًا : کل مَّنِ الْكَذَّابُ : کون جھوٹا ہے الْاَشِرُ : اترانے والا ہے اب سب جان لیں گے کل کو کہ کون جھوٹا اور شیخی خور تھا ؟ (1)
  54,27,اِنَّا مُرْسِلُوا النَّاقَةِ فِتْنَةً لَّهُمْ فَارْتَقِبْهُمْ وَ اصْطَبِرْ٘ اِنَّا مُرْسِلُوا : بیشک ہم بھیجنے والے ہیں النَّاقَةِ : اونٹنی کو فِتْنَةً لَّهُمْ : آزمائش کے طور پر ان کے لیے فَارْتَقِبْهُمْ : پس انتظار کرو ان کا وَاصْطَبِرْ : اور صبر کرو بیشک ہم ان کی آزمائش کے لئے اونٹنی بھیجیں گے (1) پس (اے صالح) تو ان کا منتظر رہ اور صبر کر۔
