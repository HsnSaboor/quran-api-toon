quran[50]{c,v,t}:
77,1,وَ الْمُرْسَلٰتِ عُرْفًاۙ وَالْمُرْسَلٰتِ : ہواؤں کی قسم عُرْفًا : دل کو خوش کرنیوالی دل خوش کن چلتی ہوئی ہواؤں کی قسم (1)
77,2,فَالْعٰصِفٰتِ عَصْفًاۙ فَالْعٰصِفٰتِ : پھر تند وتیز چلنے والی ہواؤں کی قسم عَصْفًا : شدت سے پھر زور سے جھونکا دینے والیوں کی قسم (1)
77,3,وَّ النّٰشِرٰتِ نَشْرًاۙ وَّالنّٰشِرٰتِ : بادل اٹھا کر لانیوالی ہواؤں کی قسم نَشْرًا : پھیلانے والی پھر (ابر کو) ابھار کر پراگندہ کرنے والیوں (1) کی قسم۔
77,4,فَالْفٰرِقٰتِ فَرْقًاۙ فَالْفٰرِقٰتِ : پھر پھاڑنیوالی ہواؤں کی قسم فَرْقًا : بانٹ کر پھر حق اور باطل کو جدا جدا کردینے والے (1)
77,5,فَالْمُلْقِیٰتِ ذِكْرًاۙ فَالْمُلْقِيٰتِ : پھر الٹا کرنے والے فرشتوں کی قسم ذِكْرًا : ذکر (وحی) اور وحی لانے والے فرشتوں کی قسم۔ (1)
77,6,عُذْرًا اَوْ نُذْرًاۙ عُذْرًا : حجت تمام کرنے کو اَوْ : یا نُذْرًا : ڈرانے کو جو (وحی) الزام اتارنے یا آگاہ کردینے والی ہوتی ہے (1)
77,7,اِنَّمَا تُوْعَدُوْنَ لَوَاقِعٌؕ اِنَّمَا : بیشک جو تُوْعَدُوْنَ : تمہیں وعدہ دیاجاتا ہے لَوَاقِعٌ : ضرور ہونے والا جس چیز کا تم سے وعدہ کیا جاتا ہے یقیناً ہونے والی ہے (1)۔
77,8,فَاِذَا النُّجُوْمُ طُمِسَتْۙ فَاِذَا : پس جب النُّجُوْمُ : ستارے طُمِسَتْ : مٹائے جائیں (بےنور ہوجائیں) پس جب ستارے بےنور کردیئے جائیں گے (1)
77,9,وَ اِذَا السَّمَآءُ فُرِجَتْۙ وَاِذَا السَّمَآءُ : اور جب آسمان فُرِجَتْ : پھٹ جائے اور جب آسمان توڑ پھوڑ دیا جائے گا۔
77,10,وَ اِذَا الْجِبَالُ نُسِفَتْۙ وَاِذَا الْجِبَالُ : اور جب پہاڑ نُسِفَتْ : اڑتے پھریں اور جب پہاڑ ٹکڑے ٹکڑے کرکے اڑا دیئے جائیں گے۔ (1)
77,11,وَ اِذَا الرُّسُلُ اُقِّتَتْؕ وَاِذَا : اور جب الرُّسُلُ : رسول (جمع) اُقِّتَتْ : وقت پر جمع کئے جائیں اور جب رسولوں کو وقت مقررہ پر لایا جائے گا۔ (1)
77,12,لِاَیِّ یَوْمٍ اُجِّلَتْؕ لِاَيِّ يَوْمٍ : کس دن کے لئے اُجِّلَتْ : ملتوی رکھا گیا ہے کس دن کے لئے (ان سب کو) مؤخر کیا گیا (1)
77,13,لِیَوْمِ الْفَصْلِۚ لِيَوْمِ : دن کیلئے الْفَصْلِ : فیصلے فیصلے کے دن کے لئے۔ (1)
77,14,وَ مَاۤ اَدْرٰىكَ مَا یَوْمُ الْفَصْلِؕ وَمَآ اَدْرٰىكَ : اور تم کیا سمجھے مَا : کیا ہے يَوْمُ الْفَصْلِ : فیصلے کا دن تجھے کیا معلوم کہ فیصلے کا دن کیا ہے ؟
77,15,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کی خرابی ہے۔ (1)
77,16,اَلَمْ نُهْلِكِ الْاَوَّلِیْنَؕ اَلَمْ : کیا نہیں نُهْلِكِ : ہم نے ہلاک کیا الْاَوَّلِيْنَ : پہلے لوگوں کو کیا ہم نے اگلوں کو ہلاک نہیں کیا ؟
77,17,ثُمَّ نُتْبِعُهُمُ الْاٰخِرِیْنَ ثُمَّ : پھر نُتْبِعُهُمُ : ہم انکے پیچھے چلاتے ہیں الْاٰخِرِيْنَ : پچھلوں کو پھر ہم ان کے بعد پچھلوں کو لائے (1)
77,18,كَذٰلِكَ نَفْعَلُ بِالْمُجْرِمِیْنَ كَذٰلِكَ : اسی طرح نَفْعَلُ : ہم کرتے ہیں بِالْمُجْرِمِيْنَ : مجرموں کے ساتھ ہم گنہگاروں کے ساتھ اسی طرح کرتے ہیں (1)
77,19,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کے لئے (افسوس) ہے۔
77,20,اَلَمْ نَخْلُقْكُّمْ مِّنْ مَّآءٍ مَّهِیْنٍۙ اَلَمْ نَخْلُقْكُّمْ : کیا ہم نے نہیں پیدا کیا تمہیں مِّنْ : سے مَّآءٍ : پانی مَّهِيْنٍ : حقیر کیا ہم نے تمہیں حقیر پانی سے (منی سے) پیدا نہیں کیا۔
77,21,فَجَعَلْنٰهُ فِیْ قَرَارٍ مَّكِیْنٍۙ فَجَعَلْنٰهُ : پھر ہم نے اسے رکھا فِيْ : میں قَرَارٍ مَّكِيْنٍ : ایک محفوظ جگہ پھر ہم نے اسے مضبوظ و محفوظ جگہ میں رکھا (1)
77,22,اِلٰى قَدَرٍ مَّعْلُوْمٍۙ اِلٰى : تک قَدَرٍ مَّعْلُوْمٍ : وقت معین ایک مقررہ وقت تک۔
77,23,فَقَدَرْنَا١ۖۗ فَنِعْمَ الْقٰدِرُوْنَ فَقَدَرْنَا ڰ : پھر ہم نے اندازہ کیا فَنِعْمَ : تو کیسا اچھا الْقٰدِرُوْنَ : اندازہ کرنے والے پھر ہم نے اندازہ کیا (1) اور ہم کیا خوب اندازہ کرنے والے ہیں
77,24,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کے لئے خرابی ہے۔
77,25,اَلَمْ نَجْعَلِ الْاَرْضَ كِفَاتًاۙ اَلَمْ نَجْعَلِ : کیا ہم نے نہیں بنایا الْاَرْضَ : زمین کو كِفَاتًا : سمیٹنے والی کیا ہم نے زمین کو سمیٹنے والی نہیں بنایا ؟
77,26,اَحْیَآءً وَّ اَمْوَاتًاۙ اَحْيَآءً ‎ : زندوں کو وَّاَمْوَاتًا : اور مردوں کو زندوں کو بھی اور مردوں کو بھی (1)
77,27,وَّ جَعَلْنَا فِیْهَا رَوَاسِیَ شٰمِخٰتٍ وَّ اَسْقَیْنٰكُمْ مَّآءً فُرَاتًاؕ وَّجَعَلْنَا : اور ہم نے رکھے فِيْهَا : اس میں رَوَاسِيَ : پہاڑ (جمع) شٰمِخٰتٍ : اونچے اونچے وَّاَسْقَيْنٰكُمْ : اور ہم نے پلایا تمہیں مَّآءً : پانی فُرَاتًا : میٹھا اور ہم نے اس میں بلند اور بھاری پہاڑ بنا دیئے اور تمہیں سیراب کرنے والا میٹھا پانی پلایا۔
77,28,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھوٹ جاننے والوں کے لئے وائے اور افسوس ہے۔
77,29,اِنْطَلِقُوْۤا اِلٰى مَا كُنْتُمْ بِهٖ تُكَذِّبُوْنَۚ اِنْطَلِقُوْٓا : تو تم چلو اِلٰى : طرف مَا كُنْتُمْ بِهٖ : جس کو تم تھے تُكَذِّبُوْنَ : تم جھٹلاتے اس دوزخ کی طرف جاؤ جسے تم جھٹلاتے رہے تھے (1)
77,30,اِنْطَلِقُوْۤا اِلٰى ظِلٍّ ذِیْ ثَلٰثِ شُعَبٍۙ اِنْطَلِقُوْٓا : تم چلو اِلٰى ظِلٍّ : سایہ کی طرف ذِيْ : والا ثَلٰثِ شُعَبٍ : تین شاخیں چلو تین شاخوں والے تنے کی طرف (1)
77,31,لَّا ظَلِیْلٍ وَّ لَا یُغْنِیْ مِنَ اللَّهَبِؕ لَّا ظَلِيْلٍ : نہ گہرا سایہ وَّلَا يُغْنِيْ : اور نہ وہ بچائے مِنَ اللَّهَبِ : شعلہ (تپش) سے جو دراصل نہ سایہ دینے والا ہے نہ شعلے سے بچا سکتا ہے۔
77,32,اِنَّهَا تَرْمِیْ بِشَرَرٍ كَالْقَصْرِۚ اِنَّهَا : بیشک وہ تَرْمِيْ : پھینکتی ہے بِشَرَرٍ : شعلے كَالْقَصْرِ : محل جیسے یقیناً دوزخ چنگاریاں پھینکتی ہے جو مثل محل کے ہیں (1)
77,33,كَاَنَّهٗ جِمٰلَتٌ صُفْرٌؕ كَاَنَّهٗ : گویا کہ جِمٰلَتٌ صُفْرٌ : اونٹ (جمع) زرد گویا کہ وہ زرد اونٹ ہیں (1)۔
77,34,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے آج ان جھٹلانے والوں کی درگت ہے۔
77,35,هٰذَا یَوْمُ لَا یَنْطِقُوْنَۙ هٰذَا يَوْمُ : اس دن لَا يَنْطِقُوْنَ : وہ نہ بول سکیں گے آج (کا دن) وہ دن ہے کہ یہ بول بھی نہ سکیں گے (1)
77,36,وَ لَا یُؤْذَنُ لَهُمْ فَیَعْتَذِرُوْنَ وَلَا : اور نہ يُؤْذَنُ : اجازت دی جائیگی لَهُمْ : انہیں فَيَعْتَذِرُوْنَ : کہ وہ عذر خواہی کریں نہ انہیں معذرت کی اجازت دی جائے گی۔ (1)
77,37,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کی خرابی ہے۔
77,38,هٰذَا یَوْمُ الْفَصْلِ١ۚ جَمَعْنٰكُمْ وَ الْاَوَّلِیْنَ هٰذَا : یہ يَوْمُ الْفَصْلِ ۚ : فیصلے کا دن جَمَعْنٰكُمْ : ہم نے جمع کیا تمہیں وَالْاَوَّلِيْنَ : اور پہلے لوگوں کو یہ ہے فیصلہ کا دن ہم نے تمہیں اور اگلوں کو سب کو جمع کرلیا (1)
77,39,فَاِنْ كَانَ لَكُمْ كَیْدٌ فَكِیْدُوْنِ فَاِنْ : پھر اگر كَانَ : ہے لَكُمْ : تمہارے پاس كَيْدٌ : کوئی داؤ فَكِيْدُوْنِ : تو تم مجھ پر داؤ کرلو پس اگر تم مجھ سے کوئی چال چل سکتے ہو تو چل لو (1)
77,40,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ۠    ۧ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے وائے ہے اس دن جھٹلانے والوں کے لئے۔
77,41,اِنَّ الْمُتَّقِیْنَ فِیْ ظِلٰلٍ وَّ عُیُوْنٍۙ اِنَّ : بیشک الْمُتَّقِيْنَ : پرہیزگار (جمع) فِيْ ظِلٰلٍ : سایوں میں وَّعُيُوْنٍ : اور چشموں بیشک پرہیزگار لوگ سایوں میں ہیں (1) اور بہتے چشموں میں۔
77,42,وَّ فَوَاكِهَ مِمَّا یَشْتَهُوْنَؕ وَّفَوَاكِهَ : اور میوے مِمَّا : اس (قسم کے) جو يَشْتَهُوْنَ : وہ چاہیں گے اور ان میووں میں جن کی وہ خواہش کریں (1)
77,43,كُلُوْا وَ اشْرَبُوْا هَنِیْٓئًۢا بِمَا كُنْتُمْ تَعْمَلُوْنَ كُلُوْا : تم کھاؤ وَاشْرَبُوْا : اور تم پیو هَنِيْٓئًۢا : مزے سے بِمَا : اس کے بدلے جو كُنْتُمْ تَعْمَلُوْنَ : تم کرتے تھے (اے جنتیو !) کھاؤ پیو مزے سے اپنے کئے ہوئے اعمال کے بدلے۔
77,44,اِنَّا كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ اِنَّا : بیشک ہم كَذٰلِكَ : اسی طرح نَجْزِي : جزاد یتے ہیں الْمُحْسِنِيْنَ : نیکو کاروں کو یقیناً ہم نیکی کرنے والوں کو اسی طرح جزا دیتے ہیں۔ (1)
77,45,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن سچا نہ جاننے والوں کے لئے (افسوس) ہے (1)
77,46,كُلُوْا وَ تَمَتَّعُوْا قَلِیْلًا اِنَّكُمْ مُّجْرِمُوْنَ كُلُوْا : تم کھاؤ وَتَمَتَّعُوْا : اور تم فائدہ اٹھالو قَلِيْلًا : تھوڑا اِنَّكُمْ : بیشک تم مُّجْرِمُوْنَ : مجرم (جمع) (اے جھٹلانے والو) تم دنیا میں تھوڑا سا کھالو اور فائدہ اٹھالو بیشک تم گنہگار ہو (1)
77,47,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کے لئے سخت ہلاکت ہے۔
77,48,وَ اِذَا قِیْلَ لَهُمُ ارْكَعُوْا لَا یَرْكَعُوْنَ وَاِذَا : اور جب قِيْلَ : کہا جائے لَهُمُ : ان سے ارْكَعُوْا : تم رکوع کرو لَا يَرْكَعُوْنَ : وہ رکوع نہیں کرتے ان سے جب کہا جاتا ہے کہ رکوع کرلو تو نہیں کرتے (1)
77,49,وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ وَيْلٌ : خرابی ہے يَّوْمَئِذٍ : اس دن لِّلْمُكَذِّبِيْنَ : جھٹلانے والوں کیلئے اس دن جھٹلانے والوں کی تباہی ہے۔ (1)
77,50,فَبِاَیِّ حَدِیْثٍۭ بَعْدَهٗ یُؤْمِنُوْنَ۠    ۧ فَبِاَيِّ : تو کونسی حَدِيْثٍۢ : بات بَعْدَهٗ : اس کے بعد يُؤْمِنُوْنَ : وہ ایمان لائیں گے اب اس قرآن کے بعد کس بات پر ایمان لائیں گے (1)
