tafsir[13]{c,v,t}:
  42,32,وَ مِنْ اٰیٰتِهِ الْجَوَارِ فِی الْبَحْرِ كَالْاَعْلَامِؕ وَمِنْ اٰيٰتِهِ : اور اس کی نشانیوں میں سے ہیں الْجَوَارِ : کشتیاں فِي الْبَحْرِ : سمندر میں كَالْاَعْلَامِ : پہاڑوں کی طرح اور دریا میں چلنے والی پہاڑوں جیسی کشتیاں اس کی نشانیوں میں سے ہیں (1)
  42,33,اِنْ یَّشَاْ یُسْكِنِ الرِّیْحَ فَیَظْلَلْنَ رَوَاكِدَ عَلٰى ظَهْرِهٖ١ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّكُلِّ صَبَّارٍ شَكُوْرٍۙ اِنْ يَّشَاْ : اگر وہ چاہے يُسْكِنِ الرِّيْحَ : تھما دے ہوا کو فَيَظْلَلْنَ : تو وہ ہوجائیں۔ رہ جائیں رَوَاكِدَ : تھمی ہوئی عَلٰي ظَهْرِهٖ : اس کی پشت پر اِنَّ فِيْ ذٰلِكَ : یقینا اس میں لَاٰيٰتٍ : البتہ نشانیاں ہیں لِّكُلِّ : واسطے ہر صَبَّارٍ : بہت صبر کرنے والے شَكُوْرٍ : بہت شکرگزار کے لیے اگر وہ چاہے تو ہوا بند کر دے اور یہ کشتیاں سمندروں پر رکی رہ جائیں۔ یقیناً اس میں ہر صبر کرنے والے شکر گزار کے لئے نشانیاں ہیں۔
  42,34,اَوْ یُوْبِقْهُنَّ بِمَا كَسَبُوْا وَ یَعْفُ عَنْ كَثِیْرٍ٘ اَوْ يُوْبِقْهُنَّ : یا ہلاک کردے ان کو بِمَا كَسَبُوْا : بوجہ اس کے جو انہوں نے کمائی کی وَيَعْفُ : اور وہ معاف کردیتا ہے۔ درگزر کرتا ہے عَنْ كَثِيْرٍ : بہت سی چیزوں سے یا انہیں ان کے کرتوتوں کے باعث تباہ کر دے (1) وہ تو بہت سی خطاؤں سے درگزر فرمایا کرتا ہے (2)۔
  42,35,وَّ یَعْلَمَ الَّذِیْنَ یُجَادِلُوْنَ فِیْۤ اٰیٰتِنَا١ؕ مَا لَهُمْ مِّنْ مَّحِیْصٍ وَّيَعْلَمَ الَّذِيْنَ : اور جان لیں گے وہ لوگ يُجَادِلُوْنَ : جو جھگڑتے ہیں فِيْٓ اٰيٰتِنَا : ہماری آیات میں ۭ مَا : نہیں لَهُمْ : ان کے لیے مِّنْ مَّحِيْصٍ : کوئی بچنے کی جگہ۔ جائے پناہ اور تاکہ جو لوگ ہماری نشانیوں میں جھگڑتے ہیں (1) وہ معلوم کرلیں کہ ان کے لئے کوئی چھٹکارہ نہیں (1)
  42,36,فَمَاۤ اُوْتِیْتُمْ مِّنْ شَیْءٍ فَمَتَاعُ الْحَیٰوةِ الدُّنْیَا١ۚ وَ مَا عِنْدَ اللّٰهِ خَیْرٌ وَّ اَبْقٰى لِلَّذِیْنَ اٰمَنُوْا وَ عَلٰى رَبِّهِمْ یَتَوَكَّلُوْنَۚ فَمَآ اُوْتِيْتُمْ : پس جو بھی دیے گئے تم مِّنْ شَيْءٍ : کوئی چیز فَمَتَاعُ : تو سامان ہے الْحَيٰوةِ الدُّنْيَا : دنیا کی زندگی کا وَمَا عِنْدَ اللّٰهِ : اور جو اللہ کے پاس ہے خَيْرٌ : بہتر ہے وَّاَبْقٰى : اور زیادہ باقی رہنے والا ہے لِلَّذِيْنَ : ان لوگوں کے لیے اٰمَنُوْا : جو ایمان لائے وَعَلٰي رَبِّهِمْ : اور اپنے رب پر يَتَوَكَّلُوْنَ : وہ توکل کرتے ہیں تو تمہیں جو کچھ دیا گیا وہ زندگانی دنیا کا کچھ یونہی سا اسباب ہے (1) اور اللہ کے پاس جو ہے وہ اس سے بدرجہ بہتر (2) اور پائیدار ہے، وہ ان کے لئے ہے جو ایمان لائے اور صرف اپنے رب ہی پر بھروسہ رکھتے ہیں۔
  42,37,وَ الَّذِیْنَ یَجْتَنِبُوْنَ كَبٰٓئِرَ الْاِثْمِ وَ الْفَوَاحِشَ وَ اِذَا مَا غَضِبُوْا هُمْ یَغْفِرُوْنَۚ وَالَّذِيْنَ : اور وہ لوگ يَجْتَنِبُوْنَ : جو بچتے ہیں۔ اجتناب کرتے ہیں كَبٰٓئِرَ الْاِثْمِ : بڑے گناہوں سے وَالْفَوَاحِشَ : اور بےحیائی کی باتوں سے وَاِذَا مَا غَضِبُوْا : اور جب وہ غضب ناک ہوتے ہیں هُمْ يَغْفِرُوْنَ : تو وہ درگزر کرجاتے ہیں۔ معاف کرجاتے ہیں اور کبیرہ گناہوں سے اور بےحیائیوں سے بچتے ہیں اور غصے کے وقت (بھی) معاف کردیتے ہیں (1)
  42,38,وَ الَّذِیْنَ اسْتَجَابُوْا لِرَبِّهِمْ وَ اَقَامُوا الصَّلٰوةَ١۪ وَ اَمْرُهُمْ شُوْرٰى بَیْنَهُمْ١۪ وَ مِمَّا رَزَقْنٰهُمْ یُنْفِقُوْنَۚ وَالَّذِيْنَ اسْتَجَابُوْا : اور وہ لوگ جو حکم مانتے ہیں لِرَبِّهِمْ : اپنے رب کا وَاَقَامُوا الصَّلٰوةَ : اور قائم کرتے ہیں نماز وَاَمْرُهُمْ : اور ان کے معاملات شُوْرٰى بَيْنَهُمْ : آپس کے مشورے سے ہوتے ہیں وَمِمَّا رَزَقْنٰهُمْ : اور اس میں سے جو رزق دیاہم نے ان کو يُنْفِقُوْنَ : وہ خرچ کرتے ہیں اور اپنے رب کے فرمان کو قبول کرتے ہیں (1) اور نماز کی پابندی کرتے ہیں (2) اور ان کا (ہر) کام آپس کے مشورے سے ہوتا ہے اور جو ہم نے انہیں دے رکھا ہے اس میں سے (ہمارے نام پر) دیتے ہیں۔
  42,39,وَ الَّذِیْنَ اِذَاۤ اَصَابَهُمُ الْبَغْیُ هُمْ یَنْتَصِرُوْنَ وَالَّذِيْنَ : اور وہ لوگ اِذَآ اَصَابَهُمُ : جب پہنچتی ہے ان کو الْبَغْيُ : کوئی زیادتی هُمْ يَنْتَصِرُوْنَ : وہ بدلہ لیتے ہیں اور جب ان پر ظلم (و زیادتی) ہو تو وہ صرف بدلہ لے لیتے ہیں۔
  42,40,وَ جَزٰٓؤُا سَیِّئَةٍ سَیِّئَةٌ مِّثْلُهَا١ۚ فَمَنْ عَفَا وَ اَصْلَحَ فَاَجْرُهٗ عَلَى اللّٰهِ١ؕ اِنَّهٗ لَا یُحِبُّ الظّٰلِمِیْنَ وَجَزٰٓؤُا : اور بدلہ سَيِّئَةٍ : برائی کا سَيِّئَةٌ : برائی ہے مِّثْلُهَا ۚ : اس جیسی فَمَنْ عَفَا : پس جو کوئی درگزر کرجائے وَاَصْلَحَ : اور اصلاح کرے فَاَجْرُهٗ : تو اجر اس کا عَلَي : زمہ ہے اللّٰهِ : اللہ کے اِنَّهٗ : بیشک وہ لَا يُحِبُّ الظّٰلِمِيْنَ : نہیں محبت کرتا ظالموں سے اور برائی کا بدلہ اسی جیسی برائی ہے (1) اور جو معاف کردے اور اصلاح کرلے اس کا اجر اللہ کے ذمے ہے، (فی الواقع) اللہ تعالیٰ ظالموں سے محبت نہیں کرتا۔
  42,41,وَ لَمَنِ انْتَصَرَ بَعْدَ ظُلْمِهٖ فَاُولٰٓئِكَ مَا عَلَیْهِمْ مِّنْ سَبِیْلٍؕ وَلَمَنِ انْتَصَرَ : اور جو کوئی بدلہ لے بَعْدَ : بعد ظُلْمِهٖ : اس کے ظلم کے فَاُولٰٓئِكَ : تو یہی لوگ مَا عَلَيْهِمْ : نہیں ہے ان پر مِّنْ سَبِيْلٍ : کوئی راستہ اور جو شخص اپنے مظلوم ہونے کے بعد (برابر کا) بدلہ لے لے تو ایسے لوگوں پر (الزام) کا کوئی راستہ نہیں۔
  42,42,اِنَّمَا السَّبِیْلُ عَلَى الَّذِیْنَ یَظْلِمُوْنَ النَّاسَ وَ یَبْغُوْنَ فِی الْاَرْضِ بِغَیْرِ الْحَقِّ١ؕ اُولٰٓئِكَ لَهُمْ عَذَابٌ اَلِیْمٌ اِنَّمَا السَّبِيْلُ : بیشک راستہ عَلَي الَّذِيْنَ : ان لوگوں پر ہے يَظْلِمُوْنَ النَّاسَ : جو ظلم کرتے ہیں لوگوں پر وَيَبْغُوْنَ : اور بغاوت کرتے ہیں۔ زیادتی کرتے ہیں فِي الْاَرْضِ : زمین میں بِغَيْرِ الْحَقِّ : ناحق اُولٰٓئِكَ : یہی لوگ لَهُمْ : ان کے لیے عَذَابٌ اَلِيْمٌ : عذاب ہے دردناک یہ راستہ صرف ان لوگوں پر ہے جو خود دوسروں پر ظلم کریں اور زمین میں ناحق فساد کرتے پھریں، یہی لوگ ہیں جن کے لئے دردناک عذاب ہے۔
  42,43,وَ لَمَنْ صَبَرَ وَ غَفَرَ اِنَّ ذٰلِكَ لَمِنْ عَزْمِ الْاُمُوْرِ۠    ۧ وَلَمَنْ : اور البتہ جس نے صَبَرَ : صبر کیا وَغَفَرَ : اور معاف کردیا اِنَّ ذٰلِكَ : بیشک یہ لَمِنْ عَزْمِ الْاُمُوْرِ : البتہ ہمت کے کاموں میں سے ہے اور جو شخص صبر کرلے اور معاف کر دے یقیناً یہ بڑی ہمت کے کاموں میں سے (ایک کام) ہے۔
  42,44,وَ مَنْ یُّضْلِلِ اللّٰهُ فَمَا لَهٗ مِنْ وَّلِیٍّ مِّنْۢ بَعْدِهٖ١ؕ وَ تَرَى الظّٰلِمِیْنَ لَمَّا رَاَوُا الْعَذَابَ یَقُوْلُوْنَ هَلْ اِلٰى مَرَدٍّ مِّنْ سَبِیْلٍۚ وَمَنْ يُّضْلِلِ : اور جس کو بھٹکا دے۔ گمراہ کردے اللّٰهُ : اللہ فَمَا لَهٗ : تو نہیں اس کے لیے مِنْ وَّلِيٍّ : کوئی دوست مِّنْۢ بَعْدِهٖ : اس کے بعد وَتَرَى الظّٰلِمِيْنَ : اور تم دیکھو گے ظالموں کو لَمَّا : جب رَاَوُا الْعَذَابَ : وہ دیکھ لیں گے عذاب يَقُوْلُوْنَ : وہ کہیں گے هَلْ : کیا اِلٰى مَرَدٍّ : لوٹنے کی طرف۔ پلٹنے کی طرف مِّنْ : کوئی سَبِيْلٍ : راستہ ہے اور جسے اللہ تعالیٰ بہکا دے اس کا اس کے بعد کوئی چارہ ساز نہیں، اور تو دیکھے گا کہ ظالم لوگ عذاب کو دیکھ کر کہہ رہے ہوں گے کہ کیا واپس جانے کی کوئی راہ ہے۔
