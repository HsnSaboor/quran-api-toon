tafsir[19]{c,v,t}:
  15,52,اِذْ دَخَلُوْا عَلَیْهِ فَقَالُوْا سَلٰمًا١ؕ قَالَ اِنَّا مِنْكُمْ وَ جِلُوْنَ اِذْ : جب دَخَلُوْا : وہ داخل ہوئے ( آئے) عَلَيْهِ : اس پر (پاس) فَقَالُوْا : تو انہوں نے کہا سَلٰمًا : سلام قَالَ : اس نے کہا اِنَّا : بیشک ہم مِنْكُمْ : تم سے وَجِلُوْنَ : ڈرنے والے (ڈرتے) ہیں کہ جب انہوں نے ان کے پاس آکر سلام کہا تو انہوں نے کہا کہ ہم کو تو ڈر لگتا ہے (1)
  15,53,قَالُوْا لَا تَوْجَلْ اِنَّا نُبَشِّرُكَ بِغُلٰمٍ عَلِیْمٍ قَالُوْا : انہوں نے کہا لَا تَوْجَلْ : ڈرو نہیں اِنَّا نُبَشِّرُكَ : بیشک ہم تمہیں خوشخبری دیتے ہیں بِغُلٰمٍ : ایک لڑکا عَلِيْمٍ : علم والا انہوں نے کہا ڈرو نہیں، ہم تجھے ایک صاحب علم فرزند کی بشارت دیتے ہیں۔
  15,54,قَالَ اَبَشَّرْتُمُوْنِیْ عَلٰۤى اَنْ مَّسَّنِیَ الْكِبَرُ فَبِمَ تُبَشِّرُوْنَ قَالَ : اس نے کہا اَبَشَّرْتُمُوْنِيْ : کیا تم مجھے خوشخبری دیتے ہو عَلٰٓي : پر۔ میں اَنْ : کہ مَّسَّنِيَ : مجھے پہنچ گیا الْكِبَرُ : بڑھاپا فَبِمَ : سو کس بات تُبَشِّرُوْنَ : تم خوشخبری دیتے ہو کہا، کیا اس بڑھاپے کے آجانے کے بعد تم مجھے خوشخبری دیتے ہو ! یہ خوشخبری تم کیسے دے رہے ہو ؟
  15,55,قَالُوْا بَشَّرْنٰكَ بِالْحَقِّ فَلَا تَكُنْ مِّنَ الْقٰنِطِیْنَ قَالُوْا : وہ بولے بَشَّرْنٰكَ : ہم نے تمہیں خوشخبری دی بِالْحَقِّ : سچائی کے ساتھ فَلَا تَكُنْ : آپ نہ ہوں مِّنَ : سے الْقٰنِطِيْنَ : مایوس ہونے والے انہوں نے کہا ہم آپ کو بالکل سچی خوشخبری سناتے ہیں آپ مایوس لوگوں میں شامل نہ ہوں (1)۔
  15,56,قَالَ وَ مَنْ یَّقْنَطُ مِنْ رَّحْمَةِ رَبِّهٖۤ اِلَّا الضَّآلُّوْنَ قَالَ : اس نے کہا وَمَنْ : اور کون يَّقْنَطُ : مایوس ہوگا مِنْ : سے رَّحْمَةِ : رحمت رَبِّهٖٓ : اپنا رب اِلَّا : سوائے الضَّآلُّوْنَ : گمراہ (جمع) کہا اپنے رب تعالیٰ کی رحمت سے ناامید تو صرف گمراہ اور بہکے ہوئے لوگ ہی ہوتے ہیں (1)۔
  15,57,قَالَ فَمَا خَطْبُكُمْ اَیُّهَا الْمُرْسَلُوْنَ قَالَ : اس نے کہا فَمَا خَطْبُكُمْ : پس کیا ہے تمہارا کام (مہم) اَيُّهَا : اے الْمُرْسَلُوْنَ : بھیجے ہوئے (فرشتو) پوچھا کہ اللہ کے بھیجے ہوئے (فرشتو) تمہارا ایسا کیا اہم کام ہے ؟ (1)
  15,58,قَالُوْۤا اِنَّاۤ اُرْسِلْنَاۤ اِلٰى قَوْمٍ مُّجْرِمِیْنَۙ قَالُوْٓا : وہ بولے اِنَّآ : ہم بیشک اُرْسِلْنَآ : بھیجے گئے اِلٰى : طرف قَوْمٍ : ایک قوم مُّجْرِمِيْنَ : مجرم (جمع) انہوں نے جواب دیا کہ ہم مجرم قوم کی طرف بھیجے گئے ہیں۔
  15,59,اِلَّاۤ اٰلَ لُوْطٍ١ؕ اِنَّا لَمُنَجُّوْهُمْ اَجْمَعِیْنَۙ اِلَّآ : سوائے اٰلَ لُوْطٍ : گھر والے لوط کے اِنَّا : ہم لَمُنَجُّوْهُمْ : البتہ ہم انہیں بچا لیں گے اَجْمَعِيْنَ : سب مگر خاندان لوط کہ ہم ان سب کو ضرور بچالیں گے
  15,60,اِلَّا امْرَاَتَهٗ قَدَّرْنَاۤ١ۙ اِنَّهَا لَمِنَ الْغٰبِرِیْنَ۠    ۧ اِلَّا : سوائے امْرَاَتَهٗ : اس کی عورت قَدَّرْنَآ : ہم نے فیصلہ کرلیا ہے اِنَّهَا : بیشک وہ لَمِنَ : سے الْغٰبِرِيْنَ : پیچھے رہ جانے والے سوائے اس (لوط) کی بیوی کے کہ ہم نے اسے رکنے اور باقی رہ جانے والوں میں مقرر کردیا ہے۔
  15,61,فَلَمَّا جَآءَ اٰلَ لُوْطِ اِ۟لْمُرْسَلُوْنَۙ فَلَمَّا : پس جب جَآءَ : آئے اٰلَ لُوْطِ : لوط کے گھر والے الْمُرْسَلُوْنَ : بھیجے ہوئے (فرشتے) جب بھیجے ہوئے فرشتے آل لوط کے پاس پہنچے۔
  15,62,قَالَ اِنَّكُمْ قَوْمٌ مُّنْكَرُوْنَ قَالَ : س نے کہا اِنَّكُمْ : بیشک تم قَوْمٌ : لوگ مُّنْكَرُوْنَ : اوپرے (نا آشنا) تو انہوں (لوط علیہ السلام) نے کہا تم لوگ تو کچھ انجان سے معلوم ہو رہے ہو (1)۔
  15,63,قَالُوْا بَلْ جِئْنٰكَ بِمَا كَانُوْا فِیْهِ یَمْتَرُوْنَ قَالُوْا : وہ بولے بَلْ : بلکہ جِئْنٰكَ : ہم آئے ہیں تمہارے پاس بِمَا : اس کے ساتھ جو كَانُوْا : وہ تھے فِيْهِ : اس میں يَمْتَرُوْنَ : شک کرتے انہوں نے کہا نہیں بلکہ ہم تیرے پاس وہ چیز لائے ہیں جس میں یہ لوگ شک شبہ کر رہے تھے (1)۔
  15,64,وَ اَتَیْنٰكَ بِالْحَقِّ وَ اِنَّا لَصٰدِقُوْنَ وَاَتَيْنٰكَ : اور ہم تمہارے پاس آئے ہیں بِالْحَقِّ : حق کے ساتھ وَاِنَّا : اور ہم بیشک لَصٰدِقُوْنَ : البتہ سچے ہم تیرے پاس (صریح) حق لائے ہیں اور ہیں بھی بالکل سچے (1)۔
  15,65,فَاَسْرِ بِاَهْلِكَ بِقِطْعٍ مِّنَ الَّیْلِ وَ اتَّبِعْ اَدْبَارَهُمْ وَ لَا یَلْتَفِتْ مِنْكُمْ اَحَدٌ وَّ امْضُوْا حَیْثُ تُؤْمَرُوْنَ فَاَسْرِ : پس لے نکلیں آپ بِاَهْلِكَ : اپنے گھر والوں کو بِقِطْعٍ : ایک حصہ مِّنَ : سے الَّيْلِ : رات وَاتَّبِعْ : اور خود چلیں اَدْبَارَهُمْ : ان کے پیچھے وَلَا : اور نہ يَلْتَفِتْ : پیچھے مڑ کر دیکھے مِنْكُمْ : تم میں سے اَحَدٌ : کوئی وَّامْضُوْا : اور چلے جاؤ حَيْثُ : جیسے تُؤْمَرُوْنَ : تمہیں حکم دیا گیا اب تو اپنے خاندان سمیت اس رات کے کسی حصہ میں چل دے اور آپ ان کے پیچھے رہنا (1) اور (خبردار) تم میں سے (پیچھے) مڑ کر بھی نہ دیکھے اور جہاں کا تمہیں حکم کیا جا رہا ہے وہاں چلے جانا۔
  15,66,وَ قَضَیْنَاۤ اِلَیْهِ ذٰلِكَ الْاَمْرَ اَنَّ دَابِرَ هٰۤؤُلَآءِ مَقْطُوْعٌ مُّصْبِحِیْنَ وَقَضَيْنَآ : اور ہم نے فیصلہ بھیجا اِلَيْهِ : اس کی طرف ذٰلِكَ : اس الْاَمْرَ : بات اَنَّ : کہ دَابِرَ : جڑ هٰٓؤُلَآءِ : یہ لوگ مَقْطُوْعٌ : کٹی ہوئی مُّصْبِحِيْنَ : صبح ہوتے ہم نے اس کی طرف اس بات کا فیصلہ کردیا کہ صبح ہوتے ہوتے ان لوگوں کی جڑیں کاٹ دیجائیں گی (1)۔
  15,67,وَ جَآءَ اَهْلُ الْمَدِیْنَةِ یَسْتَبْشِرُوْنَ وَجَآءَ : اور آئے اَهْلُ الْمَدِيْنَةِ : شہر والے يَسْتَبْشِرُوْنَ : خوشیاں مناتے اور شہر والے خوشیاں مناتے ہوئے آئے (1)۔
  15,68,قَالَ اِنَّ هٰۤؤُلَآءِ ضَیْفِیْ فَلَا تَفْضَحُوْنِۙ قَالَ : اس نے کہا اِنَّ : کہ هٰٓؤُلَآءِ : یہ لوگ ضَيْفِيْ : میرے مہمان فَلَا تَفْضَحُوْنِ : پس مجھے رسوا نہ کرو تم (لوط ؑ نے) کہا یہ لوگ میرے مہمان ہیں تم مجھے رسوا نہ کرو (1)۔
  15,69,وَ اتَّقُوا اللّٰهَ وَ لَا تُخْزُوْنِ وَاتَّقُوا : اور ڈرو اللّٰهَ : اللہ وَلَا تُخْزُوْنِ : اور مجھے خوار نہ کرو اللہ تعالیٰ سے ڈرو اور مجھے رسوا نہ کرو۔
  15,70,قَالُوْۤا اَوَ لَمْ نَنْهَكَ عَنِ الْعٰلَمِیْنَ قَالُوْٓا : وہ بولے اَوَ : کیا لَمْ نَنْهَكَ : ہم نے تجھے منع نہیں کیا عَنِ : سے الْعٰلَمِيْنَ : سارے جہان وہ بولے کیا ہم نے تجھے دنیا بھر (کی ٹھیکیداری) سے منع نہیں کر رکھا ؟ (1)۔
