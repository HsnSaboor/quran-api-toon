tafsir[17]{c,v,t}:
  23,43,مَا تَسْبِقُ مِنْ اُمَّةٍ اَجَلَهَا وَ مَا یَسْتَاْخِرُوْنَؕ مَا تَسْبِقُ : نہیں سبقت کرتی ہے مِنْ اُمَّةٍ : کوئی امت اَجَلَهَا : اپنی میعاد وَمَا : اور نہ يَسْتَاْخِرُوْنَ : پیچھے رہ جاتی ہے نہ تو کوئی امت اپنے وقت مقرہ سے آگے بڑھی اور نہ پیچھے رہی 1
  23,44,ثُمَّ اَرْسَلْنَا رُسُلَنَا تَتْرَا١ؕ كُلَّمَا جَآءَ اُمَّةً رَّسُوْلُهَا كَذَّبُوْهُ فَاَتْبَعْنَا بَعْضَهُمْ بَعْضًا وَّ جَعَلْنٰهُمْ اَحَادِیْثَ١ۚ فَبُعْدًا لِّقَوْمٍ لَّا یُؤْمِنُوْنَ ثُمَّ : پھر اَرْسَلْنَا : ہم نے بھیجے رُسُلَنَا : رسول (جمع) تَتْرَا : پے در پے كُلَّمَا : جب بھی جَآءَ : آیا اُمَّةً : کسی امت میں رَّسُوْلُهَا : اس کا رسول كَذَّبُوْهُ : انہوں نے اسے جھٹلایا فَاَتْبَعْنَا : تو ہم پیچھے لائے بَعْضَهُمْ : ان میں سے ایک بَعْضًا : دوسرے وَّجَعَلْنٰهُمْ : اور انہیں بنادیا ہم نے اَحَادِيْثَ : افسانے فَبُعْدًا : سو دوری (مار) لِّقَوْمٍ : لوگوں کے لیے لَّا يُؤْمِنُوْنَ : جو ایمان نہیں لائے پھر ہم نے لگاتار رسول بھیجے 1 جب جب جس امت کے پاس اس کا رسول آیا اس نے جھٹلایا، پس ہم نے ایک کو دوسرے کے پیچھے لگا دیا 2 اور انھیں افسانہ 3 بنادیا۔ ان لوگوں کو دوری ہے جو ایمان قبول نہیں کرتے۔
  23,45,ثُمَّ اَرْسَلْنَا مُوْسٰى وَ اَخَاهُ هٰرُوْنَ١ۙ۬ بِاٰیٰتِنَا وَ سُلْطٰنٍ مُّبِیْنٍۙ ثُمَّ : پھر اَرْسَلْنَا : ہم نے بھیجا مُوْسٰى : موسیٰ وَاَخَاهُ : اور ان کا بھائی هٰرُوْنَ : ہارون بِاٰيٰتِنَا : ساتھ (ہماری) اپنی نشانیاں وَ سُلْطٰنٍ : اور دلائل مُّبِيْنٍ : کھلے پھر ہم نے موسیٰ ؑ کو اور اس کے بھائی ہارون ؑ کو اپنی آیتوں اور کھلی دلیل 1 کے ساتھ بھیجا۔
  23,46,اِلٰى فِرْعَوْنَ وَ مَلَاۡئِهٖ فَاسْتَكْبَرُوْا وَ كَانُوْا قَوْمًا عَالِیْنَۚ اِلٰى : طرف فِرْعَوْنَ : فرعون وَمَلَا۟ئِهٖ : اور اس کے سردار فَاسْتَكْبَرُوْا : تو انہوں نے تکبر کیا وَكَانُوْا : اور وہ تھے قَوْمًا : لوگ عَالِيْنَ : سرکش فرعون اور اس کے لشکروں کی طرف، پس انہوں نے تکبر کیا اور تھے ہی وہ سرکش لوگ 1۔
  23,47,فَقَالُوْۤا اَنُؤْمِنُ لِبَشَرَیْنِ مِثْلِنَا وَ قَوْمُهُمَا لَنَا عٰبِدُوْنَۚ فَقَالُوْٓا : پس انہوں نے کہا اَنُؤْمِنُ : کیا ہم ایمان لے آئیں لِبَشَرَيْنِ : دو آدمیوں پر مِثْلِنَا : اپنے جیسا وَقَوْمُهُمَا : اور ان کی قوم لَنَا : ہماری عٰبِدُوْنَ : بندگی (خدمت) کرنے والے کہنے لگے کہ کیا ہم اپنے جیسے دو شخصوں پر ایمان لائیں ؟ حالانکہ خود ان کی قوم (بھی) ہمارے ماتحت 1 ہے۔
  23,48,فَكَذَّبُوْهُمَا فَكَانُوْا مِنَ الْمُهْلَكِیْنَ فَكَذَّبُوْهُمَا : پس انہوں نے جھٹلایا دونوں کو فَكَانُوْا : تو وہ ہوگئے مِنَ : سے الْمُهْلَكِيْنَ : ہلاک ہونے والے پس انہوں نے دونوں کو جھٹلایا آخر وہ بھی ہلاک شدہ لوگوں میں مل گئے۔
  23,49,وَ لَقَدْ اٰتَیْنَا مُوْسَى الْكِتٰبَ لَعَلَّهُمْ یَهْتَدُوْنَ وَلَقَدْ : اور تحقیق اٰتَيْنَا : ہم نے دی مُوْسَى : موسیٰ الْكِتٰبَ : کتب لَعَلَّهُمْ : تاکہ وہ لوگ يَهْتَدُوْنَ : ہدایت پالیں ہم نے موسیٰ ؑ کو کتاب (بھی) دی کہ لوگ راہ راست پر آجائیں 1۔
  23,50,وَ جَعَلْنَا ابْنَ مَرْیَمَ وَ اُمَّهٗۤ اٰیَةً وَّ اٰوَیْنٰهُمَاۤ اِلٰى رَبْوَةٍ ذَاتِ قَرَارٍ وَّ مَعِیْنٍ۠    ۧ وَجَعَلْنَا : اور ہم نے بنایا ابْنَ مَرْيَمَ : مریم کے بیٹے (عیسی) کو وَاُمَّهٗٓ : اور ان کی ماں اٰيَةً : ایک نشانی وَّاٰوَيْنٰهُمَآ : اور ہم نے انہیں ٹھکانہ دیا اِلٰى : طرف رَبْوَةٍ : ایک بلند ٹیلہ ذَاتِ قَرَارٍ : ٹھہرنے کا مقام وَّمَعِيْنٍ : اور جاری پانی ہم نے ابن مریم اور اس کی والدہ کو ایک نشانی بنایا 1 اور ان دونوں کو بلند صاف قرار والی اور جاری پانی 2 والی جگہ میں پناہ دی۔
  23,51,یٰۤاَیُّهَا الرُّسُلُ كُلُوْا مِنَ الطَّیِّبٰتِ وَ اعْمَلُوْا صَالِحًا١ؕ اِنِّیْ بِمَا تَعْمَلُوْنَ عَلِیْمٌؕ يٰٓاَيُّهَا : اے الرُّسُلُ : رسول (جمع) كُلُوْا : کھاؤ مِنَ : سے الطَّيِّبٰتِ : پاکیزہ چیزیں وَاعْمَلُوْا : اور عمل کرو صَالِحًا : نیک اِنِّىْ : بیشک میں بِمَا : اسے جو تَعْمَلُوْنَ : تم کرتے ہو عَلِيْمٌ : جاننے والا اے پیغمبر ! حلال چیزیں کھاؤ اور نیک عمل کرو 1 تم جو کچھ کر رہے ہو اس سے میں بخوبی واقف ہوں۔
  23,52,وَ اِنَّ هٰذِهٖۤ اُمَّتُكُمْ اُمَّةً وَّاحِدَةً وَّ اَنَا رَبُّكُمْ فَاتَّقُوْنِ وَاِنَّ : اور بیشک هٰذِهٖٓ : یہ اُمَّتُكُمْ : تمہاری امت اُمَّةً وَّاحِدَةً : ایک امت، امت واحدہ وَّاَنَا : اور میں رَبُّكُمْ : تمہارا رب فَاتَّقُوْنِ : پس مجھ سے ڈرو یقیناً تمہارا یہ دین ایک ہی دین ہے 1 اور میں ہی تم سب کا رب ہوں، پس تم مجھ سے ڈرتے رہو۔
  23,53,فَتَقَطَّعُوْۤا اَمْرَهُمْ بَیْنَهُمْ زُبُرًا١ؕ كُلُّ حِزْبٍۭ بِمَا لَدَیْهِمْ فَرِحُوْنَ فَتَقَطَّعُوْٓا : پھر انہوں نے کاٹ لیا اَمْرَهُمْ : اپنا کام بَيْنَهُمْ : آپس میں زُبُرًا : ٹکڑے ٹکڑے كُلُّ حِزْبٍ : ہر گروہ بِمَا : اس پر جو لَدَيْهِمْ : ان کے پاس فَرِحُوْنَ : خوش پھر انہوں نے خود (ہی) اپنے امر (دین) کے آپس میں ٹکڑے ٹکڑے کر لئے، ہر گروہ جو کچھ اس کے پاس ہے اس پر اترا رہا ہے۔
  23,54,فَذَرْهُمْ فِیْ غَمْرَتِهِمْ حَتّٰى حِیْنٍ فَذَرْهُمْ : پس چھوڑ دے انہیں فِيْ غَمْرَتِهِمْ : ان کی غفلت میں حَتّٰى : تک حِيْنٍ : ایک مدت مقررہ پس آپ (بھی) انھیں انکی غفلت میں ہی کچھ مدت پڑا رہنے دیں۔ 2
  23,55,اَیَحْسَبُوْنَ اَنَّمَا نُمِدُّهُمْ بِهٖ مِنْ مَّالٍ وَّ بَنِیْنَۙ اَيَحْسَبُوْنَ : کیا وہ گمان کرتے ہیں اَنَّمَا : کہ جو کچھ نُمِدُّهُمْ : ہم مدد کر رہے ہیں ان کی بِهٖ : اس کے ساتھ مِنْ : سے مَّالٍ : مال وَّبَنِيْنَ : اور اولاد کیا یہ (یوں) سمجھ بیٹھے ہیں ؟ کہ ہم جو بھی ان کے مال و اولاد بڑھا رہے ہیں۔
  23,56,نُسَارِعُ لَهُمْ فِی الْخَیْرٰتِ١ؕ بَلْ لَّا یَشْعُرُوْنَ نُسَارِعُ : ہم جلدی کر رہے ہیں لَهُمْ : ان کے لیے فِي الْخَيْرٰتِ : بھلائی میں بَلْ : بلکہ لَّا يَشْعُرُوْنَ : وہ شعور (سمجھ) نہیں رکھتے وہ ان کے لئے بھلائیوں میں جلدی کر رہے ہیں (نہیں نہیں) بلکہ یہ سمجھتے ہی نہیں۔
  23,57,اِنَّ الَّذِیْنَ هُمْ مِّنْ خَشْیَةِ رَبِّهِمْ مُّشْفِقُوْنَۙ اِنَّ : بیشک الَّذِيْنَ : جو لوگ هُمْ : وہ مِّنْ : سے خَشْيَةِ : ڈر رَبِّهِمْ : اپنا رب مُّشْفِقُوْنَ : ڈرنے والے (سہمے ہوئے) یقیناً جو لوگ اپنے رب کی ہیبت سے ڈرتے ہیں۔
  23,58,وَ الَّذِیْنَ هُمْ بِاٰیٰتِ رَبِّهِمْ یُؤْمِنُوْنَۙ وَالَّذِيْنَ : اور جو لوگ هُمْ : وہ بِاٰيٰتِ : آیتوں پر رَبِّهِمْ : اپنا رب يُؤْمِنُوْنَ : ایمان رکھتے ہیں یقیناً جو لوگ اپنے رب کی آیتوں پر ایمان رکھتے ہیں۔
  23,59,وَ الَّذِیْنَ هُمْ بِرَبِّهِمْ لَا یُشْرِكُوْنَۙ وَالَّذِيْنَ : اور جو لوگ هُمْ : وہ بِرَبِّهِمْ : اپنے رب کے ساتھ لَا يُشْرِكُوْنَ : شریک نہیں کرتے اور جو اپنے رب کے ساتھ کسی کو شریک نہیں کرتے
