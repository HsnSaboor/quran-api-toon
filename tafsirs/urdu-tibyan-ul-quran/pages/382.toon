tafsir[8]{c,v,t}:
  27,56,فَمَا كَانَ جَوَابَ قَوْمِهٖۤ اِلَّاۤ اَنْ قَالُوْۤا اَخْرِجُوْۤا اٰلَ لُوْطٍ مِّنْ قَرْیَتِكُمْ١ۚ اِنَّهُمْ اُنَاسٌ یَّتَطَهَّرُوْنَ فَمَا : پس نہ كَانَ : تھا جَوَابَ : جواب قَوْمِهٖٓ : اس کی قوم اِلَّا اَنْ : مگر۔ صرف یہ کہ قَالُوْٓا : انہوں نے کہا اَخْرِجُوْٓا : نکال دو اٰلَ لُوْطٍ : لوط کے ساتھی مِّنْ : سے قَرْيَتِكُمْ : اپنا شہر اِنَّهُمْ : بیشک وہ اُنَاسٌ : لوگ يَّتَطَهَّرُوْنَ : پاکیزگی پسند کرتے ہیں قوم کا جواب بجز اس کہنے کہ اور کچھ نہ تھا کہ آل لوط کو اپنے شہر سے شہر بدر کردو، یہ تو بڑے پاکباز بن رہے ہیں 1
  27,57,فَاَنْجَیْنٰهُ وَ اَهْلَهٗۤ اِلَّا امْرَاَتَهٗ١٘ قَدَّرْنٰهَا مِنَ الْغٰبِرِیْنَ فَاَنْجَيْنٰهُ : سو ہم نے بچالیا وَاَهْلَهٗٓ : اور اس کے گھر والے اِلَّا : سوائے امْرَاَتَهٗ : اس کی بیوی قَدَّرْنٰهَا : ہم نے اسے ٹھہرا دیا تھا مِنَ : سے الْغٰبِرِيْنَ : پیچھے رہ جانے والے پس ہم نے اسے اور اس کے اہل کو بجز اس کی بیوی کے سب کو بچا لیا، اس کا اندازہ تو باقی رہ جانے والوں میں ہم لگا ہی چکے تھے 1۔
  27,58,وَ اَمْطَرْنَا عَلَیْهِمْ مَّطَرًا١ۚ فَسَآءَ مَطَرُ الْمُنْذَرِیْنَ۠ وَاَمْطَرْنَا : اور ہم نے برسائی عَلَيْهِمْ : ان پر مَّطَرًا : ایک بارش فَسَآءَ : سو کیا ہی برا مَطَرُ : بارش الْمُنْذَرِيْنَ : ڈرائے گئے اور ان پر ایک (خاص قسم کی) بارش برسادی 1 پس ان دھمکائے ہوئے لوگوں پر بری بارش ہوئی۔ 2
  27,59,قُلِ الْحَمْدُ لِلّٰهِ وَ سَلٰمٌ عَلٰى عِبَادِهِ الَّذِیْنَ اصْطَفٰى١ؕ آٰللّٰهُ خَیْرٌ اَمَّا یُشْرِكُوْنَؕ    ۧ قُلِ : فرما دیں الْحَمْدُ لِلّٰهِ : تمام تعریفیں اللہ کے لیے وَسَلٰمٌ : اور سلام عَلٰي عِبَادِهِ : اس کے بندوں پر الَّذِيْنَ : وہ جنہیں اصْطَفٰى : چن لیا آٰللّٰهُ : کیا اللہ خَيْرٌ : بہتر اَمَّا : یا جو يُشْرِكُوْنَ : وہ شریک ٹھہراتے ہیں تو کہہ دے کہ تمام تعریف اللہ ہی کے لئے ہے اور اس کے برگزیدہ بندوں پر سلام ہے 1 کیا اللہ تعالیٰ بہتر ہے یا وہ جنہیں یہ لوگ شریک ٹھہرا رہے ہیں۔ 2
  27,60,اَمَّنْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ وَ اَنْزَلَ لَكُمْ مِّنَ السَّمَآءِ مَآءً١ۚ فَاَنْۢبَتْنَا بِهٖ حَدَآئِقَ ذَاتَ بَهْجَةٍ١ۚ مَا كَانَ لَكُمْ اَنْ تُنْۢبِتُوْا شَجَرَهَا١ؕ ءَاِلٰهٌ مَّعَ اللّٰهِ١ؕ بَلْ هُمْ قَوْمٌ یَّعْدِلُوْنَؕ اَمَّنْ : بھلا کون خَلَقَ : پیدا کیا السَّمٰوٰتِ : آسمانوں وَالْاَرْضَ : اور زمین وَاَنْزَلَ : اور اتارا لَكُمْ : تمہارے لیے مِّنَ : سے السَّمَآءِ : آسمان مَآءً : پانی فَاَنْۢبَتْنَا : پس اگائے ہم نے بِهٖ : اس سے حَدَآئِقَ : باغ (جمع) ذَاتَ بَهْجَةٍ : بارونق مَا كَانَ : نہ تھا لَكُمْ : تمہارے لیے اَنْ تُنْۢبِتُوْا : کہ تم اگاؤ شَجَرَهَا : ان کے درخت ءَاِلٰهٌ : کیا کوئی معبود مَّعَ اللّٰهِ : اللہ کے ساتھ بَلْ : بلکہ هُمْ : وہ قَوْمٌ : لوگ يَّعْدِلُوْنَ : کج روی کرتے ہیں بھلا بتاؤ ؟ کہ آسمانوں کو اور زمین کو کس نے پیدا کیا ؟ کس نے آسمان سے بارش برسائی ؟ پھر اس سے ہرے بھرے بارونق باغات اگائے ؟ ان باغوں کے درختوں کو تم ہرگز نہ اگا سکتے، 1 کیا اللہ کے ساتھ اور کوئی معبود بھی ہے ؟ 2 بلکہ یہ لوگ ہٹ جاتے ہیں 3 (سیدھی راہ سے)۔
  27,61,اَمَّنْ جَعَلَ الْاَرْضَ قَرَارًا وَّ جَعَلَ خِلٰلَهَاۤ اَنْهٰرًا وَّ جَعَلَ لَهَا رَوَاسِیَ وَ جَعَلَ بَیْنَ الْبَحْرَیْنِ حَاجِزًا١ؕ ءَاِلٰهٌ مَّعَ اللّٰهِ١ؕ بَلْ اَكْثَرُهُمْ لَا یَعْلَمُوْنَؕ اَمَّنْ : بھلا کون کس جَعَلَ : بنایا الْاَرْضَ : زمین قَرَارًا : قرار گاہ وَّجَعَلَ : اور (جاری) کیا خِلٰلَهَآ : اس کے درمیان اَنْهٰرًا : ندی نالے وَّجَعَلَ : اور (پیدا) کیے لَهَا : اس کے لیے رَوَاسِيَ : پہاڑ (جمع) وَجَعَلَ : اور بنایا بَيْنَ : درمیان الْبَحْرَيْنِ : دو دریا حَاجِزًا : آڑ (حد فاصل) ءَ اِلٰهٌ : کیا کوئی معبود مَّعَ اللّٰهِ : اللہ کے ساتھ بَلْ : بلکہ اَكْثَرُهُمْ : ان کے اکثر لَا يَعْلَمُوْنَ : نہیں جانتے کیا وہ جس نے زمین کو قرار گاہ بنایا 1 اور اس کے درمیان نہریں جاری کردیں اور اس کے لئے پہاڑ بنائے اور دو سمندروں کے درمیان روک بنادی 2 کیا اللہ کے ساتھ اور کوئی معبود بھی ہے ؟ بلکہ ان میں سے اکثر کچھ جانتے ہی نہیں۔
  27,62,اَمَّنْ یُّجِیْبُ الْمُضْطَرَّ اِذَا دَعَاهُ وَ یَكْشِفُ السُّوْٓءَ وَ یَجْعَلُكُمْ خُلَفَآءَ الْاَرْضِ١ؕ ءَاِلٰهٌ مَّعَ اللّٰهِ١ؕ قَلِیْلًا مَّا تَذَكَّرُوْنَؕ اَمَّنْ : بھلا کون يُّجِيْبُ : قبول کرتا ہے الْمُضْطَرَّ : بیقرار اِذَا : جب دَعَاهُ : وہ اسے پکارتا ہے وَيَكْشِفُ : اور دور کرتا ہے السُّوْٓءَ : برائی وَيَجْعَلُكُمْ : اور تمہیں بناتا ہے خُلَفَآءَ : نائب (جمع) الْاَرْضِ : زمین ءَاِلٰهٌ : کیا کوئی معبود مَّعَ اللّٰهِ : اللہ کے ساتھ قَلِيْلًا : تھوڑے مَّا : جو تَذَكَّرُوْنَ : نصیحت پکڑتے ہیں بےکس کی پکار کو جب کہ وہ پکارے، کون قبول کر کے سختی کو دور کردیتا ہے 1 اور تمہیں زمین کا خلیفہ بنانا ہے 2 کیا اللہ تعالیٰ کے ساتھ اور معبود ہے ؟ تم بہت کم نصیحت و عبرت حاصل کرتے ہو۔
  27,63,اَمَّنْ یَّهْدِیْكُمْ فِیْ ظُلُمٰتِ الْبَرِّ وَ الْبَحْرِ وَ مَنْ یُّرْسِلُ الرِّیٰحَ بُشْرًۢا بَیْنَ یَدَیْ رَحْمَتِهٖ١ؕ ءَاِلٰهٌ مَّعَ اللّٰهِ١ؕ تَعٰلَى اللّٰهُ عَمَّا یُشْرِكُوْنَؕ اَمَّنْ : بھلا کون يَّهْدِيْكُمْ : تمہیں راہ دکھاتا ہے فِيْ ظُلُمٰتِ : اندھیروں میں الْبَرِّ : خشکی وَالْبَحْرِ : اور سمندر وَ : اور مَنْ : کون يُّرْسِلُ : چلاتا ہے الرِّيٰحَ : ہوائیں بُشْرًۢا : خوشخبری دینے والی بَيْنَ يَدَيْ : پہلے رَحْمَتِهٖ : اس کی رحمت ءَاِلٰهٌ : کیا کوئی معبود مَّعَ اللّٰهِ : اللہ کے ساتھ تَعٰلَى اللّٰهُ : برتر ہے اللہ عَمَّا : اس سے جو يُشْرِكُوْنَ : وہ شریک ٹھہراتے ہیں کیا وہ جو تمہیں خشکی اور تری کی تاریکیوں میں راہ دکھاتا ہے 1 اور جو اپنی رحمت سے پہلے ہی خوشخبریاں دینے والی ہوائیں چلاتا ہے 2 کیا اللہ کے ساتھ کوئی اور معبود بھی ہے جنہیں یہ شریک کرتے ہیں ان سب سے اللہ بلند وبالا تر ہے۔
