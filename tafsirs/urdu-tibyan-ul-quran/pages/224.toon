tafsir[9]{c,v,t}:
  11,20,اُولٰٓئِكَ لَمْ یَكُوْنُوْا مُعْجِزِیْنَ فِی الْاَرْضِ وَ مَا كَانَ لَهُمْ مِّنْ دُوْنِ اللّٰهِ مِنْ اَوْلِیَآءَ١ۘ یُضٰعَفُ لَهُمُ الْعَذَابُ١ؕ مَا كَانُوْا یَسْتَطِیْعُوْنَ السَّمْعَ وَ مَا كَانُوْا یُبْصِرُوْنَ اُولٰٓئِكَ : یہ لوگ لَمْ يَكُوْنُوْا : نہیں ہیں مُعْجِزِيْنَ : عاجز کرنیوالے، تھکانے والے فِي الْاَرْضِ : زمین میں وَمَا كَانَ : اور نہیں ہے لَهُمْ : ان کے لیے مِّنْ : سے دُوْنِ : سوا اللّٰهِ : اللہ مِنْ : کوئی اَوْلِيَآءَ : حمایتی يُضٰعَفُ : دوگنا لَهُمُ : ان کے لیے الْعَذَابُ : عذاب مَا : نہ كَانُوْا يَسْتَطِيْعُوْنَ : وہ طاقت رکھتے تھے السَّمْعَ : سننا وَمَا : اور نہ كَانُوْا يُبْصِرُوْنَ : وہ دیکھتے تھے نہ یہ لوگ دنیا میں اللہ کو ہرا سکے اور نہ ان کا کوئی حمائتی اللہ کے سوا ہوا، ان کے لئے عذاب دگنا کیا جائے گا نہ یہ سننے کی طاقت رکھتے تھے اور نہ دیکھتے ہی تھے (1)۔
  11,21,اُولٰٓئِكَ الَّذِیْنَ خَسِرُوْۤا اَنْفُسَهُمْ وَ ضَلَّ عَنْهُمْ مَّا كَانُوْا یَفْتَرُوْنَ اُولٰٓئِكَ : یہی لوگ الَّذِيْنَ : وہ جنہوں نے خَسِرُوْٓا : نقصان کیا اَنْفُسَهُمْ : اپنی جانوں کا (اپنا) وَضَلَّ : اور گم ہوگیا عَنْهُمْ : ان سے مَّا : جو كَانُوْا يَفْتَرُوْنَ : وہ افترا کرتے تھے (جھوٹ باندھتے تھے) یہی ہیں جنہوں نے اپنا نقصان آپ کرلیا اور وہ سب کچھ ان سے کھو گیا، جو انہوں نے گھڑ رکھا تھا۔
  11,22,لَا جَرَمَ اَنَّهُمْ فِی الْاٰخِرَةِ هُمُ الْاَخْسَرُوْنَ لَا جَرَمَ : شک نہیں اَنَّهُمْ : کہ وہ فِي الْاٰخِرَةِ : آخرت میں هُمُ : وہ الْاَخْسَرُوْنَ : سب سے زیادہ نقصان اٹھانے والے بیشک یہ لوگ آخرت میں زیاں کار ہوں گے۔
  11,23,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ وَ اَخْبَتُوْۤا اِلٰى رَبِّهِمْ١ۙ اُولٰٓئِكَ اَصْحٰبُ الْجَنَّةِ١ۚ هُمْ فِیْهَا خٰلِدُوْنَ اِنَّ : بیشک الَّذِيْنَ : جو لوگ اٰمَنُوْا : ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : نیک وَاَخْبَتُوْٓا : اور عاجزی کی اِلٰي رَبِّهِمْ : اپنے رب کے آگے اُولٰٓئِكَ : یہی لوگ اَصْحٰبُ الْجَنَّةِ : جنت والے هُمْ : وہ فِيْهَا : اس میں خٰلِدُوْنَ : ہمیشہ رہیں گے یقیناً جو لوگ ایمان لائے اور انہوں نے کام بھی نیک کئے اور اپنے پالنے والے کی طرف جھکتے رہے، وہی جنت میں جانے والے ہیں، جہاں وہ ہمیشہ ہی رہنے والے ہیں۔
  11,24,مَثَلُ الْفَرِیْقَیْنِ كَالْاَعْمٰى وَ الْاَصَمِّ وَ الْبَصِیْرِ وَ السَّمِیْعِ١ؕ هَلْ یَسْتَوِیٰنِ مَثَلًا١ؕ اَفَلَا تَذَكَّرُوْنَ۠    ۧ مَثَلُ : مثال الْفَرِيْقَيْنِ : دونوں فریق كَالْاَعْمٰى : جیسے اندھا وَالْاَصَمِّ : اور بہرا وَالْبَصِيْرِ : اور دیکھتا وَالسَّمِيْعِ : اور سنتا هَلْ يَسْتَوِيٰنِ : کیا دونوں برابر ہیں مَثَلًا : مثال (حالت) میں اَفَلَا تَذَكَّرُوْنَ : کیا تم غور نہیں کرتے ان دونوں فرقوں کی مثال اندھے، بہرے اور دیکھنے، سننے والے جیسی ہے (1) کیا یہ دونوں مثال میں برابر ہیں ؟ کیا پھر بھی تم نصیحت حاصل نہیں کرتے۔
  11,25,وَ لَقَدْ اَرْسَلْنَا نُوْحًا اِلٰى قَوْمِهٖۤ١٘ اِنِّیْ لَكُمْ نَذِیْرٌ مُّبِیْنٌۙ وَلَقَدْ اَرْسَلْنَا : ہم نے بھیجا نُوْحًا : نوح اِلٰي : طرف قَوْمِهٖٓ : اس کی قوم اِنِّىْ : بیشک میں لَكُمْ : تمہارے لیے نَذِيْرٌ : ڈرانے والا مُّبِيْنٌ : کھلا یقیناً ہم نے نوح ؑ کو اس کی قوم کی طرف رسول بنا کر بھیجا کہ میں تمہیں صاف صاف ہوشیار کردینے والا ہوں۔
  11,26,اَنْ لَّا تَعْبُدُوْۤا اِلَّا اللّٰهَ١ؕ اِنِّیْۤ اَخَافُ عَلَیْكُمْ عَذَابَ یَوْمٍ اَلِیْمٍ اَنْ : کہ لَّا تَعْبُدُوْٓا : نہ پرستش کرو تم اِلَّا : سوائے اللّٰهَ : اللہ اِنِّىْٓ اَخَافُ : بیشک میں ڈرتا ہوں عَلَيْكُمْ : تم پر عَذَابَ : عذاب يَوْمٍ اَلِيْمٍ : دکھ دینے والا دن کہ تم صرف اللہ ہی کی عبادت کرو (1) مجھے تو تم پر دردناک دن کے عذاب کا خوف ہے (2)۔
  11,27,فَقَالَ الْمَلَاُ الَّذِیْنَ كَفَرُوْا مِنْ قَوْمِهٖ مَا نَرٰىكَ اِلَّا بَشَرًا مِّثْلَنَا وَ مَا نَرٰىكَ اتَّبَعَكَ اِلَّا الَّذِیْنَ هُمْ اَرَاذِلُنَا بَادِیَ الرَّاْیِ١ۚ وَ مَا نَرٰى لَكُمْ عَلَیْنَا مِنْ فَضْلٍۭ بَلْ نَظُنُّكُمْ كٰذِبِیْنَ فَقَالَ : تو بولے الْمَلَاُ : سردار الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) مِنْ قَوْمِهٖ : اس کی قوم کے مَا نَرٰىكَ : ہم نہیں دیکھتے تجھے اِلَّا : مگر بَشَرًا : ایک آدمی مِّثْلَنَا : ہمارے اپنے جیسا وَ : اور مَا نَرٰىكَ : ہم نہیں دیکھتے تجھے اتَّبَعَكَ : تیری پیروی کریں اِلَّا : سوائے الَّذِيْنَ : وہ لوگ جو هُمْ : وہ اَرَاذِلُنَا : نیچ لوگ ہم میں بَادِيَ الرَّاْيِ : سرسری نظر سے وَمَا : اور نہیں نَرٰي : ہم دیکھتے لَكُمْ : تمہارے لیے عَلَيْنَا : ہم پر مِنْ : کوئی فَضْلٍ : فضیلت بَلْ نَظُنُّكُمْ : بلکہ ہم خیال کرتے ہیں تمہیں كٰذِبِيْنَ : جھوٹے اس کی قوم کے کافروں کے سرداروں نے جواب دیا کہ ہم تو تجھے اپنے جیسا انسان ہی دیکھتے ہیں (1) اور تیرے تابعداروں کو بھی ہم دیکھتے ہیں کہ یہ لوگ واضح طور پر سوائے نیچ (2) لوگوں کے (3) اور کوئی نہیں جو بےسوچے سمجھے (تمہاری پیروی کر رہے ہیں) ہم تو تمہاری کسی قسم کی برتری اپنے اوپر نہیں دیکھ رہے، بلکہ ہم تو تمہیں جھوٹا سمجھ رہے ہیں۔
  11,28,قَالَ یٰقَوْمِ اَرَءَیْتُمْ اِنْ كُنْتُ عَلٰى بَیِّنَةٍ مِّنْ رَّبِّیْ وَ اٰتٰىنِیْ رَحْمَةً مِّنْ عِنْدِهٖ فَعُمِّیَتْ عَلَیْكُمْ١ؕ اَنُلْزِمُكُمُوْهَا وَ اَنْتُمْ لَهَا كٰرِهُوْنَ قَالَ : اس نے کہا يٰقَوْمِ : اے میری قوم اَرَءَيْتُمْ : تم دیکھو تو اِنْ : اگر كُنْتُ : میں ہوں عَلٰي : پر بَيِّنَةٍ : واضح دلیل مِّنْ رَّبِّيْ : اپنے رب سے وَاٰتٰىنِيْ : اور اس نے دی مجھے رَحْمَةً : رحمت مِّنْ عِنْدِهٖ : اپنے پاس سے فَعُمِّيَتْ : وہ دکھائی نہیں دیتی عَلَيْكُمْ : تمہیں اَنُلْزِمُكُمُوْهَا : کیا ہم وہ تمہیں زبردستی منوائیں وَاَنْتُمْ : اور تم لَهَا : اس سے كٰرِهُوْنَ : بیزار ہو نوح نے کہا میری قوم والو ! مجھے بتاؤ تو اگر میں اپنے رب کی طرف سے دلیل پر ہوا اور مجھے اس نے اپنے پاس کی کوئی رحمت عطا کی ہو (1) پھر وہ تمہاری نگاہوں میں (2) نہ آئی تو کیا یہ زبردستی میں اسے تمہارے گلے منڈھ دوں حالانکہ تم اس سے بیزار ہو (3)۔
