tafsir[15]{c,v,t}:
  20,99,كَذٰلِكَ نَقُصُّ عَلَیْكَ مِنْ اَنْۢبَآءِ مَا قَدْ سَبَقَ١ۚ وَ قَدْ اٰتَیْنٰكَ مِنْ لَّدُنَّا ذِكْرًاۖۚ كَذٰلِكَ : اسی طرح نَقُصُّ : ہم بیان کرتے ہیں عَلَيْكَ : تجھ پر۔ سے مِنْ : سے اَنْۢبَآءِ : خبریں، احوال مَا : جو قَدْ سَبَقَ : گزر چکا وَقَدْ اٰتَيْنٰكَ : اور تحقیق ہم نے تمہیں دیا مِنْ لَّدُنَّا : اپنے پاس سے ذِكْرًا : (کتاب) نصیحت اس طرح ہم تیرے سامنے (1) پہلے کی گزری ہوئی وارداتیں بیان فرما رہے ہیں اور یقیناً ہم تجھے اپنے پاس سے نصیحت عطا فرما چکے ہیں (2)۔
  20,100,مَنْ اَعْرَضَ عَنْهُ فَاِنَّهٗ یَحْمِلُ یَوْمَ الْقِیٰمَةِ وِزْرًاۙ مَنْ : جس اَعْرَضَ : منہ پھیرا عَنْهُ : اس سے فَاِنَّهٗ : تو بیشک وہ يَحْمِلُ : لادے گا يَوْمَ الْقِيٰمَةِ : قیامت کے دن وِزْرًا : (بھاری) بوجھ اس سے جو منہ پھیر لے گا (1) وہ یقیناً قیامت کے دن اپنا بھاری بوجھ لادے ہوئے ہوگا (2)۔
  20,101,خٰلِدِیْنَ فِیْهِ١ؕ وَ سَآءَ لَهُمْ یَوْمَ الْقِیٰمَةِ حِمْلًاۙ خٰلِدِيْنَ : وہ ہمیشہ رہیں گے فِيْهِ : اس میں وَسَآءَ : اور برا ہے لَهُمْ : ان کے لیے يَوْمَ الْقِيٰمَةِ : قیامت کے دن حِمْلًا : بوجھھ جس میں ہمیشہ رہے گا (1) اور ان کے لئے قیامت کے دن (بڑا) برا بوجھ ہے
  20,102,یَّوْمَ یُنْفَخُ فِی الصُّوْرِ وَ نَحْشُرُ الْمُجْرِمِیْنَ یَوْمَئِذٍ زُرْقًاۚۖ يَّوْمَ : جس دن يُنْفَخُ : پھونک ماری جائیگی فِي الصُّوْرِ : صور میں وَنَحْشُرُ : اور ہم اکٹھا کرینگے الْمُجْرِمِيْنَ : مجرموں کو يَوْمَئِذٍ : اس دن زُرْقًا : نیلی آنکھیں جس دن صور پھونکا جائیگا (1) اور گناہ گاروں کو ہم اس دن (دہشت کی وجہ سے) نیلی پیلی آنکھوں کے ساتھ گھیر لائیں گے
  20,103,یَّتَخَافَتُوْنَ بَیْنَهُمْ اِنْ لَّبِثْتُمْ اِلَّا عَشْرًا يَّتَخَافَتُوْنَ : آہستہ آہستہ کہیں گے بَيْنَهُمْ : آپس میں اِنْ : نہیں لَّبِثْتُمْ : رہے تم اِلَّا : مگر (صرف) عَشْرًا : دس دن وہ آپس میں چپکے چپکے کہہ رہے (1) ہونگے کہ ہم تو (دنیا میں) صرف دس دن ہی رہے۔
  20,104,نَحْنُ اَعْلَمُ بِمَا یَقُوْلُوْنَ اِذْ یَقُوْلُ اَمْثَلُهُمْ طَرِیْقَةً اِنْ لَّبِثْتُمْ اِلَّا یَوْمًا۠    ۧ نَحْنُ : ہم اَعْلَمُ : خوب جانتے ہیں بِمَا : وہ جو يَقُوْلُوْنَ : وہ کہتے ہیں اِذْ يَقُوْلُ : جب کہے گا اَمْثَلُهُمْ : سب سے اچھی طَرِيْقَةً : راہ اِنْ : نہیں لَّبِثْتُمْ : رہے تم اِلَّا : مگر (صرف) يَوْمًا : ایک دن جو کچھ وہ کہہ رہے ہیں اس کی حقیقت سے ہم باخبر ہیں ان میں سب سے زیادہ اچھی رائے (1) والا کہہ رہا ہوگا کہ تم صرف ایک ہی دن دنیا میں رہے۔
  20,105,وَ یَسْئَلُوْنَكَ عَنِ الْجِبَالِ فَقُلْ یَنْسِفُهَا رَبِّیْ نَسْفًاۙ وَيَسْئَلُوْنَكَ : اور وہ آپ سے دریافت کرینگے عَنِ الْجِبَالِ : پہاڑ کے متعلق فَقُلْ : تو کہ دیں يَنْسِفُهَا : انہیں بکھیر دیگا رَبِّيْ : میرا رب نَسْفًا : اڑا کر وہ آپ سے پہاڑوں کی نسبت سوال کرتے ہیں، تو آپ کہہ دیں کہ انھیں میرا رب ریزہ ریزہ کرکے اڑا دے گا۔
  20,106,فَیَذَرُهَا قَاعًا صَفْصَفًاۙ فَيَذَرُهَا : پھر اسے چھوڑ دیگا قَاعًا : میدان صَفْصَفًا : ایک ہموار اور زمین کو بالکل ہموار صاف میدان کرکے چھوڑے گا۔
  20,107,لَّا تَرٰى فِیْهَا عِوَجًا وَّ لَاۤ اَمْتًاؕ لَّا تَرٰى : نہ دیکھے گا تو فِيْهَا : اس میں عِوَجًا : کوئی کجی وَّلَآ : اور نہ اَمْتًا : کوئی بلندی جس میں تو نہ کہیں موڑ توڑ دیکھے گا، نہ اونچ نیچ۔
  20,108,یَوْمَئِذٍ یَّتَّبِعُوْنَ الدَّاعِیَ لَا عِوَجَ لَهٗ١ۚ وَ خَشَعَتِ الْاَصْوَاتُ لِلرَّحْمٰنِ فَلَا تَسْمَعُ اِلَّا هَمْسًا يَوْمَئِذٍ : اس دن يَّتَّبِعُوْنَ : وہ سب پیچھے چلیں گے الدَّاعِيَ : ایک پکارنے والا لَا عِوَجَ : نہیں کوئی کجی لَهٗ : اس کے لیے وَخَشَعَتِ : اور پست ہوجائیں گی الْاَصْوَاتُ : آوازیں لِلرَّحْمٰنِ : اللہ کیلئے۔ سامنے فَلَا تَسْمَعُ : پس تو نہ سنے گا اِلَّا : مگر (صرف) هَمْسًا : آہستہ آواز جس دن لوگ پکارنے والے کے پیچھے چلیں (1) گے جس میں کوئی کجی نہ ہوگی (2) اور اللہ رحمٰن کے سامنے تمام آوازیں پست ہوجائیں گی سوائے کھسر پھسر کے تجھے کچھ بھی سنائی نہ دے گا (3)۔
  20,109,یَوْمَئِذٍ لَّا تَنْفَعُ الشَّفَاعَةُ اِلَّا مَنْ اَذِنَ لَهُ الرَّحْمٰنُ وَ رَضِیَ لَهٗ قَوْلًا يَوْمَئِذٍ : اس دن لَّا تَنْفَعُ : نہ نفع دے گی الشَّفَاعَةُ : کوئی شفاعت اِلَّا : مگر مَنْ : جس اَذِنَ لَهُ : اجازت دے اس کو الرَّحْمٰنُ : اللہ وَرَضِيَ : اور پسند کرے لَهٗ : اس کی قَوْلًا : بات اس دن سفارش کچھ کام نہ آئیگی مگر جسے رحمٰن حکم دے اور اس کی بات کو پسند فرمائے (1)
  20,110,یَعْلَمُ مَا بَیْنَ اَیْدِیْهِمْ وَ مَا خَلْفَهُمْ وَ لَا یُحِیْطُوْنَ بِهٖ عِلْمًا يَعْلَمُ : وہ جانتا ہے مَا : جو بَيْنَ اَيْدِيْهِمْ : ان کے ہاتھوں کے درمیان ( آگے) وَمَا : اور جو خَلْفَهُمْ : ان کے پیچھے وَلَا يُحِيْطُوْنَ : اور وہ احاطہ نہیں کرسکتے بِهٖ : اس کا عِلْمًا : علم کے اندر جو کچھ ان کے آگے پیچھے ہے اسے اللہ ہی جانتا ہے مخلوق کا علم اس پر حاوی نہیں ہوسکتا۔ (1)
  20,111,وَ عَنَتِ الْوُجُوْهُ لِلْحَیِّ الْقَیُّوْمِ١ؕ وَ قَدْ خَابَ مَنْ حَمَلَ ظُلْمًا وَعَنَتِ : جھک جائیں گے الْوُجُوْهُ : چہرے لِلْحَيِّ : سامنے ” حی “ الْقَيُّوْمِ :” قیوم “ وَقَدْ خَابَ : اور نامراد ہوا مَنْ : جو۔ جس حَمَلَ : بوجھ اٹھایا ظُلْمًا : ظلم تمام چہرے اس زندہ اور قائم دائم اور مدبر، اللہ کے سامنے کمال عاجزی سے جھکے ہوئے ہونگے، یقیناً وہ برباد ہوا جس نے ظلم لاد لیا (1)
  20,112,وَ مَنْ یَّعْمَلْ مِنَ الصّٰلِحٰتِ وَ هُوَ مُؤْمِنٌ فَلَا یَخٰفُ ظُلْمًا وَّ لَا هَضْمًا وَمَنْ : اور جو يَّعْمَلْ : کرے مِنَ : سے۔ کوئی الصّٰلِحٰتِ وَ : نیکی اور (بشرطیکہ) هُوَ : وہ مُؤْمِنٌ : مومن فَلَا يَخٰفُ : تو نہ اسے خوف ہوگا ظُلْمًا : کسی ظلم کا وَّلَا هَضْمًا : اور نہ کسی نقصان کا اور جو نیک اعمال کرے اور ایمان دار بھی ہو تو نہ اسے بےانصافی کا کھٹکا ہوگا نہ حق تلفی کا (1)
  20,113,وَ كَذٰلِكَ اَنْزَلْنٰهُ قُرْاٰنًا عَرَبِیًّا وَّ صَرَّفْنَا فِیْهِ مِنَ الْوَعِیْدِ لَعَلَّهُمْ یَتَّقُوْنَ اَوْ یُحْدِثُ لَهُمْ ذِكْرًا وَكَذٰلِكَ : اور اسی طرح اَنْزَلْنٰهُ : ہم نے اس پر نازل کیا قُرْاٰنًا : قرآن عَرَبِيًّا : عربی وَّصَرَّفْنَا فِيْهِ : اور ہم نے طرح طرح سے بیان کیے اس میں مِنَ : سے الْوَعِيْدِ : ڈراوے لَعَلَّهُمْ : تاکہ وہ يَتَّقُوْنَ : پرہیزگار ہوجائیں اَوْ يُحْدِثُ : یا وہ پیدا کردے لَهُمْ : ان کے لیے ذِكْرًا : کوئی نصیحت اس طرح ہم نے تجھ پر عربی میں قرآن نازل فرمایا ہے اور طرح طرح سے اس میں ڈر کا بیان سنایا ہے تاکہ لوگ پرہیزگار بن (1) جائیں یا ان کے دل میں سوچ سمجھ تو پیدا کرے (2)
